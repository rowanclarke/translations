\id NUM - Biblica® Open Igbo Contemporary Bible 2020 
\h Ọnụọgụgụ 
\toc1 Ọnụọgụgụ 
\toc2 Ọnụọgụgụ 
\toc3 Ọnụ 
\mt1 Ọnụọgụgụ 
\c 1  
\s1 Ịgụ ọnụ 
\p  
\v 1 \nd Onyenwe anyị\nd* gwara Mosis okwu nʼọzara Saịnaị, nʼime ụlọ nzute, nʼụbọchị nke mbụ,\f + \fr 1:1 \ft Nke a bụ otu ọnwa site nʼoge ụmụ Izrel si Ijipt rute nʼọzara Saịnaị, \xt Ọpụ 9:1\ft  otu ọnwa mgbe arụchara ụlọ nzute ahụ nʼọzara, \xt Ọpụ 40:17\ft  bụrụkwa mgbe abalị iri na ise gafesịrị site nʼoge ha mere ncheta Mmemme Ngabiga nʼọzara Saịnaị.\f* nʼọnwa nke abụọ nke afọ abụọ, mgbe ụmụ Izrel pụtachara site nʼobodo Ijipt. Ọ sịrị,  
\v 2 “Gaa gụọ ma chọpụta ọnụọgụgụ ndị ikom niile e nwere nʼetiti ọgbakọ Izrel, dịka ebo ha na agbụrụ ha si dị, na dịka ezinaụlọ ha si dịkwa. Depụta aha nwoke ọbụla nʼotu na otu.  
\v 3 Gị na Erọn ga-agụkọta ndị ikom Izrel niile gbara iri afọ abụọ maọbụ karịa ọnụ, bụ ndị tozuru ije agha. Unu ga-edo ha nʼusuu, nʼusuu.  
\v 4 Otu nwoke, site nʼebo Izrel ọbụla, onye bụ onyendu ezinaụlọ, ga-esonyere unu nʼọrụ a. 
\b  
\li4  
\v 5 “Ndị a bụ aha ndị ikom ndị ahụ ga-enyere unu aka. 
\b  
\li1 “Site nʼebo Ruben, Elizọ na Shedeua, 
\li1  
\v 6 site nʼebo Simiọn, Shelumiel nwa Zurishadai, 
\li1  
\v 7 site nʼebo Juda, Nashọn nwa Aminadab, 
\li1  
\v 8 site nʼebo Isaka, Netanel nwa Zua, 
\li1  
\v 9 site nʼebo Zebụlọn, Eliab nwa Helọn, 
\li1  
\v 10 Site nʼụmụ Josef: 
\li2 site nʼebo Ifrem, Elishama nwa Amihud 
\li2 site nʼebo Manase, Gamaliel nwa Pedazo 
\li1  
\v 11 site nʼebo Benjamin, Abidan nwa Gidiọn 
\li1  
\v 12 site nʼebo Dan, Ahieza nwa Amishadai 
\li1  
\v 13 site nʼebo Asha, Pagịel nwa Okran 
\li1  
\v 14 site nʼebo Gad, Eliasaf nwa Deuel 
\li1  
\v 15 site nʼebo Naftalị, Ahira nwa Enan.” 
\b  
\li4  
\v 16 Ndị a bụ ndị ikom e si nʼọgbakọ ahụ họpụta, ndị bụ ndị ndu ebo dị iche iche nʼIzrel. Ha bụ ndị ndu ebo niile dị nʼIzrel. 
\b  
\p  
\v 17 Mosis na Erọn nabatara ndị ikom ndị a, bụ ndị e depụtara aha ha.  
\v 18 Emesịa, ha kpọrọ nzukọ ndị Izrel niile ka ha zukọọ nʼụbọchị mbụ nke ọnwa abụọ. Ndị niile zukọrọ kọwara ikwu ha na ezinaụlọ ha si pụta nʼotu na otu. Ma ndị ikom niile gbara site nʼiri afọ abụọ gbagoo ka e denyere aha ha nʼakwụkwọ nʼotu na otu,  
\v 19 dịka \nd Onyenwe anyị\nd* si nye Mosis nʼiwu. Otu a kwa ka Mosis si gụọ ha ọnụ nʼọzara Saịnaị. 
\b  
\li1  
\v 20 Ụmụ Ruben, bụ ọkpara Izrel: Ndị ikom niile gbara iri afọ abụọ gbagoo; ndị tozuru ije agha ka e dere aha ha nʼusoro nʼotu nʼotu dịka ikwu ha na ezinaụlọ ha si dị.  
\v 21 Ọnụọgụgụ ndị niile si nʼebo Ruben dị iri puku anọ, puku isii na narị ise (46,500). 
\b  
\li1  
\v 22 Site nʼụmụ Simiọn, ndị ikom niile gbara iri afọ abụọ gbagoo, ndị tozuru ije agha ka e dere aha ha nʼusoro nʼotu nʼotu dịka ikwu ha na ezinaụlọ ha si dị.  
\v 23 Ọnụọgụgụ ndị niile sị nʼebo Simiọn dị iri puku ise, puku itoolu na narị atọ (59,300). 
\b  
\li1  
\v 24 Site nʼụmụ Gad, ndị ikom niile gbara iri afọ abụọ gbagoo, ndị tozuru ije agha ka e dere aha ha nʼusoro nʼotu nʼotu dịka ikwu ha na ezinaụlọ ha si dị.  
\v 25 Ọnụọgụgụ ndị niile sị nʼebo Gad dị iri puku anọ, puku ise na narị isii na iri ise (45,650). 
\b  
\li1  
\v 26 Site nʼụmụ Juda, ndị ikom niile gbara iri afọ abụọ gbagoo, ndị tozuru ije agha ka e dere aha ha nʼusoro nʼotu nʼotu dịka ikwu ha na ezinaụlọ ha si dị.  
\v 27 Ọnụọgụgụ ndị niile sị nʼebo Juda dị iri puku asaa, puku anọ na narị isii (74,600). 
\b  
\li1  
\v 28 Site nʼụmụ Isaka, ndị ikom niile gbara iri afọ abụọ gbagoo, ndị tozuru ije agha ka e dere aha ha nʼusoro nʼotu nʼotu dịka ikwu ha na ezinaụlọ ha si dị.  
\v 29 Ọnụọgụgụ ndị niile sị nʼebo Isaka dị iri puku ise, puku anọ na narị anọ (54,400). 
\b  
\li1  
\v 30 Site nʼụmụ Zebụlọn, ndị ikom niile gbara iri afọ abụọ gbagoo, ndị tozuru ije agha ka e dere aha ha nʼusoro nʼotu nʼotu dịka ikwu ha na ezinaụlọ ha si dị.  
\v 31 Ọnụọgụgụ ndị niile sị nʼebo Zebụlọn dị iri puku ise, puku asaa na narị anọ (57,400). 
\b  
\li4  
\v 32 Site nʼụmụ Josef, ya bụ ụmụ Ifrem, ndị ikom niile gbara iri afọ abụọ gbagoo, ndị tozuru ije agha ka e dere aha ha nʼusoro nʼotu nʼotu dịka ikwu ha na ezinaụlọ ha si dị.  
\v 33 Ọnụọgụgụ ndị niile sị nʼebo Ifrem dị iri puku anọ na narị ise (40,500). 
\li1  
\v 34 Site nʼụmụ Manase, ndị ikom niile gbara iri afọ abụọ gbagoo, ndị tozuru ije agha ka e dere aha ha nʼusoro nʼotu nʼotu dịka ikwu ha na ezinaụlọ ha si dị.  
\v 35 Ọnụọgụgụ ndị niile sị nʼebo Manase dị iri puku atọ, puku abụọ na narị abụọ (32,200). 
\b  
\li1  
\v 36 Site nʼụmụ Benjamin, ndị ikom niile gbara iri afọ abụọ gbagoo, ndị tozuru ije agha ka e dere aha ha nʼusoro nʼotu nʼotu dịka ikwu ha na ezinaụlọ ha si dị.  
\v 37 Ọnụọgụgụ ndị niile sị nʼebo Benjamin dị iri puku atọ, puku ise na narị anọ (35,400). 
\b  
\li1  
\v 38 Site nʼụmụ Dan, ndị ikom niile gbara iri afọ abụọ gbagoo, ndị tozuru ije agha ka e dere aha ha nʼusoro nʼotu nʼotu dịka ikwu ha na ezinaụlọ ha si dị.  
\v 39 Ọnụọgụgụ ndị niile sị nʼebo Dan dị iri puku isii, puku abụọ na narị asaa (62,700). 
\b  
\li1  
\v 40 Site nʼụmụ Asha, ndị ikom niile gbara iri afọ abụọ gbagoo, ndị tozuru ije agha ka e dere aha ha nʼusoro nʼotu nʼotu dịka ikwu ha na ezinaụlọ ha si dị.  
\v 41 Ọnụọgụgụ ndị niile sị nʼebo Asha dị iri puku anọ, otu puku na narị ise (41,500). 
\b  
\li1  
\v 42 Site nʼụmụ Naftalị, ndị ikom niile gbara iri afọ abụọ gbagoo, ndị tozuru ije agha ka e dere aha ha nʼusoro nʼotu nʼotu dị ka ikwu ha na ezinaụlọ ha si dị.  
\v 43 Ọnụọgụgụ ndị niile sị nʼebo Naftalị dị iri puku ise, puku atọ na narị anọ (53,400). 
\b  
\li4  
\v 44 Ndị a bụ ndị ikom Mosis na Erọn, na ndị ndu Izrel iri na abụọ ndị ahụ gụrụ ọnụ, onye ọbụla nʼime ha nọchitere anya ezinaụlọ ya.  
\v 45 Ndị Izrel niile gbara iri afọ abụọ gbagoo, ndị nwere ike ije agha ka a gụrụ ọnụ dịka ezinaụlọ ha si dị.  
\v 46 Mgbakọ ọnụọgụgụ ndị a niile dị, narị puku isii, puku atọ, narị ise na iri ise (603,550). 
\b  
\p  
\v 47 A gụnyekọtaghị ọnụọgụgụ ebo nna nna Livayị nʼịgụ ọnụ a,  
\v 48 nʼihi na \nd Onyenwe anyị\nd* gwara Mosis, sị,  
\v 49 “Ị gaghị agụ ndị ebo Livayị ọnụ. Ị gakwaghị agbakọnye ọnụọgụgụ ha nʼọnụọgụgụ ndị Izrel.  
\v 50 Kama, ị ga-ahọpụta ndị Livayị ka ha bụrụ ndị nlekọta ụlọ nzute Ihe Ama, na ngwongwo niile, na ihe niile dị nye ya. Ọ bụ ha ga-ebu ụlọ nzute ahụ na ngwongwo ya niile: ha ga na-elekọta ihe banyere ya, ọ bụkwa gburugburu ya ka ha ga-ama ụlọ ikwu ha.  
\v 51 Mgbe ọbụla kwa a ga-ebugharị ya maka njem, ọ bụ ọrụ ha iweda ya. Mgbe ọbụla a ga-eguzo ya ọtọ, ọ bụkwa ọrụ ndị Livayị iguzobe ya ọtọ. Onye ọbụla ọzọ ga-abịa nso ka a ga-egbu.  
\v 52 Ebo Izrel ndị ọzọ ga-enwe ebe dị iche nye onwe ha, ebe ha ga-ewu ụlọ ikwu ha. Ha ga-akwụbakwa ọkọlọtọ nke ha, igosi aha ebo ha.  
\v 53 Ndị Livayị ga-ama ụlọ ikwu ha gburugburu ụlọ nzute Ihe Ama ahụ, ka iwe ọkụ m ghara ịbịakwasị nʼahụ nzukọ ụmụ Izrel. Ọ bụ ọrụ ndị Livayị ilekọta ụlọ nzute Ihe Ama ahụ.” 
\p  
\v 54 Ya mere, Izrel mere ihe ndị a niile \nd Onyenwe anyị\nd* nyere Mosis nʼiwu. 
\c 2  
\s1 Usoro ebo dị iche iche 
\p  
\v 1 \nd Onyenwe anyị\nd* gwara Mosis na Erọn sị ha,  
\v 2 “Ụmụ Izrel ga-ama ụlọ ikwu ha gburugburu ụlọ nzute, nʼebe dịpụturu adịpụ site nʼụlọ nzute ahụ. Onye ọbụla ga-ama ụlọ ikwu ya nʼakụkụ ọkọlọtọ ebo ya, ha na ihe ịrịbama nke ụlọ ha.” 
\b  
\li4  
\v 3 Nʼakụkụ ọwụwa anyanwụ, 
\li1 usuu ndị agha ebo Juda, ga-ama ụlọ ikwu ha nʼakụkụ ọkọlọtọ ha. Onyendu ha ga-abụ Nashọn nwa Aminadab.  
\v 4 Ọnụọgụgụ usuu ndị agha ya dị puku iri asaa na anọ, na narị isii (74,600) 
\li1  
\v 5 Nʼakụkụ ha ka usuu ndị agha ebo Isaka ga-amanye ụlọ ikwu ha. Onyendu ha bụ Netanel nwa Zua.  
\v 6 Ọnụọgụgụ usuu ndị agha ha dị iri puku ise, puku anọ na narị anọ (54,400). 
\li1  
\v 7 Nʼakụkụ ha ka usuu ndị agha ebo Zebụlọn ga-amanye ụlọ ikwu ha. Onyendu ha bụ Eliab nwa Helọn.  
\v 8 Ọnụọgụgụ usuu ndị agha ha dị iri puku ise, puku asaa na narị anọ (57,400). 
\li4  
\v 9 Ọnụọgụgụ ndị niile a gụkọtara ha na Juda nʼọwụwa anyanwụ nke ụlọ nzute ahụ dị narị puku, iri puku asatọ na puku isii na narị anọ (186,400). Ha ga-ebu ụzọ bulie ije. 
\b  
\li4  
\v 10 Nʼakụkụ ndịda ka 
\li1 usuu ndị agha ebo Ruben ga-ama ụlọ ikwu ha nʼakụkụ ọkọlọtọ ha. Onyendu ha bụ Elizọ nwa Shedeua.  
\v 11 Ọnụọgụgụ usuu ndị agha ha dị iri puku anọ, puku isii na narị ise (46,500). 
\li1  
\v 12 Nʼakụkụ ha ka ebo Simiọn ga-ama ụlọ ikwu ha. Onyendu ha bụ Shelumiel nwa Zurishadai.  
\v 13 Ọnụọgụgụ usuu ndị agha ha dị iri puku ise, puku itoolu na narị atọ (59,300). 
\li1  
\v 14 Ebo Gad ga-esokwa ha. Onyendu ha bụ Eliasaf nwa Deuel.\f + \fr 2:14 \ft Nʼime ọtụtụ akwụkwọ ndị Masoreti, akwụkwọ ise nke ndị Samarịa nakwa akwụkwọ Vọlgetị, nʼisi mbụ na amaokwu iri na anọ ha, ihe e dere bụ \fqa Reuel\f* 
\v 15 Ọnụọgụgụ usuu ndị agha ha dị iri puku anọ, puku ise na narị isii na iri ise (45,650). 
\li4  
\v 16 Ya mere ọnụọgụgụ ndị niile ha na Ruben bikọrọ na ndịda ụlọ nzute ahụ dị narị puku, iri puku ise na otu, na narị anọ na iri ise (151,450) dịka usuu ndị agha ha si dị. Ebo atọ a bụ ndị na-eso ebo atọ nke mbụ ahụ nʼoge ọbụla ụmụ Izrel nọ nʼije. 
\b  
\li1  
\v 17 Ka ụlọ nzute na-azọli ije, ụlọ ikwu ndị Livayị ga-anọ nʼetiti ụlọ ikwu ndị ọzọ. Ha ga-ebili ije nʼusoro dịka ha si maa ụlọ ikwu ha. Ndị ọbụla nʼọnọdụ ha, nʼokpuru ọkọlọtọ nke na-akọwa ndị ha bụ. 
\b  
\li4  
\v 18 Nʼakụkụ ọdịda anyanwụ 
\li1 ka ebo Ifrem ga-ama ụlọ ikwu ha dịka ọkọlọtọ ha si dị. Onyendu ha bụ Elishama nwa Amihud.  
\v 19 Ọnụọgụgụ usuu ndị agha ha dị iri puku anọ na narị ise (40,500). 
\li1  
\v 20 Ebo Manase ga-amakwa ụlọ ikwu nʼakụkụ ha. Onyendu ha bụ Gamaliel nwa Pedazo.  
\v 21 Ọnụọgụgụ usuu ndị agha ha dị iri puku atọ, puku abụọ na narị abụọ (32,200). 
\li1  
\v 22 Nʼakụkụ ha ka ebo Benjamin ga-ama ụlọ ikwu ha. Onyendu ha bụ Abidan nwa Gidiọn.  
\v 23 Ọnụọgụgụ usuu ndị agha ha dị iri puku atọ, puku ise na narị anọ (35,400). 
\li4  
\v 24 Ya mere ọnụọgụgụ ndị niile ha na Ifrem bikọrọ nʼakụkụ ọdịda anyanwụ nke ụlọ nzute ahụ dị narị puku, puku asatọ na narị mmadụ (108,100). Ha niile na-esokwa nʼazụ ndị Livayị na ụlọ nzute ahụ. Ndị a bụ ndị na-eso nʼọnọdụ nke atọ nʼoge ọbụla ụmụ Izrel nọ nʼije. 
\b  
\li4  
\v 25 Ebo Dan na usuu ndị agha ha 
\li1 ga-ama ụlọ ikwu ha nʼakụkụ elu elu nʼokpuru ọkọlọtọ ha. Onyendu ha bụ Ahieza nwa Amishadai  
\v 26 Ọnụọgụgụ usuu ha dị iri puku isii, puku abụọ na narị asaa (62,700). 
\li1  
\v 27 Nʼakụkụ ha ka ebo Asha ga-ama ụlọ ikwu ha. Onyendu ha bụ Pagịel nwa Okran.  
\v 28 Ọnụọgụgụ usuu ndị agha ha dị iri puku anọ, otu puku na narị ise (41,500). 
\li1  
\v 29 Otu aka ahụ ka ebo Naftalị ga-ama ụlọ ikwu ha. Onyendu ha bụ Ahira nwa Enan.  
\v 30 Ọnụọgụgụ usuu ndị agha ha dị iri puku ise, puku atọ na narị anọ (53,400). 
\li4  
\v 31 Ya mere ọnụọgụgụ ndị niile ha na Dan bikọrọ nʼakụkụ elu elu nke ụlọ nzute ahụ dị narị puku, iri puku ise na puku asaa na narị isii (157,600). Ha ga-abụ ndị ga-ekpe azụ bilie ije nʼokpuru ọkọlọtọ ha. 
\b  
\li4  
\v 32 Ndị a bụ ndị Izrel, ndị a gụrụ ọnụ dịka ezinaụlọ ha si dị. Ndị ikom niile nọ nʼọmụma ụlọ ikwu, dịka usuu ha dị iche iche si dị, narị puku isii, puku atọ na narị ise na iri ise (603,550) nʼọnụọgụgụ.  
\v 33 Ma otu ọ dị, a gụnyeghị ebo Livayị nʼọnụọgụgụ\f + \fr 2:33 \ft \xt Ọnụ 1:47-49\f* ndị Izrel ndị ọzọ dịka iwu \nd Onyenwe anyị\nd* nyere Mosis si dị. 
\b  
\p  
\v 34 Ya mere, ndị Izrel mere ihe niile dịka \nd Onyenwe anyị\nd* nyere Mosis nʼiwu. Otu a ka ha si maa ụlọ ikwu ha nʼakụkụ ọkọlọtọ ha. Otu a kwa ka ha si ebuli ije. Onye ọbụla nʼime ha dịka ebo ha na ezinaụlọ ha si dị. 
\c 3  
\s1 Ịgụ ndị Livayị ọnụ 
\p  
\v 1 Nke a bụ akụkọ banyere usoro agbụrụ Erọn na Mosis nʼoge \nd Onyenwe anyị\nd* gwara Mosis okwu nʼugwu Saịnaị. 
\b  
\p  
\v 2 Ndị a bụ aha ụmụ ndị ikom Erọn, Nadab, ọkpara ya, Abihu, Elieza na Itama.  
\v 3 Ndị a bụ aha ụmụ ndị ikom Erọn, ndị e tere mmanụ ịbụ ndị nchụaja, ndị e doro nsọ nʼihi ije ozi dịka ndị nchụaja.  
\v 4 Ma \nd Onyenwe anyị\nd* mere ka Nadab na Abihu nwụọ, nʼihu ya nʼime ọzara Saịnaị, mgbe ha ji ọkụ na-adịghị nsọ wetara ya onyinye. Ebe ọ bụ na ha amụtaghị ụmụ ndị ikom nke aka ha, ọ bụ naanị Elieza na Itama jere ozi dịka ndị nchụaja ogologo ụbọchị ndụ nna ha bụ Erọn. 
\p  
\v 5 Nʼoge ahụ, \nd Onyenwe anyị\nd* gwara Mosis okwu sị,  
\v 6 “Kpọkọtaa ebo Livayị\f + \fr 3:6 \ft Ndị Livayị dị iche na ndị nchụaja, ha bụ naanị ndị inyeaka nye ndị nchụaja. Ọ dị nʼakwụkwọ \xt Ọnụ 8:6-22; 18:1-6\ft  Ọ bụ naanị Erọn, na ụmụ ya bụ ndị na-aga ozi dịka ndị nchụaja. Nke a dị nʼakwụkwọ \xt Ọnụ 18:7\f* niile were ha nyefee Erọn onye nchụaja nʼaka, ka ha bụrụ ndị inyeaka ya.  
\v 7 Ha ga-ejere ya na nzukọ Izrel niile ozi nʼụlọ nzute ahụ site na ịrụ ọrụ metụtara ebe obibi ahụ.  
\v 8 Ha ga-elekọta ngwongwo ụlọ nzute, rụọ ọrụ metụtara ndị Izrel niile mgbe ha na-eje ozi ha nʼebe obibi ahụ.  
\v 9 Were ndị Livayị nyefee Erọn na ụmụ ya ndị ikom nʼaka. Ọ bụ ha ka a ga-esi nʼetiti ụmụ Izrel nyefee ha nʼaka kpamkpam.  
\v 10 Họpụta Erọn na ụmụ ya ndị ikom ka ha bụrụ ndị na-eje ozi dịka ndị nchụaja. Onye ọbụla ọzọ bịara nso ebe nsọ ahụ ka a ga-egbu.” 
\p  
\v 11 \nd Onyenwe anyị\nd* gwara Mosis okwu sị,  
\v 12 “Anarala m ndị Livayị dịka ndị nọchitere anya ụmụ ndị ikom mbụ niile a mụrụ nʼetiti ndị Izrel. Ndị Livayị niile bụ nke m.  
\v 13 Nʼihi na ihe niile meghere akpanwa bụ nke m. Site nʼụbọchị ahụ m gburu ụmụ ndị ikom niile e buru ụzọ mụọ nʼala Ijipt ka m doro ụmụ ndị ikom niile e buru ụzọ mụọ nʼetiti ndị Izrel nsọ nye onwe m, ma mmadụ, ma anụmanụ bụ nke m. Abụ m \nd Onyenwe anyị\nd*.” 
\p  
\v 14 \nd Onyenwe anyị\nd* gwara Mosis okwu nʼọzara Saịnaị sị ya,  
\v 15 “Gụọ, chọpụta ihe ọnụọgụgụ ebo Livayị bụ.\f + \fr 3:15 \ft Ndị ikom ebo Livayị adịghị eso ndị ikom Izrel ndị ọzọ a ga agha. Ya mere na-adịghị agụnye ha nʼọnụọgụgụ dịka a na-agụnye ndị ikom ebo ndị ọzọ mgbe ha gbara iri afọ abụọ. Ọgụgụ a gụrụ ndị ikom Livayị bụ nʼihi i were ha dochie anya ndị ikom niile e bu ụzọ mụọ nʼIzrel. \xt Ọnụ 3:40-49\f* Gosi ikwu na ezinaụlọ onye ọbụla si nʼime ya pụta. Chọpụta ọnụọgụgụ ndị ikom niile site nʼonye dị otu ọnwa.”  
\v 16 Ya mere, Mosis gụrụ ha ọnụ dịka iwu ọ natara site nʼokwu \nd Onyenwe anyị\nd* si dị. 
\b  
\li1  
\v 17 Ndị a bụ aha ụmụ ndị ikom Livayị: 
\li2 Geshọn, Kohat na Merari. 
\li1  
\v 18 Ndị a bụ aha ndị ikwu Geshọn dịka ezinaụlọ ha si dị: 
\li2 Libni na Shimei. 
\li1  
\v 19 Ụmụ Kohat dịka ikwu ha si dị: 
\li2 Amram, Izha, Hebrọn na Uziel. 
\li1  
\v 20 Ụmụ Merari dịka ikwu ha si dị: 
\li2 Mahali na Mushi. 
\b  
\li4 Ndị a bụ ndị agbụrụ Livayị, dịka ezinaụlọ ha si dị. 
\b  
\li4  
\v 21 Ndị Geshọn bụ ndị ikwu Libni na Shimei. Ndị a bụ ndị ikwu Geshọn. 
\li1  
\v 22 Ọnụọgụgụ ndị ikom dị otu ọnwa gbagoo dị puku asaa na narị ise (7,500). 
\li1  
\v 23 Ndị ikwu Geshọn mara ụlọ ikwu ha nʼakụkụ ọdịda anyanwụ, nʼazụ ụlọ nzute. 
\li1  
\v 24 Onyendu ezinaụlọ ndị Geshọn bụ Eliasaf nwa Lael. 
\li1  
\v 25 Ọrụ dịrị ụmụ Geshọn bụ ilekọta ụlọ nzute ahụ, na ụlọ ikwu ya, na ihe mkpuchi ya, na akwa mgbochi ọnụ ụzọ ụlọ nzute.  
\v 26 Ọ dịkwa ha nʼaka ilekọta akwa mgbochi niile nke ogige gbara ya gburugburu, na akwa e ji gechie ọnụ ụzọ ogige ahụ. Ha nwekwara ọrụ ilekọta ebe ịchụ aja, na ụdọ niile, na ozi niile metụtara ihe ndị a. 
\b  
\li4  
\v 27 Nke Kohat bụ ikwu ndị Aram, ndị Izha, ndị Hebrọn na ndị Uziel. Ndị a bụ ndị ikwu Kohat. 
\li1  
\v 28 Ọnụọgụgụ ndị ikom niile dị otu ọnwa gbagoo dị puku asatọ na narị isii (8,600). 
\li1 Ọrụ dịrị ndị Kohat bụ ilekọta ebe nsọ. 
\li1  
\v 29 Ndị ikwu Kohat mara ụlọ ikwu ha nʼakụkụ ndịda nke ebe nsọ. 
\li1  
\v 30 Onyendu ezinaụlọ ndị ikwu Kohat bụ Elizafan nwa Uziel. 
\li1  
\v 31 Ọrụ e tinyere ha nʼaka bụ ilekọta igbe ọgbụgba ndụ, tebul ahụ, ihe ịdọba oriọna ahụ na ebe ịchụ aja. Ihe ọzọ bụ ilekọta ngwongwo niile e ji eje ozi nʼebe nsọ ahụ, akwa mgbochi na ihe niile metụtara otu e si e ji ha eje ozi. 
\li1  
\v 32 Onyeisi ndị ndu nke ndị Livayị bụ Elieza nwa Erọn, onye nchụaja. Ọ bụ ya na-elekọta ndị ọrụ ha bụ ihu maka ihe niile metụtara ebe nsọ ahụ. 
\b  
\li4  
\v 33 Ndị Merari bụ ikwu Mahali na Mushi. Ndị a bụ ndị ikwu Merari. 
\li1  
\v 34 Ọnụọgụgụ ndị ikom niile dị otu ọnwa gbagoo dị puku isii na narị abụọ (6,200). 
\li1  
\v 35 Onyendu ezinaụlọ ndị ikwu Merari bụ Zuniel nwa Abihail. 
\li1 Ha mara ụlọ ikwu ha nʼakụkụ ugwu nke ụlọ nzute ahụ. 
\li1  
\v 36 Ọrụ e tinyere nʼaka ndị ikwu Merari bụ ilekọta mbudo niile nke ụlọ nzute ahụ, na mkpọrọ ya niile, ụkwụ ya niile, na ngwongwo niile e kwesiri iji rụọ ọrụ metụtara ha.  
\v 37 Ọrụ ndị ọzọ bụ ilekọta ogidi osisi niile dị gburugburu ogige ahụ ha na ụkwụ ha, ǹtu na ụdọ ha niile. 
\b  
\li1  
\v 38 Mpaghara akụkụ ọwụwa anyanwụ nʼihu ụlọ nzute ahụ ka e debere maka ụlọ ikwu Mosis na Erọn, na nke ụmụ ya ndị ikom. 
\li1 Ọrụ ha bụ ilekọta ebe nsọ ahụ nʼaha ụmụ Izrel niile. 
\li1 Onye ọbụla ọzọ bịara ebe nsọ ahụ nso ka a ga-egbu. 
\b  
\li4  
\v 39 Ya mere, ọnụọgụgụ ndị ikom Livayị niile Mosis na Erọn nwetara mgbe a gụrụ ha ọnụ nʼikwu nʼikwu dịka iwu \nd Onyenwe anyị\nd* nyere ha si dị, bụ iri puku abụọ na puku abụọ (22,000). Nke a bụ ọnụọgụgụ ndị ikom niile dị site nʼotu ọnwa gaa nʼihu. 
\b  
\p  
\v 40 Mgbe ahụ, \nd Onyenwe anyị\nd* sịrị Mosis, “Gụọ ndị ikom Izrel niile e buru ụzọ mụọ, ndị dị site nʼotu ọnwa gbagoo. Chọpụta ọnụọgụgụ ha, dee aha ha niile nʼakwụkwọ.  
\v 41 Nabata ndị Livayị ka ha bụrụ nke m nʼọnọdụ ndị ikom niile e bụrụ ụzọ mụọ nʼIzrel. Ọzọkwa, anụ ụlọ ndị Livayị niile bụ nke m, nʼọnọdụ ụmụ mbụ nke anụ ụlọ niile a mụrụ nʼetiti anụ ụlọ ndị Izrel niile. Abụ m \nd Onyenwe anyị\nd*.” 
\p  
\v 42 Ya mere, Mosis gụrụ ndị ikom niile e buru ụzọ mụọ nʼIzrel, dịka \nd Onyenwe anyị\nd* nyere ya nʼiwu,  
\v 43 chọpụta na ọnụọgụgụ ndị ikom e buru ụzọ mụọ site nʼonye dị otu ọnwa ruo nʼokenye dị iri puku abụọ na puku abụọ na narị abụọ na iri asaa na atọ (22,273). 
\p  
\v 44 Mgbe ahụ, \nd Onyenwe anyị\nd* gwara Mosis okwu sị:  
\v 45 “Nye m ndị Livayị nʼọnọdụ ndị ikom niile e bụ ụzọ mụọ nʼIzrel. Nyekwa m anụ ụlọ ndị Livayị niile nʼọnọdụ anụ ụlọ niile e bụ ụzọ mụọ nʼIzrel. Ndị Livayị bụ nke m. Mụ onwe m bụ \nd Onyenwe anyị\nd*.  
\v 46 Ihe a ga-eji gbara narị ụmụ ndị ikom Izrel abụọ na iri ndị ikom asaa, na atọ (273) ndị e buru ụzọ mụọ mapụtara nʼelu ọnụọgụgụ ndị Livayị  
\v 47 bụ ego ruru shekel ise, na isi onye ọbụla, ụdị shekel ebe nsọ, nke ọtụtụ ya bụ iri gera abụọ.  
\v 48 Were ego mgbapụta a nye Erọn na ụmụ ndị ikom ya.” 
\p  
\v 49 Ya mere, Mosis natara ego mgbapụta ahụ nʼisi onye ọbụla dị nʼọnụọgụgụ ndị ahụ mara nʼelu ọnụọgụgụ ndị Livayị.  
\v 50 Ego niile ọ natara site nʼaka ndị ikom Izrel niile e bụ ụzọ mụọ bụ ọlaọcha ruru puku shekel na narị shekel atọ na iri isii na ise (1,365), dịka ihe ọtụtụ shekel ebe nsọ si dị.  
\v 51 Mosis nyere Erọn na ụmụ ya ego mgbapụta ndị a dịka \nd Onyenwe anyị\nd* nyere ya nʼiwu. 
\c 4  
\s1 Ụmụ Kohat 
\p  
\v 1 \nd Onyenwe anyị\nd* gwara Mosis na Erọn okwu sị,  
\v 2 “Gụọ ọnụ chọpụta, ọnụọgụgụ ụmụ Kohat dị nʼebo Livayị dịka ikwu ha na ezinaụlọ ha si dị.  
\v 3 Gụọ ndị ikom niile gbarala iri afọ atọ ruo iri afọ ise, ndị tozuru ije ozi nʼụlọ nzute. 
\p  
\v 4 “Nke a bụ ọrụ dịrị ndị Kohat nʼụlọ nzute, ilekọta ihe ndị ahụ kachasị ịdị nsọ.  
\v 5 Mgbe ọmụma ụlọ ikwu ahụ ga-ebili ije ha, Erọn na ụmụ ya ndị ikom ga-eburu ụzọ banye nʼụlọ nzute ahụ wetuo akwa mgbochi ahụ, jiri ya kpuchie igbe iwu ọgbụgba ndụ ahụ.  
\v 6 Mgbe ahụ, ha ga-agbakwasị akpụkpọ anụ ehi mmiri nʼelu akwa mgbochi ahụ, sakwasịkwa akwa na-acha anụnụ anụnụ\f + \fr 4:6 \ft Maọbụ, \fqa buluu\f* nʼelu ya, tinyekwa mkpọrọ osisi niile nʼoghere ha kwesiri ịdị. 
\p  
\v 7 “Nʼelu tebul ahụ na-adị nʼihu Onyenwe anyị, ha ga-agbasa akwa anụnụ anụnụ tụkwasịkwa efere niile, ngaji niile, ọkwa niile na iko aja ihe ọṅụṅụ. Achịcha ahụ na-adịgide nʼelu ya ga-adịkwa ebe ọ dị.  
\v 8 Ha ga-agbasakwa akwa uhie nʼelu ya, jiri akpụkpọ anụ ehi mmiri gbokwasịkwa nʼelu akwa uhie ahụ. Mgbe ahụ, ha ga-etinyekwa mkpọrọ osisi e ji ebu tebul nʼime oghere o kwesiri ịdị. 
\p  
\v 9 “Ọzọ, ha ga-eji akwa anụnụ anụnụ sachie ihe ịdọba oriọna ahụ nke na-enye ìhè, ya na oriọna ya niile, mkpa ya niile na ihe ịkpakepụ ọkụ ya niile na ite mmanụ ya niile, e ji awụnye ya mmanụ.  
\v 10 Emesịa, ha ga-eji akpụkpọ anụ ehi mmiri sachie ya na ngwongwo ya niile, tụkwasị ya nʼelu ihe e ji ebu ya. 
\p  
\v 11 “Ha ga-ejikwa akwa anụnụ anụnụ tụsaa nʼelu ebe ịchụ aja ahụ e jiri ọlaedo mee, werekwa akpụkpọ anụ ehi mmiri sachie ya, tinyekwa mkpọrọ osisi e ji ebu ya nʼoghere dị nʼakụkụ ebe ịchụ aja ahụ. 
\p  
\v 12 “Ihe ndị ọzọ niile e ji eje ozi nʼebe nsọ ahụ ka ha ga-eji akwa anụnụ anụnụ kekọtaa, jirikwa akpụkpọ anụ ehi mmiri sachie ha, tụkwasị ha nʼelu ihe e ji ebu ha. 
\p  
\v 13 “A ga-ekpopụ ntụ dị nʼebe ịchụ aja bronz ahụ, jiri akwa na-acha ngwakọta anụnụ na uhie, sachie ebe ịchụ aja bronz ahụ.  
\v 14 Emesịa ha ga-atụkwasị ihe niile e ji eje ozi nʼebe ịchụ aja ahụ nʼelu akwa ahụ, ihe dịka ite ịgụ ọkụ, na ndụdụ, na ihe ikpofu ntụ, na efere ịkwọsa mmiri niile. Akpụkpọ anụ ehi mmiri ka a ga-eji sachie ha niile. Ma nʼikpeazụ, mkpọrọ osisi e ji ebu ya ka a ga-etinye nʼebe ha kwesiri ịdị. 
\p  
\v 15 “Mgbe Erọn na ụmụ ya kpuchisịrị ụlọnsọ ahụ na ngwongwo niile nke ebe nsọ ahụ, dịka ndị Izrel niile na-ejikere ibili ije, mgbe ahụ ka ndị Kohat ga-abata buru ihe ndị a. Ma ha agaghị emetụ ihe nsọ ndị a aka ka ha ghara ịnwụ. Ọrụ ibu ihe ndị a niile dị nʼime ụlọ nzute dịrị Ndị Kohat.\f + \fr 4:15 \ft Ndị Kohat, ndị agbụrụ Geshọn na ụmụ Geshọn bụ ndị agbụrụ Livayị. Ha bụ ndị e nyere ọrụ ibu ihe dị iche iche nʼụlọ nzute. \xt 4:24,29,34-49\f* 
\p  
\v 16 “Elieza nwa Erọn, onye nchụaja, ka ọrụ ndị a dị nʼaka: mmanụ e ji amụ ọkụ, na ihe nsure ọkụ e ji ụda dị iche iche na-esi isi ụtọ mee, na onyinye mkpụrụ ọka a na-enye ụbọchị niile, na mmanụ nsọ ahụ. Nʼaka ya ka ọrụ metụtara nlekọta ụlọ nzute ahụ niile, ihe niile dị nʼime ya na ngwongwo nsọ ya dị iche iche dị.” 
\p  
\v 17 \nd Onyenwe anyị\nd* gwara Mosis na Erọn sị,  
\v 18 “Unu ekwekwala ka agbụrụ Kohat bụrụ ndị e bipụrụ site nʼebo Livayị.  
\v 19 Otu a ka unu ga-esi meso ha mmeso ime ka ha dịrị ndụ, ghara ịnwụ, mgbe ha bịara nso ihe ndị ahụ dịkarịsịrị nsọ, Erọn na ụmụ ya ga-esoro ha banye gosi onye ọ bụla nʼime ha ihe ha ga-ebu.  
\v 20 Ma ndị Kohat ekwesighị ịbanye ilekwasị ihe nsọ ndị ahụ anya, ka ha ghara ịnwụ.” 
\s1 Ụmụ Geshọn 
\p  
\v 21 Mgbe ahụ \nd Onyenwe anyị\nd* gwara Mosis okwu sị,  
\v 22 “Gụọ ọnụ chọpụta ọnụọgụgụ ụmụ Geshọn, dịka ikwu ha na ezinaụlọ ha si dị.  
\v 23 Mata ọnụọgụgụ ndị ikom ole ha dị, ndị kwesiri ịrụ ọrụ nʼụlọ nzute, ndị gbara iri afọ atọ ruo iri afọ ise. 
\p  
\v 24 “Ihe ga-abụ ọrụ ndị ikwu Geshọn ga-abụ ije ozi na ibu ibu.  
\v 25 Ha ga-ebu akwa mgbochi ebe obibi ahụ na nke ụlọ nzute ahụ, tinyere akwa e ji sachie ya na akpụkpọ anụ ehi mmiri e ji mee elu ụlọ ya na akwa mgbochi dị nʼọnụ ụzọ ụlọ nzute ahụ.  
\v 26 Ha ga-ebukwa akwa mgbochi niile e ji gechie ogige ahụ, akwa e ji gechie ọnụ ụzọ ama ogige gbara ebe ịchụ aja na ụlọ nzute ahụ gburugburu, ụdọ ya niile na ngwongwo niile e ji eje ozi.  
\v 27 Ọrụ ha niile, maọbụ ibu ihe ma ọ bụkwanụ ịrụ ọrụ ọzọ, ga-abụ site na ntụziaka Erọn na ụmụ ya. Ị ga-ekenye ha ọrụ dịrị ha nʼihe niile bụ ihe ha ga-ebu.  
\v 28 Nke a bụ ọrụ dịịrị ikwu Geshọn nʼụlọ nzute. Ha ga-anọ nʼokpuru Itama, nwa Erọn, onye nchụaja, onye bụ onyeisi ha. 
\s1 Ụmụ Merari 
\p  
\v 29 “Gụọ, chọpụta ọnụọgụgụ ụmụ Merari dịka ikwu ha na ezinaụlọ ha si dị.  
\v 30 Chọpụta ọnụọgụgụ ndị ikom ole ha dị, ndị gbara iri afọ atọ ruo iri afọ ise, ndị toruru ịrụ ọrụ nʼụlọ nzute Onyenwe anyị.  
\v 31 Ije ozi ha dịka o si metụta ọrụ ụlọ nzute bụ ibu mbudo ụlọ nzute ahụ niile, osisi ntụbichi ya niile, ogidi osisi na ụkwụ ya niile;  
\v 32 tinyere ogidi osisi niile dị ogige ahụ gburugburu na ụkwụ ha niile, ǹtu niile, ụdọ ha niile na ngwongwo ndị ọzọ e ji arụ ọrụ metụtara ihe ndị a ha ga-ebu. Kenye nwoke ọbụla ọrụ nke ya. Kpọ onye ahụ aha nye ya ọrụ nke ya.  
\v 33 Nke a bụ ọrụ dịịrị ndị agbụrụ Merari mgbe ha na-aga ozi ha nʼụlọ nzute. Ha ga-anọ nʼokpuru Itama, nwa Erọn, onye nchụaja, onye bụ onyeisi ha.” 
\s1 Ịgụ agbụrụ Livayị niile ọnụ 
\li1  
\v 34 Ya mere, Mosis na Erọn na ndị ndu nzukọ ụmụ Izrel gụrụ ma chọpụta ọnụọgụgụ ụmụ Kohat, dịka ikwu ha na ezinaụlọ ha si dị. 
\li2  
\v 35 Ndị ikom niile gbara iri afọ atọ ruo iri afọ ise, ndị toruru ije ozi nʼụlọ nzute ahụ  
\v 36 dịka ikwu ha si dị bụ puku abụọ na narị asaa na iri ise (2,750).  
\v 37 Ndị a niile bụ ndị si nʼikwu Kohat ndị na-eje ozi nʼụlọ nzute. Mosis na Erọn gụrụ ha ọnụ dịka iwu \nd Onyenwe anyị\nd* nyere Mosis si dị. 
\b  
\li1  
\v 38 A gụrụ ụmụ Geshọn ọnụ dịka ikwu ha na ezinaụlọ ha si dị. 
\li2  
\v 39 Ndị ikom niile gbara iri afọ atọ ruo iri afọ ise, ndị toruru ije ozi nʼụlọ nzute,  
\v 40 dịka ikwu ha si dị bụ puku abụọ na narị isii na iri atọ (2,630).  
\v 41 Ndị a niile bụ ndị si nʼikwu Geshọn ndị na-eje ozi nʼụlọ nzute. Mosis na Erọn gụrụ ha ọnụ dịka iwu \nd Onyenwe anyị\nd* nyere Mosis si dị. 
\b  
\li1  
\v 42 A gụrụ ụmụ Merari ọnụ dịka ikwu ha na ezinaụlọ ha si dị. 
\li2  
\v 43 Ndị ikom niile gbara iri afọ atọ ruo iri afọ ise ndị toruru ije ozi nʼụlọ nzute  
\v 44 dịka ikwu ha si dị bụ puku atọ na narị abụọ (3,200).  
\v 45 Ndị a niile bụ ndị si nʼikwu Merari ndị na-eje ozi nʼụlọ nzute. Mosis na Erọn gụrụ ha ọnụ dịka iwu \nd Onyenwe anyị\nd* nyere Mosis si dị. 
\b  
\li4  
\v 46 Otu a ka Mosis na Erọn na ndị ndu ụmụ Izrel si gụọ ndị Livayị niile ọnụ dịka ikwu ha na ezinaụlọ ha si dị.  
\v 47 Ndị ikom niile gbara iri afọ atọ ruo iri afọ ise, ndị toruru ije ozi na ibu ụlọ nzute ahụ  
\v 48 dị puku asatọ na narị ise na iri asatọ (8,580).  
\v 49 Dịka iwu \nd Onyenwe anyị\nd* nyere site nʼaka Mosis si dị, e kenyere onye ọbụla ọrụ ya ma gwa ya ihe o kwesiri ibu. 
\b  
\p A gụrụ ha ọnụ dịka \nd Onyenwe anyị\nd* nyere Mosis nʼiwu. 
\c 5  
\s1 Idebe ọmụma ụlọ ikwu ọcha 
\p  
\v 1 \nd Onyenwe anyị\nd* gwara Mosis okwu sị ya,  
\v 2 “Nye ndị Izrel iwu ka ha site nʼọmụma ụlọ ikwu ha kpọpụ onye ekpenta ọbụla maọbụ onye ihe si nʼahụ na-asọpụta, na ndị merụrụ onwe ha site nʼimetụ onye nwụrụ anwụ aka.  
\v 3 Iwu a metụtara onye ọbụla, nwoke na nwanyị. Kpọpụ ha ka ha gaa nʼazụ ọmụma ụlọ ikwu, ka ha ghara imerụ ogige ụlọ ikwu ha bụ ebe ahụ m binyere unu.”  
\v 4 Ndị Izrel mezuru iwu a, site nʼetiti ha kpọpụ ndị dị otu a, dịka \nd Onyenwe anyị\nd* nyere Mosis nʼiwu. 
\s1 Ịkwụghachi ụgwọ 
\p  
\v 5 \nd Onyenwe anyị\nd* gwara Mosis okwu sị ya,  
\v 6 “Gwa ụmụ Izrel okwu sị ha, ‘Mgbe onye ọbụla, nwoke maọbụ nwanyị, mejọrọ mmadụ ibe ya nʼụzọ ọbụla, si otu a bụrụ onye na-ekwesighị ntụkwasị obi nye \nd Onyenwe anyị\nd* bụ onye ikpe mara.  
\v 7 Onye dị otu a aghaghị ikwupụta mmehie ya, kwụghachi onye ahụ o mejọrọ ihe iwu kwuru na ọ ga-akwụ. Ọ ga-atụkwasị nʼelu ihe ọ na-akwụghachi onye ahụ o mejọrọ ego ọzọ ruru otu ụzọ nʼụzọ ise.  
\v 8 Ma ọ bụrụ na onye ahụ enweghị onye ikwu ya bụ onye a ga-akwụghachi ụgwọ nʼihi mejọọ ahụ, ihe ịkwụghachi ụgwọ ahụ ga-abụ nke \nd Onyenwe anyị\nd*, aghaghị inye onye nchụaja. A ga-atụkwasịkwa ya ebule a ga-eji chụọ aja mkpuchi mmehie nʼihi onye ahụ mehiere.  
\v 9 Onyinye niile dị nsọ ndị Izrel wetaara onye nchụaja bụ nke onye nchụaja ahụ.  
\v 10 Onyinye dị nsọ niile mmadụ na-eweta bụ nke onye na-eweta ya, ma onyinye e nyere onye nchụaja bụ nke onye nchụaja.’ ” 
\s1 Iwu banyere ekwesighị ntụkwasị obi 
\p  
\v 11 Mgbe ahụ, \nd Onyenwe anyị\nd* gwara Mosis okwu sị,  
\v 12 “Gwa ụmụ Izrel okwu sị ha, Ọ bụrụ na nwunye mmadụ ejehie ụzọ bụrụ onye na-ekwesighị ntụkwasị obi nʼebe di ya nọ  
\v 13 site nʼidinakwuru nwoke ọzọ nʼụzọ zoro ezo nʼebe di ya nọ ruo na achọpụtaghị adịghị ọcha ya (ebe a na-enweghị onye ga-agba akaebe megide ya, maọbụ na e jidere ya mgbe ọ na-akwa iko ahụ),  
\v 14 ọ bụrụ na mmụọ ekworo abịakwasị di ya, ọ bụrụkwa na di nwanyị ahụ na-enyo nwunye ya enyo, na-ele ya anya dịka onye merụrụ onwe ya, ma ọ bụkwanụ, ọ bụrụ na di ya esite nʼekworo nyoo nwunye ya, ọ bụ ezie na nwanyị ahụ bụ onye na-emerụghị onwe ya,  
\v 15 nwoke a ga-akpọrọ nwunye ya bịakwute onye nchụaja. Ọ ga-eweta onyinye iji ịbịaru nso nʼihi nwunye ya, nke bụ iko ụtụ ọka balị abụọ a na-awụkwasịghị mmanụ, maọbụ ụda na-esi isi ụtọ a gwakọrọ agwakọ, nʼihi na ọ bụ onyinye mkpụrụ ọka e sitere nʼobi jupụtara nʼekworo nye, onyinye ịkpọtụ uche nʼikpe ọmụma. 
\p  
\v 16 “ ‘Onye nchụaja ga-akpọbata nwanyị a mee ka o guzo nʼihu \nd Onyenwe anyị\nd*.  
\v 17 \f + \fr 5:17 \ft Mmiri nsọ ahụ, na aja si nʼala ụlọ nzute ahụ, bụ ihe na-egosi ikpe ọmụma sitere nʼaka Chineke megide onye ahụ ikpe mara.\f*Ọ ga-ekunye mmiri nsọ nʼime ite aja, kporo aja nʼala site nʼụlọ nzute ahụ wụnye ya nʼime mmiri ahụ.  
\v 18 Dịka nwanyị ahụ guzo nʼihu \nd Onyenwe anyị\nd*, onye nchụaja ahụ ga-atọsa agịrị isi ya, tinye onyinye mkpụrụ ọka ncheta ahụ, nke bụ onyinye mkpụrụ ọka ekworo ahụ nʼọbụaka nwanyị a. Onye nchụaja nʼonwe ya ga-eguzo nʼihu nwanyị a jide ite mmiri ilu ahụ na-eweta ọbụbụ ọnụ.  
\v 19 Mgbe ahụ, onye nchụaja ga-eme ka nwanyị a ṅụọ iyi, mgbe ọ na-agwa ya okwu sị, “Ọ bụrụ na o nweghị nwoke ọbụla gị na ya nwere mmekọ, ọ bụrụ na ị kpafughị ghọọ onye na-adịghị ọcha mgbe ị nọ nʼụlọ di gị, ka ihe ọjọọ ọbụla ghara izute gị site na mmiri ilu a na-eweta ọbụbụ ọnụ.  
\v 20 Ma ọ bụrụ na ị kpafuola mgbe ị ka nọ nʼụlọ di gị, ọ bụrụ na i merụọla onwe gị site na idinakwuru nwoke ọzọ na-abụghị di gị,”  
\v 21 (nʼoge a, onye nchụaja ga-eme ka nwanyị a ṅụọ iyi nke ya na ọbụbụ ọnụ a so, gwa nwanyị okwu sị ya) “ka \nd Onyenwe anyị\nd* mee ka ndị ị nọ nʼetiti ha bụọ gị ọnụ ma kọchaa gị mgbe o mere ka apata gị ree ure, mgbe o mere ka afọ gị koo eko.  
\v 22 Ka mmiri ilu a, nke na-eweta ọbụbụ ọnụ banye gị nʼahụ ime ka afọ gị koo eko, imekwa ka akpanwa gị daa ada.” 
\p “ ‘Nwanyị ahụ ga-aza sị, “Amen, ya dịrị m otu a.” 
\p  
\v 23 “ ‘Mgbe ahụ onye nchụaja ahụ ga-ede ọbụbụ ọnụ ndị a nʼakwụkwọ, sanye ha nʼime mmiri ilu ahụ.  
\v 24 Mgbe ahụ, ọ ga-enye nwanyị a mmiri ilu ahụ na-eweta ọbụbụ ọnụ ka ọ ṅụọ, mmiri a ga-abanye ya nʼime ahụ, wetara ya ịta ahụhụ dị ilu.  
\v 25 Emesịa, onye nchụaja ga-anara nwanyị ahụ onyinye mkpụrụ ọka ekworo ahụ o ji nʼọbụaka ya, fegharịa ya nʼihu \nd Onyenwe anyị\nd*, buru ya gaa nʼebe ịchụ aja.  
\v 26 Onye nchụaja ga-esite nʼonyinye mkpụrụ ahụ kporo nke ga-eju ya aka, nke na-anọchite anya ha niile, suo ha ọkụ nʼelu ebe ịchụ aja. Emesịa, ọ ga-enye nwanyị ahụ mmiri ahụ ka ọ ṅụọ.  
\v 27 Ọ bụrụ na nwanyị a emerụọla onwe ya, bụrụ onye na-ekwesighị ntụkwasị obi nye di ya, mgbe ọ ṅụrụ mmiri na-eweta ọbụbụ ọnụ, ọ ga-abanye nʼime ya wetara ya ahụhụ dị ilu. Afọ ya ga-eko, buo ibu,\f + \fr 5:27 \ft Afọ ya ga-aza aza\f* akpanwa ya a gaghị anagide nwa. Ọ ga-aghọ onye a bụrụ ọnụ nʼetiti ndị ya.  
\v 28 Ma ọ bụrụ na nwanyị emerụghị onwe ya, kama ọ bụ onye dị ọcha, ọ ga-abụ onye nwere onwe ya site nʼikpe ọmụma. Ọ ga-atụrụ ime mụta ụmụ. 
\p  
\v 29 “ ‘Nke a bụ iwu metụtara ikwo ekworo mgbe nwanyị bi nʼụlọ di ya kpafuru merụọ onwe ya.  
\v 30 Maọbụ mgbe ekworo jupụtara nwoke nʼobi nʼihi na ọ gụrụ nwunye ya dịka onye na-ekwesighị ntụkwasị obi. Onye nchụaja ga-eme ka nwanyị a guzo nʼihu \nd Onyenwe anyị\nd*, mezuokwa ihe niile nʼusoro dịka e si depụta ha nʼebe a.  
\v 31 A gaghị ama di nwanyị a ikpe dịka onye mere ihe ọjọọ, kama nwanyị a ga-ebu ahụhụ ya na mmehie ya naanị ya.’ ” 
\c 6  
\s1 Onye Nazirait 
\p  
\v 1 \nd Onyenwe anyị\nd* gwara Mosis sị,  
\v 2 Gwa ndị Izrel sị ha, “Mgbe nwoke maọbụ nwanyị ṅụrụ iyi\f + \fr 6:2 \ft Ịṅụ iyi maka mkpebi ị bụ onye Nazirait bụ ihe a na-adịghị akwagide mmadụ ka o mee. Ma oge ụfọdụ, nne na nna nwantakịrị nwere ike ṅụọ iyi nʼisi nwa ha. Mgbe mmadụ họọrọ ịṅụ iyi a, ọnọdụ a nwere ike bụrụ maka nwa oge nta, ihe dịka iri abalị atọ ma ọ bụkwanụ oge ndụ ya niile. Ma mgbe nne na nna ṅụrụ iyi a nʼisi nwa ha, nwa ahụ ga-abụ onye Nazirait nʼoge ndụ ya niile. Ọ dị ọkpụrụkpụ ụzọ ihe atọ na-eso ịṅụ iyi a: Nke mbụ, onye ahụ agaghị aṅụ mmanya maọbụ detụ ihe ọṅụṅụ ọbụla na-aba nʼanya ire. Nke abụọ, dịka ọ na-adị ndụ, ọ gaghị akpụcha agịrị isi ya, ọ gaghị akpachakwa afụọnụ ya. Nke atọ, ọ gaghị emetụ ozu ọbụla aka.\f* o ji kpebie ikwe nkwa pụrụ iche nke ikewapụ onwe ya nye \nd Onyenwe anyị\nd* dịka onye Nazirait,  
\v 3 ha ga-ekewapụ onwe ha site na ịṅụ mmanya, maọbụ detụ ihe ọṅụṅụ ọbụla na-aba nʼanya ire. Ha agaghị aṅụ mmiri mkpụrụ vaịnị, ọ gaghị ata mkpụrụ vaịnị ọhụrụ maọbụ nke a mịkpọrọ amịkpọ.  
\v 4 Oge ahụ niile ọ bụ onye Nazirait,\f + \fr 6:4 \ft Onye e doro nsọ site na nkwa o kwere ikewapụ onwe ya nye Onyenwe anyị.\f* ọ gaghị eri ihe ọbụla sitere na mkpụrụ osisi vaịnị maọbụ mkpụrụ ya maọbụ okpokoro azụ ya. 
\p  
\v 5 “ ‘Nʼime oge niile nke imezu nkwa ikewapụ onwe ya nye \nd Onyenwe anyị\nd*, agụba agaghị agabiga ya nʼisi. Ọ ga-anọgide bụrụ onye dị nsọ tutu ruo oge nkwa ikewapụ onwe ya nye \nd Onyenwe anyị\nd* zuru. Nʼihi nke a, ọ ga-ahapụ agịrị isi ya ka o too. 
\p  
\v 6 “ ‘Nʼime oge niile nke imezu nkwa ikewapụ onwe ya nye \nd Onyenwe anyị\nd*, ọ gaghị aga nso mmadụ ọbụla nwụrụ anwụ,  
\v 7 ọ bụladị na nna ya, maọbụ nne ya, maọbụ nwanne ya nwoke, maọbụ nwanne ya nwanyị anwụọ. Ọ gaghị emerụ onwe ya nʼihi ha, nʼihi na akara ikewapụ onwe ya iche nye Chineke dị ya nʼisi.  
\v 8 Nʼoge niile nke ikewapụ onwe ya, onye e doro nsọ nye \nd Onyenwe anyị\nd* ka ọ bụ. 
\p  
\v 9 “ ‘Ọ bụrụ na mmadụ anwụọ na mberede nʼakụkụ onye nazirait, si otu a merụọ agịrị isi ya nke na-egosi ido nsọ ya, ọ ghaghị ịkpacha isi ya nʼụbọchị nke asaa bụ ụbọchị ime ka ọ dị ọcha.  
\v 10 Nʼụbọchị nke ọzọ ya, bụ nʼụbọchị nke asatọ. Ọ ghaghị iwetara onye nchụaja nduru abụọ maọbụ ụmụ kpalakwukwu abụọ, nʼọnụ ụzọ ụlọ nzute ahụ.  
\v 11 Onye nchụaja ahụ ga-ewere otu nʼime ha chụọrọ ya aja mmehie. Ọ ga-ewerekwa nnụnụ nke ọzọ chụọrọ ya aja nsure ọkụ maka ikpuchiri onye ahụ nwere akara ido nsọ mmehie ya, bụ nke o mere site nʼịnọ onye nwụrụ anwụ nso. Ọ ga-edokwa isi ya nsọ ọzọ nʼụbọchị ahụ.  
\v 12 Ọ ga-ekewapụ onwe ya nye \nd Onyenwe anyị\nd* dịka o mere na mmalite ụbọchị niile nke ido nsọ ya. Wetakwa otu nwa ebule gbara otu afọ maka aja ikpe ọmụma. A gaghị agụnyere ya ụbọchị ndị ahụ niile gafere tupu o merụọ onwe ya, nʼihi na o merụrụ onwe ya mgbe ọ nọ ọnọdụ imezu nkwa nkewapụ. 
\p  
\v 13 “ ‘Nke a bụ iwu dịrị onye Nazirait mgbe oge ido onwe ya nsọ nye \nd Onyenwe anyị\nd* zuru. A ga-eduru ya bịa nʼọnụ ụzọ ụlọ nzute ahụ.  
\v 14 Nʼebe ahụ ka ọ ga-anọ chee onyinye ya ndị a nʼihu \nd Onyenwe anyị\nd*: nwa ebule na-enweghị ntụpọ, gbara otu afọ, maka aja nsure ọkụ na otu nwa nne atụrụ na-enweghị ntụpọ gbara otu afọ maka aja mmehie, na otu ebule ahụ zuruoke maka aja udo,  
\v 15 tinyere aja mkpụrụ ọka, na aja ihe ọṅụṅụ na otu nkata achịcha a na-ejighị ihe na-eko achịcha mee, na achịcha e ji ezi ụtụ ọka a gwara mmanụ oliv mee, na achịcha mbadamba na-ekoghị eko nke e tere mmanụ oliv. 
\p  
\v 16 “ ‘Onye nchụaja ahụ ga-eche ihe aja ndị a niile nʼihu \nd Onyenwe anyị\nd*, chụọ aja mmehie na aja nsure ọkụ.  
\v 17 Ọ ga-eji nwa ebule ahụ chụọ aja udo nye \nd Onyenwe anyị\nd*, ya na nkata achịcha na-ekoghị eko ahụ. Ọ ga-achụkwa aja mkpụrụ ọka, na aja ihe ọṅụṅụ. 
\p  
\v 18 “ ‘Mgbe ahụ, onye ahụ doro onwe ya nsọ nye \nd Onyenwe anyị\nd* ga-akpụchapụ agịrị isi ya nke bụ ihe na-egosi ido nsọ ya. Ọ ga-eme nke a na mbata ọnụ ụzọ ụlọ nzute ahụ. Emesịa, ọ ga-etinye agịrị isi ahụ ọ kpụchapụtara nʼọkụ ahụ dị nʼokpuru aja udo ahụ. 
\p  
\v 19 “ ‘Mgbe a kpụchasịrị onye ahụ agịrị isi ya, nke na-egosi ido nsọ ya, onye nchụaja ga-ewere ubu aka ebule ahụ e sịrị esi, otu ogbe achịcha na-ekoghị eko na otu mbadamba achịcha na-ekoghị eko site na nkata ahụ, tinye ha niile nʼaka onye ahụ.  
\v 20 Onye nchụaja ahụ nʼoge a, ga-ewere aja ndị a fufee ha nʼihu \nd Onyenwe anyị\nd* dịka aja mfufe. Ha niile ga-abụ ihe nsọ nye onye nchụaja ahụ, tinyere obi anụ ahụ e fufere efufe, na apata anụ ahụ e chere nʼihu \nd Onyenwe anyị\nd*. Mgbe nke a gasịrị, onye ahụ doro onwe ya nsọ nwere onwe ya ịṅụ mmanya. 
\p  
\v 21 “ ‘Nke a bụ iwu dịrị onye ọ bụla kpebiri ikewapụ onwe ya nye \nd Onyenwe anyị\nd* dịka onye Nazirait. Onyinye onye ahụ ga-enye ga-abụ dịka nkwa ido nsọ ya si dị, tinyere ihe ndị ọzọ ha nwere ike inye. Onye dị otu a aghaghị imezu nkwa ọbụla o kwere dịka iwu metụtara onye Nazirait si dị.’ ” 
\s1 Ngọzị nke ndị nchụaja 
\p  
\v 22 \nd Onyenwe anyị\nd* gwara Mosis okwu sị,  
\v 23 “Gwa Erọn na ụmụ ya ndị ikom sị, ‘Otu a ka unu ga-esi gọzie ndị Izrel. Unu ga-asị ha, 
\q1  
\v 24 “ ‘ “\nd Onyenwe anyị\nd* gọzie unu 
\q2 ma chebe unu, 
\q1  
\v 25 \nd Onyenwe anyị\nd* mee ka ihu ya mụkwasị unu, 
\q2 ma meere unu amara,\f + \fr 6:25 \ft \xt Jen 43:29\f* 
\q1  
\v 26 \nd Onyenwe anyị\nd* chee ihu ya nʼebe unu nọ, 
\q2 nyekwa unu udo.” ’ 
\p  
\v 27 “Otu a ka ha ga-esi kwupụta aha m nye ụmụ Izrel. Mụ onwe m ga-agọzikwa ha.” 
\c 7  
\s1 Onyinye ido ụlọ nzute nsọ 
\p  
\v 1 Mgbe Mosis guzobesiri ụlọ nzute ahụ ọtọ, o tere ya mmanụ. Doo ya na ihe niile e ji chọọ ya mma nsọ. O tekwara ebe ịchụ aja mmanụ, doo ya nsọ, ya na ngwongwo ya niile.  
\v 2 Mgbe ahụ, ndị ndu Izrel, ndịisi ezinaụlọ niile, ndị bụ ndị ndu ebo niile e tinyere ọrụ ịgụ ndị ahụ niile ọnụ wetara onyinye ha.  
\v 3 Ha wetara dịka onyinye ha nye \nd Onyenwe anyị\nd* ụgbọala isii ihe juputara nʼime ha, na ehi iri na abụọ. Ndị ndu abụọ ọbụla wetara otu ụgbọala, ma ha niile nʼotu na otu wetara otu ehi, otu ehi. Ha chere ihe ndị a niile nʼihu ụlọ nzute ahụ. 
\p  
\v 4 Mgbe ahụ, \nd Onyenwe anyị\nd* gwara Mosis okwu sị ya,  
\v 5 “Nabata onyinye ndị a niile, ka e jiri ha rụọ ọrụ ụlọ nzute, were ha nyefee ndị Livayị nʼaka, onye ọbụla dịka mkpa ọrụ ya si dị.” 
\p  
\v 6 Ya mere, Mosis nabatara ụgbọala ndị ahụ na ehi ndị ahụ, nyefee ha ndị Livayị nʼaka.  
\v 7 O nyere ụmụ Geshọn ụgbọala abụọ na ehi anọ, dịka ọrụ ha si dị.  
\v 8 Nye ụmụ Merari, ụgbọala anọ na ehi asatọ, dịka ọrụ ha si dị. Ha niile nọ nʼokpuru nlekọta Itama nwa Erọn, onye nchụaja.  
\v 9 Mosis enyeghị ụmụ Kohat ihe ọbụla nʼihi na ọ bụ nʼisi mbụ aka ha ka ha ji ebu ihe nsọ ndị ahụ ha ketara ibu. 
\p  
\v 10 Ndị ndu ụmụ Izrel niile wetara onyinye ido nsọ nʼụbọchị e tere ebe ịchụ aja ahụ mmanụ ido ya nsọ. Ha wetara ha, debe ha nʼihu ebe ịchụ aja ahụ.  
\v 11 Nʼihi na Onyenwe anyị gwara Mosis okwu sị, “Ka onyendu ọbụla weta onyinye nʼụbọchị dị iche iche, otu onye, otu ụbọchị, maka ido nsọ nke ebe ịchụ aja ahụ.” 
\b  
\li4  
\v 12 Ya mere, Nashọn nwa Aminadab onye si nʼebo Juda wetara onyinye nke ya nʼụbọchị nke mbụ. 
\li1  
\v 13 Onyinye o wetara bụ: 
\li2 efere ọlaọcha nke ịdị arọ ya bụ narị shekel na iri shekel atọ, na otu efere ịkwọsa mmiri e ji ọlaedo kpụọ nke ịdị arọ ya bụ iri shekel asaa, dịka ihe ọtụtụ shekel ebe nsọ si dị. A wụjuru efere abụọ ndị a ụtụ ọka a gwara mmanụ maka onyinye mkpụrụ ọka. 
\li2  
\v 14 O wetara otu efere ọlaedo, nke ịdị arọ ya bụ shekel iri. A wụjuru efere a ụda na-esi isi ụtọ. 
\li2  
\v 15 O wetakwara otu nwa oke ehi, otu ebule, otu nwa ebule nke gbara otu afọ maka aja nsure ọkụ. 
\li2  
\v 16 O wetakwara otu mkpi maka aja mmehie, 
\li2  
\v 17 na ehi abụọ, na ebule\f + \fr 7:17 \ft Ya bụ oke atụrụ\f* ise, na mkpi ise, na ụmụ ebule ise gbara otu afọ, otu afọ, ka a chụọ maka aja udo. 
\li4 Nke a bụ onyinye Nashọn nwa Aminadab nyere. 
\b  
\li4  
\v 18 Nʼụbọchị nke abụọ, Netanel nwa Zua, onyendu ebo Isaka wetara onyinye nke ya. 
\li1  
\v 19 Onyinye o wetara bụ: 
\li2 otu efere ọlaọcha nke ịdị arọ ya bụ narị shekel na iri shekel atọ, na otu efere ịkwọsa mmiri e ji ọlaedo kpụọ, nke ịdị arọ ya bụ iri shekel asaa, efere abụọ ndị a bụ nʼusoro dịka shekel ebe nsọ si dị. A wụjuru efere ọbụla ezi ụtụ ọka a gwara mmanụ dịka onyinye mkpụrụ ọka. 
\li2  
\v 20 O wetara otu efere ọlaedo, nke ịdị arọ ya bụ shekel iri. A wụjuru efere a ụda na-esi isi ụtọ. 
\li2  
\v 21 O wetakwara otu oke ehi, otu ebule, otu nwa ebule gbara otu afọ maka aja nsure ọkụ. 
\li2  
\v 22 O wetakwara otu mkpi maka aja mmehie, 
\li2  
\v 23 na ehi abụọ, na ebule ise, mkpi ise, na ụmụ ebule ise gbara otu afọ, otu afọ, ka a chụọ maka aja udo. 
\li4 Nke a bụ onyinye Netanel nwa Zua. 
\b  
\li4  
\v 24 Nʼụbọchị nke atọ Eliab nwa Helọn onyendu ebo Zebụlọn wetakwara onyinye nke ya. 
\li1  
\v 25 Onyinye o wetara bụ: 
\li2 otu efere ọlaọcha nke ịdị arọ ya bụ narị shekel na iri shekel atọ, na otu efere ịkwọsa mmiri e ji ọlaedo kpụọ, nke ịdị arọ ya bụ iri shekel asaa, efere abụọ ndị a bụ nʼusoro dịka shekel ebe nsọ si dị. A wụjuru efere ọbụla ezi ụtụ ọka a gwara mmanụ dịka onyinye mkpụrụ ọka. 
\li2  
\v 26 O wetara otu efere ọlaedo nke ịdị arọ ya bụ shekel iri. A wụjuru efere a ụda na-esi isi ụtọ. 
\li2  
\v 27 O wetakwara otu nwa oke ehi, otu ebule, otu nwa ebule gbara otu afọ maka aja nsure ọkụ. 
\li2  
\v 28 O wetakwara otu mkpi maka aja mmehie, 
\li2  
\v 29 na ehi abụọ, na ebule ise, mkpi ise, na ụmụ ebule ise gbara otu afọ, otu afọ, ka a chụọ maka aja udo. 
\li4 Nke a bụ onyinye Eliab nwa Helọn wetara. 
\b  
\li4  
\v 30 Nʼụbọchị nke anọ, Elizọ nwa Shedeua onyendu ebo Ruben wetara onyinye nke ya. 
\li1  
\v 31 Onyinye o wetara bụ: 
\li2 otu efere ọlaọcha nke ịdị arọ ya bụ narị shekel na iri shekel atọ, na otu efere ịkwọsa mmiri e ji ọlaedo kpụọ, nke ịdị arọ ya bụ iri shekel asaa, efere abụọ ndị a bụ nʼusoro dịka shekel ebe nsọ si dị. A wụjuru efere ọbụla ezi ụtụ ọka a gwara mmanụ dịka onyinye mkpụrụ ọka. 
\li2  
\v 32 O wetara otu efere ọlaedo, nke ịdị arọ ya bụ shekel iri. A wụjuru efere a ụda na-esi isi ụtọ. 
\li2  
\v 33 O wetakwara otu oke ehi, otu ebule, otu nwa ebule gbara otu afọ maka aja nsure ọkụ. 
\li2  
\v 34 O wetakwara otu mkpi maka aja mmehie, 
\li2  
\v 35 na ehi abụọ, na ebule ise, mkpi ise, na ụmụ ebule ise gbara otu afọ, otu afọ, ka a chụọ maka aja udo. 
\li4 Nke a bụ onyinye Elizọ nwa Shedeua nyere. 
\b  
\li4  
\v 36 Nʼụbọchị nke ise Shelumiel nwa Zurishadai, onyendu ebo Simiọn butere onyinye nke ya. 
\li1  
\v 37 Onyinye o wetara bụ: 
\li2 otu efere ọlaọcha nke ịdị arọ ya bụ narị shekel na iri shekel atọ, na otu efere ịkwọsa mmiri e ji ọlaedo kpụọ, nke ịdị arọ ya bụ iri shekel asaa, efere abụọ ndị a bụ nʼusoro dịka shekel ebe nsọ si dị. A wụjuru efere ọbụla ezi ụtụ ọka a gwara mmanụ dịka onyinye mkpụrụ ọka. 
\li2  
\v 38 O wetara otu efere ọlaedo nke ịdị arọ ya bụ shekel iri. A wụjuru efere a ụda na-esi isi ụtọ. 
\li2  
\v 39 O wetakwara otu oke ehi, otu ebule, otu nwa ebule gbara otu afọ maka aja nsure ọkụ. 
\li2  
\v 40 O wetakwara otu mkpi maka aja mmehie, 
\li2  
\v 41 ehi abụọ, ebule ise, mkpi ise na ụmụ ebule ise gbara otu afọ, otu afọ, ka a chụọ maka aja udo. 
\li4 Nke a bụ onyinye Shelumiel nwa Zurishadai nyere. 
\b  
\li4  
\v 42 Nʼụbọchị nke isii, Eliasaf nwa Deuel onyendu ebo Gad butere onyinye nke ya. 
\li1  
\v 43 Onyinye o wetara bụ: 
\li2 otu efere ọlaọcha nke ịdị arọ ya bụ narị shekel na iri shekel atọ, na otu efere ịkwọsa mmiri e ji ọlaedo kpụọ, nke ịdị arọ ya bụ iri shekel asaa, efere abụọ ndị a bụ nʼusoro dịka shekel ebe nsọ si dị. A wụjuru efere ọbụla ezi ụtụ ọka a gwara mmanụ dịka onyinye mkpụrụ ọka. 
\li2  
\v 44 O wetara otu efere ọlaedo, nke ịdị arọ ya bụ shekel iri. A wụjuru efere a ụda na-esi isi ụtọ. 
\li2  
\v 45 O wetakwara otu oke ehi, otu ebule, otu nwa ebule gbara otu afọ maka aja nsure ọkụ. 
\li2  
\v 46 O wetakwara otu mkpi maka aja mmehie, 
\li2  
\v 47 na ehi abụọ, ebule ise, mkpi ise na ụmụ ebule ise gbara otu afọ, otu afọ, ka a chụọ maka aja udo. 
\li4 Nke a bụ onyinye Eliasaf nwa Deuel nyere. 
\b  
\li4  
\v 48 Nʼụbọchị nke asaa, Elishama, nwa Amihud, onyendu ebo Ifrem butere onyinye nke ya. 
\li1  
\v 49 Onyinye o wetara bụ: 
\li2 otu efere ọlaọcha nke ịdị arọ ya bụ narị shekel na iri shekel atọ, na otu efere ịkwọsa mmiri e ji ọlaedo kpụọ, nke ịdị arọ ya bụ iri shekel asaa, efere abụọ ndị a bụ nʼusoro dịka shekel ebe nsọ si dị. A wụjuru efere ọbụla ezi ụtụ ọka a gwara mmanụ dịka onyinye mkpụrụ ọka. 
\li2  
\v 50 O wetara otu efere ọlaedo, nke ịdị arọ ya bụ shekel iri. A wụjuru efere a ụda na-esi isi ụtọ. 
\li2  
\v 51 O wetakwara otu oke ehi, otu ebule, otu nwa ebule gbara otu afọ maka aja nsure ọkụ. 
\li2  
\v 52 O wetakwara otu mkpi maka aja mmehie, 
\li2  
\v 53 na ehi abụọ, ebule ise, mkpi ise na ụmụ ebule ise gbara otu afọ, otu afọ, ka a chụọ maka aja udo. 
\li4 Nke a bụ onyinye Elishama nwa Amihud nyere. 
\b  
\li4  
\v 54 Nʼụbọchị nke asatọ, Gamaliel nwa Pedazo onyendu ebo Manase nyere onyinye nke ya. 
\li1  
\v 55 Onyinye o wetara bụ: 
\li2 otu efere ọlaọcha nke ịdị arọ ya bụ narị shekel na iri shekel atọ, na otu efere ịkwọsa mmiri e ji ọlaedo kpụọ, nke ịdị arọ ya bụ iri shekel asaa, efere abụọ ndị a bụ nʼusoro dịka shekel ebe nsọ si dị. A wụjuru efere ọbụla ezi ụtụ ọka a gwara mmanụ dịka onyinye mkpụrụ ọka. 
\li2  
\v 56 O wetara otu efere ọlaedo, nke ịdị arọ ya bụ shekel iri. A wụjuru efere a ụda na-esi isi ụtọ. 
\li2  
\v 57 O wetakwara otu oke ehi, otu ebule, otu nwa ebule gbara otu afọ maka aja nsure ọkụ. 
\li2  
\v 58 O wetakwara otu mkpi maka aja mmehie, 
\li2  
\v 59 ehi abụọ, ebule ise, mkpi ise na ụmụ ebule ise gbara otu afọ, otu afọ, ka a chụọ maka aja udo. 
\li4 Nke a bụ onyinye Gamaliel nwa Pedazo nyere. 
\b  
\li4  
\v 60 Nʼụbọchị nke itoolu, Abidan nwa Gidiọn onyendu ebo Benjamin nyere onyinye nke ya. 
\li1  
\v 61 Onyinye o wetara bụ: 
\li2 otu efere ọlaọcha nke ịdị arọ ya bụ narị shekel na iri shekel atọ, na otu efere ịkwọsa mmiri e ji ọlaedo kpụọ, nke ịdị arọ ya bụ iri shekel asaa, efere abụọ ndị a bụ nʼusoro dịka shekel ebe nsọ si dị. A wụjuru efere ọbụla ezi ụtụ ọka a gwara mmanụ dịka onyinye mkpụrụ ọka. 
\li2  
\v 62 O wetara otu efere ọlaedo, nke ịdị arọ ya bụ shekel iri. A wụjuru efere a ụda na-esi isi ụtọ. 
\li2  
\v 63 O wetakwara otu oke ehi, otu ebule, otu nwa ebule gbara otu afọ maka aja nsure ọkụ. 
\li2  
\v 64 O wetakwara otu mkpi maka aja mmehie, 
\li2  
\v 65 na ehi abụọ, ebule ise, mkpi ise na ụmụ ebule ise gbara otu afọ, otu afọ, ka a chụọ maka aja udo. 
\li4 Nke a bụ onyinye Abidan nwa Gidiọni nyere. 
\b  
\li4  
\v 66 Nʼụbọchị nke iri, Ahieza nwa Amishadai, onyendu ebo Dan butere onyinye nke ya. 
\li1  
\v 67 Onyinye o wetara bụ: 
\li2 otu efere ọlaọcha nke ịdị arọ ya bụ narị shekel na iri shekel atọ, na otu efere ịkwọsa mmiri e ji ọlaedo kpụọ, nke ịdị arọ ya bụ iri shekel asaa, efere abụọ ndị a bụ nʼusoro dịka shekel ebe nsọ si dị. A wụjuru efere ọbụla ezi ụtụ ọka a gwara mmanụ dịka onyinye mkpụrụ ọka. 
\li2  
\v 68 O wetara otu efere ọlaedo, nke ịdị arọ ya bụ shekel iri. A wụjuru efere a ụda na-esi isi ụtọ. 
\li2  
\v 69 O wetakwara otu oke ehi, otu ebule, otu nwa ebule gbara otu afọ maka aja nsure ọkụ. 
\li2  
\v 70 O wetakwara otu mkpi maka aja mmehie, 
\li2  
\v 71 ehi abụọ, ebule ise, mkpi ise na ụmụ ebule ise gbara otu afọ, otu afọ, ka a chụọ maka aja udo. 
\li4 Nke a bụ onyinye Ahieza nwa Amishadai nyere. 
\b  
\li4  
\v 72 Nʼụbọchị nke iri na otu, Pagịel nwa Okran, onyendu ebo Asha butere onyinye nke ya. 
\li1  
\v 73 Onyinye o wetara bụ: 
\li2 otu efere ọlaọcha nke ịdị arọ ya bụ narị shekel na iri shekel atọ, na otu efere ịkwọsa mmiri e ji ọlaedo kpụọ, nke ịdị arọ ya bụ iri shekel asaa, efere abụọ ndị a bụ nʼusoro dịka shekel ebe nsọ si dị. A wụjuru efere ọbụla ezi ụtụ ọka a gwara mmanụ dịka onyinye mkpụrụ ọka. 
\li2  
\v 74 O wetara otu efere ọlaedo, nke ịdị arọ ya bụ shekel iri. A wụjuru efere a ụda na-esi isi ụtọ. 
\li2  
\v 75 O wetakwara otu oke ehi, otu ebule, otu nwa ebule gbara otu afọ maka aja nsure ọkụ. 
\li2  
\v 76 O wetakwara otu mkpi maka aja mmehie, 
\li2  
\v 77 na ehi abụọ, ebule ise, mkpi ise na ụmụ ebule ise gbara otu afọ, otu afọ, ka a chụọ maka aja udo. 
\li4 Nke a bụ onyinye Pagịel nwa Okran nyere. 
\b  
\li4  
\v 78 Nʼụbọchị nke iri na abụọ, Ahira nwa Enan, onyendu ebo Naftalị nyere onyinye nke ya. 
\li1  
\v 79 Onyinye o wetara bụ: 
\li2 otu efere ọlaọcha nke ịdị arọ ya bụ narị shekel na iri shekel atọ, na otu efere ịkwọsa mmiri e ji ọlaedo kpụọ, nke ịdị arọ ya bụ iri shekel asaa, efere abụọ ndị a bụ nʼusoro dịka shekel ebe nsọ si dị. A wụjuru efere ọbụla ezi ụtụ ọka a gwara mmanụ dịka onyinye mkpụrụ ọka. 
\li2  
\v 80 O wetara otu efere ọlaedo nke ịdị arọ ya bụ shekel iri. A wụjuru efere a ụda na-esi isi ụtọ. 
\li2  
\v 81 O wetakwara otu oke ehi, otu ebule, otu nwa ebule gbara otu afọ maka aja nsure ọkụ. 
\li2  
\v 82 O wetakwara otu mkpi maka aja mmehie, 
\li2  
\v 83 na ehi abụọ, ebule ise, mkpi ise na ụmụ ebule ise gbara otu afọ, otu afọ, ka a chụọ maka aja udo. 
\li4 Nke a bụ onyinye Ahira nwa Enan nyere. 
\b  
\li1  
\v 84 Ndị a bụ onyinye ndị ndu ụmụ Izrel wetara maka ido ebe ịchụ aja nsọ nʼoge e tere ya mmanụ: 
\li2 efere ọlaọcha iri na abụọ, na efere ọlaọcha ịkwọsa mmiri iri na abụọ, na efere ọlaedo iri na abụọ.  
\v 85 Ịdị arọ nke efere ọlaọcha ọbụla dị otu narị shekel na iri shekel atọ. Ịdị arọ nke efere ịkwọsa mmiri ọbụla dị iri shekel asaa. Ịdị arọ efere ọlaọcha niile ha wetara bụ puku shekel abụọ na narị shekel anọ,\f + \fr 7:85 \fq Puku shekel abụọ na narị shekel anọ \ft nke a bụ kilogram iri abụọ na asatọ\f* dịka ihe ọtụtụ shekel ebe nsọ si dị.  
\v 86 Ịdị arọ nke otu nʼime efere ọlaedo iri na abụọ ndị ahụ ụda nsure ọkụ na-esi isi ụtọ juru nʼime ha bụ iri shekel, dịka ihe ọtụtụ shekel ebe nsọ si dị. Ịdị arọ nke efere ọlaedo ndị ahụ niile bụ otu narị shekel na iri shekel abụọ. 
\li2  
\v 87 Ọnụọgụgụ anụ ụlọ niile e wetara maka aja nsure ọkụ bụ: oke ehi iri na abụọ, na ebule iri na abụọ, na ụmụ ebule iri na abụọ gbara otu afọ, otu afọ, tinyere ihe niile ha wetara maka aja mkpụrụ ọka. E ji mkpi iri na abụọ chụọ aja mmehie. 
\li2  
\v 88 Anụ ụlọ niile e ji chụọ aja udo bụ, iri oke ehi abụọ na anọ, na iri ebule isii, na iri mkpi isii, na ụmụ ebule iri isii ndị gbara naanị otu afọ, otu afọ. 
\b  
\li4 Ndị a niile bụ onyinye e nyere maka ido ebe ịchụ aja nsọ nʼoge e tere ya mmanụ. 
\b  
\p  
\v 89 Mgbe Mosis banyere nʼụlọ ikwu ahụ ka ya na Onyenwe anyị kparịa ụka, ọ nụrụ olu ahụ ka ọ na-agwa ya okwu site nʼetiti cherubim abụọ ndị ahụ nʼelu ebe mkpuchi mmehie dị nʼelu igbe iwu ọgbụgba ndụ gwa ya okwu. Nʼụzọ dị otu a ka \nd Onyenwe anyị\nd* si gwa ya okwu. 
\c 8  
\s1 Ịdọba oriọna 
\p  
\v 1 \nd Onyenwe anyị\nd* gwara Mosis okwu sị ya,  
\v 2 “Gwa Erọn okwu sị ya, ‘Mgbe ọbụla ị mụnyere oriọna asaa nke iheọkụ, ị ga-edozi ha ka ìhè ha na-enwupụta naanị nʼihu iheọkụ ahụ.’ ” 
\p  
\v 3 Erọn mere otu a. O doziri oriọna ndị ahụ ka ha chee ihu nʼihe ịdọba oriọna, dịka \nd Onyenwe anyị\nd* nyere Mosis nʼiwu.  
\v 4 Otu a ka esi mee ihe ịdọba oriọna ahụ. Ọ bụ naanị ọlaedo ka e ji kpụọ iheọkụ ahụ, site nʼụkwụ ya ruo nʼokooko niile e ji chọọ ya mma. A kpụrụ iheọkụ ahụ nʼusoro dịka oyiyi \nd Onyenwe anyị\nd* gosiri Mosis si dị. 
\s1 Ido ndị Livayị nsọ 
\p  
\v 5 Mgbe ahụ \nd Onyenwe anyị\nd* gwara Mosis okwu sị,  
\v 6 “Ugbu a, site nʼetiti ụmụ Izrel, kpọpụta ụmụ Livayị, doo ha iche, mee ha ka ha dịrị ọcha.  
\v 7 Ime ka ha dị ọcha, lee ihe ị ga-eme. Fesa ha mmiri na-asachapụ mmehie. Hụkwa na ha kpụchapụrụ ajị niile dị ha nʼahụ, ma sachaa uwe ha. Si otu a mee ka ha bụrụ ndị dị ọcha.  
\v 8 Gwa ha ka ha weta nwa oke ehi na onyinye mkpụrụ ọka, bụ ụtụ ọka a gwara mmanụ. Ha ga-ewetakwa nwa oke ehi ọzọ; ka ọ bụrụ ihe ha ji achụ aja mmehie.  
\v 9 Emesịa, kpọbata ụmụ Livayị nʼọnụ ụzọ ụlọ nzute ahụ. Meekwa ka ọgbakọ ndị Izrel niile zukọọ nʼebe ahụ.  
\v 10 Kpọpụta ndị Livayị nʼihu \nd Onyenwe anyị\nd*, ma mee ka ndị Izrel niile bikwasị ha aka ha.  
\v 11 Mgbe ahụ, Erọn ga-ewere ndị Livayị chee \nd Onyenwe anyị\nd* nʼihu dịka onyinye mfufe ndị Izrel niile na-enye ya. Nʼụzọ dị otu a, ụmụ Livayị niile ga-abụ ndị jikere ijere \nd Onyenwe anyị\nd* ozi. 
\p  
\v 12 “Emesịa, ndị Livayị ga-abịa bikwasị aka ha nʼisi oke ehi abụọ ndị ahụ jiri otu nʼime oke ehi abụọ ndị ahụ chụọ aja mmehie nye \nd Onyenwe anyị\nd*, jiri nke ọzọ chụọ aja nsure ọkụ, maka ikpuchi mmehie ndị Livayị.  
\v 13 Mgbe ahụ, mee ka ndị Livayị guzo nʼihu Erọn na ụmụ ndị ikom, werekwa ha nyefee \nd Onyenwe anyị\nd* nʼaka dịka a ga-asị na ha bụ onyinye mfufe a na-enye \nd Onyenwe anyị\nd*.  
\v 14 Otu a ka ị ga-esi doo ndị Livayị nsọ ime ka ha dịrị iche site nʼigwe ụmụ Izrel ndị ọzọ. Ọ bụ m nwe ndị Livayị. 
\p  
\v 15 “Mgbe i dosiri ndị Livayị nsọ, cheekwa ha nʼihu Onyenwe anyị dịka aja mfufe,\f + \fr 8:15 \ft \xt Ọpụ 29:24\f* ha ga-abịa nʼime ụlọ nzute ahụ ije ozi dịrị ha.  
\v 16 Ha bụ nke m site nʼetiti ụmụ Izrel niile. Anarala m ha ka ha bụrụ nke m nʼọnọdụ ụmụ niile e bụ ụzọ mụọ, nwa nwoke nke nwanyị ọbụla nʼIzrel.  
\v 17 Nʼihi na nwa nwoke mbụ ọbụla a mụrụ nʼetiti ndị Izrel bụ nke m, ma mmadụ ma anụmanụ niile. Edoro m ha nsọ nye onwe m, site nʼabalị ụbọchị ahụ m tigbusiri ụmụ niile e bụ ụzọ mụọ nʼIjipt.  
\v 18 Ewerela m ndị Livayị nʼọnọdụ ụmụ nwoke mbụ niile a mụrụ nʼIzrel.  
\v 19 Site nʼetiti ndị Izrel niile, ewerela m ndị Livayị nye Erọn na ụmụ ya ndị ikom dịka onyinye, ka ha rụọ ọrụ niile dị nʼime ụlọ nzute ahụ nʼọnọdụ ụmụ Izrel. Ka ha kpuchiere ha mmehie ha niile ka ihe otiti nke nrịa nrịa ghara ịbịakwasị ụmụ Izrel, mgbe ọbụla ha bịara nso ebe nsọ ahụ.” 
\p  
\v 20 Ya mere, Mosis na Erọn na nzukọ niile nke ụmụ Izrel chere ụmụ Livayị nʼihu \nd Onyenwe anyị\nd*, nʼusoro dịka \nd Onyenwe anyị\nd* nyere Mosis nʼiwu.  
\v 21 Ndị Livayị niile doro onwe ha ọcha, sachakwaa uwe ha niile. Erọn chere ha nʼihu \nd Onyenwe anyị\nd* dịka onyinye aja mfufe, chụọrọ ha aja ikpuchi mmehie, ime ka ha dị ọcha.  
\v 22 Nʼikpeazụ, ndị Livayị bịara ije ozi ha nʼụlọ nzute nʼokpuru Erọn na ụmụ ya ndị ikom. Ha nyekwara ndị Livayị ọrụ dịka \nd Onyenwe anyị\nd* nyere Mosis nʼiwu. 
\p  
\v 23 \nd Onyenwe anyị\nd* gwara Mosis okwu sị ya,  
\v 24 “Iwu m ndị a metụtara ndị Livayị niile. Nwoke onye Livayị ọbụla ga-ebido ịrụ ọrụ nʼụlọ nzute m mgbe ọ gbara iri afọ abụọ na ise.  
\v 25 Ọ ga-akwụsịkwa ịrụ ọrụ nʼime ya mgbe ọ gbara iri afọ ise, mgbe oge ezumike ọrụ ya ga-amalite.  
\v 26 Ha nwere ike inyere ụmụnne ha aka nʼịrụ ọrụ ha nʼime ụlọ nzute, ma ha onwe ha agaghị arụ ọrụ ahụ. Otu a ka ị ga-esi dozie ọrụ ije ozi nke ndị Livayị.” 
\c 9  
\s1 Mmemme Ngabiga 
\p  
\v 1 \nd Onyenwe anyị\nd* gwara Mosis okwu ndị a nʼọzara Saịnaị nʼọnwa mbụ nʼafọ nke abụọ site nʼoge ha hapụrụ ala Ijipt. Ọ sịrị ya,  
\v 2 “Gwa ụmụ Izrel ka ha mee Mmemme Ngabiga nʼoge a kara aka.  
\v 3 Ha mee ya nʼoge a kara aka, malite nʼuhuruchi abalị iri na anọ nke ọnwa a. Ha ga-eme ya nʼusoro dịka iwu na ụkpụrụ e ji eme ya si dị.” 
\p  
\v 4 Ya mere, Mosis gwara ndị Izrel sị ha mee Mmemme Ngabiga.  
\v 5 Ha mekwara ya nʼọzara Saịnaị malite nʼuhuruchi abalị iri na anọ nke ọnwa mbụ.\f + \fr 9:5 \ft Bụ ụbọchị ngabiga ụmụ Izrel\f* Ndị Izrel mere ihe niile nʼusoro dịka iwu \nd Onyenwe anyị\nd* nyere Mosis si dị. 
\p  
\v 6 Ma ụfọdụ nʼime ụmụ Izrel esoghị mee Mmemme Ngabiga ahụ nʼihi na ha rụrụ arụ site nʼịnọ ozu nso. Nʼihi ya, ha bịakwutere Mosis na Erọn nʼụbọchị ahụ,  
\v 7 sị Mosis, “Anyị ghọrọ ndị rụrụ arụ nʼihi ịnọ ozu mmadụ nso. Gịnị ga-egbochi anyị iso ndị Izrel ndị ọzọ iwetara \nd Onyenwe anyị\nd* onyinye nʼoge a kara aka?” 
\p  
\v 8 Mosis zara sị ha, “Cherenụ ka m ga jụta \nd Onyenwe anyị\nd* ihe bụ uche ya banyere mkpa unu.” 
\p  
\v 9 Mgbe ahụ, \nd Onyenwe anyị\nd* gwara Mosis okwu sị,  
\v 10 “Gwa ụmụ Izrel okwu sị ha, ‘Ọ bụrụ na e nwee onye Izrel ọbụla nke merụrụ onwe ya nʼoge Mmemme Ngabiga site nʼịnọ ozu mmadụ nso, maọbụ site nʼịnọ nʼije, ha nwekwara ike iso mee Mmemme Ngabiga \nd Onyenwe anyị\nd*.  
\v 11 Kama ha ga-eme ya nʼuhuruchi abalị iri na anọ nke ọnwa abụọ. Ha ga-eri nwa atụrụ ha, achịcha na-ekoghị eko,\f + \fr 9:11 \ft Achịcha nke yiist na-adịghị nʼime ya\f* na ahịhịa ilu.  
\v 12 Ha agaghị erifọ ihe ọbụla nʼime ya ruo chi ọbụbọ ụbọchị so ya. Ha agaghị agbaji ọkpụkpụ ọbụla nke nwa atụrụ ahụ. Mgbe ha mere Mmemme Ngabiga, ha ga-esorokwa ụzọ niile e si eme mmemme ahụ mee nke ha.  
\v 13 Ma ọbụla nọ nʼọnọdụ ịdị ọcha, onye nke na-anọghị nʼije nʼoge Mmemme Ngabiga ma kpachapụrụ anya hapụ isoro ndị ọzọ nʼoge mmemme a, a ga-ewezuga\f + \fr 9:13 \fq A ga-ewezuga \ft Maọbụ, \fqa a ga-egbu onye dị otu\f* ya site nʼetiti ụmụ Izrel niile, nʼihi na ọ jụrụ iwetara \nd Onyenwe anyị\nd* onyinye nʼoge a kara aka. Onye dị otu a ga-ebu ahụhụ mmehie ya nʼisi ya. 
\p  
\v 14 “ ‘Onye ọbịa bi nʼetiti unu chọrọ iso na Mmemme Ngabiga \nd Onyenwe anyị\nd*, ọ ga-eme ya nʼusoro dịka iwu na ụkpụrụ e nyere si dị. Unu ga-enwe otu iwu ahụ nye onye amụrụ nʼala na mbịarambịa.’ ” 
\s1 Igwe ojii kpuchiri ụlọ nzute 
\p  
\v 15 Nʼụbọchị ahụ e guzobere ụlọ nzute ahụ bụ ụlọ ikwu nke igbe iwu ọgbụgba ndụ ahụ, igwe ojii kpuchiri ya. Site nʼuhuruchi ruo nʼụtụtụ igwe ojii ahụ dị nʼelu ụlọ nzute ahụ dịka ọkụ nʼile anya.  
\v 16 Otu a ka ọ dịgidere mgbe niile. Igwe ojii kpuchigidere ya, ma nʼabalị ọ na-acha dị ka ọkụ.  
\v 17 Mgbe ọ bụla igwe ojii ahụ si nʼelu ụlọ nzute ahụ bilie, ụmụ Izrel na-ebuli njem, ma mgbe ọbụla igwe ojii ahụ na-anọgide, ha na-anọgidekwa.\f + \fr 9:17 \ft \xt 1Kọ 10:1\f* 
\v 18 Mgbe \nd Onyenwe anyị\nd* nyekwara iwu, ha na-akwụsị, maa ụlọ ikwu ha. Oge niile igwe ojii nọgidere nʼelu ụlọ nzute ahụ ka ụmụ Izrel na-anọgidekwa nʼụlọ ikwu ha.  
\v 19 Ọ bụrụ na igwe ojii ahụ anọọtee anya, ụmụ Izrel nʼonwe ha na-erube isi nʼiwu \nd Onyenwe anyị\nd* hapụ ịga nʼihu nʼije ha.  
\v 20 Oge ụfọdụ, igwe ojii ahụ na-anọgide naanị abalị ole na ole. Dịka iwu \nd Onyenwe anyị\nd* si dị, ha na-ama ụlọ ikwu ha, maọbụ bulie njem ha.  
\v 21 Oge ụfọdụ, igwe ojii ahụ na-anọgide naanị site nʼuhuruchi ruo nʼụtụtụ. Mgbe o si nʼelu ụlọ nzute ahụ bilie nʼụtụtụ, ụmụ Izrel na-ebuli njem ha. Ọ bụrụ nʼehihie, maọbụ nʼabalị, mgbe ọbụla igwe ojii ahụ biliri, ụmụ Izrel na-ebuli njem ha.  
\v 22 Ọ bụrụ na igwe ojii ahụ anọdụ nʼelu ụlọ nzute ahụ abalị abụọ, maọbụ otu ọnwa, maọbụ otu afọ, ụmụ Izrel na-anọgide nʼụlọ ikwu ha. Ma ngwangwa igwe ojii ahụ biliri, ha onwe ha na-ebulikwa njem ha.  
\v 23 Site nʼiwu \nd Onyenwe anyị\nd* na-enye, ha na-ama ụlọ ikwu ha, sitekwa nʼiwu \nd Onyenwe anyị\nd* nyere ha, ha na-ebili njem. Ha mere ihe niile \nd Onyenwe anyị\nd* kwuru nʼusoro dịka iwu o nyere ha site nʼọnụ Mosis si dị. 
\c 10  
\s1 Opi ọlaọcha 
\p  
\v 1 \nd Onyenwe anyị\nd* gwara Mosis okwu sị,  
\v 2 “Kpụọ opi ọlaọcha abụọ, jiri ha na-akpọ mkpọkọta nzukọ ụmụ Izrel na ime ka ha mara mgbe mbuli ije nke ọmụma ụlọ ikwu ruru.  
\v 3 Mgbe a fụrụ opi abụọ ahụ, nzukọ Izrel niile ga-ezukọta nʼihu gị nʼọnụ ụzọ ụlọ nzute.  
\v 4 Ma ọ bụrụ naanị otu opi ka a fụrụ, ọ bụ ndị ndu, ndịisi ikwu Izrel niile ga-ezukọta bịakwute gị.  
\v 5 Otu ụda opi ike ga-egosi na ebo Izrel niile mara ụlọ ikwu ha nʼakụkụ ọwụwa anyanwụ ga-ebuli ije.  
\v 6 Opi ike ahụ daa ụda nke ugboro abụọ, ọ na-egosi na ndị mara ụlọ ikwu ha na ndịda ga-ebuli ije. Ịda ụda nke opi ike bụ ihe e ji amata na oge ibuli ije eruola.  
\v 7 Mgbe a ga-akpọkọta ndị Izrel niile a ga-egbu opi, kama ụda ya ga-adị iche. 
\p  
\v 8 “Ọ bụ naanị ụmụ ndị ikom Erọn, ndị nchụaja ga-egbu opi ndị a. Nke a bụ iwu ga-adịgide nye unu site nʼọgbọ ruo nʼọgbọ niile.  
\v 9 Mgbe unu gara ibu agha nʼala unu imegide onye iro na-akpagbu unu, fụọnụ opi ike. Nke a ga-eme ka \nd Onyenwe anyị\nd* Chineke unu cheta unu, ma napụta unu site nʼaka ndị iro unu.  
\v 10 Unu ga-egbukwa opi ndị a nʼoge aṅụrị, nʼoge mmemme unu a kara aka, na nʼoge mmemme ọnwa ọhụrụ niile. Gbukwaanụ opi mgbe unu na-achụ aja nsure ọkụ unu, na aja udo unu niile. Ka ọ bụrụ ihe a ga-eji na-echeta unu nʼihu Chineke unu. Mụ onwe m bụ \nd Onyenwe anyị\nd* Chineke unu.” 
\s1 Ndị Izrel ahapụ Saịnaị 
\p  
\v 11 Nʼụbọchị iri abụọ, nʼime ọnwa nke abụọ, nʼafọ nke abụọ, igwe ojii ahụ biliri site nʼelu ụlọ nzute nke igbe iwu ọgbụgba ndụ ahụ.  
\v 12 Mgbe ahụ, ụmụ Izrel biliri ije site nʼọzara Saịnaị jegharịa site nʼotu ebe ruo nʼebe ọzọ tutu igwe ojii ahụ akwụsị nʼọzara Paran.  
\v 13 Nke a bụ njem mbụ ha mere dịka \nd Onyenwe anyị\nd* si nye Mosis iwu banyere ije ha. 
\p  
\v 14 Usuu ọmụma ụlọ ikwu nke ebo Juda buru ụzọ bulie ije a, nʼokpuru ọkọlọtọ ha. Nashọn, nwa Aminadab, bụ onyendu ha.  
\v 15 Netanel nwa Zua bụ onyendu usuu ebo Isaka.  
\v 16 Eliab nwa Helọn bụ onyendu usuu ebo Zebụlọn  
\v 17 Mgbe ahụ, e wedara ụlọ nzute ahụ. Ụmụ Geshọn na Merari buru ya, bilikwaa ije ha. 
\p  
\v 18 Usuu ọmụma ụlọ ikwu ebo Ruben biliri ije, nʼokpuru ọkọlọtọ ha. Elizọ nwa Shedeua bụ onyendu ha.  
\v 19 Shelumiel nwa Zurishadai bụ onyendu usuu ebo Simiọn.  
\v 20 Eliasaf nwa Deuel bụ onyendu usuu ebo Gad.  
\v 21 Mgbe ahụ, ụmụ Kohat ndị bu ihe nsọ ndị ahụ niile, biliri ije ha. Tutu ha erute, e guzobere ụlọ nzute ahụ nʼebe o kwesiri ịdị. 
\p  
\v 22 Usuu ọmụma ụlọ ikwu ebo Ifrem biliri ije nʼokpuru ọkọlọtọ ha. Elishama nwa Amihud bụ onyendu ha.  
\v 23 Gamaliel nwa Pedazo bụ onyendu usuu ebo Manase.  
\v 24 Abidan nwa Gidiọni bụ onyendu usuu ebo Benjamin. 
\p  
\v 25 Na ngwụsị usoro ahụ, usuu ọmụma ụlọ ikwu ebo Dan biliri ije nʼokpuru ọkọlọtọ ha. Onyendu ha bụ Ahieza nwa Amishadai.  
\v 26 Pagịel nwa Okran bụ onyendu usuu ebo Asha.  
\v 27 Ahira nwa Enan bụ onyendu usuu ebo Naftalị.  
\v 28 Nke a bụ usoro usuu ụmụ Izrel si bilie ije ha. 
\p  
\v 29 Mosis gwara Hobab nwa Reuel,\f + \fr 10:29 \ft \xt Ọpụ 2:18\f* nna nwunye ya onye Midia okwu sị, “Anyị ebiliela ije ịga ebe ahụ \nd Onyenwe anyị\nd* gwara anyị sị, ‘Aga m enye unu.’ Bịa ka ị soro anyị. Anyị ga-emezi gị nke ọma nʼihi na \nd Onyenwe anyị\nd* ekwela Izrel nkwa ọtụtụ ezi ihe.” 
\p  
\v 30 Ma ọ zara sị, “E e, agaghị m eso unu. Ana m alaghachi nʼala nke aka m ịlaghachikwuru ụmụnna m.” 
\p  
\v 31 Ma Mosis zara sị ya, “Biko ahapụla anyị nʼihi na ị maara ebe anyị nwere ike kwụsị zuo ike nʼọzara. Ị ga-abụrụ anyị anya anyị ji ahụ ụzọ.  
\v 32 Ọ bụrụ na i soro anyị, anyị ga-ekenye gị ihe ọma ọbụla \nd Onyenwe anyị\nd* ga-enye anyị.” 
\p  
\v 33 Ya mere ha sitere nʼugwu \nd Onyenwe anyị\nd* bilie ije. Jeekwa ije abalị atọ. Igbe ọgbụgba ndụ \nd Onyenwe anyị\nd* na-aga ha nʼihu ụbọchị atọ ndị ahụ niile ịchọtara ha ebe ha ga-akwụsị zuo ike.  
\v 34 Igwe ojii \nd Onyenwe anyị\nd* dị nʼelu ha nʼehihie mgbe ha si nʼọmụma ụlọ ikwu ha bilie ije. 
\p  
\v 35 Mgbe ọbụla igbe ọgbụgba ndụ ahụ biliri ije, Mosis na-ekwu sị, 
\q1 “Bilie O \nd Onyenwe anyị\nd*, 
\q2 ka ndị iro ya bụrụ ndị a chụsasịrị; 
\q2 ka ndị iro gị niile site nʼihu gị gbalaga.” 
\p  
\v 36 Ma mgbe ọbụla igbe ọgbụgba ndụ bịara ebe izuike, Mosis na-ekwukwa sị, 
\q1 “Lọghachi O \nd Onyenwe anyị\nd*, 
\q2 bịakwute ọtụtụ mmadụ ndị a, bụ imerime puku ndị Izrel.” 
\c 11  
\s1 Ọkụ si nʼebe \nd Onyenwe anyị\nd* nọ 
\p  
\v 1 Mgbe na-adịghị anya ụmụ Izrel bidoro itamu ntamu nʼihi ihe ike niile ha na-ezute nʼije ha. Ma ntamu a ruru \nd Onyenwe anyị\nd* ntị. Nʼihi ya, \nd Onyenwe anyị\nd* were iwe dị ukwuu megide ha. Ọkụ sitere nʼebe \nd Onyenwe anyị\nd* nọ, ree nʼetiti ha, repịa ụfọdụ ndị bi nʼakụkụ ngwụsị ọmụma ụlọ ikwu ahụ.  
\v 2 Mgbe nke a mere, ụmụ Izrel tikuru Mosis mkpu akwa. Mosis kpere ekpere nye \nd Onyenwe anyị\nd* nʼihi ha, ọkụ ahụ kwụsịkwara.  
\v 3 Nʼihi ya, a kpọrọ ebe ahụ Tabera, nʼihi ọkụ ahụ si nʼebe \nd Onyenwe anyị\nd* nọ ree nʼetiti ha. 
\s1 \nd Onyenwe anyị\nd* ezite nnụnụ kweel 
\p  
\v 4 Ndị amakekwu so ụmụ Izrel nʼije a malitere itamu ntamu banyere nri ndị ọzọ na-agụ ha agụụ. Nke a mere ka ụmụ Izrel malite ịkwa akwa, na-asị, “A sịkwarị na anyị nwere anụ anyị ga-ata.  
\v 5 Anyị chetara azụ anyị tara nʼIjipt, nke na-adịghị efu anyị ego, ya na kukumba, na melọn,\f + \fr 11:5 \ft Nke a bụ wọta melọn.\f* na liik, na ayo\f + \fr 11:5 \ft Maọbụ, \fqa yabasị\f* na galiik.  
\v 6 Ma ugbu a, anyị enweghịkwa agụụ iri nri, nʼihi na site nʼụbọchị ruo nʼụbọchị, ọ bụ naanị mánà bụ ihe oriri anyị nwere.” 
\p  
\v 7 Mánà dịka mkpụrụ kọrianda, na-acha ka eso osisi kpọrọ nkụ.  
\v 8 Ndị Izrel na-ejegharị na-achịkọta ha. Emesịa, ha na-eji nkume e ji akwọ nri na-akwọri ha. Oge ụfọdụ, ha na-eji ikwe nri sụọ ya. Emesịa, ha na-esi ya esi, maọbụ ghee ya eghe. Ọ na-atọ dịka ihe e ji mmanụ oliv ghee.  
\v 9 Mánà ndị a na-ada mgbe igirigi dara nʼọmụma ụlọ ikwu nʼabalị. 
\p  
\v 10 Mosis nụrụ mkpu akwa ụmụ Izrel niile, nke na-ada nʼezinaụlọ ọbụla nʼakụkụ ọnụ ụzọ ụlọ ikwu ha. Iwe were \nd Onyenwe anyị\nd* nke ukwuu. Otu a kwa, obi jọrọ Mosis njọ nke ukwuu.  
\v 11 Mosis jụrụ \nd Onyenwe anyị\nd* sị, “Gịnị mere i ji bokwasị ohu gị nsogbu dị otu a nʼisi? Gịnị ka m mere na m ahụtakwaghị amara nʼebe ị nọ, nke mere i ji bukwasị m ibu arọ nke ilekọta ndị a?  
\v 12 Ọ bụ m tụrụ ime ndị a niile? Ọ bụ m mụrụ ha? Gịnị mere i ji si m kuru ha nʼaka m gawa nʼala ahụ ị ṅụrụ nʼiyi inye nna nna ha,\f + \fr 11:12 \ft \xt Jen 13:5\f* dịka m bụ nne nwa na-ekugharị nwantakịrị?  
\v 13 Ebee ka m ga-achọta anụ ga-ezuru igwe mmadụ ndị a? Lee na ha na-akwasa m akwa na-asị m, ‘Nye anyị anụ!’  
\v 14 Agaghị m ebulite ibu ịchịkọta ndị a niile nʼonwe m! Ibu a dị m arọ nke ukwuu.  
\v 15 Ọ bụrụ na ị ga-esi otu a meso m mmeso, biko napụ m ndụ m ugbu a, nʼihi na ọnwụ m ga-egosi na m natara amara nʼebe ị nọ. Site nʼọnọdụ a ga-ewetara m mbibi wezuga m.” 
\p  
\v 16 Mgbe ahụ, \nd Onyenwe anyị\nd* gwara Mosis okwu sị ya, “Kpọkọta iri ndị okenye ụmụ Izrel asaa, ndị ị maara na ha bụ ndị ndu, na ndị nlekọta ije ozi nʼetiti ụmụ Izrel. Kpọta ha nʼụlọ nzute m ka ha soro gị guzoro.  
\v 17 Aga m abịa nʼebe ahụ gwa gị okwu. Mgbe ahụ kwa, aga m ewere ụfọdụ nʼime Mmụọ m dị nʼime gị tinye nʼime iri ndị ndu asaa ahụ. Ha ga-enyere gị aka ibu ibu arọ nke ịchịkọta ụmụ Izrel. Nʼụzọ dị otu a, ọ gaghị abụkwa ibu dịrị naanị gị ibu. 
\p  
\v 18 “Ugbu a, gwa ndị Izrel niile si ha, ‘Doonụ onwe unu nsọ, kwadoonụ maka echi, mgbe unu ga-ata anụ. \nd Onyenwe anyị\nd* nụrụ mgbe unu kwara akwa sị, “A sịkwa na anyị nwere anụ anyị ga-ata. Ihe dịrị anyị mma nʼIjipt karịa otu ọ dị ugbu a.”  
\v 19 Anụ unu ga-eri abụghị naanị nke otu ụbọchị, maọbụ ụbọchị abụọ, maọbụ ụbọchị ise, maọbụ iri, ma ọ bụkwanụ iri ụbọchị abụọ!  
\v 20 Kama unu ga-eri ya otu ọnwa zuru ezu, ruo mgbe ọ ga-esi unu nʼimi sọpụta, ghọrọ unu ihe ịsọ oyi. Nʼihi na unu ajụla \nd Onyenwe anyị\nd*, onye nọ nʼetiti unu, kwaa akwa nʼihu ya, sị, “Gịnị mere anyị ji site nʼala Ijipt pụta?” ’ ” 
\p  
\v 21 Ma Mosis sịrị \nd Onyenwe anyị\nd*, “Ọnụọgụgụ ndị ikom dị narị puku isii\f + \fr 11:21 \ft Ya bụ, 600,000\f* ndị ji ụkwụ eje ka m nọ nʼetiti ha, ma ị na-asị, ‘Aga m enye ha anụ otu ọnwa.’  
\v 22 Ọ ga-ezuru ha ma ọ bụrụ na e gbuoro ha igwe ehi na atụrụ? Ọ bụ azụ niile nke dị nʼoke osimiri ga-ezuru ha ma egbuo ha niile nye ha?” 
\p  
\v 23 \nd Onyenwe anyị\nd* sịrị Mosis, “Aka \nd Onyenwe anyị\nd* ọ dị mkpụmkpụ? Ugbu a, ị ga-ahụ ma m ga-emezu okwu m, maọbụ na m agaghị emezu ya.” 
\p  
\v 24 Ya mere, Mosis pụrụ ga gwa ụmụ Izrel ihe \nd Onyenwe anyị\nd* kwuru. Ọ chịkọtara iri ndị okenye asaa ahụ nye ha ọnọdụ gburugburu ụlọ nzute ahụ.  
\v 25 Mgbe ahụ, \nd Onyenwe anyị\nd* rịdatara nʼime igwe ojii. Ya na Mosis kparịtaa ụka. \nd Onyenwe anyị\nd* weere ụfọdụ nʼime Mmụọ dị nʼime Mosis, tinye ya nʼime iri ndị okenye asaa ndị ahụ. Mgbe Mmụọ a batara nʼime ha, ha niile buru amụma. Ma ha ebughị amụma gaa nʼihu. 
\p  
\v 26 Ma mmadụ abụọ nʼime iri ndị okenye asaa ndị ahụ, Eldad na Medad nọgidere nʼọmụma ụlọ ikwu ha. Ọ bụ ezie na e depụtara aha ha dịka ndị ndu, ma ha esoghị ndị ọzọ gaa nʼụlọ nzute. Ma Mmụọ ahụ bịakwasịrị ha nʼebe ahụ ha nọ. Ha bukwara amụma.  
\v 27 Otu okorobịa gbapụrụ ọsọ gaa kọọrọ Mosis sị ya, “Eldad na Medad na-ebu amụma nʼọmụma ụlọ ikwu ha.” 
\p  
\v 28 Joshua nwa Nun, onyeozi Mosis site na mgbe ọ bụ okorobịa, gwara Mosis okwu sị ya, “Onyenwe m Mosis, mee ka ndị a kwụsị ibu amụma.” 
\p  
\v 29 Ma Mosis zara sị, “Ọ bụ nʼihi ikwochitara m ekworo ka i ji chọọ ka m kwụsị ha? Ọ gaara atọ m ụtọ ma a sị na ndị \nd Onyenwe anyị\nd* niile bụ ndị amụma, ndị \nd Onyenwe anyị\nd* ga-etinye Mmụọ ya nʼime ha!”  
\v 30 Mgbe ahụ Mosis na ndị okenye Izrel ndị ahụ niile lọghachiri nʼebe ụlọ ikwu ha dị. 
\p  
\v 31 Otu oke ifufe sitere nʼebe \nd Onyenwe anyị\nd* nọ bịa si nʼosimiri bute ọtụtụ nnụnụ a na-akpọ kweel. O mere ka nnụnụ ndị a daa nʼebe ụmụ Izrel mara ụlọ ikwu ha, nʼime ogige ya niile. Nnụnụ ndị a fere ihe dịka otu mita site nʼelu ala, nʼakụkụ niile, ruo nʼebe mmadụ pụrụ iji ụkwụ jeruo nʼotu ụbọchị. Ha jupụtakwara ebe niile.  
\v 32 Ya mere ndị Izrel biliri ụbọchị ahụ niile, na nʼabalị ahụ niile, na echi ya niile pụọ ịchịkọta nnụnụ kweel ndị a! Onye gbutere nke nta gbutezuru ihe ọtụtụ homa iri. Ha gbasara ha akụkụ niile nke ogige ọmụma ụlọ ikwu ahụ.  
\v 33 Ma mgbe anụ ndị a ka dị ha nʼọnụ, \nd Onyenwe anyị\nd* were iwe dị ukwuu megide ha. O tiri ha nrịa nrịa na-efe efe.  
\v 34 Nʼihi nke a, a kpọrọ aha ebe ahụ Kibrọt Hataava, nʼihi na nʼebe ahụ ka e liri ndị Izrel nwụrụ nʼihi oke ọchịchọ nri. 
\p  
\v 35 Site na Kibrọt Hataava, ndị Izrel biliri njem rute Hazerọt ebe ha nọrọ. 
\c 12  
\s1 Miriam na Erọn eguzo megide Mosis 
\p  
\v 1 Miriam na Erọn malitere ikwu okwu megide Mosis, nʼihi na ọ lụrụ nwunye onye Kush.  
\v 2 Ha kwuru sị, “Ọ bụ naanị site nʼọnụ Mosis ka \nd Onyenwe anyị\nd* si agwa ndị ya okwu? Ọ naghị esitekwa nʼọnụ anyị kwuo okwu?” \nd Onyenwe anyị\nd* nụrụ ihe ndị a ha kwuru. 
\p  
\v 3 (Ma nwoke ahụ bụ Mosis dị umeala nʼobi nke ukwuu karịa onye ọbụla nọ nʼelu ala.) 
\p  
\v 4 Na mberede, \nd Onyenwe anyị\nd* sịrị Mosis, na Erọn, na Miriam, “Pụtanụ, bịa nʼụlọ nzute, unu mmadụ atọ” Ya mere ha atọ pụtara.  
\v 5 Mgbe ahụ, \nd Onyenwe anyị\nd* rịdatara nʼime igwe ojii, guzoro na mbata ọnụ ụzọ ụlọ nzute ahụ, kpọpụta Erọn na Miriam. Mgbe ha abụọ bịara nso.  
\v 6 \nd Onyenwe anyị\nd* gwara ha sị, “Geenụ ntị nʼokwu m ndị a: 
\q1 “Mgbe onye amụma nọ nʼetiti unu, 
\q2 Mụ onwe m bụ \nd Onyenwe anyị\nd* na-egosi ya onwe m site nʼọhụ. 
\q2 Ana m agwa ya okwu site na nrọ. 
\q1  
\v 7 Ma nʼebe ohu m Mosis nọ, o sighị otu a dịrị, 
\q2 ọ bụ onye kwesiri ntụkwasị obi nʼụlọ m niile. 
\q1  
\v 8 Nʼebe ọ nọ, ana m agwa ya okwu ihu na ihu 
\q2 nʼụzọ doro anya, ọ bụghị site nʼilu, 
\q2 ọ na-ahụkwa ụdịdị \nd Onyenwe anyị\nd*. 
\q1 Gịnị mere ụjọ atụghị unu 
\q2 ikwu okwu megide ohu m Mosis?” 
\p  
\v 9 Mgbe ahụ, \nd Onyenwe anyị\nd* were iwe dị ọkụ megide ha. O si nʼebe ha nọ pụọ. 
\p  
\v 10 Ma mgbe igwe ojii ahụ hapụrụ ụlọ nzute ahụ, lee Miriam ebe o guzo, ekpenta tiwapụtara ya nʼahụ dịka nzu ọcha. Mgbe Erọn tụgharịrị ebe ọ nọ hụ na ọ ghọọla onye ekpenta,  
\v 11 ọ gwara Mosis okwu sị, “Biko, onyenwe m, atala anyị ahụhụ nʼihi mmehie anyị sitere na nzuzu mee.  
\v 12 Ekwela ka Miriam dịrị ka nwa ọhụrụ nwụrụ anwụ nke akpụkpọ ahụ ya rere ure nʼoge o si nʼakpanwa nne ya na-apụta.” 
\p  
\v 13 Ya mere Mosis tikuru \nd Onyenwe anyị\nd* mkpu akwa sị ya, “Chineke, biko, gwọọ ya!” 
\p  
\v 14 Ma \nd Onyenwe anyị\nd* zara Mosis sị ya, “Ọ bụrụ na nna ya gbụrụ ya asụ nʼihu, ọ gaghị abụ onye rụrụ arụ abalị asaa? Ya mere, hapụ ya ka ọ bụrụ onye e sitere nʼogige ọmụma ụlọ ikwu Izrel wezuga abalị asaa. Mgbe oge a gafesịrị, o nwere ike ịlọghachi.”  
\v 15 Ya mere e wezugara Miriam site nʼogige ọmụma ụlọ ikwu Izrel abalị asaa. Ndị Izrel niile nọdụrụ chere ya ruo mgbe ọ lọghachiri, tutu ha ebilie nʼije ọzọ. 
\p  
\v 16 Mgbe ihe ndị a gasịrị, ha hapụrụ Hazerọt rute nʼọzara Paran ebe ha wuru ogige ụlọ ikwu ha. 
\c 13  
\s1 Nledo ala Kenan 
\p  
\v 1 \nd Onyenwe anyị\nd* gwara Mosis okwu sị ya,  
\v 2 “Ziga ụfọdụ ndị ikom ka ha gaa legharịa anya nʼala Kenan, ala ahụ m na-enye Izrel. Ziga mmadụ iri na abụọ, otu onyendu site nʼebo Izrel ọbụla.” 
\p  
\v 3 Ya mere, dịka iwu \nd Onyenwe anyị\nd* nyere ya si dị, Mosis zipụrụ ha site nʼọzara Paran. Ha niile bụ ndị ndu nʼetiti ụmụ Izrel. 
\b  
\li4  
\v 4 Nke a bụ aha ha: 
\b  
\li1 Site nʼebo Ruben, Shamua nwa Zakua, 
\li1  
\v 5 Shafat nwa Hori, onye si nʼebo Simiọn. 
\li1  
\v 6 Kaleb nwa Jefune, onye si nʼebo Juda. 
\li1  
\v 7 Igal nwa Josef, onye si nʼebo Isaka. 
\li1  
\v 8 Hoshea nwa Nun, onye si nʼebo Ifrem 
\li1  
\v 9 Palti nwa Rafu, onye si nʼebo Benjamin. 
\li1  
\v 10 Gadiel nwa Sodi, onye si nʼebo Zebụlọn. 
\li1  
\v 11 Gadi nwa Susi, onye sitere nʼebo Manase (ya bụ ebo Josef). 
\li1  
\v 12 Amiel nwa Gemali, onye si nʼebo Dan. 
\li1  
\v 13 Setua nwa Maikel, onye si nʼebo Asha. 
\li1  
\v 14 Nabi nwa Vofusi, onye si nʼebo Naftalị. 
\li1  
\v 15 Geuel nwa Maki, onye si nʼebo Gad. 
\b  
\li4  
\v 16 Ndị a bụ aha ndị ikom ndị ahụ Mosis zipụrụ inyocha ala ahụ. (Ọ bụ nʼoge a ka Mosis gbanwere aha Hoshea nwa Nun, ka ọ bụrụ Joshua.) 
\b  
\p  
\v 17 Mosis zipụrụ ha ịga ledoo ala Kenan, ọ sịrị, “Gbagoonụ site nʼụzọ Negev gakwanụ nʼala ugwu ugwu.  
\v 18 Letanụ otu ala ahụ dị. Chọpụtanụ ụdị ndị bi nʼime ya, ma ha dị ike ma ha bụ ndị na-adịghị ike, ma ha dị ọtụtụ ma ha dị ole na ole.  
\v 19 Letanụ ụdị ala ha bi nʼime ya, ma ọ dị mma ma ọ jọrọ njọ. Chọpụtanụ ụdị obodo dị nʼebe ahụ, ma ha bụ obodo mgbidi na-adịghị gburugburu ha, ma ha bụ obodo e wusiri ike.  
\v 20 Letanụ otu ala ahụ dị. Ọ na-epupụta ihe ka ọ bụ ala ụkpa? Letanụ ma ha nwere ọtụtụ osisi ka ọ bụ na osisi adịghị nʼime ya. Gbalịanụ ka unu weta ụfọdụ nʼime mkpụrụ osisi dị nʼala ahụ.” (Ọ bụ oge mkpụrụ mbụ nke osisi vaịnị.) 
\p  
\v 21 Ya mere ndị a gara ledoo ala ahụ anya site nʼọzara Zin ruo na Rehob, nke dị nso na Lebo Hamat.  
\v 22 Ha gara site na Negev rute Hebrọn, ebe Ahiman na Sheshai na Talmai, ụmụ ụmụ Anak bi. (Ma ewuru Hebrọn afọ asaa tupu e wuo obodo Zoan dị nʼIjipt.)  
\v 23 Mgbe ha rutere Ndagwurugwu Eshkọl,\f + \fr 13:23 \fq Eshkọl \ft pụtara \fqa Ụyọkọ \ft nke a dịkwa nʼamaokwu nke \xt 13:24\f* ha gbutere otu alaka osisi vaịnị nke nwere ụyọkọ mkpụrụ vaịnị. Mmadụ abụọ butere ya nʼosisi tinyere ụfọdụ mkpụrụ osisi pomegranet na fiig.  
\v 24 A kpọrọ ebe ahụ Ndagwurugwu Eshkọl, nʼihi ụyọkọ mkpụrụ osisi vaịnị ndị Izrel gbutere nʼebe ahụ.  
\v 25 Mgbe iri abalị anọ gasịrị, ndị nledo a sitere nʼije ha lọghachi. 
\s1 Akụkọ ndị nledo ala ahụ 
\p  
\v 26 Ha lọtara bịakwute Mosis na Erọn na nzukọ niile nke ụmụ Izrel, na Kadesh nke dị nʼọzara Paran. Ndị nledo ahụ kọrọ akụkọ otu ha si gaa nʼọgbakọ ụmụ Izrel niile. Gosikwa mkpụrụ osisi si nʼala ahụ.  
\v 27 Nke a bụ akụkọ ha kọọrọ Mosis, “Anyị ruru nʼala ahụ ị sị anyị gaa leta. Ọ bụkwa ala mmiri ara ehi na mmanụ aṅụ na-eru na ya. Ndị a bụ mkpụrụ osisi si nʼala ahụ.  
\v 28 Ma ndị bi nʼobodo ahụ siri ike. Obodo ha buru ibu bụrụkwa nke e wusiri ike. Anyị hụkwara ụmụ ụmụ Anak nʼebe ahụ.  
\v 29 Ndị Amalek bi na Negev, ndị Het na ndị Jebus na ndị Amọrait bi nʼala ugwu ugwu. Ma nʼakụkụ osimiri Mediterenịan na ndagwurugwu mmiri Jọdan ka ndị Kenan bi.” 
\p  
\v 30 Ma Kaleb kwuru okwu mere ka obi sie ndị Izrel ike nʼoge a ha guzoro nʼihu Mosis sị ha, “Ka anyị gaanụ otu ihu nweta ala ahụ. Nʼihi na anyị nwere ike imeri ha.” 
\p  
\v 31 Ma ndị nledo ahụ soro ya gaa zara sị, “Anyị enweghị ike ibu agha megide ndị a; ha dị ike karịa anyị.”  
\v 32 Ndị a gbasara akụkọ ọjọọ nʼetiti ụmụ Izrel banyere ala ahụ ha gara ledoo. Ha sịrị, “Ala ahụ anyị gara ledoo anya bụ ala na-eripịa ndị bi nʼime ya. Ndị niile anyị hụrụ nʼebe ahụ gbara nnọọ dimkpa  
\v 33 Anyị hụrụ ndị Nefilim nʼebe ahụ (ndị bụ ụmụ ụmụ Anak, ndị sitere na ndị Nefilim). Nʼanya anyị, anyị dịka ụkpana nʼebe ha nọ, otu a ka anyị dịkwa nʼanya ha.” 
\c 14  
\s1 Nnupu isi nke ụmụ Izrel 
\p  
\v 1 Nʼabalị ahụ, ọgbakọ Izrel niile weliri olu ha bido iti mkpu akwa. Ha kwagidere akwa a abalị niile.  
\v 2 Ndị Izrel niile tamuru ntamu megide Mosis na Erọn. Ọgbakọ ahụ niile sị ha, “Ọ gaara aka mma ma a sị na anyị nwụrụ nʼala Ijipt maọbụ nʼọzara a.  
\v 3 Gịnị mere \nd Onyenwe anyị\nd* ji akpọbata anyị nʼala a ime ka anyị daa nʼihu mma agha. Ndị nwunye anyị na ụmụ anyị ga-aghọ ndị a dọtara nʼagha. Ọ garaghị akara anyị mma ịlaghachi azụ nʼIjipt?”  
\v 4 Ya mere ha kwekọrịtara nʼetiti onwe ha sị, “Ka anyị họpụtaranụ onwe anyị onyendu ga-edughachi anyị azụ nʼIjipt.” 
\p  
\v 5 Mgbe ahụ, Mosis na Erọn dara kpuo ihu nʼala nʼihu ọgbakọ ndị Izrel niile zukọtara nʼebe ahụ.  
\v 6 Mmadụ abụọ nʼime ndị nledo ahụ, Joshua nwa Nun na Kaleb nwa Jefune, dọwara uwe\f + \fr 14:6 \ft Mgbe mmadụ dọwara uwe ya, nke a na-egosipụta ọnọdụ iru ụjụ na iwe.\f* ha.  
\v 7 Ha gwara nzukọ Izrel sị, “Ala ahụ anyị gara ledoo anya bụ ala mara mma.  
\v 8 Ọ bụrụ na ihe banyere anyị na-atọ \nd Onyenwe anyị\nd* ụtọ, ọ ga-edu anyị bata nʼala ahụ, ala mmiri ara ehi na mmanụ aṅụ na-eru na ya.  
\v 9 Unu enupukwala isi megide \nd Onyenwe anyị\nd*. Unu atụkwala egwu ndị bi nʼime ala ahụ, nʼihi na anyị ga-emeri ha. \nd Onyenwe anyị\nd* nọnyeere anyị. O wepụkwala aka nchebe ya nʼahụ ha. Unu atụla egwu ha.” 
\p  
\v 10 Ma naanị nzaghachi ọgbakọ ndị Izrel nyere nʼihi okwu nkasiobi ndị a bụ iche uche otu ha ga-esi jiri nkume tugbuo Joshua na Kaleb. Nʼoge a, ebube \nd Onyenwe anyị\nd* pụtara ihe nʼụlọ nzute ahụ nye ndị Izrel niile.  
\v 11 \nd Onyenwe anyị\nd* gwara Mosis okwu sị, “Ruo ole mgbe ka ndị a ga-anọgide na-eleda m anya? Ruo ole mgbe ka ha ga-anọ ju ikwenye na m, nʼagbanyeghị ọtụtụ ihe ịrịbama nke m mere nʼetiti ha.  
\v 12 Aga m eji nrịa nrịa nke na-efe efe tigbuo ha. Napụ ha ihe ha nwere. Ma aga m emekwa gị ka ị ghọọ mba dị ukwuu, nke ga-adị ukwuu, dịkwa ike karịa ha.” 
\p  
\v 13 Ma Mosis rịọrọ \nd Onyenwe anyị\nd* sị ya, “Gịnị ka ndị Ijipt ga-eche banyere nke a, mgbe ha ga-anụ ya? Ha maara nke ọma otu ị sịrị jiri ike gị napụta ndị a site nʼetiti ha.  
\v 14 Ha agwakwala ndị bi nʼobodo ndị a ihe banyere ya. Ndị obodo ndị a anụla ihe banyere gị \nd Onyenwe anyị\nd*, matakwa na ị nọnyeere Izrel, na gị bụ \nd Onyenwe anyị\nd* na ndị Izrel na-ekwurịta okwu ihu na ihu. Ha anụkwala na ogidi igwe ojii gị \nd Onyenwe anyị\nd* na-eguzo nʼelu, nʼisi anyị. Ha matakwara na ị na-edu anyị nʼime ogidi igwe ojii nʼehihie, na nʼime ogidi na-enwu ọkụ nʼabalị.  
\v 15 Ma ugbu a, ọ bụrụ na i gbusie ndị gị a dum, mba niile nụrụla akụkọ ndị a banyere gị ga-asị,  
\v 16 ‘\nd Onyenwe anyị\nd* enweghị ike ịkpọbata ndị a nʼala ahụ o kwere nkwa inye ha. Ọ bụ ya mere o ji gbuo ha nʼọzara.’ 
\p  
\v 17 “Ugbu a ka Onyenwe anyị gosi ike ya dị ukwuu, dịka i si kwuo.  
\v 18 \nd Onyenwe anyị\nd* bụ onye na-adịghị ewe iwe ọsịịsọ, onye jupụtara nʼịhụnanya, onye na-agbaghara mmehie na nnupu isi. Ma ọ dịghị ahapụ onye ikpe mara ka ọ laa na-anataghị ahụhụ, ọ na-ata ụmụ ahụhụ nʼihi mmehie nna nna ha ruo nʼọgbọ nke atọ na nke anọ.  
\v 19 Dịka ịdị ukwuu nke ịhụnanya gị si dị; gbaghara mmehie nke ndị a mere, dịka i si agbaghara ha kemgbe ha hapụrụ Ijipt ruo ugbu a.” 
\p  
\v 20 Mgbe ahụ, \nd Onyenwe anyị\nd* zaghachiri Mosis sị ya, “Agbagharala m ha dịka ị rịọrọ.  
\v 21 Ma dịka m na-adị ndụ na dịka ọ bụ eziokwu na ụwa niile ga-ejupụta nʼebube \nd Onyenwe anyị\nd*.  
\v 22 Ọ dịghị otu onye nʼetiti ndị ikom niile hụrụla ebube m, na ọrụ ịrịbama niile m rụrụ nʼime Ijipt, na nʼime ọzara a, ma bụrụ onye nupuru isi nye m na onye nwaara m ugboro iri ndị a,  
\v 23 o nweghị onye ọbụla nʼime ha ga-ahụ ala ahụ m sitere nʼịṅụ iyi kwee nkwa inye nna nna ha. O nweghị onye ọbụla nʼime ndị a lelịrị m ga-ahụ ala ahụ anya.  
\v 24 Ma ohu m nwoke Kaleb bụ nwoke nwere mmụọ dị iche. O rubeere m isi nʼihe niile. Aga m akpọbata ya nʼala ahụ ọ banyere dịka onye nledo. Ụmụ ụmụ ya niile ga-eketa ya.  
\v 25 Ma ugbu a, ebe ndị Izrel na-atụ ndị Amalek na ndị Kenan bi nʼime ndagwurugwu ahụ egwu, echi, unu ga-atụgharịa laghachi azụ nʼọzara ahụ; chee ụzọ gaje Osimiri Uhie ahụ ihu.” 
\p  
\v 26 \nd Onyenwe anyị\nd* gwara Mosis na Erọn okwu sị,  
\v 27 “Ruo ole mgbe ka ọgbakọ ọjọọ a ga-anọgide na-atamu ntamu megide m? Nʼihi na anụla m ntamu niile nke ndị Izrel a.  
\v 28 Gwa ha si, ‘Dị ka m na-adị ndụ, ka \nd Onyenwe anyị\nd* kwubiri, aga m emeso unu mmeso dịka unu kwunyere ya na ntị m.  
\v 29 Unu niile ga-anwụpịa nʼime ọzara a! Onye ọbụla nʼime unu niile gbarala iri afọ abụọ maọbụ karịa, nke tamuru ntamu megide m.  
\v 30 O nweghị onye ọbụla nʼime unu ga-abanye nʼala ahụ, m sitere nʼaka m welie elu ṅụọ iyi ime ka ọ bụrụ ebe obibi unu, karịa Kaleb nwa Jefune na Joshua nwa Nun.  
\v 31 Ma ebe unu tụrụ egwu sị na ụmụ unu na-aga ibu ndị ohu nye ndị bi nʼala ahụ. Lee na aga m edubata ha nʼime ala ahụ. Ha ga-eketakwa ala ahụ unu jụrụ, nke unu ledara anya.  
\v 32 Ma unu onwe unu, ozu unu ga-ada aghara aghara nʼọzara a.  
\v 33 Ụmụ unu ga-abụkwa ndị ọzụzụ atụrụ nʼime ọzara a iri afọ anọ, na-ata ahụhụ nʼihi ekwesighị ntụkwasị obi, ruo mgbe ozu onye ikpeazụ nʼime unu ga-atọgbọrọ nʼime ọzara.  
\v 34 Iri afọ anọ ka unu ga-ata ahụhụ nʼihi mmehie unu, matakwa ihe ọ pụtara bụ mụ iguzo megide unu, ya bụ otu afọ ga-anọchi otu ụbọchị nʼime iri ụbọchị anọ ahụ unu ji ledoo ala ahụ anya.  
\v 35 Mụ onwe m, bụ \nd Onyenwe anyị\nd*, ekwuola ya. Nke a ka m na-aghaghị ime ka ọ dakwasị ajọ nzukọ ndị a, bụ ndị gbakọrọ megide m. Ha ga-ezute ọgwụgwụ ha nʼọzara, nʼebe a ka ha ga-anwụ.’ ” 
\p  
\v 36 Ya mere ndị ahụ Mosis zipụrụ iledo ala ahụ, ndị ahụ lọtara mee ka ọgbakọ ụmụ Izrel tamuo ntamu nʼihi akụkọ ọjọọ ha gbasara.  
\v 37 Ndị ikom ndị ahụ e si nʼọnụ ha gbasaa akụkọ ọjọọ banyere ala ahụ, ka e ji nrịa nrịa na-efe efe tigbuo nʼihu \nd Onyenwe anyị\nd*.  
\v 38 Nʼime ndị ikom gara ledoo ala ahụ anya, ọ bụ naanị Joshua nwa Nun na Kaleb nwa Jefune fọdụrụ ndụ. 
\p  
\v 39 Mgbe Mosis gwara ụmụ Izrel okwu niile si nʼọnụ \nd Onyenwe anyị\nd*, ha ruru ụjụ dị ilu.  
\v 40 Nʼisi ụtụtụ echi ya, ha biliri nʼoge bulie ije ịga nʼala ugwu ugwu ahụ. Ha sịrị, “Anyị emehiela. Ugbu a anyị ejikerela ije nʼala ahụ \nd Onyenwe anyị\nd* kwere anyị nkwa.” 
\p  
\v 41 Ma Mosis zara sị ha, “Gịnị mere unu ji enupu isi nʼiwu \nd Onyenwe anyị\nd* nyere? Nke a agaghị aga nke ọma.  
\v 42 Unu arịgokwala, nʼihi na \nd Onyenwe anyị\nd* anọghị nʼetiti unu. Ndị iro unu ga-emerikwa unu.  
\v 43 Nʼihi na ndị Amalek na ndị Kenan nọ na-eche unu nʼebe ahụ! Ebe ọ bụ na unu esitela nʼebe \nd Onyenwe anyị\nd* nọ wezuga onwe unu, ọ gaghị anọnyere unu, unu ga-adakwa nʼihu mma agha.” 
\p  
\v 44 Nʼagbanyeghịkwa nke a, na ha enweghị nkwado. Ha rigooro ruo ebe kachasị elu nʼobodo ahụ dị nʼugwu, ọ bụ ezie na Mosis maọbụ igbe ọgbụgba ndụ \nd Onyenwe anyị\nd* esighị nʼọmụma ụlọ ikwu ahụ pụọ.  
\v 45 Mgbe ahụ, ndị Amalek na ndị Kenan bụ ndị bi nʼobodo ugwu ahụ, rịdatara lụso ha ọgụ. Tidaa ha nʼala ruo Homa. 
\c 15  
\s1 Ọchụchụ aja ndị ọzọ dị iche iche 
\p  
\v 1 \nd Onyenwe anyị\nd* gwara Mosis okwu sị ya,  
\v 2 “Gwa ụmụ Izrel okwu sị ha, ‘mgbe unu batara ala ahụ m na-enye unu dịka ụlọ unu,  
\v 3 ọ bụrụ na unu echee nʼihu \nd Onyenwe anyị\nd* aja nsure ọkụ nke isisi ya dị ụtọ nye \nd Onyenwe anyị\nd*, maọbụ nke si nʼigwe ehi, maọbụ nke si nʼigwe ewu na atụrụ, maọbụ aja nsure ọkụ, maọbụ aja ndị ọzọ, maka imezu nkwa pụrụ iche maọbụ onyinye afọ ofufu, maọbụ aja mmemme.  
\v 4 Onye wetara onyinye a aghaghị iweta nʼihu \nd Onyenwe anyị\nd* aja mkpụrụ ọka nke bụ ezi ụtụ ọka ruru lita abụọ nke e ji mmanụ ruru otu lita gwakọtaa.  
\v 5 Ọ ga-eweta otu lita mmanya dịka onyinye ihe ọṅụṅụ maka nwa atụrụ ọbụla e ji chụọ aja nsure ọkụ maọbụ aja ụzọ. 
\p  
\v 6 “ ‘Ọ bụrụ nwa ebule ka e ji achụ aja ahụ, weta lita ezi ụtụ ọka anọ na ọkara, nke a gwakọtara ya na mmanụ jitụ ntakịrị karịa otu lita,  
\v 7 tinyekwa ya mmanya jitụ ihe nta karịa otu lita ka ọ bụrụ onyinye ihe ọṅụṅụ nye ha, dịka aja nke isisi ya dị ụtọ nye \nd Onyenwe anyị\nd*. 
\p  
\v 8 “ ‘Mgbe i ji nwa oke ehi chụọ aja nsure ọkụ, maọbụ aja imezu nkwa, maọbụ aja udo nye \nd Onyenwe anyị\nd*,  
\v 9 tinyere oke ehi ahụ, ị ghaghị iji ezi ụtụ ọka ruru lita isii na ọkara, nke a gwakọtara ya na mmanụ ruru lita abụọ.  
\v 10 Wetakwa lita mmanya abụọ nke ga-abụ onyinye ihe ọṅụṅụ. Ọ ga-abụ onyinye e sitere nʼọkụ nye, nke isisi ya dị ụtọ nye \nd Onyenwe anyị\nd*.  
\v 11 Nke a bụ usoro a ga-agbaso nʼoge ọbụla e ji nwa oke ehi, maọbụ nwa ebule, maọbụ nwa atụrụ, maọbụ nwa ewu chụọ aja.  
\v 12 Meenụ ya maka anụ ụlọ ọbụla nʼoge niile ọbụla unu na-achụ aja. 
\p  
\v 13 “ ‘Onye ọbụla bụ nwa afọ ala aghaghị ime ihe ndị a mgbe ọbụla o wetara onyinye e sitere nʼọkụ nye dịka onyinye isisi ya dị ụtọ nye \nd Onyenwe anyị\nd*.  
\v 14 Nʼọgbọ niile na-abịa, mgbe ọbụla onye ọbịa, maọbụ onye ọzọ bi nʼetiti unu wetara onyinye e sitere nʼọkụ nye, nke isisi ya dị ụtọ nye \nd Onyenwe anyị\nd*, ọ ghaghị ịgbaso ụzọ a nye onyinye ya.  
\v 15 Ọgbakọ ụmụ Izrel ga-enwe otu iwu ga-adịrị unu na ndị ọbịa bi nʼetiti unu. Nke a bụ ụkpụrụ ebighị ebi ga-adịrị ọgbọ niile na-abịa. Unu na ndị ọbịa ga-abụ otu nʼihu \nd Onyenwe anyị\nd*.  
\v 16 Otu iwu na otu ụkpụrụ bụ ihe ga-adịrị onye ọbụla, diala na ndị ọbịa bi nʼetiti unu.’ ” 
\p  
\v 17 \nd Onyenwe anyị\nd* gwara Mosis okwu sị ya,  
\v 18 “Gwa ndị Izrel okwu sị ha, ‘mgbe unu banyere nʼala ahụ m na-akpọbata unu nʼime ya,  
\v 19 ọ bụrụ na unu erie nri dị nʼala ahụ, wetanụ ụfọdụ nʼime nri ahụ dịka onyinye nye \nd Onyenwe anyị\nd*.  
\v 20 Wetanụ ogbe achịcha site nʼọka mbụ unu ga-akwọ, chee ya nʼihu \nd Onyenwe anyị\nd* dịka onyinye e wetara site nʼebe ịzọcha ọka.  
\v 21 Unu aghaghị inye \nd Onyenwe anyị\nd* onyinye a sitere nʼọka mbụ ọbụla unu kwọrọ, site nʼọgbọ ruo nʼọgbọ. 
\s1 Onye mehiere na-amaghị ama 
\p  
\v 22 “ ‘Ọ bụrụ na unu amaghị ama ghara idebe iwu ndị a niile \nd Onyenwe anyị\nd* nyere site nʼaka Mosis,  
\v 23 bụ iwu ndị a niile \nd Onyenwe anyị\nd* nyere unu site nʼaka Mosis, site nʼụbọchị ahụ \nd Onyenwe anyị\nd* nyere ha ruo nʼọgbọ niile nke na-abịa.  
\v 24 Ọ bụrụ na e mere ya na-amaghị ama, ọ bụrụ na ọgbakọ ụmụ Izrel amaghị ama mee ya, mgbe ahụ, ọgbakọ ụmụ Izrel ga-eji nwa oke ehi chụọ aja nsure ọkụ, aja na-esi isi ụtọ nke \nd Onyenwe anyị\nd* na-anabata. Aghaghị iwetakwa mkpụrụ ọka, na onyinye ihe ọṅụṅụ nke ya na aja ahụ so, tinyere otu mkpi maka aja mmehie.  
\v 25 Onye nchụaja ga-ekpuchitere nzukọ Izrel niile mmehie ha. A ga-agbagharakwa ha mmehie ha niile, nʼihi na ọ bụ mmehie ha mere na-amaghị ama. Ha e cheela nʼihu \nd Onyenwe anyị\nd* aja onyinye nri nʼihi amaghị ama ha ya na aja mmehie.  
\v 26 A ga-agbaghara nzukọ Izrel niile na ndị ọbịa nọ nʼetiti ha mmehie ha, nʼihi na mmadụ ndị a niile akpachaghị anya mehie. 
\p  
\v 27 “ ‘Ọ bụrụ na ọ bụ naanị otu onye mehiere na-amaghị ama, ọ ga-eweta nwa nne ewu gbara otu afọ maka aja mmehie.  
\v 28 Onye nchụaja a ga-eji ya chụọ aja ikpuchitere onye ahụ na-amaghị ama mehie mmehie ya nʼihu \nd Onyenwe anyị\nd*. Mgbe ekpuchichara mmehie ya, a ga-agbaghara onye ahụ.  
\v 29 Ọ bụ otu iwu a dịrị onye ọbụla mehiere na-amaghị ama, maọbụ nwa afọ Izrel, maọbụ onye ọbịa nke bi nʼetiti unu. 
\p  
\v 30 “ ‘Ma onye ọbụla kpachapụrụ anya mehie, maọbụ nwa afọ maọbụ onye ọbịa, nke na-ekwulu \nd Onyenwe anyị\nd*, a ga-ebipụ onye dị otu a site nʼetiti ndị Izrel.  
\v 31 Nʼihi na ha eledala okwu \nd Onyenwe anyị\nd* anya, mebie ihe o nyere nʼiwu. A ghaghị ibipụ onye dị otu a, mmehie ha ga-adịkwa ha nʼisi.’ ” 
\s1 Onye merụrụ ụbọchị izuike 
\p  
\v 32 Mgbe ụmụ Izrel nọ nʼọzara, e jidere otu onye nʼime ha ka ọ na-akpa nkụ nʼụbọchị izuike.  
\v 33 Ndị hụrụ ya ebe ọ na-akpa nkụ duuru ya jekwuru Mosis na Erọn na ọgbakọ ụmụ Izrel.  
\v 34 Ha tinyere ya nʼụlọ mkpọrọ nʼihi na o doghị anya ihe e kwesiri ime ya.  
\v 35 Mgbe ahụ, \nd Onyenwe anyị\nd* gwara Mosis okwu sị ya, “Nwoke a ghaghị ịnwụ. Ọgbakọ Izrel niile ga-atụ ya nkume nʼazụ obodo.”  
\v 36 Ya mere, ọgbakọ ahụ kpọpụrụ ya nʼazụ obodo jiri nkume tugbuo ya, dịka \nd Onyenwe anyị\nd* nyere Mosis nʼiwu. 
\s1 Ihe ịchọ mma ọnụ ọnụ uwe 
\p  
\v 37 \nd Onyenwe anyị\nd* gwara Mosis okwu sị ya,  
\v 38 “Gwa ụmụ Izrel okwu sị ha, ‘Nʼọgbọ niile na-abịa unu ga-adụnye eriri akwa nʼọnụ ala ala uwe unu. Unu ga-eji eriri na-acha anụnụ anụnụ dụnye ya.  
\v 39 Eriri akwa ndị a dị nʼọnụ ọnụ uwe unu ga-eme ka unu cheta iwu niile \nd Onyenwe anyị\nd* nyere unu. Ka unu rube isi na ha hapụ imerụ onwe unu site na ịgbaso ihe ọjọọ niile na-agụ obi unu na anya unu.  
\v 40 Mgbe ahụ unu ga-echeta irube isi nʼiwu m niile, bụrụ ndị e doro nsọ nye Chineke unu.  
\v 41 Abụ m \nd Onyenwe anyị\nd* Chineke unu, onye si nʼala Ijipt kpọpụta unu ịbụ Chineke unu. Abụ m \nd Onyenwe anyị\nd* Chineke unu.’ ” 
\c 16  
\s1 Nnupu isi Kora na Datan na Abiram 
\p  
\v 1 Ugbu a, Kora nwa Izha, nwa Kohat, nwa Livayị, na ụfọdụ ndị agbụrụ Ruben bụ Datan, na Abiram ụmụ Eliab, na On, nwa Pelet nupuru isi  
\v 2 bilie imegide Mosis. Ndị so ha bụ narị ndị ikom abụọ na iri ise, ndị ndu a maara nke ọma, ndị so nọdụ nʼụlọ nzukọ ukwuu ndị Izrel.  
\v 3 Ha kpọrọ ọgbakọ imegide Mosis na Erọn sị ha, “Omume unu agafeela oke! Ọgbakọ Izrel dị nsọ, onye ọbụla nʼime ha kwa. \nd Onyenwe anyị\nd* nọnyeere ha. Gịnị mere unu ji ebuli onwe unu elu karịa ọgbakọ \nd Onyenwe anyị\nd*?” 
\p  
\v 4 Mgbe Mosis nụrụ ihe ndị a ha kwuru, ọ dara nʼala kpuo ihu ya nʼala.  
\v 5 Mgbe ahụ, ọ gwara Kora na ndị niile sonyeere ya, sị, “Nʼụtụtụ echi, \nd Onyenwe anyị\nd* ga-eme ka amara ndị bụ ndị ya na onye dị nsọ. Ọ ga-eme ka onye ahụ bịaruo ya nso. Onye ọ ga-ahọpụta ka ọ ga-emekwa ka ọ bịaruo ya nso.  
\v 6 Lee ihe ị ga-eme, Echi gị onwe gị Kora, na ndị niile nọnyeere gị, chịrịnụ ihe ịgụ ọkụ,  
\v 7 mụnye ha ọkụ. Tinyekwanụ ụda na-esi isi ụtọ nʼime ha, were ha bịa nʼihu \nd Onyenwe anyị\nd*. Onye ahụ \nd Onyenwe anyị\nd* họpụtara ga-abụ onye ahụ dị nsọ. O zuorola unu, unu ụmụ Livayị!”\f + \fr 16:7 \ft Nke a na-egosi na ha agafeela oke e nyedebere ha.\f* 
\p  
\v 8 Mgbe ahụ, Mosis gwakwara Kora okwu ọzọ sị ya, “Ugbu a, geenụ ntị, unu ndị Livayị!  
\v 9 Ọ bụ ihe dị nta nʼanya unu na Chineke nke Izrel kewapụtara unu site na nzukọ ndị Izrel niile, mee ka unu bịaruo ya nso, nʼihi ije ozi nʼụlọ nzute \nd Onyenwe anyị\nd*, nakwa iguzo nʼihu nzukọ Izrel niile ijere ha ozi\f + \fr 16:9 \ft \xt Dit 10:8\f*?  
\v 10 Ọ kpọbatala gị na ndị Livayị ibe gị nso ebe ọ nọ. Ugbu a, unu na-achọkwa ọrụ nchụaja?  
\v 11 Ọ bụ \nd Onyenwe anyị\nd* ka gị na ndị sonyeere gị gbara izu megide. Onye ka Erọn bụ unu ji atamu ntamu megide ya?” 
\p  
\v 12 Mgbe ahụ, Mosis ziri ozi ka a kpọọ Datan na Abiram, ụmụ ndị ikom Eliab, ma ha sịrị, “Anyị agaghị abịa.  
\v 13 Ọ bụ na o zurughị gị na i si nʼala Ijipt ebe mmiri ara ehi na mmanụ aṅụ na-eru kpọpụta anyị igbuchapụ anyị nʼọzara a? Ugbu a ị chọkwara ime onwe gị onyenwe anyị?  
\v 14 Nke kachasị nke, ị kpọbatabeghị anyị nʼala mmiri ara ehi na mmanụ aṅụ na-eru na ya. I nyebeghị anyị ihe nketa ala ubi na ubi vaịnị. Ị chọrọ ịghụpụsị ndị ikom ndị a mkpụrụ anya?\f + \fr 16:14 \ft Ị ga-eme ha ka ndị ohu.\f* Anyị agaghị abịa!” 
\p  
\v 15 Mgbe ahụ, oke iwe were Mosis. Ọ kpọkuru \nd Onyenwe anyị\nd* sị ya, “Anabatakwala aja ha niile! Ọ dịbeghị oge m naara ha ihe ọbụla, ọbụladị otu ịnyịnya ibu! O nwekwaghị onye ọbụla nʼime ha m mejọrọ.” 
\p  
\v 16 Mgbe ahụ, Mosis sịrị Kora, “Echi, gị na ndị na-esonyere gị ga-apụta bịa nʼihu \nd Onyenwe anyị\nd*. Erọn ga-abịakwa.  
\v 17 Nwoke ọbụla ga-eweta ihe ịgụ ọkụ nke ya, tinye ya ụda na-esi isi ụtọ, chee ha nʼihu \nd Onyenwe anyị\nd*. Ha niile dị ihe ịgụ ọkụ narị abụọ na iri ise. Gị na Erọn ga-ejikwa nke unu bịa.”  
\v 18 Ya mere, nwoke ọbụla wetara ihe ịgụ ọkụ nke ya, mụnye ya ọkụ, ma tinye ya ụda na-esi isi ụtọ. Ha niile guzoro nʼọnụ ụzọ ụlọ nzute ahụ, ha na Mosis na Erọn.  
\v 19 Mgbe Kora kpọkọtara ndị na-eso ya imegide Mosis na Erọn nʼihu ọnụ ụzọ ụlọ nzute, ebube \nd Onyenwe anyị\nd* pụtara ihe nye ọgbakọ Izrel niile.  
\v 20 \nd Onyenwe anyị\nd* gwara Mosis na Erọn okwu sị,  
\v 21 “Sitenụ nʼetiti ọgbakọ ndị a pụọ, ka m bibie ha nʼotu ntabi anya.” 
\p  
\v 22 Ma Mosis na Erọn dara kpuo ihu nʼala nʼihu \nd Onyenwe anyị\nd* rịọọ ya sị, “O Chineke, gị bụ Chineke nwe ndụ mmadụ niile, ị ga-ewe iwe megide nzukọ niile nʼihi mmehie otu onye?” 
\p  
\v 23 Ma \nd Onyenwe anyị\nd* zara Mosis sị ya,  
\v 24 “Gwa nzukọ Izrel niile sị ha, ‘Wezuganụ onwe unu site nʼụlọ ikwu Kora, Datan na Abiram.’ ” 
\p  
\v 25 Mosis biliri jekwuru Datan na Abiram, ndị okenye Izrel sokwa Mosis.  
\v 26 Mgbe Mosis ruru nʼebe ahụ, ọ dọrọ nzukọ Izrel aka na ntị sị, “Ngwa, sinụ nʼụlọ ndị ọjọọ a wezuga onwe unu. Unu ebitụkwala ihe ọbụla bụ nke ha aka. Ma ọ bụghị otu a, a ga-agụnyekọ unu na mmehie ha, lakọọ unu na ha nʼiyi.”  
\v 27 Ya mere mmadụ niile wezugara onwe ha site nʼọmụma ụlọ ikwu Kora, na Datan na Abiram. Ma Datan na Abiram pụtara guzoro nʼọnụ ụzọ ụlọ ikwu ha, ha onwe ha na ndị nwunye ha niile, na ụmụ ha niile, na ụmụntakịrị ha niile. 
\p  
\v 28 Mgbe ahụ, Mosis kwuru sị, “Ugbu a ka unu ga-amata na ọ bụ \nd Onyenwe anyị\nd* zitere m ime ihe ndị a niile m mere. Nʼihi na-emeghị m ha site nʼuche nke onwe m.  
\v 29 Ọ bụrụ na ndị ikom ndị a anwụọ ọnwụ chi ha, bụ ụdị nleta nke dịrị mmadụ ọbụla, mgbe ahụ, matanụ na ọ bụghị \nd Onyenwe anyị\nd* zitere m.  
\v 30 Ma ọ bụrụ na \nd Onyenwe anyị\nd* emee ihe ọhụrụ dị iche, mee ka ala meghee ọnụ ya, lodaa ndị a niile, na ihe niile bụ nke ha, si otu a mee ka ha rịda nʼala ili na ndụ, mgbe ahụ, unu ga-amata na ndị ikom ndị a eledala \nd Onyenwe anyị\nd* anya.” 
\p  
\v 31 Mgbe Mosis kpụ okwu a nʼọnụ ya, lee ala ahụ Kora, na Datan, na Abiram, na ndị ezinaụlọ ha niile guzo nʼelu ya kewara abụọ nʼotu ntabi anya ahụ,  
\v 32 ala ahụ meghere ọnụ ya, loo ha, na ezinaụlọ ha niile, na ndị ahụ niile so Kora, na ihe niile ha nwere.  
\v 33 Ha niile rịdaruru nʼala ndị nwụrụ anwụ na ndụ. Ala ahụ kpuchikwara ha niile, si otu a mee ka ha laa nʼiyi.  
\v 34 Ndị Izrel niile nọ ha gburugburu gbara ọsọ, mgbe ha tiri mkpu akwa, na-asị, “Ala na-agakwa iloda anyị.” 
\p  
\v 35 Mgbe ahụ, ọkụ si nʼebe \nd Onyenwe anyị\nd* nọ dara, rechapụ narị mmadụ abụọ na iri ise ndị ahụ na-enye onyinye aja nsure ọkụ na-esi isi ụtọ. 
\p  
\v 36 \nd Onyenwe anyị\nd* gwara Mosis okwu sị ya,  
\v 37 “Gwa Elieza nwa Erọn, onye nchụaja, ka o site nʼọkụ ahụ wepụta ihe ịgụ ọkụ ndị ahụ niile nʼihi na ha dị nsọ. Ọ ga-ekposakwa icheku ọkụ niile nʼakụkụ niile.  
\v 38 Ha bụ ihe ịgụ ọkụ nke ndị ikom sitere na mmehie ha tufuo ndụ ha. Ka etipịa ihe ịgụ ọkụ ndị ahụ. Mee ha ka ha ghọọ ihe sara mbara nke a ga-eji machite ebe ịchụ aja, nʼihi na e chere ha nʼihu \nd Onyenwe anyị\nd*, ha aghọọla ihe dị nsọ. Ka ha bụrụ ihe ịrịbama nye ndị Izrel niile.” 
\p  
\v 39 Ya mere Elieza, onye nchụaja, chịkọtara ihe ịgụ ọkụ bronz ndị ahụ nke ndị ahụ a kpọrọ ọkụ wetara, tipịa ha, mee ka ha ghọọ ihe sara mbara e ji ekpuchi ebe ịchụ aja,  
\v 40 dịka \nd Onyenwe anyị\nd* nyere ya nʼiwu site nʼọnụ Mosis. Ka ọ bụrụ ihe ncheta nye ndị Izrel niile na onye mba ọzọ a na-enyeghị ike, nke na-esiteghị nʼagbụrụ Erọn, ekwesighị ịbịaru \nd Onyenwe anyị\nd* nso isure aja nsure ọkụ nye ya, ka ihe mere Kora na ndị sonyere ya ghara ime ha. 
\p  
\v 41 Ma nʼụtụtụ echi ya, nzukọ Izrel niile malitere itamu ntamu megide Mosis na Erọn sị, “Unu egbuchaala ndị nke \nd Onyenwe anyị\nd*.” 
\p  
\v 42 Ma mgbe ọgbakọ Izrel zukọtara imegide Mosis na Erọn, mgbe ha chere ihu nʼụlọ nzute, na mberede, igwe ojii kpuchiri ụlọ nzute ahụ, ebube \nd Onyenwe anyị\nd* pụtakwara ihe.  
\v 43 Mgbe ahụ, Mosis na Erọn gara nʼihu ụlọ nzute ahụ.  
\v 44 Ma Onyenwe anyị gwara Mosis sị,  
\v 45 “Sinụ nʼetiti ọgbakọ a pụọ ka m bibie ha nʼotu ntabi anya.” Ha dara kpuo ihu nʼala. 
\p  
\v 46 Mgbe ahụ, Mosis sịrị Erọn, “Ngwa, were ihe ịgụ ọkụ ma site nʼebe ịchụ aja gụnye ya ọkụ. Tinye ya ụda na-esi isi ụtọ. Burukwa ya gaa ngwangwa nʼetiti nzukọ Izrel ka i kpuchiere ha mmehie ha, nʼihi na iwe ọkụ \nd Onyenwe anyị\nd* adakwasịla ha. Nrịa nrịa na-efe efe amalitekwalarị ibibi ha.”  
\v 47 Erọn mere dịka Mosis kwuru. O mere ngwangwa gbaba nʼetiti ndị Izrel nʼihi na nrịa nrịa ahụ ebidola nʼezie ịdakwasị ha. Erọn mụnyere ụda na-esi isi ụtọ ahụ ọkụ, si otu ahụ kpuchiere ha mmehie ha niile.  
\v 48 O guzokwara nʼetiti ndị dị ndụ na ndị nwụrụ anwụ tutu ihe otiti ahụ akwụsị.  
\v 49 Ma ihe otiti ahụ egbuolarị puku mmadụ iri, puku anọ na narị asaa (14,700). A gụnyeghị ndị niile ahụ so Kora nwụọ nʼụbọchị gara aga.  
\v 50 Mgbe ahụ, Erọn laghachikwutere Mosis nʼọnụ ụzọ ụlọ nzute ahụ, nʼihi na nrịa nrịa ahụ na-efe efe akwụsịla. 
\c 17  
\s1 Mkpanaka Erọn epupụta ahịhịa 
\p  
\v 1 Mgbe ahụ, \nd Onyenwe anyị\nd* gwara Mosis okwu sị ya,  
\v 2 “Gwa ụmụ Izrel okwu, sitekwa nʼaka ha nata mkpanaka iri na abụọ otu mkpanaka nʼisi onyendu nke ebo ọbụla. Dekwasị aha onyendu ọbụla nʼahụ mkpanaka nke ya.  
\v 3 Ma nʼelu mkpanaka Livayị dekwasị aha Erọn. A ga-enwe otu mkpanaka maka onyendu ebo ọbụla.  
\v 4 Tinye mkpanaka ndị a niile nʼime ụlọ nzute, nʼihu Ihe Ama ahụ, ebe m na-ezute gị.  
\v 5 Mkpanaka nke onye ahụ m họpụtara ga-ama ifuru ndụ. M ga-ewezugakwa ntamu niile nke ndị Izrel site nʼebe m nọ, bụ nke ha na-atamu megide unu.” 
\p  
\v 6 Ya mere, Mosis gwara ndị Izrel okwu ndị a. Ndị ndu ha nyere ya mkpanaka iri na abụọ, otu mkpanaka nʼisi otu onyeisi maka onyeisi ebo ha nʼotu nʼotu. Mkpanaka Erọn dịkwa nʼetiti nke ha.  
\v 7 Mosis chịịrị ha niile dozie ha nʼihu \nd Onyenwe anyị\nd* nʼime ime ụlọ nzute Ihe Ama ahụ. 
\p  
\v 8 Nʼechi ya, Mosis banyere nʼụlọ nzute Ihe Ama ahụ chọpụta na ọ bụghị naanị na mkpanaka Erọn, onye nọchitere anya ebo Livayị, amaala ifuru, kama na ọ waala okoko ma mịakwa mkpụrụ osisi chara acha a na-akpọ alụmọnd.  
\v 9 Mgbe ahụ, Mosis sitere nʼihu \nd Onyenwe anyị\nd* wepụta mkpanaka ndị ahụ niile gosi ha ndị Izrel niile. Ha hụrụ ha, ma nwoke ọbụla weghachiri mkpara osisi nke ya. 
\p  
\v 10 \nd Onyenwe anyị\nd* gwara Mosis sị, “Tinye mkpanaka Erọn nʼihu Ihe Ama ahụ, ka ọ dịgide nʼebe ahụ dịka ihe ama nye ndị nnupu isi. Nke a ga-eme ka ntamu ndị a megide m kwụsị, ka ha ghara ịnwụ.”  
\v 11 Ya mere, Mosis mezuru ihe niile dịka \nd Onyenwe anyị\nd* nyere ya nʼiwu. 
\p  
\v 12 Ma ndị Izrel zara Mosis sị ya, “Ndị nwụrụ anwụ ka anyị bụ! Ofufu ka anyị furu. Nʼezie anyị bụ ndị furu efu.  
\v 13 Onye ọbụla bịaruru nso ebe obibi \nd Onyenwe anyị\nd* ga-anwụ. Anyị niile ga-anwụ?” 
\c 18  
\s1 Ọrụ ndị nchụaja na ndị Livayị 
\p  
\v 1 \nd Onyenwe anyị\nd* gwara Erọn sị, “Gị, na ụmụ gị ndị ikom gị, na ezinaụlọ nna gị ga-ebu ahụhụ ajọ omume metụtara ebe nsọ ahụ. Gị na ụmụ gị ndị ikom naanị ka ọ dị nʼaka ịsa ajụjụ ihe ọjọọ ọbụla banyere ọrụ nchụaja.  
\v 2 Site nʼebo unu kpọbata ụmụnna gị ndị Livayị ka ha sonyere gị ma nyere gị aka mgbe gị na ụmụ gị ndị ikom na-eje ozi nʼụlọ nzute Ihe Ama.  
\v 3 Ha ga-anọ gị nʼokpuru ije ozi niile nʼụlọ nzute, ma ha agaghị abịaru nso ngwongwo e ji chọọ ebe nsọ ahụ mma, maọbụ nʼebe ịchụ aja. Ma ọ bụghị otu a, gị na ha ga-anwụ.  
\v 4 Ha ka ọ dịrị, isonye gị nʼilekọta ụlọ ikwu ahụ, ya bụ, ihe niile metụtara ụlọ ikwu anya. O nweghị onye ọzọ nke ga-abịa nso ebe ị nọ. 
\p  
\v 5 “Gị ka ọ dịrị ilekọta ihe niile metụtara ebe nsọ ahụ, na ebe ịchụ aja ahụ, ka oke iwe \nd Onyenwe anyị\nd* ghara ịdakwasị onye ọbụla nʼala Izrel ọzọ.  
\v 6 Mụ onwe m ahọpụtala ụmụnna gị ndị Livayị site nʼetiti ndị Izrel, were ha nye gị dịka onyinye, ka ha bụrụ ndị e doro nsọ nye \nd Onyenwe anyị\nd* maka ịrụ ọrụ ụlọ nzute.  
\v 7 Ma ọ bụ naanị gị, na ụmụ gị ndị ikom, ga-aga ozi dịka ndị nchụaja, ozi metụtara ebe ịchụ aja, na ihe niile dị nʼazụ akwa mgbochi ahụ. Ana m enye gị ọrụ nchụaja dịka onyinye. Onye ọbụla ọzọ bịara nso ebe nsọ ahụ ga-anwụ.” 
\s1 Oke ndị nchụaja na ndị Livayị 
\p  
\v 8 Mgbe ahụ, \nd Onyenwe anyị\nd* gwara Erọn okwu sị ya, “Mụ onwe m emeela gị onye nlekọta onyinye niile a na-eche nʼihu m, onyinye niile dị nsọ nke ụmụ Izrel wetara m ka m na-enye gị na ụmụ gị ndị ikom dịka oke ruuru unu site nʼụkpụrụ ebighị ebi.\f + \fr 18:8 \ft Ndị nchụaja na ndị Livayị enweghị oke, maọbụ ihe nketa ọbụla, dịka ebo ndị ọzọ. Ihe ndị Livayị ketara bụ naanị obodo ụfọdụ ebe ha ga-ebi na ala ebe anụ ụlọ ha ga na-ata ahịhịa. Nʼihi i ji tie ha aka nʼobi, ọ bụ ha nwe onyinye otu ụzọ nʼime ụzọ iri ha na-anata site nʼaka ụmụ Izrel, nke a dị nʼamaokwu. \xt 18:25-32\ft  Ọ bụ oke ha iri ụfọdụ ihe ndị Izrel ji chụọ aja, \xt Dit 18:1-8\ft  ọzọkwa, ha nwere ike iri onyinye ndị ọzọ niile e chere nʼihu ebe ịchụ aja, ha na ndị ezinaụlọ ha, ma ọ gaghị abụ nʼime ụlọ nzute ahụ \xt 18:11\ft .\f* 
\v 9 Unu ga-enwere akụkụ aja ahụ kachasị nsọ nke a na-edopụ iche site nʼọkụ. Site nʼonyinye niile nke a na-ewetara m, bụ onyinye mkpụrụ ọka maọbụ aja mmehie maọbụ aja ikpe ọmụma, ndị ahụ a na-edopụ iche dịka ihe kachasị nsọ, ha ga-abụ oke gị na ụmụ gị ndị ikom.  
\v 10 A ga-eri ha dịka ihe dịkarịrị nsọ. Nwa nwoke ọbụla ga-eri ya. Unu ga-agụ ha dịka ihe dị nsọ. 
\p  
\v 11 “Nke a bụkwa nke gị: Ihe ọbụla nke ewezugara site nʼonyinye nke aja mfufe niile nke ndị Izrel wetara. Mụ onwe m na-ewere nke a nye gị na ụmụ gị ndị ikom, na ụmụ gị ndị inyom dịka oke unu nʼụkpụrụ ebighị ebi. Onye ọbụla nke dooro onwe ya ọcha nʼezinaụlọ nwere ike iri ya. 
\p  
\v 12 “Ana m enye gị mmanụ oliv nke kachasị mma, na mmanya ọhụrụ nke kachasị mma na ọka, bụ mkpụrụ mbụ nke owuwe ihe ubi ha na-ewetara \nd Onyenwe anyị\nd*.  
\v 13 Mkpụrụ mbụ nke ihe niile dị nʼala nke ha na-ewebatara \nd Onyenwe anyị\nd*, ga-abụ nke gị. Onye ọbụla nke dị ọcha nʼezinaụlọ unu nwere ike iso rie ya. 
\p  
\v 14 “Ihe niile e doro nsọ nʼala Izrel niile nye \nd Onyenwe anyị\nd* bụ nke gị.  
\v 15 Ihe niile e bụ ụzọ mụọ, ma mmadụ ma anụ ụlọ, nke e nyere \nd Onyenwe anyị\nd* dịka onyinye, bụ nke gị. Ma unu aghaghị ịgbara ụmụ ndị ikom niile e bụ ụzọ mụọ, na ụmụ oke anụ ụlọ niile e bụ ụzọ mụọ ndị na-adịghị ọcha.  
\v 16 Mgbe ha dị otu ọnwa, a ga-eji shekel ọlaọcha ise, nʼusoro shekel ebe nsọ, nke bụ iri ihe ọtụtụ gera abụọ gbapụta ha. 
\p  
\v 17 “Ma a gaghị agbara nwa ehi mbụ, maọbụ nwa atụrụ mbụ maọbụ nwa ewu mbụ. Ha dị nsọ. Fesa ọbara ha nʼelu ebe ịchụ aja ahụ, ma kpọọ abụba ha ọkụ dịka onyinye e nyere site nʼọkụ, nke na-esi isi ụtọ nye \nd Onyenwe anyị\nd*.  
\v 18 Ozu anụ ndị a niile e gburu ga-abụ nke gị, dịka obi anụ na apata ụkwụ aka nri anụ nke aja mfufe a na-eche nʼihu \nd Onyenwe anyị\nd* nʼebe ịchụ aja si bụrụ nke gị.  
\v 19 Ihe ọbụla e dopụrụ iche site nʼonyinye nsọ niile ụmụ Izrel chere nʼihu \nd Onyenwe anyị\nd* ka m na-enye gị na ụmụ gị ndị ikom, na ụmụ gị ndị inyom dịka oke ruuru unu nʼụkpụrụ ebighị ebi. Ọ bụ ọgbụgba ndụ nnu ebighị ebi nʼihu \nd Onyenwe anyị\nd* nye gị na ụmụ ụmụ gị.” 
\p  
\v 20 \nd Onyenwe anyị\nd* gwara Erọn okwu sị ya, “Unu agaghị enwe ihe nketa nke ala, a gaghị ekenyekwa unu ala ọbụla nʼala Izrel niile. Nʼihi na mụ onwe m bụ oke na ihe nketa unu nwere nʼetiti ụmụ Izrel. 
\p  
\v 21 “Enyela m ndị Livayị, onyinye otu ụzọ nʼụzọ iri ahụ ụmụ Izrel niile na-akwụbatara m. Nke a bụ ihe nketa ha nʼihi ọrụ ha na-arụ nʼụlọ nzute.  
\v 22 Site ugbu a gaa nʼihu, o nweghị onye Izrel ọbụla kwesiri ịbịa nso ụlọ nzute ahụ, ka ha ghara iwetara onwe ha ikpe ọmụma, mmehie na ọnwụ.  
\v 23 Ọ bụ naanị ụmụ Livayị ga-arụ ọrụ nʼụlọ nzute ahụ. Ha ka ọ dịrị ibu ahụhụ ajọ omume ọbụla banyere ejezighị ozi nke ụlọ nzute. Ụkpụrụ a ga-adị ebighị ebi ruo ọgbọ niile dị nʼihu. Ndị Livayị agaghị enwe ihe nketa nke aka ha nʼetiti ụmụ Izrel.  
\v 24 Kama, enyela m ndị Livayị onyinye otu ụzọ nʼime ụzọ iri ahụ niile ndị Izrel na-ewetara \nd Onyenwe anyị\nd* ka ọ bụrụ ihe nketa ha. Ọ bụ nke a mere m ji kwuo sị, ‘Ha agaghị enweta ihe nketa nʼetiti ụmụ Izrel.’ ” 
\p  
\v 25 \nd Onyenwe anyị\nd* gwakwara Mosis okwu sị,  
\v 26 “Gwa ndị Livayị okwu sị, ‘Mgbe unu si nʼaka ụmụ Izrel nata onyinye otu ụzọ nʼime ụzọ iri ahụ m nyere unu dịka ihe nketa, unu aghaghị isite nʼonyinye ahụ nye otu ụzọ nʼime ụzọ iri dịka onyinye nye \nd Onyenwe anyị\nd*.  
\v 27 A ga-agụ onyinye unu wetara dịka ọ bụ onyinye ọka unu si nʼebe ịzọcha ọka weta, maọbụ dịka mmanya unu si nʼebe ịzọcha mmanya weta.  
\v 28 Nʼụzọ dị otu a, unu onwe unu ga-eche onyinye unu nʼihu \nd Onyenwe anyị\nd* site nʼonyinye otu ụzọ nʼime ụzọ iri unu si nʼaka ụmụ Izrel nata. Site nʼonyinye ndị a unu natara, unu ga-enye Erọn onye nchụaja onyinye ahụ ruuru \nd Onyenwe anyị\nd*.  
\v 29 Onyinye unu ga-enye dịka nke ruuru \nd Onyenwe anyị\nd* ga-abụ akụkụ onyinye ndị ahụ kachasị mma, na ndị kachasị ịdị nsọ.’ 
\p  
\v 30 “Gwa ndị Livayị okwu sị ha, ‘Mgbe unu wetara akụkụ onyinye ndị ahụ kachasị mma, a ga-agụnyere unu ya dịka a ga-asị na ọ bụ onyinye unu si nʼebe ịzọcha ọka, na nʼebe ịzọcha mmanya vaịnị unu weta.  
\v 31 Unu na ezinaụlọ unu nwere ike iri ndị fọdụrụ nʼụlọ unu, maọbụ nʼebe ọbụla masịrị unu, nʼihi na ha bụ ụgwọ ọrụ unu nʼihi ozi niile unu jere nʼụlọ nzute.  
\v 32 Ikpe ọmụma agaghị adịrị unu mgbe unu na-eri ya ma ọ bụrụ na unu chere onyinye ndị ahụ kachasị mma nʼihu \nd Onyenwe anyị\nd*. Ma kpachapụnụ anya hụ na unu e merụghị onyinye ndị a dị nsọ ụmụ Izrel webatara. Ọ bụrụ na unu emee nke a, unu ga-anwụ.’ ” 
\c 19  
\s1 Mmiri ido ihe ọcha 
\p  
\v 1 \nd Onyenwe anyị\nd* gwara Mosis na Erọn okwu sị ha,  
\v 2 “Ndị a bụ ụkpụrụ dị nʼiwu ahụ \nd Onyenwe anyị\nd* nyere. Gwa ụmụ Izrel ka ha wetara gị nwa nne ehi na-acha uhie uhie nke na-enweghị ntụpọ, na nke ụdọ yoku na-agabeghị nʼolu ya.  
\v 3 Nye ya Elieza onye nchụaja, ka ọ kpụrụ ya pụọ nʼazụ ogige, ebe otu onye ga-egbu ya mgbe ọ nọ na-ele ya anya.  
\v 4 Elieza bụ onye nchụaja ga-arụrụ ụfọdụ nʼime ọbara ya na mkpịsịaka ya, fesa ya na ncherita ihu ụlọ nzute ahụ ugboro asaa.  
\v 5 Mgbe ahụ, onye ọzọ ga-akpọ nwa nne ehi ahụ ọkụ mgbe Elieza nọkwa na-ele ya anya. Ọ ga-akpọ akpụkpọ ya, anụ ya, ọbara na mgbịrị afọ ya ọkụ.  
\v 6 Onye nchụaja ga-ewere osisi sida, na osisi hisọp, na ogho uhie, tụba ha nʼetiti ebe ahụ a kpọrọ nwa nne ehi ahụ ọkụ.  
\v 7 Emesịa, onye nchụaja ahụ ga-asacha uwe niile o yi; sakwaa ahụ ya. Ọ ga-alọghachikwa azụ nʼime ogige ahụ ebe ọ ga-anọ dịka onye na-adịghị ọcha ruo nʼuhuruchi.  
\v 8 Onye ahụ kpọrọ nwa ehi ahụ ọkụ aghaghị ịsa uwe ya niile, sakwaa ahụ ya. Ọ ga-anọkwa ọnọdụ onye na-adịghị ọcha ruo anyasị. 
\p  
\v 9 “Mgbe ahụ, onye nke dị ọcha, ga-ekpokọta ntụ ozu nwa nne ehi ahụ, wụnye ya nʼebe dị ọcha nʼazụ ogige ahụ. Ebe ahụ ka nzukọ Izrel ga-edebe ya maka ikporo wụnye na mmiri e ji asachapụ adịghị ọcha. Ọ bụ maka nsacha pụọ na mmehie.  
\v 10 Ma onye ahụ ga-ekpokọta ntụ nsure ọkụ nwa nne ehi ahụ aghaghị ịsa uwe ya niile, sakwaa ahụ ya, nọkwaa dịka onye na-adịghị ọcha ruo nʼuhuruchi. Iwu a ga-adịgidere ndị Izrel na ndị ọbịa binyere ha site nʼọgbọ ruo nʼọgbọ. 
\p  
\v 11 “Onye ọbụla metụrụ ozu mmadụ aka ga-abụ onye na-adịghị ọcha ụbọchị asaa.  
\v 12 Ha aghaghị iji mmiri e ji asachapụ adịghị ọcha saa ahụ ha nʼụbọchị nke atọ na nʼụbọchị nke asaa. Mgbe ahụ, ha ga-adị ọcha. Ma ọ bụrụ na ha asaghị ahụ ha nʼụbọchị nke atọ nakwa nʼụbọchị nke asaa, ha ga-anọgide bụrụ ndị na-adịghị ọcha ọ bụladị mgbe ụbọchị asaa ahụ gafesịrị.  
\v 13 Onye ọbụla metụrụ ozu mmadụ aka ma ọ saghị ahụ ya dịka usoro a si dị, o merụọla ebe nsọ \nd Onyenwe anyị\nd*. A ga-ewezuga onye dị otu a site nʼetiti ndị Izrel. Ebe ọ bụ na a wụsaghị ya mmiri nsacha ahụ; ọ ga-anọgide bụrụ onye na-adịghị ọcha. 
\p  
\v 14 “Mgbe mmadụ nwụrụ nʼụlọ ikwu, ndị a ga-abụ iwu unu ga-eso. Ndị nọ nʼime ụlọ ikwu ahụ mgbe ọ nwụrụ na onye ọbụla banyere nʼụlọ ikwu ahụ, ga-abụ ndị na-adịghị ọcha ụbọchị asaa.  
\v 15 Ihe ọbụla nke ghere oghe, nke na-enweghị ihe mkpuchi eriri e ji kechie elu ya, ga-abụ ihe na-adịghị ọcha. 
\p  
\v 16 “Onye gara nʼọhịa metụ onye e gburu nʼagha aka, maọbụ onye nwụrụ nʼụzọ ọzọ dị iche, ma ọ bụkwanụ metụ ọkpụkpụ, maọbụ ili onye nwụrụ anwụ aka, ọ ga-abụ onye na-adịghị ọcha ụbọchị asaa. 
\p  
\v 17 “Ma banyere onye ahụ na-adịghị ọcha, kporo ntụ site nʼime aja mmehie ahụ a kpọrọ ọkụ, tinye ya nʼime ite, wụkwasị ya mmiri e si nʼiyi na-eru eru kute.  
\v 18 Mgbe ahụ, nwoke nke nọ nʼọnọdụ ịdị ọcha ga-ewere ụfọdụ hisọp, denye ya na mmiri ahụ fesaa ya nʼime ụlọ ikwu ahụ, na ngwongwo niile e ji dozie ụlọ ahụ, na ndị mmadụ nọ nʼebe ahụ. Ọ ga-efesakwa ya nʼahụ onye ọbụla metụrụ ọkpụkpụ, maọbụ onye e gburu egbu, maọbụ onye nwụrụ anwụ ma ọ bụkwanụ ili aka.  
\v 19 Nwoke ahụ dị ọcha ga-efesakwa ndị ahụ rụrụ arụ nʼụbọchị nke atọ na nʼụbọchị nke asaa. Nʼụbọchị nke asaa ka ọ ga-eme ka ha dị ọcha. Ndị ahụ a na-edo ọcha ga-asa uwe ha mmiri, saa ahụ ha, nʼuhuruchi ụbọchị ahụ ka ha ga-adị ọcha.  
\v 20 Ma ọ bụrụ na ndị ahụ merụrụ onwe ha e doghị onwe ha ọcha, aghaghị iwepụ ha site nʼetiti ọgbakọ Izrel. Nʼihi na ha merụrụ ebe nsọ \nd Onyenwe anyị\nd*. E fesakwaghị ha mmiri nke ịdị ọcha nʼahụ, nke mere na ha adịghị ọcha.  
\v 21 Nke a bụ ụkpụrụ ga-adịgide mgbe ebighị ebi. 
\p “Nwoke ahụ na-efesa mmiri ahụ e ji edo mmadụ ọcha, aghaghị ịsacha uwe ya niile. Onye ọbụla metụrụ mmiri nke ịdị ọcha ahụ aka, ga-abụ onye na-adịghị ọcha ruo nʼuhuruchi.  
\v 22 Ihe ọbụla kwa onye na-adịghị ọcha metụrụ aka, ga-aghọ ihe na-adịghị ọcha, onye ọbụla metụkwara ya aka ga-abụ onye na-adịghị ọcha ruo nʼuhuruchi.” 
\c 20  
\s1 Mmiri si na nkume 
\p  
\v 1 Ụmụ Izrel, bụ nzukọ ahụ niile rutere nʼọzara Zin nʼọnwa nke mbụ. Ha manyere ụlọ ha na Kadesh. Ọ bụkwa nʼebe ahụ ka Miriam nwụrụ. E lie ya. 
\p  
\v 2 Ma mmiri ọṅụṅụ adịghị nye ndị nzukọ ahụ. Ya mere na ha gbakọtara imegide Mosis na Erọn.  
\v 3 Ha sesịrị Mosis okwu sị, “Ọ gaara akara anyị mma ma a sị na anyị nwụrụ mgbe ụmụnna anyị nwụrụ nʼihu \nd Onyenwe anyị\nd*.  
\v 4 Gịnị mere i ji kpọbata ọgbakọ nke \nd Onyenwe anyị\nd* nʼime ọzara a, ime ka anyị na anụ ụlọ anyị niile nwụọ nʼebe a?  
\v 5 Gịnị mere i ji si nʼala Ijipt kpọpụta anyị, kpọbata anyị nʼebe ọjọọ a? O nweghị mkpụrụ ọghịgha maọbụ fiig, enweghị mkpụrụ vaịnị maọbụ mkpụrụ pomegranet. Ọ dịghị mmiri dị nke ha ga-aṅụ.” 
\p  
\v 6 Mosis na Erọn si nʼebe ọgbakọ ahụ nọ tụgharịa gaa nʼọnụ ụzọ ụlọ nzute, daa kpụọ ihu ha nʼala. E mee ka ha hụ ebube \nd Onyenwe anyị\nd* anya.  
\v 7 \nd Onyenwe anyị\nd* gwara Mosis sị,  
\v 8 “Were mkpara ahụ, gị na nwanne gị Erọn kpọkọta nzukọ Izrel niile. Gwa nkume ahụ okwu nʼihu ha, ọ ga-asọpụta mmiri ya. Unu ga-eme ka mmiri si na nkume ahụ sọpụta nye ọgbakọ ahụ, ka ha na igwe anụ ụlọ ha, ṅụọ mmiri.” 
\p  
\v 9 Ya mere Mosis sitere nʼihu \nd Onyenwe anyị\nd* weere mkpara ahụ dịka iwu \nd Onyenwe anyị\nd* nyere ya si dị.  
\v 10 Emesịa, Mosis na Erọn kpọkọtara ụmụ Izrel niile nʼihu nkume ahụ. Mgbe ha bịaruru nso, Mosis gwara ha okwu sị ha, “Geenụ ntị unu ndị nnupu isi! Ọ bụ site na nkume a ka anyị ga-enye unu mmiri?”  
\v 11 Mgbe ahụ Mosis weliri aka ya elu jiri mkpara ahụ tie nkume ahụ ugboro abụọ. Mmiri sitere na ya sọpụta. Ọgbakọ Izrel niile na igwe anụ ụlọ ha ṅụkwara mmiri. 
\p  
\v 12 Ma \nd Onyenwe anyị\nd* gwara Mosis na Erọn okwu sị, “Ebe ọ bụ na unu jụrụ ikwenye nʼokwu m, jụkwa ido m nsọ nʼihu ndị Izrel niile, unu agaghị edubata ọgbakọ ndị a nʼala ahụ m na-aga inye ha.” 
\p  
\v 13 A kpọrọ ebe ahụ mmiri Meriba,\f + \fr 20:13 \fq Meriba \ft pụtara \fqa Esemokwu.\f* nʼihi na ọ bụ nʼebe ahụ ka Izrel wesoro \nd Onyenwe anyị\nd* iwe. O gosikwara ha ịdị nsọ ya. 
\s1 Edọm ajụ na Izrel ga-agafe 
\p  
\v 14 Mosis sitere nʼọzara Kadesh, zipụ ndị ozi ka ha gakwuru eze Edọm, sị ya, 
\pm “Otu a ka nwanne gị bụ Izrel na-ekwu: Ị nụla akụkọ ihe nhụju anya niile dakwasịrị anyị.  
\v 15 Nna anyị gara biri nʼala Ijipt. Anyị biri nʼebe ahụ ọtụtụ afọ. Ndị Ijipt mekpara anyị na nna nna anyị ha ahụ.  
\v 16 Ma mgbe anyị tikuru \nd Onyenwe anyị\nd* mkpu akwa, ọ nụrụ akwa anyị, zitere anyị mmụọ ozi ya, onye dupụtara anyị site nʼala Ijipt. 
\pm “Ugbu a, anyị nọ na Kadesh obodo dị nso nʼoke ala gị.  
\v 17 Biko kwere ka anyị si nʼala gị gafee. Anyị ga-akpachara anya hụ na anyị esiteghị nʼubi ihe ọkụkụ gị maọbụ nʼubi vaịnị gị gafee. Anyị agaghị aṅụ mmiri ọbụla site nʼolulu mmiri gị. Anyị ga-anọgide naanị nʼokporoụzọ eze. Anyị agaghị ahapụ ya, chee ihu akụkụ aka nri maọbụ aka ekpe, tutu ruo mgbe anyị gafechara oke ala gị.” 
\p  
\v 18 Ma eze Edọm zara sị, 
\pm “Unu amanyela ụkwụ; ọ bụrụ na unu anwaa anwa bata nʼala m, aga m eji ndị agha m zute unu.” 
\p  
\v 19 Ma ndị Izrel zara ozi o ziri sị ya, 
\pm “Ọ bụ naanị nʼokporoụzọ ka anyị ga-esi gafee. Ọ bụrụ na anyị maọbụ anụ ụlọ anyị a ṅụọ mmiri dị nʼala gị, anyị ga-akwụ ọnụahịa ya. Naanị mkpa anyị bụ ịgafe. Ọ dịghị ihe ọzọ anyị chọrọ.” 
\p  
\v 20 Ma eze Edọm aṅaghị ntị, ọ gwaghere ha ọnụ sị, 
\pm “Unu agaghị esite nʼala gabiga.” 
\p Edọm chịkọtara ọtụtụ ndị agha dị ike duru ha pụọ ịga izute ha.  
\v 21 Ebe ọ bụ na ndị Edọm ekweghị ka ndị Izrel si nʼoke ala ha gafee, ndị Izrel tụgharịrị azụ hapụ isi ụzọ ahụ. 
\s1 Ọnwụ Erọn 
\p  
\v 22 Ọgbakọ Izrel niile sitere na Kadesh bulie ije gagide rute nʼugwu Hor.  
\v 23 Nʼugwu Hor, nʼoke ala Edọm, Onyenwe anyị gwara Mosis na Erọn okwu sị ha,  
\v 24 “Oge eruola mgbe Erọn ga-anwụ. Ọ gaghị abanye nʼala ahụ m nyere ụmụ Izrel, nʼihi na unu abụọ nupuru isi nʼiwu m na mmiri Meriba.  
\v 25 Ugbu a, kpọrọ Erọn na nwa ya nwoke Elieza, duru ha gaa nʼugwu Hor.  
\v 26 Nʼebe ahụ ka ị ga-eyipụ Erọn uwe onye nchụaja o yi, yikwasị ha Elieza nwa ya nwoke. Ọ bụkwa nʼebe ahụ ka Erọn ga-anọ nwụọ.” 
\p  
\v 27 Ya mere Mosis mere dịka \nd Onyenwe anyị\nd* nyere ya iwu. Ha atọ rigoro nʼugwu Hor mgbe nzukọ Izrel niile nọ na-ele ha anya.  
\v 28 Mgbe ha ruru nʼelu ugwu ahụ, Mosis yipụrụ Erọn uwe onye nchụaja ya yikwasị ha nwa ya nwoke Elieza. Erọn nọkwa nʼebe ahụ, nʼelu ugwu ahụ nwụọ. Emesịa, Mosis na Elieza tụgharịrị site nʼugwu ahụ lọghachi.  
\v 29 Mgbe ọgbakọ Izrel nụrụ ihe banyere ọnwụ Erọn ha ruru ụjụ nʼihi ya iri ụbọchị atọ. 
\c 21  
\s1 Mbibi obodo Arad 
\p  
\v 1 Mgbe eze Kenan, bụ Arad, onye bi na Negev nụrụ na ndị Izrel na-agbaso ụzọ ahụ na-aga obodo Atarim, ọ chịkọtara ndị agha ya, pụkwuru ndị Izrel, lụso ha agha. Ọ dọtara ụfọdụ nʼime ha nʼagha.  
\v 2 Mgbe ahụ, ndị Izrel kwere \nd Onyenwe anyị\nd* nkwa sị, “Ọ bụrụ na ị ga-enyere anyị aka imeri eze Arad na ndị ya, anyị ga-ebibi obodo ha niile kpamkpam.”  
\v 3 \nd Onyenwe anyị\nd* ṅara ntị nʼarịrịọ ha, nyere ha aka imeri ndị Kenan ahụ. Mgbe ahụ, ụmụ Izrel bibiri obodo ha niile, na ndị niile bi nʼime ya. Ya mere, aha a kpọrọ ebe ahụ niile bụ Homa. 
\s1 Agwọ Bronz Ahụ 
\p  
\v 4 Mgbe ahụ, ụmụ Izrel sitere nʼugwu Hor bilie ije ha, si ụzọ gawara Osimiri Uhie, ka ha nwee ike gaa gburugburu ala ndị Edọm. Ma ndị Izrel enweghị ntachiobi oge niile ha nọ nʼije a.  
\v 5 Ha kwuru okwu megide Chineke na Mosis sị, “Gịnị mere i ji site nʼala Ijipt kpọpụta anyị ka anyị nwụsịa nʼọzara a? Lee na nri ọbụla adịghị nʼebe a, mmiri ọṅụṅụ adịghịkwa, ike iri mánà a na-enweghị isi agwụkwala anyị.” 
\p  
\v 6 Ya mere, \nd Onyenwe anyị\nd* zitere agwọ ọjọọ na-ata ata nʼetiti ha. Agwọ ndị a tagbukwara ọtụtụ nʼime ụmụ Izrel.  
\v 7 Mgbe ahụ, ndị Izrel bịakwutere Mosis sị ya, “Anyị emehiela, nʼihi na anyị ekwuluola \nd Onyenwe anyị\nd*, kwulukwaa gị onwe gị. Biko rịọrọ anyị \nd Onyenwe anyị\nd* ka o wezugara anyị agwọ ọjọọ ndị a.” Mosis rịọrọ arịrịọ nʼihi ha. 
\p  
\v 8 Mgbe ahụ, \nd Onyenwe anyị\nd* gwara Mosis okwu sị ya, “Kpụọ otu agwọ yiri agwọ ndị a. Kwụba ya nʼọnụ ogologo osisi nke ị ga-amanye nʼala ebe mmadụ niile ga-ahụ ya anya. Onye ọbụla agwọ ọjọọ a tara ga-adị ndụ ma ọ bụrụ na ọ ga-ewelite anya ya elu lekwasị agwọ ahụ ị kwụbara nʼelu osisi ahụ.”  
\v 9 Ya mere, Mosis ji bronz kpụta agwọ yiri otu nʼime agwọ ndị ahụ, tinye ya nʼọnụ osisi dị ogologo. Onye ọbụla kwa agwọ ahụ tara nke welitere anya ya elu lee agwọ bronz ahụ anya, dịkwara ndụ. 
\s1 Njem ịga obodo Moab 
\p  
\v 10 Ụmụ Izrel biliri njem, manye ụlọ ikwu ha na Obot.  
\v 11 Ha sikwa nʼObot bilie njem, maa ụlọ ikwu ha na Iye Abarim, nʼọzara ahụ nke chere ihu nʼobodo Moab, nʼụzọ ọwụwa anyanwụ.  
\v 12 Ha si nʼebe ahụ bilie njem, manye ụlọ ikwu ha na Ndagwurugwu Zered.  
\v 13 Ha sitekwara nʼebe ahụ bilie njem, maa ụlọ ikwu ha nʼofe iyi Anọn nke dị nʼọzara ruru nʼoke ala ndị Amọrait. Iyi Anọn bụ oke ala Moab, nʼetiti ndị Moab na ndị Amọrait.  
\v 14 Nʼihi nke a, nʼAkwụkwọ Agha dị iche iche nke \nd Onyenwe anyị\nd* na-asị, 
\q1 “Waheb nʼime Sufa ya na ndagwurugwu niile 
\q2 Anọn  
\v 15 na mgbadata ndagwurugwu ndị ahụ 
\q1 nke gbasapụrụ ruo nʼebe Ar dị, 
\q2 nke tọgbọrọ nʼoke ala Moab.” 
\m  
\v 16 Mgbe ahụ, ụmụ Izrel niile biliri njem bịarute Bịa bụ nʼolulu mmiri ahụ \nd Onyenwe anyị\nd* nyere Mosis iwu sị, “Kpọkọtaa ndị Izrel niile, nʼihi na m na-aga inye ha mmiri.” 
\p  
\v 17 Mgbe ahụ, ụmụ Izrel bụrụ abụ a. 
\q1 “Sọpụta gị olulu mmiri! 
\q2 Bụọnụ abụ banyere mmiri a! 
\q1  
\v 18 Olulu mmiri ụmụ ndị eze gwuru 
\q2 nke ndị ndu anyị doziri. 
\q2 Mkpara eze ha na mkpara ha, ka ha ji gwuo ya.” 
\m Emesịa, ha hapụrụ ọzara ahụ, gaa nʼihu ruo nʼobodo Matana.  
\v 19 Ha si Matana jeruo Nahaliel, si Nahaliel jeruo Bamot.  
\v 20 Sitekwa Bamot rute na ndagwurugwu ahụ dị nʼọhịa Moab, ruo nʼugwu Pisga, nke chere ihu nʼala ahụ tọgbọrọ nʼefu. 
\s1 Mmeri e meriri Saịhọn na Ọg 
\p  
\v 21 Ndị Izrel zipụrụ ndị ozi ka ha jekwuru Saịhọn, eze ndị Amọrait, sị ya, 
\pm  
\v 22 “Biko, kwere ka anyị site nʼobodo gị gafee. Anyị agaghị atụgharị banye nʼime ala ubi gị maọbụ nʼubi vaịnị, maọbụ ṅụọ mmiri site nʼolulu mmiri ọbụla dị nʼala gị. Anyị ga-eje nʼokporoụzọ eze tutu ruo mgbe anyị ga-agabiga oke ala gị.” 
\p  
\v 23 Ma Saịhọn ekweghị na ụmụ Izrel ga-esi nʼoke ala ya gafee. Ọ chịkọtara ndị agha ya niile, zọpụ ije ibu agha megide ndị Izrel nʼime ọzara ahụ. Mgbe o rutere Jehaz, ọ lụsoro Izrel agha.  
\v 24 Ma Izrel jiri mma agha gbuo ya. Nwetara onwe ha ala ya, site nʼiyi Anọn ruo nʼiyi Jabọk, gamiekwa rute nʼoke ala ha na ndị Amọn, ha kwụsịrị nʼihi nʼoke ala ndị Amọn siri ike karịa.  
\v 25 Ndị Izrel lụgburu obodo niile nke ndị Amọrait bichie nʼime ha, tinyere Heshbọn na obodo nta niile gbara ya gburugburu.  
\v 26 Heshbọn bụ isi obodo Saịhọn, eze ndị Amọrait onye busoro eze naara achị Moab agha dọta ala ya niile nʼagha ruo Anọn. 
\p  
\v 27 Ọ bụ nke a mere ndị na-arọ abụ ji kwuo sị, 
\q1 “Bịa na Heshbọn ka e wukwaa ya, 
\q2 ka e mee ka isi obodo eze Saịhọn guzosie ike. 
\b  
\q1  
\v 28 “Nʼihi na ọkụ esitela na Heshbọn pụọ. 
\q2 Ire ọkụ esitela nʼobodo ukwu Saịhọn, 
\q1 rechapụ obodo Ar, nke dị na Moab, 
\q2 ndị nwe ebe niile dị elu nke Anọn. 
\q1  
\v 29 Ahụhụ dịrị gị Moab! 
\q2 Ndị a lara nʼiyi ka unu bụ, unu ndị Kemosh. 
\q1 Ụmụ ya ndị ikom aghọọla ndị na-enweghị ebe obibi. 
\q2 A dọtala ụmụ ndị inyom nʼagha, 
\q2 nye Saịhọn eze ndị Amọrait. 
\b  
\q1  
\v 30 “Ma anyị ebibiela ha, 
\q2 bibie Heshbọn ruo rịị na Dibọn, 
\q1 bibie ha ruo Nofa, 
\q2 ruokwa rịị Medeba.” 
\p  
\v 31 Ya mere, ụmụ Izrel bichiri nʼala ndị Amọrait. 
\p  
\v 32 Emesịa, Mosis zipụrụ ndị nnyopụta ka ha ga nyochaa Jeza. Ụmụ Izrel tigburu obodo niile dị gburugburu ya chụpụkwa ndị Amọrait bi nʼebe ahụ.  
\v 33 Mgbe ahụ, ha chigharịrị gbagoo nʼụzọ gawara Bashan. Ma Ọg, eze Bashan, na ndị agha ya niile biliri chịrị agha pụọ izute ha na Edrei. 
\p  
\v 34 Ma \nd Onyenwe anyị\nd* gwara Mosis okwu, sị, “Atụla ya egwu nʼihi na ewerela m ya na ndị agha ya niile, na ala ya, nyefee gị nʼaka. Mee ya ihe i mere Saịhọn eze ndị Amọrait onyeisi obodo ya bụ Heshbọn.” 
\p  
\v 35 Ya mere, ha gburu ya, tinyere ụmụ ya na ndị agha ya niile, na-ahapụghị onye ọbụla ndụ nye ha. Ha nwetakwara ala ha, biri nʼime ya.\f + \fr 21:35 \ft Mgbe ndị Izrel meriri eze niile ndị a nʼagha, ha bichiri ala niile dị nʼọwụwa anyanwụ Jọdan. Ha bichiri ala ndị Moab ruo ọ bụladị nʼala ugwu ugwu Bashan, nke dị na mpaghara ugwu Hemon. Ndị Juu na-eme mmemme banyere mmeri a ha meriri eze Saịhọn, na Ọg. \xt Abụ 135:10-11; 136:19-20\f* 
\c 22  
\s1 Balak akpọọ Belam oku 
\p  
\v 1 Ndị Izrel biliri njem bịarute nʼobosara ala Moab. Manye ụlọ ikwu ha nʼakụkụ Jọdan ebe chere ihu nʼobodo Jeriko. 
\p  
\v 2 Ma Balak nwa Zipoa ahụlarị ihe niile Izrel mere ndị Amọrait.  
\v 3 Oke ụjọ jidere ndị Moab nʼihi na ndị Izrel dị ọtụtụ. Nʼezie, oke ụjọ dị ukwuu jidere ndị Moab nʼihi ụmụ Izrel. 
\p  
\v 4 Ndị Moab jekwuru ndị okenye Midia sị ha, “Igwe mmadụ ndị a ga-erichapụ ihe niile gbara anyị gburugburu. Ha ga-eripịa ha dịka ehi si erichapụ ahịhịa ndụ dị nʼala.” 
\p Ya mere, Balak nwa Zipoa, onye bụ eze ndị Moab nʼoge ahụ,  
\v 5 zigara ndị ozi ya ka ha jekwuru Belam, nwa Beoa onye bi nʼobodo ya bụ Petoa, nke dị nso nʼiyi ukwu Yufretis. O ziri ya sị, 
\pm “Lee otu ndị sitere nʼIjipt pụta. Lee ka ha si kpuchie elu ala a; ugbu a, ha bi nʼakụkụ m.  
\v 6 Ugbu a, bịa ka ị bụọrọ m ha ọnụ, nʼihi na ha dị ike karịa m. Ma eleghị anya aga m enwe ike merie ha, ma chụpụkwa ha site nʼala m. Nʼihi na amaara m na ndị ọbụla ị gọziri bụ ndị a gọziri agọzi, ndị ọbụla ị bụrụ ọnụ ga-anọgide bụrụ ndị a bụrụ ọnụ.” 
\p  
\v 7 Ndị ozi o zigara bụ ndị okenye obodo Moab na Midia. Ha ji ego ịjụta ase nʼaka ha. Mgbe ha ruru, ha ziri Belam ozi Balak ziri. 
\p  
\v 8 Belam gwara ha okwu sị, “Nọdụnụ nʼebe a nʼabalị a. Aga m ewetara unu ọsịsa ọbụla \nd Onyenwe anyị\nd* nyere m.” Ya mere, ndị ozi ahụ si Moab nọnyeere ya. 
\p  
\v 9 Nʼabalị ahụ, Chineke bịakwutere Belam jụọ ya sị, “Ndị ikom ndị a bịara ileta gị, ha bụ ndị ole?” 
\p  
\v 10 Belam sịrị Chineke, “Balak nwa Zipoa eze Moab zitere m ozi sị m,  
\v 11 ‘Otu ndị esitela nʼala Ijipt pụta, ndị dị ukwuu nʼọnụọgụgụ. Achọrọ m ka ị bịa bụọrọ m ha ọnụ. Ma eleghị anya aga m enwe ike lụso ha agha, ma chụpụkwa ha.’ ” 
\p  
\v 12 Ma Chineke sịrị Belam, “Esola ha aga! Ị gaghị abụ ndị a ọnụ, nʼihi na ha bụ ndị a gọziri agọzi.” 
\p  
\v 13 Mgbe chi bọrọ, Belam biliri gwa ndị ozi Balak sị ha, “Laghachinụ nʼobodo unu nʼihi na \nd Onyenwe anyị\nd* ekweghị ka m soro unu.” 
\p  
\v 14 Ya mere, ndị ozi Moab laghachikwuru Balak gwa ya sị, “Belam jụrụ iso anyị lọghachi.” 
\p  
\v 15 Balak nwara ike ya ọzọ. Nʼoge a, o zipụrụ ụmụ eze ndị dị ọtụtụ na ndị a maara aha ha karịa ndị mbụ.  
\v 16 Ha jiri ozi a bịakwute Belam sị ya, 
\pm “Ihe a ka Balak nwa Zipoa sị anyị zie gị, Ọ sị gị ekwela ka ihe ọbụla gbochie gị ịbịakwute m.  
\v 17 Nʼihi na aghaghị ịsọpụrụ gị nʼebe ọ dị ukwuu m,\f + \fr 22:17 \ft Nke a bụ ịkwụ ya ụgwọ dị mma\f* mekwaa ihe ọbụla ị sị m mee. Naanị bịa ka ị bụọrọ m ndị a ọnụ.” 
\p  
\v 18 Ma Belam zaghachiri sị, “Ọ bụrụ na Balak enye m ụlọeze ya nke juputara nʼọlaọcha na ọlaedo, apụghị m ime ihe ọbụla dị ukwuu maọbụ nke nta ịgabiga iwu \nd Onyenwe anyị\nd* bụ Chineke m.  
\v 19 Ma otu ọ dị, nọọnụ ka chị bọọ dịka ndị ọzọ ahụ mere ka m nwee ike chọpụta ma ọ dị ihe \nd Onyenwe anyị\nd* ga-atụkwasị nʼihe o kwuru na mbụ.” 
\p  
\v 20 Nʼabalị ahụ, Chineke gwara Belam okwu sị ya, “Ebe ọ bụ na ndị a bịara ịkpọ gị oku, bilie soro ha gaa, kama jikere ikwu naanị okwu m ga-etinye gị nʼọnụ.” 
\s1 Ịnyịnya ibu Belam 
\p  
\v 21 Ya mere, mgbe chi echi ya bọrọ, Belam rigooro nʼelu ịnyịnya ibu ya soro ụmụ eze Moab gaa.  
\v 22 Ma iwe were Chineke nʼihi na ọ na-aga, ma mmụọ ozi \nd Onyenwe anyị\nd* guzochiri ụzọ igbochi ya. Belam na ndị odibo ya abụọ nọ na-elu ịnyịnya ibu ya.  
\v 23 Mgbe ịnyịnya ibu ahụ hụrụ mmụọ ozi \nd Onyenwe anyị\nd* ka o guzochiri nʼụzọ, jide mma a mịpụtara amịpụta nʼaka ya, ịnyịnya ibu ahụ chigharịrị onwe ya hapụ okporoụzọ, tinye isi nʼọhịa. Ma Belam tiri ya ihe ịchụghachi ya nʼụzọ. 
\p  
\v 24 Nʼoge a, mmụọ ozi \nd Onyenwe anyị\nd* guzochiri nʼụzọ dị warawara, nke dị nʼetiti mgbidi ogige ubi vaịnị abụọ.  
\v 25 Mgbe ịnyịnya ibu ahụ hụrụ mmụọ ozi \nd Onyenwe anyị\nd*, o tinyere isi nʼahụ mgbidi ogige ubi ahụ, chọọ isite nʼebe ahụ gafee. Mgbe ọ na-eme nke a, o mere ka mgbidi ahụ chihịapụ Belam ụkwụ. Ya mere Belam tiri ịnyịnya ibu ahụ ihe ọzọ. 
\p  
\v 26 Mgbe ahụ, mmụọ ozi \nd Onyenwe anyị\nd* gakwara nʼihu nʼokporoụzọ ahụ nọchie ụzọ ahụ ebe dị nnọọ mkpakọta, ebe ịnyịnya ibu ahụ na-agaghị enwe ike gafee, maọbụ ichigharị aka nri maọbụ aka ekpe.  
\v 27 Nʼihi nke a, mgbe ịnyịnya ibu ahụ hụrụ mmụọ ozi \nd Onyenwe anyị\nd* o dinara ala nʼokporoụzọ. Nʼoke iwe, Belam ji mkpara dị ya nʼaka tie ya ihe ọzọ.  
\v 28 Mgbe ahụ, \nd Onyenwe anyị\nd* mere ka ịnyịnya ibu ahụ kwuo okwu. Ọ jụrụ Belam ajụjụ sị, “Gịnị ka m mere gị i ji tie m ihe ugboro atọ?” 
\p  
\v 29 Belam zara ịnyịnya ibu ahụ sị, “Ọ bụ nʼihi na i meela ka m dị ka onye nzuzu! Nʼezie, a sị na m ji mma agha nʼaka m, agaara m egbu gị.” 
\p  
\v 30 Ịnyịnya ibu ahụ gwara Balam okwu ọzọ sị ya, “Ọ bụ na mụ onwe m abụghị ịnyịnya ibu gị nke ị na-anọ nʼelu ya ogologo oge ndị a niile? Ọ dịla mgbe m si otu a meso gị omume nʼime ndụ m niile?” 
\p Belam zara sị ya, “Ee.” 
\p  
\v 31 Mgbe ahụ ka \nd Onyenwe anyị\nd* meghere anya Belam. Ọ hụrụ mmụọ ozi \nd Onyenwe anyị\nd* ka o ji mma agha ya guzochie ụzọ. Belam dara nʼala, gbatịa onwe ya nʼala nʼihu ya. 
\p  
\v 32 Mmụọ ozi \nd Onyenwe anyị\nd* ahụ jụrụ Belam ajụjụ sị, “Gịnị mere i ji tie ịnyịnya ibu gị ihe ugboro atọ? Abịara m igbochi gị ka ịla nʼiyi dị na-eche gị ghara irute gị.  
\v 33 Ugboro atọ ka ịnyịnya ibu a hụrụ m, ma site nʼihu m wezuga onwe ya. A sị na ọ bụghị ntụgharị ọ tụgharịrị site nʼebe m nọ, nʼezie, ugbu a, a gara m egbu gị ma hapụ ịnyịnya ibu gị ndụ.” 
\p  
\v 34 Nʼoge a, Belam sịrị mmụọ ozi \nd Onyenwe anyị\nd*, “Emehiela m. Amaghị m na i guzo nʼụzọ igbochi m. Ọ bụrụ iwe na-ewe gị, ejikeere m ịlaghachi azụ.” 
\p  
\v 35 Ma mmụọ ozi \nd Onyenwe anyị\nd* sịrị Belam, “Soro ndị ikom a gaa, ma kwuo naanị ihe m sị gị kwuo.” Ya mere, Belam soro ndị ozi eze Balak gaa. 
\p  
\v 36 Mgbe Balak nụrụ na Belam nọ nʼụzọ na-abịa, ọ pụrụ gaa izute Belam nʼotu obodo Moab nke dị nʼọnụ mmiri Anọn, nke dị na ngwụcha oke ala ya.  
\v 37 Mgbe ọ bịarutere, Balak jụrụ Belam ajụjụ sị ya, “Eziri m gị ozi ka ị bịa ngwangwa, gịnị mere ị bịaghị? Ọ bụ na m enweghị ike ịsọpụrụ gị?” 
\p  
\v 38 Belam zaghachiri, “Lee, Abịakwutelam gị ugbu a, ma enweghị m ike ikwu ihe ọbụla dị m mma. Ọ bụ naanị ihe Chineke tinyere m nʼọnụ ka m ga-ekwu.” 
\p  
\v 39 Belam sooro Balak gaa Kiriat Huzot.  
\v 40 Balak jiri ehi na atụrụ chụọ aja. O nyere Belam ụfọdụ, nyekwa ma ndị ozi eze ndị ya na ha nọ nʼebe ahụ.  
\v 41 Nʼụtụtụ echi ya, Balak kpọọrọ Belam, duru ya rigoo Bamot Baal.\f + \fr 22:41 \fq Baal \ft aha nke pụtara \fqa onye nzọpụta \ft bụ chi egbe eluigwe nke ndị ala Siria na Kenan.\f* O sitere nʼebe ahụ hụ nsọtụ ọmụma ụlọ ikwu ndị Izrel. 
\c 23  
\s1 Amụma Belam nke mbụ 
\p  
\v 1 Belam sịrị, “Wuoro m ebe ịchụ aja asaa nʼebe a. Kwadokwaara m oke ehi asaa na ebule asaa.”  
\v 2 Balak mezuru dịka Belam gwara ya. Ha abụọ gburu otu oke ehi na otu nwa ebule nʼebe ịchụ aja asaa ahụ nʼotu na otu. 
\p  
\v 3 Mgbe ahụ, Belam gwara Balak sị, “Guzoro nʼebe a nʼakụkụ aja gị ka m gaa nʼihu chọpụta ma eleghị anya \nd Onyenwe anyị\nd* ga-ezute m. Aga m agwa gị ihe ọbụla o kpughere m.” Ya mere, Belam rigooro nʼebe ọhịa na-adịghị. 
\p  
\v 4 Chineke zutere ya nʼebe ahụ. Belam gwara ya sị, “Edoziela m ebe ịchụ aja asaa, gbukwaa otu oke ehi na otu ebule nʼelu ha niile nʼotu na otu.” 
\p  
\v 5 Nʼoge a, \nd Onyenwe anyị\nd* tinyere Belam ozi nʼọnụ sị ya, “Laghachi gaa zie Balak ozi a.” 
\p  
\v 6 Mgbe Belam lọghachiri ọ hụrụ ya ka o guzoro nʼakụkụ ihe aja ya ndị ahụ, ya na ndịisi Moab niile.  
\v 7 Nke a bụ ozi Belam ziri: 
\q1 “Balak esitela nʼobodo Aram kpọta m. 
\q2 Eze Moab esitela nʼọwụwa anyanwụ nke ugwu ahụ kpọta m. 
\q1 Ọ sịrị m, bịa bụọrọ m Jekọb ọnụ 
\q2 bịa kwutọọ Izrel. 
\q1  
\v 8 M ga-esi aṅaa bụọ 
\q2 onye Chineke na-abụghị ọnụ ọnụ? 
\q1 M ga-esi aṅaa 
\q2 kọchaa onye \nd Onyenwe anyị\nd* na-akọchaghị? 
\q1  
\v 9 Esitela m nʼelu nkume ndị a hụ ha. 
\q2 Elegidere m ha anya site nʼugwu ahụ, 
\q1 hụ na ha bụ ndị biri onwe ha, 
\q2 ndị dị iche site nʼetiti mba niile ọzọ. 
\q1  
\v 10 Onye pụrụ ịgụta ole uzuzu Jekọb dị? 
\q2 Maọbụ gụta ole otu ụzọ nʼime nkewa anọ nke Izrel dị. 
\q1 Ọ ga-atọ m ụtọ ịnwụ ụdị ọnwụ ndị na-eme ezi omume. 
\q2 Ka ọgwụgwụ ndụ m bụrụ ihe nwere ike iyi nke ha!” 
\p  
\v 11 Balak sịrị Belam, “Gịnị bụ ihe a i mere m? Akpọtara m gị ka ị bụọrọ m ndị iro m ọnụ, ma ugbu a, ọ dịghị ihe ọzọ i mere karịa naanị ịgọzi ha!” 
\p  
\v 12 Ma Belam zaghachiri sị ya, “Ọ bụghị ihe \nd Onyenwe anyị\nd* tinyere m nʼọnụ ka m ga-ekwu?” 
\s1 Amụma Belam nke abụọ 
\p  
\v 13 Mgbe ahụ, Balak sịrị ya, “Soro m bịa nʼebe ọzọ ebe ị ga-ahụ ha; ọ bụ naanị nsọtụ ọmụma ụlọ ikwu ha ka ị ga-ahụ, ị gaghị ahụ ha niile. Site nʼebe ahụ bụọrọ m ha ọnụ.”  
\v 14 Ya mere, eze Balak duuru Belam gaa nʼọhịa Zofim, nʼelu ugwu Pisga, wuo ebe ịchụ aja asaa nʼebe ahụ. O jikwa otu oke ehi, otu oke ehi, na otu ebule, otu ebule, chụọ aja nʼebe ịchụ aja ndị ahụ. 
\p  
\v 15 Belam sịrị Balak, “Guzoro nʼebe a nʼakụkụ ihe aja gị, ebe mụ onwe m ga-ezute ya nʼofe nke ọzọ.” 
\p  
\v 16 Ma \nd Onyenwe anyị\nd* zutere Belam gwa ya ihe ọ ga-ekwu sị ya, “Laghachikwuru Balak zie ya ozi a.” 
\p  
\v 17 Ya mere, ọ lọghachiri azụ nʼebe ahụ Balak na ụmụ eze Moab guzoro nʼakụkụ ihe aja ha. Balak jụrụ ya sị, “Gịnị ka \nd Onyenwe anyị\nd* sịrị?” 
\p  
\v 18 Ma Belam zaghachiri sị ya: 
\q1 “Bilie ọtọ Balak, nụrụ ozi. 
\q2 Ṅaa ntị nʼokwu m, gị nwa Zipoa. 
\q1  
\v 19 Chineke agaghị agha ụgha, nʼihi na ọ bụghị mmadụ. 
\q2 Ọ gaghị agbanwe obi ya, nʼihi na ọ bụghị nwa mmadụ. 
\q1 O kwuola okwu, ma ghara ime ihe o kwuru? 
\q2 O kwela nkwa ma ghara imezu nkwa o kwere? 
\q1  
\v 20 Chineke enyela m iwu sị m gọzie ha. 
\q2 Ọ gọziela ha, a pụghịkwa ịgbanwe ya! 
\b  
\q1  
\v 21 “O nweghị ajọ ihe nke ahụrụ nʼime Jekọb, 
\q2 ahụghịkwa mwute ọbụla nʼIzrel. 
\q1 \nd Onyenwe anyị\nd* Chineke ha nọnyeere ha. 
\q2 Iti mkpu nke Eze dịkwa nʼetiti ha.\f + \fr 23:21 \ft Maọbụ, \fqa Ọ bụ eze ha!\f* 
\q1  
\v 22 Chineke kpọpụtara ha site nʼIjipt. 
\q2 Ha dị ike dịka ehi ọhịa. 
\q1  
\v 23 Ọ dịghị mgbaasị ga-emegide ha. 
\q2 Ọ dịkwaghị ịgba afa a pụrụ iji megide Izrel. 
\q1 Nʼihi na ugbu a, ihe dị otu a ka a ga-ekwu banyere Jekọb 
\q2 na Izrel. ‘Lee, ihe Chineke mere ha.’ 
\q1  
\v 24 Ha na-ebili ọtọ dịka nne ọdụm, 
\q2 ha na-enugharị onwe ha dịka ọdụm, 
\q1 nke na-adịghị edina ala tutu o richaa ihe o gburu, 
\q2 ma ṅụọkwa ọbara ihe ahụ o tigburu!” 
\p  
\v 25 Mgbe ahụ, Balak sịrị Belam, “Abụla ha ọnụ ma ọlị, ma ọ bụkwanụ gọzie ha ma ọlị.” 
\p  
\v 26 Ma Belam zaghachiri, “Ọ bụ na m agwaghị gị, ihe ọbụla nke \nd Onyenwe anyị\nd* ga-ekwu ka m ga-eme?” 
\s1 Amụma Belam nke atọ 
\p  
\v 27 Mgbe ahụ, Balak sịrị Belam, “Bịa, aga m akpọrọ gị gaa nʼebe ọzọ. Eleghị anya ọ ga-amasị Chineke ka i si nʼebe ahụ bụọrọ m ha ọnụ.”  
\v 28 Ya mere, Balak duuru Belam gaa nʼelu ugwu Peoa nke na-elegide ọzara ahụ anya. 
\p  
\v 29 Belam gwara Balak okwu sị ya, “Wuoro m ebe ịchụ aja asaa ọzọ. Doziekwa ụmụ oke ehi asaa na ebule asaa e ji achụ aja.”  
\v 30 Balak mere dịka Belam gwara ya. O ji otu oke ehi na otu ebule chụọ aja nʼebe ịchụ aja ahụ nʼotu na otu. 
\c 24  
\p  
\v 1 Nʼoge a, Belam aghọtala nʼuche ya na ọ masịrị \nd Onyenwe anyị\nd* ịgọzi Izrel. Ya mere, ọ họrọghị ịgba afa dịka o mere nʼoge ndị gara aga, kama o chere ihu ya nʼọzara.  
\v 2 Mgbe Belam lepụrụ anya ọ hụrụ ụmụ Izrel dịka ha si maa ụlọ ikwu nʼebo nʼebo. Mgbe ahụ kwa, Mmụọ nke Chineke dakwasịrị ya.  
\v 3 O buru amụma ndị a sị, 
\q1 “Okwu si nʼọnụ Belam nwa Beoa pụta, 
\q2 okwu onye ahụ anya ya saghere asaghe. 
\q1  
\v 4 Okwu onye ahụ na-anụ okwu Chineke 
\q2 onye na-ahụ ọhụ site nʼaka onye pụrụ ime ihe niile. 
\q2 Onye na-ada nʼala ma anya ya na-eghe oghe. 
\b  
\q1  
\v 5 “Lee ka ebe obibi gị si maa mma, gị Jekọb, 
\q2 ebe obibi gị niile, gị Izrel! 
\b  
\q1  
\v 6 “Dịka ndagwurugwu dị iche iche ka ha gbasapụrụ, 
\q2 dịka ubi a gbara ogige dị nʼakụkụ osimiri, 
\q1 dịka osisi aloos nke \nd Onyenwe anyị\nd* kụrụ, 
\q2 dịka osisi sida dị nʼakụkụ mmiri. 
\q1  
\v 7 Mmiri ga-esi nʼite mmiri ha na-erupụta, 
\q2 mkpụrụ ha ga-enwekwa mmiri dị ukwuu. 
\b  
\q1 “Eze ha ga-adị ukwuu karịa Agag, 
\q2 a ga-ebulikwa alaeze ha elu. 
\b  
\q1  
\v 8 “Chineke sitere nʼala Ijipt kpọpụta ha. 
\q2 Ha nwere ike dịka atụ. 
\q1 Ha ga-eripịa mba niile na-ebili imegide ha. 
\q2 Ha ga-anyajisi ọkpụkpụ ha niile, 
\q2 jirikwa ọtụtụ àkụ ha gbatuo ha. 
\q1  
\v 9 Ha na-amakpuru, dinara ala dịka ọdụm, 
\q2 dịka nne ọdụm, onye pụrụ ịkpọte ha? 
\b  
\q1 “Ngọzị na-adịrị onye ọ bụla na-agọzi gị, 
\q2 ma ọbụbụ ọnụ na-adịrị onye ọbụla na-akọcha gị.” 
\p  
\v 10 Iwe Balak dị ọkụ megide Belam nʼoge a. Ọ kụkọtara aka ya abụọ nʼiwe. Tie mkpu sị Belam, “Akpọrọ m gị ka ị bịa bụọrọ m ndị iro m ọnụ. Ma ị gọziela ha ugboro atọ a.  
\v 11 Si nʼebe m nọ wezuga onwe gị! Laghachi nʼụlọ gị! Akwadobere m inye gị ọnọdụ dị elu, ma \nd Onyenwe anyị\nd* e gbochiela gị inweta ụgwọ ọrụ a.” 
\p  
\v 12 Belam zara Balak sị, “Ọ bụ na m agwaghị ndị ozi gị niile, bụ ndị ị zitere m,  
\v 13 ‘na a sịkwarịị na Balak enye m ọlaọcha na ọlaedo niile nke dị nʼụlọeze ya, apụghị m ime ihe ọbụla nʼike aka, maọbụ ihe ọma maọbụ ihe ọjọọ, ị gabiga iwu \nd Onyenwe anyị\nd*. Ọ bụkwa naanị ihe \nd Onyenwe anyị\nd* na-ekwu ka m ga-ekwu’?  
\v 14 Ugbu a, ana m alakwuru ndị m, ma bịa, ka m dọọ gị aka na ntị banyere ihe ndị a ga-eme ndị gị nʼụbọchị ndị a na-abịa nʼihu.” 
\s1 Amụma Belam nke anọ 
\p  
\v 15 Ya mere Belam kwuru okwu ndị a: 
\q1 “Amụma Belam nwa Beoa, 
\q2 amụma nke onye ahụ anya ya nʼahụ ụzọ nke ọma, 
\q1  
\v 16 amụma onye ahụ nke na-anụ okwu Chineke, 
\q2 onye ihe ọmụma ya si nʼebe Onye kachasị ihe niile elu na-abịa. 
\q1 Onye na-ahụ ọhụ site nʼaka Onye pụrụ ime ihe niile. 
\q2 Onye na-ada nʼala, ma anya ya abụọ ghekwa oghe. 
\b  
\q1  
\v 17 “Ana m ahụ ya, ma ọ bụghị ugbu a, 
\q2 ana m ele ya anya, ma ọ nọghị nso. 
\q1 Otu kpakpando ga-esi nʼime Jekọb zolie. 
\q2 Mkpara eze ga-esi nʼetiti Izrel bilie. 
\q1 Ọ ga-etipịa egedege ihu ndị Moab, 
\q2 na okpokoro isi ndị ikom Shet niile. 
\q1  
\v 18 A ga-emeri Edọm,\f + \fr 24:18 \ft Ndị Edọm si nʼagbụrụ Ịsọ. \xt Jen 36:1-9\f* 
\q2 Sia, onye iro ya, ka a ga-emeri nʼagha. 
\q2 Ma Izrel ga-eto, ghọọ onye dị ike. 
\q1  
\v 19 Otu onye ọchịchị ga-esi na Jekọb pụta. 
\q2 Bibie ndị niile fọdụrụ nʼobodo ahụ.” 
\s1 Amụma Belam nke ise 
\p  
\v 20 Mgbe ahụ, Belam lepụrụ anya legide ụlọ ndị Amalek niile, buo amụma banyere ha sị: 
\q1 “Amalek bụ mba mbụ nʼetiti mba niile, 
\q2 ma ikpeazụ ya bụ mbibi!” 
\s1 Amụma Belam nke isii 
\p  
\v 21 Ọ hụrụ ndị Ken anya, kwuo okwu ya: 
\q1 “E, i bi ugbu a nʼebe e wusiri ike,\f + \fr 24:21 \ft Ya bụ nke nʼadịgide adịgide\f* 
\q2 akwụ gị dị nʼime oke nkume ahụ! 
\q1  
\v 22 Ma, a ga-ebibi unu ndị Ken niile, 
\q2 mgbe Ashọ ga-adọta unu nʼagha.” 
\s1 Amụma Belam nke asaa 
\p  
\v 23 Ndị a bụ okwu o ji mechie amụma ya: 
\q1 “Onye ga-adị ndụ mgbe Chineke ga-eme ihe ndị a? 
\q2  
\v 24 Ụgbọ mmiri ga-esi nʼọnụ mmiri Saiprọs bịa. 
\q1 Ha ga-eji ike dobe ndị Eba\f + \fr 24:24 \ft Eba bụ nna nna ndị Hibru. \xt Jen 10:21; 1Ih 1:25-27\f* na ndị Ashọ nʼokpuru ha, 
\q2 ma a ga-ebibikwa ha onwe ha.” 
\p  
\v 25 Emesịa, Belam biliri laghachi nʼụlọ ya, ma Balak gbasoro ụzọ nke ya. 
\c 25  
\s1 Moab emee ka Izrel mehie 
\p  
\v 1 Mgbe Izrel bi na Shitim, ndị ikom ha malitere isoro ndị inyom Moab na-akwa iko.  
\v 2 Ndị inyom a kpọrọ ha ka ha bịa soro na mmemme ịchụ aja nye chi ha niile. Ndị Izrel riri nri ihe aja ahụ, kpọọkwa isiala nye chi ndị a niile.  
\v 3 Ya mere, ndị Izrel sonyere na-akpọ isiala nye chi Baal nke Peoa.\f + \fr 25:3 \ft Ha sitere nʼịkpọ isiala kekọta onwe ha nʼahụ Baal-Peoa.\f* Nke a mere ka iwe \nd Onyenwe anyị\nd* nwuru ọkụ megide ha. 
\p  
\v 4 \nd Onyenwe anyị\nd* gwara Mosis okwu sị ya, “Duru ndị ndu ebo niile nke Izrel gbuo ha ma kwụnye ha nʼosisi nʼihu \nd Onyenwe anyị\nd* nʼetiti ehihie, ka oke iwe \nd Onyenwe anyị\nd* dị ọkụ ghara ịbịakwasị ndị Izrel.” 
\p  
\v 5 Ya mere, Mosis sịrị ndị ọkaikpe Izrel, “Onye ọbụla nʼime unu aghaghị igbu ndị unu, bụ ndị jikọtara onwe ha na Baal nke Peoa.” 
\p  
\v 6 Mgbe ahụ, otu nwoke onye Izrel kpọbatara nʼime ụlọ ikwu otu nwanyị onye Midia, nʼihu Mosis na nzukọ Izrel niile, mgbe ha niile nọ na-akwa akwa nʼọnụ ụzọ ụlọ nzute ahụ.  
\v 7 Mgbe Finehaz na Elieza, nwa Erọn, onye nchụaja hụrụ ihe a, ọ hapụrụ ọgbakọ Izrel. O were ùbe nʼaka ya,  
\v 8 soro nwoke ahụ baa nʼime ụlọ, ebe ya na nwaagbọghọ ahụ dina. Ọ mara ha ùbe ahụ, nke si nʼahụ nwoke ahụ gafee mikpuo nʼafọ nwaagbọghọ ahụ. Nke a mere ka ihe otiti ahụ na-emegide ndị Izrel kwụsị.  
\v 9 Ma tupu ihe otiti ahụ akwụsị, ndị mmadụ ọnụọgụgụ ha ruru iri puku abụọ na anọ (24,000) anwụọlarị. 
\p  
\v 10 \nd Onyenwe anyị\nd* gwara Mosis okwu sị,  
\v 11 “Finehaz nwa Elieza, nwa Erọn, onye nchụaja, emeela ka iwe m megide Izrel dajụọ. Nʼihi na o nwere ịnụ ọkụ nʼobi dịka mụ onwe m banyere idebe nsọpụrụ m nsọ nʼetiti ha, ka m ghara isite nʼịnụ ọkụ nke obi m bibie ha.  
\v 12 Ya mere, gwa ya, na m na-eme ka ọgbụgba ndụ udo m dịrị ya.  
\v 13 Ya na ụmụ ụmụ ya ka ọgbụgba ndụ ebighị ebi nke ịrụ ọrụ nchụaja ga-adịrị, nʼihi na o nwere ịnụ ọkụ nʼobi banyere nsọpụrụ nke Chineke ya, si otu a chụọrọ ndị Izrel aja ikpuchi mmehie.” 
\p  
\v 14 Aha nwoke Izrel ahụ e gburu ya na nwanyị onye Midia ahụ bụ Zimri, nwa Salu, onyendu otu ezinaụlọ nʼebo Simiọn.  
\v 15 Aha nwanyị Midia ahụ e gburu bụ Kozbi, nwa nwanyị Zua, onye bụ otu nʼime ndịisi ezinaụlọ na Midia. 
\p  
\v 16 \nd Onyenwe anyị\nd* gwara Mosis okwu sị ya,  
\v 17 “Mesoo ndị Midia mmeso dịka ndị iro. Gbukwaa ha.  
\v 18 Nʼihi na ha mesoro unu mmeso dịka ndị iro mgbe ha ji ụzọ aghụghọ ghọgbuo unu nʼokwu Peoa, na nʼokwu Kozbi nwanne ha nwanyị, bụ nwa nwanyị otu nʼime ndịisi Midia, onye e gburu mgbe ihe otiti ahụ bịara nʼihi okwu Peoa.” 
\c 26  
\s1 Ịgụ ọnụ nke ugboro abụọ 
\p  
\v 1 Mgbe ihe otiti ahụ niile gasịrị, \nd Onyenwe anyị\nd* gwara Mosis na Elieza nwa Erọn, onye nchụaja okwu sị ha,  
\v 2 “Gaanụ gụọ, chọpụta ọnụọgụgụ nzukọ niile nke ụmụ Izrel dịka ezinaụlọ ha si dị; ndị niile gbara iri afọ abụọ gafee. Chọpụta ọnụọgụgụ ndị nwere ike ije agha.”  
\v 3 Ya mere, na mbara ala Moab, nʼakụkụ osimiri Jọdan, na ncherita ihu Jeriko, ka Mosis na Elieza onye nchụaja nọ gwa ha okwu sị ha,  
\v 4 “Gụọnụ ndị ikom gbara iri afọ abụọ gafee ọnụ, dịka \nd Onyenwe anyị\nd* nyere Mosis nʼiwu.” 
\b  
\li4 Ndị a bụ ndị Izrel si Ijipt pụta: 
\b  
\li1  
\v 5 Ụmụ ụmụ Ruben, ọkpara Izrel, bụ ndị a: 
\li2 site na Hanok, ikwu Hanok, 
\li2 site na Palu, ikwu Palu, 
\li2  
\v 6 site na Hezrọn, ikwu Hezrọn 
\li2 site na Kami, ikwu Kami 
\li4  
\v 7 Ndị a bụ agbụrụ Ruben. Ọnụọgụgụ ha dị iri puku anọ, puku atọ na narị asaa na iri atọ (43,730). 
\li2  
\v 8 Nwa Palu bụ Eliab,  
\v 9 ụmụ Eliab bụ Nemuel, Datan na Abiram. Datan na Abiram bụ ndị ndu ọgbakọ ahụ nupuru isi megide Mosis na Erọn. Ha sonyere ndị ahụ so Kora mgbe ha nupuru isi megide \nd Onyenwe anyị\nd*.  
\v 10 Ala meghere ọnụ ya, loo ha na Kora, ma ọkụ rechapụrụ narị mmadụ abụọ na iri ise ndị ọzọ ahụ sonyere ha. Ọnwụ ha ghọrọ ihe ịdọ aka na ntị.  
\v 11 Otu ọ dị, ndị niile si nʼezinaụlọ Kora anwụchaghị. 
\b  
\li1  
\v 12 Ụmụ ụmụ Simiọn dịka ikwu ha si dị bụ, 
\li2 site na Nemuel, ikwu Nemuel, 
\li2 site na Jamin, ikwu Jamin, 
\li2 site na Jakin, ikwu Jakin, 
\li2  
\v 13 Site na Zera, ikwu Zera, 
\li2 site na Shaul, ikwu Shaul. 
\li4  
\v 14 Ndị a bụ ndị agbụrụ Simiọn. Ọnụọgụgụ ndị ikom ha dị iri puku abụọ, puku abụọ na narị abụọ (22,200). 
\b  
\li1  
\v 15 Ụmụ ụmụ Gad dịka ikwu ha si dị bụ ndị a: 
\li2 ikwu Zefọn, site na Zefọn, 
\li2 ikwu Hagi, site na Hagi, 
\li2 ikwu Shuni, site na Shuni, 
\li2  
\v 16 ikwu Ozni, site na Ozni, 
\li2 ikwu Eri, site na Eri, 
\li2  
\v 17 ikwu Arodi, site na Arodi, 
\li2 ikwu Areli, site na Areli, 
\li4  
\v 18 Ndị a bụ agbụrụ Gad. Ndị a gụrụ ọnụ dị iri puku anọ na narị ise (40,500). 
\b  
\li4  
\v 19 Ụmụ ndị ikom Juda abụọ, Ịa na Onan, nwụrụ nʼala Kenan. 
\li1  
\v 20 Ma ụmụ ụmụ Juda ndị ọzọ, dịka ikwu ha dị iche iche si dị bụ ndị a: 
\li2 ikwu Shela, site na Shela, 
\li2 ikwu Perez, site na Perez, 
\li2 ikwu Zera, site na Zera. 
\li2  
\v 21 Ikwu abụọ ọzọ si nʼagbụrụ Perez bụ ndị a: 
\li3 Ikwu Hezrọn, site na Hezrọn, 
\li3 Ikwu Hamul, site na Hamul. 
\li4  
\v 22 Ndị a bụ agbụrụ Juda. Ndị a gụrụ ọnụ dị iri puku asaa, puku isii na narị ise (76,500). 
\b  
\li1  
\v 23 Ụmụ ụmụ Isaka dịka ikwu ha si dị bụ ndị a: 
\li2 ikwu Tola, site na Tola, 
\li2 ikwu Pua, site na Pua 
\li2  
\v 24 ikwu Jashub, site na Jashub, 
\li2 ikwu Shịmrọn, site na Shịmrọn. 
\li4  
\v 25 Ndị a bụ agbụrụ Isaka. Ndị a gụrụ ọnụ dị iri puku isii, puku anọ na narị atọ (64,300). 
\b  
\li1  
\v 26 Ụmụ ụmụ Zebụlọn dịka ikwu ha si dị bụ ndị a: 
\li2 ndị Sered, site nʼikwu Sered, 
\li2 ndị Elọn, site nʼikwu Elọn, 
\li2 ndị Jaliil, site nʼikwu Jaliil. 
\li4  
\v 27 Ndị a bụ agbụrụ Zebụlọn. Ndị a gụrụ ọnụ dị iri puku isii na narị ise (60,500). 
\b  
\li4  
\v 28 Ụmụ ụmụ Josef dịka ha si dị nʼagbụrụ Manase na Ifrem bụ ndị a: 
\li1  
\v 29 Ụmụ ụmụ Manase bụ ndị a: 
\li2 ndị Makia, site nʼikwu Makia. Makia bụ nna Gilead. 
\li2 Ikwu Gilead, site na Gilead. 
\li2  
\v 30 Ndị a bụ ụmụ ụmụ Gilead: 
\li3 ikwu Leza, site na Leza, 
\li3 ikwu Helek, site na Helek. 
\li3  
\v 31 Ikwu Asriel, site na Asriel. 
\li3 Ikwu Shekem, site na Shekem. 
\li3  
\v 32 Ikwu Shemida, site na Shemida, 
\li3 ikwu Hefa, site na Hefa. 
\li3  
\v 33 (Hefa mụtara nwoke a na-akpọ Zelofehad. Ma Zelofehad amụtaghị nwoke ọbụla kama ndị inyom ndị a ka ọ mụtara, Mahla, na Noa, na Hogla, na Milka, na Tịaza.) 
\li4  
\v 34 Ndị a bụ agbụrụ Manase. Ndị a gụrụ ọnụ dị iri puku ise, puku abụọ na narị asaa (52,700). 
\li1  
\v 35 Ndị a bụ ụmụ ụmụ Ifrem dịka ikwu ha si dị: 
\li2 ikwu Shutela site na Shutela, 
\li2 ikwu Beka site na Beka, 
\li2 ikwu Tahan site na Tahan. 
\li2  
\v 36 Ndị a bụ ụmụ ụmụ Shutela: 
\li3 ikwu Eran site na Eran. 
\li4  
\v 37 Ndị a bụ agbụrụ Ifrem. Ndị a gụrụ ọnụ dị iri puku atọ, puku abụọ na narị ise (32,500). 
\li4 Ndị a bụ ụmụ ụmụ Josef dịka ikwu ha si dị. 
\b  
\li1  
\v 38 Ndị a bụ ụmụ ụmụ Benjamin dịka ikwu ha si dị: 
\li2 ikwu Bela site na Bela, 
\li2 ikwu Ashbel site Ashbel, 
\li2 ikwu Ahiram site na Ahiram. 
\li2  
\v 39 Ikwu Shufam site na Shufam, 
\li2 ikwu Hufam site na Hufam. 
\li2  
\v 40 Ụmụ ụmụ Bela site na Aad, na Naaman bụ, 
\li3 ikwu Aad site na Aad, 
\li3 ikwu Neeman site na Neeman. 
\li4  
\v 41 Ndị a bụ agbụrụ Benjamin. Ndị a gụrụ ọnụ dị iri puku anọ, puku ise na narị isii (45,600). 
\b  
\li1  
\v 42 Ụmụ ụmụ Dan dịka ikwu ha si dị bụ ndị a: 
\li2 ikwu Shuham, site na Shuham. 
\li4 Ndị a bụ naanị ikwu dị na Dan.  
\v 43 Ha niile si nʼagbụrụ Shuham. Ndị a gụrụ ọnụ dị iri puku isii, puku anọ na narị anọ (64,400). 
\b  
\li1  
\v 44 Ụmụ ụmụ Asha dịka ikwu ha si dị bụ ndị a: 
\li2 ikwu Imna site na Imna, 
\li2 ikwu Ishvi, site na Ishvi, 
\li2 ikwu Beriya, site na Beriya. 
\li2  
\v 45 Ikwu e nwere site nʼụmụ ụmụ Beriya bụ ndị a: 
\li3 ikwu Heba, site na Heba, 
\li3 ikwu Malkiel, site na Malkiel. 
\li4  
\v 46 Asha mụtakwara otu nwa nwanyị aha ya bụ Sera. 
\li4  
\v 47 Ndị a bụ agbụrụ Asha. Ndị a gụrụ ọnụ dị iri puku ise, puku atọ na narị anọ (53,400). 
\b  
\li1  
\v 48 Ụmụ ụmụ Naftalị dịka ikwu ha si dị bụ ndị a: 
\li2 ikwu Jaziil, site na Jaziil, 
\li2 ikwu Guni, site na Guni, 
\li2  
\v 49 ikwu Jeza, site na Jeza, 
\li2 ikwu Shilem, site na Shilem. 
\li4  
\v 50 Ndị a si nʼagbụrụ Naftalị. Ndị a gụrụ ọnụ dị iri puku anọ, puku ise na narị anọ (45,400). 
\b  
\li4  
\v 51 Ya mere, ọnụọgụgụ ndị ikom niile tozuru ije agha nʼIzrel dị narị puku isii, otu puku na narị asaa, na iri atọ (601,730). 
\b  
\p  
\v 52 Mgbe ahụ, \nd Onyenwe anyị\nd* gwara Mosis okwu sị ya,  
\v 53 “Ị ga-ekenye ha ala ahụ ka ọ bụrụ ihe nketa ha dịka ọnụọgụgụ aha ha si dị.  
\v 54 Ndị dị ukwuu nʼọnụọgụgụ ga-eketa ala dị ukwuu, ma ndị dị nta ga-eketa ala dị nta. Ihe nketa nke onye ọbụla ga-enweta ga-adị ka ọnụọgụgụ ahụ e dere.  
\v 55 Lezie anya hụ na e kesara ala ahụ site nʼife nza. Ala ndị ọbụla ga-eketa ga-abụ dịka aha nna ochie ebo ha si dị.  
\v 56 A ga-esite nʼife nza kenye ndị ọbụla ihe nketa nke ha dịka ịdị ukwuu maọbụ ịdị nta ha si dị.” 
\b  
\li1  
\v 57 Ndị a bụ ndị Livayị a gụrụ ọnụ dịka ikwu ha si dị, 
\li2 ikwu Geshọn, site na Geshọn, 
\li2 ikwu Kohat, site na Kohat, 
\li2 ikwu Merari, site na Merari. 
\li1  
\v 58 Ndị a sikwa nʼagbụrụ Livayị: 
\li2 ikwu Libni, 
\li2 ikwu Hebrọn, 
\li2 ikwu Mahali, 
\li2 ikwu Mushi, na 
\li2 ikwu Kora. 
\li2 (Kohat bụ nna nna Amram.  
\v 59 Aha nwunye Amram bụ Jekobed, nwa nwa Livayị, onye a mụrụ nʼagbụrụ ndị Livayị nʼIjipt. Ọ mụtaara Amram ụmụ ndị a: Erọn na Mosis, na Miriam, nwanne ha nwanyị.  
\v 60 Erọn mụtara Nadab, na Abihu, na Elieza, na Itama.  
\v 61 Ma Nadab na Abihu nwụrụ mgbe ha chere ọkụ na-adịghị nsọ nʼihu \nd Onyenwe anyị\nd*.) 
\b  
\li4  
\v 62 Ọnụọgụgụ ụmụ ndị ikom Livayị niile dị otu ọnwa gaa nʼihu dị iri puku abụọ na puku atọ (23,000). Ma a gụnyekọghị ọnụọgụgụ agbụrụ Livayị nʼọnụọgụgụ ndị Izrel, nʼihi na agbụrụ Livayị enweghị oke ọbụla mgbe e kenyere agbụrụ Izrel niile ihe nketa ha. 
\b  
\p  
\v 63 Ya mere, ndị a bụ nchọpụta ọnụọgụgụ ụmụ Izrel, dịka Mosis na Elieza onye nchụaja kwadobere gụọ na mbara ala Moab, nʼakụkụ osimiri Jọdan, na ncherita ihu obodo Jeriko.  
\v 64 Ma nʼetiti ndị a, o nweghị otu onye ọbụla Mosis na Erọn onye nchụaja gụrụ nʼọnụọgụgụ mgbe ha gụrụ ndị Izrel ọnụ nʼọzara Saịnaị.  
\v 65 Nʼihi na \nd Onyenwe anyị\nd* gwara ndị Izrel ahụ na ha ga-anwụ nʼime ọzara ahụ. Naanị ndị a hapụrụ ndụ bụ Kaleb, nwa Jefune, na Joshua nwa Nun. 
\c 27  
\s1 Ụmụ ndị inyom Zelofehad 
\p  
\v 1 Ụmụ ndị inyom Zelofehad nwa Hefa, nwa Gilead, nwa Makia, nwa Manase bụ ndị si nʼagbụrụ Manase nwa Josef. Aha ndị inyom ndị a bụ: Mahla, Noa, Hogla, Milka na Tịaza. Ha bịara,  
\v 2 nʼọnụ ụzọ ụlọ nzute, guzo nʼihu Mosis, na Elieza onye nchụaja, na ndị ndu niile na ọgbakọ Izrel niile kwuo sị,  
\v 3 “Nna anyị Zelofehad nwụrụ nʼọzara ma ọ bụghị otu nʼime ndị sonyere Kora, bụ ndị ahụ zukọtara megide \nd Onyenwe anyị\nd*. Ọ nwụrụ ọnwụ nʼihi mmehie nke ya. Ma otu ọ dị, ọ mụtaghị nwoke.  
\v 4 Gịnị ga-eme a ga-eji hichapụ aha nna anyị site nʼagbụrụ ya nʼihi na ọ mụtaghị nwoke? Ọ bụ uche anyị na e kwesiri ikenye anyị oke nʼoge a na-enye ụmụnne nna anyị oke.” 
\p  
\v 5 Ya mere, Mosis butere mkpa ha nʼihu \nd Onyenwe anyị\nd*.  
\v 6 Ma \nd Onyenwe anyị\nd* zaghachiri Mosis sị ya,  
\v 7 “Ihe ụmụ Zelofehad na-ekwu ziri ezi. Ị ghaghị ikenye ha oke nʼetiti ụmụnne nna ha, ma nyefeekwa ha oke ruru nna ha. 
\p  
\v 8 “Gwa ndị Izrel sị ha, ‘Ọ bụrụ na nwoke ọbụla anwụọ na-amụtaghị nwoke, oke niile ruru ya ga-alara nwa ya nwanyị.  
\v 9 Ma ọ bụrụ na ọ mụtaghị nwa nwanyị, oke ruru ya ga-alara ụmụnne ya ndị nwoke.  
\v 10 A sịkwa na o nweghị ụmụnne ndị nwoke, mgbe ahụ oke ya ga-alara ụmụnne nna ya ndị nwoke.  
\v 11 Ọ bụrụkwa na o nweghị ndị nwoke bụ ụmụnne nna ya, mgbe ahụ ihe nketa ya ga-alara onye dịkarịrị ya nso nʼikwu ya, ka ọ bụrụ nke ya. Nke a bụ iwu dịrị ndị Izrel niile dịka \nd Onyenwe anyị\nd* si nye ya Mosis nʼiwu.’ ” 
\s1 Joshua aghọọ onyendu 
\p  
\v 12 Mgbe ahụ, \nd Onyenwe anyị\nd* gwara Mosis okwu sị ya: “Gaa rigoro nʼugwu Abarim site nʼebe ahụ lefee anya nʼofe mmiri Jọdan leruo ala ahụ nke m nyere ụmụ Izrel anya.  
\v 13 Mgbe i lechasịrị ya, ị ga-anwụ dịka nwanne gị Erọn nwụrụ.  
\v 14 Nʼihi na unu nupuru isi nye okwu m nʼọzara Zin, mgbe ọgbakọ ụmụ Izrel sesịrị m okwu. Unu abụọ nupuru isi nʼiwu m ido m nsọ nʼihu ha.” (Ndị a bụ mmiri Meriba Kadesh, nke dị nʼọzara Zin.) 
\p  
\v 15 Mosis zara \nd Onyenwe anyị\nd* sị ya,  
\v 16 “Ka \nd Onyenwe anyị\nd*, Chineke nwe mmụọ nke mmadụ niile, họpụta onyendu ga-elekọta ọgbakọ a.  
\v 17 Onye ga na-apụ na-abatakwa nʼihu ha, onye ga na-edu ha pụọ, duru ha batakwa, ka ndị \nd Onyenwe anyị\nd* ghara ịdị ka atụrụ na-enweghị onye ọzụzụ.” 
\p  
\v 18 Ya mere, \nd Onyenwe anyị\nd* sịrị Mosis, “Kpọrọ Joshua, nwa Nun, onye nwere mmụọ Chineke nʼime ya, bikwasị ya aka gị.  
\v 19 Mee ka o guzo nʼihu Elieza onye nchụaja, nakwa nʼihu ọgbakọ niile, nyefee ya ọrụ nke ịbụ onyendu nʼihu ha.  
\v 20 Nyekwa ha ụfọdụ ikike\f + \fr 27:20 \ft Maọbụ, \fqa ebube nke ya na ikike so\f* gị, ka nzukọ niile nke ụmụ Izrel nwee ike rubere ya isi.  
\v 21 Ma ya onwe ya ga-eguzo nʼihu Elieza onye nchụaja, onye ga-ajụrụ ya ase site na mkpebi Urim nʼihu \nd Onyenwe anyị\nd*. Ọ bụ site nʼokwu ọnụ ya ka ha ga-apụ, site nʼokwu ọnụ ya ka ha ga-ana abata. Ma ya onwe ya, ma ndị Izrel niile, tinyekwara nzukọ niile.” 
\p  
\v 22 Ya mere, Mosis mere dịka \nd Onyenwe anyị\nd* nyere ya iwu. O duuru Joshua mee ka o guzo nʼihu Elieza onye nchụaja na ọgbakọ niile.  
\v 23 Mosis bikwasịrị aka ya abụọ nʼisi Joshua, rara ya nyefee maka ije ozi ahụ niile dịka \nd Onyenwe anyị\nd* nyere Mosis nʼiwu. 
\c 28  
\s1 Aja nke ụbọchị niile 
\p  
\v 1 \nd Onyenwe anyị\nd* gwara Mosis okwu sị ya,  
\v 2 “Nye ndị Izrel iwu a sị ha, ‘Lezienụ anya hụ na unu na-eche nʼihu m, nʼoge niile a kara aka, nri ahụ a na-enye maka onyinye m a na-enye site nʼọkụ, nke isisi ya na-adị m ezi mma.’  
\v 3 Sị ha, ‘Nke a bụ onyinye unu na-enye site nʼọkụ nke unu na-eche nʼihu \nd Onyenwe anyị\nd*: ụmụ atụrụ abụọ gbara otu afọ, nke na-enweghị ntụpọ, ka e jiri ha chụọ aja nsure ọkụ kwa ụbọchị niile.  
\v 4 Chụọ otu nwa atụrụ nʼoge ụtụtụ, chụọkwa nke ọzọ nʼoge uhuruchi.  
\v 5 Ị ga-ejikwa lita ụtụ ọka abụọ a kwọziri akwọzi nke a gwọkọtara nʼotu lita mmanụ oliv asụrụ asụ, chụọ aja mkpụrụ ọka.  
\v 6 Nke a bụ aja nsure ọkụ ahụ \nd Onyenwe anyị\nd* nyere iwu ya nʼugwu Saịnaị na a ga na-achụrụ ya mgbe niile, dịka aja isisi ya dị ezi mma, aja nke a chụrụ site nʼọkụ nye \nd Onyenwe anyị\nd*.  
\v 7 Mmanya ga-eso aja a ga-abụ otu lita mmanya gbara ụka nʼisi otu atụrụ ọbụla, ị ga-awụsa aja ihe ọṅụṅụ a nʼebe nsọ nye \nd Onyenwe anyị\nd*.  
\v 8 Nʼoge anyasị, ị ga-ewerekwa nwa atụrụ nke abụọ, ya na otu ụdị aja mkpụrụ ọka na aja ihe ọṅụṅụ dị ka i mere nʼụtụtụ, jiri chụọ aja. Nke a bụkwa aja e sitere nʼọkụ chụọ, nke isisi ya dị ezi mma nye \nd Onyenwe anyị\nd*. 
\s1 Aja nke ụbọchị izuike 
\p  
\v 9 “ ‘Nʼụbọchị izuike, jiri ụmụ atụrụ abụọ gbara otu afọ, otu afọ, ndị na-enweghị ntụpọ, ha na aja ihe ọṅụṅụ na aja mkpụrụ ọka e ji lita ụtụ ọka anọ na ọkara a kwọziri akwọzi, nke a gwaziri mmanụ mee.  
\v 10 Nke a bụ aja nsure ọkụ nke Ụbọchị Izuike, tinyere aja nsure ọkụ na aja ihe ọṅụṅụ ndị ahụ a na-achụ nʼoge ha. 
\s1 Aja nke ụbọchị mbụ nʼọnwa 
\p  
\v 11 “ ‘Ọzọ, nʼụbọchị mbụ nke ọnwa ọbụla, a ga-achụrụ \nd Onyenwe anyị\nd* aja nsure ọkụ dị iche, nke a ga-eji ụmụ oke ehi abụọ, na otu ebule, na ụmụ ebule asaa gbara otu afọ, otu afọ, ndị na-enweghị ntụpọ chụọ.  
\v 12 Tinyere oke ehi ọbụla, ị ga-eji lita ụtụ ọka isii na ọkara a kwọziri nke ọma, nke a gwara mmanụ chụọ aja. Ma lita ụtụ ọka anọ na ọkara a kwọziri nke ọma, nke a gwakọtakwara mmanụ ka a ga-eji chụọ aja mkpụrụ ọka maka otu ebule ọbụla.  
\v 13 Ma nʼisi otu nwa atụrụ ọbụla, ọ bụ lita ụtụ ọka abụọ a kwọziri nke ọma, nke a gwakọtara ya na mmanụ ka a ga-eji chụọ aja mkpụrụ ọka. A ga-eji ha chụọ aja nsure ọkụ nke isisi ya ga-atọkwa \nd Onyenwe anyị\nd* ezi ụtọ.  
\v 14 Aja ọbụla a chụrụ ga-enwe aja ihe ọṅụṅụ nke ga-eso ya, lita mmanya abụọ maka otu oke ehi, ihe ji ntakịrị karịa otu lita mmanya nʼisi otu ebule, na otu lita nʼisi otu nwa atụrụ. Nke a ga-abụ aja nsure ọkụ nke a ga-achụ nʼoge ọnwa ọhụrụ ọ bụla, nʼime afọ ọbụla,  
\v 15 nʼagbanyeghị aja nsure ọkụ na aja ihe ọṅụṅụ nke a na-achụ dịka mgbe ha si dị, a ga-eche otu mkpi nʼihu \nd Onyenwe anyị\nd* dịka aja mmehie. 
\s1 Mmemme Ngabiga 
\p  
\v 16 “ ‘Nʼụbọchị nke iri na anọ nke ọnwa mbụ, ka a ga-edebe Mmemme Ngabiga. \nd Onyenwe anyị\nd*.  
\v 17 Nʼụbọchị na-eso ya, bụ abalị iri na ise nke ọnwa ahụ ka a ga-eme mmemme. Nʼime abalị asaa ka a ga-eri achịcha a na-ejighị ihe na-eko achịcha mee.  
\v 18 Nʼụbọchị mbụ mmemme a bidoro, a ga-akpọ nzukọ dị nsọ nke ndị Izrel niile. Ọ dịghị ọrụ siri ike a ga-arụ nʼụbọchị ahụ.  
\v 19 Unu ga-eji ụmụ oke ehi abụọ, na otu ebule, na ụmụ ebule asaa gbara naanị otu afọ, otu afọ, nke na-enweghị ntụpọ ọbụla chụọrọ \nd Onyenwe anyị\nd* aja nsure ọkụ.  
\v 20 Nʼisi otu oke ehi ọbụla, a ga-achụ aja mkpụrụ ọka nke a ga-eji lita ụtụ ọka isii na ọkara a kwọziri nke ọma, a gwakọtara ya na mmanụ chụọ. Nʼisi ebule ọbụla, lita ụtụ ọka anọ na ọkara.  
\v 21 Ma nʼisi otu nwa atụrụ ọbụla, a ga-enye lita ụtụ ọka abụọ a kwọziri nke ọma.  
\v 22 Tinye otu mkpi nʼihi ịchụ aja mmehie maka ikpuchiri unu mmehie unu.  
\v 23 A ga-achụ aja ndị a, tinyere aja ndị ọzọ niile a na-achụ nʼụbọchị niile.  
\v 24 A ga-achụ aja ndị a ụbọchị niile nʼime ụbọchị asaa nke mmemme ahụ. Ha ga-abụ aja nke isisi ha dị \nd Onyenwe anyị\nd* ezi ụtọ. A ga-achụ ha, chụkwaa aja nsure ọkụ na aja ihe ọṅụṅụ nke a na-achụ dịka mgbe ha si dị.  
\v 25 Nʼụbọchị nke asaa nweenụ mkpọkọta dị nsọ, unu arụkwala ọrụ nke ụbọchị ahụ. 
\s1 Mmemme Izu Asaa 
\p  
\v 26 “ ‘Nʼụbọchị mbụ nke mkpụrụ mbụ, mgbe unu na-eche onyinye ọka ọhụrụ unu nʼihu \nd Onyenwe anyị\nd* nʼoge mmemme Izu Asaa, nweenụ mkpọkọta dị nsọ. Unu arụkwala ọrụ nke ụbọchị ahụ.  
\v 27 Unu ga-achụ aja nsure ọkụ, nke isisi ya dị ezi mma nye \nd Onyenwe anyị\nd*. Ọ bụ ụmụ oke ehi abụọ, na otu ebule, na ụmụ ebule asaa gbara otu afọ, otu afọ, ka a ga-eji chụọ aja a.  
\v 28 Ihe unu ga-etinye nʼihe ndị a bụ aja mkpụrụ ọka a ga-eji lita ụtụ ọka isii na ọkara a kwọziri akwọzi, nke a gwakọtara ya na mmanụ chụọ, nʼisi otu oke ehi. Lita ụtụ ọka anọ na ọkara, nʼisi otu ebule,  
\v 29 na lita ụtụ ọka abụọ, nʼisi otu nwa atụrụ ọbụla.  
\v 30 Ọzọkwa, a ga-eji otu mkpi chụọ aja maka mkpuchi mmehie unu.  
\v 31 Dozie aja ndị a tinyere aja ihe ọṅụṅụ ha, ya na aja nsure ọkụ na aja mkpụrụ ọka ya na aja ahụ so. Hụkwanụ na anụ ụlọ e ji chụọ aja ndị a bụ ndị na-enweghị ntụpọ ọbụla. 
\c 29  
\s1 Mmemme Opi Ike 
\p  
\v 1 “ ‘Ụbọchị unu ga-egbu opi ike ga-adị nʼabalị mbụ nke ọnwa asaa nʼafọ ọbụla. Nʼụbọchị ahụ, a ga-enwe mkpọkọta dị nsọ nke mmadụ niile. Unu agaghị arụ ọrụ ọbụla nʼụbọchị ahụ.  
\v 2 Nʼụbọchị ahụ, unu ga-achụ aja nsure ọkụ a ga-eji otu oke ehi, na ebule, na ụmụ atụrụ asaa gbara otu afọ, otu afọ ndị na-enweghị ntụpọ, chụọ. Nke a bụ aja na-adị \nd Onyenwe anyị\nd* ezi mma, ma na-esi ya isi ụtọ.  
\v 3 Aja mkpụrụ ọka ka a ga-eji lita ụtụ ọka isii na ọkara a gwakọtara ya na mmanụ chụọ, nʼisi oke ehi ahụ, lita anọ na ọkara, nʼisi ebule,  
\v 4 na lita abụọ, nʼisi otu nwa atụrụ ọbụla.  
\v 5 Tinyere otu mkpi a ga-eji chụọ aja maka mkpuchi mmehie unu.  
\v 6 Aja ndị a niile bụ nke a ga-etinye nye nʼaja nsure ọkụ a na-achụ kwa ọnwa, na aja nsure ọkụ a na-achụ ụbọchị niile, ha na aja mkpụrụ ọka, na aja ihe ọṅụṅụ dịka e depụtara. Ha bụ aja ihe oriri a na-achụrụ \nd Onyenwe anyị\nd*, aja nwere isisi dị ụtọ. 
\s1 Aja ikpuchi mmehie 
\p  
\v 7 “ ‘Nʼụbọchị nke iri nke ọnwa asaa ahụ, unu ga-enwekwa nzukọ dị nsọ. Unu ga-ebudata onwe unu nʼala. O nweghịkwa ụdị ọrụ ọbụla unu ga-arụ.  
\v 8 Nʼụbọchị ahụ, unu ga-achụrụ \nd Onyenwe anyị\nd* aja nsure ọkụ, nke isisi ya na-atọ ya ụtọ. A ga-eji otu nwa oke ehi, na otu ebule, na ụmụ ebule asaa gbara otu afọ, otu afọ ndị na-enweghị ntụpọ chụọ aja a.  
\v 9 Aja mkpụrụ ọka ga-eso ya. A ga-eji lita ụtụ ọka isii na ọkara a gwakọtara ya na mmanụ chụọ aja nwa oke ehi ahụ. Jiri lita ụtụ ọka anọ na ọkara chụọ aja ebule,  
\v 10 jirikwa lita ụtụ ọka abụọ chụọ aja nʼisi otu nʼime nwa atụrụ ọbụla.  
\v 11 Tinyekwa otu mkpi a ga-eji chụọ aja mmehie. A ga-atụkwasị nke a nʼaja mkpuchi mmehie a na-achụ, tinyere aja nsure ọkụ a na-achụ ụbọchị niile, na aja mkpụrụ ọka, na aja ihe ọṅụṅụ niile. 
\s1 Mmemme Ụlọ Ikwu 
\p  
\v 12 “ ‘Nʼụbọchị iri na ise nke ọnwa asaa, a ga-enwe mkpọkọta dị nsọ nke ụmụ Izrel niile. Nʼụbọchị ahụ, onye ọbụla agaghị arụ ọrụ ọbụla, nʼihi na ọ bụ mmalite mmemme abalị asaa nʼihu \nd Onyenwe anyị\nd*.  
\v 13 Cheenụ onyinye a na-enye site nʼọkụ nʼihu \nd Onyenwe anyị\nd* nke isisi ya na-atọ ya ụtọ, jirinụ oke ehi iri na atọ, na ebule abụọ, na ụmụ ebule iri na anọ ndị na-enweghị ntụpọ, ndị gbara otu afọ, otu afọ, chụọ aja nsure ọkụ.  
\v 14 A ga-atụkwasịkwa aja mkpụrụ ọka nke e ji lita ụtụ ọka isii na ọkara gwakọta ya na mmanụ, nʼisi otu nʼime oke ehi iri na atọ ndị ahụ niile. Lita anọ na ọkara nʼisi otu ebule nʼime ebule abụọ ndị ahụ,  
\v 15 ma lita abụọ nʼisi otu nʼime nwa atụrụ ọbụla.  
\v 16 Tinyekwa otu mkpi maka ịchụ aja mmehie, ya na aja nsure ọkụ a na-achụ nʼoge ha, tinyere aja mkpụrụ ọka na aja onyinye ihe ọṅụṅụ so ha. 
\p  
\v 17 “ ‘Nʼụbọchị abụọ nke mmemme a, a ga-eji oke ehi iri na abụọ, ebule abụọ, na ụmụ ebule iri na anọ gbara otu afọ, otu afọ, ndị na-enweghị ntụpọ chụọ aja.  
\v 18 Ihe ga-eso aja oke ehi, na ebule na ụmụ atụrụ ndị ahụ nʼọnụọgụgụ ha, bụ aja mkpụrụ ọka, na aja ihe ọṅụṅụ dịka e si nye ya nʼiwu.  
\v 19 Tinyekwa otu mkpi maka aja mmehie, ya na aja nsure ọkụ a na-achụ nʼoge ha, na aja mkpụrụ ọka, na aja ihe ọṅụṅụ so ha. 
\p  
\v 20 “ ‘Nʼụbọchị nke atọ nke mmemme ahụ, ị ga-ewere ụmụ oke ehi iri na otu, na ebule abụọ, na ụmụ ebule iri na anọ ndị gbara otu afọ, otu afọ, ndị na-enweghị ntụpọ, chụọ aja.  
\v 21 Ihe ga-eso aja oke ehi na ebule na ụmụ atụrụ ndị ahụ nʼọnụọgụgụ ha bụ aja mkpụrụ ọka na aja ihe ọṅụṅụ dịka e si nye ya nʼiwu.  
\v 22 Tinyekwa otu mkpi maka aja mmehie, ya na aja nsure ọkụ a na-achụ nʼoge ha, na aja mkpụrụ ọka, na aja ihe ọṅụṅụ so ha. 
\p  
\v 23 “ ‘Nʼụbọchị nke anọ nke mmemme ahụ, ị ga-ewere ụmụ oke ehi iri, ebule abụọ, ụmụ ebule iri na anọ ndị gbara otu afọ, otu afọ, ndị na-enweghị ntụpọ, chụọ aja.  
\v 24 Ihe ga-eso aja oke ehi, ebule na ụmụ atụrụ ndị ahụ nʼọnụọgụgụ ha bụ aja mkpụrụ ọka, na aja ihe ọṅụṅụ dịka e si nye ya nʼiwu.  
\v 25 Tinyekwa otu mkpi maka ịchụ aja mmehie ya na aja nsure ọkụ a na-achụ nʼoge ha, tinyere aja mkpụrụ ọka, na aja onyinye ihe ọṅụṅụ so ha. 
\p  
\v 26 “ ‘Nʼụbọchị nke ise nke mmemme a, ị ga-ewere ụmụ oke ehi itoolu, ebule abụọ na ụmụ ebule iri na anọ ndị gbara otu afọ, otu afọ, ndị na-enweghị ntụpọ chụọ aja.  
\v 27 Ihe ga-eso aja oke ehi, ebule na ụmụ atụrụ ndị ahụ nʼọnụọgụgụ ha bụ aja mkpụrụ ọka na aja ihe ọṅụṅụ dịka e si nye ya nʼiwu.  
\v 28 Tinyekwa otu mkpi maka aja mmehie, ya na aja nsure ọkụ a na-achụ nʼoge ha, na aja mkpụrụ ọka, na aja ihe ọṅụṅụ so ha. 
\p  
\v 29 “ ‘Nʼụbọchị nke isii nke mmemme ahụ, ị ga-ewere ụmụ oke ehi asatọ, na ebule abụọ, na ụmụ ebule iri na anọ ndị gbara otu afọ, otu afọ, ndị na-enweghị ntụpọ, chụọ aja.  
\v 30 Ihe ga-eso aja oke ehi, na ebule, na ụmụ atụrụ ndị ahụ nʼọnụọgụgụ ha bụ aja mkpụrụ ọka, na aja ihe ọṅụṅụ dịka e si nye ya nʼiwu.  
\v 31 Tinyekwa otu mkpi maka aja mmehie, ya na aja nsure ọkụ a na-achụ nʼoge ha, na aja mkpụrụ ọka, na aja ihe ọṅụṅụ so ha. 
\p  
\v 32 “ ‘Nʼụbọchị nke asaa nke mmemme ahụ, were ụmụ oke ehi asaa, ebule abụọ na ụmụ ebule iri na anọ, ndị gbara otu afọ, otu afọ, ndị na-enweghị ntụpọ, chụọ aja.  
\v 33 Ihe ga-eso aja oke ehi, ebule na ụmụ atụrụ ndị ahụ nʼọnụọgụgụ ha bụ aja mkpụrụ ọka na aja ihe ọṅụṅụ dịka e si nye ya nʼiwu.  
\v 34 Tinyekwa otu mkpi maka aja mmehie, ya na aja nsure ọkụ a na-achụ nʼoge ha, na aja mkpụrụ ọka, na aja ihe ọṅụṅụ so ha. 
\p  
\v 35 “ ‘Nʼụbọchị nke asatọ ndị Izrel niile ga-enwe oke nzukọ. Ị gaghị arụ ọrụ ọbụla nʼụbọchị ahụ.  
\v 36 Chụọ aja nsure ọkụ, nke isisi ya dị \nd Onyenwe anyị\nd* ezi ụtọ. Ị ga-eji otu nwa oke ehi, otu ebule na ụmụ ebule asaa ndị gbara otu afọ, otu afọ, ndị na-enweghị ntụpọ ọbụla, chụọ ya.  
\v 37 Ihe ga-eso aja oke ehi, ebule na ụmụ atụrụ ndị ahụ bụ aja mkpụrụ ọka na aja ihe ọṅụṅụ dịka e si nye ya nʼiwu.  
\v 38 Tinyekwa otu mkpi maka aja mmehie ya na aja nsure ọkụ a na-achụ nʼoge ha, na aja mkpụrụ ọka, na aja ihe ọṅụṅụ so ha. 
\p  
\v 39 “ ‘Tinyere onyinye a na-enye dịka nkwa e kwere si dị, na onyinye afọ ofufu unu, unu ga-akwadoro \nd Onyenwe anyị\nd* onyinye ndị a nʼoge mmemme a kara aka unu: aja nsure ọkụ unu, onyinye mkpụrụ ọka na onyinye ihe ọṅụṅụ na aja udo.’ ” 
\p  
\v 40 Ya mere Mosis gwara ụmụ Izrel ihe niile \nd Onyenwe anyị\nd* nyere ya nʼiwu ịgwa ha. 
\c 30  
\s1 Ikwe nkwa 
\p  
\v 1 Mosis kpọkọtara ndị ndu ebo Izrel niile gwa ha sị: “Ihe ndị a ka \nd Onyenwe anyị\nd* nyere nʼiwu:  
\v 2 Mgbe nwoke ọbụla kwere \nd Onyenwe anyị\nd* nkwa, maọbụ ṅụọ iyi ime ihe ọbụla, ọ gaghị emebi nkwa dị otu a. Kama ọ ga-emezu ihe niile dịka o kwuru ya. 
\p  
\v 3 “Ọ bụrụ na nwaagbọghọ nọ nʼụlọ nna ya ekwe \nd Onyenwe anyị\nd* nkwa maọbụ ṅụọ iyi ime ihe ọbụla,  
\v 4 ọ bụrụ na nna ya anụ mgbe ọ na-ekwe nkwa maọbụ ṅụọ iyi ime ihe ahụ, ma gba ya nkịtị,\f + \fr 30:4 \ft Ma o kwughị ihe ọbụla\f* onye dị otu a aghaghị imezu nkwa niile ndị ahụ o kwere.  
\v 5 Ma ọ bụrụ na nna ya ajụ mgbe ọ nụrụ banyere ya na ọ gaghị emezu nkwa dị otu ahụ, mgbe ahụ, nkwa ahụ maọbụ iyi ọ ṅụrụ ga-abụ ihe efu. \nd Onyenwe anyị\nd* ga-agbaghakwara ya, nʼihi na nna ya jụrụ na ọ ga-emezu nkwa ya. 
\p  
\v 6 “Ọ bụrụ na o mesịa lụọ dị, mgbe ọ ṅụsịrị iyi, maọbụ kwee nkwa nzuzu o kwesiri imezu,  
\v 7 di ya nụ banyere ya ma gba ya nkịtị nʼụbọchị ahụ ọ nụrụ ya, nkwa ahụ ga-eguzogide, ọ ga-emezu ya.  
\v 8 Ma ọ bụrụ na di ya ajụ ịnabata nkwa ahụ, maọbụ ọṅụṅụ iyi nzuzu ahụ, ọjụjụ di ya jụrụ nkwa ahụ ga-eme ka iyi ahụ maọbụ nkwa ahụ ghara ịdị ire. \nd Onyenwe anyị\nd* ga-agbaghakwara ya. 
\p  
\v 9 “Ma nkwa ọbụla nke nwanyị di ya nwụrụ maọbụ nwanyị ya na di ya kewara, ihe ọbụla nke o ji ọnụ ya kwuo ka ọ ghaghị imezu. 
\p  
\v 10 “Ma ọ bụrụ na nwanyị ya na di ya bi e kwee nkwa maọbụ site na kwagide ṅụọ iyi,  
\v 11 di ya nụ ihe banyere ya, ma gba nkịtị maọbụ ogbochighị ya, mgbe ahụ, ịṅụ iyi na nkwa ndị ahụ niile nke o kwere ga-eguzo.  
\v 12 Ma ọ bụrụ na di ya jụrụ ikwenye ka nkwa ahụ dịgide nʼụbọchị mbụ ọ nụrụ ya, nkwa ahụ maọbụ ọṅụṅụ iyi ahụ aghọọla ihe efu. \nd Onyenwe anyị\nd* ga-agbaghakwara ya.  
\v 13 Ya mere, di ya nwere ike ịjụ, maọbụ mesie nkwa ahụ, maọbụ iyi ahụ ọ ṅụrụ ike.  
\v 14 Ọ bụrụ na di ya ekwughị ihe ọbụla site nʼotu ụbọchị ruo nʼụbọchị ọzọ, mgbe ahụ, o gosiri na o kwenyere ka nwunye ya mezuo nkwa maọbụ iyi ndị ahụ niile.  
\v 15 Ọ bụrụ na o mesịa jụ na nwunye ya agaghị emezu nkwa ahụ ọ kwere, ikpe ọmụma niile dị nʼihi emezughị nkwa ahụ dị ya nʼisi.” 
\p  
\v 16 Ndị a bụ usoro iwu \nd Onyenwe anyị\nd* nyere Mosis banyere mmekọrịta nke nwoke na nwunye ya. Ọ metụtakwara nna na nwa ya nwanyị onye bi nʼụlọ ya. 
\c 31  
\s1 Ịbọ ọbọ megide ndị Midia 
\p  
\v 1 Mgbe ahụ, \nd Onyenwe anyị\nd* gwara Mosis okwu sị ya,  
\v 2 “Taa ndị Midia ahụhụ, ka i si otu a bọọrọ ndị Izrel ọbọ ihe ọjọọ ndị Midia mere ha. Mgbe i mesịrị nke a, ị ga-anwụ.” 
\p  
\v 3 Ya mere, Mosis gwara ndị Izrel okwu sị, “Kwadoonụ ndị ikom unu ibuso ndị Midia agha, maka ịbọtara \nd Onyenwe anyị\nd* ọbọ.  
\v 4 Sinụ nʼebo ọbụla dị nʼIzrel gụpụta puku ndị ikom puku ndị ikom.”  
\v 5 Ya mere, e sitere nʼigwe ndị ikom niile nọ nʼIzrel zipụ puku ndị ikom iri na abụọ, ka ha gaa buo agha. Ebo ọbụla zipụrụ otu puku ndị ikom.  
\v 6 Mosis zipụrụ ha ibu agha, otu puku, otu puku site nʼebo ọbụla. Finehaz nwa Elieza, onye nchụaja, du ha gaa agha ahụ. O bu ngwongwo si nʼebe nsọ, tinyere opi ike nke a ga-afụ. 
\p  
\v 7 Ha busoro ndị Midia agha dịka \nd Onyenwe anyị\nd* nyere Mosis nʼiwu. Ha gburu onye ọbụla bụ nwoke.  
\v 8 Nʼime ndị ha gburu nʼagha ahụ bụ ndị eze Midia ise a na-akpọ Evi, Rekem, Zua, Hua na Reba. Ha jikwa mma agha gbuo Belam nwa Beoa.  
\v 9 Ndị agha Izrel chịkọtara ndị inyom niile, na ụmụntakịrị niile nọ nʼala Midia dịka ndị ha dọtara nʼagha. Ha chịkọtara ngwongwo niile ndị Midia ji biri, tinyere igwe ehi, na igwe ewu na atụrụ ha niile, dịka ihe ha dọtara nʼagha.  
\v 10 Emesịa, ha mụnyere ọkụ nʼobodo ndị Midia niile na ebe ha mara ụlọ ikwu, rechapụ ha nʼọkụ.  
\v 11 Ha chịkọtara ihe niile ha dọtara nʼagha, ma mmadụ ma anụ ụlọ.  
\v 12 Ndị a niile ha dọtara nʼagha na ngwongwo niile ha lụtara nʼagha ka ha buteere Mosis, na Elieza onye nchụaja na ọgbakọ Izrel niile na mbara ala Moab, nʼakụkụ osimiri Jọdan na ncherita ihu Jeriko. 
\p  
\v 13 Mosis na Elieza onye nchụaja na ndị ndu ọgbakọ Izrel niile pụrụ gaa zute ha nʼazụ ebe ha mara ụlọ ikwu ha.  
\v 14 Ma Mosis were iwe megide ndịisi agha, ya bụ ndị ahụ na-achị imerime puku ndị agha, na ndị ọchịagha na-achị narị ndị agha, ndị si ibu agha lọta. 
\p  
\v 15 Mosis jụrụ ha sị, “Gịnị mere unu ji debe ndị inyom niile ndị a ndụ?  
\v 16 Ọ bụ ndị a bụ ndị gbasoro ndụmọdụ Belam, rafuo ndị Izrel mee ka ha ghọọ ndị na-ekwesighị ntụkwasị obi nye \nd Onyenwe anyị\nd* nʼihe gbasara okwu Peoa. Ọ bụ nke a mere ka nrịa nrịa ọjọọ ahụ na-efe efe dakwasị ndị nke \nd Onyenwe anyị\nd*.  
\v 17 Ugbu a, gbuonụ ụmụnta ndị nwoke niile, na ndị inyom niile matarala nwoke.  
\v 18 Naanị ụmụntakịrị ndị nwanyị ha nke nwoke na-edinabeghị ka unu ga-ahapụ ka ha dịrị ndụ. Unu nwere ike debere onwe unu ndị dị otu a. 
\p  
\v 19 “Ma ugbu a, unu niile bụ ndị soro gbuo mmadụ, maọbụ bitụ ozu ha aka, unu abatala nʼime ogige Izrel tutu ụbọchị asaa agafee. Nʼoge a, doonụ onwe unu ọcha, dokwaanụ ndị niile unu dọtara nʼagha ọcha, nʼụbọchị nke atọ na nʼụbọchị nke asaa.  
\v 20 Debekwanụ uwe niile ọcha, ya na ihe niile e ji akpụkpọ anụ na ajị ewu, maọbụ osisi, mee.” 
\p  
\v 21 Mgbe ahụ, Elieza onye nchụaja gwara ndị ikom niile ahụ jere agha okwu sị ha, “Nke a bụ iwu \nd Onyenwe anyị\nd* nyere Mosis.  
\v 22 Otu ọ dị ọlaedo, ọlaọcha, bronz, igwe, gbamgbam na opu,  
\v 23 na ihe ọ bụla ọzọ bụ nke ga-anagide ọkụ, ka a ga-eme ka ọ gabiga site nʼọkụ, mgbe ahụ ọ ga-adịkwa ọcha. Ma aghaghị ịga nʼihu ime ka ha dị ọcha site nʼịsacha ha nʼime mmiri nke nsacha. Ma ihe ọbụla nke na-agaghị anagide ọkụ ka a ga-eji mmiri sachaa, maka ido ya ọcha.  
\v 24 Nʼụbọchị nke asaa, unu aghaghị ịsacha uwe unu niile, bụrụ ndị dị ọcha. Mgbe ahụ, unu pụrụ ịlọghachi nʼọmụma ụlọ ikwu ndị Izrel.” 
\s1 Ike ihe nkwata nʼagha 
\p  
\v 25 Ma \nd Onyenwe anyị\nd* sịrị Mosis,  
\v 26 “Gị na Elieza onye nchụaja, na ndịisi ezinaụlọ nke ọgbakọ Izrel niile, ga-agụkọ ihe niile unu dọtara nʼagha chọpụta ọnụọgụgụ mmadụ na anụmanụ.  
\v 27 Mgbe ahụ, kee ihe ndị a niile ụzọ abụọ. Ọkara ya ga-abụ nke ndị ikom ahụ niile gara agha, ma ọkara nke ọzọ ka a ga-enye ọgbakọ Izrel niile.  
\v 28 Ma \nd Onyenwe anyị\nd* nwere oke site nʼoke ndị ahụ jere agha: mmadụ, na ehi niile, na ịnyịnya ibu niile, na atụrụ na ewu niile. Oke \nd Onyenwe anyị\nd* bụ otu ụzọ nʼime narị ise ọbụla.  
\v 29 Nye Elieza onye nchụaja oke sitere nʼaja a dịka ihe \nd Onyenwe anyị\nd* ketara.  
\v 30 Otu aka ahụ kwa, site nʼoke ndị Izrel ga-eketa, kee ụtụ. Otu ụzọ nʼime iri ise, maọbụ mmadụ, maọbụ ehi, maọbụ ịnyịnya ibu, maọbụ atụrụ, maọbụ ewu, maọbụ igwe anụ ụlọ ụzọ. Were ha nye ndị Livayị, ndị ọ dị nʼaka ilekọta ụlọ nzute \nd Onyenwe anyị\nd*, ka ọ bụrụ oke nke ha.”  
\v 31 Ya mere, Mosis na Elieza onye nchụaja mere dịka \nd Onyenwe anyị\nd* nyere ha nʼiwu. 
\p  
\v 32 Ihe nweta bụ nke fọdụrụ nʼihe ndị agha lụtara nʼagha bụ ndị a, bụ atụrụ dị narị puku isii, iri puku asaa na puku ise (675,000),  
\v 33 Ehi dị iri puku asaa na puku abụọ (72,000),  
\v 34 ịnyịnya ibu dị iri puku isii na otu puku (61,000),  
\v 35 Ụmụ agbọghọ na-amatabeghị nwoke dị iri puku atọ na puku abụọ (32,000). 
\b  
\li4  
\v 36 Ya mere, ọkara e nyere ndị gara lụọ agha dị: 
\b  
\li1 Igwe ewu na atụrụ dị narị puku atọ na iri puku atọ na puku asaa na narị ise (337,500).  
\v 37 Nʼime ya, ụtụ e nyere \nd Onyenwe anyị\nd* site nʼigwe atụrụ ahụ dị narị isii na iri asaa na ise (675). 
\li1  
\v 38 Igwe ehi dị iri puku atọ na puku isii (36,000). Nʼime ya, ihe e nyere \nd Onyenwe anyị\nd* bụ iri asaa na abụọ (72). 
\li1  
\v 39 Ịnyịnya ibu dị iri puku atọ na narị ise (30,500). Nke e nyere \nd Onyenwe anyị\nd* bụ iri isii na otu (61). 
\li1  
\v 40 Ọnụọgụgụ ụmụ agbọghọ dị puku iri na isii (16,000). Ndị e nyere \nd Onyenwe anyị\nd* dị iri atọ na abụọ (32). 
\b  
\p  
\v 41 Mosis nyere Elieza bụ onye nchụaja \nd Onyenwe anyị\nd* oke nʼihe ndị ahụ niile a tụrụ nʼụtụ, dịka \nd Onyenwe anyị\nd* nyere Mosis nʼiwu. 
\p  
\v 42 Ma ọkara nke ahụ dịrị ndị Izrel, nke Mosis kewapụtara site na nke ndị ikom lụrụ agha.  
\v 43 Ọkara nke nzukọ dị, igwe ewu na atụrụ, narị puku atọ, iri puku atọ, puku asaa na narị ise (337,500),  
\v 44 igwe ehi, iri puku atọ na isii (36,000),  
\v 45 ịnyịnya ibu, iri puku atọ na narị ise (30,500),  
\v 46 ụmụ agbọghọ, puku iri na isii (16,000).  
\v 47 Site nʼoke ndị Izrel Mosis họpụtara otu ụzọ nʼime iri ise, ma mmadụ ma anụ ụlọ dịka \nd Onyenwe anyị\nd* nyere nʼiwu. O nyere ha ndị Livayị na-elekọta ụlọ nzute \nd Onyenwe anyị\nd* mmadụ na anụ ụlọ ndị a. 
\p  
\v 48 Mgbe ahụ, ndịisi agha niile na ndị ọchịagha na-achị imerime puku ndị agha, na ndị na-achị narị ndị agha bịakwutere Mosis,  
\v 49 sị ya, “Ndị ohu gị agụọla ndị niile gara agha nọ nʼokpuru anyị, chọpụta na o nweghị onye ọbụla a na-achọ achọ.  
\v 50 Ya mere, anyị wetaara \nd Onyenwe anyị\nd* onyinye site nʼihe anyị kwatara nʼagha. Onyinye anyị bụ ihe onye ọbụla nwetara, ihe ọlaedo a na-agba nʼụkwụ na mgbaaka, na ọlaaka ikike, na ọlantị na ihe iyi nʼolu niile, i ji ha chụọ aja mkpuchi mmehie nʼihi onwe anyị nʼihu \nd Onyenwe anyị\nd*.” 
\p  
\v 51 Mosis na Elieza onye nchụaja natara onyinye ọlaedo ndị ahụ bụ ihe a kpụrụ akpụ site nʼaka ha.  
\v 52 Ịdị arọ nke ihe ọlaedo niile nke ndị ọchịagha na-achị imerime puku ndị agha, na ndị na-achị narị ndị agha, nke Mosis na Elieza chere nʼihu \nd Onyenwe anyị\nd* dịka onyinye, dị narị kilogram na iri itoolu.\f + \fr 31:52 \ft Ya bụ puku shekel iri na isii na narị asaa na iri ise\f* 
\v 53 Ndị ahụ lụrụ agha ahụ nwekwara ọtụtụ ihe ndị ọzọ ha debeere onwe ha.  
\v 54 Mosis na Elieza onye nchụaja natara onyinye ọlaedo ndị a dị iche site nʼaka ndị ọchịagha na-achị ọtụtụ puku ndị agha na narị ndị agha. E webatara onyinye ndị a nʼụlọ nzute, debe ha nʼihu \nd Onyenwe anyị\nd* ka ọ bụrụ ihe ncheta nye \nd Onyenwe anyị\nd* nʼihi ndị Izrel niile. 
\c 32  
\s1 Ndị ketara ala nʼọwụwa anyanwụ 
\p  
\v 1 Mgbe ndị Izrel rutere ala Jeza na Gilead, ndị ebo Ruben na Gad ndị nwere ọtụtụ igwe ehi, na igwe ewu na atụrụ chọpụtara na ala ahụ dị mma nke ukwuu maka ịzụ anụ ụlọ.  
\v 2 Ya mere, ha bịakwutere Mosis na Elieza onye nchụaja, na ndị ndu nzukọ Izrel, sị ha,  
\v 3 “Ala ndị a: Atarọt, Dibọn, Jeza, Nimra, Heshbọn, Eleale, Sebam, Nebo, na Beon,  
\v 4 bụ ala nke \nd Onyenwe anyị\nd* meriri nʼagha nʼihu nzukọ Izrel, dị mma maka ịzụ anụ ụlọ. Anyị onwe anyị kwa nwere igwe ewu na atụrụ.  
\v 5 Ọ bụrụ na anyị achọtala amara nʼihu unu, biko, kwerenụ ka akụkụ ala a bụrụ ihe nketa nke anyị bụ ohu unu. Unu emekwala ka anyị soro ndị Izrel gafee nʼakụkụ nke ọzọ nke osimiri Jọdan.” 
\p  
\v 6 Mosis jụrụ ndị Gad na Ruben ajụjụ sị, “Unu na-ekwu na unu chọrọ ịnọ nʼebe a mgbe ụmụnna unu ndị ikom niile ga-agafe osimiri Jọdan ịlụ agha niile ahụ dị na-eche ha?  
\v 7 Ọ bụ nʼihi gịnị ka unu ji eme ka ndị Izrel daa mba ghara ịgafe banye nʼala ahụ \nd Onyenwe anyị\nd* nyerela ha?  
\v 8 Otu a ka nna unu ha mere mgbe m si Kadesh Banea zipụ ha inyocha ala ahụ.  
\v 9 Mgbe ha letasịrị ala ahụ si na Ndagwurugwu Eshkọl lọghachi, ha mere ka obi ndị Izrel niile daa mba ịbanye nʼala ahụ \nd Onyenwe anyị\nd* nyere ha.  
\v 10 Nʼihi nke a \nd Onyenwe anyị\nd* were iwe dị ọkụ megide ha nʼụbọchị ahụ. Ọ ṅụrụ iyi kwuo sị,  
\v 11 ‘Nʼihi na unu jụrụ iji obi unu niile gbasoo m, o nweghị onye ọbụla nʼime ndị ahụ o si nʼala Ijipt kpọpụta, ndị gbara iri afọ abụọ rigoo, ga-ahụ ala ahụ m kwere Ebraham na Aịzik na Jekọb nkwa inye ha.’  
\v 12 Naanị ndị ọṅụṅụ iyi a na-emegideghị bụ Kaleb, nwa Jefune onye Keniz,\f + \fr 32:12 \ft Nkọwa e nyere banyere akwụkwọ Jenesis isi nke \xt 15:19\ft , nakwa nʼisi nke \xt 36:11\ft , mere ka anyị mata na ndị Keniz bụ ndị Kenan. Ha bụ ndị si nʼagbụrụ Ịsọ.\f* na Joshua nwa Nun, nʼihi na ha jiri obi ha niile sogide \nd Onyenwe anyị\nd*.  
\v 13 Iwe \nd Onyenwe anyị\nd* dịịrị ọkụ megide Izrel, o mere ka ha wagharịa nʼọzara iri afọ anọ, tutu ruo mgbe ọgbọ ahụ niile nke mere ihe ọjọọ nʼanya ya nwụchara. 
\p  
\v 14 “Ma lee unu ugbu a, agbụrụ ndị mmehie, ọ bụkwa otu ihe ahụ ka unu na-eme! Unu na-achọ ime ka iwe dị ukwuu wee \nd Onyenwe anyị\nd* megide ndị Izrel.  
\v 15 Ọ bụrụ na unu ajụ iso \nd Onyenwe anyị\nd* ugbu a, \nd Onyenwe anyị\nd* ga-emekwa ka ndị Izrel nọgide nʼọzara. Mbibi na ịla nʼiyi nke ga-abịakwasị ha ga-abụkwa nke unu ji aka unu kpatara ha.” 
\p  
\v 16 Ma ha zara sị ya, “Ọ gaghị adị otu a! Anyị ga-ewuru anụ ụlọ anyị ụlọ, tinye igwe ewu na atụrụ anyị nʼime ha. Anyị ga-ewukwara ndị nwunye anyị na ụmụntakịrị anyị obodo ebe ha ga-anọ.  
\v 17 Ma anyị onwe anyị ga-eburu ngwa agha anyị, buru ndị Izrel niile ọzọ ụzọ gaa nʼihu ịlụ ọgụ, tutu anyị edubata ha nʼala nke ha ga-eketa. Ma ndị nwunye anyị na ụmụntakịrị anyị ga-anọ nʼobodo e wusiri ike, ikpuchite ezinaụlọ anyị niile site nʼaka ndị iro bi anyị gburugburu.  
\v 18 Anyị agaghị alọta nʼụlọ anyị tutu onye Izrel ọbụla enweta ihe nketa nke ya.  
\v 19 Anyị achọghị ihe nketa, nʼofe Jọdan nke ọzọ, nʼihi na anyị ewerela oke nke anyị nʼebe a, nʼakụkụ ọwụwa anyanwụ Jọdan.” 
\p  
\v 20 Mgbe ahụ, Mosis zara sị ha, “Ọ dị mma, ọ bụrụ na unu ga-eme dịka unu kwuru, jikere onwe unu, nʼihu \nd Onyenwe anyị\nd*, ibu agha.  
\v 21 Ọ bụrụ na ndị agha unu ga-eso gafee nʼofe ọzọ nke osimiri Jọdan, soro ndị ọzọ buo agha tutu ruo mgbe \nd Onyenwe anyị\nd* chụpụchara ndị iro ya niile,  
\v 22 mgbe ahụ, e merichaa mba ndị ahụ niile nʼihu Onyenwe anyị, unu nwere ike ịlọghachi nʼebe a, bụrụ ndị ikpe na-amaghị nʼebe \nd Onyenwe anyị\nd* na ndị Izrel nọ. Ala a dị nʼọwụwa anyanwụ, ga-abụ ihe nketa unu nwere site nʼaka \nd Onyenwe anyị\nd*. 
\p  
\v 23 “Ọ bụrụkwanụ na unu ajụ ime dịka unu kwuru, mgbe ahụ, ọ bụ \nd Onyenwe anyị\nd* ka unu na-emehie megide. Matakwanụ na unu ga-emesịa nata ụgwọ ọrụ mmehie unu.  
\v 24 Wuonụ obodo ebe ndị inyom na ụmụ unu ga-ebi, wuokwanụ ụlọ anụ maka igwe ewu na atụrụ unu, ma mezuokwanụ ihe niile unu kweere na nkwa.” 
\p  
\v 25 Ndị ebo Gad na Ruben sịrị Mosis, “Anyị bụ ndị ohu gị ga-eme dịka onyenwe anyị nyere nʼiwu.  
\v 26 Ụmụ anyị niile, na ndị inyom anyị niile, na igwe ewu na atụrụ anyị, na ehi anyị niile, ga-anọ nʼebe a, nʼobodo ndị a anyị wuru nʼala Gilead.  
\v 27 Ma anyị, ndị ohu gị, ndị niile tozuru ije agha, ga-agafe osimiri Jọdan ibu agha nʼihu \nd Onyenwe anyị\nd*, dịka onyenwe anyị si kwuo.” 
\p  
\v 28 Mgbe ahụ, Mosis nyere Elieza, bụ onye nchụaja, na Joshua nwa Nun, na ndịisi ezinaụlọ nke ebo Izrel niile iwu banyere ha,  
\v 29 Ọ sịrị ha, “Ọ bụrụ na ndị ebo Gad na Ruben, onye ọbụla nke jikere ịga agha, ga-eso unu gafee Jọdan nʼihu \nd Onyenwe anyị\nd*, mgbe ahụ, oge unu lụgburu ndị ala ahụ niile, unu aghaghị inye ha ala Gilead dịka ihe nketa ha.  
\v 30 Ma ọ bụrụ na ha ajụ iso unu, ha ga-eso ndị ọzọ keta oke nʼala Kenan.” 
\p  
\v 31 Ndị ebo Gad na Ruben zara sị, “Ihe ọbụla \nd Onyenwe anyị\nd* nyere nʼiwu ka anyị ga-eme.  
\v 32 Anyị ga-ejikere soro \nd Onyenwe anyị\nd* jee agha nʼala Kenan. Ma ihe nketa anyị ga-adị nʼebe a, nʼakụkụ Jọdan.” 
\p  
\v 33 Mosis nyere ndị ebo Gad, na Ruben, na ọkara Manase nwa Josef, alaeze niile Saịhọn eze Amọrị nakwa alaeze niile nke Ọg, eze ndị Bashan na-achị. O nyere ha ala ahụ niile, na obodo niile dị nʼala ahụ gburugburu. 
\p  
\v 34 Ndị ebo Gad wugharịrị ma wusiekwa obodo ndị a, Dibọn, Atarọt, Aroea  
\v 35 Atrọt-Shofan, Jeza, Jogbeha,  
\v 36 Bet-Nimra na Bet-Haran bụ obodo e wusiri ike, wukwaara igwe ewu na atụrụ ha ụlọ anụ nʼime ya.  
\v 37 Ma ndị ebo Ruben wugharịrị obodo ndị a: obodo Heshbọn, Eleale, Kiriatem,  
\v 38 Nebo na Baal-Meon (ma a gbanwere aha ha) na Sibma. Ha gbanwere aha obodo niile ndị ahụ ha wugharịrị, gụọ ha aha ọhụrụ. 
\p  
\v 39 Ndị agbụrụ Makia, nwa Manase gara nʼobodo Gilead lụgbuo ya, chụpụ ndị Amọrait bi nʼebe ahụ.  
\v 40 Ya mere, Mosis were obodo Gilead nye Makia, ụmụ Manase ka ha biri nʼebe ahụ.  
\v 41 Jia, onye sikwa nʼebo Manase gara buso ọtụtụ obodo nta ndị ọzọ agha, lụgbuo ha. Ọ gbanwere aha obodo nta ndị a, gụọ ha Havọt Jaịa.  
\v 42 Nʼoge a kwa, otu nwoke a na-akpọ Nọba duuru ndị agha gaa nʼobodo Kenat, na nʼobodo nta ndị ọzọ gbara ya gburugburu, lụgbuo ha, bichie nʼime ha. Ọ gbanwere aha obodo ndị ahụ niile bido ịkpọ ha Nọba, nke bụ aha ya onwe ya. 
\c 33  
\s1 Njegharị ụmụ Izrel 
\p  
\v 1 Ndị a bụ usoro mbili ije ụmụ Izrel, site nʼoge ha hapụrụ Ijipt dịka ha si nọọ nʼigwe nʼigwe. Ọ bụ Mosis na Erọn duuru ha nʼije ndị a.  
\v 2 Mosis, nʼonwe ya, dere usoro ije ha ndị a nʼakwụkwọ dịka \nd Onyenwe anyị\nd* nyere ya nʼiwu. 
\b  
\pi1  
\v 3 Ha biliri njem site na Ramesis, nʼụbọchị nke iri na ise nʼọnwa nke mbụ, ụbọchị na-esota nke e mere Mmemme Ngabiga. Ha niile zọpụrụ ije nʼatụghị egwu nʼihu ndị Ijipt,  
\v 4 mgbe ndị ha nọ na-eli ụmụ ha niile ndị e buru ụzọ mụọ, bụ ndị \nd Onyenwe anyị\nd* tigburu nʼetiti ha nʼihi na \nd Onyenwe anyị\nd* kpere chi ha niile ikpe. 
\pi1  
\v 5 Ndị Izrel hapụrụ Ramesis, bịa maa ụlọ ikwu ha na Sukọt. 
\pi1  
\v 6 Ha hapụrụ Sukọt bịaruo Etam, nke dị nʼọnụ ọnụ ọzara ahụ. 
\pi1  
\v 7 Ha hapụrụ Etam laghachi azụ gaa Pi Hahirot, nke dị nso nʼakụkụ ọwụwa anyanwụ Baal-Zefọn, ebe ha manyere ụlọ ikwu ha na ndịda ugwu Migdol. 
\pi1  
\v 8 Mgbe ha hapụrụ Pi Hahirot, ha sitere nʼetiti Osimiri Uhie gafee gaa ije ụbọchị atọ bata nʼọzara Etam. Ha manyere ụlọ ikwu ha na Mara. 
\pi1  
\v 9 Mgbe ha hapụrụ Mara, ha batara Elim, ebe e nwere mmiri iri na abụọ si nʼala na-asọpụta, na iri osisi nkwụ asaa. Ha nọrọ ọdụ dị ukwuu nʼebe a. 
\pi1  
\v 10 Mgbe ha hapụrụ Elim, ha wuru ụlọ ikwu ha nʼakụkụ Osimiri Uhie. 
\pi1  
\v 11 Emesịa, ha hapụrụ Osimiri Uhie gaa maa ụlọ ikwu ha nʼọzara a na-akpọ Sin. 
\pi1  
\v 12 Ha hapụrụ ọzara Sin gaa maa ụlọ ikwu ha na Dofka. 
\pi1  
\v 13 Emesịa, ha hapụrụ Dofka bịaruo Alush maa ụlọ ikwu ha. 
\pi1  
\v 14 Mgbe ha hapụrụ Alush, ha rutere Refidim, ebe ndị Izrel na-ahụghị mmiri ọṅụṅụ. 
\pi1  
\v 15 Ha hapụrụ Refidim bịaruo nʼọzara Saịnaị ebe ha mara ụlọ ikwu ha. 
\pi1  
\v 16 Ha hapụrụ ọzara Saịnaị bịaruo Kibrọt Hataava ebe ha mara ụlọ ikwu ha. 
\pi1  
\v 17 Ha hapụrụ Kibrọt Hataava bịaruo Hazerọt ebe ha mara ụlọ ikwu ha. 
\pi1  
\v 18 Ha hapụrụ Hazerọt bịaruo Ritma ebe ha mara ụlọ ikwu ha. 
\pi1  
\v 19 Ha hapụrụ Ritma bịaruo Rimon-Perez ebe ha mara ụlọ ikwu ha. 
\pi1  
\v 20 Ha hapụrụ Rimon-Perez bịaruo Libna ebe ha mara ụlọ ikwu ha. 
\pi1  
\v 21 Ha hapụrụ Libna bịaruo Rissa ebe ha mara ụlọ ikwu ha. 
\pi1  
\v 22 Ha hapụrụ Rissa bịaruo Kehelata ebe ha mara ụlọ ikwu ha. 
\pi1  
\v 23 Ha hapụrụ Kehelata bịaruo nʼugwu Shefa ebe ha mara ụlọ ikwu ha. 
\pi1  
\v 24 Ha hapụrụ ugwu Shefa bịaruo Harada ebe ha mara ụlọ ikwu ha. 
\pi1  
\v 25 Ha hapụrụ Harada bịaruo Makhelot ebe ha mara ụlọ ikwu ha. 
\pi1  
\v 26 Ha hapụrụ Makhelot bịaruo Tahat ebe ha mara ụlọ ikwu ha. 
\pi1  
\v 27 Ha hapụrụ Tahat bịaruo Tera ebe ha mara ụlọ ikwu ha. 
\pi1  
\v 28 Ha hapụrụ Tera bịaruo Mitka ebe ha mara ụlọ ikwu ha. 
\pi1  
\v 29 Ha hapụrụ Mitka bịaruo Hashmona ebe ha mara ụlọ ikwu ha. 
\pi1  
\v 30 Ha hapụrụ Hashmona bịaruo Moserot ebe ha mara ụlọ ikwu ha. 
\pi1  
\v 31 Ha hapụrụ Moserot bịaruo Bene Jaakan ebe ha mara ụlọ ikwu ha. 
\pi1  
\v 32 Ha hapụrụ Bene Jaakan bịaruo Họ Hagịdgad ebe ha mara ụlọ ikwu ha. 
\pi1  
\v 33 Ha hapụrụ Họ Hagịdgad bịaruo Jotbata ebe ha mara ụlọ ikwu ha. 
\pi1  
\v 34 Ha hapụrụ Jotbata bịaruo Abrona ebe ha mara ụlọ ikwu ha. 
\pi1  
\v 35 Ha hapụrụ Abrona bịaruo Eziọn Geba ebe ha mara ụlọ ikwu ha. 
\pi1  
\v 36 Ha hapụrụ Eziọn Geba bịa maa ụlọ ikwu ha na Kadesh, nke dị nʼọzara Zin. 
\pi1  
\v 37 Ha hapụrụ Kadesh bịa maa ụlọ ikwu ha nʼugwu Hor nʼoke ala ndị Edọm.  
\v 38 Erọn, bụ onye nchụaja gbagoro nʼugwu Hor site nʼiwu \nd Onyenwe anyị\nd*. Nʼebe ọ nọ nwụọ, nʼụbọchị mbụ nke ọnwa nke ise, nʼafọ nke iri anọ site na mgbe ụmụ Izrel si Ijipt pụta.  
\v 39 Erọn gbara narị afọ na iri afọ abụọ na atọ mgbe ọ nwụrụ nʼugwu Hor. 
\pi1  
\v 40 Onye Kenan bụ eze Arad, onye bi na Negev nʼime ala Kenan, nụrụ na ndị Izrel na-abịa. 
\pi1  
\v 41 Ha hapụrụ ugwu Hor bịaruo Zalmona ebe ha mara ụlọ ikwu ha. 
\pi1  
\v 42 Ha hapụrụ Zalmona bịaruo Punon ebe ha mara ụlọ ikwu ha. 
\pi1  
\v 43 Ha hapụrụ Punon bịaruo Obot ebe ha mara ụlọ ikwu ha. 
\pi1  
\v 44 Ha hapụrụ Obot bịaruo Iye Abarim, nʼoke ala ndị Moab. 
\pi1  
\v 45 Ha hapụrụ Iye Abarim bịaruo Dibọn Gad ebe ha mara ụlọ ikwu ha. 
\pi1  
\v 46 Ha hapụrụ Dibọn Gad bịaruo Almon Diblataim ebe ha mara ụlọ ikwu ha. 
\pi1  
\v 47 Ha hapụrụ Almon Diblataim bịaruo nʼugwu Abarim nke dị nso na Nebo ebe ha mara ụlọ ikwu ha. 
\pi1  
\v 48 Ha hapụrụ ugwu Abarim bata nʼobosara ala Moab nʼakụkụ osimiri Jọdan, na ncherita ihu Jeriko, ebe ha mara ụlọ ikwu ha.  
\v 49 Mgbe ha nọ nʼebe a, ha manyere ụlọ ikwu ha nʼebe dị iche iche nʼakụkụ osimiri Jọdan, site na Bet-Jeshimọt rute rịị ebe a na-akpọ Ebel-Shitim, nʼobosara ala Moab. 
\b  
\p  
\v 50 Nʼobosara ala Moab, nʼakụkụ Jọdan, na ncherita ihu Jeriko ka \nd Onyenwe anyị\nd* nọ gwa Mosis okwu sị ya,  
\v 51 “Gwa ụmụ Izrel okwu sị ha, ‘Mgbe unu gafere osimiri Jọdan banye nʼala Kenan,  
\v 52 unu aghaghị ịchụpụ ndị niile bi nʼebe ahụ ma bibie chi niile ha na-efe, ndị ha ji nkume tụọ na ndị ha kpụrụ akpụ. Unu ga-ebibikwa ebe niile dị nʼelu ugwu niile, ebe ha na-anọ efe arụsị ha niile ofufe.  
\v 53 Nwetanụ ala ahụ, birikwa nʼime ya, nʼihi na enyela m unu ala ahụ ka unu nwere ya.  
\v 54 Unu ga-eke ala ahụ site nʼife nza, dịka agbụrụ unu niile si dị. Ndị bara ụba nye ha ihe nketa dị ukwuu, ndị dị ole na ole nye ha ihe nketa dị nta. Ihe ọ bụla ruuru agbụrụ ọbụla site nʼife nza ga-abụ nke ha. Kee ya dịka ebo nna nna unu ha si dị. 
\p  
\v 55 “ ‘Ma ọ bụrụ na unu achụpụghị ndị niile bi nʼala ahụ, ndị unu hapụrụ ga-abụrụ unu iberibe unyi nʼanya unu. Ha ga-adịkwara unu ka ogwu nke ga-adụkasị unu ahụ. Ha ga-enye unu nsogbu nʼala ahụ unu na-aga ibi nʼime ya.  
\v 56 Mgbe ahụ kwa, aga m emeso unu ụdị mmeso ahụ m na-akwado imeso ha ugbu a.’ ” 
\c 34  
\s1 Oke ala na Kenan 
\li4  
\v 1 \nd Onyenwe anyị\nd* gwara Mosis okwu sị ya,  
\v 2 “Nye ndị Izrel iwu sị ha, ‘Mgbe unu banyere nʼala Kenan, ndị a bụ oke ala ndị ahụ unu ga-enweta dịka ihe nketa unu: 
\b  
\li1  
\v 3 “ ‘Oke ala unu nʼakụkụ ndịda ga-etinyetụ aka nʼọzara Zin. Ala unu na ala ndị Edọm ga-enwekọ oke ala. Nʼakụkụ ọwụwa anyanwụ, oke ala ndịda unu ga-ebido na ngwụcha Osimiri Nnu,  
\v 4 gafee ndịda Akrabim, gabiga ruo ọzara Zin, gbada ndịda ruo Kadesh Banea. Site nʼebe ahụ ọ ga-aga ruo Haza Ada, gafee ruo Azmọn,  
\v 5 ebe ọ ga-echigharị gbasoro iyi Wadi nke Ijipt ma kwụsị nʼosimiri Mediterenịa. 
\li1  
\v 6 Oke ala unu nʼakụkụ ọdịda anyanwụ ga-abụ ọnụ mmiri osimiri Mediterenịa. Nke a ga-abụ oke ala unu. 
\li1  
\v 7 Oke ala unu nʼakụkụ ugwu ga-amalite nʼosimiri Mediterenịa ruo nʼugwu Hor.  
\v 8 Ọ ga-esitekwa nʼugwu Hor ruo Lebo Hamat, gbatịakwa ruo Zedad,  
\v 9 ruo Zifron tutu kwụsị na Haza Enan. Nke a ga-abụ oke ala unu nʼakụkụ ugwu. 
\li1  
\v 10 Oke ala unu nʼakụkụ ọwụwa anyanwụ ga-ebido na Haza Enan ruo Shefam.  
\v 11 Oke ala ahụ ga-agbada site Shefam ruo Ribla nʼakụkụ ọwụwa anyanwụ Ain. Site nʼebe ahụ, ọ ga-agbasoro ndịda ọdịda anyanwụ Osimiri Galili.  
\v 12 Mgbe ahụ, ọ ga-aga ogologo ogologo, gbasoro osimiri Jọdan, tutu kwụsị nʼOsimiri Nnu. 
\b  
\li4 “ ‘Nke a bụ ala unu, na oke ala ya nʼakụkụ ọbụla.’ ” 
\b  
\p  
\v 13 Mosis nyere ndị Izrel iwu sị, “Kesaanụ ala a dịka ihe nketa site nʼife nza. \nd Onyenwe anyị\nd* enyela iwu ka enye ya ebo itoolu na ọkara ndị ahụ fọdụrụ.  
\v 14 Nʼihi na ebo Ruben na Gad tinyere ọkara ebo Manase, enwetalarị ala ihe nketa ha.  
\v 15 Ebo abụọ nʼọkara ndị a enwetala ihe nketa nke ha nʼakụkụ ọwụwa anyanwụ osimiri Jọdan, na ncherita ihu obodo Jeriko.” 
\p  
\v 16 \nd Onyenwe anyị\nd* gwara Mosis okwu sị ya,  
\v 17 “Ndị a bụ aha ndị ikom m họpụtara ịhụ na e kenyere unu ala ahụ dịka ihe nketa unu. Elieza onye nchụaja, na Joshua nwa Nun.  
\v 18 Site nʼebo ọbụla họpụta otu onyendu ka ha nye aka ikesa ala nketa ahụ. 
\b  
\li4  
\v 19 “Ndị a bụ aha ndị a họpụtara: 
\b  
\li1 “Kaleb nwa Jefune, site nʼebo Juda. 
\li1  
\v 20 Shemuel nwa Amihud, site nʼebo Simiọn 
\li1  
\v 21 Elidad nwa Kislon, site nʼebo Benjamin. 
\li1  
\v 22 Buki nwa Jogli, onyendu si nʼebo Dan. 
\li1  
\v 23 Haniel nwa Efod, onyendu si nʼebo Manase, nwa Josef. 
\li1  
\v 24 Kemuel nwa Shiftan, onyendu si nʼebo Ifrem, nwa Josef. 
\li1  
\v 25 Elizafan nwa Panak, onyendu si nʼebo Zebụlọn. 
\li1  
\v 26 Paltiel nwa Azan, onyendu si nʼebo Isaka. 
\li1  
\v 27 Abihud nwa Shelomi, onyendu si nʼebo Asha. 
\li1  
\v 28 Pedahel nwa Amihud, onyendu si nʼebo Naftalị.” 
\b  
\li4  
\v 29 Ndị a bụ ndị ikom \nd Onyenwe anyị\nd* nyere iwu si ha kenye ndị Izrel ihe nketa ha nʼala Kenan. 
\c 35  
\s1 Obodo ndị Livayị 
\p  
\v 1 Nʼoge a, mgbe ndị Izrel ka nọ nʼakụkụ osimiri Jọdan nʼobosara ala Moab, na ncherita ihu Jeriko, ka \nd Onyenwe anyị\nd* gwara Mosis okwu sị ya,  
\v 2 “Nye ndị Izrel iwu ka ha nye ndị Livayị ụfọdụ obodo ebe ha ga-ebi. Obodo ndị a ga-abụ ndị si nʼihe nketa ndị Izrel ketara. Nyekwa ha ala ebe anụ ụlọ ha ga-anọ na-akpa nri, nke ga-agba obodo ndị a gburugburu.  
\v 3 Obodo ndị a ga-abụrụ ha ebe obibi, ma ala niile gbara ha gburugburu ga-abụ ebe ịta nri nke igwe ehi na atụrụ, na anụ ụlọ ha niile. 
\p  
\v 4 “Ala ebe ịta nri nke obodo niile nke unu ga-enye ndị Livayị ga-adị narị mita anọ na ọkara nʼogologo site na mgbidi obodo ga gburugburu mgbidi obodo ọbụla.  
\v 5 Ya mere nʼobodo ndị Livayị ọbụla, ala ịzụ anụ ụlọ ga-adị narị mita anọ na ọkara site na mgbidi ha ruo nʼoke ala ha. Ọ ga-adị narị mita anọ na ọkara nʼakụkụ ọwụwa anyanwụ, narị mita anọ na ọkara nʼakụkụ ọdịda anyanwụ, narị mita anọ na ọkara nʼakụkụ ugwu, narị mita anọ na ọkara nʼakụkụ ndịda. Obodo ha ga-adịkwa nʼetiti ala ịzụ anụ ụlọ ndị a. 
\s1 Obodo mgbaba 
\p  
\v 6 “Obodo isii nʼime obodo ndị ahụ unu na-enye ndị Livayị ga-abụ obodo mgbaba, ebe onye ọbụla gburu mmadụ na-amaghị ama nwere ike gbaga izere ndụ ya. Tinyere obodo ndị a unu ga-enyekwasị ha iri obodo anọ na abụọ ọzọ.  
\v 7 Ya mere obodo niile a ga-enye ndị Livayị ga-adị iri obodo anọ na asatọ, tinyere obosara ala ịzụ igwe ewu na atụrụ nke gbara obodo ndị a gburugburu.  
\v 8 Obodo unu na-enye ndị Livayị site nʼihe nketa ndị Izrel ga-abụ dịka unu si keta oke unu. A ga-esite nʼaka ebo nwere ọtụtụ obodo wepụta ọtụtụ obodo, ma site nʼaka ebo obodo ha nwere na-ehighị nne wepụta ole na ole.” 
\p  
\v 9 Mgbe ahụ, \nd Onyenwe anyị\nd* gwara Mosis okwu sị ya,  
\v 10 “Gwa ndị Izrel sị ha, ‘mgbe unu gafere Jọdan banye nʼala Kenan,  
\v 11 họpụtanụ ụfọdụ obodo ka ọ bụrụ obodo mgbaba ebe mmadụ nwere ike ịgbabanye ma ọ bụrụ na o gbuo mmadụ na-amaghị ama.  
\v 12 Obodo ndị a ga-abụ ebe mgbaba nye onye na-ezere ndụ site nʼaka onye ahụ chọrọ ịbọrọ ọbọ,\f + \fr 35:12 \ft Onye ọbụla ga-abọrọ ọbọ a, ga-abụ nwanne onye e gburu egbu.\f* ka a ghara igbu onye e boro ebubo igbu mmadụ tutu ruo mgbe e buru ụzọ kpee ya ikpe nʼihu ọgbakọ.  
\v 13 Obodo isii ndị a unu wepụtara ga-abụ obodo mgbaba.  
\v 14 Họpụta obodo mgbaba atọ nʼakụkụ ọzọ nke Jọdan. Ka atọ ndị ọzọ dịrị na Kenan.  
\v 15 Obodo ndị a agaghị abụ ebe izere ndụ maka naanị ndị Izrel, kama ọ dịkwara ndị ọbịa na ndị ọzọ bi nʼetiti unu, ka onye na-akpachaghị anya gbuo mmadụ gbaga ebe ahụ izere ndụ ya. 
\p  
\v 16 “ ‘Ọ bụrụ na mmadụ e jiri mkpirisi igwe tigbuo mmadụ ibe ya, a ga-agụ onye dị otu a dịka ogbu mmadụ. A ga-egbukwa ya.  
\v 17 A sịkwa na mmadụ ejide nʼaka ya nkume nke o nwere ike iji tugbuo mmadụ, ọ bụrụ na ọ tụọ mmadụ nkume ahụ tugbuo ya, ọ bụ ogbu mmadụ. Ogbu mmadụ ahụ aghakwaghị ịnwụ.  
\v 18 A sikwa na mmadụ ji ihe e ji osisi tụọ nʼaka ya, nke o nwere ike i ji tigbuo mmadụ, ọ bụrụ na o tie mmadụ ihe osisi ahụ, tigbuo ya, ọ bụ ogbu mmadụ. A ghaghị ime ka ogbu mmadụ ahụ nwụọ.  
\v 19 Onye na-abọ ọbọ ọbara ga-egbu ogbu mmadụ ahụ nʼonwe ya mgbe ọbụla o zutere ya.  
\v 20 Ọ bụrụ na mmadụ esite nʼekworo nuo onye ọzọ aka, maọbụ kpachara anya tụọ onye ahụ ihe nke mere ka ọ nwụọ,  
\v 21 maọbụ na o sitere nʼobi ọnụma jiri aka ya tie mmadụ ihe nke mere ka ọ nwụọ, a ga-egbu onye ahụ, nʼihi na ogbu mmadụ ka ọ bụ. Onye na-agwachite ọchụ ga-egbu ogbu mmadụ ahụ mgbe ọbụla o zutere ya. 
\p  
\v 22 “ ‘Ma ọ bụrụ na mmadụ ebughị iro nʼobi nutuo mmadụ ibe ya na mberede, maọbụ tụọ ya ihe,  
\v 23 maọbụ tụtuo nkume nke datara dagbuo mmadụ ibe ya mgbe ọ na-ahụghị ya, bụ onye na-abụghị onye iro ya, onye ọ na-ebughị nʼobi imejọ,  
\v 24 mgbe ahụ, ndị ọgbakọ ga-ekpe ikpe nʼetiti onye e boro ebubo na onye na-agwachite ọchụ dịka usoro iwu ndị a si dị.  
\v 25 Nzukọ aghaghị ichekwa onye e boro ebubo na o gburu mmadụ site nʼaka onye na-agwachite ọchụ, zilaga onye ahụ e boro ebubo nʼobodo mgbaba, bụ ebe ha gbalagara. Onye ahụ e boro ebubo ga-anọgide nʼobodo mgbaba ahụ tutu ruo mgbe onyeisi nchụaja nwụrụ, bụ onye ahụ e tere mmanụ nsọ. 
\p  
\v 26 “ ‘Ma ọ bụrụ na ogbu mmadụ a ahapụ obodo mgbaba ahụ pụọ, ọ bụrụkwa,  
\v 27 na onye ahụ na-abọ ọbọ ọbara achọta ya nʼazụ obodo mgbaba ahụ, o nwere ike igbu onye ahụ e boro ebubo, ikpe igbu mmadụ agaghị ama ya.  
\v 28 Onye ahụ e boro ebubo na o gburu mmadụ aghaghị ịnọ nʼime obodo mgbaba ahụ tutu ruo mgbe onyeisi nchụaja nwụrụ. Ọ bụ naanị mgbe onyeisi nchụaja nwụchara, ka ha nwere ike ịlaghachi nʼụlọ ya, nʼihe nketa ya. 
\p  
\v 29 “ ‘Ndị a bụ usoro iwu ga-adịgide nye unu site nʼọgbọ ruo nʼọgbọ, nʼebe obibi unu niile. 
\p  
\v 30 “ ‘Onye ọbụla gburu mmadụ ga-anwụ. A ga-ama ya ikpe ọnwụ naanị mgbe e nwere karịa otu onye akaebe. Ọ dịghị onye ọbụla a ga-egbu nʼihi akaebe nke otu onye gbara megide ya. 
\p  
\v 31 “ ‘Unu a narakwala ihe ịgbara isi nʼọnọdụ ndụ nke onye gburu mmadụ, bụ onye nke ikpe ọnwụ mara. Aghaghị ime ka ha nwụọ. 
\p  
\v 32 “ ‘Unu a narakwala ihe mgbapụta site nʼaka onye ọbụla nke gbagara nʼobodo mgbaba, site otu a kwere ka ha lọghachite azụ ga biri nʼala nke aka ha tupu onyeisi nchụaja anwụọ. 
\p  
\v 33 “ ‘Unu emerụkwala ala ahụ nke unu bi nʼime ya. Ọbara igbu ọchụ na-emerụ ala. Ọ dịkwaghị mkpuchi mmehie a ga-eme banyere ala a wufuru ọbara nʼime ya, ma ọ bụghị naanị ọbara nke onye ahụ gburu ọchụ ahụ.  
\v 34 Unu emerụla ala ahụ unu na-aga ibi nʼime ya. Nʼihi na mụ onwe m bikwa nʼebe ahụ, mụ bụ \nd Onyenwe anyị\nd* bi nʼetiti ụmụ Izrel.’ ” 
\c 36  
\s1 Oke ụmụ ndị inyom Zelofehad 
\p  
\v 1 Nʼoge ahụ, ndịisi ezi agbụrụ Gilead, nwa Makia, nwa Manase, otu nʼime ụmụ Josef, bịakwutere Mosis na ndị ndu, na ndịisi ezi ụmụ Izrel sị ha:  
\v 2 “Mgbe \nd Onyenwe anyị\nd* nyere unu onyenwe m iwu inye ụmụ Izrel ala ahụ nʼihe nketa site nʼife nza, onye nyekwara gị iwu iwere ihe nketa nwanne anyị nwoke Zelofehad nyefee nʼaka ụmụ ya ndị inyom.  
\v 3 Ugbu a, ọ bụrụ na ha alụọ ndị ikom Izrel si nʼebo ọzọ, mgbe ahụ, ihe nketa ha ga-abụ nke anapụrụ anyị, tụkwasị nʼihe nketa nke ebo ebe ha lụrụ di. Nʼụzọ dị otu a, ihe nketa anyị ga-abụ nke e wepụrụ ihe site na ya.  
\v 4 Mgbe afọ inwere onwe nye Izrel ruru, a ga-agụnye ihe nketa ha nʼebo ebe ha lụrụ dị. A ga-esi otu a wepụ ala ha site nʼihe nketa nke nna nna anyị ha ketara.” 
\p  
\v 5 Mgbe ahụ, Mosis nyere ndị Izrel ntụziaka site nʼiwu \nd Onyenwe anyị\nd* sị, “Ihe ndị ikom ebo Josef na-ekwu ziri ezi.  
\v 6 Ma nke a bụ iwu \nd Onyenwe anyị\nd* na-enye maka ụmụ ndị inyom Zelofehad. Ha nwere ike ịlụ onye ọbụla masịrị ha, ma onye ha ga-alụ ga-abụrịrị onye si nʼagbụrụ ebo nna ha.  
\v 7 O nweghị ihe nketa ọbụla nʼIzrel ga-esi nʼaka otu ebo gafee nʼebo ọzọ. Nʼihi na ihe nketa nke ebo ọbụla ga-adịgidere ha dịka otu e siri kee ya nye nna nna ha.  
\v 8 Nwa nwanyị Izrel ọbụla ketara ala nʼebo Izrel ọ bụla ga-alụ di site nʼagbụrụ ebo nna ya. Ka ala ha ghara ịgafere ebo ọzọ.  
\v 9 Ọ dịghị ihe nketa ọbụla ga-esi nʼotu ebo feere ebo ọzọ. Nʼihi na ebo Izrel ọbụla ga-edebere onwe ha ala ha ketara.” 
\p  
\v 10 Ya mere, ụmụ ndị inyom Zelofehad mere dịka \nd Onyenwe anyị\nd* nyere Mosis nʼiwu.  
\v 11 Ụmụ Zelofehad ndị a: Mahla, na Tịaza, na Hogla, na Milka, na Noa, lụrụ ndị ikom si nʼebo nna ha.  
\v 12 Ha lụrụ di nʼagbụrụ ụmụ Manase, nwa Josef. Nʼụzọ dị otu a, ihe nketa ha dịgidere nʼebo na agbụrụ nna ha. 
\b  
\p  
\v 13 Ndị a bụ iwu na ụkpụrụ \nd Onyenwe anyị\nd* sitere nʼaka Mosis nye ndị Izrel nʼoge ha nọ nʼobosara ala Moab, nʼakụkụ osimiri Jọdan, na ncherita ihu Jeriko.