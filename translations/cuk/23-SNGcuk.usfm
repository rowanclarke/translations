\id SNG - Kuna, San Blas - Bible -Panama 2014 (DBL -2014) 
\h Cantares 
\toc1 Namakleged-Birigined-Garda 
\toc2 Cantar de los Cantares 
\toc3 Ct 
\mt1 NAMAKLEGED-BIRIGINED-GARDA 
\mt2 CANTARES 
\imt2 GEBE-SOGLENAID 
\imt1 Garda-nug 
\ip \it Namakleged-Birigined-Garda.\it* We garda, Hebreo-gayabali, \it Shir-Hashirimʼye\it* bileged. “Namakleged-biriginedye” sogleged. 
\is1 Namakleged-Birigined-Gardagi weyob sunmaklenaid 
\ip We-namaklegedi, sabguedgi namakleged. Degi, abirgin-abegedgi namakleged. Machigwa-wargwen bunagwa-abesiidgi namaked. 
\ip We-namaklegedi soganergwagi akar-akar-namaklemalad naid. Machigwa bunagwa-ebo na abesimalad muchub-muchub sunmaknanaid. We-namaklegedi bukidara egi akar-akar ibmarmarba-dakagwale sunmaklenaid. 
\ip We-namaked-garda oyobalid igi-Bab-Dummadi Israel-dulemar-sabgusa. Degisoggu, emi-ibasega amba deyob Bab-sordamala Jesucristo-sabguedgi sunmakmarmogad. 
\ip We-garda sunmakbalid, igi Cristo iglesia e-omeyobi na dake, a-burbagi anmarga sunmaked. 
\ip Binsaleged, we-garda Rey-Salomón narmaksaye. 
\ip We-gardagine, weyob ilemakar sunmaklenaid: 
\io1 1. Namakleged-gebed (1:1–2:7). 
\io1 2. Namakleged-sogbogwad (2:8–3:5). 
\io1 3. Namakleged-sogbaagwad (3:6–5:1). 
\io1 4. Namakleged-sogbakegwad (5:2–6:3). 
\io1 5. Namakleged-sogataled (6:4–8:4). 
\io1 6. Namakleged-soganergwad (8:5-14). 
\ip Be itogua. 
\c 1  
\ms1 1. NAMAKLEGED-GEBED 
\mr (1:1–2:7) 
\s1 Ome-abirgin-nikad-e-namaked 
\q1  
\v 1 Salomón we-namakleged-birigined narmaksad. 
\sp Ome-nue-sabgulediid namaked 
\q1  
\v 2 ¡Bitigi be an-wagar-usana gadina! 
\q2 Be-sabgued vino-goblegedbali, bur bule yeer itoleged. 
\q1  
\v 3 Be-ina-wawadikid-e-yapannedi, nue-yeer yapanned. 
\q2 Ar be-sunnadi, ina-wawadikidyob gued. 
\q2 ¡Agala, yagana nue-bebina sogmalad! 
\b  
\q1  
\v 4 ¡Be an-nide! ¡Gwae beba be an-nide! 
\q2 ¡An-rey, be-gabednegse be an-sede! 
\q1 Anmar wergumarsun, 
\q2 anmar yeer-itomarsun. 
\q1 Be-sabguedgi, vino-goblegedbali, bur bule anmar egi wergue. 
\q2 ¡Agala, bebina nue sogmalad! 
\b  
\q1  
\v 5 ¡Jerusalén-neggwebur-bunamala! An uka sichii gued, an yeer dakleged. 
\q2 Cedar-dulemar-dordoneg-sichigan-bubukwadyob an-uka sichii dakleged. 
\q2 Salomón-mor-dummaganyob an yeer dakleged. 
\q1  
\v 6 Mer an-uka-sichigwadgi be atakmala, 
\q2 ar dad-ibeler-gaedba, deyob an gusad. 
\q1 An-susmar anse ulusmalad, 
\q2 e-uva-dub-nainu-akwega an-imaksamalad. 
\q2 A-ulale, an-uva-dub-nainu bar an nue akwissurgusad. 
\b  
\q1  
\v 7 ¡An-sui-nue-sabesailad! Anga be soge, be-sibadmar-gagangi-omanaegala, ¿bia be omanaddae? 
\q2 ¿Bia yorukudba be obunnogega seddae? 
\q1 ¿Ar ibiga an dule-negsuligudidaeyobi, 
\q2 be-aimar-sibad-bukwad-abargi an be-amidii guoe? 
\sp E-aimar bular namaked 
\q1  
\v 8 Omegan-yeerdaklemaladba, bur be yeer dakleged. 
\q2 Be-sui-nue-sabesailad-amiegala, sibad-gannarba be nae. 
\q1 Be-sibad-burwigan masgi-omanae, 
\q2 dule-sibad-edarbemalad-e-dordoneg-dikarba be omanae. 
\sp Sui-nue-sabgulediid namaked 
\q1  
\v 9 Be, an-ome-nue-sabesailadid. 
\q2 Bee be Faraón-ur-ebipimalad-moli-omegan-nuegan-yeerdaklegedyob be gued. 
\q1  
\v 10 Ibiyob be-wagar yeerdaklege, 
\q2 be-wagar oluamar-abargi yeer dakleged. 
\q1 Ibiyob be-dukar yeerdaklege, 
\q2 wingwamar-naid-abargi yeer be-dukar dakleged. 
\q1  
\v 11 Anmar bega oluamar-olobiid soboed, 
\q2 oluamargi manimar-nanai bega imakoed. 
\sp Ome-nue-sabgulediid namaked 
\q1  
\v 12 Rey e-megedgi yollekwaa megisale, 
\q2 an-ina-wawad, wawadik-oburmakdedaed. 
\q1  
\v 13 An-sui, ina-wawadikid binasgargi-atinnar-sagu-bipigi-seledidaedyob, anba gabdiid. 
\q2  
\v 14 An-sui, Engadiʼye-neg-nugadgi dutu-nuegan-nigwichiyob, anga gued. 
\sp Sui-nue-sabgulediid namaked 
\q1  
\v 15 An-ome-nue-sabesailad, ¡ibiyob be yeer daklege! 
\q2 ¡Doggus nued be dakleged! 
\q2 ¡Be-ibyamar, nuumaryobi gued! 
\sp Ome-nue-sabgulediid namaked 
\q1  
\v 16 ¡An-sui-nue-sabesailad! ¡Ar ibiyob be yeer daklege! 
\q2 ¡Machered-nued be daed! 
\sp Sui-nue-sabgulediid namaked 
\q1 Gaganmar-aramakmamaidi anmar-gabedga guoed, 
\q2  
\v 17 anmar-neg-nagubirmar urwarmar mamaid, 
\q2 anmar-neg-uas ciprés-e-urgomar mamaid. 
\c 2  
\sp Ome-nue-sabgulediid namaked 
\q1  
\v 1 Sarón-neba-naidgi dutu-gwichidyob an gued. 
\q2 Nebagi dutu-lirio-digar-gwichidyob an gued. 
\sp Sui-nue-sabgulediid namaked 
\q1  
\v 2 An-ome-nue-sabesailad, ikoganba dutu-lirio-gwichiyobi, 
\q2 omegan-abalagi gudiid. 
\sp Ome-nue-sabgulediid namaked 
\q1  
\v 3 An-sui-nue-sabesailad sapimar-abalagi manzana-sapi-gwichiyobi, sapingan-abalagi gudiid. 
\q2 A-sapi-urba-sigedi yeer an itodaed, 
\q2 e-sana, yeer gulledaed. 
\q1  
\v 4 An-sui, yeer-masgullegedse an-semai gusad, 
\q2 agi e-sabed anga nue-oyosad. 
\b  
\q1  
\v 5 Uva-odinnolegaledgi an-niga be ogannomala, 
\q2 manzanaʼgi an-niga be ogannomala, 
\q2 sui-abegedbina an nue-soged. 
\q1  
\v 6 Bitigi, e-sakwa-sapiled an-nono-urba mesisana gadin. 
\q2 Bitigi, e-sakwa-nueddi angaagwar an-imakena gadin. 
\sp Sui-nue-sabgulediid namaked 
\q1  
\v 7 Omegan-Jerusalénʼginmalad, goe-sapurbarmalad-nukad an bemarga ise-wilegagwar soged, 
\q2 melle be an-ome-nue-sabesailad an-ibe odakmalo, 
\q2 melle be ese gormalo, na atakbiedba atakdagoed. 
\ms1 2. NAMAKLEGED-SOGBOGWAD 
\mr (2:8–3:5) 
\sp Ome-nue-sabgulediid namaked 
\q1  
\v 8 ¡An-sui-nue-sabesailad-e-gaya gordani an itoged! 
\q2 ¡Be dakmala! ¡Wegi danikid be dakmala! 
\q1 Yalaganba ichomakdanikid, 
\q2 yar-mulluganba icho-icho danikid. 
\q1  
\v 9 An-sui-nue-sabesailad goe-sapuryob daed. 
\q2 An-sui-nue-sabesailad goe-sapur-senigwadyob gued. 
\q1 Be dakmalana, anmar-galu-naba gwichid, galu-imbaba atakgwichid, 
\q2 arbakee yawagak-senigwad-ollo-ollogwadba an-dakgwichid. 
\b  
\q1  
\v 10 An-sui-nue-sabesailad anga sunmaksad. 
\q2 Weyob anga sogded: 
\q1 “An-ome-nue-sabesailad, be gwisguye. 
\q2 ¡Ome-yeerdakleged, be anba dagye! 
\q1  
\v 11 Be dakena, dii-wied-ibagan bato nasye, 
\q2 dii-wied bato bergusye. 
\q1  
\v 12 Dutumar bato sapurba ainiarye. 
\q2 Namakleged-ibagan noniye. 
\q2 Suirgwamar-namakmalad, bela anmar-yargi itoleye. 
\q1  
\v 13 Higuera-sapi bato sanmakdeeye, 
\q2 uva-dub durbamakgwisye, e-dutumar bato oyapachaye. 
\q1 ¡An-ome-nue-sabesailad, be gwisguye. 
\q2 Ome-yeerdakleged, be anba dagye!” 
\sp Sui-nue-sabgulediid namaked 
\q1  
\v 14 Igi nuu akwa-imbaba, degi, yar-imbaba yaa-olloganagi dukue, 
\q2 melle be deyob an-idu dukue. 
\q1 Be-wagar anga be oyoge, 
\q2 be-sunmaked-itogega be an-imake. 
\q1 Ar be-gayaburba yeer itoledaed, 
\q2 be-wagar yeer daklebalid. 
\sp Ome, e-suibo namakdemalad 
\q1  
\v 15 Achu-asdubingiidmar anmarga be gamala. 
\q2 We-achu-senigana nainu-oichoged gudimalad. 
\q2 Ar anmar-ibe uva-dubmar-durbamakgwismalad wiogedid. 
\sp Ome-nue-sabgulediid namaked 
\q1  
\v 16 An-sui-nue-sabesailad angadid, an egadmogad. 
\q2 Dutumar-imbagi sibadmar-akwedii daed. 
\q1  
\v 17 An-sui-nue-sabesailad, dad-argwaned-iduale, 
\q2 negsichilealile, anse be dage. 
\q1 Goe-sapurbalidyobi be abarmakdage, 
\q2 yar-Beterʼye-nugad-yalaganba be abarmakdage. 
\c 3  
\s1 Ome e-sui-aminaded 
\q1  
\v 1 Mutik-gabmaidgine, an-sui an amialid, 
\q2 an-sui-na-nue-sabesailad an amialid. 
\q1 An-gabmaidgi an aminaigusanad, 
\q2 an amissurgusad. 
\q1  
\v 2 Geb an gwisguded, neg-imbaba an aminadgusad. 
\q2 Galimbaba an aminaded, 
\q2 ibmar-uklebukwadgi an aminaded. 
\q1 An-sui-nue-sabesailad an amidii gualid. 
\q2 An amidigusanad, an amissurgusad. 
\q1  
\v 3 Dule-nakulemalad galimbaba-bipirmakdimaladgi an-abingunonimalad. 
\q2 Geb amarse an egisded: “¿An-sui-nue-sabesailad be daksasurmala?” 
\q1  
\v 4 An a-dulemargi sikwas-aibategua, an-sui-nue-sabesailad an aminonikid. 
\q2 Angaagwar an gasad, bar an indaksasulid. 
\q1 Deyobi an-nan-negse an sesad, 
\q2 an-gwalulesad-negse an sesad. 
\sp Sui-nue-sabgulediid namaked 
\q1  
\v 5 Omegan-Jerusalénʼginmalad, goe-sapurbarmalad-nukad an bemarga ise-wilegagwar soged, 
\q2 melle be an-ome-nue-sabesailad an-ibe odakmalo, 
\q2 melle be ese gormalo, na atakbiedba atakdagoed. 
\ms1 3. NAMAKLEGED-SOGBAAGWAD 
\mr (3:6–5:1) 
\sp Bular-namakleged 
\q1  
\v 6 ¿We ibu waayobi neg-dulesulidganba ainakdani-daklege? 
\q2 Ina-wawadikid-mirra-abargi danikid, 
\q1 ina-wawadikid-incienso-abargi danikid, 
\q2 dutumar-wawadik-yapanmalad-abargi danikid. 
\q1  
\v 7 ¡Be dakmala! 
\q2 Salomón-e-moli-ur danikid. 
\q1 E-yalabali sordamar-niga-gandikmalad e-dulapaa (60) danikid. 
\q2 Israel-sordamar-niga-gandikmalad-abargi sulesmaladid. 
\q1  
\v 8 Wemar bela es-suid-nikamaladbiid, 
\q2 bilagi-urwemalagala odurdaklesmaladid. 
\q1 Neg-mutikidba e-isdarmalad-ainiardaed-ular, 
\q2 e-dikargi es-suid-nika-nika gudimalad. 
\b  
\q1  
\v 9 Rey-Salomón e-sii-seleged-ulu sobsad, 
\q2 Líbano-yargi sapimar-nuegan-gwismalad-e-urgogi sobsad. 
\q1  
\v 10 Ulu-e-suarmar, manigi-sobsabalid, 
\q2 e-bargamaladdi, orgi sobsabalid, 
\q1 e-siged, mor-suir-akwagiidgi oginnar nasiksabalid. 
\q2 Ulu-negyabali, ibmar-imaklesadi, 
\q1 bunamala-Jerusalénʼginmalad imaksad, 
\q2 ise-nudakar imaksamalad. 
\b  
\q1  
\v 11 ¡Omegan-Sión-yarginmalad, nodamala! 
\q2 Rey-Salomón be dakdamala. 
\q1 E-nan-ega-ologurgin-imaksad-yoi danikid. 
\q2 Ome-nikued-ibagi-yosad-yoi danikid. 
\q2 Wergued-dummad-itoged-ibagi-yosad-yoi danikid. 
\c 4  
\s1 Sui omebina-nue-soged 
\sp Sui-nue-sabgulediid namaked 
\q1  
\v 1 Be an-ome-nue-sabesailad, ibiyob be yeer daklege, 
\q2 doggus wilub-obicha be dakleged. 
\q1 Be-ibyamar, be-muswe-batenaid-imbaba nuumaryobi, yeer dakleged. 
\q2 Be-saila-batenaidi, sibadmar-Galaad-yargi danagwen ichomakar-aidedanidamaladyob, be-saila-batenaidi, yeer dakleged. 
\q1  
\v 2 Be-nugarmar, sibad-wawaadmar, e-absar-siklesad-sorba, oglesadgi dagudik-nakwedanidamaladyob dakleged. 
\q2 Degine, be-nugarmar, bela emaladbi daklebalid, 
\q1 bela amba sogedba bubukwad. 
\q2 Degidbali, yeer dakleged. 
\q1  
\v 3 Be-gakuli-daklegedi, morgo-gisigwadyobi dakleged. 
\q2 Be-sunmakedi, ibiyob yeer-itole an-imake. 
\q2 Be-wagar, be-muswe-batenaid-imbagi mammi-gisigwadyobi yeerdakleged. 
\q1  
\v 4 Be-dukar-daklegedi, David-e-neg-matusulidyobi yeer dakleged. 
\q2 We-neg-matusulidi, akwamar-yamo-sobaledgi sobaled. 
\q1 Be-dukargi, neg-matusulidgi miligwen-sigu-abgamalad-nanaiyob naid. 
\q2 We-sigu-abgamalad, bila-onomalad-bulegangadid. 
\q1  
\v 5 Be-mam-abinbela-naidi, goe-sapurmar-emarbi-daklegedyob dakleged. 
\q2 Goe-sapurmar dutumar-imbagi gagan-mananaidaeyobi, be-mam yeer dakleged. 
\q1  
\v 6 Dad-ibeler-nakwialile, negsichid miledele, ina-wawadikid-mirra-yarse an nakwenaoed, 
\q2 ina-wawadikid-incienso-yar-mulluse an nakwenaoed. 
\b  
\q1  
\v 7 Be an-ome-nue-sabesailad, nue be yeer dakleged. 
\q2 Be swilimakar dakleged. 
\b  
\q1  
\v 8 An-ome, Líbano-yar-akar anba be dage, 
\q2 Líbano-yargi-gudiidgi anba be dage, 
\q1 Amana-yar-akar be aidedage, 
\q2 Senir-yar-akar be aidedage, 
\q1 Hermón-yargi be aidedage. 
\q2 Achumigur-e-negmar-akar be aidedage, 
\q2 achu-barbad-e-yarmar-akar be aidedage. 
\b  
\q1  
\v 9 An-ome-nue-sabesailad, gebe be an-daksagua, bela-belagwad be an-binsaed ganonikid. 
\q2 Be-win-dukarba-naidgi an-edichayob be an-imaknonikid. 
\q2 Agi an-gwage begadga gunonikid. 
\q1  
\v 10 An-ome-nue-sabesailad, be-sabgued ibiyobi itolege. 
\q2 Be-sabgued, vino-goblegedba bur bule yeer itoleged. 
\q1 Be-ina-wawadikid-yapannedi, bela-ina-wawadikid-bamaladba 
\q2 bur bule yeer yapanned. 
\q1  
\v 11 An-ome-nue-sabesailad. Be-gakuligi, acha-uugi achanis-aryomaiyob gued. 
\q2 Be-gwabin-urba, nunis-aryomaiyobi gued, 
\q1 egi achanis-aryomaiyobbalid. 
\q2 Be-mormar-yapannedi Líbano-yar-yeer-yapannedyobi yapanned. 
\b  
\q1  
\v 12 An-ome-nue-sabesailad, be an-bun gued. 
\q2 Dutugalu-emakar-naiyob be gued. 
\q2 Dii-nued-aryomaid-emakar-naiyob be gued. 
\q1  
\v 13 Be-nuu, nainu-nued-naidgi, manzanaʼmar digar-gwisnanaeyobi gued. 
\q2 E-san-gullegedi yeer-gulle-nanaed. 
\q2 Be-nuu nainugi, dutu-nardo, degi, dutu-azahar nigwis-nanaedyob gued. 
\q1  
\v 14 Be-nuu nainugi ibmar-wawagana-nuegan, 
\q2 akar-akar egi digar-bukwayob gued: 
\q2 Egi dutu-nardo-digaleyob gued, 
\q2 dutu-azafrán-digaleyob gued, 
\q2 dutu-cálamo-digaleyob gued, 
\q2 ina-canela-digaleyob gued, 
\q2 ina-mirra-digaleyob gued, 
\q2 ina-áloe-digaleyob gued, 
\q3 degi, dutumar-baigan-nuegan-digaleyob, be-nuu gued. 
\q1  
\v 15 Igi diwar nainu-oge, deyob be gued. 
\q2 Dii-sukemakmaidi, Líbano-yar-akale aidedanidaeyobi, be gued. 
\sp Ome-nue-sabgulediid namaked 
\q1  
\v 16 Burwa-dad-nakwed-argan-sapiledsikid, be gordage. 
\q2 Burwa-dad-nakwed-argan-nuedsikid, be dage. 
\q1 An-dutugalugi be gordage. 
\q2 E-wawadikid-oyapandagega be imakdage. 
\q1 Be an-sui-nue-sabesailad, be-dutugaluse be dage. 
\q2 E-sanmakgwichid-yeer-gulleged be gundage. 
\c 5  
\sp Sui-nue-sabgulediid namaked 
\q1  
\v 1 Be, an-ome-nue-sabesailad, an-bunbalid. 
\q2 An-dutugaluse an dogsad, 
\q1 agi an-mirra-wawadikid an aminonikid, 
\q2 agi an-ina-wawadikid an sunonikid. 
\q1 Agi an-achanis an nue-masad, 
\q2 agi an-achanis-e-uu an nue-guchabalid. 
\q1 Agi vino an nue-gobsad, 
\q2 nunis an nue-gobsabalid. 
\sp Bular-namakleged 
\q1 An-aimar, mas-nued be gunmala, gatik be gobmarbali, 
\q2 immee gudii be imakmala. 
\ms1 4. NAMAKLEGED-SOGBAKEGWAD 
\mr (5:2–6:3) 
\sp Ome-nue-sabgulediid namaked 
\q1  
\v 2 An gabmaidgine itoakwaa an gabmaid. 
\q2 Agine, an-sui yawagakba gorgwichi an itoalid: 
\q1 “An-ome, an-buna, nuu-yeerdaklegeyob be yeer dakleged. 
\q2 ¡Anga yawagak be egae! 
\q1 Ar boo-batenaidba an-nono waradikgusad, 
\q2 ar neg-mutikidba-boo-batenaidba, an-sailagia waradikgusad.” 
\b  
\q1  
\v 3 Bato an mor esusad. 
\q2 ¿Gannar an mor yobarsunde? 
\q1 Bato nag an enuksabalid. 
\q2 ¿Gannar an nag ollibi-gubarsunde? 
\b  
\q1  
\v 4 An-sui yawagakgi-yaa-ollo-siidgi e-argan odosad. 
\q2 Deyob an daksagua, bela an-gwagese an-ebusad. 
\q1  
\v 5 An-suiga an yawagak-egaegala, yog gwisguar an imaksad. 
\q2 An-argangi mirra-wawadikid ariomaid, 
\q1 an-goomar-imbaba bela ariomaid, 
\q2 yawagak-eduedgi deemaknai gusad. 
\b  
\q1  
\v 6 An an-sui-nue-sabesailadga yawagak-egasgua, bar gwichisulid, an-idu naded. 
\q2 An-idu-nadedbali, an naibi itononikid. 
\q1 Aisaar an amisanad, 
\q2 an amissurgusad. 
\q1 An ese gornaigusbalinad, 
\q2 an-abin-imaksasurbalid. 
\q1  
\v 7 Agine geb, dulemar-nakulemalad nakuledimargua, an-aminonimalad. 
\q2 A-dulemala an-sarsononimalad, an-naibi-imaksamalad. 
\q2 Dulemar-galugi-nakulebukwad, sabsur-an-ibe mor esusmalad. 
\q1  
\v 8 Jerusalén-bunamala, ise-wilegagwar an bega sogmar. 
\q2 Bemar an-sui-nue-sabesailad-abingualile, ega be sogmalo, sui-abegedba an uelledye. 
\sp Bular-namakleged 
\q1  
\v 9 Omegan-bamaladba-bur-yeerdakleged, be anmarga soge, 
\q2 “¿ibugi be-macheredde, machergan-bamaladgi obinsunna? 
\q2 ¿Ibugi obinsunna, emide be weyob anmarse egisnaigu?” 
\sp Ome-nue-sabgulediid namaked 
\q1  
\v 10 An-sui-nue-sabesailad, machered-nued dakleged, 
\q2 e-uka sichisaar-daklebalid. 
\q2 Dule-miliambegwad-abargi (10,000) magasar dakleged. 
\q1  
\v 11 An-sui-e-nono, or-nuedyob yeer dakleged. 
\q2 E-sailagia, sinni-sinni nikad, sikwisichidyob sichii gued. 
\q1  
\v 12 E-ibyamar-gwabogwad-daklegedi, nuumar diwar-gakanaba-simalayob dakleged, 
\q2 nunisgi-obsayob dakleged. 
\q2 E-ibyamar innikimakar bukwad. 
\q1  
\v 13 E-wagardi, wawadikid, 
\q2 ina-wawadikid egi digar-naiyobid. 
\q1 E-gakuli dutumar-daklegeyobid, 
\q2 agi mirra-nis egi dedemaknaiyobid. 
\q1  
\v 14 E-swidamardina, or-suarmar-daklegeyobid, 
\q2 akwa-nuegan egi nanaiyobid. 
\q1 Bela-e-abagan, elefante-nugar-daklegeyob, swilidikid dakleged. 
\q2 Akwa-nuegan-zafiroʼye-nugad, bela egi ebiris naiyobid. 
\q1  
\v 15 E-malimar-warbogwaddina, akwa-nued-mármol or-nued-sobaled-birgi-gwigwichidyob dakleged. 
\q2 E-gwisgued, yeerdakle gwisgued, 
\q2 Líbano-yargi-urwar-gwigwichidyob dakleged. 
\q1  
\v 16 E-gakulide, bela osidikid, 
\q2 bela e-daklegedi, machered-nued itoged. 
\b  
\q1 Jerusalén-bunamala, ar deyob an-sui dakleged, 
\q2 ar deyob an-ai dakleged. 
\c 6  
\s1 Na abebukmalad 
\sp Bular-namakleged 
\q1  
\v 1 Omegan-bamaladba-bur-be-yeerdakleged, ¿bia be-sui-nue-sabesailad nade? 
\q2 ¿Bitisik nade? 
\q2 Anmar beba bulakwaa aminaoe. 
\sp Ome-nue-sabgulediid namaked 
\q1  
\v 2 An-sui e-dutugaluse aidenaded, 
\q2 ina-wawadikid-bukwadse naded, 
\q1 dutumar-imbaba-garmakdii imaknaded, 
\q2 dutumar-gwanega naded. 
\b  
\q1  
\v 3 Ani an, an-sui-nue-sabesailadgadid, 
\q2 an-sui-nue-sabesailad, angadmogad. 
\q2 Dutumar-imbaba na e-ibmar-durgan akwediid. 
\ms1 5. NAMAKLEGED-SOGATALED 
\mr (6:4–8:4) 
\sp Sui-nue-sabgulediid namaked 
\q1  
\v 4 Be, an-ome-nue-sabesailad. 
\q2 Ar igi Tirsa-neggwebur yeer daklege, 
\q1 igi Jerusalén-neggwebur yeer daklege, 
\q2 igi niisgwamar-niba-nanaid geger daklege, 
\q2 deyob be yeer dakleged. 
\q1  
\v 5 Mer bar be an-daknai gue, 
\q2 ar be an-daksadbali, an bebina-sognonikid. 
\q1 Be-saila-batenaidi, sibadmar-Galaad-yargi danagwen ichomakar-aidedanidamaladyob, 
\q2 be-saila-batenaidi, yeer dakleged. 
\q1  
\v 6 Be-nugarmar, sibad-wawaadmar, e-absar-siklesad-sorba, oglesadgi dagudik-nakwedanidamaladyob dakleged. 
\q2 Degine, be-nugarmar, bela emaladbi daklebalid, 
\q1 bela amba sogedba bubukwad. 
\q2 Degidbali, yeer dakleged. 
\q1  
\v 7 Be-wagar, be-muswe-batenaid-imbagi 
\q2 mammi-gisigwadyobi yeerdakleged 
\q1  
\v 8 Ar rey-omegan e-dulapaa (60) gued, 
\q2 rey-omegan-dikarbarmalad e-dulabake (80) gubalid, 
\q2 degi, yagana-bukidar gubalid, 
\q1  
\v 9 degi-inigwele, unnila wargwenna nuu-yeerdaklegedyobid angad gudiid. 
\q2 E-nan, a-omegwa na nue sabedid, ega wargwenna guedid, 
\q1 na we-napnegse odesadid, 
\q2 a-bina bur gadi-sogedid. 
\q1 Yagana, a-ome-dakarmale, egi ise-nued binsadamalad. 
\q2 Rey-omegan, degi, e-omegan-dikarbarmalad, bunagwa-e-nug odummodamalad. 
\sp Bular-namakleged 
\q1  
\v 10 ¿Ar we doawa, yeerdakleged? 
\q2 Ar bolegoedba neg-ainakwiardaeyobi, 
\q1 mutikidba nii-daarmakenaidaeyobi, 
\q2 dad-ibeler daarmakenaidaeyobi, 
\q1 niba niisgwamar gananaidaeyobi, 
\q2 ber yeer dakleged. 
\sp Ome-nue-sabgulediid namaked 
\q1  
\v 11 Sapimar-Nogalʼye-nugad-bukwadse an aidesad, 
\q2 yar-imbagi dutumar-binigan-dakega an aidesad, 
\q1 abakale, uva-e-muumar ainisale, 
\q2 abakale, manzana-e-durbamar ainisale. 
\q1  
\v 12 Degine, naded an itossulid, 
\q2 an yeer-itogedbali, an-dummad-naba urgi-gwichi an itoalid. 
\sp Bular-namakleged 
\q1  
\v 13 Ome-Sulamʼgined, be dage, be dage. 
\q2 Gannar be anmarse dage, 
\q2 anmar nue be-dakbied. 
\sp Ome-nue-sabgulediid namaked 
\q1 ¿Ar Ibiga be an-dakbimala? 
\q2 ¿Ibiga bemar emar-abargi-dodonai be an-dakbimala? 
\c 7  
\sp Sui-nue-sabgulediid namaked 
\q1  
\v 1 An-yagwa-yeerdakleged, be-nag, nag-uka-yoid yeer dakleged. 
\q2 Be-duawar-billikwaa-daklegedi, dule-or-sobed ormar-yeerdakleged-sobsayobi, yeer dakleged. 
\q1  
\v 2 Be-simu-daklegedi, noga-dirbikwagwadgi, vino enamakarsiiyobi dakleged. 
\q2 Be-saban-daklegedi, orosgi-dakleged-trigo-dunnumaksiidgi, dutumar ebiris-nanaiyobi, yeer dakleged. 
\q1  
\v 3 Be-mam-abinbela-naidi, goe-sapurmar-emarbi-daklegeyobi, yeer dakleged. 
\q2  
\v 4 Be-dukar-daklegedi, neg-matusulid-elefante-nugargi-soblegaleyobi, yeer dakleged. 
\q1 Be-ibyamar-daklegedi, Hesbón-neg-nugad-e-diamar, Bat-Rabim-e-yawagak-naba dakarmakbukwayobi, yeer dakleged. 
\q2 Be-asu-daklegedi, Líbano-yargi neg-matusulid, Damasco-neggwebursik negadakegwichiyobi, yeer dakleged. 
\q1  
\v 5 Be-nono-daklegedi, Carmelo-yar-magasar-daklesiyobi, yeer dakleged. 
\q2 Be-sailagia-ilemakmaid, dub-suir-akwa-daklegeyob dakleged. 
\q2 Be-sailabali, rey binsaed-galenai gusad. 
\b  
\q1  
\v 6 An-ome-nue-sabesailad, ibiyobi be yeerdaklege, 
\q2 be-sabgued yeer an-imaked. 
\q1  
\v 7 Be-daklegedi, ogobwar-innikimakar-gwichiyobi yeer dakleged. 
\q2 Be-mam, ogobmar-naidyobi yeer dakleged. 
\q1  
\v 8 Weyob an sogded: 
\q2 “Ogobgi an nakwenaoe, e-san an gwannaoe.” 
\q1 Be-mam, uva-duk-dukwen-naidyobid. 
\q2 Be-gaya-yapannedi, manzana-yeer-yapannedyobid. 
\q1  
\v 9 Be-gaya-itolegedi, vino-nued goblegedyob itoleged. 
\q2 Igi vino, binnasdikii gaya-yaba ariomaidae, bela gakuli waradik imake, 
\q1 nugarse-bakale waradik naddae, 
\q2 deyobi be-gaya itoleged. 
\sp Ome-nue-sabgulediid namaked 
\q1  
\v 10 Ani an, an-sui-nue-sabesailadgadid. 
\q2 Nue-anbina-sogedbali, angi nue-wergudiid. 
\q1  
\v 11 An-sui-nue-sabesailad, anba be dage, 
\q2 sapurba anmar nae, 
\q2 dutugan-imbaba oibodii anmar imaknae. 
\q1  
\v 12 Neg-oibosale, anmar uva-nainuse naoed, 
\q2 abakale, e-muumar ainisale, 
\q1 abakale, e-dutumar-ainisale, 
\q2 abakale sapi-granada-e-dutumar ainisale. 
\q2 ¡Agi an bega sabgued oyogoed! 
\b  
\q1  
\v 13 Gagan-mandrágora-e-san-yapanned bato magar itoleged. 
\q2 Anmar-yawagak-nagaba bukidar akar-akar sapi-sanmar bubukwad. 
\q1 An-ome-nue-sabesailad, sapi-sanmar-binigan an bega sabosad, 
\q2 sapi-sanmar-dinnagana, an bega sabosbalid. 
\c 8  
\q1  
\v 1 Be, an-sus-gargwenadina yeerbana, 
\q2 an-nangi be nuugusmogana yeerbana. 
\q1 Degina, igarba an be-abingunonikidgi an be-ibe wagar uoenad, 
\q2 dule gwen anga akar sogosulinad. 
\q1  
\v 2 Argangi-gasa an be-imakoenad, 
\q2 an-nan-negse an be-sedoenad, 
\q1 agine, sabgued-igargi be an-odurdakoenad. 
\q2 Vino-wawadikidgi be-ogobega an be-imakoenad, 
\q2 an-nur-granada-nisgi an be-ogobbaloenad. 
\b  
\q1  
\v 3 Bitigi, e-sakwa-sapiled an-nono-urba mesisana gadin. 
\q2 Bitigi, e-sakwa-nueddi angaagwar an-imakena gadin. 
\sp Sui-nue-sabgulediid namaked 
\q1  
\v 4 Omegan-Jerusalénʼginmalad, an bemarga ise-wilegagwar soged: 
\q2 “Melle be an-ome-nue-sabesailad an-ibe odakmalo, 
\q2 Melle be ese gormalo, na atakbiedba atakdagoed.” 
\ms1 6. NAMAKLEGED-SOGANERGWAD 
\mr (8:5-14) 
\sp Bular-namakleged 
\q1  
\v 5 ¿We doa negsulidganba e-sui-gukingi birikwaa-mai-akas nakwedaniki? 
\sp Sui-nue-sabgulediid namaked 
\q1 Manzana-sapi-urba, an be-odaksad. 
\q2 A-sapi-urbali, be-nan nunmakedgi be-odenoniki gusad. 
\sp Ome-nue-sabgulediid namaked 
\q1  
\v 6 Be-gwagegine an-sedii be gue. 
\q2 Be-swidagine an-wilub narmakar be sedii imake. 
\q1 Ar sabgued-e-ganguedi burgwed-igaryobid, gege dule e-igar gaed. 
\q2 Suibina-soglegedi, sulibinsa emar-imaked. 
\q1 Sabgued-itolegedi, soo-dummad-gwabunyemaiyob itoleged. 
\q2 Bab-Dummad deyob imaksad. 
\q1  
\v 7 We-sabgued-sooyobidi, dii-dummadi gege oginned, 
\q2 diwarmarbela gege we-sabgued obelobalid. 
\q1 Dule-gwensak sabgued-bakega, bela e-ibmar-nikad ukdele, 
\q2 we-dulegi dodoledoed. 
\sp Bular-namakleged 
\q1  
\v 8 Anmar-bun senigwad, 
\q2 amba yoo e-nuu mullugudaged. 
\q1 Dule anmarse nikuega egisdanikile, 
\q2 ¿igi anmar abin sogosunna? 
\q1  
\v 9 Ar galu-matusulidyob-guena, anmar e-birgi nega-dummad-manibiid soboenad. 
\q2 Ar yawagakga-guena anmar urwala-e-urgo egi nasikoenad. 
\sp Ome-nue-sabgulediid namaked 
\q1  
\v 10 An galu-matusulidyob gued, 
\q2 ar an-mam, neg-suigan-warbo-gwichiyob gued. 
\q2 Agala, an-sui-nue-sabesailadga, an gwage-bogidikid uked. 
\b  
\q1  
\v 11 Salomón, Baal-Hamón-yargi nainu-gwensak nikanad, 
\q2 ega akwemalaga, dulemarga manigi-urmaksagusad. 
\q2 E-nainu-sanmaksale, we-dulemar ega war-wargwen mani-sibu-milibo (2,000) senonidamalad. 
\q1  
\v 12 Salomón, mani-milibogwad be sue, 
\q2 bemar-dule-nainu-akwemalad, mani-sibu-dulataled-ilabakegwad (400) be sumarmoga. 
\q2 Ar an-nainudina, unnila angadid. 
\sp Sui-nue-sabgulediid namaked 
\q1  
\v 13 Be, dutugalu-abargi gudiid, 
\q2 anmar-aimar be-sunmaked itobigudimalad. 
\q2 Be-gaya-itogega be anmar-imake. 
\sp Ome-nue-sabgulediid namaked 
\q1  
\v 14 An-sui-nue-sabesailad, gwae be dage. 
\q2 Goe-sapuryob be abarmakdage, 
\q2 yalamar-wawadikid-yapanned-abargi gwae be abarmakdage.