\p
\v 20 \w Era|strong="H1961"\w* incalculable \w el|strong="H3605"\w* \w peso|strong="H4948"\w* del bronce \w de|strong="H8478"\w* las \w dos|strong="H8147"\w* \w columnas|strong="H5982"\w*, \w el|strong="H3605"\w* \w mar|strong="H3220"\w* \w y|strong="H1241"\w* \w los|strong="H3605"\w* 12 \w bueyes|strong="H1241"\w* \w de|strong="H8478"\w* bronce \w que|strong="H3808"\w* sostenían \w el|strong="H3605"\w* \w mar|strong="H3220"\w* \w que|strong="H3808"\w* \w el|strong="H3605"\w* \w rey|strong="H4428"\w* \w Salomón|strong="H8010"\w* \w hizo|strong="H6213"\w* \w para|strong="H4948"\w* \w la|strong="H3605"\w* \w Casa|strong="H1004"\w* \w de|strong="H8478"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.  
