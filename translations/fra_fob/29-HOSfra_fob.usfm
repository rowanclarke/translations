\v 7 Mais \w j|strong="H3068"\w*'\w aurai|strong="H3068"\w* \w pitié|strong="H7355"\w* \w de|strong="H1004"\w* \w la|strong="H3068"\w* \w maison|strong="H1004"\w* \w de|strong="H1004"\w* \w Juda|strong="H3063"\w*; \w je|strong="H3068"\w* \w les|strong="H3068"\w* \w sauverai|strong="H3467"\w* \w par|strong="H3068"\w* l'\w Éternel|strong="H3068"\w* \w leur|strong="H3068"\w* \w Dieu|strong="H3068"\w*, \w et|strong="H3068"\w* \w je|strong="H3068"\w* \w ne|strong="H3808"\w* \w les|strong="H3068"\w* \w sauverai|strong="H3467"\w* \w ni|strong="H3808"\w* \w par|strong="H3068"\w* l'\w arc|strong="H7198"\w*, \w ni|strong="H3808"\w* \w par|strong="H3068"\w* l'\w épée|strong="H2719"\w*, \w ni|strong="H3808"\w* \w par|strong="H3068"\w* \w les|strong="H3068"\w* \w combats|strong="H4421"\w*, \w ni|strong="H3808"\w* \w par|strong="H3068"\w* \w les|strong="H3068"\w* \w chevaux|strong="H5483"\w*, \w ni|strong="H3808"\w* \w par|strong="H3068"\w* \w les|strong="H3068"\w* \w cavaliers|strong="H6571"\w*.  
\v 8 Puis, \w quand|strong="H1121"\w* \w elle|strong="H1121"\w* \w eut|strong="H3205"\w* \w sevré|strong="H1580"\w* Lo-Ruchama, \w elle|strong="H1121"\w* \w conçut|strong="H2029"\w* \w et|strong="H1121"\w* \w enfanta|strong="H3205"\w* \w un|strong="H1121"\w* \w fils|strong="H1121"\w*.  
\v 9 \w Et|strong="H5971"\w* \w l|strong="H5971"\w*'Éternel \w dit|strong="H5971"\w*: Appelle-le \w du|strong="H5971"\w* \w nom|strong="H8034"\w* \w de|strong="H5971"\w* Lo-Ammi (\w pas|strong="H3808"\w* \w mon|strong="H7121"\w* \w peuple|strong="H5971"\w*); \w car|strong="H3588"\w* \w vous|strong="H3808"\w* n'\w êtes|strong="H5971"\w* \w pas|strong="H3808"\w* \w mon|strong="H7121"\w* \w peuple|strong="H5971"\w*, \w et|strong="H5971"\w* \w je|strong="H3588"\w* \w ne|strong="H3808"\w* \w suis|strong="H1961"\w* \w pas|strong="H3808"\w* \w votre|strong="H1961"\w* \w Dieu|strong="H3588"\w*.  
\v 10 Cependant le nombre des enfants d'Israël sera comme le sable de la mer, qui ne peut ni se mesurer, ni se compter; et il arrivera que dans le lieu où il leur est dit: “Vous n'êtes pas mon peuple, “ on leur dira: “Enfants du Dieu vivant! “  
\v 11 Et les enfants de Juda et les enfants d'Israël se réuniront ensemble et s'établiront un chef, et ils remonteront du pays; car la journée de Jizréel sera grande.   
\c 2
\p
\v 1 \w Dites|strong="H3808"\w* \w à|strong="H3478"\w* \w vos|strong="H5971"\w* \w frères|strong="H1121"\w*: \w Ammi|strong="H5971"\w* (\w mon|strong="H1961"\w* \w peuple|strong="H5971"\w*)! \w et|strong="H1121"\w* \w à|strong="H3478"\w* \w vos|strong="H5971"\w* \w sœurs|strong="H1121"\w*: Ruchama (\w dont|strong="H3478"\w* \w on|strong="H5971"\w* \w a|strong="H3068"\w* pitié)!  
\v 2 Plaidez \w contre|strong="H5927"\w* \w votre|strong="H3588"\w* \w mère|strong="H3117"\w*, plaidez! \w Car|strong="H3588"\w* \w elle|strong="H3588"\w* n'\w est|strong="H3117"\w* \w pas|strong="H5927"\w* \w ma|strong="H3117"\w* \w femme|strong="H3117"\w*, \w et|strong="H1121"\w* \w je|strong="H3588"\w* \w ne|strong="H3478"\w* \w suis|strong="H3588"\w* \w point|strong="H7760"\w* \w son|strong="H3117"\w* \w mari|strong="H3117"\w*. \w Qu|strong="H3588"\w*'\w elle|strong="H3588"\w* ôte \w ses|strong="H3117"\w* prostitutions \w de|strong="H1121"\w* \w son|strong="H3117"\w* visage \w et|strong="H1121"\w* \w ses|strong="H3117"\w* adultères \w de|strong="H1121"\w* \w son|strong="H3117"\w* \w sein|strong="H3117"\w*;  
\v 3 \w De|strong="H5971"\w* peur \w que|strong="H5971"\w* \w je|strong="H5971"\w* \w ne|strong="H5971"\w* \w la|strong="H5971"\w* dépouille \w à|strong="H5971"\w* nu, \w et|strong="H5971"\w* \w que|strong="H5971"\w* \w je|strong="H5971"\w* \w ne|strong="H5971"\w* \w la|strong="H5971"\w* mette \w comme|strong="H5971"\w* \w au|strong="H5971"\w* jour \w de|strong="H5971"\w* sa naissance, \w et|strong="H5971"\w* \w que|strong="H5971"\w* \w je|strong="H5971"\w* \w ne|strong="H5971"\w* \w la|strong="H5971"\w* \w rende|strong="H5971"\w* \w semblable|strong="H5971"\w* \w à|strong="H5971"\w* \w un|strong="H5971"\w* désert, \w à|strong="H5971"\w* \w une|strong="H5971"\w* \w terre|strong="H5971"\w* aride, \w et|strong="H5971"\w* \w ne|strong="H5971"\w* \w la|strong="H5971"\w* fasse mourir \w de|strong="H5971"\w* soif;  
\v 4 \w Et|strong="H6440"\w* \w que|strong="H3588"\w* \w je|strong="H3588"\w* n'\w aie|strong="H6440"\w* \w point|strong="H3808"\w* pitié \w de|strong="H6440"\w* \w ses|strong="H6440"\w* \w enfants|strong="H6440"\w*, \w parce|strong="H3808"\w* \w que|strong="H3588"\w* \w ce|strong="H1931"\w* \w sont|strong="H6440"\w* \w des|strong="H6440"\w* \w enfants|strong="H6440"\w* \w de|strong="H6440"\w* \w prostitution|strong="H2183"\w*.  
\v 5 Car \w leur|strong="H3117"\w* \w mère|strong="H3117"\w* s'\w est|strong="H3117"\w* prostituée, \w celle|strong="H3205"\w* \w qui|strong="H3117"\w* \w les|strong="H7760"\w* \w a|strong="H3068"\w* conçus s'\w est|strong="H3117"\w* déshonorée; car \w elle|strong="H3117"\w* \w a|strong="H3068"\w* \w dit|strong="H3117"\w*: “\w J|strong="H3068"\w*'irai \w après|strong="H3205"\w* \w mes|strong="H3117"\w* amants, \w qui|strong="H3117"\w* \w me|strong="H3117"\w* donnent \w mon|strong="H7760"\w* \w pain|strong="H3117"\w* \w et|strong="H3117"\w* \w mon|strong="H7760"\w* eau, \w ma|strong="H3117"\w* laine \w et|strong="H3117"\w* \w mon|strong="H7760"\w* lin, \w mon|strong="H7760"\w* huile \w et|strong="H3117"\w* \w mon|strong="H7760"\w* breuvage. “  
\v 6 C'\w est|strong="H1121"\w* \w pourquoi|strong="H3588"\w*, \w voici|strong="H3588"\w*, \w je|strong="H3588"\w* \w vais|strong="H3588"\w* fermer \w ton|strong="H1121"\w* chemin \w avec|strong="H1121"\w* \w des|strong="H1121"\w* épines. \w J|strong="H3068"\w*'\w y|strong="H1121"\w* élèverai \w un|strong="H1121"\w* mur, tellement \w qu|strong="H3588"\w*'\w elle|strong="H3588"\w* \w ne|strong="H3808"\w* trouvera \w plus|strong="H3808"\w* \w ses|strong="H1121"\w* sentiers.  
\v 7 \w Elle|strong="H3588"\w* poursuivra \w ses|strong="H5414"\w* \w amants|strong="H5414"\w*, \w et|strong="H3212"\w* \w elle|strong="H3588"\w* \w ne|strong="H4325"\w* \w les|strong="H5414"\w* atteindra \w pas|strong="H5414"\w*; \w elle|strong="H3588"\w* \w les|strong="H5414"\w* cherchera, \w mais|strong="H3588"\w* \w elle|strong="H3588"\w* \w ne|strong="H4325"\w* \w les|strong="H5414"\w* trouvera \w point|strong="H5414"\w*. Puis \w elle|strong="H3588"\w* dira: “\w J|strong="H3068"\w*'\w irai|strong="H3212"\w*, \w et|strong="H3212"\w* \w je|strong="H3588"\w* retournerai \w à|strong="H5414"\w* \w mon|strong="H5414"\w* premier \w mari|strong="H5414"\w*; \w car|strong="H3588"\w* \w alors|strong="H5414"\w* j'\w étais|strong="H5414"\w* mieux \w que|strong="H3588"\w* \w je|strong="H3588"\w* \w ne|strong="H4325"\w* \w suis|strong="H3588"\w* \w maintenant|strong="H3588"\w*. “  
\v 8 Or \w elle|strong="H3808"\w* n'\w a|strong="H3068"\w* \w pas|strong="H3808"\w* reconnu \w que|strong="H3808"\w* c'\w était|strong="H1870"\w* \w moi|strong="H3808"\w* \w qui|strong="H1870"\w* \w lui|strong="H3808"\w* \w donnais|strong="H3808"\w* \w le|strong="H4672"\w* froment, \w et|strong="H3808"\w* \w le|strong="H4672"\w* moût, \w et|strong="H3808"\w* l'huile, \w et|strong="H3808"\w* \w qui|strong="H1870"\w* \w lui|strong="H3808"\w* multipliais l'\w argent|strong="H3808"\w* \w et|strong="H3808"\w* l'or, dont \w ils|strong="H3651"\w* \w faisaient|strong="H3808"\w* \w un|strong="H4672"\w* Baal.  
\v 9 C'\w est|strong="H2896"\w* \w pourquoi|strong="H3588"\w* \w je|strong="H3588"\w* \w reprendrai|strong="H7725"\w* \w mon|strong="H3588"\w* froment \w en|strong="H3212"\w* \w son|strong="H7725"\w* \w temps|strong="H7223"\w*, \w et|strong="H3212"\w* \w mon|strong="H3588"\w* moût \w en|strong="H3212"\w* \w sa|strong="H7725"\w* saison, \w et|strong="H3212"\w* j'enlèverai \w ma|strong="H7725"\w* laine \w et|strong="H3212"\w* \w mon|strong="H3588"\w* lin \w qui|strong="H3808"\w* couvraient \w sa|strong="H7725"\w* nudité.  
\v 10 \w Et|strong="H6213"\w* \w je|strong="H3588"\w* découvrirai \w maintenant|strong="H3588"\w* \w sa|strong="H5414"\w* turpitude \w aux|strong="H5414"\w* \w yeux|strong="H5414"\w* \w de|strong="H6213"\w* \w ses|strong="H6213"\w* \w amants|strong="H5414"\w*, \w et|strong="H6213"\w* \w nul|strong="H3588"\w* \w ne|strong="H3808"\w* \w la|strong="H6213"\w* délivrera \w de|strong="H6213"\w* \w ma|strong="H5414"\w* \w main|strong="H7235"\w*.  
\v 11 \w Je|strong="H3068"\w* \w ferai|strong="H7725"\w* cesser \w toute|strong="H7725"\w* \w sa|strong="H7725"\w* joie, \w ses|strong="H3947"\w* \w fêtes|strong="H4150"\w*, \w ses|strong="H3947"\w* nouvelles \w lunes|strong="H4150"\w*, \w ses|strong="H3947"\w* sabbats \w et|strong="H7725"\w* \w toutes|strong="H7725"\w* \w ses|strong="H3947"\w* \w solennités|strong="H4150"\w*.  
\v 12 \w Je|strong="H3068"\w* dévasterai \w ses|strong="H3027"\w* \w vignes|strong="H3027"\w* \w et|strong="H3027"\w* \w ses|strong="H3027"\w* figuiers, \w dont|strong="H5869"\w* \w elle|strong="H3027"\w* \w a|strong="H3068"\w* \w dit|strong="H3808"\w*: “\w Ce|strong="H3808"\w* \w sont|strong="H3027"\w* \w là|strong="H3027"\w* \w mes|strong="H3027"\w* salaires, \w que|strong="H3808"\w* \w mes|strong="H3027"\w* amants m'\w ont|strong="H5869"\w* donnés. “ \w Je|strong="H3068"\w* \w les|strong="H3027"\w* réduirai \w en|strong="H5869"\w* forêt, \w et|strong="H3027"\w* \w les|strong="H3027"\w* bêtes \w des|strong="H3027"\w* champs \w les|strong="H3027"\w* \w dévoreront|strong="H5869"\w*.  
\v 13 \w Et|strong="H2320"\w* \w je|strong="H4150"\w* \w la|strong="H7673"\w* punirai \w pour|strong="H4150"\w* \w les|strong="H3605"\w* jours \w où|strong="H3605"\w* elle offrait \w des|strong="H2282"\w* parfums aux Baals, \w en|strong="H2282"\w* se parant \w de|strong="H3605"\w* \w ses|strong="H3605"\w* bagues \w et|strong="H2320"\w* \w de|strong="H3605"\w* \w ses|strong="H3605"\w* joyaux, \w et|strong="H2320"\w* s'\w en|strong="H2282"\w* allait \w après|strong="H2320"\w* \w ses|strong="H3605"\w* amants, \w et|strong="H2320"\w* m'oubliait, dit l'Éternel.  
\v 14 C'\w est|strong="H2416"\w* pourquoi, voici, \w je|strong="H5414"\w* l'attirerai, \w et|strong="H5414"\w* \w je|strong="H5414"\w* \w la|strong="H5414"\w* \w ferai|strong="H5414"\w* aller \w au|strong="H5414"\w* désert, \w et|strong="H5414"\w* \w je|strong="H5414"\w* parlerai \w à|strong="H5414"\w* \w son|strong="H5414"\w* \w cœur|strong="H7760"\w*.  
\v 15 \w Et|strong="H3068"\w* \w de|strong="H3117"\w* \w là|strong="H3068"\w* \w je|strong="H3117"\w* \w lui|strong="H3068"\w* \w donnerai|strong="H3068"\w* \w ses|strong="H5921"\w* vignes, \w et|strong="H3068"\w* \w la|strong="H3068"\w* \w vallée|strong="H3117"\w* \w d|strong="H1992"\w*'Acor, \w comme|strong="H3068"\w* \w une|strong="H3068"\w* entrée \w d|strong="H1992"\w*'espérance; \w et|strong="H3068"\w* \w elle|strong="H3117"\w* \w y|strong="H3068"\w* chantera \w comme|strong="H3068"\w* \w au|strong="H3068"\w* \w temps|strong="H3117"\w* \w de|strong="H3117"\w* \w sa|strong="H3068"\w* jeunesse, \w comme|strong="H3068"\w* \w au|strong="H3068"\w* \w jour|strong="H3117"\w* \w où|strong="H3117"\w* \w elle|strong="H3117"\w* remonta \w du|strong="H3117"\w* \w pays|strong="H3068"\w* \w d|strong="H1992"\w*'Égypte.  
