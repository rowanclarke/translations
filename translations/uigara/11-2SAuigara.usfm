\id 2SA
\h سامۇئىل «2»
\toc1 سامۇئىل «2»
\toc2 سامۇئىل «2»
\toc3 2سام.
\mt1 سامۇئىل «2»
\c 1
\s1 سائۇل ۋە يوناتان ئۈچۈن ھەسرەت چېكىش
\m 
\v 1 سائۇل ئۆلگەندىن كېيىن، داۋۇت ئامالەكلەرنى قىرغىن قىلىپ يېنىپ كەلگەندە، ئۇ زىكلاگدا ئىككى كۈن تۇردى. \x ◘ \xo 1:1 \xt 1سام. 30‏:17\x*
\v 2 ئۈچىنچى كۈنى شۇنداق بولدىكى، مانا سائۇلنىڭ لەشكەرگاھىدىن كىيىمى يىرتىق ۋە بېشىغا توپا-چاڭ چاچقان بىر ئادەم كەلدى. ئۇ داۋۇتنىڭ قېشىغا كەلگەندە، يەرگە يىقىلىپ باش ئۇردى.
\m 
\v 3 داۋۇت ئۇنىڭدىن: نەدىن كەلدىڭ؟ دەپ سورىدى. ئۇ جاۋاپ بېرىپ: ئىسرائىلنىڭ لەشكەرگاھىدىن قېچىپ كەلدىم ــ دېدى.
\m 
\v 4 داۋۇت ئۇنىڭدىن: ئىش قانداق بولدى؟ ماڭا دەپ بەرگىن، دەپ سورىدى. ئۇ: خەلق جەڭدىن قاچتى، خەلقتىن بەك جىق كىشى سوقۇشتا ئۆلدى. سائۇل بىلەن ئوغلى يوناتانمۇ ئۆلدى، ــ دېدى.
\m 
\v 5 داۋۇت خەۋەر ئېلىپ كەلگەن يىگىتتىن: سائۇل بىلەن ئوغلى يوناتاننىڭ ئۆلگىنىنى قانداق بىلدىڭ؟ ــ دەپ سورىدى.
\m 
\v 6 ئۇنىڭغا خەۋەر بەرگەن يىگىت: مەن تاسادىپىي گىلبوئا تېغىغا چىققانىدىم، مانا سائۇل نەيزىگە يۆلىنىپ تۇرۇپتۇ؛ جەڭ ھارۋىلىرى ۋە ئاتلىقلار ئۇنىڭغا ھۇجۇم قىلىپ ئۇنى قوغلاۋاتاتتى.
\v 7 ئۇ كەينىگە قاراپ مېنى كۆرۈپ چاقىردى. مەن «مانا مەن»، دېدىم.
\m 
\v 8 ئۇ: ئۆزۈڭ كىم بولىسەن، دەپ مەندىن سورىۋىدى، مەن ئامالەكلەردىنمەن، دېدىم.
\m 
\v 9 ئۇ يەنە ماڭا: ئۈستۈمدە تۇرۇپ مېنى ئۆلتۈرۈۋەتكىن؛ گەرچە جېنىم مەندە بولسىمۇ، مەن بەك ئازاپلىنىپ كېتىۋاتىمەن ــ دېدى. \f ◼ \fr 1:9 \ft \bd «مەن بەك ئازاپلىنىپ كېتىۋاتىمەن»\bd* ــ ياكى «مېنىڭ بېشىم ئايلىنىۋاتىدۇ».\f*
\m 
\v 10 شۇڭا مەن ئۇنىڭ ئۈستىدە تۇرۇپ، ئۇنى ئۆلتۈردۈم، چۈنكى، ئۇ شۇ ھالدا يىقىلسىلا، تىرىك قالمايدىغانلىقىنى بىلەتتىم. ئاندىن بېشىدىكى تاجنى ۋە بىلىكىدىكى بىلەزۈكنى ئېلىپ مۇشۇ يەرگە غوجامغا ئېلىپ كەلدىم، ــ دېدى. \f ◼ \fr 1:10 \ft \bd «شۇڭا مەن ئۇنىڭ ئۈستىدە تۇرۇپ، ئۇنى ئۆلتۈردۈم، ... ئاندىن ... تاجنى ۋە ... بىلەزۈكنى ئېلىپ ... غوجامغا ئېلىپ كەلدىم»\bd* ــ «1سام.» 30-بابتىكى تەپسىلاتلارغا قارىغاندا، بۇ يىگىتنىڭ دېگەنلىرىنىڭ ھەممىسى يالغان، داۋۇتتىن مەلۇم ئىنئام ياكى مەرتىۋىگە ئېرىشىش مەقسىتىدە ئېيتقان بولسا كېرەك؛ لېكىن يالغانچىلىقى ئۆزىنىڭ ھاياتىغا زامىن بولىدۇ.\f*
\m 
\v 11 شۇئان داۋۇت ئۆز كىيىملىرىنى يىرتىپ، تىلما-تىلما قىلىۋەتتى؛ ئۇنىڭ بىلەن بولغان بارلىق ئادەملەرمۇ ھەم شۇنداق قىلدى. \x ◘ \xo 1:11 \xt 2سام. 3‏:31؛ 13‏:31\x*
\v 12 ئۇلار سائۇل بىلەن ئوغلى يوناتان ئۈچۈن، پەرۋەردىگارنىڭ خەلقى ئۈچۈن، شۇنداقلا ئىسرائىلنىڭ جەمەتى ئۈچۈن ماتەم تۇتۇپ ئاھ-زار كۆتۈرۈپ كەچكىچە روزا تۇتتى؛ چۈنكى ئۇلار قىلىچ ئاستىدا يىقىلىپ قازا قىلغانىدى.
\m 
\v 13 داۋۇت ئۇنىڭ ئۆزىگە خەۋەر بەرگەن يىگىتتىن: قەيەردىن سەن؟ ــ دەپ سورىدى. ئۇ: مەن بىر ئامالەك مۇساپىرنىڭ ئوغلىمەن ــ دېدى.
\m 
\v 14 داۋۇت ئۇنىڭغا: سەن قانداقمۇ پەرۋەردىگارنىڭ مەسىھ قىلغىنىنى ھالاك قىلىشقا قولۇڭنى سوزۇشتىن قورقمىدىڭ؟ ــ دېدى. \f ◼ \fr 1:14 \ft \bd «پەرۋەردىگارنىڭ مەسىھ قىلغىنى»\bd* ــ خۇدا بېكىتكەن پادىساھ، دېمەكچى. «تەبىرلەر»نى كۆرۈڭ.\f*
\m 
\v 15 ئاندىن داۋۇت ئۆز غۇلاملىرىدىن بىرىنى چاقىرىپ ئۇنىڭغا: بۇياققا كەل، ئۇنىڭغا ئېتىلىپ بېرىپ، ئۇنى ئۆلتۈرگىن ــ دەپ بۇيرۇدى. شۇنىڭ بىلەن ئۇ ئۇنى ئۇرۇۋىدى، \add ئامالەك\add* ئۆلدى.
\m 
\v 16 داۋۇت ئۇنىڭغا: قان قەرزىڭ بېشىڭغا چۈشسۇن! چۈنكى ئۆز ئاغزىڭ پەرۋەردىگارنىڭ مەسىھ قىلغىنىنى ئۆلتۈرگىنىڭگە گۇۋاھلىق بېرىپ ئەيىبلىدى، ــ دېدى.
\m 
\v 17 شۇنىڭ بىلەن داۋۇت سائۇل بىلەن ئوغلى يوناتان ئۈچۈن ماتەم تۇتۇپ مۇنداق بىر نەزمە ئوقۇدى
\v 18 (ئۇ «ئوقيا» دەپ ئاتالغان بۇ نەزمىنى پۈتكۈل يەھۇدا خەلقىگە ئۆگىتىڭلار، دەپ بۇيرۇدى. دەرۋەقە ئۇ «ياشار» دېگەن كىتابتا پۈتۈلگەنىدى): ــ \f ◼ \fr 1:18 \ft \bd «دەرۋەقە ئۇ «ياشار» دېگەن كىتابتا پۈتۈلگەنىدى»\bd* ــ مۇشۇ يەردە «ئۇ» «ئوقيا» دەپ ئاتالغان نەزمىنىڭ ئۆزىنى ياكى داۋۇتنىڭ بۇ نەزمىنى ئۆگەتكەنلىكىنى كۆرسىتىدۇ. «ئوقيا» دېگەن نەزمە بولسا بەلكىم تۆۋەندىكى 19-27-ئايەتتىكى مەرسىيەنى كۆرسىتىشى مۇمكىن. \bd ««ياشار» دېگەن كىتاب»\bd* ــ ھازىر يوقىلىپ كەتكەن قەدىمكى بىر كىتاب («يە.» 12:10-13نى كۆرۈڭ).\f*  \x ◘ \xo 1:18 \xt يە. 10‏:13\x*
\m 
\v 19 ــ ئى ئىسرائىل، سېنىڭ گۈزەل ئەزىزىڭ يۇقىرى جايلىرىڭدا قىرغىن بولۇپ ياتىدۇ!
\m پالۋانلار شۇنداق دەھشەتلىك يىقىلدىغۇ!؟ \f ◼ \fr 1:19 \ft \bd «سېنىڭ گۈزەل ئەزىزىڭ»\bd* ــ ئىبرانىي تىلىدا «سېنىڭ گۈزىلىڭ». بۇ ئىسرائىلنىڭ پەزىلەتلىك قەھرىمانلىرى بولغان سائۇل ۋە يوناتاننى كۆرسىتىدۇ.\f*
\m 
\v 20 گات شەھىرىدە بۇ خەۋەرنى بەرمەڭلار،
\m ئاشكېلوننىڭ كوچىلىرىدا ئۇنى ئېلان قىلماڭلار،
\m فىلىستىيىنىڭ قىزلىرى شادلانمىسۇن،
\m خەتنىسىزلەرنىڭ قىزلىرى تەنتەنە قىلمىسۇن! \x ◘ \xo 1:20 \xt مىك. 1‏:10\x*
\m 
\v 21 ئى گىلبوئا تاغلىرى، ئۈستۈڭلارغا نە شەبنەم بولمىسۇن، نە يامغۇر چۈشمىسۇن،
\m نە سىلەردە كۆتۈرمە ھەدىيەلەر ئۈچۈن ھوسۇل بېرىدىغان ئېتىزلار يەنە كۆرۈنمىسۇن!
\m چۈنكى ئۇ يەردە پالۋانلارنىڭ قالقىنى بۇلغاندى؛
\m سائۇلنىڭ قالقىنى ياغ بىلەن سۈرۈلمەيدىغان بولدى. \f ◼ \fr 1:21 \ft \bd «ئى گىلبوئا تاغلىرى، ئۈستۈڭلارغا نە شەبنەم بولمىسۇن، نە يامغۇر چۈشمىسۇن،... ھوسۇل بېرىدىغان ئېتىزلار يەنە كۆرۈنمىسۇن!»\bd* ــ سائۇل ۋە يوناتان گىلبوئا تاغلىرى ئۈستىدە يىقىلىپ ئۆلگەنىدى. \bd «پالۋانلارنىڭ قالقىنى بۇلغاندى»\bd* ــ ياكى «پالۋانلارنىڭ قالقىنى ھاقارەت قىلىندى» ياكى «پالۋانلارنىڭ قالقىنى لەنەتلىك نەرسىدەك تاشلاندى». \bd «سائۇلنىڭ قالقىنى ياغ بىلەن سۈرۈلمەيدىغان»\bd* ــ كونا زامانلاردا جەڭچىلەر قالقاننىڭ تېرىسى (قالقاننىڭ بىر قىسمىغا تېرە ئىشلىتەتتى) قۇرۇپ يېرىلىپ كەتمىسۇن دەپ، قالقانلارغا ماي سۈرەتتى. مۇشۇ يەردە «سۈرۈش» ئىبرانىي تىلىدا «مەسىھ قىلىش» بىلەن ئىپادىلىنىدۇ.\f*
\m 
\v 22 قىرىلىدىغانلارنىڭ قېنىنى تۆكمەي،
\m پالۋانلارنىڭ تېنىدىكى يېغىنى چاپماي،
\m يوناتاننىڭ ئوقياسى ھېچقاچان \add جەڭدىن\add* يانغان ئەمەس،
\m سائۇلنىڭ قىلىچى ھېچقاچان قىنىغا قايتقان ئەمەس.
\m 
\v 23 سائۇل بىلەن يوناتان ھايات ۋاقتىدا سۆيۈملۈك ھەم يېقىملىق ئىدى،
\m ئۇلار ئۆلۈمىدىمۇ بىر-بىرىدىن ئايرىلمىدى؛
\m ئۇلار بۈركۈتلەردىن چاققان، شىرلاردىن كۈچلۈك ئىدى.
\m 
\v 24 ئى ئىسرائىل قىزلىرى، سائۇل ئۈچۈن يىغلاڭلار،
\m ئۇ سىلەرنى بېزەپ قىزغۇچ كىيىملەرنى كىيدۈرۈپ،
\m كىيىملىرىڭلارنى ئالتۇن زىبۇ-زىننەت بىلەن زىننەتلىگەنىدى. \f ◼ \fr 1:24 \ft \bd «ئۇ سىلەرنى بېزەپ قىزغۇچ كىيىملەرنى كىيدۈرۈپ...»\bd* ــ قىزىل ياكى قىزغۇچ رەخت ئىنتايىن قىممەتلىك ئىدى.\f*
\m 
\v 25 پالۋانلار كەسكىن جەڭدە شۇنداق دەھشەتلىك يىقىلدىغۇ!؟
\m يوناتان يۇقىرى جايلىرىڭدا قىرغىن بولۇپ ياتىدۇ!
\m 
\v 26 سەن ئۈچۈن ھەسرەتتە قالدىم، ئى ئىنىم يوناتان! ماڭا شۇنچە سۆيۈملۈك ئىدىڭ!
\m ماڭا بولغان مۇھەببىتىڭ قالتىس ئىدى،
\m ھەتتا قىز-ئاياللارنىڭ مۇھەببىتىدىن ئارتۇق ئىدى. \f ◼ \fr 1:26 \ft \bd «ماڭا بولغان مۇھەببىتىڭ قالتىس ئىدى»\bd* ــ «قالتىس» ياكى «كارامەت» دېگەن بۇ سۆز ئىبرانىي تىلىدا ئادەتتە خۇداغا خاس بولغان خۇسۇسىيەتلەرنى كۆرسىتىدۇ.\f*
\m 
\v 27 پالۋانلار شۇنداق دەھشەتلىك يىقىلدىغۇ!
\m جەڭ قوراللىرى شۇنداق دەھشەتلىك ۋەيران قىلىندىغۇ!»
\b
\b
\c 2
\s1 داۋۇت مەسىھ قىلىنىپ پادىشاھ بولىدۇ
\m 
\v 1 ئاندىن كېيىن داۋۇت پەرۋەردىگاردىن يول سوراپ: يەھۇدا شەھەرلىرىنىڭ بىرىگە چىقايمۇ؟ دېدى؛ پەرۋەردىگار ئۇنىڭغا: ــ چىققىن، دېدى. داۋۇت، نەگە چىقاي؟ ــ دەپ سورىۋىدى، ئۇ: ھېبرونغا چىققىن ــ دېدى.
\m 
\v 2 شۇنىڭ بىلەن داۋۇت ئىككى ئايالى بىلەن، يەنى يىزرەئەللىك ئاھىنوئام ۋە ئەسلى كارمەللىك نابالنىڭ ئايالى بولغان ئابىگائىل بىلەن ئۇ يەرگە چىقتى.
\v 3 داۋۇت ئۇنىڭ بىلەن بىرگە بولغان ئادەملەرنىڭ ھەربىرىنى ھەم ئۇلارنىڭ ھەربىرى ئۆز ئۆيىدىكىلەرنى ئۇ يەرگە ئېلىپ چىقتى؛ ئۇلار ھېبروننىڭ شەھەرلىرىدە ئولتۇراقلاشتى.
\v 4 يەھۇدانىڭ ئادەملىرىمۇ ئۇ يەرگە كېلىپ داۋۇتنى يەھۇدا جەمەتىگە پادىشاھ بولۇشقا مەسىھ قىلدى. داۋۇتقا سائۇلنى دەپنە قىلغانلار يابەش-گىلېئادتىكىلەر، دەپ خەۋەر بېرىلدى؛
\v 5 داۋۇت يابەش-گىلېئادتىكىلەرگە ئەلچىلەر ئەۋەتىپ ئۇلارغا: ــ «غوجاڭلار بولغان سائۇلغا شۇنداق ياخشىلىق قىلىپ، ئۇنى دەپنە قىلغىنىڭلار ئۈچۈن پەرۋەردىگار سىلەرگە بەخت-بەرىكەت ئاتا قىلغاي.
\v 6 پەرۋەردىگار سىلەرگىمۇ مېھرىبانلىق ۋە ئۆز ۋاپالىقىنى كۆرسەتكەي؛ سىلەر بۇنداق قىلغىنىڭلار ئۈچۈن مەنمۇ بۇ ياخشىلىقىڭلارنى سىلەرگە قايتۇرىمەن.
\v 7 ئەمدى ھازىر غەيرەتلىك بولۇڭلار؛ چۈنكى غوجاڭلار سائۇل ئۆلدى، يەھۇدا جەمەتى مېنى مەسىھ قىلىپ، ئۆزلىرىگە پادىشاھ قىلدى» ــ دەپ خەۋەر يەتكۈزدى.
\b
\s1 داۋۇتنىڭ قوشۇنى سائۇلنىڭ قوشۇنى بىلەن سوقۇشىدۇ
\m 
\v 8 ئەمما سائۇلنىڭ قوشۇنىنىڭ سەردارى نەرنىڭ ئوغلى ئابنەر سائۇلنىڭ ئۇغلى ئىشبوشەتنى ماھانائىمغا ئېلىپ بېرىپ،
\v 9 ئۇنى گىلېئادقا، گەشۇرىيلارغا، يىزرەئەلگە، ئەفرائىمغا، بىنيامىنغا ۋە شۇنداقلا پۈتكۈل ئىسرائىلغا پادىشاھ قىلدى. \f ◼ \fr 2:9 \ft \bd «گەشۇرىيلارغا»\bd* ــ ياكى «ئاشۇرلار (ئاسۇرىيەلىكلەر)». \bd «...پۈتكۈل ئىسرائىلغا پادىشاھ قىلدى»\bd* ــ مۇشۇ يەردە «پۈتكۈل ئىسرائىل» ئاساسەن ئىسرائىلنىڭ شىمالىي ۋە شەرقىي تەرەپلىرى، يەنى ئون بىر قەبىلىنى كۆرسىتىدۇ. داۋۇت بولسا يەھۇدا قەبىلىسىگە پادىشاھ بولدى.\f*
\v 10 سائۇلنىڭ ئوغلى ئىشبوشەت پادىشاھ بولغاندا قىرىق ياشقا كىرگەنىدى. ئۇ ئىسرائىلنىڭ ئۈستىدە ئىككى يىل سەلتەنەت قىلدى. ھالبۇكى، يەھۇدا جەمەتى داۋۇتقا ئەگىشەتتى.
\v 11 داۋۇتنىڭ ھېبروندا يەھۇدا جەمەتى ئۈستىدە سەلتەنەت قىلغان ۋاقتى يەتتە يىل ئالتە ئاي بولدى. \x ◘ \xo 2:11 \xt 2سام. 5‏:5؛ 1پاد. 2‏:11\x*
\m 
\v 12 \add بىر كۈنى\add* نەرنىڭ ئوغلى ئابنەر سائۇلنىڭ ئوغلى ئىشبوشەتنىڭ ئادەملىرى بىلەن ماھانائىمدىن چىقىپ گىبېئونغا باردى. \f ◼ \fr 2:12 \ft \bd «ئىشبوشەتنىڭ ئادەملىرى»\bd* ــ ئىبرانىي تىلىدا «ئىشبوشەتنىڭ خىزمەتكارلىرى» ــ مۇشۇ يەردە شۈبھىسىزكى، ئەسكەرلىرىنى كۆرسىتىدۇ.\f*
\v 13 شۇ چاغدا زەرۇئىيانىڭ ئوغلى يوئاب بىلەن داۋۇتنىڭ ئادەملىرى چىقىپ ئۇلار بىلەن گىبېئوندىكى كۆلنىڭ يېنىدا ئۇچراشتى. ئۇلاردىن بىر تەرەپ كۆلنىڭ ئۇ يېقىدا، يەنە بىر تەرەپ كۆلنىڭ بۇ يېقىدا ئولتۇردى.
\v 14 ئابنەر يوئابقا: يىگىتلەر قوپۇپ ئالدىمىزدا ئېلىشىپ ئوينىسۇن ــ دېدى. يوئاب: قوپسۇن ــ دېدى. \f ◼ \fr 2:14 \ft \bd «يىگىتلەر قوپۇپ ئالدىمىزدا ئېلىشىپ ئوينىسۇن»\bd* ــ ئەمەلىيەتتە بولسا بۇ «ئويۇن» ئەمەس، بەلكى مۇسابىقە خاراكتېرىدىكى سوقۇشۇش. ئىككى تەرەپتىن بەلگىلەنگەن ئادەملەر ئوتتۇرىغا چىقىدۇ، بىر تەرەپ قارشى تەرەپنىڭ ئادىمىنى پۈتۈنلەي ياتقۇزۇۋەتسە، شۇ تەرەپ غەلىبە قىلغان بولۇپ «ئويۇن» ئاخىرلىشىدۇ. لېكىن بۇ قېتىم بىر تەرەپ ئېنىق غەلىبە قىلمىغان بولغاچقا، «ئويۇن» ئاخىر بېرىپ ئىككى قوشۇننىڭ چوڭ سوقۇشىغا ئايلاندى.\f*
\m 
\v 15 ئۇلار بېكىتىلگەن سان بويىچە بىنيامىن بىلەن سائۇلنىڭ ئوغلى ئىشبوشەت تەرەپتىن ئون ئىككى كىشى ۋە داۋۇتنىڭ ئادەملىرىدىن ئون ئىككى كىشى چىقىپ ئوتتۇرىغا ئۆتتى.
\v 16 ئۇلار بىر-بىرىنىڭ بېشىنى قاماللاپ تۇتۇپ ھەربىرى رەقىبىنىڭ بىقىنىغا قىلىچى بىلەن سانجىشتى، ھەممىسى يىقىلىپ ئۆلدى. شۇنىڭ بىلەن ئۇ يەر «قىلىچ بىسلىرىنىڭ ئېتىزى» دەپ ئاتالدى؛ ئۇ گىبېئوندىدۇر. \f ◼ \fr 2:16 \ft \bd «قىلىچ بىسلىرىنىڭ ئېتىزى»\bd* ــ ياكى «چاقماق تاشلىرى ئېتىزى». ئىبرانىي تىلىدا: «ھەلقۇت-ھاززۇرىم».\f*
\m 
\v 17 ئۇ كۈندىكى بولغان سوقۇشۇش ئىنتايىن ئەشەددىي بولدى؛ ئابنەر بىلەن ئىسرائىلنىڭ ئادەملىرى داۋۇتنىڭ ئادەملىرى تەرىپىدىن مەغلۇپ قىلىندى.
\m 
\v 18 شۇ يەردە زەرۇئىيانىڭ ئوغۇللىرى يوئاب، ئابىشاي ۋە ئاساھەل دېگەن ئۈچەيلەن بار ئىدى. ئاساھەل خۇددى دالادىكى جەرەندەك چاققان ئىدى.
\v 19 ئاساھەل ئابنەرنىڭ كەيىدىن قوغلاپ يۈگۈردى؛ ئابنەرگە ئەگىشىپ ئوڭغا ياكى سولغا بۇرۇلماي تاپ بېسىپ قوغلىدى.
\v 20 ئابنەر كەينىگە قاراپ: سەن ئاساھەلمۇسەن؟ ــ دەپ سورىدى. ئۇ: ــ شۇنداق، مەن شۇ، دەپ جاۋاب بەردى.
\m 
\v 21 ئابنەر ئۇنىڭغا: يا ئوڭغا يا سولغا بۇرۇلۇپ يىگىتلەرنىڭ بىرىگە ھۇجۇم قىلىپ ئۇنىڭ يارىغىنى ئۆزۈڭگە تارتىۋالغىن، دېدى. لېكىن ئاساھەل ئۇنى قوغلاشتىن بۇرۇلۇشقا ئۇنىمىدى.
\m 
\v 22 ئابنەر ئاساھەلگە يەنە: مېنى ئەمدى قوغلىماي بۇرۇلۇپ كەتكىن؛ مەن سېنى نېمە دەپ ئۇرۇپ يىقىتقۇدەكمەن؟ ئۇنداق قىلسام ئاكاڭ يوئابنىڭ ئالدىدا قانداقمۇ يۈزۈمنى كۆتۈرۈلەيمەن؟ ــ دېدى. \f ◼ \fr 2:22 \ft \bd «مەن سېنى نېمە دەپ ئۇرۇپ يىقىتقۇدەكمەن»\bd* ــ مۇشۇ يەردە «ئۇرۇپ يىقىتىش» ئۆلتۈرۈشنى بىلدۈرىدۇ.\f*
\m 
\v 23 لېكىن ئاساھەل يەنىلا قوغلاشتىن توختىمىدى؛ شۇنىڭ بىلەن ئابنەر نەيزىسىنىڭ تۇتقۇچىنى ئۇنىڭ قورسىقىغا تىقىۋەتتى. نەيزە دۈمبىسىنى تىشىپ چىقتى؛ ئۇ شۇ يەردە يىقىلىپ ئۆلدى. شۇنداق بولدىكى، ئاساھەل يىقىلىپ ئۆلگەن يەرگە ھازىر كېلىدىغان ھەربىر كىشىلەر ئۇ يەردە توختاپ قالىدۇ. \f ◼ \fr 2:23 \ft \bd «ئاساھەل ... ئۆلگەن يەرگە ھازىر كېلىدىغان ھەربىر كىشىلەر ئۇ يەردە توختاپ قالىدۇ»\bd* ــ دېمەك، ئاساھەلنىڭ ھۆرمىتى ئۈچۈن توختايدۇ. باشقا بىرخىل تەرجىمىسى: «ئاساھەل يىقىلىپ ئۆلگەن يەرگە كەلگەن ھەربىر كىشىلەر ئۇ يەردە توختاپ قالدى».\f*
\m 
\v 24 شۇنىڭ بىلەن يوئاب بىلەن ئابىشاي ئابنەرنى قوغلاشتى. كۈن پاتقاندا ئۇلار گىبېئوننىڭ چۆلىگە ماڭىدىغان يولنىڭ بويىغا، گىئاھ يېزىسىنىڭ ئۇدۇلىدىكى ئامماھ ئېدىرلىقىغا يېتىپ كەلدى؛
\v 25 بىنيامىنلار بولسا ئابنەرنىڭ كەينىدە قوشۇندەك سەپ بولۇپ، بىر دۆڭ تۆپىسىگە چىقىپ تۇردى.
\v 26 ئابنەر يوئابنى چاقىرىپ: قىلىچ دائىم ئادەملەرنى يەپ تۇرۇشى كېرەكمۇ؟ بۇ ئىشلارنىڭ ئاقىۋىتى پەقەت ئۆچ-ئاداۋەتتىن ئىبارەت بولىدىغانلىقىنى بىلمەمسەن؟ سەن قاچانغىچە خەلقلەرگە: «قېرىنداشلىرىڭلارنى قوغلاشتىن توختاڭلار» دەپ بۇيرۇماي تۇرۇۋېرىسەن؟
\m 
\v 27 يوئاب: خۇدانىڭ ھاياتى بىلەن قەسەم قىلىمەنكى، ئەگەر سەن مۇشۇ سۆزنى قىلمىغان بولساڭ، كۆپچىلىكنىڭ ھېچبىرى قېرىنداشلىرىنى قوغلاشتىن ئەتىگەنگىچىمۇ يانمايتتى ــ دېدى.
\m 
\v 28 بۇنىڭ بىلەن يوئاب كاناي چالدى؛ ھەممە \add يەھۇدالار\add* شۇئان توختىدى ۋە قايتا ئىسرائىلنى قوغلىمىدى، ئۇلار بىلەن قايتا جەڭ قىلىشمىدى.
\v 29 ئابنەر بىلەن ئادەملىرى بولسا كېچىچە مېڭىپ، ئاراباھ تۈزلەڭلىكىدىن چىقىپ، ئىئوردان دەرياسىدىن ئۆتۈپ بىترون دېگەن پۈتكۈل يۇرتنى كېزىپ ئۆتۈپ، ماھانايىمغا يېتىپ كەلدى.
\m 
\v 30 يوئاب ئابنەرنى قوغلاشتىن يېنىپ بارلىق ئادەملەرنى جەم قىلدى. ئاساھەلدىن باشقا داۋۇتنىڭ غۇلاملىرىدىن ئون توققۇز ئادەم يوق چىقتى؛
\v 31 لېكىن داۋۇتنىڭ ئادەملىرى بىنيامىنلاردىن ۋە ئابنەرنىڭ ئادەملىرىدىن ئۈچ يۈز ئاتمىش كىشىنى ئۇرۇپ ئۆلتۈرگەنىدى.
\m 
\v 32 ئۇلار ئاساھەلنى ئېلىپ بەيت-لەھەمدە ئۆز ئاتىسىنىڭ قەبرىسىدە دەپنە قىلدى؛ ئاندىن يوئاب بىلەن ئادەملىرى كېچىچە مېڭىپ، تاڭ ئاتقاندا ھېبرونغا يېتىپ كەلدى.
\b
\b
\c 3
\m 
\v 1 ھالبۇكى، سائۇلنىڭ جەمەتى بىلەن داۋۇتنىڭ جەمەتى ئوتتۇرسىدىكى جەڭ ئۇزۇن ۋاقىتقىچە داۋاملاشتى؛ داۋۇتنىڭ جەمەتى بارغانسېرى كۈچەيدى، لېكىن سائۇلنىڭ جەمەتى بارغانسېرى ئاجىزلاشماقتا ئىدى.
\m 
\v 2 ھېبروندا داۋۇت بىر قانچە ئوغۇللۇق بولدى، ئۇنىڭ تۇنجىسى ئامنون بولۇپ، يىزرەئەللىك ئاھىنوئامدىن تۇغۇلدى؛ \x ◘ \xo 3:2 \xt 1تار. 3‏:1-9\x*
\v 3 ئىككىنچىسى كىلېئاب بولۇپ كارمەللىك نابالنىڭ ئايالى بولغان ئابىگائىلدىن تۇغۇلدى. ئۈچىنچىسى ئابشالوم ئىدى. ئۇ گەشورنىڭ پادىشاھى تالماينىڭ قىزى مائاكاھدىن تۇغۇلغانىدى،
\v 4 تۆتىنچىسى ئادونىيا بولۇپ ھاگگىتتىن تۇغۇلغان ئىدى. بەشىنچىسى شەفاتىيا بولۇپ ئابىتالدىن تۇغۇلغان ئىدى.
\v 5 ئالتىنچىسى يىترىئام بولۇپ داۋۇتنىڭ ئايالى ئەگلاھدىن تۇغۇلدى. داۋۇتنىڭ بۇ ئالتە ئوغلىنىڭ ھەممىسى ھېبروندا تۇغۇلدى.
\m 
\v 6 سائۇلنىڭ جەمەتى بىلەن داۋۇتنىڭ جەمەتى ئوتتۇرىسىدىكى جەڭ داۋامىدا، ئابنەر سائۇلنىڭ جەمەتىدە ئۆز ھوقۇقىنى كۈچەيتتى.
\v 7 ئەمدى سائۇلنىڭ بىر كېنىزىكى بار ئىدى؛ ئۇ ئاياھنىڭ قىزى بولۇپ، ئىسمى رىزپاھ ئىدى. بىر كۈنى ئىشبوشەت ئابنەرگە: نېمىشقا ئاتامنىڭ كېنىزىكى بىلەن بىللە بولدۇڭ؟ ــ دېدى. \x ◘ \xo 3:7 \xt 2سام. 21‏:8، 10، 11\x*
\m 
\v 8 ئابنەر ئىشبوشەتنىڭ بۇ سۆزلىرىگە ئىنتايىن ئاچچىقلىنىپ مۇنداق دېدى: ــ «مەن بۈگۈنكى كۈندىمۇ ئاتاڭ سائۇلنىڭ جەمەتىگە، ئۇنىڭ ئۇرۇق-تۇغقانلىرىغا ۋە دوستلىرىغا مېھرىبانلىق كۆرسىتىپ، سېنى داۋۇتنىڭ قولىغا تاپشۇرمىغان تۇرسام، مېنى يەھۇداغا تەۋە بىر ئىتىنىڭ بېشىدەك كۆرۈپ، بۈگۈن بۇ خوتۇن ئۈچۈن مېنى گۇناھقا بۇيرۇماقچىمۇسەن؟ \f ◼ \fr 3:8 \ft \bd «سائۇلنىڭ ... ئۇرۇق-تۇغقانلىرىغا...»\bd* ــ ئىبرانىي تىلىدا «سائۇلنىڭ... قېرىنداشلىرىغا».\f*
\v 9 مەن پەرۋەردىگارنىڭ داۋۇتقا قەسەم بىلەن ۋەدە قىلغىنىدەك قىلمىسام خۇدا مەنكى ئابنەرنى قاتتىق ئۇرسۇن ۋە ئۇنىڭدىن ئارتۇق ئۇرسۇن! \f ◼ \fr 3:9 \ft \bd «خۇدا مەنكى ئابنەرنى قاتتىق ئۇرسۇن ۋە ئۇنىڭدىن ئارتۇق ئۇرسۇن!»\bd* ــ ئىبرانىي تىلىدا «خۇدا ئابنەرنىڭ بېشىغا مۇنداق ئىش چۈشۈرسۇن ياكى تېخىمۇ ئېغىر ئىش چۈشۈرسۇن».\f*
\v 10 ــ يەنى، پادىشاھلىقنى سائۇلنىڭ جەمەتىدىن يۆتكەپ، داۋۇتنىڭ تەختىنى داندىن بەئەر-شېباغىچە پۈتكۈل ئىسرائىل بىلەن يەھۇدانىڭ ئۈستىگە تىكلىمىسەم!». \f ◼ \fr 3:10 \ft \bd «داندىن بەئەر-شېباغىچە»\bd* ــ «دان» ئىسرائىلنىڭ ئەڭ شىمالىي يۇرتى، «بەئەر-شېبا» يەھۇدانىڭ ئەڭ جەنۇبىدىكى جاي ئىدى.\f*
\m 
\v 11 ئىشبوشەت ئابنەردىن قورقۇپ، ئۇنىڭغا جاۋابەن بىر ئېغىز سۆز قىلىشقىمۇ جۈرئەت قىلالمىدى.
\m 
\v 12 ئابنەر بولسا ئۆزى ئۈچۈن ئەلچىلەرنى داۋۇتنىڭ قېشىغا ماڭدۇرۇپ ئۇنىڭغا: زېمىن كىمنىڭكى؟ مەن بىلەن ئەھدە تۈزگىن، مېنىڭ قولۇم سېنىڭ تەرىپىڭدە بولۇپ، پۈتكۈل ئىسرائىلنى ساڭا مايىل قىلىمەن ــ دېدى. \f ◼ \fr 3:12 \ft \bd «ئابنەر بولسا ئۆزى ئۈچۈن ئەلچىلەرنى داۋۇتنىڭ قېشىغا ماڭدۇرۇپ ئۇنىڭغا....»\bd* ــ مۇشۇ يەردە «ئۆزى ئۈچۈن» دېگەننىڭ ئىبرانىي تىلىدا ئۈچ خىل چۈشەنچىسى بار: ــ (1) «ئابنەرنىڭ ئۆزى ئۈچۈن» ( ئىشبوشەت بىلمىگەن ھالدا)؛ (2) «ئۇنىڭ ئۈچۈن» (يەنى ئىشبوشەت ئۈچۈن)؛ (3) «نەق مەيداندا». بىز بىرىنچى تەرجىمىگە مايىلمىز.\f*
\m 
\v 13 داۋۇت جاۋاب بېرىپ: ــ بولىدۇ، مەن سەن بىلەن ئەھدە قىلاي. پەقەت بىرلا ئىشنى تەلەپ قىلاي؛ مېنىڭ قېشىمغا كەلگەندە سائۇلنىڭ قىزى مىقالنى ئېلىپ كەلمىسەڭ، يۈزۈمنى كۆرەلمەيسەن، دېدى.
\m 
\v 14 ئاندىن داۋۇت ئىشبوشەتنىڭ قېشىغا ئەلچىلەرنى ماڭدۇرۇپ: مەن بىر يۈز فىلىستىينىڭ خەتنىلىكى بەدىلى بىلەن ئالغان ئايالىم مىقالنى ماڭا قايتۇرۇپ بەرگىن ــ دېدى. \f ◼ \fr 3:14 \ft \bd «مەن بىر يۈز فىلىستىينىڭ خەتنىلىكى بەدىلى بىلەن ئالغان ئايالىم مىقالنى ماڭا قايتۇرۇپ بەرگىن»\bd* ــ مۇشۇ ئىش توغرۇلۇق «1سام.»20:18-27نى كۆرۈڭ.\f*  \x ◘ \xo 3:14 \xt 1سام. 18‏:25، 27\x*
\m 
\v 15 ئىشبوشەت ئادەم ئەۋەتىپ مىقالنى ئۇنىڭ ئېرىدىن، يەنى لائىشنىڭ ئوغلى پالتىيەلدىن ئېلىپ كەلدى. \f ◼ \fr 3:15 \ft \bd «لائىشنىڭ ئوغلى پالتىيەل»\bd* ــ «1سام.» 44:25دە «لائىشنىڭ ئوغلى فالتى» ياكى «لائىشنىڭ ئوغلى پالتى» دەپ ئاتىلىدۇ.\f*  \x ◘ \xo 3:15 \xt 1سام. 25‏:44\x*
\v 16 لېكىن ئۇنىڭ ئېرى باخۇرىمغىچە ئۇنىڭ كەينىدىن يىغلىغان پېتى ئەگىشىپ ماڭدى. ئاخىر بېرىپ ئابنەر ئۇنىڭغا: ــ يېنىپ كەتكىن، دېۋىدى، ئۇ قايتىپ كەتتى.
\m 
\v 17 ئەمدى ئابنەر ئىسرائىلنىڭ ئاقساقاللىرىغا: سىلەر بۇرۇن داۋۇت ئۈستىمىزگە پادىشاھ بولسۇن، دېگەن ئارزۇ-ئىستەكتە بولدۇڭلار.
\v 18 ئەمدى ھازىر ھەرىكەت قىلىڭلار؛ چۈنكى پەرۋەردىگار داۋۇت توغرىسىدا: ــ قۇل-بەندەم داۋۇتنىڭ قولى بىلەن ئىسرائىل خەلقىمنى فىلىستىيلەرنىڭ قولىدىن، شۇنداقلا بارلىق دۈشمەنلىرىنىڭ قولىدىن قۇتقۇزىمەن، ــ دېگەنىدى، دېدى.
\m 
\v 19 ئابنەر يەنە بىنيامىنلارنىڭ قۇلىقىغىمۇ مۇشۇ سۆزلەرنى ئېيتتى. ئاندىن ئىسرائىل بىلەن بىنيامىننىڭ پۈتكۈل جەمەتىنىڭ ئارزۇ-ئىستەكلىرىنى داۋۇتنىڭ قۇلىقىغا ئېيتىشقا ھېبرونغا باردى.
\v 20 شۇنداق قىلىپ ئابنەر يىگىرمە ئادەمنىڭ ھەمراھلىقىدا ھېبرونغا داۋۇتنىڭ قېشىغا كەلگەندە داۋۇت ئابنەر ۋە ئۇنىڭ ئادەملىرىگە بىر زىياپەت تەييارلىدى.
\v 21 ئابنەر داۋۇتقا: مەن قوزغىلىپ پۈتكۈل ئىسرائىلنى غوجام پادىشاھنىڭ ئالدىغا جەم قىلاي، ئۇلار سېنىڭ بىلەن ئەھدە قىلىشسۇن، ئاندىن سەن ئۆز كۆڭلۈڭ خالىغاننىڭ بارلىقى ئۈستىدىن سەلتەنەت قىلالايدىغان بولىسەن، دېدى. شۇنىڭ بىلەن داۋۇت ئابنەرنى يولغا سېلىپ قويدى، ئۇ ئامان-ئېسەن قايتىپ كەتتى. \f ◼ \fr 3:21 \ft \bd «مەن قوزغىلىپ پۈتكۈل ئىسرائىلنى غوجام پادىشاھنىڭ ئالدىغا جەم قىلاي...»\bd* ــ ياكى «مەن ھازىر چىقىپ پۈتكۈل ئىسرائىلنى غوجام پادىشاھنىڭ ئالدىغا جەم قىلاي...» ياكى «مەن ئورنۇمدىن تۇرۇپ غوجام پادىشاھنىڭ ئالدىغا جەم قىلاي...».\f*
\b
\s1 ئابنەر ئۆلتۈرۈلىدۇ
\m 
\v 22 مانا، شۇ ئەسنادا داۋۇتنىڭ ئادەملىرى بىلەن يوئاب بىر يەرگە ھۇجۇم قىلىپ نۇرغۇن ئولجا ئېلىپ قايتىپ كەلدى. لېكىن ئابنەر شۇ چاغدا ھېبروندا داۋۇتنىڭ قېشىدا يوق ئىدى؛ چۈنكى داۋۇتنىڭ ئۇزىتىپ قويۇشى بىلەن ئامان-ئېسەن قايتىپ كەتكەنىدى.
\v 23 يوئاب ۋە ئۇنىڭ بىلەن بولغان پۈتكۈل قوشۇن يېتىپ كەلگەندە، خەلق ئۇنىڭغا: نەرنىڭ ئوغلى ئابنەر پادىشاھنىڭ قېشىغا كەلدى، پادىشاھ ئۇنى يولغا سېلىپ قويۇشى بىلەن ئۇ ئامان-ئېسەن قايتىپ كەتتى ــ دېدى.
\m 
\v 24 ئاندىن يوئاب پادىشاھنىڭ قېشىغا بېرىپ: بۇ سېنىڭ نېمە قىلغىنىڭ؟! مانا، ئابنەر قېشىڭغا كەپتۇ! نېمىشقا ئۇنى يولغا سېلىپ قويدۇڭ؟ ئۇ ھازىر كېتىپتۇ!
\v 25 سەن نەرنىڭ ئوغلى ئابنەرنى بىلىسەنغۇ! ئۇنىڭ كېلىشى جەزمەن سېنى ئالداش ئۈچۈن، سېنىڭ چىقىپ-كىرىدىغان يولۇڭنى، شۇنداقلا بارلىق ئىش-پائالىيىتىڭنى بىلىۋېلىش ئۈچۈندۇر، ــ دېدى.
\m 
\v 26 يوئاب داۋۇتنىڭ قېشىدىن چىقىشى بىلەن ئۇ خەۋەرچىلەرنى ئابنەرنىڭ كەينىدىن ماڭدۇردى. ئۇلار ئۇنى سىراھ قۇدۇقىنىڭ يېنىدىن ياندۇرۇپ ئېلىپ كەلدى؛ لېكىن داۋۇت بۇ ئىشتىن بىخەۋەر ئىدى.
\v 27 ئابنەر ھېبرونغا يېنىپ كەلگەندە يوئاب ئۇنى شەھەر قوۋۇقىدا ئۇچرىتىپ، «ساڭا دەيدىغان مەخپىي سۆزۈم بار ئىدى» دەپ ئۇنى بىر چەتكە ئەكىلىپ ئۇ يەردە ئىنىسى ئاساھەلنىڭ قان قىساسىنى ئېلىش ئۈچۈن قورسىقىغا پىچاق سالدى، شۇنىڭ بىلەن ئۇ ئۆلدى. \x ◘ \xo 3:27 \xt 2سام. 2‏:23؛ 1پاد. 2‏:5\x*
\m 
\v 28 كېيىن، داۋۇت بۇ ئىشنى ئاڭلاپ: مەن ۋە پادىشاھلىقىم پەرۋەردىگارنىڭ ئالدىدا نەرنىڭ ئوغلى ئابنەرنىڭ ئاققان قېنى ئۈچۈن مەڭگۈ بىگۇناھدۇرمىز؛
\v 29 \add ئۇنىڭ قېنىنى ئاققۇزۇش\add* گۇناھى يوئابنىڭ بېشىغا ۋە ئاتىسىنىڭ جەمەتىنىڭ بېشىغا قاينام بولۇپ چۈشسۇن؛ يوئابنىڭ ئائىلىسىدىن ئاقما يارا كېسىلى، ياكى ماخاۋ كېسىلى، ياكى ھاسىغا تايانغۇچى، قىلىچتىن ئۆلگۈچى ياكى ئاش-تۈلۈكسىزلەر ئۆكسۈمىسۇن! ــ دېدى. \f ◼ \fr 3:29 \ft \bd «ھاسىغا تايانغۇچى»\bd* ــ ياكى «چاق ئېگىرگۈچى».\f*
\m 
\v 30 شۇنداق قىلىپ، ئابنەر گىبېئوندىكى جەڭدە ئۇلارنىڭ ئىنىسى ئاساھەلنى ئۆلتۈرگىنى ئۈچۈن، يوئاب بىلەن ئىنىسى ئابىشاي ئۇنى ئۆلتۈردى.
\m 
\v 31 داۋۇت يوئابقا ۋە ئۇنىڭغا ئەگەشكەن بارلىق خەلققە: كىيىملىرىڭلارنى يىرتىڭلار! بۆز كىيىم كىيىڭلار! ئابنەرنىڭ \add مېيىتى\add* ئالدىدا ماتەم تۇتۇڭلار! دېدى. داۋۇت پادىشاھ \add ئابنەرنىڭ\add* جىنازىسىنىڭ كەينىدىن ماڭدى.
\v 32 ئۇلار ئابنەرنى ھېبروندا دەپنە قىلدى، پادىشاھ ئابنەرنىڭ قەبرىسىنىڭ يېنىدا ئاۋازىنى كۆتۈرۈپ يىغلىدى؛ خەلقنىڭ ھەممىسىمۇ يىغلاشتى.
\v 33 پادىشاھ ئابنەر ئۈچۈن مەرسىيە ئوقۇپ:
\m ــ «ئابنەرنىڭ ئەخمەقتەك ئۆلگىنى توغرىمۇ؟
\m 
\v 34 قوللىرىڭ باغلاقلىق بولمىسىمۇ،
\m پۇتلۇرۇڭ ئىشكەللىك بولمىسىمۇ،
\m لېكىن سەن كىشىلەرنىڭ رەزىللەرنىڭ قولىدا يىقىلغىنىدەك، يىقىلىپ ئۆلگەنسەن!» ــ دېدى.
\m شۇنىڭ بىلەن خەلقنىڭ ھەممىسى ئۇنىڭ ئۈچۈن يەنە يىغلاشتى.
\v 35 ئاندىن بارلىق خەلق داۋۇتنىڭ يېنىغا كېلىپ، ئۇنىڭغا كۈن پاتقۇچە تاماق يېيىشنى ئۆتۈندى. ئەمما داۋۇت قەسەم ئىچىپ: مەن كۈن پاتماستا يا نان يا باشقا ھەرقانداق نەرسىنى تېتىسام، خۇدا مېنى ئۇرسۇن ياكى ئۇنىڭدىن ئارتۇق جازالىسۇن، ــ دېدى. \f ◼ \fr 3:35 \ft \bd «خۇدا مېنى ئۇرسۇن ياكى ئۇنىڭدىن ئارتۇق جازالىسۇن»\bd* ــ ئىبرانىي تىلىدا «خۇدا مېنىڭ بېشىغا بۇنداق ياكى ئۇنداق قىلسۇن ياكى ئۇنىڭدىن تېخىمۇ ئارتۇق قىلسۇن!».\f*
\m 
\v 36 بارلىق خەلق بۇنى بايقاپ، بۇ ئىشتىن رازى بولدى؛ ئەمەلىيەتتە پادىشاھ قىلغان ھەربىر ئىش بارلىق خەلقنى رازى قىلاتتى.
\m 
\v 37 شۇنىڭ بىلەن بارلىق خەلق، شۇنداقلا پۈتكۈل ئىسرائىل شۇ كۈنى نەرنىڭ ئوغلى ئابنەرنىڭ ئۆلتۈرۈلىشىنىڭ پادىشاھنىڭ كۆرسەتمىسى ئەمەسلىكىنى بىلىپ يەتتى.
\v 38 پادىشاھ ئۆز خىزمەتكارلىرىغا: بىلەمسىلەر؟ بۈگۈن ئىسرائىلدا بىر سەردار، ئۇلۇغ بىر زات يىقىلدى! \f ◼ \fr 3:38 \ft \bd «پادىشاھ ئۆز خىزمەتكارلىرىغا: بىلەمسىلەر؟...»\bd* ــ ئىبرانىي تىلىدا «پادىشاھ ئۆز خىزمەتكارلىرىغا: بىلمەمسىلەر...؟».\f*
\v 39 گەرچە مەن مەسىھ قىلىنىپ پادىشاھ تىكلەنگەن بولساممۇ، مەن ئاجىز بىر بەندىمەن. بۇ ئادەملەر، يەنى زەرۇئىيانىڭ ئوغۇللىرىنىڭ ۋەھشىيىلىكىنى مەن كۆتۈرەلمىگۈدەكمەن؛ پەرۋەردىگار رەزىللىك قىلغۇچىنىڭ رەزىللىكىنى ئۆز بېشىغا قايتۇرسۇن! ــ دېدى.
\b
\b
\c 4
\s1 ئىشبوشەت ئۆلتۈرۈلىدۇ
\m 
\v 1 سائۇلنىڭ ئوغلى ئابنەرنىڭ ھېبروندا ئۆلگىنىنى ئاڭلىغاندا قولى بوشىشىپ كەتتى، بارلىق ئىسرائىل دەككە-دۈككىگە چۈشتى.
\m 
\v 2 سائۇلنىڭ ئوغلىنىڭ قوشۇنىنىڭ ئالدىن يۈرەر قىسمىدا ئىككى سەردارى بولۇپ، بىرىنىڭ ئىسمى بائاناھ، يەنە بىرىنىڭ ئىسمى رەكاب ئىدى. ئۇلار بىنيامىن قەبىلىسىدىن بولغان بەئەروتلۇق رىمموننىڭ ئوغۇللىرى ئىدى (چۈنكى بەئەروت بىنيامىن قەبىلىسىگە تەۋە ھېسابلىناتتى؛ \x ◘ \xo 4:2 \xt يە. 9‏:17؛ 18‏:25 \x*
\v 3 لېكىن بەئەروتلۇقلار گىتتائىمغا قېچىپ بېرىپ ئۇ يەردە بۇ كۈنگىچە مۇساپىردەك ياشاۋاتىدۇ).
\m 
\v 4 سائۇلنىڭ ئوغلى يوناتاننىڭ بىر ئوغلى بولۇپ، پۇتى ئاقساق ئىدى. سائۇل بىلەن يوناتاننىڭ ئۆلگەنلىكى توغرۇلۇق خەۋەر يىزرەئەلگە يەتكەندە، ئۇ بەش ياشقا كىرگەن ئىدى. ئىنىك ئانىسى ئۇنى ئېلىپ قاچتى؛ لېكىن شۇنداق بولدىكى، ئۇ ئالدىراپ يۈگۈرگەچكە، بالا چۈشۇپ كېتىپ، ئاقساق بولۇپ قالغانىدى. ئۇنىڭ ئىسمى مەفىبوشەت ئىدى. \x ◘ \xo 4:4 \xt 2سام. 9‏:3-13\x*
\m 
\v 5 ئەمدى بىر كۈنى بەئەروتلوق رىمموننىڭ ئوغۇللىرى رەكاب بىلەن بائاناھ چىڭقى چۈش ۋاقتىدا ئىشبوشەتنىڭ ئۆيىگە باردى. ئىشبوشەت چۈشلۈك ئۇيقۇدا ئۇخلاۋاتقانىدى.
\v 6 ئۇلار بۇغداي ئالىمىز دېگەننى باھانە قىلىپ، ئۆيىنىڭ ئىچكىرىگە كىرىپ، ئىشبوشەتنىڭ قورسىقىغا \add پىچاق\add* سانجىدى. ئاندىن رەكاب ۋە بائاناھ قېچىپ كەتتى
\v 7 (ئۇلار ئىشبوشەت ھۇجرىسىدا كارىۋاتتا ياتقىنىدا، ئۆيگە كىرىپ، ئۇنى ئۆلتۈرگەنىدى). ئۇلار ئۇنىڭ كاللىسىنى كېسىپ، ئاندىن كاللىسىنى ئېلىپ كېچىچە ئاراباھ تۈزلەڭلىكىدىن مېڭىپ ئۆتتى.
\v 8 ئۇلار ئىشبوشەتنىڭ كاللىسىنى ھېبرونغا، داۋۇتنىڭ قېشىغا ئېلىپ بېرىپ، پادىشاھقا: مانا، بۇ جانابلىرىنىڭ جېنىنى ئىزدىگەن دۈشمەنلىرى سائۇلنىڭ ئوغلى ئىشبوشەتنىڭ كاللىسى! بۈگۈن پەرۋەردىگار غوجام پادىشاھنى سائۇل بىلەن نەسلىدىن ئىنتىقام ئېلىشقا مۇيەسسەر قىلدى ــ دېدى.
\m 
\v 9 داۋۇت بەئەروتلۇق رىمموننىڭ ئوغۇللىرى رەكاب بىلەن ئىنىسى بائاناھغا: مېنى بارلىق قىيىنچىلىقلاردىن قۇتقۇزغان پەرۋەردىگارنىڭ ھاياتى بىلەن قەسەم قىلىمەنكى،
\v 10 بۇرۇن بىرسى داۋۇتقا خۇش خەۋەر ئېلىپ كەلدىم، دەپ ئويلاپ، ماڭا: ــ مانا، سائۇل ئۆلدى، دەپ كەلگەندە، مەن ئۇنى ئېلىپ زىكلاگتا ئۆلتۈرۈۋەتتىم. بەرھەق، مانا بۇ ئۇنىڭ يەتكۈزگەن خەۋىرىنىڭ مۇكاپاتى بولغانىدى! \x ◘ \xo 4:10 \xt 2سام. 1‏:15\x*
\v 11 ئەمدى مەن شۇنداق قىلغان يەردە، رەزىل ئادەملەر ئۆز ئۆيىدە ئورۇندا ياتقان بىر ھەققانىي كىشىنى ئۆلتۈرگەن بولسا، مەن نېمە قىلاي؟! ئۇنىڭ ئاققان قان قەرزىنى سىلەرنىڭ قولۇڭلاردىن ئېلىپ، سىلەرنى يەر يۈزىدىن يوقاتمامدىم؟ ــ دېدى.
\m 
\v 12 داۋۇت غۇلاملىرىغا بۇيرۇق قىلىۋىدى، ئۇلار بۇلارنى قەتل قىلدى. ئۇلارنىڭ قول-پۇتلىرىنى كېسىپ، ئۇلارنى ھېبروندىكى كۆلنىڭ يېنىدا ئېسىپ قويدى؛ لېكىن ئۇلار ئىشبوشەتنىڭ بېشىنى ئېلىپ ھېبروندا ئابنەرنىڭ قەبرىسىدە دەپنە قىلدى. \f ◼ \fr 4:12 \ft \bd « \bdit رەكاب بىلەن بائاناھنىڭ\bdit* قول-پۇتلىرىنى كېسىپ، ئۇلارنى ھېبروندىكى كۆلنىڭ يېنىدا ئېسىپ قويدى»\bd* ــ «ئۇلارنى» بەلكىم رەكاب بىلەن بائاناھنىڭ قول-پۇتلىرىنىلا ئەمەس، بەلكى جەسەتلىرىنى كۆرسىتىشى مۇمكىن.\f*  \x ◘ \xo 4:12 \xt 2سام. 3‏:32\x*
\b
\b
\c 5
\s1 داۋۇت ئىسرائىلغا پادىشاھ بولۇشقا مەسىھ قىلىنىدۇ
\r 1تار. 11‏:1-9؛ 14‏:1-17
\m 
\v 1 ئاندىن كېيىن ئىسرائىلنىڭ بارلىق قەبىلىلىرى ھېبرونغا داۋۇتنىڭ قېشىغا كېلىپ: قارىسىلا، بىز ئۆزلىرىنىڭ ئەت-سۆڭەكلىرىدۇرمىز!
\v 2 بۇرۇن سائۇل بىزنىڭ ئۈستىمىزدە سەلتەنەت قىلغاندىمۇ ئىسرائىل خەلقىگە جەڭگە چىقىپ-كىرىشكە يولباشچى بولغان ئۆزلىرى ئىدىلا؛ پەرۋەردىگار سىلىگە: سەن مېنىڭ خەلقىم ئىسرائىلنىڭ پادىچىسى بولۇپ، ئۇلارنى باقىسەن، ئىسرائىلنىڭ ئەمىرى بولىسەن، دېگەنىدى ــ دېدى. \f ◼ \fr 5:2 \ft \bd «ئىسرائىل خەلقىگە جەڭگە چىقىپ-كىرىشكە يولباشچى بولغان ئۆزلىرى ئىدىلا»\bd* ــ ئىبرانىي تىلىدا «ئىسرائىلنىڭ چىقىشىدا ھەم كىرىشىدە ئۇلارغا باشلىغۇچى ئىدىلا» دېگەنلىك بىلەن ئىپادىلىنىدۇ؛ مۇشۇ ئىبارە ئىسرائىلنىڭ بارلىق پائالىيەتلىرىنىمۇ كۆرسىتىشى مۇمكىن.\f*  \x ◘ \xo 5:2 \xt 2سام. 7‏:7؛ زەب. 78‏:70-72\x*
\m 
\v 3 شۇنىڭ بىلەن ئىسرائىلنىڭ ھەممە ئاقساقاللىرى ھېبرونغا پادىشاھنىڭ قېشىغا كەلدى؛ داۋۇت پادىشاھ ھېبروندا، پەرۋەردىگارنىڭ ئالدىدا ئۇلار بىلەن ئەھدە تۈزۈشتى. ئاندىن ئۇلار داۋۇتنى ئىسرائىلغا پادىشاھ بولۇشقا مەسىھ قىلدى.
\m 
\v 4 داۋۇت پادىشاھ بولغاندا ئوتتۇز ياشقا كىرگەن بولۇپ، قىرىق يىل سەلتەنەت قىلدى.
\v 5 ئۇ ھېبروندا يەھۇدانىڭ ئۈستىدە يەتتە يىل ئالتە ئاي سەلتەنەت قىلىپ، يېرۇسالېمدا پۈتكۈل ئىسرائىل بىلەن يەھۇدانىڭ ئۈستىدە ئوتتۇز ئۈچ يىل سەلتەنەت قىلدى. \x ◘ \xo 5:5 \xt 2سام. 2‏:11؛ 1پاد. 2‏:11؛ 1تار. 3‏:4\x*
\m 
\v 6 پادىشاھ ئۆز ئادەملىرى بىلەن يېرۇسالېمغا چىقىپ، شۇ زېمىندا تۇرغان يەبۇسىيلار بىلەن جەڭ قىلغىلى باردى. ئۇلار داۋۇتقا: سەن بۇ يەرگە كىرەلمەيسەن، بەلكى ھەتتا كورلار بىلەن ئاقساقلار سېنى چېكىندۈرىدۇ! ــ دېدى. چۈنكى ئۇلار: «داۋۇت بۇ يەرگە قەتئىي كىرەلمەيدۇ»، دەپ ئويلايتتى. \f ◼ \fr 5:6 \ft \bd «بەلكى ھەتتا كورلار بىلەن ئاقساقلار سېنى چېكىندۈرىدۇ! ــ دېدى. چۈنكى ئۇلار: «داۋۇت بۇ يەرگە قەتئىي كىرەلمەيدۇ»، دەپ ئويلايتتى»\bd* ــ بۇ ئىككى جۈملىنىڭ باشقا بىرخىل تەرجىمىسى: ــ «بەلكى سەن كورلار بىلەن ئاقساقلارنى ھەيدىۋەتمىسەڭ، بۇ يەرگە كىرەلمەيسەن، ــ دېدى، داۋۇتنى ھەرگىز بۇ يەرگە كىرمەيدۇ، دەپ ئويلاتتى».\f*
\v 7 لېكىن داۋۇت زىئون قورغىنىنى ئالدى (بۇ يەر داۋۇتنىڭ شەھىرى دەپ ئاتىلىدۇ). \f ◼ \fr 5:7 \ft \bd «زىئون قورغىنىنى»\bd* ــ «زىئون» يېرۇسالېمنىڭ ئىچىدىكى ئېگىزلىك بولۇپ، شۇ يەرگە دائىم قورغان سېلىنىپ تۇراتتى. كېيىن ئىبادەتخانىمۇ زىئوندا قۇرۇلغان. كېيىن «زىئون» دېگەن ئىسىم بەزىدە پۈتكۈل يېرۇسالېم شەھىرىگىمۇ ۋە بەزىدە ئىسرائىلنىڭ ئۆزىگىمۇ ۋەكىللىك بولغان.\f*
\m 
\v 8 داۋۇت ئۇ كۈنى: كىمكى يەبۇسىيلارنى ئۇراي دېسە سۈڭگۈچ بىلەن چىقىشى كېرەك، ئاندىن ئۇ داۋۇت قىن-قىنىدىن ئۆچ كۆرىدىغان بۇ كور، ئاقساقلار بىلەن \add ھېسابلىشالايدۇ\add*، دېدى. شۇنىڭ بىلەن «كورلار يا ئاقساقلار ئۆيگە كىرمىسۇن» دەيدىغان ماقال پەيدا بولدى. \f ◼ \fr 5:8 \ft \bd «كىمكى يەبۇسىيلارنى ئۇراي دېسە، سۈڭگۈچ بىلەن چىقىشى كېرەك»\bd* ــ بۇ سىرلىق سۆزنىڭ مەنىسى پەقەت يېقىندا ئارخېئولوگلار تەكشۈرۈپ تاپقان تارىخىي ئىزلاردىن ئېنىقلاندى. ئەسلىدە يېرۇسالېم شەھىرىنىڭ ئاستىدا مەخپىي بىر سۇ يولى بار ئىدى؛ شەھەردە بۇ سۇ يولىغا تۇتىشىدىغان تىك بىر قۇدۇق بار ئىدى. داۋۇتنىڭ ئادەملىرى شۇ قۇدۇقتىن يامىشىپ چىققان بولسا كېرەك. \bd «كورلار يا ئاقساقلار ئۆيگە كىرمىسۇن»\bd* ــ بۇ سۆزنىڭ مەنىسى بەلكىم (1) ھېچقانداق بۇتپەرەس ئادەملەرنىڭ (مەسىلەن، يەبۇسىيلارنىڭ) پادىشاھنىڭ ئوردىسىغا كىرىشىگە رۇخسەت يوق؛ (2) داۋۇت يەبۇسىيلار تايانغان ھەرقانداق بۇتلار («كور ۋە ئاقساقلار)نى ھەرگىز ئۆيىگە كىرىشكە رۇخسەت قىلمايتتى (دېمەك، بۇتلار «كور»، «ئاقساق»لاردەك ھېچنېمە قىلالمايدۇ). بۇ سۆز كورلار ۋە ئاقساقلارنىڭ ئۆزلىرىنى كۆرسەتمەيدۇ، چۈنكى كېيىن ئاقساق بولغان مەفىبوشەت ھەركۈنى داۋۇت بىلەن ھەمداستىخان ئولتۇراتتى.\f*  \x ◘ \xo 5:8 \xt 1تار. 11‏:6 \x*
\m 
\v 9 شۇنداق قىلىپ داۋۇت قورغاندا تۇردى ۋە ئۇ يەرنى «داۋۇتنىڭ شەھىرى» دەپ ئاتىدى. داۋۇت شەھەرنىڭ ئەتراپىغا مىللودىن تارتىپ ئىچ تەرەپكىچە ئىمارەت سالدى. \f ◼ \fr 5:9 \ft \bd «مىللودىن تارتىپ ئىچ تەرەپكىچە ئىمارەت سالدى»\bd* ــ «مىللو»: «پەلەمپەيلىك يەر» دېگەن مەنىدە بولۇشى مۇمكىن.\f*
\v 10 داۋۇت بارغانسېرى قۇدرەت تاپتى؛ ساماۋىي قوشۇنلارنىڭ سەردارى بولغان خۇدا پەرۋەردىگار ئۇنىڭ بىلەن بىللە ئىدى.
\m 
\v 11 تۇرنىڭ پادىشاھى ھىرام داۋۇتنىڭ قېشىغا ئەلچىلەرنى ئەۋەتتى ۋە ئۇلار بىلەن قوشۇپ، كېدىر ياغاچلىرى، ياغاچچىلار ۋە تاشچىلارنى ئەۋەتتى؛ ئۇلار داۋۇت ئۈچۈن بىر ئوردا ياساپ بەردى.
\v 12 داۋۇت پەرۋەردىگارنىڭ ئۆزىنى ئىسرائىلغا پادىشاھ تىكلەپ، ئۆز خەلقى ئىسرائىل ئۈچۈن ئۆزىنىڭ پادىشاھلىقىنى گۈللەندۈرگەنلىكىنى بىلىپ يەتتى.
\m 
\v 13 داۋۇت ھېبروندىن كەلگەندىن كېيىن يېرۇسالېمدىن يەنە ئاياللارنى ۋە كېنىزەكلەرنى ئالدى؛ شۇنىڭ بىلەن داۋۇتقا يەنە كۆپ ئوغۇل-قىزلار تۇغۇلدى. \x ◘ \xo 5:13 \xt 1تار. 3‏:9؛ 14‏:3-7\x*
\m 
\v 14 يېرۇسالېمدا ئۇنىڭدىن تۇغۇلغانلارنىڭ ئىسىملىرى مانا مۇنداق ئىدى: شاممۇئا، شوباب، ناتان، سۇلايمان،
\v 15 ئىبھار، ئېلىشۇئا، نەفەگ، يافىيا،
\v 16 ئېلىشاما، ئېلىئادا ۋە ئېلىفەلەت.
\b
\s1 فىلىستىيە بىلەن جەڭ قىلىش
\m 
\v 17 فىلىستىيلەر داۋۇتنىڭ ئىسرائىلغا پادىشاھ بولۇشقا مەسىھلەنگىنىنى ئاڭلىغاندا، ئۇلار ھەممىسى داۋۇتنى تۇتقىلى چىقتى، داۋۇت بۇنى ئاڭلاپلا، قورغانغا چۈشتى.
\m 
\v 18 فىلىستىيلەر كېلىپ «رەفايىم جىلغىسى»دا يېيىلىپ تۇردى؛ \f ◼ \fr 5:18 \ft \bd «رەفايىم جىلغىسى»\bd* ــ يېرۇسالېمغا يېقىن، ھىننوم جىلغىسىنىڭ جەنۇبىي تەرىپىدە.\f*
\v 19 داۋۇت پەرۋەردىگاردىن يول سوراپ: فىلىستىيلەرگە قارشى ئاتلىنايمۇ؟ ئۇلارنى قولۇمغا تاپشۇرارسەنمۇ؟ ــ دېدى. پەرۋەردىگار داۋۇتقا: چىققىن! چۈنكى، مەن فىلىستىيلەرنى جەزمەن قولۇڭغا تاپشۇرىمەن ــ دېدى.
\m 
\v 20 ئۇ ۋاقىتتا داۋۇت بائال-پەرازىمغا باردى. ئۇ يەردە داۋۇت ئۇلارنى تارمار قىلدى. ئۇ: ــ «پەرۋەردىگار مېنىڭ ئالدىمدا دۈشمەنلىرىم ئۈستىگە خۇددى كەلكۈن يارنى ئېلىپ كەتكەندەك بۆسۈپ كىردى» ــ دېدى. شۇنىڭ بىلەن ئۇ يەرنى «بائال-پەرازىم» دەپ ئاتىدى. \f ◼ \fr 5:20 \ft \bd «بائال-پەرازىم»\bd* ــ «بۆسۈپ چىققۇچىلارنىڭ رەببى» دېگەن مەنىدە.\f*  \x ◘ \xo 5:20 \xt يەش. 28‏:21\x*
\v 21 فىلىستىيلەر ئۇ يەردە ئۆز مەبۇدلىرىنى تاشلاپ كەتتى؛ داۋۇت بىلەن ئادەملىرى ئۇلارنى ئېلىپ كەتتى.
\m 
\v 22 ئەمدى فىلىستىيلەر يەنە چىقىپ «رەفايىم جىلغىسى»دا يېيىلىپ تۇردى.
\m 
\v 23 داۋۇت پەرۋەردىگاردىن يول سورىدى. پەرۋەردىگار: سەن ئۇ يەرگە چىقماي، بەلكى ئۇلارنىڭ كەينىدىن ئايلىنىپ ئۆتۈپ ئۈجمە دەرەخلىرىنىڭ ئۇدۇلىدىن ھۇجۇم قىلغىن ــ دېدى، \f ◼ \fr 5:23 \ft \bd «ئۈجمە دەرەخلىرى»\bd* ــ بۇ بىزنىڭ قىياسىمىز. ئىبرانىي تىلىدا «يىغلىغۇچى دەرەخلەر». زادى قايسى دەرەخ ئىكەنلىكى بىزگە نامەلۇم. باشقا بىر قىياس «خىنە دەرەخلىرى».\f*
\m 
\v 24 شۇنداق بولىدۇكى، سەن ئۈجمە دەرەخلىكىنىڭ ئۈستىدىن ئاياغ تىۋىشىنى ئاڭلىشىڭ بىلەنلا دەرھال ئاتلان؛ چۈنكى شۇ تاپتا پەرۋەردىگار فىلىستىيلەرنىڭ قوشۇنىغا ھۇجۇمغا چىققان بولىدۇ، ــ دېدى.
\m 
\v 25 داۋۇت پەرۋەردىگارنىڭ ئۇنىڭغا ئەمر قىلغىنىدەك قىلىپ، فىلىستىيلەرنى گىبېئوندىن گەزەرگىچە قوغلاپ قىردى. \f ◼ \fr 5:25 \ft \bd «گىبېئوندىن»\bd* ــ ياكى «گېبادىن».\f*
\b
\b
\c 6
\s1 داۋۇت ئەھدە ساندۇقىنى يېرۇسالېمغا ئەكىلىدۇ
\r 1تار. 13‏:1-14؛ 15‏:25-29‏؛ 16‏:1-3
\m 
\v 1 داۋۇت ئىسرائىلنىڭ ئارىسىدىن بارلىق سەرخىل ئادەملەرنى يىغىۋىدى، بۇلار ئوتتۇز مىڭ چىقتى.
\v 2 ئاندىن داۋۇت ۋە ئۇنىڭغا ئەگەشكەنلەرنىڭ ھەممىسى خۇدانىڭ ئەھدە ساندۇقىنى يۆتكەپ كېلىش ئۈچۈن يەھۇدادىكى بائالاھغا چىقتى؛ ساندۇق \add مۇقەددەس\add* نام بىلەن، يەنى كېرۇبلارنىڭ ئوتتۇرىسىدا ئولتۇرغۇچى ساماۋىي قوشۇنلارنىڭ سەردارى بولغان پەرۋەردىگارنىڭ نامى بىلەن ئاتالغانىدى. \f ◼ \fr 6:2 \ft \bd «يەھۇدادىكى بائالاھ»\bd* ــ (ياكى «بائالاھ-جەھۇداغا») ــ باشقا ئىسمى «كىرىئات-يېئارىم» («1سام.» 2:7، «1تار.» 6:13نى كۆرۈڭ).\f*
\v 3 ئۇلار خۇدانىڭ ئەھدە ساندۇقىنى دۆڭدە ئولتۇرۇشلۇق ئابىنادابنىڭ ئۆيىدە يېڭى بىر ھارۋىغا سېلىپ، ئۇنى شۇ يەردىن ئېلىپ چىقتى. ئابىنادابنىڭ ئوغۇللىرى ئۇززاھ بىلەن ئاھىيو ئۇ يېڭى ھارۋىنى ھەيدىدى. \x ◘ \xo 6:3 \xt 1سام. 6‏:7، 8؛ 7‏:1، 2\x*
\v 4 ئۇلار ھارۋىنى خۇدانىڭ ئەھدە ساندۇقى بىلەن دۆڭدە ئولتۇرۇشلۇق ئابىنادابنىڭ ئۆيىدىن ئېلىپ چىقتى؛ ئاھىيو ئەھدە ساندۇقىنىڭ ئالدىدا ماڭدى.
\v 5 داۋۇت بىلەن پۈتكۈل ئىسرائىل جەمەتىدىكىلەر پەرۋەردىگارنىڭ ئالدىدا تەنتەنە قىلىپ كۈي ئوقۇپ چىلتار، تەمبۇر، داپ، داقا-دۇمباق ۋە جاڭلار چېلىپ ئۇسسۇل ئوينىدى. \f ◼ \fr 6:5 \ft \bd «تەنتەنە قىلىپ كۈي ئوقۇپ... »\bd* ــ ياكى «ھەرخىل ئارچا ياغاچلىرىدىن ياسالغان سازلارنى چېلىپ...». \bd «داقا-دۇمباق»\bd* ــ ياكى «شاقىلداق(لار)».\f*
\m 
\v 6 لېكىن ئۇلار ناكوننىڭ خامىنىغا كەلگەندە، كالىلار ئالدىغا مۈدۈرەپ كەتكەنلىكى ئۈچۈن، ئۇززاھ قولىنى سوزۇپ خۇدانىڭ ئەھدە ساندۇقىنى تۇتۇۋالدى.
\v 7 پەرۋەردىگارنىڭ غەزىپى ئۇززاھقا قوزغالدى؛ ئۇ خاتا قىلغىنى ئۈچۈن، ئۇنى خۇدا شۇ يەردە ئۇردى. شۇنىڭ بىلەن ئۇززاھ خۇدانىڭ ئەھدە ساندۇقىنىڭ يېنىغا يىقىلىپ ئۆلدى.
\m 
\v 8 لېكىن داۋۇت بولسا پەرۋەردىگارنىڭ ئۇززاھنىڭ تېنىنى بۆسكەنلىكىگە ئاچچىقلاندى ۋە ئۇ يەرنى «پەرەز-ئۇززاھ» دەپ ئاتىدى؛ ئۇ يەر بۈگۈنكى كۈنگىچە شۇنداق ئاتىلىدۇ. \f ◼ \fr 6:8 \ft \bd «پەرەز-ئۇززاھ»\bd* ــ «ئۇززاھغا بۆسۈپ كىرىش» دېگەن مەنىدە.\f*
\v 9 ئۇ كۈنى داۋۇت پەرۋەردىگاردىن قورقۇپ: پەرۋەردىگارنىڭ ئەھدە ساندۇقىنى ئۆزۈمنىڭكىگە قايسى يول بىلەن ئەكېلەرمەن؟ ــ دېدى.
\m 
\v 10 شۇنىڭ ئۈچۈن داۋۇت پەرۋەردىگارنىڭ ئەھدە ساندۇقىنى «داۋۇت شەھىرى»گە، ئۆزىنىڭكىگە يۆتكەشنى خالىمىدى؛ داۋۇت ئۇنى ئېلىپ بېرىپ، گاتلىق ئوبەد-ئېدومنىڭ ئۆيىدە قالدۇردى.
\m 
\v 11 پەرۋەردىگارنىڭ ئەھدە ساندۇقى گاتلىق ئوبەد-ئېدومنىڭ ئۆيىدە ئۈچ ئاي تۇردى؛ پەرۋەردىگار ئوبەد-ئېدوم ۋە ئۇنىڭ پۈتكۈل ئۆيىدىكىلەرنى بەرىكەتلىدى.
\m 
\v 12 داۋۇت پادىشاھقا: ــ «پەرۋەردىگار ئۆز ئەھدە ساندۇقى ۋەجىدىن ئوبەد-ئېدوم ۋە ئۇنىڭ بارىنى بەرىكەتلىدى» دەپ ئېيتىلدى. شۇڭا داۋۇت خۇدانىڭ ئەھدە ساندۇقىنى ئوبەد-ئېدومنىڭ ئۆيىدىن ئېلىپ چىقىپ، خۇشلۇق بىلەن داۋۇتنىڭ شەھىرىگە ئېلىپ كەلدى. \f ◼ \fr 6:12 \ft \bd «پەرۋەردىگار ئۆز ئەھدە ساندۇقى ۋەجىدىن...»\bd* ــ ئىبرانىي تىلىدا «پەرۋەردىگار خۇدانىڭ ئەھدە ساندۇقى ۋەجىدىن...».\f*
\m 
\v 13 پەرۋەردىگارنىڭ ساندۇقىنى كۆتۈرگەنلەر ئالتە قەدەم مېڭىپ، شۇنداق بولدىكى، ئۇ بىر بۇقا بىلەن بىر بورداق موزاينى قۇربانلىق قىلدى. \f ◼ \fr 6:13 \ft \bd «پەرۋەردىگارنىڭ ساندۇقىنى كۆتۈرگەنلەر ئالتە قەدەم مېڭىپ، شۇنداق بولدىكى، ئۇ بىر بۇقا بىلەن بىر بورداق موزاينى قۇربانلىق قىلدى»\bd* ــ «ئالتە قەدەم» بىزنىڭچە بۇ دەسلەپكى ئالتە قەدەمنى كۆرسىتىدۇ. باشقا بىرخىل تەرجىمىسى «ئۇلار ھەر ئالتە قەدەم ماڭغاندا، بىر قېتىم بۇقا ۋە بورداق موزاي قۇربانلىق قىلدى». لېكىن ئۇنداق بولسا، ئىلگەرلەش بەك ئاستا بولاتتى!\f*
\v 14 داۋۇت بولسا كاناپ ئەفودنى كىيىپ پەرۋەردىگارنىڭ ئالدىدا كۈچىنىڭ بارىچە ئۇسسۇل ئوينايتتى؛ \f ◼ \fr 6:14 \ft \bd «داۋۇت بولسا كاناپ ئەفودنى كىيىپ...»\bd* ــ «ئەفود» ئادەتتە پەقەت كاھىنلار كىيىدىغان جىلىتكىدەك قىسقا بىر كۆينەك ئىدى. بىزنىڭ «تەبىرلەر»ىمىزنى كۆرۈڭ. داۋۇتنىڭ ئەفودنى كىيىشى بەلكىم ئۇسسۇل ئويناشقا ئازادە بولۇش ئۈچۈن ئىدى (14-ئايەتنى كۆرۈڭ).\f*
\v 15 داۋۇت بىلەن ئىسرائىلنىڭ پۈتكۈل جەمەتى تەنتەنە قىلىپ ۋارقىرىشىپ، كاناي چېلىشىپ پەرۋەردىگارنىڭ ئەھدە ساندۇقىنى ئېلىپ چىقىۋاتاتتى.
\m 
\v 16 پەرۋەردىگارنىڭ ئەھدە ساندۇقى داۋۇتنىڭ شەھىرىگە ئېلىپ كىرىلگىنىدە، سائۇلنىڭ قىزى مىقال دېرىزىدىن قاراپ، داۋۇت پادىشاھنىڭ سەكرەپ پەرۋەردىگارنىڭ ئالدىدا ئۇسسۇل ئويناۋاتقانلىقىنى كۆرۈپ، ئۇنى ئۆز كۆڭلىدە مەنسىتمىدى.
\m 
\v 17 ئۇلار پەرۋەردىگارنىڭ ئەھدە ساندۇقىنى ئېلىپ كىرىپ، داۋۇت ئۇنىڭ ئۈچۈن تىكتۈرگەن چېدىرنىڭ ئوتتۇرسىدا قويدى. ئاندىن داۋۇت پەرۋەردىگارنىڭ ئالدىدا كۆيدۈرمە قۇربانلىق بىلەن ئىناقلىق قۇربانلىقلىرىنى سۇندى.
\m 
\v 18 داۋۇت كۆيدۈرمە قۇربانلىق بىلەن ئىناقلىق قۇربانلىقلىرىنى كەلتۈرۈپ بولۇپ، خالايىققا ساماۋىي قوشۇنلارنىڭ سەردارى بولغان پەرۋەردىگارنىڭ نامىدا بەخت-بەرىكەت تىلىدى.
\v 19 ئۇ پۈتكۈل ئىسرائىل جامائىتىگە، ئەر بىلەن ئاياللارنىڭ ھەربىرىگە بىردىن قوتۇرماچ، بىردىن خورما پوشكىلى ۋە بىردىن ئۈزۈم پوشكىلىنى تەقسىم قىلىپ بەردى. ئاندىن خەلقنىڭ ھەربىرى ئۆز ئۆيىگە يېنىپ كەتتى. \f ◼ \fr 6:19 \ft \bd «بىردىن خورما پوشكىلى»\bd* ــ ياكى «بىر يۇتۇم شاراب» ياكى «بىر پارچە گۆش».\f*
\m 
\v 20 داۋۇت ئۆز ئائىلىسىدىكىلەرنى مۇبارەكلەش ئۈچۈن يېنىپ كەلگەندە، سائۇلنىڭ قىزى مىقال ئۇنىڭ ئالدىغا چىقىپ: بۈگۈن ئىسرائىلنىڭ پادىشاھى ئۆزىنى شۇنچە شەرەپلىك كۆرسەتتىمۇ، قانداق؟ ئۇ خۇددى پەس بىر ئادەمنىڭ نومۇسسىزلاچە ئۆزىنى يالىڭاچلىغىنىغا ئوخشاش، خىزمەتكارلىرىنىڭ دېدەكلىرىنىڭ كۆز ئالدىدا ئۆزىنى يالىڭاچلىدى! \f ◼ \fr 6:20 \ft \bd «...ئۆز ئائىلىسىدىكىلەرنى مۇبارەكلەش ئۈچۈن...»\bd* ــ «مۇبارەكلەش» مۇشۇ يەردە «بەخت-بەرىكەت تىلەش»نى ئۆز ئىچىگە ئالىدۇ. \bd «بۈگۈن ئىسرائىلنىڭ پادىشاھى ... خىزمەتكارلىرىنىڭ دېدەكلىرىنىڭ كۆز ئالدىدا ئۆزىنى يالىڭاچلىدى!»\bd* ــ «ئۆزىنى يالىڭاچلىدى» دېگەن گەپ ئەركىنرەك ئۇسسۇل ئويناشقا داۋۇتنىڭ «ئەفود»نى كىيگەنلىكىنى كۆرسىتىدۇ.\f*
\m 
\v 21 داۋۇت مىقالغا: ئۇنداق \add شادلانغىنىم\add* پەرۋەردىگار ئالدىدا ئىدى. ئۇ ئاتاڭ ۋە ئۇنىڭ پۈتكۈل جەمەتىنى ئۆرۈپ، مېنى پەرۋەردىگارنىڭ خەلقى بولغان ئىسرائىل ئۈستىگە باشلامچى قىلىپ تىكلىدى. شۇڭا مەن پەرۋەردىگارنىڭ ئالدىدا ئۇسسۇل ئوينايمەن!
\v 22 ئەمەلىيەتتە مەن ئۆزۈمنى تېخىمۇ ئەرزىمەس قىلىپ، ئۆز نەزىرىمدە ئۆزۈم تۆۋەن بولۇشقا رازىمەن. لېكىن سەن ئېيتقان ئۇ دېدەكلەرنىڭ نەزىرىدە بولسا، ھۆرمەتكە سازاۋەر بولىمەن ــ دېدى.
\m 
\v 23 سائۇلنىڭ قىزى مىقال بولسا، ئۆلىدىغان كۈنىگىچە بالا تۇغمىدى.
\b
\b
\c 7
\s1 پەرۋەردىگارنىڭ داۋۇتقا قىلغان ئۇلۇغ ۋەدىلىرى
\r 1تار. 17‏:1-27
\m 
\v 1 پادىشاھ ئۆز ئوردىسىدا تۇراتتى، پەرۋەردىگار ئۇنىڭغا ئەتراپىدىكى بارلىق دۈشمەنلىرىدىن ئارام بەرگەندىن كېيىن،
\v 2 پادىشاھ ناتان پەيغەمبەرگە: مانا قارا، مەن كېدىر ياغىچىدىن ياسالغان ئۆيدە ئولتۇرىمەن، لېكىن خۇدانىڭ ئەھدە ساندۇقى بىر چىدىرنىڭ ئىچىدە تۇرۇۋاتىدۇ ــ دېدى. \f ◼ \fr 7:2 \ft \bd «خۇدانىڭ ئەھدە ساندۇقى بىر چىدىرنىڭ ئىچىدە تۇرۇۋاتىدۇ»\bd* ــ مۇشۇ يەردە «چېدىرنىڭ ئىچىدە» ئىبرانىي تىلىدا «پەردىلەر ئىچىدە» دېگەن سۆز بىلەن ئىپادىلىنىدۇ.\f*
\m 
\v 3 ناتان پادىشاھقا جاۋاپ بېرىپ: كۆڭلۈڭدە نېمە ئويلىغىنىڭ بولسا، شۇنى قىلغىن؛ چۈنكى پەرۋەردىگار سېنىڭ بىلەن بىللىدۇر ــ دېدى.
\m 
\v 4 لېكىن كېچىدە شۇنداق بولدىكى، پەرۋەردىگارنىڭ سۆزى ناتانغا كېلىپ مۇنداق دېگەندە:
\v 5 ــ بېرىپ قۇلۇم داۋۇتقا دېگىن: «پەرۋەردىگار: ــ «سەن دەرۋەقە ماڭا تۇرىدىغانغا ئۆي سالماقچىمۇسەن؟» ــ دەيدۇ. \f ◼ \fr 7:5 \ft \bd «قۇلۇم داۋۇت»\bd* ــ «قۇل» دېگەن ئۇقۇم توغرۇلۇق «تەبىرلەر»ىمىزنى كۆرۈڭ.\f*
\v 6 ــ «مەن ئىسرائىللارنى مىسىردىن چىقارغاندىن تارتىپ، بۇ كۈنگىچە بىر ئۆيدە ئولتۇرمىدىم، بەلكى بىر چېدىرنى ماكان قىلىپ، كېزىپ يۈردۈم.
\v 7 مەن ئۆزۈم بارلىق ئىسرائىللار بىلەن يۈرگەن ھەممە يەرلەردە، خەلقىم ئىسرائىلنى پادىچى بولۇپ بېقىشقا ئەمر قىلغانلارغا، يەنى ئىسرائىلنىڭ ھەرقانداق قەبىلىسىنىڭ بىر \add يېتەكچىسىگە\add*: نېمىشقا ماڭا كېدىر ياغاچتىن بىر ئۆي ياسىمايسىلەر؟ ــ دەپ باققانمۇ؟ \f ◼ \fr 7:7 \ft \bd «ئىسرائىلنىڭ ھەرقانداق قەبىلىسىنىڭ بىر يېتەكچىسى...»\bd* ــ «1تار.» 6:17دە «ئىسرائىلنىڭ ھەرقانداق يېتەكچى ھاكىمى» دېيىلىدۇ.\f*
\v 8 ئەمدى قۇلۇم داۋۇتقا مۇنداق دېگىن: ــ ساماۋىي قوشۇنلارنىڭ سەردارى بولغان پەرۋەردىگار: ــ سېنى خەلقىم ئىسرائىلغا باشلامچى قىلىپ تىكلەش ئۈچۈن سېنى يايلاقلاردىن، قوي بېقىشتىن ئېلىپ كەلدىم، ــ دەيدۇ،
\v 9 ــ ۋە مەيلى قەيەرگە بارمىغىن، مەن ھامان سېنىڭ بىلەن بىللە بولدۇم ۋە سېنىڭ ئالدىڭدىن بارلىق دۈشمەنلىرىڭنى يوقىتىپ كەلدىم؛ يەر يۈزىدىكى ئۇلۇغلار نام-شۆھرەتكە ئىگە بولغاندەك سېنى ئۇلۇغ نام-شۆھرەتكە سازاۋەر قىلدىم. \x ◘ \xo 7:9 \xt 2سام. 8‏:14،6\x*
\v 10‏-11 مەن خەلقىم بولغان ئىسرائىلغا بىر جاينى بېكىتىپ، ئۇلارنى شۇ يەردە تىكىپ ئۆستۈرىمەن؛ شۇنىڭ بىلەن ئۇلار ئۆز زېمىنىدا تۇرىدىغان، پاراكەندىچىلىككە ئۇچرىمايدىغان بولىدۇ. رەزىللەر دەسلەپتىدىكىدەك، شۇنداقلا مەن خەلقىم ئىسرائىل ئۈستىگە ھۆكۈمرانلىق قىلىشقا ھاكىملارنى تەيىنلىگەن كۈنلەردىكىدەك، ئۇلارغا قايتىدىن زۇلۇم سالمايدۇ. مەن ھازىر ساڭا ھەممە دۈشمەنلىرىڭدىن ئارام بەردىم. ئەمدى مەنكى پەرۋەردىگار ساڭا شۇنى ئېيتىپ قويايكى، مەن سېنىڭ ئۈچۈن بىر ئۆينى قۇرۇپ بېرىمەن!» ــ دەيدۇ. \f ◼ \fr 7:10‏-11 \ft \bd «سەن ئۈچۈن بىر ئۆي قۇرۇپ بېرىمەن»\bd* ــ داۋۇت ئەسلى خۇدا ئۈچۈن بىر ئۆي قۇرماقچى بولغان، لېكىن خۇدا داۋۇتقا: ساڭا بىر ئۆي (ئائىلە، جەمەت، سۇلالە دېگەن مەنىدە) قۇرۇپ بېرىمەن» دەپ جاۋاب بېرىدۇ.\f*
\b
\m 
\v 12 «كۈنلىرىڭ توشۇپ، ئاتا-بوۋىلىرىڭ بىلەن \add ئۆلۈمدە\add* ئۇخلىغىنىڭدا، مەن ئۆز پۇشتىڭدىن بولغان نەسلىڭنى سېنىڭ ئورنۇڭدا تۇرغۇزۇپ، پادىشاھلىقىنى مەزمۇت قىلىمەن. \f ◼ \fr 7:12 \ft \bd «مەن ئۆز پۇشتىڭدىن بولغان نەسلىڭنى سېنىڭ ئورنۇڭدا تۇرغۇزۇپ، ...»\bd* ــ مۇشۇ يەردە «پۇشتىڭدىن» ــ ئىبرانىي تىلىدا «ئىچ-باغرىڭدىن».\f*  \x ◘ \xo 7:12 \xt 1پاد. 8‏:20\x*
\v 13 مېنىڭ نامىم ئۈچۈن بىر ئۆينى ياسىغۇچى ئۇ بولىدۇ، ۋە مەن ئۇنىڭ پادىشاھلىق تەختىنى ئەبەدگىچە مۇستەھكەم قىلىمەن. \x ◘ \xo 7:13 \xt 1پاد. 5‏:19؛ 6‏:12؛ 1تار. 22‏:10\x*
\v 14 مەن ئۇنىڭغا ئاتا بولىمەن، ئۇ ماڭا ئوغۇل بولىدۇ. ئەگەر ئۇ قەبىھلىك قىلسا، ئۇنىڭغا ئىنسانلارنىڭ تايىقى بىلەن ۋە ئادەم بالىلىرىنىڭ ساۋاق-دۇمبالاشلىرى بىلەن تەربىيە بېرىمەن. \f ◼ \fr 7:14 \ft \bd «ئۇنىڭغا ئىنسانلارنىڭ تايىقى بىلەن ۋە ئادەم بالىلىرىنىڭ ساۋاق-دۇمبالاشلىرى بىلەن تەربىيە بېرىمەن»\bd* ــ دېمەك، داۋۇتنىڭ ئەۋلادلىرىدىن بولغان پادىشاھلار گۇناھ قىلسا، خۇدا ئۇلارغا ئىنسانىي ۋاسىتە (بەلكىم دۈشمەننىڭ ۋاسىتىسى) بىلەن تەربىيە بېرىدۇ.\f*  \x ◘ \xo 7:14 \xt زەب. 89‏:26-27، 31؛ ئىبر. 1‏:5\x*
\v 15 ئەمما مەن سېنىڭ ئالدىڭدا ئۆرۈۋەتكەن سائۇلدىن مېھىر-شەپقىتىمنى جۇدا قىلغىنىمدەك، ئۇنىڭدىن مېھىر-شەپقىتىمنى جۇدا قىلمايمەن.
\v 16 شۇنىڭ بىلەن سېنىڭ ئۆيۈڭ ۋە سېنىڭ پادىشاھلىقىڭ ئالدىڭدا ھەمىشە مەزمۇت قىلىنىدۇ؛ تەختىڭ ئەبەدگىچە مەزمۇت تۇرغۇزۇلىدۇ». \f ◼ \fr 7:16 \ft \bd «...سېنىڭ ئۆيۈڭ ۋە سېنىڭ پادىشاھلىقىڭ ئالدىڭدا ھەمىشە مەزمۇت قىلىنىدۇ»\bd* ــ ياكى «...سېنىڭ ئۆيۈڭ ۋە سېنىڭ پادىشاھلىقىڭ ئالدىمدا ھەمىشە مەزمۇت قىلىنىدۇ».\f*
\m 
\v 17 ناتان بۇ بارلىق سۆزلەر ۋە بارلىق ۋەھىينى ھېچنېمە قالدۇرماي، داۋۇتقا ئېيتىپ بەردى.
\m 
\v 18 ئاندىن داۋۇت پادىشاھ كىرىپ، پەرۋەردىگارنىڭ ئالدىدا ئولتۇرۇپ مۇنداق دېدى: «ئى، رەب پەرۋەردىگار، مەن زادى كىم ئىدىم، مېنىڭ ئۆيۈم نېمە ئىدى، سەن مېنى مۇشۇ دەرىجىگە كۆتۇرگۈدەك؟
\v 19 لېكىن، ئى رەب پەرۋەردىگار، \add مېنىڭ بۇ مەرتىۋەم\add* سېنىڭ نەزىرىڭدە كىچىككىنە بىر ئىش ھېسابلاندى؛ چۈنكى سەن مەن قۇلۇڭنىڭ ئۆيىنىڭ يىراق كەلگۈسى توغرۇلۇق سۆزلىدىڭ؛ بۇ ھەممىلا ئادەمگە دائىم بولىدىغان ئىشمۇ، ئى، رەب پەرۋەردىگار؟ \f ◼ \fr 7:19 \ft \bd «مېنىڭ بۇ مەرتىۋەم سېنىڭ نەزىرىڭدە كىچىككىنە بىر ئىش ھېسابلاندى»\bd* ــ دېمەك، «سەن (ئاللىقاچان) مېنى مۇشۇ (يۇقىرى) دەرىجىگە كۆتۇرگەنىكەنسەن...» دېگەن سۆز (18-ئايەتنى كۆرۈڭ) ئۇنىڭ پادىشاھ بولغانلىقىنى كۆرسىتىدۇ. لېكىن خۇدا بۇ ئىمتىيازدىن يەنە كۆپ ئىمتىيازلارنى قوشۇپ بەرمەكچى. 9-16-ئايەتلەرنى قايتىدىن كۆرۈڭ. «بۇ ھەممىلا ئادەمگە دائىم بولىدىغان ئىشمۇ، ئى، رەب پەرۋەردىگار؟» ــ باشقا بىرخىل تەرجىمىسى: «بۇ ئىش بارلىق ئىنسامىيەتكە بولىدىغان ۋەهىي، رەب پەرۋەردىگار!».\f*
\v 20 ئەمدى داۋۇت ساڭا يەنە نېمە دېسۇن؟ سەن ئۆز قۇلۇڭنى تونۇيسەن، ئى، رەب پەرۋەردىگار!
\v 21 سەن سۆز-ۋەدەڭ ۋەجىدىن، ئۆز كۆڭلۈڭدىكىگە ئاساسەن بۇ ئۇلۇغ ئىشنىڭ ھەممىسىنى قۇلۇڭ بىلسۇن دەپ بېكىتىپ قىلغانسەن.
\v 22 شۇڭا سەن ئۇلۇغسەن، ئى پەرۋەردىگار؛ قۇلاقلىرىمىز بارلىق ئاڭلىغىنىدەك، سېنىڭ تەڭدىشىڭ يوق، سەندىن باشقا ھېچقانداق ئىلاھ يوقتۇر. \x ◘ \xo 7:22 \xt قان. 3‏:24؛ 4‏:35؛ 32‏:39؛ 1سام. 2‏:2؛ زەب. 86‏:8؛ يەش. 45‏:5، 18، 22؛ مار. 12‏:29، 32\x*
\m 
\v 23 خەلقىڭ ئىسرائىلدەك يەنە باشقا بىر ئەل بارمۇ، ئۇلار جاھاندا ئالاھىدە تۇرىدۇ؟ ــ چۈنكى \add سەن\add* خۇدا ئۇلارنى مىسىردىن قۇتقۇزۇپ ئۆزۈڭگە خاس بىر خەلق قىلىش ئۈچۈن، شۇنداقلا نام-شۆھرەتكە ئىگە بولۇش ئۈچۈن، ئۆزۈڭ باردىڭ؛ سەن ئۆزۈڭ ئۈچۈن مىسىردىن، ئەللەردىن ۋە ئۇلارنىڭ ئىلاھلىرىدىن قۇتقۇزۇپ چىققان خەلقىڭ ئالدىدا زېمىنىڭ ئۈچۈن ئۇلۇغ ۋە دەھشەتلىك ئىشلارنى قىلدىڭ. \f ◼ \fr 7:23 \ft \bd «ئۇلارنى... قۇتقۇزۇپ ئۆزۈڭگە خاس بىر خەلق قىلىش ئۈچۈن، شۇنداقلا نام-شۆھرەتكە ئىگە بولۇش ئۈچۈن، ئۆزۈڭ باردىڭ»\bd* ــ تېكىستنىڭ ئېنىق مەنىسى شۇكى، ئىسرائىلنى مىسىردىن قۇتقۇزۇش ئۈچۈن خۇدا ئۆزى شەخسەن مىسىرغا بارغان. \bd «...ئۇلارنى... ئەللەردىن ۋە ئۇلارنىڭ ئىلاھلىرىدىن قۇتقۇزۇپ چىققان»\bd* ــ مۇشۇ ئىبارە بەلكىم خۇدانىڭ ئىسرائىل ئالدىدا پەلەستىن زېمىنىدا تۇرۇۋاتقان بۇتپەرەس ئەللەرنى قوغلىۋېتىشىنى كۆرسىتىشى مۇمكىن.\f*  \x ◘ \xo 7:23 \xt قان. 4‏:7، 34؛ 10‏:21؛ 33‏:29؛ زەب. 147‏:19-20\x*
\v 24 سەن خەلقىڭ ئىسرائىلنى ئۆزۈڭ ئۈچۈن ئەبەدگىچە بىر خەلق بولۇشقا بېكىتتىڭ؛ سەن، ئى پەرۋەردىگار، ئۇلارنىڭ خۇداسى بولدۇڭ.
\m 
\v 25 ئەمدى ھازىر، ئى پەرۋەردىگار خۇدا، ئۆز قۇلۇڭ ۋە ئۇنىڭ ئۆيى توغرىسىدا ئېيتقان ۋەدەڭگە ئەبەدگىچە مەزمۇت ئەمەل قىلغىن؛ سەن دېگەنلىرىڭ بويىچە ئىشنى ئادا قىلغايسەن!
\v 26 سېنىڭ نامىڭ ئەبەدگىچە ئۇلۇغلىنىپ: ــ ساماۋىي قوشۇنلارنىڭ سەردارى بولغان پەرۋەردىگار ئىسرائىلنىڭ ئۈستىدە تۇرىدىغان خۇدادۇر، دەپ ئېيتىلسۇن، شۇنداقلا ئۆز قۇلۇڭنىڭ ئۆي-سۇلالىسى سېنىڭ ئالدىڭدا مەزمۇت تۇرغۇزۇلسۇن.
\m 
\v 27 چۈنكى سەن، ئى ساماۋىي قوشۇنلارنىڭ سەردارى بولغان پەرۋەردىگار، ئىسرائىلنىڭ خۇداسى ئۆز قۇلۇڭغا: مەن ساڭا بىر ئۆي-سۇلالە قۇرۇپ بېرىمەن، دەپ ۋەھىي قىلدىڭ؛ شۇڭا قۇلۇڭ بۇ دۇئانى سېنىڭ ئالدىڭدا قىلىشقا جۈرئەت قىلدى.
\m 
\v 28 ئەمدى سەن، ئى رەب پەرۋەردىگار، بىردىنبىر خۇدادۇرسەن، سېنىڭ سۆزلىرىڭ ھەقىقەتتۇر ۋە سەن بۇ بەخت-ئىلتىپاتنى ئۆز قۇلۇڭغا ۋەدە قىلدىڭ؛ \x ◘ \xo 7:28 \xt يـۇھ. 17‏:17\x*
\v 29 شۇڭا قۇلۇڭنىڭ ئۆي-جەمەتىنى سېنىڭ ئالدىڭدا مەڭگۈ تۇرۇشقا نېسىپ قىلىپ بەرىكەتلىگەيسەن؛ چۈنكى سەن، ئى رەب پەرۋەردىگار، بۇنى ۋەدە قىلغانسەن؛ بۇ بەخت-ئىلتىپاتىڭ بىلەن ئۆز قۇلۇڭنىڭ ئۆي-جەمەتى ئەبەدگىچە بەخت-ئىلتىپاتقا نېسىپ بولىدۇ».
\b
\b
\c 8
\s1 داۋۇت ئەتراپىدىكى ئەللەرنى ئۆزىگە بېقىندۈرىدۇ
\r 1تار. 18‏:1-14
\m 
\v 1 بۇ ئىشلاردىن كېيىن شۇنداق بولدىكى، داۋۇت فىلىستىيلەرگە ھۇجۇم قىلىپ، ئۇلارنى بويسۇندۇردى. شۇنداق قىلىپ، داۋۇت فىلىستىيلەرنىڭ قولىدىن مەركىزىي شەھەرنىڭ ھوقۇقىنى ئالدى. \f ◼ \fr 8:1 \ft \bd «...مەركىزىي شەھەرنىڭ ھوقۇقىنى ئالدى»\bd* ــ ياكى «مەتتەگ-ئامماھ شەھىرىنى ئالدى».\f*
\m 
\v 2 ئۇ ھەم موئابىيلارغا ھۇجۇم قىلىپ، ئۇلارنىمۇ مەغلۇپ قىلدى. ئۇ ئۇلارنى يەرگە ياتقۇزۇپ، تانا بىلەن ئۆلچەپ، ئىككى تانا كەلگەنلەرنى ئۆلتۈردى، بىر تانا كەلگەنلەرنى تىرىك قالدۇردى. موئابىيلار بولسا داۋۇتقا بېقىنىپ، ئۇنىڭغا سېلىق تاپشۇردى.
\m 
\v 3 ئاندىن زوباھنىڭ پادىشاھى رەھوبنىڭ ئوغلى ھادادئېزەر ئەفرات دەرياسىغا چىقىپ، شۇ يەردىكى ھاكىمىيەتنى ئۆزىگە قايتىدىن تارتىۋالماقچى بولغاندا، داۋۇت ئۇنىڭغا ھۇجۇم قىلىپ، مەغلۇپ قىلدى.
\v 4 داۋۇت ئۇنىڭ قوشۇنىدىن بىر مىڭ يەتتە يۈز ئاتلىق ئەسكەرنى ۋە يىگىرمە مىڭ پىيادە ئەسكەرنى ئەسىر قىلدى؛ داۋۇت ھارۋا ئاتلىرىنىڭ پىيىنى كەستۈردى، لېكىن ئۆزىگە يۈز ھارۋىلىق ئاتنى قالدۇرۇپ قويدى. \f ◼ \fr 8:4 \ft \bd «بىر مىڭ يەتتە يۈز ئاتلىق ئەسكەر»\bd* ــ ياكى «بىر مىڭ يەتتە يۈز جەڭ ھارۋىسى».\f*  \x ◘ \xo 8:4 \xt 1تار. 18‏:4\x*
\m 
\v 5 دەمەشقتىكى سۇرىيلەر زوباھنىڭ پادىشاھى ھادادئېزەرگە ياردەم بېرىش ئۈچۈن چىقتى، لېكىن داۋۇت سۇرىيلەردىن يىگىرمە ئىككى مىڭ ئادەمنى ئۆلتۈردى. \f ◼ \fr 8:5 \ft \bd «دەمەشقتىكى سۇرىيلەر»\bd* ــ يەنى «دەمەشقتىكى سۇرىيەلىكلەر».\f*
\v 6 ئاندىن داۋۇت بىرنەچچە بارگاھ ئەسكەرلەرنى دەمەشقتىكى سۇرىيلەرنىڭ زېمىنىدا تۇرغۇزدى؛ شۇنىڭ بىلەن سۇرىيلەر داۋۇتقا بېقىنىپ ئۇنىڭغا سېلىق تاپشۇردى. داۋۇت قەيەرگە بارسا، پەرۋەردىگار ئۇنىڭغا نۇسرەت بېرەتتى. \f ◼ \fr 8:6 \ft \bd «سۇرىيلەر»\bd* ــ ياكى «ئارامىيلار». ھازىرقى سۇرىيەدىكىلەر ئۇلاردىن، يەنى ئارامىيلاردىن چىققان.\f*
\m 
\v 7 داۋۇت ھادادئېزەرنىڭ غۇلاملىرىغا تەمىنلەنگەن ئالتۇن قالقاننى تارتىۋېلىپ، يېرۇسالېمغا كەلتۈردى
\v 8 ۋە ھادادئېزەرنىڭ شەھەرلىرى بولغان بىتاھ بىلەن بىروتاي شەھەرلىرىدىنمۇ ئىنتايىن كۆپ مىسنى قولغا چۈشۈردى. \f ◼ \fr 8:8 \ft \bd «بىتاھ»\bd* ــ ياكى «تېباھ» ــ «1تار.» 8:18نى كۆرۈڭ.\f*
\m 
\v 9 خاماتنىڭ پادىشاھى توي داۋۇتنىڭ ھادادئېزەرنىڭ پۈتۈن قوشۇنىنى مەغلۇپ قىلغىنىنى ئاڭلاپ،
\v 10 ئۆز ئوغلى يورامنى داۋۇتنىڭ ھالىنى سوراشقا ۋە داۋۇتنىڭ ھادادئېزەر بىلەن جەڭ قىلىپ ئۇنى مەغلۇپ قىلغىنىغا ئۇنى تەبرىكلەشكە ئەۋەتتى. چۈنكى ھادادئېزەر دائىم توي بىلەن جەڭ قىلىپ كېلىۋاتاتتى. يورام بولسا كۈمۈش، ئالتۇن ۋە مىس قاچا-بۇيۇملارنى ئېلىپ كەلدى. \f ◼ \fr 8:10 \ft \bd «توي ... ئۆز ئوغلى يورامنى ... تەبرىكلەشكە ئەۋەتتى»\bd* ــ «1تار.» 10:18دە «يورام» «خادورام» دېگەن باشقا بىر ئىسىم بىلەن ئاتىلىدۇ.\f*
\v 11‏-12 داۋۇت پادىشاھ مۇشۇلارنى ۋە ئۆزى بېقىندۇرغان ھەممە ئەللەردىن، جۈملىدىن سۇرىيلەردىن، موئابىيلاردىن، ئاممونىيلاردىن، فىلىستىيلەردىن ۋە ئامالەكلەردىن ئولجا ئالغان ئالتۇن-كۈمۈشلەرنى پەرۋەردىگارغا ئاتاپ بېغىشلىدى. بۇلار زوباھنىڭ پادىشاھى رەھوبنىڭ ئوغلى ھادادئېزەردىن ئالغان ئولجىنى ئۆز ئىچىگە ئالىدۇ. \f ◼ \fr 8:11‏-12 \ft \bd «سۇرىيلەردىن»\bd* ــ ياكى «ئېدوملاردىن» ــ 14-ئايەتنى ۋە «1تار.» 11:18نى كۆرۈڭ.\f*
\m 
\v 13 داۋۇت سۇرىيلەرنى مەغلۇپ قىلىپ، يەنى ئون سەككىز مىڭ ئادەمنى «شور ۋادىسى»دا ئۆلتۈرۈپ يانغاندا، ئۇنىڭ نام-داڭقى خېلى چىققانىدى. \x ◘ \xo 8:13 \xt زەب. 60‏:1-4\x*
\v 14 ئۇ ئېدومدا ئەسكەر بارگاھلىرىنى تۇرغۇزدى؛ پۈتۈن ئېدومدا بارگاھلارنى قۇردى. شۇنىڭ بىلەن ئېدومىيلارنىڭ ھەممىسى داۋۇتقا بېقىندى. داۋۇت قەيەرگە بارسا، پەرۋەردىگار ئۇنىڭغا نۇسرەت بېرەتتى.
\m 
\v 15 داۋۇت پۈتكۈل ئىسرائىل ئۈستىگە سەلتەنەت قىلدى؛ ئۇ پۈتكۈل خەلقىنى سوراپ، ئادىل ھۆكۈملەر چىقىرىپ ئادالەت يۈرگۈزەتتى.
\b
\s1 ئوردا ئەمەلدارلىرى
\r 2سام. 20‏:23-26؛ 1تار. 18‏:15-17
\m 
\v 16 زەرۇئىيانىڭ ئوغلى يوئاب قوشۇننىڭ سەردارى بولدى؛ ئاھىلۇدنىڭ ئوغلى يەھوشافات مىرزا بولدى؛
\v 17 ئاخىتۇبنىڭ ئوغلى زادوك بىلەن ئابىياتارنىڭ ئوغلى ئاخىمەلەك كاھىن بولدى؛ سېرايا كاتىپ بولدى.
\v 18 يەھويادانىڭ ئوغلى بىنايا كەرەتىيلەر بىلەن پەلەتىيلەرنىڭ يولباشچىسى بولدى؛ داۋۇتنىڭ ئوغۇللىرىمۇ كاھىن بولدى. \f ◼ \fr 8:18 \ft \bd «كەرەتىيلەر بىلەن پەلەتىيلەر»\bd* ــ بەلكىم داۋۇتقا ئالاھىدە مۇھاپىزەتچىلەر ياكى ئالاھىدە زەربىدار ئەسكەرلەر بولغان بولۇشى مۇمكىن ئىدى. \bd «داۋۇتنىڭ ئوغۇللىرىمۇ كاھىن بولدى»\bd* ــ مۇشۇ يەردە «كاھىن» بەلكىم (1) ئۇلارنىڭ خۇدانىڭ ئىبادىتىدە ئادەتتىكى كاھىنلاردىن باشقا ئالاھىدە ۋەزىپىلىرى بارلىقىنى؛ (2) ھاكىمىيەتتە بىرخىل ۋەزىرلىكىنى كۆرسىتىشى مۇمكىن («1تار.» 17:18نىمۇ كۆرۈڭ).\f*
\b
\b
\c 9
\s1 مەفىبوشەتكە شەپقەت كۆرسىتىش
\m 
\v 1 داۋۇت: سائۇلنىڭ ئۆيىدىن تىرىك قالغان بىرەرسى بارمىكىن، بار بولسا مەن يوناتاننىڭ ھۆرمىتىدە ئۇنىڭغا شاپائەت كۆرسىتەي؟ ــ دېدى.
\m 
\v 2 ئەمدى سائۇلنىڭ ئائىلىسىدىكى زىبا دېگەن بىر خىزمەتكار قالغانىدى. ئۇلار ئۇنى داۋۇتنىڭ قېشىغا چاقىردى. كەلگەندە، پادىشاھ ئۇنىڭدىن: سەن زىبامۇ؟ دەپ سورىدى. ئۇ: پېقىر مەن شۇ! ــ دېدى. \x ◘ \xo 9:2 \xt 2سام. 16‏:1-4؛ 19‏:17\x*
\m 
\v 3 پادىشاھ: سائۇلنىڭ ئائىلىسىدىن بىرەرسى تىرىك قالدىمۇ؟ مەن ئۇنىڭغا خۇدانىڭ شاپائىتىنى كۆرسىتەي دەۋاتىمەن، ــ دېدى. زىبا پادىشاھقا: يوناتاننىڭ بىر ئوغلى تىرىك قالدى؛ ئۇنىڭ ئىككى پۇتى ئاقسايدۇ ــ دېدى. \f ◼ \fr 9:3 \ft \bd «يوناتاننىڭ بىر ئوغلى تىرىك قالدى؛ ئۇنىڭ ئىككى پۇتى ئاقسايدۇ»\bd* ــ زىبانىڭ بۇ سۆزنى دېيىشى، بەلكىم، داۋۇتنىڭ سائۇلنىڭ جەمەتىدىكىلەرنى ئىزدەشتىكى مەقسىتى ئۆز تەختىگە ھېچقانداق تەھدىت بولماسلىقى ئۈچۈن، ئۇلارنى يوقىتىش، دەپ ئويلىسا كېرەك؛ شۇڭا ئۇ مەفىبوشەتنى ئاقساق دەيدۇ ــ ئاقساق بىر ئادەم تەختكە ھېچقانداق تەھدىت بولمايدۇ، ئەلۋەتتە.\f*  \x ◘ \xo 9:3 \xt 2سام. 4‏:4\x*
\m 
\v 4 پادىشاھ ئۇنىڭدىن: ئۇ قەيەردە، دەپ سورىدى. زىبا پادىشاھقا: ئۇ لو-دىباردا، ئاممىئەلنىڭ ئوغلى ماكىرنىڭ ئۆيىدە تۇرىدۇ ــ دېدى.
\m 
\v 5 شۇڭا داۋۇت پادىشاھ كىشى ئەۋەتىپ ئۇنى لو-دىباردىن، ئاممىئەلنىڭ ئوغلى ماكىرنىڭ ئۆيىدىن ئېلىپ كەلدى.
\m 
\v 6 سائۇلنىڭ نەۋرىسى، يوناتاننىڭ ئوغلى مەفىبوشەت داۋۇتنىڭ ئالدىغا كەلگەندە، يۈزىنى يەرگە يىقىپ، تەزىم قىلدى. داۋۇت: \add سەن\add* مەفىبوشەتمۇ؟ ــ دەپ چاقىرىۋىدى، ئۇ: پېقىر شۇ! ــ دەپ جاۋاپ قايتۇردى.
\m 
\v 7 داۋۇت ئۇنىڭغا: قورقمىغىن، ئاتاڭ يوناتان ئۈچۈن، ساڭا شاپائەت قىلماي قالمايمەن؛ بوۋاڭ سائۇلنىڭ ھەممە يەر-زېمىنلىرىنى ساڭا قايتۇرۇپ بېرەي، سەن ھەمىشە مېنىڭ داستىخىنىمدىن غىزالىنىسەن ــ دېدى. \f ◼ \fr 9:7 \ft \bd «بوۋاڭ سائۇل»\bd* ــ ئىبرانىي تىلىدا «ئاتاڭ سائۇل» دېگەن سۆز بىلەن ئىپادىلىنىدۇ. «ئاتا» دېگەننىڭ ئىبرانىي تىلىدا مەنىسى كەڭدۇر.\f*
\m 
\v 8 مەفىبوشەت تەزىم قىلىپ: قۇلۇڭ نېمە ئىدى، مەندەك بىر ئۆلۈك ئىت ئالىيلىرى قەدىرلىگۈدەك نېمە ئىدىم؟ ــ دېدى.
\m 
\v 9 ئاندىن پادىشاھ سائۇلنىڭ خىزمەتكارى زىبانى چاقىرىپ ئۇنىڭغا: سائۇلنىڭ ۋە پۈتكۈل ئائىلىسىنىڭ ھەممە تەئەللۇقاتىنى مانا مەن غوجاڭنىڭ ئوغلىنىڭ قولىغا بەردىم.
\v 10 سەن بىلەن ئوغۇللىرىڭ ۋە خىزمەتكارلىرىڭ ئۇنىڭ ئۈچۈن شۇ زېمىندا تېرىقچىلىق قىلىپ، چىققان مەھسۇلاتلىرىنى غوجاڭنىڭ ئوغلىغا يېيىشكە تاپشۇرۇڭلار. غوجاڭنىڭ ئوغلى مەفىبوشەت مەن بىلەن ھەمىشە ھەمداستىخان بولۇپ غىزالىنىدۇ، ــ دېدى (زىبانىڭ ئون بەش ئوغلى ۋە يىگىرمە خىزمەتكارى بار ئىدى).
\m 
\v 11 زىبا پادىشاھقا: غوجام پادىشاھ قۇللىرىغا بۇيرۇغاننىڭ ھەممىسىگە كەمىنىلىرى ئەمەل قىلىدۇ، ــ دېدى. پادىشاھ داۋۇت \add يەنە\add*: مەفىبوشەت بولسا پادىشاھنىڭ بىر ئوغلىدەك داستىخىنىمدىن تائام يېسۇن ــ \add دېدى\add*.
\m 
\v 12 مەفىبوشەتنىڭ مىكا دېگەن كىچىك بىر ئوغلى بار ئىدى. زىبانىڭ ئۆيىدە تۇرۇۋاتقانلارنىڭ ھەممىسى مەفىبوشەتنىڭ خىزمەتكارلىرى بولدى.
\v 13 ئەمدى مەفىبوشەت يېرۇسالېمدا تۇراتتى؛ چۈنكى ئۇ ھەمىشە پادىشاھنىڭ داستىخىنىدىن تائام يەپ تۇراتتى. ئۇنىڭ ئىككى پۇتى ئاقساق ئىدى.
\b
\b
\c 10
\s1 داۋۇت ۋە ئاممونىيلار
\r 1تار. 19‏:1-19
\m 
\v 1 كېيىن شۇنداق ئىش بولدىكى، ئاممونىيلارنىڭ پادىشاھى ئۆلدى ۋە ئۇنىڭ ھانۇن دېگەن ئوغلى ئورنىدا پادىشاھ بولدى.
\m 
\v 2 داۋۇت بولسا: ئۇنىڭ ئاتىسى ماڭا ئىلتىپات كۆرسەتكەندەك مەن ناھاشنىڭ ئوغلى ھانۇنغا ئىلتىپات كۆرسىتەي، ــ دېدى. ئاندىن داۋۇت ئاتىسىنىڭ پەتىسىگە \add ھانۇننىڭ\add* كۆڭلىنى سوراشقا ئۆز خىزمەتكارلىرىدىن بىرنەچچىنى ماڭدۇردى. داۋۇتنىڭ خىزمەتكارلىرى ئاممونىيلارنىڭ زېمىنىغا كەلگەندە،
\v 3 ئاممونىيلارنىڭ ئەمەلدارلىرى غوجىسى ھانۇنغا: سىلى داۋۇتنى راستلا ئاتىلىرىنىڭ ھۆرمىتى ئۈچۈن قاشلىرىغا كۆڭۈل سوراپ ئادەم ئەۋەتىپتۇ، دەپ قاراملا؟ داۋۇتنىڭ خىزمەتكارلىرىنى قاشلىرىغا ئەۋەتكىنى شەھەرنى پايلاپ ئۇنىڭدىن مەلۇمات ئېلىش، ئاندىن بۇ شەھەرنى ئاغدۇرۇش ئۈچۈن ئەمەسمۇ؟ ــ دېدى.
\m 
\v 4 شۇنىڭ بىلەن ھانۇن داۋۇتنىڭ خىزمەتكارلىرىنى تۇتۇپ، ساقاللىرىنىڭ يېرىمىنى چۈشۈرۈپ، كىيىملىرىنىڭ بەلدىن تۆۋىنىنى كەستۈرۈپ، كۆتىنى ئېچىپ كەتكۈزۈۋەتتى.
\v 5 بۇ خەۋەر داۋۇتقا يەتكۈزۈلدى؛ ئۇ ئۇلارنى كۈتۈۋېلىشقا ئالدىغا ئادەم ماڭدۇردى؛ چۈنكى ئۇلار ئىنتايىن نومۇس ھېس قىلغانىدى. پادىشاھ ئۇلارغا: ساقال-بۇرۇتۇڭلار ئۆسكىچىلىك يېرىخو شەھىرىدە تۇرۇپ، ئاندىن يېنىپ كېلىڭلار، ــ دېدى.
\m 
\v 6 ئاممونىيلار ئۆزلىرىنىڭ داۋۇتنىڭ نەپرىتىگە ئۇچرىغانلىقىنى بىلىپ، ئادەم ئەۋەتىپ بەيت-رەھوبدىكى سۇرىيلەر بىلەن زوباھدىكى سۇرىيلەردىن يىگىرمە مىڭ پىيادە ئەسكەر، مائاكاھنىڭ پادىشاھىدىن بىر مىڭ ئادەم ۋە توبدىكى ئادەملەردىن ئون ئىككى مىڭ ئادەمنى ياللاپ كەلدى.
\v 7 داۋۇت بۇنى ئاڭلاپ، يوئابنىڭ پۈتكۈل جەڭگىۋار قوشۇنىنى \add ئۇلارنىڭ ئالدىغا\add* ماڭدۇردى.
\v 8 ئاممونىيلار چىقىپ شەھەرنىڭ دەرۋازىسىنىڭ ئالدىدا سەپ تۈزدى؛ زوباھ بىلەن رەھوبدىكى سۇرىيلەر ۋە توب بىلەن مائاكاھنىڭ ئادەملىرى دالادا سەپ تۈزدى؛ \f ◼ \fr 10:8 \ft \bd «شەھەرنىڭ دەرۋازىسى»\bd* ــ «شەھەر» بەلكىم ئۇلارنىڭ پايتەختى رابباھنى كۆرسىتىدۇ (14-ئايەتنى كۆرۈڭ).\f*
\v 9 يوئاب جەڭنىڭ ئالدى ھەم كەينىدىن بولىدىغانلىقىغا كۆزى يېتىپ، ئىسرائىلدىن بىر قىسىم سەرخىل ئادەملەرنى ئىلغاپ، سۇرىيەلەرگە قارشى سەپ تۈزدى؛
\v 10 قالغانلارنى ئاممونىيلارغا قارشى سەپ تىزغىن دەپ ئىنىسى ئابىشاينىڭ قولىغا تاپشۇرۇپ، ئۇنىڭغا:
\m 
\v 11 ــ ئەگەر سۇرىيلەر ماڭا كۈچلۈك كەلسە، سەن ماڭا ياردەم بەرگەيسەن؛ ئەمما ئاممونىيلار ساڭا كۈچلۈك كەلسە، مەن بېرىپ ساڭا ياردەم بېرەي.
\v 12 جۈرئەتلىك بولغىن! ئۆز خەلقىمىز ئۈچۈن ۋە خۇدايىمىزنىڭ شەھەرلىرى ئۈچۈن باتۇرلۇق قىلايلى. پەرۋەردىگار ئۆزىگە لايىق كۆرۈنگىنىنى قىلغاي! ــ دېدى.
\m 
\v 13 ئەمدى يوئاب ۋە ئۇنىڭ بىلەن بولغان ئادەملەر سۇرىيلەرگە ھۇجۇم قىلغىلى چىقتى؛ سۇرىيلەر ئۇنىڭ ئالدىدا قاچتى.
\v 14 ئاممونىيلار سۇرىيلەرنىڭ قاچقىنىنى كۆرگەندە، ئۇلارمۇ ئابىشايدىن قېچىپ، شەھەرگە كىرىۋالدى. يوئاب بولسا ئاممونىيلار بىلەن جەڭ قىلىشتىن چېكىنىپ، يېرۇسالېمغا يېنىپ كەلدى.
\m 
\v 15 سۇرىيلەر بولسا ئۆزلىرىنىڭ ئىسرائىللارنىڭ ئالدىدا مەغلۇپ بولغىنىنى كۆرگەندە، يەنە جەم بولۇشتى.
\v 16 ھادادئېزەر ئادەملەرنى ئەۋەتىپ، \add ئەفرات\add* دەرياسىنىڭ نېرى تەرىپىدىكى سۇرىيلەرنى \add ياردەمگە\add* چاقىرىپ، ئۇلارنى يۆتكەپ كەلدى؛ ئۇلار خېلام شەھىرىگە كەلگەندە، ھادادئېزەرنىڭ قوشۇنىنىڭ سەردارى شوباك ئۇلارغا باشچىلىق قىلدى.
\m 
\v 17 بۇ خەۋەر داۋۇتقا يەتكەندە، ئۇ پۈتكۈل ئىسرائىلنى يىغدۇرۇپ، ئىئوردان دەرياسىدىن ئۆتۈپ، خېلام شەھىرىگە باردى. سۇرىيلەر داۋۇتقا قارشى سەپ تىزىپ، ئۇنىڭغا ھۇجۇم قىلدى.
\v 18 سۇرىيلەر يەنە ئىسرائىلدىن قاچتى. داۋۇت بولسا يەتتە يۈز جەڭ ھارۋىلىقنى، قىرىق مىڭ ئاتلىق ئەسكەرنى قىردى ھەم قوشۇنىنىڭ سەردارى شوباكنى ئۇ يەردە ئۆلتۈردى. \f ◼ \fr 10:18 \ft \bd «قىرىق مىڭ ئاتلىق ئەسكەر»\bd* ــ ياكى «قىرىق مىڭ پىيادە ئەسكەرنى» ــ «1تار.» 18:19نى كۆرۈڭ. شۇ يەردە «يەتتە مىڭ جەڭ ھارۋىسى» دېيىلىدۇ. پەرقىنىڭ سەۋەبى بەلكىم: (1) قولىمىزدىكى كۆچۈرمىلەردە كۆچۈرگۈچىنىڭ سەۋەنلىكى بولۇشى مۇمكىن؛ (2) ئىككى ئايەتتە خاتىرىلەنگەن سانلارنى ھېسابلاش نۇقتىسى ئوخشىمايدىغان بولۇشى مۇمكىن.\f*
\m 
\v 19 ھادادئېزەرگە بېقىنغان ھەممە پادىشاھلار ئۆزلىرىنىڭ ئىسرائىل ئالدىدا يېڭىلگىنىنى كۆرگەندە، ئىسرائىل بىلەن سۈلھ قىلىشىپ ئۇلارغا بېقىندى. شۇنىڭدىن كېيىن سۇرىيلەر ئاممونىيلارغا يەنە ياردەم بىرىشكە جۈرئەت قىلالمىدى.
\b
\b
\c 11
\s1 داۋۇتنىڭ ئېغىر گۇناھى
\m 
\v 1 شۇنداق بولدىكى، يېڭى يىلنىڭ بېشىدا، پادىشاھلار جەڭگە ئاتلانغان ۋاقىتتا داۋۇت يوئابنى ئادەملىرى بىلەن ھەمدە ھەممە ئىسرائىلنى جەڭگە ماڭدۇردى؛ ئۇلار ئاممونىيلارنىڭ زېمىنىنى ۋەيران قىلىپ، رابباھ شەھىرىنى مۇھاسىرىگە ئالدى. لېكىن داۋۇت يېرۇسالېمدا قالدى. \f ◼ \fr 11:1 \ft \bd «يېڭى يىلنىڭ بېشىدا»\bd* ــ خۇدا يەھۇدىي خەلقىگە تاپشۇرغان كالېندار بويىچە «يېڭى يىل» ئەتىيازدا باشلىناتتى («مىس.» 1:12).\f*  \x ◘ \xo 11:1 \xt 1تار. 20‏:1-3\x*
\m 
\v 2 بىر كۈنى كەچتە داۋۇت كارىۋاتتىن قوپۇپ، پادىشاھ ئوردىسىنىڭ ئۆگىزىسىدە ئايلىنىپ يۈرەتتى؛ ئۆگزىدىن ئۇ مۇنچىدا يۇيۇنۇۋاتقان بىر ئايالنى كۆردى. بۇ ئايال بەك چىرايلىق ئىدى.
\v 3 داۋۇت ئادەم ئەۋەتىپ، ئايالنىڭ خەۋىرىنى سورىدى؛ بىرسى ئۇنىڭغا: ــ بۇ ئېلىئامنىڭ قىزى، ھىتتىي ئۇرىيانىڭ ئايالى بات-شېبا ئەمەسمۇ؟ ــ دېدى.
\m 
\v 4 داۋۇت كىشى ئەۋەتىپ، ئۇنى قېشىغا ئەكەلتۈردى (ئۇ ۋاقىتتا ئۇ ئادەتتىن پاكلىنىۋاتقانىدى). ئۇ ئۇنىڭ قېشىغا كەلگەندە، داۋۇت ئۇنىڭ بىلەن بىللە بولدى؛ ئاندىن ئۇ ئۆز ئۆيىگە يېنىپ كەتتى. \f ◼ \fr 11:4 \ft \bd «ئۇ ۋاقىتتا ئۇ ئادەتتىن پاكلىنىۋاتقانىدى»\bd* ــ ياكى «ئۇ ۋاقىتتا ئۇ يېڭىلا پاكلانغانىدى». مۇساغا چۈشۈرۈلگەن قانۇن بويىچە («لاۋ.» 19:15-20) ئەر كىشىنىڭ ئۆز ئايالىنىڭ ئادەت ۋاقتىدا (7 كۈن ھېسابلىناتتى) ئۇنىڭ بىلەن بىللە يېتىشىغا بولمايتتى، بولمىسا ئۇ ئىبادەتكە نىسبەتەن «ناپاك» قىلىناتتى (ئايال كىشىنىڭ «ئادەتتىن يېڭىلا پاكلانغان» ۋاقتىدا ھامىلىدار بولۇشى ئەڭ مۇمكىن بولغان ۋاقىت، ئەلۋەتتە). «پاك» بولسۇن «ناپاك» بولسۇن باشقا بىرسىنىڭ ئايالىغا تېگىش ئىنتايىن ئېغىر گۇناھدۇر، ئەلۋەتتە.\f*  \x ◘ \xo 11:4 \xt لاۋ. 15‏:19-24؛ 18‏:19\x*
\m 
\v 5 شۇنىڭ بىلەن ئۇ ئايال ھامىلىدار بولدى، ھەم داۋۇتقا: مېنىڭ بويۇمدا قاپتۇ، دەپ خەۋەر ئەۋەتتى.
\m 
\v 6 شۇنىڭ بىلەن داۋۇت يوئابقا خەۋەر يەتكۈزۈپ: ھىتتىي ئۇرىيانى مېنىڭ قېشىمغا ئەۋەتىڭلار، دېدى. يوئاب ئۇرىيانى داۋۇتنىڭ قېشىغا ماڭدۇردى.
\v 7 ئۇرىيا داۋۇتنىڭ قېشىغا كەلگەندە، ئۇ يوئابنىڭ ھالىنى، خەلقنىڭ ھالىنى ۋە جەڭ ئەھۋالىنى سورىدى.
\v 8 ئاندىن داۋۇت ئۇرىياغا: ئۆز ئۆيۈڭگە بېرىپ پۇتلىرىڭنى يۇغىن، دېدى. ئۇرىيا پادىشاھنىڭ ئوردىسىدىن چىققاندا، پادىشاھ كەينىدىن ئۇنىڭغا بىر سوۋغا ئەۋەتتى. \f ◼ \fr 11:8 \ft \bd «ئۆز ئۆيۈڭگە بېرىپ...»\bd* ــ ئىبرانىي تىلىدا «ئۆز ئۆيۈڭگە چۈشۈپ» ــ ئوردا يېرۇسالېمنىڭ بەك يۇقىرى بىر جايىدا ئىدى. \bd «پۇتلىرىڭنى يۇغىن...»\bd* ــ دېمەك، «راھەتلەن».\f*
\v 9 لېكىن ئۇرىيا ئۆز ئۆيىگە بارماي، پادىشاھنىڭ ئوردىسىنىڭ دەرۋازىسىدا، غوجىسىنىڭ باشقا قۇل-خىزمەتكارلىرىنىڭ ئارىسىدا ياتتى.
\m 
\v 10 ئۇلار داۋۇتقا: ئۇرىيا ئۆز ئۆيىگە بارمىدى، دەپ خەۋەر بەردى. داۋۇت ئۇرىيادىن: سەن يىراق سەپەردىن كەلدىڭ ئەمەسمۇ؟ نېمىشقا ئۆز ئۆيۈڭگە كەتمىدىڭ؟ ــ دەپ سورىدى.
\m 
\v 11 ئۇرىيا داۋۇتقا: مانا، ئەھدە ساندۇقى، ئىسرائىللار ۋە يەھۇدالار بولسا كەپىلەردە تۇرۇپ، غوجام يوئاب بىلەن غوجامنىڭ خىزمەتكارلىرى ئوچۇق دالادا چېدىر تىكىپ يېتىۋاتسا، مەن يەپ-ئىچىپ، ئايالىم بىلەن يېتىشقا ئۆيۈمگە بارايمۇ؟ سېنىڭ جېنىڭ بىلەن ۋە ھاياتىڭ بىلەن قەسەم قىلىمەنكى، مەن ئۇنداق ئىشنى قىلمايمەن ــ دېدى.
\m 
\v 12 داۋۇت ئۇرىياغا: بۈگۈن بۇ يەردە قالغىن، ئەتە سېنى كەتكۈزۈۋېتىمەن، ــ دېدى. ئۇرىيا ئۇ كۈنى ۋە ئەتىسى يېرۇسالېمدا قالدى.
\v 13 داۋۇت ئۇنى چاقىرىپ ھەمداستىخان قىلىپ، يەپ-ئىچكۈزۈپ مەست قىلدى. لېكىن شۇ كېچىسى ئۇرىيا ئۆز ئۆيىگە بارماي، چىقىپ غوجىسىنىڭ قۇل-خىزمەتكارلىرىنىڭ ئارىسىدا ئۆز كارىۋىتىدا ئۇخلىدى.
\m 
\v 14 ئەتىسى داۋۇت يوئابقا خەت يېزىپ، ئۇرىيانىڭ ئالغاچ كېتىشىگە بەردى.
\v 15 خەتتە ئۇ: ئۇرىيانى سوقۇش ئەڭ كەسكىن بولىدىغان ئالدىنقى سەپتە تۇرغۇزغىن، ئاندىن ئۇنىڭ ئۆلتۈرۈلۈشى ئۈچۈن ئۇنىڭدىن چېكىنىپ تۇرۇڭلار، دەپ يازغانىدى.
\m 
\v 16 شۇنىڭ بىلەن يوئاب شەھەرنى كۆزىتىپ، ئۇرىيانى پالۋانلار \add كەسكىن سوقۇشقان\add* يەرگە ماڭدۇردى.
\v 17 شەھەردىكى ئادەملەر چىقىپ، يوئاب بىلەن سوقۇشقاندا خەلقتىن، يەنى داۋۇتنىڭ ئادەملىرىدىن بىرنەچچىسى يىقىلدى؛ ئۇرىيامۇ ئۆلدى.
\m 
\v 18 يوئاب ئادەم ئەۋەتىپ جەڭنىڭ ھەممە ۋەقەلىرىدىن داۋۇتقا خەۋەر بەردى.
\v 19 ئۇ خەۋەرچىگە مۇنداق تاپىلىدى: پادىشاھقا جەڭنىڭ ھەممە ۋەقەلىرىنى دەپ بولغىنىڭدا،
\v 20 ئەگەر پادىشاھ غەزەپلىنىپ سېنىڭدىن: سوقۇشقاندا نېمىشقا شەھەر سېپىلىغا شۇنداق يېقىن باردىڭلار؟ ئۇلارنىڭ سېپىلىدىن يا ئاتىدىغانلىقىنى بىلمەمتىڭلار؟
\v 21 يەرۇببەشەتنىڭ ئوغلى ئابىمەلەكنى كىم ئۆلتۈرگىنىنى بىلمەمسەن؟ بىر خوتۇن سېپىلدىن ئۇنىڭغا بىر پارچە يارغۇنچاق تېشىنى ئېتىپ، ئۇ تەبەز شەھىرىدە ئۆلمىدىمۇ؟ نېمىشقا سېپىلغا ئۇنداق يېقىن باردىڭلار؟ ــ دېسە، سەن: سىلىنىڭ قۇللىرى ھىتتىي ئۇرىيامۇ ئۆلدى، دەپ ئېيتقىن ــ دېدى. \f ◼ \fr 11:21 \ft \bd «بىر خوتۇن سېپىلدىن ئۇنىڭغا بىر پارچە يارغۇنچاق تېشىنى ئېتىپ، ئۇ ... ئۆلمىدىمۇ؟»\bd* ــ بۇ ۋەقە «ھاك.» 50:9-57دە تېپىلىدۇ.\f*  \x ◘ \xo 11:21 \xt ھاك. 9‏:52، 53\x*
\m 
\v 22 خەۋەرچى بېرىپ يوئاب ئۇنىڭغا تاپشۇرۇپ ئەۋەتكەن خەۋەرنىڭ ھەممىسىنى داۋۇتقا دەپ بەردى.
\v 23 خەۋەرچى داۋۇتقا: دۈشمەنلەر بىزدىن كۈچلۈك كېلىپ، دالادا بىزگە ھۇجۇم قىلدى؛ لېكىن بىز ئۇلارغا زەربە بېرىپ چېكىندۈرۈپ، شەھەرنىڭ دەرۋازىسىغىچە قوغلىدۇق.
\v 24 ئاندىن يا ئاتقۇچىلار سېپىلدىن قۇل-خىزمەتكارلىرىڭغا يا ئېتىپ، پادىشاھنىڭ قۇل-خىزمەتكارلىرىدىن بىرنەچچىنى ئۆلتۈردى. قۇللىرى ئۇرىيامۇ ئۆلدى ــ دېدى.
\m 
\v 25 داۋۇت خەۋەرچىگە: يوئابقا مۇنداق دېگىن: ــ بۇ ئىش نەزىرىڭدە ئېغىر بولمىسۇن، قىلىچ يا ئۇنى يا بۇنى يەيدۇ؛ شەھەرگە بولغان ھۇجۇمىڭلارنى قاتتىق قىلىپ، ئۇنى غۇلىتىڭلار، دەپ ئېيتىپ ئۇنى جۈرئەتلەندۈرگىن ــ دېدى.
\m 
\v 26 ئۇرىيانىڭ ئايالى ئېرى ئۇرىيانىڭ ئۆلگىنىنى ئاڭلاپ، ئېرى ئۈچۈن ماتەم تۇتتى.
\m 
\v 27 ماتەم كۈنلىرى ئۆتكەندە داۋۇت ئادەم ئەۋەتىپ ئۇنى ئوردىسىغا كەلتۈردى. شۇنىڭ بىلەن ئۇ داۋۇتنىڭ ئايالى بولۇپ، ئۇنىڭغا بىر ئوغۇل تۇغدى. لېكىن داۋۇتنىڭ قىلغان ئىشى پەرۋەردىگارنىڭ نەزىرىدە رەزىل ئىدى.
\b
\b
\c 12
\s1 ناتان پەيغەمبەر داۋۇتقا تەنبىھ بېرىدۇ
\m 
\v 1 پەرۋەردىگار ناتاننى داۋۇتنىڭ قېشىغا ماڭدۇردى. ئۇ داۋۇتنىڭ قېشىغا كېلىپ ئۇنىڭغا مۇنداق دېدى: «بىر شەھەردە ئىككى ئادەم بار بولۇپ، بىرسى باي، يەنە بىرسى كەمبەغەل ئىدى.
\v 2 باينىڭ ئىنتايىن تولا قوي ۋە كالا پادىلىرى بار ئىدى.
\v 3 لېكىن كەمبەغەلنىڭ ئۆزى سېتىۋېلىپ باققان كىچىك بىر ساغلىق قوزىدىن باشقا بىر نەرسىسى يوق ئىدى. قوزا كەمبەغەلنىڭ ئۆيىدە بالىلىرى بىلەن تەڭ ئۆسۈپ چوڭ بولدى. قوزا ئۇنىڭ يېگىنىدىن يەپ، ئۇنىڭ ئىچكىنىدىن ئىچىپ، ئۇنىڭ قۇچىقىدا ئۇخلىدى؛ ئۇنىڭ نەزىرىدە ئۇ ئۆز قىزىدەك ئىدى.
\v 4 بىر كۈنى بىر يولۇچى باينىڭكىگە كەلدى. ئەمما ئۇ ئۆزىگە كەلگەن مېھمان ئۈچۈن ئۆزىنىڭ قوي ياكى كالا پادىلىرىدىن بىرىنى يېگۈزۈشكە تەييارلاشقا كۆزى قىيماي، بەلكى كەمبەغەلنىڭ قوزىسىنى تارتىۋېلىپ سويۇپ، كەلگەن مېھمان ئۈچۈن تەييارلىدى».
\m 
\v 5 داۋۇت بۇنى ئاڭلاپ ئۇ كىشىگە قاتتىق غەزەپلەندى. ئۇ ناتانغا: پەرۋەردىگارنىڭ ھاياتى بىلەن \add قەسەم قىلىمەنكى\add*، شۇنى قىلغان ئادەم ئۆلۈمگە لايىقتۇر!
\v 6 ئۇ ھېچ رەھىمدىللىق كۆرسەتمەي بۇ ئىشنى قىلغىنى ئۈچۈن قوزىغا تۆت ھەسسە تۆلەم تۆلىسۇن ــ دېدى. \f ◼ \fr 12:6 \ft \bd «بۇ ئىشنى قىلغىنى ئۈچۈن قوزىغا تۆت ھەسسە تۆلەم تۆلىسۇن»\bd* ــ «مىس.» 1:22نى كۆرۈڭ.\f*  \x ◘ \xo 12:6 \xt مىس. 22‏:1\x*
\m 
\v 7 ناتان داۋۇتقا: سەن دەل شۇ كىشىدۇرسەن! ئىسرائىلنىڭ خۇداسى پەرۋەردىگار مۇنداق دەيدۇ: «مەن سېنى ئىسرائىلنىڭ ئۈستىدە پادىشاھ بولغىلى مەسىھ قىلدىم ۋە سائۇلنىڭ قولىدىن قۇتقۇزدۇم؛ \x ◘ \xo 12:7 \xt 1سام. 16‏:13\x*
\v 8 مەن غوجاڭنىڭ جەمەتىنى ساڭا بېرىپ، غوجاڭنىڭ ئاياللىرىنى قۇچىقىڭغا ياتقۇزۇپ، ئىسرائىلنىڭ جەمەتى بىلەن يەھۇدانىڭ جەمەتىنى ساڭا بەردىم. ئەگەر سەن بۇنى ئاز كۆرگەن بولساڭ، مەن ساڭا يەنە ھەسسىلەپ بېرەتتىم؛ \f ◼ \fr 12:8 \ft \bd «مەن غوجاڭنىڭ جەمەتىنى ساڭا بېرىپ، غوجاڭنىڭ ئاياللىرىنى قۇچىقىڭغا ياتقۇزۇپ...»\bd* ــ «غوجاڭ» سائۇل پادىشاھنى كۆرسىتىدۇ.\f*
\v 9 نېمىشقا پەرۋەردىگارنىڭ سۆزىنى كۆزگە ئىلماي، ئۇنىڭ نەزىرىدە رەزىل بولغاننى قىلدىڭ؟ سەن ھىتتىي ئۇرىيانى قىلىچ بىلەن ئۆلتۈرگۈزۈپ، ئۇنىڭ ئايالىنى ئۆزۈڭگە ئايال قىلدىڭ، سەن ئۇنى ئاممونىيلارنىڭ قىلىچى بىلەن قەتل قىلدىڭ.
\v 10 ئەمدى سەن مېنى كۆزگە ئىلماي، ھىتتىي ئۇرىيانىڭ ئايالىنى ئۆزۈڭگە ئايال قىلغىنىڭ ئۈچۈن، قىلىچ سېنىڭ ئۆيۈڭدىن قەتئىي ئايرىلمايدۇ».
\m 
\v 11 پەرۋەردىگار مۇنداق دەيدۇ: ــ «مانا ئۆز ئۆيۈڭدىن ساڭا يامانلىق كەلتۈرۈپ، كۆزلىرىڭنىڭ ئالدىدا ئاياللىرىڭنى ئېلىپ، ساڭا يېقىن بىرسىگە بېرىمەن، ئۇ بولسا كۈپكۈندۈزدە ئاياللىرىڭ بىلەن ياتىدۇ. \x ◘ \xo 12:11 \xt قان. 28‏:30؛ 2سام. 16‏:22\x*
\v 12 سەن بولساڭ ئۇ ئىشنى مەخپىي قىلدىڭ، لېكىن مەن بۇ ئىشنى پۈتكۈل ئىسرائىلنىڭ ئالدىدا كۈندۈزدە قىلىمەن» ــ دېدى.
\m 
\v 13 داۋۇت ناتانغا: ــ مەن پەرۋەردىگارنىڭ ئالدىدا گۇناھ قىلدىم ــ دېدى. ناتان داۋۇتقا: پەرۋەردىگار ھەم گۇناھىڭدىن ئۆتتى؛ سەن ئۆلمەيسەن.
\v 14 ھالبۇكى، بۇ ئىش بىلەن پەرۋەردىگارنىڭ دۈشمەنلىرىگە كۇپۇرلۇق قىلىشقا پۇرسەت بەرگىنىڭ ئۈچۈن، سېنىڭدىن تۇغۇلغان ئوغۇل بالا چوقۇم ئۆلىدۇ ، ــ دېدى.
\m 
\v 15 شۇنىڭ بىلەن ناتان ئۆز ئۆيىگە قايتىپ كەتتى. پەرۋەردىگار ئۇرىيانىڭ ئايالىدىن داۋۇتقا تۇغۇلغان بالىنى شۇنداق ئۇردىكى، ئۇ قاتتىق كېسەل بولدى.
\m 
\v 16 داۋۇت بالا ھەققىدە خۇداغا يېلىندى. ئۇ روزا تۇتۇپ، كېچىلەردە ئىچكىرىگە كىرىپ يەردە دۈم ياتاتتى. \f ◼ \fr 12:16 \ft \bd «ئۇ روزا تۇتۇپ، كېچىلەردە ئىچكىرىگە كىرىپ يەردە دۈم ياتاتتى»\bd* ــ ياكى «ئۇ روزا تۇتۇپ، كېچىدە ئىچكىرىگە كىرىپ يەردە دۈم ياتتى».\f*
\v 17 ئۇنىڭ جەمەتىنىڭ ئاقساقاللىرى قوپۇپ ئۇنىڭ قېشىغا بېرىپ، ئۇنى يەردىن قوپۇرماقچى بولدى؛ لېكىن ئۇ ئۇنىمىدى ۋە ئۇلار بىلەن تاماق يېيىشنى رەت قىلدى.
\v 18 يەتتىنچى كۈنى بالا ئۆلدى. داۋۇتنىڭ خىزمەتكارلىرى بالا ئۆلدى، دېگەن خەۋەرنى ئۇنىڭغا بېرىشتىن قورقۇپ: «بالا تىرىك ۋاقىتىدا پادىشاھ بىزنىڭ سۆزلىرىمىزگە قۇلاق سالمىدى، ئەمدى بىز قانداقمۇ ئۇنىڭغا بالا ئۆلدى، دەپ خەۋەر بېرىمىز؟ ئۇ ئۆزىنى زەخىملەندۈرۈشى مۇمكىن!» ــ دېيىشتى.
\m 
\v 19 لېكىن داۋۇت خىزمەتكارلىرىنىڭ پىچىرلاشقىنىنى كۆرۈپ، بالىنىڭ ئۆلگىنىنى ئۇقتى. شۇڭا داۋۇت خىزمەتكارلىرىدىن: بالا ئۆلدىمۇ؟ دەپ سورىدى. ئۇلار: ئۆلدى، ــ دەپ جاۋاب بەردى.
\m 
\v 20 شۇنىڭ بىلەن داۋۇت يەردىن قوپۇپ، يۇيۇنۇپ، \add خۇشبۇي\add* ماي بىلەن مەسىھلىنىپ، كىيىملىرىنى يەڭگۈشلەپ، پەرۋەردىگارنىڭ ئۆيىگە كىرىپ ئىبادەت قىلدى؛ ئاندىن ئۆز ئۆيىگە قايتىپ ئۆزىگە تاماق ئەكەلتۈرۈپ يېدى.
\v 21 خىزمەتكارلىرى ئۇنىڭغا: سىلىنىڭ بۇ نېمە قىلغانلىرى؟ بالا تىرىك چاغدا روزا تۇتۇپ يىغلىدىلا، لېكىن بالا ئۆلگەندىن كېيىن قوپۇپ تاماق يېدىلا، ــ دېدى.
\m 
\v 22 ئۇ: مەن: «كىم بىلسۇن، پەرۋەردىگار ماڭا شاپائەت كۆرسىتىپ، بالىنى تىرىك قالدۇرارمىكىن» دەپ ئويلاپ، بالا تىرىك ۋاقىتتا روزا تۇتۇپ يىغلىدىم.
\v 23 لېكىن ئەمدى ئۇ ئۆلگەندىن كېيىن نېمىشقا روزا تۇتاي؟ مەن ئۇنى ياندۇرۇپ ئالالايمەنمۇ؟ مەن ئۇنىڭ يېنىغا بارىمەن، لېكىن ئۇ يېنىمغا يېنىپ كېلەلمەيدۇ، ــ دېدى
\m 
\v 24 داۋۇت ئايالى بات-شېباغا تەسەللى بەردى. ئۇ ئۇنىڭ قېشىغا كىرىپ ئۇنىڭ بىلەن ياتتى؛ ئۇ بىر ئوغۇل تۇغىۋىدى، داۋۇت ئۇنى سۇلايمان دەپ ئاتىدى. پەرۋەردىگار ئۇنى سۆيدى، \f ◼ \fr 12:24 \ft \bd «داۋۇت ئۇنى سۇلايمان دەپ ئاتىدى»\bd* ــ «سۇلايمان» ئىبرانىي تىلىدا «شالوم» ــ ئامان-تىنچلىق، خاتىرجەملىك دېگەن مەنىدىكى سۆز بىلەن مۇناسىۋەتلىك.\f*  \x ◘ \xo 12:24 \xt 1تار. 22‏:9؛ مات. 1‏:6\x*
\v 25 ۋە ناتان پەيغەمبەر ئارقىلىق ۋەھىي يەتكۈزۈپ، ئۇنىڭغا پەرۋەردىگار ئۈچۈن «يەدىدىيا» دەپ ئىسىم قويدى. \f ◼ \fr 12:25 \ft \bd «ناتان پەيغەمبەر ئارقىلىق ... ئۇنىڭغا ... «يەدىدىيا» دەپ ئىسىم قويدى»\bd* ــ «يەدىدىيا»: «پەرۋەردىگار سۆيگەن»، دېگەن مەنىدە.\f*
\b
\s1 داۋۇتنىڭ قوشۇنلىرى ئاممونىيلارنى مەغلۇپ قىلىدۇ
\r 1تار. 20‏:1-3
\m 
\v 26 يوئاب ئاممونىيلارنىڭ شاھانە پايتەختى رابباھقا ھۇجۇم قىلىپ ئۇنى ئالدى. \x ◘ \xo 12:26 \xt 1تار. 20‏:1-3\x*
\v 27 ئاندىن يوئاب خەۋەرچىلەرنى داۋۇتنىڭ قېشىغا ماڭدۇرۇپ: مەن رابباھقا ھۇجۇم قىلىپ، شەھەرنىڭ سۇ بار قىسمىنى ئالدىم.
\v 28 ھازىر سەن قالغان ئەسكەرلەرنى يىغىپ، شەھەرنى قامال قىلىپ، ئۇنى ئىشغال قىلغىن؛ بولمىسا مەن شەھەرنى ئالسام، مېنىڭ ئىسمىم بىلەن ئاتىلىشى مۇمكىن ــ دېدى.
\m 
\v 29 شۇڭا داۋۇت ھەممە خەلقنى جەم قىلىپ، رابباھقا ھۇجۇم قىلىپ ئۇنى ئالدى.
\m 
\v 30 ئۇ ئۇلارنىڭ پادىشاھىنىڭ تاجىنى ئۇنىڭ بېشىدىن ئالدى. ئۇنىڭ ئۈستىدىكى ئالتۇننىڭ ئېغىرلىغى بىر تالانت ئىدى، ۋە ئۇنىڭ كۆزىدە بىر گۆھەر بار ئىدى. كىشىلەر بۇ تاجنى داۋۇتنىڭ بېشىغا كىيگۈزدى، داۋۇت بولسا ئۇ شەھەردىن نۇرغۇن ئولجا ئالدى. \f ◼ \fr 12:30 \ft \bd «ئالتۇننىڭ ئېغىرلىغى بىر تالانت ئىدى»\bd* ــ «بىر تالانت» بەلكىم 34 كىلوگرامدۇر. \bd «ئۇنىڭ كۆزىدە بىر گۆھەر بار ئىدى»\bd* ــ ياكى «ئۇنىڭغا بىرنەچچە گۆھەر قادالدى».\f*  \x ◘ \xo 12:30 \xt 1تار. 20‏:2\x*
\m 
\v 31 ئەمما ئۇ يەردىكى خەلقنى شەھەردىن چىقىرىپ ئۇلارنى ھەرە، خامان تېپىدىغان تىرنىلار ۋە تۆمۈر پالتىلار بىلەن ئىشلەتتى ياكى خۇمداندا قاتتىق ئەمگەككە سالدى؛ داۋۇت ئاممونىيلارنىڭ ھەممە شەھەرلىرىدە شۇنداق قىلدى؛ ئاندىن داۋۇت بارلىق خەلق بىلەن يېرۇسالېمغا يېنىپ كەلدى. \f ◼ \fr 12:31 \ft \bd «ئۇ ... ئۇلارنى ھەرە، خامان تېپىدىغان تىرنىلار ۋە تۆمۈر پالتىلار بىلەن ئىشلەتتى ياكى خۇمداندا قاتتىق ئەمگەككە سالدى»\bd* ــ باشقا بىرخىل تەرجىمىسى: «ئۇ ... ئۇلارنى ھەرىلەرنىڭ تېگىگە بېسىپ ياكى خامان تېپىدىغان تىرنىلار ئاستىغا ياكى پالتىنىڭ ئاستىغا ئالدى ياكى ئۇلارنى خۇمداندىن ئۆتكۈزدى» (دېمەك، ئۇلارنى ئىنتايىن قىينىدى).\f*  \x ◘ \xo 12:31 \xt 1تار. 20‏:3\x*
\b
\b
\c 13
\s1 داۋۇتنىڭ قىزى تامار زىيانكەشلىككە ئۇچرايدۇ
\m 
\v 1 داۋۇتنىڭ ئوغلى ئابشالومنىڭ تامار دېگەن چىرايلىق بىر سىڭلىسى بار ئىدى. بۇ ئىشلاردىن كېيىن، داۋۇتنىڭ ئوغلى ئامنون ئۇنىڭغا ئاشىق بولۇپ قالدى.
\v 2 ئامنون سىڭلىسى تامارنىڭ ئىشقىدا شۇنچە دەرد تارتتىكى، ئۇ كېسەل بولۇپ قالدى. ئەمما تامار تېخى قىز ئىدى؛ شۇنىڭ بىلەن ئامنونغا ئۇنى بىر ئىش قىلىش مۇمكىن بولمايدىغاندەك كۆرۈندى.
\m 
\v 3 لېكىن ئامنوننىڭ يوناداب ئىسىملىك بىر دوستى بار ئىدى. ئۇ داۋۇتنىڭ ئاكىسى شىمېئاھنىڭ ئوغلى ئىدى. بۇ يوناداب تولىمۇ ھىيلىگەر بىر كىشى ئىدى.
\m 
\v 4 ئۇ ئامنونغا: سەن پادىشاھنىڭ ئوغلى تۇرۇپ، نېمىشقا كۈندىن كۈنگە بۇنداق جۈدەپ كېتىسەن؟ قېنى، ماڭا ئېيتىپ بەر، دېدى. ئامنون ئۇنىڭغا: مەن ئىنىم ئابشالومنىڭ سىڭلىسى تامارغا ئاشىق بولدۇم، دېدى. \f ◼ \fr 13:4 \ft \bd «كۈندىن كۈنگە ...»\bd* ــ ئىبرانىي تىلىدا «ئەتىگەندىن ئەتىگەنگە...».\f*
\m 
\v 5 يوناداب ئۇنىڭغا: سەن ئاغرىپ ئورۇن تۇتۇپ، يېتىپ قالغان بولۇۋال؛ ئاتاڭ سېنى كۆرگىلى كەلگەندە ئۇنىڭغا: سىڭلىم تامار كېلىپ ماڭا تاماق بەرسۇن؛ ئۇنىڭ تاماق ئەتكىنىنى كۆرۈشۈم ئۈچۈن، ئالدىمدا تاماق ئېتىپ بەرسۇن، مەن ئۇنىڭ قولىدىن تاماق يەي، دەپ ئېيتقىن، دېدى.
\m 
\v 6 شۇنىڭ بىلەن ئامنون يېتىۋېلىپ ئۆزىنى كېسەل كۆرسەتتى. پادىشاھ ئۇنى كۆرگىلى كەلگەندە، ئامنون پادىشاھقا: ئۆتۈنىمەن، سىڭلىم تامار بۇ يەرگە كېلىپ، ماڭا ئىككى قوتۇرماچ تەييار قىلىپ بەرسۇن، ئاندىن مەن ئۇنىڭ قولىدىن ئېلىپ يەي، دېدى.
\m 
\v 7 شۇنىڭ بىلەن داۋۇت ئوردىسىغا ئادەم ئەۋەتىپ تامارغا: سەندىن ئۆتۈنىمەنكى، ئاكاڭ ئامنوننىڭ ئۆيىگە بېرىپ، ئۇنىڭغا يېگۈدەك بىر نېمە تەييارلاپ بەرگىن، دەپ ئېيتتى.
\m 
\v 8 تامار ئامنوننىڭ ئۆيىگە باردى؛ ئۇ ياتقانىدى. ئۇ ئۇن ئېلىپ يۇغۇرۇپ، قوتۇرماچلارنى كۆز ئالدىدا ئەتتى.
\m 
\v 9 ئاندىن ئۇ قوتۇرماچنى قازاندىن ئېلىپ، ئۇنىڭ ئالدىغا قويدى. لېكىن ئۇ يېگىلى ئۇنىمىدى؛ ئۇ: ــ ھەممە ئادەم مېنىڭ قېشىمدىن چىقىپ كەتسۇن، دېدى. شۇنىڭ بىلەن ھەممە كىشىلەر ئۇنىڭ قېشىدىن چىقىپ كەتتى.
\m 
\v 10 ئاندىن ئامنون تامارغا: تائامنى ئىچكىرىكى ھۇجرىغا ئېلىپ كىرگىن، ئاندىن قولۇڭدىن ئېلىپ يەيمەن، ــ دېدى. تامار ئۆزى ئەتكەن قوتۇرماچنى ئىچكىرىكى ھۇجرىغا، ئاكىسى ئامنوننىڭ قېشىغا ئېلىپ كىردى.
\m 
\v 11 تامار ئۇلارنى ئۇنىڭغا يېگۈزۈپ قويماقچى بولۇۋىدى، ئۇ ئۇنى تۇتۇۋېلىپ: ئى سىڭلىم، كەل! مەن بىلەن ياتقىن! دېدى.
\m 
\v 12 لېكىن ئۇ ئۇنىڭغا جاۋاب بېرىپ: ياق، ئى ئاكا، مېنى نومۇسقا قويمىغىن! ئىسرائىلدا بۇنداق ئىش يوق! سەن بۇنداق پەسكەشلىك قىلمىغىن!
\v 13 مەن بۇ شەرمەندىچىلىكنى قانداقمۇ كۆتۈرۈپ يۈرەلەيمەن؟! سەن بولساڭ ئىسرائىلنىڭ ئارىسىدىكى ئەخمەقلەردىن بولۇپ قالىسەن. ئۆتۈنۈپ قالاي، پەقەت پادىشاھقا دېسەڭلا، ئۇ مېنى ساڭا تەۋە بولۇشتىن توسىمايدۇ، ــ دېدى.
\m 
\v 14 لېكىن ئۇ ئۇنىڭ سۆزىگە قۇلاق سالمىدى. ئۇ ئۇنىڭدىن كۈچلۈك كېلىپ، ئۇنى زورلاپ ئاياغ ئاستى قىلىپ ئۇنىڭ بىلەن ياتتى.
\m 
\v 15 ئاندىن ئامنون ئۇنىڭغا ئىنتايىن قاتتىق نەپرەتلەندى؛ ئۇنىڭ ئۇنىڭغا بولغان نەپرىتى ئۇنىڭغا بولغان ئەسلىدىكى مۇھەببىتىدىن زىيادە بولدى. ئامنون ئۇنىڭغا: قوپۇپ، يوقال! ــ دېدى.
\m 
\v 16 تامار ئۇنىڭغا: ياق! مېنى ھەيدىگەن گۇناھىڭ سەن ھېلى ماڭا قىلغان شۇ ئىشتىن بەتتەردۇر، دېدى. لېكىن ئامنون ئۇنىڭغا قۇلاق سالمىدى،
\v 17 بەلكى خىزمىتىدىكى ياش يىگىتنى چاقىرىپ: بۇ \add خوتۇننى\add* ماڭا چاپلاشتۇرماي، سىرتقا چىقىرىۋەت، ئاندىن ئىشىكنى تاقاپ قوي، دېدى. \f ◼ \fr 13:17 \ft \bd «بۇ خوتۇننى ماڭا چاپلاشتۇرماي...»\bd* ــ ئىبرانىي تىلىدا «بۇنى ماڭا چاپلاشتۇرماي...».\f*
\m 
\v 18 تامار تولىمۇ رەڭدار بىر كۆڭلەك كىيگەنىدى؛ چۈنكى پادىشاھنىڭ تېخى ياتلىق بولمىغان قىزلىرى شۇنداق كىيىم كىيەتتى. ئامنوننىڭ خىزمەتكارى ئۇنى قوغلاپ چىقىرىپ، ئىشىكنى تاقىۋالدى.
\v 19 تامار بېشىغا كۈل چېچىپ، كىيگەن رەڭدار كۆڭلىكىنى يىرتىپ، قولىنى بېشىغا قويۇپ يىغلىغان پېتى كېتىۋاتاتتى.
\v 20 ئاكىسى ئابشالوم ئۇنىڭغا: ئاكاڭ ئامنون سەن بىلەن ياتتىمۇ؟ ھازىرچە جىم تۇرغىن، سىڭلىم. ئۇ سېنىڭ ئاكاڭ ئەمەسمۇ؟ بۇ ئىشنى كۆڭلۈڭگە ئالمىغىن، ــ دېدى. تامار ئاكىسى ئابشالومنىڭ ئۆيىدە كۆڭلى سۇنۇق ھالدا تۇرۇپ قالدى.
\m 
\v 21 داۋۇت پادىشاھمۇ بولغان بارلىق ئىشلارنى ئاڭلاپ ئىنتايىن ئاچچىقلاندى.
\m 
\v 22 ئابشالوم بولسا ئامنونغا يا ياخشى، يا يامان ھېچ گەپ قىلمىدى. چۈنكى ئابشالوم سىڭلىسى تامارنى ئامنوننىڭ خورلىغانلىقىدىن ئۇنى ئۆچ كۆرەتتى.
\b
\s1 ئابشالوم ئامنوننى ئۆلتۈرىدۇ
\m 
\v 23 تولۇق ئىككى يىل ئۆتۈپ، ئەفرائىمغا يېقىن بائال-ھازوردا ئابشالومنىڭ قىرقىغۇچىلىرى قويلىرىنى قىرقىۋاتاتتى؛ ئۇ پادىشاھنىڭ ھەممە ئوغۇللىرىنى تەكلىپ قىلدى. \f ◼ \fr 13:23 \ft \bd «ئىككى يىل ئۆتۈپ،... بائال-ھازوردا ئابشالومنىڭ قىرقىغۇچىلىرى قويلىرىنى قىرقىۋاتاتتى»\bd* ــ ئىبرانىي تىلىدا: «... ئىككى يىل ئۆتۈپ،... ئابشالومنىڭ ...بائال-ھازوردا (قوي) قىرقىغۇچىلىرى بار ئىدى».\f*
\v 24 ئابشالوم پادىشاھنىڭ قېشىغا كېلىپ: مانا قۇللىرى قويلىرىنى قىرقىتىۋاتىدۇ، پادىشاھ ۋە خىزمەتكارلىرىنىڭ سىلىنىڭ قۇللىرى بىلەن بىللە بېرىشىنى ئۆتۈنىمەن، ــ دېدى.
\m 
\v 25 پادىشاھ ئابشالومغا: ياق، ئوغلۇم، بىز ھەممىمىز بارمايلى، ساڭا ئېغىرچىلىق چۈشۈپ قالمىسۇن، ــ دېدى. ئابشالوم شۇنچە دېسىمۇ، ئۇ بارغىلى ئۇنىمىدى، بەلكى ئۇنىڭغا ئامەت تىلىدى.
\m 
\v 26 لېكىن ئابشالوم: ئەگەر بېرىشقا ئۇنىمىسىلا، ئاكام ئامنوننى بىز بىلەن بارغىلى قويسىلا، ــ دېدى.
\m پادىشاھ ئۇنىڭدىن: نېمىشقا ئۇ سېنىڭ بىلەن بارىدۇ؟» ــ دەپ سورىدى. \f ◼ \fr 13:26 \ft \bd «ئەگەر بېرىشقا ئۇنىمىسىلا، ئاكام ئامنوننى بىز بىلەن بارغىلى قويسىلا»\bd* ــ ئابشالوم ئاتىسى داۋۇتنىڭ گۇمانىنى قوزغاپ قويماسلىق ئۈچۈن (تەكەللۇپ بويىچە) ئۇنى ئاۋۋال تەكلىپ قىلىدۇ. ئۇ پادىشاھ قوشۇلماسالىقى مۇمكىن، دەپ بىلەتتى (پادىشاھ دەرۋەقە ئۇنىمىدى)؛ شۇنىڭ بىلەن ئۇ تەكەللۈپ بىلەن پادىشاھنىڭ تۇنجى ئوغلى ئامنوننى تەكلىپ قىلالايتتى.\f*
\m 
\v 27 ئەمما ئابشالوم ئۇنى كۆپ زورلىغىنى ئۈچۈن ئۇ ئامنوننىڭ، شۇنداقلا پادىشاھنىڭ ھەممە ئوغۇللىرىنىڭ ئۇنىڭ بىلەن بىللە بېرىشىغا قوشۇلدى.
\m 
\v 28 ئابشالوم ئۆز غۇلاملىرىغا بۇيرۇپ: سەگەك تۇرۇڭلار، ئامنون شاراب ئىچىپ خۇش كەيپ بولغاندا، مەن سىلەرگە ئامنوننى ئۇرۇڭلار دېسەم، ئۇنى دەرھال ئۆلتۈرۈڭلار. قورقماڭلار! بۇلارنى سىلەرگە بۇيرۇغۇچى مەن ئەمەسمۇ؟ جۈرئەتلىك بولۇپ باتۇرلۇق كۆرسىتىڭلار ــ دېدى.
\m 
\v 29 شۇنىڭ بىلەن ئابشالومنىڭ غۇلاملىرى ئامنونغا ئابشالوم ئۆزى بۇيرۇغاندەك قىلدى. شۇئان پادىشاھنىڭ ھەممە ئوغۇللىرى قوپۇپ، ھەر بىرى ئۆز قېچىرىغا مىنىپ قاچتى.
\v 30 شۇنداق بولدىكى، ئۇلار تېخى يولدا قېچىپ كېتىۋاتقاندا، «ئابشالوم پادىشاھنىڭ ھەممە ئوغۇللىرىنى ئۆلتۈردى. ئۇلارنىڭ ھېچ بىرى قالمىدى» دېگەن خەۋەر داۋۇتقا يەتكۈزۈلدى.
\m 
\v 31 پادىشاھ قوپۇپ كىيىملىرىنى يىرتىپ يەردە دۈم ياتتى؛ ئۇنىڭ ھەممە قۇل-خىزمەتكارلىرى بولسا كىيىملىرى يىرتىق ھالدا يېنىدا تۇراتتى. \x ◘ \xo 13:31 \xt 2سام. 1‏:11\x*
\v 32 ئەمما داۋۇتنىڭ ئاكىسى شىمېئاھنىڭ ئوغلى يوناداب ئۇنىڭغا: ــ غوجام، ئۇلار پادىشاھنىڭ ئوغۇللىرى بولغان ھەممە يىگىتلەرنى ئۆلتۈردى، دەپ خىيال قىلمىسىلا. چۈنكى پەقەت ئامنون ئۆلدى؛ ئۇ ئىش ئامنوننىڭ ئابشالومنىڭ سىڭلىسى تامارنى خار قىلغان كۈندىن باشلاپ ئابشالومنىڭ ئاغزىدىن چىقارمىغان نىيىتى ئىدى.
\v 33 ئەمدى غوجام پادىشاھ «پادىشاھنىڭ ھەممە ئوغۇللىرى ئۆلدى» دېگەن ئويدا بولۇپ كۆڭۈللىرىنى بىئارام قىلمىسىلا. چۈنكى پەقەت ئامنونلا ئۆلدى ــ دېدى.
\m 
\v 34 ئابشالوم بولسا قېچىپ كەتكەنىدى. \add يېرۇسالېمدىكى\add* كۆزەتچى غۇلام قارىۋىدى، مانا، غەرب تەرىپىدىن تاغنىڭ يېنىدىكى يول بىلەن نۇرغۇن ئادەملەر كېلىۋاتاتتى. \f ◼ \fr 13:34 \ft \bd «غەرب تەرىپىدىن...»\bd* ــ ياكى «ئۇنىڭ كەينى تەرىپىدىن...».\f*
\v 35 يوناداب پادىشاھقا: مانا، پادىشاھنىڭ ئوغۇللىرى كەلدى. دەل قۇللىرى دېگەندەك بولدى ــ دېدى.
\m 
\v 36 سۆزىنى تۈگىتىپ تۇرىۋىدى، پادىشاھنىڭ ئوغۇللىرى كېلىپ قاتتىق يىغا-زار قىلدى. پادىشاھ بىلەن خىزمەتكارلىرىمۇ قاتتىق يىغلاشتى.
\v 37 لېكىن ئابشالوم بولسا گەشۇرنىڭ پادىشاھى، ئاممىھۇدنىڭ ئوغلى تالماينىڭ قېشىغا باردى. داۋۇت ئوغلى ئۈچۈن ھەر كۈنى ھازا تۇتۇپ قايغۇردى. \f ◼ \fr 13:37 \ft \bd «ئابشالوم بولسا گەشۇرنىڭ پادىشاھى، ئاممىھۇدنىڭ ئوغلى تالماينىڭ قېشىغا باردى»\bd* ــ تالماي ئابشالومنىڭ چوڭ ئاتىسى (ئاپىسىنىڭ ئاتىسى) ئىدى («1تار.» 3:2).\f*
\m 
\v 38 ئابشالوم قېچىپ، گەشۇرغا بېرىپ ئۇ يەردە ئۈچ يىل تۇردى.
\v 39 داۋۇت پادىشاھنىڭ قەلبى ئابشالومنىڭ يېنىغا بېرىشقا ئىنتىزار بولدى؛ چۈنكى ئۇ ئامنونغا نىسبەتەن تەسەللى تاپقانىدى، چۈنكى ئۇ ئۆلگەنىدى. \f ◼ \fr 13:39 \ft \bd «داۋۇت پادىشاھنىڭ قەلبى ئابشالومنىڭ يېنىغا بېرىشقا ئىنتىزار بولدى»\bd* ــ بۇ ئايەتنىڭ بىرىنچى قىسمى توغرۇلۇق باشقا بىرخىل چۈشەنچە: «داۋۇت پادىشاھ قەلبىدە «مەن چىقىپ ئابشالومنى ئۇراي» دېگەن نىيەتتىن يېنىپ قالدى».\f*
\b
\b
\c 14
\s1 ئابشالوم يېرۇسالېمغا قايتىپ كېلىدۇ
\m 
\v 1 ئەمدى زەرۇئىيانىڭ ئوغلى يوئاب پادىشاھ قەلبىنىڭ ئابشالومغا تەلمۈرۈۋاتقانلىقىنى بايقىدى. \f ◼ \fr 14:1 \ft \bd «...يوئاب پادىشاھ قەلبىنىڭ ئابشالومغا تەلمۈرۈۋاتقانلىقىنى بايقىدى»\bd* ــ باشقا بىرخىل تەرجىمىسى: «...يوئاب پادىشاھ قەلبىنىڭ ئابشالومغا ئۆچ بولغانلىقىنى بايقىدى». بىراق يوئابنىڭ ئىشلەتكەن تەدبىرىدىن (2-23) قارىغاندا، بىزنىڭ تەرجىمىمىزنى شۇ ئەھۋالغا بەكرەك ماسلىشىدۇ، دەپ قارايمىز.\f*
\v 2 شۇنىڭ ئۈچۈن يوئاب تەكوئاغا ئادەم ئەۋەتىپ ئۇ يەردىن دانىشمەن بىر خوتۇننى ئەكەلدۈرۈپ ئۇنىڭغا: سەندىن ئۆتۈنەي، ئۆزۈڭنى ماتەم تۇتقان كىشىدەك كۆرسىتىپ قارىلىق كىيىمى كىيىپ، ئۆزۈڭنى ئەتىرلىك ماي بىلەن ياغلىماي، بەلكى ئۆزۈڭنى ئۆلگۈچى ئۈچۈن ئۇزۇن ۋاقىت ھازىدار بولغان ئايالدەك قىلىپ \f ◼ \fr 14:2 \ft \bd «ئۆزۈڭنى ئەتىرلىك ماي بىلەن ياغلىماي،...»\bd* ــ ئىبرانىي تىلىدا «ئۆزۈڭنى ئەتىرلىك ماي بىلەن مەسىھلىمەي،...». كونا زامانلاردا ئوتتۇرا شەرقتىكى ئەللەر ئارىسىدا كىشىلەردە (ئەرلەر ۋە ئاياللاردىمۇ) يۈزلىرىنى ئەتىرلىك ماي بىلەن سۈرۈش ئادىتى بار ئىدى. لېكىن ماتەم تۇتقانلار قايغۇنى بىلدۈرۈش ئۈچۈن شۇنداق قىلمايتتى.\f*
\v 3 \add داۋۇت\add* پادىشاھنىڭ قېشىغا بېرىپ ئۇنىڭغا مۇنداق دېگىن، ــ دېدى.
\m شۇنداق قىلىپ، يوئاب دېمەكچى بولغانلىرىنى ئۇ ئايالغا ئۆگەتتى.
\v 4 شۇنىڭ بىلەن تەكوئالىق بۇ ئايال پادىشاھنىڭ ئالدىغا بېرىپ، تەزىم قىلىپ، باش ئۇرۇپ: ئى پادىشاھىم، مېنى قۇتقۇزۇۋالغايلا، ــ دېدى.
\m 
\v 5 پادىشاھ ئۇنىڭدىن: نېمە دەردىڭ بار؟ دەپ سورىدى. ئۇ جاۋاپ بېرىپ: مەن دەرۋەقە بىر تۇل خوتۇنمەن! ئېرىم ئۆلۈپ كەتتى؛
\v 6 دېدەكلىرىنىڭ ئىككى ئوغلى بار ئىدى. ئىككىسى ئېتىزلىقتا ئۇرۇشۇپ قېلىپ، ئارىغا چۈشىدىغان ئادەم بولمىغاچقا، بىرى يەنە بىرىنى ئۇرۇپ ئۆلتۈرۈپ قويدى.
\v 7 مانا، ھازىر پۈتۈن ئۆيدىكىلەر دېدەكلىرىگە قارشى قوپۇپ، ئىنىسىنى ئۆلتۈرگىنىنى بىزگە تۇتۇپ بەرگىن؛ ئىنىسىنىڭ جېنىنى ئېلىپ، قەتل قىلغىنى ئۈچۈن بىز جانغا جان ئالىمىز. شۇنىڭ بىلەنمۇ مىراس ئالغۇچىنى يوقىتىمىز، دەۋاتىدۇ. ئۇلار شۇنداق قىلىپ يالغۇز قالغان چوغۇمنى ئۆچۈرۈپ، ئېرىمگە نە نام نە يەر يۈزىدە ئەۋلادمۇ قالدۇرغىلى قويمايدۇ، ــ دېدى.
\m 
\v 8 پادىشاھ ئايالغا: ئۆيۈڭگە بارغىن، مەن ئەھۋالغا قاراپ سەن توغرۇلۇق ھۆكۈم چىقىرىمەن، ــ دېدى.
\m 
\v 9 تەكوئالىق ئايال پادىشاھقا: ئى، غوجام پادىشاھ، بۇ ئىشتا گۇناھ بولسا، ھەممىسى مېنىڭ بىلەن ئاتامنىڭ جەمەتى ئۈستىدە بولسۇن، پادىشاھ ۋە ئۇنىڭ تەختى بىلەن مۇناسىۋەتسىز بولسۇن، ــ دېدى. \f ◼ \fr 14:9 \ft \bd «بۇ ئىشتا گۇناھ بولسا،...»\bd* ــ مۇسا پەيغەمبەرگە چۈشۈرۈلگەن قانۇن بويىچە، بىرسى باشقا بىرسىنى بىكاردىن-بىكار ئۆلتۈرگەن بولسا، ئۆلتۈرۈلگۈچىنىڭ يېقىن ئۇرۇق-تۇغقانلىرىنىڭ ئۇنىڭ ئۈچۈن قىساس ئېلىش ھوقۇقى بار ئىدى («چۆل.» 9:35-34). بىرسى بىرەرسىنى تاسادىپىيلىقتىن ئۆلتۈرۈپ قويسا، ئۆلتۈرگۈچى كىشى چەتئەلگە ياكى «پاناھلىق شەھىرى»گە قاچسا بولاتتى. ئەمما مۇشۇ يەردە پادىشاھ شۇ ئايالنىڭ تۇغقانلىرىنىڭ «قىساس ئېلىش»تىن ئىبارەت قانۇنلۇق ھوقۇقىنى توسماقچى بولىدۇ. كېيىن ئۇ شۇنى بىلىدۇكى، ھەممە سۆزلەر پەقەت بىر تەمسىلدۇر، خالاس.\f*
\m 
\v 10 پادىشاھ: بىرەر كىم ساڭا \add بۇ توغرۇلۇق\add* گەپ قىلسا، ئۇنى مېنىڭ قېشىمغا ئېلىپ كەلگىن، ئۇ سېنى يەنە ئاۋارە قىلمايدىغان بولىدۇ، ــ دېدى.
\m 
\v 11 ئايال جاۋاب بېرىپ: ئۇنداقتا پادىشاھ پەرۋەردىگار خۇدالىرىنى ياد قىلغايلا، قانغا قان ئىنتىقام ئالغۇچىلارنىڭ ئوغلۇمنى يوقاتماسلىقى ئۈچۈن، ئۇلارنىڭ ھالاك قىلىشىغا يول قويمىغايلا، ــ دېدى. پادىشاھ: پەرۋەردىگارنىڭ ھاياتى بىلەن قەسەم قىلىمەنكى، سېنىڭ ئوغلۇڭنىڭ بىر تال چېچى يەرگە چۈشمەيدۇ، ــ دېدى. \f ◼ \fr 14:11 \ft \bd «پادىشاھ پەرۋەردىگار خۇدالىرىنى ياد قىلغايلا...»\bd* ــ دېگەننىڭ مەنىسى بەلكىم «پادىشاھ پەرۋەردىگارنىڭ نامى بىلەن قەسەم قىلغايلا...».\f*
\m 
\v 12 لېكىن ئايال: دېدەكلىرى غوجام پادىشاھقا يەنە بىر سۆزنى دېگىلى قويغايلا، دېۋىدى، ئۇ: ئېيتقىن ــ دېدى.
\v 13 ئايال يەنە مۇنداق دېدى: ئەمدى سىلى نېمىشقا خۇدانىڭ خەلقىگە شۇنىڭغا ئوخشاش زىيانلىق بىر ئىشنى نىيەت قىلدىلا؟ پادىشاھ شۇ گېپى بىلەن ئۆزىنى گۇناھكار قىلىپ بېكىتىۋاتىدۇ، چۈنكى ئۇ ئۆزى پالىغان كىشىنى قايتۇرۇپ ئەكەلمىدى.
\v 14 دەرۋەقە ھەممىمىز چوقۇم ئۆلۈپ، يەرگە تۆكۈلگەن، قايتىدىن يىغىۋالغىلى بولمايدىغان سۇدەك بولىمىز. لېكىن خۇدا ئادەمنىڭ جېنىنى ئېلىشقا ئەمەس، بەلكى ئۆز پالانغىنىنى ئۆزىگە قايتۇرۇپ ئەكىلىشكە ئىلاج قىلىدۇ. \f ◼ \fr 14:14 \ft \bd «خۇدا... پالانغىنىنى ئۆزىگە قايتۇرۇپ ئەكىلىشكە ئىلاج قىلىدۇ»\bd* ــ ئىبرانىي تىلىدا: «خۇدا... ئۆزىنىڭ پالىغىنىنى ئۆزىدىن پالاندى قېلىۋەرمەسلىكىگە ئىلاج قىلىدۇ» دېگەن سۆز بىلەن ئىپادىلىنىدۇ.\f*
\m 
\v 15 ئەمەلىيەتتە، مېنىڭ غوجام پادىشاھقا شۇ ئىش توغرىسىدىن سۆز قىلغىلى كېلىشىمنىڭ سەۋەبى، خەلق مېنى قورقاتتى. لېكىن دېدەكلىرى: بۇ گەپنى پادىشاھقا ئېيتاي! پادىشاھ بەلكىم ئۆز چۆرىسىنىڭ ئىلتىماسىنى بەجا كەلتۈرەر، دېگەن ئويدا بولدى.
\v 16 چۈنكى پادىشاھ ئاڭلىشى مۇمكىن، چۆرىسىنى ھەم ئوغلۇمنى خۇدانىڭ مىراسىدىن تەڭ يوقاتماقچى بولغان كىشىنىڭ قولىدىن قۇتقۇزۇپ قالار. \f ◼ \fr 14:16 \ft \bd «خۇدانىڭ مىراسى»\bd* ــ شۈبھىسىزكى، تۇل خوتۇن ۋە ئوغلىغا (خۇدانىڭ بىرنەچچە دەۋر ئىلگىرى ئىسرائىل خەلقىنىڭ ئەجدادلىرىغا تاپشۇرغان كۆرسەتمىسىگە ئاساسەن) («يە.» 7:12 قاتارلىقلار) مىراس قالغان زېمىنىنى كۆرسىتىدۇ.\f*
\v 17 شۇڭا دېدەكلىرى، غوجام پادىشاھنىڭ سۆزى ماڭا ئاراملىق بېرەر، دەپ ئويلىدىم. چۈنكى غوجام پادىشاھ خۇدانىڭ بىر پەرىشتىسىدەك ياخشى-ياماننى پەرق ئەتكۈچىدۇر. پەرۋەردىگار خۇدالىرى سىلى بىلەن بىللە بولغاي!
\m 
\v 18 پادىشاھ ئايالغا جاۋاب بېرىپ: سەندىن ئۆتۈنىمەنكى، مەن سەندىن سورىماقچى بولغان ئىشنى مەندىن يوشۇرمىغايسەن، دېدى. ئايال: غوجام پادىشاھ سۆز قىلسىلا، دېدى.
\m 
\v 19 پادىشاھ: بۇ گەپلىرىڭنىڭ ھەممىسى يوئابنىڭ كۆرسەتمىسىمۇ، قانداق؟ ــ دېدى. ئايال جاۋاب بېرىپ: ئى، غوجام پادىشاھ، سىلىنىڭ جانلىرى بىلەن قەسەم قىلىمەنكى، غوجام پادىشاھ ئېيتقانلىرى ئوڭغىمۇ، سولغىمۇ قايمايدىغان ھەقىقەتتۇر. دەرۋەقە سىلىنىڭ قۇللىرى يوئاب ماڭا شۇنى تاپىلاپ، بۇ سۆزلەرنى دېدەكلىرىنىڭ ئاغزىغا سالدى. \f ◼ \fr 14:19 \ft \bd «يوئابنىڭ كۆرسەتمىسى»\bd* ــ ئىبرانىي تىلىدا: «يوئابنىڭ قولى». \bd «غوجام پادىشاھ ئېيتقانلىرى ئوڭغىمۇ، سولغىمۇ قايمايدىغان ھەقىقەتتۇر»\bd* ــ ئىبرانىي تىلىدا «بىرسى غوجام پادىشاھ ئېيتقانلىرىدىن ئوڭغىمۇ، سولغىمۇ بۇرۇلسا، ئۇ ھەقىقەتتە تۇرمايدۇ».\f*
\v 20 يوئابنىڭ بۇنداق قىلىشى بۇ ئىشنى ھەل قىلىش ئۈچۈن ئىدى. غوجامنىڭ دانالىقى خۇدانىڭ بىر پەرىشتىسىنىڭكىدەك ئىكەن، زېمىندا يۈز بېرىۋاتقان ھەممە ئىشلارنى بىلىدىكەن، ــ دېدى.
\m 
\v 21 شۇنىڭ بىلەن پادىشاھ يوئابقا: ماقۇل! مانا، بۇ ئىشقا ئىجازەت بەردىم. بېرىپ ئۇ يىگىت ئابشالومنى ئېلىپ كەلگىن، دېدى.
\m 
\v 22 يوئاب يەرگە يىقىلىپ باش ئۇرۇپ، پادىشاھقا بەخت-بەرىكەت تىلىدى. ئاندىن يوئاب: ئى غوجام پادىشاھ، ئۆز قۇلۇڭنىڭ تەلىپىگە ئىجازەت بەرگىنىڭدىن، ئۆز قۇلۇڭنىڭ سېنىڭ ئالدىڭدا ئىلتىپات تاپقىنىنى بۈگۈن بىلدىم، ــ دېدى.
\m 
\v 23 ئاندىن يوئاب قوزغىلىپ، گەشۇرغا بېرىپ ئابشالومنى يېرۇسالېمغا ئېلىپ كەلدى.
\v 24 ئەمما پادىشاھ: ــ ئۇ مېنىڭ يۈزۈمنى كۆرمەي، ئۆز ئۆيىگە بارسۇن، دېگەنىدى. شۇڭا ئابشالوم پادىشاھنىڭ يۈزىنى كۆرمەي، ئۆز ئۆيىگە كەتتى.
\m 
\v 25 ئەمدى پۈتكۈل ئىسرائىل تەۋەسىدە ئابشالومدەك چىرايلىق دەپ ماختالغان ئادەم يوق ئىدى. تاپىنىدىن تارتىپ چوققۇسىغىچە ئۇنىڭدا ھېچ ئەيىب يوق ئىدى.
\v 26 ئۇنىڭ چېچىنى چۈشۈرگەندە (ئۇ ھەر يىلنىڭ ئاخىرىدا چېچىنى چۈشۈرەتتى؛ چېچى ئېغىرلىشىپ كەتكەچكە، شۇڭا ئۇنى چۈشۈرەتتى)، چېچىنى پادىشاھنىڭ «ئۆلچەم تارازا»سى بىلەن تارتسا ئىككى يۈز شەكەل چىقاتتى. \f ◼ \fr 14:26 \ft \bd «ئىككى يۈز شەكەل»\bd* ــ 1.4 كىلوگرام بولۇشى مۇمكىن.\f*
\v 27 ئابشالومدىن ئۈچ ئوغۇل ۋە تامار ئىسىملىك بىر قىز تۇغۇلدى. قىزى تولىمۇ چىرايلىق ئىدى.
\m 
\v 28 ئابشالوم پادىشاھنىڭ يۈزىنى كۆرمەي، يېرۇسالېمدا توپتوغرا ئىككى يىل توشقۇچە تۇردى؛
\v 29 ئابشالۇم يوئابقا ئادەم ماڭدۇرۇپ، ئۆزىنى پادىشاھنىڭ قېشىغا ئەۋەتىشىنى ئۆتۈندى، ئەمما ئۇ كەلگىلى ئۇنىمىدى. ئابشالوم ئىككىنچى قېتىم ئۇنىڭ يېنىغا ئادەم ئەۋەتتى، لېكىن يوئاب كېلىشنى خالىمىدى.
\m 
\v 30 شۇنىڭ بىلەن ئابشالوم ئۆز خىزمەتكارلىرىغا: ــ يوئابنىڭ مېنىڭكىگە يانداش ئارپا تېرىقلىق بىر پارچە ئېتىزلىقى بار. بېرىپ ئۇنىڭغا ئوت قويۇڭلار، دەپ بۇيرۇدى. شۇنداق قىلىپ، ئابشالومنىڭ خىزمەتكارلىرى يوئابنىڭ بۇ بىر پارچە ئېتىزلىقىغا ئوت قويدى.
\v 31 ئاندىن يوئاب قوزغىلىپ ئابشالومنىڭ ئۆيىگە كىرىپ ئۇنىڭدىن: نېمىشقا خىزمەتكارلىرىڭ ئېتىزلىقىمغا ئوت قويدى! ــ دەپ سورىدى.
\m 
\v 32 ئابشالوم يوئابقا جاۋاب بېرىپ: مانا، مەن ساڭا ئادەم ئەۋەتىپ: قېشىمغا كەلسۇن، ئاندىن پادىشاھنىڭ قېشىغا ماڭا ۋاكالىتەن بارغۇزۇپ ئۇنىڭغا: مەن نېمىشقا گەشۇردىن يېنىپ كەلگەندىمەن؟ ئۇ يەردە قالسام، ياخشى بولاتتىكەن، دەپ ئېيتقۇزماقچى ئىدىم. ئەمدى پادىشاھ بىلەن دىدارلاشسام دەيمەن؛ مەندە قەبىھلىك بولسا، ئۇ مېنى ئۆلتۈرسۇن، ــ دېدى.
\m 
\v 33 شۇنىڭ بىلەن يوئاب پادىشاھنىڭ قېشىغا بېرىپ، ئۇنىڭغا بۇ خەۋەرنى يەتكۈزدى. پادىشاھ ئابشالومنى چاقىردى؛ ئۇ پادىشاھنىڭ قېشىغا كېلىپ، پادىشاھنىڭ ئالدىدا تەزىم قىلىپ باش ئۇردى؛ پادىشاھ ئابشالومنى سۆيدى.
\b
\b
\c 15
\s1 ئابشالوم پادىشاھقا ئىسيان كۆتۈرىدۇ
\m 
\v 1 بۇ ئىشلاردىن كېيىن ئابشالوم ئۆزىگە جەڭ ھارۋىسى بىلەن ئاتلارنى تەييارلاتتى ھەم ئۆز ئالدىدا يۈگۈرىدىغان ئەللىك ئەسكەرنى بېكىتتى.
\v 2 ئابشالوم تاڭ سەھەردە قوپۇپ، دەرۋازىغا بارىدىغان يولنىڭ يېنىدا تۇراتتى. قاچان بىرسى دەۋايىمنى كەسسۇن دەپ، پادىشاھقا ئەرز تۇتقىلى كەلسە، ئابشالوم ئۇنى چاقىرىپ: سەن قايسى شەھەردىن كەلدىڭ، ــ دەپ سورايتتى. ئۇ كىشى: قۇلۇڭ ئىسرائىلنىڭ پالانچى قەبىلىسىدىن كەلدى، دېسە،
\v 3 ئابشالوم ئۇنىڭغا: مانا، دەۋايىڭلار دۇرۇس ۋە ھەق ئىكەن، لېكىن پادىشاھ تەرىپىدىن ئۆزىگە ۋاكالىتەن ئەرزىڭنى ئاڭلاشقا قويۇلغان ئادەم يوق، دەيتتى.
\v 4 ئاندىن ئابشالوم يەنە: كاشكى، مەن زېمىندا سوراقچى قىلىنسامىدى، ھەر كىمنىڭ ئەرزى ياكى دەۋايى بولۇپ، مېنىڭ قېشىمغا كەلسە، ئۇنىڭغا ئادالەت كۆرسىتەتتىم! ــ دەيتتى.
\m 
\v 5 بىركىم ئۇنىڭغا تەزىم قىلغىلى ئالدىغا بارسا، ئابشالوم قولىنى ئۇزۇتۇپ، ئۇنى تۇتۇپ سۆيەتتى.
\v 6 ئابشالوم شۇنداق قىلىپ پادىشاھنىڭ ھۆكۈم چىقىرىشىغا كەلگەن ئىسرائىلنىڭ ھەربىر ئادەملىرىنىڭ كۆڭۈللىرىنى ئۇتۇۋالاتتى.
\m 
\v 7 تۆت يىل ئۆتكەندە، ئابشالوم پادىشاھقا: مېنىڭ ھېبروندا پەرۋەردىگارغا ئىچكەن قەسىمىمنى ئادا قىلىشىم ئۈچۈن، شۇ يەرگە بېرىشقا ئىجازەت بەرسەڭ؛ \f ◼ \fr 15:7 \ft \bd «تۆت يىل ئۆتكەندە...»\bd* ــ بەزى كونا كۆچۈرمىلەردە «قىرىق يىل ئۆتكەندە...» دېيىلىدۇ. بۇ بەلكىم كۆچۈرمىچىنىڭ خاتالىقىدىن بولغان.\f*
\v 8 چۈنكى قۇلۇڭ سۇرىيەدىكى گەشۇردا تۇرغىنىمدا قەسەم ئىچىپ: ئەگەر پەرۋەردىگار مېنى يېرۇسالېمغا قايتۇرسا، مەن پەرۋەردىگارغا ئىبادەت قىلىمەن، دەپ ئېيتقانىدى، ــ دېدى.
\m 
\v 9 پادىشاھ ئۇنىڭغا: تىنچ-ئامان بېرىپ كەلگىن، دېۋىدى، ئۇ قوزغىلىپ ھېبرونغا كەتتى.
\m 
\v 10 لېكىن ئابشالوم ئىسرائىلنىڭ ھەممە قەبىلىلىرىگە مەخپىي ئەلچىلەرنى ماڭدۇرۇپ: بۇرغا ئاۋازىنى ئاڭلىغىنىڭلاردا: «ئابشالوم ھېبروندا پادىشاھ بولدى!» دەپ ئېلان قىلىڭلار، دېدى.
\m 
\v 11 ئەمدى ئىككى يۈز ئادەم تەكلىپ بىلەن ئابشالوم بىلەن بىرگە يېرۇسالېمدىن بارغانىدى. ئۇلار ھەقىقىي ئەھۋالدىن بىخەۋەر بولغاچقا، ساددىلىق بىلەن بارغانىدى.
\v 12 ئابشالوم قۇربانلىق ئۆتكۈزگەندە، ئۇ ئادەم ئەۋەتىپ داۋۇتنىڭ مەسلىھەتچىسى بولغان گىلوھلۇق ئاھىتوفەلنى ئۆز شەھىرى گىلوھدىن ئېلىپ كەلدى. شۇنىڭ بىلەن قەست بارغانسېرى كۈچەيدى، ئابشالومغا ئەگەشكەنلەر بارغانسېرى كۆپىيىۋاتاتتى.
\b
\s1 داۋۇت يېرۇسالېمدىن قاچىدۇ
\m 
\v 13 داۋۇتقا بىر خەۋەرچى كېلىپ: ئىسرائىلنىڭ ئادەملىرىنىڭ كۆڭۈللىرى ئابشالومغا مايىل بولدى، ــ دېدى.
\m 
\v 14 شۇنىڭ بىلەن داۋۇت يېرۇسالېمدا ئۇنىڭ بىلەن بولغان ھەممە قۇل-خىزمەتكارلىرىغا: قوپۇپ قاچايلى! بولمىسا، ئابشالومدىن قۇتۇلالمايمىز. ئىتتىك كېتەيلى؛ بولمىسا، ئۇ تۇيۇقسىز ئۈستىمىزگە بېسىپ كېلىپ، بىزگە بالا كەلتۈرۈپ شەھەر خەلقىنى قىلىچ بىسى بىلەن ئۇرىدۇ، دېدى.
\m 
\v 15 پادىشاھنىڭ قۇل-خىزمەتكارلىرى پادىشاھقا: غوجام پادىشاھ نېمە بېكىتسە، شۇنى قىلىمىز، دېدى.
\m 
\v 16 شۇنىڭ بىلەن پادىشاھ پۈتۈن ئائىلىسىدىكىلەرنى ئېلىپ، چىقىپ كەتتى؛ ئەمما پادىشاھ كېنىزەكلىرىدىن ئوننى ئوردىغا قاراشقا قويدى.
\v 17 پادىشاھ چىقىپ كەتكەندە ھەممە خەلق ئۇنىڭغا ئەگەشتى؛ ئۇلار بەيت-مەرھاكتا تۇرۇپ قالدى. \f ◼ \fr 15:17 \ft \bd «بەيت-مەرھاك»\bd* ــ ياكى «يىراقتىكى ئوردا».\f*
\v 18 ھەممە خىزمەتكارلىرى ئۇنىڭ بىلەن بىللە \add كىدرون ئېقىنىدىن\add* ئۆتۈۋاتاتتى؛ بارلىق كەرەتىيلەر، بارلىق پەلەتىيلەر، بارلىق گاتلىقلار، يەنى گات شەھىرىدىن چىقىپ ئۇنىڭغا ئەگەشكەن ئالتە يۈز ئادەم پادىشاھنىڭ ئالدىدا ماڭاتتى. \f ◼ \fr 15:18 \ft \bd «كىدرون دەرياسىدىن»\bd* ــ بۇ سۆزلەر ئىبرانىي تېكىستىدە يوق، لېكىن «ئۆتۈۋاتاتتى» دېگەن سۆز بۇ مەنىنى كۆرسىتىدۇ (23-ئايەتنى كۆرۈڭ). كىدرون ئېقىنى يېرۇسالېمنىڭ شەرقىي تەرىپىگە يېقىن بولۇپ، ئىئوردان دەرياسىغا ماڭغاندا ئۇنىڭدىن ئۆتۈشى كېرەك.\f*  \x ◘ \xo 15:18 \xt 2سام. 8‏:18؛ 1پاد. 1‏:38؛ 1تار. 18‏:17\x*
\v 19 پادىشاھ گاتلىق ئىتتايغا: سەن نېمىشقا بىز بىلەن بارىسەن؟ يېنىپ بېرىپ پادىشاھنىڭ قېشىدا تۇرغىن؛ چۈنكى سەن ئۆز يۇرتۇڭدىن مۇساپىر بولۇپ پالانغانسەن. \f ◼ \fr 15:19 \ft \bd «يېنىپ بېرىپ پادىشاھنىڭ قېشىدا تۇرغىن...»\bd* ــ داۋۇت «پادىشاھ» دېگەن سۆزنى ئىشلىتىپ، ئابشالوم «يېڭى پادىشاھ»نى كۆرسىتىدۇ. 34-ئايەتنىمۇ كۆرۈڭ.\f*
\v 20 سەن پەقەت تۈنۈگۈنلا كەلدىڭ، مەن بۈگۈن قانداقسىگە سېنى ئۆزۈم بىلەن بىللە سەرسان قىلاي؟ مەن بولسام، نەگە بارالىسام، شۇ يەرگە بارىمەن. قېرىنداشلىرىڭنى ئېلىپ يېنىپ كەتكىن؛ خۇدانىڭ رەھىم-شەپقىتى ۋە ھەقىقىتى ساڭا يار بولغاي! ــ دېدى.
\v 21 لېكىن ئىتتاي پادىشاھقا جاۋاب بېرىپ: پەرۋەردىگارنىڭ ھاياتى بىلەن ۋە غوجام پادىشاھنىڭ ھاياتى بىلەن قەسەم قىلىمەنكى، مەيلى ھايات ياكى مامات بولسۇن، غوجام پادىشاھ قەيەردە بولسا، قۇلۇڭ شۇ يەردىمۇ بولىدۇ! ــ دېدى.
\m 
\v 22 داۋۇت ئىتتايغا: ئەمدى سەنمۇ بېرىپ \add ئېقىندىن\add* ئۆتكىن، دېدى. شۇنىڭ بىلەن گاتلىق ئىتتاي ھەممە ئادەملىرى ۋە ئۇنىڭ بىلەن ماڭغان بارلىق بالا-چاقىلىرى ئۆتۈپ كەتتى. \f ◼ \fr 15:22 \ft \bd «ئېقىندىن ئۆتكىن»\bd* ــ بەلكى كىدرون دەرياسىدىن (23-ئايەتنى كۆرۈڭ).\f*
\v 23 ھەممە خەلق ئۆتۈۋاتقاندا، پۈتكۈل شۇ يۇرتتىكىلەر قاتتىق ئاۋاز بىلەن يىغلىدى. پادىشاھ ئۆزىمۇ كىدرون ئېقىنىدىن ئۆتكەندە، بارلىق خەلق چۆللۈك تەرىپىگە قاراپ يول ئالدى. \x ◘ \xo 15:23 \xt يـۇھ. 18‏:1\x*
\m 
\v 24 ۋە مانا، زادوك بىلەن لاۋىيلارمۇ خۇدانىڭ ئەھدە ساندۇقىنى كۆتۈرۈپ بىللە كەلدى؛ ئۇلار خۇدانىڭ ئەھدە ساندۇقىنى يەردە قويدى. بارلىق خەلق شەھەردىن چىقىپ ئۆتكۈچە ئابىياتار بولسا، قۇربانلىقلارنى سۇنۇپ تۇراتتى. \f ◼ \fr 15:24 \ft \bd «بارلىق خەلق شەھەردىن چىقىپ ئۆتكۈچە ئابىياتار بولسا، قۇربانلىقلارنى سۇنۇپ تۇراتتى»\bd* ــ باشقا بىرخىل تەرجىمىسى: «بارلىق خەلق شەھەردىن چىقىپ ئۆتكۈچە ئابىياتار ساقلاپ تۇرۇپ، ئاندىن ئۆتتى».\f*
\v 25 پادىشاھ زادوكقا: خۇدانىڭ ئەھدە ساندۇقىنى شەھەرگە ياندۇرۇپ ئېلىپ كىرگىن. مەن ئەگەر پەرۋەردىگارنىڭ كۆزلىرىدە ئىلتىپات تاپسام، ئۇ چوقۇم مېنى ياندۇرۇپ كېلىدۇ ۋە ئۇ ماڭا ئەھدە ساندۇقىنى ۋە ئۆز ماكانىنى يەنە كۆرگۈزىدۇ؛
\v 26 لېكىن ئۇ مېنىڭ توغرامدا: سەندىن خۇرسەنلىكىم يوق، دېسە، مانا مەن؛ ئۇ مېنى قانداق قىلىشنى لايىق كۆرسە، شۇنداق قىلسۇن، ــ دېدى.
\m 
\v 27 پادىشاھ كاھىن زادوكقا: سەن ئالدىن كۆرگۈچى ئەمەسمۇ؟ سەن ۋە ئۆز ئوغلۇڭ ئاخىمائاز ۋە ئابىياتارنىڭ ئوغلى يوناتان، يەنى ئىككىڭلارنىڭ ئىككى ئوغلۇڭلار ساڭا ھەمراھ بولۇپ تىنچ-ئامان شەھەرگە قايتقىن.
\v 28 مانا، مەن سىلەردىن خەۋەر كەلگۈچە چۆلدىكى ئۆتكەللەردە كۈتۈپ تۇراي، ــ دېدى.
\m 
\v 29 شۇنىڭ بىلەن زادوك بىلەن ئابىياتار خۇدانىڭ ئەھدە ساندۇقىنى يېرۇسالېمغا قايتۇرۇپ بېرىپ، ئۇ يەردە قالدى.
\m 
\v 30 لېكىن داۋۇت زەيتۇن تېغىغا چىققاندا، بېشىنى يېپىپ يالاڭ ئاياغ بولۇپ يىغلاۋاتاتتى؛ ئۇنىڭ بىلەن بولغان ھەممە خەلقنىڭ ھەربىرى بېشىنى يېپىپ يىغلاپ چىقىۋاتاتتى.
\v 31 بىرسى كېلىپ داۋۇتقا: ئاھىتوفەلمۇ ئابشالومنىڭ قەستىگە قاتناشقانلار ئىچىدە ئىكەن، دېدى. شۇنىڭ بىلەن داۋۇت دۇئا قىلىپ: ئى پەرۋەردىگار، ئاھىتوفەلنىڭ مەسلىھەتىنى ئەخمەقانىلىككە ئايلاندۇرغايسەن، دېدى.
\m 
\v 32 داۋۇت تاغنىڭ چوققىسىغا، يەنى ئادەتتە ئۇ مەخسۇس خۇداغا ئىبادەت قىلىدىغان جايغا يەتكەندە، ئاركىلىق ھۇشاي تونى يىرتىق، بېشىغا توپا-چاڭ چېچىلغان ھالدا ئۇنىڭ ئالدىغا كەلدى.
\v 33 داۋۇت ئۇنىڭغا: مېنىڭ بىلەن بارساڭ، ماڭا يۈك بولۇپ قالىسەن؛
\v 34 لېكىن شەھەرگە قايتىپ بېرىپ ئابشالومغا: ئى پادىشاھ، مەن بۈگۈنگە قەدەر ئاتاڭنىڭ قۇل-خىزمەتكارى بولغاندەك، ئەمدى سېنىڭ قۇل-خىزمەتكارىڭ بولاي، دېسەڭ، سەن مەن ئۈچۈن ئاھىتوفەلنىڭ مەسلىھەتىنى بىكار قىلىۋېتەلەيسەن.
\v 35 مانا زادوك ۋە ئابىياتار دېگەن كاھىنلارمۇ شۇ يەردە سەن بىلەن بىللە بولىدۇ ئەمەسمۇ؟ پادىشاھنىڭ ئوردىسىدىن نېمە ئاڭلىساڭ، زادوك بىلەن ئابىياتار كاھىنلارغا ئېيتقىن.
\v 36 مانا، ئۇلارنىڭ ئىككى ئوغلى، يەنى زادوكنىڭ ئوغلى ئاخىمائاز بىلەن ئابىياتارنىڭ ئوغلى يوناتانمۇ شۇ يەردە ئۇلارنىڭ يېنىدا تۇرىدۇ. ھەرنېمە ئاڭلىساڭ، ئۇلار ئارقىلىق ماڭا خەۋەر يەتكۈزگىن ــ دېدى.
\m 
\v 37 شۇنىڭ بىلەن داۋۇتنىڭ دوستى ھۇشاي شەھەرگە باردى؛ ئابشالوممۇ دەل شۇ چاغدا يېرۇسالېمغا كىردى.
\b
\b
\c 16
\s1 داۋۇت زىبادىن سوۋغاتلارنى قوبۇل قىلىدۇ
\m 
\v 1 داۋۇت تاغنىڭ چوققىسىدىن ئەمدىلا ئۆتۈشىگە مەفىبوشەتنىڭ خىزمەتكارى زىبا ئىككى يۈز نان، بىر يۈز كىشمىش پوشكىلى، يۈز يازلىق مېۋە پوشكىلى ۋە بىر تۇلۇم شارابنى ئىككى ئېشەككە ئارتىپ ئۇنىڭ ئالدىغا چىقتى. \f ◼ \fr 16:1 \ft \bd «يۈز يازلىق مېۋە پوشكىلى»\bd* ــ ياكى «يۈز ئەنجۈر پوشكىلى».\f*
\m 
\v 2 پادىشاھ زىباغا: بۇلارنى نېمە ئۈچۈن ئەكەلدىڭ؟ دېدى. زىبا: ئېشەكلەرنى پادىشاھنىڭ ئائىلىسىدىكىلەر مېنىشى ئۈچۈن، نانلار بىلەن يازلىق مېۋىلەرنى غۇلاملارنىڭ يېيىشى ئۈچۈن، شارابنى چۆلدە ھېرىپ كەتكەنلەرنىڭ ئىچىشى ئۈچۈن ئەكەلدىم ــ دېدى.
\m 
\v 3 پادىشاھ: غوجاڭنىڭ ئوغلى نەدە؟ ــ دەپ سورىدى. زىبا پادىشاھقا جاۋاب بېرىپ: ئۇ يەنىلا يېرۇسالېمدا قالدى، چۈنكى ئۇ: بۈگۈن ئىسرائىل جەمەتىدىكىلەر ئاتامنىڭ پادىشاھلىقىنى ماڭا ياندۇرۇپ بېرىدۇ، دەپ ئولتۇرىدۇ ــ دېدى. \x ◘ \xo 16:3 \xt 2سام. 19‏:27\x*
\m 
\v 4 پادىشاھ زىباغا: مانا مەفىبوشەتنىڭ ھەممىسى ساڭا تەۋە بولسۇن، دېۋىدى، زىبا: مەن سىلىگە تەزىم قىلىمەن؛ سىلىنىڭ ئالدىلىرىدا ئىلتىپات تاپسام، ئى غوجام پادىشاھ، ــ دېدى.
\m 
\v 5 داۋۇت پادىشاھ باھۇرىمغا كەلگەندە، مانا سائۇلنىڭ جەمەتىدىن بولغان، گېرانىڭ ئوغلى شىمەي ئىسىملىك بىر ئادەم شۇ يەردىن ئۇنىڭ ئالدىغا چىقتى؛ ئۇ بۇ ياققا كەلگەچ كىمدۇ بىرىنى قارغاۋاتاتتى. \x ◘ \xo 16:5 \xt 1پاد. 2‏:8\x*
\v 6 ئۇ داۋۇتنىڭ ئۆزىگە ۋە داۋۇت پادىشاھنىڭ بارلىق خىزمەتكارلىرىغا قاراپ تاشلارنى ئاتتى؛ ھەممە خەلق بىلەن بارلىق پالۋانلار پادىشاھنىڭ ئوڭ تەرىپىدە ۋە سول تەرىپىدە تۇراتتى.
\m 
\v 7 شىمەي قارغاپ: يوقال، يوقال، ھەي سەن قانخور، ئىپلاس! \f ◼ \fr 16:7 \ft \bd «ھەي سەن قانخور، ئىپلاس!»\bd* ــ «ئىپلاس» ئىبرانىي تىلىدا: «ئىبلىس (بېلىيال)نىڭ ئوغلى».\f*
\v 8 سەن سائۇلنىڭ ئورنىدا پادىشاھ بولدۇڭ، لېكىن پەرۋەردىگار ئۇنىڭ جەمەتىنىڭ قېنىنى سېنىڭ بېشىڭغا قايتۇردى؛ ئەمدى پەرۋەردىگار پادىشاھلىقنى ئوغلۇڭ ئابشالومنىڭ قولىغا بەردى؛ مانا، ئۆزۈڭنىڭ رەزىللىكىڭ سېنىڭ ئۈستۈڭگە چۈشتى، چۈنكى سەن بىر قانخورسەن! ــ دېدى.
\m 
\v 9 زەرۇئىيانىڭ ئوغلى ئابىشاي پادىشاھقا: نېمىشقا بۇ ئۆلۈك ئىت غوجام پادىشاھنى قارغىسۇن؟ ئۇ يەرگە بېرىپ ئۇنىڭ بېشىنى كەسكىلى ماڭا ئىجازەت بەرگەيسەن! ــ دېدى. \x ◘ \xo 16:9 \xt 1سام. 24‏:15؛ 2سام. 9‏:8\x*
\m 
\v 10 لېكىن پادىشاھ: ئى زەرۇئىيانىڭ ئوغۇللىرى، مېنىڭ بىلەن نېمە كارىڭلار؟ ئۇ قارغىسا قارغىسۇن! ئەگەر پەرۋەردىگار ئۇنىڭغا، داۋۇتنى قارغىغىن، دەپ ئېيتقان بولسا، ئۇنداقتا كىم ئۇنىڭغا: نېمىشقا بۇنداق قىلىسەن؟ ــ دېيەلىسۇن؟
\m 
\v 11 داۋۇت ئابىشايغا ۋە بارلىق خىزمەتكارلىرىغا: مانا ئۆز پۇشتۇمدىن بولغان ئوغلۇم مېنىڭ جېنىمنى ئىزدىگەن يەردە، بۇ بىنيامىن كىشى ئۇنىڭدىن ئارتۇقراق قىلمامدۇ؟ ئۇنى قارغىغىلى قويغىن، چۈنكى پەرۋەردىگار ئۇنىڭغا شۇنداق بۇيرۇپتۇ.
\v 12 پەرۋەردىگار بەلكىم مېنىڭ دەردلىرىمنى نەزىرىگە ئېلىپ، بۇ ئادەمنىڭ بۈگۈن مېنى قارغىغانلىرىنىڭ ئورنىدا ماڭا ياخشىلىق ياندۇرار، دېدى.
\m 
\v 13 شۇنىڭ بىلەن داۋۇت ئۆز ئادەملىرى بىلەن يولدا مېڭىۋەردى. شىمەي بولسا داۋۇتنىڭ ئۇدۇلدىكى تاغ باغرىدا ماڭغاچ قارغايتتى ھەم تاش ئېتىپ توپا-چاڭ چاچاتتى.
\m 
\v 14 پادىشاھ ۋە ئۇنىڭ بىلەن بولغان خەلقنىڭ ھەممىسى ھېرىپ، مەنزىلگە بارغاندا ئۇ يەردە ئارام ئالدى.
\b
\s1 ئاھىتوفەلنىڭ مەسلىھەتى
\m 
\v 15 ئەمدى ئابشالوم بارلىق ئىسرائىللار بىلەن يېرۇسالېمغا كەلدى؛ ئاھىتوفەل ئۇنىڭ بىلەن بىللە ئىدى.
\v 16 داۋۇتنىڭ دوستى ئاركىلىق ھۇشاي ئابشالومنىڭ قېشىغا كەلگەندە، ئۇ ئابشالومغا: پادىشاھ ياشىسۇن! پادىشاھ ياشىسۇن! ــ دېدى.
\m 
\v 17 ئابشالوم ھۇشايغا: بۇ سېنىڭ دوستۇڭغا كۆرسىتىدىغان ھىممىتىڭمۇ؟ نېمىشقا دوستۇڭ بىلەن بارمىدىڭ؟ ــ دېدى.
\m 
\v 18 ھۇشاي ئابشالومغا: ياق، ئۇنداق ئەمەس، بەلكى پەرۋەردىگار ۋە بۇ خەلق ھەمدە ئىسرائىللارنىڭ ھەممىسى كىمنى تاللىسا، مەن ئۇنىڭغا تەۋە بولاي ۋە ئۇنىڭ يېنىدا تۇرىمەن.
\v 19 شۇنىڭدىن باشقا كىمنىڭ خىزمىتىدە بولاي؟ ئۇنىڭ ئوغلىنىڭ قېشىدا خىزمەت قىلمامدىم؟ سېنىڭ ئاتاڭنىڭ قېشىدا خىزمەت قىلغاندەك، ئەمدى سېنىڭ قېشىڭدا خىزمەت قىلاي، ــ دېدى.
\m 
\v 20 ئاندىن ئابشالوم ئاھىتوفەلگە: مەسلىھەتلىشىپ يول كۆرسىتىڭلار؛ قانداق قىلساق بولار؟ ــ دېدى.
\m 
\v 21 ئاھىتوفەل ئابشالومغا: ئاتاڭنىڭ ئوردىسىغا قارىغىلى قويغان كېنىزەكلىرى بىلەن بىللە ياتقىن؛ شۇنىڭ بىلەن پۈتكۈل ئىسرائىل سېنىڭ ئۆزۈڭنى ئاتاڭغا نەپرەتلىك قىلغانلىقىڭنى ئاڭلايدۇ؛ شۇنداق قىلىپ ساڭا ئەگەشكەنلەرنىڭ قوللىرى كۈچلەندۈرۈلىدۇ، دېدى.
\m 
\v 22 شۇنىڭ بىلەن ئۇلار ئابشالوم ئۈچۈن ئوردىنىڭ ئۆگزىسىدە بىر چېدىر تىكتى؛ ئابشالوم ھەممە ئىسرائىلنىڭ كۆزلىرى ئالدىدا ئۆز ئاتىسىنىڭ كېنىزەكلىرى بىلەن بىللە بولدى.
\m 
\v 23 ئۇ كۈنلەردە ئاھىتوفەلنىڭ بەرگەن مەسلىھەتى خۇددى كىشى خۇدادىن سوراپ ئېرىشكەن سۆز-كالامدەك ھېسابلىناتتى. ئۇنىڭ داۋۇتقا ۋە ئابشالومغا بەرگەن ھەممە مەسلىھەتىمۇ ھەم شۇنداق قارىلاتتى.
\b
\b
\c 17
\s1 ئاھىتوفەلنىڭ مەسلىھەتى بىكار قىلىنىدۇ
\m 
\v 1 ئاھىتوفەل ئابشالومغا: ماڭا ئون ئىككى مىڭ ئادەمنى تاللىۋېلىشقا رۇخسەت بەرسەڭ، مەن بۈگۈن كېچە قوزغىلىپ، داۋۇتنى قوغلاي؛
\v 2 مەن ئۇنىڭ ئۈستىگە چۈشكىنىمدە ئۇ ھېرىپ، قوللىرى ئاجىز بولىدۇ؛ مەن ئۇنى ئالاقزادە قىلىۋېتىمەن، شۇنداقلا ئۇنىڭ بىلەن بولغان بارلىق خەلق قاچىدۇ. مەن پەقەت پادىشاھنىلا ئۇرۇپ ئۆلتۈرىمەن،
\v 3 ئاندىن ھەممە خەلقنى ساڭا بېقىندۇرۇپ قايتۇرىمەن. سەن ئىزدىگەن ئادەم يوقالسا، ھەممە خەلق سېنىڭ قېشىڭغا قايتىدۇ؛ شۇنىڭ بىلەن ھەممە خەلق ئامان-ئېسەن قالىدۇ، دېدى. \f ◼ \fr 17:3 \ft \bd «سەن ئىزدىگەن ئادەم يوقالسا، ھەممە خەلق سېنىڭ قېشىڭغا قايتىدۇ»\bd* ــ ئىبرانىي تىلىدا: «بارلىق ئادەمنىڭ قايتىپ كېلىشى، سەن ئىزدىگەن ئادەمنىڭ جېنىغا باراۋەردۇر».\f*
\m 
\v 4 بۇ مەسلىھەت ئابشالومغا ۋە ئىسرائىلنىڭ بارلىق ئاقساقاللىرىغا ياقتى،
\v 5 لېكىن ئابشالوم: ئاركىلىق ھۇشاينىمۇ چاقىرىڭلار؛ ئۇنىڭ سۆزىنىمۇ ئاڭلايلى، ــ دېدى.
\m 
\v 6 ھۇشاي ئابشالومنىڭ قېشىغا كەلگەندە، ئابشالوم ئۇنىڭغا: ئاھىتوفەل مۇنداق-مۇنداق ئېيتتى؛ ئۇ دېگەندەك قىلايلىمۇ؟ بولمىسا، سەن بىر مەسلىھەت بەرگىن، ــ دېدى.
\m 
\v 7 ھۇشاي ئابشالومغا: ئاھىتوفەلنىڭ بۇ ۋاقىتتا بەرگەن مەسلىھەتى ياخشى ئەمەس، ــ دېدى.
\m 
\v 8 ھۇشاي يەنە مۇنداق دېدى: «سەن ئاتاڭ بىلەن ئادەملىرىنى بىلىسەنغۇ ــ ئۇلار پالۋانلاردۇر، ھازىر دالادىكى بالىلىرىدىن جۇدا قىلىنغان چىشى ئېيىقتەك پەيلى يامان. ئاتاڭ بولسا ھەقىقىي جەڭچىدۇر، ئۆز ئادەملىرى بىلەن بىرگە قونمايدۇ.
\v 9 مانا ئۇ ھازىر بىر غاردا يا باشقا بىر يەردە مۆكۈنۈۋالغان بولسا كېرەك. مۇبادا ئۇ ئاۋۋال خەلقىمىز ئۈستىگە چۈشسە شۇنى ئاڭلىغان ھەركىم: ئابشالومغا ئەگەشكەنلەر قىرغىنچىلىققا ئۇچراپتۇ، ــ دەيدۇ. \f ◼ \fr 17:9 \ft \bd «مۇبادا ئۇ ئاۋۋال خەلقىمىز ئۈستىگە چۈشسە...»\bd* ــ ياكى «دەسلەپتە خەلق(ىمىز)دىن نەچچىسى يىقىلىپ ئۆلتۈرۈلسە،...»\f*
\v 10 ئۇ ۋاقىتتا ھەتتا شىر يۈرەك پالۋانلارنىڭ يۈرەكلىرىمۇ سۇ بولۇپ كېتىدۇ؛ چۈنكى پۈتكۈل ئىسرائىل ئاتاڭنىڭ باتۇر ئىكەنلىكىنى، شۇنداقلا ئۇنىڭغا ئەگەشكەنلەرنىڭمۇ پالۋان ئىكەنلىكىنى بىلىدۇ.
\v 11 شۇڭا مەسلىھەتىم شۇكى، پۈتكۈل ئىسرائىل داندىن تارتىپ بەئەر-شېباغىچە سېنىڭ قېشىڭغا تېز يىغىلسۇن (ئۇلار دېڭىزدىكى قۇملاردەك كۆپتۇر!). سەن ئۆزۈڭ ئۇلارنى باشلاپ جەڭگە چىققىن.
\v 12 بىز ئۇنى قەيەردە تاپساق، شەبنەم يەرگە چۈشكەندەك ئۇنىڭ ئۈستىگە چۈشەيلى. شۇنىڭ بىلەن ئۇنىڭ ئۆزى ۋە ئۇنىڭ بىلەن بولغان كىشىلەردىن ھېچ كىممۇ قالمايدۇ.
\v 13 ئەگەر ئۇ بىر شەھەرگە كىرىۋالسىمۇ، پۈتكۈل ئىسرائىل شۇ يەرگە ئارغامچىلارنى ئېلىپ كېلىپ، شەھەرنى ھەتتا ئۇنىڭدىكى كىچىك شېغىل-تاشلارنىمۇ قالدۇرماي سۆرەپ ئەكىلىپ، دەريا جىلغىسىغا تاشلىۋېتىمىز».
\m 
\v 14 ئابشالوم بىلەن ئىسرائىلنىڭ ھەممە ئادەملىرى: ئاركىلىق ھۇشاينىڭ مەسلىھەتى ئاھىتوفەلنىڭ مەسلىھەتىدىن ياخشى ئىكەن، دېيىشتى. چۈنكى پەرۋەردىگار ئابشالومنىڭ بېشىغا بالا كەلسۇن دەپ، ئاھىتوفەلنىڭ ياخشى مەسلىھەتىنىڭ بىكار قىلىنىشىنى بېكىتكەنىدى.
\m 
\v 15 ھۇشاي زادوك بىلەن ئابىياتار كاھىنلارغا: ئاھىتوفەلنىڭ ئابشالوم بىلەن ئىسرائىلنىڭ ئاقساقاللىرىغا بەرگەن مەسلىھەتى مۇنداق-مۇنداق، ئەمما مېنىڭ مەسلىھەتىم بولسا مۇنداق-مۇنداق؛
\v 16 ھازىر سىلەر دەرھال ئادەم ئەۋەتىپ داۋۇتقا: بۇ كېچىدە چۆلنىڭ كېچىكلىرىدە قونماي، بەلكى تېز ئۆتۈپ كېتىڭلار، بولمىسا پادىشاھ ۋە ئۇنىڭ بىلەن بولغان ھەممە خەلق ھالاك بولۇشى مۇمكىن، دەپ يەتكۈزۈڭلار ــ دېدى.
\m 
\v 17 ئۇ ۋاقىتتا يوناتان بىلەن ئاخىمائاز ئەن-روگەلدە كۈتۈپ تۇراتتى؛ ئۇلار باشقىلارنىڭ كۆرۈپ قالماسلىقى ئۈچۈن شەھەرگە كىرمىدى؛ بىر دېدەكنىڭ چىقىپ ئۇلارغا خەۋەر بېرىشى بېكىتىلدى. ئۇلار بېرىپ داۋۇت پادىشاھقا خەۋەرنى يەتكۈزدى.
\m 
\v 18 لېكىن بىر ياش يىگىت ئۇلارنى كۆرۈپ قېلىپ، ئابشالومغا دەپ قويدى. ئەمما بۇ ئىككىيلەن ئىتتىك بېرىپ، باھۇرىمدىكى بىر ئادەمنىڭ ئۆيىگە كىردى. بۇ ئادەمنىڭ ھويلىسىدا قۇدۇق بار ئىدى؛ ئۇلار شۇنىڭغا چۈشۈپ يوشۇرۇندى.
\v 19 ئۇنىڭ ئايالى قۇدۇقنىڭ ئاغزىغا ياپقۇچىنى يېپىپ ئۈستىگە سوقۇلغان بۇغداينى تۆكۈپ قويدى؛ شۇنىڭ بىلەن ھېچ ئىش ئاشكارىلانمىدى.
\m 
\v 20 ئابشالومنىڭ خىزمەتكارلىرى ئۆيگە كىرىپ ئايالنىڭ قېشىغا كېلىپ: ئاخىمائاز بىلەن يوناتان قەيەردە؟ ــ دەپ سورىدى. ئايال: ئۇلار ئېرىقتىن ئۆتۈپ كەتتى، دېدى. كەلگەنلەر ئۇلارنى ئىزدەپ تاپالماي، يېرۇسالېمغا قايتىپ كەتتى.
\m 
\v 21 ئۇلار كەتكەندىن كېيىن، بۇ ئىككىيلەن قۇدۇقتىن چىقىپ، بېرىپ داۋۇت پادىشاھقا خەۋەر بەردى. ئۇلار داۋۇتقا: قوپۇپ، سۇدىن ئۆتكىن؛ چۈنكى ئاھىتوفەل سېنى تۇتۇش ئۈچۈن شۇنداق مەسلىھەت بېرىپتۇ، ــ دېدى.
\m 
\v 22 شۇنىڭ بىلەن داۋۇت ۋە ئۇنىڭ بىلەن بولغان بارلىق خەلق قوزغىلىپ ئىئوردان دەرياسىدىن ئۆتتى؛ تاڭ ئاتقۇچە ئىئوردان دەرياسىدىن ئۆتمىگەن ھېچكىم قالمىدى.
\m 
\v 23 ئاھىتوفەل ئۆز مەسلىھەتىنى قوبۇل قىلمىغانلىقىنى كۆرۈپ ئېشىكىنى توقۇپ، ئۆز شەھىرىدىكى ئۆيىگە بېرىپ، ئۆيىدىكىلەرگە ۋەسىيەت تاپشۇرغاندىن كېيىن، ئېسىلىپ ئۆلۈۋالدى. ئۇ ئۆز ئاتىسىنىڭ قەبرىسىدە دەپنە قىلىندى.
\m 
\v 24 شۇ ئارىلىقتا داۋۇت ماھانائىمغا يېتىپ كەلگەنىدى، ئابشالوم ۋە ئۇنىڭ بىلەن بولغان ئىسرائىلنىڭ ھەممە ئادەملىرىمۇ ئىئوردان دەرياسىدىن ئۆتۈپ بولغانىدى.
\m 
\v 25 ئابشالوم يوئابنىڭ ئورنىدا ئاماسانى قوشۇننىڭ ئۈستىگە سەردار قىلىپ قويدى. ئاماسا بولسا يىترا ئىسىملىك بىر ئىسرائىللىق كىشىنىڭ ئوغلى ئىدى. ئۇ كىشى ناھاشنىڭ قىزى ئابىگائىل بىلەن يېقىنچىلىق قىلغانىدى. ناھاش يوئابنىڭ ئانىسى زەرۇئىيا بىلەن ئاچا-سىڭىل ئىدى.
\m 
\v 26 ئىسرائىل بىلەن ئابشالوم گىلېئادنىڭ زېمىنىدا بارگاھ تىكتى.
\m 
\v 27 داۋۇت ماھانائىمغا يېتىپ كەلگەندە، ئاممونىيلارنىڭ رابباھ شەھىرىدىن بولغان ناھاشنىڭ ئوغلى شوبى بىلەن لو-دىبارلىق ئاممىئەلنىڭ ئوغلى ماكىر ۋە روگېلىمدىن بولغان گىلېئادلىق بارزىللاي دېگەنلەر \x ◘ \xo 17:27 \xt 2سام. 19‏:31، 32؛ 1پاد. 2‏:7\x*
\v 28 يوتقان-كۆرپە، داس، قاچا-قۇچا، بۇغداي، ئارپا، ئۇن، قوماچ، پۇرچاق، قىزىل ماش، قورۇغان پۇرچاقلار،
\v 29 ھەسەل، قايماق ۋە قويلارنى كەلتۈرۈپ، كالا سۈتىدە قىلىنغان قۇرۇت-ئىرىمچىك قاتارلىقلارنى داۋۇت بىلەن خەلققە يېيىش ئۈچۈن ئېلىپ كەلدى، چۈنكى ئۇلار: شۈبھىسىزكى، خەلق چۆلدە ھېرىپ-ئېچىپ، ئۇسساپ كەتكەندۇ، دەپ ئويلىغانىدى.
\b
\b
\c 18
\s1 ئابشالومنىڭ ئۆلۈشى
\m 
\v 1 داۋۇت ئۆزى بىلەن بولغان خەلقنى يىغىپ ئېدىتلىدى ۋە ئۇلارنىڭ ئۈستىگە مىڭبېشى بىلەن يۈزبېشى قويدى.
\v 2 ئاندىن داۋۇت خەلقنى ئۈچ بۆلەككە بۆلۈپ جەڭگە چىقاردى؛ بىرىنچى بۆلەكنى يوئابنىڭ قول ئاستىدا، ئىككىنچى بۆلەكنى زەرۇئىيانىڭ ئوغلى، يوئابنىڭ ئىنىسى ئابىشاينىڭ قول ئاستىدا ۋە ئۈچىنچى بۆلەكنى گاتلىق ئىتتاينىڭ قول ئاستىدا قويدى. پادىشاھ خەلققە: بەرھەق، مەنمۇ سىلەر بىلەن جەڭگە چىقىمەن، دېدى.
\m 
\v 3 لېكىن خەلق: سىلى چىقمىسىلا، ئەگەر بىز قاچساق دۈشمەن بىزگە پەرۋا قىلمايدۇ؛ ھەتتا يېرىمىمىز ئۆلۈپ كەتسەكمۇ بىزگە پەرۋا قىلمايدۇ. چۈنكى ئۆزلىرى بىزنىڭ ئون مىڭىمىزگە باراۋەر بولىلا. ياخشىسى سىلى شەھەردە تۇرۇپ بىزگە ھەمدەم بولۇشقا تەييار تۇرغايلا، دېدى.
\m 
\v 4 پادىشاھ ئۇلارغا: سىلەرگە نېمە لايىق كۆرۈنسە، شۇنى قىلىمەن، ــ دېدى. شۇنىڭ بىلەن خەلق يۈزدىن، مىڭدىن بولۇپ شەھەردىن چىقىۋاتقاندا، پادىشاھ دەرۋازىنىڭ يېنىدا تۇردى.
\v 5 پادىشاھ يوئاب بىلەن ئابشاي ۋە ئىتتايغا: مەن ئۈچۈن ئابشالومغا ياخشى مۇئامىلىدە بولۇپ ئاياڭلار، دېدى. پادىشاھنىڭ \add ھەممە سەردارلىرىغا\add* ئابشالوم توغرىسىدا شۇنداق تاپىلىغىنىدا، بارلىق خەلق تاپىلىغىنىنى ئاڭلىدى.
\v 6 ئاندىن خەلق ئىسرائىل بىلەن سوقۇشقىلى مەيدانغا چىقتى؛ سوقۇش ئەفرائىمنىڭ ئورمانلىقىدا بولدى.
\m 
\v 7 ئۇ يەردە ئىسرائىل داۋۇتنىڭ ئادەملىرىدىن مەغلۇپ بولدى. ئۇ كۈنى ئۇلار قاتتىق قىرغىن قىلىندى ــ يىگىرمە مىڭى ئۆلدى.
\v 8 سوقۇش شۇ زېمىنغا يېيىلدى؛ ئورمانلىق يەۋەتكەنلەر قىلىچتا ئۆلگەنلەردىن كۆپ بولدى.
\b
\m 
\v 9 ئابشالوم داۋۇتنىڭ غۇلاملىرى بىلەن تۇيۇقسىز ئۇچرىشىپ قالدى؛ ئابشالوم ئۆز قېچىرىغا مىنىپ، چوڭ دۇب دەرىخىنىڭ قويۇق شاخلىرىنىڭ تېگىدىن ئۆتكەندە، ئۇنىڭ بېشى دەرەخ شېخىغا كەپلىشىپ قېلىپ، ئۇ ئېسىلىپ قالدى؛ ئۇ مىنگەن قېچىر بولسا ئالدىغا كېتىپ قالدى. \f ◼ \fr 18:9 \ft \bd «ئۇنىڭ بېشى ... كەپلىشىپ قېلىپ، ئۇ ئېسىلىپ قالدى»\bd* ــ ئىبرانىي تىلىدا: «ئۇنىڭ بېشى ... كەپلىشىپ قېلىپ، ئۇ ئاسمان-زېمىن ئوتتۇرىسىدا ئېسىلىپ قالدى».\f*
\v 10 بىرسى بۇنى كۆرۈپ يوئابقا خەۋەر بېرىپ: مانا، مەن ئابشالومنىڭ بىر دۇب دەرىخىدە ساڭگىلاپ تۇرغىنىنى كۆردۈم، دېدى.
\m 
\v 11 يوئاب خەۋەر بەرگەن ئادەمگە: نېمە! سەن ئۇنى كۆرۈپ تۇرۇپ، نېمىشقا ئۇنى ئۇرۇپ ئۆلتۈرۈپ يەرگە چۈشۈرمىدىڭ؟ شۇنداق قىلغان بولساڭ، ساڭا ئون كۈمۈش تەڭگە ۋە بىر كەمەر بېرەتتىم، ــ دېدى.
\m 
\v 12 ئۇ ئادەم يوئابقا: قولۇمغا مىڭ كۈمۈش تەڭگە تەگسىمۇ، قولۇمنى پادىشاھنىڭ ئوغلىغا ئۇزاتمايتتىم! چۈنكى پادىشاھنىڭ ھەممىمىز ئالدىدا ساڭا، ئابىشايغا ۋە ئىتتايغا: مېنىڭ ئۈچۈن ھەر بىرىڭلار ئابشالومنى ئاياڭلار، دەپ بۇيرۇغىنىنى ئاڭلىدۇق.
\v 13 ئەگەر مەن ئۆز جېنىمنى تەۋەككۇل قىلىپ، شۇنداق قىلغان بولسام (ھەرقانداق ئىش پادىشاھتىن يوشۇرۇن قالمايدۇ!) سەن مېنى تاشلاپ، دۈشمىنىڭ قاتارىدا كۆرەتتىڭ، ــ دېدى.
\m 
\v 14 يوئاب: سېنىڭ بىلەن بۇنداق دېيىشىشكە چولام يوق! ــ دېدى-دە، قولىغا ئۈچ نەيزىنى ئېلىپ دەرەختە ساڭگىلاقلىق ھالدا تىرىك تۇرغان ئابشالومنىڭ يۈرىكىگە سانجىدى. \f ◼ \fr 18:14 \ft \bd «دەرەختە ساڭگىلاقلىق ھالدا تىرىك تۇرغان ئابشالومنىڭ يۈرىكىگە سانجىدى»\bd* ــ ئىبرانىي تىلىدا «دەرەخنىڭ يۈرىكىدە ساڭگىلاقلىق تىرىك تۇرغان ئابشالومنىڭ يۈرىكىگە سانجىدى» دېگەن سۆزلەر بىلەن ئىپادىلىنىدۇ.\f*
\v 15 ئاندىن يوئابنىڭ ياراغ كۆتۈرگۈچىسى بولغان ئون غۇلام ئابشالومنىڭ چۆرىسىگە يىغىلىپ، ئۇنى ئۇرۇپ ئۆلتۈردى.
\m 
\v 16 ئاندىن يوئاب كاناي چالدى؛ خەلق ئىسرائىلنى قوغلاشتىن ياندى؛ چۈنكى يوئاب قوشۇننى چېكىنىشكە چاقىردى.
\v 17 ئۇلار ئابشالومنى ئورمانلىقتىكى چوڭ بىر ئازگالغا تاشلاپ ئۈستىگە نۇرغۇن تاشلارنى دۆۋىلەپ قويدى. ئىسرائىللار بولسا قېچىپ ھەربىرى ئۆز ماكانىغا كەتتى. \f ◼ \fr 18:17 \ft \bd «ئىسرائىللار بولسا قېچىپ ھەربىرى ئۆز ماكانىغا كەتتى»\bd* ــ ئىبرانىي تىلىدا: «ئىسرائىللار بولسا قېچىپ ھەربىرى ئۆز چېدىرىغا كەتتى».\f*
\m 
\v 18 ئابشالوم تىرىك ۋاقتىدا پادىشاھ ۋادىسىدا ئۆزىگە بىر ئابىدە تۇرغۇزغانىدى. چۈنكى ئۇ: مېنىڭ نامىمنى قالدۇرىدىغانغا ئوغلۇم يوق دەپ، ئۇ تاش ئابىدىنى ئۆز نامى بىلەن ئاتىغانىدى. شۇنىڭ بىلەن بۇ تاش بۈگۈنگە قەدەر «ئابشالومنىڭ يادىكارى» دەپ ئاتىلىدۇ. \f ◼ \fr 18:18 \ft \bd «مېنىڭ نامىمنى قالدۇردىغانغا ئوغلۇم يوق...»\bd* ــ ئابشالومنىڭ بۇ سۆزىدىن قارىغاندا، ئۇنىڭ ئۈچ ئوغلى (27:14) ھەممىسى بالدۇر ئۆلگەنىدى\f*
\b
\s1 داۋۇت ئابشالومنىڭ ئۆلۈمىدىن خەۋەر تاپىدۇ
\m 
\v 19 زادوكنىڭ ئوغلى ئاخىمائاز \add يوئابقا\add*: پەرۋەردىگار سېنى دۈشمەنلىرىڭدىن قۇتقۇزۇپ سەن ئۈچۈن ئىنتىقام ئالدى، دەپ پادىشاھقا خەۋەر بېرىشكە مېنى دەرھال ماڭغۇزغىن، ــ دېدى.
\m 
\v 20 لېكىن يوئاب ئۇنىڭغا: سەن بۈگۈن خەۋەر بەرمەيسەن، بەلكى باشقا بىر كۈنى خەۋەر بېرىسەن؛ پادىشاھنىڭ ئوغلى ئۆلگىنى تۈپەيلىدىن، بۈگۈن خەۋەر بەرمەيسەن، دېدى.
\m 
\v 21 شۇنىڭ بىلەن يوئاب كۇشىيغا: بېرىپ پادىشاھقا كۆرگىنىڭنى دەپ بەرگىن، دېدى. كۇشىي يوئابقا تەزىم قىلىپ يۈگۈرۈپ كەتتى. \f ◼ \fr 18:21 \ft \bd «شۇنىڭ بىلەن يوئاب كۇشىيغا... دېدى»\bd* ــ «كۇشىي»: ھەبەش، ئېفىئوپىيەلىك. ئېفىئوپىيەلىكلەرنىڭ بۈگۈنگە قەدەر ئۇزۇنغا يۈگۈرۈشتە داڭقى بار.\f*
\m 
\v 22 لېكىن زادوكنىڭ ئوغلى ئاخىمائاز يوئابقا يەنە: قانداقلا بولمىسۇن بۇ كۇشىينىڭ كەينىدىن يۈگۈرۈشكە ماڭا ئىجازەت بەرگىن، ــ دېدى. يوئاب: ئى ئوغلۇم، ساڭا ھېچقانداق سۆيۈنچى بەرگۈدەك خەۋەر بولمىسا، نېمىشقا يۈگۈرۈشنى خالايسەن؟ ــ دېدى.
\m 
\v 23 ئۇ يەنە: قانداقلا بولمىسۇن، مېنى يۈگۈرگۈزگىن، دېدى. يوئاب ئۇنىڭغا: ماڭ، يۈگۈر، دېۋىدى، ئاخىمائاز ئىئوردان دەرياسىدىكى تۈزلەڭلىك بىلەن يۈگۈرۈپ كۇشىيگە يېتىشىپ ئۇنىڭدىن ئۆتۈپ كەتتى.
\m 
\v 24 داۋۇت ئىچكى-تاشقى دەرۋازىنىڭ ئوتتۇرىسىدا ئولتۇراتتى. كۆزەتچى دەرۋازىنىڭ ئۆگزىسىدىن سېپىلنىڭ ئۈستىگە چىقىپ، بېشىنى كۆتۈرۈپ قارىۋىدى، مانا بىر ئادەمنىڭ يۈگۈرۈپ كېلىۋاتقىنىنى كۆردى. \f ◼ \fr 18:24 \ft \bd «داۋۇت ئىچكى-تاشقى دەرۋازىنىڭ ئوتتۇرىسىدا ئولتۇراتتى»\bd* ــ ئىبرانىي تىلىدا «داۋۇت ئىككى دەرۋازىنىڭ ئوتتۇرىسىدا ئولتۇراتتى». پەرزىمىزچە «بۇ ئىككى دەرۋازا» شەھەرنىڭ ئىچكى ۋە تاشقى قوۋۇقى بولسا كېرەك.\f*
\m 
\v 25 كۆزەتچى ۋارقىراپ پادىشاھقا خەۋەر بەردى. پادىشاھ: ئەگەر ئۇ يالغۇز بولسا ئۇنىڭدا چوقۇم خەۋەر بار، دېدى. خەۋەرچى بولسا يېقىنلىشىپ كېلىۋاتاتتى.
\v 26 ئاندىن كۆزەتچى يەنە بىر ئادەمنىڭ يۈگۈرۈپ كەلگىنىنى كۆردى. كۆزەتچى دەرۋازىۋەنگە: مانا يەنە بىر ئادەم يالغۇز يۈگۈرۈپ كېلىۋاتىدۇ، ــ دېدى. پادىشاھ: بۇمۇ خەۋەرچى ئىكەن، دېدى.
\m 
\v 27 كۆزەتچى: ئاۋۋالقىسىنىڭ يۈگۈرۈشى ماڭا زادوكنىڭ ئوغلى ئاخىمائازنىڭ يۈگۈرشىدەك كۆرۈندى، ــ دېدى. پادىشاھ: ئۇ ياخشى ئادەم، خۇش خەۋەر يەتكۈزىدۇ، ــ دېدى.
\m 
\v 28 ئاخىمائاز پادىشاھقا توۋلاپ: سالام! دەپ پادىشاھقا يۈزىنى يەرگە تەگكۈزۈپ تەزىم قىلىپ: غوجام پادىشاھقا زىيان يەتكۈزۈشكە قوللىرىنى كۆتۈرگەن ئادەملەرنى مەغلۇبىيەتكە مۇپتىلا قىلغان پەرۋەردىگار خۇدالىرى مۇبارەكتۇر! ــ دېدى. \f ◼ \fr 18:28 \ft \bd «سالام!»\bd* ــ (ئىبرانىي تىلىدا «شالوم»)نىڭ مەنىسى: «تىنچلىق! خاتىرجەملىك!».\f*
\m 
\v 29 پادىشاھ: ئابشالوم سالامەتمۇ؟ ــ دەپ سورىدى. ئاخىمائاز جاۋاب بېرىپ: يوئاب پادىشاھنىڭ قۇلى ۋە پېقىرلىرىنى ماڭدۇرغاندا، پېقىر كىشىلەرنىڭ چوڭ قالايمىقانچىلىقىنى كۆردۇم، لېكىن نېمە ئىش بولغانلىقىنى بىلمىدىم، ــ دېدى.
\m 
\v 30 پادىشاھ: بولدى، بۇياقتا تۇرۇپ تۇرغىن، دېدى. ئۇ بىر تەرەپكە بېرىپ تۇردى.
\m 
\v 31 ۋە مانا، كۇشىي يېتىپ كەلدى؛ كۇشىي: غوجام پادىشاھ خۇش خەۋەرنى ئاڭلىغايلا. پەرۋەردىگار بۈگۈن ئاسىيلىق قىلىپ قوزغالغان ھەممىسىدىن سىلىنى قۇتقۇزۇپ، ئۇلاردىن ئىنتىقام ئالدى، دېدى.
\m 
\v 32 پادىشاھ كۇشىيغا: يىگىت ئابشالوم سالامەتمۇ؟ دەپ سورىدى. كۇشىيلىق: غوجام پادىشاھنىڭ دۈشمەنلىرى ۋە سىلىنى قەستلەشكە قوزغالغانلارنىڭ ھەممىسى ئۇ يىگىتكە ئوخشاش بولسۇن! ــ دېدى.
\m 
\v 33 پادىشاھ تولىمۇ ئازابلىنىپ، دەرۋازىنىڭ تۆپىسىدىكى بالىخانىغا يىغلىغان پېتى چىقتى؛ ئۇ ماڭغاچ: ئى ئوغلۇم ئابشالوم! ئى ئوغلۇم، ئوغلۇم ئابشالوم! كاشكى، مەن سېنىڭ ئورنۇڭدا ئۆلسەم بولماسمىدى! ئى ئابشالوم، مېنىڭ ئوغلۇم، مېنىڭ ئوغلۇم! دېدى.
\b
\b
\c 19
\m 
\v 1 بىرسى يوئابقا: پادىشاھ ئابشالوم ئۈچۈن يىغلاپ ماتەم تۇتماقتا، دەپ خەۋەر بەردى.
\v 2 شۇنىڭ بىلەن شۇ كۈندىكى نۇسرەت خەلق ئۈچۈن مۇسىبەتكە ئايلاندى؛ چۈنكى خەلق شۇ كۈنىدە: پادىشاھ ئۆز ئوغلى ئۈچۈن قايغۇ-ھەسرەت تارتىۋاتىدۇ، دەپ ئاڭلىدى.
\v 3 ئۇ كۈنى خەلق سوقۇشتىن قېچىپ خىجالەتتە قالغان ئادەملەردەك، ئوغرىلىقچە شەھەرگە كىردى.
\v 4 پادىشاھ يۈزىنى يېپىپ: ئى، ئوغلۇم ئابشالوم، ئى ئابشالوم، مېنىڭ ئوغلۇم، مېنىڭ ئوغلۇم! ــ دەپ قاتتىق ئاۋاز بىلەن پەرياد كۆتۈردى.
\m 
\v 5 لېكىن يوئاب پادىشاھنىڭ ئۆيىگە كىرىپ، ئۇنىڭ قېشىغا كېلىپ: ئۆز جېنىڭنى، ئوغۇللىرىڭ بىلەن قىزلىرىڭنىڭ جېنىنى، ئاياللىرىڭنىڭ جېنى بىلەن كېنىزەكلىرىڭنىڭ جېنىنى قۇتقۇزغان ھەممە خىزمەتكارلارنىڭ يۈزىنى سەن بۈگۈن خىجالەتتە قالدۇردۇڭ!
\v 6 سەن ئۆزۈڭگە نەپرەتلىنىدىغانلارنى سۆيىسەن، سېنى سۆيىدىغانلارغا نەپرەتلىنىدىغاندەك قىلىسەن! چۈنكى سەن بۈگۈن سەردارلىرىڭنى ياكى خىزمەتكارلىرىڭنى نەزىرىڭدە ھېچنەرسە ئەمەس دېگەندەك قىلدىڭ! چۈنكى بۈگۈن ئابشالوم تىرىك قېلىپ، بىز ھەممىمىز ئۆلگەن بولساق، نەزىرىڭدە ياخشى بولاتتىكەن، دەپ بىلىپ يەتتىم.
\v 7 ئەمدى چىقىپ خىزمەتكارلىرىڭنىڭ كۆڭلىگە تەسەللىي بەرگىن؛ چۈنكى مەن پەرۋەردىگار بىلەن قەسەم قىلىمەنكى، ئەگەر چىقمىساڭ، بۈگۈن كېچە ھېچ ئادەم سېنىڭ بىلەن قالمايدۇ. بۇ بالا ياشلىقىڭدىن تارتىپ بۈگۈنكى كۈنگىچە ئۈستۈڭگە چۈشكەن ھەرقانداق بالادىن ئېغىر بولىدۇ، ــ دېدى.
\m 
\v 8 شۇنىڭ بىلەن پادىشاھ چىقىپ دەرۋازىدا ئولتۇردى، ھەممە خەلققە: مانا، پادىشاھ دەرۋازىدا ئولتۇرىدۇ، دېگەن خەۋەر يەتكۈزۈلگەندە، ئۇلارنىڭ ھەممىسى پادىشاھنىڭ قېشىغا كەلدى. ئەمما ئىسرائىللار بولسا ھەممىسى قېچىپ، ئۆز ئۆيىگە قايتىپ كەتتى. \f ◼ \fr 19:8 \ft \bd «...ھەممىسى قېچىپ، ئۆز ئۆيىگە قايتىپ كەتتى»\bd* ــ ئىبرانىي تىلىدا «... ھەممىسى قېچىپ، ئۆز چېدىرىغا قايتىپ كەتتى». مۇشۇ ئايەتتىكى «ئىسرائىللار» ئابشالومغا ئەگەشكەن ئىسرائىللارنى كۆرسىتىدۇ، ئەلۋەتتە (ئۇلارنىڭ كۆپىنچىسى يەھۇدا ۋە بىنيامىندىن باشقا ئون قەبىلىدىن ئىدى).\f*
\m 
\v 9 ئەمدى ئىسرائىل قەبىلىسىدىكى ھەممە خەلق غۇلغۇلا قىلىشىپ: پادىشاھ بىزنى دۈشمەنلىرىمىزنىڭ قولىدىن ئازاد قىلغان، بىزنى فىلىستىيلەرنىڭ قولىدىن قۇتقۇزغانىدى. ئەمما، ئۇ ھازىر ئابشالوم تۈپەيلىدىن زېمىندىن ئۆزىنى قاچۇرۇۋاتىدۇ.
\v 10 لېكىن بىز ئۈستىمىزگە پادىشاھ بولۇشقا مەسىھ قىلغان ئابشالوم بولسا جەڭدە ئۆلدى. ئەمدى نېمىشقا پادىشاھنى ياندۇرۇپ ئېلىپ كېلىشكە گەپ قىلمايسىلەر؟ دېيىشتى. \f ◼ \fr 19:10 \ft \bd «...نېمىشقا پادىشاھنى ياندۇرۇپ ئېلىپ كېلىشكە گەپ قىلمايسىلەر؟»\bd* ــ ئىبرانىي تىلىدا «نېمىشقا پادىشاھنى ياندۇرۇپ ئېلىپ كېلىشكە سۈكۈت قىلىسىلەر؟».\f*
\m 
\v 11 داۋۇت پادىشاھ زادوك بىلەن ئابىياتار كاھىنلارغا ئادەم ئەۋەتىپ: سىلەر يەھۇدانىڭ ئاقساقاللىرىغا: \add پادىشاھ مۇنداق دەيدۇ\add*: ــ ھەممە ئىسرائىللارنىڭ پادىشاھنى ئوردىسىغا قايتۇرۇپ كېلەيلى، دېيىشكەن تەلىپلىرىنىڭ ھەممىسى پادىشاھنىڭ قۇلىقىغا يەتكەن يەردە، نېمىشقا سىلەر بۇ ئىشتا ئۇلاردىن كېيىن قالىسىلەر؟
\v 12 سىلەر مېنىڭ قېرىنداشلىرىم، مېنىڭ ئەت-ئۇستىخانلىرىم تۇرۇپ، نېمىشقا پادىشاھنى ئېلىپ كېلىشتە ھەممىسىدىن كېيىن قالىسىلەر؟! ــ دەڭلار.
\v 13 ۋە شۇنداقلا يەنە ئاماساغىمۇ: پادىشاھ مۇنداق دەيدۇ: ــ سەن مېنىڭ ئەت-ئۇستىخانلىرىم ئەمەسمۇسەن؟ ئەگەر سېنى يوئابنىڭ ئورنىدا مېنىڭ قېشىمدا دائىم تۇرىدىغان قوشۇننىڭ سەردارى قىلمىسام، خۇدا مېنى ئۇرسۇن ھەم ئۇنىڭدىن ئارتۇق جازالىسۇن ــ دەڭلار، ــ دېدى. \x ◘ \xo 19:13 \xt 2سام. 17‏:25\x*
\m 
\v 14 بۇنىڭ بىلەن ئۇ يەھۇدادىكى ئادەملەرنىڭ كۆڭۈللىرىنى بىر ئادەمنىڭ كۆڭلىدەك ئۆزىگە مايىل قىلدى. ئۇلار پادىشاھقا ئادەم ماڭدۇرۇپ: سەن ئۆزۈڭ بىلەن ھەممە خىزمەتكارلىرىڭ بىرگە يېنىپ كېلىڭلار، دەپ خەۋەر يەتكۈزدى.
\m 
\v 15 شۇنىڭ بىلەن پادىشاھ يېنىپ ئىئوردان دەرياسىغىچە كەلدى. يەھۇدادىكى ئادەملەر پادىشاھنى ئىئوردان دەرياسىدىن ئۆتكۈزىمىز دەپ، پادىشاھنىڭ ئالدىغا گىلگالغا بارغانىدى.
\v 16 باھۇرىمدىن چىققان بىنيامىنلىق گېرانىڭ ئوغلى شىمەي ئالدىراپ كېلىپ، يەھۇدادىكى ئادەملەر بىلەن چۈشۈپ، پادىشاھنىڭ ئالدىغا چىقتى. \x ◘ \xo 19:16 \xt 2سام. 16‏:5؛ 1پاد. 2‏:8\x*
\m 
\v 17 شىمەيگە بىنيامىن قەبىلىسىدىن مىڭ ئادەم ئەگەشتى؛ ئۇلار بىلەن سائۇلنىڭ جەمەتىدە خىزمەتكار بولغان زىبا، ئۇنىڭ ئون بەش ئوغلى ۋە يىگىرمە خىزمەتكارىمۇ ئۇنىڭغا قوشۇلۇپ كەلدى؛ بۇلارنىڭ ھەممىسى ئىئوردان دەرياسىدىن ئۆتۈپ پادىشاھنىڭ ئالدىغا چىقتى.
\m 
\v 18 بىر كېمە پادىشاھنىڭ ئىختىيارىغا قويۇلۇپ، ئائىلە تاۋابىئاتلىرىنى ئۆتكۈزۈش ئۈچۈن ئۇيان-بۇيان ئۆتۈپ يۈرەتتى. پادىشاھ ئىئوردان دەرياسىدىن ئۆتكەندە، گېرانىڭ ئوغلى شىمەي كېلىپ ئۇنىڭ ئالدىدا يىقىلىپ تۇرۇپ \f ◼ \fr 19:18 \ft \bd «بىر كېمە پادىشاھنىڭ ئىختىيارىغا قويۇلۇپ، ئائىلە تاۋابىئاتلىرىنى ... ئۆتۈپ يۈرەتتى»\bd* ــ بەزىلەر: «ئۇلار ئۆزلىرىنى پادىشاھنىڭ ئىختىيارىغا قويۇپ، دەريا كېچىكىدە ئائىلە تاۋابىئاتلىرىنى ... ئۆتۈپ يۈرەتتى» دەپ تەرجىمە قىلىدۇ.\f*
\v 19 پادىشاھقا: غوجام قۇللىرىغا قەبىھلىك سانىمىغايلا؛ غوجام پادىشاھ يېرۇسالېمدىن چىققان كۈندە قۇللىرىنىڭ قىلغان قەبىھلىكىنى ئەسلىرىگە كەلتۈرمىگەيلا؛ ئۇ پادىشاھنىڭ كۆڭلىگە كەلمىسۇن.
\v 20 چۈنكى قۇللىرى ئۆزىنىڭ گۇناھ قىلغىنىمنى ئوبدان بىلىدۇ؛ شۇڭا مانا، مەن يۈسۈپنىڭ جەمەتىدىن ھەممىدىن ئاۋۋال بۈگۈن غوجام پادىشاھنى قارشى ئېلىشقا چىقتىممەن، ــ دېدى.
\m 
\v 21 زەرۇئىيانىڭ ئوغلى ئابىشاي بۇنى ئاڭلاپ: شىمەي پەرۋەردىگارنىڭ مەسىھ قىلغىنىنى قارغىغان تۇرسا، ئۆلۈمگە مەھكۇم قىلىنىش لازىم بولمامدۇ؟ ــ دېدى.
\m 
\v 22 لېكىن داۋۇت: ئى زەرۇئىيانىڭ ئوغۇللىرى، سىلەرنىڭ مېنىڭ بىلەن نېمە كارىڭلار؟ بۈگۈن سىلەر ماڭا قارشى چىقماقچمۇسىلەر؟ بۈگۈنكى كۈندە ئىسرائىلدا ئادەملەر ئۆلۈمگە مەھكۇم قىلىنىشى كېرەكمۇ؟ بۈگۈن ئىسرائىلغا پادىشاھ ئىكەنلىكىمنى بىلمەيمەنمۇ؟ ــ دېدى. \f ◼ \fr 19:22 \ft \bd «...سىلەر ماڭا قارشى چىقماقچمۇسىلەر؟»\bd* ــ ئىبرانىي تىلىدا: «سىلەر ماڭا شەيتان بولماقچىمۇسىلەر؟»\f*
\m 
\v 23 ئاندىن پادىشاھ شىمەيگە: سەن ئۆلمەيسەن، ــ دېدى. پادىشاھ ئۇنىڭغا قەسەم قىلدى.
\m 
\v 24 ئەمدى سائۇلنىڭ نەۋرىسى مەفىبوشەت پادىشاھنى قارشى ئالغىلى كەلدى. پادىشاھ كەتكەن كۈندىن تارتىپ ساق-سالامەت قايتىپ كەلگەن كۈنگىچە، ئۇ يا پۇتلىرىنىڭ تىرنىقىنى ئالمىغان يا ساقىلىنى ياسىمىغان ۋە ياكى كىيىملىرىنى يۇمىغانىدى.
\v 25 ئۇ پادىشاھنى قارشى ئالغىلى يېرۇسالېمدىن كەلگەندە، پادىشاھ ئۇنىڭدىن: ئى مەفىبوشەت، نېمىشقا مېنىڭ بىلەن بارمىدىڭ؟ ــ دەپ سورىدى. \f ◼ \fr 19:25 \ft \bd «ئۇ ... يېرۇسالېمدىن كەلگەندە...»\bd* ــ ياكى، «ئۇ ... يېرۇسالېمغا كەلگەندە...».\f*
\m 
\v 26 ئۇ: ئى، غوجام پادىشاھ، قۇللىرى ئاقساق بولغاچقا، ئېشىكىمنى توقۇپ، مىنىپ پادىشاھ بىلەن بىللە باراي، دېدىم. ئەمما خىزمەتكارىم مېنى ئالداپ قويۇپتۇ؛
\v 27 ئۇ يەنە غوجام پادىشاھىڭ ئالدىدا قۇللىرىنىڭ غەيۋىتىنى قىلدى. لېكىن غوجام پادىشاھ خۇدانىڭ بىر پەرىشتىسىدەكتۇر؛ شۇنىڭ ئۈچۈن سىلىگە نېمە لايىق كۆرۈنسە، شۇنى قىلغايلا. \x ◘ \xo 19:27 \xt 2سام. 16‏:3\x*
\v 28 چۈنكى ئاتامنىڭ جەمەتىنىڭ ھەممىسى غوجام پادىشاھنىڭ ئالدىدا ئۆلگەن ئادەملەردەك ئىدى؛ لېكىن سىلى ئۆز قۇللىرىنى ئۆزلىرى بىلەن ھەمداستىخان بولغانلار ئارىسىدا قويدىلا؛ مېنىڭ پادىشاھنىڭ ئالدىدا پەرياد قىلغىلى نېمە ھەققىم بار؟ ــ دېدى. \f ◼ \fr 19:28 \ft \bd «...ئاتامنىڭ جەمەتىنىڭ ھەممىسى غوجام پادىشاھنىڭ ئالدىدا ئۆلگەن ئادەملەردەك ئىدى»\bd* ــ مەنىسى بەلكىم، «بىز ھەممىمىز ئەسلىدە سېنىڭ ئالدىڭدا ئۆلۈمگە مەھكۇم قىلىنىشقا لايىق ئىدۇق».\f*
\m 
\v 29 پادىشاھ ئۇنىڭغا: نېمىشقا ئىشلىرىڭ توغرىسىدا سۆزلەۋېرىسەن؟ مېنىڭ ھۆكۈمۈم، سەن بىلەن زىبا يەرلەرنى بۆلۈشۈۋېلىڭلار، ــ دېدى.
\m 
\v 30 مەفىبوشەت پادىشاھقا: غوجام پادىشاھ ئامان-ېسەن ئۆز ئۆيىگە كەلگەندىن كېيىن، زىبا ھەممىسىنى ئالسىمۇ رازىمەن! ــ دېدى.
\m 
\v 31 گىلېئادلىق بارزىللايمۇ روگېلىمدىن چۈشۈپ پادىشاھنى ئىئوردان دەرياسىدىن ئۆتكۈزۈپ قويۇشقا كېلىپ، پادىشاھ بىلەن بىللە ئىئوردان دەرياسىدىن ئۆتتى.
\v 32 ئەمدى بارزىللاي خېلى ياشانغان بىر ئادەم بولۇپ، سەكسەن ياشقا كىرگەنىدى. پادىشاھ ماھانائىمدا تۇرغان ۋاقىتتا، ئۇنى قامدىغان دەل مۇشۇ ئادەم ئىدى؛ چۈنكى ئۇ خېلى كاتتا بىر كىشى ئىدى. \x ◘ \xo 19:32 \xt 2سام. 17‏:27-29؛ 1پاد. 2‏:7\x*
\v 33 پادىشاھ بارزىللايغا: مېنىڭ بىلەن بارغىن، مەن سەندىن يېرۇسالېمدا ئۆزۈمنىڭكىدە خەۋەر ئالىمەن، دېدى.
\m 
\v 34 لېكىن بارزىللاي پادىشاھقا: مېنىڭ بىرنەچچە كۈنلۈك ئۆمرۈم قالغاندۇ، پادىشاھ بىلەن بىرگە يېرۇسالېمغا بارامدىم؟ \f ◼ \fr 19:34 \ft \bd «مېنىڭ بىرنەچچە كۈنلۈك ئۆمرۈم قالغاندۇ؟»\bd* ــ ئىبرانىي تىلىدا «مېنىڭ ئۆمرۈمدىكى يىللارنىڭ كۈنلىرى قانچىدۇ؟» دېگەن سۆزلەر بىلەن ئىپادىلىنىدۇ.\f*
\v 35 قۇللىرى سەكسەن ياشقا كىردىم. ياخشى-ياماننى يەنە پەرق ئېتەلەيمەنمۇ؟ يەپ-ئىچكىنىمنىڭ تەمىنى تېتالامدىم؟ يىگىت نەغمىچىلەر بىلەن قىز نەغمىچىلەرنىڭ ئاۋازىنى ئاڭلىيالامدىم؟ نېمىشقا قۇللىرى غوجام پادىشاغا يەنە يۈك بولىمەن؟
\v 36 قۇللىرى پەقەت پادىشاھنى ئىئوردان دەرياسىدىن ئۆتكۈزۈپ ئاندىن ئازراق ئۇزىتىپ قوياي دېگەن؛ پادىشاھ بۇنىڭ ئۈچۈن نېمىشقا ماڭا شۇنچە شاپائەت كۆرسىتىدىلا؟
\v 37 قۇللىرىنىڭ ئۆلگەندە ئۆز شەھىرىمدە، ئاتام بىلەن ئانامنىڭ قەبرىسىنىڭ يېنىدا يېتىشىم ئۈچۈن قايتىپ كېتىشىگە ئىجازەت بەرگەيلا. ئەمدى مانا، بۇ يەردە ئۆز قۇللىرى كىمھام بار ئەمەسمۇ؟ ئۇ غوجام پادىشاھ بىلەن ئۆتۈپ بارسۇن، ئۇنىڭغا ئۆزلىرىگە نېمە لايىق كۆرۈنسە شۇنى قىلغايلا، ــ دېدى.
\m 
\v 38 پادىشاھ: كىمھام مېنىڭ بىلەن ئۆتۈپ بارسۇن؛ ساڭا نېمە لايىق كۆرۈنسە ئۇنىڭغا شۇنى قىلاي، شۇنداقلا سەن مەندىن ھەر نېمە سورىساڭ، ساڭا قىلىمەن، ــ دېدى.
\m 
\v 39 ئاندىن خەلقنىڭ ھەممىسى ئىئوردان دەرياسىدىن ئۆتتى، پادىشاھمۇ ئۆتتى. ئاندىن پادىشاھ بارزىللاينى سۆيۈپ ئۇنىڭغا بەخت تىلىدى؛ بارزىللاي ئۆز يۇرتىغا يېنىپ كەتتى.
\m 
\v 40 پادىشاھ گىلگالغا چىقتى، كىمھام ئۇنىڭ بىلەن باردى. يەھۇدادىكى بارلىق ئادەملەر بىلەن ئىسرائىلنىڭ خەلقىنىڭ يېرىمى پادىشاھنى دەريادىن ئۆتكۈزۈپ ئۇزىتىپ قويغانىدى.
\v 41 ئاندىن مانا، ئىسرائىلنىڭ بارلىق ئادەملىرى پادىشاھنىڭ قېشىغا كېلىپ: نېمىشقا قېرىنداشلىرىمىز يەھۇدانىڭ ئادەملىرى ئوغرىلىقچە پادىشاھنى ۋە پادىشاھنىڭ ئائىلە-تاۋابىئاتلىرىنى، شۇنداقلا داۋۇتقا ئەگەشكەن ھەممە ئادەملەرنى ئىئوردان دەرياسىدىن ئۆتكۈزۈشكە مۇيەسسەر بولىدۇ؟ ــ دېدى.
\m 
\v 42 يەھۇدانىڭ ھەممە ئادەملىرى ئىسرائىلنىڭ ئادەملىرىگە جاۋاپ بېرىپ: چۈنكى پادىشاھ بىلەن بىزنىڭ تۇغقانچىلىقىمىز بار، نېمىشقا بۇ ئىش ئۈچۈن بىزدىن خاپا بولىسىلەر؟ بىز پادىشاھنىڭكىدىن بىر نېمىنى يىدۇقمۇ، ياكى ئۇ بىزگە بىر ئىنئام بەردىمۇ؟ ــ دېدى.
\m 
\v 43 ئىسرائىلنىڭ ئادەملىرى يەھۇدانىڭ ئادەملىرىگە جاۋاب بېرىپ: قەبىلە بويىچە ئالغاندا، پادىشاھنىڭ \add ئون ئىككى\add* ئۈلۈشتىن ئونى بىزگە تەۋەدۇر، سىلەرگە نىسبەتەن بىزنىڭ داۋۇت بىلەن تېخىمۇ چوڭراق بۇرادەرچىلىكىمىز بار. نېمىشقا بىزنى كۆزگە ئىلمايسىلەر؟ پادىشاھىمىزنى ياندۇرۇپ ئېلىپ كېلىشكە ئاۋۋال تەشەببۇس قىلغانلار بىز ئەمەسمىدۇق؟ ــ دېدى. ئەمما يەھۇدانىڭ ئادەملىرىنىڭ سۆزلىرى ئىسرائىلنىڭ ئادەملىرىنىڭ سۆزلىرىدىن تېخىمۇ قاتتىق ئىدى. \f ◼ \fr 19:43 \ft \bd «پادىشاھنىڭ ئون ئىككى ئۈلۈشتىن ئونى بىزگە تەۋەدۇر»\bd* ــ دېگەن ئىبارە بەلكىم ئىسرائىلنىڭ ئون قەبىلە ئىكەنلىكىنى، يەھۇدانىڭ بىنيامىننى قوشقاندا پەقەت ئىككى قەبىلە ئىكەنلىكىنى كۆرسىتىدۇ.\f*
\b
\b
\c 20
\s1 شېبانىڭ كۆتۈرگەن ئىسيانى
\m 
\v 1 ۋە شۇنداق بولدىكى، شۇ يەردە بىنيامىن قەبىلىسىدىن، بىكرىنىڭ ئوغلى شېبا ئىسىملىك بىر ئىپلاس بار ئىدى. ئۇ كاناي چېلىپ: ــ
\m بىزنىڭ داۋۇتتا ھېچقانداق ئورتاق نېسىۋىمىز يوق؛ يەسسەنىڭ ئوغلىدىن ھېچقانداق مىراسىمىز يوق! ئى ئىسرائىل، ھەربىرلىرىڭلار ئۆز ئۆيۈڭلارغا يېنىپ كېتىڭلار، ــ دېدى. \f ◼ \fr 20:1 \ft \bd «بىكرىنىڭ ئوغلى شېبا ئىسىملىك بىر ئىپلاس»\bd* ــ «بىر ئىپلاس» ئىبرانىي تىلىدا «شەيتان (بېلىئال)نىڭ بىر ئوغلى». \bd «ھەربىرلىرىڭلار ئۆز ئۆيۈڭلارغا يېنىپ كېتىڭلار»\bd* ــ ئىبرانىي تىلىدا: «ھەربىرلىرىڭلار ئۆز چېدىرىغا يېنىپ كېتىڭلار».\f*
\m 
\v 2 شۇنىڭ بىلەن ئىسرائىلنىڭ ھەممە ئادەملىرى داۋۇتتىن يېنىپ بىكرىنىڭ ئوغلى شېباغا ئەگەشتى. لېكىن يەھۇدانىڭ ئادەملىرى ئىئوردان دەرياسىدىن تارتىپ يېرۇسالېمغىچە ئۆز پادىشاھىغا چىڭ باغلىنىپ، ئۇنىڭغا ئەگەشتى.
\v 3 داۋۇت يېرۇسالېمغا كېلىپ ئوردىسىغا كىردى. پادىشاھ ئوردىغا قاراشقا قويۇپ كەتكەن ئاشۇ ئون كېنىزەكنى بىر ئۆيگە قاماپ قويدى. ئۇ ئۇلارنى باقتى، لېكىن ئۇلارغا يېقىنچىلىق قىلمىدى. شۇنىڭ بىلەن ئۇلار ئۇ يەردە تۇل ئاياللاردەك ئۆلگۈچە قامالغان پېتى تۇردى.
\m 
\v 4 ئاندىن پادىشاھ ئاماساغا: ئۈچ كۈن ئىچىدە يەھۇدانىڭ ئادەملىرىنى چاقىرىپ، يىغىپ كەلگىن؛ ئۆزۈڭمۇ بۇ يەردە ھازىر بولغىن، دېدى.
\m 
\v 5 شۇنىڭ بىلەن ئاماسا يەھۇدانىڭ ئادەملىرىنى چاقىرىپ يىغقىلى باردى. لېكىن ئۇنىڭ ئۇنداق قىلىشى پادىشاھ بېكىتكەن ۋاقىتتىن كېيىن قالدى،
\v 6 ئۇ ۋاقىتتا داۋۇت ئابىشايغا: ئەمدى بىكرىنىڭ ئوغلى شېبا بىزگە چۈشۈرىدىغان ئاپەت ئابشالومنىڭ چۈشۈرگىنىدىن تېخىمۇ يامان بولىدۇ. ئەمدى غوجاڭنىڭ خىزمەتكارلىرىنى ئېلىپ ئۇلارنى قوغلاپ بارغىن. بولمىسا، ئۇ مۇستەھكەم شەھەرلەرنى ئىگىلىۋېلىپ، بىزدىن ئۆزىنى قاچۇرۇشى مۇمكىن، ــ دېدى.
\m 
\v 7 شۇنىڭ بىلەن يوئابنىڭ ئادەملىرى ۋە كەرەتىيلەر، پەلەتىيلەر، شۇنداقلا بارلىق پالۋانلار ئۇنىڭغا ئەگىشىپ چىقتى؛ ئۇلار يېرۇسالېمدىن چىقىپ، بىكرىنىڭ ئوغلى شېبانى قوغلىغىلى باردى.
\v 8 ئۇلار گىبېئوندىكى قورام تاشقا يېقىن كەلگەندە ئاماسا ئۇلارنىڭ ئالدىغا چىقتى. يوئاب ئۈستىبېشىغا جەڭ لىباسىنى كىيىپ، بېلىگە غىلاپلىق بىر قىلىچىنى ئاسقان كەمەر باغلىغانىدى. ئۇ ئالدىغا مېڭىۋىدى، قىلىچ غىلاپتىن چۈشۈپ كەتتى.
\m 
\v 9 يوئاب ئاماسادىن: تىنچلىقمۇ، ئىنىم؟ ــ دەپ سورىدى. يوئاب ئاماسانى سۆيمەكچى بولغاندەك ئوڭ قولى بىلەن ئۇنى ساقىلىدىن تۇتتى.
\v 10 ئاماسا يوئابنىڭ يەنە بىر قولىدا قىلىچ بارلىغىغا دىققەت قىلمىدى. يوئاب ئۇنىڭ قورسىقىغا شۇنداق تىقتىكى، ئۈچەيلىرى چىقىپ يەرگە چۈشتى. ئىككىنچى قېتىم سېلىشنىڭ ھاجىتى قالمىغانىدى؛ چۈنكى ئۇ ئۆلدى. ئاندىن يوئاب بىلەن ئىنىسى ئابىشاي بىكرىنىڭ ئوغلى شېبانى قوغلىغىلى كەتتى. \x ◘ \xo 20:10 \xt 1پاد. 2‏:5\x*
\m 
\v 11 يوئابنىڭ غۇلاملىرىدىن بىرى ئاماسانىڭ يېنىدا تۇرۇپ: كىم يوئاب تەرەپتە تۇرۇپ داۋۇتنى قوللىسا، يوئابقا ئەگەشسۇن، دەيتتى.
\m 
\v 12 ئەمما ئاماسا ئۆز قېنىدا يۇمىلىنىپ، يولنىڭ ئوتتۇرسىدا ياتاتتى؛ ئۇنى كۆرگەن خەلقنىڭ ھەربىرى توختايتتى. ئۇ كىشى ھەممە خەلقنىڭ توختىغىنىنى كۆرۈپ، ئاماسانىڭ جەسىتىنى يولدىن ئېتىزلىققا تارتىپ قويدى ھەم بىر كىيىمنى ئۇنىڭ ئۈستىگە تاشلىدى.
\v 13 جەسەت يولدىن يۆتكەلگەندىن كېيىن خەلقنىڭ ھەممىسى بىكرىنىڭ ئوغلى شېبانى قوغلىغىلى يوئابقا ئەگەشتى.
\m 
\v 14 شېبا بولسا بەيت-مائاكاھدىكى ئابەلگىچە ۋە بېرىيلىكلەرنىڭ يۇرتىنىڭ ھەممە يەرلىرىنى كېزىپ ئىسرائىلنىڭ ھەممە قەبىلىلىرىدىن ئۆتتى. \add بېرىيلىكلەرمۇ\add* جەم بولۇپ ئۇنىڭغا ئەگىشىپ باردى. \f ◼ \fr 20:14 \ft \bd «بېرىيلىكلەرمۇ جەم بولۇپ...»\bd* ــ ياكى «ئۇ يەردىكى كىشىلەرمۇ جەم بولۇپ...».\f*
\v 15 شۇنىڭ بىلەن يوئاب ۋە ئادەملىرى كېلىپ، بەيت-مائاكاھدىكى ئابەلدە ئۇنى مۇھاسىرىگە ئالدى. ئۇلار شەھەرنىڭ چۆرىسىدىكى سېپىلنىڭ ئۇدۇلىدا بىر ئىستىھكام سالدى؛ يوئابقا ئەگەشكەنلەرنىڭ ھەممىسى كېلىپ، سېپىلنى ئۆرۈشكە بازغانلاۋاتقاندا،
\v 16 دانىشمەن بىر خوتۇن شەھەردىن توۋلاپ: قۇلاق سېلىڭلار! قۇلاق سېلىڭلار! يوئابنى بۇ يەرگە چاقىرىپ كېلىڭلار، مېنىڭ ئۇنىڭ بىلەن سۆزلەشمەكچى بولغىنىمنى ئۇنىڭغا ئېيتىڭلار، ــ دېدى.
\m 
\v 17 ئۇ يېقىن كەلگەندە خوتۇن ئۇنىڭدىن: سىلى يوئابمۇ؟ ــ دەپ سورىدى. ئۇ: شۇنداق، مەن شۇ، دېدى. خوتۇن ئۇنىڭغا: دېدەكلىرىنىڭ سۆزىنى ئاڭلىغايلا، دېدى. ئۇ: ئاڭلاۋاتىمەن، دېدى.
\m 
\v 18 خوتۇن: كونىلاردا ئابەلدە مەسلىھەت تاپقىن، ئاندىن مەسىلىلەر ھەل قىلىنىدۇ، دېگەن گەپ بار؛
\v 19 ئىسرائىلنىڭ تىنچ ۋە مۆمىن بەندىلىرىدىن بىرىمەن؛ سىلى ھازىر ئىسرائىلدىكى ئانا كەبى چوڭ بىر شەھەرنى خاراپ قىلىۋاتىدىلا؛ نېمىشقا پەرۋەردىگارنىڭ مىراسىنى يوقاتماقچى بولىلا؟ ــ دېدى. \f ◼ \fr 20:19 \ft \bd «سىلى ھازىر ئىسرائىلدىكى ئانا كەبى چوڭ بىر شەھەرنى خاراپ قىلىۋاتىدىلا»\bd* ــ «ئانا كەبى چوڭ بىر شەھەر» دېگەننىڭ مەنىسى بەلكىم، باشقا شەھەرلەر ئابەلگە بېقىنىدۇ. باشقا بىرخىل تەرجىمىسى «بىر شەھەر ۋە ئىسرائىلدىكى بىر ئانا بولغۇچىنى خاراب قىلىۋاتىدىلا».\f*
\m 
\v 20 يوئاب جاۋاپ بېرىپ: ئۇنداق ئىش مەندىن نېرى بولسۇن! مەندىن نېرى بولسۇن! مېنىڭ ھېچنېمىنى يۇتۇۋالغۇم ياكى يوقاتقۇم يوقتۇر؛
\v 21 ئىش ئۇنداق ئەمەس، بەلكى ئەفرائىمدىكى ئېدىرلىقتىن بىكرىنىڭ ئوغلى شېبا دېگەن بىر ئادەم داۋۇت پادىشاھقا قارشى قولىنى كۆتۈرۈپتۇ. پەقەت ئۇنى تاپشۇرساڭلار، ئاندىن شەھەردىن كېتىمەن، دېدى. خوتۇن يوئابقا: مانا ئۇنىڭ بېشى سېپىلدىن سىلىگە تاشلىنىدۇ، ــ دېدى.
\m 
\v 22 ئاندىن خوتۇن ئۆز دانالىقى بىلەن ھەممە خەلققە مەسلىھەت بەردى؛ ئۇلار بىكرىنىڭ ئوغلى شېبانىڭ بېشىنى كېسىپ، يوئابقا تاشلاپ بەردى. يوئاب كاناي چالدى، ئۇنىڭ ئادەملىرى شۇنى ئاڭلاپ، شەھەردىن كېتىپ، ھەربىرى ئۆز ئۆيىگە قايتتى. يوئاب يېرۇسالېمغا پادىشاھنىڭ قېشىغا باردى. \f ◼ \fr 20:22 \ft \bd «شۇنى ئاڭلاپ... ھەربىرى ئۆز ئۆيىگە قايتتى»\bd* ــ ئىبرانىي تىلىدا: «شۇنى ئاڭلاپ... ھەربىرى ئۆز چېدىرىغا قايتتى».\f*
\m 
\v 23 ئەمدى يوئاب پۈتكۈل ئىسرائىلنىڭ قوشۇنىنىڭ سەردارى ئىدى؛ يەھويادانىڭ ئوغلى بىنايا بولسا كەرەتىيلەر بىلەن پەلەتىيلەرنىڭ ئۈستىگە سەردار بولدى.
\v 24 ئادونىرام باج-ئالۋانغا باش بولدى، ئاھىلۇدنىڭ ئوغلى يەھوشافات بولسا دىۋان بېگى بولدى؛
\v 25 شېۋا كاتىپ، زادوك بىلەن ئابىياتار كاھىن ئىدى؛
\v 26 يائىرلىق ئىرا بولسا داۋۇتقا خاس كاھىن بولدى. \f ◼ \fr 20:26 \ft \bd «يائىرلىق ئىرا بولسا داۋۇتقا خاس كاھىن بولدى»\bd* ــ ياكى «يائىرلىق ئىرا بولسا داۋۇتنىڭ باش ۋەزىرى بولدى».\f*
\b
\b
\c 21
\s1 گىبېئونلۇقلار قىساس سورايدۇ
\m 
\v 1 ئەمما داۋۇتنىڭ كۈنلىرىدە ئۇدا ئۈچ يىل ئاچارچىلىق بولدى. داۋۇت ئۇنىڭ توغرۇلۇق پەرۋەردىگاردىن سورىدى. پەرۋەردىگار ئۇنىڭغا: ئاچارچىلىق سائۇل ۋە ئۇنىڭ قانخور جەمەتىدىكىلەر سەۋەبىدىن، يەنى ئۇنىڭ گىبېئونلۇقلارنى قىرغىن قىلغىنىدىن بولدى، دېدى. \f ◼ \fr 21:1 \ft \bd «ئەمما داۋۇتنىڭ كۈنلىرىدە ئۇدا ئۈچ يىل ئاچارچىلىق بولدى...»\bd* ــ 21-24-بابلار بەلكىم تارىخقا قوشۇلغان قوشۇمچە سۆز بولۇپ، «سامۇئىل (2)»دىكى يىللار ئارىلىقىدا يۈز بەرگەن باشقا مۇھىم ئىشلارنى تەسۋىرلەيدۇ.\f*
\m 
\v 2 پادىشاھ گىبېئونلۇقلارنى چاقىرىپ، ئۇلار بىلەن سۆزلەشتى (گىبېئونلۇقلار ئىسرائىللاردىن ئەمەس ئىدى، بەلكى ئامورىيلارنىڭ بىر قالدىسى ئىدى. ئىسرائىل ئەسلىدە ئۇلار بىلەن ئەھدە قىلىپ قەسەم ئىچكەنىدى؛ لېكىن سائۇل ئىسرائىل ۋە يەھۇدالارغا بولغان قىزغىنلىقى بىلەن ئۇلارنى ئۆلتۈرۈشكە ئىنتىلگەنىدى). \f ◼ \fr 21:2 \ft \bd «ئىسرائىل ئەسلىدە ئۇلار بىلەن ئەھدە قىلىپ قەسەم ئىچكەنىدى»\bd* ــ بۇ ئىش «يەشۇئا» 9-بابتا خاتىرىلەنگەن.\f*  \x ◘ \xo 21:2 \xt يە. 9‏:19\x*
\m 
\v 3 داۋۇت گىبېئونلۇقلارغا: سىلەرگە نېمە قىلىپ بېرەي؟ مەن قانداق قىلىپ بۇ گۇناھنى كەفارەت قىلىپ ياپسام، ئاندىن سىلەر پەرۋەردىگارنىڭ مىراسىغا بەخت-بەرىكەت تىلىيەلەيسىلەر؟ ــ دېدى. \f ◼ \fr 21:3 \ft \bd «... ئاندىن سىلەر پەرۋەردىگارنىڭ مىراسىغا بەخت-بەرىكەت تىلىيەلەيسىلەر»\bd* ــ دېمەك، ئۇلارنىڭ ئىسرائىلغا بولغان بۇ ئادىۋىتى تۈگەيدۇ.\f*
\m 
\v 4 گىبېئونلۇقلار ئۇنىڭغا: بىزنىڭ سائۇل ۋە ئۇنىڭ جەمەتىدىكىلەردىن ئالتۇن-كۈمۈش سوراش ھەققىمىز يوق، ۋە بىزنىڭ سەۋەبىمىزدىن ئىسرائىلدىن بىر ئادەمنىمۇ ئۆلۈمگە مەھكۇم قىلدۇرۇش ھەققىمىز يوق، دېدى. داۋۇت: سىلەر نېمە دېسەڭلار، مەن شۇنداق قىلاي، دېدى.
\m 
\v 5 ئۇلار پادىشاھقا: بۇرۇن بىزنى يوقاتماقچى بولغان، بىزنى ئىسرائىلنىڭ بارلىق پاسىللىرى ئىچىدە تۇرغۇدەك يېرى قالمىسۇن دەپ، بىزنى ھالاك قىلىشقا قەستلىگەن ھېلىقى كىشىنىڭ،
\v 6 ھازىر ئۇنىڭ ئەركەك نەسلىدىن يەتتىسى بىزگە تاپشۇرۇپ بېرىلسۇن، بىز پەرۋەردىگارنىڭ تاللىغىنى بولغان سائۇلنىڭ گىبېئاھ شەھىرىدە، پەرۋەردىگارنىڭ ئالدىدا ئۇلارنى ئۆلتۈرۈپ، ئېسىپ قويايلى، دېدى. پادىشاھ: ــ مەن سىلەرگە چوقۇم تاپشۇرۇپ بېرىمەن، دېدى.
\m 
\v 7 لېكىن داۋۇت بىلەن سائۇلنىڭ ئوغلى يوناتاننىڭ پەرۋەردىگار ئالدىدا ئىچىشكەن قەسىمى ۋەجىدىن پادىشاھ سائۇلنىڭ نەۋرىسى، يوناتاننىڭ ئوغلى مەفىبوشەتنى ئايىدى. \x ◘ \xo 21:7 \xt 1سام. 18‏:3؛ 20‏:15، 42؛ 23‏:18\x*
\m 
\v 8 پادىشاھ ئاياھنىڭ قىزى رىزپاھنىڭ سائۇلغا تۇغۇپ بەرگەن ئىككى ئوغلى ئارمونى ۋە مەفىبوشەتنى ۋە سائۇلنىڭ قىزى مىقال مەھولاتلىق بارزىللاينىڭ ئوغلى ئادرىئەل ئۈچۈن بېقىۋالغان بەش ئوغۇلنى تۇتۇپ، \f ◼ \fr 21:8 \ft \bd «سائۇلنىڭ قىزى مىقال مەھولاتلىق بارزىللاينىڭ ئوغلى ئادرىئەل ئۈچۈن بېقىۋالغان بەش ئوغۇل...»\bd* ــ مىقال بەلكىم ئاچىسى مەرابنىڭ بۇ بەش ئوغلىنى بېقىۋالغان (23:6نى، «1سام.» 19:18نى كۆرۈڭ). بەزى كونا كۆچۈرمىلەردە «مەرابنىڭ مەھولاتلىق بارزىللاينىڭ ئوغلى ئادرىئەل ئۈچۈن تۇغۇپ بەرگەن بەش ئوغلىنى» دېيىلىدۇ.\f*
\v 9 گىبېئونلۇقلارنىڭ قولىغا تاپشۇردى. بۇلار ئۇلارنى دۆڭدە پەرۋەردىگارنىڭ ئالدىدا ئېسىپ قويدى. بۇ يەتتەيلەن بىر كۈندە ئۆلتۈرۈلدى؛ ئۇلار ئۆلتۈرۈلگەندە ئارپا ئورمىسى ئالدىدىكى كۈنلەر ئىدى.
\m 
\v 10 ئاندىن ئاياھنىڭ قىزى رىزپاھ بۆز رەختنى ئېلىپ، قورام ئۈستىگە يېيىپ سالدى. ئۇ ئورما باشلانغاندىن تارتىپ ئاسماندىن يامغۇر چۈشكەن ۋاقىتقىچە، ئۇ يەردە ئولتۇرۇپ كۈندۈزى قۇشلارنىڭ جەسەتلەرنىڭ ئۈستىگە قونۇشىغا، كېچىسى يىرتقۇچلارنىڭ ئۇلارنى دەسسەپ چەيلىشىگە يول قويمىدى.
\m 
\v 11 بىرسى سائۇلنىڭ كېنىزىكى، ئاياھنىڭ قىزى رىزپاھنىڭ قىلغانلىرىنى داۋۇتقا ئېيتتى.
\m 
\v 12 شۇنىڭ بىلەن داۋۇت يابەش-گىلېئادتىكىلەرنىڭ قېشىغا بېرىپ، ئۇ يەردىن سائۇلنىڭ ۋە ئۇنىڭ ئوغلى يوناتاننىڭ سۆڭەكلىرىنى ئېلىپ كەلدى (فىلىستىيلەر گىلبوئادا سائۇلنى ئۆلتۈرگەن كۈنىدە ئۇلارنىڭ جەسەتلىرىنى بەيت-شاندىكى مەيداندا ئېسىپ قويغانىدى؛ يابەش-گىلېئادتىكىلەر ئەسلىدە بۇلارنى شۇ يەردىن ئوغرىلىقچە ئېلىپ كەتكەنىدى). \x ◘ \xo 21:12 \xt 1سام. 31‏:10-13\x*
\v 13 داۋۇت سائۇل بىلەن ئۇنىڭ ئوغلى يوناتاننىڭ سۆڭەكلىرىنى شۇ يەردىن ئېلىپ كەلدى؛ ئۇلار ئېسىپ ئۆلتۈرۈلگەن يەتتەيلەننىڭ سۆڭەكلىرىنىمۇ يىغىپ قويدى،
\v 14 ئاندىن شۇلارنى سائۇل بىلەن ئوغلى يوناتاننىڭ سۆڭەكلىرى بىلەن بىنيامىن زېمىنىدىكى زېلادا، ئاتىسى كىشنىڭ قەبرىسىدە دەپنە قىلدى. ئۇلار پادىشاھ ئەمر قىلغاندەك قىلدى. ئاندىن خۇدا \add خەلقنىڭ\add* زېمىن توغرۇلۇق دۇئالىرىنى ئىجابەت قىلدى. \f ◼ \fr 21:14 \ft \bd «ئاندىن خۇدا خەلقنىڭ زېمىن توغرۇلۇق دۇئالىرىنى ئىجابەت قىلدى»\bd* ــ «زېمىن توغرۇلۇق دۇئالىرى» ــ دېمەك، قەھەتچىلىكنىڭ تۈگىتىلىشى ئۈچۈن.\f*
\b
\s1 فىلىستىيلەر بىلەن قايتا جەڭ قىلىش
\r 1تار. 20‏:4-8
\m 
\v 15 فىلىستىيلەر بىلەن ئىسرائىلنىڭ ئوتتۇرسىدا يەنە جەڭ بولدى، داۋۇت ئۆز ئادەملىرى بىلەن چۈشۈپ، فىلىستىيلەر بىلەن سوقۇشتى. ئەمما داۋۇت تولىمۇ چارچاپ كەتتى؛
\v 16 رافاھنىڭ ئەۋلادلىرىدىن بولغان ئىشبى-بىنوب داۋۇتنى ئۆلتۈرمەكچى ئىدى؛ ئۇنىڭ مىس نەيزىسىنىڭ ئېغىرلىقى ئۈچ يۈز شەكەل ئىدى؛ ئۇنىڭغا يەنە يېڭى ساۋۇت باغلاقلىق ئىدى. \f ◼ \fr 21:16 \ft \bd «رافاھنىڭ ئەۋلادلىرىدىن بولغان ئىشبى-بىنوب»\bd* ــ «رافاھنىڭ ئەۋلادلىرى» ھەممىسى دېگۈدەك يوغان ئادەملەر ئىدى (18، 20، 22نى كۆرۈڭ). \bd «ئۇنىڭ مىس نەيزىسىنىڭ ئېغىرلىقى»\bd* ــ ياكى «ئۇنىڭ نەيزىنىڭ مىس بېشىنىڭ ئېغىرلىقى». \bd «300 شەكەل»\bd* ــ بەلكىم 3.5 كىلوگرام ئىدى. \bd «ئۇنىڭغا يەنە يېڭى ساۋۇت باغلاقلىق ئىدى»\bd* ــ ياكى، «ئۇنىڭغا يەنە يېڭى بىر قورالى بار ئىدى».\f*
\v 17 لېكىن زەرۇئىيانىڭ ئوغلى ئابىشاي ئۇنىڭغا ياردەمگە كېلىپ فىلىستىينى قىلىچلاپ ئۆلتۈردى. شۇ كۈنى داۋۇتنىڭ ئادەملىرى ئۇنىڭغا قەسەم قىلىپ: سەن يەنە بىز بىلەن جەڭگە چىقمىغىن! بولمىسا ئىسرائىلنىڭ چىرىغى ئۆچۈپ قالىدۇ، ــ دېدى. \x ◘ \xo 21:17 \xt پەند. 9:13\x*
\m 
\v 18 بۇ ئىشتىن كېيىن شۇنداق بولدىكى، گوبتا فىلىستىيلەر بىلەن يەنە جەڭ بولدى؛ ئۇ ۋاقىتتا ھۇشاتلىق سىببىكاي رافاھنىڭ ئەۋلادىدىن بولغان سافنى ئۆلتۈردى. \x ◘ \xo 21:18 \xt 1تار. 20‏:4\x*
\m 
\v 19 گوبتا يەنە بىر قېتىم فىلىستىيلەر بىلەن جەڭ بولدى؛ ئۇ چاغدا بەيت-لەھەملىك يائىرنىڭ ئوغلى ئەل-ھانان گاتلىق گولىياتنىڭ ئىنىسىنى ئۆلتۈردى. ئۇنىڭ نەيزىسىنىڭ سېپى باپكارنىڭ خادىسىدەك ئىدى. \f ◼ \fr 21:19 \ft \bd «بەيت-لەھەملىك يائىر»\bd* ــ بەزى كونا كۆچۈرۈلمىلەردە «يائىر» «يائىر-ئورىگىم» دەپ ئاتىلىدۇ. \bd «گولىياتنىڭ ئىنىسى»\bd* ــ بەزى كونا كۆچۈرمىلەردە پەقەت «گولىيات» دېيىلىدۇ.\f*
\m 
\v 20 يەنە بىر جەڭ گاتتا بولدى؛ ئۇ يەردە ئېگىز بويلۇق بىر ئادەم بار ئىدى، قوللىرىنىڭ ئالتىدىن بارماقلىرى، پۇتلىرىنىڭ ئالتىدىن بارماقلىرى بولۇپ جەمئىي يىگىرمە تۆت بارمىقى بار ئىدى. ئۇ ھەم رافاھنىڭ ئەۋلادى ئىدى.
\v 21 ئۇ ئىسرائىللارنىڭ ئالدىدا تۇرۇپ ئۇلارنى مازاق قىلدى؛ لېكىن داۋۇتنىڭ ئاكىسى شىمىيانىڭ ئوغلى يوناتان ئۇنى ئۆلتۈردى.
\m 
\v 22 بۇ تۆت كىشى گاتلىق رافاھنىڭ ئەۋلادى بولۇپ، ھەممىسى داۋۇتنىڭ قولىدا ياكى ئۇنىڭ خىزمەتكارلىرىنىڭ قولىدا ئۆلتۈرۈلدى.
\b
\b
\c 22
\s1 داۋۇتنىڭ مەدھىيە كۈيى
\r زەب. 18
\m 
\v 1 پەرۋەردىگار ئۇنى بارلىق دۈشمەنلىرىدىن ھەم سائۇل پادىشاھنىڭ قولىدىن قۇتقۇزغان كۈنى، ئۇ پەرۋەردىگارغا بۇ كۈينى ئېيتتى: ــ \f ◼ \fr 22:1 \ft \bd «...ئۇ پەرۋەردىگارغا بۇ كۈينى ئېيتتى»\bd* ــ زەبۇر، 18-كۈي ۋە ئۇنىڭ ئىزاھاتلىرى بىلەن سېلىشتۇرۇڭ.\f*
\b
\m 
\v 2 ئۇ مۇنداق دېدى: ــ پەرۋەردىگار مېنىڭ خادا تېغىم، مېنىڭ قورغىنىم، مېنىڭ نىجاتكارىمدۇر!
\m 
\v 3 خۇدا مېنىڭ قورام تېشىمدۇر، مەن ئۇنىڭغا تايىنىمەن ــ
\m ئۇ مېنىڭ قالقىنىم، مېنىڭ قۇتقۇزغۇچى مۈڭگۈزۈم،
\m مېنىڭ ئېگىز مۇنارىم ۋە باشپاناھىم، مېنىڭ قۇتقۇزغۇچىمدۇر؛
\m سەن مېنى زوراۋانلاردىن قۇتقۇزىسەن! \f ◼ \fr 22:3 \ft \bd «...مېنىڭ قۇتقۇزغۇچى مۈڭگۈزۈم»\bd* ــ ئىبرانىي تىلىدا «....نىجاتىمنىڭ مۈڭگۈزى». \bd «سەن مېنى زوراۋانلاردىن قۇتقۇزىسەن!»\bd* ــ ئىبرانىي تىلىدا «سەن مېنى زوراۋانلىقتىن قۇتقۇزىسەن».\f*  \x ◘ \xo 22:3 \xt ئىبر. 2‏:13\x*
\m 
\v 4 مەدھىيىلەرگە لايىق پەرۋەردىگارغا مەن نىدا قىلىمەن،
\m شۇنداق قىلىپ، مەن دۈشمەنلىرىمدىن قۇتقۇزۇلىمەن؛
\m 
\v 5 چۈنكى ئۆلۈمنىڭ ئاسارەتلىرى مېنى قورشىۋالدى،
\m ئىخلاسسىزلارنىڭ يامراپ كېتىشى مېنى قورقۇتۇۋەتتى؛ \f ◼ \fr 22:5 \ft \bd «ئىخلاسسىزلارنىڭ يامراپ كېتىشى مېنى قورقۇتۇۋەتتى»\bd* ــ ئىبرانىي تىلىدا «ئىخلاسسىزلارنىڭ قىيان-تاشقىنلىرى مېنى قورقۇتۇۋەتتى».\f*
\m 
\v 6 تەھتىسارانىڭ تانىلىرى مېنى چىرمىۋالدى،
\m ئۆلۈم سىرتماقلىرى ئالدىمغا كەلدى.
\m 
\v 7 قىينالغىنىمدا مەن پەرۋەردىگارغا نىدا قىلدىم،
\m خۇدايىمغا پەرياد كۆتۈردۈم؛
\m ئۇ ئىبادەتخانىسىدىن ئاۋازىمنى ئاڭلىدى،
\m مېنىڭ پەريادىم ئۇنىڭ قۇلىقىغا كىردى.
\m 
\v 8 ئاندىن يەر-زېمىن تەۋرەپ سىلكىنىپ كەتتى،
\m ئاسمانلارنىڭ ئۇللىرى دەھشەتلىك تەۋرەندى، سىلكىنىپ كەتتى؛
\m چۈنكى ئۇ غەزەپلەندى.
\m 
\v 9 ئۇنىڭ دىمىغىدىن ئىس ئۆرلەپ تۇراتتى،
\m ئاغزىدىن چىققان ئوت ھەممىسىنى يۇتۇۋەتتى؛
\m ئۇنىڭدىن كۆمۈر چوغلىرى چىقتى؛
\m 
\v 10 ئۇ ئاسمانلارنى ئېڭىشتۈرۈپ ئېگىپ چۈشتى،
\m پۇتى ئاستىدا تۇم قاراڭغۇلۇق ئىدى.
\m 
\v 11 ئۇ بىر كېرۇب ئۈستىدە پەرۋاز قىلدى،
\m ئۇ شامالنىڭ قاناتلىرىدا كۆرۈندى.
\m 
\v 12 ئۇ قاراڭغۇلۇقنى، شۇنداقلا يىغىلغان سۇلارنى،
\m ئاسمانلارنىڭ قويۇق بۇلۇتلىرىنى،
\m ئۆز ئەتراپىدا چېدىرى قىلدى.
\m 
\v 13 ئۇنىڭ ئالدىدا تۇرغان يورۇقلۇقتىن،
\m ئوتلۇق چوغلار چىقىپ ئۆتتى؛
\m 
\v 14 پەرۋەردىگار ئاسماندا گۈلدۈرلىدى؛
\m ھەممىدىن ئالىي بولغۇچى ئاۋازىنى ياڭراتتى؛
\m 
\v 15 بەرھەق، ئۇ ئوقلىرىنى ئېتىپ، \add دۈشمەنلىرىمنى\add* تارقىتىۋەتتى؛
\m چاقماقلارنى چاقتۇرۇپ، ئۇلارنى قىيقاس-سۈرەنگە سالدى؛ \f ◼ \fr 22:15 \ft \bd «بەرھەق، ئۇ ... دۈشمەنلىرىمنى تارقىتىۋەتتى»\bd* ــ ئىبرانىي تىلىدا «بەرھەق، ئۇ ... ئۇلارنى تارقىتىۋەتتى». 18-ئايەتنى كۆرۈڭ.\f*
\m 
\v 16 شۇنىڭ بىلەن دېڭىزنىڭ تەكتى كۆرۈنۈپ قالدى،
\m ئالەمنىڭ ئۇللىرى ئاشكارىلاندى،
\m پەرۋەردىگارنىڭ تەنبىھى بىلەن،
\m دىمىغىنىڭ نەپىسىنىڭ زەربىسى بىلەن.
\m 
\v 17 ئۇ يۇقىرىدىن قولىنى ئۇزىتىپ، مېنى تۇتتى؛
\m مېنى ئۇلۇغ سۇلاردىن تارتىپ ئالدى.
\m 
\v 18 ئۇ مېنى كۈچلۈك دۈشمىنىمدىن،
\m ماڭا ئۆچمەنلەردىن قۇتقۇزدى؛
\m چۈنكى ئۇلار مەندىن كۈچلۈك ئىدى.
\m 
\v 19 كۈلپەتكە ئۇچرىغان كۈنۈمدە، ئۇلار ماڭا قارشى ھۇجۇمغا ئۆتتى؛
\m بىراق پەرۋەردىگار مېنىڭ تايانچىم ئىدى.
\m 
\v 20 ئۇ مېنى كەڭرى-ئازادە بىر جايغا ئېلىپ چىقاردى؛
\m ئۇ مېنى قۇتقۇزدى، چۈنكى ئۇ مەندىن خۇرسەن بولدى.
\m 
\v 21 پەرۋەردىگار ھەققانىيلىقىمغا قاراپ ماڭا ئىلتىپات كۆرسەتتى؛
\m قولۇمنىڭ ھالاللىقىنى ئۇ ماڭا قايتۇردى؛
\m 
\v 22 چۈنكى پەرۋەردىگارنىڭ يوللىرىنى تۇتۇپ كەلدىم؛
\m رەزىللىك قىلىپ خۇدايىمدىن ئايرىلىپ كەتمىدىم؛
\m 
\v 23 چۈنكى ئۇنىڭ بارلىق ھۆكۈملىرى ئالدىمدىدۇر؛
\m مەن ئۇنىڭ بەلگىلىمىلىرىدىن چەتنەپ كەتمىدىم؛
\m 
\v 24 مەن ئۇنىڭ بىلەن غۇبارسىز يۈردۇم،
\m ئۆزۈمنى گۇناھتىن نېرى قىلدىم.
\m 
\v 25 ۋە پەرۋەردىگار ھەققانىيلىقىمغا قاراپ،
\m كۆز ئالدىدا بولغان ھالاللىقىم بويىچە قىلغانلىرىمنى قايتۇردى.
\m 
\v 26 ۋاپادار-مېھرىبانلارغا ئۆزۈڭنى ۋاپادار-مېھرىبان كۆرسىتىسەن؛
\m غۇبارسىزلارغا ئۆزۈڭنى غۇبارسىز كۆرسىتىسەن؛
\m 
\v 27 ساپ دىللىقلارغا ئۆزۈڭنى ساپ دىللىق كۆرسىتىسەن؛
\m تەتۈرلەرگە ئۆزۈڭنى تەتۈر كۆرسىتىسەن؛
\m 
\v 28 چۈنكى سەن ئاجىز مۆمىن خەلقنى قۇتقۇزىسەن؛
\m بىراق كۆزلىرىڭنى تەكەببۇر ئۈستىگە تىكىپ،
\m ئۇلارنى شەرمەندە قىلىسەن؛
\m 
\v 29 چۈنكى سەن پەرۋەردىگار مېنىڭ چىرىغىمدۇرسەن؛
\m پەرۋەردىگار مېنى باسقان قاراڭغۇلۇقنى نۇرلاندۇرىدۇ؛ \x ◘ \xo 22:29 \xt پەند. 9؛13\x*
\m 
\v 30 چۈنكى سەن ئارقىلىق دۈشمەن قوشۇنى ئارىسىدىن يۈگۈرۈپ ئۆتتۈم؛
\m سەن خۇدايىم ئارقىلىق مەن سېپىلدىن ئاتلاپ ئۆتتۈم. \f ◼ \fr 22:30 \ft \bd «دۈشمەن قوشۇنى ئارىسىدىن يۈگۈرۈپ ئۆتتۈم»\bd* ــ «يۈگۈرۈپ ئۆتتۈم» دېگەن مۇشۇ سۆزلەر «بۆسۈپ ئۆتتۈم» دېگەن مەنىنى ئۆز ئىچىگە ئالىدۇ.\f*
\m 
\v 31 تەڭرىم ــ ئۇنىڭ يولى مۇكەممەلدۇر؛
\m پەرۋەردىگارنىڭ سۆزى سىناپ ئىسپاتلانغاندۇر؛
\m ئۇ ئۆزىگە تايانغانلارنىڭ ھەممىسىگە قالقاندۇر. \x ◘ \xo 22:31 \xt قان. 32‏:4؛ دان. 4‏:34؛ زەب. 12‏:6؛ 119‏:140؛ پەند. 30‏:5؛ ۋەھ. 15‏:3\x*
\m 
\v 32 چۈنكى پەرۋەردىگاردىن باشقا يەنە كىم ئىلاھتۇر؟
\m بىزنىڭ خۇدايىمىزدىن باشقا كىم قورام تاشتۇر؟ \x ◘ \xo 22:32 \xt قان. 32‏:39؛ 1سام. 2‏:2؛ زەب. 86‏:8؛ يەش. 45‏:5\x*
\m 
\v 33 تەڭرى مېنىڭ مۇستەھكەم قورغىنىمدۇر؛
\m ئۇ يولۇمنى مۇكەممەل، تۈپ-تۈز قىلىدۇ؛
\m 
\v 34 ئۇ مېنىڭ پۇتلىرىمنى كېيىكنىڭكىدەك قىلىدۇ؛
\m ئۇ مېنى يۇقىرى جايلىرىمغا تۇرغۇزىدۇ؛
\m 
\v 35 قوللىرىمنى ئۇرۇش قىلىشقا ئۆگىتىدۇ،
\m شۇڭلاشقا بىلەكلىرىم مىس كاماننى كېرەلەيدۇ؛
\m 
\v 36 سەن ماڭا نىجاتىڭدىكى قالقاننى بەردىڭ،
\m سېنىڭ مۇلايىم كەمتەرلىكىڭ مېنى ئۇلۇغ قىلدى.
\m 
\v 37 سەن قەدەملىرىم ئاستىدىكى جاينى كەڭ قىلدىڭ،
\m مېنىڭ پۇتلىرىم تېيىلىپ كەتمىدى.
\m 
\v 38 مەن دۈشمەنلىرىمنى قوغلاپ يوقاتتىم،
\m ئۇلار ھالاك بولمىغۇچە ھېچ يانمىدىم.
\m 
\v 39 قايتا تۇرالمىغۇدەك قىلىپ،
\m ئۇلارنى ھالاك قىلىپ يانجىدىم،
\m ئۇلار پۇتلىرىم ئاستىدا يىقىلدى.
\m 
\v 40 سەن جەڭ قىلىشقا كۈچ بىلەن بېلىمنى باغلىدىڭ؛
\m سەن ماڭا ھۇجۇم قىلغانلارنى پۇتۇم ئاستىدا ئېگىلدۈردۈڭ؛
\m 
\v 41 دۈشمەنلىرىمنى ماڭا ئارقىنى قىلىپ قاچقۇزدۇڭ،
\m شۇنىڭ بىلەن مەن ماڭا ئۆچمەنلەرنى يوقاتتىم.
\m 
\v 42 ئۇلار تەلمۈردى، بىراق قۇتقۇزىدىغان ھېچكىم يوق ئىدى؛
\m ھەتتا پەرۋەردىگارغا قارىۋىدى، ئۇمۇ ئۇلارغا جاۋاب بەرمىدى.
\m 
\v 43 مەن ئۇلارنى سوقۇپ يەردىكى توپىدەك قىلىۋەتتىم؛
\m كوچىدىكى پاتقاقتەك مەن ئۇلارنى چەيلىۋەتتىم؛
\m ئۇلارنىڭ ئۈستىدىن پېتىقدىۋەتتىم.
\m 
\v 44 سەن مېنى خەلقىمنىڭ نىزالىرىدىن قۇتقۇزغانسەن؛
\m سەن مېنى ئەللەرنىڭ بېشى بولۇشقا ساقلىدىڭ؛
\m ماڭا يات بولغان بىر خەلق خىزمىتىمدە بولماقتا.
\m 
\v 45 يات ئەلدىكىلەر ماڭا زەئىپلىشىپ تەسلىم بولىدۇ؛
\m ئاڭلىشى بىلەنلا ئۇلار ماڭا ئىتائەت قىلىدۇ؛
\m 
\v 46 يات ئەلدىكىلەر چۈشكۈنلىشىپ كېتىدۇ؛
\m ئۇلار ئۆز ئىستىھكاملىرىدىن تىترىگەن ھالدا چىقىپ كېلىدۇ؛
\m 
\v 47 پەرۋەردىگار ھاياتتۇر!
\m مېنىڭ قورام تېشىم مۇبارەكلەنسۇن؛
\m نىجاتىم بولغان قورام تاش خۇدا ئالىيدۇر، دەپ مەدھىيىلەنسۇن!
\m 
\v 48 ئۇ، يەنى مەن ئۈچۈن تولۇق قىساس ئالغۇچى تەڭرى،
\m خەلقلەرنى ماڭا بويسۇندۇرغۇچىدۇر؛
\m 
\v 49 ئۇ مېنى دۈشمەنلىرىم ئارىسىدىن چىقارغان؛
\m بەرھەق، سەن مېنى ماڭا ھۇجۇم قىلغانلاردىن يۇقىرى كۆتۈردۈڭ؛
\m زوراۋان ئادەمدىن سەن مېنى قۇتۇلدۇردۇڭ.
\m 
\v 50 مۇشۇ سەۋەبلىك مەن ئەللەر ئارىسىدا ساڭا تەشەككۈر ئېيتىمەن، ئى پەرۋەردىگار؛
\m نامىڭنى ئۇلۇغلاپ كۈيلەرنى ئېيتىمەن؛ \x ◘ \xo 22:50 \xt رىم. 15‏:9\x*
\m 
\v 51 ئۇ بولسا ئۆزى تىكلىگەن پادىشاھقا زور قۇتقۇزۇشلارنى بېغىشلايدۇ؛
\m ئۆزى مەسىھ قىلغىنىغا،
\m يەنى داۋۇتقا ھەم ئۇنىڭ نەسلىگە مەڭگۈگە ئۆزگەرمەس مۇھەببەتنى كۆرسىتىدۇ.
\b
\b
\c 23
\s1 داۋۇتنىڭ ئاخىرقى سۆزلىرى
\m 
\v 1 تۆۋەندىكىلەر داۋۇتنىڭ ئاخىرقى سۆزلىرىدۇر: ــ
\m ئىسرائىلنىڭ كۈيلىرىنىڭ سۆيۈملۈك تېمىسى بولغۇچىنى،
\m يەنى ياقۇپنىڭ خۇداسىنىڭ مەسىھىنى مەلۇم قىلىش ئۈچۈن،
\m يۇقىرى مەرتىۋىگە كۆتۈرۈلگەن ئادەم مۇنداق سۆزلەيدۇ،
\m يەسسەنىڭ ئوغلى داۋۇتنىڭ مۇنداق بېشارەت بېرىدۇ: ــ \f ◼ \fr 23:1 \ft \bd «ئىسرائىلنىڭ كۈيلىرىنىڭ سۆيۈملۈك تېمىسى بولغۇچىنى، يەنى ياقۇپنىڭ خۇداسىنىڭ مەسىھىنى مەلۇم قىلىش ئۈچۈن يۇقىرى مەرتىۋىگە كۆتۈرۈلگەن ئادەم مۇنداق سۆزلەيدۇ، يەسسەنىڭ ئوغلى داۋۇتنىڭ مۇنداق بېشارەت بېرىدۇ،...»\bd* ــ بۇرۇنقى بىرخىل تەرجىمىمىز: «يەسسەنىڭ ئوغلى داۋۇتنىڭ بېشارىتى، يۇقىرى مەرتىۋىگە كۆتۈرۈلگەن، ياقۇپنىڭ خۇداسى تەرىپىدىن مەسىھلەنگەن، ئىسرائىلنىڭ سۆيۈملۈك كۈيچىسىنىڭ بېشارەت سۆزلىرى مانا...». يېقىندىكى تەتقىقات ھازىرقى تەرجىمىمزنى تەستىقلەيدۇ.\f*
\m 
\v 2 پەرۋەردىگارنىڭ روھى مەن ئارقىلىق سۆز قىلدى،
\m ئۇنىڭ سۆزلىرى تىلىمدىدۇر.
\m 
\v 3 ئىسرائىلنىڭ خۇداسى سۆز قىلدى،
\m ئىسرائىلنىڭ قورام تېشى ماڭا شۇنداق دېدى: ــ
\m كىمكى ئادەملەرنىڭ ئارىسىدا ئادالەت بىلەن سەلتەنەت قىلسا،
\m كىمكى خۇدادىن قورقۇش بىلەن سەلتەنەت قىلسا،
\m 
\v 4 ئۇ قۇياش چىققاندىكى تاڭ نۇرىدەك،
\m بۇلۇتسىز سەھەردەك بولىدۇ،
\m يامغۇردىن كېيىن ئاسمان سۈزۈك بولۇشى بىلەن،
\m يۇمران مايسىلار تۇپراقتىن چىقىدۇ، مانا ئۇ شۇنداق بولىدۇ. \f ◼ \fr 23:4 \ft \bd «ئۇ قۇياش چىققاندىكى تاڭ نۇرىدەك،...»\bd* ــ ياكى «قۇياش چىققاندەك، تاڭ نۇرىدەك،...».\f*
\m 
\v 5 مېنىڭ ئۆيۈم تەڭرى ئالدىدا شۇنداق بولمىسىمۇ،
\m ئۇ يەنىلا مەن بىلەن مەڭگۈلۈك ئەھدە تۈزدى؛
\m ئەھدە ھەممە ئىشلاردا مۇپەسسەل ھەم مۇستەھكەمدۇر؛
\m گەرچە ئۇ بۇنى تېخى بەرق ئۇرغۇزمامىغان بولسىمۇ،
\m بۇ مېنىڭ بارلىق نىجاتلىق ئىشلىرىم،
\m مېنىڭ ھەممە ئىنتىزارلىقىمدۇر!
\m 
\v 6 لېكىن ئىپلاسلارنىڭ ھەممىسى تىكەنلەردەك،
\m ھېچكىم قولىدا تۇتالمىغاچقا، چۆرۈۋېتىلىدۇ. \f ◼ \fr 23:6 \ft \bd «ئىپلاسلارنىڭ ھەممىسى»\bd* ــ ئىبرانىي تىلىدا: «بېلىئال (شەيتان)نىڭ ئوغۇللىرىنىڭ ھەممىسى».\f*
\m 
\v 7 ئۇلارغا قول ئۇزاتقۇچى ئۆزىنى تۆمۈر قورال ۋە نەيزە سېپى بىلەن قوراللاندۇرمىسا بولمايدۇ؛
\m ئۇلار ھامان تۇرغان يېرىدە ئوتتا كۆيدۈرۈۋېتىلىدۇ!
\b
\s1 داۋۇتنىڭ پالۋانلىرى
\r 1تار. 11‏:10-47
\m 
\v 8 داۋۇتنىڭ پالۋانلىرىنىڭ ئىسىملىرى تۆۋەندىكىدەك خاتىرىلەنگەندۇر: ــ
\m تاخكىمونلۇق يوشەب-باشسەبەت سەردارلارنىڭ بېشى ئىدى. ئۇ بىر قېتىملىق جەڭدە نەيزە ئوينىتىپ، سەككىز يۈز ئادەمنى ئۆلتۈرگەنىدى. \f ◼ \fr 23:8 \ft \bd «ئۇ بىر قېتىملىق جەڭدە نەيزە ئوينىتىپ، سەككىز يۈز ئادەمنى ئۆلتۈرگەنىدى»\bd* ــ كونا كۆچۈرۈلمىلەرنىڭ كۆپىنچىسىدە: «ئۇنىڭ باشقا ئىسمى «ئەزنىلىق ئادىنو»؛ چۈنكى ئۇ بىر قېتىمدىلا سەككىز يۈز ئادەمنى ئۆلتۈرگەنىدى» دېيىلىدۇ. بىز مۇشۇ يەردە گرېك تىلىدىكى («LXX») تەرجىمىسىگە ئەگىشىمىز («1تار.» 11:11نى كۆرۈڭ).\f*
\m 
\v 9 كېيىنكىسى ئاخوخىي دودونىڭ ئوغلى ئەلىئازار ئىدى؛ فىلىستىيلەر يىغىلىپ جەڭ قىلماقچى بولدى؛ شۇ ۋاقىتتا داۋۇت ۋە ئۇنىڭغا ھەمراھ بولۇپ چىققان ئۈچ پالۋان ئۇلارنى جەڭگە چاقىردى؛ ئەلىئازار شۇ ئۈچتىن بىرى ئىدى. لېكىن ئىسرائىللار چېكىندى؛ \f ◼ \fr 23:9 \ft \bd «...ئاخوخىي دۇدونىڭ ئوغلى...»\bd* ــ ياكى «...ئاخوخىنىڭ نەۋرىسى، دودونىڭ ئوغلى،...»\f*
\v 10 ئۇ قوزغىلىپ، تاكى بېلىكى تېلىپ، قولى قىلىچقا چاپلىشىپ قالغۇچە فىلىستىيلەرنى قىردى. ئۇ كۈنى پەرۋەردىگار ئىسرائىللارنى چوڭ نۇسرەتكە ئېرىشتۈردى. خەلق ئۇنىڭ قېشىغا قايتقاندا پەقەت ئولجا يىغىش ئىشىلا قالغانىدى.
\m 
\v 11 ۋە ئۇنىڭدىن كېيىنكىسى ھارارلىق ئاگىينىڭ ئوغلى شامماھ ئىدى. بىر كۈنى فىلىستىيلەر قوشۇن بولۇپ يىغىلغانىدى؛ يېقىن ئەتراپتا قويۇق ئۆسكەن بىر قىزىل ماشلىق بار ئىدى. كىشىلەر فىلىستىلەرنىڭ ئالدىدىن قاچقانىدى، \f ◼ \fr 23:11 \ft \bd «بىر كۈنى فىلىستىيلەر قوشۇن بولۇپ يىغىلغانىدى»\bd* ــ باشقا بىرخىل تەرجىمىسى: «بىر كۈنى فىلىستىيلەر لېھى (يېزىسى)دا يىغىلغانىدى».\f*
\v 12 شامماھ بولسا قىزىل ماشلىق ئوتتۇرىسىدا مەزمۇت تۇرۇپ، ئۇنى قوغداپ فىلىستىيلەرنى قىردى؛ شۇنىڭ بىلەن پەرۋەردىگار \add ئىسرائىللارغا\add* غايەت زور نۇسرەت ئاتا قىلدى.
\m 
\v 13 ئورما ۋاقتىدا ئوتتۇز يولباشچى ئىچىدىن يەنە ئۈچى ئادۇللامنىڭ غارىغا چۈشۈپ، داۋۇتنىڭ يېنىغا كەلدى. فىلىستىيلەرنىڭ قوشۇنى رەفايىم ۋادىسىغا بارگاھ قۇرغانىدى؛
\v 14 ئۇ چاغدا داۋۇت قورغاندا ئىدى، فىلىستىيلەرنىڭ قاراۋۇلگاھى بولسا بەيت-لەھەمدە ئىدى.
\v 15 داۋۇت ئۇسساپ: ئاھ، بىرسى ماڭا بەيت-لەھەمنىڭ دەرۋازىسىنىڭ يېنىدىكى قۇدۇقتىن سۇ ئەكىلىپ بەرگەن بولسا ياخشى بولاتتى! ــ دېۋىدى،
\v 16 بۇ ئۈچ پالۋان فىلىستىيلەرنىڭ لەشكەرگاھىدىن بۆسۈپ ئۆتۈپ، بەيت-لەھەمنىڭ دەرۋازىسىنىڭ يېنىدىكى قۇدۇقتىن سۇ تارتتى ۋە داۋۇتقا ئېلىپ كەلدى؛ لېكىن ئۇ ئۇنىڭدىن ئىچكىلى ئۇنىمىدى، بەلكى سۇنى پەرۋەردىگارغا ئاتاپ تۆكۈپ:
\v 17 ــ ئى پەرۋەردىگار، بۇنداق ئىش مەندىن نېرى بولسۇن! بۇ ئۈچ ئادەمنىڭ ئۆز ھاياتىغا تەۋەككۇل قىلىپ بېرىپ ئەكەلگەن بۇ سۇ ئۇلارنىڭ قېنىغا ئوخشاش ئەمەسمۇ! ــ دېدى. شۇنىڭ ئۈچۈن ئۇ ئىچىشكە ئۇنىمىدى. بۇ ئۈچ پالۋان قىلغان ئىشلار دەل شۇلار ئىدى.
\v 18 زەرۇئىيانىڭ ئوغلى يوئابنىڭ ئىنىسى ئابىشاي بۇ ئۈچىنىڭ بېشى ئىدى. ئۇ ئۈچ يۈز ئادەم بىلەن قارشىلىشىپ نەيزىسىنى پىقىرىتىپ ئۇلارنى ئۆلتۈرگەن. شۇنىڭ بىلەن ئۇ بۇ «ئۈچ پالۋان» ئىچىدە نامى چىققانىدى.
\v 19 ئۇ بۇ ئۈچەيلەننىڭ ئىچىدە ئەڭ ھۆرمەتلىكى ئىدى، شۇڭا ئۇلارنىڭ بېشى ئىدى؛ لېكىن ئۇ ئاۋۋالقى ئۈچەيلەنگە يەتمەيتتى.
\m 
\v 20 يەھويادانىڭ ئوغلى بىنايا كابزەئەلدىن بولۇپ، بىر باتۇر پالۋان ئىدى؛ ئۇ كۆپ قالتىس ئىشلارنى قىلغان. ئۇ موئابىي ئارىئەلنىڭ ئىككى ئوغلىنى ئۆلتۈرگەن. يەنە قار ياغقان بىر كۈنى ئازگالغا چۈشۈپ، بىر شىرنى ئۆلتۈرگەنىدى. \f ◼ \fr 23:20 \ft \bd «ئۇ موئابىي ئارىئەلنىڭ ئىككى ئوغلىنى ئۆلتۈرگەن»\bd* ــ ياكى «ئۇ موئابتىكى ئىككى شىردەك كىشىنى ئۆلتۈرگەن».\f*
\v 21 ئۇ ھەم كۈچتۈڭگۈر بىر مىسىرلىقنى ئۆلتۈرگەنىدى. مىسىرلىقنىڭ قولىدا بىر نەيزە بار ئىدى، لېكىن بىنايانىڭ قولىدا بىر ھاسىلا بار ئىدى. ئۇ مىسىرلىقنىڭ قولىدىن نەيزىسىنى تارتىۋېلىپ، ئۆز نەيزىسى بىلەن ئۇنى ئۆلتۈردى.
\v 22 بۇ ئىشلارنى يەھويادانىڭ ئوغلى بىنايا قىلغان بولۇپ، ئۇ ئۈچ پالۋان ئارىسىدا نام چىقارغانىدى.
\v 23 ئۇ ئوتتۇز يولباشچى ئىچىدە ھۆرمەتلىك ئىدى. لېكىن ئۇ ئاۋۋالقى ئۈچ پالۋانغا يەتمەيتتى. داۋۇت ئۇنى ئۆزىنىڭ پاسىبان بېگى قىلدى.
\m 
\v 24 ئوتتۇز يولباشچى ئىچىدە يوئابنىڭ ئىنىسى ئاساھەل، بەيت-لەھەملىك دودونىڭ ئوغلى ئەل-ھانان بار ئىدى.
\v 25 \add بۇنىڭدىن باشقا\add*: ھارودلۇق شامماھ، ھارودلۇق ئېلىكا،
\v 26 پاتلىلىق ھەلەز، تەكوئالىق ئىككەشنىڭ ئوغلى ئىرا،
\v 27 ئاناتوتلۇق ئابىئېزەر، ھۇشاتلىق مىبونناي،
\v 28 ئاخوھلۇق زالمون، نىتوفاتلىق ماھاراي،
\v 29 نىتوفاتلىق بائاناھنىڭ ئوغلى خەلەب، بىنيامىنلاردىن گىبېئاھلىق رىباينىڭ ئوغلى ئىتتاي، \f ◼ \fr 23:29 \ft \bd «بائاناھنىڭ ئوغلى ھەلەب»\bd* ــ ياكى «بائاناھنىڭ ئوغلى خەلەد».\f*
\v 30 پىراتونلۇق بىنايا، گائاش ۋادىلىرىدىن ھىدداي،
\v 31 ئارباتلىق ئابى-ئالبون، بارھۇملۇق ئازماۋەت،
\v 32‏-33 شائالبونلۇق ئەلىياھبا، ياشەننىڭ ئوغۇللىرى، ھارارلىق شامماھنىڭ \add ئوغلى\add* يوناتان، ھارارلىق شارارنىڭ ئوغلى ئاھىيام، \f ◼ \fr 23:32‏-33 \ft \bd «ھارارلىق شامماھنىڭ ئوغلى يوناتان»\bd* ــ ئىبرانىي تىلىدا «ئوغلى» دېگەن سۆز تېپىلمايدۇ. يوناتاننىڭ شامماھ (شاگى) بىلەن بولغان مۇناسىۋىتى «1تار.» 34:11دىن كۆرۈلىدۇ.\f*
\v 34 مائاكاتىي ئاخاسباينىڭ ئوغلى ئەلىفەلەت، گىلونلۇق ئاھىتوفەلنىڭ ئوغلى ئېلىيام،
\v 35 كارمەللىك ھەزراي، ئاربىلىق پائاراي،
\v 36 زوباھدىن بولغان ناتاننىڭ ئوغلى ئىگال، گادلىق باننى،
\v 37 ئاممونىي زەلەك، بەئەروتلۇق ناھاراي (ئۇ زەرۇئىيانىڭ ئوغلى يوئابنىڭ ياراغ كۆتۈرگۈچىسى ئىدى)،
\v 38 يىترىلىق ئىرا، يىترىلىق گارەب
\v 39 ۋە ھىتتىي ئۇرىيا قاتارلىقلار بولۇپ، ئۇلارنىڭ ھەممىسى ئوتتۇز يەتتە كىشى ئىدى. \f ◼ \fr 23:39 \ft \bd «... ۋە ھىتتىي ئۇرىيا قاتارلىقلار بولۇپ، ئۇلارنىڭ ھەممىسى ئوتتۇز يەتتە كىشى ئىدى»\bd* ــ بۇ تىزىملىكتە يەھۇدىي ئەمەسلەردىن بىرنەچچىسى بار ــ مەسىلەن ئاممونلۇق زەلەك، ھىتتىي ئۇرىيا ۋە موئابلىق يىتما بار.\f*
\b
\b
\c 24
\s1 داۋۇتنىڭ ئىسرائىللارنى رويخەتكە ئېلىش گۇناھى
\r 1تار. 21
\m 
\v 1 پەرۋەردىگارنىڭ غەزىپى ئىسرائىلغا يەنە قوزغالدى. شۇنىڭ بىلەن ئۇ ئۇلارنى جازالاش ئۈچۈن داۋۇتنى قوزغىۋىدى، ئۇ ئادەم چىقىرىپ، ئۇلارغا: ــ ئىسرائىللار بىلەن يەھۇدالىقلارنىڭ سانىنى ئال، دېدى. \f ◼ \fr 24:1 \ft \bd « \bdit خۇدا\bdit* ئۇلارنى جازالاش ئۈچۈن داۋۇتنى قوزغىۋىدى، ئۇ ...: ــ ئىسرائىللار بىلەن يەھۇدالىقلارنىڭ سانىنى ئال، دېدى»\bd* ــ شۈبھىسىزكى، داۋۇت ئەسلى شۇ نىيەتتە ئىدى. مەقسىتى بەلكىم ئۆز ئۇلۇغلۇقىنى كۆرسىتىش ياكى شۇنىڭغا ئوخشاش تەكەببۇرلۇق نىيىتى بولسا كېرەك. پەرۋەردىگار ئىسرائىلغا غەزىپىنى كۆرسىتىش ئۈچۈن، داۋۇتنىڭ بۇ يامان ئىشنى قىلىشىغا يول قويدى.\f*
\m 
\v 2 پادىشاھ ئۆز يېنىدا تۇرغان قوشۇن سەردارى يوئابقا: بارغىن، داندىن تارتىپ بەئەر-شېباغىچە ئىسرائىلنىڭ ھەممە قەبىلىلىرىنىڭ يۇرتلىرىنى كېزىپ، خەلقنى ساناپ چىققىن، مەن خەلقنىڭ سانىنى بىلەي، دېدى.
\m 
\v 3 يوئاب پادىشاھقا: بۇ خەلق ھازىر مەيلى قانچىلىك بولسۇن، پەرۋەردىگار خۇدايىڭ ئۇلارنىڭ سانىنى يۈز ھەسسە ئاشۇرغاي. بۇنى غوجام پادىشاھ ئۆز كۆزى بىلەن كۆرگەي! لېكىن غوجام پادىشاھ نېمىشقا بۇ ئىشتىن خۇش بولىدىكىن؟ ــ دېدى. \f ◼ \fr 24:3 \ft \bd «لېكىن غوجام پادىشاھ نېمىشقا بۇ ئىشتىن خۇش بولىدىكىن؟»\bd* ــ غەلىتە ئىش شۇكى، ھەتتا خۇدادىن قورقمايدىغان يوئابتەك بىر كىشى بۇ ئىشنىڭ خۇداغا ياقمايدىغانلىقىنى بىلىدۇ.\f*
\m 
\v 4 ئەمما يوئاب بىلەن قوشۇننىڭ باشقا سەردارلىرى ئۇنىمىسىمۇ، پادىشاھنىڭ يارلىقى ئۇلاردىن كۈچلۈك ئىدى؛ شۇنىڭ بىلەن يوئاب بىلەن قوشۇننىڭ باشقا سەردارلىرى ئىسرائىلنىڭ خەلقىنى سانىغىلى پادىشاھنىڭ قېشىدىن چىقتى.
\v 5 ئۇلار ئىئوردان دەرياسىدىن ئۆتۈپ يائازەرگە يېقىن گاد ۋادىسىدا ئاروئەردە، يەنى شەھەرنىڭ جەنۇب تەرىپىدە بارگاھ تىكتى.
\v 6 ئاندىن ئۇلار گىلېئادقا ۋە تاختىم-ھودشىنىڭ يۇرتىغا كەلدى. ئاندىن دان-يائانغا كېلىپ ئايلىنىپ زىدونغا باردى.
\v 7 ئاندىن ئۇلار تۇر دېگەن قورغانلىق شەھەرگە، شۇنداقلا ھىۋىيلار بىلەن قانائانىيلارنىڭ ھەممە شەھەرلىرىگە كەلدى؛ ئاندىن ئۇلار يەھۇدا يۇرتىنىڭ جەنۇب تەرىپىگە، شۇ يەردىكى بەئەر-شېباغىچە باردى.
\v 8 شۇنداق قىلىپ ئۇلار پۈتكۈل زېمىننى كېزىپ، توققۇز ئاي يىگىرمە كۈن ئۆتكەندىن كېيىن، يېرۇسالېمغا يېنىپ كەلدى.
\m 
\v 9 يوئاب پادىشاھقا خەلقنىڭ سانىنى مەلۇم قىلىپ: ئىسرائىلدا قىلىچ كۆتۈرەلەيدىغان باتۇردىن سەككىز يۈز مىڭى، يەھۇدادا بەش يۈز مىڭى بار ئىكەن، دېدى.
\m 
\v 10 داۋۇت خەلقنىڭ سانىنى ئالغاندىن كېيىن، ۋىجدانى ئازابلاندى ۋە پەرۋەردىگارغا: بۇ قىلغىنىم ئېغىر گۇناھ بولۇپتۇ. ئى پەرۋەردىگار، قۇلۇڭنىڭ قەبىھلىكىنى كۆتۈرۈۋەتكەيسەن؛ چۈنكى مەن تولىمۇ ئەخمەقانىلىك قىپتىمەن، دېدى. \f ◼ \fr 24:10 \ft \bd «داۋۇت خەلقنىڭ سانىنى ئالغاندىن كېيىن، ۋىجدانى ئازابلاندى... تولىمۇ ئەخمەقانىلىك قىپتىمەن، دېدى»\bd* ــ «خەلقنى ساناقتىن ئۆتكۈزۈش» دېگەن گۇناھ توغرۇلۇق «قوشۇمچە سۆز»ىمىزدە ئازراق توختىلىمىز.\f*
\m 
\v 11 داۋۇت ئەتىگەندە تۇرغاندا پەرۋەردىگارنىڭ سۆزى داۋۇتنىڭ ئالدىن كۆرگۈچىسى بولغان گاد پەيغەمبەرگە كېلىپ دېگەندە:
\m 
\v 12 ــ «بېرىپ داۋۇتقا ئېيتقىن، پەرۋەردىگار: ــ
\m مەن ئۈچ \add بالا-قازانى\add* ئالدىڭغا قويىمەن، ئۇلارنىڭ بىرىنى تاللىۋالغىن، مەن شۇنى ئۈستۈڭگە چۈشۈرىمەن، دەيدۇ ــ دېگىن».
\m 
\v 13 شۇنىڭ بىلەن گاد داۋۇتنىڭ قېشىغا كېلىپ بۇنى ئۇنىڭغا دېدى. ئۇ ئۇنىڭغا: «يەتتە يىلغىچە زېمىنىڭدا ئاچارچىلىق ساڭا بولسۇنمۇ؟ ياكى دۈشمەنلىرىڭ ئۈچ ئايغىچە سېنى قوغلاپ، سەن ئۇلاردىن قاچامسەن؟ ۋە ياكى ئۈچ كۈنگىچە زېمىنىڭدا ۋابا تارقالسۇنمۇ؟ ئەمدى سەن ئوبدان ئويلاپ، بىر نېمە دېگىن، مەن مېنى ئەۋەتكۈچىگە نېمە دەپ جاۋاپ بېرەي؟» ــ دېدى.
\m 
\v 14 داۋۇت گادقا: مەن تولىمۇ تەڭلىكتە قالدىم! سەندىن ئۆتۈنەيكى، بىز پەرۋەردىگارنىڭ قولىغا چۈشەيلى؛ چۈنكى ئۇنىڭ رەھىمدىللىقى زوردۇر؛ ئىنساننىڭ قولىغا پەقەت چۈشۈپ قالمىغايمەن! ــ دېدى.
\m 
\v 15 شۇنىڭ بىلەن پەرۋەردىگار ئەتىگەندىن تارتىپ بېكىتىلگەن ۋاقىتقىچە ۋابا چۈشۈردى. داندىن تارتىپ بەئەر-شېباغىچە يەتمىش مىڭ ئادەم ئۆلدى.
\v 16 ئەمدى پەرىشتە قولىنى يېرۇسالېمغا ئۇزۇتۇپ شەھەرنى ھالاك قىلاي دېگەندە، پەرۋەردىگار ئېغىر ھۆكۈمىدىن پۇشايمان قىلىپ، خەلقنى ھالاك قىلىۋاتقان پەرىشتىگە: ئەمدى بولدى قىلغىن؛ قولۇڭنى يىغقىن، ــ دېدى. ئۇ ۋاقىتتا پەرۋەردىگارنىڭ پەرىشتىسى يەبۇسىي ئاراۋناھنىڭ خامىنىنىڭ يېنىدا ئىدى. \f ◼ \fr 24:16 \ft \bd «پەرۋەردىگارنىڭ پەرىشتىسى»\bd* ــ بۇ ئالاھىدە شەخس توغرۇلۇق بىزنىڭ «تەبىرلەر»ىمىزنى كۆرۈڭ.\f*
\m 
\v 17 داۋۇت خەلقنى يوقىتىۋاتقان پەرىشتىنى كۆرگەندە پەرۋەردىگارغا: مانا، گۇناھ قىلغان مەن، قەبىھلىك قىلغۇچى مەندۇرمەن. لېكىن بۇ قويلار بولسا نېمە قىلدى؟ سېنىڭ قولۇڭ مېنىڭ ئۈستۈمگە ۋە ئاتامنىڭ جەمەتىنىڭ ئۈستىگە چۈشسۇن! ــ دېدى. \f ◼ \fr 24:17 \ft \bd «لېكىن بۇ قويلار بولسا نىمە قىلدى؟»\bd* ــ «بۇ قويلار» خۇدانىڭ خەلقىنى كۆرسىتىدۇ.\f*
\b
\s1 داۋۇت خاماننى سېتىۋېلىپ قۇربانگاھ قۇرىدۇ
\m 
\v 18 شۇ كۈنى گاد داۋۇتنىڭ قېشىغا كېلىپ ئۇنىڭغا: بېرىپ يەبۇسىي ئاراۋناھنىڭ خامىنىغا پەرۋەردىگارغا ئاتاپ بىر قۇربانگاھ ياسىغىن، دېدى.
\m 
\v 19 داۋۇت گادنىڭ سۆزى بويىچە پەرۋەردىگار بۇيرۇغاندەك قىلدى.
\m 
\v 20 ئاراۋناھ قاراپ پادىشاھ بىلەن خىزمەتكارلارنىڭ ئۆز تەرىپىگە كېلىۋاتقىنىنى كۆرۈپ، ئالدىغا چىقىپ پادىشاھنىڭ ئالدىدا يۈزىنى يەرگە تەككۈزۈپ، تەزىم قىلدى.
\v 21 ئاراۋناھ: غوجام پادىشاھ نېمە ئىش بىلەن قۇللىرىنىڭ ئالدىغا كەلدىلىكىن؟ ــ دەپ سورىدى. داۋۇت: خەلقنىڭ ئارىسىدا ۋابانى توختىتىش ئۈچۈن، بۇ خاماننى سەندىن سېتىۋېلىپ، بۇ يەردە پەرۋەردىگارغا بىر قۇربانگاھ ياسىغىلى كەلدىم، ــ دېدى.
\m 
\v 22 ئاراۋناھ داۋۇتقا: غوجام پادىشاھ ئۆزلىرى نېمىنى خالىسىلا شۇنى ئېلىپ قۇربانلىق قىلسىلا. مانا بۇ يەردە كۆيدۈرمە قۇربانلىق ئۈچۈن كالىلار بار، ئوتۇن قىلىشقا خامان تېپىدىغان تىرنىلار بىلەن كالىلارنىڭ بويۇنتۇرۇقلىرى بار.
\v 23 ئى پادىشاھ، بۇنىڭ ھەممىسىنى مەنكى \add ئاراۋناھ\add* پادىشاھقا تەقدىم قىلاي، دېدى. ئۇ يەنە پادىشاھقا: پەرۋەردىگار خۇدالىرى سىلىنى قوبۇل قىلىپ شەپقەت كۆرسەتكەي، دېدى.
\m 
\v 24 پادىشاھ ئاراۋناھغا: ياق، قانداقلا بولمىسۇن بۇلارنى سەندىن ئۆز نەرخىدە سېتىۋالمىسام بولمايدۇ. مەن بەدەل تۆلىمەي پەرۋەردىگار خۇدايىمغا كۆيدۈرمە قۇربانلىقلارنى ھەرگىز سۇنمايمەن، ــ دېدى. ئاندىن داۋۇت خامان بىلەن كالىلارنى ئەللىك شەكەل كۈمۈشكە سېتىۋالدى. \f ◼ \fr 24:24 \ft \bd «ئەللىك شەكەل»\bd* ــ بەلكىم 600 گرام ئەتراپىدا ئىدى.\f*
\m 
\v 25 ئاندىن داۋۇت ئۇ يەردە پەرۋەردىگارغا بىر قۇربانگاھ ياساپ، كۆيدۈرمە قۇربانلىقلار بىلەن ئىناقلىق قۇربانلىقلىرى قىلدى. پەرۋەردىگار زېمىن ئۈچۈن قىلغان دۇئالارنى قوبۇل قىلىپ، ۋابا ئىسرائىلنىڭ ئارىسىدا توختىدى. 
