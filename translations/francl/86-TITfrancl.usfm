\p
\v 8 \w C|strong="G3778"\w*’\w est|strong="G3588"\w* \w là|strong="G2532"\w* \w une|strong="G2532"\w* \w parole|strong="G3056"\w* \w certaine|strong="G4103"\w*, \w et|strong="G2532"\w* \w je|strong="G2532"\w* \w désire|strong="G1014"\w* \w que|strong="G2532"\w* \w tu|strong="G4771"\w* \w affirmes|strong="G1226"\w* \w ces|strong="G3778"\w* \w choses|strong="G3588"\w*, \w afin|strong="G2443"\w* \w que|strong="G2532"\w* \w ceux|strong="G3588"\w* \w qui|strong="G3588"\w* \w croient|strong="G4100"\w* \w en|strong="G2532"\w* \w Dieu|strong="G2316"\w* \w s|strong="G2532"\w*’\w appliquent|strong="G5431"\w* \w à|strong="G2532"\w* \w être|strong="G2532"\w* \w les|strong="G2532"\w* \w premiers|strong="G2532"\w* \w dans|strong="G2532"\w* \w la|strong="G2532"\w* \w pratique|strong="G3588"\w* \w des|strong="G2532"\w* \w bonnes|strong="G2570"\w* \w œuvres|strong="G2041"\w*. \w C|strong="G3778"\w*’\w est|strong="G3588"\w* \w ce|strong="G3778"\w* \w qui|strong="G3588"\w* \w est|strong="G3588"\w* \w bon|strong="G2570"\w* \w et|strong="G2532"\w* \w utile|strong="G3588"\w* \w aux|strong="G2532"\w* \w hommes|strong="G3778"\w*.  
