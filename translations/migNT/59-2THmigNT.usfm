\id 2TH
\h 2 Tesalonicenses
\toc1 YA'A KUU CARTA UU JA NI CHAA SAN PABLO APOSTOL NUU ÑAYƗVƗ ÑUU TESALONICA
\toc2 2 Tesalonicenses
\toc3 2 Ts.
\mt2 LA SEGUNDA EPISTOLA DEL APOSTOL SAN PABLO A LOS TESALONICENSES
\mt1 YA'A KUU CARTA UU JA NI CHAA SAN PABLO APOSTOL NUU ÑAYƗVƗ ÑUU TESALONICA
\c 1
\p 
\v 1 Máá‑rí kákuu Pablo jíín Silas jíín Timoteo, te káchaa‑ri̱ tutu̱ yá'a nuu̱ tɨ́ku'ni̱ kákandíja ñuu̱ Tesalónica, ja̱ ká'i̱in‑i nuu̱ máá Táa̱‑yo̱ Dios, jíín núu̱ máá Jíto'o̱‑yo̱ Jesucristo.
\v 2 Tu̱'un luu íó ini̱‑ya̱ jíín tú'un kuaká'nu ini̱ ja̱ kíi nuu̱ máá Táa̱‑yo̱ Dios jíín núu̱ máá Jíto'o̱‑yo̱ Jesucristo, ná kóo jíín‑ró jíná'an‑ró.
\s1 Dios kúu I'a̱ sándaa̱ va̱'a tiñu‑yó
\p 
\v 3 Kánakuatá'ú nɨ́nɨ‑rí nuu̱ Dios ja̱ sɨkɨ́ róó ñáni̱. Súan íó va̱'a, chi kua̱kukútu‑gá‑ro̱ jíín tú'un kákandíja‑ró, te bueno kákundá'ú ini̱‑ro̱ tá'an‑ró.
\v 4 Ja̱ yúán kákusɨɨ̱ iní‑ri̱ ja̱ sɨkɨ́ róó jíná'an‑ró, hora kánakani‑ri̱ tu̱'un‑ró núu̱ tɨ́ku'ni̱ máá Dios, ndasa kákandíja‑ró, jíín já ká'i̱in ni̱'in‑ró, va̱sa káchindiki̱n‑i róó, va̱sa káta'a̱n‑ro̱ túndó'o.
\v 5 Yu̱án kúu ɨɨn tuni̱ ja̱ sándaa̱ ndaa̱‑ya̱‑í, náva̱'a nani'i̱n tá'u̱‑ro̱ nájaa̱‑ro̱ iní ñuu̱ nuu̱ tá'ú Dios tiñu, chi ja̱ sɨkɨ́ yúán kándo'o‑ró.
\v 6 Chi̱ íó va̱'a ja̱ súni jíín túndó'o nachunáa Dios nuu̱ ñáyɨvɨ káxndó'o róó.
\v 7 Te róó, ña̱yɨvɨ kándo'o, ɨɨn ká'nu‑ni ndeta̱tú‑ro̱ jíín‑rí jíná'an‑ri̱ sá'a‑ya̱ kɨvɨ já ndíi ndiji̱n Jito'o̱‑yo̱ Jesús ichi ándɨ́vɨ́, jíín táká ndajá'a̱‑yá ja̱ ká'i̱o ni̱'in téyíí.
\v 8 Te jíín yáá ñú'u̱n kii‑ya̱, te xndó'o‑ya̱ ñáyɨvɨ tú kájito nuu̱ Dios, jíín ñáyɨvɨ tú kájandatu̱ nuu̱ tú'un va̱'a máá Jíto'o̱‑yo̱ Jesucristo.
\v 9 Te máá ñáyɨvɨ‑ún ndo'o‑i ja̱ náa‑í nɨ́ɨ́ káni sá'a‑ya̱, jíín já má kúu kɨ̱vɨ koyo‑i nuu̱ kánchaa̱ máá Jíto'o̱‑yo̱ jíín núu̱ lúu ndíi ncháa̱ fuerza‑ya̱.
\v 10 Súan sá'a‑ya̱ kɨvɨ́ ncháa̱‑ya̱ já ndúñá'nu luu‑ya̱ sá'a ta̱ká ña̱yɨvɨ ndóo‑ya̱, te náva̱'a naa iní sava ña̱yɨvɨ ndé'é‑i nuu̱‑yá kɨvɨ̱‑ún sá'a ta̱ká ña̱yɨvɨ kákandíja nuu̱‑yá, chi ni̱ ka̱kandíja‑ró tú'un ndaa̱ ni̱ ka̱kastu̱'ún‑rí nuu̱‑ro̱.
\v 11 Ja̱ sɨkɨ́ yá'á, te nene̱ kájika̱n ta'u̱‑rí ja'a̱ róó, náva̱'a Dios máá‑yó kuva̱'a ini̱‑ya̱ jíín‑ró já ní kana‑ya̱ róó. Te ta̱ká tiñu va̱'a kákuni̱‑ro̱ ná skíkuu‑ya̱ jíín‑ró, jíín fuerza‑ya̱, te suni jíín tíñu kásá'a‑ró, jíín tú'un kákandíja‑ró.
\v 12 Náva̱'a ná nákana jaa‑i sɨ́'vɨ́ máá Jíto'o̱‑yo̱ Jesucristo sá'a‑ró jíná'an‑ró, te suni kuatú'ún‑i róó sá'a‑ya̱, chi̱ súan sá'a tu̱'un luu íó ini̱ Dios máá‑yó jíín já íó ini̱ Jito'o̱‑yo̱ Jesucristo.
\c 2
\s1 Sɨkɨ̱ ñáyɨvɨ ñáá kɨvɨ̱ ndíi Jesús
\p 
\v 1 Te vina káka'a̱n nda̱'ú‑ri̱ jíín‑ró, ñáni̱, sɨkɨ̱ já ndíi máá Jíto'o̱‑yo̱ Jesucristo jíín já ndútútú‑yó núu̱‑yá,
\v 2 ja̱ má nátu'u̱ yachi̱ ini̱‑ro̱, ni ma̱ kúkuí'a̱ ini̱‑ro̱ sá'a ɨɨn ja̱ jíka kuu, xí tú'un, xí tutú ja̱ sá'a sɨ́kɨ́‑i ja̱ rúu̱ tájí, cuenta sɨkɨ̱ já á ni̱ kuyani ndaa̱ kɨvɨ̱ máá Jíto'o̱‑yo̱.
\v 3 Ma̱ kuá'a‑ró tú'un ja̱ xndá'ú kutɨ ní ɨɨn‑i róó. Chi ma̱ cháa̱ kɨvɨ̱‑ún onde̱ nú túu ndu'ichi̱ ini̱ kua'a̱‑í‑ya̱, te suni onde̱ ná kénda ndiji̱n máá cháa ja̱ xíin kuáchi, chi̱ máá cháa ta'nu̱ ndatu̱ kúu‑de.
\v 4 Te ndonda‑de kasu̱‑de nuu̱ táká ja̱ káskúnání‑i Dios, jíín núu̱ já káchiñú'ún‑i. Ja̱ yúán te nungo̱o‑de ini̱ ve̱'e ii̱ Dios, te ka'a̱n‑de ja̱ Dios kúu máá‑de.
\v 5 Á tú kánuku̱'un ini̱‑ro̱ já ondé ná kánchaa̱‑ga̱‑ri̱ jíín‑ró, ni̱ ka'a̱n‑ri̱ tu̱'un yá'a jíín‑ró jíná'an‑ró.
\v 6 Te vina a kájini̱‑ro̱ ndéja̱ kúu ja̱ jasú nuu̱‑dé, náva̱'a onde̱ ná jáa̱ kɨvɨ̱ máá‑de te kenda ndiji̱n‑de.
\v 7 Chi̱ máá tú'un sa̱'í xíin kuáchi, a yáji ní'ni kua'a̱n, ko íó ja̱ jasú nuu̱ vína, onde̱ ná kúxio‑ún.
\v 8 Yúan‑na te kenda ndiji̱n máá cháa xíin kuáchi‑ún. Te máá Jíto'o̱‑yo̱ ká'ni‑yá‑de nini jíín máá já tɨvɨ́ tachi̱‑ní‑ya̱, te nini ja̱ ndíi ncháa̱ kenda ndiji̱n‑ya̱, te xnáa‑yá‑de.
\v 9 Te cha̱a‑ún kii‑de sá'a Satanás, te jíín fuerza ni̱'in xaa̱n, jíín tuní, jíín tíñu ñá'nu sá'a sɨ́kɨ́‑ni‑de.
\v 10 Te jíín táká tiñu tú jíka ndaa̱, te tɨɨn yátá‑de ña̱yɨvɨ náa, kua̱chi ja̱ tú ní kájatú'ún‑i kumani̱‑í jíín tú'un ndaa̱, náva̱'a ka̱ku‑i sá'a‑ya̱ núú.
\v 11 Ja̱ yúán te skíi Dios ini̱‑i, te kuñáá xini̱‑í, ja̱ kándíja‑i ɨɨn tu̱'un xndá'ú,
\v 12 náva̱'a naku̱xndíi‑ya̱ sɨkɨ́ táká‑i ja̱ tú kákandíja‑i tu̱'un ndaa̱, chi̱ sasua kákusɨɨ̱ iní‑i jíín tíñu tú jíka ndaa̱.
\s1 Máá‑yá kúu I'a̱ skíkuu
\p 
\v 13 Nene̱ kánakuatá'ú nɨ́nɨ‑rí nuu̱ Dios ja'a̱ róó, ñáni̱, ja̱ kúndá'ú ini̱ Jito'o̱‑yo̱ róó. Chi̱ máá Dios ni̱ ka̱ji‑ya̱ róó onde̱ ná xnáñúú náva̱'a ka̱ku‑ró, te suni jíín Espíritu‑ya̱ ndúndoo ini̱‑ro̱ te kandíja‑ró tú'un ndaa̱.
\v 14 Ja̱ yúán ní kana‑ya̱ xiní‑ro̱ jíná'an‑ró ní sá'a tu̱'un va̱'a káka'a̱n‑ri̱, náva̱'a jaa̱‑ro̱ nú ndíi ncháa̱ kánchaa̱ Jito'o̱‑yo̱ Jesucristo.
\v 15 Núsáá te kuiñi ni̱'in‑ró ñáni̱, te kutɨɨn ni̱'in‑ró tú'un ni̱ ka̱kutu̱'a‑ró, kúu jíín tú'un xí jíín tutú‑ri̱.
\v 16 Máá Táa̱‑yo̱ Dios kúu I'a̱ ni̱ kúndá'ú ini̱ yóó, jíín já ní ja̱'a‑ya̱ tú'un koo ndéé iní‑yo̱ nɨ́ɨ́ káni, jíín já kúñukuu va̱'a ini̱‑yo̱ sá'a tu̱'un luu íó ini̱‑ya̱. Te máá‑yá, onde̱ jíín máá Jíto'o̱‑yo̱ Jesucristo,
\v 17 ná násándéé‑yá ini̱ añú‑ro̱ jíná'an‑ró, te ná síyíja‑ya̱ róó sɨkɨ̱ tú'un jíín sɨkɨ́ tíñu va̱'a.
\c 3
\p 
\v 1 Ɨɨn‑na̱ tu̱'un íó, ñáni̱. Ná kakán ta'u̱‑ro̱ jíná'an‑ró já'a̱‑rí jíná'an‑ri̱, náva̱'a yachi̱ ná kuichá nu̱u tu̱'un máá Jíto'o̱‑yo̱ kí'i̱n, te ná kuátú'ún‑i, nátu̱'un nuu̱ máá‑ró jíná'an‑ró,
\v 2 te suni náva̱'a ná káku‑ri̱ ini̱ nda'a cháa ñáá jíín cháa kástá'a̱n ruu̱ jíná'an‑ri̱, chi̱ nasu̱ ndɨ́'ɨ‑de kákandíja.
\v 3 Ko bueno skíkuu máá Jíto'o̱‑yo̱. Te ná síyíja‑ya̱ iní‑ro̱, te koto‑ya̱ róó nuu̱ kíni nuu̱ kuí'a̱.
\v 4 Te kájani ndija ini̱‑ri̱, sá'a máá Jíto'o̱‑yo̱, já kákuu‑ró jíín tíñu ni̱ ka̱tá'ú‑rí nuu̱‑ro̱ te kukuu‑ga̱‑ro̱ jíín.
\v 5 Te máá Jíto'o̱‑yo̱, ná stá'a̱n‑ya̱ núu̱ añú‑ro̱ ndasa koo mani̱‑ro̱ jíín Dios, te ndasa kundiso‑ró paciencia Cristo.
\s1 Sɨkɨ̱ cháa kúxí
\p 
\v 6 Ko kátá'ú‑rí tiñu nuu̱‑ro̱, ñáni̱, jíín sɨ́'vɨ́ máá Jíto'o̱‑yo̱ Jesucristo, ja̱ kúxio‑ró núu̱ táká ñani̱‑yo̱ já kájika kuu kátá‑ni‑de, chi̱ nasu̱ súan ní kástá'a̱n‑ri̱ nuu̱‑ro̱.
\v 7 Chi̱ a kájini̱ máá‑ró ndasa kánúú ndáku‑ró rúu̱, chi̱ tú súan ní kájika kuu kátá‑ni‑ri̱ nuu̱‑ro̱ jíná'an‑ró.
\v 8 Ni tú ní káyee sáni‑ri̱ staa̱ sɨkɨ́ ní ɨɨn‑ró, chi̱ sua ni̱ ka̱ja'ni‑rí máá‑rí jíín tíñu, te ndúú ñúú‑ni ni̱ ka̱sátiñu‑ri̱, te tú ní kúnɨ́nɨ iní ni ɨɨn‑ró ní ka̱sá'a‑ri̱.
\v 9 Nasu̱ já túu derecho‑ri̱ kaka̱n‑ri̱ núú. Chi̱ sua kuní‑ri̱ kuu‑ri̱ ɨɨn ejemplo nuu̱‑ro̱ ndasa ndaku‑ró rúu̱.
\v 10 Chi̱ onde̱ ná káxiu̱kú‑ga̱‑ri̱ jíín‑ró, te ni̱ ka̱tá'ú‑rí tiñu yá'a nuu̱‑ro̱, ja̱ nú ndé ɨɨn ña̱yɨvɨ tú kuní‑i sátiñu‑i, te ma̱ kée‑í núsáá.
\v 11 Chi ni̱ ka̱jini tu̱'un‑ri̱ ja̱ kájika kuu kátá‑ni sava‑i jíín‑ró, tú kásátiñu kutɨ‑í, chi̱ sasua kájika kuu‑i kándúkú tú'un‑ni‑i tá'an‑i.
\v 12 Te nuu̱ ñáyɨvɨ‑ún kátá'ú‑rí tiñu, te káka'a̱n nda̱'ú‑ri̱ jíín‑i sɨkɨ̱ máá Jíto'o̱‑yo̱ Jesucristo, ja̱ ná'ín‑ni ná kóo‑i, te ná sátiñu‑i, te ni'i̱n‑í kee‑í sɨkɨ̱ máá‑i.
\v 13 Te róó jíná'an‑ró ñáni̱, ma̱ kuítá‑ro̱ já kásá'a‑ró tíñu va̱'a.
\v 14 Te nú ndé ɨɨn‑i tú kuní‑i kuandatu̱‑i nuu̱ tú'un‑ri̱ ja̱ ká'a̱n carta yá'a, kunchaa̱ nuu̱‑ro̱‑í te ma̱ kétá'an‑ró jíín‑i jíná'an‑ró, náva̱'a ná kúka nuu̱‑í.
\v 15 Ko ma̱ kóto u'u̱‑ro̱‑í, chi̱ sua kana jíín‑ró núu̱‑í nátu̱'un nuu̱ ɨ́ɨn ñani̱‑ro̱.
\v 16 Te máá Jíto'o̱‑yo̱, I'a̱ ndíso tu̱'un kuaká'nu ini̱, nene̱ ná kuá'a‑ya̱ tú'un vindáa̱ vinené ini̱‑ro̱ jíná'an‑ró jíín táká‑ni modo. Te máá Jíto'o̱‑yo̱ ná kúnchaa̱‑ya̱ jíín táká‑ro̱ jíná'an‑ró.
\v 17 Ruu̱, Pablo, áchí‑ri̱ ja̱ ná sándéé iní‑ro̱ te cháa nda'a máá‑rí, chi ya̱'á‑ni kúu ɨɨn tuni̱ ja̱ chísó‑rí nuu̱ táká‑ni carta‑ri̱. Chi̱ súan cháa‑ri̱.
\v 18 Tu̱'un luu íó ini̱ máá Jíto'o̱‑yo̱ Jesucristo ná kóo jíín táká róó jíná'an‑ró. Súan ná kóo. Amén.
