\p
\v 5  \w I|strong="H3588"\w* said, “Too bad \w for|strong="H3588"\w* \w me|strong="H7200"\w*! \w I|strong="H3588"\w* \w am|strong="H3068"\w* \w destroyed|strong="H1820"\w*, \w for|strong="H3588"\w* \w my|strong="H3068"\w* \w lips|strong="H8193"\w* \w are|strong="H5971"\w* contaminated \w by|strong="H3068"\w* sin, \w and|strong="H3068"\w* \w I|strong="H3588"\w* \w live|strong="H3427"\w* \w among|strong="H8432"\w* \w people|strong="H5971"\w* whose \w lips|strong="H8193"\w* \w are|strong="H5971"\w* contaminated \w by|strong="H3068"\w* sin. \w My|strong="H3068"\w* \w eyes|strong="H5869"\w* \w have|strong="H3068"\w* \w seen|strong="H7200"\w* \w the|strong="H7200"\w* \w king|strong="H4428"\w*, \w the|strong="H7200"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w who|strong="H5971"\w* commands \w armies|strong="H6635"\w*.”  
