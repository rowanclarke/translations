\id PSA - Biblica® Open Luganda Contemporary Bible 2014
\h Zabbuli
\toc1 Zabbuli
\toc2 Zabbuli
\toc3 Zab
\mt1 Zabbuli
\c 1
\ms1 EKITABO I
\mr Zabbuli 1–41
\cl Zabbuli 1
\q1 
\v 1 Alina omukisa omuntu
\q2 atatambulira mu kuteesa kw’ababi,
\q1 era atayimirira mu kibiina ky’ababi,
\q2 newaakubadde okutuula n’abo abanyooma ebya Katonda.
\q1 
\v 2 Naye asanyukira okugondera amateeka ga \nd Mukama\nd*,
\q2 era mu mateeka ago mw’alowooleza emisana n’ekiro.
\q1 
\v 3 Afaanana ng’omuti ogwasimbibwa ku mabbali g’omugga,
\q2 ogubala ebibala byagwo mu ntuuko zaabyo,
\q1 n’ebikoola byagwo tebiwotoka.
\q2 Na buli ky’akola kivaamu birungi byereere.
\b
\q1 
\v 4 Naye abakola ebibi tebakola bwe batyo.
\q2 Bali ng’ebisusunku ebifuumuuliddwa.
\q1 
\v 5 Noolwekyo abakola ebibi tebaligumira lunaku lwa kusalirako musango;
\q2 newaakubadde aboonoonyi okuyimirira mu kibiina ky’abatuukirivu.
\b
\q1 
\v 6 Kubanga \nd Mukama\nd* alabirira ekkubo ly’abatuukirivu,
\q2 naye ekkubo ly’abakola ebibi liribula.
\c 2
\cl Zabbuli 2
\q1 
\v 1 Lwaki amawanga geegugunga
\q2 n’abantu ne bateganira obwereere okusala enkwe?
\q1 
\v 2 Bakabaka ab’ensi bakuŋŋaanye,
\q2 n’abafuzi ne bateeseza wamu
\q1 ku \nd Mukama\nd*
\q2 ne ku Kristo we, nga bagamba nti,
\q1 
\v 3 “Ka tukutule enjegere zaabwe,
\q2 era tweyambulemu ekikoligo kyabwe.”
\b
\q1 
\v 4 Naye Katonda oyo atuula mu ggulu,
\q2 abasekerera busekerezi, n’enkwe zaabwe ezitaliimu zimusesa.
\q1 
\v 5 N’alyoka abanenya ng’ajjudde obusungu,
\q2 n’abatiisa nnyo ng’aswakidde.
\q1 
\v 6 N’abagamba nti, “Ddala ddala nateekawo kabaka owange
\q2 ku lusozi lwange Sayuuni olutukuvu.”
\p 
\v 7 Nzija kulangirira ekiragiro kya \nd Mukama\nd*:
\q1 kubanga yaŋŋamba nti, “Ggwe oli Mwana wange,
\q2 olwa leero nfuuse kitaawo.
\q1 
\v 8 Nsaba,
\q2 nange ndikuwa amawanga gonna okuba obusika bwo,
\q2 era n’ensi yonna gy’ekoma okuba amatwale go.
\q1 
\v 9 Olibafugisa omuggo ogw’ekyuma,
\q2 era olibabetenta ng’entamu y’omubumbi.”
\b
\q1 
\v 10 Kale nno mubeere n’amagezi mmwe bakabaka;
\q2 muyige okulabulwa mmwe abafuzi b’ensi.
\q1 
\v 11 Muweereze \nd Mukama\nd* nga mumutya,
\q2 era musanyuke n’okukankana.
\q1 
\v 12 Mwanirize Omwana, mumusembeze \nd Mukama\nd* aleme okubasunguwalira
\q2 n’okubazikiriza nga muli mu kkubo lyammwe;
\q1 kubanga obusungu bwe bubuubuuka mangu.
\q2 Kyokka bonna abaddukira gy’ali balina omukisa.
\c 3
\cl Zabbuli 3
\d Zabbuli ya Dawudi bwe yadduka mutabani we Abusaalomu.
\q1 
\v 1 Ayi \nd Mukama\nd*, abalabe bange nga beeyongedde obungi!
\q2 Abanfubutukiddeko okunnumba nga bangi!
\q1 
\v 2 Bangi abanjogerako nti,
\q2 “Katonda tagenda kumununula.”
\b
\q1 
\v 3 Naye ggwe, Ayi \nd Mukama\nd*, ggwe ngabo yange enkuuma;
\q2 ggwe kitiibwa kyange, era gw’onzizaamu amaanyi.
\q1 
\v 4 Nkoowoola \nd Mukama\nd* n’eddoboozi ery’omwanguka,
\q2 n’annyanukula ng’asinziira ku lusozi lwe olutukuvu.
\b
\q1 
\v 5 Ngalamira ne neebaka, era ne nzuukuka bulungi,
\q2 kubanga \nd Mukama\nd* ye ampanirira.
\q1 
\v 6 Siityenga enkumi n’enkumi z’abalabe bange
\q2 abanneetoolodde, okunnumba.
\b
\q1 
\v 7 Golokoka, Ayi \nd Mukama\nd*,
\q2 ondokole Ayi Katonda wange
\q1 okube abalabe bange bonna
\q2 omenye oluba lw’abakola ebibi.
\b
\q1 
\v 8 Obulokozi buva gy’oli, Ayi \nd Mukama\nd*.
\q2 Emikisa gyo gibeerenga ku bantu bo.
\c 4
\cl Zabbuli 4
\d Ya mukulu wa Bayimbi. Eyimbibwa n’ebivuga eby’enkoba. Zabbuli ya Dawudi.
\q1 
\v 1 Bwe nkukoowoola onnyanukule,
\q2 Ayi Katonda wange omutuukirivu.
\q1 Bwe mba mu nnaku, onnyambe.
\q2 Onkwatirwe ekisa owulire okusaba kwange.
\b
\q1 
\v 2 Mmwe abaana b’abantu, mulituusa wa okuswazanga ekitiibwa kyange?
\q2 Mulituusa ddi okugoberera okwagala ebitaliimu, n’okunoonya eby’obulimba?
\q1 
\v 3 Naye mutegeere nga \nd Mukama\nd* yeerondeddemu abo abamugondera.
\q2 Bwe nnaamukoowoolanga anampuliranga era anannyanukulanga.
\b
\q1 
\v 4 Ne bwe munyiiga ennyo, temusaana kwonoona; musiriikirire,
\q2 mwekebere era mufumiitirize mu mitima gyammwe nga mugalamidde ku bitanda byammwe.
\q1 
\v 5 Muweeyo ebiweebwayo ebisaanidde;
\q2 era mwesigenga \nd Mukama\nd*.
\b
\q1 
\v 6 Waliwo bangi abasaba nti, “Oyongere okutulaga ebirungi, Ayi \nd Mukama\nd*,
\q2 otumulisize omusana gw’amaaso go.”
\q1 
\v 7 Ondeetedde essanyu lingi mu mutima gwange
\q2 erisinga ne lye bafuna mu makungula nga batunuulira ku bibala byabwe ebingi.
\b
\q1 
\v 8 Nnaagalamira ne nneebaka mirembe;
\q2 kubanga ggwe wekka, Ayi \nd Mukama\nd*,
\q2 ggwe ondabirira akabi ne katantuukako.
\c 5
\cl Zabbuli 5
\d Ya mukulu wa Bayimbi. Ya ndere. Zabbuli ya Dawudi.
\q1 
\v 1 Otege okutu eri ebigambo byange, Ayi \nd Mukama\nd*;
\q2 olowooze ku kunyolwa kwange.
\q1 
\v 2 Wuliriza eddoboozi ly’omulanga gwange,
\q2 Ayi Kabaka wange era Katonda wange:
\q2 kubanga ggwe gwe nsaba.
\b
\q1 
\v 3 Ayi \nd Mukama\nd*, buli nkya owulira eddoboozi lyange;
\q2 buli nkya ndeeta gy’oli okusaba kwange,
\q2 ne nnindirira onziremu.
\q1 
\v 4 Kubanga ggwe Ayi Katonda, tosanyukira bibi:
\q2 n’ebitasaana tobigumiikiriza.
\q1 
\v 5 Ab’amalala era abakola ebibi tobeetaaga mu maaso go:
\q2 kubanga okyawa abakola ebibi bonna.
\q1 
\v 6 Abalimba bonna obazikiriza;
\q2 \nd Mukama\nd* akyawa abatemu
\q2 era n’abalimba.
\q1 
\v 7 Naye olw’ekisa kyo ekingi,
\q2 nze nnaayingiranga mu nnyumba yo:
\q1 ne nkusinziza mu Yeekaalu yo Entukuvu
\q2 n’okutya okungi.
\b
\q1 
\v 8 Onkulembere, Ayi \nd Mukama\nd*, mu butuukirivu bwo,
\q2 olw’abalabe bange,
\q2 ondage ekkubo eggolokofu ery’okutambulirangamu.
\q1 
\v 9 Abalabe bange bye boogera tebyesigibwa;
\q2 emitima gyabwe gijjudde bussi bwereere.
\q1 Emimiro gyabwe ntaana eyasaamiridde:
\q2 akamwa kaabwe koogera bya bulimba.
\q1 
\v 10 Basalire omusango gubasinge, Ayi Katonda;
\q2 baleke bagwe mu mitego gyabwe.
\q1 Bagobe
\q2 kubanga baakujeemera.
\q1 
\v 11 Naye leka abo bonna abakwesiga basanyukenga;
\q2 ennaku zonna bayimbenga n’essanyu,
\q1 obakuumenga,
\q2 abo abaagala erinnya lyo basanyukirenga mu ggwe.
\b
\q1 
\v 12 Kubanga, Ayi \nd Mukama\nd*, omutuukirivu omuwa omukisa;
\q2 era omukuuma, n’omwetoolooza okwagala ng’engabo.
\c 6
\cl Zabbuli 6
\d Eri Omukulu wa Bayimbi. Eyimbibwa n’ebivuga eby’enkoba. Zabbuli ya Dawudi.
\q1 
\v 1 Ayi \nd Mukama\nd*, tonnenya ng’ojjudde obusungu;
\q2 so tombonereza mu kiruyi kyo.
\q1 
\v 2 Onsaasire, Ayi \nd Mukama\nd*, kubanga ndi munafu.
\q2 Omponye, Ayi \nd Mukama\nd*, kubanga amagumba gange gali mu bulumi.
\q1 
\v 3 Emmeeme yange ejjudde ennaku.
\q2 Olirindirira kutuusa ddi olyoke onnyambe?
\b
\q1 
\v 4 Onkyukire, Ayi \nd Mukama\nd*, olokole omwoyo gwange;
\q2 omponye okufa olw’okwagala kwo okungi.
\q1 
\v 5 Kubanga tewali ayinza kukujjukira ng’amaze okufa.
\q2 Ani alikutendereza ng’asinziira emagombe?
\b
\q1 
\v 6 Mpweddemu amaanyi olw’okusinda.
\b
\q1 Buli kiro obuliri bwange bujjula amaziga gange
\q2 n’omutto ne gutoba.
\q1 
\v 7 Amaaso gange ganafuye olw’okunyolwa,
\q2 tegakyalaba bulungi olw’abalabe bange.
\b
\q1 
\v 8 Muve we ndi mmwe mwenna abakola ebibi;
\q2 kubanga \nd Mukama\nd* awulidde okukaaba kwange.
\q1 
\v 9 \nd Mukama\nd* awulidde okwegayirira kwange,
\q2 n’okusaba kwange akukkirizza.
\q1 
\v 10 Abalabe bange bonna baliswazibwa era balitya nnyo;
\q2 bazzibwe emabega nga bajjudde obuswavu mangu ago.
\c 7
\cl Zabbuli 7
\d Zabbuli ya Dawudi gye yayimbira \nd Mukama\nd* ng’efa ku Kuusi Omubenyamini.
\q1 
\v 1 Ayi \nd Mukama\nd*, Katonda wange, neesiga ggwe:
\q2 ngobaako bonna abangigganya era omponye,
\q1 
\v 2 si kulwa nga bantagulataagula ng’empologoma
\q2 ne bankutulakutula obufiififi ne watabaawo amponya.
\b
\q1 
\v 3 Ayi \nd Mukama\nd*, Katonda wange, obanga nkoze kino,
\q2 era ng’engalo zange ziriko omusango,
\q1 
\v 4 obanga waliwo andaze ebirungi nze ne si muyisa bulungi,
\q2 oba nzibye omulabe wange awatali nsonga:
\q1 
\v 5 Kale, abalabe bange baleke bangoberere bankwate,
\q2 bankube wansi banninnyirire,
\q2 banzitire mu nfuufu.
\b
\q1 
\v 6 Golokoka, Ayi \nd Mukama\nd*, mu busungu bwo oziyize abalabe bange abajjudde obukambwe.
\q2 Golokoka, Ayi Katonda wange,
\q2 onnyambe ggwe asala omusango mu bwenkanya.
\q1 
\v 7 Kuŋŋaanya bannaggwanga bonna okukwetooloola;
\q2 obafuge ng’oli waggulu ennyo.
\q2 
\v 8 Ggwe, Ayi \nd Mukama\nd*, Ali Waggulu Ennyo,
\q2 asalira amawanga gonna emisango,
\q1 osale omusango gwange Ayi \nd Mukama\nd* Ali Waggulu Ennyo ng’obutuukirivu bwange bwe buli,
\q2 era n’amazima agali mu nze bwe gali.
\q1 
\v 9 Ayi Katonda omutukuvu,
\q2 akebera emitima n’emmeeme;
\q1 okomye ebikolwa by’abakola ebibi:
\q2 era onyweze abatuukirivu.
\b
\q1 
\v 10 Katonda Ali Waggulu Ennyo ye ngabo yange;
\q2 alokola abo abalina omutima omulongoofu.
\q1 
\v 11 Katonda mulamuzi wa mazima;
\q2 era alaga ekiruyi kye buli lunaku.
\q1 
\v 12 \nd Mukama\nd* awagala ekitala kye
\q2 n’aleega omutego gwe
\q2 ogw’obusaale.
\q1 
\v 13 Era ategese ebyokulwanyisa ebissi;
\q2 era akozesa obusaale obw’omuliro.
\b
\q1 
\v 14 Omuntu ajjudde ebibi afuna emitawaana,
\q2 n’azaala obulimba.
\q1 
\v 15 Asima ekinnya, n’akiwanvuya nnyo;
\q2 ate n’akigwamu ye kye yasimye.
\q1 
\v 16 Emitawaana gye gimwebunguludde;
\q2 n’obukambwe bwe bumuddire.
\b
\q1 
\v 17 Nneebazanga \nd Mukama\nd* olw’obutuukirivu bwe;
\q2 nnaayimbanga nga ntendereza erinnya lya \nd Mukama\nd* Ali Waggulu Ennyo.
\c 8
\cl Zabbuli 8
\d Ya Mukulu wa Bayimbi. Zabbuli ya Dawudi.
\q1 
\v 1 Ayi \nd Mukama\nd*, Mukama waffe,
\q2 erinnya lyo nga ddungi era kkulu nnyo mu nsi yonna!
\b
\q1 Ekitiibwa kyo kitenderezebwa
\q2 okutuuka waggulu mu ggulu.
\q1 
\v 2 Abaana abato n’abawere
\q2 wabawa amaanyi okukutendereza;
\q1 ne basirisa omulabe wo
\q2 n’oyo ayagala okwesasuza.
\q1 
\v 3 Bwe ntunuulira eggulu lyo,
\q2 omulimu gw’engalo zo,
\q1 omwezi n’emmunyeenye
\q2 bye watonda;
\q1 
\v 4 omuntu kye ki ggwe okumujjukira,
\q2 omuntu obuntu ggwe okumussaako omwoyo?
\b
\q1 
\v 5 Kubanga wamukola n’abulako katono okuba nga Katonda;
\q2 n’omussaako engule ey’obukulu n’ekitiibwa.
\q1 
\v 6 Wamukwasa okufuga ebintu byonna bye wakola n’emikono gyo:
\q2 byonna wabissa wansi w’ebigere bye,
\q1 
\v 7 ebisibo n’amagana ag’ebisolo byonna eby’omu nsiko,
\q1 
\v 8 n’ennyonyi ez’omu bbanga,
\q2 n’ebyennyanja eby’omu nnyanja;
\q2 era na buli kiramu kyonna ekiyita mu nnyanja.
\b
\q1 
\v 9 Ayi \nd Mukama\nd*, Mukama waffe, erinnya lyo nga ddungi
\q2 era kkulu nnyo mu nsi yonna!
\c 9
\cl Zabbuli 9\f + \fr 9 \ft Kiyinza okuba nga Zabbuli 9 ne 10 zaali kitontome kimu, kubanga mu kukyusa okwasookera ddala ziwandiikibbwa nga Zabbuli emu\f*
\d Ya Mukulu wa Bayimbi. Eyimbibwa okujjukira Okufa kw’Omwana. Zabbuli ya Dawudi.
\q1 
\v 1 Nnaakutenderezanga, Ayi \nd Mukama\nd* n’omutima gwange gwonna;
\q2 nnaayolesanga ebikolwa byo eby’ekitalo byonna.
\q1 
\v 2 Nnaasanyukanga era nnaajagulizanga mu ggwe.
\q2 Nnaayimbanga nga ntendereza erinnya lyo, Ayi \nd Mukama\nd* Ali Waggulu Ennyo.
\b
\q1 
\v 3 Abalabe bange bazzeeyo emabega,
\q2 beesittadde ne bazikiririra mu maaso go.
\q1 
\v 4 Kubanga owagidde ebiŋŋwanira, n’ensonga zange;
\q2 era otudde ku ntebe yo ey’obwakabaka n’osala omusango mu bwenkanya.
\q1 
\v 5 Waboggolera amawanga, n’ozikiriza ababi;
\q2 erinnya lyabwe n’olisangulirawo ddala emirembe n’emirembe.
\q1 
\v 6 Abalabe obamaliddewo ddala,
\q2 n’ebibuga byabwe obizikirizza,
\q2 era tewali aliddayo kubijjukira.
\b
\q1 
\v 7 Naye \nd Mukama\nd* afuga emirembe gyonna;
\q2 era ataddewo entebe ye ey’okusalirako emisango.
\q1 
\v 8 Aliramula ensi mu butuukirivu,
\q2 era alisalira abantu bonna emisango mu bwenkanya.
\q1 
\v 9 \nd Mukama\nd* kye kiddukiro ky’abo abanyigirizibwa;
\q2 era kye kigo kyabwe mu biseera eby’akabi.
\q1 
\v 10 Abo abamanyi erinnya lyo, Ayi \nd Mukama\nd*, banaakwesiganga;
\q2 kubanga abakunoonya tobaleka bokka.
\b
\q1 
\v 11 Muyimbe okutendereza \nd Mukama\nd*, atudde ku ntebe ey’obwakabaka mu Sayuuni;
\q2 mutegeeze amawanga gonna by’akoze.
\q1 
\v 12 Ajjukira n’awoolera eggwanga
\q2 era assaayo omwoyo eri abo abanyigirizibwa.
\b
\q1 
\v 13 Onsaasire, Ayi \nd Mukama\nd*; otunuulire abalabe bange abangigganya,
\q2 onzigye ku miryango gy’okufa.
\q1 
\v 14 Ndyoke nkutenderezenga mu lwatu
\q2 mu miryango\f + \fr 9:14 \ft Ensonga enkulu zonna zaateesebwangako mu mulyango gw’ekibuga.\f* gy’omuwala wa Sayuuni:
\q2 era njagulizenga mu bulokozi bwo.
\b
\q1 
\v 15 Abantu mu mawanga bagudde mu binnya bye baasima;
\q2 era n’emitego gyabwe gimasuse ne gibakwasa.
\q1 
\v 16 \nd Mukama\nd* yeeraze nga bw’asala emisango egy’ensonga.
\q2 Omubi akwatiddwa mu mutego gw’emikono gye.
\q1 
\v 17 Ababi balisuulibwa emagombe;
\q2 ebyo bye bituuka ku mawanga gonna ageerabira Katonda.
\q1 
\v 18 Kubanga abali mu kwetaaga tebalyerabirwa ennaku zonna,
\q2 era n’ababonyaabonyezebwa tebaliggwaamu ssuubi emirembe gyonna.
\b
\q1 
\v 19 Ogolokoke, Ayi \nd Mukama\nd*, tokkiriza muntu kuwangula;
\q2 leka amawanga gasalirwe omusango mu maaso go.
\q1 
\v 20 Bakankanye n’okutya, Ayi \nd Mukama\nd*;
\q2 amawanga gonna galyoke gategeere nti bantu buntu.
\c 10
\cl Zabbuli 10
\q1 
\v 1 Lwaki otwekwese, Ayi \nd Mukama\nd*?
\q2 Lwaki otwekwese mu biseera eby’emitawaana?
\b
\q1 
\v 2 Omubi, mu malala ge, ayigganya abanafu;
\q2 muleke agwe mu nkwe ezo z’asaze.
\q1 
\v 3 Kubanga omubi yeewaana ng’anyumya ku bibi ebiri mu mutima gwe,
\q2 agabula aboomululu n’avuma \nd Mukama\nd*.
\q1 
\v 4 Omubi mu malala ge
\q2 tanoonya Katonda.
\q1 
\v 5 Buli ky’akola kimugendera bulungi.
\q2 Amateeka go tagafaako,
\q2 era n’abalabe be abanyooma.
\q1 
\v 6 Ayogera mu mutima gwe nti, “Sikangibwa,
\q2 nzija kusanyuka emirembe gyonna.”
\b
\q1 
\v 7 Mu kamwa ke mujjudde okukolima n’obulimba awamu n’okutiisatiisa;
\q2 ebigambo bye bya mutawaana era bibi.
\q1 
\v 8 Yeekukuma mu byalo
\q2 okutemula abantu abataliiko musango.
\q2 Yeekweka ng’aliimisa b’anatta.
\q1 
\v 9 Asooba mu kyama ng’empologoma,
\q2 ng’alindirira okuzinduukiriza abateesobola.
\q2 Abakwasa n’abatwalira mu kitimba kye.
\q1 
\v 10 B’abonyaabonya bagwa wansi
\q2 ne babetentebwa ng’amaanyi g’omubi gabasukkiridde.
\q1 
\v 11 Ayogera mu mutima gwe nti, “Katonda yeerabidde, amaaso ge agakwese,
\q2 era takyaddayo kubiraba.”
\b
\q1 
\v 12 Golokoka, Ayi \nd Mukama\nd*, ozikirize omubi, Ayi Katonda;
\q2 abanaku tobeerabiranga.
\q1 
\v 13 Omuntu omubi ayinza atya okukunyooma, Ayi Katonda,
\q2 n’agamba mu mutima gwe nti
\q2 “Sigenda kwennyonnyolako?”
\q1 
\v 14 Naye ggwe, Ayi Katonda, ennaku zaabwe n’okubonaabona kwabwe obiraba
\q2 era ojja kubikolako.
\q1 Ateesobola yeewaayo mu mikono gyo,
\q2 kubanga gwe mubeezi w’abatalina bakitaabwe.
\q1 
\v 15 Malawo amaanyi g’omwonoonyi,
\q2 muyite abyogere ebyo
\q2 ebibadde bitajja kuzuulwa.
\b
\q1 
\v 16 \nd Mukama\nd* ye Kabaka emirembe n’emirembe.
\q2 Amawanga galizikirizibwa mu nsi ye.
\q1 
\v 17 \nd Mukama\nd* awulira okwetaaga kw’ababonyaabonyezebwa, ogumye emitima gyabwe;
\q2 otege okutu kwo obaanukule.
\q1 
\v 18 Olwanirira abataliiko bakitaabwe n’abajoogebwa;
\q2 omuntu obuntu ow’oku nsi n’ataddayo kubatiisa.
\c 11
\cl Zabbuli 11
\d Ya Mukulu wa Bayimbi. Zabbuli ya Dawudi.
\q1 
\v 1 Mu \nd Mukama\nd* mwe neekweka;
\q2 ate muyinza mutya okuŋŋamba nti,
\q2 “Ddukira ku nsozi ng’ebinyonyi?
\q1 
\v 2 Kubanga laba ababi baleega emitego gyabwe
\q2 egy’obusaale,
\q1 balase abalina omutima
\q2 omulongoofu.
\q1 
\v 3 Emisingi nga gizikirizibwa,
\q2 omutuukirivu ayinza kukola ki?”
\b
\q1 
\v 4 \nd Mukama\nd* ali mu Yeekaalu ye entukuvu;
\q2 \nd Mukama\nd* atudde ku ntebe ye ey’obwakabaka eri mu ggulu.
\q1 Amaaso ge gatunuulira
\q2 era geetegereza abaana b’abantu.
\q1 
\v 5 \nd Mukama\nd* akebera abatuukirivu
\q2 naye omutima gwe gukyawa ababi,
\q2 n’abakola eby’obukambwe.
\q1 
\v 6 Ababi alibayiwako
\q2 amanda ag’omuliro;
\q2 n’empewo ezibambula gwe guliba omugabo gwabwe.
\b
\q1 
\v 7 Kubanga \nd Mukama\nd* mutuukirivu
\q2 era ayagala eby’obutuukirivu;
\q2 abo abalongoofu be balimulaba.
\c 12
\cl Zabbuli 12
\d Ya Mukulu wa Bayimbi. Zabbuli ya Dawudi.
\q1 
\v 1 Tuyambe, Ayi \nd Mukama\nd*, kubanga tewakyali n’omu amanyi Katonda;
\q2 abantu abeesigwa bonna baweddewo.
\q1 
\v 2 Buli muntu alimba munne;
\q2 akamwa kaabwe akawaana koogera bya bulimba.
\b
\q1 
\v 3 \nd Mukama\nd*, osirise akamwa k’abo bonna abeewaanawaana,
\q2 na buli lulimi olwenyumiriza;
\q1 
\v 4 nga boogera nti, “Tujja kuwangula n’olulimi lwaffe, era tufune byonna bye twetaaga n’akamwa kaffe,
\q2 kubanga ani alitukuba ku mukono.”
\b
\q1 
\v 5 \nd Mukama\nd* ayogera nti, “Olw’okujoogebwa kw’abanafu,
\q2 n’olw’okusinda kw’abali mu bwetaavu,
\q1 nnaasituka kaakano
\q2 ne nnwanirira abo abalumbibwa.”
\q1 
\v 6 Ebigambo bya \nd Mukama\nd* bya bwesigwa era bya mazima.
\q2 Bigeraageranyizibwa n’effeeza
\q2 erongoosebbwa obulungi emirundi musanvu mu kyoto eky’ebbumba.
\b
\q1 
\v 7 Ayi \nd Mukama\nd*, tukwesiga ng’onootukuumanga,
\q2 n’otuwonya abantu abali ng’abo emirembe gyonna.
\q1 
\v 8 Ababi beeyisaayisa
\q2 nga bagulumiza ebitaliimu nsa.
\c 13
\cl Zabbuli 13
\d Ya Mukulu wa Bayimbi. Zabbuli ya Dawudi.
\q1 
\v 1 Olinneerabira kutuusa ddi, Ayi \nd Mukama\nd*? Okutuusa emirembe gyonna?
\q2 Olikomya ddi okunkweka amaaso go?
\q1 
\v 2 Okulumwa mu mmeeme yange kulikoma ddi,
\q2 n’okunyolwa okwa buli lunaku mu mutima gwange kuliggwaamu ddi?
\q2 Abalabe bange balikomya ddi okumpangulanga nga beegulumiza?
\b
\q1 
\v 3 Onnyanukule, Ayi \nd Mukama\nd* Katonda wange;
\q2 onzizeemu amaanyi nneme okufa.
\q1 
\v 4 Si kulwa ng’omulabe wange yeewaana nti, “Mmuwangudde;”
\q2 abalabe bange ne bajaguza nga ngudde.
\b
\q1 
\v 5 Naye nze neesiga okwagala kwo okutajjulukuka;
\q2 era omutima gwange gunaasanyukiranga mu bulokozi bwo.
\q1 
\v 6 Nnaayimbiranga \nd Mukama\nd*,
\q2 kubanga ankoledde ebirungi.
\c 14
\cl Zabbuli 14
\d Ya Mukulu wa Bayimbi. Zabbuli ya Dawudi.
\q1 
\v 1 Omusirusiru ayogera mu mutima gwe nti,
\q2 “Tewali Katonda.”
\q1 Aboogera bwe batyo boonoonefu,
\q2 bakola ebitasaana tekuli n’omu ku bo akola kirungi.
\b
\q1 
\v 2 \nd Mukama\nd* atunuulira abantu bonna mu nsi
\q2 ng’asinziira mu ggulu,
\q1 okulaba obanga mulimu mu bo ategeera,
\q2 era abanoonya Katonda.
\q1 
\v 3 Naye bonna bakyamye
\q2 boonoonese;
\q1 teri akola kirungi,
\q2 era teri n’omu.
\b
\q1 
\v 4 Abo bonna abakola ebibi tebaliyiga?
\q2 Kubanga basaanyaawo abantu bange ng’abalya emmere;
\q2 so tebakoowoola \nd Mukama\nd*.
\q1 
\v 5 Balitya nnyo!
\q2 Kubanga Katonda abeera wamu n’abatuukirivu.
\q1 
\v 6 Mulemesa entegeka z’omwavu,
\q2 songa \nd Mukama\nd* kye kiddukiro kye.
\b
\q1 
\v 7 Singa obulokozi bwa Isirayiri butuuse mu kiseera kino nga buva mu Sayuuni!
\q2 \nd Mukama\nd* bw’alirokola abantu be,
\q2 Yakobo alijaguza ne Isirayiri alisanyuka.
\c 15
\cl Zabbuli 15
\d Zabbuli ya Dawudi.
\q1 
\v 1 Ayi \nd Mukama\nd*, ani anaabeeranga mu nnyumba yo?
\q2 Ani anaatuulanga ku lusozi lwo olutukuvu?
\b
\q1 
\v 2 Oyo ataliiko kya kunenyezebwa,
\q2 akola eby’obutuukirivu,
\q1 era ayogera eby’amazima nga biviira ddala mu mutima gwe.
\q2 
\v 3 Olulimi lwe talwogeza bya bulimba,
\q1 era mikwano gye tagiyisa bubi,
\q2 so tasaasaanya ŋŋambo ku baliraanwa be.
\q1 
\v 4 Anyooma ababi,
\q2 naye abatya \nd Mukama\nd* abassaamu ekitiibwa.
\q1 Atuukiriza ky’asuubiza
\q2 ne bwe kiba nga kimulumya.
\q1 
\v 5 Bw’awola tasaba magoba;
\q2 so takkiriza kulya nguzi ku muntu yenna.
\b
\q1 Oyo akola ebyo
\q2 aliba munywevu emirembe gyonna.
\c 16
\cl Zabbuli 16
\d Ya Dawudi.
\q1 
\v 1 Onkuume, Ayi Katonda,
\q2 kubanga ggwe buddukiro bwange.
\b
\q1 
\v 2 Nagamba \nd Mukama\nd* nti, “Ggwe Mukama wange,
\q2 ebirungi byonna bye nnina biva gy’oli.”
\q1 
\v 3 Abatukuvu abali mu nsi be njagala
\q2 era mu bo mwe nsanyukira.
\q1 
\v 4 Ennaku y’abo abagoberera bakatonda abalala
\q2 yeeyongera.
\q1 Siriwaayo ssaddaaka zaabwe ez’omusaayi,\f + \fr 16:4 \ft Ssaddaaka ez’omusaayi zaaweebwangayo mu kusinza balubaale, era yali mpisa y’abo abaasinzanga balubaale. Empisa eyo, omuwandiisi wa Zabbuli gyavumirira\f*
\q2 wadde okusinza bakatonda baabwe.
\b
\q1 
\v 5 \nd Mukama\nd*, ggwe mugabo gwange,
\q2 era ggw’oliisa obulamu bwange; era ggw’olabirira ebyange.
\q1 
\v 6 Ensalo zange ziri mu bifo ebisanyusa,
\q2 ddala ddala omugabo omulungi.
\b
\q1 
\v 7 Nnaatenderezanga \nd Mukama\nd* kubanga annuŋŋamya
\q2 ne mu kiro ayigiriza omutima gwange.
\q1 
\v 8 Nkulembeza \nd Mukama\nd* buli kiseera,
\q2 era ali ku mukono gwange ogwa ddyo,
\q2 siinyeenyezebwenga.
\b
\q1 
\v 9 Noolwekyo omutima gwange gusanyuka, n’akamwa kange ne kajaguza;
\q2 era n’omubiri gwange gunaabeeranga mu mirembe.
\q1 
\v 10 Kubanga omwoyo gwange toliguleka magombe,
\q2 wadde okukkiriza Omutukuvu wo okuvunda.
\q1 
\v 11 Olindaga ekkubo ery’obulamu;
\q2 w’oli we wanaabanga essanyu erijjuvu,
\q2 era mu mukono gwo ogwa ddyo nga mwe muli ebisanyusa emirembe gyonna.
\c 17
\cl Zabbuli 17
\d Okusaba kwa Dawudi.
\q1 
\v 1 Wulira, Ayi \nd Mukama\nd*, okukoowoola kwange nga nneegayirira,
\q2 wuliriza okukaaba kwange.
\q1 Tega okutu owulirize okukoowoola kwange,
\q2 kubanga tekuva ku mimwa gya bulimba.
\q1 
\v 2 Nzigyako omusango;
\q2 kubanga olaba ekituufu.
\b
\q1 
\v 3 Weekenneenyezza omutima gwange era n’onkebera n’ekiro.
\q2 Ne bw’onongezesa toobeeko kibi ky’onsangamu;
\q2 kubanga mmaliridde obutayogeranga bya bulimba.
\q1 
\v 4 Ggwe, gwe nkoowoola,
\q2 ngoberedde ebigambo by’akamwa ko,
\q1 ne neewala
\q2 ebikolwa by’abantu abakambwe.
\q1 
\v 5 Nnyweredde mu makubo go,
\q2 era ebigere byange tebiigalekenga.
\b
\q1 
\v 6 Nkukoowoola, Ayi Katonda, kubanga mmanyi ng’onnyanukula;
\q2 ontegere okutu kwo owulire okusaba kwange.
\q1 
\v 7 Ndaga okwagala kwo okutaggwaawo, okwewuunyisa,
\q2 ggwe alokola n’omukono gwo ogwa ddyo
\q2 abo bonna abakweyuna nga badduka abalabe baabwe.
\q1 
\v 8 Onkuume ng’emmunye ey’eriiso lyo; onkweke mu kisiikirize ky’ebiwaawaatiro byo.
\q1 
\v 9 Omponye ababi abannumba,
\q2 n’abalabe bange abanneetoolodde.
\b
\q1 
\v 10 Omutima gwabwe mukakanyavu,
\q2 n’akamwa kaabwe koogera by’amalala.
\q1 
\v 11 Banzingizza era banneetoolodde;
\q2 bansimbye amaaso nga beeteeseteese okunsuula wansi.
\q1 
\v 12 Bali ng’empologoma enjala gy’eruma eyeeteeseteese okutaagula omuyiggo gwayo
\q2 era ng’empologoma enkulu eteeze.
\b
\q1 
\v 13 Golokoka n’ekitala kyo, Ayi \nd Mukama\nd*,
\q2 oyolekere abalabe bange obawangule, omponye ababi abo.
\q1 
\v 14 Ayi \nd Mukama\nd*, mponya abantu,
\q2 abantu ab’ensi n’omukono gwo, kubanga balowooleza mu bya bulamu buno byokka, n’emigabo gyabwe giri mu nsi.
\b
\q1 Embuto zaabwe zigezze,
\q2 obagaggawazizza ne baterekera n’abaana baabwe
\q2 ne bazzukulu baabwe.
\q1 
\v 15 Nze ndikulaba n’amaaso mu butuukirivu
\q2 era ndimatira, bwe ndiraba obwenyi bwo nga nzuukuse.
\c 18
\cl Zabbuli 18
\d Ya Mukulu wa Bayimbi. Zabbuli ya Dawudi gye yayimbira \nd Mukama\nd* bwe yamuwonya abalabe be ne Sawulo.
\q1 
\v 1 Nkwagala Ayi \nd Mukama\nd* kubanga ggwe maanyi gange.
\b
\q1 
\v 2 \nd Mukama\nd* lwe lwazi lwange, ky’ekigo kyange ekigumu era ye mununuzi wange,
\q2 ye Katonda wange era lwe lwazi lwange mwe neekweka;
\q2 ye ngabo yange era ye mulokozi wange ow’amaanyi, era kye kigo kyange ekinywevu.
\q1 
\v 3 Nkoowoola \nd Mukama\nd* asaana okutenderezebwa,
\q2 era amponya eri abalabe bange.
\b
\q1 
\v 4 Emiguwa gy’okufa gyanneetooloola;
\q2 embuyaga ez’okusaanawo zansaanikira.
\q1 
\v 5 Ebisiba eby’amagombe byanneetooloola;
\q2 n’emitego gy’okufa ne ginjolekera.
\q1 
\v 6 Mu nnaku yange nakoowoola \nd Mukama\nd*;
\q2 ne nkaabirira Katonda wange annyambe.
\q1 Yawulira eddoboozi lyange ng’ali mu yeekaalu ye;
\q2 omulanga gwange ne gutuuka mu matu ge.
\b
\q1 
\v 7 Emisingi gy’ensi ne gikankana ne giyuuguuma;
\q2 ensozi ne zinyeenyezebwa ne ziseeseetuka,
\q2 kubanga yali asunguwadde.
\q1 
\v 8 Omukka ne gunyooka nga guva mu nnyindo ze.
\q2 Omuliro ne guva mu kamwa ke,
\q2 ne gukoleeza amanda ne gabuubuuka.
\q1 
\v 9 Yayabuluza eggulu n’akka wansi;
\q2 ebire ebikutte nga biri wansi w’ebigere bye.
\q1 
\v 10 Yeebagala kerubi n’abuuka,\f + \fr 18:10 \ft Bakerubi batonde ba Katonda era babeera mu kitiibwa kye. Be balabirira Entebe ey’Obwakabaka ey’Obwakatonda.\f*
\q2 n’aseeyeeyeza ku biwaawaatiro by’empewo.
\q1 
\v 11 Yafuula ekizikiza ekyamwetooloolanga
\q2 okuba enkuufiira ey’ebire ebijjudde amazzi.
\q1 
\v 12 Okumasamasa okwali mu maaso ge ne kuva mu bire bye,
\q2 n’okumyansa kw’eggulu n’omuzira.
\q1 
\v 13 \nd Mukama\nd* yabwatuka ng’asinziira mu ggulu; oyo Ali Waggulu Ennyo yayogera;
\q2 mu kamwa ke ne muvaamu omuzira n’okumyansa kw’eggulu.
\q1 
\v 14 Yalasa obusaale bwe n’asaasaanya abalabe;
\q2 n’okumyansa okw’eggulu n’abawangula.
\q1 
\v 15 Ebiwonvu eby’omu nnyanja ne bibikkulwa
\q2 n’emisingi gy’ensi ne gyeyerula
\q1 olw’okunenya kwo Ayi \nd Mukama\nd*
\q2 n’olw’okubwatuka kw’omukka ogw’omu nnyindo zo.
\b
\q1 
\v 16 \nd Mukama\nd* yagolola omukono gwe ng’ali waggulu,
\q2 n’ankwata n’annyinyulula mu mazzi amangi.
\q1 
\v 17 Yamponya abalabe bange ab’amaanyi,
\q2 abankyawa, abo abaali bansinza amaanyi.
\q1 
\v 18 Bannumba nga ndi mu buzibu,
\q2 naye \nd Mukama\nd* n’annyamba.
\q1 
\v 19 N’antwala mu kifo ekigazi n’amponya,
\q2 kubanga yansanyukira nnyo.
\q1 
\v 20 \nd Mukama\nd* ankoledde ng’obutuukirivu bwange bwe buli,
\q2 ansasudde ng’ebikolwa byange ebirungi bwe biri.
\q1 
\v 21 Kubanga ntambulidde mu makubo ga \nd Mukama\nd*,
\q2 ne sikola kibi eri Katonda wange.
\q1 
\v 22 Ddala ddala amateeka ga \nd Mukama\nd* gonna ngagondedde,
\q2 era ne siva ku biragiro bye.
\q1 
\v 23 Sisobyanga mu maaso ge
\q2 era nneekuuma obutayonoona.
\q1 
\v 24 Noolwekyo, \nd Mukama\nd* ansasudde ng’obutuukirivu bwange bwe buli,
\q2 era ng’ebikolwa byange ebirungi bwe biri by’alaba.
\b
\q1 
\v 25 Eri omwesigwa weeraga ng’oli mwesigwa,
\q2 n’eri atalina musango weeraga nga tolina musango.
\q1 
\v 26 Eri abalongoofu weeraga ng’oli mulongoofu,
\q2 n’eri abakyamu weeraga ng’obasinza amagezi.
\q1 
\v 27 Owonya abawombeefu,
\q2 naye abeegulumiza obakkakkanya.
\q1 
\v 28 Okoleezezza ettaala yange;
\q2 Ayi \nd Mukama\nd* Katonda wange, ekizikiza kyange okimulisizza.
\q1 
\v 29 Bwe mbeera naawe nsobola okulumba abalabe bange;
\q2 nga ndi ne Katonda wange nsobola okuwalampa bbugwe.
\b
\q1 
\v 30 Katonda byonna by’akola bigolokofu;
\q2 \nd Mukama\nd* ky’asuubiza akituukiriza;
\q1 era bwe buddukiro
\q2 bw’abo bonna abamwekwekamu.
\q1 
\v 31 Kale, ani Katonda, wabula \nd Mukama\nd*?
\q2 Era ani Lwazi, wabula Katonda waffe?
\q1 
\v 32 Oyo ye Katonda ampa amaanyi era aluŋŋamya ekkubo lyange.
\q1 
\v 33 Ebigere byange abinyweza ng’eby’empeewo,
\q2 n’ansobozesa okuyimirira ku ntikko z’ensozi.
\q1 
\v 34 Anjigiriza okulwana entalo,
\q2 ne nsobola n’okuleega omutego ogw’obusaale ogw’ekikomo.
\q1 
\v 35 Ompadde obulokozi bwo okuba engabo yange;
\q2 era ompaniridde n’omukono gwo ogwa ddyo;
\q2 weetoowazizza n’ongulumiza.
\q1 
\v 36 Ongaziyirizza ekkubo ebigere byange we biyita,
\q2 obukongovvule bwange ne butanuuka.
\b
\q1 
\v 37 Nagoba abalabe bange embiro,
\q2 ne mbakwata ne sidda mabega okutuusa nga mbazikirizza.
\q1 
\v 38 Nababetenta ne batasobola na kugolokoka,
\q2 ne mbalinnyako ebigere byange.
\q1 
\v 39 Ompadde amaanyi ag’okulwana;
\q2 abalabe bange ne banvuunamira.
\q1 
\v 40 Okyusizza abalabe bange ne bankuba amabega ne badduka,
\q2 ne ndyoka nsanyaawo abo bonna abankyawa.
\q1 
\v 41 Baalaajana naye tewaali yabawonya;
\q2 ne bakaabirira \nd Mukama\nd*, naye n’atabaddamu.
\q1 
\v 42 Ne mbamerengula ng’enfuufu empewo gy’efuumuula;
\q2 ne mbasammula eri ng’ebisooto by’omu luguudo.
\b
\q1 
\v 43 Omponyezza obulumbaganyi bw’abantu;
\q2 n’onfuula omufuzi w’amawanga.
\q2 Abantu be nnali simanyi ne bafuuka abaweereza bange.
\q1 
\v 44 Olumpulira ne baŋŋondera,
\q2 bannamawanga ne bajugumira mu maaso gange.
\q1 
\v 45 Bannamawanga baggwaamu omutima
\q2 ne bava mu bigo byabwe nga bakankana.
\q1 
\v 46 \nd Mukama\nd* mulamu! Atenderezebwe, Olwazi lwange;
\q2 era agulumizibwe Katonda w’obulokozi bwange.
\q1 
\v 47 Ye Katonda, asasula ku lwange abankola obubi
\q2 era akakkanya amawanga ne ngafuga.
\q2 Amponyeza abalabe bange.
\q1 
\v 48 Ayi \nd Mukama\nd*, ongulumizizza okusinga abalabe bange,
\q2 n’onkuuma abakambwe ne batankwatako.
\q1 
\v 49 Noolwekyo, Ayi \nd Mukama\nd*, nnaakutenderezanga mu mawanga,
\q2 era nnaayimbanga nga ntendereza erinnya lyo.
\q1 
\v 50 Awa kabaka obuwanguzi obw’amaanyi,
\q2 amulaga ebyekisa emirembe gyonna oyo gwe yafukako amafuta,
\q2 eri Dawudi n’eri ezzadde lye.
\c 19
\cl Zabbuli 19
\d Ya Mukulu wa Bayimbi. Zabbuli ya Dawudi.
\q1 
\v 1 Eggulu litegeeza ekitiibwa kya Katonda,
\q2 ebbanga ne litegeeza emirimu gy’emikono gye.
\q1 
\v 2 Buli lunaku litegeeza ekitiibwa kye,
\q2 era liraga amagezi ge buli kiro.
\q1 
\v 3 Tewali bigambo oba olulimi olwogerwa,
\q2 era n’eddoboozi lyabyo teriwulikika.
\q1 
\v 4 Naye obubaka bwabyo
\q2 bubunye mu nsi yonna.
\q1 Mu ggulu omwo Katonda mwe yasimbira enjuba eweema.
\q2 
\v 5 Evaayo ng’awasa omugole bw’ava mu nju ye,
\q2 era ng’omuddusi asinga bonna bw’ajjula essanyu ng’agenda mu mpaka.
\q1 
\v 6 Evaayo ku ludda olumu olw’eggulu,
\q2 ne yeetooloola okutuuka ku nkomerero yaalyo,
\q2 era tewali kyekweka bbugumu lyayo.
\b
\q1 
\v 7 Ekiragiro kya \nd Mukama\nd* kirimu byonna,
\q2 era kizzaamu amaanyi mu mwoyo.
\q1 Etteeka lya \nd Mukama\nd* lyesigika,
\q2 ligeziwaza abatalina magezi.
\q1 
\v 8 Okuyigiriza kwa \nd Mukama\nd* kutuufu,
\q2 kusanyusa omutima gw’oyo akugondera.
\q1 Ebiragiro bya \nd Mukama\nd* bimulisiza amaaso,
\q2 bye galaba.
\q1 
\v 9 Okutya \nd Mukama\nd* kirungi,
\q2 era kya mirembe gyonna.
\q1 Ebiragiro bya \nd Mukama\nd* bya bwenkanya,
\q2 era bya butuukirivu ddala.
\q1 
\v 10 Ebyo byonna bisaana okuyaayaanirwa okusinga zaabu,
\q2 okusingira ddala zaabu ennungi ennyo.
\q1 Biwoomerera okusinga omubisi gw’enjuki,
\q2 okusukkirira omubisi gw’enjuki ogutonnya nga guva mu bisenge byagwo.
\q1 
\v 11 Ebyo bye birabula omuddu wo,
\q2 era mu kubigondera muvaamu empeera ennene.
\q1 
\v 12 Ani asobola okulaba ebyonoono bye?
\q2 Onsonyiwe, Ayi \nd Mukama\nd*, ebibi ebinkisiddwa.
\q1 
\v 13 Era omuddu wo omuwonye okukola ebibi ebigenderere,
\q2 bireme kunfuga.
\q1 Bwe ntyo mbeere ng’ataliiko kyakunenyezebwa
\q2 nneme okuzza omusango omunene ogw’ekibi.
\q1 
\v 14 Nsaba ebigambo by’omu kamwa kange, n’okulowooza okw’omu mutima gwange,
\q2 bisiimibwe mu maaso go,
\q2 Ayi \nd Mukama\nd*, Olwazi lwange, era Omununuzi wange.
\c 20
\cl Zabbuli 20
\d Ya Mukulu wa Bayimbi. Zabbuli ya Dawudi.
\q1 
\v 1 \nd Mukama\nd* akwanukulenga ng’oli mu buzibu.
\q2 Erinnya lya Katonda wa Yakobo likukuumenga.
\q1 
\v 2 Akuweerezenga obuyambi obuva mu kifo kye ekitukuvu;
\q2 akudduukirirenga okuva ku lusozi Sayuuni.
\q1 
\v 3 Ajjukirenga ssaddaaka zo zonna z’omuwa,
\q2 era asiimenga ebiweebwayo byo ebyokebwa.
\q1 
\v 4 Akuwenga omutima gwo bye gwetaaga,
\q2 era atuukirizenga by’oteekateeka byonna.
\q1 
\v 5 Tulijaganya olw’obuwanguzi bwo,
\q2 ne tuwuuba ebendera zaffe mu linnya lya Katonda waffe.
\b
\q1 \nd Mukama\nd* akuwenga byonna by’omusaba.
\b
\q1 
\v 6 Kaakano ntegedde nga \nd Mukama\nd* awanguza oyo gwe yafukako amafuta,
\q2 amwanukula ng’amuwa obuwanguzi n’omukono gwe ogwa ddyo,
\q2 ng’asinziira mu ggulu lye ettukuvu.
\q1 
\v 7 Abamu beesiga amagaali, n’abalala beesiga embalaasi,
\q2 naye ffe twesiga erinnya lya \nd Mukama\nd* Katonda waffe.
\q1 
\v 8 Batalantuka ne bagwa wansi ne balemerawo,
\q2 naye ffe tugolokoka ne tuyimirira nga tuli banywevu.
\q1 
\v 9 Ayi \nd Mukama\nd*, lokola kabaka,
\q2 otwanukule bwe tukukoowoola.
\c 21
\cl Zabbuli 21
\d Ya Mukulu wa Bayimbi. Zabbuli ya Dawudi.
\q1 
\v 1 Ayi \nd Mukama\nd*, kabaka ajaguliza mu maanyi go.
\q2 Obuwanguzi bw’omuwadde nga bumuleetedde essanyu lingi!
\b
\q1 
\v 2 Omuwadde omutima gwe bye gwetaaga,
\q2 era buli ky’asabye n’akamwa ke tokimummye.
\q1 
\v 3 Ddala ddala wamwaniriza n’emikisa gyo egijjudde ebirungi,
\q2 n’omutikkira engule eya zaabu omuka ennyo ku mutwe gwe.
\q1 
\v 4 Yakusaba obulamu, era n’obumuwa,
\q2 ennaku ennyingi ez’emirembe n’emirembe.
\q1 
\v 5 Obuwanguzi bwe wamuwa bumuleetedde ekitiibwa kinene.
\q2 Omuwadde ekitiibwa n’oyatiikirira.
\q1 
\v 6 Ddala omuwadde emikisa gyo egy’olubeerera,
\q2 n’omujjuza essanyu ng’oli naye buli kiseera.
\q1 
\v 7 Kubanga kabaka yeesiga \nd Mukama\nd*,
\q2 era olw’okwagala okutaggwaawo okw’oyo Ali Waggulu Ennyo,
\q2 kabaka tagenda kunyeenyezebwa.
\b
\q1 
\v 8 Omukono gwo guliwamba abalabe bo bonna;
\q2 omukono gwo ogwa ddyo gulikwata abo abakukyawa.
\q1 
\v 9 Bw’olirabika, Ayi \nd Mukama\nd*,
\q2 olibasiriiza n’omuliro ng’ogw’omu kyoto ekyengeredde.
\q1 \nd Mukama\nd*, ng’ajjudde obusungu, alibamira bonna,
\q2 era alibamalirawo ddala.
\q1 
\v 10 Olizikiriza ezzadde lyabwe ku nsi,
\q2 n’abaana baabwe bonna n’obamalawo mu baana b’abantu.
\q1 
\v 11 Newaakubadde nga bakusalira enkwe,
\q2 ne bateekateeka ebikolwa ebibi, kyokka tewali kye basobola kutuukiriza.
\q1 
\v 12 Balikyuka ne bakudduka bwe baliraba
\q2 ng’obaleezeemu omutego gwo ogw’obusaale.
\b
\q1 
\v 13 Ogulumizibwenga, Ayi \nd Mukama\nd*, mu maanyi go.
\q2 Tunaayimbanga nga tutendereza obuyinza bwo.
\c 22
\cl Zabbuli 22
\d Ya Mukulu wa Bayimbi. Zabbuli ya Dawudi.
\q1 
\v 1 Katonda wange, Katonda wange, lwaki onjabulidde?
\q2 Lwaki ogaana okunnyamba
\q2 wadde okuwuliriza okwaziirana kwange?
\q1 
\v 2 Ayi Katonda wange, emisana nkukoowoola, naye tonnyanukula;
\q2 n’ekiro bwe ntyo, naye siweerako.
\b
\q1 
\v 3 Songa ggwe Mutukuvu atudde ku Ntebe,
\q2 era ettendo lya Isirayiri yonna.
\q1 
\v 4 Bajjajjaffe baakwesiganga;
\q2 baakwesiga naawe n’obawonya.
\q1 
\v 5 Baakukoowoolanga n’obalokola;
\q2 era baakwesiganga ne batajulirira.
\b
\q1 
\v 6 Naye nze ndi lusiriŋŋanyi, siri muntu;
\q2 abantu bampisaamu amaaso, n’abalala bannyooma.
\q1 
\v 7 Bonna abandaba banduulira,
\q2 era banvuma nga bwe banyeenyeza omutwe nga bagamba nti,
\q1 
\v 8 “Yeesiga \nd Mukama\nd*;
\q2 kale amuwonye.
\q1 Obanga \nd Mukama\nd* amwagala,
\q2 kale nno amulokole!”
\b
\q1 
\v 9 Naye ggwe wanziggya mu lubuto lwa mmange,
\q2 era wampa okukwesiga
\q2 ne mu buto bwange bwonna nga nkyayonka.
\q1 
\v 10 Olwazaalibwa ne nteekebwa mu mikono gyo;
\q2 olwava mu lubuto lwa mmange n’obeera Katonda wange.
\b
\q1 
\v 11 Tobeera wala nange,
\q2 kubanga emitawaana ginsemberedde,
\q2 ate nga tewali mulala n’omu asobola kunnyamba.
\b
\q1 
\v 12 Zisseddume nnyingi zinneetoolodde,
\q2 zisseddume enkambwe ez’e Basani\f + \fr 22:12 \fq Basani \ft kyali kifo ekyali ku luuyi olw’obukiikakkono obw’ebuvanjuba, era kyali kimanyiddwa olw’ente zisseddume ez’amaanyi ate nga nsava.\f* zinzingizizza.
\q1 
\v 13 Banjasamiza akamwa kaabwe
\q2 ng’empologoma bw’ewuluguma ng’etaagulataagula omuyiggo gwayo.
\q1 
\v 14 Ngiyiddwa ng’amazzi,
\q2 n’amagumba gange gasowose mu nnyingo zaago.
\q1 Omutima gwange guli ng’obubaane,
\q2 era gusaanuukidde mu mubiri gwange.
\q1 
\v 15 Amaanyi gampweddemu, gakaze ng’oluggyo;
\q2 n’olulimi lwange lukutte waggulu mu kibuno kyange.
\q2 Ondese awo mu nfuufu ng’omufu.
\b
\q1 
\v 16 Abantu ababi banneetoolodde;
\q2 banneebunguludde ng’embwa ennyingi;
\q2 banfumise ne bawummula ebibatu byange n’ebigere byange.
\q1 
\v 17 Amagumba gansowose nnyinza n’okugabala.
\q2 Abalabe bange bantunuulira nga bannyoomoola.
\q1 
\v 18 Bagabana engoye zange;
\q2 era ekyambalo kyange bakikubira akalulu.
\b
\q1 
\v 19 Naye ggwe, Ayi \nd Mukama\nd*, tobeera wala nange.
\q2 Ggwe, Amaanyi gange, yanguwa okunnyamba!
\q1 
\v 20 Omponye okuttibwa n’ekitala;
\q2 obulamu bwange obw’omuwendo butaase mu maanyi g’embwa!
\q1 
\v 21 Nzigya mu kamwa k’empologoma,
\q2 omponye amayembe g’embogo enkambwe.
\b
\q1 
\v 22 Nnaategezanga ku linnya lyo mu booluganda;
\q2 nnaakutenderezanga mu kibiina ky’abantu.
\q1 
\v 23 Mmwe abatya \nd Mukama\nd*, mumutenderezenga.
\q2 Abaana ba Yakobo mwenna mumugulumizenga;
\q2 era mumussengamu ekitiibwa nga mumutya, mmwe abaana ba Isirayiri mwenna.
\q1 
\v 24 Kubanga tanyooma kwaziirana
\q2 kw’abo abali mu nnaku,
\q1 era tabeekweka,
\q2 wabula abaanukula bwe bamukoowoola.
\b
\q1 
\v 25 Mu ggwe mwe muva ettendo lyange mu kibiina ekinene, ne nkutendereza olw’ebyo by’onkoledde.
\q2 Obweyamo bwange nnaabutuukirizanga mu maaso gaabo abakutya.
\q1 
\v 26 Abaavu banaalyanga ne bakkuta,
\q2 abo abanoonya \nd Mukama\nd* banaamutenderezanga.
\q2 Emitima gyabwe ginaajaguzanga emirembe gyonna.
\b
\q1 
\v 27 Ensi zonna zirijjukira
\q2 ne zikyukira \nd Mukama\nd*,
\q1 ebika byonna eby’amawanga gonna
\q2 birimuvuunamira.
\q1 
\v 28 Kubanga obwakabaka bwonna bwa \nd Mukama\nd*,
\q2 era y’afuga amawanga gonna.
\b
\q1 
\v 29 Abagagga bonna ab’omu nsi balirya embaga, ne bamusinza.
\q2 Bonna abagenda mu nfuufu, balimufukaamirira,
\q2 abatakyali balamu.
\q1 
\v 30 Ezadde lyabwe lirimuweereza;
\q2 abaliddawo balibuulirwa ekigambo kya Mukama.
\q1 
\v 31 N’abo abatannazaalibwa
\q2 balibuulirwa obutuukirivu bwe nti,
\q2 “Ekyo yakikoze.”
\c 23
\cl Zabbuli 23
\d Zabbuli ya Dawudi.
\q1 
\v 1 \nd Mukama\nd* ye Musumba wange, seetaagenga.
\q2 
\v 2 Angalamiza ne mpummulira mu ddundiro ly’omuddo omuto.
\q1 Antwala awali amazzi amateefu.
\q2 
\v 3 Akomyawo emmeeme yange.
\q1 Annuŋŋamya okukola eby’obutuukirivu
\q2 olw’erinnya lye.
\q1 
\v 4 Newaakubadde nga ntambulira mu kiwonvu eky’ekisiikirize eky’olumbe, siritya kabi konna;
\q2 kubanga ggwe oli nange.
\q1 Oluga lwo n’omuggo gwo
\q2 bye binsanyusa.
\b
\q1 
\v 5 Onsosootolera emmere
\q2 abalabe bange nga balaba;
\q1 onsiize amafuta ku mutwe,\f + \fr 23:5 \ft Okusiiga omuntu amafuta ku mutwe, kaali kabonero akalaga nti omugenyi ayanirizibbwa ku mukolo.\f*
\q2 ekikompe kyange kiyiwa.
\q1 
\v 6 Ddala ddala obulungi n’okwagala okutaggwaawo binaagendanga nange
\q2 ennaku zonna ez’obulamu bwange;
\q1 nange nnaabeeranga mu nnyumba ya \nd Mukama\nd*,
\q2 ennaku zonna.
\c 24
\cl Zabbuli 24
\d Zabbuli ya Dawudi.
\q1 
\v 1 Ensi ya \nd Mukama\nd* n’ebigirimu byonna,
\q2 n’ensi zonna n’abo abazibeeramu.
\q1 
\v 2 Kubanga yasimba emisingi gyayo mu nnyanja,
\q2 n’agizimba ku mazzi amangi.
\b
\q1 
\v 3 Alyambuka ku lusozi lwa \nd Mukama\nd* ye afaanana atya?
\q2 Era wa ngeri ki aliyingira n’ayimirira mu nnyumba ye entukuvu?
\q1 
\v 4 Oyo alina omutima omulongoofu, nga n’emikono gye mirongoofu;
\q2 atasinza bakatonda abalala,
\q2 era atalayirira bwereere.
\b
\q1 
\v 5 Oyo \nd Mukama\nd* anaamuwanga omukisa,
\q2 n’obutuukirivu okuva eri Katonda ow’obulokozi bwe.
\q1 
\v 6 Ogwo gwe mulembe gw’abo abakunoonya,
\q2 Ayi Katonda wa Yakobo.
\b
\q1 
\v 7 Mweggulewo, mmwe bawankaaki!
\q2 Muggulwewo, mmwe enzigi ez’edda,
\q2 Kabaka ow’ekitiibwa ayingire.
\q1 
\v 8 Kabaka ow’ekitiibwa ye ani?
\q2 Ye \nd Mukama\nd* ow’amaanyi era ow’obuyinza,
\q2 omuwanguzi mu ntalo.
\q1 
\v 9 Mweggulewo, mmwe bawankaaki,
\q2 muggulwewo mmwe enzigi ez’edda!
\q2 Kabaka ow’ekitiibwa ayingire.
\q1 
\v 10 Kabaka ow’ekitiibwa oyo ye ani?
\q2 \nd Mukama\nd* Ayinzabyonna;
\q2 oyo ye Kabaka ow’ekitiibwa.
\c 25
\cl Zabbuli 25
\d Zabbuli ya Dawudi.
\q1 
\v 1 Eri ggwe, Ayi \nd Mukama\nd*,
\q2 gye ndeeta okusaba kwange.
\b
\q1 
\v 2 Neesiga ggwe, Ayi \nd Mukama\nd*, tondeka kuswala mu maaso g’abalabe bange. Tobaganya kumpangula.
\q1 
\v 3 Ddala ddala abakwesiga tebaajulirirenga,
\q2 naye ab’enkwe baliswazibwa.
\b
\q1 
\v 4 Njigiriza nga bwe nnaakolanga, Ayi \nd Mukama\nd*,
\q2 ondage amakubo go mwe nnaatambuliranga.
\q1 
\v 5 Onjigirizenga okunywerera ku mazima go, era onkulemberenga mu byonna;
\q2 kubanga ggwe Katonda, ow’obulokozi bwange
\q2 era essuubi lyange liri mu ggwe olunaku lwonna.
\q1 
\v 6 Jjukira, Ayi \nd Mukama\nd*, okusaasira kwo okunene, n’okwagala kwo okungi,
\q2 kubanga byava dda.
\q1 
\v 7 Tojjukira bibi byange
\q2 n’obujeemu bwange eby’omu buvubuka bwange.
\q1 Onzijukire, Ayi \nd Mukama\nd*,
\q2 ng’okwagala kwo gye ndi bwe kuli, kubanga oli mulungi.
\b
\q1 
\v 8 \nd Mukama\nd* mulungi, era wa mazima,
\q2 noolwekyo ayigiriza aboonoonyi ekkubo lye.
\q1 
\v 9 Abawombeefu abaluŋŋamya mu kkubo ettuufu
\q2 n’abayigiriza ekkubo lye.
\q1 
\v 10 Amakubo ga \nd Mukama\nd* gonna gajjudde okwagala n’amazima
\q2 eri abo abagondera endagaano ye n’ebiragiro bye.
\q1 
\v 11 Olw’erinnya lyo, Ayi \nd Mukama\nd*,
\q2 onsonyiwe ebibi byange, kubanga bingi.
\b
\q1 
\v 12 Omuntu wa ngeri ki atya Katonda?
\q2 Oyo gw’anaayigirizanga okukwata ekkubo lye yamulondera.
\q1 
\v 13 Obulamu bwe bunajjuzibwanga emikisa gya Katonda,
\q2 era bazzukulu be ensi eriba yaabwe.
\q1 
\v 14 Mikwano gya \nd Mukama\nd* be bo abamugondera;
\q2 anaababikkuliranga ekyama eky’endagaano ye.
\q1 
\v 15 Ntunuulira \nd Mukama\nd* buli kiseera,
\q2 kubanga yekka y’anzigya mu kabi.
\b
\q1 
\v 16 Nkyukira, Ayi \nd Mukama\nd*, onkwatirwe ekisa,
\q2 kubanga nsigadde bw’omu, era ndi munafu.
\q1 
\v 17 Obuyinike bweyongedde mu mutima gwange;
\q2 mponya okweraliikirira kwange.
\q1 
\v 18 Tunuulira ennaku endiko, weetegereze obulumi bwange;
\q2 onzigyeko ebibi byange byonna.
\q1 
\v 19 Laba abalabe bange nga bwe beeyongedde obungi
\q2 n’okunkyawa kwe bankyawamu!
\b
\q1 
\v 20 Labiriranga obulamu bwange, obamponye;
\q2 tondekanga mu buswavu,
\q2 kubanga ggwe kiddukiro kyange.
\q1 
\v 21 Amazima n’obulongoofu bindabirirenga,
\q2 essubi lyange liri mu ggwe.
\b
\q1 
\v 22 Nunula Isirayiri, Ayi Katonda,
\q2 omuwonye emitawaana gye gyonna.
\c 26
\cl Zabbuli 26
\d Zabbuli ya Dawudi.
\q1 
\v 1 Onnejjeereze, Ayi \nd Mukama\nd*,
\q2 kubanga obulamu bwange tebuliiko kya kunenyezebwa;
\q1 nneesiga ggwe, Ayi \nd Mukama\nd*,
\q2 nga sibuusabuusa.
\q1 
\v 2 Neetegereza, Ayi \nd Mukama\nd*, ongezese;
\q2 weekalirize ebiri mu mutima gwange ne mu mmeeme yange.
\q1 
\v 3 Kubanga okwagala kwo kwe kunkulembera,
\q2 era mu mazima go mwe ntambulira.
\b
\q1 
\v 4 Situula na bantu balimba,
\q2 so siteesaganya na bakuusa.
\q1 
\v 5 Nkyawa ekibiina ky’aboonoonyi;
\q2 so situula na bakozi ba bibi.
\q1 
\v 6 Naaba mu ngalo zange okulaga nga bwe sirina misango;\f + \fr 26:6 \ft Okunaaba mu ngalo mu lujjudde, kaali kabonero akalaga ng’omuntu oyo bw’atalina musango\f*
\q2 ne ndyoka nzija ku Kyoto kyo, Ayi \nd Mukama\nd*;
\q1 
\v 7 ne nnyimba oluyimba olw’okwebaza,
\q2 olwogera ku bikolwa byo ebyewuunyisa.
\b
\q1 
\v 8 Ennyumba yo mw’obeera njagala, Ayi \nd Mukama\nd*,
\q2 kye kifo ekijjudde ekitiibwa kyo.
\q1 
\v 9 Tombalira mu boonoonyi,
\q2 wadde mu batemu,
\q1 
\v 10 abakozesa emikono gyabwe okutegeka ebikolwa ebibi,
\q2 era abali b’enguzi.
\q1 
\v 11 Naye nze ntambula nga siriiko kye nnenyezebwa;
\q2 nkwatirwa ekisa, Ayi \nd Mukama\nd*, ondokole.
\b
\q1 
\v 12 Nnyimiridde watereevu.
\q2 Nnaatenderezanga \nd Mukama\nd* mu kibiina ky’abantu ekinene.
\c 27
\cl Zabbuli 27
\d Zabbuli ya Dawudi.
\q1 
\v 1 \nd Mukama\nd* gwe musana gwange n’obulokozi bwange;
\q2 ani gwe nnaatyanga?
\q1 \nd Mukama\nd* ge maanyi ag’obulamu bwange;
\q2 ani asobola okuntiisa?
\b
\q1 
\v 2 Abalabe bange n’abantu ababi bonna
\q2 bwe banannumba nga baagala okunzita,
\q1 baneesittala
\q2 ne bagwa.
\q1 
\v 3 Newaakubadde ng’eggye linaasiisira okunneebungulula,
\q2 omutima gwange teguutyenga;
\q1 olutalo ne bwe lunansitukirangako,
\q2 nnaabanga mugumu.
\b
\q1 
\v 4 Ekintu kimu kye nsaba \nd Mukama\nd*,
\q2 era ekyo kye nnoonya:
\q1 okubeeranga mu nnyumba ya \nd Mukama\nd*
\q2 ennaku zonna ez’obulamu bwange,
\q1 ne ndabanga obulungi bwa \nd Mukama\nd*,
\q2 era ne nsinzizanga mu Yeekaalu ye.
\q1 
\v 5 Kubanga mu biseera eby’obuzibu
\q2 anansuzanga mu nju ye;
\q1 anankwekanga mu weema ye,
\q2 n’ankuumira ku lwazi olugulumivu.
\b
\q1 
\v 6 Olwo ononnyimusanga
\q2 waggulu w’abalabe bange abanneetoolodde.
\q1 Nnaaweerangayo ssaddaaka mu weema ye nga bwe ntendereza n’eddoboozi ery’omwanguka olw’essanyu;
\q2 nnaayimbiranga \nd Mukama\nd* ennyimba ez’okumutenderezanga.
\b
\q1 
\v 7 Wulira eddoboozi lyange, Ayi \nd Mukama\nd*, nga nkukoowoola;
\q2 onkwatirwe ekisa onnyanukule!
\q1 
\v 8 Omutima gwange guwulidde eddoboozi lyo nga lyogera nti, “Munnoonye, munsinze.”
\q2 Omutima gwange ne guddamu nti, “Nnaakunoonyanga, Ayi \nd Mukama\nd*.”
\q1 
\v 9 Tonneekweka,
\q2 so tonyiigira muweereza wo,
\q2 kubanga ggw’obadde omubeezi wange bulijjo.
\q1 Tonneggyaako, so tonsuula,
\q2 Ayi Katonda, Omulokozi wange.
\q1 
\v 10 Kitange ne mmange bwe balindeka,
\q2 \nd Mukama\nd* anandabiriranga.
\q1 
\v 11 Njigiriza, Ayi \nd Mukama\nd*, by’oyagala nkole,
\q2 era onkulembere mu kkubo lyo,
\q2 kubanga abalabe bange banneetoolodde.
\q1 
\v 12 Tompaayo mu balabe bange,
\q2 kubanga abajulizi ab’obulimba bansitukiddeko n’enkwe zaabwe,
\q2 okunkambuwalira.
\b
\q1 
\v 13 Nkyakakasiza ddala
\q2 nga ndiraba obulungi bwa \nd Mukama\nd*
\q2 mu nsi ey’abalamu.
\q1 
\v 14 Lindirira \nd Mukama\nd*.
\q2 Ddamu amaanyi, ogume omwoyo.
\q2 Weewaawo, lindirira \nd Mukama\nd*.
\c 28
\cl Zabbuli 28
\d Zabbuli ya Dawudi.
\q1 
\v 1 Nkukoowoola ggwe, Ayi \nd Mukama\nd*, Olwazi lwange,
\q2 tolema kumpuliriza;
\q1 kubanga bw’onoonsiriikirira
\q2 nzija kuba nga bali abakkirira mu kinnya.
\q1 
\v 2 Owulire eddoboozi ery’okwegayirira kwange,
\q2 nga mpanise emikono gyange
\q1 okwolekera ekifo kyo ekisinga byonna obutukuvu,
\q2 nga nkukaabirira okunnyamba.
\b
\q1 
\v 3 Tontwalira mu boonoonyi,
\q2 abakola ebibi;
\q1 abanyumya obulungi ne bannaabwe,
\q2 so ng’emitima gyabwe gijjudde bukyayi bwerere.
\q1 
\v 4 Basasule ng’ebikolwa byabwe bwe biri,
\q2 n’olw’ebyambyone bye bakoze.
\q1 Basasule olwa byonna emikono gyabwe gye bisobezza,
\q2 obabonereze nga bwe basaanidde.
\b
\q1 
\v 5 Olwokubanga tebafaayo ku mirimu gya \nd Mukama\nd*,
\q2 oba ku ebyo bye yakola n’emikono gye,
\q1 alibazikiririza ddala,
\q2 era talibaddiramu.
\b
\q1 
\v 6 Atenderezebwe \nd Mukama\nd*,
\q2 kubanga awulidde eddoboozi ly’okwegayirira kwange.
\q1 
\v 7 \nd Mukama\nd* ge maanyi gange,
\q2 era ye ngabo yange, ye gwe neesiga.
\q1 Bwe ntyo ne nyambibwa.
\q2 Omutima gwange gunaajaguzanga, ne mmuyimbira ennyimba ez’okumwebazanga.
\b
\q1 
\v 8 \nd Mukama\nd* y’awa abantu be amaanyi,
\q2 era kye kiddukiro eky’obulokozi bw’oyo gwe yafukako amafuta.
\q1 
\v 9 Olokole abantu bo, obawe omukisa abalonde bo.
\q2 Obakulemberenga ng’omusumba, era obawanirirenga emirembe gyonna.
\c 29
\cl Zabbuli 29
\d Zabbuli ya Dawudi.
\q1 
\v 1 Mutendereze \nd Mukama\nd*, mmwe abaana b’ab’amaanyi.
\q2 Mutendereze \nd Mukama\nd* n’ekitiibwa n’amaanyi.
\q1 
\v 2 Mutendereze \nd Mukama\nd* n’ekitiibwa ekisaanira erinnya lye;
\q2 musinze \nd Mukama\nd* mu kitiibwa eky’obutukuvu bwe.
\b
\q1 
\v 3 Eddoboozi lya \nd Mukama\nd* liwulirwa ku mazzi;
\q2 Katonda ow’ekitiibwa abwatuka,
\q2 n’eddoboozi lye ne liwulirwa ku mazzi amangi.
\q1 
\v 4 Eddoboozi lya \nd Mukama\nd* ly’amaanyi;
\q2 eddoboozi lya \nd Mukama\nd* lijjudde ekitiibwa.
\q1 
\v 5 Eddoboozi lya \nd Mukama\nd* limenya emivule;
\q2 \nd Mukama\nd* amenyaamenya emivule gya Lebanooni.
\q1 
\v 6 Aleetera Lebanooni okubuukabuuka ng’akayana,
\q2 ne Siriyooni\f + \fr 29:6 \fq Siriyooni \ft linnya eribbulwa mu bitundu bya Kalumooni. Kalumooni ye yali ensalo ey’omu bukiikakkono obw’ensi ensuubize\f* ng’ennyana y’embogo.
\q1 
\v 7 Eddoboozi lya \nd Mukama\nd*
\q2 libwatukira mu kumyansa.
\q1 
\v 8 Eddoboozi lya \nd Mukama\nd* likankanya eddungu;
\q2 \nd Mukama\nd* akankanya eddungu lya Kadesi.
\q1 
\v 9 Eddoboozi lya \nd Mukama\nd* linyoolanyoola emivule,
\q2 n’emiti mu bibira ne gitasigalako makoola.
\q1 Mu Yeekaalu ye, abantu bonna boogerera waggulu nti, “Ekitiibwa kibe eri \nd Mukama\nd*!”
\b
\q1 
\v 10 \nd Mukama\nd* atuula waggulu w’amataba ku ntebe ye ey’obwakabaka.
\q2 \nd Mukama\nd* ye Kabaka afuga emirembe gyonna.
\q1 
\v 11 \nd Mukama\nd* awa abantu be amaanyi;
\q2 \nd Mukama\nd* awa abantu be emirembe.
\c 30
\cl Zabbuli 30
\d Zabbuli n’Oluyimba. Okuwaayo Yeekaalu. Zabbuli ya Dawudi.
\q1 
\v 1 Nnaakugulumizanga, Ayi \nd Mukama\nd*,
\q2 kubanga wannyimusa;
\q2 n’otoganya balabe bange kunneeyagalirako.
\q1 
\v 2 Ayi \nd Mukama\nd*, nakukaabirira onnyambe,
\q2 n’omponya.
\q1 
\v 3 Ayi \nd Mukama\nd*, omwoyo gwange waguggya emagombe,
\q2 n’omponya ekinnya.
\b
\q1 
\v 4 Muyimbire \nd Mukama\nd* nga mumutendereza, mmwe abatukuvu be;
\q2 mutendereze erinnya lye ettukuvu.
\q1 
\v 5 Kubanga obusungu bwe bwa kiseera buseera,
\q2 naye obulungi bwe bwa mirembe gyonna.
\q1 Amaziga gayinza okubaawo ekiro kyokka
\q2 essanyu ne lijja nga bukedde.
\b
\q1 
\v 6 Bwe namala okunywera
\q2 ne njogera nti, “Sigenda kusiguukululwa.”
\q1 
\v 7 Ayi \nd Mukama\nd*, bwe wanjagala,
\q2 wanyweza olusozi lwange;
\q1 naye bwe wankweka amaaso go
\q2 ne neeraliikirira.
\q1 
\v 8 Ggwe gwe nakoowoola, Ayi \nd Mukama\nd*;
\q2 ne nkukaabirira Mukama, onsaasire.
\q1 
\v 9 “Kingasa ki bwe nzika mu kinnya
\q2 ne nzikirira?
\q1 Enfuufu eneekutenderezanga
\q2 n’etegeeza abantu obwesigwa bwo?
\q1 
\v 10 Mpuliriza, Ayi \nd Mukama\nd*, onsaasire;
\q2 Ayi \nd Mukama\nd*, onnyambe.”
\b
\q1 
\v 11 Ofudde okwaziirana kwange amazina;
\q2 onnyambuddemu ebibukutu, n’onnyambaza essanyu.
\q1 
\v 12 Omutima gwange gulemenga kusirika busirisi, wabula gukuyimbirenga ennyimba ez’okukutenderezanga.
\q2 Ayi \nd Mukama\nd*, Katonda wange, nnaakwebazanga emirembe gyonna.
\c 31
\cl Zabbuli 31
\d Ya Mukulu wa Bayimbi. Zabbuli ya Dawudi.
\q1 
\v 1 Ayi \nd Mukama\nd*, ggwe kiddukiro kyange,
\q2 leka nneme kuswazibwa.
\q2 Ndokola mu butuukirivu bwo.
\q1 
\v 2 Ontegere okutu kwo
\q2 oyanguwe okunziruukirira.
\q1 Beera ekiddukiro kyange eky’olwazi
\q2 era ekigo eky’amaanyi eky’okumponya.
\q1 
\v 3 Nga bw’oli olwazi lwange era ekigo kyange;
\q2 olw’erinnya lyo onkulembebere era onnuŋŋamye.
\q1 
\v 4 Omponye mu mutego gwe banteze;
\q2 kubanga ggwe kiddukiro kyange.
\q1 
\v 5 Nteeka omwoyo gwange mu mikono gyo;
\q2 ondokole, Ayi \nd Mukama\nd*, Katonda ow’amazima.
\b
\q1 
\v 6 Nkyawa abo abeesiga bakatonda abalala;
\q2 nze nneesiga \nd Mukama\nd*.
\q1 
\v 7 Nnaajaguzanga ne nsanyukira mu kwagala kwo,
\q2 kubanga olabye okubonaabona kwange
\q2 era omanyi ennaku endi ku mwoyo.
\q1 
\v 8 Tompaddeeyo mu balabe bange,
\q2 naye otadde ebigere byange mu kifo ekigazi.
\b
\q1 
\v 9 Onsaasire, Ayi \nd Mukama\nd*, kubanga ndi mu nnaku nnyingi;
\q2 amaaso gange gakooye olw’ennaku;
\q2 omwoyo gwange n’omubiri gwange nabyo binafuye olw’obuyinike.
\q1 
\v 10 Obulamu bwange buweddewo olw’obunaku n’emyaka gyange
\q2 ne giggwaawo olw’okusinda.
\q1 Amaanyi gampweddemu olw’okwonoona kwange,
\q2 n’amagumba ganafuye.
\q1 
\v 11 Abalabe bange bonna bansekerera,
\q2 banneetamiddwa.
\q1 Nfuuse ekyenyinyalwa mu mikwano gyange,
\q2 n’abandaba mu kkubo banziruka.
\q1 
\v 12 Nneerabiddwa ng’eyafa edda;
\q2 nfuuse ng’ekibumbe ekyatifu.
\q1 
\v 13 Buli ludda mpulirayo obwama
\q2 nga bangeya;
\q1 bye banteesaako
\q2 nga basala olukwe okunzita.
\b
\q1 
\v 14 Naye nneesiga ggwe, Ayi \nd Mukama\nd*;
\q2 nga njogera nti, “Oli Katonda wange.”
\q1 
\v 15 Entuuko zange ziri mu mikono gyo;
\q2 ondokole mu mikono gy’abalabe bange
\q2 n’abangigganya.
\q1 
\v 16 Amaaso go ogatunuulize omuweereza wo;
\q2 ondokole n’okwagala kwo okutaggwaawo.
\q1 
\v 17 Ayi \nd Mukama\nd* tondeka kuswazibwa,
\q2 kubanga nkukoowoola;
\q1 leka abo ababi baswale,
\q2 era bagalamire emagombe nga basirise.
\q1 
\v 18 Akamwa kaabwe akayogera eby’obulimba
\q2 kasirisibwe,
\q1 kubanga boogera ebitaliimu ku batuukirivu bo,
\q2 nga babyogeza amalala n’okunyooma.
\b
\q1 
\v 19 Obulungi bwo,
\q2 bwe waterekera abo abakutya nga buyitirivu,
\q1 n’obuwa mu lwatu
\q2 abo abaddukira gy’oli.
\q1 
\v 20 Obalabirira n’obawonya enkwe z’abalabe baabwe,
\q2 n’obakuuma bulungi mu nnyumba yo,
\q1 n’ennyombo z’abantu
\q2 ne zitabatuukako.
\b
\q1 
\v 21 \nd Mukama\nd* atenderezebwenga
\q2 kubanga yandaga okwagala kwe okungi,
\q2 bwe nnali mu kibuga kye baali bazingizza.
\q1 
\v 22 Bwe natya ennyo
\q2 ne njogera nti, “Ngobeddwa mu maaso go.”
\q1 Kyokka wampulira nga nkukaabirira
\q2 n’onsaasira.
\b
\q1 
\v 23 Mwagalenga \nd Mukama\nd* abatukuvu be mwenna!
\q2 \nd Mukama\nd* akuuma abo abamwesiga,
\q2 naye ab’amalala ababonereza mu bujjuvu.
\q1 
\v 24 Muddeemu amaanyi mugume omwoyo
\q2 mmwe mwenna abalina essuubi mu \nd Mukama\nd*.
\c 32
\cl Zabbuli 32
\d Zabbuli ya Dawudi.
\q1 
\v 1 Alina omukisa oyo
\q2 asonyiyiddwa ebyonoono bye
\q2 ekibi ne kiggyibwawo.
\q1 
\v 2 Alina omukisa omuntu oyo
\q2 \nd Mukama\nd* gw’atakyabalira kibi kye,
\q2 ne mu mutima gwe nga temuli bukuusa.
\b
\q1 
\v 3 Bwe nasirikiranga ekibi kyange,
\q2 ne nkogga,
\q2 kubanga nasindanga olunaku lwonna.
\q1 
\v 4 Wambonerezanga
\q2 emisana n’ekiro,
\q1 amaanyi ne ganzigwamu
\q2 ng’amazzi bwe gakalira mu kyeya.
\b
\q1 
\v 5 Awo ne nkwatulira ekibi kyange,
\q2 ne sibikkirira kwonoona kwange.
\q1 Ne njogera nti,
\q2 “Leka neenenyeze \nd Mukama\nd* ebibi byange.”
\q1 Bw’otyo n’onsonyiwa,
\q2 n’onziggyako omusango gw’ebibi byange.
\b
\q1 
\v 6 Noolwekyo abaweereza bo bonna abeesigwa
\q2 bakwegayirire ng’okyalabika;
\q1 oluvannyuma ebizibu bwe birijja,
\q2 ng’amazzi ag’amaanyi amangi tebiribatuukako.
\q1 
\v 7 Oli kifo kyange mwe nneekweka,
\q2 ononkuumanga ne situukwako kabi
\q2 era ononneetooloozanga ennyimba ez’obulokozi.
\b
\q1 
\v 8 Nnaakulagiranga era ne nkuyigiriza ekkubo mw’onootambuliranga;
\q2 nnaakuwanga amagezi nga bwe nkulabirira.
\q1 
\v 9 Temubeeranga ng’embalaasi
\q2 oba ennyumbu ezitategeera,
\q1 ze bateekwa okussa ekyuma mu kamwa ekisibwa ku lukoba,
\q2 ziryoke zifugibwe zijje gy’oli.
\q1 
\v 10 Ababi balaba ennaku nnyingi;
\q2 naye abeesiga \nd Mukama\nd* bakuumirwa
\q2 mu kwagala kwe okutaggwaawo.
\b
\q1 
\v 11 Musanyukire mu \nd Mukama\nd* era mujaguze mmwe abatuukirivu,
\q2 era muyimbire waggulu n’essanyu mmwe abalina omutima omulongoofu.
\c 33
\cl Zabbuli 33
\d Zabbuli ya Dawudi.
\q1 
\v 1 Muyimbire \nd Mukama\nd* n’essanyu mmwe abatuukirivu;
\q2 kisaanira abalongoofu okumutenderezanga.
\q1 
\v 2 Mutendereze \nd Mukama\nd* n’ennanga,
\q2 mumukubire ennyimba ku ntongooli ey’enkoba ekkumi.
\q1 
\v 3 Mumuyimbire oluyimba oluggya;
\q2 musune enkoba ze ntongooli n’amagezi nga bwe muyimba mu ddoboozi ery’omwanguka olw’essanyu.
\b
\q1 
\v 4 Kubanga ekigambo kya \nd Mukama\nd* kituufu era kya mazima;
\q2 mwesigwa mu buli ky’akola.
\q1 
\v 5 \nd Mukama\nd* ayagala obutuukirivu n’obwenkanya.
\q2 Ensi ejjudde okwagala kwa \nd Mukama\nd* okutaggwaawo.
\b
\q1 
\v 6 \nd Mukama\nd* yayogera kigambo, eggulu ne likolebwa;
\q2 n’assiza omukka mu kamwa ke eggye lyonna ery’omu ggulu ne litondebwa.
\q1 
\v 7 Yakuŋŋaanya amazzi g’ennyanja mu ntuumu,
\q2 agayanja n’agasibira mu masitoowa gaago.
\q1 
\v 8 Ensi yonna esaana etyenga \nd Mukama\nd*,
\q2 n’abantu ab’omu mawanga gonna bamussengamu ekitiibwa;
\q1 
\v 9 kubanga yayogera bwogezi n’etondebwa,
\q2 n’alagira n’eyimirira nga nywevu.
\b
\q1 
\v 10 \nd Mukama\nd* asansulula enteekateeka y’amawanga;
\q2 alemesa abantu okutuukiriza bye bagenderera.
\q1 
\v 11 Naye enteekateeka za \nd Mukama\nd* zibeerawo nga nywevu emirembe gyonna;
\q2 n’ebigendererwa by’omutima gwe bya lubeerera.
\b
\q1 
\v 12 Lirina omukisa eggwanga eririna Katonda nga ye \nd Mukama\nd* waalyo,
\q2 ng’abantu baalyo yabalonda babeere bantu be.
\q1 
\v 13 \nd Mukama\nd* asinziira mu ggulu
\q2 n’alaba abaana b’abantu bonna;
\q1 
\v 14 asinziira mu kifo kye mw’abeera
\q2 n’alaba abantu bonna abali ku nsi.
\q1 
\v 15 Ye y’ategeka ebirowoozo byabwe bonna
\q2 ne yeetegereza byonna bye bakola.
\b
\q1 
\v 16 Tewali kabaka asobola kuwona olw’obunene bw’eggye lye;
\q2 era tewali mulwanyi ayinza kuwona olw’amaanyi ge amangi.
\q1 
\v 17 Okusuubira embalaasi yokka okukuwanguza olutalo kuteganira bwerere;
\q2 newaakubadde erina amaanyi mangi naye tesobola kulokola.
\q1 
\v 18 Naye amaaso ga \nd Mukama\nd* galabirira abo abamutya;
\q2 abalina essuubi mu kwagala kwe okutaggwaawo,
\q1 
\v 19 abawonya okufa,
\q2 era abawonya enjala.
\b
\q1 
\v 20 Tulindirira \nd Mukama\nd* nga tulina essuubi,
\q2 kubanga ye mubeezi waffe era ye ngabo yaffe.
\q1 
\v 21 Mu ye emitima gyaffe mwe gijaguliza,
\q2 kubanga twesiga erinnya lye ettukuvu.
\q1 
\v 22 Okwagala kwo okutaggwaawo kubeerenga mu ffe,
\q2 Ayi \nd Mukama\nd*, ng’essuubi lyaffe bwe liri mu ggwe.
\c 34
\cl Zabbuli 34
\d Ya Dawudi. Bwe yeefuula okuba omugu w’eddalu mu maaso ga Abimereki, oluvannyuma eyamugoba, era naye n’amuviira.
\q1 
\v 1 Nnaagulumizanga \nd Mukama\nd* buli kiseera,
\q2 akamwa kange kanaamutenderezanga bulijjo.
\q1 
\v 2 Omwoyo gwange guneenyumiririzanga mu \nd Mukama\nd*;
\q2 ababonyaabonyezebwa bawulire bajaguzenga.
\q1 
\v 3 Kale tutendereze \nd Mukama\nd*,
\q2 ffenna tugulumizenga erinnya lye.
\b
\q1 
\v 4 Nanoonya \nd Mukama\nd*, n’annyanukula;
\q2 n’ammalamu okutya kwonna.
\q1 
\v 5 Abamwesiga banajjulanga essanyu,
\q2 era tebaaswalenga.
\q1 
\v 6 Omunaku ono yakoowoola \nd Mukama\nd* n’amwanukula,
\q2 n’amumalako ebyali bimuteganya byonna.
\q1 
\v 7 Malayika wa \nd Mukama\nd* yeebungulula abo abatya \nd Mukama\nd*,
\q2 n’abawonya.
\b
\q1 
\v 8 Mulegeeko mulabe nga \nd Mukama\nd* bw’ali omulungi!
\q2 Balina omukisa abaddukira gy’ali.
\q1 
\v 9 Musseemu \nd Mukama\nd* ekitiibwa mmwe abatukuvu be,
\q2 kubanga abamutya tebaajulenga.
\q1 
\v 10 Empologoma zirumwa enjala ne ziggwaamu amaanyi;
\q2 naye abo abanoonya \nd Mukama\nd*, ebirungi tebiibaggwengako.
\q1 
\v 11 Mujje wano baana bange, mumpulirize;
\q2 mbayigirize okutya \nd Mukama\nd*.
\q1 
\v 12 Oyagala okuwangaala mu bulamu obulungi,
\q2 okuba mu ssanyu emyaka emingi?
\q1 
\v 13 Olulimi lwo lukuumenga luleme okwogera ebitasaana,
\q2 n’akamwa ko kaleme okwogera eby’obulimba.
\q1 
\v 14 Lekeraawo okukola ebibi, okolenga ebirungi;
\q2 noonya emirembe era ogigobererenga.
\b
\q1 
\v 15 Amaaso ga \nd Mukama\nd* gatunuulira abo abatuukirivu,
\q2 n’amatu ge gawulira okukaaba kwabwe.
\q1 
\v 16 \nd Mukama\nd* amaliridde okumalawo abakola ebibi,
\q2 okubasaanyizaawo ddala n’obutaddayo kujjukirwa ku nsi.
\b
\q1 
\v 17 Abatuukirivu bakoowoola \nd Mukama\nd* n’abawulira
\q2 n’abawonya mu byonna ebiba bibateganya.
\q1 
\v 18 \nd Mukama\nd* abeera kumpi n’abalina emitima egimenyese, era alokola abo abalina emyoyo egyennyise.
\b
\q1 
\v 19 Omuntu omutuukirivu ayinza n’okuba n’ebizibu bingi,
\q2 naye byonna \nd Mukama\nd* abimuyisaamu.
\q1 
\v 20 Amagumba ge gonna \nd Mukama\nd* agakuuma,
\q2 ne watabaawo na limu limenyeka.
\b
\q1 
\v 21 Ekibi kiritta abakola ebibi,
\q2 n’abalabe b’abatuukirivu balibonerezebwa.
\q1 
\v 22 \nd Mukama\nd* anunula abaweereza be;
\q2 so tewali n’omu ku abo abaddukira gy’ali alibonerezebwa.
\c 35
\cl Zabbuli 35
\d Zabbuli ya Dawudi.
\q1 
\v 1 Ayi \nd Mukama\nd*, wakanya abo abampakanya,
\q2 lwanyisa abo abannwanyisa.
\q1 
\v 2 Golokoka okwate engabo,
\q2 n’akagabo onziruukirire.
\q1 
\v 3 Galula effumu,
\q2 abangigganya obazibire ekkubo;
\q1 otegeeze omwoyo gwange nti,
\q2 “Nze bulokozi bwo.”
\b
\q1 
\v 4 Abo bonna abannoonya okunzita bajolongebwe
\q2 era baswazibwe;
\q1 abo abateesa okunsanyaawo
\q2 bazzibweyo ennyuma babune emiwabo.
\q1 
\v 5 Babe ng’ebisusunku ebifuumuulibwa empewo,
\q2 malayika wa \nd Mukama\nd* ng’abagoba.
\q1 
\v 6 Ekkubo lyabwe libe lya kizikiza era lijjule obuseerezi, ne malayika wa \nd Mukama\nd* ng’abagoba.
\b
\q1 
\v 7 Nga bwe bantega omutego nga siriiko kye mbakoze,
\q2 ne bansimira n’ekinnya mu kkubo lyange awatali nsonga,
\q1 
\v 8 bazikirizibwe nga tebategedde,
\q2 n’omutego gwe banteze be baba bagugwamu,
\q2 era bagwe ne mu kinnya kiri bazikirire.
\q1 
\v 9 Omwoyo gwange ne gulyoka gujaguliza mu \nd Mukama\nd*,
\q2 ne gusanyukira mu bulokozi bwe.
\q1 
\v 10 Amagumba gange galyogera nti,
\q2 “Ani afaanana nga ggwe, Ayi \nd Mukama\nd*?
\q1 Kubanga abaavu obadduukirira n’obawonya ababasinza amaanyi,
\q2 n’abali mu kwetaaga n’obawonya abanyazi.”
\b
\q1 
\v 11 Abajulizi abakambwe bagolokoka
\q2 ne bambuuza ebintu bye sirinaako kye mmanyi.
\q1 
\v 12 Bwe mbayisa obulungi bo bampisa bubi,
\q2 ne banakuwaza omwoyo gwange.
\q1 
\v 13 So nga bwe baalwala nanakuwala ne nnyambala ebibukutu,
\q2 ne neerumya nga nsiiba, ne nsaba \nd Mukama\nd* nga nkotese omutwe,
\q1 naye okusaba kwange bwe kutaddibwamu,
\q2 
\v 14 ne mbeera mu nnaku
\q2 ng’ankungubagira ow’omukwano
\q1 oba owooluganda nkoteka omutwe gwange mu buyinike
\q2 ng’akaabira nnyina.
\q1 
\v 15 Naye bwe nagwa mu kabi ne beekuŋŋaanya nga basanyuse;
\q2 ne bannumba nga simanyi,
\q2 ne bampayiriza obutata.
\q1 
\v 16 Banduulidde n’ettima ng’abatamanyi Katonda bwe bakola,
\q2 ne bannumira obujiji.
\q1 
\v 17 Ayi Mukama, olituusa ddi ng’otunula butunuzi?
\q2 Nziruukirira nga bannumba, obulamu bwange obuwonye okutaagulwataagulwa,
\q2 obulamu bwange obw’omuwendo eri empologoma zino.
\q1 
\v 18 Nnaakwebalizanga mu lukuŋŋaana olukulu,
\q2 ne nkutenderezanga mu kibiina ky’abantu abangi ennyo.
\q1 
\v 19 Tokkiriza balabe bange kunneeyagalirako,
\q2 abankyawa awatali nsonga;
\q1 abankyayira obwereere
\q2 tobakkiriza kunziimuula.
\q1 
\v 20 Teboogera bya mirembe,
\q2 wabula okuwaayiriza abantu abeetuulidde emirembe mu nsi.
\q1 
\v 21 Banjasamiza akamwa kaabwe ne boogera nti,
\q2 “Leero luno, ky’okoze tukirabye n’amaaso gaffe.”
\b
\q1 
\v 22 Bino byonna obirabye, Ayi \nd Mukama\nd*.
\q2 Noolwekyo tosirika. Tonsuulirira, Ayi Mukama.
\q1 
\v 23 Golokoka ojje onnyambe;
\q2 nnwanirira Ayi Katonda wange era Mukama wange.
\q1 
\v 24 Mu butuukirivu bwo nnejjeereza, Ayi \nd Mukama\nd* Katonda wange,
\q2 tobaganya kunneeyagalirako.
\q1 
\v 25 Tobaleka kulowooza nti, “Leero luno! Kino kye twali twagala!”
\q2 Oba nti, “Tumusaanyizzaawo!”
\b
\q1 
\v 26 Abo bonna abanneeyagalirako olw’ennaku yange ne beesanyusa,
\q2 batabulwetabulwe era baswazibwe;
\q1 abo bonna abanneegulumirizaako
\q2 baswazibwe era banyoomebwe.
\q1 
\v 27 Abo abasanyuka ng’annejjeereza,
\q2 baleekaanire waggulu olw’essanyu n’okujaganya;
\q1 era boogerenga nti, “\nd Mukama\nd* agulumizibwe,
\q2 asanyuka omuweereza we ng’atebenkedde.”
\b
\q1 
\v 28 Olulimi lwange lunaayogeranga ku butuukirivu bwo,
\q2 era nnaakutenderezanga olunaku lwonna.
\c 36
\cl Zabbuli 36
\d Ya Mukulu wa Bayimbi. Zabbuli ya Dawudi.
\q1 
\v 1 Nnina obubaka mu mutima gwange
\q2 obukwata ku bwonoonyi bw’omukozi w’ebibi.
\q1 N’okutya
\q2 tatya Katonda.
\b
\q1 
\v 2 Ye nga bw’alaba yeewaanawaana n’atasobola kutegeera
\q2 oba okukyawa ekibi kye.
\q1 
\v 3 Ebigambo ebiva mu kamwa ke biba bibi era nga bya bulimba;
\q2 takyalina magezi era takyakola birungi.
\q1 
\v 4 Ne ku kitanda kye afumiitiriza ebibi by’anaakola;
\q2 amalirira okutambuliranga mu kkubo ekyamu,
\q2 era ebitali bituufu tabyewala.
\b
\q1 
\v 5 Okwagala kwo, Ayi \nd Mukama\nd*, kutuuka ne ku ggulu;
\q2 obwesigwa bwo butuuka ku bire.
\q1 
\v 6 Obutuukirivu bwo bugulumivu ng’agasozi aganene,
\q2 n’obwenkanya bwo buwanvu nnyo ng’ennyanja ennene ennyo.
\q1 Ayi \nd Mukama\nd*, olabirira abantu n’ebisolo.
\q2 
\v 7 Okwagala kwo okutaggwaawo nga tekugeraageranyizika.
\q1 Ab’ebitiibwa n’abatali ba bitiibwa
\q2 baddukira mu biwaawaatiro byo.
\q1 
\v 8 Balya ku bingi eby’omu nnyumba yo ne bakkuta;
\q2 obawa ebyokunywa by’omugga gwo ogwesiimisa.
\q1 
\v 9 Kubanga gw’olina ensulo ey’obulamu,
\q2 era gw’otwakiza omusana.
\b
\q1 
\v 10 Yongeranga okwagala abo abakutegeera,
\q2 era n’obutuukirivu bwo eri abo abalina emitima emirongoofu.
\q1 
\v 11 Ab’amalala baleme okunninnyirira,
\q2 wadde ababi okunsindiikiriza.
\q1 
\v 12 Laba, ababi nga bwe bagudde!
\q2 Basuuliddwa wansi era tebasobola na ku golokokawo.
\c 37
\cl Zabbuli 37
\d Zabbuli ya Dawudi.
\q1 
\v 1 Teweeraliikiriranga olw’abantu ababi,
\q2 so tokwatirwanga buggya abo abakola ebitasaana.
\q1 
\v 2 Kubanga bagenda kuwotoka ng’omuddo,
\q2 bafiire ddala ng’essubi ekkalu.
\b
\q1 
\v 3 Weesigenga \nd Mukama\nd* okolenga bulungi,
\q2 onoobeeranga n’emirembe mu nsi n’ofuna ebirungi.
\q1 
\v 4 Sanyukiranga mu \nd Mukama\nd*,
\q2 anaakuwanga omutima gwo bye gwetaaga.
\b
\q1 
\v 5 By’okola byonna byesigamyenga ku \nd Mukama\nd*;
\q2 mwesigenga, anaakukoleranga ky’oyagala.
\q1 
\v 6 Anaayolekanga obutuukirivu bwo ng’omusana,
\q2 n’obwenkanya bw’ebikolwa byo ne bwakaayakana ng’enjuba ey’omu ttuntu.
\b
\q1 
\v 7 Siriikirira awali \nd Mukama\nd*,
\q2 ogumiikirize ng’olindirira ky’anaakola.
\q2 Tofangayo ng’abalala bafunye ebirungi nga bayita mu kutetenkanya kwabwe okubi.
\b
\q1 
\v 8 Tonyiiganga era weewale ekiruyi;
\q2 teweeraliikiriranga kubanga bivaamu bibi byereere.
\q1 
\v 9 Kubanga ababi balisalibwako,
\q2 naye abeesiga \nd Mukama\nd* baligabana ensi.
\b
\q1 
\v 10 Wanaayitawo akabanga katono ababi baggweerewo ddala;
\q2 wadde mulibanoonya temulibalabako.
\q1 
\v 11 Naye abateefu baligabana ensi
\q2 ne beeyagalira mu ddembe eritatendeka.
\b
\q1 
\v 12 Ababi basalira abatuukirivu enkwe,
\q2 ne babalumira obujiji.
\q1 
\v 13 Naye Mukama asekerera ababi,
\q2 kubanga amanyi ng’entuuko zaabwe ziri kumpi.
\b
\q1 
\v 14 Ababi basowoddeyo ebitala byabwe
\q2 ne baleega emitego gy’obusaale,
\q1 batte abaavu n’abali mu kwetaaga
\q2 era basaanyeewo abo abatambulira mu kkubo eggolokofu.
\q1 
\v 15 Naye ebitala byabwe birifumita mitima gyabwe gyennyini,
\q2 n’emitego gyabwe egy’obusaale girimenyebwa.
\b
\q1 
\v 16 Ebitono omutuukirivu by’alina
\q2 bisinga obugagga bw’ababi abangi;
\q1 
\v 17 kubanga amaanyi g’abakola ebibi galikoma,
\q2 naye \nd Mukama\nd* anaawaniriranga abatuukirivu.
\b
\q1 
\v 18 Ennaku z’abataliiko kya kunenyezebwa, zimanyibwa \nd Mukama\nd*,
\q2 era omugabo gwabwe gunaabanga gwa lubeerera.
\q1 
\v 19 Mu biseera eby’akabi ebyakatyabaga tebaayongoberenga,
\q2 ne mu biro eby’enjala banakkusibwanga.
\b
\q1 
\v 20 Naye ababi balizikirira;
\q2 abalabe ba \nd Mukama\nd* balifaanana ng’obulungi bwe ttale,
\q2 era baliggwaawo, baliggwaawo ng’omukka.
\b
\q1 
\v 21 Ababi beewola, ne batasasula;
\q2 naye abatuukirivu basaasira era bagaba bingi.
\q1 
\v 22 Abo \nd Mukama\nd* b’awa omukisa baligabana ensi,
\q2 naye abo b’akolimira balizikirizibwa.
\b
\q1 
\v 23 \nd Mukama\nd* bw’asanyukira ekkubo ly’omuntu,
\q2 aluŋŋamya entambula ye.
\q1 
\v 24 Ne bw’aneesittalanga, taagwenga wansi,
\q2 kubanga omukono gwa \nd Mukama\nd* gumuwanirira.
\b
\q1 
\v 25 Nnali muto kati nkaddiye,
\q2 naye sirabanga batuukirivu nga balekeddwa ttayo,
\q2 wadde abaana baabwe nga basabiriza ekyokulya.
\q1 
\v 26 Bagaba bingi bulijjo, era baazika ku byabwe n’essanyu.
\q2 Abaana baabwe banaaweebwanga omukisa.
\b
\q1 
\v 27 Muve mu bibi, mukolenga ebirungi,
\q2 munaabanga balamu emirembe gyonna.
\q1 
\v 28 Kubanga \nd Mukama\nd* ayagala ab’amazima,
\q2 n’abeesigwa be taabaabulirenga.
\q1 Banaalabirirwanga emirembe gyonna;
\q2 naye ezzadde ly’ababi lirizikirizibwa.
\q1 
\v 29 Abatuukirivu baligabana ensi
\q2 ne babeeranga omwo emirembe gyonna.
\b
\q1 
\v 30 Akamwa k’omutuukirivu koogera bya magezi,
\q2 n’olulimi lwe lwogera bya mazima.
\q1 
\v 31 Amateeka ga Katonda we gali mu mutima gwe,
\q2 era ebigere bye tebiseerera.
\b
\q1 
\v 32 Omubi ateega omutuukirivu
\q2 ng’anoonya okumutta,
\q1 
\v 33 naye \nd Mukama\nd* taliganya babi kuwangula,
\q2 wadde okukkiriza abatuukirivu okusingibwa omusango.
\b
\q1 
\v 34 Lindirira \nd Mukama\nd* n’okugumiikiriza,
\q2 otambulirenga mu makubo ge;
\q1 naye alikugulumiza n’akuwa ensi;
\q2 ababi bwe balisalirwako olikitegeera.
\b
\q1 
\v 35 Nalaba omuntu omubi era omukambwe ennyo, naye nga buli ky’akola kimugendera bulungi,
\q2 ng’agimuse ng’omuti ogukulidde mu ttaka eggimu,
\q1 
\v 36 naye teyalwawo n’abula,
\q2 ne mmumagamaga buli wantu, nga talabikako.
\b
\q1 
\v 37 Tunuulira omuntu ataliiko kya kunenyezebwa, wekkaanye oyo omulongoofu;
\q2 obulamu bwe bunajjulanga emirembe.
\q1 
\v 38 Naye aboonoonyi bonna balizikirizibwa;
\q2 ezzadde ly’ababi lirisaanyizibwawo.
\b
\q1 
\v 39 Obulokozi bw’abatuukirivu buva eri \nd Mukama\nd*;
\q2 ye ky’ekigo kyabwe ekinywevu gye baddukira mu kiseera eky’emitawaana.
\q1 
\v 40 \nd Mukama\nd* abayamba n’abalokola;
\q2 abaggya mu mikono gy’ababi n’abalokola,
\q2 kubanga gy’ali gye baddukira.
\c 38
\cl Zabbuli 38
\d Zabbuli ya Dawudi, ey’okujjukiza.
\q1 
\v 1 Ayi \nd Mukama\nd* tonnenya ng’okyaliko obusungu,
\q2 oba okunkangavvula ng’oliko ekiruyi.
\q1 
\v 2 Kubanga obusaale bwo bunfumise,
\q2 n’omuggo gwo gunkubye nnyo.
\q1 
\v 3 Obusungu bwo bundwazizza nzenna,
\q2 n’amagumba gange gonna gansagala olw’ebyonoono byange.
\q1 
\v 4 Omusango gwe nzizizza guyitiridde,
\q2 gunzitoowerera ng’omugugu omunene oguteetikkika.
\b
\q1 
\v 5 Ebiwundu byange bitanye era biwunya,
\q2 olw’okwonoona kwange okw’obusirusiru.
\q1 
\v 6 Nkootakoota era mpweddemu ensa,
\q2 ŋŋenda nsinda obudde okuziba.
\q1 
\v 7 Omugongo gunnuma nnyo,
\q2 ne mu mubiri gwange temukyali bulamu.
\q1 
\v 8 Sikyalimu maanyi era nzenna mmenyesemenyese;
\q2 nsinda buli bbanga olw’obulumi mu mutima.
\b
\q1 
\v 9 Mukama, bye neetaaga byonna obimanyi,
\q2 n’okusinda kwange okuwulira.
\q1 
\v 10 Omutima gumpejjawejja, amaanyi gampweddemu;
\q2 n’okulaba sikyalaba.
\q1 
\v 11 Mikwano gyange ne be nayitanga nabo banneewala olw’amabwa gange;
\q2 ne bannange tebakyansemberera.
\q1 
\v 12 Abaagala okunzita bantega emitego,
\q2 n’abo abangigganya bateesa okummalawo.
\q2 Buli bbanga baba bateesa kunkola kabi.
\b
\q1 
\v 13 Ndi ng’omuggavu w’amatu, atawulira;
\q2 nga kiggala, atayogera.
\q1 
\v 14 Nfuuse ng’omuntu atalina ky’awulira,
\q2 atasobola kwanukula.
\q1 
\v 15 Ddala ddala nnindirira ggwe, Ayi \nd Mukama\nd*,
\q2 onnyanukule, Ayi Mukama Katonda wange.
\q1 
\v 16 Tobakkiriza kunneeyagalirako,
\q2 oba okunneegulumirizaako ng’ekigere kyange kiseeredde.
\b
\q1 
\v 17 Kubanga nsemberedde okugwa,
\q2 era nga nnumwa buli kiseera.
\q1 
\v 18 Ddala ddala njatula ebyonoono byange;
\q2 nnumirizibwa ekibi kyange.
\q1 
\v 19 Abalabe bange bangi era ba maanyi;
\q2 n’abo abankyayira obwereere bangi nnyo.
\q1 
\v 20 Abalabe bange bankyawa olw’okuba omulongoofu,
\q2 era bwe nkola ebirungi banjogerako ebitasaana.
\b
\q1 
\v 21 Ayi \nd Mukama\nd*, tonjabulira;
\q2 tobeera wala nange, Ayi Katonda wange.
\q1 
\v 22 Ayi Mukama Omulokozi wange,
\q2 yanguwa okumbeera.
\c 39
\cl Zabbuli 39
\d Ya Mukulu wa Bayimbi: Ya Yedusuni. Zabbuli ya Dawudi.
\q1 
\v 1 Nagamba nti, “Nneekuumanga mu bye nkola,
\q2 n’olulimi lwange lulemenga okwogera ebitali birongoofu.
\q1 Abakola ebitali bya butuukirivu bwe banaabanga awamu nange
\q2 nnaabuniranga bubunizi ne soogera.”
\q1 
\v 2 Naye bwe nasirika
\q2 ne sibaako kye njogedde wadde ekirungi,
\q2 ate obuyinike bwange ne bweyongera.
\q1 
\v 3 Omutima gwange ne gumbabuukirira munda yange.
\q2 Bwe nnali nkyakifumiitirizaako, omuliro ne gukoleera munda yange;
\q2 kyenava njogera nti:
\b
\q1 
\v 4 “Ayi \nd Mukama\nd*, ntegeeza entuuko zange nga bwe ziriba,
\q2 n’ennaku ze nsigazza;
\q2 ommanyise ebiseera byange mu bulamu buno bwe biri ebimpi ennyo.”
\q1 
\v 5 Ennaku z’obulamu bwange wazitegeka ziri ng’oluta.
\q2 Obungi bw’emyaka gyange tobulabamu kantu.
\q2 Buli muntu, mukka bukka.
\b
\q1 
\v 6 Ddala ddala omuntu ku nsi ali ng’ekisiikirize.
\q2 Atawaana mu kino ne mu kiri, naye byonna butaliimu.
\q2 Akuŋŋaanya obugagga, so nga tamanyi agenda kubutwala.
\b
\q1 
\v 7 Naye kaakano, Ayi Mukama, nnoonya ki? Essuubi lyange liri mu ggwe.
\q1 
\v 8 Ondokole mu bibi byange byonna,
\q2 abasirusiru baleme okunsekerera.
\q1 
\v 9 Nasirika busirisi, saayasamya kamwa kange;
\q2 kubanga kino ggwe wakikola.
\q1 
\v 10 Olekere awo okunkuba,
\q2 emiggo gy’onkubye giyitiridde!
\q1 
\v 11 Onenya omuntu ng’omukangavvula olw’ekibi kye ky’akola,
\q2 omumaliramu ddala ensa, ng’ennyenje bw’ekola olugoye.
\q2 Ddala omuntu mukka bukka.
\b
\q1 
\v 12 Ayi \nd Mukama\nd*, wulira okusaba kwange,
\q2 owulire okukaaba kwange onnyambe.
\q2 Tonsiriikirira nga nkukaabirira.
\q1 Kubanga ndi mugenyi bugenyi, omutambuze,
\q2 nga bajjajjange bonna bwe baali.
\q1 
\v 13 Ndeka nsanyukemu, nga sinnava mu nsi muno,
\q2 ne mbulirawo ddala.
\c 40
\cl Zabbuli 40
\d Ya Mukulu wa Bayimbi. Zabbuli ya Dawudi.
\q1 
\v 1 Nalindirira \nd Mukama\nd* n’obugumiikiriza,
\q2 n’antegera okutu, n’awulira okukoowoola kwange,
\q1 
\v 2 n’anziggya mu kinnya eky’entiisa,
\q2 n’annyinyulula mu bitosi,
\q1 n’anteeka ku lwazi olugumu
\q2 kwe nyimiridde.
\q1 
\v 3 Anjigirizza oluyimba oluggya,
\q2 oluyimba olw’okutenderezanga Katonda waffe.
\q1 Bangi bino balibiraba ne batandika okutya \nd Mukama\nd*
\q2 n’okumwesiganga.
\b
\q1 
\v 4 Balina omukisa
\q2 abo abeesiga \nd Mukama\nd*,
\q1 abatagoberera ba malala
\q2 abasinza bakatonda ab’obulimba.
\q1 
\v 5 Ayi \nd Mukama\nd* Katonda wange,
\q2 otukoledde eby’ewunyisa bingi.
\q1 Ebintu by’otuteekeddeteekedde
\q2 tewali ayinza kubikutegeeza.
\q1 Singa ngezaako okubittottola,
\q2 sisobola kubimalayo byonna olw’obungi bwabyo.
\b
\q1 
\v 6 Ssaddaaka n’ebiweebwayo tewabyagala.
\q2 Ebiweebwayo ebyokebwa olw’okutangirira ebibi,
\q1 tobyetaaga.
\q2 Naye onzigudde amatu.
\q1 
\v 7 Kyenava njogera nti, “Nzuuno,
\q2 nzize nga bwe kyampandiikibwako mu muzingo gw’ekitabo.”
\q1 
\v 8 Nsanyukira okukola ky’oyagala, Ayi Katonda wange,
\q2 kubanga amateeka go gali mu mutima gwange.
\b
\q1 
\v 9 Ntegeeza obutuukirivu mu lukuŋŋaana olunene.
\q2 Sisirika busirisi,
\q2 nga naawe bw’omanyi, Ayi \nd Mukama\nd*.
\q1 
\v 10 Bye mmanyi ku butuukirivu bwo sisirika nabyo mu mutima gwange,
\q2 naye ntegeeza ku bwesigwa bwo n’obulokozi bwo.
\q1 Abantu nga bakuŋŋaanye,
\q2 sirema kubategeeza ku mazima go n’okwagala kwo okungi.
\b
\q1 
\v 11 Onsasirenga bulijjo, Ayi \nd Mukama\nd*,
\q2 amazima n’okwagala kwo byeyongerenga okunkuuma.
\q1 
\v 12 Kubanga ebizibu bye siyinza na kubala binneetoolodde;
\q2 ebibi byange binsukiridde, sikyasobola na kulaba;
\q1 bisinga enviiri ez’oku mutwe gwange obungi,
\q2 mpweddemu amaanyi.
\q1 
\v 13 Onsasire ayi \nd Mukama\nd* ondokole;
\q2 Ayi \nd Mukama\nd*, oyanguwe okumbeera.
\b
\q1 
\v 14 Abo abaagala okunzita batabuketabuke baswale;
\q2 n’abo bonna abagenderera okummalawo bagobebwe nga baswadde.
\q1 
\v 15 Abo abankubira akasonso baswazibwe nnyo.
\q1 
\v 16 Naye abo abakunoonya basanyuke
\q2 era bajaguze;
\q1 abo abaagala obulokozi bwo boogerenga bulijjo nti,
\q2 “\nd Mukama\nd* agulumizibwenga.”
\b
\q1 
\v 17 Ndi mwavu, eyeetaaga ennyo.
\q2 Mukama ondowoozeeko.
\q1 Tolwawo, Ayi Katonda wange.
\q2 Ggwe mubeezi wange era Omulokozi wange.
\c 41
\cl Zabbuli 41
\d Ya Mukulu wa Bayimbi. Zabbuli ya Dawudi.
\q1 
\v 1 Alina omukisa asaasira omunaku;
\q2 \nd Mukama\nd* amulokola ku lunaku olw’akabi.
\q1 
\v 2 \nd Mukama\nd* anaamukuumanga anaawonyanga obulamu bwe,
\q2 era anaamuwanga omukisa mu nsi;
\q2 n’atamuwaayo eri okwegomba kw’abalabe be.
\q1 
\v 3 \nd Mukama\nd* anaamujjanjabanga nga mulwadde;
\q2 n’amuwonya mu bulumi.
\b
\q1 
\v 4 Nayogera nti, “Ayi \nd Mukama\nd* onsaasire omponye; kubanga nnyonoonye mu maaso go.”
\q1 
\v 5 Abalabe bange boogeza obukyayi nti,
\q2 “Alifa ddi n’okwerabirwa ne yeerabirwa?”
\q1 
\v 6 Bwe bajja okundaba beefuula mikwano gyange;
\q2 naye munda yaabwe bankyawa era basanyuka okulaba nga ngalamidde awo nnumwa.
\q2 Bwe bansiibula bagenda beesekera nga bwe baduula.
\b
\q1 
\v 7 Abalabe bange bonna abo bateesa mu kaama;
\q2 nga banjogerako ebitali birungi.
\q1 
\v 8 Boogera nti, “Endwadde emukutte mbi nnyo,
\q2 emukubye wansi tayinza kuwona.”
\q1 
\v 9 Era ne mukwano gwange gwe neesiganga
\q2 bwe twalyanga,
\q2 anneefuukidde.
\b
\q1 
\v 10 Naye ggwe, Ayi \nd Mukama\nd*, onsaasire,
\q2 onzizeemu amaanyi ndyoke nneesasuze.
\q1 
\v 11 Mmanyi ng’onsanyukira,
\q2 kubanga omulabe wange tampangudde.
\q1 
\v 12 Onnywezezza mu bwesimbu bwange,
\q2 ne mbeera mu maaso go ennaku zonna.
\b
\q1 
\v 13 Atenderezebwenga \nd Mukama\nd* Katonda wa Isirayiri,
\q2 oyo eyabaawo okuva edda n’edda lyonna n’okutuusa emirembe gyonna.
\qc Amiina era Amiina.
\c 42
\ms1 EKITABO II
\mr Zabbuli 42–72
\cl Zabbuli 42\f + \fr 42 \ft Mu byawandiikibwa Ebyebbulaniya zabbuli eyo eri emu ne Zabbuli 43\f*
\d Ya Mukulu wa Bayimbi: Zabbuli ya Batabani ba Koola.
\q1 
\v 1 Ng’empeewo bw’ewejjawejja olw’amazzi,
\q2 n’emmeeme yange bw’etyo bwe wejjawejja ku lulwo, Ayi Katonda.
\q1 
\v 2 Emmeeme yange eyaayaanira Katonda, Katonda omulamu.
\q2 Ndigenda ddi ne nsisinkana Katonda?
\q1 
\v 3 Nkaabirira \nd Mukama\nd*
\q2 emisana n’ekiro.
\q1 Amaziga gange gabadde emmere yange emisana n’ekiro,
\q2 abantu ne baŋŋamba nti, “Katonda wo ali ludda wa?”
\q1 
\v 4 Bino mbijjukira nga nfuka emmeeme yange
\q2 nga bwe nagendanga n’ekibiina ekinene,
\q1 ne nkulembera ennyiriri z’abantu empanvu,
\q2 nga tugenda mu nnyumba ya Katonda,
\q1 nga tuyimba mu ddoboozi ery’omwanguka
\q2 n’okwebaza mu kibiina ekijaguza.
\b
\q1 
\v 5 Lwaki oweddemu amaanyi ggwe emmeeme yange?
\q2 Lwaki otabusetabuse mu nda yange?
\q1 Essuubi lyo liteeke mu Katonda,
\q2 kubanga natenderezanga omulokozi wange era Katonda wange;
\q2 ye mubeezi wange.
\b
\q1 
\v 6 Ayi Katonda wange, emmeeme yange yennyise,
\q2 yeeraliikiridde;
\q1 naye nkujjukira olw’ebyo bye wakola mu nsi ya Yoludaani
\q2 ne ku nsozi engulumivu eza Kalumooni\f + \fr 42:6 \fq Kalumooni \ft ye yali ensalo ey’omu bukiikakkono ey’ensi ensuubize\f* ne ku Lusozi Mizali.
\q1 
\v 7 Obuziba bukoowoola obuziba,
\q2 olw’okuwuluguma kw’ebiyiriro
\q1 amayengo n’amasingisira go
\q2 bimpiseeko.
\b
\q1 
\v 8 \nd Mukama\nd* alaga okwagala kwe emisana n’ekiro
\q2 ne muyimbira oluyimba lwe;
\q2 y’essaala eri Katonda w’obulamu bwange.
\b
\q1 
\v 9 Ŋŋamba Katonda, olwazi lwange nti,
\q2 “Lwaki onneerabidde?
\q1 Lwaki ŋŋenda nkungubaga
\q2 olw’okujoogebwa abalabe bange?”
\q1 
\v 10 Mbonyaabonyezebwa ng’abalabe bange
\q2 bancocca,
\q1 nga bwe bagamba buli kiseera nti,
\q2 “Katonda wo ali ludda wa?”
\b
\q1 
\v 11 Lwaki wennyise Ayi ggwe emmeeme yange?
\q2 Lwaki otabusetabuse mu nda yange?
\q1 Weesigenga Katonda,
\q2 kubanga nnaamutenderezanga,
\q2 Omulokozi wange era ye Katonda wange.
\c 43
\cl Zabbuli 43
\q1 
\v 1 Ayi Katonda, onnejjeereze
\q2 omponye eggwanga eritatya Katonda
\q2 ondokole mu mikono gy’abantu abalimba, abakola ebibi.
\q1 
\v 2 Ddala ddala ggwe Katonda, ekigo kyange eky’amaanyi.
\q2 Lwaki ondese?
\q1 Lwaki ŋŋenda nkaaba
\q2 nga nnyigirizibwa omulabe?
\q1 
\v 3 Kale tuma omusana gwo n’amazima
\q2 binnuŋŋamye;
\q1 bindeete ku lusozi lwo olutukuvu,
\q2 mu kifo mw’obeera.
\q1 
\v 4 Ne ndyoka ndaga ku kyoto kya Katonda,
\q2 eri Katonda wange era essanyu lyange eritasingika.
\q1 Weewaawo nnaakutenderezanga n’ennanga,
\q2 Ayi Katonda, Katonda wange.
\b
\q1 
\v 5 Lwaki wennyise ggwe emmeeme yange?
\q2 Lwaki otabusetabuse munda yange?
\q1 Weesige Katonda; kubanga nnaamutenderezanga,
\q2 Omulokozi wange era Katonda wange.
\c 44
\cl Zabbuli 44
\d Ya mukulu wa bayimbi. Zabbuli ya Batabani ba Koola.
\q1 
\v 1 Ayi Katonda, twawulira n’amatu gaffe,
\q2 bajjajjaffe baatubuulira,
\q1 ebyo bye wakola mu biro byabwe,
\q2 mu nnaku ez’edda ezaayita.
\q1 
\v 2 Nga bwe wagoba amawanga mu nsi
\q2 n’ogiwa bajjajjaffe,
\q1 wasaanyaawo amawanga
\q2 n’okulaakulanya bajjajjaffe.
\q1 
\v 3 Ekitala kyabwe si kye kyabaleetera okuwangula ensi,
\q2 n’omukono gwabwe si gwe gwabalokola;
\q1 wabula baawangula n’omukono gwo ogwa ddyo
\q2 awamu n’obulungi bwo, kubanga wabaagala.
\b
\q1 
\v 4 Ggwe oli Kabaka wange, era Katonda wange;
\q2 awa Yakobo obuwanguzi.
\q1 
\v 5 Ku lulwo tunaawangulanga abalabe baffe;
\q2 ku lw’erinnya lyo tunaalinnyiriranga abalabe baffe.
\q1 
\v 6 Ddala ddala omutego gwange ogw’obusaale si gwe neesiga,
\q2 n’ekitala kyange si kye kimpa obuwanguzi.
\q1 
\v 7 Wabula ggwe otulokola mu balabe baffe,
\q2 n’oswaza abo abatuyigganya.
\q1 
\v 8 Twenyumiririza mu Katonda olunaku lwonna.
\q2 Era tunaatenderezanga erinnya lyo emirembe gyonna.
\b
\q1 
\v 9 Naye kaakano otusudde ne tuswala;
\q2 era tokyatabaala na magye gaffe.
\q1 
\v 10 Watuzza emabega okuva mu bifo mwe twali ng’abalabe baffe balaba,
\q2 abatuyigganya ne batunyaga.
\q1 
\v 11 Watuwaayo okuliibwa ng’endiga;
\q2 n’otusaasaanya mu mawanga.
\q1 
\v 12 Watunda abantu bo omuwendo mutono nnyo,
\q2 n’otobaako ky’oganyulwa.
\b
\q1 
\v 13 Watufuula ekivume eri baliraanwa baffe,
\q2 ekinyoomebwa era ekisekererwa abo abatwetoolodde.
\q1 
\v 14 Otufudde ekinyoomebwa mu mawanga gonna;
\q2 era abantu banyeenya emitwe gyabwe.
\q1 
\v 15 Nswazibwa obudde okuziba,
\q2 amaaso gange ne gajjula ensonyi,
\q1 
\v 16 olw’abo abangigganya, abanvuma nga tebandabamu ka buntu,
\q2 olw’omulabe amaliridde okuwoolera eggwanga.
\b
\q1 
\v 17 Ebyo byonna bitutuseeko,
\q2 newaakubadde nga tetukwerabidde,
\q2 wadde obutagondera ndagaano yo.
\q1 
\v 18 Omutima gwaffe tegukuvuddeeko,
\q2 so tetugaanyi kutambulira mu kkubo lyo.
\q1 
\v 19 Naye ggwe otubonerezza n’otulekera emisege,
\q2 n’otuleka mu kizikiza ekikutte.
\b
\q1 
\v 20 Ddala singa twerabira erinnya lya Katonda waffe,
\q2 ne tusinza katonda omulala,
\q1 
\v 21 ekyo Katonda waffe teyandikizudde?
\q2 Kubanga ye amanyi n’ebikisibwa mu mutima.
\q1 
\v 22 Katonda waffe, tetukuvuddeeko, kubanga ku lulwo tuttibwa obudde okuziba,
\q2 era tuli ng’endiga ez’okusalibwa.
\b
\q1 
\v 23 Golokoka Ayi Mukama, lwaki weebase?
\q2 Zuukuka! Totusuula Ayi Mukama!
\q1 
\v 24 Lwaki otwekwese?
\q2 Lwaki tofaayo ku kulumwa kwaffe n’okujoogebwa?
\b
\q1 
\v 25 Ddala ddala tusuuliddwa mu nfuufu;
\q2 tuli ku ttaka.
\q1 
\v 26 Golokoka otuyambe;
\q2 tulokole olw’okwagala kwo okutaggwaawo.
\c 45
\cl Zabbuli 45
\d Ya Mukulu wa Bayimbi. Oluyimba “olw’Amalanga.” Zabbuli ya Batabani ba Koola.
\q1 
\v 1 Omutima gwange gujjudde ebigambo ebirungi
\q2 nga nnyimba oluyimba lwa Kabaka.
\q2 Olulimi lwange kkalaamu y’omuwandiisi omukugu.
\b
\q1 
\v 2 Ggw’osinga abaana b’abantu obulungi;
\q2 n’akamwa ko nga kafukiddwako amafuta ag’ekisa.
\q2 Kubanga Katonda akuwadde omukisa emirembe gyonna.
\b
\q1 
\v 3 Weesibe ekitala kyo, Ayi ggwe ow’amaanyi,
\q2 yambala ekitiibwa kyo n’obukulu bwo!
\q1 
\v 4 Weebagale embalaasi yo mu kitiibwa kyo eky’obuwanguzi,
\q2 ng’olwanirira amazima, obuwombeefu, n’obutuukirivu.
\q2 Omukono gwo ogwa ddyo gukole ebyewuunyisa.
\q1 
\v 5 Obusaale bwo obwogi bufumite emitima gy’abalabe ba kabaka;
\q2 afuge amawanga.
\q1 
\v 6 Entebe yo ey’obwakabaka, Ayi Katonda, ya lubeerera;
\q2 n’omuggo ogw’obwenkanya gwe guliba ogw’obwakabaka bwo.
\q1 
\v 7 Oyagala obutuukirivu n’okyawa okukola ebibi;
\q2 noolwekyo Katonda, Katonda wo, kyavudde akugulumiza
\q2 n’akufukako amafuta ag’essanyu okusinga bakabaka banno bonna.
\q1 
\v 8 Ebyambalo byo birina akawoowo ka mmooli ne alowe, ne kasiya.
\q2 Ebivuga eby’enkoba bikusanyusiza
\q2 mu mbiri zo ez’amasanga.
\q1 
\v 9 Mu bakyala bo mulimu abambejja;
\q2 namasole ali ku mukono gwo ogwa ddyo ng’ayambadde ebya zaabu ya Ofiri.
\b
\q1 
\v 10 Muwala, wuliriza bye nkugamba:
\q2 “Weerabire ab’ewammwe n’ab’omu nnyumba ya kitaawo.
\q1 
\v 11 Kabaka akulowoozaako nnyo, kubanga walungiwa n’oyitirira;
\q2 nga bw’ali mukama wo, muwenga ekitiibwa.”
\q1 
\v 12 Muwala w’e Ttuulo\f + \fr 45:12 \ft Kabaka w’e Tuulo ye kabaka eyasooka okukkiriza enju ya Dawudi okulya entebe ey’obwakabaka bwa Isirayiri. Sulemaani yasigaza omukwano ogwo ne kabaka w’e Tuulo, era Tuulo kyali kibuga ky’aby’amaguzi kikulu ku Nnyanja Ennene eya Meditereniyaani.\f* alijja n’ekirabo,
\q2 abasajja abagagga balikwegayirira obalage ekisa kyo.
\q1 
\v 13 Omuwala wa kabaka ajjudde ekitiibwa mu kisenge kye,
\q2 ng’ayambadde ekyambalo ekyalukibwa ne zaabu.
\q1 
\v 14 Aleetebwa mu maaso ga kabaka ng’ayambadde ebyambalo eby’emidalizo emingi.
\q2 Emperekeze ze zimuwerekerako;
\q2 bonna ne bajja gy’oli.
\q1 
\v 15 Baleetebwa nga bajjudde essanyu n’okweyagala,
\q2 ne bayingira mu lubiri lwa kabaka.
\b
\q1 
\v 16 Batabani bo baliweebwa ebifo bya bajjajjaabwe,
\q2 olibafuula ng’abalangira mu nsi omwo.
\q1 
\v 17 Erinnya lyo linajjukirwanga emirembe gyonna.
\q2 Amawanga kyeganaavanga gakutendereza emirembe n’emirembe.
\c 46
\cl Zabbuli 46
\d Ya Mukulu wa Bayimbi: Zabbuli ya Batabani ba Koola.
\q1 
\v 1 Katonda kye kiddukiro kyaffe, era ge maanyi gaffe;
\q2 omubeezi ddala atabulawo mu kulaba ennaku.
\q1 
\v 2 Kyetunaavanga tulema okutya, ensi ne bw’eneeyuuguumanga,
\q2 ensozi ne bwe zinaasiguulukukanga ne zigwa mu buziba bw’ennyanja;
\q1 
\v 3 amazzi g’ennyanja ne bwe ganaayiranga ne gabimba ejjovu
\q2 ensozi ne zikankana olw’okwetabula kwago.
\b
\q1 
\v 4 Waliwo omugga, emyala gyagwo gisanyusa ekibuga kya Katonda,
\q2 kye kifo ekitukuvu ekya Katonda Ali Waggulu Ennyo.
\q1 
\v 5 Tekirigwa kubanga Katonda mw’abeera.
\q2 Katonda anaakirwaniriranga ng’obudde bunaatera okukya.
\q1 
\v 6 Amawanga geetabula, obwakabaka bugwa;
\q2 ayimusa eddoboozi lye ensi n’esaanuuka.
\b
\q1 
\v 7 \nd Mukama\nd* ow’Eggye ali naffe,
\q2 Katonda wa Yakobo kye kigo kyaffe.
\b
\q1 
\v 8 Mujje, mulabe \nd Mukama\nd* by’akola,
\q2 mulabe nga bw’afaafaaganya ensi.
\q1 
\v 9 Y’akomya entalo mu nsi yonna;
\q2 akutula emitego gy’obusaale, effumu alimenyaamenya;
\q2 amagaali n’engabo abyokya omuliro.
\q1 
\v 10 Musiriikirire mutegeere nga nze Katonda.
\q2 Nnaagulumizibwanga mu mawanga.
\q2 Nnaagulumizibwanga mu nsi.
\b
\q1 
\v 11 Katonda ow’Eggye ali naffe;
\q2 Katonda wa Yakobo kye kigo kyaffe.
\c 47
\cl Zabbuli 47
\d Ya Mukulu wa Bayimbi. Zabbuli ya Batabani ba Koola.
\q1 
\v 1 Mukube mu ngalo mmwe amawanga gonna;
\q2 muyimuse amaloboozi muyimbire nnyo Katonda ennyimba ez’essanyu;
\q1 
\v 2 \nd Mukama\nd* Ali Waggulu Ennyo wa ntiisa.
\q2 Ye Kabaka afuga ensi yonna.
\q1 
\v 3 Yatujeemululira abantu,
\q2 n’atujeemululira amawanga ne tugafuga.
\q1 
\v 4 Yatulondera omugabo gwaffe,
\q2 Yakobo gw’ayagala mwe yeenyumiririza.
\b
\q1 
\v 5 Katonda alinnye waggulu ng’atenderezebwa mu maloboozi ag’essanyu eringi.
\q2 \nd Mukama\nd* alinnye nga n’amakondeere gamuvugira.
\q1 
\v 6 Mutendereze Katonda, mumutendereze.
\q2 Mumutendereze Kabaka waffe, mumutendereze.\f + \fr 47:6 \ft Okutenderezebwa kwakolebwanga ne Siyofa, ejjembe eryafuuyibwanga okulangirira Omwaka Omuggya\f*
\q1 
\v 7 Kubanga Katonda ye Kabaka w’ensi yonna,
\q2 mumutendereze ne Zabbuli ey’ettendo.
\b
\q1 
\v 8 Katonda afuga amawanga gonna;
\q2 afuga amawanga ng’atudde ku ntebe ye entukuvu.
\q1 
\v 9 Abakungu bannaggwanga bakuŋŋanye
\q2 ng’abantu ba Katonda wa Ibulayimu;
\q1 kubanga Katonda y’afuga abakulembeze b’ensi.
\q2 Katonda agulumizibwenga nnyo.
\c 48
\cl Zabbuli 48
\d Oluyimba. Zabbuli ya Batabani ba Koola.
\q1 
\v 1 \nd Mukama\nd* mukulu, asaanira okutenderezebwa ennyo
\q2 mu kibuga kya Katonda waffe, ku lusozi lwe olutukuvu.
\b
\q1 
\v 2 Sayuuni lwe lusozi lwe olulungi olugulumivu,
\q2 olusanyusa ensi yonna.
\q1 Ku ntikko Zafoni kwe kuli
\q2 ekibuga kya Kabaka Omukulu;
\q1 
\v 3 Katonda mw’abeera;
\q2 yeeraze okuba ekigo kye.
\b
\q1 
\v 4 Kale laba, bakabaka b’ensi baakuŋŋaana
\q2 ne bakyolekera bakirumbe;
\q1 
\v 5 bwe baakituukako ne bakyewuunya,
\q2 ne batya nnyo ne badduka;
\q1 
\v 6 nga bakankana,
\q2 ne bajjula obulumi ng’omukazi alumwa okuzaala.
\q1 
\v 7 Wabazikiriza ng’omuyaga ogw’ebuvanjuba
\q2 bwe guzikiriza ebyombo by’e Talusiisi.
\b
\q1 
\v 8 Ebyo bye twawuliranga obuwulizi,
\q2 kaakano tubirabye
\q1 mu kibuga kya \nd Mukama\nd* ow’Eggye,
\q2 mu kibuga kya Katonda waffe,
\q2 kyalinywereza ddala emirembe gyonna.
\b
\q1 
\v 9 Ayi Katonda, tufumiitiriza ku kwagala kwo okutaggwaawo
\q2 nga tuli mu Yeekaalu yo.
\q1 
\v 10 Erinnya lyo nga bwe liri ekkulu, Ayi Katonda,
\q2 bw’otyo bw’otenderezebwa mu nsi yonna.
\q2 Omukono gwo ogwa ddyo gujjudde obuwanguzi.
\q1 
\v 11 Sanyuka gwe Sayuuni,
\q2 musanyuke mmwe ebibuga bya Yuda;
\q2 kubanga Katonda alamula bya nsonga.
\b
\q1 
\v 12 Mutambule mu Sayuuni, mukibune;
\q2 mubale n’ebigo byakyo.
\q1 
\v 13 Mwekalirize nnyo munda wa bbugwe waakyo
\q2 n’olusiisira lw’amaggye lwamu lwonna;
\q2 mulyoke mutegeeze ab’emirembe egiriddawo.
\b
\q1 
\v 14 Kubanga Katonda ono, ye Katonda waffe emirembe gyonna;
\q2 y’anaatuluŋŋamyanga ennaku zonna okutuusa okufa.
\c 49
\cl Zabbuli 49
\d Ya Mukulu wa Bayimbi. Zabbuli ya Batabani ba Koola.
\q1 
\v 1 Muwulire mmwe amawanga gonna,
\q2 mutege amatu mmwe mwenna abali mu nsi.
\q1 
\v 2 Ab’ekitiibwa n’abakopi, abagagga n’abaavu, mwenna;
\q2 muwulirize ebigambo byange.
\q1 
\v 3 Kubanga ebigambo by’omu kamwa kange bya magezi,
\q2 ebiva mu mutima gwange bijjudde okutegeera.
\q1 
\v 4 Nnaakozesanga ebikwata ku ngero,
\q2 nga nnyinnyonnyola amakulu gaazo n’oluyimba ku nnanga.
\b
\q1 
\v 5 Siityenga ne bwe nnaabanga mu buzibu;
\q2 newaakubadde ng’abalabe bange banneetoolodde,
\q1 
\v 6 abantu abeesiga obugagga bwabwe
\q2 beenyumiririza mu bintu ebingi bye balina.
\q1 
\v 7 Ddala ddala, tewali muntu ayinza kununula bulamu bwa munne,
\q2 wadde okwegula okuva eri Katonda.
\q1 
\v 8 Kubanga omuwendo ogununula obulamu munene nnyo,
\q2 tewali n’omu agusobola;
\q1 
\v 9 alyoke awangaale ennaku zonna
\q2 nga tatuuse magombe.
\q1 
\v 10 Kubanga n’abantu abagezi bafa;
\q2 abasirusiru n’abatalina magezi bonna baaggwaawo,
\q2 obugagga bwabwe ne babulekera abalala.
\q1 
\v 11 Entaana zaabwe ge ganaabanga amaka gaabwe ennaku zonna;
\q2 nga bye bisulo ebya buli mulembe oguliddawo;
\q2 baafuna ettaka mu mannya gaabwe.
\b
\q1 
\v 12 Omuntu tabeerera mirembe gyonna, ne bw’aba mugagga atya,
\q2 alifa ng’ensolo bwe zifa.
\b
\q1 
\v 13 Ako ke kabi akatuuka ku beesiga ebitaliimu,
\q2 era ye nkomerero y’abo abeesiga obugagga bwabwe.
\q1 
\v 14 Okufaanana ng’endiga, bateekwa kufa;
\q2 olumbe ne lubalya.
\q1 Bakka butereevu emagombe,
\q2 obulungi bwabwe ne bubula,
\q2 amagombe ne gafuuka amaka gaabwe.
\q1 
\v 15 Naye Katonda alinunula emmeeme yange mu magombe,
\q2 ddala ddala alintwala gy’ali.
\q1 
\v 16 Omuntu bw’agaggawalanga n’ekitiibwa ky’ennyumba ye nga kyeyongedde,
\q2 tomutyanga,
\q1 
\v 17 kubanga bw’alifa taliiko ky’alitwala, wadde n’ekitiibwa kye tekirigenda naye.
\q1 
\v 18 Newaakubadde nga mu bulamu yeerowoozaako ng’aweereddwa omukisa
\q2 kubanga omugagga abantu bamugulumiza,
\q1 
\v 19 kyokka alikka emagombe eri bajjajjaabe,
\q2 n’ayingira mu kizikiza ekikutte.
\b
\q1 
\v 20 Omuntu omugagga naye nga simutegeevu tabeerera mirembe gyonna,
\q2 alizikirira ng’ensolo ez’omu nsiko.
\c 50
\cl Zabbuli 50
\d Zabbuli ya Asafu.
\q1 
\v 1 Oyo Owaamaanyi, \nd Mukama\nd* Katonda,
\q2 akoowoola ensi
\q2 okuva enjuba gy’eva okutuuka gy’egwa.
\q1 
\v 2 Katonda ayakaayakana
\q2 ng’ava mu Sayuuni n’obulungi bw’ekitiibwa kye ekituukiridde.
\q1 
\v 3 Katonda waffe ajja, naye tajja kasirise,
\q2 omuliro ogusaanyaawo buli kintu gwe gumukulembera,
\q2 n’omuyaga ogw’amaanyi ne gumwetooloola.
\q1 
\v 4 Akoowoola abali mu ggulu ne ku nsi,
\q2 azze okusalira abantu be omusango.
\q1 
\v 5 Agamba nti, “Munkuŋŋaanyize abantu bange abaayawulibwa,
\q2 abaakola nange endagaano nga bawaayo ssaddaaka.”
\q1 
\v 6 Eggulu litegeeza obutuukirivu bwa Katonda
\q2 kubanga Katonda yennyini ye mulamuzi.
\b
\q1 
\v 7 “Muwulirize, mmwe abantu bange, nange nnaayogera.
\q2 Ggwe Isirayiri bino bye nkuvunaana:
\q2 Nze Katonda, Katonda wo.
\q1 
\v 8 Sikunenya lwa ssaddaaka zo,
\q2 oba ebiweebwayo ebyokebwa by’ossa mu maaso gange bulijjo.
\q1 
\v 9 Sikyakkiriza nte nnume n’emu evudde mu kiralo kyo,
\q2 wadde embuzi ennume ezivudde mu bisibo byo.
\q1 
\v 10 Kubanga buli nsolo ey’omu kibira yange,
\q2 awamu n’ente eziri ku nsozi olukumi.
\q1 
\v 11 Ennyonyi zonna ez’oku nsozi nzimanyi,
\q2 n’ebiramu byonna eby’omu nsiko byange.
\q1 
\v 12 Singa nnumwa enjala sandikubuulidde:
\q2 kubanga ensi n’ebigirimu byonna byange.
\q1 
\v 13 Ndya ennyama y’ente ennume,
\q2 wadde okunywa omusaayi gw’embuzi?
\b
\q1 
\v 14 “Owangayo ssaddaaka ey’okwebaza eri Katonda;
\q2 era otuukirizanga obweyamo bwo eri oyo Ali Waggulu Ennyo.
\q1 
\v 15 Bw’obanga mu buzibu,
\q2 nnaakuwonyanga, naawe onongulumizanga.”
\p 
\v 16 Naye omubi Katonda amugamba nti,
\q1 “Lekeraawo okwatulanga amateeka gange,
\q2 n’endagaano yange togyogerangako.
\q1 
\v 17 Kubanga okyawa okuluŋŋamizibwa,
\q2 n’ebigambo byange tobissaako mwoyo.
\q1 
\v 18 Bw’olaba omubbi, ng’omukwana;
\q2 era weetaba n’abenzi.
\q1 
\v 19 Okolima era olimba;
\q2 olulimi lwo lwogera ebitali bya butuukirivu.
\q1 
\v 20 Muganda wo omwogerako bibi byereere buli kiseera,
\q2 era owayiriza omwana wa nnyoko yennyini.
\q1 
\v 21 Ebyo byonna obikoze, ne nsirika,
\q2 n’olowooza nti twenkanankana.
\q1 Naye kaakano ka nkunenye,
\q2 ebisobyo byonna mbikulage.
\b
\q1 
\v 22 “Ggwe eyeerabira Katonda, ebyo bisseeko omwoyo,
\q2 nneme kukuyuzaayuza nga tewali na wa kukuwonya.
\q1 
\v 23 Oyo awaayo ssaddaaka ey’okwebaza angulumiza,
\q2 era ateekateeka ekkubo
\q2 ndyoke mulage obulokozi bwa Katonda.”
\c 51
\cl Zabbuli 51
\d Ya Mukulu wa Bayimbi. Zabbuli ya Dawudi. Nnabbi Nasani bwe yajja eri Dawudi, Dawudi ng’amaze okutwala Basuseba n’okutemula bba, Uliya.
\q1 
\v 1 Onsaasire, Ayi \nd Mukama\nd*,
\q2 ggwe alina okwagala okutaggwaawo.
\q1 Olw’okusaasira kwo okungi
\q2 nziggyaako ebyonoono byange byonna.
\q1 
\v 2 Nnaazaako obutali butuukirivu bwange,
\q2 ontukulize ddala okuva mu kibi kyange.
\b
\q1 
\v 3 Ebyonoono byange mbikkiriza,
\q2 era ebibi byange mbimanyi bulijjo.
\q1 
\v 4 Ggwe wennyini ggwe nnyonoonye,
\q2 ne nkola ebitali bya butuukirivu mu maaso go ng’olaba;
\q1 noolwekyo by’oyogera bituufu,
\q2 era n’ensala yo ey’omusango ya bwenkanya.
\q1 
\v 5 Ddala, nazaalibwa mu kibi;
\q2 kasookedde ntondebwa mu lubuto lwa mmange ndi mwonoonyi.
\q1 
\v 6 Oyagala amazima agaviira ddala mu mutima gwange.
\q2 Ompe amagezi munda ddala mu nze.
\b
\q1 
\v 7 Onnaaze n’ezobu\f + \fr 51:7 \fq Ezobu \ft kimera ekisangibwa mu Asiya, era kikozesebwa okutuukiriza obulombolombo obw’enjawulo okutukuzibwa, mu Baebbulaniya\f* ntukule
\q2 onnaaze ntukule n’okusinga omuzira.
\q1 
\v 8 Onzirize essanyu n’okwesiima,
\q2 amagumba gange ge wamenyaamenya gasanyuke.
\q1 
\v 9 Totunuulira bibi byange,
\q2 era osangule ebyonoono byange byonna.
\b
\q1 
\v 10 Ontondemu omutima omulongoofu, Ayi Katonda,
\q2 era onteekemu omwoyo omulungi munda yange.
\q1 
\v 11 Tongoba w’oli,
\q2 era tonzigyako Mwoyo wo Omutukuvu.
\q1 
\v 12 Onkomezeewo essanyu ery’obulokozi bwo,
\q2 era ompe omutima ogugondera by’oyagala,
\q1 
\v 13 ndyoke njigirizenga aboonoonyi amakubo go,
\q2 n’abakola ebibi bakukyukirenga bakomewo gy’oli.
\q1 
\v 14 Ondokole mu kibi eky’okuyiwa omusaayi, Ayi Katonda,
\q2 ggwe Katonda ow’obulokozi bwange;
\q2 olulimi lwange lunaatenderezanga obutuukirivu bwo.
\q1 
\v 15 Ayi Mukama, yasamya emimwa gyange,
\q2 n’akamwa kange kanaakutenderezanga.
\q1 
\v 16 Tosanyukira ssaddaaka, nandigikuleetedde;
\q2 n’ebiweebwayo ebyokebwa tobisanyukira.
\q1 
\v 17 Ssaddaaka Katonda gy’ayagala gwe mwoyo ogutegedde okusobya kwagwo.
\q2 Omutima ogumenyese era oguboneredde,
\q2 Ayi Katonda, toogugayenga.
\b
\q1 
\v 18 Okulaakulanye Sayuuni nga bw’osiima.
\q2 Yerusaalemi okizzeeko bbugwe waakyo.
\q1 
\v 19 Olyoke osanyukire ssaddaaka ey’obutuukirivu,
\q2 ebiweebwayo ebyokebwa ebikusanyusa;
\q2 n’ente ziweebweyo ku kyoto kyo.
\c 52
\cl Zabbuli 52
\d Ya Mukulu wa Bayimbi. Zabbuli ya Dawudi Dowegi Omwedomu bwe yagenda n’abuulira Sawulo nti, “Dawudi alaze mu nnyumba ya Akimereki.”
\q1 
\v 1 Lwaki weenyumiririza mu kibi ggwe omusajja ow’amaanyi?
\q2 Endagaano ya Katonda ey’obwesigwa ebeerera emirembe n’emirembe.
\q1 
\v 2 Oteekateeka enkwe ez’okuzikiriza.
\q2 Olulimi lwo lwogi nga kkirita
\q2 era buli kiseera lwogera bya bulimba.
\q1 
\v 3 Oyagala okukola ebibi okusinga okukola ebirungi,
\q2 n’okulimba okusinga okwogera amazima.
\q1 
\v 4 Osanyukira nnyo okwogera ebirumya.
\q2 Ggwe olulimi kalimbira!
\b
\q1 
\v 5 Kyokka Katonda alikuzikiriza emirembe gyonna;
\q2 alikusikula, akuggye mu maka go;
\q2 alikugoba mu nsi y’abalamu.
\q1 
\v 6 Bino abatuukirivu balibiraba, ne babitunuulira nga batidde.
\q2 Naye balikusekerera, nga bwe bagamba nti,
\q1 
\v 7 “Mumulabe omusajja
\q2 ateesiga Katonda okuba ekiddukiro kye,
\q1 naye ne yeesiganga obugagga bwe obungi,
\q2 ne yeeyongera n’amaanyi ng’azikiriza abalala.”
\b
\q1 
\v 8 Naye nze nfaanana ng’omuti omuzeyituuni
\q2 ogukulira mu nnyumba ya Katonda.
\q1 Neesiga okwagala kwa Katonda okutaggwaawo
\q2 emirembe n’emirembe.
\q1 
\v 9 Nnaakwebazanga emirembe gyonna olw’ekyo ky’okoze.
\q2 Nneesiganga erinnya lyo kubanga erinnya lyo ddungi;
\q2 era nnaakutendererezanga awali abatuukirivu bo.
\c 53
\cl Zabbuli 53
\d Ya Mukulu wa Bayimbi. Zabbuli ya Dawudi.
\q1 
\v 1 Omusirusiru ayogera mu mutima gwe nti,
\q2 “Tewali Katonda.”
\q1 Boonoonefu, n’empisa zaabwe mbi nnyo;
\q2 tewali n’omu akola kirungi.
\q1 
\v 2 Katonda atunuulira abaana b’abantu
\q2 ng’asinziira mu ggulu,
\q1 alabe obanga mulimu mu bo abamutegeera
\q2 era abamunoonya.
\q1 
\v 3 Bonna bamukubye amabega
\q2 ne boonooneka;
\q1 tewali akola kirungi,
\q2 tewali n’omu.
\b
\q1 
\v 4 Aboonoonyi tebaliyiga?
\b
\q1 Basaanyaawo abantu bange, ng’abalya emmere;
\q2 so tebakoowoola Katonda.
\q1 
\v 5 Balitya okutya okutagambika;
\q2 kubanga Katonda alisaasaanya amagumba g’abalabe be.
\q1 Baliswazibwa
\q2 kubanga Katonda yabanyooma.
\b
\q1 
\v 6 Singa obulokozi bwa Isirayiri bufuluma mu Sayuuni,
\q2 Katonda n’akomyawo emirembe eri abantu be,
\q2 Yakobo asanyuka ne Isirayiri n’ajaguza.
\c 54
\cl Zabbuli 54
\d Ya Mukulu wa Bayimbi. Eyimbibwa n’ebivuga eby’enkoba. Zabbuli ya Dawudi, Abazifu bwe bajja ne babuulira Sawulo nti, “Dawudi yeekwese mu ffe.”
\q1 
\v 1 Olw’erinnya lyo ondokole, Ayi Katonda,
\q2 n’amaanyi go amangi onzigyeko omusango.
\q1 
\v 2 Wulira okusaba kwange, Ayi Katonda,
\q2 owulirize ebigambo by’omu kamwa kange.
\b
\q1 
\v 3 Abantu be simanyi bannumba;
\q2 abantu abalina ettima abatatya Katonda;
\q2 bannoonya okunzita.
\b
\q1 
\v 4 Laba, Katonda ye mubeezi wange,
\q2 Mukama ye mukuumi wange.
\b
\q1 
\v 5 Leka ebintu ebibi byonna bye bantegekera, bibeekyusize,
\q2 obazikirize olw’obwesigwa bwo.
\b
\q1 
\v 6 Nnaakuleeteranga ssaddaaka ey’ekyeyagalire;
\q2 ne ntendereza erinnya lyo, Ayi \nd Mukama\nd*,
\q2 kubanga ddungi.
\q1 
\v 7 Kubanga Katonda amponyezza ebizibu byange byonna;
\q2 era amaaso gange galabye ng’awangula abalabe bange.
\c 55
\cl Zabbuli 55
\d Ya Mukulu wa Bayimbi. Eyimbibwa n’ebivuga eby’enkoba. Zabbuli ya Dawudi.
\q1 
\v 1 Owulirize okusaba kwange, Ayi Katonda,
\q2 togaya kwegayirira kwange.
\q2 
\v 2 Ompulire era onziremu,
\q1 kubanga ndi mu buzibu, nga nsinda olw’okweraliikirira okunene.
\q2 
\v 3 Mpulira amaloboozi g’abalabe bange;
\q2 ababi bankanulidde amaaso
\q1 ne banvuma nga bajjudde obusungu.
\b
\q1 
\v 4 Omutima gwange gulumwa nnyo munda yange;
\q2 entiisa y’okufa entuukiridde.
\q1 
\v 5 Okutya n’okukankana binnumbye;
\q2 entiisa empitiridde.
\q1 
\v 6 Ne njogera nti, Singa nnina ebiwaawaatiro ng’ejjiba,
\q2 nandibuuse ne ŋŋenda mpummulako.
\q1 
\v 7 “Nandiraze wala nnyo,
\q2 ne mbeera eyo mu ddungu;
\q1 
\v 8 nandiyanguye ne ntuuka mu kifo kyange eky’okuwummuliramu,
\q2 eteri kibuyaga na mpewo ekunta n’amaanyi.”
\b
\q1 
\v 9 Mukama tabulatabula ennimi z’ababi, ozikirize enkwe zaabwe;
\q2 kubanga ndaba obukambwe n’okulwanagana mu kibuga.
\q1 
\v 10 Beetooloola bbugwe waakyo emisana n’ekiro,
\q2 ne munda mu kyo mujjudde ettima n’ebikolwa ebibi.
\q1 
\v 11 Obutemu n’obussi obwa buli ngeri biri mu kibuga omwo.
\q2 Buli lw’oyita mu nguudo zaakyo osanga bulimba bwereere na kutiisibwatiisibwa.
\b
\q1 
\v 12 Singa omulabe wange y’abadde anvuma,
\q2 nandikigumiikirizza;
\q1 singa oyo atakkiriziganya nange y’annumbaganye n’anduulira,
\q2 nandimwekwese.
\q1 
\v 13 Naye ggwe munnange,
\q2 bwe tuyita, era mukwano gwange ddala!
\q1 
\v 14 Gwe twabanga naye mu ssanyu ng’abooluganda,
\q2 nga tutambulira mu kibiina ekinene mu nnyumba ya Katonda.
\b
\q1 
\v 15 Okufa kubatuukirire,
\q2 bakke emagombe nga bakyali balamu;
\q2 kubanga bajjudde okukola ebibi.
\b
\q1 
\v 16 Naye nze nkoowoola \nd Mukama\nd* Katonda,
\q2 n’andokola.
\q1 
\v 17 Ekiro, ne mu makya ne mu ttuntu,
\q2 ndaajana nga bwe nsinda;
\q2 n’awulira eddoboozi lyange.
\q1 
\v 18 Amponyezza mu lutalo
\q2 nga siriiko kintuseeko
\q2 newaakubadde ng’abannwanyisizza babadde bangi.
\q1 
\v 19 Katonda oyo atudde ku ntebe ye ebbanga lyonna,
\q2 aliwulira n’ababonereza
\q1 abo abatakyusa makubo gaabwe
\q2 era abatatya Katonda.
\b
\q1 
\v 20 Agololera emikono gye ku mikwano gye;
\q2 n’amenya endagaano ye.
\q1 
\v 21 By’ayogera bigonvu okusinga omuzigo,
\q2 so nga mu mutima gwe alowooza lutalo;
\q1 ebigambo bye biweweera okusinga amafuta,
\q2 so nga munda mu mutima gwe asowodde bitala byennyini.
\b
\q1 
\v 22 Ebizibu byo byonna bireete eri \nd Mukama\nd*,
\q2 ajja kukuwanirira;
\q2 kubanga talireka mutuukirivu kugwa.
\q1 
\v 23 Naye ggwe, Ayi Katonda,
\q2 olisuula abakola ebibi mu kinnya eky’okuzikirira;
\q1 era abatemu n’abalimba bonna
\q2 tebagenda kuwangaala kimu kyakubiri eky’obulamu bwabwe.
\b
\q1 Naye nze, neesiga ggwe.
\c 56
\cl Zabbuli 56
\d Ya Mukulu wa Bayimbi. Zabbuli ya Dawudi. Abafirisuuti bwe baamukwatira mu Gaasi.
\q1 
\v 1 Onsaasire, Ayi Katonda, kubanga abalabe bange banjigganya;
\q2 buli lunaku bannumba n’amaanyi.
\q1 
\v 2 Abalabe bange bannondoola,
\q2 bangi bannwanyisa nga bajjudde amalala.
\b
\q1 
\v 3 Buli lwe ntya,
\q2 neesiga ggwe.
\q1 
\v 4 Nditendereza Katonda ne nyweerera mu kigambo kye,
\q2 ye Katonda gwe neesiga; siityenga.
\q2 Abantu obuntu bagenda kunkolako ki?
\b
\q1 
\v 5 Olunaku lwonna bye njogera babifuulafuula;
\q2 ebbanga lyonna baba basala nkwe kunkola kabi.
\q1 
\v 6 Beekobaana ne bateesa,
\q2 banneekwekerera ne bawuliriza enswagiro zange;
\q2 nga bannindirira banzite.
\q1 
\v 7 Tobakkiriza kudduka ne bawona;
\q2 mu busungu bwo, Ayi Katonda, osuule amawanga.
\b
\q1 
\v 8 Emirundi gye ntawaanyizibwa nga njaziirana ogimanyi;
\q2 amaziga gange gateeke mu ccupa yo!
\q2 Wagawandiika.
\q1 
\v 9 Bwe nkukoowoola,
\q2 abalabe bange nga badduka.
\q2 Kino nkimanyi kubanga Katonda ali ku ludda lwange.
\b
\q1 
\v 10 Katonda gwe ntendereza olw’ekisuubizo kye;
\q2 \nd Mukama\nd* gwe ntendereza olw’ekisuubizo kye;
\q1 
\v 11 Katonda oyo gwe neesiga, siityenga.
\q2 Abantu bayinza kunkolako ki?
\b
\q1 
\v 12 Ndituukiriza obweyamo bwange gy’oli, Ayi Katonda;
\q2 ndikuleetera ebirabo eby’okukwebaza.
\q1 
\v 13 Kubanga emmeeme yange ogiwonyezza okufa.
\q2 Ebigere byange tobiwonyezza okwesittala;
\q1 ne ndyoka ntambulira mu maaso ga Katonda
\q2 mu musana nga ndi mulamu?
\c 57
\cl Zabbuli 57
\d Ya Mukulu wa Bayimbi. Ku ddoboozi, “Tozikiriza.” Zabbuli ya Dawudi bwe yadduka Sawulo, n’alaga mu mpuku.
\q1 
\v 1 Onsaasire, Ayi Katonda, onsaasire,
\q2 kubanga neesiga ggwe.
\q1 Nzija kwekweka mu kisiikirize ky’ebiwaawaatiro byo
\q2 okutuusa okuzikirira bwe kulikoma.
\b
\q1 
\v 2 Nkoowoola Katonda Ali Waggulu Ennyo,
\q2 Katonda atuukiriza bye yantegekera.
\q1 
\v 3 Alisinzira mu ggulu n’andokola,
\q2 n’amponya abo abampalana.
\q2 Katonda anandaganga obwesigwa bwe n’okwagala kwe okutaggwaawo.
\b
\q1 
\v 4 Mbeera wakati mu mpologoma,
\q2 nsula mu bisolo ebirya abaana b’abantu.
\q1 Amannyo g’abalabe bange gali ng’amafumu n’obusaale.
\q2 Ennimi zaabwe ziri ng’ebitala ebyogi.
\b
\q1 
\v 5 Ayi Katonda, ogulumizibwenga okusinga eggulu;
\q2 n’ekitiibwa kyo kibune ensi yonna.
\b
\q1 
\v 6 Baatega ekitimba mu kkubo lyange,
\q2 ne ntya nnyo;
\q1 ne basimamu obunnya,
\q2 ate bo bennyini ne babugwamu.
\b
\q1 
\v 7 Omutima gwange munywevu, Ayi Katonda,
\q2 omutima gwange munywevu.
\q2 Nnaakutenderezanga n’ennyimba.
\q1 
\v 8 Zuukuka, ggwe omwoyo gwange!
\q2 Zuukuka ggwe ennanga ey’enkoba, naawe entongooli,
\q2 ndyoke nnyimbe okukeesa obudde.
\b
\q1 
\v 9 Ayi Mukama, ndikwebaza mu mawanga;
\q2 ndiyimba nga nkutendereza mu bantu.
\q1 
\v 10 Kubanga okwagala kwo kungi nnyo, kutuuka ne ku ggulu;
\q2 n’obwesigwa bwo butuuka ku bire.
\b
\q1 
\v 11 Ogulumizibwenga, Ayi Katonda, okusinga eggulu;
\q2 n’ekitiibwa kyo kibune ensi yonna.
\c 58
\cl Zabbuli 58
\d Ya Mukulu wa Bayimbi. Ku ddoboozi, “Tozikiriza.” Zabbuli ya Dawudi.
\q1 
\v 1 Ddala mwogera eby’amazima oba musirika busirisi?
\q2 Abaana b’abantu mubasalira emisango mu bwenkanya?
\q1 
\v 2 Nedda, mutegeka ebitali bya bwenkanya mu mitima gyammwe;
\q2 era bye mukola bireeta obwegugungo mu nsi.
\b
\q1 
\v 3 Abakola ebibi bakyama nga baakazaalibwa,
\q2 bava mu lubuto nga balina ekibi, era bakula boogera bya bulimba.
\q1 
\v 4 Balina obusagwa ng’obw’omusota;
\q2 bali ng’enswera etawulira ezibikira amatu gaayo;
\q1 
\v 5 n’etawulira na luyimba lwa mukugu
\q2 agisendasenda okugikwata.
\b
\q1 
\v 6 Ayi Katonda, menya amannyo gaabwe;
\q2 owangulemu amannyo g’empologoma zino, Ayi \nd Mukama\nd*.
\q1 
\v 7 Leka babule ng’amazzi agakulukuta ne gagenda.
\q2 Bwe banaanuula omutego, leka obusaale bwabwe bwe balasa bufufuggale.
\q1 
\v 8 Babe ng’ekkovu erisaanuukira mu lugendo lwalyo.
\q2 Babe ng’omwana azaaliddwa ng’afudde, ataliraba ku njuba!
\b
\q1 
\v 9 Nga n’entamu tennabuguma,
\q2 alibayerawo n’obusungu obungi nga kibuyaga ow’amaanyi ennyo.
\q1 
\v 10 Omutuukirivu alisanyuka ng’alabye bamuwalanidde eggwanga,
\q2 olwo n’ebigere bye ne bisaabaana omusaayi ogw’abakola ebibi.
\q1 
\v 11 Awo abantu bonna balyogera nti,
\q2 “Ddala, abatuukirivu balwanirirwa.
\q2 Ddala waliwo Katonda alamula mu bwenkanya ku nsi.”
\c 59
\cl Zabbuli 59
\d Ya Mukulu wa Bayimbi. Ku ddoboozi, “Tozikiriza.” Zabbuli ya Dawudi, Sawulo bwe yatuma bakuume enju ya Dawudi bamutte.
\q1 
\v 1 Ayi Katonda wange, mponya abalabe bange;
\q2 onnwanirire, abantu bwe bangolokokerako.
\q1 
\v 2 Omponye abakola ebitali bya butuukirivu,
\q2 era ondokole mu batemu.
\b
\q1 
\v 3 Laba banneekwekeredde nga banteega okunzita.
\q2 Abasajja ab’amaanyi abakambwe banneekobera, Ayi \nd Mukama\nd*,
\q2 so nga soonoonye wadde okubaako ne kye nsobezza.
\q1 
\v 4 Sirina kye nsobezza, naye bateekateeka okunnumba.
\q2 Tunuulira obuzibu bwange, osituke, onnyambe.
\q1 
\v 5 Ayi \nd Mukama\nd* Katonda ow’Eggye, Katonda wa Isirayiri,
\q2 golokoka obonereze amawanga gonna;
\q2 abo bonna abasala enkwe tobasaasira.
\b
\q1 
\v 6 Bakomawo buli kiro,
\q2 nga babolooga ng’embwa,
\q2 ne batambulatambula mu kibuga.
\q1 
\v 7 Laba, bwe bavuma!
\q2 Ebigambo biwamatuka mu kamwa kaabwe ng’ebitala,
\q2 nga boogera nti, “Ani atuwulira?”
\q1 
\v 8 Naye ggwe, Ayi \nd Mukama\nd*, obasekerera,
\q2 era amawanga ago gonna oganyooma.
\b
\q1 
\v 9 Ayi Katonda, Amaanyi gange, nnaakwesiganga
\q2 era nnaakutenderezanga, kubanga ggwe kigo kyange ekinywevu.
\v 10 Katonda wange anjagala
\q1 anankulemberanga,
\q2 ne ndyoka neeyagalira ku balabe bange.
\q1 
\v 11 Tobatta, Ayi Mukama, engabo yaffe,
\q2 abantu bange baleme kwerabira;
\q1 mu buyinza bwo obungi, baleke batangetange;
\q2 n’oluvannyuma obakkakkanyize ddala.
\q1 
\v 12 Amalala gaabwe n’ebyonoono ebiva mu kamwa kaabwe,
\q2 n’ebigambo by’oku mimwa gyabwe
\q2 leka byonna bibatege ng’omutego.
\q1 Kubanga bakolima era ne boogera eby’obulimba.
\q2 
\v 13 Bamaleewo n’ekiruyi kyo,
\q2 bamalirewo ddala;
\q1 amawanga gonna galyoke gategeere
\q2 nga Katonda wa Yakobo y’afuga ensi yonna.
\b
\q1 
\v 14 Bakomawo nga buwungedde
\q2 nga babolooga ng’embwa,
\q2 ne batambulatambula mu kibuga.
\q1 
\v 15 Banoonya emmere buli wantu mu kibuga,
\q2 ne bawowoggana bwe batakkuta.
\q1 
\v 16 Naye nze nnaayimbanga nga ntendereza amaanyi go;
\q2 mu makya nnaayimbanga ku kwagala kwo;
\q1 kubanga ggwe kigo kyange,
\q2 era ggwe kiddukiro kyange mu buzibu bwange.
\b
\q1 
\v 17 Ggwe, Ayi Katonda, Amaanyi gange, nnaakuyimbiranga nga nkutendereza;
\q2 kubanga ggwe kigo kyange, era ggwe Katonda wange, anjagala.
\c 60
\cl Zabbuli 60
\d Ya Mukulu wa Bayimbi. Ku ddoboozi, “Eddanga ery’Endagaano.” Zabbuli ya Dawudi. Yakuyigiriza. Dawudi bwe yalwana n’Abaalamu abaava e Nakalayimu n’abaava e Zoba, Yowaabu n’akomawo n’atta Abayedomu omutwalo gumu mu enkumi bbiri mu Kiwonvu eky’Omunnyo.
\q1 
\v 1 Otusudde, Ayi Katonda, otumazeemu amaanyi,
\q2 otunyiigidde. Tukwegayiridde otuzze gy’oli.
\q1 
\v 2 Ensi ogiyuuguumizza n’ogyasaayasa;
\q2 tukwegayirira enjatika ozizibe, kubanga ekankana.
\q1 
\v 3 Obadde mukambwe nnyo eri abantu bo;
\q2 tuli nga b’owadde omwenge omungi ne gututagaza.
\q1 
\v 4 Naye abo abakutya obawanikidde ebbendera okuba akabonero akabakuŋŋaanya awamu,
\q2 era akatiisa abalabe baabwe.
\b
\q1 
\v 5 Otulokole era otuyambe n’omukono gwo ogwa ddyo,
\q2 abakwagala baleme kutuukibwako kabi konna.
\q1 
\v 6 Katonda ayogedde ng’asinziira mu kifo kye ekitukuvu, n’agamba nti,
\q2 “Mu buwanguzi, ndisala mu Sekemu,
\q2 era n’ekiwonvu kya Sukkosi ndikigabanyagabanyaamu.
\q1 
\v 7 Ensi ya Gireyaadi yange, n’eya Manase nayo yange.
\q2 Efulayimu ye nkufiira ey’oku mutwe gwange;
\q2 ate Yuda gwe muggo gwange ogw’okufuga.
\q1 
\v 8 Mowaabu kye kinaabirwamu kyange,
\q2 ate Edomu gye nkasuka engatto yange:
\q2 ne ku Bafirisuuti ndeekaana mu buwanguzi.”
\b
\q1 
\v 9 Ani anantuusa ku kibuga ekigumu ekinywevu?
\q2 Ani anankulembera okunnyingiza mu Edomu?
\q1 
\v 10 Si ggwe Ayi Katonda, atusudde,
\q2 atakyatabaala na magye gaffe?
\q1 
\v 11 Tudduukirire, nga tulwanyisa abalabe baffe,
\q2 kubanga obuyambi bw’abantu temuli nsa.
\q1 
\v 12 Bwe tunaabeeranga ne Katonda, tunaabanga bawanguzi,
\q2 kubanga ye y’anaalinnyiriranga abalabe baffe wansi w’ebigere bye.
\c 61
\cl Zabbuli 61
\d Ya Mukulu wa Bayimbi. Ebivuga eby’enkoba. Zabbuli ya Dawudi.
\q1 
\v 1 Wulira okukaaba kwange, Ayi Katonda;
\q2 wulira okusaba kwange.
\b
\q1 
\v 2 Nkukoowoola okuva ku nkomerero y’ensi,
\q2 omutima gwange nga gugenda gunafuwa.
\q2 Onkulembere ontuuse ku lwazi olunsinga obuwanvu mwe nnyinza okwekweka.
\q1 
\v 3 Kubanga gw’oli kiddukiro kyange.
\q2 Oli kigo eky’amaanyi mwe neekweka omulabe.
\b
\q1 
\v 4 Nnaabeeranga mu weema yo ennaku zonna;
\q2 ndyoke nkuumirwenga mu biwaawaatiro byo.
\q1 
\v 5 Kubanga ggwe, Ayi Katonda, owulidde obweyamo bwange:
\q2 ompadde omugabo awamu n’abo abatya erinnya lyo.
\b
\q1 
\v 6 Oyongere ku nnaku z’obulamu bwa kabaka;
\q2 emyaka gye gimutuuse mu mirembe mingi,
\q1 
\v 7 alyoke abeerenga mu maaso ga Katonda ennaku zonna.
\q2 Okwagala kwo n’obwesigwa bwo bimukuumenga.
\b
\q1 
\v 8 Ndyoke nnyimbenga nga ntendereza erinnya lyo ennaku zonna,
\q2 nga ntuukiriza obweyamo bwange buli lunaku.
\c 62
\cl Zabbuli 62
\d Ya Mukulu wa Bayimbi. Ya Yedusuni. Zabbuli ya Dawudi.
\q1 
\v 1 Emmeeme yange ewummulira mu Katonda yekka;
\q2 oyo obulokozi bwange mwe buva.
\q1 
\v 2 Ye yekka, lwe lwazi lwange era bwe bulokozi bwange;
\q2 ye kye kigo kyange siinyeenyezebwenga n’akatono.
\b
\q1 
\v 3 Mulituusa ddi nga mulumba omuntu,
\q2 mmwe mwenna okwagala okumusuula wansi
\q2 ng’ekisenge ekyewunzise era ng’olukomera oluyuuguuma?
\q1 
\v 4 Bateesa okumuggya
\q2 mu kifo kye ekinywevu,
\q2 basanyukira eby’obulimba.
\q1 Basaba omukisa n’emimwa gyabwe
\q2 so nga munda bakolima.
\b
\q1 
\v 5 Emmeeme yange ewummulire mu Katonda yekka;
\q2 kubanga mu ye mwe muli essuubi lyange.
\q1 
\v 6 Ye yekka lwe lwazi lwange era bwe bulokozi bwange,
\q2 ye kye kigo kyange, siinyeenyezebwenga.
\q1 
\v 7 Okulokolebwa kwange n’ekitiibwa kyange biri mu Katonda yekka;
\q2 ye lwe lwazi lwange olw’amaanyi era kye kiddukiro kyange.
\q1 
\v 8 Mumwesigenga bulijjo mmwe abantu,
\q2 mumutegeezenga byonna ebiri mu mitima gyammwe,
\q2 kubanga Katonda kye kiddukiro kyaffe.
\b
\q1 
\v 9 Abaana b’abantu mukka bukka,
\q2 abazaalibwa mu bugagga bulimba bwereere;
\q1 ne bwe bageraageranyizibwa ku minzaani,
\q2 n’omukka gubasinga okuzitowa.
\q1 
\v 10 Temwesigamanga ku bujoozi
\q2 wadde ku bintu ebibbe.
\q1 Temuyitirira okwewaanirawaanira mu bugagga bwammwe ne bwe bweyongeranga,
\q2 era temubumalirangako mwoyo gwammwe.
\b
\q1 
\v 11 Katonda ayogedde ekintu kimu,
\q2 kyokka nze nziggyemu ebintu bibiri nti:
\q1 Katonda, oli w’amaanyi,
\q2 
\v 12 era ggwe, Ayi Mukama, ojjudde okwagala.
\q1 Ddala olisasula buli muntu
\q2 ng’ebikolwa bye bwe biri.
\c 63
\cl Zabbuli 63
\d Zabbuli ya Dawudi, bwe yali mu ddungu lya Yuda.
\q1 
\v 1 Ayi Katonda, oli Katonda wange,
\q2 nkunoonya n’omutima gwange gwonna;
\q1 emmeeme yange ekwetaaga,
\q2 omubiri gwange gwonna gukuyaayaanira,
\q1 nga nnina ennyonta ng’ali
\q2 mu nsi enkalu omutali mazzi.
\b
\q1 
\v 2 Nkulabye ng’oli mu kifo kyo ekitukuvu,
\q2 ne ndaba amaanyi go n’ekitiibwa kyo.
\q1 
\v 3 Kubanga okwagala kwo okutaggwaawo kusinga obulamu;
\q2 akamwa kange kanaakutenderezanga.
\q1 
\v 4 Bwe ntyo nnaakutenderezanga obulamu bwange bwonna;
\q2 nnaayimusanga emikono gyange mu linnya lyo.
\q1 
\v 5 Emmeeme yange enekkutanga ebyassava n’obugagga;
\q2 nnaayimbanga nga nkutendereza n’emimwa egy’essanyu.
\b
\q1 
\v 6 Nkujjukira nga ndi ku kitanda kyange,
\q2 era nkufumiitirizaako mu ssaawa ez’ekiro.
\q1 
\v 7 Olw’okuba ng’oli mubeezi wange,
\q2 nnyimba nga ndi mu kisiikirize ky’ebiwaawaatiro byo.
\q1 
\v 8 Emmeeme yange yeekwata ku ggwe;
\q2 omukono gwo ogwa ddyo gumpanirira.
\b
\q1 
\v 9 Naye abo abannoonya okunzita balizikirizibwa,
\q2 baliserengeta emagombe.
\q1 
\v 10 Balisaanawo n’ekitala;
\q2 ne bafuuka emmere y’ebibe.
\b
\q1 
\v 11 Naye ye kabaka anaajagulizanga mu Katonda;
\q2 bonna abalayira mu linnya lya Katonda banaatenderezanga Katonda,
\q2 naye akamwa k’abalimba kalisirisibwa.
\c 64
\cl Zabbuli 64
\d Ya Mukulu wa Bayimbi. Zabbuli ya Dawudi.
\q1 
\v 1 Ayi Katonda, owulire eddoboozi lyange, ery’okwemulugunya kwange;
\q2 okuume obulamu bwange eri okutiisibwatiisibwa omulabe.
\b
\q1 
\v 2 Onkweke mpone enkwe z’abakola ebibi,
\q2 onzigye mu kibinja ky’aboonoonyi, abaleekaana
\q1 
\v 3 abawagala ennimi zaabwe ng’ebitala,
\q2 ne balasa ebigambo byabwe ng’obusaale obutta.
\q1 
\v 4 Beekweka ne bateega oyo atalina musango bamulase;
\q2 amangwago ne bamulasa nga tebatya.
\b
\q1 
\v 5 Bawagiragana mu kigendererwa kyabwe ekibi
\q2 ne bateesa okutega emitego mu kyama;
\q2 ne boogera nti, “Ani asobola okutulaba?”
\q1 
\v 6 Beekobaana okukola ebitali bya bwenkanya, ne boogera nti,
\q2 “Tukoze enteekateeka empitirivu.”
\q2 Ddala ddala ebirowoozo by’omuntu n’omutima gwe byekusifu.
\b
\q1 
\v 7 Naye Katonda alibalasa n’obusaale bwe;
\q2 alibafumita, mangwago ne bagwa ku ttaka.
\q1 
\v 8 Ebyo bye boogera biribaddira,
\q2 ne bibazikiriza,
\q2 ababalaba ne babanyeenyeza emitwe.
\q1 
\v 9 Olwo abantu bonna ne batya,
\q2 ne bategeeza abalala omulimu gwa Katonda,
\q2 ne bafumiitiriza ku ebyo by’akoze.
\b
\q1 
\v 10 Omutuukirivu ajagulizenga mu \nd Mukama\nd*,
\q2 era yeekwekenga mu ye.
\q2 Abo bonna abalina omutima omulongoofu bamutenderezenga!
\c 65
\cl Zabbuli 65
\d Ya Mukulu wa Bayimbi. Oluyimba, Zabbuli ya Dawudi.
\q1 
\v 1 Osaanira okutenderezebwanga, Ayi Katonda, ali mu Sayuuni;
\q2 tunaatuukiririzanga obweyamo bwaffe gy’oli.
\q1 
\v 2 Ayi ggwe awulira okusaba kw’abantu bo,
\q2 abantu bonna banajjanga gy’oli olw’ebibi byabwe.
\q1 
\v 3 Ebibi byaffe bwe byatusukkirira,
\q2 n’otutangiririra.
\q1 
\v 4 Alina omukisa oyo gw’olonda
\q2 n’omusembeza okumpi naawe, abeerenga mu mpya zo.
\q1 Tunaamalibwanga ebirungi eby’omu nnyumba yo;
\q2 eby’omu Yeekaalu yo entukuvu.
\b
\q1 
\v 5 Otwanukula n’ebikolwa byo eby’obutuukirivu eby’entiisa n’otulokola,
\q2 Ayi Katonda ow’obulokozi bwaffe;
\q1 ggwe ssuubi ly’abo abali mu nsi yonna n’abo bonna
\q2 abali ewala mu nnyanja zonna,
\q1 
\v 6 ggwe, eyakola ensozi n’obuyinza bwo,
\q2 n’ozinyweza n’amaanyi go,
\q1 
\v 7 ggwe, asirisa okusiikuuka kw’ennyanja,
\q2 n’okkakkanya okwetabula kw’amayengo gaayo,
\q2 era ggw’okkakkanya okwegugunga kw’amawanga.
\q1 
\v 8 Abo bonna ababeera ewala balaba ne batya ebyewuunyo byo;
\q2 ne bakuyimbira ennyimba ez’essanyu
\q2 okuva ku makya okutuusa akawungeezi.
\b
\q1 
\v 9 Ensi ogirabirira n’ogifukirira
\q2 n’egimuka nnyo.
\q1 Emigga gya Katonda gijjudde amazzi,
\q2 okuwa abantu emmere ey’empeke,
\q2 kubanga bw’otyo bwe wakiteekateeka.
\q1 
\v 10 Otonnyesa enkuba mu nnimiro,
\q2 n’ojjuza ebitaba byamu;
\q1 n’ogonza ettaka,
\q2 ebibala by’omu nsi n’obiwa omukisa.
\q1 
\v 11 Ofundikira omwaka n’amakungula amangi,
\q2 ebigaali ne bigenda nga byetisse ebibala nga bikubyeko.
\q1 
\v 12 Ebifo awali omuddo mu ddungu bijjula amazzi,
\q2 n’obusozi ne bulabika bulungi nga bweyagala.
\q1 
\v 13 Amalundiro gajjula ebisibo,
\q2 n’ebiwonvu ne bijjula emmere ey’empeke.
\q2 Ensi yonna eyimba mu ddoboozi ery’omwanguka ng’ejjudde essanyu.
\c 66
\cl Zabbuli 66
\d Ya mukulu wa bayimbi. Oluyimba, Zabbuli ya Dawudi.
\q1 
\v 1 Yimbira \nd Mukama\nd* n’eddoboozi ery’omwanguka, ggwe ensi yonna.
\q2 
\v 2 Muyimbe ekitiibwa ky’erinnya lye.
\q2 Mumuyimbire ennyimba ezimusuuta.
\q1 
\v 3 Gamba Katonda nti, “Ebikolwa byo nga bya ntiisa!
\q2 Olw’amaanyi go amangi
\q2 abalabe bo bakujeemulukukira.
\q1 
\v 4 Ab’omu nsi yonna bakuvuunamira,
\q2 bakutendereza,
\q2 bayimba nga bagulumiza erinnya lyo.”
\b
\q1 
\v 5 Mujje mulabe Katonda ky’akoze;
\q2 mulabe eby’entiisa by’akoledde abaana b’abantu!
\q1 
\v 6 Ennyanja yagifuula olukalu.
\q2 Abantu baasomoka omugga n’ebigere nga temuli mazzi,
\q2 kyetuva tujaguza.
\q1 
\v 7 Afuga n’amaanyi ge emirembe gyonna;
\q2 amaaso ge agasimba ku mawanga,
\q2 ab’omutima omujeemu baleme okumujeemera.
\b
\q1 
\v 8 Mutendereze Katonda waffe, mmwe amawanga;
\q2 eddoboozi ery’okumutendereza liwulirwe wonna.
\q1 
\v 9 Oyo y’atukuumye ne tuba balamu,
\q2 n’ataganya bigere byaffe kuseerera.
\q1 
\v 10 Kubanga ggwe, Ayi Katonda, otugezesezza,
\q2 n’otulongoosa nga bwe bakola ffeeza mu muliro.
\q1 
\v 11 Watuteeka mu kkomera,
\q2 n’otutikka emigugu.
\q1 
\v 12 Waleka abantu ne batulinnyirira;
\q2 ne tuyita mu muliro ne mu mazzi,
\q2 n’otutuusa mu kifo eky’okwesiima.
\b
\q1 
\v 13 Nnaayambukanga mu yeekaalu yo n’ebiweebwayo ebyokebwa,
\q2 ntuukirize obweyamo bwange gy’oli,
\q1 
\v 14 nga ndeeta ekyo emimwa gyange kye gyasuubiza;
\q2 akamwa kange kye kaayogera bwe nnali mu kabi.
\q1 
\v 15 Nnaawaayo gy’oli ssaddaaka ez’ensolo ensava,
\q2 mpeeyo ne ssaddaaka ey’endiga ennume;
\q2 mpeeyo ente ennume n’embuzi.
\b
\q1 
\v 16 Mujje muwulire, mmwe mwenna abatya Katonda,
\q2 mbategeeze ebyo by’ankoledde.
\q1 
\v 17 Namukaabirira n’akamwa kange,
\q2 ne mutendereza n’olulimi lwange.
\q1 
\v 18 Singa nnali nsirikidde ekibi mu mutima gwange,
\q2 Mukama teyandimpulirizza;
\q1 
\v 19 ddala ddala Katonda yampuliriza era n’awulira eddoboozi lyange nga nsaba.
\q1 
\v 20 Katonda atenderezebwenga,
\q2 atagobye kusaba kwange,
\q2 wadde okunziggyako okwagala kwe okutaggwaawo!
\c 67
\cl Zabbuli 67
\d Ya Mukulu wa Bayimbi. Ebivuga eby’enkoba. Zabbuli. Oluyimba.
\q1 
\v 1 Ayi Katonda tukwatirwe ekisa, otuwe omukisa,
\q2 era otwakize amaaso go.
\q1 
\v 2 Ekkubo lyo limanyibwe mu nsi,
\q2 n’obulokozi bwo mu mawanga gonna.
\b
\q1 
\v 3 Abantu bakutenderezenga, Ayi Katonda,
\q2 abantu bonna bakutenderezenga.
\q1 
\v 4 Amawanga gonna gasanyuke, gayimbe nga gajjudde essanyu.
\q2 Kubanga ofuga abantu bonna mu bwenkanya,
\q2 n’oluŋŋamya amawanga ag’ensi.
\q1 
\v 5 Abantu bakutenderezenga, Ayi Katonda,
\q2 abantu bonna bakutenderezenga.
\b
\q1 
\v 6 Ensi erireeta amakungula gaayo;
\q2 era Katonda, Katonda waffe, anaatuwanga omukisa.
\q1 
\v 7 Katonda anaatuwanga omukisa;
\q2 n’enkomerero z’ensi zinaamutyanga.
\c 68
\cl Zabbuli 68
\d Ya Mukulu wa Bayimbi. Oluyimba lwa Dawudi.
\q1 
\v 1 Katonda agolokoke, abalabe be basaasaane,
\q2 n’abo abamukyawa bamudduke.
\q1 
\v 2 Ng’empewo bw’efuumuula omukka,
\q2 naawe bafuumuule bw’otyo;
\q1 envumbo nga bw’esaanuuka mu muliro,
\q2 n’abakola ebibi bazikirire bwe batyo mu maaso ga Katonda!
\q1 
\v 3 Naye abatuukirivu basanyuke
\q2 bajagulize mu maaso ga Katonda,
\q2 nga bajjudde essanyu.
\b
\q1 
\v 4 Muyimbire Katonda,
\q2 muyimbe nga mutendereza erinnya lye;
\q1 mumuyimusize amaloboozi gammwe oyo atambulira mu bire.
\q2 Erinnya lye ye \nd Mukama\nd*, mujagulize mu maaso ge.
\q1 
\v 5 Ye Kitaawe w’abataliiko bakitaabwe, ye mukuumi wa bannamwandu;
\q2 ye Katonda abeera mu kifo kye ekitukuvu.
\q1 
\v 6 Katonda afunira abatalina we babeera ekifo eky’okubeeramu,
\q2 aggya abasibe mu kkomera n’abagaggawaza;
\q2 naye abajeemu babeera mu bifo bikalu ddala.
\b
\q1 
\v 7 Ayi Katonda, bwe wakulembera abantu bo,
\q2 n’obayisa mu ddungu,
\q1 
\v 8 ensi yakankana,
\q2 eggulu ne lifukumula enkuba mu maaso ga Katonda;
\q1 n’olusozi Sinaayi ne lukankana
\q2 awali Katonda, Katonda wa Isirayiri!
\q1 
\v 9 Watonnyesa enkuba nnyingi ku nsi, Ayi Katonda;
\q2 ensi y’obusika bwo n’ogizzaamu obugimu bwe bwali nga buggweerera;
\q1 
\v 10 abantu bo ne babeera omwo; era olw’ekisa kyo ekingi, Ayi Katonda,
\q2 abaavu ne bafuna bye beetaaga okuva ku bugagga bwo.
\q1 
\v 11 Mukama yalangirira;
\q2 ne babunyisa ekigambo kye; baali bangi ne boogera nti:
\q1 
\v 12 “Bakabaka badduse n’amaggye gaabwe;
\q2 abantu ne bagabana omunyago.
\q1 
\v 13 Balabe bwe banyirira n’obugagga bwa ffeeza ne zaabu!
\q2 Babikkiddwa ng’ejjuba bwe libikkibwa
\q2 ebiwaawaatiro byalyo.”
\q1 
\v 14 Ayinzabyonna yasaasaanya bakabaka,
\q2 ne baba ng’omuzira bwe gugwa ku Zalumoni.
\q1 
\v 15 Ggwe olusozi olw’ekitiibwa, olusozi lwa Basani;
\q2 ggwe olusozi olw’emitwe emingi, olusozi lwa Basani!
\q1 
\v 16 Lwaki otunuza obuggya ggwe olusozi olw’emitwe emingi?
\q2 Lwaki okwatirwa obuggya olusozi Katonda lwe yalonda okufugirako?
\q2 Ddala okwo \nd Mukama\nd* kw’anaabeeranga ennaku zonna.
\q1 
\v 17 Mukama ava ku lusozi Sinaayi
\q2 nga yeetooloddwa amagaali enkumi n’enkumi
\q2 n’ajja mu kifo kye ekitukuvu.
\q1 
\v 18 Bwe walinnyalinnya olusozi,
\q2 ng’abanyage bakugoberera;
\q2 abantu ne bakuwa ebirabo
\q1 nga ne bakyewaggula mwebali;
\q2 bw’atyo \nd Mukama\nd* Katonda n’abeeranga wamu nabo.
\q1 
\v 19 Atenderezebwe Mukama, Katonda omulokozi waffe,
\q2 eyeetikka emigugu gyaffe egya buli lunaku.
\q1 
\v 20 Katonda waffe ye Katonda alokola;
\q2 era tuddukira eri \nd Mukama\nd* Katonda okuwona okufa.
\q1 
\v 21 Ddala, Katonda alibetenta emitwe gy’abalabe be,
\q2 kubanga ne mu bukadde bwabwe balemera mu bibi byabwe.
\q1 
\v 22 Mukama agamba nti, “Ndibakomyawo nga mbaggya mu Basani,
\q2 ndibazza nga mbaggya mu buziba bw’ennyanja,
\q1 
\v 23 mulyoke munaabe ebigere byammwe mu musaayi gw’abalabe bammwe,
\q2 n’embwa zammwe zeefunire ebyokulya.”
\b
\q1 
\v 24 Ekibiina kyo ky’okulembedde bakirabye, Ayi Katonda,
\q2 balabye abali ne Katonda wange, era Kabaka wange, ng’otambula okugenda mu watukuvu;
\q1 
\v 25 abayimbi nga bakulembedde, ab’ebivuga nga bavaako emabega
\q2 ne wakati waabwe nga waliwo abawala abakuba ebitaasa.
\q1 
\v 26 Mutendereze Katonda mu kibiina ekinene;
\q2 mumutendereze \nd Mukama\nd*, mmwe abakuŋŋaanye abangi Abayisirayiri.
\q1 
\v 27 Waliwo ekika kya Benyamini asinga obuto kye kikulembedde,
\q2 ne kuddako ekibinja ekinene eky’abalangira ba Yuda,
\q2 n’abalangira ba Zebbulooni n’abalangira ba Nafutaali.
\b
\q1 
\v 28 Laga obuyinza bwo, Ayi Katonda,
\q2 otulage amaanyi go, Ayi Katonda onyweze ebyo by’otukoledde.
\q1 
\v 29 Bakabaka balikuleetera ebirabo
\q2 olwa Yeekaalu yo eri mu Yerusaalemi.
\q1 
\v 30 Nenya ensolo enkambwe ey’omu bisaalu,
\q2 eggana lya ziseddume eriri mu nnyana z’amawanga.
\q1 Gikkakkanye ereete omusolo ogwa ffeeza.
\q2 Osaasaanye amawanga agasanyukira entalo.
\q1 
\v 31 Ababaka baliva e Misiri,
\q2 ne Kuusi aligondera Katonda.
\b
\q1 
\v 32 Muyimbire Katonda mmwe obwakabaka obw’ensi zonna.
\q2 Mutendereze Mukama.
\q1 
\v 33 Oyo eyeebagala eggulu erya waggulu ery’edda,
\q2 eddoboozi lye ery’amaanyi liwuluguma okuva mu ggulu.
\q1 
\v 34 Mulangirire obuyinza bwa Katonda,
\q2 ekitiibwa kye kibuutikidde Isirayiri;
\q2 obuyinza bwe buli mu bire.
\q1 
\v 35 Oli wa ntiisa, Ayi Katonda, mu kifo kyo ekitukuvu.
\q2 Katonda wa Isirayiri, yawa abantu obuyinza n’amaanyi.
\b
\q1 Katonda atenderezebwe.
\c 69
\cl Zabbuli 69
\d Ya Mukulu wa Bayimbi. Mu ddoboozi ery’Amalanga. Zabbuli ya Dawudi.
\q1 
\v 1 Ondokole, Ayi Katonda,
\q2 kubanga amazzi gandi mu bulago.
\q1 
\v 2 Ntubira mu bitosi
\q2 nga sirina we nnywereza kigere.
\q1 Ntuuse ebuziba
\q2 n’amataba gansaanikira.
\q1 
\v 3 Ndajanye ne nkoowa,
\q2 n’emimiro ginkaze.
\q1 Amaaso ganzizeeko ekifu gakooye
\q2 olw’okutunula enkaliriza nga nnindirira Katonda wange.
\q1 
\v 4 Abo abankyayira obwereere
\q2 bangi okusinga enviiri ez’oku mutwe gwange;
\q1 abalabe bange bangi
\q2 abannoonya okunzita awatali nsonga;
\q1 ne mpalirizibwa mbaddizeewo
\q2 ekyo kye sibbanga.
\b
\q1 
\v 5 Ayi Katonda, omanyi obusirusiru bwange,
\q2 n’okusobya kwange tekukukwekeddwa.
\b
\q1 
\v 6 Sisaana kuswaza
\q2 abo abakwesiga,
\q2 Ayi Mukama, \nd Mukama\nd* ow’Eggye.
\q1 Abo abakunoonya
\q2 baleme kuswazibwa ku lwange,
\q2 Ayi Katonda wa Isirayiri.
\q1 
\v 7 Ngumiikirizza okuvumwa ku lulwo,
\q2 n’amaaso gange ne gajjula ensonyi.
\q1 
\v 8 Nfuuse nga omugwira eri baganda bange,
\q2 munnaggwanga eri abaana ba mmange.
\q1 
\v 9 Nzijudde obuggya olw’ennyumba yo,
\q2 n’abo abakuvuma bavuma nze.
\q1 
\v 10 Bwe nkaaba ne nsiiba,
\q2 ekyo nakyo ne kinvumisa.
\q1 
\v 11 Bwe nnyambala ebibukutu ne nfuuka eky’okuzanyisa kyabwe.
\q1 
\v 12 Abo abatuula ku mulyango gw’ekibuga banduulira,
\q2 era nfuuse luyimba lw’abatamiivu.
\b
\q1 
\v 13 Naye nze, Ayi \nd Mukama\nd*, nsaba ggwe,
\q2 mu kiseera eky’ekisa kyo.
\q1 Olw’okwagala kwo okungi, onnyanukule, Ayi Katonda,
\q2 ondokole nga bwe wasuubiza.
\q1 
\v 14 Onnyinyulule mu ttosi
\q2 nneme okutubira;
\q1 omponye abankyawa,
\q2 onzigye mu mazzi amangi;
\q1 
\v 15 amataba galeme okumbuutikira
\q2 n’obuziba okunsanyaawo,
\q2 n’ennyanja ereme okummira.
\b
\q1 
\v 16 Onnyanukule, Ayi \nd Mukama\nd* olw’obulungi bw’okwagala kwo;
\q2 onkyukire olw’okusaasira kwo okungi.
\q1 
\v 17 Tokisa muddu wo maaso go; yanguwa okunziramu,
\q2 kubanga ndi mu kabi.
\q1 
\v 18 Onsemberere onziruukirire,
\q2 onnunule mu balabe bange.
\b
\q1 
\v 19 Omanyi bwe nsekererwa, ne bwe nswazibwa ne bwe siteekebwamu kitiibwa,
\q2 era n’abalabe bange bonna obamanyi.
\q1 
\v 20 Okusekererwa kunkutudde omutima
\q2 era kummazeemu amaanyi.
\q1 Nanoonya okusaasirwa ne kumbula,
\q2 n’ow’okumpooyawooya naye nga simulaba.
\q1 
\v 21 Mu kifo ky’emmere bampa mususa,
\q2 era bwe nalumwa ennyonta bampa nkaatu.
\b
\q1 
\v 22 Emmere yaabwe gye bategese okulya ebafuukire ekyambika,
\q2 n’embaga zaabwe ez’ebiweebwayo zibafuukire omutego.
\q1 
\v 23 Amaaso gaabwe gazibe baleme okulaba,
\q2 n’emigongo gyabwe gyewetenga ennaku zonna.
\q1 
\v 24 Bayiweeko ekiruyi kyo,
\q2 obamalewo n’obusungu obw’amaanyi go obungi.
\q1 
\v 25 Ebifo byabwe bifuuke bifulukwa,
\q2 waleme kubaawo n’omu abeera mu weema zaabwe.
\q1 
\v 26 Kubanga bayigganya oyo gw’ofumise,
\q2 ne boogera ku bulumi bw’oyo gw’olumizza.
\q1 
\v 27 Bavunaane omusango kina gumu,
\q2 era tobaganya kugabana ku bulokozi bwo.
\q1 
\v 28 Bawanduukululwe mu kitabo ky’obulamu;
\q2 baleme kulabika ku lukalala lw’abatuukirivu.
\b
\q1 
\v 29 Ndi mu bulumi era mu nnaku;
\q2 obulokozi bwo, Ayi Katonda, bunkuume.
\q1 
\v 30 Nnaatenderezanga erinnya lya Katonda nga nnyimba;
\q2 nnaamugulumizanga n’okwebaza.
\q1 
\v 31 Kino kinaasanyusanga \nd Mukama\nd* okusinga okumuwa ente ennume,
\q2 oba okumuwa seddume n’amayembe gaayo, n’ebigere byayo.
\q1 
\v 32 Abaavu banaakirabanga ne basanyuka;
\q2 mmwe abanoonya Katonda omutima gwammwe ne gubeera omulamu.
\q1 
\v 33 Kubanga \nd Mukama\nd* awulira abo abali mu kwetaaga,
\q2 era ababe ne bwe baba mu busibe, tabanyooma.
\b
\q1 
\v 34 Kale eggulu n’ensi bimutenderezenga
\q2 awamu n’ennyanja zonna n’ebyo ebizirimu.
\q1 
\v 35 Kubanga Katonda alirokola Sayuuni,
\q2 n’ebibuga bya Yuda n’abizimba buggya,
\q1 abantu ne babibeerangamu nga byabwe.
\q2 
\v 36 Abaana b’abaweereza be balikisikira;
\q2 n’abo abaagala erinnya lya \nd Mukama\nd* omwo mmwe banaabeeranga.
\c 70
\cl Zabbuli 70
\d Ya Mukulu wa Bayimbi. Zabbuli ya Dawudi, ey’okujjukiza.
\q1 
\v 1 Ayi Katonda oyanguwa okundokole.
\q2 Ayi \nd Mukama\nd* oyanguwe okumbeera.
\b
\q1 
\v 2 Abo abannoonya okunzita
\q2 batabulwetabulwe;
\q1 abo abannoonya okunzikiriza,
\q2 bagobebwe nga baswadde.
\q1 
\v 3 Abagamba nti, “Kasonso,”
\q2 badduke nga bajjudde ensonyi.
\q1 
\v 4 Naye bonna abakunoonya
\q2 basanyukenga bajagulizenga mu ggwe.
\q1 Abo abaagala obulokozi bwo boogerenga bulijjo nti,
\q2 “Katonda agulumizibwenga!”
\b
\q1 
\v 5 Naye nze ndi mwavu era ndi mu kwetaaga;
\q2 oyanguwe okujja gye ndi, Ayi Katonda.
\q1 Ggwe onnyamba era ggwe ondokola,
\q2 Ayi \nd Mukama\nd*, tolwa!
\c 71
\cl Zabbuli 71
\q1 
\v 1 Mu ggwe, Ayi \nd Mukama\nd*, mwe neekweka,
\q2 tondeka kuswazibwa.
\q1 
\v 2 Mu butuukirivu bwo ondokole, omponye;
\q2 ontegere okutu ondokole.
\q1 
\v 3 Onfuukire olwazi obuddukiro bwange,
\q2 ekifo eky’amaanyi;
\q1 ondokole
\q2 kubanga oli lwazi lwange era ekiddukiro kyange.
\q1 
\v 4 Ayi Katonda wange omponye mu mukono gw’ababi,
\q2 omponye abantu abatali batuukirivu era abakambwe.
\b
\q1 
\v 5 Kubanga ggwe, Ayi \nd Mukama\nd*, ggwe ssuubi lyange;
\q2 ggwe, ggwe neesiga, okuviira ddala mu buvubuka bwange.
\q1 
\v 6 Neesiga ggwe kasookedde nzalibwa;
\q2 ggwe wanziggya mu lubuto lwa mmange.
\q2 Nnaakutenderezanga ennaku zonna.
\q1 
\v 7 Eri abangi nafuuka;
\q2 naye ggwe kiddukiro kyange eky’amaanyi.
\q1 
\v 8 Akamwa kange kajjudde ettendo lyo,
\q2 nga ntenda ekitiibwa kyo obudde okuziba.
\b
\q1 
\v 9 Tonsuula mu kiseera kyange eky’obukadde.
\q2 Tondekerera ng’amaanyi gampweddemu.
\q1 
\v 10 Kubanga abalabe bange banjogerako;
\q2 abo abaagala okunzita bansalira olukwe.
\q1 
\v 11 Bagamba nti, “Katonda amulese,
\q2 ka tumugobe tumukwate,
\q2 kubanga taliiko anaamuwonya.”
\q1 
\v 12 Ayi Katonda, tombera wala, Ayi Katonda wange,
\q2 yanguwa ojje ombeere.
\q1 
\v 13 Abo abampawaabira bazikirizibwe nga bajjudde ensonyi,
\q2 abanoonya okunnumya baswale
\q2 era banyoomebwe.
\b
\q1 
\v 14 Naye nze nnaabanga n’essuubi ennaku zonna.
\q2 Era nneeyongeranga okukutenderezanga.
\b
\q1 
\v 15 Akamwa kange kanaayogeranga ku bikolwa byo eby’obutuukirivu obudde okuziba;
\q2 nnaayogeranga ku bulokozi bwo,
\q2 wadde siyinza kubupima.
\q1 
\v 16 Nnaatambuliranga mu maanyi go, Ayi \nd Mukama\nd* Katonda,
\q2 era ne ntegeezanga nti ggwe wekka ggwe mutuukirivu.
\q1 
\v 17 Ayi Katonda, ggwe wanjigiriza okuva mu buvubuka bwange;
\q2 n’okutuusa leero nkyatenda ebikolwa byo eby’ekitalo.
\q1 
\v 18 Ne bwe ndiba nga nkaddiye nga mmeze n’envi,
\q2 tonjabuliranga, Ayi Katonda,
\q1 okutuusiza ddala nga mmaze okutendera abo abaliddawo amaanyi go amangi,
\q2 n’okumanyisa emirembe egigenda okujja obuyinza bwo.
\b
\q1 
\v 19 N’obutuukirivu bwo, Ayi Katonda, butuuka mu ggulu.
\q2 Ggw’okoze ebikulu,
\q2 Ayi Katonda, ani akwenkana?
\q1 
\v 20 Newaakubadde wandeka ne mbonaabona nnyo bwe ntyo,
\q2 ggw’olinzizaamu obulamu,
\q1 n’ompa amaanyi amaggya,
\q2 n’onnyimusa okuva mu kinnya ekiwanvu ennyo wansi w’ensi.
\q1 
\v 21 Olinnyongerako ekitiibwa
\q2 n’oddamu okunsanyusa.
\b
\q1 
\v 22 Nnaakutenderezanga ne nnanga ey’enkoba
\q2 olw’obwesigwa bwo, Ayi Katonda wange;
\q1 nnaakutenderezanga n’entongooli,
\q2 Ayi ggwe Omutukuvu wa Isirayiri.
\q1 
\v 23 Nnaayimusanga eddoboozi lyange olw’essanyu
\q2 nga nkutendereza,
\q2 nze gw’onunudde!
\q1 
\v 24 Olulimi lwange nalwo lunaayogeranga ku bikolwa byo eby’obutuukirivu
\q2 obudde okuziba,
\q1 kubanga abo ababadde baagala okunkola akabi
\q2 otabuddetabudde enkwe zaabwe ne baswazibwa.
\c 72
\cl Zabbuli 72
\d Zabbuli ya Sulemaani.
\q1 
\v 1 Ayi Katonda, kabaka omuwe okuba omwenkanya,
\q2 ne mutabani we omuwe obutuukirivu,
\q1 
\v 2 alyoke alamulenga abantu bo mu butuukirivu,
\q2 n’abaavu abalamulenga mu mazima.
\b
\q1 
\v 3 Ensozi zireeterenga abantu bo okukulaakulana
\q2 n’obusozi bubaleetere obutuukirivu.
\q1 
\v 4 Anaalwaniriranga abaavu,
\q2 n’atereeza abaana b’abo abeetaaga,
\q2 n’omujoozi n’amusaanyaawo.
\q1 
\v 5 Abantu bakutyenga ng’enjuba n’omwezi gye bikoma
\q2 okwaka mu mirembe gyonna.
\q1 
\v 6 Abeere ng’enkuba bw’etonnya ku muddo ogusaliddwa,
\q2 afaanane ng’oluwandaggirize olufukirira ensi.
\q1 
\v 7 Obutuukirivu bweyongere nnyo mu mulembe gwe,
\q2 n’okufuga kwe kujjule emirembe okutuusa omwezi lwe gulikoma okwaka!
\b
\q1 
\v 8 Afugenga okuva ku nnyanja okutuuka ku nnyanja,\f + \fr 72:8 \ft Kyalowoozebwanga nti ensi yakomanga ku Nnyanja ey’Omunnyo okumpi n’Ennyanja Ennene, eya Meditereniyaani.\f*
\q2 n’okuva ku mugga Fulaati\f + \fr 72:8 \ft Omugga Fulaati gwe gwali ensalo ku luuyi olw’ebuvanjuba bwa Isirayiri, mu bufuzi bwa Sulemaani. Kyali kyasuubizibwa Abayisirayiri mu biro eby’okuva mu Misiri.\f* okutuuka ku nkomerero z’ensi!
\q1 
\v 9 Ebika eby’omu malungu bimugonderenga,
\q2 n’abalabe be bamujeemulukukire beekulukuunye ne mu nfuufu.
\q1 
\v 10 Bakabaka b’e Talusiisi\f + \fr 72:10 \fq Talusiisi \ft kyali mu Esupaniya, era eyo ye yalowoozebwa okuba enkomerero y’ensi.\f* n’ab’oku bizinga eby’ewala
\q2 bamuwenga omusolo;
\q1 bakabaka b’e Syeba n’ab’e Seeba\f + \fr 72:10 \fq Syeba \ft kiri mu Buwalabu, ate Seeba kiri mu Afirika.\f*
\q2 bamutonerenga ebirabo.
\q1 
\v 11 Bakabaka bonna banaavuunamanga mu maaso ge;
\q2 amawanga gonna ganaamuweerezanga.
\b
\q1 
\v 12 Kubanga anaawonyanga eyeetaaga bw’anaamukoowoolanga,
\q2 n’omwavu ne kateeyamba ataliiko mwasirizi.
\q1 
\v 13 Anaasaasiranga omunafu n’omwavu;
\q2 n’awonya obulamu bwa kateeyamba.
\q1 
\v 14 Anaabanunulanga mu mikono gy’omujoozi n’abawonya obukambwe bwe;
\q2 kubanga obulamu bwabwe bwa muwendo mungi gy’ali.
\b
\q1 
\v 15 Awangaale!
\q2 Aleeterwe zaabu okuva e Syeba.
\q1 Abantu bamwegayiririrenga
\q2 era bamusabirenga emikisa buli lunaku.
\q1 
\v 16 Eŋŋaano ebale nnyingi nnyo mu nsi,
\q2 ebikke n’entikko z’ensozi.
\q1 Ebibala byayo byale ng’eby’e Lebanooni;
\q2 n’abantu baale mu bibuga ng’omuddo ogw’oku ttale.
\q1 
\v 17 Erinnya lye libeerengawo ennaku zonna,
\q2 n’okwatiikirira kwe kube kwa nkalakkalira ng’enjuba.
\b
\q1 Amawanga gonna ganaaweebwanga omukisa ku lu lw’erinnya lye,
\q2 era abantu bonna bamuyitenga aweereddwa omukisa.
\b
\q1 
\v 18 \nd Mukama\nd* Katonda agulumizibwe, Katonda wa Isirayiri,
\q2 oyo yekka akola ebyewuunyisa.
\q1 
\v 19 Erinnya lye ekkulu ligulumizibwenga emirembe n’emirembe!
\q2 Ensi yonna ejjule ekitiibwa kye.
\qc Amiina era Amiina!
\b
\b
\q1 
\v 20 Okusaba kwa Dawudi mutabani wa Yese kukomye awo.
\c 73
\ms1 EKITABO III
\mr Zabbuli 73–89
\cl Zabbuli 73
\d Zabbuli ya Asafu.
\q1 
\v 1 Ddala Katonda mulungi eri Isirayiri
\q2 n’eri abo abalina omutima omulongoofu.
\b
\q1 
\v 2 Naye nze amagulu gange gaali kumpi okutagala
\q2 era n’ebigere byange okuseerera.
\q1 
\v 3 Kubanga nakwatirwa ab’amalala obuggya;
\q2 bwe nalaba ababi nga bagaggawala nnyo.
\b
\q1 
\v 4 Kubanga tebalina kibaluma;
\q2 emibiri gyabwe miramu era minyirivu.
\q1 
\v 5 Tebeeraliikirira kabi konna ng’abalala.
\q2 So tebalina kibabonyaabonya.
\q1 
\v 6 Amalala kyegavudde gabafuukira ng’omukuufu ogw’omu bulago,
\q2 n’obukambwe ne bubafuukira ekyambalo.
\q1 
\v 7 Bagezze n’amaaso gaabwe ne gazimbagatana;
\q2 balina bingi okusinga bye beetaaga.
\q1 
\v 8 Baduula era emboozi zaabwe zijjudde eby’okujooga.
\q2 Batiisatiisa abalala n’okubeeragirako.
\q1 
\v 9 Emimwa gyabwe gyolekedde eggulu;
\q2 n’ennimi zaabwe zoogera eby’okwewaanawaana buli wantu.
\q1 
\v 10 Abantu ba Katonda kyebava babakyukira
\q2 ne banywa amazzi mangi.
\q1 
\v 11 Era ne beebuuza nti, “Katonda bino abimanyi atya?
\q2 Ali Waggulu Ennyo abitegeera?”
\b
\q1 
\v 12 Aboonoonyi bwe bafaanana bwe batyo;
\q2 bulijjo babeera mu ddembe, nga beeyongera kugaggawala.
\b
\q1 
\v 13 Ddala omutima gwange ngukuumidde bwereere obutayonoona,
\q2 n’engalo zange ne nzinaaba obutaba na musango.
\q1 
\v 14 Naye mbonaabona obudde okuziba,
\q2 era buli nkya mbonerezebwa.
\b
\q1 
\v 15 Singa ŋŋamba nti njogere bwe nti,
\q2 nandibadde mukuusa eri omulembe guno ogw’abaana bo.
\q1 
\v 16 Bwe nafumiitiriza ntegeere ensonga eyo;
\q2 nakisanga nga kizibu nnyo,
\q1 
\v 17 okutuusa lwe nalaga mu watukuvu wa Katonda,
\q2 ne ntegeera enkomerero y’ababi.
\b
\q1 
\v 18 Ddala obatadde mu bifo ebiseerera;
\q2 obasudde n’obafaafaaganya.
\q1 
\v 19 Nga bazikirizibwa mangu nga kutemya kikowe!
\q2 Entiisa n’ebamalirawo ddala!
\q1 
\v 20 Bali ng’omuntu azuukuse n’ategeera nti yaloose buloosi;
\q2 era naawe bw’otyo, Ayi Mukama,
\q2 bw’oligolokoka olinyooma embeera yaabwe omutali nsa.
\b
\q1 
\v 21 Omutima gwange bwe gwanyiikaala,
\q2 n’omwoyo gwange ne gujjula obubalagaze,
\q1 
\v 22 n’aggwaamu okutegeera ne nfuuka ataliiko kye mmanyi,
\q2 ne mba ng’ensolo obusolo mu maaso go.
\b
\q1 
\v 23 Newaakubadde ebyo biri bwe bityo naye ndi naawe bulijjo;
\q2 gw’onkwata ku mukono gwange ogwa ddyo.
\q1 
\v 24 Mu kuteesa kwo onkulembera,
\q2 era olintuusa mu kitiibwa.
\q1 
\v 25 Ani gwe nnina mu ggulu, wabula ggwe?
\q2 Era tewali na kimu ku nsi kye neetaaga bwe mba naawe.
\q1 
\v 26 Omubiri gwange n’omutima gwange biyinza okulemwa;
\q2 naye Katonda ge maanyi g’omutima gwange,
\q2 era ye wange ennaku zonna.
\b
\q1 
\v 27 Kale laba, abo bonna abatakussaako mwoyo balizikirira;
\q2 kubanga bonna abatakwesiga obamalirawo ddala.
\q1 
\v 28 Naye nze kye nsinga okwetaaga kwe kubeera okumpi ne Katonda wange.
\q2 Ayi \nd Mukama\nd* Katonda, nkufudde ekiddukiro kyange;
\q2 ndyoke ntegeezenga abantu bonna ebikolwa byo eby’ekyewuunyo.
\c 74
\cl Zabbuli 74
\d Zabbuli ya Asafu.
\q1 
\v 1 Ayi Katonda, lwaki otusuulidde ddala ennaku zonna?
\q2 Obusungu bwo lwaki bunyookera ku ndiga z’omu ddundiro lyo?
\q1 
\v 2 Ojjukire abantu bo be wagula edda;
\q2 ekika kye wanunula okuba ababo.
\q2 Ojjukire olusozi Sayuuni gye wabeeranga.
\q1 
\v 3 Tambulatambulako mu bifo by’ekibuga olabe bwe byonooneddwa!
\q2 Olabe omulabe nga bw’azikirizza ennyumba yo.
\b
\q1 
\v 4 Abalabe bo baleekaanira mu kifo kyo gye twakuŋŋaaniranga;
\q2 ne bagenda nga bakiramba n’ebendera zaabwe.
\q1 
\v 5 Beeyisa ng’abantu ababagalidde embazzi
\q2 abatema emiti mu kibira.
\q1 
\v 6 Batemyetemye n’embazzi ebintu ebyole,
\q2 era ne babissessebbula n’obubazzi.
\q1 
\v 7 Bookezza awatukuvu wo;
\q2 ne bafaafaaganya ekifo kyo eky’Erinnya lyo.
\q1 
\v 8 Baateesa nga bagamba nti, “Tujja kubazikiririza ddala!”
\q2 Baayokya dda amasinzizo ga Katonda gonna agali mu nsi eno.
\b
\q1 
\v 9 Tetukyalaba ku bubonero bwo; ne bannabbi tewakyali n’omu.
\q2 So tewali n’omu mu ffe ategeera ebyo lwe birikoma.
\q1 
\v 10 Ayi Katonda, omulabe alituusa ddi ng’akuduulira?
\q2 Omulabe anavvoolanga erinnya lyo ennaku zonna? Bazikirize.
\q1 
\v 11 Lwaki totuyambye n’omukono gwo ogwa ddyo?
\q2 Kiki ekikukuumisa omukono gwo ogwa ddyo mu kifuba kyo?
\b
\q1 
\v 12 Naye ggwe, Ayi Katonda, oli Kabaka wange wa dda;
\q2 gw’oleeta obulokozi mu nsi.
\b
\q1 
\v 13 Ggwe wayawula mu mazzi g’ennyanja;
\q2 omulabe n’omuzikiririza mu mazzi.
\q1 
\v 14 Wamenyaamenya emitwe gya lukwata ogunene;
\q2 n’oguwaayo okuba ekyokulya eri ebitonde eby’omu ddungu.
\q1 
\v 15 Ggwe wazibukula ensulo n’emyala;
\q2 ate n’okaza n’emigga
\q2 egyakulukutanga bulijjo.
\q1 
\v 16 Obudde bw’emisana bubwo, n’ekiro kikyo;
\q2 ggwe wakola omwezi n’enjuba.
\q1 
\v 17 Ggwe wateekawo ensalo z’ensi;
\q2 ggwe wakola ebiro eby’ekyeya n’eby’obutiti.
\b
\q1 
\v 18 Jjukira ebyo, Ayi Katonda, olabe okuduula kw’omulabe,
\q2 n’abantu abasirusiru nga bwe banyoomodde erinnya lyo.
\q1 
\v 19 Ayi Katonda, towaayo mwoyo gwa jjiba lyo eri ensolo enkambwe;
\q2 so teweerabiriranga ddala bulamu bw’abantu bo ababonyaabonyezebwa.
\q1 
\v 20 Ojjukire endagaano yo;
\q2 kubanga ensi ejjudde ekizikiza n’abantu abakambwe.
\q1 
\v 21 Tokkiriza abo abajoogebwa okuwangulwa;
\q2 era leka abaavu n’abeetaaga batenderezenga erinnya lyo ennaku zonna.
\q1 
\v 22 Yimuka, Ayi Katonda, osalire abalabe baffe omusango.
\q1 Jjukira abo abatakussaamu kitiibwa, nga bwe bakuduulira obudde okuziba.
\q1 
\v 23 Tonyooma luyoogaano lw’abalabe bo,
\q2 n’okuleekaana okwa buli kiseera.
\c 75
\cl Zabbuli 75
\d Ya Mukulu wa Bayimbi. Ku ddoboozi, “Tozikiriza.” Zabbuli ya Asafu. Oluyimba.
\q1 
\v 1 Tukwebaza, Ayi Katonda.
\q2 Tukwebaza, kubanga Erinnya lyo liri kumpi.
\q2 Abantu boogera ku bikolwa byo eby’ekyewuunyo.
\b
\q1 
\v 2 \nd Mukama\nd* Katonda oyogera nti, “Neerondera ekiseera kye neetegekera
\q2 era nsala omusango gwa bwenkanya.
\q1 
\v 3 Kyokka newaakubadde ng’ensi eyuuguuma abantu ne beeraliikirira,
\q2 naye nze nywezezza empagi zaayo.”
\q1 
\v 4 Nalabula ab’amalala bagaleke,
\q2 n’ababi bakomye okuyimusa ejjembe lyabwe ng’ery’embogo.
\q1 
\v 5 Mukomye okuyimusa ejjembe lyammwe eri eggulu
\q2 n’okwogera nga muduula.
\b
\q1 
\v 6 Kubanga okugulumizibwa tekuva mu ddungu
\q2 era n’obuyinza tebuva buvanjuba wadde obugwanjuba bw’ensi,
\q1 
\v 7 wabula biva eri Katonda;
\q2 era ye y’agulumiza omu ate n’atoowaza omulala.
\q1 
\v 8 \nd Mukama\nd* akutte mu mukono gwe ekikompe eky’obusungu bwe
\q2 ekijjudde omwenge ogutabuddwamu ebirungo era kijjudde ejjovu;
\q1 akifuka, aboonoonyi bonna ku nsi
\q2 ne bakinywa ne bakimaliramu ddala.
\b
\q1 
\v 9 Naye nze nnaatendanga obulungi bwa \nd Mukama\nd*;
\q2 nnaatenderezanga Katonda wa Yakobo ennaku zonna.
\q1 
\v 10 \nd Mukama\nd* ayogera nti, Ababi ndibamalamu amaanyi,
\q2 naye abatuukirivu nnaabongeranga amaanyi.
\c 76
\cl Zabbuli 76
\d Ya Mukulu wa Bayimbi. Eyimbibwa n’ebivuga eby’enkoba. Zabbuli ya Asafu.
\q1 
\v 1 Katonda amanyiddwa mu Yuda;
\q2 erinnya lye kkulu mu Isirayiri.
\q1 
\v 2 Eweema ye eri mu Yerusaalemi;
\q2 era abeera mu Sayuuni.
\q1 
\v 3 Eyo gy’asinziira n’amenyaamenya obusaale bw’omulabe obujja bwesooza;
\q2 n’engabo n’ebitala n’ebyokulwanyisa byonna eby’olutalo.
\b
\q1 
\v 4 Owa ekitangaala,
\q2 oli wa kitiibwa okusinga ensozi ennene eziriko ensolo eziyiggibwa.
\q1 
\v 5 Ab’amaanyi bagalamira nga banyaguluddwa,
\q2 beebaka ne batasobola kugolokoka,
\q1 ne watabaawo n’omu asobola
\q2 okuyimusa omukono gwe.
\q1 
\v 6 Bw’obaboggolera, Ayi Katonda wa Yakobo,
\q2 abeebagala embalaasi ezisika ebigaali bagwiira wamu n’ebigaali ne batagolokoka.
\b
\q1 
\v 7 Ggwe ayi Katonda, osaanira okutiibwanga.
\q2 Ani ayinza okuyimirira mu maaso go ng’osunguwadde?
\q1 
\v 8 Osalira abantu emisango ng’osinziira mu ggulu,
\q2 ensi n’etya n’ekankana n’esirika olw’obusungu bwo,
\q1 
\v 9 bw’ogolokoka okusala omusango,
\q2 okuwonya ababonyaabonyezebwa mu nsi.
\q1 
\v 10 Bw’osunguwalira omuntu kikuleetera okutenderezebwa,
\q2 n’abo b’otasunguwalidde ne beegendereza.
\q1 
\v 11 Mweyame obweyamo bwammwe eri \nd Mukama\nd* Katonda wammwe, era mubutuukirizenga;
\q2 bonna abamuli okumpi bamuleetere ebirabo,
\q2 kubanga asaanidde okutiibwa.
\q1 
\v 12 \nd Mukama\nd* akkakkanya abalangira,
\q2 ne bakabaka b’ensi bamutya.
\c 77
\cl Zabbuli 77
\d Ya Mukulu wa Bayimbi. Zabbuli ya Asafu.
\q1 
\v 1 Nnaakaabirira Katonda ambeere,
\q2 ddala nnaakaabirira Katonda nga musaba ampulire.
\q1 
\v 2 Bwe nnali mu nnaku, nanoonya Mukama,
\q2 ekiro kyonna ne ngolola emikono gyange obutakoowa;
\q2 emmeeme yange neegaana okusanyusibwa.
\b
\q1 
\v 3 Nakujjukiranga, Ayi Katonda ne nsinda,
\q2 ne nfumiitiriza emmeeme yange n’ezirika.
\q1 
\v 4 Tewaŋŋanya kwebaka; natawaanyizibwa nnyo ne sisobola kwogera.
\q1 
\v 5 Ne ndowooza ku biseera eby’edda,
\q2 ne nzijukira emyaka egyayita.
\q1 
\v 6 Najjukiranga ennyimba zange ekiro,
\q2 ne nfumiitiriza nga bwe neebuuza mu mutima gwange nti:
\b
\q1 
\v 7 “Mukama anaatusuuliranga ddala ennaku zonna
\q2 naataddayo kutulaga kisa kye?
\q1 
\v 8 Okwagala kwe okutaggwaawo kukomedde ddala?
\q2 Kye yasuubiza kibulidde ddala emirembe n’emirembe?
\q1 
\v 9 Katonda yeerabidde ekisa kye?
\q2 Asunguwalidde ddala ne yeggyako n’okusaasira kwe?”
\b
\q1 
\v 10 Awo ne ndowooza nti, “Ebyo bye mmanyi
\q2 eby’emyaka emingi eby’omukono ogwa ddyo ogw’oyo Ali Waggulu Ennyo.”
\q1 
\v 11 Nnajjukiranga ebikolwa bya \nd Mukama\nd*,
\q2 weewaawo, nnajjukiranga ebyamagero byo eby’edda.
\q1 
\v 12 Nnaafumiitirizanga ku bikolwa byo byonna eby’amaanyi;
\q2 nnaalowoozanga ku byamagero byo byonna.
\q1 
\v 13 Ekkubo lyo, Ayi Katonda, liri mu watukuvu.
\q2 Tewali katonda yenkana Katonda waffe.
\q1 
\v 14 Ggwe Katonda akola eby’amagero;
\q2 era amaanyi go ogalaga mu mawanga.
\q1 
\v 15 Wanunula abantu bo n’omukono gwo,
\q2 abazzukulu ba Yakobo ne Yusufu.
\b
\q1 
\v 16 Amazzi gaakulaba, Ayi Katonda;
\q2 amazzi bwe gaakulaba ne gatya,
\q2 n’obuziba ne bukankanira ddala.
\q1 
\v 17 Ebire byayiwa amazzi
\q2 ne bivaamu n’okubwatuka,
\q2 era n’obusaale bwo ne bubuna.
\q1 
\v 18 Eddoboozi lyo ery’okubwatuka lyawulirwa mu kikuŋŋunta
\q2 okumyansa kwo ne kumulisa ensi.
\q2 Ensi n’ekankana n’enyeenyezebwa.
\q1 
\v 19 Ekkubo lyo lyali mu nnyanja;
\q2 wayita mu mazzi amangi,
\q2 naye ebigere mwe walinnya tebyalabika.
\b
\q1 
\v 20 Wakulembera abantu bo ng’ekisibo,
\q2 nga bali mu mikono gya Musa ne Alooni.
\c 78
\cl Zabbuli 78
\d Oluyimba lwa Asafu.
\q1 
\v 1 Muwulire okuyigiriza kwange mmwe abantu bange,
\q2 musseeyo omwoyo ku bye njogera.
\q1 
\v 2 Ndyogerera mu ngero,
\q2 njogere ebintu eby’ekyama ebyaliwo edda,
\q1 
\v 3 ebintu bye twawulira ne tumanya;
\q2 ebintu bajjajjaffe bye baatutegeeza.
\q1 
\v 4 Tetuubikisenga baana baabwe,
\q2 naye tunaabuuliranga buli mulembe ogunnaddangawo
\q1 ebikolwa bya \nd Mukama\nd* eby’ekitalo,
\q2 n’amaanyi ge n’ebyamagero bye yakola.
\q1 
\v 5 Yawa Yakobo ebiragiro,
\q2 n’ateeka amateeka mu Isirayiri;
\q1 n’alagira bajjajjaffe
\q2 babiyigirizenga abaana baabwe,
\q1 
\v 6 ab’omu mulembe oguliddirira nabo babimanye,
\q2 n’abaana abalizaalibwa,
\q2 nabo babiyigirize abaana baabwe,
\q1 
\v 7 balyoke beesigenga Katonda,
\q2 era balemenga okwerabira ebyo byonna Katonda bye yakola;
\q2 naye bagonderenga ebiragiro bye.
\q1 
\v 8 Baleme okuba nga bajjajjaabwe,
\q2 omulembe ogw’abakakanyavu
\q1 era abajeemu abatali bawulize,
\q2 ab’emyoyo egitali myesigwa eri Katonda.
\b
\q1 
\v 9 Abaana ba Efulayimu abaalina obusaale obw’okulwanyisa,
\q2 naye ne badduka mu lutalo,
\q1 
\v 10 tebaatuukiriza ndagaano ya Katonda;
\q2 ne bagaana okugondera amateeka ga \nd Mukama\nd*.
\q1 
\v 11 Beerabira ebyo bye yakola,
\q2 n’ebyamagero bye yabalaga.
\q1 
\v 12 Yakola ebyamagero mu maaso ga bajjajjaabwe nga bali
\q2 mu nsi y’e Misiri, mu kitundu kya Zowani.
\q1 
\v 13 Ennyanja yajaawulamu,
\q2 amazzi ne geetuuma ebbali n’ebbali ng’ebisenge.
\q1 
\v 14 Emisana yabakulemberanga n’ekire,
\q2 n’ekiro n’abakulemberanga n’empagi ey’omuliro.
\q1 
\v 15 Yayasa enjazi mu ddungu,
\q2 n’abawa amazzi amangi agaali ng’agava mu buziba bw’ennyanja.
\q1 
\v 16 Yaggya ensulo mu lwazi,
\q2 n’akulukusa amazzi ng’emigga.
\b
\q1 
\v 17 Naye bo ne beeyongera bweyongezi okwonoona,
\q2 ne bajeemera Oyo Ali Waggulu Ennyo nga bali mu ddungu.
\q1 
\v 18 Ne bagezesa Katonda mu bugenderevu,
\q2 nga bamusaba emmere gye baalulunkanira.
\q1 
\v 19 Era ne boogera ku Katonda; nga bagamba nti,
\q2 “Katonda asobola okutuliisiza mu ddungu?
\q1 
\v 20 Weewaawo yakuba olwazi,
\q2 amazzi ne gakulukuta ng’emigga;
\q1 naye anaatuwa emmere?
\q2 Anaawa abantu be ennyama?”
\q1 
\v 21 Awo \nd Mukama\nd* bwe yawulira ebyo n’asunguwala nnyo;
\q2 omuliro gwe ne gwaka ku Yakobo,
\q2 n’obusungu bwe ne bubuubuukira ku Isirayiri.
\q1 
\v 22 Kubanga tebakkiriza Katonda,
\q2 era tebeesiga maanyi ge agalokola.
\q1 
\v 23 Naye era n’alagira eggulu;
\q2 n’aggulawo enzigi z’omu ggulu.
\q1 
\v 24 N’abaweereza maanu okuva mu ggulu balye.
\q2 Yabawa emmere eyava mu ggulu.
\q1 
\v 25 Abantu ne balya emmere ya bamalayika;
\q2 \nd Mukama\nd* n’abawanga emmere nnyingi eyabamaliranga ddala.
\q1 
\v 26 N’akunsa empewo ey’Ebuvanjuba okuva mu ggulu,
\q2 era n’aweereza empewo okuva obukiika obwaddyo n’amaanyi ge.
\q1 
\v 27 Yatonnyesa ennyama okuva mu ggulu ennyingi ennyo ng’enfuufu;
\q2 n’abaweereza n’obunyonyi enkumu ennyo ng’omusenyu gw’okulubalama lw’ennyanja.
\q1 
\v 28 Ebyokulya ebyo n’abisuula wakati mu lusiisira lwabwe;
\q2 okwetooloola eweema zaabwe.
\q1 
\v 29 Awo ne balya ne bakkuta nnyo;
\q2 kubanga yabawa kye baali bayaayaanira.
\q1 
\v 30 Naye bwe baali nga bakyalulunkana,
\q2 nga n’emmere ekyali mu kamwa kaabwe,
\q1 
\v 31 obusungu bwa \nd Mukama\nd* ne bubabuubuukirako,
\q2 n’abattamu abasajja abasinga amaanyi;
\q2 abavubuka ba Isirayiri ne bazikirizibwa.
\b
\q1 
\v 32 Naye newaakubadde ebyo byonna byabatuukako, kyokka beeyongera okwonoona;
\q2 newaakubadde nga yabakolera ebyamagero, naye tebakkiriza.
\q1 
\v 33 \nd Mukama\nd* kyeyava asala ku myaka gyabwe,
\q2 n’abaleetako okuzikirizibwa okw’amangu era okw’entiisa.
\q1 
\v 34 Bwe yattanga abamu ku bo, ne balyoka bamunoonya,
\q2 ne beenenya ne badda gy’ali.
\q1 
\v 35 Ne bajjukira nti Katonda lwe Lwazi lwabwe;
\q2 era nti Katonda Ali Waggulu Ennyo ye Mununuzi waabwe.
\q1 
\v 36 Kyokka baamuwaananga n’emimwa gyabwe,
\q2 nga bwe bamulimba n’ennimi zaabwe,
\q1 
\v 37 so tebaali beesigwa mu mitima gyabwe,
\q2 era nga tebatuukiriza ndagaano ye.
\q1 
\v 38 Naye ye n’abakwatirwanga ekisa
\q2 n’abasonyiwanga,
\q2 n’atabazikiriza;
\q1 emirundi n’emirundi ng’akoma ku busungu bwe,
\q2 n’atabamalirako kiruyi kye okubazikiririza ddala.
\q1 
\v 39 Yajjukira nga baali mubiri bubiri;
\q2 ng’empewo egenda n’etedda!
\b
\q1 
\v 40 Baamujeemeranga nnyo bwe baali mu ddungu;
\q2 ne banakuwaza nnyo omutima gwe.
\q1 
\v 41 Ne baddamu ne bakema Katonda,
\q2 ne banyiiza Omutukuvu wa Isirayiri.
\q1 
\v 42 Tebajjukira buyinza bwe;
\q2 wadde olunaku lwe yabanunulirako mu mikono gy’omulabe;
\q1 
\v 43 bwe yalaga obubonero bwe mu Misiri,
\q2 n’ebyamagero bye mu kitundu kya Zowani,
\q1 
\v 44 yafuula amazzi g’emigga gyabwe omusaayi,
\q2 ne batanywa mazzi gaagyo.
\q1 
\v 45 Yabaweereza agabinja g’ensowera ne zibaluma,
\q2 n’abaweereza n’ebikere ne bibadaaza.
\q1 
\v 46 Ebirime n’ebibala byabwe yabiwa enzige
\q2 ne bulusejjera.
\q1 
\v 47 Yazikiriza emizabbibu gyabwe n’omuzira,
\q2 era ne gukuba n’emisukomooli gyabwe.
\q1 
\v 48 Yatta ente zaabwe n’amayinja g’omuzira;
\q2 n’ebisibo byabwe ne bittibwa eraddu.
\q1 
\v 49 Obusungu bwe obungi bwababuubuukirako,
\q2 n’ekiruyi kye n’obukambwe ne bibamalamu ensa.
\q2 N’alyoka abasindikira ekibinja kya bamalayika okubazikiriza.
\q1 
\v 50 Yabalaga obusungu bwe,
\q2 n’atabasonyiwa kufa,
\q2 n’abasindikira kawumpuli.
\q1 
\v 51 Yatta ababereberye bonna ab’omu Misiri,
\q2 nga be bavubuka ab’ebibala ebibereberye eby’omu nnyumba ya Kaamu.
\q1 
\v 52 N’alyoka afulumya abantu be ng’endiga,
\q2 n’abatambuza mu ddungu ng’ekisibo.
\q1 
\v 53 N’abaluŋŋamya mu mirembe nga tebatya,
\q2 ennyanja n’esaanyaawo abalabe baabwe.
\q1 
\v 54 N’abatuusa ku nsalo y’ensi entukuvu;
\q2 ku lusozi lwe yeewangulira, n’omukono gwe ogwa ddyo.
\q1 
\v 55 Yagobamu amawanga nga balaba,
\q2 n’abagabanyiza ebitundu by’ensi eyo;
\q2 n’atuuza bulungi ebika bya Isirayiri mu maka gaabyo.
\q1 
\v 56 Naye era ne bakema Katonda;
\q2 ne bamujeemera oyo Ali Waggulu Ennyo,
\q2 ne bagaana okugondera ebiragiro bye.
\q1 
\v 57 Ne bamuvaako ne baba bakuusa nga bajjajjaabwe bwe baali,
\q2 ne baggwaamu obwesigwa ng’omutego gw’obusaale omukyamu.
\q1 
\v 58 Kubanga baasunguwaza Katonda olw’ebifo ebigulumivu bo bye beegunjira okusinzizangamu,
\q2 ne bamukwasa obuggya olwa bakatonda baabwe abalala.
\q1 
\v 59 Katonda bwe yabiraba n’asunguwala nnyo, n’aviira ddala ku Isirayiri.
\q1 
\v 60 N’ava mu weema ey’omu Siiro\f + \fr 78:60 \fq Siiro \ft kye kyali ekifo ekitukuvu awasinzibwanga edda mu biro bya Yoswa. Kyali mu bitundu bya Efulayimu wakati wa Beseri ne Sekemu. Essanduuko y’Endagaano yaterekebwanga eyo okutuusa mu biro bya Samwiri; kyokka Abafirisuuti baakizikiriza\f*,
\q2 eweema mwe yabeeranga ng’ali mu bantu be.
\q1 
\v 61 N’awaayo amaanyi ge mu busibe,
\q2 n’ekitiibwa kye n’akiwaayo eri omulabe.
\q1 
\v 62 Abantu be yabaleka ne battibwa n’ekitala,
\q2 n’asunguwalira omugabo gwe.
\q1 
\v 63 Omuliro ne gusaanyaawo abavubuka baabwe abalenzi,
\q2 ne bawala baabwe ne babulwa ow’okubawasa.
\q1 
\v 64 Bakabona baabwe battibwa n’ekitala, ne bannamwandu baabwe tebaasobola kubakungubagira.
\b
\q1 
\v 65 Awo Mukama n’alyoka agolokoka ng’ali nga ava mu tulo,
\q2 ng’omusajja omuzira azuukuka mu tulo ng’atamidde.
\q1 
\v 66 N’akuba abalabe be ne badduka;
\q2 n’abaswaza emirembe gyonna.
\q1 
\v 67 \nd Mukama\nd* yaleka ennyumba ya Yusufu,
\q2 n’ekika kya Efulayimu n’atakironda;
\q1 
\v 68 naye n’alonda ekika kya Yuda,
\q2 lwe lusozi Sayuuni lwe yayagala.
\q1 
\v 69 N’azimba awatukuvu we ne wagulumira ng’ensozi empanvu;
\q2 ne waba ng’ensi gye yanyweza emirembe gyonna.
\q1 
\v 70 Yalonda Dawudi omuweereza we;
\q2 n’amuggya mu kulunda endiga.
\q1 
\v 71 Ave mu kuliisa endiga,
\q2 naye alundenga Yakobo, be bantu be,
\q2 era alabirirenga Isirayiri omugabo gwe, gwe yeerondera.
\q1 
\v 72 N’abalabirira n’omutima ogutaliimu bukuusa,
\q2 n’abakulembera n’amagezi g’emikono gye.
\c 79
\cl Zabbuli 79
\d Zabbuli ya Asafu.
\q1 
\v 1 Ayi Katonda omugabo gwo gulumbiddwa amawanga;
\q2 boonoonye yeekaalu yo entukuvu ne Yerusaalemi kizikiriziddwa,
\q2 ne kifuuka entuumo.
\q1 
\v 2 Emirambo gy’abaweereza bo bagifudde
\q2 mmere ya nnyonyi ez’omu bbanga,
\q2 n’emibiri gy’abatukuvu bo giweereddwa ensolo ez’omu nsiko.
\q1 
\v 3 Omusaayi gwabwe ne guyiibwa ng’amazzi
\q2 okwetooloola Yerusaalemi,
\q2 so nga abafudde tewali muntu abaziika.
\q1 
\v 4 Baliraanwa baffe batuyisaamu amaaso,
\q2 era tufuuse ekisekererwa eri abo abatwetoolodde.
\b
\q1 
\v 5 Ayi \nd Mukama\nd* olitusunguwalira kutuusa ddi, nnaku zonna?
\q2 Obuggya bwo bunaabuubuukanga ng’omuliro?
\q1 
\v 6 Obusungu bwo bubuubuukire ku mawanga
\q2 agatakumanyi,
\q1 ne ku bwakabaka
\q2 obutakoowoola linnya lyo.
\q1 
\v 7 Kubanga bazikirizza Yakobo,
\q2 ne basaanyaawo ensi ye.
\b
\q1 
\v 8 Totubalira kibi kya bajjajjaffe;
\q2 tukusaba oyanguwe okutusaasira
\q2 kubanga tuli mu bwetaavu bungi nnyo.
\q1 
\v 9 Tuyambe olw’ekitiibwa ky’erinnya lyo,
\q2 Ayi Katonda ow’obulokozi bwaffe;
\q1 otuwonye era otutangiririre olw’ebibi byaffe
\q2 olw’erinnya lyo.
\q1 
\v 10 Lwaki abamawanga babuuza nti,
\q2 “Katonda waabwe ali ludda wa?”
\b
\q1 Kkiriza okuwalana eggwanga olw’omusaayi gw’abaweereza bo ogwayiyibwa,
\q2 kumanyibwe mu mawanga gonna nga naffe tulaba.
\q1 
\v 11 Wuliriza okusinda kw’omusibe;
\q2 okozese omukono gwo ogw’amaanyi
\q2 owonye abo abasaliddwa ogw’okufa.
\q1 
\v 12 Ayi Mukama, baliraanwa baffe abakuduulira,
\q2 bawalane emirundi musanvu.
\q1 
\v 13 Kale nno, ffe abantu bo era endiga ez’omu ddundiro lyo,
\q2 tulyoke tukutenderezenga emirembe gyonna;
\q2 buli mulembe gulyoke gukutenderezenga emirembe gyonna.
\c 80
\cl Zabbuli 80
\d Ya Mukulu wa Bayimbi. Ku ddoboozi, “Amalanga g’Endagaano.” Zabbuli ya Asafu.
\q1 
\v 1 Wulira, Ayi Omusumba wa Isirayiri;
\q2 ggwe akulembera Yusufu ng’alunda ekisibo kyo;
\q1 ggwe atudde ku ntebe ey’obwakabaka mu bakerubi, twakire.
\q2 
\v 2 Amaanyi go galabike mu Efulayimu,
\q1 ne mu Benyamini ne mu Manase,\f + \fr 80:2 \ft Ebika ebyo ebisatu, bazzukulu ba Lakeeri; baagoberera Essanduuko y’Endagaano nga bakumba okulaga mu nsi ensuubize.\f*
\q2 ojje otulokole.
\b
\q1 
\v 3 Tukomyewo gy’oli, Ayi Katonda,
\q2 otutunuulize amaaso ag’ekisa,
\q2 otulokole.
\b
\q1 
\v 4 Ayi Katonda, \nd Mukama\nd* ow’Eggye,
\q2 olituusa ddi okusunguwalira okusaba kw’abantu bo?
\q1 
\v 5 Wabaliisa emmere ejjudde amaziga;
\q2 n’obanywesa ebikopo by’amaziga musera.
\q1 
\v 6 Otufudde eky’okusekererwa mu baliraanwa baffe,
\q2 n’abalabe baffe ne batuduulira.
\b
\q1 
\v 7 Tukomyewo gy’oli, Ayi \nd Mukama\nd* ow’Eggye,
\q2 otutunuulize amaaso go ag’ekisa,
\q2 tulokolebwe.
\b
\q1 
\v 8 Waleeta omuzabbibu ng’oguggya mu Misiri;
\q2 n’ogobamu amawanga agaali mu nsi muno n’ogusimba.
\q1 
\v 9 Wagulongooseza ettaka, ne gumera,
\q2 emirandira ne ginywera bulungi, ne gwagaagala mu nsi.
\q1 
\v 10 Ekisiikirize kyagwo ne kibikka ensozi,
\q2 n’amatabi gaagwo ne gaba ng’emivule egy’amaanyi.
\q1 
\v 11 Amatabi gaagwo ne gatuuka ku Nnyanja eya Wakati
\q2 n’amatabi g’ennyanja gaayo ne gatuuka ku Mugga Fulaati.
\b
\q1 
\v 12 Kale wamenyera ki ebisenge byagwo,
\q2 abayitawo bonna ne beenogera ebibala byagwo?
\q1 
\v 13 Embizzi ez’omu kibira zigwonoona,
\q2 na buli nsolo ey’omu nsiko egulya.
\q1 
\v 14 Tukyukire, Ayi Katonda ow’Eggye,
\q2 otunuulire ensi ng’osinziira mu ggulu;
\q1 olabirire omuzabbibu guno.
\q2 
\v 15 Gwe wagwesimbira n’omukono gwo ogwa ddyo,
\q2 era ggwe weerondera omwana wo.
\b
\q1 
\v 16 Bagutemye, ne bagwokya omuliro;
\q2 abakoze ekyo banenye mu bukambwe, obazikirize.
\q1 
\v 17 Naye muwe amaanyi omusajja oyo gw’oyagala
\q2 era omwana oyo gwe weerondera.
\q1 
\v 18 Bwe tutyo tuleme okukuvaako, n’okukukuba amabega.
\q2 Otuzzeemu amaanyi, naffe tunaakoowoolanga erinnya lyo.
\b
\q1 
\v 19 Otukomyewo gy’oli, Ayi \nd Mukama\nd* Katonda ow’Eggye,
\q2 otutunuulize amaaso go ag’ekisa,
\q2 tulyoke tulokolebwe.
\c 81
\cl Zabbuli 81
\d Ya Mukulu wa Bayimbi. Zabbuli ya Asafu.
\q1 
\v 1 Mumuyimbire nnyo n’essanyu Katonda amaanyi gaffe;
\q2 muyimuse waggulu amaloboozi gammwe eri Katonda wa Yakobo!
\q1 
\v 2 Mutandike okuyimba, mukube ebitaasa
\q2 n’ennanga evuga obulungi ey’enkoba awamu n’entongooli.
\q1 
\v 3 Mufuuwe eŋŋombe ng’omwezi gwakaboneka,
\q2 era mugifuuwe nga gwa ggabogabo, ku lunaku olw’embaga yaffe.
\q1 
\v 4 Ekyo kye kiragiro eri Isirayiri,
\q2 lye tteeka lya Katonda wa Yakobo.
\q1 
\v 5 Yaliteekera Yusufu,
\q2 Katonda bwe yalumba ensi ya Misiri;
\q2 gye nawulirira olulimi olwannema okutegeera.
\b
\q1 
\v 6 “Nnamutikkula omugugu okuva ku kibegabega kye;
\q2 n’emikono gye ne ngiwummuza okusitula ebisero.
\q1 
\v 7 Mwankoowoola nga muli mu nnaku ne mbadduukirira ne mbawonya,
\q2 nabaanukulira mu kubwatuka mu kire;
\q2 ne mbagezesa ku mazzi ag’e Meriba.
\q1 
\v 8 Muwulire, mmwe abantu bange, nga mbalabula.
\q2 Singa onompuliriza, ggwe Isirayiri!
\q1 
\v 9 Temubeeranga na katonda mulala,
\q2 wadde okuvuunamira katonda omulala yenna.
\q1 
\v 10 Nze \nd Mukama\nd* Katonda wo,
\q2 eyakuggya mu nsi y’e Misiri.
\q2 Yasamya akamwa ko, nange nnaakajjuza.
\b
\q1 
\v 11 “Naye abantu bange tebampuliriza;
\q2 Isirayiri teyaŋŋondera.
\q1 
\v 12 Nange ne mbawaayo eri obujeemu bw’omutima gwabwe,
\q2 okugoberera ebyo bye baagala.
\b
\q1 
\v 13 “Singa abantu bange bampuliriza;
\q2 singa Isirayiri agondera ebiragiro byange,
\q1 
\v 14 mangwago nandirwanyisizza abalabe baabwe,
\q2 ne mbawangula.
\q1 
\v 15 Abo abakyawa \nd Mukama\nd* ne beegonza gy’ali;
\q2 ekibonerezo kyabwe kya mirembe gyonna.
\q1 
\v 16 Naye ggwe, Isirayiri, nandikuliisizza eŋŋaano esingira ddala obulungi,
\q2 ne nkukkusa omubisi gw’enjuki nga guva mu lwazi.”
\c 82
\cl Zabbuli 82
\d Zabbuli ya Asafu.
\q1 
\v 1 Katonda akubiriza olukiiko lwe olukulu olw’omu ggulu,
\q2 ng’alamula bakatonda.
\b
\q1 
\v 2 Mulituusa ddi okusala emisango n’obukuusa,
\q2 nga musalira abanafu?
\q1 
\v 3 Abanafu n’abatalina bakitaabwe mubalamulenga mu bwenkanya;
\q2 abaavu n’abanyigirizibwa mubayambenga mu bwenkanya.
\q1 
\v 4 Mulwanirire abatalina maanyi n’abali mu kwetaaga, mubawonye;
\q2 mubanunule nga mubaggya mu mikono gy’ababi.
\b
\q1 
\v 5 Tebalina kye bamanyi, era tebategeera.
\q2 Batambulira mu kizikiza;
\q2 emisingi gy’ensi gyonna ginyeenyezebwa.
\b
\q1 
\v 6 Njogedde nti, Muli bakatonda,
\q2 era mwenna muli baana b’oyo Ali Waggulu Ennyo.
\q1 
\v 7 “Naye mugenda kufa ng’abantu obuntu;
\q2 muliggwaawo ng’abafuzi abalala bonna bwe baggwaawo.”
\b
\q1 
\v 8 Ogolokoke, Ayi Katonda, olamule ensi;
\q2 kubanga amawanga gonna gago.
\c 83
\cl Zabbuli 83
\d Oluyimba. Zabbuli ya Asafu.
\q1 
\v 1 Ayi Katonda, tosirika busirisi n’etebaayo kanyego.
\q2 Tosirika, Ayi Katonda, n’otobaako ky’okola.
\q1 
\v 2 Wuliriza oluyoogaano oluva mu balabe bo;
\q2 abo abaagala okukulwanyisa bali mu keetalo.
\q1 
\v 3 Bateesa n’obujagujagu okulumba abantu bo;
\q2 basalira enkwe abo b’oyagala ennyo.
\q1 
\v 4 Bagamba nti, “Mujje eggwanga lyabwe tulizikirize,
\q2 n’erinnya lya Isirayiri lireme okujjukirwanga emirembe gyonna!”
\b
\q1 
\v 5 Basala olukwe n’omwoyo gumu;
\q2 beegasse wamu bakulwanyise.
\q1 
\v 6 Abantu b’omu weema za Edomu, n’ez’Abayisimayiri,
\q2 n’eza Mowaabu, n’Abakagale;
\q1 
\v 7 Gebali ne Amoni, ne Amaleki,
\q2 n’Abafirisuuti n’abantu b’omu Ttuulo.
\q1 
\v 8 Era ne Asiriya yeegasse nabo,
\q2 okuyamba bazzukulu ba Lutti.
\b
\q1 
\v 9 Bakoleko nga bwe wakola Midiyaani,
\q2 era nga bwe wakola Sisera ne Yabini\f + \fr 83:9 \fq Yabini \ft yali kabaka w’Abakanani, ate nga Sisera mutabani we. Yawangulibwa Debola\f* ku mugga Kisoni,
\q1 
\v 10 abaazikiririra mu Endoli
\q2 ne bafuuka ng’obusa ku ttaka.
\q1 
\v 11 Abakungu baabwe bafuule nga Olebu ne Zeebu,\f + \fr 83:11 \fq Olebu ne Zeebu \ft baali bakabaka b’Abamidiyaani, Gidyoni be yawangula\f*
\q2 n’abalangira baabwe bonna bafuuke nga Zeba ne Zalumunna,
\q1 
\v 12 abaagamba nti, “Ka tutwale
\q2 amalundiro ga Katonda, tugeefunire.”
\b
\q1 
\v 13 Ayi Katonda wange, bafuumuule ng’enfuufu,
\q2 obasaasaanye ng’ebisusunku mu mbuyaga.
\q1 
\v 14 Ng’omuliro bwe gwokya ekibira;
\q2 n’ennimi z’omuliro ne zikoleeza ensozi,
\q1 
\v 15 naawe bw’otyo bw’oba obawondera n’omuyaga gwo,
\q2 obatiise ne kibuyaga wo ow’amaanyi.
\q1 
\v 16 Baswaze nnyo,
\q2 balyoke banoonyenga erinnya lyo, Ayi \nd Mukama\nd*.
\b
\q1 
\v 17 Bajjule ensonyi n’okutya,
\q2 bazikirire nga baswadde nnyo.
\q1 
\v 18 Balyoke bategeere nti, Ggwe wekka, Ayi \nd Mukama\nd*, ggw’oyitibwa \em Yakuwa\em*,
\q2 gw’obeera waggulu ennyo ng’ofuga ensi yonna.
\c 84
\cl Zabbuli 84
\d Ya Mukulu wa Bayimbi. Zabbuli ya Batabani ba Koola.
\q1 
\v 1 Eweema zo nga nnungi,
\q2 Ayi \nd Mukama\nd* ow’Eggye!
\q1 
\v 2 Omwoyo gwange guyaayaana,
\q2 gwagala na kuzirika,
\q1 olw’empya za \nd Mukama\nd*,
\q2 omutima gwange n’omubiri gwange bikoowoola Katonda omulamu.
\q1 
\v 3 Weewaawo,
\q2 ne nkazaluggya yeekoledde ekisu,
\q2 n’akataayi ennyumba mwe binaakulizanga abaana baabyo
\q1 awo okumpi n’Ebyoto byo,
\q2 Ayi \nd Mukama\nd* Ayinzabyonna, Kabaka wange, era Katonda wange.
\q1 
\v 4 Balina omukisa ababeera mu nnyumba yo,
\q2 banaakutenderezanga.
\b
\q1 
\v 5 Alina omukisa omuntu eyeesiga amaanyi go,
\q2 era assaayo omwoyo okutambulira mu makubo go.
\q1 
\v 6 Bayita mu kiwonvu Baka,
\q2 ne bakifuula ekifo ky’ensulo;
\q2 n’enkuba ya ddumbi n’ejjuza ebidiba byakyo.
\q1 
\v 7 Bagenda beeyongera amaanyi,
\q2 okutuusa lwe batuuka mu maaso ga Katonda mu Sayuuni.
\b
\q1 
\v 8 Wulira okusaba kwange, Ayi \nd Mukama\nd* Katonda ow’Eggye;
\q2 mpuliriza, Ayi Katonda wa Yakobo.
\q1 
\v 9 Ayi Katonda, Engabo yaffe,
\q2 tunuulira kabaka wo n’okusaasira oyo gwe wafukako amafuta.
\b
\q1 
\v 10 Okumala olunaku olumu mu mpya zo,
\q2 kisinga okubeera emyaka olukumi mu bifo ebirala.
\q1 Njagala okuba omuggazi mu nnyumba ya Katonda wange,
\q2 okusinga okubeeranga mu weema z’abakola ebibi.
\q1 
\v 11 Kubanga \nd Mukama\nd* Katonda ye njuba yaffe era ye ngabo yaffe;
\q2 atuwa emikisa gye awamu n’ekitiibwa;
\q1 tewaliiwo kirungi na kimu ky’ataawa
\q2 abo abatambulira mu makubo ge nga tebaliiko kyakunenyezebwa.
\b
\q1 
\v 12 Ayi \nd Mukama\nd* ow’Eggye
\q2 alina omukisa omuntu akwesiga.
\c 85
\cl Zabbuli 85
\d Ya Mukulu wa Bayimbi. Zabbuli ya Batabani ba Koola.
\q1 
\v 1 Ensi yo ogikoledde ebyekisa Ayi \nd Mukama\nd*;
\q2 Yakobo omuddizza ebibye.
\q1 
\v 2 Abantu bo obasonyiye ebyonoono byabwe,
\q2 n’ebibi byabwe byonna n’obibikkako.
\q1 
\v 3 Ekiruyi kyo kyonna okirese,
\q2 n’oleka n’obusungu bwo obubuubuuka.
\b
\q1 
\v 4 Tukomyewo gy’oli, Ayi Katonda w’obulokozi bwaffe,
\q2 oleke okutusunguwalira.
\q1 
\v 5 Onootusunguwaliranga emirembe gyonna?
\q2 Onootunyiigiranga emirembe n’emirembe?
\q1 
\v 6 Tolituzaamu ndasi,
\q2 abantu bo basanyukirenga mu ggwe?
\q1 
\v 7 Tulage okwagala kwo okutaggwaawo Ayi Katonda,
\q2 era otuwe obulokozi bwo.
\b
\q1 
\v 8 Nnaawulirizanga \nd Mukama\nd* Katonda by’agamba;
\q2 asuubiza abantu be, be batukuvu be, okubawa emirembe;
\q2 naye tebaddayo mu byonoono byabwe.
\q1 
\v 9 Ddala ddala obulokozi bwe busemberera abo abamutya,
\q2 ensi yaffe n’eryoka ejjula ekitiibwa kye.
\b
\q1 
\v 10 Okwagala n’obwesigwa bisisinkanye;
\q2 obutuukirivu n’emirembe binywegeraganye.
\q1 
\v 11 Obwesigwa bulose mu nsi,
\q2 n’obutukuvu ne butunuulira ensi nga businzira mu ggulu.
\q1 
\v 12 Ddala ddala Katonda anaatuwanga ebirungi,
\q2 n’ensi yaffe eneebalanga ebibala bingi.
\q1 
\v 13 Obutuukirivu bunaamukulemberanga,
\q2 era bunaateekateekanga ekkubo mw’anaayitanga.
\c 86
\cl Zabbuli 86
\d Okusaba kwa Dawudi.
\q1 
\v 1 Otege okutu kwo, Ayi \nd Mukama\nd*, owulire okusaba kwange, onnyanukule,
\q2 kubanga ndi mwavu atalina kintu.
\q1 
\v 2 Okuume obulamu bwange, kubanga nkuweereza n’obwesigwa.
\q2 Katonda wange, ondokole
\q2 nze omuddu wo akwesiga.
\q1 
\v 3 Onsaasire, Ayi Mukama,
\q2 kubanga olunaku lwonna nsiiba nkukoowoola.
\q1 
\v 4 Osanyuse omuweereza wo Ayi Mukama;
\q2 kubanga omwoyo gwange
\q2 nguyimusa eyo gy’oli.
\b
\q1 
\v 5 Ddala ddala olina ekisa era osonyiwa, Ayi Mukama;
\q2 n’abo bonna abakukoowoola obaagala nnyo.
\q1 
\v 6 Owulire okusaba kwange, Ayi \nd Mukama\nd*;
\q2 owulirize eddoboozi erikaabirira ekisa kyo.
\q1 
\v 7 Bwe nnaabanga mu buzibu nnaakukoowoolanga;
\q2 kubanga ononnyanukulanga.
\b
\q1 
\v 8 Mu bakatonda bonna tewali ali nga ggwe, Ayi Mukama;
\q2 era teriiyo akola bikolwa ng’ebibyo.
\q1 
\v 9 Ayi Mukama amawanga gonna ge watonda
\q2 ganajjanga mu maaso go ne gakusinza;
\q2 era ne bagulumiza erinnya lyo ery’ekitiibwa.
\q1 
\v 10 Kubanga oli mukulu, era okola ebyewunyisa;
\q2 ggwe wekka ggwe Katonda.
\b
\q1 
\v 11 Onjigirize ekkubo lyo, Ayi \nd Mukama\nd*,
\q2 ntambulirenga mu mazima go;
\q1 ompe omutima omunywevu ogutasagaasagana,
\q2 ntyenga erinnya lyo.
\q1 
\v 12 Nnaakutenderezanga, Ayi Mukama Katonda wange, n’omutima gwange gwonna;
\q2 erinnya lyo nnaaligulumizanga emirembe gyonna.
\q1 
\v 13 Okwagala kwo okutaggwaawo kungi nnyo gye ndi;
\q2 wawonya omwoyo gwange amagombe.
\b
\q1 
\v 14 Ayi Katonda, ab’amalala bannumba,
\q2 ekibinja ky’abantu abataliimu kusaasira bannoonya okunzita,
\q2 be bantu abatakufiirako ddala.
\q1 
\v 15 Naye ggwe, Mukama Katonda oli musaasizi era ow’ekisa,
\q2 olwawo okusunguwala, ojjudde okwagala n’obwesigwa.
\q1 
\v 16 Onkyukire, onsaasire,
\q2 ompe amaanyi go nze omuweereza wo;
\q2 nze omwana w’omuweereza wo omukazi ondokole.
\q1 
\v 17 Nkolera akabonero akalaga ebirungi byo,
\q2 abalabe bange bakalabe baswale;
\q2 kubanga ggwe, Ayi \nd Mukama\nd*, onnyambye era onzizizzaamu amaanyi.
\c 87
\cl Zabbuli 87
\d Zabbuli ya Batabani ba Koola. Oluyimba.
\q1 
\v 1 Atadde emisingi gye ku lusozi olutukuvu.
\q2 
\v 2 \nd Mukama\nd* ayagala emiryango gya Sayuuni
\q2 okusinga ennyumba zonna eza Yakobo.
\b
\q1 
\v 3 Ebintu eby’ekitiibwa bikwogerwako,
\q2 ggwe ekibuga kya Katonda.
\q1 
\v 4 “Mu mawanga ge mmanyi mwe muli Lakabu,
\q2 ne Babulooni;
\q1 era ndyogera ku Bufirisuuti, ne ku Ttuulo
\q2 ne ku Esiyopya nti, ‘Ono yazaalirwa mu Sayuuni.’ ”
\q1 
\v 5 Bwe baliba boogera ku Sayuuni baligamba nti,
\q2 “Ono n’oli baazaalirwa omwo,”
\q2 n’oyo Ali Waggulu Ennyo alikinyweza.
\q1 
\v 6 \nd Mukama\nd* aliwandiika mu kitabo bw’ati,
\q2 omuli amannya g’abantu nti, “Ono yazaalibwa omwo.”
\b
\q1 
\v 7 Banaakubanga ebivuga nga bwe bayimba nti,
\q2 “Ensulo zange zonna ziri mu ggwe.”
\c 88
\cl Zabbuli 88
\d Ya Mukulu wa Bayimbi. Zabbuli ya Batabani ba Koola.
\q1 
\v 1 Ayi \nd Mukama\nd* Katonda, Omulokozi wange,
\q2 nkaaba emisana n’ekiro mu maaso go.
\q1 
\v 2 Kkiriza okusaba kwange kutuuke gy’oli;
\q2 otege okutu kwo nga nkukoowoola.
\b
\q1 
\v 3 Kubanga emmeeme yange ejjudde ebizibu,
\q2 era nsemberedde okufa.
\q1 
\v 4 Mbalirwa mu abo abaserengeta emagombe;
\q2 nfaanana ng’omuntu atalina maanyi.
\q1 
\v 5 Bandese wano ng’afudde,
\q2 nga ndi ng’abo be basse abalinda obulinzi entaana,
\q1 nga tokyaddayo kubajjukira,
\q2 era nga tewakyali kya kubakolera.
\b
\q1 
\v 6 Ontadde mu kinnya ekisinga obuwanvu,
\q2 era eky’ekizikiza ekikutte ennyo.
\q1 
\v 7 Obusungu bwo bumbuubuukiddeko nnyo,
\q2 ng’ennyanja esiikuuse n’amayengo gaayo ne gankuba okusukkirira.
\q1 
\v 8 Ab’emikwano abasingira ddala okunjagala obammazeeko,
\q2 n’onfuula ekyenyinyalwa gye bali.
\q1 Nsibiddwa, so sisobola kwesumattula.
\q2 
\v 9 Amaaso gange gayimbadde olw’ennaku.
\b
\q1 Nkukoowoola buli lunaku, Ayi \nd Mukama\nd*,
\q2 ne ngolola emikono gyange gy’oli nga nkwegayirira.
\q1 
\v 10 Ebyamagero byo onoobikoleranga bafu?
\q2 Abafudde banaagolokokanga ne bakutendereza?
\q1 
\v 11 Okwagala kwo onookulaganga abali emagombe
\q2 n’obwesigwa bwo abo abali mu kifo eky’okuzikirira?
\q1 
\v 12 Ebyamagero byo binaamanyibwanga mu kifo ekyo eky’ekizikiza?
\q2 Oba ebikolwa byo eby’obutuukirivu bwo bye binaamanyibwanga mu nsi eyamala edda okwerabirwa?
\b
\q1 
\v 13 Naye nze, Ayi \nd Mukama\nd*, naakabiriranga ggwe okunnyamba;
\q2 buli nkya okusaba kwange kunaatuukanga gy’oli.
\q1 
\v 14 Ayi \nd Mukama\nd*, onsuulidde ki?
\q2 Onkwekedde ki amaaso go?
\b
\q1 
\v 15 Ombonyaabonyezza okuviira ddala mu buvubuka bwange, era nga mbeera kumpi n’okufa;
\q2 ngumiikirizza nnyo entiisa yo, era kaakano mpweddemu essuubi.
\q1 
\v 16 Obusungu bwo obubuubuuka bunzigwereddeko era bunzikkiriza.
\q2 Entiisa yo tendeseemu ka buntu.
\q1 
\v 17 Binzingiza nga mukoka olunaku lwonna;
\q2 binsaanikiridde ddala.
\q1 
\v 18 Ommazeeko ab’emikwano n’abo abanjagala ennyo;
\q2 nsigazza nzikiza yokka.
\c 89
\cl Zabbuli 89
\d Endagaano ya Katonda ne Dawudi.
\q1 
\v 1 Nnaayimbanga ku kwagala kwo okungi, Ayi \nd Mukama\nd*, emirembe gyonna.
\q2 Nnaatenderezanga obwesigwa bwo n’akamwa kange, bumanyibwe ab’emirembe gyonna.
\q1 
\v 2 Ddala ddala nnaategeezanga nti okwagala kwo tekuggwaawo ennaku zonna;
\q2 n’obwesigwa bwo bunywevu ng’eggulu.
\q1 
\v 3 Nakola endagaano n’omulonde wange;
\q2 nalayirira omuweereza wange Dawudi nti,
\q1 
\v 4 “Ezadde lyo nnaalinywezanga ennaku zonna,
\q2 era entebe yo ey’obwakabaka nnaaginywezanga emirembe gyonna.”
\b
\q1 
\v 5 Eggulu linaatenderezanga ebyamagero byo n’obwesigwa bwo,
\q2 Ayi \nd Mukama\nd*, mu kibiina ky’abatukuvu bo.
\q1 
\v 6 Kale, mu ggulu waggulu, ani ageraageranyizika ne \nd Mukama\nd*?
\q2 Ani afaanana nga \nd Mukama\nd*, mu abo ababeera mu ggulu?
\q1 
\v 7 Katonda atiibwa nnyo mu lukiiko olw’abatukuvu;
\q2 era wa ntiisa okusinga bonna abamwetooloola.
\q1 
\v 8 Ayi \nd Mukama\nd* Katonda ow’Eggye, ani akufaanana?
\q2 Oli wa buyinza, Ayi \nd Mukama\nd*, ojjudde obwesigwa.
\q1 
\v 9 Ggwe ofuga amalala g’ennyanja;
\q2 amayengo gaayo bwe geekuluumulula ogakkakkanya.
\q1 
\v 10 Lakabu wamubetentera ddala;
\q2 abalabe bo n’obasaasaanya n’omukono gwo ogw’amaanyi.
\q1 
\v 11 Eggulu liryo, n’ensi yiyo;
\q2 ensi yonna gwe wagitonda ne byonna ebigirimu.
\q1 
\v 12 Watonda obukiikakkono n’obukiikaddyo;
\q2 ensozi Taboli ne Kerumooni zitendereza erinnya lyo.
\q1 
\v 13 Oli wa buyinza bungi nnyo; omukono gwo gwa maanyi,
\q2 omukono gwo ogwa ddyo gunaagulumizibwanga.
\b
\q1 
\v 14 Obutuukirivu n’obwenkanya gwe musingi gw’obwakabaka bwo.
\q2 Okwagala n’obwesigwa bye binaakukulemberanga.
\q1 
\v 15 Balina omukisa abantu abamanyi okukutendereza \nd Mukama\nd* n’amaloboozi ag’essanyu;
\q2 Ayi \nd Mukama\nd*, banaatambuliranga mu ssanyu lyo.
\q1 
\v 16 Banaasanyukiranga mu linnya lyo okuzibya obudde,
\q2 n’obutuukirivu bwo banaabugulumizanga.
\q1 
\v 17 Kubanga gw’obawa amaanyi ne bafuna ekitiibwa.
\q2 Olw’okwagala kwo otutuusa ku buwanguzi olw’ekisa kyo.
\q1 
\v 18 Ddala ddala, \nd Mukama\nd* ye ngabo yaffe,
\q2 Omutukuvu wa Isirayiri kabaka waffe.
\b
\q1 
\v 19 Mu biro biri eby’edda wayogera n’omuweereza wo
\q2 omwesigwa mu kwolesebwa nti, Ngulumizizza omuzira ow’amaanyi;
\q1 ngulumizizza omuvubuka
\q2 okuva mu bantu abaabulijjo.
\q1 
\v 20 Nalaba Dawudi, omuweereza wange;
\q2 ne mufukako amafuta gange amatukuvu okuba kabaka.
\q1 
\v 21 Nnaamukulemberanga,
\q2 n’omukono gwange gunaamunywezanga.
\q1 
\v 22 Tewaliba mulabe we alimuwangula,
\q2 so n’aboonoonyi tebaamunyigirizenga.
\q1 
\v 23 Abalabe be n’abamukyawa ndibamerengula,
\q2 n’amaggye agamulwanyisa ndigabetenta.
\q1 
\v 24 Obwesigwa bwange n’okwagala kwange kunaabanga naye,
\q2 ne mu linnya lyange aneeyongeranga okuba ow’amaanyi.
\q1 
\v 25 Alifuga okuva ku migga
\q2 okutuuka ku nnyanja ennene.\f + \fr 89:25 \ft Ennyanja eyogerwako wano ye ya Meditereniyaani, n’emigga gya Fulaati n’amatabi gaayo. Eyo ye yali ensalo ey’ensi eyasuubizibwa Dawudi ne Sulemaani.\f*
\q1 
\v 26 Anankowoolanga ng’agamba nti, Ggwe Kitange era Katonda wange,
\q2 ggwe Lwazi olw’Obulokozi bwange.
\q1 
\v 27 Ndimufuula omwana wange omubereberye,
\q2 era kabaka asinga okugulumizibwa mu bakabaka bonna ab’ensi.
\q1 
\v 28 Okwagala kwange kunaabeeranga naye ennaku zonna;
\q2 n’endagaano gye nkoze naye teeremenga kutuukirira.
\q1 
\v 29 Ezzadde lye teririggwaawo emirembe gyonna,
\q2 n’obwakabaka bunaavanga mu kika kye ennaku zonna.
\b
\q1 
\v 30 Abaana be bwe banaanyoomanga amateeka gange,
\q2 ne batagoberera biragiro byange;
\q1 
\v 31 bwe banaamenyanga ebiragiro byange,
\q2 ne batagondera mateeka gange,
\q1 
\v 32 ndibabonereza n’omuggo olw’ebibi byabwe,
\q2 ne mbakuba emiggo olw’ebyonoono byabwe.
\q1 
\v 33 Naye ssirirekayo kumwagala,
\q2 wadde okumenyawo obwesigwa bwange gy’ali.
\q1 
\v 34 Sigenda kulemwa kutuukiriza ndagaano yange,
\q2 wadde okukyusa ku ebyo akamwa kange bye koogedde.
\q1 
\v 35 Nalayira omulundi gumu, ng’obutuukirivu bwange bwe buli,
\q2 nti, “Dawudi sigenda kumulimba.”
\q1 
\v 36 Ezzadde lye teririggwaawo emirembe gyonna;
\q2 n’entebe ye ey’obwakabaka enaabeerangawo emirembe gyonna okufaanana ng’enjuba.
\q1 
\v 37 Entebe ye ey’obwakabaka erinywezebwa emirembe n’emirembe,
\q2 ng’omwezi ku ggulu era nga ye mujulirwa wange omwesigwa.
\b
\q1 
\v 38 Naye kaakano, gwe wafukako amafuta omusudde,
\q2 omukyaye era omunyiigidde.
\q1 
\v 39 Endagaano gye wakola n’omuweereza wo wagimenyawo,
\q2 n’engule ye n’ogisuula eri mu nfuufu.
\q1 
\v 40 Wamenyaamenya bbugwe we yenna,
\q2 n’oggyawo n’ebigo bye.
\q1 
\v 41 Abatambuze baanyaga ebintu bye;
\q2 n’afuuka ekisekererwa mu baliraanwa be.
\q1 
\v 42 Wayimusa omukono gw’abalabe be ogwa ddyo,
\q2 n’osanyusa abalabe be bonna.
\q1 
\v 43 Wakyusa ekitala kye
\q2 n’otomuyamba mu lutalo.
\q1 
\v 44 Ekitiibwa kye wakikomya;
\q2 entebe ye ey’obwakabaka n’ogisuula wansi.
\q1 
\v 45 Ennaku z’obuvuka bwe wazisalako,
\q2 n’omuswaza.
\q1 
\v 46 Ayi \nd Mukama\nd*, olyekweka ennaku zonna?
\q2 Obusungu bwo obubuubuuka ng’omuliro bulikoma ddi?
\q1 
\v 47 Jjukira ekiseera ky’obulamu bwange nga bwe kiri ekimpi.
\q2 Wateganira bwereere okutonda abantu bonna!
\q1 
\v 48 Muntu ki omulamu atalifa, omuntu asobola okwewonya okufa
\q2 n’awangula amaanyi g’emagombe?
\q1 
\v 49 Ayi Mukama, okwagala kwo okw’edda okutaggwaawo,
\q2 kwe walayirira Dawudi mu bwesigwa bwo, kuli luuyi wa?
\q1 
\v 50 Ayi Mukama, jjukira abaweereza bo nga basekererwa,
\q2 engeri abantu ab’omu mawanga amangi, bwe banzitoowerera mu mutima nga banvuma;
\q1 
\v 51 abalabe bo banvuma, Ayi \nd Mukama\nd*;
\q2 ne bajerega oyo gwe wafukako amafuta, nga bamukijjanya buli gy’alaga.
\b
\b
\q1 
\v 52 \nd Mukama\nd* atenderezebwenga emirembe gyonna!
\qc Amiina era Amiina!
\c 90
\ms1 EKITABO IV
\mr Zabbuli 90–106
\cl Zabbuli 90
\d Okusaba kwa Musa, omusajja wa Katonda.
\q1 
\v 1 Ayi Mukama, obadde kifo kyaffe eky’okubeeramu
\q2 emirembe gyonna.
\q1 
\v 2 Ensozi nga tezinnabaawo,
\q2 n’ensi yonna nga tonnagitonda;
\q2 okuva ku ntandikwa okutuusa ku nkomerero y’emirembe gyonna, ggwe Katonda.
\b
\q1 
\v 3 Omuntu omuzzaayo mu nfuufu,
\q2 n’oyogera nti, “Mudde mu nfuufu, mmwe abaana b’abantu.”
\q1 
\v 4 Kubanga emyaka olukumi,
\q2 gy’oli giri ng’olunaku olumu olwayita,
\q2 oba ng’ekisisimuka mu kiro.
\q1 
\v 5 Obeera n’obamalirawo ddala nga bali mu tulo otw’okufa.
\q2 Ku makya baba ng’omuddo omuto.
\q1 
\v 6 Ku makya guba munyirivu,
\q2 naye olw’eggulo ne guwotoka ne gukala.
\b
\q1 
\v 7 Ddala ddala obusungu bwo butumalawo,
\q2 n’obukambwe bwo bututiisa nnyo.
\q1 
\v 8 Ebyonoono byaffe obyanjadde mu maaso go,
\q2 n’ebyo bye tukoze mu kyama obyanise awo w’oli.
\q1 
\v 9 Ddala ddala tumala ennaku z’obulamu bwaffe zonna ng’otunyiigidde;
\q2 tukomekkereza emyaka gyaffe n’okusinda.
\q1 
\v 10 Obungi bw’ennaku zaffe gy’emyaka nsanvu,
\q2 oba kinaana bwe tubaamu amaanyi.
\q1 Naye emyaka egyo gijjula ennaku n’okutegana,
\q2 era giyita mangu, olwo nga tuggwaawo.
\q1 
\v 11 Ani amanyi amaanyi g’obusungu bwo?
\q2 Kubanga ekiruyi kyo kingi ng’ekitiibwa kye tusaana okukuwa bwe kyenkana.
\q1 
\v 12 Otuyigirize okutegeeranga obulungi ennaku zaffe,
\q2 tulyoke tubeere n’omutima ogw’amagezi.
\b
\q1 
\v 13 Ayi Mukama, komawo gye tuli. Olitusuula kutuusa ddi?
\q2 Abaweereza bo bakwatirwe ekisa.
\q1 
\v 14 Tujjuze okwagala kwo okutaggwaawo ku makya,
\q2 tulyoke tuyimbenga nga tujaguza n’essanyu era tusanyukenga obulamu bwaffe bwonna.
\q1 
\v 15 Tusanyuse, Ayi \nd Mukama\nd*, okumala ennaku nga ze tumaze ng’otubonyaabonya,
\q2 era n’okumala emyaka nga gye tumaze nga tulaba ennaku.
\q1 
\v 16 Ebikolwa byo biragibwe abaweereza bo,
\q2 n’abaana baabwe balabe ekitiibwa kyo.
\q1 
\v 17 Okusaasira kwo, Ayi \nd Mukama\nd* Katonda waffe, kubeerenga ku ffe,
\q2 otusobozesenga okutuukiriza obulungi emirimu gyaffe;
\q2 weewaawo, otusobozesenga okutuukiriza obulungi emirimu gyaffe.
\c 91
\cl Zabbuli 91
\d Obwesige bw’oyo atya Katonda.
\q1 
\v 1 Oyo abeera mu kifo eky’ekyama eky’oyo Ali Waggulu Ennyo;
\q2 aliwumulira mu kisiikirize kya Katonda Ayinzabyonna.
\q1 
\v 2 Nnaayogeranga ku \nd Mukama\nd* nti, Oli kiddukiro kyange era ekigo kyange;
\q2 ggwe Katonda wange gwe nneesiga.
\b
\q1 
\v 3 Ddala ddala y’anaakuwonyanga omutego gw’omuyizzi,
\q2 ne kawumpuli azikiriza.
\q1 
\v 4 Alikubikka n’ebyoya bye,
\q2 era mu biwaawaatiro bye mw’onoddukiranga;
\q2 obwesigwa bwe bunaabanga ngabo yo okukukuumanga.
\q1 
\v 5 Tootyenga ntiisa ya kiro,
\q2 wadde akasaale akalasibwa emisana;
\q1 
\v 6 newaakubadde olumbe olusoobasooba mu kizikiza,
\q2 wadde kawumpuli azikiriza mu ttuntu.
\q1 
\v 7 Abantu olukumi balifiira ku lusegere lwo,
\q2 n’omutwalo ne bafiira ku mukono gwo ogwa ddyo,
\q2 naye olumbe terulikutuukako.
\q1 
\v 8 Olitunuulira butunuulizi n’amaaso go;
\q2 n’olaba ekibonerezo ky’omukozi w’ebibi.
\b
\q1 
\v 9 Kubanga bw’olifuula \nd Mukama\nd* ekiddukiro kyo;
\q2 Ali Waggulu Ennyo n’omufuula ekifo kyo mw’obeera,
\q1 
\v 10 tewali kabi kalikutuukako,
\q2 so tewali kibonoobono kirisemberera nnyumba yo.
\q1 
\v 11 Kubanga \nd Mukama\nd* aliragira bamalayika be
\q2 bakukuume mu makubo go gonna.
\q1 
\v 12 Balikuwanirira mu mikono gyabwe;
\q2 oleme okwekoona ekigere kyo ku jjinja.
\q1 
\v 13 Olirinnya ku mpologoma ne ku nswera;
\q2 olirinnyirira empologoma ey’amaanyi, n’omusota.
\b
\q1 
\v 14 “Olw’okuba nga njagala kyendiva muwonya;
\q2 nnaamukuumanga, kubanga amanyi erinnya lyange.
\q1 
\v 15 Anankowoolanga ne muyitabanga;
\q2 nnaabeeranga naye mu biseera eby’akabi.
\q2 Ndimuwonya era ndimuwa ekitiibwa.
\q1 
\v 16 Ndimuwangaaza n’asanyuka
\q2 era ndimulaga obulokozi bwange.”
\c 92
\cl Zabbuli 92
\d Zabbuli. Oluyimba lwa Ssabbiiti.
\q1 
\v 1 Kirungi okwebazanga \nd Mukama\nd*,
\q2 n’okuyimba ennyimba n’okutenderezanga erinnya lyo, Ayi Ggwe, Ali Waggulu Ennyo;
\q1 
\v 2 okutendanga okwagala kwo okutakoma buli nkya,
\q2 n’okutendanga obwesigwa bwo buli kiro.
\q1 
\v 3 Okukutenderezanga n’amaloboozi g’enkoba z’ennanga
\q2 n’endere awamu n’entongooli.
\b
\q1 
\v 4 Kubanga ggwe, Ayi \nd Mukama\nd*, onkoledde ebinsanyusizza;
\q2 kyenva nkuyimbira n’essanyu olw’emirimu gy’emikono gyo.
\q1 
\v 5 Emirimu gyo nga mikulu, Ayi \nd Mukama\nd*;
\q2 ebirowoozo byo nga tebitegeerekeka!
\q1 
\v 6 Omuntu atalina magezi tamanyi;
\q2 n’omusirusiru kino tasobola kukitegeera;
\q1 
\v 7 newaakubadde ng’abakola ebibi baloka ng’omuddo,
\q2 n’aboonoonyi bonna ne bafuna ebirungi,
\q1 boolekedde okuzikirira okw’emirembe n’emirembe!
\b
\q1 
\v 8 Naye ggwe, Ayi \nd Mukama\nd*, ogulumizibwa emirembe gyonna.
\b
\q1 
\v 9 Kubanga abalabe bo, Ayi \nd Mukama\nd*,
\q2 abalabe bo balizikirira,
\q2 abakola ebibi bonna balisaasaanyizibwa.
\q1 
\v 10 Naye nze wanfuula wa maanyi okwenkana embogo,
\q2 n’onfukako amafuta amalungi.
\q1 
\v 11 Amaaso gaalaba bbugwe ng’agwa ku balabe bange;
\q2 n’amatu gange gawulidde akabi akatuuse ku abo abanjigganya.
\b
\q1 
\v 12 Abatuukirivu balyegolola ng’enkindu,
\q2 ne bakula ne bawanvuwa ng’emivule gy’e Lebanooni.
\q1 
\v 13 Egisimbibwa mu nnyumba ya \nd Mukama\nd*.
\q2 Baligimukira mu mpya za Katonda waffe.
\q1 
\v 14 Ne mu bukadde bwabwe balibala ebibala;
\q2 baliba balamu era abagimu,
\q1 
\v 15 kiryoke kitegeeze nti, \nd Mukama\nd* w’amazima,
\q2 lwe Lwazi lwange era mu ye temuli butali butuukirivu.
\c 93
\cl Zabbuli 93
\q1 
\v 1 \nd Mukama\nd* afuga; ayambadde ekitiibwa.
\q2 \nd Mukama\nd* ayambadde ekitiibwa
\q2 era yeesibye amaanyi.
\q1 Ensi yanywezebwa;
\q2 teyinza kunyeenyezebwa.
\q1 
\v 2 Entebe yo ey’obwakabaka yanywezebwa okuva edda n’edda.
\q2 Ggwe, Ayi Katonda, oli wa mirembe na mirembe.
\b
\q1 
\v 3 Amayengo gatumbidde, Ayi \nd Mukama\nd*;
\q2 ennyanja ziyimusizza amaloboozi gaazo,
\q2 n’amazzi g’ennyanja gayira.
\q1 
\v 4 \nd Mukama\nd*, Ali Waggulu Ennyo,
\q2 oli wa maanyi okusinga okuyira kw’amazzi amangi;
\q2 oli wa maanyi okusinga amayengo g’ennyanja.
\b
\q1 
\v 5 Ayi \nd Mukama\nd* ebiragiro byo binywevu,
\q2 n’obutukuvu bujjudde ennyumba yo,
\q2 ennaku zonna.
\c 94
\cl Zabbuli 94
\q1 
\v 1 Ayi \nd Mukama\nd*, ggwe Katonda awalana eggwanga,
\q2 ggwe Katonda awalana eggwanga, labika omasemase.
\q1 
\v 2 Golokoka, Ayi ggwe Omulamuzi w’ensi,
\q2 osasule ab’amalala nga bwe kibagwanidde.
\q1 
\v 3 Ayi \nd Mukama\nd*, omukozi w’ebibi alikomya ddi?
\q2 Omukozi w’ebibi alituusa ddi ng’asanyuka?
\b
\q1 
\v 4 Bafukumula ebigambo eby’okwewaanawaana;
\q2 abakola ebibi bonna beepankapanka.
\q1 
\v 5 Babetenta abantu bo, Ayi \nd Mukama\nd*,
\q2 babonyaabonya ezzadde lyo.
\q1 
\v 6 Batta nnamwandu n’omutambuze;
\q2 ne batemula ataliiko kitaawe.
\q1 
\v 7 Ne boogera nti, “Katonda talaba;
\q2 Katonda wa Yakobo tafaayo.”
\b
\q1 
\v 8 Mwerinde mmwe abantu abatategeera.
\q2 Mmwe abasirusiru muligeziwala ddi?
\q1 
\v 9 Oyo eyatonda okutu tawulira?
\q2 Oyo eyakola eriiso talaba?
\q1 
\v 10 Oyo akangavvula amawanga, taakubonereze?
\q2 Oyo ayigiriza abantu talina ky’amanyi?
\q1 
\v 11 \nd Mukama\nd* amanyi ebirowoozo by’abantu;
\q2 amanyi nga mukka bukka.
\b
\q1 
\v 12 Ayi \nd Mukama\nd*, alina omukisa oyo gw’ogunjula,
\q2 gw’oyigiriza eby’omu mateeka go;
\q1 
\v 13 omuwummuzaako mu kabi kaalimu,
\q2 okutuusa abakola ebibi lwe balisimirwa ekinnya.
\q1 
\v 14 Kubanga \nd Mukama\nd* talireka bantu be;
\q2 talyabulira zzadde lye.
\q1 
\v 15 Aliramula mu butuukirivu,
\q2 n’abo abalina emitima emigolokofu bwe banaakolanga.
\b
\q1 
\v 16 Ani alinnwanyisizaako abakola ebibi?
\q2 Ani alinnwanirira eri abakola ebibi?
\q1 
\v 17 Singa \nd Mukama\nd* teyali mubeezi wange,
\q2 omwoyo gwange gwandiserengese emagombe.
\q1 
\v 18 Bwe naleekaana nti, “Nseerera!”
\q2 Okwagala kwo okutaggwaawo, Ayi \nd Mukama\nd*, ne kumpanirira.
\q1 
\v 19 Ebyeraliikiriza omutima gwange bwe byayitirira obungi,
\q2 okusaasira kwo ne kuzzaamu omwoyo gwange amaanyi.
\b
\q1 
\v 20 Oyinza okukolagana n’obufuzi obukyamu,
\q2 obukaabya abantu n’amateeka gaabwe?
\q1 
\v 21 Abakola ebibi beegatta ne balumbagana abatuukirivu;
\q2 atasobezza ne bamusalira ogw’okufa.
\q1 
\v 22 Naye \nd Mukama\nd* afuuse ekiddukiro kyange eky’amaanyi;
\q2 ye Katonda wange, era Olwazi lwange mwe neekweka.
\q1 
\v 23 \nd Mukama\nd* alibabonereza olw’ebibi byabwe,
\q2 n’abazikiriza olw’ebyonoono byabwe;
\q2 \nd Mukama\nd* Katonda waffe alibamalirawo ddala.
\c 95
\cl Zabbuli 95
\q1 
\v 1 Mujje tuyimbire \nd Mukama\nd*;
\q2 tuyimbire waggulu n’essanyu nga tutendereza \nd Mukama\nd* Olwazi olw’obulokozi bwaffe.
\q1 
\v 2 Tujje mu maaso ge n’okwebaza;
\q2 tumuyimbire ennyimba ez’okumutendereza.
\b
\q1 
\v 3 Kubanga \nd Mukama\nd* ye Katonda Omukulu;
\q2 era Kabaka Omukulu asinga bakatonda bonna.
\q1 
\v 4 Enkonko ez’ensi ziri mu mukono gwe;
\q2 n’entikko z’ensozi nazo zize.
\q1 
\v 5 Ennyanja yiye, kubanga ye yagikola;
\q2 n’emikono gye, gye gyabumba olukalu.
\b
\q1 
\v 6 Mujje tusinze tuvuuname mu maaso ge;
\q2 tufukamire mu maaso ga \nd Mukama\nd*, Omutonzi waffe.
\q1 
\v 7 Kubanga ye Katonda waffe,
\q2 naffe tuli bantu ab’omu ddundiro lye,
\q2 era tuli ndiga ze z’alabirira.
\b
\q1 Olwa leero bwe muwulira eddoboozi lye,
\q2 
\v 8 “Temukakanyaza mitima gyammwe nga bwe kyali e Meriba\f + \fr 95:8 \fq Meriba \ft kitegeeza okwemulugunya\f*,
\q2 ne ku lunaku luli e Maasa\f + \fr 95:8 \fq Maasa \ft kitegeeza kugezesa\f* mu ddungu;
\q1 
\v 9 bajjajjammwe gye bangezesa;
\q2 newaakubadde baali baalaba dda ebyamagero bye nakola.
\q1 
\v 10 Abantu b’omulembe ogwo ne mbasunguwalira okumala emyaka amakumi ana;
\q2 ne ŋŋamba nti, ‘Be bantu abakyama mu mutima gwabwe,
\q2 era tebamanyi makubo gange.’
\q1 
\v 11 Kyennava ndayira nga nsunguwadde nti,
\q2 ‘Tebaliyingira mu kiwummulo kyange.’ ”
\c 96
\cl Zabbuli 96
\q1 
\v 1 Muyimbire \nd Mukama\nd* oluyimba oluggya;
\q2 muyimbire \nd Mukama\nd* mmwe ensi yonna.
\q1 
\v 2 Muyimbire \nd Mukama\nd*; mutendereze erinnya lye,
\q2 mulangirire obulokozi bwe buli lukya.
\q1 
\v 3 Mutende ekitiibwa kye mu mawanga gonna,
\q2 eby’amagero bye mubimanyise abantu bonna.
\b
\q1 
\v 4 Kubanga \nd Mukama\nd* mukulu era asaanira nnyo okutenderezebwa;
\q2 asaana okutiibwa okusinga bakatonda bonna.
\q1 
\v 5 Kubanga bakatonda bonna abakolebwa abantu bifaananyi bufaananyi;
\q2 naye \nd Mukama\nd* ye yakola eggulu.
\q1 
\v 6 Ekitiibwa n’obukulu bimwetooloola;
\q2 amaanyi n’obulungi biri mu nnyumba ye entukuvu.
\b
\q1 
\v 7 Mugulumize \nd Mukama\nd* mmwe ebika eby’amawanga byonna;
\q2 mutende ekitiibwa kya \nd Mukama\nd* awamu n’amaanyi ge.
\q1 
\v 8 Mugulumize \nd Mukama\nd* mu ngeri esaanira erinnya lye;
\q2 muleete ekiweebwayo mujje mu mbuga ze.
\q1 
\v 9 Musinze \nd Mukama\nd* mu kitiibwa eky’obutuukirivu bwe.
\q2 Ensi yonna esinze \nd Mukama\nd* n’okukankana.
\q1 
\v 10 Mutegeeze amawanga gonna nti \nd Mukama\nd* y’afuga.
\q2 Ensi nnywevu, tewali asobola kuginyeenyaako;
\q2 \nd Mukama\nd* aliramula abantu mu bwenkanya.
\b
\q1 
\v 11 Kale eggulu lisanyuke n’ensi ejaguze;
\q2 ennyanja eyire ne byonna ebigirimu.
\q2 
\v 12 Ennimiro n’ebirime ebizirimu bijaguze;
\q1 n’emiti gyonna egy’omu kibira nagyo gimutendereze n’ennyimba ez’essanyu.
\q2 
\v 13 Kubanga \nd Mukama\nd* ajja;
\q2 ajja okusalira ensi omusango.
\q1 \nd Mukama\nd* aliramula ensi mu butuukirivu,
\q2 n’abantu bonna abalamule mu mazima.
\c 97
\cl Zabbuli 97
\q1 
\v 1 \nd Mukama\nd* afuga; ensi esanyuke,
\q2 n’embalama eziri ewala zijaguze.
\q1 
\v 2 Ebire n’ekizikiza bimwetooloola;
\q2 obutuukirivu n’obwenkanya gwe musingi gw’entebe y’obwakabaka bwe.
\q1 
\v 3 Omuliro gumukulembera
\q2 ne gwokya abalabe be ku njuyi zonna.
\q1 
\v 4 Okumyansa kwe kumulisa ensi;
\q2 ensi n’ekulaba n’ekankana.
\q1 
\v 5 Ensozi zisaanuuka ng’envumbo awali \nd Mukama\nd*,
\q2 mu maaso ga Mukama ow’ensi yonna.
\q1 
\v 6 Eggulu lirangirira obutuukirivu bwe;
\q2 n’abantu bonna ne balaba ekitiibwa kye.
\b
\q1 
\v 7 Abasinza ebifaananyi ebikole n’emikono bonna baswadde,
\q2 abo abeenyumiririza mu bifaananyi ebyole.
\q2 Mumusinze mwe mwenna bakatonda.
\b
\q1 
\v 8 Sayuuni akiwulira n’asanyuka,
\q2 n’ebyalo bya Yuda bijaguza;
\q2 kubanga ogoberera eby’ensonga, Ayi Katonda.
\q1 
\v 9 Kubanga ggwe, Ayi \nd Mukama\nd*, oli waggulu nnyo okusinga ensi;
\q2 ogulumizibwa okusinga bakatonda bonna.
\q1 
\v 10 Abo abaagala \nd Mukama\nd* bakyawa ekibi,
\q2 akuuma obulamu bw’abamwesiga,
\q2 n’abawonya okuva mu mukono gw’omukozi w’ebibi.
\q1 
\v 11 Omusana gwe gwakira abatuukirivu,
\q2 n’abalina omutima ogw’amazima bajjula essanyu.
\q1 
\v 12 Musanyukirenga mu \nd Mukama\nd* mmwe abatuukirivu,
\q2 era mwebazenga erinnya lye ettukuvu.
\c 98
\cl Zabbuli 98
\d Zabbuli.
\q1 
\v 1 Muyimbire \nd Mukama\nd* oluyimba oluggya,
\q2 kubanga akoze eby’ekitalo.
\q1 Omukono gwe ogwa ddyo,
\q2 era omukono omutukuvu, gumuwadde obuwanguzi.
\q1 
\v 2 \nd Mukama\nd* ayolesezza obulokozi bwe,
\q2 era abikkulidde amawanga obutuukirivu bwe.
\q1 
\v 3 Ajjukidde okwagala kwe okutakoma
\q2 n’obwesigwa bwe eri ennyumba ya Isirayiri.
\q1 Enkomerero z’ensi yonna zirabye
\q2 obulokozi bwa Katonda waffe.
\b
\q1 
\v 4 Muyimbire \nd Mukama\nd* n’essanyu lingi mwe ensi yonna;
\q2 muyimbe ennyimba mu maloboozi ag’essanyu.
\q1 
\v 5 Mutendereze \nd Mukama\nd* n’ennanga ez’enkoba;
\q2 n’ennanga ez’enkoba n’amaloboozi ag’okuyimba,
\q1 
\v 6 n’amakondeere n’eddoboozi ly’eŋŋombe.
\q2 Muyimbe n’essanyu mu maaso ga \nd Mukama\nd* era Kabaka.
\b
\q1 
\v 7 Ennyanja eyire ne byonna ebigirimu,
\q2 n’ensi ne byonna ebigirimu bijaguze.
\q1 
\v 8 Emigga gikube mu ngalo
\q2 n’ensozi zonna ziyimbire wamu olw’essanyu;
\q1 
\v 9 byonna biyimbe mu maaso ga \nd Mukama\nd*,
\q2 kubanga ajja okulamula ensi.
\q1 Aliramula ensi mu butuukirivu;
\q2 aliramula amawanga mu bwenkanya.
\c 99
\cl Zabbuli 99
\q1 
\v 1 \nd Mukama\nd* afuga,
\q2 amawanga gakankane;
\q1 atuula wakati wa bakerubi,
\q2 ensi ekankane.
\q1 
\v 2 \nd Mukama\nd* mukulu mu Sayuuni;
\q2 agulumizibwa mu mawanga gonna.
\q1 
\v 3 Amawanga gonna gatendereze erinnya lyo ekkulu era ery’entiisa.
\q2 \nd Mukama\nd* mutukuvu.
\b
\q1 
\v 4 Ye Kabaka ow’amaanyi, ayagala obwenkanya.
\q2 Onywezezza obwenkanya;
\q1 era by’okoledde Yakobo bya bwenkanya
\q2 era bituufu.
\q1 
\v 5 Mumugulumize \nd Mukama\nd* Katonda waffe;
\q2 mumusinzize wansi w’entebe y’ebigere bye.
\q2 \nd Mukama\nd* mutukuvu.
\b
\q1 
\v 6 Musa ne Alooni baali bamu ku bakabona be;
\q2 ne Samwiri yali mu abo abaakoowoolanga erinnya lye;
\q1 baasabanga \nd Mukama\nd*
\q2 n’abaanukula.
\q1 
\v 7 Yayogera nabo mu mpagi ey’ekire;
\q2 baagondera amateeka ge n’ebiragiro bye, bye yabawa.
\b
\q1 
\v 8 Ayi \nd Mukama\nd* Katonda waffe,
\q2 wabaanukulanga;
\q1 n’obeeranga Katonda asonyiwa eri Isirayiri,
\q2 newaakubadde wababonerezanga olw’ebikolwa byabwe ebibi.
\q1 
\v 9 Mugulumizenga \nd Mukama\nd* Katonda waffe,
\q2 mumusinzizenga ku lusozi lwe olutukuvu,
\q2 kubanga \nd Mukama\nd* Katonda waffe mutukuvu.
\c 100
\cl Zabbuli 100
\d Zabbuli ey’okwebaza.
\q1 
\v 1 Muleetere \nd Mukama\nd* eddoboozi ery’essanyu mmwe ensi zonna.
\q2 
\v 2 Muweereze \nd Mukama\nd* n’essanyu;
\q2 mujje mu maaso ge n’ennyimba ez’essanyu.
\q1 
\v 3 Mumanye nga \nd Mukama\nd* ye Katonda;
\q2 ye yatutonda, tuli babe,
\q2 tuli bantu be era endiga ez’omu ddundiro lye.
\b
\q1 
\v 4 Muyingire mu miryango gye nga mwebaza,
\q2 ne mu mpya ze n’okutendereza;
\q2 mumwebaze mutendereze erinnya lye.
\q1 
\v 5 Kubanga \nd Mukama\nd* mulungi, n’okwagala kwe kwa lubeerera;
\q2 n’obwesigwa bwe bwa mirembe gyonna.
\c 101
\cl Zabbuli 101
\d Zabbuli ya Dawudi.
\q1 
\v 1 Nnaayimbanga ku kwagala kwo n’obutuukirivu bwo;
\q2 nnaayimbiranga ggwe, Ayi \nd Mukama\nd*.
\q1 
\v 2 Nneegenderezanga, mu bulamu bwange ne nkola eby’obutuukirivu,
\q2 naye olijja ddi gye ndi?
\b
\q1 Nnaabeeranga mu nnyumba yange
\q2 nga siriiko kya kunenyezebwa.
\q1 
\v 3 Sijjanga kwereetereza kintu
\q2 kyonna ekibi.
\b
\q1 Nkyayira ddala ebikolwa by’abo abava mu kkubo lyo;
\q2 sijjanga kubyeteekako.
\q1 
\v 4 Sijjanga kuba mukuusa;
\q2 ekibi nnaakyewaliranga ddala.
\b
\q1 
\v 5 Oyo alyolyoma muliraanwa we mu kyama,
\q2 nnaamuzikiririzanga ddala; amaaso ag’amalala n’omutima ogw’amalala
\q2 sijja kubigumiikirizanga.
\b
\q1 
\v 6 Abeesigwa abali mu nsi yaffe nnaabasanyukiranga,
\q2 balyoke babeerenga nange;
\q1 akola eby’obutuukirivu
\q2 y’anamperezanga.
\b
\q1 
\v 7 Atayogera mazima
\q2 taabeerenga mu nnyumba yange.
\q1 Omuntu alimba
\q2 sirimuganya kwongera kubeera nange.
\b
\q1 
\v 8 Buli nkya nnaazikirizanga
\q2 abakola ebibi bonna mu nsi,
\q1 bwe ntyo abakozi b’ebibi ne mbamalirawo ddala
\q2 mu kibuga kya \nd Mukama\nd*.
\c 102
\cl Zabbuli 102
\d Okusaba kw’oyo ali mu buyinike ng’ayigganyizibwa nga yeeyongedde okunafuwa, n’afukumula byonna ebimuli ku mutima mu maaso ga \nd Mukama\nd*.
\q1 
\v 1 Wulira okusaba kwange, Ayi \nd Mukama\nd*,
\q2 okkirize okukoowoola kwange kutuuke gy’oli.
\q1 
\v 2 Tonneekweka
\q2 mu biseera eby’obuyinike bwange.
\q1 Ntegera okutu kwo
\q2 onnyanukule mangu bwe nkukoowoola!
\b
\q1 
\v 3 Kubanga ennaku zange zifuumuuka ng’omukka,
\q2 n’amagumba gange gaaka ng’amanda.
\q1 
\v 4 Omutima gwange gulinnyirirwa ng’omuddo, era guwotose;
\q2 neerabira n’okulya emmere yange.
\q1 
\v 5 Olw’okwaziirana kwange okunene,
\q2 nzenna nfuuse ŋŋumbagumba.
\q1 
\v 6 Ndi ng’ekiwuugulu eky’omu ddungu,
\q2 era ng’ekiwuugulu eky’omu nsiko.
\q1 
\v 7 Nsula ntunula,
\q2 nga ndi ng’ekinyonyi ekitudde kyokka ku kasolya k’ennyumba.
\q1 
\v 8 Abalabe bange banvuma olunaku lwonna;
\q2 abo abanduulira bakozesa linnya lyange nga bakolima.
\q1 
\v 9 Kubanga ndya evvu ng’alya emmere,
\q2 n’amaziga gange ne geegattika mu kyokunywa kyange.
\q1 
\v 10 Olw’obusungu n’okunyiiga kwo;
\q2 onneegobyeko n’onsuula eyo.
\q1 
\v 11 Ennaku zange ziri ng’ekisiikirize ky’olweggulo nga buziba;
\q2 mpotoka ng’omuddo.
\b
\q1 
\v 12 Naye ggwe, Ayi \nd Mukama\nd*, obeera mu ntebe yo ey’obwakabaka emirembe n’emirembe;
\q2 erinnya lyo linajjukirwanga ab’omu mirembe gyonna.
\q1 
\v 13 Olisituka n’osaasira Sayuuni,
\q2 kino kye kiseera okulaga Sayuuni omukwano;
\q2 ekiseera kye wateekateeka kituuse.
\q1 
\v 14 Kubanga amayinja gaakyo abaweereza bo bagaagala nnyo,
\q2 n’enfuufu y’omu kibuga ekyo ebakwasa ekisa.
\q1 
\v 15 Amawanga gonna ganaatyanga erinnya lya \nd Mukama\nd*;
\q2 ne bakabaka bonna ab’ensi banaakankananga olw’ekitiibwa kyo.
\q1 
\v 16 Kubanga \nd Mukama\nd* alizimba Sayuuni buto,
\q2 era n’alabika mu kitiibwa kye.
\q1 
\v 17 Alyanukula okusaba kw’abanaku;
\q2 talinyooma kwegayirira kwabwe.
\b
\q1 
\v 18 Bino leka biwandiikirwe ab’omu mirembe egirijja,
\q2 abantu abatannatondebwa bwe balibisoma balyoke batendereze \nd Mukama\nd*.
\q1 
\v 19 Bategeere nti \nd Mukama\nd* yatunula wansi ng’asinziira waggulu mu kifo kye ekitukuvu;
\q2 \nd Mukama\nd* yasinzira mu ggulu n’atunuulira ensi,
\q1 
\v 20 okuwulira okusinda kw’abasibe,
\q2 n’okusumulula abo abasaliddwa ogw’okufa.
\q1 
\v 21 Erinnya lya \nd Mukama\nd*, liryoke litenderezebwe mu Sayuuni,
\q2 bamutenderezenga mu Yerusaalemi;
\q1 
\v 22 abantu nga bakuŋŋaanye, awamu n’obwakabaka,
\q2 okusinza \nd Mukama\nd*.
\b
\q1 
\v 23 \nd Mukama\nd* ammazeemu amaanyi nga nkyali muvubuka;
\q2 akendeezezza ku nnaku z’obulamu bwange.
\q1 
\v 24 Ne ndyoka mmukaabira nti,
\q2 “Ayi Katonda wange, tontwala nga nkyali mu makkati g’emyaka gy’obulamu bwange,
\q2 ggw’abeera omulamu emirembe gyonna.
\q1 
\v 25 Ku ntandikwa wassaawo omusingi gw’ensi;
\q2 n’eggulu gy’emirimu gy’emikono gyo.
\q1 
\v 26 Byonna biriggwaawo, naye ggwe oli wa lubeerera.
\q2 Byonna birikaddiwa ng’ebyambalo.
\q2 Olibikyusa ng’ebyambalo, ne bisuulibwa.
\q1 
\v 27 Naye ggwe tokyuka oli wa lubeerera
\q2 n’emyaka gyo tegirikoma.
\q1 
\v 28 Abaana b’abaweereza bo baliba mu ddembe;
\q2 ne bazzukulu baabwe banaabeeranga w’oli nga tebalina kye batya.”
\c 103
\cl Zabbuli 103
\d Zabbuli Ya Dawudi.
\q1 
\v 1 Weebaze \nd Mukama\nd*, ggwe emmeeme yange;
\q2 ne byonna ebiri mu nze byebaze erinnya lye ettukuvu.
\q1 
\v 2 Weebaze \nd Mukama\nd*, ggwe emmeeme yange,
\q2 era teweerabiranga birungi bye byonna.
\q1 
\v 3 Asonyiwa ebibi byo byonna,
\q2 n’awonya n’endwadde zo zonna.
\q1 
\v 4 Anunula obulamu bwo emagombe, n’akusaasira
\q2 era n’akwagala n’okwagala okutaggwaawo.
\q1 
\v 5 Awa emmeeme yo ebintu ebirungi byeyagala;
\q2 obuvubuka bwo ne budda buggya ng’empungu.\f + \fr 103:5 \ft Empungu emanyiddwa olw’amaanyi gaayo n’olw’obuwangaazi bwayo.\f*
\b
\q1 
\v 6 \nd Mukama\nd* asala mu butuukirivu ne mu bwenkanya,
\q2 ensonga z’abo bonna abajoogebwa.
\b
\q1 
\v 7 Yamanyisa Musa ebyo by’ayagala,
\q2 n’alaga abaana ba Isirayiri ebikolwa bye.
\q1 
\v 8 \nd Mukama\nd* wa kisa era ajjudde okusaasira,
\q2 tasunguwala mangu, era alina okwagala okutaggwaawo.
\q1 
\v 9 Taasibenga busungu ku mwoyo,
\q2 era tasunguwala kumala bbanga lyonna.
\q1 
\v 10 Tatukola ng’okwonoona kwaffe bwe kuli,
\q2 wadde okutusasula ng’ebikolwa byaffe ebitali bya butuukirivu bwe biri.
\q1 
\v 11 Ng’eggulu bwe litumbidde ennyo waggulu w’ensi,
\q2 n’okwagala kwe bwe kuli okunene bwe kutyo eri abo abamutya.
\q1 
\v 12 Ebibi byaffe abituggyako
\q2 n’abitwala wala ng’ebuvanjuba bw’eri ewala okuva ebugwanjuba.
\b
\q1 
\v 13 Kitaawe w’abaana nga bw’asaasira abaana be,
\q2 ne \nd Mukama\nd* bw’atyo bw’asaasira abo abamutya.
\q1 
\v 14 Kubanga amanyi nga bwe twakolebwa
\q2 era ng’ajjukira nti tuli nfuufu.
\q1 
\v 15 Wabula omuntu, ennaku z’obulamu bwe ziri ng’omuddo;
\q2 akula n’agimuka ng’ekimuli eky’omu nnimiro;
\q1 
\v 16 empewo ekifuuwa, ne kifa;
\q2 nga ne we kyali tewakyajjukirwa.
\q1 
\v 17 Naye okwagala kwa Katonda eri abo abamutya tekuggwaawo
\q2 emirembe gyonna,
\q2 n’obulokozi bwe eri abaana b’abaana baabwe.
\q1 
\v 18 Be bo abakuuma endagaano ye
\q2 ne bajjukira okugondera amateeka ge.
\b
\q1 
\v 19 \nd Mukama\nd* anywezezza entebe ye ey’obwakabaka mu ggulu,
\q2 n’obwakabaka bwe bufuga ensi yonna.
\b
\q1 
\v 20 Mwebaze \nd Mukama\nd* mmwe bamalayika be,
\q2 mmwe ab’amaanyi abakola ky’agamba,
\q2 era abagondera ekigambo kye.
\q1 
\v 21 Mwebaze \nd Mukama\nd* mmwe amaggye ge ag’omu ggulu,
\q2 mmwe abaweereza be abakola by’ayagala.
\q1 
\v 22 Mwebaze \nd Mukama\nd*, mmwe ebitonde bye byonna
\q2 ebiri mu matwale ge gonna.
\b
\q1 Weebaze \nd Mukama\nd*, ggwe emmeeme yange.
\c 104
\cl Zabbuli 104
\q1 
\v 1 Weebaze \nd Mukama\nd*, ggwe emmeeme yange.
\b
\q1 Ayi \nd Mukama\nd* Katonda wange, oli mukulu nnyo;
\q2 ojjudde obukulu n’ekitiibwa.
\b
\q1 
\v 2 Yeebika ekitangaala ng’ayeebikka ekyambalo
\q2 n’abamba eggulu ng’eweema,
\q2 
\v 3 n’ateeka akasolya k’ebisulo bye eby’oku ntikko kungulu ku mazzi;
\q1 ebire abifuula amagaali ge,
\q2 ne yeebagala ebiwaawaatiro by’empewo.
\q1 
\v 4 Afuula empewo ababaka be,
\q2 n’ennimi z’omuliro ogwaka abaweereza be.
\b
\q1 
\v 5 Yassaawo ensi ku misingi gyayo;
\q2 teyinza kunyeenyezebwa.
\q1 
\v 6 Wagibikkako obuziba ng’ekyambalo;
\q2 amazzi ne gatumbiira okuyisa ensozi ennene.
\q1 
\v 7 Bwe wagaboggolera ne gadduka;
\q2 bwe gaawulira okubwatuka kwo ne gaddukira ddala;
\q1 
\v 8 gaakulukutira ku nsozi ennene,
\q2 ne gakkirira wansi mu biwonvu
\q2 mu bifo bye wagategekera.
\q1 
\v 9 Wagassizaawo ensalo ze gatasaana kusukka,
\q2 na kuddayo kubuutikira nsi.
\b
\q1 
\v 10 Alagira ensulo ne zisindika amazzi mu biwonvu;
\q2 ne gakulukutira wakati w’ensozi.
\q1 
\v 11 Ne ganywesa ebisolo byonna eby’omu nsiko;
\q2 n’endogoyi ne gazimalako ennyonta.
\q1 
\v 12 Ebinyonyi eby’omu bbanga bizimba ebisu byabyo ku mabbali g’amazzi,
\q2 ne biyimbira mu matabi.
\q1 
\v 13 Afukirira ensozi ennene ng’osinziira waggulu gy’obeera;
\q2 ensi n’ekkuta ebibala by’emirimu gyo.
\q1 
\v 14 Olagira omuddo ne gukula okuliisa ente,
\q2 n’ebirime abantu bye balima,
\q2 balyoke bafune ebyokulya okuva mu ttaka.
\q1 
\v 15 Ne wayini okusanyusa omutima gwe,
\q2 n’ebizigo okwesiiga awoomye endabika ye,
\q2 n’emmere okumuwa obulamu.
\q1 
\v 16 Emiti gya \nd Mukama\nd* gifuna amazzi mangi;
\q2 gy’emivule gy’e Lebanooni gye yasimba.
\q1 
\v 17 Omwo ebinyonyi mwe bizimba ebisu byabyo;
\q2 ne ssekanyolya asula mu miti omwo.
\q1 
\v 18 Ku nsozi empanvu eyo embulabuzi ez’omu nsiko gye zibeera;
\q2 n’enjazi kye kiddukiro ky’obumyu.
\b
\q1 
\v 19 Wakola omwezi okutegeeza ebiro;
\q2 n’enjuba bw’egwa n’eraga olunaku.
\q1 
\v 20 Oleeta ekizikiza, ne buba ekiro;
\q2 olwo ebisolo byonna eby’omu bibira ne biryoka bivaayo.
\q1 
\v 21 Empologoma ento zikaabira emmere gye zinaalya;
\q2 nga zinoonya ebyokulya okuva eri Katonda.
\q1 
\v 22 Enjuba bw’evaayo ne zigenda, n’oluvannyuma
\q2 ne zikomawo ne zigalamira mu mpuku zaazo.
\q1 
\v 23 Abantu ne bagenda ku mirimu gyabwe,
\q2 ne bakola okutuusa akawungeezi.
\b
\q1 
\v 24 Ayi \nd Mukama\nd*, ebintu bye wakola nga bingi nnyo!
\q2 Byonna wabikola n’amagezi ag’ekitalo;
\q2 ensi ejjudde ebitonde byo.
\q1 
\v 25 Waliwo ennyanja, nnene era ngazi,
\q2 ejjudde ebitonde ebitabalika,
\q2 ebintu ebirina obulamu ebinene era n’ebitono.
\q1 
\v 26 Okwo amaato kwe gaseeyeeyera nga galaga eno n’eri;
\q2 ne galukwata ge wakola mwe gabeera okuzannyiranga omwo.
\b
\q1 
\v 27 Ebyo byonna bitunuulira ggwe
\q2 okubiwa emmere yaabyo ng’ekiseera kituuse.
\q1 
\v 28 Bw’ogibiwa,
\q2 nga bigikuŋŋaanya;
\q1 bw’oyanjuluza engalo zo n’obigabira ebintu ebirungi
\q2 ne bikkusibwa.
\q1 
\v 29 Bw’okweka amaaso go
\q2 ne byeraliikirira nnyo;
\q1 bw’obiggyamu omukka nga bifa,
\q2 nga biddayo mu nfuufu.
\q1 
\v 30 Bw’oweereza Omwoyo wo,
\q2 ne bifuna obulamu obuggya;
\q2 olwo ensi n’ogizza buggya.
\b
\q1 
\v 31 Ekitiibwa kya Katonda kibeerengawo emirembe gyonna;
\q2 era \nd Mukama\nd* asanyukirenga ebyo bye yakola.
\q1 
\v 32 Atunuulira ensi, n’ekankana;
\q2 bw’akwata ku nsozi ennene, ne zinyooka omukka.
\b
\q1 
\v 33 Nnaayimbiranga \nd Mukama\nd* obulamu bwange bwonna;
\q2 nnaayimbanga nga ntendereza Katonda wange ennaku zonna ze ndimala nga nkyali mulamu.
\q1 
\v 34 Ebirowoozo byange, nga nfumiitiriza, bimusanyusenga;
\q2 kubanga mu \nd Mukama\nd* mwe neeyagalira.
\q1 
\v 35 Naye abakola ebibi baggweewo ku nsi;
\q2 aboonoonyi baleme kulabikirako ddala.
\b
\q1 Weebaze \nd Mukama\nd*, gwe emmeeme yange.
\b
\q1 Mumutenderezenga \nd Mukama\nd*.
\c 105
\cl Zabbuli 105
\q1 
\v 1 Mwebaze \nd Mukama\nd*, mukoowoole erinnya lye;
\q2 amawanga gonna mugategeeze by’akoze.
\q1 
\v 2 Mumuyimbire, mumutendereze;
\q2 muyimbe ku byamagero bye.
\q1 
\v 3 Mumusuute, ng’erinnya lye ettukuvu muligulumiza;
\q2 emitima gy’abo abanoonya \nd Mukama\nd* gijjule essanyu.
\q1 
\v 4 Munoonye \nd Mukama\nd* n’amaanyi ge;
\q2 mumunoonyenga ennaku zonna.
\b
\q1 
\v 5 Mujjukirenga eby’ekitalo bye yakola,
\q2 ebyamagero bye, n’emisango gye yasala;
\q1 
\v 6 mmwe abazzukulu ba Ibulayimu, abaweereza be
\q2 mmwe abaana ba Yakobo, abalonde be.
\q1 
\v 7 Ye \nd Mukama\nd* Katonda waffe;
\q2 ye alamula mu nsi yonna.
\b
\q1 
\v 8 Ajjukira endagaano ye emirembe gyonna,
\q2 kye kigambo kye yalagira, ekyakamala emirembe olukumi,
\q1 
\v 9 ye ndagaano gye yakola ne Ibulayimu,
\q2 era kye kisuubizo kye yalayirira Isaaka.
\q1 
\v 10 Yakikakasa Yakobo ng’etteeka,
\q2 n’akiwa Isirayiri ng’endagaano eteriggwaawo nti,
\q1 
\v 11 “Ndikuwa ggwe ensi ya Kanani
\q2 okuba omugabo gwo.”
\b
\q1 
\v 12 Bwe baali bakyali batono,
\q2 nga si bangi n’akamu, era nga bagwira mu nsi omwo,
\q1 
\v 13 baatambulatambulanga okuva mu ggwanga erimu okulaga mu ddala,
\q2 ne bavanga mu bwakabaka obumu ne balaga mu bulala.
\q1 
\v 14 Teyaganya muntu yenna kubayisa bubi;
\q2 n’alabulanga bakabaka ku lwabwe nti,
\q1 
\v 15 “Abalonde bange,
\q2 ne bannabbi bange temubakolangako kabi.”
\b
\q1 
\v 16 Yaleeta enjala mu nsi,
\q2 emmere yaabwe yonna n’agizikiriza.
\q1 
\v 17 N’atuma omuntu okubeesooka mu maaso,
\q2 ye Yusufu eyatundibwa ng’omuddu,
\q1 
\v 18 ebigere bye ne binuubulwa enjegere ze baamusibya,
\q2 obulago bwe ne buteekebwa mu byuma,
\q1 
\v 19 okutuusa bye yategeeza lwe byatuukirira,
\q2 okutuusa ekigambo kya \nd Mukama\nd* lwe kyamukakasa nti bye yayogera bya mazima.
\q1 
\v 20 Kabaka n’atuma ne bamusumulula;
\q2 omufuzi w’ensi eyo yamuggya mu kkomera.
\q1 
\v 21 Yamufuula omukulu w’eby’omu maka ge,
\q2 n’akulira byonna omufuzi oyo bye yalina;
\q1 
\v 22 okukangavvulanga abalangira be nga bwe yalabanga,
\q2 n’okuyigiriza abakulu eby’amagezi.
\b
\q1 
\v 23 Oluvannyuma Isirayiri n’ajja mu Misiri;
\q2 Yakobo bw’atyo n’atuula mu nsi ya Kaamu nga munnaggwanga.
\q1 
\v 24 \nd Mukama\nd* n’ayaza nnyo abantu be;
\q2 ne baba bangi nnyo, n’abalabe baabwe ne beeraliikirira,
\q1 
\v 25 n’akyusa emitima gyabwe ne bakyawa abantu be,
\q2 ne basalira abaweereza be enkwe.
\q1 
\v 26 Yatuma abaweereza be Musa
\q2 ne Alooni, be yalonda.
\q1 
\v 27 Ne bakola obubonero bwe obw’ekitalo mu bantu abo;
\q2 ne bakolera ebyamagero bye mu nsi ya Kaamu.
\q1 
\v 28 Yaleeta ekizikiza ensi yonna n’ekwata,
\q2 kubanga baali bajeemedde ekigambo kye.
\q1 
\v 29 Amazzi gaabwe yagafuula omusaayi,
\q2 ne kireetera ebyennyanja byabwe okufa.
\q1 
\v 30 Ensi yaabwe yajjula ebikere,
\q2 ebyatuukira ddala ne mu bisenge by’abafuzi baabwe.
\q1 
\v 31 Yalagira, ebiwuka ebya buli ngeri ne bijja,
\q2 n’ensekere ne zeeyiwa mu bitundu byonna eby’ensi yaabwe.
\q1 
\v 32 Yafuula enkuba okuba amayinja g’omuzira;
\q2 eggulu ne libwatuka mu nsi yaabwe yonna.
\q1 
\v 33 Yakuba emizeeyituuni n’emizabbibu,
\q2 n’azikiriza emiti gy’omu nsi yaabwe.
\q1 
\v 34 Yalagira, enzige ne zijja
\q2 ne bulusejjera obutabalika muwendo.
\q1 
\v 35 Ne birya buli kimera kyonna mu nsi yaabwe,
\q2 na buli kisimbe kyonna mu ttaka lyabwe ne kiriibwa.
\q1 
\v 36 N’azikiriza abaana ababereberye bonna mu nsi yaabwe,
\q2 nga bye bibala ebisooka eby’obuvubuka bwabwe.
\q1 
\v 37 Yaggya Abayisirayiri mu nsi eyo nga balina ffeeza nnyingi ne zaabu;
\q2 era bonna baali ba maanyi.
\q1 
\v 38 Abamisiri baasanyuka bwe baalaba Abayisirayiri nga bagenze,
\q2 kubanga baali batandise okubatiira ddala.
\q1 
\v 39 Yayanjuluzanga ekire ne kibabikka,
\q2 n’omuliro ne gubamulisiza ekiro.
\q1 
\v 40 Baamusaba, n’abaweereza enkwale
\q2 era n’abaliisanga emmere eva mu ggulu ne bakkuta.
\q1 
\v 41 Yayasa olwazi, amazzi ne gatiiriika,
\q2 ne gakulukuta mu ddungu ng’omugga.
\b
\q1 
\v 42 Kubanga yajjukira ekisuubizo kye ekitukuvu
\q2 kye yawa omuweereza we Ibulayimu.
\q1 
\v 43 Abantu be yabaggyayo nga bajaguza,
\q2 abalonde be nga bayimba olw’essanyu.
\q1 
\v 44 Yabawa ensi eyali ey’amawanga amalala,
\q2 ne basikira ebyo abalala bye baakolerera;
\q1 
\v 45 balyoke bakwatenga amateeka ge,
\q2 era bagonderenga ebiragiro bye.
\b
\q1 Mumutendereze \nd Mukama\nd*.
\c 106
\cl Zabbuli 106
\q1 
\v 1 Mumutendereze \nd Mukama\nd*!
\b
\q1 Mwebaze \nd Mukama\nd* kubanga mulungi,
\q2 kubanga okwagala kwe tekuggwaawo emirembe gyonna.
\b
\q1 
\v 2 Ani ayinza okwogera ku bikulu \nd Mukama\nd* by’akola n’abimalayo,
\q2 oba okumutendereza obulungi nga bw’asaanira?
\q1 
\v 3 Balina omukisa abalina obwenkanya,
\q2 era abakola ebituufu bulijjo.
\b
\q1 
\v 4 Onzijukiranga, Ayi \nd Mukama\nd*, bw’obanga okolera abantu bo ebirungi;
\q2 nange onnyambe bw’olibalokola,
\q1 
\v 5 ndyoke neeyagalire wamu n’abalonde bo nga bafunye ebirungi,
\q2 nsanyukire wamu n’eggwanga lyo,
\q2 era ntendererezenga mu bantu bo.
\b
\q1 
\v 6 Twonoonye, nga bajjajjaffe bwe baakola;
\q2 tukoze ebibi ne tusobya nnyo.
\q1 
\v 7 Bakadde baffe
\q2 tebaafaayo kujjukira ebyamagero bye wakola nga bali mu Misiri;
\q1 n’ebyekisa ebingi bye wabakolera tebaabijjukira,
\q2 bwe baatuuka ku Nnyanja Emyufu ne bakujeemera.
\q1 
\v 8 Naye \nd Mukama\nd* n’abalokola, olw’erinnya lye,
\q2 alyoke amanyise amaanyi g’obuyinza bwe obungi.
\q1 
\v 9 Yaboggolera Ennyanja Emyufu, n’ekalira;
\q2 n’abakulembera okubayisa mu buziba ng’abayita ku lukalu mu ddungu.
\q1 
\v 10 Yabawonya abalabe baabwe;
\q2 n’abanunula mu mikono gy’abo ababakyawa.
\q1 
\v 11 Amazzi ne gabuutikira abalabe baabwe;
\q2 ne wataba n’omu awona.
\q1 
\v 12 Olwo ne bakkiriza ebigambo bye, bye yabasuubiza;
\q2 ne bayimba nga bamutendereza.
\b
\q1 
\v 13 Waayita akabanga katono ne beerabira ebyo byonna bye yakola;
\q2 ne batawulirizanga kubuulirira kwe.
\q1 
\v 14 Bwe baatuuka mu ddungu, okwegomba ne kubasukkirira;
\q2 ne bagezesa Katonda nga bali mu lukoola olwo.
\q1 
\v 15 Bw’atyo n’abawa kye baasaba,
\q2 kyokka n’abaleetera n’olumbe olw’amaanyi.
\b
\q1 
\v 16 Nga bali mu lusiisira baakwatirwa obuggya eri Musa
\q2 ne Alooni abalonde ba \nd Mukama\nd*.
\q1 
\v 17 Ettaka ne lyasama ne limira Dasani;
\q2 Abiraamu ne banne ne libasaanyaawo.
\q1 
\v 18 Omuliro ne gukoleera ne gukwata abagoberezi baabwe;
\q2 ennimi z’omuliro ne zookya aboonoonyi.
\q1 
\v 19 Bwe baali e Kolebu ne beekolera ennyana;
\q2 ne basinza ekifaananyi ekyo kye baakola mu byuma bye baasaanuusa.
\q1 
\v 20 Ekitiibwa kya Katonda
\q2 ne bakiwaanyisaamu ekibumbe ekifaanana ente erya omuddo.
\q1 
\v 21 Ne beerabira Katonda eyabanunula,
\q2 eyabakolera ebintu ebikulu bwe bityo mu Misiri,
\q1 
\v 22 ebyamagero bye yabakolera mu nsi ya Kaamu,
\q2 n’ebikolwa eby’entiisa ku Nnyanja Emyufu.
\q1 
\v 23 N’agamba nti,
\q2 Ajja kubazikiriza.
\q1 Naye Musa, omulonde we, n’ayimirira mu maaso ge
\q2 n’amwegayirira, obusungu bwe ne bumuggwaako n’atabazikiriza.
\b
\q1 
\v 24 Baanyooma eby’ensi ennungi,
\q2 kubanga ekisuubizo kye tebaakirinaamu bwesige.
\q1 
\v 25 Beemulugunyiriza mu weema zaabwe,
\q2 ne batagondera ddoboozi lya \nd Mukama\nd*.
\q1 
\v 26 Kyeyava yeerayirira
\q2 nti alibazikiririza mu ddungu,
\q1 
\v 27 era nga n’abaana baabwe
\q2 balisaasaanira mu mawanga ne bafiira eyo.
\b
\q1 
\v 28 Baatandika okusinza Baali e Peoli;
\q2 ne balya ebyaweebwangayo eri bakatonda abataliimu bulamu.
\q1 
\v 29 Ne banyiiza Katonda olw’ebikolwa byabwe ebibi;
\q2 kawumpuli kyeyava abagwamu.
\q1 
\v 30 Naye Finekaasi n’ayimirira wakati waabwe ne Katonda,
\q2 kawumpuli n’agenda.
\q1 
\v 31 Ekyo ne kimubalirwa nga kya butuukirivu
\q2 emirembe gyonna.
\q1 
\v 32 Bwe baatuuka okumpi n’amazzi ag’e Meriba ne banyiiza \nd Mukama\nd*,
\q2 ne baleetera Musa emitawaana;
\q1 
\v 33 kubanga baajeemera ebiragiro bye,
\q2 ne kimwogeza n’ebigambo ebitaali bya magezi.
\b
\q1 
\v 34 Abantu be baalwanyisa tebaabazikiriza
\q2 nga \nd Mukama\nd* bwe yali abalagidde,
\q1 
\v 35 naye beetabika n’abannaggwanga ago
\q2 ne bayiga empisa zaabwe.
\q1 
\v 36 Baasinza ebifaananyi ebikole n’emikono eby’amawanga ago
\q2 ne bibafuukira omutego.
\q1 
\v 37 Baawaayo batabani baabwe
\q2 ne bawala baabwe eri bakatonda abo.
\q1 
\v 38 Ne bayiwa omusaayi gwa batabani baabwe ne bawala baabwe
\q2 abataliiko musango,
\q1 be baawangayo eri ebifaananyi ebikole n’emikono Abakanani bye baakola,
\q2 ensi n’eyonoonebwa n’omusaayi gwabwe.
\q1 
\v 39 Beeyonoona olw’ebyo bye baakola,
\q2 ebikolwa byabwe ne bibafuula abataliimu nsa nga bavudde ku Katonda waabwe.
\b
\q1 
\v 40 \nd Mukama\nd* kyeyava asunguwalira abantu be,
\q2 n’akyawa ezzadde lye.
\q1 
\v 41 N’abawaayo eri amawanga amalala,
\q2 abalabe ne babafuga.
\q1 
\v 42 Abalabe baabwe ne babanyigiriza,
\q2 ne babatuntuza nnyo ddala.
\q1 
\v 43 Yabawonyanga abalabe baabwe emirundi mingi,
\q2 naye obujeemu ne bubalemeramu,
\q2 ebibi byabwe ne bigenda nga bibasaanyaawo.
\b
\q1 
\v 44 Naye bwe yawulira okukaaba kwabwe,
\q2 n’abakwatirwa ekisa;
\q1 
\v 45 ku lwabwe, n’ajjukira endagaano ye;
\q2 okwagala kwe okungi ne kumuleetera okukyusa ekirowoozo kye.
\q1 
\v 46 N’abaleetera okusaasirwa
\q2 abo abaabawambanga.
\q1 
\v 47 Ayi \nd Mukama\nd* Katonda,
\q2 otulokole, otukuŋŋaanye, otuggye mu mawanga,
\q1 tulyoke twebazenga erinnya lyo ettukuvu,
\q2 era tusanyukenga nga tukutendereza.
\b
\q1 
\v 48 \nd Mukama\nd* atenderezebwenga, Katonda wa Isirayiri,
\q2 emirembe n’emirembe.
\b
\q1 Abantu bonna ka boogere nti, “Amiina!”
\b
\q1 Mumutendereze \nd Mukama\nd*.
\c 107
\ms1 EKITABO V
\mr Zabbuli 107–150
\cl Zabbuli 107
\q1 
\v 1 Mwebaze \nd Mukama\nd*, kubanga mulungi;
\q2 okwagala kwe kubeerera emirembe gyonna.
\b
\q1 
\v 2 Kale abanunule ba \nd Mukama\nd* boogere bwe batyo;
\q2 abo be yanunula mu mikono gy’abalabe;
\q1 
\v 3 abo be yakuŋŋaanya mu mawanga; okuva Ebugwanjuba n’Ebuvanjuba,
\q2 n’okuva obukiikakkono ne mu bukiikaddyo.
\b
\q1 
\v 4 Abamu baataataaganira mu malungu
\q2 nga babuliddwa ekkubo eribatwala ku kibuga gye banaabeeranga.
\q1 
\v 5 Baalumwa ennyonta n’enjala,
\q2 obulamu bwabwe ne butandika okusereba.
\q1 
\v 6 Bwe batyo ne bakaabira \nd Mukama\nd* nga bali mu kabi;
\q2 n’abawonya mu kweraliikirira kwabwe.
\q1 
\v 7 Yabakulembera butereevu
\q2 n’abatuusa mu kibuga mwe baabeera.
\q1 
\v 8 Kale singa beebazanga \nd Mukama\nd* olw’okwagala kwe okutaggwaawo,
\q2 n’olw’eby’ekitalo by’akolera abaana b’abantu!
\q1 
\v 9 Kubanga abalina ennyonta abanywesa,
\q2 n’abayala abakkusa ebirungi.
\b
\q1 
\v 10 Abamu baatuulanga mu kizikiza ne mu kisiikirize eky’okufa;
\q2 abasibiddwa mu byuma era abali mu nnaku ennyingi;
\q1 
\v 11 kubanga baajeemera ekigambo kya Katonda,
\q2 ne banyoomoola amagezi g’oyo Ali Waggulu Ennyo.
\q1 
\v 12 Baakozesebwa emirimu egy’amaanyi, emitima gyabwe ne gijjula obuyinike;
\q2 baagwanga wansi, naye nga tebalina abasitulawo.
\q1 
\v 13 Bwe batyo ne bakaabirira \nd Mukama\nd* nga bali mu bizibu byabwe,
\q2 era n’abawonya;
\q1 
\v 14 n’abaggya mu kizikiza ne mu kisiikirize eky’okufa;
\q2 n’enjegere ezaali zibasibye n’azikutula.
\q1 
\v 15 Kale singa beebazanga \nd Mukama\nd* olw’okwagala kwe okutaggwaawo,
\q2 n’olwebikolwa bye eby’ekitalo by’akolera abaana b’abantu!
\q1 
\v 16 Kubanga enzigi ez’ebikomo azaasaayasa,
\q2 n’emitayimbwa egy’ekyuma agimenyamu.
\b
\q1 
\v 17 Abamu baafuuka basirusiru olw’obujeemu bwabwe;
\q2 ne babonaabona olw’ebikolwa byabwe ebibi.
\q1 
\v 18 Ne batamwa emmere yonna, ne babulako katono ddala okufa.
\q1 
\v 19 Bwe batyo ne bakaabirira \nd Mukama\nd* nga bali mu buzibu obwo,
\q2 n’abawonya.
\q1 
\v 20 Yabatumira ekigambo kye, n’awonya endwadde zaabwe;
\q2 n’abalokola mu kuzikirira.
\q1 
\v 21 Kale singa beebazanga \nd Mukama\nd* olw’okwagala kwe okutaggwaawo,
\q2 n’olw’ebikolwa bye eby’ekyewuunyo by’akolera abaana b’abantu!
\q1 
\v 22 Bamuleeterenga ebiweebwayo eby’okwebaza,
\q2 era batendenga ebikolwa bye n’ennyimba ez’essanyu.
\b
\q1 
\v 23 Abalala baasaabalira mu maato ku nnyanja;
\q2 baali basuubuzi b’oku gayanja aganene.
\q1 
\v 24 Baalaba \nd Mukama\nd* bye yakola,
\q2 ebikolwa bye eby’ekitalo mu buziba bw’ennyanja.
\q1 
\v 25 Kubanga yalagira omuyaga
\q2 ne gusitula amayengo waggulu.
\q1 
\v 26 Ne gagulumira okutuuka ku ggulu, ate ne gakka wansi mu ddubi;
\q2 akabenje ne kabayitirira, ne baggwaamu amaanyi.
\q1 
\v 27 Ne beesunda, eruuyi n’eruuyi ne baba ng’omutamiivu atagala;
\q2 n’amagezi ne gabaggwaako.
\q1 
\v 28 Bwe batyo ne bakaabira \nd Mukama\nd* nga bali mu buzibu;
\q2 n’abawonya mu kweraliikirira kwabwe.
\q1 
\v 29 Omuyaga yagusirisa,
\q2 ennyanja n’etteeka.
\q1 
\v 30 Ne bajjula essanyu kubanga ennyanja yateeka;
\q2 n’abakulembera n’abatuusa bulungi ku mwalo gwabwe.
\q1 
\v 31 Kale singa abantu beebazanga \nd Mukama\nd* olw’okwagala kwe okutaggwaawo,
\q2 n’olw’ebikolwa bye eby’ekyewuunyo by’akolera abaana b’abantu!
\q1 
\v 32 Bamugulumizenga ng’abantu bakuŋŋaanye,
\q2 era bamutenderezenga mu lukiiko lw’abakulu.
\b
\q1 
\v 33 Afuula emigga amalungu,
\q2 n’emikutu gy’amazzi ne giba ng’ettaka ekkalu,
\q1 
\v 34 ensi engimu n’agifuula olukoola olw’olunnyo
\q2 olw’obwonoonyi bw’abantu baamu.
\q1 
\v 35 Eddungu yalijjuza ebidiba by’amazzi,
\q2 n’ensi enkalu n’agikulukusizaamu amazzi,
\q1 
\v 36 abalina enjala n’abateeka omwo,
\q2 ne beezimbira ekibuga eky’okubeeramu,
\q1 
\v 37 ennimiro zaabwe ne bazisigamu emmere, ne basimba emizabbibu,
\q2 ne bakungula ebibala bingi.
\q1 
\v 38 Yabawa omukisa gwe, ne beeyongera obungi;
\q2 n’ebisibo byabwe n’atabiganya kukendeera.
\b
\q1 
\v 39 Ate ne bakendeera obungi, ne bakkakkanyizibwa
\q2 olw’okujeezebwa, n’okujoogebwa n’okulaba ennaku;
\q1 
\v 40 oyo anyooma n’abakungu,
\q2 n’ababungeetanyiza mu lukoola omutali kantu.
\q1 
\v 41 Naye abaali mu kwetaaga yabamalako ennaku n’okubonaabona,
\q2 n’ayaza ezzadde lyabwe ng’ebisibo.
\q1 
\v 42 Abagolokofu, bino babiraba ne basanyuka;
\q2 naye abakola ebibi bo basirika busirisi.
\b
\q1 
\v 43 Abalina amagezi bonna, bagondere ebigambo bino
\q2 era bategeere okwagala kwa \nd Mukama\nd* okutaggwaawo.
\c 108
\cl Zabbuli 108
\d Oluyimba. Zabbuli ya Dawudi.
\q1 
\v 1 Omutima gwange munywevu, Ayi Katonda;
\q2 nnaayimbanga ne nkutendereza n’omwoyo gwange gwonna.
\q1 
\v 2 Muzuukuke, mmwe entongooli n’ennanga ey’enkoba,
\q2 nzija kuyimba okukeesa obudde.
\q1 
\v 3 Nnaakutenderezanga, Ayi \nd Mukama\nd*, mu bantu bonna,
\q2 nnaakuyimbiranga mu mawanga gonna.
\q1 
\v 4 Okwagala kwo kunene, kutumbiira okutuuka ku ggulu;
\q2 n’obwesigwa bwo butuuka ku bire.
\q1 
\v 5 Ogulumizibwenga, Ayi Katonda, okuyisa eggulu;
\q2 n’ekitiibwa kyo kibune ensi yonna.
\b
\q1 
\v 6 Tulokole otuyambe n’omukono gwo ogwa ddyo,
\q2 abo booyagala banunulibwe.
\q1 
\v 7 Katonda ayogedde ng’asinziira mu kifo kye ekitukuvu n’agamba nti,
\q2 “Nga nzijudde essanyu, ndisala mu Sekemu,
\q2 era n’Ekiwonvu kya Sukkosi ndikigabanyagabanyaamu.
\q1 
\v 8 Ensi ya Gireyaadi yange, n’eya Manase nayo yange.
\q2 Efulayimu mwe muli abalwanyi bange abazira;
\q2 ate mu Yuda mwe munaavanga bakabaka.
\q1 
\v 9 Mowaabu be baweereza bange abawulize;
\q2 ate Edomu be baddu bange;
\q2 Abafirisuuti ndibaleekaanira mu ddoboozi ery’omwanguka ery’obuwanguzi.”
\b
\q1 
\v 10 Ani anantuusa ku kibuga ekigumu ekinywevu?
\q2 Ani anankulembera okunnyingiza mu Edomu?
\q1 
\v 11 Si ggwe, ayi Katonda, atusudde,
\q2 atakyatabaala n’amaggye gaffe?
\q1 
\v 12 Tudduukirire nga tulwanyisa abalabe baffe,
\q2 kubanga obuyambi bw’abantu temuli nsa.
\q1 
\v 13 Bwe tunaabeeranga ne Katonda tunaabanga bawanguzi;
\q2 kubanga y’anaalinnyiriranga abalabe baffe wansi w’ebigere bye.
\c 109
\cl Zabbuli 109
\d Ya Makulu wa Bayimbi. Zabbuli ya Dawudi.
\q1 
\v 1 Ayi Katonda wange gwe ntendereza,
\q2 tonsiriikirira.
\q1 
\v 2 Kubanga abantu abakola ebibi era abalimba,
\q2 banjogeddeko eby’obulimba.
\q1 
\v 3 Banfukumulidde ebigambo eby’obukyayi,
\q2 ne bannumbagana awatali nsonga.
\q1 
\v 4 Bwe mbalaga omukwano, bo bandaga bukyayi;
\q2 kyokka nze mbasabira.
\q1 
\v 5 Bwe mbakolera ebirungi bo bansasulamu bibi;
\q2 bwe mbalaga okwagala bo bankyawa bukyayi.
\b
\q1 
\v 6 Mumulabire omuntu omukozi w’ebibi amwolekere;
\q2 wabeewo amuwawaabira.
\q1 
\v 7 Bwe banaawoza, omusango gumusinge;
\q2 n’okusaba kwe kufuuke kwonoona.
\q1 
\v 8 Aleme kuwangaala;
\q2 omuntu omulala amusikire.
\q1 
\v 9 Abaana be basigalire awo nga tebaliiko kitaabwe,
\q2 ne mukyala we afuuke nnamwandu.
\q1 
\v 10 Abaana be bataataaganenga nga bagenda basabiriza;
\q2 bagobebwe ne mu bifulukwa mwe basula.
\q1 
\v 11 Amubanja ajje awambe ebibye byonna;
\q2 n’abagwira bamunyageko ebintu bye byonna bye yakolerera.
\q1 
\v 12 Waleme kubaawo amusaasira,
\q2 wadde akolera abaana be ebyekisa.
\q1 
\v 13 Ezzadde lye lizikirizibwe,
\q2 n’amannya g’abazzukulu be gasangulwe mu ago ag’omu mulembe oguliddirira.
\q1 
\v 14 \nd Mukama\nd* ajjukirenga ebyonoono bya bakadde be;
\q2 n’ekibi kya nnyina kireme kwerabirwanga.
\q1 
\v 15 \nd Mukama\nd* ajjukirenga ebyonoono byabwe bulijjo,
\q2 n’ensi ebeerabirire ddala.
\b
\q1 
\v 16 Kubanga talowoozangako kukolera muntu yenna kya kisa;
\q2 naye yayigganyanga abaavu, n’abeetaaga,
\q2 n’abanakuwavu n’abatuusa ne ku kufa.
\q1 
\v 17 Yayagalanga nnyo okukolima; kale ebikolimo bimwefuulire. Teyayagalanga mikisa; kale gimwesambire ddala!
\q1 
\v 18 Yeeteekako okukolima ng’ekyambalo,
\q2 ne kumutobya ng’amazzi,
\q2 ne kuyingira mu magumba ge ng’amafuta.
\q1 
\v 19 Kubeerenga ng’ekyambalo ky’ayambadde,
\q2 era ng’olukoba lwe yeesibye emirembe gyonna.
\q1 
\v 20 Ebyo byonna y’eba ebeera empeera, \nd Mukama\nd* gy’awa abo abandoopaloopa,
\q2 era abanjogerako eby’akabi ebyereere.
\b
\q1 
\v 21 Naye ggwe, Ayi \nd Mukama\nd* Katonda wange,
\q2 nnwanirira olw’erinnya lyo;
\q2 era omponye olw’okwagala kwo okulungi okutaggwaawo.
\q1 
\v 22 Kubanga ndi mwavu era ali mu kwetaaga,
\q2 n’omutima gwange gunyolwa nnyo.
\q1 
\v 23 Sikyaliwo, ndi ng’ekisiikirize eky’akawungeezi;
\q2 mmansuddwa eri ng’enzige.
\q1 
\v 24 Amaviivi gange ganafuye olw’okusiiba;
\q2 omubiri gwange gukozze ne guggwaamu ensa.
\q1 
\v 25 Abandoopaloopa bansekerera;
\q2 bwe bandaba nga banyeenyeza omutwe.
\b
\q1 
\v 26 Mbeera, Ayi \nd Mukama\nd* Katonda wange!
\q2 Ondokole ng’okwagala kwo okutaggwaawo bwe kuli.
\q1 
\v 27 Baleke bategeere nti ggwe okikoze,
\q2 n’omukono gwo Ayi \nd Mukama\nd*.
\q1 
\v 28 Balikoma, naye ggwe olimpa omukisa!
\q2 Leka abannumbagana baswale,
\q2 naye nze omuddu wo nga nsanyuka!
\q1 
\v 29 Abandoopa baswazibwe,
\q2 n’ensonyi zaabwe zibabuzeeko obwekyusizo.
\b
\q1 
\v 30 Nneebazanga \nd Mukama\nd* n’akamwa kange;
\q2 nnaamutenderezanga wakati mu kibiina ekinene.
\q1 
\v 31 Kubanga alwanirira omunaku ali mu kwetaaga,
\q2 n’amuwonya abo abaagala afe.
\c 110
\cl Zabbuli 110
\d Zabbuli ya Dawudi.
\q1 
\v 1 \nd Mukama\nd* yagamba Mukama wange nti:
\b
\q1 “Tuula wano ku mukono gwange ogwa ddyo,
\q2 okutuusa lwe ndimala okufufuggaza abalabe bo
\q2 ne mbassa wansi w’ebigere byo.\f + \fr 110:1 \ft Entebe ez’obwakabaka ez’edda, zaateekebwanga waggulu, kabaka ng’alina kulinnya maddaala okutuulako. Bakabaka abaawangulanga abalabe baabwe, babafufugazanga ne babassa wansi w’ebigere byabwe.\f*”
\b
\q1 
\v 2 \nd Mukama\nd* aligaziya obufuzi bwo okuva mu Sayuuni;
\q2 olifuga abalabe bo.
\q1 
\v 3 Abantu bo balyewaayo bokka mu ggye lyo
\q2 ng’ekiseera ky’olutalo kituuse.
\q1 Abavubuka bo,
\q2 nga bali mu by’ekitiibwa ekitukuvu,
\q2 balikukuŋŋaanirako ng’omusulo bwe gulabika ng’obudde bwakakya.
\b
\q1 
\v 4 \nd Mukama\nd* yalayira,
\q2 era tagenda kukijjulula,
\q1 yagamba nti, “Olibeera kabona emirembe gyonna
\q2 ng’engeri ya Merukizeddeeki bw’eri.”
\b
\q1 
\v 5 Mukama anaakulwaniriranga;
\q2 bakabaka abakulwanyisa anaababetentanga mu busungu bwe obungi.
\q1 
\v 6 Aliramula amawanga, abafuzi b’ensi yonna n’abazikiriza,
\q2 n’entuumo z’emirambo ziriba nnyingi ku nsi yonna.
\q1 
\v 7 Alinywa amazzi mu kagga ku kkubo,
\q2 n’addamu amaanyi ag’obuwanguzi.
\c 111
\cl Zabbuli 111
\q1 
\v 1 Mutendereze \nd Mukama\nd*!
\b
\q1 Nneebazanga \nd Mukama\nd* n’omutima gwange gwonna,
\q2 mu lukiiko lw’abalongoofu, era ne mu lukuŋŋaana.
\b
\q1 
\v 2 \nd Mukama\nd* by’akola bikulu;
\q2 bifumiitirizibwako abo bonna ababisanyukira.
\q1 
\v 3 Emirimu gye mikulu nnyo era gya kitiibwa,
\q2 n’obutuukirivu bwe tebuggwaawo emirembe gyonna.
\q1 
\v 4 Ayamba abantu okujjukira ebyamagero bye,
\q2 \nd Mukama\nd* wa kisa era ajjudde okusaasira.
\q1 
\v 5 Agabira abamutya emmere;
\q2 era ajjukira endagaano ye buli kiseera.
\b
\q1 
\v 6 Abantu be abalaze ng’ebikolwa bye bwe biri eby’amaanyi;
\q2 n’abagabira ensi eyali ey’abannaggwanga.
\q1 
\v 7 By’akola byonna bya bwesigwa era bya bwenkanya;
\q2 n’amateeka ge gonna ga bwesigwa,
\q1 
\v 8 manywevu emirembe gyonna;
\q2 era yagassaawo nga ga bwesigwa era nga ga mazima.
\q1 
\v 9 Yanunula abantu be;
\q2 n’alagira endagaano ye ebeerewo emirembe gyonna.
\q2 Erinnya lye ttukuvu era lya ntiisa!
\b
\q1 
\v 10 Mu kutya \nd Mukama\nd* amagezi mwe gasookera
\q2 era abo abagondera ebigambo ebyo bajjudde obutegeevu.
\q2 \nd Mukama\nd* atenderezebwenga emirembe gyonna.
\c 112
\cl Zabbuli 112
\q1 
\v 1 Mutendereze \nd Mukama\nd*!\f + \fr 112:1 \ft Mu Lwebbulaniya \fqa Aleruuya\f*
\b
\q1 Alina omukisa omuntu atya Katonda,
\q2 era asanyukira ennyo mu mateeka ge.
\b
\q1 
\v 2 Abaana be baliba ba kitiibwa mu nsi;
\q2 omulembe gw’abalongoofu guliweebwa omukisa.
\q1 
\v 3 Ennyumba ye enejjulanga ebintu n’obugagga obungi;
\q2 era anaabanga mutuukirivu ennaku zonna.
\q1 
\v 4 Ne mu kizikiza, ekitangaala kyakira omulongoofu,
\q2 alina ekisa, n’oyo alina okusaasira, era omutuukirivu.
\q1 
\v 5 Omuntu oyo agabira abeetaaga, era tawolera magoba,
\q2 era akola emirimu gye gyonna n’obwenkanya, alifuna ebirungi.
\q1 
\v 6 Omutuukirivu talinyeenyezebwa,
\q2 era anajjukirwanga ennaku zonna.
\q1 
\v 7 Amawulire amabi tegaamutiisenga,
\q2 kubanga omutima gwe munywevu gwesiga \nd Mukama\nd*.
\q1 
\v 8 Omutima gwe guteredde, tewali ky’anaatyanga,
\q2 era oluvannyuma alitunuulira abalabe be n’amaaso ag’obuwanguzi.
\q1 
\v 9 Agabidde abaavu bye beetaaga;
\q2 mutuukirivu ebbanga lyonna;
\q2 era bonna banaamussangamu ekitiibwa.
\b
\q1 
\v 10 Omubi anaabirabanga ebyo, n’asunguwala,
\q2 n’aluma abugigi, naye nga talina kya kukola.
\q2 Okwegomba kw’ababi tekuubengako kye kubagasa.
\c 113
\cl Zabbuli 113
\q1 
\v 1 Mutendereze \nd Mukama\nd*!
\b
\q1 Mumutendereze, mmwe abaweereza be,
\q2 mutendereze erinnya lya \nd Mukama\nd*.
\q1 
\v 2 Erinnya lya \nd Mukama\nd* litenderezebwe
\q2 okuva leero n’okutuusa emirembe gyonna.
\q1 
\v 3 Enjuba weeviirayo okutuusa bw’egwa,
\q2 erinnya lya \nd Mukama\nd* litenderezebwenga.
\b
\q1 
\v 4 \nd Mukama\nd* agulumizibwa okusinga amawanga gonna,
\q2 era n’ekitiibwa kye kisinga eggulu.
\q1 
\v 5 Ani afaanana nga \nd Mukama\nd* Katonda waffe,
\q2 atuula ku ntebe ye ey’obwakabaka eri waggulu ennyo,
\q1 
\v 6 ne yeetoowaza
\q2 okutunuulira eggulu n’ensi?
\b
\q1 
\v 7 Abaavu abayimusa n’abaggya mu nfuufu;
\q2 n’abali mu kwetaaga n’abasitula ng’abaggya mu vvu,
\q1 
\v 8 n’abatuuza wamu n’abalangira,
\q2 awamu n’abalangira abo abafuga abantu be.
\q1 
\v 9 Omukazi omugumba amuwa abaana,
\q2 n’abeera mu maka ge n’ezzadde lye ng’ajjudde essanyu.
\b
\q1 Mutendereze \nd Mukama\nd*!
\c 114
\cl Zabbuli 114
\q1 
\v 1 Isirayiri bwe yava mu Misiri,
\q2 abaana ba Yakobo abo, ne bava mu bantu abaayogeranga olulimi olutali lwabwe;
\q1 
\v 2 Yuda n’afuuka omutukuvu wa Katonda,
\q2 Isirayiri n’afuuka amatwale ge.
\b
\q1 
\v 3 Ennyanja bwe yabalaba n’edduka;
\q2 Omugga Yoludaani ne gudda emabega.
\q1 
\v 4 Ensozi ne zibuukabuuka ng’endiga zisseddume,
\q2 n’obusozi obutono ng’obuliga obuto.
\b
\q1 
\v 5 Ggwe ennyanja, lwaki wadduka?
\q2 Ggwe Yoludaani, lwaki wadda emabega?
\q1 
\v 6 Mmwe ensozi, lwaki mwabuukabuuka ng’endiga zisseddume,
\q2 nammwe obusozi obutono ng’obuliga obuto?
\b
\q1 
\v 7 Kankana, ggwe ensi, mu maaso ga Mukama,
\q2 mu maaso ga Katonda wa Yakobo,
\q1 
\v 8 eyafuula olwazi ekidiba eky’amazzi,
\q2 n’olwazi olugumu n’aluggyamu ensulo ez’amazzi.
\c 115
\cl Zabbuli 115
\q1 
\v 1 Si ffe, Ayi \nd Mukama\nd*, si ffe.
\q2 Wabula erinnya lyo lye ligwana okuweebwanga ekitiibwa,
\q2 olw’okwagala kwo n’olw’obwesigwa bwo.
\b
\q1 
\v 2 Lwaki amawanga gabuuza nti,
\q2 “Katonda waabwe ali ludda wa?”
\q1 
\v 3 Katonda waffe ali mu ggulu;
\q2 akola buli ky’ayagala.
\q1 
\v 4 Bakatonda baabwe bakole mu ffeeza ne zaabu,
\q2 ebikolebwa n’emikono gy’abantu.
\q1 
\v 5 Birina emimwa, naye tebyogera;
\q2 birina amaaso, naye tebiraba.
\q1 
\v 6 Birina amatu, naye tebiwulira;
\q2 birina ennyindo, naye tebiwunyiriza.
\q1 
\v 7 Birina engalo, naye tebikwata;
\q2 birina ebigere, naye tebitambula;
\q2 ne mu bulago bwabyo temuvaamu ddoboozi n’akamu,
\q1 
\v 8 abakozi ababikola,
\q2 n’abo bonna ababyesiga balibifaanana.
\b
\q1 
\v 9 Mmwe ennyumba ya Isirayiri mwesigenga \nd Mukama\nd*,
\q2 ye mubeezi wammwe era ye ngabo yammwe.
\q1 
\v 10 Mmwe ennyumba ya Alooni mwesigenga \nd Mukama\nd*,
\q2 ye mubeezi wammwe era ye ngabo yammwe.
\q1 
\v 11 Mmwe abamutya, mwesigenga \nd Mukama\nd*,
\q2 ye mubeezi wammwe, era ye ngabo yammwe.
\b
\q1 
\v 12 \nd Mukama\nd* anaatujjukiranga, era anaatuwanga omukisa.
\q2 Ab’ennyumba ya Isirayiri anaabawanga omukisa;
\q2 ab’omu nnyumba ya Alooni anaabawanga omukisa;
\q1 
\v 13 n’abo abamutya, ab’ekitiibwa n’abatali ba kitiibwa,
\q2 \nd Mukama\nd* anaabawanga omukisa.
\b
\q1 
\v 14 \nd Mukama\nd* abaaze mweyongere nnyo obungi,
\q2 mmwe n’abaana bammwe.
\q1 
\v 15 \nd Mukama\nd*, eyakola eggulu n’ensi,
\q2 abawe omukisa.
\b
\q1 
\v 16 Eggulu ery’oku ntikko lya \nd Mukama\nd*,
\q2 naye ensi yagiwa abantu bonna.
\q1 
\v 17 Abafu tebatendereza \nd Mukama\nd*,
\q2 wadde abo abaserengeta emagombe.
\q1 
\v 18 Naye ffe tunaatenderezanga \nd Mukama\nd*,
\q2 okuva leero n’okutuusa emirembe gyonna.
\b
\q1 Mutendereze \nd Mukama\nd*!
\c 116
\cl Zabbuli 116
\q1 
\v 1 \nd Mukama\nd* mmwagala,
\q2 kubanga awulidde eddoboozi lyange n’okwegayirira kwange.
\q1 
\v 2 Kubanga ateze okutu kwe gye ndi,
\q2 kyennaavanga mmukoowoola ebbanga lyonna lye ndimala nga nkyali mulamu.
\b
\q1 
\v 3 Emiguwa gy’okufa gyansiba,
\q2 n’okulumwa okw’emagombe kwankwata;
\q2 ne nzijula ennaku nnyingi n’okutya.
\q1 
\v 4 Ne ndyoka nkoowoola erinnya lya \nd Mukama\nd* nti,
\q2 “Ayi \nd Mukama\nd*, ndokola.”
\b
\q1 
\v 5 \nd Mukama\nd* wa kisa, era mutuukirivu;
\q2 Katonda waffe ajjudde okusaasira.
\q1 
\v 6 \nd Mukama\nd* alabirira abantu abaabulijjo;
\q2 bwe nnali mu buzibu obunene, n’andokola.
\b
\q1 
\v 7 Wummula ggwe emmeeme yange,
\q2 kubanga \nd Mukama\nd* abadde mulungi gy’oli.
\q1 
\v 8 Kubanga ggwe, Ayi \nd Mukama\nd*, owonyezza omwoyo gwange okufa,
\q2 n’amaaso gange ogawonyezza okukaaba;
\q2 n’ebigere byange n’obiwonya okwesittala,
\q1 
\v 9 ndyoke ntambulirenga mu maaso ga \nd Mukama\nd*
\q2 mu nsi ey’abalamu.
\b
\q1 
\v 10 Nakkiriza kyennava njogera nti,
\q2 “Numizibbwa nnyo.”
\q1 
\v 11 Ne njogera nga nterebuse nti,
\q2 “Abantu bonna baliraba.”
\b
\q1 
\v 12 \nd Mukama\nd* ndimusasula ntya
\q2 olw’ebirungi bye ebingi bwe bityo by’ankoledde?
\q1 
\v 13 Nditoola ekikompe eky’obulokozi,
\q2 ne nkoowoola erinnya lya \nd Mukama\nd*.
\q1 
\v 14 Ndituukiriza obweyamo bwange eri \nd Mukama\nd*,
\q2 mu maaso g’abantu be bonna.
\b
\q1 
\v 15 Okufa kw’abatukuvu ba \nd Mukama\nd* kwa muwendo nnyo eri \nd Mukama\nd*.
\q1 
\v 16 Ayi \nd Mukama\nd*,
\q2 onsumuluddeko ebyansiba n’onfuula wa ddembe,
\q2 nange nnaakuweerezanga ennaku zonna.
\b
\q1 
\v 17 Ndiwaayo ekiweebwayo eky’okwebaza,
\q2 ne nkoowoola erinnya lya \nd Mukama\nd*.
\q1 
\v 18 Ndituukiriza obweyamo bwange eri \nd Mukama\nd*,
\q2 mu maaso g’abantu be bonna,
\q1 
\v 19 mu mpya z’ennyumba ya \nd Mukama\nd*;
\q2 wakati wo, ggwe Yerusaalemi.
\b
\q1 Mutendereze \nd Mukama\nd*.
\c 117
\cl Zabbuli 117
\q1 
\v 1 Mutendereze \nd Mukama\nd*, mmwe ensi zonna;
\q2 mumugulumize, mmwe amawanga gonna.
\q1 
\v 2 Kubanga okwagala kwe okutaggwaawo kungi gye tuli;
\q2 n’obwesigwa bwa \nd Mukama\nd* bwa lubeerera.
\b
\q1 Mutendereze \nd Mukama\nd*.
\c 118
\cl Zabbuli 118
\q1 
\v 1 Mwebaze \nd Mukama\nd*, kubanga mulungi;
\q2 okwagala kwe kubeerera emirembe gyonna.
\b
\q1 
\v 2 Kale Isirayiri ayogere nti,
\q2 “Okwagala kwa \nd Mukama\nd* kubeerera emirembe gyonna.”
\q1 
\v 3 N’ab’ennyumba ya Alooni boogere nti,
\q2 “Okwagala kwe kubeerera emirembe gyonna.”
\q1 
\v 4 Abo abatya \nd Mukama\nd* boogere nti,
\q2 “Okwagala kwe kubeerera emirembe gyonna.”
\b
\q1 
\v 5 Bwe nnali mu nnaku empitirivu, nakoowoola \nd Mukama\nd*,
\q2 n’annyanukula, n’agimponya.
\q1 
\v 6 \nd Mukama\nd* ali ku ludda lwange, siriiko kye ntya.
\q2 Abantu bayinza kunkolako ki?
\q1 
\v 7 \nd Mukama\nd* ali nange, ye anyamba.
\q2 Abalabe bange nnaabatunuuliranga n’amaaso ag’obuwanguzi.
\b
\q1 
\v 8 Kirungi okwesiga \nd Mukama\nd*
\q2 okusinga okwesiga omuntu.
\q1 
\v 9 Kirungi okuddukira eri \nd Mukama\nd*
\q2 okusinga okwesiga abalangira.
\q1 
\v 10 Ensi zonna zanzinda ne zinneebungulula,
\q2 naye mu linnya lya \nd Mukama\nd* naziwangula.
\q1 
\v 11 Banneebungulula enjuuyi zonna;
\q2 naye mu linnya lya \nd Mukama\nd* nabawangula.
\q1 
\v 12 Bankuŋŋaanirako ne banneebungulula ng’enjuki;
\q2 naye ne basirikka ng’amaggwa agakutte omuliro;
\q2 mu linnya lya \nd Mukama\nd* nabawangula.
\q1 
\v 13 Bannumba n’amaanyi mangi, ne mbulako katono okugwa;
\q2 naye \nd Mukama\nd* n’annyamba.
\q1 
\v 14 \nd Mukama\nd* ge maanyi gange, era lwe luyimba lwange,
\q2 afuuse obulokozi bwange.
\b
\q1 
\v 15 Muwulire ennyimba ez’essanyu ez’obuwanguzi,
\q2 nga ziyimbirwa mu weema z’abatuukirivu nti,
\q2 “Omukono gwa \nd Mukama\nd* ogwa ddyo gutukoledde ebikulu!
\q1 
\v 16 Omukono gwa \nd Mukama\nd* ogwa ddyo gugulumizibbwa;
\q2 omukono gwa \nd Mukama\nd* ogwa ddyo gutukoledde ebikulu!”
\q1 
\v 17 Sijja kufa, wabula nzija kuba mulamu,
\q2 ndyoke ntegeeze ebyo byonna \nd Mukama\nd* by’akoze.
\q1 
\v 18 \nd Mukama\nd* ambonerezza nnyo,
\q2 naye tandese kufa.
\q1 
\v 19 Munzigulirewo emiryango egy’obutuukirivu,
\q2 nnyingire, neebaze \nd Mukama\nd*.
\q1 
\v 20 Guno gwe mulyango omunene ogwa \nd Mukama\nd*,
\q2 abatuukirivu mmwe banaayingiriranga.
\q1 
\v 21 Nkwebaza kubanga onnyanukudde
\q2 n’ofuuka obulokozi bwange.
\b
\q1 
\v 22 Ejjinja abazimbi lye baagaana lye
\q2 lifuuse ejjinja ekkulu ery’oku nsonda.
\q1 
\v 23 Kino \nd Mukama\nd* ye yakikola;
\q2 era ffe tukiraba nga kya kitalo mu maaso gaffe.
\q1 
\v 24 Luno lwe lunaku \nd Mukama\nd* lw’akoze;
\q2 tusanyuke tulujagulizeeko.
\b
\q1 
\v 25 Ayi \nd Mukama\nd* tukwegayiridde, tulokole,
\q2 Ayi \nd Mukama\nd* tukwegayiridde otuwe obuwanguzi.
\b
\q1 
\v 26 Alina omukisa oyo ajja mu linnya lya \nd Mukama\nd*.
\q2 Tubasabidde omukisa nga tuli mu nnyumba ya \nd Mukama\nd*.
\q1 
\v 27 \nd Mukama\nd* ye Katonda,
\q2 y’atwakiza omusana.
\q1 Mukumbire wamu nga mukutte amatabi mu ngalo zammwe n’ekiweebwayo kyammwe
\q2 kituukire ddala ku mayembe g’ekyoto.
\b
\q1 
\v 28 Ggwe Katonda wange, nnaakwebazanga;
\q2 ggwe Katonda wange, nange nnaakugulumizanga.
\b
\q1 
\v 29 Mwebaze \nd Mukama\nd* kubanga mulungi,
\q2 n’okwagala kwe kubeerera emirembe gyonna.
\c 119
\cl Zabbuli 119
\qa א Alefu
\q1 
\v 1 Balina omukisa abo abatambulira mu butuukirivu;
\q2 abatambulira mu mateeka ga \nd Mukama\nd*.
\q1 
\v 2 Balina omukisa abo abagondera ebiragiro bye,
\q2 era abanoonya \nd Mukama\nd* n’omutima gwabwe gwonna.
\q1 
\v 3 Abo abatasobya, era abatambulira mu makubo ge.
\q1 
\v 4 Ggwe wateekawo ebiragiro byo;
\q2 n’olagira bigonderwenga n’obwegendereza bungi.
\q1 
\v 5 Ayi \nd Mukama\nd*, nsaba mbeerenga munywevu bulijjo;
\q2 nga nkuuma bye walagira.
\q1 
\v 6 Bwe ntyo siriswazibwa, amaaso gange nga
\q2 ngasimbye ku ebyo bye walagira byonna.
\q1 
\v 7 Nga njiga ebiragiro byo ebitukuvu,
\q2 nnaakutenderezanga n’omutima omulungi.
\q1 
\v 8 Nnaakwatanga amateeka go;
\q2 Ayi \nd Mukama\nd*, tonsuulira ddala.
\qa ב Bessi
\q1 
\v 9 Omuvubuka anaakuumanga atya ekkubo lye nga ttereevu?
\q2 Anaalikuumanga ng’agoberera ekigambo kyo nga bwe kiri.
\q1 
\v 10 Nkunoonya n’omutima gwange gwonna;
\q2 tonzikiriza kuva ku mateeka go.
\q1 
\v 11 Ntadde ekigambo kyo mu mutima gwange;
\q2 ndyoke nneme okwonoona.
\q1 
\v 12 Ogulumizibwe, Ayi \nd Mukama\nd*;
\q2 onjigirize amateeka go.
\q1 
\v 13 Njatula n’akamwa kange
\q2 amateeka go gonna ge walagira.
\q1 
\v 14 Nsanyukira okugondera ebiragiro byo,
\q2 ng’asanyukira eby’obugagga.
\q1 
\v 15 Nnaafumiitirizanga ku biragiro byo,
\q2 ne nzisaayo omwoyo ku makubo go.
\q1 
\v 16 Nnaasanyukiranga amateeka go,
\q2 era siigeerabirenga.
\qa ג Gimero
\q1 
\v 17 Omuddu wo omukolere ebirungi, mbe omulamu,
\q2 ngobererenga ekigambo kyo.
\q1 
