\id PHM  
\h Filemón 
\toc1 YA'A KUU CARTA JA NI CHAA SAN PABLO APOSTOL NUU FILEMON 
\toc2 Filemón 
\toc3 Flm. 
\mt2 LA EPISTOLA DEL APOSTOL SAN PABLO A FILEMON 
\mt1 YA'A KUU CARTA JA NI CHAA SAN PABLO APOSTOL NUU FILEMON 
\c 1  
\p  
\v 1 Máá‑rí kúu Pablo, te kándee‑ri̱ veka̱a ja̱ sɨkɨ́ Jesucristo te jíín ñaní‑yo̱ Timoteo katájí‑rí tutu̱ yá'a nuu̱‑ro̱ Filemón, chaa mani jíín‑rí kúu‑ró, te chíndéé tá'an‑ró jíín‑rí.  
\v 2 Suni káchaa‑ri̱ tutu̱ yá'a nuu̱ Apia, ña'an maní jíín‑ró, jíín núu̱ Arquipo, cha̱a chíndéé tá'an jíín‑rí sɨkɨ̱ tíñu kándúkú ndéé‑rí yá'a, jíín núu̱ tɨ́ku'ni̱ kákandíja íó ini̱ ve̱'e‑ró jián.  
\v 3 Tu̱'un luu íó ini̱‑ya̱ jíín tú'un kuaká'nu ini̱ ja̱ kíi nuu̱ máá Táa̱‑yo̱ Dios jíín já kíi nuu̱ máá Jíto'o̱‑yo̱ Jesucristo ná kóo jíín‑ró jíná'an‑ró.  
\v 4 Nákuatá'ú‑rí nuu̱ Dios máá‑rí, te nene̱ núku̱'un ini̱‑ri̱ róó, nú jikán ta'u̱‑rí nuu̱‑yá.  
\v 5 Chi̱ a jíni so̱'o‑ri̱ ja̱ bueno kákundá'ú ini̱‑ro̱ táká ña̱yɨvɨ ndóo, te kándíja va̱'a‑ró núu̱ máá Jíto'o̱‑yo̱ Jesús.  
\v 6 Te jikán‑ri̱ nuu̱‑yá náva̱'a nú kájani‑ró tú'un te ná skándíja va̱'a‑ró‑i, te kuni̱ kájí‑i ta̱ká tiñu va̱'a káñava̱'a‑yó jíín Cristo Jesús.  
\v 7 Chi̱ kákusɨɨ̱ xáa̱n iní‑ri̱, te ká'i̱o ndéé iní‑ri̱, ja̱ súan kákundá'ú ini̱‑ro̱‑í, chi ja̱ róó ñáni̱, te ni̱ nani'i̱n‑gá ini̱ añú ña̱yɨvɨ ndóo. 
\s1 Ja̱ ní ka'a̱n Pablo ja'a̱ Onésimo 
\p  
\v 8 Núsáá te va̱sa kuu chundéé iní‑ri̱, sá'a Cristo, ja̱ tá'ú‑rí tiñu nuu̱‑ro̱ núú, ja̱ ná skíkuu‑ró tíñu va̱'a,  
\v 9 chi̱ sua va'a̱‑ga̱ ná ká'a̱n nda̱'ú‑ri̱ jíín‑ró já jíín sɨkɨ́ já maní‑ro̱ jíín‑rí, jíín sɨkɨ́ já rúu̱ kúu Pablo, cha̱a ni̱ yii jíín já kándee‑ri̱ veka̱a ja̱ sɨkɨ́ Jesucristo.  
\v 10 Núsáá te ká'a̱n nda̱'ú‑ri̱ jíín‑ró já ná sá'a‑ró túká'nu ini̱‑ro̱ núu̱ sé'e‑ri̱ Onésimo, chi̱ a ni̱ skándíja‑ri̱‑i nini kándee‑ri̱ veka̱a.  
\v 11 Te su̱chí yá'a, tú ní ní'i̱n tíñu‑i nuu̱‑ro̱ sáá, ko vina, chi̱ bueno ní'i̱n tíñu‑i nuu̱‑ro̱ jíín núu̱‑rí.  
\v 12 Te ná nátájí‑rí‑i najaa̱‑i nuu̱‑ro̱. Te kuatá'ú‑ró‑i, nátu̱'un ruu̱, chi̱ ɨɨn‑ni kákuu‑ri̱ jíín‑i.  
\v 13 Te kúsɨɨ̱ iní‑ri̱ ja̱ kúnchaa̱‑i jíín‑rí te kuu‑i yu'u núu̱‑ro̱ kuátíñu‑i nuu̱‑rí núú, nini kándee‑ri̱ veka̱a ja̱ sɨkɨ́ máá tú'un va̱'a.  
\v 14 Ko tú ní kuní‑ri̱ sá'a‑ri̱ súan, onde̱ nú tú kuatu̱'un máá‑ró, chi̱ nasu̱ stétuu‑ri̱ róó sá'a va̱'a‑ró, chi̱ sua sɨkɨ̱ já játa'a̱n ini̱‑ro̱.  
\v 15 Chi̱ sanaa te ja̱ sɨkɨ́ yúán kúu ja̱ ní jinu‑i ni̱ jito‑i róó yaku̱ tiempo ni̱ sá'a‑ya̱, náva̱'a kuu naki'in‑ró‑i te ma̱ sía̱ tá'an‑ró jíín‑i nɨ́ɨ́ káni.  
\v 16 Te ma̱ káni‑ga̱ ini̱‑ro̱ já mozo kúu‑i, chi̱ va̱'a‑ga̱ koo‑ró jíín‑i vásá jíín mozo nátu̱'un mani̱‑ro̱ jíín ɨ́ɨn ñani̱‑ro̱, chi̱ súan jáni ini̱‑ri̱ jíto‑ri̱‑i. Ko ví'í‑gá kúu máá‑i nuu̱ máá‑ró ja̱ sɨkɨ́ tá'an‑ró kúu‑i jíín já sɨkɨ́ máá Jíto'o̱‑yo̱.  
\v 17 Núsáá te nú jiní máá‑ró já cháa chíndéé tá'an jíín‑ró kúu‑ri̱, te ná kuatá'ú‑ró‑i, nátu̱'un ruu̱ núsáá.  
\v 18 Te nú na̱ún falta ni̱ sá'a‑i jíín‑ró, xí taú‑i nuu̱‑ro̱, te sɨkɨ̱ máá‑rí ná chí'i‑ró cuenta.  
\v 19 Máá‑rí kúu Pablo, cháa‑ri̱ tutu̱ yá'a jíín ndá'a máá‑rí, te máá‑rí chunáa. Súan ká'a̱n‑ri̱ lugar ja̱ ká'a̱n‑ri̱ ja̱ súni onde̱ jíín máá‑ró jíín añú‑ro̱ taú‑ro̱ núu̱‑rí.  
\v 20 Jándáa̱ ñáni̱, kuní‑ri̱ ja̱ ná kúsɨɨ̱ iní‑ri̱ sá'a‑ró sɨkɨ́ tíñu máá Jíto'o̱‑yo̱. Te ná náni'i̱n‑gá ini̱‑ri̱ sá'a‑ró jíín máá Jíto'o̱‑yo̱.  
\v 21 Cháa‑ri̱ tutu̱ yá'a nuu̱‑ro̱, chi̱ kúva̱'a ini̱‑ri̱ ja̱ kuándatu̱ va̱'a‑ró, te jiní‑ri̱ ja̱ skíkuu‑ga̱‑ro̱ vásá já ní ka'a̱n‑ri̱ jíín‑ró.  
\v 22 Te suni kuní‑ri̱ ja̱ sátu̱'a‑ró nú kúnchaa̱‑ri̱, chi̱ ñúkuu ini̱‑ri̱ kenda‑ri̱ yá'a te jaa̱‑ri̱ nuu̱‑ro̱, sá'a‑ya̱ jíín tú'un jikán ta'u̱‑ro̱ já'a̱‑rí.  
\v 23 Te Epafras, cha̱a kándee ta'a̱n jíín‑rí veka̱a yá'a ja̱ sɨkɨ́ Cristo Jesús, ká'a̱n‑de ja̱ násándéé iní‑ro̱.  
\v 24 Te Marcos, Aristarco, Demas, jíín Lucas, cha̱a kásátiñu ta'a̱n jíín‑rí, suni súan káka'a̱n‑de.  
\v 25 Tu̱'un luu íó ini̱ máá Jíto'o̱‑yo̱ Jesucristo ná kóo ini̱‑ro̱. Súan ná kóo. Amén.