\id JOL - Biblica® Open Ndebele Contemporary Bible 
\h UJoweli 
\toc1 UJoweli 
\toc2 UJoweli 
\toc3 Jow 
\mt1 UJoweli 
\c 1  
\p  
\v 1 Ilizwi \nd likaThixo\nd* lafika kuJoweli indodana kaPhethuweli. 
\b  
\s1 Ukuhlasela Kwesikhongwane 
\q1  
\v 2 Zwanini lokhu, lina badala; 
\q2 lalelani lonke lina elihlala elizweni. 
\q1 Into enjengale seyake yenzakala na ensukwini zenu 
\q2 loba ensukwini zabokhokho benu? 
\q1  
\v 3 Kutsheleni abantwabenu, 
\q2 abantwabenu labo batshele ababantwababo, 
\q2 abantwababo batshele isizukulwane esilandelayo. 
\q1  
\v 4 Lokho okutshiywe ngumtshitshi wezintethe 
\q2 kudliwe yisikhongwane; 
\q1 okutshiywe yisikhongwane 
\q2 kudliwe yibuyane; 
\q1 okutshiywe yibuyane 
\q2 kudliwe ngezinye intethe. 
\b  
\q1  
\v 5 Vukani lina zidakwa likhale! 
\q2 Lilani lonke lina banathi bewayini; 
\q1 lilani ngenxa yewayini elitsha, 
\q2 ngoba lihluthunwe ezindebeni zenu. 
\q1  
\v 6 Isizwe sihlasele ilizwe lami, 
\q2 silamandla asingeke sibalwe, 
\q1 silamazinyo esilwane, 
\q2 ingavula zesilwanekazi. 
\q1  
\v 7 Sesitshabalalise izivini zami, 
\q2 saqothula lezihlahla zami zemikhiwa. 
\q1 Sebule amaxolo azo 
\q2 sawaphosela khatshana, 
\q2 ingatsha zazo zasala sezimhlophe nke. 
\b  
\q1  
\v 8 Lilani njengentombi egqoke isaka 
\q2 idabukele umyeni wobutsha bayo. 
\q1  
\v 9 Umnikelo wamabele lomnikelo wokunathwa 
\q2 kususiwe endlini \nd kaThixo\nd*. 
\q1 Abaphristi bayalila, 
\q2 bona abakhonzayo phambi \nd kukaThixo\nd*. 
\q1  
\v 10 Amasimu atshabalele, 
\q2 umhlabathi womile; 
\q1 amabele onakele, 
\q2 iwayini elitsha liphelile, 
\q2 amafutha kawasekho. 
\b  
\q1  
\v 11 Delani, lina balimi, 
\q2 lilani, lina balimi bamavini; 
\q1 bubulelani ingqoloyi lebhali, 
\q2 ngoba isivuno sensimu sitshabalalisiwe. 
\q1  
\v 12 Ivini lomile 
\q2 lomkhiwa ubunile; 
\q1 iphomegranathi, lelala lesihlahla sama-aphula, 
\q2 zonke izihlahla zeganga, zomile. 
\q1 Impela ukuthokoza kwabantu 
\q2 kuphelile. 
\s1 Isimemezelo Sokuphenduka 
\q1  
\v 13 Vunulani amasaka, lina baphristi, likhale. 
\q2 Lilani lina elikhonzayo phambi kwe-alithari. 
\q1 Wozani, lilale lembethe amasaka ebusuku, 
\q2 lina elikhonzayo phambi kukaNkulunkulu wami, 
\q1 ngoba iminikelo yamabele leminikelo yokunathwayo igodliwe, 
\q2 kayanikelwa endlini kaNkulunkulu wenu. 
\q1  
\v 14 Memezelani ukuzila okungcwele; 
\q2 bizani ibandla elingcwele. 
\q1 Memani abadala 
\q2 labo bonke abahlala elizweni, 
\q1 baye endlini \nd kaThixo\nd* uNkulunkulu wenu, 
\q2 likhale \nd kuThixo\nd*. 
\b  
\q1  
\v 15 Maye ngalolosuku! 
\q2 Ngoba usuku \nd lukaThixo\nd* seluseduze; 
\q2 luzafika njengencithakalo evela kuSomandla. 
\b  
\q1  
\v 16 Ukudla akuzange kuphele 
\q2 phambi kwamehlo ethu, 
\q1 lokuthokoza kanye lokuthaba 
\q2 endlini kaNkulunkulu wethu na? 
\q1  
\v 17 Inhlanyelo itshwabhene 
\q2 ngaphansi kwamagade. 
\q1 Izindlu zamabele zingamanxiwa, 
\q2 iziphala zidiliziwe, 
\q2 ngoba amabele kawasekho. 
\q1  
\v 18 Yeka ukukhala kwezinkomo! 
\q2 Imihlambi yenkomo iyaphithizela 
\q1 ngoba kayilamadlelo; 
\q2 lemihlambi yezimvu iyahlupheka. 
\b  
\q1  
\v 19 Ngiyakhala kuwe \nd Thixo\nd*, 
\q2 ngoba umlilo usuqede amadlelo 
\q2 lamalangabi asetshise zonke izihlahla zeganga. 
\q1  
\v 20 Lezinyamazana zeganga zifuna wena; 
\q2 izifula zamanzi sezicitshile njalo 
\q2 lomlilo usuqede amadlelo. 
\c 2  
\s1 Umtshitshi Wentethe 
\q1  
\v 1 Vuthelani icilongo eZiyoni; 
\q2 hlabani umkhosi entabeni yami engcwele. 
\b  
\q1 Bonke abahlala elizweni kabathuthumele, 
\q2 ngoba usuku \nd lukaThixo\nd* luyeza. 
\q1 Selusondele, selufikile, 
\q2  
\v 2 usuku lomnyama lokudana, 
\q2 usuku lwamayezi lobumnyama. 
\q1 Njengokusa kusendlaleka phezu kwezintaba, 
\q2 liyeza ibutho elikhulu elilamandla 
\q1 elingazange libe khona endulo 
\q2 kumbe libe khona eminyakeni ezayo. 
\b  
\q1  
\v 3 Phambi kwabo umlilo uyatshisa, 
\q2 ngemva kwabo amalangabi ayavutha. 
\q1 Phambi kwabo ilizwe linjengensimu yase-Edeni 
\q2 ngemva kwabo yinkangala elugwadule, 
\q2 akukho okubaphunyukayo. 
\q1  
\v 4 Bakhangeleka benjengamabhiza; 
\q2 bamatha njengamabhiza empi. 
\q1  
\v 5 Ngomsindo onjengowezinqola zempi, 
\q2 beqa phezu kwezingqongo zezintaba, 
\q1 njengamabibi omlilo etshisa inhlanga, 
\q2 njengebutho elilamandla selilungele impi. 
\b  
\q1  
\v 6 Ekubaboneni nje, izizwe zizwa ubuhlungu; 
\q2 ubuso bonke buyadana. 
\q1  
\v 7 Bahlasela njengamaqhawe; 
\q2 bakhwele imiduli njengamabutho. 
\q1 Bonke bahamba beludwendwe 
\q2 bengaphambuki endleleni yabo. 
\q1  
\v 8 Kabasunduzani; 
\q2 lowo lalowo uhamba eqonde phambili. 
\q1 Badabula phakathi kwezivikelo 
\q2 kungekho kwehlukana kubo. 
\q1  
\v 9 Baya ngesiqubu edolobheni; 
\q2 bagijima besekele umduli. 
\q1 Bayakhwela bangene ezindlini; 
\q2 bangena ngamawindi njengamasela. 
\b  
\q1  
\v 10 Umhlaba uyanyikinyeka phambi kwabo; 
\q2 umkhathi uyaqhaqhazela, 
\q1 ilanga lenyanga kube mnyama, 
\q2 lezinkanyezi kazisakhanyisi. 
\q1  
\v 11 \nd UThixo\nd* uyakhwaza 
\q2 phambi kwebutho lakhe; 
\q1 amabutho akhe angeke abalwe, 
\q2 njalo balamandla labo abalalela ukulaya kwakhe. 
\q1 Usuku \nd lukaThixo\nd* lukhulu; 
\q2 luyesabeka. 
\q2 Ngubani ongalumela na? 
\s1 Guqulani Inhliziyo Zenu 
\q1  
\v 12 “Lakhathesi,” kutsho \nd uThixo\nd*, 
\q2 “phendukelani kimi ngenhliziyo zenu zonke, 
\q2 ngokuzila langokukhala lokulila.” 
\b  
\q1  
\v 13 Dabulani inhliziyo zenu 
\q2 hatshi izigqoko zenu. 
\q1 Buyelani \nd kuThixo\nd* uNkulunkulu wenu, 
\q2 ngoba ulomusa lesihawu, 
\q1 uyaphuza ukuthukuthela, ulothando olukhulu, 
\q2 njalo uyaxola ukuthumela umonakalo. 
\q1  
\v 14 Ngubani owaziyo? Engxenye angaphenduka abe lesihawu 
\q2 atshiye isibusiso, 
\q1 iminikelo yamabele leminikelo yokunathwayo 
\q2 \nd kaThixo\nd* uNkulunkulu wenu. 
\b  
\q1  
\v 15 Vuthelani icilongo eZiyoni, 
\q2 memezelani ukuzila okungcwele, 
\q2 bizani ibandla elingcwele. 
\q1  
\v 16 Buthanisani abantu, 
\q2 ngcwelisani ibandla; 
\q1 hlanganisani abadala, 
\q2 buthanisani abantwana 
\q2 labo abamunyayo. 
\q1 Umyeni katshiye indlu yakhe 
\q2 lomlobokazi atshiye ikamelo lakhe. 
\q1  
\v 17 Abaphristi abakhonzayo phambi \nd kukaThixo\nd*, 
\q2 kabakhale bephakathi laphakathi kwentuba le-alithari. 
\q1 Kabathi, “Awu \nd Thixo\nd*, zwela abantu bakho. 
\q2 Ungenzi ilifa lakho libe yinto yokuhlekwa, 
\q2 isiga phakathi kwezizwe. 
\q1 Kungani phakathi kwezizwe kumele bathi, 
\q2 ‘Ungaphi uNkulunkulu wabo?’ ” 
\s1 Impendulo \nd KaThixo\nd* 
\q1  
\v 18 Lapho-ke \nd uThixo\nd* uzakuba lobukhwele ngelizwe lakhe 
\q2 abe lesihawu ebantwini bakhe. 
\p  
\v 19 \nd UThixo\nd* uzabaphendula athi: 
\q1 “Ngiyalithumela amabele lewayini elitsha lamafutha, 
\q2 okwaneleyo ukulisuthisa ngokugcweleyo; 
\q1 angiyikuphinda futhi ukulenza 
\q2 into yokuhlekisa ezizweni. 
\b  
\q1  
\v 20 Ibutho lasenyakatho ngizalixotshela khatshana lani, 
\q2 ngilifuqele elizweni elomileyo elilugwadule, 
\q1 amaviyo alo aphambili esiya olwandle lwasempumalanga 
\q2 lawo angemuva esiya olwandle lwasentshonalanga. 
\q1 Iphunga lalo elibi lizakuya phezulu, 
\q2 umnuko walo uzaphakama.” 
\b  
\q1 Ngempela wenze izinto ezinkulu ezimangalisayo. 
\q2  
\v 21 Ungesabi, wena lizwe; 
\q2 thaba uthokoze. 
\q1 Impela \nd uThixo\nd* wenze izinto ezinkulu. 
\q2  
\v 22 Lingesabi, lina zinyamazana zeganga, 
\q2 ngoba amadlelo asesiba luhlaza. 
\q1 Izihlahla sezithela izithelo zazo; 
\q2 imikhiwa lemivini kuthela kakhulu. 
\q1  
\v 23 Thabani, lina bantu baseZiyoni, 
\q2 thokozani \nd kuThixo\nd* uNkulunkulu wenu 
\q1 ngoba ulinike izulu lekwindla 
\q2 ngokulunga. 
\q1 Ulilethela izulu elinengi 
\q2 kanye lezulu lekwindla lelentwasa, njengakuqala. 
\q1  
\v 24 Iziza zizagcwala amabele; 
\q2 izikhamelo zizaphuphuma iwayini lamafutha. 
\b  
\q1  
\v 25 “Ngizalihlawula okwaleyo minyaka lokho okwadliwa zintethe, 
\q2 lesikhonyane lobuyane, 
\q2 ezinye izintethe kanye lemitshitshi yezintethe, 
\q1 ibutho lami elikhulu engalithumela kini. 
\q1  
\v 26 Lizakuba lokudla okunengi lize lisuthe, 
\q2 njalo lizadumisa ibizo \nd likaThixo\nd* uNkulunkulu wenu, 
\q2 olenzele izimangaliso; 
\q1 abantu bami kabayikuphinda bayangeke futhi. 
\q1  
\v 27 Ngakho lizakwazi ukuthi ngiko-Israyeli, 
\q2 lokuthi mina \nd nginguThixo\nd* uNkulunkulu wenu, 
\q2 kanye lokuthi kakho omunye; 
\q1 abantu bami kabayikuphinda bayangeke futhi.” 
\s1 Usuku \nd LukaThixo\nd* 
\q1  
\v 28 “Emva kwalokho, 
\q2 ngizathululela uMoya wami kubo bonke abantu. 
\q1 Amadodana lamadodakazi enu azaphrofitha, 
\q2 izinsizwa zenu zizabona imibono, 
\q2 lamaxhegu enu azaphupha amaphupho. 
\q1  
\v 29 Lasezincekwini zami, ezesilisa lezesifazane, 
\q2 ngizawuthulula uMoya wami ngalezonsuku. 
\q1  
\v 30 Ngizabonakalisa izimangaliso emazulwini 
\q2 lasemhlabeni, 
\q2 igazi lomlilo lezikhatha zentuthu. 
\q1  
\v 31 Ilanga lizaphendulwa libe yibumnyama 
\q2 lenyanga ibeligazi 
\q2 phambi kokuba kufike 
\q2 usuku olukhulu \nd lukaThixo\nd*, olwesabekayo. 
\q1  
\v 32 Njalo wonke obiza 
\q2 ibizo \nd likaThixo\nd* uzasindiswa; 
\q1 ngoba eNtabeni iZiyoni laseJerusalema 
\q2 kuzakuba lokukhululwa, 
\q2 njengoba \nd uThixo\nd* etshilo, 
\q1 iloba phakathi kwabasindileyo 
\q2 labo ababizwa \nd nguThixo\nd*.” 
\c 3  
\s1 Izizwe Ziyahlulelwa 
\q1  
\v 1 “Ngalezonsuku langalesosikhathi, 
\q2 lapho sengibuyisela inotho kaJuda leJerusalema, 
\q1  
\v 2 ngizaqoqa izizwe zonke 
\q2 ngizehlisele eSigodini sikaJehoshafathi. 
\q1 Lapho-ke ngizazahlulela 
\q2 mayelana lelifa lami, abantu bami u-Israyeli 
\q1 ngoba zahlakazela abantu bami phakathi kwezizwe, 
\q2 zabelana ilizwe lami. 
\q1  
\v 3 Zenza inkatho ngabantu bami, 
\q2 zathenga izifebe ngabafana; 
\q2 zathengisa amankazana ngewayini ukuze zinathe. 
\p  
\v 4 Manje-ke lisolani ngami, wena Thire loSidoni lani lonke zifunda zaseFilistiya? Liyangiphindisela ngolutho engilwenzileyo na? Nxa lingiphindisela, ngizaphanga ngibuyisele elakwenzayo phezu kwamakhanda enu ngokuphangisa.  
\v 5 Ngoba lathatha isiliva sami legolide lami lathwalela lenotho yami eligugu emathempelini enu.  
\v 6 Lathengisa abantu bakoJuda laseJerusalema kumaGrikhi, ukuze libase khatshana lelizwe labo. 
\p  
\v 7 Khangelani, ngizabavusa ezindaweni elabathengisa kuzo, njalo ngizabuyisela phezu kwamakhanda enu lokho elakwenzayo.  
\v 8 Ngizathengisa amadodana enu lamadodakazi enu ebantwini bakoJuda, njalo labo bazawathengisa kumaSabhini, isizwe esikhatshana.” \nd UThixo\nd* usekhulumile. 
\q1  
\v 9 Memezelani lokhu ezizweni lithi: 
\q2 Lungiselani impi! 
\q1 Vusani amabutho! 
\q2 Wonke amadoda empi kasondele ahlasele. 
\q1  
\v 10 Khandani amakhuba enu abe zinkemba 
\q2 lemihedla yenu yokuthena izihlahla ibe yimikhonto. 
\q1 Obuthakathaka kathi, 
\q2 “Ngiqinile!” 
\q1  
\v 11 Wozani ngokuphangisa, lonke lina zizwe zasezinhlangothini zonke, 
\q2 libuthane khonapho. 
\b  
\q1 Yehlisa amabutho akho, Oh \nd Thixo!\nd* 
\b  
\q1  
\v 12 “Izizwe kazivuswe; 
\q2 kaziye eSigodini sikaJehoshafathi 
\q1 ngoba ngizahlala khona 
\q2 ukwehlulela izizwe zonke zasezinhlangothini zonke. 
\q1  
\v 13 Hehethani ngesikela 
\q2 ngoba okuvunwayo sekuvuthiwe. 
\q1 Wozani, gxobani amavini, 
\q2 ngoba isikhamelo sewayini sesigcwele 
\q2 lezimbizakazi seziphuphuma, 
\q1 bukhulu kangaka ububi bazo! 
\b  
\q1  
\v 14 Amaxuku, amaxuku 
\q2 esigodini sesinqumo! 
\q1 Ngoba usuku \nd lukaThixo\nd* luseduze 
\q2 esigodini sezinqumo. 
\q1  
\v 15 Ilanga lenyanga kuzakuba mnyama, 
\q2 lezinkanyezi zingabe zisakhanya. 
\q1  
\v 16 \nd UThixo\nd* uzavungama eseZiyoni 
\q2 aphinde akhwaze eseJerusalema; 
\q2 umhlaba lomkhathi kuzagedezela. 
\q1 Kodwa \nd uThixo\nd* uzakuba yisiphephelo sabantu bakhe, 
\q2 inqaba yabantu bako-Israyeli.” 
\s1 Izibusiso Zabantu BakaNkulunkulu 
\q1  
\v 17 “Ngakho lizakwazi ukuthi mina, \nd uThixo\nd* uNkulunkulu wenu, 
\q2 ngihlala eZiyoni, intaba yami engcwele. 
\q1 IJerusalema izakuba ngcwele; 
\q2 kayiyikuphinda ihlaselwe ngabezizweni futhi. 
\b  
\q1  
\v 18 Ngalolosuku izintaba zizagobhoza iwayini elitsha, 
\q2 lamaqaqa ageleze uchago; 
\q2 zonke indonga zakoJuda zizageleza amanzi. 
\q1 Umthombo uzantuntuza endlini \nd kaThixo\nd* 
\q2 uthambise isigodi saseShithima. 
\q1  
\v 19 Kodwa iGibhithe izachithakala, 
\q2 i-Edomi ibe yinkangala elugwadule, 
\q1 ngenxa yodlakela olwenziwa ebantwini bakoJuda 
\q2 lapho bachitha khona igazi elingelacala elizweni labo. 
\q1  
\v 20 KoJuda kuzahlalwa khona kuze kube nininini 
\q2 laseJerusalema kuzahlala izizukulwane zonke. 
\q1  
\v 21 Umlandu wabo wegazi, engingakaxoli ngawo, 
\q2 ngizabaxolela ngawo.” 
\b  
\qc \nd UThixo\nd* uhlala eZiyoni!