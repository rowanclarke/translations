\id NAM Azeri-N: Azerbaijani Bible 2008 
\h NAHUM 
\toc1 Nahum Peyğəmbərin Kitabi 
\toc2 Nahum 
\toc3 Nah 
\mt1 NAHUM  
\mt2 PEYĞƏMBƏRİN KİTABI  
\imt1 GİRİŞ  
\ip \bk «Nahum»\bk* Kitabı İsraillilərin qüdrətli düşməni olan Aşşurun paytaxtı Ninevanın süqutunu əvvəlcədən bildirən kitabdır. Miladdan əvvəl 614-cü ildə baş vermiş Ninevanın süqutu qəddar və təkəbbürlü millətin üzərində Allahın məhkəməsi kimi qiymətləndirilir.  
\iot Kitabın məzmunu:  
\io2 1:1-15 Rəbbin Ninevadan aldığı qisas  
\io2 2:1–3:19 Ninevanın dağılması  
\c 1  
\p
\v 1 \x * \xo 1:1 \xt Yeş. 10:5-34; 14:24-27; Sef. 2:13-15 \x* Bu, Nineva haqqındakı xəbərdarlıq, Elqoşlu Nahumun görüntülərindən ibarət kitabdır.   
\s1 Rəbbin Ninevadan aldığı qisas  
\q1
\v 2 Rəbb qısqancdır, qisas alan Allahdır,  
\q1 İntiqam alır, qəzəblə doludur,  
\q1 Düşmənlərindən qisas alır,  
\q1 Yağılarına qarşı qəzəblidir.   
\q1
\v 3 Rəbb hədsiz səbirlidir, qüdrətlidir,  
\q1 Təqsirkarı əsla cəzasız qoymaz,  
\q1 Onun yolu qasırğadadır, fırtınadadır,  
\q1 Buludlar ayaqlarının tozudur,   
\q1
\v 4 Dənizə əmr edib onu qurudar,  
\q1 Bütün çayların sularını da qurudar,  
\q1 Başan və Karmel meşələri saralır,  
\q1 Livanın gül-çiçəyi solur.   
\q1
\v 5 Rəbbin hüzurundan dağlar titrəyir,  
\q1 Təpələr əriyir,  
\q1 Yer üzü Rəbbin önündə sarsılır,  
\q1 Dünya və onun sakinləri lərzəyə gəlir.   
\q1
\v 6 Onun qəzəbinə qarşı kim dura bilər?  
\q1 Qızğın hiddətinə kim tab gətirər?  
\q1 Rəbbin qeyzi od kimi tökülər,  
\q1 Qarşısında qayalar dağılar.   
\q1
\v 7 Rəbb xeyirxahdır, dar gündə sığınacaqdır,  
\q1 Ona güvənənləri tanıyır.   
\q1
\v 8 Lakin O, Ninevanın olduğu yeri  
\q1 Azğın sellərlə məhv edəcək.  
\q1 Düşmənlərini zülmətə salacaq.   
\b  
\q1
\v 9 Rəbbə qarşı nə qəsd etsələr,  
\q1 O hər şeyə son qoyacaq,  
\q1 Onlardan bir daha bəla çıxmaz.   
\q1
\v 10 Tikanlar kimi bir-birinə dolaşmışlar,  
\q1 Əyyaşlar kimi sərxoş olmuşlar,  
\q1 Quru küləş tək tamamilə yanacaqlar.   
\q1
\v 11 Ey Nineva, Rəbbə qarşı pislik düşünən  
\q1 Şər məsləhətçini sən yetirdin!   
\q1
\v 12 Rəbb belə deyir:  
\q1 «Aşşurlular çox və güclü olsa da,  
\q1 Yenə məhv olub gedəcək.  
\q1 Ey xalqım İsrail, sənə çox əzab vermişəm,  
\q1 Səni bir daha incitmərəm.   
\q1
\v 13 İndi boyunduruğunu parçalayıb,  
\q1 Qandallarını qıracağam».   
\b  
\q1
\v 14 Ey Nineva, Rəbb sənin haqqında  
\q1 Belə əmr verib:  
\q1 «Artıq övladların olmayacaq, adını daşımayacaq,  
\q1 Allahlarının məbədindən  
\q1 Oyma bütləri, tökmə bütləri məhv edəcəyəm.  
\q1 Qəbir qazacağam sənə, çünki alçaqsan!   
\q1
\v 15 \x * \xo 1:15 \xt Yeş. 52:7 \x* Budur, müjdə gətirənin  
\q1 Ayaqları dağlar aşır, gəlir,  
\q1 Sülh xəbəri gətirir.  
\q1 Ey Yəhuda, bayramlarını keçir,  
\q1 Əhdlərini yerinə yetir!  
\q1 O pis millətin ayağı ölkəndən artıq keçməyəcək,  
\q1 Çünki tamamilə məhv oldu».   
\c 2  
\s1 Ninevanın dağılması  
\q1
\v 1 Ey Nineva, həlak edən qüvvə qarşına çıxdı,  
\q1 İstehkamını qoru, yolunu qoru,  
\q1 Belini möhkəm qurşa,  
\q1 Bütün gücünü topla!   
\b  
\q1
\v 2 Rəbb Yaqub nəslini  
\q1 İsrailin əvvəlki əzəmətinə qaytaracaq.  
\q1 Hərçənd quldurlar onu viran etdi,  
\q1 Tənəklərini dağıtdı.   
\b  
\q1
\v 3 İgidlərin qalxanları qıpqırmızıdır,  
\q1 Cəngavərlərin libasları al rəngdədir.  
\q1 Onlar hazır olan gün  
\q1 Döyüş arabalarının dəmirləri necə də parıldayır,  
\q1 Şam ağacından nizələr havada oynayır!   
\q1
\v 4 Döyüş arabaları küçələrdən dəlicəsinə qaçır,  
\q1 Meydanlarda ora-bura yüyürür,  
\q1 Məşəllər kimi parıldayır,  
\q1 Şimşək kimi cəld qaçır.   
\q1
\v 5 Nineva padşahı seçmə əsgərlərini toplayır,  
\q1 Amma onlar yolda büdrəyir.  
\q1 Düşmən orduları şəhər divarına tərəf qaçır,  
\q1 Qalxanlarını qaldırıb sipər qurur.   
\q1
\v 6 Çayların suyunu saxlayan bəndlər açıldı,  
\q1 Sarayı dəhşət bürüdü.   
\q1
\v 7 Mələkəni lüt-üryan aparırlar,  
\q1 Kənizləri qumru kimi inləyib  
\q1 Sinələrinə vurur.   
\q1
\v 8 Qədimdən bəri Nineva  
\q1 Sulu hovuz kimi idi,  
\q1 İndi isə sular axıb gedir,  
\q1 Onlara «Dayanın, dayanın!» deyirlər,  
\q1 Amma geri dönən yoxdur.   
\q1
\v 9 Gümüşü talan edin, qızılı oğurlayın,  
\q1 Sərvətlərin sonu yoxdur,  
\q1 Bol miqdarda qiymətli əşyalar var.   
\b  
\q1
\v 10  \x * \xo 2:10 \xt Yoel 2:6 \x* Nineva viran oldu, dağıldı, xaraba qaldı!  
\q1 Sakinlərinin ürəyi əsir, dizləri taqətdən düşür.  
\q1 Hamının bədənləri titrəyir, üzləri solur!   
\q1
\v 11 Nə oldu aslanlar yuvasına?  
\q1 Gənc aslanların bəsləndiyi,  
\q1 Şirlə dişisinin və balalarının qorxusuz gəzdiyi yerə nə oldu?   
\q1
\v 12 Aslan öz balalarına kifayət qədər şikar ovladı,  
\q1 Dişisi üçün ovunu boğazladı,  
\q1 Mağarasını ovladığı heyvanlarla,  
\q1 Yuvasını şikarla doldurdu.   
\b  
\q1
\v 13 Ordular Rəbbi bəyan edir:  
\q1 «Mən sizin əleyhinizəyəm,  
\q1 Döyüş arabalarınızı tüstüdə yandıracağam,  
\q1 Gənc aslanlarını qılınc yeyəcək,  
\q1 Yer üzündən şikarını kəsəcəyəm,  
\q1 Qasidlərinin səsi daha eşidilməyəcək».   
\b  
\c 3  
\q1
\v 1 Qanlı şəhərin vay halına!  
\q1 O yalan və soyğunçuluqla doludur,  
\q1 Orada quldurluğun ardı kəsilmir!   
\q1
\v 2 Qamçı səsi, təkərlər gurultusu,  
\q1 Çapan atların, yırğalanan döyüş arabalarının sədası!   
\q1
\v 3 Süvarilər hücum edir, qılınclar parıldayır,  
\q1 Nizələr bərq vurur, ölənlər yığın-yığın,  
\q1 Cəsədlərin sayı yox,  
\q1 İnsanların ayağı meyitlərə dolaşır!   
\q1
\v 4 Millətləri fahişəliyi ilə,  
\q1 Xalqları cadugərliyi ilə satan, cazibəli,  
\q1 Cadugərlikdə mahir fahişə – Ninevanın  
\q1 Hədsiz əxlaqsızlığına görə  
\q1 Bunlar baş verdi.   
\b  
\q1
\v 5 Ordular Rəbbi bəyan edir:  
\q1 «Ey Nineva, Mən sənin əleyhinəyəm!  
\q1 Paltarının ətəyini üzünə qaldıracağam,  
\q1 Çılpaqlığını millətlərə göstərəcəyəm,  
\q1 Ayıbını ölkələrə açacağam.   
\q1
\v 6 Üstünə iyrənc şeyləri atacağam,  
\q1 Səni rüsvay edəcəyəm,  
\q1 Tamaşaya qoyacağam!   
\q1
\v 7 Səni görənlərin hamısı səndən qaçıb  
\q1 Belə deyəcək:  
\q1 “Nineva viran qaldı!  
\q1 Onun üçün kim ağlayacaq?”  
\q1 Haradan sənə təsəlli verənləri tapım?»   
\b  
\q1
\v 8 Axı sənin No-Ammondan \f + \fr 3:8 \fq No-Ammon \ft – qədim Misirin paytaxt şəhərlərindən biri.\f* nəyin artıqdır?  
\q1 O şəhər çaylar arasında yerləşib  
\q1 Sularla əhatə olunmuşdu,  
\q1 Sipəri dəniz,  
\q1 Qala divarı isə Nil çayı idi.   
\q1
\v 9 Kuş və Misir onun sonsuz qüvvəti idi,  
\q1 Put və Liviya da köməkçiləri idi.   
\b  
\q1
\v 10 Lakin əsir aparıldı, sürgün oldu,  
\q1 Övladları parça-parça doğrandı,  
\q1 Hər küçə başına atıldı,  
\q1 Adlı-sanlı adamları üçün püşk atdılar,  
\q1 Əyanlarını qandallara saldılar.   
\q1
\v 11 Sən də, ey Nineva, sərxoş olacaqsan,  
\q1 Mat-məəttəl qalacaqsan,  
\q1 Düşmənlərin əlindən pənahgah axtaracaqsan.   
\b  
\q1
\v 12 Bütün istehkamların  
\q1 Əncir ağacının ilk yetişən meyvələri kimidir,  
\q1 Silkələnəndə yeyənin ağzına düşür.   
\q1
\v 13 Budur, əsgərlərin qadın kimidir,  
\q1 Ölkənin darvazaları düşmənlərin üzünə taybatay açılıb.  
\q1 Qapı rəzələrini od yeyib.   
\b  
\q1
\v 14 Mühasirə vaxtı üçün özünə su çək,  
\q1 Qalalarını möhkəmləndir,  
\q1 Çamıra gir, palçığı tapda,  
\q1 Kərpic kəsmək üçün qəlib götür!   
\q1
\v 15 Orada od səni yeyib-qurtaracaq,  
\q1 Qılınc səni kəsib-qıracaq,  
\q1 Çəyirtkələrin yedikləri əkin kimi yox olacaqsan.  
\q1 Sayını çəyirtkə kimi artır,  
\q1 Özünü qaynaşan çəyirtkə kimi çoxalt!   
\q1
\v 16 Tacirlərinin sayı  
\q1 Göylərdəki ulduzlardan çoxdur,  
\q1 Amma düşmənlərin  
\q1 Çəyirtkə kimi ölkəni talan edib uçacaq.   
\q1
\v 17 Gözətçilərin çəyirtkə kimi,  
\q1 Məmurların çəyirtkə sürüsü kimidir –  
\q1 Soyuq gündə çəpərlərə yerləşir,  
\q1 Gün doğanda uçub gedir,  
\q1 Getdikləri yer bilinmir.   
\b  
\q1
\v 18 Ey Aşşur padşahı,  
\q1 Əyanların ölüm yuxusuna gedib,  
\q1 Adlı-sanlı adamların yatıb.  
\q1 Xalqın dağlara səpələnib,  
\q1 Onları bir yerə yığan yoxdur.   
\q1
\v 19 Dərdinə dərman yoxdur, yaraların sağalmaz.  
\q1 Barəndə xəbər eşidənlər sevinib əl çalır.  
\q1 Axı sənin bu sonsuz pisliyin kimə dəyməyib?   