\p
\v 15 \w While|strong="H1961"\w* Abraham’s worker \w was|strong="H1961"\w* still \w praying|strong="H1696"\w*, \w a|strong="H3068"\w* \w young|strong="H1121"\w* \w woman|strong="H3205"\w* walked \w out|strong="H3318"\w* \w of|strong="H1121"\w* \w the|strong="H5921"\w* town \w with|strong="H1696"\w* \w a|strong="H3068"\w* \w jar|strong="H3537"\w* \w on|strong="H5921"\w* \w her|strong="H5921"\w* \w shoulder|strong="H7926"\w*. \w That|strong="H1931"\w* \w woman|strong="H3205"\w*’s name \w was|strong="H1961"\w* \w Rebekah|strong="H7259"\w*, \w and|strong="H1121"\w* \w her|strong="H5921"\w* \w father|strong="H3205"\w*’s name \w was|strong="H1961"\w* \w Bethuel|strong="H1328"\w*. \w Bethuel|strong="H1328"\w*’s mother \w was|strong="H1961"\w* \w Milcah|strong="H4435"\w*, \w and|strong="H1121"\w* \w Bethuel|strong="H1328"\w*’s \w father|strong="H3205"\w* \w was|strong="H1961"\w* \w Nahor|strong="H5152"\w*. \w And|strong="H1121"\w* \w Nahor|strong="H5152"\w* \w was|strong="H1961"\w* Abraham’s brother.   
\p
\v 16 Rebekah \w was|strong="H3966"\w* \w a|strong="H3068"\w* \w very|strong="H3966"\w* \w beautiful|strong="H2896"\w* \w young|strong="H5291"\w* \w woman|strong="H5291"\w*, \w and|strong="H5869"\w* \w she|strong="H2896"\w* wasn’t married. \w She|strong="H2896"\w* \w never|strong="H3808"\w* slept \w with|strong="H4390"\w* \w a|strong="H3068"\w* \w man|strong="H2896"\w*, \w like|strong="H4758"\w* \w a|strong="H3068"\w* \w woman|strong="H5291"\w* sleeps \w with|strong="H4390"\w* \w her|strong="H4390"\w* husband.  
\p Rebekah \w got|strong="H5927"\w* \w to|strong="H3381"\w* \w the|strong="H3045"\w* water-hole, \w and|strong="H5869"\w* \w she|strong="H2896"\w* \w went|strong="H5927"\w* \w down|strong="H3381"\w* \w to|strong="H3381"\w* \w the|strong="H3045"\w* \w water|strong="H4390"\w* \w and|strong="H5869"\w* \w filled|strong="H4390"\w* \w up|strong="H5927"\w* \w her|strong="H4390"\w* \w jar|strong="H3537"\w*, \w and|strong="H5869"\w* \w then|strong="H5927"\w* \w she|strong="H2896"\w* \w came|strong="H5927"\w* \w back|strong="H5927"\w* \w up|strong="H5927"\w*.   
\p
\v 17 \w Then|strong="H5650"\w* Abraham’s worker \w ran|strong="H7323"\w* \w to|strong="H4325"\w* \w meet|strong="H7125"\w* Rebekah. \w He|strong="H4325"\w* said \w to|strong="H4325"\w* \w her|strong="H7323"\w*, “\w Please|strong="H4994"\w* \w let|strong="H4994"\w* \w me|strong="H4994"\w* \w drink|strong="H1572"\w* \w a|strong="H3068"\w* \w little|strong="H4592"\w* bit \w of|strong="H5650"\w* \w water|strong="H4325"\w* \w from|strong="H5650"\w* \w your|strong="H4994"\w* \w jar|strong="H3537"\w*.”   
\p
\v 18 Rebekah said, “Yes, please \w have|strong="H3027"\w* \w a|strong="H3068"\w* \w drink|strong="H8354"\w*, sir.” Straight away, \w she|strong="H5921"\w* \w took|strong="H3381"\w* \w the|strong="H5921"\w* \w jar|strong="H3537"\w* \w off|strong="H5921"\w* \w her|strong="H5921"\w* shoulder. \w Then|strong="H3381"\w* \w she|strong="H5921"\w* held \w the|strong="H5921"\w* \w jar|strong="H3537"\w* \w in|strong="H5921"\w* \w her|strong="H5921"\w* \w hands|strong="H3027"\w* \w and|strong="H3027"\w* \w gave|strong="H8248"\w* Abraham’s worker \w a|strong="H3068"\w* \w drink|strong="H8354"\w*.   
\p
\v 19 \w After|strong="H5704"\w* Rebekah \w finished|strong="H3615"\w* \w giving|strong="H8248"\w* \w him|strong="H8248"\w* \w a|strong="H3068"\w* \w drink|strong="H8354"\w*, \w she|strong="H8248"\w* said, “\w Now|strong="H1571"\w* \w I|strong="H5704"\w* \w will|strong="H1571"\w* get \w water|strong="H8248"\w* \w for|strong="H5704"\w* \w your|strong="H5704"\w* \w camels|strong="H1581"\w* \w too|strong="H1571"\w*, \w until|strong="H5704"\w* \w they|strong="H5704"\w* \w have|strong="H1571"\w* \w enough|strong="H1571"\w* \w to|strong="H5704"\w* \w drink|strong="H8354"\w*.”  
