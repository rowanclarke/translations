\v 17 ¿\w Por|strong="H1870"\w* \w qué|strong="H4100"\w*, \w oh|strong="H4100"\w* \w SEÑOR|strong="H3068"\w*, \w nos|strong="H4100"\w* has hecho \w errar|strong="H8582"\w* de tus \w caminos|strong="H1870"\w*, y endureciste nuestro \w corazón|strong="H3820"\w* \w a|strong="H3068"\w* tu \w temor|strong="H3374"\w*? \w Vuélvete|strong="H7725"\w* \w por|strong="H1870"\w* amor de tus \w siervos|strong="H5650"\w*, \w por|strong="H1870"\w* las \w tribus|strong="H7626"\w* de tu \w heredad|strong="H5159"\w*.   
\m
\v 18 Por poco \w tiempo|strong="H4705"\w* \add lo\add* \w poseyó|strong="H3423"\w* el \w pueblo|strong="H5971"\w* \w de|strong="H5971"\w* tu \w santidad|strong="H6944"\w*: nuestros \w enemigos|strong="H6862"\w* han hollado tu santua­rio.   
\m
\v 19 Hemos venido \w a|strong="H3068"\w* ser \w como|strong="H1961"\w* aquellos \w de|strong="H5921"\w* quienes \w nunca|strong="H3808"\w* \w te|strong="H5921"\w* enseñoreaste, \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* cuales \w nunca|strong="H3808"\w* \w fue|strong="H1961"\w* \w llamado|strong="H8034"\w* tu \w nombre|strong="H8034"\w*.   
\c 64
\m
\v 1 ¡OH \w si|strong="H6440"\w* rompieses los cielos, \add y\add* descendieras, \add y\add* \w a|strong="H3068"\w* tu pre­sencia \w se|strong="H3045"\w* escurriesen los montes,   
\m
\v 2 Como fuego abrasador \w de|strong="H6440"\w* fun­diciones, fuego \w que|strong="H3808"\w* \w hace|strong="H6213"\w* hervir las aguas, para \w que|strong="H3808"\w* hicieras noto­rio \w tu|strong="H6213"\w* nombre \w a|strong="H3068"\w* tus enemigos, y las naciones temblasen \w a|strong="H3068"\w* \w tu|strong="H6213"\w* presen­cia!   
\m
\v 3 Cuando, \w haciendo|strong="H6213"\w* terriblezas cuales \w nunca|strong="H3808"\w* esperábamos, des­cendiste, fluyeron los montes \w delante|strong="H5869"\w* \w de|strong="H2108"\w* ti.   
\m
\v 4 Ni \w nunca|strong="H5769"\w* oyeron, ni oídos per­cibieron, ni ojo ha visto, oh Dios, fuera de ti, que \w hiciese|strong="H6213"\w* \w por|strong="H1870"\w* \w el|strong="H6213"\w* que en \w él|strong="H6213"\w* espera.   
\m
\v 5 Saliste al encuentro al \w que|strong="H1961"\w* con alegría obraba \w justicia|strong="H6666"\w*, \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w que|strong="H1961"\w* \w se|strong="H1961"\w* acordaban de ti en tus cami­nos\add :\add* he aquí, tú te enojaste por­\w que|strong="H1961"\w* pecamos; en esos \add tus cami­nos\add* \w hay|strong="H1961"\w* perpetuidad, y \w seremos|strong="H1961"\w* salvos.   
\m
\v 6 \w Si|strong="H3588"\w* \w bien|strong="H3588"\w* todos nosotros somos \w como|strong="H3588"\w* suciedad, \w y|strong="H3588"\w* todas nuestras justicias \w como|strong="H3588"\w* trapo \w de|strong="H4480"\w* inmundicia; \w y|strong="H3588"\w* caímos todos nosotros \w como|strong="H3588"\w* \w la|strong="H3588"\w* hoja, \w y|strong="H3588"\w* nuestras malda­des \w nos|strong="H4480"\w* llevaron \w como|strong="H3588"\w* viento.   
\m
\v 7 \w Y|strong="H3068"\w* \w nadie|strong="H3605"\w* hay \w que|strong="H6258"\w* invoque tu nombre, \w que|strong="H6258"\w* se despierte \w para|strong="H6258"\w* tenerte; \w por|strong="H3027"\w* \w lo|strong="H3605"\w* cual escondiste de \w nosotros|strong="H3605"\w* tu rostro, y nos dejaste marchitar en \w poder|strong="H3027"\w* de nuestras maldades.   
\m
\v 8 \w Ahora|strong="H4994"\w* \w pues|strong="H4994"\w*, oh \w SEÑOR|strong="H3068"\w*, tú \add eres\add* nuestro padre; \w nosotros|strong="H3605"\w* lodo, \w y|strong="H5704"\w* tú \w el|strong="H3605"\w* \w que|strong="H4994"\w* nos formaste; así \w que|strong="H4994"\w* obra \w de|strong="H5704"\w* tus manos, \w todos|strong="H3605"\w* \w nosotros|strong="H3605"\w*.   
\m
\v 9 \w No|strong="H1961"\w* te aires, oh SEÑOR, \w sobre|strong="H1961"\w*­manera, ni tengas perpetua memoria de la iniquidad: he aquí mira ahora, pueblo tuyo \add somos\add* todos nosotros.   
\m
\v 10 Tus \w santas|strong="H6944"\w* ciudades \w están|strong="H1961"\w* de­siertas, Sión \w es|strong="H1961"\w* un desierto, Jerusalem una soledad.   
\m
\v 11 \w La|strong="H5921"\w* casa \w de|strong="H5921"\w* nuestro santuario \w y|strong="H5921"\w* \w de|strong="H5921"\w* nuestra gloria, \w en|strong="H5921"\w* \w la|strong="H5921"\w* cual \w te|strong="H5921"\w* alabaron nuestros padres, fue consumida \w al|strong="H5921"\w* fuego; \w y|strong="H5921"\w* todas nuestras cosas preciosas han sido destruídas.   
\m
\v 12 ¿Te estarás quieto, oh SEÑOR, sobre estas cosas? ¿callarás, y nos afligirás sobre­manera?   
\c 65
\m
\v 1 \w FUI|strong="H3808"\w* buscado de \add los que\add* \w no|strong="H3808"\w* \w preguntaban|strong="H7592"\w* \add por mí\add*; \w fui|strong="H3808"\w* \w hallado|strong="H4672"\w* de \add los que\add* \w no|strong="H3808"\w* me buscaban. Dije \w a|strong="H3068"\w* \w una|strong="H4672"\w* \w nación|strong="H1471"\w* \add que\add* \w no|strong="H3808"\w* \w invocaba|strong="H7121"\w* \w mi|strong="H1245"\w* \w nombre|strong="H8034"\w*: Heme \w aquí|strong="H2005"\w*, heme \w aquí|strong="H2005"\w*.   
\m
\v 2 \w Extendí|strong="H6566"\w* mis \w manos|strong="H3027"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w día|strong="H3117"\w* \w a|strong="H3068"\w* \w pueblo|strong="H5971"\w* \w rebelde|strong="H5637"\w*, \w el|strong="H3605"\w* cual \w anda|strong="H1980"\w* \w por|strong="H1870"\w* \w camino|strong="H1870"\w* \w no|strong="H3808"\w* \w bueno|strong="H2896"\w*, en pos \w de|strong="H5971"\w* sus \w pensamientos|strong="H4284"\w*;   
\m
\v 3 \w Pueblo|strong="H5971"\w* \w que|strong="H5921"\w* \w en|strong="H5921"\w* \w mi|strong="H5921"\w* \w cara|strong="H6440"\w* \w me|strong="H5921"\w* pro­voca \w de|strong="H5921"\w* \w continuo|strong="H8548"\w* \w a|strong="H3068"\w* ira, sacrifi­cando \w en|strong="H5921"\w* \w huertos|strong="H1593"\w*, \w y|strong="H5921"\w* \w ofreciendo|strong="H2076"\w* \w perfume|strong="H6999"\w* \w sobre|strong="H5921"\w* \w ladrillos|strong="H3843"\w*;   
\m
\v 4 Que se quedan en \w los|strong="H3427"\w* sepul­cros, y en \w los|strong="H3427"\w* desiertos tienen la noche; que comen \w carne|strong="H1320"\w* de puer­co, y en sus ollas hay caldo de cosas inmundas;   
\m
\v 5 \w Que|strong="H3588"\w* dicen: Estáte \w en|strong="H3588"\w* tu lugar, \w no|strong="H3588"\w* \w te|strong="H3588"\w* llegues \w a|strong="H3068"\w* mí, \w que|strong="H3588"\w* soy \w más|strong="H3588"\w* \w santo|strong="H6942"\w* \w que|strong="H3588"\w* tú: \w éstos|strong="H3605"\w* \w son|strong="H3588"\w* \w humo|strong="H6227"\w* \w en|strong="H3588"\w* mi furor, fuego \w que|strong="H3588"\w* arde \w todo|strong="H3605"\w* \w el|strong="H3588"\w* \w día|strong="H3117"\w*.   
\m
\v 6 He \w aquí|strong="H2009"\w* \w que|strong="H3588"\w* \w escrito|strong="H3789"\w* \w está|strong="H5921"\w* delan­\w te|strong="H5921"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w*; \w no|strong="H3808"\w* \w callaré|strong="H2814"\w*, \w antes|strong="H6440"\w* retor­naré, \w y|strong="H3588"\w* daré \w el|strong="H5921"\w* pago \w en|strong="H5921"\w* \w su|strong="H3588"\w* \w seno|strong="H2436"\w*,   
\m
\v 7 \add Por\add* vuestras \w iniquidades|strong="H5771"\w*, \w y|strong="H5921"\w* \w las|strong="H5921"\w* \w iniquidades|strong="H5771"\w* \w de|strong="H5921"\w* vuestros padres \w juntamente|strong="H3162"\w*, dice \w el|strong="H5921"\w* \w SEÑOR|strong="H3068"\w*, \w los|strong="H5921"\w* cuales hicieron \w perfume|strong="H6999"\w* \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* \w montes|strong="H2022"\w*, \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* \w collados|strong="H1389"\w* \w me|strong="H5921"\w* \w afrentaron|strong="H2778"\w*: \w por|strong="H5921"\w* \w tanto|strong="H5921"\w* yo \w les|strong="H5921"\w* mediré su \w obra|strong="H6468"\w* \w antigua|strong="H7223"\w* \w en|strong="H5921"\w* su \w seno|strong="H2436"\w*.   
\m
\v 8 \w Así|strong="H3541"\w* dice \w el|strong="H3588"\w* \w SEÑOR|strong="H3068"\w*: \w Como|strong="H3588"\w* \add si alguno\add* \w hallase|strong="H4672"\w* \w mosto|strong="H8492"\w* \w en|strong="H3588"\w* un raci­mo, \w y|strong="H3588"\w* dijese: \w No|strong="H6213"\w* \w lo|strong="H6213"\w* desperdicies, \w que|strong="H3588"\w* \w bendición|strong="H1293"\w* hay \w en|strong="H3588"\w* \w él|strong="H3588"\w*; \w así|strong="H3541"\w* \w haré|strong="H6213"\w* \w yo|strong="H3588"\w* \w por|strong="H3588"\w* mis \w siervos|strong="H5650"\w*, \w que|strong="H3588"\w* \w no|strong="H6213"\w* \w lo|strong="H6213"\w* des­truiré \w todo|strong="H3605"\w*.   
\m
\v 9 Mas sacaré \w simiente|strong="H2233"\w* de \w Jacob|strong="H3290"\w*, y de \w Judá|strong="H3063"\w* \w heredero|strong="H3423"\w* de mis mon­tes; y mis escogidos \w poseerán|strong="H3423"\w* por \w heredad|strong="H3423"\w* la tierra, y mis sier­vos \w habitarán|strong="H7931"\w* \w allí|strong="H8033"\w*.   
