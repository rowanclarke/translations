\id HAB - Biblica® Open Kikuyu Holy Word of God
\h Habakuku
\toc1 Habakuku
\toc2 Habakuku
\toc3 Hab
\mt1 HABAKUKU
\c 1
\p 
\v 1 Ĩno nĩyo ndũmĩrĩri nditũ ĩrĩa yakinyĩrĩire mũnabii Habakuku.
\s1 Gũteta kwa Habakuku
\q1 
\v 2 Wee Jehova-rĩ, nĩ nginya rĩ ngũtũũra ngũkayagĩra ũndeithie,
\q2 no wee ũkaaga kũnjigua?
\q1 Githĩ ndigũkayagĩra ngiugaga, “Haaro! Haaro!”
\q2 no wee ũkaaga kũhonokania?
\q1 
\v 3 Ũtũmaga ndĩrorere wagi wa kĩhooto nĩkĩ?
\q2 Ũkiragĩrĩria maũndũ mooru nĩkĩ?
\q1 Mwanangĩko na haaro irĩ mbere yakwa;
\q2 kũrĩ na njũgitano, nayo mbaara nĩ nyingĩ.
\q1 
\v 4 Nĩ ũndũ ũcio, watho nĩmwagithie hinya,
\q2 na kĩhooto gĩtihootanaga.
\q1 Andũ arĩa aaganu marigiicaga arĩa athingu,
\q2 na nĩ ũndũ ũcio kĩhooto gĩkoogomio.
\s1 Icookia rĩa Jehova
\q1 
\v 5 “Atĩrĩrĩ, ta rorai ndũrĩrĩ na mwĩrorere ũhoro wacio,
\q2 na mũmake biũ.
\q1 Nĩgũkorwo matukũ-inĩ maku nĩngwĩka ũndũ
\q2 ũrĩa ũtangĩĩtĩkia o na ũngĩĩrwo.
\q1 
\v 6 Nĩngwarahũra andũ a Babuloni,
\q2 andũ a haaro, na matarĩ tha,
\q1 arĩa matuĩkanagia thĩ yothe,
\q2 na makegwatĩra ciikaro itarĩ ciao.
\q1 
\v 7 Nĩ andũ a kũmakania, na a gwĩtigĩrwo;
\q2 nĩo meyathaga, na magetũũgĩria.
\q1 
\v 8 Mbarathi ciao irĩ ihenya gũkĩra ngarĩ,
\q2 na nĩ ooru mũno gũkĩra njũũi iria icangacangaga kĩhwaĩ-inĩ.
\q1 Thigari ciao iria ithiiaga ihaicĩte mbarathi itengʼeraga ta ciũmbũkĩte;
\q2 ahaici acio a mbarathi moimaga kũndũ kũraya.
\q1 Mombũkaga ta nderi ĩgĩcuuhũkĩra gĩa kũrĩa;
\q2 
\v 9 othe mokaga mehaarĩirie kũruta haaro.
\q1 Thigari icio ciao nyingĩ mũno ithiiaga ihaatĩte ta rũhuho rwa werũ-inĩ,
\q2 igathiĩ itahĩte andũ aingĩ mũno ta mũthanga.
\q1 
\v 10 Manyararaga athamaki,
\q2 na makanyũrũria andũ arĩa maathanaga.
\q1 Mathekagĩrĩra matũũra mothe manene marĩa mairigĩre;
\q2 maakaga ihumbu cia tĩĩri, magatunyana matũũra macio.
\q1 
\v 11 Ningĩ mahĩtũkagĩra kuo na ihenya o ta rũhuho mathiĩte na mbere:
\q2 andũ maagararaga watho, magatuĩka ehia,
\q2 magatua atĩ hinya wao nĩguo ngai yao.”
\s1 Gũteta gwa Keerĩ kwa Habakuku
\q1 
\v 12 Wee Jehova-rĩ, githĩ ndũtũũraga kuuma tene o na tene?
\q2 O Wee Ngai wakwa, ũrĩa wakwa mũtheru, tondũ ũcio tũtigakua.
\q1 Wee Jehova-rĩ, nĩwe ũthuurĩte andũ a Babuloni mahingie ituĩro rĩaku;
\q2 wee Rwaro rwa Ihiga-rĩ, ũkamaamũra matũherithie.
\q1 
\v 13 Maitho maku nĩ matheru mũno, matingĩĩrorera ũmaramari;
\q2 wee-rĩ, ndũngĩkirĩrĩria maũndũ mooru.
\q1 Ũgĩkiragĩrĩria andũ arĩa oingumania nĩkĩ?
\q2 Ũkiraga nĩkĩ rĩrĩa andũ arĩa aaganu
\q2 mekũmeria andũ arĩa athingu kũmakĩra?
\q1 
\v 14 Ũtuĩte andũ ta thamaki cia iria,
\q2 ũkamatua ta ciũmbe cia iria-inĩ, iria itarĩ mũciathi.
\q1 
\v 15 Thũ ĩyo njaganu ĩmaguucagia othe na ndwano,
\q2 ĩkamagwatia na wabu wayo,
\q1 ĩkamacookereria thĩinĩ wa mũtego wayo;
\q2 nĩ ũndũ ũcio ĩgakena na ĩgacanjamũka.
\q1 
\v 16 Nĩ ũndũ ũcio, ĩrutagĩra wabu wayo igongona,
\q2 na ĩgacinĩra mũtego wayo ũbumba,
\q1 nĩgũkorwo wabu wayo nĩguo ũtũmaga ĩtũũre ĩĩkenagia,
\q2 na ĩkarĩĩaga irio iria njega mũno.
\q1 
\v 17 Ĩĩgũtũũra ĩtahaga na wabu wayo,
\q2 ĩkaniinaga ndũrĩrĩ ingĩ ĩtegũciguĩra tha?
\b
\c 2
\q1 
\v 1 Nĩngũrũgama handũ hakwa ha kũrangĩra,
\q2 na njikare o hau rũthingo igũrũ.
\q1 Njetereire njigue ũrĩa ekũnjĩĩra,
\q2 nĩguo menye ũrĩa ingĩcookia nĩ ũndũ wa iteta rĩĩrĩ.
\s1 Icookia rĩa Jehova
\p 
\v 2 Nake Jehova akĩnjookeria atĩrĩ,
\q1 “Andĩka ũguũrio ũyũ,
\q2 ũwandĩke wega ihengere-inĩ na ndemwa nene,
\q1 nĩgeetha ũthomeke wega,
\q2 o na mũndũ angĩkorwo atengʼerete.
\q1 
\v 3 Nĩgũkorwo ũguũrio ũyũ wetereire ihinda rĩrĩa rĩtuĩtwo;
\q2 waragia ũhoro wa matukũ ma mũthia,
\q2 na ndũngĩtuĩka wa maheeni.
\q1 O na ũngĩikara mũno-rĩ, weterere.
\q2 Ti-itherũ nĩũkahingio, na ndũgatĩĩrio.
\b
\q1 
\v 4 “Atĩrĩrĩ, mũndũ mwĩtĩĩi-rĩ,
\q2 merirĩria maake ti marũngĩrĩru;
\q2 no mũndũ ũrĩa mũthingu
\q2 agatũũra muoyo nĩ ũndũ wa gwĩtĩkia gwake;
\q1 
\v 5 ti-itherũ, mũndũ ũcio mwĩtĩĩi nĩakunyanagĩrwo nĩ ndibei;
\q2 nĩ mwĩtĩĩi na ndarĩ hĩndĩ ahurũkaga.
\q1 Tondũ akorokete ta mbĩrĩra,
\q2 na o ta ũrĩa gĩkuũ gĩtaiganagia,
\q1 o nake ndaiganagia;
\q2 acookanagĩrĩria ndũrĩrĩ ciothe harĩ we,
\q2 na agataha andũ a ndũrĩrĩ ciothe.
\p 
\v 6 “Githĩ andũ othe matikamũthekerera makĩmũnyũrũragia, na mamũnyarare, makiugaga atĩrĩ,
\q1 “ ‘Kaĩ mũndũ ũrĩa wĩigagĩra indo cia ũici,
\q2 na agetongia na indo cia ũtunyani arĩ na haaro-ĩ!
\q2 Egũtũũra ekaga ũguo nginya-rĩ?’
\q1 
\v 7 Andũ arĩa ũrĩ na thiirĩ wao githĩ matigagũũkĩrĩra o rĩmwe?
\q2 Githĩ matikaarahũka, na matũme ũinaine,
\q2 macooke makũnyamarie?
\q1 
\v 8 Tondũ nĩũtahĩte ndũrĩrĩ nyingĩ indo ciao,
\q2 matigari ma ndũrĩrĩ icio, nĩmagagũtaha indo o nawe.
\q1 Nĩ ũndũ nĩũitĩte thakame ya andũ,
\q2 na ũkaananga mabũrũri, na matũũra manene, o na arĩa othe marĩ kuo.
\b
\q1 
\v 9 “Mũndũ ũrĩa wakaga wathani wake,
\q2 na agetongia na uumithio ũtarĩ wa kĩhooto,
\q1 nĩgeetha aake nyũmba yake handũ igũrũ
\q2 nĩguo ehonokie ndakanyiitwo nĩ mwanangĩko,
\q2 kaĩ arĩ na haaro-ĩ!
\q1 
\v 10 Wee wanaciirĩra kũniinwo kwa ndũrĩrĩ nyingĩ,
\q2 ũgaconorithia nyũmba yaku mwene,
\q2 na ũkoorwo nĩ muoyo waku.
\q1 
\v 11 Mahiga ma rũthingo nĩmakanĩrĩra,
\q2 na mĩgamba ya mbaũ nĩĩkamũkĩria.
\b
\q1 
\v 12 “Mũndũ ũrĩa wakithagia itũũra inene na ũiti wa thakame,
\q2 na akahaanda itũũra na njĩra cia ũmaramari, kaĩ arĩ na haaro-ĩ!
\q1 
\v 13 Githĩ Jehova Mwene-Hinya-Wothe ndatuĩte
\q2 atĩ wĩra wa andũ no ngũ cia gwakĩrĩria mwaki,
\q2 na atĩ ndũrĩrĩ ciĩnogagia o tũhũ?
\q1 
\v 14 Nĩgũkorwo thĩ nĩĩkaiyũrwo nĩ ũmenyo wa riiri wa Jehova,
\q2 o ta ũrĩa maaĩ maiyũrĩte iria-inĩ.
\b
\q1 
\v 15 “Mũndũ ũrĩa ũheaga andũ a itũũra rĩake njoohi,
\q2 akamatahĩria mondo-inĩ ya rũũa ya ndibei nginya makarĩĩo,
\q2 nĩgeetha erorere njaga yao, kaĩ arĩ na haaro-ĩ!
\q1 
\v 16 Ũkaiyũrwo nĩ thoni, handũ ha kũgĩa na riiri.
\q2 Rĩĩrĩ nĩrĩo ihinda rĩaku!
\q1 Nyua, ũrĩĩo,
\q2 nayo njaga yaku yoneke!
\q1 Gĩkombe kuuma guoko-inĩ kwa ũrĩo kwa Jehova
\q2 nĩkĩragũkora, na njono nĩikũhumbĩra riiri waku.
\q1 
\v 17 Haaro ĩrĩa ũrutĩire Lebanoni-rĩ, nĩĩgakũhubĩkania,
\q2 na wanangi waku wa nyamũ-rĩ, nĩũgakũmakia mũno.
\q1 Nĩ ũndũ nĩũitĩte thakame ya andũ,
\q2 na ũkaananga mabũrũri, na matũũra manene, na arĩa othe marĩ kuo.
\b
\q1 
\v 18 “Mũhianano mũicũhie nĩ wa bata ũrĩkũ mũndũ aarĩkia kũwacũhia?
\q2 O naguo mũhianano wa gũtwekio ũrĩa ũtũmaga andũ maheeneke nĩ wa bata ũrĩkũ?
\q1 Nĩgũkorwo ũrĩa ũũthondekaga ehokaga kĩrĩa ombĩte;
\q2 athondekaga mĩhianano ĩtaaragia.
\q1 
\v 19 Mũndũ ũrĩa wĩraga rũbaũ atĩrĩ, ‘Gĩa na muoyo!’
\q2 Kana akeera ihiga rĩtarĩ muoyo atĩrĩ, ‘Arahũka!’ Kaĩ arĩ na haaro-ĩ!
\q1 Indo ta icio ciakĩhota kuonia mũndũ njĩra?
\q2 Ihumbĩtwo thahabu na betha;
\q2 no itirĩ na mĩhũmũ thĩinĩ wacio.
\q1 
\v 20 No rĩrĩ, Jehova arĩ hekarũ-inĩ yake theru;
\q2 thĩ yothe nĩĩkire ki ĩrĩ mbere yake.”
\c 3
\s1 Ihooya rĩa Habakuku
\p 
\v 1 Rĩrĩ nĩ ihooya rĩa mũnabii Habakuku, rĩa kũinwo ta rwĩmbo.
\q1 
\v 2 Atĩrĩrĩ Jehova, nĩnjiguĩte ũhoro wa ngumo yaku,
\q2 nganyiitwo nĩ guoya nĩ ũndũ wa ciĩko ciaku.
\q1 Rurumũkia ciĩko ciaku matukũ-inĩ maya maitũ,
\q2 ũtũme imenyeke matukũ-inĩ maitũ;
\q2 o na hĩndĩ ĩrĩa ũrĩ mũrakaru, iguanagĩra tha.
\b
\q1 
\v 3 Ngai ookire oimĩte Temani,
\q2 ũcio Mũtheru agĩũka oimĩte Kĩrĩma kĩa Parani.
\q1 Riiri wake ũkĩhumbĩra igũrũ,
\q2 naguo ũgooci wake ũkĩiyũra thĩ.
\q1 
\v 4 Ũkengi wake wahaanaga ta riũa rĩkĩratha;
\q2 mĩrũri yahenũkaga kuuma guoko-inĩ gwake,
\q2 naho hau nĩho hinya wake wahithĩtwo.
\q1 
\v 5 Mũthiro nĩguo wamũtongoragia;
\q2 mũrimũ wa mũthiro ũkamuuma thuutha.
\q1 
\v 6 Aarũgamire, agĩthingithia thĩ;
\q2 agĩcũthĩrĩria agĩtũma ndũrĩrĩ ciinaine.
\q1 Irĩma cia tene ikĩmumuthũka,
\q2 natuo tũrĩma twa tene tũkĩmomoka.
\q2 Mĩthiĩre yake-rĩ, nĩ ya tene na tene.
\q1 
\v 7 Nĩndonire andũ arĩa matũũraga hema cia Kushani marĩ na mĩnyamaro,
\q2 nao arĩa matũũraga Midiani maiyũrĩtwo nĩ ruo rũnene.\f + \fr 3:7 \ft Andũ a Kushani na Midiani maarĩ Aarabu arĩa matũũraga gũkuhĩ na Edomu.\f*
\b
\q1 
\v 8 Wee Jehova-rĩ, nĩ njũũĩ warakarĩire?
\q2 Mangʼũrĩ maku-rĩ, nĩ tũrũũĩ mokĩrĩire?
\q1 Wee-rĩ, wokĩrĩire iria na mangʼũrĩ maku
\q2 rĩrĩa wahaicĩte mbarathi ciaku
\q2 na ngaari ciaku cia ũhootani cia ita?
\q1 
\v 9 Nĩwarutire ũta waku, ũkĩwoya na igũrũ,
\q2 na ũgĩĩtia mĩguĩ mĩingĩ.\f + \fr 3:9 \ft Mĩguĩ haha nĩ heni na marurumĩ iria Mwathani aahũthĩrire.\f*
\q1 Nayo thĩ ũkĩmĩgayania na njũũĩ;
\q2 
\v 10 irĩma ciakuonire ikĩĩnyogonda.
\q1 Kĩguũ kĩa maaĩ nakĩo gĩgĩtherera;
\q2 maaĩ ma kũrĩa kũriku makĩhũũyũka,
\q2 na makĩambararia makũmbĩ mamo na igũrũ taarĩ moko.
\b
\q1 
\v 11 Riũa na mweri nĩciarũgamire o ro ũguo kũu igũrũ,
\q2 ciona ũtheri wa mĩguĩ yaku ĩkĩrathũka,
\q2 na ciona kũhenia gwa itimũ rĩaku rĩkĩmenũka.
\q1 
\v 12 Watuĩkanĩirie thĩ na mangʼũrĩ,
\q2 na ũkĩhũũra ndũrĩrĩ ũrĩ na marakara.
\q1 
\v 13 Wokire kũhonokia andũ aku,
\q2 na ũhonokie ũrĩa waku mũitĩrĩrie maguta.
\q1 Wahehenjire kĩongo kĩa nyũmba ya waganu,
\q2 ũkĩmĩtharia nginya itina-inĩ ciayo.
\q1 
\v 14 Wamũtheecire mũtwe na itimũ rĩake mwene,
\q2 rĩrĩa njamba ciake cia ita ciatũtharĩkĩire itũharaganie;
\q2 cigakenagĩrĩra ta igũtambuura athĩĩni arĩa mehithĩte.
\q1 
\v 15 Wee wakinyire iria igũrũ na mbarathi ciaku,
\q2 ũgĩthuka maaĩ macio maingĩ, magĩtuĩka makũmbĩ manene.
\b
\q1 
\v 16 Ndaiguire ũhoro ũcio,
\q2 ngoro yakwa ĩgĩtumatuuma,
\q1 nacio iromo ciakwa ikĩinaina nĩ mũgambo ũcio;
\q2 mahĩndĩ makwa makĩonja,
\q2 namo magũrũ makwa makĩinaina.
\q1 No niĩ nĩngweterera ngirĩrĩirie,
\q2 nginya mũthenya ũrĩa wa kũnyariirĩka ũgaakinya,
\q2 ũkore rũrĩrĩ rũrĩa rũtũtharĩkagĩra.
\q1 
\v 17 Atĩrĩrĩ, o na mũkũyũ ũngĩaga kũruta kĩro,
\q2 nayo mĩthabibũ yaage thabibũ,
\q1 o naguo mũtamaiyũ wage maciaro,
\q2 nayo mĩgũnda yaage irio;
\q1 o na kũngĩaga ngʼondu gĩcegũ
\q2 na kwage ngʼombe ciugũ-inĩ-rĩ,
\q1 
\v 18 niĩ no ndĩrĩkenagĩra Jehova,
\q2 njanjamũkage nĩ ũndũ wa Ngai Mũhonokia wakwa.
\b
\q1 
\v 19 Mwathani Jehova nĩwe hinya wakwa,
\q2 atũmaga magũrũ makwa magĩe ihenya ta magũrũ ma thwariga,
\q2 nake aahotithagia kũhaica kũrĩa gũtũũgĩru.
\b
\q1 Kũrĩ mũtongoria wa nyĩmbo. Rwĩmbo rũrũ nĩ rwa kũinwo na inanda cia mũgeeto.
