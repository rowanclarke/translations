\id 1CH - Yorumsuz Türkçe Çeviri (YTC)
\h 1. TARİHLER
\toc1 1. TARİHLER
\toc2 1. TARİHLER
\toc3 1. TARİHLER
\mt1 1. TARİHLER
\c 1
\p 
\v 1 Adem, Şit, Enoş,
\v 2 Kenan, Mahalalel, Yeret,
\v 3 Hanok, Metuşelah, Lemek,
\v 4 Noa, Sam, Ham, Yafet
\p 
\v 5 Yafet'in oğulları: Gomer, Magog, Meday, Yâvan, Tuval, Meşek, Tiras.
\v 6 Gomer'in oğulları: Aşkenaz, Difat, Togarma.
\v 7 Yâvan'ın oğulları: Elişa, Tarşiş, Kittim, Rodanim.
\p 
\v 8 Ham'ın oğulları: Kûş, Misrayim, Pût, Kenan.
\v 9 Kûş'un oğulları: Seva, Havila, Savta, Raama, Savteka. Raama'nın oğulları: Şeva, Dedan.
\v 10 Kûş, Nimrod'un babası oldu. O yeryüzünde güçlü biri olmaya başladı.
\v 11 Misrayim Ludlular'ın, Anamlılar'ın, Lehavlılar'ın, Naftuhlular'ın,
\v 12 Patruslular'ın, Filistliler'in ataları olan Kasluhlular'ın (Filistliler bunlardan geldi) ve Kaftorlular'ın atasıydı.
\v 13 Kenan ilk oğlu Sidon'un ve Hititler'in,
\v 14 Yevuslular'ın, Amorlular'ın, Girgaşlılar'ın,
\v 15 Hivliler'in, Arklılar'ın, Sinliler'in,
\v 16 Arvatlılar'ın, Semarlılar'ın, Hamalılar'ın babasıydı.
\p 
\v 17 Sam'ın oğulları: Elam, ve Aşur, ve Arpakşad, ve Lud, ve Aram, ve Uts, ve Hul, ve Geter, ve Meşek.
\v 18 Arpakşad, Şelahın babası oldu, ve Şelah Everin babası oldu.
\v 19 Ever'e iki oğul doğdu; birinin adı Pelek'di; çünkü onun günlerinde yeryüzü bölündü; ve kardeşinin adı Yoktan idi.
\v 20 Yoktan, Almodad'ın, Şelef'in, Hazarmavet'in, Yerah'ın,
\v 21 Hadoram'ın, Uzal'ın, Diklah'ın,
\v 22 Eval'ın, Avimael'in, Şeva'nın,
\v 23 Ofir, Havila ve Yovav'ın babası oldu. Bunların hepsi Yoktan'ın oğullarıydı.
\v 24 Şem, Arpakşad, Şela,
\v 25 Ever, Pelek, Reu,
\v 26 Seruk, Nahor, Terah,
\v 27 Avram (Avraham da denilir).
\p 
\v 28 Avraham'ın oğulları: İshak ve İşmael.
\v 29 Bunlar onların kuşaklarıdır: İşmael'in ilk oğlu Nevayot; sonra Kedar, Adbeel, Mivsam,
\v 30 Mişma, Duma, Massa, Hadad, Tema,
\v 31 Yetur, Nafiş ve Kedema. Bunlar İşmael'in oğullarıydı.
\p 
\v 32 Avraham'ın cariyesi Ketura'nın oğulları: Zimran, Yokşan, Medan, Midyan, Yişvak ve Şuah'ı doğurdu. Yokşan'ın oğulları: Şeva ve Dedan.
\v 33 Midyan'ın oğulları: Efa, Efer, Hanok, Avida ve Eldaa. Bunların hepsi Ketura'nın oğullarıydı.
\p 
\v 34 Avraham, İshak'ın babası oldu. İshak'ın oğulları: Esav ve İsrael.
\v 35 Esav'ın oğulları: Elifaz, Reuel, Yeuş, Yalam ve Korah.
\v 36 Elifez'in oğulları: Teman, Omar, Sefi, Gatam, Kenaz, Timna ve Amalek.
\v 37 Reuel'in oğulları: Nahat, Zerah, Şamma ve Mizza.
\p 
\v 38 Seir'in oğulları: Lotan, Şoval, Siveon, Ana, Dişon, Ezer ve Dişan.
\v 39 Lotan'ın oğulları: Hori ve Homam; Timna Lotan'ın kız kardeşiydi.
\v 40 Şoval'ın oğulları: Alian, Manahat, Eval, Şefi ve Onam. Siveon'un oğulları: Aya ve Ana.
\v 41 Anah'ın oğulları: Dişon. Dişon'un oğulları: Hamran, Eşvan, İtran ve Keran.
\v 42 Ezer'in oğulları: Bilhan, Zaavan ve Yaakan. Dişan'ın oğulları: Uts ve Aran.
\p 
\v 43 İsrael'in çocukları üzerinde hiçbir kral hüküm sürmeden önce, Edom ülkesinde hüküm süren krallar şunlardır: Beor oğlu Bela; ve kentinin adı Dinhabah idi.
\v 44 Bela öldü ve yerine Bosralı Zerah oğlu Yovav kral oldu.
\v 45 Yovav öldü ve yerine Temanlılar ülkesinden Huşam kral oldu.
\v 46 Huşam öldü ve yerine Moav kırlarında Midyan'ı vuran Bedad oğlu Hadad kral oldu; kentinin adı Avit idi.
\v 47 Hadad öldü ve yerine Masrekalı Samla kral oldu.
\v 48 Samla öldü ve yerine Irmak kıyısındaki Rehovotlu Şaul kral oldu.
\v 49 Şaul öldü ve yerine Akvor oğlu Baal Hanan kral oldu.
\v 50 Baal Hanan öldü ve yerine Hadad kral oldu; kentinin adı Pai idi. Karısının adı Mezahav kızı Matred'in kızı Mehetabel'di.
\v 51 Sonra Hadad öldü. Edom'un beyleri şunlardı: Bey Timna, Bey Aliah, Bey Yetet,
\v 52 Bey Oholivama, Bey Ela, Bey Pinon,
\v 53 Bey Kenaz, Bey Teman, Bey Mivsar,
\v 54 Bey Magdiel ve Bey İram. Bunlar Edom'un beyleridir
\c 2
\p 
\v 1 İsrael'in oğulları şunlardır: Ruven, Şimon, Levi, Yahuda, İssakar, Zevulun,
\v 2 Dan, Yosef, Benyamin, Naftali, Gad ve Aşer.
\p 
\v 3 Yahuda'nın oğulları: Er, Onan ve Şela. Bu üçü, Kenanlı Şua'nın kızından olan oğluydu. Yahuda'nın ilk oğlu olan Er, Yahve'nin\f + \fr 2:3 \ft “Yahve” Tanrı’nın asıl ismidir, diğer çevirilerde bazen “RAB=EFENDİ” (tamamı büyük harflerle) olarak çevrilir.\f* gözünde kötüydü ve onu öldürdü.
\v 4 Gelini Tamar ona Peres ve Zerah'ı doğurdu. Yahuda'nın bütün oğulları beştir.
\p 
\v 5 Peres'in oğulları: Hetsron ve Hamul.
\v 6 Zera'nın oğulları: Zimri, Etan, Heman, Kalkol ve Dara; bunların hepsi beştir.
\v 7 Karmi'nin oğlu: Adanmış şeye karşı suç işleyerek İsrael'i sıkıntıya sokan Ahar.
\v 8 Etan'ın oğlu: Azarya.
\p 
\v 9 Hetsron'un kendisine doğan oğulları: Yerahmeel, Ram ve Keluva.
\v 10 Ram, Amminadav'ın babası oldu; Amminadav da Yahuda oğullarının beyi Nahşon'un babası oldu.
\v 11 Nahşon, Salma'nın babası oldu; Salma, Boaz'ın babası oldu.
\v 12 Boaz, Oved'in babası oldu; Oved de Yişay'ın babası oldu.
\v 13 Yişay, ilk oğlu Eliav'ın, ikinci oğlu Avinadav'ın, üçüncü oğlu Şimea'nın,
\v 14 dördüncü oğlu Netanel'in, beşinci oğlu Radday'ın,
\v 15 Altıncı oğlu Otsem'in ve yedinci oğlu David'in babası oldu.
\v 16 Kız kardeşleri ise Seruya ve Avigail'di. Seruya'nın oğulları: Avişay, Yoav ve Asahel, üçtü.
\v 17 Avigail, Amasa'yı doğurdu; Amasa'nın babası ise İşmaelli Yeter'di.
\p 
\v 18 Hetsron oğlu Kalev, karısı Azuvah'dan ve Yeriot'tan çocuk sahibi oldu. Bunlar kadının oğullarıydı: Yeşer, Şovav ve Ardon.
\v 19 Azuvah öldü ve Kalev, kendisine Hur'u doğuran Efrat'la evlendi.
\v 20 Hur, Uri'nin babası oldu ve Uri de Betsalel'in babası oldu.
\p 
\v 21 Daha sonra Hetsron, altmış yaşındayken Gilad'ın babası Makir'in kızının yanına girdi ve onu eş olarak aldı. Kadın ona Seguv'u doğurdu.
\v 22 Seguv, Gilad ülkesinde yirmi üç kenti olan Yair'in babası oldu.
\v 23 Geşur ve Aram, Yair'in kasabalarını, Kenat'ı ve köylerini, altmış kenti onlardan aldılar. Bunların hepsi Gilad'ın babası Makir'in oğullarıydı.
\v 24 Hetsron Kalev Efrata'da öldükten sonra, Hetsron'un karısı Aviya, ona Tekoa'nın babası Aşhur'u doğurdu.
\p 
\v 25 Hetsron'un ilk oğlu Yerahmeel'in oğulları, ilk oğlu Ram, Bunah, Oren, Otsem ve Ahiya'ydı.
\v 26 Yerahmeel'in başka bir karısı daha vardı; adı Atara'ydı. Onam'ın annesiydi.
\v 27 Yerahmeel'in ilk oğlu Ram'ın oğulları, Maats, Yamin ve Eker'di.
\v 28 Onam'ın oğulları, Şammay ve Yada'ydı. Şammay'ın oğulları, Nadav ve Avişar'dı.
\v 29 Avishur'un karısının adı Avihayil'di; kadın ona Ahvan ve Molid'i doğurdu.
\v 30 Nadav'ın oğulları, Seled ve Appaim'di; ama Seled çocuksuz öldü.
\v 31 Appaim'in oğlu, İşi. İşi'nin oğlu, Şeşan'dı. Şeşan'ın oğlu: Ahlay.
\v 32 Şammay'ın kardeşi Yada'nın oğulları: Yeter ve Yonatan; ve Yeter çocuksuz öldü.
\v 33 Yonatan'ın oğulları: Pelet ve Zaza. Bunlar Yerahmeel'in oğullarıydı.
\v 34 Şeşan'ın oğlu yoktu, yalnız kızları vardı. Şeşan'ın bir hizmetkârı vardı, Mısırlı, adı Yarha'ydı.
\v 35 Şeşan kızını hizmetkârı Yarha'ya eş olarak verdi; ve ona Attay'ı doğurdu.
\v 36 Attay, Natan'ın babası oldu ve Natan, Zavad'ın babası oldu.
\v 37 Zavad, Eflal'ın babası oldu ve Eflal, Oved'in babası oldu.
\v 38 Oved, Yehu'nun babası oldu ve Yehu, Azarya'nın babası oldu.
\v 39 Azarya, Heles'in babası oldu ve Heles, Eleasa'nın babası oldu.
\v 40 Elasa, Sismay'ın babası oldu ve Sismay, Şallum'un babası oldu.
\v 41 Şallum, Yekamya'nın babası oldu ve Yekamya, Elişama'nın babası oldu.
\p 
\v 42 Yerahmeel'in kardeşi Kalev'in oğulları, ilk oğlu Zif'in babası olan Meşa ve Hevron'un babası olan Mareşah'ın oğullarıydı.
\v 43 Hevron'un oğulları: Korah, Tappuah, Rekem ve Şema.
\v 44 Şema, Yorkeam'ın babası olan Raham'ın babası oldu. Rekem, Şammay'ın babası oldu.
\v 45 Şammay'ın oğlu Maon'du. Maon da Beyt Sur'un babasıydı.
\v 46 Kalev'in cariyesi Efa, Haran'ı, Motsa'yı ve Gazez'i doğurdu. Haran, Gazez'in babası oldu.
\v 47 Yahday'ın oğulları: Regem, Yotan, Geşan, Pelet, Efa ve Şaaf.
\v 48 Kalev'in cariyesi Maaka, Şeber ve Tirhana'yı doğurdu.
\v 49 Madmanna'nın babası Şaaf'ı, Makbena'nın babası Şeva'yı ve Gibea'nın babasını doğurdu; Kalev'in kızı da Aksa'ydı.
\p 
\v 50 Efrata'nın ilk oğlu Hur'un oğlu Kalev'in oğulları şunlardı: Kiryat Yearim'in babası Şoval,
\v 51 Beytlehem'in babası Salma ve Beyt Gader'in babası Haref.
\v 52 Kiryat Yearim'in babası Şoval'ın oğulları vardı: Haroeh, Menuhot'un yarısı.
\v 53 Kiryat Yearim'in aileleri: İtriler, Putiler, Şumatlılar ve Mişralılar; bunlardan da Soralılar ve Eştaollular geldi.
\v 54 Salma'nın oğulları: Beytlehemliler, Netofalılar, Atrot Beyt Yoav ve Manahatlılar'ın yarısı, Sorlular.
\v 55 Yaves'te yaşayan yazıcı aileleri: Tiratlılar, Şimeatlılar ve Şukatlılar. Bunlar, Rekav evinin babası olan Hammat'tan gelen Kenliler'dir.
\c 3
\p 
\v 1 Hevron'da David'e doğan oğulları şunlardır: İlk oğlu, Yizreelli Ahinoam'dan Amnon; ikincisi, Karmelli Avigail'den Daniel;
\v 2 Üçüncüsü, Geşur Kralı Talmay'ın kızı Maaka'nın oğlu Avşalom; dördüncüsü, Hagit'in oğlu Adoniya;
\v 3 Beşincisi, Avital'den Şefatya; altıncısı, karısı Egla'dan İtream.
\v 4 Hevron'da kendisine altı çocuk doğdu; ve orada yedi yıl altı ay hüküm sürdü. Yeruşalem'de otuz üç yıl hüküm sürdü.
\v 5 Ve Yeruşalem'de kendisine bunlar doğdu: Şimea, Şovav, Natan ve Solomon, dördü, Ammiel'in kızı Batşua'dan;
\v 6 ve İvhar, Elişama, Elifelet,
\v 7 Noga, Nefeg, Yafia,
\v 8 Elişama, Eliyeda ve Elifelet, dokuz.
\v 9 Bunların hepsi David'in oğullarıydı, cariyelerin oğulları hariç; Tamar da onların kız kardeşiydi.
\p 
\v 10 Solomon'un oğlu Rehovam'dı; Aviya onun oğlu, Asa onun oğlu, Yehoşafat onun oğlu,
\v 11 Yoram onun oğlu, Ahazya onun oğlu, Yoaş onun oğlu,
\v 12 Amatsya onun oğlu, Azarya onun oğlu, Yotam onun oğlu,
\v 13 Ahaz onun oğlu, Hizkiya onun oğlu, Manaşşe onun oğlu,
\v 14 Amon onun oğlu Yoşiya onun oğlu.
\v 15 Yoşiya'nın oğulları: İlk oğlu Yohanan, ikincisi Yehoyakim, üçüncüsü Sidkiya ve dördüncüsü Şallum.
\v 16 Yehoyakim'in oğulları: Oğlu Yekonya ve oğlu Sidkiya.
\v 17 Sürgün olan Yekonya'nın oğulları: Onun oğlu Şealtiel,
\v 18 Malkiram, Pedaya, Şenazar, Yekamya, Hoşama ve Nedavya.
\v 19 Pedaya'nın oğulları: Zerubbabel ve Şimei. Zerubbabel'in oğulları: Meşullam ve Hananya; onların kız kardeşi Şelomit'ti;
\v 20 Haşuva, Ohel, Berekya, Hasadya ve Yuşav Hesed, beş.
\v 21 Hananya'nın oğulları: Pelatya ve Yeşaya; Refaya'nın oğulları, Arnan'ın oğulları, Ovadya'nın oğulları, Şekanya'nın oğulları.
\v 22 Şekanya'nın oğlu: Şemaya. Şemaya'nın oğulları: Hattuş, İgal, Barya, Nearya ve Şafat, altı.
\v 23 Neraya'nın oğulları: Elyoenay, Hizkiya ve Azrikam, üç.
\v 24 Elyoenay'ın oğulları: Hodavya, Elyaşiv, Pelaya, Akkub, Yohanan, Delaya ve Anani; yedi.
\c 4
\p 
\v 1 Yahuda'nın oğulları: Perez, Hetsron, Karmi, Hur ve Şoval.
\v 2 Şoval'ın oğlu Reaya, Yahat'ın babası oldu; Yahat da Ahumay ve Lahad'ın babası oldu. Bunlar Soralılar'ın boylarıdır.
\v 3 Etam'ın babasının oğulları şunlardır: Yizreel, İşma ve İdvaş. Kız kardeşlerinin adı Hazzelelponi'ydi.
\v 4 Penuel, Gedor'un babasıydı ve Ezer, Huşa'nın babasıydı. Bunlar, Efrata'nın ilk oğlu Hur'un, Beytlehem'in babasıdır.
\v 5 Tekoa'nın babası Aşhur'un iki karısı vardı: Helah ve Naara.
\v 6 Naara ona Ahuzzam, Hefer, Temeni ve Haahaştari'yi doğurdu. Bunlar Naara'nın oğullarıydı.
\v 7 Helah'ın oğulları Seret, Yitshar ve Etnan'dı.
\v 8 Hakkots, Anuv'un, Soveva'nın ve Harum'un oğlu Aharhel boylarının atası oldu.
\p 
\v 9 Yaves kardeşlerinden daha saygındı. Annesi ona Yaves\f + \fr 4:9 \ft “Yaves” İbranice’deki “acı” kelimesini çağrıştırır.\f* adını verdi, “Çünkü onu acı çekerek doğurdum” dedi.
\p 
\v 10 Yaves, İsrael'in Tanrısı'na\f + \fr 4:10 \ft “Tanrı” olarak tercüme edilen İbranice kelime “אֱלֹהִ֑ים” (Elohim)’dir.\f* feryat edip, “Keşke beni gerçekten kutsasan ve sınırımı genişletsen! Elin benimle olsun ve acı çekmeyeyim diye beni kötülükten koru!” dedi.
\p Tanrı ona istediğini verdi.
\p 
\v 11 Şuha'nın kardeşi Keluv, Eşton'un babası olan Mehir'in babası oldu.
\v 12 Eşton, Beyt Rafa, Paseah ve İr Nahaş'ın babası Tehinna'nın babası oldu. Bunlar Reka adamlarıdır.
\v 13 Kenaz'ın oğulları: Otniel ve Seraya. Otniel’in oğulları: Hatat.\f + \fr 4:13 \ft Grekçe and Vulgata'ya “ve Meonotay” eklenir\f*
\v 14 Meonotay, Ofra’nın babası oldu; Seraya, Ge Haraşim’in babası Yoav’ın babası oldu; çünkü onlar zanaatkârlardı.
\v 15 Yefunne’nin oğlu Kalev’in oğulları: İru, Ela ve Naam. Ela’nın oğlu: Kenaz.
\v 16 Yehallelel’in oğulları: Zif, Zifa, Tirya ve Asarel.
\v 17 Ezra’nın oğulları: Yeter, Mered, Efer ve Yalon. Mered’in karısı Miryam’ı, Şammay’ı ve Eştemoa’nın babası İşva’yı doğurdu.
\v 18 Yahudi olan karısı, Gedor’un babası Yered’i, Soko’nun babası Hever’i ve Sanoah’ın babası Yekutiel’i doğurdu. Bunlar, Mered’in aldığı Firavun’un kızı Bitya’nın oğullarıydı.
\v 19 Naham'ın kız kardeşi Hodiya'nın karısının oğulları, Keilalı Garmlılar'ın ve Eştemoalı Maakalılar'ın atalarıydı.
\v 20 Şimon'un oğulları: Amnon, Rinna, Ben Hanan ve Tilon. Yişi'nin oğulları: Zohet ve Ben Zohet.
\v 21 Yahuda oğlu Şela'nın oğulları: Leka'nın babası Er, Mareşah'ın babası Laada ve ince keten yapanlar evinin, Aşvea evinin boyları;
\v 22 Yokim ve Moav ve Yaşubilehem'de egemenlik kuran Kozeva adamları, Yoaş ve Saraf. Bu kayıtlar eskidir.
\v 23 Bunlar çömlekçiler ve Netaim ve Gederah sakinleriydi; kralın işinde onunla birlikte orada yaşıyorlardı.
\p 
\v 24 Şimon'un oğulları: Nemuel, Yamin, Yariv, Zerah, Şaul;
\v 25 Onun oğlu Şallum, onun oğlu Mivsam, onun oğlu Mişma.
\v 26 Mişma'nın oğulları: Onun oğlu Hammuel, onun oğlu Zakkur, onun oğlu Şimei.
\v 27 Şimei'nin on altı oğlu ve altı kızı vardı; ama kardeşlerinin çok çocuğu yoktu ve bütün boyları Yahuda'nın çocukları gibi çoğalmadı.
\v 28 Beerşeva'da, Molada'da, Hazarşual'da,
\v 29 Bilha'da, Esem'de, Tolad'da,
\v 30 Betuel'de, Horma'da, Ziklag'da,
\v 31 Bet Markavot'ta, Hazar Susim'de, Beyt Biri'de ve Şaaraim'de oturdular. David'in krallığına kadar kentleri bunlardı.
\v 32 Köyleri Etam, Ayn, Rimmon, Token ve Aşan'dı; beş kent;
\v 33 Ve aynı kentlerin çevresindeki Baal'a kadar bütün köyler onlarındı. Yerleşim yerleri bunlardı ve soy kütüklerini tuttular.
\v 34 Meşovav, Yamlek, Amatsya'nın oğlu Yoşa,
\v 35 Yoel, Asiel oğlu Seraya oğlu Yoşivya oğlu Yehu,
\v 36 Elioenay, Yaakovah, Yeşohayya, Asaya, Adiel, Yesimiel, Benaya,
\v 37 Ve Şemaya oğlu, Şimri'nin oğlu, Yedaya'nın oğlu, Allon'un oğlu, Şifi'nin oğlu Ziza.
\v 38 Bunların adları anılanlar, kendi ailelerinde beylerdi. Atalarının evleri çok çoğaldı.
\p 
\v 39 Sürüleri için otlak aramak üzere Gedor girişine, vadinin doğu tarafına gittiler.
\v 40 Bol ve iyi otlaklar buldular. Ülke geniş, sakin ve huzurluydu. Çünkü daha önce orada yaşayanlar Ham soyundandı.
\v 41 Bunlar, Yahuda Kralı Hizkiya'nın günlerinde adları yazılı olanlar geldiler ve onların çadırlarını ve orada bulunan Meunlar'ı vurdular; ve onları tamamen yok ettiler, bügüne dek böyledir ve onların yerinde yaşadılar, çünkü orada sürüleri için otlak vardı.
\v 42 Onlardan bazıları, Şimonoğulları'ndan beş yüz kişi, Seir dağına gittiler; ve onların başları Yişi'nin oğulları Pelatya, Nearya, Refaya ve Uzziel'di.
\v 43 Amalekliler'in kaçaklarından geri kalanını vurdular ve bugüne dek orada yaşadılar.
\c 5
\p 
\v 1 İsrael'in ilk oğlu Ruven'in oğulları (Çünkü ilk doğan oydu, ama babasının yatağını kirlettiği için ilk oğulluk hakkı İsrael'in oğlu Yosef'in oğullarına verildi; ve soy kütüğü ilk oğulluk hakkına göre sayılmadı.
\v 2 Çünkü Yahuda kardeşlerinden üstün geldi ve hükümdar ondan çıktı; ama ilk oğulluk hakkı Yosef''indi)
\v 3 İsrael'in ilk oğlu Ruven'in oğulları: Hanok, Pallu, Hetsron ve Karmi.
\v 4 Yoel'in oğulları: Onun oğlu Şemaya, onun oğlu Gog, onun oğlu Şimei,
\v 5 Onun oğlu Mika, onun oğlu Reaya, onun oğlu Baal,
\v 6 ve onun oğlu Beera, Aşur Kralı Tilgat Pilneser'in sürgüne gönderdiği kişiydi. Ruvenliler'in beyiydi.
\v 7 Boylarına göre kardeşleri, kuşaklarının soyağacına göre sayıldığında: Baş Yeiel ve Zekariya,
\v 8 Ve Yoel oğlu Şema oğlu Azaz oğlu Bela, o Nebo'ya ve Baal Meon'a kadar Aroer'de yaşıyordu;
\v 9 Ve Gilad ülkesinde hayvanları çoğaldığı için, Fırat Irmağı'ndan çölün girişine kadar doğuda yaşadı.
\p 
\v 10 Saul'un günlerinde, onların eliyle düşen Hagriler ile savaştılar; ve Gilad'ın doğusundaki bütün ülkede çadırlarında yaşadılar.
\p 
\v 11 Gadoğulları Başan ülkesinde Saleka'ya kadar onların yanında yaşadılar:
\v 12 Başı Yoel, ikincisi Şafam, Yanay ve Başan'da Şafat.
\v 13 Ataları evlerinden olan kardeşleri: Mikael, Meşullam, Şeva, Yoray, Yakan, Zia ve Ever, yedi.
\v 14 Bunlar Huri oğlu, Yaroah oğlu, Gilad oğlu, Mikael oğlu, Yeşişay oğlu, Yahdo oğlu, Buz oğlu Avihayil'in oğullarıydı.
\v 15 Guni oğlu Avdiel oğlu Ahi ataları evlerinin başıydı.
\v 16 Gilad'da, Başan'da ve kasabalarında, Şaron'un bütün otlaklarında da, onların sınırlarına kadar yaşıyorlardı.
\v 17 Bunların hepsi Yahuda Kralı Yotam'ın ve İsrael Kralı Yarovam'ın günlerinde soy kütüklerine göre sayıldı.
\p 
\v 18 Ruvenoğulları, Gadlılar ve Manaşşe'nin yarım oymağı, yiğit adamlardan, kalkan ve kılıç taşıyabilen, yay ile ok atabilen ve becerikli savaşa çıkabilen kırk dört bin yedi yüz altmış kişiydi.
\v 19 Hagrilerle, Yetur, Nafiş ve Nodav'la savaştılar.
\v 20 Onlara karşı yardım gördüler ve Hagriler ve onlarla birlikte olanların hepsi onların eline teslim edildi; çünkü savaşta Tanrı'ya feryat ettiler ve O da onlara yanıt verdi, çünkü O'na güvenmişlerdi.
\v 21 Onların hayvanlarını alıp götürdüler: Develerinden elli bin, koyunlarından iki yüz elli bin, eşeklerinden iki bin, adamlarından da yüz bin.
\v 22 Çünkü savaş Tanrı'dan olduğu için düşüp ölen çok oldu. Sürgüne dek onların yerinde yaşadılar.
\p 
\v 23 Manaşşe'nin yarım oymağı çocukları ülkede yaşadılar. Başan'dan Baal Hermon, Senir ve Hermon Dağı'na kadar çoğaldılar.
\v 24 Ataları evlerinin başları şunlardı: Efer, Yişi, Eliel, Azriel, Yeremya, Hodavya ve Yahdiel. Bunlar cesur yiğitler, ünlü adamlardı, ataları evlerinin başlarıydı.
\v 25 Atalarının Tanrısı'na karşı suç işlediler ve Tanrı'nın önlerinden yok ettiği ülke halklarının ilâhları ardınca fahişelik ettiler.
\v 26 Böylece İsrael'in Tanrısı, Aşur Kralı Pul'un ve Aşur Kralı Tilgat Pilneser'in ruhunu harekete geçirdi ve Ruvenliler'i, Gadlılar'ı ve Manaşşe'nin yarım oymağını sürüp Halah'a, Habor'a, Hara'ya ve Gozan Irmağı'na götürdü; bugüne dek öyledir.
\c 6
\p 
\v 1 Levi'nin oğulları: Gerşon, Kehat ve Merari.
\v 2 Kohat'ın oğulları: Amram, Yitshar, Hevron ve Uzziel.
\v 3 Amram'ın oğulları: Aron, Moşe ve Miryam. Aron'un oğulları: Nadav, Avihu, Eleazar ve İtamar.
\v 4 Eleazar, Pinehas'ın babası oldu. Pinehas, Abişua'nın babası oldu.
\v 5 Avişua, Bukki'nin babası oldu. Bukki, Uzzi'nin babası oldu.
\v 6 Uzzi, Zerahya'nın babası oldu. Zerahya, Merayot'un babası oldu.
\v 7 Merayot, Amarya'nın babası oldu. Amarya, Ahituv'un babası oldu.
\v 8 Ahituv, Sadok'un babası oldu. Sadok, Ahimaats'ın babası oldu.
\v 9 Ahimaats, Azarya'nın babası oldu. Azarya, Yohanan'ın babası oldu.
\v 10 Yohanan, Solomon'un Yeruşalem'de yaptırdığı evde kâhinlik görevini yürüten Azarya'nın babası oldu.
\v 11 Azarya, Amarya'nın babası oldu. Amarya, Ahituv'un babası oldu.
\v 12 Ahituv, Sadok'un babası oldu. Sadok, Şallum'un babası oldu.
\v 13 Şallum, Hilkiya'nın babası oldu. Hilkiya, Azarya'nın babası oldu.
\v 14 Azarya, Seraya'nın babası oldu. Seraya, Yehotsadak'ın babası oldu.
\v 15 Yahve Nebukadnetsar'ın eliyle Yahuda ve Yeruşalem'i sürdüğü zaman, Yehotsadak sürgüne gitti.
\p 
\v 16 Levi'nin oğulları: Gerşom, Kehat ve Merari.
\v 17 Gerşom'un oğullarının adları şunlardır: Livni ve Şimei.
\v 18 Kohat'ın oğulları: Amram, Yitshar, Hevron ve Uzziel'di.
\v 19 Merari'nin oğulları: Mahli ve Muşi. Bunlar, ataları evlerine göre Levililer'in boylarıdır.
\v 20 Gerşom'dan: Onun oğlu Livni, onun oğlu Yahat, onun oğlu Zimmah,
\v 21 onun oğlu Yoah, onun oğlu İddo, onun oğlu Zerah ve onun oğlu Yeateray.
\v 22 Kohat'ın oğulları: Onun oğlu Amminadav, onun oğlu Korah, onun oğlu Assir,
\v 23 onun oğlu Elkana, onun oğlu Eviasaf, onun oğlu Assir,
\v 24 onun oğlu Tahat, onun oğlu Uriel, onun oğlu Uzziya ve onun oğlu Şaul.
\v 25 Elkana'nın oğulları: Amasay ve Ahimot.
\v 26 Elkana'ya gelince, Elkana'nın oğulları: Onun oğlu Sofay, onun oğlu Nahat,
\v 27 onun oğlu Eliav, onun oğlu Yeroham ve onun oğlu Elkana.
\v 28 Samuel'in oğulları: İlk oğlu Yoel, ikincisi Aviya.
\v 29 Merari'nin oğulları: Mahli, oğlu Livni, oğlu Şimei, oğlu Uzza,
\v 30 onun oğlu Şimea, onun oğlu Haggya, onun oğlu Asaya.
\p 
\v 31 Bunlar, David'in, Sandık oraya dinlenmeye geldikten sonra, Yahve'nin evinde ilahi söyleme hizmetine koyduğu kişilerdir.
\v 32 Solomon, Yeruşalem'de Yahve'nin evini bina edene kadar, Buluşma Çadırı meskeni önünde ilahi söyleyerek hizmet ettiler. Görevlerini sıralarına göre yerine getirdiler.
\v 33 Hizmet edenler ve oğulları şunlardır: Kohatoğulları'ndan: Samuel oğlu Yoel oğlu ilahi söyleyen Heman,
\v 34 Toah oğlu, Eliel oğlu, Yeroham oğlu, Elkana oğlu,
\v 35 Amasay oğlu Mahat oğlu Elkana oğlu Suf oğlu,
\v 36 Sefanya oğlu Azarya oğlu Yoel oğlu Elkana oğlu,
\v 37 Korah oğlu, Evyasaf oğlu, Assir oğlu, Tahat oğlu,
\v 38 İsrael oğlu, Levi oğlu, Kohat oğlu, Yitshar oğlu.
\v 39 Sağında duran onun kardeşi Asaf, Şimea oğlu, Berekya oğlu Asaf,
\v 40 Malkiya oğlu, Baaseya oğlu Mikael oğlu,
\v 41 Adaya oğlu, Serah oğlu Etni oğlu,
\v 42 Şimei oğlu, Zimma oğlu, Etan oğlu,
\v 43 Levi oğlu, Gerşom oğlu, Yahat
\v 44 Sol tarafta onların kardeşleri Merarioğulları: Malluk oğlu, Avdi oğlu, Kişi oğlu Etan,
\v 45 Hilkiya oğlu, Amatsya oğlu, Haşavya oğlu,
\v 46 Şemer oğlu, Bani oğlu, Amtsi oğlu,
\v 47 Levi oğlu, Merari oğlu, Muşi oğlu, Mahli oğlu.
\v 48 Tanrı Evi'nin çadırının bütün hizmeti için kardeşleri Levililer atandı.
\v 49 Ama Aron ve oğulları, Tanrı'nın hizmetkârı Moşe'nin buyurduğu her şeye göre, yakmalık sunu sunağında ve buhur sunağında, En Kutsal Yer'in bütün işleri için ve İsrael için kefaret etmek üzere sunular sundular.
\p 
\v 50 Aron'un oğulları şunlardır: Onun oğlu Eleazar, onun oğlu Pinehas, onun oğlu Avişua,
\v 51 onun oğlu Bukki, onun oğlu Uzzi, onun oğlu Zerahya,
\v 52 onun oğlu Merayot, onun oğlu Amarya, onun oğlu Ahituv,
\v 53 onun oğlu Sadok ve onun oğlu Ahimaats.
\v 54 Şimdi, sınırlarında ordugâhlarına göre meskenleri şunlardır: Kohatlılar'ın boylarından Aronoğulları'na (çünkü ilk kura onlarındı),
\v 55 Yahuda ülkesindeki Hevron'u ve çevresindeki otlakları onlara verdiler.
\v 56 Ancak kentin tarlalarını ve köylerini Yefunne oğlu Kalev'e verdiler.
\v 57 Aronoğulları'na sığınma kentlerini verdiler: Hevron, otlaklarıyla Livna, Yattir, Eştemoa, otlaklarıyla,
\v 58 Hilen otlaklarıyla, Devir otlaklarıyla,
\v 59 Aşan otlaklarıyla ve Beyt Şemeş otlaklarıyla;
\v 60 ve Benyamin oymağından, Giva otlaklarıyla, Allemet otlaklarıyla ve Anatot otlaklarıyla. Boylarına göre bütün kentleri on üç kentti.
\p 
\v 61 Kohatoğulları'nın geri kalanına, bu oymağın boylarından, yarım oymak, Manaşşe'nin yarısından, on kent kurayla verildi.
\v 62 Gerşomoğulları'na, boylarına göre, İssakar oymağından, Aşer oymağından, Naftali oymağından ve Başan'daki Manaşşe oymağından, on üç kent verildi.
\v 63 Merarioğulları'na, boylarına göre, Ruven oymağından, Gad oymağından ve Zevulun oymağından on iki kent kurayla verildi.
\v 64 İsrael'in çocukları, Levililer'e otlaklarıyla birlikte o kentleri verdiler.
\v 65 Yahuda'nın çocukları oymağından, Şimon'un çocukları oymağından, Benyamin'in çocukları oymağından adlarıyla anılan şu kentleri kura ile verdiler.
\p 
\v 66 Kohatoğulları'nın bazı oymaklarının Efraim oymağından sınır kentleri vardı.
\v 67 Onlara sığınma kentleri verildi: Efraim dağlık bölgesindeki Şekem ile otlaklarını ve Gezer ile otlaklarını,
\v 68 Yokmeam ile otlaklarını ve Beyt Horon ile otlaklarını,
\v 69 Ayalon ile otlaklarını ve Gat Rimmon ile otlaklarını;
\v 70 Manaşşe'nin yarım oymağından da Aner ile otlaklarını, Bileam ile otlaklarını, Kohatoğulları boyunun geri kalanına verdiler.
\p 
\v 71 Manaşşe yarım oymağının Gerşomoğulları'na, Başan'daki Golan ile otlaklarını, Aştarot ile otlaklarını;
\v 72 İssakar oymağından Kedeş ile otlaklarını, Daverat ile otlaklarını,
\v 73 Ramot ile otlaklarını, Anem ile otlaklarını;
\v 74 Aşer oymağından Maşal ile otlaklarını, Avdon ile otlaklarını,
\v 75 Hukok ile otlaklarını, Rehov ile otlaklarını;
\v 76 Naftali oymağından Galile'deki Kedeş ile otlaklarını, Hammon ile otlaklarını, Kiriatayim ile otlaklarını verdiler.
\p 
\v 77 Merarioğulları'na, Levililer'in geri kalanına, Zevulun oymağından, Rimmon ile otlaklarını ve Tabor ile otlaklarını,
\v 78 Yarden'in ötesinde, Yeriha'da, Yarden'in doğusunda, Ruven oymağından, çölde Betser ile otlaklarını, Yahtsa ile otlaklarını,
\v 79 Kedemot ile otlaklarını Mefaat ile otlaklarını,
\v 80 Gad oymağından, Gilad'da Ramot ile otlaklarını, Mahanaim ile otlaklarını,
\v 81 Heşbon ile otlaklarını, Yatser ile otlaklarını verdiler.
\c 7
\p 
\v 1 İssakaroğulları'ndan: Tola, Pua, Yaşuv ve Şimron, dört.
\v 2 Tolaoğulları: Uzzi, Refaya, Yeriel, Yahmay, İvsam ve Şemuel, ataları evlerinin başları, Tola'dan; kuşaklarından cesur yiğitler. David'in günlerinde onların sayıları yirmi iki bin altı yüzdü.
\v 3 Uzzi'nin oğlu: İzrahya. İzrahya'nın oğulları: Mikael, Ovadya, Yoel ve İşşiya, beş; hepsi de baş adamlardı.
\v 4 Onlarla birlikte, kuşaklarına göre, ataları evlerine göre, savaş için ordu birlikleri, otuz altı bin; çünkü çok karıları ve oğulları vardı.
\v 5 İssakar'ın bütün boyları arasında, soy kütüğüne göre sayılan cesur yiğitler, kardeşleri seksen yedi bindi.
\p 
\v 6 Benyamin'in oğulları: Bela, Beker ve Yediael, üç.
\v 7 Bela'nın oğulları: Etsvon, Uzzi, Uzziel, Yerimot ve İri, beş; atalar evlerinin başları, cesur yiğitler; ve soy kütüğüne göre yirmi iki bin otuz dört kişi sayıldı.
\v 8 Beker'in oğulları: Zemirah, Yoaş, Eliezer, Elyoenay, Omri, Yeremot, Aviya, Anatot ve Alemet. Bunların hepsi Beker'in oğullarıydı.
\v 9 Kuşaklarına göre soy kütüğüne göre, ataları evlerinin başları, cesur yiğitler, yirmi bin iki yüz kişi sayıldı.
\v 10 Yediael'in oğlu: Bilhan. Bilhan'ın oğulları: Yeuş, Benyamin, Ehud, Kenaana, Zetan, Tarşiş ve Ahişahar.
\v 11 Bütün bunlar, ataları evlerinin başlarına göre, Yediael'in oğullarıydı; savaşa gidebilecek kadar güçlü, cesur yiğitlerdi. On yedi bin iki yüz.
\v 12 Şuppim, Huppim, İr'in oğulları, Aher'in oğulları, Huşim.
\p 
\v 13 Naftali'nin oğulları: Yahziel, Guni, Yeser, Şallum ve Bilha'nın oğulları.
\p 
\v 14 Manaşşe'nin oğulları: Aramlı cariyesi Asriel'i doğurdu. O, Gilad'ın babası Makir'i doğurdu.
\v 15 Makir, Huppim ve Şuppim'den bir karı aldı. Kız kardeşinin adı Maaka'ydı. İkincisinin adı Selofhad'dı. Selofhad'ın da kızları oldu.
\v 16 Makir'in karısı Maaka bir oğul doğurdu ve adını Pereş koydu. Kardeşinin adı Şereş'ti. Onun oğulları da Ulam ve Rakem'diler.
\v 17 Ulam'ın oğulları: Bedan. Bunlar Manaşşe'nin oğlu Makir'in oğlu Gilad'ın oğullarıydı.
\v 18 Kız kardeşi Hammoleket, İşhod'u, Aviezer'i ve Mahla'yı doğurdu.
\v 19 Şemida'nın oğulları: Ahian, Şekem, Likhi ve Aniam idi.
\p 
\v 20 Efraim'in oğulları: Şutelah, onun oğlu Bered, onun oğlu Tahat, onun oğlu Eleada, onun oğlu Tahat,
\v 21 onun oğlu Zavad, onun oğlu Şutelah, Ezer ve Elead. Bunları ülkede doğmuş olan Gatlılar öldürdüler, çünkü onların hayvanlarını alıp götürmek için inmişlerdi.
\v 22 Babaları Efraim günlerce yas tuttu ve kardeşleri onu avutmak için geldiler.
\v 23 Karısının yanına girdi, kadın gebe kaldı ve bir oğul doğurdu ve babası evinde sıkıntı olduğu için adını Beria\f + \fr 7:23 \ft “Beria” kelimesi İbranice’deki “talihsizlik” kelimesine benzemektedir.\f* koydu.
\v 24 Kızı, Aşağı ve Yukarı Beyt Horon'u ve Uzzen Şerah'ı kuran Şeera'ydı.
\v 25 Refah onun oğluydu ve Reşef, onun oğlu Telah, onun oğlu Tahan,
\v 26 Onun oğlu Ladan, onun oğlu Ammihud, onun oğlu Elişama,
\v 27 onun oğlu Nun ve onun oğlu Yeşu'ydu.
\v 28 Mülkleri ve yerleşim yerleri Beytel ve kasabaları, doğuda Naaran, batıda Gezer ve kasabaları, Şekem ve kasabaları, Azza ve kasabalarına kadar;
\v 29 Manaşşeoğulları'nın sınırları yanında ise Beyt Şean ve kasabaları, Taanak ve kasabaları, Megiddo ve kasabaları, Dor ve kasabalarıydı. İsrael oğlu Yosef'in çocukları buralarda yaşıyordu.
\p 
\v 30 Aşer'in oğulları: İmna, Yişva, Yişvi ve Beria. Serah kız kardeşleriydi.
\v 31 Beria’nın oğulları: Hever ve Birzait'in babası olan Malkiel.
\v 32 Hever, Yaflet’in, Şomer’in, Hotam’ın ve onların kız kardeşleri Şua’nın babası oldu.
\v 33 Yaflet’in oğulları: Pasak, Bimhal ve Aşvat. Bunlar Yaflet’in oğullarıydı.
\v 34 Şemer’in oğulları: Ahi, Rohga, Yehubba ve Aram.
\v 35 Kardeşi Helem’in oğulları: Sofah, İmna, Şeleş ve Amal.
\v 36 Sofah’ın oğulları: Suah, Harnefer, Şual, Beri, İmra,
\v 37 Bezer, Hod, Şamma, Şilshah, İtran ve Beera.
\v 38 Yeter’in oğulları: Yefunne, Pispa ve Ara.
\v 39 Ulla’nın oğulları: Arah, Hanniel ve Ritsya.
\v 40 Bunların hepsi Aşer'in çocuklarıydı, ata evlerinin başlarıydı, cesur seçkin yiğitlerdi, beylerin başlarıydılar. Savaşta hizmet için soy kütüğüne göre sayılanların sayısı yirmi altı bin kişiydi.
\c 8
\p 
\v 1 Benyamin, ilk oğlu Bela'nın, ikinci oğlu Aşvel'in, üçüncü oğlu Aharah'ın,
\v 2 dördüncü oğlu Noha'nın ve beşinci oğlu Rafa'nın babası oldu.
\v 3 Bela'nın oğulları vardı: Addar, Gera, Avihud,
\v 4 Avişua, Naaman, Ahoah,
\v 5 Gera, Şefufan ve Huram.
\v 6 Bunlar Ehud'un oğullarıydı. Bunlar, Manahat'a sürgün edilen Geva sakinlerinin ataları evlerinin başlarıydı:
\v 7 Naaman, Ahiya ve Gera, onları sürgün eden buydu ve Uzza ile Ahihud'un babası oldu.
\p 
\v 8 Şaharayim, onları gönderdikten sonra Moav kırlarında çocuklar babası oldu. Karıları Huşim ve Baara'ydı.
\v 9 Karısı Hodeş'ten Yovav'ın, Sîvya'nın, Meşa'nın, Malkam'ın,
\v 10 Yeuts'un, Şakya'nın ve Mirma'nın babası oldu. Bunlar onun oğullarıydı, atalar evlerinin başlarıydı.
\v 11 Huşim'den Avituv ve Elpaal'ın babası oldu.
\v 12 Elpaal'ın oğulları: Ever, Mişam, Ono ve Lod ile kasabalarını kuran Şemed;
\v 13 Ayalon sakinlerinin ataları evlerinin başları olan ve Gat sakinlerini kaçıran Beria ve Şema;
\v 14 Ahio, Şaşak, Yeremot,
\v 15 Zevadya, Arad, Eder,
\v 16 Mikael, İşpa, Yoha, Beria'nın oğulları,
\v 17 Zevadya, Meşullam, Hizki, Hever,
\v 18 İşmeray, İzliya, Yovav, Elpaal'ın oğulları,
\v 19 Yakim, Zikri, Zavdi,
\v 20 Elienay, Silletay, Eliel,
\v 21 Adaya, Beraya, Şimrat, Şimei'nin oğulları,
\v 22 İşpan, Ever, Eliel,
\v 23 Avdon, Zikri, Hanan,
\v 24 Hananya, Elam, Antotiya,
\v 25 İfdeya, Penuel, Şaşak'ın oğulları,
\v 26 Şamşeray, Şehariya, Atalya,
\v 27 Yaareşiya, Eliya, Zikri ve Yeroham.
\v 28 Bunlar kuşaklar boyunca atalar evlerinin başları, önderlerdi. Bunlar Yeruşalem'de yaşadılar.
\p 
\v 29 Karısının adı Maaka olan Givon'un babası, Givon'da yaşadı.
\v 30 İlk oğlu Avdon ile, Sur, Kiş, Baal, Nadav,
\v 31 Gedor, Ahio, Zeker,
\v 32 ve Şimeah'ın babası olan Miklot da orada yaşadı. Bunlar da aileleriyle birlikte Yeruşalem'de, akrabalarının yanında yaşadılar.
\v 33 Ner, Kiş'in babası oldu. Kiş, Saul'un babası oldu. Saul, Yonatan'ın, Malkişua'nın, Avinadav'ın ve Eşvaal'ın babası oldu.
\v 34 Yonatan'ın oğlu Meriv Baal'dı. Meriv Baal, Mika'nın babası oldu.
\v 35 Mika'nın oğulları: Piton, Melek, Tarea ve Ahaz.
\v 36 Ahaz, Yehoaddah'ın babası oldu. Yehoaddah, Alemet'in, Azmavet'in ve Zimri'nin babası oldu. Zimri, Motsa'nın babası oldu.
\v 37 Motsa, Binea'nın babası oldu. Rafa onun oğluydu, Eleasa onun oğluydu ve Atsel de onun oğluydu.
\v 38 Atsel'in altı oğlu vardı. Adları şunlardır: Atsrikam, Bokeru, İşmael, Şearya, Ovadya ve Hanan. Bunların hepsi Atsel'in oğullarıydı.
\v 39 Kardeşi Esek'in oğulları: İlk oğlu Ulam, ikincisi Yeuş ve üçüncüsü Elifelet.
\v 40 Ulam'ın oğulları cesur, okçu yiğitlerdi ve oğulları ve torunları çoktu, yüz elli. Bunların hepsi Benyamin'in oğullarındandı.
\c 9
\p 
\v 1 Böylece bütün İsrael soy kütüklerine göre sayıldılar; ve işte,\f + \fr 9:1 \ft “İşte”, “הִנֵּה” kelimesinden gelir ve bakmak, farkına varmak, gözlemlemek, görmek veya dik dik bakmak anlamına gelir. Genellikle bir ünlem olarak kullanılır.\f* bunlar İsrael krallarının kitabında yazılıdır. Yahuda, itaatsizliği yüzünden Babil'e sürgün edildi.
\v 2 Kentlerindeki mülklerinde oturan ilk sakinler İsrael, kâhinler, Levililer ve tapınak görevlileriydi.
\v 3 Yeruşalem'de Yahuda'nın çocuklarından, Benyamin'in çocuklarından, Efraim'in ve Manaşşe'nin çocuklarından şunlar oturuyordu:
\v 4 Yahudanın oğlu Peretsin çocuklarından: Bani'nin oğlu, İmri'nin oğlu, Omri'nin oğlu, Ammihud'un oğlu Utay.
\v 5 Şilolular'dan: İlk oğlu Asaya ve oğulları.
\v 6 Zeraoğulları'ndan: Yeuel ve kardeşleri, altı yüz doksan.
\v 7 Benyaminoğulları'ndan: Hassenua oğlu Hodavya oğlu Meşullam oğlu Sallu;
\v 8 ve Yeroham'ın oğlu İvneya, ve Mikrinin oğlu, Uzzi oğlu Ela, ve İbniya'nın oğlu, Reuelin oğlu, Şefatya oğlu Meşullam;
\v 9 ve onların kardeşleri, soylarına göre, dokuz yüz elli altı. Bunların hepsi ataları evlerine göre atalar evlerinin başlarıydı.
\p 
\v 10 Kâhinlerden: Yedaya, Yehoyariv, Yakin,
\v 11 Tanrı evinin yöneticisi Ahitiuv'un oğlu, Merayot'un oğlu, Sadok'un oğlu, Meşullam'ın oğlu, Hilkiya'nın oğlu Azarya;
\v 12 ve Malkiya'nın oğlu, Paşhur'un oğlu, Yeroham'ın oğlu Adaya, ve İmmer'in oğlu, Meşillemit'in oğlu, Meşullam'ın oğlu, Yahzera'nın oğlu, Adiel'in oğlu Maasay;
\v 13 ve atalar evlerinin başları olan kardeşleri, bin yedi yüz altmış; Tanrı evinin hizmetinde çok yetenekli adamlardı.
\p 
\v 14 Levililer'den: Merarioğulları'ndan Haşavya oğlu, Azrikam oğlu, Haşşuv oğlu Şemaya;
\v 15 Bakbakkar, Hereş, Galal ve Asaf oğlu Zikri oğlu Mika oğlu Mattanya;
\v 16 Yedutun oğlu, Galal oğlu Şemaya oğlu, Ovadya; ve Netofalılar'ın köylerinde yaşayan Elkana oğlu, Asa oğlu Berekya.
\p 
\v 17 Kapı bekçileri: Şallum, Akkuv, Talmon, Ahiman ve kardeşleri (Şallum baştı).
\v 18 Daha önce doğu tarafındaki kral kapısında görev yapmışlardı. Levi'nin çocuklarının ordugâh kapı bekçileriydi bunlar.
\v 19 Şallum, Kore'nin oğlu, Evyasaf'ın oğlu, Korah'ın oğluydu. Atalar evinden olan kardeşleri, Korahlılar, hizmet işi üzerinde, çadır eşiklerinin bekçileriydiler. Ataları, Yahve'nin ordugâhı üzerinde, girilecek yerin bekçileri olmuşlardı.
\v 20 Eleazar'ın oğlu Pinehas eskiden onların başındaydı ve Yahve onunla birlikteydi.
\v 21 Meşelemya'nın oğlu Zekariya, Buluşma Çadırı'nın kapısının kapı bekçisiydi.
\v 22 Eşiklerde kapı bekçisi olarak seçilenlerin hepsi iki yüz on iki kişiydi. Bunlar, köylerinde soy kütüğüne göre yazılmıştı. David ve Gören Samuel, onları görevlerine atamışlardı.
\v 23 Böylece kendileri ve çocukları, Yahve'nin evinin kapılarını, çadır evini muhafız olarak bakıyorlardı.
\v 24 Dört tarafta, doğuya, batıya, kuzeye ve güneye doğru kapıcılar vardı.
\v 25 Köylerindeki kardeşleri, zaman zaman onlarla birlikte olmak için her yedi günde bir gelirlerdi.
\v 26 Çünkü Levili olan dört baş kapı bekçisi, görevdeydiler ve Tanrı evindeki odaların ve hazinelerin başındaydı.
\v 27 Tanrı evinin çevresinde kalırlardı, çünkü bu onların göreviydi ve onu her sabah açmak onların göreviydi.
\p 
\v 28 Bazıları hizmet kaplarından sorumluydu, çünkü bunlar sayıyla içeri getirilirdi ve bunlar sayıyla dışarı çıkarılırdı.
\v 29 Onlardan bazıları da eşyaların ve kutsal yerin bütün kaplarının, ince unun, şarabın, yağın, günlük ve baharatların başına atandı.
\p 
\v 30 Kâhin oğullarından bazıları baharatların karıştırılmasını hazırlardı.
\v 31 Korahlı Şallum'un ilk oğlu olan Levililer'den Mattitya, tava işleri üzerinde görevliydi.
\v 32 Kohatoğulları'ndan olan kardeşlerinden bazıları, her Şabat Günü sergi ekmeği hazırlamak için görevliydi.
\p 
\v 33 Bunlar, Levililer'in ata evlerinin başları olan ezgi söyleyenlerdi. Odalarda yaşarlardı ve başka bir hizmetten muaf olurlardı. Çünkü gece gündüz işleriyle meşguldüler.
\v 34 Bunlar, kuşaklar boyunca Levililer'in ata evlerinin başları, önderlerdi. Yeruşalem'de yaşarlardı.
\p 
\v 35 Karısının adı Maaka olan Givon'un babası Yeiel, Givon'da yaşardı.
\v 36 İlk oğlu Avdon'du; sonra Sur, Kiş, Baal, Ner, Nadav,
\v 37 Gedor, Ahio, Zekariya ve Miklot.
\v 38 Miklot, Şimeam'ın babası oldu. Onlar da akrabalarının yanında, Yeruşalem'de onlara yakın yaşıyorlardı.
\v 39 Ner, Kiş'in babası oldu. Kiş, Saul'un babası oldu. Saul, Yonatan, Malkişua, Avinadav ve Eşbaal'ın babası oldu.
\v 40 Yonatan'ın oğlu Merib Baal'dı. Merib Baal, Mika'nın babası oldu.
\v 41 Mika'nın oğulları: Piton, Melek, Tahrea ve Ahaz.
\v 42 Ahaz, Yarah'ın babası oldu. Yarah, Alemet, Azmavet ve Zimri'nin babası oldu. Zimri, Moza'nın babası oldu.
\v 43 Motsa, Binea'nın babası oldu. Onun oğlu Refaya, onun oğlu Eleasah ve onun oğlu Atsel.
\v 44 Atsel'in altı oğlu vardı. Bunların adları Atsrikam, Bokeru, İşmael, Şearya, Ovadya ve Hanan'dı. Bunlar Atsel'in oğullarıydı.
\c 10
\p 
\v 1 Filistliler İsrael'e karşı savaştılar. İsraelliler Filistliler'in önünden kaçtılar ve Gilboa Dağı'nda düşüp öldüler.
\v 2 Filistliler Saul'un ve oğullarının ardından sertçe geldiler. Filistliler Saul'un oğulları Yonatan'ı, Avinadav'ı ve Malkişua'yı öldürdüler.
\v 3 Saul'a karşı savaş sertleşti. Okçular onu bastırdı. Okçular yüzünden sıkıntıya girdi.
\v 4 Saul silahını taşıyan adama, “Kılıcını çek de onu bana sapla, yoksa sünnetsizler gelip beni taciz edebilirler” dedi.
\p Ama silahını taşıyan adamı yapmak istemedi, çünkü çok korkmuştu. Bunun üzerine Saul kılıcını alıp onun üzerine düştü.
\v 5 Silahını taşıyan adam Saul'un öldüğünü görünce, kendisi de kılıcının üzerine düşüp öldü.
\v 6 Böylece Saul üç oğluyla birlikte öldü, bütün evi de birlikte öldü.
\v 7 Vadide bulunan bütün İsraelliler, onların kaçtıklarını ve Saul'un ve oğullarının öldüklerini görünce, kentlerini terk edip kaçtılar; Filistliler de gelip içlerinde yaşamaya başladılar.
\p 
\v 8 Ertesi gün, Filistliler öldürülenleri soymaya geldiklerinde, Saul'u ve oğullarını Gilboa Dağı'nda düşmüş buldular.
\v 9 Onu soyup başını ve zırhını aldılar, sonra Filist diyarının her yanına gönderip putlarına ve halka haber verdiler.
\v 10 Zırhını kendi ilâhlarının evine koydular ve başını Dagon'un evinin içinde çaktılar.
\v 11 Bütün Yaveş Gilad, Filistliler'in Saul'a yaptıklarını duyunca,
\v 12 bütün yiğitler kalkıp Saul'un ve oğullarının cesetlerini aldılar ve Yaveş'e getirdiler, kemiklerini Yaveş'teki meşe ağacının altına gömdüler ve yedi gün oruç tuttular.
\p 
\v 13 Böylece Saul, Yahve'ye karşı işlediği suçtan, Yahve'nin sözünü tutmadığı için ve Yahve'ye sormayıp ruh çağıranlardan öğüt almak için sorduğu için,
\v 14 Yahve onu öldürdü ve krallığı Yişay oğlu David'e devretti.
\c 11
\p 
\v 1 Sonra bütün İsrael Hevron'da David'in yanına toplanıp dediler: “İşte, biz senin kemiğin ve senin etiniz.
\v 2 Geçmişte, Saul kralken, İsrael'i dışarı çıkaran ve içeri sokan sendin. Tanrın Yahve sana, 'Halkım İsrael'in çobanı sen olacaksın ve halkım İsrael'in üzerine sen hükümdar olacaksın' dedi.”
\p 
\v 3 Böylece İsrael'in bütün ihtiyarları Hevron'daki kralın yanına geldiler; David de Hevron'da Yahve'nin önünde onlarla bir antlaşma yaptı. Yahve'nin Samuel aracılığıyla olan sözüne göre David'i İsrael üzerine kral olarak meshettiler.
\p 
\v 4 David ve bütün İsrael Yeruşalem'e (Yevus olarak da bilinir) gittiler; ve ülkenin sakinleri olan Yevuslular oradaydılar.
\v 5 Yevuslular David'e, “Buraya girmeyeceksin!” dediler. Buna rağmen David Siyon Kalesi'ni aldı. Orası David'in kentidir.
\v 6 David, “Yevuslular'ı önce vuran, baş ve komutan olacak” demişti. Seruya oğlu Yoav önce çıktı ve baş oldu.
\v 7 David kalede yaşıyordu; bu yüzden ona David kenti dediler.
\v 8 Kenti Millo'dan başlayarak çevresine kadar çepeçevre bina etti; Yoav da kentin geri kalanını onardı.
\v 9 David gittikçe büyüyordu; çünkü Ordular Yahvesi onunla birlikteydi.
\p 
\v 10 Yahve'nin İsrael için olan sözüne göre, David'i kral yapmak için kendisiyle ve bütün İsrael'le birlikte onun krallığında güç göstermiş olan David'in yiğitlerinin başları şunlardır;
\p 
\v 11 David'in yiğitlerinin sayısı şudur: Otuzlar'ın başı Hakmonit oğlu Yaşoveam; mızrağını üç yüze karşı kaldırdı ve onları bir kerede öldürdü.
\v 12 Ondan sonra, üç yiğitten biri olan Ahohlu Dodo oğlu Eleazar.
\v 13 O David'le Pasdammim'deydi. Filistliler orada savaşmak için toplanmışlardı. Orada arpa dolu bir tarla vardı. Halk Filistliler'in önünden kaçtı.
\v 14 Onlar tarlanın ortasında durup onu savundular ve Filistliler'i öldürdüler. Yahve de onları büyük bir zaferle kurtardı.
\p 
\v 15 Baş Otuzlar'dan üçü kayaya, David'in yanına, Adullam Mağarası'na indiler. Filistliler'in ordusu Refaim Vadisi'nde ordugâh kurmuştu.
\v 16 David o sırada kaledeydi. Filistliler'in birliği de o sırada Beytlehem'deydi.
\v 17 David özlemle, “Keşke biri bana Beytlehem'deki kapının yanındaki kuyudan su verse!” dedi.
\p 
\v 18 Üçlü Filist ordusunu yarıp, Beytlehem'in kapısındaki kuyudan su çekip aldılar ve David'e getirdiler; ama David içmek istemedi, onu Yahve'ye döktü,
\v 19 Ve şöyle dedi, “Tanrım, bunu yapmaktan beni alıkoysun! Canlarını tehlikeye koyan bu adamların kanını mı içeyim?” Çünkü onu getirmek için canlarını tehlikeye attılar. Bu yüzden içmek istemedi. Bu şeyleri üç yiğit yaptı.
\p 
\v 20 Üçler'in başı Yoav'ın kardeşi Avişay'dı; çünkü mızrağını üç yüze doğru kaldırıp onları öldürdü ve Üçler arasında üne sahipti.
\v 21 Üçler'in ikisinden daha saygındı ve onların başı oldu; ancak Üçler'e dahil değildi.
\p 
\v 22 Yehoyada oğlu Benaya, Kabseel'den cesur bir adamın oğluydu. O, kudretli işler yapmıştı. Moavlı Ariel'in iki oğlunu öldürdü. Karlı bir günde inip çukurun ortasında bir aslanı da öldürdü.
\v 23 İri yapılı, beş arşın\f + \fr 11:23 \ft Bir arşın, bir insanın kolundaki orta parmağın ucundan dirseğe kadar olan uzunluktur veya yaklaşık 18 inç veya 46 santimetredir. Bu nedenle bu Mısırlı yaklaşık 7 fit 6 inç veya 2,28 metre boyundaydı.\f* boyunda bir Mısırlı'yı öldürdü. Mısırlı'nın elinde dokumacı sırığı gibi bir mızrak vardı. Bir değnekle ona doğru indi, mızrağı Mısırlı'nın elinden kaptı ve onu kendi mızrağıyla öldürdü.
\v 24 Yehoyada oğlu Benaya bu şeyleri yaptı ve üç yiğit arasında ünü vardı.
\v 25 İşte, Otuzlar'dan daha saygındı, ama Üçler'e erişemedi; David de onu muhafızlarının başına koydu.
\p 
\v 26 Orduların yiğitleri: Yoav'ın kardeşi Asahel, Beytlehemli Dodo oğlu Elhanan,
\v 27 Harorlu Şammot, Pelonlu Heles,
\v 28 Tekolu İkkeş oğlu İra, Anatotlu Aviezer,
\v 29 Huşatlı Sivvekay, Ahohlu İlay,
\v 30 Netofalı Maharay, Netofalı Baana oğlu Heled,
\v 31 Benyamin'in çocuklarından Giva'lı Rivay oğlu İtay, Piratonlu Benaya,
\v 32 Gaaş derelerinden Huray, Arbatlı Abiel,
\v 33 Baharumlu Atsmavet, Şaalvonlu Eliahva,
\v 34 Gizonlu Haşem'in oğulları, Hararlı Şagee oğlu Yonatan,
\v 35 Hararlı Sakar oğlu Ahiam, Ur oğlu Elifal,
\v 36 Mekeralı Hefer, Pelonlu Ahiya,
\v 37 Karmelli Hetsro, Ezbay oğlu Naarai,
\v 38 Natan'ın kardeşi Yoel, Hagri oğlu Mivhar,
\v 39 Ammonlu Selek, Seruya oğlu Yoav'ın silah taşıyıcısı Berotlu Naharai,
\v 40 İtritli İra, İtritli Garev,
\v 41 Hititli Uriya, Ahlay oğlu Savad,
\v 42 Ruvenliler'in başlarından Ruvenli Şitsa oğlu Adina ve onunla birlikte otuz kişi,
\v 43 Maaka oğlu Hanan, Mitnitli Yoşafat,
\v 44 Aşteralı Uzziya, Aroerli Hotam'ın oğulları Şama ve Yeiel,
\v 45 Şimri oğlu Yediael, kardeşi Tizli Yoha,
\v 46 Mahavlı Eliel, Elnaam'ın oğulları Yerivay ve Yoşavya, Moavlı İtma,
\v 47 Eliel, Oved ve Metsobalı Yaasiel.
\c 12
\p 
\v 1 Bunlar, Kiş oğlu Saul'dan kaçmakta olan David'in yanına, Ziklag'a gelenlerdi. Onlar savaşta ona yardımcı olan yiğitler arasındaydılar.
\v 2 Yaylarla silahlanmışlardı ve hem sağ ellerini hem de sol ellerini kullanarak taş atabiliyor ve yaydan ok atabiliyorlardı. Bunlar Benyamin oymağından Saul'un akrabalarıydı.
\v 3 Baş Ahiezer'di, sonra Givalı Şemaah'ın oğulları Yoaş; Azmavet'in oğulları Yeziel ve Pelet; Beraka; Anatotlu Yehu;
\v 4 Otuzlar'dan bir yiğit olup ve Otuzlar'ın önderi olan Givonlu İşmaya; Yeremya; Yahaziel; Yohanan; Gederalı Yozavad;
\v 5 Eluzay; Yerimot; Bealya; Şemarya; Haruplu Şefatya;
\v 6 Korahlılar'dan Elkana, İşşiya, Azarel, Yoezer ve Yaşoveam;
\v 7 Gedorlu Yeroham'ın oğulları Yoelah ve Zevadya.
\p 
\v 8 Çöldeki kalede David'e katılan bazı Gadlılar, savaşa hazır, kalkan ve mızrak kullanabilen cesur yiğitlerdi, yüzleri aslan yüzleri gibiydi ve dağlardaki ceylanlar kadar hızlıydılar:
\v 9 Baş Ezer, ikincisi Ovadya, üçüncüsü Eliav,
\v 10 Dördüncüsü Mişmanna, beşincisi Yeremya,
\v 11 Altıncısı Attay, yedincisi Eliel,
\v 12 Sekizinci Yohanan, dokuzuncusu Elzavad,
\v 13 Onuncusu Yeremya ve on birincisi Makvannay'dı.
\v 14 Gadoğulları'ndan bunlar ordu komutanlarıydı. En küçüğü yüz adama, en büyüğü bin adama denkti.
\v 15 Bunlar, Yarden'in bütün kıyılarının taştığı birinci ayda ondan geçenlerdir; ve vadilerde oturanların hepsini hem doğuya hem de batıya doğru kaçırdılar.
\p 
\v 16 Benyamin'in ve Yahuda'nın çocuklarından bazıları David'in yanına, kaleye geldiler.
\v 17 David onları karşılamak için çıkıp onlara şöyle yanıt verdi: “Eğer bana yardım etmek için esenlikle bana geldiyseniz, yüreğim sizinle bir olacaktır; ama ellerimde hiçbir haksızık yokken, eğer beni düşmanlarımın eline vermek için geldiyseniz, atalarımızın Tanrısı bunu görsün ve onu azarlasın.”
\v 18 O zaman Ruh Otuzlar'ın başı olan Amasay'ın üzerine geldi ve dedi: “Biz seniniz, ey David, senin tarafındayız, ey Yişay oğlu. Sana esenlik, esenlik olsun, sana yardım edenlere de esenlik olsun; çünkü Tanrın sana yardım ediyor.” Sonra David onları kabul etti ve onları çete başları yaptı.
\p 
\v 19 Manaşşe'den bazıları da David'in Filistliler'le birlikte Saul'a karşı savaşmak için geldiğinde David'e katıldılar, ama Filistliler'e yardım etmediler. Çünkü Filistliler'in beyleri, “Efendisi Saul'un yanına geçip başımızı tehlikeye sokacak” diyerek danıştıktan sonra onu gönderdiler.
\p 
\v 20 Ziklag'a gittiğinde, Manaşşe'den binlerin başları olan Adna, Yozavad, Yediael, Mikael, Yozavad, Elihu ve Silletay, Manaşşe'den ona katıldılar.
\v 21 Akıncılara karşı David'e yardım ettiler. Çünkü hepsi de cesur yiğitlerdi, ordu komutanlarıydı.
\v 22 Çünkü her gün David'e yardım etmek için adamlar geliyordu. Ta ki, Tanrı'nın ordusu gibi büyük bir ordu oluncaya dek.
\p 
\v 23 Yahve'nin sözüne göre, Saul'un krallığını David'e döndürmek için onun yanına, Hevron'a, gelen savaş için silahlanmış olanların başlarının sayıları şunlardır.
\v 24 Yahuda'nın çocuklarından kalkan ve mızrak taşıyanlar, savaş için silahlanmış altı bin sekiz yüz kişi.
\v 25 Şimon'un çocuklarından, savaş için cesur yiğitler, yedi bin yüz kişi.
\v 26 Levi'nin çocuklarından: Dört bin altı yüz kişi.
\v 27 Aron'un ev halkının önderi Yehoyada idi; onunla birlikte üç bin yedi yüz kişi.
\v 28 Cesur yiğit bir genç olan Sadok ve atası evinden yirmi iki komutan.
\v 29 Benyamin'in çocuklarından, Saul'un akrabaları: Üç bin, çünkü o zamana dek onların çoğu Saul'un evine bağlı kalmıştı.
\v 30 Efraim'in çocuklarından: Yirmi bin sekiz yüz, cesur yiğitler, ataları evlerinde ünlü adamlar.
\v 31 Manaşşe'nin yarım oymağından: David'i kral yapmak için gelip adlarıyla anılan on sekiz bin kişi.
\v 32 İssakar'ın çocuklarından, İsrael'in ne yapması gerektiğini bilmek için zamanların anlayışına sahip olanlar, onların başları iki yüz kişiydi; bütün kardeşleri de onların buyruğundaydı.
\v 33 Zevulun'dan, orduyla çıkabilen, her türlü savaş aletiyle savaş düzeni alabilen: Buyruk verilebilir ve çift yürekli olmayan elli bin kişi.
\v 34 Naftali'den: Bin komutan ve onlarla birlikte kalkan ve mızrakla otuz yedi bin kişi.
\v 35 Danlılar'dan, savaş düzeni alabilen: Yirmi sekiz bin altı yüz kişi.
\v 36 Aşer'den, orduyla çıkabilen, savaş düzeni alabilen: Kırk bin kişi.
\v 37 Yarden'in öte yakasında, Ruvenliler'den, Gadlılar'dan ve Manaşşe'nin yarım oymağından, savaş için her türlü savaş aletiyle: Yüz yirmi bin kişi.
\p 
\v 38 Bunların hepsi savaş düzenini bilen savaşçılardı ve David'i bütün İsrael'in üzerine kral yapmak için Hevron'a tam bir yürekle geldiler; İsrael'in geri kalanı da David'i kral yapmak için tek yürekti.
\v 39 Onlar David'le birlikte üç gün orada kaldılar, yiyip içtiler; çünkü kardeşleri onlara erzak sağlamıştı.
\v 40 İssakar, Zevulun ve Naftali'ye varıncaya kadar onlara yakın olanlar da, eşekler, develer, katırlar ve öküzler üzerinde ekmek getirdiler; un, basılmış incir, kuru üzüm salkımları, şarap, yağ, bol miktarda sığır ve koyun getirdiler; çünkü İsrael'de sevinç vardı.
\c 13
\p 
\v 1 David binlerin, yüzlerin başlarıyla ve her önderle danıştı.
\v 2 David bütün İsrael topluluğuna şöyle dedi: “Eğer size iyi görünüyorsa ve bu Tanrımız Yahve'den ise, İsrael diyarında kalan kardeşlerimize, otlakları olan kentlerinde kâhinlerle Levililer'in bulunduğu her yere haber gönderelim de yanımıza toplansınlar.
\v 3 Tanrımız'ın Sandığı'nı da geri getirelim. Çünkü Saul zamanında onu aramadık.”
\p 
\v 4 Bütün topluluk, öyle yaparız dediler; çünkü bütün halkın gözünde bu şey doğru idi.
\v 5 Bunun üzerine David bütün İsrael halkını, Mısır'ın Şihor Irmağı'ndan Hamat'ın girişine kadar, Tanrı'nın Sandığı'nı Kiryat Yearim'den getirmek üzere topladı.
\p 
\v 6 David, bütün İsrael'le birlikte, Tanrı Yahve'nin, Keruvlar'ın üstünde oturan ve Adıyla anılan sandığını, Baala'dan, Yahuda'nın Kiryat Yearim'inden çıkarmak için oraya çıktı.
\v 7 Tanrı'nın Sandığı'nı yeni bir arabaya bindirip Avinadav'ın evinden çıkardılar; Uzza ve Ahio da arabayı sürüyordu.
\v 8 David ve bütün İsrael, Tanrı'nın önünde bütün güçleriyle, ezgilerle, çenklerle, telli çalgılarla, teflerle, zillerle ve borularla oynuyorlardı.
\p 
\v 9 Kidon'un harman yerine geldiklerinde, Uzza elini uzatıp sandığı tuttu; çünkü öküzler tökezlemişti.
\v 10 Yahve'nin öfkesi Uzza'ya karşı alevlendi ve elini sandığa koyduğu için onu vurdu; ve orada Tanrı'nın önünde öldü.
\v 11 David hoşnut değildi, çünkü Yahve Uzza'ya karşı öfkelenmişti. O, o yere Perez Uzza dedi; bugüne dek öyle denir.
\v 12 David o gün Tanrı'dan korkup, “Tanrı'nın Sandığı'nı nasıl eve yanıma getireyim?” dedi.
\v 13 Bunun üzerine David sandığı kendisiyle birlikte David Kenti'ne götürmedi, ama onu Gadlı Oved Edom'un evine saptırıp götürdü.
\v 14 Tanrı'nın Sandığı Oved Edom'un ailesiyle birlikte evinde üç ay kaldı. Yahve, Oved Edom'un evini ve sahip olduğu her şeyi kutsadı.
\c 14
\p 
\v 1 Sur Kralı Hiram, David'e haberciler ve ona ev yapmak için sedir ağaçları, duvarcılarla marangozlar gönderdi.
\v 2 David, Yahve'nin kendisini İsrael üzerine kral olarak pekiştirdiğini, çünkü halkı İsrael uğruna krallığını çok yükselttiğini anladı.
\p 
\v 3 David Yeruşalem'de daha çok karılar aldı ve David daha çok oğullar ve kızlar babası oldu.
\v 4 Yeruşalem'de olan çocuklarının adları şunlardır: Şammua, Şovav, Natan, Solomon,
\v 5 İvhar, Elişua, Elpelet,
\v 6 Nogah, Nefeg, Yafia,
\v 7 Elişama, Beeliada ve Elifelet.
\p 
\v 8 Filistliler, David'in bütün İsrael üzerine kral olarak meshedildiğini duyunca, Filistliler'in tümü David'i aramaya çıktılar. David de bunu duyunca onlara karşı çıktı.
\v 9 Filistliler gelip Refaim Vadisi'ne baskın yapmışlardı.
\v 10 David Tanrı'ya sorup şöyle dedi, “Filistliler'e karşı çıkayım mı? Onları elime teslim edecek misin?”
\p Yahve ona, “Çık, çünkü onları senin eline teslim edeceğim” dedi.
\p 
\v 11 Bunun üzerine Baal Perazim'e çıktılar ve David onları orada yendi. David, “Suların yarıldığı gibi, Tanrı düşmanlarımı elimle kırdı” dedi. Bu yüzden o yerin adını Baal Perazim\f + \fr 14:11 \ft “Baal Perazim” “Yarıp geçen Efendi” anlamına gelir.\f* koydular.
\v 12 Onlar ilâhlarını orada bıraktılar ve David buyruk verdi ve onlar ateşle yakıldı.
\p 
\v 13 Filistliler vadide bir baskın daha yaptılar.
\v 14 David Tanrı'ya yine sordu ve Tanrı ona, “Onların peşinden çıkmayacaksın. Onlardan dön ve dut ağaçlarının karşısında onların üzerine gel.” dedi.
\v 15 “Dut ağaçlarının tepelerinde yürüyüş sesi duyduğunda savaşa çık; çünkü Tanrı Filist ordusunu vurmak için senden önce çıkmıştır.”
\p 
\v 16 David Tanrı'nın kendisine buyurduğu gibi yaptı ve Filist ordusuna Givon'dan Gezer'e kadar saldırdılar.
\v 17 David'in ünü bütün ülkelere yayıldı ve Yahve bütün ulusların üzerine onun korkusunu getirdi.
\c 15
\p 
\v 1 David, kendisi için David Kenti'nde evler yaptı; Tanrı'nın Sandığı için bir yer hazırladı ve onun için bir çadır kurdu.
\v 2 David, “Tanrı'nın Sandığı'nı Levililer'den başkası taşımamalı. Çünkü Yahve, Tanrı'nın Sandığı'nı taşımak ve daima kendisine hizmet etmek için onları seçti.” dedi.
\p 
\v 3 David, Yahve'nin Sandığı'nı hazırladığı yere çıkarmak için bütün İsrael'i Yeruşalem'de topladı.
\v 4 David, Aron'un oğullarını ve Levililer'i topladı:
\v 5 Kohatoğulları'nın başı Uriel ve kardeşleri yüz yirmi kişi;
\v 6 Merari oğullarının başı Asaya ve kardeşleri iki yüz yirmi kişi;
\v 7 Gerşom oğullarının başı Yoel ve kardeşleri yüz otuz kişi;
\v 8 Elizafan oğullarının başı Şemaya ve kardeşleri iki yüz kişi;
\v 9 Hevron oğullarının başı Eliel ve kardeşleri seksen kişi;
\v 10 Uzziel oğullarının başı Amminadav ve kardeşleri yüz on iki kişi.
\p 
\v 11 David, kâhinleri, Sadok'u ve Aviyatar'ı ve Levililer'i, Uriel, Asaya, Yoel, Şemaya, Eliel ve Amminadav'ı çağırdı.
\v 12 Onlara, “Siz Levililer'in atalar evlerinin başlarısınız. Siz ve kardeşleriniz, İsrael'in Tanrısı Yahve'nin Sandığı'nı onun için hazırlamış olduğum yere çıkarmak için kendinizi kutsayın.” dedi.
\v 13 “Çünkü siz onu ilk başta taşımadığınız için, Tanrımız Yahve bize karşı öfkeyle çıkıştı; çünkü biz O'nun kuralına göre aramadık.”
\p 
\v 14 Böylece kâhinler ve Levililer, İsrael'in Tanrısı Yahve'nin Sandığı'nı çıkarmak için kendilerini kutsadılar.
\v 15 Levililer'in çocukları, Yahve'nin sözüne göre Moşe'nin buyurduğu gibi, Tanrı'nın Sandığı'nı sırıklarıyla omuzları üzerinde taşıdılar.
\p 
\v 16 David, Levililer'in başına, müzik aletleri, telli çalgılar, çenkler ve zillerle, sevinçle ses yükselten ezgi söyleyenleri kardeşlerinden atasın diye söyledi.
\v 17 Böylece Levililer, Yoel oğlu Heman'ı, kardeşlerinden Berekya oğlu Asaf'ı, Merarioğulları'ndan kardeşleri Kuşaya oğlu Etan'ı,
\v 18 ve onlarla birlikte ikinci sıradaki kardeşlerinden kapıcıları Zekariya, Ben, Yaaziel, Şemiramot, Yehiel, Unni, Eliav, Benaya, Maaseya, Mattitya, Elifelehu, Mikneya, Oved Edom ve Yeiel'i atadılar.
\v 19 Böylece ezgi söyleyenler, Heman, Asaf ve Etan'a yüksek sesle çalmaları için tunç ziller verildi;
\v 20 Zekariya, Aziel, Şemiramot, Yehiel, Unni, Eliav, Maaseya ve Benaya telli çalgılarla Alamot'a;
\v 21 Matitya, Elifelehu, Mikneya, Oved Edom, Yeiel ve Azaziya ise sekiz telli lire göre ayarlanmış çenklerle önderlik etsinler diye atandılar.
\v 22 Levililer'in başı Kenanya ezgiyi yönetiyordu. Yetenekli olduğu için ezgicilere o öğretiyordu.
\v 23 Berekya ve Elkana sandık için kapıcılardı.
\v 24 Şevanya, Yoşafat, Netanel, Amasay, Zekariya, Benaya ve Eliezer, kâhinler, Tanrı'nın Sandığı önünde boruları çalıyorlardı; Oved Edom ve Yehiya sandık için kapıcı idiler.
\p 
\v 25 Böylece David, İsrael'in ihtiyarları ve binlerin başları, sevinçle Yahve'nin Antlaşma Sandığı'nı Oved Edom'un evinden yukarı çıkarmak için gittiler.
\v 26 Tanrı, Yahve'nin Antlaşma Sandığı'nı taşıyan Levililer'e yardım edince, yedi boğa ve yedi koç kurban ettiler.
\v 27 David ince ketenden bir cübbe giymişti, sandığı taşıyan bütün Levililer, ezgi söyleyenlerle birlikte koro şefi Kenanya da öyle. David'in üzerinde keten bir efod vardı.
\v 28 Böylece bütün İsrael, bağırışla, zurna sesiyle, borular ve zillerle, yüksek ses çıkaran telli çalgılar ve çenkler çalarak Yahve'nin Antlaşma Sandığı'nı yukarı çıkardılar.
\v 29 Yahve'nin Antlaşma Sandığı David'in kentine geldiğinde, Saul'un kızı Mikal pencereden baktı ve Kral David'in dans edip oynadığını gördü; ve yüreğinde onu küçümsedi.
\c 16
\p 
\v 1 Tanrı'nın Sandığı'nı içeri getirip David'in onun için kurmuş olduğu çadırın ortasına koydular. Tanrı'nın önünde yakmalık sunular ve esenlik sunuları sundular.
\v 2 David yakmalık sunuyu ve esenlik sunularını sunmayı bitirince, halkı Yahve'nin adıyla kutsadı.
\v 3 İsraelliler'in her birine, hem erkek hem de kadın, herkese birer somun ekmek, birer parça et ve birer kuru üzüm pestili verdi.
\p 
\v 4 Levililer'den bazılarını Yahve'nin Sandığı önünde hizmet etmek, İsrael'in Tanrısı Yahve'yi anmak, O'na şükretmek ve O'nu övmek için atadı:
\v 5 Baş Asaf, onun ikincisi olan Zekariya, sonra Yeiel, Şemiramot, Yehiel, Mattitya, Eliav, Benaya, Obed Edom ve Yeiel, telli çalgılar ve çenklerle; Asaf da yüksek ses çıkaran zillerle;
\v 6 Benaya ve Yahaziel kâhinler, sürekli olarak, Tanrı'nın Antlaşma Sandığı'nın önünde borularla.
\p 
\v 7 O zaman David, ilk olarak o gün Asaf ve kardeşleri eli aracılığıyla Yahve'ye şükretme işini verdi.
\q1 
\v 8 Yahve'ye şükredin.
\q2 Adını çağırın.
\q2 Yaptıklarını halklar arasında bildirin.
\q1 
\v 9 O'na ezgiler söyleyin.
\q2 O'na övgüler sunun.
\q2 Bütün şaşılası işlerini anlatın.
\q1 
\v 10 Kutsal adıyla övünün.
\q2 Yahve'yi arayanların yüreği sevinsin.
\q1 
\v 11 Yahve'yi ve O'nun gücünü arayın.
\q2 Daima O'nun yüzünü arayın.
\q1 
\v 12 O'nun yaptığı şaşılası işlerini,
\q2 O'nun harikalarını ve ağzının hükümlerini hatırlayın,
\q1 
\v 13 Ey hizmetkârı İsrael'in soyu,\f + \fr 16:13 \ft veya tohum\f*
\q2 ey seçilmişleri, Yakov'un çocukları.
\q1 
\v 14 O, Tanrımız Yahve'dir.
\q2 Hükümleri bütün yeryüzündedir.
\q1 
\v 15 Sonsuza dek antlaşmasını,
\q2 bin kuşağa kadar buyurduğu sözünü,
\q1 
\v 16 Avraham'la yaptığı antlaşmayı,
\q2 İshak'a olan andını hatırlayın.
\q1 
\v 17 Bunu Yakov'a bir yasa olarak,
\q2 İsrael'e de ebedi bir antlaşma olarak onayladı.
\q1 
\v 18 “Size Kenan diyarını,
\q2 mirasınızın payı olmak üzere vereceğim” dedi.
\q1 
\v 19 Siz sayıca az,
\q2 evet, çok az ve orada yabancıyken,
\q1 
\v 20 Ulustan ulusa,
\q2 bir krallıktan başka bir halka dolaştınız.
\q1 
\v 21 Hiç kimsenin onlara kötülük etmesine izin vermedi.
\q2 Evet, kralları onlar uğruna azarladı.
\q1 
\v 22 “Meshedilmişlerime dokunmayın!
\q2 Peygamberlerime kötülük etmeyin!”
\q1 
\v 23 Ey bütün dünya, Yahve'ye ezgi söyleyin!
\q2 Kurtarışını her gün gösterin.
\q1 
\v 24 Uluslar arasında görkemini,
\q2 bütün halklar arasında şaşılası işlerini duyurun.
\q1 
\v 25 Çünkü Yahve büyüktür ve övgüye çok layıktır.
\q2 Bütün ilâhlardan çok da O'ndan korkulmalıdır.
\q1 
\v 26 Çünkü halkların bütün ilâhları putlardır,
\q2 ancak gökleri yaratan Yahve'dir.
\q1 
\v 27 O'nun önünde onur ve görkem vardır.
\q2 Güç ve sevinç O'nun bulunduğu yerdedir.
\q1 
\v 28 Ey halkların soyları, Yahve'ye verin,
\q2 yüceliği ve gücü Yahve'ye verin!
\q1 
\v 29 Yahve'ye adına yaraşır görkemi verin.
\q2 Sunu getirin ve O'nun önüne çıkın.
\q2 Kutsal giysiler içinde Yahve'ye tapının.
\q1 
\v 30 Ey bütün dünya Yahve'nin önünde titreyin.
\q2 Dünya da kurulmuştur, sarsılamaz.
\q1 
\v 31 Gökler sevinsin, yeryüzü coşsun!
\q2 Uluslar arasında, “Yahve hüküm sürüyor!” desinler.
\q1 
\v 32 Deniz ve onun doluluğu gürlesin!
\q2 Kırlar ve içindekilerin hepsi sevinçle coşsun!
\q1 
\v 33 Orman ağaçları Yahve'nin önünde sevinçle ezgi söyleyecekler,
\q2 çünkü O yeryüzüne hükmetmeye geliyor.
\q1 
\v 34 Yahve'ye şükredin, çünkü O iyidir,
\q2 çünkü O'nun sevgi dolu iyiliği sonsuza dek sürer.
\q1 
\v 35 Söyleyip deyin, “Kurtar bizi, kurtuluşumuzun Tanrısı!
\q2 Bizi bir araya topla ve uluslardan kurtar,
\q2 senin kutsal adına şükretmek, övgünle övünmek için.”
\q1 
\v 36 İsrael'in Tanrısı Yahve, sonsuzluktan sonsuza dek övülsün.
\p Bütün halk, “Amin” dedi ve Yahve'ye övgüler sundu.
\p 
\v 37 Bunun üzerine Asaf'ı ve kardeşlerini, her günkü işlerin gerektirdiği gibi, sürekli olarak sandığın önünde hizmet etsinler diye, Yahve'nin Antlaşma Sandığı'nın önünde;
\v 38 ve Obed Edom'u ve altmış sekiz akrabasını; Yedutun oğlu Obed Edom'u ve Hosa'yı kapı bekçisi olarak bıraktı;
\v 39 ve kâhin Sadok'u ve kâhin kardeşlerini, Givon'daki yüksek yerde bulunan Yahve'nin çadırının önünde;
\v 40 Yahve'ye yakmalık sunular sunağında, Yahve'nin İsrael'e buyurduğu yasada yazılı olan her şeye göre, her sabah ve akşam sürekli olarak yakmalık sunular sunmak için;
\v 41 ve onlarla birlikte Heman'ı, Yedutun'u ve adları anılan seçilmiş geri kalanları bıraktı, Yahve'ye şükretmek için, çünkü O'nun sevgi dolu iyiliği sonsuza dek sürer;
\v 42 ve onlarla birlikte Heman ve Yedutun da; yüksek ses çıkaranlara borular ve ziller, ve Tanrı'nın ezgileri için çalgılar verdi, kapıda olmak üzere Yedut'un oğullarını da orada bıraktı.
\p 
\v 43 Bütün halk, her biri kendi evine gitti; David de evini kutsamak için geri döndü.
\c 17
\p 
\v 1 David evinde yaşarken, David Peygamber Natan'a, “Ben sedirden yapılmış bir evde oturuyorum, ama Yahve'nin Antlaşma Sandığı bir çadırda” dedi.
\p 
\v 2 Natan David'e, “Yüreğinde olan her şeyi yap, çünkü Tanrı seninledir” dedi.
\p 
\v 3 O gece Tanrı'nın sözü Natan'a geldi ve şöyle dedi,
\v 4 “Git, hizmetkârım David'e söyle, 'Yahve şöyle diyor, “Bana oturmak için sen bana ev yapmayacaksın.
\v 5 Çünkü İsrael'i çıkardığım günden bu güne dek bir evde yaşamadım, çadırdan çadıra, bir çadırdan öbürüne dolaştım.
\v 6 Bütün İsrael'le birlikte yürüdüğüm yerlerin hepsinde, halkımın çobanı olmalarını buyurduğum İsrael hâkimlerinden herhangi birine, 'Neden bana sedirden bir ev yapmadınız?' diye bir söz söyledim mi?”'”
\p 
\v 7 “Şimdi, hizmetkârım David'e şöyle diyeceksin: 'Ordular Yahvesi şöyle diyor, “Halkım İsrael'in üzerine hükümdar olmak üzere seni koyun ağılından, koyunların ardından aldım.
\v 8 Gittiğin her yerde seninle oldum, önünden bütün düşmanlarını söküp attım. Yeryüzündeki büyüklerin adı gibi sana bir ad yapacağım.
\v 9 Halkım İsrael için bir yer belirleyeceğim, onları dikeceğim, kendi yerlerinde oturacaklar ve bir daha yerinden oynatılmayacaklar. İlk başta olduğu gibi,
\v 10 Ve halkım İsrael'in üzerine hâkimler buyurduğum günden beri olduğu gibi, kötülüğün çocukları onları bir daha harap etmeyecek. Bütün düşmanlarına boyun eğdireceğim. Yahve'nin sana bir ev yapacağını da sana bildiriyorum.
\v 11 Öyle olacak ki, senin günlerin dolup atalarınla birlikte olmak üzere gitmen gerektiğinde, senden sonra oğullarından olacak soyunu durduracağım ve onun krallığını pekiştireceğim.
\v 12 O bana ev yapacak ve onun tahtını sonsuza dek pekiştireceğim.
\v 13 Ben onun babası olacağım ve o da benim oğlum olacak. Senden öncekinden geri aldığım gibi, sevgi dolu iyiliğimi ondan geri almayacağım.
\v 14 Ama onu sonsuza dek evimde ve krallığımda yerleştireceğim. Tahtı sonsuza dek pekiştirilecektir.”'”
\v 15 Bütün bu sözlere ve bütün bu görüme göre, Natan David’e böyle söyledi.
\p 
\v 16 O zaman Kral David içeri girip Yahve'nin önünde oturdu ve şöyle dedi, “Ben kimim, Ey Yahve Tanrı, evim nedir ki, beni buraya kadar getirdin?
\v 17 Ey Tanrım, bu senin gözünde küçük bir şeydi, ama hizmetkârının evinden uzun bir süre için söz ettin ve bana yüksek bir adammışım gibi saygı gösterdin, ey Yahve Tanrı.
\v 18 David, hizmetkârına verilen bu saygınlıkla ilgili sana daha ne diyebilir? Çünkü hizmetkârını bilirsin.
\v 19 Ey Yahve, hizmetkârının hatırı için ve senin kendi yüreğine göre, bütün bu büyük şeyleri bildirmek için bütün bu büyüklüğü yaptın.
\v 20 Ey Yahve, kulaklarımızla duyduğumuz her şeye göre senin gibisi yoktur, senden başka Tanrı da yoktur.
\v 21 Kendi halkının önünden ulusları kovarak, büyük ve korkunç şeylerle kendine isim yapmak için, Mısır'dan fidye ile kurtardığın halkın İsrael gibi, yeryüzünde hangi ulus var ki, Tanrı onu kendisine halk olması için kurtarmaya gitmiştir?
\v 22 Çünkü halkın İsrael'i sonsuza dek kendi halkın yaptın ve sen, ey Yahve, onların Tanrısı oldun.
\v 23 Şimdi, ey Yahve, hizmetkârın ve onun evi hakkında söylediğin söz sonsuza dek sabit olsun ve söylediğin gibi yap.
\v 24 'Ordular Yahvesi, İsrael'in Tanrısı'dır, İsrael'e Tanrı'dır' denilip adın sonsuza dek sabit olsun ve yüceltilsin, 'Hizmetkârın David'in evi senin önünde sabit olsun.'
\v 25 Çünkü sen, Tanrım, hizmetkârına bir ev yapacağını açığa vurdun. Bu nedenle hizmetkârın önünde dua etme cesaretini buldu.
\v 26 Şimdi, ey Yahve, sen Tanrı'sın ve hizmetkârına bu iyi şeyi vaat ettin.
\v 27 Şimdi, hizmetkârının evini daima önünde sürsün diye kutsamak seni hoşnut etti; çünkü sen, ey Yahve, kutsadın ve sonsuza dek kutsandı.
\c 18
\p 
\v 1 Bundan sonra David Filistliler'i yendi ve onlara boyun eğdirdi ve Gat'ı ve kasabalarını Filistliler'in elinden aldı.
\v 2 Moav'ı yendi; Moavlılar David'e vergi ödeyen hizmetkârlar oldular.
\p 
\v 3 David, Fırat Irmağı yanındaki hakimiyetini kurmak için giderken, Hamat'a doğru, Sova Kralı Hadadezer'i yendi.
\v 4 David ondan bin savaş arabası, yedi bin atlı ve yirmi bin yaya asker aldı; David bütün savaş arabalarının atlarını sakatladı, ancak bunlardan yüz savaş arabasına yetecek kadarını ayırdı.
\v 5 Damaskuslu Suriyeliler Sova Kralı Hadadezer'e yardım etmeye geldiklerinde, David Suriyeliler'den yirmi iki bin kişiyi vurdu.
\v 6 Sonra David Suriye'nin Damaskus'unda askeri birlikler koydu; Suriyeliler David'e hizmetkâr oldular ve vergi ödediler. Yahve David'in gittiği her yerde ona zafer verdi.
\v 7 David, Hadadezer'in hizmetkârlarının üzerindeki altın kalkanları alıp Yeruşalem'e getirdi.
\v 8 Hadadezer'in kentleri olan Tivhat ve Kun'dan David çok miktarda tunç aldı. Solomon bunlarla tunç denizi, direkleri ve tunç kapları yaptı.
\p 
\v 9 Hamat Kralı Tou, David'in Sova Kralı Hadadezer'in bütün ordusunu vurduğunu duyunca,
\v 10 oğlu Hadoram'ı David'i selamlamak ve kutsamak için ona gönderdi; çünkü Hadadezer'e karşı savaşmış ve onu vurmuştu (çünkü Hadadezer'in, Tou ile savaşları vardı); yanında da her çeşit altın, gümüş ve tunç kaplar vardı.
\v 11 Kral David de, bütün bu uluslardan Edom'dan, Moav'dan, Ammon'un çocuklarından, Filistliler'den ve Amalek'ten getirmiş olduğu gümüş ve altınla birlikte bunları Yahve'ye adadı.
\p 
\v 12 Seruya oğlu Avişay da, Tuz Vadisi'nde Edomlular'dan on sekiz bin kişiyi vurdu.
\v 13 Edom'a askeri birlikler koydu ve bütün Edomlular David'in hizmetkârları oldular. Yahve, David'in gittiği her yerde ona zafer verdi.
\p 
\v 14 David bütün İsrael üzerinde hüküm sürdü ve halkının tümüne adalet ve doğruluk sağladı.
\v 15 Seruya oğlu Yoav ordu komutanıydı; Ahilud oğlu Yehoşafat tarihçiydi;
\v 16 Ahituv oğlu Sadok ve Aviyatar oğlu Avimelek kâhinlerdi; Şavşa kâtipti;
\v 17 Yehoyada oğlu Benaya Keretiler ve Peletliler'in başındaydı; David'in oğulları ise krala hizmet eden baş görevlilerdi.
\c 19
\p 
\v 1 Bundan sonra Ammon'un çocuklarının kralı Nahaş öldü ve yerine oğlu kral oldu.
\v 2 David, “Babası bana iyilik ettiği için ben de Nahaş oğlu Hanun’a iyilik edeceğim” dedi.
\p Bunun üzerine David, babasıyla ilgili olarak onu teselli etmek için ulaklar gönderdi. David’in hizmetkârları, onu teselli etmek için Ammon'un çocuklarının ülkesine, Hanun’un yanına vardılar.
\v 3 Ama Ammon'un çocuklarının beyleri Hanun’a, “David’in sana teselliciler göndererek babanı onurlandırdığını mı sanıyorsun? Hizmetkârları sana gelip ülkeyi araştırmak, devirmek ve casusluk yapmak için gelmediler mi?” dediler.
\v 4 Bunun üzerine Hanun, David'in hizmetkârlarını aldı, onları tıraş etti ve giysilerini kalçalarının ortasından kesip gönderdi.
\v 5 O zaman bazı kişiler gidip David’e adamlara nasıl davranıldığını anlattılar. David onları karşılamak için adam gönderdi; çünkü adamlar çok aşağılanmışlardı. Kral, “Sakallarınız uzayıncaya dek Yeriha’da kalın, sonra dönün” dedi.
\p 
\v 6 Ammon'un çocukları, David’e karşı kendilerini iğrenç ettiklerini görünce, Hanun ve Ammon'un çocukları, Mezopotamya’dan, Aram Maaka’dan ve Sova’dan savaş arabaları ve atlılar tutmak için bin talant\f + \fr 19:6 \ft Bir talant yaklaşık 30 kilogram veya 66 pound'dur, bu nedenle 1000 talant yaklaşık 30 metrik tondur\f* gümüş gönderdiler.
\v 7 Böylece kendileri için otuz iki bin savaş arabası ve Maaka Kralı'nı ve adamlarını ücretli tuttular. Onlar da gelip Medeva’nın yakınında ordugâh kurdu. Ammon'un çocukları kentlerden toplanıp savaşa geldiler.
\v 8 David bunu duyunca, Yoav’ı ve bütün yiğitler ordusunu gönderdi.
\v 9 Ammon'un çocukları çıkıp kentin kapısında savaş düzenine koyuldular. Gelen krallar ise ayrı olarak kırdaydılar.
\p 
\v 10 Yoav, savaşın önünde ve arkasında kendisine karşı olduğunu görünce, İsrael'in seçme adamlarından bazılarını ayırıp onları Suriyeliler'e karşı dizdi.
\v 11 Halkın geri kalanını kardeşi Avişay'ın eline teslim etti, onlar da Ammon'un çocuklarına karşı dizildiler.
\v 12 Şöyle dedi: “Eğer Suriyeliler benden güçlü çıkarsa, o zaman bana yardım edeceksiniz; ama eğer Ammon'un çocukları sizden güçlü çıkarsa, o zaman ben size yardım edeceğim.
\v 13 Cesur olun ve halkımız ve Tanrımız'ın kentleri için güçlü olalım. Yahve kendisine iyi görüneni yapsın.”
\p 
\v 14 Böylece Yoav ve yanındaki halk, savaş için Suriyeliler'in önüne yaklaştılar; onlar da onun önünden kaçtılar.
\v 15 Ammon'un çocukları, Suriyeliler'in kaçtığını görünce, onlar da kardeşi Avişay'ın önünden kaçıp kente girdiler. O zaman Yoav Yeruşalem'e geldi.
\p 
\v 16 Suriyeliler İsrael tarafından yenildiklerini görünce, ulaklar gönderip, Hadadezer'in ordusunun başkomutanı Şofak'ın önderliğinde, Irmak\f + \fr 19:16 \ft veya Fırat Irmağı\f* ötesindeki Suriyeliler'i çağırdılar.
\v 17 David bunu duyunca, bütün İsrael'i topladı, Yarden'i geçti, onlara geldi ve onlara karşı savaş düzeni aldı. Böylece David Suriyeliler'e karşı savaş düzeni aldığında, onunla savaştılar.
\v 18 Suriyeliler İsrael'in önünden kaçtılar; David Suriyeliler'den yedi bin arabacı ve kırk bin yaya asker öldürdü, ordunun başkomutanı Şofak'ı da öldürdü.
\v 19 Hadadezer'in hizmetkârları İsrael tarafından yenildiklerini görünce, David'le barış yaptılar ve ona hizmet ettiler. Suriyeliler artık Ammon'un çocuklarına yardım etmediler.
\c 20
\p 
\v 1 Yıl dönümünde, kralların dışarı çıktığı zaman, Yoav orduyu çıkardı ve Ammon'un çocuklarının ülkesini harap etti ve gelip Rabba'yı kuşattı. Ama David Yeruşalem'de kaldı. Yoav Rabba'yı vurdu ve onu yıktı.
\v 2 David krallarının tacını başından aldı ve onu bir talant\f + \fr 20:2 \ft Bir talant yaklaşık 30 kilogram veya 66 pound veya 965 Truva onsudur. \f* altın ağırlığında buldu, içinde değerli taşlar vardı. David'in başına konuldu ve kentten çok miktarda ganimet çıkardı.
\v 3 İçinde bulunan halkı dışarı çıkardı ve onları testerelere, demir kazmalara ve baltalara koydurdu. David Ammon'un çocuklarının bütün kentlerine böyle yaptı. Sonra David ve bütün halk Yeruşalem'e döndü.
\p 
\v 4 Bundan sonra Gezer'de Filistliler'le savaş çıktı. Sonra Huşatlı Sibbekay dev oğullarından Sippay'ı öldürdü, onlar da boyun eğdiler.
\p 
\v 5 Filistliler'le yine savaş çıktı; ve Yair oğlu Elhanan, Gatlı Golyat'ın kardeşi Lahmi'yi öldürdü. Mızrağının sapı dokumacı sırığı gibiydi.
\v 6 Gat'ta yine savaş çıktı. Orada iri yapılı bir adam vardı. Adamın her elinde altı, her ayağında altı olmak üzere yirmi dört parmağı vardı. O da deve doğmuştu.
\v 7 İsrael'e meydan okuyunca, David'in kardeşi Şimea'nın oğlu Yonatan onu öldürdü.
\v 8 Bunlar Gat'taki deve doğmuşlardı. David'in ve hizmetkârlarının eliyle düştüler.
\c 21
\p 
\v 1 Şeytan İsrael'e karşı çıktı ve David'i İsrael'i saymak için harekete geçirdi.
\v 2 David Yoav'a ve halkın beylerine, “Gidin, İsrael'i Beerşeva'dan Dan'a kadar sayın; bana haber getirin de kaç kişi olduğunu bileyim” dedi.
\p 
\v 3 Yoav, “Yahve halkını olduklarından yüz kat daha çoğaltsın” dedi. “Ama efendim kral, onların hepsi efendimin hizmetkârları değil mi? Efendim neden bu şeyi istiyor? Neden İsrael'e suç getirtsin?”
\p 
\v 4 Yine de kralın sözü Yoav'a karşı üstün geldi. Bunun üzerine Yoav ayrılıp bütün İsrael'i dolaştıktan sonra Yeruşalem'e geldi.
\v 5 Yoav halkın yazılan sayısını David'e verdi. İsrael'in hepsi kılıç çeken bir milyon yüz bin kişiydi; Yahuda'da ise kılıç çeken dört yüz yetmiş bin kişi vardı.
\v 6 Ama Levi ve Benyamin'i onların arasında saymadı, çünkü kralın sözü Yoav'a iğrenç geldi.
\p 
\v 7 Tanrı bu şeyden hoşnut değildi ve bu yüzden İsrael'i vurdu.
\v 8 David Tanrı'ya, “Bu işi yapmakla büyük günah işledim” dedi, “Ama şimdi yalvarırım, hizmetkârının suçunu kaldır, çünkü çok akılsızlık ettim.”
\p 
\v 9 Yahve, David'in Gören'i Gad'a şöyle dedi:
\v 10 “Git, David'e söyle, 'Yahve şöyle diyor, “Sana üç şey sunuyorum. Bunlardan birini seç de sana onu yapayım.'””
\p 
\v 11 Gad David'in yanına geldi ve ona şöyle dedi: “Yahve şöyle diyor, 'Seçimini yap:
\v 12 Ya üç yıl kıtlık; ya da düşmanlarının kılıcı seni yakalarken düşmanlarının önünde üç ay bitip tükenmek; ya da, üç gün Yahve'nin kılıcı, Yahve'nin meleğinin İsrael'in bütün sınırlarındaki yıkımı, ülkede veba. Şimdi bu nedenle beni gönderene ne yanıt götüreceğimi düşün.'”
\p 
\v 13 David Gad'a, “Sıkıntıdayım” dedi, “Duacıyım, Yahve'nin eline düşeyim, çünkü O'nun merhametleri çok büyüktür. İnsan eline düşmeyeyim.”
\p 
\v 14 Bunun üzerine Yahve İsrael'in üzerine veba gönderdi ve İsrael'den yetmiş bin kişi düştü.
\v 15 Tanrı, Yeruşalem'i yok etmek için bir melek gönderdi. Onu yok etmek üzereyken Yahve gördü ve felaketten vazgeçti ve yok edici meleğe, “Yeter artık. Şimdi elini çek.” dedi. Yahve'nin meleği, Yevuslu Ornan'ın harman yerinin yanında duruyordu.
\v 16 David gözlerini kaldırdı ve elinde çekilmiş bir kılıçla Yeruşalem üzerine uzatmış, yeryüzüyle gökyüzü arasında duran Yahve'nin meleğini gördü.
\p O zaman çul giymiş olan David ve ihtiyarlar yüzüstü yere kapandılar.
\v 17 David Tanrı'ya, “Halkın sayılmasını buyuran ben değil miyim? Günah işleyen ve çok kötülük eden benim. Ama bu koyunlar ne yaptılar? Lütfen, ey Tanrım Yahve, elin bana ve babamın evine karşı olsun; ama kendi halkını cezalandırmak için onlara karşı olmasın.” dedi.
\p 
\v 18 O zaman Yahve'nin meleği Gad'a, David'e çıkıp Yevuslu Ornan'ın harman yerinde Yahve'ye bir sunak kurmasını söylemesini buyurdu.
\v 19 David, Yahve'nin adıyla söylediği Gad'ın sözü üzerine yukarı çıktı.
\p 
\v 20 Ornan arkasına döndü ve meleği gördü; ve kendisiyle birlikte olan dört oğlu saklandılar. Ornan buğday dövüyordu.
\v 21 David Ornan'ın yanına gelince, Ornan baktı ve David'i gördü, harman yerinden çıktı ve yüzüstü yere kapanıp David'in önünde eğildi.
\p 
\v 22 David Ornan'a, “Bu harman yerinin yerini bana sat da üzerinde Yahve'ye bir sunak yapayım. Bana tam değeriyle satacaksın ki, veba halkın üzerinden kalksın.” dedi.
\p 
\v 23 Ornan David'e, “Onu kendine al, efendim kral gözünde iyi olanı yapsın. İşte, yakmalık sunular için öküzleri, odun için dövenleri ve ekmek sunusu için buğdayı veriyorum. Hepsini veriyorum.” dedi.
\p 
\v 24 Kral David Ornan'a, “Hayır, ama kesinlikle tam değeriyle satın alacağım” dedi. “Çünkü senin olanı Yahve için almam, bana hiçe mal olmuş yakmalık sunu sunmam.”
\p 
\v 25 Bunun üzerine David, Ornan'a yer için ağırlıkta altı yüz şekel\f + \fr 21:25 \ft Bir şekel yaklaşık 10 gram veya yaklaşık 0,32 Troy onsudur, dolayısıyla 600 şekel yaklaşık 6 kilogram veya yaklaşık 192 Troy onsudur.\f* altın verdi.
\v 26 David orada Yahve'ye bir sunak yaptı, yakmalık sunularını ve esenlik sunularını sundu ve Yahve'yi çağırdı. Yahve de yakmalık sunu sunağı üzerinde gökyüzünden ateşle ona yanıt verdi.
\p 
\v 27 O zaman Yahve meleğe buyurdu, o da kılıcını kınına koydu.
\p 
\v 28 O sırada David, Yahve'nin kendisine Yevuslu Ornan'ın harman yerinde yanıt verdiğini görünce, orada kurban kesti.
\v 29 Çünkü Moşe'nin çölde yaptığı Yahve'nin çadırı ve yakmalık sunu sunağı o sırada Givon'daki yüksek yerdeydi.
\v 30 Ama David, Tanrı'dan sormak için O'nun önüne gidemedi; çünkü Yahve'nin meleğinin kılıcı yüzünden korkuyordu.
\c 22
\p 
\v 1 O zaman David, “Bu, Tanrı Yahve'nin evidir, İsrael için yakmalık sunu sunağı da budur” dedi.
\p 
\v 2 David, İsrael ülkesinde bulunan yabancıların toplanmasını buyurdu ve Tanrı'nın evini yapmak için yontma taşlar kesmeleri için duvarcıları koydu.
\v 3 David, kapıların çivileri ve bağlantı parçaları için bol miktarda demir, çoklukta tartılamaz miktarda tunç ve sayısız sedir ağacı hazırladı.
\v 4 Saydalılar ve Sur halkı David'e bol miktarda sedir ağacı getirdiler.
\v 5 David, “Oğlum Solomon genç ve toydur” dedi. “Yahve için yapılacak ev çok büyük, bütün ülkelerde ünlü ve görkemli olmalı. Bu nedenle onun için hazırlık yapacağım.” Böylece David ölümünden önce bolca hazırlık yaptı.
\v 6 Sonra oğlu Solomon'u çağırdı ve ona İsrael'in Tanrısı Yahve için bir ev yapmasını buyurdu.
\v 7 David oğlu Solomon'a şöyle dedi, “Ben kendim, Tanrım Yahve'nin adına bir ev yapmak yüreğimde vardı.
\v 8 Ama Yahve'nin sözü bana geldi ve şöyle dedi: Sen çok kan döktün ve büyük savaşlar yaptın. Adıma bir ev yapmayacaksın, çünkü gözümün önünde yeryüzünde çok kan döktün.
\v 9 İşte, sana bir oğul doğacak, o barış adamı olacak. Ona çevresindeki bütün düşmanlarından rahat vereceğim; çünkü onun adı Solomon olacak ve İsrael'e onun günlerinde barış ve huzur vereceğim.
\v 10 Adıma ev yapacak olan odur; ve o bana oğul olacak, ben ona baba olacağım; ve İsrael üzerinde krallığının tahtını sonsuza dek pekiştireceğim.
\v 11 Şimdi oğlum, Yahve seninle birlikte olsun ve seni başarılı kılsın ve Tanrın Yahve'nin evini, senin hakkında söylediği gibi yap.
\v 12 Yahve sana sağduyu ve anlayış versin ve seni İsrael'in başına koysun, öyle ki Tanrın Yahve'nin yasasını tutasın.
\v 13 Yahve'nin Moşe'ye İsrael hakkında verdiği kuralları ve ilkeleri yapmak üzere onları tutarsan, o zaman başarılı olacaksın. Güçlü ve cesur ol. Korkma ve yılgınlığa düşme.
\v 14 Şimdi, işte, sıkıntım içinde Yahve'nin evi için yüz bin talant\f + \fr 22:14 \ft Bir talantyaklaşık 30 kilogram veya 66 pound veya 965 Truva onsudur, bu nedenle 100.000 talant yaklaşık 3 metrik tondur\f* altın, bir milyon talant\f + \fr 22:14 \ft yaklaşık 30.000 metrik ton\f* gümüş, tartısız tunç ve demir hazırladım; çünkü bol miktardadır. Kereste ve taş da hazırladım; sen de bunlara ekleyebilirsin.
\v 15 Yanında çok sayıda işçi de var; taş ve kereste kesen işçiler ve her türlü işte becerikli her çeşit adam var;
\v 16 altının, gümüşün, tunçun ve demirin sayısı yoktur. Kalk da yap, Yahve seninle birlikte olsun.”
\p 
\v 17 David İsrael'in bütün beylerine de oğlu Solomon'a yardım etmelerini buyurup dedi,
\v 18 “Tanrınız Yahve sizinle birlikte değil mi? Her yandan size rahat vermedi mi? Çünkü ülkenin sakinlerini benim elime teslim etti; ülke Yahve'nin ve halkının önünde boyun eğdi.
\v 19 Şimdi yüreğinizle ve canınızla Tanrınız Yahve'yi izlemeye koyulun. Bu yüzden kalkın ve Yahve'nin Antlaşma Sandığı'nı ve Tanrı'nın kutsal kaplarını Yahve'nin adına bina edilecek evin içine getirmek için Yahve Tanrı'nın kutsal yerini bina edin .”
\c 23
\p 
\v 1 David yaşlanmış ve günlere doymuştu. Oğlu Solomon'u İsrael üzerine kral yaptı.
\v 2 İsrael'in bütün beylerini, kâhinleri ve Levililer'i bir araya topladı.
\v 3 Otuz yaş ve ondan yukarı olan Levililer sayıldı. Onların birer birer sayısı otuz sekiz bin erkekti.
\v 4 David, “Bunlardan yirmi dört bini Yahve'nin evinin işine bakmak içindi, altı bini memur ve hâkimdi,
\v 5 dört bini kapı bekçisi ve dört bini de övgü sunmak için yaptığım aletlerle Yahve'yi övecek” dedi.
\p 
\v 6 David onları Levi'nin oğullarına göre takımlara ayırdı: Gerşon, Kehat ve Merari.
\p 
\v 7 Gerşonlular'dan: Ladan ve Şimei.
\v 8 Ladan'ın oğulları: Baş Yehiel, Zetam ve Yoel, üç kişi.
\v 9 Şimei'nin oğulları: Şelomit, Haziel ve Haran, üç kişi. Bunlar Ladan'ın atalar evlerinin başlarıydı.
\v 10 Şimei'nin oğulları: Yahat, Sina, Yeuş ve Beria. Bu dördü Şimei'nin oğullarıydı.
\v 11 Baş Yahat, ikincisi Ziza idi; ama Yeuş ve Beria'nın çok sayıda oğlu yoktu; bu yüzden bir sayıda ata evi oldular.
\p 
\v 12 Kohat'ın oğulları: Amram, Yisthar, Hevron ve Uzziel, dört kişi.
\v 13 Amram'ın oğulları: Aron ve Moşe; ve Aron, kendisi ve oğulları daima en kutsal şeyleri kutsal kılsınlar, Yahve'nin önünde buhur yaksınlar, O'na hizmet etsinler ve daima O'nun adıyla kutsasınlar diye ayrılmıştı.
\v 14 Ama Tanrı adamı Moşe'ye gelince, oğulları Levi oymağı arasında sayıldılar.
\v 15 Moşe'nin oğulları: Gerşom ve Eliezer.
\v 16 Gerşom'un oğulları: Baş Şevuel.
\v 17 Eliezer'in oğlu baş Rehavya'ydı. Eliezer'in başka oğlu yoktu. Ama Rehavya'nın oğulları çoktu.
\v 18 Yitshar'ın oğulları: Baş Şelomit.
\v 19 Hevron'un oğulları: Baş Yeriah, ikincisi Amarya, üçüncüsü Yahaziel ve dördüncüsü Yekameam.
\v 20 Uzziel'in oğulları: Baş Mika ve ikincisi İşşiya.
\p 
\v 21 Merari'nin oğulları: Mahli ve Muşi. Mahli'nin oğulları: Eleazar ve Kiş.
\v 22 Eleazar öldü ve onun oğulları yoktu, sadece kızları vardı; ve onların akrabaları olan Kiş oğulları onları karıları olarak aldılar.
\v 23 Muşi'nin oğulları: Mahli, Eder ve Yeremot, üç kişi.
\p 
\v 24 Atalar evlerine göre Levioğulları; yirmi yaşında ve ondan yukarı adlarıyla tek tek sayılan atalar evlerinin başları; Yahve'nin evinin hizmeti için iş görenler bunlardı.
\v 25 Çünkü David, “İsrael'in Tanrısı Yahve halkına rahat verdi; sonsuza dek Yeruşalem'de oturmaktadır” demişti.
\v 26 “Levililer'in artık çadırı ve onun hizmetinde kullanılan bütün kapları taşımayacaklar.”
\v 27 Çünkü David'in son sözleriyle Levioğulları yirmi yaşında ve ondan yukarı olanlar sayıldı.
\v 28 Çünkü görevleri, Yahve'nin evinin hizmeti için, avlularda, odalarda ve bütün kutsal şeylerin temizlenmesinde, Tanrı evinin hizmetinde Aronoğulları'nın yanında durmak,
\v 29 sergi ekmeğine, gerek mayasız yufkaların, gerek sacda pişirilen şeylerin, gerekse yoğrulmuş şeylerin ekmek sunusuna mahsus ince una, her çeşit ölçek ve ölçülere bakmak için;
\v 30 her sabah ve akşam da aynı şekilde, Yahve'ye şükretmek ve O'nu övmek için durmak;
\v 31 Şabatlar'da, yeni aylarda ve belli bayramlarda, bütün yakmalık sunuları sayısı ile, onlar hakkında olan yasaya göre, sürekli olarak Yahve'nin önünde, Yahve'ye sunmaktı;
\v 32 Buluşma Çadırı görevini, kutsal yer görevini ve kardeşleri Aronoğulları'nın Yahve'nin evinin hizmetindeki görevini yerine getireceklerdi.
\c 24
\p 
\v 1 Aronoğulları'nın bölükleri şunlardı. Aron'un oğulları: Nadav, Avihu, Eleazar ve İtamar.
\v 2 Ama Nadav ve Avihu babalarından önce öldüler ve çocukları yoktu; bu yüzden Eleazar ve İtamar kâhin olarak hizmet ettiler.
\v 3 David ve Eleazaroğulları'ndan Sadok ve İtamaroğulları'ndan Ahimelek, onları kendi hizmetlerindeki sıraya göre ayırdı.
\v 4 Eleazaroğulları'na göre, İtamaroğulları arasında daha fazla baş bulundu; ve şöyle ayrıldılar: Eleazaroğulları'ndan atalar evlerinin başları on altı; ve İtamaroğulları'ndan, ataları evlerine göre sekiz.
\v 5 Böylece bunlar kura ile taraf tutmadan ayrıldılar; çünkü hem Eleazaroğulları'ndan, hem de İtamaroğulları'ndan kutsal yer için önderler ve Tanrı için önderler vardı;
\v 6 Levililer'den Netanel'in oğlu kâtip Şemaya, bunları kralın, beylerin, kâhin Sadok'un, Aviyatar'ın oğlu Ahimelek'in ve kâhinlerin ve Levililer'in atalar evlerinin başları önünde yazdı. Bir atalar evi Eleazar için, bir atalar evi de İtamar için alındı.
\p 
\v 7 İlk kura Yehoyariv'e, ikincisi Yedaya'ya,
\v 8 Üçüncüsü Harim'e, dördüncüsü Seorim'e,
\v 9 Beşincisi Malkiya'ya, altıncısı Miyamin'e,
\v 10 Yedincisi Hakkos'a, sekizincisi Aviya'ya,
\v 11 Dokuzuncusu Yeşua'ya, onuncusu Şekanya'ya,
\v 12 On birincisi Elyaşiv'e, on ikincisi Yakim'e,
\v 13 On üçüncüsü Hupa'ya, on dördüncüsü Yeşevav'a,
\v 14 On beşincisi Bilga'ya, on altıncısı İmmer'e,
\v 15 On yedincisi Hezir'e, on sekizincisi Hapitsets'e,
\v 16 On dokuzuncusu Petahya'ya, yirmincisi Yehezkel'e,
\v 17 Yirmi birincisi Yakin'e, yirmi ikincisi Gamul'a,
\v 18 Yirmi üçüncüsü Delaya'ya, yirmi dördüncüsü Maaziya'ya çıktı.
\v 19 Bu, İsrael'in Tanrısı Yahve'nin kendisine buyurmuş olduğu gibi, ataları Aron'un kendilerine verdiği kurala göre, Yahve'nin evine girmeleri için onların hizmet sırasıydı.
\p 
\v 20 Levi'nin geri kalan oğullarına gelince: Amram'ın oğullarından Şuvael; Şuvael'in oğullarından Yehdeya.
\v 21 Rehavya'dan: Rehavya'nın oğullarından, baş İşşiya.
\v 22 Yitshariler'den Şelomot; Şelomot'un oğullarından Yahat.
\v 23 Hevron'un oğulları: Yeriah, ikinci Amarya, üçüncü Yahaziel ve dördüncü Yekameam.
\v 24 Uzziel'in oğulları: Mika; Mikaoğulları'ndan Şamir.
\v 25 Mika'nın kardeşi: İşşiya; İşşiya'nın oğullarından Zekariya.
\v 26 Merari'nin oğulları: Mahli ve Muşi. Yaaziya'nın oğlu: Beno.
\v 27 Merari'nin Yaaziya'dan olan oğulları: Beno, Şoham, Zakkur ve İbri.
\v 28 Mahli'den: Oğlu olmayan Eleazar.
\v 29 Kiş'den, Kiş'in oğulları: Yerahmeel.
\v 30 Muşi'nin oğulları: Mahli, Eder ve Yerimot. Bunlar ata evlerine göre Levililer'in oğullarıydı.
\v 31 Bunlar da kardeşleri Aronoğulları gibi, Kral David'in, Sadok'un, Ahimelek'in ve kâhinlerin ve Levililer'in ata evlerinin başlarının önünde, atalar evlerinin başları küçük kardeşleri gibi kura çektiler.
\c 25
\p 
\v 1 David ve ordu komutanları, Asaf'ın, Heman'ın ve Yedutu'nun oğullarından bazılarını, çenklerle, telli çalgılar ve zillerle peygamberlik etmek üzere hizmet için ayırdılar. Hizmetlerine göre işi yapanların sayısı şöyleydi:
\v 2 Asafoğulları'ndan: Zakkur, Yosef, Netanya ve Aşarela. Asaf'ın oğulları, kralın buyruğuna göre peygamberlik eden Asaf'ın eli altındaydı.
\v 3 Yedutun'dan, Yedutoğulları: Gedalya, Zeri, Yeşaya, Şimei, Haşavya ve Mattitya, Yahve'ye şükredip övgüler sunarak çenkle peygamberlik eden babaları Yedutun'un eli altında altı kişiydi.
\v 4 Heman'dan, Heman'ın oğulları: Bukkiya, Mattanya, Uzziel, Şevuel, Yerimot, Hananya, Hanani, Eliyata, Giddalti, Romamti Ezer, Yoşvekaşah, Malloti, Hotir ve Mahaziot.
\v 5 Bunların hepsi, boynuzu kaldırmak için, Tanrı'nın sözlerinde kralın göreni olan Heman'ın oğullarıydı. Tanrı, Heman'a on dört oğul ve üç kız verdi.
\v 6 Onların hepsi, zillerle, telli çalgılarla ve çenklerle, Tanrı evinin hizmeti için, babalarının eli altında, Yahve'nin evinde ezgi söylemek içindiler: Asaf, Yedutun ve Heman, kralın buyruğu altındaydılar.
\v 7 Bunların sayısı, Yahve'ye ezgi söylemekte eğitilmiş kardeşleriyle birlikte, becerikli olanların hepsi, iki yüz seksen sekizdi.
\v 8 Küçük büyük, öğretmen öğrenci ayrımı yapılmaksızın, görevleri için kura çektiler.
\p 
\v 9 İlk kura Asaf'a, Yosef'e çıktı; ikincisi Gedalya'ya, kendisi ve kardeşleriyle oğulları on iki;
\v 10 üçüncüsü Zakkur'a, oğulları ve kardeşleri on iki;
\v 11 dördüncüsü İzri'ye, oğulları ve kardeşleri on iki;
\v 12 Beşincisi, Netanya'ya, oğulları ve kardeşleri on iki;
\v 13 altıncısı Bukkiya'ya, oğulları ve kardeşleri on iki;
\v 14 yedincisi, Yeşarela'ya, oğulları ve kardeşleri on iki;
\v 15 sekizincisi, Yeşaya'ya, oğulları ve kardeşleri on iki;
\v 16 dokuzuncusu Mattanya'ya, oğulları ve kardeşleri on iki;
\v 17 onuncusu Şimei'ye, oğulları ve kardeşleri on iki;
\v 18 on birincisi Azarel'e, oğulları ve kardeşleri on iki;
\v 19 on ikincisi Haşavya'ya, oğulları ve kardeşleri, on iki;
\v 20 on üçüncüsü Şubael'e, oğulları ve kardeşleri, on iki;
\v 21 on dördüncüsü Mattitya'ya, oğulları ve kardeşleri, on iki;
\v 22 on beşincisi Yeremot'a, oğulları ve kardeşleri, on iki;
\v 23 on altıncısı Hananya'ya, oğulları ve kardeşleri, on iki;
\v 24 on yedincisi Yoşvekaş'a, oğulları ve kardeşleri, on iki;
\v 25 on sekizinci Hanani'ye, oğulları ve kardeşleri, on iki;
\v 26 on dokuzuncusu Malloti'ye, oğulları ve kardeşleri, on iki;
\v 27 yirmincisi Eliata'ya, oğulları ve kardeşleri, on iki;
\v 28 yirmi birincisi Hotir'e, oğulları ve kardeşleri, on iki;
\v 29 yirmi ikincisi Giddalti'ye, oğulları ve kardeşleri, on iki;
\v 30 yirmi üçüncüsü Mahaziot'a, oğulları ve kardeşleri on iki;
\v 31 yirmi dördüncüsü Romamti Ezer'e, oğulları ve kardeşleri on iki.
\c 26
\p 
\v 1 Kapı bekçilerinin bölükleri: Korahlılar'dan, Asafoğulları'ndan Kore'nin oğlu Meşelemya.
\v 2 Meşelemya'nın oğulları: İlk oğlu Zekariya, ikincisi Yediael, üçüncüsü Zevadya, dördüncüsü Yatniel,
\v 3 Beşincisi Elam, altıncısı Yehohanan ve yedincisi Elihoenay.
\v 4 Oved Edom'un oğulları: İlk oğlu Şemaya, ikincisi Yehozavad, üçüncüsü Yoah, dördüncüsü Sakar, beşincisi Netanel,
\v 5 altıncısı Ammiel, yedincisi İssakar ve sekizincisi Peulletay; çünkü Tanrı onu kutsamıştı.
\v 6 Babalarının evini yöneten onun oğlu Şemaya'nın da oğulları oldu; çünkü onlar cesur yiğitlerdi.
\v 7 Şemaya'nın oğulları: Otni, Refael, Oved ve Elzavad; akrabaları yiğit adamlardı, Elihu ve Semakya.
\v 8 Bunların hepsi Oved Edomoğulları'ndan, bunlar oğullar ve kardeşleri, hizmet için güçte yiğit adamlardı: Oved Edom'dan altmış iki kişi.
\v 9 Meşelemya'nın oğulları ve kardeşleri, yiğit adamlar, on sekiz kişi.
\v 10 Merari'nin çocuklarından Hosa'nın da oğulları vardı: Baş Şimri (ilk doğan olmamasına rağmen babası onu baş yaptı),
\v 11 ikincisi Hilkiya, üçüncüsü Tevalya ve dördüncüsü Zekariya. Hosa'nın bütün oğulları ve kardeşleri on üç kişi.
\p 
\v 12 Yahve'nin evinde hizmet etmek için, kardeşleri gibi olan kapı bekçileri bölükleri bunlardan, baş adamlardı.
\v 13 Her kapı için, atalar evlerine göre, küçüğü de büyüğü de kura çektiler.
\v 14 Doğuya doğru kura Şelemya'ya düştü. Sonra bilge bir danışman olan oğlu Zekariya için kura çektiler; ve onun kurası kuzeye çıktı.
\v 15 Oved Edom'a güneye; ve oğullarına ambar evine.
\v 16 Şuppim ve Hosa'ya batıya, Şalleket Kapısı yanında, yukarı çıkan geçitte, karşılıklı iki nöbet yerine çıktı.
\v 17 Doğuya doğru altı Levili, kuzeye günde dört, güneye günde dört ve ambar için ikişer ikişer.
\v 18 Batıya doğru Parbar için, geçitte dört ve Parbar'da iki.
\v 19 Kapı bekçilerinin bölükleri şunlardı: Korahlılar'ın oğulları ve Merarililer'in oğulları.
\p 
\v 20 Levililer'den Ahiya, Tanrı evinin hazinelerinin ve adanmış şeylerin hazinelerinin başındaydı.
\v 21 Ladanoğulları, Ladan'a ait Gerşonlular'ın oğulları, Ladan'a ait ata evlerinin başları Gerşonlu Yehieli.
\v 22 Yehieli’nin oğulları: Zetam ve kardeşi Yoel, Yahve'nin evinin hazinelerinin başındaydılar.
\v 23 Amramlılar'dan, Yitsharlılar'dan, Hebronlular'dan, Uzzielliler'den:
\v 24 Moşe’nin oğlu Gerşom’un oğlu Şevuel hazinelerin yöneticisiydi.
\v 25 Kardeşleri: Eliezer’den, oğlu Rehavya, onun oğlu Yeşaya, onun oğlu Yoram, onun oğlu Zikri ve onun oğlu Şelomot.
\v 26 Bu Şelomot ve kardeşleri, Kral David’in ve atalar evlerinin başlarının, binlerin ve yüzlerin komutanlarının ve ordu komutanlarının adadığı bütün hazinelerin başındaydılar.
\v 27 Savaşlarda kazanılan ganimetlerden bazılarını Yahve'nin evini onarmak için adadılar.
\v 28 Gören Samuel'in, Kiş oğlu Saul'un, Ner oğlu Avner'in ve Seruya oğlu Yoav'ın adadığı her şey, kim bir şey adamışsa, Şelomot'un ve kardeşlerinin eli altındaydı.
\p 
\v 29 Yitsharlılar'dan Kenanya ve oğulları, İsrael üzerine memurlar ve hâkimler olarak dışarıdaki işlere bakmak üzere atandılar.
\v 30 Hevronlular'dan Haşavya ve kardeşleri, bin yedi yüz yiğit adam, Yahve'nin bütün işlerini ve kralın hizmetini, Yarden'in ötesinde batıya doğru İsrael'in gözetimini üstlendi.
\v 31 Hevronlular'dan Yeriyah, ataları evlerinin kuşaklarına göre Hevronlular'ın başıydı. David'in krallığının kırkıncı yılında arandılar ve Gilad'ın Yatser Kenti'nde onların arasında cesur yiğitler bulundu.
\v 32 Akrabaları yiğit adamlardı; atalar evlerinin başları olan iki bin yedi yüz kişiydiler. Kral David, Tanrı'yla ilgili her iş için ve kralın işleri için Ruvenliler, Gadlılar ve Manaşşeliler'in yarım oymağı üzerinde onları gözetmenler olarak atadı.
\c 27
\p 
\v 1 İsrael'in çocukları, sayılarına göre, atalar evlerinin başları, binlerin ve yüzlerin başları ve yılın bütün aylarında krala her ay girip çıkan bölüklerde hizmet eden memurları, her bölüğün yirmi dört bin kişisi vardı.
\p 
\v 2 Birinci ay için, birinci bölüğün başında Zavdiel oğlu Yaşoveam vardı. Onun bölüğünde yirmi dört bin kişi vardı.
\v 3 Kendisi Peres'in çocuklarındandı, birinci ay için bütün ordu komutanlarının başıydı.
\v 4 İkinci ayın bölüğü başında Ahohlu Doday vardı, onun bölüğünde önder Miklot'du; onun bölüğünde yirmi dört bin kişi vardı.
\v 5 Üçüncü ay için üçüncü ordu komutanı, başkâhin Yehoyada'nın oğlu Benaya'ydı. Onun bölüğünde yirmi dört bin kişi vardı.
\v 6 Otuzlar'ın yiğidi ve Otuzlar'ın başında olan Benaya budur. Onun bölüğünde oğlu Ammizavad vardı.
\v 7 Dördüncü ay için dördüncü komutan Yoav'ın kardeşi Asahel ve kendisinden sonra oğlu Zevadya'ydı. Onun bölüğünde yirmi dört bin kişi vardı.
\v 8 Beşinci ay için beşinci komutan İzrahlı Şamhut'tu. Onun bölüğünde yirmi dört bin kişi vardı.
\v 9 Altıncı ay için altıncı komutan Tekolu İkkeş'in oğlu İra'ydı. Onun bölüğünde yirmi dört bin kişi vardı.
\v 10 Yedinci ay için yedinci komutan Efraim'in çocuklarından Pelonlu Heles'ti. Onun bölüğünde yirmi dört bin kişi vardı.
\v 11 Sekizinci ay için sekizinci komutan Zerahlılar'dan Huşalı Sivvekay'dı. Onun bölüğünde yirmi dört bin kişi vardı.
\v 12 Dokuzuncu ay için dokuzuncu komutan Benyaminliler'den Anatotlu Aviezer'di. Onun bölüğünde yirmi dört bin kişi vardı.
\v 13 Onuncu ay için onuncu komutan Zerahlılar'dan Netofalı Maharay'dı. Onun bölüğünde yirmi dört bin kişi vardı.
\v 14 On birinci ay için on birinci komutan, Efraim'in çocuklarından Piratonlu Benaya'ydı. Onun bölüğünde yirmi dört bin kişi vardı.
\v 15 On ikinci ay için on ikinci komutan, Otniel'den Netofalı Helday'dı. Onun bölüğünde yirmi dört bin kişi vardı.
\p 
\v 16 İsrael oymaklarının başında da şunlar vardı: Ruvenliler'den baş Zikri'nin oğlu Eliezer; Şimonlular'dan Maaka'nın oğlu Şefatya;
\v 17 Levi'den Kemuel'in oğlu Haşavya; Aron'dan Sadok;
\v 18 Yahuda'dan David'in kardeşlerinden Elihu; İssakar'dan Mikael'in oğlu Omri;
\v 19 Zevulun'dan Ovadya oğlu İşmaya; Naftalililer'den Azriel'in oğlu Yeremot;
\v 20 Efraim'in çocuklarından Azaziya'nın oğlu Hoşea; Manaşşe'nin yarım oymağından, Pedaya oğlu Yoel;
\v 21 Gilad'daki Manaşşe'nin yarım oymağından, Zekariya oğlu İddo; Benyamin'den Avner'in oğlu Yaasiel;
\v 22 Dan'dan Yeroham'ın oğlu Azarel. Bunlar İsrael oymaklarının komutanlarıydı.
\v 23 Ancak David yirmi yaş ve altındakilerin sayısını almadı. Çünkü Yahve İsrael'i gökyüzünün yıldızları gibi çoğaltacağını söylemişti.
\v 24 Seruya oğlu Yoav sayım yapmaya başladı, ama bitirmedi. Bunun üzerine İsrael üzerine gazap geldi. Sayı Kral David'in Tarihler Kitabı'nda hesaba konulmadı.
\p 
\v 25 Kralın hazinelerinin başında Adiel oğlu Azmavet vardı. Kırlardaki, kentlerdeki, köylerdeki ve kulelerdeki hazinelerin başında Uzziya oğlu Yonatan vardı.
\v 26 Tarlada çalışıp toprağı sürenlerin başında Keluv oğlu Ezri vardı.
\v 27 Bağların başında Ramalı Şimei vardı. Şarap mahzenleri için bağların ürünü başında Şifamlı Zavdi vardı.
\v 28 Ovadaki zeytin ağaçlarının ve yabanıl incir ağaçlarının başında Gedeli Baal Hanan vardı. Yağ mahzenlerinin başı Yoaş'tı.
\v 29 Şaron'da otlayan sürülerin başında Şaronlu Şitray vardı. Vadilerdeki sürülerin başında Adlay oğlu Şafat vardı.
\v 30 Develerin başında İşmaelli Ovil vardı. Eşeklerin başında Meronotlu Yehdeya vardı. Sürülerin başında Hagritli Yaziz vardı.
\v 31 Bütün bunlar Kral David'in mülkünün yöneticileriydi.
\p 
\v 32 David'in amcası Yonatan da danışman, anlayışlı bir adam ve yazıcıydı. Hakmoni'nin oğlu Yehiel kralın oğullarıyla birlikteydi.
\v 33 Kralın danışmanı Ahitofel'di. Kralın dostu Arklı Huşay'dı.
\v 34 Ahitofel'den sonra Benaya'nın oğlu Yehoyada ve Aviyatar vardı. Kralın ordusunun başkomutanı Yoav'dı.
\c 28
\p 
\v 1 David, İsrael'in bütün beylerini, oymak beylerini, krala bölük bölük hizmet eden birlik komutanlarını, binlerin başlarını, yüzlerin başlarını ve kralın ve oğullarının bütün malının ve mülklerinin yöneticilerini, subayları ve yiğitleri, bütün cesur yiğitleri Yeruşalem'e topladı.
\v 2 O zaman Kral David ayağa kalkıp şöyle dedi: “Ey kardeşlerim ve halkım beni dinleyin! Ben, Yahve'nin Antlaşma Sandığı için ve Tanrımız'ın ayaklarının basamağı için bir dinlenme evi yapmak yüreğimdeydi. Onun için hazırlık da yapmıştım.
\v 3 Ama Tanrı bana, 'Adım için bir ev yapmayacaksın, çünkü sen savaş adamısın ve kan döktün' dedi.
\v 4 Ancak İsrael'in Tanrısı Yahve, İsrael üzerine daima kral olmak için babamın bütün evinden beni seçti; çünkü hükümdar olarak Yahuda'yı, Yahuda evinden de babamın evini seçti; ve bütün İsrael üzerine babamın oğulları arasında beni kral yapmaktan hoşnut oldu.
\v 5 Bütün oğullarım arasından (çünkü Yahve bana birçok oğul verdi), İsrael üzerinde Yahve'nin krallığının tahtına oturması için oğlum Solomon'u seçti.
\v 6 Bana şöyle dedi, 'Oğlun Solomon evimi ve avlularımı yapacak; çünkü onu oğlum olarak seçtim ben de onun babası olacağım.
\v 7 Bugün olduğu gibi, buyruklarımı ve kurallarımı yerine getirmeyi sürdürürse, onun krallığını daima pekiştireceğim.'
\p 
\v 8 Şimdi, bütün İsrael'in gözü önünde, Yahve'nin topluluğu önünde ve Tanrımız duyarken, Tanrınız Yahve'nin bütün buyruklarını tutun ve araştırın ki, bu güzel ülkeyi mülk olarak edinesiniz ve onu daima sizden sonraki çocuklarınıza miras olarak bırakasınız.
\p 
\v 9 Sen, oğlum Solomon, babanın Tanrısı'nı tanı ve ona tam bir yürekle ve istekli bir düşünceyle hizmet et; çünkü Yahve bütün yürekleri araştırır ve düşüncelerin bütün hayal ettiği şeyleri anlar. Eğer onu ararsan, sana kendisini buldurur; ama eğer onu bırakırsan, seni sonsuza dek atar.
\v 10 Şimdi dikkat et, çünkü kutsal yer için ev yapmak üzere Yahve seni seçti. Güçlü ol ve yap.”
\p 
\v 11 Sonra David, oğlu Solomon'a tapınağın eyvanla evlerinin, hazinelerinin, üst odalarının, iç odalarının, merhamet yerinin planlarını verdi;
\v 12 Yahve'nin evinin avluları, çevredeki bütün odalar, Tanrı evinin hazineleri ve adanmış şeylerin hazineleri için;
\v 13 kâhinlerin ve Levililer'in takımları için, Yahve'nin evinin hizmetinin bütün işi için, Yahve'nin evindeki bütün hizmet kapları için,
\v 14 altın kaplar için, tartısına göre altından, her türlü hizmetin bütün kapları için, bütün gümüş kaplar için, tartısına göre gümüşten her türlü hizmetin bütün kapları için, Ruh aracılığıyla sahip olduğu her şeyin planlarını verdi.
\v 15 Her şamdanla ve onun kandillerinin tartısına göre, altın şamdanların ve kandillerinin tartısını; ve her şamdanın hizmetine göre gümüş şamdanlar için, her bir şamdanın ve kandillerinin tartısına göre onları da tartsın;
\v 16 ve sergi ekmeği masaları için, her masa için altın; ve gümüş masalar için gümüş tartısını;
\v 17 ve saf altından çatallarının, leğenlerin ve kâselerin tartısını; ve altın taslar için, her tasın tartısını, gümüş taslar için, her tasın tartısını;
\v 18 ve buhur sunağı için, saf altının tartısını; ve kanatlarını yapıp Yahve'nin Antlaşma Sandığı'nı örten Keruvlar arabasının planlarına göre altın tartısını verdi.
\v 19 David, “Bütün bunlar,” dedi, “Bu örneğin bütün işleri, Yahve'nin elinden bana yazılı olarak anlatıldı.”
\p 
\v 20 David oğlu Solomon'a, “Güçlü ve cesur ol, yap” dedi, “Korkma, yılma, çünkü Yahve Tanrı, benim Tanrım seninle birliktedir. Yahve'nin evinin hizmeti için bütün iş bitinceye dek seni başarısızlığa uğratmayacak, seni bırakmayacaktır.
\v 21 İşte, Tanrı'nın evinin bütün hizmeti için kâhinlerin ve Levililer'in bölükleri var. Her türlü hizmette, becerikli olan her istekli adam her türlü işte seninle birlikte olacak. Komutanlar ve bütün halk da tümüyle senin buyruğunda olacak.”
\c 29
\p 
\v 1 Kral David bütün topluluğa şöyle dedi: “Tanrı'nın tek seçtiği oğlum Solomon henüz genç ve toydur; yapılacak iş de büyüktür. Çünkü bu saray insan için değil, Tanrı Yahve içindir.
\v 2 Şimdi Tanrım'ın evi için bütün gücümle altın şeyler için altın, gümüş şeyler için gümüş, tunç şeyler için tunç, demir şeyler için demir, ağaç şeyler için ağaç, ayrıca oniks taşları, kakma taşlar, ziynet taşları, çeşitli renkli taşlar, her türlü değerli taşlar ve bol miktarda mermer taşları da hazırladım.
\v 3 Bundan başka, Tanrım'ın evini sevdiğim için, madem ki kendi altın ve gümüş hazinem vardır, kutsal ev için hazırladığım her şeyden daha fazlasını Tanrım'ın evine,
\v 4 Ofir altınından üç bin talant\f + \fr 29:4 \ft Bir talant yaklaşık 30 kilogram veya 66 pound veya 965 Truva onsudur, dolayısıyla 3000 talant yaklaşık 90 metrik tondur\f* altını ve evlerin duvarlarını kaplamak için yedi bin talant\f + \fr 29:4 \ft yaklaşık 210 metrik ton\f* saf gümüşü;
\v 5 altın şeyler için altını, gümüş şeyler için gümüşü ve zanaatkârların elleriyle yapılacak her türlü işler için veriyorum. Öyleyse kim bugün gönüllü olarak kendini Yahve'ye adıyor?”
\p 
\v 6 Atalar evlerinin beyleri, İsrael oymaklarının beyleri, binlerin ve yüzlerin komutanları, kralın işlerinin yöneticileriyle birlikte gönülden sundular.
\v 7 Tanrı'nın evinin hizmeti için beş bin talant\f + \fr 29:7 \ft Bir talant yaklaşık 30 kilogram veya 66 pound veya 965 Truva onsudur, dolayısıyla 5000 talant yaklaşık 150 metrik tondur\f* altın, on bin darik,\f + \fr 29:7 \ft Daric, Pers kralı tarafından basılan, her biri yaklaşık 8,4 gram veya 0,27 Truva onsu ağırlığındaki altın sikkeydi.\f* on bin talant gümüş, on sekiz bin talant tunç ve yüz bin talant demir verdiler.
\v 8 Kendilerinde değerli taşlar bulunanlar, Gerşonlu Yehiel'in eliyle Yahve'nin evinin hazinesine verdiler.
\v 9 O zaman halk sevindi, çünkü gönülden sunmuşlardı, çünkü bütün yürekle Yahve'ye gönülden sundular. Kral David de büyük bir sevinçle sevindi.
\p 
\v 10 Bunun üzerine David bütün topluluğun önünde Yahve'yi övdü. David, “Ey Yahve, atamız İsrael'in Tanrısı, sen sonsuzluklar boyunca yücesin” dedi.
\v 11 “Ey Yahve, büyüklük, güç, görkem, zafer ve heybet senindir! Çünkü göklerde ve yerde olan her şey senindir. Ey Yahve, krallık senindir ve sen baş olarak her şeyden yükseksin.
\v 12 Zenginlik ve onur senden gelir ve sen her şeye hakimsin! Güç ve kudret senin elindedir! Büyük kılmak ve herkesi güçlendirmek senin elindedir!
\v 13 Şimdi, ey Tanrımız, biz sana şükrederiz ve görkemli adını överiz.
\v 14 Ama ben kimim ve halkım nedir ki, böyle gönülden sunabilelim? Çünkü her şey senden gelir ve biz sana seninkilerden verdik.
\v 15 Çünkü biz senin önünde yabancıyız ve bütün atalarımız gibi misafiriz. Yeryüzündeki günlerimiz bir gölge gibidir, geriye bir şey kalmaz.
\v 16 Ey Tanrımız Yahve, kutsal adına bir ev yapmak için hazırladığımız bütün bu hazine senin elinden gelmiştir ve hepsi senindir.
\v 17 Ey Tanrım, yüreği sınadığını ve doğruluktan hoşlandığını da biliyorum. Bense yüreğimin doğruluğuyla bütün bunları gönülden sundum. Şimdi burada bulunan halkının sana gönülden sunduğunu sevinçle gördüm.
\v 18 Atalarımız Avraham'ın, İshak'ın ve İsrael'in Tanrısı ey Yahve, bu isteği daima halkının yüreğinin düşüncelerinde tut ve yüreğini kendine hazırla;
\v 19 oğlum Solomon'a da senin buyruklarını, tanıklıklarını ve kurallarını tutmak için, bütün bu şeyleri yapmak için ve hazırlığını yaptığım sarayı bina etmek için bütün bir yürek ver.”
\p 
\v 20 Sonra David bütün topluluğa, “Şimdi Tanrınız Yahve'yi övün!” dedi.
\p Bütün topluluk atalarının Tanrısı Yahve'yi övdüler ve başlarını eğip Yahve'nin ve kralın önünde yere kapandılar.
\v 21 Yahve'ye kurbanlar kestiler ve o günün ertesi gün Yahve'ye yakmalık sunular sundular; bin boğa, bin koç ve bin kuzu, onların dökmelik sunularını, bütün İsrael için bol miktarda kurbanlar sundular.
\v 22 O gün büyük bir sevinçle Yahve'nin önünde yiyip içtiler. David oğlu Solomon'u ikinci kez kral yaptılar ve onu Yahve'nin önünde hükümdar, Sadok'u da kâhin olarak meshettiler.
\p 
\v 23 O zaman Solomon babası David'in yerine Yahve'nin tahtına oturdu ve başarılı oldu; bütün İsrael ona itaat etti.
\v 24 Bütün beyler, yiğitler ve Kral David'in bütün oğulları Kral Solomon'a boyun eğdiler.
\v 25 Yahve, Solomon'u bütün İsrael'in gözünde çok büyüttü, İsrael'de kendisinden önce hiçbir kralın üzerinde olmayan krallık yüceliğini ona verdi.
\p 
\v 26 Yişay oğlu David bütün İsrael üzerinde hüküm sürdü.
\v 27 İsrael'de kırk yıl hüküm sürdü; Hevron'da yedi yıl hüküm sürdü, Yeruşalem'de de otuz üç yıl hüküm sürdü.
\v 28 Güzel ihtiyarlıkta, günlere, zenginliğe ve onura doymuş olarak öldü; ve oğlu Solomon onun yerine kral oldu.
\v 29 Kral David'in işleri, ilk ve son işleri, işte bunlar, gören Samuel'in tarihinde, Peygamber Natan'ın tarihinde ve gören Gad'ın tarihinde,
\v 30 onun bütün krallığı ve kudreti, İsrael ve bütün ülkelerdeki krallıkların dahil olduğu olaylarla birlikte yazılıdır. 
