\id JER - Aguaruna 
\h Jeremías 
\toc1 Jeremías 
\toc2 (Jeremías) 
\toc3 Jer. 
\mt1 Jeremías 
\c 1  
\ms1 Jerusalén Judájai pachisa chicham etsegkamu 
\mr (1—25) 
\s1 Yama nagkamchaku agagbau 
\p  
\v 1 Profeta Jeremías Hilquíasa uchiji sacerdote wegantu, Benjamígka nugken yaakat Anatot pujujakua nuna, Tuke Pujuu chicham etsegtugkata tusa ausauwai.  
\v 2 Tuke Pujuu Jeremíasan ausauwa nunak, Amónka uchiji Josías Judá apuji wajas trece mijan inamai, chichaman ujakui.  
\v 3 Tuja nuigtushkam Josíasa uchiji Joaquim Judá wegantu aidaun apuji aajakua duishkam Apajuík Jeremíasnak ausauwai. Tuja Josíasa uchiji tikich Sedequías Judá apuji wajasa inabaujin nantu Julion achiak, once mijanan ejeyuwa nunak, Apajuík Jeremíasjaig kuashta chichasui. Nunú tsawantin Jerusalégkan jetekag depetuk, Israel aents aidaun achijag yajuakajui. 
\s1 Apajuí Jeremíasan mina takagtusta tusa inagbau 
\p  
\v 4 Tuke Pujuu mina chichagtak: 
\b  
\q1  
\v 5 “Wi aminak eke akiintsuminig, 
\q1 mina chichamjun ashí nugkanum etsegtugkati tusan etegkauwaitjame”, 
\q1 tujutmayi. 
\q1  
\v 6 Tusa tujutkui wi ayaakun: 
\q1 “Chah, apu Tuke Pujuuwah, wika tsakataitag nuniau asan 
\q1 jintiaja chichatnak dekatsjai”, tibaijai. 
\b  
\q1  
\v 7 Tusa tai nii chichagtak: 
\q1 “Tsakataitjai tusamek tiipa. 
\q1 Wi amina tuwi awemattagme nuwi amek wetatme, 
\q1 nunikam wi titatjam nunú etsegkattame. 
\q1  
\v 8 Makichkish ishamkagtukaipa 
\q1 wi aminak kuitamkattagme, 
\q1 wi nunak dekas umiktinjun tajai”, tujutmayi. 
\b  
\p  
\v 9 Nuna tusa Tuke Pujuu wenujun achigtuk chichagtak: 
\q1  
\v 10 “Antukta nijah, aminak yamai nagkamas 
\q1 aents nugka muunnumia aidaush, 
\q1 nuna apuji aidaush antugtamkagtinun, tuja tsaiktinun, 
\q1 ijinatnun, tsaikbau ataktu yaaktamkatnun 
\q1 ajakmatnum senchimtikajame”, tujutmayi. 
\b  
\p  
\v 11 Nuna tusa chichagtak: “¿Jusha wajimpaya?” tujutmayi. Tujutkui wi ayaakun: “Anka almendro kanawegai”, tibaijai. Tusa tai Tuke Pujuu aijak:  
\v 12 “Dekas tame, wika mina chichameg uminkati tusan antaku pujuttajai”, tujutmayi. 
\p  
\v 13 Nuna tujuti ataktu chichagtak: “¿Jusha wajimpaya?” tujutkui wi ayaakun: “Ichinak ekenkamu kuwaak nujinmanini yantak ukagattak eketui”, tibaijai. 
\p  
\v 14 Tusa tai Tuke Pujuu chichagtak: 
\b  
\q1 “Nujinmaya juwaki tsumujiya aatus aents 
\q1 batsata nunak suwimkan susattajai. 
\q1  
\v 15 Dutikakun aents nugka muunnumia 
\q1 nujinum batsata nunak ashí untsuktatjai. 
\q1 Dutika ai nuna apuji aidau kaunawag 
\q1 Jerusalégnum waitaiya nuwi kaunawag, 
\q1 yaakat peejamua nuna tenteawag batsamtusag, 
\q1 Judá wegantu aidaun jeteka depetuk 
\q1 achija yajuakagtatui. 
\q1  
\v 16 Nuni suwimkan susattajai, 
\q1 aents aidau mina umigtutsuk wainka apajuímtain 
\q1 tikich aents aidau emematin aina 
\q1 nuna dakumak najanawag, nuna emematuinak 
\q1 kugkuin incienson apenau asagmatai. 
\q1  
\v 17 Untsu amek umintsata; 
\q1 nunika weme wi amina titatjam nunú ashí etsegkata. 
\q1 ¡Wainka ishamkagtukaipa! 
\q1 Ishamkagtakminig shiwagjai igkuniak 
\q1 sapijin kujaiti titatjame. 
\q1  
\v 18 Wi aminak yaakat peejamu utumainchawa iman, 
\q1 jiju hierro ajiamu kupinchauwa iman, 
\q1 tuja yaakat broncejai peejamu tsaika 
\q1 utumainchawa iman awajsajame. 
\q1 Judá wegantu aina nuna nugkenig, 
\q1 tuja dita apuji aina nujaishkam, 
\q1 sacerdote aina nujai nagkamas 
\q1 ashí aents aina nuna chichagkati tusan 
\q1 senchimtikajame. 
\q1  
\v 19 Jetepakagtatui, tujash depetamkachagtinai, 
\q1 wagki wi amina kuitamkatasan, 
\q1 amejai pujau asamtai. 
\q1 Witjai Tuke Pujuu ashí senchigtinnuk, 
\q1 junak dekas uminkatnun tajai”, tiuwai. 
\c 2  
\s1 Israel aents aidau pegkegchaun takainak Apajuíjai shiwagmagawagbau 
\p  
\v 1 Tuke Pujuu mina chichagtak: 
\p  
\v 2 “Jerusalén wetá, nunikam ashí aents aidau senchi untsumka chichagkum aatus Tuke Pujuu tawai tita: 
\q1 “ ‘Ame tsakat asam ima minak umigtin ayum nuna aneakjai. 
\q1 Tuja yama nuwatkamu aishin aneemaina 
\q1 imatikam anentiume, nuniau asam 
\q1 uwejush ajakmamash tsapamainchaunum 
\q1 juki emaish pataetugsam miniyume. 
\q1  
\v 3 Israel aents aidauk midau agtin etegkamu ayi, 
\q1 ditak ajak ajakmamu yama nagkamchak 
\q1 shiig pegkejan nejegama iman aajabi. 
\q1 Tuja ditan waitkainakuig, 
\q1 wi nunak suwimkan su ayajai. 
\q1 Nunak dekas dutikamujun’, tajai”, tiuwai. 
\b  
\p  
\v 4 ¡Israel aents aidauwah, Apajuí chichame antuktajum!  
\v 5 Tuke Pujuu chichagtamak: 
\b  
\q1 “Atumi apachjum aajaku aina dusha 
\q1 ¿waji utugchatan waitjukajaya minash 
\q1 tupanjujush ainawa? 
\q1 Dakumka najanamu pegkegchaun emematu yujau asag, 
\q1 ditashkam nuninuk wajasajui. 
\q1  
\v 6 Nunidau asag, dita apachji aidau 
\q1 Egipto nugkanum batsatun jiija yajuakan, 
\q1 uwejush yumi atsau, muja yumpunjau aidau, 
\q1 ishamain aents aidaush pujumainchau, 
\q1 makichkish nagkaemamainchau 
\q1 ishamain wegajunum wi kuitamsan 
\q1 emauwaitag nunak aneetsuk pachitkachajui. 
\q1  
\v 7 Wi atumnak juju nugka pegkeja juwi 
\q1 ajakmawag yuwatnume tusan ikaunmawaitjime. 
\q1 Tujash atum kaunajum mina nugkag pegkeg ayá nunú emesjauwaitjume. 
\q1 Nuadui mina nugkag pegkeg ayá duka tsumain awajsaugme. 
\q1  
\v 8 Sacerdote aidaush mina pachittsag inimsachu ainawai; 
\q1 tuja mina chichamjun jintinkagtin aidaush 
\q1 makichkish waitkachaju ainawai, 
\q1 apu aidaush pegkegchaun takamjuttsau ainawai, 
\q1 tuja mina profetag aidaushkam 
\q1 Baalan etsegtuinak, mina chichamjunak 
\q1 etsegkachu ainawai. 
\q1 Nunidau asag dakumka najanamu aidaun 
\q1 wainak emematujaku ainawai. 
\q1  
\v 9 Nuadui atumnak, atumi uchijum aidaun, 
\q1 tijajum aidaujaí suwimkan jukitnume tusan umigkattajime. 
\q1 Nunak wi Tuke Pujuun dekas umiktinjun tajai. 
\b  
\q1  
\v 10 “Etsa akaetaiya nuni nayantsa ajuntaijin 
\q1 yaakat ayá nuwi wetajum, 
\q1 nuniakjum Quedar nugkanum aents awematajum. 
\q1 Dutikajum inimsatajum 
\q1  
\v 11 tikich aents dakumka najanamun emematin aina dusha, 
\q1 atum wajukeajum ankampash 
\q1 nuna idayinak, tikichin nemaju yujau aina. 
\q1 Nunú aents aidauk wainka apajuímtai dakumka 
\q1 najanamun pegkegchaun emematin ainayatkush, 
\q1 yapa yapajiakuag wechau ainawai. 
\q1 Tujash mina aentsug aina duka dakumka 
\q1 najanamu aidaun yujajak, dekas wi 
\q1 Tuke Pujuu senchigtinaitag nunak idaitusaje. 
\q1  
\v 12 Nugka múunta duka nuna antuk 
\q1 puyatuk ishamak senchi kujawai. 
\q1 Witjai Tuke Pujuunuk. Nunak dekas tajai” tiuwai. 
\b  
\q1  
\v 13 “Mina aentsug aidauk jimajan tudaun takamsaje: 
\q1 Yumi pukuni pujutan sukagtina duka witjai, 
\q1 nuniaig mina kajimatjukiag idaitusaje. 
\q1 Nuninak yumi aimtain chigkaejaun tikichin umikaje.” 
\s1 Israel aents aidau  //  Apajuín umigkachaju asag  //  suwimka jukiag waittsagbau 
\q1  
\v 14 “Israel aents aidauk wainka inaku waitkataig ainatsui, 
\q1 Israel aents aidauk inaku waitkatai atinuk akiinachajui. 
\q1 Tujash ¿wagka imatika waitkamash ainawa? 
\q1  
\v 15 ¿Wagka imatikash leónjai betek jetenakush 
\q1 senchish untsumainawa? 
\q1 Dita nugkega duka yaaktaji aidau apegkam 
\q1 pegkegchau wajas bashiak awai. 
\q1 Nuwi pujauk makichkish atsawai. 
\q1  
\v 16 Menfisnumia suntag aidau, 
\q1 Tafnesnumia aidaujai buukmin tsaigtamjaje. 
\q1  
\v 17 Nunak wi Tuke Pujuu atumi Apajuíjum asan, 
\q1 kuitamka itamaitkujum mina kajimatjukiu asajum 
\q1 dutikam asaugme. 
\q1  
\v 18 Tuja yamaish atumesh 
\q1 ¿waji wakegakjumea 
\q1 egiptunmaya suntag aidau asirianmaya aidaujai 
\q1 atujatkatajum tusa ditajai chicham umikmi 
\q1 tusagmesh tajume? 
\q1  
\v 19 Atumek intimkiu, pegkegchau takamin ainajum 
\q1 duwi dekas nunin ainagme tama ajume. 
\q1 Nuadui mina umigtichagtaish, 
\q1 waji utugchatak miniawa nunú wainkajum 
\q1 dekaskeapi titajum. 
\q1 Witjai apu Tuke Pujuu ashí senchigtinnuk, nunak dekas tajai. 
\q1  
\v 20 Yaunchuk nagkamsajum wijai shiwagmagajum, 
\q1 mina umigtut dakitakjum: 
\q1 ‘Apajuí umigtak dakitaji’, tiuwaitjume. 
\q1 Tau asajum, mina umigtutsuk 
\q1 dakumka najanamu aidau nain aidaunum emematkujum, 
\q1 numi kampuja aidau wakentin nuwa akika dutiktaijai betek wajasjum, 
\q1 pegkegchau takama yujayugme. 
\q1  
\v 21 Wi atumnak uva numiji 
\q1 dekas shiig pegkeg etejamu juki ajamaina 
\q1 iman amainun waji ajataitkuish ajauwaitjime. 
\q1 Tujash ¿wagka imanikjumesh pegkegchaush wajasugme? 
\q1 ¡Imaniku asagmin wainkatag takunush waintsujime! 
\q1  
\v 22 Lejiajai nijamakjumesh, tuja jabón pegkeg aidaujai 
\q1 atum wakegamu nijamakjumesh, 
\q1 atumi pegkegchaujum makichkish esakaumaitsugme. 
\q1 Witjai Tuke Pujuunuk, nunak dekas tajai. 
\q1  
\v 23 Ibau pegkegchau ainayatkugmesh 
\q1 ¿wajukeakjumea iik pegkegchauk takatsji, 
\q1 tuja dakumka najanamu aina dushakam 
\q1 emamatuinatsji tajume? 
\q1 Nijah, nugka Ben-hinom aajakua nuwi 
\q1 wakeen pujusjumesh wajukin ayugme nunú adeagtajum, 
\q1 nunikjum dekaskeapi titajum. 
\q1 Atumek camello numpajak emetnag 
\q1 pujuschamin wajama nujai betek ainagme. 
\q1  
\v 24 Atumek burro numpajak 
\q1 aishmag entsamjutkati tusa egak, 
\q1 dase dasentai mejea, mejea, mejea wajak 
\q1 tupikaki ikam akumkuig, 
\q1 makichkish emetmaitsu nujai betek wajagme. 
\q1 Imaniau asamtai, aishmag egakug yupichuch igkuinai. 
\q1  
\v 25 ¡Israel aents aidauwah, 
\q1 sapatjinchau tupika yujasjum dawem ichiajaigpa, 
\q1 kitakai jinawaigpa! tusa tamash, 
\q1 atum chichaakjum: 
\q1 Atsa, duka makichkish nunikchattawai, 
\q1 iik tikich aents aidau dakumkamun emematin aina 
\q1 nunú emematmi tusa wakegau asa, 
\q1 ditajai shimaji tusajum shimutjume. 
\s1 Israel aents aidauk dita pegkegchaujin suwimak suwam atin 
\q1  
\v 26 Atumek kasa kasamkatatus wekagu wainkam 
\q1 datsaamama numamtuk, atumi apujum aidaujai, 
\q1 sacerdote aidaujai, profeta aidaujai ashí datsagtatjume. 
\q1  
\v 27 Atumek numi chichagkujum: 
\q1 ‘Ametme iina apajimek’, tajume. 
\q1 Tuja kaya chichagkujum: 
\q1 ‘Ametme iina dukujig’, tajume. 
\q1 Tujash atumek minak diigtsuk tuntupmatjagme. 
\q1 Nuniayatkujum ishamainnum jegakjumek: 
\q1 ‘¡Ayamkagtukta!’ tusajum segatjume. 
\q1  
\v 28 Tuja atum aidautijum atumek dakumka najanamu 
\q1 apajuíma yujaujum dusha ¿wajukawaje? 
\q1 Atumi apajuímtai aidauk yaakat kuashta iman ainawai. 
\q1 Nunú aidau kaunawag atum ishamain igkuagminish 
\q1 ayamjutpaktinme. 
\q1  
\v 29 ¡Atumek minak tuke intimjutin ainagme! 
\q1 Nunin asajum minak wainkagmek pegkegchauk chichagtumaitsugme. 
\q1 Witjai Tuke Pujuunuk, nunak dekas tajai. 
\q1  
\v 30 Atumi uchijum aidauk 
\q1 suwimak suwakuish wainka dutikmainai, 
\q1 wagki imanik suwimka juinakush makichkish unuimainatsui. 
\q1 Atumek león kajeaujai betek 
\q1 mina profetag aidau ijinawaitjume. 
\q1  
\v 31 Tuja atum yamai uchi aidautigmeshkam 
\q1 Tuke Pujuu chichame antuktajum. 
\q1 Wika uwejush nimpain asamtai, 
\q1 waittayama dutikankesh waitkachuitjime, 
\q1 tuja waa suwenum pujusa waittayama 
\q1 dutikankesh waitkachuitjime. 
\q1 Dutika waitkashtayaitkugmesh ¿wagka iik 
\q1 agkan batsatji, nuniau asa ataktuk 
\q1 aminak emematchattagme tusagmesh tujutjume? 
\q1  
\v 32 Nuwa aishinatnuk jáanch aishinku nugkutainak 
\q1 patakumtai aidaujaig makichkish kajimatbaitsui. 
\q1 Tujash mina aentsug aidauk yaunchuk 
\q1 minak kajimatjukiaje. 
\q1  
\v 33 ¡Amek pakijintai aina nuanuig shiig yachaitme! 
\q1 Iman asamin nuwa akika dutiktai aina duka 
\q1 aminiyan unuimainawai. 
\q1  
\v 34 Amina jáanchjum aidauk 
\q1 aents pegkegchaun takachu aina nuna numpen, 
\q1 ujudauch aidau numpejai maatug numpak wajasui. 
\q1 Makichkish takamsachu aig, tsagkugtsuk 
\q1 tuke aneasam mainaitme. 
\q1  
\v 35 Nuninaitkum datsantainkas chichaakum: 
\q1 ‘Wika Apajuí kajegtukti tusanuk 
\q1 pegkegchaunak takamtsujai’, tame. 
\q1 Ayu kame takamtsujai tusa imatu asamin, 
\q1 nuna dekajuatasan apu chichama inagdau aina 
\q1 nuwi ematjame. 
\q1  
\v 36 ¿Wagka tujash atuniktinjum egaakmesh 
\q1 imanikmesh waugtame? 
\q1 Auk Asiria nugkanmaya aidau idaitamsa antsag 
\q1 Egipto nugkanmayashkam idaitamsattawai. 
\q1  
\v 37 Mina kumpag ainawai tame nunak 
\q1 wi dakitjan idaisajai. 
\q1 Nuadui amek egiptunmaya aidaujai atunikan maaniatjai 
\q1 tukamam depetamkagmatai, 
\q1 datsaaja wake besekam wakitkittame. 
\q1 ¡Amina kumpajum ainakush makichkish yaimpakchagtatui! 
\q1 tujamui Tuke Pujuu”, tiuwai Jeremías. 
\c 6  
\s1 Israel aents aidau Apajuín intimjukiagbau 
\q1  
\v 16 Apajuí niina aentsji aidaun chichajak: 
\q1 “Jintanum wajasjum diistajum, 
\q1 yaunchuk jinta pegkeg aajakua dusha 
\q1 tuki ayi tusajum inimsatajum. 
\q1 Jinta pegkeja nunú ainkujum ayamat igkugtatjume”, 
\q1 tujamui. 
\q1 Tujash dita chichainak: 
\q1 “Atsa, iik nii tawa nunú umigtak dakitaji”, tuinawai. 
\q1  
\v 17 Jinta niimin aidau utugchat atai, etsegkatnun 
\q1 Apajuí ishiaku asa, Israel aents aidaun chichajak: 
\q1 “Dita chicham atai etsejainakui antuktajum” tiuwai. 
\q1 Tusa tamashkam dita chichainak: 
\q1 “Iik nunú antutak dakitaji”, tuinawai. 
\q1  
\v 18 Tusa tiagtai Apajuí chichaak: 
\q1 “Mina aentsug aidaunash itugkagtajak 
\q1 nunú tikich nugkanmaya aidautigmesh dekatajum. 
\q1  
\v 19 Ashí nugkanmaya aidautigmesh antuktajum: 
\q1 Mina aentsug aidau dita wakegamun 
\q1 takastag tuidau asag, 
\q1 wi chicham umiktajum timawa nuna 
\q1 dakitug umitsuk idaisaju asagmatai, 
\q1 wi ditanak suwimkan susagtatjai. 
\q1  
\v 20 ¿Wagka Sabá nugkanmaya kugkuin incienso 
\q1 jukigmesh itagtuaugme? 
\q1 ¿Wagka tikich nugka atushtanmaya 
\q1 kugkuin jukigmesh itagtuaugme? 
\q1 Atum anentag itaamu aidau, tuja mina emematjaku 
\q1 kuntin maa nuna neje ashí apeajum duka 
\q1 minak shiig awajtatsui.” 
\q1  
\v 21 Nuna tusa Tuke Pujuu chichaak: 
\q1 “Wi shiwag aidaun ishitkattajime, 
\q1 dutika ai jetepakag, 
\q1 uchijum aidaun, 
\q1 atum pujamunum nuna yantamen ijunag pujuidaunak 
\q1 atumi kumpaji aidaujai ashí ijinatnume, tusan”, tiuwai. 
\s1 Nujinmanini jeteka ijinam agtin 
\q1  
\v 22 Tuke Pujuu chichaak: 
\q1 “Aents atushat nujinum batsamin senchigtin aidau 
\q1 uminainawai maaniawagtatus. 
\q1  
\v 23 Suntag aidauk puyag aidaun akentai aidaujai 
\q1 yajuakag umintsaje; 
\q1 ditak magkagtin wait anenkagtuchu ainawai. 
\q1 Dita untsubaujig nayants uutbaujai betekai 
\q1 caballonum ekemiag mininawai 
\q1 Jerusalégkan jetekagtatus”, tiuwai. 
\q1  
\v 24 Nuna aents aidau antukag chichainak: 
\q1 “Nunú chicham dekawaja 
\q1 sapigmainaku kakaumainchau dekapeaji, 
\q1 nuniaku nuwa tsawanji 
\q1 jegajim uchin najaimak waitama imaniaji. 
\q1  
\v 25 Nuadui makichkitigmekesh ajanmak wegpajum, 
\q1 tuja jinta ainjagmesh yujasaigpajum, 
\q1 ¡shiwag aidau puyaja yajuakag mininawai! 
\q1 ¡Ashí yantamnumak sapigmainawai! 
\q1  
\v 26 Mina aentsug aidauwah, 
\q1 jáanch wake besemag pujaku nugkutai nugkugjum 
\q1 yuku tadaetugtajum, 
\q1 nunikjum makichik uchi pujau jakamtai, wake 
\q1 besemag dekapeaku buutmaina imanikjum buuttajum; 
\q1 wagki iina ijipawagtinuk dukap atsuk 
\q1 kautjamkagtatui”, tibaijai. 
\q1  
\v 27 Tuja Tuke Pujuu mina chichagtak: 
\q1 “Wi aminak mina aentsug aina nuna pujutish 
\q1 wajukuk ainawa nuna diigsati tusan 
\q1 apusabiagme”, tujutmayi. 
\q1  
\v 28 Tujutkui wi ayaakun: 
\q1 “Ditak intimkiu, tsanumkagtin, chichama antuchu, 
\q1 pegkeja iman wantinaidau, tujash 
\q1 chichamesh pegkegchau antumtikmainchau 
\q1 bronce, hierro katsugma iman ainawai. 
\q1  
\v 29 Jiju jinum jiyamak kuwija 
\q1 pegkegchaujin utsanak pegkeg weawai, 
\q1 tujash aents pegkegchau aina nuna 
\q1 iwagmainuk atsawai. 
\q1 Nunú iwajatag takuish, wainka tsawan megkaemainai. 
\q1  
\v 30 Nunin asagmatai ame idaisau asamin: 
\q1 ‘Plata pegkegchau asagmatai utsagbau’ 
\q1 tuu adaikagtinai.” 
\c 7  
\s1 Jega Apajuí emematku ijuntai jegamkamunum Jeremías chichagkagtukbau 
\q1  
\v 1 Tuke Pujuu Jeremíasan chichajak: 
\p  
\v 2 “Jega Apajuí emematku ijuntainum wetá, nunikam nuwi wajasam juju chicham etsegkum: ‘Judá wegantu aidautijum Apajuí ememattag tusajum juju jeganum utsanin aidautijum, Tuke Pujuu Israel aents aidaun Apajuíji ashí senchigtina nuna chichamega nunú antuktajum: 
\b  
\q1 “ ‘Atumi pujutjum, pegkegchau takataijum aidaujai 
\q1 iwagmamjatajum, nunikagmin kuashat tsawan 
\q1 juju nugka juwi iwaku batsamsatnume titatjime. 
\q1  
\v 4 Waita jintinkagtin aidau chichagtamainak: 
\q1 ¡Jega Apajuí emematku ijuntaig jujuwai, 
\q1 tusa ujapainakuish, duka antugkaigpa! 
\q1  
\v 5-7 Atumi pujutjum iwajatajum, 
\q1 nuniakjum tikich aidaujaish, pegkegnum yainiktajum, 
\q1 tuja aents tikich nugkanmaya aidau, 
\q1 bitaik aidau, waje aidau, shiig akikchatnaitkujum 
\q1 inaku waitkajum nunú idaisatajum. 
\q1 Nuniakjum aents takamsachu aig, 
\q1 maajum dushakam idaisajum, 
\q1 nuigtush wainka apajuímtai aidau emematkujum, 
\q1 atumek pegkegchau wegajum nunú ashí idaisagminig, 
\q1 juju nugka juna 
\q1 atumi apachjum aidaun susauwaitag nuwi 
\q1 kuashat tsawan iwaku batsamsatnume titatjime. 
\b  
\p  
\v 8 “ ‘¡Tujash atumek wait chicham, atumnash pegkegnumkesh yaimpakchatna nunú ima dekas antugjume!  
\v 9 Atumek kasamjume, magkagtagme, tikichi nuwejai tsanijinjume, nuninaitkujum tsanumkujum Apajuí anagmagme, tuja wainka apajuímtai aidau Baal tikich aina nujai yaunchkesh wainchau ainayatkujum emematkujum kugkuin incienso apé yujagme.  
\v 10 Nunin ainayatkujum juju jega mina emematjaku ijuntaya juwi kaunajum, juju jega juwi pujakuits, uwemtak jumainaitai tajume. Nuadui agá jiinkigmek pegkegchau tsumain wi dakitamu aina nunú takagme.  
\v 11 Atumek mina emematjaku ijuntai jegamkamua duka kasa batsamtai emaugme, wika nunak ashí wainkajai. Witjai Tuke Pujuunuk, nunak dekas tajai. 
\p  
\v 12 “ ‘Israel aents aidauwah, yama nagkamchak mina emematjaku waitai pegkejam aakmakbau Silónum aajakua nuwi wetajum, nunikjum diistajum wisha nunú jeganash atumi tudaujinish itugkauwaitja nunú.  
\v 13 Wika atumi pujutjumin pachisan atumnak kuashta chichagkauwaitjime, tujash mina umigtutak dakitjauwaitjume. Nuniau asajum wi tabau antuka umitsuk pegkegchau takata nunú ainjauwaitjume. Witjai Tuke Pujuunuk, nunak dekas tajai. 
\p  
\v 14 “ ‘Nuadui, juju mina emematjaku ijuntai jegamkamua nuna wi atumin, tuja atumi apachjum aajaku aina nunashkam susauwaitag, nuwi atum kajinmamsajum anentaimjum nunak, wi amasu akunush wi yaunchuk nunú aak Silónum aun tsaikuitag dutiksanuk tsaiktatjai.  
\v 15 Dutikakun yaunchuk atumi yatsum Efraín wegantu aidaun jiijan utsagkuitag dutiksanuk atumnashkam utsagtatjime’ tujamui Apajuí”, tiuwai Jeremías. 
\s1 Israel aents aidau Apajuí umigtan idaisagbau 
\p  
\v 16 Apajuí chichagtak: “Jeremíasah, yamai nagkamsamek juju aents aina nunú pachismek segatipa, tuja dita anentaimtusmesh buutipa, tuja yaigta tusa segatkumesh waitkagsaipa, tujutkuminish antugkashtatjame. 
\p  
\v 17 “Judá wegantu aidau nugken tuja Jerusalégnum jinta aina nuwi pegkegchaun takaina duka ¿amek waintsumek?  
\v 18 Uchi aidau chigkimin ikaunmainawai, múun aidau jiin ikapainawai, nuwa aidau pagkan inajuinawai dita apajuímtaiji nuwa shigmauch nayaimpinmaya etegkamu tuina nuna emematuinak susatnun. Dutikainak nuigtushkam tikich wainka apajuímtai aina nuna emematuinak, vinon suwina duka mina dushiktuinak aninawai.  
\v 19 Tujash dekas minak dushiktuinatsui, ditak pempeentumakiag datsantan dushikmamainak aan yujawai. ¡Witjai apu Tuke Pujuunuk, nunak dekas tajai!  
\v 20 Nuadui wi kajekbaujui juju nugka junak aents aidaun, kuntin aidaun, numi aidaun, ajak aidaun, ashí ijinattajai. ¡Wi kajekbaujua duka jiijai betek kakajus kajinchauwai! Nunak dekas uminkatnun tajai.” 
\p  
\v 21 Tuke Pujuu ashí senchigtin, Israel aents aidaun Apajuíji niina aentsji aidaun chichajak: “Atum wakegakjumek mina eme anenjusjum anentag sujustin aina duka, kuntin maa nuna neje ashí apeatin aidaujai yajuakjum ijuma pujutajum, dutikajum nuna neje yuwajum tagkaijum kantaushmaktajum.  
\v 22 Untsu atumi apachjum aidau Egipto nugkanum batsatun jiijuitag nunak wika mina eme anenjusjum anentag sujustajum, nuniakjum kuntin maajum nuna neje ashí apeatajum tusanuk ditanak inagchauwaitjai.  
\v 23 Wika ditanak mina umigtuktinme, nuninakui wi ditá Apajuíji atajai, untsu dita mina aentsug atinme tiuwaitjai. Tuja nuigtushkam chicham umiktinun wi susajuitag nuna umiktinme nuninak shiig batsamsatnume tiuwaitjai.  
\v 24 Tujash minak umigtukchajui, nuigtush puyatjusagkesh dekaskeap tawa tujutchajui. Nunidau asag, anentainkachu najaneawag dita wakegamun takajaku ainawai. Nunidau asag mina idaituinak nuni senchi pegkegchau wajasajui.  
\v 25 Atumi apachjum aidau Egipto nugkanum batsatu jiinjau aina duwi nagkamsan wika yamaikish atumnak profeta mina chichamjun etsejin aidaunak makichkish mijattsuk tuke ishitnaitjime.  
\v 26 Imatikamaitkujum atumek minak umigtatsjume. Nuadui mina chichamjuk puyatjusjumkesh diitsuk, atumi apachjum aidaun nagkaesau pegkegchau ainagme. 
\p  
\v 27 “Jeremíasah, antugtamkashtin ainaigkish, tuja aipakchagtin ainaigkish, juju chicham senchi untsumkam ashí etsegkata.  
\v 28 Ame dita chichagkum: ‘Juju aents aina duka Tuke Pujuu dita Apajuíji umigtanak dakituinawai. Nunidau asag Apajuí jintintuatag tamash dakituinawai. Dita dekaskenum chichataijig shiig atsujuinawai’, tita” tujutmayi. 
\s1 Jerusalégnum pegkegchaun takasagbau 
\q1  
\v 29 ¡Jerusalégnumia aidauwah, 
\q1 intashim esajam aina duka tsupigjum utsagtajum! 
\q1 ¡Dutikajum muja uwegshunum shiyakjum, 
\q1 nuwi yujasjum wake besemag pujaku kantamtai kantamatajum, 
\q1 wagki atumnak Apajuí kajegtamak idaitamsau asamtai! 
\b  
\p  
\v 30 Apajuí chichaak: 
\p “Judá wegantu aina duka wi dakitamu aidaun, dakumka najanamu pegkegchau tsumain aina nuna mina jegag pegkegma nuwi awayawag mina jegajun pegkegchau etugtiaje.  
\v 31 Tuja nuigtushkam, wi dutikata tichamaitak makichkish anentaimtushtaijun, dita uchiji aidaun nawanji aidaujai maawag, apeenak dita apajuímtaijin emematiagtinun Ben-hinom nugka ségaju awa nuwi altar Tófet tutain najanawaje.  
\v 32 Tujash nunú Tófet, Ben-hinom tutai aina nuna daajig dukek achagtinai. Nuna daaji yapajinkatnuk tsawan jegattawai. Nunikmatai: ‘Nugka ségaju aents aidau kajeetai’, adaikagtinai. Witjai Tuke Pujuu, nunak dekas tajai. Tuja aents jinawajunak tikich nugka ukumamain atsau asamtai, Tófet tutaya nuwig batsakiagtinai.  
\v 33 Dutikamun, nuna ayamjumainuk atsau asamtai chuwag aidau, kuntin aidau yuwa amukagtinai.  
\v 34 Tuja Judá wegantu aidaun yaaktaji aidaunum jiistamku kantabau, shiig aneamu, nuwenbaunum shiig aneaku kantabau aajabia nunak ashí emegkagtatjai. Dutikamtai Judá aents aidau nugkega duka bashiak itajak wajas asattawai.” 
\c 9  
\p  
\v 10 “Nunikmatai muja aidaunum yujasjum 
\q1 “atumi tagkujum aidaun yutaiji chijichi aidauk 
\q1 ashí apekbau asamtai, 
\q1 wake besemag dekapeakjum buuttajum. 
\q1 Tuja imatika apekbau asamtai, 
\q1 nuni nagkaematnak dakitainawai; 
\q1 tuja atumi tagkujum aidau shinaukesh 
\q1 makichkish antuenatsui, 
\q1 chigki aidaush, kuntin ikamia aidaush 
\q1 ashí pisag megkaejaje. 
\b  
\q1  
\v 11 “Judá wegantun yaaktaji aidaunak wi ashí tsaiktatjai, 
\q1 dutika ai aents atsau bashiak agkan wajas asatnai. 
\q1 Jerusalégnashkam tsaiktatjai, dutika ai 
\q1 ayatak kaya tuwasua weaku atatui. 
\q1 Nunú nugkanmak ikamia yawá aina duke 
\q1 batsamsatnai, tujamui Tuke Pujuu”, tiuwai Jeremías. 
\b  
\p  
\v 12 Nuigtu Jeremías chichaak: “Juju nugkanum yaakat ayá dusha ¿wagka imatikaish tsaikbauwaita? Juju nugka juni waya nagkaebauk makichkish atsawai. 
\p “¡Uwegshuchuashit tumain wajas awai! ¿Yaita nuna shiig dekamainush? Profeta Apajuí awemamu asa, ¿nuna pachis iina ujapamainush awash?” tiuwai. 
\p  
\v 13 Tutai Tuke Pujuu ayaak: “Ehe, auk chicham umiktinun wi ditan susauwaitag nuna intimkiag umitsuk idaisaju asag aikam asaje.  
\v 14 Nuna umitsuk dita apaji emematujakagbaun nuna, ditashkam dita anentai wakegamun Baal aidaun emematiaju ainawai.  
\v 15 Nuadui wi Tuke Pujuun, Israel aents aidaun Apajuíji, ashí senchigtinun juna tajai: Wi ditanak yutai yapaun ayujawagtatjai, tuja umutai jatai egketuamun aajagtatjai.  
\v 16 Tuja yaunchkesh dita apajigkesh wainajakchamunum tikich nugkanum dapampaakan utsagtatjai. Dutika ai, shiwag aidau puyaja juki yujagsag ashí amuktinme titatjai”, tiuwai. 
\s1 Jerusalégnumia aidau awake anentaimjag buutiagbau 
\p  
\v 17 Tuke Pujuu ashí senchigtina nunú chichaak: 
\q1 “¡Juju shiig antugtuktajum! 
\q1 Aents jakamtai buutin atinme tusa 
\q1 etegjamu nuwa aina nunú untsuka ikaunmatajum. 
\q1  
\v 18 ¡Duka dekas buuttan yacha aina nunú 
\q1 wamak kaunawag atumin egampagtinme! 
\q1 ¡Imatuinak dita jiinig negaikijinak bete wajastinme! 
\q1  
\v 19 Nunik Siógnum nagkamas buutuinak: 
\q1 ‘¡Jauchah, wagkaik imatika tsayamash asaji! 
\q1 Iina jee aidaunak ashí tsaigtamkaje, 
\q1 tikich nugkanum shimaku ukukiagmi’, 
\q1 wajaidau antuenawai. 
\q1  
\v 20 Tuja nuwa buuttan yacha aidauwah, 
\q1 Tuke Pujuu chichame shiig jitusa antuktajum, 
\q1 nunikjum atumi nawanjum aidau 
\q1 kumpajum aidaujai wake besemag pujaku 
\q1 buuttai, juju aatsa jintintuatajum: 
\q1  
\v 21 Iina jee aidaunum jata wainjamae, 
\q1 tuja apu pujusa inamtainish wayae, 
\q1 nuniku asa, uchi piipich jintá wasugkamak yujaun, 
\q1 datsauch aidau plazanum yujaunashkam ijinui. 
\q1  
\v 22 Dutikamu asa aents jinau aidauk, 
\q1 ajak juwaam kakegak batsamama numamtuk, 
\q1 tuja tsuwat ukaja ukukmawa numamtuk wajas awai. 
\q1 Witjai Tuke Pujuunuk, nunak dekas tajai. 
\b  
\q1  
\v 23 “Tuja aents yacha duka 
\q1 niina yachajinigkik eme anenmamigka, 
\q1 tuja aents senchigtina dushakam, 
\q1 niina senchijinigkik eme anenmamigka, 
\q1 tuja wiakchashkam niina wiakchajinig eme anenmamigka. 
\q1  
\v 24 Dekas eme anenmamsatatus wakegakug, 
\q1 wi Tuke Pujuu ashí senchigtinaitag nuna shiig dekaa 
\q1 umigtak eme anenmamainai. 
\q1 Wika nugkag anenkajai takajai, 
\q1 nuadui anenka nunú tsanumtsuk shiig takamua 
\q1 nujai shiig awajtawai.” 
\c 14  
\s1 Kuashat tsawantai yumi yutugchamu 
\p  
\v 1 Yumi yututsuk kuashat tsawan au asamtai, Tuke Pujuu Jeremíasan chichajak: 
\b  
\q1  
\v 2 “Judá wegantu aidauk wake besemag dekapenak buutuinawai, 
\q1 dita yaaktaji aidaunmash 
\q1 waji sujutaiji aidauk atsujuinawai. 
\q1 Ashí aents aidauk nugká batsatui, 
\q1 tuja Jerusalégnumak senchi buutuinawai. 
\q1  
\v 3 Wiakuch aidauk dita inake aidaun yumi 
\q1 egaktajum tusa ishimainawai, 
\q1 tusa tima yumi aimtainum shiyakag egainawai, 
\q1 tujash yumik atsawai. 
\q1 Nunitai yumi shikitainak wainak takus yuja yujakua waketuinak, 
\q1 puyatkiag datsantin buuken dukumakag waketuinawai. 
\q1  
\v 4 Tagkugtin aidauk yumi yutachu asamtai, 
\q1 nugka buku wajasmatai, 
\q1 senchi puyatuinak buuken dukuinawai. 
\q1  
\v 5 Nugka buku wajasu asa chijichi jinaamtai, 
\q1 japa aidauk yumainji atsujam, 
\q1 uchiji yama petsakbaunak ukukiag yaja shimuinawai. 
\q1  
\v 6 Ikamia burro unuinakchamu aidauk 
\q1 chijichi yumain atsutai, 
\q1 nain uwegshunum ijunas nujantai jinuinak, 
\q1 ikamia yawajai betek 
\q1 dase dasentai mejea mejea mejea wajainawai, 
\q1 imaaninak jaka iyainawai”, tiuwai. 
\s1 Profeta Jeremías Apajuí segamu 
\q1  
\v 7 Jeremías Apajuín segaak: 
\q1 “Tuke Pujuuwah, iik dekas ame umigtsuk 
\q1 amina emtimin shiig kuashat pegkegchau takamsaji. 
\q1 ¡Tujash wait aneasam ame tuke pujuuwaitam 
\q1 nunú anentaimsam yaijatkata! 
\q1  
\v 8 ¡Ametme Israel aents aidau uwemtiknumek, 
\q1 ametme tsawan utugchat akuish ayamkagtukam 
\q1 uwemtikagtinmek! 
\q1 Imanaitkumesh, ¿wagka aents tikich nugkanmaya ijaak tau asa, 
\q1 ayatak diijatus kanag tsawak wegama 
\q1 numamtukesh awajkagtame? 
\q1  
\v 9 Israel aents aidau Apajuíjiyah, 
\q1 ashí aents aidauk dekainawai amina aentsjum ainag nunak, 
\q1 tuja amek jutijai pujame. 
\q1 ¡Kajimatkimek idaikagtusaipa! 
\q1 Aents kakakchau maanitan yachachu 
\q1 ayamkagtumainchauwa nunin wajasume”, tiuwai. 
\p  
\v 10 Tuke Pujuu aents aidaun chichajak: 
\q1 “Atumek wainka apajuímtai aidau 
\q1 ememattasajum ima senchi wakegagme, 
\q1 nuniau asajum wainka yujagme, 
\q1 anka minak shiig awajtatsui, 
\q1 nuadui wi atumnak suwimkan amastatjime”, 
\q1 tujamui. 
\p  
\v 11 Nuna tusa Tuke Pujuu mina chichagtak: 
\p “Jeremíasah, anú aents aina nuna yaigti tusam segatkumek waitkagsaipa.  
\v 12 Yujumak ijagma pujusam segatkuminish, wika antugkashtatjame; kuntin aidau, trigo, cebada aidau kuashat anentag sujakjuminish, wika jujukchattajime. Wika atumnak maaniamunum, nujantai, jatai ijinattajime”, tujutmayi Apajuí. 
\p  
\v 13 Tujutkui wi ayaakun: 
\p “Tujash apu Tuke Pujuuwah, tikich profeta aidau aents aidaun chichajuinak, maaniamuk atsuttawai, tuja nujanchakam tepeashtatui tusa, amina au nii shiig utugchat atsaunum batsamsatnume tusa yaimpaktatui tuinawai”, tibaijai. 
\p  
\v 14 Tusa tai Tuke Pujuu aijak: 
\p “Nunú profeta aidau mina daajun pachis tuina nunak waitjuinak tuinawai. Wika ditanak, atum wejum chicham etsegkatajum tusanuk makichkish inatsjai. Nuigtush wika ditanak aujuinatsjai. Nunak ditak anentaimas waitjuinak tuinawai.  
\v 15 Nunú profeta aidau wi akatja awemachmaitak mina pachitus, auk maaniamuk atsuttawai, tuja nujanchakam juju nugkanmak tepeashtatui tuu yuja duka nujantai, puyajai jinawagtatui.  
\v 16 Tuja tikich aents aidaun dita ujaina dushakam nunisag nuwe aidau, nawanji aidau, uchiji aidau aatus ashí nujantai, puyajai jinawagtatui. Nunik jinawagmatai, dita iyashi aidauk Jerusalén jinta ayá nuwi tepetag waigtatui, wagki ditan ukumainuk atsau asamtai. Nuni akikmakagtatui dita pegkegchau takamsamujinak. 
\p  
\v 17 “Nuniktin asamtai juju aatsam aents aidau ujakta: 
\b  
\q1 “ ‘¡Mina aentsug aidau utugchat ishamainun 
\q1 igkugkaju asamtai, nuna anentaimtusan tsawaish, 
\q1 kashish mijamtsuk tuke buut pujuttajai! 
\q1 Dita utugchatjiya duka tsupimakbaujai betek najamawai. 
\q1  
\v 18 Jiinkin ajanum wekaman, 
\q1 aents aidau puyajai kajegkam batsatun wainjai, 
\q1 tuja yaaktanum waikmanchakam, 
\q1 nujantai jinuidaun wainjai. 
\q1 Imanitaish profetakesh, sacerdotekesh, 
\q1 wagkag imaniawa nunak puyatjutsuk 
\q1 wainak tikich nugkanum yujawai’, tujutmayi.” 
\s1 Profeta Jeremías Apajuín aikbau 
\p  
\v 19 Jeremías Apajuín ayaak: 
\b  
\q1 “Apuh, ¿Judá wegantu aidauk tuke idaikumek idaisaum? 
\q1 ¿Yaakat Jerusalégkak yawetjamek idaisaum? 
\q1 ¿Wagka waji jataitkuish ampimakuish, 
\q1 tsagaumainchaush ekagtiume? 
\q1 Pegkejap batsamsattaji tibaiji, 
\q1 tujash pegkegchau iyanjamamtai, kuashat waituinaji. 
\q1  
\v 20 Tuke Pujuuwah, 
\q1 iina pegkegchaujiya duka dekagmamji, 
\q1 tuja iina apachji pegkegchaun takasu aina 
\q1 dushakam dekaji. 
\q1 Iik dekas ame pegkegchau takagku tunamagji. 
\q1  
\v 21 ¡Amek betek uminaitam iman asam, 
\q1 antugkagtuskek idaikagtusaipa, 
\q1 tuja amina pujutaijum jega pegkegma nunú tsaikaipa! 
\q1 Duka dutiktsuk ame jutijai chicham umikuitam nunú 
\q1 adeagta nunikam betek umikta. 
\q1  
\v 22 Tuke Pujuu, iina Apajuíjiyah, 
\q1 dakumkamu apajuímtai aina duka 
\q1 yuminak makichkish yutumtikmaitsui, 
\q1 ametme yumi nayaimpinmaya yutumtiknumek, 
\q1 ametme ashí najankaumek. 
\q1 ¡Nuadui ima aminig kajintsa anentaimji!” tiuwai. 
\c 15  
\s1 Suwimak atin etsegkamu 
\p  
\v 1 Tuke Pujuu chichagtak: “Juju aents aina nunú wait anenjata tusa Moisés, Samueljai segatainakuish, wika juju aents aina nunak wait anenmaitsujai. Jiinag shiyaktinme tujamui tusam ujakta, dutikam jiinag shiyaktinme.  
\v 2 Tuja tuwi shiyaktatji tusa inimpainakuig ame ayaakum: 
\b  
\q1 “ ‘Nii jatai jakati tibauk nunisag jakati; 
\q1 tuja nii maaniamunum jakatnuk nunisag 
\q1 maaniamunum jakati; 
\q1 untsu nujantai jakatnuk dushakam nunisag 
\q1 nujantai jakati; 
\q1 tuja achija yajuakam yujas waittsatnuk 
\q1 nunisag waittsatnume’. 
\b  
\p  
\v 3 “Wi ditanak ipak usumta imajin suwimkan ishitkattajai. Tuja duka juju ainawai: Maaniamunum jinawagtinai, nunikmatai yawá aidau esainiag japisa yujagtatui, chuwag amukagtinai, dutikawagmatai kuntin kajen aidau, shiig amutan amukagtinai.  
\v 4 Nunak Ezequíasa uchiji Manasésa pegkegchaujin dutikattajai. Wika nunú Judá apuji wajas pujusa Jerusalégnum wajina dutikauwaita nunak kajimattsujai. Nuna antukag nugka múun aidaun apuji aidau senchi ishamkagtatui. Nunak dekas nuniktinun tajai. 
\b  
\q1  
\v 5 “¿Jerusalégkah, aminash yaki wait anenjamjainta? 
\q1 ¿Yaki amina anempakush buutti? 
\q1 ¿Yaki aminash jamamtuchu pujusti 
\q1 tusash puyatjutpakti? 
\q1  
\v 6 Atumek mina idaitusjum pegkegchau takagtusugme. 
\q1 Nuniakjuminish wait anentau asan 
\q1 tsawanta ewae ewaekawan yawegjai, 
\q1 nuniku asan yamaik ijinattajime. 
\q1  
\v 7 Jerusalégkah, aminí aents batsata nunak 
\q1 chijichin dase umpui utsauwama numamtuk 
\q1 yaakta ukumtikin utsagtatjai. 
\q1 Mina aentsug aidauk mina umigtukchaju asag 
\q1 uchigtuchu juwakaje. 
\q1 Wi ditanak mina umigtukchaju asagmatai ijinawagjai. 
\q1  
\v 8 Dutika ai nayantsa kamatkaji kuashta nuna nagkagas 
\q1 nuwa aidauk shiig kuashat wajemeakagtinai. 
\q1 ¡Etsash etsantaig nuwa aidaunak 
\q1 dita uchiji datsa aidaujai ijinattajai! 
\q1 Makichkish nuniktatuapi tachamunum 
\q1 pachiachbau ishamainun ajunjagtatjai. 
\q1  
\v 9 Nuwa kuashat uchigtin aidauk wampainag 
\q1 iyajag nunisag jagtinai. 
\q1 Nunikag datsan dushikiam agtinai, 
\q1 Tuja etsa pegkeg etsantug au suwe wajastinai. 
\q1 Makichik aentskesh iwaku pujaunak 
\q1 tikich aents aidau maatnume tusan idaisattajai. 
\q1 Nunak dekas nuniktinun tajai”, tiuwai Tuke Pujuu. 
\s1 Profeta Jeremías buutbau 
\q1  
\v 10 “¡Chah, dukuwa wika senchi anentaimkun waitiajai! 
\q1 ¡Wika akiinmainchaunas akiinawamiagtai! 
\q1 Wika makichik aentsnakesh pegkegchauk awagmachuitjai, 
\q1 tujash minak ashí pegkegchaun chichagtuinawai, 
\q1 dutijuinak shiwagmatuinakui ditajai maaniajai. 
\q1  
\v 11 Wi ame inatjamun umikchau ataik, 
\q1 tuja dita pachisnush amijai chichaschau ataik, 
\q1 dita tujutuina duka betek uminkati. 
\q1 ¡Tujash mina shiwag aidau waituinakui, 
\q1 nuna yaigti tusan 
\q1 wi amina segajam duka amek dekame! 
\q1  
\v 12 Tuke Pujuu aents aidaun chichajak: 
\q1 Suntag asirianmaya, babilonianmaya aina nuna 
\q1 depetmainuk atsawai. 
\q1  
\v 13 Israel aents aidautigmek ashí tunamakugme, 
\q1 nuniku asagmin atumi tagkujum aidau, wajijum 
\q1 aidau, tuja atumi nugkemin ayá nunashkam 
\q1 atumi shiwajumin ashí susattajai. 
\q1  
\v 14 Wika shiig senchi kajekjai, 
\q1 nuniku asan, jiijai betek apeattajime. 
\q1 Atumi shiwaajum aidau achipag tikich nugka atumi wainchataijin yajupakag, 
\q1 dita inainak waitkastinme tusan idaisattajime”, 
\q1 tiuwai Tuke Pujuu. 
\s1 Jeremías Apajuín ausamu 
\p  
\v 15 Jeremías Tuke Pujuun aujak: 
\b  
\q1 “Tuke Pujuuwah, amek ashí dekame, 
\q1 wika amina takaju asan maatag tama ajai, 
\q1 minash kajimatjutsuk yainkata. 
\q1 ¡Tuke Pujuuwah, mina mantuatag tuina duka 
\q1 ayatak dii pujugtsuk eke mina mantuinatsaig, 
\q1 suwimak susam ijinata! 
\q1  
\v 16 Tuke Pujuu ashí senchigtinuh, 
\q1 ame mina aujtuyum nunak 
\q1 wika puyatjusan antuyajai. 
\q1 ¡Wika aminuitag duwi 
\q1 amina chichamjumin antakun shiig aneyajai! 
\q1  
\v 17 Wika aents pegkegchau takatnak yujajin aina 
\q1 nujai ijunja wekaetanak idaisajai. 
\q1 Aminu etiuwaitam duwi nagkamsan wika wiki pujajai, 
\q1 tuja pegkegchau takat ame kajejam nunak 
\q1 wishakam kajejajai. 
\q1  
\v 18 ¿Wagka tujash imaniknush waitush pujaja? 
\q1 ¿Wagka wi imanikan waitiag dusha 
\q1 megkaemainchauwaita? 
\q1 Niimpap yainkattawa timajai, tujash idaitusume, 
\q1 amek yumi pukuni jiinu kuyua 
\q1 buku wegama numamtin wajasume”, tiabiajai. 
\s1 Apajuí Jeremíasan aikbau 
\p  
\v 19 Tusa ti ai Tuke Pujuu aijak: 
\q1 “Nunú anin wainka tuu wekaetsuk, 
\q1 awake anentaimjam minai minakminig, 
\q1 mina chichamjun etsegtujin ati tusan yaigtatjame. 
\q1 Dutika ai ame mina profetag atatme. 
\q1 Amek ditaig waketmaitsume, 
\q1 auk dita aminí minimain ainawai. 
\q1  
\v 20 Juju aents aina nuna emtinig wi aminak 
\q1 yaakat broncejai peejamua iman awajsattajame. 
\q1 Amina shiwaajum aidau jetepainakush 
\q1 depetamkachagtatui, 
\q1 wi aminak ayamjukan uwemtijattagme. 
\q1 Witjai Tuke Pujuunuk, nunak dekas dutikatin asan tajai. 
\q1  
\v 21 Aents pegkegchau aidau mantamatag tuinakuish, 
\q1 wi ayamjukan uwemtikjattagme; 
\q1 tuja magkagtin aidau mantamatag tuinakuish, 
\q1 wi uwemtikjattagme”, tiuwai. 
\c 18  
\s1 Duwe namuka najanin pachisa augmattsamu 
\q1  
\v 1 Tuke Pujuu chichagtak: 
\p  
\v 2 “Jeremíasah, duwe namuka najanin puja nuna jeen wetá. Nunikamin nuwi chichaman ujaktagme”, tujutmayi.  
\v 3 Tusa tujutmatai nuna jeen webaijai. Nunika jegakman nunú aents shikika umutain tornonum najanak pujaun wainkabiajai.  
\v 4 Nuna najanak pujus, shiig jiinkichmatai, nunú duwenak juki ataktu nagkama nii wakegamunak imatiksag shiig pegkejan najanmayi.\fig |alt="The potter" src="LB00138b.tif" size="span" loc="Jeremiah 18.3-4" ref="Jer. 18.3-4" \fig* 
\p  
\v 5 Nuwi Tuke Pujuu mina chichagtak: 
\p  
\v 6 “Atumek mina uwejui pujagme, nuadui wika atumnak juju aents duwen namuka najanak itujeawa nujai betek awagmamainaitjime. 
\p “Witjai Tuke Pujuunuk, nunak dekas tajai.  
\v 7 Wi wakegaknuk, nugka múun aidaunash, tuja apu aidaunash, shiig wamak tsaikan utsajai.  
\v 8 Untsu nunú aents aidau pegkegchau takatan idayinak mina umigtuinakuig, suwimkan susatasan umigkau akunush suwimkanak sumaitsujai.  
\v 9 Tuja tikich tsawantai, aents nugka muunnumia aina nunú takainak emkatnume, nuninak senchigtin wajastinme tusanush dutikajai.  
\v 10 Untsu nunú aents aidau pegkegchaun takainak mina umigtuinachkuig, wi dita wajiji aidaun susatag tibaugnash suchauwaitjai”, tujutmayi Apajuí. 
\p  
\v 11 Tuja duwi pujus Tuke Pujuu chichagtak: 
\p “Judá aents aina nunú Jerusalégnum batsamin aidaujai, wi taja nunú ujakta: ‘Atumin suwimka amastasan chichaman umiajai. Tuja suwimak dakitakjumek, pegkegchau takat idaikujum pujutjum iwajatajum’ tujamui Apajuí tita tujutmayi.  
\v 12 Tusa tamin dita chichagtamainak: ‘¡Wainka tsawan megkaekum tuu wekaetsuk wetá, iik ii wakegamu takainaku batsamsatasa wakegaji!’ tujamiagtatui. 
\p  
\v 13 “Tusa tujamainakui wi ditan chichagkun: 
\b  
\q1 “Tikich aents pegkegchaun takau aina duka 
\q1 tikima atumjai betekak atsawai. 
\q1 ¡Tuja atum Israel aents aidautigmek 
\q1 tikima shiig pegkegchau takagme! 
\q1  
\v 14 Muja Líbano titiji aidaunum bicha nujamag ayá duka 
\q1 makichkish megkaechauwai. 
\q1 Tuja entsa bichatin muja aidaunum ayá dushakam 
\q1 kuyuag megkaechauwai. 
\q1  
\v 15 Tujash mina aentsug aidauk minak kajimatjukiaje, 
\q1 nuninak dakumka najanamu apajuímtai aidaun 
\q1 emematuinak kugkuin incienson apé yujawai. 
\q1 Dita yujatai jinta aya nuna imagkag 
\q1 wainak jintachunum yujawai. 
\q1  
\v 16 Nunidau asagmatai, 
\q1 dita shiwaaji aidau wa wamak waitkamu asag yaaktaji tsaigkam, 
\q1 dita nugkeg bashiak awai. 
\q1 Ashí aents nuni nagkaemaidauk nuna diisag 
\q1 puyatkag buuken pegag nagkagainawai. 
\q1  
\v 17 Israel aents aidaunak dase etsa minitainmaya 
\q1 dasentak utsaumaina numamtuk wi utsagtatjai; 
\q1 tuja dita shiwaaji aidaun ishamkag pisagtinme titatjai. 
\q1 Suwimak jukitnuji tsawan jegamtaig, 
\q1 ditanak ausachagtatjai, 
\q1 ayatak atsu ayampatuan idaisagtatjai”, tiuwai. 
\s1 Jeremías maatasa chicham umigkamu 
\p  
\v 18 Aents aidau chichainak: “Sacerdote aidau, aents yacha aidau, profeta aidau Apajuí chichamen iina jintinjamainuk tuke aitnai. Nuadui nii tawa duka makichkish antugkachmi, dutikaku Jeremíasak chicham umigka tsanumjuja maa ajapami”, tuidau. 
\s1 Jeremías Apajuín ausamu 
\q1  
\v 19 ¡Tuke Pujuuwah, wait aneasam antugtukta! 
\q1 ¡Mina shiwag aidau chichaina nunú antukta! 
\q1  
\v 20 ¡Wi egkema jakatnujun waa muuntan tautjiaje! 
\q1 ¡Wika ditanak pegkegnum yayamaitak, 
\q1 dita mina aan iiktuina duka pegkegchauwai! 
\q1 Wi ditan wait anentakun juwi taan, 
\q1 suwimak susaipa tusan amina segajam nunú adeagta. 
\q1  
\v 21 ¡Tujash yamaik ame dita uchiji aina duka 
\q1 nujantai jinaati tita! 
\q1 Untsu nuniachkush maaniamunum jinaati tita. 
\q1 ¡Nunikagmatai dita nuwe aidauk waje 
\q1 uchigtuchu juwakagtinme! 
\q1 ¡Tuja aents múun aidaunak jata ijinatnume! 
\q1 ¡Untsu datsa aidauk maaniamunum jinatnume! 
\q1  
\v 22 Tuja pachiachbau kasa aidau ishitkata, 
\q1 ¡nuna ishamainak pampaidau antuekati! 
\q1 Wagki ditak wi egkema jakatnun waa muuntan tai umigtukaje. 
\q1 Tuja wi weamunmashkam iyatnun umigtuinawai. 
\q1  
\v 23 Tujash Tuke Pujuuwah, mina mantuawagtatus 
\q1 chichaman umigtuina duka amek shiig dekame. 
\q1 ¡Dita pegkegchauji aina duka tsagkujaipa! 
\q1 ¡Tuja kajimatkimesh idaisaipa! 
\q1 ¡Ame kajekbaugmin suwimak susata, 
\q1 shiwag aidau depetuk ijinatnume tusam idaisata! 
\c 19  
\s1 Yumi shikitai intajamu pachisa augmattsamu 
\p  
\v 1 Tuke Pujuu mina chichagtak: “Yumi shikitai makichik duwe najanamu sumakta. Dutikam aents aidaun apuji múun aina nuwiya ujumak, sacerdote múun chichin aidaujai untsukam ijumjata.  
\v 2 Dutikam dita uyuntamsagmatai, Ben-hinoman pakajin wetá. Nunikam yaakta waitiji ichinak duwejai najanamu tutaya nujai niniaku wajasam, wi amina akatjattajam nunú etsegkata.  
\v 3 Nuwi wajanta chichaakum: ‘Judá apuji aidauwah, Jerusalégnumia aidautigmejai, Tuke Pujuu ashí senchigtin, Israel aents aidaun Apajuíjiya nuna chichame antuktajum. Apajuí chichaak juna aatus tawai: 
\p “ ‘Juju nugka juwi waitut ishamainun awemattajai, dutika ai nuna antuidauk senchi ishamak kujainiagtinai.  
\v 4 Wagki Israel aents aidauk mina kajimatjukiag, juju nugka junak Apajuí etegkachua nunin awajsag, ditash wainchataijin, tuja dita apachji aajaku aina dukesh wainajakchamun, Judá wegantu aidaun apuji aidaukesh wainchatai wainka apajuímtai aidaun emematuinak nuwi kugkuin incienson apé yujawai. Nunidau asag juju nugkanak aents takamsachu aina nuna numpeg awajsaje.  
\v 5 Tuja nuigtushkam, wi dutikatajum tichamaitak, nuigtush makichkish anentaimtachbaujun, Baalan emematuinak dita uchijin maawag patasa apeatnun altaran najadau ainawai.  
\v 6 Nuadui juju nugka daaji Tófet tutaiya nunú yapagtuatin tsawan jegattawai. Dutikamu asa Ben-hinoman pakaji tutaigkesh achattawai. Juju nugka daajig: “Aents ijinamu” tutai atinai. Witjai Tuke Pujuunuk, nunak dekas uminkatnun tajai.  
\v 7 Judá wegantu aidau Jerusalégnumia aidaujai chichaman umina nunak pachimjukan emegkatkattajai. Dutikan shiwag aidau maaniamunum ijinatnume tusan idaisagtatjai. Dutika ai nuwi jinawag tepetag waigkun chuwag aidau, kuntin kajen aidaujai amuktinme titatjai. 
\p  
\v 8 “ ‘Tuja Jerusalégnak ashí tsaikan ishamain awajsattajai. Dutika ai bashiak asattawai. Tuja aents nuni nagkaemaidauk nunú imatika yaakat tsaikbaun diisag ishamiagtinai. Nuninakush dushikiagtinai.  
\v 9 Shiwag ishamain aidau ditan ijinawagtatus yaaktan tenteawagtinai. Dutikawagmatai jiintsuk batsamas yumain atsutai, nujantai jinuinak dita uchiji aidaun, nawanji aidaujai yuwatnume, dutikainak pempeentunikiag yudaitinme tusan idaisattajai, tawai Apajuí’, titatme. 
\p  
\v 10 “Nunú tusa inagnakam, aents aidau amina uyuntamainak yuja nunú wainainamunum yumi shikitai duwe najanamu takakbaujum ajiaja tsaiktatme, dutika tsaikam  
\v 11 chichagkum: Apajuí ashí senchigtina nunú chichaak: ‘Juju aents aina nunak yumi shikitai tsainka nunú iwagmaitsu numamtuk ataktush nantamainchaun tsaiktatjai. Dutikamtai aents aidauk nuna iyashi aidaunak tikich ukumamain atsau asamtai Tófetnum ukusagtinai.  
\v 12 Tuja Jerusalégkak tsaikam Tófetjai betek wajastatui. Witjai Tuke Pujuunuk, duka dekaskenum uminkattawai.  
\v 13 Nuadui, Jerusalégnumia jega aina nuwig, tuja Judá wegantu aidaun apuji aidau pujusa inamtaiji aina nuwishkam minak makichkish emematjishtinme titatjai, wagki ashí yaya aidaun emematuinak nunú jega aina nuna tuntupen kugkuin incienson apeenak, tikich apajuímtai aidaun anentag suwinak vinon ukaidau asag senchi tunamaidau asagmatai. Nuadui duka ashí Tófetjai betek juwaktatui’ tawai Apajuí”, tiuwai Jeremías. 
\p  
\v 14 Nuna tusa inagnak, Tuke Pujuu mina chichameg etsegkata tima, Tófetnum weuwa nuwiya wakitkiuwai. Nunik jega Apajuí emematku ijuntai jegamkamunum nuna waitijin jegantatak wajanta ashí aents aidaun chichajak:  
\v 15 “Tuke Pujuu ashí senchigtin, Israel aents aidaun Apajuíjiya nunú chichaak: ‘Juju aents aina duka yaaktajijai nagkamas nuni senchi intimkiag mina umigtutnak dakitjaje. Nuadui dita suwimak jukitnun pachisan timag nunak imatiksanuk suwimkan susagtatjai’ tawai Apajuí”, tiuwai Jeremías. 
\c 20  
\s1 Profeta Jeremías sacerdote Pashurjai 
\p  
\v 1 Imer aajakua nuna uchiji Pashur sacerdote Apajuí emematku ijuntai jegamkamun apuji aajakua nunú Jeremías utugchat nagkaemagtinun pachis chichagkagtaun antukui.  
\v 2 Nunik: “Jeremías achikjum asutiatajum, dutikajum aents achika chimpitai Apajuí emematku ijuntai jegamkamua nuwi jegantatak, Benjamígka waitiji tutaya nuwi ayaumas awa nuni egkeatajum”, tusa inamjauwai.  
\v 3 Tusa inamjayatak kashinia duwi kashikmas Jeremías jiiktajum tusa tiuwai. Tusa timatai jiikiajui, dutikam Jeremías niina chichajak: 
\p “Amina daagminak Tuke Pujuu yapagtugmattawai. Dutijamamtai Pashur idaikum Magor-misabid\f + \fr 20:3 \ft “Magor-misabid” tawa duka hebreo chichamnumak, “ashí yantamnum sapigmamu awai” taku tawai.\f* namkattame.  
\v 4 Wagki Tuke Pujuu chichaak: ‘Aminak senchi sapigmitkaktatjame, dutikakun amina kumpajum aidaunashkam sapigmitkaktatjai. Nuadui amesh wainminig shiwag aidau amina kumpajum aidaunak ijinawagtatui. Tuja ashí Judá wegantu aidaunak Babilonian apuji depetuk achija niina nugkeen yajuakti, tuja dutikachkush kuchiiyai kajegti tusan niina idaitustatjai.  
\v 5 Tuja nuigtushkam ashí dita wajiji aidaunak apu takatai waji akik pegkeg aidaujaí nagkamsan shiwajan ashí susattajai. Dutika ai nuna ashí yajuakag Babilonia nugkanum ejegawagtinai.  
\v 6 Tuja Pashura aminak amina pataim aidaujaí achipajag Babilonia nugkanum yajupakagtinai. Dutijamawagmatai nuwi pujusam jakattame, nunikamin amina kumpajum aidau Apajuí pachisam wainka tsanu ayum nujai ijumag ukupasagtinai’ tusa Apajuí tawai”, tiuwai Jeremías. 
\s1 Jeremías senchi waitiak Apajuíyai chichamjumakbau 
\p  
\v 7 Jeremías chichaak: 
\b  
\q1 “Tuke Pujuuwah, amek minak pegkeg 
\q1 chichagtukam untsugkabiume, 
\q1 tusa tujutkumin ayu tusan aikmaijame. 
\q1 ¡Amek mina nagkaetasu senchigtinaitme, 
\q1 iman asam wagagtukmayume! 
\b  
\q1 “Minak aents aidauk tuké dushiktuinawai. 
\q1  
\v 8 Wi tuwi chichaja nuniaknuk: 
\q1 ‘¡Suwimak juki waittsatin tsawan jegawai! 
\q1 ¡Shiwag ijipatin tsawan jegawai!’ 
\q1 tusan tuké nuna tajai. 
\q1 Nuadui amina chichamjumin etseju asan 
\q1 kashi kashinig dushikiam pujajai. 
\q1  
\v 9 Tuja wi anentaimsa chichaakun: 
\q1 ‘Dekas yamai nagkamsanuk Apajuínak kajimatkitjai, 
\q1 tuja niina daajin pachisnush etsegkashtatjai’, tajai. 
\q1 ¡Tujash amina chichamem mina anentaijui 
\q1 jiijai betek nimpak mina ukunchjunash sukuawai! 
\q1 Dekas yamaik chichakchatjai tajai, 
\q1 tujash amina chichamjumnak etsegtsuk 
\q1 idaimainchau dekapeajai. 
\b  
\q1  
\v 10 “Aents aidau tuke aneas dushiktus chichainak: 
\q1 ‘¡Ashí yantamnum sapigmainaji!’ tuinawai. 
\q1 Tikichnashkam chichainak: 
\q1 ‘¡Kaunatajum tsanumjuja utugchat apujtusmi!’ 
\q1 tuidaunash antajai. 
\q1 Mina shiig kumpauchig aidaush 
\q1 itusag pegkegchaun takasa tusa utugchatan egatjuinawai. 
\q1 Nuninak: ‘Tsanusa dekapsami, 
\q1 dutikkama ajuaik depetka emegkaktatji’, tujutuinawai. 
\b  
\q1  
\v 11 “Tujash Tuke Pujuuwah, 
\q1 amek maanitan yacha depetmainchauwaitme, 
\q1 ame wijaig tuké pujame; 
\q1 nuadui mina aintuina duka minak depetukchagtatui. 
\q1 Ame depetkamu asa datsagkag, ame dutikamua 
\q1 nunak makichkish kajimatkishtinun 
\q1 tuke augmatu yujatin atinme. 
\b  
\q1  
\v 12 “Tuke Pujuu ashí senchigtinuh, 
\q1 amek aentsu anentaimtajig shiig wainme, 
\q1 nuadui ii anentaibaujish, tuja ii dutikatasa 
\q1 anentaimtamush ashí dekame. 
\q1 Ame wajuk suwimak susattame nuna wainkatasan wakegajai, 
\q1 wagki wika midauwa nunak amina idaitusjame. 
\q1  
\v 13 ¡Tuke Pujuu kantamjuatajum! 
\q1 ¡Tuke Pujuu ememattajum, 
\q1 wagki aents pegkegchau aidau 
\q1 ujudauch aidaun waitkagtaish, 
\q1 nii ayamjuk agkanmitkawai! 
\b  
\q1  
\v 14 “¡Tsawan wi akiinamua duka 
\q1 shiig pegkegchau atin ati! 
\q1 ¡Mina dukug uchigmatjukua nunú tsawanta duka 
\q1 pegkegnum chichagtai achati! 
\q1  
\v 15 Wi akiinamtai: ¡Aishmag akiinae! tusa 
\q1 mina apajun ujaka shiig anemtiksauwa duka 
\q1 shiig pegkegchau atin ati. 
\q1  
\v 16 Utusag nunú aentsuk yaakat Tuke Pujuu tsaikam, 
\q1 tuke megkaena numamtuk megkaeka tusan wakegajai. 
\q1 ¡Nuniak imaanjaujai betek kashikmas untsumiagtai, 
\q1 tuja etsa tutupit aish, 
\q1 maaniamunmas imatuinawa tumainun antak sapigma wekaya tajai! 
\q1  
\v 17-18 Imanikan waitu pujutnaitkunush 
\q1 ¿wagkanuk akiinawabiajah? 
\q1 Aika datsanmain maa ajapeam atinaitkunus 
\q1 dekas jakau akiinachamiagtai. 
\q1 ¡Akiintsuk jakauwaitkunuk 
\q1 wi ukumasbaujuk mina dukuju wake amainai!” tiuwai. 
\c 23  
\s1 Achija yajuakbau waketjagtin 
\p  
\v 1 Tuke Pujuu chichaak: 
\p “¡Chah, aents uwija kuitamin, mina uwijun pachitsuk ipisig ishima nunak wait anentajai!” 
\p  
\v 2 Tuke Pujuu, Israel aents aidaun Apajuíjiya nunú, niina aentsji aidaun apuji aina nuna chichajak: “Atum aidautijum mina uwig aidau dapampaakugme, dutikajum shiig kuitamtsuk ipisjaugme. Dutikau asagmin wi atumnak suwimkan amastatjime, wagki atumi pegkegchaujin achijag tikich nugkanum yajuakaju asagmatai. Witjai Tuke Pujuunuk, nunak dekas tajai.  
\v 3 Tujash wi dutika yajuaktinme tibau asag dutikau ainakuish, mina uwig aidaunak wiki ataktu awakjan dita nugken ikaunmattajai, dutika ai nuwiyan chijichin yuwinak yujakag kuashat wajasagti tusan. 
\p  
\v 4 “Dutika ikaunman, ditan kuitamkagtinun tikich aidaun adaitugtatjai, dutika ai ishamkagtutsuk batsamsagtinai. Witjai Tuke Pujuunuk, nunak dekas tajai”, tiuwai. 
\b  
\q1  
\v 5 Tuke Pujuu chichaak: 
\q1 “Mina aentsug aidaunmak 
\q1 aents shiig takau, yacha nunú apu atatui. 
\q1 Duka David wegantunmaya atinai. 
\q1 Nunú dekaskenmak shiig takastinai. 
\q1  
\v 6 Nii inamjatna dui, 
\q1 mina aentsug Judá wegantu aidauk ayamjumaktinai, 
\q1 tuja Israel aents aidaushkam agkan shiig batsamsagtinai. 
\q1 Nunidau asag, Apajuí daajinak: 
\q1 ‘Tuke Pujuuwai iina depetmitkagbauk’ 
\q1 tuu adaikagtinai. 
\b  
\p  
\v 7 “Tuke Pujuu chichaak: ‘Israel aents aidau Egipto nugkanum batsatun Tuke Pujuu jiijua nuna daajin tajai’ tusa tutaiya nunú yapajinatnuk tsawan jegattawai.  
\v 8 Nunikmatai nuna idayinak: ‘Israel wegantu aidau Babilonia nugkanum, tuja tikich nugka aidaunum, utsagkam batsatun Tuke Pujuu jiija yajuak ikaunmauwa nuna daajin tajai’ tiagtinai. Apajuí yajuaka ikaunmam dita nugken batsamsagtinai”, tiuwai. 
\s1 Profeta waitjin aidau 
\p  
\v 9 Jeremías chichaak: 
\q1 “Profeta aidaun anentaimtusan 
\q1 shiig senchi anentaimkun waitiajai, 
\q1 imaniai mina iyashjuk ashí sunatui. 
\q1 Tuja Tuke Pujuu niina chichame pegkegma duwi 
\q1 profeta aidaun pachis ujatkau asamtai, 
\q1 nuwi senchi anentaimkun, 
\q1 aents vinon nampeka wajukmaina numamtuk 
\q1 winchainjan iyaumain dekapeajai. 
\q1  
\v 10 Juju nugkanmak, 
\q1 ayatak aents pegkegchaun takau aidau, 
\q1 pegkegchaun takastatus tupikatin aidau, 
\q1 apu adaikam nuna anagma 
\q1 tikichi waitkau aidau aatus batsatui. 
\q1 Nunin asagmatai juju nugkanak Apajuí pegkegchaunum yumigjauwai. 
\q1 Dutikamu asamtai chijichi kagaka megkaejamtai, 
\q1 juju nugka juka uwejush wajas asae.” 
\b  
\q1  
\v 11 Tuke Pujuu chichaak: 
\q1 “Profetayaske, sacerdoteyaske 
\q1 pegkegchaun takainawai, 
\q1 núnidau asag mina emematjaku ijuntai 
\q1 jegamkamua nuwi pegkegchaun takaidaun wainkamjai. 
\q1  
\v 12 Nuadui dita jintig suwe atakuinja iyaumain atinai. 
\q1 Shitaki ajuatnume tusan wi inamjattajai. 
\q1 Suwimak jukitnuji tsawan jegamtai, 
\q1 wi ditanak suwimkan susagtatjai. 
\q1 Witjai Tuke Pujuunuk, nunak dekas tajai. 
\b  
\q1  
\v 13 “Samarianum shiig pegkegchaun wainkamjai. 
\q1 Wi dakitamua nuna profeta aidau 
\q1 Baalan pachis etsejuinawai, 
\q1 dutikainak mina aentsug aidau ima minak 
\q1 umigtumainun datupainawai. 
\q1  
\v 14 Tuja profeta Jerusalégnumia aina duka dekas 
\q1 nuna nagkaesau shiig pegkegchau ainawai. 
\q1 Nuadui ditak dekas Apajuí chichamen etsegtsuk 
\q1 dita anentaimsa jiikbaujin waitan etsejuinawai. 
\q1 Nuna aents pegkegchau aidau antuinak 
\q1 ichichmamainawai. 
\q1 Nunú aidauk, makichkish pujutjin yapajiatag 
\q1 tusagkesh anentaimainatsui. 
\q1 Ayatak pegkegchaunak takainawai. 
\q1 Nuadui ditak dekas aents sodomanmaya, 
\q1 gomorranmayajai aajaku aina nuna nagkaesau ainawai. 
\q1  
\v 15 Nuadui wi apu Tuke Pujuu ashí senchigtinun 
\q1 profeta Jerusalégnumia aina dusha wajukawagtigki 
\q1 nuna yamai etsegjai: 
\q1 Ditanak yutai yapaun ayujawagtatjai. 
\q1 Tuja umutainashkam jatain egketuan aajagtatjai, 
\q1 nunak dita pegkegchauji aidau ashí Israel aents 
\q1 aidau nugken yujaku asamtai, dutikawagtatjai”, 
\q1 tawai Apajuí. 
\b  
\q1  
\v 16 Tuja atum Israel aents aidautigmin pachipas 
\q1 Tuke Pujuu ashí senchigtina nunú chichagtamak: 
\q1 “Israel aents aidautigmek anú profeta aidau 
\q1 tujamaina duka makichkish antugkaigpa. 
\q1 Dita etsejuina nunak waitjak tuu yujawai, 
\q1 wi mina chichameg etsegtugkata tichamaitak, ditak nagkabiag tuu yujawai. 
\q1  
\v 17 Nunidau asag mina chichamjun dakitin aidaun chichajuinak: 
\q1 ‘Tuke Pujuu tujamui, 
\q1 utugchatak atsugtamiagtatui’, tuinawai. 
\q1 Tuja aents dita wakegamunak takaina nuna 
\q1 chichajuinak: ‘Makichik suwimkakesh 
\q1 jukishtatjume’, tuinawai.” 
\s1 Jeremías senchi chichakbau 
\q1  
\v 18 ¿Yaita nigki waya Tuke Pujuujai chichasush? 
\q1 ¿Yaita nuna wainkaush, tuja nuniashkush 
\q1 chichamen antugkaush? 
\q1 ¿Yaita nuna antuk puyatjus umiktajai tusa 
\q1 anentaimush? 
\q1  
\v 19 Tuke Pujuu kajekbaujiya duka dase ishamainun 
\q1 dasentama iman asa, 
\q1 aents pegkegchau aidaunak ijinattawai. 
\q1  
\v 20 Tuke Pujuu kajekbaujiya duka makichkish 
\q1 mijamtsuk ashí wajina dutikatjai tawa nuna 
\q1 umika nagkankattawai. 
\q1 Makichik tsawantai dekatnaitjume, 
\q1 wagkag dusha imaniktinaita. 
\s1 Profeta waita etsejin aidaun pachis Apajuí etsegkamu 
\q1  
\v 21 Nunú profeta aina nunak wika makichkish awematsjai, 
\q1 mina chichameg etsegtugkatajum tusanuk, 
\q1 ditanak augtanakesh augtsujai, 
\q1 dutikamaitak jiinki yujasag mina daajun pachisag etsejuinawai. 
\q1  
\v 22 Dekas mina chichamjun antuk uminakug, 
\q1 mina aentsug aidaunak mina chichamjun ujakag 
\q1 pegkegchau takatnak idaimitkamain ainawai. 
\b  
\q1  
\v 23 Tuke Pujuu chichaak: 
\q1 “Atushat akuish, tuja tikijuch akuish 
\q1 wika nuwi pujajai. 
\q1  
\v 24 Nuadui minak makichkish uumjutmainchau ainawai. 
\q1 Nayaimpinmash, nugkanmash wika pujajai, 
\q1 wi nunak Tuke Pujuun dekaskenum tajai. 
\b  
\p  
\v 25 “Anú profeta aidau waitjuinak mina pachitus Apajuíjai kajanum chichaji tuidaun antukjai.  
\v 26 Wainak waitjuinak ditak anentaimas dita wakegamun chichá yuja nunash ¿wajutik idaisagti?  
\v 27 Kajanmayan augmatuinak mina aentsug aidaun tsanuinawai, dutikam yaunchuk dita apachji aidau Baalan emematuinak mina kajimatjuki idaitusu aina numamtuk ditashkam kajimatki idaisatnume tusa.  
\v 28 Makichik profetakesh kajamkagtujag, kajanmayan tajai titi. ¡Untsu mina chichamjun antuk etsejuk, shiig betek etsegkati! Trigon dukega duka nejejaig betekchauwai.  
\v 29 Mina chichamjuk jiijai betek, nuigtu martillowai kaya awati tsaitiama imanai. Witjai Tuke Pujuunuk, nunak dekas tajai. 
\p  
\v 30 “Nuadui wika au profeta aidau dita ditak pempeentunikiag, witjai dekas Apajuí chichamen etsejunuk tusa tuu yuja nuna antakun kajeajai. Witjai Tuke Pujuunuk, nunak dekas tajai.  
\v 31 Au profeta aidau ditak anentaimas jiikiag tsanumak mina chichamjua numamtuk etsejuina nuna antakun kajeajai.  
\v 32 Au profeta aidau kajanmayan waitan etsejuinak, mina aentsug aidaun anentain yapagtuawag pegkegchau takamtikaina duwi kajeajai. Wika ditanak makichkish mina chichameg etsegtugkatajum tusanuk ishimtsujai. Nuadui ditak mina aentsug aidaunak pegkegnumkesh yaimainchau ainawai. Witjai Tuke Pujuunuk, nunak dekas tajai”, tiuwai. 
\c 26  
\ms1 Aents aidau  //  pegkegchaunum yumigjamu  //  uwemtajai pachisa agagbau 
\mr (26—45) 
\s1 Jeremíasan maatag tiagbau 
\p  
\v 1 Josíasan uchiji Joaquim Judá wegantu aidaun apuji wajas inabaun nagkamai, Tuke Pujuu Jeremíasan Jerusalén pujaun chichajak:  
\v 2 “Mina emematjaku ijuntai jegamkamua nuna waitijin jegantatak agkaju ayatak shugku ajigbauwa nuwi wajasta. Nuwi wajasam, aents Judá wegantu aidau mina emematjitatus minidau wi amina akatjamjam nunú ashí ujakta.  
\v 3 Nuna antukag pegkegchau takatan idayinak pujutjin yapajinakuig, suwimkan susatjai tiu akunush dutikashtatjai.  
\v 4 Tuja jujuwai ame dita ujaktinuk: ‘Mina antugtutsuk, wi ditan jintintuawaitag nunash umitsuk,  
\v 5 wi mina profetag aidaun ishiakbau yujasag pata pataka ujamash nunashkam antugkachaju asagmatai,  
\v 6 juju mina emematjaku ijuntai Jerusalén awa nunak yaunchuk Silónum aak mina emematjaku waitai aakmakbaun tsaikuitag dutiksanuk tsaiktatjai, dutika ai juju yaakta duka ashí aents tikich nugkanmaya aidau dushiktai atatui’ tawai Apajuí”, tiuwai Jeremías. 
\p  
\v 7 Nuna aatus Jeremías tabaun sacerdote aidau, profeta aidau, ashí aents aidaujai antukajui.  
\v 8 Tuja Tuke Pujuu tita tibaun ashí tusa inagnakmatai, sacerdote aidau, profeta aidau, ashí aents aidaujai ijuntujag Jeremíasan achikajui. Dutikawag chichajuinak: “¡Amek yamaik mantamnattame!  
\v 9 ¿Wajukeakmea amesh Tuke Pujuu daajinish, juju Apajuín jega duka, yaunchuk Silónum Apajuíjai chichatai aakmakbau wajukauwa nuniktatui tusamesh, nuigtush yaaktashkam tsaikam aents jinaamtai agkan wajastatui tusamesh tame?” tuidau. Nuna tusag ashí aents aidau nuwi batsatuk ijuntug tenteawag achikajui. 
\p  
\v 10 Nuna Judá wegantu aidaun apuji aidau antukag apu inamtain batsatu Apajuí emematku ijuntai jegamkamunum shiyakajui. Nunik jegawag nunú jega waitiji yamajam aajakua nuwi jegantag ekemsajui.  
\v 11 Nuwi pekajun sacerdote aidau, profeta aidaujai ditan chichajuinak: “Juju aentsua duka mantamnamainai, wagki atumesh antagmin: ‘Juju jega duka yaaktajaí tsainkattawai’ tuu wekagu asa”, tuidau. 
\p  
\v 12 Tusa imatiagtai, Jeremías apu aidaun ashí tikich aents aidaujai ijunun chichajak: “Apajuí emematku ijuntai jegamkamun, yaakat Jerusalégjai pachisan wi tabau antukujum nunak wiki nagkamnukek tatsujai, nunak dekas Tuke Pujuu tita tujutbaun tajai.  
\v 13 Suwimak dakitakjumek pujutjum iwajatajum, nunikjum Tuke Pujuu atumin Apajuíjiya nunú umigkatajum. Nuniagminig nii suwimkan amastatjime tujabi nunak amaschattawai.  
\v 14 Tuja wika juwi atumjai pujajai, atum itugtuktatajume, nunú atum wakegamu umiktajum.  
\v 15 Tujash atum mina mantakjumek, utugchatak atumdau atatui, wagki aents utugchatji atsaig mau asajum. Wika wiki nagkamnukek tatsujai, dekas Tuke Pujuu etsegkata tujutbaun etsegjai”, tiuwai. 
\p  
\v 16 Tusa timatai apu aidau, ashí aents aidaujai sacerdote aidaun profeta aidaujai chichajuinak: “Juju aents pegkegchau takamsamujig atsujui, niig Tuke Pujuu iina Apajuíjiya nunú tibaun etsejui, nuadui niig makichkish mantamnamaitsui”, tuidau. 
\p  
\v 17 Tusa tiagtai, apu múun aidau ujumak wajakiag nuwi aents ijunag batsatun chichajuinak:  
\v 18 “Ezequías Judá apuji wajas inamjauwa nunú tsawantin profeta Miqueas Morésetnumia aajakua nunú, Tuke Pujuu akatjam ashí aents Judá wegantu aidaun juna aatus chichajak: 
\b  
\q1 “Tuke Pujuu ashí senchigtina nunú chichaak: 
\q1 ‘Jerusalégnak tsaikagtinai; 
\q1 dutikam ayatak kaya tuwasua weaku atinai. 
\q1 Tuja nainnum Apajuí emematku ijuntai 
\q1 jegamkamua nunak dupa tsapaka akijuatnai. 
\q1 Jerusalégkak dutika tsaikbau asa jega atsau, 
\q1 ayatak ajak ajakmatai wajastatui’, tiuwai. 
\b  
\p  
\v 19 “Nuna aatus Miqueas tutaish, apu Ezequíasak Judá wegantu aidaujai ijunjag niinak maachajui. Nuadui apu Ezequíasak ashí aents aidaujai Tuke Pujuun ishamaidau asag, tsagkugkagtugta tusag segajui. Nuadui Tuke Pujuu ditan suwimkan susatag tiuwaitak tsagkujug idaisauwai. ¿Dita nuniku ainaimpash, ii Jeremías maaku utugchat igkugtag?” tiajui. 
\p  
\v 20 Tuja Semaías yaakat Quiriat-jearimnumia aajakua nuna uchiji profeta Urías Jeremíasjai betek Tuke Pujuu daajin Jerusalégkan nugka múunta nujai pegkegchaun chichagkauwai.  
\v 21 Tusa timatai, apu Joaquim niina atuwe aidaujai nuna antukag mantamnati tiuwai. Tujash nuna Urías dekaa ishamak Egipto nugkanum tupikakiuwai.  
\v 22 Nunikmatai apu Joaquim Acboran uchiji Elnatán aajakua nuna uchijin tikich aents aidaujai Urías egaktajum tusa ishiakui.  
\v 23 Dutikam yujajus Egipto nugkanum pujaun juki itawajui. Dutikawag apu Joaquiman ejetuawajui. Dutikawagmatai: “Maatajum, dutikajum aents jakau egkea ajaptai nugka taimua nuwi egkeatajum”, tusa inamjauwai. 
\p  
\v 24 Tuja Zafagka uchiji Ahicam Jeremíasan wait anentau asa, aents aidau maawainum tusa ayamjukui. 
\c 31  
\s1 Israel aents aidau dita nugken waketjamu 
\p  
\v 1 Tuke Pujuu chichaak: 
\p “Israel aents aidau achija yajuakbau Babilonia nugkanum batsata nunú ataktu waketug kaunawagmataig, wi ashí Israel aents aidaun Apajuíji atatjai, untsu dita mina aentsug agtinai”, tawai. 
\b  
\q1  
\v 2 Tuke Pujuu chichaak: 
\q1 “Israel aents aidau uwegshunum yujayanum nunak 
\q1 wi wait anenjan yaigkuitjai. 
\q1 Tuja maaniamunum jinachu aina nunashkam 
\q1 wi ayamtiksauwaitjai. 
\q1  
\v 3 Yaunchkek wika ditanak atushat wantintukuitjai. 
\q1 Nunika chichagkun: Wika atumnak tuke aneen asan, 
\q1 yamaikish tuke wait anentakun kuitamjime. 
\q1  
\v 4 Israel aents aidauwah, ataktu inantaittajime. 
\q1 Dutika ai ataktu pandereta awatkujum 
\q1 shiig aneasjum nantsemtinaitjume. 
\q1  
\v 5 Samaria mujajin ataktu uva ajakmakjum 
\q1 nunú nejekmatai, shiig aneasjum yuwatnaitjume. 
\q1  
\v 6 Tuja suntag jinta kuitamin aidau 
\q1 Efraígka mujajinia untsumainak: 
\q1 ‘¡Kaunatajum, nunikagmin Jerusalén shiyaka 
\q1 Tuke Pujuu iina Apajuíji emematiagmi!’ 
\q1 tiagtina nunú tsawan jegatnai”, tawai. 
\b  
\q1  
\v 7 Tuke Pujuu chichaak: 
\q1 “Israel aents aidau pachisjum, 
\q1 shiig aneasjum kantamatajum, 
\q1 atum ainagme tikich nugka múun aina 
\q1 nuna nagkaesau eme anentsa diitai aidautijum. 
\q1 Nuadui senchi kantamkujum: 
\q1 ‘¡Tuke Pujuu niina aentsji aidau ujumak iwaku 
\q1 juwaku aina nuna ayamjuk uwemtikjati!’ titajum. 
\q1  
\v 8 Babilonia nugkanum batsatjum nunak awakjattajime, 
\q1 tuja tikich nugkanum batsatutigminashkam 
\q1 atumi nugkemin awakjattajime. 
\q1 Wainmachu aidaush, shutuu aidaush, 
\q1 nuwa ejamtin aidaush, yama uchigmaku aidaush waketjagtinai. 
\q1 Nuninak shiig kuashat waketjagtinai. 
\q1  
\v 9 Awake anentaimag buutkiag waketiagtinai, 
\q1 nunik mininakui wi yajuakan, 
\q1 jinta pegkeg paka tukumka iyaumainchau wega nuni emagtinaitjai. 
\q1 Witjai Israel aents aidaun apajinuk. 
\q1 Tuja Efraígkai mina uchig iwaiya duka. 
\q1  
\v 10 Ashí aents aidautijum 
\q1 Tuke Pujuu chichame antuktajum, 
\q1 nunikjum nayantsa pakajin atushat yujasjum 
\q1 niina chichame etsegkatajum. 
\q1 Israel aents aidaunak Apajuí dapampaak emegkajui. 
\q1 Tujash nigki ataktu ikaunmattawai, 
\q1 dutika uwija kuitamin uwigjin kuitamama imatikas kuitamkattawai. 
\q1  
\v 11 Tuke Pujuu Israel aents aidaunak 
\q1 tikich nugka muunnumia achija yajuakbaun 
\q1 ayamjuk agkanmitkatnai. 
\q1  
\v 12 Dutika Apajuí yaigbau asag, Israel aents aidauk Jerusalén 
\q1 kaunawag shiig aneenak kantamiagtinai. 
\q1 Untsu Tuke Pujuu ditan yayaak: Trigo, vino, aceite, 
\q1 uwig aidau, baka aidau susamun nuna maawag 
\q1 shiig aneas yuwawagtinai. 
\q1 Tuja ditak ajak ajakbau yumi ukattai asa, 
\q1 pegkegchiama iman agtinai. 
\q1 Ditak atakesh depeteamak achagtinai. 
\q1  
\v 13 Tuja nuwa muntsujut aidau, aishmag datsa aidau, 
\q1 múuntuch aidau aatus shiig aneasag nantsebiagtinai. 
\q1 Wi dita anentainak ichichtugtinaitjai, 
\q1 dutikakun wake besemag batsatunak yapagtuan 
\q1 dakujamun susagtinaitjai. 
\q1 Tuja dita najaimainak waituina nuna nagkaesau 
\q1 shiig anemtiksagtinaitjai. 
\q1  
\v 14 Sacerdote aidaushkam dekas 
\q1 yutai shiig pegkeg aidaun yuwawagtinai, 
\q1 tuja mina aentsug aidaushkam, 
\q1 wi ditan susagtinaitag nunak dita atsumamun 
\q1 nagkaesau jukiagtinai, nuninak shiig anediagtinai. 
\q1 Witjai Tuke Pujuunuk, nunak dekas tajai.” 
\q1  
\v 15 Nuigtu Tuke Pujuu chichaak: 
\q1 “Ramá nugkanum senchi buutbau antuenawai, 
\q1 nunak Raquel niina uchiji jinamunum buutak imatui, 
\q1 tuja anentai ichichtugta tamash dakitawai”, tawai. 
\q1  
\v 16 Tujash Tuke Pujuu niina chichajak: 
\q1 “Raquelah, buutu pujutsuk idaisata, 
\q1 nunikam negaikijum jaipjata, 
\q1 wainkan uchigtuchu juwakchatjash tiipa, 
\q1 amina uchijum aidauk 
\q1 shiwaja nugken batsatu waketug kaunattawai. 
\q1 Nunikmatai wake besemag pujam duka 
\q1 shiig aneastatme. 
\q1 Witjai Tuke Pujuunuk, nunak dekas tajai. 
\q1  
\v 17 Uchigtuchuap wajasja tusam anentaimkum waitiame, 
\q1 tujash amina uchijum aidauk atakea duwi 
\q1 waketug kaunatnai. 
\q1 Witjai Tuke Pujuunuk nunak dekas tajai. 
\q1  
\v 18 Mina aentsug Efraín wegantu aidau kajeka buutuinak: 
\q1 ‘Israel aents aidau Apajuíjiyah, 
\q1 ¡Ametme Tuke Pujuu, ii aidauti Apajuíjimek! 
\q1 Iik toro kakajus unuinamaitsu iman ayaji, 
\q1 tujash ame unuinakbau asa, ame tabau umiaji. 
\q1 ¡Ametme jutii Apajuíjimek, 
\q1 nuadui ataktu awagkim yaijatkata! 
\q1  
\v 19 Ii aidautik ame umigtsuk wainka yujasji, 
\q1 tujash awake anentaimja ii pegkegchau 
\q1 takamsamu anentaimtusa, 
\q1 pempeentumaki iina bakui iju yujaji. 
\q1 Yaunchuk datsa asa pegkegchau takamsamu 
\q1 anentaimtusa datsaamaji’, tuidau.” 
\q1  
\v 20 Tujash Tuke Pujuu ditan chichajak: 
\q1 “Efraín aents aina duka mina uchig ainawai, 
\q1 nuadui wika dita aidaun ima senchi aneajai. 
\q1 Suwimka susanush pachitskek idaitsujai. 
\q1 ¡Ashí mina anentaigjai aneajai! 
\q1 ¡Ditanak shiig anentuinajai! 
\q1 Witjai Tuke Pujuunuk, nunak dekas tajai. 
\q1  
\v 21 Israel aents aidauwah, 
\q1 atum weajum nunú jinta shiig diisa wetajum, 
\q1 kajimatkugmesh ataktu yupichu wainkamnujum. 
\q1 Atumi wekaetaijum aajakua nunú shiig diistajum. 
\q1 Nunikjum, ¡wakitkijum atumi yaaktajin kaunatajum! 
\q1  
\v 22 Makichik nuwauch emetnag pujuchujai betek 
\q1 wainka yujajum dusha ¿wajutiya idaisattagme? 
\q1 Witjai Tuke Pujuu, Israel aents aidau Apajuíjinuk, 
\q1 juju nugka juwi pegkejan Apajuí umike. 
\q1 Nunak nuwa aishin aneak ataktu wakitkittawai”, tawai. 
\s1 Israel aents aidau atakea duwi shiig batsamsagtin 
\p  
\v 23 Tuke Pujuu, Israel aents aidaun Apajuíji ashí senchigtina nunú kajanum chichagtak: 
\p “Judá wegantu aidau shiwaja nugken batsata nuna awakjan Jerusalén ikaunmattajai. Dutika ai dita nugken, dita yaaktajin batsamas ataktu chichainak: ‘¡Jerusalégkah, amek Tuke Pujuu pegkegnum yumigsamu ata! ¡Jerusalégnum dekas shiig takamu awai!’ tiagtinai. 
\p  
\v 24 “Nunú nugkanmak, Judá wegantu aidau, dita yaaktaji aidau, ajak ajakbau aidau, uwija kuitamin aidau aatus aitnai. 
\p  
\v 25 “Tuja aents pimpikiag kakaumainchau wajas batsatunak wi ayujatnaitjai, dutikakun umutainashkam agtinaitjai”, tusa Apajuí tujutmayi. 
\p  
\v 26 Tujutkui antu pujaun shintajan, kajanmap ankaja tibaijai, nunú mina shiig awajtukmayi. 
\p  
\v 27 Tuke Pujuu chichaak: “Israel aents aidau nugken, Judá wegantu aidau nugken, aents aidau shiig kuashat, tuja kuntin aidaushkam imanisag yujakti tusan titatjai. Nunú uminkatin tsawan jegattawai.  
\v 28 Tuja tsaiktasan, ijinatasan, tegaktasan, aneaku pujuyag nunisnuk yamaishkam yaakat tsaikbaun ataktu yaaktamkatasan, ataktu ajakmatasan, ataktu iwajatasan nunú betek uminkati tusan aneaku pujuttajai. Witjai Tuke Pujuu, nunak dekas uminkatnun tajai.  
\v 29 Nunú tsawantin chichainak: ‘Múun aidau takainawai, nuniagtai uchi aidau akikmainawai’ tusa tauk makichkish atsutnai.  
\v 30 Wagki maki makichik aentsuk nii pegkegchau takamsamujin suwimkan jukitnai. Nuadui maki makichik dita pegkegchau takasbaunum jakagtinai”, tiuwai. 
\p  
\v 31 Tuja Tuke Pujuu junashkam tawai: 
\p “Wi Israel aents aidaujai, Judá wegantu aidaujai, chichaman umiktinaitag nunú tsawan jegatnai.  
\v 32 Wi chichaman umiktinaitag duka yaunchuk dita apachji aajaku aidau Egipto nugkanum batsatun jiijan ditajai chichaman umikuitag nujai betekak achatnai, wagki ditak midau ainayatak, mina chichamjun umikchaju ainawai. Witjai Tuke Pujuunuk, nunak dekas tajai. 
\p  
\v 33 “Tuja nunú tsawan jegamtai, wi ditajai chichaman umiktinaitag duka juju atinai: Wi chicham umikbauwa nuna dita anentain egketjattajai, tuja anentaimtajinish agatjagtatjai. Wi dita Apajuíji atatjai, untsu dita mina aentsug agtatui. Witjai Tuke Pujuunuk, nunak dekas tajai. 
\p  
\v 34 “Nuadui makichik aents mina chichamjun unuimag tikichi jintinmainuk makichkish atsumnashtinai, wagki nunú tsawantinig uchi aidau nagkamas múun aidaushkam ashí mina chichamjunak unuimajagtinai. Tuja wi dita tudaujinak ashí tsagkujatnaitjai. Ataktu awagkinuk dita tudaujinak adeagchatnaitjai. Witjai Tuke Pujuunuk, nunak dekas uminkatnun tajai”, tiuwai. 
\b  
\q1  
\v 35 Tuke Pujuu etsanak tsawai etsanjatnun apusauwai, 
\q1 tuja yaya, nantu, aina nunashkam kashi 
\q1 etsanjagtinun apusauwai. 
\q1 Tuja nayantsak tsukatak uutti tama imaniawai. 
\q1 Nunak Tuke Pujuu ashí senchigtina nunú tawai: 
\q1  
\v 36 “Tuja Israel aents aidau chicham umikagtinun 
\q1 wi umikag nuna betek uminachkug, 
\q1 duwi nagkamsag mina aentsug achagtinai. 
\q1 Witjai Tuke Pujuunuk, nunak dekas tajai. 
\q1  
\v 37 Untsu wi ditan anagkuawaitag nuna, 
\q1 dita pegkegchaujin idaisatag takunuk, 
\q1 makichik tsawantai nayaimpin ashí dekapa ashimak, 
\q1 nugka initkenash ashí ejeyagmatai idaisatnaitjai. 
\q1 Witjai Tuke Pujuunuk nunak dekas tajai.” 
\p  
\v 38 Tuke Pujuu chichaak: “Mina yaaktag Jerusalén tsaikbau ataktu kumpin jiikbau Hananel awa, nuwi nagkama waiti múun najanamu yaakat tuniakbaunum awa imanui yaaktamkatin tsawan jegattawai.  
\v 39 Yaakat peejamu nagkatkau aidauk, tutupit juwaki Garebnum nain awa nuwi ejeenta, nuwi tunimtikja juki Goa tutaya nuni emamu atatui.  
\v 40 Tuja aents jakau aidau ukutai, yuku aidau utsautai wake aina duka ashí midau atatui. Tuja nuigtushkam nugka agkan takaschamu entsa Cedrón tutaya aatus nagkamas, caballo waitai tutai etsa minitaiya nuni awa imanui nagkatkauwa duka ashí midau atatui. ¡Atakea duish Jerusalégkak ataktu awagki tsayamak achatnai!” tiuwai. 
\c 36  
\s1 Baruc chicham duwapnum agagbaun jega Apajuí emematku ijuntainum waya ausamu 
\p  
\v 1 Josíasa uchiji Joaquim Judá apuji wajas ipak usumat mijan inamai, Tuke Pujuu Jeremíasan chichajak:  
\v 2 “Jeremíasah, duwap ikamkata, dutikam wi Israel aents aidaun, Judá wegantu aidaun, tuja tikich nugkanmaya aidaunashkam pachisan apu Josías pujusmatai nagkamsan timajam nunú yamai tajam nujai ashí ijumjam agagta.  
\v 3 Judá wegantu aidaun wi suwimka susatasan umijag nuna antukag, pegkegchaun takaina nuna idayinakuig, dita tudaujinak tsagkujagtatjai”, tiuwai. 
\p  
\v 4 Tusa timatai, Neríasan uchiji Baruc aajakua nuna Jeremías untsuka itan Tuke Pujuu tibaunak imatiksag ashí ujakui. Dutikam Baruc nuna agajui.  
\v 5 Nuna ashí agagmatai, Jeremías Barukan chichajak: 
\p “Minak juwi achijuk emetjuawagmatai, Apajuí emematku ijuntainmag wemainchau wajasan pujajai.  
\v 6 Nuniau asamtai, tsawan ijagma pujusa Apajuí augtai jegatta duwi ame dekas Apajuí emematku ijuntainum wetá. Nunika jegaam wi Tuke Pujuu chichamen amina ujaka ai, ame agagmaum nunú senchi jiika ausata. Dutikamin Jerusalégnumia aidau, tikich aents Judá wegantu dita yaaktajin batsamin aidaujai nuwi kaunawag Tuke Pujuu chichamen antuktinme.  
\v 7 Nunikag Tuke Pujuu ditan kajejuk suwimka susatatus umia nuna dekawag, pegkegchau takamujin idayinak pujutjin yapajiachajaintash”, tiuwai.  
\v 8 Tusa tima ayu tusa nuwi weuwai. Nunik jegaa Jeremías tibaunak imatiksag Tuke Pujuu chichame agagbaun ausauwai. 
\p  
\v 9 Tuja nunú tsawantin Jerusalégnumia aidau, tikich aents Judá wegantu dita yaaktajin batsamin kaunau aidaujai ashí ijagma pujusa Tuke Pujuu augnasti tusa Josíasa uchiji Joaquim, Judá wegantu aidaun apuji aajakua nunú, tiuwai. Nunak apu Joaquim inabaujin cinco mijanan achika, nantu nueveya nunú takau ai tiuwai.  
\v 10 Nunú tsawantin Baruc Apajuí emematku ijuntainum weuwai, nunik aatu yantamnum waiti yamajam najanamu aajakua nuwi jegantatak agkaju ayatak shugku ajigbau aajakua nuwi wayauwai. Nunik nuwi Safánka uchiji Guemaríasan papii takataiji tesaamu aajakua nuwi wajas, ashí aents aidau antuinamunum Tuke Pujuu chichamen ausauwai. 
\s1 Apu aidau emtin Baruc Apajuí chichamen ausamu 
\p  
\v 11 Micaías, Guemaríasa uchiji, Safánka tijaji aajakua nunú, Tuke Pujuu chichamen Baruc augbaun ashí antukui.  
\v 12 Nunik apu pujusa inamtain weuwai, nunik papiin agau pujutai tesaamunum apu aidau: Papii agatan yacha Elisamá aajakua nunú, Semaíasan uchiji Delaías, Acboran uchiji Elnatán, Safánkan uchiji Guemarías, Ananíasan uchiji Sedequías, nuigtu tikich apu aidau aatus ijunag batsatbaunum wayauwai.  
\v 13 Nunik Micaías waya, Baruc Apajuí chichame agagbaun ashí aents aidau emtin aujun antukbaujinak imatiksag etsegkauwai.  
\v 14 Tusa etsegkamtai, apu atuwe aidau Netaníasan uchiji, Selemíasan tijaji, Cusígkan ama tijaji Jehudí aajakua nuna, Baruc ujakta nii chicham agagbaun aents aidau antuinamunum ausama nuna itaati tusa akateg awemajui. Nunú ujakam Barucshakam chicham agagbaun juki dita batsatbaunum jegauwai.  
\v 15 Nunikmatai dita chichajuinak: 
\p “Anui ekemsam chicham agagbau takakam nunú ausata antukmi”, tuidau. 
\p Tusa tima, Baruc nuna ausauwai.  
\v 16 Dutika aujus ashimkamtai, nuna antukag ishamak pempeentunikiag chichainak: 
\p “Dekas juju pachisa apu ujakagmi”, tiajui. 
\p  
\v 17 Nuna tusag Barukan iniinak: 
\p “Jusha tuwiya agagmaume nunú etsegkata. ¿Jeremíasak tuu agagta tujamatai agagmaum?” tuidau. 
\p  
\v 18 Tusa tama Baruc ditan ayaak: 
\p “Wika junak Jeremías tuu agagta tujutkui, nuna imatiksanuk tintai agagmajai”, tiuwai. 
\p  
\v 19 Tusa timatai niina chichajuinak: 
\p “¡Nuniakuig amek yamaikiuch Jeremíasjai mai tupikakim uumkatajum! ¡Makichkish atum pujamunak dekashtinme!” tiajui. 
\s1 Apu Joaquim papii agagbaun apeamu 
\p  
\v 20 Nuna tusag apu atuwe aidauk nunú chicham agagbaun Elisamá pujusa papii takataijin awaya ukuinak, nuna pachis apu ujakagtatus wegajui.  
\v 21 Dutika ujakam, nunú chicham agagbau Elisamá papii takatainum au asamtai, nunú utita tusa Jehudínkan awemauwai. Tusa tima juki itaa, apu niina atuwe aidaujai antuinamunum ausauwai.  
\v 22 Tuja nantu Quislevtinig tsetsek aajakui. Iman asamtai apuk tsetsektin pujustinji tesaamunum nuwi jii anamak pujau.  
\v 23 Nuwi pujau asa Jehudí chicham agagbaun aujus wetai, ausa nagkaikimun apu kuchiyai tsupik jinum pataka apejakui. Duti dutikakua ashí apea ashimkauwai.  
\v 24 Nunú chicham Apajuínu agagbaun antuinakush, apuk niina atuwe aidaujaig makichkish ishamkachajui, tuja awake anentaimjagkesh wake besemag dekapenakug jáanchjinak ichigchajui.  
\v 25 Nunú chicham agagbaun apu apetai, Elnatán, Delaías, Guemaríasjai niina chichajuinak: “Wait aneasam apeawaipa”, tuidau. Tusa tamash ditanak antugtsuk,  
\v 26 Jerahmeel aajakua nuna, tuja Asrielan uchiji Seraíasan, Abdeelan uchiji Selemíasan aatus apu chichajak: “Baruc Jeremías tabaun agauwa nunú Jeremíasjai achikjum egkeatajum”, tusa inamjauwai. Tujash ditanak Tuke Pujuu uukui wainkainum tusa. 
\s1 Jeremías Barukan ataktu Apajuí chichame agagta tusa inagbau 
\p  
\v 27 Baruc Tuke Pujuu chichamen Jeremías agagta tima agajua nuna apu apea ajapamtai, Tuke Pujuu Jeremíasan ataktu chichajak:  
\v 28 “Yamajam duwap ikamkata, dutikam yama nagkamchaku agagbaun Judá apuji Joaquim apeabia nujai betek nunú duwapnum agagta.  
\v 29 Tuja nuigtushkam apu Joaquim chichagkum: ‘Tuke Pujuu chichaak: Babilonianmaya aidauk makichkish megkaetsuk tuké kaunattawai, nunikag aents aidaunak kuntin aidaujai ijinawagtatui, tusa Jeremías agajua nunú apeaume, dutikakum Jeremíaschakam jiyakume.  
\v 30 Dutikau asam yamai juju dekata. Amina uchijum aina nuwiyag makichkish Judá wegantu aidaun apujig achatnai. Tuja ame jakaminig ukugmaschagtinai, dutijamawagmatai amina iyashmek etsa sukuam tepetnai, untsu kashi bichatug tepetnai.  
\v 31 Aminak ame wegantu aidaujai, tuja amina atuwem apu aina nujai ijumjan atumi pegkegchaujin suwimkan amastatjime. Atumin, tuja Jerusalégnumia aidaunashkam, ashí Judá wegantu aina nujai ijumjan suwimak ishamain aidaun amastatjime tusan tibaijim nunak imatiksanuk amastatjime. Nunak dutikattajime wagki atumek mina umigtukchau asagmin’, tujamui Apajuí”, tiuwai Jeremías. 
\p  
\v 32 Nuna tusa nagkanak, Jeremías tikich duwapen juki Baruc papiin agau aajakua nuna susauwai, dutikam nuna juki Jeremías tabaunak imatiksag ashí agajui. Nunak yama nagkamchaku agagbaun apu Joaquim apeauwa nuna ashí betek agajui, dutikak, nuigtushkam tikichin nunú chicham agagbaujai betekmamtinun Jeremías ekek tutai nunashkam dutiksag ashí agajui. 
\c 37  
\s1 Jeremías achika egkeamu 
\p  
\v 1 Babilonia nugkan apuji Nabucodonosor, apu Joaquima uchiji Jeconíasan Judá apuji adaimainun idayak, Josíasa uchiji Sedequíasan apu adaikauwai.  
\v 2 Tujash Sedequíasak, niina atuwe aidaush, tuja tikich aents Judá wegantu aidaushkam Jeremías Tuke Pujuu chichamen etsegbaunak antugkachu ainawai. 
\p  
\v 3 Nuninayatak apu Sedequías Selemíasan uchiji Jucal aajakua nuna sacerdote Sofonías Maaseíasan uchiji aajakua nujai akateg profeta Jeremías ujaktajum tusa ishiakui. Dutika ishimak aatus akatmamjauwai: “Jeremíasah, Tuke Pujuu iina Apajuíjiya nunú ame segatkagtita”, tiuwai.  
\v 4 Tuja Jeremíasak eke aents achika chimpitainmak egkeachbau asa, agkan wekagajakui.  
\v 5 Nunú tsawantin babilonianmaya suntag aidau Jerusalégkan jetektatus tenteawag batsamtau. Nunik batsatun egiptunmaya suntag aidau apu Sedequías maanitai atukagtatus mininawai tabaun antukajui, nunik antukag ishamak dita nugken waketuinak Jerusalégnak ukukiajui. 
\p  
\v 6 Nunikagmatai Tuke Pujuu Jeremíasan chichajak:  
\v 7 “Judá apuji aents chichama etsejin aidaun awemama nunú ujakta: Egiptunmaya suntag aidau dita ayamjuktatus minina duka dita nugken waketjattawai.  
\v 8 Nunikmatai, babilonianmaya aidau ataktu waketug Jerusalégnak jetekag depetuk ditanu emagtatui, dutikainak yaaktanak jiiyai apeawagtatui.  
\v 9 Tuke Pujuu chichaak: Babilonianmaya aidauk tuke shimak shiyakaje, ataktu wakitkig kaunachagtatui tusagmek shiijak aneasaigpajum, nunak nunikchattawai.  
\v 10 Tuja atumin ataktu jetepainakui, atum ashí ijinawagminish, ujumak aents kupinau aidau dita aakjin juwaju aina nunú ataktu nantajag atumnak depetamak atumi yaaktajinak jiiyai ekemakagtatui”, tiuwai. 
\p  
\v 11 Tuja egiptunmaya suntag aidau mininamun antukag, caldeo suntag aidau Jerusalégkan tentea batsatu waketuinaig,  
\v 12 Jeremías nuwi pujau jiinkiuwai, Benjamín wegantu aidau nugken wetatus, wagki nuwi jegaa nugkan tinamkagtiagtai niinu atinun jukitin asa.  
\v 13 Nunik wea weakua Benjamígka waitijin jegattaman, Selemíasan uchiji Irías Hananíasan tijaji waitin kuitamin aajakua nunú awajus chichajak: 
\p “¡Amek dekas babilonianmaya suntag aidaujai ijunjatjai tusameap wakegame!” tiuwai.  
\v 14 Tusa tama Jeremías ayaak: 
\p “¡Wika babilonianmaya suntag aidaujai ijunjatag tusanuk wakegatsjai!” tiuwai. 
\p Tusa tutaish antugtsuk achika juki apu atuwe batsatbaunum ejegauwai.  
\v 15-16 Dutikamtai nunú apu atuwe aidau Jeremíasan shiig senchi kajejuidau asag, suwimatajum dutikajum Jonatán papiin agauwa nuna jee aajakua nunú, yamai aents achika egketai awajsamua nuwi initak taimua nuwi egkeatajum tusa tima egkeawajui. Dutikam nuwi kuashat tsawan pujusui. 
\p  
\v 17 Nuwi pujaun, Jeremías jiikjum wi pujusa inamtaijua juwi itaatajum tusa apu Sedequías, tiuwai. Tusa timatai Jeremíasan juki ejegawajui. Dutikawagmatai apu Sedequías ima niinak akanak iniak: 
\p “¿Chicham etsegkata tusa Tuke Pujuu akatamjamush atsuak?” tau. 
\p Tama Jeremías ayaak: 
\p “Ehe awai, tuja apujuh, aminak Babilonia nugkan apujiya nunú depetamkattawai tujutmae”, tiuwai. 
\p  
\v 18 Nuna tusa niina pempeentuki iniak: 
\p “Atum mina achigkajum egketuaujum nunash wisha ¿aminash, amina atuwem aidaunash, nuniachkunush ashí tikich aents aina nunash waji pegkegchauna dutikau asamtai egketuaugme?  
\v 19 Tuja profeta aidau chichainak, babilonianmaya aidauk atumnak, tuja atumi nugkenash jetekchagtinai tusa tujamin agma dusha ¿tuwi batsatua?  
\v 20 Apuh, minash wait anenjugta tajame. Wait aneasam, ¡ataktu awagkimek Jonatágka jeen egkeatajum tusamek tiipa! ¡Nuwi epenim pujus jakati tusamesh wait aneasam idaitusaipa!” tiuwai. 
\p  
\v 21 Tusa timatai apu Sedequías, Jeremías jukijum agá suntaja ijuntai awa nuwi apusajum, kashi kashinig pagka sujin yuja nuwiya makichik pag sutatjume, tiuwai. Tusa timatai jukiag, suntaja ijuntain apusajui. Dutikawag makichik tsawantai makichik pagkan suwidau. Dutika suu batsatu ashí yaaktanum pag amuekamtai, sutsuk idaisajui. 
\c 38  
\s1 Jeremías achika waanum egkeamu 
\p  
\v 1 Nunú kuashat tsawan nagkaemakiu ai, Jeremíasan shiwaaji aidau: Matánka uchiji Sefatías, Pashura uchiji Guedalías, Selemíasa uchiji Jucal, aatus antuinamunum Jeremías aents tuwakbaunum chichaman etsejak:  
\v 2 “Tuke Pujuu chichaak: ‘Juju yaaktanum juwak pujauk maaniamunum, nujantai, jatai aatus jinawagtatui, untsu babilonianmaya suntag aidaunum sujumanuk, pujutjinakesh uwemtijattawai.’  
\v 3 Tuja nuigtu Tuke Pujuu chichaak: ‘Juju yaaktanak Babilonia nugkan apuji niinu awajsattawai, dutikamtaig makichkish atanmainchau atatui’, tawai Apajuí”, tiuwai Jeremías. 
\p  
\v 4 Nuna antukag apu atuwe aidau apun chichajuinak: 
\p “Jeremiasak nuna taku, suntag yaaktanum batsata nunak ashí aents aidaujai, kakakchau wainkauchia nunin anemtikawai. Juju aentsuk pegkegnakesh augmatu wekaetsui, ima pegkegchaunak augmatui”, tuidau. 
\p  
\v 5 Tusa tiagtai apu Sedequías ditan ayaak: 
\p “Ayu, atum tajum duka pegkejai, atum itugkatag tajume dutikatajum. Wika atum dutikatag tabaunak dutikawaigpajum tumaitsujai”, tiuwai.  
\v 6 Tusa timatai, shimutuk Jeremíasan achikajui, dutikawag daekai jigkawag apu uchiji Melquías aajakua nuna yumigmatji agá taimu aajakua nuwi egkeawajui. Nunú yumigmatnumak yumi atsau, ayatak kunta piyaku asamtai, nuwi initak amamki egkemsauwai.  
\v 7 Dutikawaju ai etiope aents apu inake kajittsa diitai Ébed-mélec apu inamtain pujujakua nunú, Jeremíasan achika waanum egkeawaje tabaun dekauwai. Nunú tsawantinig apu Sedequíasak Benjamígka waitiji tutainum ijunak pujujakui.  
\v 8 Untsu Ébed-mélec apu pujusa inamtaijin pujau jiinki apu ujaktatus weuwai.  
\v 9 Nunik jegajua ujaak: “Apujuh, au aents aidau Jeremíasan shiig senchi waitkainawai, nugka taimunum initak egkeam puja nuwig pujus nujantai jakattawai, tuja pag sumainchakam ashí yaaktanmak atsawai”, tiuwai.  
\v 10 Tusa ujakam apu Sedequías Ébed-mélekan inajui, treinta aents jukim Jeremías eke jatsaig jiiktajum tusa.  
\v 11 Tusa tima Ébed-mélec aentsu yajuak, apu pujusa inamtaijin makichik tesaamu jáanch ijumtainum waya, jáanch mamukun juki, daekai jigka Jeremíasan detuauwai.  
\v 12 Dutika chichajak: 
\p “Anú jáanchia duwi kuntugmin pempemagta, daek pakapakai”, tiuwai. Tusa tima kuntujin jáanchin pempemajui.  
\v 13 Nunikmatai daeka detuawag jiikiajui. Dutika jiikim Jeremiasak apu suntaji aidau ijuntai agá aajakua nuwi pujau. 
\s1 Sedequías Jeremíasan untsukbau 
\p  
\v 14 Nuwi pujaun Jeremías jukijum Apajuí emematku ijuntai waitiji kampatuma nuwi ejentatajum, tusa apu Sedequías timatai, jukiag ejeentajui. Dutikawagmatai apu Sedequías Jeremíasan jegantun chichajak: 
\p “Wi amina iniastatjam nunú waitjutsuk dekas aigkata”, tiuwai.  
\v 15 Tusa tama Jeremías ayaak: 
\p “Wi dekaskenum aimkamtaig amek mantuattame, tuja wi chicham pegkejan amina ujaish antugtukchattame”, tiuwai.  
\v 16 Tusa tutai apu Sedequías nii dekaskenum umiktinjin ashishmas chichajak: 
\p “Atsa, mashtatjame, nunak Tuke Pujuu iina pujutan amasua nuna daajin tajame. Tuja tikich maatnume tusanush idaisashtatjame”, tiuwai.  
\v 17 Tusa tama Jeremías Sedequíasan chichajak: 
\p “Ayu, kame ujaktajame: Tuke Pujuu ashí senchigtina nunú chichaak: ‘Atum aidautigmek ashí Babilonia apujin sumimkatajum, nunikjumek amina pataim aidaujaí uwemjattagme. Tuja yaaktakesh apenashtatui.  
\v 18 Untsu ame nunishtaik, juju yaaktanak babilonianmaya aidau utsantuawag apeawagtatui, dutikainakui atumshakam makichkish uwemjashtatjume’ tujamui”, tiuwai.  
\v 19 Tusa tutai Sedequías ayaak: 
\p “Kame nunak nunimainaitjai, tujash judío aents aidau babilonianmayajai ijunjaja nuna wi ishamajai. Wi Babilonia apujin yunumtaik, nunú judío aents aidau minak senchi suwi suwimjuinakua mantumain ainawai”, tiuwai.  
\v 20 Tusa tutai Jeremías ayaak: 
\p “Apujuh, aminak judío aents aidauk suwimjamachagtatui. Tuke Pujuu chichamen wi amina tajam nunú wait aneasam umikta, nunú umiakmek shiig pujustatme, tuja nuigtush mantamachagtatui.  
\v 21 Untsu Tuke Pujuu tujama nunú umiatsminish, waji utugchatak nagkaetamkiti nuna Apajuí iwaintugkame.  
\v 22 Apujuh, ame pujusa inamtaigmin nuwa aidau batsata nunak babilonianmaya aidau ashí yajuakag suntaja apuji aidaun susagtatui, dutikam imau batsamas chichainak: 
\p “ ‘Apu Sedequíasnak niina kumpauchiji aidau tsanujag depetkagmayi, amina kumpajum aidauk ashí idaitamsaje. Tuja amek suwemea iman kuntanum amamam tepeattaku wajame’, tujamiagtinai”, tiuwai.  
\v 23 Nuna tusa nuigtushkam chichajak: 
\p “Amina nuwem aina nunak uchijum aidaujai ashí Babilonia nugkanum yajuakagtatui, tuja ameshkam uwemjashtatme, Babilonia apuji aminak achigmaktatui, tuja yaaktanashkam apeawagtatui”, tiuwai.  
\v 24 Tusa tutai Sedequías Jeremíasan chichajak: 
\p “Ame pujutjum puyatjakmek, juju mina ujatkaum duka makichkish tikichik ujakaipa.  
\v 25 Tuja wi amijai chichasag nuna apu aidau dekawag, waji pachisam apush ausamume, tuja niish wajinjutpame nunú uutsuk etsegkata, tuja nunú etsegchakmek mantamnattame tujamain ainawai.  
\v 26 Tusa tujamainakuig ame chichagkum: ‘Ataktu awagtukmek Jonatágka jeen aents achika egketai awa nuwi egkeam pujus jakati tusamek wait aneasam tujutipa tusan augkun pujumjai’ tita”, tiuwai.  
\v 27 Tusa apu tibaunak imatiksag ashí apu atuwe aidau Jeremíasan shimutkajui. Nunik jegajuawag inidau. Tusa iniam, apu tuu aimkata tibaunak imatiksag betek aimkauwai. Tusa timatai, apu Sedequías Jeremíasjai chichamun antukchaju asag utugchatan tutsuk agkan ukukiajui.  
\v 28 Tuja Jeremiasak suntaja ijuntai agá aajakua nuwi pujau. Nuwi pujaig Jerusalégkan jetekag utuawajui.