\id 2JN
\h 2 JUAN
\toc1 Yóxin xroon tsíkjin chꞌín Juan
\toc2 2 JUAN
\toc3 2 Jn.
\mt1 Yóxin xroon tsíkjin chꞌín Juan
\c 1
\p 
\v 1 Janhan mé ijnko nkexro ó táda tꞌayakonhen ni̱nko mé ikjian tí xroon tsꞌáyéhe̱ tí sín tsíkjeyá Dios tójnkotsé sín ntiha, la mé chaxín tjua̱ha̱ sín: a̱ ntá jehya janhván, la kja̱xin kaín tí sín chóxin tí tan chaxín.
\v 2 Tjua̱hará tí jahará kíxin tí tan chaxín ó chónta a̱sénni, tíha mé tsꞌejókoni jnkochríxín.
\v 3 Itꞌéni Dios la ko Ìnchéni Jesucristo mé Xje̱en Dios chrókjuintayaonrá chꞌán la ko chrókui̱konóa̱ha̱rá chꞌán la ko chrótjáhará chꞌán kjuaxróxin kíxin chaxín tjuahará chꞌán.
\p 
\v 4 Imá chàna kꞌuíkua̱n kíxin isorá tjejorá títekáonrá tí nkehe chaxín, éxí tsíkꞌe̱to̱an Itꞌéni Dios.
\v 5 A̱ ntá jie jahará kíchó ni, xrja̱nóa̱hará kíxin chrótjuèhérá kíchuárá. Méxra̱ xi̱kaha tjékjian tí xroon i, la jehya ijnko nkehe ni̱xin tsíkꞌe̱to̱an Dios. Náhí. Tíha la mé tí nkehe tsíkꞌáyéhe̱ni tí kjuákꞌe Ìnchéni Jesucristo.
\v 6 A̱ ntá tí tjuèheni kíchó ni la mé tíhi kíxin chrókꞌuejóni éxí tsíkꞌe̱to̱an Dios; a̱ ntá tí nkehe tsíkꞌe̱to̱an Dios la mé ó tsíkinhínrá jahará tí senó kíxin chrótjuèheni kíchó ni.
\s1 Tí chojni xrichꞌia
\p 
\v 7 Nchónhya chojni chjasintajni xrichꞌia sín titekakonhya sín kíxin Jesucristo kui kꞌóna chojni. A̱ ntá tí chojni xi̱kaha mé ixri xrichꞌia la ko nínkakonhen Cristo.
\v 8 Chrókóxakonhanrá kíxin chrókꞌuitjáyanhya tí xra̱ kjui̱chꞌerá kíxin na̱xa̱ chrókꞌuayéhérá tí nkehe tsjintaxín tsꞌayéhérá.
\p 
\v 9 A̱ ntá tí siín ijnko nkexro kuíto̱he tí nkehe kjuako Cristo ntá kjuichroe la mé chóntahya sín Dios; a̱ ntá tí nkexro títo̱ehya tí nkehe kjuako Cristo mé chónta sín Itꞌéni Dios la ko tí Xje̱en chꞌán.
\v 10 A̱ ntá jnkojín sín chrókjuijitsjehe tí jahará, a̱ ntá ntoáhya chrókjuako sín, la chrókjuánjonhyará kjuachaxin chrókuito̱he tí sín a nto̱ará la ko ni chrónixje̱éhyará sín jnkojína.
\v 11 A̱ ntá tí nkexro tsonixje̱he̱ tsontáchro kíxin: “¿Á jína kꞌuinka?” na mé éxí tóxrjínhi̱n sín tí nkehe jínahya ichꞌe tí sín a.
\s1 Tí tan tsjixixín
\p 
\v 12 Chonta nchónhya nkehe chrókuinhínrá jahará, kjánchó tjínka̱konhya chrókjian xroon ó. Náhí. Tjínka̱van kíxin tjoka chrókjuasántsjahárá tí jahará tsonixja̱hará kíxin chrókjuintaxín chrókóchéhe̱ni.
\p 
\v 13 Tí sín kíchuárá tójnkotsé kuènte ni̱nko ntihi, mé tí sin kja̱xin tsíkjeyá Dios, mé nixjahará sín. Amén. Ó tjen.
