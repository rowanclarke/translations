\v 1 \w Étant|strong="G2532"\w* \w parti|strong="G2532"\w* \w de|strong="G2532"\w* \w ce|strong="G3588"\w* \w lieu|strong="G1564"\w*, \w Jésus|strong="G2532"\w* \w vint|strong="G2064"\w* \w aux|strong="G2532"\w* confins \w de|strong="G2532"\w* \w la|strong="G2532"\w* \w Judée|strong="G2449"\w*, \w au|strong="G1519"\w* \w delà|strong="G4008"\w* \w du|strong="G2532"\w* \w Jourdain|strong="G2446"\w*\f + \fr 10:1 \ft 10, 1. Matth. 19, 1 ; Luc. 9, 51. \fq Au delà du Jourdain\ft  : commencement du dernier voyage de Jésus à Jérusalem par la Pérée. . cf. Matth. 19, 3-17 ; Luc. 16, 17-18.\f* ; \w et|strong="G2532"\w* \w le|strong="G2532"\w* \w peuple|strong="G3793"\w* \w s|strong="G1438"\w*’\w assembla|strong="G4848"\w* \w de|strong="G2532"\w* \w nouveau|strong="G3825"\w* \w près|strong="G4314"\w* \w de|strong="G2532"\w* \w lui|strong="G2532"\w*, \w et|strong="G2532"\w*, \w suivant|strong="G2064"\w* \w sa|strong="G2532"\w* \w coutume|strong="G1486"\w*, \w il|strong="G2532"\w* recommença \w à|strong="G1519"\w* \w les|strong="G2532"\w* \w enseigner|strong="G1321"\w*.
\v 2 \w Les|strong="G2532"\w* \w Pharisiens|strong="G5330"\w* \w l|strong="G2532"\w*’\w ayant|strong="G2532"\w* abordé \w lui|strong="G2532"\w* \w demandèrent|strong="G1905"\w* \w s|strong="G1487"\w*’\w il|strong="G2532"\w* \w était|strong="G3588"\w* \w permis|strong="G1832"\w* \w à|strong="G2532"\w* \w un|strong="G2532"\w* \w mari|strong="G2532"\w* \w de|strong="G2532"\w* \w répudier|strong="G2532"\w* \w sa|strong="G2532"\w* \w femme|strong="G1135"\w* : \w c|strong="G2532"\w*’\w était|strong="G3588"\w* \w pour|strong="G2532"\w* \w le|strong="G2532"\w* \w mettre|strong="G2532"\w* \w à|strong="G2532"\w* \w l|strong="G2532"\w*’\w épreuve|strong="G3985"\w*.
