\id 1TH Sanskrit Bible (NT) in Cologne Script (satyavEdaH ।)
\h 1 Thessalonians
\toc1 1 thiSalanIkinaH patraM
\toc2 1 thiSalanIkinaH
\toc3 1 thiSalanIkinaH
\mt1 1 thiSalanIkinaH patraM
\c 1
\p 
\v 1 paulaH silvAnastImathiyazca piturIzvarasya prabhO ryIzukhrISTasya cAzrayaM prAptA thiSalanIkIyasamitiM prati patraM likhanti| asmAkaM tAta IzvaraH prabhu ryIzukhrISTazca yuSmAn pratyanugrahaM zAntinjca kriyAstAM|
\p 
\v 2 vayaM sarvvESAM yuSmAkaM kRtE IzvaraM dhanyaM vadAmaH prArthanAsamayE yuSmAkaM nAmOccArayAmaH,
\p 
\v 3 asmAkaM tAtasyEzvarasya sAkSAt prabhau yIzukhrISTE yuSmAkaM vizvAsEna yat kAryyaM prEmnA yaH parizramaH pratyAzayA ca yA titikSA jAyatE
\p 
\v 4 tat sarvvaM nirantaraM smarAmazca| hE piyabhrAtaraH, yUyam IzvarENAbhirucitA lOkA iti vayaM jAnImaH|
\p 
\v 5 yatO'smAkaM susaMvAdaH kEvalazabdEna yuSmAn na pravizya zaktyA pavitrENAtmanA mahOtsAhEna ca yuSmAn prAvizat| vayantu yuSmAkaM kRtE yuSmanmadhyE kIdRzA abhavAma tad yuSmAbhi rjnjAyatE|
\p 
\v 6 yUyamapi bahuklEzabhOgEna pavitrENAtmanA dattEnAnandEna ca vAkyaM gRhItvAsmAkaM prabhOzcAnugAminO'bhavata|
\p 
\v 7 tEna mAkidaniyAkhAyAdEzayO ryAvantO vizvAsinO lOkAH santi yUyaM tESAM sarvvESAM nidarzanasvarUpA jAtAH|
\p 
\v 8 yatO yuSmattaH pratinAditayA prabhO rvANyA mAkidaniyAkhAyAdEzau vyAptau kEvalamEtannahi kintvIzvarE yuSmAkaM yO vizvAsastasya vArttA sarvvatrAzrAvi, tasmAt tatra vAkyakathanam asmAkaM niSprayOjanaM|
\p 
\v 9 yatO yuSmanmadhyE vayaM kIdRzaM pravEzaM prAptA yUyanjca kathaM pratimA vihAyEzvaraM pratyAvarttadhvam amaraM satyamIzvaraM sEvituM
\p 
\v 10 mRtagaNamadhyAcca tEnOtthApitasya putrasyArthata AgAmikrOdhAd asmAkaM nistArayitu ryIzOH svargAd AgamanaM pratIkSitum Arabhadhvam Etat sarvvaM tE lOkAH svayam asmAn jnjApayanti|
\c 2
\p 
\v 1 hE bhrAtaraH, yuSmanmadhyE 'smAkaM pravEzO niSphalO na jAta iti yUyaM svayaM jAnItha|
\p 
\v 2 aparaM yuSmAbhi ryathAzrAvi tathA pUrvvaM philipInagarE kliSTA ninditAzca santO'pi vayam IzvarAd utsAhaM labdhvA bahuyatnEna yuSmAn Izvarasya susaMvAdam abOdhayAma|
\p 
\v 3 yatO'smAkam AdEzO bhrAntErazucibhAvAd vOtpannaH pravanjcanAyuktO vA na bhavati|
\p 
\v 4 kintvIzvarENAsmAn parIkSya vizvasanIyAn mattvA ca yadvat susaMvAdO'smAsu samArpyata tadvad vayaM mAnavEbhyO na rurOciSamANAH kintvasmadantaHkaraNAnAM parIkSakAyEzvarAya rurOciSamANA bhASAmahE|
\p 
\v 5 vayaM kadApi stutivAdinO nAbhavAmEti yUyaM jAnItha kadApi chalavastrENa lObhaM nAcchAdayAmEtyasmin IzvaraH sAkSI vidyatE|
\p 
\v 6 vayaM khrISTasya prEritA iva gauravAnvitA bhavitum azakSyAma kintu yuSmattaH parasmAd vA kasmAdapi mAnavAd gauravaM na lipsamAnA yuSmanmadhyE mRdubhAvA bhUtvAvarttAmahi|
\p 
\v 7 yathA kAcinmAtA svakIyazizUn pAlayati tathA vayamapi yuSmAn kAgkSamANA
\p 
\v 8 yuSmabhyaM kEvalam Izvarasya susaMvAdaM tannahi kintu svakIyaprANAn api dAtuM manObhirabhyalaSAma, yatO yUyam asmAkaM snEhapAtrANyabhavata|
\p 
\v 9 hE bhrAtaraH, asmAkaM zramaH klEेzazca yuSmAbhiH smaryyatE yuSmAkaM kO'pi yad bhAragrastO na bhavEt tadarthaM vayaM divAnizaM parizrAmyantO yuSmanmadhya Izvarasya susaMvAdamaghOSayAma|
\p 
\v 10 aparanjca vizvAsinO yuSmAn prati vayaM kIdRk pavitratvayathArthatvanirdOSatvAcAriNO'bhavAmEtyasmin IzvarO yUyanjca sAkSiNa AdhvE|
\p 
\v 11 aparanjca yadvat pitA svabAlakAn tadvad vayaM yuSmAkam EkaikaM janam upadiSTavantaH sAntvitavantazca,
\p 
\v 12 ya IzvaraH svIyarAjyAya vibhavAya ca yuSmAn AhUtavAn tadupayuktAcaraNAya yuSmAn pravarttitavantazcEti yUyaM jAnItha|
\p 
\v 13 yasmin samayE yUyam asmAkaM mukhAd IzvarENa pratizrutaM vAkyam alabhadhvaM tasmin samayE tat mAnuSANAM vAkyaM na mattvEzvarasya vAkyaM mattvA gRhItavanta iti kAraNAd vayaM nirantaram IzvaraM dhanyaM vadAmaH, yatastad Izvarasya vAkyam iti satyaM vizvAsinAM yuSmAkaM madhyE tasya guNaH prakAzatE ca|
\p 
\v 14 hE bhrAtaraH, khrISTAzritavatya Izvarasya yAH samityO yihUdAdEzE santi yUyaM tAsAm anukAriNO'bhavata, tadbhuktA lOkAzca yadvad yihUdilOkEbhyastadvad yUyamapi svajAtIyalOkEbhyO duHkham alabhadhvaM|
\p 
\v 15 tE yihUdIyAH prabhuM yIzuM bhaviSyadvAdinazca hatavantO 'smAn dUrIkRtavantazca, ta IzvarAya na rOcantE sarvvESAM mAnavAnAM vipakSA bhavanti ca;
\p 
\v 16 aparaM bhinnajAtIyalOkAnAM paritrANArthaM tESAM madhyE susaMvAdaghOSaNAd asmAn pratiSEdhanti cEtthaM svIyapApAnAM parimANam uttarOttaraM pUrayanti, kintu tESAm antakArI krOdhastAn upakramatE|
\p 
\v 17 hE bhrAtaraH manasA nahi kintu vadanEna kiyatkAlaM yuSmattO 'smAkaM vicchEdE jAtE vayaM yuSmAkaM mukhAni draSTum atyAkAgkSayA bahu yatitavantaH|
\p 
\v 18 dvirEkakRtvO vA yuSmatsamIpagamanAyAsmAkaM vizESataH paulasya mamAbhilASO'bhavat kintu zayatAnO 'smAn nivAritavAn|
\p 
\v 19 yatO'smAkaM kA pratyAzA kO vAnandaH kiM vA zlAghyakirITaM? asmAkaM prabhO ryIzukhrISTasyAgamanakAlE tatsammukhasthA yUyaM kiM tanna bhaviSyatha?
\p 
\v 20 yUyam EvAsmAkaM gauravAnandasvarUpA bhavatha|
\c 3
\p 
\v 1 atO'haM yadA sandEhaM punaH sOPhuM nAzaknuvaM tadAnIm AthInInagara EkAkI sthAtuM nizcitya
\p 
\v 2 svabhrAtaraM khrISTasya susaMvAdE sahakAriNanjcEzvarasya paricArakaM tImathiyaM yuSmatsamIpam aprESayaM|
\p 
\v 3 varttamAnaiH klEzaiH kasyApi cAnjcalyaM yathA na jAyatE tathA tE tvayA sthirIkriyantAM svakIyadharmmamadhi samAzvAsyantAnjcEti tam AdizaM|
\p 
\v 4 vayamEtAdRzE klEेzE niyuktA Asmaha iti yUyaM svayaM jAnItha, yatO'smAkaM durgati rbhaviSyatIti vayaM yuSmAkaM samIpE sthitikAlE'pi yuSmAn abOdhayAma, tAdRzamEva cAbhavat tadapi jAnItha|
\p 
\v 5 tasmAt parIkSakENa yuSmAsu parIkSitESvasmAkaM parizramO viphalO bhaviSyatIti bhayaM sOPhuM yadAhaM nAzaknuvaM tadA yuSmAkaM vizvAsasya tattvAvadhAraNAya tam aprESayaM|
\p 
\v 6 kintvadhunA tImathiyO yuSmatsamIpAd asmatsannidhim Agatya yuSmAkaM vizvAsaprEmaNI adhyasmAn suvArttAM jnjApitavAn vayanjca yathA yuSmAn smarAmastathA yUyamapyasmAn sarvvadA praNayEna smaratha draSTum AkAgkSadhvE cEti kathitavAn|
\p 
\v 7 hE bhrAtaraH, vArttAmimAM prApya yuSmAnadhi vizESatO yuSmAkaM klEzaduHkhAnyadhi yuSmAkaM vizvAsAd asmAkaM sAntvanAjAyata;
\p 
\v 8 yatO yUyaM yadi prabhAvavatiSThatha tarhyanEna vayam adhunA jIvAmaH|
\p 
\v 9 vayanjcAsmadIyEzvarasya sAkSAd yuSmattO jAtEna yEnAnandEna praphullA bhavAmastasya kRtsnasyAnandasya yOgyarUpENEzvaraM dhanyaM vadituM kathaM zakSyAmaH?
\p 
\v 10 vayaM yEna yuSmAkaM vadanAni draSTuM yuSmAkaM vizvAsE yad asiddhaM vidyatE tat siddhIkarttunjca zakSyAmastAdRzaM varaM divAnizaM prArthayAmahE|
\p 
\v 11 asmAkaM tAtEnEzvarENa prabhunA yIzukhrISTEna ca yuSmatsamIpagamanAyAsmAkaM panthA sugamaH kriyatAM|
\p 
\v 12 parasparaM sarvvAMzca prati yuSmAkaM prEma yuSmAn prati cAsmAkaM prEma prabhunA varddhyatAM bahuphalaM kriyatAnjca|
\p 
\v 13 aparamasmAkaM prabhu ryIzukhrISTaH svakIyaiH sarvvaiH pavitralOkaiH sArddhaM yadAgamiSyati tadA yUyaM yathAsmAkaM tAtasyEzvarasya sammukhE pavitratayA nirdOSA bhaviSyatha tathA yuSmAkaM manAMsi sthirIkriyantAM|
\c 4
\p 
\v 1 hE bhrAtaraH, yuSmAbhiH kIdRg AcaritavyaM IzvarAya rOcitavyanjca tadadhyasmattO yA zikSA labdhA tadanusArAt punaratizayaM yatnaH kriyatAmiti vayaM prabhuyIzunA yuSmAn vinIyAdizAmaH|
\p 
\v 2 yatO vayaM prabhuyIzunA kIdRzIrAjnjA yuSmAsu samarpitavantastad yUyaM jAnItha|
\p 
\v 3 IzvarasyAyam abhilASO yad yuSmAkaM pavitratA bhavEt, yUyaM vyabhicArAd dUrE tiSThata|
\p 
\v 4 yuSmAkam EkaikO janaH svakIyaM prANAdhAraM pavitraM mAnyanjca rakSatu,
\p 
\v 5 yE ca bhinnajAtIyA lOkA IzvaraM na jAnanti ta iva tat kAmAbhilASasyAdhInaM na karOtu|
\p 
\v 6 Etasmin viSayE kO'pyatyAcArI bhUtvA svabhrAtaraM na vanjcayatu yatO'smAbhiH pUrvvaM yathOktaM pramANIkRtanjca tathaiva prabhurEtAdRzAnAM karmmaNAM samucitaM phalaM dAsyati|
\p 
\v 7 yasmAd IzvarO'smAn azucitAyai nAhUtavAn kintu pavitratvAyaivAhUtavAn|
\p 
\v 8 atO hEtO ryaH kazcid vAkyamEtanna gRhlAti sa manuSyam avajAnAtIti nahi yEna svakIyAtmA yuSmadantarE samarpitastam Izvaram EvAvajAnAti|
\p 
\v 9 bhrAtRSu prEmakaraNamadhi yuSmAn prati mama likhanaM niSprayOjanaM yatO yUyaM parasparaM prEmakaraNAyEzvarazikSitA lOkA AdhvE|
\p 
\v 10 kRtsnE mAkidaniyAdEzE ca yAvantO bhrAtaraH santi tAn sarvvAn prati yuSmAbhistat prEma prakAzyatE tathApi hE bhrAtaraH, vayaM yuSmAn vinayAmahE yUyaM puna rbahutaraM prEma prakAzayata|
\p 
\v 11 aparaM yE bahiHsthitAstESAM dRSTigOcarE yuSmAkam AcaraNaM yat manOramyaM bhavEt kasyApi vastunazcAbhAvO yuSmAkaM yanna bhavEt,
\p 
\v 12 EtadarthaM yUyam asmattO yAdRzam AdEzaM prAptavantastAdRzaM nirvirOdhAcAraM karttuM svasvakarmmaNi manAMmi nidhAtuM nijakaraizca kAryyaM sAdhayituM yatadhvaM|
\p 
\v 13 hE bhrAtaraH nirAzA anyE lOkA iva yUyaM yanna zOcEdhvaM tadarthaM mahAnidrAgatAn lOkAnadhi yuSmAkam ajnjAnatA mayA nAbhilaSyatE|
\p 
\v 14 yIzu rmRtavAn punaruthitavAMzcEti yadi vayaM vizvAsamastarhi yIzum AzritAn mahAnidrAprAptAn lOkAnapIzvarO'vazyaM tEna sArddham AnESyati|
\p 
\v 15 yatO'haM prabhO rvAkyEna yuSmAn idaM jnjApayAmi; asmAkaM madhyE yE janAH prabhOrAgamanaM yAvat jIvantO'vazEkSyantE tE mahAnidritAnAm agragAminOna na bhaviSyanti;
\p 
\v 16 yataH prabhuH siMhanAdEna pradhAnasvargadUtasyOccaiH zabdEnEzvarIyatUrIvAdyEna ca svayaM svargAd avarOkSyati tEna khrISTAzritA mRtalOkAH prathamam utthAsyAnti|
\p 
\v 17 aparam asmAkaM madhyE yE jIvantO'vazEkSyantE ta AkAzE prabhOH sAkSAtkaraNArthaM taiH sArddhaM mEghavAhanEna hariSyantE; itthanjca vayaM sarvvadA prabhunA sArddhaM sthAsyAmaH|
\p 
\v 18 atO yUyam EtAbhiH kathAbhiH parasparaM sAntvayata|
\c 5
\p 
\v 1 hE bhrAtaraH, kAlAn samayAMzcAdhi yuSmAn prati mama likhanaM niSprayOjanaM,
\p 
\v 2 yatO rAtrau yAdRk taskarastAdRk prabhO rdinam upasthAsyatIti yUyaM svayamEva samyag jAnItha|
\p 
\v 3 zAnti rnirvvinghatvanjca vidyata iti yadA mAnavA vadiSyanti tadA prasavavEdanA yadvad garbbhinIm upatiSThati tadvad akasmAd vinAzastAn upasthAsyati tairuddhArO na lapsyatE|
\p 
\v 4 kintu hE bhrAtaraH, yUyam andhakArENAvRtA na bhavatha tasmAt taddinaM taskara iva yuSmAn na prApsyati|
\p 
\v 5 sarvvE yUyaM dIptEH santAnA divAyAzca santAnA bhavatha vayaM nizAvaMzAstimiravaMzA vA na bhavAmaH|
\p 
\v 6 atO 'parE yathA nidrAgatAH santi tadvad asmAbhi rna bhavitavyaM kintu jAgaritavyaM sacEtanaizca bhavitavyaM|
\p 
\v 7 yE nidrAnti tE nizAyAmEva nidrAnti tE ca mattA bhavanti tE rajanyAmEva mattA bhavanti|
\p 
\v 8 kintu vayaM divasasya vaMzA bhavAmaH; atO 'smAbhi rvakSasi pratyayaprEmarUpaM kavacaM zirasi ca paritrANAzArUpaM zirastraM paridhAya sacEtanai rbhavitavyaM|
\p 
\v 9 yata IzvarO'smAn krOdhE na niyujyAsmAkaM prabhunA yIzukhrISTEna paritrANasyAdhikArE niyuुktavAn,
\p 
\v 10 jAgratO nidrAgatA vA vayaM yat tEna prabhunA saha jIvAmastadarthaM sO'smAkaM kRtE prANAn tyaktavAn|
\p 
\v 11 ataEva yUyaM yadvat kurutha tadvat parasparaM sAntvayata susthirIkurudhvanjca|
\p 
\v 12 hE bhrAtaraH, yuSmAkaM madhyE yE janAH parizramaM kurvvanti prabhO rnAmnA yuSmAn adhitiSThantyupadizanti ca tAn yUyaM sammanyadhvaM|
\p 
\v 13 svakarmmahEtunA ca prEmnA tAn atIvAdRyadhvamiti mama prArthanA, yUyaM parasparaM nirvvirOdhA bhavata|
\p 
\v 14 hE bhrAtaraH, yuSmAn vinayAmahE yUyam avihitAcAriNO lOkAn bhartsayadhvaM, kSudramanasaH sAntvayata, durbbalAn upakuruta, sarvvAn prati sahiSNavO bhavata ca|
\p 
\v 15 aparaM kamapi pratyaniSTasya phalam aniSTaM kEnApi yanna kriyEta tadarthaM sAvadhAnA bhavata, kintu parasparaM sarvvAn mAnavAMzca prati nityaM hitAcAriNO bhavata|
\p 
\v 16 sarvvadAnandata|
\p 
\v 17 nirantaraM prArthanAM kurudhvaM|
\p 
\v 18 sarvvaviSayE kRtajnjatAM svIkurudhvaM yata EtadEva khrISTayIzunA yuSmAn prati prakAzitam IzvarAbhimataM|
\p 
\v 19 pavitram AtmAnaM na nirvvApayata|
\p 
\v 20 IzvarIyAdEzaM nAvajAnIta|
\p 
\v 21 sarvvANi parIkSya yad bhadraM tadEva dhArayata|
\p 
\v 22 yat kimapi pAparUpaM bhavati tasmAd dUraM tiSThata|
\p 
\v 23 zAntidAyaka IzvaraH svayaM yuSmAn sampUrNatvEna pavitrAn karOtu, aparam asmatprabhO ryIzukhrISTasyAgamanaM yAvad yuSmAkam AtmAnaH prANAH zarIrANi ca nikhilAni nirddOSatvEna rakSyantAM|
\p 
\v 24 yO yuSmAn Ahvayati sa vizvasanIyO'taH sa tat sAdhayiSyati|
\p 
\v 25 hE bhrAtaraH, asmAkaM kRtE prArthanAM kurudhvaM|
\p 
\v 26 pavitracumbanEna sarvvAn bhrAtRn prati satkurudhvaM|
\p 
\v 27 patramidaM sarvvESAM pavitrANAM bhrAtRNAM zrutigOcarE yuSmAbhiH paThyatAmiti prabhO rnAmnA yuSmAn zapayAmi|
\p 
\v 28 asmAkaM prabhO ryIzukhrISTasyAnugratE yuSmAsu bhUyAt| AmEn|
