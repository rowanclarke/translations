\v 10 \w When|strong="H6437"\w* \w the|strong="H5921"\w* \w cloud|strong="H6051"\w* rose \w up|strong="H5921"\w* \w from|strong="H5493"\w* \w the|strong="H5921"\w* Sacred Tent, Aaron \w looked|strong="H6437"\w* \w at|strong="H5921"\w* \w Miriam|strong="H4813"\w*, \w and|strong="H6437"\w* \w he|strong="H5921"\w* \w saw|strong="H2009"\w* \w that|strong="H2009"\w* \w her|strong="H5493"\w* skin \w was|strong="H6051"\w* \add as white\add* \w as|strong="H6051"\w* \w snow|strong="H7950"\w*, \w because|strong="H5921"\w* \w she|strong="H5921"\w* \w now|strong="H2009"\w* \w had|strong="H6051"\w* leprosy.
