\v 27 \w The|strong="H5414"\w* \w king|strong="H4428"\w* \w gave|strong="H5414"\w* \w his|strong="H5414"\w* verdict. “\w Give|strong="H5414"\w* \w the|strong="H5414"\w* \w child|strong="H3205"\w* \w that|strong="H1931"\w*'s \w alive|strong="H2416"\w* \w to|strong="H4191"\w* \w the|strong="H5414"\w* first \w woman|strong="H3205"\w*,” \w he|strong="H1931"\w* ordered. “\w On|strong="H4191"\w* \w no|strong="H3808"\w* \w account|strong="H6030"\w* \w kill|strong="H4191"\w* \w him|strong="H5414"\w*, \w for|strong="H4191"\w* \w she|strong="H1931"\w* \w is|strong="H1931"\w* \w his|strong="H5414"\w* real mother.”   
\p
\v 28 \w When|strong="H3588"\w* \w everyone|strong="H3605"\w* \w in|strong="H3478"\w* \w Israel|strong="H3478"\w* \w heard|strong="H8085"\w* \w about|strong="H8085"\w* \w the|strong="H3605"\w* \w verdict|strong="H4941"\w* \w the|strong="H3605"\w* \w king|strong="H4428"\w* \w had|strong="H3478"\w* delivered, \w they|strong="H3588"\w* \w had|strong="H3478"\w* \w great|strong="H6213"\w* \w respect|strong="H7200"\w* \w for|strong="H3588"\w* \w the|strong="H3605"\w* \w king|strong="H4428"\w*, \w because|strong="H3588"\w* \w they|strong="H3588"\w* recognized \w the|strong="H3605"\w* \w wisdom|strong="H2451"\w* \w God|strong="H2451"\w* \w had|strong="H3478"\w* \w given|strong="H8085"\w* \w him|strong="H6440"\w* \w to|strong="H3478"\w* \w judge|strong="H8199"\w* \w rightly|strong="H3588"\w*.   
\b  
\c 4  
\p
\v 1 \w King|strong="H4428"\w* \w Solomon|strong="H8010"\w* \w ruled|strong="H4428"\w* \w over|strong="H5921"\w* \w all|strong="H3605"\w* \w of|strong="H4428"\w* \w Israel|strong="H3478"\w*.  
\v 2 These \w were|strong="H1121"\w* \w his|strong="H3548"\w* \w officials|strong="H8269"\w*: \w Azariah|strong="H5838"\w*, \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Zadok|strong="H6659"\w*, \w was|strong="H1121"\w* \w the|strong="H6659"\w* \w priest|strong="H3548"\w*;  
\v 3 Elihoreph \w and|strong="H1121"\w* Ahijah, \w sons|strong="H1121"\w* \w of|strong="H1121"\w* \w Shisha|strong="H7894"\w*, \w were|strong="H1121"\w* \w the|strong="H2142"\w* king's secretaries. \w Jehoshaphat|strong="H3092"\w*, \w son|strong="H1121"\w* \w of|strong="H1121"\w* Ahilud, kept \w the|strong="H2142"\w* royal records.  
\v 4 \w Benaiah|strong="H1141"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Jehoiada|strong="H3077"\w* \w was|strong="H1121"\w* \w the|strong="H5921"\w* \w army|strong="H6635"\w* commander. \w Zadok|strong="H6659"\w* \w and|strong="H1121"\w* Abiathar \w were|strong="H1121"\w* \w priests|strong="H3548"\w*.  
\v 5 \w Azariah|strong="H5838"\w*, \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Nathan|strong="H5416"\w*, \w was|strong="H4428"\w* \w in|strong="H5921"\w* \w charge|strong="H5921"\w* \w of|strong="H1121"\w* \w the|strong="H5921"\w* governors. \w Zabud|strong="H2071"\w*, \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Nathan|strong="H5416"\w*, \w was|strong="H4428"\w* \w a|strong="H3068"\w* \w priest|strong="H3548"\w* \w and|strong="H1121"\w* \w the|strong="H5921"\w* \w king|strong="H4428"\w*'s counselor.  
\v 6 Ahishar \w was|strong="H1004"\w* \w the|strong="H5921"\w* \w palace|strong="H1004"\w* manager. Adoniram, \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Abda|strong="H5653"\w*, \w was|strong="H1004"\w* \w in|strong="H5921"\w* \w charge|strong="H5921"\w* \w of|strong="H1121"\w* \w those|strong="H5921"\w* \w forced|strong="H4522"\w* \w to|strong="H5921"\w* work \w for|strong="H5921"\w* \w the|strong="H5921"\w* \w king|strong="H5921"\w*.   
\p
\v 7 \w Solomon|strong="H8010"\w* \w had|strong="H1961"\w* \w twelve|strong="H8147"\w* area governors \w whose|strong="H3605"\w* responsibilities covered \w the|strong="H3605"\w* \w whole|strong="H3605"\w* \w of|strong="H4428"\w* \w Israel|strong="H3478"\w*, providing \w food|strong="H1004"\w* \w for|strong="H5921"\w* \w the|strong="H3605"\w* \w king|strong="H4428"\w* \w and|strong="H3478"\w* \w his|strong="H3605"\w* \w household|strong="H1004"\w*. \w Each|strong="H3605"\w* \w one|strong="H3605"\w* \w in|strong="H8141"\w* \w turn|strong="H1961"\w* arranged supplies \w for|strong="H5921"\w* \w one|strong="H3605"\w* \w month|strong="H2320"\w* \w of|strong="H4428"\w* \w the|strong="H3605"\w* \w year|strong="H8141"\w*.   
\p
\v 8 Their \w names|strong="H8034"\w* \w were|strong="H2022"\w*: \w Ben-hur|strong="H1133"\w*, \w in|strong="H8034"\w* \w the|strong="H8034"\w* \w hill|strong="H2022"\w* \w country|strong="H2022"\w* \w of|strong="H2022"\w* \w Ephraim|strong="H8034"\w*;   
\p
\v 9 \w Ben-deker|strong="H1128"\w* \w in|strong="H1128"\w* \w Makaz|strong="H4739"\w*, \w Shaalbim|strong="H8169"\w*, \w Beth-shemesh|strong="H1053"\w* \w and|strong="H1053"\w* Elon-beth-hanan;   
\p
\v 10 \w Ben-hesed|strong="H1136"\w* \w in|strong="H3605"\w* Arubboth (\w Socoh|strong="H7755"\w* \w and|strong="H3605"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* land \w of|strong="H3605"\w* \w Hepher|strong="H2660"\w* \w was|strong="H3605"\w* \w his|strong="H3605"\w*);   
\p
\v 11 \w Ben-abinadab|strong="H1125"\w*, \w in|strong="H8010"\w* \w the|strong="H3605"\w* \w whole|strong="H3605"\w* \w of|strong="H1323"\w* Naphath-dor (\w Taphath|strong="H2955"\w*, \w the|strong="H3605"\w* \w daughter|strong="H1323"\w* \w of|strong="H1323"\w* \w Solomon|strong="H8010"\w*, \w was|strong="H1961"\w* \w his|strong="H3605"\w* wife);   
\p
\v 12 \w Baana|strong="H1195"\w*, \w son|strong="H1121"\w* \w of|strong="H1121"\w* Ahilud, \w in|strong="H1121"\w* \w Taanach|strong="H8590"\w* \w and|strong="H1121"\w* \w Megiddo|strong="H4023"\w*, \w the|strong="H3605"\w* \w whole|strong="H3605"\w* \w of|strong="H1121"\w* \w Beth-shan|strong="H1052"\w* \w near|strong="H5704"\w* \w Zarethan|strong="H6891"\w* \w below|strong="H8478"\w* \w Jezreel|strong="H3157"\w*, \w and|strong="H1121"\w* \w from|strong="H1121"\w* \w Beth-shan|strong="H1052"\w* \w to|strong="H5704"\w* Abel-meholah \w and|strong="H1121"\w* \w across|strong="H5676"\w* \w to|strong="H5704"\w* \w Jokmeam|strong="H3361"\w*;   
\p
\v 13 \w Ben-geber|strong="H1127"\w*, \w in|strong="H5892"\w* \w Ramoth-gilead|strong="H7433"\w* (\w the|strong="H1121"\w* \w towns|strong="H5892"\w* \w of|strong="H1121"\w* \w Jair|strong="H2971"\w*, \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Manasseh|strong="H4519"\w*, \w in|strong="H5892"\w* \w Gilead|strong="H1568"\w* belonged \w to|strong="H1121"\w* \w him|strong="H1121"\w*, \w as|strong="H1121"\w* well \w as|strong="H1121"\w* \w the|strong="H1121"\w* \w region|strong="H2256"\w* \w of|strong="H1121"\w* Argob \w in|strong="H5892"\w* \w Bashan|strong="H1316"\w*, \w with|strong="H5892"\w* \w sixty|strong="H8346"\w* \w great|strong="H1419"\w* \w cities|strong="H5892"\w* having \w walls|strong="H2346"\w* \w and|strong="H1121"\w* \w bronze|strong="H5178"\w* \w bars|strong="H1280"\w*);   
\p
\v 14 Ahinadab, \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Iddo|strong="H5714"\w*, \w in|strong="H1121"\w* \w Mahanaim|strong="H4266"\w*;   
\p
\v 15 Ahimaaz, \w in|strong="H8010"\w* \w Naphtali|strong="H5321"\w* (\w he|strong="H1931"\w* \w had|strong="H8010"\w* \w married|strong="H3947"\w* \w Basemath|strong="H1315"\w* \w the|strong="H3947"\w* \w daughter|strong="H1323"\w* \w of|strong="H1323"\w* \w Solomon|strong="H8010"\w*);   
\p
\v 16 \w Baana|strong="H1195"\w*, \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Hushai|strong="H2365"\w*, \w in|strong="H1121"\w* Asher \w and|strong="H1121"\w* \w in|strong="H1121"\w* \w Aloth|strong="H1175"\w*;   
\p
\v 17 \w Jehoshaphat|strong="H3092"\w*, \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Paruah|strong="H6515"\w*, \w in|strong="H1121"\w* \w Issachar|strong="H3485"\w*;   
\p
\v 18 \w Shimei|strong="H8096"\w*, \w son|strong="H1121"\w* \w of|strong="H1121"\w* Ela, \w in|strong="H1121"\w* \w Benjamin|strong="H1144"\w*;   
\p
\v 19 \w Geber|strong="H1398"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Uri \w in|strong="H4428"\w* \w the|strong="H1121"\w* land \w of|strong="H1121"\w* \w Gilead|strong="H1568"\w* (\w the|strong="H1121"\w* former country \w of|strong="H1121"\w* \w Sihon|strong="H5511"\w*, \w king|strong="H4428"\w* \w of|strong="H1121"\w* \w the|strong="H1121"\w* Amorites, \w and|strong="H1121"\w* \w of|strong="H1121"\w* \w Og|strong="H5747"\w*, \w king|strong="H4428"\w* \w of|strong="H1121"\w* \w Bashan|strong="H1316"\w*. There \w was|strong="H4428"\w* \w also|strong="H4428"\w* \w a|strong="H3068"\w* governor \w who|strong="H1121"\w* \w was|strong="H4428"\w* \w over|strong="H4428"\w* \w the|strong="H1121"\w* land \w of|strong="H1121"\w* Judah).\f + \fr 4:19 \ft The Hebrew text is unclear. The Septuagint reading is followed here, indicating that there was also a governor over Judah. Some however take this to refer to the previous governor mentioned who was the sole governor during this reign.\f*   
\p
\v 20 \w Judah|strong="H3063"\w* \w and|strong="H3063"\w* \w Israel|strong="H3478"\w* \w had|strong="H3478"\w* become \w as|strong="H7230"\w* \w numerous|strong="H7227"\w* \w as|strong="H7230"\w* \w the|strong="H5921"\w* \w sand|strong="H2344"\w* \w on|strong="H5921"\w* \w the|strong="H5921"\w* \w seashore|strong="H3220"\w*. \w They|strong="H5921"\w* ate, \w they|strong="H5921"\w* \w drank|strong="H8354"\w*, \w they|strong="H5921"\w* \w were|strong="H3478"\w* \w happy|strong="H8056"\w*.  
\v 21 Solomon ruled over all the kingdoms from the Euphrates River to the land of the Philistines, right up to the border of Egypt. They presented tribute to Solomon and served him during his lifetime.  
\v 22 The food required every day for Solomon's court was thirty cors of the best flour and sixty cors of meal;  
\v 23 ten fattened cattle, twenty range cattle, one hundred sheep, as well as deer, gazelles, roe deer, and fattened poultry.  
\v 24 For Solomon ruled over the whole region west of the Euphrates, from Tiphsah to Gaza—over all the kingdoms west of the Euphrates. And he had peace on all sides around him. He had peace on every border.  
\v 25 During Solomon's lifetime, everyone in Judah and Israel lived in safety, from Dan to Beersheba. Each one had their own vine and fig tree.  
\v 26 Solomon had 40,000 stalls for his chariot horses, and 12,000 charioteers.  
\v 27 Every month the area governors provided in turn food for King Solomon and all who ate at his table. They made sure that nothing was missing.  
\v 28 They also delivered barley and straw where they were needed for the chariot horses and cart horses.   
\p
\v 29 God gave to Solomon wisdom, very great discernment, and understanding as extensive as the sand on the seashore.  
\v 30 Solomon's wisdom was greater than that of all the Eastern wise men, greater than all of Egypt's wisdom.  
\v 31 He was wiser than anyone, wiser than Ethan the Ezrahite, wiser than Heman, Calcol, and Darda, sons of Mahol. His reputation spread through the nations around.  
\v 32 Solomon composed three thousand proverbs and one thousand and five songs.  
\v 33 He was able to discuss knowledge of trees, from the cedar in Lebanon to the hyssop that grows in the wall. He taught about animals, birds, reptiles, and fish.  
\v 34 People from all nations came to hear Solomon's wisdom. They were sent by all the kings of the earth, who had heard about his wisdom.   
\b  
\c 5  
\p
\v 1 \w When|strong="H1961"\w* Hiram king \w of|strong="H3117"\w* Tyre heard \w that|strong="H3605"\w* \w Solomon|strong="H8010"\w* \w had|strong="H1961"\w* \w been|strong="H1961"\w* anointed king \w to|strong="H5704"\w* succeed \w his|strong="H3605"\w* father, \w he|strong="H3117"\w* sent ambassadors \w to|strong="H5704"\w* \w Solomon|strong="H8010"\w* \w because|strong="H4480"\w* Hiram \w had|strong="H1961"\w* \w always|strong="H3605"\w* \w been|strong="H1961"\w* \w David|strong="H3117"\w*'s friend.  
\v 2 \w So|strong="H1961"\w* \w Solomon|strong="H8010"\w* sent \w this|strong="H3117"\w* message back \w to|strong="H1961"\w* Hiram,  
\v 3 “As you know, my father David \w was|strong="H6629"\w* not able \w to|strong="H6242"\w* build \w a|strong="H3068"\w* Temple \w to|strong="H6242"\w* honor \w the|strong="H3967"\w* Lord his God because \w of|strong="H6629"\w* \w the|strong="H3967"\w* wars fought against him \w from|strong="H3967"\w* every direction, until \w the|strong="H3967"\w* Lord \w had|strong="H6629"\w* conquered his enemies.\f + \fr 5:3 \ft “Conquered his enemies”: literally, “put them under the soles of his feet.”\f*  
\v 4 \w But|strong="H3588"\w* \w now|strong="H1961"\w* \w the|strong="H3605"\w* Lord \w my|strong="H3605"\w* God \w has|strong="H1961"\w* given \w me|strong="H1961"\w* \w peace|strong="H7965"\w* \w all|strong="H3605"\w* \w around|strong="H5439"\w*—\w no|strong="H3605"\w* enemies, \w no|strong="H3605"\w* bad \w things|strong="H3605"\w* happening.   
\p
\v 5 \w So|strong="H3427"\w* \w I|strong="H3117"\w* plan \w to|strong="H5704"\w* build \w a|strong="H3068"\w* Temple \w to|strong="H5704"\w* honor \w the|strong="H3605"\w* Lord \w my|strong="H3605"\w* God, \w as|strong="H5704"\w* \w the|strong="H3605"\w* Lord \w told|strong="H8010"\w* \w my|strong="H3605"\w* father \w David|strong="H3117"\w*. \w He|strong="H3117"\w* said \w to|strong="H5704"\w* \w him|strong="H3605"\w*, ‘\w Your|strong="H3605"\w* son whom \w I|strong="H3117"\w* \w will|strong="H3478"\w* \w place|strong="H8478"\w* \w on|strong="H3117"\w* \w your|strong="H3605"\w* throne \w to|strong="H5704"\w* succeed \w you|strong="H3605"\w* \w will|strong="H3478"\w* build \w the|strong="H3605"\w* Temple \w to|strong="H5704"\w* honor \w me|strong="H3605"\w*.’  
\v 6 \w So|strong="H1961"\w* please order some cedars \w of|strong="H8147"\w* Lebanon \w to|strong="H1961"\w* \w be|strong="H1961"\w* cut down \w for|strong="H1961"\w* \w me|strong="H1961"\w*. \w My|strong="H1961"\w* workers \w will|strong="H1961"\w* assist \w your|strong="H1961"\w* workers, \w and|strong="H5483"\w* \w I|strong="H1961"\w* \w will|strong="H1961"\w* pay \w your|strong="H1961"\w* workers \w at|strong="H1961"\w* \w the|strong="H1961"\w* rate \w that|strong="H1961"\w* \w you|strong="H1961"\w* decide, \w for|strong="H1961"\w* \w you|strong="H1961"\w* know \w that|strong="H1961"\w* \w we|strong="H3068"\w* don't \w have|strong="H1961"\w* anyone who knows how \w to|strong="H1961"\w* cut timber \w like|strong="H1961"\w* \w the|strong="H1961"\w* Sidonians.”   
\p
\v 7 When Hiram heard \w Solomon|strong="H8010"\w*'s \w message|strong="H1697"\w*, \w he|strong="H3605"\w* \w was|strong="H1697"\w* very happy \w and|strong="H4428"\w* \w said|strong="H1697"\w*, “Praise \w the|strong="H3605"\w* Lord today, \w for|strong="H4428"\w* \w he|strong="H3605"\w* \w has|strong="H4428"\w* given David \w a|strong="H3068"\w* wise son \w to|strong="H4428"\w* lead \w this|strong="H1697"\w* great nation!”  
\v 8 Hiram sent \w this|strong="H1961"\w* reply \w to|strong="H1961"\w* Solomon:  
\p “Thank \w you|strong="H4725"\w* \w for|strong="H4941"\w* \w your|strong="H1961"\w* message. \w As|strong="H1961"\w* \w for|strong="H4941"\w* \w the|strong="H1961"\w* cedar \w and|strong="H4941"\w* cypress timber, \w I|strong="H1961"\w* \w will|strong="H1961"\w* do everything \w you|strong="H4725"\w* want.  
\v 9 \w My|strong="H5414"\w* workers \w will|strong="H3820"\w* \w bring|strong="H5414"\w* \w the|strong="H5921"\w* logs \w down|strong="H5414"\w* \w from|strong="H5921"\w* Lebanon \w to|strong="H5921"\w* \w the|strong="H5921"\w* \w sea|strong="H3220"\w*, \w and|strong="H2451"\w* \w I|strong="H5414"\w* \w will|strong="H3820"\w* \w have|strong="H5414"\w* \w them|strong="H5414"\w* \w floated|strong="H5921"\w* \w in|strong="H5921"\w* rafts \w by|strong="H5921"\w* \w sea|strong="H3220"\w* \w to|strong="H5921"\w* \w wherever|strong="H5921"\w* \w you|strong="H5414"\w* decide. \w I|strong="H5414"\w* \w will|strong="H3820"\w* \w have|strong="H5414"\w* \w the|strong="H5921"\w* rafts broken apart there, \w and|strong="H2451"\w* \w you|strong="H5414"\w* can \w take|strong="H5414"\w* \w the|strong="H5921"\w* logs \w away|strong="H5414"\w*. \w In|strong="H5921"\w* return \w I|strong="H5414"\w* \w would|strong="H8010"\w* \w like|strong="H3820"\w* \w you|strong="H5414"\w* \w to|strong="H5921"\w* \w provide|strong="H5414"\w* food \w for|strong="H5921"\w* \w my|strong="H5414"\w* household.”   
\p
\v 10 \w So|strong="H7235"\w* Hiram \w provided|strong="H7235"\w* \w Solomon|strong="H8010"\w* \w with|strong="H4714"\w* \w as|strong="H1121"\w* \w much|strong="H7235"\w* cedar \w and|strong="H1121"\w* cypress timber \w as|strong="H1121"\w* \w he|strong="H3605"\w* wanted,  
\v 11 Solomon \w gave|strong="H1961"\w* Hiram 20,000 cors \w of|strong="H1121"\w* wheat \w for|strong="H8034"\w* food \w and|strong="H1121"\w* 20,000 cors \w of|strong="H1121"\w* olive oil \w for|strong="H8034"\w* \w his|strong="H3605"\w* household. Solomon provided \w this|strong="H1121"\w* \w to|strong="H1961"\w* Hiram \w every|strong="H3605"\w* \w year|strong="H1121"\w*.  
\v 12 \w The|strong="H1961"\w* Lord \w gave|strong="H1696"\w* Solomon wisdom \w just|strong="H1696"\w* \w as|strong="H1961"\w* \w he|strong="H2568"\w* \w had|strong="H1961"\w* \w promised|strong="H1696"\w* \w him|strong="H1696"\w*. Hiram \w and|strong="H2568"\w* Solomon \w had|strong="H1961"\w* \w a|strong="H3068"\w* good relationship \w and|strong="H2568"\w* \w they|strong="H1696"\w* \w made|strong="H1696"\w* \w a|strong="H3068"\w* peace treaty \w with|strong="H1696"\w* each other.   
\p
\v 13 \w King|strong="H5921"\w* Solomon drafted \w a|strong="H3068"\w* labor force \w of|strong="H4480"\w* 30,000 \w from|strong="H4480"\w* \w all|strong="H5704"\w* \w of|strong="H4480"\w* Israel.  
