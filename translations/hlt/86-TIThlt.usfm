\mt1 TITUS CAPAT  
\mt2 (Letter to Titus)  
\c 1  
\s1 Uemnah Ol  
\p
\v 1 \w Pathen|strong="G2316"\w* kah \w sal|strong="G1401"\w* \w neh|strong="G1161"\w* \w Jesuh|strong="G2424"\w* \w Khrih|strong="G5547"\w* kah \w caeltueih|strong="G0652"\w* kai \w Paul|strong="G3972"\w* loh, \w Pathen|strong="G2316"\w* hlang \w coelh|strong="G1588"\w* kah \w tangnah|strong="G4102"\w* \w neh|strong="G2532"\w* \w oltak|strong="G0225"\w* \w mingnah|strong="G1922"\w*, \w dungyan|strong="G0166"\w* \w hingnah|strong="G2222"\w* \w ngaiuepnah|strong="G1680"\w* \w dongkah|strong="G1909"\w* \w hingcimnah|strong="G2150"\w* \w vanbangla|strong="G2596"\w* kan yaak sak.  
\v 2 \w Te|strong="G3739"\w* te \w oltak|strong="G0893"\w* \w Pathen|strong="G2316"\w* \w loh|strong="G3588"\w* \w khosuen|strong="G0166"\w* \w tue|strong="G5550"\w* \w hlanah|strong="G4253"\w* ni a \w kam|strong="G1861"\w* coeng.  
\v 3 \w Tedae|strong="G1161"\w* \w olhoe|strong="G2782"\w* \w dongah|strong="G1722"\w* \w amah|strong="G0846"\w* kah \w olka|strong="G3056"\w* \w tah|strong="G3588"\w* \w amah|strong="G2398"\w* \w tue|strong="G2540"\w* vaengah \w phoe|strong="G5319"\w* coeng. \w Tekah|strong="G3739"\w* te \w mamih|strong="G2257"\w* \w khangkung|strong="G3588"\w* \w Pathen|strong="G2316"\w* kah \w olpaek|strong="G2003"\w* \w vanbangla|strong="G2596"\w* \w kai|strong="G1473"\w* taengah a \w hal|strong="G4100"\w* coeng.  
\v 4 \x - \xo 1.4 \xt 2Ko 8. 23; Gal 2. 3; 2Ti 4. 10.\x*A \w cui|strong="G2839"\w* la \w tangnah|strong="G4102"\w* \w dongah|strong="G2596"\w* ka \w ca|strong="G5043"\w* \w tak|strong="G1103"\w* \w Titu|strong="G5103"\w* taengah, \w Pa|strong="G3962"\w* \w Pathen|strong="G2316"\w* \w neh|strong="G2532"\w* \w mamih|strong="G2257"\w* \w khangkung|strong="G4990"\w* \w Jesuh|strong="G2424"\w* \w Khrih|strong="G5547"\w* kah \w lungvatnah|strong="G5485"\w* \w neh|strong="G2532"\w* \w ngaimongnah|strong="G1515"\w* te soep saeh.   
\s1 Krete ah Titu kah Bibi  
\p
\v 5 \w Te|strong="G5127"\w* \w ham|strong="G5494"\w* ni \w Krete|strong="G2914"\w* \w ah|strong="G1722"\w* \w nang|strong="G4571"\w* kang \w khueh|strong="G0620"\w*. Te \w daengah|strong="G2443"\w* ni \w Kai|strong="G1473"\w* loh \w nang|strong="G4671"\w* kan \w uen|strong="G1299"\w* \w vanbangla|strong="G5613"\w* \w kho|strong="G4172"\w* \w takuem|strong="G2596"\w* ah a hamca rhoek na \w tuek|strong="G2525"\w* \w vetih|strong="G2532"\w* a \w vawtthoek|strong="G3007"\w* \w te|strong="G3588"\w* na \w soepsoei|strong="G1930"\w* thai eh.  
\v 6 \x - \xo 1.6 \xt 1Ti 3. 2-7.\x*Tedae \w khat|strong="G5100"\w* khat ni \w cimbit|strong="G0410"\w* la a \w om|strong="G2076"\w* \w atah|strong="G1487"\w*, \w yuu|strong="G1135"\w* \w va|strong="G0435"\w* \w pakhat|strong="G3391"\w* bueng aka om, a \w ca|strong="G5043"\w* rhoek \w uepom|strong="G4103"\w* \w la aka\w* \w om|strong="G2192"\w*, \w cungpoehnah|strong="G0810"\w* \w neh|strong="G2228"\w* \w thinthah|strong="G0506"\w* \w dongah|strong="G1722"\w* \w lai|strong="G2724"\w* om \w boel|strong="G3361"\w* saeh.  
\v 7 \w Hiphoelkung|strong="G1985"\w* \w he|strong="G3588"\w* \w Pathen|strong="G2316"\w* kah \w hnokhoem|strong="G3623"\w* \w la|strong="G5613"\w* a om \w dongah|strong="G1063"\w* a \w cimbit|strong="G0410"\w* la \w om|strong="G1511"\w* ham a \w kuek|strong="G1163"\w*. \w Cungpoeh|strong="G0829"\w* \w boel|strong="G3361"\w* saeh, \w thintoi|strong="G3711"\w* \w boel|strong="G3361"\w* saeh, \w yumi|strong="G3943"\w* \w boel|strong="G3361"\w* saeh, \w kuthlah|strong="G4131"\w* \w boel|strong="G3361"\w* saeh, \w tangkarhai|strong="G0146"\w* \w boel|strong="G3361"\w* saeh.  
\v 8 \w Tedae|strong="G0235"\w* \w moeihoeih|strong="G5382"\w* la, \w ko-op|strong="G5358"\w* la, \w cuepmueih|strong="G4998"\w* la, a \w dueng|strong="G1342"\w* la, a \w cim|strong="G3741"\w* la \w kuemsuem|strong="G1468"\w* saeh.  
\v 9 \w Thuituennah|strong="G1322"\w* \w vanbangla|strong="G2596"\w* \w olka|strong="G3056"\w* te \w uepom|strong="G4103"\w* la \w tu|strong="G0472"\w* saeh. Te \w daengah|strong="G2443"\w* ni \w thaphoh|strong="G3870"\w* vetih \w boekoek|strong="G0483"\w* rhoek \w te|strong="G3588"\w* aka \w cuem|strong="G5198"\w* \w thuituennah|strong="G1319"\w* \w nen|strong="G1722"\w* \w khaw|strong="G2532"\w*, \w toeltham|strong="G1651"\w* ham \w khaw|strong="G2532"\w* a \w om|strong="G5600"\w* \w thai|strong="G1415"\w* eh.   
\p
\v 10 \w Thinthah|strong="G0506"\w* rhoek, \w olhong|strong="G3151"\w* rhoek \w neh|strong="G2532"\w* \w vuelvaekkung|strong="G5423"\w* rhoek loh, \w olpuei|strong="G3122"\w* la \w yahvinrhetnah|strong="G4061"\w* \w khuikah|strong="G1537"\w* \w muep|strong="G4183"\w* \w om|strong="G1526"\w* \w ngawn|strong="G2532"\w*.  
\v 11 \w Amih|strong="G3739"\w* te \w kamkhuem|strong="G1993"\w* sak ham a \w kuek|strong="G1163"\w* coeng. \w Amih|strong="G3748"\w* loh \w rhaidaeng|strong="G0150"\w* a \w ti|strong="G1163"\w* uh \w mueh|strong="G3361"\w* la \w imkhui|strong="G3624"\w* \w tom|strong="G3650"\w* a \w palet|strong="G0396"\w* uh tih amah \w hoeikhangnah|strong="G2771"\w* \w ham|strong="G5494"\w* \w te|strong="G3739"\w* a \w thuituen|strong="G1321"\w* uh.  
\v 12 \w Amih|strong="G0846"\w* \w khuikah|strong="G1537"\w* hlang \w pakhat|strong="G5100"\w*, \w amih|strong="G0846"\w* kah \w tonghma|strong="G4396"\w* loh, “\w Krete|strong="G2912"\w*, \w laithae|strong="G5583"\w* rhoek, \w boethae|strong="G2556"\w* \w maehkai|strong="G2342"\w*, \w palyal|strong="G0692"\w* \w bungkawng|strong="G1064"\w* \w taitu|strong="G0104"\w* uh mai,” a \w ti|strong="G2036"\w*.   
\p
\v 13 \w Hekah|strong="G3778"\w* \w laipai|strong="G3141"\w* \w tah|strong="G3588"\w* \w thuem|strong="G0227"\w*. \w Tekah|strong="G3739"\w* \w paelnaehnah|strong="G0156"\w* \w lamloh|strong="G1223"\w* \w amih|strong="G0848"\w* te \w rhap|strong="G0664"\w* \w toeltham|strong="G1651"\w*. Te \w daengah|strong="G2443"\w* ni \w tangnah|strong="G4102"\w* \w dongah|strong="G1722"\w* a sa a \w ding|strong="G5198"\w* uh eh.  
\v 14 \w Judah|strong="G2451"\w* rhoek kah \w yancil|strong="G3454"\w* \w neh|strong="G2532"\w* \w oltak|strong="G0225"\w* aka \w phaelh|strong="G0654"\w* \w hlang|strong="G0444"\w* rhoek kah \w olpaek|strong="G1785"\w* te \w hnatung|strong="G4337"\w* \w boeh|strong="G3361"\w*.  
\v 15 A \w rhoepsaep|strong="G3956"\w* he aka \w caih|strong="G2513"\w* rhoek \w ham|strong="G3588"\w* a \w caih|strong="G2513"\w* la om. \w Tedae|strong="G1161"\w* aka \w boi|strong="G3392"\w* rhoek \w neh|strong="G2532"\w* aka \w tangnahmueh|strong="G0571"\w* rhoek ham tah \w caih|strong="G2513"\w* \w pawh|strong="G3762"\w*. \w Tedae|strong="G0235"\w* \w amih|strong="G0846"\w* kah \w lungbuei|strong="G3563"\w* \w neh|strong="G2532"\w* \w mingcimnah|strong="G4893"\w* \w khaw|strong="G2532"\w* \w boi|strong="G3392"\w* uh coeng.  
\v 16 \w Pathen|strong="G2316"\w* te \w ming|strong="G1492"\w* ham a \w phong|strong="G3670"\w* uh \w dae|strong="G1161"\w* a \w khoboe|strong="G2041"\w* \w neh|strong="G3588"\w* a \w hnawt|strong="G0720"\w* uh. \w Rhalawt|strong="G0947"\w* la \w om|strong="G5607"\w* uh \w tih|strong="G2532"\w* \w lokhak|strong="G0545"\w* uh. \w Bibi|strong="G2041"\w* \w then|strong="G0018"\w* \w boeih|strong="G3956"\w* \w nen|strong="G4314"\w* \w khaw|strong="G2532"\w* \w lolhmaih|strong="G0096"\w* uh.   
\c 2  
\s1 Aka Soep Thuituennah  
\p
\v 1 \w Tedae|strong="G1161"\w* \w nang|strong="G4771"\w* tah aka \w cuem|strong="G5198"\w* \w thuituennah|strong="G1319"\w* neh aka \w rhoep|strong="G4241"\w* \w te|strong="G3739"\w* \w thui|strong="G2980"\w* lah.  
\v 2 \w Patong|strong="G4246"\w* rhoek te aka \w khuel|strong="G3524"\w* la, a \w hinom|strong="G4586"\w* la, a \w cuepmueih|strong="G4998"\w* la, \w tangnah|strong="G4102"\w* \w dongah|strong="G3588"\w* \w sading|strong="G5198"\w* la, \w lungnah|strong="G0026"\w*, \w uehnah|strong="G5281"\w* neh \w om|strong="G1511"\w* saeh.  
\v 3 Te \w vanbangla|strong="G5615"\w* a \w ham|strong="G4247"\w* rhoek te \w omih|strong="G2688"\w* \w ah|strong="G1722"\w* \w hingcim|strong="G2412"\w* la om saeh, \w hmuiyoih|strong="G1228"\w* \w boel|strong="G3361"\w* saeh, \w misurtui|strong="G3631"\w* kah sal \w muep|strong="G4183"\w* \w bi|strong="G1402"\w* \w boel|strong="G3361"\w* saeh, olthen aka \w thuituen|strong="G2567"\w* la om uh saeh.  
\v 4 Te \w daengah|strong="G2443"\w* ni \w tanoe|strong="G3501"\w* rhoek \w te|strong="G3588"\w*, va aka \w lungnah|strong="G5362"\w*, ca aka \w lungnah|strong="G5388"\w* la \w om|strong="G1511"\w* ham a \w rhaengtuk|strong="G4994"\w* thaihawn uh eh.  
\v 5 A \w cuepmueih|strong="G4998"\w* la, a \w cuem|strong="G0053"\w* la, \w imkhoem|strong="G3626"\w* \w then|strong="G0018"\w* neh \w a|strong="G2398"\w* \w va|strong="G0435"\w* \w taengah|strong="G3588"\w* boe a \w ngai|strong="G5293"\w*. Te \w daengah|strong="G2443"\w* ni \w Pathen|strong="G2316"\w* \w kah|strong="G3588"\w* \w olka|strong="G3056"\w* \w te|strong="G3588"\w* a \w soehsal|strong="G0987"\w* \w pawt|strong="G3361"\w* eh.  
\v 6 \w Te\w* \w vanbangla|strong="G5615"\w* cadong \w tanoe|strong="G3501"\w* \w rhoek\w* \w te|strong="G3588"\w* \w a\w* \w muet|strong="G4993"\w* \w uh \w*\w ham \w* \w hloephoelh|strong="G3870"\w* \w lah \w*.  
\v 7 A \w cungkuem|strong="G3956"\w* \w ah|strong="G4012"\w* \w namah|strong="G4572"\w* te \w bibi|strong="G2041"\w* \w then|strong="G2570"\w* kah \w mueimae|strong="G5179"\w* la \w tueng|strong="G3930"\w* lah. \w Thuituennah|strong="G1319"\w* \w dongah|strong="G1722"\w* \w rhuepomnah|strong="G0090"\w* neh \w hinomnah|strong="G4587"\w* tueng sak.  
\v 8 \w Olka|strong="G3056"\w* te a \w koemboek|strong="G0176"\w* la \w thuem|strong="G5199"\w* saeh. Te \w daengah|strong="G2443"\w* ni aka \w kingkalh|strong="G1727"\w* \w loh|strong="G3588"\w* \w yak|strong="G1788"\w* vetih \w mamih|strong="G2257"\w* \w te|strong="G4012"\w* a \w thae|strong="G5337"\w* la \w thui|strong="G3004"\w* ham a \w khueh|strong="G2192"\w* \w pawt|strong="G3367"\w* eh.  
\v 9 \w Sal|strong="G1401"\w* rhoek te soeprhaep \w boeih|strong="G3956"\w* \w ah|strong="G1722"\w* \w a|strong="G2398"\w* \w boeikung|strong="G1203"\w* taengah \w boengai|strong="G5293"\w* saeh lamtah a \w kolo|strong="G2101"\w* la \w om|strong="G1511"\w* saeh, \w boekoek|strong="G0483"\w* \w boel|strong="G3361"\w* saeh.  
\v 10 \w Thuhrhawk|strong="G3557"\w* \w boel|strong="G3361"\w* saeh. \w Tedae|strong="G0235"\w* a \w tangnah|strong="G4102"\w* te \w cungkuem|strong="G3956"\w* dongah a \w then|strong="G0018"\w* la \w tueng|strong="G1731"\w* coeng. Te \w daengah|strong="G2443"\w* ni a \w cungkuem|strong="G3956"\w* \w dongah|strong="G1722"\w* \w mamih|strong="G2257"\w* \w khangkung|strong="G4990"\w* \w Pathen|strong="G2316"\w* \w kah|strong="G3588"\w* \w thuituennah|strong="G1319"\w* neh a \w thoeihcam|strong="G2885"\w* eh.  
\v 11 \w Pathen|strong="G2316"\w* \w kah|strong="G3588"\w* \w lungvatnah|strong="G5485"\w* \w loh|strong="G3588"\w* \w hlang|strong="G0444"\w* \w boeih|strong="G3956"\w* taengah \w khangnah|strong="G4992"\w* te a \w thoeng|strong="G2014"\w* sak coeng.  
\v 12 \w Hlangrhong|strong="G0763"\w* \w neh|strong="G2532"\w* \w lunglai|strong="G2886"\w* kah \w hoehhamnah|strong="G1939"\w* \w te|strong="G3588"\w* \w hnawt|strong="G0720"\w* \w ham|strong="G2443"\w* \w mamih|strong="G2248"\w* n'\w toel|strong="G3811"\w* coeng. \w Kumhal|strong="G0165"\w* \w ah|strong="G1722"\w* a \w cuepmueih|strong="G4996"\w* la, a \w tiktam|strong="G1346"\w* la, \w hingcim|strong="G2153"\w* la \w hing|strong="G2198"\w* uh \w pawn|strong="G3568"\w* sih.  
\v 13 \w Ngaiuepnah|strong="G1680"\w* \w yoethen|strong="G3107"\w* \w neh|strong="G2532"\w* \w boeilen|strong="G3173"\w* \w Pathen|strong="G2316"\w* \w kah|strong="G3588"\w* \w thangpomnah|strong="G1391"\w* \w khaw|strong="G2532"\w*, \w mamih|strong="G2257"\w* \w khangkung|strong="G4990"\w* \w Jesuh|strong="G2424"\w* \w Khrih|strong="G5547"\w* \w kah|strong="G3588"\w* a \w phoenah|strong="G2015"\w* \w te|strong="G3588"\w* n'\w lamtawn|strong="G4327"\w*.  
\v 14 \x - \xo 2.14 \xt Tgt 130. 8; \xt Sng 19. 5; Olr 4. 20; 7. 6; 14. 2; 1Pe 2. 9.\x*\w Amah|strong="G3739"\w* loh \w mamih|strong="G2257"\w* \w yueng|strong="G5228"\w* la \w amah|strong="G1438"\w* pae uh. Te \w daengah|strong="G2443"\w* ni \w mamih|strong="G2248"\w* te \w olaeknah|strong="G0458"\w* \w cungkuem|strong="G3956"\w* \w lamloh|strong="G0575"\w* n'\w tlan|strong="G3084"\w* \w tih|strong="G2532"\w* \w amah|strong="G1438"\w* ham a \w khueh|strong="G4041"\w* \w pilnam|strong="G2992"\w*, \w bibi|strong="G2041"\w* \w then|strong="G2570"\w* kah aka \w hmae|strong="G2207"\w* te n'\w cilpoe|strong="G2511"\w* eh.  
\v 15 \w Hekah|strong="G5023"\w* he na \w thui|strong="G2980"\w* \w phoeiah|strong="G2532"\w* \w hloephoelh|strong="G3870"\w* \w lamtah|strong="G2532"\w* \w olpaek|strong="G2003"\w* \w boeih|strong="G3956"\w* \w neh|strong="G3326"\w* \w toeltham|strong="G1651"\w* lah. \w Nang|strong="G4675"\w* te n'\w hnoel|strong="G4065"\w* \w boel|strong="G3367"\w* saeh.   
\c 3  
\s1 Bibi Then a Kuek  
\p
\v 1 \w Amih|strong="G0848"\w* te \w boeilu|strong="G0746"\w* rhoek taengah, \w saithainah|strong="G1849"\w* taengah, \w boengai|strong="G5293"\w* ham, \w olngai|strong="G3980"\w* ham, \w bibi|strong="G2041"\w* \w then|strong="G0018"\w* \w boeih|strong="G3956"\w* \w dongah|strong="G4314"\w* \w sikim|strong="G2092"\w* la \w om|strong="G1511"\w* ham \w thoelh|strong="G5279"\w* pah.  
\v 2 \w Soehsal|strong="G0987"\w* uh \w boel|strong="G3367"\w* saeh. \w Kodo|strong="G1933"\w* neh oldip \w kadip|strong="G0269"\w* la \w om|strong="G1511"\w* ham, \w hlang|strong="G0444"\w* \w boeih|strong="G3956"\w* \w taengah|strong="G4314"\w* \w muelhtuetnah|strong="G4240"\w* \w boeih|strong="G3956"\w* \w tueng|strong="G1731"\w* sak.  
\v 3 \w Hnukbuet|strong="G4218"\w* ah \w mamih|strong="G2249"\w* \w khaw|strong="G2532"\w* \w hlangang|strong="G0453"\w* \w altha|strong="G0545"\w* la ng'\w om|strong="G2252"\w* uh tih n'\w rhaithi|strong="G4105"\w* uh. \w Hoehhamnah|strong="G1939"\w* \w neh|strong="G2532"\w* \w omthenbawnnah|strong="G2237"\w* \w rhoepsaep|strong="G4164"\w* dongah sal m'\w bi|strong="G1398"\w* uh. \w Phayoenah|strong="G2549"\w* \w neh|strong="G2532"\w* \w uethnetnah|strong="G5355"\w* \w dongah|strong="G1722"\w* kho n'\w sak|strong="G1236"\w* uh. \w Khat neh khat|strong="G0240"\w* \w rhalawt|strong="G4767"\w* la \w hmuhuet|strong="G3404"\w* uh thae.  
\v 4 \w Tedae|strong="G1161"\w* \w mamih|strong="G2257"\w* \w khangkung|strong="G4990"\w* \w Pathen|strong="G2316"\w* \w kah|strong="G3588"\w* \w rhennah|strong="G5544"\w* \w neh|strong="G2532"\w* \w lungnah|strong="G5363"\w* \w te|strong="G3588"\w* a \w thoeng|strong="G2014"\w* \w vaengah|strong="G3753"\w*,  
\v 5 \w mamih|strong="G2249"\w* loh \w duengnah|strong="G1343"\w* \w dongah|strong="G1722"\w* \w bibi|strong="G2041"\w* n'\w saii|strong="G4160"\w* uh \w nen|strong="G1537"\w* \w moenih|strong="G3756"\w*. \w Tedae|strong="G0235"\w* \w amah|strong="G0846"\w* kah \w rhennah|strong="G1656"\w* \w vanbangla|strong="G2596"\w* \w koepcunnah|strong="G3824"\w* dongkah \w silhnah|strong="G3067"\w* \w neh|strong="G2532"\w* \w Cim|strong="G0040"\w* \w Mueihla|strong="G4151"\w* kah \w tlaihvongnah|strong="G0342"\w* \w rhangnen|strong="G1223"\w* ni \w mamih|strong="G2248"\w* n'\w khang|strong="G4982"\w*.  
