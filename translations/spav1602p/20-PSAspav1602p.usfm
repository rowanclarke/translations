\v 2 \w Porque|strong="H3588"\w* \w boca|strong="H6310"\w* \w de|strong="H5921"\w* \w impío|strong="H7563"\w* \w y|strong="H3588"\w* \w boca|strong="H6310"\w* \w de|strong="H5921"\w* engañador \w se|strong="H5921"\w* han \w abierto|strong="H6605"\w* \w sobre|strong="H5921"\w* \w mí|strong="H5921"\w*: han \w hablado|strong="H1696"\w* \w de|strong="H5921"\w* \w mí|strong="H5921"\w* \w con|strong="H5921"\w* \w lengua|strong="H3956"\w* \w mentirosa|strong="H8267"\w*,
