\c 21
\s1 Restauración de la tribu de Benjamín
\p 
\v 1 Los hombres \w de|strong="H4480"\w* \w Israel|strong="H3478"\w* \w juraron|strong="H7650"\w* \w en|strong="H4480"\w* \w Mizpa|strong="H4709"\w*: \w Ninguno|strong="H3808"\w* \w de|strong="H4480"\w* nosotros \w dará|strong="H5414"\w* su \w hija|strong="H1323"\w* como esposa \w a|strong="H3068"\w* los \w de|strong="H4480"\w* \w Benjamín|strong="H1144"\w*.
