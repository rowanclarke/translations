\id JHN IYAH - Ajigha
\toc3 IYah
\toc2 IYahaya
\toc1 Ila ididuma ka avọ IYahaya
\mt2 ILA IDIDUMA KA AVỌ
\mt1 IYAHAYA
\c 1
\s1 Ighang Tee Ajiya
\p 
\v 1 Kọ kpaa ka akyua ni ighang shi kọ, ighang ni ishi kina Ọnọng, ighang ni, Ọnọng nga.
\v 2 Anga shi kina Ọnọng kọ kpaa ka akyua.
\v 3 Nadidu uma ba kukushi nga, ni ba imumani aker nadidu ingọ mani aker bọ yọ kini nga ba.
\v 4 Ighang yọ shi ẹrẹpiya ọkyuọ, ọkyuọ wọ shi uyeri ka ajiya nadidu.
\v 5 Uyeri sọ taa kidẹ itii, ni itii ta bra yọ la akyuọ nga ba.
\p 
\v 6 Ace ajiya shi kọ, aghọnọ uca si iYahaya aghọmani Ọnọng tuma nga.
\v 7 Ka aba tẹri ajiya aipang kaya uyeri, ka ajiya nadidu ma aipang ni nga.
\v 8 Anga shi uyeri ba, aba ka aba yeni uyeri.
\v 9 Uyeri aipang umani uka ma uyeri ka ajiya nadidu ki ba idẹ ashi ri.
\p 
\v 10 Akyua ni, ighang shi kọ ka ashi, kina umani kini inga wọ ni aker ashi wọ ni, ashi ta ye wọ ngaa ba.
\v 11 Aba upra umumani ishi inga nga, ni ajiya nga ta yira bọ nga ba.
\v 12 Nadidu aghọmani ayira nga, ki ba va ma aipang nọ uca nga ni, ama bọ ẹrẹgọrọ na atee anọ Ọnọng,
\v 13 aghọmani ajee bọ, basi na ayi ba, ko uwang ẹrẹnọma ko uwang ajiya, unga Ọnọng kọ.
\p 
\v 14 Ighang ba tee ajiya ki ci kidẹ bayọ. Ayọ nu ujọọ nga, ujọọ unga Anọ aye anga Ate, ashi ni ikyua kina aipang.
\p 
\v 15 IYahaya tẹri aipang kaya nga, ki ba sang ẹrẹwyuẹ ki tẹri si, “Adii aghọ ri nga shi aghọmani imẹ sọ pii kaya nga ka akyua ni imẹ si, ‘Aghọmani aki ba kọ utumu mi cẹẹ mi, ka ashi ite mi.’”
\v 16 Inu ikyua nga wọ sa ni ama ayọ ọka yi nadidu yi kwaligba akyua.
\v 17 Ọnọng ma umẹẹ ka avọ iMusa ni asi ma unu ikyua kina aipang ka avọ iYesu Aghọfoo.
\v 18 Ba ajiya na akọ nu Ọnọng ba. Anọ aye nga aghọmani Ọnọng ngaa, aba shi kina Ate ayaya nga yeni ayọ nga ni.
\s1 IYahaya tẹri aipang kaya iYesu
\r (IMat 3.1-12; IMar 1.1-8; ILuk 3.1-18)
\p 
\v 19 Upii aipang ni iYahaya yeni wẹ ka akyua umani aYahudawa tuma afirist kina aLawiyawa ka Urushelima ka aya ghulu nga si, “Ingọ si inga?”
\p 
\v 20 IYahaya ta la nga inang kọ ba, atẹri ka ayayẹ si, “Imẹ shi Aghọfoo ba.”
\p 
\v 21 Aba ghulu nga si, “Ingọ shi inga?
\p Ingọ shi Iliya?”
\p Aba yira bọ si, “Kayi, Imẹẹ ba.” Ingọ shi aghọ pii kọ ọtọ Ọnọng ra?”
\p Aba yira si “Kayi.”
\p 
\v 22 Aba tẹri nga si, “Ingọ shi inga? Yira ayọ upii umani ayọ ki ya tẹri aghọmani atuma ayọ. Ikẹmbọ nọ ingọ sọ tẹri ni ẹrẹkwyuẹ ngọ?”
\p 
\v 23 Asi,
\b
\q1 “Imẹ ni ẹrẹyuẹ yọrọ wọ ka aghumu,
\q2 ‘Inu ker Ate ayaya nga itra kọnọ umani aghọ pii kọ ọtọ Ọnọng Ishaya tẹri ni.”
\p 
\v 24 Ni ace aFarisiyawa umani atuma
\v 25 ba ghulu nga si, “Insi ingọ shi Aghọfoo ko Iliya ko aghọ pii kọ ọtọ Ọnọng ra ba ni, ikẹmbọ sa ni ingọ sọ ju iminimini?”
\p 
\v 26 IYahaya ba yira bọ si, “Imẹ ni, ika ju iminimini na amusum, ace aghọ shi kidẹ nu ni inu ta ye nu ngaa ba.
\v 27 Anga ki ba kọ utumu mi, aghọmani ita maa mi ni ishii ani na akpọ nga ba.”
\v 28 Nadidu uma ri ba ka aBetani wọ, ka ubuu ẹrẹyẹma aYodan.
\s1 IYesu nga shi Itimi Ọnọng
\p 
\v 29 Ikyua ya yẹẹ ni, aba nu na aki ba nga ukushi nga. Aba ju si, “Itimi Ọnọng wẹ aghọ kpaa uvulu ashi nadidu!
\v 30 Aghọmani imẹ tẹri si, ‘Ace aghọ ki ba kọ utumu mi na acẹẹ mi, ka ashi kọ na akọ jee mi nga ba.’
\v 31 Akyua ni imẹ kọ ye mi nga ba, ni imẹ ba ni imẹ sọ ju iminimini na amusum ka ayeni ngaa ka ajiya Israila.”
\p 
\v 32 IYahaya ba yeni nga si, “Imẹ nu Aghing kini ikhimi kọ ni isọ shulu ka yaya ki ba cica ka aya nga.
\v 33 Akyua ni imẹ ye mi ngaa ba, Ọnọng na atuma mi uju iminimini na amusum nga tẹri mi si, ‘Aghọmani ingọ nu na Aghing Ọnọng shulu ki cica ka aya nga ni, anga shi aghọ uju iminimini na Aghing Ọnọng.’
\v 34 Imẹ ẹrẹkwyuẹ mi nu kindọ ki ma aipang shi ajiya ri ni Anọ Ọnọng ngaa.”
\s1 Aghọmani akyọ uyii IYesu
\r (IMat 4.18-22; IMar 1.16-20; ILuk 5.2-11)
\p 
\v 35 Ikyua ya yẹẹ ni, iYahaya ting kọ kadu kina agha apai kidẹ aghọyii ngaa.
\v 36 Aba nu iYesu na asọ wor, na aba ju si, “Nu, itimi Ọnọng wudu!”
\p 
\v 37 Aghọyii ngaa agha apai ra ya kọọ upii nga ni, aba yii iYesu.
\v 38 IYesu ya tee ki nu na asọ yii ngaa ni, aba ghulu bọ si, “Ikẹmbọ ni inu sọ wang?”
\p Aba tẹri nga si, “Aghọmẹẹ, abi wọ ni ingọ ci kọ?”
\p 
\v 39 IYesu ba yira bọ si, inu ba ka inu ba nu.” Ava ba ki ba nu uka uci nga, ni ava ci ila bọ kini inga ka awii ra, aci kọ ukadu kini nga ki wiya ya.
\p 
\v 40 Andrawus, anayuru iSiman iBitrus shi aghaye kidẹ agha apai na ayii iYesu nọ umani akọọ upii iYahaya kaya iYesu.
\v 41 Andrawus zọnọ wang anayuru nga iSiman, asi, “Ayọ kọ peni Aghọfoo, iKristi.”
\v 42 Aba kyaa na iSiman kukushi iYesu.
\p IYesu nu nga na asi, “Ingọ shi iSiman anọ iYahaya. Aki yọrọ ngọ si iKefas ko iBitrus, angọ yeni si utii.”
\s1 IYesu Yọrọ iFilibus kina iNataniyel
\p 
\v 43 Ikyua ya yẹẹ ni iYesu wang kyaa aGalili ni, aba ya peni iFilibus ki ju nga, “Yii mi.”
\p 
\v 44 IFilibus ni agha aBetsaida ngaa, ifọng Andrawus bọ kina iBitrus.
\v 45 IFilibus ya peni iNataniyel ki tẹri ngaa si, “Ayọ peni ajiya umani awọọ ila nga kidẹ umẹẹ iMusa, kina ẹrẹwọ aghọ pii kọ ọtọ Ọnọng, iYesu agha aNazaret, anọ iYusufu.”
\p 
\v 46 INataniyel ba ghulu si, “Iligba ima ididuma yọ ki kunu ka aNazaret?”
\p IFilibus ba ju nga si, “Ba kọ ingọ ba nu.”
\p 
\v 47 IYesu ya nu iNataniyel na aki ba ukushi nga ni, aba ju si, “Nu agha Israila aipang, aghọmani ashi na atẹri kidẹ nga ba.”
\p 
\v 48 INataniyel ba ghulu iYesu si, “Abi wọ ni ingọ yemi kọ?”
\p IYesu ba yira nga si, “Imẹ nu ngọ ki ẹrẹpiya ọshẹ uwe na iFilibus kọ yọrọ ngọ ngaa ba.”
\p 
\v 49 INataniyel ba yira iYesu si, “Aghọmẹẹ, ingọ shi Anọ Ọnọng! Ingọ shi agọm Israila!”
\p 
\v 50 IYesu ba yira nga si, “Ingọ ma aipang kọ nọ umani imẹ tẹri ngọ si, imẹ nu ngọ ki ẹrẹpiya ọshẹ uwe? Ingọ ki nu uma umani ucẹẹ kindọ.”
\v 51 IYesu va khimi utẹri nga kọ si, “Aipang ni imẹ sọ tẹri nu, inu ki nu ayaya na ashi ayẹ, atuma Ọnọng ki shi kọ kila na ashulu kaya Anọ Ajiya.”
\c 2
\s1 IYesu sa ni amusum tee amusum Ikọlọ na ashẹ
\p 
\v 1 Awii itai ni, asa sra agya ubiya ka aKana anga aGalili. Ayuru iYesu shiya kọ ukaa.
\v 2 Akọ yọrọ iYesu kina aghọyii nga agya ubiya.
\v 3 Amusum ikọlọ na ashẹ ya kpẹẹ bọ ni, ayuru iYesu ba tẹri ngaa si, “Amusum ikọlọ na ashẹ bọ kpẹẹ bọ.”
\p 
\v 4 IYesu ba yira ngaa si, “Ayiri, ikẹmbọ sa ni ingọ ba ukushi mi? Akyua mi ta kọ ba wọ ba.”
\p 
\v 5 Ayuru nga ba tẹri agira nga si, “Inu ju imumani asa nọ uju.”
\p 
\v 6 Akyua ra ni, ukyo na amusum utin ugna umani aker na atii ni aYahudawa ka hwuru irighe wọ shiya kọ ukaa. Kọlọgba ka la ima umra amusum araji.
\v 7 IYesu ba tẹri bọ si, “Sa amusum kọ ukyo na lilai. Aba sa ya ki tili wọ na lilai.
\v 8 Aba tẹri bọ si, “Ka akyakyua ri ni, inu vo ace ka inu ya ma agha aghaghẹ na agya.” Aba vo amusum ki ya ma ngaa.
\v 9 Agha aghaghẹ na agya ya piya amusum ki kọọ ni akọ tee anga ikọlọ na ashẹ ni ata ye ngaa uka umani aba ni bọ kọ ba, (agira ye uka umani avo amusum wọ), agha aghaghẹ agya ba yọrọ aghẹmẹ asasa ki kyaa ugẹẹ uye kọ,
\v 10 ni asi, “Kwinga ka zọnọ uma amusum ikọlọ na ashẹ adaduma, na atọ ba na angọ umani ata fuma bọ adidu ba insi akyeng kọ sa ki shuu ni. Ingọ ni ingọ sọ amusum ikọlọ na ashẹ adaduma, akyua ri kọ ni ingọ woo kọ!”
\p 
\v 11 Udii wọ shi ima usa uwo ica iye ni iYesu ju ka aKana anga aGalili, ki yeni ujọọ nga; ni aghọyii nga ma aipang ni ngaa.
\p 
\v 12 Aya kpẹẹ ni, aba wor kyaa aKafarnahum kina ayuru nga, kina anayuru nga, kina aghọyii nga; aya ci kọ ukadu ki la anirawii wọ.
\s1 IYesu Yẹri Ọna Ọnọng
\r (IMat 21.12-13; IMar 11.15-17; ILuk 19.45-46)
\p 
\v 13 Akyua usra agya ubulu aYahudawa ya ba ayayo ni, iYesu ba kyaa Urushelima.
\v 14 Kidẹ Ọna Ọnọng ni, aya peni ni ajiya sọ gbara inaa kina atẹm kina ukhimi, ni aghọ user ufẹ shi ka atebur bọ.
\v 15 IYesu va keri aiwili na anii, ava kla bọ nadidu bọ kina atẹm kina inaa kidẹ Ọna Ọnọng. Ava naa ufẹ umani aghọ user sọ ju ki vila atebur nga kọ.
\v 16 Aba tẹri aghọ gbra ukhimi si, “Inu kpaa uma nu wọ kọ ukadii! Inu ba tee nọ Ọna Ate mi uka la izẹ ba!”
\v 17 Aghọyii nga wa shuni sa awọọ si, “Usa ikwyi uyoo ọna ngọ sọ la kọnọ ugha wọ ni.”
\p 
\v 18 AYahudawa va ghulu ngaa si, “Aligba amaa uwo ica ngaa ni ingọ ki yeni ayọ ungọ umani uyeni ẹrẹkyuọ ni ingọ ju uma ri kọ?”
\p 
\v 19 IYesu ba yira bọ si, “Inu pulu Ọna Ọnọng ri kọ, imẹ ki shang wọ kidẹ na awii atai.”
\v 20 AYahudawa ba ju si, “Akpaa anyi ishinari na atin na asọ vra ọna Ọnọng ri! Ingọ si ingọ ki shang wọ kidẹ na awii atai?”
\p 
\v 21 Ni, Ọna Ọnọng umani iYesu sọ pii kaya wọ shi ẹrẹnọma nga.
\v 22 Kọ utumu umani asang kọ ukpo ni, aghọyii ngaa shuni si asa tẹri kindii; ni ava ma aipang nọ upii Ọnọng kina imumani iYesu sa tẹri.
\p 
\v 23 Akyua umani ashi ka Urushelima ka usra agya ubulu ni, ajiya na pam ma aipang nọ uca nga nọ umani anu uma usa uwo ica na asọ ju.
\v 24 Ni iYesu ta yira nga bọ ba ka aye bọ nadidu bọ nagigang.
\v 25 Ata wang ngaa aghọ umani aki tẹri ngaa ima kaya ajiya ba ka aye imumani ishi kidẹ ikwyi kwinga.
\c 3
\s1 INikodimus ba ukushi iYesu
\p 
\v 1 Ace ajiya aghọnọ uca si iNikodimus shi kọ, aghaye kidẹ aFarisiyawa, agha aghaghẹ aYahudawa.
\v 2 Ajiya nga ba ukushi iYesu na atii, atẹri nga si, “Aghọmẹẹ, ayọ ye si ingọ ni aghọmẹẹ umani aba kukushi Ọnọng ngaa; ki ba aghọmani aki bra uju uma usa uwo ica ri ba sa aghọmani Ọnọng shi kini ngaa.”
\p 
\v 3 IYesu ba yira ki tẹri si, “Aipang, imẹ sọ tẹri ngọ, ba aghọmani aki bra unu ẹrẹgọm Ọnọng, sa azọnọ khimi ujee ngaa kọ.”
\p 
\v 4 INikodimus ba yira ngaa si, “Aki jee ajiya nagyi ni ashi kọ la awii apai? Aki va ghila ngaa idẹ afo ayuru nga ka aba jee ngaa unga ipai?”
\p 
\v 5 IYesu ba yira nga si, “Aipang, imẹ sọ tẹri ngọ, ba aghọmani aki bra ughila idẹ ẹrẹgọm Ọnọng ba, sa ajee nga na amusum kina aghing.
\v 6 Imumani ajiya jee ni, ajiya ngaa, imumani aghing jee ni, aghing ngaa.
\v 7 Ba woo ica nọ umani imẹ si, ‘Iyiya ni, sa ajee nọ ka ayaya ba.’
\v 8 Uwuru ka te ki kya wọ ọka nọ uhwiya, ni inu ka kọọ ishimi nga, ni inu ta ye uka umani ukunu wọ kọnọ ọka ni ọki kya wọ kọ ba. Kindii wọ ni aghọmani ajee ngaa na aghing shi kọ.”
\p 
\v 9 INikodimus ba ghulu iYesu si, “Nagyi wọ ni udii ki ba kọ?”
\p 
\v 10 IYesu ba yira nga si, “Ingọ ni aghọmẹẹ aghaghẹ nga ki Israila, ni ingọ ta kpẹlẹ ngọ uma ri ba?
\v 11 Aipang ni imẹ sọ tẹri nọ, ayọ ka pii kaya imumani ayọ ye wọ, ni ayọ sọ ba yeni nu imumani ayọ nu, kindọ ni inu tọọ nọ ọkọọ imumani ayọ tẹri nu.
\v 12 Imẹ tẹri nu kaya uma ashi ri ni inu ta ma nu aipang kọ ba, nagyi wọ ni inu ki tọ ma aipang kọ nọ uma ni ushi unga ayaya?
\v 13 Ba aghọ umani akọ kyaa ayaya ba, Anọ Ajiya kayu nga umani asuu ka ayaya ngaa kọ akyaa.
\p 
\v 14 “Kọnọ umani iMusa zẹẹ iyọọ utii uyeri ka aghumu ni, kindii wọ ni iyiya na azẹẹ Anọ Ajiya kọ,
\v 15 ka nadidu aghọmani ama aipang ni ngaa ni, aki peni ọkyuọ ni ushi wọ na amaa ba.
\p 
\v 16 “Ka Ọnọng yoo ashi nagigang ki ma Anọ nga ka aye, ka aghọmani ama aipang ni ngaa ni, aba kpoo ba, na asa peni ọkyuọ ni ushi wọ na amaa ba.
\v 17 Ọnọng ta tuma ngaa na Anọ nga ka aba wa ashi ashuwa ba, ashi ni, apeni ufoo kukushi nga.
\p 
\v 18 Nadidu aghọmani ama aipang na Anọ Ọnọng ni, aki wa bọ ngaa ashuwa ba. Nadidu aghọmani ata ma bọ aipang ni ngaa ba ni, akọ wa nga ashuwa wudu ka ata ma nga aipang nọ uca Anọ aye Ọnọng ba.
\v 19 Umani ashuwa shi wẹ, uyeri ghila ashi, ni ajiya cẹẹ nọ uyoo itii kina uyeri, ka uma uju bọ ni unga akakiya bọ.
\v 20 Ka aghọmani aka ju akakiya ni atọọ ngọ uyeri, aka va ba nga ọka uyeri ba ka aba nu uma uju nga ba.
\v 21 Aghọ ju aipang ka ba ọka uyeri, ka anu ka ayayẹ si uma uju nga ni, Ọnọng ta nga avọ wọ.”
\s1 Imumani IYahaya Yeni kaya IYesu
\p 
\v 22 Aya kpẹẹ kindọ ni, iYesu kina aghọyii nga ba sang ki kyabọ ishẹẹ ẹrẹbọ aYahudiya. Akpaa akyua na ci kọ ukadu, na asọ ju ajiya iminimini.
\v 23 IYahaya sọ kọ ju iminimini ka Ainon ka ayayo aSalim, ka amusum shi ya na pam kọ ukadu. Ajiya kyeng na aju bọ iminimini.
\v 24 Aju umari na akọ ta bọ iYahaya kidẹ ubọọ itii ba.\x - \xo 3.24 \xt IMat 14.3; IMar 6.17; ILuk 3.19-20.\x*
\p 
\v 25 Ni aghọyii iYahaya tee aghọ la ilang kina ace aBayahude kaya itali uhwuru ka ahwuru irighe kọnọ umani umẹẹ iMusa yeni ni.
\v 26 Aghọyii ba kyaa ukushi iYahaya aghọ uju iminimini kiya tẹri nga si, “Aghọmẹẹ, ajiya umani inu shi kini ngaa ka udaa ugẹẹ ighọ Urdun, aghọmani ingọ ki kirẹkwyuẹ ngọ tẹri upii kaya nga ra, awudu na asọ ju iminimini, ni kwinga sọ kyaa ukushi nga.”
\p 
\v 27 IYahaya ba yira nga si, “Ba aghọmani aki bra uyira ima ba sa ama nga ka ayaya.
\v 28 Inu ka kyakwyuẹ nu ni inu shiya kọ uka ka asi, ‘Imẹ shi aghọfoo ba, atuma mi ki imẹ la nga ite wo.’
\v 29 Aghọ shi na ayiri asasa nga shi aghẹmẹ asasa. Ayikyo aghẹmẹ ka tara ka akọ ẹrẹwyuẹ nga, aka kọọ ikwyifu nagigang nọ ọkọọ ẹrẹwyuẹ aghẹmẹ. Kindọ wọ ni ikwyifu mi hwura wọ.
\v 30 Iyiya yọ ni ajiya nga sọ khimi ni imẹ sa vuu mi utumu.
\s1 Aghọmani aba ka ayaya
\p 
\v 31 “Aghọmani aba ka ayaya cẹẹ kwinga. Aghọmani aba ka asing ni, agha asing ngaa, na aka pii kaya uma asing wọ. Aghọmani aba ka ayaya ni, acẹẹ kwinga.
\v 32 Aka tẹri imumani anu ki kọọ wọ, nadidu kindọ ni, ba aghọmani ayira ima utẹri nga.
\v 33 Ni aghọmani ayira uyeni amaa nga ni, a yira wudu si, iyiya ni Ọnọng na agha aipang nga.
\v 34 Ka aghọmani Ọnọng tuma ni, upii Ọnọng wọ na asọ tẹri, ka Ọnọng ma nga aghing nga angọ umani ashi na amaa.
\v 35 Ate yoo Anọ, ama kwikẹ ki ivọ nga.
\v 36 Nadidu aghọmani asọ ma aipang ka anọ ni, ashi na ọkyuọ nọ ushi wọ na amaa ba. Nadidu aghọmani ata yira nga Anọ ba ni, aki peni nga ọkyuọ nọ ushi wọ na amaa ba, anang Ọnọng ki shi kaya ẹrẹkwyuẹ nga.”
\c 4
\s1 IYesu Kina Ace Ayiri Ka ASamariya
\p 
\v 1 AFarisiyawa ya kọng si iYesu sọ pee Aghọyii nga, na asha ju bọ iminimini ki gina iYahaya kọ.
\v 2 Ni ba iYesu nga ki ẹkẹrẹkywuẹ nga sọ ju iminimini ba, aghọyii nga bọ.
\v 3 IYesu ya kọng Ila imumani iba ni, ava ya aYahudiya ki vuu nga aGalili.
\v 4 Iyiya yọ ni iYesu kyeng idẹ aSamariya.
\v 5 Ava ba idẹ ice ifọng ka aSamariya ayọrọ si aSaikar. Ifọng shi ayayo kina ẹrẹbọ umani iYakubu ma Anọ nga iYusufu ka akyua ra.
\v 6 Akadu wu ni irijiya iYakubu shi kọ. IYesu ya kiya nọ kyeng ni, ava cicaa ka anyu irijiya. Udi ba kina abiyatẹ atinọng kọ.
\v 7 Ace ayiri agha aSamariya va ba uvo amusumu. IYesu va tẹri nga si, “Ma mi amusumu ki imẹ sa.”
\v 8 Aghọyii nga kọ ghila bọ idẹ ifọng ka ya ghẹ imila.
\v 9 Ayiri ra agha aSamariya va tẹri iYesu si, “Nanyi wu ni ungọ ni aBayahude nga ni ingọ ki shọr mi amusum usa, imẹ aghọmani imẹ shi ayiri aghọ aSamariya?” Ka aYahudawa ka kyoo bọ aghọ aSamariya ba.
\v 10 IYesu va yira nga si, “Ingọ ta ye uma Ọnọng, kina aghọmani atẹri ngọ si, ‘Ma mi amusum usa ni,’ ingọ ta kọ shọr nga ni ata kọ ma ngọ amusum uma ọkyuọ.”
\v 11 Ayiri va tẹri IYesu si, “Agha aghaghẹ, Ingọ shi ngọ ni ima uvo amusumu ba, irijiya shi ikyuu. Ni abi kọ nọ peni adibi amusumu uma ọkyuọ kọ?
\v 12 Ta ingọ gina ate yi iYakubu le, aghọmani aya yi irijiya ni, anga ki kirẹkwyuẹ nga, kina anọ nga, kina ikina nga, asa amusumu nga le?”
\v 13 IYesu va yira si, “Aghọmani asa amusumu ri ki va kọng idafo na amusumu.
\v 14 Ki nadidu aghọmani asa amusumu mani iki ma nga ni, aki sọ kọng idafo na amusumu ba ka aya ta kọ sang asing. Amusumu mani iki ma nga ni aki tee nga angọ uma ọkyuọ umani ushi wọ na amaa ba.
\v 15 Ayiri va tẹri nga si, “Aghaghaghẹ, ma mi adidu amusumu, ki ima sọ kọng idafo na amusumu ba, ki imẹ ma sọ ba ukadi uvo amusumu ba.
\v 16 IYesu va tẹri nga si, “Ya yọrọ aghẹmẹ ngọ kọ ba ukẹẹ.”
\v 17 Ava yira ki tẹri si, “Ita shi mi na aghẹmẹ ba.” IYesu va tẹri nga si, “Ingọ tẹri aipang nọ mani ingọ tẹri si ushi ngọ na aghẹmẹ ba.
\v 18 Ka aipang nga shi si, ingọ kọ biya aghẹmẹ atọng, aghọmani ingọ shi kini nga ka aikyua ri ni ba aghẹmẹ ngọ nga ba.”
\v 19 Ayiri va tẹri iYesu si, “Aghaghaghẹ, imẹ kyoo ni ọngọ na aghọ pii kọ ọtọ Ọnọng nga.
\v 20 Anirakpẹẹ nọ shọr Ọnọng ki itili ri. Ni inu aYahudawa tẹri si Urushelima bọ kpaa nọ mani jọọ Ọnọng kọ.”
\v 21 IYesu va yira nga si, “Ayiri, ma aipang ki imumani isọ tẹri, akyua ki ba mani ajiya ki jọọ bọ Ate ki itili ra ba, ko Urushelima ba.
\v 22 Inu ajiya aSamariya inu sọ ta agho ki imumani inu ye nu ba. Ki iyi aYahudawa ye imumani iyi sọ ju, ka ufoo kunu kidẹ aYahudawa kọ.
\v 23 Ni akyua ki ba, kaa akọ ba, na aghọ ujọọ aipang aki jọọ Ate kidẹ aghing, kina aipang, ka Ate wang idi ighọ ajiya ka ajọọ nga.
\v 24 Ọnọng ni aghing ngaa, aghọ ujọọ nga ni, asọ jọọ nga kidẹ aghing, kini idẹ aipang.”
\v 25 Ayiri va tẹri iYesu si, “Imẹ ye si aghọfoo mani ayọrọ nga si iKristi ki ba. Insi aba ni aki yeni yi kwikẹ.”
\v 26 IYesu tẹri nga si, “Imẹ aghọ pii ni ngọ, imẹ shi inga.”
\p 
\v 27 Asọ kpẹẹ upii wudu ni aghọyii nga va vuu, ava wo ica kọnọ mani anu ni asọ pii na ayiri. Ni ba aghọmani atẹri nga si, “Ikẹmbọ nọ wang?” ko na awulu nga si, “Ikẹmbọ sa ni ọsọ pii ni nga?”
\p 
\v 28 Ayiri ra vasa ya ikyo nga ya kọ ukadu ki kyaa idẹ ifọng ki ya tẹri ajiya,
\v 29 “Inu ba, ku ma nu ajiya mani atẹri mi kwikẹ mani ikọ ju! Ta anga shi aghọfoo ra?”
\v 30 Ajiya va hwuu kidẹ ifọng ki ba ukushi iYesu.
\v 31 Ashi kidẹ udu wudu ni, aghọyii iYesu va shọr nga ki tẹri si, “Aghọmẹẹ, la imila.”
\p 
\v 32 Ni iYesu va tẹri bọ si, “Imẹ shi ni ice imila mani inu ye nu ice ima kaya ba.”
\v 33 Aghọyii nga va wulu ace bọ si, “Ta ace aghọ ma nga imila le?”
\p 
\v 34 IYesu va yira si, “Imila mi yọ shi mani iju uwang aghọmani atuma mi, ki imẹ va kpẹẹ utina nga.
\v 35 Ba inu ka tẹri si, ‘Ipiri inari yọ shẹ nọ curu imila ba’? Kindọ ni imẹ sọ tẹri nu, inu irite na bibọrọ, iyeni si, itọ ucuru.
\v 36 Aghọ curu imila sọ peni ọka nga, aka va curu ima upeni nga ki kya ọkyuọ utaa amaa kọ, ka aghọ pila na curu ka ju ikwyifu.
\v 37 Akyua ra kọ ni, ighang upii ra ni aipang nga, si, ‘Ace aghọ pila, ace ghọ curu imila.’
\v 38 Ituma nọ curu imumani uta kọng nu ọlọ kaya ba. Ace aghọ bọ kọng ọlọ, inu ni inu la udọng usher bọ.”
\v 39 Aghọ aSamariya napam kidẹ ifọng ma aipang ni iYesu kọ upii ayiri ra mani atẹri si, “Atẹri mi nadidu uma mani ikọ ju.”
\v 40 Aghọ aSamariya ya ba ukushi iYesu ni, ava shọr nga sa aci kini bọ, ava ci ni bọ awii apai.
\v 41 Ajiya napam vasa ma aipang ni iYesu kaya upii nga.
\v 42 Akyua ra kọ ni aghọ aSamariya tẹri ayiri si, “Aikyua ri ni iyi ma aipang kọ, ba si imumani ọsọ tẹri yọ ba, kiyi ka kyakwyuẹ yi kọng, kiva ma aipang si ajiya ri nga shi aghọfoo asing.”
\s1 IYesu Lẹni na Anọ Aghọ Tẹri Ashuwa
\p 
\v 43 Aya la awii apai ni iYesu va sang ki isii aSamariya ki kyaa aGalili.
\v 44 Ki iYesu ki ẹkẹrẹkywuẹ nga kọ tẹri si, “Atina Ọnọng ka ata shi nọ ujọọ ki ẹrẹbọng nga ba”.
\v 45 Aya fọma aGalili ni, agha aGalili va yira nga kini ivọ ipai, ki ibọ ma kya agya ubulu kọ Urushelima, anu imumani iYesu ju.
\v 46 IYesu va vuu nga ifọng aKana ka aGalili, ọka mani atee amusumu ikọlọ nashi. Ọka ni ace atina utẹri ashuwa aghọmani anọ nga shi akyuọ ba ka aKafarnahum.
\v 47 Ajiya ra ya kọng si iYesu wẹ na vuu nga aGalili kọ sang ka aYahudiya ni, ava kyaa ọkọ shi nga kiya shọr nga kaya lẹni na anọ nga aghọmani ashi ki anyu ukpo.
\v 48 IYesu va tẹri nga si “Insi inu ta nu nọ amaa kini uma ọsa uwo ica ba ni, inu ki ma nọ aipang ba ko nazii.”
\v 49 Atina ọka utẹri ashuwa va tẹri iYesu si, “Aghaghaghẹ, ba ki ma kẹẹ ka anọ mi kina ma kpoo ba.”
\v 50 IYesu va tẹri nga si, “Wor ka anọ ngọ ki ba akyuọ.” Ajiya nga ma aipang ki imumani iYesu tẹri nga, ava walu.
\v 51 Ashi kọ utira ukyaa ọna nga ni, agira vasa takwyuẹ ni nga ava tẹri nga si, “Anọ ngọ kọ ba akyuọ.”
\v 52 Ava wulu nga agọlọ mani aba akyuọ kọ. Ava tẹri nga si “Amushẹ ki na awa ayeng anga atinọng ni ufuru ẹrẹnọma sher nga kọ.”
\v 53 Ate Anọ va kpẹlẹ si akyua umani iYesu tẹri nga si “Wolu, ka anọ ngọ ki ba akyuọ kọ.” Ajiya kina aghọ ọna nga va ma aipang ni iYesu.
\v 54 Udiwu shi utina uwo ica unga ipai mani iYesu ju kọ sang nga ka aYahudiya ki kyaa aGalili.
\c 5
\s1 IYesu Lẹni na Agunu ka Ighọ ABetasda
\p 
\v 1 Aya kpẹẹ ni, iYesu va wolu ki kyaa Urushelima kọ uce usra agya aYahudawa.
\v 2 Kọ Urushelima ni ice ighọ na amusum shiya angọ mani aghimi nọ agẹẹ ọtọng. Kina ijiya aYahudawa ni ayọrọ si ABetasda. Udidu ighọ ushi ayayo kina anyu ubọọ na Atẹm.
\v 3 Agẹẹ ra yọ na adumu, kina afoo kina agunu na aghọ shọmọ ivọ napam kọ ghẹli na molu kọ.
\v 4 Asọ sha ka zọọ amusumu nga ni. Ki ace agọlọ ni Atina Ọnọng ka shulu ki zọọ amusumu nga, Avasa lẹni ki ighọ idumu mani ashi kini yọ.
\v 5 Ukadu ni ace ajiya shiya akọ la anyi ishitai na ananari kini udumu nga.
\v 6 IYesu ya nu nga na yẹẹ ni, aye si ajiya nga kọ tiri wọ nọ udumu nga, iYesu va tẹri ajiya si, “Ingọ wang Lẹni?”
\v 7 Adumu nga va yira nga si, “Aghaghaghẹ, ishimi na aghọ mani aki shẹ mi kọ ki ghila ighọ ka kyua mani asọ zọọ amusumu nga kọ ba. Insi imẹ sher si imẹ sọ ghila ni ace aghọ sa la mi ite kọ.”
\v 8 IYesu vasa tẹri nga si, “Sisang, kọ kpaa ishọr ngọ, kọ kyeng ila ngọ!”
\v 9 Kaidu agọlọ ni aghọ vasa lẹni, ava kpaa ishọr nga ki wolu. Idi ima ba ka awii uwuru aYahudawa.
\v 10 Kindọ ni AYahudawa vasa tẹri ajiya mani a lẹni ni ngaa si, “aidi ni awii wuru kọ, kọnọ umẹẹ IMusa ni ikikya yọ na akpaa ishọr ba.”
\v 11 Ajiya nga vasa yira bọ si, “Aghọmani a lẹni ni mẹ, a ngaa tẹri si imẹ kpaa ishọr mi ki wolu.”
\v 12 Avasa ghulu nga si, “Inga shi aidi ajiya mani atẹri ngọ si kpaa ishọr ngọ ku wolu?”
\v 13 Aghọmani a lẹni ni ngaa ni, ata ye ti inga lẹni ni ngaa ba, ka ajiya shiya napam kọ ukaa, iYesu vasa wolu kidẹ majiya.
\m 
\v 14 Ana kyua nazii ni, iYesu vasa peni nga kidẹ Ọna Ọnọng, ki tẹri nga si, “Nu ni, ingọ lẹni! Ni, ma sọ ju avulu ba, ki imumani icẹẹ idi nọ ububi ma ba ngọ ba.”
\v 15 Ajiya nga vasa wolu kiya tẹri aghakakọng aYahudawa si, iYesu nga lẹni ni nga.
\v 16 Kindọ ni avasa tee aghọ ma iYesu ọlọ, ka asọ ju udibi uma ka awii uwuru aYahudawa.
\v 17 IYesu vasa tẹri bọ si, “Ate mi sọ ju utina kọ ta kai kyua ri, imẹ ma ka ju.”
\v 18 Udi upii sa ni aYahudawa khimi uwang iYesu sa apii nga kọ. Avasa tẹri si, “Ba si acẹẹ imumani atẹri ka awii uwuru aYahudawa ba, ka atẹri si ate nga Ọnọng ngaa, ka ama si anga shi Ọnọng wudu.”
\s1 Ẹrẹgọrọ IYesu Anọ Ọnọng
\p 
\v 19 IYesu vasa yira bọ si, “Iyiya, isọ tẹri nu, Anọ ka ata ju ice ima, ka yayu nga ba, si imumani anu na Ate ka ju. Ki ididu imumani Ate ka ju, iyọ ni Anọ ka ju.
\v 20 Ka Ate yoo Anọ, aka va yeni nga uma mani inga ki ẹkẹrẹkywuẹ nga ka ju, aki va yeni nga itina mani icẹẹ idibi, ka inu wo ica.
\v 21 Kọnọ umani Ate ka sang aghọ ukpuru ka apeni ikyuọ ni, kindọ ni Anọ shi na akyuọ ka aghọ umani ayoo.
\v 22 Ate ra ju ace aghọ ashuwa ba, Na va ma Anọ ẹrẹgọrọ uju kwinga ashuwa,
\v 23 Ka ajiya naidu jọọ Anọ, kọnọ mani aka jọọ Ate ni. Naidu aghọmani ata jọọ Anọ ba ni, aka ta jọọ ate mani atuma nga wudu ba.
\v 24 “Iyiya, isọ tẹri nọ, Naidu aghọmani aka kọng upii mi, kiva ma aipang ka aghọmani atuma mi ni, ashi nọ ọkyuọ utaa amaa. Aki ju nga ashuwa ba, akọ bulu ukpọ ki peni ọkyuọ.
\v 25 Iyiya ni sọ tẹri nọ, akyua ki ba, akọ ba ma, na aghọ kpuru bọ ki kọng ẹrẹwyuẹ Anọ Ọnọng, aghọmani akọng ki lang.
\v 26 Kọnọ mani Ate ki ẹkẹrẹkywuẹ nga ni ẹrẹpiya ọkyuọ kọ ni, kindọ ni asa si Anọ nga tee ẹrẹpiya ọkyuọ kọ.
\v 27 Ava ma nga ẹrẹgọrọ uju ashuwa ki nga ni Anọ ajiya nga.
\v 28 Inu ma woo ica na udi upii ba, ka akyua ki ba mani aghọmani ashi kidẹ na alọr ki kọng ẹrẹwyuẹ nga,
\v 29 Ka akunu. Aghọmani aju uma ọdọdọma ki sisang, ka apeni ọkyuọ, ni aghọmani aju utaa aipang ni, aki sisang ka va ju bọ ashuwa.
\v 30 Imẹ ka bra mi uju ima ka ayayu mi ba. Imẹ sọ ju ashuwa kọnọ umani Ọnọng tẹri yi si iyi ju ni. Kindọ ni ashuwa anga aipang kọ, ki ba ima ushi kidẹ ikwyi mi yọ ni isọ ju ba, ki ima ukunu kukushi aghọ utuma mi yọ.
\s1 Aghọ Tara IYesu
\p 
\v 31 “Ipeni imẹ tara ẹrẹkwyuẹ mi ni, ni ima tẹri mi shi yọ aipang ba.
\v 32 Ka ace ghọ shi wu ni aki tara mi, ni iye si imumani aki tẹri kaya ẹrẹkwyuẹ mi ni aipang nga.
\v 33 Inu tuma ajiya kukushi iYahaya, inga vasa tẹri nọ aipang.
\v 34 Kindọ ni ira tọrọ mi na utara ajiya ba. Imẹ tẹri kindọ ka inu peni ufoo.
\v 35 IYahaya ni ọgbẹlẹmọ ula ugha kọ, ọngọ uyeri kọ, ọva ma aipang kọ ju ikwyifu naigang kọnọ uyeri nga ka ana gọlọ nazii.
\v 36 Ni imẹ shi ni anga mẹ aghọ tara mi angọ mani agina aghọ tara iYahaya ya kaya ẹrẹkwyuẹ mi. Uma mani isọ ju, ọngọ mani Ate mi ma mi si ju, ọbọ shi uma umani uyeni amaa, ate mi ngaa tuma nga.
\v 37 Ate mani anga tuma mi anga ki ẹkẹrẹkywuẹ nga yeni aghọmani atara mi. Inu sọnọ kọ kọng nu ẹrẹwyuẹ nga ba, inu sọnọ kọ nu nọ umani ashi ba.
\v 38 Ighang nga ci yọ ki ikwyi nu ba, ki nu ta ma nu aipang kukushi aghọmani Ate tuma ba.
\v 39 Inu sọ shuwa upii Ọnọng, kọ ukyoo nu ki ikwyi ki peni ọkyuọ utaa amaa kidẹ bọ. Idibi ipii Ọnọng iyọ ki tara mi.
\v 40 Kindọ ni inu tọrọ nọ ba ọkọ shi mi kọ peni ọkyuọ.
\v 41 “Imẹ ka ta yira mi ujọọ kukushi shi bajiya ba”
\v 42 Ki imẹ ye nu, iva sa ye si inu shi nu nọ uyoo Ọnọng kidẹ ikwyi nu ba.
\v 43 Imẹ ba kidẹ nọ uca Ate mi, inu ta yira mi ba, ipeni ace aghọ ba kidẹ nọ uca ẹrẹkwyuẹ nga ni, inu ki yira nga.
\v 44 Nanyi kọ ni inu ki ma aipang ka akyua umani inu wang peni ujọọ kushi ace nu, ni inu ta wang nọ peni ujọọ mani ukunu kukushi Ọnọng umani anga shi ka ayayu nga ba?
\v 45 Inu ma tẹri si iki kyaa ashuwa nu kukushi Ate yi ba. Aghọ ki kyaa ashuwa nga shi iMusa, umani inu sa ikwyi si anga ki foo nu.
\v 46 Tẹri si inu ma aipang ni iMusa ni, inu ta kọ ma aipang ni imẹ, ki iMusa wọọ kaya ẹrẹkwyuẹ mi.
\v 47 Ipeni inu ra ma nu aipang kini imumani awọọ ba ni, nanyi kọ ni inu ki ma aipang kọ?”
\c 6
\s1 IYesu cee ajiya Araji ushọ Atọ
\r (IMat 14.13-21; IMar 6.30-44; ILuk 9.10-17)
\p 
\v 1 Awii ra ya woru bọ ni, iYesu va bulu ki kyaa udaa ugẹẹ ẹrẹyẹma aGalili, aka ba yọrọ wọ si ẹrẹyẹma aTibariya.
\v 2 Ikir bajiya lite nọ uyii nga, ka anu amaa nọ uma umani asọ ju na adumu.
\v 3 IYesu va kila nga izizẹ ki cica kina atina nga.
\v 4 Ka akyakyua ri ni, agya ubulu ya sọ ba ayayo.
\v 5 IYesu ya sang ẹrẹkwyuẹ ki nu ikir bajiya ni, aba tẹri iFilibus si, “Abi wọ ni ayọ ki ghẹ imila umani iki maa ajiya ri kọ?”
\v 6 IYesu ghulu iFilibus kindọ ka amara nga wọ ka aye imumani aki ju.
\p 
\v 7 IFilibus ba yira nga ki tẹri si, “Ufẹ ipii itin aghọtina ki maa yọ na aghẹ imila umani kwinga ki peni na zẹẹ ba.”
\p 
\v 8 Aghaye kidẹ atina nga aghọnọ uca si Andrawus, anayuru iSiman iYahaya va tẹri iYesu si,
\v 9 “Ace ananọ wẹ na asi ni agbọ ubiredi itọ kina itagbo ipai. Ikẹmbọ wọ yi idi ima ki ju na ajiya ri kindii?”
\p 
\v 10 IYesu ba tẹri bọ si, “Inu sa ajiya ka acica.” Uka ni ọbọng shiya nagigang. Aghẹmẹ va cica, afuma agha araji ushọ atọ.
\v 11 IYesu ba kpaa agbọ ubiredi, aya kpẹẹ usa Ọnọng izaa ni, aba kau aghọmani aci, aba bọ nadidu imumani iki maa bọ kọ. Kindii wọ na aju ni itagbo.
\v 12 Aya la ki suu ni, aba tẹri atina nga si, “Inu curu awo na ashẹ ka aba bra yọ ba.”
\v 13 Atina va curu awo ubiredi ki tii ka ọkọọ ushọ nọ upai, awo umani ashẹ kidẹ agbọ ubiredi utọ kọ umani ajiya kpẹẹ ula.
\p 
\v 14 Ajiya ya nu amaa imu wo ica ni iYesu ju ni, aba tẹri si, “Aipang, anga shi aghọ pii kọ ọtọ Ọnọng umani asi aki ba asing.”
\v 15 IYesu ya kpẹlẹ si, ajiya wang kpaa nga ni ẹrẹkyuọ ka ama nga ẹrẹgọm ni, aba vuu nga aya izizẹ kayu nga.
\s1 IYesu Kyeng kaya na Amusumu
\r (IMat 14.22-23; IMar 6.45-52)
\p 
\v 16 Ughẹ ya kpaa ni, atina iYesu ka sang ki kyabọ ẹrẹyẹma.
\v 17 Akyua ra ni uka ya sang uba ni itii, iYesu sa kọ sang nga uba ukushi bọ ba. Atina va ghila bọ idẹ ọgbọlọ ki kpẹnẹ ubulu kyabọ aKafarnahum.
\v 18 Ẹrẹyẹma kpẹnẹ utiyagha ka uce uwuru ẹrẹkyuọ sọ tẹ.
\v 19 Aya tẹ ki fuma amel atai ko anari ni, aba nu iYesu na akyeng kaya na amusum, asọ ba nga ayayo kina ọgbọlọ. Atina va kọọ ẹrẹbata.
\v 20 IYesu va tẹri bọ si, “Imẹẹ, ba kọọ ẹrẹbata ba.”
\v 21 Aba tọ yira nga kidẹ ọgbọlọ. Kidẹ anakyua ni ọgbọlọ nga fuma uka umani aki kyabọ kọ.
\s1 Ajiya Wang IYesu
\p 
\v 22 Ikyua ya yẹẹ na ushẹ bajiya na aci ka uhwo udaa ugẹẹ ẹrẹyẹma ba kpẹlẹ si ọgbọlọ uye wọ ba ukaa, akpẹlẹ si iYesu ta ghila nga ọgbọlọ kina atina ba, atina nga bọ kyaa kayu bọ.
\v 23 Ace agbọlọ umani aba ka aTibariya tara kọ ka ayayo kina uka umani ajiya la ubiredi wọ kọ utumu umani akpẹẹ usa Ọnọng izaa.
\v 24 Ajiya ya nu ni iYesu kina atina nga shi bọ ya kọ ukaa ba ni, aba ghila bọ ọgbọlọ ki kyabọ aKafarnahum na asọ wang iYesu.
\s1 IYesu nga shi Ubiredi uma Ukyuọ
\p 
\v 25 Aya nu nga ka udaa ugẹẹ ẹrẹyẹma ni, aba ghulu nga si, “Aghọmẹẹ, agba awii wọ ni ingọ ki ba wọ?”
\p 
\v 26 IYesu va yira bọ si, “Aipang, imẹ sọ tẹri nu, inu sọ wang ka inu la ubiredi ki suu, ba si inu kpẹlẹ si amaa uma usa uwo ica ni imẹ ju ba.
\v 27 Inu ba duma na uwang imila ni ika bra yọ ba, inu ju utina kaya imila umani ishi yọ na amara ba inga uma ọkyuọ utaa amaa. Imila umani Anọ Ajiya ki ma nu yidii. Ka aya Anọ Ajiya wọ ni Ate Ọnọng kọ sa amaa uyeni nga uyira nu.”
\p 
\v 28 Ajiya ba ghulu iYesu si, “Ikẹmbọ na ayọ ki ju ka ayọ hwura uma umani Ọnọng wang?”
\p 
\v 29 IYesu ba yira bọ si, “Imumani Ọnọng wang si inu ju yẹ, inu ma aipang ka aghọmani atuma.”
\p 
\v 30 Ajiya va ghulu iYesu si, “Aligba amaa uwo ica nga ni inu ki ju ka ayọ nu ni ayọ ma aipang ni ingọ. Ikẹmbọ ni ingọ ki ju?
\v 31 Ananirakpẹẹ bayọ la umanna ka aghumu, kọnọ umani awọọ upii Ọnọng si, “Ama bọ imila ka ayaya ka ala.’”
\v 32 IYesu ba yira bọ si, “Aipang, imẹ sọ tẹri nu, iMusa nga ma nu imila ra ka ayaya ba, Ate mi nga ka ma nu imila aipang ka yaya.
\v 33 Imila Ọnọng yọ ka shulu ka ayaya na asing ọkyuọ.”
\p 
\v 34 Aba tẹri nga si, “Aghọ aghaghẹ, ka ma ayọ ighọ imila ri kwaligba awii!”
\p 
\v 35 IYesu yira ki tẹri bọ si, “Imẹ shi imila uma ọkyuọ, aghọmani aba ukushi mi ni, aki sọ kọọ nga idafo ba, aghọmani ama aipang ni imẹ ni, aki sọ kọọ nga idafo na amusum ba.
\v 36 Kọnọ umani imẹ tẹri nu ni, inu nu mi, inu ta ma nu aipang ba.
\v 37 Nadidu aghọmani Ate ma mi ni, aki ba ukushi mi, aghọmani aba ukushi mi ni, iki kla mi nga ba.
\v 38 Ka imẹ shulu mi ka ayaya ki imẹ ba ju uyoo mi ba, uyoo aghọmani a tuma mi wọ.
\v 39 Uyoo aghọmani a tuma ni, imẹ ba vulu agha ayaye kọ kidẹ aghọmani a ma mi ba, imẹ sang bọ ka awii usang asing.
\v 40 Ka uyoo Ate mi wọ si, nadidu aghọmani asọ kra Anọ ni, ki va ma aipang ni nga ni, ashi na ọkyuọ utaa amaa, imẹ ki va sang nga awii usang asing.”
\p 
\v 41 AYahudawa va duma kidẹ ikwyi bọ ni iYesu ka atẹri si, “Imẹ shi imila ni ishulu ka ayaya.”
\v 42 AYahudawa si, “Ba iYesu wẹ ri ba, anọ iYusufu aghọmani ayọ ye ate nga kina ayuru nga nadidu ba? Ikẹmbọ sa ka akyakyua ri na asi, ‘Imẹ shulu ka ayaya’?”
\p 
\v 43 IYesu ba yira bọ si, “Inu shee uduma ki ikwyi nu kina ace nu.
\v 44 Ba aghọmani aki bra uba ukushi mi, in ba si Ate umani a tuma mi nga waa nga ba, imẹ ki va sang adidu ajiya ka awii usang asing.
\v 45 Awọọ kidẹ ẹrẹwọ aghọ pii kọ ọtọ Ọnọng si, ‘Nadidu bọ ni Ọnọng nga ki mẹẹ bọ.’ Nadidu aghọmani akọọ, ki va mẹẹ kukushi Ate ni, aka ba ukushi mi.\x - \xo 6.45 \xt Ish 54.13.\x*
\v 46 Ba aghọmani akọ nu Ate in ba si aghọmani a kunu kukushi Ọnọng ba, agna kọ nu Ate.
\v 47 Aipang ni isọ tẹri nu, nadidu aghọmani ama aipang ni ashi nọ ọkyuọ utaa amaa.
\v 48 Imẹ shi imila uma ọkyuọ.
\v 49 Ananirakpẹẹ nu la umanna ka aghumu, nadidu kindọ ni akpuru bọ.
\v 50 Ni imila umani ika shulu ka ayaya ka nadidu aghọmani ala ni, aki kpoo nga ba.
\v 51 Imẹ shi imila umani ika shulu ka ayaya. Nadidu aghọmani ala imila ri ni, aki peni ọkyuọ ki ta kọ sang asing. Imila ri ni inọma ẹrẹnọma mi yọ, ingọ umani imẹ ki ma ka asing peni ọkyuọ.”
\v 52 AYahudawa ba tee aghọ linang kina ace bọ, asọ ju si, “Nagyi wọ ni ajiya ri ki ma ayọ inọma ẹrẹnọma nga ka ayọ la?”
\p 
\v 53 IYesu ba tẹri bọ si, “Aipang, imẹ sọ tẹri nu inkini inu ta la nu inọma ẹrẹnọma Anọ Ajiya ki sa ayi nga ba ni, inu shi nu nọ ọkyuọ kidẹ nu ba wudu.
\v 54 Nadidu aghọmani asọ la inọma ẹrẹnọma mi, na asọ va sa ayi ẹrẹnọma mi ni, ashi na ọkyuọ utaa amaa, imẹ ki sang nga kọ sang asing.
\v 55 Ka inọma ẹrẹnọma mi ni, imila aipang yọ, ayi mi ni, uma usa aipang yọ.
\v 56 Nadidu aghọmani asọ inọma ẹrẹnọma mi, na asọ va sa ayi mi ni, ashi kidẹ mi, imẹ kọ shi kidẹ nga.
\v 57 Kọnọ umani Ate akyuọ tuma mi ni, kaya nga wọ ni imẹ sọ cẹ wọ, kindii wọ ni aghọmani akpaa mi kina imila nga yọ ni, aki peni ọkyuọ kaya mi.
\v 58 Imẹ shi imila umani ishulu ka ayaya. Ananirakpẹẹ nu la umanna, nadidu kindọ ni, akpuru bọ, nadidu aghọmani ala imila ri ni, aki peni ọkyuọ ki ta kọ sang asing.”
\p 
\v 59 IYesu tẹri uma ri nadidu ka akyua umani asọ mẹẹ kidẹ ọkọ takwyuẹ aYahudawa ka aKafarnahum.
\s1 Iwọọ Ọkyuọ ni ishi yọ na amara ba
\p 
\v 60 Ace aghọ bọ na pam kidẹ aghọyii nga ya kọọ kindọ ni, aba ju si, “Udii upii ri ni, ọlọ shiya, inga ki bra uyira wọ?”
\p 
\v 61 IYesu ye si aghọyii nga sọ pii na ace bọ kaya umẹẹ nga ni, aba tẹri bọ si, “Udii umẹẹ bra nu ikwyi wọ?
\v 62 Nagyi wọ ni inu kọọ wọ ki ikwyi nu insi inu nu Anọ Ajiya na asọ kila nga ọka umani aba wọ?
\v 63 Aghing nga ka ma ọkyuọ. Ẹrẹnọma shi wọ na akyuọ uju ima ba. Upii ni imẹ tẹri nu ni, aghing nga kina ọkyuọ.
\v 64 Ace aghọ bọ shi wọ kidẹ nu na ata ma bọ aipang ba.” Ko kpaa ka akyua ni, iYesu ye aghọmani ata ma bọ aipang ba, kina aghọmani aki gbura na wọ.
\v 65 IYesu ba khimi utẹri si, “Uwu sa ni imẹ tẹri nu si, ‘Ba aghọmani aki bra uba ukushi mi, sa Ate ma nga akyuọ.’”
\p 
\v 66 IYesu ya kpẹẹ upii nga ni, ajiya na pam kidẹ aghọyii ya nga, asọ yii bọ nga ba.
\p 
\v 67 IYesu ba ghulu ushọ na apai si, “Inu wang kọ sang nu?”
\p 
\v 68 ISiman iBitrus ba yira si, “Ate, ukushi inga wọ na ayọ ki kyaa? Ingọ shina upii nọ uka ma ọkyuọ umani ushi wọ na amara ba.
\v 69 Ayọ ma aipang, ayọ va ye si ingọ shi agha upipar Ọnọng ra.”\x - \xo 6.69 \xt IMat 16.16; IMar 8.29; ILuk 9.20. \x*
\p 
\v 70 IYesu ba yira bọ si, “Imẹ hwiya aghọ ushọ na apai, aghaye nu ni ishẹẹ wọ.”
\v 71 Asọ yeni si iYahuda, anọ iSiman Iskariyoti, ka anga ki gbura nga kọ, ka anga ni aghaye nga kidẹ ushọ na apai.
\c 7
\s1 Anayuru IYesu ta ma bọ Aipang ni nga ba
\p 
\v 1 Aya sang ni iYesu ba kigor kidẹ aGalili, ni ata wang nga ukyeng kidẹ aYahudiya ba, ka aYahudawa na shiya kọ akadu wang pii nga kọ.
\v 2 Awii usra agya nọ uzọọ aYahudawa ya sang ju,
\v 3 ni anayuru iYesu ba tẹri nga si, “Ushi ọdọma ni ingọ vuu kyang aYahudiya ka aghọyii ngọ ya nu uma uwọ ica nọ ọsọ ju.
\v 4 Nadidu aghọmani awang na aye nga nagigang ni, aki shọ nga ni uma na asọ ju ba. Insi ingọ su ju uma ri ni, yeni ẹrẹkwyuẹ ngọ ka ajiya ye ngọ.”
\v 5 Ka ibọ anayuru iYesu ta ma bọ aipang ni nga ba.
\v 6 Ni iYesu ba tẹri bọ si, “Akyua mi kọ sang wọ ju ba, ukushi nu ni kwaligba akyua shi na kikẹ.
\v 7 Inu ni ashi ki bra wọ tọọ nu nga ba, imẹ ni ashi ta wang mi nga ba ka imẹ ka tẹri utina akakiya ni aka ju.
\v 8 Inu wor kya nu uka usra agya. imẹ ta ki kya mi ba, ka akyua mi kọ sang wọ ju ba.”
\v 9 IYesu ya kpẹẹ utẹri bọ udibi uma ri ni, ava zọnọ laa nga ka aGalili.
\s1 IYesu kya usra agya ka Urushalima
\p 
\v 10 Anayuru nga ya kpẹẹ uworu kya bọ uka usra agya ni, iYesu va woru kọ uyuyi, ata woru nga ka ayayẹ ba.
\v 11 AYahudawa su wang nga kọ ọkọ usra agya, asọ ghulu si, “Abi kọ ni ajiya ri shi kọ?”
\v 12 Kidẹ ikir bajiya ni ajiya sọ pii na ace bọ kaya iYesu kọ uyuyi. Ace aghọ bọ sọ tẹri si, “Ajiya adaduma nga.” Ace aghọ bọ si, “Kayi, asọ dor ajiya wọ.”
\v 13 Ni ba aghọmani abra utẹri ila iYesu kidẹ bajiya ba, ka asọ hwiri ẹrẹbata aYahudawa.
\s1 IYesu Mẹẹ kaya Usra Agya Uzọọ
\p 
\v 14 Aya fuma abiyatẹ usra agya ni, iYesu va ghila nga idẹ ọna Ọnọng ki kpẹnẹ umẹẹ.
\v 15 Agha akakọng aYahudawa va woo ica ki ghulu si, “Ikẹmbọ sa na ajiya ri ye uma nagigang ba si akọ kya ọkọ upila iwọọ ba?”
\v 16 IYesu va yira bọ si, uma umani imẹ sọ mẹẹ ni, unga mẹ bọ ba, unga aghọmani atuma mi bọọ.
\v 17 Nadidu aghọmani hwiya uju ima ni Ọnọng wang ni, aki ye si umẹẹ mi ba kọ ukushi Ọnọng, ba ukushi mi ba.
\v 18 Aghọmani amẹẹ uma ẹrẹkwyuẹ nga ni, awang jọọ ẹrẹkwyuẹ nga kọ. Ni aghọmani asọ jọọ aghọmani atuma mi ni, anga shi agha aipang, ni ashi nga ni utaa aipang ba.
\v 19 iMusa nga mẹẹ nu ba? Ni ba ace aghọmani asọ yii umẹẹ ba?”
\v 20 ajiya va yira si, “Ingọ shi nọ ushẹẹ kidẹ ngọ. Inga bu bọ wang pii ngọ kọ?”
\v 21 IYesu va yira bọ si, “Imẹ ju ima uwoo ica iye, ni inu woo ica nadidu nu.
\v 22 IMusa ma nu upii si inu sho aghumu, anga kyọ uju ba, ananirakpẹẹ bọ. Kindọ ni unu ka sho ananọ aghumu ka awii uwuru aYahudawa.
\v 23 In kini aki bra usho aghumu na anọ ka awii uwuru aYahudawa ni ka aju imumani umẹẹ iMusa tẹri ni, ikẹmbọ sa ni inu kọọ anaa wọ nọ umani imẹ ma ẹrẹnọma ọkyuọ ka awii uwuru?
\v 24 inu ba tẹri ajiya ashuwa ni ima ni inu nu ni ica ba, inu tẹri ajiya ashuwa ni ima ushi na birbọ.”
\s1 IYesu nga shi Aghọfoo?
\p 
\v 25 Na ace ajiya Urushelima tẹri si, “Ajiya ri nga na su wang na wang pii nga kọ ri ba”
\v 26 Awẹ ni, asọ pii ka ayaye, ata tẹri bọ nga ice ima ba. Ta agha ite kọ yira si anga shi aghọfoo ni?
\v 27 Uwẹ ni, ayọ ye uka ni ajiya ri kunu kọ, akyua ni aghọfoo aipang ki ba kọ ni, ba aghọ ki ye uka ni a kunu kọ ba.”
\v 28 IYesu sọ mẹẹ kidẹ ọna Ọnọng ni, ava sang ẹrẹyuẹ si, “Inu ye mi, inu va ye uka ni ikunu kọ. Ita bami ni ẹrẹkyuọ ẹrẹkwyuẹ mi ba. Aghọ utuma mi ni agha aipang nga, anga ni inu ta ye nu nga ba.
\v 29 Imẹ ni iye nga, ka ukushi nga kọ ni imẹ kunu kọ, anga tuma mi.”
\v 30 IYesu ya tẹri udibi uma ri ni, ajiya nga va wang utra ukpẹnẹ nga. Ni ba aghọ piya nga ba, ka akyua nga ta kọ ju wọ ba.
\v 31 Kindọ ni ajiya na pam va ma aipang ni iYesu, na asọ ju si, “Ni, akyua ni aghọfoo ki ba ni, aki ju uma uwo ica ka acẹẹ uma ni ajiya ri ju ni?”
\s1 Aghite aYahudawa wang kpẹnẹ IYesu
\p 
\v 32 AFarisiyawa kọọ uma ni ajiya sọ tẹri kaya iYesu, ni afirist akakọng kina aFirisiyawa va tuma aghọ sha ọna Ọnọng sa ya kpini nga.
\v 33 IYesu yira bọ si, “Akyua ni iki ci kini nu si na zẹẹ, akpẹẹ ni iki vuu mi ukushi aghọ utuma mi.
\v 34 Inu ki wang mi, ni inu ta ki nu mi nga ba. Uka ni shiya ni uta ki bra nọ uba ba.”
\v 35 AYahudawa va pii na ace bọ ki ju si, “Abi wọ na ki kyaa kọ na ayu ta ki peni yi nga ba? Ta aki kyaa ukushi aYahudawa na ku furu bọ na shi kina aghọmani ashi bọ aYahudawa ba ni, ka aya mẹẹ aghọmani ashi bọ aYahudawa ba ku kadu ni?
\v 36 Ikẹmbọ na asọ yeni na si, ‘Inu ki wang mi, ni uta ki peni mi nga ba’? Ikẹmbọ na asọ yeni si “Uka ni imẹ shiya ni uta ki bra nọ uba ba’?”
\s1 Uta anyu Amusum uma Ọkyuọ
\p 
\v 37 Awii upra usra agya, angọ shi awii aghaghẹ usra agya ni, iYesu tara ki sang ẹrẹyuẹ ki ju si, “Nadidu aghọ kọọ usa amusum na ba ukushi mi ka aba sa.
\v 38 Nadidu aghọ ma aipang ni me ni, ‘Avọ mẹẹ amusum umẹẹ ọkyuọ ki kunu kidẹ ikwyi nga,’ Kọnọ umani upii Ọnọng tẹri ni.”
\v 39 IYesu sọ pii kaya aghing Ọnọng, anga ni aghọ ma aipang ni nga ki yira, ka agha akyua ri ni a ta kọ ma bọ aghing Ọnọng ba, ka ata ku jọọ bọ iYesu ba.
\s1 Ajiya wang Igẹr kaya IYesu
\p 
\v 40 Ajiya ya kọọ udi upii ni iYesu tẹri ni, ava ju si, “Aipang, adi aghọ ri nga si aghọ pii kọ ọtọ Ọnọng ra.”
\v 41 Ace aghọ bọ va ju si, “Adi aghọ ri nga si aghọfoo.” Ki ta ka kyua ri, aghọfoo ri ni aGalili nga na kunu wọ?
\v 42 Ba upii Ọnọng tẹri si aghọfoo ki kunu kidẹ ute uDauda ba?” Aki va kunu ka aBaitalami, anifọng umani uDauda kunu kọ ba?”
\v 43 Anyu bajiya va kau kaya iYesu.
\v 44 Ace aghọ bọ wang kpẹnẹ nga, ba aghọmani abra piya nga ba.
\s1 Utaa Aipang Aghọ ite AYahudawa
\p 
\v 45 Aghọ sha ya vuu bọ ni, afirist akakọng kina aghite aFarisiyawa va ghulu bọ si, “Ikẹmbọ sa ni uta ba nu ni nga ba?”
\v 46 Aghọ sha nga va yira si, “Ba ajiya na akọ pii kina ajiya ri ni ba.”
\v 47 AFarisiyawa va tẹri aghọ sha si, “Inu ni akọ dor nu wudii?
\v 48 Ta ace aghọ shi wọ kidẹ aghọ ite ko aFarisiyawa ni ama aipang ni nga?
\v 49 Ni ikir bajiya ri ni ata ye bọ ice ima kọ umẹẹ iMusa ba, ibọ ni agha anyu ababi bọ.”
\v 50 INikodimus aghọmani akya ukushi iYesu ka akyua, agha aye kidẹ bọ, tẹri bọ si, \x - \xo 7.50 \xt IYah 3.1-2.\x*
\v 51 Kọ umẹẹ iMusa ni ayọ taki bra bọ uwa ajiya ashuwa ba, sa akọọ ka anyu nga, ka ye ima ni asọ ju.”
\v 52 Ava yira nga si, “Ingọ ni agha aGalili nga na? Kra idẹ upii Ọnọng kọ nu, ba ace aghọ pii kọ ọtọ Ọnọng na ki ba ka aGalili ba.”
\s1 Ayiri na akpẹnẹ kọ Wang Aghẹmẹ
\p 
\v 53 Kwinga va kyaa aca.
\c 8
\p 
\v 1 Ni iYesu va wor kya izizẹ na ashẹ uzaitun.
\v 2 Ni kikyuating ni iYesu va ghila nga idẹ ọna Ọnọng. Ajiya nadidu va ba bọ ukushi nga, ava kọ cica na asọ mẹẹ bọ.
\v 3 Na aghọmẹẹ iMusa kina aFarisiyawa va ba na yiri na akpẹnẹ nga na anyẹ kina aghẹmẹ. Ava sa nga na tara ka fatẹ bọ.
\v 4 Na ava ju iYesu nga si, “Aghọmẹẹ, ayiri ri ni akpẹnẹ nga na nyẹ kina aghẹmẹ.
\v 5 Ni, umẹẹ iMusa tẹri si ataa ighọ ri na atii sa akpuru bọ. Ni ingọ ni ingọ tẹri si ikẹ?”
\v 6 Aghulu nga kindi ri ka mra nga, ka peni uvulu na ki kya ni ashuwa nga. Ni iYesu va kpikpo, ki wọọ iwọọ ki ẹrẹbọ na anivọ nga.
\v 7 Aya dẹẹ kọ ghulu iYesu nga ni, ava sisang ki tara ki ju bọ si, “Nadidu aghọ na ashi nọ uvulu ba ni akyọ uta ayiri ri nọ utii.”
\v 8 Ni iYesu va kpikpo ki dẹẹ kọ wọọ ki ẹrẹbọ.
\v 9 Aya kọọ kindọ ni, ava dẹẹ kọ sang bọ kọ ukadu ka yila ye, kọ kpaa ka aghọ ite bọ ki ta agha azazi bọ, ki she iYesu nga ka yu nga, kina ayiri na tai kite nga.
\v 10 Ni iYesu va sang ki tara, ki ghulu nga si, “Ayiri, abi na ashi kọ? Ba aghọ na awa ngọ ashuwa ba ni?”
\v 11 Ava yira si, “Ba aghọ ba.” ni iYesu ju nga si, imẹ ma ta wa ngọ nga ashuwa ba. wor, ni ba khimi uvulu kọ ba.”
\s1 IYesu nga shi Uyeri Ashi
\p 
\v 12 IYesu va khimi upẹni na ajiya si, “Imẹ shi uyeri ashi. Aghọ yii mi ta ki kyeng nga kidẹ itii ba, aki peni uyeri ọkyuọ.”
\v 13 Na afarisiyawa va ju iYesu nga si, “Ingọ sọ yeni ẹrẹkwyuẹ ngọ shi aipang nga ni ingọ yira kọ ba.”
\v 14 IYesu va yira bọ si, “Ko ni imẹ yeni ẹrẹkwyuẹ mi ni, uyira mi ni aipang nga, ki imẹ ye uka ni ukunu kọ, kini uka ni iki kya mi kọ. Inu ta ye nu uka ni ikunu kọ ba kini uka ni ikya mi kọ ba.
\v 15 Unu ka kyua ashuwa kọ kyoo ajiya. Imẹ ni ika ju mi ace aghọ ashuwa ba.
\v 16 Ko ni imẹ ki ju ashuwa ni, ashuwa mi ni aipang nga, ki imẹẹ kayu mi ba, ka Ate mi na atuma mi shi kini mẹ.
\v 17 Kidẹ umẹẹ nu ni awọọ si, inkini agha pai tẹri ima iyeng ra ni, iyiya yọ na yira upii bọ ka aipang nga.
\v 18 Imẹ ni ika yeni ẹrẹkwyuẹ mi, Ate aghọ tuma mi ni anga shi agha ipai.”
\v 19 Ava ghulu nga si, “Abi wọ ni Ate ngọ ra shi kọ?” iYesu va yira bọ si, “Inu ta ye mi nga ba, inu ta va ye nu Ate mi ba. Inu ta ye mi ni, Inu ta ye Ate mi.”
\v 20 IYesu tẹri upii ri ka akyua na asọ mẹẹ ka ayayo kọnọ uka ni aka kyo ufẹ na aka ma kidẹ ọna Ọnọng. Kindọ ni ba aghọ ukpẹnẹ nga ba, ka akyua nga ta kọ ju wọ ba.
\s1 Uka ni iki Kya mi ni inu ta ki bra ukyaa ba
\p 
\v 21 Ni iYesu va khimi utẹri ajiya nga si, “Imẹ ki wor, inu ki wang mi, inu ki va kpuru nu kidẹ uvulu nu. Uka ni iki kya mi ni, inu ta ki bra nu kyaa ba.”
\v 22 Udi sa ni agha ite aYahudawa va ju si, “Ushi ni, Aki pii ẹrẹkwyuẹ nga wọ nu nga ni a ju si, ‘Uka ni iki kya mi ni, inu taki bra nu kyaa ba’?”
\v 23 Ni iYesu va lite nọ tẹri bọ si, “Inu shi ka ẹrẹbọ, imẹ ni ikunu ka ayaya kọ. Inu ni anga ashi ri bọ, imẹ ni anga ashi ri nga ba.
\v 24 Ọwọ sa ni imẹ tẹri nu si inu ki kpuru nu kidẹ uvulu nu. Ka insi inu ta ma nu aipang si aghọ ni imẹ tẹri nu si imẹ shi ba ni, inu ki kpuru nu kidẹ uvulu nu.”
\v 25 Ibọ va ghulu iYesu nga si, “Ingọ ni inga”? IYesu va yira bọ si, “Imẹ shi aghọ ni imẹ tẹri nu kọ kpaa ka akyua.
\v 26 Uma shi wo na pam ni imẹ ki bra utẹri kaya nu, ki imẹ ju nu ashuwa. Ni imẹ su tẹri ashi uma ni imẹ kọng kukushi aghọ na tuma mi kayu wọ, na asọ tẹri aipang kọ.”
\v 27 Ajiya nga ta kpẹlẹ bọ si asu pii ni bọ kaya Ate ba.
\v 28 Ọwọ sa ni iYesu ju bọ si, “Akyua ni inu ki zẹẹ Anọ Ajiya ni, akyua ra kọ ni inu ki kpẹlẹ si imẹ shi nga. Inu ki kpẹlẹ si ita shi mi kọ uju kwikẹ nọ ubra ẹrẹkwyuẹ mi ba, ka imẹ sọ tẹri ima ni Ate tuma mi kọ.
\v 29 Aghọ tuma mi shi kini imẹ, ata shee mi nga kayu mi ba, ka imẹ sọ ju imumani awang kọ agba akyua.”
\v 30 Akyua ni iYesu sọ tẹri udibi uma ri na ajiya napam va ma aipang ni nga.
\s1 Anọ Ibrahim
\p 
\v 31 IYesu va tẹri aYahudawa na ma aipang ni nga si, “In kini inu ko umẹẹ mi ni, inu ni aghọyii mi bọ anga aipang.
\v 32 Ni inu ki ye aipang, aipang ki ma nu ulang.”
\v 33 Ava yira nga si, “Ayọ ni anọ Ibrahim bọ, ayọ ta kọ shi yi agira ace aghọ ba. Ni ikẹmbọ sa ni ingọ sa ju si ayọ ki peni ulang ni?”
\v 34 IYesu va yira bọ si, “Aipang, isọ tẹri nu si, nadidu aghọ na asọ ju uvulu ni agira uvulu nga.
\v 35 Agira ka ci nga ka aca ki ta kọ sang asing ba, ka anọ ni anga ọna nga ki ta kọ sang asing.
\v 36 Kindii ni insi anọ ma nu ulang ni, inu ki peni ulang unga aipang.
\v 37 Imẹ ye ni inu ni anọ Ibrahim bọ, ni inu wang pii mi kọ, ka inu ta yira nọ umẹẹ mi ba.
\v 38 Imẹ sọ tẹri nu imumani imẹ nu kukushi Ate mi, ni inu sọ ju imumani inu kọng kukushi ate nu.”
\s1 Ishẹẹ nga shi Ate nu
\p 
\v 39 Ava yira nga si, “Ibrahim nga shi ate ba yọ.” Ni iYesu va yira bọ si, “Awasi inu na anọ Ibrahim bọ ni, inu ta kọ ju uma umani Ibrahim ju.
\v 40 Imẹ ni ajiya nga aghọ utẹri aipang anga ni imẹ kọng kukushi Ọnọng, ni inu wang pii mi kọ. Ibrahim ta ju idi ima ba.
\v 41 Kindii ni inu sọ ju imumani ate nu ka ju wọ.” Ni aYahudawa va ju si, “Ayọ ni anọ useshi bọ ba. Ọnọng nga shi Ate ba yọ, anga ashi kayu nga Ate na ayọ shi ni nga.”
\v 42 IYesu ju bọ si, “Ata ju si Ọnọng nga shi Ate nu ni inu ta kọ yoo mi, ka ukushi Ọnọng kọ ni imẹ kunu kọ, agha akyua ri ni imẹ wẹ kọ kẹẹ. Ita ba mi nọ ubra ẹrẹkwyuẹ mi ba, Ọnọng nga tuma mi.
\v 43 Ikẹmbọ sa ni inu ta kpẹlẹ nu upii mi ba? Ka inu ta bra nu ọkọng umẹẹ mi ba.
\v 44 Inu ni anga ate nu Ishẹẹ bọ, ni inu wang ju imumani awang. Inga ni aghọ pili nga kọ kpaa ka akyua awang nga aipang ba, ba aipang kidẹ nga ba. Akyua na asọ tẹri atẹr ni asọ yeni ighọ nga kọ, ka inga ni agha atẹr nga, ate atẹr nga.
\v 45 Ni imẹ sọ tẹri aipang, inu ta yira mi nga ba.
\v 46 Inga kidẹ nu ki bra uyeni uvulu nga? In kini aipang nga ni imẹ sọ tẹri ni, ikẹmbọ sa ni inu ta ma nu aipang ni imẹ ba?
\v 47 Aghọ na ashi angọ Ọnọng ni aka hwiri imumani Ọnọng tẹri. Ni inu ta hwiri imumani Ọnọng tẹri ba, ka inu ni angọ Ọnọng bọ ba.”
\s1 IYesu Cẹẹ Ibrahim nga
\p 
\v 48 AYahudawa va yira nga ki ju si, “Aipang nga nọ umani, ayọ tẹri si ingọ ni aghọ aSamariya nga aghọ shi nu ushẹẹ ba?”
\v 49 IYesu va yira bọ si, “Imẹ ni aghọ shi nọ ushẹẹ nga ba. Imẹ sọ ma Ate mi ughọghẹ wọ, ni inu su vuu nọ ughọghẹ mi kọ.
\v 50 Imẹ sọ wang ujọọ ẹrẹkwyuẹ mi ba. Ace aghọ shi kọ na nga sọ wang mi wọ, anga shi aghọ tẹri ashuwa.
\v 51 Aipang, imẹ sọ tẹri nu, aghọ na sọ yii umẹẹ mi ni ata ki kpoo nga ba.”
\v 52 Na aYahudawa va ju nga si, “Ka akyua ri ni, ayọ ma aipang si ingọ shi nọ ushẹẹ. Ibrahim kina Atina Ọnọng kọ kpuru bọ, ni ingọ si, ‘Nadidu aghọ na asọ yii umẹẹ mi ni ata ki kpoo nga ba.’
\v 53 Ingọ kpaa kọnọ ucẹẹ ate bayọ Ibrahim ni? Inga ku kpoo, kindọ wọ ni aghọ pii kọ ọtọ Ọnọng kọ kpuru bọ. Ingọ kpaa kini ingọ ni ingaa ni?”
\v 54 IYesu yira bọ si, “Inkini imẹ jọọ ẹrẹkwyuẹ mi ni, udu ujọọ ra ni uma wọ ice ima ba. Aghọ na asọ jọọ mi ni anga shi Ate mi, aghọmani inu sọ tẹri si anga shi Ọnọng nu.
\v 55 Inu ta ye nu nga ba, ni imẹ ye nga. Awasi imẹ tẹri nu si imẹ ta ye mi nga ba ni, imẹ ta kọ tee agha atẹri kini inu ni. Ni imẹ ye nga, imẹ ka va ju imumani wang si imẹ ju.
\v 56 Ate nu Ibrahim wẹ ni akọọ ikwyifu nagigang ka apeni unu ufọnọ mi, anu wọ, ki kọọ ikwyifu.”
\v 57 AYahudawa va tẹri iYesu si, “Ighọ wẹ ni uta kọ fuma ngọ anyi ishi itọng ba, nọ sọ ju si ingọ ye Ibrahim.”
\v 58 IYesu tẹri bọ si, “Aipang, imẹ sọ tẹri nu, ata kọ jee Ibrahim nga ni, imẹ shi kọ.
\v 59 IYesu ya tẹri udii upii ri ni ava kpaa atii na wang taa nga kọ. Ni iYesu va sọ ẹrẹkwyuẹ nga, ki kunu nga kidẹ ọna Ọnọng.
\c 9
\s1 IYesu Ma Aghọmani Ajee nga na ashi Afoo Ukyoo Uka
\p 
\v 1 IYesu sọ wor wudu ni, ava nu ace ajiya ni kọ kpaa kọ ujee nga ni afoo nga.
\v 2 Na aghọyii nga va ghulu nga si, “Aghọmẹẹ, uvulu inga wọ sa ni ajee ajiya ri na shi afọọ ri? Uvulu nga kọ, ta uvulu aghọjee nga kọ?”
\v 3 Ni iYesu va yira bọ si, “Basi ajiya ri kọ aghọjee nga vulu ba, ni ajee nga afoo ka yeni ubra Ọnọng kọ.
\v 4 Iyiya yọ ni ayọ lite nọ uju utina aghọmani atuma mi ni ọnọng shi kọ. Atii ki ba, ni ba aghọ ki bra uju utina ba.
\v 5 Insi imẹ shi ka ashi ni, imẹ shi uyeri ashi.”
\v 6 Aya tẹri kindii ni ava ta akpe ki ẹrẹbọng, ki zọọ ni ẹrẹbọng, nava vo ẹrẹbọng na azọọ ki coo ki ica ajiya nga.
\v 7 Aju ajiya nga si, “Wor, ya hwuru ica ngọ ka amusum ighọ aSiluwam.” Idi ighang ri yọ shi “Utuma.” Na ajiya nga va wor kiya hwuru ica nga, ki vuu ni ica sọ kyoo uka.
\v 8 Agha ayayo nga kina aghọ ka kyoo nga kọ shọr ka akyua, aju si, “Ba ajiya ri nga ka shọr ra ba?”
\v 9 Ace aghọ bọ va ju si, “Anga.” Ace aghọ bọ si, “Kayi, alilẹ ace wọ.” Ni, ajiya nga va yira ki kirẹkwyuẹ nga si, “Aini, imẹ shi ajiya nga.”
\v 10 Ibọ va ghulu nga si, “Aju nagyi wọ ni ica ngọ fọmọ?”
\v 11 Ava yira bọ si “Ajiya na aka yọrọ si iYesu ra nga zọọ ẹrẹbọng ki coo mi ki ica. Atẹri mi si imẹ ya hwuru ka ighọng aSiluwam. Imẹ va kyaa ki ya hwuru ni imẹ tee aghọ ukyoo uka.”
\v 12 Ibọ va ghulu nga si, “Abi kọ na ajiya shi kọ?” Ava ju si, “Ita yemi ba.”
\s1 AFarisiyawa wang uye upeni ukyoo uka Afoo
\p 
\v 13 Na ajiya nga va kyaa na aghọjee nga na shi afoo ka kyua ukushi aFarisiyawa.
\v 14 Awii uwuru aYahudawa kọ ni iYesu zọọ ẹrẹbọng ki fọmọ ajiya ri ica wọ.
\v 15 Kindọ wọ ni aFarisiyawa va ghulu nga si, nagyi wọ na apeni ukyoo wọ. Ni ajiya nga va ju si, “Azọọ ẹrẹbọ ki coo ki ica mi, ni imẹ hwuru, ka akyakyua ri ni imẹ ka kyoo uka.”
\v 16 Ace aFarisiyawa va ju si, “Ajiya ri ni ọkọ ushi Ọnọng wọ na akunu wọ ba, ka aka yii nga ọnọng awii uwuru aYahudawa ba.” Ni ace aghọ bọ ghulu ki ju si, “Nagyi wọ na ajiya ushi nọ uvulu ki ju uma uwo ica kindii wọ?” Ni aghọ bọ va kau.
\v 17 Ni ava khimi ughulu ajiya nga si, “Ikẹmbọ nọ ingọ ki tẹri kaya ẹrẹkwyuẹ ajiya ri, ka ingọ na afọmọ ngọ ica?” Ajiya nga va yira bọ si, “Atina Ọnọng nga.”
\v 18 Aghakakọng aYahudawa ni, ata ma bọ aipang si ajiya ri shi afoo kọ kpaa ka akyua ba, ni akyakyua ri ni aka kyoo uka ba. Kindọ ni, ava tuma na aghọjee nga.
\v 19 Ava ghulu bọ si, “Adi aghọ ni anọ nọ ngaa? Inu si ajee nga ni ashi afoo? Ni, aju nanyi na asọ bra ukyoo kakyakyua ri?”
\v 20 Ni aghọjee nga va yira si, “Ayọ ye si anọ bayọ wẹ ri, ni ajee nga na ashi afoo.
\v 21 Ayọ ni, ayọ ta ye yi unga ni aju na asọ kyoo uka kakyakyua ri ba, ayọ ta ye yi aghọ ni afọmọ nga ica ba. Inu ghulu nga, ashi nga ananọ ba, aki tẹri na anyu nga.”
\v 22 Aghọjee nga tẹri kindii ka atẹ ẹrẹbata aghakakọng aYahudawa, ka kọ kpaa ka akyua ni aYahudawa ku ju si nadidu aghọ ni aju si iYesu nga si aghọfoo ni, aki kla nu ka ọkọ takwyuẹ aYahudawa.
\v 23 Ọwọ sa ni aghọjee nga ju si, “Ashi nga ananọ ba, inu ghulu nga.”
\v 24 Ni aFarisiyawa va khimi uyọrọ ajiya ni ajee nga na ashi afoo kọ kpaa ka akyua, ki ju nga si, “Tẹri aipang kọ ujọọ Ọnọng. Ka ayọ ni ayọ ye si ajiya ni ama ngọ ukyoo uka ri ni aghọ uvulu nga.”
\v 25 Ni ava yira ki ju bọ si, “Ko ni aghọ uvulu nga, ni imẹ ta ye mi ba. Ima iye yọ ni imẹ ye, akyua nishi afoo, kindi ni imẹ kyoo uka.”
\v 26 Ava khimi ughulu nga si, “Ikẹmbọ na ju ngọ? Afọmọ ngọ ica nagyi?”
\v 27 Ava yira bọ si, “Imẹ kọ tẹri nu, inu ta kọọ nu ba. Ikẹmbọ sa ni inu wang va khimi ọkọọ kọ? Ta inu wang kọ tee aghọyii nga ni?”
\v 28 Ava ciya ajiya nga si, “Ingọ tee shi aghọyii nga, ka ayọ ni, aghọyii iMusa bọ.
\v 29 Ayọ tee ye si Ọnọng pii kini iMusa, ni, ajiya ri ni ayọ ta ye yi uka ni akunu wọ ba.”
\v 30 Ni, ajiya nga va yira bọ si, “Aidi ni ima uwo ica yẹ! Inu ta ye nu uka ni akunu wọ ba, awẹ ni afọmọ mi ica!
\v 31 Ayọ ye si Ọnọng ka kọọ nga aghọ uvulu ba, ni aka kọọ aghọ shọr nga, ki ka va yii upii nga.
\v 32 Kọ ukpaa ka akyua ni aker ashi ni ata kọ kọọ bọ si ace aghọ fọmọ ica aghọ ni ajee nga na ashi afoo ba.
\v 33 Ajiya ri ni, awasi ukushi Ọnọng wọ ni akunu wọ ba ni, ata kọ bra nga uju ice ima ba.”
\v 34 Ava yira nga si, “Ungọ aghọni ajee ngọ kidẹ uvulu, uwang mẹẹ yi ta?” Ni, ava kla nga.
\s1 Ufoo unga Aghing
\p 
\v 35 IYesu kọọ ila si akla ajiya nga, Aya peni nga ni, ava ghulu nga si, “Ingọ ma aipang na Anọ Ajiya ni?”
\v 36 Ajiya nga va yira si, “Ate, inga shi aghọ? Tẹri mi ki ma aipang ni nga.”
\v 37 IYesu tẹri nga si, “Ingọ nu nga, anga shi aghọ upii ni ngọ.”
\v 38 Ni ajiya nga va ju si, “Ate, imẹ ma aipang.” Ava jọọ nga.
\v 39 IYesu va ju si, Imẹ ghila ashi ri wọ ki imẹ tẹri ashuwa, ka aghọni aka kyoo bọ ba ni apeni ukyoo, aghọ ukyoo ni asa tee afoo.”
\v 40 Ni aFarisiyawa ushi kọ ukadu ya kọọ kindọ ni, ava ju nga si, “Ungọ sọ ju si ayọ ni afoo bọ wudu?”
\v 41 IYesu va tẹri bọ si, “Awasi inu ni afoo bọ ni, inu ta shinu na alaki uvulu ba. Ni, inu si inu kyoo ni, alaki uvulu nu ni ashiya.
\c 10
\s1 Aghọcee kina atẹm nga.
\p 
\v 1 Aipang nga ni isọ tẹri nu, aghọmani aghila nga ishu na atẹm ka anyu ghila ba ni, aghila ka ace anyu ni, anga na ayi ngaa.
\v 2 Aghọmani aghila ka anyu ni, anga shi aghọ shi na atẹm.
\v 3 Aghọ sha atẹm ka fọmọ nga ọka, atẹm ka kọng ẹrẹwyuẹ nga, aka yọrọ bọ nọ uca bọ.
\v 4 In kini awoo bọ ka asing ni, aka woru kite bọ, atẹm ka yii nga ka aye ẹrẹwyuẹ nga.
\v 5 Aki yii bọ akyeng ba, aki tẹbọ ka ata ye bọ ẹrẹwyuẹ nga ba.
\v 6 IYesu tẹri bọ idi ighang upii ri, ibọ ni ata kpẹlẹ bọ imu tẹri nga ba.
\v 7 IYesu va khimi utẹri bọ si, “Aipang nga ni isọ tẹri nu, imẹ sa anyu ughila atẹm.
\v 8 Aghọmani aba ku kite mi ni ayi bọ, atẹm ka va kọọ bọ bu ba.
\v 9 Imẹ sa anyu, aghọmani aghila ukushi mi imẹ ki foo nga, aki ghila ka kunu ngaa, aki peni imu wang nga.
\v 10 Ayi ka ba ki va yi, ki pili, ki bra wo. Imẹ ba ki ẹbọ pẹni ọkyuọ, ki ẹbọ peni wọ na giga.
\v 11 Imẹ sa aghọcee adaduma. Aghọcee adaduma ka ma ọkyuọ nadidu ka atẹm.
\v 12 Aghọ ju utina umani na abiba ni ngaa sa cee atẹm ne, inga na aghọ cee ngaa ba, atẹm na ngaa ba. Inkini ava aghumu ba ukushi bọ ne, a ki shiri atẹm ka te ngaa. Ava aghumu ki kpẹni atẹm ka kiya bọ nadidu.
\v 13 Aghọ utina umani abiba ni ngaa ki te ngaa kọ ufẹ bọ na aja ngaa, ba ima ni iduma ngaa na atẹm ba.
\v 14 “Imẹ sa aghucee adaduma. Iye amẹẹ atẹm, amẹẹ atẹm ye mi,
\v 15 Kini umani ni imẹ ye ate mi, ate me ma na ye mi. Ika ma ọkyuọ mi ka atẹm.
\v 16 Imẹ si na atẹm nga mani ashi bọ udi ishu ri ba. Imẹ ki vu ne bọ. Ka aki kọng ẹrẹyuẹ mi, aki ba ishu iyẹ, aghọ cee agha yẹ.
\v 17 Ima ni sa ni ate mi ka Yoo mi idi, ika ma ọkyuọ mi ki va kpaa wo ko.
\v 18 Ba aghọ mani aki kpaa mi ọkyuọ wo, imẹ ma wo ki kirikwyi mi, imẹ shina ẹrẹgọrọ ni ki ma wo ko, imẹ shi ni ẹrẹgọrọ ni ki kpaa wo kọ. Ima ni ate mi tẹri mi si iju idi.”
\v 19 kindu ne aYahudawa va de ku ola inang kina acee bọ.
\v 20 Na pam ki idẹ bọ va tẹri si asa ni ushẹẹ aghọ tiyagha ngaa. Ikẹmbọ sa ni inu so kọng nga?
\v 21 Acee aghọ va tẹri si, “upii ri ni nga aghọ shi no ushẹẹ wo ba. To ni ushẹẹ ki bara ufumu ica afoo?”
\v 22 Akyua ya ju nga usra agya uma ọna Ọnọng ka Urushelima, akyua ra ni iriwe shi wo.
\v 23 IYesu kyeng ke da izọgọ ọna ọnọng na iSulemanu vra.
\s1 Izọọ iSulemanu.
\p 
\v 24 AYahudawa ba ghẹmẹ nga, ki tẹri nga si “Ayọ ki sha ki ita ka agbawii nọ ingọ shee yi kọ ughulu ikwyi yi? Insi ngọ shi iKristi ni, tẹri ayọ ka ayayẹ.”.
\v 25 IYesu va yira ki tẹri bọ si “Imẹ kọ tẹri nu, inu taa ma nu aipang ki yira ba. Utina ni imẹ sọ ju nọ uca Ate mi ni, inu ki ye ta kọ imẹ ni ingaa.
\v 26 Inu taa ma nu aipang ba, ki inu shi nọ atẹm mi ba.
\v 27 Atẹm mi ka kọng ẹrẹwyuẹ mi, imẹ ye bọ, ibọ kọ ye mi.
\v 28 Imẹ ka ma bọ ọkyuọ umani ushi wo na amaa ba. Aki kpuru bọ nga ba, ba aghọ umani aki yira bọ kọ ki ivọ mi.
\v 29 Ate mi na ama mi atẹm ni, acee kwinga nọ ughọghẹ. Ba aghọ umani aki yira bọ kọ ki ivọ Ate mi.
\v 30 Imẹ kina Ate mi shi aghaye ra.”
\v 31 AYahudawa va khimi uyẹri atii na wang taa nga kọ.
\v 32 IYesu va yira ki tẹri bọ si “Kidẹ nọ upam ni imẹ ju nu kukushi Ate, kaya uligba wọ kidẹ ni inu wang taa mi na atii?”
\v 33 AYahudawa va tẹri nga si “Ba si iyi wang taa ngọ na atii kidẹ utina ọdọdọma ni ingọ ju wọ ba, ingọ sọ tẹri upii ububi Ọnọng wọ sa.” Ingọ aghọ mani ingọ sa ajiya ni ingọ wang yeni ẹrẹkwyuẹ ngọ si ingọ sa aghaye ra kina Ọnọng.”
\v 34 IYesu va tẹri bọ si “Awọọ kidẹ umẹẹ iMusa si, Ọnọng tẹri si, inu ni inọng yọ”.
\v 35 Ayu ye si nadidu upii Ọnọng na awọọ ni ushi wọ atẹr ba. Insi ate tẹri aghọmani asọ hwiri upii nga si ‘inọng’ yọ ni,
\v 36 Imẹ, aghọmani ate hwiya ki tuma mi ka ashi ri ni, inu wang tẹri si utina ujer amara ni isọ ju, nọ umani imẹ tẹri si, ‘Imẹ ni Anọ Ọnọng nga’?
\v 37 Insi uma umani Ate mi sọ ju bọ ni imẹ sọ ju ba ni, inu ba ma aipang ni imẹ ba.
\v 38 Insi uma bọ ni imẹ sọ ju ni, inu ta ma nu aipang ba ni, inu sa ma aipang ni uma ni inu kyoo ni imẹ sọ ju, Ate shi kidẹ mi, imẹ kọ shi kidẹ nga.’
\v 39 Ava ma ẹrẹkyuọ na wang kpẹnẹ nga, ava sang nga kidẹ bọ.
\v 40 IYesu va sang nga ki kyaa anyu ẹrẹyẹma Urdun uka ni iYahaya ju iminimini kọ ukpaa ka akyua, ni aci ya kọ ukaa.
\v 41 Ajiya na pam va ba ukushi nga, ni asọ tẹri nga si “IYahaya ka ju nga uma uwo ica kindi ba, imumani a tẹri ka ajiya ri ne aipang nga.”
\v 42 Kọ ukadu ra ni ajiya na pam va ma aipang ni iYesu.
\c 11
\s1 Ukpo ILazaru
\p 
\v 1 Ace Ajiya shi wọ na ayọrọ nga si iLazaru aghọmani a sa shi akyuọ ba ka aBetani. Ki ifọng iMaryamu kina anayuru nga iMatta.
\v 2 ILazaru aghọmani ashi akyuọ ba ni anayuru iMaryamu nga, anga shi aghọmani asa coo Ate iYesu nga anyẹ uvọng ki ifra na va cira wọ ni ufarikwyi nga ra.
\v 3 Anayuru va tuma kukushi iYesu, ki tẹri si “Ate, aghọmani ngọ yoo ra ni, ashi akyuọ ba”.
\p 
\v 4 IYesu ya kọng kindọ ni, ava tẹri si “Udumu ri ta ki sa wọ nga ukpo ba, ọki ba nọ ujọọ kukushi Ọnọng ka brẹ Anọ nga.”
\v 5 IYesu yoo iMatta kina anayuru nga, kina iLazaru.
\v 6 Kindọ ni aya kọọ si iLazaru shi akyuọ ba ni, ava khimi awii apai kọ ọka umani ashi wọ.
\p 
\v 7 Aya kpẹẹ ni ava tẹri aghọyii nga si, “Ayọ vuu yi aYahudiya”.
\p 
\v 8 Aghọyii nga va tẹri nga si, Aghọmẹẹ, awii ri ni aYahudawa wang taa ngọ na atii, ni ingọ wang va kya ngọ ukadu?”
\p 
\v 9 IYesu va yira bọ si, “Ba si awa ushọ na apai yọ shi awii aye ba? aghọmani a wang kyeng kidẹ uyeri ni aki kpa nga afra nga ba, ka akyoo uyeri ashi ri.
\v 10 Aghọmani asọ kyeng kidẹ itii ni, aka kẹr ifra nga ka uyeri shi wu ya ba”.
\p 
\v 11 Aya kpẹẹ utẹri bọ udu umara ni, ava khimi utẹri bọ si “Aghikyo yi iLazaru sọ mor wu, imẹ ki kyami ki imẹ ya sang ngaa kọ mor”.
\p 
\v 12 Kindọ ni aghọyii nga va tẹri nga si, “Ate, inkini umor wọ ni, aki lẹni”.
\v 13 IYesu yeni si iLazaru ku kpọọ wu, ẹbọ aghọyii nga kpaa si asọ umọr wulu wu ni.
\p 
\v 14 IYesu va tẹri bọ ka ayaye si, “iLazaru kọ kpoo.
\v 15 Inu bọ sa ni imẹ shi ni ikwyifu nọ umani imẹ shimi ya kọ ka ba, ki inu ma aipang. Ayọ ba wolu ka ayọ kya yi ukushi nga”.
\p 
\v 16 IToma aghọmani ayọrọ si iDidimọs va tẹri anayuru nga, aghọyii si, “Iyi ma kọ kẹẹ, ki iyi ya kpuru yi kina nga”.
\s1 IYesu nga usang kọ ukpo kina ọkyuọ.
\p 
\v 17 IYesu ya fọma ukadu ni, ava kọng si, iLazaru kọ la awii anari kidẹ alọr nọ umani anaa wọ.
\v 18 ABetani shi ka yayo kina Urushelima, ọtọọ bọ cẹẹ wọ ikang itai ba.
\v 19 AYahudawa na pam sọ ba na abili iMatta kina iMaryamu nọ kpọọ anayuru bu.
\p 
\v 20 Ni iMarta ya kọng si iYesu wo di ni, ava kunu ki ya sa ngaa asho nu ba. Ni UMaryamu va ghila ngaa ka aca.
\p 
\v 21 Kindu ni iMata ba tẹri iyesu ngaa si, “Ate, da sa aku shi wo ni anayuru nga ta kọ kpọọ ngaa ba.
\v 22 ko ka akyuakyuari ni iye ni ọnọng ta ma ngọ imumani ngọ sọrọ nga”.
\p 
\v 23 IYesu va tẹri ngaa si, “Anayuru ngọ ki sisang”.
\p 
\v 24 Ni iMarta va tẹri nga si, “Iye ni aki sisang ka awii utaa amara”.
\p 
\v 25 IYesu va tẹri nga si, “Imẹ sa aghọmani iki sang aghọ kpuru, aghọmani a ma aipang ni mẹ ni, kọ na akpọọ ni aki ọkyuọ.
\v 26 Aghọmani a sa akyuu ni, aka ma aipang ni mẹ ni, aki ci ka fuma sang asing aki kpọọ ngaa ba. Ngọ ma aipang ni mẹ?”
\p 
\v 27 IMata ba tẹri nga si, “ima aipang ate, “Ẹẹ, Ate, ima aipang ngọ sa aghọfoo ra, anọ Ọnọng aghọmani aki ba asing ri”.
\s1 IYesu ci.
\p 
\v 28 A ya tẹri kindọ ni, a va wor ki ya yọrọ anayuru nga uMaryamu, ki tẹri si, “aghumẹẹ a ba, asi ngọ ba.”
\v 29 A kọng kindọ ni, ava ju kaisa ki sisang ki kyaa ukushi iyesu.
\v 30 IYesu kọ sang nga ọghila ngaa idi ifọng ba. A shi kọ ka ni iMarta sa ngaa ashọ ko.
\v 31 Amara ni aYahudawa na si kini imaryamu na abili ngaa va nu na kunu ngaa asing ni, a va ki yi ngaa akpaa si aki kyaa ọka alo ngaa ni, ka ya ci kọ kadu ni.
\v 32 Ni uMaryamu ya fuma ọka ni iYesu shi wọ ni, anu ngaa ni, a va kpaa ki tẹ nga, ki tẹri si, “Atẹ, da si ngọ shi wọ ni, anayuru mi ta ku kpọọ ngaa ba.”
\p 
\v 33 IYesu ya nu na asu ci ni, aYahudawa na keng kini ngaa ẹbọ ma na su ci ni, ima va lo ngaa ke ikwyi na giga.
\v 34 A va tẹri si, “Abi wu inu naa nga ko”?
\p A va tẹri ngaa si, “Atẹ ba kọ ba nu.”
\p 
\v 35 Amaa ra ni iYesu va ci.
\v 36 Kindu ni aYahudawa va tẹri si, “kara mani a yoo ngaa!”
\p 
\v 37 Acee aghọ bọ ki de bọ va tẹri si, “A fumu ica afọọ ra ni, ikẹmbọ sa ni ata ju nga umani ajiya ra ki kpọọ ngaa ba?”.
\s1 IYesu sang iLi’azaru ngaa.
\p 
\v 38 IYesu ghẹmi duma wọ ki ikwyi nga na giga, a va kyaa ọka alo nga. Alo nga ni utii ughọghẹ bọ na a dara ayu kọ.
\v 39 IYesu va tẹri bọ si, “Inu yini utii wọ.”
\p Amaa ra ni iMarta anayuru aghọmani akpọọ va tẹri iYesu si, “Atẹ, aki shi kọ yuu kindi, asa awii anari ku mani akpọọ.”
\v 40 IYesu va tẹri nga si, “Imẹ tẹri ngọ si inkini ngọ ma aipang ni ngọ ki nu ujọọ Ọnọng ba?”
\p 
\v 41 A va yini utii wọ. IYesu va sang irikwyi nga ka ayaya ki tẹri si, “Atẹ, isa ngọ izaa ni ngọ kọng mi.
\v 42 Iye si ngọ ka kọng mi kọ agba akyua, i tẹri kindọ ka ajiya na shi kọ kawẹ ri ni ama aipang si ngọ tuma mi.
\v 43 A tẹri kindọ ni a va sang ẹrẹyuẹ ka yaya ki tẹri si, “ILi’azaru kunu!”
\v 44 Aghọmani akpọọ va kunu, ifra nga kini ifọng nga na loru na agẹẹ nọ uma ko, ibate nga ni ayuru na uma ni anaa nga kọ.
\p IYesu va tẹri bọ si, “inu shiri nga, ka wor.”
\s1 Alor IYesu ngaa anyu ababi.
\r (IMat 26.1-5; IMar 14.1-2; ILuk 22.1-2)
\p 
\v 45 Amara ni aYahudawa na ba ubili uMaryamu ngaa ba nu ima ni iYesu ju ni, ava ma aipang kukushi nga.
\v 46 Ace aghọ bọ va wor ki kyaa bọ kukushi aFarisiyawa, ki ya tẹri bọ ima ni iYesu ju.
\v 47 Kindọ ni Afirist akakọng kina aFarisiyawa va curu agha akakọng ọkọ ọka. A va ghulu bọ si, “Ikẹmbọ nọ inu su ju? Ajiya ri we ni asu ju uma uwo ica na gigang!
\v 48 insi iyii shẹri nga na aju uma ri ni, naidu ajiya ki ma aipang ku kushi nga, kindọ ni aRomawa ki ba ka va kpaa ifọng yi wọ kina Ọna Ọnọng yii kọ!”
\v 49 Kidẹ bọ ni acee ajiya shi wọ ni ayuru nga si ikayafa aghumani ashi kidẹ afirist akakọng ka ayii ra, a va tẹri bọ si, “Inu ta ye nu ice ima ba ko na ji!
\v 50 Inu ta kra nu ba, ushi uduma na ajiya ayeng kpọọ ka ya ajiya na pam, nọ mani a tẹri si ajiya na didu bọ na kpuru bọ.”
\v 51 Udii upii ni iKayafa tẹri ni, unga yọọ irikwyi nga wọ ba, ka nga si aya aghaghẹ nga aFirist ayii ra, ayeni nga kidẹ aghing si iYesu ki kpọọ ka aya ajiya na didu.
\v 52 Ba si aYahudawa ka yu ba, ka curu anọ Ọnọng aghọmani ashi kọ ucẹẹ nọ ka na pam ka ba ajiya aye ra.
\p 
\v 53 Imu kpẹni ka awii ni, aba taa ayuu aghu mani aki pii iYesu nga wọ.
\v 54 Kindu ni iYesu ta su keng nga ka ayayẹ kidẹ aYahudawa ba, aba shẹ uka, ki kyaa ifọng ni sa yayọ kina aghumu, ki ghila ngaa ifọng na yuru si iFrayim. ọka du wu ni a va cẹ wo kina aghọyii nga.
\p 
\v 55 Awii sra agya ubulu nga aYahudawa ya sang ba ni, Ajiya na pam va ba ifọng Urushelima ka ba huru akwyi bọ na ki sa awii usra agya.
\v 56 Adẹ ku wang iyesu ngaa, ati tara kọ ka ushọr Ọnọng na aghulu acee bọ, asu tẹri si, “ikẹmbọ ni inu nu? Aki ba usra agha ri?”
\v 57 Kindọ ni aFirist akakọng kina aFarisiyawa kọ lor ayuu si, aghọmani ayẹ ọkọ mani iYesu shi wọ ni, aghọ ba tẹri bọ ki ẹbọ ya kpẹni nga.
\c 12
\s1 A coo iYesu nga ayii uvọng ka aBetani.
\r (IMat 26.6-13; IMar 14.3-9)
\p 
\v 1 Usra agya ubulu ya sẹ awii atin ni, iYesu va kyaa aBetani, ọka ni iLazaru aghọmani iYesu sang ngaa a shi wọ
\v 2 kọ ka du wu ni a keri nga imila atii kọ, iMarta ngaa ka wu imila, iLazaru shi agha ayeng ki dẹ aghumani ni ala imila kini iYesu.
\v 3 uMaryamu va kpaa ayi uvọng kidẹ abiya ate abọ unardi nga ni a shini ọfe na giga, ki coo iYesu ngaa ki ifra ki cira wọ ni fuu irikwyi nga. ọka na didu ọna va ba ni avọng.
\v 4 Amara ni iYahuda Iskariyoti, agha ayeng ki dẹ aghọyii ngaa, aghọmani aki gbara iYesu nga wọ, va tẹri si,
\v 5 “Ikẹmbọ sa ni ata gbara bọ ayi uvọng ri wọ ka aya na ọfe aji usho atai ka va ma aghọ shi na amiri ba?”
\v 6 IYahuda tẹri udi upii ba si a duma na aghọ shi na amiri ba, ki nga ni ayi ngaa. Nga ka kọ ipa nọ ọfe, ki dẹ wọ ni aka sa yi wo.
\v 7 Iyesu va tẹri nga si, “shẹri nga ya, ka akyọ ayi ri sa awii ni aki naa mi wọ ngaa tọ wo bọ.
\v 8 Kọ a gba awii ni aghọ wang ka shi kini inu, inu ma ni ba kọ agba wii ni inu shi kini imẹ ba.
\s1 Ataa ILazaru ngaa ayuu ababi.
\p 
\v 9 Ikir ma ajiya aYahudawa ya kọng si iYesu shi kọ ka wẹ ni, a va ba, ba si iYesu ngaa ni aba ukushi nga ka yu nga ba, ama ni ibọ nu iLazaru aghọmani asang nga kọ kpọọ.
\v 10 Kindọ ni aya akakọng aFirist a va taa ayuu si asu pii iLazaru ngaa wọ.
\v 11 Ki iLazaru ngaa sa ni aYahudawa na pam su sheri aFirist bọ na ma aipang ni iYesu.
\s1 IYesu ghila Urushẹlima.
\r (IMat 21.1-11; IMar 11.1-11; ILuk 19.28-40)
\p 
\v 12 Ni ikyua ni ikir bajiya na ba usra agya ubulu ni, a va kọng si iYesu ashii kọ utiya uba Urushelima.
\v 13 A va yẹri ayaa udabinu ki kunu bọ asing, ki ya sa nga ashọ, na sang ayuu na tẹri si,
\b
\q1 “Ujọọ!
\q2 Ayuu adaduma ka aghọmani aki ba kọ uca ate!
\q2 Ayuu adaduma ka agọm nga Israila!”
\b
\p 
\v 14 IYesu pẹni acee anọ Izaki ni a va kila nga, kini imuma ni awoo si,
\b
\q1 
\v 15 “Inu ba kọng ẹrẹbata ba, inu ajiya Urushelima.
\q2 Agọm nọ udii ka ya anọ Izaki!”
\b
\p 
\v 16 Kọ kpaa ka amara ni aghọyii nga ta kpii bọ imumani a ju ra ba, a ya kpẹẹ ubrẹ iYesu nga ni, a va kpii si iwoo na awulu ra ni ka ya irikwyi ngaa iYesu, umaa keng na brẹbọ kọ nọ ma ni awulu.
\p 
\v 17 Aghọmani a shi kini nga ka kyua na yọrọ iLi’azaru ngaa na kunu ki da alo ni, ki sang ngaa kọ kpọọ, a dẹ kọ tẹri ajiya imumani iYesu ju.
\v 18 Ajiya na giga kyaa ki ya sa nga asho, ka kọng ima uwo ica na aju.
\v 19 Amaa ra ni, aFarisiyawa va pii kina anayuru bọ si, “Inu kra, inu ta biya nu ula ẹrẹkyuọ nga ba, ashi ri na didu su yii nga!”
\s1 Acee Helenawa kra iYesu ngaa.
\p 
\v 20 Kidẹ aghọmani aba shọr ka wii usra agya ubulu ki ẹbọ ba jọọ ni, Helenawa shiya.
\v 21 A va ba ukushi IFilibus, agha aBetsaida ka AGalili, ki tẹri nga si, “Aya aghaghẹ, iyi wang pii kini iYesu.”
\v 22 IFilibus va wor ki ya tẹri Andarawus ngaa, ni ka pai bọ va kya ki ya tẹri iYesu ngaa.
\p 
\v 23 IYesu va yara bọ si, “Akyua ku ju na brẹ anọ ajiya.
\v 24 Aipang ngaa ni imẹ sọ tẹri ngọ, in ba si ikir alkama ki ẹrẹbọ ni kpọọ yu ba ni, iki cẹ ki yu bọ. Inkini i kpọọ yu ni, iki ma anọ na pam.
\v 25 Naidu aghọmani yoo ọkyuọ nga aki shiri wo. Aghọmani a toro nga ọkyuọ nga ka ashi ri ni, asu sheri wo ya ka ki pẹni ọkyuọ ka awii taa amaa.
\v 26 Aghọmani awang ju mi utina ni, aki yii mi. ọka ni imẹ shi wo ni aki yii mi ka ju mi utina. Ate mi ki jọọ aghọmani asu ju utina mi.”
\s1 IYesu pii kọ mani ngaa ki kpọọ.
\p 
\v 27 “Akyuakyuari ni imẹ huri ikwyi mi ni isọ lo. Ikẹmbọ ni imẹ su tẹri? ‘Ate, foo mi ka adidi akyua’? Akau, imẹ ba don adidi ri akyua kọ.
\v 28 Ate, brẹ uca ngọ.”
\p Upii va kunu ka yaya si, “Ikọ brẹ ngaa, iki va ghẹmi ubrẹ ngaa kọ.”
\v 29 Ikir bajiya ni shiya, ko pii ni, a va tẹri si, “Aini iriviya kọ,” Ace ghọ bọ si, “Atuma Ọnọng ngaa pẹni.”
\p 
\v 30 IYesu va tẹri bọ si, “Upii ri ba ka ya inu kọ, ba si ka ya imẹ wọ ba.
\v 31 Akyua ri kọ ni aki tẹri ashi ri ashuwa kọ, Akyua ri kọ ni aki tumu aghọ ẹrẹgọm ashi kọ.
\v 32 Inkini aya sang mẹ kọ ka ashi ri kọ ni, iki curu ajiya ka ba ukushi mi.”
\v 33 IYesu tẹri kindọ ki ngaa yeni bọ ighọ kpọ ni ngaa ki kpọọ
\v 34 Ikir bajiya va tẹri iYesu si, “Aini, umẹẹ ba yọ tẹri iyii si, aghọfoo ki cẹ kini awii sang ashi. Iya ya wo ni ngọ su tẹri si aki sang Anọ Ajiya ka yaya? Ngaa si adidu anọ ajiya?”
\p 
\v 35 IYesu va tẹri bọ si, “Uyeri shi wo kini inu ka akyua na a zẹẹ kọ. Inu keng akyua ni uyeri shi ki ni inu, ka itii ki ba. Aghọ keng ki itii ta ye ngaa uka na ki kyaa kọ ba.
\v 36 Inu ma aipang ni uyeri, ka akyua ni ushi kini inu, ki inu tee anọ yeri.”
\s1 AYahudawa va dẹ kọ toro bu ma aipang ni iYesu.
\p Iyesu ya kpẹẹ tẹri udii upii ri ni, a va sang ngaa ki ya sho irikwyi nga ki dẹ bọ.
\p 
\v 37 Kọ nu mani iYesu ka ju uma uwo ica ki ite bọ ni, ama ni ataa ma bọ aipang kọ ukushi nga ba.
\v 38 Udii umari hwura ka ya imumani atuma Ọnọng Ishaya tẹri si,
\b
\q1 “Ate, ingaa ma aipang ni utuma ba yo,
\q2 Ngaa na ayini nga ni
\q2 Imumani avọ Ate ju?”
\b
\p 
\v 39 Imumani sa ni ataa ma bọ aipang ba, kọ nọ mani Ishaya tẹri kọ cee ọka si,
\b
\q1 
\v 40 “A tee ni bọ afoo,
\q2 A sa ufoo irikwyi ki ikwyi bọ,
\q1 Ka ba bra ukyoo ni ica bọ ba,
\q2 kọni akpili ki dẹ ikwyi bọ,
\q2 Ka vuu ukushi mi, imẹ ki lẹni bọ.”
\b
\m 
\v 41 Ishaya ju kindu ki ngaa nu ujọọ iYesu, ki ngaa ma ni ama ila nga.
\p 
\v 42 Kindu ra ni Ajiya na pam ma aipang ni iYesu, kina acee akwyite bọ ma aipang kọ ukushi nga. Kindu ra ni ahuri ẹrẹbata na yini ka aFarisiyawa ye, ka wang bọ ka kla bọ ka ọkọ takwyuẹ aYahudawa ba.
\v 43 Ibọ ka wang jọọ ka ayuu ba Ajiya ki te na ujọọ mani Ọnọng ki ju bọ.
\s1 Upii Iyesu ki ju ashuwa
\p 
\v 44 IYesu sang ẹrẹyuẹ ki tẹri bọ si, “Aghọmani ama aipang ukushi mẹ ni, ukushi mi kọ yu wu na ma aipang kọ ba, ama ni ukushi aghọmani a tuma mẹ wọ.
\v 45 Naidu aghọmani asọ kyoo mi ni, aghọ kyoo aghọmani a tuma mẹ.
\v 46 Imẹ ba kana anọ uyeri ngaa ka ashi naidu aghọmani na ma aipang ni mẹ ni aki cẹ bọ kidẹ itii ba.
\p 
\v 47 Naidu aghọmani ahuri umẹẹ mi ni, ata ma bọ aipang ba ni, imẹ ki ma bu ẹrẹkiya utina bu ba. Imẹ ta ba mẹ tẹri ashi ashuwa ba, imẹ ba ki mẹ ba foo ashi kọ.
\v 48 Aghọmani a toro mi ngaa, ata yara nga upii mi ba, ashi ki na aghọmani aki tara ashuwa, upii ni mẹ tẹri, uwu ki tẹri nga ashuwa ka awii utaa amaa.
\v 49 Uma ni mẹ su mẹẹ nu ba ukushi mi wo ni ọka ba wo ba, Ate mi na atuma mi ngaa su tẹri uma ni mẹ su tẹri nu kọnọ upii ni imẹ ki tẹri.
\v 50 Imẹ ye si ọkyuọ utaa amara ni aka pẹni wo kọ upii na Ate ma. Kindu ni naidu ima ni imẹ tẹri ni, imẹ tẹri yo kini imumani Ate tẹri si imẹ tẹri.”
\c 13
\s1 IYesu hwuru ifra atina nga
\p 
\v 1 Na akyua usra agya ubulu aYahudawa ya sọ ba ni, iYesu ye si akyua ngaa ba, inga ki sher asing ka vuu, ọka ushi Ate ayaya. IYesu yoo agha asing nadidu, ayoo bọ ki ta ka amaa.
\v 2 Akyua mani iYesu kina aghọyii nga sọ la imila ni, Ishẹẹ va ghila ikwyi iYahuda Iskariyoti, anọ iSiman, ava gbra iYesu.
\v 3 IYesu ye ni Ate ma kwikẹ ki ivọ nga, ava ye si inga ba kukushi Ọnọng kọ, ni ukushi Ọnọng kọ ni inga ki vuu kọ.
\v 4 Akyua mani asọ la imila ni, iYesu va sisang ki woo igbang nga, inga ayaya, ava loru ugyauto ka buu nga.
\v 5 Ava sa amusum kidẹ awuu, ki hwuru atina nga ifra, na sha na bra bọ ifra kina ugyauto mani a loru ka buu nga.
\v 6 IYesu va ukushi iBitrus. IBitrus va wulu nga si, “Ate, ingọ ki hwuru mi ifra?”
\v 7 IYesu va tẹri nga si, “Ingọ ki ye ngọ ima ushi kọ ju mi kakyakyua ri ba ni, ingọ ki kpẹlẹ kọ tutumu.”
\v 8 IBitrus va tẹri nga si, “Kayi! ingọ ki hwuru mi ifra ba.” IYesu va tẹri nga si, “Insi ita hwuru ngọ nga ifra ba ni, ingọ shi ngọ nọ ọka kukushi mi ba”.
\v 9 IBitrus va tẹri nga si, “Aghọ ọna, basi ifra yọ ni ingọ ki hwuru ba, hwuru nadidu ivọ mi kina ẹrẹkwyuẹ mi”
\v 10 IYesu va tẹri nga si, “Aghọmani akọ sọmọ ni, atọ na pipar, ifra nga yọ wang hwuru, ba ọsọmọ ba ko ma. Inu shi na pipar, ba nadidu nu wọ ba.”
\v 11 Ka iYesu ye aghọ mani aki gbra nga. Ọwọ sa ni atẹri si, “Ba nadidu nu bọ shi na pipar ba.”
\v 12 Na aya kpẹẹ uhwuru bọ ifra ni, ava sọmọ igbang nga, na va vuu ọka uci nga, kiya cicaa. Ava wulu bọ si, “Inu kpẹlẹ imumani imẹ ju nu?
\v 13 Inu yọrọ mi si Aghọmẹẹ kina Ate, aipang nga, kọ umani ushi wudu.
\v 14 Insi imẹ Ate nu kina Aghọmẹẹ nu, hwuru nu ifra ni, iyiya yọ ni inu hwuru ifra ace nu.
\v 15 Imẹ yeni nu amaa kọ, inu sọ kọ ju kọnọ umani imẹ yeni nu.
\v 16 Imẹ tẹri nu aipang, agira kara cẹri ate nga ba, aghọmani atuma kara gina aghọ mani atuma nga ba.
\v 17 Akyakyua ri ni inu kpẹlẹ ọmari ni, Ọnọng ki ma nu anyu adaduma peni inu ju bọ ni.
\p 
\v 18 Ba nadidu nu kọ ni imẹ sọ pii kọ ba, imẹ ye aghọmani imẹ hwiya. Ka ahwura uma mani, awọọ kidẹ upii ọnọng, ọngo mani ingọ tẹri si ‘Aghọmani ala imila mi, a ta mi utumu’
\v 19 “Imẹ sọ tẹri ngọ uma ri nọ ọkọ ba bọ ba, peni uya ba ni ingọ sọ ma aipang si imẹ shi inga.
\v 20 Imẹ sọ tẹri ngọ aipang, aghọmani ayira, aghọmani imẹ tuma ni, ayira mi wudu. Aghọmani ayira mi ni ikwyi iye ni, ayira aghọmani atuma mi wudu.”
\v 21 IYesu ya kpẹẹ utẹri uma ri ni, ikwyi nga va bra yọ nagigang, ava tẹri si “Aipang nga ni imẹ tẹri nu, agha yeng ki gbra mi kọ.”
\v 22 Ni atina iYesu va tee aghọ ukyoo ace nọ umani ara ye bọ atina umani asọ tẹri kaya nga ba.
\v 23 Ace atina iYesu mani ayoo nagigang, cicaa ka ayayo nga.
\v 24 ISiman iBitrus va wulu nga na avọ si awulu iYesu ta inga na asọ pii kaya nga.
\v 25 Ni atina iYesu va ba ayayo kini nga, ki wulu nga si, Ate ingaa?
\v 26 IYesu va tẹri si, “Imẹ ki sọmọ awo ubiredi ri kidẹ isọ. Aghọmani imẹ ma nga ni, anga.” IYesu ya kpaa awo ubiredi ki sọmọ kidẹ isọ ni, aba ma iYahuda anọ iSiman Iskariyoti.
\v 27 Ni iYahuda ya yira ubiredi nga ni, ishẹẹ va ghila nga. IYesu va tẹri nga si “Aju ima mani awang ju kaishang.”
\v 28 Kọ umani, ba aghọmani akpẹlẹ imumani iYesu sọ yeni.
\v 29 Ace aghọ bọ kpaa si, iYahuda nga shi aghọ kyuru ipa nọ ufẹ bọ ni, IYesu sọ tẹri nga si aya ghẹ ima uwang bọ kọ usra agya wọ, ko na ama aghina amir ice ima.
\v 30 Ni iYahuda ya kpẹẹ ula ubiredi nga ni, ava kyaa asing. Akyua ni, ating kọ ju.
\s1 IYesu Tẹri Umani IBitrus Ki La Inang Uye IYesu
\p 
\v 31 IYahuda ya kunu kidẹ ubọọ ni, iYesu va tẹri si “Akyakyua ri kọ ni ajọọ Anọ Ajiya kọ, ava jọọ Ọnọng ni nga.
\v 32 Insi Ọnọng yira ujọọ ni nga ni, Ọnọng ki ma Anọ ujọọ ni ẹrẹkwyuẹ nga, ka akyua ra ni aki peni ujọọ.
\v 33 Inu anọ mi ọfisi, imẹ shi kini inu, ka anakyua nazii. Kọnọ umani imẹ tẹri aYahudawa si, Inu ki wang mi, ni inu ki bra nu ba ọkọ shi mi ba.
\v 34 Imẹ ma nu imumani Ọnọng sa uju ọsọsa, inu yoo ace nu. Inu yoo ace nu kọnọ umani imẹ yoo nu ni.
\v 35 Kindi wọ ni kwinga ki ye si inu ni aghọyii mi bọ, insi inu yoo ace nu.”
\v 36 ISiman iBitrus va wulu si “Ate, abi wu ni ingọ ki kyang kọ?” IYesu va tẹri nga si, “Ingọ ki bra ngọ ukyaa kini imẹ ka akyakyua ri ba, ingọ ki ba kọ tutumu.
\v 37 IBitrus va wulu nga si “Ate, ikẹmbọ sa ni imẹ ki bra mi uyii ngọ ka akyakyua ri ba? Imẹ ki ma ọkyuọ mi kaya ngọ”
\v 38 IYesu va tẹri nga si, “Ingọ ki ma ọkyuọ ngọ kaya mi? Imẹ sọ tẹri ngọ aipang, akọr ta kọ ta ẹrẹwyuẹ ni, ingọ ki tẹri si ingọ ta ye mi ba iritai.”
\c 14
\s1 IYesu Nga Shi Utra Ukyaa Ọkushi Ate Ayaya
\p 
\v 1 “Inu ma dama ikwyi nu ba. Inu ma aipang kọ Ọnọng kina ka inu va ma aipang ki imẹ.
\v 2 Ọna ate mi ni, abọọ shiya napam. Ba kindọ ba ni ita kọ tẹri nu si imẹ ki kya mi ki imẹ ya ker nu ọkaa?.
\v 3 Peni iya kpẹẹ uker nu ọka ni, iki ba ki ma kpaa nu, ka inu ma peni mi.
\v 4 Ọka umani imẹ ki kya mi ni, inu ye utra.”
\v 5 Ni iToma va tẹri iYesu si, “Ate, iyi ye yi ọka mani ọki kyang ba, nanyi wọ ni iyi ki kpẹlẹ utra kọ?”
\v 6 IYesu va tẹri nga si, “Imẹ shi utra, imẹ shi aipang, imẹ va shi ọkyuọ. Ba aghọ mani aki kyaa ukushi ate ayaya, na ata yii nga ukushi mi ba.
\v 7 Awasi inu ye mi ni, inu ta kọ ye ate mi. Ni kọ kpaa akyua ri ni inu ye nga, kiva nu nga!”
\v 8 IFilibus va tẹri nga si, “Ate, yeni yi Ate ayaya, kọ uwang yi wudu.”
\v 9 IYesu va tẹri nga si “Imẹ kọ kpaa akyua ni nu kindi nagigang, ni ki ta ka akyua ri ni, inu ta ye mi nga ba iFilibus? Aghọmani anu mi ni, anu Ate ayaya! Ikẹmbọ sa ni ingọ tẹri si, ‘Imẹ yeni nu Ate?
\v 10 Ingọ ta ma ngọ aipang si, imẹ shi kidẹ Ate, ni Ate kọ shi kidẹ mi ba? Upii umani imẹ so tẹri nu ni, ọnga mẹ bọ ba, ọnga Ate umani ashi kidẹ mi, anga sọ ju utina nga.
\v 11 Inu ma aipang si imẹ shi kidẹ Ate, Ate kọ shi kidẹ mi, ko ni inu ma aipang kina utina mani imẹ ju.
\v 12 Aipang nga ni isọ tẹri nu, aghọmani ama aipang kini imẹ ni, aki ju itina mani imẹ ju. Aghọ ki ju itina mani igina inga mẹ, ka imẹ ki vuu mi ukushi Ate.
\v 13 Inu shọr kwikẹ kidẹ nọ uca mi, imẹ ki ju, ka Anọ ma Ate ujọọ.
\v 14 Nadidu imumani inu shọr kidẹ nọ uca mi ni, imẹ ki ju.
\s1 Uta Anyu Uki ba Aghing Ọnọng
\p 
\v 15 “Peni inu yoo mi ni, inu ki ju imumani imẹ sa uju.
\v 16 Imẹ ki shọr Ate, ka ama nu ace aghọ ki shẹ nu kọ, aghọmani aki ci kini nu ka aya ta kọ sang asing.
\v 17 Aghọ nga shi aghing aipang, agha ayasing ta yira bọ nga ba, ka ata nu bọ nga ba, ko ni ata ye bọ nga ba. Ni inu ye nga, ashi kini inu, aki va shi kidẹ nu.
\v 18 Imẹ ki sher nga ya kina akyọr ni ba, imẹ ki vuu mi ukushi nu.
\v 19 Akyua shi najii, agha aya asing ki sọ nu mi ba, ni inu ki nu mi, ka imẹ shi akyuọ, inu ki kọ shi akyuọ.
\v 20 Awii ra ni inu ki kpẹlẹ si, imẹ shi kidẹ Ate mi, inu kidẹ mi, imẹ kidẹ nu.
\v 21 Aghọmani ayira imumani imẹ sa uju ki ju ni, abọ shi aghọ uyoo mi. Aghọmani ayoo mi ni, Ate mi ki yoo bọ. Imẹ ki kọ yoo bọ, ki imẹ va yeni bọ ẹrẹkwyuẹ mi.
\v 22 Ni iYahuda, ba Iskariyoti ba, va tẹri nga si, “Ate, ikẹmbọ sa ni ingọ yeni yi ẹrẹkwyuẹ ngọ ni ingọ ta yeni ngọ agha aya asing ba?”
\v 23 IYesu va tẹri nga si “Nadidu aghọmani ayoo mi ni, aki ju imumani imẹ tẹri bọ ni, Ate mi ki yoo bọ, iyi ki ba ukushi bọ ki ima ci kini inga.
\v 24 Nadidu aghọmani ata yoo mi nga ba ni, aki ju uma utẹri mi ba. Nadidu ighang upii mi ni, ba imẹẹ yọ ba. Nadidu ighang upii mi ni, inga Ate mi yọ, aghọmani atuma mi.
\v 25 Imẹ sọ tẹri nu uma ri ka akyua ni imẹ shi kini nu.
\v 26 Aghọ ki shẹ nu kọ, aghing Ọnọng, aghọmani Ate ayaya ki tuma kidẹ nọ uca mi, anga ki mẹẹ nu uma nadidu, aki va shuni nu uma umani imẹ tẹri nu.
\v 27 “Imẹ sher nu nọ uci ọkyuọ, uci ọkyuọ mi kọ ni imẹ ma nu. Imẹ ta ma nu nga kina agha aya asing ri ka ma ba. Inu ma dama ikwyi nu ba, inu ma va kọng ẹrẹbata ba.
\v 28 Inu kọng ni imẹ tẹri si imẹ ki wor, ni imẹ kiva vuu ukushi nu. Awasi inu yoo mi ni, inu ta kọ ju ikwyifu ka imẹ ki kya mi ukushi Ate, ka Ate cẹẹ mi.
\v 29 Imẹ sọ tẹri nu uma ri ka akyakyua ri, nọ tọ ba. Peni uya ba ni, inu sọ ma aipang.
\v 30 Imẹ ki sọ kpaa mi akyua kọ pii ni inu nagigang ba, ka aghọ go ẹrẹgọm asing ri sọ ba. Ashi na akyuọ kaya ẹrẹkwyuẹ mi ba.
\v 31 Imẹ ju nabibọrọ imumani Ate sa mi uju, ka agha aya asing ye si imẹ yoo Ate. Inu sisang ki iyi sher ukẹẹ”
\c 15
\s1 IYesu Nga Shi Ọshẹ Inabi Ọnga Aipang
\p 
\v 1 “Imẹ shi ọshẹ inabi ọnga aipang, Ate mi nga shi aghọ uwuu ikọlọ na ashi.
\v 2 Aki kpa kwaligba aga umani ita ma wọ ikọlọ ba. Aki khimi uker kwaligba aga umani ama ikọlọ, ka ukhimi ujee wọ.
\v 3 Inu shina pipar nọ upii mani imẹ tẹri nu.
\v 4 Inu ci kidẹ mi, imẹ kọ ci kidẹ nu. Kọnọ umani ba aga ọshẹ ikọlọ iki mu ikọlọ ni ẹrẹkwyuẹ wọ ba, sa ushi kina ọshẹ ikọlọ. Inu ki kọ bra nu ba, sa inu shi kini imẹ.
\v 5 “Ẹẹ, imẹ shi ọshẹ ikọlọ, inu ni, aga nga. Aghọmani ashi kidẹ mi ni, imẹ ki kọ shi kidẹ bọ, aki mu ikọlọ nagigang. Inbasi kini imẹ ba ni, inu ki bra nu ju ice ima ba.
\v 6 Aghọmani ashi kini imẹ ba ni, ashi kini aga umani anaa kọ ni iva hwiya wọ. Ighọ aga ra ni aka yẹri bọ ki sa kidẹ ugha.
\v 7 Peni inu shi kidẹ mi ni, upii mi ki kọ shi kidẹ nu, nadidu imumani inu shọr ni, aki ma nu.
\v 8 Peni inu ma ikọlọ nagigang ni, inu ni aghọyii mi anga aipang bọ. Ọki nyeni ujọọ Ate mi.
\v 9 “Kọnọ umani Ate yoo nu ni, kindi wọ ni imẹ kọ yoo nu wọ. Inu ci ya kidẹ uyoo mi.
\v 10 Pẹni inu ju imumani imẹ sa uju ni, inu ki shi kidẹ uyoo mi, kọnọ umani imẹ ju ima utẹri Ate mi ki ci kidẹ uyoo nga ni.
\v 11 Imẹ tẹri nu uma ri, ka inu peni ikwyifu. Ẹẹ, ikwyifu nu tii.
\v 12 Utẹri mi wọ si, inu yoo ace kọnọ umani imẹ yoo nu ni.
\v 13 Ba uyoo umani ucẹẹ udii, uma ọkyuọ ngọ kaya na aghikyo ngọ.
\v 14 Inu ni aghikyo mi bọ, peni inu ju ima utẹri mi ni.
\v 15 Imẹ sọ yọrọ nu si agira ba, ka agira ye imumani aghọ ọna nga sọ ju ba. Akyua ri, inu ni aghikyo mi bọ, ka imẹ tẹri nu kwikẹ mani Ate mi tẹri mi.
\v 16 Ba inu bọ hwiya mi ba, imẹ hwiya nu. Utina nu wọ shi, inu ya ma ikọlọ ingọ ki ci nagigang, ka Ate ma nu imumani inu shọr nga kidẹ nọ uca mi.
\v 17 Utẹri mi wọ nga shi si, inu yoo ace nu.
\s1 Asing Tọrọ wọ Aghọyii IYesu
\p 
\v 18 “Insi asing tọrọ nu ni, inu ye si imẹ ni a tọrọ wọ na atọ tọrọ nu.
\v 19 Asing ki yoo nu, peni inu ni anga nga bọ ni, inu ni ba anga asing bọ ba. Imẹ hwiya nu kaya asing ri, ọwọ sani asing tọrọ nu.
\v 20 Inu shuni ni imumani isa tẹri nu? ‘Agira kara gina aghọ ọna nga ba.’ Peni asa ju mi ububi ni, inu mani aki tọ ju nu ububi. Peni ayira umẹẹ mi ni, aki yira unga nu.
\v 21 Aki ju nu umari nadidu kaya nọ uca mi, ka aye bọ aghọmani atuma mi ba.
\v 22 Basi umani iba ki ma pii kini bọ ba ni, ada shi bọ kina ivulu ba, ni ana akyua ri ni ashi bọ na ice ima utẹri anga ivulu bọ ba.
\v 23 Aghọmani atọrọ mi ni, a tọrọ Ate mi.
\v 24 Adawasi imẹ da ju mi bọ uma umani ba aghọmani aki bra uju ba ni, ada shi bọ ni ivulu ba. Ni anu uma ju mi, nadidu kindii ni atọrọ mi kina ate mi.
\v 25 Uma ri ba ka na ahwura umẹẹ iMusa mani utẹri si, ‘A tọrọ mi ba ice ima.’
\v 26 Imẹ ki tuma aghọmani aki ma shẹ nu kọ, aki ba kukushi Ate mi. Anga shi aghing aipang, aghọmani akunu kukushi Ate, anga ki tẹri aipang kaya ẹrẹkwyuẹ mi.
\v 27 Inu ni amaa na ayeni nga, ka inu shi kini nga kọ kpaa ka akyua.
\c 16
\p 
\v 1 “Imẹ tẹri nu uma ri ka inu ba waa utumu nọ uma aipang nọ ba.
\v 2 Aki kla nu ka ọkọ takwyuẹ aYahudawa. Iyiya ni akyua ya sang uba umani nadidu aghọmani apii nu kọ ni, aki hwiri kini inga sọ ju utina Ọnọng wọ ni.
\v 3 Asọ ju kindii ka ata kọ sang bọ uye Ate kina Anọ.
\v 4 Imẹ tẹri nu uma ri ka akyua ni uba kọ ni, inu shuni si imẹ kọ tẹri nu.
\s1 Utina Aghing Ọnọng
\p “Imẹ ta tẹri nu nga uma ri kọ kpaa ka akyua ba ka imẹ shi kini inu.
\v 5 Ka akyakyua ri ni imẹ ki kyami ukushi aghọmani atuma mi. Nadidu kindọ ni, ba aghọmani aghulu mi si, ‘Abi wọ nọ ingọ ki kya ngọ kọ ba?’
\v 6 Ikwyi nu sọ kọọ ububi nọ umani imẹ tẹri nu uma ri.
\v 7 Kindii ni, imẹ sọ tẹri nu aipang, ukyeng mi cẹẹ nọ ọdọdọma kukushi nu, ka aghọ ushẹ nu kọ ra kọ ba nga ba. Insi imẹ woru ni, imẹ ki tuma nu ni nga.
\v 8 Akyua umani aghọ shẹ nu ki, aki yeni asing si iyiya ni ughulu ikwyi bọ shi na kikya ba kaya uvulu, kina aya uju aipang, kina uwa ashuwa.
\v 9 Ughulu ikwyi bọ kaya uvulu shi wọ na kikya ba ka atọọ bọ uta ẹrẹpiya uma aipang bọ ba.
\v 10 Ughulu ikwyi bọ kaya uju aipang shi wọ na kikya ba, ka imẹ ki kya mi ukushi Ate mi, inu va sọ nu mi nga ba.
\v 11 Ughulu ikwyi bọ kaya uwa ashuwa shi wọ na kikya ba, ka akọ wa aghọ uko ẹrẹgọm asing ri ashuwa.
\p 
\v 12 Imẹ shẹ nọ uma na pam umani imẹ ki tọ tẹri nu, ni inu ta ki bra nọ ukpaa bọ kakyakyua ri ba.
\v 13 Insi aghing aipang ya ba ni, aki kyeng ni nu kidẹ aipang nadidu, ka ba upii nga wọ na aki tẹri ba, aji tẹri uma umani aka hwiri wọ, aki ba tẹri nu uma umani ọki ba.
\v 14 Aki jọọ mi, ka aki kpaa imumani imẹ tẹri wọ ka atẹri nu.
\v 15 Nadidu imumani Ate shi ni yọ ni imẹẹ yọ, imẹẹ ni inga yọ. Ọwọ sa ni imẹ si Aghing ki kpaa imumani imẹ tẹri wọ ka atẹri nu.”
\s1 Ikwyi ibibi ki vuu yọ ikwyifu
\p 
\v 16 “Kọ utumu anakyua ni, inu ta ki nu mi nga ba, kọ utumu anakyua ni, inu ki nu mi.”
\p 
\v 17 Ace aghọyii nga ba tẹri ace bọ si, “Ikẹmbọ na asọ yeni nọ umani atẹri yi si, ‘Kọ utumu anakyua ni, inu ta ki nu mi nga ba, kọ utumu anakyua ni, inu ki nu mi’? Ikẹmbọ na asọ ba yeni nọ umani asi, ‘Imẹ ki kya mi ukushi Ate’?”
\v 18 Aba lite nọ utẹri si, ‘Kọ utumu anakyua na zẹẹ’? Ayọ ta ye bọ imumani asọ yeni ba.”
\p 
\v 19 IYesu ye si aghọyii nga wang ghulu nga kaya upii ri, aba tẹri bọ si, “Inu sọ ghulu ace nu kaya imumani imẹ sọ yeni nọ umani imẹ si, ‘Kọ utumu anakyua ni, inu ta ki nu mi nga ba, kọ utumu anakyua ni, inu ki nu mi’?
\v 20 Aipang, imẹ sọ tẹri nu, inu ki ni ikwyi ibibi, asing ki kọọ ikwyifu. Inu ki kọọ ikwyi ibibi, ni ikwyi ibibi nu ki tee ikwyifu.
\v 21 Insi ayiri ki jee ni, aka kọọ ọlọ nagigang, ka akyua ujee nga kọ ju. Insi akpẹẹ ujee anọ ni, aka yuu ọlọ na asa kọọ wọ ka ashi ni ikwyifu nọ umani ajee anọ ka asing.
\v 22 Umani ushi wudu kukushi nu. Inu sọ ju ikwyi ibibi ka akyakyua ri, imẹ ki khimi unu nu kọ, akyua ra wọ ni inu ki ju ikwyifu wọ, ba aghọmani aki yira nu ikwyifu kọ ba.
\v 23 Awii ra ni inu ta ki shọr mi nga ice ima ba. Aipang ni imẹ sọ tẹri nu, Ate ki ma nu nadidu imumani inu shọr kidẹ nọ uca mi.
\v 24 Ki ba ta ka akyua ri ni, inu ta kọ shọr nu ima kidẹ nọ uca mi ba. Inu shọr, inu ki peni, ka ikwyifu nu hwura.”
\p 
\v 25 Imẹ ju utina na ighang upii ki yeni nu uma ri kọ. Akyua ki ba ni iki pii ni inu ka ayayẹ kaya Ate, iki sọ ju mi utina ni ighang upii ba.
\v 26 Awii ra ni inu shọr kidẹ nọ uca mi. Inu ki shọr Ate ka akyakwyi nu, imẹ ki shọr nu ya ba,
\v 27 ka Ate yoo nu ka akyakwyi nu, ka inu yoo nga, inu ba ma aipang si aba kukushi Ọnọng wọ.
\v 28 Ukushi Ate wọ ni imẹ ba wọ, imẹ shila asing, akyakyua ri ni iki ya asing ki vuu mi ukushi Ate.”
\p 
\v 29 Aghọyii nga ba yira si, “Ẹẹ!, akyakyua ri wọ ni ingọ sọ pii wọ ka ayayẹ, ba ni ighang upii ba!
\v 30 Akyakyua ri ni ayọ ye si ingọ ye kwikẹ. Ingọ ka bra uyira upii na akọ ghulu ngọ nga ba. Udii sa ni ayọ ma aipang si ingọ ba kukushi Ọnọng kọ.”
\p 
\v 31 IYesu yira si, “Inu ma aipang ka akyakyua ri?
\v 32 Akyua ki ba, akọ ba, agna umani kwinga ki te kyaa aca nga ka inu ya mi kayu mi. Kindọ ni, imẹ shi kayu mi ba, Ate shi kini imẹ.
\v 33 “Imẹ tẹri nu umari ka inu peni uci ọkyuọ kidẹ mi. Kidẹ asing ri ni inu sọ kọọ ọlọ, inu kpẹnẹ ikwyi nu ka imẹ la ẹrẹkyuọ asing.”
\c 17
\s1 IYesu Pii nọ Ọnọng
\p 
\v 1 IYesu ya kpẹẹ utẹri udubi uma ni avasa shang ẹrẹkwyuẹ nga ka ayaya ki pii nọ Ọnọng si,
\p “Ate mi, akyua ya ju. Nọ ujọọ Anọ ngọ ka ingaa ni akọ jọọ ngọ.
\v 2 Kọ uma Anọ ẹrẹgọrọ kaya ajiya, ka ama ọkyuọ utaa amaa kukushi aghọmani ingọ ma nga.
\v 3 Ọkyuọ utaa amaa shi si, ajiya ye ngọ, ọngọ aghọmani ọngọ shi Ọnọng kayu ngọ aghọ uma aipang.
\v 4 Imẹ jọọ ngọ ka asing ri kọ hwura utina mani ingọ ma mi si imẹ ju.
\v 5 Ka aikyua ri ni, Ate, jọọ mi kini ujọọ mani imẹ shi ni wọ kite ngọ nọ ta kọ ker asing ba.”
\s1 IYesu Pii nọ Ọnọng kaya aghọyii nga
\p 
\v 6 “Imẹ kọ yeni umani ushi ka ajiya mani ingọ ma mi ka asing ri. Kọ kpaa ka akyua ni abọ na anga ngọ bọ, ni ingọ ma mi bọ, ava yii upii ngọ.
\v 7 Aikyua ri na aye si nadidu imumani ingọ ma mi ni ukushi ngọ kọ.
\v 8 Ki ighang mani ingọ tẹri mi ni Imẹ tẹri bọ, avasa yira. Aye si aipang nga ni ukushi ngọ kọ ni imẹ kunu kọ, ama aipang si ingọ tuma mi.
\v 9 Imẹ sọ shọr kaya akwyuẹ bọ. Ba ajiya asing ri ni sọ shọr kọ ba, ki kaya ajiya mani ingọ ma mi bọ, abọ ni imẹ sọ shọr kọ.
\v 10 Nadidu imumani imẹ shi ni yọ ni inga ngọ yọ, ni imumani ingọ shi ni yọ ni inga mẹ yọ. Ava yeni ujọọ kukushi bọ.
\v 11 Imẹ kyeng ba ọkọ ushi ngọ. Imẹ ki sọ cica mi ka asing ri ba, ki ibọ sọ shi kidẹ asing. Ate aghọ upipar, kyuru bọ kidẹ nọ uca ngọ, uca umani ingọ ma mi, ka tee agha ayeng, kọnọ umani imẹ shi kini ingọ ni.
\v 12 Akyua umani imẹ shi kini ibọ ni, isha bọ kidẹ nọ uca ngọ, uca umani ingọ ma mi, isha bọ, ba aghọ umani avulu si agha yeng mani ashi aghọ idẹ ugha, ka ahwura imumani upii Ọnọng tẹri.
\v 13 Akyua ri ni imẹ kyeng ba ọkọ shi ngọ. Ni isọ shọr udubi uma ni imẹ sọ shi ka aya asing ka aghọyii mi peni uhwura ikwyifu kidẹ ikwyi bọ.
\v 14 Imẹ tẹri bọ ighang ngọ. Asing vasa tọrọ bọ, ka abọ ni ba anga asing ri bọ ba, kọnọ umani imẹ ni ba anga asing ri nga ba ni.
\v 15 Imẹ shi mi kọ shọr ngọ sọ ukpaa bọ kaya asing ri ba, Ni isọ shọr ngọ sọ udara bọ ka agha ababi ri.
\v 16 Abọ ni ba anga asing ri bọ ba, kọnọ mani imẹ ni ba anga asing ri nga ba.
\v 17 Hwuru bọ aipang, ki ighang ngọ ni, ọnga aipang kọ.
\v 18 Imẹ tuma bọ kidẹ asing, kọnọ mani ọngọ tuma mi ni.
\v 19 Ki ibọ bọ ni imẹ sọ hwuru ẹrẹkwyuẹ mi ki ibọ kọ hwuru akwyi bọ na aipang.”
\s1 IYesu Pii nọ Ọnọng kaya aghọ uma Aipang
\p 
\v 20 “Ba adi bẹ aghọ kayu bọ ni imẹ shọr ba, ni imẹ sọ shọr kaya ajiya mani aki ma aipang kọnọ upii bọ.
\v 21 Ate, imẹ sọ shọr nadidu bọ ka teghi agha yeng ra. Kọnọ mani ingọ shi kidẹ mi ni, imẹ ni ishi kidẹ ngọ, isọ shọr ta ni ashi kidẹ yi, ka Ajiya asing ri ma aipang si ingọ tuma mi.
\v 22 Imẹ ma Ajiya ri ujọọ mani ingọ ma mi, ka teghi agha yeng kọnọ mani ishi agha ayeng ni.
\v 23 Imẹ ki cica kidẹ bọ, ingọ kidẹ mi, ka teghi agha yeng ra, ka Ajiya ye si ingọ tuma mi, ka aye si uyoo mi.
\v 24 “Ate, imẹ wang si adibi ajiya mani ingọ ma mi ka aci ni imẹ ọkọ mani imẹ shi wu. Imẹ wang si anu ujọọ ngọ, ọngọ mani ingọ ma mi nọ uyoo mi na akọ keri bọ asing ba.
\v 25 Ate, agha aipang, agha asing yeng ba, imẹ ni imẹ yeng, ajiya ri ni, aye si ọngọ tuma mi.
\v 26 Imẹ tẹri bọ mani ọngọ ushi, iki lite nọ uyeni bọ, kọ yoo mani ingọ yoo mi, ni, ulara kidẹ bọ, imẹ ni ishi kidẹ bọ.”
\c 18
\s1 A kpeni IYesu
\r (IMat 26.47-56; IMar 14.46-50; ILuk 22.47-53)
\p 
\v 1 IYesu ya kperi upii nọ Ọnọng ni, a va bulu na atina nga ki kyabọ ọda uhọ avọng aKidron. Kọ ọda uhọ avọng nga ni ice ija shi ya, ni iYesu kina atina nga va ghila idẹ.
\v 2 IYahuda, aghọ mani a gbura iYesu wu, a ye ukadu, ki iYesu kọ gheli nọ kyeng ukadu na atina nga.
\v 3 Ni iYahuda va kpa aghọla ọkpọ ikir, kina aghọ sha, aghọ mani agha kakọng afirist kina aFarisiyawa a tuma. A kya ija nga na kọ agbilimọ uyer, na ashi ugha, kina uma ọkọrọ.
\p 
\v 4 IYesu mani aye nadidu ima ki ba nga ni, ava kunu, ki wulu bọ si, “Inga nọ wang?”
\p 
\v 5 Ava yira si, “IYesu aBanazaret.”
\p IYesu va yira bọ si, “Imẹ” IYahuda aghọ mani a gbura nga wu ting kina ibọ
\v 6 IYesu ya yira si, “Imẹ shi nga ni”, ajigha nga vasa waa nọ tumu ki kpaa ki ẹrẹbọng.
\p 
\v 7 IYesu vasa kimi uwulu bọ si, “Inga nọ wang?”
\p Ava yira si, “IYesu aBanazaret.”
\p 
\v 8 IYesu vasa yira bọ si, “I mẹ tẹri nọ si, imẹ shi nga, Insi imẹ inu wang ni, na ajigha ri na akikyabọ.”
\v 9 Udi ba ka upii iYesu mani akọ tẹri hura. Ka akọ tẹri akyua ra si, “Aghọ mani ingọ mani ko agha ayeng ra vulu ba.”
\p 
\v 10 Ni iSiman iBitrus aghọ mani ashi kina ikuma, ava wo ki kpa agira ifirist ighighẹ, ni ọtọng avọ ila nga kua wu. uca agira nga bọ shi iMalkus.
\p 
\v 11 Ni iYesu vasa tẹri iBitrus si, “Vuu kina ikuma ngọ kidẹ ọfọng. Iki sa mi kidẹ asong mani Ate mẹ ma mi si isa ba?”
\s1 IYesu ki ite iFirist ighighẹ
\r (IMat 26.57-58; IMar 14.53-54; ILuk 22.54)
\p 
\v 12 Na aghọla ọkpọọ kina aghaghẹ bọ kina aghọ sha ọna Ọnọng ba ki ma kpẹni nga, ki va loru nga
\v 13 ava kyu ba ni nga ukushi iHannana, inga shi ate ayiri iKayafa. IKayafa ni anga shi ifirist ighighẹ ka anyi ri.
\v 14 IKayafa nga ma aYahudawa upii si uceri ni ọduduma agha yeng kpoo kaya agha pai.
\s1 IBitrus la inang uye iYesu
\r (IMat 26.69-70; IMar 14.66-68; ILuk 22.55-57)
\p 
\v 15 Ni iSiman iBitrus kina ace atina iYesu yii nga kọ utumu. Atina iYesu ri ni ifirist ighighẹ nga ye nga, anga va sa ghila idẹ ọna ifirist ighighẹ nga kini iYesu.
\v 16 Ni iBitrus va sa lara ta ka anyu bọọ ka sing. ada atina iYesu mani ifirist ighighẹ nga ye nga ni va kunu ki peni kina anayiri shi kọ sha anyu bọọ, avasa ghila kina iBitrus.
\v 17 Anayiri mani asha anyu bọọ va tẹri iBitrus, “Ingọ shi ngọ ka idẹ agha atina ajiya ri ba?” IBitrus va yira nga si, “Kayi, imẹ shi mi ka idẹ ba.”
\v 18 Asọ ju iriwe, aghọ sha ya kyeri ugha na akyiri, na ati-ting, na ahuri ucoci ugha. IBitrus ni ati-ting ya kina bọ na whuru ucoci ugha.
\s1 Ifirist Ighighẹ wulu iYesu uma
\r (IMat 26.59-66; IMar 14.55-64; ILuk 22.66-71)
\p 
\v 19 Ni ifirist ighighẹ va wulu iYesu ipii kaya atina nga kina umẹẹ nga.
\p 
\v 20 IYesu va yira nga ki tẹri si, “Ai, imẹ tẹri upii ka ayaye ki ite akwinga, imẹ va mẹẹ ki ọna Ọnọng kina ika ọta akwyi aYahudawa na acuru nadidu. Imẹ sono kọ tẹri mi ice ma kuyuyi ba.
\v 21 Ya ni ingọ sọ wulu mi? Wulu aghọ mani akọng mi. Ka aye imumani imẹ tẹri.”
\p 
\v 22 IYesu ya tẹri kindọ ni, ace aghọ kidẹ aghọ sha na ting va hala iYesu na avọ, na va wulu nga si, “Kindọ wu ni ingọ ki yira ifirist ighighẹ wu?”
\p 
\v 23 IYesu va yira si, “Insi imẹ tẹri uvulu ni,” “Ni asọ nyeni mani ushi. Insi imẹ tẹri aipang ni, ikẹmbọ sa ni ingọ gyo mi?”
\v 24 Ni iHannana va sa na kpa iYesu kaya loru, ukushi iKayafa ifirist ighighẹ.
\s1 IBitrus vasa nẹrẹ uye iYesu ọnga ipai
\r (IMat 26.71-75; IMar 14.69-72; ILuk 22.58-62)
\p 
\v 25 Ni iBitrus shi kọ kọng ọcọci ugha ni, ace aghọ va wulu nga si, “Ka ingọ shi agha yeng kidẹ atina iYesu?”
\p Ni iBitrus vasa nẹrẹ, ki tẹri si, “Ba imẹ ba.”
\p 
\v 26 Ace aghọ ka idẹ agira ifirist ighighẹ ashi ya. Agira nga ni ashi ko ute aghọ mani iBitrus kwya nga ọtọng ko, ava sa tẹri iBitrus si, “I ta nu ngọ kina inga ka ija ba?”
\v 27 Ni iBitrus vasa ba nẹrẹ. Ba ọbura akyua akọr va sa ta iriwi.
\s1 IYesu ki ite iBilatus
\r (IMat 27.1-2; IMat 27.11-14; IMar 15.1-5; ILuk 23.1-5)
\p 
\v 28 Ni ikwyating ava kpa iYesu ka ọna iKayafa ki kya ugunu igwamna aRoma. ni avasa tọrọ bọ ọghila idẹ ugunu, ka ma kpẹni irighe ki ite Ọnọng ka va bọra bọ ọla imila ubulu ba.
\v 29 Ukadu wu ni IBilatus va kunu asing ki ma wulu, “Avulu ikẹ nga ni upẹni ajiya ri ni nga?”
\p 
\v 30 Avasa yira nga si, “Ada wa si ashi ayi ba ni,” “iyi da kọ ba yi ni inga ukushi ngọ ba.”
\p 
\v 31 IBilatus va tẹri bọ si, “Uwulu ni nga ka kyakwyi nu kọ ya ju nga ashuwa kini mani umẹẹ nu tẹri ni.”
\p Ni aYahudawa vasa tẹri si, “Ai, ara mayi irigoro ukpa ọkyọ ajiya ba.”
\v 32 Udi ba ka hura upii mani iYesu tẹri ighọ ukpọ mani inga ki ju.
\p 
\v 33 IBilatus va vuu idẹ ọbọọ tẹri ashuwa, avasa yuru iYesu ki wulu nga si, “Ingọ shi agọm aYahudawa?”
\p 
\v 34 IYesu va yira si, “Udi upii ngọ ta ace aghọ tẹri ngọ upii kaya irikwyi mi?”
\p 
\v 35 IBilatus va yira nga si, “Ai, ni imẹ shi mi aBayahude, ajiya ngọ bọ kina agha kakọng afirist abọ ba ni ngọ ukushi mi. Ikẹmbọ ni uju?”
\p 
\v 36 IYesu va tẹri nga si, “Ẹrẹgọm mi ni ba inga asing ri kọ ba. Ada wa si ikọ ni, agira mi da kọ kọrọ ki kla mani aYahudawa a kpeni mi wu.”
\p 
\v 37 Ni iBilatus va tẹri si, “Ingọ na agọm nga, ni!”
\p IYesu va yira nga si, “Ingọ tẹri na kikya ni mani utẹri si Imẹ ni agọm nga. imumani isa na ajee mi wudu, imumani isa ni mẹ ba asing ri dọ, ki mẹ tara ka aipang. Nadidu aghọ mani ashi ka uho aipang na akọng mi.”
\p 
\v 38 IBilatus va wulu nga si, “Ikẹmbọ shi aipang?” Kini udi ni akunu kikya ukushi aYahudawa ki tẹri bọ si, “Imẹ ni ita peni nga kina ace avulu ba.
\v 39 Ni uwẹ ni itali nu yu ni isher nu agha yeng kidẹ aghọ shi kọ bọọ iting ka agya ubulu. Inu wang mi si ‘isher agọm aYahudawa’?”
\p 
\v 40 Avasa tẹri bọ ni ẹrẹwyuẹ ighighẹ, “Kai, ba anga ba! Ma yi iBarabbas!” IBarabbas ni ace ayi upili ajiya nga.
\c 19
\s1 A wa iYesu ashuwa ọkpọ
\p 
\v 1 Ukadu ni iBilatus va sa ni ata iYesu aiwirimi.
\v 2 Aghọ ọkpọ nga vasa ju itagya inga akara ki sumu ki irikwyi iYesu. Ava sumu nga uma vẹng
\v 3 ava kya ukushi nga ki va kya, na sha ca nga na tẹri si, “Ọkyọ ngọ tiri wu, agọm aYahudawa!”
\p 
\v 4 Ni iBilatus va kimi ukunu kọ, ki tẹri aYahudawa, “Uwẹ ni ki woo nu iYesu, ki ira peni mi nga na vulu ba.”
\v 5 Uka udu ni iYesu va kunu ni itagya ẹrẹgọm inga akara kina igbang vẹng. Ni iBilatus va tẹri bọ si, “Ajiya nu wẹ.”
\p 
\v 6 Agha kakọng afirist kina aghọ sha ọna Ọnọng, ava ta shang ẹrẹwyuẹ na tẹri si, “Agara nga! Agara nga!”
\p 
\v 7 AYahudawa va tẹri nga si, “Ai, iyi shi kini umẹẹ, kọnọ mani umẹẹ tẹri ni ọshi na pii ngọ kọ, ka a tee ni irikwyi Ọnọng.”
\p 
\v 8 IBilatus ya kọng udi upii ni ava kimi ọkọng ẹrẹbata kọ.
\v 9 Ava kimi ghila idẹ ugunu. Ki ya wulu iYesu “Ingọ kunu ka abi?” Ni iYesu ra yira nga ba.
\v 10 Ọkọ sani iBilatus va tẹri nga si, “Ingọ tọrọ ngọ upii ni mẹ? Ingọ ta yẹng si imẹ shi kina akyọ mani ishẹring ngọ ba, kọ ni igara ngọ ba?”
\p 
\v 11 IYesu va yira nga si, “Ingọ ki shi ngọ ni akyọ kaya mi ba in da si ara ma ngọ ka yaya ba. Aghọ mani a ma mi kidẹ ivọ ngọ aceri ngọ kina vulu.”
\p 
\v 12 Ka aya upii ra ni, iBilatus a wang mani asher iYesu, ni aYahudawa la ite nọ tẹri si, “Insi ingọ sher ajiya ri ni, ingọ shi ngọ aghikyọọ iKaisar ba. Nadidu aghọ mani akpa irikwyi nga sa ashi agọm ni asọ wang la utumu iKaisar wudu.”
\p 
\v 13 IBilatus ya kọng mani atẹri ni, ava wọ iYesu ki cica ki ice igọ ashuwa ọka mani ayuru si ọdẹmi atighi. kini irighimi Aramaya ni aka yuru si aGabbata.
\v 14 Awii ucuru akpara usra agya ubulu kọ ọnga awii atinsara, kina atinọng.
\p “Agọm nu wẹ,” IBilatus va tẹri aYahudawa.
\p 
\v 15 AYahudawa va shang ẹrẹwyuẹ na tẹri si, “A pighi nga! A pighi nga! Agara nga!”
\p IBilatus va wulu bọ si, “Inu wang si igara agọm nu?”
\p Ni aghakakọng afirist va tẹri si, “Iyi shi yi kina ace agọm ba in ba si iKaisar ba.”
\v 16 Ọka udu ni iBilatus va kpa iYesu ki ma aYahudawa ka gara nga.
\s1 Agara iYesu
\r (IMat 27.32-44; IMar 15.21-32; ILuk 23.26-43)
\p Aghọla ọkpọ va wulu ni iYesu.
\p 
\v 17 A go gara ushi nga, ki kya uce ọka mani ayọrọ si ọka igbahu irikwyi. Kina irighimi Aramaya ni ayọrọ si aGolgota.
\v 18 Ọka dọ kọ ni agara nga kọ, kina ace agha pai, ace aghọ ka avọ ila, ace aghọ ka avọ ipuruma iYesu ka bọgating.
\p 
\v 19 IBilatus wọ ice iwọ kiya deri kaya gara. A wọ si, \sc “IYESU ABANAZARET, AGỌM AYAHUDAWA.”\sc*
\v 20 AYahudawa nagigang pila iwọ ka ọka mani agara iYesu kọ ni ushi ayayo ni ifọng, iwọ ni awọ ni irighimi Aramaya, ni iRomanci, ni iHelenanci.
\v 21 Ni agha kakọng afirist aYahudawa va tẹri iBilatus, “Ma wọ si, ‘Agọm aYahudawa’, ọsọ wọ si, ‘Ajiya ri tẹri si anga shi agọm aYahudawa’.”
\p 
\v 22 IBilatus va yira bọ si, “Ima mani imẹ kọ wọ ni, imẹ kọ wọ wudu.”
\p 
\v 23 Aghọla ọkpọ nga ya kperi gara nga ni, ava yeri uma ugo nga, ki ko ika inari, kwagba ọkpọ kpa ọka yeng, ava kpa igbang igbigbang mani ara huri bọ ba. a huri kọ kpa ka ya ki ta ka ta.
\p 
\v 24 Ava tẹri ace bọ si, “Iyi ma giya kọ ba, iyi ma wuru itọ kaya ki nu aghọ mani aki la.”
\p Udi ba ka imumani awọ kidẹ upii Ọnọng hura,
\q1 “Akọ ọgbang mi kidẹ bọ
\q2 kiva wuru itọ kaya umami.”
\m Imumani aghọla ọkpọ nga ju wudu.
\p 
\v 25 Ni, ucice gara ni ayuru iYesu, anayuru ayuru nga, iMaryamu ayiri ikilobas, kina iMaryamu iMagadala.
\v 26 IYesu ya nu ayuru nga kina atina nga mani ayọ nagigang na ating ka yayọ, ava tẹri ayuru nga si, “Ayiri, anọ ngọ wẹ,”
\v 27 ni atina nga ni, “Ayuru ngọ wẹ.” Kọ kpa ka kua ra ni, atina va kpa nga kikya ọna nga.
\s1 Ọkpọ iYesu
\r (IMat 27.45-56; IMar 15.33-41; ILuk 23.44-49)
\p 
\v 28 IYesu ye si a kpẹri akwikẹ ni, ka va hura imumani awọ kidẹ awọ Ọnọng na ava tẹri si, “Imẹ wang sa amusum.”
\v 29 Ace abom shi kina amusum ikọlọ na ashi shi kọ ka dọ. Ava sọ imusumu kidẹ, ki sọmọ ka ashi ki sang ki ta ka anyu iYesu.
\v 30 IYesu ya yira amusum ikọlọ na ashi ni ava tẹri si, “Akpẹri!” Ọkadọ ava suu ni irikwyi nga ki shẹri ọkyọ nga.
\p 
\v 31 Awii ucuru akpara, ikua na awii ọkọkọng kọ. Ka aYahudawa wang bọ mani ọkọng shi kaya gara ka awii uwuru ba, ava sọrọ iBilatus ka ma bọ anyu wura ifra bọ ka va shulu ni ikọng.
\v 32 Aghọla akpọ ba ki wura ifra agha yẹng mani agara ki na iYesu, ava kya ki ya wura ifra aghing ipai kọ.
\v 33 Ni aya ba aya iYesu ni, ara wura bọ ifra nga kọ ba, ka akọ kpọ.
\v 34 Ni, agha yẹng va waa nga ni ikuma kọ uho, ki isha nga, ayii kina amusum va kunu.
\v 35 Aghọ mani anu nga tẹri, ni aipang nga na atẹri. Ayẹ si atẹri aipang, ni atẹri ki inu ma ma aipang.
\v 36 Uma ri ba ka upii Ọnọng hura, “Ba ọgbahọ yẹng nga mani ọki wura wu ba,”
\v 37 ni, uce upii Ọnọng tẹri si, “A ki wang aghọ mani atulu.”
\s1 Ọnaa iYesu
\r (IMat 27.57-61; IMar 15.42-47; ILuk 23.50-56)
\p 
\v 38 Ata iricuru ni, iYusuf ajiya Arimatiya, aghọ mani ashi atina iYesu kọ uyuyi ka ahuri ẹrẹbata aYahudawa, a sọrọ ọkọng iYesu ka kpa. IBilatus ma nga, ava ya kpa ọkọng iYesu.
\v 39 INikodimus aghọ mani asa kya ọkushi iYesu na ating, akyeng ni iYusuf, akọ uma ọvọng, azọọ amur kina alos, ọfọma ọmọọ ishi tai.
\v 40 Ajiya nga ka pai bọ kpa ọkọng ki lọmọ ki na ugyauto ki na uma ọvọng kini mani aYahudawa ka ju kọ naa ajiya.
\v 41 Ọka mani agara iYesu ice ija shiya, kidẹ ija nga ni ace alọr shiya angọ mani asọnọ ta bọ ace aghọ yaba.
\v 42 Ushi si awii ucuru akpara aYahudawa ni alọr shi ka yayọ, ava ta iYesu ya kọ ka dọ.
\c 20
\s1 Usisang IYesu Ka Alọr
\p 
\v 1 Kina ikwyating inga awii ayeng ọsati, nọ ka sọnọ kọ yẹr wu ba, iMaryamu iMagadaliya, akya ọka alọr iYesu, anu na kọ yini ọtighi anyu alọr kọ.
\v 2 Ava tii kiya pẹni iBitrus kina da aghọ yii iYesu mani ayọ ra. Ava tẹri bọ si “Akọ woo Ate kọ kidẹ alọr, ọwẹ ni ita yẹ yi ọka mani asọmọ nga kọ ba.”
\p 
\v 3 IBitrus kina da aghọ yii iYesu, va wor ki kya bọ ọka alọr.
\v 4 Ibọ ka pai bọ asọ tii, ni ada ghọ tii ki kyu fuma ọka alọr kiya iBitrus.
\v 5 Ava ta aghong ki tẹni, ava nu ugyauto mani afuwa nga kọ yii, ni ada ghila idẹ alọr ba.
\v 6 Ni si go ọba iBitrus kọ utumu nga, ava ma ghila idẹ alọr, ki nu ugyauto mani afuwa anga ni ọyii.
\v 7 Ava nu imu ọkọng mani afuwa anga irikwyi kọ, kọ da uho, ada zọọ bọ ya kina ọda ugyauto ba.
\v 8 Ni aghọ yii iYesu mani afuma alọr kishẹri iBitrus, va ghila. Aya nu ni ava ma aipang.
\v 9 Ni ki ta ka aikyuari ni ada kpili bọ ima mani awọọ kidẹ upii Ọnọng si, iyiya yu ni iYesu ki sisang kọ kpo.
\v 10 Ni aghọ yii nga va vuu bọ aca.
\s1 IYesu Nyeni Irikwyi Nga Kushi iMaryamu
\p 
\v 11 IMaryamu ting ka sing kọka alọr, na sha na ci. Na asọ ci ni, ava ta aghong ki tẹni idẹ alọr.
\v 12 Na va nu atuma Ọnọng apai ago uma ufufugu, na acica kọka mani ọkọng iYesu ọsa shi kọ, agha yẹng cica kọka irikwyi nga, ada ghọ ni ka ta ifra nga.
\p 
\v 13 Ava wulu nga si, “Ayir, ikẹmbọ sani ingọ sọ ci?”
\p Ava yira bọ si, “Akọ kpaa Ate mi kọ,” Atẹri si, “Imẹ ta yẹmi ọka mani asọmọ nga kọ ba.”
\v 14 Aya kpẹr ọtẹri ọmari ni, ava tee ki nu iYesu nating, ni ada kpili nga ba.
\p 
\v 15 IYesu va tẹri nga si, “Ayir, ikẹmbọ ni ingọ su ci? inga ni ingọ sọ wang?”
\p Imaryamu kpasi aghọ ju tina kidẹ ija nga, ọkọ sani atẹri nga si “Aghọ ọna, pẹni ingọ kpaa nga ni, nọ tẹri mi ọka mani ọsọmọ nga kọ, kiya wo nga.”
\p 
\v 16 IYesu va tẹri nga si, “IMaryamu!”
\p Ava tee kikya ọka shi iYesu, ki tẹri nga kina iYahudanci si, “Rabboni” ọkọ shi aghọmẹẹ.
\p 
\v 17 IYesu va tẹri nga si, “Ma kpini mi ba, ki sọnọ kyami ọka shi atemi ba. Ni kya kọ ya tẹri anayurumi si, iki vuu mi ọka shi ate mi kina ate nu, Ọnọng mi kina Ọnọng nu.”
\v 18 Ni iMaryamu iMagadala va kya ọka shi aghọ yii iYesu, ki tẹri bọ si “inga nu iYesu!” ava tẹri bọ uma mani a tẹri nga.
\s1 IYesu Nyeni Irikwyi Nga Ọka Shi Aghọ Yii Nga
\p 
\v 19 Kina ọghe ọnga awii ayeng atinsara, na aghọ yii iYesu afuwa akwyi bọ kidẹ ọbọọ, ka ahuri ẹrẹbata aghakakọng aYahudawa. Ni iYesu va ba, ki ma titara ga bughating bọ, ki tẹri bọ si, “Inu pẹni ikwyifu!”
\v 20 A kpẹr tẹri bọ upii ni, ava nyeni bọ ivọ nga kina ẹsha nga. Na aghọ yii nga va peni ikwyifu nagigang kini unu iYesu.
\p 
\v 21 IYesu va kimi ọtẹri bọ si “Inu peni ikwyifu! umani Ate mi tọma mi ọkọ ni imẹ ma tọma nu.”
\v 22 Ava sho bọ fẹni nga, ki tẹri bọ si, “Inu yira aghing Ọnọng.
\v 23 Insi inu yira ọlọkpaa ivulu aghọ ni, ayira; insi ọda yira nu ọlọkpaa ivulu nga ba ni, aki yira bọ ba.
\s1 IYesu Nyeni IToma Irikwyi Nga
\p 
\v 24 Agha yeng kidẹ aghọ yii iYesu, aghọ mani ayọrọ si iToma (ko iciri), asara shiya kakua mani iYesu sa ba kọ ba.
\v 25 Ushe aghọ yii iYesu va tẹri nga si “Ibọ nu Ate!”
\p Ava tẹri bọ si, “Inga ki ma aipang ba, si inga nu irinyuru ẹka akusa, ki nga va piya kina ani vọ nga, ki nga ta avọ ka irinyuru ọnga ẹsha nga.”
\p 
\v 26 Utumu awii ananari ni, aghọ yii iYesu ashi kidẹ ọna, iToma shiya ni bọ. Anyu abọọ shibọ ayẹ ba, iYesu va ghila ki titara ka bughating bọ, ki tẹri bọ si, “Inu peni ikwyi ifuu.”
\v 27 Ava tẹri iToma si, “Ta ani vọng kọ kawẹ, kẹri ivọ mi. Nawa avọng kọ piya irinyuru ẹsha mi. Sheri uju ọta uma aipang ya nọ tee aghọ ma aipang.”
\p 
\v 28 IToma va tẹri nga si, “Atemi kina Ọnọng mi!”
\p 
\v 29 IYesu va tẹri nga si, “Ingọ ma aipang ki ingọ nu mi. Agha anyu adaduma bọ aghọ mani ama aipang ba a numi ba.”
\p 
\v 30 IYesu ju uce nọ uma uwo ica nagigang kọka shi atina nga, ọngọ mani ada wọ bọ kidẹ awọ riba.
\v 31 Awọ udibi ri ki inu ma aipang si, iYesu nga shi Ikristi, anọ Ọnọng. Kọ ma aipang ni nga ni, iki peni ọkyo kidẹ uca nga.
\c 21
\s1 IYesu kini huri itagbo inga wo ica
\p 
\v 1 Utumu udi ni iYesu kunu ọkushi atina, ka anyu avọng aTibariya. Mani ọba wẹ,
\v 2 ISiman iBitrus, kina iToma aghọ mani ayuru nga si uciri, kina iNataniyel ka aKana anga aGalili, kina anọ iZabadi, kina ace atina apai ashiya kini bọ.
\v 3 IBitrus va tẹri si, “Imẹ kikya mi ahuri itagbo.” Aghọ sha va tẹri si, “Iyi maa kikya ni ngọ.” Ava kọnọ ki ghila ọgbọlọ ki wulu. Ka ting ni ata kpẹni bọ ice ma ba.
\p 
\v 4 Ọka sọ yeri ni, iYesu ting ki belẹ avọng, ni atina nga ta kpili bọ si iYesu nga ting ba.
\p 
\v 5 IYesu va yuru bọ ki tẹri si, “Aghọ ikyọ, inu shi ki na itagbo?”
\p Ayira si, “Kai”
\p 
\v 6 IYesu va tẹri bọ si, “Fẹni ima huri itagbo nu ka avọ ila ọgbọlọ nu ki inu ki peni.” A ya ju kindọ ni avasa kpini itagbo nagigang na ara bọra bọ ọwaga ka ata kidẹ ọgbọlọ nga ba.
\p 
\v 7 Atina ra mani iYesu yọ ra va tẹri iBitrus si, “Ate nga!” ISiman iBitrus ya kọng na atẹri si, “Ate nga,” ava kpa igbang nga ki sọmọ ka ago igbang ba ava funu ki ghila idẹ amusum.
\v 8 Ushẹ atina ayii kidẹ ọgbọlọ, awaa imu huri itagbo ki huri itagbo natitọ, ka atọ bọ atọọ na uho avọng ba, kina ọmara aji kọ ni.
\v 9 Aya shulu ni, ava nu ujakri ugha sọ yara kọ kadu kina itagbo kaya, kina ubiredi.
\p 
\v 10 IYesu tẹri bọ si, “Ba ki na ice itagbo mani inu kpini ka aikuari.”
\p 
\v 11 ISiman iBitrus ghila ọgbọlọ idẹ na amusum nga ki ya waa imu huri itagbo ki ba uho avọng. Itagbo tii ni ikikọng, 153, ki ni ọghẹ ni ima huri itagbo ta gaa yu ba.
\v 12 IYesu va tẹri bọ si, (Inu ba kọ ma la imila ikwyating.”) Ba aghọ kidẹ bọ mani abura wulu nga, “ta anga ni inga?” Ka aye si Ate nga.
\v 13 IYesu ba, ki kpa ubiredi ki ma bọ, ki va ju kindọ kini itagbo.
\v 14 Ọnga itai mani iYesu nyeni irikwyi nga ka kushi atina nga utumu mani ashang nga ka kpo.
\s1 IYesu kina iBitrus
\p 
\v 15 Aya kpẹri la imila ni, iYesu va tẹri iSiman iBitrus si, “ISiman anọ iYohanna, ingọ yọ mi kina aipang ki cee aduba aghọ?”
\p 
\v 16 IYesu va kimi tẹri si, “ISiman anọ iYohanna, ingọ yọ mi ka aipang?”
\p Ava yira si, “A, Ate, ingọ ye si imẹ yọ ngọ.”
\p IYesu va tẹri, “Sa ica kina atẹm mi.”
\p 
\v 17 Ọnga itai mani awulu nga, “iSiman anọ iYohanna ingọ yọ mi?”
\p IBitrus kọng anang ka iYesu wulu nga sọ iritai, “Ingọ yọ mi?” Ava tẹri si, “Ate, ingọ ye umari nadidu; ingọ ye si imẹ yọ ngọ.”
\p IYesu va tẹri si, “Ma atẹm mi imila.
\v 18 Imẹ tẹri nu aipang, ushi ananọ ni usa ka sọmọ uma ka irinuma nu ka kyakwyi nu nọ kya nọ ọka mani inu wang; insi inu ya ba anọrapyi ni ọki nawa ivọ nọ, ace aghọ nga ki sọmọ nọ uma na nyeni nu ọka mani inu wang kya.”
\v 19 IYesu tẹri kindọ ka nyeni ighọ ukpo mani iBitrus ki ju ka jọọ Ọnọng. Ni ava tẹri nga si, “Yii mi!”
\p 
\v 20 IBitrus va tẹẹ ki nu aghọ yii iYesu mani ayoo sọ yii bọ. Anga shi aghọ yii iYesu ra mani atọrọ ki ikọ iYesu ka akua la imila ubulu. Anga wulu iyesu si, “Ate, inga ki gbra ngọ kọ?”
\v 21 IBitrus ya nu nga ni, ava wulu nga si, “Ate, ajiya ri ni?”
\p 
\v 22 IYesu va yira si, “Insi imẹ wang si aci akyọ si iya vuu, ikẹmbọ shi ẹmẹnẹ ngọ? Ingọ nọ yii mi.”
\v 23 Kaya udi ni ila nga kpa kwabi ọka shi anayuru si aghọ yii iYesu ri ki kpo ba. Ni iYesu ra tẹri si aki kpo nga ba; atẹri si, “Insi imẹ wang si aci akyọ si mẹ ya vuu ni, ikẹmbọ shi ẹmẹnẹ ngọ?”
\p 
\v 24 Anga shi aghọ yii iYesu ra mani atara kọ tumu uma ri ki va wọ bọ. Iyi ye si ọtẹri nga ni aipang nga.
\p 
\v 25 IYesu va ju uce nọ uma ikir. Ada wa si aki wọ akwikẹ ni, nadidu asing ki shi wu na ọbọọ mani aki ta awọ mani awọ kọ ba.
