\v 17 \w God|strong="H5414"\w* \w placed|strong="H5414"\w* these lights \w in|strong="H5921"\w* \w the|strong="H5921"\w* \w sky|strong="H8064"\w* \w to|strong="H5921"\w* shine \w upon|strong="H5921"\w* \w the|strong="H5921"\w* \w earth|strong="H8064"\w*,  
\v 18 \w to|strong="H3117"\w* \w be|strong="H3117"\w* \w in|strong="H3117"\w* \w charge|strong="H4910"\w* \w of|strong="H3117"\w* \w the|strong="H7200"\w* \w day|strong="H3117"\w* \w and|strong="H3117"\w* \w in|strong="H3117"\w* \w charge|strong="H4910"\w* \w of|strong="H3117"\w* \w the|strong="H7200"\w* \w night|strong="H3915"\w*, \w and|strong="H3117"\w* \w to|strong="H3117"\w* separate light \w from|strong="H3117"\w* \w darkness|strong="H2822"\w*. God \w saw|strong="H7200"\w* \w that|strong="H3588"\w* \w it|strong="H3588"\w* \w was|strong="H3117"\w* \w good|strong="H2896"\w*.  
\v 19 \w So|strong="H1961"\w* \w there|strong="H1961"\w* \w was|strong="H1961"\w* \w evening|strong="H6153"\w*, \w and|strong="H3117"\w* \w then|strong="H1961"\w* \w the|strong="H3117"\w* \w morning|strong="H1242"\w*, making \w day|strong="H3117"\w* four.   
\p
\v 20 \w God|strong="H8064"\w* said, “\w Let|strong="H5315"\w* \w the|strong="H6440"\w* \w waters|strong="H4325"\w* \w be|strong="H5315"\w* full \w of|strong="H6440"\w* \w living|strong="H2416"\w* \w creatures|strong="H2416"\w*, \w and|strong="H8064"\w* \w let|strong="H5315"\w* \w birds|strong="H5775"\w* \w fly|strong="H5774"\w* \w above|strong="H5921"\w* \w the|strong="H6440"\w* \w earth|strong="H8064"\w* \w in|strong="H5921"\w* \w the|strong="H6440"\w* \w sky|strong="H8064"\w*.”  
