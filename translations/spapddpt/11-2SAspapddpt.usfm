\v 21 Abner \w le|strong="H5921"\w* dijo: \w Apártate|strong="H5493"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w derecha|strong="H3225"\w* \w o|strong="H3068"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w izquierda|strong="H8040"\w*. Echa mano \w a|strong="H3068"\w* uno \w de|strong="H5921"\w* \w los|strong="H5921"\w* jóvenes \w y|strong="H5921"\w* \w toma|strong="H3947"\w* su despojo. Pero \w Asael|strong="H6214"\w* \w no|strong="H3808"\w* quiso dejar \w de|strong="H5921"\w* perseguirlo.
\p 
\v 22 \w Y|strong="H3068"\w* Abner \w volvió|strong="H3254"\w* \w a|strong="H3068"\w* decir \w a|strong="H3068"\w* \w Asael|strong="H6214"\w*: ¡Deja \w de|strong="H6440"\w* perseguirme! ¿\w Por|strong="H6440"\w* \w qué|strong="H4100"\w* debo herirte y derribarte \w a|strong="H3068"\w* tierra? ¿\w Cómo|strong="H4100"\w* \w levantaré|strong="H5375"\w* \w mi|strong="H5375"\w* \w rostro|strong="H6440"\w* \w ante|strong="H6440"\w* \w Joab|strong="H3097"\w* tu hermano?
\p 
\v 23 Pero \w como|strong="H1961"\w* \w él|strong="H3605"\w* \w no|strong="H3985"\w* quiso \w apartarse|strong="H5493"\w*, Abner \w lo|strong="H3605"\w* \w hirió|strong="H5221"\w* con \w el|strong="H3605"\w* casquillo \w de|strong="H8478"\w* \w la|strong="H3605"\w* \w lanza|strong="H2595"\w* \w por|strong="H8478"\w* \w la|strong="H3605"\w* quinta costilla, y \w la|strong="H3605"\w* \w lanza|strong="H2595"\w* le \w salió|strong="H3318"\w* \w por|strong="H8478"\w* \w la|strong="H3605"\w* espalda. \w Allí|strong="H8033"\w* \w cayó|strong="H5307"\w* y \w murió|strong="H4191"\w* \w en|strong="H3318"\w* \w el|strong="H3605"\w* \w mismo|strong="H3605"\w* \w sitio|strong="H4725"\w*. \w Sucedió|strong="H1961"\w* \w que|strong="H1961"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w que|strong="H1961"\w* llegaba \w al|strong="H8478"\w* \w lugar|strong="H4725"\w* \w donde|strong="H8033"\w* \w Asael|strong="H6214"\w* \w cayó|strong="H5307"\w* \w muerto|strong="H4191"\w*, \w se|strong="H1961"\w* detenía.
\p 
\v 24 Pero \w Joab|strong="H3097"\w* \w y|strong="H5921"\w* Abisai \w siguieron|strong="H7291"\w* tras Abner. \w Cuando|strong="H5704"\w* \w se|strong="H5921"\w* ocultó \w el|strong="H5921"\w* \w sol|strong="H8121"\w* \w ellos|strong="H1992"\w* llegaron \w a|strong="H3068"\w* \w la|strong="H5921"\w* colina \w de|strong="H5921"\w* Amá, \w que|strong="H5921"\w* \w está|strong="H1992"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* Gía, \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w camino|strong="H1870"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* región despoblada \w de|strong="H5921"\w* \w Gabaón|strong="H1391"\w*.
\v 25 \w Y|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Benjamín|strong="H1144"\w* \w se|strong="H1961"\w* agruparon detrás \w de|strong="H5921"\w* Abner \w y|strong="H5921"\w* formaron una sola tropa. \w Se|strong="H1961"\w* detuvieron \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w cumbre|strong="H7218"\w* \w de|strong="H5921"\w* una colina.
\p 
\v 26 \w Entonces|strong="H3588"\w* Abner \w gritó|strong="H7121"\w* \w a|strong="H3068"\w* \w Joab|strong="H3097"\w*: ¿Devorará \w la|strong="H3588"\w* \w espada|strong="H2719"\w* \w para|strong="H5704"\w* siempre? ¿\w No|strong="H3808"\w* \w sabes|strong="H3045"\w* \w que|strong="H3588"\w* \w al|strong="H5704"\w* final \w habrá|strong="H1961"\w* \w amargura|strong="H4751"\w*? ¿\w Hasta|strong="H5704"\w* \w cuándo|strong="H3588"\w* \w te|strong="H3588"\w* tardas \w en|strong="H5704"\w* \w decir|strong="H7121"\w* \w al|strong="H5704"\w* \w pueblo|strong="H5971"\w* \w que|strong="H3588"\w* deje \w de|strong="H3588"\w* perseguir \w a|strong="H3068"\w* sus hermanos?
\p 
\v 27 \w Y|strong="H3068"\w* \w Joab|strong="H3097"\w* contestó: \w Vive|strong="H2416"\w* \nd ʼElohim\nd* \w que|strong="H3588"\w* \w si|strong="H3588"\w* \w no|strong="H3884"\w* hubieras \w hablado|strong="H1696"\w*, \w ciertamente|strong="H3588"\w* \w el|strong="H3588"\w* \w pueblo|strong="H5971"\w* \w no|strong="H3884"\w* hubiera dejado \w de|strong="H3588"\w* perseguir \w a|strong="H3068"\w* \w su|strong="H3588"\w* prójimo hasta \w la|strong="H3588"\w* \w mañana|strong="H1242"\w*.
\p 
\v 28 \w Joab|strong="H3097"\w* \w ordenó|strong="H5975"\w* sonar \w la|strong="H3605"\w* \w corneta|strong="H7782"\w* y \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w se|strong="H3808"\w* detuvo. \w No|strong="H3808"\w* \w persiguieron|strong="H7291"\w* \w más|strong="H5750"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* \w ni|strong="H3808"\w* continuaron \w la|strong="H3605"\w* lucha.
\p 
\v 29 Abner y \w sus|strong="H1931"\w* hombres \w caminaron|strong="H3212"\w* por \w el|strong="H1931"\w* Arabá \w toda|strong="H3605"\w* \w aquella|strong="H1931"\w* \w noche|strong="H3915"\w*, y al cruzar \w el|strong="H1931"\w* \w Jordán|strong="H3383"\w* marcharon por \w todo|strong="H3605"\w* \w el|strong="H1931"\w* \w Bitrón|strong="H1338"\w* y llegaron \w a|strong="H3068"\w* \w Mahanaim|strong="H4266"\w*.
