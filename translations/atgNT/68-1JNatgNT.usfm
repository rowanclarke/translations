\id 1JN - Okphela 
\h 1 iJọni 
\toc1 1 iJọni 
\toc2 1 iJọni 
\toc3 1 iJọn 
\mt2 Ebe onododẹ ni 
\mt1 IJọni 
\mt2 Ọ kẹkẹ 
\c 1  
\s1 Ungmemhi ni o mhọli agbọ 
\p  
\v 1 Anye kẹkẹ ungmemhi oyi ọni ọ ri agbọ ọ na ọgbọ ghi ẹ, ọni ọ rọte igbaekẹle la ọ. Anye she suọ ọli, anye ri alo eyi anye mẹ ọli, anye bino ọli, anye gbo ri abọ eyi anye ti ọli.\f + \fr 1:1 \ft Li zẹ \fq iJọn 1.1\f* 
\v 2 Abi ọni ọ ri agbọ ọ na ọgbọ ọna ọ rọ feli lasele, anye mẹ ọli, anye gbo li pfi ọtsẹlẹ shi ọni agbọ na agbọagbọ ọna. Lọli ọ nu Ita la, ni a rọkhasẹ anye.\f + \fr 1:2 \ft Li zẹ \fq iJọn 1.14\f* 
\v 3 Emini anye mẹ ni anye suọ, anye gbo liẹ gueyẹ ẹ, isheghọ ni awa kugbe nu Ita ali Omi ọli iJesu iKirisiti la.  
\v 4 Eri anye kẹkẹ ona ni oghẹlẹ oyawa o gba pfo. 
\s1 Okiali elemhi ákpá 
\p  
\v 5 Onana khi usomhi ni anye rọte obọ oyi Omi ọli suọ, ni anye gue ẹ yẹ ẹ khi, Ẹshinẹgba khi ákpá, obili okhọghuo ọa fẹ la li egbe kpa.  
\v 6 Awa kha guele khi awa nu ọli la kugbe ni awa rọ kie la elemhi alo ebili ẹ kia, ẹgbhọli awa lo, awa aa la agbọ igẹsikia.  
\v 7 Ama ini awa la elemhi ákpá a kia, abi lọli ọli la elemhi ákpá, ona o rọkhasẹ khi awa nu ọli la kugbe, isheghọ ọlia eyi iJesu Omi ọli, e khuẹsẹ awa olamhẹ-a pfuasẹ.  
\v 8 Ini awa guele khi awa aa mhọli olamhẹ, egbawa awa a di, awa aa mhọli igẹsikia.  
\v 9 Ama ini awa zọnọ olamhẹ eyawa ye Ẹshinẹgba ni ọ ri igẹsikia riẹlẹ emhikpa; ọni ọọ riẹlẹ emini o te odẹ ọ khi, ọ ya ri olamhẹ eyawa topfa awa, ọ khuẹsẹ awa umha-pfuasẹ egbe-a nya.  
\v 10 Ini awa ẹ khi awa aa lamhẹ, eri awa ri Ẹshinẹgba mele ọlo-ẹgbhọli-a. Ungmemhi oyọli ọa la agbọ oyawa. 
\c 2  
\s1 IKirisiti, ọkpaghiobọ ọyawa 
\p  
\v 1 Eniyẹ eyẹmhẹ, ẹẹ mhi kẹkẹ ebe ona ghi, ini a khi lamhẹ. Ama, ini a bhale ya ẹ khi ọgbọkhọghuo ọ lamhẹ, awa mhọli ọni ọ nu Ita a ngme khẹ awa shi ekẹ. Lọli khi iJesu iKirisiti ọni ọ pfuasẹ.  
\v 2 Lọli ọ khi iluasobo ni a rọ shishi olamhẹ eyawa-a, ọa khi eyawa tsẹ ama olamhẹ eyi ẹgbọ kpa. 
\p  
\v 3 Ini awa ri omhẹsẹ eyọli ẹ gbe akanya, lọli awa rọ ya lẹsẹ gboo khi awa lẹsẹ ọli.  
\v 4 Eni liẹ khi wẹwẹ e lẹsẹ ọli ni ẹa ri omhẹsẹ eyọli ẹ gbe akanya, elo-ẹgbhuẹ e khi, ẹa mhọli igẹsikia.  
\v 5 Ama ọnini ọ da ri ungmemhi oyọli da gbe akanya ne, inono oyi Ẹshinẹgba o gba shi ọli egbe. Ina awa li ya lẹsẹ khi awa ali Ẹshinẹgba khi ọghuo awa khi.  
\v 6 Eni e da liẹ khi wẹwẹ e kugbe Ẹshinẹgba ọ ne, e mema ya ke ngeli abi iJesu iKirisiti ọ liẹ ngeli. 
\s1 Ushi onogbọ 
\p  
\v 7 Emọle mhẹ, ọa khi omhẹsẹ olese mhi kẹkẹ ẹ ghi ẹ, ama onodiọ lọ, ikhi oni a rọte igbaekẹle rọ na ẹ. Oni omhẹsẹ onodiọ ona o khi oni usomhi ni a she kpẹ suọ.\f + \fr 2:7 \ft Li zẹ \fq iJọn 13.34\f* 
\v 8 Aboriẹkhi ighọ, omhẹsẹ onogbọ mhi kẹkẹ ẹ ghi ẹ, irari khi a mẹ igẹsikia oyi oni omhẹsẹ ona iJesu egbe, a gbo mẹ ọli agbọ oyẹẹ. Itobọ khi obili o shẹ ẹ kalaa, oni ákpá oyi igẹsikia o she ẹ gẹ.  
\v 9 Ọnini ọ da liẹ khi lọli la elemhi ákpá ni ọọ biselemhi inyọghuo ọli ne, elemhi alo obili ọ kie la.  
\v 10 Ọnini ọ da nono ingme oyi inyọghuo ọli ne, elemhi ákpá ọ la, emhikhọghuo ọa la li egbe ni o rọli ya khi owẹ.  
\v 11 Ama ọnini ọ da biselemhi inyọghuo ọli ne, alo obili ọ la, alo obili ọ la kia gasẹ. Ọa lẹsẹ obini ọọ je, irari khi obili o she zuse ọli alo. 
\q1  
\v 12 Mhi kẹkẹ ebe ona ghi ẹ eniyẹ, 
\q2 itobọ khi a she ri olamhẹ topfa ẹ 
\q2 itobọ eva oyi iKirisiti. 
\q1  
\v 13 Mhi kẹkẹ ebe ona ghi ẹ, ẹẹ ita, 
\q2 itobọ khi a she lẹsẹ ọli, 
\q2 ọni ọ rọte igbaekẹle la ọ. 
\q1 Mhi kẹkẹ ebe ona ghi ẹ ozele, 
\q2 itobọ khi a she mu 
\q2 Ọni ọ khi Ọgbọ-ọbe ọ le. 
\q1 Mhi kẹkẹ ebe ghi ẹ eniyẹ, 
\q2 itobọ khi a she lẹsẹ ọni Ita. 
\q1  
\v 14 Mhi kẹkẹ ebe ghi ẹ, ẹẹ ita, 
\q2 itobọ khi a she lẹsẹ ọli, 
\q2 ọni ọ rọte igbaekẹle la ọ. 
\q1 Mhi kẹkẹ ebe ona ghi ẹ ezele, 
\q2 itobọ khi a mhọli ekpabọ, 
\q1 ali khi ungmemhi 
\q2 oyi Ẹshinẹgba o la 
\q2 elemhi oyẹ ẹ, 
\q1 ali khi a she mu 
\q2 Ọni ọ khi Ọgbọ-ọbe ọ le. 
\s1 Agbọ ona o khi ghọle ẹ dọsẹ 
\p  
\v 15 Agbọ ona o khi ghọle ẹ dọsẹ, wẹkhi emhikhọghuo ni e la ọ. Ini ọgbọkhọghuo ọ mhọli ọghuẹmhẹ na agbọ, inono oyi Ita ọa la agbọ oyọli.  
\v 16 Irari emhikpa ni e la elemhi agbọ, ni e khi, ọghuẹmhẹ olamhẹ idiegbe, emini ukpẹloe o viẹ shi, ali itipfuabọ-nga shi emini ọ mhọli ali ni ọ dobẹ ẹ riẹlẹ. Okhọghuo ena nya ẹa rọte obọ oyi Ita bhale, ama agbọ ona e te bhale.  
\v 17 Oni agbọ ona ali emini e la ọ ni ẹẹ ghọle ẹgbọ e she ẹ dọsẹ, ama eni ẹ riẹlẹ ọghuẹmhẹ oyi Ẹshinẹgba e ya la ọ agbọagbọ. 
\s1 Eni ẹẹ khọli iKirisiti 
\p  
\v 18 Eniyẹ, ukpẹsẹ agbọ o she ti bhale! A she gueyẹ ẹ khi ọni ọ khọli Ọmiepfuese ọ ya bhale, memena eni ẹẹ khọli Ọmiepfuese ebubu e she bhale agbọ. Onana awa rọ ya lẹsẹ khi ukpẹsẹ agbọ o she ti bhale.  
\v 19 Eni ẹgbọ ena ẹa mema kie kpẹ khi eyawa, lọli o zẹ khi e rọte awa iteva vu. Ini e kie kpẹ khi eyawa lọ, e kha migha. Ama eri uvumhi oyẹwẹ o rọkhasẹ khi ẹa ku ma awa ọ. 
\p  
\v 20 Ama Ọmiepfuese, Ọni ọ pfuasẹ ọ she zẹ ẹ, irarighọ a she lẹsẹ igẹsikia.  
\v 21 Ọa khi itobọ khi aa lẹsẹ igẹsikia mhi rọ kẹkẹ ebe ona ghi ẹ, ama itobọ khi a lẹsẹ igẹsikia, a gbo lẹsẹ khi ẹgbhọli ọa rọte igẹsikia a lasele. 
\p  
\v 22 Mena, ọghuo ọ khi ọlo-ẹgbhuẹ? Ọni ọọ khi iJesu ọa khi ọni Ọmiepfuese, lọli ọ khi Ọbe vule shi Ọmiepfuese ọ, lọli ọ kie Ita ali Ọmọ.  
\v 23 Aa mẹ ọgbọkhọghuo ni ọ kie Ọmọ ni ọ mhọli Ita. Ọni ọ da mie-obọ shi Ọmọ ọ, ọ li mhọli Ita. 
\p  
\v 24 Zobẹ ni emini u rọte ekẹ suọ o kie lẹ egbe. Ini o lighọ kie lẹ egbe, u ya li kie nu ọni Ọmọ ali Ita la kugbe.  
\v 25 Emini ọ shobọ na wa na, ikhi agbọ na agbọagbọ. 
\p  
\v 26 Ingme eyi ẹgbọ eni ẹ nono ni wẹwẹ e yẹsẹ ẹ da odẹ mhi kẹkẹ ẹ ghi ẹ.  
\v 27 Ama ẹẹ oyẹ ẹ, ekpabọ Ayẹmhẹ nọ pfuasẹ ni a mie, o kie la ẹ egbe, irarighọ, aa ke khi eni a sẹsẹ. Ama eri Ayẹmhẹ oyọli ọọ sẹsẹ ẹ emhikpa, ikhi emini e khi igẹsikia ni ẹa khi ẹgbhọli. A ri osẹsẹ oyi Ayẹmhẹ ke gbe akanya, a kie nu ọli la kugbe. 
\s1 Imi Ẹshinẹgba 
\p  
\v 28 Mena, eniyẹ, a kie kugbe ọli ọ. Isheghọ ini ọ feli lasele, awa mhọli igbedu ni omama ọa mu awa odalo oyọli, ini ọ nyenẹ egbe bhale. 
\p  
\v 29 Ini u lẹsẹ khi iKirisiti khi ọni ọ migha shi ipfuasẹ ọ khi, lẹsẹ khi ọni ọ riẹlẹ emini e te odẹ Omi Ẹshinẹgba ọ khi. 
\c 3  
\p  
\v 1 A bino abi inono ni Ita awa ọ nono awa o li fu ramhi, ni a rọ bhale ya ẹ khi àá lu awa imi Ẹshinẹgba! Ni o khia khi ighọ awa khi! Emini o zẹ khi ẹgbọ na agbọ ẹa lẹsẹ awa khi, ẹa lẹsẹ Ẹshinẹgba.\f + \fr 3:1 \ft Li zẹ \fq iJọn 1.12\f* 
\v 2 Emọle mhẹ, imi Ẹshinẹgba awa khi, ama, awa aa lẹsẹ ne, abi awa ya li, ama awa lẹsẹ khi ini iKirisiti ọ lasele, awa ya li abi lọli, irari khi awa ya mẹ ọli abi ọ li tee.  
\v 3 Ọgbọkpa ni ọ da mhọli irudushi ona ne, ọọ mhọli oni ọghuẹmhẹ ni ọ rọ khi ọni ọ pfuasẹ abi iKirisiti ọ li pfuasẹ. 
\p  
\v 4 Ọnini ọ da lamhẹ ne, eri ọ gbe ushi oyi Ẹshinẹgba-a, irari khi olamhẹ, igbushi oyi Ẹshinẹgba-a o khi.  
\v 5 Ama u lẹsẹ khi eri iKirisiti ọ bhale ni ọ ya rue olamhẹ eyawa vu, ali khi olamhẹ ọa la li egbe.\f + \fr 3:5 \ft Li zẹ \fq iJọn 1.29\f* 
\v 6 Irarighọ, ọgbọkpa ni ọ nu ọli la kugbe, ọa ya lamhẹ ke lẹ. Ọnini ọ kie da la olamhẹ ne, ọa fẹ mẹ ọli ghue wẹkhi eri ọ lẹsẹ ọli. 
\p  
\v 7 Eniyẹ, a khi zẹ ni ọgbọkhọghuo ọ di ẹ ya de odẹ-a. Ọni ọ da riẹlẹ emini o te odẹ ne, ọ pfuasẹ, ẹzẹzẹ abi iKirisiti ọ li pfuasẹ.  
\v 8 Ọnini ọ da riẹlẹ emhi olamhẹ ne, ọyi Ọkphaghiẹ ọ khi. Irari khi te-ekẹ vu, ọkphaghiẹ ọ te ẹ lamhẹ. Emini o zẹ ni Omi Ẹshinẹgba ọ rọ feli bhale khi, ni ọ rọ mẹ asha pfuẹchẹ ikanya eyi ọkphaghiẹ-a.  
\v 9 Ọgbọkpa ni ọ da khi Omi Ẹshinẹgba ọ ya lamhẹ, irari khi ukpamhi oyi Ẹshinẹgba o la li egbe, ẹa ya lamhẹ irari khi Ẹshinẹgba ọ khi Ita wẹ.  
\v 10 Onana o ri ikhiọda shi iteva imi Ẹshinẹgba ali imi Ọkphaghiẹ. Enieni ẹa da riẹlẹ emini o te odẹ ne ali ni ẹa mhọli inono na ẹgbọẹse ne, ẹa khi imi Ẹshinẹgba. 
\s1 A nono ingme oyi egbe ẹ 
\p  
\v 11 Onana o khi usomhi ni a rọte ekẹ suọ. Ikhi, awa nono ingme oyi egbe awa.\f + \fr 3:11 \ft Li zẹ \fq iJọn 13.34\f* 
\v 12 Khi li abi iKeni ni ọ khi ọyi Ọna Ọkhọlọ, ni ọ gbe Ebẹli inyọghuo ọli-a. Elọ o zẹ ni iKeni ọ rọ gbe ọli-a? Irari khi emini ọni iKeni ọọ riẹlẹ, ẹa gbe akanya, ama emini inyọghuo ọli ọọ riẹlẹ e khi eni e pfuasẹ.\f + \fr 3:12 \ft Li zẹ \fq Igbae 4.8\f* 
\v 13 Irarighọ, o khi sha ẹ abọ, inyọghuo-mhẹ eni emọse ali eni ikpotso, ini ẹgbọ na agbọ ẹa ti elemhi ẹ.  
\v 14 Awa lẹsẹ khi awa she te eghuli lasele je agbọ, itobọ khi awa nono ingme oyi inyọghuo awa. Ọnini ọa da mhọli inono ne, elemhi eghuli ọ kie la.\f + \fr 3:14 \ft Li zẹ \fq iJọn 5.24\f* 
\v 15 Ọnini ọ da biselemhi inyọghuo ọli ne, ọgbọ-ugbeli ọ khi. U lẹsẹ khi ọgbọ-ugbeli ọa mhọli agbọ oyi Ẹshinẹgba shi agbọ oyọli. 
\p  
\v 16 Ina awa liẹ lẹsẹ emini inono o khi. Eri iJesu iKirisiti ọ ri agbọ oyọli bhale, ni e pfuse-a, shi itobọ oyawa. Awa kha li rue agbọ oyawa li shi ekẹ na inyọghuo awa.  
\v 17 Ini ọgbọ ọ mhọli ẹpfue, ni ọ rọ mẹ khi inyọghuo ọli ọ mhọli emini o to ọli, ni ọa rọ mhọli ilẹlemhi na li, sẹẹ ọ li dobẹ ya liẹ khi lọli mhọli inono oyi Ẹshinẹgba?  
\v 18 Eniyẹ, a khi zẹ ni awa ri ungmemhi ali ẹlẹmhi ke riẹlẹ inono, ama awa ri iriẹlẹ ali igẹsikia ke ri inono khasẹ.  
\v 19 Ini awa nono ingme oyi ẹgbọẹse, awa lẹsẹ khi igẹsikia awa la kia, awa mhọli udu opfọmhẹ odalo oyi Ẹshinẹgba.  
\v 20 Abi eni e miesuọ, ini udu oyawa o pfa ẹzọ mu awa, awa lẹsẹ khi Ẹshinẹgba ọ fu dọsẹ udu oyawa, ali khi ọ lẹsẹ emhikpa.  
\v 21 Irarighọ, emọle mhẹ, ini udu oyawa ọa da pfa ẹzọ mu awa ne, lọli awa rọọ mhọli igbedu odalo oyi Ẹshinẹgba.  
\v 22 Emiemini awa da mhila kpa, awa te obọ oyọli ya mie ọli, itobọ khi awa ri ishi eyọli ẹ gbe akanya ali khi awa a riẹlẹ emini e ghọle ọli.  
\v 23 Emini ọ mhẹsẹ na awa khi, awa mie Omi ọli iJesu iKirisiti suọ, ali awa nono ingme oyi egbe, ẹzẹzẹ abi iKirisiti ọ li mhẹsẹ na awa.\f + \fr 3:23 \ft Li zẹ \fq iJọn 13.34; 15.12,17\f* 
\v 24 Eni e ri omhẹsẹ oyi Ẹshinẹgba a gbe akanya, eri wẹwẹ ali Ẹshinẹgba e ga kugbe, Ẹshinẹgba ọ li kugbe wẹ ọ. Itobọ Ayẹmhẹ ni Ẹshinẹgba ọ rọ na awa, awa rọ lẹsẹ khi awa kugbe Ẹshinẹgba ọ. 
\c 4  
\s1 Ke mu Iyẹmhẹ fẹ bino 
\p  
\v 1 Emọle mhẹ, a khi mie shi iyẹmhẹ nya ọ, ama mu wẹ fẹ bino ni a mẹ ini obọ oyi Ẹshinẹgba e te bhale. Irari khi emekẹguele eyi ẹgbhọli ebubu e she fiẹ lasele shi agbọ ona.  
\v 2 Ina a li ya lẹsẹ ini Ayẹmhẹ oyi Ẹshinẹgba lọ: Ayẹmhẹ nya ni o da lama khi iJesu iKirisiti ọ she bhale abi ọgbọ ne, oyi Ẹshinẹgba lọ.  
\v 3 Ama ayẹmhẹ nya ni ọa da mie-obọ shi iJesu ọ ne, ọa rọte obọ oyi Ẹshinẹgba bhale. Onana o khi ayẹmhẹ oyi ọni ọ khọli Ọmiepfuese, ni a suọ khi ọọ bhale, o she ga la elemhi agbọ memena.  
\v 4 Ama enayi Ẹshinẹgba a khi, imi mhẹ, a she gbo mu emekẹguele eyi ẹgbhọli ọ le, irari khi Ayẹmhẹ ni o la ẹ egbe o fu dọsẹ oyi ọni ọ la elemhi agbọ.  
\v 5 Elemhi agbọ eni emekẹguele eyi ẹgbhọli eghọ e rọte lasele, ingmemhi agbọ ẹẹ ngme, irarighọ ẹgbọ agbọ e rọ mie shi emini ẹẹ ngme.  
\v 6 Ama enayi Ẹshinẹgba awa khi. Ọnini ọ da lẹsẹ Ẹshinẹgba, lọli ọ ri esọ ọ shi emini anye ẹ ngme. Ọni ọa da khi ọyi Ẹshinẹgba ne, ọa ya ri esọ shi emini anye ẹ ngme. Ina awa liẹ lẹsẹ ikhiọda ni o la Ayẹmhẹ igẹsikia ali ayẹmhẹ ẹgbhọli. 
\s1 Ẹshinẹgba inono ọ khi 
\p  
\v 7 Emọle mhẹ, a zẹ ni awa nono ingme egbe, irari khi obọ oyi Ẹshinẹgba inono o te bhale. Ọni ọ da mhọli inono, Ẹshinẹgba ọ khi itali ali khi ọ lẹsẹ Ẹshinẹgba.  
\v 8 Ọgbọ ni ọa da mhọli inono ne, ọa lẹsẹ Ẹshinẹgba, irari khi Ẹshinẹgba khi inono.  
\v 9 Eri Ẹshinẹgba ọ ri Omi ọli ọtuọghuo kpe ni ọ ghie bhale agbọ rọ ri inono ni ọ mhọli na awa khasẹ, ini awa a rọte obọ oyọli mhọli agbọ.  
\v 10 Onana o khi egbegbi inono, ọa khia khi eri awa nono ingme oyi Ẹshinẹgba, ama eri ọ nono ingme oyawa, lọli o zẹ ni ọ rọ ghie Omi ọli bhale ni ọ rọ luasẹ obo rọ shishi olamhẹ eyawa.  
\v 11 Emọle mhẹ, ini o khia khi ina Ẹshinẹgba ọ li nono awa, awa li nono ingme egbe awa.  
\v 12 Ọgbọkhọghuo ọa mẹ Ẹshinẹgba ghue, ama ini awa nono ingme egbe awa, Ẹshinẹgba ọ la agbọ oyawa, ali khi, inono oyọli ọọ gbe akanya ni ọ nono ni lọli gbe agbọ oyawa.\f + \fr 4:12 \ft Li zẹ \fq iJọn 1.18\f* 
\p  
\v 13 Awa ga lẹsẹ khi Ẹshinẹgba ọ la agbọ oyawa, irari khi ọ she ri Ayẹmhẹ oyọli na awa.  
\v 14 Ali khi awa mẹ, awa gbo pfi ọtsẹlẹ khi Ita ọ ghie Omi ọli ni ọ rọ khi Ọmiepfuese ọyi agbọ.  
\v 15 Ini ọgbọkhọghuo ọ mie shi ọ khi Omi Ẹshinẹgba iJesu ọ khi, Ẹshinẹgba ọ la agbọ oyọli, lọli ọ li la elemhi Ẹshinẹgba  
\v 16 Isheghọ, awa lẹsẹ, awa gbo mie shi inono ni Ẹshinẹgba ọ mhọli na awa. 
\p Inono Ẹshinẹgba ọ khi, eni e la agbọ inono e nu Ẹshinẹgba la kugbe, Ẹshinẹgba ọ li nu wẹ la kugbe.  
\v 17 Ina inono oyọli o liẹ gbe akanya ni ọ nono ni lọli gbe agbọ oyawa, ni awa rọ mhọli igbedu ogbẹlẹ iguẹzọ, irari khi eri awa li abi lọli ekagbọ ona.  
\v 18 Ulishi ọa la inono. Ama eri inono ni o gba pfo, ọọ khu ulishi fiẹ, irari khi eri ẹgbọ ẹẹ na ulishi Ẹshinẹgba itobọ khi ọ ya na wẹ osoli. Ọni ọọ na ulishi ọa gba pfo elemhi inono. 
\p  
\v 19 Eri awa mhọli inono, itobọ khi lọli ọ kpe nono ingme oyawa.  
\v 20 Ini ọgbọkhọghuo ọọ liẹ, “Mhi nono ingme oyi Ẹshinẹgba,” ama ọ kiele ẹ biselemhi inyọghuo ọli, ọloẹgbhuẹ ọ khi. Irari khi ọgbọ ni ọa da nono ingme oyi inyọghuo ọli ni ọọ mẹ ẹloe, ọa dobẹ ya nono ingme oyi Ẹshinẹgba ni ọa mẹ ẹloe ghue.  
\v 21 Omhẹsẹ ni iKirisiti ọ rọ na awa na: Eni e nono ingme oyi Ẹshinẹgba nya, e mema li nono ingme oyi inyọghuo wẹ. 
\c 5  
\s1 Imuọle ni awa mu agbọ ọ le 
\p  
\v 1 Ọnini ọ da mie shi ọ ne khi iJesu ọ khi ọni iKirisiti Ọmiepfuese, Omi Ẹshinẹgba ọ khi, Ọnini ọ da nono ingme oyi Ita ne, ọ li nono ingme oyi omi ọli.  
\v 2 Abi awa liẹ lẹsẹ khi awa nono ingme oyi imi Ẹshinẹgba khi, ini awa nono ingme oyi Ẹshinẹgba, ni awa gbo rọ ri omhẹsẹ oyọli gbe akanya.  
\v 3 Ini awa nono ingme oyi Ẹshinẹgba egbegbọ, awa mema ya ri omhẹsẹ oyọli gbe akanya. Ama omhẹsẹ eyọli ẹa ya mu unu irọgbe-akanya.\f + \fr 5:3 \ft Li zẹ \fq iJọn 14.15\f* 
\v 4 Itobọ khi ọgbọkpa ni Ẹshinẹgba ọ bia, lọli ọ dobẹ ya mu agbọ ọ le, irudunga oyawa o khi oni imuọle.  
\v 5 Ọghuo ọ dobẹ mu agbọ ọọ le? Sẹ ni ọgbọ ni ọ miesuọ khi, iJesu khi Omi Ẹshinẹgba. 
\p  
\v 6 Ọna khi iJesu iKirisiti ni ọ bhale, rọte iri-amẹ-batazi, ali rọte ọlia ikushiekẹ abi ọ rọ ghua. Ọa khi rọte amẹ tsẹ, ama li shi ọlia ni ọ ku shi ekẹ abi ọ rọ ghua. Ayẹmhẹ ọ pfi ọtsẹlẹ shi ọ, irari khi ọni Ayẹmhẹ ọyi igẹsikia lọ.  
\v 7 Irari khi ọtsẹlẹ esẹ e la ọ.  
\v 8 Ayẹmhẹ, amẹ, ali ọlia. Eni ọtsẹlẹ esẹ ena unu oghuo ee ngme.  
\v 9 Ọtsẹlẹ ọyi agbọ awa mie ẹ suọ, ama ọtsẹlẹ ọyi Ẹshinẹgba ọ toto ne. Ọ she pfi ọtsẹlẹ shi ingme oyi Omi ọli  
\v 10 Irarighọ, ọgbọkpa ni ọ mie Omi Ẹshinẹgba suọ nya, ọ mhọli ọtsẹlẹ onana shi udu oyọli. Ama ọni ọa mie Ẹshinẹgba suọ, eri ọ rọli shi ọlo-ẹgbhọli, itobọ khi ọa mie shi emini Ẹshinẹgba ọ ngme shi ingme oyi Omi ọli.  
\v 11 Oni ọtsẹlẹ o khi Ẹshinẹgba ọ she ri agbọ na agbọagbọ na awa. Oni agbọ ona o la obọ oyi Omi ọli.\f + \fr 5:11 \ft Li zẹ \fq iJọn 3.36\f* 
\v 12 Irarighọ, ọni ọ da kugbe Omi Ẹshinẹgba ọ ne, lọli ọ mhọli oni agbọ oyi Ẹshinẹgba ona. Ọni ọa da kugbe Omi Ẹshinẹgba ọ ne, ọa mhọli agbọ oyi Ẹshinẹgba. 
\p  
\v 13 Mhi she kẹkẹ emhikpa shi elemhi ebe ona ghi ẹ, ni a mie iJesu Omi Ẹshinẹgba suọ, ni a rọ mhọli ọli shi udu khi a mhọli agbọ oyi Ẹshinẹgba.  
\v 14 Igbe-udu ni awa a mhọli ini awa la odalo oyi Ẹshinẹgba a sọ iromhi khi, awa lẹsẹ khi ẹghẹghẹ kpa ni awa rọ mhila li emhikhọghuo abi o ghọle ọli shi, eri ọọ suọ awa ọ.  
\v 15 Irarighọ, abi awa rọ da lẹsẹ khi ọọ suọ awa ini awa da mhila emhi ne, awa lẹsẹ khi awa she mhọli emini awa mhila li. 
\p  
\v 16 Ini ọgbọkhọghuo ọ mẹ khi inyọghuo ọli ọọ lamhẹ olamhẹ ni ọa ri eghuli gbe ọgbọ, ọ lema na li, khi Ẹshinẹgba ya ri agbọ nali. Eni olamhẹ oyẹwẹ e khi olamhẹ ni ẹa ri eghuli gbe ọgbọ mhia ngme. Olamhẹ o la ọ ni o ri eghuli ẹ gbe ọgbọ. Ọa khi olamhẹ eghọghọ mhiẹ a lema shi.  
\v 17 Umha-guẹli kpa, olamhẹ o khi. Ama olamhẹ o la ọ ni ọa ya ri eghuli gbe ọgbọ.  
\v 18 Awa lesẹ khi ọni Ẹshinẹgba ọ bia, ọa ya lamhẹ olamhẹ, irari khi eri Omi Ẹshinẹgba ọ khukhu ọli, ini Ọkphaghiẹ ọ khi dobẹ li ọli onobe.  
\v 19 Awa lẹsẹ khi imi Ẹshinẹgba awa khi, ali khi Ọkphaghiẹ ọ mhẹsẹ ẹ na ẹgbọ nya ni ẹa lẹsẹ Ẹshinẹgba.  
\v 20 Awa gbo lẹsẹ khi Omi Ẹshinẹgba ọ she bhale elemhi agbọ, ali khi ọ she ri ilẹsẹ ni awa rọ lẹsẹ ọni egbegbi Ẹshinẹgba. Ali khi awa kugbe ọni Ẹshinẹgba ni ọ khi igẹsikia ọ, ighọ awa gbo li kugbe iJesu iKirisiti ni ọ khi Omi ọli ọ. Lọlighuo kpe ọ khi egbegbi Ẹshinẹgba, ali oni agbọ na agbọagbọ.  
\v 21 Eniyẹ eyẹmhẹ, a mu egbe ẹ. A khi mhọli emini e ku ẹ ali ilitsa gbe.