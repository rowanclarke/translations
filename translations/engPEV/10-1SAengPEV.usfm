\c 22
\s1 Saul told the soldiers to kill the men that look after God’s ceremonies
\p 
\v 9 \w That|strong="H7200"\w* \w man|strong="H1121"\w* \w Doeg|strong="H1673"\w*, \w from|strong="H5921"\w* Edom, \w he|strong="H1931"\w* \w went|strong="H7586"\w* back \w and|strong="H1121"\w* told \w Saul|strong="H7586"\w*, “\w I|strong="H5921"\w* \w saw|strong="H7200"\w* David \w at|strong="H5921"\w* \w Nob|strong="H5011"\w*. \w He|strong="H1931"\w* \w went|strong="H7586"\w* \w to|strong="H5921"\w* \w see|strong="H7200"\w* \w that|strong="H7200"\w* \w old|strong="H1121"\w* \w man|strong="H1121"\w* Ahimelek, Ahitub’s \w son|strong="H1121"\w*.
