\v 22 \w Y|strong="H3068"\w* \w Samuel|strong="H8050"\w* respondió: ¿\nd \w Yavé|strong="H3068"\w*\nd* se complace \add tanto\add* en \w holocaustos|strong="H5930"\w* y \w sacrificios|strong="H2077"\w* como en la obediencia \w a|strong="H3068"\w* la \w voz|strong="H6963"\w* de \nd \w Yavé|strong="H3068"\w*\nd*? \w Ciertamente|strong="H2009"\w* el \w obedecer|strong="H8085"\w* es \w mejor|strong="H2896"\w* que los \w sacrificios|strong="H2077"\w*, y el prestar atención es \w mejor|strong="H2896"\w* que la grasa de los carneros.
\v 23 \w Porque|strong="H3588"\w* \w como|strong="H3588"\w* \w pecado|strong="H2403"\w* \w de|strong="H3588"\w* brujería \w es|strong="H3588"\w* \w la|strong="H3588"\w* rebeldía, \w y|strong="H3588"\w* \w la|strong="H3588"\w* obstinación, \w como|strong="H3588"\w* \w la|strong="H3588"\w* idolatría \w y|strong="H3588"\w* \w el|strong="H3588"\w* culto \w a|strong="H3068"\w* imágenes. \w Porque|strong="H3588"\w* tú \w desechaste|strong="H3988"\w* \w la|strong="H3588"\w* \w Palabra|strong="H1697"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w Él|strong="H3588"\w* también \w te|strong="H3588"\w* \w desechó|strong="H3988"\w* \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w no|strong="H3588"\w* seas \w rey|strong="H4428"\w*.
\p 
\v 24 \w Saúl|strong="H7586"\w* respondió \w a|strong="H3068"\w* \w Samuel|strong="H8050"\w*: \w Pequé|strong="H2398"\w*. \w Ciertamente|strong="H3588"\w* quebranté \w el|strong="H3588"\w* \w Mandamiento|strong="H6310"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w y|strong="H3588"\w* tus \w palabras|strong="H1697"\w*, \w porque|strong="H3588"\w* \w temí|strong="H3372"\w* al \w pueblo|strong="H5971"\w* \w y|strong="H3588"\w* obedecí \w la|strong="H3588"\w* \w voz|strong="H6963"\w* \w de|strong="H3588"\w* ellos.
\v 25 \w Ahora|strong="H6258"\w* \w te|strong="H5973"\w* \w ruego|strong="H4994"\w* \w que|strong="H6258"\w* \w perdones|strong="H5375"\w* \w mi|strong="H5375"\w* \w pecado|strong="H2403"\w* y \w vuelvas|strong="H7725"\w* \w conmigo|strong="H5973"\w* \w para|strong="H5973"\w* \w que|strong="H6258"\w* \w yo|strong="H4994"\w* pueda postrarme ante \nd \w Yavé|strong="H3068"\w*\nd*.
\p 
\v 26 \w Samuel|strong="H8050"\w* dijo \w a|strong="H3068"\w* \w Saúl|strong="H7586"\w*: \w No|strong="H3808"\w* \w volveré|strong="H7725"\w* \w contigo|strong="H5973"\w*, \w porque|strong="H3588"\w* \w desechaste|strong="H3988"\w* \w la|strong="H5921"\w* \w Palabra|strong="H1697"\w* \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w y|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w te|strong="H5921"\w* \w desechó|strong="H3988"\w* \w para|strong="H5921"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w seas|strong="H1961"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.
