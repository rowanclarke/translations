\p
\v 5 \w Tedae|strong="G2532"\w* hlang \w tlo|strong="G0732"\w* a \w yool|strong="G3641"\w* \w kut|strong="G5495"\w* a \w tloeng|strong="G2007"\w* tih \w hoeih|strong="G2323"\w* sak \w pawt|strong="G3361"\w* \w koinih|strong="G1487"\w* \w te|strong="G1563"\w* ah te a \w thaomnah|strong="G1411"\w* \w pakhat|strong="G3762"\w* khaw \w tueng|strong="G4160"\w* \w thai|strong="G1410"\w* \w mahpawh|strong="G3756"\w*.  
