\v 41 \w Te\w* \w vaengah|strong="G2532"\w* \w vaidam|strong="G0740"\w* hluem \w nga|strong="G4002"\w* \w neh|strong="G2532"\w* \w nga|strong="G2486"\w* lung \w nit|strong="G1417"\w* \w te|strong="G3588"\w* \w a\w* \w doe|strong="G2983"\w*. \w Vaan|strong="G3772"\w* \w la|strong="G1519"\w* \w oeloe|strong="G0308"\w* \w tih \w*\w a\w* \w uem|strong="G2127"\w* \w phoeiah|strong="G2532"\w* \w vaidam|strong="G0740"\w* \w te|strong="G3588"\w* \w a\w* \w aeh|strong="G2622"\w* \w tih|strong="G2532"\w* \w hlangping|strong="G0846"\w* \w paek|strong="G3908"\w* \w ham|strong="G2443"\w* \w a|strong="G0846"\w* \w hnukbang|strong="G3101"\w* \w rhoek \w* \w te|strong="G3588"\w* \w a\w* \w paek|strong="G1325"\w*. \w Nga|strong="G2486"\w* \w rhoi|strong="G1417"\w* \w te|strong="G3588"\w* \w khaw|strong="G2532"\w* \w boeih|strong="G3956"\w* \w a\w* \w rhek|strong="G3306"\w*.  
\v 42 Te \w vaengah|strong="G2532"\w* \w boeih|strong="G3956"\w* a \w caak|strong="G5315"\w* uh \w tih|strong="G2532"\w* \w hah|strong="G5526"\w* uh.  
