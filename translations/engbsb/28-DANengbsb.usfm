\v 23 \w Instead|strong="H5922"\w*, \w you|strong="H1768"\w* \w have|strong="H1768"\w* \w exalted|strong="H7313"\w* \w yourself|strong="H7313"\w* \w against|strong="H5922"\w* \w the|strong="H3606"\w* \w Lord|strong="H4756"\w* \w of|strong="H1005"\w* \w heaven|strong="H8065"\w*. \w The|strong="H3606"\w* \w vessels|strong="H3984"\w* \w from|strong="H1768"\w* \w His|strong="H5922"\w* \w house|strong="H1005"\w* \w were|strong="H1768"\w* brought \w to|strong="H5922"\w* \w you|strong="H1768"\w*, \w and|strong="H6523"\w* \w as|strong="H3606"\w* \w you|strong="H1768"\w* \w drank|strong="H8355"\w* \w wine|strong="H2562"\w* \w from|strong="H1768"\w* \w them|strong="H5922"\w* \w with|strong="H5922"\w* \w your|strong="H1768"\w* \w nobles|strong="H7261"\w*, \w wives|strong="H7695"\w*, \w and|strong="H6523"\w* \w concubines|strong="H3904"\w*, \w you|strong="H1768"\w* \w praised|strong="H7624"\w* \w your|strong="H1768"\w* gods \w of|strong="H1005"\w* \w silver|strong="H3702"\w* \w and|strong="H6523"\w* \w gold|strong="H1722"\w*, \w bronze|strong="H5174"\w* \w and|strong="H6523"\w* \w iron|strong="H6523"\w*, wood \w and|strong="H6523"\w* stone, \w which|strong="H1768"\w* \w cannot|strong="H3809"\w* \w see|strong="H2370"\w* \w or|strong="H3809"\w* \w hear|strong="H8086"\w* \w or|strong="H3809"\w* \w understand|strong="H3046"\w*. \w But|strong="H1768"\w* \w you|strong="H1768"\w* \w have|strong="H1768"\w* failed \w to|strong="H5922"\w* glorify \w the|strong="H3606"\w* God \w who|strong="H1768"\w* holds \w in|strong="H5922"\w* \w His|strong="H5922"\w* \w hand|strong="H3028"\w* \w your|strong="H1768"\w* very \w breath|strong="H5396"\w* \w and|strong="H6523"\w* \w all|strong="H3606"\w* \w your|strong="H1768"\w* ways.
\v 24 \w Therefore|strong="H4481"\w* \w He|strong="H1768"\w* \w sent|strong="H7972"\w* \w the|strong="H4481"\w* \w hand|strong="H3028"\w* \w that|strong="H1768"\w* wrote \w the|strong="H4481"\w* \w inscription|strong="H3792"\w*.
