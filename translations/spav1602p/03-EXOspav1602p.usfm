\v 8 \w Y|strong="H3068"\w* la \w hija|strong="H1323"\w* de \w Faraón|strong="H6547"\w* respondió: \w Ve|strong="H3212"\w*. Entonces \w fue|strong="H3212"\w* la doncella, y \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* la madre del niño;   
\m
\v 9 \w A|strong="H3068"\w* la cual dijo la \w hija|strong="H1323"\w* \w de|strong="H5414"\w* \w Faraón|strong="H6547"\w*: \w Lleva|strong="H3212"\w* \w este|strong="H2088"\w* niño, y críamelo, y yo \add te\add* \w lo|strong="H2088"\w* \w pagaré|strong="H5414"\w*. \w Y|strong="H3068"\w* la mujer \w tomó|strong="H3947"\w* al niño, y criólo.   
\m
\v 10 \w Y|strong="H3068"\w* \w creció|strong="H1431"\w* \w el|strong="H3588"\w* niño, \w y|strong="H3588"\w* \w ella|strong="H4480"\w* lo trajo \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w hija|strong="H1323"\w* \w de|strong="H4480"\w* \w Faraón|strong="H6547"\w*, \w la|strong="H3588"\w* \w cual|strong="H3588"\w* lo tomó \w por|strong="H3588"\w* \w hijo|strong="H1121"\w*. \w Y|strong="H3068"\w* le puso \w por|strong="H3588"\w* \w nombre|strong="H8034"\w* \w Moisés|strong="H4872"\w*, diciendo: \w Porque|strong="H3588"\w* \w de|strong="H4480"\w* las \w aguas|strong="H4325"\w* lo saqué.   
\m
\v 11 \w Y|strong="H3068"\w* \w en|strong="H3318"\w* \w aquellos|strong="H1992"\w* \w días|strong="H3117"\w* \w acaeció|strong="H1961"\w* \w que|strong="H3117"\w*, \w crecido|strong="H1431"\w* ya \w Moisés|strong="H4872"\w*, \w salió|strong="H3318"\w* \w a|strong="H3068"\w* \w sus|strong="H1992"\w* hermanos, y \w vio|strong="H7200"\w* \w sus|strong="H1992"\w* cargas: y observó \w a|strong="H3068"\w* un \w egipcio|strong="H4713"\w* \w que|strong="H3117"\w* \w hería|strong="H5221"\w* \w a|strong="H3068"\w* uno de \w los|strong="H1992"\w* \w hebreos|strong="H5680"\w*, \w sus|strong="H1992"\w* herma­nos.   
\m
\v 12 \w Y|strong="H3068"\w* \w miró|strong="H7200"\w* \w a|strong="H3068"\w* todas partes, \w y|strong="H3588"\w* vien­do \w que|strong="H3588"\w* \w no|strong="H3588"\w* \add había\add* nadie, \w mató|strong="H5221"\w* al \w egipcio|strong="H4713"\w*, \w y|strong="H3588"\w* escondiólo \w en|strong="H3588"\w* \w la|strong="H3588"\w* arena.   
\m
\v 13 \w Y|strong="H3068"\w* \w salió|strong="H3318"\w* al \w día|strong="H3117"\w* \w siguiente|strong="H8145"\w*, y he \w aquí|strong="H2009"\w* \w dos|strong="H8147"\w* \w hebreos|strong="H5680"\w* \w que|strong="H4100"\w* reñían, y dijo al \w que|strong="H4100"\w* hacía la injuria: ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* hieres \w a|strong="H3068"\w* tu \w prójimo|strong="H7453"\w*?   
\m
\v 14 \w Y|strong="H3068"\w* \w él|strong="H5921"\w* respondió: ¿\w Quién|strong="H4310"\w* \w te|strong="H5921"\w* ha puesto \w a|strong="H3068"\w* \w ti|strong="H5921"\w* \w por|strong="H5921"\w* \w príncipe|strong="H8269"\w* \w y|strong="H5921"\w* \w juez|strong="H8199"\w* \w sobre|strong="H5921"\w* \w nosotros|strong="H5921"\w*? ¿piensas matar­\w me|strong="H5921"\w* \w como|strong="H5921"\w* \w mataste|strong="H2026"\w* \w al|strong="H5921"\w* \w egipcio|strong="H4713"\w*? Entonces \w Moisés|strong="H4872"\w* \w tuvo|strong="H3372"\w* \w miedo|strong="H3372"\w*, \w y|strong="H5921"\w* dijo: Ciertamente \w esta|strong="H5921"\w* \w cosa|strong="H1697"\w* \w es|strong="H1697"\w* descubierta.   
\m
\v 15 \w Y|strong="H3068"\w* \w oyendo|strong="H8085"\w* \w Faraón|strong="H6547"\w* \w este|strong="H2088"\w* \w negocio|strong="H1697"\w*, \w procuró|strong="H1245"\w* matar \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: \w mas|strong="H5921"\w* \w Moisés|strong="H4872"\w* \w huyó|strong="H1272"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w faz|strong="H6440"\w* \w de|strong="H5921"\w* \w Faraón|strong="H6547"\w*, \w y|strong="H5921"\w* \w habitó|strong="H3427"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w Madián|strong="H4080"\w*; \w y|strong="H5921"\w* \w sentóse|strong="H3427"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* un pozo.   
\m
