\tc1  7 
\tc2 Eparaima 
\tc3 Elisama Amihuda 
\tr
\tc1  8 
\tc2 Manase 
\tc3 Gamaliela Pedasuru 
\tr
\tc1  9 
\tc2 Beniamina 
\tc3 Abidana Gideoni 
