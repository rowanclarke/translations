\c 23  
\s1 The Divisions of the Levites  
\m
\v 1 \w When|strong="H3117"\w* \w David|strong="H1732"\w* \w was|strong="H1732"\w* \w old|strong="H1121"\w* \w and|strong="H1121"\w* \w full|strong="H7646"\w* \w of|strong="H1121"\w* \w years|strong="H3117"\w*, \w he|strong="H3117"\w* installed \w his|strong="H1732"\w* \w son|strong="H1121"\w* \w Solomon|strong="H8010"\w* \w as|strong="H3117"\w* \w king|strong="H4427"\w* \w over|strong="H5921"\w* \w Israel|strong="H3478"\w*.  
