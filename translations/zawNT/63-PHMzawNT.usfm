\id PHM
\h Filemón
\toc1 Te Guijtz Lo Filemón
\toc2 Filemón
\toc3 Flm.
\mt1 Te Guijtz Lo Filemón
\c 1
\s1 Rucuaa Pabl guijtz lo Filemón
\p 
\v 1 Narä, Pabl, yu'ä neṉ latzguiib sa'csi rniä xtidx Dad Jesucrist. Narä näjza bejtznu Timoteu cagucuaanu guijtzre lojlu, Filemón, ni sanälazduxhnu sa'csi najclu sa'nu lo xtzun Dios.
\v 2 Rucuaazanu guijtzre lo Apia, bisiajnnu lo yäḻrililajz, näj lo Arquipo ni racnäj nuurnu lo dzuunre, näjza loj rebeṉguidoo ni rchagsa' rolijzlu.
\v 3 Dios Xtadnu näj Dad Jesucrist gacnäj la'tu, guscuedxireni lajztu.
\s1 Xcäḻsanälajz näj xcäḻrililajz Filemón
\p 
\v 4 Rudedä xquixtios lo Dios xcuent luj che rniä lo Dios.
\v 5 Abiejn diagä xcuent yäḻrinälajz näj yäḻrililajz ni rajplu lo Dad Jesucrist, näjza reni yu' lo Dios.
\v 6 Rniabä lo Dios tioobru xcäḻrililajzlu laḻ ni rusule'luni, te gacbesa'creni xcuent guiraa reyäḻnasa'c ni rajplu, ni runiidx Dad Jesucrist lojlu.
\v 7 Lacti rbalazduxhä, rbedxi lazä sa'csi sanälajzlu resa'nu näjza sa'csi luj, betzä, agulecdxilu lastoo reni rililajz.
\s1 Pabl rniabni lo Filemón xcasacni Onésimo
\p 
\v 8 Mase rapä xcäḻrnibee Jesucrist sajc guiniä gunlu xhitis ni riäjḻ gunlu,
\v 9 rniabä lojlu gunlu te dzunsa'c sa'csi narä nacä Pabl ni rinälajzlu, nacä beṉgool, yu'ä latzguiib xcuent Dad Jesucrist.
\v 10 Canabä xcuent Onésimo ni najc si'c xi'nä, sa'csi huililajzni xtidx Dios ni basule'ä lojni ṉaj ni yu'ä latzguiib.
\p 
\v 11 Galoo, dini niajc beṉsa'c lojlu, niluxh ṉaj sacnäduxhni guiro'pnu.
\v 12 Ruxhaḻsacäni lojlu, te xcasacluni stehuält si'c ni najräni xca'lu, sa'csi siädnäni lojlu ascanu lagajc lastoä.
\v 13 Narä rlazä niannäjni narä xcuentlu, te niacnäjni narä ṉaj ni yu'ä latzguiib sa'csi basule'ä xtidx Dios.
\v 14 Niluxh di rlazä niunä si'c palga luj dilu xcäjb gacni si'c. Dina guinia gacnäjpaclu narä si'c gojn. Narä rlazä gunluni sa'csi rlajzpaclu gacni si'c.
\v 15 Pet gubicaj Onésimo lojlu tio'p-choṉ dxejsi. Niluxh ṉaj xca'luni te chuni lojlu par tejpas.
\v 16 N̲aj xhetru si'cdi te mos chuni lojlu. N̲aj sajcruni loj te mos. N̲aj najcni si'c te betzbiidlu ni sanälajzlu. Narä sanälazduxhäni, niluxh luj riäjḻ chanälajzruluni, xhet si'c chutis te bejṉ, alga si'c te bejtzlu lo Dad Jesucrist.
\p 
\v 17 Näj palga rumbeelu narä si'c te sa'lu, cua'ni sigajc narä.
\v 18 Palga yu' xhi bejnni lojlu o palga yu' xhi nazääbni lojlu, basa'nni lo xcuentä.
\v 19 Lagajc narä, Pabl abacuaä guijtzre con ṉaä con xleträ, narä siguixäni. (Te na'c guiniä nazääbzalu lagajc luj loä.)
\v 20 Betzä, benḻaa hueenre narä si'c te ni sanälajz Dios te guspaalu lazä nez loj Dad Jesucrist.
\p 
\v 21 Bacuaä guijtzre lojlu sa'csi nancheä susooblu xtidxä, sujnzalu maazdi loj ni rniabä lojlu.
\v 22 Sigajcza basuchee te lajt cadro jia'nä, sa'csi cabäzä gudzu' Dios ni gunabtu lojni, gusaan Dios jiädhuiä la'tu.
\s1 Ruxhaḻni xtixtios lojni
\p 
\v 23 Epafras ruxhaḻ xtixtios lojlu. Laani yunäjni narä latzguiib, sa'csi guniizani xtidx Jesucrist.
\v 24 Marcw, Aristarco, Demas, näj Lucas, ni racnäj narä lo dzuunre, ruxhaḻzareni xtixtios lojlu.
\p 
\v 25 Dad Jesucrist gacnäj la'tu. Sugacni si'c.
