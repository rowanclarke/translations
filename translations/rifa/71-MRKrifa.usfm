\id MRK
\h مَارْكُوسْ
\toc1 مَارْكُوسْ
\toc2 مَارْكُوسْ
\toc3 مك.
\mt1 مَارْكُوسْ
\c 1
\s1 يُوحَانَّا أَمْسغْضَاصْ ذ شّْهَاذثْ نّسْ خْ يَاسُوع
\m 
\v 1 بدُّو ن لْ-إِنْجِيلْ ن يَاسُوع لْمَاسِيحْ، مِّيسْ ن أَربِّي. \x ◘ \xo 1:‏1 \xt [مت. 3‏:‏1‏-‏17؛ 4‏:‏1‏-‏11؛ لك. 3‏:‏1‏-‏9، 15‏-‏17؛ 21‏-‏22؛ 4‏:‏‏-‏13؛ يُوح. 1‏:‏19‏-‏28] \x*
\v 2 أَمْ مَامّشْ ثُورَا ذڭْ \add وذْلِيسْ ن\add* ؤُنَابِي إِشَاعْيَا ...
\b
\m \qt ”أَقَا نشّْ أَذْ سّكّغْ\qt*
\m \qt زَّاثْ إِ وُوذمْ نّشْ لْمَالَاكْ إِنُو،\qt*
\m \qt ونِّي إِ غَا إِسّْوجْذنْ أَبْرِيذْ نّشْ.“\qt* \x ◘ \xo 1:‏2 \xt ؤُف. 23‏:‏20؛ مـَال. 3‏:‏1؛ مت. 11‏:‏10؛ لك. 7‏:‏27. \x*
\m 
\v 3 \qt ”ثْمِيجَّا \tl ن ونِّي\tl* إِسْغُويُّونْ ذِي ڒخْڒَا:\qt*
\m \qt ’سْوجْذمْ أَبْرِيذْ ن سِيذِي،\qt*
\m \qt سڭّْممْ إِمسْرَاقْ نّسْ!‘ “\qt* \x ◘ \xo 1:‏3 \xt إِشا. 40‏:‏3؛ مت. 3‏:‏3؛ لك. 3‏:‏4؛ يُوح. 1‏:‏23. \x*
\b
\m 
\v 4 ... \add أَمُّو إِ\add* ثُوغَا يُوحَانَّا إِسّغْضَاصْ ذِي ڒخْڒَا، إِتّْبَارّحْ س ؤُسغْضصْ ن تُّوبثْ إِ وغْفَارْ ن دّْنُوبْ. \x ◘ \xo 1:‏4 \xt مت. 3‏:‏1؛ لك. 3‏:‏3؛ يُوح. 3‏:‏23. \x*
\v 5 فّْغنْ-د غَارسْ مَارَّا جّْوَايهْ ن يَاهُوذِييَّا ذ أَيْثْ ن ؤُرْشَالِيمْ، تّْوَاسّْغضْصنْ زَّايسْ ذڭْ إِغْزَارْ ن لْ-ؤُرْذُونْ أَمْ نعّْمنْ س دّْنُوبْ نْسنْ. \x ◘ \xo 1:‏5 \xt مت. 3‏:‏5؛ لك. 3‏:‏7. \x*
\m 
\v 6 ثُوغَا يُوحَانَّا وَانِيثَا يَارْضْ ثَاضُوفْثْ ن إِڒغْمَانْ، إِبكّسْ س يِيجّْ ن وبْيَاسْ ن يِيڒمْ خْ ثجْعِينَّا نّسْ، ؤُ ثُوغَا إِتّتّْ إِبُورخْسنْ ذ ثَامّنْثْ ثَاحُورّشْثْ. \x ◘ \xo 1:‏6 \xt 2 إِج. 1‏:‏8؛ لَاوِي 11‏:‏22؛ مت. 3‏:‏4. \x*
\v 7 ثُوغَا إِتّْبَارّحْ، إِقَّارْ: ”خْزَارْ، أَذْ د-يَاسْ أَوَارْنِي أَيِي ونِّي إِجهْذنْ خَافِي، ونِّي ؤُمِي وَارْ سْذِيهِيدْجغْ أَذْ أَضَارغْ مَاحنْذْ أَذْ فسْيغْ إِفِيڒَانْ ن سَانْذَالِييَاثْ نّسْ. \x ◘ \xo 1:‏7 \xt مت. 3‏:‏11؛ لك. 3‏:‏16؛ يُوح. 1‏:‏27. \x*
\v 8 نشّْ سّْغضْصغْ كنِّيوْ ذڭْ وَامَانْ، مَاشَا نتَّا أَذْ كنِّيوْ إِسّغْضصْ ذِي أَرُّوحْ إِقدّْسنْ.“ \x ◘ \xo 1:‏8 \xt إِشا. 44‏:‏3؛ يُووِ. 3‏:‏1؛ مت. 3‏:‏11؛ ڒخ. 1‏:‏5؛ 2‏:‏4؛ 11‏:‏15، 16؛ 19‏:‏4. \x*
\b
\m 
\v 9 ذڭْ وُوسَّانْ نِّي يُوسَا-د يَاسُوع زِي نَّاصِيرَا، ذِي لْجَالِيلْ، إِتّْوَاسّغْضصْ زِي يُوحَانَّا ذڭْ يغْزَارْ ن لْ-ؤُرْذُونْ. \x ◘ \xo 1:‏9 \xt [مت. 3‏:‏13‏-‏17؛ لك. 3‏:‏21‏-‏22] \x*
\v 10 ذغْيَا، أَمْ د-إِڭعّذْ زڭْ وَامَانْ، إِژْرَا إِجنْوَانْ أَرْزْمنْ ؤُشَا أَرُّوحْ أَمْ ثذْبِيرْثْ ثهْوَا-د خَاسْ. \x ◘ \xo 1:‏10 \xt مت. 3‏:‏16؛ لك. 3‏:‏21؛ يُوح. 1‏:‏32. \x*
\v 11 ثُوسَا-د إِشْثْ ن ثْمِيجَّا زڭْ إِجنْوَانْ: \bd ”شكْ ذ مِّي إِعِيزّنْ، ذَايكْ ؤُفِيغْ أَرْضَا إِنُو.“\bd*\x ◘ \xo 1:‏11 \xt إِزهد. 2‏:‏7؛ إِشا. 5‏:‏1؛ 42‏:‏1؛ مت. 3‏:‏17؛ 17‏:‏5؛ مك. 9‏:‏7؛ لك. 3‏:‏22؛ 9‏:‏35؛ عبر. 1‏:‏5؛ 5‏:‏5؛ كُول. 1‏:‏13؛ 2 بُط. 1‏:‏17. \x*
\b
\m 
\v 12 ذغْيَا إِڭوّذْ إِ-ث أَرُّوحْ غَارْ ڒخْڒَا. \x ◘ \xo 1:‏12 \xt [مت. 4‏:‏1‏-‏11؛ لك. 4‏:‏1‏-‏13] — مت. 4‏:‏1؛ لك. 4‏:‏1. \x*
\v 13 ؤُشَا \bd إِقِّيمْ ذِينْ ذِي ڒخْڒَا أَربْعِينْ ن وُوسَّانْ\bd*، إِجَارّبْ إِ-ث شِّيطَانْ، ثُوغَا-ث أَكْ-ذ ڒوْحُوشْ ؤُشَا سخَّارنْثْ خَاسْ لْمَالَاكَاثْ.
\b
\s1 ثَاڒَاغِيثْ ن يَاسُوع خْ إِمحْضَارنْ إِمزْوُورَا
\m 
\v 14 أَوَارْنِي ڒَامِي طّْفنْ يُوحَانَّا، يُوذفْ-د يَاسُوع غَارْ لْجَالِيلْ، إِتّْبَارّحْ س ڒخْبَارْ أَصبْحَانْ ن ثْڭلْذِيثْ، \x ◘ \xo 1:‏14 \xt [مت. 4‏:‏12‏-‏22؛ لك. 4‏:‏14‏-‏15؛ 5‏:‏1‏-‏11] — مت. 4‏:‏12؛ مك. 6‏:‏17، 18؛ لك. 4‏:‏14؛ يُوح. 4‏:‏43. \x*
\v 15 إِنَّا: ”أَقَا ڒْوقْثْ ثِيوضْ-د، ثْقَارّبْ-د ثْڭلْذِيثْ ن أَربِّي. ثُوبمْ، أَمْنمْ ذِي ڒخْبَارْ أَصبْحَانْ.“
\b
\m 
\v 16 أَمْ ثُوغَا إِڭُّورْ غَارْ ڒبْحَارْ ن لْجَالِيلْ، إِژْرَا شِيمْعُونْ ذ أَنْذْرَاوُوسْ ؤُمَاسْ، نطَّارنْ ثْرَاشَّا ذِي ڒبْحَارْ، مَاغَارْ نِيثْنِي ذ إِنيْمَارنْ ن إِسڒْمَانْ. \x ◘ \xo 1:‏16 \xt مت. 4‏:‏18. \x*
\v 17 إِنَّا أَسنْ يَاسُوع: ”أَسمْ-د أَوَارْنِي أَيِي ؤُشَا أَذْ كنِّيوْ أَرّغْ ذ إِنيْمَارنْ ن يوْذَانْ.“ \x ◘ \xo 1:‏17 \xt إِرْم. 16‏:‏16؛ حِز. 47‏:‏10. \x*
\v 18 ڒخْذنِّي جِّينْ ثِيرَاشِّيوِينْ نْسنْ ؤُشَا ضْفَارنْ ث. \x ◘ \xo 1:‏18 \xt مت. 19‏:‏27؛ مك. 10‏:‏28؛ لك. 5‏:‏11؛ 18‏:‏28. \x*
\v 19 خنِّي أَوَارْنِي ڒَامِي إِعْذُو شْوَايْثْ سّنِّي، إِژْرَا يَاعْقُوبْ مِّيسْ ن زَابْذِي ذ ؤُمَاسْ يُوحَانَّا ذِي ثْغَارَّابُوثْ،عذْڒنْ ثِيرَاشِّيوِينْ نْسنْ. \x ◘ \xo 1:‏19 \xt مت. 4‏:‏21. \x*
\v 20 إِڒَاغَا خَاسنْ ؤُشَا ڒخْذنِّي جِّينْ بَابَاثْسنْ زَابْذِي أَكْ-ذ إِخمَّاسنْ ذِي ثْغَارَّابُوثْ، ؤُشَا ضْفَارنْ ث.
\b
\s1 أَمرْيَاحْ ذِي ثمْزِيذَا ن كَافرْنَاحُومْ
\m 
\v 21 خشّنْ غَارْ كَافَارْنَاحُومْ ؤُشَا ذغْيَا \add إِبْذَا\add* إِسّڒْمَاذْ ذِي سّبْثْ ذِي ثمْزِيذَا. \x ◘ \xo 1:‏21 \xt [لك. 4‏:‏31‏-‏37] — مت. 4‏:‏13؛ لك. 4‏:‏31. \x*
\v 22 ثْبهْثنْ زڭْ ؤُسڒْمذْ نّسْ، مِينْزِي إِسّڒْمذْ إِ-ثنْ أَمْ ونِّي غَارْ ثدْجَا صُّولْطَا، وَارْ إِدْجِي أَمْ يِيمْسڒْمَاذنْ ن إِذْلِيسنْ. \x ◘ \xo 1:‏22 \xt مت. 7‏:‏28؛ لك. 4‏:‏32. \x*
\v 23 ثُوغَا ذِي ثمْزِيذَا نْسنْ إِجّْ ن بْنَاذمْ ذَايسْ إِجّْ ن ڒَارْيَاحْ ذ أَمنْڭُوسْ، إِسْغُويُّو، \x ◘ \xo 1:‏23 \xt لك. 4‏:‏33. \x*
\v 24 إِقَّارْ: ”مِينْ ذِينْ جَارْ أَنغْ نشِّينْ ذ شكْ أَ يَاسُوع نَّاصِيرِي. مَا ثُوسِيذْ-د حِيمَا أَذْ أَنغْ ثسّْهلّْكذْ؟ أَقَا نشّْ سّْنغْ شكْ مِينْ ثعْنِيذْ: \add أَقَا شكْ\add* ذ أَمْقدَّاسْ ن أَربِّي.“
\v 25 ؤُشَا إِعْڒمْ أَسْ يَاسُوع، إِنَّا أَسْ: ”سْقَارْ! فّغْ زَّايسْ!“
\v 26 إِمّنْضَارْ إِ-ث ڒَارْيَاحْ أَمنْڭُوسْ، إِسْغُويْ س إِشْثْ ن ثْغُويِّيثْ ثجْهذْ ؤُشَا خنِّي إِفّغْ-د زَّايسْ.
\v 27 ثْبهْثنْ مَارَّا، مّْسقْسَانْ أَكْ-ذ وَايَاوْيَا، نَّانْ: ”مَانْ أَيَا؟ مَانَا ثَاغُورِي-يَا ن جْذِيذْ؟ مِينْزِي س صُّولْطَا يُومُورْ ؤُڒَا ذ ڒَارْيَاحْ إِمنْڭَاسْ ؤُشَا تّڭّنْ أَسْ أَرَّايْ.“
\v 28 ڒخْذنِّي إِفّغْ ڒخْبَارْ نّسْ غَارْ مَارَّا جّْوَايهْ إِ ذ أَسْ د-إِنّْضنْ إِ لْجَالِيلْ.
\b
\s1 أَسْڭنْفِي ن ثْضكّْوَاتْشْ ن بُوطْرُوسْ س ؤُفُوسْ ن يَاسُوع
\m 
\v 29 \add أَوَارْنِي ڒَامِي\add* د-فّْغنْ زِي ثمْزِيذَا، رُوحنْ غَارْ ثَادَّارْثْ ن شِيمْعُونْ ذ أَنْذْرَاوُوسْ أَكْ-ذ يَاعْقُوبْ ذ يُوحَانَّا. \x ◘ \xo 1:‏29 \xt [مت. 8‏:‏14‏-‏17؛ لك. 4‏:‏38‏-‏41] — مت. 8‏:‏14؛ لك. 4‏:‏38. \x*
\v 30 ثُوغَا ثَاضكّْوَاتْشْ ن شِيمْعُونْ ثزّڒْ س ثْمسِّي، ؤُشَا نِيثْنِي سِّيوْڒنْ خَاسْ أَكِيذسْ.
\v 31 إِقَارّبْ-د غَارسْ، إِشبَّارْ ذڭْ ؤُفُوسْ نّسْ، إِسّْڭعّذْ إِ-ت-إِ-د. ذغْيَا ثجَّا خَاسْ ثْمسِّي ؤُشَا نتَّاثْ \add ثبْذَا\add* ثتّْسخَّارْ خَاسنْ.
\v 32 ڒَامِي د-ثِيوضْ ثْمذِّيثْ، ثَافُوشْثْ ثْرُوحْ أَذْ ثغْڒِي، إِوْينْ غَارسْ مَارَّا إِمهْڒَاشْ ذ إِنِّي ذَايْسنْ شّْوَاطنْ. \x ◘ \xo 1:‏32 \xt مت. 8‏:‏16؛ لك. 4‏:‏40. \x*
\v 33 ثُوغَا ثَانْذِينْثْ مَارَّا ثْمُونْ غَارْ ثوَّارْثْ.
\v 34 إِسّْڭنْفَا أَطَّاسْ ن إِمحْڒَاشْ س عْڒَامْ كُوڒْ ڒهْڒَاشَاثْ ؤُشَا إِسُّوفّغْ أَطَّاسْ ن شّْوَاطنْ، وَارْ إِجِّي شّْوَاطنْ أَذْ سِّيوْڒنْ، مِينْزِي سّْننْ ث.
\b
\s1 يَاسُوع إِژُّودْجْ غَارْ صّْبحْ زِيشْ
\m 
\v 35 ثِيوشَّا زِيشْ، \add ثُوغَا عَاذْ ذ دْجِيڒثْ،\add* إِكَّارْ ؤُشَا إِفّغْ غَارْ إِجّْ ن ومْشَانْ إِخْڒَانْ، ثُوغَا إِتّْژَادْجْ ذِينْ. \x ◘ \xo 1:‏35 \xt [لك. 4‏:‏42‏-‏44] — مت. 14‏:‏23؛ لك. 4‏:‏42. \x*
\v 36 شِيمْعُونْ ذ يِينِّي ثُوغَا أَكِيذسْ، أَرْزُونْ خَاسْ.
\v 37 ڒَامِي ث ؤُفِينْ، نَّانْ أَسْ: ”مَارَّا إِوْذَانْ أَرزُّونْ خَاكْ!“
\v 38 إِنَّا أَسنْ: ”إِتّْخصَّا أَذْ نْرَاحْ غَارْ ذْشُورَاثْ ذ ثْندَّامْ يُوذْسنْ، حِيمَا أَذْ ذِينْ بَارّْحغْ عَاوذْ مِينْزِي أَقَا إِ ؤُيَا ؤُمِي د-ؤُسِيغْ.“ \x ◘ \xo 1:‏38 \xt إِشا. 61‏:‏1؛ لك. 4‏:‏18، 43. \x*
\v 39 ثُوغَا إِسّڒْمَاذْ ذِي ثمْزِيذَاوِينْ نْسنْ ذِي مَارَّا لْجَالِيلْ، ؤُ إِسُّوفُّوغْ شّْوَاطنْ.
\b
\s1 أَسْڭنْفِي ن إِجّْ ن بْنَاذمْ ذَايسْ ڒْبَارْصْ
\m 
\v 40 يُوسَا-د غَارسْ إِجّنْ ذَايسْ ڒْبَارْصْ، إِوْضَا غَارْ إِضَارنْ نّسْ، إِتَّارْ أَسْ، إِنَّا: ”مَاڒَا ثخْسذْ، ثْزمَّارذْ أَذْ أَيِي ثسِّيزْذڭذْ.“ \x ◘ \xo 1:‏40 \xt [مت. 8‏:‏1‏-‏4؛ لك. 5‏:‏12‏-‏16] — مت. 8‏:‏2؛ لك. 5‏:‏12. \x*
\v 41 إِزِّيدْجزْ إِ يَاسُوع، إِسّْوِيژّضْ أَفُوسْ نّسْ، إِحَاذَا إِ-ث، إِنَّا أَسْ: ”خْسغْ! إِوَا، ذْوڒْ ذ أَمزْذَاڭْ!“
\v 42 ذِي ثْسَاعّثْ نِّي، ڒخْذنِّي إِرُوحْ خَاسْ ڒْبَارْصْ ؤُشَا إِذْوڒْ إِزْذِيڭْ.
\v 43 ؤُشَا \add أَوَارْنِي ڒَامِي\add* ذ أَسْ إِعْڒمْ، إِسّكّْ إِ-ث ڒخْذنِّي،
\v 44 إِنَّا أَسْ: ”خْزَارْ، وَارْ ث تّْعِيوِيذْ ؤُڒَا إِ يِيجّنْ، مَاشَا رُوحْ، سْشنْ إِخفْ نّشْ إِ ؤُكهَّانْ ؤُشَا أوْشْ خْ ؤُسِيزْذڭْ نّشْ مِينْ يُومُورْ مُوسَا مَاحنْذْ أَذْ ثْشهْذذْ إِ نِيثْنِي.“ \x ◘ \xo 1:‏44 \xt لَاوِي 13‏:‏2؛ 14‏:‏1. \x*
\v 45 مَاشَا ڒَامِي إِرُوحْ، إِبْذَا إِتّْبَارّحْ أَطَّاسْ، إِسُّوفّغْ ڒخْبَارْ أَڒَامِي وَارْ إِزمَّارْ يَاسُوع أَذْ يَاذفْ غَارْ ثَانْذِينْثْ س بْطَايْطَايْ، مَاشَا ثُوغَا-ث بَارَّا ذڭْ إِمُوشَانْ إِخْڒَانْ، ثُوغَا تَّاسنْ-د غَارسْ زِي كُوڒْ جّْوَايهْ.
\b
\b
\c 2
\s1 أَسْڭنْفِي ن إِجّْ ن ؤُنعْضَابْ
\m 
\v 1 أَوَارْنِي إِ شَا ن وُوسَّانْ يُوذفْ يَاسُوع عَاوذْ غَارْ كَافَارْنَاحُومْ. ڒَامِي سْڒِينْ بلِّي أَقَا-ث ذِي ثَادَّارْثْ، \x ◘ \xo 2:‏1 \xt [مت. 9‏:‏1‏-‏8؛ لك. 5‏:‏17‏-‏26] — مت. 9‏:‏1؛ لك. 5‏:‏17. \x*
\v 2 مُوننْ خَاسْ وَاطَّاسْ \add ن إِوْذَانْ\add*، أَڒَامِي وَارْ زمَّارنْ أَذْ د-أَوْضنْ ؤُڒَا غَارْ ثوَّارْثْ، ؤُ نتَّا ثُوغَا إِسَّاوَاڒْ أَكِيذْسنْ س وَاوَاڒْ.
\v 3 ؤُسِينْ-د شَا غَارسْ، إِوْينْ-د إِجّْ ن ؤُنعْضَابْ غَارسْ، أَرْبُونْ ث-إِ-د جَارْ أَسنْ أَربْعَا ن يرْيَازنْ. \x ◘ \xo 2:‏3 \xt مت. 9‏:‏1؛ لك. 5‏:‏18. \x*
\v 4 مِينْزِي وَارْ زمَّارنْ أَذْ غَارسْ د-قَارّْبنْ زِي سِّيبّثْ ن ڒْغَاشِي، ڭَاعّْذنْ خْ ثْزقَّا، كْسِينْ شْوَايْثْ زِي ثْزقَّا سنّجْ أَمْشَانْ مَانِي ثُوغَا يَاسُوع، ؤُشَا سّهْوَانْ-د ثَاسُّوثْ مِينْ خفْ إِزّڒْ ؤُنعْضَابْ.
\m 
\v 5 ؤُمِي إِژْرَا يَاسُوع لْ-إِيمَانْ نْسنْ، إِنَّا إِ ؤُنعْضَابْ: ”\add أَ\add* مِّي، أَقَا دّْنُوبْ نّشْ تّْوَاغْفَارنْ.“
\v 6 ثُوغَا قِّيمنْ ذِينْ شَا ن إِمْسڒْمَاذنْ ن إِذْلِيسنْ ذ إِفَارِيسِييّنْ، تّْخَارَّاصنْ ذڭْ وُوڒْ نْسنْ:
\v 7 ”مِينْ إِعْنَا وَا إِ إِتّْشقَّافنْ \add أَمُّو\add*؟ وِي إِزمَّارنْ أَذْ إِغْفَارْ دّْنُوبْ مْغِيرْ أَربِّي وحّْذسْ؟“ \x ◘ \xo 2:‏7 \xt إِزهد. 32‏:‏5؛ 51‏:‏3؛ إِشا. 43‏:‏25. \x*
\v 8 يُوشَا يَاسُوع س أَرُّوحْ نّسْ بلِّي أَقَا تّْخَارَّاصنْ أَمُّو ذڭْ إِخفْ نْسنْ. إِنَّا أَسنْ: ”مَايمِّي ثتّْخمَّاممْ ذِي مَانْ أَيَا ذڭْ وُوڒَاونْ نْومْ؟
\v 9 مِينْ إِهوْننْ أَذْ إِنِيغْ إِ ؤُنعْضَابْ: ’تّْوَاغْفَارنْ دّْنُوبْ نّشْ‘ نِيغْ أَذْ إِنِيغْ: ’كَّارْ، كْسِي ثَاسُّوثْ نّشْ ؤُشَا ؤُيُورْ‘؟
\v 10 مَاشَا حِيمَا أَذْ ثسّْنمْ بلِّي مِّيسْ ن بْنَاذمْ غَارسْ صُّولْطَا خْ ثمُّورْثْ، مَاحنْذْ أَذْ إِغْفَارْ دّْنُوبْ، إِنَّا خنِّي إِ ؤُنعْضَابْ:
\v 11 ’نشّْ أَذْ أَشْ إِنِيغْ: كَّارْ، كْسِي ثَاسُّوثْ نّشْ، ثْرُوحذْ غَارْ ثَادَّارْثْ نّشْ!‘ “
\v 12 ذغْيَا إِكَّارْ، ڒخْذنِّي إِكْسِي ثَاسُّوثْ نّسْ ؤُشَا إِفّغْ قِيبَاتْشْ إِ مَارَّا \add إِوْذَانْ\add*، أَڒَامِي ثْبهْثنْ مَارَّا، سّمْغَارنْ ذِي أَربِّي، نَّانْ: ”عمَّارْصْ وَارْ نژْرِي مَانْ أَيَا!“
\b
\s1 ثَاڒَاغِيثْ ن يَاسُوع خْ مَاتَّا لَاوِي
\m 
\v 13 خنِّي إِفّغْ عَاوذْ غَارْ ڒبْحَارْ، ؤُشَا يُوسَا-د غَارسْ ڒْغَاشِي مَارَّا ؤُشَا إِسّڒْمذْ إِ-ثنْ. \x ◘ \xo 2:‏13 \xt [مت. 9‏:‏9‏-‏13؛ لك. 5‏:‏27‏-‏32] — مت. 9‏:‏9؛ لك. 5‏:‏27. \x*
\v 14 أَمْ يعْذُو، إِبَارْقْ لَاوِي مِّيسْ ن حَالْفَا إِقِّيمْ غَارْ ثَادَّارْثْ ن ضَّارِيبَا، ؤُشَا إِنَّا أَسْ: ”ضْفَارْ أَيِي-د!“. إِكَّارْ ؤُشَا إِضْفَارْ إِ-ث.
\v 15 أَمْ إِقِّيمْ نتَّا \add غَارْ طَّابْڒَا\add* ذِي ثَادَّارْثْ نّسْ، ثُوغَا أَطَّاسْ ن أَيْثْ ن ضَّارِيبَا ذ إِمذْنَابْ قِّيمنْ أَكْ-ذ يَاسُوع ذ إِمحْضَارنْ نّسْ، مِينْزِي ثُوغَا أَثنْ ذڭْ وَاطَّاسْ ؤُشَا ضْفَارنْ ث.
\v 16 ؤُمِي ژْرِينْ إِمْسڒْمَاذنْ ن إِذْلِيسنْ ذ إِفَارِيسِييّنْ أَقَا إِتّتّْ أَكْ-ذ أَيْثْ ن ضَّارِيبَا ذ إِمذْنَابْ، نَّانْ إِ إِمحْضَارنْ نّسْ: ”مَايمِّي إِتّتّْ، إِسسّْ أَكْ-ذ أَيْثْ ن ضَّارِيبَا ذ إِمذْنَابْ؟“
\v 17 ڒَامِي إِسْڒَا يَاسُوع مَانْ أَيَا، إِنَّا أَسنْ: ”إِنِّي إِصحّنْ وَارْ حْذِيجنْ شَا أَضْبِيبْ، مَاشَا إِمهْڒَاشْ وَاهْ. أَقَا وَارْ د-ؤُسِيغْ حِيمَا أَذْ ڒَاغِيغْ إِ يِينِّي إِسڭّْذنْ مَاشَا إِ إِمذْنَابْ.“ \x ◘ \xo 2:‏17 \xt مت. 9‏:‏13؛ 21‏:‏31؛ لك. 5‏:‏32؛ 19‏:‏10؛ 1 تِيم. 1‏:‏15. \x*
\b
\s1 أَسقْسِي خْ ؤُژُومِّي
\m 
\v 18 ثُوغَا إِمحْضَارنْ ن يُوحَانَّا \add أَمْسغْضَاصْ\add* ذ إِفَارِيسِييّنْ تّْژُومَّانْ ؤُشَا \add خنِّي\add* ؤُسِينْ-د غَارسْ، نَّانْ أَسْ: ”مَايمِّي تّْژُومَّانْ إِمحْضَارنْ ن يُوحَانَّا ذ إِفَارِيسِييّنْ، \add مَاشَا\add* إِمحْضَارنْ نّشْ وَارْ تّْژُومِّينْ شَا؟“ \x ◘ \xo 2:‏18 \xt [مت. 9‏:‏14‏-‏17؛ لك. 5‏:‏33‏-‏39] — مت. 9‏:‏14؛ لك. 5‏:‏33. \x*
\v 19 إِنَّا أَسنْ يَاسُوع: ”مَا زمَّارنْ ثَارْوَا ن ؤُمُوڒَايْ أَذْ ژُومّنْ ذ ؤُمُوڒَايْ \add عَاذْ\add* أَكِيذْسنْ؟ لَّ!\x ◘ \xo 2:‏19 \xt إِشا. 62‏:‏5؛ 2 كُور. 11‏:‏2. \x*
\v 20 مَاشَا أَذْ د-أَسنْ وُوسَّانْ خْمِي ذ غَا إِمّكْسِي ؤُمُوڒَايْ خَاسنْ، خنِّي أَذْ ژُومّنْ، ذڭْ وُوسَّانْ نِّي.
\v 21 وَارْ إِدْجِي حذْ إِتّْخيّضْ ثَانقِّيتْشْ زِي ثْشُوقّثْ ن جْذِيذْ خْ وَارُّوضْ أَقْذِيمْ، نِيغْ خنِّي ثَانقِّيتْشْ نِّي ن جْذِيذْ أَذْ ثقْڒعْ زڭْ \add وَارُّوضْ\add* أَبُوڒَايْ، ؤُشَا أَذْ إِذْوڒْ ؤُشَارّڭْ إِمْغَارْ.
\v 22 ؤُڒَا ذ إِجّْ وَارْ إِتّْفَارّغْ بِينُو ن جْذِيذْ ذِي ثْخُونْشَايْ ثِيقْذِيمِينْ، حِيمَا بِينُو ن جْذِيذْ وَارْ إِتّْشَارِّيڭْ ثِيخُونْشَايْ ؤُ ثِيخُونْشَايْ أَذْ ضيّْعنْثْ ؤُشَا بِينُو أَذْ إِزدْجعْ. مَاشَا إِتّْخصَّا أَذْ إِتّْوَافَّارغْ بِينُو ن جْذِيذْ ذِي ثْخُونْشَايْ ن جْذِيذْ.“ \x ◘ \xo 2:‏22 \xt مت. 9‏:‏17. \x*
\b
\s1 مِّيسْ ن بْنَاذمْ ذ بَابْ ن سّبْثْ
\m 
\v 23 خنِّي إِمْسَارْ أَقَا إِشُوقْ يَاسُوع ذڭْ إِيَّارنْ ن إِمنْذِي ذِي سّبْثْ، ؤُشَا إِمحْضَارنْ نّسْ بْذَانْ ڒقّْضنْ ثِيذْرِينْ أَمْ ڭُّورنْ. \x ◘ \xo 2:‏23 \xt [مت. 12‏:‏1‏-‏8؛ لك. 6‏:‏1‏-‏5] — أَعَوذ. 23‏:‏24؛ مت. 12‏:‏1؛ لك. 6‏:‏1. \x*
\v 24 نَّانْ أَسْ إِفَارِيسِييّنْ: ”خْزَارْ، مَايمِّي تّڭّنْ ذِي سّبْثْ مِينْ وَارْ إِحدْجْڒنْ؟“ \x ◘ \xo 2:‏24 \xt ؤُف. 20‏:‏10؛ أَعَوذ. 23‏:‏25\x*
\v 25 إِنَّا أَسنْ يَاسُوع: ”مَا وَارْ ثغْرِيمْ قَاعْ مِينْ إِڭَّا ذَاوُوذْ، ڒَامِي ثُوغَا إِتّْوَاحْصَارْ، إِطّفْ إِ-ث ڒَاژْ، نتَّا ذ يِينِّي أَكِيذسْ؟ \x ◘ \xo 2:‏25 \xt لَاوِي 24‏:‏8؛ 1 صم. 21‏:‏6. \x*
\v 26 مَامّشْ د-يُوذفْ غَارْ ثَادَّارْثْ ن أَربِّي ذڭْ وُوسَّانْ ن أَبْيَاثَارْ، أَرَّايْسْ ن إِكهَّاننْ، ؤُشَا إِشَّا أَغْرُومْ ن وسْشَانْ ن سِيذِي إِ وَارْ إِحدْجْڒنْ أَذْ ث شّنْ مْغِيرْ إِكهَّاننْ وَاهَا، ؤُشَا إِوْشَا عَاوذْ إِ يِينِّي ثُوغَا أَكِيذسْ؟“ \x ◘ \xo 2:‏26 \xt لَاوِي 24‏:‏9. \x*
\v 27 \add خنِّي\add* إِنَّا أَسنْ: ”أَقَا أَسّْ ن سّبْثْ إِتّْوَاڭّْ إِ بْنَاذمْ، وَارْ إِدْجِي بْنَاذمْ إِ سّبْثْ.
\v 28 أَمُّو إِ إِدْجَا مِّيسْ ن بْنَاذمْ ؤُڒَا ذ بَابْ ن سّبْثْ.“ \x ◘ \xo 2:‏28 \xt مت. 12‏:‏8؛ لك. 6‏:‏5. \x*
\b
\b
\c 3
\s1 أَسْڭنْفِي ذڭْ وَاسّْ ن سّبْثْ
\m 
\v 1 ؤُشَا يُوذفْ-د يَاسُوع عَاوذْ غَارْ ثمْزِيذَا. ثُوغَا ذِينْ إِجّْ ن ورْيَازْ، أَفُوسْ نّسْ إِقُوشّحْ. \x ◘ \xo 3:‏1 \xt [مت. 12‏:‏9‏-‏14؛ لك. 6‏:‏6‏-‏11] — مت. 12‏:‏9؛ لك. 6‏:‏6. \x*
\v 2 بْذَانْ حطَّانْ ث، مَا أَذْ ثَاغْ أَذْ ث إِسّْڭنْفَا ذِي سّبْثْ، حِيمَا زمَّارنْ أَذْ زَّايسْ شثْشَانْ.
\v 3 إِنَّا أَسْ إِ ورْيَازْ ونِّي غَارْ إِدْجَا أَفُوسْ إِقُوشّحْ: ”بدّْ ذِي ڒْوسْطْ.“
\v 4 خنِّي إِنَّا أَسنْ عَاوذْ: ”مَا إِحدْجڒْ \add إِ بْنَاذمْ\add* ذِي سّبْثْ، مَاحنْذْ أَذْ إِڭّْ ڒْخَارْ نِيغْ ڒْغَارْ، أَذْ إِسّنْجمْ إِجّْ ن ڒعْمَارْ نِيغْ أَذْ ث يَاردّدْجْ؟“ \add مَاشَا\add* نِيثْنِي سْقَارنْ.
\v 5 إِخْزَارْ غَارْ يِينِّي ذ أَسْ د-إِنّْضنْ س ثفْقحْثْ زِي سِّيبّثْ ن ڒقْسَاحثْ ن وُوڒَاونْ نْسنْ، ؤُشَا إِنَّا إِ ورْيَازْ: ”سْوِيژّضْ أَفُوسْ نّشْ!“ إِسّْوِيژّضْ إِ-ث-إِ-د، إِذْوڒْ ؤُفُوسْ نّسْ إِصحّْ عَاوذْ. \x ◘ \xo 3:‏5 \xt 1 إِج. 13‏:‏6؛ مت. 12‏:‏13؛ لك. 6‏:‏10\x*
\v 6 ڒخْذنِّي فّْغنْ إِفَارِيسِييّنْ أَكْ-ذ شَا زِي ثَادَّارْثْ ن هِيرُوذُوسْ، ؤُشَا مْشَاوَارنْ خَاسْ، مَامّشْ غَا ڭّنْ أَذْ ث أَردّْدْجنْ. \x ◘ \xo 3:‏6 \xt مت. 12‏:‏14؛ يُوح. 10‏:‏39؛ 11‏:‏53. \x*
\b
\s1 يَاسُوع إِسّْشنْ صُّولْطَا نّسْ خْ ڒَارْيَاحْ إِمنْڭَاسْ
\m 
\v 7 إِفّغْ يَاسُوع أَكْ-ذ إِمحْضَارنْ نّسْ غَارْ ڒبْحَارْ، ؤُشَا يَارْنِي إِضفَّارْ إِ-ث-د ڒْغَاشِي أَطَّاسْ زِي لْجَالِيلْ، زِي يَاهُوذِييَّا، \x ◘ \xo 3:‏7 \xt مت. 4‏:‏25؛ لك. 6‏:‏17. \x*
\v 8 زِي ؤُرْشَالِيمْ، زِي إِذُومِييَا، زڭْ ؤُجمَّاضْ ن لْ-ؤُرْذُونْ، زِي صُورْ ؤُ زِي صَايْذُونْ. أَقَا إِجّْ ن ڒْغَاشِي ذ أَمقّْرَانْ يُوسَا-د غَارسْ، مِينْزِي نِيثْنِي سْڒِينْ مَارَّا مِينْ إِڭَّا.
\v 9 إِنَّا إِ إِمحْضَارنْ نّسْ مَاحنْذْ أَذْ أَوْينْ إِشْثْ ن ثْغَارَّابُوثْ غَارسْ س سِّيبّثْ ن ڒْغَاشِي، حِيمَا وَارْ ث دّحّْسنْ.
\v 10 مِينْزِي ثُوغَا إِسّْڭنْفَا \add ذِينْ\add* أَطَّاسْ، أَڒَامِي خَاسْ وْضَانْ حِيمَا أَذْ ث أَوْضنْ أَذْ ث حَاذَانْ.
\v 11 إِنِّي إِتّْوَاجيّْحنْ زِي ڒَارْيَاحْ إِمنْڭَاسْ، وْضَانْ زَّاثسْ غَارْ إِضَارنْ نّسْ، ڒَامِي ث ژْرِينْ، سْغُوينْ، نَّانْ: ”أَقَا شكْ ذ مِّيسْ ن أَربِّي.“
\v 12 \add مَاشَا\add* إِوصَّا ثنْ أَطَّاسْ حِيمَا وَارْ خَاسْ سُّوفُّوغنْ ڒخْبَارْ.
\b
\s1 يَاسُوع إِخْضَارْ ثنْعَاشْ ن رُّوسُولْ نّسْ
\m 
\v 13 \add خَاسْ ؤُشَا\add* يُوڒِي غَارْ وذْرَارْ، إِڒَاغَا-د غَارسْ إِنِّي إِخْسْ، ؤُشَا ؤُسِينْ-د غَارسْ. \x ◘ \xo 3:‏13 \xt [مت. 10‏:‏1‏-‏4؛ لك. 6‏:‏12‏-‏16] — مت. 10‏:‏1؛ مك. 6‏:‏7؛ لك. 6‏:‏13؛ 9‏:‏1. \x*
\v 14 إِفَارْزْ زَّايْسنْ ثنْعَاشْ حِيمَا أَذْ كِيذسْ إِڒِينْ ؤُ حِيمَا أَذْ ثنْ إِسّكّْ مَاحنْذْ أَذْ بَارّْحنْ
\v 15 ؤُ مَاحنْذْ أَذْ غَارْسنْ ثِيڒِي صُّولْطَا خْ ؤُسْڭنْفِي ن ڒهْڒَاشْ ؤُ خْ ؤُسُوفّغْ ن شّْوَاطنْ.
\v 16 شِيمْعُونْ إِڭَّا أَسْ بُوطْرُوسْ، \add إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَژْرُو‘\add*،
\v 17 ذ يَاعْقُوبْ، مِّيسْ ن زَابْذِي، ذ يُوحَانَّا، ؤُمَاسْ ن يَاعْقُوبْ، إِسمَّا أَثنْ ’بُووَانِيرْجِيسْ‘، مِينْ إِخْسْ أَذْ يِينِي ’أَيْثْ ن وَاجَّاجْ‘،
\v 18 ؤُشَا \add إِفَارْزْ عَاوذْ\add* أَنْذْرَاوُوسْ ذ فِيلِيبُّوسْ ذ بَارْ-ثُولُومَاوُوسْ ذ مَاتَّا ذ ثُومَا ذ يَاعْقُوبْ، مِّيسْ ن حَالْفَا، ذ ثَادَّايْ ذ شِيمْعُونْ، \add ونِّي ؤُمِي تّْكنَّانْ\add* أَمْعسَّابْ،
\v 19 ذ يَاهُوذَا إِسْخَارِييُوطِي ونِّي ث إِ غَا إِغْذَارنْ.
\b
\s1 يَاسُوع ذ بعَالْزَاپُوبْ
\m 
\v 20 ؤُسِينْ-د غَارْ ثَادَّارْثْ ؤُشَا إِنّيْرُو ذِينْ عَاوذْ ڒْغَاشِي، أَڒَامِي وَارْ ؤُفِينْ ثَاوَّارْثْ خْ مَاشَّا ن وغْرُومْ. \x ◘ \xo 3:‏20 \xt [مت. 12‏:‏22‏-‏32؛ لك. 11‏:‏14‏-‏23؛ 12‏:‏10] — مك. 6‏:‏31. \x*
\v 21 ؤُمِي سْڒِينْ ڒَادْجْ نّسْ \add مَانْ أَيَا\add*، فّْغنْ-د، حِيمَا أَذْ ث طّْفنْ، مِينْزِي نَّانْ: ”أَقَا إِبُّوهْڒِي.“
\v 22 مَاشَا إِمْسڒْمَاذنْ ن إِذْلِيسنْ إِنِّي د-إِهْوَانْ زِي ؤُرْشَالِيمْ نَّانْ: ”أَقَا ذَايسْ ’بعَالْزابُوبْ‘!“ ؤُشَا \add نَّانْ:\add* ”س ؤُمقّْرَانْ ن شّْوَاطنْ إِسُّوفُّوغْ شّْوَاطنْ.“ \x ◘ \xo 3:‏22 \xt مت. 9‏:‏34؛ 12‏:‏24؛ لك. 11‏:‏15؛ يُوح. 7‏:‏20؛ 8‏:‏48، 52. \x*
\v 23 إِڒَاغَا أَسنْ-د ؤُشَا إِسِّيوڒْ أَكِيذْسنْ س إِمذْيَا: ”مَامّشْ إِزمَّارْ شِّيطَانْ أَذْ إِسُّوفّغْ شِّيطَانْ؟ \x ◘ \xo 3:‏23 \xt مت. 12‏:‏25. \x*
\v 24 مَاغَارْ مَاڒَا ثمْسبْضَا إِشْثْ ن ثْڭلْذِيثْ خْ يِيخفْ نّسْ، وَارْ ثْزمَّارْ ثْڭلْذِيثْ نِّي أَذْ ثْبدّْ.
\v 25 مَاڒَا ثمْسبْضَا إِشْثْ ن ثَادَّارْثْ خْ يِيخفْ نّسْ، وَارْ ثْزمَّارْ ثَادَّارْثْ نِّي أَذْ ثْبدّْ.
\v 26 مَاڒَا إِكَّارْ شِّيطَانْ ضِيدّْ إِ يِيخفْ نّسْ، خنِّي وَارْ إِتِّيڒِي ذ إِجّنْ، ؤُشَا وَارْ إِزمَّارْ أَذْ إِبدّْ، مَاشَا أَذْ يِيڒِي مَانْ أَيَا ذ أَنڭَّارْ نّسْ.
\v 27 وَارْ إِزمَّارْ حذْ أَذْ يَاذفْ غَارْ ثَادَّارْثْ ن ونِّي إِجهْذنْ مَاحنْذْ أَذْ إِكشّضْ ڒقْشُوعْ نّسْ، مَاڒَا وَارْ إِشَارْفْ ونِّي إِجهْذنْ أَمزْوَارْ. خنِّي إِزمَّارْ أَذْ إِكشّضْ ثَادَّارْثْ نّسْ. \x ◘ \xo 3:‏27 \xt مت. 12‏:‏29؛ كُول. 2‏:‏15. \x*
\v 28 س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ بلِّي أَذْ أَسنْ تّْوَاغْفَارنْ إِ ثَارْوَا ن بْنَاذمْ مَارَّا دّْنُوبْ نْسنْ ؤُڒَا ذ أَشقّفْ إِ زِي غَا شقّْفنْ، \x ◘ \xo 3:‏28 \xt 1 صم. 2‏:‏25؛ مت. 12‏:‏31؛ لك. 12‏:‏10؛ 1 يُوح. 5‏:‏16. \x*
\v 29 مَاشَا ونِّي إِ غَا إِشقّْفنْ ذِي أَرُّوحْ إِقدّْسنْ وَارْ غَارسْ بُو وغْفَارْ قَاعْ، مَاشَا أَقَا إِتّْوَاحْكمْ خَاسْ س ڒْحُوكْمْ إِتّْذُومَانْ.“ \x ◘ \xo 3:‏29 \xt 1 يُوح. 5‏:‏16. \x*
\v 30 مِينْزِي نِيثْنِي نَّانْ: ”أَقَا ذَايسْ ڒَارْيَاحْ أَمنْڭُوسْ.“
\b
\s1 يمَّاسْ ذ أَيْثْمَاسْ ن يَاسُوع
\m 
\v 31 ڒخْذنِّي ثُوسَا-د يمَّاسْ ذ أَيْثْمَاسْ، بدّنْ بَارَّا إِ ثَادَّارْثْ، سّكّنْ-د غَارسْ، ڒَاغَانْ أَسْ-د مَاحنْذْ أَذْ غَارْسنْ د-يَاسْ. \x ◘ \xo 3:‏31 \xt [مت. 12‏:‏46‏-‏50؛ لك. 8‏:‏19‏-‏21] — مت. 12‏:‏46؛ لك. 8‏:‏19. \x*
\v 32 ؤُشَا ڒْغَاشِي قِّيمنْ نّْضنْ أَسْ-د، نَّانْ أَسْ: ”خْزَارْ، يمَّاشْ ذ أَيْثْمَاشْ أَقَا أَثنْ ذِي بَارَّا، أَرزُّونْ خَاكْ.“
\v 33 يَارَّا-د خَاسنْ، إِنَّا: ”مَانْ ثنْ إِ إِدْجَانْ ذ يمَّا ؤُ مَانْ ينْ إِ إِدْجَانْ ذ أَيْثْمَا؟“
\v 34 ؤُشَا ؤُمِي إِخْزَارْ غَارْ يِينِّي غَارسْ إِقِّيمنْ، إِنَّا: ”خْزَارْ، أَقَا يمَّا ذ أَيْثْمَا،
\v 35 مِينْزِي ونِّي إِتّڭّنْ مِينْ إِخْسْ أَربِّي ذ نتَّا ذ ؤُمَا ذ ؤُتْشْمَا ذ يمَّا.“ \x ◘ \xo 3:‏35 \xt يُوح. 15‏:‏14؛ 2 كُور. 5‏:‏16، 17. \x*
\b
\b
\c 4
\s1 أَمذْيَا ن زَّارِيعثْ
\m 
\v 1 إِبْذَا إِسّڒْمَاذْ عَاوذْ غَارْ ڒبْحَارْ ؤُ إِمُونْ-د خَاسْ ڒْغَاشِي أَطَّاسْ أَڒَامِي ينْيَا ذِي ثْغَارَّابُوثْ ؤُشَا إِقِّيمْ \add ذَايسْ\add* خْ ڒبْحَارْ، أَمْ ڒْغَاشِي مَارَّا ثُوغَا-ث خْ ثْمَا ن ڒبْحَارْ خْ ڒْبَارّْ. \x ◘ \xo 4:‏1 \xt [مت. 13‏:‏1‏-‏23؛ لك. 8‏:‏4‏-‏15] — مت. 13‏:‏1؛ لك. 8‏:‏4 \x*
\v 2 ثُوغَا إِسّڒْمَاذْ إِ-ثنْ س إِمذْيَا أَطَّاسْ. إِنَّا ذِي ثْغُورِي نّسْ:
\v 3 ”سْڒمْ! خْزَارْ، إِجّْ ن ؤُفدْجَاحْ إِفّغْ حِيمَا أَذْ إِزَارْعْ.
\v 4 أَمْ ثُوغَا إِزَارّعْ، ثوْضَا شَا \add ن زَّارِيعثْ\add* خْ ثْمَا ن وبْرِيذْ، إِخشّْ-د إِجّْ ن ؤُجْضِيضْ، إِنقْبْ إِ-ت.
\v 5 ثوْضَا شَا \add ن زَّارِيعثْ\add* نّغْنِي خْ وژْرُو مَانِي وَارْ ذَايسْ ثُوغِي بُو ؤُشَاڒْ أَطَّاسْ. ذغْيَا ثغْمِي س مِينْزِي ثَامُّورْثْ وَارْ ثُودْجِيغْ.
\v 6 مَاشَا ؤُمِي د-ثنْقَارْ ثْفُوشْثْ، ثشْمضْ، مِينْزِي وَارْ غَارسْ ثُوغِي بُو وژْوَارْ، خنِّي ثِيسْڒَاوْ.
\v 7 ثوْضَا شَا \add ن زَّارِيعثْ\add* نّغْنِي جَارْ إِسنَّاننْ ؤُشَا مْغَارنْ خَاسْ إِسنَّاننْ ؤُشَا جيّْحنْ ت، وَارْ ثوْشِي شَا ڒْغِيدْجثْ.
\v 8 ثوْضَا شَا \add ن زَّارِيعثْ\add* نّغْنِي خْ ثمُّورْثْ ثصْبحْ ؤُشَا ثغْمِي، ثڭْمَا، ثوْشَا ڒْغِيدْجثْ. شَا \add ن زَّارِيعثْ\add* ثُوسَا-د س ثْڒَاثِينْ، شَا س ستِّينْ ؤُ شَا س مْيَا ن ثْسقَّارْ.“
\v 9 \add خنِّي\add* إِنَّا: ”ونِّي غَارْ إِدْجَا إِمزُّوغنْ إِ ؤُسدْجِي، أجّْ إِ-ث أَذْ إِسڒْ.“
\b
\m 
\v 10 ؤُمِي ثُوغَا أَثنْ وحّذْسنْ، سّقْسَانْ ث إِنِّي ذ أَسْ د-إِنّْضنْ \add جْمِيعْ\add* أَكْ-ذ ثنْعَاشْ خْ ؤُمذْيَا \add نِّي\add*. \x ◘ \xo 4:‏10 \xt [مت. 13‏:‏10‏-‏17؛ لك. 8‏:‏9‏-‏10] \x*
\v 11 إِنَّا أَسنْ: ”أَقَا إِمّوْشْ أَومْ مَاحنْذْ أَذْ ثسّْنمْ سِّيرّْ ن ثْڭلْذِيثْ ن أَربِّي، مَاشَا إِنِّي ذِي بَارَّا أَذْ أَسنْ يِيڒِي كُوڒْشِي س إِمذْيَا، \x ◘ \xo 4:‏11 \xt مت. 11‏:‏25؛ 2 كُور. 2‏:‏14؛ 3‏:‏14. \x*
\v 12 حِيمَا أَمْ تّْوَاڒَانْ، تّْوَاڒَانْ، \add مَاشَا\add* وَارْ تّْوِيڒِينْ، أَمْ تّسْڒَانْ، تّسْڒَانْ، \add مَاشَا\add* وَارْ فهّْمنْ، حِيمَا وَارْ تّثُوبنْ ؤُشَا أَذْ أَسنْ إِتّْوَاغْفَارْ دّْنُوبْ نْسنْ.‘ “ \x ◘ \xo 4:‏12 \xt إِشا. 6‏:‏9‏-‏10؛ مت. 13‏:‏14؛ لك. 8‏:‏10؛ يُوح. 12‏:‏40؛ ڒخ. 28‏:‏26؛ رُوم. 11‏:‏8. \x*
\b
\m 
\v 13 إِنَّا أَسنْ: ”مَا وَارْ ثفْهِيممْ شَا إِ ؤُمذْيَا-يَا؟ مَامّشْ إِ غَا ثسّْنمْ مَارَّا إِمتِّيڒنْ-أَ؟ \x ◘ \xo 4:‏13 \xt [مت. 13‏:‏18‏-‏23؛ لك. 8‏:‏11‏-‏15]\x*
\v 14 أَفدْجَاحْ نِّي إِزَارْعنْ، إِزَارّعْ أَوَاڒْ. \x ◘ \xo 4:‏14 \xt مت. 13‏:‏19؛ لك. 8‏:‏11. \x*
\v 15 إِنَا أَقَا ذ إِنِّي خْ وبْرِيذْ، أَقَا يِينَا ذ يِينِّي ذَايْسنْ إِتّْوَازَارْعْ وَاوَاڒْ، \add مَاشَا\add* أَوَارْنِي ڒَامِي ذ أَسْ سْڒِينْ، ڒخْذنِّي يُوسَا-د شِّيطَانْ ؤُشَا إِكّسْ أَوَاڒْ إِ إِتّْوَازَارْعنْ ذڭْ وُوڒَاونْ نْسنْ.
\v 16 ؤُشَا يِينَا ذ إِنِّي إِتّْوَازَارْعنْ خْ ثمُّورْثْ ؤُحجْرِي، أَقَا يِينَا ذ إِنِّي خْمِي غَا سْڒنْ أَوَاڒْ، أَذْ ث قبْڒنْ ذغْيَا س ڒفْرَاحثْ،
\v 17 \add مَاشَا\add* وَارْ غَارْسنْ بُو جَّاذِيرَا ذڭْ إِخفْ نْسنْ، أَذْ قِّيمنْ غَارْ إِجّْ ن ڒْمِيجَاڒْ \add وَاهَا\add*. مَاڒَا ثمْسَارْ ڒْمحْنثْ نِيغْ ؤُمَارّثْ ذِي سِّيبّثْ ن وَاوَاڒْ، أَذْ نْقَارْضنْ ذغْيَا.
\v 18 ؤُشَا يِينَا ذ إِنِّي إِتّْوَازَارْعنْ جَارْ إِسنَّاننْ، أَقَا يِينَا ذ إِنِّي خْمِي غَا سْڒنْ أَوَاڒْ،
\v 19 أَذْ غَارْسنْ د-أَذْفنْثْ ثْحِيسَّافْ ن دُّونشْثْ-أَ ذ ؤُغكّْوِي ن وَاڭْڒَا ذ \add مَارَّا\add* نّشْوَاثْ إِنّغْنِي، أَذْ جيّْفنْثْ أَوَاڒْ، خنِّي إِذَاكّْوَاڒْ \add وَاوَاڒْ\add* بْڒَا ڒْغِيدْجثْ. \x ◘ \xo 4:‏19 \xt مت. 19‏:‏23؛ مك. 10‏:‏23؛ لك. 18‏:‏24؛ 1 تِيم. 6‏:‏9. \x*
\v 20 ؤُشَا يِينَا ذ إِنِّي إِتّْوَازَارْعنْ خْ ثمُّورْثْ إِصبْحنْ، أَقَا يِينَا ذ إِنِّي، خْمِي غَا سْڒنْ أَوَاڒْ، أَذْ ث قبْڒنْ، أَذْ وْشنْ ڒْغِيدْجثْ، شَا \add زَّايْسنْ\add* ثْڒَاثِينْ، إِنّغْنِي ستِّينْ ؤُ إِنّغْنِي مْيَا ن ثْسقَّارْ.“
\b
\s1 أَمذْيَا ن ڒْقنْذِيڒْ ذ ڒْمرْفعْ نّسْ
\m 
\v 21 إِنَّا أَسنْ: ”مَا أَذْ د-أَسنْ س ڒْقنْذِيڒْ، حِيمَا أَذْ إِمَّارْسْ سَاذُو ڒْمُوذْ ن إِمنْذِي نِيغْ سَاذُو قَامَا؟ مَا وَارْ إِتّْمَارْسِي شَا خْ ڒْمرْفعْ؟ \x ◘ \xo 4:‏21 \xt [لك. 8‏:‏16‏-‏18] — مت. 5‏:‏15؛ لك. 8‏:‏16؛ 11‏:‏33. \x*
\v 22 مِينْزِي وَارْ ذِينْ مِينْ إِنُوفَّارنْ وَارْ د-إِتّْوَاسَّارْڭبْ، ؤُشَا \add وَارْ ذِينْ\add* ؤُڒَا ذ إِشْثْ ن ڒْحَاجّثْ ذِي ثْنُوفّْرَا وَارْ ثثْوَاسّضْهَارِي. \x ◘ \xo 4:‏22 \xt أَيُوبْ 12‏:‏22؛ مت. 10‏:‏26؛ لك. 8‏:‏17؛ 12‏:‏2. \x*
\v 23 مَاڒَا \add ذِينْ\add* حذْ إِ غَارْ إِدْجَا إِمزُّوغنْ إِ ؤُسدْجِي، أجّْ إِ-ث أَذْ إِسڒْ.“
\b
\m 
\v 24 إِنَّا أَسنْ: ”حْضَامْ مِينْ غَا ثسْڒمْ. س ڒقْيَاسْ نِّي زَّايسْ إِ غَا ثعْبَارمْ، زَّايسْ إِ ذ أَومْ غَا عْبَارنْ \add عَاوذْ\add*، ؤُشَا إِ كنِّيوْ إِنِّي إِتّسْڒَانْ أَذْ أَسنْ إِمَّارْنِي عَاذْ. \x ◘ \xo 4:‏24 \xt مت. 7‏:‏2؛ لك. 6‏:‏38. \x*
\v 25 مِينْزِي ونِّي غَارْ إِدْجَا أَذْ أَسْ إِمَّارْنِي، ؤُ ونِّي وَارْ غَارْ إِدْجِي، ؤُڒَا ذ مِينْ غَارسْ أَذْ أَسْ إِتّْوَاكّسْ.“ \x ◘ \xo 4:‏25 \xt مت. 13‏:‏12؛ 25‏:‏29؛ لك. 8‏:‏18؛ 19‏:‏26. \x*
\b
\s1 أَمذْيَا ن زَّارِيعثْ ذ ثْڭلْذِيثْ ن أَربِّي
\m 
\v 26 إِنَّا: ”س ؤُينِّي أَذْ ثِيڒِي ثَاڭلْذِيثْ ن أَربِّي أَمْ يِيجّْ ن ورْيَازْ إِنطَّارْ زَّارِيعثْ ذِي ثمُّورْثْ،
\v 27 خنِّي أَذْ إِطّصْ، أَذْ د-إِكَّارْ، دْجِيڒثْ ذ وَاسّْ. ؤُشَا زَّارِيعثْ أَذْ ثْڭعّذْ، أَذْ ثڭْمَا، مَاشَا نتَّا وَارْ إِسِّينْ مَامّشْ.
\v 28 مِينْزِي ثَامُّورْثْ ثتَّاوِي-د ڒْغِيدْجثْ \add س يِيخفْ نّسْ\add*: أَمزْوَارْ أَغمُّويْ، خنِّي ثِيذَارْثْ، أَوَارْنِي أَسْ إِرْذنْ إِكمّْڒنْ ذِي ثِيذَارْثْ.
\v 29 ڒَامِي د-ثِيوضْ ڒْغِيدْجثْ، ڒخْذنِّي إِسّكّْ أَمْجَارْ، مِينْزِي ثَاميْرَا ثِيوضْ-د.“ \x ◘ \xo 4:‏29 \xt يُووِ. 3‏:‏13\x*
\b
\s1 أَمذْيَا ن ثْحبُّوشْثْ ن زَّارِيعثْ ن ؤُخرْذلْ
\m 
\v 30 إِنَّا: ”مِينْ ذِي إِ غَا نَارْوسْ ثَاڭلْذِيثْ ن أَربِّي نِيغْ س مَانْ أَمذْيَا إِ زِي ت إِ غَا نَارْشمْ؟ \x ◘ \xo 4:‏30 \xt [مت. 13‏:‏31‏-‏32، 34‏-‏35؛ لك. 13‏:‏18‏-‏19] — مت. 13‏:‏31؛ لك. 13‏:‏18. \x*
\v 31 أَقَا-ت أَمْ ثْحبُّوشْثْ ن زَّارِيعثْ ن ؤُخرْذلْ، ثنِّي، ڒَامِي ثتّْوَازَارْعْ ذِي ثمُّورْثْ، أَقَا نتَّاثْ ذ ثَامژْيَانْثْ خْ مَارَّا ثِيحبَّا ن زَّارِيعثْ إِ إِدْجَانْ ذِي ثمُّورْثْ.
\v 32 أَوَارْنِي ڒَامِي ثتّْوَازَارْعْ، ثغْمِي-د، ثمْغَارْ خْ مَارَّا ثِيبِّي، أَذْ ثڭّْ ڒفْرُوعْ إِمْغَارنْ أَڒَامِي إِجْضَاضْ ن ؤُجنَّا زمَّارنْ أَذْ ڭّنْ ڒعْوَاشّْ ذِي ثِيڒِي نّسْ.“
\b
\m 
\v 33 ثُوغَا يَاسُوع إِسَّاوَاڒْ أَوَاڒْ أَكِيذْسنْ س إِمذْيَا أَطَّاسْ أَمْ يِينَا، س إِمذْيَا إِتّْڒِيقنْ مَاحنْذْ أَذْ ثنْ سْڒنْ \add إِوْذَانْ\add*.\x ◘ \xo 4:‏33 \xt مت. 13‏:‏34. \x*
\v 34 بْڒَا إِمذْيَا وَارْ كِيسنْ إِسِّيوڒْ شَا، مَاشَا ثُوغَا إِسّفْهَامْ كُوڒْشِي إِ إِمحْضَارنْ نّسْ وحّذْسنْ.
\b
\s1 يَاسُوع ذ ثْحَارْيَاضْثْ
\m 
\v 35 ذڭْ وَاسّْ نِّي، ڒَامِي ذ ثوْضَا ثْمذِّيثْ، إِنَّا أَسنْ: ”أجّْ أَنغْ أَذْ نژْوَا غَارْ ؤُجمَّاضِينْ.“ \x ◘ \xo 4:‏35 \xt [مت. 8‏:‏23‏-‏27؛ لك. 8‏:‏22‏-‏25] — مت. 8‏:‏23؛ لك. 8‏:‏22. \x*
\v 36 سمْحنْ ذِي ڒْغَاشِي، إِوْينْ ث ؤُمِي ث ثُوغَا عَاذْ ذِي ثْغَارَّابُوثْ، ؤُشَا ثُوغَا ذِينْ أَكِيذْسنْ عَاوذْ ثِيغَارُّوبَا نّغْنِي.
\v 37 ؤُشَا ثكَّارْ-د إِشْثْ ن ثْحَارْيَاضْثْ ثمْغَارْ، ڒمْوَاجْ شَّاثنْ ذِي ثْغَارَّابُوثْ أَڒَامِي ثبْذَا ثتّْشُورَا.
\v 38 \add مَاشَا\add* يَاسُوع ثُوغَا إِطّصْ خْ إِشْثْ ن ثْسُونْثَا غَارْ ضفَّارْ ن ثْغَارَّابُوثْ. نِيثْنِي سّْفَاقنْ ث، نَّانْ أَسْ: ”\add أَ\add* أَمْسڒْمَاذْ نّغْ، مَا وَارْ ذ أَشْ نشْقِي شَا نشِّينْ مَاڒَا نتّْوَاهلّكْ؟“
\v 39 \add خنِّي\add* إِكَّارْ، إِوبّخْ أَسمِّيضْ، إِنَّا إِ ڒبْحَارْ: ”أَرْسْ! سْقَارْ!“ يَارْسَا ؤُسمِّيضْ ؤُشَا إِذْوڒْ كُوڒْشِي يَارْسَا. \x ◘ \xo 4:‏39 \xt أَيُوبْ 26‏:‏12؛ إِزهد. 107‏:‏29؛ إِشا. 51‏:‏10. \x*
\v 40 \add خنِّي\add* إِنَّا أَسنْ: ”مَايمِّي ثڭّْوذمْ أَمُّو؟ مِينْ كنِّيوْ يُوغِينْ وَارْ ذَايْومْ بُو لْ-إِيمَانْ؟“
\v 41 ثُوذفْ إِ-ثنْ ثِيڭّْوُوذِي ثمْغَارْ، نَّانْ إِ وَايَاوْيَا: ”مِينْ إِعْنَا وَا، أَقَا ؤُڒَا ذ أَسمِّيضْ ذ ڒبْحَارْ تّطَّاعنْ أَسْ؟“
\b
\b
\c 5
\s1 أَسْڭنْفِي ن إِجّْ ن ؤُمرْيَاحْ
\m 
\v 1 ؤُشَا يِيوضْ نتَّا غَارْ ؤُجمَّاضِينْ ن ڒبْحَارْ ذِي ثمُّورْثْ ن ڭَاذَارِينِيسْ. \x ◘ \xo 5:‏1 \xt [مت. 8‏:‏28‏-‏34؛ لك. 8‏:‏26‏-‏39] — مت. 8‏:‏28؛ لك. 8‏:‏26. \x*
\v 2 ؤُمِي د-إِفّغْ زِي ثْغَارَّابُوثْ، إِڒْقَا إِ-ث إِجّْ ن بْنَاذمْ زڭْ إِمضْڒَانْ ذَايسْ إِجّْ ن ڒَارْيَاحْ ذ أَمنْڭُوسْ.
\v 3 ثُوغَا إِزدّغْ ذڭْ إِمضْڒَانْ ؤُشَا وَارْ إِزمَّارْ حذْ أَذْ ث إِشَارْفْ ؤُڒَا س سّْنَاسڒْ،
\v 4 مِينْزِي وَاخَّا ثُوغَا شَارْفنْ ث أَطَّاسْ ن ثْوَاڒَاوِينْ س إِشذِّييّنْ غَارْ إِضَارنْ ؤُ س سّْنَاسڒْ، أَقَا نتَّا إِقْضُو سّْنَاسڒْ \add نِّي\add*، يَارْژَا إِشذِّييّنْ ؤُ وَارْ إِزمَّارْ حذْ أَذْ ث إِقمّعْ.
\v 5 ثُوغَا-ث ڒبْذَا، أَسّْ ذ دْجِيڒثْ، ذڭْ إِذُورَارْ ؤُ ذڭْ إِمضْڒَانْ، إِسْغُويُّو، إِيزّمْ إِخفْ نّسْ س إِژْرَا.
\m 
\v 6 ؤُمِي إِژْرَا نتَّا يَاسُوع زِي ڒَاڭّْوَاجْ، يُوزّڒْ ؤُشَا إِسْجذْ أَسْ.
\v 7 إِسْغُويْ س جّهْذْ ؤُشَا إِنَّا أَسْ: ”مِينْ ذِينْ جَارْ أَيِي أَكِيذكْ، أَ يَاسُوع، مِّيسْ ن أَربِّي، أَمْعُودْجِي خْ كُوڒْشِي. تّْزَاوْڭغْ شكْ س أَربِّي، وَارْ ذ أَيِي تّْمَارَّاثْ!“
\v 8 مِينْزِي أَقَا إِنَّا أَسْ: ”فّغْ زِي بْنَاذمْ-أَ، \add أَ\add* ڒَارْيَاحْ أَمنْڭُوسْ!“
\v 9 إِسّقْسَا ث: ”مَامّشْ ذ أَشْ قَّارنْ؟“ يَارَّا-د، إِنَّا: ”إِسمْ إِنُو ’لِيخْيُونْ‘، \add مَانْ أَيَا إِخْسْ أَذْ يِينِي ’أَبَارُّو‘\add*، مِينْزِي نشِّينْ ذڭْ وَاطَّاسْ.“
\v 10 إِزَاوْڭْ إِ-ث أَطَّاسْ حِيمَا وَارْ ث إِسِّيڭّْوجْ بَارَّا إِ ثمُّورْثْ \add نِّي\add*.
\v 11 ثُوغَا ذِينْ غَارْ وذْرَارْ إِشْثْ ن ثْحِيمَارْثْ ثمْغَارْ ن إِڒْفَانْ ثتّْهدَّا.
\v 12 زَاوْڭنْ ث شّْوَاطنْ نِّي، نَّانْ: ”سكّْ أَنغْ غَارْ إِڒْفَانْ، حِيمَا نْزمَّارْ أَذْ ذَايْسنْ نَاذفْ.“
\v 13 إِسَامْحْ أَسنْ يَاسُوع. ڒخْذنِّي فّْغنْ ڒَارْيَاحْ إِمنْڭَاسْ \add زڭْ ورْيَازْ نِّي\add*، ؤُذْفنْ ذڭْ إِڒْفَانْ، ؤُشَا ثُوزّڒْ ثْحِيمَارْثْ نِّي غَارْ إِجّْ ن جَّارْفْ يُوعْڒَانْ ؤُشَا ثوْضَا ذِي ڒبْحَارْ. ثُوغَا-ثنْ عْڒَاحَاڒْ ذڭْ وَاڒْفَاينْ زَّايْسنْ ؤُشَا غَارْقنْ ذِي ڒبْحَارْ.
\m 
\v 14 مَاشَا إِمكْسَاونْ ن إِڒْفَانْ أَروْڒنْ، خبَّارنْ مَانْ أَيَا ذِي ثنْذِينْثْ ؤُ خْ إِيَّارنْ. \add إِوْذَانْ\add* فّْغنْ-د حِيمَا أَذْ ژَترنْ مِينْ إِمْسَارنْ.
\v 15 ؤُسِينْ-د غَارْ يَاسُوع، تّْوَاڒَانْ أَمَارْيَاحْ إِ ذَايسْ ثُوغَا شّْوَاطنْ، ونِّي ذِي ثُوغَا إِزدّغْ ’لِيخْيُونْ‘، إِقِّيمْ، يَارْضْ، س ڒْبَاڒْ نّسْ، ؤُشَا ڭّْوذنْ.
\v 16 إِنِّي إِژْرِينْ مَانْ أَيَا، خبَّارنْ ثنْ مِينْ إِمْسَارنْ إِ ؤُمَارْيَاحْ إِ ذِي ثُوغَا شّْوَاطنْ، ؤُ عَاوذْ خْ يِيڒْفَانْ نِّي.
\v 17 ؤُشَا بْذَانْ تّْزَاوْڭنْ ث مَاحنْذْ أَذْ إِڭّْوجْ خْ ثمُّورْثْ نْسنْ.
\m 
\v 18 ڒَامِي إِنْيَا نتَّا ذِي ثْغَارَّابُوثْ، إِزَاوْڭْ إِ-ث ؤُمَارْيَاحْ إِ ذَايسْ ثُوغَا شّْوَاطنْ حِيمَا أَذْ إِقِّيمْ أَكِيذسْ. \x ◘ \xo 5:‏18 \xt لك. 8‏:‏38. \x*
\v 19 وَارْ ث إِجِّي، مَاشَا إِنَّا أَسْ: ”رُوحْ غَارْ ثَادَّارْثْ نّشْ ذ ڒَادْجْ نّشْ، خبَّارْ إِ-ثنْ مَارَّا مِينْ زَّايكْ إِڭَّا سِيذِي، مَامّشْ خَاكْ يَارْحمْ.“
\v 20 ؤُشَا إِرُوحْ، إِبْذَا إِتّْبَارّحْ ذِي ذِيكاپُولِيسْ مَارَّا مِينْ ذ أَسْ إِڭَّا يَاسُوع، ؤُشَا مَارَّا ثْبهْثنْ.
\b
\s1 يدْجِيسْ ن يَايْرُوسْ - ثَامْغَارْثْ ثهْڒشْ ڒْقدّْ ن ثنْعَاشْ ن إِسڭّْوُوسَا
\m 
\v 21 أَوَارْنِي ڒَامِي إِژْوَا يَاسُوع س ثْغَارَّابُوثْ غَارْ ؤُجمَّاضْ، إِمُونْ-د خَاسْ عَاوذْ أَطَّاسْ ن ڒْغَاشِي أَمْ ثُوغَا-ث خْ ثْمَا ن ڒبْحَارْ. \x ◘ \xo 5:‏21 \xt [مت. 9‏:‏18‏-‏26؛ لك. 8‏:‏40‏-‏56] — لك. 8‏:‏40. \x*
\v 22 يُوسَا-د \add عَاوذْ\add* إِجّنْ زڭْ إِمقّْرَاننْ ن ثمْزِيذَا، قَّارنْ أَسْ يَايْرُوسْ. ؤُمِي ث إِژْرَا، إِوْضَا أَسْ غَارْ إِضَارنْ. \x ◘ \xo 5:‏22 \xt مت. 9‏:‏18؛ لك. 8‏:‏41. \x*
\v 23 إِزَاوْڭْ إِ-ث أَطَّاسْ، إِنَّا أَسْ: ”إِدْجِي ثْمَاژُوژْثْ ثْحڒْشْ أَطَّاسْ. تّْزَاوْڭغْ شكْ أَذْ د-ثَاسذْ، أَذْ خَاسْ ثسَّارْسذْ إِفَاسّنْ نّشْ، حِيمَا أَذْ ثڭّنْفَا، أَذْ ثدَّارْ.“
\v 24 إِرُوحْ أَكِيذسْ ؤُشَا إِضْفَارْ إِ-ث-إِ-د وَاطَّاسْ ن ڒْغَاشِي، ؤُشَا نِيثْنِي ذحّْسنْ ث.
\m 
\v 25 مَاشَا ثُوغَا \add ذِينْ\add* إِشْثْ ن ثمْغَارْثْ تَّازّْڒنْ زَّايسْ إِذَامّنْ ثنْعَاشْ ن إِسڭّْوُوسَا، \x ◘ \xo 5:‏25 \xt لَاوِي 15‏:‏25؛ مت. 9‏:‏20؛ لك. 8‏:‏43. \x*
\v 26 ؤُشَا ثكَّا خَاسْ ثَامَارَا أَطَّاسْ زڭْ إِضْبِيبنْ ؤُمِي ثسُّوفّغْ مَارَّا مِينْ غَارسْ، \add مَاشَا\add* وَارْ ثسْثنْفِيعْ س وَالُو، ؤُشَا يَارْنِي عَاذْ خَاسْ ڒْحَاڒْ.
\v 27 أَقَا ثسْڒَا خْ يَاسُوع ؤُشَا ثُوسَا-د \add غَارسْ\add* أَمْ ثكَّا خْ دّْحَاسْ ن ڒْغَاشِي زِي ضفَّارْ نّسْ ؤُشَا ثْحَاذَا أَرُّوضْ نّسْ،
\v 28 مِينْزِي ثنَّا: ”مَاڒَا حَاذِيغْ مْغِيرْ أَرُّوضْ نّسْ، أَذْ \add قِّيمغْ\add* دَّارغْ.“
\v 29 ڒخْذنِّي يُوژغْ ؤُسِيزّڒْ ن إِذَامّنْ، ثُوشَا أَكْ-ذ أَرِّيمثْ نّسْ بلِّي ثڭّنْفَا زِي ڒهْڒَاشْ نّسْ.
\m 
\v 30 ڒخْذنِّي يُوشَا يَاسُوع أَكْ-ذ يِيخفْ نّسْ بلِّي إِفّغْ زَّايسْ جّهْذْ ؤُشَا إِنّقْڒبْ غَارْ ڒْغَاشِي، إِنَّا: ”وِي إِحَاذَانْ أَرُّوضْ إِنُو؟“ \x ◘ \xo 5:‏30 \xt لك. 6‏:‏19. \x*
\v 31 نَّانْ أَسْ إِمحْضَارنْ نّسْ: ”شكْ ثْوَاڒِيذْ ڒْغَاشِي إِذحّسْ إِ شكْ ؤُ شكْ ثسّقْسِيذْ: ’وِي ذ أَيِي إِحَاذَانْ؟‘ “
\v 32 \add مَاشَا\add* إِقِّيمْ إِخزَّارْ حِيمَا أَذْ إِژَارْ وِي يڭِّينْ مَانْ أَيَا.
\v 33 ثُوغَا ثَامطُّوثْ ثڭّْوذْ، ثتَّارْجِيجِي، أَمْ ثسّنْ مِينْ ذ أَسْ إِمْسَارنْ، ؤُشَا ثُوسَا-د، ثوْضَا أَسْ غَارْ إِضَارنْ ؤُشَا ثْعَاوذْ أَسْ ثِيذتّْ مَارَّا.
\v 34 \add خنِّي\add* إِنَّا أَسْ: ”\add أَ\add* يدْجِي، لْ-إِيمَانْ نّمْ أَقَا إِوْشَا أَمْ ثُوذَارْثْ، رُوحْ س ڒهْنَا أَذْ ثِيڒِيذْ ثڭّنْفِيذْ زِي ڒهْڒَاشْ نّمْ!“ \x ◘ \xo 5:‏34 \xt مت. 9‏:‏22؛ مك. 10‏:‏52. \x*
\m 
\v 35 أَمْ ثُوغَا عَاذْ إِسَّاوَاڒْ، ؤُسِينْ-د شَا زِي ثَادَّارْثْ ن ؤُمقّْرَانْ ن ثمْزِيذَا، نَّانْ أَسْ: ”إِدْجِيشْ ثمُّوثْ، مَايمِّي ثْصدَّاعذْ عَاذْ أَمْسغَّارْ؟“ \x ◘ \xo 5:‏35 \xt لك. 8‏:‏49. \x*
\v 36 \add مَاشَا\add* يَاسُوع إِسْڒَا أَوَاڒنْ إِ إِنَّانْ ؤُشَا إِنَّا إِ ؤُمقّْرَانْ ن ثمْزِيذَا: ”وَارْ تّڭّْوذْ شَا! أَمنْ وَاهَا!“
\v 37 وَارْ إِسْمِيحْ ؤُڒَا إِ يِيجّنْ أَذْ ث يُويُورْ أَكِيذسْ، مْغِيرْ شِيمْعُونْ بُوطْرُوسْ ذ يَاعْقُوبْ ذ يُوحَانَّا، ؤُمَاسْ ن يَاعْقُوبْ.
\v 38 ؤُسِينْ-د غَارْ ثَادَّارْثْ ن ؤُمقّْرَانْ ن ثمْزِيذَا ؤُشَا إِژْرَا إِ-ثنْ شَّاثنْ أَڭجْذُورْ، تّْرُونْ ؤُشَا سْغُويُّونْ.
\v 39 ؤُمِي د-يُوذفْ، إِنَّا أَسنْ: ”مَايمِّي ثشَّاثمْ أَڭجْذُورْ، ثتّْرُومْ؟ ثَاحنْجِيرْثْ وَارْ ثمُّوثْ شَا، مَاشَا أَقَا ثطّصْ.“ \x ◘ \xo 5:‏39 \xt يُوح. 11‏:‏11. \x*
\v 40 نِيثْنِي ضحْشنْ زَّايسْ. \add مَاشَا\add* نتَّا إِسُّوفّغْ إِ-ثنْ كُوڒْشِي بَارَّا ؤُشَا يِيوِي أَكِيذسْ بَابَاسْ ذ يمَّاسْ ن ثْحنْجِيرْثْ ذ يِينِّي ثُوغَا أَكِيذسْ، خنِّي يُوذفْ-د مَانِي ثُوغَا ثتّْوَاسَّارْسْ ثْحنْجِيرْثْ.
\v 41 إِطّفْ ذڭْ ؤُفُوسْ ن ثْحنْجِيرْثْ، إِنَّا أَسْ: ”كَّارْ، \add أَ\add* ثَاحنْجِيرْثْ!“
\v 42 ڒخْذنِّي ثكَّارْ ثْحنْجِيرْثْ ؤُشَا ثُويُورْ، مِينْزِي ثُوغَا ثَاحنْجِيرْثْ غَارسْ ثنْعَاشْ ن إِسڭّْوُوسَا. ثْبهْثنْ نِيثْنِي س يِيجّْ ن ؤُثبْهثْ إِمْغَارْ.
\v 43 ؤُشَا نتَّا يُومُورْ إِ-ثنْ س جّهْذْ، حِيمَا ؤُڒَا ذ إِجّنْ أَذْ إِبَارّحْ س مَانْ أَيَا. \add خنِّي\add* إِوصَّا أَذْ أَسْ وْشنْ حِيمَا أَذْ ثشّْ.
\b
\b
\c 6
\s1 أَنَابِي وَارْ غَارسْ بُو شَّانْ ذِي ثمُّورْثْ نّسْ
\m 
\v 1 إِفّغْ سّنِّي، يُوسَا-د غَارْ ثنْذِينْثْ نّسْ، ؤُشَا ضْفَارنْ ث-إِ-د إِمحْضَارنْ نّسْ. \x ◘ \xo 6:‏1 \xt [مت. 13‏:‏53‏-‏58؛ لك. 4‏:‏16‏-‏30] — مت. 13‏:‏53؛ لك. 4‏:‏16. \x*
\v 2 ڒَامِي د-ثِيوضْ سّبْثْ، إِبْذَا إِسّڒْمَاذْ ذِي ثمْزِيذَا. أَطَّاسْ ن يِينِّي ذ أَسْ إِسْڒِينْ، ثْبهْثنْ، نَّانْ: ”زِي مَانِيسْ د-ؤُسِينْثْ ثْمسْڒَايِينْ-أَ غَارْ وَانِيثَا؟ مَانَا ثِيغِيثْ-أَ إِ ذ أَسْ إِمّوْشنْ أَڒَامِي مْسَارنْثْ خْ إِفَاسّنْ نّسْ ڒعْجَايبْ أَمْ ثِينَا؟
\v 3 مَا وَارْ إِدْجِي وَا ذ أَنجَّارْ، مِّيسْ ن مَارْيَامْ، ذ ؤُمَاسْ ن يَاعْقُوبْ ذ يُوسِيسْ ذ يَاهُوذَا ذ شِيمْعُونْ؟ مَا وَارْ دْجِينْثْ سُويثْمَاسْ ذَا أَكِيذْنغْ؟“ ؤُ نِيثْنِي نْذرْفنْ ذَايسْ. \x ◘ \xo 6:‏3 \xt مت. 13‏:‏55؛ يُوح. 6‏:‏42. \x*
\v 4 \add مَاشَا\add* يَاسُوع إِنَّا أَسنْ: ”أَنَابِيعمَّارْصْ وَارْ إِدْجِي بْڒَا شَّانْ مْغِيرْ ذِي ثنْذِينْثْ نّسْ، جَارْ ڒَادْجْ نّسْ ؤُ ذِي ثَادَّارْثْ نّسْ.“ \x ◘ \xo 6:‏4 \xt مت. 13‏:‏57؛ لك. 4‏:‏24؛ يُوح. 4‏:‏44. \x*
\v 5 ؤُشَا نتَّا وَارْ إِزمَّارْ أَذْ ذِينْ إِڭّْ ؤُڒَا ذ إِجّْ ن ڒعْجبْ، إِلَّا إِسَّارْسْ أَفُوسْ نّسْ خْ ذْرُوسْ ن إِمهْڒَاشْ وَاهَا ؤُشَا إِسّْڭنْفَا إِ-ثنْ. \x ◘ \xo 6:‏5 \xt مت. 13‏:‏58. \x*
\v 6 ثُوغَا إِتّبْهثْ زِي ثِيكّسْثْ ن لْ-إِيمَانْ نْسنْ. \add خنِّي\add* إِرُوحْ، إِتّْسَارَا ذْشُورَاثْ يُوذْسنْ، إِسّڒْمَاذْ. \x ◘ \xo 6:‏6 \xt مت. 9‏:‏35؛ لك. 13‏:‏22. \x*
\b
\s1 أَسكِّي ن ثنْعَاشْ ن رُّوسُولْ
\m 
\v 7 إِڒَاغَا-د إِ ثنْعَاشْ \add ن رُّوسُولْ\add*، إِبْذَا إِسّكّْ إِ-ثنْ ثْيُويَا ثْيُويَا ؤُشَا إِوْشَا أَسنْ صُّولْطَا خْ ڒَارْيَاحْ إِمنْڭَاسْ، مَاحنْذْ أَذْ ثنْ سُّوفّْغنْ. \x ◘ \xo 6:‏7 \xt [مت. 10‏:‏1، 5‏-‏15؛ لك. 9‏:‏1‏-‏6] — مت. 10‏:‏1؛ لك. 6‏:‏13؛ 9‏:‏1. \x*
\v 8 يُومُورْ إِ-ثنْ حِيمَا وَارْ كسِّينْ وَالُو ذڭْ وبْرِيذْ مْغِيرْ ثَاغَّارْشْثْ وَاهَا، لَّا تّسْطِيمْ، لَّا أَغْرُومْ، لَّا \add ثِيبْيِيسِينْ ن\add* نّْحَاسْ ذِي ثشْيَارِينْ نْسنْ، \x ◘ \xo 6:‏8 \xt مت. 10‏:‏10؛ لك. 9‏:‏3\x*
\v 9 \add مَاشَا\add* إِوْشْ أَسنْ تّسْرِيحْ مَاحنْذْ أَذْ قّْننْ سَانْذَالِييَاثْ، \add مَاشَا\add* وَارْ يَارّْضنْ ثْيُويَا ن ثْشَامِيرَاثْ. \x ◘ \xo 6:‏9 \xt ڒخ. 12‏:‏8. \x*
\v 10 إِنَّا أَسنْ: ”مَانِي مَا ثُوذْفمْ غَارْ شَا ن ثَادَّارْثْ، قِّيممْ ذَايسْ، أَڒْ سّنِّي إِ غَا ثفّْغمْ.
\v 11 غَارْ مَارَّا إِنِّي وَارْ كنِّيوْ إِقْبِيڒنْ ؤُ وَارْ غَارْومْ تّسْڒِينْ، زّرْزمْ ثَاعجَّاجْثْ زڭْ إِضَارنْ نْومْ ذ شّْهَاذثْ إِ نِيثْنِي. س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ، أَذْ يِيڒِي \add ڒْْحَاڒْ\add* إِهْونْ إِ ثمُّورْثْ ن سَاذُومْ ذ عَامُورَّا ذڭْ وَاسّْ ن لْحِيسَابْ زِي ثنْذِينْثْ نِّي.“ \x ◘ \xo 6:‏11 \xt مت. 10‏:‏14، 15؛ لك. 9‏:‏5؛ 10‏:‏12؛ ڒخ. 13‏:‏51؛ 18‏:‏6\x*
\v 12 ؤُشَا رُوحنْ، بَارّْحنْ حِيمَا أَذْ ثُوبنْ.
\v 13 سُّوفّْغنْ أَطَّاسْ ن شّْوَاطنْ، ذهْننْ إِمهْڒَاشْ أَطَّاسْ س زّشْثْ ؤُشَا سّْڭنْفَانْ ثنْ. \x ◘ \xo 6:‏13 \xt يَاع. 5‏:‏14. \x*
\b
\s1 ڒْموْثْ ن يُوحَانَّا أَمْسغْضَاصْ
\m 
\v 14 إِسْڒَا خَاسْ ؤُجدْجِيذْ هِيرُوذُوسْ، مِينْزِي إِسمْ نّسْ إِذْوڒْ إِشْنعْ، إِنَّا: ”أَقَا يُوحَانَّا أَمْسغْضَاصْ إِتّْوَاسّْنكَّارْ-د زِي ثَادَّارْثْ ن إِمتِّيننْ، س ؤُينِّي تّْوَاڭّنْثْ زَّايسْ ڒعْجَايبْ نِّي.“ \x ◘ \xo 6:‏14 \xt [مت. 14‏:‏1‏-‏12؛ لك. 9‏:‏7‏-‏9] — مت. 14‏:‏1؛ لك. 9‏:‏7. \x*
\v 15 إِنّغْنِي نَّانْ: ”أَقَا-ث ذ إِلِييَا!“، ؤُ إِنّغْنِي نَّانْ عَاوذْ: ”أَقَا-ث ذ نَّابِي أَمْ يِيجّنْ زڭْ إِنَابِييّنْ!“ \x ◘ \xo 6:‏15 \xt مت. 16‏:‏14؛ مك. 8‏:‏28؛ لك. 9‏:‏8، 19\x*
\v 16 ڒَامِي إِسْڒَا هِيرُوذُوسْ مَانْ أَيَا، إِنَّا: ”وَا ذ يُوحَانَّا ونِّي ؤُمِي قسّغْ أَزدْجِيفْ، أَقَا نتَّا إِتّْوَاسّْنكَّارْ-د زِي ثَادَّارْثْ ن إِمتِّيننْ.“
\v 17 مِينْزِي هِيرُوذُوسْ سِيمَانْثْ نّسْ، ثُوغَا إِسّكّْ-د \add غَارسْ\add* ؤُشَا إِحبّسْ يُوحَانَّا، إِشَارْفْ إِ-ث ذِي ڒحْبسْ خْ سِّيبّثْ ن هِيرُوذِييَّا، ثَامْغَارْثْ ن ؤُمَاسْ فِيلِيبُّوسْ، ثنِّي إِ-كْ-ذ إِمْڒشْ \add هِيرُوذُوسْ\add*. \f ◼ \fr 6:‏17 \ft \bd أَفسَّارْ\bd* - هِيرُوذُوسْ ثُوغَا ذ أَڒْوسْ ن هِيرُوذِييَّا، ثَامْغَارْثْ ن ؤُمَاسْ فِيلِيبُّوسْ.\f*  \x ◘ \xo 6:‏17 \xt مت. 14‏:‏3؛ لك. 3‏:‏19؛ 9‏:‏9. \x*
\v 18 مِينْزِي يُوحَانَّا ثُوغَا إِقَّارْ إِ هِيرُوذُوسْ: ”وَارْ ذ أَشْ إِحدْجڒْ أَذْ غَاركْ ثِيڒِي ثمْغَارْثْ ن ؤُمَاشْ.“ \x ◘ \xo 6:‏18 \xt لَاوِي 18‏:‏16؛ 20‏:‏21. \x*
\v 19 \add س ؤُينِّي\add* ثُوغَا هِيرُوذِييَّا ثنْضَارْ ذَايسْ ثِيطَّاوِينْ ؤُشَا ثَارزُّو أَذْ ث ثْنغْ، مَاشَا وَارْ ثْزمَّارْ،
\v 20 مِينْزِي هِيرُوذُوسْ ثُوغَا إِتّڭّْوذْ زِي يُوحَانَّا، إِسّنْ بلِّي نتَّا ذ أَرْيَازْ ذ أَمْسڭَّاذْ ذ أَمْقدَّاسْ ؤُ إِحطَّا خَاسْ. إِسْڒَا زَّايسْ أَطَّاسْ ن ثْمسْڒَايِينْ، \add خْ مِينْ\add* ثُوغَا إِتّڭّْ، ؤُشَا إِفَارْحْ أَذْ أَسْ إِسڒْ. \x ◘ \xo 6:‏20 \xt مت. 14‏:‏5؛ 21‏:‏26. \x*
\m 
\v 21 ذڭْ إِجّْ ن وَاسّْ إِتّْوَاسّْننْ إِڭَّا هِيرُوذُوسْ إِشْثْ ن زَّارْذثْ ذڭْ وَاسّْ ن ثْڒَاڒِيثْ نّسْ إِ ڒْحُوكَّامْ نّسْ إِ غَارْسنْ ڒمْغَارثْ أَطَّاسْ، إِ أَرُّويَاسْ خْ وَاڒفْ ن ڒْعسْكَارْ ؤُ إِ إِمقّْرَاننْ ن لْجَالِيلْ. \x ◘ \xo 6:‏21 \xt أَمز. 40‏:‏20؛ مت. 14‏:‏6. \x*
\v 22 ؤُشَا ثُوذفْ-د يدْجِيسْ \add ن هِيرُوذِييَّا\add*، ثشْضحْ، ثعْجبْ أَسْ إِ هِيرُوذُوسْ ذ يِينِّي إِقِّيمنْ أَكِيذسْ. خنِّي إِنَّا أَسْ ؤُجدْجِيذْ إِ ثْحنْجِيرْثْ: ”تَّارْ زَّايِي مَارَّا مِينْ ثخْسذْ، أَذْ أَمْ ث وْشغْ!“
\v 23 إِجُّودْجْ أَسْ: ”مشْحَاڒْ مَا زَّايِي إِ غَا ثتَّارذْ، أَذْ أَمْ ث وْشغْ، وَاخَّا أَڒْ أَزْينْ ن ثْڭلْذِيثْ إِنُو!“ \x ◘ \xo 6:‏23 \xt ڒقض. 11‏:‏30؛ إِسْت. 7‏:‏2\x*
\v 24 ثفّغْ-د نتَّاثْ، ثنَّا إِ يمَّاسْ: ”مِينْ ذ أَسْ إِ غَا تَّارغْ؟“ ثنَّا أَسْ ثَانِيثَا: ”أَزدْجِيفْ ن يُوحَانَّا أَمْسغْضَاصْ.“
\v 25 ثُوذفْ ذغْيَا س ثَازْڒَا غَارْ ؤُجدْجِيذْ، ثنَّا أَسْ: ”خْسغْ أَذْ أَيِي د-ثسَّارْسذْ ذِي ثْسَاعّثْ-أَ أَزدْجِيفْ ن يُوحَانَّا خْ إِجّْ ن طّبْصِي.“
\v 26 إِشْضنْ ؤُجدْجِيذْ أَطَّاسْ، مَاشَا خْ سِّيبّثْ ن ثْجَادْجِيثْ ؤُ خْ سِّيبّثْ ن \add إِنوْجِيونْ\add* إِ إِقِّيمنْ \add غَارْ طَّابْڒَا\add*، وَارْ إِخْسْ أَذْ ت إِقمّعْ،
\v 27 ؤُ ڒخْذنِّي إِسّكّْ ؤُجدْجِيذْ إِجّْ ن ؤُعسَّاسْ غَارْ ڒحْبسْ س سِّيفْ، يُومُورْ حِيمَا أَذْ د-يَاوِي أَزدْجِيفْ ن يُوحَانَّا. وَانِيثَا إِرُوحْ، إِقسّْ أَسْ أَزدْجِيفْ إِ يُوحَانَّا ذِي ڒحْبسْ. \x ◘ \xo 6:‏27 \xt مت. 14‏:‏10. \x*
\v 28 \add خَاسْ ؤُشَا\add* يِيوِي-د \add أَزدْجِيفْ نّسْ\add* خْ طّبْصِي، إِوْشَا أَسْ ث إِ ثْحنْجِيرْثْ ؤُ ثَاحنْجِيرْثْ ثوْشْ أَسْ ث إِ يمَّاسْ.
\v 29 ڒَامِي سْڒِينْ إِمحْضَارنْ نّسْ مَانْ أَيَا، ؤُسِينْ-د، كْسِينْ ڒْخشْبثْ نّسْ، سَّارْسنْ ت ذڭْ ونْضڒْ.
\b
\s1 لْمُوعْجِيزَا ن ؤُسشِّي أَمزْوَارُو
\m 
\v 30 مُوننْ رُّوسُولْ عَاوذْ غَارْ يَاسُوع، خبَّارنْ ث خْ كُوڒْشِي، خْ مِينْ ڭِّينْ ذ خْ مِينْ ثُوغَا سّڒْمَاذنْ. \f ◼ \fr 6:‏30 \ft \bd ’رُّوسُولْ‘\bd* - نِيغْ ’إِمَازَاننْ‘.\f*  \x ◘ \xo 6:‏30 \xt [مت. 14‏:‏13‏-‏21؛ لك. 9‏:‏10‏-‏17؛ يُوح. 6‏:‏1‏-‏14] — لك. 9‏:‏10. \x*
\v 31 إِنَّا أَسنْ: ”أَسمْ-د، أجّْ أَنغْ أَذْ نْرَاحْ وحّذْنغْ غَارْ إِجّْ ن ومْشَانْ إِخْڒَانْ، \add حِيمَا\add* أَذْ ثَاريّْحمْ شْوَايْثْ!“ مِينْزِي ثُوغَا ذِينْ أَطَّاسْ ن يِينِّي د-يُوسِينْ ذ ن يِينِّي إِرُوحنْ، أَڒَامِي وَارْ إِوِيضنْ أَذْ شّنْ. \x ◘ \xo 6:‏31 \xt مك. 3‏:‏20. \x*
\v 32 \add خنِّي\add* رُوحنْ وحّذْسنْ ذِي ثْغَارَّابُوثْ غَارْ إِجّْ ن ومْشَانْ إِخْڒَانْ. \x ◘ \xo 6:‏32 \xt مت. 14‏:‏13؛ لك. 9‏:‏10؛ يُوح. 6‏:‏1. \x*
\v 33 \add مَاشَا\add* ڒْغَاشِي إِژْرَا إِ-ثنْ فّْغنْ-د \add ذِي ثْغَارَّابُوثْ\add* ؤُشَا أَطَّاسْ إِ-ثعقْڒنْ. ؤُشَا إِزْوَارنْ أَسْ أَمْ تَّازّْڒنْ خْ إِضَارنْ غَارْ ذِينِّي زِي مَارَّا ثِيندَّامْ.
\m 
\v 34 ؤُمِي د-إِضْرَا يَاسُوع، إِژْرَا أَطَّاسْ ن ڒْغَاشِي، زِّيدْجْزنْ أَسْ، مِينْزِي ثُوغَا أَثنْ أَمْ وُودْجِي بْڒَا أَمكْسَاوْ. \add خنِّي\add* إِبْذَا أَذْ ثنْ إِسّڒْمذْ أَطَّاسْ. \x ◘ \xo 6:‏34 \xt إِرْم. 23‏:‏1؛ حِز. 34‏:‏2؛ مت. 9‏:‏36؛ 14‏:‏4؛ لك. 9‏:‏11. \x*
\m 
\v 35 رَامِي إِرُوحْ وَاسّْ أَذْ إِقْضَا، قَارّْبنْ-د غَارسْ إِمحْضَارنْ نّسْ، نَّانْ أَسْ: ”أَمْشَانْ-أَ إِخْڒَا ؤُ ڒْوقْثْ ثعْذُو. \x ◘ \xo 6:‏35 \xt مت. 14‏:‏15؛ لك. 9‏:‏12؛ يُوح. 6‏:‏5. \x*
\v 36 سكّْ إِ-ثنْ حِيمَا أَذْ رَاحنْ غَارْ ڒعْرَاصِييَّاثْ ؤُ غَارْ ذْشُورَاثْ يُوذْسنْ، حِيمَا أَذْ سْغنْ أَغْرُومْ إِ يِيخفْ نْسنْ، مِينْزِي وَارْ غَارْسنْ مِينْ غَا شّنْ.“
\v 37 مَاشَا نتَّا إِنَّا أَسنْ: ”وْشمْ أَسنْ كنِّيوْ مِينْ غَا شّنْ!“ نَّانْ أَسْ: ”مَا أَذْ نْرَاحْ مَاحنْذْ أَذْ أَسنْ نْسغْ أَغْرُومْ س مِيثَاينْ ذِينَارْ ؤُشَا أَذْ أَسنْ نوْشْ مِينْ غَا شّنْ؟“
\v 38 إِنَّا أَسنْ: ”رُوحمْ، خْزَارمْ مشْحَاڒْ ن ثشْنِيفِينْ إِ غَارْومْ ذَانِيثَا!“ ؤُمِي أَرْڭْبنْ، نَّانْ أَسْ: ”خمْسَا ن ثشْنِيفِينْ ن وغْرُومْ ذ ثْنَاينْ ن إِسڒْمَانْ.“ \x ◘ \xo 6:‏38 \xt مت. 14‏:‏17؛ مك. 8‏:‏5؛ لك. 9‏:‏13؛ يُوح. 6‏:‏9. \x*
\m 
\v 39 يُومُورْ إِ-ثنْ أَذْ \add ثنْ\add* سّْغِيمنْ مَارَّا ذِي ثْعُورِّيشِينْ خْ أَرْبِيعْ \add أَزِيزَا\add*.
\v 40 ؤُشَا قِّيمنْ ذِي ثْعُورِّيشِينْ ن مْيَا ؤُ ذِي ثْعُورِّيشِينْ ن خمْسِينْ.
\v 41 ؤُمِي إِكْسِي \add يشُّو\add* خمْسَا ن ثشْنِيفِينْ ذ ثْنَاينْ ن إِسڒْمَانْ \add نِّي\add*، إِسّْڭعّذْ ثَامُوغْڒِي نّسْ غَارْ ؤُجنَّا، إِبَاركْ ؤُشَا يَارْژَا ثِيشْنِيفِينْ، إِوْشَا إِ-ثنْثْ إِ إِمحْضَارنْ نّسْ، حِيمَا أَذْ ثنْثْ سَّارْسنْ زَّاثْسنْ. \add أَمُّو إِ\add* فَارْقنْ نِيثْنِي \add عَاوذْ\add* ثْنَاينْ ن إِسڒْمَانْ إِ مَارَّا.
\v 42 شِّينْ مَارَّا، جِّيوْننْ.
\v 43 \add خنِّي\add* ڒقْضنْ إِڒقّْوَازْ إِشطّنْ، شُّورنْ ثنْعَاشْ ن ثْسُودْجَاثِينْ، ؤُڒَا ذ إِسڒْمَانْ \add إِشطّنْ\add*.
\v 44 إِنِّي إِشِّينْ زِي ثشْنِيفِينْ ثُوغَا أَثنْ ذِي خمْسَا-أَڒَافْ ن يرْيَازنْ.
\b
\s1 يَاسُوع إِڭُّورْ خْ وَامَانْ ن ڒبْحَارْ
\m 
\v 45 ڒخْذنِّي إِزِييَّارْ خْ إِمحْضَارنْ نّسْ مَاحنْذْ أَذْ أَذْفنْ غَارْ ثْغَارَّابُوثْ، أَذْ أَسْ إِزْوَارنْ غَارْ ؤُجمَّاضْ، غَارْ بَايْثْ-صَايْذَا أَمْ إِسْقَاذْ نتَّا ڒْغَاشِي. \x ◘ \xo 6:‏45 \xt [مت. 14‏:‏22‏-‏33؛ يُوح. 6‏:‏16‏-‏21] — مت. 14‏:‏22؛ يُوح. 6‏:‏17. \x*
\v 46 ؤُشَا \add أَوَارْنِي ڒَامِي\add* ثنْ إِسْقَاذْ، إِرُوحْ غَارْ وذْرَارْ حِيمَا أَذْ إِژَّادْجْ. \x ◘ \xo 6:‏46 \xt مت. 14‏:‏23؛ لك. 6‏:‏12. \x*
\v 47 ڒَامِي د-ثوْضَا ثْمذِّيثْ ثُوغَا ثَاغَارَّابُوثْ ذِي ڒْبُوغَازْ ؤُشَا نتَّا ثُوغَا وحّْذسْ خْ ڒْبَارّْ. \x ◘ \xo 6:‏47 \xt مت. 14‏:‏23؛ يُوح. 6‏:‏16. \x*
\v 48 إِژْرَا بلِّي نِيثْنِي تّمْقثْمَارنْ س ؤُقدّفْ \add ن ثْغَارَّابُوثْ\add*، مِينْزِي أَسمِّيضْ يُوسَا أَسنْ-د ذڭْ ؤُغمْبُوبْ. غَارْ حطُّو وِيسّْ أَربْعَا ن دْجِيڒثْ يُوسَا-د غَارْسنْ يَاسُوع، إِڭُّورْ خْ وَاوَانْ ن ڒبْحَارْ، ؤُشَا ثُوغَا إِخْسْ أَذْ ثنْ إِعْذُو.
\v 49 ؤُمِي ث ژْرِينْ إِڭُّورْ ذِي ڒبْحَارْ، إِتّْغِيڒْ أَسنْ ذ ڒخْيَاڒْ أَغدَّارْ ؤُشَا سْغُوينْ، \x ◘ \xo 6:‏49 \xt مت. \x*
\v 50 مِينْزِي مَارَّا ژْرِينْ ث ؤُشَا نّْخڒْعنْ. ڒخْذنِّي إِسِّيوڒْ أَكِيذْسنْ، إِنَّا أَسنْ: ”ڭّمْ ؤُڒْ! أَقَا ذ نشّْ، وَارْ ثڭّْوذمْ شَا!“
\v 51 إِنْيِي-د غَارْسنْ ذِي ثْغَارَّابُوثْ ؤُشَا يَارْسَا ؤُسمِّيضْ. ثُوغَا نِيثْنِي تّْبهْثنْ، أَروّْعنْ أَطَّاسْ ذڭْ يِيخفْ نْسنْ،
\v 52 مِينْزِي وَارْ فْهِيمنْ وَالُو إِ \add لْمُوعْجِيزَا ن\add* ثشْنِيفِينْ، مِينْزِي ؤُڒْ نْسنْ ثُوغَا إِقْسحْ.
\b
\s1 أَسْڭنْفِي ن وَاطَّاسْ ن إِوْذَانْ ذِي جِينِيسَارثْ
\m 
\v 53 أَوَارْنِي ڒَامِي ژْوَانْ غَارْ ؤُجمَّاضْ، ؤُسِينْ-د غَارْ ثمُّورْثْ ن جِينِّيسَارثْ. \x ◘ \xo 6:‏53 \xt [مت. 14‏:‏34‏-‏36] — مت. 14‏:‏3. \x*
\v 54 ؤُمِي د-فّْغنْ زِي ثْغَارَّابُوثْ،عقْڒنْ ث إِوْذَانْ ذغْيَا.
\v 55 ؤُزّْڒنْ غَارْ مَارَّا جّْوَايهْ نِّي ؤُشَا بْذَانْ أَذْ د-أَوْينْ إِنِّي ثُوغَا إِهڒْشنْ أَطَّاسْ ذِي ثَاسُّوثْ غَارْ ومْشَانْ مَانِي سْڒِينْ أَقَا-ث نتَّا.
\v 56 مَانِي مَا د-يُوسَا، ذِي ثنْذِينْثْ نِيغْ ذِي ڒذْشُورْ نِيغْ ذِي ڒعْرَاصِييَّاثْ، سّْرُوسَانْ \add أَسْ-د\add* إِمهْڒَاشْ ذڭْ إِبْرِيذنْ ؤُشَا تّْزَاوَاڭنْ ث أَذْ أَسنْ إِسْمحْ أَذْ حَاذَانْ مْغِيرْ أَبحْڒُوڒْ ن ؤُجدْجَابْ نّسْ، ؤُ مَارَّا إِنِّي ث إِحَاذَانْ، ڭّنْفَانْ.
\b
\b
\c 7
\s1 شَّارِيعَا ذ ثُوبَّارْثْ ن إِوْذَانْ
\m 
\v 1 مُوننْ غَارسْ إِفَارِيسِييّنْ ذ إِمْسڒْمَاذنْ ن إِذْلِيسنْ إِ د-يُوسِينْ زِي ؤُرْشَالِيمْ. \x ◘ \xo 7:‏1 \xt [مت. 15‏:‏1‏-‏20] — مت. 15‏:‏1. \x*
\v 2 \add ؤُمِي\add* ژْرِينْ بلِّي شَا ن إِمحْضَارنْ نّسْ شِّينْ أَغْرُومْ بْڒَا ڭِّينْ أَذْ سِّيرْذنْ إِفَاسّنْ نْسنْ \add ذ أَمزْوَارُو\add*،عيّْبنْ خَاسنْ.
\v 3 مِينْزِي مَارَّا إِفَارِيسِييّنْ ذ وُوذَاينْ وَارْ تّتّنْ مْغِيرْ أَوَارْنِي ڒَامِي سِّيرْذنْ إِفَاسّنْ س يِيجّْ ن ڒُوضُو مْلِيحْ، مِينْزِي تّطّْفنْ ذِي ثُوبَّارْثْ ن إِمْغَارنْ.
\v 4 ؤُ ڒَامِي د-ؤُسِينْ زِي سُّوقْ، وَارْ تّتّنْ مَاڒَا وَارْ سّْغضْصنْ \add إِفَاسّنْ نْسنْ ذِي ثْبَانْيُوثْ\add* ذ أَمزْوَارُو، ؤُ أَقَا ذِينْ أَطَّاسْ ن ثْمسْڒَايِينْ نّغْنِي قبْڒنْ ثنْثْ، مَاحنْذْ أَذْ زَّايْسنْثْ طّْفنْ \add عْلَاحْسَابْ ثُوبَّارْثْ نْسنْ\add*، أَمْ ؤُسغْضَاسْ ن ڒْكِيسَانْ ذ ثيْذُورِينْ ذ ثبْرِيقِينْ ن نّْحَاسْ ذ \add دُّورِي\add* ن ڒشْثَاوَاثْ \add ذڭْ إِشْثْ ن ثْبَانْيُوثْ\add*. \x ◘ \xo 7:‏4 \xt لك. 11‏:‏‏:‏38\x*
\v 5 \add خنِّي\add* سّقْسَانْ ث إِفَارِيسِييّنْ ذ إِمْسڒْمَاذنْ ن إِذْلِيسنْ: ”مَايمِّي وَارْ ضْفَارنْ إِمحْضَارنْ نّشْ ثُوبَّارْثْ ن إِمْغَارنْ، مَاشَا تّتّنْ أَغْرُومْ أَمْ وَارْ سِّيرِيذنْ إِفَاسّنْ؟“
\v 6 يَارَّا-د، إِنَّا أَسنْ: ”نِيشَانْ إِنبَّا إِشَاعْيَا خَاومْ، \add أَ\add* إِمْنَافْقنْ، أَمْ مَامّشْ ثُورَا:
\b
\m \qt ’ڒْْڭنْسْ-أَ إِوقَّارْ أَيِي س إِينْشِيشنْ نّسْ،\qt*
\m \qt مَاشَا ؤُڒْ نْسنْ إِڭّْوجْ خَافِي!\qt* \x ◘ \xo 7:‏6 \xt إِشا. 29‏:‏13؛ حِز. 33‏:‏31. \x*
\m 
\v 7 \qt مَاشَا نِيثْنِي شنّْعنْ أَيِي بَاطڒْ،\qt*
\m \qt مِينْزِي سّڒْمَاذنْ ثِيغُورِيوِينْ\qt*
\m \qt ثِينِّي ذ ثِيوصَّا ن إِوْذَانْ.‘\qt* \x ◘ \xo 7:‏7 \xt مت. 15‏:‏9؛ كُول. 2‏:‏18، 20؛ ثِيث. 1‏:‏14. \x*
\b
\m 
\v 8 مِينْزِي ثجِّيمْ ثَاوْصيّثْ ن أَربِّي، ثطّْفمْ ذِي ثُوبَّارْثْ ن إِوْذَانْ، أَمْ ؤُسغْضَاسْ ن ڒْكِيسَانْ ذ ثيْذُورِينْ \add ذڭْ إِشْثْ ن ثْبَانْيُوثْ\add* ؤُ أَطَّاسْ ن ثْمسْڒَايِينْ نّغْنِي أَمْ ثِينَا.“
\v 9 إِنَّا أَسنْ: ”نِيشَانْ أَقَا ثْنطَّاڒمْ ثَاوْصيّثْ ن أَربِّي، حِيمَا أَذْ ثقِّيممْ ثتّطّْفمْ ذِي ثُوبَّارْثْ نْومْ.
\v 10 مِينْزِي مُوسَا إِنَّا: ’وقَّارْ بَابَاشْ ذ يمَّاشْ!‘، ؤُ: ’ونِّي إِ غَا إِخْزَانْ بَابَاسْ نِيغْ يمَّاسْ، إِتّْخصَّا أَسْ أَذْ إِمّثْ.‘ \x ◘ \xo 7:‏10 \xt ؤُف. 20‏:‏12؛ 21‏:‏17؛ لَاوِي 20‏:‏9؛ أَعَوذ. 5‏:‏16؛ 27‏:‏16؛ أَوڒن. 20‏:‏20؛ أَفا. 6‏:‏2. \x*
\v 11 مَاشَا كنِّيوْ ثقَّارمْ: ’مَاڒَا إِجّْ ن ورْيَازْ إِنَّا إِ بَابَاسْ نِيغْ إِ يمَّاسْ: مِينْ مَا ثْزمَّارمْ أَذْ زَّايِي ثسْثنْفْعمْ، أَقَا ڭِّيغْ ث ذ صّذْقثْ!‘،
\v 12 أَمُّو وَارْ ث ثتّجِّيمْ قَاعْ أَذْ إِڭّْ شَا إِ بَابَاسْ ذ يمَّاسْ.
\v 13 \add أَمُّو إِ\add* ثسّحْقَارَامْ أَوَاڒْ ن أَربِّي س ثُوبَّارْثْ نْومْ إِ ثتّْسلَّاممْ، ؤُ ثتّڭّمْ أَطَّاسْ ن ثْمسْڒَايِينْ أَمْ ثِينَا.“ \x ◘ \xo 7:‏13 \xt مت. 15‏:‏6؛ 1 تِيم. 4‏:‏3؛ 2 تِيم. 3‏:‏2. \x*
\b
\s1 ثَازْذُوڭِي ن وُوڒْ
\m 
\v 14 إِڒَاغَا-د يَاسُوع غَارسْ مَارَّا ڒْغَاشِي، إِنَّا أَسنْ: ”سْڒمْ-د غَارِي مَارَّا ؤُشَا فهْممْ \add مَانْ أَيَا مْلِيحْ\add*: \x ◘ \xo 7:‏14 \xt مت. 15‏:‏10. \x*
\v 15 وَارْ ذِينْ ؤُڒَا ذ إِشْثْ ن ڒْحَاجّثْ إِ د-إِتَّاذْفنْ غَارْ بْنَاذمْ زِي بَارَّا ثْزمَّارْ أَذْ ث ثسّخْمجْ. مَاشَا مِينْ إِ د-إِتّفّْغنْ زِي بْنَاذمْ، أَقَا مَانْ أَيَا إِسّخْمَاجْ بْنَاذمْ. \x ◘ \xo 7:‏15 \xt ڒخ. 10‏:‏15؛ رُوم. 14‏:‏17، 20؛ ثِيث. 1‏:‏15. \x*
\v 16 ونِّي غَارْ دْجَانْ إِمزُّوغنْ إِ ؤُسدْجِي، أجّْ إِ-ث أَذْ إِسڒْ.“
\m 
\v 17 ؤُمِي د-يُوذفْ غَارْ ثَادَّارْثْ، إِڭّْوجْ خْ ڒْغَاشِي، سّقْسَانْ ث إِمحْضَارنْ نّسْ خْ ؤُمذْيَا \add نِّي\add*. \x ◘ \xo 7:‏17 \xt مت. 15‏:‏15. \x*
\v 18 إِنَّا أَسنْ: ”مَا كنِّيوْ عَاذْ بْڒَا ڒفْهَامثْ؟ مَا وَارْ ثفْهِيممْ شَا بلِّي مَارَّا مِينْ غَا يَاذْفنْ بْنَاذمْ زِي بَارَّا، وَارْ إِزمَّارْ أَذْ ث إِسّخْمجْ،
\v 19 مِينْزِي مَانْ أَيَا وَارْ د-إِتِّيذفْ شَا غَارْ وُوڒْ نّسْ، مَاشَا غَارْ ؤُعذِّيسْ، خنِّي أَذْ إِفّغْ غَارْ ومْشَانْ نّسْ، أَڒْ إِتّْوَاسِّيزْذڭْ مَارَّا مَاشَّا.“
\v 20 \add خنِّي\add* إِنَّا: ”مِينْ إِ د-إِتّفّْغنْ زِي بْنَاذمْ ذ مَانْ أَيَا إِسّْخمَّاجْ بْنَاذمْ.
\v 21 مِينْزِي زِي ذَاخڒْ، زڭْ وُوڒَاونْ ن إِوْذَانْ إِ د-إِتّفّْغنْ إِنْوَاينْ إِعفَّاننْ: زِّينَا، فَارْقْ-شّْغڒْ، ثُوكَّارْضَا، أَنْغَايْ، \x ◘ \xo 7:‏21 \xt أَمز. 6‏:‏5؛ 8‏:‏21؛ أَوڒن. 6‏:‏14؛ إِرْم. 17‏:‏9. \x*
\v 22 طّْمعْ، ڒْغَارْ، ثَاحْرَايْمشْثْ، أَفُوشّحْ، ثِيطّْ ثَاعفَّانْثْ، أَشقّفْ، ثُوفّثْ ذ ثُوبُّوهڒْيَا.
\v 23 مَارَّا ثِيمسْڒَايِينْ-أَ ثِيعفَّانِينْ تّفّْغنْثْ-إِ-د زِي ذَاخڒْ ؤُشَا سّْخمَّاجنْثْ بْنَاذمْ.“
\b
\s1 لْ-إِمَانْ ن ثمْغَارْثْ ذِي ثمُّورْثْ ن صُورْ ذ صَايْذُونْ
\m 
\v 24 إِكَّارْ سّنِّي ؤُشَا إِرُوحْ غَارْ ثمُّورْثْ ن ويْمِيرْ ن صُورْ ذ صَايْذُونْ. ڒَامِي د-يُوذفْ غَارْ إِشْثْ ن ثَادَّارْثْ، وَارْ إِخْسْ أَذْ ث إِسّنْ حذْ، وَاخَّا أَمنِّي وَارْ إِزمَّارْ أَذْ إِنُّوفَّارْ. \x ◘ \xo 7:‏24 \xt [مت. 15‏:‏21‏-‏28] — مت. 15‏:‏21. \x*
\v 25 مِينْزِي إِشْثْ ن ثْمطُّوثْ، غَارسْ يدْجِيسْ ذَايسْ إِجّْ ن ڒَارْيَاحْ ذ أَمنْڭُوسْ، ثسْڒَا خَاسْ ذغْيَا. نتَّاثْ ثُوسَا-د غَارسْ، ثوْضَا أَسْ غَارْ إِضَارنْ نّسْ.
\v 26 ثُوغَا ثَامْغَارْثْ-أَ ذ إِشْثْ ن ثمْغَارْثْ ثَاكَافْرِيوْثْ زِي \add ثمُّورْثْ ن\add* فِينِيقِييَا نِّي ثُوغَا ذ ثَاسْغَارْثْ ن سُورِييَا. نتَّاثْ ثْزَاوْڭْ إِ-ث مَاحنْذْ أَذْ إِسُّوفّغْ شِّيطَانْ زڭْ يدْجِيسْ.
\v 27 \add مَاشَا\add* يَاسُوع إِنَّا أَسْ: ”أجّْ إِحنْجِيرنْ أَمزْوَارْ أَذْ جِّيوْننْ، مِينْزِي وَارْ إِتّْڒِيقْ أَذْ إِتّْوَاكّسْ وغْرُومْ ن إِحنْجِيرنْ حِيمَا أَذْ إِمّنْضَارْ إِ يِيطَانْ.“
\v 28 مَاشَا نتَّاثْ ثَارَّا-د، ثنَّا أَسْ: ”وَاهْ، \add أَ\add* سِيذِي، ؤُڒَا ذ إِطَانْ تّتّنْ إِڒقّْوَازْ ن إِحنْجِيرنْ سَاذُو طَّابْڒَا.“
\v 29 إِنَّا أَسْ يَاسُوع: ”ؤُيُورْ، مِينْزِي خْ سِّيبّثْ ن وَاوَاڒْ-أَ \add إِ ثنِّيذْ\add*، أَقَا إِفّغْ شِّيطَانْ زڭْ يدْجِيمْ.“
\v 30 ڒَامِي د-ثُوسَا غَارْ ثَادَّارْثْ نّسْ، ثُوفَا يدْجِيسْ ثزّڒْ ذِي قَامَا ؤُ شِّيطَانْ إِتّْوَاسُّوفّغْ زَّايسْ.
\b
\s1 أَسْڭنْفِي ن إِجّْ ن ؤُذهْشُورْ
\m 
\v 31 إِفّغْ-د يَاسُوع عَاوذْ زِي ثمُّورْثْ ن صُورْ ذ صَايْذُونْ، يِيوضْ غَارْ ڒبْحَارْ ن لْجَالِيلْ غَارْ طَّارْفْ ن ثمُّورْثْ ن ذِيكاپُولِيسْ. \x ◘ \xo 7:‏31 \xt مت. 15‏:‏29. \x*
\v 32 إِوْينْ-د غَارسْ إِجّْ ن ؤُذهْشُورْ، إِثوْثَاوْ، ؤُشَا تَّارنْ زَّايسْ أَذْ خَاسْ إِسَّارْسْ أَفُوسْ نّسْ. \x ◘ \xo 7:‏32 \xt مت. 9‏:‏32؛ لك. 11‏:‏14. \x*
\v 33 إِسِّيڭّْوجْ إِ-ث زِي ڒْغَاشِي غَارْ ؤُغزْذِيسْ ؤُشَا إِڭَّا أَسْ إِضوْضَانْ ذڭْ إِمزُّوغنْ نّسْ، إِسُّوسفْ ؤُشَا إِحَاذَا إِڒسْ نّسْ.
\v 34 \add خنِّي\add* إِخْزَارْ غَارْ ؤُجنَّا، إِزهَّارْ، إِنَّا أَسْ: ”نُورْزمْ!“
\v 35 ڒخْذنِّي نُّورْزْمنْ إِمزُّوغنْ نّسْ ؤُشَا ثفْسِي ثسْغُونْثْ ن يِيڒسْ نّسْ، \add إِبْذَا\add* إِسَّاوَاڒْ نِيشَانْ.
\v 36 إِعْڒمْ أَسنْ وَارْ \add ث\add* قَّارنْ إِ حذْ، مَاشَا مشْحَاڒْ مَا ثنْ يُومُورْ، وَاخَّا أَمنِّي ثُوغَا سُّوفُّوغنْ خَاسْ ڒخْبَارْ مَاهُو.
\v 37 ؤُشَا ثْبهْثنْ س ؤُنخْڒِيعْ أَڒَامِي نَّانْ: ”مَارَّا إِڭَّا إِ-ث مْلِيحْ! يَارَّا إِذهْشَارْ تّسْڒَانْ ذ إِڭْنَاونْ سَّاوَاڒنْ.“ \x ◘ \xo 7:‏37 \xt أَمز. 1‏:‏31. \x*
\b
\b
\c 8
\s1 لْمُوعْجِيزَا ن ؤُسشِّي إِ ثْوَاڒَا وِيسّْ ثْنَاينْ
\m 
\v 1 ذڭْ وُوسَّانْ نِّي، أَمْ ثُوغَا ذِينْ \add عَاوذْ\add* أَطَّاسْ ن ڒْغَاشِي ؤُشَا وَارْ ثُوغِي غَارْسنْ مِينْ غَا شّنْ، إِڒَاغَا يَاسُوع خْ إِمحْضَارنْ نّسْ، إِنَّا أَسنْ: \x ◘ \xo 8:‏1 \xt [مت. 15‏:‏32‏-‏39] — مت. 15‏:‏32. \x*
\v 2 ”أَقَا زِّيدْجْزنْ أَيِي ڒْغَاشِي، مِينْزِي قِّيمنْ أَكِيذِي \add عَاذْ\add* ثْڒَاثَا ن وُوسَّانْ، وَارْ غَارْسنْ مِينْ غَا شّنْ.
\v 3 مَاڒَا سّكّغْ ثنْ غَارْ ثُوذْرِينْ نْسنْ أَمْ \add عَاذْ\add* دْجُوژنْ، أَذْ تّْوَاهيّْفنْ ذڭْ وبْرِيذْ، مِينْزِي شَا زَّايْسنْ ؤُسِينْ-د زِي ڒَاڭّْوَاجْ.“
\v 4 نَّانْ أَسْ إِمحْضَارنْ نّسْ: ”زِي مَانِيسْ إِزمَّارْ حذْ أَذْ يَافْ أَغْرُومْ ذِي ڒخْڒَا-يَا مَاحنْذْ أَذْ إِسّْجِّيونْ مَارَّا إِنَا؟“
\v 5 إِسّقْسَا ثنْ: ”مشْحَاڒْ ن ثشْنِيفِينْ إِ غَارْومْ؟“ نَّانْ: ”سبْعَا.“ \x ◘ \xo 8:‏5 \xt مك. 6‏:‏38\x*
\v 6 \add خنِّي\add* يُومُورْ ڒْغَاشِي أَذْ إِقِّيمْ ذِي ثمُّورْثْ، ؤُشَا إِكْسِي سبْعَا نِّي ن ثشْنِيفِينْ، ؤُ أَوَارْنِي ڒَامِي إِبَاركْ، يَارْژَا إِ-ثنْثْ، إِوْشَا إِ-ثنْثْ إِ إِمحْضَارنْ نّسْ حِيمَا أَذْ ثنْثْ قدّْمنْ، ؤُشَا خنِّي قدّْمنْ ثنْثْ إِ ڒْغَاشِي.
\v 7 ثُوغَا غَارْسنْ شْوَايْثْ ن إِسڒْمَانْ ذ إِمژْيَاننْ. إِبَارْكْ إِ-ثنْ عَاوذْ، إِنَّا أَذْ قدّْمنْ إِنَا.
\v 8 شِّينْ، جِّيوْننْ، ؤُشَا يَارْونْ مِينْ إِشطّنْ، أَقَا سبْعَا ن ثْسُودْجَاثِينْ.
\v 9 إِنِّي إِشّنْ ثُوغَا أَثنْ عْڒَاحَاڒْ ذِي أَربْعَا-أَڒَافْ.
\v 10 \add خنِّي\add* إِسّكّْ إِ-ثنْ، ؤُشَا ڒخْذنِّي إِنْيَا ذِي ثْغَارَّابُوثْ أَكْ-ذ إِمحْضَارنْ نّسْ، يِيوضْ غَارْ جّْوَايهْ ن ذَالْمَانُوثَا. \x ◘ \xo 8:‏10 \xt مت. 15‏:‏39. \x*
\b
\s1 أَنْثُونْ ن إِفَارِيسِييّنْ
\m 
\v 11 فّْغنْ إِفَارِيسِييّنْ، بْذَانْ تّْقَاشَاحنْ ذَايسْ، تَّارنْ زَّايسْ إِشْثْ ن ڒعْڒَامثْ زڭْ ؤُجنَّا حِيمَا أَذْ ث جَارّْبنْ. \x ◘ \xo 8:‏11 \xt [مت. 16‏:‏1‏-‏12] — مت. 12‏:‏38؛ 16‏:‏1؛ لك. 11‏:‏29؛ يُوح. 6‏:‏30. \x*
\v 12 إِزهَّارْ ذِي أَرُّوحْ نّسْ، إِنَّا: ”مَايمِّي إِتّتَّارْ جِّيڒْ-أَ إِشْثْ ن ڒعْڒَامثْ؟ س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ،عمَّارْصْ وَارْ ذ أَسْ ثمّوْشْ إِ جِّيڒْ-أَ إِشْثْ ن ڒعْڒَامثْ!“ \x ◘ \xo 8:‏12 \xt مت. 16‏:‏4. \x*
\v 13 \add خنِّي\add* إِسْمحْ ذَايْسنْ ؤُشَا إِنْيَا ذِي ثْغَارَّابُوثْ، ؤُشَا رُوحنْ نِيثْنِي غَارْ ؤُجمَّاضْ.
\b
\m 
\v 14 إِمحْضَارنْ نّسْ تُّونْ أَذْ كِيسنْ كْسِينْ أَغْرُومْ، ؤُشَا وَارْ ثُوغِي غَارْسنْ وَالُو ذِي ثْغَارَّابُوثْ مْغِيرْ إِشْثْ ن ثشْنِيفْثْ ن وغْرُومْ وَاهَا. \x ◘ \xo 8:‏14 \xt [مت. 16‏:‏5‏-‏12] \x*
\v 15 ؤُشَا يُومُورْ إِ-ثنْ، إِنَّا: ”خْزَارمْ، حْضَامْ زڭْ ونْثُونْ ن إِفَارِيسِييّنْ ذ ونْثُونْ ن هِيرُوذُوسْ.“ \x ◘ \xo 8:‏15 \xt مت. 16‏:‏6، 12؛ لك. 12‏:‏1. \x*
\v 16 مْشَاوَارنْ جَارْ أَسنْ، نَّانْ: ”ذ مَانْ أَيَا مِينْزِي وَارْ \add غَارْنغْ\add* بُو \add ثشْنِيفِينْ ن\add* وغْرُومْ.“
\v 17 \add مَاشَا\add* يَارْڭبْ يَاسُوع، إِنَّا أَسنْ: ”مَايمِّي ثمْشَاوَارمْ بلِّي وَارْ غَارْومْ بُو \add ثشْنِيفِينْ ن\add* وغْرُومْ؟ مَا وَارْ ثُوشِيمْ، مَا وَارْ ثفْهِيممْ؟ مَا عَاذْ ؤُڒَاونْ نْومْ قسْحنْ؟ \x ◘ \xo 8:‏17 \xt مك. 6‏:‏52. \x*
\v 18 مَا غَارْومْ ثِيطَّاوِينْ، مَاشَا وَارْ ثتّْوِيڒِيمْ؟ مَا غَارْومْ إِمزُّوغنْ، مَاشَا وَارْ ثتّسْڒِيمْ؟ مَا وَارْ ثْعقِّيڒمْ عَاذْ؟
\v 19 ؤُمِي أَرْژِيغْ خمْسَا ن ثشْنِيفِينْ ن وغْرُومْ إِ خمْسَا-أَڒَافْ، مشْحَاڒْ ن ثْسُودْجَاثِينْ إِ إِشُّورنْ س إِڒقّْوَازْ إِ ثْيَارْومْ؟“ نَّانْ أَسْ: ”ثنْعَاشْ.“ \x ◘ \xo 8:‏19 \xt مت. 14‏:‏17، 20؛ مك. 6‏:‏38؛ لك. 9‏:‏13؛ يُوح. 6‏:‏9. \x*
\v 20 ”ؤُ غَارْ سبْعَا \add ن ثشْنِيفِينْ ن وغْرُومْ\add* إِ أَربْعَا-أَڒَافْ، مشْحَاڒْ ن ثْسُودْجَاثِينْ إِشُّورنْ س إِڒقّْوَازْ إِ ثْيَارْومْ؟“ نَّانْ: ”سبْعَا!“ \x ◘ \xo 8:‏20 \xt مت. 15‏:‏36، 37. \x*
\v 21 \add خنِّي\add* إِنَّا أَسنْ: ”مَامّشْ عَاذْ وَارْ ثفْهِيممْ أَڒْ ڒخُّو؟“
\b
\s1 أَسْڭنْفِي ن إِجّْ ن ؤُذَارْغَاڒْ ذِي بَايْثْصَايْضَا
\m 
\v 22 يُوسَا-د غَارْ بَايْثْ-صَايْذَا ؤُشَا نِيثْنِي إِوْينْ أَسْ-د إِجّْ ن ؤُذَارْغَاڒْ، زَاوْڭنْ ث أَذْ إِحَاذَا وَانِيثَا.
\v 23 نتَّا إِمْنعْ أَذَارْغَاڒْ زڭْ ؤُفُوسْ، إِنْذهْ إِ-ث بَارَّا إِ ذْشَارْ ؤُشَا إِسُّوسفْ ذِي ثِيطَّاوِينْ نّسْ، إِسَّارْسْ \add خَاسْ\add* أَفُوسْ نّسْ، إِسّقْسَا مِينْ إِتّْوَاڒَا. \x ◘ \xo 8:‏23 \xt مك. 7‏:‏32. \x*
\v 24 إِسوْضْ، إِنَّا: ”تّْوَاڒِيغْ إِوْذَانْ ڭُّورنْ أَمْ ثِيشجُّورَا.“
\v 25 خنِّي إِسَّارْسْ عَاوذْ أَفُوسْ نّسْ خْ ثِيطَّاوِينْ نّسْ. \add خنِّي\add* إِڭّنْفَا، إِذْوڒْ إِتّْوَاڒَا مَارَّا مْلِيحْ.
\v 26 إِسّكّْ إِ-ث غَارْ ثَادَّارْثْ نّسْ، إِنَّا: ”وَارْ ذ تِّيذفْ ذْشَارْ، وَارْ ث قَّارْ إِ حذْ ذِي ذْشَارْ!“
\b
\s1 شّْهَاذثْ ن بُوطْرُوسْ خْ يَاسُوع
\m 
\v 27 \add خنِّي\add* يُويُورْ يَاسُوع أَكْ-ذ إِمحْضَارنْ نّسْ غَارْ ڒذْشُورْ ن قَايْصَارِييَا-فِيلِيبُّوسْ. ذڭْ وبْرِيذْ إِسّقْسَا إِمحْضَارنْ نّسْ، إِنَّا أَسنْ: ”مِينْ قَّارنْ إِوْذَانْ مِينْ عْنِيغْ نشّْ؟“ \x ◘ \xo 8:‏27 \xt [مت. 16‏:‏13‏-‏20؛ لك. 9‏:‏18‏-‏21] — مت. 16‏:‏13؛ لك. 9‏:‏18. \x*
\v 28 أَرِّينْ-د: ”يُوحَانَّا أَمْسغْضَاصْ!“، شَا نّغْنِي \add نَّانْ\add*: ”إِلِييَا!“، إِنّغْنِي \add عَاوذْ\add*: ”إِجّنْ زڭْ إِنَابِييّنْ!“ \x ◘ \xo 8:‏28 \xt مت. 14‏:‏2؛ 16‏:‏14؛ مك. 6‏:‏15؛ لك. 9‏:‏8، 19 \x*
\v 29 إِنَّا أَسنْ: ”إِ كنِّيوْ مِينْ ثقَّارمْ خَافِي؟“ يَارَّا-د شِيمْعُونْ، إِنَّا أَسْ: ”شكْ ذ لْمَاسِيحْ، مِّيسْ ن أَربِّي إِدَّارنْ!“ \x ◘ \xo 8:‏29 \xt مت. 16‏:‏16؛ يُوح. 6‏:‏69. \x*
\v 30 يُومُورْ إِ-ثنْ مْلِيحْ، مَاحنْذْ وَارْ \add ت\add* خَاسْ قَّارنْ ؤُڒَا إِ يِيجّْ.
\b
\s1 يَاسُوع إِسَّاوَاڒْ خْ ڒْموْثْ ذ ثْنُوكْرَا نّسْ إِ ثْوَاڒَا ثَامزْوَارُوثْ
\m 
\v 31 إِبْذَا إِسّڒْمَاذْ أَقَا مِّيسْ ن بْنَاذمْ إِتّْخصَّا أَذْ إِودّبْ أَطَّاسْ ؤُشَا أَذْ إِتّْوَاسّحْقَارْ زڭْ إِمْغَارنْ \add ن ڒْڭنْسْ\add* ذ إِمقّْرَاننْ ن إِكهَّاننْ ذ إِمْسڒْمَاذنْ ن إِذْلِيسنْ، أَذْ ث نْغنْ ؤُشَا ذڭْ وَاسّْ وِيسّْ ثْڒَاثَا أَذْ د-إِكَّارْ. \x ◘ \xo 8:‏31 \xt [مت. 16‏:‏21‏-‏28؛ لك. 9‏:‏22‏-‏27] — مت. 16‏:‏21؛ 17‏:‏22؛ 20‏:‏18؛ مك. 9‏:‏31؛ 10‏:‏33؛ لك. 9‏:‏22؛ 18‏:‏31؛ 24‏:‏7. \x*
\v 32 إِنَّا أَوَاڒْ-أَ س بْطَايْطَايْ. \add مَاشَا\add* إِكْسِي ث بُوطْرُوسْ غَارسْ غَارْ ؤُغزْذِيسْ ؤُشَا إِبْذَا إِتّْوبّخْ إِ-ث.
\v 33 \add خَاسْ ؤُشَا\add* إِنّقْڒبْ، إِخْزَارْ ذڭْ إِمحْضَارنْ نّسْ ؤُشَا إِوبّخْ إِ شِيمْعُونْ، إِقَّارْ: ”أَڭّْوجْ خَافِي أَوَارْنِي أَيِي، \add أَ\add* شِّيطَانْ مِينْزِي شكْ وَارْ ذ أَشْ إِشْقِي مِينْ إِدْجَانْ ن أَربِّي، مَاشَا مِينْ إِدْجَانْ ن إِوْذَانْ.“ \x ◘ \xo 8:‏33 \xt 2 صم. 19‏:‏22. \x*
\m 
\v 34 إِڒَاغَا-د يَاسُوع إِ ڒْغَاشِي أَكْ-ذ إِمحْضَارنْ نّسْ غَارسْ، إِنَّا أَسنْ: ”ونِّي إِخْسنْ أَذْ أَيِي إِضْفَارْ، أَذْ إِنْكَارْ إِخفْ نّسْ، أَذْ إِكْسِي صَّالِيبْ نّسْ ؤُشَا أَذْ أَيِي إِضْفَارْ. \x ◘ \xo 8:‏34 \xt مت. 10‏:‏38؛ 16‏:‏24؛ لك. 9‏:‏23؛ 14‏:‏27. \x*
\v 35 مِينْزِي ونِّي إِخْسنْ أَذْ إِسّنْجمْ ثُوذَارْثْ نّسْ، أَذْ ت إِخْسَارْ، \add مَاشَا\add* ونِّي إِ غَا إِخْسَارنْ ثُوذَارْثْ نّسْ ذِي طّْوعْ إِنُو ؤُ ذِي طّْوعْ ن ڒخْبَارْ أَصبْحَانْ، أَذْ ت إِسّنْجمْ. \x ◘ \xo 8:‏35 \xt مت. 10‏:‏39؛ 16‏:‏25؛ لك. 9‏:‏24؛ 17‏:‏33؛ يُوح. 12‏:‏25. \x*
\v 36 مِينْزِي مَانْ ڒفْضڒْ ن بْنَاذمْ مَاڒَا يَارْبحْ دُّونشْثْ مَارَّا، \add مَاشَا\add* أَذْ إِخْسَارْ ڒعْمَارْ نّسْ؟
\v 37 مِينْزِي مِينْ غَا إِوْشْ بْنَاذمْ ذڭْ ومْشَانْ ن ڒعْمَارْ نّسْ؟ \x ◘ \xo 8:‏37 \xt إِزهد. 49‏:‏9. \x*
\v 38 مِينْزِي ونِّي زَّايِي إِ غَا إِسضْحَانْ ؤُ زڭْ وَاوَاڒنْ إِنُو ذِي جِّيڒْ-أَ إِزنَّانْ إِخْضَانْ، أَقَا ؤُڒَا ذ مِّيسْ ن بْنَاذمْ أَذْ زَّايسْ إِسضْحَا، خْمِي د غَا يَاسْ س ؤُعُودْجِي ن بَابَاسْ أَكْ-ذ لْمَالَاكَاثْ إِقدّْسنْ.“ \x ◘ \xo 8:‏38 \xt لك. 9‏:‏26؛ 12‏:‏8؛ 1 Tes. 2‏:‏19؛ 2 تِيم. 2‏:‏12؛ 1 يُوح. 2‏:‏23. \x*
\b
\b
\c 9
\s1 أَسْعُودْجِي خْ وذْرَارْ أَكْ-ذ مُوسَا ذ إِلِييَا
\m 
\v 1 إِنَّا أَسنْ: ”س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ، أَقَا شَا زڭْ إِنِّي ذَا إِبدّنْ وَارْ تّْقَاسِينْ شَا ڒْموْثْ أَڒْ غَا ژَترنْ ثَاڭلْذِيثْ ن أَربِّي أَذْ د-ثَاسْ س جّهْذْ.“ \x ◘ \xo 9:‏1 \xt [مت. 17‏:‏1‏-‏13؛ لك. 9‏:‏28‏-‏36] — مت. 16‏:‏28؛ لك. 9‏:‏27. \x*
\v 2 أَوَارْنِي ستَّا ن وُوسَّانْ يَاسُوع يِيوِي-د \add أَكِيذسْ\add* بُوطْرُوسْ ذ يَاعْقُوبْ ذ يُوحَانَّا وحّذْسنْ غَارْ إِجّْ ن وذْرَارْ يُوعْڒَانْ، ؤُشَا إِبدّڒْ قِيبَاتْشْ إِ ثِيطَّاوِينْ نْسنْ. \x ◘ \xo 9:‏2 \xt مت. 17‏:‏1؛ لك. 9‏:‏28. \x*
\v 3 أَرُّوضْ نّسْ إِذْوڒْ يَاڒقّْ ذ أَشمْڒَاڒْ أَطَّاسْ أَمْ وذْفڒْ، وَارْ إِزمَّارْ ؤُڒَا ذ إِجّْ ن بْنَاذمْ خْ ثمُّورْثْ أَذْ إِسّمْڒڒْ أَمنِّي.
\v 4 إِضْهَارْ أَسنْ-د إِلِييَا أَكْ-ذ مُوسَا أَمْ ثُوغَا سَّاوَاڒنْ أَكْ-ذ يَاسُوع. \x ◘ \xo 9:‏4 \xt ؤُف. 24‏:‏1، 9، 10، 16\x*
\v 5 إِنَّا أَسْ بُوطْرُوسْ: ”\add أَ\add* أَمْسڒْمَاذْ إِنُو، أَقَا مْلِيحْ ؤُمِي ذَا ندْجْ، أجّْ أَنغْ أَذْ نوّثْ ثْڒَاثَا ن إِعُوشُّوثنْ ن ثْسطَّا، إِجّنْ إِ شكْ، إِجّنْ إِ مُوسَا ؤُ إِجّنْ إِ إِلِييَا.“ \x ◘ \xo 9:‏5 \xt مت. 17‏:‏4؛ مك. 9‏:‏5؛ لك. 9‏:‏33\x*
\v 6 مَاشَا ثُوغَا إِودَّارْ أَسْ مِينْ غَا يِينِي، مِينْزِي نِيثْنِي ڭّْوذنْ أَطَّاسْ.
\v 7 إِكَّا-د ؤُسيْنُو إِسّْذُورِييْ إِ-ثنْ س ثِيڒِي نّسْ، ؤُشَا ثْڒَاغَا-د إِشْثْ ن ثْمِيجَّا زڭْ ؤُسيْنُو، ثقَّارْ: ”وَا ذ مِّي إِعِيزّنْ، سْڒمْ غَارسْ!“ \x ◘ \xo 9:‏7 \xt أَعَوذ. 18‏:‏15؛ إِشا. 42‏:‏1؛ مت. 3‏:‏17؛ 17‏:‏5؛ مك. 1‏:‏11؛ لك. 3‏:‏22؛ 9‏:‏35؛ كُول. 1‏:‏13؛ 2 بُط. 1‏:‏17. \x*
\v 8 ؤُمِي سّْڭعّْذنْ نِيثْنِي ثِيطَّاوِينْ نْسنْ، ذڭْ إِشْثْ ن ثشْثِي وَارْ قِّيمنْ تّْوَاڒَانْ عَاذْ حذْ أَكِيذْسنْ، مْغِيرْ يَاسُوع وحّْذسْ.
\m 
\v 9 أَڒَامِي د-هْوَانْ زڭْ وذْرَارْ، يُومُورْ إِ-ثنْ حِيمَا وَارْ تّْعِيوِيذنْ إِ حذْ وَالُو زِي مِينْ ژْرِينْ أَڒْ د غَا إِكَّارْ مِّيسْ ن بْنَاذمْ جَارْ إِمتِّيننْ. \x ◘ \xo 9:‏9 \xt مت. 17‏:‏9؛ لك. 9‏:‏36. \x*
\v 10 خمّْڒنْ أَوَاڒْ-أَ ذڭْ يِيخفْ نْسنْ أَمْ ثُوغَا تّْسقْسَانْ إِخفْ نْسنْ مِينْ إِخْسْ أَذْ يِينِي \add وَاوَاڒْ-أَ\add*: ’أَڒْ د غَا إِكَّارْ زِي ثَادَّارْثْ ن إِمتِّيننْ‘؟
\v 11 سّقْسَانْ ث، نَّانْ أَسْ: ”مَايمِّي قَّارنْ إِمْسڒْمَاذنْ ن إِذْلِيسنْ بلِّي إِتّْخصَّا أَذْ د-يَاسْ إِلِييَا ذ أَمزْوَارُو؟“ \x ◘ \xo 9:‏11 \xt مـَال. 3‏:‏23؛ مت. 11‏:‏14؛ لك. 1‏:‏17. \x*
\v 12 يَارَّا-د، إِنَّا أَسنْ: ”أَقَا إِلِييَا أَذْ د-يَاسْ ذ أَمزْوَارُو ؤُشَا أَذْ يَارّْ كُوڒْشِي، ؤُشَا \add أَذْ ثِيڒِي\add* أَمْ مَامّشْ ثُورَا خْ مِّيسْ ن بْنَاذمْ، أَقَا أَذْ إِودّبْ أَطَّاسْ ؤُشَا أَذْ ث سّحْقَارنْ. \x ◘ \xo 9:‏12 \xt إِزهد. 22‏:‏7؛ إِشا. 53‏:‏4؛ دَان. 9‏:‏26، أَسَا. 11‏:‏4‏-‏7\x*
\v 13 مَاشَا نشّْ أَذْ أَومْ إِنِيغْ، إِلِييَا أَقَا يُوسَا-د ؤُشَا ڭِّينْ زَّايسْ مِينْ خْسنْ أَمْ مَامّشْ خَاسْ ثُورَا.“ \x ◘ \xo 9:‏13 \xt مـَال. 3‏:‏23، 24. \x*
\b
\s1 أَبْڒِيغْ ذَايسْ ڒَارْيَاحْ أَمنْڭُوسْ
\m 
\v 14 ڒَامِي د-يُوسَا غَارْ إِمحْضَارنْ، إِژْرَا إِجّْ ن ڒْغَاشِي ذ أَمقّْرَانْ إِتّنّضْ أَسنْ-د ؤُ إِمْسڒْمَاذنْ ن إِذْلِيسنْ تّْقَاشَاحنْ ثنْ. \x ◘ \xo 9:‏14 \xt [مت. 17‏:‏14‏-‏20؛ لك. 9‏:‏37‏-‏43] \x*
\v 15 ذغْيَا إِژْرَا إِ-ث مَارَّا ڒْغَاشِي، ثْبهْثنْ أَطَّاسْ، ؤُشَا ؤُزّْڒنْ-د \add غَارسْ\add*، سدْجْمنْ خَاسْ.
\v 16 خنِّي إِسّقْسَا إِمْسڒْمَاذنْ ن إِذْلِيسنْ: ”مِينْ خفْ كِيذْسنْ ثتّْقَاشَاحمْ؟“
\v 17 يَارَّا-د إِجّنْ زِي ڒْغَاشِي، إِنَّا: ”\add أَ\add* أَمْسغَّارْ، إِوْيغْ-د مِّي غَاركْ. أَقَا ذَايسْ ڒَارْيَاحْ نِّي ث يَارِّينْ ذ أَڭْنَاوْ. \x ◘ \xo 9:‏17 \xt مت. 17‏:‏14؛ لك. 9‏:‏37، 38. \x*
\v 18 ڒبْذَا خْمِي ث إِتّطّفْ، إِنطَّارْ إِ-ث غَارْ ثمُّورْثْ، إِتّفّغْ أَسْ-د ؤُكُوفُّو زڭْ ؤُقمُّومْ، إِتّْغزَّا ثِيغْمَاسْ نّسْ ؤُشَا إِتَّاژغْ. نِّيغْ إِ إِمحْضَارنْ نّشْ أَذْ ث سُّوفّْغنْ، \add مَاشَا\add* وَارْ ذ أَسْ زمَّارنْ.“
\v 19 يَاسُوع يَارَّا-د، إِنَّا أَسنْ: ”\add أَ\add* جِّيڒْ وَارْ يُومِيننْ، مشْحَاڒْ كِيذْومْ إِ غَا قِّيمغْ، مشْحَاڒْ إِ كنِّيوْ إِ غَا يَارْبُوغْ عَاذْ؟ أَوْيمْ ث-إِ-د غَارِي!“
\m 
\v 20 ؤُشَا إِوْينْ ث-إِ-د غَارسْ. ؤُمِي ث إِژْرَا، ڒخْذنِّي إِمّنْضَارْ إِ-ث ڒَارْيَاحْ، أَڒَامِي إِوْضَا غَارْ ثمُّورْثْ، إِبْذَا إِتّْبَارْكِيكِّيضْ، إِتّكّْ أَسْ-د ؤُكُوفُّو \add زڭْ ؤُقمُّومْ\add*. \x ◘ \xo 9:‏20 \xt مك. 1‏:‏26. \x*
\v 21 يَاسُوع إِسّقْسَا بَابَاسْ: ”مشْحَاڒْ زڭْ وَامِي ث-إِ-د-إِحْكمْ ؤُيَا؟“ إِنَّا أَسْ: ”زِي ثمْژِي نّسْ.
\v 22 أَطَّاسْ ن إِمُورنْ إِنطَّارْ إِ-ث ذِي ثْمسِّي ؤُ ذڭْ وَامَانْ حِيمَا أَذْ ث إِسّْهلّكْ. مَاشَا مَاڒَا ثْزمَّارذْ خْ شَا، عَاونْ أَيِي ؤُ حِينّْ خَافِي!“
\v 23 إِنَّا أَسْ يَاسُوع: ”مَاڒَا ثْزمَّارذْ أَذْ ثَامْنذْ، أَقَا كُوڒْشِي إِزمَّارْ إِ ونِّي يُومْننْ.“ \x ◘ \xo 9:‏23 \xt لك. 17‏:‏6. \x*
\v 24 ڒخْذنِّي إِسْغُويْ بَابَاسْ ن ؤُحنْجِيرْ س إِمطَّاونْ، إِنَّا: ”ؤُمْنغْ، \add أَ\add* سِيذِي! عَاونْ لْ-إِيمَانْ إِنقْصنْ إِنُو.“
\v 25 ؤُمِي إِژْرَا يَاسُوع ڒْغَاشِي إِتَّازّڒْ ؤُشَا سّْمُوننْ-د غَارسْ نِيثْنِي، إِوبّخْ ڒَارْيَاحْ أَمنْڭُوسْ، إِنَّا أَسْ: ”\add أَ\add* ڒَارْيَاحْ أَڭْنَاوْ، نشّْ ؤُمُورغْ شكْ: فّغْ زَّايسْ! وَارْ تّْذكّْوِيڒْ ذَايسْعمَّارْصْ!“
\v 26 إِسْغُويْ شِّيطَانْ نِّي أَطَّاسْ، إِجبّذْ إِ-ث أَطَّاسْ أَمُّو ذ وَامُّو ؤُشَا إِفّغْ \add زَّايسْ\add*. \add خنِّي\add* إِذْوڒْ ؤُحنْجِيرْ أَمْ يِيجّْ ن ؤُمتِّينْ، أَڒَامِي ثُوغَا نَّانْ أَطَّاسْ، أَقَا إِمُّوثْ.
\v 27 مَاشَا يَاسُوع إِطّفْ إِ-ث زڭْ ؤُفُوسْ نّسْ، إِسّْبدّْ إِ-ث.
\m 
\v 28 ؤُمِي د-يُوذفْ غَارْ ثَادَّارْثْ، سّقْسَانْ ث إِمحْضَارنْ نّسْ وحّذْسنْ: ”مَايمِّي وَارْ نْزمَّارْ نشِّينْ أَذْ ث نسُّوفّغْ؟“ \x ◘ \xo 9:‏28 \xt مت. 17‏:‏19. \x*
\v 29 إِنَّا أَسنْ: ”دّڭّْ-أَ وَارْ إِزمَّارْ أَذْ إِتّْوَاسُّوفّغْ ؤُڒَا س إِشْثْ ن ڒْحَاجّثْ مْغِيرْ س ؤُژُومِّي ذ ثْژَادْجِيثْ وَاهَا.“
\b
\s1 يَاسُوع إِسَّاوَاڒْ خْ ڒْموْثْ ذ ثْنُوكْرَا نّسْ إِ ثْوَاڒَا وِيسّْ ثْنَاينْ
\m 
\v 30 فّْغنْ-د سّنِّي ؤُشَا شُوقنْ ذِي لْجَالِيلْ. نتَّا ثُوغَا وَارْ إِخْسْ أَذْ ث إِعْقڒْ ؤُڒَا ذ إِجّنْ. \x ◘ \xo 9:‏30 \xt [مت. 17‏:‏22‏-‏23؛ لك. 9‏:‏43‏-‏45] — مت. 16‏:‏21؛ 17‏:‏22؛ 20‏:‏18؛ مك. 8‏:‏31؛ 10‏:‏33؛ لك. 9‏:‏22؛ 18‏:‏31؛ 24‏:‏7. \x*
\v 31 مَاغَارْ ثُوغَا إِسّڒْمَاذْ إِمحْضَارنْ نّسْ، إِقَّارْ أَسنْ: ”أَقَا مِّيسْ ن بْنَاذمْ أَذْ إِمّوْشْ ذڭْ إِفَاسّنْ ن إِوْذَانْ، أَذْ ث نْغنْ ؤُشَا أَوَارْنِي ڒَامِي ث غَا نْغنْ، أَذْ د-إِكَّارْ ذڭْ وَاسّْ وِيسّْ ثْڒَاثَا.“
\v 32 مَاشَا نِيثْنِي وَارْ فْهِيمنْ إِ وَاوَاڒْ-أَ ؤُشَا ڭّْوذنْ أَذْ ث سّقْسَانْ \add خْ ؤُيَا\add*.
\b
\s1 مَانْ ونْ إِدْجَانْ ذ أَمقّْرَانْ؟
\m 
\v 33 ؤُسِينْ-د غَارْ كَافَارْنَاحُومْ ؤُ أَوَارْنِي ڒَامِي ؤُذْفنْ غَارْ ثَادَّارْثْ، إِسّقْسَا ثنْ: ”ذِي مِينْ ذِي ثُوغَا ثْحَارّْضمْ أَكْ-ذ وَايَاوْيَا ذڭْ وبْرِيذْ؟“ \x ◘ \xo 9:‏33 \xt [مت. 18‏:‏1‏-‏5؛ لك. 9‏:‏46‏-‏48] — مت. 18‏:‏1؛ لك. 9‏:‏46؛ 22‏:‏24. \x*
\v 34 مَاشَا سْقَارنْ، مِينْزِي ثُوغَا تّمْقَاشَاحنْ ذڭْ وبْرِيذْ ذِي وِينْ إِدْجَانْ ذ أَمقّْرَانْ زَّايْسنْ.
\v 35 إِقِّيمْ، إِڒَاغَا-د إِ ثنْعَاشْ، إِنَّا أَسنْ: ”مَاڒَا إِخْسْ حذْ أَذْ يِيڒِي ذ أَمزْوَارْ، أَذْ يِيڒِي ذ أَنڭَّارْ ؤُڒَا ذ أَمْسخَّارْ إِ مَارَّا.“ \x ◘ \xo 9:‏35 \xt مت. 20‏:‏27؛ مك. 10‏:‏43. \x*
\v 36 إِكْسِي أَحنْجِيرْ، إِسّْبدّْ إِ-ث ذِي ڒْوسْطْ نْسنْ، إِذَارّعْ أَسْ، ؤُشَا إِنَّا أَسنْ: \x ◘ \xo 9:‏36 \xt مك. 10‏:‏16. \x*
\v 37 ”وِي غَا إِقبْڒنْ \add مْغِيرْ\add* إِجّْ \add ن ؤُحنْجِيرْ\add* أَمْ ؤُحنْجِيرْ-أَ س يِيسمْ إِنُو، أَقَا إِقْبڒْ أَيِي ؤُ وِي ذ أَيِي غَا إِقبْڒنْ، وَارْ ذ أَيِي إِقبّڒْ، مَاشَا إِقبّڒْ وِي ذ أَيِي-د-إِسّكّنْ.“ \x ◘ \xo 9:‏37 \xt مت. 18‏:‏5؛ لك. 9‏:‏48؛ يُوح. 13‏:‏20. \x*
\b
\s1 وِي وَارْ إِدْجِينْ ضِيدّْ نّغْ، أَقَا-ث أَكِيذْنغْ
\m 
\v 38 يَارَّا-د خَاسْ يُوحَانَّا، إِنَّا أَسْ: ”\add أَ\add* أَمْسڒْمَاذْ إِنُو، نژْرَا إِجّنْ إِسُّوفُّوغْ شّْوَاطنْ س يِيسمْ نّشْ ؤُ نمْنعْ إِ-ث مِينْزِي نتَّا وَارْ د أَنغْ إِضفَّارْ.“ \x ◘ \xo 9:‏38 \xt [لك. 9‏:‏49‏-‏50] — لك. 9‏:‏49. \x*
\v 39 إِنَّا أَسنْ يَاسُوع: ”وَارْ \add ث\add* منّْعمْ شَا، مِينْزِي وَارْ ذِينْ ؤُڒَا ذ إِجّْ إِ غَا يڭّنْ ثِيمڭَّا إِجهْذنْ س يِيسمْ إِنُو، ؤُشَا ڒخْذنِّي ذغْيَا أَذْ خَافِي إِسِّيوڒْ س ڒْغَارْ. \x ◘ \xo 9:‏39 \xt 1 كُور. 12‏:‏3. \x*
\v 40 مِينْزِي وِي وَارْ إِدْجِينْ ضِيدّْ نْومْ، أَقَا-ث أَكِيذْومْ. \x ◘ \xo 9:‏40 \xt مت. 12‏:‏30؛ مك. 9‏:‏39؛ لك. 9‏:‏50؛ 11‏:‏23. \x*
\v 41 وِي كنِّيوْ إِ غَا إِسّسْونْ س يِيجّْ ن ڒْكَاسْ ن وَامَانْ وَاهَا، مِينْزِي أَقَا كنِّيوْ ن لْمَاسِيحْ \add إِ ثدْجَامْ\add*، أَقَا س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ، نتَّا وَارْ إِخسَّارْ شَا ڒْمُونثْ نّسْ. \x ◘ \xo 9:‏41 \xt مت. 10‏:‏42. \x*
\b
\s1 يَاسُوع إِعْڒمْ إِوْذَانْ خْ مِينْ إِغكّْوَانْ إِ دّْنُوبْ
\m 
\v 42 وِي غَا إِسّنْقْرَاضنْ إِجّنْ زڭْ إِمژْيَاننْ-أَ إِ ذَايِي يُومْننْ، إِحْڒَا أَسْ أَذْ أَسْ ثتّْوَاڭّْ إِشْثْ ن ثصْضَارْثْ ن ثْسِيرْثْ ثذْقڒْ ذڭْ إِرِي نّسْ، أَذْ إِمّنْضَارْ ذِي ڒبْحَارْ. \x ◘ \xo 9:‏42 \xt [مت. 18‏:‏6‏-‏9؛ لك. 17‏:‏1‏-‏2] — مت. 18‏:‏6؛ لك. 17‏:‏2. \x*
\v 43 مَاڒَا إِسّنْقَارْضْ شكْ ؤُفُوسْ نّشْ، قسّْ إِ-ث. إِحْڒَا أَشْ أَذْ ثَاذْفذْ غَارْ ثُوذَارْثْ ذ أَمعْضُوڒْ خْ وَاذَافْ س ثْنَاينْ ن إِفَاسّنْ ذِي جهنَّامَا، \x ◘ \xo 9:‏43 \xt أَعَوذ. 13‏:‏7؛ مت. 5‏:‏30؛ 18‏:‏8. \x*
\v 44 مَانِي ثِيكشَّا نْسنْ وَارْ ثتّْمتِّي ؤُ ثِيمسِّي نْسنْ وَارْ ثْخسِّي. \x ◘ \xo 9:‏44 \xt إِشا. 66‏:‏24. \x*
\v 45 مَاڒَا إِسّنْقَارْضْ شكْ ؤُضَارْ نّشْ، قسّْ إِ-ث. إِحْڒَا أَشْ أَذْ ثَاذْفذْ غَارْ ثُوذَارْثْ ذ أَقجْذَاحْ خْ ؤُوطُّو س ثْنَاينْ ن إِضَارنْ ذِي جهنَّامَا،
\v 46 مَانِي ثِيكشَّا نْسنْ وَارْ ثتّْمتِّي ؤُ ثِيمسِّي نْسنْ وَارْ ثْخسِّي. \x ◘ \xo 9:‏46 \xt إِشا. 66‏:‏24\x*
\v 47 مَاڒَا ثسّنْقَارْضْ شكْ ثِيطّْ نّشْ، قڒْعْ إِ-ت. إِحْڒَا أَشْ أَذْ ثَاذْفذْ غَارْ ثْڭلْذِيثْ ن أَربِّي س إِشْثْ ن ثِيطّْ خْ ؤُوطُّو س ثْنَاينْ ن ثِيطَّاوِينْ ذِي ثْمسِّي ن جهنَّامَا،
\v 48 مَانِي ثِيكشَّا نْسنْثْ وَارْ ثتّْمتِّي ؤُ ثِيمسِّي نْسنْثْ وَارْ ثْخسِّي. \x ◘ \xo 9:‏48 \xt إِشا. 66‏:‏24\x*
\v 49 مِينْزِي كُوڒْ إِجّنْ أَذْ إِتّْوَامدْجحْ س ثْمسِّي ؤُ كُوڒْ ثَاغَارْصْثْ أَذْ ثتّْوَامدْجحْ س ثْمدْجَاحْثْ. \x ◘ \xo 9:‏49 \xt لَاوِي 2‏:‏13. \x*
\v 50 ثَامدْجَاحْثْ ثصْبحْ، مَاشَا مَاڒَا ثَامدْجَاحْثْ إِخْسَارْ ؤُڒذِّي نّسْ، س مِينْ زِي ت إِ غَاعذْڒنْ. أَذْ ثِيڒِي ثْمدْجَاحْثْ ذَايْومْ ؤُشَا حْضَامْ ڒهْنَا جَارْ أَومْ.“ \x ◘ \xo 9:‏50 \xt مت. 5‏:‏13؛ لك. 14‏:‏34؛ رُوم. 12‏:‏18؛ عبر. 12‏:‏14. \x*
\b
\b
\c 10
\s1 يَاسُوع إِسِّيوڒْ خْ ڒمْڒَاشْ ذ وَادْجَافْ
\m 
\v 1 إِكَّارْ، يُويُورْ سّنِّي ؤُشَا يِيوضْ غَارْ ثمُّورْثْ ن يَاهُوذِييَّا، غَارْ ومْشَانْ ن ؤُژكّْوِي ن لْ-ؤُرْذُونْ. مُوننْ-د خَاسْ ڒْغَاشِي أَطَّاسْ ؤُ عَاوذْ ثُوغَا إِسّڒْمَاذْ إِ-ثنْ أَمْ مَامّشْ ثُوغَا إِنُّومْ. \x ◘ \xo 10:‏1 \xt [مت. 19‏:‏1‏-‏12] — مت. 19‏:‏1. \x*
\v 2 ؤُسِينْ-د غَارسْ إِفَارِيسِييّنْ، سّقْسَانْ ث حِيمَا أَذْ ث جَارّْبنْ: ”مَا إِحدْجڒْ إِ ورْيَازْ أَذْ إِدْجفْ إِ ثمْغَارْثْ نّسْ؟“
\v 3 يَارَّا-د، إِنَّا أَسنْ: ”مِينْ خفْ ثُوغَا كنِّيوْ يُومُورْ مُوسَا؟“
\v 4 نَّانْ: ”مُوسَا إِوْشَا تّسْرِيحْ أَذْ ثتّْوَارِي ثبْرَاثْ ن وَادْجَافْ مَاحنْذْ \add أَرْيَازْ\add* أَذْ أَسْ إِدْجفْ.“ \x ◘ \xo 10:‏4 \xt أَعَوذ. 24‏:‏1، 3؛ إِرْم. 3‏:‏1؛ مت. 5‏:‏31. \x*
\v 5 يَارَّا-د يَاسُوع، إِنَّا أَسنْ: ”خْ سِّيبّثْ ن ڒقْسَاحثْ ن وُوڒَاونْ نْومْ أَقَا يُورَا أَومْ ثَاوْصيّثْ-أَ،
\v 6 مَاشَا زِي بدُّو \add زِي مَانِي ثتّْوَاڭّْ دُّونشْثْ\add*، إِخْڒقْ إِ-ثنْ-د أَربِّي ذ أَوْثمْ ذ ثوْثمْثْ. \x ◘ \xo 10:‏6 \xt أَمز. 1‏:‏27، 2‏:‏24، 5‏:‏2؛ مت. 19‏:‏4. \x*
\v 7 س ؤُينِّي أَذْ إِسْمحْ ورْيَازْ ذِي بَابَاسْ ذ يمَّاسْ، أَذْ إِقّنْ غَارْ ثمْغَارْثْ نّسْ، \x ◘ \xo 10:‏7 \xt أَمز. 2‏:‏24؛ 1 كُور. 6‏:‏16؛ أَفا. 5‏:‏31. \x*
\v 8 ؤُشَا ثْنَاينْ إِذْسنْ خنِّي أَذْ إِڒِينْ ذ إِشْثْ ن دَّاثْ، ؤُشَا أَمُّو وَارْ تِّيڒِينْ عَاذْ ذ ثْنَاينْ، مَاشَا أَذْ إِڒِينْ ذ إِشْثْ ن أَرِّيمثْ. \x ◘ \xo 10:‏8 \xt أَمز. 2‏:‏24؛ مت. 19‏:‏5، 6؛ أَفا. 5‏:‏31؛ 1 كُور. 6‏:‏16. \x*
\v 9 س ؤُيَا مِينْ إِسّْمُونْ أَربِّي، وَارْ ث إِبطِّي بْنَاذمْ.“ \x ◘ \xo 10:‏9 \xt 1 كُور. 7‏:‏10. \x*
\m 
\v 10 ذِي ثَادَّارْثْ سّقْسَانْ ث إِمحْضَارنْ نّسْ عَاوذْ خْ مَانْ أَيَا.
\v 11 إِنَّا أَسنْ: ”وِي غَا إِدْجْفنْ إِ ثمْغَارْثْ نّسْ ؤُشَا أَذْ يَاوِي ثنّغْنِيثْ، أَقَا نتَّا إِزْنَا. \x ◘ \xo 10:‏11 \xt مت. 5‏:‏32؛ 19‏:‏9؛ لك. 16‏:‏18؛ 1 كُور. 7‏:‏10. \x*
\v 12 ؤُ مَاڒَا ثَامْغَارْثْ ثدْجفْ إِ ورْيَازْ نّسْ، ؤُشَا خنِّي أَذْ ثِيڒِي إِ ورْيَازْ نّغْنِي، أَقَا نتَّاثْ ثزْنَا.“
\b
\s1 يَاسُوع إِبَاركْ إِحنْجِيرنْ
\m 
\v 13 إِوْينْ أَسْ-د إِحنْجِيرنْ حِيمَا أَذْ ثنْ إِحَاذَا، مَاشَا إِمحْضَارنْ وبّْخنْ إِنِّي ثنْ د-يِيوْينْ. \x ◘ \xo 10:‏13 \xt [مت. 19‏:‏13‏-‏15؛ لك. 18‏:‏15‏-‏17] — مت. 19‏:‏13؛ لك. 18‏:‏15. \x*
\v 14 ؤُمِي إِژْرَا يَاسُوع مَانْ أَيَا، إِخيّقْ، إِنَّا أَسنْ: ”جّمْ إِحنْجِيرنْ أَذْ غَارِي د-أَسنْ، وَارْ ثنْ منّْعمْ، مِينْزِي ثَاڭلْذِيثْ ن أَربِّي ن يِينِّي إِدْجَانْ أَمْ نِيثْنِي. \x ◘ \xo 10:‏14 \xt مت. 18‏:‏3؛ 19‏:‏14؛ 1 كُور. 14‏:‏20؛ 1 بُط. 2‏:‏2. \x*
\v 15 س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ: ”وِي وَارْ إِقبّْڒنْ ثَاڭلْذِيثْ ن أَربِّي أَمْ يِيجّْ ن ؤُحنْجِيرْ، أَقَاعمَّارْصْ وَارْ غَارسْ إِتِّيذفْ.“
\v 16 إِذَارّعْ أَسنْ، ؤُشَا أَمْ خَاسنْ إِسَّارْسْ إِفَاسّنْ نّسْ، إِبَارْكْ إِ-ثنْ. \x ◘ \xo 10:‏16 \xt مت. 19‏:‏15؛ مك. 9‏:‏36. \x*
\b
\s1 يَاسُوع ذ ورْيَازْ بُو-وَاڭْڒَا
\m 
\v 17 ؤُمِي إِفّغْ مَاحنْذْ أَذْ يُويُورْ ذڭْ وبْرِيذْ، يُوزّڒْ-د غَارسْ إِجّنْ، إِوْضَا أَسْ غَارْ إِفَادّنْ ؤُشَا إِسّقْسَا ث، إِنَّا: ”\add أَ\add* أَمْسغَّارْ أَصبْحَانْ، مِينْ غَا ڭّغْ حِيمَا أَذْ وَارْثغْ ثُوذَارْثْ إِتّْذُومَانْ؟“ \x ◘ \xo 10:‏17 \xt [مت. 19‏:‏16‏-‏30؛ لك. 18‏:‏18‏-‏30] — مت. 19‏:‏16؛ لك. 18‏:‏18. \x*
\v 18 إِنَّا أَسْ يَاسُوع: ”مَايمِّي ذ أَيِي ثتّْڒَاغِيذْ: ’أَصبْحَانْ‘؟ ؤُڒَا ذ إِجّْ وَارْ إِدْجِي ذ أَصبْحَانْ، مْغِيرْ إِجّنْ وَاهَا: أَربِّي!
\v 19 شكْ ثسّْنذْ ثِيوصَّا: ’وَارْ زنِّي، وَارْ نقّْ، وَارْ تِّيشَارْ، وَارْ شهّذْ س ژُورْ، وَارْ تّْغشَّا، وقَّارْ بَابَاشْ ذ يمَّاشْ.‘ “ \x ◘ \xo 10:‏19 \xt ؤُف. 20‏:‏12‏-‏16؛ 21‏:‏12؛ أَعَوذ. 5‏:‏16‏-‏20؛ أَعَوذ. 24‏:‏14؛ رُوم. 13‏:‏9. \x*
\v 20 يَارَّا-د، إِنَّا أَسْ: ”\add وَاهْ، أَ\add* أَمْسغَّارْ، أَقَا مَارَّا ثِينَا ثُوغَا ضفَّارغْ ثنْثْ زِي ثمْژِي إِنُو.“
\v 21 إِخْزَارْ ذَايسْ يَاسُوع ؤُشَا إِسّْعِيزّْ إِ-ث، إِنَّا أَسْ: ”ثقِّيمْ إِشْثنْ \add عَاذْ\add*: ؤُيُورْ، زنْزْ مَارَّا مِينْ غَاركْ، أوْشْ إِ-ث إِ إِمزْڒَاضْ ؤُشَا أَذْ غَاركْ يِيڒِي إِجّْ ن ڒْكنْزْ ذڭْ ؤُجنَّا. خنِّي كْسِي صَّالِيبْ نّشْ، ضْفَارْ أَيِي-د!“ \x ◘ \xo 10:‏21 \xt مت. 6‏:‏19؛ لك. 12‏:‏33؛ 1 تِيم. 6‏:‏17. \x*
\v 22 مَاشَا نتَّا ثُوغَا إِحْزنْ س وَاوَاڒْ نِّي، ؤُشَا إِرُوحْ إِشْضنْ، مِينْزِي ثُوغَا غَارسْ أَطَّاسْ ن وَاڭْڒَا.
\m 
\v 23 إِخْزَارْ يَاسُوع غَارْ إِمحْضَارنْ نّسْ، إِنَّا أَسنْ: ”مشْحَاڒْ إِوْعَارْ خْ يِينِّي غَارْ إِدْجَا أَڭْڒَا حِيمَا أَذْ أَذْفنْ غَارْ ثْڭلْذِيثْ ن أَربِّي!“ \x ◘ \xo 10:‏23 \xt أَوڒن. 11‏:‏28؛ مت. 19‏:‏23؛ لك. 18‏:‏24. \x*
\v 24 ثْبهْثنْ إِمحْضَارنْ زڭْ وَاوَاڒنْ نّسْ. مَاشَا يَاسُوع إِعَاوذْ إِطّفْ ذڭْ وَاوَاڒْ، إِنَّا أَسنْ: ”\add أَ\add* ثَارْوَا إِنُو، مشْحَاڒْ إِوْعَارْ خْ يِينِّي إِتّْشَاڒَانْ خْ وَاڭْڒَا نْسنْ مَاحنْذْ أَذْ د-أَذْفنْ غَارْ ثْڭلْذِيثْ ن أَربِّي!
\v 25 إِهْونْ أَذْ يَاذفْ وڒْغمْ زِي ثِيطّْ ن ثْسِينفْثْ زڭْ وَاذَافْ ن بُو-وَاڭْڒَا غَارْ ثْڭلْذِيثْ ن أَربِّي.“
\v 26 إِمَّارْنِي ذَايْسنْ عَاذْ ؤُنخْڒِيعْ، نَّانْ إِ وَايَاوْيَا: ”وِي إِزمَّارنْ \add خنِّي\add* أَذْ إِتّْوَاسّنْجمْ؟“
\v 27 إِخْزَارْ ذَايْسنْ يَاسُوع، إِنَّا: ”غَارْ إِوْذَانْ وَارْ إِزمَّارْ، مَاشَا غَارْ أَربِّي وَارْ إِدْجِي أَمنِّي، مِينْزِي أَقَا غَارْ أَربِّي كُوڒْشِي ذِي ثْزمَّارْ نّسْ.“ \x ◘ \xo 10:‏27 \xt أَيُوبْ 42‏:‏2؛ إِرْم. 32‏:‏17؛ زَاك. 8‏:‏6؛ لك. 1‏:‏37. \x*
\b
\s1 ڒْمُونثْ ن وضْفَارْ ن يَاسُوع
\m 
\v 28 إِبْذَا بُوطْرُوسْ أَذْ يِينِي: ”خْزَارْ، أَقَا نشِّينْ نجَّا كُوڒْشِي، نضْفَارْ إِ شكْ-د.“ \x ◘ \xo 10:‏28 \xt مت. 4‏:‏20؛ 19‏:‏27؛ لك. 5‏:‏11؛ 18‏:‏28. \x*
\v 29 يَارَّا-د خَاسْ يَاسُوع، إِنَّا: ”س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ: وَارْ ذِينْ إِدْجِي ؤُڒَا ذ إِجّنْ ونِّي إِسمْحنْ ذِي ثَادَّارْثْ نِيغْ ذڭْ أَيْثْمَاسْ نِيغْ ذِي يسّْمَاسْ نِيغْ ذِي بَابَاسْ نِيغْ ذِي يمَّاسْ نِيغْ ذِي ثمْغَارْثْ نِيغْ ذِي ثَارَّاوْثْ ؤُڒَا ذڭْ إِيَّارنْ ذِي طّْوعْ إِنُو ؤُ ذِي طّْوعْ ن ڒخْبَارْ أَصبْحَانْ،
\v 30 إِ وَارْ إِكسِّينْ مْيَا ن ثْسقَّارْ. ڒخُّو ذِي ڒْوقْثْ-أَ \add أَذْ إِكْسِي\add* ثُوذْرِينْ ذ أَيْثْمَاسْ ذ يسّْمَاسْ ذ ثْيمَّاثِينْ ذ ثَارَّاوْثْ ذ ييَّارنْ أَكْ-ذ ؤُمَارّثْ، ؤُشَا ذِي زّْمَانْ إِ د غَا يَاسنْ \add أَذْ إِكْسِي\add* ثُوذَارْثْ إِتّْذُومَانْ.
\v 31 مَاشَا أَطَّاسْ ن يِينِّي إِدْجَانْ ذ إِمزْوُورَا أَذْ إِڒِينْ ذ إِنڭُّورَا، ؤُشَا إِنِّي إِدْجَانْ ذ إِنڭُّورَا أَذْ إِڒِينْ ذ إِمزْوُورَا.“ \x ◘ \xo 10:‏31 \xt مت. 19‏:‏30؛ 20‏:‏16؛ لك. 13‏:‏30. \x*
\b
\s1 يَاسُوع إِسَّاوَاڒْ خْ ڒْموْثْ ذ ثْنُوكْرَا نّسْ إِ ثْوَاڒَا وِيسّْ ثْڒَاثَا
\m 
\v 32 ثُوغَا-ثنْ ذڭْ وبْرِيذْ مَاحنْذْ أَذْ ڭعّْذنْ غَارْ ؤُرْشَالِيمْ ؤُ يَاسُوع ثُوغَا إِزْوَارْ أَسنْ. نِيثْنِي ثُوغَا تّْبهْثنْ ؤُشَا ڭّْوذنْ ؤُمِي ث-إِ-د-ضفَّارنْ. إِكْسِي ثنْعَاشْ \add غَارْ ؤُغزْذِيسْ\add* ؤُشَا إِبْذَا إِقَّارْ أَسنْ خْ مِينْ ذ أَسْ غَا إِمْسَارنْ، \add إِنَّا\add*: \x ◘ \xo 10:‏32 \xt [مت. 20‏:‏17‏-‏19؛ لك. 18‏:‏31‏-‏34] — مت. 16‏:‏21؛ 17‏:‏22؛ 20‏:‏18؛ مك. 8‏:‏31؛ 9‏:‏31؛ لك. 9‏:‏22؛ 18‏:‏31؛ 24‏:‏7. \x*
\v 33 ”خْزَارْ، نشِّينْ أَذْ نْڭعّذْ غَارْ ؤُرْشَالِيمْ ؤُ مِّيسْ ن بْنَاذمْ أَذْ إِمّوْشْ \add ذڭْ إِفَاسّنْ ن\add* إِمقّْرَاننْ ن إِكهَّاننْ ذ إِمْسڒْمَاذنْ ن إِذْلِيسنْ، ؤُ نِيثْنِي أَذْ خَاسْ حكْمنْ س ڒْموْثْ، أَذْ ث سلّْمنْ إِ ڒڭْنُوسْ.
\v 34 أَذْ ث سّحْقَارنْ، أَذْ ث هتّْكنْ س ؤُركُّوضْ، أَذْ خَاسْ سُّوسْفنْ، أَذْ ث نْغنْ، ؤُشَا ذڭْ وَاسّْ وِيسّْ ثْڒَاثَا أَذْ إِكَّارْ.“
\b
\s1 ثُوثْرَا ن يَاعْقُوبْ ذ يُوحَانَّا
\m 
\v 35 يُوسَا-د غَارسْ يَاعْقُوبْ ذ يُوحَانَّا، ثَارْوَا ن زَابْذِي، نَّانْ أَسْ: ”\add أَ\add* أَمْسغَّارْ، نخْسْ أَذْ أَنغْ ثڭّذْ مَارَّا مِينْ زَّايكْ غَا نتَّارْ.“ \x ◘ \xo 10:‏35 \xt [مت. 20‏:‏20‏-‏28] — مت. 20‏:‏20. \x*
\v 36 إِنَّا أَسنْ: ”مِينْ ثخْسمْ أَذْ أَومْ ڭّغْ؟“
\v 37 نَّانْ أَسْ: ”أوْشْ أَنغْ أَذْ نقِّيمْ، إِجّنْ غَارْ ؤُفُوسِي نّشْ ؤُ ونّغْنِي غَارْ ؤُزڒْمَاضْ نّشْ، ذڭْ ؤُعُودْجِي نّشْ.“
\v 38 مَاشَا نتَّا إِنَّا أَسنْ: ”أَقَا وَارْ ثسِّينمْ شَا مِينْ ثتَّارمْ. مَا ثْزمَّارمْ أَذْ ثسْومْ ڒْكَاسْ إِ زِي غَا سْوغْ نشّْ نِيغْ أَذْ ثتّْوَاسّْغضْصمْ س ؤُسغْضصْ إِ زِي غَا تّْوَاسّْغضْصغْ نشّْ؟“ \x ◘ \xo 10:‏38 \xt مت. 20‏:‏22؛ لك. 12‏:‏50. \x*
\v 39 نَّانْ أَسْ: ”نْزمَّارْ!“ إِنَّا أَسنْ يَاسُوع: ”ڒْْكَاسْ إِ غَا سْوغْ نشّْ، أَذْ ث ثسْومْ، ؤُ أَسغْضصْ إِ زِي تّْوَاسّْغضْصغْ نشّْ، أَذْ زَّايسْ تّْوَاسّْغضْصمْ، \f ◼ \fr 10:‏39 \ft \bd أَفسَّارْ\bd* - ڒْكَاسْ إِ ثُوغَا إِسْوَا لْمَاسِيحْ أَقَا-ث ذ ڒعْذَابْ إِ إِكْسِي خْ صَّالِيبْ ؤُمِي أَغْضَابْ ن سِيذِي إِهْوَا خَاسْ ذِي طّْوعْ ن مَارَّا إِمذْنَابْ إِ ذِينْ إِدْجَانْ ؤُ أَذْ ذِينْ إِڒِينْ خْ ڒحْسَابْ صِّيفثْ ن أَذَامْ ونِّي إِخْضَانْ خْ سِيذِي أَربِّي (خْزَارْ إِشا. 53:4-7).\f*  \x ◘ \xo 10:‏39 \xt مت. 20‏:‏23\x*
\v 40 مَاشَا أَغِيمِي خْ يفُوسْ إِنُو نِيغْ خْ ؤُزڒْمَاضْ إِنُو، وَارْ غَارِي إِدْجِي ذڭْ ؤُفُوسْ إِنُو مَاحنْذْ أَذْ ث وْشغْ، مَاشَا أَذْ إِمّوْشْ إِ يِينِّي ؤُمِي إِتّْوَاسّوْجذْ.“ \x ◘ \xo 10:‏40 \xt مت. 25‏:‏34. \x*
\m 
\v 41 ڒَامِي سْڒِينْعشْرَا \add ن إِمحْضَارنْ\add* مَانْ أَيَا، خيّْقنْ خْ يَاعْقُوبْ ذ يُوحَانَّا. \x ◘ \xo 10:‏41 \xt مت. 20‏:‏24. \x*
\v 42 \add خنِّي\add* إِڒَاغَا أَسنْ-د يَاسُوع غَارسْ، إِنَّا أَسنْ: ”كنِّيوْ ثسّْنمْ بلِّي إِنِّي إِتّْوَاحسْبنْ ذ ڒْحُوكَّامْ ن ڒڭْنُوسْ، أَقَا حكّْمنْ خَاسنْ، ؤُ إِمقّْرَاننْ نْسنْ، أَقَا تّْصدْجَاضنْ خَاسنْ. \x ◘ \xo 10:‏42 \xt مت. 20‏:‏25؛ لك. 22‏:‏25. \x*
\v 43 وَارْ إِتِّيڒِي أَمُّو جَارْ أَومْ، مَاشَا ونِّي إِخْسنْ أَذْ إِذْوڒْ ذ أَمقّْرَانْ جَارْ أَومْ، أَقَا نتَّا أَذْ يِيڒِي ذ أَمْسخَّارْ نْومْ، \x ◘ \xo 10:‏43 \xt 1 بُط. 5‏:‏3. \x*
\v 44 ؤُ ونِّي إِخْسنْ أَذْ يِيڒِي ذ أَمزْوَارُو جَارْ أَومْ، أَقَا نتَّا أَذْ يِيڒِي ذ أَمْسخَّارْ إِ مَارَّا.
\v 45 مِينْزِي عَاوذْ مِّيسْ ن بْنَاذمْ وَارْ د-يُوسِي، حِيمَا أَذْ خَاسْ سخَّارنْ، مَاشَا حِيمَا أَذْ إِخْذمْ، أَذْ إِوْشْ ثُوذَارْثْ نّسْ ذ أَصْڒَاحْ إِ وَاطَّاسْ \add ن إِوْذَانْ\add*.“ \x ◘ \xo 10:‏45 \xt يُوح. 13‏:‏14؛ أَفا. 1‏:‏7؛ فِيل. 2‏:‏7؛ كُول. 1‏:‏14؛ 1 تِيم. 2‏:‏6؛ ثِيث. 2‏:‏14. \x*
\b
\s1 أَسْڭنْفِي ن مِّيسْ ن ثِيمَاوُوسْ أَذَارْغَاڒْ
\m 
\v 46 إِوْضنْ-د غَارْ أَرِيحَا. ڒَامِي د-إِفّغْ يَاسُوع زِي أَرِيحَا أَكْ-ذ إِمحْضَارنْ نّسْ ذ وَاطَّاسْ ن ڒْغَاشِي، ثُوغَا ثِيمَاوُوسْ، مِّيسْ ن ثِيمَاوُوسْ، إِجّْ ن ورْيَازْ ذ أَذَارْغَاڒْ، إِقِّيمْ ذڭْ وبْرِيذْ، إِتّتَّارْ. \x ◘ \xo 10:‏46 \xt [مت. 20‏:‏29‏-‏34؛ لك. 18‏:‏35‏-‏43] — مت. 20‏:‏29؛ لك. 18‏:‏35. \x*
\v 47 ؤُمِي إِسْڒَا بلِّي يَاسُوع نَّاصِيرِي أَقَا-ث ذِينْ، إِبْذَا إِسْغُويُّو، إِقَّارْ: ”\add أَ\add*، مِّيسْ ن ذَاوُوذْ، أَرْحمْ أَيِي!“
\v 48 وبّْخنْ ث أَطَّاسْ حِيمَا أَذْ إِسْقَارْ، مَاشَا نتَّا إِقِّيمْ إِسْغُويُّو كْثَارْ: ”أَ مِّيسْ ن ذَاوُوذْ، أَرْحمْ أَيِي!“
\v 49 إِبدّْ يَاسُوع ؤُشَا يُومُورْ أَذْ خَاسْ د-ڒَاغَانْ. ڒَاغَانْ-د إِ ؤُذَارْغَاڒْ، نَّانْ أَسْ: ”أڭّْ ؤُڒْ! كَّارْ، أَقَا إِتّْڒَاغَا-د خَاكْ!“
\v 50 إِنْضَارْ ؤُذَارْغَاڒْ أَجدْجَابْ نّسْ، إِكَّارْ ؤُشَا يُوسَا-د غَارْ يَاسُوع.
\v 51 يَارَّا-د يَاسُوع، إِنَّا أَسْ: ”مِينْ ثخْسذْ أَذْ أَشْ ث ڭّغْ؟“ إِنَّا أَسْ ؤُذَارْغَاڒْ: ”\add أَ\add* أَمْسڒْمَاذْ إِنُو، حِيمَا أَذْ ثْوَاڒِيغْ.“
\v 52 إِنَّا أَسْ يَاسُوع: ”خْزَارْ، لْ-إِيمَانْ نّشْ إِوْشَا أَشْ ثُوذَارْثْ!“ ڒخْذنِّي إِذْوڒْ إِتّْوَاڒَا، ؤُشَا إِضْفَارْ \add إِ-ث\add* ذڭْ وبْرِيذْ. \x ◘ \xo 10:‏52 \xt مت. 9‏:‏22؛ مك. 5‏:‏34. \x*
\b
\b
\c 11
\s1 أَذَافْ ن يَاسُوع غَارْ ؤُرْشَالِيمْ أَمْ ؤُجدْجِيذْ
\m 
\v 1 ؤُمِي د-قَارّْبنْ غَارْ ؤُرْشَالِيمْ زڭْ ؤُغزْذِيسْ ن بَايْثْ-فَاجِي ذ بَايْثْ-عَانْيَا، زَّاثْ إِ وذْرَارْ ن زِّيثُونْ، إِسّكّْ ثْنَاينْ ن إِمحْضَارنْ نّسْ، \x ◘ \xo 11:‏1 \xt [مت. 21‏:‏1‏-‏11؛ لك. 19‏:‏28‏-‏40؛ يُوح. 12‏:‏12‏-‏19] — مت. 21‏:‏1؛ لك. 19‏:‏29. \x*
\v 2 إِنَّا أَسنْ: ”رُوحمْ غَارْ ذْشَارْ \add نِّي\add* قِيبَاتْشْ نْومْ. خْمِي غَارسْ إِ غَا ثَاذْفمْ، ڒخْذنِّي أَذْ ثَافمْ إِجّْ ن وسْنُوسْ إِقّنْ، وَارْ خَاسْ إِنْيِي ؤُڒَا ذ إِجّْ ن بْنَاذمْ. فسْيمْ أَسْ-د ؤُشَا أَوْيمْ ث-إِ-د غَارِي.
\v 3 مَاڒَا إِنَّا أَومْ حذْ: ’مَايمِّي إِ ثتّڭّمْ أَيَا؟‘، خنِّي إِنِيمْ: ’أَقَا سِيذِيثْنغْ إِحْذَاجْ إِ-ث، ؤُشَا ڒخْذنِّي أَذْ ث-إِ-د-إِسّكّْ ذَا \add عَاوذْ\add*.‘ “
\v 4 نِيثْنِي رُوحنْ، ؤُفِينْ أَسْنُوسْ نِّي إِقّنْ غَارْ ثوَّارْثْ بَارَّا خْ وبْرِيذْ. ڒَامِي ذ أَسْ د-أَرْخُونْ،
\v 5 نَّانْ أَسنْ شَا ن يِينِّي ثُوغَا ذِينْ إِبدّنْ: ”مِينْ ثتّڭّمْ، ثْفسّْيمْ إِ وسْنُوسْ؟“
\v 6 نَّانْ أَسنْ أَمْ مَامّشْ ثنْ إِوصَّا يَاسُوع، ؤُشَا جِّينْ ثنْ.
\v 7 إِوْينْ-د أَسْنُوسْ غَارْ يَاسُوع، سَّارْسنْ خَاسْ أَرُّوضْ نْسنْ ؤُشَا إِنْيَا خَاسْ يَاسُوع \x ◘ \xo 11:‏7 \xt 2 إِج. 9‏:‏13؛ يُوح. 12‏:‏14. \x*
\v 8 أَطَّاسْ سُّونْ أَرُّوضْ نْسنْ خْ وبْرِيذْ، شَا نّغْنِي قسّنْ-د ڒفْرُوعْ أَكْ-ذ وَافْرِيونْ زِي ثْشجُّورَا ؤُشَا سُّونْ ثنْ \add عَاوذْ\add* خْ وبْرِيذْ.
\v 9 إِنِّي ث إِزْوَارنْ ذ يِينِّي ث-إِ-د-إِضْفَارنْ، ثُوغَا سْغُويُّونْ س جّهْذْ، قَّارنْ: ”ؤُصَانَّا! لْبَارَاكَا إِ ونِّي د-يُوسِينْ س يِيسمْ ن سِيذِي! \x ◘ \xo 11:‏9 \xt إِزهد. 118‏:‏25، 26؛ Mt‏:‏21‏:‏15؛ يُوح. 12‏:‏13\x*
\v 10 أَذْ ثتّْوَابَاركْ ثْڭلْذِيثْ ثنِّي إِ د غَا يَاسنْ س ؤُفُوسْ ن بَابَاثْنغْ ذَاوُوذْ. ؤُصَانَّا ذِي ڒُوعْڒَا خْ ڒُوعْڒَا \add ن إِجنْوَانْ\add*!“ \x ◘ \xo 11:‏10 \xt إِزهد. 118‏:‏25، 26؛ مت. 21‏:‏9؛ يُوح. 12‏:‏13 \x*
\v 11 يُوسَا-د يَاسُوع غَارْ ؤُرْشَالِيمْ، يُوذفْ غَارْ زَّاوشْثْ ثَامقّْرَانْثْ ؤُشَا إِژْرَا مَارَّا \add مِينْ ذِينْ إِمْسَارنْ\add*. ڒَامِي ثُوغَا إِسُّوثمْ ڒْحَاڒْ، إِفّغْ غَارْ بَايْثْ-عَانْيَا أَكْ-ذ ثنْعَاشْ. \x ◘ \xo 11:‏11 \xt مت. 21‏:‏12، 14؛ لك. 19‏:‏45؛ يُوح. 2‏:‏14. \x*
\b
\s1 أَنْعَاڒْ ن وَارْثُو
\m 
\v 12 ثِيوشَّا نّسْ، ڒَامِي د-إِفّغْ زِي بَايْثْ-عَانْيَا، إِطّفْ إِ-ث-إِ-د ڒَاژْ. \x ◘ \xo 11:‏12 \xt [مت. 21‏:‏18‏-‏19] — مت. 21‏:‏18. \x*
\v 13 ؤُمِي إِژْرَا زِي ڒَاڭّْوَاجْ إِجّْ ن وَارْثُو ن ثَازَارْثْ غَارسْ ثِيفْرَايْ، يُويُورْ ذِينْ حِيمَا أَذْ يَارْزُو مَا أَذْ ثَاغْ أَذْ ذَايسْ يَافْ شَا. ؤُمِي غَارسْ د-يِيوضْ، وَارْ يُوفِي وَالُو مْغِيرْ ثِيفْرَايْ، مِينْزِي وَارْ ثُوغِي بُو ڒْوقْثْ ن ثَازَارْثْ.
\v 14 إِطّفْ ذڭْ وَاوَاڒْ، إِنَّا أَسْ \add إِ وَارْثُو\add*: ”زِي ڒخُّو ذ ثْسَاونْثْ وَارْ زَّايمْ إِتّتّْ ؤُڒَا ذ إِجّْ عَاذْ ڒْغِيدْجثْ.“ ثُوغَا إِمحْضَارنْ نّسْ تّسْڒَانْ \add مِينْ إِقَّارْ\add*.
\b
\s1 يَاسُوع ذ إِسبَّابنْ ذِي ثَادَّارْثْ إِقدّْسنْ
\m 
\v 15 ؤُشَا يُوذفْ يَاسُوع غَارْ زَّاوشْثْ ثَامقّْرَانْثْ ن أَربِّي، إِبْذَا إِسُّوفُّوغْ إِمْسوَّاقنْ ذ إِسبَّابنْ \add نِّي إِدْجَانْ\add* ذِي زَّاوشْثْ ثَامقّْرَانْثْ، ؤُشَا إِبْذَا إِسّْنقْڒَابْ طّْوَابڒْ ن إِصَارَّافنْ \add ن ثْمنْيَاثْ\add* ذ ڒكْرَاسِي ن يِينِّي ثُوغَا إِزْنُوزَانْ إِذْبِيرنْ، \x ◘ \xo 11:‏15 \xt [مت. 21‏:‏12‏-‏17؛ لك. 19‏:‏45‏-‏48؛ يُوح. 2‏:‏13‏-‏22] — مت. 21‏:‏12؛ لك. 19‏:‏45؛ يُوح. 2‏:‏14. \x*
\v 16 ؤُشَا وَارْ إِجِّي حذْ أَذْ إِعْذُو زَّاوشْثْ ثَامقّْرَانْثْ ؤُڒَا س إِشْثْ ن ڒْقشْعثْ.
\v 17 ثُوغَا إِسّڒْمَاذْ، إِنَّا أَسنْ:
\b
\m ”مَا وَارْ ثُورِي:
\m \qt ثَادَّارْثْ إِنُو أَذْ أَسْ ڒَاغَانْ\qt*
\m \qt ’ثَادَّارْثْ ن ثْژَادْجِيثْ إِ مَارَّا ڒڭْنُوسْ؟‘\qt*
\m مَاشَا كنِّيوْ ثَارِّيمْ ت
\m ذ إِفْرِي ن إِشفَّارنْ.“ \x ◘ \xo 11:‏17 \xt 1 إِج. 8‏:‏29؛ إِشا. 56‏:‏7؛ إِرْم. 7‏:‏11؛ مت. 21‏:‏13؛ لك. 19‏:‏46. \x*
\b
\m 
\v 18 إِمْسڒْمَاذنْ ن إِذْلِيسنْ ذ إِمقّْرَاننْ ن إِكهَّاننْ سْڒِينْ مَانْ أَيَا، كَّارنْ ؤُشَا أَرزُّونْ مَامّشْ غَا ڭّنْ أَذْ ث نْغنْ، مِينْزِي ڭّْوذنْ زَّايسْ، مِينْزِي ڒْغَاشِي مَارَّا ثُوغَا إِتّبْهثْ س ؤُسڒْمذْ نّسْ. \x ◘ \xo 11:‏18 \xt 7‏:‏19. \x*
\v 19 ڒَامِي د-ثوْضَا ثْمذِّيثْ، فّْغنْ غَارْ بَارَّا ن ثنْذِينْثْ.
\b
\s1 أَرْثُو إِسْڒَاوْ
\m 
\v 20 ذِي صّْبحْ زِيشْ، ڒَامِي ذِينِّي عْذُونْ، ژْرِينْ بلِّي وَارْثُو \add نِّي\add* إِسْڒَاوْ زڭْ إِژوْرَانْ.
\v 21 شِيمْعُونْ إِفْثنْ، خنِّي إِنَّا أَسْ: ”\add أَ\add* أَمْسڒْمَاذْ إِنُو، خْزَارْ، أَرْثُو إِ ثْنعْڒذْ، أَقَا إِسْڒَاوْ.“
\v 22 يَارَّا-د يَاسُوع، إِنَّا أَسنْ: ”مَاعْلِيكْ أَذْ ذَايْومْ يِيڒِي لْ-إِيمَانْ ن أَربِّي،
\v 23 مَاغَارْ س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ، مَاڒَا حذْ أَذْ يِينِي إِ وذْرَارْ-أَ: ’مكْسِي، وْضَا ذِي ڒبْحَارْ!‘، وَارْ إِتّْشكِّي ذڭْ وُوڒْ نّسْ مَاشَا أَذْ يَامنْ بلِّي مِينْ إِنَّا أَذْ إِفّغْ، إِوَا أَقَا أَذْ إِفّغْ إِ نتَّا أَمْ مَامّشْ إِنَّا نتَّا. \x ◘ \xo 11:‏23 \xt مت. 17‏:‏20؛ 21‏:‏21؛ لك. 17‏:‏6. \x*
\v 24 س ؤُينِّي نشّْ أَذْ أَومْ إِنِيغْ، مَارَّا مِينْ غَا ثتَّارمْ أَمْ ثتّْژَادْجَامْ، أَمْننْ بلِّي أَذْ ث ثْكسْبمْ، ؤُشَا أَذْ غَارْومْ يِيڒِي. \x ◘ \xo 11:‏24 \xt إِرْم. 29‏:‏12؛ مت. 7‏:‏7؛ لك. 11‏:‏9؛ يُوح. 14‏:‏13؛ 15‏:‏7؛ 16‏:‏24؛ يَاع. 1‏:‏5، 6؛ 1 يُوح. 3‏:‏22؛ 5‏:‏14. \x*
\v 25 ؤُ خْمِي غَا ثْبدّمْ ثتّْژَّادْجَامْ، غْفَارمْ مِينْ غَارْومْ خْ شَا ن إِجّنْ، حِيمَا أَذْ أَومْ إِغْفَارْ عَاوذْ بَابَاثْومْ إِ إِدْجَانْ ذڭْ إِجنْوَانْ دّْنُوبْ نْومْ. \x ◘ \xo 11:‏25 \xt مت. 6‏:‏14؛ كُول. 3‏:‏13. \x*
\v 26 مَاڒَا وَارْ ثْغفَّارمْ كنِّيوْ، وَارْ ذ أَومْ إِغفَّارْ ؤُڒَا ذ بَابَاثْومْ إِ إِدْجَانْ ذڭْ إِجنْوَانْ إِ دّْنُوبْ نْومْ.“ \x ◘ \xo 11:‏26 \xt مت. 18‏:‏35. \x*
\b
\s1 أَسقْسِي خْ تّسْرِيحْ ن يَاسُوع
\m 
\v 27 ؤُسِينْ-د عَاوذْ غَارْ ؤُرْشَالِيمْ. أَمْ ثُوغَا إِڭُّورْ ذِي زَّاوشْثْ ثَامقّْرَانْثْ، قَارّْبنْ-د غَارسْ إِمقّْرَاننْ ن إِكهَّاننْ ذ إِمْسڒْمَاذنْ ن إِذْلِيسنْ ذ إِمْغَارنْ \add ن ڒْڭنْسْ\add*. \x ◘ \xo 11:‏27 \xt [مت. 21‏:‏23‏-‏27؛ لك. 20‏:‏1‏-‏8] — مت. 21‏:‏23؛ لك. 20‏:‏1. \x*
\v 28 نَّانْ أَسْ: ”س مَانْ تّسْرِيحْ إِ \add زِي\add* ثتّڭّذْ ثِيمسْڒَايِينْ-أَ؟ وِي ذ أَشْ إِوْشِينْ صُّولْطَا-يَا حِيمَا أَذْ ثڭّذْ ثِيمسْڒَايِينْ-أَ؟“ \x ◘ \xo 11:‏28 \xt ؤُف. 2‏:‏14؛ ڒخ. 4‏:‏7؛ 7‏:‏27. \x*
\v 29 يَارَّا-د يَاسُوع، إِنَّا أَسنْ: ”ؤُڒَا ذ نشّْ أَذْ كنِّيوْ سّقْسِيغْ إِجّْ ن ؤُسقْسِي، حِيمَا كنِّيوْ أَذْ خَافِي ثَارِّيمْ، ؤُشَا \add خنِّي\add* ؤُڒَا ذ نشّْ أَذْ أَومْ إِنِيغْ س مَانْ تّسْرِيحْ إِ زِي تّڭّغْ أَيَا.
\v 30 أَسغْضَاصْ ن يُوحَانَّا، مَا إِكَّا-د زڭْ ؤُجنَّا نِيغْ زڭْ إِوْذَانْ؟ أَرّمْ-د خَافِي!“
\v 31 مْشَاوَارنْ جَارْ أَسنْ، نَّانْ: ”مَاڒَا ننَّا: ’زڭْ ؤُجنَّا!‘، أَذْ يِينِي: ’مَايمِّي وَارْ زَّايسْ ثُومِينمْ؟‘
\v 32 مَاشَا مَاڒَا ننَّا: ’زڭْ إِوْذَانْ!‘، \add خنِّي\add* إِتّْخصَّا أَذْ نڭّْوذْ زِي ڒْڭنْسْ!“، مِينْزِي مَارَّا حسْبنْ يُوحَانَّا ذ أَنَابِي س ثِيذتّْ. \x ◘ \xo 11:‏32 \xt مت. 14‏:‏5؛ مك. 6‏:‏20. \x*
\v 33 أَرِّينْ-د، نَّانْ إِ يَاسُوع: ”وَارْ نسِّينْ!“ نتَّا إِنَّا أَسنْ: ”خنِّي ؤُڒَا ذ نشّْ وَارْ ذ أَومْ قَّارغْ زِي مَانْ تّسْرِيحْ إِ زِي تّڭّغْ ثِيمسْڒَايِينْ-أَ.“
\b
\b
\c 12
\s1 أَمذْيَا ن ؤُمَارْجُوعْ ن ثْزَايَارْثْ ذ إِخمَّاسنْ إِعفَّاننْ
\m 
\v 1 إِبْذَا إِسَّاوَاڒْ أَكِيذْسنْ س إِمذْيَا: ”إِجّْ ن بْنَاذمْ إِڭَّا إِجّْ ن ؤُمَارْجعْ ن ؤُضِيڒْ، إِژُّو ذَايسْ ثِيزَايَارِينْ، إِقوَّارْ أَسْ-د س إِجّْ ن وفْرَايْ، إِغْزَا ثَاسِيرْثْ ن ؤُضِيڒْ، إِبْنَا ذَايسْ صُّومْعثْ ؤُشَا إِوكّڒْ \add أَمَارْجُوعْ نِّي\add* إِ إِخمَّاسنْ ؤُشَا إِسَافَارْ. \x ◘ \xo 12:‏1 \xt [مت. 21‏:‏33‏-‏46؛ لك. 20‏:‏9‏-‏19] — إِزهد. 80‏:‏1؛ إِشا. 5‏:‏1؛ إِرْم. 2‏:‏21؛ 12‏:‏10؛ مت. 21‏:‏33؛ لك. 20‏:‏9. \x*
\v 2 ڒَامِي د-يِيوضْ ڒْحَاڒْ، إِسّكّْ أَمْسخَّارْ نّسْ غَارْ إِخمَّاسنْ، حِيمَا أَذْ إِكْسِي \add ثَاسْغَارْثْ نّسْ\add* زڭْ وڒْقَاضْ ن ؤُمَارْجعْ ن ؤُضِيڒْ.
\v 3 مَاشَا نِيثْنِي وْثِينْ ث ؤُشَا سّكّنْ ث إِخْوَا.
\v 4 عَاوذْ إِسّكّْ غَارْسنْ إِجّْ ن ؤُمْسخَّارْ نّغْنِي، أَرجْمنْ ث، مَارْژنْ أَسْ، ؤُشَا ڒَامِي ث سّْبحْثْڒنْ، ؤُژّْڒنْ \add خَاسْ\add*.
\v 5 عَاوذْ إِسّكّْ-د غَارْسنْ ونّغْنِي ؤُشَا نْغِينْ ث \add ؤُڒَا ذ نتَّا\add*. أَمُّو \add إِ إِسّكّْ عَاذْ\add* أَطَّاسْ ن إِنّغْنِي، هتّْكنْ شَا زَّايْسنْ س ؤُركُّوضْ ذ شَا نّغْنِي زَّايْسنْ نْغِينْ ثنْ.
\v 6 غَارْ ؤُنڭَّارْ إِسّكّْ غَارْسنْ أَينِّي ن مِّيسْ إِ غَارسْ إِ خَاسْ إِعِيزّنْ، مَاغَارْ إِنَّا: ’نِيشَانْ أَذْ وقَّارنْ مِّي!‘
\v 7 مَاشَا إِخمَّاسنْ، نِّي نَّانْ جَارْ أَسنْ: ’أَقَا ذ وَا ذ أَوْرِيثْ. زِيذمْ، أَذْ ث ننغْ ؤُشَا أَذْ غَارْنغْ يِيڒِي ڒْوَارْثْ.‘ \x ◘ \xo 12:‏7 \xt أَمز. 37‏:‏17؛ إِزهد. 2‏:‏8؛ مت. 26‏:‏3؛ يُوح. 11‏:‏53\x*
\v 8 طّْفنْ ث، نْغِينْ ث ؤُشَا نْضَارنْ ث بَارَّا إِ ؤُمَارْجعْ ن ؤُضِيڒْ.
\v 9 مِينْ غَا يڭّْ بَابْ ن ؤُمَارْجعْ ن ؤُضِيڒْ؟ أَذْ د-يَاسْ، أَذْ إِنغْ إِخمَّاسنْ ؤُشَا أَذْ إِوْشْ أَمَارْجعْ ن ؤُضِيڒْ إِ إِنّغْنِي.
\v 10 مَا وَارْ ثغْرِيمْ \add أَوَاڒْ-أَ ن\add* ثِيرَا \add إِقدّْسنْ\add*؟ ...
\b
\m \qt ’أَژْرُو إِ ثُوغَا إِمّنْضَارنْ إِبنَّاينْ،\qt*
\m \qt أَقَا إِذْوڒْ ذ \tl أَژْرُو ذ\tl* أَزدْجِيفْ ن ثغْمَارْثْ.\qt* \x ◘ \xo 12:‏10 \xt إِزهد. 118‏:‏22، 23؛ إِشا. 28‏:‏16؛ مت. 21‏:‏42؛ لك. 20‏:‏17؛ ڒخ. 4‏:‏11؛ رُوم. 9‏:‏33؛ 1 بُط. 2‏:‏6. \x*
\m 
\v 11 \qt وَا يُوسَا-د زِي سِيذِي\qt*
\m \qt ؤُ مَانْ أَيَا ذ ڒعْجبْ ذِي ثِيطَّاوِينْ نّغْ.‘ “\qt* \x ◘ \xo 12:‏11 \xt إِزهد. 118‏:‏22، 23\x*
\b
\m 
\v 12 خْسنْ أَذْ ث طّْفنْ مَاشَا نِيثْنِي ڭّْوذنْ زِي ڒْغَاشِي، مِينْزِي فهْمنْ بلِّي ثُوغَا إِسَّاوَاڒْ خَاسنْ س ؤُمذْيَا نِّي. نِيثْنِي جِّينْ ث ؤُشَا ؤُيُورنْ.
\b
\s1 أَخدْجصْ ن ضَّارِيبَا إِ قَايْصَارْ
\m 
\v 13 خنِّي سّكّنْ غَارسْ شَا ن يرْيَازنْ زڭْ إِفَارِيسِييّنْ ؤُ شَا زِي ثَادَّارْثْ ن هِيرُوذُوسْ، حِيمَا أَذْ أَسْ طّْفنْ س وَاوَاڒنْ نّسْ. \x ◘ \xo 12:‏13 \xt [مت. 22‏:‏15‏-‏22؛ لك. 20‏:‏20‏-‏26] — مت. 22‏:‏15؛ لك. 20‏:‏20. \x*
\v 14 ؤُمِي د-ؤُسِينْ، نَّانْ أَسْ: ”\add أَ\add* أَمْسغَّارْ، نشِّينْ نسّنْ أَقَا شكْ ذ ثِيذتّْ، وَارْ ثڭّْوِيذذْ زڭْ إِوْذَانْ ؤُ وَارْ ثْخزَّارذْ شَا غَارْ وُوذمْ ن إِوْذَانْ، مَاشَا ثسّڒْمَاذذْ أَبْرِيذْ ن أَربِّي س ثِيذتّْ. مَا إِحدْجڒْ أَذْ نوْشْ دَّارِيبَا إِ كُوڒْ  إِجّنْ \add زَّايْنغْ\add* إِ قَايْصَارْ نِيغْ لَّا؟ مَا إِتّْخصَّا أَنغْ أَذْ نْخدْجصْ ضَّارِيبَا نِيغْ لَّا؟“
\v 15 ڒَامِي نتَّا يَارْڭبْ خْ نِّيفَاقْ نْسنْ، إِنَّا أَسنْ: ”مَايمِّي ذ أَيِي ثتّْجَارَّابمْ؟ أَوْيمْ أَيِي-د إِجّْ ن ذِينَارْ حِيمَا أَذْ ث ژَترغْ!“
\v 16 إِوْينْ أَسْ-د إِجّْ \add ن ذِينَارْ\add*. خنِّي إِنَّا أَسنْ: ”وِي يِيڒَانْ ثَاصْوِيرْثْ-أَ ذ ثِيرَا-يَا؟“ نَّانْ أَسْ: ”ن قَايْصَارْ!“
\v 17 يَارَّا-د يَاسُوع، إِنَّا أَسنْ: ”وْشمْ \add خنِّي\add* إِ قَايْصَارْ مِينْ إِدْجَانْ إِ قَايْصَارْ، ؤُ مِينْ إِدْجَانْ إِ أَربِّي إِ أَربِّي.“ ؤُشَا تّْعجْبنْ ذَايسْ. \x ◘ \xo 12:‏17 \xt مت. 17‏:‏25؛ 22‏:‏21؛ رُوم. 13‏:‏7. \x*
\b
\s1 أَسقْسِي ن إِصَاذُوقِييّنْ خْ ثْنُوكْرَا
\m 
\v 18 ؤُسِينْ-د غَارسْ \add عَاوذْ\add* إِصَاذُوقِييّنْ نِّي إِقَّارنْ بلِّي وَارْ ذِينْ بُو ثْنُوكْرَا. سّقْسَانْ ث، نَّانْ: \x ◘ \xo 12:‏18 \xt [مت. 22‏:‏23‏-‏33؛ لك. 20‏:‏27‏-‏40] — مت. 22‏:‏23؛ لك. 20‏:‏27؛ ڒخ. 23‏:‏8. \x*
\v 19 ”\add أَ\add* أَمْسغَّارْ، أَقَا يُورَا أَنغْ مُوسَا، مَاڒَا إِمُّوثْ إِ حذْ ؤُمَاسْ ؤُشَا إِجَّا ثَامْغَارْثْ، \add مَاشَا\add* وَارْ د-إِجِّي بُو ثَارَّاوْثْ، أَذْ يَاوِي ؤُمَاسْ ثَامْغَارْثْ نِّي ؤُشَا أَذْ د-يجّْ أَحنْجِيرْ إِ ؤُمَاسْ. \x ◘ \xo 12:‏19 \xt أَمز. 38‏:‏8؛ أَعَوذ. 25‏:‏5، 6. \x*
\v 20 ثُوغَا ذِينْ سبْعَا ن وَاوْمَاثنْ. أَمزْوَارُو يِيوِي إِشْثْ ن ثمْغَارْثْ ؤُشَا أَوَارْنِي ڒَامِي إِمُّوثْ، وَارْ د-إِجِّي بُو دُّورِييثْ.
\v 21 خنِّي يِيوْيِي إِ-ت ونِّي وِيسّْ ثْنَاينْ ؤُشَا إِمُّوثْ، وَارْ د-إِجِّي بُو دُّورِييثْ ؤُڒَا ذ نتَّا، ؤُشَا أَمُّو ؤُڒَا ذ ونِّي وِيسّْ ثْڒَاثَا.
\v 22 مَارَّا سبْعَا \add نِّي\add* إِوْينْ ت، وَارْ د-جِّينْ بُو دُّورِييثْ. أَنڭَّارْ نْسنْ مَارَّا ثمُّوثْ ثمْغَارْثْ \add نِّي\add* عَاوذْ.
\v 23 إِوَا ذِي ثْنُوكْرَا، خْمِي د غَا كَّارنْ، ؤُمِي غَا ثِيڒِي ثمْغَارْثْ نِّي؟ مِينْزِي سبْعَا \add نِّي مَارَّا\add* إِوْينْ ت ذ ثَامْغَارْثْ.“
\v 24 يَارَّا-د يَاسُوع، إِنَّا أَسنْ: ”مَا وَارْ ثْخطِّيمْ شَا مِينْزِي وَارْ ثسِّينمْ شَا ثِيرَا \add إِقدّْسنْ\add* ذ جّهْذْ ن أَربِّي؟
\v 25 مَاغَارْ خْمِي د غَا كَّارنْ جَارْ إِمتِّيننْ، وَارْ ثنْثْ تِّيوْينْ ذ ثَامْغَارْثْ ؤُ وَارْ سّْمِيدْجِيشنْ ثِيمْغَارِينْ إِ يرْيَازنْ، مَاشَا أَذْ إِڒِينْ أَمْ لْمَالَاكَاثْ \add إِ إِدْجَانْ\add* ذڭْ ؤُجنَّا. \x ◘ \xo 12:‏25 \xt مت. 22‏:‏30؛ 1 يُوح. 3‏:‏2. \x*
\v 26 مَاشَا زِي جِّيهثْ ن إِمتِّيننْ أَقَا تّْوَاسّْنكَّارنْ: مَا وَارْ ثغْرِيمْ ذڭْ وذْلِيسْ ن مُوسَا، مَامّشْ أَكِيذسْ إِسِّيوڒْ أَربِّي زِي شْبَارْقْ أَكْ-ذ إِسنَّاننْ، إِنَّا: ’ذ نشّْ ذ أَربِّي ن إِبْرَاهِيمْ ذ أَربِّي ن إِسْحَاقْ ذ أَربِّي ن يَاعْقُوبْ‘؟ \x ◘ \xo 12:‏26 \xt ؤُف. 3‏:‏6، 15؛ مت. 22‏:‏31، 32؛ ڒخ. 7‏:‏32؛ عبر. 11‏:‏16. \x*
\v 27 نتَّا وَارْ إِدْجِي ذ أَربِّي ن إِمتِّيننْ، مَاشَا \add ذ أَربِّي\add* ن يِينِّي إِدَّارنْ. س ؤُينِّي أَقَا كنِّيوْ ثْخطَّامْ أَطَّاسْ.“
\b
\s1 ثَاوْصيّثْ ثَامقّْرَانْثْ
\m 
\v 28 إِجّنْ زڭْ إِمْسڒْمَاذنْ ن إِذْلِيسنْ إِقَارّبْ-د غَارسْ، إِسْڒَا أَسنْ تّمْهَارْوَاضنْ جَارْ أَسنْ ؤُشَا إِسّنْ بلِّي نتَّا أَقَا يَارَّا-د خَاسنْ مْلِيحْ. \add خنِّي\add* إِسّقْسَا ث: ”مَانْ ثنْثْ إِدْجَانْ ذ ثَاوْصيّثْ ثَامزْوَارُوثْ خْ كُوڒْشِي؟“ \x ◘ \xo 12:‏28 \xt [مت. 22‏:‏34‏-‏40؛ لك. 10‏:‏25‏-‏28] — مت. 22‏:‏34؛ لك. 10‏:‏25. \x*
\v 29 يَارَّا-د خَاسْ يَاسُوع: ”أَقَا ثَامزْوَارُوثْ خْ مَارَّا ثِيوصَّا: سڒْ أَ إِسْرَائِيل! سِيذِي، أَربِّي نّغْ، سِيذِي ذ إِجّْ. \x ◘ \xo 12:‏29 \xt أَعَوذ. 6‏:‏4‏-‏5؛ 10‏:‏12؛ لك. 10‏:‏27. \x*
\v 30 أَذْ ثخْسذْ سِيذِي، أَربِّي نّشْ س مَارَّا وُوڒْ نّشْ س مَارَّا ڒعْمَارْ نّشْ س مَارَّا ڒعْقڒْ نّشْ س مَارَّا جّهْذْ نّشْ. ثَا ذ ثَاوْصيّثْ ثَامزْوَارُوثْ. \x ◘ \xo 12:‏30 \xt أَعَوذ. 6‏:‏5؛ 10‏:‏12؛ 30‏:‏6؛ مت. 22‏:‏37؛ لك. 10‏:‏27. \x*
\v 31 ؤُ ثَاوْصيّثْ وِيسّْ ثْنَاينْ، أَمشْنَاوْ ثَانِيثَا، أَقَا ذ ثَا: أَذْ ثخْسذْ جَّارْ نّشْ أَمشْنَاوْ إِخفْ نّشْ. وَارْ ذِينْ بُو ثوْصيّثْ نّغْنِيثْ ذ ثَامقّْرَانْثْ خْ ثِينَا \add س ثْنَاينْ\add*.“ \x ◘ \xo 12:‏31 \xt لَاوِي 19‏:‏18؛ مت. 22‏:‏39؛ رُوم. 13‏:‏9؛ ڭال. 5‏:‏14؛ يَاع. 2‏:‏8. \x*
\v 32 إِنَّا أَسْ ؤُمْسڒْمَاذْ ن إِذْلِيسنْ: ”نِيشَانْ، \add أَ\add* أَمْسڒْمَاذْ إِنُو، س ثِيذتّْ ثنِّيذْ بلِّي نتَّا ذ إِجّنْ، وَارْ ذِينْ ؤُڒَا ذ إِجّْ نّغْنِي مْغِيرْ نتَّا،
\v 33 ؤُ بلِّي مَاڒَا إِجّْ ن بْنَاذمْ أَذْ ث إِخْسْ س وُوڒْ مَارَّا، س ڒعْقڒْ مَارَّا، س ڒعْمَارْ مَارَّا ؤُ س جّهْذْ مَارَّا، ؤُشَا أَذْ إِخْسْ جَّارْ نّسْ أَمشْنَاوْ إِخفْ نّسْ، أَقَا ذ مَانْ أَيَا حْسنْ زِي مَارَّا ثِيغَارْصِينْ ن وشْمَاضْ ذ مَارَّا ثِيغَارْصِينْ نّغْنِيثْ.“
\v 34 ؤُمِي إِژْرَا يَاسُوع بلِّي يَارَّا-د س ڒعْقڒْ، إِنَّا أَسْ: ”أَقَا شكْ وَارْ ثِيڭّْوِيجذْ شَا خْ ثْڭلْذِيثْ ن أَربِّي.“ خنِّي وَارْ إِعوّڒْ حذْ أَذْ ث إِسّقْسَا ؤُڒَا ذڭْ إِشْثْ ن ثْمسْڒَاشْثْ. \x ◘ \xo 12:‏34 \xt أَعَوذ. 6‏:‏4‏-‏5، 4‏:‏35؛ إِشا. 45‏:‏21\x*
\b
\s1 مَانْ ونْ إِدْجَانْ ذ مِّيسْ ن ذَاوُوذْ؟
\m 
\v 35 ڒَامِي ثُوغَا إِسّڒْمَاذْ ذِي زَّاوشْثْ ثَامقّْرَانْثْ إِطّفْ يَاسُوع ذڭْ وَاوَاڒْ، إِنَّا: ”مَامّشْ قَّارنْ إِمْسڒْمَاذنْ ن إِذْلِيسنْ بلِّي لْمَاسِيحْ ذ مِّيسْ ن ذَاوُوذْ؟ \x ◘ \xo 12:‏35 \xt [مت. 22‏:‏41‏-‏46؛ لك. 20‏:‏41‏-‏44] — مت. 22‏:‏41؛ مك. 10‏:‏47، 48؛ مك. 11‏:‏10؛ لك. 20‏:‏41. \x*
\v 36 مِينْزِي ذَاوُوذْ س يِيخفْ نّسْ إِنَّا س أَرُّوحْ إِقدّْسنْ:
\b
\m \qt ’إِنَّا سِيذِي إِ سِيذِي إِنُو:\qt*
\m \qt قِّيمْ-د خْ ؤُفُوسِي إِنُو\qt*
\m \qt أَڒْ د غَا ڭّغْ ڒْعذْيَانْ نّشْ\qt*
\m \qt ذ ثَانبْذَاثْ سَاذُو إِضَارنْ نّشْ.‘\qt* \x ◘ \xo 12:‏36 \xt 2 صم. 23‏:‏2؛ إِزهد. 110‏:‏1؛ ڒخ. 1‏:‏16؛ 2‏:‏34؛ 28‏:‏25؛ 1 كُور. 15‏:‏25؛ عبر. 1‏:‏13؛ 10‏:‏13؛ 2 بُط. 1‏:‏21 \x*
\b
\m 
\v 37 س ؤُيَا إِتّْڒَاغَا أَسْ-د ذَاوُوذْ: ’سِيذِي إِنُو!‘ مَانِيسْ د-إِكَّا ذ مِّيسْ؟“ مَارَّا ڒْغَاشِي ثُوغَا إِسْڒَا أَسْ س ڒفْرَاحثْ.
\b
\s1 أَعْڒَامْ غَارْ ڒْڭنْسْ خْ إِمْسڒْمَاذنْ ن إِذْلِيسنْ
\m 
\v 38 إِنَّا أَسنْ ذڭْ ؤُسڒْمَاذْ نّسْ: ”حْضَامْ إِخفْ نْومْ زڭْ إِمْسڒْمَاذنْ ن إِذْلِيسنْ إِنِّي ؤُمِي إِتّعْجِيبْ أَسنْ ڒْحَاڒْ خْمِي غَا ؤُيُورنْ س ڒعْبَايَاثْ ثِيزِيرَارِينْ ؤُ خْمِي خَاسنْ إِ غَا سدْجْمنْ \add إِوْذَانْ\add* ذِي ڒسْوَاقْ، \x ◘ \xo 12:‏38 \xt [مت. 23‏:‏1‏-‏36؛ لك. 20‏:‏45‏-‏47] — مت. 23‏:‏5، 6؛ لك. 11‏:‏43؛ 20‏:‏46. \x*
\v 39 إِنِّي \add ؤُمِي إِتّعْجِيبْ أَسنْ\add* ڒكْرَاسِي ن زَّاثْ ذِي ثمْزِيذَاوِينْ، ؤُڒَا ذ إِمُوشَانْ إِمزْوُورَا غَارْ إِمنْسِيونْ \add ن وُورَارنْ\add*.
\v 40 نِيثْنِي تّتّنْ ثُوذْرِينْ ن ثِيجَّاڒْ \add أَمْ تّتَّارنْ\add* ثِيوْهِيبِينْ ذِي طّْوعْ ن ثْژَادْجَاثِينْ نْسنْ ثِيزِيرَارِينْ. أَقَا إِنَا أَذْ كْسِينْ ڒْحُوكْمْ ذ أَمقّْرَانْ.“ \x ◘ \xo 12:‏40 \xt مت. 23‏:‏14؛ لك. 20‏:‏47؛ 2 تِيم. 3‏:‏6؛ ثِيث. 1‏:‏11. \x*
\b
\s1 صّذْقثْ ن ثَاجَّاتْشْ
\m 
\v 41 أَمْ إِقِّيمْ يَاسُوع قِيبَاتْشْ إِ سّنْذُوقْ ن صّذْقثْ، إِژْرَا مَامّشْ إِنطَّارْ ڒْغَاشِي ثِينْعَاشِينْ ذِي سّنْذُوقْ. أَطَّاسْ ن أَيْثْبَابْ ن وَاڭْڒَا ثُوغَا نطَّارنْ ذَايسْ أَطَّاسْ. \x ◘ \xo 12:‏41 \xt [لك. 21‏:‏1‏-‏4] — 2 إِج. 12‏:‏10؛ لك. 21‏:‏1. \x*
\v 42 ثُوسَا-د إِشْثْ ن ثَاجَّاتْشْ ذ ڒْمسْكِينَا ثنْضَارْ ذَايسْ ثْنَاينْ ن ؤُقِييَّاثْ، سمَّانْ ثنْثْ ’شَامُونَاثْ‘. \f ◼ \fr 12:‏42 \ft \bd ’شَامُونَا\bd* - نتَّاثْ ذ إِجّْ نُوصُولْذِي ن وُوذَاينْ. أَقَا ثَامْغَارْثْ-أَ ثنْضَارْ ذَايسْ ثْنَاينْ ن شَامُونَاثْ. ؤُقِييَّا قَّارنْ أَسْ ’شَامُونَا‘ ذ أَمژْيَانْ خْ مَارَّا ؤُقِييَّاثْ ن نّْحَاسْ.\f*
\v 43 \add خنِّي\add* إِڒَاغَا يَاسُوع إِ إِمحْضَارنْ نّسْ، إِنَّا أَسنْ: ”س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ، ثَاجَّاتْشْ-أَ ڒْمسْكِينَا أَقَا ثنْضَارْ ذَايسْ كْثَارْ خْ مَارَّا إِوْذَانْ نِّي إِنْضَارنْ ذِي سّنْذُوقْ ن صّذْقثْ. \x ◘ \xo 12:‏43 \xt 2 كُور. 8‏:‏12. \x*
\v 44 مِينْزِي مَارَّا نْضَارنْ ذَايسْ زِي مِينْ غَارْسنْ أَطَّاسْ، مَاشَا ثَا زِي ذْرُوسْ نّسْ ثنْضَارْ ذَايسْ كُوڒْشِي مِينْ غَارسْ، أَقَا ثنْضَارْ مَارَّا مِينْ غَارسْ ذ أَڭْڒَا.“
\b
\b
\c 13
\s1 أَبَارّحْ ن يَاسُوع خْ قطُّو ن دُّونشْثْ
\m 
\v 1 أَڒَامِي د-إِفّغْ زِي زَّاوشْثْ ثَامقّْرَانْثْ، إِنَّا أَسْ إِجّنْ زڭْ إِمحْضَارنْ نّسْ: ”\add أَ\add* أَمْسغَّارْ، خْزَارْ، مَامّشْ دْجَانْ إِژْرَا-يَا ذ ڒبْنِي-يَا!“ \x ◘ \xo 13:‏1 \xt [مت. 24‏:‏1‏-‏44؛ لك. 21‏:‏5‏-‏33] — مت. 24‏:‏1؛ لك. 21‏:‏5. \x*
\v 2 يَارَّا-د يَاسُوع، إِنَّا أَسْ: ”مَا ثژْرِيذْ ڒبْنِي-يَا إِمْغَارنْ؟ وَارْ ذَا إِتّْغِيمِي ؤُڒَا ذ إِجّْ ن وژْرُو خْ وژْرُو نّغْنِي إِ وَارْ إِتّْنهْذِيمْ.“ \x ◘ \xo 13:‏2 \xt 1 إِج. 9‏:‏7، 8؛ مِيخَا 3‏:‏12؛ لك. 19‏:‏44. \x*
\m 
\v 3 ڒَامِي ثُوغَا إِقِّيمْ خْ وذْرَارْ ن زِّيثُونْ قِيبَاتْشْ إِ زَّاوشْثْ ثَامقّْرَانْثْ، سّقْسَانْ ث بُوطْرُوسْ ذ يَاعْقُوبْ ذ يُوحَانَّا ذ أَنْذْرَاوُوسْ ڒَْامِي ثنْ ثُوغَا وحّذْسنْ: \x ◘ \xo 13:‏3 \xt مت. 24‏:‏3؛ لك. 21‏:‏7. \x*
\v 4 ”إِنِي أَنغْ مڒْمِي إِ غَا يِيڒِي مَانْ أَيَا، ؤُ مَانْ أَذْ ثِيڒِي ڒعْڒَامثْ أَقَا مَارَّا ثِيمسْڒَايْنْ-أَ أَذْ أَوْضنْثْ؟“ \x ◘ \xo 13:‏4 \xt ڒخ. 1‏:‏6. \x*
\m 
\v 5 إِبْذَا يَاسُوع إِقَّارْ أَسنْ: ”\bd خْزَارمْ\bd*، حِيمَا وَارْ كنِّيوْ إِغكّْوِي حذْ. \x ◘ \xo 13:‏5 \xt إِرْم. 29‏:‏8؛ أَفا. 5‏:‏6؛ 2 تس. 2‏:‏2، 3؛ 1 يُوح. 4‏:‏1. \x*
\v 6 أَقَا أَطَّاسْ أَذْ د-أَسنْ س يِيسمْ إِنُو قَّارنْ: ’أَقَا ذ نشّْ!‘، ؤُشَا أَذْ غْوَانْ أَطَّاسْ. \x ◘ \xo 13:‏6 \xt إِرْم. 14‏:‏14؛ 23‏:‏21. \x*
\v 7 مَاڒَا ثسْڒِيمْ خْ إِمنْغَانْ ذ ڒخْبَارْ ن ڭَارَّاثْ، وَارْ تّْنخْڒِيعمْ شَا، مِينْزِي س ؤُغِيڒْ أَذْ يِيڒِي مَانْ أَيَا، مَاشَا وَارْ إِتِّيڒِي عَاذْ ذ أَنڭَّارْ.
\v 8 مِينْزِي ڒْڭنْسْ أَذْ إِكَّارْ ضِيدّْ إِ ڒْڭنْسْ نّغْنِي ؤُ ثَاڭلْذِيثْ ضِيدّْ إِ ثْڭلْذِيثْ نّغْنِي. أَذْ إِڒِينْ إِنْهزَّانْ ن ثمُّورْثْ زڭْ ومْشَانْ غَارْ ومْشَانْ نّغْنِي ؤُشَا أَذْ يِيڒِي ڒَاژْ ذ ؤُغوُّوغْ. ثِيمسْڒَايِينْ-أَ ذ بدُّو ن ڒوْجعْ \add ن ثَارْوَا\add*. \x ◘ \xo 13:‏8 \xt إِشا. 19‏:‏2. \x*
\m 
\v 9 \bd حْضَامْ\bd* إِخفْ نْومْ، مِينْزِي أَذْ كنِّيوْ سلّْمنْ إِ ثُوذْرِينْ ن شّْرعْ، أَذْ كنِّيوْ هتّْكنْ س ؤُركُّوضْ ذِي ثمْزِيذَاوِينْ نْسنْ ؤُشَا أَذْ كنِّيوْ سِّيوْضنْ غَارْ إِجدْجِيذنْ ذ ڒْحُوكَّامْ ذِي سِّيبّثْ إِنُو، ذ شّْهَاذثْ إِ نِيثْنِي. \x ◘ \xo 13:‏9 \xt مت. 10‏:‏17؛ 24‏:‏9؛ لك. 21‏:‏12؛ يُوح. 15‏:‏19؛ 16‏:‏2؛ أَسَا. 2‏:‏10. \x*
\v 10 مَاشَا غَارْ ؤُمزْوَارْ إِتّْخصَّا أَذْ إِتّْوَابَارّحْ س ڒخْبَارْ أَصبْحَانْ ذِي مَارَّا ڒڭْنُوسْ.
\v 11 خْمِي كنِّيوْ إِ غَا ڭوّْذنْ حِيمَا أَذْ كنِّيوْ سلّْمنْ، وَارْ كسِّيمْ س ومْنُوسْ قْبڒْ زِي مِينْ غَا ثِينِيمْ، وَارْ ذَايسْ ثْخَارِّيصمْ شَا، \add مَاشَا\add* مِينْ مَا ذ أَومْ إِ غَا إِمّوْشنْ ذِي ثْسَاعّثْ نِّي، سِيوْڒمْ زَّايسْ، مِينْزِي وَارْ ثدْجِيمْ ذ كنِّيوْ إِ إِسَّاوَاڒنْ، مَاشَا ذ أَرُّوحْ إِقدّْسنْ. \x ◘ \xo 13:‏11 \xt مت. 10‏:‏19؛ لك. 12‏:‏11؛ 21‏:‏4. \x*
\v 12 ؤُمَاسْ أَذْ إِسلّمْ ؤُمَاسْ مَاحنْذْ أَذْ \add ث\add* نْغنْ، ؤُ بَابَاسْ أَذْ إِسلّمْ مِّيسْ، ؤُشَا أَذْ ثكَّارْ ثَارْوَا خْ لْوَالِيذِينْ نّسْ ؤُشَا أَذْ ثنْ نْغنْ. \x ◘ \xo 13:‏12 \xt حِز. 38‏:‏21؛ مِيخَا 7‏:‏6. \x*
\v 13 أَذْ كنِّيوْ شَارْهنْ مَارَّا ذِي سِّيبّثْ ن يِيسمْ إِنُو، مَاشَا ونِّي إِ غَا إِصْبَارنْ أَڒْ أَنڭَّارْ، أَذْ إِتّْوَاسّنْجمْ. \x ◘ \xo 13:‏13 \xt مت. 10‏:‏22؛ 24‏:‏13؛ لك. 21‏:‏19؛ أَسَا. 2‏:‏7، 10. \x*
\m 
\v 14 خْمِي غَا ثْژَارمْ نّْعِي ن وَاريّبْ، مِينْ خفْ ثُوغَا إِسَّاوَاڒْ ؤُنَابِي ذَانِييَالْ، إِتّْبدَّا مَانِي وَارْ إِتّْخصَّا أَذْ إِبدّْ - ونِّي إِغْرِينْ أَذْ إِفْهمْ! - ڒخْذنِّي إِتّْخصَّا إِ يِينِّي إِدْجَانْ ذِي يَاهُوذِييَّا، أَذْ أَروْڒنْ غَارْ إِذُورَارْ، \x ◘ \xo 13:‏14 \xt دَان. 9‏:‏27؛ مت. 24‏:‏15؛ لك. 21‏:‏20، 21. \x*
\v 15 ؤُ ونِّي إِدْجَانْ خْ ثْزقَّا وَارْ د-إِهكّْوِي شَا غَارْ ثَادَّارْثْ ؤُ وَارْ إِتِّيذفْ شَا حِيمَا أَذْ إِكْسِي شَا زِي ثَادَّارْثْ نّسْ،
\v 16 ؤُ ونِّي إِدْجَانْ ذڭْ إِيَّارْ وَارْ د-إِتّْعِيقِّيبْ شَا حِيمَا أَذْ إِكْسِي أَسڒْهَامْ نّسْ.
\v 17 ؤُشْثْ خْ ثِينِّي إِدْجَانْ س دّيْسثْ ذ ثِينِّي إِسُّوطُوضنْ ذڭْ وُوسَّانْ نِّي!
\v 18 ژَتدْجمْ حِيمَا وَارْ ثتِّيڒِي ثَاروْڒَا نْومْ ذِي ڒْمشْثَا،
\v 19 مِينْزِي ذڭْ وُوسَّانْ نِّي أَذْ ذِينْ ثِيڒِي إِشْثْ ن ڒْمحْنثْ إِ وَارْ ثُوغِي أَمْ نتَّاثْ زڭْ وَامِي د-إِخْڒقْ أَربِّي دُّونشْثْ أَڒْ ڒخُّو، ؤُشَا وَارْ ثتِّيڒِيعمَّارْصْ عَاوذْ. \x ◘ \xo 13:‏19 \xt مت. 24‏:‏21\x*
\v 20 مَاڒَا سِيذِي وَارْ إِسّمْژِي ؤُسَّانْ نِّي، وَارْ ثْنجّمْ ؤُڒَا ذ إِشْثْ ن دَّاثْ، مَاشَا ذِي طّْوعْ ن يِينِّي إِتّْوَافَارْزنْ، إِنِّي إِ إِخْضَارْ نتَّا، أَقَا إِسّمْژِي ؤُسَّانْ نِّي.
\m 
\v 21 خنِّي مَاڒَا إِنَّا أَومْ إِجّنْ: ’أَقَا لْمَاسِيحْ ذَا!‘، نِيغْ: ’أَقَا-ث ذِيهَا!‘، وَارْ ث تَّامْنمْ. \x ◘ \xo 13:‏21 \xt مت. 24‏:‏23؛ لك. 21‏:‏8. \x*
\v 22 مِينْزِي أَذْ كَّارنْ إِمَاسِيحنْ إِفَالْسُوثنْ ذ إِنَابِييّنْ إِسّْخَارِّيقنْ، أَذْ ڭّنْ ڒعْڒَامَاثْ ذ ڒعْجَايبْ حِيمَا، مَاڒَا إِزمَّارْ، أَذْ خذْعنْ عَاذْ إِنِّي إِتّْوَافَارْزنْ. \x ◘ \xo 13:‏22 \xt أَعَوذ. 13‏:‏2؛ 2 تس. 2‏:‏11. \x*
\v 23 كنِّيوْ مَاشَا، حْضَامْ، أَقَا مَارَّا نِّيغْ أَومْ ث قْبڒْ.
\m 
\v 24 مَاشَا ذڭْ وُوسَّانْ نِّي، أَوَارْنِي ڒْمحْنثْ نِّي، أَذْ ثبَّارْشنْ ثْفُوشْثْ ؤُشَا ثَازِيرِي وَارْ ثتِّيشْ عَاذْ ثَافَاوْثْ نّسْ، \x ◘ \xo 13:‏24 \xt إِشا. 13‏:‏10؛ حِز. 32‏:‏7؛ يُووِ. 3‏:‏4؛ 3‏:‏15؛ مت. 24‏:‏29؛ لك. 21‏:‏25؛ أَسَا. 6‏:‏12. \x*
\v 25 إِثْرَانْ أَذْ د-وْضَانْ زڭْ ؤُجنَّا ؤُشَا صُّولَاطَاثْ إِ إِدْجَانْ ذڭْ إِجنْوَانْ أَذْ تّْوَانْهزّنْثْ. \x ◘ \xo 13:‏25 \xt إِشا. 13‏:‏10؛ 34‏:‏4. \x*
\v 26 خنِّي أَذْ ژَترنْ مِّيسْ ن بْنَاذمْ خْمِي د غَا يَاسْ ذڭْ إِسيْنُوثنْ، س جّهْذْ ذ ؤُعُودْجِي أَمقّْرَانْ. \x ◘ \xo 13:‏26 \xt دَان. 7‏:‏10؛ مت. 16‏:‏27؛ 24‏:‏30؛ مك. 14‏:‏62؛ لك. 21‏:‏27؛ ڒخ. 1‏:‏11؛ 1 تس. 4‏:‏16؛ 2 تس. 1‏:‏10؛ أَسَا. 1‏:‏7. \x*
\v 27 ڒخْذنِّي أَذْ إِسّكّْ لْمَالَاكَاثْ نّسْ ؤُشَا أَذْ إِيْرُو إِنِّي زَّايسْ إِتّْوَافَارْزنْ زِي أَربْعَا ن ثْغمُّورَا ن ؤُسمِّيضْ، زِي طَّارْفْ أَنڭَّارُو ن ثمُّورْثْ أَڒْ طَّارْفْ أَنڭَّارُو ن ؤُجنَّا. \x ◘ \xo 13:‏27 \xt أَعَوذ. 30‏:‏4، 5\x*
\m 
\v 28 ڒمْذمْ زڭْ وَارْثُو ن ثَازَارْثْ أَمتِّيڒْ-أَ: خْمِي غَا ذوْڒنْ ڒفْرُوعْ نّسْ أَذْ د-أَرضْبنْ ؤُشَا ثِيفْرَايْ أَذْ د-فّْغنْثْ، خنِّي أَذْ ثسّْنمْ أَقَا أَنبْذُو يِيوضْ-د. \x ◘ \xo 13:‏28 \xt مت. 24‏:‏32؛ لك. 21‏:‏29. \x*
\v 29 أَمُّو إِتّْخصَّا ؤُڒَا ذ كنِّيوْ، خْمِي غَا ثْژَارمْ ثِيمسْڒَايِينْ-أَ تّمْسَارَانْثْ، أَذْ ثسّْنمْ، أَقَا مَانْ أَيَا يُوذسْ-د، خْ ثوَّارْثْ.
\v 30 س ثِيذتّْ أَذْ أَومْ إِنِيغْ، جِّيڒْ-أَ وَارْ إِعدُّو شَا أَڒْ ذ غَا يِيڒِي مَانْ أَيَا مَارَّا.
\v 31 أَجنَّا ذ ثمُّورْثْ أَذْ عْذُونْ، \add مَاشَا\add* أَوَاڒنْ إِنُو وَارْعدُّونْعمَّارْصْ. \x ◘ \xo 13:‏31 \xt إِزهد. 102‏:‏27؛ إِشا. 40‏:‏8؛ 51‏:‏6؛ عبر. 1‏:‏11. \x*
\v 32 مَاشَا أَسّْ نِّي ذ ثْسَاعّثْ نِّي ؤُڒَا ذ إِجّْ وَارْ ث إِسِّينْ، ؤُڒَا ذ لْمَالَاكَاثْ نِّي إِدْجَانْ ذڭْ ؤُجنَّا، ؤُڒَا ذ مِّيسْ، مْغِيرْ بَابَاسْ. \x ◘ \xo 13:‏32 \xt مت. 24‏:‏36؛ ڒخ. 1‏:‏7. \x*
\m 
\v 33 \bd خْژَارمْ\bd*، حْضَامْ، ژَتدْجمْ، مِينْزِي وَارْ ثسِّينمْ شَا مڒْمِي د غَا ثَاوضْ ڒْوقْثْ نِّي. \x ◘ \xo 13:‏33 \xt مت. 24‏:‏42؛ 25‏:‏13؛ لك. 12‏:‏40؛ 21‏:‏36؛ 1 تس. 5‏:‏6. \x*
\v 34 أَقَا-ث أَمْ يِيجّْ ن بْنَاذمْ إِتّْخصَّا أَسْ أَذْ إِسَافَارْ، إِجَّا ثَادَّارْثْ نّسْ، إِوكّڒْ إِمْسخَّارنْ نّسْ س صُّولْطَا، إِوْشَا إِ كُوڒْ إِجّْ \add زَّايْسنْ\add* ڒْخذْمثْ نّسْ، ؤُشَا إِعْڒمْ أَسْ إِ ؤُعسَّاسْ ن ثوَّارْثْ مَاحنْذْ أَذْ إِقِّيمْ أَذْ إِحْضَا.
\v 35 إِوَا حْضَامْ خنِّي، مِينْزِي وَارْ ثسِّينمْ شَا مڒْمِي إِ د غَا يَاسْ بَابْ ن ثَادَّارْثْ، غَارْ ؤُعشِّي نِيغْ غَارْ وزْينْ ن دْجِيڒثْ نِيغْ غَارْ ؤُسْقُوقعْ ن ؤُيَاژِيضْ نِيغْ غَارْ صّْبحْ \add زِيشْ\add*،
\v 36 حِيمَا، مَاڒَا د-إِتِّيسْ ذغْيَا، وَارْ كنِّيوْ إِتِّيفْ ثتّطّْصمْ.
\v 37 مِينْ ذ أَومْ قَّارغْ ڒخُّو، قَّارغْ ث إِ مَارَّا: فَاقمْ!“
\b
\b
\c 14
\s1 ؤُذَاينْ أَرزُّونْ أَذْ نْغنْ يَاسُوع
\m 
\v 1 أَوَارْنِي إِ ثْنَاينْ ن وُوسَّانْ ثُوغَا ثدْجَا \add ثْغَارْصْثْ ن\add* ؤُسعْذُو ن \add ڒْْعِيذْ ن وغْرُومْ\add* بْڒَا أَنْثُونْ، ؤُ ثُوغَا إِمقّْرَاننْ ن إِكهَّاننْ ذ إِمْسڒْمَاذنْ ن إِذْلِيسنْ أَرزُّونْ إِشْثْ ن ثوَّارْثْ مَاحنْذْ أَذْ ث طّْفنْ س ثحْرَايْمشْثْ ؤُشَا أَذْ ث نْغنْ. \x ◘ \xo 14:‏1 \xt [مت. 26‏:‏1‏-‏5؛ لك. 22‏:‏1‏-‏2؛ يُوح. 11‏:‏45‏-‏53] — مت. 26‏:‏2؛ لك. 22‏:‏1؛ يُوح. 11‏:‏55؛ 13‏:‏1. \x*
\v 2 مَاشَا نِيثْنِي نَّانْ: ”وَارْ إِتِّيڒِي ذِي ڒْعِيذْ، حِيمَا وَارْ إِتِّيڒِي ؤُغوُّوغْ ذِي ڒْڭنْسْ.“
\b
\s1 أَذْهَانْ ن يَاسُوع ذِي بَايْثْ-عَانْيَا
\m 
\v 3 ڒَامِي ثُوغَا إِقِّيمْ \add غَارْ طَّابْڒَا\add* ذِي بَايْثْ-عَانْيَا ذِي ثَادَّارْثْ ن شِيمْعُونْ، ونِّي ذِي إِدْجَا ڒْبَارْصْ، ثُوسَا-د إِشْثْ ن ثمْغَارْثْ، أَقَا-ت غَارسْ إِجّْ ن ؤُغَارَّافْ ن أَلَابَاسْثرْ ذَايسْ زّشْثْ إِ وذْهَانْ زِي ڒعْطُورْ ن صّنْبلْ ثصْبحْ، ثِيغْڒَا. ثَارْزمْ ثَازِييَّاثْ نِّي، ثْفَارّغْ إِ-ت خْ ؤُزدْجِيفْ ن يَاسُوع. \x ◘ \xo 14:‏3 \xt [مت. 26‏:‏6‏-‏13؛ يُوح. 12‏:‏1‏-‏8] \x*
\v 4 ثُوغَا ذِينْ شَا ن إِمحْضَارنْ، خيّْقنْ أَطَّاسْ ذڭْ إِخفْ نْسنْ خْ مَانْ أَيَا، نَّانْ: ”مَايمِّي أَضيّعْ ن زّشْثْ-أَ إِ وذْهَانْ؟
\v 5 مِينْزِي إِڒِي أَذْ ثتّْوَامّنْزْ \add زّشْثْْ-أَ\add* س كْثَارْ زِي ثڒْثْ-مْيَا ذِينَارْ ؤُشَا خنِّي أَذْ إِمّوْشْ إِ إِمزْڒَاضْ.“ ؤُشَا خيّْقنْ خَاسْ أَطَّاسْ.
\v 6 مَاشَا يَاسُوع إِنَّا: ”جّمْ ت! مَايمِّي خَاسْ ثتّْعدَّامْ؟ أَقَا ثڭَّا ذَايِي إِجّْ ن شْغڒْ إِشْنَا.
\v 7 مِينْزِي إِمزْڒَاضْ أَقَا أَثنْ ڒبْذَا أَكِيذْومْ، ثْزمَّارمْ أَذْ كِيسنْ ثڭّمْ ڒْخَارْ مڒْمِي مَا ثخْسمْ، مَاشَا نشّْ وَارْ كِيذْومْ تّْغِيمِيغْ ڒبْذَا. \x ◘ \xo 14:‏7 \xt أَعَوذ. 15‏:‏11. \x*
\v 8 نتَّاثْ ثڭَّا مِينْ ؤُمِي ثْزمَّارْ. أَقَا ثِيزَّارْ ثمْسحْ أَرِّيمثْ إِنُو س ڒعْطُورْ إِ ونْضڒْ.
\v 9 س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ: مَانِي مَا إِ غَا إِتّْوَابَارّحْ س ڒخْبَارْ-أَ أَصبْحَانْ زَّايِي ذِي مَارَّا دُّونشْثْ، أَذْ خبَّارنْ عَاوذْ خْ مِينْ ثڭَّا، ذ ڒِيذَارثْ إِ نتَّاثْ.“
\b
\s1 يَاهُوذَا إِزّنْزْ إِخفْ نّسْ مَاحنْذْ أَذْ إِسلّمْ يَاسُوع
\m 
\v 10 \add خنِّي\add* إِرُوحْ يَاهُوذَا إِسْخَارِييُوطِي، إِجّنْ زِي ثنْعَاشْ، غَارْ إِمقّْرَاننْ ن إِكهَّاننْ حِيمَا أَذْ أَسنْ إِسلّمْ يَاسُوع. \x ◘ \xo 14:‏10 \xt [مت. 26‏:‏14‏-‏16؛ لك. 22‏:‏3‏-‏6] — مت. 26‏:‏14؛ لك. 22‏:‏4. \x*
\v 11 ؤُمِي سْڒِينْ مَانْ أَيَا، فَارْحنْ ؤُشَا وَاعْذنْ أَذْ أَسْ وْشنْ \add ثْمنْيَاثْ ن\add* نُّوقَارْثْ. ؤُ نتَّا ثُوغَا يَارزُّو إِشْثْ ن ثوَّارْثْ، حِيمَا أَذْ \add أَسنْ\add* ث إِسلّمْ.
\b
\s1 أَسوْجذْ ن أَمنْسِي ن ؤُسعْذُو
\m 
\v 12 ذڭْ وَاسّْ أَمزْوَارْ ن \add وغْرُومْ\add* بْڒَا أَنْثُونْ، ؤُمِي تّْنُومَانْ وُوذَاينْ أَذْ غَارْصنْ إِ \add ثْغَارْصْثْ ن\add* ؤُسعْذُو، نَّانْ أَسْ إِمحْضَارنْ نّسْ: ”مَانِي ثخْسذْ أَذْ نْرَاحْ حِيمَا أَذْ نسّوْجذْ مَاحنْذْ أَذْ ثشّذْ \add أَمنْسِي ن\add* ؤُسعْذُو؟“ \x ◘ \xo 14:‏12 \xt [مت. 26‏:‏17‏-‏25؛ لك. 22‏:‏7‏-‏14، 21‏-‏23؛ يُوح. 13‏:‏21‏-‏30] — ؤُف. 12‏:‏17؛ مت. 26‏:‏17؛ لك. 22‏:‏7. \x*
\v 13 إِسّكّْ ثْنَاينْ زڭْ إِمحْضَارنْ نّسْ، إِنَّا أَسنْ: ”رُوحمْ غَارْ ثنْذِينْثْ، ؤُ خْزَارْ، أَذْ ثمْسَاڭَارمْ أَكْ-ذ إِجّْ ن ورْيَازْ، يَارْبُو إِشْثْ ن ثقْبُوشْثْ ن وَامَانْ. ضْفَارمْ ث!
\v 14 ؤُ مَانِي غَا يَاذفْ، إِنِيمْ إِ بَابْ ن ثَادَّارْثْ: ’أَمْسڒْمَاذْ نّغْ إِقَّارْ: مَانِي ثدْجَا ثْغُورْفثْ حِيمَا أَذْ شّغْ \add أَمنْسِي ن\add* ؤُسعْذُو أَكْ-ذ إِمحْضَارنْ إِنُو؟‘
\v 15 \add خنِّي\add* نتَّا أَذْ أَومْ إِمّڒْ إِجّْ ن أَرْوَا إِمْغَارْ سنّجْ، إِسُّو، إِعْذڒْ. ذِينِّي إِ ذ أَنغْ غَا ثسّْوجْذمْ.“
\v 16 فّْغنْ إِمحْضَارنْ، ؤُسِينْ-د غَارْ ثنْذِينْثْ ؤُشَا ؤُفِينْ \add مَارَّا\add* أَمْ مَامّشْ ثُوغَا ذ أَسنْ إِنَّا، خنِّي سّْوجْذنْ إِ \add ؤُمنْسِي ن\add* ؤُسعْذُو.
\b
\m 
\v 17 غَارْ ؤُعشِّي يُوسَا-د أَكْ-ذ ثنْعَاشْ \add ن رُّوسُولْ\add* نّسْ. \x ◘ \xo 14:‏17 \xt مت. 26‏:‏20؛ لك. 22‏:‏14. \x*
\v 18 ڒَامِي ثُوغَا قِّيمنْ \add غَارْ طَّابْڒَا\add*، تّتّنْ، إِنَّا يَاسُوع: ”س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ، أَقَا إِجّنْ زَّايْومْ ونِّي كِيذِي إِتّتّنْ، أَذْ أَيِي إِغْذَارْ!“ \x ◘ \xo 14:‏18 \xt إِزهد. 41‏:‏10؛ ڒخ. 1‏:‏17. \x*
\v 19 بْذَانْ تّشْضِيننْ، نَّانْ أَسْ إِجّنْ أَوَارْنِي ونّغْنِي: ”مَا ذ نشّْ؟“
\v 20 إِنَّا أَسنْ: ”\add أَقَا-ث\add* ذ إِجّنْ زِي ثنْعَاشْ إِ إِسِّيسْننْ أَكِيذِي أَغْرُومْ ذِي طّبْصِي.
\v 21 أَقَا مِّيسْ ن بْنَاذمْ أَذْ إِرَاحْ مَامّشْ ذ أَسْ ثُورَا. مَاشَا ؤُشْثْ خْ ورْيَازْ نِّي زِي غَا إِتّْوَاغْذَارْ مِّيسْ ن بْنَاذمْ. إِحْڒَا أَسْ إِ ورْيَازْ نِّي مْڒِي وَارْ د-إِخْڒِيقْ.“
\b
\s1 أَمنْسِي ن سِيذِيثْنغْ
\m 
\v 22 ڒَامِي ثُوغَا تّتّنْ، إِكْسِي يَاسُوع أَغْرُومْ، إِبَاركْ إِ-ث، يَارْژَا إِ-ث ؤُشَا إِوْشَا أَسنْ ث، إِنَّا: ”كْسِيمْ، شّمْ، أَقَا ثَا ذ أَرِّيمثْ إِنُو.“ \x ◘ \xo 14:‏22 \xt [مت. 26‏:‏26‏-‏30؛ لك. 22‏:‏15‏-‏20؛ 1 كُور. 11‏:‏23‏-‏25] — إِرْم. 16‏:‏7 \x*
\v 23 خنِّي إِكْسِي ڒْكَاسْ، إِقَاذَا، إِبَاركْ، ؤُشَا إِوْشَا أَسنْ ث، ؤُ مَارَّا إِذْسنْ سْوِينْ زَّايسْ.
\v 24 إِنَّا أَسنْ: ”أَقَا إِنَا ذ إِذَامّنْ إِنُو ن ڒْعَاهْذْ ن جْذِيذْ إِ غَا إِتّْوَاسِّيزْڒنْ إِ وَاطَّاسْ \add ن إِوْذَانْ\add*. \x ◘ \xo 14:‏24 \xt إِرْم. 31‏:‏31؛ مت. 26‏:‏28، مك. 14‏:‏24، لك. 22‏:‏20، 1 كُور. 11‏:‏25، 2 كُور. 3‏:‏6، عبر. 8‏:‏6، 8، 13؛ 9‏:‏15؛ 12‏:‏24\x*
\v 25 س ثِيذتّْ، نشّْ أَذْ أَومْ إِنِيغْ، نشّْ وَارْ سسّغْعمَّارْصْ عَاذْ زِي ڒْغِيدْجثْ ن ثْزَايَارْثْ أَڒْ أَسّْ إِ ذِي إِ ت غَا سْوغْ جْذِيذْ ذِي ثْڭلْذِيثْ ن أَربِّي.“
\v 26 أَوَارْنِي ڒَامِيغنّْجنْ نِيثْنِي إِژْڒِي ن تّسْبِيحْ، فّْغنْ غَارْ وذْرَارْ ن زِّيثُونْ.
\b
\s1 يَاسُوع إِزْوَارْ إِسِّيوڒْ خْ ونْكَارْ ن بُوطْرُوسْ
\m 
\v 27 إِنَّا أَسنْ يَاسُوع: ”أَقَا مَارَّا كنِّيوْ أَذْ ذَايِي ثنْذرْفمْ ذِي دْجِيڒثْ-أَ، مِينْزِي ثُورَا:
\b
\m \qt ’أَقَا أَذْ وْثغْ أَمكْسَاوْ\qt*
\m \qt ؤُشَا أَذْ تّْوَازُوزَّارنْ إِحُوڒِييّنْ.‘\qt* \x ◘ \xo 14:‏27 \xt [مت. 26‏:‏31‏-‏35؛ لك. 22‏:‏31‏-‏34؛ يُوح. 13‏:‏36‏-‏38] — زَاك. 13‏:‏7؛ مت. 26‏:‏31؛ يُوح. 16‏:‏32. \x*
\b
\m 
\v 28 مَاشَا أَوَارْنِي ڒَامِي تّْوَاسّْنكَّارغْ، أَذْ أَومْ إِزْوَارغْ غَارْ لْجَالِيلْ.“ \x ◘ \xo 14:‏28 \xt مت. 26‏:‏32؛ 28‏:‏10؛ مك. 16‏:‏7. \x*
\m 
\v 29 إِنَّا أَسْ بُوطْرُوسْ: ”وَاخَّا أَذْ \add ذَايكْ\add* نْذرْفنْ مَارَّا، نشّْ وَارْ ذَايكْ تّْنذْرِيفغْ شَا.“
\v 30 إِنَّا أَسْ يَاسُوع: ”س ثِيذتّْ، نشّْ أَذْ أَشْ إِنِيغْ، أَقَا أَسّْ-أَ ذِي دْجِيڒثْ-أَ، قْبڒْ إِ غَا إِسّْقُوقعْ ؤُيَاژِيضْ ثْنَاينْ ن ثْوَاڒَاوِينْ، أَذْ أَيِي ثنْكَارذْ ثْڒَاثَا ن ثْوَاڒَاوِينْ.“ \x ◘ \xo 14:‏30 \xt مت. 26‏:‏34؛ لك. 22‏:‏34؛ يُوح. 13‏:‏38. \x*
\v 31 مَاشَا نتَّا ثُوغَا إِقَّارْ س ثْمِيجَّا إِجهْذنْ عَاذْ أَطَّاسْ: ”مَاڒَا إِتّْخصَّا أَذْ مّْثغْ أَكِيذكْ، وَارْ شكْ نكَّارغْ، \add أَ\add* سِيذِي إِنُو!“ ؤُشَا أَمْ نتَّا، أَمُّو إِ نَّانْ ؤُڒَا ذ نِيثْنِي مَارَّا. \x ◘ \xo 14:‏31 \xt يُوح. 13‏:‏37. \x*
\b
\s1 ثَاژَادْجِيثْ ن يَاسُوع ذِي خِيثْسِيمَانِييْ
\m 
\v 32 ؤُسِينْ-د غَارْ ومْشَانْ ؤُمِي قَّارنْ ’خِيثْسِيمَانِييْ‘. إِنَّا إِ إِمحْضَارنْ نّسْ: ”قِّيممْ ذَا، أَڒَامِي ژُودْجغْ نشّْ“ \x ◘ \xo 14:‏32 \xt [مت. 26‏:‏36‏-‏46؛ لك. 22‏:‏39‏-‏46] — مت. 26‏:‏36؛ لك. 22‏:‏39؛ يُوح. 18‏:‏1. \x*
\v 33 \add خنِّي\add* إِكْسِي أَكِيذسْ بُوطْرُوسْ ذ يَاعْقُوبْ ذ يُوحَانَّا ؤُشَا إِبْذَا إِتّْنخْڒَاعْ، إِڭّْوذْ أَطَّاسْ.
\v 34 إِنَّا أَسنْ: ”أَقَا ڒعْمَارْ إِنُو إِشْضنْ أَڒْ ڒْموْثْ. قِّيممْ ذَا، ثحْضَامْ!“ \x ◘ \xo 14:‏34 \xt يُوح. 12‏:‏27. \x*
\v 35 يُويُورْ شْوَايْثْ غَارْ زَّاثْ ؤُشَا إِوْضَا غَارْ ثمُّورْثْ، إِژُّودْجْ حِيمَا، مَاڒَا إِعدّڒْ، أَذْ خَاسْ ثعْذُو ثْسَاعّثْ نِّي. \x ◘ \xo 14:‏35 \xt مت. 26‏:‏39؛ لك. 22‏:‏42\x*
\v 36 إِنَّا: ”بَابَا، بَابَا إِنُو، كُوڒْشِي ثْزمَّارذْ خَاسْ! كْسِي خَافِي ڒْكَاسْ-أَ، مَاشَا وَارْ إِتِّيڒِي مِينْ خْسغْ نشّْ، مَاشَا مِينْ ثخْسذْ شكْ.“ \x ◘ \xo 14:‏36 \xt يُوح. 6‏:‏38. \x*
\m 
\v 37 ؤُشَا إِذْوڒْ-د، يُوفَا إِ-ثنْ طّْصنْ. إِنَّا أَسْ إِ بُوطْرُوسْ: ”أَ شِيمْعُونْ، مَا أَقَا شكْ ثتّطّْصذْ؟ مَا وَارْ ثْزمَّارذْ أَذْ ثحْضِيذْ ؤُڒَا ذ إِشْثْ ن ثْسَاعّثْ؟ \x ◘ \xo 14:‏37 \xt مت. 26‏:‏40؛ لك. 22‏:‏45. \x*
\v 38 حْضَامْ، ژَتدْجمْ، حِيمَا وَارْ ثتِّيذْفمْ ذڭْ ؤُجَارّبْ. أَرُّوحْ أَقَا إِوْجذْ، مَاشَا دَّاثْ أَقَا ثضْعفْ.“ \x ◘ \xo 14:‏38 \xt ڭال. 5‏:‏17. \x*
\v 39 ؤُشَا يُويُورْ عَاوذْ، إِژُّودْجْ، إِعَاوذْ إِ وَاوَاڒنْ نِّي ذ إِجّنْ.
\m 
\v 40 إِذْوڒْ-د عَاوذْ، يُوسَا-د \add غَارْسنْ\add* ثْوَاڒَا نّغْنِي يُوفَا إِ-ثنْ طّْصنْ، مَاغَارْ ثُوغَا ثِيطَّاوِينْ نْسنْ ذقْڒنْثْ ؤُ نِيثْنِي وَارْ سِّيننْ مَامّشْ خَاسْ د غَا يَارّنْ.
\v 41 ؤُشَا إِذْوڒْ-د نتَّا غَارْسنْ ثْوَاڒَا وِيسّْ ثْڒَاثَا، إِنَّا أَسنْ: ”طّْصمْ ڒخُّو، ثَاريّْحمْ! أَقَا يُوذسْ-د ؤُنڭَّارْ، ثِيوضْ-د ثْسَاعّثْ. خْزَارمْ، مِّيسْ ن بْنَاذمْ أَذْ إِمّوْشْ ذڭْ إِفَاسّنْ ن إِمذْنَابْ.
\v 42 كَّارمْ، أَذْ نْرَاحْ. خْزَارمْ، أَقَا ذَا ونِّي ذ أَيِي غَا إِسلّْمنْ، أَقَا يُوذسْ-د.“
\b
\s1 أَحبّسْ ن يَاسُوع
\m 
\v 43 أَمْ ثُوغَا \add عَاذْ\add* إِسَّاوَاڒْ، يُوسَا-د يَاهُوذَا، إِجّنْ زِي ثنْعَاشْ. ثُوغَا أَكِيذسْ إِرْيَازنْ أَطَّاسْ س ڒسْيُوفْ ذ إِعُومَاذْ. ؤُسِينْ-د نِيثْنِي زڭْ إِمقّْرَاننْ ن إِكهَّاننْ ذ إِمْسڒْمَاذنْ ن إِذْلِيسنْ ذ إِمْغَارنْ \add ن ڒْڭنْسْ\add*. \x ◘ \xo 14:‏43 \xt [مت. 26‏:‏47‏-‏56؛ لك. 22‏:‏47‏-‏53؛ يُوح. 18‏:‏3‏-‏12] — مت. 26‏:‏47؛ لك. 22‏:‏47؛ يُوح. 18‏:‏3. \x*
\v 44 ؤُشَا ونِّي ث إِ غَا إِغْذَارنْ ثُوغَا إِتّڭّْ أَسنْ إِشْثْ ن ڒعْڒَامثْ، إِقَّارْ: ”ونِّي إِ غَا سُّوذْمغْ ذ ونِّي نتَّا. طّْفمْ ث ؤُشَا أَوْيمْ ث-إِ-د.“
\v 45 ذغْيَا يُويُورْ غَارسْ، إِنَّا: ”\add أَ\add* أَمْسڒْمَاذْ إِنُو، \add أَ\add* أَمْسڒْمَاذْ إِنُو!“، ؤُشَا إِسُّوذمْ إِ-ث. \x ◘ \xo 14:‏45 \xt 2 صم. 20‏:‏9. \x*
\v 46 سَّارْسنْ خَاسْ إِفَاسّنْ ؤُشَا طّْفنْ ث.
\v 47 إِجّنْ زڭْ إِنِّي ذِينْ إِبدّنْ إِجْبذْ سِّيفْ \add نّسْ\add*، إِوْثَا أَمْسخَّارْ ن أَرَّايْسْ ن إِكهَّاننْ، إِقسّْ أَسْ أَمزُّوغْ.
\v 48 يَارَّا-د يَاسُوع، إِنَّا أَسنْ: ”مَا أَخْمِي خْ يِيجّْ ن ؤُقْطَاطْعِييْ إِ ثفّْغمْ خَافِي س ڒسْيُوفْ ذ إِعُومَاذْ، حِيمَا أَذْ أَيِي ثطّْفمْ؟
\v 49 كُوڒْ أَسّْ ثُوغَا أَيِي أَكِيذْومْ ذِي زَّاوشْثْ ثَامقّْرَانْثْ سّڒْمَاذغْ، وَارْ ذ أَيِي ثطِّيفمْ. مَاشَا مَانْ أَيَا إِمْسَارْ، حِيمَا أَذْ تّْوَاكمّْڒنْثْ ثِيرَا \add إِقدّْسنْ\add*.“ \x ◘ \xo 14:‏49 \xt إِزهد. 22‏:‏7؛ 69‏:‏10؛ لك. 24‏:‏25. \x*
\v 50 \add خنِّي\add* جِّينْ ث إِمحْضَارنْ نّسْ ؤُشَا أَروْڒنْ. \x ◘ \xo 14:‏50 \xt أَيُوبْ 19‏:‏13؛ إِزهد. 88‏:‏9. \x*
\v 51 إِضْفَارْ إِ-ث إِجّْ ن ؤُعزْرِي، ثُوغَا يَارْضْ إِشْثْ ن ثشْضَاضْثْ \add نْ ڒقْطنْ وَاهَا\add* خْ ثْقذِّيثْ نّسْ، ؤُشَا طّْفنْ ث-إِ-د.
\v 52 مَاشَا نتَّا إِجَّا ثَاشْضَاضْثْ ؤُشَا يَارْوڒْ زَّايْسنْ ذ أَعَارْيَانْ.
\b
\s1 يَاسُوع زَّاثْ إِ جْمَاعثْ ثَامقّْرَانْثْ ن وُوذَاينْ
\m 
\v 53 إِوْينْ يَاسُوع غَارْ قَايَافَا، أَرَّايْسْ ن إِكهَّاننْ، ؤُشَا مُوننْ-د غَارسْ مَارَّا إِمقّْرَاننْ ن إِكهَّاننْ ذ إِمْغَارنْ \add ن ڒْڭنْسْ\add* ذ إِمْسڒْمَاذنْ ن إِذْلِيسنْ. \x ◘ \xo 14:‏53 \xt [مت. 26‏:‏57‏-‏68؛ لك. 22‏:‏54‏-‏55، 63‏-‏71؛ يُوح. 18‏:‏13‏-‏14، 19‏-‏24] — مت. 26‏:‏57؛ لك. 22‏:‏54؛ يُوح. 18‏:‏13، 24. \x*
\v 54 ثُوغَا شِيمْعُونْ إِضْفَارْ إِ-ث-إِ-د زِي ڒَاڭّْوَاجْ، غَارْ ذَاخڒْ ن ڒمْرَاحْ ن أَرَّايْسْ ن إِكهَّاننْ، ؤُشَا ثُوغَا إِقِّيمْ جَارْ إِعسَّاسنْ، إِتّْوقَّاحْ إِخفْ نّسْ غَارْ ثْمسِّي.
\v 55 ثُوغَا إِمقّْرَاننْ ن إِكهَّاننْ ذ مَارَّا جْمَاعثْ \add ثَامقّْرَانْثْ\add* أَرزُّونْ شّْهَاذثْ ضِيدّْ إِ يَاسُوع حِيمَا أَذْ ث نْغنْ، مَاشَا وَارْ ت ؤُفِينْ، \f ◼ \fr 14:‏55 \fk جْمَاعثْ \bdit ثَامقّْرَانْثْ\bdit*‘ - نِيغْ: ’جْمَاعثْ ن ڒْحُوكَّامْ إِمقّْرَاننْ ن وُوذَاينْ‘.\f*  \x ◘ \xo 14:‏55 \xt مت. 26‏:‏59؛ ڒخ. 6‏:‏13. \x*
\v 56 مِينْزِي أَطَّاسْ ثُوغَا خَاسْ شهّْذنْ س ژُورْ، \add مَاشَا\add* شّْهَاذَاثْ نْسنْ وَارْ تّْمڒْقِينْثْ.
\m 
\v 57 \add خنِّي\add* كَّارنْ شَا ؤُشَا شهْذنْ خَاسْ س ژُورْ، نَّانْ:
\v 58 ”نشِّينْ نسْڒَا أَسْ ؤُمِي إِنَّا: ’أَذْ هذْمغْ زَّاوشْثْ ثَامقّْرَانْثْ إِ إِتّْوَاڭّنْ س إِفَاسّنْ ؤُشَا ذِي ثْڒَاثَا ن وُوسَّانْ أَذْ بْنِيغْ إِشْثنْ نّغْنِيثْ إِ وَارْ إِتّْوَاڭّنْ س إِفَاسّنْ.‘ “ \x ◘ \xo 14:‏58 \xt مك. 15‏:‏29؛ يُوح. 2‏:‏19. \x*
\v 59 \add مَاشَا\add* ؤُڒَا أَمُّو وَارْ تّْمڒْقِينْثْ شَا شّْهَاذَاثْ نْسنْ.
\m 
\v 60 خنِّي إِكَّارْ أَرَّايْسْ ن إِكهَّاننْ ذِي ڒْوسْطْ \add نْسنْ\add* ؤُشَا إِسّقْسَا يَاسُوع، إِنَّا \add أَسْ\add*: ”مَا وَارْ د-ثَارِّيذْ س شَا؟ مِينْ خَاكْ شهّْذنْ يِينَا؟“ \x ◘ \xo 14:‏60 \xt مت. 26‏:‏62. \x*
\v 61 مَاشَا نتَّا إِسْقَارْ، وَارْ د-يَارِّي س شَا. إِسّقْسَا ث أَرَّايْسْ ن إِكهَّاننْ عَاوذْ، إِنَّا أَسْ: ”مَا شكْ ذ لْمَاسِيحْ، مِّيسْ ن لْمُوبَاركْ؟“ \x ◘ \xo 14:‏61 \xt إِشا. 53‏:‏7؛ ڒخ. 8‏:‏32. \x*
\v 62 إِنَّا أَسْ يَاسُوع: ”أَقَا ذ نشّْ! ؤُ كنِّيوْ أَذْ ثْژَارمْ مِّيسْ ن بْنَاذمْ إِتّْغِيمَا خْ ؤُفُوسِي ن جّهْذْ، أَذْ د-يَاسْ س إِسيْنُوثنْ ن ؤُجنَّا.“ \x ◘ \xo 14:‏62 \xt دَان. 7‏:‏13؛ إِزهد. 110‏:‏1؛ مت. 16‏:‏27؛ 24‏:‏30؛ 25‏:‏31؛ لك. 21‏:‏27؛ ڒخ. 1‏:‏11؛ 1 تس. 4‏:‏16؛ 2 تس. 1‏:‏10؛ أَسَا. 1‏:‏7. \x*
\v 63 إِشَارّڭْ أَرَّايْسْ ن إِكهَّاننْ ثْشَامِيرْ نّسْ، إِنَّا: ”مَايمِّي نحْذَاجْ عَاذْ ڒشْهُوذْ!
\v 64 أَقَا ثسْڒِيمْ أَشقّفْ \add نِّي\add*! مِينْ د أَومْ إِضْهَارنْ؟“ ؤُشَا مَارَّا حكْمنْ خَاسْ بلِّي إِسْذَاهدْجْ ڒْموْثْ.
\v 65 شَا \add زَّايْسنْ\add* بْذَانْ سُّوسُوفنْ خَاسْ، تّْڒحَّافنْ إِ ؤُغمْبُوبْ نّسْ، شَّاثنْ ث س ڒْپُونِييَّاثْ، قَّارنْ أَسْ: ”نَابّْ!“ ؤُشَا وْثِينْ ث إِعسَّاسنْ خْ ؤُقَابْسِي نّسْ. \x ◘ \xo 14:‏65 \xt أَيُوبْ 16‏:‏10؛ إِشا. 50‏:‏6؛ يُوح. 19‏:‏3. \x*
\b
\s1 أَنْكَارْ ن بُوطْرُوسْ
\m 
\v 66 ڒَامِي ثُوغَا شِيمْعُونْ ذِي ڒمْرَاحْ سْوَادَّايْ، ثُوسَا-د \add ذِينْ\add* إِشْثنْ زِي ثِييَّا ن أَرَّايْسْ ن إِكهَّاننْ. \x ◘ \xo 14:‏66 \xt [مت. 26‏:‏69‏-‏75؛ لك. 22‏:‏56‏-‏62؛ يُوح. 18‏:‏15‏-‏18، 25‏-‏27] — مت. 26‏:‏58، 69؛ لك. 22‏:‏55؛ يُوح. 18‏:‏16، 17. \x*
\v 67 ؤُمِي ث ثژْرَا إِتّْوقَّاحْ، ثخْزَارْ ذَايسْ، ثنَّا: ”أَقَا ثُوغَا شكْ أَكْ-ذ يَاسُوع نَّاصِيرِي.“
\v 68 مَاشَا نتَّا إِنْكَارْ، إِنَّا: ”وَارْ \add ث\add* سِّينغْ، وَارْ فْهِيمغْ مِينْ ثقَّارذْ.“ إِفّغْ بَارَّا غَارْ ثسْقِيفْثْ ن ثوَّارْثْ، ؤُشَا ڒخْذنِّي إِسّْقُوقعْ ؤُيَاژِيضْ.
\v 69 ؤُمِي ث ثژْرَا ثَايَّا إِجّْ ن ؤُمُورْ نّغْنِي، ثبْذَا ثقَّارْ إِ يِينِّي ذِينْ إِبدّنْ: ”أَقَا وَا ذ إِجّنْ زَّايْسنْ!“ \x ◘ \xo 14:‏69 \xt مت. 26‏:‏71؛ لك. 22‏:‏58؛ يُوح. 18‏:‏25. \x*
\v 70 مَاشَا نتَّا إِنْكَارْ إِ ؤُمُورْ نّغْنِي. شْوَايْثْ خنِّي نَّانْ إِنِّي ثُوغَا ذِينْ إِبدّنْ إِ بُوطْرُوسْ: ”س ثِيذتّْ، شكْ زَّايْسنْ نِيشَانْ، مِينْزِي شكْ عَاوذْ ذ أَجَالِيلِي. ڒْحَارْضْ نّشْ أَمْ ونِّي نْسنْ.“
\v 71 إِبْذَا إِنعّڒْ إِخفْ نّسْ، إِتّْجَّادْجْ: ”وَارْ سِّينغْ بْنَاذمْ-أَ مِيخفْ ثسَّاوَاڒمْ.“
\v 72 ڒخْذنِّي إِسّْقُوقعْ ؤُيَاژِيضْ وِيسّْ مَارْثَاينْ. إِفكَّارْ شِيمْعُونْ ذڭْ وَاوَاڒْ إِ إِنَّا يَاسُوع: ”قْبڒْ إِ غَا إِسّْقُوقعْ ؤُيَاژِيضْ وِيسّْ مَارْثَاينْ، أَذْ أَيِي ثنْكَارذْ ثْڒَاثَا ن ثْوَاڒَاوِينْ.“ خنِّي إِبْذَا إِتّْرُو \add أَطَّاسْ\add*. \x ◘ \xo 14:‏72 \xt مت. 26‏:‏34، 75؛ لك. 22‏:‏61؛ يُوح. 13‏:‏38؛ 18‏:‏27. \x*
\b
\b
\c 15
\s1 يَاسُوع زَّاثْ إِ لْوَالِي بِيلَاطُوسْ
\m 
\v 1 ذغْيَا غَارْ صّْبحْ زِيشْ مْشَاوَارنْ إِمقّْرَاننْ ن إِكهَّاننْ أَكْ-ذ إِمْغَارنْ \add ن ڒْڭنْسْ\add* ذ إِمْسڒْمَاذنْ ن إِذْلِيسنْ ذ مَارَّا جْمَاعثْ \add ثَامقّْرَانْثْ\add*. نِيثْنِي شَارْفنْ يَاسُوع، إِوْينْ ث ؤُشَا سلّْمنْ ث إِ بِيلَاطُوسْ. \x ◘ \xo 15:‏1 \xt [مت. 27‏:‏1‏-‏2، 11‏-‏14؛ لك. 23‏:‏1‏-‏5؛ يُوح. 18‏:‏28‏-‏38] — إِزهد. 2‏:‏2؛ مت. 27‏:‏1؛ لك. 22‏:‏66؛ 23‏:‏1؛ يُوح. 18‏:‏28؛ ڒخ. 3‏:‏13. \x*
\v 2 إِسّقْسَا إِ-ث بِيلَاطُوسْ: ”مَا شكْ ذ أَجدْجِيذْ ن وُوذَاينْ؟“ يَارَّا-د خَاسْ، إِنَّا أَسْ: ”شكْ ثنِّيذْ \add ث\add*.“ \x ◘ \xo 15:‏2 \xt مت. 27‏:‏11؛ لك. 23‏:‏3؛ يُوح. 18‏:‏33. \x*
\v 3 ثُوغَا إِمقّْرَاننْ ن إِكهَّاننْ تّْشثْشَانْ زَّايسْ زڭْ وَاطَّاسْ ن ثْمسْڒَايِينْ.
\v 4 إِسّقْسَا ث بِيلَاطُوسْ عَاوذْ، إِنَّا أَسْ: ”مَا وَارْ د-ثتَّارِيذْ س شَا؟ خْزَارْ، أَطَّاسْ ن يِينِّي خَاكْ إِتّْشثْشَانْ!“ \x ◘ \xo 15:‏4 \xt مت. 27‏:‏13؛ يُوح. 19‏:‏10. \x*
\v 5 وَارْ د-يَارِّي يَاسُوع س وَالُو، أَڒَامِي إِثبْهثْ بِيلَاطُوسْ. \x ◘ \xo 15:‏5 \xt إِشا. 53‏:‏7\x*
\b
\s1 يَاسُوع ذ بَارْ-أَبَّاسْ
\m 
\v 6 إِنُّومْ إِضدْجقْ إِ إِجّْ ن ؤُمحْبُوسْ ذِي كُوڒْ ڒْعِيذْ، ونِّي إِخْسنْ نِيثْنِي. \x ◘ \xo 15:‏6 \xt [مت. 27‏:‏15‏-‏31؛ لك. 23‏:‏13‏-‏25؛ يُوح. 18‏:‏39‏-‏19.16] — مت. 27‏:‏15؛ لك. 23‏:‏17؛ يُوح. 18‏:‏39. \x*
\v 7 ثُوغَا ذِينْ إِجّنْ ؤُمِي قَّارنْ بَارْ-أَبَّاسْ، حبّْسنْ ث أَكْ-ذ إِمْغوّْغنْ، إِنِّي إِنْغِينْ إِجّنْ ذڭْ ؤُغوّغْ. \f ◼ \fr 15:‏7 \ft \bd ’أَغوّغْ‘\bd* - نِيغْ ’ڒْْفَاوْضَا‘.\f*  \x ◘ \xo 15:‏7 \xt مت. 27‏:‏16؛ لك. 23‏:‏19؛ يُوح. 18‏:‏40. \x*
\v 8 إِسْغُويّْ ڒْغَاشِي ؤُشَا نِيثْنِي بْذَانْ تّتَّارّنْ زَّايسْ حِيمَا أَذْ إِڭّْ أَمْ مَامّشْ ثُوغَا إِنُّومْ إِتّڭّْ إِ نِيثْنِي.
\v 9 يَارَّا-د بِيلَاطُوسْ، إِنَّا: ”مَا ثخْسمْ أَذْ أَومْ د-أَرْخُوغْ إِ ؤُجدْجِيذْ ن وُوذَاينْ؟“
\v 10 مِينْزِي ثُوغَا إِسّنْ بلِّي إِمقّْرَاننْ ن إِكهَّاننْ أَقَا سلّْمنْ ث زِي ڒحْسذْ.
\v 11 مَاشَا إِمقّْرَاننْ ن إِكهَّاننْ عَارْننْ ڒْغَاشِي، مَاحنْذْ \add أَذْ تَّارنْ\add* أَذْ أَسنْ د-إِضْڒقْ إِ بَارْ-أَبَّاسْ. \x ◘ \xo 15:‏11 \xt مت. 27‏:‏20؛ لك. 23‏:‏18؛ يُوح. 18‏:‏40؛ ڒخ. 3‏:‏14. \x*
\v 12 بِيلَاطُوسْ إِنَّا أَسنْ: ”مِينْ ثخْسمْ أَذْ ڭّغْ س ونِّي ؤُمِي ثتّْڒَاغَامْ أَجدْجِيذْ ن وُوذَاينْ؟“
\v 13 سْغُويّنْ عَاوذْ: ”صلّْبْ إِ-ث!“
\v 14 إِنَّا أَسنْ بِيلَاطُوسْ: ”مَانْ ثُوعفّْنَا إِ إِڭَّا؟“ خنِّي أَرْنِينْ ذِي ثْغُويِّيثْ عَاذْ كْثَارْ: ”صلّْبْ إِ-ث!“
\v 15 أَمْ ثُوغَا إِخْسْ بِيلَاطُوسْ أَذْ إِسَّارْضَا ڒْغَاشِي، إِضْڒقْ إِ بَارْ-أَبَّاسْ، \add مَاشَا\add* إِسلّمْ أَسنْ يَاسُوع، أَوَارْنِي ڒَامِي ث هتّْكنْ س ؤُركُّوضْ، حِيمَا أَذْ ث صلّْبنْ. \x ◘ \xo 15:‏15 \xt مت. 27‏:‏26؛ يُوح. 19‏:‏1. \x*
\b
\s1 إِعسْكَارِييّنْ سّحْقَارَانْ يَاسُوع
\m 
\v 16 ڭوّْذنْ ث إِعسْكَارِييّنْ غَارْ ذَاخڒْ ن ڒمْرَاحْ ن ثَادَّارْثْ ن شّْرَاعْ، \add ؤُمِي قَّارنْ ’بْرِيثُورِييُومْ‘،\add* ؤُشَا سّْمُوننْ مَارَّا ڒْكُومْبَانِييّثْ ن ڒْعسْكَارْ. \x ◘ \xo 15:‏16 \xt مت. 27‏:‏27؛ يُوح. 19‏:‏2. \x*
\v 17 سّْيَارْضنْ أَسْ \add إِجّْ ن ورُّوضْ\add* ذ أَزڭّْوَاغْ، مُوذنْ أَسْ إِجّْ ن تَّاجْ س إِسنَّاننْ ؤُشَا قّْننْ أَسْ-ث،
\v 18 بْذَانْ تّْسدْجَامنْ خَاسْ، قَّارنْ أَسْ: ”أَزُولْ خَاكْ، أَ أَجدْجِيذْ ن وُوذَاينْ!“
\v 19 ثُوغَا شَّاثنْ ث غَارْ ؤُزدْجِيفْ س يِيجّْ ن وعْمُوذْ ن ؤُغَانِيمْ، سُّوسُوفنْ خَاسْ ؤُشَا ؤُضَارنْ خْ إِفَادّنْ نْسنْ،عبْذنْ ث.
\v 20 أَوَارْنِي ڒَامِي ث سّحْقَارنْ، كّْسنْ أَسْ أَسڒْهَامْ أَزڭّْوَاغْ ؤُشَا سّْيَارْضنْ أَسْ أَرُّوضْ نّسْ، خنِّي سُّوفّْغنْ ث حِيمَا أَذْ ث صلّْبنْ.
\b
\s1 أَبْرِيذْ غَارْ صَّالِيبْ
\m 
\v 21 حْصَارنْ إِجّنْ ونِّي د-إِكِّينْ سّنِّي أَمْ د-يُوسَا زڭْ إِيَّارْ، شِيمْعُونْ زِي قَايْرَاوَانْ، بَابَاسْ ن أَلِيكْسَانْذِيرْ ذ رُوفُوسْ، حِيمَا أَذْ أَسْ يَارْبُو صَّالِيبْ. \f ◼ \fr 15:‏21 \ft \bd ’زڭْ إِيَّارْ‘\bd* - نِيغْ ’زِي ڒْكَامْپُو‘.\f*  \x ◘ \xo 15:‏21 \xt [مت. 27‏:‏32‏-‏44؛ لك. 23‏:‏26‏-‏39؛ يُوح. 19‏:‏17‏-‏19] — مت. 27‏:‏32؛ لك. 23‏:‏26. \x*
\v 22 إِوْينْ \add يشُّو\add* غَارْ ومْشَانْ \add ؤُمِي قَّارنْ\add* ’جُولْجُوثَا‘، مِينْ إِخْسْ أَذْ يِينِي ’ثَاشقُّوفْثْ‘. \x ◘ \xo 15:‏22 \xt مت. 27‏:‏33؛ لك. 23‏:‏33؛ يُوح. 19‏:‏17. \x*
\v 23 وْشِينْ أَسْ بِينُو إِخدْجْضنْ س مِيرُّو \add ذ أَمَارْزَاڭْ\add*، حِيمَا أَذْ ث إِسُووْ، مَاشَا نتَّا وَارْ إِخْسْ أَذْ ث إِسُووْ.
\v 24 ؤُمِي ث صلّْبنْ، بْضَانْ أَرُّوضْ نّسْ، ڭِّينْ خَاسْ أَكشُّوضْ خْ مِينْ غَا إِكْسِي كُوڒْ إِجّْ \add زَّايْسنْ\add*. \x ◘ \xo 15:‏24 \xt إِزهد. 22‏:‏19؛ مت. 27‏:‏35؛ لك. 23‏:‏34؛ يُوح. 19‏:‏23. \x*
\v 25 ثُوغَا ثَاسَاعّثْ ذ ثْڒَاثَا، \add أَقَا-ت ذ ثسْعَا ن صّْبحْ\add*، ؤُمِي ث صلّْبنْ.
\v 26 سِّيبّثْ نْ ڒْموْثْ نّسْ أَقَا-ت ذِي ثِيرَا-يَا \add سنّجْ نّسْ\add*: ’وَا ذ أَجدْجِيذْ ن وُوذَاينْ‘. \x ◘ \xo 15:‏26 \xt مت. 27‏:‏37؛ لك. 23‏:‏38؛ يُوح. 19‏:‏19. \x*
\v 27 صلّْبنْ أَكِيذسْ ثْنَاينْ ن إِخوَّاننْ، إِجّنْ خْ ؤُفُوسِي نّسْ، ونّغْنِي خْ ؤُزڒْمَاضْ نّسْ.
\v 28 أَمُّو إِ تّْوَاكمّْڒنْثْ ثِيرَا \add إِقدّْسنْ\add* إِ إِقَّارنْ: ”إِتّْوَاحْسبْ أَكْ-ذ إِنِّي وَارْ إِسڭّْذنْ.“ \x ◘ \xo 15:‏28 \xt إِشا. 53‏:‏12؛ لك. 22‏:‏37. \x*
\m 
\v 29 إِنِّي سّنِّي د-إِتّكّنْ، ثُوغَا تّْشقَّافنْ ذَايسْ، تّْهزَّانْ إِزدْجِيفنْ نْسنْ، نَّانْ: ”أَ شكْ ونِّي إِ غَا إِهذْمنْ زَّاوشْثْ ثَامقّْرَانْثْ ؤُشَا أَذْ ت ثبْنِيذْ \add عَاوذْ\add* ذِي ثْڒَاثَا ن وُوسَّانْ، \x ◘ \xo 15:‏29 \xt إِزهد. 22‏:‏8؛ 69‏:‏21؛ 109‏:‏25؛ مت. 27‏:‏39؛ لك. 23‏:‏35؛ يُوح. 2‏:‏19. \x*
\v 30 سنْجمْ إِخفْ نّشْ، هْوَا-د زِي صَّالِيبْ!“
\v 31 أَمُّو إِ ث سّحْقَارنْ عَاوذْ إِمقّْرَاننْ ن إِكهَّاننْ أَكْ-ذ إِمْسڒْمَاذنْ ن إِذْلِيسنْ، نَّانْ: ”ثُوغَا إِسّنْجمْ إِنّغْنِي، مَاشَا وَارْ إِزمَّارْ أَذْ إِسّنْجمْ إِخفْ نّسْ.
\v 32 أجّْ لْمَاسِيحْ، أَجدْجِيذْ ن إِسْرَائِيل، أَذْ د-إِهْوَا ڒخُّو زِي صَّالِيبْ، حِيمَا أَذْ نْژَارْ ؤُشَا أَذْ ذَايسْ نَامنْ.“ ؤُڒَا ذ يِينِّي إِتّْوَاصلّْبنْ أَكِيذسْ، كّْوَارنْ ث.
\b
\s1 ڒْموْثْ ن يَاسُوع
\m 
\v 33 ؤُمِي د-ثِيوضْ ثْسَاعّثْ ستَّا، \add أَقَا-ت ذ ضّْهُورْ\add*، ثوْضَا-د ثَادْجسْثْ خْ ثمُّورْثْ مَارَّا أَڒْ ثسْعَا، \add أَقَا-ت ذ ثْڒَاثَا ن ؤُعشِّي\add*. \x ◘ \xo 15:‏33 \xt [مت. 27‏:‏45‏-‏56؛ لك. 23‏:‏44‏-‏49؛ يُوح. 19‏:‏28‏-‏30] — مت. 27‏:‏45؛ لك. 23‏:‏44. \x*
\v 34 ذِي ثْسَاعّثْ ثسْعَا إِسْغُويْ يَاسُوع س ثْمِيجَّا ثجْهذْ، إِنَّا: ”إِلْ، إِلْ، لْمَانَا شَابَاقْثَانِي؟“، مِينْ إِخْسْ أَذْ يِينِي: ”\add أَ\add* أَربِّي إِنُو، \add أَ\add* أَربِّي إِنُو، مَايمِّي ذَايِي ثْسمْحذْ؟“ \f ◼ \fr 15:‏34 \ft \bd ’إِلْ، إِلْ، لْمَانَا شَابَاقْثَانِي‘\bd* - ثُوغَا يَاسُوع إِسَّاوَاڒْ س يِيڒسْ ن ثْڒَامِيثْ أَمْ ث سَّاوَاڒنْ مَارَّا وُوذَاينْ ذِي ؤُرْشَالِيمْ ذ ثمُّورْثْ ن لْجَالِيلْ.\f*  \x ◘ \xo 15:‏34 \xt إِزهد. 22‏:‏2؛ مت. 27‏:‏46. \x*
\m 
\v 35 شَا زڭْ إِنِّي \add ذِينْ\add* إِبدّنْ، ؤُمِي سْڒِينْ أَيَا، نَّانْ: ”أَقَا نتَّا إِڒَاغَا إِ إِلِييَا!“
\v 36 يُوزّڒْ-د غَارسْ إِجّنْ، إِسُّوفّْ إِشْثْ ن سْپُونْخَا س ڒْخدْجْ، إِڭَّا إِ-ت خْ ؤُغَانِيمْ، إِوْشَا أَسْ حِيمَا أَذْ إِسُووْ. مَاشَا نِيثْنِي نَّانْ: ”رَاجَا! أجّْ أَنغْ أَذْ نْژَارْ مَا أَذْ د-يَاسْ إِلِييَا حِيمَا أَذْ ث-إِ-د-إِسّهْوَا.“ \x ◘ \xo 15:‏36 \xt إِزهد. 69‏:‏22؛ يُوح. 19‏:‏29. \x*
\v 37 \add خنِّي\add* إِسْغُويْ يَاسُوع س إِشْثْ ن ثْمِيجَّا ثجْهذْ ؤُشَا إِسلّمْ \add أَرُّوحْ نّسْ\add*.
\v 38 أَڒحَّافْ ن وَاذَافْ غَارْ زَّاوشْثْ ثَامقّْرَانْثْ إِتّْوَاشَارّڭْ خْ ثْنَاينْ زِي سنّجْ غَارْ سْوَادَّايْ. \x ◘ \xo 15:‏38 \xt 2 إِم. 3‏:‏14؛ مت. 27‏:‏51؛ لك. 23‏:‏45. \x*
\v 39 ؤُمِي إِژْرَا ڒْقبْطَانْ ن مْيَا إِ \add ذِينْ\add* إِبدّنْ زَّاثسْ، إِسْغُويُّو أَمُّو س جّهْذْ ؤُشَا \add خنِّي\add* إِبدّْ ؤُسُوفّغْ ن نّفْسْ، إِنَّا: ”س ثِيذتّْ ثُوغَا بْنَاذمْ-أَ ذ مِّيسْ ن أَربِّي!“ \x ◘ \xo 15:‏39 \xt مت. 27‏:‏54؛ لك. 23‏:‏47. \x*
\v 40 ثُوغَا ذِينْ عَاوذْ ثِيمْغَارِينْ خزَّارنْثْ إِ-د زِي ڒَاڭّْوَاجْ، جَارْ أَسنْثْ عَاوذْ مَارْيَامْ ن مَاجْذَالَا ذ مَارْيَامْ، يمَّاسْ ن يَاعْقُوبْ، أَمَاژُوژْ، ؤُ ن يُوسِيسْ، ذ سَالُومِي. \x ◘ \xo 15:‏40 \xt مت. 27‏:‏56؛ لك. 23‏:‏49. \x*
\v 41 ثِينِّي ث-إِ-د-إِضْفَارنْ، سخَّارنْثْ خَاسْ ؤُمِي ث ثُوغَا ذِي لْجَالِيلْ. ثُوغَا ذِينْ ؤُڒَا ذ أَطَّاسْ ن ثِيمْغَارِينْ نّغْنِيثْ ثِينِّي ثُوغَا أَكِيذسْ إِ د-إِڭعّْذنْ غَارْ ؤُرْشَالِيمْ. \x ◘ \xo 15:‏41 \xt لك. 8‏:‏2، 3. \x*
\b
\s1 أَنْضڒْ ن يَاسُوع
\m 
\v 42 ڒَامِي د-ثِيوضْ ثْمذِّيثْ ن ؤُسوْجذْ، \add ثَامذِّيثْ\add* نِّي إِدْجَانْ قْبڒْ إِ سّبْثْ، \x ◘ \xo 15:‏42 \xt [مت. 27‏:‏57‏-‏61؛ لك. 23‏:‏50‏-‏56؛ يُوح. 19‏:‏38‏-‏42] — مت. 27‏:‏57؛ لك. 23‏:‏50؛ يُوح. 19‏:‏38. \x*
\v 43 يُوسَا-د يُوسُوفْ زِي رَامْثَا، إِجّْ ن ؤُمْشَاوَارْ إِشنّْعنْ ن جْمَاعثْ \add ثَامقّْرَانْثْ\add*، ونِّي ثُوغَا إِتّْرَاجَانْ ثَاڭلْذِيثْ ن أَربِّي. ؤُشَا نتَّا إِزْعمْ أَذْ يَاذفْ غَارْ بِيلَاطُوسْ مَاحنْذْ أَذْ أَسْ إِتَّارْ أَرِّيمثْ ن يَاسُوع.
\v 44 إِثبْهثْ بِيلَاطُوسْ ؤُمِي إِمُّوثْ أَمُّو ذغْيَا. إِڒَاغَا-د إِ ڒْقبْطَانْ ن مْيَا، إِسّقْسَا ث، مَا إِمُّوثْ قْبڒْ ڒْوقْثْ. \x ◘ \xo 15:‏44 \xt إِزهد. 34‏:‏22؛ يُوح. 1(؛31‏-‏38\x*
\v 45 ؤُمِي إِفْهمْ مَانْ أَيَا \add زِي ڒْقبْطَانْ ن مْيَا\add*، إِوْشَا أَرِّيمثْ إِ يُوسُوفْ.
\v 46 إِسْغَا يُوسُوفْ ڒشْفنْ ن ڒقْطنْ \add أَزْذَاذْ\add*، إِكْسِي ث \add زِي صَّالِيبْ\add*، إِشْفنْ إِ-ث \add ذِي ڒشْفنْ نِّي\add*، إِسَّارْسْ إِ-ث ذڭْ ونْضڒْ إِ خبْشنْ ذِي سّدْجَاحْ ؤُشَا إِسّقْنُونِّي إِشْثْ ن ثصْضَارْثْ خْ ثوَّارْثْ ن ونْضڒْ. \x ◘ \xo 15:‏46 \xt مت. 12‏:‏40؛ 26‏:‏12؛ 27‏:‏60؛ لك. 23‏:‏53. \x*
\v 47 ثُوغَا مَارْيَامْ ن مَاجْذَالَا ذ مَارْيَامْ، يمَّاسْ ن يُوسِي، ژْرِينْثْ مَانِي ث سَّارْسنْ.
\b
\b
\c 16
\s1 ثَانُوكْرَا
\m 
\v 1 ؤُمِي إِعْذُو سّبْثْ، ثسْغَا مَارْيَامْ ن مَاجْذَالَا ذ مَارْيَامْ، \add يمَّاسْ\add* ن يَاعْقُوبْ، ذ سَالُومِي ڒعْطُورْ حِيمَا أَذْ ث ذهْننْثْ. \x ◘ \xo 16:‏1 \xt [مت. 28‏:‏1‏-‏8؛ لك. 24‏:‏1‏-‏12؛ يُوح. 20‏:‏1‏-‏10] — مت. 28‏:‏1؛ لك. 24‏:‏1؛ يُوح. 20‏:‏1. \x*
\v 2 غَارْ صّْبحْ زِيشْ ذڭْ \add وَاسّْ\add* أَمزْوَارْ ن سِّيمَانَا إِوْضنْثْ-إِ-د غَارْ ونْضڒْ، أَڒَامِي د-ثنْقَارْ ثْفُوشْثْ.
\v 3 نَّانْثْ جَارْ أَسنْثْ: ”وِي ذ أَنغْ إِ غَا إِسّقْنُونّْينْ ثَاصْضَارْثْ نِّي إِدْجَانْ خْ وَاذَافْ ن ونْضڒْ؟“
\v 4 ڒَامِي خْزَارنْثْ، ژْرِينْثْ أَقَا ثَاصْضَارْثْ ثتّْوَاسّقْنُونِّي \add زڭْ ونْضڒْ\add*، وَاخَّا ثُوغَا ثمْغَارْ أَطَّاسْ.
\v 5 ڒَامِي ؤُذْفنْثْ غَارْ \add يِيفْڒِي ن\add* ونْضڒْ، ژْرِينْثْ إِجّْ ن ؤُبْڒِيغْ إِقِّيمْ غَارْ ؤُغزْذِيسْ أَفُوسِي، يَارْضْ أَرُّوضْ ذ أَشمْڒَاڒْ، ؤُشَا نِيثنْثِي نّْخڒْعنْثْ. \x ◘ \xo 16:‏5 \xt مت. 28‏:‏2؛ يُوح. 20‏:‏12. \x*
\v 6 \add مَاشَا\add* نتَّا إِنَّا أَسنْثْ: ”وَارْ تّْنخْڒِيعنْثْ شَا! كنِّينْثْ ثَارزُّونْثْ خْ يَاسُوع نَّاصِيرِي ونِّي إِتّْوَاصلّْبنْ. أَقَا نتَّا إِكَّارْ، وَارْ ذَا إِدْجِي، خْزَارنْثْ، أَقَا أَمْشَانْ مَانِي ث سَّارْسنْ. \x ◘ \xo 16:‏6 \xt مت. 28‏:‏5؛ لك. 24‏:‏5. \x*
\v 7 مَاشَا رُوحنْثْ، إِنِينْثْ إِ إِمحْضَارنْ نّسْ ؤُڒَا إِ بُوطْرُوسْ، أَقَا أَذْ أَومْ إِزْوَارْ غَارْ لْجَالِيلْ. ذِينِّي أَذْ ث ثْژَارمْ أَمْ مَامّشْ ثُوغَا إِ ذ أَومْ إِنَّا.“ \x ◘ \xo 16:‏7 \xt مت. 26‏:‏32؛ 28‏:‏10؛ مك. 14‏:‏28؛ ڒخ. 1‏:‏3؛ 13‏:‏31؛ 1 كُور. 15‏:‏5. \x*
\v 8 فّْغنْثْ \add ذغْيَا\add* ؤُشَا أَروْڒنْثْ زڭْ ونْضڒْ، مِينْزِي ثْقبْسْ إِ-ثنْثْ ثَارْجِيجِيثْ ذ دّهْشَانْ، ؤُشَا وَارْ ث نِّينْثْ إِ حذْ، مِينْزِي ثُوغَا ڭّْوذنْثْ. \x ◘ \xo 16:‏8 \xt مت. 28‏:‏8؛ لك. 24‏:‏9؛ يُوح. 20‏:‏18. \x*
\b
\s1 أَضْحَارْ ن يَاسُوع أَوَارْنِي إِ ثْنُوكْرَا نّسْ
\m 
\v 9 غَارْ صّْبحْ زِيشْ ذڭْ \add وَاسّْ\add* أَمزْوَارْ ن سِّيمَانَا إِكَّارْ-د ؤُشَا إِضْهَارْ-د ذ أَمزْوَارُو إِ مَارْيَامْ ن مَاجْذَالَا، ثنِّي زِي ثُوغَا إِسُّوفّغْ سبْعَا ن شّْوَاطنْ. \x ◘ \xo 16:‏9 \xt [مت. 28‏:‏9‏-‏10؛ يُوح. 20‏:‏11‏-‏18؛ لك. 24‏:‏13‏-‏35] — لك. 8‏:‏2؛ يُوح. 20‏:‏14، 16. \x*
\v 10 ثَانِيثَا ثْرُوحْ ؤُشَا ثْخبَّارْ أَيَا إِ يِينِّي ثُوغَا أَكِيذسْ إِدْجَانْ، إِنِّي ثُوغَا إِشضْننْ ؤُ تّْرُونْ.
\v 11 ڒَامِي إِنَا سْڒِينْ بلِّي نتَّا أَقَا إِدَّارْ ؤُشَا إِبَانْ أَسنْثْ، وَارْ زَّايْسنْثْ ؤُمِيننْ. \x ◘ \xo 16:‏11 \xt مت. 28‏:‏\x*
\v 12 أَوَارْنِي أَيَا إِبَانْ-د س يِيجّْ ن وَادُّوذْ نّغْنِي إِ ثْنَاينْ زَّايْسنْ، ؤُمِي ثُوغَا ڭُّورنْ نِيثْنِي غَارْ إِجّْ ن ذْشَارْ. \x ◘ \xo 16:‏12 \xt لك. 24‏:‏13. \x*
\v 13 ؤُڒَا ذ إِنَا رُوحنْ عَاوذْ ؤُشَا خبَّارنْ إِنّغْنِي، مَاشَا وَارْ ؤُمِيننْ ؤُڒَا ذ إِنَا.
\b
\m 
\v 14 غَارْ ؤُنڭَّارْ إِبَانْ-د إِ حِيطَاشْ أَڒَامِي ثُوغَا قِّيمنْ \add غَارْ طَّابْڒَا\add* ؤُشَا إِعَايَارْ إِ-ثنْ زِي سِّيبّثْ ن ثِيكّسْثْ ن لْ-إِيمَانْ نْسنْ ؤُ زِي سِّيبّثْ ن ڒقْسَاحثْ ن وُوڒَاونْ نْسنْ، مِينْزِي وَارْ ؤُمِيننْ زڭْ إِنِّي ث إِژْرِينْ أَوَارْنِي ڒَامِي د-إِتّْوَاسّْنكَّارْ نتَّا.
\b
\s1 ڒُومُورْ أَمقّْرَانْ إِ ؤُبَارّحْ ن ڒخْبَارْ أَصبْحَانْ
\m 
\v 15 إِنَّا أَسنْ: ”رُوحمْ غَارْ دُّونشْثْ مَارَّا، بَارّْحمْ س ڒخْبَارْ أَصبْحَانْ ذِي مَارَّا مِينْ د-إِتّْوَاخڒْقنْ. \x ◘ \xo 16:‏15 \xt [مت. 28‏:‏16‏-‏20؛ لك. 24‏:‏36‏-‏49؛ يُوح. 20‏:‏19‏-‏23؛ ؤُف. 1‏:‏6‏-‏8] — لك. 24‏:‏36؛ يُوح. 15‏:‏16؛ 20‏:‏19؛ 1 كُور. 15‏:‏5. \x*
\v 16 ونِّي يُومِيننْ ؤُ إِتّْوَاسّغْضصْ، أَقَا إِدَّارْ، مَاشَا ونِّي وَارْ يُومِيننْ، أَقَا إِتّْوَاحَاسبْ. \x ◘ \xo 16:‏16 \xt يُوح. 3‏:‏18؛ 12‏:‏48. \x*
\v 17 ثِينَا ذ ڒعْڒَامَاثْ إِ غَا إِضْفَارنْ إِنِّي يُومِيننْ: أَقَا نِيثْنِي أَذْ سُّوفّْغنْ شّْوَاطنْ س يِيسمْ إِنُو، أَذْ سِّيوْڒنْ س إِڒْسَاونْ ن جْذِيذْ، \x ◘ \xo 16:‏17 \xt لك. 10‏:‏17؛ ڒخ. 2‏:‏4؛ 5‏:‏16؛ 8‏:‏7؛ 10‏:‏46؛ 16‏:‏18؛ 19‏:‏6، 12. \x*
\v 18 أَذْ كْسِينْ إِفِيغْرَانْ س إِفَاسّنْ نْسنْ ؤُ مَاڒَا سْوِينْ مِينْ إِنقّنْ، وَارْ ثنْ إِضَّارِّي شَا مَانْ أَيَا، ؤُشَا أَذْ سَّارْسنْ إِفَاسّنْ نْسنْ خْ إِمهْڒَاشْ، أَذْ ڭّنْفَانْ.“ \x ◘ \xo 16:‏18 \xt لك. 10‏:‏19؛ ڒخ. 28‏:‏5، 8. \x*
\b
\s1 ثَامكْسِيثْ ن يَاسُوع غَارْ ؤُجنَّا
\m 
\v 19 أَوَارْنِي ڒَامِي كِيذْسنْ إِسِّيوڒْ، إِمّكْسِي سِيذِيثْنغْ يَاسُوع غَارْ ؤُجنَّا ؤُشَا إِسّْغِيمْ إِخفْ نّسْ خْ ؤُفُوسِي ن أَربِّي. \x ◘ \xo 16:‏19 \xt [لك. 24‏:‏50‏-‏53؛ ؤُف. 1‏:‏9‏-‏11] — لك. 24‏:‏50، 51؛ ڒخ. 1‏:‏9. \x*
\v 20 مَاشَا نِيثْنِي فّْغنْ ؤُشَا بَارّْحنْ ذِي كُوڒْ أَمْشَانْ، ؤُ سِيذِيثْنغْ ثُوغَا إِعَاونْ إِ-ثنْ ؤُشَا إِسَّارْسْ ڒْخطْ نّسْ خْ وَاوَاڒنْ نْسنْ س ڒعْڒَامَاثْ إِ يڭِّينْ. أَمِينْ.
\b
\m أَنڭَّارْ ن لْ-إِنْجِيلْ إِقدّْسنْ أَمْ مَامّشْ ث إِبَارّحْ مَارْكُوسْ. \x ◘ \xo 16:‏20 \xt ڒخ. 1‏:‏2؛ 14‏:‏3؛ 1 تِيم. 3‏:‏16؛ عبر. 2‏:‏4. \x* 
