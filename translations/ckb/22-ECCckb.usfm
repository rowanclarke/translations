\id ECC - Biblica® Open Kurdi Sorani Standard Version
\h ژیرمەندی
\toc1 ژیرمەندی
\toc2 ژیرمەندی
\toc3 ژیرمەندی
\mt1 ژیرمەندی
\c 1
\s1 هەرچی هەیە بێ واتایە
\p 
\v 1 وتەکانی وتاربێژی ژیرمەند، کوڕی داود، پاشا لە ئۆرشەلیم:
\q1 
\v 2 وتاربێژی ژیرمەند دەڵێت:
\q2 «بێ واتایە! بێ واتایە!
\q1 بێ واتا، هەر بێ واتایە!
\q2 هەرچی هەیە بێ واتایە.»
\b
\q1 
\v 3 مرۆڤ لە هەموو ماندووبوونەکەی چی بۆ دەمێنێتەوە،
\q2 کە لەسەر زەوی\f + \fr 1:3 \ft لە عیبری نووسراوە لەژێر خۆردا، بەڵام مەبەست لەسەر زەوییە نەک لەبەر گەرمای هەتاو.‏\f* پێوەی ماندوو دەبێت؟
\q1 
\v 4 نەوەیەک دێت و نەوەیەک دەڕوات،
\q2 بەڵام زەوی هەتاهەتایە هەر هەیە.
\q1 
\v 5 خۆر هەڵدێت و خۆرئاوا دەبێت،
\q2 بە پەلەیە بۆ شوێنەکەی لەوێوە هەڵدێت.
\q1 
\v 6 با هەڵدەکات بەرەو باشوور و
\q2 دەسووڕێتەوە بەرەو باکوور،
\q1 دەسووڕێتەوە و دەسووڕێتەوە،
\q2 هەمیشە بۆ خولگەکەی خۆی دەگەڕێتەوە.
\q1 
\v 7 هەرچەندە هەموو ڕووبارەکان بەرەو دەریا دەچن،
\q2 بەڵام دەریا هەر پڕ نابێت.
\q1 ڕووبارەکان بۆ شوێنەکەی خۆیان دەچنەوە،
\q2 بۆ ئەوێ دەڕۆن و دەگەڕێنەوە.
\q1 
\v 8 هەموو شتەکان ماندووکەرن،
\q2 مرۆڤ ناتوانێت دەریانببڕێت.
\q1 چاو لە سەیرکردن تێر نابێت و
\q2 گوێ لە بیستن پڕ نابێت.
\q1 
\v 9 ئەوەی بووە هەر ئەو دەبێت،
\q2 ئەوەی کراوە هەر ئەو دەکرێت،
\q2 هیچی نوێ لەسەر زەوی نییە.
\q1 
\v 10 هیچ شتێک نییە کە بگوترێت:
\q2 «سەیر بکە، ئەمە نوێیە!»
\q1 لە دێرزەمانەوە هەر بووە،
\q2 لە سەردەمانی پێش ئێمەوە.
\q1 
\v 11 کەس یادی نەوەکانی پێشوو ناکاتەوە،
\q2 تەنانەت نەوەکانی داهاتووش
\q1 نایەنەوە یادی
\q2 ئەوانەی کە لەپاش ئەوان دێن.
\s1 دانایی بێ واتایە
\p 
\v 12 من کە وتاربێژی ژیرمەندم، پاشای ئیسرائیل بووم لە ئۆرشەلیم.
\v 13 لە ڕێگای داناییەوە خۆمم تەرخان کرد بۆ فێربوون و لێکۆڵینەوە سەبارەت بە هەموو ئەو کارانەی کە لەسەر زەوی کراون. بارێکی گرانە کە خودا لەسەر شانی مرۆڤی داناوە!
\v 14 ڕوانیمە هەموو کردارەکان کە لەسەر زەویدا کراون و ئەوەتا هەمووی بێ واتایە و گڤەی بایە.
\q1 
\v 15 خوار ناتوانرێت ڕاست بکرێتەوە و
\q2 ونبوو ناتوانرێت بژمێردرێت.
\p 
\v 16 لە دڵی خۆمدا گوتم: «ئەوەتا من مەزن بووم، داناییم زۆرتر بوو لە هەموو ئەوانەی پێش من لەسەر تەختی ئۆرشەلیم بوون و دڵم دانایی و زانینی زۆری بینی.»
\v 17 ئینجا خۆمم تەرخان کرد بۆ تێگەیشتن لە دانایی، هەروەها شێتی و گێلی، ئەو کاتە بۆم دەرکەوت ئەمەش بە هەمان شێوە گڤەی بایە،
\q1 
\v 18 چونکە لە زۆری دانایی، پەستی زۆر دەبێت و
\q2 ئەوەی زانینی زیاتر بێت خەمی زیاد دەبێت.
\c 2
\s1 شادی بێ واتایە
\p 
\v 1 من لە دڵی خۆمدا گوتم: «ئێستا وەرە با بە شادی تاقیت بکەمەوە، جا چاکە دەبینیت!» بەڵام ئەمیش بووە شتێکی بێ واتا.
\v 2 لەبارەی پێکەنینەوە گوتم: «گێلایەتییە! ئەی شادی دەتگەیەنێتە چی؟»
\v 3 هەوڵم دا ڕۆحی خۆم بە شەراب شاد و گێل بکەم، لەو کاتەی کە هێشتا بیرم بە دانایی ڕێنمایی دەکردم. ویستم ببینم چی بۆ مرۆڤ باشە کە بە درێژایی ڕۆژانی ژیانی لەژێر ئاسماندا بیکات.
\p 
\v 4 کاری مەزنم ئەنجام دا، چەندین ماڵم بۆ خۆم بنیاد نا، چەندین ڕەزم بۆ خۆم چاند،
\v 5 باخ و بێستانم دروستکرد، لەناویاندا هەموو جۆرە دارێکی بەردارم چاند.
\v 6 حەوزی ئاوم دروستکرد هەتا لەوێوە دارستانە سەوزەکان ئاو بدەم.
\v 7 کۆیلە و کەنیزەم کڕی و چەند کۆیلەیەکی دیکەشم هەبوو کە لە ماڵەکەم لەدایک ببوون. هەروەها سەرمایەی مەڕ و مانگام زۆرتر بوو لە هەموو ئەوانەی پێش من لە ئۆرشەلیم بوون.
\v 8 زێڕ و زیو و گەنجینەی پاشاکان و هەرێمەکانم بۆ خۆم کۆکردەوە، چەندین ژن و پیاوی گۆرانیبێژ و کەنیزەم بۆ خۆم دانا. ئەوەی چێژ بداتە مرۆڤ بۆ خۆم دامنا.
\v 9 مەزن و پایەدارتر بووم لە هەموو ئەوانەی پێش من لە ئۆرشەلیم بوون، لەگەڵ هەموو ئەمانەشدا هەر بە دانایی مامەوە.
\q1 
\v 10 هەرچی چاوم خواستی ڕێم لێ نەگرت،
\q2 ئەوەی دڵم پێی خۆش بوو کردم.
\q1 دڵم بە هەموو ماندووبوونەکەم خۆش بوو،
\q2 ئەمەش پاداشتی هەموو ماندووبوونەکەم بوو.
\q1 
\v 11 بەڵام کاتێک سەیری هەموو کارەکانی دەستی خۆمم کرد،
\q2 لەوانەی کە پێیانەوە ماندوو ببووم،
\q1 بینیم هەمووی بێ واتا بوون وەک گڤەی با.
\q2 لەسەر زەوی هیچت بۆ نامێنێتەوە.
\s1 دانایی و گێلایەتی بێ واتان
\q1 
\v 12 پاشان ئاوڕم دایەوە بۆ ئەوەی دانایی و
\q2 شێتی و گێلایەتی ببینم،
\q1 چونکە ئەو کەسەی کە دوای پاشا دێت
\q2 چی زیاتر دەکات، لەوەی پێشتر کراوە؟
\q1 
\v 13 جا بینیم دانایی لە گێلی بەسوودترە،
\q2 وەک چۆن ڕووناکی بەسوودترە لە تاریکی.
\q1 
\v 14 دانا چاوی لە سەریدایە،
\q2 بەڵام گێل بە تاریکیدا دەڕوات،
\q1 پاشان بۆم دەرکەوت
\q2 کە هەردووکیان یەک چارەنووسیان هەیە.
\p 
\v 15 ئینجا لە دڵی خۆمدا گوتم:
\q1 «ئەوەی لە گێل ڕوودەدات لە منیش ڕوودەدات،
\q2 ئیتر قازانجی چییە کە من داناتربم؟»
\q1 لەبەر ئەوە لە دڵی خۆمدا گوتم:
\q2 «ئەمەش هەر بێ واتایە.»
\q1 
\v 16 نە دانا و نە گێل، هەتاهەتایە یاد ناکرێنەوە،
\q2 لە ڕۆژانی داهاتوودا هەردووکیان لەبیر دەچنەوە.
\q1 هەروەک گێل، داناش دەمرێت.
\s1 ماندووبوون بێ واتایە
\p 
\v 17 ئیتر ڕقم لە ژیان هەستا، چونکە ئەوەی لەسەر زەویدا دەکرێت، لەلام خراپە، هەمووی بێ واتایە و گڤەی بایە.
\v 18 ڕقم لە هەموو ماندووبوونەکەم هەستا کە لەسەر زەویدا ڕەنجم بۆی کێشا، لەبەر ئەوەی بە ناچاری بۆ ئەو کەسەی بەجێدەهێڵم کە لەپاش خۆم دێت.
\v 19 کێ دەزانێت ئەو کەسە دانا دەبێت یان گێل؟ لەگەڵ ئەوەشدا دەست بەسەر هەموو ماندووبوونەکەم دەگرێت کە لەسەر زەویدا ڕەنجم بۆی کێشا. ئەمەش هەر بێ واتایە.
\v 20 ئیتر دڵی خۆم بێ ئومێد بووە لە هەموو ئەو ماندووبوونە کە لەسەر زەویدا پێوەی ماندوو بووم.
\v 21 لەوانەیە کەسێک بە دانایی و زانین و کارامەییەوە خۆی ماندوو بکات، بەڵام بۆ کەسێک کە پێوەی ماندوو نەبووبێت وەک میرات بەجێی بهێڵێت. هەروەها ئەمەش بێ واتایە و نەهامەتییەکی گەورەیە.
\v 22 چی تێدایە بۆ مرۆڤ لە هەموو ئەو ماندووبوون و کۆششەی کە بە دڵەڕاوکێ لەسەر زەویدا ڕەنجی بۆ دەکێشێت؟
\v 23 بە درێژایی ژیانی کارەکەی پڕ لە خەم و ئازارە، بگرە لە شەویشدا بیری ئاسوودە نابێت. ئەمەش هەر بێ واتایە.
\p 
\v 24 لەوە باشتر نییە بۆ مرۆڤ کە بخوات و بخواتەوە و چێژ لە ماندووبوونەکەی ببینێت. هەروەها ئەمەشم بینی کە لە خوداوەیە،
\v 25 چونکە بەبێ خودا کێ دەتوانێت بخوات و کێ دەتوانێت خۆشی ببینێت؟
\v 26 خودا ئەوەی چاکە لەبەردەمی، دانایی و زانین و دڵخۆشی دەداتێ، گوناهباریش خەریک دەکات بە کۆکردنەوەی ماڵ و سامان و ئەمبارکردنی، هەتا بیداتە ئەو کەسەی کە خودا پەسەندی دەکات. ئەمەش بێ واتایە و گڤەی بایە.
\c 3
\s1 وەرزێک بۆ هەر شتێک
\q1 
\v 1 هەر شتێک وەرزی خۆی هەیە،
\q2 هەر چالاکییەک لەسەر زەوی کاتی خۆی هەیە:
\b
\q2 
\v 2 لەدایکبوون کاتی خۆی هەیە و مردنیش کاتی خۆی،
\q2 چاندن کاتی خۆی هەیە و هەڵکێشانی چێنراویش کاتی خۆی،
\q2 
\v 3 کوشتن کاتی خۆی هەیە و چاکبوونەوەش کاتی خۆی،
\q2 ڕووخاندن کاتی خۆی هەیە و بنیادنانیش کاتی خۆی،
\q2 
\v 4 گریان کاتی خۆی هەیە و پێکەنینیش کاتی خۆی،
\q2 شیوەن گێڕان کاتی خۆی هەیە و سەماکردن کاتی خۆی،
\q2 
\v 5 بەرد بڵاوکردنەوە کاتی خۆی هەیە و بەرد کۆکردنەوە کاتی خۆی،
\q2 لەئامێزگرتن کاتی خۆی هەیە و لەئامێزنەگرتنیش کاتی خۆی،
\q2 
\v 6 کۆڵدان کاتی خۆی هەیە و کۆڵنەدان کاتی خۆی،
\q2 پارێزگاریکردن کاتی خۆی هەیە و فڕێدان کاتی خۆی،
\q2 
\v 7 دڕاندن کاتی خۆی هەیە و دوورینەوە کاتی خۆی،
\q2 بێدەنگی کاتی خۆی هەیە و قسەکردن کاتی خۆی،
\q2 
\v 8 خۆشویستن کاتی خۆی هەیە و ڕق کاتی خۆی،
\q2 جەنگ کاتی خۆی هەیە و ئاشتی کاتی خۆی.
\p 
\v 9 کرێکار چی بۆ دەمێنێتەوە لەوەی خۆی پێوە ماندوو دەکات؟
\v 10 ئەو بارەم بینی کە خودا داویەتی بە ئادەمیزاد هەتا هەڵیبگرن.
\v 11 خودا هەموو شتێکی دروستکرد کە لە کاتی خۆیدا جوان بێت، هەروەها وای کرد مرۆڤ هەستی ژیانی هەتاهەتایی هەبێت؛ لەگەڵ ئەوەشدا کەس ناتوانێت لە بنجوبنەوانی کاری خودا تێبگات، لە سەرەتاوە هەتا کۆتایی.
\v 12 جا زانیم کە لەوە باشتر نییە بۆ مرۆڤ کە پێی دڵخۆش بێت و چاکە بکات لە ژیانیدا.
\v 13 هەروەها کە هەموو مرۆڤێک بخوات و بخواتەوە و چێژ لە هەموو ماندووبوونەکەی ببینێت، ئەوە دیاری خودایە.
\v 14 زانیم کە هەموو ئەوەی خودا ئەنجامی دەدات بۆ هەتاهەتایە، هیچی بۆ زیاد ناکرێت و هیچیشی کەم ناکرێتەوە. خودا کردوویەتی بۆ ئەوەی خەڵک لێی بترسن.
\q1 
\v 15 ئەوەی هەیە پێشتر هەبووە،
\q2 ئەوەش کە دەبێت پێشتر بووە،
\q2 خوداش لێپرسینەوە لەسەر ڕابردوو دەکات.
\p 
\v 16 هەروەها لەسەر زەوی بینیم:
\q1 خراپەکاری لە جێی دادپەروەری،
\q2 بەدکاریش لە جێگای ڕاستودروستی.
\p 
\v 17 جا لە دڵی خۆمدا گوتم:
\q1 «کەسی ڕاستودروست و خراپەکاریش
\q2 خودا دادگایی هەردووکیان دەکات،
\q1 چونکە بۆ هەر چالاکییەک کاتی خۆی دەبێت،
\q2 بۆ بڕیاردانیش لەسەر هەر کارێک کاتی خۆی.»
\p 
\v 18 من لە دڵی خۆمدا گوتم: «سەبارەت بە ئادەمیزاد، خودا تاقییان دەکاتەوە بۆ ئەوەی تێیانبگەیەنێت کە ئاژەڵ چۆنە ئەوانیش بەو شێوەیەن.
\v 19 بێگومان چارەنووسی مرۆڤ هەروەک چارەنووسی ئاژەڵە، چونکە مردنی ئەمیان وەک مردنی ئەویانە و یەک هەناسە بۆ هەردووکیانە، مرۆڤ هیچی لە ئاژەڵ زیاتر نییە. بێگومان هەرچی هەیە بێ واتایە.
\v 20 هەموو بۆ یەک شوێن دەڕۆن: هەردووکیان لە خۆڵەوە هاتن و دەشگەڕێنەوە بۆ خۆڵ.
\v 21 کێ دەزانێت: ئایا ڕۆحی ئادەمیزاد بەرەو سەرەوە هەڵدەکشێت یان ڕۆحی ئاژەڵ بەرەو خوارەوە بۆ زەوی دادەبەزێت؟»
\p 
\v 22 ئیتر بینیم لەوە باشتر نییە کە مرۆڤ بە کارەکەی دڵخۆش بێت، لەبەر ئەوەی ئەمە بەشی ئەوە، چونکە کێ دەیبینێت بۆ ئەوەی بیگێڕێتەوە کە لەدوای ئەو چی دەبێت؟
\c 4
\s1 ستەمکاری، ماندووبوون، تەنهایی
\p 
\v 1 پاشان ئاوڕم دایەوە و بینیم هەموو ئەو ستەمەی کە لەسەر زەویدا دەکرێت و ئەوەتا:
\q1 فرمێسکی ستەملێکراوانم بینی،
\q2 کەس نەبوو دڵنەواییان بکات،
\q1 ستەمکارانیشیان زەبریان بەدەست بوو،
\q2 کەس نەبوو دڵنەواییان بکات.
\q1 
\v 2 خۆزگە بە مردووان دەخوازرێت
\q2 کە دەمێکە مردوون،
\q1 ئەوان خۆشحاڵترن لەوانەی
\q2 کە لە ژیاندا ماون.
\q1 
\v 3 بەڵام لە هەردووکیان باشتر ئەوەیە
\q2 کە هێشتا لەدایک نەبووە،
\q1 ئەوەی ئەو خراپەکارییەی نەدیوە
\q2 کە لەسەر زەوی ئەنجام دەدرێت.
\p 
\v 4 من بینیم کە هەموو ماندووبوون و هەموو ئەوەی مرۆڤ بەرهەمی دەهێنێت لە ئەنجامی ئەو کێشمەکێشەی کە مرۆڤ بەرامبەر بە نزیکەکەی دەیکات، ئەمەش بێ واتایە و گڤەی بایە.
\q1 
\v 5 کەسی گێل دەست دەخاتە سەر دەست و
\q2 گۆشتی خۆی دەخوات.
\q1 
\v 6 مشتێک حەسانەوە باشترە
\q2 لە دوو مشتی پڕ ماندووبوون و گڤەی با.
\p 
\v 7 دیسان شتێکی بێ واتام لەسەر زەوی بینی:
\q1 
\v 8 یەکێکی تاک و تەنها،
\q2 نە کوڕی هەبوو، نە برا،
\q1 هەموو ماندووبوونەکەی بێ کۆتایی بوو،
\q2 هەروەها چاوی لە دەوڵەمەندی تێر نەدەبوو.
\q1 گوتی: «ئیتر بۆ کێ خۆم ماندوو بکەم و
\q2 گیانی خۆم بۆچی لە خۆشی بێبەش بکەم؟»
\q1 ئەمەش بێ واتایە و بارێکی قورسە.
\b
\q1 
\v 9 دوو کەس لە یەک کەس باشترە،
\q2 چونکە لە ماندووبوونەکەیان قازانجێکی باشتریان دەبێت.
\q1 
\v 10 ئەگەر یەکێکیان بکەوێت،
\q2 هاوڕێکەی هەڵیدەستێنێتەوە.
\q1 بەڵام قوڕبەسەر ئەوەی کە تەنهایە،
\q2 دەکەوێت و کەس نییە هەڵیبستێنێتەوە.
\q1 
\v 11 هەروەها ئەگەر دوو کەس پێکەوە ڕابکشێن، گەرم دەبنەوە،
\q2 بەڵام یەکێک تەنها بێت، چۆن گەرم دەبێتەوە؟
\q1 
\v 12 ئەگەر یەکێک یەک کەس ببەزێنێت،
\q2 دووان دەتوانن بەرامبەری بوەستن،
\q1 گوریسی سێ تاڵیش زوو ناپسێت.
\s1 پلە بەرزبوونەوە بێ واتایە
\p 
\v 13 گەنجێکی هەژار و دانا باشترە لە پاشایەکی پیر و گێل، کە ئیتر ناتوانێت گوێ لە هۆشداری بگرێت.
\v 14 دەشێت گەنجەکە لە بەندیخانەوە هاتبێتە دەرەوە هەتا ببێت بە پاشا، یاخود بە هەژاری لەو شانشینەدا لەدایک بووبێت.
\v 15 ڕوانیمە هەموو ئەو مرۆڤانەی کە بەسەر زەویدا هاتوچۆیان دەکرد پشتگیری گەنجەکەیان دەکرد کە جێگەی پاشاکەی گرتەوە.
\v 16 ئەو مرۆڤانەی کە هاتنە بەردەمی پاشا بێشومار بوون، بەڵام گەل دڵیان بەو پاشایە خۆش نەبوو. ئەمەش بێ واتایە و گڤەی بایە.
\c 5
\s1 ئەنجامدانی نەزر
\p 
\v 1 کاتێک دەچیت بۆ ماڵی خودا، ئاگاداری پێی خۆت بە. وەرە پێشەوە هەتا گوێ بگریت، نەوەک قوربانی گێلەکان بکەی کە خراپەکاری خۆیان نازانن.
\q1 
\v 2 با دەمت لە قسەکردندا پەلە نەکات،
\q2 با دڵیشت خێرا نەکات،
\q2 لە دەربڕینی قسە لەبەردەم خودا،
\q1 چونکە خودا لە ئاسمانە و
\q2 تۆ لەسەر زەویت،
\q2 لەبەر ئەمە با وشەکانت کەم بن.
\q1 
\v 3 خەون لە ئەنجامی ماندووبوونی زۆرەوە دێت و
\q2 قسەی گێلیش لە زۆر گوتن.
\p 
\v 4 ئەگەر نەزرێکت\f + \fr 5:4 \ft واتا پابەندکردنی مرۆڤ خۆیەتی بە مەرجێکەوە، لە کاتێکدا کە داخوازییەک بەرز دەکاتەوە بۆ خودا و بە ئەرێ وەڵام دەدرێتەوە لەلایەن خوداوە. بڕوانە \xt سەرژمێری 21‏:2‏\xt*\ft ‏.‏\f* بۆ خودا کرد، دوا مەکەوە لە ئەنجامدانی، چونکە بە گێلەکان دڵخۆش نابێت. جا ئەوەی نەزرت کردووە ئەنجامی بدە.
\v 5 باشترە نەزر نەکەیت لەوەی بیکەیت و ئەنجامی نەدەیت.
\v 6 ڕێگا مەدە دەمت وا بکات لەشت گوناه بکات و لەبەردەم نێردراوی پەرستگا\f + \fr 5:6 \ft بڕوانە \xt مەلاخی 2‏:7‏\xt*\ft ‏.‏\f* مەڵێ: «ئەم نەزرە هەڵە بوو.» بۆچی خودا لە قسەکەت تووڕە بێت و ئەوەی کردووتە لەناوی ببات؟
\v 7 زیادبوونی خەون و چەنەبازی بێ واتان، لەبەر ئەوە لەخواترس بە.
\s1 سامان بێ واتایە
\p 
\v 8 ئەگەر بینیت لە هەرێمێکدا هەژار ستەمی لێ کرا و ڕاستودروستی و دادپەروەری پشتگوێ خرا، ئەوا سەرسام مەبە، چونکە لێپرسراوی بەرز لێپرسراوی بەرزتر دەپارێزێت و بەرزتریش لەوان هەردووکیان دەپارێزێت.
\v 9 بەڵام گەل لە وڵات سوود وەردەگرن، چونکە پاشا هەموو کێڵگەکانی دەپارێزێت.
\q1 
\v 10 ئەوەی حەزی لە پارە بێت لە پارە تێر نابێت،
\q2 ئەوەی حەزی لە سامان بێت لە داهات تێر نابێت،
\q2 هەروەها ئەمەش بێ واتایە.
\b
\q1 
\v 11 بە زیادبوونی خێروبێر
\q2 زیاد دەبن ئەوانەی دەیخۆن.
\q1 ئایا چ سوودێکی بۆ خاوەنەکەی هەیە،
\q2 جگە لەوەی تەنها چاوەکانی تێری لێ دەخۆن؟
\b
\q1 
\v 12 خۆشە خەوی کارگەر،
\q2 کەم بخوات یان زۆر،
\q1 بەڵام تێریی دەوڵەمەند
\q2 ڕێ بە خەو نادات.
\p 
\v 13 خراپەیەکی ناخۆش هەیە لەسەر زەویدا بینیم:
\q1 سامانێک پارێزراوە بۆ خراپەی خاوەنەکەی،
\q2 
\v 14 ئەم سامانەش لە مامەڵەیەکی خراپدا لەناوچوو،
\q2 ئینجا کوڕێکی بوو و هیچی بۆ نەمایەوە هەتا بۆ کوڕەکەی بەجێبهێڵێت.
\q1 
\v 15 وەک چۆن لە سکی دایکی هاتە دەرەوە،
\q2 بە ڕووتی دەگەڕێتەوە، دەڕوات وەک هات.
\q1 هیچ شتێک لە ماندووبوونەکەی نابات
\q2 لەگەڵ دەستی کە دەڕوات.
\p 
\v 16 ئەمەش خراپەیەکی ناخۆشە:
\q1 هەروەک چۆن مرۆڤ دێتە جیهان، بە هەمان شێوە بەجێدەهێڵێت،
\q2 ئەوەی ماندووبوونەکەی بۆ با دەبێت
\q2 چ قازانجێک دەکات؟
\q1 
\v 17 هەروەها هەموو ڕۆژانی ژیانی لە تاریکیدا بەسەردەبات،
\q2 لەگەڵ وەڕسبوونێکی زۆر و نەخۆشی و تووڕەیی.
\p 
\v 18 ئەوەی من بینیومە باشە، ئەوەی گونجاوە، کە مرۆڤ بخوات و بخواتەوە و خۆشی ببینێت لە هەموو ئەوەی کە لەسەر زەویدا پێوەی ماندوو دەبێت، بە درێژایی ئەو ڕۆژگارە کەمەی کە خودا پێیداوە، چونکە بەشی ئەوە.
\v 19 هەروەها کە خودا بە یەکێک دەوڵەمەندی و سامان دەدات و ئەویش دەتوانێت سوودی لێی وەربگرێت و بە بەشی خۆی ڕازی بێت و بە ماندووبوونەکەی دڵخۆش بێت، ئەمە دیارییەکە لە خوداوە.
\v 20 جا ڕۆژگاری ژیانی بەبیر نایەتەوە، چونکە خودا بە خۆشی دڵییەوە خەریکی کردووە.
\c 6
\p 
\v 1 بارگرانییەکم لەسەر زەوی بینیوە کە ئادەمیزاد خراپ گیرۆدە بوون بە دەستیەوە،
\v 2 کەسێک خودا دەوڵەمەندی و سامان و ڕێزی پێدابێت و هیچ کەمی نەبێت لەوەی گیانی ئارەزووی دەکات، بەڵام خودا دەسەڵاتی پێنەداوە بۆ ئەوەی بیخوات، بەڵکو بێگانە دەیخوات، ئەمە بێ واتایە و دەردێکی خراپە.
\p 
\v 3 ئەگەر کەسێک سەد منداڵی هەبێت و ساڵانێکی زۆر بژیێت و تەمەنی زۆر بێت، بەڵام گیانی تێر خۆشی نەبێت و هەروەها ناشتنی بۆ نەبێت، دەڵێم: لەبارچووێک لەو باشترە،
\v 4 چونکە بێ واتایانە دێت و بە تاریکیدا دەڕوات، ناویشی بە تاریکی دادەپۆشرێت.
\v 5 هەروەها نە خۆری بینی و نە دەشزانێت، ئەم ئاسوودەترە لەو کەسە.
\v 6 ئەگەر هەزار ساڵ دووبارەش بژیێت بەڵام خۆشی نەبینێت، ئایا هەمووان بۆ یەک شوێن ناڕۆن؟
\q1 
\v 7 هەموو ماندووبوونی مرۆڤ بۆ دەمییەتی،
\q2 بەڵام هەرگیز تێر ناخوات.
\q1 
\v 8 دانا چی لە گێل زیاترە؟
\q2 چی یارمەتی هەژار دەدات
\q1 کە ئەو بزانێت چۆن هەڵسوکەوت بکات
\q2 لەگەڵ ئەوانەی کە لە ژیاندان؟
\q1 
\v 9 ئەوەی هەتە و لەبەرچاوتە
\q2 باشترە لەوەی کە نیتە و ئارەزووت لێیەتی.
\q2 ئەمەش بێ واتایە و گڤەی بایە.
\b
\q1 
\v 10 ئەوەی هەبووە لە کۆنەوە ناوی لێنراوە و
\q2 زانراوە.
\q1 مرۆڤ ناتوانێت ململانێ لەگەڵ یەکێک بکات
\q2 کە لە خۆی بەهێزترە.
\q1 
\v 11 ئەوەندە قسە زیاد دەبێت،
\q2 ئەوەندە سوودی کەم دەبێتەوە،
\q2 جا مرۆڤ چی بۆ دەمێنێتەوە؟
\p 
\v 12 کێ دەزانێت چی باشە بۆ مرۆڤ لە ژیاندا کە درێژی تەمەنی بێ واتا وەک سێبەر بەسەردەچێت؟ کێ بە مرۆڤ ڕادەگەیەنێت پاش ئەو لەسەر زەوی چی ڕوودەدات؟
\c 7
\s1 دانایی
\q1 
\v 1 ناوبانگی باش لە بۆنی خۆش باشترە و
\q2 ڕۆژی مردنیش لە ڕۆژی لەدایکبوون.
\q1 
\v 2 چوون بۆ ماڵی ماتەمدار باشترە
\q2 لە چوون بۆ ماڵی ئاهەنگدار،
\q1 چونکە مردن کۆتایی هەموو مرۆڤێکە،
\q2 زیندوو دەیخاتە دڵی خۆیەوە.
\q1 
\v 3 وەڕسبوون لە پێکەنین باشترە،
\q2 چونکە بە خەمۆکی ڕوخسار دڵ چاک دەبێتەوە.
\q1 
\v 4 دڵی دانایان لە ماڵی ماتەمدارە و
\q2 دڵی گێلانیش لە ماڵی ئاهەنگدارە.
\q1 
\v 5 گوێگرتن لە سەرزەنشتی دانا باشترە
\q2 لە گوێگرتن لە گۆرانیی گێلەکان،
\q1 
\v 6 چونکە پێکەنینی پیاوی گێل،
\q2 وەک قرچەی دڕکە کە لەژێر مەنجەڵدا.
\q2 ئەمەش هەر بێ واتایە.
\b
\q1 
\v 7 زۆرداری پیاوی دانا گێل دەکات و
\q2 بەرتیل دڵ گەندەڵ دەکات.
\b
\q1 
\v 8 کۆتایی شت باشترە لە سەرەتاکەی،
\q2 پشوو درێژ باشترە لە هەڵەشە.
\q1 
\v 9 لە ناخەوە زوو پەست مەبە،
\q2 چونکە تووڕەیی لەناو سنگی گێلەکاندا جێگیرە.
\b
\q1 
\v 10 مەڵێ: «بۆچی سەردەمانی کۆن لە ئەمڕۆ باشتر بوون؟»
\q2 چونکە لە داناییەوە نییە لەمە پرسیار دەکەیت.
\b
\q1 
\v 11 دانایی باشە وەک میرات و
\q2 بە سوودە بۆ ئەوانەی کە خۆر دەبینن.
\q1 
\v 12 دانایی پەناگایە
\q2 وەک چۆن پارەش پەناگایەکە،
\q1 بەڵام ئەمە سوودی زانینە:
\q2 دانایی ژیان دەبەخشێت بە خاوەنەکەی.
\p 
\v 13 تەماشای کاری خودا بکە:
\q1 کێ دەتوانێت ڕاستی بکاتەوە
\q2 ئەوەی خودا خواری کردووەتەوە؟
\q1 
\v 14 لە ڕۆژی باشدا، لە خۆشیدا بە،
\q2 بەڵام لە ڕۆژی خراپدا، ئەوە بزانە کە
\q1 خودا هەردووکیانی دروستکردووە.
\q1 ئیتر مرۆڤ ناتوانێت هیچ شتێک
\q2 سەبارەت بە داهاتووەکەی بدۆزێتەوە.
\p 
\v 15 لە ڕۆژگاری بێ واتای خۆمدا ئەم دووانەم بینی:
\q1 کەسی ڕاستودروست هەیە بە ڕاستودروستییەکەی دەفەوتێت،
\q2 خراپەکاریش هەیە درێژە بە خراپەکەی دەدات.
\q1 
\v 16 زۆر ڕاستودروست مەبە و
\q2 زیاد دانا مەبە.
\q2 بۆچی خۆت تێکدەدەیت؟
\q1 
\v 17 زۆر بەدکار مەبە و
\q2 مەبە بە گێل.
\q2 بۆچی بمریت لە کاتی خۆت نەبێت؟
\q1 
\v 18 باشترە دەست بە یەکێکیانەوە بگریت و
\q2 دەست لەوەی دیکەش شل نەکەیت،
\q2 چونکە لەخواترس بە هیچ شێوەیەک زیادەڕۆیی ناکات.
\b
\q1 
\v 19 دانایی دانا بەهێزتر دەکات
\q2 لە دە فەرمانڕەوا کە لە شاردا بن.
\b
\q1 
\v 20 بێگومان هیچ مرۆڤێکی ڕاستودروست لەسەر زەویدا نییە،
\q2 کە چاکە دەکات و هەرگیز گوناه ناکات.
\b
\q1 
\v 21 هەروەها هەموو قسەیەک کە دەیکەن دڵی خۆتی مەدەرێ،
\q2 نەوەک گوێت لە خزمەتکارەکەت بێت نەفرەتت لێ بکات،
\q1 
\v 22 چونکە دڵت دەزانێت
\q2 کە تۆش زۆر جار نەفرەتت لەوانی دیکە کردووە.
\p 
\v 23 هەموو ئەمانەم بە دانایی تاقی کردەوە و گوتم:
\q1 «دانا دەبم،»
\q2 کەچی لێم دوور بوو.
\q1 
\v 24 ئەو داناییە کە هەیە دوورە و زۆر قووڵە؛
\q2 کێ دەیدۆزێتەوە؟
\q1 
\v 25 هاتم سەرنجم دا لە دانایی و لێم کۆڵییەوە و
\q2 گەڕام بەدوای ڕاستیەکاندا بۆ ئەوەی لێی تێبگەم،
\q1 لە ئەنجامدا بۆم دەرکەوت کە خراپەکاری نەزانینە و
\q2 گێلایەتیش شێتییە.
\b
\q1 
\v 26 من دۆزیمەوە کە لە مردن تاڵترە
\q2 ئەو ژنەی کە تۆڕە و دڵی تەڵەیە،
\q1 دەستەکانیشی کۆتن.
\q2 ئەوەی لەبەردەم خودا چاک بێت، لێی دەرباز دەبێت،
\q2 بەڵام گوناهبار بە تەڵەکەیەوە دەبێت.
\p 
\v 27 وتاربێژی ژیرمەند دەڵێت: «سەیر بکە، ئەمەم دۆزییەوە:
\q1 «بۆ ئەوەی بگەمە ئەنجامی ڕاستییەکان زانیارییەکانم یەک بە یەک کۆکردەوە،
\q2 
\v 28 لە کاتێکدا کە هێشتا دەگەڕام و
\q2 جارێ نەگەیەشتبوومە ئەنجام،
\q1 پەندێکم بیستووە کە دەڵێت:
\q2 ”لەنێو هەزار پیاودا تەنها یەکێکم دۆزییەوە،
\q1 بەڵام لەنێو هەموویان یەک ئافرەتم نەبینی.“
\q1 
\v 29 تەنها شتێکم دۆزیوەتەوە، ئەمەش ئەوەیە:
\q2 خودا مرۆڤی لەسەر بنچینەیەکی ڕاست دروستکردووە،
\q2 بەڵام ئەوان دوای داهێنانی زۆر کەوتوون.»
\b
\c 8
\q1 
\v 1 کێ وەک مرۆڤی دانایە؟
\q2 کێ ڕوونکردنەوەی شت دەزانێت؟
\q1 دانایی مرۆڤ ڕووی ڕووناک دەکاتەوە و
\q2 تاڵی ڕوخساری دەگۆڕێت.
\s1 فەرمانی پاشا بەجێبگەیەنە
\p 
\v 2 من دەڵێم: فەرمانی پاشا بەجێبگەیەنە، لە پێناوی ئەو سوێندەی کە بۆ خودات خوارد.
\v 3 پەلە مەکە لە ڕۆیشتن لەبەردەمی پاشا. داکۆکی لە خراپە مەکە، چونکە پاشا هەرچی پێی خۆش بێت دەیکات.
\v 4 فەرمایشتی پاشا فەرموودەی دەسەڵاتدارە، کێ دەتوانێت پێی بڵێت: «تۆ چی دەکەیت؟»
\q1 
\v 5 ئەوەی فەرمانەکەی بەجێبگەیەنێت تووشی خراپە نابێت،
\q2 دڵی داناش کات و ڕێوشوێنی گونجاو دەزانێت،
\q1 
\v 6 چونکە هەر شتێک کات و ڕێوشوێنی خۆی هەیە،
\q2 هەرچەندە مرۆڤ دەردەسەری زۆر بێت.
\b
\q1 
\v 7 کەس نازانێت لە داهاتوودا چی دەبێت،
\q2 ئەوەی ڕوودەدات کێ پێی ڕادەگەیەنێت؟
\q1 
\v 8 وەک چۆن کەس دەسەڵاتی بەسەر بادا نییە، بۆ ئەوەی با بگرێت،
\q2 مرۆڤ دەسەڵاتی بەسەر ڕۆژی مردندا نییە.
\q1 وەک چۆن نەسرەوتن لە کاتی شەڕدا نییە،
\q2 خراپەکار توانای نییە خۆی لە خراپە ئازاد بکات.
\p 
\v 9 هەموو ئەمانەم بینی، کە سەرنجم دایە هەموو ئەو کارانەی لەسەر زەوی کراون. کاتێک هەیە کەسێک بەسەر کەسێکی دیکەدا دەسەڵاتدار دەبێت بۆ زیانی خۆی.
\v 10 بەم جۆرە بینیم خراپەکاران لە گۆڕ نران، ئەوانەی کە لە شوێنی پیرۆزەوە هاتوچۆیان دەکرد و لەو شارەی ئەو کارانەیان کرد ستایش کرابوون. ئەمەش هەر بێ واتایە.
\p 
\v 11 لەبەر ئەوەی سزای تاوان بە پەلە جێبەجێ ناکرێت، دڵی ئادەمیزاد پڕ بووە لە پیلانی خراپ.
\v 12 هەرچەندە بەدکار کە سەد جار تاوانی کردبێت و تەمەنێکی درێژ بژیێت، بەڵام من دەزانم کە بۆ لەخواترس کە ڕێزی خودا دەگرێت باشتر دەبێت.
\v 13 بەڵام بۆ بەدکاران چاک نابێت و وەک سێبەر ڕۆژانیان درێژە ناکێشێت، چونکە لە خودا ناترسن.
\p 
\v 14 شتێکی دیکەی بێ واتا هەیە کە لەسەر زەویدا دەکرێت، ئەمەیە: ڕاستودروستان هەن بەگوێرەی کاری بەدکارانیان بەسەردا دێت و بەدکارانیش هەن بەگوێرەی کاری ڕاستودروستانیان بەسەردا دێت. گوتم، ئەمەش هەر بێ واتایە.
\v 15 لەبەر ئەوە ئامۆژگاری دەکەم بەشدار بن لە شادی، چونکە کوا چاکە بۆ مرۆڤ لەسەر زەوی؟ بێجگە لەوەی کە بخوات و بخواتەوە و شادبێت و ئەمەی بۆ دەمێنێتەوە لە ماندووبوونەکەی بە درێژایی ژیانی، کە خودا پێیداوە لەسەر زەویدا.
\p 
\v 16 کاتێک سەرنجم دایە دانایی و ڕەنجکێشانی خەڵکی زەوی، کە شەو و ڕۆژ خەو نەدەچووە چاویان،
\v 17 هەموو ئەوەی خودا ئەنجامی داوە بینیم. کەس ناتوانێت لە کارەکانی خودا لەسەر زەوی تێ بگات. سەرەڕای ئەوەی مرۆڤ ماندوو دەبێت بۆ دۆزینەوەی بنچینەکەی، بەڵام نایدۆزێتەوە. هەرچەندە کەسی داناش دەڵێت دەزانم، بەڵام ناتوانێت بیدۆزێتەوە.
\c 9
\s1 یەک ڕووداو بۆ هەمووان
\p 
\v 1 ئیتر لە هەموو ئەوانە ڕامام و بۆم دەرکەوت کە ڕاستودروستان و دانایان و کردەوەکانیان لەژێر دەسەڵاتی خودان، بەڵام کەس نازانێت لە ڕێگەی خۆشەویستی یان ڕق لێبوونەوەوە دێت.
\v 2 هەموویان یەک چارەنووسیان هەیە، ڕاستودروست و بەدکار، چاک و خراپ، پاک و گڵاو، قوربانی سەربڕ و ئەوەی قوربانی سەرنابڕێت؛
\q1 چاکەکار و گوناهبار،
\q1 سوێندخۆر و ئەوەی دەترسێت سوێند بخوات.
\p 
\v 3 ئەمە ئەو خراپەیە کە لە پشتی هەموو ڕووداوەکانی سەر زەوییە: کە یەک چارەنووس بۆ هەمووان بێت، هەروەها دڵی ئادەمیزاد پڕە لە خراپە، شێتییش لە دڵیاندایە لە کاتێکدا زیندوون و پاشان کە دەچنە پاڵ مردووان.
\v 4 هەرکەسێک کە لەنێو زیندووان بێت، ئومێدەوارە. تەنانەت سەگی زیندووش لە شێری تۆپیو چاکترە!
\q1 
\v 5 زیندووان دەزانن کە دەمرن،
\q2 بەڵام مردووان هیچ نازانن و
\q1 لەمەودواش پاداشتیان نییە،
\q2 تەنانەت ناویان لەبیرکراوە.
\q1 
\v 6 خۆشەویستی و ڕق و
\q2 بەغیلیشیان لەمێژە لەناوچوون،
\q1 ئیتر بەشیان نییە هەتاهەتایە
\q2 لە هەموو ئەوەی لەسەر زەویدا دەکرێت.
\p 
\v 7 بڕۆ بە شادی نانی خۆت بخۆ و بە دڵێکی خۆش شەرابی خۆت بنۆشە، چونکە لەمێژە خودا لە کردەوەت ڕازییە.
\v 8 با هەموو کاتێک جلوبەرگت سپی بێت و زەیت لە سەری خۆت بدە.
\v 9 خۆشی ببینە لەگەڵ ژنەکەت کە خۆشت دەوێت، هەموو ڕۆژانی ژیانی بێ واتات، کە خودا لەسەر زەوی پێیداویت، هەموو ڕۆژانی بێ واتات، چونکە ئەمە بەشی تۆیە لە ژیان و لە ماندووبوونەکەت کە لەسەر زەوی پێوەی ماندوو دەبیت.
\v 10 ئەوەی لە دەستت دێت، بەوپەڕی هێز و تواناوە بیکە، چونکە نە کار و نە پلاندانان و نە زانین و نە دانایی نییە لە جیهانی مردووان، ئەوەی تۆ دەچیت بۆ ئەوێ.
\p 
\v 11 دیاردەیەکی نوێم لەسەر زەوی بینی:
\q1 ڕاکردن بۆ سووکەڵەکان نییە و
\q2 جەنگ بۆ پاڵەوانان نییە و
\q1 نان بۆ دانایان نییە و
\q2 دەوڵەمەندی بۆ تێگەیشتووان نییە و
\q2 پەسەندی بۆ زانایان نییە،
\q1 چونکە کات و بەخت تووشی هەمووان دێت.
\p 
\v 12 هەروەها مرۆڤ کاتی خۆی نازانێت:
\q1 وەک ئەو ماسییانەی بە تۆڕێکی لەناوبەر دەبردرێن،
\q2 یان وەک ئەو چۆلەکانەی بە تەڵەوە دەبن،
\q1 ئادەمیزادیش بە هەمان شێوەی ئەوان
\q2 لەناکاو و لە کاتێکی خراپدا دەکەونە تەڵەوە.
\s1 دانایی لە گێلایەتی باشترە
\p 
\v 13 ئەم داناییەشم لەسەر زەویدا بینی، لەلای من مەزنە:
\v 14 شارێکی بچووک و خەڵکێکی کەمی تێدابوو، پاشایەکی مەزن پەلاماری دا و ئابڵوقەی دا و قوللەی مەزنی بەدەوریدا بنیاد نا.
\v 15 ئەو شارە پیاوێکی هەژاری دانای تێدابوو، بە دانایی خۆی شارەکەی دەرباز کرد. بەڵام کەس ئەو پیاوە هەژارەی لەبیر نەما.
\v 16 منیش گوتم: «دانایی لە هێز باشترە،» بەڵام دانایی هەژاریش بە سووکی تەماشا دەکرێت و گوێ لە قسەکانی ناگیرێت.
\q1 
\v 17 قسەی بە هێمنی لەلایەن دانایان شایانی سەرنجدانە
\q2 زیاتر لە هاواری دەسەڵاتدار لەناو گێلان.
\q1 
\v 18 دانایی لە چەکی جەنگ چاکترە،
\q2 بەڵام یەک گوناهبار چاکەیەکی زۆر تێک دەدات.
\b
\c 10
\q2 
\v 1 وەک چۆن مێشی مردوو بۆنی خۆش بۆگەن دەکات،
\q2 کەمێک کاری گێلانە دەتوانێت دانایی و ڕێزی کەسێک لەناوبەرێت.
\q1 
\v 2 دڵی دانا مەیلی ڕێی ڕاست دەکات،
\q2 دڵی گێلیش مەیلی ڕێی چەوت دەکات.
\q1 
\v 3 کە گێل بە ڕێگادا دەڕوات
\q2 گێلی لێ دەبارێت،
\q2 ئیتر گێلایەتییەکەی بۆ هەموو لایەک دیارە.
\q1 
\v 4 ئەگەر تووڕەیی فەرمانڕەوا بەسەرتدا جۆشا،
\q2 شوێنی کاری خۆت بەجێمەهێڵە،
\q2 چونکە هێمنی هەڵەی گەورە ئارام دەکاتەوە.
\b
\q1 
\v 5 خراپەیەک هەیە لەسەر زەویدا بینیم،
\q2 وەک هەڵەیەکی مەزنە لەلایەن فەرمانڕەوا:
\q1 
\v 6 گێل زۆر جار لە پلەوپایەی بەرز دادەنرێت و
\q2 دەوڵەمەندەکانیش لە شوێنە نزمەکان دادەنیشن.
\q1 
\v 7 بینیم خزمەتکاران ئەسپ سوار بوون و
\q2 میران پیادە بوون وەک خزمەتکار.
\b
\q1 
\v 8 ئەوەی چاڵ هەڵکەنێت خۆی تێی دەکەوێت،
\q2 ئەوەی دیوار بڕووخێنێت مار پێیەوە دەدات.
\q1 
\v 9 ئەوەی بەرد هەڵبکەنێت ئازاری پێوە دەبینێت،
\q2 ئەوەی دار ببڕێت لە مەترسییەکەیدا دەبێت.
\b
\q1 
\v 10 ئەگەر تەور کول بێت و
\q2 دەمی تیژ نەکرێت،
\q1 هێزی زیاتری دەوێت،
\q2 بەڵام دانایی بەسوودە بۆ سەرکەوتن.
\b
\q1 
\v 11 ئەگەر پێش نوشتەکردن مار پێتەوە بدات،
\q2 ئیتر نوشتەکەر کرێیەکەی وەرناگرێت.
\b
\q1 
\v 12 قسەی زاری دانا شیرینە،
\q2 بەڵام گێل لێوەکانی خۆی هەڵیدەلووشن.
\q1 
\v 13 سەرەتای وشەکانی دەمی گێلییە،
\q2 لە کۆتاییدا دەبنە شێتێکی خراپ.
\q2 
\v 14 گێل زۆر قسە دەکات.
\b
\q1 مرۆڤ نازانێت چی دەبێت و
\q2 کێ دەتوانێت بە کەسێکی دیکە ڕابگەیەنێت
\q2 کە چی لەدوای خۆی ڕوودەدات؟
\b
\q1 
\v 15 ماندووبوونی گێل خۆی شەکەت دەکات،
\q2 بە جۆرێک نازانێت چۆن بۆ شار بچێت.
\b
\q1 
\v 16 قوڕبەسەر ئەو خاکەی کە پاشاکەی پێشتر خزمەتکار بوو و
\q2 میرەکانیشی بەیانییان لەسەر خوان دادەنیشن.
\q1 
\v 17 خۆزگە بەو خاکەی کە پاشاکەی لە نەوەی شازادە بێت و
\q2 میرەکانیشی نان لە کاتی خۆیدا بخۆن،
\q2 بۆ هێز نەک بۆ سەرخۆشی.
\b
\q1 
\v 18 بە تەمبەڵی بنمێچ دێتە خوارێ و
\q2 بە دەست شلکردنیش خانوو دڵۆپە دەکات.
\b
\q1 
\v 19 بۆ ئەوەی پێبکەنن خوان ئامادە دەکەن و
\q2 شەرابیش ژیان خۆش دەکات،
\q2 بەڵام پارە هەموو شتێکی پێ دەکرێت.
\b
\q1 
\v 20 تەنانەت لەبیری خۆشت نەفرەت لە پاشا مەکە،
\q2 لە ژووری نوستنیشت نەفرەت لە دەوڵەمەند مەکە،
\q1 چونکە چۆلەکەی ئاسمان دەنگەکەت دەگەیەنێت و
\q2 باڵداریش قسەکەت ڕادەگەیەنێت.
\c 11
\s1 نانی سەر ئاوەکان
\q1 
\v 1 نان بدە بە دەم ئاوەوە،
\q2 چونکە لە پاشەڕۆژدا دێتەوە ڕێگای خۆت.
\q1 
\v 2 بەش بدە بە حەوت کەس، بەڵێ، بە هەشتیش،
\q2 چونکە نازانیت چ کارەساتێک لەسەر زەوی ڕوودەدات.
\b
\q1 
\v 3 ئەگەر هەور پڕبێت،
\q2 باران بەسەر زەویدا دەبارێنێت.
\q1 ئەگەر دارێک بەرەو باشوور بکەوێت یان بەرەو باکوور،
\q2 ئەو شوێنەی دارەکەی لێ دەکەوێت، لەوێ دەبێت.
\q1 
\v 4 ئەوەی چاوی لە با بێت ناچێنێت،
\q2 ئەوەی سەیری هەور بکات دروێنە ناکات.
\b
\q1 
\v 5 هەروەک نازانیت کامە ڕێگای بایە،
\q2 یان چۆن کۆرپەلە لەناو سکی دایکیدا شێوەی دەکێشرێت،
\q1 بە هەمان شێوە ناتوانیت لە کارەکانی خودا تێبگەیت،
\q2 کە هەمووان دروستدەکات.
\b
\q1 
\v 6 سەر لە بەیانی تۆوی خۆت بچێنە،
\q2 سەر لە ئێوارەش دەستت شل مەکە،
\q1 چونکە نازانیت کامیان سەوز دەبێت،
\q2 ئەم یان ئەو،
\q2 یان بەرهەمی هەردووکیان وەک یەک باش دەبێت.
\s1 بەدیهێنەرت لە لاویێتیت لەبیر بێت
\q1 
\v 7 ڕووناکی شیرینە و
\q2 باشە بۆ چاوان کە خۆر ببینێت.
\q1 
\v 8 ئەگەر مرۆڤ تەمەنێکی درێژ ژیا،
\q2 با بە هەمووی دڵخۆش بێت.
\q1 بەڵام با ڕۆژانی تاریکی لەبیربێت،
\q2 چونکە زۆر دەبێت.
\q2 هەموو ئەوەی دێت بێ واتایە.
\b
\q1 
\v 9 ئەی لاو، لە سەردەمی گەنجیێتیت شادمان بە،
\q2 با لە ڕۆژانی لاویێتیت دڵت خۆش بێت.
\q1 بە ڕێگای دڵی خۆت و
\q2 بە بینینی چاوەکانتدا بڕۆ،
\q1 بەڵام بزانە کە لەسەر هەموو ئەمانە
\q2 خودا دەتهێنێت بۆ حوکم بەسەردادان.
\q1 
\v 10 پەستی لە دڵت داماڵە و
\q2 خراپە لە لەشت دووربخەوە،
\q2 چونکە نەوجەوانی و گەنجیێتی بێ واتان.
\b
\c 12
\q1 
\v 1 بەدیهێنەری خۆت لەبیر بێت
\q2 لە سەردەمی گەنجیێتیت،
\q1 پێش ئەوەی ڕۆژگاری خراپە بێت
\q2 یان ئەو ساڵانە نزیک بێتەوە کە بڵێی:
\q2 «خۆشییان تێدا نابینم،»
\q1 
\v 2 پێش ئەوەی درەوشانەوەی خۆر و
\q2 ڕووناکی و مانگ و ئەستێرە تەواو بێت،
\q2 پێش ئەوەی گەڕانەوەی هەوری باران ئاسمان تاریک بکات؛
\q1 
\v 3 ئەو ڕۆژەی پارێزەرانی ماڵ دەلەرزن،
\q2 پیاوانی بەهێز دەچەمێنەوە،
\q1 ئەو ئافرەتانەی کە ئیشی دەستاڕیان دەکرد لەبەر کەمی لە کار دەکەون،
\q2 تاریک دادێن ئەو ژنانەش کە لە پەنجەرەکانەوە تەماشا دەکەن؛
\q1 
\v 4 کاتێک دەرگاکانی بازاڕ دادەخرێن و
\q2 دەنگی هاڕین نزم دەبێتەوە؛
\q1 ئەو ڕۆژەی کە پیرەمێرد لە دەنگی چۆلەکە هەڵدەستێت،
\q2 هەرچەندە بەلایەوە گۆرانی کچەکان کز دەبن؛
\q1 
\v 5 ئەو ڕۆژەش کە خەڵک لە بەرزایی دەترسن و
\q2 لە ڕێگا تۆقیون،
\q1 کە بادەم چرۆ دەکات و
\q2 کوللەحاجی خۆی ڕادەکێشێت و
\q2 هیچ ئارەزوو نامێنێت.
\q1 ئیتر مرۆڤ بەرەو ماڵی هەتاهەتایی خۆی دەچێت و
\q2 شینگێڕەکان بە شەقامەکاندا دەسووڕێنەوە.
\b
\q1 
\v 6 لەبیرت بێت، پێش ئەوەی زنجیری زیو بپچڕێت و
\q2 قاپی زێڕین بشکێت؛
\q1 پێش ئەوەی گۆزە لەسەر کانی وردوخاش بکرێت،
\q2 یان چەرخە لەسەر بیر بشکێنرێت و
\q1 
\v 7 خۆڵ دەگەڕێتەوە سەر زەوی وەک پێشوو،
\q2 ڕۆحیش دەگەڕێتەوە لای ئەو خودایەی کە بەخشیویەتی.
\b
\q1 
\v 8 وتاربێژی ژیرمەند دەڵێت: «بێ واتایە! بێ واتایان!
\q2 هەموو شتێک بێ واتایە!»
\s1 دەرئەنجامی بابەتەکە
\p 
\v 9 سەرباری ئەوەی کە وتاربێژی ژیرمەند دانا بوو، گەلیشی فێری زانین کرد، شارەزای هەڵسەنگاندن و پشکنین و ڕێکخستنی پەندی زۆر بوو.
\v 10 وتاربێژی ژیرمەند هەوڵی دا وشە شادی بەخشەکان بدۆزێتەوە کە بە سەرڕاستی نووسراون و وشەکانی ڕاستین.
\p 
\v 11 وشەکانی پیاوی دانا وەک نەقیزە وایە، وەک بزمارە چەقیوەکانن لە پیاوانی کۆمەڵ، لەلایەن یەک شوانەوە\f + \fr 12:11 \ft مەبەستی لە خودایە.‏\f* دراون.
\v 12 ئەی ڕۆڵە، سەرەڕای ئەمانە، ئاگاداری شتەکانی دیکەش بە.
\p دانانی پەڕتووکی زۆر کۆتایی بۆ نییە، لێکۆڵینەوەی زۆریش لەش ماندوو دەکات.
\q1 
\v 13 هەموو شت ئێستا بیستراوە و
\q2 دەرئەنجامەکەی ئەوەیە:
\q1 لە خودا بترسە و ڕاسپاردەکانی بەجێبگەیەنە،
\q2 چونکە ئەمە ئەرکی سەر شانی هەموو مرۆڤە.
\q1 
\v 14 خودا حوکم بەسەر هەموو کارێکدا دەدات،
\q2 بە هەموو کارێکی نهێنیشەوە،
\q2 جا چاک بێت یان خراپ.
