\id MAT  - AÅaataha-Ainde NT -Papua New Guinea 2003 (DBL 2014) 
\h Matiyuho 
\toc1 KÉØma PÉØwÉØha Gaaha WanÉØha Matiyuho JÉØpatÉØpaisÉØhaare 
