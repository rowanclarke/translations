\v 42 \wj Empuñan \+w arco|strong="H7198"\+w* \+w y|strong="H5921"\+w* lanza. \+w Son|strong="H3808"\+w* crueles \+w e|strong="H3068"\+w* implacables. \+w Su|strong="H1992"\+w* \+w voz|strong="H6963"\+w* \+w ruge|strong="H1993"\+w* \+w como|strong="H5921"\+w* \+w el|strong="H5921"\+w* \+w mar|strong="H3220"\+w*, \+w y|strong="H5921"\+w* cabalgan \+w en|strong="H5921"\+w* formación \+w de|strong="H5921"\+w* \+w guerra|strong="H4421"\+w* \+w contra|strong="H5921"\+w* \+w ti|strong="H5921"\+w*, oh \+w hija|strong="H1323"\+w* \+w de|strong="H5921"\+w* Babilonia.\wj*  
\v 43 \wj El \+w rey|strong="H4428"\+w* de Babilonia \+w oye|strong="H8085"\+w* el informe y sus \+w manos|strong="H3027"\+w* se debilitan. La \+w angustia|strong="H6869"\+w* se apodera de él y siente dolores como de parturienta.\wj*  
\v 44 \wj \+w Ciertamente|strong="H3588"\+w* uno \+w viene|strong="H5927"\+w* \+w como|strong="H3588"\+w* un león \+w que|strong="H3588"\+w* \+w sube|strong="H5927"\+w* \+w de|strong="H5921"\+w* \+w la|strong="H5921"\+w* espesura \+w del|strong="H5921"\+w* \+w Jordán|strong="H3383"\+w* \+w a|strong="H3068"\+w* \+w la|strong="H5921"\+w* vivienda fortificada. \+w Porque|strong="H3588"\+w* muy pronto \+w lo|strong="H2088"\+w* hago huir \+w de|strong="H5921"\+w* \+w ella|strong="H5921"\+w*, \+w y|strong="H3588"\+w* \+w al|strong="H5921"\+w* \+w que|strong="H3588"\+w* \+w Yo|strong="H3588"\+w* escoja, \+w la|strong="H5921"\+w* \+w encargaré|strong="H6485"\+w*. \+w Porque|strong="H3588"\+w* ¿\+w quién|strong="H4310"\+w* \+w es|strong="H2088"\+w* semejante \+w a|strong="H3068"\+w* \+w Mí|strong="H5921"\+w*? ¿\+w Quién|strong="H4310"\+w* \+w me|strong="H5921"\+w* desafía? ¿\+w Cuál|strong="H4310"\+w* \+w es|strong="H2088"\+w* \+w el|strong="H5921"\+w* \+w pastor|strong="H7462"\+w* \+w que|strong="H3588"\+w* pueda resistirme?\wj*   
\p
\v 45 \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w* \w oigan|strong="H8085"\w* \w el|strong="H5921"\w* plan \w que|strong="H3808"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w tiene|strong="H2803"\w* \w contra|strong="H5921"\w* Babilonia \w y|strong="H5921"\w* \w lo|strong="H3808"\w* \w que|strong="H3808"\w* \w se|strong="H5921"\w* propone \w contra|strong="H5921"\w* \w los|strong="H5921"\w* \w caldeos|strong="H3778"\w*: \w Ciertamente|strong="H8085"\w* \w los|strong="H5921"\w* arrastrarán fuera \w como|strong="H5921"\w* \w corderos|strong="H6629"\w* \w del|strong="H5921"\w* \w rebaño|strong="H6629"\w* \w y|strong="H5921"\w* su prado \w será|strong="H3808"\w* desolado \w a|strong="H3068"\w* causa \w de|strong="H5921"\w* \w ellos|strong="H5921"\w*.  
\v 46 La tierra es estremecida ante el \w clamor|strong="H2201"\w*: ¡Babilonia es capturada! El \w clamor|strong="H2201"\w* es \w oído|strong="H8085"\w* entre las \w naciones|strong="H1471"\w*. Se estremece la tierra por la caída de Babilonia, y el \w clamor|strong="H2201"\w* es \w oído|strong="H8085"\w* entre las \w naciones|strong="H1471"\w*.   
\c 51  
\s1 Continuación de la profecía contra Babilonia  
\p
\v 1 \nd \+w Yavé|strong="H3068"\+w*\nd* dice: \wj \+w Ciertamente|strong="H2005"\+w* Yo envío un \+w viento|strong="H7307"\+w* destructor \+w contra|strong="H5921"\+w* Babilonia \+w y|strong="H5921"\+w* \+w contra|strong="H5921"\+w* sus \+w habitantes|strong="H3427"\+w* \+w que|strong="H5921"\+w* \+w se|strong="H5921"\+w* \+w levantan|strong="H6965"\+w* \+w contra|strong="H5921"\+w* \+w Mí|strong="H5921"\+w*.\wj*  
\v 2 \wj \+w Enviaré|strong="H7971"\+w* aventadores \+w contra|strong="H5921"\+w* Babilonia \+w que|strong="H3588"\+w* \+w la|strong="H5921"\+w* aventarán \+w y|strong="H3588"\+w* vaciarán \+w su|strong="H3588"\+w* tierra. \+w Estarán|strong="H1961"\+w* \+w contra|strong="H5921"\+w* \+w ella|strong="H5921"\+w* \+w en|strong="H5921"\+w* \+w el|strong="H5921"\+w* \+w día|strong="H3117"\+w* \+w de|strong="H5921"\+w* \+w su|strong="H3588"\+w* aflicción \+w y|strong="H3588"\+w* \+w en|strong="H5921"\+w* \+w todo|strong="H5439"\+w* \+w su|strong="H3588"\+w* \+w alrededor|strong="H5439"\+w*.\wj*  
\v 3 \wj \+w Que|strong="H1869"\+w* no se \+w vaya|strong="H5927"\+w* \+w el|strong="H3605"\+w* arquero ni se retire \+w el|strong="H3605"\+w* \+w que|strong="H1869"\+w* se cubre con \+w la|strong="H3605"\+w* coraza. No perdonen \+w a|strong="H3068"\+w* sus jóvenes. Exterminen \+w a|strong="H3068"\+w* \+w todo|strong="H3605"\+w* su \+w ejército|strong="H6635"\+w*.\wj*  
\v 4 \wj \+w Caigan|strong="H5307"\+w* \+w muertos|strong="H2491"\+w* en la tierra de los \+w caldeos|strong="H3778"\+w* y sean \+w alanceados|strong="H1856"\+w* en sus \+w calles|strong="H2351"\+w*,\wj*  
\v 5 \wj \+w porque|strong="H3588"\+w* \+w Israel|strong="H3478"\+w* \+w y|strong="H3588"\+w* \+w Judá|strong="H3063"\+w* \+w no|strong="H3808"\+w* están viudas \+w de|strong="H3588"\+w* \+w su|strong="H3588"\+w* \+nd ʼElohim\+nd*, \+w de|strong="H3588"\+w* \+nd \+w Yavé|strong="H3068"\+w*\+nd* \+w de|strong="H3588"\+w* las huestes, \+w aunque|strong="H3588"\+w* \+w su|strong="H3588"\+w* tierra esté \+w llena|strong="H4390"\+w* \+w de|strong="H3588"\+w* pecado \+w contra|strong="H3478"\+w* \+w el|strong="H3588"\+w* \+w Santo|strong="H6918"\+w* \+w de|strong="H3588"\+w* \+w Israel|strong="H3478"\+w*.\wj*   
\p
\v 6 Huyan \w de|strong="H3588"\w* \w en|strong="H8432"\w* \w medio|strong="H8432"\w* \w de|strong="H3588"\w* Babilonia, \w y|strong="H3588"\w* cada uno salve \w su|strong="H1931"\w* \w vida|strong="H5315"\w*. \w No|strong="H3588"\w* sean destruidos \w en|strong="H8432"\w* \w el|strong="H1931"\w* castigo \w a|strong="H3068"\w* \w ella|strong="H1931"\w*. \w Porque|strong="H3588"\w* \w es|strong="H1931"\w* \w tiempo|strong="H6256"\w* \w de|strong="H3588"\w* \w venganza|strong="H5360"\w* \w de|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*. \w Él|strong="H1931"\w* \w va|strong="H3068"\w* \w a|strong="H3068"\w* darle \w su|strong="H1931"\w* retribución.  
\v 7 Babilonia fue una copa \w de|strong="H5921"\w* \w oro|strong="H2091"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w mano|strong="H3027"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w que|strong="H5921"\w* embriagó \w a|strong="H3068"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* tierra. \w Las|strong="H5921"\w* \w naciones|strong="H1471"\w* \w bebieron|strong="H8354"\w* \w de|strong="H5921"\w* su \w vino|strong="H3196"\w*. \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w* están enloquecidas.  
\v 8 ¡Babilonia \w cae|strong="H5307"\w* \w de|strong="H5921"\w* repente \w y|strong="H5921"\w* es \w quebrantada|strong="H7665"\w*! Giman \w por|strong="H5921"\w* \w ella|strong="H5921"\w*. \w Tomen|strong="H3947"\w* \w bálsamo|strong="H6875"\w* \w para|strong="H5921"\w* su herida. Tal vez pueda ser sanada.   
\p
\v 9 Quisimos sanar \w a|strong="H3068"\w* Babilonia, \w pero|strong="H3588"\w* \w no|strong="H3808"\w* \w sanó|strong="H7495"\w*. Abandónenla. \w Vayamos|strong="H3212"\w* cada uno \w a|strong="H3068"\w* nuestra tierra, \w porque|strong="H3588"\w* \w su|strong="H3588"\w* castigo llega \w hasta|strong="H5704"\w* \w el|strong="H3588"\w* \w cielo|strong="H8064"\w*. \w Se|strong="H3808"\w* \w levanta|strong="H5375"\w* \w hasta|strong="H5704"\w* las nubes.  
\v 10 \nd \+w Yavé|strong="H3068"\+w*\nd* produjo nuestra vindicación. ¡Vayamos, anunciemos \w en|strong="H3318"\w* \w Sion|strong="H6726"\w* las proezas de \nd \+w Yavé|strong="H3068"\+w*\nd* nuestro \nd ʼElohim\nd*!   
\p
\v 11 ¡Afilen \w las|strong="H5921"\w* flechas \w y|strong="H3588"\w* embracen \w el|strong="H1931"\w* escudo! \nd \+w Yavé|strong="H3068"\+w*\nd* incita \w el|strong="H1931"\w* \w espíritu|strong="H7307"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w Media|strong="H4074"\w*, \w cuyo|strong="H1931"\w* plan \w es|strong="H1931"\w* \w destruir|strong="H7843"\w* \w a|strong="H3068"\w* Babilonia. \w Porque|strong="H3588"\w* \w la|strong="H1931"\w* retribución \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w es|strong="H1931"\w* \w la|strong="H1931"\w* \w venganza|strong="H5360"\w* \w de|strong="H5921"\w* \w su|strong="H1931"\w* \w Templo|strong="H1964"\w* destruido.  
\v 12 ¡\w Alcen|strong="H5375"\w* \w bandera|strong="H5251"\w* contra \w los|strong="H3427"\w* \w muros|strong="H2346"\w* \w de|strong="H3588"\w* Babilonia! ¡Refuercen \w la|strong="H1571"\w* guardia, pongan \w centinelas|strong="H8104"\w* \w y|strong="H1571"\w* dispongan celadas! \w Porque|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w no|strong="H6213"\w* solo propone, \w sino|strong="H3588"\w* ejecuta \w lo|strong="H6213"\w* \w que|strong="H3588"\w* \w habló|strong="H1696"\w* contra \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* \w de|strong="H3588"\w* Babilonia.  
\v 13 ¡Oh tú \w que|strong="H5921"\w* vives \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w muchas|strong="H7227"\w* \w aguas|strong="H4325"\w*, \w y|strong="H5921"\w* abundas \w en|strong="H5921"\w* tus riquezas! Tu \w fin|strong="H7093"\w* llega, \w la|strong="H5921"\w* medida \w de|strong="H5921"\w* tu \w fin|strong="H7093"\w*.  
\v 14 \nd \+w Yavé|strong="H3068"\+w*\nd* \w de|strong="H5921"\w* \w las|strong="H5921"\w* huestes \w juró|strong="H7650"\w* \w por|strong="H5921"\w* \w Él|strong="H5921"\w* mismo: \wj \+w Aunque|strong="H3588"\+w* tu población sea \+w más|strong="H3588"\+w* \+w que|strong="H3588"\+w* \+w las|strong="H5921"\+w* langostas, \+w sobre|strong="H5921"\+w* \+w ti|strong="H5921"\+w* alzan \+w los|strong="H5921"\+w* gritos \+w de|strong="H5921"\+w* victoria.\wj*   
\p
\v 15 \w Él|strong="H6213"\w* \w hizo|strong="H6213"\w* \w la|strong="H2451"\w* tierra con su \w poder|strong="H3581"\w*. \w La|strong="H2451"\w* estableció con su \w sabiduría|strong="H2451"\w* y \w extendió|strong="H5186"\w* los \w cielos|strong="H8064"\w* con su \w entendimiento|strong="H8394"\w*.  
\v 16 Las \w aguas|strong="H4325"\w* \w en|strong="H3318"\w* los \w cielos|strong="H8064"\w* retumban \w a|strong="H3068"\w* su trueno. Eleva las \w nubes|strong="H5387"\w* desde \w el|strong="H6213"\w* horizonte. Desata la \w lluvia|strong="H4306"\w* con \w relámpagos|strong="H1300"\w* y \w saca|strong="H3318"\w* \w el|strong="H6213"\w* \w viento|strong="H7307"\w* \w de|strong="H5414"\w* sus depósitos.   
\p
\v 17 \w Todo|strong="H3605"\w* hombre \w se|strong="H3808"\w* embrutece \w por|strong="H3588"\w* falta \w de|strong="H3588"\w* \w conocimiento|strong="H1847"\w*. \w Todo|strong="H3605"\w* orfebre \w se|strong="H3808"\w* avergüenza \w de|strong="H3588"\w* \w su|strong="H3588"\w* ídolo \w porque|strong="H3588"\w* sus ídolos \w de|strong="H3588"\w* fundición \w son|strong="H3588"\w* un \w engaño|strong="H8267"\w*, \w y|strong="H3588"\w* \w no|strong="H3808"\w* hay aliento \w en|strong="H3588"\w* \w ellos|strong="H3605"\w*.  
\v 18 Son vanos, \w obra|strong="H4639"\w* digna \w de|strong="H6256"\w* burla. \w Ellos|strong="H1992"\w* perecerán en \w el|strong="H1992"\w* \w tiempo|strong="H6256"\w* \w de|strong="H6256"\w* \w su|strong="H1992"\w* castigo.  
\v 19 \w No|strong="H3808"\w* \w es|strong="H1931"\w* \w así|strong="H3588"\w* \w la|strong="H1931"\w* \w herencia|strong="H5159"\w* \w de|strong="H3588"\w* \w Jacob|strong="H3290"\w*, \w porque|strong="H3588"\w* \w Él|strong="H1931"\w* \w es|strong="H1931"\w* \w el|strong="H1931"\w* Creador \w de|strong="H3588"\w* \w todas|strong="H3605"\w* las cosas. Israel \w es|strong="H1931"\w* \w la|strong="H1931"\w* \w tribu|strong="H7626"\w* \w de|strong="H3588"\w* \w su|strong="H1931"\w* \w heredad|strong="H5159"\w*. \w Su|strong="H1931"\w* \w nombre|strong="H8034"\w* \w es|strong="H1931"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w de|strong="H3588"\w* las huestes.   
\p
\v 20 \wj Tú fuiste mi mazo y mis \+w armas|strong="H3627"\+w* de \+w guerra|strong="H4421"\+w*: Por medio de ti quebranté \+w naciones|strong="H1471"\+w*, aniquilé \+w reinos|strong="H4467"\+w*,\wj*  
\v 21 \wj destrocé \+w caballos|strong="H5483"\+w* y jinetes, destrocé el carruaje de guerra y al que lo conduce,\wj*  
\v 22 \wj quebranté hombres y mujeres, quebranté al \+w anciano|strong="H2205"\+w* y al \+w niño|strong="H5288"\+w*, quebranté al joven y \+w a|strong="H3068"\+w* la doncella,\wj*  
\v 23 \wj quebranté al \+w pastor|strong="H7462"\+w* y al rebaño, quebranté al labrador y su yunta, y quebranté \+w gobernadores|strong="H6346"\+w* y magistrados.\wj*   
\p
\v 24 \wj Pero ahora \+w pagaré|strong="H7999"\+w* \+w a|strong="H3068"\+w* Babilonia y \+w a|strong="H3068"\+w* \+w todos|strong="H3605"\+w* \+w los|strong="H3427"\+w* \+w caldeos|strong="H3778"\+w* \+w todo|strong="H3605"\+w* \+w el|strong="H3605"\+w* \+w mal|strong="H7451"\+w* \+w que|strong="H3605"\+w* \+w hicieron|strong="H6213"\+w* \+w a|strong="H3068"\+w* \+w Sion|strong="H6726"\+w* en presencia \+w de|strong="H5869"\+w* \+w él|strong="H3605"\+w*, \wj*\w dice|strong="H5002"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.   
\p
\v 25 \wj \+w En|strong="H5921"\+w* verdad \+w Yo|strong="H4480"\+w* estoy \+w contra|strong="H5921"\+w* \+w ti|strong="H5921"\+w*, oh volcán destructor, \+w que|strong="H4480"\+w* \+w destruyó|strong="H7843"\+w* \+w toda|strong="H3605"\+w* \+w la|strong="H5921"\+w* tierra, \wj*\w dice|strong="H5002"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*. \wj \+w Extenderé|strong="H5186"\+w* \+w contra|strong="H5921"\+w* \+w ti|strong="H5921"\+w* \+w mi|strong="H5921"\+w* brazo \+w y|strong="H5921"\+w* \+w te|strong="H5921"\+w* echaré \+w a|strong="H3068"\+w* rodar \+w por|strong="H5921"\+w* \+w las|strong="H5921"\+w* peñas. Serás un volcán extinguido.\wj*  
\v 26 \wj \+w No|strong="H3808"\+w* \+w tomarán|strong="H3947"\+w* piedra \+w angular|strong="H6438"\+w* \+w de|strong="H4480"\+w* \+w ti|strong="H4480"\+w*, \+w ni|strong="H3808"\+w* piedra \+w para|strong="H3588"\+w* cimientos. \+w Porque|strong="H3588"\+w* \+w serás|strong="H1961"\+w* una desolación \+w perpetua|strong="H5769"\+w*, \wj*\w dice|strong="H5002"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.   
\p
\v 27 \w Alcen|strong="H5375"\w* estandarte \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra. Toquen \w trompeta|strong="H7782"\w* \w entre|strong="H5921"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w*. Convoquen \w a|strong="H3068"\w* \w la|strong="H5921"\w* guerra santa. Convoquen \w contra|strong="H5921"\w* \w ella|strong="H5921"\w* \w los|strong="H5921"\w* \w reinos|strong="H4467"\w* \w de|strong="H5921"\w* Ararat, \w de|strong="H5921"\w* Mini \w y|strong="H5921"\w* \w de|strong="H5921"\w* Asquenaz. Designen \w contra|strong="H5921"\w* \w ella|strong="H5921"\w* un capitán. Suban \w caballos|strong="H5483"\w* \w como|strong="H5921"\w* langostas erizadas.  
\v 28 Consagren \w a|strong="H3068"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w* \w contra|strong="H5921"\w* \w ella|strong="H5921"\w*, \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w Media|strong="H4074"\w* \w con|strong="H5921"\w* sus oficiales \w y|strong="H5921"\w* \w todos|strong="H3605"\w* sus magistrados, \w y|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* su dominio.  
\v 29 \w Tiembla|strong="H7493"\w* \w la|strong="H5921"\w* tierra \w y|strong="H3588"\w* \w se|strong="H5921"\w* aflige, \w porque|strong="H3588"\w* todos \w los|strong="H3427"\w* planes \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w contra|strong="H5921"\w* Babilonia \w son|strong="H3588"\w* confirmados \w para|strong="H5921"\w* convertir \w su|strong="H3588"\w* tierra \w de|strong="H5921"\w* Babilonia \w en|strong="H5921"\w* una desolación despoblada.  
\v 30 \w Los|strong="H3427"\w* \w valientes|strong="H1368"\w* \w de|strong="H3898"\w* Babilonia \w dejan|strong="H2308"\w* \w de|strong="H3898"\w* luchar. \w Se|strong="H1961"\w* quedan en sus \w fortalezas|strong="H4679"\w*. Su fuerza \w está|strong="H1961"\w* exhausta. \w Son|strong="H1961"\w* \w como|strong="H1961"\w* mujeres. Sus casas \w están|strong="H3427"\w* \w quemadas|strong="H3341"\w*, rotos \w los|strong="H3427"\w* \w cerrojos|strong="H1280"\w* \w de|strong="H3898"\w* sus puertas.  
\v 31 Un corredor releva \w a|strong="H3068"\w* \w otro|strong="H7097"\w*. Un \w mensajero|strong="H5046"\w* releva \w a|strong="H3068"\w* \w otro|strong="H7097"\w* \w para|strong="H3588"\w* \w anunciar|strong="H5046"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w* \w de|strong="H3588"\w* Babilonia \w que|strong="H3588"\w* \w su|strong="H3588"\w* \w ciudad|strong="H5892"\w* fue totalmente capturada:  
\v 32 Los vados fueron tomados. Las fortificaciones fueron incendiadas. Los guerreros están consternados.  
