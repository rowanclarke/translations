\v 8 \w knowing|strong="G1492"\w* \w that|strong="G3754"\w* \w whatever|strong="G1437"\w* \w good|strong="G1437"\w* \w each|strong="G1538"\w* \w one|strong="G5100"\w* \w does|strong="G4160"\w*, \w he|strong="G3754"\w* \w will|strong="G2962"\w* \w receive|strong="G2865"\w* \w the|strong="G3754"\w* \w same|strong="G3778"\w* again \w from|strong="G3844"\w* \w the|strong="G3754"\w* \w Lord|strong="G2962"\w*, \w whether|strong="G1535"\w* \w he|strong="G3754"\w* \w is|strong="G3778"\w* \w slave|strong="G1401"\w* \w or|strong="G1535"\w* \w free|strong="G1658"\w*.\f + \fr 6:8 \ft It pays to do good!\f*   
\p
\v 9 \w And|strong="G2532"\w* \w masters|strong="G2962"\w*, \w be|strong="G1510"\w* \w the|strong="G1722"\w* \w same|strong="G2532"\w* \w way|strong="G1722"\w* towards \w them|strong="G3588"\w*, \w giving|strong="G4160"\w* \w up|strong="G2532"\w* threatening, \w knowing|strong="G1492"\w* \w that|strong="G3754"\w* \w your|strong="G2962"\w* \w own|strong="G1438"\w* \w Master|strong="G2962"\w* \w is|strong="G1510"\w* \w in|strong="G1722"\w* \w heaven|strong="G3772"\w*, \w and|strong="G2532"\w* \w there|strong="G2532"\w* \w is|strong="G1510"\w* \w no|strong="G3756"\w* \w partiality|strong="G4382"\w* \w with|strong="G1722"\w* \w Him|strong="G3588"\w*.   
\ms1 Spiritual warfare  
\p
\v 10 \w Finally|strong="G3064"\w*, \w my|strong="G1722"\w* brothers,\f + \fr 6:10 \ft Only some 3% of the Greek manuscripts, of objectively inferior quality, omit “my brothers” (as in NIV, NASB, LB, TEV, etc.), but since the whole letter is written to Christians, there really is no doubt. Besides, how could an unbeliever put on the full armor of God? Note that Paul writes “our” wrestling match—apostles are also under attack, not to mention pastors, etc.\f* \w be|strong="G2532"\w* \w strong|strong="G1743"\w* \w in|strong="G1722"\w* \w the|strong="G1722"\w* \w Lord|strong="G2962"\w* \w and|strong="G2532"\w* \w in|strong="G1722"\w* \w His|strong="G1722"\w* \w mighty|strong="G2532"\w* \w power|strong="G2904"\w*.  
\v 11 \w Put|strong="G1746"\w* \w on|strong="G1746"\w* \w the|strong="G4314"\w* \w full|strong="G3833"\w* \w armor|strong="G3833"\w* \w of|strong="G2316"\w* \w God|strong="G2316"\w* \w so|strong="G4314"\w* \w as|strong="G2316"\w* \w to|strong="G4314"\w* \w be|strong="G1410"\w* \w able|strong="G1410"\w* \w to|strong="G4314"\w* \w stand|strong="G2476"\w* \w firm|strong="G2476"\w* \w against|strong="G4314"\w* \w the|strong="G4314"\w* stratagems \w of|strong="G2316"\w* \w the|strong="G4314"\w* \w devil|strong="G1228"\w*.  
\v 12 \w Because|strong="G3754"\w*, \w our|strong="G2532"\w* wrestling match\f + \fr 6:12 \ft The word here is a noun, not a verb, and means precisely ‘wrestling match’. A wrestling match is based on violent physical contact, and the Holy Spirit, through Paul, is advising us that we are in such a match, and the opponents are malignant spirits of all ranks. The ‘doctrine’ to be found in some circles that Christians can't be attacked by demons is totally and dangerously false.\f* \w is|strong="G1510"\w* \w not|strong="G3756"\w* \w against|strong="G4314"\w* \w flesh|strong="G4561"\w* \w and|strong="G2532"\w* blood,\f + \fr 6:12 \ft Even though people may indeed act as our enemies, we need to keep in mind that they are only being used by the \+nd real\+nd* enemy.\f* \w but|strong="G2532"\w* \w against|strong="G4314"\w* \w the|strong="G1722"\w* principalities, \w against|strong="G4314"\w* \w the|strong="G1722"\w* \w authorities|strong="G1849"\w*, \w against|strong="G4314"\w* \w the|strong="G1722"\w* world-rulers \w of|strong="G2532"\w* \w the|strong="G1722"\w* \w darkness|strong="G4655"\w* \w of|strong="G2532"\w* \w this|strong="G3778"\w* age, \w against|strong="G4314"\w* \w the|strong="G1722"\w* malignant spirits \w in|strong="G1722"\w* \w the|strong="G1722"\w* \w heavenly|strong="G2032"\w* realms.  
\v 13 \w That|strong="G2443"\w* \w is|strong="G3588"\w* \w why|strong="G1223"\w* \w you|strong="G1722"\w* \w must|strong="G3588"\w* \w take|strong="G1410"\w* \w up|strong="G2476"\w* \w the|strong="G1722"\w* \w full|strong="G3833"\w* \w armor|strong="G3833"\w* \w of|strong="G2250"\w* \w God|strong="G2316"\w*, \w so|strong="G2443"\w* \w that|strong="G2443"\w* \w you|strong="G1722"\w* \w may|strong="G2532"\w* \w be|strong="G2532"\w* \w able|strong="G1410"\w* \w to|strong="G2443"\w* resist \w in|strong="G1722"\w* \w the|strong="G1722"\w* \w evil|strong="G4190"\w* \w day|strong="G2250"\w*, \w to|strong="G2443"\w* \w stand|strong="G2476"\w* \w firm|strong="G2476"\w*, \w with|strong="G1722"\w* everything \w in|strong="G1722"\w* \w place|strong="G1722"\w*.   
\p
\v 14 \w So|strong="G3767"\w* \w stand|strong="G2476"\w* \w firm|strong="G2476"\w*, \w having|strong="G2532"\w* belted \w your|strong="G2532"\w* \w waist|strong="G3751"\w* \w with|strong="G1722"\w* truth,\f + \fr 6:14 \ft Any lack of truth or righteousness in our lives will leave us vulnerable to attack.\f* \w having|strong="G2532"\w* \w put|strong="G1746"\w* \w on|strong="G1722"\w* \w the|strong="G1722"\w* \w breastplate|strong="G2382"\w* \w of|strong="G2532"\w* \w righteousness|strong="G1343"\w*,  
\v 15 \w and|strong="G2532"\w* \w having|strong="G2532"\w* \w shod|strong="G5265"\w* \w your|strong="G2532"\w* \w feet|strong="G4228"\w* \w with|strong="G1722"\w* \w the|strong="G1722"\w* readiness \w of|strong="G2532"\w* \w the|strong="G1722"\w* \w Gospel|strong="G2098"\w* \w of|strong="G2532"\w* \w the|strong="G1722"\w* \w peace|strong="G1515"\w*;  
\v 16 above \w all|strong="G3956"\w*, having taken \w up|strong="G1722"\w* \w the|strong="G1722"\w* \w shield|strong="G2375"\w* \w of|strong="G1722"\w* \w the|strong="G1722"\w* \w faith|strong="G4102"\w*, \w with|strong="G1722"\w* \w which|strong="G3739"\w* \w you|strong="G3739"\w* \w will|strong="G3739"\w* \w be|strong="G1410"\w* \w able|strong="G1410"\w* \w to|strong="G1410"\w* \w quench|strong="G4570"\w* \w all|strong="G3956"\w* \w the|strong="G1722"\w* \w flaming|strong="G4448"\w* arrows\f + \fr 6:16 \ft If it is faith that quenches these arrows, then they probably come in the form of doubts and fears.\f* \w of|strong="G1722"\w* \w the|strong="G1722"\w* \w malignant|strong="G4190"\w* \w one|strong="G3739"\w*;  
\v 17 \w also|strong="G2532"\w*, grasp \w the|strong="G2532"\w* \w helmet|strong="G4030"\w* \w of|strong="G4151"\w* \w the|strong="G2532"\w* \w salvation|strong="G4992"\w* \w and|strong="G2532"\w* \w the|strong="G2532"\w* \w sword|strong="G3162"\w* \w of|strong="G4151"\w* \w the|strong="G2532"\w* \w Spirit|strong="G4151"\w*, \w which|strong="G3739"\w* \w is|strong="G1510"\w* \w God|strong="G2316"\w*'s \w Word|strong="G4487"\w* spoken;\f + \fr 6:17 \ft ρημα (rather than λογος)—the implication appears to be that we must speak the Word. Well, how else can you \+nd use\+nd* the ‘Sword’?\f*  
\v 18 \w praying|strong="G4336"\w* \w at|strong="G1722"\w* \w all|strong="G3956"\w* \w times|strong="G2540"\w* \w in|strong="G1722"\w* \w the|strong="G1722"\w* \w Spirit|strong="G4151"\w*, using \w every|strong="G3956"\w* \w prayer|strong="G4335"\w* \w and|strong="G2532"\w* \w petition|strong="G1162"\w*, yes \w being|strong="G2532"\w* watchful \w to|strong="G1519"\w* \w this|strong="G3588"\w* \w end|strong="G1519"\w* \w with|strong="G1722"\w* \w all|strong="G3956"\w* \w perseverance|strong="G4343"\w* \w and|strong="G2532"\w* \w petition|strong="G1162"\w* \w for|strong="G1519"\w* \w all|strong="G3956"\w* \w the|strong="G1722"\w* saints  
\v 19 —\w on|strong="G1722"\w* \w my|strong="G1722"\w* \w behalf|strong="G5228"\w* \w too|strong="G2532"\w*,\f + \fr 6:19 \ft We all need prayer, even apostles.\f* \w that|strong="G2443"\w* \w when|strong="G2532"\w* \w I|strong="G1473"\w* open \w my|strong="G1722"\w* \w mouth|strong="G4750"\w* \w utterance|strong="G3056"\w* \w may|strong="G2532"\w* \w be|strong="G2532"\w* \w given|strong="G1325"\w* \w to|strong="G2443"\w* \w me|strong="G1325"\w* \w with|strong="G1722"\w* \w boldness|strong="G3954"\w*, \w to|strong="G2443"\w* \w make|strong="G1107"\w* \w known|strong="G1107"\w* \w the|strong="G1722"\w* \w mystery|strong="G3466"\w* \w of|strong="G3056"\w* \w the|strong="G1722"\w* \w Gospel|strong="G2098"\w*,  
\v 20 \w for|strong="G5228"\w* \w which|strong="G3739"\w* \w I|strong="G1473"\w* \w am|strong="G1473"\w* \w an|strong="G1722"\w* \w ambassador|strong="G4243"\w* \w in|strong="G1722"\w* \w chains|strong="G1210"\w*; \w that|strong="G2443"\w* \w I|strong="G1473"\w* \w may|strong="G2443"\w* declare \w it|strong="G3739"\w* \w boldly|strong="G3955"\w*,\f + \fr 6:20 \ft If you are in prison because you spoke out, to keep on doing so does require boldness and courage.\f* \w as|strong="G5613"\w* \w I|strong="G1473"\w* \w ought|strong="G1163"\w* \w to|strong="G2443"\w* \w do|strong="G1722"\w*.   
\ms1 Closing greetings  
\p
