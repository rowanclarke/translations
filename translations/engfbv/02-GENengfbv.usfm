\v 1 \w Joseph|strong="H3130"\w* \w went|strong="H3130"\w* \w to|strong="H5046"\w* \w report|strong="H5046"\w* \w to|strong="H5046"\w* \w Pharaoh|strong="H6547"\w* \w and|strong="H6629"\w* \w told|strong="H5046"\w* \w him|strong="H5046"\w*, “\w My|strong="H3605"\w* father \w and|strong="H6629"\w* brothers, along \w with|strong="H3605"\w* \w their|strong="H3605"\w* \w flocks|strong="H6629"\w* \w and|strong="H6629"\w* \w herds|strong="H1241"\w* \w and|strong="H6629"\w* \w all|strong="H3605"\w* \w their|strong="H3605"\w* possessions, \w have|strong="H3605"\w* arrived \w from|strong="H5046"\w* \w the|strong="H3605"\w* land \w of|strong="H3605"\w* \w Canaan|strong="H3667"\w* \w and|strong="H6629"\w* \w now|strong="H2005"\w* \w they|strong="H3605"\w*'re \w here|strong="H2005"\w* \w in|strong="H6629"\w* \w Goshen|strong="H1657"\w*.”  
