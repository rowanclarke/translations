\v 6 \w Ellos|strong="G3588"\w* han dado \w testimonio|strong="G3140"\w* \w de|strong="G3588"\w* \w tu|strong="G4771"\w* amor \w delante|strong="G1799"\w* \w de|strong="G3588"\w* \w la|strong="G3588"\w* \w iglesia|strong="G1577"\w*. \w Harás|strong="G4160"\w* \w bien|strong="G2573"\w* \w en|strong="G3588"\w* ayudarlos \w a|strong="G1799"\w* seguir \w su|strong="G3588"\w* viaje \w de|strong="G3588"\w* \w una|strong="G3588"\w* manera digna \w de|strong="G3588"\w* \w Dios|strong="G2316"\w*.   
\p
\v 7 \w Porque|strong="G1063"\w* \w ellos|strong="G3588"\w* \w salieron|strong="G1831"\w* \w por|strong="G5228"\w* causa \w del|strong="G3588"\w* \w Nombre|strong="G3686"\w*, \w sin|strong="G3367"\w* \w recibir|strong="G2983"\w* \w nada|strong="G3367"\w* \w de|strong="G5228"\w* \w los|strong="G3588"\w* gentiles.   
\p
\v 8 \w Por|strong="G2443"\w* eso \w debemos|strong="G3784"\w* recibir \w a|strong="G2443"\w* \w tales|strong="G5108"\w* personas, \w para|strong="G2443"\w* \w que|strong="G3588"\w* \w seamos|strong="G1096"\w* colaboradores \w de|strong="G3588"\w* \w la|strong="G3588"\w* verdad.   
