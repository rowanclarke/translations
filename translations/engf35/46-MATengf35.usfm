\v 26 \w Blind|strong="G5185"\w* \w Pharisee|strong="G5330"\w*! \w First|strong="G4413"\w* \w cleanse|strong="G2511"\w* \w the|strong="G2532"\w* \w inside|strong="G1787"\w* \w of|strong="G2532"\w* \w the|strong="G2532"\w* \w cup|strong="G4221"\w* \w and|strong="G2532"\w* \w the|strong="G2532"\w* \w dish|strong="G3953"\w*, \w so|strong="G2443"\w* \w that|strong="G2443"\w* \w their|strong="G2532"\w* \w outside|strong="G1622"\w* \w may|strong="G2532"\w* \w also|strong="G2532"\w* \w be|strong="G1096"\w* \w clean|strong="G2513"\w*.   
