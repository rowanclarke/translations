\id 2PE - Biblica® Open Igbo Contemporary Bible 2020 
\h 2 Pita 
\toc1 2 Pita 
\toc2 2 Pita 
\toc3 2Pt 
\mt1 2 Pita 
\c 1  
\p  
\v 1 Ọ bụ Saimọn Pita, odibo na onyeozi nke Jisọs Kraịst, 
\b  
\p Na-edegara ndị niile anyị na ha ketara otu ụdị okwukwe a dị oke ọnụahịa, nʼime ezi omume nke Chineke na Onye nzọpụta anyị Jisọs Kraịst akwụkwọ ozi a: 
\b  
\p  
\v 2 Ka amara na udo bara unu ụba, site na mmazu nke Chineke na nke Jisọs Onyenwe anyị. 
\b  
\s1 Ọkpụkpọ na nhọpụta Chineke 
\p  
\v 3 O sitela nʼike o ji bụrụ Chi nye anyị ihe niile dị anyị mkpa ibi ndụ na-asọpụrụ ya, site nʼọmụma nke anyị mara ya, bụ onye ahụ kpọrọ anyị site nʼebube ya na ịdị mma ya.  
\v 4 O sitela nʼihe ndị a nye anyị nkwa dị ukwuu na nke dị oke ọnụahịa, ka anyị site na ha keta oke nʼụdịdị nsọ ya, si otu a gbanarị ịrụ arụ dị nʼụwa, nke ọchịchọ ọjọọ na-ebute. 
\p  
\v 5 Nʼihi nke a, gbalịsienụ ike ịtụkwasị ịdị mma nʼelu okwukwe unu, ma na-atụkwasịkwanụ ihe ọmụma nʼelu ịdị mma,  
\v 6 tụkwasịkwanụ imerụ ihe nʼoke nʼelu ihe ọmụma, tụkwasịkwanụ ntachiobi nʼelu imerụ ihe na oke, ma na-atụkwasịkwanụ ibi ndụ dị ka ndị Chineke nʼelu ntachiobi.  
\v 7 Tụkwasịkwanụ obiọma nye ụmụnna nʼelu ibi ndụ dị ka ndị Chineke, ma na-atụkwasịkwanụ ịhụnanya nʼelu obiọma nye ụmụnna.  
\v 8 Ọ bụrụ na unu enwe ihe ndị a nʼụzọ ha jubigakwara oke nʼime unu, mgbe ahụ ha ga-eme ka unu ndị na-adịghị amị mkpụrụ, bụrụ ndị na-amị mkpụrụ, na ndị bara uru nʼihe unu maara banyere Onyenwe anyị Jisọs Kraịst.  
\v 9 Ma onye ọbụla na-atụkwasịghị ihe ndị a nʼokwukwe ya nọ nʼọchịchịrị. Ọ naghị ahụ ụzọ. Ọ bụkwa onye na-echefu na a sachapụla ya mmehie ya, ndị o mere nʼoge gara aga. 
\p  
\v 10 Nʼihi ya ụmụnna m, gbalịsienụ ike iguzosike nʼọkpụkpọ na nhọpụta unu. Nke a ga-eme ka unu hapụ ịsọ ngọngọ maọbụ daa.  
\v 11 Nʼụzọ dị otu a, a ga-enye unu ohere dị ukwuu iji bata nʼalaeze ebighị ebi nke Onyenwe anyị na Onye nzọpụta anyị Jisọs Kraịst. 
\s1 Okwu amụma nke Akwụkwọ nsọ 
\p  
\v 12 Aga m na-aga nʼihu na-echetara unu ihe ndị a site nʼoge ruo nʼoge. Ọ bụ ezie na unu maara na ha na-eguzosikwa ike nʼeziokwu ahụ unu natara.  
\v 13 Ana m agụ ya nʼihe ziri ezi ịkpọte mmụọ unu na uche unu site nʼichetara unu ihe ndị a ugbu a m dị ndụ nʼanụ ahụ a.  
\v 14 Nʼihi na Onyenwe anyị Jisọs Kraịst agwala m hoohaa, na m ga-eyipụ\f + \fr 1:14 \ft Maọbụ, \fqa a ga m anwụ\f* ya nʼoge na-adịghị anya.  
\v 15 Aga m agbalịsi ike ịhụ na mgbe m hapụchara ụwa nke a, unu ga na-echeta ihe ndị a mgbe niile. 
\s1 Eso m jiri anya m hụ Jisọs 
\p  
\v 16 Ihe niile anyị na-akọrọ unu abụghị akụkọ ifo mmadụ kọrọ site nʼamamihe ya. Nʼihi na anyị kọwaara unu ihe banyere ike Onyenwe anyị Jisọs Kraịst na ọbịbịa ọ ga-abịa ọzọ. Ọ bụ anya anyị abụọ ka anyị ji hụ ebube nke ịbụ eze ya.  
\v 17 Nʼihi na ọ natara nsọpụrụ na ebube site nʼaka Chineke bụ Nna mgbe olu ahụ si nʼebube ahụ dị ukwuu daa sị, “Onye a bụ Ọkpara m, onye m hụrụ nʼanya, onye ihe ya dị m ezi mma.”\f + \fr 1:17 \ft \xt Mat 17:5; Mak 9:7; Luk 9:35\f* 
\v 18 Anyị onwe anyị nụrụ olu ahụ si nʼeluigwe daa mgbe anyị so ya nọdụ nʼelu ugwu nsọ ahụ. 
\p  
\v 19 Anyị nwapụtara na okwu ndị amụma ahụ bụ ihe mezuru emezu. Unu onwe unu kwesikwara ilezi anya nʼokwu ndị ahụ, dịka a ga-asị na ha bụ ìhè na-enwu nʼebe ọchịchịrị gbara nke na-adị ruo mgbe chi bọrọ, mgbe e mere ka kpakpando ọtụtụ walie nʼobi unu.  
\v 20 Nke ka nke, ghọtanụ na okwu amụma ọbụla dị nʼakwụkwọ nsọ abụghị nke e dere dịka akọnuche mmadụ si dị.  
\v 21 Nʼihi na o nweghị okwu amụma ọbụla nke e chepụtara dị ka ọchịchọ obi mmadụ si dị, kama mgbe ndị mmadụ kwuru okwu nʼaha Chineke, ọ bụ Mmụọ Nsọ duru ha. 
\c 2  
\s1 Ịla nʼiyi nke ndị ozizi ụgha 
\p  
\v 1 Ma na mgbe ochie ahụ kwa, e nwere ọtụtụ ndị amụma ụgha nʼetiti ha, dịka a ga-esi nwee ndị ozizi ụgha nʼetiti unu. Ndị a ga-esite na nzuzo na-ewebata ozizi ọjọọ nke na-eweta ịla nʼiyi, ha ga-agọnarị ọ bụladị onye kachasị ihe niile, bụ Onyenwe, onye gbapụtara ha. Ha na-eweta ịla nʼiyi na mberede, na-atụkwasị onwe ha nʼisi.  
\v 2 Ya mere, ọtụtụ mmadụ ga-esoro ndụ rụrụ arụ ha na-ebi, nʼihi ha ga-ekwutọkwa ụzọ nke eziokwu ahụ.  
\v 3 Nʼanya ukwu ha, ndị nkuzi ụgha ndị a ga-eji okwu nrafu rigbuo unu nʼuru. Site na mgbe ochie, onye ga-ekpe ha ikpe dị njikere. Onye ga-ala ha nʼiyi anaghị arahụ ụra. 
\p  
\v 4 Ọ bụrụ na Chineke ahapụghị ndị mmụọ ozi ahụ mgbe ha mehiere, kama o weere ha kpọchie nʼime ala mmụọ,\f + \fr 2:4 \ft Maọbụ, \fqa olulu ọchịchịrị \ft ma ọ bụkwanụ, \fqa Tatarọs \ft nʼasụsụ Griik\f* ebe e kere ha agbụ na-eche ụbọchị ikpe ahụ.  
\v 5 Ọ bụrụkwa na o mereghị ndị ụwa nke mbụ ebere mgbe o mere ka uju mmiri bịakwasị ndị bi na ya na-amaghị Chineke, kama ọ zọpụtara naanị Noa bụ onye kwusara ezi omume na mmadụ asaa ndị ọzọ.  
\v 6 Ọ bụrụ na ọ mara obodo Sọdọm na Gọmọra ikpe site nʼiwere ọkụ rechapụ ha, mee ha ihe ịmaatụ banyere ihe gaje ịbịakwasị ndị na-amaghị Chineke;  
\v 7 ọ bụrụkwa na ọ napụtara Lọt bụ onye ezi omume, onye ndụ ọjọọ nke ndị na-emebi iwu wutere  
\v 8 (nʼihi na nwoke ezi omume ahụ nke na-ebi nʼetiti ha ụbọchị niile, ehihie na abalị, bụ onye eji ọrụ mmebi iwu niile ọ na-anụ, na nke o ji anya ya na-ahụ, mekpaa mkpụrụobi ezi omume ya ahụ).  
\v 9 Ọ bụrụ na ọ dị otu a, Onyenwe anyị maara otu o si anapụta ndị na-asọpụrụ Chineke site nʼọnwụnwa niile gbara ha gburugburu. Ọ makwaara edebe ndị ajọ omume nʼahụhụ, tutu ruo ụbọchị ikpe ahụ. 
\s1 Ahụhụ nke na-abịa 
\p  
\v 10 Nke a bụ eziokwu banyere ndị ahụ na-agbaso ọchịchọ emerụrụ emerụ nke anụ ahụ mmehie ha, na-eledakwa ike ọchịchị anya. Ndị nwere anya ike ma jupụtakwa na mpako. Ndị ahụ ụjọ na-adịghị atụ ikwutọ ọ bụladị mmụọ ndị ahụ jupụtara nʼebube nke anya na-adịghị ahụ.  
\v 11 Lee, ọ bụ ezie na ndị mmụọ ozi karịrị ha nʼịdị ike, nweekwa ume karịa, ma ha anaghị e kpegide ha ikpe nkwujọ nʼihu Onyenwe anyị.  
\v 12 Lee ka ha si na-ekwulu ihe ndị ha aghọtaghị. Ha dị ka ụmụ anụ ọhịa, ndị nzuzu na-eme naanị ihe ọbụla ha kpebiri nʼobi ha. Ndị a mụrụ naanị maka ijide ha ma bibiekwa ha. A ga-egbu ha otu e si egbu ụmụ anụ ọhịa ndị a. 
\p  
\v 13 A ga-eji ntaramahụhụ kwụghachi ha ụgwọ ihe ọjọọ ha mere. Ihe na-atọ ha ụtọ bụ ịkpọ oriri na ọṅụṅụ nʼetiti ehihie. Ha bụ ihe ihere, bụrụkwa ndị na-ewetara unu ntụpọ ma ọ bụrụ na ha na-eso unu na-erikọta oriri.  
\v 14 Anya ha jupụtara nʼagụụ ịkwa iko, mmehie adịghị ejukwa ha afọ. Ha na-arafu ndị okwukwe ha na-esighị ike. Ha bụkwa ndị a maara aha ha nʼihi oke ọchịchọ. Nʼezie ha bụ ụmụ a bụrụ ọnụ.  
\v 15 Ha esitela nʼezi ụzọ ahụ jehie, soro omume Belam nwa Beoa, onye hụrụ ụgwọ ọrụ nke ajọ omume nʼanya.  
\v 16 Ma a baara ya mba maka ajọ omume ya, mgbe e mere ka ịnyịnya ibu ya jiri olu mmadụ gwa ya okwu; gbochie ọrụ onyeisi na-adịghị mma nke onye amụma ahụ chọrọ ịrụ. 
\p  
\v 17 Ndị a dịkwa ka iyi tara ata nke mmiri ọbụla na-adịghị nʼime ya. Ha dịkwa ka igwe ojii nke oke ifufe na-efesasị, nke na-adịghị ezo mmiri ọbụla. Ndị a kwadobere ebe kachasị ịgba ọchịchịrị.  
\v 18 Ha na-eji okwu efu na-enweghị isi, na agụụ ihe ọjọọ nke na-agụ anụ ahụ ha, na-arafu ndị sitere nʼetiti ndị na-ebi ndụ ọjọọ na-ekewapụ onwe ha.  
\v 19 Ha na-ekwe ha nkwa inwere onwe ha, ma ha onwe ha bụ ohu nye ihe rere ure, nʼihi na mmadụ bụ ohu nye ihe ọbụla na-achị achị nʼime ya.  
\v 20 Mgbe ha sitere nʼihe niile emerụrụ emerụ nke ụwa gbapụ, site na mmazu nke Onyenwe anyị, na Onye nzọpụta anyị Jisọs Kraịst, bụrụ ndị atụhịrị na mmehie ọzọ, bụrụkwa ndị e meriri, ha ga-abụ ndị ọnọdụ ha ga-ajọ njọ karịa ka ọ dị na mbụ.  
\v 21 Ọ gaara akara ha mma ma ọ bụrụ na ha amataghị ụzọ ezi omume, karịa na ha matara ya, mesịa gbakụta iwu ahụ dị nsọ nyere ha azụ.  
\v 22 Ilu ndị a bụ eziokwu banyere ha sị, “Nkịta laghachiri ọzọ nʼihe ọ gbọrọ,”\f + \fr 2:22 \ft \xt Ilu 26:11\f* ya na, “Nne ezi a sachara ahụ laghachiri ọzọ ịtụrụ onwe ya nʼapịtị.” 
\c 3  
\s1 Ụbọchị nke Onyenwe anyị 
\p  
\v 1 Ndị enyi m, nke a bụ akwụkwọ nke abụọ m na-edetara unu. Nʼime ha abụọ, ihe m mere bụ ichetara unu ihe ndị ahụ niile unu maara na itute uche unu banyere echiche zuruoke.  
\v 2 Achọrọ m ka unu cheta okwu ndị amụma dị nsọ kwuru mgbe ochie na iwu nke Onyenwe anyị na Onye nzọpụta anyị nyere site na ndị ozi ya. 
\p  
\v 3 Na mbụ, unu ga-amata nke a, na nʼoge ikpeazụ, ndị na-akwa emo ga-apụta, site nʼịkwa emo gbaso agụ ihe ọjọọ niile nke anụ ahụ ha chọrọ  
\v 4 na-asị, “O kwere unu nkwa na ọ ga-abịa, gịnị mere na ọ bịabeghị? Kemgbe nna nna anyị ha nwụrụ, ihe niile ka dị otu ha dị na mbụ, site nʼokike ụwa.”  
\v 5 Ha kpachaara anya chefuo na site nʼogologo oge gara aga, e sitere nʼokwu ọnụ Chineke kee eluigwe ma meekwa ka ụwa dịrị site na mmiri nke gbara ụwa gburugburu.  
\v 6 Ọ bụkwa site na mmiri ndị a ka e ji bibie ma laa nʼiyi ụwa nke dị nʼoge ahụ.  
\v 7 Ọ bụkwa otu okwu ahụ ka e ji nye iwu ka e chebe eluigwe na ụwa tutu ruo ụbọchị ahụ, mgbe a ga-eji ọkụ laa ha nʼiyi nʼụbọchị ahụ a ga-ekpe ndị niile na-amaghị Chineke ikpe, laakwa ha nʼiyi. 
\p  
\v 8 Ndị enyi m, unu echefula otu okwu a, nʼanya Chineke, otu ụbọchị dịka puku afọ, puku afọ dịkwa ka otu ụbọchị.  
\v 9 Onyenwe anyị anaghị anọ ọdụ nʼimezu nkwa ya, dịka ndị ụfọdụ nʼahụta ya na ọ bụ ịnọ ọdụ. Kama o nwere ntachiobi nʼebe unu nọ, nʼihi na ọ chọghị ka onye ọbụla laa nʼiyi, kama ọ chọrọ ka onye ọbụla bịaruo na nchegharị. 
\p  
\v 10 Ma ụbọchị Onyenwe anyị ga-abịa dịka onye ohi. Nʼụbọchị ahụ, eluigwe ga-eji oke ụzụ gafee. Ihe niile dị nʼeluigwe ga-agba ọkụ, laa nʼiyi. Ụwa na ọrụ niile a rụrụ nʼime ya ga-erepịakwa ọkụ nʼotu ntabi anya. 
\p  
\v 11 Ebe ọ bụ na ihe niile gbara anyị gburugburu ga-esi otu a laa nʼiyi, ụdị ndị dị aṅaa ka unu kwesiri ịbụ? Unu kwesiri ị na-ebi ndụ dị nsọ na nke ịsọpụrụ Chineke,  
\v 12 dịka unu na-ele anya ọbịbịa ụbọchị nke Chineke, na-echesikwa ya ike ka ọ bịa ngwangwa. Nʼihi na ọ bụ ụbọchị a ga-amụnye eluigwe niile ọkụ, mee ka ihe niile dị na ya gbaze bụrụ ihe na-agaghị adịkwa.  
\v 13 Ma anyị na-ele anya mmezu nkwa ahụ o kwere, nkwa inye anyị eluigwe ọhụrụ na ụwa ọhụrụ ebe ezi omume naanị ga-adị. 
\p  
\v 14 Bikonu ndị m hụrụ nʼanya, mgbe unu nọ na-ele anya ihe ndị a, jisienụ ike hụ na aka unu dị ọcha, ndị na-enweghị ịta ụta na ndị ha na ya dị nʼudo.  
\v 15 Chetakwanụ na ntachiobi Onyenwe anyị pụtara nzọpụta, dịka ezi nwanna anyị Pọl jiri amamihe Chineke nyere ya deere unu ihe banyere ya.  
\v 16 O na-ede otu ihe ahụ nʼakwụkwọ ozi ya niile, na-ekwu ihe banyere ihe ndị a nʼime ha. E nwere ụfọdụ ihe o kwuru nke siri ike ịghọta nke ndị nzuzu na ndị na-amaghị ihe na-akọwa dịka ha si chepụta nʼobi ha. Ha asụgharịala ihe o dere dịka ha na-emekwa mpaghara akwụkwọ nsọ ụfọdụ, si otu a wetara onwe ha ịla nʼiyi. 
\p  
\v 17 Ya mere, ezi ndị enyi m, ebe unu matara nke a, nọrọnụ na nche ka a ghara isite na njehie ndị na-emebi iwu duhie unu, ime ka unu si nʼọnọdụ unu daa.  
\v 18 Bụrụnụ ndị na-eto eto nʼime amara. Bụrụkwanụ ndị na-aga nʼihu ịmụta ihe banyere Onyenwe anyị na Onye nzọpụta anyị Jisọs Kraịst nke ọma. 
\b  
\b  
\p Ka otuto dịrị ya ugbu a na mgbe niile ebighị ebi. Amen.