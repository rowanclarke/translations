\v 3 \w In|strong="H4430"\w* \w the|strong="H1768"\w* \w first|strong="H2298"\w* \w year|strong="H8140"\w* \w of|strong="H1005"\w* \w King|strong="H4430"\w* \w Cyrus|strong="H3567"\w*, \w he|strong="H1768"\w* \w issued|strong="H7761"\w* \w a|strong="H3068"\w* \w decree|strong="H2942"\w* regarding God's \w Temple|strong="H1005"\w* \w in|strong="H4430"\w* \w Jerusalem|strong="H3390"\w*: Let \w the|strong="H1768"\w* \w Temple|strong="H1005"\w* \w be|strong="H1005"\w* \w rebuilt|strong="H1124"\w* \w as|strong="H1768"\w* \w a|strong="H3068"\w* place \w where|strong="H1768"\w* \w sacrifices|strong="H1685"\w* \w are|strong="H1768"\w* \w offered|strong="H1684"\w*, \w and|strong="H4430"\w* ensure it \w has|strong="H1768"\w* strong foundations. \w Make|strong="H7761"\w* it \w sixty|strong="H8361"\w* cubits high \w and|strong="H4430"\w* \w sixty|strong="H8361"\w* cubits \w wide|strong="H6613"\w*,
