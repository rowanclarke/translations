\v 2 \w So|strong="H3427"\w* \w the|strong="H3605"\w* \w prophet|strong="H5030"\w* \w Jeremiah|strong="H3414"\w* \w spoke|strong="H1696"\w* \w to|strong="H1696"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w people|strong="H5971"\w* \w of|strong="H3427"\w* \w Judah|strong="H3063"\w* \w and|strong="H3063"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w residents|strong="H3427"\w* \w of|strong="H3427"\w* \w Jerusalem|strong="H3389"\w* \w as|strong="H3389"\w* follows:   
\b  
\m
\v 3 “\w From|strong="H4480"\w* \w the|strong="H8085"\w* \w thirteenth|strong="H7969"\w* \w year|strong="H8141"\w* \w of|strong="H1121"\w* \w Josiah|strong="H2977"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Amon \w king|strong="H4428"\w* \w of|strong="H1121"\w* \w Judah|strong="H3063"\w* \w until|strong="H5704"\w* \w this|strong="H2088"\w* \w very|strong="H2088"\w* \w day|strong="H3117"\w*—\w twenty-three|strong="H6242"\w* \w years|strong="H8141"\w*—\w the|strong="H8085"\w* \w word|strong="H1697"\w* \w of|strong="H1121"\w* \w the|strong="H8085"\w* \w LORD|strong="H3068"\w* \w has|strong="H3068"\w* \w come|strong="H1961"\w* \w to|strong="H1696"\w* \w me|strong="H4480"\w*, \w and|strong="H1121"\w* \w I|strong="H3117"\w* \w have|strong="H1961"\w* \w spoken|strong="H1696"\w* \w to|strong="H1696"\w* \w you|strong="H3117"\w* \w again|strong="H7925"\w* \w and|strong="H1121"\w* \w again|strong="H7925"\w*,\f + \fr 25:3 \ft Literally I have spoken to you, rising up early and speaking,\f* \w but|strong="H3808"\w* \w you|strong="H3117"\w* \w have|strong="H1961"\w* \w not|strong="H3808"\w* \w listened|strong="H8085"\w*.  
\v 4 \w And|strong="H3068"\w* \w the|strong="H3605"\w* \w LORD|strong="H3068"\w* \w has|strong="H3068"\w* \w sent|strong="H7971"\w* \w all|strong="H3605"\w* \w His|strong="H3605"\w* \w servants|strong="H5650"\w* \w the|strong="H3605"\w* \w prophets|strong="H5030"\w* \w to|strong="H3068"\w* \w you|strong="H3605"\w* \w again|strong="H7925"\w* \w and|strong="H3068"\w* \w again|strong="H7925"\w*,\f + \fr 25:4 \ft Literally to you, rising up early and sending (them),\f* \w but|strong="H3808"\w* \w you|strong="H3605"\w* \w have|strong="H3068"\w* \w not|strong="H3808"\w* \w listened|strong="H8085"\w* \w or|strong="H3808"\w* \w inclined|strong="H5186"\w* \w your|strong="H3068"\w* \w ear|strong="H8085"\w* \w to|strong="H3068"\w* \w hear|strong="H8085"\w*.   
