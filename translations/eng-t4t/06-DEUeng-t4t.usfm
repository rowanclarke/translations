\s1 Keeping the camp clean  
\p
\v 9 “\w When|strong="H1121"\w* \w your|strong="H3068"\w* \w soldiers|strong="H1121"\w* \w are|strong="H1121"\w* living \w in|strong="H3068"\w* tents \w at|strong="H3068"\w* \w a|strong="H3068"\w* \w time|strong="H7992"\w* \w of|strong="H1121"\w* fighting \w your|strong="H3068"\w* enemies, \w they|strong="H3068"\w* \w must|strong="H1121"\w* avoid doing things \w that|strong="H3068"\w* \w would|strong="H3068"\w* make \w them|strong="H1121"\w* unacceptable \w to|strong="H3068"\w* \w God|strong="H3068"\w*.  
\v 10 \w If|strong="H3588"\w* \w any|strong="H3605"\w* soldier \w becomes|strong="H3588"\w* unacceptable \w to|strong="H3318"\w* God \w because|strong="H3588"\w* semen \w comes|strong="H3318"\w* \w out|strong="H3318"\w* \w of|strong="H1697"\w* \w his|strong="H3605"\w* body \w during|strong="H3605"\w* \w the|strong="H3605"\w* night, \add the next morning\add* \w he|strong="H3588"\w* \w must|strong="H4264"\w* \w go|strong="H3318"\w* \w outside|strong="H3318"\w* \w the|strong="H3605"\w* \w camp|strong="H4264"\w* \w and|strong="H1697"\w* stay \w there|strong="H3605"\w* \w during|strong="H3605"\w* \w that|strong="H3588"\w* day.  
\v 11 \w But|strong="H3588"\w* \w in|strong="H8432"\w* \w the|strong="H3588"\w* \w evening|strong="H3915"\w* \w of|strong="H8432"\w* \w that|strong="H3588"\w* day, \w he|strong="H3588"\w* \w must|strong="H2351"\w* bathe \w himself|strong="H3808"\w*, \w and|strong="H3915"\w* \w at|strong="H4264"\w* sunset \w he|strong="H3588"\w* \w is|strong="H1961"\w* allowed \w to|strong="H3318"\w* \w come|strong="H1961"\w* \w back|strong="H3318"\w* \w into|strong="H8432"\w* \w the|strong="H3588"\w* \w camp|strong="H4264"\w*.   
\p
\v 12 “\w Your|strong="H1961"\w* soldiers \w must|strong="H4264"\w* \w have|strong="H1961"\w* \w a|strong="H3068"\w* toilet area outside \w the|strong="H8432"\w* \w camp|strong="H4264"\w* where \w you|strong="H8432"\w* can \w go|strong="H1961"\w* \add when you need to\add*.  
\v 13  \add When you go to fight against your enemies\add*, \w carry|strong="H3318"\w* \w a|strong="H3068"\w* stick \w along|strong="H3027"\w* \w with|strong="H3318"\w* \w your|strong="H1961"\w* weapons, \w in|strong="H3027"\w* \w order|strong="H3027"\w* \w that|strong="H3027"\w* \w when|strong="H1961"\w* \w you|strong="H3027"\w* need \w to|strong="H3318"\w* defecate [EUP], \w you|strong="H3027"\w* can dig \w a|strong="H3068"\w* hole \w with|strong="H3318"\w* \w the|strong="H3318"\w* stick, \w and|strong="H3027"\w* \w then|strong="H1961"\w* cover \w up|strong="H3318"\w* \w the|strong="H3318"\w* hole \add when you have finished defecating\add*.  
\v 14 \w You|strong="H5921"\w* \w must|strong="H2351"\w* \w keep|strong="H1961"\w* \w the|strong="H5921"\w* camp acceptable \w to|strong="H7725"\w* \w Yahweh|strong="H3068"\w* \w our|strong="H5921"\w* God, \w because|strong="H5921"\w* \w he|strong="H5921"\w* \w is|strong="H1961"\w* \w with|strong="H5921"\w* \w you|strong="H5921"\w* \w in|strong="H3427"\w* \w your|strong="H5921"\w* camp \w to|strong="H7725"\w* protect \w you|strong="H5921"\w* \w and|strong="H7725"\w* \w to|strong="H7725"\w* enable \w you|strong="H5921"\w* \w to|strong="H7725"\w* defeat \w your|strong="H5921"\w* enemies. Do \w not|strong="H1961"\w* do anything disgraceful/indecent \w that|strong="H1961"\w* would \w cause|strong="H7725"\w* \w Yahweh|strong="H3068"\w* \w to|strong="H7725"\w* abandon \w you|strong="H5921"\w*.”   
\s1 Various other laws  
\p
\v 15 “\w If|strong="H3588"\w* slaves \w who|strong="H3068"\w* \w escape|strong="H5337"\w* \w from|strong="H7725"\w* \w their|strong="H3068"\w* masters \w come|strong="H1980"\w* \w to|strong="H1980"\w* \w you|strong="H5414"\w* \add and request you to protect them\add*, \w do|strong="H3068"\w* \w not|strong="H3808"\w* \w send|strong="H5414"\w* \w them|strong="H5414"\w* \w back|strong="H7725"\w* \w to|strong="H1980"\w* \w their|strong="H3068"\w* masters.  
\v 16 Allow \w them|strong="H5337"\w* \w to|strong="H5650"\w* stay/live \w among|strong="H5973"\w* \w you|strong="H5973"\w*, \w in|strong="H5650"\w* whatever town \w they|strong="H3808"\w* choose, \w and|strong="H5650"\w* do \w not|strong="H3808"\w* mistreat \w them|strong="H5337"\w*.   
\p
\v 17 “\w Do|strong="H3238"\w* \w not|strong="H3808"\w* \add allow\add* \w any|strong="H3808"\w* Israeli \w man|strong="H2896"\w* \w or|strong="H3808"\w* woman \add to\add* become \w a|strong="H3068"\w* prostitute \w at|strong="H3427"\w* \w the|strong="H5973"\w* temple.  
\v 18 \w Also|strong="H3478"\w*, do \w not|strong="H3808"\w* allow \w any|strong="H1961"\w* \w people|strong="H1121"\w* \w who|strong="H1121"\w* earned money \w from|strong="H3478"\w* \w being|strong="H1961"\w* \w a|strong="H3068"\w* \w prostitute|strong="H6945"\w* \w to|strong="H3478"\w* \w bring|strong="H1961"\w* \w any|strong="H1961"\w* \w of|strong="H1121"\w* \w that|strong="H3478"\w* money \w into|strong="H1961"\w* \w the|strong="H1961"\w* \w temple|strong="H6945"\w* \w of|strong="H1121"\w* \w Yahweh|strong="H3068"\w* \w our|strong="H1961"\w* \w God|strong="H3808"\w*, \w even|strong="H3808"\w* \w if|strong="H1961"\w* \w they|strong="H3808"\w* solemnly promised \w to|strong="H3478"\w* pay \w that|strong="H3478"\w* money \w to|strong="H3478"\w* \w Yahweh|strong="H3068"\w*. \w Yahweh|strong="H3068"\w* hates \w those|strong="H1121"\w* \w who|strong="H1121"\w* \w are|strong="H1121"\w* \w prostitutes|strong="H6945"\w*.   
\p
\v 19 “\w When|strong="H3588"\w* \w you|strong="H3588"\w* lend money \w or|strong="H3808"\w* \w food|strong="H1004"\w* \w or|strong="H3808"\w* \w anything|strong="H3605"\w* \w else|strong="H3808"\w* \w to|strong="H3068"\w* \w a|strong="H3068"\w* fellow Israeli, \w do|strong="H3068"\w* \w not|strong="H3808"\w* charge \w them|strong="H8147"\w* interest.  
\v 20 \w You|strong="H3605"\w* \w are|strong="H1697"\w* allowed \w to|strong="H1697"\w* \w charge|strong="H5391"\w* \w interest|strong="H5392"\w* when \w you|strong="H3605"\w* lend \w money|strong="H3701"\w* \w to|strong="H1697"\w* foreigners \add who live in your land\add*, \w but|strong="H3808"\w* \w not|strong="H3808"\w* when \w you|strong="H3605"\w* lend \w money|strong="H3701"\w* \w to|strong="H1697"\w* Israelis. \w Do|strong="H3605"\w* \w this|strong="H1697"\w* \w in|strong="H1697"\w* \w order|strong="H1697"\w* \w that|strong="H3605"\w* \w Yahweh|strong="H3068"\w* \w our|strong="H3605"\w* \w God|strong="H3808"\w* \w will|strong="H1697"\w* bless \w you|strong="H3605"\w* \w in|strong="H1697"\w* \w everything|strong="H3605"\w* \w that|strong="H3605"\w* \w you|strong="H3605"\w* \w do|strong="H3605"\w* \w in|strong="H1697"\w* \w the|strong="H3605"\w* land \w that|strong="H3605"\w* \w you|strong="H3605"\w* \w are|strong="H1697"\w* \w about|strong="H1697"\w* \w to|strong="H1697"\w* enter \w and|strong="H3701"\w* occupy.   
\p
\v 21 “\w When|strong="H3068"\w* \w you|strong="H3605"\w* \w vow|strong="H3027"\w* \w to|strong="H3068"\w* give \w something|strong="H3605"\w* \w to|strong="H3068"\w* \w Yahweh|strong="H3068"\w* \w your|strong="H3068"\w* \w God|strong="H3068"\w* \add or to do something for him\add*, \w do|strong="H3068"\w* \w it|strong="H5921"\w* \w as|strong="H3068"\w* soon \w as|strong="H3068"\w* \w you|strong="H3605"\w* \w can|strong="H3808"\w*. \w Yahweh|strong="H3068"\w* expects \w you|strong="H3605"\w* \w to|strong="H3068"\w* \w do|strong="H3068"\w* \w what|strong="H5921"\w* \w you|strong="H3605"\w* \w promised|strong="H3068"\w*, \w and|strong="H3068"\w* \w if|strong="H1288"\w* \w you|strong="H3605"\w* \w do|strong="H3068"\w* \w not|strong="H3808"\w* \w do|strong="H3068"\w* \w it|strong="H5921"\w*, \w you|strong="H3605"\w* \w will|strong="H3068"\w* \w be|strong="H3808"\w* committing \w a|strong="H3068"\w* sin.  
\v 22 \w But|strong="H3588"\w* \w if|strong="H3588"\w* \w you|strong="H3588"\w* [SYN] \w do|strong="H3068"\w* \w not|strong="H3808"\w* \w vow|strong="H5088"\w* \add to do something\add*, \w that|strong="H3588"\w* \w is|strong="H3068"\w* \w not|strong="H3808"\w* \w sinful|strong="H2399"\w*.  
\v 23 \w But|strong="H3588"\w* \w if|strong="H3588"\w* \w you|strong="H3588"\w* voluntarily promise \w to|strong="H1961"\w* do something, \w you|strong="H3588"\w* \w must|strong="H3808"\w* do \w it|strong="H3588"\w*.   
\p
\v 24 “\w When|strong="H1696"\w* \w you|strong="H6213"\w* walk \w through|strong="H6213"\w* someone else’s vineyard, \w you|strong="H6213"\w* \w are|strong="H3068"\w* \w allowed|strong="H3068"\w* \w to|strong="H1696"\w* \add pick and\add* \w eat|strong="H6310"\w* \w as|strong="H6213"\w* many grapes \w as|strong="H6213"\w* \w you|strong="H6213"\w* want, \w but|strong="H1696"\w* \w you|strong="H6213"\w* must \w not|strong="H6213"\w* \add cut some from a vine and carry them away\add* \w in|strong="H3068"\w* \w a|strong="H3068"\w* container.  
\v 25 \w When|strong="H3588"\w* \w you|strong="H5414"\w* walk \add along a path\add* \w in|strong="H5315"\w* \w someone|strong="H5315"\w* \w else|strong="H3808"\w*’s field \w of|strong="H3627"\w* grain, \w you|strong="H5414"\w* \w are|strong="H3627"\w* \w allowed|strong="H5414"\w* \w to|strong="H5414"\w* pluck/pick \w some|strong="H5315"\w* \w of|strong="H3627"\w* \w the|strong="H3588"\w* grain \w and|strong="H3754"\w* eat \w it|strong="H5414"\w*, \w but|strong="H3588"\w* \w you|strong="H5414"\w* \w must|strong="H5315"\w* \w not|strong="H3808"\w* cut \w any|strong="H5315"\w* grain \w with|strong="H3627"\w* \w a|strong="H3068"\w* sickle \add and take it with you\add*.”   
\c 24  
\s1 Laws about divorcing and remarrying  
\p
\v 1 “\w Suppose|strong="H3588"\w* \w a|strong="H3068"\w* man \w marries|strong="H1166"\w* \w a|strong="H3068"\w* \w woman|strong="H1004"\w* \w and|strong="H7971"\w* \w later|strong="H1961"\w* decides \w that|strong="H3588"\w* \w he|strong="H3588"\w* \w does|strong="H3808"\w* \w not|strong="H3808"\w* \w want|strong="H3808"\w* \w her|strong="H5414"\w* \w because|strong="H3588"\w* \w there|strong="H1961"\w* \w is|strong="H3027"\w* \w something|strong="H1697"\w* \w about|strong="H1961"\w* \w her|strong="H5414"\w* \w that|strong="H3588"\w* \w he|strong="H3588"\w* doesn’t \w like|strong="H1961"\w*. \w And|strong="H7971"\w* \w suppose|strong="H3588"\w* \w he|strong="H3588"\w* \w writes|strong="H3789"\w* \w on|strong="H3027"\w* paper \w that|strong="H3588"\w* \w he|strong="H3588"\w* \w is|strong="H3027"\w* divorcing \w her|strong="H5414"\w*, \w and|strong="H7971"\w* \w he|strong="H3588"\w* \w gives|strong="H5414"\w* \w the|strong="H3588"\w* paper \w to|strong="H7971"\w* \w her|strong="H5414"\w* [SYN] \w and|strong="H7971"\w* \w sends|strong="H7971"\w* \w her|strong="H5414"\w* \w away|strong="H7971"\w* \w from|strong="H3027"\w* \w his|strong="H5414"\w* \w house|strong="H1004"\w*.  
\v 2 \w Then|strong="H1961"\w* suppose \w that|strong="H1004"\w* \w she|strong="H1980"\w* \w goes|strong="H1980"\w* \w and|strong="H1980"\w* marries another man,  
\v 3 \w and|strong="H7971"\w* \w that|strong="H3588"\w* \w man|strong="H4191"\w* \add later also\add* decides \w that|strong="H3588"\w* \w he|strong="H3588"\w* does \w not|strong="H5414"\w* \w like|strong="H1004"\w* \w her|strong="H5414"\w*, \w and|strong="H7971"\w* \w he|strong="H3588"\w* \w also|strong="H3027"\w* \w writes|strong="H3789"\w* \w on|strong="H3027"\w* paper \w that|strong="H3588"\w* \w he|strong="H3588"\w* \w is|strong="H3027"\w* divorcing \w her|strong="H5414"\w*, \w and|strong="H7971"\w* \w he|strong="H3588"\w* \w sends|strong="H7971"\w* \w her|strong="H5414"\w* \w away|strong="H7971"\w* \w from|strong="H3027"\w* \w his|strong="H5414"\w* \w house|strong="H1004"\w*. \w Or|strong="H1004"\w*, \w suppose|strong="H3588"\w* \w that|strong="H3588"\w* \w the|strong="H3588"\w* second husband \w dies|strong="H4191"\w*.  
\v 4 \w If|strong="H3588"\w* \w either|strong="H3808"\w* \w of|strong="H3068"\w* \w those|strong="H1931"\w* \w things|strong="H7223"\w* \w happens|strong="H1961"\w*, \w her|strong="H5414"\w* \w first|strong="H7223"\w* \w husband|strong="H1167"\w* \w must|strong="H3947"\w* \w not|strong="H3808"\w* \w marry|strong="H3947"\w* \w her|strong="H5414"\w* \w again|strong="H7725"\w*. \w He|strong="H1931"\w* \w must|strong="H3947"\w* \w consider|strong="H7725"\w* \w that|strong="H3588"\w* \w she|strong="H1931"\w* \w has|strong="H3068"\w* \w become|strong="H1961"\w* unacceptable \w to|strong="H7725"\w* \w Yahweh|strong="H3068"\w*. \w Yahweh|strong="H3068"\w* \w would|strong="H3068"\w* \w consider|strong="H7725"\w* \w it|strong="H5414"\w* \w to|strong="H7725"\w* \w be|strong="H1961"\w* \w disgusting|strong="H8441"\w* \add if he married her again\add*. \w You|strong="H3588"\w* \w must|strong="H3947"\w* \w not|strong="H3808"\w* \w sin|strong="H2398"\w* [MTY] \w by|strong="H3068"\w* doing \w that|strong="H3588"\w* \w in|strong="H3068"\w* \w the|strong="H6440"\w* \w land|strong="H5159"\w* \w that|strong="H3588"\w* \w Yahweh|strong="H3068"\w* \w our|strong="H3068"\w* \w God|strong="H3068"\w* \w is|strong="H3068"\w* \w giving|strong="H5414"\w* \w to|strong="H7725"\w* \w you|strong="H3588"\w*.”   
\s1 Various laws  
\p
\v 5 “\w When|strong="H3588"\w* \w some|strong="H1697"\w* \w man|strong="H3605"\w* \w has|strong="H1961"\w* recently \w become|strong="H1961"\w* \w married|strong="H3947"\w*, \w he|strong="H3588"\w* \w must|strong="H3947"\w* \w not|strong="H3808"\w* \add be required to\add* \w become|strong="H1961"\w* \w a|strong="H3068"\w* \w soldier|strong="H6635"\w* \w in|strong="H5921"\w* \w the|strong="H3605"\w* \w army|strong="H6635"\w* \w or|strong="H3808"\w* \w be|strong="H1961"\w* \w required|strong="H1697"\w* \w to|strong="H3318"\w* \w do|strong="H3318"\w* \w any|strong="H3605"\w* \w other|strong="H3605"\w* \w work|strong="H1697"\w* \add for the government\add* \w for|strong="H3588"\w* \w one|strong="H3605"\w* \w year|strong="H8141"\w* \add after being married\add*. \w He|strong="H3588"\w* \w should|strong="H3588"\w* stay happily \w at|strong="H5921"\w* \w home|strong="H1004"\w* \w with|strong="H1004"\w* \w his|strong="H3605"\w* wife \w for|strong="H3588"\w* \w that|strong="H3588"\w* \w year|strong="H8141"\w*.   
\p
\v 6 “\w Anyone|strong="H5315"\w* \w who|strong="H1931"\w* lends money \w to|strong="H5315"\w* \w someone|strong="H5315"\w* \w else|strong="H3808"\w* \add is allowed to require that person to give him something\add* \w to|strong="H5315"\w* guarantee \add that he will pay back the money that he borrowed. But\add* \w he|strong="H1931"\w* \w must|strong="H3808"\w* \w not|strong="H3808"\w* \w take|strong="H2254"\w* \w from|strong="H5315"\w* \w him|strong="H1931"\w* \w his|strong="H3588"\w* ◄\w millstone|strong="H7393"\w*/stone \w for|strong="H3588"\w* grinding grain►. \w That|strong="H3588"\w* \w would|strong="H5315"\w* \w be|strong="H3808"\w* \w taking|strong="H2254"\w* \add the millstone that his family needs to grind the grain to make the bread\add* \w they|strong="H3588"\w* need \w to|strong="H5315"\w* stay \w alive|strong="H5315"\w*.   
\p
\v 7 “\w If|strong="H3588"\w* \w someone|strong="H5315"\w* \w kidnaps|strong="H1589"\w*/\w steals|strong="H1589"\w* \w a|strong="H3068"\w* \w fellow|strong="H1121"\w* Israeli \w to|strong="H3478"\w* cause \w that|strong="H3588"\w* \w person|strong="H5315"\w* \w to|strong="H3478"\w* \w become|strong="H1197"\w* \w his|strong="H3478"\w* \w slave|strong="H5315"\w* \w or|strong="H1121"\w* \w to|strong="H3478"\w* \w sell|strong="H4376"\w* \w him|strong="H4672"\w* \add to become someone else’s slave\add*, \w you|strong="H3588"\w* \w must|strong="H4191"\w* \w execute|strong="H4191"\w* \w the|strong="H3588"\w* \w person|strong="H5315"\w* \w who|strong="H1931"\w* \w did|strong="H3478"\w* \w that|strong="H3588"\w*. \w By|strong="H4191"\w* \w doing|strong="H7451"\w* \w that|strong="H3588"\w*, \w you|strong="H3588"\w* \w will|strong="H3478"\w* \w get|strong="H4672"\w* rid \w of|strong="H1121"\w* \w this|strong="H1931"\w* \w evil|strong="H7451"\w* \w among|strong="H7130"\w* \w you|strong="H3588"\w*.   
\p
\v 8 “If \w you|strong="H6680"\w* \w are|strong="H6213"\w* suffering \w from|strong="H3881"\w* ◄\w leprosy|strong="H6883"\w*/\w a|strong="H3068"\w* dreaded skin \w disease|strong="H6883"\w*►, \w be|strong="H5061"\w* \w sure|strong="H8104"\w* \w to|strong="H6213"\w* \w do|strong="H6213"\w* \w everything|strong="H3605"\w* \w that|strong="H3605"\w* \w the|strong="H3605"\w* \w priests|strong="H3548"\w*, \w who|strong="H3605"\w* \w are|strong="H6213"\w* \w from|strong="H3881"\w* \w the|strong="H3605"\w* tribe \w of|strong="H3605"\w* \w Levi|strong="H3881"\w*, \w tell|strong="H3605"\w* \w you|strong="H6680"\w* \w to|strong="H6213"\w* \w do|strong="H6213"\w*. \w Obey|strong="H6213"\w* \w carefully|strong="H6213"\w* \w the|strong="H3605"\w* \w instructions|strong="H6680"\w* \w that|strong="H3605"\w* \w I|strong="H6680"\w* \w have|strong="H3548"\w* \w given|strong="H6680"\w* \w to|strong="H6213"\w* \w them|strong="H6213"\w*.  
\v 9 \w Do|strong="H6213"\w* \w not|strong="H6213"\w* forget \w what|strong="H6213"\w* \w Yahweh|strong="H3068"\w* \w our|strong="H3068"\w* \w God|strong="H3068"\w* \w did|strong="H6213"\w* \w to|strong="H3318"\w* \w Miriam|strong="H4813"\w*, \add when she became a leper\add*, \w after|strong="H3318"\w* \w your|strong="H3068"\w* ancestors \w left|strong="H3318"\w* \w Egypt|strong="H4714"\w*.   
\p
\v 10 “\w When|strong="H3588"\w* \w you|strong="H3588"\w* \w lend|strong="H5670"\w* \w something|strong="H3972"\w* \w to|strong="H1004"\w* someone, do \w not|strong="H3808"\w* go into \w his|strong="H3588"\w* \w house|strong="H1004"\w* \w to|strong="H1004"\w* \w take|strong="H5670"\w* \w the|strong="H3588"\w* cloak \w that|strong="H3588"\w* \w he|strong="H3588"\w* says \w that|strong="H3588"\w* \w he|strong="H3588"\w* \w will|strong="H1004"\w* give \w you|strong="H3588"\w* \w to|strong="H1004"\w* guarantee \add that he will return what he has borrowed\add*.  
