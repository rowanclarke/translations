\id 3JN Quechua de Margos-Yarowilca-Lauricocha, Huánuco 
\h 3 JUAN 
\toc1 3 JUAN Apóstol Juanpa quimsa cag cartan 
\toc2 3 JUAN 
\toc3 3 Jn. 
\mt1 3 JUAN 
\mt2 Apóstol Juanpa quimsa cag cartan 
\c 1  
\s1 Gayuta apóstol Juan saludashgan 
\p  
\v 1 Cuyay waugui Gayo: 
\p Noga mayor waugui carmi cay cartata gampag apaycätsimö. 
\p  
\v 2 Cuyay waugui, Tayta Diosnintsitami manacö lapanchöpis yanapaycushunayquipag y gueshyaptiquipis aliyätsishunayquipag. Tsaynogpis Tayta Diosnintsita agradëcicö payman yäracur ali cawashgayquipita.  
\v 3 Jesucristupa wilacuynin nishgannog cawaycashgayquitami waquin wauguicuna chämur wilamashga. Tsaynog cawaycashgayquita musyarmi fiyupa cushicushcä.  
\v 4 Tsaynoglami cushicö yäracog mayintsi Tayta Diosnintsi munashgannog cawarcaycashganta musyashpä. 
\s1 Gayo yanapäcog cashganpita apóstol Juan cushicushgan 
\p  
\v 5 Waugui Gayo, Jesucristupa wilacuyninta wilacur pureg wauguicunata posädatsir alitami ruraycanqui.  
\v 6 Paycunami cayman chämur waugui-panicuna juntacashgancho wilapäcamashga ali yanapashgayquita. Yapay cutimuptin puntata yanapashgayquinogla yapaypis yanapayculay Jesucristupa wilacuyninta wilacur purinanpag.  
\v 7 Paycunaga Diosta mana cäsucog runacunata manami imatapis manacuntsu.  
\v 8 Tsaynog yanapaptintsimi waquin marcacunamanpis aywanga Jesucristupa wilacuyninta wilacärinanpag. 
\s1 Diótrefes mana cäsucog cashgan 
\p  
\v 9 Jesucristupa wilacuyninta wilacogcunata yanapanantsipag cashganta tantyatsirmi juc cartata apatsimushcä gamcuna cagman. Tsaynog captinpis Diótrefes manami yätsishgäcunata cäsucuntsu. Payga mandag cayninman atiënicuycurmi munashganta ruracun.  
\v 10 Tsayshi wasäcunatapis rimashpan puriycan. Tsaynogpis carupita shamog yachatsicogcunata manashi chasquicuntsu. Posädatsegcunatapis waugui-panicunawan manana juntacänanpag micharshi garguycan. Tsaynog rurashganpitaga chämurnami payta tantyatsishag mana alita ruraycashganta. 
\s1 Demetrio cäsucog cashgan 
\p  
\v 11 Cuyay waugui Gayo, cuidädu Diótrefesnog canquiman. Tsaypa trucanga Tayta Dios munashgannogla alicunata rurar imaypis caway. Tayta Dios munashgannog cawagcunaga Diospa wamrancunami carcaycan. Tayta Diosta mana cäsucogcunaga manami payta chasquicushgaragtsu.  
\v 12 Demetriupagmi itsanga lapan runacunapis parlapäcun Jesucristupa wilacuynin nishgannog cawashganta. Nogacunapis paytaga ricapäcushcä Tayta Dios munashgannog cawashgantami. 
\s1 Carta ushanan 
\p  
\v 13 Waugui Gayo, gamta yätsinäpag caycanragmi. Itsanga cartalachöga manami lapanta yätsiycätsu.  
\v 14 Quiquë shamurnami waquin cagtaga yätsishayqui. 
\p  
\v 15 Tayta Diosnintsi yanapayculäshunqui maquincho ali cawanayquipag. Caycho cag reguinacushgayqui waugui-panicunapis salüdunta apatsicamunmi. Tsaycho cag waugui-panicunata salüdöta goyculanqui.