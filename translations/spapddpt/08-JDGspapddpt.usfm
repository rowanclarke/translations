\v 46 Al oírlo, \w todos|strong="H3605"\w* \w los|strong="H3605"\w* habitantes de \w la|strong="H3605"\w* \w torre|strong="H4026"\w* de Siquem se replegaron \w a|strong="H3068"\w* \w la|strong="H3605"\w* fortaleza del \w templo|strong="H1004"\w* de ʼEl-berit.
\v 47 \w Cuando|strong="H3588"\w* se dio \w aviso|strong="H5046"\w* \w a|strong="H3068"\w* Abimelec \w de|strong="H3588"\w* \w que|strong="H3588"\w* \w los|strong="H1167"\w* habitantes \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w torre|strong="H4026"\w* \w de|strong="H3588"\w* Siquem estaban reunidos,
\v 48 Abimelec \w subió|strong="H5927"\w* \w a|strong="H3068"\w* \w la|strong="H1931"\w* montaña Salmón \w con|strong="H5973"\w* \w toda|strong="H3605"\w* \w la|strong="H1931"\w* \w gente|strong="H5971"\w* \w que|strong="H4100"\w* \w lo|strong="H1931"\w* acompañaba. \w Luego|strong="H1931"\w* Abimelec \w tomó|strong="H3947"\w* un hacha \w en|strong="H5921"\w* \w su|strong="H1931"\w* \w mano|strong="H3027"\w*, \w cortó|strong="H3772"\w* una rama \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w árboles|strong="H6086"\w*, \w la|strong="H1931"\w* \w cual|strong="H4100"\w* \w alzó|strong="H5375"\w* \w sobre|strong="H5921"\w* \w su|strong="H1931"\w* \w hombro|strong="H7926"\w*, \w y|strong="H5921"\w* dijo \w al|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w que|strong="H4100"\w* \w estaba|strong="H7760"\w* \w con|strong="H5973"\w* \w él|strong="H1931"\w*: \w Lo|strong="H1931"\w* \w que|strong="H4100"\w* \w me|strong="H5921"\w* \w vean|strong="H7200"\w* \w hacer|strong="H6213"\w*, apresúrense \w a|strong="H3068"\w* hacerlo \w como|strong="H4100"\w* \w yo|strong="H6213"\w*.
\p 
\v 49 \w Todo|strong="H3605"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w cortó|strong="H3772"\w* \w también|strong="H1571"\w* su rama, \w y|strong="H1571"\w* \w cada|strong="H3605"\w* uno \w siguió|strong="H3212"\w* \w a|strong="H3068"\w* Abimelec. \w Las|strong="H5921"\w* \w pusieron|strong="H7760"\w* \w contra|strong="H5921"\w* \w la|strong="H5921"\w* fortaleza, prendieron fuego \w a|strong="H3068"\w* \w la|strong="H5921"\w* fortaleza \w con|strong="H5921"\w* \w ellas|strong="H5921"\w*, \w de|strong="H5921"\w* modo \w que|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* habitantes \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w torre|strong="H4026"\w* \w de|strong="H5921"\w* Siquem \w murieron|strong="H4191"\w*, unos 1.000 \w entre|strong="H5921"\w* hombres \w y|strong="H1571"\w* mujeres.
