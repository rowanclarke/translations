\id SNG
\h سُوكِ
\toc1 عَننَبِ سُلٍمَنِ شَ سُوكِ قِسَمَنتٍ
\toc2 سُوكِ
\toc3 سُو
\mt1 عَننَبِ سُلٍمَنِ شَ سُوكِ قِسَمَنتٍ
\imt1 مَسٍنيِ ندٍ يِ كِتَابُي شَ قٍ رَ
\ip عَننَبِ سُلٍمَنِ، نَشَن نُ قِندِشِ عِسِرَيِلَ مَنفّ رَ عَ بَبَ دَوُدَ دَنفِ شَنبِ، عَ نُ بَرَ كِتَابُي ندٍيٍ سّبّ عَلَ شَ لْننِ شَ قٍ رَ. عَلَتَلَ نُ بَرَ قٍ فبٍفبٍ مَسٍن عَ بّ عَ شَ مَنفّيَ كُي، نَشٍيٍ بَرَ قِندِ لْننِ شُنفبٍ رَ دُنِحَ بِرِن بّ.
\ip يِ كِتَابُي كُي، عَلَ بَرَ لْننِ مْولِ فبّتّ مَسٍن سُلٍمَنِ بّ، نَشَن قِندِشِ شَنُنتٍيَ رَ شّمّ نُن فِنّ تَفِ. تَوُرٍتَ مُنسَ عَ مَسٍنمَ وٌن بّ، عَلَتَلَ تٌ شّمّ دَا، عَ نَشَ عَ تٌ عَ هَيِ نُ نَ فِنّ مَ. عَ نَشَ عٍ قِرِن دَا عَلَكٌ عٍ شَ كَقُ عٍ بٌورٍيٍ رَ، عٍ شَ وُيَ. نَ كُي وٌن عَ كٌلٌنمَ شَنُنتٍيَ نَشَن نَ شّمّ نُن فِنّ تَفِ، عَ قِندِشِ عَلَ سَفٌ نَن نَ. شَ عَ سَ لِ شّمّ، شَ نَ مُ عَ رَ فِنّ، عَ وَ مَ نَ قٍ مْولِ شْن قُتِ مُ نَ نَشَن نَ، نَ تّمُي عَ بَرَ قِندِ يُنُبِ رَ. يّنّ مُ رَقَن عَلَ مَ، كْنْ قُتِ شِرِقٍ شّمّ نُن فِنّ تَفِ، عَلَتَلَ يَتِ نَن نَ يَمَرِشِ.
\ip «سُلٍمَنِ شَ سُوكِ قِسَمَنتٍ» عَ نَ بِرِن مَسٍنمَ تَالِ وْيّنيِ رَ. شّمّ وَ مَ فِنّ شْن، فِنّ قَن وَ مَ شّمّ شْن. عٍ بَرَ عٍ بٌورٍ شَنُ هَن عٍ وَ مَ لُقٍ يِرٍ كٍرٍن تُن. نَ شَنُنتٍيَ مْولِ مُ حَاشُ. عَلَ وَ مَ نَ شْن مِشِيٍ بّ نَشٍيٍ بَرَ نَتّ تٌنفٌ عٍ شَ قُتِ شِرِ. عَلَ قٍ نَشَن دَاشِ، نَ مُ نْمَ قِندِدٍ يُنُبِ رَ شَ عَ رَوَلِمَ عَ رَوَلِ كِ مَ.
\ip عَلَ شَ نَ سّرِيّ مَسٍن وٌن بّ، عَلَكٌ وٌن شَ لُ سّنِيّنيِ كُي عَلْ عَلَتَلَ وَ مَ عَ شْن مَ كِ نَشّ. عَمِنَ.
\mt1 عَننَبِ سُلٍمَنِ شَ سُوكِ قِسَمَنتٍ
\c 1
\s1 فِنّ شَنُشِ شَ حّلّشِنيِ
\p 
\v 1 عَننَبِ سُلٍمَنِ شَ سُوكِ قِسَمَنتٍ نَن يَ؛
\sp فِنّ شَ مَسٍنيِ عَ شَنُنتٍنيِ بّ
\q1 
\v 2 «عِ شَ ﭑ مَسُنبُ.
\q1 عِ شَ شَنُنتٍيَ حْشُن وّنِ بّ.
\q1 
\v 3 عِ شِرِ حْشُنمّ لُشِ نّ عَلْ لَبُندّ،
\q1 نَشَن شِرِ قَنيِ مِنِمَ.
\q1 نَ نَن عَ رَ عِ رَقَن فِنّدِ مّ بِرِن مَ.
\q1 
\v 4 عِ شَ ﭑ تٌنفٌ، وٌن شَ سِفَ.
\q1 مَنفّ شَ ﭑ شَنِن عَ شْنيِ.
\sp فِنّدِ مّيٍ شَ مَسٍنيِ فِنّ بّ
\q1 عِ شَ قٍ نَ عَ نِيَمَ وٌن شَ لُ سّيوّ كُي.
\q1 عِ شَ شَنُنتٍيَ حْشُن وّنِ بّ.
\q1 نْندِ نَ مِشِ بّ عِ رَقَنشِ نَشَن مَ.»
\sp فِنّ شَ مَسٍنيِ فِنّدِ مّيٍ بّ
\q1 
\v 5 «دَرِ سَلَمُ فِنّدِ مّيٍ، ﭑ كِرِ قْورْ،
\q1 كْنْ ﭑ تٌقَن عَلْ كٍدَرِ شَ كِرِ بَنشِيٍ،
\q1 عَلْ دُفِ نَشٍيٍ فبَكُشِ عَننَبِ سُلٍمَنِ شْنيِ.
\q1 
\v 6 وٌ نَشَ ﭑ كِرِ قْورْشِ مَتٌ،
\q1 سٌفٍ نَن ﭑ قْورْشِ.
\q1 ﭑ نفَ شَ دِ شّمّيٍ نُ شْنْشِ ﭑ مَ،
\q1 عٍ نُ ﭑ شّيمَ عٍ شَ وّنِ بِلِيٍ رَوَلِدٍ.
\q1 ﭑ مُ نْ ﭑ حّنفِ سَدٍ ﭑ فبٍ شْن مَ.»
\sp فِنّ شَ مَسٍنيِ عَ شَنُنتٍنيِ بّ
\q1 
\v 7 «ﭑ شَنُنتٍنيِ، عِ شَ عَ قَلَ ﭑ بّ
\q1 عِ شُرُ سٍيٍ دّ مَدٌنمَ دّننَشّ،
\q1 عَلَكٌ ﭑ نَشَ لُ عِ قٍن نَ مَلَبُي تّمُي
\q1 عِ بٌورٍيٍ شَ شُرُ سٍ فْورّيٍ يَ مَ.»
\sp شّمّ شَ مَسٍنيِ فِنّ بّ
\q1 
\v 8 «فِنّ تٌقَنيِ قِسَمَنتٍ،
\q1 شَ عِ مُ نَ يِرٍ كٌلٌن،
\q1 عِ شَ ﭑ مَ يّشّييٍ قْشِ قٍن،
\q1 عِ شَ عِ فبٍيٍ دّ مَدٌن ﭑ مَ فْورّ لٌنفٌرِ رَ.
\q1 
\v 9 ﭑ شَنُنتٍنيِ،
\q1 عِ تٌقَن عَلْ مِسِرَ مَنفّ شَ سٌي،
\q1 نَشَن عَ رَفِسٍ بّندُنمَ.
\q1 
\v 10 عِ شَ تُلِرَ سٌييٍ بَرَ عِ شّرّيٍ رَتٌقَن،
\q1 عِ كْنيِ رَيَبُ كْنمَفٌرٍ كُي.
\q1 
\v 11 وٌن شَ مَرَتٌقَن سٍ فبّتّيٍ قٍن،
\q1 نَشٍيٍ يَءِلَنشِ شّيمَ نُن فبٍتِ رَ.»
\sp فِنّ شَ مَسٍنيِ عَ شَ شّمّ شَ قٍ رَ
\q1 
\v 12 «ﭑ مَ لَبُندّ شِرِ نُ مّمَ،
\q1 مَنفّ شَ شُلُنيِ يِرٍ.
\q1 
\v 13 ﭑ شَنُنتٍنيِ مَنِيَشِ سٍ سَسٍ نَن نَ،
\q1 نَشَن فبَكُشِ ﭑ شِحّيٍ تَفِ،
\q1 سٍ شِرِ قَنيِ سَشِ عَ كُي.
\q1 
\v 14 عَ شِرِ لُشِ نّ عَلْ سَنسِ قُفٍ شِرِ،
\q1 نَشٍيٍ كٍلِشِ وّنِ بِلِيٍ يَ مَ عٍن فٍدِ بْشِ مَ.»
\sp شّمّ شَ مَسٍنيِ فِنّ بّ
\q1 
\v 15 «ﭑ شَنُنتٍنيِ، عِ تٌقَن، عِ تٌقَن.
\q1 عِ يَيٍ رَيَبُ عَلْ فَنبّ.»
\sp فِنّ شَ مَسٍنيِ شّمّ بّ
\q1 
\v 16 «ﭑ شَنُنتٍنيِ، عِ تٌقَن، عِ تٌقَن.
\q1 وٌن نَ دّننَشّ،
\q1 حٌوفٍ قَنيِ بَرَ قِندِ وٌن مَ سَدٍ رَ،
\q1 
\v 17 سّدِرِ وُرِ سَلٌنيِيٍ بَرَ قِندِ وٌن مَ بَنشِ شُنيِ رَ،
\q1 سِثِرّ وُرِ بَرَ قِندِ وٌن مَ بَنشِ كَنكٍ رَ.»
\c 2
\s1 شَنُنتٍنيِيٍ شَ تٌقَنيِ
\sp فِنّ شَ مَسٍنيِ شّمّ بّ
\q1 
\v 1 «ﭑ تَن لُمَ نّ عَلْ سَنسِ قُفٍ تٌقَنيِ،
\q1 نَشَن مْولِ تٌمَ سَرْن فُلُنبَ يِرٍ.»
\sp شّمّ شَ مَسٍنيِ فِنّ بّ
\q1 
\v 2 «عِ تَن لُشِ نّ عَلْ سَنسِ قُفٍ تٌقَنيِ تُنبٍيٍ يَ مَ.
\q1 عِ تٌقَن فِنّدِ مّيٍ بِرِن بّ.»
\sp فِنّ شَ مَسٍنيِ عَ شَ شّمّ شَ قٍ رَ
\q1 
\v 3 «ﭑ شَنُنتٍنيِ لُشِ نّ عَلْ مَنفٌي بِلِ وٌندِ كُي.
\q1 عَ قَن سّفّتَلَيٍ بِرِن بّ.
\q1 ﭑ بَرَ وَ لُقٍ عَ شَ نِينِ بُن مَ،
\q1 عَ شَ قٍ رَقَن ﭑ مَ عَلْ مَنفٌي رَقَنمَ مِشِ مَ كِ نَشّ.
\q1 
\v 4 عَ بَرَ ﭑ شَنِن عَ شْنيِ،
\q1 عَ شَ شَنُنتٍيَ بَرَ قِندِ حّلّشِنيِ رَ ﭑ بّ.»
\sp فِنّ شَ مَسٍنيِ عَ شَ شّمّ بّ
\q1 
\v 5 «دٌنسٍ حْشُنمّ سٌ ﭑ يِ، ﭑ كِ مَنفٌي،
\q1 بَرِ مَ شَنُنتٍيَ نَشَن نَ ﭑ بْحّ كُي،
\q1 عَ بَرَ ﭑ سّنبّ بَ ﭑ يِ رَ.
\q1 
\v 6 ﭑ شُنيِ نَ ﭑ شَنُنتٍنيِ بّلّشّ،
\q1 عَ نَ ﭑ مَقُرُكُقٍ عَ يِرٍقَنيِ رَ.»
\sp فِنّ شَ مَسٍنيِ فِنّدِ مّيٍ بّ
\q1 
\v 7 «دَرِ سَلَمُ فِنّدِ مّيٍ، ﭑ بَرَ وٌ مَيَندِ،
\q1 تْوكّ نُن شٍلِ شِلِ رَ نَشٍيٍ نَ وُلَ عِ،
\q1 وٌ نَشَ شَنُنتٍيَ رَشُنُ، وٌ نَشَ عَ رَكٍلِ،
\q1 بٍينُ عَ وَ مَ عَ شْن مَ تّمُي نَشّ.»
\sp فِنّ شَ مَسٍنيِ عَ شَ شّمّ شَ قٍ رَ
\q1 
\v 8 «ﭑ شَنُنتٍنيِ شُي نَ عَ رَ،
\q1 عَ نَ قَقٍ عَ فِ رَ فٍيَيٍ قَرِ.
\q1 
\v 9 عَ فِمَ عَلْ تْوكّ، عَ تُفَنمَ عَلْ شٍلِ.
\q1 عَ نَ بٍ وٌن مَ تّتّ شَنبِ رَ،
\q1 عَ نَ بٍ مَتٌقٍ وُندّرِ رَ.
\q1 
\v 10 عَ نَشَ عَ قَلَ ﭑ بّ،
\q1 ‹ﭑ شَنُنتٍنيِ تٌقَنيِ، كٍلِ، عِ شَ قَ،
\q1 
\v 11 بَرِ مَ حّمّ تّمُي بَرَ دَنفِ،
\q1 تُنّ مُ بِرَ مَ سْنْن.
\q1 
\v 12 سَنسِ نَ بٌفِقٍ دَاشَ،
\q1 حّلّشِن وَشَتِ بَرَ عَ لِ،
\q1 شْنِيٍ نَ عٍ شُي رَ مِنِقٍ وٌن مَ بْشِ مَ.
\q1 
\v 13 شْرّ بِلِ نَ بٌفِقٍ،
\q1 وّنِ بِلِ نَ قُفَقٍ، عَ شِرِ قَن.
\q1 ﭑ شَنُنتٍنيِ، كٍلِ، عِ شَ قَ.
\q1 
\v 14 ﭑ مَ فِنّ، عِ نَشَ عِ نْشُن
\q1 عَلْ فَنبّ عَ نْشُنمَ فّمّيٍ لٌنفٌرِ رَ كِ نَشّ.
\q1 مِنِ، ﭑ وَ مَ عِ شُي حْشُنمّ مّقٍ،
\q1 ﭑ وَ مَ عِ يَتَفِ تٌقَنيِ تٌقٍ.›»
\sp شّمّ شَ مَسٍنيِ عَ شَ مِشِيٍ بّ
\q1 
\v 15 «وٌ شُلُمَسٍيٍ سُشُ،
\q1 نَشٍيٍ وَ مَ مُشُ شَ وّنِ بِلِ قُفَشِيٍ كَنَقٍ.»
\sp فِنّ شَ مَسٍنيِ شّمّ بّ
\q1 
\v 16 «ﭑ شَنُنتٍنيِ قِندِشِ ﭑ فبٍ نَن نَ،
\q1 ﭑ قَن قِندِشِ عَ فبٍ نَن نَ.
\q1 عَ عَ شَ شُرُ سٍيٍ دّ مَدٌنمَ سَنسِ قُفَشِيٍ يَ مَ.
\q1 
\v 17 ﭑ شَنُنتٍنيِ، بٍينُ كُيٍ شَ عِبَ،
\q1 عِ شَ فبِلٍن، عِ شَ عِ فِ عَلْ تْوكّ،
\q1 عِ شَ عِ فِ فٍيَيٍ قَرِ عَلْ شٍلِ.»
\c 3
\s1 فِنّ عَ شَنُنتٍنيِ قٍنقٍ
\sp فِنّ شَ مَسٍنيِ شّمّ شَ قٍ رَ
\q1 
\v 1 «كْي رَ ﭑ بَرَ ﭑ شَنُنتٍنيِ قٍن ﭑ مَ سَدٍ مَ،
\q1 كْنْ ﭑ مُ عَ تٌشِ.
\q1 
\v 2 ﭑ نَشَ كٍلِ، ﭑ نَشَ مِنِ تَا كُي،
\q1 ﭑ شَ ﭑ شَنُنتٍنيِ تٌ، كْنْ ﭑ مُ عَ تٌشِ.
\q1 
\v 3 ﭑ تٌ تَا كَنتَمَيٍ لِ، ﭑ نَشَ عٍ مَشْرِن،
\q1 ‹وٌ بَرَ ﭑ شَنُنتٍنيِ تٌ؟›
\q1 
\v 4 ﭑ تٌ دَنفِ عٍ رَ،
\q1 ﭑ نَشَ ﭑ شَنُنتٍنيِ لِ يِرٍ ندٍ،
\q1 ﭑ نَشَ عَ سُشُ، ﭑ مُ عَ لُ،
\q1 ﭑ نَشَ عَ شَنِن ﭑ نفَ شْنيِ،
\q1 عَ شَ كٌنكٌي كُي ﭑ بَرِشِ دّننَشّ.»
\sp فِنّ شَ مَسٍنيِ فِنّدِ مّيٍ بّ
\q1 
\v 5 «دَرِ سَلَمُ فِنّدِ مّيٍ، ﭑ بَرَ وٌ مَيَندِ،
\q1 تْوكّ نُن شٍلِ شِلِ رَ نَشٍيٍ نَ وُلَ عِ،
\q1 وٌ نَشَ شَنُنتٍيَ رَشُنُ، وٌ نَشَ عَ رَكٍلِ،
\q1 بٍينُ عَ وَ مَ عَ شْن مَ تّمُي نَشّ.»
\b
\q1 
\v 6 «ندٍ نَ قَقٍ كٍلِقٍ فبٍنفبٍرٍن يِرٍ؟
\q1 عَ نَ شُبٍ رَتٍقٍ عَلْ تُورِ.
\q1 نَ تُورِ لُشِ نّ عَلْ سُرَيِ تُورِ نَشَن شِرِ قَن.
\q1 
\v 7 سُلٍمَنِ رَفِسٍ نَ عَ رَ،
\q1 عِسِرَيِلَ شَ سْورِ فبَنفبَلَنيِ تٌنفٌ سٍننِ نَ عَ مَتِقٍ،
\q1 
\v 8 سَنتِدّفّمَ نَ عٍ بِرِن يِ رَ،
\q1 عٍ قَتَ فٍرٍ رَ، عٍ قَتَ مِشِ مَكَنتَدٍ كْي رَ.
\q1 
\v 9 مَنفّ سُلٍمَنِ رَفِسٍ نَ عَ رَ،
\q1 عَ يَءِلَنشِ وُرِ قَنيِ رَ نَشَن كٍلِشِ لِبَن.
\q1 
\v 10 عَ رَشُنمَشِ شّيمَ، فبٍتِ، نُن دُفِ فبٍيلِ رَ.
\q1 دَرِ سَلَمُ فِنّيٍ نُ بَرَ دُفِ دّفّ سُلٍمَنِ رَفِسٍ رَشُنمَقٍ رَ،
\q1 مَنفّ شَ مَرَقَنيِ شَ قٍ رَ.
\q1 
\v 11 سِيٌن فِنّدِ مّيٍ، وٌ شَ مَنفّ سُلٍمَنِ مَتٌ،
\q1 مَنفّ تْنشُمَ نَ عَ شُن مَ،
\q1 عَ نفَ نَشَن سٌشِ عَ يِ رَ عَ شَ قُتِ شِرِ لْشْي.
\q1 نَ لْشْي عَ نُ سّيوَشِ كِ قَنيِ رَ.»
\c 4
\s1 فِنّ مَنِيَشِ سَنسِ يِرٍ نَن نَ
\sp شّمّ شَ مَسٍنيِ فِنّ بّ
\q1 
\v 1 «ﭑ شَنُنتٍنيِ، عِ تٌقَن، عِ تٌقَن.
\q1 عِ يَيٍ رَيَبُ عَلْ فَنبّ،
\q1 عٍ نْشُنشِ مَقٍلٍنيِ كُي.
\q1 عِ شُنسّشّ فبٌ.
\q1 عٍ لُشِ نّ عَلْ سِ فْورّ نَشَن فٌرٌ مَ فَلَدِ فٍيَ قَرِ.
\q1 
\v 2 عِ حِنيِ قِيشّ عَلْ يّشّي فْورّ نَشَن شَبٍ مَشَبَشِ،
\q1 عٍ كٍلِشِ مَشَدٍ.
\q1 عِ حِنيِ كٍرٍن مُ بَشِ،
\q1 عٍ بِرِن نَ عٍ بٌورٍ سّيتِ مَ.
\q1 
\v 3 عِ دّ تٌقَن،
\q1 عِ دّ كِرِ لُشِ نّ عَلْ لُوتِ فبٍيلِ.
\q1 عِ شّرّ تٌقَن عَلْ مَنفٌي نَشَن عِشَبَشِ عَ تَفِ.
\q1 عٍ مَكٌتٌشِ عِ شَ مَقٍلٍنيِ كُي.
\q1 
\v 4 عِ كْنيِ قِلِنشِ،
\q1 عَ لُشِ عَلْ دَوُدَ شَ يِرٍ مَكَنتَشِ عِتٍشِ.
\q1 عِ شَ كْنمَفٌرٍ مَنِيَشِ سْورِيٍ شَ مَكَنتَسٍيٍ نَن نَ،
\q1 نَشٍيٍ فبَكُشِ سْورِ بَنشِ كَنكٍ.
\q1 
\v 5 عِ شِحّ قِرِنيِ لُشِ نّ عَلْ بٌلٍ شَ فُلِيٍ،
\q1 نَشٍيٍ عٍ دّ مَدٌنمَ سَنسِيٍ تٌقَنيِ تَفِ.
\q1 
\v 6 سٌفٍ نَ فٌرٌ، كْي نَشَ سٌ،
\q1 ﭑ تٍمَ نّ لَبُندّ نُن سُرَيِ نَ دّننَشّ.
\q1 
\v 7 ﭑ شَنُنتٍنيِ، عِ تٌقَن،
\q1 سٍسٍ مُ لُشِ عِ شَ تٌقَنيِ رَ.
\q1 
\v 8 ﭑ مَ فِنّ، وٌن شَ كٍلِ لِبَن،
\q1 وٌن شَ كٍلِ لِبَن عَمَنَ فٍيَ قَرِ،
\q1 سٍنِرِ نُن شٍرِ مٌن فٍيَيٍ قَرِ،
\q1 يّتّيٍ نُن بَرَتّيٍ نَ دّننَشّ.
\q1 
\v 9 ﭑ مَ فِنّ، عِ ﭑ سٌندٌنيِ رَ سّيوَ مَ.
\q1 ﭑ شُنيَ، عِ نَ عِ يَ تِ ﭑ نَ، ﭑ بْحّ حّلّشِنمَ نّ.
\q1 عِ شَ كْنمَفٌرٍ تٌقٍ رَقَن ﭑ مَ.
\q1 
\v 10 ﭑ مَ فِنّ، عِ شَ شَنُنتٍيَ حْشُن ﭑ بّ،
\q1 دَنفِقٍ وّنِ رَ.
\q1 عَ شِرِ قَن دَنفِقٍ لَبُندّ رَ.
\q1 
\v 11 ﭑ مَ فِنّ، عِ دّ كِرِ حْشُن كُمِ بّ،
\q1 عِ نّنيِ حْشُن دَنفِ كُمِ نُن شِحّ رَ.
\q1 عِ شَ دُفِ شِرِ لُشِ نّ عَلْ لِبَن شِرِ قَنيِ.»
\b
\q1 
\v 12 «ﭑ مَ فِنّ، عِ قِندِشِ ﭑ فبٍ نَن نَ،
\q1 عَلْ سَنسِ يِرٍ تّتّ رَبِلِنشِ نَشَن نَ.
\q1 ﭑ شُنيَ، عِ لُشِ نّ عَلْ ﭑ مَ كْلْنيِ،
\q1 نَشَن بَلَنشِ، مِشِ فبّتّ مُ نْمَ يٍ بَدٍ نَا.
\q1 
\v 13 عِ قَن عَلْ سَنسِ يِرٍ سَنسِ مْولِ بِرِن نَ دّننَشّ،
\q1 عَلْ مَنفٌي، لَالِ، سَنسِ شِرِ قَنيِ،
\q1 
\v 14 سَنسِ قُفٍ نٍرٍقُنيِ،
\q1 وُرِ بِلِ نَشَن قُحِ حْشُن،
\q1 وُرِ بِلِ نَشَن شِرِ قَن،
\q1 سُرَيِ مْولِ بِرِن كٍلِشِ نَشٍيٍ مَ.
\q1 
\v 15 عِ لُشِ نّ عَلْ يٍ نَشَن مِنِمَ بْشِ مَ،
\q1 نَشَن عَ نِيَمَ لِبَن سَنسِ بِرِن شَ قَن.»
\sp فِنّ شَ مَسٍنيِ شّمّ بّ
\q1 
\v 16 «قٌيٍ قَنيِ شَ قَ كٍلِقٍ كْولَ مَ،
\q1 كٍلِقٍ يِرٍ قَنيِ مَ،
\q1 عَلَكٌ ﭑ مَ سَنسِ شِرِ شَ تٍ.
\q1 ﭑ شَنُنتٍنيِ شَ قَ ﭑ يِرٍ،
\q1 عَ شَ سَنسِ بٌفِ قَنيِ دٌن نَشٍيٍ قِندِشِ عَ فبٍ رَ.»
\c 5
\s1 شّمّ شَ تٌقَنيِ
\sp شّمّ شَ مَسٍنيِ فِنّ بّ
\q1 
\v 1 «ﭑ شَنُنتٍنيِ، ﭑ بَرَ سٌ ﭑ مَ سَنسِ يِرٍ.
\q1 ﭑ شُنيَ، ﭑ بَرَ ﭑ مَ سُرَيِ مَلَن،
\q1 ﭑ بَرَ كُمِ دٌن،
\q1 ﭑ بَرَ وّنِ نُن شِحّ مِن.
\q1 ﭑ بَرَ عَ قَلَ ﭑ بٌورٍيٍ بّ عٍ قَن شَ عٍ مِن،
\q1 عٍ شَ شَنُنتٍيَ كٌلٌن.»
\sp فِنّ شَ مَسٍنيِ شّمّ شَ قٍ رَ
\q1 
\v 2 «ﭑ نُ نَ شِقٍ، كْنْ ﭑ بْحّ مُ شِشِ،
\q1 عَ ﭑ شَنُنتٍنيِ شُي مّشِ،
\q1 نَشَن نُ بَرَ نَادّ كْنكْن.»
\sp شّمّ شَ مَسٍنيِ فِنّ بّ
\q1 «ﭑ مَافِنّ، ﭑ دْشْفِنّ، نَادّ رَبِ ﭑ بّ.
\q1 ﭑ مَ تْوكّ فِنّ، نَشَن شَ تٌقَنيِ مَنِيّ مُ نَ.
\q1 شِنِ بَرَ ﭑ شُنيِ شِنبٍلِ،
\q1 عَ بَرَ ﭑ شُنسّشّ بُندَ.»
\sp فِنّ شَ مَسٍنيِ شّمّ بّ
\q1 
\v 3 «ﭑ حَن نُ بَرَ ﭑ مَ دُفِ بَ،
\q1 قٌ ﭑ مَن شَ عَ رَفٌرٌ ﭑ مَ؟
\q1 ﭑ حَن نُ بَرَ ﭑ سَنيِ مَشَ،
\q1 قٌ ﭑ مَن شَ تِ بْشِ مَ؟
\q1 
\v 4 ﭑ شَنُنتٍنيِ نَشَ عَ بّلّشّ رَ سٌ نَادّ لٌنفٌرِ رَ،
\q1 عَلَكٌ عَ شَ عَ رَبِ.
\q1 ﭑ بْحّ نَشَ سّيوَ عَ شَ قٍ رَ.
\q1 
\v 5 ﭑ نَشَ كٍلِ عَلَكٌ ﭑ شَ نَادّ رَبِ ﭑ شَنُنتٍنيِ بّ.
\q1 لَبُندّ نُ نَ ﭑ بّلّشّ مَ،
\q1 تُرٍ نُ نَ ﭑ بّلّشّسٌلٍيٍ مَ.
\q1 نَ بِرِن نَشَ لُ نَادّ رَبِ سٍ مَ.
\q1 
\v 6 ﭑ نَشَ نَادّ رَبِ ﭑ شَنُنتٍنيِ بّ،
\q1 كْنْ عَ حَن نُ بَرَ سِفَ.
\q1 ﭑ بْحّ نَشَ سُننُن.
\q1 ﭑ نَشَ عَ قٍن، كْنْ ﭑ مُ عَ تٌشِ.
\q1 ﭑ نَشَ عَ شِلِ، كْنْ عَ مُ ﭑ مَ شِلِ رَتِنشِ.
\q1 
\v 7 تَا كَنتَمَيٍ تٌ ﭑ تٌ،
\q1 عٍ نَشَ ﭑ سُشُ، عٍ ﭑ بْنبْ،
\q1 عٍ ﭑ مَ شِنبٍلِ دُفِ مُحَ.»
\sp فِنّ شَ مَسٍنيِ فِنّدِ مّيٍ بّ
\q1 
\v 8 «دَرِ سَلَمُ فِنّدِ مّيٍ،
\q1 ﭑ بَرَ وٌ مَيَندِ،
\q1 شَ وٌ بَرَ ﭑ شَنُنتٍنيِ تٌ،
\q1 وٌ شَ عَ قَلَ عَ بّ عَ شْلِ بَرَ ﭑ سُشُ شَنُنتٍيَ شَ قٍ رَ.»
\sp فِنّدِ مّيٍ شَ مَسٍنيِ فِنّ بّ
\q1 
\v 9 «فِنّ تٌقَنيِ قِسَمَنتٍ،
\q1 عِ شَنُنتٍنيِ قَن عَ بِرِن بّ؟
\q1 عِ بَرَ مُشُ مَيَندِ
\q1 بَرِ مَ عَ قَن عَ بِرِن بّ؟»
\sp فِنّ شَ مَسٍنيِ فِنّدِ مّيٍ بّ
\q1 
\v 10 «ﭑ شَنُنتٍنيِ كِرِ قِيشّ، عَ رَفبٍيلِ.
\q1 عَ كٌلٌن حْشُن نَ شّمّ وُلُ قُ يَ مَ.
\q1 
\v 11 عَ شُنيِ لُشِ نّ عَلْ شّيمَ قَنيِ،
\q1 عَ شُنسّشّ عِقْورْشِ عَلْ شَشَ قْورّ شَبٍ.
\q1 
\v 12 عَ يَيٍ رَيَبُ عَلْ فَنبّ نَشٍيٍ تِشِ شُرٍ دّ رَ،
\q1 عٍ قِيشّ عَلْ شِحّ، عٍ يَنبَمَ عَلْ دِيَمَن.
\q1 
\v 13 عَ شّرّيٍ لُشِ نّ عَلْ لَبُندّ يَءِلَندٍ،
\q1 عَ دّ كِرِ مَنِيَشِ سَنسِ قُفٍ تٌقَنيِ نَن نَ،
\q1 عَ شِرِ حْشُن.
\q1 
\v 14 عَ بّلّشّ تٌقَن عَلْ بّلّشّسٌلٍرَ سٌي شّيمَ دَاشِ،
\q1 دِيَمَن نَ نَشَن مَ.
\q1 عَ قَتٍ لُشِ نّ عَلْ سِلِ حِنيِ قِيشّ،
\q1 فّمّ تٌقَنيِ مْولِ ندٍ، يٍيٍ مَسٌشِ نَشَن مَ.
\q1 
\v 15 عَ سَنيِ سّنبّ فبٌ عَلْ قَنيٍ قِيشّ،
\q1 نَشَن تِشِ شّيمَ قَرِ.
\q1 عَ تٌقَن عَلْ لِبَن،
\q1 عَ عِتٍ عَلْ سّدِرِ وُرِ بِلِيٍ.
\q1 
\v 16 عَ دّ عِحْشُن، عَ شَ قٍ بِرِن قَن.
\q1 دَرِ سَلَمُ فِنّدِ مّيٍ، ﭑ شَنُنتٍنيِ نَ نَ كِ نّ،
\q1 ﭑ دّ قَن بٌورٍ نَن عَ رَ.»
\c 6
\s1 فِنّ شَ تٌقَنيِ
\sp فِنّدِ مّيٍ شَ مَسٍنيِ فِنّ بّ
\q1 
\v 1 «فِنّ تٌقَنيِ قِسَمَنتٍ،
\q1 عِ شَنُنتٍنيِ سِفَشِ مِندٍن؟
\q1 عَ سِفَ مِندٍن مَبِرِ عَلَكٌ وٌن بِرِن شَ عَ قٍن؟»
\sp فِنّ شَ مَسٍنيِ فِنّدِ مّيٍ بّ
\q1 
\v 2 «ﭑ شَنُنتٍنيِ بَرَ سِفَ عَ شَ سَنسِ يِرٍ،
\q1 سٍ شِرِ قَنيِ نَ دّننَشّ،
\q1 عَلَكٌ عَ شَ عَ مَحّرّ،
\q1 عَ شَ سَنسِ قُفٍ تٌقَنيِ ندٍ بَ.
\q1 
\v 3 ﭑ قِندِشِ ﭑ شَنُنتٍنيِ فبٍ نَن نَ،
\q1 عَ قَن قِندِشِ ﭑ فبٍ نَن نَ.
\q1 عَ لُمَ عَ مَحّرّ رَ سَنسِ قُفٍ تٌقَنيِيٍ يَ مَ.»
\sp شّمّ شَ مَسٍنيِ فِنّ بّ
\q1 
\v 4 «ﭑ دّ قَن بٌورٍ، عِ تٌقَن عَلْ تِرِ سَ،
\q1 عِ رَيَبُ عَلْ دَرِ سَلَمُ،
\q1 عِ سّنبّ فبٌ عَلْ عِسِرَيِلَ شَ سْورِيٍ.
\q1 
\v 5 عِ نَشَ عِ يَ تِ ﭑ نَ،
\q1 شَ نَ مُ عَ رَ ﭑ شَشِلِ عِقُمَ نّ.
\q1 عِ شُنسّشّيٍ فبٌ.
\q1 عٍ لُشِ نّ عَلْ سِ فْورّ نَشَن فٌرٌ مَ فَلَدِ فٍيَ قَرِ.
\q1 
\v 6 عِ حِنيِ قِيشّ عَلْ يّشّي فْورّ نَشَن شَبٍ مَشَبَشِ،
\q1 عٍ كٍلِشِ نَشٍيٍ مَشَدٍ.
\q1 عِ حِنيِ كٍرٍن مُ بَشِ،
\q1 عٍ بِرِن دّحّشِ.
\q1 
\v 7 عِ شّرّ تٌقَن عَلْ مَنفٌي نَشَن عِشَبَشِ عَ تَفِ.
\q1 عٍ نْشُنشِ عِ شَ مَقٍلٍنيِ بُن مَ.
\q1 
\v 8 مَنفّ فِنّ تٌنفٌ سٍننِ نْمَ لُدٍ نَا،
\q1 مَنفّ شَ كٌنيِ فِنّ تٌنفٌ سٌلٌمَسَشَن قَن لُ نَا،
\q1 عَ نُن عَ شَ فِنّدِ مّ تٌقَنيِ فبٍفبٍ نَشَن كْنتِ مُ كٌلٌن.
\q1 
\v 9 كْنْ فِنّ كٍرٍن ثٍتِ نَن ﭑ يِ نَشَن دَنفِ عٍ بِرِن نَ.
\q1 عَ كٍرٍن نَن نَ عَ نفَ بّ،
\q1 نَشَن نَقَنشِ عَ مَ دَنفِقٍ عٍ بِرِن نَ.
\q1 فِنّدِ مّيٍ، مَنفّ فِنّيٍ، نُن مَنفّ شَ فِنّيٍ،
\q1 عٍ بِرِن عَ مَتْشْمَ يِ وْيّنيِ رَ،
\q1 
\v 10 ‹ندٍ نَ يِ فِنّ رَ،
\q1 نَشَن يَنبَمَ عَلْ سُبَشّ نَءِيَلَنيِ،
\q1 نَشَن تٌقَن عَلْ كِكٍ،
\q1 نَشَن قَتٍ يَنبَمَ عَلْ سٌفٍ،
\q1 نَشَن مَمِرِن عَلْ تُنبُي فَالِ؟›»
\sp فِنّ شَ مَسٍنيِ عَ شَ قُتِ شَ قٍ رَ
\q1 
\v 11 «ﭑ وَ مَ فٌرٌقٍ سَنسِ يِرٍ،
\q1 عَلَكٌ ﭑ شَ سَنسِ نّينّ تٌ فُلُنبَ كُي،
\q1 عَلَكٌ ﭑ شَ عَ كٌلٌن شَ وّنِ بِلِ بَرَ بٌفِ،
\q1 شَ مَنفٌي بَرَ قُفَ.
\q1 
\v 12 ﭑ مُ نُ عَ كٌلٌن
\q1 شَ ﭑ يّتّ قَمَ تٍدٍ ﭑ مَ حَمَ شَ مَنفّ رَفِسٍ كُي.»
\c 7
\s1 فِنّ نُن شّمّ شَ شَنُنتٍيَ
\sp فِنّدِ مّيٍ شَ مَسٍنيِ فِنّ بّ
\q1 
\v 1 «سُلَمِكَ، عِ شَ فبِلٍن، عِ شَ فبِلٍن،
\q1 عَلَكٌ مُشُ شَ عِ مَتٌ.»
\sp شّمّ شَ مَسٍنيِ فِنّيٍ بّ
\q1 «مُنقٍ رَ وٌ سُلَمِكَ مَتٌمَ
\q1 عَ قَرٍ بٌرٌنقٍ كِ نَشّ حَمَ يَ مَ؟»
\sp شّمّ شَ مَسٍنيِ فِنّ بّ
\q1 
\v 2 «مَنفّ شَ دِ، عِ سَنيِ تٌقَن سَنكِرِ كُي.
\q1 عِ تَفِ بِلِنيِ رَيَبُ عَلْ شُنمَسٍ مِشِ نَشَن يَءِلَنشِ.
\q1 
\v 3 عِ قُرِ دِفِلِن، عَ رَقٍشِ قٍ قَنيِ رَ،
\q1 عِ تَفِ لُشِ عَلْ مّنفِ مَلَنشِ،
\q1 عَ رَبِلِنشِ سَنسِ قُفٍ تٌقَنيِيٍ رَ.
\q1 
\v 4 عِ شِحّ قِرِنيِ لُشِ عَلْ شٍلِ شَ فُلِيٍ.
\q1 
\v 5 عِ كْنيِ قِلِنشِ،
\q1 عَ لُشِ عَلْ يِرٍ مَكَنتَشِ عِتٍشِ،
\q1 نَشَن يَءِلَنشِ سِلِ حِنيِ رَ.
\q1 عِ يَيٍ لُشِ عَلْ يٍ رَفَتَدٍيٍ شّسِبْن،
\q1 بَتِ رَبِمِ نَادّ سّيتِ مَ.
\q1 عِ حْي لُشِ عَلْ لِبَن شَ يِرٍ مَكَنتَشِ،
\q1 نَشَن يَ رَقِندِشِ دَ مَسِ مَ.
\q1 
\v 6 عِ شُنيِ لُشِ عَلْ كَرٍ مٍلٍ فٍيَ،
\q1 عِ شُنسّشّ لُشِ عَلْ دُفِ فبٍيلِ.
\q1 مَنفّ مُ نْمَ عَ يَ بَدٍ نَشَن نَ.
\q1 
\v 7 ﭑ شَنُنتٍنيِ، عِ تٌقَن،
\q1 ﭑ شَنُنتٍنيِ قَنيِ، عِ رَقَن ﭑ مَ.
\q1 
\v 8 عِ كُيَ عَلْ تُفِ بِلِ،
\q1 عِ شِحّ مِسَالِشِ نَشَن بٌفِيٍ رَ.
\q1 
\v 9 ﭑ بَرَ عَ قَلَ ﭑ يّتّ بّ،
\q1 ‹ﭑ شَ تٍ نَ تُفِ كْن نَ،
\q1 ﭑ شَ نَ بٌفِ سُشُ.›
\q1 عِ شِحّ مِسَالِشِ وّنِ بِلِ بٌفِ نَن نَ،
\q1 عِ دّ شِرِ حْشُن عَلْ مَنفٌي،
\q1 
\v 10 عِ دّ رَقَن ﭑ مَ دَنفِقٍ وّنِ رَ.»
\sp فِنّ شَ مَسٍنيِ شّمّ بّ
\q1 «عِيٌ، عَ مَنِيَشِ وّنِ نَن نَ،
\q1 نَشَن قِندِشِ ﭑ شَنُنتٍنيِ فبٍ رَ،
\q1 وٌن قِرِن نَشَن مِنمَ.
\q1 
\v 11 ﭑ بَرَ قِندِ ﭑ شَنُنتٍنيِ فبٍ رَ،
\q1 عَ شْلِ نَ ﭑ تَن نَن مَ.
\q1 
\v 12 ﭑ شَنُنتٍنيِ، وٌن شَ مِنِ دَاشَ،
\q1 وٌن شَ كْي رَدَنفِ تَا شُنشُرِيٍ كُي.
\q1 
\v 13 وٌن كُرُنمَ نّ سِفَقٍ رَ وّنِ بٌفِ بِلِ مَتٌدٍ،
\q1 وٌن شَ عَ تٌ شَ عٍ قُفَشِ،
\q1 وٌن شَ عَ مَتٌ شَ مَنفٌي قَن قُفٍ بَرَ مِنِ.
\q1 مّننِ ﭑ ﭑ مَ شَنُنتٍيَ مَسٍنمَ نّ عِ بّ.
\q1 
\v 14 شَنُنتٍيَ حْشُن عَلْ سَنسِ بٌفِ.
\q1 ﭑ نَ قٍ قَنيِ قٌرِ نُن عَ نّينّ رَفَتَشِ عِ تَن نَن بّ.»
\c 8
\s1 شَنُنتٍيَ سّنبّ فبٌ
\b
\sp فِنّ شَ مَسٍنيِ شّمّ بّ
\q1 
\v 1 «شَ عِ قِندِشِ ﭑ تَارَ شّمّمَ نَن نَ نُ،
\q1 ﭑ نفَ شِحّ قِشِ نَشَن مَ،
\q1 ﭑ نُ نْمَ عِ مَسُنبُدٍ مِشِ يَ شْرِ ﭑ مُ يَافِمَ نَ رَ.
\q1 
\v 2 ﭑ نُ نْمَ عِ شَنِندٍ ﭑ نفَ يِرٍ،
\q1 عِ شَ قِندِ ﭑ كَرَ مْشْ رَ،
\q1 ﭑ قَ وّنِ قَنيِ نُن مَنفٌي يٍ سٌ عِ يِ رَ.»
\sp فِنّ شَ مَسٍنيِ فِنّدِ مّيٍ بّ
\q1 
\v 3 «ﭑ شُنيِ نَ ﭑ شَنُنتٍنيِ بّلّشّ،
\q1 عَ نَ ﭑ مَقُرُكُقٍ عَ يِرٍقَنيِ رَ.
\q1 
\v 4 دَرِ سَلَمُ فِنّدِ مّيٍ، ﭑ بَرَ وٌ مَيَندِ،
\q1 وٌ نَشَ شَنُنتٍيَ رَشُنُ، وٌ نَشَ عَ رَكٍلِ،
\q1 بٍينُ عَ وَ مَ عَ شْن مَ تّمُي نَشّ.»
\sp فِنّدِ مّيٍ شَ مَسٍنيِ فِنّ شَ قٍ رَ
\q1 
\v 5 «ندٍ نَ يِ فِنّ رَ نَشَن كٍلِشِ فبٍنفبٍرٍن يِرٍ،
\q1 عَ عَ شَنُنتٍنيِ بّلّشّ سُشُشِ؟»
\sp فِنّ شَ مَسٍنيِ شّمّ بّ
\q1 «ﭑ بَرَ عِ رَشُنُ مَنفٌي بِلِ بُن مَ،
\q1 عِ نفَ تْورْشِ عِ بَرِدٍ دّننَشّ.
\q1 
\v 6 ﭑ شَ قِندِ عِ كٍرٍن فبٍ رَ،
\q1 عَلْ عِ شَ تْنشُمَ نَشَن فبَكُشِ عِ كْن مَ،
\q1 شَ نَ مُ عَ رَ نَشَن نَسٌشِ عِ بّلّشّسٌلٍ رَ،
\q1 بَرِ مَ شَنُنتٍيَ سّنبّ فبٌ دَنفِقٍ قَشّ رَ.
\q1 ﭑ وَ مَ عِ شْن ﭑ يّتّ بّ،
\q1 عَلْ عَلِفِيَمَ وَ مَ مِشِيٍ شْن مَ كِ نَشّ.
\q1 شَنُنتٍيَ سّنبّ فبٌ عَلْ تّ،
\q1 عَلَتَلَ نَشَن نَدّشّشِ، عَ مُ شُبٍنمَ.
\q1 
\v 7 بَا يٍ مُ نْمَ شَنُنتٍيَ رَشُبٍندٍ،
\q1 شُرٍ يٍ مُ نْمَ عَ بَدٍ.
\q1 مِشِ نَشَن وَ مَ عَ هَرِفٍ بِرِن مَسَرَقٍ شَنُنتٍيَ رَ،
\q1 مِشِ نَ كَنيِ مَيٍلٍمَ نّ.»
\sp فِنّ تَارَ شّمّمَيٍ شَ مَسٍنيِ
\q1 
\v 8 «شُنيَ فِنّمَ نَ مُشُ يِ رَ،
\q1 عَ مُ مْشِ سِندٍن، عَ شِحّيٍ شُرُن.
\q1 مُشُ قَمَ مُنسٍ رَبَدٍ عَ بّ
\q1 مِشِ نَ عَ قٍن تّمُي نَشّ؟
\q1 
\v 9 شَ عَ لُشِ عَلْ تّتّ نَشَن بَلَنشِ،
\q1 مُشُ عَ يّنسّمَ نّ فبٍتِ رَ،
\q1 كْنْ شَ عَ لُشِ عَلْ نَادّ نَشَن نَبِشِ،
\q1 مُشُ عَ بَلَنمَ نّ.»
\sp فِنّ شَ مَسٍنيِ شّمّ بّ
\q1 
\v 10 «ﭑ تَن لُشِ نّ عَلْ تّتّ نَشَن مُ رَبِمَ،
\q1 ﭑ شِحّيٍ قِندِشِ يِرٍ مَكَنتَشِيٍ نَن نَ.
\q1 نَ كُي ﭑ بَرَ قِندِ ﭑ شَنُنتٍنيِ شَ بْحّسَ رَ.
\q1 
\v 11 وّنِ سَنسِ بِلِ يِرٍ نُ نَ سُلٍمَنِ يِ رَ بَلِ هَمٌن.
\q1 عَ نَشَ عَ تَشُ عَ شَ وَلِكّيٍ رَ،
\q1 نَشٍيٍ نُ لَنمَ عٍ شَ فبٍتِ كْبِرِ كٌلٍ وُلُ قِ نَ شَ قٍ رَ.
\q1 
\v 12 ﭑ تَن نَن ﭑ مَ وّنِ بِلِيٍ يِرٍ مَكَنتَمَ.
\q1 عِ بَرَ فبٍتِ كٌلٍ وُلُ سْتْ،
\q1 عِ شَ وَلِكّيٍ بَرَ فبٍتِ كٌلٍ كّمّ قِرِن سْتْ.»
\sp شّمّ شَ مَسٍنيِ فِنّ بّ
\q1 
\v 13 «عِ تَن نَشَن نَ سَنسِ يِرٍ،
\q1 عِ بٌورٍيٍ وَ مَ عِ شُي رَ مّقٍ،
\q1 كْنْ ﭑ تَن نَن نَ رَ مّمَ.»
\sp فِنّ شَ مَسٍنيِ شّمّ بّ
\q1 
\v 14 «ﭑ شَنُنتٍنيِ،
\q1 عِ شَ عِ فِ عَلْ شٍلِ،
\q1 عِ شَ عِ فِ عَلْ تْوكّ تٍقٍ رَ فٍيَيٍ قَرِ،
\q1 سُرَيِ حْشُنمّ نَ دّننَشّ.»
