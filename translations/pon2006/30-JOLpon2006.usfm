\id JOL Pohnpeian Bible
\h JOEL
\toc1 JOEL
\toc2 JOEL
\toc3 Joel
\mt1 Pwuhken SOEL
\is1 Oaralap en Pwuhk wet
\ip Rongen soukohp Soel rehtail me tikitik, oh e sohte dehde iahd de ahnsou me e momourki. Ahpw likamwete pwuhk wet wiawihda nan senturi kelimau de kapahieu mwohn Krais, ni mwehin Persia. Soel koasoiahda duwen pelin loukost ehu oh duwen lehk lapalap en pihl nan Palestain. Ni wiewia pwukat e kin kilang kilel en Rahnen Kaun-o me kohkohdo, ahnsou me Kaun-o pahn ketin kaloke irail kan me kin uhwong pwungen sapwellime kupwur. Soukohp Soel eri uhsehiong aramas akan sapwellimen Kaun-o mahsen pwe re en koluhla, oh sapwellime inoun onehda sapahl oh kupwuramwahwih irail. Me konehng kitail en tehk mwahu inou me Koht ketin wiadahr, ni eh ketin inoukihda me e pahn ketin kadarodo sapwellime ngehn pohn aramas koaros, ohl oh lih, me tikitik oh me mah kan.
\iot Audepe ni Oaralap
\io1 Pelin loukost 1.1—2.17
\io1 Inoupen onohnsapahl 2.18-27
\io1 Rahnen Kaun-o 2.28—3.21
\c 1
\s1 Nsensuwed pwehki Mwomwlahn Wahnsahpw akan
\p 
\v 1 Iet mahsen en KAUN-O ong Soel, nein Petwel.
\q1 
\v 2 Kumwail me mah kan, kumwail rong;
\q2 oh aramas teikan koaros nan Suda, kumwail pil rong.
\q1 Ia duwe, mie mehkot wiawiher nan amwail mwehiet,
\q2 de nan mwehin samamwail ako, me rasehng wiawi wet?
\q1 
\v 3 Kumwail padahkihong noumwail seri kan duwe;
\q2 noumwail seri kan ahpw pahn padahkihong neirail seri kan,
\q2 oh nein neirail seri kan ahpw pahn uhd padakihong dihen mwuhr kan.
\b
\q1 
\v 4 Pelin loukost kan kangalahr wahnsahpw akan;
\q2 ni ehu pelin loukost ar kin kohkohla, a ehu pelin loukost kin uhd kohdo.
\q1 
\v 5 Kumwail me kin kamam sakau, kumwail pirida oh sengiseng;
\q2 kumwail me kin nim wain, kumwail pil sengiseng;
\q2 pwe kreip, mehn wiahda wain kapw, mwomwlahr.
\b
\q1 
\v 6 Pelin loukost ngeder ehu kauwelahr sapwatailo;
\q2 re me kehlail oh ngeder mehlel;
\q2 ngihrail kan me keng, rasehng ngihn laion.\x - \xo 1:6 \xt Kaud. 9.8.\x*
\q1 
\v 7 Re kamwomwalahr atail mwetin wain kan,
\q2 oh pil kangalahr atail tuhke pik kan.
\q1 Re rerehsangehr kilin tuhke kan
\q2 lao pwetepwetala.
\b
\q1 
\v 8 Eri, kumwail sengiseng, kumwail aramas akan, rasehng serepein men me kin mwahieiki
\q2 ohl emen me e inoun pwopwoudiong eh melahr.
\q1 
\v 9 Solahr wahnsahpw de wain mehn meirong nan Tehnpas Sarawio;
\q2 samworo kan pil sengiseng pwehki eh solahr me re en meirongkihong KAUN-O.
\q1 
\v 10 Sahpw akan tehnlahr;
\q1 pwehl en nan mwetuwel kin mwahmwahiei;
\q2 pwehki werentuhke kan mwomwlahr,
\q2 oh kreip kan mwomwlahr;
\q2 oh tuhke olip kan pil mengidier.
\b
\q1 
\v 11 Kumwail soumwet kan, kumwail mwahiei;
\q1 kumwail me kin apwahpwalih mwetin wain kan, kumwail pil sengiseng,
\q2 pwehki wihd kan, parli kan
\q2 oh pil wahnsahpw akan koaros mwomwlahr.
\q1 
\v 12 Mwetin wain kan oh tuhke pik kan pil mengilahr.
\q2 tuhke koaros me kin wa pil mengilahr.
\q1 En aramas akan ar peren sohralahr.
\q1 
\v 13 Kumwail samworo kan, me kin patohwanda meirong pohn pei sarawio,
\q2 kumwail pwuhriong nan likoun nsensuwed oh mwahiei.
\q1 Kumwail pedolong nan Tehnpas Sarawio oh mwahmwahieiki erein pwohng ehu pwon!
\q1 Solahr wahnsahpw de wain mehn meirong ong amwail Koht.
\q1 
\v 14 Kumwail koasoanediong aramas akan re en kaisihsol;
\q2 kumwail kapokoneirailpene pwe re en kaudok!
\q1 Kumwail kapokonepene kaun akan,
\q2 oh aramas en Suda koaros
\q2 nan Tehnpas Sarawien KAUN-O, amwail Koht,
\q2 oh likweriong ih!
\q1 
\v 15 Rahnen KAUN-O kerendohr,
\q2 rahn me Wasa Lapalap pahn ketikihdo mehn kamwomwala wasa.
\q2 Ia pahn uwen kamasepwehk en rahno!\x - \xo 1:15 \xt Ais. 13.6.\x*
\b
\q1 
\v 16 Pein masatail udiahlehr wahnsahpw akan ar mwomwmwomwlahr.
\q2 Solahr peren nan Tehnpas Sarawien atail Koht.
\q1 
\v 17 Werentuhke kan mehkihla madekeng en pwehlo.
\q1 Solahr wahnsahpw mehn nekinekla;
\q2 ihme kahrehda imwen nahk kan tehnlahr oh ohlahr.
\q1 
\v 18 Pelin kou kan wie weriwerki ar nsensuwed,
\q2 pwehki eh solahr dihpw me re en kang;
\q2 pelin sihpw kan pil wie lokolok.
\q1 
\v 19 Maing KAUN, I kin likweriong komwi,
\q2 pwehki dihpw oh tuhke kan eh mengilahr,
\q2 likamwete kisiniei me kamwasikahla.
\q1 
\v 20 Mahn lawalo kan pil iang likweriong komwi,
\q2 pwehki piletik kan pil madadahr.
\c 2
\s1 Loukost kan me wia mehn Kilel ehu duwen Rahnen KAUN-O
\q1 
\v 1 Kumwail peuk sowi nan Saion,
\q2 pohn dohl sarawien\f a \fr 2:1 \fk DOHL SARAWI: \ft Tehk Saion nan kawehwehpen lepin mahsen kan.\f* Koht.
\q1 Kumwail rerrer, kumwail mehn Suda kan!
\q2 Rahnen KAUN-O kerendohr.
\q1 
\v 2 Rahno pahn rotorot oh kansensuwed,
\q2 e pahn mahliok oh depwekin.
\q1 Pelin loukost ngeder kan kin kohkohdo,
\q2 rasehng rotorot me kipehdi nahna kan.
\q1 Sohte mehkot me wiawiher me duwehte met,
\q2 oh sohte pahn pil mie mwuhr.
\b
\q1 
\v 3 Re kin kangala tuhke kan, likamwete kisiniei me karongehla.
\q2 A sahpw akan me mi mwohrail rasehng Mwetuwel en Ihden,
\q2 a sahpw akan me mi mwurirail wialahr sapwtehn me sohte mehkot kak mour ie.
\q2 Sohte mehkot me kak pitsang irail.
\q1 
\v 4 Re mwomwen oahs;
\q2 re kin tang duwehte oahs en mahwen.\x - \xo 2:4 \xt Kaud. 9.7-9.\x*
\q1 
\v 5 Ngilen ar lusulusseli pohn nahna kan
\q2 rasehng ngilen werennansapw en mahwen;
\q2 de ngilen dihpw meng eh kin lulda.
\q1 Re ireklahr rasehng lapalahn karis ehu me onopadahr ong mahwen.
\q1 
\v 6 Ni arail kohkohdo, aramas koaros kin masepwehkada,
\q2 oh masarail kin poh reireila.
\q1 
\v 7 Re kin pei duwehte sounpei kan;
\q2 re kin doudahng pohn kehl kan duwehte sounpei kan.
\q1 Irail koaros kin inenweite,
\q2 oh sohte wekidekla ekis wasa tohrohr
\q2 
\v 8 de sohte me pil kin keidla mwohn emen.
\q1 Re kin kohweite kauwehla wasahn poadoandoar kan,
\q2 oh sohte mehkot kak kapweiekiraildi.
\q1 
\v 9 Re kin tangowehng ni kahnimwo;
\q2 re kin tang pohn kehl kan;
\q2 re kin doudahng nan ihmw kan,
\q2 oh pwedilong nan wenihmwtok kan duwehte sounpirap akan.
\b
\q1 
\v 10 Sampah kin rerrer mwohrail,
\q2 oh pahnlahng pil kin rerrer.
\q1 Ketipin oh maram kin rotala,
\q2 oh usuh kan kin sohla linge.\x - \xo 2:10 \xt Kaud. 8.12.\x*
\q1 
\v 11 Kapitien KAUN-O kin ngiringirisek ni eh kin ketin mahseniong sapwellime kariso.
\q2 Sounpei ko me kin peikiong
\q2 me ngeder oh kehlail.
\q1 Meid kamasepwehk rahnen KAUN-O!
\q2 Ihs me kak pitsang?\x - \xo 2:11 \xt Kaud. 6.17.\x*
\s1 Paeker en Koluhla
\q1 
\v 12 KAUN-O ahpw mahsanih, “Pil ahnsou wet
\q2 kumwail koluhla ni mehlel oh pwurkihdo rehi,
\q2 amwail kaisihsol, sengiseng, oh mwahmwahiei.
\q1 
\v 13 Ohlahn mohngiongimwail en kasalehda amwail nsensuwed;
\q2 amwail tehrpeseng amwail likou kan sohte itar.”
\b
\q1 Kumwail pwurodohng KAUN-O, amwail Koht.
\q2 Ih me kupwurkalahngan oh diren mahk;
\q2 ih me ketin kanengamah oh kin dadaur sapwellime inou;
\q2 ahnsou koaros e kin ketin onopada en kupwurmahk oh sohte ketikihdo kalokolok.
\q1 
\v 14 Mweinele KAUN-O, amwail Koht, pahn ketin wekidala kupwure
\q2 oh kupwuramwahwihkin kumwail wahnsahpw ngeder.
\q1 Eri, kumwail ahpw pahn kakehr meirongkihong wahnsahpw oh wain.
\b
\q1 
\v 15 Peuk sowi pohn Nahna Saion;
\q2 kapokonepene aramas akan pwe re en kaudok oh kaisihsol.
\q1 
\v 16 Kapokonepene aramas akan,
\q2 kaunopadahng irail ehu wie lamalam sarawi;
\q2 kahrehdo me mah kan;
\q2 kapokonepene seri kan,
\q2 iangahki seri pwelel kan.
\q2 Me ahpwtehn pwopwoudida kan
\q2 pahn pil mweselsang nan imwarail kan oh kodohng wasaht.
\q1 
\v 17 Samworo kan, me kin papah KAUN-O
\q2 nanpwungen pei sarawio oh wenihmwen Tehnpas Sarawio,
\q1 re en sengiseng oh kapakap, patohwan,
\q2 “Maing KAUN, komwi ketin kupwurehla sapwellimomwi aramas akan.
\q2 Komwi dehr ketin mweidohng wehi teikan en kepitkin kiht
\q2 ni ar kin nda, ‘Ia amwail Koht?’”\x - \xo 2:17 \xt 1 Mak. 7.36-38.\x*
\s1 Sahpw akan Pwurehng Pwelmwahula
\q1 
\v 18 Eri, KAUN-O ahpw ketin kasalehda me e kupwurelahr sapwellime sahpwo,
\q2 oh pil ketin kupwurmahkohng sapwellime aramas akan.
\q1 
\v 19 Ih eri ketin sapeng irail, mahsanih,
\q2 “Met I pahn kihong kumwail
\q2 wahnsahpw oh wain oh lehn olip;
\q2 oh kumwail pahn medkihla.
\q2 Wehi teikan solahr pahn kin mwamwahlikin kumwail.
\q1 
\v 20 I pahn kapwurehsang rehmwail karis en loukost me kohdo sang paliepeng,
\q2 oh pahn kasarelahng ekei irail nan sapwtehn.
\q1 Arail karis akan me kin mi mwowe pahn pekeuslahng nan Sehden Mehla,
\q2 oh arail karis akan me kin mi mwurirail pahn pekeuslahng nan Sehd Mediderenien.
\q2 Kahleparail pahn pwohsuwedla.
\q1 I pahn kamwomwirailla pwehki mehkoaros me re wiahiong kumwail.
\b
\q1 
\v 21 “Kumwail mwetuwel kan, kumwail dehr masepwehk,
\q2 ahpw kumwail peren oh nsenamwahu,
\q2 pwehki mehkoaros me KAUN-O wiahiongkumwailehr.
\q1 
\v 22 Kumwail mahn akan, kumwail dehr masepwehk;
\q2 pwe dihpw kan poh molomollahr;
\q2 tuhke kan weuwa,
\q2 oh diren pik oh kreip.
\b
\q1 
\v 23 “Kumwail mehn Saion, kumwail nsenamwahula,
\q2 kumwail perenkihda mehkan me KAUN-O, amwail Koht, ketin wiahiongkumwailehr.
\q2 E ketin kamweredier keteu me konehng ni ahnsoun rahk;
\q2 e pil ketin kamweredier keteu ni ahnsoun pou,
\q2 oh pil ni ahnsoun karakar, duwehte mahs.
\q1 
\v 24 Wasahn kamwakele wahnsahpw akan pahn direkihla wahnsahpw;
\q2 pwoahr kan limwahn wasahn tiak kreip pahn direkihla wain oh lehn olip.
\q1 
\v 25 I pahn kapwurehiong kumwail mehkan me sohrala sang kumwail
\q2 nan sounpahr ako me pelin loukost ko kangala amwail wahnsahpw akan.
\q2 Pwe ngehi me kadarowohng kumwail karis wet.
\q1 
\v 26 Ahnsou wet kanamwail mwenge pahn itar, oh kumwail pahn medkihla.
\q2 Kumwail pahn kapinga KAUN-O, amwail Koht,
\q2 me ketin wiahiong kumwail manaman kapwuriamwei kan.
\q2 Solahr me pahn pwurehng mwamwahliki nei aramas akan.
\q1 
\v 27 Eri, kumwail mehn Israel kan, kumwail pahn ese me I kin ketikette nanpwungamwail,
\q2 oh me ngehi, KAUN-O, me amwail Koht,
\q2 oh sohte pil emen tohrohr.
\q2 Solahr me pahn pwurehng mwamwahliki nei aramas akan.”
\s1 Rahnen KAUN-O
\q1 
\v 28 “Mwurin mepwukat I pahn kamwerehdi ngeni pohn aramas akan koaros:
\q2 noumwail pwutak oh serepein kan pahn kalohkiseli ei mahsen;
\q2 me mah kan rehmwail pahn wia auraman kei,
\q2 oh noumwail mwahnakapw kan pahn kilang kaudiahl kan.\x - \xo 2:28 \xt Wie. 2.17-21.\x*
\q1 
\v 29 Ni ahnsowo I pahn kamwerehdi ngeni
\q2 pil pohn lidu kan, ohl oh lih, sohte lipilipil.
\b
\q1 
\v 30 “I pahn kihong sampah oh pahnlahng
\q2 ei kehkehlik kei duwen rahno;
\q2 kamaramas pahn wiawi, kisiniei, oh ediniei laud, duwehte depwek kan.
\q1 
\v 31 Ketipin pahn rotala,
\q2 oh maram pahn weitahtahla duwehte nta
\q2 mwohn rahn lapalap oh kamasepwehk wet en ketidohn KAUN-O.\x - \xo 2:31 \xt Mad. 24.29; Mark 13.24-25; Luk 21.25; Kaud. 6.12-13.\x*
\q1 
\v 32 Ahpw irail koaros me pahn peki sawas sang rehn KAUN-O pahn mourla.
\q1 Nin duwen me KAUN-O mahsanih,
\q2 ‘Ekei pahn pitla nan Serusalem;
\q2 irail kan me I piladahr pahn mourla.’”\x - \xo 2:32 \xt Rom 10.13.\x*
\c 3
\s1 Kadeikpen Wehi kan
\p 
\v 1 KAUN-O eri mahsanih,
\q1 “Eri, ni ahnsowo I pahn kapwuredohng
\q2 Suda oh Serusalem ara paiamwahu.
\q1 
\v 2 I pahn kapokonepene tohn wehi kan koaros,
\q2 oh kahreiraildohng nan Wahun Kopwung.
\q1 I pahn kapwung irail wasao
\q2 pwehki mehkoaros me re wiahiongehr nei aramas akan.
\q1 Irail kasarepeseng mehn Israel akan ong nan sapwen mehn liki kan,
\q2 oh nehkpeseng wehin Israel, nin limeio.
\q1 
\v 3 Irail koadoaropwehki
\q2 ma ihs me pahn naineki me lohdi kan.
\q1 Re pil netikihla kisin pwutak oh serepein kei pwe re en wiahla lidu,
\q2 pwe re en pwainda lihen netiki paliwararail kan oh wain.
\b
\p 
\v 4 “Mehn Dair oh Saidon, oh mehn Pilisdia kan koaros, dahme kumwail songosong en wiahiong ie? Kumwail men dupukohng ie mehkot? Ma iei, I pahn mwadangete dupukohng kumwail!\x - \xo 3:4 \xt Ais. 23.1-18; Esek. 26.1—28.26; Eimw 1.9-10; Sek. 9.1-4; Mad. 11.21-22; Luk 10.13-14.\x*\x - \xo 3:4 \xt Ais. 14.29-31; Ser. 47.1-7; Esek. 25.15-17; Eimw. 1.6-8; Sep. 2.4-7; Sek. 9.5-7.\x*
\v 5 Kumwail wahsangehr nei silper oh kohl, iangahki ei kepwe kesempwal kan, walahng nan amwail wasahn kaudok kan.
\v 6 Kumwail wahsangehr mehn Suda kan, oh mehn Serusalem kan, walahng wasa doh, oh netikinirailla rehn mehn Krihs kan.
\v 7 Eri, met I pahn kapwureiraildo sang ni wasa kan me kumwail netikinirailla ie. I pahn wiahiong kumwail dahme kumwail wiahiong irail.
\v 8 I pahn mweidohng mehn Suda kan en pwainda noumwail pwutak oh serepein kan. Re pahn uhd netikinkumwailla wasa doh rehn mehn Sapea kan. Ngehi, KAUN-O, me mahmahsen.”
\b
\q1 
\v 9 “Eri, kumwail kalohkihda pakair wet nanpwungen tohn wehi kan:
\q2 ‘Kumwail onopadahng mahwen;
\q2 kumwail kapokonepene sounpei kan koaros oh kariswei!
\q1 
\v 10 Kumwail sukada imwin noumwail mehn deipwel kan oh wiahkihda kedlahs,
\q2 oh kumwail wiahkihda ketieu noumwail naip en kamwakel kan.
\q1 Me luwet akan pahn pil uhdahn iang mahwen.\x - \xo 3:10 \xt Ais. 2.4; Maika 4.3.\x*
\q1 
\v 11 Kumwail mwadangodo,
\q2 kumwail wehi kan koaros me kapilpene Suda,
\q2 kumwail pokonpene nan wahwo.’”
\b
\q1 Maing KAUN, komw ketikihdo sapwellimomwi karis pwe re en mahweniong irail!
\b
\q1 
\v 12 “Tohn wehi kan pahn onopada
\q2 oh kodohng nan Wahun Kopwung.
\q1 Iei wasa me ngehi, KAUN-O, pahn kadeikada
\q2 wehi koaros me kapilpene Suda.
\q1 
\v 13 Re me inenen suwed mehlel;
\q1 kumwail lupukiraildi rasehng wahnsahpw ni ahnsoun rahk;
\q1 kumwail kamwutirailpene, duwehte kreip eh kin kamwutpene
\q2 ni wasahn kangid kreip me diradahr
\q2 lao wain pahn kusieisang loale.”\x - \xo 3:13 \xt Kaud. 14.14-16; b Kaud. 14.19-20; 19.15.\x*
\b
\q1 
\v 14 Aramas ngedehrie mihmi
\q2 nan Wahun Kopwung.
\q1 Iei wasao me rahnen KAUN-O
\q2 pahn mwadang pwarodohng.
\q1 
\v 15 Ketipin oh maram rotorotalahr,
\q2 oh usu kan solahr linge.
\s1 Koht pahn ketin Kupwuramwahwih Sapwellime Aramas akan
\q1 
\v 16 KAUN-O ahpw mahsendihdo sang nin Nahna Saion, ni kapitie laud;
\q2 kapitie peipeido sang Serusalem, rasehng nansapwe,
\q2 eri, sampah oh pahnlahng kin rerrerki.
\q1 Ahpw e pahn ketin uhki sapwellime aramas akan.\x - \xo 3:16 \xt Eimw. 1.2.\x*
\q1 
\v 17 “Eri, kumwail mehn Israel kan, kumwail ahpw pahn ese me ngehi, KAUN-O, amwail Koht.
\q2 I kin ketiket pohn ei dohl sarawi Saion.
\q1 Serusalem pahn wiahla kahnimw sarawi ehu;
\q2 mehn liki kan solahr pahn kak pwurehng kalowehdi.
\q1 
\v 18 Ni ahnsowo mwetin wain pahn koaduhpwaldi nahna kan;
\q2 kou tohto pahn dierek pohn dohl kan koaros;
\q2 pihl pahn rek ong mehn Suda koaros.
\q1 Piletik pwoat pahn pwilipwilweisang nan Tehnpas Sarawien KAUN-O,
\q2 piletiko ahpw pahn kin kalamwurih nan Wahun Akasia.
\b
\q1 
\v 19 “Isip pahn wiahla sapwtehn ehu,
\q2 oh Edom pahn ohla douluhl,
\q1 pwehki arail mahweniong wehin Suda
\q2 oh kemehla towe me soh dipe kan.
\q1 
\v 20-21 I pahn ikih irail kan me kamakamalahr;
\q2 I sohte pahn mahkohng me dipan akan.
\q1 Ahpw Serusalem oh Suda pahn tohnla kohkohlahte,
\q2 oh ngehi, KAUN-O, pahn ketiket pohn Nahna Saion.” 
