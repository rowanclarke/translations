\id JOL
\h Soeli
\toc1 Ko E Tohi  Ľae PalŇćfita Ko Soeli
\toc2 Soeli
\toc3 Soel
\mt2 KO E TOHI
\mt3  ĽAE PALŇĆFITA KO
\mt1 SOELI
\cl KO E VAHE
\c 1
\cd \it 1  ĽOku fakahńĀ  Ľe Soeli  Ľae ngaahi fakamaau kehekehe  Ľae  ĽOtua, pea  Ľoku ne enginaki ke tokanga ki ai; 8 Pea ke tangi. 14  ĽOku ne tu Ľutu Ľuni  Ľae  Ľaukai ke tangi ai.\it*
\p 
\v 1 Na Ľe hoko  Ľae folofola  Ľa Sihova kia Soeli ko e foha  Ľo Petueli.
\q1 
\v 2 Fanongo ki he me Ľa ni,  Ľakimoutolu ko e kau mńĀtu Ľa,
\q2 pea tokanga homou telinga,  Ľae kakai  Ľoe fonua.
\q2 Kuo  Ľai ha me Ľa pehńď ni  Ľi homou ngaahi  Ľaho,
\q2 pe  Ľi he ngaahi  Ľaho  Ľo ho Ľomou ngaahi tamai?
\q1 
\v 3 Tala ia ki ho Ľomou fńĀnau,
\q2 pea ke nau tala ki he Ľenau fńĀnau,
\q2 pea mo e fńĀnau  Ľanautolu ki he to Ľutangata  Ľe taha.
\q1 
\v 4 Ko ia na Ľe tuku  Ľe he he Ľe kuo kai  Ľe he he Ľe maumau;
\q2 pea ko ia na Ľe tuku  Ľe he he Ľe maumau kuo kai  Ľe he  Ľunufe fulufulu,
\q2 pea ko ia na Ľe tuku  Ľe he  Ľunufe fulufulu, kuo kai  Ľe he  Ľunufe.
\q1 
\v 5 ‚ÄĆ ĽAe kau konńĀ, mou  ĽńĀ, pea tangi;
\q2 pea fakatangiloloa,  Ľakimoutolu  Ľae kau inu uaine, koe Ľuhi ko e uaine fo Ľou;
\q2 he kuo motuhi ia mei homou ngutu.
\q1 
\v 6 He kuo  Ľalu hake ha pule Ľanga ki hoku fonua,  Ľoku mńĀlohi pea ta Ľefa Ľalaua,
\q2 ko hono nifo ko e nifo  Ľoe laione,
\q2 pea ko hono kou Ľahe ko e kou Ľahe  Ľoe laione lahi.
\q1 
\v 7 Kuo ne fakalala  Ľeku vaine,
\q2 pea fohi Ľi  Ľae kili  Ľo  Ľeku  Ľakau ko e fiki;
\q2 kuo ne fakamolemole ia  Ľo ma Ľa;
\q2 kuo fakahinehina hono ngaahi va Ľa.
\q1 
\v 8 Tangi,  Ľo hangńď ko e ta Ľahine polo Ľi kuo kofu Ľaki  Ľae tauanga Ľa, koe Ľuhi ko e husepńĀniti  Ľo  Ľene kei si Ľi.
\v 9 Ko e hifo  Ľaki  Ľae me Ľakai, pea mo e hifo  Ľaki  Ľae me Ľainu kuo motuhi ia mei he fale  Ľo Sihova;
\q2  Ľoku tangi  Ľae kau taula Ľeiki,  Ľae kau faifekau  Ľa Sihova.
\q1 
\v 10 ‚ÄĆ ĽOku maumau  Ľae ngoue,
\q2  Ľoku tangi  Ľae fonua; he kuo maumau Ľi  Ľae koane;
\q2  Ľoku maha  Ľae uaine fo Ľou,
\q2  Ľoku vaivai  Ľae lolo.
\q1 
\v 11 Mou mńĀ,  Ľae kau tangata ngoue;
\q2 fakatangilŇćloa,  Ľe kau tauhi vaine,
\q2 koe Ľuhi ko e uite mo e pa Ľale;
\q2 he kuo  Ľauha  Ľae ututa Ľu  Ľi he ngoue.
\q1 
\v 12 ‚ÄĆ ĽOku mŇćmoa  Ľae vaine,  Ľoku vaivai  Ľae  Ľakau ko e fiki;
\q2 ko e  Ľakau ko e pomikanite, mo e  Ľakau ko e ponga,
\q2 mo e  Ľakau ko e  Ľapele foki,  Ľio, ko e  Ľakau kotoa pńď  Ľoe ngoue  Ľoku mae;
\q2 koe Ľuhi  Ľoku mate  Ľae fiefia mei he loto  Ľoe ngaahi foha  Ľoe tangata.
\q1 
\v 13 No Ľotaki homou vala, pea tangi,  Ľae kau taula Ľeiki:
\q2 tangi fakalŇćloa,  Ľae kau faifekau  Ľoe feilaulau Ľanga;
\q1 ha Ľu,  Ľo tokoto  Ľi he pŇć kńĀtoa  Ľi he tauanga Ľa  Ľae kau tamaio Ľeiki  Ľa hoku  ĽOtua:
\q2 he ko e feilaulau me Ľakai pea mo e feilaulau inu, kuo ta Ľofi mei he fale  Ľo homou  ĽOtua.
\q1 
\v 14 Mou tu Ľutu Ľuni  Ľae  Ľaukai,
\q2 fanongonongo  Ľae fakataha mamafa,
\q2 tńĀnaki  Ľae kau mńĀtu Ľa,
\q2 pea mo e kakai kotoa pńď  Ľoe fonua ki he fale  Ľo Sihova ko homou  ĽOtua,
\q2 pea tangi kia Sihova,  Ľo pehńď,
\q1 
\v 15 ‚ÄĆ ĽOiauńď  Ľae  Ľaho!
\q2 He kuo ofi  Ľae  Ľaho  Ľo Sihova,
\q2 pea  Ľe hoko mai ia  Ľo hangńď ko e faka Ľauha mei he MńĀfimafi.
\q1 
\v 16 ‚ÄĆ ĽIkai kuo motuhi  Ľae me Ľakai mei hotau mata,
\q2  Ľio, ko e fiefia mo e nekeneka mei he fale  Ľo hotau  ĽOtua?
\q1 
\v 17 ‚ÄĆ ĽOku popo  Ľae tenga  Ľi he loto kelekele,
\q2  Ľoku lala  Ľae ngaahi feleoko,
\q2 kuo holoki  Ľae ngaahi fale koloa; he kuo mae  Ľae koane.
\q1 
\v 18 ‚ÄĆ ĽOiauńď  Ľae to Ľe  Ľae fanga manu!
\q2  ĽOku feinga  Ľae fanga pulu, koe Ľuhi  Ľoku  Ľikai hanau mohuku;
\q2  Ľio,  Ľoku tu ĽutńĀmaki  Ľae fanga sipi.
\q1 
\v 19 ‚ÄĆ ĽE Sihova, te u tangi kiate koe:
\q2 koe Ľuhi kuo kai  Ľe he afi  Ľae mohuku  Ľoe toafa,
\q2 pea kuo tutu  Ľe he ulo afi  Ľae ngaahi  Ľakau kotoa pńď ngoue.
\q1 
\v 20 ‚ÄĆ ĽOku tangi foki kiate koe  Ľae fanga manu  Ľoe vao:
\q2 koe Ľuhi  Ľoku mŇćmoa  Ľae ngaahi tafe Ľanga vai,
\q2 pea kuo kai  Ľe he afi  Ľae mohuku  Ľoe toafa.
\b
\c 2
\cd \it 1  ĽOku ne fakahńĀ ki Saione hono fakailifia  Ľoe fakamaau  Ľae  ĽOtua. 12  ĽOku ne enginaki ki he fakatomala, 15 Pea tu Ľutu Ľuni  Ľae  Ľaukai, 18 Mo ne fakahńĀ  Ľae tńĀpuaki ki ai. 21  ĽOku ne fakafiemńĀlie Ľi  Ľa Saione  Ľi he ngaahi tńĀpuaki ni, 28 Pea mo ia  Ľe hoko mai.\it*
\q1 
\v 1 Ifi  Ľae me Ľalea  Ľi Saione,
\q2 pea fanongonongo  Ľae ilifia  Ľi hoku mo Ľunga tapu:
\q1 ke tetetete  Ľae kakai kotoa pńď  Ľoe fonua,
\q2 koe Ľuhi  Ľoku hoko  Ľae  Ľaho  Ľo Sihova, he  Ľoku ofi ia;
\q1 
\v 2 Ko e  Ľaho  Ľoe fakapo Ľuli, pea mo e fakapo Ľupo Ľuli,
\q2 ko e  Ľaho  Ľao Ľaofia, pea mo e po Ľuli matolu:
\q1 hangńď ko e pongipongi kuo mafola  Ľi he funga mo Ľunga,
\q2  Ľoku \add hau \add*pehńď  Ľae kakai lahi mo mńĀlohi;
\q2 na Ľe  Ľikai pehńď  Ľi mu Ľa, pea  Ľe  Ľikai toe hangńď ko ia  Ľamui,
\q2  Ľo a Ľu ki he ngaahi ta Ľu  Ľoe ngaahi to Ľutangata lahi.
\q1 
\v 3 ‚ÄĆ ĽOku kai  Ľe he afi  Ľi honau  Ľao;
\q2 pea  Ľoku vela  Ľae ulo afi  Ľi honau tu Ľa:
\q1 ko e fonua  Ľoku hangńď ko e ngoue ko Iteni  Ľi honau  Ľao,
\q2 pea ki mui  Ľiate kinautolu  Ľoku hangńď ko e toafa kuo lala;
\q1  Ľio, pea  Ľe  Ľikai hao ha me Ľa meiate kinautolu.
\q1 
\v 4 ‚ÄĆ ĽOku nau hńĀ mai hangńď ko e hńĀ mai  Ľae fanga hoosi;
\q2 pea hangńď ko e kau tangata heka hoosi,  Ľe pehńď  Ľenau lele.
\q1 
\v 5 Hangńď ko e  Ľaulolongo  Ľoe ngaahi saliote  Ľi he funga mo Ľunga,
\q2  Ľe pehńď  Ľenau hopohopo,  Ľo hangńď ko e mumuhu  Ľoe ulo afi  Ľi he Ľene kai  Ľae mohuku mŇćmoa,
\q2  Ľo hangńď ko e kakai mńĀlohi kuo fakataha ki he tau.
\q1 
\v 6 ‚ÄĆ ĽE mamahi lahi  Ľae kakai  Ľi honau  Ľao:
\q2  Ľe peko  Ľae mata kotoa pńď.
\q1 
\v 7 Te nau lele hangńď ko e kau tangata mńĀlohi;
\q2 te nau kaka  Ľi he  ĽńĀ, hangńď ko e kau tangata tau;
\q2 pea te nau laka taki taha  Ľi hono hala, ka  Ľe  Ľikai ha taha te ne veuki  Ľae faka Ľotu:
\q1 
\v 8 Pea  Ľe  Ľikai te nau feteketeke Ľi  Ľae taha ki he taha;
\q2 ka te nau taki taha  Ľalu  Ľi hono hala:
\q2 pea ka nau ka tŇć ki he heletńĀ,
\q2  Ľe  Ľikai te nau lavea.
\q1 
\v 9 Te nau lele fano pe  Ľi he kolo;
\q2 te nau lele  Ľi he fukahi  ĽńĀ,
\q2 te nau kaka ki he tu Ľa fale;
\q2 te nau hŇę  Ľi he ngaahi matapńĀ sio Ľata, hangńď ko e kaiha Ľa.
\q1 
\v 10 ‚ÄĆ ĽE tetetete  Ľae fonua  Ľi honau  Ľao;
\q2 pea  Ľe ngalulululu  Ľae langi:
\q2  Ľe po Ľuli  Ľae la ĽńĀ mo e mńĀhina,
\q2 pea  Ľe ta Ľofi  Ľenau ulo  Ľe he ngaahi fetu Ľu:
\q1 
\v 11 Pea  Ľe fakaongo hono le Ľo  Ľe Sihova ki he Ľene kautau:
\q2 he  Ľoku lahi  Ľae fakataha  Ľo  Ľene kautau:
\q2 pea  Ľoku mńĀlohi ia  Ľoku fai ki he Ľene folofola:
\q2 koe Ľuhi ko e  Ľaho  Ľo Sihova  Ľoku lahi mo fakamanavahńď;
\q2 pea ko hai te ne fa Ľa tu Ľu ai?
\q1 
\v 12 ‚ÄĆ ĽOku pehńď  Ľe Sihova, ‚ÄúPea ko eni foki, mou tafoki kiate au  Ľaki homou loto kotoa,
\q2 pea  Ľi he  Ľaukai, pea  Ľi he tangi, mo e tangilńĀulau:‚ÄĚ
\q1 
\v 13 Pea mou haehae homou loto, kae  Ľikai ko homou kofu pe,
\q2 pea tafoki kia Sihova, ko homou  ĽOtua:
\q2 he  Ľoku ne angalelei mo  Ľalo Ľofa,
\q2  Ľo tuotuai ki he houhau, pea  Ľoku ne anga Ľofa lahi,
\q2 pea  Ľoku ne fakatomala  Ľi he kovi.
\q1 
\v 14 ‚ÄĆ ĽE  Ľilo  Ľe hai? Pe te ne tafoki mo fakatomala,
\q2 pea tuku mai ki mui ha tńĀpuaki  Ľiate ia;
\q2  Ľio, ha feilaulau me Ľakai, pea mo e feilaulau me Ľainu kia Sihova ko homou  ĽOtua?
\q1 
\v 15 Ifi  Ľae me Ľalea  Ľi Saione,
\q2 tu Ľutu Ľuni ha  Ľaukai,
\q2 ui  Ľae fakataha mamafa:
\q1 
\v 16 TńĀnaki  Ľae kakai,
\q2 fakatapui  Ľae fakataha,
\q2 fakakńĀtoa mai  Ľae kau mńĀtu Ľa,
\q2 tńĀnaki  Ľae fńĀnau, pea mo kinautolu  Ľoku kei huhu:
\q1 ke  Ľalu  Ľae tangata ta Ľane mei hono fale teuteu,
\q2 pea mo e ta Ľahine mei hono loki.
\q1 
\v 17 Tuku ke tangi  Ľae kau taula Ľeiki,  Ľae kau faifekau  Ľa Sihova,  Ľi he vaha Ľa  Ľoe fale hala mo e feilaulau Ľanga,
\q2 pea ke nau lea pehńď, ‚Äú ĽE Sihova, fakamo Ľui ho Ľo kakai,
\q2 pea  Ľoua na Ľa ke tuku ho tofi Ľa ki he manuki,
\q2 ke pule Ľi  Ľakinautolu  Ľe he hiteni:
\q1 koe Ľuma ĽńĀ  Ľenau pehńď  Ľi he lotolotonga  Ľo ho Ľo kakai,
\q2 ‚Äė ĽOku  Ľi fńď honau  ĽOtua?‚Äô‚ÄĚ
\q1 
\v 18 Pea  Ľe toki fua Ľa  Ľa Sihova ki hono fonua,
\q2 pea  Ľofa mamahi ki hono kakai.
\q1 
\v 19 ‚ÄĆ ĽIo, ko Sihova te ne tali, pea pehńď ki hono kakai,
\q2 ‚ÄúVakai, te u  Ľatu kiate kimoutolu  Ľae koane, mo e uaine, mo e lolo,
\q2 pea te mou mńĀkona ai:
\q2 pea  Ľe  Ľikai te u toe tuku  Ľakimoutolu ke manuki Ľi  Ľe he hiteni:
\q1 
\v 20 Ka te u  Ľave ke mama Ľo  Ľiate kimoutolu  Ľae tau mei he tokelau,
\q2 pea te u kapusi  Ľakinautolu ki ha fonua kńĀkńĀ mo lala,
\q2  Ľoku hanga hono mata ki he tahi hahake,
\q2 pea mo hono tu Ľa ki he tahi mama Ľo atu  Ľaupito,
\q2 pea  Ľe  Ľalu hake hono namukŇę,
\q2 pea  Ľe  Ľalu hake hono  Ľeho  Ľo ia,‚ÄĚ
\q1 Koe Ľuhi kuo ne fai  Ľae ngaahi me Ľa lahi.
\q1 
\v 21 ‚Äú ĽE fonua,  Ľoua na Ľa manavahńď;
\q2 fiefia pea nekeneka: koe Ľuhi  Ľe fai  Ľe Sihova  Ľae me Ľa lahi.
\q1 
\v 22 ‚ÄĆ ĽOua na Ľa manavahńď,  Ľe fanga manu  Ľoe vao!
\q2 He  Ľoku tupu  Ľae mohuku  Ľi he toafa,
\q2 pea  Ľoku fua  Ľae  Ľakau,
\q2 ko e  Ľakau ko e fiki mo e vaine,  Ľoku tuku mai hona mńĀlohi.
\b
\q1 
\v 23 ‚ÄúPea mou fiemńĀlie,  Ľe fńĀnau  Ľa Saione,
\q2 pea fiefia  Ľia Sihova, ko homou  ĽOtua:
\q2 koe Ľuhi kuo ne foaki kiate kimoutolu fakalelelelei  Ľae  Ľuha mu Ľa,
\q2 pea te ne tuku ke tŇć kiate kimoutolu  Ľae  Ľuha,
\q2 ko e  Ľuha mu Ľa, mo e  Ľuha mui,
\q2  Ľi he  Ľuluaki mńĀhina.
\q1 
\v 24 Pea  Ľe fonu  Ľi he uite  Ľae ngaahi haha Ľanga,
\q2 pea  Ľe pito mahuohua  Ľae ngaahi tata Ľo Ľanga  Ľi he uaine mo e lolo.
\q1 
\v 25 Pea te u toe  Ľomi kiate kimoutolu  Ľae ngaahi ta Ľu ne kai
\q2  Ľe he he Ľe mo e  Ľunufe maumau, mo e  Ľunufe, mo e  Ľunufe fulufulu,
\q2 ko  Ľeku kau tau lahi na Ľaku fekau kiate kimoutolu.
\q1 
\v 26 Pea te mou kai  Ľi he mahu, pea te mou mńĀkona ai,
\q2 pea fakamńĀlŇć ki he huafa  Ľo Sihova ko homou  ĽOtua,
\q2  Ľaia kuo ne fai fakaofo kiate kimoutolu:
\q2 pea  Ľe  Ľikai toe mńĀ  Ľa hoku kakai  Ľo lauikuonga.
\q1 
\v 27 Pea te mou  Ľilo  Ľoku ou  Ľi he ha Ľoha Ľonga  Ľo  ĽIsileli,
\q2 pea ko Sihova au ko homou  ĽOtua, kae  Ľikai ha taha kehe:
\q2 pea  Ľe  Ľikai toe mńĀ  Ľa hoku kakai  Ľo lauikuonga.
\b
\q1 
\v 28 ‚ÄúPea  Ľe hoko  Ľamui, te u hua Ľi hoku LaumńĀlie ki he kakai kotoa pńď;
\q2 pea  Ľe kikite homou ngaahi foha mo homou ngaahi  Ľofefine,
\q2 pea  Ľe misi  Ľe ho Ľo kau mńĀtu Ľa  Ľae ngaahi misi,
\q2 pea  Ľe mamata  Ľae ngaahi me Ľa hńĀ mai  Ľe ho Ľo kau talavou:
\q1 
\v 29 Pea ki he kau tamaio Ľeiki mo e kau kaunanga,
\q2 te u hua Ľi foki hoku LaumńĀlie  Ľi he ngaahi  Ľaho ko ia.
\q1 
\v 30 Pea te u fakahńĀ  Ľae ngaahi me Ľa fakaofo  Ľi he langi, pea  Ľi mńĀmani,
\q2 ko e toto, mo e afi, mo e  Ľahu  Ľoe afi.
\q1 
\v 31 Pea  Ľe liliu  Ľae la ĽńĀ  Ľo po Ľuli,
\q2 mo e mńĀhina ke toto  Ľi he te Ľeki hoko  Ľae  Ľaho lahi,
\q2 pea fakamanavahńď  Ľo Sihova.
\q1 
\v 32 Pea  Ľe pehńď, ko ia  Ľe ui ki he huafa  Ľo Sihova  Ľe fakamo Ľui ia:
\q2 koe Ľuhi  Ľe ai  Ľae fakamo Ľui  Ľi he mo Ľunga ko Saione, pea  Ľi SelŇęsalema,
\q2  Ľo hangńď ko e folofola  Ľa Sihova,
\q2 pea  Ľi he toenga  Ľe uiui Ľi  Ľe Sihova.‚ÄĚ
\b
\c 3
\cd \it 1 Ko e fakamaau  Ľae  ĽOtua ki he ngaahi fili  Ľo hono kakai. 9  ĽE  Ľilo Ľi  Ľae  ĽOtua  Ľi he Ľene fakamaau. 18 Ko  Ľene tńĀpuaki ki he siasi.\it*
\q1 
\v 1 ‚ÄúVakai, koe Ľuhi  Ľi he ngaahi  Ľaho ko ia,
\q2 pea  Ľi he kuonga ko ia,
\q2  Ľaia te u toe  Ľomi ai  Ľae pŇćpula  Ľo Siuta mo SelŇęsalema,
\q1 
\v 2 Te u tńĀnaki foki  Ľae ngaahi pule Ľanga kotoa pńď,
\q2 pea te u  Ľomi ki lalo  Ľakinautolu ki he tele Ľa  Ľo Sihosafate,
\q2 pea te u fakamaau Ľi  Ľakinautolu koe Ľuhi ko hoku kakai,
\q2 pea mo hoku tofi Ľa ko  ĽIsileli,  Ľaia kuo nau fakamovetevete ki he ngaahi pule Ľanga,
\q2 pea vahe Ľi hoku fonua.
\q1 
\v 3 Pea kuo nau talotalo ki hoku kakai:
\q2 pea kuo nau foaki ha tamasi Ľi ke ma Ľu  Ľaki ha fefine fe Ľauaki,
\q2 pea nau fakatau  Ľae ta Ľahine ma Ľa e uaine, koe Ľuhi ke nau inu.
\q1 
\v 4 ‚Äú ĽIo, pea ko e hńĀ  Ľamoutolu ke mo fai mo au,  Ľe Taia mo Saitone,
\q2 pea mo e matńĀtahi kotoa pńď  Ľo Palesitaine?
\q1 Te mou totongi kiate au?
\q2 Pea kapau te mou totongi mai,
\q2  Ľe mńĀtu Ľaki vave mo to Ľoto Ľo  Ľeku toe  Ľatu ho Ľomou totongi ki homou tumu Ľaki;
\q1 
\v 5 Koe Ľuhi kuo mou  Ľave  Ľeku siliva mo  Ľeku koula,
\q2 pea kuo mou  Ľave ki homou ngaahi fale faka Ľeiki  Ľa  Ľeku ngaahi me Ľa matamatalelei mo  Ľaonga:
\q1 
\v 6 Ko e fńĀnau foki  Ľa Siuta, pea mo e fńĀnau  Ľa SelŇęsalema kuo mou fakatau ki he kakai Kalisi,
\q2 koe Ľuhi ke mou fakahńď mama Ľo  Ľakinautolu mei honau mata fonua.
\q1 
\v 7 Vakai, te u hiki  Ľakinautolu mei he potu ne mou fakatau  Ľakinautolu ki ai,
\q2 pea te u toe  Ľatu ho Ľomou totongi ki homou tumu Ľaki:
\q1 
\v 8 Pea te u fakatau homou ngaahi foha mo homou ngaahi  Ľofefine ki he nima  Ľoe fńĀnau  Ľa Siuta,
\q2 pea te nau fakatau  Ľakinautolu ki he kakai Sapea,
\q2 ki ha kakai mama Ľo atu:
\q2 he kuo pehńď  Ľe Sihova.‚ÄĚ
\b
\q1 
\v 9 ‚ÄúFanongonongo eni ki he ngaahi Senitaile,
\q2 ‚ÄúTeuteu  Ľae tau,
\q2 faka ĽńĀ  Ľae kau tangata mńĀlohi,
\q1 tuku ke unu mai  Ľae kau tangata tau kotoa pńď;
\q2 ke nau  Ľalu hake:
\v 10 Tuki  Ľaki ho Ľomou huo toho  Ľae ngaahi heletńĀ,
\q2 pea mo ho Ľomou ngaahi hele  Ľauhani  Ľae ngaahi tao:
\q2 ke pehńď  Ľe he vaivai, ‚Äė Ľoku ou mńĀlohi;‚Äô
\q1 
\v 11 Fakataha  Ľakimoutolu, pea ha Ľu  Ľakimoutolu ko e kau hiteni,
\q2 pea tńĀnaki takatakai  Ľakimoutolu:‚ÄĚ
\q1  ĽE Sihova, ke hifo  Ľi hena ho Ľo kau mńĀlohi:
\q1 
\v 12 ‚ÄúKe  ĽńĀ  Ľae hiteni, pea  Ľalu hake ki he tele Ľa  Ľo Sihosafate:
\q2 he te u nofo  Ľi ai ke fakamaau Ľi  Ľae hiteni  Ľoku nofo takatakai.
\q1 
\v 13 ‚ÄĆ ĽAi  Ľae hele tu Ľusi,
\q2 he kuo motu Ľa  Ľae ta Ľu:
\q2 ha Ľu, pea  Ľalu hifo;
\q2 he kuo pito  Ľae tata Ľo Ľanga,
\q2  Ľoku mahuohua  Ľae ngaahi puha fakatali; koe Ľuhi  Ľoku lahi  Ľenau angahala.‚ÄĚ
\q1 
\v 14 Ko e fu Ľu tokolahi, ko e fu Ľu tokolahi  Ľi he tele Ľa  Ľoe fakamaau:
\q2 he  Ľoku ofi  Ľae  Ľaho  Ľo Sihova  Ľi he tele Ľa  Ľoe fakamaau.
\q1 
\v 15 ‚ÄĆ ĽE fakapo Ľuli  Ľae la ĽńĀ mo e mńĀhina,
\q2 pea  Ľe  Ľikai ulo  Ľae ngaahi fetu Ľu.
\q1 
\v 16 ‚ÄĆ ĽE  Ľu Ľulu  Ľa Sihova mei Saione,
\q2 pea  Ľe fakaongo hono le Ľo mei SelŇęsalema;
\q2 pea  Ľe lulululu  Ľae langi mo mńĀmani:
\q2 ka ko Sihova ko e  Ľamanaki lelei Ľanga ia  Ľo hono kakai,
\q2 pea ko e mńĀlohi Ľanga  Ľoe fńĀnau  Ľa  ĽIsileli.
\q1 
\v 17 ‚ÄúPea te mou  Ľilo ai ko au ko Sihova,
\q2 ko homou  ĽOtua  Ľoku  Ľafio  Ľi Saione, ko hoku mo Ľunga tapu:
\q1 pea  Ľe toki mńĀ Ľoni Ľoni  Ľa SelŇęsalema,
\q2 pea  Ľe  Ľikai toe  Ľalu  Ľiate ia ha muli.
\q1 
\v 18 ‚ÄúPea  Ľe pehńď  Ľi he  Ľaho ko ia,
\q2 ko e ngaahi mo Ľunga te nau to Ľi Ľi  Ľae uaine fo Ľou,
\q2 pea  Ľe tafe  Ľae huhu Ľa  Ľi he ngaahi tafungofunga,
\q2 pea ko e ngaahi vaitafe kotoa pńď  Ľo Siuta  Ľe tafe ai  Ľae vai,
\q2 pea ko e matavai  Ľe pa mai mei he fale  Ľo Sihova,
\q2 pea fakavai  Ľae tele Ľa  Ľo Sitimi.
\q1 
\v 19 ‚ÄĆ ĽE lala  Ľa  ĽIsipite,
\q2 pea  Ľe hoko  Ľa  ĽItomi ko e toafa kuo lala,
\q2 koe Ľuhi ko e fakamńĀlohi ki he fńĀnau  Ľa Siuta,
\q2 he kuo nau lilingi  Ľae toto ta Ľehalaia  Ľi honau fonua.
\q1 
\v 20 Ka  Ľe nofo  Ľa Siuta  Ľo ta Ľengata,
\q2 pea mo SelŇęsalema mei he to Ľutangata ki he to Ľutangata.
\q1 
\v 21 Koe Ľuhi te u fakama Ľa  Ľae toto
\q2  Ľi ai  Ľoku te Ľeki ai te u fakama Ľa:
\q2 he  Ľoku  Ľafio  Ľa Sihova  Ľi Saione.‚ÄĚ 
