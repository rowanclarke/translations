\p
\v 1 \w And|strong="H3117"\w* Hiram king \w of|strong="H3117"\w* Tyre sends \w his|strong="H3605"\w* \w servants|strong="H5647"\w* \w to|strong="H5704"\w* \w Solomon|strong="H8010"\w*, \w for|strong="H5704"\w* \w he|strong="H3117"\w* heard \w that|strong="H3605"\w* \w they|strong="H3117"\w* \w had|strong="H1961"\w* anointed \w him|strong="H5647"\w* \w for|strong="H5704"\w* king instead \w of|strong="H3117"\w* \w his|strong="H3605"\w* father, \w for|strong="H5704"\w* Hiram \w was|strong="H1961"\w* loving \w toward|strong="H4480"\w* \w David|strong="H3117"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w days|strong="H3117"\w*;  
