\id 1SA
\h 1 صَامْوِيلْ 
\toc1 1 صَامْوِيلْ 
\toc2 1 صَامْوِيلْ 
\toc3 1 صم. 
\mt1 1 صَامْوِيلْ  
\c 1
\s1 ثَاژَادْجِيثْ ن حَانَّا  
\m
\v 1 ثُوغَا ذِينْ إِجّْ ن ورْيَازْ زِي رَامَاثَايِيمْ-صُوفِيمْ، زڭْ إِذُورَارْ ن إِفْرَايِيمْ، قَّارنْ أَسْ إِلْقَانَا، مِّيسْ ن يَارُوحَامْ، مِّيسْ ن أَلِيهُو، مِّيسْ ن ثُوحُو، مِّيسْ ن صُوفْ، إِجّْ ن \add ورْيَازْ\add* زِي إِفْرَايِيمْ. \f ◼ \fr 1:‏1 \ft \+bd ’أَفْرَاثَا‘\+bd* - إِسمْ نّغْنِي إِ ثنْذِينْثْ ن بَايْثْ-لَاحْمْ.\f*  \x ◘ \xo 1:‏1 \xt 1 إِم. 6‏:‏11، 12\x*  
\v 2 نتَّا ثُوغَا غَارسْ ثْنَاينْ ن ثمْغَارِينْ. إِشْثنْ قَّارنْ أَسْ حَانَّا ؤُ ثنّغْنِيثْ قَّارنْ أَسْ فَانِينَّا. فَانِينَّا ثُوغَا غَارسْ إِحنْجِيرنْ، \add مَاشَا\add* حَانَّا وَارْ غَارسْ ثُوغِي بُو إِحنْجِيرنْ.  
\v 3 أَرْيَازْ-أَ ثُوغَا إِتّْڭعَّاذْ أَسڭّْوَاسْ خْ ؤُسڭّْوَاسْ زِي ثنْذِينْثْ نّسْ حِيمَا أَذْ إِسْجذْ ؤُ أَذْ إِقدّمْ ثِيغَارْصَا إِ سِيذِي ن ڒْعسْكَارَاثْ \add غَارْ ثَادَّارْثْ ن سِيذِي\add* ذِي شِيلُو. ذِينِّي ثُوغَا ثْنَاينْ ن إِحنْجِيرنْ ن عَالِي، حُوفْنِي ذ فِينَاحَاسْ. نِيثْنِي ذ إِكهَّاننْ ن سِيذِي. \x ◘ \xo 1:‏3 \xt ؤُف. 23‏:‏14؛ أَعَوذ. 16‏:‏16. \x*   
\m
\v 4 ذڭْ وَاسّْ ڒَامِي د-يِيوِي إِلْقَانَا ثَاغَارْصْثْ، إِمْسَارْ أَقَا إِوْشَا ثِيسقَّارْ \add ن ثْغَارْصْثْ\add* إِ ثمْغَارْثْ نّسْ فَانِينَّا ؤُ إِ مَارَّا إِحنْجِيرنْ نّسْ ذ ثْحنْجِيرِينْ نّسْ، \f ◼ \fr 1:‏4 \ft \+bd ’\+bdit إِشْثْ ن\+bdit* ثسْغَارْثْ‘\+bd* - س ثْعِيبْرَانِيثْ ’ثِيسقَّارْ‘.\f*  
\v 5 \add مَاشَا\add* إِ حَانَّا إِوْشَا أَسْ ثْنَاينْ ن ثْسقَّارْ، مَاغَارْ نتَّا ثُوغَا إِتّخْسْ حَانَّا، وَاخَّا سِيذِي ثُوغَا إِبلّعْ أَسْ ڒمْڒَاوثْ.  
\v 6 ثَاغْرِيمْثْ نّسْ ثُوغَا ثْسعَّارْ إِ-ت أَطَّاسْ مَاحنْذْ أَذْ ت ثسّْفُوڭمْ، مِينْزِي سِيذِي ثُوغَا إِبلّعْ أَسْ ڒمْڒَاوثْ.   
\m
\v 7 أَمُّو إِ إِڭَّا \add إِلْقَانَا\add* أَسڭّْوَاسْ خْ ؤُسڭّْوَاسْ. ؤُشَا مڒْمِي مَا ثتّْڭعّذْ \add حَانَّا أَكِيذسْ\add* غَارْ ثَادَّارْثْ ن سِيذِي، ثْسعَّارْ إِ-ت \add فَانِينَّا\add* ؤُ نتَّاثْ ثْرُو، وَارْ ثشِّي وَالُو.  
\v 8 \add خنِّي\add* إِنَّا أَرْيَازْ نّسْ إِلْقَانَا: ”حَانَّا، مَايمِّي ثتّْرُوذْ، مَايمِّي وَارْ ثتّتّذْ شَا ؤُ مَايمِّي ؤُڒْ نّمْ إِشْضنْ؟ مَا نشّْ وَارْ ذ أَمْ شْنِيغْ خْعشْرَا ن إِحنْجِيرنْ؟“ \x ◘ \xo 1:‏8 \xt رَاع. 4‏:‏15. \x*   
\m
\v 9 \add ذڭْ إِجّْ ن وَاسّْ\add*، أَوَارْنِي ؤُمِي ثشَّا ؤُ ثسْوَا ذِي شِيلُو، ثكَّارْ حَانَّا. ثُوغَا أَكهَّانْ عَالِي إِقِّيمْ خْ ڒْكُورْسِي غَارْ ثفْڒَاوْثْ \add ن ؤُغزْضِيسْ ن ثوَّارْثْ\add* ن زَّاوشْثْ ن سِيذِي.  
\v 10 \add ثُوغَا\add* ڒعْمَارْ \add ن حَانَّا\add* يَارْزڭْ، ثژُّودْجْ غَارْ سِيذِي، ثْرُو أَطَّاسْ.  
\v 11 نتَّاثْ ثڭَّا إِجّْ ن لْوَاعْذْ، ثنَّا: ”\add أَ\add*، سِيذِي ن ڒْعسْكَارَاثْ، مَاڒَا شكْ ثخْزَارذْ س ثِيذتّْ غَارْ ڒمْحَاينْ ن ثَايَّا نّشْ ؤُ ثْخَارّْصذْ ذَايِي ؤُ وَارْ ثتّتُّوذْ ثَايَّا نّشْ، أَذْ ثوْشذْ إِ ثَايَّا نّشْ إِجّْ ن ؤُحنْجِيرْ ذ أَوْثمْ، \add خنِّي\add* أَذْ ث وْشغْ إِ سِيذِي مِينْ غَا يكّْ إِدَّارْ ؤُشَا ؤُڒَا ذ إِجّْ ن ڒْمُوسْ وَارْ إِتّْحفِّي إِ ؤُزدْجِيفْ نّسْ.“ \f ◼ \fr 1:‏11 \ft \+bd ’أَحنْجِيرْ‘\+bd* - س ثْعِيبْرَانِيثْ ’زَّارِيعثْ‘. \+bd ’مِينْ غَا يكّْ إِدَّارْ‘\+bd* - س ثْعِيبْرَانِيثْ ’مَارَّا ؤُسَّانْ ن ثُوذَارْثْ نّسْ.‘\f*  \x ◘ \xo 1:‏11 \xt ڒقض. 13‏:‏5. \x*  
\v 12 ؤُمِي ثكَّا أَطَّاسْ ثتّْژَادْجْ زَّاثْ إِ وُوذمْ ن سِيذِي، إِمْسَارْ، أَقَا عَالِي إِحْضَا أَقمُّومْ نّسْ.  
\v 13 ثُوغَا حَانَّا ثسِّيوڒْ ذڭْ وُوڒْ نّسْ، إِينْشِيشنْ نّسْ تّنْهزَّانْ وَاهَا، \add مَاشَا\add* ثْمِيجَّا نّسْ ثُوغَا وَارْ ثتّْوَاسڒْ. عَالِي إِتّْغِيڒْ أَسْ ثسْشَارْ.  
\v 14 إِنَّا أَسْ عَالِي: ”مشْحَاڒْ \add عَاذْ\add* إِ غَا ثقِّيمذْ ثسْشَارذْ؟ كّسْ خَامْ سّكْرَا نّمْ!“  
\v 15 حَانَّا ثَارَّا-د خَاسْ، ثنَّا: ”لَّ، سِيذِي إِنُو، نشّْ ذ إِشْثْ ن ثمْغَارْثْ س بُوحْبڒْ إِشْضنْ. نشّْ وَارْ سْوِيغْ بِينُو ؤُڒَا ذ شّْرَابْ، مَاشَا فَارّْغغْ ؤُڒْ إِنُو زَّاثْ إِ وُوذمْ ن سِيذِي. \x ◘ \xo 1:‏15 \xt إِزهد. 62‏:‏9. \x*  
\v 16 وَارْ حسّبْ شَا ثَايَّا نّشْ ذ إِشْثْ ن ثْيدْجِيثْ إِ وَارْ ثْسكّْوِي، مَاغَارْ أَڒْ إِ ڒخُّو سِّيوْڒغْ \add وَاهَا\add* زِي ڒْهمّْ إِنُو أَمقّْرَانْ ؤُ زِي ثِيقّسْثْ \add ن وُوڒْ\add* إِنُو.“  
\v 17 عَالِي يَارَّا-د خَاسْ، إِنَّا: ”ؤُيُورْ ذِي ڒهْنَا ؤُشَا أَربِّي ن إِسْرَائِيل أَذْ أَمْ إِوْشْ مِينْ زَّايسْ ثتَّارذْ.“  
\v 18 نتَّاثْ ثنَّا: ”إِڒِي أَذْ ثَافْ ثَايَّا نّشْ ذ أَحِينِّي زَّاثْ إِ ثِيطَّاوِينْ نّشْ!“ \add خنِّي\add* ثُويُورْ ثمْغَارْثْ أَبْرِيذْ نّسْ، ثشَّا ؤُ ثُوغَا أَغمْبُوبْ نّسْ وَارْ إِشْضِينْ عَاذْ.  
\v 19 غَارْ ثُوفُّوثْ ن صّْبحْ كَّارنْ زِيشْ، بنْذْقنْ زَّاثْ إِ وُوذمْ ن سِيذِي ؤُشَاعقْبنْ غَارْ ثَادَّارْثْ نْسنْ ذِي رَامَا. ثُوغَا إِلْقَانَا إِطّصْ أَكْ-ذ حَانَّا، ثَامْغَارْثْ نّسْ، ؤُشَا سِيذِي إِخَارّصْ ذَايسْ، ذِي حَانَّا.   
\b  
\m  
\s1 أَخْڒَاقْ ن صَامْوِيلْ  
\m
\v 20 ؤُمِي عْذُونْ وُوسَّانْ أَوَارْنِي ڒَامِي ثكْسِي حَانَّا س دّيْسثْ، ثُورُووْ-د إِجّْ ن ؤُحنْجِيرْ. ثڭَّا أَسْ شَامْوِيلْ، \add ؤُمِي نتَّاثْ ثنَّا\add*: ”مَاغَارْ نشّْ تَّارغْ ث زِي سِيذِي.“  
\v 21 ؤُشَا أَرْيَازْ نِّي، إِلْقَانَا، إِڭعّذْ \add عَاوذْ\add* أَكْ-ذ مَارَّا \add إِنِّي ن\add* ثَادَّارْثْ نّسْ، حِيمَا أَذْ يَاوِي ثَاغَارْصْثْ ن كُوڒْ أَسڭّْوَاسْ ذ ثْغَارْصْثْ نّسْ ن لْوَاعْذْ إِ سِيذِي.  
\v 22 \add مَاشَا\add* حَانَّا وَارْ كِيذْسنْ ثْڭِيعِّيذْ شَا، مَاشَا ثنَّا إِ ورْيَازْ نّسْ: ”خْمِي ذ أَسْ غَا كّْسغْ ؤُطُّوضْ إِ ؤُسيْمِي، \add خنِّي\add* أَذْ ث-إِ-د-أَوْيغْ \add ذِينْ\add*، ؤُشَا أَذْ إِضْهَارْ \add ؤُحنْجِيرْ\add* زَّاثْ إِ وُوذمْ ن سِيذِي ؤُ نتَّا أَذْ إِقِّيمْ ذِينِّي إِ ڒبْذَا.“  
\v 23 أَرْيَازْ نّسْ، إِلْقَانَا، إِنَّا أَسْ: ”أڭّْ مِينْ ثتّْوَاڒِيذْ مْلِيحْ ذِي ثِيطَّاوِينْ نّمْ. قِّيمْ ذَا \add ذِي ثَادَّارْثْ\add* أَڒْ ذ أَسْ إِ غَا ثكّْسذْ ؤُطُّوضْ. أَذْ إِقْفڒْ سِيذِي أَوَاڒْ نّسْ!“ أَمُّو إِ ثقِّيمْ ثمْغَارْثْ ذِي ثَادَّارْثْ ؤُشَا ثسُّوطُّوضْ أَحنْجِيرْ نّسْ أَڒَامِي إِ ذ أَسْ ثكّسْ ؤُطُّوضْ.  
\v 24 أَوَارْنِي ڒَامِي إِ ذ أَسْ ثكّسْ ؤُطُّوضْ، ثِيوْيِي ث أَكِيذسْ أَكْ-ذ ثْڒَاثَا ن إِفُونَاسنْ إِمژْيَاننْ ذ إِجّْ ن إِفَا ن وَارنْ ذ إِشْثْ ن ثْخَانْشثْ ن بِينُو. نتَّاثْ ثِيوْيِي ث غَارْ ثَادَّارْثْ ن سِيذِي ذِي شِيلُو. ثُوغَا-ث أَحنْجِيرْ \add عَاذْ\add* ذ أَمژْيَانْ. \x ◘ \xo 1:‏24 \xt لك. 2‏:‏41. \x*  
\v 25 نِيثْنِي غَارْصنْ إِ ؤُفُونَاسْ أَمژْيَانْ ؤُشَا إِوْينْ أَحنْجِيرْ غَارْ عَالِي.  
\v 26 نتَّاثْ ثنَّا: ”أَ، سِيذِي إِنُو، س ثِيذتّْ أَمْ إِدَّارْ ڒعْمَارْ نّشْ، \add أَ\add* سِيذِي إِنُو، نشّْ ذ ثَامْغَارْثْ نِّي ثُوغَا إِ ذَا إِبدّنْ غَارْ ؤُغزْذِيسْ نّشْ، حِيمَا أَذْ ژَّادْجغْ غَارْ سِيذِي.  
\v 27 نشّْ تَّارغْ أَحنْجِيرْ-أَ ؤُ سِيذِي إِسْڒَا إِ ثُوثْرَا إِنُو نِّي زَّايسْ تَّارغْ.  
\v 28 س ؤُينِّي أَقَا سلّْمغْ ث إِ سِيذِي مَارَّا ؤُسَّانْ مِينْ غَا يكّْ إِدَّارْ. أَقَا إِمّوْشْ إِ سِيذِي.“ ؤُشَا نتَّا إِبنْذقْ \add ذِينْ\add* زَّاثْ إِ وُوذمْ ن سِيذِي.   
\b  
\b  
\m  
\c 2
\s1 إِزْڒِي ن هَانَّا  
\m
\v 1 \add خنِّي\add* ثژُّودْجْ حَانَّا، ثنَّا:  
\m \qt ”ؤُڒْ إِنُو إِتّسْڒِيوْڒِيوْ\qt*  
\m \qt س ڒفْرَاحثْ ذِي سِيذِي.\qt*  
\m \qt إِشّْ إِنُو إِتّْوَاسّْڭعّذْ ذِي سِيذِي.\qt*  
\m \qt أَقمُّومْ إِنُو يَارْزمْ ذ أَرْزَامْ\qt*  
\m \qt خْ ڒْعذْيَانْ إِنُو،\qt*  
\m \qt مَاغَارْ فَارْحغْ خْ ؤُسنْجمْ نّشْ.\qt*\x ◘ \xo 2:‏1 \xt لك. 1‏:‏46. \x*   
\m
\v 2 \qt ؤُڒَا ذ إِجّْ ذ أَمْقدّسْ أَمْ سِيذِي،\qt*  
\m \qt مَاغَارْ وَارْ ذِينْ إِدْجِي حذْ مْغِيرْ شكْ،\qt*  
\m \qt ؤُ وَارْ ذِينْ ثدْجِي ثصْضَارْثْ\qt*  
\m \qt أَمْ أَربِّي نّغْ!\qt* \x ◘ \xo 2:‏2 \xt أَعَوذ. 3‏:‏24؛ إِزهد. 86‏:‏8. \x*   
\m
\v 3 \qt وَارْ ثَارنِّيمْ ثسَّاوَاڒمْ\qt*  
\m \qt أَمُّو س نّْفَاخثْ، \qt*  
\m \qt وَارْ د-تّفِّيغْ ؤُڒَا ذ شَا ن ثُوفّثْ\qt*  
\m \qt زڭْ ؤُقمُّومْ نْومْ،\qt*  
\m \qt مَاغَارْ سِيذِي ذ إِجّْ ن أَربِّي\qt*  
\m \qt إِسّنْ \+tl مَارَّا\+tl*،\qt*  
\m \qt ثِيمڭَّا \+tl نّسْ\+tl* تّْوَاوزْننْثْ.\qt*   
\m
\v 4 \qt ڒْْقوْسْ ن أَيْثْ ن بُو-ثغْرُوضْثْ إِتّْوَارْژَا،\qt*  
\m \qt \+tl مَاشَا\+tl* إِنِّي إِنْقَارْضنْ\qt*  
\m \qt حزّْمنْ س جّْهذْ.\qt*   
\m
\v 5 \qt إِنِّي إِجِّيوْننْ أَرهْننْ إِخفْ نْسنْ إِ وغْرُومْ،\qt*  
\m \qt \+tl مَاشَا\+tl* إِنِّي إِدْجُوژنْ،\qt*  
\m \qt وَارْ قِّيمنْ عَاذْ \+tl دْجُوزنْ\+tl*.\qt*  
\m \qt ثنِّي وَارْ إِتِّيرْونْ\qt*  
\m \qt ثُورُووْ-د سبْعَا ن إِحنْجِيرنْ،\qt*  
\m \qt ثنِّي غَارْ إِدْجَا ؤُبَارُّو ن إِحنْجِيرنْ، ثِيسْڒَاوْ.\qt* \x ◘ \xo 2:‏5 \xt إِزهد. 34‏:‏11؛ إِڭجذ. 5‏:‏6؛ لك. 1‏:‏53. \x*   
\m
\v 6 \qt أَربِّي إِنقّْ ؤُ إِتِّيشْ ثُوذَارْثْ، \qt*  
\m \qt نتَّا إِسّْهكّْوَّا غَارْ ڒَاخَارْثْ\qt*  
\m \qt ؤُ إِسّْڭعَّاذْ-د \+tl سّنِّي\+tl*.\qt*\x ◘ \xo 2:‏6 \xt أَعَوذ. 32‏:‏39؛ حِز. 37‏:‏11‏-‏14\x*   
\m
\v 7 \qt سِيذِي إِتَّارَّا \+tl إِجّْ\+tl* ذ أَمزْڒُوضْ\qt*  
\m \qt ؤُ \+tl إِجّْ نّغْنِي\+tl* يَارَّا إِ-ث ذ بُو-وَاڭْڒَا،\qt*  
\m \qt إِسّْهكّْوَا ذ إِسّْڭعَّاذْ.\qt*   
\m
\v 8 \qt أَمُوقْڒِيڒْ إِسّكَّارْ إِ-ث زِي ثْعجَّاجْثْ،\qt*  
\m \qt ڒْمسْكِينْ إِجبْذْ إِ-ث-إِ-د زڭْ وفْرَاضْ،\qt*  
\m \qt مَاحنْذْ أَذْ \+tl ثنْ\+tl* إِسّْغِيمْ\qt*  
\m \qt غَارْ ثَارْوَا ن ثَاصِيڒثْ، \qt*  
\m \qt \+tl مَاحنْذْ\+tl* أَذْ إِوْشْ\qt*  
\m \qt إِجّْ ن ڒْكُورْسِي ن ڒْعزّْ ذ ڒْوَارْثْ،\qt*  
\m \qt مِينْزِي ذْسُوسَا ن ثمُّورْثْ \+tl إِدْجَانْ\+tl* ن سِيذِي\qt*  
\m \qt ؤُ نتَّا إِسّْبدّْ خَاسنْ دُّونشْثْ.\qt*\x ◘ \xo 2:‏8 \xt أَيُوبْ 36‏:‏15؛ إِزهد. 113‏:‏7، 8؛ لك. 1‏:‏52؛ إِزهد. 24‏:‏2؛ 102‏:‏26؛ 104‏:‏5. \x*   
\m
\v 9 \qt نتَّا إِ إِسّْڒقَّانْ\qt*  
\m \qt خْ إِصُورَافْ ن إِمْثِيقَّانْ نّسْ،\qt*  
\m \qt \+tl مَاشَا\+tl* إِعفَّاننْ\qt*  
\m \qt أَذْ تّْوَاسّْبكْمنْ ذِي ثَادْجسْثْ،\qt*  
\m \qt مِينْزِي أَرْيَازْ وَارْ إِتِّيڒِي شَا ذ بُو ثغْرُوضْثْ\qt*  
\m \qt زِي جّهْذْ \+tl ن يِيخفْ\+tl* نّسْ.\qt*   
\m
\v 10 \qt ونِّي إِتّمْشُوبُّوشنْ أَكْ-ذ سِيذِي،\qt*  
\m \qt أَذْ إِتّْوَارْژْ.\qt*  
\m \qt أَذْ خَاسنْ إِسّْهمْهمْ ذڭْ ؤُجنَّا.\qt*  
\m \qt سِيذِي أَذْ إِحْكمْ ثِينڭُّورَا ن دُّونشْثْ،\qt*  
\m \qt أَذْ إِوْشْ ثِيزمَّارْ إِ ؤُجدْجِيذْ\qt*  
\m \qt ؤُشَا أَذْ إِسّْڭعّذْ إِشّْ ن لْمَاسِيحْ نّسْ.“\qt*\x ◘ \xo 2:‏10 \xt 1 صم. 7‏:‏10؛ إِزهد. 2‏:‏6؛ 89‏:‏25. \x*   
\b  
\m  
\s1 إِحنْجِيرنْ ن عَالِي  
\m
\v 11 إِعْقبْ إِلْقَانَا \add عَاوذْ\add* غَارْ ثَادَّارْثْ نّسْ غَارْ رَامَا، \add مَاشَا\add* أَحنْجِيرْ إِسخَّارْ إِ سِيذِي زَّاثْ إِ وُوذمْ ن ؤُكهَّانْ عَالِي.  
\v 12 \add مَاشَا\add* ثَارْوَا ن عَالِي ثُوغَا ذ ثَارْوَا إِ وَارْ إِسكّْوِينْ. نِيثْنِي وَارْ سِّيننْ شَا سِيذِي.  
\v 13 إِكهَّاننْ نُّومنْ أَذْ ڭّنْ أَكْ-ذ ڒْڭنْسْ \add أَمُّو\add*: مَاڒَا يِيوِي إِجّْ ن ورْيَازْ إِشْثْ ن ثْغَارْصْثْ، \add خنِّي\add*، ؤُمِي ثُوغَا أَيْسُومْ \add عَاذْ\add* إِتّْننَّا، يُوسَا-د إِجّْ ن ؤُمْسخَّارْ ن إِكهَّاننْ أَكْ-ذ إِشْثْ ن فُورْشِيثَا ن ثْڒَاثَا ن إِشُوكْضَانْ ذڭْ ؤُفُوسْ نّسْ،  
\v 14 إِجُّو ت ذِي ڒْبُورْمثْ نِيغْ ذڭْ ؤُطنْجِيرْ نِيغْ ذِي مَارْمِيثَا نِيغْ ذِي ثيْذُورْثْ ؤُ مَارَّا مِينْ غَا ثكْسِي فُورْشِيثَا، إِكْسِي ث ؤُكهَّانْ إِ يِيخفْ نّسْ. أَمُّو إِ ث ڭِّينْ غَارْ مَارَّا \add أَيْثْ ن\add* إِسْرَائِيل إِنِّي د-يُوسِينْ غَارْ شِيلُو.  
\v 15 أَمُّو عَاوذْ، قْبڒْ غَا بخَّارنْ ثَاذُونْثْ، يُوسَا-د إِجّْ ن ؤُمْسخَّارْ ن إِكهَّاننْ، إِنَّا إِ ورْيَازْ نِّي د-إِوْينْ ثَاغَارْصْثْ: ”أوْشْ أَيِي أَيْسُومْ حِيمَا أَذْ ث قْڒِيغْ إِ ؤُكهَّانْ، مِينْزِي نتَّا وَارْ خَاكْ إِكْسِي شَا أَيْسُومْ إِتّْوَاننَّانْ، مَاشَا مْغِيرْ أَزِيزَا.“ \f ◼ \fr 2:‏15 \ft \+bd ’أَزِيزَا‘\+bd* - نِيغْ ’وَارْ إِتّْوَاننِّينْ‘.\f*  
\v 16 مَاڒَا يَارَّا-د خَاسْ ورْيَازْ: ”أَمزْوَارْ إِتّْخصَّا أَذْ بخَّارنْ ثَاذُونْثْ مَارَّا، خنِّي كْسِي مِينْ إِخْسْ وُوڒْ نّشْ إِ يِيخفْ نّشْ!“، إِنَّا أَسْ \add ؤُمْسخَّارْ ن ؤُكهَّانْ\add*: ”لَّ، إِتّْخصَّا أَذْ ث ثوْشذْ ڒخُّو، مَاڒَا لَّا، أَذْ ث كْسِيغْ س ؤُغِيڒْ!“  
\v 17 دّنْبْ ن إِمْسخَّارنْ ثُوغَا إِمْغَارْ أَطَّاسْ زَّاثْ إِ وُوذمْ ن سِيذِي، مَاغَارْ إِرْيَازنْ سّحْقَارنْ ثَاوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* ن سِيذِي.   
\b  
\m
\v 18 \add مَاشَا\add* شَامْوِيلْ ثُوغَا إِتّْسخَّارْ زَّاثْ إِ وُوذمْ ن سِيذِي، أَقَا-ث ذ إِجّْ ن ؤُحنْجِيرْ إِحزّْمنْ س يِيجّْ ن ؤُپَالْطُو \add ن ؤُكهَّانْ\add* ن ڒقْطنْ.  
\v 19 يمَّاسْ ثڭَّا أَسْ إِجّْ ن ؤُسڒْهَامْ ؤُشَا ثتَّاوْيِي أَسْ ث-إِ-د زڭْ ؤُسڭّْوَاسْ غَارْ ؤُسڭّْوَاسْ، خْمِي ثتّْڭعّذْ أَكْ-ذ ورْيَازْ نّسْ حِيمَا أَذْ ثَاوِي ذِينْ ثَاغَارْصْثْ ن كُوڒْ أَسڭّْوَاسْ.  
\v 20 إِڭَّا عَالِي لْبَارَاكَا ذِي إِلْقَانَا ذ ثمْغَارْثْ نّسْ، إِنَّا: ”إِڒِي أَذْ أَشْ إِوْشْ سِيذِي زِي ثمْغَارْثْ-أَ إِجّْ ن ؤُحنْجِيرْ ذڭْ ومْشَانْ ن \add ؤُحنْجِيرْ\add* إِ ثْسلّمْ نتَّاثْ، \add ذڭْ ومْشَانْ ن ؤُحنْجِيرْ\add* إِ إِمّوْشنْ إِ سِيذِي.“ \add خنِّي\add*عقْبنْ نِيثْنِي غَارْ ومْشَانْ ن ثْزذِّيغْثْ نّسْ. \f ◼ \fr 2:‏20 \ft \+bd ’إِجّْ ن ؤُحنْجِيرْ‘\+bd* - س ثْعِيبْرَانِيثْ ’إِشْثْ ن زَّارِيعثْ‘. \+bd ’ذڭْ ومْشَانْ ن \+bdit ؤُحنْجِيرْ\+bdit*‘\+bd* - س ثْعِيبْرَانِيثْ ’ذڭْ ومْشَانْ ن ثُوثْرَا‘.\f*  
\v 21 سِيذِي مَاشَا إِخْزَارْ غَارْ حَانَّا ؤُ نتَّاثْ ثكْسِي س دّيْسثْ ؤُشَا ثُورُووْ-د ثْڒَاثَا ن إِحنْجِيرنْ ذ ثْنَاينْ ن ثْحنْجِيرِينْ، أَمْ ثُوغَا إِمقَّارْ شَامْوِيلْ أَمژْيَانْ غَارْ سِيذِي.   
\m
\v 22 إِذْوڒْ عَالِي إِوْسَارْ أَطَّاسْ. نتَّا إِسْڒَا خْ مَارَّا مِينْ ڭِّينْ إِحنْجِيرنْ نّسْ إِ مَارَّا إِسْرَائِيل ؤُشَا \add إِسْڒَا عَاوذْ\add* أَقَا نِيثْنِي طّْصنْ أَكْ-ذ ثمْغَارِينْ إِ ثُوغَا تّْسخَّارنْثْ غَارْ وَاذَافْ ن ؤُقِيضُونْ ن ؤُمْسَاڭَارْ. \x ◘ \xo 2:‏22 \xt ؤُف. 38‏:‏8\x*  
\v 23 نتَّا إِنَّا أَسنْ: ”مَايمِّي ثتّڭّمْ أَيَا أَمُّو، أَڒَامِي إِ تّسْڒِيغْ زِي مَارَّا ڒْڭنْسْ-أَ خْ ثْمڭَّا نْومْ ثِيعفَّانِينْ؟  
\v 24 لَّ، أَ إِحنْجِيرنْ إِنُو، أَيَا وَارْ إِدْجِي ذ إِجّْ ن ڒخْبَارْ إِحْڒَا إِ سْڒِيغْ. كنِّيوْ ثتَّارَّامْ ڒْڭنْسْ-أَ ن سِيذِي أَذْ إِوْضَا ذِي خطُّو.  
\v 25 مَاڒَا إِجّْ ن بْنَاذمْ إِخْضَا أَكْ-ذ إِجّْ بْنَاذمْ \add نّغْنِي\add*، \add خنِّي\add* أَذْ خَاسْ إِحْكمْ أَربِّي، مَاشَا مَاڒَا إِجّْ ن بْنَاذمْ أَذْ إِخْضَا خْ سِيذِي، وِي خَاسْ غَا إِوْثنْ؟“ \add وَاخَّا أَمنِّي\add* نِيثْنِي وَارْ سْڒِينْ شَا غَارْ بَابَاثْسنْ، مَاغَارْ سِيذِي ثُوغَا إِخْسْ أَذْ ثنْ إِنغْ. \f ◼ \fr 2:‏25 \ft \+bd ’غَارْ بَابَاثْسنْ‘\+bd* - س ثْعِيبْرَانِيثْ ’غَارْ ثْمِيجَّا ن بَابَاثْسنْ‘.\f*  
\v 26 \add مَاشَا\add* شَامْوِيلْ أَمژْيَانْ ثُوغَا إِمقَّارْ ؤُشَا يَارْنِي إِتَّاسْ-د خْ ڒْخَاضَارْ إِ سِيذِي ؤُڒَا غَارْ إِوْذَانْ. \x ◘ \xo 2:‏26 \xt لك. 2‏:‏52. \x*   
\b  
\m  
\s1 أَوَاڒْ ن أَربِّي خْ عَالِي ذ ثَارْوَا نّسْ  
\m
\v 27 ؤُشَا يُوسَا-د إِجّْ ن ورْيَازْ ن سِيذِي غَارْ عَالِي، إِنَّا أَسْ: ”أَمُّو إِ إِقَّارْ سِيذِي: ’مَا وَارْ إِ ذ سّشْنغْ إِخفْ إِنُو نِيشَانْ إِ ثَادَّارْثْ ن بَابَاشْ ؤُمِي ثنْ ثُوغَا ذِي مِيصْرَا، ذِي ثَادَّارْثْ ن فِيرْعُونْ؟ \x ◘ \xo 2:‏27 \xt ڒخ. 7‏:‏25. \x*  
\v 28 نشّْ فَارْزغْ ث زِي مَارَّا ثِيقبَّاڒْ ن إِسْرَائِيل ذ أَكهَّانْ إِ نشّْ مَاحنْذْ أَذْ إِڭعّذْ غَارْ ؤُعَالْطَارْ إِنُو حِيمَا أَذْ ذِينْ إِسَّارْغْ ڒبْخُورْ \add ؤُ\add* مَاحنْذْ أَذْ يَارْضْ أَپَالْطُو \add ن ؤُكهَّانْ\add* زَّاثْ إِ وُوذمْ إِنُو. نشّْ وْشِيغْ \add عَاوذْ\add* إِ ثَادَّارْثْ ن بَابَاشْ مَارَّا ثِيغَارْصَا ن ثْمسِّي ن أَيْثْ ن إِسْرَائِيل. \x ◘ \xo 2:‏28 \xt لَاوِي 10‏:‏14. \x*  
\v 29 مَايمِّي ثْعفّْسمْ كنِّيوْ خْ ثْغَارْصْثْ إِنُو ذ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* إِ زِي ؤُمُورغْ \add مَاحنْذْ أَذْ ثنْثْ ثْوهّْبمْ\add* ذِي ثْزذِّيغْثْ \add إِنُو\add*، ؤُ \add مَايمِّي\add* ثتّْوقَّارمْ إِحنْجِيرنْ نْومْ أَطَّاسْ خَافِي ؤُمِي ثْمسْڒمْ كنِّيوْ إِخفْ نْومْ س مُومُّو ن مَارَّا ثِيوْهِيبِينْ \add ن ڒْغِيدْجثْ\add* ن ڒْڭنْسْ إِنُو إِسْرَائِيل؟‘ \x ◘ \xo 2:‏29 \xt أَعَوذ. 32‏:‏15. \x*  
\v 30 س ؤُيَا إِقَّارْ سِيذِي، أَربِّي ن إِسْرَائِيل: ’نشّْ نِّيغْ نِيشَانْ: ثَادَّارْثْ نّشْ ذ ثَادَّارْثْ ن بَابَاشْ أَذْ ؤُيُورنْثْ زَّاثْ إِ وُوذمْ إِنُو إِ ڒبْذَا!‘، \add مَاشَا\add* ڒخُّو إِقَّارْ سِيذِي: ’أَيَا أَقَا إِڭّْوجْ خَافِي، مَاغَارْ إِنِّي ذ أَيِي إِتّْوقَّارنْ، أَذْ ثنْ وقَّارغْ، \add مَاشَا\add* إِنِّي إِ ذ أَيِي إِسّحْقَارَانْ، أَذْ تّْوَاحسْبنْ ذ إِمُوقْڒِيڒنْ. \x ◘ \xo 2:‏30 \xt ؤُف. 28‏:‏43؛ 29‏:‏9. \x*  
\v 31 خْزَارْ أَذْ أَسنْ وُوسَّانْ، أَذْ قضْعغْ أَغِيڒْ نّشْ ذ ؤُغِيڒْ ن ثَادَّارْثْ ن بَابَاشْ أَڒَامِي وَارْ إِتِّيڒِي \add عَاذْ\add* ذ أَوسَّارْ ذِي ثَادَّارْثْ نّشْ.  
\v 32 شكْ أَذْ ثخْزَارذْ \add بلِّي أَذْ د-يَاسْ\add* إِجّْ ن وغْرِيمْ \add ن\add* ثْزذِّيغْثْ، وَاخَّا نتَّا إِتّڭّْ ثْشُونِي-يَا مَارَّا إِ إِسْرَائِيل، ؤُشَاعمَّارْصْ أَذْ يِيڒِي \add عَاذْ\add* إِجّْ ن ؤُوسَّارْ ذِي ثَادَّارْثْ نّشْ، مَارَّا ؤُسَّانْ.  
\v 33 وَارْ قطّْعغْ شَا كُوڒْ أَرْيَازْ إِ غَاركْ إِدْجَانْ خْ ؤُعَالْطَارْ إِنُو، أَڒَامِي غَا ؤُحْڒنْثْ ثِيطَّاوِينْ نّشْ قَاعْ، أَذْ ثفْنَا ڒعْمَارْ نّشْ ؤُشَا مَارَّا أَرَّاوْ ن ثَادَّارْثْ نّشْ أَذْ مّْثنْ ذ إِرْيَازنْ.  
\v 34 ذ ثَا إِ ذ أَكْ غَا ثِيڒِي ذ ڒعْڒَامثْ نِّي د غَا ثَاسْ خْ ثْنَاينْ ن إِحنْجِيرنْ نّشْ، حُوفْنِي ذ فِينَاحَاسْ: أَذْ مّْثنْ س ثْنَاينْ ذڭْ إِجّْ ن وَاسّْ. \x ◘ \xo 2:‏34 \xt 1. Sm. 4‏:‏11\x*  
\v 35 نشّْ مَاشَا أَذْ ڭّغْ إِ إِخفْ إِنُو إِجّْ ن ؤُكهَّانْ ذ أَمْثِيقِّي. نتَّا أَذْ إِڭّْ عْلَاحْسَابْ ؤُڒْ ذ ڒعْمَارْ إِنُو. نشّْ أَذْ أَسْ سّْبدّغْ إِشْثْ ن ثَادَّارْثْ ثمْثنْ ؤُشَا نتَّا أَذْ يُويُورْ ڒبْذَا زَّاثْ إِ وُوذمْ ن لْمَاسِيحْ إِنُو.  
\v 36 ؤُشَا أَذْ إِمْسَارْ، بلِّي مَارَّا وِي غَا إِقِّيمنْ زِي ثَادَّارْثْ نّشْ، أَذْ د-يَاسْ أَذْ أَسْ إِبنْذقْ إِ يِيشْثْ ن ثُوقِييَّاثْ ن نُّوقَارْثْ نِيغْ إِ يِيشْثْ ن ثشْنِيفْثْ ن وغْرُومْ، أَذْ يِينِي: ’أَرْنِي أَيِي مْغِيرْ غَارْ إِشْثْ ن ڒْخذْمثْ ن ثْسخَّارْثْ ن إِكهَّاننْ، مَاحنْذْ أَذْ غَارِي يِيڒِي إِجّْ ن ؤُڒقِّيمْ ن وغْرُومْ إِ مَاشَّا.‘ “   
\b  
\b  
\m  
\c 3
\s1 ثَاڒَاغِيثْ ن أَربِّي خْ صَامْوِيلْ  
\m
\v 1 شَامْوِيلْ أَمژْيَانْ ثُوغَا إِتّْسخَّارْ إِ سِيذِي زَّاثْ إِ وُوذمْ ن عَالِي. ذڭْ وُوسَّانْ نِّي ثُوغَا أَوَاڒْ ن سِيذِي إِقِّيدْجثْ. وَارْ ثُوغِي ثتّفِّيغْ شَا ن ڒوْحِييْ.  
\v 2 ذڭْ وَاسّْ نِّي، ؤُمِي عَالِي إِطّصْ ذڭْ ومْشَانْ نّسْ ؤُشَا ذوْڒنْثْ ثِيطَّاوِينْ نّسْ أَرْخُونْثْ أَڒَامِي ثُوغَا وَارْ إِزمَّارْ أَذْ إِتّْوَاڒَا \add عَاذْ\add*، إِمْسَارْ - \x ◘ \xo 3:‏2 \xt 1 صم. 4‏:‏15. \x*   
\m
\v 3 \add عَاذْ\add* قْبڒْ إِخْسِي ڒفْنَارْ ن أَربِّي ؤُ شَامْوِيلْ ثُوغَا إِطّصْ ذِي زَّاوشْثْ ن سِيذِي مَانِي ثدْجَا تَّابُوثْ ن أَربِّي -  
\v 4 أَقَا سِيذِي إِڒَاغَا إِ شَامْوِيلْ. ؤُشَا يَارَّا-د خَاسْ شَامْوِيلْ: ”نشّْ أَقَا أَيِي ذَا!“  
\v 5 نتَّا يُوزّڒْ غَارْ عَالِي، إِنَّا: ”ذَانِيثَا إِ دْجِيغْ، شكْ ثْڒَاغِيذْ أَيِي-د.“ \add مَاشَا\add* نتَّا إِنَّا: ”نشّْ وَارْ خَاكْ د-ڒَْاغِيغْ شَا، عْقبْ، أَذْ ثزّْڒذْ!“ ؤُشَا إِعْقبْ، إِزّڒْ.   
\m
\v 6 سِيذِي إِڒَاغَا إِ شَامْوِيلْ ثْوَاڒَا نّغْنِيثْ ؤُشَا إِكَّارْ-د شَامْوِيلْ، يُويُورْ غَارْ عَالِي، إِنَّا: ”نشّْ أَقَا أَيِي ذَا، مِينْزِي شكْ ثْڒَاغِيذْ أَيِي-د.“ يَارَّا-د خَاسْ نتَّا: ”نشّْ وَارْ خَاكْ د-ڒَْاغِيغْ شَا، مِّي، عْقبْ، أَذْ ثزّْڒذْ!“  
\v 7 شَامْوِيلْ عَاذْ وَارْ إِسِّينْ سِيذِي ؤُ أَوَاڒْ ن سِيذِي ثُوغَا عَاذْ وَارْ ذ أَسْ إِتّْوَاسَّارْڭبْ.   
\m
\v 8 إِڒَاغَا-د سِيذِي خْ شَامْوِيلْ عَاوذْ إِ ثْوَاڒَا وِيسّْ ثْڒَاثَا ؤُ نتَّا إِكَّارْ-د، يُويُورْ غَارْ عَالِي، إِنَّا: ”نشّْ أَقَا أَيِي ذَا، شكْ ثْڒَاغِيذْ أَيِي-د.“ \add خَاسْ ؤُشَا\add* إِحكَّارْ عَالِي، أَقَا سِيذِي ثُوغَا إِڒَاغَا خْ ؤُحنْجِيرْ،  
\v 9 ؤُشَا عَالِي إِنَّا إِ شَامْوِيلْ: ”رُوحْ، أَذْ ثزّْڒذْ! مَاڒَا نتَّا إِڒَاغَا أَشْ-د \add عَاوذْ\add*، خنِّي أَرّْ خَاسْ: ’سِيوڒْ، سِيذِي، مَاغَارْ أَمْسخَّارْ نّشْ إِتّسْڒَا!‘ “ ؤُشَا إِعْقبْ شَامْوِيلْ، إِزّڒْ ذڭْ ومْشَانْ نّسْ.   
\m
\v 10 \add خنِّي\add* يُوسَا-د سِيذِي ؤُشَا إِبدّْ ذِينْ ؤُشَا إِڒَاغَا أَمْ ثْوَاڒَاوِينْ نّغْنِي: ”شَامْوِيلْ، شَامْوِيلْ!“ إِنَّا شَامْوِيلْ: ”سِيوڒْ، مَاغَارْ أَمْسخَّارْ نّشْ إِتّسْڒَا!“  
\v 11 سِيذِي إِنَّا إِ شَامْوِيلْ: ”خْزَارْ، نشّْ أَذْ ڭّغْ شَا ذِي إِسْرَائِيل أَڒَامِي مَارَّا وِي خَاسْ إِ غَا إِسْڒنْ، ثْنَاينْ ن إِمزُّوغنْ نّسْ أَذْ طْنطْننْ. \x ◘ \xo 3:‏11 \xt 2 إِج. 21‏:‏12؛ إِرْم. 19‏:‏3. \x*  
\v 12 ذڭْ وَاسّْ نِّي أَذْ قفْڒغْ مَارَّا إِ عَالِي، زڭْ ؤُمزْوَارُو أَڒْ أَنڭَّارُو مِينْ زِي سِّيوْڒغْ خْ ثَادَّارْثْ نّسْ. \x ◘ \xo 3:‏12 \xt 1 صم. 2‏:‏31. \x*  
\v 13 \add مِينْزِي\add* نشّْعڒْمغْ أَسْ، أَقَا نشّْ أَذْ حكْمغْ ثَادَّارْثْ نّسْ إِ ڒبْذَا خْ ڒْمُوعْصِييّثْ مِينْ خفْ إِسّنْ، مِينْزِي ڒَامِي سِّيوْضنْ إِحنْجِيرنْ نّسْ نّعْڒثْ خْ يِيخفْ نْسنْ، نتَّا وَارْ ثنْ إِطِّيفْ شَا.  
\v 14 س ؤُيَا نشّْ جُّودْجغْ إِ ثَادَّارْثْ ن عَالِي: ’وَارْ إِتّْوَاڭّْ وصْڒَاحْ إِ ڒبْذَا إِ ڒْمُوعْصِييّثْ ن ثَادَّارْثْ ن عَالِي س ثْغَارْصْثْ ؤُڒَا س ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add*!‘ “   
\m
\v 15 شَامْوِيلْ إِقِّيمْ إِزّڒْ أَڒْ صّْبحْ، \add خنِّي\add* يَارْزمْ ثِيوُّورَا ن ثَادَّارْثْ ن سِيذِي. \add مَاشَا\add* شَامْوِيلْ إِڭّْوذْ أَذْ إِحَاجَا ڒوْحِييْ إِ عَالِي.  
\v 16 \add خنِّي\add* إِڒَاغَا عَالِي خْ شَامْوِيلْ، إِنَّا: ”شَامْوِيلْ، مِّي!“ نتَّا يَارَّا-د خَاسْ: ”نشّْ أَقَا أَيِي ذَا!“  
\v 17 \add خنِّي\add* إِنَّا: ”مَانْ أَوَاڒْ إِ ذ أَشْ إِنَّا؟ تّْزَاوْڭغْ شكْ، وَارْ خَافِي سْنُوفَّارْ! أجّْ أَذْ أَشْ إِڭّْ أَربِّي أَمُّو، عَاذْ مَاهُو، مَاڒَا شكْ ثسّْنُوفَّارذْ خَافِي إِجّْ ن وَاوَاڒْ \add وَاهَا\add* زِي مَارَّا أَوَاڒْ\add أنْ\add* إِ كِيذكْ إِسِّيوڒْ نتَّا.“  
\v 18 \add خنِّي\add* إِحَاجَا أَسْ شَامْوِيلْ مَارَّا أَوَاڒنْ ؤُ وَارْ خَاسْ ثنْ إِفَّارْ. ؤُشَا يَارَّا-د خَاسْ \add عَالِي\add*: ”أَقَا-ث ذ سِيذِي، أجّْ إِ-ث أَذْ إِڭّْ مِينْ إِدْجَانْ نِيشَانْ ذِي ثِيطَّاوِينْ نّسْ!“   
\m
\v 19 شَامْوِيلْ ثُوغَا إِمقَّارْ ؤُ سِيذِي ثُوغَا-ث أَكِيذسْ ؤُ وَارْ إِجِّي \add ؤُڒَا ذ إِجّنْ\add* زِي مَارَّا أَوَاڒنْ نّسْ أَذْ إِوْضَا غَارْ ثمُّورْثْ.  
\v 20 مَارَّا إِسْرَائِيل، زِي ذَانْ أَڒْ بِئرْ-سبْعَا، ثُوغَا إِتّْوَاڒَا أَقَا شَامْوِيلْ ثُوغَا إِتّْوَاڒقّمْ ذ أَنَابِي ن سِيذِي.  
\v 21 سِيذِي إِقِّيمْ أَذْ د-إِضْهَارْ ذِي شِيلُو، مِينْزِي سِيذِي إِسَّارْڭبْ إِخفْ نّسْ إِ شَامْوِيلْ ذِي شِيلُو س وَاوَاڒْ ن سِيذِي.   
\b  
\b  
\m  
\c 4
\s1 إِفِيلِيسْطِينِييّنْ طّْفنْ تَّاپُوثْ ن سِيذِي  
\m
\v 1 أَوَاڒْ ن شَامْوِيلْ يِيوضْ غَارْ مَارَّا إِسْرَائِيل ؤُشَا إِفّغْ إِسْرَائِيل غَارْ ؤُمْسَاڭَارْ أَكْ-ذ إِفِيلِيسْطِينِييّنْ إِ ؤُمنْغِي \add أَكِيذْسنْ\add*. نِيثْنِي وْثِينْ إِقِيضَانْ نْسنْ غَارْ أَبِينْ-هَاعِيزِيرْ، ؤُشَا إِفِيلِيسْطِينِييّنْ وْثِينْ إِقِيضَانْ نْسنْ غَارْ أَفِيقْ. \f ◼ \fr 4:‏1 \ft \+bd ’أَبِينْ-هَاعِيزِيرْ‘\+bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَژْرُو ن ؤُعَاونْ‘.\f*  
\v 2 إِفِيلِيسْطِينِييّنْ سدّنْ إِخفْ نْسنْ \add إِ ؤُمنْغِي\add* أَكْ-ذ إِسْرَائِيل ؤُشَا \add ؤُمِي\add* إِميّڒْ ؤُمنْغِي ذَا ذ ذِيهَا، إِتّْوَاغلّبْ إِسْرَائِيل زَّاثْ إِ وُوذمْ ن إِفِيلِيسْطِينِييّنْ ؤُشَا نِيثْنِي نْغِينْ عْڒَاحَاڒْ أَربْعَا-أَڒَافْ ن يرْيَازنْ ذِي ڒصْفُوفْ \add ن ڒْعسْكَارْ نْسنْ\add* ذڭْ وَازَّايْ \add ن ؤُمنْغِي\add*.  
\v 3 \add ؤُمِي\add* إِعْقبْ ڒْڭنْسْ غَارْ ڒْمَارْڭحْ ن ڒْعسْكَارْ، نَّانْ إِمْغَارنْ ن إِسْرَائِيل: ”مَايمِّي ذ أَنغْ إِوْثَا سِيذِي أَسّْ-أَ زَّاثْ إِ وُوذمْ ن إِفِيلِيسْطِينِييّنْ؟ أجّْ أَنغْ أَذْ نكْسِي تَّابُوثْ ن ڒْعَاهْذْ ن سِيذِي زِي شِيلُو، أَذْ د-ثَاسْ ذِي ڒْوسْثْ نّغْ، حِيمَا أَذْ أَنغْ ثْفكّْ زڭْ ؤُفُوسْ ن ڒْعذْيَانْ نّغْ.“  
\v 4 ڒْڭنْسْ إِسّكّْ \add إِرْيَازنْ\add* غَارْ شِيلُو، إِوْينْ-د سّنِّي تَّابُوثْ ن ڒْعَاهْذْ ن سِيذِي ن ڒْعسْكَارَاثْ ونِّي إِتّْغِيمَانْ \add خْ\add* إِكِيرُوبنْ. ثُوغَا ذِينِّي ثْنَاينْ ن إِحنْجِيرنْ ن عَالِي، حُوفْنِي ذ فِينَاحَاسْ، أَكْ-ذ تَّابُوثْ ن ڒْعَاهْذْ ن أَربِّي. \f ◼ \fr 4:‏4 \ft \+bd ’إِكِيرُوبنْ‘\+bd* - إِشْثْ ن مَارْكَا ن لْمَالَاكَاثْ.\f*  \x ◘ \xo 4:‏4 \xt 2 صم. 6‏:‏2؛ إِزهد. 80‏:‏2؛ 99‏:‏1. \x*  
\v 5 \add ؤُمِي\add* د-ثُوسَا تَّابُوثْ ن ڒْعَاهْذْ ن سِيذِي غَارْ ڒْمَارْڭحْ ن ڒْعسْكَارْ، إِمْسَارْ، أَقَا مَارَّا إِسْرَائِيل إِسْڒِيوْڒوْ س يِيجّْ ن ؤُسْڒِيوْڒوْ إِجهْذنْ، أَڒَامِي ثَارْجِيجِي ثمُّورْثْ.   
\m
\v 6 \add ؤُمِي\add* سْڒَانْ إِفِيلِيسْطِينِييّنْ إِ ڒْحسّْ ن ؤُسْڒِيوْڒوْ، نَّانْ: ”مَانَا ڒْحسّْ-أَ ن ؤُسْڒِيوْڒوْ إِجهْذنْ ذِي ڒْمَارْڭحْ ن ڒْعسْكَارْ ن إِعِيبْرَانِييّنْ؟“ ؤُشَا نِيثْنِي فهْمنْ، أَقَا تَّابُوثْ ن سِيذِي ثُوسَا-د ذِي ڒْمَارْڭحْ ن ڒْعسْكَارْ.  
\v 7 ڭّْوذنْ إِفِيلِيسْطِينِييّنْ أَطَّاسْ، مَاغَارْ نِيثْنِي نَّانْ: ”أَربِّي يُوسَا-د \add غَارْسنْ\add* غَارْ ڒْمَارْڭحْ ن ڒْعسْكَارْ!“ ؤُشَا نَّانْ: ”أَيَّاوْ خَانغْ، مَاغَارْ أَيَا أَمُّوعمَّارْصْ وَارْ إِمْسَارْ!  
\v 8 ؤُشْثْ خَانغْ، مَانْ ونْ إِ ذ أَنغْ غَا إِفكّنْ زڭْ ؤُفُوسْ ن إِربِّيثنْ إِجهْذنْ؟ إِنَا ذ إِربِّيثنْ إِ إِوْثِينْ إِمِيصْرِييّنْ س مَارَّا جّْرَايحْ ذِي ڒخْڒَا!  
\v 9 إِڒِيمْ ثْمحْضمْ ؤُ إِڒِيمْ ذ إِرْيَازنْ، \add كنِّيوْ\add* إِفِيلِيسْطِينِييّنْ، مَاحنْذْ وَارْ ثتّْسخَّارمْ إِ إِعِيبْرَانِييّنْ أَمْ مَامّشْ نِيثْنِي غَارْومْ سخَّارنْ. إِڒِيمْ ذ إِرْيَازنْ ؤُ منْغمْ!“ \x ◘ \xo 4:‏9 \xt ڒقض. 13‏:‏1. \x*  
\v 10 ؤُشَا فّْغنْ إِفِيلِيسْطِينِييّنْ غَارْ ؤُمنْغِي ؤُ إِتّْوَاغْڒبْ إِسْرَائِيل. أَروْڒنْ نِيثْنِي، كُوڒْ إِجّْ غَارْ ؤُقِيضُونْ نّسْ. ثُوغَا ذ إِشْثْ ن ثْخسَّارْثْ ذ ثَامقّْرَانْثْ أَطَّاسْ، أَڒَامِي وْضَانْ ثْڒَاثِينْ-أَڒفْ ن يرْيَازنْ زِي إِسْرَائِيل إِ د-إِفّْغنْ غَارْ ؤُمنْغِي خْ إِضَارنْ.  
\v 11 تَّابُوثْ ن أَربِّي ثتّْوَاحوّسْ ؤُ ثْنَاينْ ن إِحنْجِيرنْ ن عَالِي، حُوفْنِي ذ فِينَاحَاسْ، مُّوثنْ. \x ◘ \xo 4:‏11 \xt 1 صم. 2‏:‏34؛ إِزهد. 78‏:‏61. \x*   
\m
\v 12 \add خنِّي\add* يُوزّڒْ إِجّنْ زڭْ أَيْثْ ن بِينْيَامِينْ زڭْ وَازَّايْ ن ؤُمنْغِي، يِيوضْ غَارْ شِيلُو ذڭْ وَاسّْ نِّي سِيمَانْثْ نّسْ، س وَارُّوضْ إِشَارّڭْ ؤُشَا \add أَ\add*شَاڒْ ثُوغَا خْ ؤُزدْجِيفْ نّسْ. \x ◘ \xo 4:‏12 \xt ياش. 7‏:‏6. \x*  
\v 13 \add ڒَْامِي\add* يِيوضْ نتَّا، إِقِّيمْ عَالِي خْ ڒْكُورْسِي نّسْ غَارْ ثْمَا ن وبْرِيذْ، إِقْشعْ، مِينْزِي ؤُڒْ نّسْ ثُوغَا إِتَّارْجِيجِي زِي سِّيبّثْ ن تَّابُوثْ ن أَربِّي. \add ؤُمِي\add* د-يُوسَا ورْيَازْ نِّي مَاحنْذْ أَذْ ث إِحَاجَا ذِي ثنْذِينْثْ، ثسْغُويْ ثنْذِينْثْ مَارَّا.  
\v 14 \add ؤُمِي\add* إِسْڒَا عَالِي ڒْحسّْ ن ؤُسْغُويِّي، إِنَّا: ”مَانَا ڒْحسّْ ن ڒْهَارَاجْ-أَ ن ڒْغَاشِي نِّي؟“ \add خنِّي\add* إِقدْجقْ ورْيَازْ، يُوسَا-د، إِحَاجَا \add ث\add* إِ عَالِي.  
\v 15 ثُوغَا غَارْ عَالِي ثْمنْيَا ؤُ-ثسْعِينْ ن إِسڭّْوُوسَا. ثِيطَّاوِينْ نّسْ ذوْڒنْثْ أَرْخُونْثْ، أَڒَامِي وَارْ إِتّْوِيڒِي عَاذْ. \x ◘ \xo 4:‏15 \xt 1 صم. 3‏:‏2\x*   
\m
\v 16 أَرْيَازْ إِنَّا إِ عَالِي: ”نشّْ ؤُسِيغْ-د زڭْ وَازَّايْ ن ؤُمنْغِي. أَسّْ-أَ أَروْڒغْ زِي ڒصْفُوفْ \add ن ڒْعسْكَارْ\add*.“ إِنَّا \add أَسْ عَالِي\add*: ”مِينْ إِمْسَارنْ، أَ مِّي؟“  
\v 17 أَرقَّاسْ يَارَّا-د خَاسْ، إِنَّا: ”إِسْرَائِيل يَارْوڒْ زَّاثْ إِ وُوذمْ ن إِفِيلِيسْطِينِييّنْ ؤُ ڒْڭنْسْ إِڭَّا إِشْثْ ن ثْخسَّارْثْ ثوْعَارْ أَطَّاسْ. ؤُڒَا ذ ثْنَاينْ ن إِحنْجِيرنْ نّشْ، حُوفْنِي ذ فِينَاحَاسْ، تّْوَانْغنْ ؤُ تَّابُوثْ ن أَربِّي ثتّْوَاحوّسْ.“  
\v 18 ؤُمِي نتَّا يِيذَارْ تَّابُوثْ ن أَربِّي، إِمْسَارْ، أَقَا عَالِي إِوْضَا غَارْ ضفَّارْ زِي ڒْكُورْسِي زَّاثْ إِ ثوَّارْثْ. نتَّا يَارّژْ زڭْ يِيرِي ؤُشَا إِفّغْ أَسْ بُوحْبڒْ، مَاغَارْ أَرْيَازْ ثُوغَا إِوْسَارْ ؤُ إِذْقڒْ. نتَّا ثُوغَا ذ ڒْقَاضِي خْ إِسْرَائِيل أَربْعِينْ ن إِسڭّْوُوسَا.  
\v 19 ثَاسْڒِيثْ نّسْ، ثَامْغَارْثْ ن \add مِّيسْ\add* فِينَاحَاسْ، ثُوغَا ثكْسِي س دّيْسثْ، ثُوغَا \add عْڒَاينْ\add* أَذْ د-ثَارُووْ. \add ؤُمِي\add* نتَّاثْ ثسْڒَا أَقَا تَّابُوثْ ن أَربِّي ثتّْوَاحوّسْ، ؤُعمِّيسْ إِمُّوثْ ؤُڒَا ذ أَرْيَازْ نّسْ، \add خنِّي\add* ثكْمُومّشْ ؤُشَا ثُورُووْ-د \add أَحنْجِيرْ نّسْ\add*، مِينْزِي ثُوغَا إِطّفْ إِ-ت ڒوْجعْ نّسْ ن ثَارُوثْ.  
\v 20 \add ؤُمِي\add* د-ثِيوضْ ڒْوقْثْ ن ڒْموْثْ نّسْ، نَّانْثْ ثمْغَارِينْ ثِينِّي غَارسْ إِبدّنْ: ”وَارْ تّڭّْوذْ شَا، شمْ ثُورْوذْ-د إِجّْ ن ؤُحنْجِيرْ.“ مَاشَا نتَّاثْ وَارْ \add خَاسنْثْ\add* د-ثَارِّي شَا ؤُ ؤُڒْ نّسْ وَارْ ثْحكَّارْ.  
\v 21 نتَّاثْ ثڭَّا أَسْ إِ ؤُحنْجِيرْ ’إِكابُوذْ‘، ثنَّا: ”إِتّْوَاكّسْ ؤُعُودْجِي زِي إِسْرَائِيل!“، مِينْزِي ثمّكْسِي تَّابُوثْ ن أَربِّي، ؤُشَا ؤُڒَا ذِي سِّيبّثْ \add ن ڒْموْثْ\add* نعمِّيسْ ذ ورْيَازْ نّسْ.  
\v 22 نتَّاثْ ثنَّا: ”إِتّْوَاكّسْ ؤُعُودْجِي زِي إِسْرَائِيل، مَاغَارْ ثمّكْسِي تَّابُوثْ ن أَربِّي.“   
\b  
\b  
\m  
\c 5
\s1 تَّاپُوثْ ذِي ثمُّورْثْ ن إِفِيلِيسْطِينِييّنْ  
\m
\v 1 إِفِيلِيسْطِينِييّنْ كْسِينْ تَّابُوثْ ن أَربِّي ؤُشَا إِوْينْ ت زِي أَبِينْ-هَاعِيزِيرْ غَارْ أَشْذُوذْ.  
\v 2 \add خنِّي\add* كْسِينْ إِفِيلِيسْطِينِييّنْ تَّابُوثْ ن أَربِّي ؤُشَا سِّيوْضنْ ت ذِي ثَادَّارْثْ ن ذَاجُونْ ؤُشَا سَّارْسنْ ت خْ ؤُغزْذِيسْ ن ذَاجُونْ.  
\v 3 ثِيوشَّا نّسْ \add ؤُمِي إِمزْذَاغْ\add* ن أَشْذُوذْ كَّارنْ زِيشْ، خْزَارْ، ذَاجُونْ ثُوغَا إِوْضَا خْ ؤُغمْبُوبْ نّسْ خْ ثمُّورْثْ زَّاثْ إِ تَّابُوثْ ن سِيذِي. كْسِينْ نِيثْنِي ذَاجُونْ، سّْبدّنْ ث عَاوذْ ذڭْ ومْشَانْ نّسْ.  
\v 4 ثِيوشَّا نّسْ ؤُمِي د-كَّارنْ نِيثْنِي زِيشْ \add عَاوذْ\add*، خْزَارْ، ذَاجُونْ ثُوغَا إِوْضَا \add عَاوذْ\add* خْ ؤُغمْبُوبْ نّسْ خْ ثمُّورْثْ زَّاثْ إِ تَّابُوثْ ن سِيذِي، مَاشَا أَزدْجِيفْ ن ذَاجُونْ ذ إِفَاسّنْ نّسْ س ثْنَاينْ مَّارْسنْ قسّنْ غَارْ ثْنبْذَاثْ. مْغِيرْ \add أَرِّيمثْ ن\add* ذَاجُونْ ثُوغَا ثقِّيمْ ذڭْ \add ومْشَانْ\add* نّسْ.  
\v 5 خْ ؤُيَا وَارْ عْفِيسنْ إِكهَّاننْ ن ذَاجُونْ ذ مَارَّا إِنِّي إِ د-إِتَّاسنْ غَارْ ثَادَّارْثْ ن ذَاجُونْ خْ ثْنبْذَاثْ ن ذَاجُونْ ذِي أَشْذُوذْ أَڒْ أَسّْ-أَ.   
\m
\v 6 أَفُوسْ ن سِيذِي إِذْقڒْ خْ \add إِمزْذَاغْ\add* ن أَشْذُوذْ. نتَّا إِسَّارْعبْ إِ-ثنْ ؤُشَا إِوْثَا ثنْ س ثْحبَّا، \add ذِي ثَانْذِينْثْ ن\add* أَشْذُوذْ ذ جّْوَايهْ نّسْ. \x ◘ \xo 5:‏6 \xt إِزهد. 78‏:‏66. \x*  
\v 7 \add ؤُمِي\add* إِرْيَازنْ ن أَشْذُوذْ ژْرِينْ، أَقَا أَمُّو إِ إِمْسَارْ، نَّانْ نِيثْنِي: ”تَّابُوثْ ن أَربِّي ن إِسْرَائِيل وَارْ ثْزمَّارْ أَذْ غَارْنغْ ثقِّيمْ، مَاغَارْ أَفُوسْ نّسْ إِڭَّا خَانغْ دّْقڒْ ؤُڒَا خْ أَربِّي نّغْ ذَاجُونْ.“  
\v 8 نِيثْنِي سّكّنْ \add إِرْيَازنْ\add* ؤُشَا ڭِّينْ أَذْ سّْمُوننْ مَارَّا ڒْبَاشَاثْ \add ن ثْندَّامْ\add* ن إِفِيلِيسْطِينِييّنْ، نَّانْ: ”مِينْ غَا نڭّْ س تَّابُوثْ ن أَربِّي ن إِسْرَائِيل؟“ نَّانْ نِيثْنِي: ”تَّابُوثْ ن أَربِّي ن إِسْرَائِيل أَذْ ثتّْوَاسّْمُوطِّييْ غَارْ جَاثْ.“ \add خنِّي\add* سّْمُوطِّيينْ تَّابُوثْ ن أَربِّي ن إِسْرَائِيل \add غَارْ جَاثْ\add*.   
\m
\v 9 مَاشَا أَوَارْنِي إِ ؤُمِي ت سّْمُوطِّيينْ، إِسِّيوضْ ؤُفُوسْ ن سِيذِي إِجّْ ن ؤُخَارْوضْ ذ أَمقّْرَانْ خْ ثنْذِينْثْ نِّي ؤُشَا إِوْثَا إِرْيَازنْ ن ثنْذِينْثْ، زڭْ ؤُمژْيَانْ أَڒْ أَمقّْرَانْ، س ثْحبَّا \add إِنُّوفَارنْ\add*.  
\v 10 \add خنِّي\add* سّكّنْ نِيثْنِي تَّابُوثْ ن أَربِّي غَارْ عَاقْرُونْ. ؤُمِي د-ثُوسَا تَّابُوثْ ن أَربِّي غَارْ عَاقْرُونْ، إِمْسَارْ، أَقَا \add إِمزْذَاغْ ن\add* عَاقْرُونْ سْغُوينْ، نَّانْ: ”نِيثْنِي إِوْينْ-د تَّابُوثْ ن أَربِّي ن إِسْرَائِيل غَارْنغْ \add ذَانِيثَا\add*، حِيمَا أَذْ أَنغْ نْغنْ ؤُڒَا ذ ڒْڭنْسْ نّغْ.“  
\v 11 سّكّنْ نِيثْنِي \add إِرقَّاسنْ\add* ؤُشَا ڭِّينْ أَذْ سّْمُوننْ مَارَّا ڒْبَاشَاثْ \add ن ثْندَّامْ\add* ن إِفِيلِيسْطِينِييّنْ، نَّانْ: ”سِيڭّْوجمْ تَّابُوثْ ن أَربِّي ن إِسْرَائِيل، جّمْ ت أَذْ د-ثذْوڒْ غَارْ ومْشَانْ نّسْ، حِيمَا وَارْ ذ أَيِي إِنقّْ ؤُڒَا ذ ڒْڭنْسْ إِنُو!“، مِينْزِي ثُوغَا ذِينْ إِجّْ ن ؤُقزّبْ إِمْغَارْ ذِي مَارَّا ثَانْذِينْثْ ؤُشَا أَفُوسْ ن أَربِّي إِذْقڒْ أَطَّاسْ \add خْ عَاقْرُونْ\add*.  
\v 12 إِوْذَانْ، إِنِّي وَارْ إِمُّوثنْ، ثُوغَا تّْوَاوْثنْ س ثْحبَّا، أَڒَامِي أَغُويِّي ن ؤُسْغَاثِي ن ثنْذِينْثْ إِڭعّذْ غَارْ ؤُجنَّا سنّجْ.   
\b  
\b  
\m  
\c 6
\s1 أَذْوڒْ ن تَّاپُوثْ غَارْ إِسْرَائِيل  
\m
\v 1 \add ؤُمِي\add* تَّابُوثْ ن سِيذِي ثكَّا سبْعَا ن إِيُورنْ ذِي ثمُّورْثْ ن إِفِيلِيسْطِينِييّنْ،  
\v 2 ڒَاغَانْ إِفِيلِيسْطِينِييّنْ خْ إِكهَّاننْ ذ إِڭزَّاننْ، نَّانْ: ”مِينْ غَا نڭّْ أَكْ-ذ تَّابُوثْ ن سِيذِي؟ سشْنمْ أَنغْ، مَامّشْ ت إِ غَا نسّكّْ غَارْ ومْشَانْ نّسْ.“  
\v 3 نِيثْنِي أَرِّينْ-د \add خَاسنْ\add*: ”مَاڒَا كنِّيوْ ثسّكّمْ تَّابُوثْ ن أَربِّي ن إِسْرَائِيل، خنِّي وَارْ ت ثسّكّمْ ثخْوَا، مِينْزِي إِتّْخصَّا أَذْ ثْخدْجْصمْ إِشْثْ ن ثوْهِيبْثْ ن ؤُمَارْوَاسْ إِ وعْذَاڒْ. خنِّي أَذْ ثڭّنْفَامْ ؤُشَا أَذْ ثسّْنمْ، مَايمِّي أَفُوسْ نّسْ وَارْ زَّايْومْ إِتّكّسْ.“  
\v 4 \add خنِّي\add* نَّانْ نِيثْنِي: ”مَانْ ثَاوْهِيبْثْ ن ؤُمَارْوَاسْ إِ ذ أَسْ غَا نْقدّمْ إِ وعْذَاڒْ؟“ نِيثْنِي أَرِّينْ-د \add خَاسنْ\add*: ”خمْسَا ن ثْحبَّا ن وُورغْ ذ خمْسَا ن إِغَارْذَاينْ ن وُورغْ، خْ قدَّا ن ڒْبَاشَاثْ \add ن ثْندَّامْ\add* ن إِفِيلِيسْطِينِييّنْ، مِينْزِي كنِّيوْ مَارَّا \add ثڒْقفْ\add* كنِّيوْ جّْرِيحشْثْ ذ إِشْثنْ ؤُڒَا ذ ڒْبَاشَاثْ نْومْ.  
\v 5 ڭّمْ ڒخْيَاڒَاثْ ن ثْحبَّا نْومْ ذ ڒخْيَاڒَاثْ ن إِغَارْذَاينْ نْومْ نِّي يَاردّْدْجنْ ثَامُّورْثْ، ؤُشَا سْعُودْجمْ أَربِّي ن إِسْرَائِيل. أَذْ ثَاغْ أَذْ إِسّفْسسْ أَفُوسْ نّسْ خَاومْ، خْ إِربِّيثنْ نْومْ ؤُ خْ ثمُّورْثْ نْومْ.  
\v 6 مَايمِّي غَا ثسّْقسْحمْ ؤُڒْ نْومْ أَمْ سّْقسْحنْ إِمِيصْرِييّنْ ذ فِيرْعُونْ ؤُڒْ نْسنْ؟ \add ؤُمِي\add* خَاسنْ إِزيَّارْ نتَّا أَڒْ طَّارْفْ، مَا نِيثْنِي وَارْ ذ أَرْخُونْ \add إِ أَيْثْ إِسْرَائِيل\add* ؤُ مَا نِيثْنِي وَارْ د-فِّيغنْ شَا \add خنِّي\add*؟ \x ◘ \xo 6:‏6 \xt ؤُف. 12‏:‏31. \x*  
\v 7 خنِّي  ڒخُّو، كْسِيمْ إِجّْ ن ؤُكَارُّو ن جْذِيذْ، سْوجْذمْ ث س ثْنَاينْ ن ثْفُونَاسِينْ سُّوطُّوضنْثْ، وَارْ خَاسنْثْ إِمَّارْسْ عَاذْ ؤُزَايْڒُو، ؤُ قّْنمْ ثِيفُونَاسِينْ غَارْ زَّاثْ إِ ؤُكَارُّو ؤُ كّْسمْ أَسنْثْ زِي ضفَّارْ نْسنْثْ إِمژْيَاننْ نْسنْثْ ؤُ أَوْيمْ ثنْ غَارْ ثَادَّارْثْ. \f ◼ \fr 6:‏7 \ft \+bd ’أَمَايْنُو‘\+bd* - نِيغْ ’جْذِيذْ‘.\f*  
\v 8 \add خنِّي\add* كْسِيمْ تَّابُوثْ ن سِيذِي، سَارْسمْ ت خْ ؤُكَارُّو ؤُ سَارْسمْ خْ ؤُغزْذِيسْ نّسْ، ذڭْ إِشْثْ ن ثْسنْذُوقْثْ، ڒقْشُوعْ ن وُورغْ إِ ثخْسمْ أَذْ أَسْ ثْخدْجْصمْ \add أَمْ\add* ثوْهِيبْثْ ن ؤُمَارْوَاسْ إِ وعْذَاڒْ. سكّمْ ت، أَذْ ثْرَاحْ.  
\v 9 حْضَامْ، مَاڒَا \add أَكَارُّو\add* إِڭعّذْ-د ذڭْ وبْرِيذْ غَارْ ويْمِيرْ نّسْ، غَارْ بَايْثْ-شَامْسْ، \add خنِّي\add* ذ نتَّا إِ ذ أَنغْ إِوْثِينْ س ثشْثِي-يَا ثَامقّْرَانْثْ، مَاڒَا لَّا، \add خنِّي\add* نسّنْ نشِّينْ، أَقَا وَارْ إِدْجِي ذ أَفُوسْ نّسْ إِ ذ أَنغْ إِڒقْفنْ: أَقَا ثُوسَا-د أَمنِّي وَاهَا.“   
\m
\v 10 إِرْيَازنْ ڭِّينْ \add ت\add* أَمُّو. نِيثْنِي كْسِينْ ثْنَاينْ ن ثْفُونَاسِينْ سُّوطُّوضنْثْ، قّْننْ ثنْثْ غَارْ زَّاثْ إِ ؤُكَارُّو ؤُشَا قّْننْ إِمژْيَاننْ نْسنْثْ ذڭْ ؤُينِّيرْ ن ثَادَّارْثْ.  
\v 11 نِيثْنِي سَّارْسنْ تَّابُوثْ ن سِيذِي خْ ؤُكَارُّو، ؤُڒَا ذ ثَاسنْذُوقْثْ أَكْ-ذ إِغَارْذَاينْ ن وُورغْ ذ ڒخْيَاڒَاثْ ن ثْحبَّا نْسنْ.  
\v 12 ثِيفُونَاسِينْ ؤُيُورنْثْ نِيشَانْ غَارْ وبْرِيذْ جِّيهثْ ن بَايْثْ-شَامْسْ، ؤُيُورنْثْ خْ وبْرِيذْ إِسڭّْمنْ نِّي. نِيثنْثِي قِّيمنْثْ ڭُّورنْثْ، أَمْ سّْمُوهْرُوثنْثْ، وَارْ حيّْذنْثْ \add خْ وبْرِيذْ\add* \add غَارْ\add* يفُوسْ ؤُڒَا \add غَارْ\add* ؤُزڒْمَاضْ. ڒْبَاشَاثْ \add ن ثْندَّامْ\add* ن إِفِيلِيسْطِينِييّنْ أَردّْفنْ ثنْثْ أَڒْ أَيْمِيرْ ن بَايْثْ-شَامْسْ.  
\v 13 \add إِمزْذَاغْ\add* ن بَايْثْ-شَامْسْ ثُوغَا مجَّارنْ صَّابثْ ن إِرْذنْ ذِي ڒوْضَا ن ثغْزُورْثْ. \add ؤُمِي\add* سّْڭعّْذنْ نِيثْنِي ثَامُوغْڒِي نْسنْ، ژْرِينْ تَّابُوثْ ؤُ فَارْحنْ أَطَّاسْ ؤُمِي ت ژْرِينْ.  
\v 14 أَكَارُّو ثُوغَا يِيوضْ أَڒْ إِيَّارْ ن يَاشُووَا، ونِّي زِي بَايْثْ-شَامْسْ، ؤُشَا إِبدّْ \add ؤُكَارُّو\add* ذِينِّي. ثُوغَا ذِينِّي إِجّْ ن وژْرُو ذ أَمقّْرَانْ. نِيثْنِي زذْمنْ ثِيفڒْوِينْ ن ؤُكَارُّو ؤُ سّْڭعّْذنْ ثِيفُونَاسِينْ ذ ثَاغَارْصْثْ ن وشْمَاضْ إِ سِيذِي.  
\v 15 إِلَاوِييّنْ كْسِينْ تَّابُوثْ ن سِيذِي ذ ثْسنْذُوقْثْ \add إِمَّارْسنْ\add* خْ ؤُغزْذِيسْ نّسْ، إِ ذِي ثُوغَا ڒقْشُوعْ ن وُورغْ، ؤُ سَّارْسنْ أَيَا خْ وژْرُو نِّي أَمقّْرَانْ. ذڭْ وَاسّْ نِّي سِيمَانْثْ نّسْ سّْڭعّْذنْ يرْيَازنْ ن بَايْثْ-شَامْسْ ثِيغَارْصَا ن وشْمَاضْ إِ سِيذِي ؤُ قدّْمنْ \add عَاوذْ\add* ثِيغَارْصَا.  
\v 16 \add ؤُمِي\add* ژْرِينْ خمْسَا ن ڒْبَاشَاثْ \add ن ثْندَّامْ\add* ن إِفِيلِيسْطِينِييّنْ \add مَانْ أَيَا\add*، ذوْڒنْ-د غَارْ عَاقْرُونْ ذڭْ وَاسّْ نِّي سِيمَانْثْ نّسْ.   
\m
\v 17 ثِينَا ذ ثِيحبَّا ن وُورغْ نِّي إِخدْجْصنْ إِفِيلِيسْطِينِييّنْ أَمْ ثوْهِيبْثْ ن ؤُمَارْوَاسْ إِ وعْذَاڒْ إِ سِيذِي: إِشْثْ إِ أَشْذُوذْ، إِشْثْ إِ غَازَا، إِشْثْ إِ أَشْقِيلُونْ، إِشْثْ إِ جَاثْ، إِشْثْ إِ عَاكْرُونْ.  
\v 18 \add ؤُڒَا ذ\add* إِغَارْذَاينْ ن وُورغْ خْ قدَّا ن مَارَّا ثِيندَّامْ ن إِفِيلِيسْطِينِييّنْ ثِينِّي إِقّْننْ إِ خمْسَا ن ڒْبَاشَاثْ \add ن ثْندَّامْ\add*، زِي ثْندَّامْ إِفَارْينْ أَڒْ ذْشُورَاثْ إِ ذ أَسنْثْ إِ-د-إِنّْضنْ. \add يِيوضْ ؤُكَارُّو\add* أَڒْ أَبِيلْ، أَژْرُو أَمقّْرَانْ إِ خفْ ثُوغَا سَّارْسنْ تَّابُوثْ ن سِيذِي، \add أَژْرُو\add* إِ ذِينْ \add إِقِّيمنْ\add* أَڒْ أَسّْ-أَ ذڭْ إِيَّارْ ن يَاشُووَا زِي بَايْثْ-شَامْسْ.   
\m
\v 19 نتَّا مَاشَا إِوْثَا إِرْيَازنْ ن بَايْثْ-شَامْسْ، مِينْزِي نِيثْنِي ثُوغَا خْزَارنْ تَّابُوثْ ن سِيذِي. زِي ڒْڭنْسْ إِوْثَا نتَّا سبْعِينْ ن يرْيَازنْ \add زڭْ\add* خمْسِينْ-أَڒفْ ن يرْيَازنْ. ؤُشَا إِشْضنْ ڒْڭنْسْ، مِينْزِي سِيذِي ثُوغَا إِڭَّا إِ ڒْڭنْسْ إِشْثْ ن ثشْثِي ذ ثَامقّْرَانْثْ.  
\v 20 \add خنِّي\add* نَّانْ إِرْيَازنْ ن بَايْثْ-شَامْسْ: ”وِي إِزمَّارنْ أَذْ إِقِّيمْ إِبدّْ زَّاثْ إِ وُوذمْ ن سِيذِي، أَربِّي ذ أَمْقدّسْ وَا؟ ذ غَارْ مَانْ ونْ زَّايْنغْ إِ غَا ثُويُورْ تَّابُوثْ؟“  
\v 21 نِيثْنِي سّكّنْ إِرقَّاسنْ غَارْ إِمزْذَاغْ ن قَارْيَاثْ-يَاعَارِيمْ، نَّانْ: ”إِفِيلِيسْطِينِييّنْ أَرِّينْ-د تَّابُوثْ ن سِيذِي. هْوَامْ ؤُشَا سّْڭعّْذمْ ت غَارْومْ سنّجْ!“   
\b  
\b  
\m  
\c 7
\s1 أَمنْغِي غَارْ مِيصْفَا  
\m
\v 1 \add خنِّي\add* ؤُسِينْ-د يرْيَازنْ ن قَارْيَاثْ-يَاعَارِيمْ ؤُشَا إِوْينْ تَّابُوثْ ن سِيذِي غَارْسنْ سنّجْ. نِيثْنِي سِّيذْفنْ ت ذِي ثَادَّارْثْ ن أَبِينَاذَابْ، خْ ثوْرِيرْثْ، ؤُشَا سّْقدّْسنْ مِّيسْ أَلِيعَازَارْ حِيمَا أَذْ إِحْضَا خْ تَّابُوثْ ن سِيذِي. \x ◘ \xo 7:‏1 \xt 2 صم. 6‏:‏4. \x*  
\v 2 زڭْ وَاسّْ نِّي إِمْسَارْ أَقَا تَّابُوثْ ثقِّيمْ ذِي قَارْيَاثْ-يَاعَارِيمْ. ثُوغَا عْذُونْ أَطَّاسْ ن وُوسَّانْ أَڒَامِي عْذُونْ عِيشْرِينْ ن إِسڭّْوُوسَا. مَارَّا ثَادَّارْثْ ن إِسْرَائِيل \add ثُويُورْ\add* أَوَارْنِي إِ سِيذِي، ثتّْشثْشَا.  
\v 3 \add خنِّي\add* إِسِّيوڒْ شَامْوِيلْ غَارْ مَارَّا ثَادَّارْثْ ن إِسْرَائِيل، إِنَّا: ”مَاڒَا كنِّيوْ ثخْسمْ أَذْ د-ثْذوْڒمْ غَارْ سِيذِي س مَارَّا ؤُڒْ نْومْ، \add خنِّي\add* نْضَارمْ خَاومْ إِربِّيثنْ إِغْرِيبنْ زِي ڒْوسْطْ نْومْ، ؤُڒَا ذ ’عَاشْثَارُوثِينْ‘، ؤُ أَرّمْ ؤُڒْ نْومْ غَارْ سِيذِي، خذْممْ أَسْ إِ نتَّا وحّْذسْ، \add خنِّي\add* نتَّا أَذْ كنِّيوْ إِفكّْ زڭْ ؤُفُوسْ ن إِفِيلِيسْطِينِييّنْ.“ \x ◘ \xo 7:‏3 \xt أَعَوذ. 6‏:‏13؛ 10‏:‏20؛ مت. 4‏:‏10؛ لك. 4‏:‏8\x*   
\m
\v 4 ؤُشَا نْضَارنْ أَيْثْ ن إِسْرَائِيل ’إِبَاعْلنْ‘ ذ ’عَاشْثَارُوثِينْ‘ ؤُشَاعبْذنْ إِ سِيذِي وحّْذسْ.  
\v 5 إِنَّا شَامْوِيلْ: ”سْمُونمْ مَارَّا إِسْرَائِيل ذِي مِيصْفَاثْ، \add خنِّي\add* نشّْ أَذْ ژَّادْجغْ إِ سِيذِي إِ كنِّيوْ.“  
\v 6 مُوننْ ذِي مِيصْفَا ؤُشَا ؤُيْمنْ أَمَانْ، فَارّْغنْ ثنْ زَّاثْ إِ وُوذمْ ن سِيذِي. ذڭْ وَاسّْ نِّي ژُومّنْ ؤُشَا نَّانْ ذِينْ: ”أَقَا نخْضَا أَكْ-ذ سِيذِي!“ أَمُّو إِ إِحْكمْ شَامْوِيلْ أَيْثْ ن إِسْرَائِيل ذِي مِيصْفَا.  
\v 7 \add ؤُمِي\add* إِفِيلِيسْطِينِييّنْ سْڒِينْ، أَقَا أَيْثْ ن إِسْرَائِيل ثُوغَا مُوننْ ذِي مِيصْفَاثْ، فّْغنْ ڒْبَاشَاثْ \add ن ثْندَّامْ\add* ن إِفِيلِيسْطِينِييّنْ ضِيدّْ إِ إِسْرَائِيل. \add ڒَْامِي\add* سْڒِينْ أَيْثْ ن إِسْرَائِيل إِ مَانَا أَيَا، ڭّْوذنْ نِيثْنِي زڭْ إِفِيلِيسْطِينِييّنْ.  
\v 8 نَّانْ أَيْثْ ن إِسْرَائِيل إِ شَامْوِيلْ: ”وَارْ سْبذِّي س ؤُڒَاغِي ذِي طّْوعْ نّغْ إِ سِيذِي، أَربِّي نّغْ، \add مَاحنْذْ\add* نتَّا أَذْ أَنغْ إِفكّْ زڭْ ؤُفُوسْ ن إِفِيلِيسْطِينِييّنْ.“  
\v 9 \add خنِّي\add* إِكْسِي شَامْوِيلْ إِجّْ ن إِزْمَارْ إِطّضْ ؤُ إِقدّمْ إِ-ث قَاعْ ذ ثَاغَارْصْثْ ن وشْمَاضْ إِ سِيذِي ؤُ شَامْوِيلْ إِڒَاغَا غَارْ سِيذِي ذِي طّْوعْ ن إِسْرَائِيل ؤُ سِيذِي إِسْڒَا أَسْ.   
\m
\v 10 ؤُمِي إِقدّمْ شَامْوِيلْ ثَاغَارْصْثْ ن وشْمَاضْ، إِمْسَارْ، أَقَا ؤُسِينْ-د إِفِيلِيسْطِينِييّنْ إِ ؤُمنْغِي أَكْ-ذ إِسْرَائِيل. ؤُشَا إِسّْهمْهمْ سِيذِي أَطَّاسْ ذڭْ وَاسّْ نِّي خْ إِفِيلِيسْطِينِييّنْ، إِسَّارْجفْ إِ-ثنْ \add أَڒَامِي\add* تّْوَاغڒْبنْ زَّاثْ إِ وُوذمْ ن إِسْرَائِيل. \x ◘ \xo 7:‏10 \xt ياش. 10‏:‏10. \x*  
\v 11 فّْغنْ يرْيَازنْ ن إِسْرَائِيل زِي مِيصْفَا، ضْفَارنْ إِفِيلِيسْطِينِييّنْ ؤُشَا وْثِينْ ثنْ أَڒْ سَاذُو بَايْثْ-كَارْ.   
\b  
\m
\v 12 إِكْسِي شَامْوِيلْ إِجّْ ن وژْرُو، إِسّْبدّْ إِ-ث جَارْ مِيصْفَا ذ سَانْ. نتَّا إِڭَّا أَسْ إِسمْ ’أَبِينْ-هَاعِيزِيرْ‘، إِنَّا: ”أَڒْ ذَانِيثَا إِ ذ أَنغْ إِوْشَا سِيذِي أَفُوسْ.“ \f ◼ \fr 7:‏12 \ft \+bd ’أَبِينْ-هَاعِيزِيرْ‘\+bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَژْرُو ن ثْوِيزَا‘.\f*  \x ◘ \xo 7:‏12 \xt 1 صم. 4‏:‏1. \x*  
\v 13 \add أَمُّو\add* إِ تّْوَاسّحْقَارنْ إِفِيلِيسْطِينِييّنْ ؤُشَا وَارْ ؤُذِيفنْ شَا عَاذْ ذَاخڒْ إِ إِيْمِيرنْ ن إِسْرَائِيل، \add مِينْزِي\add* ثُوغَا أَفُوسْ ن سِيذِي ضِيدّْ إِ إِفِيلِيسْطِينِييّنْ مَارَّا ؤُسَّانْ ن شَامْوِيلْ.  
\v 14 ثِيندَّامْ زِي عَاقْرُونْ أَڒْ جَاثْ إِ ثُوغَا طّْفنْ إِفِيلِيسْطِييّنْ زڭْ أَيْثْ ن إِسْرَائِيل، ذوْڒنْثْ-د غَارْ إِسْرَائِيل ؤُشَا جّْوَايهْ إِ غَارْسنْ د-إِقّْننْ، إِقْڒعْ إِ-ثنْثْ إِسْرَائِيل زڭْ ؤُفُوسْ ن إِفِيلِيسْطِينِييّنْ ؤُشَا إِذْوڒْ ذِينْ ڒهْنَا جَارْ إِسْرَائِيل ذ إِمُورِييّنْ.   
\m
\v 15 ثُوغَا شَامْوِيلْ ذ ڒْقَاضِي خْ إِسْرَائِيل مَارَّا ؤُسَّانْ ن ثُوذَارْثْ نّسْ.  
\v 16 أَسڭّْوَاسْ خْ ؤُسڭّْوَاسْ ثُوغَا نتَّا إِتّفّغْ، إِڭُّورْ ذِي بَايْثْ-إِلْ ذ جِيلْجَالْ ذ مِيصْفَا. ذِي مَارَّا إِمُوشَانْ نِّي ثُوغَا نتَّا ذ ڒْقَاضِي خْ إِسْرَائِيل.  
\v 17 \add أَوَارْنِي أَيَا\add* إِذْوڒْ نتَّا غَارْ رَامَا، مَاغَارْ ذِينِّي إِ ثُوغَا ثَادَّارْثْ نّسْ ؤُ ذِينِّي ثُوغَا نتَّا ذ ڒْقَاضِي خْ إِسْرَائِيل ؤُشَا إِبْنَا ذِينِّي إِجّْ ن ؤُعَالْطَارْ إِ سِيذِي. \x ◘ \xo 7:‏17 \xt 1 صم. 8‏:‏4. \x*   
\b  
\b  
\m  
\c 8
\s1 ڒْڭنْسْ إِتَّارْ إِجّْ ن ؤُجدْجِيذْ  
\m
\v 1 \add ؤُمِي\add* إِذْوڒْ شَامْوِيلْ إِوْسَارْ، إِمْسَارْ، أَقَا إِڭَّا إِحنْجِيرنْ نّسْ ذ ڒْقُوضَاثْ خْ إِسْرَائِيل.  
\v 2 مِّيسْ أَمزْوَارُو ثُوغَا قَّارنْ أَسْ يُووِيلْ ؤُ ونِّي وِيسّْ ثْنَاينْ قَّارنْ أَسْ أَبِييَا. نِيثْنِي ثُوغَا أَثنْ ذ ڒْقُوضَاثْ ذِي بِئرْ-سبْعَا.  
\v 3 مَاشَا إِحنْجِيرنْ نّسْ وَارْ أَرذْفنْ إِبْرِيذنْ نّسْ. نِيثْنِي أَرزُّونْ خْ أَرْبحْ \add إِ يِيخفْ نْسنْ\add*، طّْفنْ أَرِّيغَالُوثْ ؤُ سّْفَارّْغنْ ڒْحقّْ. \x ◘ \xo 8:‏3 \xt ؤُف. 18‏:‏21؛ أَعَوذ. 16‏:‏19. \x*  
\v 4 \add خنِّي\add* مُوننْ مَارَّا إِمْغَارنْ ن إِسْرَائِيل، ؤُسِينْ-د غَارْ شَامْوِيلْ ذِي رَامَا.  
\v 5 نِيثْنِي نَّانْ أَسْ: ”خْزَارْ، شكْ ثوْسَارذْ ؤُ إِحنْجِيرنْ نّشْ وَارْ ڭُّورنْ شَا خْ ثبْرِيذِينْ نّشْ. س ؤُيَا أڭّْ ڒخُّو إِجّْ ن ؤُجدْجِيذْ خَانغْ مَاحنْذْ أَذْ خَانغْ إِحْكمْ، أَمْ مَامّشْ \add إِدْجَا\add* غَارْ مَارَّا ڒڭْنُوسْ نّغْنِي.“ \x ◘ \xo 8:‏5 \xt حُوش. 13‏:‏10؛ ڒخ. 13‏:‏21. \x*   
\m
\v 6 أَوَاڒْ-أَ إِدْجَا ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن شَامْوِيلْ، ڒَامِي نَّانْ: ”أوْشْ أَنغْ إِجّْ ن ؤُجدْجِيذْ مَاحنْذْ أَذْ خَانغْ إِحْكمْ!“ ؤُشَا شَامْوِيلْ إِژُّودْجْ إِ سِيذِي. \x ◘ \xo 8:‏6 \xt 1 صم. 12‏:‏17. \x*  
\v 7 إِنَّا سِيذِي إِ شَامْوِيلْ: ”سڒْ غَارْ ڒْڭنْسْ ذِي مَارَّا مِينْ إِ ذ أَشْ غَا إِنِينْ، مَاغَارْ وَارْ إِدْجِي ذ شكْ إِ نْضَارنْ نِيثْنِي، مَاشَا ذ نشّْ إِ نْضَارنْ نِيثْنِي، حِيمَا نشّْ وَارْ تِّيڒِيغْ ذ أَجدْجِيذْ خَاسنْ. \f ◼ \fr 8:‏7 \ft \+bd ’غَارْ ڒْڭنْسْ‘\+bd* - س ثْعِيبْرَانِيثْ ’غَارْ ثْمِيجَّا ن ڒْڭنْسْ‘.\f*  
\v 8 نِيثْنِي تّڭّنْ \add عَاذْ\add* أَمْ مَامّشْ ڭِّينْ س مَارَّا ثِيمڭَّا نْسنْ زڭْ وَاسّْ إِ ثنْ د-سّْڭعّْذغْ زِي مِيصْرَا أَڒْ أَسّْ-أَ. نِيثْنِي سمْحنْ ذ أَيِي ؤُشَا سخَّارنْ إِ إِربِّيثنْ نّغْنِي. أَمُّو إِ ذَايكْ تّڭّنْ نِيثْنِي عَاوذْ.  
\v 9 سڒْ ڒخُّو غَارْسنْ، مَاشَا عْڒمْ أَسنْ نِيشَانْ ؤُشَا سَارْڭبْ إِ-ثنْ س ڒْحقّْ ن ؤُجدْجِيذْ ونِّي إِ خَاسنْ إِ غَا إِحكْمنْ.“ \f ◼ \fr 8:‏9 \ft \+bd ’سڒْ ڒخُّو غَارْسنْ‘\+bd* - س ثْعِيبْرَانِيثْ ’سڒْ ڒخُّو غَارْ ثْمِيجَّا نْسنْ‘.\f*   
\m
\v 10 إِسِّيوڒْ شَامْوِيلْ مَارَّا أَوَاڒنْ ن سِيذِي أَكْ-ذ ڒْڭنْسْ نِّي زَّايسْ إِتَّارنْ إِجّْ ن ؤُجدْجِيذْ.  
\v 11 نتَّا إِنَّا: ”أَيَا إِ غَا يِيڒِي ذ ڒْحقّْ ن ؤُجدْجِيذْ إِ خَاومْ إِ غَا إِحكْمنْ: نتَّا أَذْ يَاوِي إِحنْجِيرنْ نْومْ، أَذْ ثنْ يَارَّا إِ يِيخفْ نّسْ غَارْ إِكَارُّوثنْ نّسْ مَاحنْذْ أَذْ إِڒِينْ ذ إِمْنَاينْ نّسْ، ؤُ أَذْ زّْڒنْ غَارْ زَّاثْ إِ إِكَارُّوثنْ نّسْ.  
\v 12 نتَّا أَذْ ثنْ إِڭّْ إِ يِيخفْ نّسْ ذ إِمقّْرَاننْ خْ وَاڒفْ ؤُڒَا ذ إِمقّْرَاننْ خْ خمْسِينْ، ؤُ أَذْ ثنْ يَارّْ أَذْ شَارْزنْ إِيَّارنْ نّسْ، أَذْ مْجَارنْ صَّابثْ نّسْ ؤُ أَذْ ڭّنْ دُّوزَانْ ن ؤُمنْغِي نّسْ ذ دُّوزَانْ ن إِكَارُّوثنْ نّسْ.  
\v 13 يسِّيثْومْ أَذْ ثنْثْ-إِ-د-يَاوِي مَاحنْذْ أَذْ أَسْ ڭّنْثْ فُومَاضَاثْ، أَذْ سّْننَّانْثْ ؤُ أَذْ ڭّْونْثْ.  
\v 14 أَذْ إِكْسِي مُومُّو ن إِيَّارنْ نْومْ، ن إِمَارْجَاعنْ نْومْ ن ؤُضِيڒْ ؤُ ن إِحْوِيشنْ ن ثَازَارْثْ نْومْ، ؤُشَا أَذْ \add ث\add* إِوْشْ إِ إِمْسخَّارنْ نّسْ.  
\v 15 أَذْ إِكْسِي ڒعْشُورْ ن زَّارِيعثْ نْومْ، ن إِمَارْجَاعنْ نْومْ ن ؤُضِيڒْ ؤُشَا أَذْ ثنْ إِوْشْ إِ إِمْسخَّارنْ نّسْ إِشنّْعنْ ؤُ إِ إِمْسخَّارنْ نّسْ إِنّغْنِي.  
\v 16 أَذْ إِكْسِي إِسمْغَانْ ذ ثِييَّا نْومْ ذ إِحُوذْرِييّنْ نْومْ إِصبْحنْ ذ إِغْيَاڒْ نْومْ، ؤُشَا أَذْ \add ثنْ\add* يجّْ أَذْ أَسْ خذْمنْ.  
\v 17 أَذْ إِكْسِي ڒعْشُورْ ن ثْحِيمْرِيوِينْ نْومْ ؤُ كنِّيوْ أَذْ ثِيڒِيمْ ذ إِمْسخَّارنْ نّسْ.  
\v 18 ذڭْ وَاسّْ نِّي أَذْ ثسْغُويمْ زَّاثْ إِ وُوذمْ ن ؤُجدْجِيذْ نْومْ إِ ثخْضَارمْ كنِّيوْ، \add مَاشَا\add* سِيذِي وَارْ ذ أَومْ إِتّسْڒِي شَا ذڭْ وَاسّْ نِّي.“  
\v 19 \add مَاشَا\add* ڒْڭنْسْ وَارْ إِخْسْ أَذْ إِسڒْ غَارْ شَامْوِيلْ، نَّانْ: ”لَّ، إِتّْخصَّا أَذْ خَانغْ يِيڒِي إِجّْ ن ؤُجدْجِيذْ.“  
\v 20 ؤُڒَا ذ نشِّينْ أَذْ نِيڒِي أَمْ ڒڭْنُوسْ \add نّغْنِي\add* مَارَّا، أَجدْجِيذْ نّغْ أَذْ خَانغْ إِحْكمْ س ڒْحقّْ. نتَّا أَذْ يِيزْوَارْ زَّاثْ إِ وُوذمْ نّغْ ؤُشَا أَذْ إِسُّويُورْ إِمنْغَانْ نّغْ.“  
\v 21 \add ؤُمِي\add* إِسْڒَا شَامْوِيلْ إِ مَارَّا أَوَاڒنْ ن ڒْڭنْسْ، إِنَّا ثنْ ذڭْ إِمزُّوغنْ ن سِيذِي.  
\v 22 سِيذِي إِنَّا إِ شَامْوِيلْ: ”سڒْ غَارْسنْ، أڭّْ خَاسنْ إِجّْ ن ؤُجدْجِيذْ!“ \add خَاسْ ؤُشَا\add* إِنَّا شَامْوِيلْ إِ يرْيَازنْ ن إِسْرَائِيل: ”أجّْ أَذْ يُويُورْ كُوڒْ  إِجّْ غَارْ ثنْذِينْثْ نّسْ.“ \f ◼ \fr 8:‏22 \ft \+bd ’سڒْ غَارْسنْ‘\+bd* - س ثْعِيبْرَانِيثْ ’سڒْ غَارْ ثْمِيجَّا نْسنْ‘.\f*   
\b  
\b  
\m  
\c 9
\s1 شَاوُولْ يَارزُّو خْ إِغْيَاڒْ ؤُشَا إِمْسَاڭَارْ أَكْ-ذْ صَامْوِيلْ  
\m
\v 1 ثُوغَا \add ذِينْ\add* إِجّْ ن ورْيَازْ زِي بِينْيَامِينْ، قَّارنْ أَسْ قِيسْ، مِّيسْ ن أَبِييِيلْ، مِّيسْ ن صَارُورْ، مِّيسْ ن بَاكُورَاثْ، مِّيسْ ن أَفِييَاحْ، إِجّْ ن ورْيَازْ زڭْ أَيْثْ ن بِينْيَامِينْ، إِجّْ ن ورْيَازْ س وَاڭْڒَا أَطَّاسْ. \x ◘ \xo 9:‏1 \xt 1 صم. 14‏:‏51. \x*  
\v 2 نتَّا ثُوغَا غَارسْ إِجّْ ن مِّيسْ، قَّارنْ أَسْ شَاوُولْ. ثُوغَا-ث ذ أَمژْيَانْ ؤُ ذَايسْ أَژْرِي. ؤُڒَا ذ إِجّْ ن ورْيَازْ جَارْ أَيْثْ ن إِسْرَائِيل وَارْ ذَايسْ ثُوغِي أَژْرِي أَمْ نتَّا. نتَّا يُوجَارْ مَارَّا ڒْڭنْسْ س ثِيذِّي ن ؤُزدْجِيفْ.  
\v 3 ثُوغَا ثِيغْيَاڒْ ن قِيسْ، بَابَاسْ ن شَاوُولْ، ودَّارنْثْ. \add خنِّي\add* إِنَّا قِيسْ إِ مِّيسْ شَاوُولْ: ”كْسِي إِجّنْ زڭْ إِمْسخَّارنْ، أَوْيِي ث أَكِيذكْ ؤُشَا كَّارْ، أَرْزُو خْ ثغْيَاڒْ.“  
\v 4 نتَّا إِكَّا خْ إِذُورَارْ ن إِفْرَايِيمْ، إِكَّا خْ ثمُّورْثْ ن شَالِيشَا، \add مَاشَا\add* نِيثْنِي وَارْ ثنْثْ ؤُفِينْ. \add خَاسْ ؤُشَا\add* كِّينْ نِيثْنِي خْ ثمُّورْثْ ن شَاعَالِيمْ، وَارْ \add ثنْثْ\add* ؤُفِينْ \add ذِينِّي\add*. \add خنِّي\add* كِّينْ خْ ثمُّورْثْ ن بِينْيَامِينْ، وَارْ \add ثنْثْ\add* ؤُفِينْ ذِينِّي \add عَاوذْ\add*.  
\v 5 \add ؤُمِي\add* إِوْضنْ نِيثْنِي غَارْ ثمُّورْثْ ن صُوفْ، إِنَّا شَاوُولْ إِ ؤُمْسخَّارْ نّسْ نِّي ثُوغَا أَكِيذسْ: ”أَسْ-د، أَذْ نعْقبْ، نِيغْ بَابَا وَارْ إِكسِّي عَاذْ س ومْنُوسْ ذِي ثغْيَاڒْ، مَاشَا ذَايْنغْ.“  
\v 6 وَانِيثَا يَارَّا-د خَاسْ: ”خْزَارْ خنِّي، أَقَا إِجّْ ورْيَازْ ن أَربِّي إِزدّغْ ذِي ثنْذِينْثْ-أَ. أَقَا-ث ذ إِجّْ ن ورْيَازْ ذ أَمْشنّعْ. مَارَّا مِينْ إِقَّارْ، إِتّفّغْ-د نِيشَانْ. أجّْ أَنغْ أَذْ غَارسْ نْرَاحْ ذِينِّي، خنِّي أَذْ ثَاغْ أَذْ أَنغْ إِسّْشنْ أَبْرِيذْ إِ إِتّْخصَّا أَذْ ذَايسْ نُويُورْ.“  
\v 7 \add خنِّي\add* إِنَّا شَاوُولْ إِ ؤُمْسخَّارْ نّسْ: ”\add مَاشَا\add* خْزَارْ، مَاڒَا نْرَاحْ، مِينْ غَا نَاوِي \add خنِّي\add* إِ ورْيَازْ نِّي؟ مَاغَارْ أَغْرُومْ جَارْ ڒحْوَايجْ نّغْ إِرُوحْ. نشِّينْ وَارْ غَارْنغْ أَغِيرَالُوثْ إِ نْزمَّارْ أَذْ نوْشْ إِ ورْيَازْ ن أَربِّي. نِيغْ مِينْ غَارْنغْ \add نّغْنِي\add*؟“  
\v 8 يَارَّا-د ؤُمْسخَّارْ عَاوذْ خْ شَاوُولْ، إِنَّا: ”خْزَارْ، نشّْ غَارِي ذَا \add عَاذْ\add* إِجّْ ن أَرْبعْ ن إِجّْ ن شِيقْلُو ن نُّوقَارْثْ. أَذْ ث وْشغْ إِ ورْيَازْ ن أَربِّي، \add مَاحنْذْ\add* نتَّا أَذْ أَنغْ إِسّْشنْ أَبْرِيذْ.“  
\v 9 زِيشْ ثُوغَا إِقَّارْ ورْيَازْ ذِي إِسْرَائِيل، مَاڒَا ثُوغَا إِفّغْ حِيمَا أَذْ إِسّقْسَا أَربِّي: ”أَسمْ-د، أَذْ نُويُورْ غَارْ ؤُمْوَاڒَاوْ!“، مَاغَارْ أَنَابِي ن وَاسّْ-أَ، زِيشْ قَّارنْ أَسْ ’أَمْوَاڒَاوْ‘. \f ◼ \fr 9:‏9 \ft \+bd ’أَمْوَاڒَاوْ‘\+bd* - إِجّْ ن بْنَاذمْ ونِّي إِتّْوَاڒَانْ.\f*  \x ◘ \xo 9:‏9 \xt أَمز. 25‏:‏22. \x*  
\v 10 إِنَّا شَاوُولْ إِ ؤُمْسخَّارْ نّسْ: ”أَوَاڒْ نّشْ إِصْبحْ! أَسْ-د، أجّْ أَنغْ أَذْ نُويُورْ!“ ؤُشَا ؤُيُورنْ نِيثْنِي غَارْ ثنْذِينْثْ مَانِي \add إِدْجَا\add* أَرْيَازْ ن أَربِّي.   
\m
\v 11 \add ؤُمِي\add* ڭعّْذنْ نِيثْنِي ثْسَاونْثْ ن ثنْذِينْثْ مْسَاڭَارنْ أَكْ-ذ ثبْڒِيغِينْ ثِينِّي د-إِفّْغنْ مَاحنْذْ أَذْ أَيْمنْثْ أَمَانْ ؤُشَا نَّانْ أَسنْثْ: ”مَا أَمْوَاڒَاوْ ذَا؟“  
\v 12 نِيثنْثِي أَرِّينْثْ خَاسنْ، نَّانْثْ: ”خْزَارْ، نتَّا أَقَا-ث ذِيهَا غَارْ زَّاثْ. ذغْيَاثْ، مَاغَارْ نتَّا يُوسَا-د أَسّْ-أَ غَارْ ثنْذِينْثْ، مِينْزِي ڒْڭنْسْ أَسّْ-أَ أَذْ إِڭّْ إِشْثْ ن ثْغَارْصْثْ خْ ڒْڭعّْذثْ.  
\v 13 خْمِي غَا ثَاذْفمْ غَارْ ثَانْذِينْثْ، أَذْ ث ثَافمْ قْبڒْ مَا أَذْ إِڭعّذْ غَارْ ڒْڭعّْذثْ حِيمَا أَذْ إِمُونْ إِ مَاشَّا، مَاغَارْ ڒْڭنْسْ وَارْ إِتّتّْ مَاڒَا وَارْ د-يُوسِي نتَّا، مِينْزِي نتَّا أَذْ إِڭّْ لْبَارَاكَا ذِي ثْغَارْصْثْ، خنِّي عَاذْ أَذْ شّنْ إِنوْجِيونْ. ڭعّْذمْ ڒخُّو، مِينْزِي أَسّْ-أَ أَقَا-ث \add ذ لْفُورْصَا\add* أَذْ ث ثَافمْ \add نِيشَانْ\add*!“ \f ◼ \fr 9:‏13 \ft \+bd ’لْفُورْصَا‘\+bd* - نِيغْ ’أَڒَاقْ‘.\f*  
\v 14 نِيثْنِي ڭعّْذنْ غَارْ ثنْذِينْثْ ؤُشَا \add ؤُمِي\add* إِوْضنْ غَارْ ڒْوسْطْ ن ثنْذِينْثْ، خْزَارْ، إِفّغْ-د غَارْسنْ شَامْوِيلْ، إِمْسَاڭَارْ أَكِيذْسنْ مَاحنْذْ أَذْ إِڭُّورْ غَارْ ڒْڭعّْذثْ.   
\m
\v 15 \add مِينْزِي\add* إِجّْ ن وَاسّْ قْبڒْ إِ د-يُوسَا شَاوُولْ، إِسَّارْڭبْ سِيذِي إِ شَامْوِيلْ ذڭْ ؤُمزُّوغْ، إِنَّا: \x ◘ \xo 9:‏15 \xt 1 صم. 15‏:‏1. \x*  
\v 16 ”ثِيوشَّا أَمُّو ذِي ڒْوقْثْ-أَ، أَذْ غَاركْ سّكّغْ إِجّْ ن ورْيَازْ زِي ثمُّورْثْ ن بِينْيَامِينْ. أَذْ ث ثْذهْنذْ ذ ڒْحَاكمْ خْ ڒْڭنْسْ إِنُو إِسْرَائِيل. نتَّا أَذْ إِفكّْ ڒْڭنْسْ إِنُو زڭْ ؤُفُوسْ ن إِفِيلِيسْطِينِييّنْ، مَاغَارْ نشّْ ژْرِيغْ ڒْڭنْسْ إِنُو إِسْرَائِيل ؤُ ثْغُويِّيثْ نْسنْ إِ ؤُسْغَاثِي ثِيوضْ-د غَارِي.“   
\m
\v 17 \add ؤُمِي\add* شَامْوِيلْ إِژْرَا شَاوُولْ \add إِتَّاسْ-د\add*، يَارَّا-د خَاسْ سِيذِي: ”خْزَارْ، \add ذ وَا\add* ذ أَرْيَازْ إِ خْ إِ ذ أَشْ نِّيغْ: ’وَا أَذْ إِحْكمْ خْ ڒْڭنْسْ إِنُو.‘ “  
\v 18 يُويُورْ شَاوُولْ غَارْ شَامْوِيلْ ذِي ڒْوسْطْ ن ثوَّارْثْ ن ثنْذِينْثْ إِنَّا: ”سْشنْ أَيِي مَانِي ثدْجَا ثَادَّارْثْ ن ؤُمْوَاڒَاوْ.“  
\v 19 يَارَّا-د شَامْوِيلْ خْ شَاوُولْ، إِنَّا: ”نشّْ ذ أَمْوَاڒَاوْ. ؤُيُورْ غَارْ زَّاثْ إِ وُوذمْ إِنُو خْ ڒْڭعّْذثْ، حِيمَا كنِّيوْ أَذْ كِيذِي ثشّمْ أَسّْ-أَ. ثِيوشَّا زِيشْ أَذْ شكْ جّغْ أَذْ ثعْذُوذْ ؤُ نشّْ أَذْ شكْ سَّارْڭْبغْ خْ مَارَّا مِينْ \add إِدْجَانْ\add* ذڭْ وُوڒْ نّشْ.  
\v 20 خْ ثغْيَاڒْ إِ ذ أَشْ إِودَّارنْ أَسّْ-أَ عَاذْ ثْڒَاثَا ن وُوسَّانْ زڭْ وَامِي، وَارْ ذَايكْ إِتِّيڒِي بُو ومْنُوسْ، مَاغَارْ تّْوَافنْثْ نِيثنْثِي. \add مَاشَا\add* وِي غَارْ إِتّْرَاحْ مَارَّا مژْرِي ن إِسْرَائِيل؟ مَا وَارْ إِدْجِي غَاركْ ؤُ غَارْ مَارَّا ثَادَّارْثْ ن بَابَاشْ؟“  
\v 21 \add خنِّي\add* يَارَّا-د شَاوُولْ، إِنَّا: ”مَا وَارْ دْجِيغْ نشّْ زڭْ أَيْثْ ن بِينْيَامِينْ، زِي ثْمژْيَانْثْ قَاعْ ن ثْقبَّاڒْ ن إِسْرَائِيل؟ مَا وَارْ ثدْجِي ڒَادْجْ إِنُو ثَامُوقْڒِيڒْثْ قَاعْ زِي مَارَّا ڒَادْجَاثْ ن ثقْبِيتْشْ ن بِينْيَامِينْ؟ مَايمِّي كِيذِي ثسَّاوَاڒذْ أَوَاڒنْ أَمْ إِنَا؟“  
\v 22 شَامْوِيلْ إِكْسِي شَاوُولْ ذ ؤُمْسخَّارْ نّسْ أَكِيذسْ، إِسِّيذفْ إِ-ثنْ ذڭْ وخَّامْ \add ن أَرْوَا\add*، إِسّْغِيمْ إِ-ثنْ ذڭْ ومْشَانْ أَمزْوَارُو جَارْ إِنوْجِيونْ. ثُوغَا \add نّْيَارْونْ\add* أَمنِّي ثْڒَاثِينْ ن يرْيَازنْ.   
\m
\v 23 \add خنِّي\add* إِنَّا شَامْوِيلْ إِ ؤُڭزَّارْ: ”أَوِي-د \add ڒخُّو\add* ثَاسْغَارْثْ إِ ذ أَشْ وْشِيغْ، ثنِّي خْ ذ أَشْ نِّيغْ: ’أجّْ إِ-ت غَاركْ!‘ “  
\v 24 ذ أَڭزَّارْ إِسّْڭعّذْ ثَاغْرُوضْثْ أَكْ-ذ مَارَّا مِينْ خَاسْ \add إِدْجَانْ\add*، إِسَّارْسْ إِ-ت زَّاثْ إِ شَاوُولْ، إِنَّا: ”خْزَارْ، أَيَا مِينْ إِشطّنْ. أڭّْ إِ-ت زَّاثكْ أَذْ ثشّذْ، مِينْزِي إِتّْوَاحْضَا إِ ثْسَاعّثْ-أَ، ؤُمِي نِّيغْ: ’نشّْ عَارْضغْ خْ ڒْڭنْسْ.‘ “ ؤُشَا إِشَّا شَاوُولْ أَكْ-ذ شَامْوِيلْ ذڭْ وَاسّْ نِّي.  
\v 25 \add خنِّي\add* هْوَانْ-د نِيثْنِي زِي ڒْڭعّْذثْ غَارْ ثنْذِينْثْ ؤُ نتَّا إِسِّيوڒْ أَكْ-ذ شَاوُولْ خْ ثْزقَّا.   
\m
\v 26 كَّارنْ زِيشْ، ؤُشَا إِمْسَارْ، غَارْ ڒفْجَارْ ن وَاسّْ، أَقَا إِڒَاغَا-د شَامْوِيلْ خْ شَاوُولْ \add إِ ثُوغَا إِدْجَانْ\add* خْ ثْزقَّا، إِنَّا: ”كَّارْ، نشّْ خْسغْ أَذْ شكْ سّْقبّْضغْ!“ \add خنِّي\add* إِكَّارْ شَاوُولْ ؤُشَا فّْغنْ س ثْنَاينْ إِذْسنْ غَارْ بَارَّا، نتَّا أَكْ-ذ شَامْوِيلْ.  
\v 27 ؤُمِي د-هْوَانْ نِيثْنِي أَڒْ طَّارْفْ ن ثنْذِينْثْ، إِنَّا شَامْوِيلْ إِ شَاوُولْ: ”إِنِي إِ ؤُمْسخَّارْ أَذْ إِبعّذْ زَّاثْ إِ وُوذمْ نّغْ!“ \add خنِّي\add* إِڭّْوجْ نتَّا. \add إِنَّا شَامْوِيلْ\add*: ”قِّيمْ ڒخُّو، بدّْ ذَا ؤُ نشّْ أَذْ أَشْ إِنِيغْ أَوَاڒْ ن أَربِّي.“   
\b  
\b  
\m  
\c 10
\s1 إِتّْوَاذْهنْ شَاوُولْ ذ أَجدْجِيذْ  
\m
\v 1 \add خَاسْ ؤُشَا\add* إِكْسِي شَامْوِيلْ ثَازِييَّاثْ ن زّشْثْ، إِسيّبْ \add إِ-ت\add* خْ ؤُزدْجِيفْ نّسْ، إِسُّوذمْ إِ-ث، إِنَّا: ”مَا \add خنِّي\add* سِيذِي وَارْ شكْ إِذْهِينْ ذ ڒْحَاكمْ خْ ڒْوَارْثْ نّسْ؟ \x ◘ \xo 10:‏1 \xt ڒخ. 13‏:‏21. \x*  
\v 2 خْمِي خَافِي إِ غَا ثُويُورذْ أَسّْ-أَ، أَذْ ثَافذْ ثْنَاينْ ن يرْيَازنْ غَارْ ونْضڒْ ن رَاحِيلْ ذِي صَالْصَاحْ ذِي ثمُّورْثْ ن بِينْيَامِينْ، نِيثْنِي أَذْ أَشْ إِنِينْ: ’ثِيغْيَاڒْ إِ خْ ثُوغَا ثَارزُّوذْ، تّْوَافنْثْ ؤُشَا بَابَاشْ إِسْمحْ ذِي ثْمسْڒَاشْثْ ن ثغْيَاڒْ، مَاشَا نتَّا ذَايسْ \add ڒخُّو\add* أَمْنُوسْ خَاومْ، إِقَّارْ: مِينْ غَا ڭّغْ خْ مِّي؟‘ “  
\v 3 سّنِّي أَذْ ثَارْنِيذْ أَذْ ثُويُورذْ ؤُشَا أَذْ ثَاوْضذْ غَارْ ثْشجَّارْثْ ن يِيڭّْ ن ثابُورْ. ذِينِّي إِ غَا ثمّڒْقِيذْ أَكْ-ذ ثْڒَاثَا ن يرْيَازنْ نِّي إِتّْڭعَّاذنْ غَارْ سِيذِي غَارْ بَايْثْ-إِلْ. إِجّنْ أَذْ يَارْبُو ثْڒَاثَا ن إِغَايْضنْ إِمژْيَاننْ، إِجّنْ أَذْ يَارْبُو ثْڒَاثَا ن ثشْنِيفِينْ ؤُ إِجّنْ أَذْ يَارْبُو إِشْثْ ن ثْخَانْشثْ ن بِينُو.  
\v 4 نِيثْنِي أَذْ سّقْسَانْ خْ  ؤُمدُّورْ نّشْ ؤُشَا أَذْ أَشْ وْشنْ ثْنَاينْ ن ثشْنِيفِينْ إِ غَا ثطّْفذْ زڭْ ؤُفُوسْ نْسنْ. \x ◘ \xo 10:‏4 \xt ڒقض. 18‏:‏15. \x*  
\v 5 أَوَارْنِي أَسْ أَذْ د-ثَاسذْ غَارْ \add ثنْذِينْثْ ن\add* جِيبْعَا ن أَربِّي مَانِي بدّنْثْ ثشْبَارِينْ ن ثْعسَّاسْثْ ن إِفِيلِيسْطِينِييّنْ. خْمِي ذِينِّي إِ غَا ثَاوْضذْ غَارْ ثنْذِينْثْ، أَذْ إِمْسَارْ أَذْ ثمّڒْقِيذْ أَكْ-ذ إِشْثْ ن كُولَا ن إِنَابِييّنْ، إِنِّي د-إِهْوَانْ زِي ڒْڭعّْذثْ، ؤُشَا زَّاثْسنْ لهَارْپَا ذ ؤُبنْذِيرْ ذ ثْژَامَارْثْ ذ ڒْڭَامْبْرِي أَمْ تّْنبَّانْ نِيثْنِي. \x ◘ \xo 10:‏5 \xt 1 إِم. 16‏:‏39؛ ڒخْڒ. 11‏:‏25\x*  
\v 6 أَذْ خَاكْ د-إِهْوَا أَرُّوحْ ن سِيذِي ؤُ شكْ أَذْ ثْنبَّاذْ أَكِيذْسنْ ؤُشَا أَذْ ثْذوْڒذْ ذ إِجّْ ن بْنَاذمْ نّغْنِي.  
\v 7 أَذْ إِمْسَارْ خْمِي غَاركْ إِ د غَا يَاسنْ ڒعْڒَامَاثْ-أَ، أَقَا أَذْ خَاكْ يِيڒِي حِيمَا أَذْ ثڭّذْ مِينْ غَا يَافْ ؤُفُوسْ نّشْ، مِينْزِي أَربِّي أَقَا-ث أَكِيذكْ.  
\v 8 أَذْ أَيِي ثِيزْوَارذْ أَذْ د-ثهْوِيذْ غَارْ جِيلْجَالْ، ؤُ خْزَارْ، نشّْ أَذْ د-هْوِيغْ غَاركْ حِيمَا أَذْ ذِينْ سّْڭعّْذغْ ثِيغَارْصَا ن وشْمَاضْ \add ذ\add* ثْغَارْصَا ن ڒهْنَا. سبْعَا ن وُوسَّانْ إِ ذِينْ إِ غَا ثْرَاجِيذْ أَڒْ د غَاركْ إِ غَا يَاسغْ، أَذْ أَشْ د-بَارّْحغْ مِينْ غَا ثڭّذْ.“ \x ◘ \xo 10:‏8 \xt 1 صم. 13‏:‏8. \x*   
\m
\v 9 ؤُمِي إِسّْنقْڒبْ أَعْرُورْ نّسْ حِيمَا أَذْ يُويُورْ خْ شَامْوِيلْ، إِمْسَارْ أَقَا أَربِّي إِبدّڒْ ؤُڒْ \add نّسْ\add* ذڭْ إِجّْ ن \add وُوڒْ\add* نّغْنِي. مَارَّا ڒعْڒَامَاثْ-أَ إِمْسَارنْ ذڭْ وَاسّْ نِّي \add سِيمَانْثْ نّسْ\add*.  
\v 10 \add ؤُمِي\add* إِوْضنْ نِيثْنِي غَارْ جِيبْعَا، أَقَا إِڒْقَا إِ-ث إِجّْ ن كُولَا ن إِنَابِييّنْ ؤُشَا أَرُّوحْ ن أَربِّي إِهْوَا-د خَاسْ ؤُشَا نتَّا إِنبَّا ذِي ڒْوسْطْ نْسنْ. \x ◘ \xo 10:‏10 \xt 1 صم. 19‏:‏19. \x*  
\v 11 ؤُشَا إِمْسَارْ، أَقَا مَارَّا إِنِّي ثُوغَا ث إِسّْننْ إِضنَّاضْ ذ فَارِيضنَّاضْ، ژْرِينْ مَامّشْ ثُوغَا إِتّْنبَّا أَكْ-ذ إِنَابِييّنْ، ؤُشَا ڒْڭنْسْ إِنَّا جَارْ أَسنْ: ”مِينْ يُوغِينْ مِّيسْ ن قِيشْ؟ مَا ؤُڒَا ذ شَاوُولْ جَارْ إِنَابِييّنْ؟“  
\v 12 إِجّْ ن ورْيَازْ سّنِّي يَارَّا-د، إِنَّا: ”مَانْ ونْ إِدْجَانْ ذ بَابَاثْسنْ؟“ أَمُّو إِ إِقِّيمْ وَاوَاڒْ-أَ إِتّْوَاسّْننْ: ”مَا ؤُڒَا ذ شَاوُولْ جَارْ إِنَابِييّنْ؟“ \x ◘ \xo 10:‏12 \xt ڭال. 1‏:‏24؛ 1 صم. 19‏:‏25\x*  
\v 13 ؤُمِي إِسّْبدّْ إِتّْنبَّا، يُوسَا-د غَارْ ڒْڭعّْذثْ.  
\v 14 عمِّيسْ ن شَاوُولْ إِنَّا أَسْ ؤُ إِ ؤُمْسخَّارْ نّسْ: ”مَانِي ثُوغَا ثتّْرَاهمْ كنِّيوْ؟“ نتَّا يَارَّا-د خَاسْ: ”نَارزُّو خْ ثغْيَاڒْ، \add مَاشَا ؤُمِي\add* نژْرَا، أَقَا نِيثنْثِي وَارْ ذِينِّي دْجِينْثْ، نِيوضْ غَارْ شَامْوِيلْ.“  
\v 15 \add خنِّي\add* إِنَّاعمِّيسْ ن شَاوُولْ: ”إِنِي أَيِي، عَافَاكْ، مِينْ ذ أَومْ إِنَّا شَامْوِيلْ؟“  
\v 16 شَاوُولْ يَارَّا-د خْعمِّيسْ: ”نتَّا إِنَّا أَنغْ نِيشَانْ، أَقَا ثِيغْيَاڒْ تّْوَافنْثْ.“ ثَامسْڒَاشْثْ ن ثْڭلْذَا مَاشَا إِ خْ ثُوغَا إِسِّيوڒْ شَامْوِيلْ، وَارْ ذ أَسْ ت إِعِيوذْ شَا.   
\m
\v 17 شَامْوِيلْ إِڒَاغَا-د إِ ڒْڭنْسْ غَارْ سِيذِي ذِي مِيصْفَا.  
\v 18 نتَّا إِنَّا إِ أَيْثْ ن إِسْرَائِيل: ”أَمُّو إِ إِقَّارْ سِيذِي، أَربِّي ن إِسْرَائِيل: ’نشّْ سُّوفّْغغْ-د إِسْرَائِيل زِي مِيصْرَا ؤُ فكّغْ كنِّيوْ زڭْ ؤُفُوسْ ن إِمِيصْرِييّنْ ؤُ زڭْ ؤُفُوسْ ن مَارَّا ثِيڭلْذِيوِينْ نِّي كنِّيوْ إِحْصَارنْ.  
\v 19 \add مَاشَا\add* أَسّْ-أَ كنِّيوْ ثنْضَارمْ سِيذِي نْومْ، ونِّي ثُوغَا كنِّيوْ إِفكّنْ زِي مَارَّا زّْعَافْ نْومْ ؤُ زِي مَارَّا ڒحْصَارَاثْ نْومْ. كنِّيوْ ثنَّامْ أَسْ: أڭّْ إِجّْ ن ؤُجدْجِيذْ خَانغْ! \add خنِّي\add* ڒخُّو، بدّمْ زَّاثْ إِ وُوذمْ ن سِيذِي، عْلَاحْسَابْ ثِيقبَّاڒْ نْومْ ذ ڒُوڒُوفْ نْومْ!‘ “ \x ◘ \xo 10:‏19 \xt 1 صم. 8‏:‏7؛ 1 صم. 8‏:‏19؛ 12‏:‏12. \x*  
\v 20 شَامْوِيلْ إِجَّا مَارَّا ثِيقبَّاڒْ ن إِسْرَائِيل أَذْ د-قَارّْبنْثْ ؤُشَا ثَاقْبِيتْشْ ن بِينْيَامِينْ ثتّْوَاكّسْ \add زَّايْسنْثْ\add* \x ◘ \xo 10:‏20 \xt ياش. 7‏:‏14\x*  
\v 21 \add خَاسْ ؤُشَا\add* إِجَّا ثَاقْبِيتْشْ ن بِينْيَامِينْ أَذْ ثْقَارّبْ، عْلَاحْسَابْ ڒَادْجَاثْ نّسْ، ؤُشَا إِتّْوَاكّسْ \add زَّايسْ\add* ڒَادْجْ ن مَاثْرِي ؤُ خنِّي إِتّْوَاكّسْ \add زَّايسْ\add* شَاوُولْ، مِّيسْ ن قِيشْ. أَرْزُونْ خَاسْ، \add مَاشَا\add* وَارْ زمَّارنْ أَذْ ث أَفنْ.  
\v 22 نِيثْنِي سّقْسَانْ سِيذِي إِشْثْ ن ثْوَاڒَا نّغْنِيثْ: ”مَا نِيشَانْ يُوسَا-د ورْيَازْ نِّي ذَانِيثَا؟“ سِيذِي يَارَّا-د: ”خْزَارْ، نتَّا إِفَّارْ جَارْ ڒحْوَايجْ.“  
\v 23 نِيثْنِي ؤُزّْڒنْ \add ذِينْ\add*، إِوْينْ ث-إِ-د سّنِّي. \add ؤُمِي\add* د-يُوسَا نتَّا إِبدّْ جَارْ ڒْڭنْسْ، يُوجَارْ نتَّا مَارَّا ڒْڭنْسْ س ثِيذِّي ن ؤُزدْجِيفْ. \x ◘ \xo 10:‏23 \xt 1 صم. 9‏:‏2\x*  
\v 24 إِنَّا شَامْوِيلْ إِ مَارَّا ڒْڭنْسْ: ”مَا ثژْرِيمْ \add ڒخُّو\add* مَانْ ونْ إِفَارْزْ سِيذِي؟ ؤُڒَا ذ إِجّنْ زِي ڒْڭنْسْ وَارْ ذَايسْ يَارْوِيسْ.“ ؤُشَا إِسْڒِيوْڒوْ مَارَّا ڒْڭنْسْ، نِيثْنِي نَّانْ: ”ثُوذَارْثْ إِ ؤُجدْجِيذْ!“   
\m
\v 25 شَامْوِيلْ إِسّْشنْ إِ ڒْڭنْسْ ڒْحقّْ ن ثْڭلْذَا، يُورَا إِ-ث ذڭْ إِجّْ ن وذْلِيسْ ؤُشَا إِسَّارْسْ إِ-ث زَّاثْ إِ وُوذمْ ن سِيذِي. \add خنِّي\add* يَارْخُو شَامْوِيلْ إِ مَارَّا ڒْڭنْسْ، كُوڒْ إِجّْ يُويُورْ غَارْ ثَادَّارْثْ نّسْ.  
\v 26 ؤُڒَا ذ شَاوُولْ يُويُورْ غَارْ ثَادَّارْثْ نّسْ غَارْ جِيبْعَا ؤُشَا إِرُوحْ أَكِيذسْ \add وزْينْ ن\add* ڒْعسْكَارْ نِّي ثُوغَا إِحَاذَا سِيذِي ؤُڒْ نْسنْ. \x ◘ \xo 10:‏26 \xt 1 صم. 13‏:‏2. \x*  
\v 27 \add مَاشَا\add* أَيْثْ إِ وَارْ إِسكّْوِينْ نَّانْ: ”مَامّشْ إِ ذ أَنغْ غَا إِفكّْ ورْيَازْ-أَ؟“ ؤُ نِيثْنِي سّحْقَارنْ ث ؤُ وَارْ ذ أَسْ د-إِوْينْ شَا ثَارْزفْثْ، \add مَاشَا\add* نتَّا إِڭَّا أَخْمِي وَارْ إِتّسْڒِي. \x ◘ \xo 10:‏27 \xt 1 صم. 11‏:‏12؛ 2 إِم. 17‏:‏5. \x*   
\b  
\b  
\m  
\c 11
\s1 شَاوُولْ إِفكّْ ثَانْذِينْثْ ن يَابِيشْ ذِي جِيلْعَاذْ  
\m
\v 1 \add خنِّي\add* إِفّغْ-د نَاحَاشْ، أَعَامُّونِي، ؤُشَا إِنّضْ \add س ڒْعسْكَارْ نّسْ\add* إِ \add ثنْذِينْثْ ن\add* يَابِيشْ ذِي جِيلْعَاذْ. مَارَّا إِرْيَازنْ ن يَابِيشْ نَّانْ إِ نَاحَاشْ: ”أڭّْ إِجّْ ن ڒْعَاهْذْ أَكِيذْنغْ ؤُشَا خنِّي أَذْ أَشْ نْسخَّارْ.“ \f ◼ \fr 11:‏1 \ft \+bd ’أَعَامُّونِي‘\+bd* - إِجّنْ زِي ڒْڭنْسْ ن عَامُّونْ نِيغْ زِي أَيْثْ ن عَامُّونْ.\f*  
\v 2 إِنَّا أَسنْ أَعَامُّونِي نَاحَاشْ: ”خْ وبْرِيذْ-أَ نشّْ أَكِيذْومْ ڭّغْ ڒْعَاهْذْ، نشّْ أَذْ أَومْ د-قڒْعغْ مَارَّا ثِيطّْ ثَافُوسشْثْ، أَذْ ت ڭّغْ ذ ڒفْضِيحثْ خْ مَارَّا إِسْرَائِيل.“  
\v 3 إِمْغَارنْ ن يَابِيشْ نَّانْ: ”أجّْ أَنغْ سبْعَا ن وُوسَّانْ، حِيمَا أَذْ د-نسّكّْ إِرقَّاسنْ غَارْ مَارَّا ثَامُّورْثْ ن إِسْرَائِيل. مَاڒَا وَارْ نُوفِي ؤُڒَا ذ إِجّْ إِ ذ أَنغْ غَا إِسّْنجْمنْ، \add خنِّي\add* أَذْ غَاركْ د-نفّغْ.“   
\m
\v 4 \add ؤُمِي\add* د-إِوْضنْ إِرقَّاسنْ غَارْ جِيبْعَا ن شَاوُولْ، سِّيوْضنْ-د نِيثْنِي أَوَاڒنْ-أَ غَارْ إِمزُّوغنْ ن ڒْڭنْسْ ؤُ مَارَّا ڒْڭنْسْ إِسّْڭعّذْ ثْمِيجَّا نّسْ، رُونْ.  
\v 5 ؤُ خْزَارْ، شَاوُولْ يُوسَا-د أَوَارْنِي إِ إِفُونَاسنْ نّسْ زڭْ إِيَّارْ، إِنَّا: ”مِينْ يُوغِينْ ڒْڭنْسْ إِتّْرُو أَمُّو؟“ نِيثْنِي حَاجَانْ أَسْ أَوَاڒنْ ن يرْيَازنْ ن يَابِيشْ.  
\v 6 إِهْوَا-د أَرُّوحْ ن أَربِّي خْ شَاوُولْ ؤُمِي إِسْڒَا أَوَاڒنْ-أَ ؤُشَا يَارْغَا ؤُخيّقْ نّسْ أَطَّاسْ.  
\v 7 نتَّا إِكْسِي إِجّْ ن ؤُزَايْڒُو ن إِفُونَاسنْ، إِقطّسْ إِ-ثنْ ذ إِشدْجِيقنْ، إِسّكّْ إِشدْجِيقنْ س ؤُفُوسْ ن إِرقَّاسنْ غَارْ مَارَّا ثَامُّورْثْ ن إِسْرَائِيل. إِرقَّاسنْ نَّانْ: ”ونِّي وَارْ إِفِّيغنْ أَوَارْنِي إِ شَاوُولْ ؤُ أَوَارْنِي شَامْوِيلْ \add غَارْ ؤُمنْغِي\add*، خْزَارْ، أَمُّو إِ غَا إِتّْوَاڭّْ أَكْ-ذ إِفُونَاسنْ ذ ثْفُونَاسِينْ نّسْ.“ \add خنِّي\add* ثوْضَا-د ثِيڭّْوُوذِي ن سِيذِي خْ مَارَّا ڒْڭنْسْ ؤُشَا فّْغنْ مُوننْ أَمْ يِيجّْ ن ورْيَازْ. \x ◘ \xo 11:‏7 \xt ڒقض. 20‏:‏1. \x*  
\v 8 إِسدّْ إِ-ثنْ شَاوُولْ ذِي بَازَاقْ. ثُوغَا-ثنْ ذِي ثڒْثْ-مْيَا-أَڒفْ زڭْ أَيْثْ ن إِسْرَائِيل ؤُ ثْڒَاثِينْ-أَڒفْ ن يرْيَازنْ زِي يَاهُوذَا.  
\v 9 نِيثْنِي نَّانْ إِ إِرقَّاسنْ نِّي ثُوغَا د-يُوسِينْ: ”أَمُّو إِ غَا ثِينِيمْ إِ يرْيَازنْ ن يَابِيشْ ذِي جِيلْعَاذْ: ’ثِيوشَّا، خْمِي غَا ثِيڒِي ثْفُوشْثْ ثَاڒْغَا، أَذْ ثتّْوَاسّْنجْممْ.‘ “ \add ؤُمِي\add* إِوْضنْ إِرقَّاسنْ، عَاوْذنْ ت إِ يرْيَازنْ ن يَابِيشْ ؤُشَا فَارْحنْ نِيثْنِي.  
\v 10 نَّانْ يرْيَازنْ ن يَابِيشْ: ”ثِيوشَّا أَذْ غَاركْ د-نفّغْ ؤُشَا \add خنِّي\add* ثْزمَّارمْ أَكِيذْنغْ ثتّڭّمْ مِينْ ثتّْوَاڒَامْ كنِّيوْ مْلِيحْ ذِي ثِيطَّاوِينْ نْومْ.“   
\m
\v 11 ثِيوشَّا نّسْ إِمْسَارْ، أَقَا شَاوُولْ إِبْضَا ڒْڭنْسْ خْ ثْڒَاثَا ن إِبَاطَايُوننْ ؤُ غَارْ ثُوفُّوثْ ن صّْبحْ ؤُذْفنْ نِيثْنِي غَارْ ڒْمَارْڭحْ ن ڒْعسْكَارْ، ؤُشَا وْثِينْ أَيْثْ ن عَامُّونْ غَارْ طّْحَا ن ؤُزِيڒْ. إِنِّي إِقِّيمنْ إِدَّارنْ تّْوَابزّْعنْ أَڒَامِي وَارْ إِقِّيمْ ؤُڒَا ذ ثْيُويَا زَّايْسنْ أَكْ-ذ وَايَاوْيَا.   
\m
\v 12 \add خنِّي\add* إِنَّا ڒْڭنْسْ إِ شَامْوِيلْ: ”مَانْ ونْ إِ إِنَّانْ: ’مَا شَاوُولْ أَذْ خَانغْ يِيڒِي ذ أَجدْجِيذْ؟‘ أَوْيِي ثنْ-د ذَانِيثَا، حِيمَا أَذْ ثنْ ننغْ.“ \x ◘ \xo 11:‏12 \xt 1 صم. 10‏:‏27. \x*  
\v 13 \add مَاشَا\add* شَاوُولْ إِنَّا: ”ذڭْ وَاسّْ-أَ ؤُڒَا ذ إِجّنْ وَارْ إِتّْوَانغْ، مَاغَارْ أَسّْ-أَ سِيذِي إِسِّيوضْ-د أَسنْجمْ غَارْ إِسْرَائِيل.“   
\m
\v 14 إِنَّا شَامْوِيلْ إِ ڒْڭنْسْ: ”أجّْ أَنغْ أَذْ نُويُورْ غَارْ جِيلْجَالْ، أَذْ ذِينِّي نْڒقّحْ ثَاڭلْذَا.“  
\v 15 \add خنِّي\add* يُويُورْ مَارَّا ڒْڭنْسْ غَارْ جِيلْجَالْ ؤُ نِيثْنِي ڭِّينْ ذِينِّي ذِي جِيلْجَالْ شَاوُولْ ذ أَجدْجِيذْ زَّاثْ إِ وُوذمْ ن سِيذِي. غَارْصنْ ثِيغَارْصَا ن ڒهْنَا زَّاثْ إِ وُوذمْ ن سِيذِي ؤُشَا إِفَارْحْ شَاوُولْ أَطَّاسْ أَكْ-ذ مَارَّا إِرْيَازنْ ن إِسْرَائِيل.   
\b  
\b  
\m  
\c 12
\s1 أَوَاڒْ أَنڭَّارُو ن صَامْوِيلْ إِ ڒْڭنْسْ  
\m
\v 1 \add خنِّي\add* إِنَّا شَامْوِيلْ إِ مَارَّا إِسْرَائِيل: ”خْزَارْ، نشّْ سْڒِيغْ غَارْومْ ذِي مَارَّا مِينْ إِ ذ أَيِي ثنَّامْ ؤُ نشّْ ڭِّيغْ إِجّْ ن ؤُجدْجِيذْ خَاومْ. \f ◼ \fr 12:‏1 \ft \+bd ’سْڒِيغْ غَارْومْ‘\+bd* - س ثْعِيبْرَانِيثْ ’سْڒِيغْ غَارْ ثْمِيجَّا نْومْ‘.\f*  
\v 2 ؤُشَا ڒخُّو، خْزَارْ، أَجدْجِيذْ إِرُوحْ زَّاثْ إِ وُوذمْ نْومْ. نشّْ وْسَارغْ، ذوْڒغْ شَابغْ، ؤُ خْزَارْ، أَرَّاوْ إِنُو أَقَا أَثنْ جَارْ أَومْ. زِي ثمْژِي إِنُو أَڒْ أَسّْ-أَ نشّْ ڭُّورغْ \add أَمْ ؤُكهَّانْ\add* زَّاثْ إِ وُوذمْ نْومْ.  
\v 3 أَقَا أَيِي نشّْ \add ذَا\add*. شهْذمْ خَافِي زَّاثْ إِ سِيذِي ؤُ زَّاثْ إِ لْمَاسِيحْ نّسْ. إِ ؤُمِي إِوْيغْ شَا ن ؤُفُونَاسْ؟ إِ ؤُمِي إِوْيغْ إِجّْ ن وغْيُوڒْ؟ مَانْ ونْ إِ حْصَارغْ ؤُ مَانْ ونْ إِغزِّيغْ ؤُ زِي مَانْ ونْ إِ طّْفغْ إِشْثْ ن ثرْزفْثْ مَاحنْذْ أَذْ قّْنغْ ثِيطَّاوِينْ إِنُو؟ نشّْ أَذْ أَومْ ث أَرّغْ.“  
\v 4 نِيثْنِي أَرِّينْ-د خَاسْ: ”شكْ وَارْ ذ أَنغْ ثحْصَارذْ شَا ؤُ وَارْ ذ أَنغْ ثْغزِّيذْ ؤُ وَارْ ثطِّيفذْ ؤُڒَا ذ إِشْثْ ن ڒْحَاجّثْ زِي شَا ن يِيجّنْ.“  
\v 5 \add خنِّي\add* إِنَّا أَسنْ: ”سِيذِي ذ أَشهَّاذْ خَاومْ ؤُ لْمَاسِيحْ نّسْ ذ أَشهَّاذْ أَسّْ-أَ، أَقَا كنِّيوْ وَارْ ثُوفِيمْ ؤُڒَا ذ إِشْثْ ن ڒْحَاجّثْ ذڭْ ؤُفُوسْ إِنُو!“ إِنَّا ڒْڭنْسْ: ”أَقَا-ث ذ أَشهَّاذْ!“   
\m
\v 6 إِنَّا شَامْوِيلْ إِ ڒْڭنْسْ: ”ذ سِيذِي إِ ثُوغَا إِڭِّينْ مُوسَا ذ هَارُونْ ؤُ نتَّا ذ ونِّي إِ د-إِسُّوفّْغنْ ڒجْذُوذْ نْومْ زِي مِيصْرَا.  
\v 7 خنِّي ڒخُّو، بدّمْ-د غَارِي، مَاحنْذْ أَذْ أَومْ سّشْنغْ ڒْحقّْ زَّاثْ إِ وُوذمْ ن سِيذِي، مَارَّا ثِيمڭَّا إِسڭّْذنْ ن سِيذِي ثِينِّي إِڭَّا إِ كنِّيوْ ؤُ إِ ڒجْذُوذْ نْومْ.  
\v 8 ؤُمِي د-يُوسَا يَاعْقُوبْ غَارْ مِيصْرَا، سْغُوينْ ڒجْذُوذْ نْومْ غَارْ سِيذِي ؤُ سِيذِي إِسّكّْ-د مُوسَا ذ هَارُونْ، ؤُشَا نِيثْنِي سُّوفّْغنْ-د ڒجْذُوذْ نْومْ زِي مِيصْرَا ؤُ سّْزذْغنْ ثنْ ذڭْ ومْشَانْ-أَ. \x ◘ \xo 12:‏8 \xt أَمز. 46‏:‏5؛ ؤُف. 2‏:‏23؛ ؤُف. 3‏:‏10. \x*  
\v 9 \add مَاشَا\add* نِيثْنِي تُّونْ سِيذِي، أَربِّي نْسنْ. \add خنِّي\add* نتَّا إِزّنْزْ إِ-ثنْ إِ سِيسَارَا، أَكُومَانْذَارْ ن ڒْعسْكَارْ، ذِي حَاصُورْ، ؤُ إِ إِفِيلِيسْطِينِييّنْ ؤُ إِ ؤُجدْجِيذْ ن أَيْثْ ن مُوآبَ. مَارَّا نِيثْنِي ثُوغَا مّنْغنْ أَكِيذْسنْ. \x ◘ \xo 12:‏9 \xt ڒقض. 4‏:‏2؛ ڒقض. 10‏:‏7؛ ڒقض. 3‏:‏12. \x*  
\v 10 ؤُشَا سْغُوينْ نِيثْنِي غَارْ سِيذِي، نَّانْ: ’نشِّينْ نخْضَا، مَاغَارْ نشِّينْ نسْمحْ ذِي سِيذِي، نْسخَّارْ إِ ’إِبَاعْلنْ‘ ذ ’عَاشْثَارُوثِينْ‘. ؤُ ڒخُّو، فكّْ أَنغْ زڭْ ؤُفُوسْ ن ڒْعذْيَانْ نّغْ ؤُشَا نشِّينْ أَذْ شكْ نْسخَّارْ.‘   
\m
\v 11 \add خَاسْ ؤُشَا\add* إِسّكّْ-د سِيذِي يَارُوبَّاعْلْ ذ بَاذَانْ ذ يَافْثَاحْ ذ شَامْوِيلْ ؤُ نتَّا إِفكّْ كنِّيوْ زڭْ ؤُفُوسْ ن ڒْعذْيَانْ نْومْ إِ ذ أَومْ د-إِنّْضنْ، \add أَڒَامِي\add* ثْزدّْغمْ كنِّيوْ ذِي ڒَامَانْ. \x ◘ \xo 12:‏11 \xt ڒقض. 6‏:‏14؛ 10‏:‏3؛ 11‏:‏15. \x*  
\v 12 \add ؤُمِي\add* ثژْرِيمْ كنِّيوْ أَقَا نَاحَاشْ، أَجدْجِيذْ ن أَيْثْ ن عَامُّونْ، إِفّغْ-د غَارْومْ، ثنِّيمْ أَيِي: ’لَّ، إِتّْخصَّا أَذْ خَانغْ يِيڒِي إِجّْ ن ؤُجدْجِيذْ!‘، وَاخَّا سِيذِي، أَربِّي نْومْ، ذ أَجدْجِيذْ نْومْ. \x ◘ \xo 12:‏12 \xt 1 صم. 8‏:‏5، 19. \x*  
\v 13 ڒخُّو، خْزَارْ، أَقَا أَجدْجِيذْ نْومْ، ونِّي إِ ثِيخْضَارمْ، ونِّي ثُوغَا ثتّْرَاجَامْ. أَقَا سِيذِي إِڭَّا إِ-ث ذ أَجدْجِيذْ خَاومْ. \x ◘ \xo 12:‏13 \xt 1 صم. 10‏:‏19. \x*  
\v 14 مَاڒَا كنِّيوْ ثتّڭّْوذمْ سِيذِي، أَذْ أَسْ ثْسخَّارمْ ؤُ أَذْ ثسْڒَامْ إِ ثْمِيجَّا نّسْ، ؤُ وَارْ تّْغوّْغمْ خْ \add مِينْ د-إِفّْغنْ\add* زڭْ ؤُقمُّومْ ن سِيذِي، خنِّي كنِّيوْ، إِوَا كنِّيوْ ذ ؤُجدْجِيذْ نْومْ ونِّي إِ خَاومْ إِ غَا إِحكْمنْ، أَذْ ثِيڒِيمْ ذِي ڒَامَانْ غَارْ ضفَّارْ ن سِيذِي، أَربِّي نْومْ. \x ◘ \xo 12:‏14 \xt أَعَوذ. 1‏:‏26. \x*  
\v 15 \add مَاشَا\add* مَاڒَا كنِّيوْ وَارْ ثسْڒِيمْ غَارْ ثْمِيجَّا ن سِيذِي، أَذْ ثْغوّْغمْ خْ \add مِينْ د-إِفّْغنْ زڭْ\add* ؤُقمُّومْ ن سِيذِي، خنِّي أَفُوسْ ن سِيذِي أَذْ خَاومْ يِيڒِي أَمْ ث ثُوغَا خْ ڒجْذُوذْ نْومْ.  
\v 16 خنِّي ڒخُّو، بدّمْ كنِّيوْ، خْزَارمْ \add ڒْْخذْمثْ\add* ثَامقّْرَانْثْ إِ ذ غَا إِڭّْ سِيذِي زَّاثْ إِ ثِيطَّاوِينْ نْومْ.  
\v 17 مَا وَارْ إِدْجِي أَسّْ-أَ صَّابثْ ن إِرْذنْ؟ نشّْ أَذْ ڒَاغِيغْ غَارْ سِيذِي ؤُ نتَّا أَذْ إِوْشْ أَجَّاجنْ ذ ونْژَارْ أَڒْ غَا ثسّْنمْ ؤُ أَذْ ثْژَارمْ مشْهَاڒْ إِمْغَارْ ڒْغَارْ إِ ثڭِّيمْ زَّاثْ إِ ثِيطَّاوِينْ ن سِيذِي مَاحنْذْ أَذْ أَسْ ثتَّارمْ إِجّْ ن ؤُجدْجِيذْ إِ يِيخفْ نْومْ.“   
\m
\v 18 ؤُ شَامْوِيلْ إِڒَاغَا غَارْ سِيذِي، ؤُ سِيذِي إِسّكّْ-د ذڭْ وَاسّْ نِّي أَجَّاجّنْ ذ ونْژَارْ، ؤُشَا مَارَّا ڒْڭنْسْ ثڒْقفْ إِ-ث ثِيڭّْوُوذِي ذ ثَامقّْرَانْثْ زِي سِيذِي ؤُ زِي شَامْوِيلْ.  
\v 19 مَارَّا ڒْڭنْسْ إِنَّا إِ شَامْوِيلْ: ”ژَتدْجْ إِ إِمْسخَّارنْ نّشْ غَارْ سِيذِي، أَربِّي نّشْ، مَاحنْذْ وَارْ نتّْمتِّي شَا، مَاغَارْ نشِّينْ نَارْنِي-د غَارْ مَارَّا دّْنُوبْ نّغْ عَاذْ ثُوعفّْنَا \add أَيَا\add*، بلِّي نَارْزُو إِجّْ ن ؤُجدْجِيذْ إِ نشِّينْ.“   
\m
\v 20 \add خنِّي\add* إِنَّا شَامْوِيلْ إِ ڒْڭنْسْ: ”وَارْ تّڭّْوْذمْ شَا! كنِّيوْ ثڭِّيمْ مَارَّا ثُوعفّْنَا-يَا، مَاشَا حْضَامْ أَڒَامِي وَارْ تّْحيَّاذمْ \add شَا عَاذْ\add* زِي غَارْ ضفَّارْ ن سِيذِي، ؤُشَا سخَّارمْ إِ سِيذِي س مَارَّا ؤُڒْ نْومْ.  
\v 21 وَارْ تّْحيَّاذمْ شَا، مِينْزِي \add خنِّي\add* أَذْ ثَافْ ثْضَافَّارمْ \add لْ-أَصْنَامْ\add* إِخْوَانْ، \add ثِيمسْڒَايِينْ\add* نِّي وَارْ إِنفّْعنْ ؤُ وَارْ إِتّْفكِّينْ، مِينْزِي نِيثنْثِي خْوَانْثْ.  
\v 22 مِينْزِي سِيذِي وَارْ إِسمّحْ ذِي ڒْڭنْسْ نّسْ ذِي طّْوعْ ن يِيسمْ نّسْ أَمقّْرَانْ، مَاغَارْ سِيذِي إِڭَّا أَذْ كنِّيوْ إِڭّْ ذ ڒْڭنْسْ إِ يِيخفْ نّسْ.  
\v 23 مِينْ ذ أَيِي إِشْقَانْ، إِڭّْوجْ خَافِي أَقَا أَذْ خْضِيغْ أَكْ-ذ سِيذِي ؤُمِي سّْبدّغْ ثْژَادْجِيثْ أَكِيذْومْ، \add مَاشَا\add* نشّْ أَذْ أَومْ سّشْنغْ أَبْرِيذْ إِصبْحنْ إِسڭّْمنْ.  
\v 24 مْغِيرْ، ڭّْوذمْ سِيذِي، سخَّارمْ خَاسْ س ڒْمَانثْ س وُوڒْ نْومْ مَارَّا، مَاغَارْ خْزَارمْ، مَا وَارْ إِڭِّي نتَّا جَارْ أَومْ \add مَارَّا\add* ثِيمسْڒَايِينْ \add نِّي\add* إِمْغَارنْ!  
\v 25 \add مَاشَا\add* مَاڒَا كنِّيوْ أَذْ ثَارْنِيمْ أَذْ ثڭّمْ ثُوعفّْنَا، خنِّي ڒَا ذ كنِّيوْ ؤُڒَا ذ أَجدْجِيذْ نْومْ أَذْ ثْهلّْكمْ.“   
\b  
\b  
\m  
\c 13
\s1 ڒْمُوعْصِييّثْ ن شَاوُولْ  
\m
\v 1 ثُوغَا غَارْ شَاوُولْ عِيشْرِينْ ن إِسڭّْوُوسَا ؤُمِي إِذْوڒْ ذ أَجدْجِيذْ. نتَّا إِحْكمْ أَربْعِينْ ن إِسڭّْوُوسَا خْ إِسْرَائِيل.  
\v 2 شَاوُولْ إِفَارْزْ ثڒْثْ-أَڒَافْ \add ن يرْيَازنْ\add* زِي إِسْرَائِيل. أَڒْفَاينْ \add زَّايْسنْ\add* ثُوغَا أَثنْ غَارْ شَاوُولْ ذِي مِيخْمَاسْ ؤُ خْ إِذُورَارْ ن بَايْثْ-إِلْ، ؤُ أَڒفْ \add زَّايْسنْ\add* ثُوغَا أَثنْ غَارْ يُونَاثَانْ ذِي جِيبْعَا ذِي \add ثمُّورْثْ ن\add* بِينْيَامِينْ. مِينْ إِقِّيمنْ زِي ڒْڭنْسْ يَارْخُو أَسْ إِجّْ إِجّْ أَذْ يُويُورْ غَارْ ؤُقِيضُونْ نّسْ.   
\m
\v 3 يُونَاثَانْ إِغْڒبْ خْ ثشْبَارْثْ ن ڒْعسْكَارْ ن إِفِيلِيسْطِينِييّنْ ذِي جِيبْعَا، ؤُشَا سْڒَانْ خَاسْ إِفِيلِيسْطِينِييّنْ. \add خنِّي\add* إِڭَّا شَاوُولْ أَذْ سُوضنْ ذڭْ ؤُيِيشّْ ن إِشَارِّي ذِي مَارَّا ثَامُّورْثْ، إِنَّا: ”أجّْ إِعِيبْرَانِييّنْ أَذْ \add ث\add* سْڒنْ!“  
\v 4 مَارَّا إِسْرَائِيل إِسْڒَا أَبَارّحْ-أَ: ”شَاوُولْ إِغْڒبْ خْ إِشْثْ ن ثشْبَارْثْ ن ڒْعسْكَارْ ن إِفِيلِيسْطِينِييّنْ ؤُ س مَانْ أَيَا إِسَّارْزڭْ إِسْرَائِيل إِخفْ نّسْ غَارْ إِفِيلِيسْطِينِييّنْ.“ إِتّْوَاڒَاغَا ڒْڭنْسْ \add مَاحنْذْ أَذْ ؤُيُورنْ\add* أَوَارْنِي إِ شَاوُولْ غَارْ جِيلْجَالْ.   
\m
\v 5 إِفِيلِيسْطِينِييّنْ سّْمُوننْ إِ ؤُمنْغِي أَكْ-ذ إِسْرَائِيل. \add نِيثْنِي ثُوغَا غَارْسنْ\add* ثڒْثْ-أَڒَافْ ن إِكَارُّوثنْ ذ ستَّا-أَڒَافْ ن إِمْنَاينْ، ؤُشَا ڒْڭنْسْ ن ڒْعسْكَارْ ثُوغَا ذڭْ وَاطَّاسْ أَمْ يِيجْذِي غَارْ ثْمَا ن ڒبْحَارْ. نِيثْنِي ڭعّْذنْ ؤُ وْثِينْ إِقِيضَانْ نْسنْ غَارْ مِيخْمَاسْ، غَارْ شَّارْقْ ن بَايْثْ-أَوِينْ. \f ◼ \fr 13:‏5 \ft \+bd ’إِمْنَاينْ‘\+bd* - ’إِنِّي إِنْيِينْ خْ إِيْسَانْ‘.\f*  
\v 6 \add كُوڒْ\add* أَرْيَازْ ذِي إِسْرَائِيل ثُوغَا إِتّْوَاڒَا أَقَا نِيثْنِي ذِي ڒحْصَارثْ، مِينْزِي ؤُژّْڒنْ خْ ڒْڭنْسْ. ؤُشَا إِنُّوفَارْ ڒْڭنْسْ ذڭْ إِفْرَانْ ؤُ ذڭْ إِفدْجَاقنْ ن ثصْضَارْثْ ؤُ ذِي ثْصُوضَارْ ؤُ ذڭْ إِمُوشَانْ ن ثْنُوفّْرَا ؤُ ذڭْ وَانُوثنْ.  
\v 7 ژْوَانْ إِعِيبْرَانِييّنْ لْ-ؤُرْذُونْ غَارْ ثمُّورْثْ ن جَاذْ ذ جِيلْعَاذْ. ثُوغَا شَاوُولْ س يِيخفْ نّسْ عَاذْ ذِي جِيلْجَالْ ؤُ مَارَّا ڒْڭنْسْ ثُوغَا إِتَّارْجِيجِي أَوَارْنِي أَسْ.  
\v 8 نتَّا إِرَاجَا ذِي جِيلْجَالْ سبْعَا ن وُوسَّانْ أَڒْ ڒْوقْثْ إِ إِڭَّا شَامْوِيلْ. مَاشَا ؤُمِي شَامْوِيلْ وَارْ د-يُوسِي، أَقَا إِبزّعْ ڒْڭنْسْ إِخفْ نّسْ، \add ؤُيُورنْ\add* خَاسْ.  
\v 9 \add ڒخْذنِّي\add* إِنَّا شَاوُولْ: ”أَوْيمْ أَيِي-د ذَا إِشْثْ ن ثْغَارْصْثْ ن وشْمَاضْ ذ ثْغَارْصَا ن ڒهْنَا!“ \add خنِّي\add* إِسّْڭعّذْ ثَاغَارْصْثْ ن وشْمَاضْ.  
\v 10 ؤُمِي إِكمّڒْ س ثوْهِيبْثْ ن ثْغَارْصْثْ ن وشْمَاضْ، إِمْسَارْ، أَقَا يُوسَا-د شَامْوِيلْ. شَاوُولْ إِفّغْ أَذْ ث إِڒْقَا، حِيمَا أَذْ أَسْ إِبَاركْ.  
\v 11 \add خنِّي\add* إِنَّا شَامْوِيلْ: ”مِينْ ثڭِّيذْ شكْ؟“ إِنَّا شَاوُولْ: ”مِينْزِي نشّْ ژْرِيغْ، أَقَا ڒْڭنْسْ يُويُورْ أَيِي ؤُ شكْ وَارْ د-ثُوسِيذْ عَاذْ ذڭْ وُوسَّانْ إِتّْوَاڭّنْ ؤُشَا إِفِيلِيسْطِينِييّنْ نّْجَارْونْ غَارْ مِيخْمَاسْ،  
\v 12 نِّيغْ نشّْ: ’ڒخُّو أَذْ غَارِي د-هْوَانْ إِفِيلِيسْطِينِييّنْ ؤُ نشّْ وَارْ زَاوْڭغْ \add عَاذْ\add* زَّاثْ إِ وُوذمْ ن سِيذِي!‘. \add خْ ؤُيَا\add* ؤُشِيغْ أَقَا ذِينْ أَغِيڒْ خَافِي، حِيمَا أَذْ سّْڭعّْذغْ إِشْثْ ن ثْغَارْصْثْ ن وشْمَاضْ.“   
\m
\v 13 شَامْوِيلْ يَارَّا-د خْ شَاوُولْ: ”شكْ ثڭِّيذْ ثُوبُّوهڒْيَا. وَارْ ثحْضِيذْ شَا ثَاوْصيّثْ ن سِيذِي، أَربِّي نّشْ، ثنِّي ذ أَشْ يُومُورْ، مِينْزِي خنِّي إِڒِي أَقَا سِيذِي إِشدّْ ڒخُّو ثَاڭلْذَا نّشْ خْ إِسْرَائِيل إِ ڒبْذَا.  
\v 14 ڒخُّو مَاشَا ثَاڭلْذَا نّشْ وَارْ ثتّْغِيمِي شَا. سِيذِي إِفَارْزْ إِ يِيخفْ نّسْ إِجّْ ن ورْيَازْ خْ وُوڒْ نّسْ ؤُ سِيذِي يُومُورْ أَسْ \add أَذْ يِيڒِي\add* ذ ڒْحَاكمْ خْ ڒْڭنْسْ نّسْ، مَاغَارْ شكْ وَارْ ثحْضِيذْ شَا مِينْ إِ ذ أَشْ يُومُورْ سِيذِي.“   
\m
\v 15 إِكَّارْ شَامْوِيلْ، إِڭعّذْ زِي جِيلْجَالْ غَارْ جِيبْعَا ذِي بِينْيَامِينْ ؤُشَا شَاوُولْ إِسدّْ ڒْڭنْسْ إِ ثُوغَا غَارسْ إِدْجَانْ، شَا ن ستَّا-مْيَا ن يرْيَازنْ.  
\v 16 شَاوُولْ، مِّيسْ يُونَاثَانْ ذ ڒْڭنْسْ إِ غَارْسنْ إِدْجَانْ، قِّيمنْ ذِي جِيبْعَا ذِي \add ثمُّورْثْ ن\add* بِينْيَامِينْ. ؤُشَا إِفِيلِيسْطِينِييّنْ وْثِينْ إِقِيضَانْ نْسنْ ذِي مِيخْمَاسْ.  
\v 17 ؤُشَا إِفّغْ \add ؤُبَارُّو ن\add* إِقْطَاطْعِييّنْ زِي ڒْمَارْڭحْ ن ڒْعسْكَارْ ن إِفِيلِيسْطِينِييّنْ ذِي ثْڒَاثَا ن بَانْذِييَّاثْ إِشْثْ ن بَانْذِييَّا ثَارَّا أَزدْجِيفْ غَارْ وبْرِيذْ ن عُوفْرَا، غَارْ ثمُّورْثْ ن شُوعَالْ،  
\v 18 ؤُ بَانْذِييَّا \add نّغْنِي\add* ثَارَّا أَزدْجِيفْ غَارْ وبْرِيذْ ن بَايْثْ-حُورُونْ ؤُ بَانْذِييَّا \add وِيسّْ ثْڒَاثَا\add* ثَارَّا أَزدْجِيفْ غَارْ وبْرِيذْ ن ويْمِيرْ نِّي إِخزَّارنْ ذِي ثغْزُورْثْ ن صابُوعِيمْ، غَارْ ڒخْڒَا.   
\m
\v 19 ذِي مَارَّا إِسْرَائِيل وَارْ إِتّْوِيفْ ؤُڒَا ذ إِجّْ ن ومْزِيڒْ، مِينْزِي إِفِيلِيسْطِينِييّنْ ثُوغَا نَّانْ: ”حِيمَا إِعِيبْرَانِييّنْ وَارْ تّڭّنْ سِّيفْ نِيغْ لَانْسَا.“ \x ◘ \xo 13:‏19 \xt ڒقض. 5‏:‏8. \x*  
\v 20 \add خْ ؤُيَا\add* مَارَّا إِسْرَائِيل إِقِّيمْ إِهكّْوَا غَارْ إِفِيلِيسْطِينِييّنْ، حِيمَا أَذْ إِسّقْضعْ \add كُوڒْ\add* أَرْيَازْ ؤُزَّاڒْ ن وسْغَارْ نّسْ، دُّوزَانْ نّسْ، وُوزَّاڒْ ن ؤُزدَّامْ نّسْ ذ وُوزَّاڒْ ن ثْسِيڒِيثْ نّسْ.  
\v 21 ثُوغَا غَارْسنْ إِزيْنَاثنْ وَارْ إِقْضِيعنْ غَارْ وُوزَّاڒْ ن إِسُوغَارْ ؤُ غَارْ دُّوزَانْ ؤُ غَارْ ثَازَّارِينْ \add س ثْڒَاثَا ن إِشُوكْضَانْ\add* ؤُ غَارْ إِسنَّاننْ إِبدّنْ \add ن ڒْمَاشَامْ ن إِينْذُوزنْ\add*.  
\v 22 ؤُمِي د-يِيوضْ وَاسّْ ن ؤُمنْغِي وَارْ إِتّْوِيفْ ؤُڒَا ذ إِجّْ ن سِّيفْ ؤُڒَا ذ إِجّْ ن ؤُحْرِيشْ ذِي مَارَّا ڒْڭنْسْ نِّي ثُوغَا إِدْجَانْ غَارْ شَاوُولْ ذ يُونَاثَانْ، أَقَا تّْوَافنْ مْغِيرْ غَارْ شَاوُولْ ذ يُونَاثَانْ.  
\v 23 إِشْثْ ن ثرْبِيعْثْ ن إِعسَّاسنْ ن ڒسْكَارْ ن إِفِيلِيسْطِينِييّنْ إِفّغْ غَارْ وبْرِيذْ ن ؤُژكّْوُو خْ إِذُورَارْ ن مِيخْمَاسْ.   
\b  
\b  
\m  
\c 14
\s1 أَذفْ ن يُونَاثَانْ غَارْ ثشْبَارْثْ ن إِفِيلِيسْطِينِييّنْ  
\m
\v 1 إِجّْ ن وَاسّْ إِمْسَارْ، أَقَا يُونَاثَانْ، مِّيسْ ن شَاوُولْ، إِنَّا إِ ؤُمْسخَّارْ ونِّي ذ أَسْ يَاربُّونْ ڒسْنَاحْ: ”أَسْ-د، أجّْ أَنغْ أَذْ نژْوَا غَارْ ثرْبِيعْثْ ن إِعسَّاسنْ ن ڒْعسْكَارْ ن إِفِيلِيسْطِينِييّنْ نِّي ذِينْ \add إِدْجَانْ\add* خْ ؤُجمَّاضْ!“، \add مَاشَا\add* نتَّا وَارْ ث إِنِّي إِ بَابَاسْ.   
\m
\v 2 ثُوغَا شَاوُولْ إِقِّيمْ غَارْ ثْمَا ن جِيبْعَا سَاذُو إِشْثْ ن ثْشجَّارْثْ ن أَرمَّامْ نِّي \add إِبدّنْ\add* ذِي مِيغْرُونْ، ؤُشَا ڒْڭنْسْ إِ ثُوغَا أَكِيذسْ إِدْجَانْ، ذَايسْ عْڒَاحَاڒْ ستَّا-مْيَا ن يرْيَازنْ. \x ◘ \xo 14:‏2 \xt 1 صم. 13‏:‏15\x*  
\v 3 أَخِييَا، مِّيسْ ن أَخِيطُوبْ، ؤُمَاسْ ن إِخابُوذْ، مِّيسْ ن فِينَاحَاسْ، مِّيسْ ن عَالِي، أَكهَّانْ ن سِيذِي ذِي شِيلُو، ثُوغَا يَارْضْ أَپَالْطُو \add ن ؤُكهَّانْ\add*. ڒْڭنْسْ وَارْ إِسِّينْ أَقَا يُونَاثَانْ ثُوغَا يُويُورْ.   
\m
\v 4 جَارْ إِمُوشَانْ ن ؤُژكّْوُو \add خْ إِذُورَارْ\add* إِ خْ ثُوغَا يُونَاثَانْ يَارزُّو أَذْ إِژْوَا غَارْ ثرْبِيعْثْ ن إِعسَّاسنْ ن ڒسْكَارْ ن إِفِيلِيسْطِينِييّنْ، ثُوغَا ذِينْ غَارْ ؤُغزْذِيسْ-أَ إِشْثْ ن ثصْضَارْثْ إِقضْعنْ إِ د-إِفّْغنْ ؤُڒَا ذ إِشْثْ ثصْضَارْثْ إِقضْعنْ إِ د-إِفّْغنْ غَارْ ؤُغزْذِيسْ نّغْنِي. إِشْثْ تّْڒَاغَانْ أَسْ بُوصَايْصْ ذ إِشْثْ نّغْنِيثْ \add تّْڒَاغَانْ أَسْ\add* سَانَا.  
\v 5 إِشْثْ ن ثصْذَارْثْ إِقضْعنْ ثُوغَا غَارْ شَّامَالْ أَرنْذَاذْ ن مِيخْمَاسْ ذ \add إِشْثْ ن ثسْضَارْثْ إِقضْعنْ\add* نّغْنِي ثُوغَا غَارْ لْجَانُوبْ أَرنْذَاذْ ن جِيبَاعْ.   
\m
\v 6 إِنَّا يُونَاثَانْ إِ ؤُمْسخَّارْ ونِّي ذ أَسْ يَاربُّونْ ڒسْنَاحْ: ”أَسْ-د، أجّْ أَنغْ أَذْ نژْوَا غَارْ ثرْبِيعْثْ ن إِعسَّاسنْ ن ڒسْكَارْ ن يِينِّي وَارْ إِتّْوَاخثْننْ، أَذْ ثَاغْ أَذْ إِڭّْ سِيذِي شَا ذِي طّْوعْ نّغْ، مِينْزِي وَارْ إِوْعَارْ إِ سِيذِي، حِيمَا أَذْ إِفكّْ س ؤُفُوسْ ن وَاطَّاسْ نِيغْ س ؤُفُوسْ ن ذْرُوسْ.“  
\v 7 أَحمَّاڒْ ن ڒسْنَاحْ نّسْ يَارَّا-د خَاسْ: ”أڭّْ مَارَّا مِينْ غَاركْ ذڭْ وُوڒْ نّشْ. ؤُيُورْ، خْزَارْ، نشّْ أَكِيذكْ أَمْ وُوڒْ نّشْ.“  
\v 8 يُونَاثَانْ إِنَّا: ”خْزَارْ، نشِّينْ أَذْ نژْوَا غَارْ يرْيَازنْ نِّي، أَذْ أَسنْ نسّْشنْ إِخفْ نّغْ.  
\v 9 مَاڒَا نِيثْنِي \add خنِّي\add* أَذْ أَنغْ إِنِينْ: ’بدّمْ أَڒْ غَارْومْ د غَا نَاسْ!‘، \add خنِّي\add* أَذْ نقِّيمْ نْبدّْ ذڭْ ومْشَانْ نّغْ، وَارْ غَارْسنْ نتّْڭعِّيذْ شَا.  
\v 10 \add مَاشَا\add* مَاڒَا نِيثْنِي أَذْ إِنِينْ: ’ڭعّْذمْ-د غَارْنغْ!‘، \add خنِّي\add* أَذْ غَارْسنْ نْڭعّذْ، مِينْزِي سِيذِي إِڭَّا أَنغْ ثنْ ذڭْ ؤُفُوسْ نّغْ. أَيَا أَذْ أَنغْ يِيڒِي ذ ڒعْڒَامثْ.“   
\m
\v 11 \add ڒَْامِي\add* د سشّْننْ نِيثْنِي إِخفْ نْسنْ س ثْنَاينْ إِذْسنْ غَارْ ثرْبِيعْثْ ن إِعسَّاسنْ ن ڒسْكَارْ ن إِفِيلِيسْطِينِييّنْ، نَّانْ إِفِيلِيسْطِينِييّنْ: ”خْزَارمْ، إِعِيبْرَانِييّنْ فّْغنْ-د زڭْ إِخُوبَاشْ نْسنْ إِ ذِي ثُوغَا نُّوفَّارنْ.“  
\v 12 إِرْيَازنْ ن ثرْبِيعْثْ ن ڒْعسْكَارْ نَّانْ إِ يُونَاثَانْ ؤُ إِ ونِّي ذ أَسْ يَاربُّونْ ڒسْنَاحْ: ”ڭعّْذمْ-د غَارْنغْ، نشِّينْ أَذْ أَومْ د-نسِّيوضْ ڒخْبَارْ!“ ؤُشَا إِنَّا يُونَاثَانْ إِ ؤُحمَّاڒْ ن ڒسْنَاحْ نّسْ: ”ڭعّذْ أَوَارْنِي أَيِي، مَاغَارْ سِيذِي إِڭَّا إِ-ثنْ ذڭْ ؤُفُوسْ ن إِسْرَائِيل.“  
\v 13 \add خنِّي\add* إِڭعّذْ يُونَاثَانْ خْ إِفَاسّنْ ذ إِضَارنْ غَارْ سنّجْ، ؤُ أَحمَّاڒْ ن ڒسْنَاحْ نّسْ إِضْفَارْ إِ-ث ؤُشَا وْضَانْ \add إِعسَّاسنْ نِّي\add* زَّاثْ إِ وُوذمْ ن يُونَاثَانْ ؤُ أَوَارْنِي أَسْ إِنْغَا إِ-ثنْ ؤُحمَّاڒْ ن ڒسْنَاحْ نّسْ.  
\v 14 ثِيشْثِي-يَا ثَامزْوَارُوثْ إِ زِي إِوْثَا يُونَاثَانْ ذ ؤُحمَّاڒْ ن ڒسْنَاحْ نّسْ عْڒَاحَاڒْ عِيشْرِينْ ن يرْيَازنْ، ثُوغَا ثدْجَا خْ إِجّْ ن ييَّارْ إِ ثُوغَا أَنشْثْ ن إِجّْ ن وزْينْ ن ييَّارْ \add إِ إِزمَّارْ\add* إِجّْ ن ؤُزَايْڒُو \add ن إِينْذُوزنْ\add* أَذْ ث إِشَارْزْ \add ذڭْ إِجّْ ن وَاسّْ\add*.  
\v 15 أَمنِّي ثُوذفْ ثَارْجِيجثْ ذِي ڒْمَارْڭحْ ن ڒْعسْكَارْ خْ ييَّارْ، ذِي مَارَّا ڒْڭنْسْ ؤُ ذڭْ يِينِّي ن ثرْبِيعْثْ ن ڒْعسْكَارْ. ؤُڒَا ذ أَبَارُّو ن إِكشَّاضنْ تَّارْجِيجنْ س يِيخفْ نْسنْ، \add وَاهْ،\add* ؤُڒَا ذ ثَامُّورْثْ ثنْهزّْ. ثُوغَا-ت ذ إِشْثْ ن ڒْعُورّثْ ثمْغَارْ ن أَربِّي.   
\m
\v 16 إِعسَّاسنْ ن شَاوُولْ ذِي جِيبْعَا ذِي بِينْيَامِينْ ژْرِينْ، أَقَا إِتّْوَابزّعْ ڒْغَاشِي، ذوْڒنْ نِيثْنِي تّْمنْغَانْ أَكْ-ذ وَايَاوْيَا.  
\v 17 \add خنِّي\add* إِنَّا شَاوُولْ إِ ڒْڭنْسْ إِ ثُوغَا غَارسْ إِدْجَانْ: ”أَرْزُومْ خنِّي ؤُ خْزَارمْ مَانْ ونْ إِ زَّايْنغْ إِفّْغنْ.“ نِيثْنِي أَرْزُونْ ؤُ خْزَارْ، أَقَا يُونَاثَانْ ذ ؤُحمَّاڒْ ن ڒسْنَاحْ نّسْ وَارْ ذِينْ دْجِينْ.  
\v 18 \add خنِّي\add* إِنَّا شَاوُولْ إِ أَخِييَا: ”أَوِي-د تَّابُوثْ ن أَربِّي ذَانِيثَا!“ مَاغَارْ تَّابُوثْ ثُوغَا-ت ذڭْ وُوسَّانْ نِّي غَارْ أَيْثْ ن إِسْرَائِيل .  
\v 19 ؤُمِي ثُوغَا شَاوُولْ إِسَّاوَاڒْ عَاذْ أَكْ-ذ ؤُكهَّانْ، إِمْسَارْ، أَقَا ڒْغَاشِي ذِي ڒْمَارْڭحْ ن ڒْعسْكَارْ ن إِفِيلِيسْطِينِييّنْ إِذْوڒْ إِنّهْوڒْ أَطَّاسْ. \add خنِّي\add* إِنَّا شَاوُولْ إِ ؤُكهَّانْ: ”فكّْ أَفُوسْ نّشْ!“  
\v 20 شَاوُولْ ذ مَارَّا ڒْڭنْسْ نِّي ثُوغَا غَارسْ، أَقَا تّْوَاڒَاغَانْ-د مَاحنْذْ أَذْ مُوننْ، ؤُشَا ؤُسِينْ-د غَارْ وَازَّايْ ن ؤُمنْغِي، ؤُ خْزَارْ، سِّيفْ ن إِجّنْ ثُوغَا خْ ونّغْنِي. أَقَا إِكَّارْ إِجّْ ن ؤُخَارْوضْ ذ أَمقّْرَانْ.  
\v 21 ثُوغَا ذِينْ عَاوذْ إِعِيبْرَانِييّنْ إِنِّي أَطَّاسْ زڭْ وَامِي ثُوغَا إِبدّنْ خْ ؤُغزْذِيسْ ن إِفِيلِيسْطِينِييّنْ، ثُوغَا تّفّْغنْ-د أَكِيذْسنْ مّْطَارّْشنْ جَارْ ڒْعسْكَارْ. ؤُڒَا ذ نِيثْنِي مُوننْ غَارْ إِسْرَائِيل إِيّنْ نِّي إِدْجَانْ أَكْ-ذ شَاوُولْ ذ يُونَاثَانْ.  
\v 22 \add ؤُمِي\add* مَارَّا إِرْيَازنْ ن إِسْرَائِيل، إِنِّي ثُوغَا إِنُّوفَّارنْ خْ إِذُورَارْ ن إِفْرَايِيمْ، سْڒَانْ، أَقَا إِفِيلِيسْطِينِييّنْ ثُوغَا أَروْڒنْ، مُوننْ ؤُڒَا ذ نِيثْنِي غَارْسنْ إِ ؤُمنْغِي مَاحنْذْ أَذْ ضْفَارنْ \add إِفِيلِيسْطِينِييّنْ\add*.  
\v 23 ذڭْ وَاسّْ نِّي إِفكّْ سِيذِي إِسْرَائِيل ؤُشَا أَمنْغِي إِفّغْ ؤُڒَا غَارْ بَايْثْ-أَوِينْ.   
\m
\v 24 تّْوَاعَارّْننْ إِرْيَازنْ ن إِسْرَائِيل ذڭْ وَاسّْ نِّي \add أَرْ طَّارْفْ\add*، مِينْزِي شَاوُولْ إِجُّودْجْ إِ ڒْڭنْسْ، إِنَّا: ”ونِّي إِ غَا إِشّنْ مَاشَّا قْبڒْ ثَامذِّيثْ ؤُ قْبڒْ إِ غَا نْثَاقْمغْ نشّْ خْ ڒْعذْيَانْ إِنُو، أَذْ يِيڒِي إِتّْوَانْعڒْ!“ \add خْ ؤُيَا\add* وَارْ إِشِّي مَارَّا ڒْڭنْسْ.  
\v 25 مَارَّا \add ڒْْڭنْسْ ن\add* ثمُّورْثْ يُوذفْ غَارْ وزْغَارْ ؤُشَا ثُوغَا \add ذِينْ\add* ثَامّنْثْ \add ثوْسعْ\add* ذڭْ إِيَّارْ. \f ◼ \fr 14:‏25 \ft \+bd ’أَزْغَارْ‘\+bd* - نِيغْ ’ڒْغَابثْ‘ نِيغْ ’ثَازْڭَانْثْ‘.\f*  
\v 26 \add ؤُمِي\add* د-يُوذفْ ڒْڭنْسْ غَارْ وزْغَارْ، \add أَقَا ذِينْ\add* ثَامّنْثْ س ؤُفيّضْ، \add مَاشَا\add* ؤُڒَا ذ إِجّْ وَارْ غَارسْ إِسّْوِيژّضْ س ؤُفُوسْ مَاحنْذْ أَذْ زَّايسْ إِكْسِي غَارْ ؤُقمُّومْ نّسْ، مَاغَارْ ڒْڭنْسْ إِڭّْوذْ ثَاجَادْجِيثْ \add ن شَاوُولْ\add*.   
\m
\v 27 \add مَاشَا\add* يُونَاثَانْ ثُوغَا وَارْ إِسْڒِي ڒَامِي إِسّْجُودْجْ بَابَاسْ ڒْڭنْسْ. نتَّا إِسّْوِيژّضْ س ؤُنڭَّارْ ن ؤُزدْجَاضْ نّسْ نِّي \add إِدْجَانْ\add* ذڭْ ؤُفُوسْ نّسْ ؤُشَا إِسِّيسنْ إِ-ث ذڭْ إِشْثْ ن ثغْرَاصْثْ ن ثَامّنْثْ. \add ڒَامِي\add* يِيوِي أَفُوسْ نّسْ غَارْ ؤُقمُّومْ نّسْ، أَقَا ذوْڒنْثْ ثِيطَّاوِينْ نّسْ إِزْذِيڭنْثْ أَطَّاسْ.  
\v 28 \add خنِّي\add* يَارَّا-د إِجّْ ن ورْيَازْ زِي ڒْڭنْسْ، إِنَّا: ”بَابَاشْ إِسّْجُودْجْ ڒْڭنْسْ س إِشْثْ ن ثْجَادْجِيثْ، إِنَّا: ’أَرْيَازْ إِ غَا إِشّنْ أَسّْ-أَ أَغْرُومْ، أَذْ يِيڒِي إِتّْوَانْعڒْ!‘ \add س ؤُينِّي\add* إِفْنَا ڒْڭنْسْ.“  
\v 29 \add خَاسْ ؤُشَا\add* إِنَّا يُونَاثَانْ: ”بَابَا إِغْضڒْ ثَامُّورْثْ ذِي أَرّْژِييّثْ. خْزَارمْ وَاهَا، ثِيطَّاوِينْ إِنُو تّْشعّْڒنْثْ، مِينْزِي نشّْ قَّاسغْ ذْرُوسْثْ زِي ثَامّنْثْ-أَ.  
\v 30 إِحْڒَا أَسنْ مْڒِي إِشَّا ڒْڭنْسْ مْلِيحْ أَسّْ-أَ زِي ثْكشَّاضْثْ إِ إِطّفْ زِي ڒْعذْيَانْ نّسْ، مِينْزِي ڒخُّو ثِيشْثِي \add إِ زِي وْثِينْ نِيثْنِي\add* إِفِيلِيسْطِينِييّنْ وَارْ ثدْجِي ذ ثَامقّْرَانْثْ \add عَاذْ\add*.“   
\m
\v 31 ذڭْ وَاسّْ نِّي وْثِينْ نِيثْنِي إِفِيلِيسْطِينِييّنْ زِي مِيخْمَاسْ أَڒْ أَيَالُونْ، ؤُ ڒْڭنْسْ ثُوغَا إِفْنَا أَطَّاسْ.  
\v 32 ڒْڭنْسْ إِعمّذْ خْ ثْكشَّاضْثْ ؤُ نِيثْنِي كْسِينْ ؤُدْجِي ذ إِفُونَاسنْ ذ ثْفُونَاسِينْ، ؤُشَا غَارْصنْ أَسنْ خْ ثمُّورْثْ، ؤُ ڒْڭنْسْ إِشَّا \add أَيْسُومْ\add* س إِذَامّنْ.  
\v 33 سَّارْڭْبنْ مَانْ أَيَا إِ شَاوُولْ، نَّانْ: ”أَقَا ڒْڭنْسْ إِخْضَا أَكْ-ذ سِيذِي ؤُمِي نِيثْنِي شِّينْ \add أَيْسُومْ\add* أَكْ-ذ إِذَامّنْ.“ نتَّا إِنَّا: ”كنِّيوْ ثْغدَّارمْ. سقْنُونِّييمْ-د كنِّيوْ أَسّْ-أَ إِشْثْ ن ثصْضَارْثْ غَارِي.“  
\v 34 إِنَّا شَاوُولْ \add عَاوذْ\add*: ”بزّْعمْ إِخفْ نْومْ جَارْ ڒْڭنْسْ، ثِينِيمْ أَسنْ: ’أجّْ \add كُوڒْ\add* أَرْيَازْ أَذْ أَيِي د-يَاوِي أَفُونَاسْ نّسْ، ؤُ \add أجّْ كُوڒْ\add* أَرْيَازْ \add أَذْ أَيِي د-يَاوِي عَاوذْ\add* إِجّنْ زڭْ وُودْجِي نّسْ. غَارْصمْ أَسنْ ذَا، شّمْ زَّايْسنْ، \add مَاشَا\add* وَارْ تّْخطِّيمْ أَكْ-ذ سِيذِي ؤُمِي غَا ثشّمْ س إِذَامّنْ.“ ؤُشَا \add كُوڒْ\add* أَرْيَازْ زِي مَارَّا ڒْڭنْسْ يِيوِي-د أَفُونَاسْ نّسْ س ؤُفُوسْ ذِي دْجِيڒثْ ؤُشَا غَارْصنْ أَسْ ذِينِّي.  
\v 35 ؤُشَا شَاوُولْ إِبْنَا إِجّْ ن ؤُعَالْطَارْ إِ سِيذِي. ثُوغَا-ث ذ أَعَالْطَارْ أَمزْوَارُو إِ إِسّْبدّْ إِ سِيذِي.   
\m
\v 36 \add خنِّي\add* إِنَّا شَاوُولْ: ”أجّْ أَنغْ أَذْ نهْوَا دْجِيڒثْ-أَ، أَذْ نضْفَارْ إِفِيلِيسْطِينِييّنْ ؤُ أَذْ ثنْ نْكشّضْ أَڒْ ثُوفُّوثْ ن صّْبحْ، وَارْ زَّايْسنْ نتّجِّي ؤُڒَا ذ إِجّنْ \add أَذْ إِدَّارْ عَاذْ\add*.“ نَّانْ نِيثْنِي ”أڭّْ مَارَّا مِينْ ثتّْوَاڒِيذْ نِيشَانْ ذِي ثِيطَّاوِينْ نّشْ.“ مَاشَا أَكهَّانْ إِنَّا: ”جّمْ أَنغْ أَذْ د-نْقَارّبْ غَارْ أَربِّي.“  
\v 37 \add خنِّي\add* إِسّقْسَا شَاوُولْ أَربِّي ”مَا أَذْ هْوِيغْ، أَذْ ضْفَارغْ إِفِيلِيسْطِينِييّنْ؟ مَا أَذْ ثنْ ثڭّذْ ذڭْ ؤُفُوسْ ن إِسْرَائِيل؟“ \add مَاشَا\add* سِيذِي وَارْ خَاسْ د-يَارِّي ذڭْ وَاسّْ نِّي.  
\v 38 \add خَاسْ ؤُشَا\add* إِنَّا شَاوُولْ: ”أَسمْ-د ذَا، مَارَّا إِمْضبَّارنْ نْ ڒْڭنْسْ، سْنمْ ؤُ خْزَارمْ، مِينْ ذِي إِدْجَا دّْنُوبْ-أَ إِ إِتّْوَاڭّنْ أَسّْ-أَ. \x ◘ \xo 14:‏38 \xt ڒقض. 20‏:‏2\x*  
\v 39 مِينْزِي س ثِيذتّْ أَمْ إِدَّارْ سِيذِي ونِّي إِفكّنْ إِسْرَائِيل، وَاخَّا ثُوغَا-ث ذ مِّي يُونَاثَانْ، نتَّا أَذْ إِمّثْ نِيشَانْ.“ مَاشَا ؤُڒَا ذ إِجّْ زِي ڒْڭنْسْ وَارْ د-يَارِّي شَا.   
\m
\v 40 إِنَّا \add عَاوذْ\add* إِ مَارَّا أَيْثْ ن إِسْرَائِيل: ”إِتّْخصَّا أَذْ ثْبدّمْ غَارْ إِجّْ ن ؤُغزْذِيسْ، نشّْ ذ مِّي يُونَاثَانْ أَذْ نْبدّْ غَارْ ؤُغزْذِيسْ نّغْنِي.“ ڒْڭنْسْ يَارَّا-د خْ شَاوُولْ: ”أڭّْ مِينْ ثتّْوَاڒِيذْ شكْ مْلِيحْ ذِي ثِيطَّاوِينْ نّشْ.“  
\v 41 \add خَاسْ ؤُشَا\add* إِسِّيوڒْ شَاوُولْ أَكْ-ذ سِيذِي، أَربِّي ن إِسْرَائِيل ”أَرّْ-د خَانغْ مَاحنْذْ أَذْ ث نسّنْ نِيشَانْ!“ \add خنِّي\add* إِتّْوَاطّفْ يُونَاثَانْ ذ شَاوُولْ ؤُشَا ڒْڭنْسْ إِفّغْ \add ذ أَمزْذَاڭْ\add*.  
\v 42 شَاوُولْ إِنَّا: ”نْضَارمْ ثَاقدُّوحْثْ جَارْ أَيِي نشّْ ذ مِّي يُونَاثَانْ!“ \add خنِّي\add* إِتّْوَاطّفْ يُونَاثَانْ.  
\v 43 إِنَّا شَاوُولْ إِ يُونَاثَانْ: ”إِنِي أَيِي، مِينْ ثڭِّيذْ شكْ!“ يُونَاثَانْ إِحَاجَا أَسْ ث، إِنَّا: ”نشّْ قَّاسغْ مْغِيرْ شْوَايْثْ ن ثَامّنْثْ س ؤُنڭَّارُو ن ؤُژدْجَاضْ نِّي \add إِدْجَانْ\add* ذڭْ ؤُفُوسْ إِنُو. أَقَا أَيِي ذَا، مَا إِتّْخصَّا أَيِي أَذْ مّْثغْ؟“  
\v 44 \add خنِّي\add* إِنَّا شَاوُولْ: ”أجّْ أَذْ أَيِي إِڭّْ أَربِّي ثَا ذ ثَا ؤُ أَذْ ذَايسْ يَارْنِي عَاذْ، \add مَاڒَا وَارْ شكْ نقّغْ\add* مِينْزِي \add شكْ\add*، يُونَاثَانْ، إِتّْخصَّا أَشْ أَذْ ثمّْثذْ نِيشَانْ.“  
\v 45 \add مَاشَا\add* ڒْڭنْسْ إِنَّا إِ شَاوُولْ: ”مَا إِتّْخصَّا أَذْ إِمّثْ يُونَاثَانْ، ونِّي إِوْينْ أَسنْجمْ-أَ أَمقّْرَانْ إِ إِسْرَائِيل؟ وَارْ خَاسْ نسِّيوڒْ! س ثِيذتّْ أَمْ إِدَّارْ سِيذِي، أَيَا وَارْ إِتِّيڒِي، وَارْ زَّايسْ إِوطَّا ؤُڒَا ذ إِشْثْ ن ؤُژطُّو ن ؤُشُوَّافْ ن ؤُزدْجِيفْ نّسْ غَارْ ثمُّورْثْ، مِينْزِي نتَّا إِڭَّا إِ-ث أَسّْ-أَ أَكْ-ذ أَربِّي.“ \add أَمُّو\add* إِ إِفكّْ ڒْڭنْسْ إِ يُونَاثَانْ ؤُشَا ثُوغَا وَارْ إِتّْخصِّي أَذْ إِمُّوثْ.   
\m
\v 46 شَاوُولْ إِسْمحْ ذڭْ وضْفَارْ ن إِفِيلِيسْطِينِييّنْ ؤُشَا إِفِيلِيسْطِينِييّنْعقْبنْ غَارْ إِمُوشَانْ \add ن ثْزذِّيغْثْ\add* نْسنْ.   
\b  
\m
\v 47 ؤُشَا شَاوُولْ إِطّفْ ثَاڭلْذَا خْ إِسْرَائِيل، إِمّْنغْ أَكْ-ذ مَارَّا ڒْعذْيَانْ نّسْ إِ ذ أَسْ د-إِنّْضنْ: أَكْ-ذ مُوآبَ، أَكْ-ذ أَيْثْ ن عَامُّونْ، أَكْ-ذ إِذُومْ، أَكْ-ذ إِجدْجِيذنْ ن صُوبَا ؤُ أَكْ-ذ إِفِيلِيسْطِينِييّنْ. مَانِي مَا يَارَّا س ؤُزدْجِيفْ، يِيوِي-د أَغلّبْ.  
\v 48 نتَّا إِڭَّا س ثرْيَاسْثْ، إِغْڒبْ خْ أَيْثْ ن عَامَالِيقْ ؤُ إِفكّْ إِسْرَائِيل زڭْ ؤُفُوسْ ن يِينِّي ث إِكشّْضنْ.   
\m
\v 49 أَرَّاونْ ن شَاوُولْ \add ثُوغَا أَثنْ ذ\add* يُونَاثَانْ ذ يِيشْوِي ذ مَالْكِيشُوعَا. إِسْمَاونْ ن ثْنَاينْ ن يسِّيسْ ذ مِيرَابْ، ثنِّي ذ ثَامنْزُوثْ، ؤُ إِسمْ ن ثْمَاژُوژْثْ \add أَقَا\add* ذ مِيخَالْ.  
\v 50 ثَامْغَارْثْ ن شَاوُولْ قَّارنْ أَسْ أَخِينُوعَامْ، يدْجِيسْ ن أَخِيمَاعَاصْ. ؤُشَا إِسمْ ن ؤُكُومَانْذَارْ ن ڒْعسْكَارْ نّسْ، \add أَقَا\add* ذ أَبْنِيرْ، مِّيسْ ن نِيرْ،عمِّيسْ ن شَاوُولْ.  
\v 51 قِيشْ، ونِّي ذ بَابَاسْ ن شَاوُولْ، ؤُ نِيرْ، ونِّي ذ بَابَاسْ ن أَبْنِيرْ، \add ثُوغَا أَثنْ ذ\add* إِحنْجِيرنْ ن أَبِييِيلْ.   
\m
\v 52 ثُوغَا \add ذِينْ\add* إِجّْ ن ؤُمنْغِي إِوْعَارْ أَكْ-ذ إِفِيلِيسْطِينِييّنْ مَارَّا ؤُسَّانْ مِينْ إِكَّا إِدَّارْ شَاوُولْ. كُوڒْ إِجّْ ن ورْيَازْ بُو-ثغْرُوضْثْ ذ كُوڒْ إِجّْ ن مِّيسْ ن ؤُمنْغِي إِ إِژْرَا شَاوُولْ، إِكْسِي إِ-ث غَارسْ.   
\b  
\b  
\m  
\c 15
\s1 شَاوُولْ إِتّْوَامّنْضَارْ زِي أَربِّي أَمْ ؤُجدْجِيذْ خْ إِسْرَائِيل  
\m
\v 1 شَامْوِيلْ إِنَّا إِ شَاوُولْ: ”سِيذِي ثُوغَا إِسّكّْ أَيِي-د حِيمَا أَذْ شكْ ذهْنغْ ذ أَجدْجِيذْ خْ ڒْڭنْسْ نّسْ، خْ إِسْرَائِيل. سڒْ خنِّي غَارْ وَاوَاڒنْ ن سِيذِي.  
\v 2 أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ: ’نشّْ أَذْ خدْجْصغْ مِينْ إِڭَّا عَامَالِيقْ إِ إِسْرَائِيل، أَقَا إِبدّْ أَسْ ذڭْ وبْرِيذْ ؤُمِي د-إِڭعّذْ إِسْرَائِيل زِي مِيصْرَا. \x ◘ \xo 15:‏2 \xt ؤُف. 17‏:‏8، 14؛ أَعَوذ. 25‏:‏17\x*  
\v 3 كَّارْ ڒخُّو ؤُ وّثْ عَامَالِيقْ. حَارّمْ مَارَّا مِينْ غَارسْ إِ ؤُثحِّي ؤُ وَارْ خَاسْ تّْحِيوِيڒْ شَا، مَاشَا نغْ \add مَارَّا\add*، زڭْ ورْيَازْ أَڒْ ثمْغَارْثْ، زڭْ ؤُحنْجِيرْ أَڒْ أَسيْمِي، زڭْ ؤُفُونَاسْ أَڒْ ؤُدْجِي، زڭْ وڒْغمْ أَڒْ أَغْيُوڒْ!‘ “   
\m
\v 4 إِڒَاغَا-د شَاوُولْ خْ ڒْڭنْسْ. إِسدّْ إِ-ثنْ ذِي طَالَايِيمْ. ثُوغَا-ثنْ ذِي مِيثَاينْ-أَڒفْ ن يرْيَازنْ خْ إِضَارنْ ذ ثنْعَاشْ أَڒفْ ن يرْيَازنْ ن يَاهُوذَا.  
\v 5 \add ؤُمِي\add* يِيوضْ شَاوُولْ غَارْ ثنْذِينْثْ ن عَامَالِيقْ، إِڭَّا إِجّْ ن ڒْفخْ ذِي ثغْزُورْثْ،  
\v 6 ؤُشَا شَاوُولْ إِجَّا أَذْ إِنِينْ إِ أَيْثْ ن إِقِينِييّنْ: ”فّْغمْ، بعّْذمْ، سمْحمْ ذِي ڒْوسْطْ ن عَامَالِيقْ، حِيمَا نشّْ وَارْ كنِّيوْ تّحِّيغْ أَكِيذْسنْ، مَاغَارْ كنِّيوْ ثڭِّيمْ س ثْمخْسِيوْثْ إِشوَّارنْ أَكْ-ذ أَيْثْ ن إِسْرَائِيل ؤُمِي د-فّْغنْ زِي مِيصْرَا.“ \add خَاسْ ؤُشَا\add* فّْغنْ إِقِينِييّنْ زِي ڒْوسْطْ ن أَيْثْ ن عَامَالِيقْ. \x ◘ \xo 15:‏6 \xt ؤُف. 18‏:‏10، 19؛ ڒخْڒ. 10‏:‏29؛ ڒقض. 1‏:‏16\x*  
\v 7 \add خنِّي\add* إِغْڒبْ شَاوُولْ خْ أَيْثْ ن عَامَالِيقْ زِي حَاوِيلَا أَڒْ شُورْ \add إِ إِدْجَانْ\add* أَرنْذَاذْ ن مِيصْرَا.  
\v 8 أَجَاجْ، أَجدْجِيذْ ن عَامَالِيقْ، إِطّفْ إِ-ث إِدَّارْ، مَاشَا مَارَّا ڒْڭنْسْ إِحَارّمْ إِ-ثنْ إِ ؤُثحِّي س ڒقْضعْ ن سِّيفْ. \x ◘ \xo 15:‏8 \xt ڒخْڒ. 24‏:‏7\x*  
\v 9 \add مَاشَا\add* شَاوُولْ ذ ڒْڭنْسْ حَاوْڒنْ خْ أَجَاجْ ؤُڒَا خْ ڒمْخيّرْ ن وُودْجِي ذ إِفُونَاسنْ ذ ثْفُونَاسِينْ ؤُ خْ مِينْ \add إِدْجَانْ\add* إِصبْحنْ أَوَارْنِي أَسْ ؤُ خْ مَارَّا إِزْمَارنْ ذَايْسنْ ثَاذُونْثْ ؤُ خْ مَارَّا مِينْ ثُوغَا ذ أَصبْحَانْ قَاعْ. وَارْ خْسنْ أَذْ ثنْ حَارّْمنْ إِ ؤُثحِّي، \add مَاشَا\add* مَارَّا مِينْ \add إِدْجَانْ\add* ذْرُوسْ ذ مِينْ إِضعْفنْ، حَارّْمنْ ث إِ ؤُثحِّي.   
\m
\v 10 \add خنِّي\add* يُوسَا-د وَاوَاڒْ ن سِيذِي غَارْ شَامْوِيلْ، إِنَّا:  
\v 11 ”نشّْ نذْمغْ، أَقَا ڭِّيغْ شَاوُولْ ذ أَجدْجِيذْ، مَاغَارْ نتَّا إِحيّذْ زِي ضفَّارْ إِنُو ؤُ وَارْ إِسّقْفڒْ أَوَاڒنْ إِنُو.“ إِنّهْوڒْ شَامْوِيلْ، إِسْغُويْ ثَامذِّيثْ ثْمُونْ غَارْ سِيذِي.  
\v 12 ثِيوشَّا نّسْ زِيشْ إِكَّارْ شَامْوِيلْ، يُويُورْ أَذْ إِڒْقَا شَاوُولْ. إِتّْوَانَّا أَسْ إِ شَامْوِيلْ، نَّانْ: ”شَاوُولْ يُوسَا-د غَارْ كَارْمِيلْ ؤُ إِسّْبدّْ \add ذِينِّي\add* إِجّْ ن ؤُقلِّيجْ ن ڒِيذَارثْ إِ يِيخفْ نّسْ، خنِّي إِنّقْڒبْ، إِعْذُو، إِهْوَا غَارْ جِيلْجَالْ.“   
\m
\v 13 يُوسَا-د شَامْوِيلْ غَارْ شَاوُولْ ؤُ شَاوُولْ إِنَّا أَسْ: ”أَقَا شكْ ثتّْوَابَارْكذْ زِي سِيذِي! نشّْ سّْقفْڒغْ أَوَاڒْ ن سِيذِي.“  
\v 14 \add خنِّي\add* يَارَّا-د خَاسْ شَامْوِيلْ: ”ذ مِينْ \add إِخْسْ أَذْ يِينِي\add* ڒْحسّْ-أَ ن وُودْجِي \add إِ ذ أَيِي إِتَّاذْفنْ\add* ذڭْ إِمزُّوغنْ إِنُو، ذ ڒْحسّْ ن إِفُونَاسنْ ذ ثْفُونَاسِينْ إِ تّسْڒِيغْ؟“  
\v 15 شَاوُولْ إِنَّا: ”نِيثْنِي إِوْينْ ثنْ-د أَكِيذْسنْ زِي عَامَالِيقْ، مِينْزِي ڒْڭنْسْ إِحَاوڒْ خْ مُومُّو ن وُودْجِي ذ إِفُونَاسنْ ذ ثْفُونَاسِينْ، حِيمَا أَذْ ثنْ قدّْمنْ ذ ثَاغَارْصْثْ إِ سِيذِي، أَربِّي نّشْ. مِينْ إِقِّيمنْ نْحَارّمْ إِ-ث إِ ؤُثحِّي.“  
\v 16 \add خنِّي\add* إِنَّا شَامْوِيلْ إِ شَاوُولْ: ”شْفَا! نشّْ أَذْ شكْ إِنِيغْ مِينْ إِ ذ أَيِي إِنَّا سِيذِي ذِي دْجِيڒثْ-أَ.“ إِنَّا أَسْ شَاوُولْ: ”سِيوڒْ!“   
\m
\v 17 إِنَّا شَامْوِيلْ: ”ؤُمِي ثدْجِيذْ \add عَاذْ\add* ذ أَمژْيَانْ ذِي ثِيطَّاوِينْ نّشْ، مَا وَارْ ثْذوْڒذْ شَا ذ أَزدْجِيفْ ن ثْقبَّاڒْ ن إِسْرَائِيل، ؤُ مَا وَارْ شكْ إِذْهنْ سِيذِي ذ أَجدْجِيذْ خْ إِسْرَائِيل؟  
\v 18 سِيذِي إِسّكّْ إِ شكْ غَارْ وبْرِيذْ، إِنَّا: ”ؤُيُورْ، حَارّمْ إِمذْنَابْ نِّي، أَيْثْ ن عَامَالِيقْ، إِ ؤُثحِّي ؤُ مْنغْ أَكِيذْسنْ أَڒْ ثنْ غَا ثقْضِيذْ قَاعْ.  
\v 19 مَايمِّي وَارْ ثسْڒِيذْ شَا غَارْ ثْمِيجَّا ن سِيذِي ؤُشَا ثوْضِيضْ شكْ خْ ثْكشَّاضْثْ ؤُ ثڭِّيذْ \add مِينْ إِدْجَانْ\add* ذ ڒْغَارْ ذِي ثِيطَّاوِينْ ن سِيذِي؟“   
\m
\v 20 \add خنِّي\add* إِنَّا شَاوُولْ إِ شَامْوِيلْ: ”نشّْ سْڒِيغْ غَارْ ثْمِيجَّا ن سِيذِي ؤُ نشّْ كّغْ أَبْرِيذْ إِ خْ إِ ذ أَيِي د-إِسّكّْ سِيذِي. نشّْ إِوْيغْ-د ذَانِيثَا أَجَاجْ، أَجدْجِيذْ ن عَامَالِيقْ ؤُشَا أَيْثْ ن عَامَالِيقْ حَارّْمغْ ثنْ إِ ؤُثحِّي.  
\v 21 ڒْڭنْسْ إِكْسِي ؤُدْجِي ذ إِفُونَاسنْ ذ ثْفُونَاسِينْ زِي ثْكشَّاضْثْ، مُومُّو ن مِينْ إِتّْوَاحَارّْمنْ، حِيمَا أَذْ قدّْمنْ أَيَا إِ سِيذِي، أَربِّي نّشْ، ذِي جِيلْجَالْ.“  
\v 22 \add مَاشَا\add* شَامْوِيلْ إِنَّا: ”مَا ثعْجبْ أَسْ إِ سِيذِي ثِيغَارْصَا ن وشْمَاضْ ذ ثِيغَارْصَا نّغْنِي أَمْ مَامّشْ إِ ذ أَسْ إِعْجبْ ؤُسدْجِي إِ ثْمِيجَّا ن سِيذِي؟ خْزَارْ أَسدْجِي حْسنْ زِي ثْغَارْصْثْ ؤُ أَسْحسِّي س ثَايْنِيثْ \add حْسنْ زِي\add* ثَاذُونْثْ ن إِشَارِّييّنْ. \x ◘ \xo 15:‏22 \xt أَمب. 4‏:‏17؛ حُوش. 6‏:‏6؛ مت. 9‏:‏13؛ 12‏:‏7\x*  
\v 23 مِينْزِي أَغوّغْ أَمْ دّنْبْ ن ؤُعزّمْ، ؤُ ثَاغنَّانْثْ أَمْ وعْبَاذْ نْ صَّانَامْ ذ ڒخْيَاڒَاثْ ثِيمژْيَانِينْ ن لْ-أَصْنَامْ. مِينْزِي شكْ ثنْضَارذْ أَوَاڒْ ن سِيذِي، إِنْضَارْ نتَّا إِ شكْ \add أَمْ\add* ؤُجدْجِيذْ.“   
\m
\v 24 \add خنِّي\add* إِنَّا شَاوُولْ إِ شَامْوِيلْ: ”نشّْ خْضِيغْ، مَاغَارْ نشّْ تّْعذِّيغْ خْ \add ڒُْومُورْ إِ د-إِفّْغنْ زڭْ\add* ؤُقمُّومْ ن سِيذِي ؤُ خْ وَاوَاڒنْ نّشْ، مِينْزِي نشّْ ڭّْوذغْ زِي ڒْڭنْسْ ؤُ سْڒِيغْ غَارْسنْ. \f ◼ \fr 15:‏24 \ft \+bd ’سْڒِيغْ غَارْسنْ‘\+bd* - س ثْعِيبْرَانِيثْ ’سْڒِيغْ غَارْ ثْمِيجَّا نْسنْ‘.\f*  
\v 25 س ؤُينِّي، غْفَارْ أَيِي دّنْبْ إِنُو ؤُ ذْوڒْ أَكِيذِي، \add خنِّي\add* أَذْ سجْذغْ إِ سِيذِي.“  
\v 26 \add مَاشَا\add* شَامْوِيلْ يَارَّا-د خْ شَاوُولْ: ”نشّْ وَارْ كِيذكْ ذِيكّْوِيڒغْ شَا، مَاغَارْ شكْ ثنْضَارذْ أَوَاڒْ ن سِيذِي. س ؤُيَا سِيذِي إِنْضَارْ إِ شكْ \add أَمْ\add* ؤُجدْجِيذْ خْ إِسْرَائِيل.“   
\m
\v 27 \add ؤُمِي\add* شَامْوِيلْ إِنّقْڒبْ حِيمَا أَذْ يُويُورْ، إِشبَّارْ أَسْ \add شَاوُولْ\add* ذِي ثْمَا ن ؤُسڒْهَامْ نّسْ، \add مَاشَا\add* وَانِيثَا إِشَارّڭْ.  
\v 28 \add خنِّي\add* إِنَّا أَسْ شَامْوِيلْ: ”ذڭْ وَاسّْ-أَ إِشَارّڭْ أَشْ سِيذِي ثَاڭلْذَا ن إِسْرَائِيل ؤُ إِوْشَا إِ-ت إِ جَّارْ نّشْ ونِّي إِدْجَانْ حْسنْ زَّايكْ.\f ◼ \fr 15:‏28 \ft \+bd ’ثَاڭلْذَا‘\+bd* - أَوَاڒْ-أَ إِخْسْ أَذْ يِينِي ’ڒحْكَامْ خْ إِشْثْ ن ثْڭلْذِيثْ‘.\f*  
\v 29 ؤُڒَا لْعَاضِيمْ ن إِسْرَائِيل إِ إِتّْذُومَانْ إِ ڒبْذَا وَارْ إِسّْخَارِّيقْ شَا ؤُ وَارْ إِنْذِيمْ، مَاغَارْ نتَّا وَارْ إِدْجِي ذ بْنَاذمْ أَڒَامِي إِ غَا إِنْذمْ.“ \x ◘ \xo 15:‏29 \xt ڒخْڒ. 23‏:‏19؛ يَاع. 1‏:‏17\x*  
\v 30 \add خَاسْ ؤُشَا\add* إِنَّا أَسْ: ”نشّْ خْضِيغْ. أوْشْ أَيِي مَاشَا أَوقَّارْ زَّاثْ إِ إِمْغَارنْ ن ڒْڭنْسْ ؤُ زَّاثْ إِ إِسْرَائِيل. ذْوڒْ أَكِيذِي، \add خنِّي\add* أَذْ سجْذغْ إِ سِيذِي، أَربِّي نّشْ.“  
\v 31 ؤُشَا إِذْوڒْ شَامْوِيلْ، يَاردّفْ شَاوُولْ ؤُ شَاوُولْ إِبنْذقْ زَّاثْ إِ سِيذِي.   
\m
\v 32 \add خَاسْ ؤُشَا\add* إِنَّا شَامْوِيلْ: ”أَوِي-د غَارِي أَجَاجْ، أَجدْجِيذْ ن عَامَالِيقْ. أَجَاجْ يُويُورْ غَارسْ س أَرَّاثُوحْ. إِنَّا أَجَاجْ \add أَكْ-ذ إِخفْ نّسْ\add*: ”س ثِيذتّْ، ثَارْزُوڭِي ن ڒْموْثْ ثتّْوَاحيّذْ \add خَافِي\add*.“  
\v 33 \add مَاشَا\add* شَامْوِيلْ إِنَّا: ”أَمْ مَامّشْ إِسّْحَارّمْ سِّيفْ نّشْ ثِيمْغَارِينْ خْ إِحنْجِيرنْ نْسنْثْ، أَمُّو إِ غَا ثتّْوَاحَارّمْ يمَّاشْ جَارْ ثِيمْغَارِينْ خْ ثَارْوَا نّسْ.“ ؤُ شَامْوِيلْ إِقطّسْ أَجَاجْ ذ إِشدْجِيقنْ زَّاثْ إِ وُوذمْ ن سِيذِي ذِي جِيلْجَالْ.  
\v 34 \add خنِّي\add* يُويُورْ شَامْوِيلْ غَارْ رَامَا ؤُ شَاوُولْ إِڭعّذْ غَارْ ثَادَّارْثْ نّسْ ذِي جِيبْعَا ن شَاوُولْ.  
\v 35 شَامْوِيلْ وَارْ إِژْرِي عَاذْ شَاوُولْ أَڒْ أَسّْ ن ڒْموْثْ نّسْ، مَاشَا شَامْوِيلْ إِشْضنْ خْ شَاوُولْ. ؤُشَا إِنْذمْ سِيذِي ڒَامِي إِڭَّا شَاوُولْ ذ أَجدْجِيذْ خْ إِسْرَائِيل.   
\b  
\b  
\m  
\c 16
\s1 ذَاوُوذْ إِتّْوَاذْهنْ أَمْ ؤُجدْجِيذْ  
\m
\v 1 \add خنِّي\add* إِنَّا سِيذِي إِ شَامْوِيلْ: ”مشْحَاڒْ ذ أَشْضَانْ \add إِ يدْجَانْ عَاذْ\add* غَاركْ خْ شَاوُولْ، ونِّي ڭِّيغْ نشّْ ذ أَجدْجِيذْ خْ إِسْرَائِيل؟عمَّارْ إِشّْ نّشْ س زّشْثْ، ؤُشَا ثُويُورذْ. نشّْ أَذْ شكْ سّكّغْ غَارْ يَاسَّا زِي بَايْثْ-لَاحْمْ، مِينْزِي جَارْ أَرَّاوْ نّسْ أَقَا ژْرِيغْ إِجّْ ن ؤُجدْجِيذْ إِ نشّْ.“  
\v 2 \add مَاشَا\add* شَامْوِيلْ إِنَّا: ”مَامّشْ إِ غَا ڭّغْ أَذْ \add ذِينْ\add* رَاحغْ؟ مَاڒَا إِسڒْ خْ مَانْ أَيَا شَاوُولْ، أَذْ أَيِي إِنغْ.“ يَارَّا-د سِيذِي: ”كْسِي إِشْثْ ن ثْعجْمِيثْ زڭْ إِفُونَاسنْ أَكِيذكْ، أَذْ ثِينِيذْ: ’نشّْ ؤُسِيغْ-د حِيمَا أَذْ قدّْمغْ إِشْثْ ن ثْغَارْصْثْ ذ ثَاوْهِيبْثْ إِ سِيذِي.‘  
\v 3 إِتّْخصَّا أَذْ ثْعَارْضذْ خْ يَاسَّا غَارْ ثوْهِيبْثْ ؤُ نشّْ أَذْ شكْ سَّارْڭْبغْ خْ مِينْ إِ إِتّْخصَّانْ أَذْ ثڭّذْ. شكْ أَذْ ثْذهْنذْ ونِّي إِ ذ أَشْ غَا إِنِيغْ.“  
\v 4 شَامْوِيلْ إِڭَّا مِينْ ثُوغَا ذ أَسْ إِنَّا سِيذِي. ؤُمِي د-يُوسَا غَارْ بَايْثْ-لَاحْمْ، فّْغنْ-د غَارسْ إِمْغَارنْ ن ثنْذِينْثْ تَّارْجِيجِينْ، نَّانْ: ”مَا ثَاوَاسِيثْ نّشْ س ڒهْنَا؟“  
\v 5 نتَّا إِنَّا: ”س ڒهْنَا. نشّْ ؤُسِيغْ-د حِيمَا أَذْ قدّْمغْ إِشْثْ ن ثْغَارْصْثْ ذ صّذْقثْ إِ سِيذِي. قدّْسمْ إِخفْ نْومْ ؤُ أَسمْ-د أَكِيذِي غَارْ صّذْقثْ. نتَّا إِقدّسْ يَاسَّا ذ إِحنْجِيرنْ نّسْ ؤُشَا إِعَارْضْ إِ-ثنْ غَارْ ثوْهِيبْثْ ن ثْغَارْصْثْ.   
\m
\v 6 ؤُشَا إِمْسَارْ ؤُمِي د-ؤُسِينْ نِيثْنِي، إِژْرَا نتَّا إِلِييَابْ ؤُشَا إِخَارّصْ: ”ذ وَا س ثِيذتّْ غَارْ سِيذِي ذ أَمذْهُونْ نّسْ.“  
\v 7 سِيذِي \add مَاشَا\add* إِنَّا إِ شَامْوِيلْ: ”وَارْ خزَّارْ شَا غَارْ وَادُّوذْ نّسْ ؤُڒَا غَارْ ڒُوعْڒَا نّسْ ن ثِيذِّي، مِينْزِي نشّْ نْضَارغْ ث، مَاغَارْ وَارْ إِتّْهِيمِّي شَا مِينْ غَارْ إِخزَّارْ بْنَاذمْ، مِينْزِي بْنَاذمْ إِتّْوَاڒَا مِينْ إِدْجَانْ زَّاثْ إِ ثِيطَّاوِينْ \add نّسْ\add*، \add مَاشَا\add* سِيذِي إِتّْوَاڒَا ؤُڒْ.“ \x ◘ \xo 16:‏7 \xt 1 إِم. 28‏:‏9؛ إِزهد. 7‏:‏10؛ إِرْم. 11‏:‏20؛ 17‏:‏10؛ 20‏:‏12\x*   
\m
\v 8 \add خنِّي\add* إِڒَاغَا يَاسَّا خْ أَبِينَاذَابْ، إِجَّا إِ-ث أَذْ إِعْذُو خْ شَامْوِيلْ، \add مَاشَا\add* نتَّا إِنَّا: ”وَانِيثَا عَاوذْ وَارْ ث يِيخْضَارْ سِيذِي.“  
\v 9 \add خَاسْ ؤُشَا\add* إِجَّا يَاسَّا أَذْ \add خَاسْ\add* إِعْذُو شَامَّا، مَاشَا نتَّا إِنَّا: ”وَانِيثَا عَاوذْ وَارْ ث يِيخْضَارْ سِيذِي.“  
\v 10 أَمُّو إِ إِجَّا يَاسَّا أَذْ عْذُونْ سبْعَا ن إِحنْجِيرنْ نّسْ خْ شَامْوِيلْ، \add مَاشَا\add* شَامْوِيلْ إِنَّا إِ يَاسَّا: ”إِنَا وَارْ ثنْ إِخْضَارْ شَا سِيذِي.“  
\v 11 \add خنِّي\add* إِنَّا شَامْوِيلْ إِ يَاسَّا: ”مَا ذ إِنَا مَارَّا إِحُوذْرِييّنْ \add نّشْ\add*؟“ نتَّا يَارَّا-د خَاسْ: ”أَمَاژُوژْ إِقِّيمْ عَاذْ، أَقَا يَاركّْوسْ ؤُدْجِي.“ إِنَّا شَامْوِيلْ إِ يَاسَّا: ”سكّْ \add إِجّْ\add* مَاحنْذْ أَذْ ث-إِ-د-يَاوِي، مِينْزِي نشِّينْ وَارْ نتّْقُووِّيرْ شَا \add إِ طَّابْڒَا\add* قْبڒْ إِ د غَا يَاسْ نتَّا.“ \x ◘ \xo 16:‏11 \xt 2 صم. 7‏:‏8؛ إِزهد. 78‏:‏70\x*  
\v 12 نتَّا إِسّكّْ \add إِجّْ\add* مَاحنْذْ أَذْ ث-إِ-د يَاوِي. نتَّا ثُوغَا ذ أَرُّوبْيُو ؤُ ثُوغَا غَارسْ ثِيطَّاوِينْ شْنَانْثْ ؤُ ثُوغَا ذ مُوصْبِيحْ إِ ڒْخزْرَاثْ. \add خنِّي\add* إِنَّا سِيذِي: ”كَّارْ، ذهْنْ إِ-ث، مَاغَارْ أَقَا ذ وَا.“  
\v 13 ؤُشَا إِكْسِي شَامْوِيلْ إِشّْ س زّشْثْ، إِذهْنْ إِ-ث ذِي ڒْوسْثْ ن أَيْثْمَاسْ. ؤُشَا أَرُّوحْ ن سِيذِي إِهْوَا خْ ذَاوُوذْ زڭْ وَاسّْ نِّي ذ ثْسَاونْثْ. شَامْوِيلْ إِكَّارْ، يَارڭّْوحْ غَارْ رَامَا. \x ◘ \xo 16:‏13 \xt إِزهد. 89‏:‏21؛ ڒخ. 7‏:‏46؛ 13‏:‏22\x*   
\b  
\m  
\s1 ذَاوُوذْ إِتِّيرَارْ خْ ڒْڭَامْبْرِي إِ شَاوُولْ  
\m
\v 14 أَرُّوحْ ن سِيذِي ثُوغَا إِحيّذْ خْ شَاوُولْ ؤُ إِجّْ ن ڒَارْيَاهْ ذ أَعفَّانْ زِي غَارْ سِيذِي إِسِّيڭّْوذْ إِ-ث.  
\v 15 نَّانْ أَسْ إِمْسخَّارنْ ن شَاوُولْ: ”خْزَارْ، إِجّْ ن ڒَارْيَاهْ ذ أَعفَّانْ ن أَربِّي إِسِّيڭّْوذْ إِ شكْ.  
\v 16 أجّْ أَذْ يِينِي سِيذِيثْنغْ إِ إِمْسخَّارنْ نّشْ إِنِّي إِبدّنْ زَّاثْ إِ وُوذمْ نّشْ، مَاحنْذْ أَذْ أَرْزُونْ خْ إِجّْ ن ورْيَازْ إِتّْحَاكَانْ ذِي ڒْڭَامْبْرِي. مَاڒَا إِطّفْ إِ شكْ ڒَارْيَاحْ أَعفَّانْ ن أَربِّي، أجّْ إِ-ث \add خنِّي\add* أَذْ يِيرَارْ نتَّا س ؤُفُوسْ نّسْ \add ذِي ڒْڭَامْبْرِي،\add* \add حِيمَا\add* أَذْ ثِيڒِيذْ مْلِيحْ.“ \f ◼ \fr 16:‏16 \ft \+bd ’لْهَارْبَا‘\+bd* - نِيغْ ’ڒْڭَامْبْرِي ن ثمُّورْثْ‘.\f*  
\v 17 \add خنِّي\add* إِنَّا شَاوُولْ إِ إِمْسخَّارنْ نّسْ: ”أَرْزُومْ أَيِي-د خْ إِجّْ ن ورْيَازْ نِّي إِتِّيرَارنْ مْلِيحْ \add خْ ڒْڭَامْبْرِي\add* ؤُ أَوْيمْ ث-إِ-د ذَا غَارِي!“  
\v 18 إِجّنْ زڭْ إِمْسخَّارنْ يَارَّا-د خَاسْ، إِنَّا: ”أَقَا ژْرِيغْ إِجّْ ن مِّيسْ ن يَاسَّا زِي بَايْثْ-لَاحْمْ ونِّي إِزمَّارنْ أَذْ يِيرَارْ \add مْلِيحْ\add*. نتَّا ذ إِجّْ ن بُو-ثغْرُوضْثْ إِمحْضنْ ذ إِجّْ ن ورْيَازْ أَعسْكَارِي، إِسّنْ أَذْ إِخْضَارْ أَوَاڒنْ نّسْ. أَقَا-ث ذ إِجّْ ن ورْيَازْ ذ أَصبْحَانْ ن وَادُّوذْ ؤُ سِيذِي أَكِيذسْ.“   
\m
\v 19 إِسّكّْ شَاوُولْ إِرقَّاسنْ غَارْ يَاسَّا، إِنَّا: ”سكّْ أَيِي-د مِّيشْ ذَاوُوذْ ونِّي إِدْجَانْ أَكْ-ذ وُودْجِي.“  
\v 20 يَاسَّا إِكْسِي إِجّْ ن وغْيُوڒْ أَكْ-ذ وغْرُومْ ذ إِشْثْ ن ثشْيَارْثْ ن بِينُو ذ إِجّْ ن إِغَايْضْ ذ أَمژْيَانْ زڭْ إِغَايْضنْ ؤُشَا إِسّكّْ أَيَا س ؤُفُوسْ ن مِّيسْ ذَاوُوذْ غَارْ شَاوُولْ.  
\v 21 أَمُّو د-يُوسَا ذَاوُوذْ غَارْ شَاوُولْ ؤُشَا إِبدّْ زَّاثْ إِ وُوذمْ نّسْ ؤُ نتَّا إِتّخْسْ إِ-ث أَطَّاسْ. نتَّا إِذْوڒْ ذ أَحمَّاڒْ ن ڒسْنَاحْ نّسْ.  
\v 22 س ؤُينِّي إِسّكّْ شَاوُولْ غَارْ يَاسَّا مَاحنْذْ أَذْ أَسْ يِينِي: ”تّْزَاوْڭغْ شكْ، أجّْ ذَاوُوذْ أَذْ إِقِّيمْ إِبدّْ زَّاثْ إِ وُوذمْ إِنُو، مَاغَارْ نتَّا يُوفَا أَرْضَا ذِي ثِيطَّاوِينْ إِنُو.“  
\v 23 مڒْمِي مَا د-يُوسَا ڒَارْيَاحْ ذ أَعفَّانْ ن أَربِّي غَارْ شَاوُولْ، إِكْسِي ذَاوُوذْ ڒْڭَامْبْرِي ؤُشَا إِبْذَا إِتِّيرَارْ ذَايسْ س ؤُفُوسْ نّسْ. ذ مَانْ أَيَا د-يَارِّينْ نّفْسْ غَارْ شَاوُولْ أَڒَامِي إِذْوڒْ مْلِيحْ، ؤُشَا \add خنِّي\add* إِحيّذْ خَاسْ بُوحْبڒْ أَعفَّانْ.   
\b  
\b  
\m  
\c 17
\s1 ذَاوُوذْ ذ جُولِييَاثْ  
\m
\v 1 إِفِيلِيسْطِينِييّنْ سّْمُوننْ ڒْعسْكَارَاثْ نْسنْ إِ ؤُمنْغِي ؤُ نِيثْنِي نّْيَارْونْ غَارْ سُوكُو ذِي \add ثمُّورْثْ ن\add* يَاهُوذَا. وْثِينْ إِقِيضَانْ نْسنْ جَارْ سُوكُو ذ عَازِيقَّا غَارْ أَفَاسْ-ذَامِّيمْ.  
\v 2 \add ؤُڒَا ذ\add* شَاوُولْ ذ يرْيَازنْ ن إِسْرَائِيل نّْيَارْونْ ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِي ثغْزُورْثْ ن إِلَا. نِيثْنِي سدّنْ إِخفْ نْسنْ إِ ؤُمنْغِي قِيبَاتْشْ إِ إِفِيلِيسْطِينِييّنْ.  
\v 3 إِفِيلِيسْطِينِييّنْ بدّنْ خْ وذْرَارْ غَارْ ؤُغزْذِيسْ-أَ ؤُ إِسْرَائِيل إِيّنْ بدّنْ خْ وذْرَارْ غَارْ ؤُغزْذِيسْ نِّي ؤُ ثَاغْزُورْثْ ثُوغَا جَارْ أَسنْ.  
\v 4 \add خنِّي\add* إِفّغْ-د إِجّْ ن ؤُعسْكَارِي ذ أَزعَّامْ زِي ڒْمَارْڭحْ ن ڒْعسْكَارْ ن إِفِيلِيسْطِينِييّنْ، قَّارنْ أَسْ جُولِييَاثْ. ثُوغَا-ث زِي جَاثْ. ڒُْوعْڒَا نّسْ ستَّا ن إِغَادْجنْ ذ إِجّْ ن وزْينْ ن ؤُغِيڒْ.  
\v 5 خْ ؤُزدْجِيفْ نّسْ ثُوغَا إِجّْ ن لْكَاسْكْ ن نّْحَاسْ، ؤُ نتَّا يَارْضْ أَرُّوضْ ن وُوزَّاڒْ ن ؤُعسْكَارِي س ثقْشُورِينْ. ثُوغَا ڒوْزنْ ن وَارُّوضْ ن وُوزَّاڒْ خمْسَا-أَڒَافْ شِيقْلُو ن نّْحَاسْ.  
\v 6 نتَّا ثُوغَا غَارسْ إِسڒْقَانْ ن إِفَادّنْ ن نّْحَاسْ إِ ؤُحطُّو ن إِضَارنْ ؤُ جَارْ ثْغَارْضِينْ نّسْ \add يَارْبُو\add* إِجّْ ن ؤُحْرِيشْ ن نّْحَاسْ.  
\v 7 أَعْمُوذْ ن لَانْسَا نّسْ ثُوغَا ث أَمْ يِيجّْ ن ؤُكشُّوضْ ن ؤُخيّضْ ؤُ ثِيخفْثْ \add ن وُوزَّاڒْ\add* ن لَانْسَا نّسْ ثوْزنْ ستَّا-مْيَا شِيقْلُو ن وُوزَّاڒْ ؤُ ونِّي ذ أَسْ يَاربُّونْ ثَاسدَّارْثْ نّسْ ثَامقّْرَانْثْ ن ؤُعسْكَارِي إِزْوَارْ أَسْ.   
\m
\v 8 نتَّا ثُوغَا إِبدّْ \add ذِينْ\add*، إِڒَاغَا إِ إِسذِّييّنْ ن ڒْعسْكَارْ ن إِسْرَائِيل، إِنَّا أَسنْ: ”مَايمِّي إِ د-ثفّْغمْ ؤُ ثْسدّمْ إِخفْ نْومْ إِ ؤُمنْغِي؟ وَارْ إِدْجِي نشّْ ذ أَفِيلِيسْطِينِي ؤُ كنِّيوْ ذ إِمْسخَّارنْ ن شَاوُولْ؟ فَارْزمْ إِجّْ ن ورْيَازْ إِ كنِّيوْ ونِّي غَارِي د غَا إِهْوَانْ.  
\v 9 مْڒِي خَافِي إِزمَّارْ ذڭْ ؤُمنْغِي، أَذْ أَيِي إِوّثْ، \add خنِّي\add* نشِّينْ أَذْ نِيڒِي ذ إِمْسخَّارنْ نْومْ، \add مَاشَا\add* مَاڒَا نشّْ أَربْحغْ ؤُشَا أَذْ خَاسْغڒْبغْ، \add خنِّي\add* كنِّيوْ أَذْ ثِيڒِيمْ ذ إِمْسخَّارنْ نّغْ، أَذْ أَنغْ ثْسخَّارمْ.“  
\v 10 إِنَّا ؤُفِيلِيسْطِينِي \add عَاوذْ\add*: ”ذڭْ وَاسّْ-أَ سْثهْزِيغْ زڭْ إِسذِّييّنْ ن ڒْعسْكَارْ ن إِسْرَائِيل، أَذْ \add أَومْ\add* إِنِيغْ: ’أوْشْ أَيِي إِجّْ ن ورْيَازْ مَاحنْذْ أَذْ نمّْنغْ أَكْ-ذ وَايَاوْيَا!‘ “  
\v 11 شَاوُولْ ذ مَارَّا إِسْرَائِيل سْڒَانْ أَوَاڒنْ-أَ ن ؤُفِيلِيسْطِينِي ؤُشَا نّْخڒْعنْ ؤُ ڭّْوذنْ أَطَّاسْ.   
\m
\v 12 ذَاوُوذْ ثُوغَا ذ مِّيسْ ن إِجّْ ن ورْيَازْ زِي إِفْرَاثَا، زِي بَايْثْ-لَاحْمْ ذِي \add ثمُّورْثْ ن\add* يَاهُوذَا، قَّارنْ أَسْ يَاسَّا. نتَّا ثُوغَا غَارسْ ثْمنْيَا ن إِحنْجِيرنْ ؤُ ذڭْ وُوسَّانْ ن شَاوُولْ \add ثُوغَا حسّْبنْ ث\add* ذ أَوسَّارْ ؤُمِي د-يُوسَا جَارْ يرْيَازنْ.  
\v 13 ثْڒَاثَا ن إِحنْجِيرنْ إِمقّْرَاننْ ن يَاسَّا ضْفَارنْ شَاوُولْ غَارْ ؤُمنْغِي. إِسْمَاونْ ن ثْڒَاثَا ن إِحنْجِيرنْ نّسْ، إِنِّي د-إِفّْغنْ غَارْ ؤُمنْغِي، أَقَا أَثنْ إِلِييَابْ، أَمنْزُو، ؤُ ونِّي وِيسّْ ثْنَاينْ ذ أَبِينَاذَابْ ؤُ ونِّي وِيسّْ ثْڒَاثَا ذ شَامَّا.  
\v 14 ثُوغَا ذَاوُوذْ ذ أَمَاژُوژْ ؤُشَا ثْڒَاثَا ن \add إِحنْجِيرنْ\add* إِمقّْرَاننْ ثُوغَا ضْفَارنْ شَاوُولْ.  
\v 15 ذَاوُوذْ ثُوغَا \add إِنُّومْ\add* إِتّْرَاحْ \add ذِينِّي\add* ؤُ \add خنِّي\add* إِتَّارڭّْوحْ-د زِي شَاوُولْ، حِيمَا أَذْ يَارْوسْ ؤُدْجِي ن بَابَاسْ ذِي بَايْثْ-لَاحْمْ. \x ◘ \xo 17:‏15 \xt 1 صم. 16‏:‏19\x*   
\m
\v 16 أَفِيلِيسْطِينِي ثُوغَا إِتَّاسْ-د غَارْ ثُوفُّوثْ ؤُ غَارْ ثْمذِّيثْ، إِسّْشَانْ إِخفْ نّسْ \add ذِينْ\add*، أَربْعِينْ ن وُوسَّانْ.   
\m
\v 17 إِنَّا يَاسَّا إِ مِّيسْ ذَاوُوذْ: ”كْسِي عَافَاكْ إِ أَيْثْمَاشْ إِجّْ ن إِفَا ن ثغْوَاوِينْ-أَ ذعشْرَا ن ثشْنِيفِينْ، أَوْيِي ثنْثْ ذغْيَا غَارْ ڒْمَارْڭحْ ن ڒْعسْكَارْ غَارْ أَيْثْمَاشْ.  
\v 18 ؤُعشْرَا ن ثْرُوسِّي ن ؤُغِي-يَا أَوْيِي ثنْثْ غَارْ ؤُمقّْرَانْ خْ وَاڒفْ. أَرْزُو خْ يَايْثْمَاشْ، مَا مْلِيحْ إِ إِدْجَانْ ؤُ أَوْيِي زَّايْسنْ إِشْثْ ن وضْمَانْ \add ذ جُّورّثْ ن ثُوذَارْثْ\add*!“  
\v 19 شَاوُولْ ذ أَيْثْمَاسْ ذ مَارَّا إِرْيَازْ\add أنْ\add* ن إِسْرَائِيل، ثُوغَا تّْمنْغَانْ أَكْ-ذ إِفِيلِيسْطِينِييّنْ ذِي ثغْزُورْثْ ن إِلَا.   
\m
\v 20 إِكَّارْ ذَاوُوذْ زِيشْ غَارْ ثُوفُّوثْ، إِجَّا ثْحِيمَارْثْ ن وُودْجِي غَارْ إِجّْ ن ؤُعسَّاسْ ؤُ يِيوِي \add مَارَّا أَيَا\add* أَكِيذسْ ؤُشَا يُويُورْ أَمْ مَامّشْ ثُوغَا إِ ذ أَسْ ث يُومُورْ يَاسَّا. ؤُمِي د-يِيوضْ غَارْ ڒْمَارْڭحْ ن إِكَارُّوثنْ، ڒخْذنِّي إِ إِفّغْ ڒْعسْكَارْ غَارْ ؤُسذِّي ن ؤُمنْغِي، \add بْذَانْ\add* أَذْ سْغُوينْ س إِغُويَّانْ ن ؤُمنْغِي. \x ◘ \xo 17:‏20 \xt 1 صم. 26‏:‏5\x*  
\v 21 إِسْرَائِيل ذ إِفِيلِيسْطِينِييّنْ سدّنْ إِخفْ نْسنْ \add إِ ؤُمنْغِي\add*، أَغمْبُوبْ ن إِجّْ ن ؤُسذِّي ذڭْ ؤُغمْبُوبْ ن إِجّْ ن ؤُسذِّي نّغْنِي.  
\v 22 ذَاوُوذْ إِجَّا ڒحْوَايجْ نِّي غَارسْ ذڭْ إِفَاسّنْ ن إِجّْ ن ؤُعسَّاسْ ن ڒحْوَايجْ ؤُشَا يُوزّڒْ غَارْ ؤُسذِّي ن ڒْعسْكَارْ. ؤُمِي \add ذِينْ\add* يِيوضْ، إِسّقْسَا خْ يَايْثْمَاسْ مَامّشْ دْجَانْ نِيثْنِي.  
\v 23 \add ڒَْامِي\add* ثُوغَا أَكِيذْسنْ إِسَّاوَاڒْ، خْزَارْ، إِفّغْ-د ؤُمْجَاهذْ أَزعَّامْ نِّي، قَّارنْ أَسْ جُولْيَاثْ زِي جَاثْ، زِي ڒْعسْكَارْ ن إِفِيلِيسْطِينِييّنْ. نتَّا إِسِّيوڒْ س وَاوَاڒنْ ذ إِجّنْ ؤُ ذَاوُوذْ إِسْڒَا \add خَاسْ\add*.  
\v 24 ؤُمِي ژْرِينْ مَارَّا إِرْيَازنْ ن إِسْرَائِيل أَرْيَازْ \add نِّي\add*، أَروْڒنْ. نِيثْنِي ڭّْوذنْ أَطَّاسْ.  
\v 25 نَّانْ يرْيَازنْ ن إِسْرَائِيل: ”مَا ثژْرِيمْ كنِّيوْ مَامّشْ إِ د-إِڭعّذْ ورْيَازْ نِّي؟ نتَّا إِڭعّذْ-د حِيمَا أَذْ إِسْثهْزَا زِي إِسْرَائِيل. أَرْيَازْ ونِّي ث إِ غَا إِغڒْبنْ، أَذْ ث يَارّْ ؤُجدْجِيذْ ذ بُو-وَاڭْڒَا أَمقّْرَانْ. نتَّا أَذْ أَسْ إِوْشْ يدْجِيسْ ؤُ أَذْ إِكّسْ خْ \add ڒَْادْجْ ن\add* ثَادَّارْثْ ن بَابَاسْ ضَّارِيبَا ذِي إِسْرَائِيل.“  
\v 26 \add خنِّي\add* إِسِّيوڒْ ذَاوُوذْ أَكْ-ذ يرْيَازنْ إِنِّي غَارسْ د-إِبدّنْ، إِنَّا: ”مِينْ غَا إِتّْوَاڭّْ إِ ورْيَازْ نِّي إِ غَا إِوْثنْ أَفِيلِيسْطِينِي-أَيَا، ونِّي إِ غَا إِكّسْ أَسْثهْزِي خْ إِسْرَائِيل؟ مِينْ إِعْنَا أَفِيلِيسْطِينِي-أَيَا إِ وَارْ إِتّْوَاخثْننْ، أَقَا إِسْثهْزَا خْ إِسذِّييّنْ ن ڒْعسْكَارْ ن أَربِّي إِدَّارنْ؟“  
\v 27 يَارَّا-د خَاسْ ڒْڭنْسْ س وَاوَاڒْ ذ إِجّنْ، نَّانْ: ”ذ مَانْ أَيَا إِ غَا إِتّْوَاڭّْ إِ ورْيَازْ نِّي ث إِ غَا إِغڒْبنْ.“   
\m
\v 28 ؤُمَاسْ أَمقّْرَانْ إِلِييَابْ إِسْڒَا أَسْ إِسَّاوَاڒْ أَكْ-ذ يرْيَازنْ. يَارْغَا ؤُخيّقْ ن إِلِييَابْ خْ ذَاوُوذْ، إِنَّا: ”مَايمِّي إِ د-ثهْوِيذْ شكْ \add ذَانِيثَا\add* ؤُ مَانْ ونْ إِ ؤُمِي ثجِّيذْ ثَاحِيمَارْثْ ثَامژْيَانْثْ ن وُودْجِي ذِي ڒخْڒَا؟ نشّْ سّْنغْ أَعفَّارْ نّشْ ذ ثُوعفّْنَا ن وُوڒْ نّشْ، مِينْزِي شكْ ثهْوِيذْ-د \add ذَانِيثَا\add* حِيمَا أَذْ ثخْزَارذْ غَارْ ؤُمنْغِي.“  
\v 29 ذَاوُوذْ إِنَّا: ”مِينْ ڭِّيغْ ڒخُّو عَاوذْ؟ مَا وَارْ \add إِدْجِي\add* مْغِيرْ إِجّْ ن وَاوَاڒْ \add إِ سّقْسِيغْ\add*؟“  
\v 30 نتَّا إِحيّذْ خَاسْ، إِرُوحْ غَارْ إِجّنْ نّغْنِي، إِسّقْسَا أَسقْسِي ذ إِجّنْ ؤُشَا يَارَّا-د خَاسْ ڒْڭنْسْ س وَاوَاڒْ ذ إِجّنْ أَمْ مَامّشْ د-أَرِّينْ نِيثْنِي ثْوَاڒَا ثَامزْوَارُوثْ.   
\m
\v 31 نِيثْنِي سْڒَانْ إِ وَاوَاڒنْ إِ ثُوغَا إِسَّاوَاڒْ ذَاوُوذْ ؤُشَا سِّيوْڒنْ خْ مَانْ أَيَا زَّاثْ إِ وُوذمْ ن شَاوُولْ ؤُ نتَّا إِجَّا أَذْ ث-إِ-د-أَوْينْ.  
\v 32 إِنَّا ذَاوُوذْ إِ شَاوُولْ: ”ؤُڒَا ذ إِجّْ ن بْنَاذمْ وَارْ إِتّفْشِيڒْ وُوڒْ نّسْ زڭْ ؤُفِيلِيسْطِينِي. أَمْسخَّارْ نّشْ أَذْ يُويُورْ أَذْ إِمّْنغْ أَكْ-ذ ؤُفِيلِيسْطِينِي.“  
\v 33 شَاوُولْ إِنَّا إِ ذَاوُوذْ: ”شكْ وَارْ ثْزمَّارذْ أَذْ ثْرَاحذْ غَارْ ؤُفِيلِيسْطِينِي-أَيَا حِيمَا أَكِيذسْ ثمّنْغذْ، مَاغَارْ شكْ ذ أَحُوذْرِي \add عَاذْ\add*، \add مَاشَا\add* نتَّا ذ أَرْيَازْ أَعسْكَارِي زِي ثمْژِي نّسْ.“  
\v 34 \add خَاسْ ؤُشَا\add* إِنَّا ذَاوُوذْ إِ شَاوُولْ: ”أَمْسخَّارْ نّشْ ثُوغَا يَاركّْوسْ ثَاحِيمَارْثْ ن وُودْجِي ن بَابَاسْ. \add مَاڒَا\add* يُوسَا-د إِجّْ ن ويْرَاذْ نِيغْ إِجّْ ن دُّوبْ، ؤُشَا إِطّفْ إِجّنْ زڭْ وُودْجِي ن ثْحِيمَارْثْ،  
\v 35 \add خنِّي\add* ضْفَارغْ ث، وْثِيغْ ث ؤُ فكّغْ-د \add إِزْمَارْ\add* زڭْ ؤُقمُّومْ نّسْ. \add ڒَْامِي\add* د-إِكَّارْ أَكِيذِي، شبَّارغْ أَسْ ذِي ثْمَارْثْ، وْثِيغْ ث ؤُشَا نْغِيغْ ث.  
\v 36 أَمْسخَّارْ نّشْ إِنْغَا أَيْرَاذْ ؤُڒَا ذ دُّوبْ. أَمُّو إِ غَا يِيڒِي أَكْ-ذ ؤُفِيلِيسْطِينِي-أَيَا إِ وَارْ إِتّْوَاخثْننْ، أَذْ أَسْ ثمْسَارْ أَمْ إِ يِيجّْ ن زَّايْسنْ، مِينْزِي نتَّا إِسْثهْزَا زڭْ إِسذِّييّنْ ن ڒْعسْكَارْ ن أَربِّي إِدَّارنْ.“  
\v 37 إِنَّا ذَاوُوذْ \add عَاوذْ\add*: ”سِيذِي ونِّي ذ أَيِي إِفكّنْ زڭْ إِشقْڒَاضنْ ن وَايْرَاذْ ؤُ زڭْ إِشقْڒَاضنْ ن دُّوبْ، أَذْ أَيِي إِفكّْ زڭْ ؤُفُوسْ ن أَفِيلِيسْطِينِي-أَيَا.“ \add خنِّي\add* إِنَّا شَاوُولْ إِ ذَاوُوذْ: ”ؤُيُورْ، أَذْ كِيذكْ يِيڒِي سِيذِي!“  
\v 38 شَاوُولْ إِسّْيَارْضْ إِ ذَاوُوذْ أَرُّوضْ نّسْ \add ن ؤُمنْغِي\add*، إِڭَّا أَسْ إِجّْ ن لْكَاسْكْ ن نّْحَاسْ خْ ؤُزدْجِيفْ نّسْ ؤُ إِحزّمْ أَسْ س يِيجّْ ن وَارُّوضْ ن وُوزَّاڒْ.  
\v 39 إِشدّْ ذَاوُوذْ سِّيفْ نّسْ ثِيوَا إِ وَارُّوضْ نّسْ، إِنْوَا أَذْ يُويُورْ \add شْوَايْثْ\add*، مِينْزِي وَارْ ث إِقدْجبْعمَّارْصْ. \add خنِّي\add* إِنَّا ذَاوُوذْ إِ شَاوُولْ: ”نشّْ وَارْ زمَّارغْ أَذْ ؤُيُورغْ ذِي ڒحْوَايجْ-أَ، وَارْ ت قدْجْبغْعمَّارْصْ!“ ؤُشَا ذَاوُوذْ إِسَّارْسْ إِ-ثنْثْ عَاوذْ.  
\v 40 إِكْسِي أَعكَّازْ ذڭْ ؤُفُوسْ نّسْ، إِخْضَارْ خمْسَا ن إِژْرَا إِحْنُونّْينْ زِي ثغْزَارْثْ ؤُشَا إِڭَّا إِ-ثنْ ذِي ثشْيَارْثْ نّسْ ن ثَاروْسَا إِ غَارسْ ثُوغَا، \add مَاشَا\add* مَانِي ثنْ إِ غَا يَاوضْ ذغْيَا، ؤُ ثُوغَا إِدْجِييْ ذڭْ ؤُفُوسْ نّسْ. \add أَمُّو إِ\add* إِفّغْ غَارْ ؤُمْسَاڭَارْ أَكْ-ذ ؤُفِيلِيسْطِينِي.  
\v 41 أَفِيلِيسْطِينِي يُويُورْ، إِقَارّبْ-د غَارْ ذَاوُوذْ ؤُ ونِّي ذ أَسْ يَاربُّونْ ثَاسدَّارْثْ ثَامقّْرَانْثْ إِزْوَارْ أَسْ.  
\v 42 \add ؤُمِي\add* د إِسّْڭعّذْ ؤُفِيلِيسْطِينِي ثَامُوغْڒِي نّسْ، إِژْرَا ذَاوُوذْ، إِسّحْقَارْ إِ-ث، مَاغَارْ ذَاوُوذْ ثُوغَا ذ أَحُوذْرِي عَاذْ، نتَّا ثُوغَا أَرُّوبْيُو ذ مُوصْبِيحْ إِ ڒْخزْرَاثْ.  
\v 43 أَفِيلِيسْطِينِي إِنَّا إِ ذَاوُوذْ: ”مَا نشّْ ذ إِجّْ ن وقْزِينْ، أَقَا شكْ ثُوسِيذْ-د غَارِي س إِكشْوَاضْ؟“ ؤُشَا أَفِيلِيسْطِينِي ثُوغَا إِنعّڒْ خْ ذَاوُوذْ غَارْ إِربِّيثنْ نّسْ.  
\v 44 إِنَّا ؤُفِيلِيسْطِينِي \add عَاوذْ\add* إِ ذَاوُوذْ: ”أَسْ-د غَارِي، \add خنِّي\add* نشّْ أَذْ وْشغْ أَيْسُومْ نّشْ، \add مَاحنْذْ أَذْ ث صَارْضنْ\add* إِجْضَاضْ ن ؤُجنَّا ذ ڒْمَاڒْ ن ڒخْڒَا.“   
\m
\v 45 \add خنِّي\add* إِنَّا ذَاوُوذْ إِ ؤُفِيلِيسْطِينِي: ”شكْ ثُوسِيذْ-د غَارِي س سِّيفْ ذ لَانْسَا ذ ؤُحْرِيشْ، مَاشَا نشّْ ؤُسِيغْ-د غَاركْ ذڭْ يِيسمْ ن سِيذِي ن ڒْعسْكَارَاثْ، أَربِّي ن إِسذِّييّنْ ن ڒْعسْكَارْ ن إِسْرَائِيل نِّي زِي ثسْثهزِّيذْ.“  
\v 46 أَسّْ-أَ أَذْ شكْ إِڭّْ سِيذِي ذڭْ ؤُفُوسْ إِنُو. نشّْ أَذْ شكْغڒْبغْ. أَذْ أَشْ كّْسغْ أَزدْجِيفْ ؤُ ذڭْ وَاسّْ-أَ أَذْ وْشغْ ڒْخشْبَاثْ ن ڒْعسْكَارْ ن إِفِيلِيسْطِينِييّنْ، \add مَاحنْذْ أَذْ ثنْثْ صَارْضنْ\add* إِجْضَاضْ ن ؤُجنَّا ذ ڒْمَاڒْ نْ ڒخْڒَا. مَارَّا دُّونشْثْ أَذْ ثسّنْ أَقَا إِسْرَائِيل غَارسْ إِجّْ ن أَربِّي.  
\v 47 ؤُڒَا ذ مَارَّا أَڭْرَاوْ-أَ \add ن ڒْڭنْسْ\add* أَذْ إِسّنْ أَقَا سِيذِي وَارْ إِتّْفكِّي س سِّيفْ ؤُڒَا س لَانْسَا، مَاغَارْ أَمنْغِي ن سِيذِي ؤُ نتَّا أَذْ شكْ إِڭّْ ذڭْ إِفَاسّنْ نّغْ.“ \f ◼ \fr 17:‏47 \ft \+bd ’ذڭْ إِفَاسّنْ نّغْ‘\+bd* - س ثْعِيبْرَانِيثْ ’ذڭْ ؤُفُوسْ نّغْ‘.\f*  
\v 48 ؤُشَا إِمْسَارْ، ؤُمِي أَفِيلِيسْطِينِي إِكَّارْ، إِقَارّبْ-د غَارْ ذَاوُوذْ، ذَاوُوذْ إِڭَّا س ثَازْڒَا ؤُشَا يُوزّڒْ غَارْ ؤُسذِّي ن ڒْعسْكَارْ \add ن ڒعْذُو\add* إِ ؤُمْسَاڭَارْ أَكْ-ذ ؤُفِيلِيسْطِينِي.  
\v 49 إِوْثَا ذَاوُوذْ غَارْ ثشْيَارْثْ نّسْ ن ثَاروْسَا، إِكّسْ-د إِجّْ ن وژْرُو، إِحجَّارْ \add إِ-ث\add* س إِدْجِييْ ؤُشَا إِڒْقفْ أَفِيلِيسْطِينِي ذِي ثنْيَارْثْ نّسْ. أَژْرُو إِنْذفْ إِ ثنْيَارْثْ نّسْ أَڒَامِي إِوْضَا نتَّا خْ ؤُغمْبُوبْ نّسْ غَارْ ثمُّورْثْ.  
\v 50 أَمُّو إِ إِغْڒبْ ذَاوُوذْ خْ ؤُفِيلِيسْطِينِي س إِجّْ ن يِيدْجِييْ ذ إِجّْ ن وژْرُو. نتَّا إِڒْقفْ أَفِيلِيسْطِينِي، إِنْغَا إِ-ث. وَارْ غَارسْ ثُوغِي إِ ذَاوُوذْ قَاعْ سِّيفْ ذڭْ ؤُفُوسْ نّسْ.  
\v 51 \add خنِّي\add* يُوزّڒْ ذَاوُوذْ \add ذِينْ\add* غَارْ ؤُفِيلِيسْطِينِي ؤُ \add ؤُمِي\add* د-إِبدّْ \add زَّاثسْ\add*، إِطّفْ سِّيفْ نّسْ، إِجْبذْ إِ-ث-إِ-د زڭْ وغْرَافْ، إِنْغَا إِ-ث، ؤُشَا إِقسّْ أَسْ أَزدْجِيفْ س سِّيفْ نّسْ. \add ؤُمِي\add* ژْرِينْ إِفِيلِيسْطِينِييّنْ، أَقَا بُو-ثغْرُوضْثْ نْسنْ إِمُّوثْ، أَروْڒنْ نِيثْنِي.  
\v 52 إِرْيَازنْ ن إِسْرَائِيل ذ يَاهُوذَا كَّارنْ، سْغُوينْ أَڒَاغِي ن ؤُمنْغِي ؤُشَا ضْفَارنْ إِفِيلِيسْطِينِييّنْ أَڒْ جَاثْ ؤُ أَڒْ ثِيوُّورَا ن عَاقْرُونْ. إِنِّي إِتّْوَانْغنْ زڭْ إِفِيلِيسْطِينِييّنْ وْضَانْ ذڭْ وبْرِيذْ زِي شَاعَارَايِيمْ أَڒْ جَاثْ ذ عَاقْرُونْ.  
\v 53 \add أَوَارْنِي أَيَا\add*عقْبنْ-د أَيْثْ ن إِسْرَائِيل زڭْ وضْفَارْ س وشْنَاقْ ن إِفِيلِيسْطِينِييّنْ ؤُشَا كشّْضنْ ڒمْرَاڭحْ ن ڒْعسْكَارْ نْسنْ.  
\v 54 إِكْسِي ذَاوُوذْ أَزدْجِيفْ ن ؤُفِيلِيسْطِينِي، يِيوْيِي ث غَارْ ؤُرْشَالِيمْ، \add مَاشَا\add* ڒسْنَاحْ نّسْ إِڭَّا إِ-ثنْ ذڭْ ؤُقِيضُونْ نّسْ. \f ◼ \fr 17:‏54 \ft \+bd ’ڒسْنَاحْ نّسْ‘\+bd* - إِخْسْ أَذْ يِينِي ’ڒسْنَاحْ ن جُولْيَاثْ‘.\f*   
\m
\v 55 \add ؤُمِي\add* إِژْرَا شَاوُولْ أَقَا ذَاوُوذْ إِڭُّورْ غَارْ ؤُمْسَاڭَارْ أَكْ-ذ ؤُفِيلِيسْطِينِي، إِنَّا نتَّا إِ أَبْنِيرْ، أَكُومَانْذَارْ ن ڒْعسْكَارْ: ”ؤُمِي إِڭَّا مِّيسْ ؤُحُوذْرِي-يَا؟“ أَبْنِيرْ يَارَّا-د خَاسْ: ”س ثِيذتّْ أَمْ إِدَّارْ ڒعْمَارْ نّشْ، \add أَ\add* أَجدْجِيذْ، نشّْ وَارْ ث سِّينغْ.“  
\v 56 أَجدْجِيذْ إِنَّا: ”سقْسَا \add خنِّي\add* ؤُمِي إِڭَّا مِّيسْ ؤُحُوضْرِي-يَا!“  
\v 57 \add ؤُمِي\add* د-إِعْقبْ ذَاوُوذْ أَوَارْنِي إِ ؤُمِي ثُوغَا إِغْڒبْ خْ ؤُفِيلِيسْطِينِي، يِيوْيِي ث أَكِيذسْ أَبْنِيرْ، إِنْذهْ إِ-ث غَارْ شَاوُولْ. ذَاوُوذْ ثُوغَا غَارسْ عَاذْ أَزدْجِيفْ ن ؤُفِيلِيسْطِينِي ذڭْ ؤُفُوسْ نّسْ.  
\v 58 شَاوُولْ إِسّقْسَا ث: ”ؤُمِي ثڭِّيذْ مِّيسْ شكْ، \add أَ\add* أَحُوذْرِي؟“ ذَاوُوذْ يَارَّا-د خَاسْ: ”مِّيسْ ن ؤُمْسخَّارْ نّشْ، \add ن\add* يَاسَّا زِي بَايْثْ-لَاحْمْ.“   
\b  
\b  
\m  
\c 18
\s1 ڒعْذَاوَاثْ ن شَاوُولْ ضِيدّْ إِ ذَاوُوذْ  
\m
\v 1 ؤُمِي إِكمّڒْ \add ذَاوُوذْ\add* ڒْهَارْذْ أَكْ-ذ شَاوُولْ، إِمْسَارْ، أَقَا ڒعْمَارْ ن يُونَاثَانْ إِقّنْ غَارْ ذَاوُوذْ، ؤُ يُونَاثَانْ إِتّخْسْ ذَاوُوذْ أَمْ ڒعْمَارْ نّسْ.  
\v 2 شَاوُولْ إِكْسِي غَارسْ ذَاوُوذْ ذڭْ وَاسّْ نِّي ؤُ وَارْ ث إِجِّي عَاذْ أَذْ إِعْقبْ غَارْ ثَادَّارْثْ ن بَابَاسْ.  
\v 3 يُونَاثَانْ إِڭَّا إِجّْ ن ڒْعَاهْذْ أَكْ-ذ ذَاوُوذْ، مِينْزِي نتَّا إِتّخْسْ إِ-ث أَمْ يِيخفْ نّسْ.  
\v 4 يُونَاثَانْ إِكّسْ أَسڒْهَامْ نّسْ إِ ثُوغَا يَارْضْ، إِوْشَا إِ-ث إِ ذَاوُوذْ، ؤُڒَا ذ أَرُّوضْ نّسْ، \add ؤُشَا\add* عَاوذْ سِّيفْ نّسْ ذ ڒْقوْسْ نّسْ ذ وبْيَاسْ نّسْ \add إِ ڒسْنَاحْ\add*.  
\v 5 ذَاوُوذْ إِفّغْ \add غَارْ ؤُمنْغِي\add* مَانِي مَا إِسّكّْ إِ-ث شَاوُولْ. ثُوغَا أَبْرِيذْ نّسْ مْلِيحْ أَڒَامِي ث يَارَّا شَاوُولْ خْ إِعسْكَارِييّنْ نّسْ. ثُوغَا \add ذَاوُوذْ\add* ذ لمْلِيحْ ذِي ثِيطَّاوِينْ ن مَارَّا ڒْڭنْسْ ؤُڒَا ذِي ثِيطَّاوِينْ ن إِمْسخَّارنْ ن شَاوُولْ.  
\v 6 \add خْمِي\add* د-ؤُسِينْ ؤُمِي يَارڭّْوحْ ذَاوُوذْ أَوَارْنِي إِ ڒغْڒبْ خْ إِفِيلِيسْطِينِييّنْ، إِمْسَارْ، أَقَا فّْغنْثْ-إِ-د ثمْغَارِينْ زِي مَارَّا ثِيندَّامْ ن إِسْرَائِيل إِ ؤُمْسَاڭَارْ أَكْ-ذ شَاوُولْ ؤُشَاغنّْجنْثْ ؤُ شضْحنْثْ س إِبنْذِيرنْ، س ڒفْرَاحثْ ؤُ س ڒْڭَامْبْرِييَاثْ س ثْڒَاثَا ن إِفِيڒَانْ.  
\v 7 ثِيمْغَارِينْ أَرِّينْثْ مژْرِي نْسنْثْ،غنّْجنْثْ س نُّوبْثَاثْ، نَّانْثْ: ”شَاوُولْ إِغْڒبْ خْ ڒُوڒُوفْ نّسْ، مَاشَا ذَاوُوذْ خْعشْرَا ن ڒُوڒُوفْ نّسْ!“ \x ◘ \xo 18:‏7 \xt ؤُف. 15‏:‏21؛ 1 صم. 21‏:‏11؛ 29‏:‏5\x*  
\v 8 شَاوُولْ إِفُّوڭمْ أَطَّاسْ. ثُوغَا ذ مَانْ أَيَا ذ ڒْعِيبْ ذِي ثِيطَّاوِينْ نّسْ، إِنَّا: ”وْشِينْثْ إِ ذَاوُوذْعشْرَا ن ڒُوڒُوفْ، مَاشَا وْشِينْثْ أَيِي مْغِيرْ ڒُوڒُوفْ. \add مَاشَا\add* ثقِّيمْ أَسْ مْغِيرْ ثْڭلْذَا \add وَاهَا\add*؟“  
\v 9 زڭْ وَاسّْ نِّي سنّجْ إِبْذَا شَاوُولْ إِحطَّا ذَاوُوذْ.   
\m
\v 10 ثِيوشَّا نّسْ إِمْسَارْ، أَقَا إِوْضَا-د عَاوذْ ڒَارْيَاحْ ذ أَعفَّانْ ن أَربِّي خْ شَاوُولْ، ؤُ إِذْوڒْ إِتّكّْ خْ ؤُزدْجِيفْ ذِي ثَادَّارْثْ نّسْ، أَمْ ثُوغَا إِتِّيرَارْ ذَاوُوذْ أَمْ وُوسَّانْ نّغْنِي س ؤُفُوسْ نّسْ \add خْ ڒْڭَامْبْرِي\add*. شَاوُولْ ثُوغَا غَارسْ لَانْسَا ذڭْ ؤُفُوسْ.  
\v 11 شَاوُولْ إِنْضَارْ لَانْسَا، إِنَّا: ”نشّْ أَذْ ڒقْفغْ ذَاوُوذْ ؤُ \add أَذْ ث سمَّارغْ\add* غَارْ ڒْحِيضْ.“ إِزمَّارْ ذَاوُوذْ أَذْ أَسْ إِخْنسْ ثْنَاينْ ن ثْوَاڒَاوِينْ.  
\v 12 ثُوغَا شَاوُولْ إِتّڭّْوذْ زِي ذَاوُوذْ، مِينْزِي سِيذِي ثُوغَا-ث أَكْ-ذ ذَاوُوذْ، مَاشَا ثُوغَا إِسْمحْ ذِي شَاوُولْ.  
\v 13 س ؤُينِّي إِسِّيڭّْوجْ شَاوُولْ \add ذَاوُوذْ\add* خْ يِيخفْ نّسْ، إِڭَّا إِ-ث ذ أَمقّْرَانْ خْ وَاڒفْ. نتَّا إِتّفّغْ ؤُ إِتَّارڭّْوَاحْ زَّاثْ إِ وُوذمْ ن ڒْڭنْسْ.  
\v 14 ثُوغَا ذَاوُوذْ إِفْڒحْ ذِي مَارَّا إِبْرِيذنْ نّسْ ؤُ سِيذِي ثُوغَا-ث أَكِيذسْ.   
\m
\v 15 \add ؤُمِي\add* إِژْرَا شَاوُولْ، أَقَا ذَاوُوذْ إِفْڒحْ، ثُوغَا نتَّا إِتّڭّْوذْ زَّاثْ إِ وُوذمْ نّسْ.  
\v 16 \add مَاشَا\add* مَارَّا إِسْرَائِيل ذ يَاهُوذَا تّخْسنْ ذَاوُوذْ، مِينْزِي نتَّا إِتّفّغْ ؤُ إِتَّارڭّْوَاحْ زَّاثْ إِ وُوذمْ نْسنْ.   
\m
\v 17 شَاوُولْ إِنَّا إِ ذَاوُوذْ: ”خْزَارْ، نشّْ أَذْ أَشْ وْشغْ مِيرَابْ، يدْجِي ثَامقّْرَانْثْ قَاعْ، ذ ثَامْغَارْثْ. مْغِيرْ إِڒِي ذ إِجّْ ن ؤُضڭّْوَاڒْ إِمْحضْ \add ذڭْ ؤُمنْغِي\add* إِ نشّْ ؤُ مْنغْ إِمنْغَانْ ن سِيذِي.“ إِنَّا شَاوُولْ \add أَكْ-ذ يِيخفْ نّسْ\add*: ”حِيمَا وَارْ إِتِّيڒِي ؤُفُوسْ إِنُو ضِيدّْ نّسْ، مَاشَا أَفُوسْ ن إِفِيلِيسْطِينِييّنْ أَذْ يِيڒِي ضِيدّْ نّسْ.“  
\v 18 إِنَّا ذَاوُوذْ إِ شَاوُولْ: ”مِينْ عْنِيغْ نشّْ ذ مِينْ ثعْنَا ثُوذَارْثْ إِنُو ذ مِينْ ثعْنَا ڒَادْجْ ن بَابَا ذِي إِسْرَائِيل، أَقَا نشّْ أَذْ ذوْڒغْ ذ أَضڭّْوَاڒْ ن ؤُجدْجِيذْ؟“  
\v 19 ؤُمِي د-ثِيوضْ ڒْوقْثْ إِ ذِي إِ غَا ثمّوْشْ مِيرَابْ، يدْجِيسْ ن شَاوُولْ، ذ ثَامْغَارْثْ إِ ذَاوُوذْ، إِمْسَارْ، أَقَا ثمّوْشْ نتَّاثْ ذ ثَامْغَارْثْ إِ عَاذْرِييِيلْ زِي مَاحُولَا.  
\v 20 مِيخَالْ، يدْجِيسْ ن شَاوُولْ، ثُوغَا ثتّخْسْ ذَاوُوذْ. خبَّارنْ أَسْ ث إِ شَاوُولْ ؤُ ثُوغَا أَيَا ذ إِشْثْ ن ثْمسْڒَاشْثْ ثشْنَا ذِي ثِيطَّاوِينْ نّسْ.  
\v 21 إِنَّا شَاوُولْ: ”نشّْ أَذْ أَسْ ت وْشغْ، حِيمَا أَذْ أَسْ إِذْوڒْ ذ ڒْفخْ ؤُ حِيمَا أَذْ يِيڒِي ؤُفُوسْ ن إِفِيلِيسْطِينِييّنْ ضِيدّْ نّسْ.“ إِنَّا شَاوُولْ إِ ذَاوُوذْ: ”أَسّْ-أَ ثْزمَّارذْ أَذْ ثْذوْڒذْ ذ أَضڭّْوَاڒْ إِنُو س ثنِّي ذ وِيسّْ ثْنَاينْ.“ \f ◼ \fr 18:‏21 \ft \+bd ’أَضڭّْوَاڒْ‘\+bd* - إِخْسْ أَذْ يِينِي أَقَا شَاوُولْ إِوَاعْذْ إِ ذَاوُوذْ بلِّي وَانِيثَا أَذْ إِذْوڒْ ذ مِّيسْ نّسْ س ڒمْرَاشْ أَكْ-ذ يسِّيسْ.\f*  
\v 22 يُومُورْ شَاوُولْ إِ إِمْسخَّارنْ نّسْ: ”سِيوڒْ أَكْ-ذ ذَاوُوذْ ذِي ثْنُوفّْرَا، إِنِي: ’أَقَا شكْ ثُوسِيذْ-د إِ ؤُجدْجِيذْ خْ ڒْخَاضَارْ ؤُ مَارَّا إِمْسخَّارنْ تّخْسنْ شكْ. \add خنِّي\add* ذْوڒْ ڒخُّو ذ أَضڭّْوَاڒْ ن ؤُجدْجِيذْ.‘ “  
\v 23 سِّيوْڒنْ إِمْسخَّارنْ ن شَاوُولْ أَوَاڒنْ-أَ ذڭْ إِمزُّوغنْ ن ذَاوُوذْ. \add خنِّي\add* إِنَّا ذَاوُوذْ: ”مَا ذ ثَامسْڒَاشْثْ ثهْونْ ذِي ثِيطَّاوِينْ نْومْ أَذْ إِذْوڒْ إِجّْ ذ أَضڭّْوَاڒْ ن ؤُجدْجِيذْ؟ مَا وَارْ دْجِيغْ ذ إِجّْ ن ورْيَازْ ذ أَمزْڒُوضْ ذ أَمُوقْڒِيڒْ؟“  
\v 24 إِمْسخَّارنْ ن شَاوُولْ حَاجَانْ أَسْ ث، نَّانْ: ”إِسِّيوڒْ ذَاوُوذْ أَوَاڒنْ-أَ.“  
\v 25 \add خنِّي\add* إِنَّا شَاوُولْ: ”أَمُّو إِ غَا ثِينِيمْ إِ ذَاوُوذْ: ’أَجدْجِيذْ وَارْ ذ أَسْ ثعْجِيبْ صَّاذَاقْ، مَاشَا \add إِعْجبْ أَسْ\add* مْيَا ن ڒعْذَاڒيَّاثْ ن إِفِيلِيسْطِينِييّنْ، حِيمَا أَذْ إِنْثَاقمْ زِي ڒْعذْيَانْ ن ؤُجدْجِيذْ.“ ثُوغَا شَاوُولْ إِتّْخَارَّاصْ أَذْ إِنغْ ذَاوُوذْ س ؤُفُوسْ ن إِفِيلِيسْطِينِييّنْ.   
\m
\v 26 إِخدَّامنْ نّسْ عَاوْذنْ أَوَاڒنْ-أَ إِ ذَاوُوذْ. \add خنِّي\add* ثُوغَا أَيَا ذ إِشْثْ ن ثْمسْڒَاشْثْ ثشْنَا ذِي ثِيطَّاوِينْ ن ذَاوُوذْ، حِيمَا أَذْ إِذْوڒْ ذ أَضڭّْوَارْ ن ؤُجدْجِيذْ. ڒْمِيجَاڒْ ن وُوسَّانْ \add إِتّْوَاڭّنْ\add* ثُوغَا عَاذْ وَارْ عْذُونْ.  
\v 27 \add خنِّي\add* إِكَّارْ ذَاوُوذْ. نتَّا ذ يرْيَازنْ نّسْ طّْفنْ أَبْرِيذْ، ؤُشَا إِوْثَا نتَّا مِيثَاينْ ن يرْيَازنْ ن إِفِيلِيسْطِينِييّنْ. يِيوِي-د ذَاوُوذْ ڒعْذَاڒيَّاثْ نْسنْ ؤُ س ؤُيَا سدّنْ نِيثْنِي قَاعْ \add ڒْْقدّْ-أَ\add* إِ ؤُجدْجِيذْ، حِيمَا أَذْ إِذْوڒْ ذ أَضڭّْوَاڒْ ن ؤُجدْجِيذْ. \add خنِّي\add* إِوْشَا أَسْ شَاوُولْ يدْجِيسْ مِيخَالْ ذ ثَامْغَارْثْ. \x ◘ \xo 18:‏27 \xt 2 صم. 3‏:‏14\x*  
\v 28 شَاوُولْ إِژْرَا ؤُ إِسّنْ، أَقَا سِيذِي ثُوغَا-ث أَكْ-ذ ذَاوُوذْ، ؤُ مِيخَالْ، يدْجِيسْ ن شَاوُولْ، ثُوغَا ثتّخْسْ إِ-ث.  
\v 29 إِذْوڒْ شَاوُولْ إِڭّْوذْ عَاذْ كْثَارْ زِي ذَاوُوذْ ؤُشَا شَاوُولْ إِذْوڒْ ذ ڒعْذُو ن ذَاوُوذْ مَارَّا ؤُسَّانْ \add ن ثُوذَارْثْ نّسْ\add*.   
\m
\v 30 ؤُمِي د-فّْغنْ ڒْحُوكَّامْ ن إِفِيلِيسْطِينِييّنْ، إِمْسَارْ، مڒْمِي مَا فّْغنْ ثُوغَا ذَاوُوذْ يَارنِّي مَاهُو ذِي وفْڒَاحْ نّسْ خْ مَارَّا إِمْسخَّارنْ ن شَاوُولْ، أَڒَامِي إِذْوڒْ إِسمْ نّسْ إِشنّْعنْ أَڒْ طَّارْفْ.   
\b  
\b  
\m  
\c 19
\s1 ذَاوُوذْ يَارْوڒْ زِي شَاوُولْ  
\m
\v 1 إِسِّيوڒْ شَاوُولْ أَكْ-ذ مِّيسْ يُونَاثَانْ ؤُ أَكْ-ذ إِمْسخَّارنْ نّسْ بلِّي إِتّْخصَّا أَذْ نْغنْ ذَاوُوذْ. \add مَاشَا\add* يُونَاثَانْ، مِّيسْ ن شَاوُولْ، ثُوغَا إِسّْعِيزّْ خَاسْ ذَاوُوذْ أَطَّاسْ.  
\v 2 إِحَاجَا يُونَاثَانْ خْ ؤُيَا إِ ذَاوُوذْ، إِنَّا: ”بَابَا شَاوُولْ يَارزُّو أَذْ شكْ إِنغْ. خنِّي ڒخُّو، رَاجَا أَڒْ ثِيوشَّا. أَذفْ غَارْ ومْشَانْ ن ؤُسْنفَّارْ ؤُ خمّڒْ إِخفْ نّشْ.  
\v 3 نشّْ أَذْ فّْغغْ، أَذْ بدّغْ أَكْ-ذ بَابَا ذڭْ وحْوِيشْ مَانِي غَا ثِيڒِيذْ شكْ. أَذْ خَاكْ سِّيوْڒغْ أَكْ-ذ بَابَا، أَذْ خْزَارغْ مَامّشْ ڭُّورنْثْ ثْمسْڒَايِينْ. \add خنِّي\add* أَذْ شكْ سَّارْڭْبغْ.“   
\m
\v 4 يُونَاثَانْ إِسِّيوڒْ س ثِيزِي ن ذَاوُوذْ أَكْ-ذ بَابَاسْ، إِنَّا أَسْ: ”إِتّْخصَّا ؤُجدْجِيذْ وَارْ إِتّڭّْ شَا دّنْبْ ذڭْ ؤُمْسخَّارْ نّسْ ذَاوُوذْ، مَاغَارْ ؤُڒَا ذ نتَّا وَارْ ذَايكْ إِڭِّي شَا دّنْبْ، ؤُ ثِيمڭَّا نّسْ أَقَا أَثنْثْ ذ ڒفْضڒْ إِ شكْ أَطَّاسْ.  
\v 5 نتَّا إِسبّڒْ ثُوذَارْثْ نّسْ، إِغْڒبْ خْ ؤُفِيلِيسْطِينِي ؤُ سِيذِي يِيوِيضْ إِجّْ ن ؤُسنْجمْ ذ أَمقّْرَانْ إِ مَارَّا إِسْرَائِيل. شكْ ثژْرِيذْ ث سِيمَانْثْ نّشْ ؤُ ثْفَارْحذْ. مَايمِّي ثخْسذْ أَذْ ثخْضِيذْ خْ إِذَامّنْ إِمزْذَاڭنْ أَڒَامِي غَا ثنْغذْ ذَاوُوذْ بْڒَا سِّيبّثْ؟“  
\v 6 شَاوُولْ إِسْڒَا غَارْ يُونَاثَانْ ؤُ شَاوُولْ إِجِّيدْجْ: ”س ثِيذتّْ أَمْ إِدَّارْ سِيذِي، نتَّا وَارْ إِتّْوَانقّْ شَا!“ \f ◼ \fr 19:‏6 \ft \+bd ’غَارْ يُونَاثَانْ‘\+bd* - س ثْعِيبْرَانِيثْ ’غَارْ ثْمِيجَّا ن يُونَاثَانْ‘.\f*  
\v 7 ؤُشَا إِڒَاغَا يُونَاثَانْ خْ ذَاوُوذْ، إِحَاجَا أَسْ يُونَاثَانْ مَارَّا أَوَاڒنْ-أَ. \add خنِّي\add* إِنْذهْ يُونَاثَانْ ذَاوُوذْ غَارْ شَاوُولْ ؤُ نتَّا ثُوغَا-ث زَّاثْ إِ وُوذمْ نّسْ أَمْ إِضنَّاضْ ذ فَارِيضنَّاضْ.   
\m
\v 8 يِيوضْ-د ؤُمنْغِي عَاوذْ ؤُشَا إِفّغْ ذَاوُوذْ، إِمّْنغْ أَكْ-ذ إِفِيلِيسْطِينِييّنْ. نتَّا إِهتّكْ إِ-ثنْ س إِشْثْ ن ثشْثِي ذ ثَامقّْرَانْثْ ؤُ نِيثْنِي طّْفنْ ثَاروْڒَا زَّاثْ إِ وُوذمْ نّسْ.   
\m
\v 9 مَاشَا ڒَارْيَاحْ ذ أَعفَّانْ ن سِيذِي إِوْضَا-د \add عَاوذْ\add* خْ شَاوُولْ. ؤُمِي نتَّا إِقِّيمْ ذِي ثَادَّارْثْ نّسْ، إِمْنعْ لَانْسَا ذڭْ ؤُفُوسْ نّسْ ؤُمِي ثُوغَا ذَاوُوذْ إِتِّيرَارْ س ؤُفُوسْ نّسْ \add خْ ڒْڭَامْبْرِي\add*. \x ◘ \xo 19:‏9 \xt 1 صم. 16‏:‏14؛ 18‏:‏10\x*  
\v 10 شَاوُولْ ثُوغَا يَارزُّو أَذْ إِسمَّارْ ذَاوُوذْ ذِي ڒْحِيضْ س لَانْسَا نّسْ، مَاشَا نتَّا إِخْنسْ أَسْ إِ شَاوُولْ ؤُ نتَّا إِڒْقفْ ڒْحِيضْ س لَانْسَا. ذَاوُوذْ يَارْوڒْ، إِسّنْجمْ إِخفْ نّسْ دْجِيڒثْ نِّي.   
\m
\v 11 إِسّكّْ شَاوُولْ إِرقَّاسنْ غَارْ ثَادَّارْثْ ن ذَاوُوذْ، حِيمَا أَذْ ث حْضَانْ ؤُ أَذْ ث نْغنْ غَارْ ثُوفُّوثْ. \add مَاشَا\add* مِيخَالْ، ثَامْغَارْثْ ن ذَاوُوذْ، ثْحَاجَا \add خَاسْ\add* إِ ذَاوُوذْ، ثنَّا: ”مَاڒَا شكْ وَارْ ثسّْنجْمذْ إِخفْ نّشْ ذِي دْجِيڒثْ-أَ، أَذْ ثتّْوَانْغذْ ثِيوشَّا.“  
\v 12 مِيخَالْ ثسّهْوَا ذَاوُوذْ زِي ڒْكَازِي. \add خنِّي\add* يُويُورْ، يَارْوڒْ ؤُشَا إِسّنْجمْ إِخفْ نّسْ.  
\v 13 \add خنِّي\add* ثكْسِي مِيخَالْ إِجّْ ن ڒخْيَاڒْ ن صَّانَامْ، ثسَّارْسْ \add إِ-ث\add* ذِي قَامَا ؤُشَا ثڭَّا إِشْثْ ن ثْهِيضُورْثْ ن شْعَارْ ن إِغَايْضْ غَارْ مَانِي إِدْجَا ؤُزدْجِيفْ ؤُ ثذْڒَا \add إِ-ث\add* س يِيجّْ ن وَارُّوضْ.   
\m
\v 14 شَاوُولْ إِسّكّْ إِرقَّاسنْ مَاحنْذْ أَذْ د-أَوْينْ ذَاوُوذْ، \add مَاشَا\add* نتَّاثْ ثنَّا: ”نتَّا إِهْڒشْ.“  
\v 15 \add خنِّي\add* إِسّكّْ شَاوُولْ إِرقَّاسنْ مَاحنْذْ أَذْ سِّيجّنْ خْ ذَاوُوذْ، إِنَّا: ”أَوْيمْ ث-إِ-د ذِي ثَاسُّوثْ غَارِي ذَا، حِيمَا أَذْ ث نْغغْ.“  
\v 16 ؤُمِي د-ؤُسِينْ إِرقَّاسنْ، خْزَارْ، أَقَا ذِينْ إِجّْ ن ڒخْيَاڒْ ن صَّانَامْ ذِي قَامَا ذ إِشْثْ ن ثْهِيضُورْثْ ن شْعَارْ ن إِغَايْضْ غَارْ مَانِي إِدْجَا ؤُزدْجِيفْ نّسْ.  
\v 17 ؤُشَا إِنَّا شَاوُولْ إِ مِيخَالْ: ”مَايمِّي ذ أَيِي ثغْذَارذْ أَمُّو، ثجِّيذْ ڒعْذُو إِنُو أَذْ يَارْوڒْ، أَڒَامِي إِسّنْجمْ إِخفْ نّسْ؟“ مِيخَالْ ثَارَّا-د خْ شَاوُولْ: ”نتَّا إِنَّا أَيِي: ’أجّْ أَيِي أَذْ ؤُيُورغْ، مَايمِّي إِ شمْ إِ غَا نْغغْ؟‘ “   
\m
\v 18 أَمُّو يَارْوڒْ ذَاوُوذْ، إِسّنْجمْ إِخفْ نّسْ ؤُشَا يُوسَا-د غَارْ شَامْوِيلْ ذِي رَامَا، إِحَاجَا أَسْ مَارَّا مِينْ ثُوغَا إِ ذ أَسْ إِڭَّا شَاوُولْ. خنِّي يُويُورْ نتَّا \add جْمِيعْ\add* أَكْ-ذ شَامْوِيلْ، قِّيمنْ ذِي نَايُوثْ.  
\v 19 ؤُشَا حَاجَانْ أَيَا إِ شَاوُولْ، نَّانْ: ”ذَاوُوذْ أَقَا-ث ذِي نَايُوثْ غَارْ رَامَا.“  
\v 20 \add خنِّي\add* إِسّكّْ شَاوُولْ إِرقَّاسنْ، حِيمَا أَذْ أَوْينْ ذَاوُوذْ. نِيثْنِي ژْرِينْ ثَارْبِيعْثْ ن إِنَابِييّنْ نِّي إِتّْنبَّانْ. ثُوغَا شَامْوِيلْ إِبدّْ غَارْسنْ ذ أَمحْضَايْ، ؤُشَا إِهْوَا-د أَرُّوحْ ن أَربِّي خْ إِرقَّاسنْ ن شَاوُولْ أَڒَامِي ؤُڒَا ذ نِيثْنِي بْذَانْ أَذْ نبَّانْ.  
\v 21 \add ؤُمِي\add* إِتّْوَانَّا \add أَيَا\add* إِ شَاوُولْ، إِسّكّْ نتَّا إِرقَّاسنْ نّغْنِي، مَاشَا ؤُڒَا ذ نِيثْنِي بْذَانْ أَذْ نبَّانْ. يَارْنِي شَاوُولْ ذڭْ ؤُسكِّي ن إِرقَّاسنْ إِ ثْوَاڒَا وِيسّْ ثْڒَاثَا، ؤُشَا ؤُڒَا ذ نِيثْنِي بْذَانْ أَذْ نبَّانْ.  
\v 22 \add خَاسْ ؤُشَا\add* يُويُورْ نتَّا سِيمَانْثْ نّسْ غَارْ رَامَا. يِيوضْ نتَّا غَارْ وَانُو أَمقّْرَانْ ذِي سِيخُو، إِسّقْسَا، إِنَّا: ”مَانِي \add دْجَانْ\add* شَامْوِيلْ ذ ذَاوُوذْ؟“ نَّانْ أَسْ: ”خْزَارْ، \add أَقَا أَثنْ\add* ذِي نَايُوثْ غَارْ رَامَا.“  
\v 23 \add خنِّي\add* يُويُورْ ذِينْ غَارْ نَايُوثْ غَارْ رَامَا، ؤُ إِهْوَا-د خَاسْ أَرُّوحْ ن أَربِّي. نتَّا ثُوغَا إِڭُّورْ أَمْ إِتّْنبَّا أَڒْ د-يِيوضْ غَارْ نَايُوثْ غَارْ رَامَا.  
\v 24 ؤُڒَا ذ نتَّا إِكّسْ أَرُّوضْ نّسْ ؤُشَا ؤُڒَا ذ نتَّا إِتّْنبَّا زَّاثْ إِ وُوذمْ ن شَامْوِيلْ. أَسّْ نِّي ذ دْجِيڒثْ ثْمُونْ إِزّڒْ ذِينْ ذ أَقذِّيذْ. خْ ؤُيَا قَّارنْ: ”مَا ؤُڒَا ذ شَاوُولْ جَارْ إِنَابِييّنْ؟“   
\b  
\b  
\m  
\c 20
\s1 ڒْعَاهْذْ جَارْ ذَاوُوذْ ذ يُونَاثَانْ  
\m
\v 1 ذَاوُوذْ يَارْوڒْ زِي نَايُوثْ ثنِّي غَارْ رَامَا ؤُشَا يُوسَا-د غَارْ يُونَاثَانْ، إِنَّا: ”مِينْ ڭِّيغْ نشّْ؟ مَانْ لْجَارِيمَا إِنُو ذ دّنْبْ إِ ذ أَسْ ڭِّيغْ إِ بَابَاشْ، أَقَا نتَّا إِخْسْ أَذْ زَّايِي إِكّسْ ثُوذَارْثْ؟“  
\v 2 إِنَّا أَسْ يُونَاثَانْ: ”وَارْ خَاسْ نسِّيوڒْ! شكْ وَارْ ثتّْمتِّيذْ شَا. خْزَارْ بَابَا وَارْ إِتّڭّْ وَالُو، ؤُڒَا ذ إِشْثْ ن ڒْحَاجّثْ ذ ثَامقّْرَانْثْ نِيغْ ثَامژْيَانْثْ، بْڒَا مَا إِ ذ أَيِي ت غَا إِسَّارْڭبْ. مَايمِّي بَابَا زَّايِي إِ غَا إِسّْنُوفَّارْ ثَامسْڒَاشْثْ-أَ؟ أَيَا وَارْ إِزمَّارْ.“  
\v 3 \add خنِّي\add* إِجُّودْجْ أَسْ ذَاوُوذْ ثْوَاڒَا نّغْنِيثْ، إِنَّا: ”بَابَاشْ إِسّنْ نِيشَانْ، أَقَا ؤُفِيغْ ڒْخَاضَارْ ذِي ثِيطَّاوِينْ نّشْ. \add خْ ؤُيَا\add* إِنَّا: ’وَارْ تّجِّي أَذْ إِسّنْ يُونَاثَانْ مَانْ أَيَا، حِيمَا وَارْ إِكسِّي س ومْنُوسْ!‘ \add خْ ؤُيَا\add*، س ثِيذتّْ أَمْ إِدَّارْ سِيذِي ؤُ أَمْ دَّارغْ نشّْ، أَقَا ذِينْ جَارْ أَيِي ذ ڒْموْثْ مْغِيرْ إِجّْ ن ؤُصُورِيفْ وَاهَا!“   
\m
\v 4 يُونَاثَانْ إِنَّا إِ ذَاوُوذْ: ”مِينْ \add إِدْجَانْ\add* ذڭْ وُوڒْ نّشْ، نشّْ أَذْ أَشْ ث ڭّغْ.“  
\v 5 ذَاوُوذْ يَارَّا-د خْ يُونَاثَانْ: ”خْزَارْ، ثِيوشَّا أَذْ إِبدّْ ؤُيُورْ ؤُشَا إِتّْخصَّا أَيِي أَذْ قِّيمغْ \add غَارْ طَّابْڒَا\add* أَكْ-ذ ؤُجدْجِيذْ أَذْ شّغْ. أوْشْ أَيِي تّسْڒِيحْ حِيمَا أَذْ ؤُيُورغْ مَاحنْذْ أَذْ نُوفَّارغْ ذڭْ إِيَّارْ أَڒْ ثَامذِّيثْ وِيسّْ ثْڒَاثَا.  
\v 6 مَاڒَا يَارْزُو خَافِي بَابَاشْ، إِفْقذْ أَيِي، خنِّي إِنِي: ’ذَاوُوذْ إِحشّمْ أَيِي س وَاطَّاسْ حِيمَا إِزمَّارْ أَذْ إِرَاحْ غَارْ ثنْذِينْثْ نّسْ ذغْيَا، غَارْ بَايْثْ-لَاحْمْ، مِينْزِي ذِينِّي إِ غَا ثِيڒِي ثْغَارْصْثْ ن ؤُسڭّْوَاسْ إِ مَارَّا ڒَادْجْ.‘  
\v 7 مَاڒَا نتَّا خنِّي إِنَّا: ’مْلِيحْ!‘، أَذْ يِيڒِي ڒهْنَا إِ ؤُمْسخَّارْ نّشْ، مَاشَا مَاڒَا يَارْغَا ؤُفُوڭمْ نّسْ، خنِّي أَذْ ثسّْنذْ، أَقَا نتَّا إِڭَّا ذِي ڒْبَاڒْ نّسْ أَذْ \add ذ أَيِي\add* إِڭّْ ڒْغَارْ.  
\v 8 أڭّْ س ثْمخْسِيوْثْ إِشوَّارنْ أَكْ-ذ ؤُمْسخَّارْ نّشْ، مِينْزِي ثسِّيذْفذْ أَمْسخَّارْ نّشْ أَكِيذكْ ذڭْ إِجّْ ن ڒْعَاهْذْ ن سِيذِي. \add مَاشَا\add* مَاڒَا ڭِّيغْ إِشْثْ ن لْجَارِيمَا، نغْ أَيِي شكْ. مَايمِّي ثخْسذْ أَذْ أَيِي ثَاوْيذْ غَارْ بَابَاشْ؟“ \x ◘ \xo 20:‏8 \xt 1 صم. 18‏:‏3\x*  
\v 9 إِنَّا يُونَاثَانْ: ”أَقَا مَانْ أَيَا إِڭّْوجْ خَاكْ! مِينْزِي وَاخَّا أَرڭْبغْ خَاسْ، أَقَا بَابَا إِڭَّا ذِي ڒْبَاڒْ نّسْ أَذْ ذَايكْ إِڭّْ ڒْغَارْ، مَا خنِّي نشّْ وَارْ ذ أَشْ ث قَّارغْ؟“  
\v 10 إِنَّا ذَاوُوذْ إِ يُونَاثَانْ: ”مَانْ ونْ إِ ذ أَيِي د غَا يَاوْينْ أَرقَّاسْ، مَاڒَا إِوْشَا أَشْ بَابَاشْ إِشْثْ ن ثمْوَارِّيثْ ثقْسحْ؟“  
\v 11 \add خنِّي\add* إِنَّا يُونَاثَانْ إِ ذَاوُوذْ: ”أَسْ-د، أجّْ أَنغْ أَذْ نفّغْ بَارَّا غَارْ ييَّارْ.“ ؤُشَا فّْغنْ نِيثْنِي س ثْنَاينْ إِذْسنْ، غَارْ ييَّارْ بَارَّا.   
\m
\v 12 إِنَّا يُونَاثَانْ إِ ذَاوُوذْ: ”\add جُّودْجغْ غَارْ\add* سِيذِي، أَربِّي ن إِسْرَائِيل، مَاڒَا نشّْ ثِيوشَّا نِيغْ فَارْوِيشَّا غَارْ ڒْوقْثْ-أَ، أَقَا وْثِيغْ ڒحْسَابْ أَمُّو ذ وَامُّو \add زِي جِّيهثْ\add* ن بَابَا، ؤُفِيغْ أَقَا مْلِيحْ إِ ذَاوُوذْ ؤُشَا خنِّي نشّْ وَارْ سّكِّيغْ \add حذْ\add* أَذْ أَشْ \add ث\add* يِينِي،  
\v 13 خنِّي أَذْ إِڭّْ سِيذِي ثَا ذ ثَا س يُونَاثَانْ ؤُ أَذْ ذَايسْ يَارْنِي عَاذْ. \add مَاشَا\add* مَاڒَا إِتّْغِيڒْ أَسْ مْلِيحْ إِ بَابَا أَذْ ذَايكْ إِڭّْ ڒْغَارْ، خنِّي نشّْ أَذْ أَشْ ث إِنِيغْ، أَذْ شكْ جّغْ أَذْ ثفّْغذْ حِيمَا \add ثْزمَّارذْ\add* أَذْ ثُويُورذْ ذِي ڒهْنَا. سِيذِي أَذْ يِيڒِي أَكِيذكْ أَمْ مَامّشْ إِ ثُوغَا أَكْ-ذ بَابَا.  
\v 14 \add ؤُشَا خَاكْ،\add* وَارْ إِتِّيڒِي \add وَاهَا\add* أَمْ دَّارغْ، وَارْ إِتِّيڒِي \add خنِّي وَاهَا\add* أَذْ أَيِي ثسّشْنذْ ثَامخْسِيوْثْ إِشوَّارنْ ن سِيذِي حِيمَا وَارْ تّْمتِّيغْ شَا،  
\v 15 \add مَاشَا عَاذْ\add* وَارْ ثْقطّْعذْ ثَامخْسِيوْثْ نّشْ إِشوَّارنْ إِ ڒبْذَا خْ ثَادَّارْثْ إِنُو، ؤُڒَا خْمِي غَا إِقْضعْ سِيذِي مَارَّا ڒْعذْيَانْ ن ذَاوُوذْ زڭْ وُوذمْ ن ثمُّورْثْ!“  
\v 16 ؤُشَا إِڭَّا يُونَاثَانْ إِجّْ ن ڒْعَاهْذْ أَكْ-ذ ثَادَّارْثْ ن ذَاوُوذْ ؤُشَا سِيذِي إِتَّارْ إِ-ث زڭْ ؤُفُوسْ ن ڒْعذْيَانْ ن ذَاوُوذْ.  
\v 17 يُونَاثَانْ إِجَّا ذَاوُوذْ أَذْ إِجَّادْجْ ثْوَاڒَا نّغْنِيثْ، مِينْزِي نتَّا ثُوغَا إِتّخْسْ إِ-ث، أَقَا إِتّخْسْ إِ-ث أَمْ مَامّشْ ثُوغَا إِتّخْسْ إِخفْ نّسْ.   
\m
\v 18 \add خَاسْ ؤُشَا\add* إِنَّا أَسْ يُونَاثَانْ: ”ثِيوشَّا ذ أَيُورْ أَمَايْنُو ؤُ نِيثْنِي وَارْ شكْ تِّيفنْ، مَاغَارْ ڒْكُورْسِي نّشْ أَذْ إِقِّيمْ إِخْوَا.  
\v 19 أَوَارْنِي عْذُونْ ثْڒَاثَا ن وُوسَّانْ إِتّْخصَّا أَذْ ثهْوِيذْ قَاعْ، أَذْ ثْرُوحذْ غَارْ ومْشَانْ مَانِي ثُوغَا ثنُّوفَّارذْ ذڭْ وَاسّْ نِّي ذِي يَارْزُو نتَّا أَذْ شكْ إِنغْ، ؤُ قِّيمْ غَارْ ؤُغزْذِيسْ ن وژْرُو ن هَا‘إِزِيلْ.  
\v 20 نشّْ أَذْ وْثغْ ثْڒَاثَا ن فْڒِيثْشَاثْ زَّاثسْ أَخْمِي خْسغْ أَذْ ڒقْفغْ ثَانْذَايْثْ.  
\v 21 خْزَارْ، نشّْ أَذْ سّكّغْ أَحُوذْرِي \add أَوَارْنِي أَسنْثْ\add*، أَذْ أَسْ إِنِيغْ: ’ؤُيُورْ، أَرْزُو خْ فْڒِيثْشَاثْ!‘ مَاڒَا نشّْ أَذْ إِنِيغْ نِيشَانْ إِ ؤُحُوذْرِي: ’حْضَا، فْڒِيثْشَاثْ أَقَا \add ؤُذْسنْثْ\add* غَارْ ؤُغزْذِيسْ-أَ زِي غَاركْ!‘، \add خنِّي\add* أَوْيِي ثنْثْ-إِ-د، أَسْ-د، مَاغَارْ أَقَا ذِينْ ڒهْنَا إِ شكْ ؤُ وَارْ ذِينْ وَالُو، \add س ثِيذتّْ أَمْ\add* إِدَّارْ سِيذِي!  
\v 22 \add مَاشَا\add* مَاڒَا نشّْ نِّيغْ إِ ؤُحُوذْرِي: ’خْژَارْ، فْڒِيثْشَاثْ أَقَا أَڭّْوجنْثْ خَاكْ \add عَاذْ\add* كْثَارْ!‘، خنِّي أَڭّْوجْ، مَاغَارْ سِيذِي إِسّكَّا شكْ غَارْ ڒَاڭّْوَاجْ.  
\v 23 ؤُشَا \add خْ\add* وَاوَاڒْ إِ نكّسْ، نشّْ ذ شكْ، أَقَا سِيذِي أَذْ يِيڒِي \add ذ أَشهَّاذْ\add* جَارْ أَيِي ذ شكْ إِ ڒبْذَا!“   
\m
\v 24 إِسّْنُوفَّارْ ذَاوُوذْ إِخفْ نّسْ بَارَّا ذڭْ إِيَّارْ. ڒَامِي د-يُوسَا ؤُيُورْ أَمَايْنُو إِقِّيمْ ؤُجدْجِيذْ \add غَارْ طَّابْڒَا\add* حِيمَا أَذْ إِشّْ.  
\v 25 ثُوغَا أَجدْجِيذْ إِقِّيمْ غَارْ ؤُمنْسِي-يَا ذڭْ ومْشَانْ نّسْ أَمْ مَامّشْ \add ثُوغَا إِقِّيمْ\add* غَارْ إِمنْسِييّنْ إِنّغْنِي، ذِي ڒْكُورْسِي \add إِ إِدْجَانْ\add* غَارْ ڒْحِيضْ. يُونَاثَانْ إِكَّارْ ؤُ أَبْنِيرْ إِقِّيمْ غَارْ ؤُغزْذِيسْ ن شَاوُولْ ؤُ ڒْكُورْسِي ن ذَاوُوذْ إِبَانْ-د إِخْوَا.  
\v 26 ذڭْ وَاسّْ نِّي شَاوُولْ وَارْ إِنِي وَالُو، مَاغَارْ نتَّا إِنَّا \add ذڭْ إِخفْ نّسْ\add*: ”إِمْسَارْ أَسْ شَا أَڒَامِي نتَّا وَارْ إِدْجِي ذ أَمزْذَاڭْ. أَقَا نِيشَانْ نتَّا وَارْ إِدْجِي ذ أَمزْذَاڭْ.“   
\m
\v 27 ثِيوشَّا نّسْ، ذڭْ وَاسّْ وِيسّْ ثْنَاينْ أَوَارْنِي إِ ؤُيُورْ أَمَايْنُو، ؤُمِي إِقِّيمْ ڒْكُورْسِي ن ذَاوُوذْ إِخْوَا \add عَاوذْ\add*، إِمْسَارْ، أَقَا إِنَّا شَاوُولْ إِ مِّيسْ يُونَاثَانْ: ”مَايمِّي مِّيسْ ن يَاسَّا وَارْ د-يُوسِي إِضنَّاضْ ذ وَاسّْ-أَ غَارْ ؤُمنْسِي؟“  
\v 28 يُونَاثَانْ يَارَّا-د خْ شَاوُولْ: ”ذَاوُوذْ إِحشّمْ أَيِي أَطَّاسْ \add مَاحنْذْ إِزمَّارْ أَذْ إِرَاحْ\add* غَارْ بَايْثْ-لَاحْمْ.  
\v 29 نتَّا إِنَّا: ’أجّْ أَيِي أَذْ ؤُيُورغْ، مَاغَارْ نشِّينْ أَذْ نڭّْ إِشْثْ ن ثْغَارْصْثْ ن ڒَادْجْ نّغْ ذِي ثنْذِينْثْ. ؤُمَا إِڭَّا خَافِي \add أَذْ حْضَارغْ\add*. مَاڒَا \add خنِّي\add* ؤُفِيغْ ڒخُّو أَرْضَا ذِي ثِيطَّاوِينْ نّشْ، تّْزَاوَاڭغْ، أجّْ أَيِي أَذْ ؤُيُورغْ حِيمَا أَذْ ژَترغْ أَيْثْمَا.‘ خْ ؤُيَا وَارْ د-يُوسِي ذَاوُوذْ غَارْ طَّابْڒَا ن ؤُجدْجِيذْ.“   
\m
\v 30 \add خنِّي\add* يَارغْ ؤُخيّقْ ن شَاوُولْ خْ يُونَاثَانْ، إِنَّا أَسْ: ”شكْ، مِّيسْ ن \add ثمْغَارْثْ\add* إِغنَّانْ إِفَارْغنْ، نشّْ سّْنغْ مْلِيحْ، أَقَا شكْ ثِيخْضَارذْ أَغزْذِيسْ ن مِّيسْ ن يَاسَّا. ذ مَانْ أَيَا ذ ڒفْضِيحثْ إِ شكْ ذ ڒفْضِيحثْ إِ ثُوعَّارْينْثْ ن يمَّاشْ!  
\v 31 مِينْزِي مَارَّا ؤُسَّانْ مِينْ غَا يكّْ مِّيسْ ن يَاسَّا إِدَّارْ خْ ثمُّورْثْ، وَارْ ثْبذِّيذْ شكْ ؤُڒَا ذ ثَاڭلْذِيثْ نّشْ. خنِّي ڒخُّو، سكّْ \add إِجّنْ\add*، أَوْيِي ث-إِ-د غَارِي، مَاغَارْ نتَّا ذ مِّيسْ ن ڒْموْثْ.“   
\m
\v 32 يَارَّا-د يُونَاثَانْ خْ بَابَاسْ شَاوُولْ، إِنَّا أَسْ: ”مَايمِّي إِتّْخصَّا أَذْ إِتّْوَانغْ نتَّا؟ مِينْ إِڭَّا؟“  
\v 33 \add خنِّي\add* إِحجَّارْ إِ-ث شَاوُولْ س لَانْسَا نّسْ، حِيمَا أَذْ ث إِڒْقفْ. أَمُّو إِ إِسّنْ يُونَاثَانْ، أَقَا بَابَاسْ ثُوغَا إِڭَّا ذِي ڒْبَاڒْ نّسْ أَذْ إِنغْ ذَاوُوذْ.  
\v 34 إِكَّارْ يُونَاثَانْ خْ طَّابْڒَا ؤُمِي يَارْغَا ؤُخيّقْ \add نّسْ\add*، وَارْ إِشِّي أَغْرُومْ ذڭْ وَاسّْ وِيسّْ ثْنَاينْ ن ؤُيُورْ أَمَايْنُو، مَاغَارْ نتَّا ثُوغَا إِكسِّي س ومْنُوسْ إِ ذَاوُوذْ، مِينْزِي بَابَاسْ ثُوغَا إِسّْبهْذڒْ إِ-ث أَمُّو.   
\m
\v 35 ثِيوشَّا نّسْ غَارْ ثُوفُّوثْ، إِمْسَارْ أَقَا يُونَاثَانْ يُويُورْ بَارَّا ذڭْ إِيَّارْ، ذِي ڒْوقْثْ إِ إِڭَّا أَمْسَاڭَارْ أَكْ-ذ ذَاوُوذْ ؤُ ثُوغَا أَكِيذسْ إِجّْ ن ؤُحُوذْرِي ذ أَمژْيَانْ.  
\v 36 نتَّا إِنَّا إِ ؤُحُوذْرِي: ”ؤُيُورْ، أَرْزُو خْ فْڒِيثْشَاثْ نِّي غَا وْثغْ.“ أَحُوذْرِي يُوزّڒْ ؤُ نتَّا إِوْثَا إِشْثْ ن فْڒِيثْشَا ثكَّا سنّجْ نّسْ.  
\v 37 \add ؤُمِي\add* د-يِيوضْ ؤُحُوذْرِي غَارْ ومْشَانْ مَانِي ثدْجَا فْڒِيثْشَا، إِڒَاغَا-د يُونَاثَانْ أَوَارْنِي إِ ؤُحُوذْرِي، إِنَّا: ”مَا وَارْ ثوْضِي فْڒِيثْشَا زَّايكْ أَغِيرِينْ عَاذْ؟“  
\v 38 إِڒَاغَا يُونَاثَانْ \add عَاوذْ\add* إِ ؤُحُوذْرِي ”ذغْيَا، أَزّڒْ، وَارْ تّْبذِّي!“ أَحُوذْرِي \add إِ إِدْجَانْ\add* أَكْ-ذ يُونَاثَانْ إِسّْمُونْ فْڒِيثْشَا ؤُشَا إِعْقبْ غَارْ بَابْ نّسْ.  
\v 39 أَحُوذْرِي وَارْ إِسِّينْ وَالُو. مْغِيرْ يُونَاثَانْ ذ ذَاوُوذْ سّْننْ خْ ثْمسْڒَاشْثْ \add جَارْ أَسنْ\add*.  
\v 40 \add خنِّي\add* إِوْشَا يُونَاثَانْ ڒقْشُوعْ \add ن ڒسْنَاحْ نّسْ\add* إِ ؤُحُوذْرِي إِ ثُوغَا غَارسْ إِدْجَانْ، إِنَّا أَسْ: ”ؤُيُورْ، أَرّْ إِ-ثنْ غَارْ ثنْذِينْثْ!“  
\v 41 \add ؤُمِي\add* يُويُورْ ؤُحُوذْرِي، إِكَّارْ ذَاوُوذْ زڭْ ؤُغزْذِيسْ ن لْجَانُوبْ، إِوْضَا س ؤُغمْبُوبْ نّسْ غَارْ ثمُّورْثْ ؤُشَا يُوضَارْ ثْڒَاثَا ن ثْوَاڒَاوِينْ. نِيثْنِي سُّوذْمنْ أَيَاوْيَا، رُونْ س ثْنَاينْ إِذْسنْ أَڒَامِي ذَاوُوذْ يَارْنِي ذَايسْ.  
\v 42 ؤُ يُونَاثَانْ إِنَّا إِ ذَاوُوذْ: ”ؤُيُورْ ذِي ڒهْنَا. أَقَا نجُّودْجْ س ثْنَاينْ إِذْنغْ س يِيسمْ ن سِيذِي، ننَّا: ’أَذْ يِيڒِي سِيذِي ذ أَشهَّاذْ جَارْ أَيِي ذ شكْ، جَارْ زَّارِيعثْ إِنُو ذ زَّارِيعثْ نّشْ إِ ڒبْذَا!‘ “   
\b  
\b  
\m  
\c 21
\s1 ذَاوُوذْ ذِي نُوبْ  
\m
\v 1 خنِّي إِكَّارْ \add ذَاوُوذْ\add*، يُويُورْ، ؤُشَا يُوذفْ يُونَاثَانْ غَارْ ثنْذِينْثْ.  
\v 2 \add خنِّي\add* يِيوضْ ذَاوُوذْ غَارْ نُوبْ غَارْ ؤُكهَّانْ أَخِيمَالِيكْ. أَخِيمَالِيكْ إِفّغْ-د غَارْ ذَاوُوذْ يَارْجفْ، إِنَّا أَسْ: ”مَايمِّي شكْ وحّْذكْ، وَارْ كِيذكْ ؤُڒَا ذ إِجّْ؟“  
\v 3 ذَاوُوذْ إِنَّا إِ ؤُكهَّانْ أَخِيمَالِيكْ: ”أَجدْجِيذْ إِوْشَا أَيِي إِجّْ ن وَارقَّاسْ، إِنَّا أَيِي: ’ؤُڒَا ذ إِجّْ وَارْ إِتّْرِيڭِّيبْ خْ ثْمسْڒَاشْثْ إِ ذ أَشْ د-سّكّغْ ؤُ خَاكْ ڭِّيغْ!‘ سَارْڭْبغْ إِ إِمْسخَّارنْ أَقَا \add أَذْ رُوحنْ\add* غَارْ ومْشَانْ-أَ ذ ومْشَانْ-إِنْ.  
\v 4 خنِّي ڒخُّو، مِينْ غَاركْ؟ أوْشْ أَيِي خمْسَا ن ثشْنِيفِينْ ذڭْ ؤُفُوسْ نِيغْ مِينْ مَا ثْزمَّارذْ أَذْ ثَافذْ.“   
\m
\v 5 أَكهَّانْ يَارَّا-د خْ ذَاوُوذْ، إِنَّا: ”وَارْ ذِينْ أَغْرُومْ إِ مَاشَّا غَارْ ؤُفُوسْ، مْغِيرْ أَغْرُومْ أَمْقدّسْ وَاهَا إِ ذَا. معْلِيكْ إِمْسخَّارنْ ثُوغَا تَّاڭّْوجنْ وَاهَا خْ ثمْغَارِينْ!“  
\v 6 ذَاوُوذْ يَارَّا-د خْ ؤُكهَّانْ، إِنَّا أَسْ: ”س ثِيذتّْ، ثِيمْغَارِينْ تّْوَاحيّْذنْثْ خَانغْ أَمْ مَامّشْ ثدْجَا لْقَاعِيذَا زڭْ وَامِي فّْغغْ، ؤُ ڒقْشُوعْ ن إِمْسخَّارنْ تّْوَاقدّْسنْ. وَاخَّا أَمنِّي مَانَاوْيَا ذ إِجّْ ن وُوفُّوغْ أَمْ ڒبْذَا، أَقَا ؤُفُّوغْ-أَ إِتّْوَاقدّسْ أَسّْ-أَ س ڒقْشُوعْ.“   
\m
\v 7 \add خنِّي\add* إِوْشَا أَسْ ؤُكهَّانْ \add أَغْرُومْ\add* إِقدّْسنْ، مَاغَارْ وَارْ ثُوغِي ذِينِّي أَغْرُومْ مْغِيرْ أَغْرُومْ ن وسْشَانْ نِّي إِتّْوَاكّسْ زِي زَّاثْ إِ وُوذمْ ن سِيذِي، حِيمَا أَذْ سَّارْسنْ ذڭْ ومْشَانْ نّسْ أَغْرُومْ إِحْمَا ذڭْ وَاسّْ نِّي إِتّْوَاكّسْ. \x ◘ \xo 21:‏7 \xt مت. 12‏:‏3؛ مك. 2‏:‏25؛ لك. 6‏:‏3\x*  
\v 8 ذڭْ وَاسّْ نِّي ثُوغَا ذِينِّي إِجّْ زڭْ إِمْسخَّارنْ ن شَاوُولْ. نتَّا ثُوغَا إِتّْوَاحْصَارْ ذِينِّي زَّاثْ إِ وُوذمْ ن سِيذِي. قَّارنْ أَسْ ذُووَاعْ، زِي إِذُومْ. نتَّا ثُوغَا غَارسْ صُّولْطَا أَطَّاسْ جَارْ إِمكْسَاونْ إِنِّي \add إِدْجَانْ\add* غَارْ شَاوُولْ.  
\v 9 ؤُشَا إِنَّا ذَاوُوذْ إِ أَخِيمَالِيكْ: ”مَا وَارْ ذَا غَاركْ إِشْثْ ن لَانْسَا نِيغْ إِجّْ ن سِّيفْ غَارْ ؤُفُوسْ؟ مَاغَارْ وَارْ كِيذِي كْسِيغْ سِّيفْ ذ ڒسْنَاحْ إِنُو ذڭْ ؤُفُوسْ إِنُو، مِينْزِي ثَامسْڒَاشْثْ ن ؤُجدْجِيذْ ثُوغَا ثتّْقدْجِيقْ.“   
\m
\v 10 إِنَّا ؤُكهَّانْ: ”سِّيفْ ن جُولْيَاثْ، أَفِيلِيسْطِينِي ونِّي خْ ثْغڒْبذْ ذِي ڒوْضَا ن ثغْزُورْثْ ن إِلَا، أَقَا-ث \add ذَا\add*، إِتّْوَانّضْ ذڭْ إِجّْ ن وَارُّوضْ أَوَارْنِي إِ ؤُپَالْطُو ن إِكهَّاننْ. مَاڒَا ثخْسذْ أَذْ ث ثكْسِيذْ، كْسِي ث، مِينْزِي وَارْ ذَا وَالُو مْغِيرْ وَانِيثَا.“ إِنَّا ذَاوُوذْ: ”وَارْ إِدْجِي إِجّْ أَمْ نتَّا! أوْشْ أَيِي ث!“   
\b  
\m  
\s1 ذَاوُوذْ ذِي جَاثْ  
\m
\v 11 إِكَّارْ ذَاوُوذْ، يَارْوڒْ ذڭْ وَاسّْ نِّي زَّاثْ إِ وُوذمْ ن شَاوُولْ ؤُشَا نتَّا يُوسَا-د غَارْ أَخِيشْ، أَجدْجِيذْ ن جَاثْ.  
\v 12 إِمْسخَّارنْ ن أَخِيشْ نَّانْ أَسْ: ”مَا وَانِيثَا وَارْ إِدْجِي ذ ذَاوُوذْ، أَجدْجِيذْ ن ثمُّورْثْ؟ مَا وَارْ إِدْجِي ذ ونِّي زِيغنّْجنْثْ، شضْحنْثْ ثمْغَارِينْ س نُّوبْثَاثْ، قَّارنْثْ: ’شَاوُولْ إِغْڒبْ خْ ڒُوڒُوفْ نّسْ، مَاشَا ذَاوُوذْ خْعشْرَا ن ڒُوڒُوفْ نّسْ؟‘ “\x ◘ \xo 21:‏12 \xt 1 صم. 18‏:‏7\x*  
\v 13 ذَاوُوذْ يَارَّا أَوَاڒنْ-أَ غَارْ وُوڒْ نّسْ ؤُ ثُوغَا إِتّڭّْوذْ أَطَّاسْ زَّاثْ إِ وُوذمْ ن أَخِيشْ، أَجدْجِيذْ ن جَاثْ.  
\v 14 \add خنِّي\add* إِڭَّا إِخفْ نّسْ أَخْمِي إِودَّارْ ڒعْقڒْ نّسْ زَّاثْ إِ ثِيطَّاوِينْ نْسنْ، إِڭَّا أَخْمِي إِجّنْ ذَايسْ أَطمّسْ ؤُمِي خَاسْ سَّارْسنْ إِفَاسّنْ، ؤُشَا إِبْذَا إِخبّشْ ذِي ثوُّورَا ن ثوَّارْثْ \add ن ثنْذِينْثْ\add*، إِجَّا إِكُوفَّانْ نّسْ هكّْوَانْ-د خْ ثْمَارْثْ نّسْ.  
\v 15 \add خنِّي\add* إِنَّا أَخِيشْ إِ إِمْسخَّارنْ نّسْ: ”خْزَارمْ، كنِّيوْ ثتّْوَاڒَامْ أَقَا أَرْيَازْ إِبُّوهْڒِي. مَايمِّي إِ-ث-إِ-د-ثِيوْيمْ غَارِي؟“  
\v 16 مَا تّْخصَّانْ أَيِي إِبُوهَاڒِييّنْ، أَقَا ثِيوْيمْ-د غَارِي وَانِيثَا مَاحنْذْ أَذْ غَارِي إِڭّْ ثُوبُّوهڒْيَا؟ مَا ذ وَانِيثَا إِ د غَا يَاذْفنْ غَارْ ثَادَّارْثْ إِنُو؟“   
\b  
\b  
\m  
\c 22
\s1 ذَاوُوذْ ذڭْ إِفْرِي ن أَذُولَّامْ  
\m
\v 1 \add خنِّي\add* يُويُورْ ذَاوُوذْ سّنِّي، إِسّنْجمْ إِخفْ نّسْ غَارْ إِفْرِي ن أَذُولَّامْ. أَيْثْمَاسْ ذ مَارَّا ثَادَّارْثْ ن بَابَاسْ سْڒَانْ أَيَا ؤُشَا هْوَانْ غَارسْ ذِينِّي.  
\v 2 ؤُشَا \add كُوڒْ\add* أَرْيَازْ نِّي ثُوغَا ذِي شَا ن ڒحْصَارثْ ؤُ \add كُوڒْ\add* أَرْيَازْ إِ ذِي ثُوغَا إِدْجَا ؤُمَارْوَاسْ ؤُ \add كُوڒْ\add* أَرْيَازْ س ڒْبَاڒْ ذ أَمرْزَاڭْ، أَقَا \add مَارَّا\add* نِيثْنِي فّْغنْ غَارسْ ؤُشَا نتَّا إِذْوڒْ ذ أَمْڭوّذْ نْسنْ. ثُوغَا غَارسْ ڒْقدّْ ن أَربْعَا-مْيَا ن يرْيَازنْ.  
\v 3 سّنِّي إِفّغْ ذَاوُوذْ غَارْ مِيصْفَاثْ ذِي مُوآبَ. إِنَّا نتَّا إِ ؤُجدْجِيذْ ن مُوآبَ: ”أجّْ بَابَا ذ يمَّا أَذْ غَارْومْ د-أَسنْ، أَڒْ غَا سّْنغْ مِينْ كِيذِي إِ غَا يڭّْ سِيذِي.“   
\m
\v 4 نتَّا يِيوْيِي ثنْ زَّاثْ إِ وُوذمْ ن ؤُجدْجِيذْ ن مُوآبَ ؤُشَا نِيثْنِي قِّيمنْ غَارسْ مَارَّا ؤُسَّانْ إِ ذِي إِكَّا ذَاوُوذْ ذِي لْبُورْجْ \add ذڭْ إِذُورَارْ\add*.  
\v 5 \add مَاشَا\add* أَنَابِي جَاثْ إِنَّا إِ ذَاوُوذْ: ”وَارْ تّْغِيمِي ذِي لْبُورْجْ \add ذڭْ إِذُورَارْ\add*، مَاشَا أَڭّْوجْ، أَذْ ثَاذْفذْ غَارْ ثمُّورْثْ ن يَاهُوذَا!“ \add خنِّي\add* يُويُورْ ذَاوُوذْ، يِيوضْ غَارْ وزْغَارْ ن حَارِيثْ. \f ◼ \fr 22:‏5 \ft \+bd ’أَزْغَارْ‘\+bd* - نِيغْ ’ڒْغَابثْ‘ نِيغْ ’ثَازْڭَانْثْ‘.\f*   
\b  
\m  
\s1 ثَامنْغِيوْثْ ن إِكهَّاننْ ن نُوبْ  
\m
\v 6 شَاوُولْ إِسْڒَا بلِّي ذَاوُوذْ ذ إِرْيَازنْ، إِنِّي ثُوغَا غَارسْ \add إِدْجَانْ\add*، تّْوَافنْ. ثُوغَا شَاوُولْ إِقِّيمْ ذِي جِيبْعَا سَاذُو إِشْثْ ن ثْشجَّارْثْ ن ثْمَارِيسْثْ غَارْ رَامَا. ثُوغَا غَارسْ إِشْثْ ن لَانْسَا ذڭْ ؤُفُوسْ نّسْ ؤُ مَارَّا إِمْسخَّارنْ نّسْ بدّنْ غَارسْ. \f ◼ \fr 22:‏6 \ft \+bd ’ثَاشجَّارْثْ ن ثَامَارِيسْثْ‘\+bd* - س ثْلَاثِينِيثْ ’ثَامَارِيخْ‘.\f*  
\v 7 إِنَّا شَاوُولْ إِ إِمْسخَّارنْ نّسْ إِ غَارسْ إِبدّنْ: ”تّْزَاوْڭغْ، سْڒمْ، كنِّيوْ أَيْثْ ن بِينْيَامِينْ! مَا أَذْ إِوْشْ مِّيسْ ن يَاسَّا إِيَّارنْ ذ إِمَارْجَاعنْ ن ؤُضِيڒْ إِ كنِّيوْ مَارَّا؟ مَا أَذْ يَارّْ كنِّيوْ مَارَّا ذ إِمقّْرَاننْ خْ وَاڒفْ ذ إِمقّْرَاننْ خْ مْيَا؟  
\v 8 أَقَا كنِّيوْ مَارَّا ثڭِّيمْ خَافِي ثَامعْمُوتْشْ ؤُشَا ؤُڒَا ذ إِجّنْ وَارْ ذ أَيِي إِسَّارْڭبْ بلِّي مِّي إِڭَّا إِجّْ ن ڒْعَاهْذْ أَكْ-ذ مِّيسْ ن يَاسَّا ؤُشَا ؤُڒَا ذ إِجّْ زَّايْومْ وَارْ ذ أَسْ شْقِيغْ، وَارْ ذ أَيِي ثسَّارْڭْبمْ أَقَا مِّي إِسَّامَارْ أَمْسخَّارْ إِنُو خَافِي مَاحنْذْ أَذْ خَافِي إِزيَّارْ س ثْحْرَايْمشْثْ أَمْ مَامّشْ \add إِدْجَا\add* أَسّْ-أَ.“   
\m
\v 9 \add خنِّي\add* يَارَّا-د ذُووَاعْ، ونِّي إِدْجَانْ زِي إِذُومْ، ونِّي ذ أَمحْضَايْ خْ إِمْسخَّارنْ ن شَاوُولْ، إِنَّا: ”نشّْ ژْرِيغْ مِّيسْ ن يَاسَّا ڒَامِي د-يُوسَا ذِي نُوبْ غَارْ أَخِيمَالِيكْ، مِّيسْ ن أَخِيطُوبْ.  
\v 10 نتَّا إِتَّارْ سِيذِي ذِي طّْوعْ نّسْ، إِوْشَا أَسْ مَاشَّا ؤُڒَا ذ سِّيفْ ن جُولْيَاثْ، أَفِيلِيسْطِينِي.“  
\v 11 \add خَاسْ ؤُشَا\add* إِسّكّْ ؤُجدْجِيذْ \add إِجّْ\add* مَاحنْذْ أَذْ د-إِڒَاغَا خْ ؤُكهَّانْ أَخِيمَالِيكْ، مِّيسْ ن أَخِيطُوبْ، \add جْمِيعْ\add* أَكْ-ذ مَارَّا ثَادَّارْثْ ن بَابَاسْ، إِكهَّاننْ، إِنِّي \add إِدْجَانْ\add* ذِي نُوبْ. ؤُشَا مَارَّا ؤُسِينْ-د غَارْ ؤُجدْجِيذْ.   
\m
\v 12 إِنَّا شَاوُولْ: ”سڒْ، شكْ، مِّيسْ ن أَخِيطُوبْ!“ نتَّا يَارَّا-د: ”خْزَارْ، أَقَا أَيِي ذَا، أَ سِيذِي إِنُو!“  
\v 13 شَاوُولْ إِنَّا أَسْ: ”مَايمِّي خَافِي ثڭِّيمْ ثَامعْمُوتْشْ، شكْ ذ مِّيسْ ن يَاسَّا، أَقَا شكْ ثوْشِيذْ أَسْ مَاشَّا ذ سِّيفْ ؤُ ثتَّارذْ أَربِّي ذِي طّْوعْ نّسْ حِيمَا أَذْ خَافِي إِغوّغْ ؤُ أَذْ خَافِي إِزيَّارْ، أَمْ مَامّشْ \add إِدْجَا\add* أَسّْ-أَ.“  
\v 14 يَارَّا-د أَخِيمَالِيكْ خْ ؤُجدْجِيذْ، إِنَّا: ”مَانْ ونْ زِي مَارَّا إِمْسخَّارنْ نّشْ ذ أَمْثِيقِّي أَمْ ذَاوُوذْ، أَضڭّْوَاڒْ ن ؤُجدْجِيذْ، ؤُ \add مَانْ ونْ\add* إِ غَا يَاوْضنْ \add أَمنِّي\add* غَارْ إِمْثِيقَّانْ نّشْ ؤُ وِي غَارْ إِدْجَا شَّانْ \add أَمُّو\add* ذِي ثَادَّارْثْ نّشْ؟  
\v 15 مَا أَسّْ-أَ وَاهَا إِ كَّارغْ أَذْ تَّارغْ سِيذِي ذِي طّْوعْ نّسْ؟ أَقَا مَانْ أَيَا إِڭّْوجْ خَافِي. أجّْ أَجدْجِيذْ وَارْ إِنطَّارْ ڒْبَاطڒْ خْ ؤُمْسخَّارْ نّسْ نِيغْ خْ مَارَّا ثَادَّارْثْ ن بَابَا ذِي سِّيبّثْ ن شَا ن ڒْحَاجّثْ، مِينْزِي أَمْسخَّارْ نّشْ وَارْ إِسِّينْ وَالُو خْ مَارَّا أَيَا، مَا \add ذ ثَامسْڒَاشْثْ\add* ذ ثَامژْيَانْثْ نِيغْ ذ ثَامقّْرَانْثْ \add إِ ثدْجَا\add*.“  
\v 16 \add مَاشَا\add* أَجدْجِيذْ إِنَّا: ”شكْ س ثِيذتّْ أَذْ ثمّْثذْ، \add أَ\add* أَخِيمَالِيكْ، شكْ ذ مَارَّا ثَادَّارْثْ ن بَابَاشْ.“  
\v 17 أَجدْجِيذْ إِنَّا إِ إِڒقَّاسنْ ن ثَازْڒَا نِّي غَارسْ-د إِبدّنْ: ”نْقڒْبمْ ؤُ نْغمْ إِكهَّاننْ ن سِيذِي، مَاغَارْ ؤُڒَا ذ نِيثْنِي وْشِينْ أَفُوسْ إِ ذَاوُوذْ، مِينْزِي نِيثْنِي سّْننْ أَقَا نتَّا ثُوغَا إِتّْرَاكّْوَاڒْ ؤُ نِيثْنِي وَارْ ذ أَيِي خَاسْ سَّارْڭْبنْ شَا.“ \add مَاشَا\add* إِمْسخَّارنْ ن ؤُجدْجِيذْ وَارْ خْسنْ أَذْ سّْوِيژّْضنْ أَفُوسْ نْسنْ، حِيمَا أَذْ زَّايسْ وْثنْ إِكهَّاننْ ن سِيذِي.  
\v 18 \add خنِّي\add* إِنَّا ؤُجدْجِيذْ إِ ذُووَاعْ: ”نقْڒبْ، وّثْ إِكهَّاننْ!“ \add خنِّي\add* إِنّقْڒبْ ذُووَاعْ، ونِّي إِدْجَانْ زِي إِذُومْ، إِوْثَا إِكهَّاننْ. ذڭْ وَاسّْ نِّي إِنْغَا نتَّا خمْسَا ؤُ-ثْمَانْيِينْ ن يرْيَازنْ نِّي يَارْضنْ أَپَالْطُو \add ن ؤُكهَّانْ\add*.  
\v 19 نتَّا إِوْثَا ؤُڒَا ذ نُوبْ، ثَانْذِينْثْ ن إِكهَّاننْ، س ڒقْضعْ ن سِّيفْ، إِرْيَازنْ ذ ثمْغَارِينْ، إِحنْجِيرنْ ذ إِسيْمَانْ. إِوْثَا عَاوذْ إِفُونَاسنْ ذ يغْيَاڒْ ذ وُودْجِي س ڒقْضعْ ن سِّيفْ.  
\v 20 إِجّْ زڭْ وَارَّاوْ ن أَخِيمَالِيكْ، مِّيسْ ن أَخِيطُوبْ، إِسّنْجمْ إِخفْ نّسْ. \add ثُوغَا\add* إِسمْ نّسْ أَبْيَاثَارْ ؤُ نتَّا إِقدْجقْ \add إِخفْ نّسْ\add* أَوَارْنِي إِ ذَاوُوذْ.   
\m
\v 21 أَبْيَاثَارْ إِحَاجَا إِ ذَاوُوذْ، أَقَا شَاوُولْ ثُوغَا إِنْغَا إِكهَّاننْ ن سِيذِي.  
\v 22 \add خنِّي\add* إِنَّا ذَاوُوذْ إِ أَبْيَاثَارْ: ”ذڭْ وَاسّْ نِّي، ؤُمِي ثُوغَا ذُووَاعْ زِي إِذُومْ ذِينِّي، سّْنغْ أَقَا نتَّا أَذْ إِحَاجَا أَيَا إِ شَاوُولْ. نشّْ ذ ونِّي خْ \add إِدْجَانْ\add* مَارَّا ڒعْمُورْ ن ثَادَّارْثْ ن بَابَاشْ.  
\v 23 قِيمْ غَارِي، وَارْ تّڭّْوذْ شَا، مَاغَارْ ونِّي يَارزُّونْ \add أَذْ إِنغْ\add* ڒعْمَارْ إِنُو، يَارزُّو \add أَذْ إِنغْ\add* ؤُڒَا ذ ڒعْمَارْ نّشْ. أَقَا شكْ \add عَاوذْ\add* غَارِي ذِي ڒَامَانْ.“   
\b  
\b  
\m  
\c 23
\s1 ذَاوُوذْ ذِي قَاعِيلَا  
\m
\v 1 حَاجَانْ إِ ذَاوُوذْ، نَّانْ: ”أَقَا إِفِيلِيسْطِينِييّنْ تّْمنْغَانْ أَكْ-ذ قَاعِيلَا ؤُشَا تّْكشَّاضنْ إِنذْرَارْ.“  
\v 2 إِسّقْسَا ذَاوُوذْ سِيذِي، إِنَّا: ”مَا أَذْ فّْغغْ ذِينْ، أَذْ وْثغْ إِفِيلِيسْطِينِييّنْ؟“ سِيذِي يَارَّا-د خْ ذَاوُوذْ: ”فّغْ، وّثْ إِفِيلِيسْطِينِييّنْ ؤُشَا فكّْ قَاعِيلَا!“  
\v 3 نَّانْ أَسْ يرْيَازنْ ن ذَاوُوذْ: ”خْزَارْ، نشِّينْ نتّڭّْوذْ \add ذغْيَا\add* ذَا ذِي يَاهُوذَا، مَامّشْ عَاذْ مَاڒَا نشِّينْ نفّغْ غَارْ قَاعِيلَا غَارْ إِسذِّييّنْ ن ڒْعسْكَارْ ن إِفِيلِيسْطِينِييّنْ.“  
\v 4 ؤُشَا ذَاوُوذْ إِسّقْسَا سِيذِي ثْوَاڒَا نّغْنِيثْ ؤُ سِيذِي يَارَّا-د خَاسْ، إِنَّا: ”كَّارْ، هْوَا غَارْ قَاعِيلَا، مِينْزِي نشّْ أَذْ أَشْ وْشغْ إِفِيلِيسْطِينِييّنْ ذڭْ إِفَاسّنْ \add نّشْ\add*.“  
\v 5 \add خَاسْ ؤُشَا\add* إِفّغْ ذَاوُوذْ أَكْ-ذ يرْيَازنْ نّسْ غَارْ قَاعِيلَا، إِمّْنغْ أَكْ-ذ إِفِيلِيسْطِينِييّنْ. نتَّا يُوژّڒْ خْ ثْحِيمَارِينْ نْسنْ ؤُشَا إِوْثَا ثنْ س إِشْثْ ن ثشْثِي ذ ثَامقّْرَانْثْ. \add أَمُّو إِ\add* إِفكّْ ذَاوُوذْ إِمزْذَاغْ ن قَاعِيلَا.   
\m
\v 6 ؤُمِي أَبْيَاثَارْ، مِّيسْ ن أَخِيمَالِيكْ، يَارْوڒْ غَارْ ذَاوُوذْ غَارْ قَاعِيلَا، إِمْسَارْ، نتَّا أَقَا إِهْوَا أَكْ-ذ ؤُپَالْطُو \add ن ؤُكهَّانْ\add* ذڭْ إِفَاسّنْ نّسْ. \x ◘ \xo 23:‏6 \xt 1 صم. 22‏:‏20\x*   
\m
\v 7 حَاجَانْ أَسْ إِ شَاوُولْ، أَقَا ذَاوُوذْ يِيوضْ غَارْ قَاعِيلَا. \add خنِّي\add* إِنَّا شَاوُولْ: ”أَربِّي إِڭَّا أَيِي إِ-ث ذڭْ ؤُفُوسْ إِنُو، مِينْزِي نتَّا إِتّْوَاحبّسْ أَڒَامِي يُوذفْ غَارْ إِشْثْ ن ثنْذِينْثْ س ثوُّورَا ذ زّكْرُونَاثْ.“  
\v 8 إِجَّا شَاوُولْ أَذْ ڒَاغَانْ خْ مَارَّا ڒْڭنْسْ غَارْ ؤُمنْغِي، حِيمَا أَذْ هْوَانْ غَارْ قَاعِيلَا مَاحنْذْ أَذْ نّْضنْ إِ ذَاوُوذْ ذ يرْيَازنْ نّسْ.   
\m
\v 9 \add ڒَْامِي\add* يَارْڭبْ ذَاوُوذْ بلِّي شَاوُولْ إِسّوْجذْ أَسْ ثُوعفّْنَا-يَا س ثْنُوفّْرَا، إِنَّا نتَّا إِ ؤُكهَّانْ أَبْيَاثَارْ: ”أَوِي-د أَپَالْطُو \add ن ؤُكهَّانْ\add* ذَا!“  
\v 10 إِنَّا ذَاوُوذْ: ”\add أَ\add* سِيذِي، أَربِّي ن إِسْرَائِيل، أَمْسخَّارْ نّشْ إِسْڒَا نِيشَانْ، أَقَا شَاوُولْ إِعمّذْ أَذْ د-يَاسْ غَارْ قَاعِيلَا، حِيمَا أَذْ إِخَارّبْ ثَانْذِينْثْ ذِي سِّيبّثْ إِنُو.  
\v 11 مَا أَذْ أَيِي سّعْذُونْ إِمزْذَاغْ ن قَاعِيلَا ذڭْ ؤُفُوسْ نّسْ؟ مَا أَذْ إِهْوَا شَاوُولْ أَمْ مَامّشْ إِسْڒَا ؤُمْسخَّارْ نّشْ؟ \add أَ\add* سِيذِي، أَربِّي ن إِسْرَائِيل، إِنِي ث إِ ؤُمْسخَّارْ نّشْ!“ سِيذِي يَارَّا-د: ”نتَّا أَذْ إِهْوَا.“  
\v 12 \add خَاسْ ؤُشَا\add* إِنَّا ذَاوُوذْ: ”مَا إِمزْذَاغْ ن قَاعِيلَا أَذْ سّعْذُونْ نشّْ ذ يرْيَازنْ إِنُو إِ شَاوُولْ؟“ إِنَّا سِيذِي ”نِيثْنِي أَذْ \add شكْ\add* سّعْذُونْ.“  
\v 13 \add خَاسْ ؤُشَا\add* إِكَّارْ ذَاوُوذْ أَكْ-ذ يرْيَازنْ نّسْ، أَمنِّي ستَّا مْيَا ن يرْيَازنْ، ؤُشَا فّْغنْ نِيثْنِي زِي قَاعِيلَا، ذوْڒنْ ڭُّورنْ مَانِي مَا زمَّارنْ أَذْ ؤُيُورنْ. \add ؤُمِي\add* إِتّْوَانَّا إِ شَاوُولْ، أَقَا إِنْجمْ-د ذَاوُوذْ زِي قَاعِيلَا، إِجَّا \add زڭْ وبْرِيذْ نّسْ\add*، وَارْ إِفِّيغْ شَا.   
\b  
\m  
\s1 ذَاوُوذْ ذِي ڒخْڒَا ن زِيفْ  
\m
\v 14 ذَاوُوذْ إِقِّيمْ ذِي ڒخْڒَا ذِي لْقلْعَاثْ ن إِذُورَارْ ؤُشَا إِقِّيمْ خْ إِذُورَارْ ذِي ڒخْڒَا ن زِيفْ. شَاوُولْ يَارْزُو خَاسْ مَارَّا ؤُسَّانْ، \add مَاشَا\add* أَربِّي وَارْ ث إِڭِّي ذڭْ ؤُفُوسْ نّسْ.  
\v 15 \add ؤُمِي\add* إِژْرَا ذَاوُوذْ، أَقَا شَاوُولْ ثُوغَا إِفّغْ حِيمَا أَذْ خَاسْ يَارْزُو، \add ثُوغَا\add* ذَاوُوذْ ذِي ڒخْڒَا ن زِيفْ ذِي خُورِيسَا. \f ◼ \fr 23:‏15 \ft \+bd ’حِيمَا أَذْ خَاسْ يَارْزُو‘\+bd* - س ثْعِيبْرَانِيثْ ’حِيمَا أَذْ يَارْزُو خْ ڒعْمَارْ نّسْ‘.\f*  
\v 16 \add خنِّي\add* إِكَّارْ يُونَاثَانْ، مِّيسْ ن شَاوُولْ، ؤُشَا يُويُورْ غَارْ ذَاوُوذْ ذِي خُورِيسَا، إِسّجْهذْ أَفُوسْ نّسْ ذِي أَربِّي.  
\v 17 نتَّا إِنَّا أَسْ: ”وَارْ تّڭّْوذْ شَا، مِينْزِي أَفُوسْ ن بَابَا شَاوُولْ وَارْ شكْ د-إِتِّيكّْوِيضْ ؤُ شكْ أَذْ ثْذوْڒذْ ذ أَجدْجِيذْ خْ إِسْرَائِيل ؤُ نشّْ أَذْ ذوْڒغْ ذ وِيسّْ ثْنَاينْ غَاركْ. ؤُڒَا ذ بَابَا شَاوُولْ إِسّنْ أَيَا.“  
\v 18 ؤُ نِيثْنِي س ثْنَاينْ إِذْسنْ ڭِّينْ إِجّْ ن ڒْعَاهْذْ زَّاثْ إِ وُوذمْ ن سِيذِي. ذَاوُوذْ إِقِّيمْ ذِي خُورِيسَا ؤُ يُونَاثَانْ يَارڭّْوحْ غَارْ ثَادَّارْثْ نّسْ.   
\m
\v 19 \add خَاسْ\add* ؤُشَا ڭعّْذنْ يرْيَازنْ زِي زِيفْ غَارْ شَاوُولْ ذِي جِيبْعَا، نَّانْ: ”مَا وَارْ إِنُّوفَّارْ ذَاوُوذْ غَارْنغْ ذِي لْقلْعَاثْ \add ذڭْ إِذُورَارْ\add* ذِي خُورِيسَا، خْ ثوْرِيرْثْ ن حَاخِيلَا، غَارْ لْجَانُوبْ ن ثْنزْرُوفْثْ؟ \f ◼ \fr 23:‏19 \ft \+bd ’غَارْ لْجَانُوبْ ن ثْنزْرُوفْثْ‘\+bd* - نِيغْ ’غَارْ يفُّوسِي ن ثْنزْرُوفْثْ‘.\f*  
\v 20 \add خنِّي\add* ڒخُّو، \add أَ\add* أَجدْجِيذْ، هْوَا-د عْلَاحْسَابْ مَارَّا مژْرِي ن وُوڒْ نّشْ. أَذْ ثِيڒِي \add خنِّي\add* ثْمسْڒَاشْثْ نّغْ، حِيمَا أَذْ ث نسّعْذُو غَارْ ؤُفُوسْ ن ؤُجدْجِيذْ.“  
\v 21 شَاوُولْ إِنَّا: ”أَذْ ثتّْوَابَارْكمْ زِي سِيذِي، مِينْزِي شْقِيغْ أَومْ \add أَمُّو\add*.  
\v 22 ؤُيُورمْ، وجْذمْ عَاذْ كْثَارْ ؤُ حْضَامْ ؤُ سْنمْ ؤُ خْزَارمْ أَمْشَانْ مَانِي إِدْجَا ؤُضَارْ نّسْ ؤُ مَانْ ونْ إِ ث ذِينِّي إِژْرِينْ، مَاغَارْ قَّارنْ أَيِي، أَقَا نتَّا ذ أَحْرَايْمِي أَطَّاسْ.  
\v 23 حْضَامْ ؤُ سّْنمْ مَارَّا إِمُوشَانْ ن ثْنُوفّْرَا مَانِي إِسّْنُوفَّارْ إِخفْ نّسْ ؤُعقْبمْ مَاڒَا ثْكمّْڒمْ. \add خنِّي\add* أَذْ كِيذْومْ ؤُيُورغْ ؤُ مَاڒَا نتَّا ذِي ثمُّورْثْ، نشّْ أَذْ خَاسْ أَرْزُوغْ جَارْ مَارَّا ڒُوڒُوفْ ن يَاهُوذَا.“  
\v 24 كَّارنْ نِيثْنِي، إِزَّارنْ زَّاثْ إِ وُوذمْ ن شَاوُولْ غَارْ زِيفْ. ذَاوُوذْ ذ يرْيَازنْ نّسْ ثُوغَا أَثنْ ذِي ڒخْڒَا ن مَاعُونْ، ذِي ڒوْضَا غَارْ لْجَانُوبْ ن ثْنزْرُوفْثْ.   
\m
\v 25 شَاوُولْ ذ يرْيَازنْ نّسْ فّْغنْ حِيمَا أَذْ خَاسْ أَرْزُونْ. نَّانْ أَيَا إِ ذَاوُوذْ ؤُ نتَّا إِهْوَا-د زِي ڒجْرُوفْ ذِي ڒخْڒَا ن مَاعُونْ. \add ؤُمِي\add* ث إِسْڒَا شَاوُولْ، \add ڒخْذنِّي\add* إِضْفَارْ نتَّا ذَاوُوذْ ذِي ڒخْڒَا ن مَاعُونْ.  
\v 26 شَاوُولْ إِكَّا خْ إِجّْ ن ؤُغزْذِيسْ ن وذْرَارْ ؤُ ذَاوُوذْ ذ يرْيَازنْ نّسْ كّنْ خْ ؤُغزْذِيسْ نّغْنِي ن وذْرَارْ. ڒَامِي إِقدْجقْ ذَاوُوذْ مَاحنْذْ أَذْ يَاڭّْوجْ خْ وُوذمْ ن شَاوُولْ، إِمْسَارْ، أَقَا شَاوُولْ ذ يرْيَازنْ نّسْ نّْضنْ-د إِ ذَاوُوذْ ذ يرْيَازنْ نّسْ حِيمَا أَذْ ثنْ طّْفنْ.  
\v 27 \add مَاشَا\add* يُوسَا-د إِجّْ ن ؤُرقَّاسْ غَارْ شَاوُولْ إِنَّا: ”ذغْيَا، أَسْ-د، مِينْزِي إِفِيلِيسْطِينِييّنْ هجْمنْ خْ ثمُّورْثْ!“  
\v 28 \add خنِّي\add* إِعْقبْ-د شَاوُولْ زڭْ وضْفَارْ ن ذَاوُوذْ ؤُشَا إِفّغْ غَارْ ؤُمْسَاڭَارْ أَكْ-ذ إِفِيلِيسْطِينِييّنْ. خْ ؤُيَا قَّارنْ أَسْ إِ ومْشَانْ نِّي سَالَاعْ-هَا-مَاخْلِيكُوثْ. \f ◼ \fr 23:‏28 \ft \+bd ’سَالَاعْ-هَامَاخْلِيكُوثْ‘\+bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَسدْجَاحْ ن ؤُبطُّو‘ نِيغْ ’أَسدْجَاحْ ن وَارْوڒْ‘.\f*   
\b  
\b  
\m  
\c 24
\s1 ذَاوُوذْ إِسّْعِيزّْ خْ ثُوذَارْثْ ن شَاوُولْ  
\m
\v 1 يُويُورْ ذَاوُوذْ سّنِّي ؤُشَا إِقِّيمْ ذِي لْقلْعَاثْ \add ذڭْ إِذُورَارْ\add* ن عَايْنْ-جَاذِي.  
\v 2 ؤُشَا إِمْسَارْ، ؤُمِي د-إِعْقبْ شَاوُولْ زڭْ وضْفَارْ ن إِفِيلِيسْطِينِييّنْ، عَاوْذنْ أَسْ، نَّانْ: ”ذَاوُوذْ أَقَا-ث ذِي ڒخْڒَا ن عَايْنْ-جَاذِي.“  
\v 3 \add خنِّي\add* إِكْسِي شَاوُولْ ثڒْثْ-أَڒَافْ ن يرْيَازنْ إِتّْوَافَارْزنْ زِي مَارَّا إِسْرَائِيل، إِفّغْ حِيمَا أَذْ يَارْزُو خْ ذَاوُوذْ ذ يرْيَازنْ نّسْ أَرنْذَاذْ ن ثْصُوضَارْ ن إِغَايْضنْ ن ڒجْرُوفْ.  
\v 4 نتَّا يُوسَا-د غَارْ ڒْكُورِييَّاثْ ن وُودْجِي إِ \add إِدْجَانْ\add* غَارْ وبْرِيذْ مَانِي ثُوغَا إِدْجَا إِجّْ ن يفْرِي. شَاوُولْ يُوذفْ غَارسْ، حِيمَا أَذْ إِذڒْ إِضَارنْ نّسْ. ثُوغَا ذَاوُوذْ ذ يرْيَازنْ نّسْ قِّيمنْ غَارْ ضفَّارْ ذڭْ إِفْرِي. \f ◼ \fr 24:‏4 \ft \+bd ’حِيمَا أَذْ إِذڒْ إِضَارنْ نّسْ‘\+bd* - أَوَاڒْ-أَ إِخْسْ أَذْ يِينِي ’حِيمَا أَذْ إِبَارْضْ‘.\f*  
\v 5 \add خنِّي\add* نَّانْ أَسْ يرْيَازنْ ن ذَاوُوذْ: ”خْزَارْ، وَا ذ أَسّْ إِ خْ ذ أَشْ إِنَّا سِيذِي: ’خْزَارْ، نشّْ أَذْ أَشْ ڭّغْ ڒعْذُو نّشْ ذڭْ ؤُفُوسْ نّشْ ؤُ شكْ ثْزمَّارذْ أَكِيذسْ ثڭّذْ مِينْ ثتّْوَاڒِيذْ نِيشَانْ ذِي ثِيطَّاوِينْ نّشْ.“ ؤُشَا إِكَّارْ ذَاوُوذْ، إِقسّْ س ثْنُوفّْرَا إِجّْ ن طَّارْفْ زڭْ ؤُسڒْهَامْ ن شَاوُولْ.  
\v 6 أَوَارْنِي أَسْ \add مَاشَا\add* إِسّْذوْذِيوْ ؤُڒْ ن ذَاوُوذْ ذَايسْ، مِينْزِي نتَّا ثُوغَا إِشَارّڭْ إِجّْ ن طَّارْفْ \add زڭْ ؤُسڒْهَامْ\add* ن شَاوُولْ.  
\v 7 نتَّا إِنَّا إِ يرْيَازنْ نّسْ: ”سِيذِي أَذْ أَيِي إِحْضَا أَقَا نشّْ أَذْ ڭّغْ أَيَا إِ سِيذِي إِنُو، إِ ؤُمذْهُونْ ن سِيذِي، أَقَا أَذْ سّْوِيژّْضغْ أَفُوسْ إِنُو ضِيدّْ نّسْ، مَاغَارْ نتَّا ذ أَمذْهُونْ ن سِيذِي!“ \f ◼ \fr 24:‏7 \ft \+bd ’أَمذْهُونْ ن سِيذِي‘\+bd* - أَوَاڒْ-أَ إِخْسْ أَذْ يِينِي ’ونِّي إِتّْوَافَارْزنْ زِي سِيذِي‘.\f*  
\v 8 إِسِّيوڒْ ذَاوُوذْ أَكْ-ذ يرْيَازنْ نّسْ س وَاوَاڒنْ إِقسْحنْ ؤُ وَارْ ثنْ إِجِّي أَذْ هجْمنْ خْ شَاوُولْ. ؤُ شَاوُولْ إِكَّارْ، إِفّغْ-د زڭْ إِفْرِي، إِطّفْ أَبْرِيذْ.   
\m
\v 9 \add خَاسْ ؤُشَا\add* إِكَّارْ ؤُڒَا ذ ذَاوُوذْ، إِفّغْ-د زڭْ إِفْرِي، إِڒَاغَا-د خْ شَاوُولْ، إِنَّا: ”سِيذِي إِنُو، أَجدْجِيذْ!“ ؤُ شَاوُولْ إِخْزَارْ غَارْ ضفَّارْ ؤُشَا يُوضَارْ ذَاوُوذْ س ؤُغمْبُوبْ \add نّسْ\add* غَارْ ثمُّورْثْ، إِبنْذقْ. \f ◼ \fr 24:‏9 \ft \+bd ’س ؤُغمْپُوبْ \+bdit ’نّسْ‘\+bdit*‘\+bd* - س ثْعِيبْرَانِيثْ ’س ثِينْزَارْ نّسْ‘.\f*  
\v 10 إِنَّا ذَاوُوذْ إِ شَاوُولْ: ”مَايمِّي ثسْڒِيذْ غَارْ وَاوَاڒنْ ن إِوْذَانْ، إِنِّي إِقَّارنْ: ’خْژَارْ، ذَاوُوذْ إِخْسْ أَذْ أَشْ إِڭّْ ڒْغَارْ؟‘  
\v 11 خْزَارْ أَسّْ-أَ ثژْرِيذْ س ثِيطَّاوِينْ نّشْ، أَقَا سِيذِي إِڭَّا شكْ أَسّْ-أَ ذڭْ إِفْرِي ذڭْ ؤُفُوسْ إِنُو. نَّانْ أَيِي حِيمَا أَذْ شكْ نْغغْ، مَاشَا نشّْ حَاوْڒغْ خَاكْ، مِينْزِي نِّيغْ \add أَكْ-ذ يِيخفْ إِنُو\add*: ’نشّْ وَارْ سّْوِيژَّاضغْ أَفُوسْ إِنُو ضِيدّْ إِ سِيذِي إِنُو، مَاغَارْ نتَّا ذ أَمذْهُونْ ن سِيذِي.‘  
\v 12 خْزَارْ بَابَا، طَّارْفْ ن ؤُسڒْهَامْ نّشْ أَقَا-ث ذڭْ ؤُفُوسْ إِنُو. ؤُمِي نشّْ شَارّْڭغْ إِجّْ ن طَّارْفْ ن ؤُپَارْثسُّو نّشْ، وَارْ شكْ نْغِيغْ. \add خنِّي\add* سّنْ ؤُ خْزَارْ، أَقَا وَارْ غَارِي ذڭْ ؤُفُوسْ إِنُو ڒَا ذ ثُوعفّْنَا ؤُڒَا ذ أَخطُّو ؤُ نشّْ وَارْ كِيكْ خْضِيغْ شَا. \add مَاشَا\add* شكْ ثَارزُّوذْ حِيمَا أَذْ أَيِي ثكّْسذْ ثُوذَارْثْ إِنُو. \f ◼ \fr 24:‏12 \ft \+bd ’ثُوذَارْثْ إِنُو‘\+bd* - س ثْعِيبْرَانِيثْ ’ڒعْمَارْ إِنُو‘.\f*  
\v 13 سِيذِي أَذْ إِحْكمْ جَارْ أَيِي ذ شكْ ؤُشَا سِيذِي أَذْ إِنْثَاقمْ إِ نشّْ زَّايكْ، \add مَاشَا\add* أَفُوسْ إِنُو وَارْ إِتِّيڒِي خَاكْ.  
\v 14 أَمْ مَامّشْ إِقَّارْ وَاوَاڒْ إِوزْننْ ن ڒجْذُوذْ: ’زڭْ إِعفَّاننْ إِتَّاسْ-د ثُوعفّْنَا!‘، مَاشَا أَفُوسْ إِنُو وَارْ إِتِّيڒِي ضِيدّْ إِ شكْ.  
\v 15 أَوَارْنِي مَانْ ونْ إِضفَّارْ ؤُجدْجِيذْ ن إِسْرَائِيل؟ مَانْ ونْ إِ ثْيمَّارذْ؟ أَوَارْنِي يِيجّْ ن وقْزِينْ إِمُّوثنْ، أَوَارْنِي إِ يِيجّْ ن ؤُينِّي ن ؤُشُورْذُو!  
\v 16 سِيذِي أَذْ يِيڒِي ذ ڒْقَاضِي نّغْ ؤُ نتَّا أَذْ إِحْكمْ جَارْ أَيِي ذ شكْ. نتَّا أَذْ إِخْزَارْ \add ذِي مَانْ أَيَا\add* ؤُشَا أَذْ إِحْكمْ خْ دّعْوثْ إِنُو ؤُ نتَّا أَذْ أَيِي يَاغْ ثَاسْغَارْثْ زڭْ ؤُفُوسْ نّشْ.“ \f ◼ \fr 24:‏16 \ft \+bd ’ڒْقَاضِي‘\+bd* - نِيغْ ’أَمزْرُوفْ‘.\f*   
\m
\v 17 ؤُمِي إِكمّڒْ ذَاوُوذْ خْ ڒْهَارْذْ ن وَاوَاڒنْ-أَ إِ شَاوُولْ، إِمْسَارْ، أَقَا شَاوُولْ إِنَّا: ”مَا ثَا ذ ثْمِيجَّا نّشْ، مِّي ذَاوُوذْ؟“ \add خنِّي\add* إِسّْڭعّذْ شَاوُولْ ثْمِيجَّا نّسْ، إِرُو.  
\v 18 إِنَّا نتَّا إِ ذَاوُوذْ: ”شكْ ذ أَمْسڭّذْ خَافِي نشّْ، مَاغَارْ شكْ ثڭِّيذْ أَكِيذِي مْلِيحْ، مَاشَا نشّْ ڭِّيغْ أَكِيذكْ ثُوعفّْنَا.  
\v 19 شكْ، \add وَاهْ\add* شكْ ثسّشْنذْ أَيِي أَسّْ-أَ، مَامّشْ ذ أَيِي ثڭِّيذْ مْلِيحْ، مَاغَارْ سِيذِي ثُوغَا إِڭَّا أَيِي ذڭْ ؤُفُوسْ نّشْ ؤُ شكْ وَارْ ذ أَيِي ثنْغِيذْ شَا.  
\v 20 مَاغَارْ \add مَاڒَا\add* إِجّْ ن ورْيَازْ يُوفَا ڒعْذُو نّسْ، مَا \add خنِّي\add* أَذْ ث يجّْ أَذْ يُويُورْ أَبْرِيذْ \add نّسْ\add* ذِي ڒْخَارْ؟ سِيذِي أَذْ شكْ إِخدْجصْ س ڒْخَارْ ذِي سِّيبّثْ ن مِينْ ذ أَيِي ثڭِّيذْ أَسّْ-أَ.  
\v 21 ڒخُّو سّْنغْ، أَقَا شكْ أَذْ ثْذوْڒذْ ذ أَجدْجِيذْ ؤُ ثَاڭلْذِيثْ ن إِسْرَائِيل أَذْ ثمْثنْ س ؤُفُوسْ نّشْ.  
\v 22 \add خْ ؤُينِّي\add* جَّادْجْ أَيِي ڒخُّو غَارْ سِيذِي، أَقَا شكْ وَارْ ثْقطّْعضْ زَّارِيعثْ إِنُو أَوَارْنِي أَيِي ؤُ وَارْ ثتّكّْسذْ إِسمْ إِنُو زِي ثَادَّارْثْ ن بَابَا!“  
\v 23 ذَاوُوذْ إِجُّودْجْ إِ شَاوُولْ ؤُ شَاوُولْ يَارڭّْوحْ غَارْ ثَادَّارْثْ نّسْ ؤُ ذَاوُوذْ ذ يرْيَازنْ نّسْ ڭعّْذنْ غَارْ لْبُورْجْ \add ذڭْ إِذُورَارْ\add*.   
\b  
\b  
\m  
\c 25
\s1 ذَاوُوذْ ذ نَابَالْ أَكْ-ذ أَبِيجَايِيلْ  
\m
\v 1 شَامْوِيلْ إِمُّوثْ ؤُ مَارَّا إِسْرَائِيل إِمُونْ. نِيثْنِي وْثِينْ خَاسْ أَڭجْذُورْ ؤُ نضْڒنْ ث ذِي ثَادَّارْثْ نّسْ ذِي رَامَا. \add خَاسْ ؤُشَا\add* إِكَّارْ ذَاوُوذْ، إِهْوَا غَارْ ڒخْڒَا ن فَارَانْ. \x ◘ \xo 25:‏1 \xt 1 صم. 28‏:‏3\x*  
\v 2 ثُوغَا ذِي مَاعُونْ إِجّْ ن ورْيَازْ ونِّي ثُوغَا غَارْ إِدْجَا وَاڭْڒَا ذِي كَارْمِيلْ. أَرْيَازْ ثُوغَا ذ بُو-وَاڭْڒَا أَڒْ طَّارْفْ، إِدْجَا غَارسْ ثڒْثْ-أَڒَافْ ن وُودْجِي ذ أَڒفْ ن إِغَايْضنْ. نتَّا ثُوغَا إِدْجَاسْ ؤُدْجِي نّسْ ذِي كَارْمِيلْ.  
\v 3 أَرْيَازْ تّْڒَاغَانْ أَسْ نَابَالْ ؤُ ثَامْغَارْثْ نّسْ تّْڒَاغَانْ أَسْ أَبِيجَايِيلْ. ثَامْغَارْثْ ثُوغَا غَارسْ ڒعْقڒْ مْلِيحْ ؤُ ثُوغَا-ت ذ مُوصْبِيحْ إِ ڒْخزْرَاثْ، مَاشَا أَرْيَازْ ثُوغَا إِقْسحْ ؤُ ثِيمڭَّا نّسْ ذ ثِيعفَّانِينْ \add إِ دْجَانْثْ\add*. نتَّا ثُوغَا-ث أَمْ وُوڒْ نّسْ. \f ◼ \fr 25:‏3 \ft \+bd ’نَابَالْ‘\+bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَپُوهَاڒِي‘. \+bd ’أَبِيجَايِيلْ‘\+bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’بَابَا ذ ڒفْرَاحثْ إِنُو‘.\f*   
\m
\v 4 \add ؤُمِي\add* إِسْڒَا ذَاوُوذْ ذِي ڒخْڒَا، أَقَا نَابَالْ ثُوغَا إِدْجَاسْ ؤُدْجِي نّسْ،  
\v 5 إِسّكّْ ذَاوُوذْعشْرَا ن إِمْسخَّارنْ ذِينْ. إِنَّا ذَاوُوذْ إِ إِحُوذْرِييّنْ: ”ڭَاعّْذمْ غَارْ كَارْمِيلْ ؤُ خْمِي غَا ثَاوْضمْ غَارْ نَابَالْ، إِتّْخصَّا أَومْ أَذْ ثسّقْسَامْ خْ ؤُمدُّورْ نّسْ ذڭْ يِيسمْ إِنُو.  
\v 6 إِتّْخصَّا أَذْ ثِينِيمْ أَمُّو: ’إِڒِي أَذْ خَاكْ يِيڒِي ڒهْنَا ؤُشَا أَذْ يِيڒِي ڒهْنَا خْ ثَادَّارْثْ نّشْ ذ ڒهْنَا \add غَارْ\add* مَارَّا مِينْ إِدْجَانْ نّشْ!  
\v 7 أَقَا نشّْ سْڒِيغْ بلِّي شكْ غَاركْ إِروَّانْ. إِوَا خنِّي، إِمكْسَاونْ نِّي غَاركْ ثُوغَا أَثنْ أَكِيذْنغْ ؤُشَا نشِّينْ وَارْ ثنْ نْخوّجْ شَا ؤُشَا وَارْ ثنْ إِنْقِيصْ وَالُو زِي مِينْ غَارْسنْ مَارَّا ؤُسَّانْ إِ إِكِّينْ نِيثْنِي \add أَكِيذْنغْ\add* ذِي كَارْمِيلْ.  
\v 8 سقْسَا إِمْسخَّارنْ نّشْ ؤُ نِيثْنِي أَذْ أَشْ إِنِينْ. أجّْ أَذْ أَفنْ إِمْسخَّارنْ أَرْضَا ذِي ثِيطَّاوِينْ نّشْ، مَاغَارْ نُوسَا-د غَارْ إِجّْ ن وَاسّْ ن وُورَارْ. تّْزَاوْڭغْ، أوْشْ إِ إِمْسخَّارنْ نّشْ ؤُ إِ مِّيشْ ذَاوُوذْ مِينْ غَا يَافْ ؤُفُوسْ نّشْ.‘ “   
\m
\v 9 \add ؤُمِي\add* إِوْضنْ إِمْسخَّارنْ ن ذَاوُوذْ \add ذِينْ\add*، سِّيوْڒنْ أَكْ-ذ نَابَالْ مَارَّا أَوَاڒنْ-أَ ذڭْ يِيسمْ ن ذَاوُوذْ، ؤُشَا قِّيمنْ تّْرَاجَانْ.  
\v 10 \add مَاشَا\add* نَابَالْ يَارَّا-د خْ إِمْسخَّارنْ ن ذَاوُوذْ، إِنَّا: ”مَانْ ونْ إِ إِدْجَانْ ذَاوُوذْ ؤُ مَانْ ونْ إِ إِدْجَانْ ذ مِّيسْ ن يَاسَّا؟ أَسّْ-أَ \add أَقَا ذِينْ\add* أَطَّاسْ ن إِمْسخَّارنْ نِّي يَاروْڒنْ. كُوڒْ إِجّْ \add يَارْوڒْ\add* زِي زَّاثْ ن وُوذمْ ن بَابْ نّسْ.  
\v 11 مَا أَذْ كْسِيغْ خنِّي أَغْرُومْ إِنُو ذ وَامَانْ إِنُو ذ ثْغَارْصْثْ إِ غَارْصغْ إِ إِروَّانْ إِنُو ؤُشَا أَذْ ث وْشغْ إِ يرْيَازنْ خْ يِينِّي وَارْ سِّينغْ ؤُڒَا ذ مَانِيسْ د-ؤُسِينْ نِيثْنِي؟“  
\v 12 \add خنِّي\add* نّْقڒْبنْ إِمْسخَّارنْ ن ذَاوُوذْ غَارْ وبْرِيذْ إِ زِي د-ؤُسِينْ،عقْبنْ ؤُشَا ؤُسِينْ-د \add غَارْ ذَاوُوذْ\add* ؤُ حَاجَانْ أَسْ مَارَّا أَوَاڒنْ-أَ. \f ◼ \fr 25:‏12 \ft \+bd ’غَارْ وبْرِيذْ إِ زِي د-ؤُسِينْ‘\+bd* - س ثْعِيبْرَانِيثْ ’غَارْ وبْرِيذْ نْسنْ‘.\f*  
\v 13 \add خَاسْ ؤُشَا\add* إِنَّا ذَاوُوذْ إِ يرْيَازنْ نّسْ: ”كُورْ أَرْيَازْ أَذْ إِبْيسْ سِّيفْ نّسْ!“ ؤُشَا \add كُوڒْ\add* أَرْيَازْ إِبْيسْ سِّيفْ نّسْ، ؤُڒَا ذ ذَاوُوذْ إِبْيسْ سِّيفْ نّسْ. نِيثْنِي ڭعّْذنْ أَوَارْنِي إِ ذَاوُوذْ، أَمنِّي أَربْعَا-مْيَا ن يرْيَازنْ، ؤُ قِّيمنْ مِيثَاينْ غَارْ ڒحْوَايجْ.   
\b  
\m
\v 14 إِجّنْ زڭْ إِمْسخَّارنْ ثُوغَا إِحَاجَا أَيَا إِ أَبِيجَايِيلْ، ثَامْغَارْثْ ن نَابَالْ، إِنَّا \add أَسْ\add*: ”خْزَارْ، ذَاوُوذْ إِسّكّْ-د إِرقَّاسنْ زِي ڒخْڒَا حِيمَا أَذْ سِّيوْضنْ لْبَارَاكَا إِ سِيذِيثْنغْ، مَاشَا وَانِيثَا إِقْڒعْ خَاسنْ س ثْزَاوَارْثْ.  
\v 15 إِرْيَازنْ ثُوغَا أَثنْ شْنَانْ إِ نشِّينْ ؤُ نِيثْنِي وَارْ ذ أَنغْ سدّْعنْ شَا. وَارْ نفْقِيذْ وَالُو مَارَّا ؤُسَّانْ إِ ذِينِّي نسّعْذُو أَكِيذْسنْ ذڭْ إِيَّارْ ن ثَاروْسَا.  
\v 16 نِيثْنِي ثُوغَا أَثنْ أَمْ يِيجّْ ن ڒْحِيضْ إِ نشِّينْ، دْجِيڒثْ ذ وَاسّْ، ذِي مَارَّا ؤُسَّانْ إِ كِيذْسنْ ندْجْ ؤُ ثُوغَا نشِّينْ نَارْوسْ ؤُدْجِي.  
\v 17 ڒخُّو أَقَا ثسّْنذْ ت. خْزَارْ مْلِيحْ، مِينْ إِتّْخصَّا أَذْ ث ثڭّذْ، مَاغَارْ ڒْغَارْ خْ سِيذِيثْنغْ ذ مَارَّا ثَادَّارْثْ نّسْ إِمْثنْ. نتَّا ذ إِجّْ ن ورْيَازْ وَارْ إِسكّْوِي وَاوَاڒْ أَكِيذسْ.“  
\v 18 ثْقدْجقْ أَبِيجَايِيلْ، ثكْسِي مِيثَاينْ ن ثشْنِيفِينْ ذ ثْنَاينْ ن ثْخُونْشَايْ ن يِيڒمْ إِ بِينُو ذ خمْسَا ن ثخْسِيوِينْ وجْذنْثْ ذ خمْسَا ن ڒقْيَاسْ ن ثغْوَاوِينْ ذ مْيَا ن ثْغَايِيطَاثِينْ ن زّْبِيبْ ذ مِيثَاينْ ن إِغْرُومنْ ن ثَازَارْثْ، ؤُ نتَّاثْ ثسَّارْسْ مَانَاونِّي مَارَّا خْ يغْيَاڒْ. \f ◼ \fr 25:‏18 \ft \+bd ’ڒقْيَاسْ‘\+bd* - عْڒَاينْ 7-8 لِيثْرُو.\f*  
\v 19 ثنَّا إِ إِمْسخَّارنْ نّسْ: ”ؤُيُورمْ زَّاثْ إِ وُوذمْ إِنُو. خْزَارْ نشّْ أَذْ كنِّيوْ أَرذْفغْ.“ \add مَاشَا\add* نتَّاثْ وَارْ ذ أَسْ ثنِّي أَيَا إِ ورْيَازْ نّسْ نَابَالْ. \f ◼ \fr 25:‏19 \ft \+bd ’ؤُيُورُومْ‘\+bd* - س ثْعِيبْرَانِيثْ ’ژْوَامْ‘.\f*   
\m
\v 20 ؤُمِي ثنْيَا نتَّاثْ خْ وغْيُوڒْ، ثهْوَا خْ ؤُذُورِّي ن وذْرَارْ، خْزَارْ، إِمْسَارْ أَقَا ذَاوُوذْ ذ يرْيَازنْ نّسْ هْوَانْ-د إِ ؤُمْسَاڭَارْ أَكِيذسْ ؤُ نتَّاثْ ثمّڒْقَا أَكِيذْسنْ.  
\v 21 ذَاوُوذْ ثُوغَا إِنَّا: ”س ثِيذتّْ، بَاطڒْ إِ حْضِيغْ خْ مَارَّا مِينْ غَارسْ إِدْجَانْ ذِي ڒخْڒَا، أَڒَامِي وَارْ إِودَّارْ وَالُو زِي مِينْ غَارسْ. نتَّا إِخدْجصْ أَيِي مِينْ إِصبْحنْ س مِينْ وَارْ إِحْڒِينْ.  
\v 22 أجّْ أَذْ إِڭّْ أَربِّي ثَا ذ ثَا أَكْ-ذ ڒْعذْيَانْ ن ذَاوُوذْ ؤُ أَذْ ذَايسْ يَارْنِي عَاذْ، مَاڒَا نشّْ أَذْ جّغْ أَڒْ ثِيوشَّا ؤُڒَا ذ إِجّْ ونِّي ث إِتّڭّنْ خْ ڒْحِيضْ زِي مَارَّا مِينْ غَارسْ!“   
\m
\v 23 ؤُمِي ثژْرَا أَبِيجَايِيلْ ذَاوُوذْ، ثضْرَا ذغْيَا خْ وغْيُوڒْ نّسْ، ثوْضَا \add خْ ثمُّورْثْ\add* زَّاثْ إِ ذَاوُوذْ، ثُوضَارْ \add أَسْ\add* س ؤُغمْبُوبْ نّسْ غَارْ ثمُّورْثْ.  
\v 24 نتَّاثْ ثوْضَا أَسْ غَارْ إِضَارنْ، ثنَّا: ”نشّْ، وَاهَا، إِ ذِي إِدْجَا ڒْعِيبْ، \add أَ\add* سِيذِي إِنُو. أجّْ أَذْ ثسِّيوڒْ ثَايَّا نّشْ أَكِيذكْ ؤُ سڒْ إِ وَاوَاڒنْ ن ثَايَّا نّشْ.  
\v 25 أجّْ سِيذِي إِنُو وَارْ إِخزَّارْ غَارْ ورْيَازْ-أَ إِ وَارْ إِسكّْوِينْ، غَارْ نَابَالْ، مَاغَارْ أَمْ مَامّشْ ذ أَسْ قَّارنْ، أَمُّو \add إِ يدْجَا\add* نتَّا. نَابَالْ ذ إِسمْ نّسْ ؤُ ثُوبُّوهڒْيَا أَقَا-ت ذَايسْ. \bd نشّْ\bd*، ثَايَّا نّشْ، وَارْ ژْرِيغْ شَا إِمْسخَّارنْ ن سِيذِي إِنُو إِ د-ثسّكّذْ.  
\v 26 خنِّي ڒخُّو، أَ سِيذِي، \add س ثِيذتّْ\add* أَمْ إِدَّارْ سِيذِي ؤُ إِدَّارْ ڒعْمَارْ نّشْ، أَقَا سِيذِي ذ ونِّي شكْ إِمّنْعنْ مَاحنْذْ أَذْ ثسِّيزّْڒذْ إِذَامّنْ ؤُ أَذْ ثْفكّذْ إِخفْ نّشْ س ؤُفُوسْ نّشْ. أَذْ ذوْڒنْ ڒخُّو ڒْعذْيَانْ نّشْ ذ يِينِّي يَارزُّونْ أَذْ ڭّنْ ڒْغَارْ ذِي سِيذِي إِنُو أَمْ نَابَالْ.  
\v 27 إِوَا ڒخُّو، مَانْ أَيَا ذ لْبَارَاكَا إِ د-ثِيوِي ثَايَّا نّشْ إِ سِيذِي إِنُو، مَاحنْذْ أَذْ ت وْشنْ إِ إِمْسخَّارنْ نِّي يُويُورنْ ذڭْ إِصُورَافْ ن سِيذِي إِنُو.  
\v 28 تّْزَاوْڭغْ، غْفَارْ أَخطُّو إِ ثَايَّا نّشْ، مَاغَارْ سِيذِي \add أَربِّي\add* أَذْ إِسّْبدّْ إِ سِيذِي إِنُو إِشْثْ ن ثَادَّارْثْ ثمْثنْ، مِينْزِي سِيذِي إِنُو إِتّڭّْ ڭَارَّاثْ ن سِيذِي ؤُ وَارْ ذَايكْ إِتّْوَافّْ ڒْغَارْ زڭْ وُوسَّانْ \add إِمزْوُورَا\add* نّشْ.  
\v 29 \add مَاڒَا\add* إِجّْ ن بْنَاذمْ إِكَّارْ خَاكْ حِيمَا أَذْ شكْ إِضْفَارْ، حِيمَا أَذْ يَارْزُو خْ ڒعْمَارْ نّشْ، خنِّي أَذْ يِيڒِي ڒعْمَارْ ن سِيذِي إِنُو \add ذِي ڒَامَانْ،\add* إِقّنْ ذِي ثشْيَارْثْ ن يِينِّي إِدَّارنْ غَارْ سِيذِي أَربِّي نّشْ، \add مَاشَا\add* ڒعْمَارْ ن ڒْعذْيَانْ نّشْ أَذْ زَّايسْ إِحجَّارْ نتَّا غَارْ ڒَاڭّْوَاجْ زڭْ ؤُكمِّيشْ ن إِدْجِييْ.  
\v 30 أَذْ إِمْسَارْ، مَاڒَا سِيذِي أَذْ إِڭّْ أَكْ-ذ سِيذِي إِنُو عْلَاحْسَابْ مَارَّا ثَاصبْحَانْثْ إِ خَاكْ إِسِّيوڒْ ؤُ أَذْ شكْ يڭّْ ذ ڒْحَاكمْ خْ إِسْرَائِيل،  
\v 31 خنِّي وَارْ إِتِّيڒِي أَيَا إِ شكْ، \add أَ\add* سِيذِي إِنُو، ذ سِّيبّثْ إِ زِي غَا ثنْقَارْضذْ ؤُڒَا ذ ثَاعنْكْرِيفْثْ إِ وُوڒْ، أَقَا شكْ ثسِّيزّْڒذْ إِذَامّنْ بَاطڒْ ؤُ أَقَا سِيذِي إِنُو إِڭَّا أَذْ إِفكّْ إِخفْ نّسْ. مَاڒَا سِيذِي \add أَربِّي\add* أَذْ إِڭّْ ڒْخَارْ ذِي سِيذِي إِنُو، عْقڒْ \add خنِّي\add* خْ ثَايَّا نّشْ.“   
\m
\v 32 \add خنِّي\add* إِنَّا ذَاوُوذْ إِ أَبِيجَايِيلْ: ”أَذْ إِتّْوَابَاركْ سِيذِي، أَربِّي ن إِسْرَائِيل، ونِّي شمْ د-إِسّكّنْ أَسّْ-أَ إِ ؤُمْسَاڭَارْ أَكِيذِي!  
\v 33 أَقَا ثتّْوَابَاركْ ڒفْهَامثْ نّمْ ؤُشَا ثتّْوَابَارْكذْ ؤُڒَا ذ شمْ، ڒَامِي ذ أَيِي ثسّْبدّذْ أَسّْ-أَ زڭْ ؤُسِيزّڒْ ن إِذَامّنْ ؤُ زِي نّقْمثْ إِ يِيخفْ إِنُو س إِفَاسّنْ إِنُو!  
\v 34 \add مَاغَارْ\add* س ثِيذتّْ، أَمْ إِدَّارْ سِيذِي، أَربِّي ن إِسْرَائِيل، ونِّي ذ أَيِي إِسّْبدّنْ أَذْ أَمْ ڭّغْ ڒْغَارْ، مَاڒَا شمْ وَارْ غَارِي د-ثفِّيغذْ ذغْيَا، خنِّي وَارْ إِتّْغِيمِي غَارْ ثْفَاوْثْ ن ثُوفُّوثْ ؤُڒَا ذ إِجّنْ \add زڭْ إِوْذَانْ\add* ن نَابَالْ، ونِّي ث إِتّڭّنْ خْ ڒْحِيضْ!“  
\v 35 ؤُشَا إِكْسِي ذَاوُوذْ زڭْ ؤُفُوسْ نّسْ مِينْ ثُوغَا إِ ذ أَسْ د-ثِيوِي، إِنَّا أَسْ: ”ؤُيُورْ ذِي ڒهْنَا غَارْ ثَادَّارْثْ نّمْ! خْزَارْ، نشّْ سْڒِيغْ-د غَارمْ ؤُ أَذْ سّْڭعّْذغْ ؤُذمْ نّمْ \add إِحزْننْ\add*.“ \f ◼ \fr 25:‏35 \ft \+bd ’سْڒِيغْ غَاركْ‘\+bd* - س ثْعِيبْرَانِيثْ ’سْڒِيغْ إِ ثْمِيجَّا نّمْ‘.\f*   
\b  
\m
\v 36 \add ؤُمِي\add* د-ثُوسَا أَبِيجَايِيلْ غَارْ نَابَالْ، إِتّڭّْ نتَّا إِشْثْ ن زَّارْذثْ ن ثِيسِّيثْ ذِي ثَادَّارْثْ نّسْ أَمْ يِيشْثْ ن زَّارْذثْ ن ؤُجدْجِيذْ. ؤُڒْ ن نَابَالْ ثُوغَا-ث خْ ڒْخَاضَارْ نّسْ، إِسْشَارْ أَڒْ طَّارْفْ. س ؤُينِّي نتَّاثْ وَارْ ذ أَسْ ثنِّي ؤُڒَا ذ إِجّْ ن وَاوَاڒْ، أَمژْيَانْ نِيغْ أَمقّْرَانْ، خْ مِينْ إِمْسَارنْ أَڒْ ثَافَاوْثْ ن ثُوفُّوثْ.  
\v 37 غَارْ ثُوفُّوثْ، ڒَامِي إِفّغْ بِينُو خْ نَابَالْ، إِمْسَارْ، أَقَا ثَامْغَارْثْ نّسْ ثنَّا أَسْ مَانْ أَيَا. ؤُشَا إِجْمذْ وُوڒْ نّسْ، إِذْوڒْ أَمْ يِيجّْ ن وژْرُو.  
\v 38 أَوَارْنِيعشْرَا ن وُوسَّانْ، إِمْسَارْ، أَقَا سِيذِي إِوْثَا نَابَالْ أَڒَامِي إِمُّوثْ.   
\m
\v 39 ؤُمِي إِسْڒَا ذَاوُوذْ بلِّي نَابَالْ إِمُّوثْ، إِنَّا نتَّا: ”أَذْ إِتّْوَابَاركْ سِيذِي ونِّي إِڭِّينْ ڒْحُوكْمْ خْ ڒْحڭْرَا إِ ذ أَيِي إِتّْوَاڭّنْ، إِتَّارْ إِ-ث زڭْ ؤُفُوسْ ن نَابَالْ، ؤُشَا إِسّْبدّْ أَمْسخَّارْ نّسْ حِيمَا أَذْ إِڭّْ ڒْغَارْ. سِيذِي يَارَّا ڒْغَارْ ن نَابَالْ أَذْ د-إِذْوڒْ خْ ؤُزدْجِيفْ نّسْ!“ ؤُشَا ذَاوُوذْ إِسّكّْ \add إِجّْ\add* ؤُ وَانِيثَا إِسِّيوڒْ أَكْ-ذ أَبِيجَايِيلْ، حِيمَا أَذْ ت يَاوِي ذ ثَامْغَارْثْ إِ نتَّا.   
\b  
\m
\v 40 \add ؤُمِي\add* د-ؤُسِينْ إِمْسخَّارنْ ن ذَاوُوذْ غَارْ أَبِيجَايِيلْ غَارْ كَارْمِيلْ، سِّيوْڒنْ أَكِيذسْ، نَّانْ: ”ذَاوُوذْ إِسّكّْ أَنغْ-د غَارمْ، حِيمَا أَذْ شمْ نَاوِي ذ ثَامْغَارْثْ إِ نتَّا.“  
\v 41 \add ڒخْذنِّي\add* ثكَّارْ، ثْبنْذقْ س ؤُغمْبُوبْ نّسْ غَارْ ثمُّورْثْ، ثنَّا: ”خْزَارْ، ثَامْسخَّارْثْ نّشْ أَمْ يِيشْثْ ن ثَايَّا، حِيمَا أَذْ ثسِّيرْذْ إِضَارنْ إِ إِمْسخَّارنْ ن سِيذِي إِنُو.“  
\v 42 ثْقدْجقْ أَبِيجَايِيلْ، ثكَّارْ. نتَّاثْ ثنْيَا خْ وغْيُوڒْ نّسْ أَكْ-ذ خمْسَا ن ثمْسخَّارِينْ نّسْ ثِيمژَايْنِينْ ثِينِّي ت يَاردّْفنْ خْ إِضَارنْ. نتَّاثْ ثضْفَارْ إِرقَّاسنْ ن ذَاوُوذْ ؤُشَا ثذْوڒْ ذ ثَامْغَارْثْ نّسْ.   
\m
\v 43 يِيوِي ذَاوُوذْ عَاوذْ أَخِينُوعَامْ زِي يَازْرَاعِيلْ \add ذ ثَامْغَارْثْ\add*. نِيثنْثِي س ثْنَاينْ إِذْسنْثْ ذوْڒنْثْ ذ ثَامْغَارْثْ إِ نتَّا.  
\v 44 شَاوُولْ مَاشَا ثُوغَا إِوْشَا يدْجِيسْ مِيخَالْ، ثَامْغَارْثْ ن ذَاوُوذْ، إِ بَالْثِي، مِّيسْ ن لَايِيشْ ونِّي \add إِدْجَانْ\add* زِي جَالِّيمْ. \x ◘ \xo 25:‏44 \xt 2 صم. 3‏:‏15\x*   
\b  
\b  
\m  
\c 26
\s1 ذَاوُوذْ إِسّْعِيزّْ خْ ثُوذَارْثْ ن شَاوُولْ إِ ثْوَاڒَا وِيسّْ ثْنَاينْ  
\m
\v 1 إِرْيَازنْ ن زِيفْ ؤُسِينْ-د غَارْ شَاوُولْ غَارْ جِيبْعَا، نَّانْ: ”مَا وَارْ إِسّْنُوفَّارْ ذَاوُوذْ إِخفْ نّسْ خْ ثوْرِيرْثْ ن حَاخِيلَا أَرنْذَاذْ ن ثْنزْرُوفْثْ؟“  
\v 2 \add خنِّي\add* إِكَّارْ شَاوُولْ ؤُشَا إِهْوَا غَارْ ڒخْڒَا ن زِيفْ، أَكِيذسْ ثڒْثْ-أَڒَافْ ن يرْيَازنْ إِتّْوَافَارْزنْ زِي إِسْرَائِيل، حِيمَا أَذْ يَارْزُو خْ ذَاوُوذْ ذِي ڒخْڒَا ن زِيفْ.  
\v 3 إِوْثَا شَاوُولْ إِقِيضَانْ نّسْ غَارْ وبْرِيذْ خْ ثوْرِيرْثْ ن حَاخِيلَا ثنِّي أَرنْذَاذْ ن ثْنزْرُوفْثْ. ذَاوُوذْ إِقِّيمْ ذِي ڒخْڒَا، إِژْرَا شَاوُولْ إِضْفَارْ إِ-ث-إِ-د غَارْ ڒخْڒَا.  
\v 4 \add مَاغَارْ\add* ذَاوُوذْ ثُوغَا إِسّكّْ إِخْبَارْجِييّنْ ؤُ نتَّا ثُوغَا إِسّنْ أَقَا شَاوُولْ إِڭَّا أَذْ د-يَاسْ.  
\v 5 ذَاوُوذْ إِكَّارْ ؤُ يُوسَا-د مَانِي ثُوغَا إِوْثَا شَاوُولْ إِقِيضَانْ نّسْ. ذَاوُوذْ ثُوغَا إِتّْوَاڒَا مَانِي ثُوغَا إِزّڒْ شَاوُولْ أَكْ-ذ ؤُكُومَانْذَارْ ن ڒْعسْكَارْ نّسْ، أَبْنِيرْ، مِّيسْ ن نِيرْ. شَاوُولْ إِطّصْ ذِي ڒْمَارْڭحْ ن إِكَارُّوثنْ ؤُ ڒْڭنْسْ ثُوغَا إِنّضْ أَسْ-د \add س إِقِيضَانْ نْسنْ\add*.  
\v 6 \add خنِّي\add* إِطّفْ ذَاوُوذْ ذڭْ وَاوَاڒْ. إِسِّيوڒْ أَكْ-ذ أَخِيمَالِيكْ، أَحِيتِّي، ؤُ أَكْ-ذ أَبِيشَايْ، مِّيسْ ن صِيرُويَا، ؤُمَاسْ ن يُووَابْ، إِنَّا: ”مَانْ ونْ أَكِيذِي إِ غَا إِهْوَانْ غَارْ شَاوُولْ ذِي ڒْمَارْڭحْ ن ڒْعسْكَارْ؟“ أَبِيشَايْ إِنَّا: ”نشّْ أَذْ كِيذكْ هْوِيغْ.“   
\m
\v 7 يُوسَا-د ذَاوُوذْ أَكْ-ذ أَبِيشَايْ ذِي دْجِيڒثْ غَارْ ڒْڭنْسْ، ؤُ خْزَارْ، شَاوُولْ ثُوغَا إِطّصْ ذِي ڒْمَارْڭحْ ن إِكَارُّوثنْ ؤُ لَانْسَا نّسْ ثجِّي زَّاثْ إِ ؤُزدْجِيفْ نّسْ ذِي ثمُّورْثْ. إِنّْضنْ أَسْ-د أَبْنِيرْ ذ ڒْڭنْسْ.  
\v 8 \add خنِّي\add* إِنَّا أَبِيشَايْ إِ ذَاوُوذْ: ”أَسّْ-أَ إِقّنْ سِيذِي ڒعْذُو نّشْ ذڭْ ؤُفُوسْ نّشْ. أجّْ أَيِي ڒخُّو أَذْ ث سّْنُوقّْبغْ أَكْ-ذ ثمُّورْثْ س إِشْثْ ن ثشْثِي ن لَانْسَا. وَارْ تّحْذِيجِيغْ أَذْ ت ڭّغْ إِشْثْ ن ثْوَاڒَا نّغْنِيثْ.“  
\v 9 ذَاوُوذْ إِنَّا إِ أَبِيشَايْ: ”وَارْ ث تَّاردّدْجْ شَا، مَاغَارْ مَانْ ونْ إِزمَّارنْ أَذْ يَارّْ أَفُوسْ نّسْ غَارْ ؤُمذْهُونْ ن سِيذِي ؤُشَا أَذْ إِقِّيمْ ذ أَفُورِّي؟“  
\v 10 \add خنِّي\add* إِنَّا ذَاوُوذْ: ”\add س ثِيذتّْ أَمْ\add* إِدَّارْ سِيذِي، سِيذِي أَذْ ث إِوّثْ: نِيغْ أَذْ د-يَاسْ وَاسّْ نّسْ إِ ذِي إِ غَا إِمّثْ نِيغْ أَذْ د-إِهْوَا غَارْ ؤُمنْغِي ؤُشَا أَذْ إِتّْوَانغْ.  
\v 11 سِيذِي أَذْ أَيِي إِحْضَا أَقَا نشّْ أَذْ وْثغْ س ؤُفُوسْ إِنُو أَمذْهُونْ ن سِيذِي. تّْزَاوْڭغْ شكْ، كْسِي لَانْسَا إِ \add إِدْجَانْ\add* زَّاثْ إِ ؤُزدْجِيفْ نّسْ ذ ثبْرِيقْثْ ن وَامَانْ ؤُشَا أجّْ أَنغْ أَذْ نُويُورْ!“  
\v 12 إِكْسِي ذَاوُوذْ لَانْسَا ذ ثبْرِيقْثْ ن وَامَانْ \add إِ ثُوغَا ذِينْ إِدْجَانْ\add* زَّاثْ إِ ؤُزدْجِيفْ ن شَاوُولْ ؤُشَا فّْغنْ نِيثْنِي. ؤُڒَا ذ إِجّْ وَارْ \add ث\add* إِژْرِي، ڒَا ذ إِجّْ وَارْ \add ث\add* يُوشِي ؤُ ؤُڒَا ذ إِجّْ وَارْ إِفِيقْ، مَاغَارْ مَارَّا طّْصنْ، مِينْزِي سِيذِي ثُوغَا إِسّغْضسْ إِ-ثنْ ذڭْ إِجّْ ن يِيضصْ يُودْجغْ.  
\v 13 ذَاوُوذْ إِعْذُو غَارْ ؤُغزْذِيسْ نّغْنِي ؤُشَا إِبدّْ غَارْ ڒَاڭّْوَاجْ خْ ثْقِيشَّاثْ ن وذْرَارْ. ثُوغَا إِدْجَا تَّاسِيعْ ذ أَمقّْرَانْ جَارْ أَسنْ.  
\v 14 إِڒَاغَا-د ذَاوُوذْ إِ ڒْڭنْسْ ؤُ إِ أَبْنِيرْ، مِّيسْ ن نِيرْ، إِنَّا: ”مَا وَارْ د-ثَارِّيذْ شَا، أَبْنِيرْ؟“ \add خنِّي\add* يَارَّا-د أَبْنِيرْ، إِنَّا: ”مِينْ ثعْنِيذْ شكْ ونِّي ذ إِتّْڒَاغَانْ خْ ؤُجدْجِيذْ؟“  
\v 15 \add خنِّي\add* إِنَّا ذَاوُوذْ إِ أَبْنِيرْ: ”مَا شكْ وَارْ ثدْجِيذْ ذ أَرْيَازْ؟ مَانْ ونْ ذِي إِسْرَائِيل إِ إِدْجَانْ أَمْ شكْ؟ مَايمِّي \add خنِّي\add* وَارْ ثحْضِيذْ خْ سِيذِي نّشْ، أَجدْجِيذْ؟ أَقَا إِجّنْ زِي ڒْڭنْسْ يُوذفْ-د حِيمَا أَذْ يَاردّدْجْ أَجدْجِيذْ، سِيذِي نّشْ.  
\v 16 مِينْ ثڭِّيذْ وَارْ إِدْجِي شَا مْلِيحْ. \add س ثِيذتّْ أَمْ\add* إِدَّارْ سِيذِي، كنِّيوْ ذ ثَارْوَا ن ڒْموْثْ، مِينْزِي كنِّيوْ وَارْ ثْعسّمْ خْ سِيذِي نْومْ، أَمذْهُونْ ن سِيذِي! خْزَارْ مَانِي دْجَانْثْ ڒخُّو لَانْسَا ن ؤُجدْجِيذْ ذ ثبْرِيقْثْ ن وَامَانْ ثِينِّي ثُوغَا زَّاثْ إِ ؤُزدْجِيفْ نّسْ!“   
\m
\v 17 شَاوُولْ إِعْقڒْ ثْمِيجَّا ن ذَاوُوذْ، إِنَّا: ”مَا ثَا ذ ثْمِيجَّا نّشْ، أَ مِّي ذَاوُوذْ؟“ ذَاوُوذْ إِنَّا: ”أَقَا-ت ذ ثْمِيجَّا إِنُو، سِيذِي إِنُو، أَجدْجِيذْ!“  
\v 18 \add خنِّي\add* إِنَّا: ”مَايمِّي إِضفَّارْ سِيذِي إِنُو أَمْسخَّارْ نّسْ أَمُّو؟ مِينْزِي مِينْ ڭِّيغْ ؤُ مَانْ \add ث\add* ڒْعِيبْ إِ \add يُومْسنْ\add* غَارْ ؤُفُوسْ إِنُو؟  
\v 19 خنِّي ڒخُّو، أجّْ أَذْ إِسڒْ سِيذِي إِنُو، أَجدْجِيذْ، إِ وَاوَاڒنْ ن ؤُمْسخَّارْ نّسْ. مَاڒَا سِيذِي إِسّهْوڒْ إِ شكْ خَافِي، إِڒِي أَذْ إِشمّْ نتَّا ثَاوْهِيبْثْ \add ن ڒْغِيدْجثْ\add*، مَاشَا مَاڒَا ذ إِوْذَانْ \add إِ إِدْجَانْ\add*، \add خنِّي\add* أَذْ تّْوَانعْڒنْ نِيثْنِي زَّاثْ إِ وُوذمْ ن سِيذِي، مَاغَارْ نِيثْنِي ؤُژّْڒنْ خَافِي أَسّْ-أَ أَڒَامِي وَارْ زمَّارغْ أَذْ قِّيمغْ قّْنغْ \add عَاذْ\add* إِ ڒْوَارْثْ ن سِيذِي، ؤُ \add مَاغَارْ\add* نِيثْنِي قَّارنْ: ’رُوهْ، سخَّارْ إِ إِربِّيثنْ إِنّغْنِي!‘  
\v 20 \add خنِّي\add* ڒخُّو، أجّْ إِذَامّنْ إِنُو وَارْ تِّيزّْڒنْ ذڭْ إِشْثْ ن ثمُّورْثْ إِڭّْوجنْ خْ سِيذِي. مِينْزِي أَجدْجِيذْ ن إِسْرَائِيل إِفّغْ، حِيمَا أَذْ يَارْزُو خْ إِجّْ ن ؤُينِّي ن ؤُشُورْذُو وَاهَا، أَمْ مَامّشْ يمَّارنْ ثَاسكُّورْثْ ذڭْ إِذُورَارْ.“ \x ◘ \xo 26:‏20 \xt 1 صم. 24‏:‏15\x*   
\m
\v 21 \add خَاسْ\add* ؤُشَا إِنَّا شَاوُولْ: ”نشّْ خْضِيغْ، عْقبْ-د، \add أَ\add* مِّي ذَاوُوذْ، مَاغَارْ نشّْ وَارْ ذ أَشْ تّڭّغْ عَاذْ ڒْغَارْ، مِينْزِي ثُوذَارْثْ إِنُو ثُوغَا أَسّْ-أَ ثْسكّْوَا غَاركْ ذِي ثِيطَّاوِينْ نّشْ. خْزَارْ، نشّْ ڭِّيغْ ثُوبُّوهڒْيَا ؤُ ودَّارغْ س وَاطَّاسْ.“ \f ◼ \fr 26:‏21 \ft \+bd ’ثُوذَارْثْ إِنُو‘\+bd* - س ثْعِيبْرَانِيثْ ’ڒعْمَارْ إِنُو‘.\f*  
\v 22 ذَاوُوذْ يَارَّا-د، إِنَّا: ”خْزَارْ، أَقَا ذَا لَانْسَا ن ؤُجدْجِيذْ. أجّْ إِجّْ زڭْ إِمْسخَّارنْ نّشْ أَذْ إِژْوَا، أَذْ ت-إِ-د يَاوِي.  
\v 23 أَذْ إِخدْجصْ سِيذِي كُوڒْ إِجّْ خْ ثْسڭْذَا نّسْ ذ تِّيقّثْ نّسْ، مِينْزِي سِيذِي ثُوغَا إِسلّمْ إِ شكْ أَسّْ-أَ ذڭْ ؤُفُوسْ إِنُو، مَاشَا وَارْ خْسغْ شَا أَذْ ڭّغْ أَفُوسْ إِنُو ذڭْ ؤُمذْهُونْ ن سِيذِي.  
\v 24 خْزَارْ، أَمْ مَامّشْ ثُوغَا ثُوذَارْثْ نّشْ أَسّْ-أَ ثِيغْڒَا ذِي ثِيطَّاوِينْ إِنُو، أَمُّو إِ غَا ثِيڒِي ثُوذَارْثْ إِنُو ذِي ثِيطَّاوِينْ ن سِيذِي ثِيغْڒَا. نتَّا أَذْ أَيِي إِفكّْ زِي مَارَّا ڒحْصَارثْ.“ \f ◼ \fr 26:‏24 \ft \+bd ’ثُوذَارْثْ‘\+bd* - س ثْعِيبْرَانِيثْ ’ڒعْمَارْ‘.\f*  
\v 25 شَاوُولْ إِنَّا إِ ذَاوُوذْ: ”أَقَا شكْ ثتّْوَابَارْكذْ، مِّي ذَاوُوذْ. مِينْ مَا إِ غَا ثڭّذْ، أَقَا أَذْ ثَاوْضذْ عَاوذْ.“ \add خنِّي\add* يُويُورْ ذَاوُوذْ أَبْرِيذْ نّسْ ؤُ شَاوُولْ إِعْقبْ غَارْ ومْشَانْ نّسْ \add مَانِي ثُوغَا إِزدّغْ\add*.   
\b  
\b  
\m  
\c 27
\s1 ذَاوُوذْ ذِي ثمُّورْثْ ن إِفِيلِيسْطِينِييّنْ  
\m
\v 1 إِنَّا ذَاوُوذْ ذڭْ وُوڒْ نّسْ: ”ڒخُّو عَاذْ إِجّْ ن وَاسّْ ؤُشَا أَذْ تّْوَانْغغْ خْ ؤُفُوسْ ن شَاوُولْ. وَارْ إِقِّيمْ حَاشَا أَذْ أَروْڒغْ ذغْيَا غَارْ ثمُّورْثْ ن إِفِيلِيسْطِينِييّنْ، مَاحنْذْ أَذْ إِقْضعْ إِ شَاوُولْ ڒَايَاسْ زِي جِّيهثْ إِنُو مَاحنْذْ أَذْ خَافِي يَارْزُو عَاذْ \add كْثَارْ\add* ذِي مَارَّا ثَامُّورْثْ ن إِسْرَائِيل. \add أَمُّو\add* إِ غَا نجْمغْ إِ ؤُفُوسْ نّسْ.“  
\v 2 ذَاوُوذْ إِكَّارْ، نتَّا ذ ستَّا-مْيَا ن يرْيَازنْ نِّي ثُوغَا غَارسْ إِدْجَانْ، عْذُونْ غَارْ مِّيسْ ن مَاعُوكْ، أَجدْجِيذْ ن جَاثْ.  
\v 3 إِقِّيمْ ذَاوُوذْ غَارْ أَخِيسْ، نتَّا ذ يرْيَازنْ نّسْ، \add كُوڒْ\add* أَرْيَازْ أَكْ-ذ ثَادَّارْثْ نّسْ. ذَاوُوذْ \add إِزْذغْ ذِينْ\add* أَكْ-ذ ثْنَاينْ ن ثمْغَارِينْ نّسْ، أَخِينُوعَامْ زِي يَازْرَاعِيلْ ؤُ أَبِيجَايِيلْ، ثَامْغَارْثْ ن نَابَالْ، زِي كَارْمِيلْ.  
\v 4 \add ؤُمِي\add* نَّانْ إِ شَاوُولْ، أَقَا ذَاوُوذْ يَارْوڒْ غَارْ جَاثْ، وَارْ يَارْنِي إِقِّيمْ أَذْ خَاسْ يَارْزُو عَاذْ كْثَارْ.   
\m
\v 5 إِنَّا ذَاوُوذْ إِ أَخِيشْ: ”مَاڒَا ؤُفِيغْ نشّْ ڒْخَاضَارْ ذِي ثِيطَّاوِينْ نّشْ، خنِّي أوْشْ أَيِي إِجّْ ن ومْشَانْ ذڭْ إِشْثْ زِي ثْندَّامْ نّشْ ن ثمُّورْثْ، حِيمَا زمَّارغْ أَذْ زذْغغْ ذِينْ. مَايمِّي إِ غَاركْ إِ غَا إِزْذغْ ؤُمْسخَّارْ نّشْ أَكِيذكْ ذِي ثنْذِينْثْ ن ؤُجدْجِيذْ؟“  
\v 6 ذڭْ وَاسّْ نِّي إِوْشَا أَسْ أَخِيشْ \add ثَانْذِينْثْ ن\add* صِيقْلَاغْ. س ؤُيَا ثُوغَا ثدْجَا صِيقْلَاغْ ن إِجدْجِيذنْ ن يَاهُوذَا أَڒْ أَسّْ-أَ.  
\v 7 ؤُسَّانْ إِ إِكَّا ذَاوُوذْ ذِي ثمُّورْثْ ن إِفِيلِيسْطِينِييّنْ، ثُوغَا ذ إِجّْ ن ؤُسڭّْوَاسْ ذ أَربْعَا ن إِيُورنْ.   
\m
\v 8 ذَاوُوذْ إِفّغْ أَكْ-ذ إِرْيَازنْ نّسْ ؤُ نِيثْنِي كشّْضنْ إِجَاشُورِييّنْ ذ إِجَارْزِييّنْ ذ أَيْثْ ن عَامَالِيقْ، مِينْزِي إِنَا ثُوغَا زدّْغنْ زڭْ وشْحَاڒْ ؤُيَا ذِي ثمُّورْثْ، جِّيهثْ ن شُورْ أَڒْ ثَامُّورْثْ ن مِيصْرَا.  
\v 9 ذَاوُوذْ إِوْثَا ثَامُّورْثْ ؤُ وَارْ إِجِّي أَذْ إِدَّارْ ؤُڒَا ذ إِجّْ ن ورْيَازْ نِيغْ ؤُڒَا ذ إِشْثْ ن ثمْغَارْثْ. إِطّفْ عَاوذْ ؤُدْجِي ذ إِفُونَاسنْ ذ ثْفُونَاسِينْ ذ يغْيَاڒْ ذ إِڒغْمَانْ ذ وَارُّوضْ ؤُشَا إِعْقبْ، يُوسَا-د غَارْ أَخِيشْ.  
\v 10 ؤُ أَخِيشْ إِنَّا: ”مَانِي ثْرُوحمْ أَسّْ-أَ مَاحنْذْ أَذْ ثْكشّْضمْ؟“ إِنَّا ذَاوُوذْ: ”غَارْ لْجَانُوبْ ن يَاهُوذَا!“، نِيغْ: ”غَارْ لْجَانُوبْ ن \add ثمُّورْثْ ن\add* إِيَارْحَامِيثِيلِييّنْ!“، نِيغْ: ”غَارْ لْجَانُوبْ ن \add ثمُّورْثْ ن\add* إِقِينِييّنْ!“  
\v 11 وَارْ إِجِّي ذَاوُوذْ أَذْ إِدَّارْ ؤُڒَا ذ إِجّْ ن ورْيَازْ نِيغْ ؤُڒَا ذ إِشْثْ ن ثمْغَارْثْ حِيمَا أَذْ د-يَاسْ غَارْ جَاثْ. إِنَّا: ”حِيمَا نِيثْنِي وَارْ خَانغْ تّْعِيوِيذنْ وَالُو، أَذْ إِنِينْ: ’ثَا إِ إِڭَّا ذَاوُوذْ!‘ “ أَمُّو إِ إِقِّيمْ إِتّڭّْ ذِي مَارَّا ؤُسَّانْ إِ إِكَّا ذِي جّْوَايهْ ن إِفِيلِيسْطِينِييّنْ.  
\v 12 أَخِيشْ إِتِّيقّْ ذِي ذَاوُوذْ، إِنَّا: ”س ثِيذتّْ نتَّا إِسَّارْزڭْ إِخفْ نّسْ غَارْ ڒْڭنْسْ نّسْ، غَارْ إِسْرَائِيل، ؤُشَا خْ ؤُينِّي أَقَا نتَّا أَذْ يِيڒِي ذ أَمْسخَّارْ إِنُو إِ ڒبْذَا.“   
\b  
\b  
\m  
\c 28
\s1 شَاوُولْ إِرُوحْ غَارْ إِشْثْ ن ثمْغَارْثْ ذِي عَايْنْ-ذُورْ  
\m
\v 1 ذڭْ وُوسَّانْ نِّي، ڒَامِي سّْمُوننْ إِفِيلِيسْطِينِييّنْ ڒْعسْكَارْ نْسنْ إِ ؤُمنْغِي، حِيمَا أَذْ مّنْغنْ أَكْ-ذ إِسْرَائِيل، إِمْسَارْ، أَقَا أَخِيشْ إِنَّا إِ ذَاوُوذْ: ”إِتّْخصَّا أَذْ ثسّْنذْ مْلِيحْ، أَقَا شكْ أَذْ كِيذِي ثفّْغذْ س ؤُغِيڒْ ذِي ڒْعسْكَارْ، شكْ ذ يرْيَازنْ نّشْ.“  
\v 2 \add خنِّي\add* إِنَّا ذَاوُوذْ إِ أَخِيشْ: ”ذِي مَانْ أَيَا أَذْ ثْژَارذْ مِينْ إِزمَّارْ أَذْ يڭّْ ؤُمْسخَّارْ نّشْ!“ أَخِيشْ إِنَّا إِ ذَاوُوذْ: ”س ؤُيَا أَذْ شكْ ڭّغْ ذ أَعسَّاسْ خَافِي ذِي مَارَّا ؤُسَّانْ.“ \f ◼ \fr 28:‏2 \ft \+bd ’أَعسَّاسْ خَافِي‘\+bd* - س ثْعِيبْرَانِيثْ ’أَعسَّاسْ إِ ؤُزدْجِيفْ إِنُو‘.\f*   
\m
\v 3 شَامْوِيلْ ثُوغَا إِمُّوثْ ذ مَارَّا إِسْرَائِيل ثُوغَا إِشْضنْ خَاسْ. نِيثْنِي نضْڒنْ ث ذِي رَامَا، ذِي ثنْذِينْثْ نّسْ. شَاوُولْ ثُوغَا إِسُّوفُّوغْ إِنِّي إِسَّاوَاڒنْ أَكْ-ذ إِمتَّانْ ؤُڒَا ذ إِڭزَّاننْ زِي ثمُّورْثْ. \x ◘ \xo 28:‏3 \xt 1 صم. 25‏:‏1\x*   
\m
\v 4 إِفِيلِيسْطِينِييّنْ مُوننْ مَارَّا. نِيثْنِي ؤُسِينْ-د ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ غَارْ شُونَامْ ؤُ شَاوُولْ إِسّْمُونْ مَارَّا إِسْرَائِيل ؤُ نِيثْنِي وْثِينْ إِقِيضَانْ نْسنْ غَارْ جِيلْبُوعَا.  
\v 5 ؤُمِي إِژْرَا شَاوُولْ ڒْمَارْڭحْ ن ڒْعسْكَارْ ن إِفِيلِيسْطِينِييّنْ، ثُوسَا أَسْ-د ثِيڭّْوُوذِي ؤُ وُوڒْ نّسْ إِذْوڒْ إِتّقْذِيذِّيسْ س وَاطَّاسْ.  
\v 6 شَاوُولْ إِسّقْسَا سِيذِي، مَاشَا سِيذِي وَارْ خَاسْ د-يَارِّي شَا، وَارْ إِدْجِي س ثِيرْجَا، ؤُڒَا س ؤُرِيمْ، ؤُڒَا س إِنَابِييّنْ.  
\v 7 \add خنِّي\add* إِنَّا شَاوُولْ إِ إِمْسخَّارنْ نّسْ: ”أَرْزُومْ أَيِي-د إِشْثْ ن ثمْغَارْثْ إِدّبَّارَانْ خْ بُوحْبڒَاثْ ن إِمتَّانْ، حِيمَا نشّْ أَذْ غَارسْ رَاحغْ ؤُ أَذْ ت سّقْسِيغْ.“ إِمْسخَّارنْ نّسْ نَّانْ أَسْ: ”خْزَارْ، ذِي عَايْنْ-ذُورْ أَقَا ذِينْ إِشْثْ ن ثمْغَارْثْ ثنِّي إِدّبَّارَانْ خْ بُوحْبڒَاثْ ن إِمتَّانْ.“  
\v 8 شَاوُولْ إِسّْنقْڒبْ إِخفْ نّسْ، يَارْضْ أَرُّوضْ نّغْنِي ؤُشَا يُويُورْ. ثْنَاينْ ن يرْيَازنْ رُوحنْ أَكِيذسْ ؤُ نِيثْنِي إِوْضنْ ذِي دْجِيڒثْ غَارْ ثمْغَارْثْ، ؤُشَا إِنَّا نتَّا: ”ڭزّنْ أَيِي زِي بُوحْبڒْ ن إِجّْ ن ؤُمتِّينْ ؤُشَا ڒَاغَا أَيِي-د خْ ونِّي ذ أَمْ إِ غَا إِنِيغْ.“  
\v 9 \add خنِّي\add* ثنَّا خَاسْ ثمْغَارْثْ: ”أَقَا ذَا شكْ ثسّْنذْ \add مْلِيحْ\add* مِينْ إِڭَّا شَاوُولْ، مَامّشْ ثُوغَا إِتّحَّا إِنِّي إِسَّاوَاڒنْ أَكْ-ذ إِمتَّانْ ذ إِڭزَّاننْ زِي ثمُّورْثْ. مَايمِّي ذ أَيِي ثتّڭّذْ ڒْفخْ، حِيمَا أَذْ أَيِي ثنْغذْ؟“  
\v 10 شَاوُولْ \add مَاشَا\add* إِجُّودْجْ أَسْ غَارْ سِيذِي، إِنَّا: ”\add س ثِيذتّْ أَمْ\add* إِدَّارْ سِيذِي، وَارْ شمْ إِڒقّفْ ذِي ثْمسْڒَاشْثْ-أَ شَا ڒْعِيبْ!“  
\v 11 \add خنِّي\add* ثنَّا ثمْغَارْثْ: ”مَانْ ونْ إِ خفْ-د إِ غَا ڒَاغِيغْ إِ شكْ؟“ نتَّا إِنَّا ”ڒَاغَا أَيِي-د خْ شَامْوِيلْ!“  
\v 12 \add ؤُمِي\add* ثژْرَا ثمْغَارْثْ شَامْوِيلْ، ثسْغُويْ ذڭْ ؤُجنَّا ؤُ ثسِّيوڒْ ثمْغَارْثْ أَكْ-ذ شَاوُولْ، ثنَّا أَسْ: ”مَايمِّي ذ أَيِي ثْشمْثذْ؟ شكْ أَقَا ذ شَاوُولْ!“  
\v 13 إِنَّا أَسْ ؤُجدْجِيذْ: ”وَارْ تّڭّْوذْ شَا، مَاشَا مِينْ ثتّْوَاڒِيذْ شمْ؟“ \add خنِّي\add* ثنَّا ثمْغَارْثْ إِ شَاوُولْ: ”نشّْ تّْوَاڒِيغْ إِنِّي يَاروْسنْ ذڭْ إِربِّيثنْ إِ د-إِتّْڭعَّاذنْ زِي ثمُّورْثْ.“  
\v 14 نتَّا إِنَّا أَسْ: ”مَامّشْ ثڭَّا ثِيذِّي نّسْ؟“ نتَّاثْ ثنَّا: ”إِجّْ ن ؤُوسَّارْ إِتّْڭعّذْ ؤُ يَارْضْ س يِيجّْ ن ؤُسڒْهَامْ.“ \add خنِّي\add* إِسّنْ شَاوُولْ، أَقَا-ث ذ شَامْوِيلْ، يُوضَارْ نتَّا س ؤُغمْبُوبْ نّسْ غَارْ ثمُّورْثْ ؤُشَا إِبنْذقْ.   
\m
\v 15 ؤُشَا شَامْوِيلْ إِنَّا: ”مَايمِّي ذ أَيِي ثْهوْڒذْ، ثجِّيذْ أَذْ خَافِي د-ڒَاغَانْ؟“ شَاوُولْ إِنَّا: ”نشّْ تّْوَاحْصَارغْ أَطَّاسْ، مَاغَارْ إِفِيلِيسْطِينِييّنْ تّْمنْغَانْ أَكِيذِي ؤُ أَربِّي إِحيّذْ خَافِي ؤُ وَارْ إِقِّيمْ إِتَّارَّا-د خَافِي عَاذْ، وَارْ إِدْجِي خْ ثبْرِيذِينْ ن إِنَابِييّنْ ؤُڒَا س ثِيرْجَا. س ؤُينِّي ڒَاغِيغْ-د خَاكْ، مَاحنْذْ أَذْ أَيِي ثسّشْنذْ مِينْ غَا ڭّغْ.“  
\v 16 \add خنِّي\add* إِنَّا شَامْوِيلْ: ”مَايمِّي ذ أَيِي ثتّْسقْسِيذْ، \add مَاڒَا\add* سِيذِي إِحيّذْ خَاكْ ؤُ نتَّا إِذْوڒْ ضِيدّْ نّشْ؟  
\v 17 سِيذِي سِيمَانْثْ نّسْ إِڭَّا أَمْ مَامّشْ ثُوغَا زَّايِي إِنَّا ؤُ نتَّا إِقْڒعْ إِ شكْ ثَاڭلْذِيثْ زڭْ ؤُفُوسْ نّشْ، إِوْشَا إِ-ت إِ جَّارْ نّشْ، إِ ذَاوُوذْ.  
\v 18 مِينْزِي شكْ وَارْ ثسْڒِيذْ شَا غَارْ ثْمِيجَّا ن سِيذِي ؤُ شكْ وَارْ ثسِّيوْضذْ شَا ڒْحَاذُوقْ ن وغْضَابْ نّسْ غَارْ عَامَالِيقْ، خْ ؤُيَا إِ ذ أَشْ إِڭَّا سِيذِي أَسّْ-أَ أَيَا.  
\v 19 سِيذِي أَذْ كِيذكْ إِڭّْ ؤُڒَا ذ إِسْرَائِيل ذڭْ ؤُفُوسْ ن إِفِيلِيسْطِينِييّنْ، ؤُ ثِيوشَّا أَذْ ثِيڒِيذْ شكْ ذ إِحنْجِيرنْ نّشْ غَارِي. ؤُڒَا ذ ڒْعسْكَارْ ن إِسْرَائِيل أَذْ ث إِڭّْ سِيذِي ذڭْ ؤُفُوسْ ن إِفِيلِيسْطِينِييّنْ.“  
\v 20 \add خنِّي\add* إِوْضَا شَاوُولْ ذغْيَا، إِبقّضْ ذِي ثمُّورْثْ، ثُوغَا إِتّڭّْوذْ أَطَّاسْ زڭْ وَاوَاڒنْ ن شَامْوِيلْ، ؤُشَا جّهْذْ وَارْ ذَايسْ إِقِّيمْ، مِينْزِي وَارْ إِشِّي أَغْرُومْ، أَسّْ ذ دْجِيڒثْ كمّْڒنْ.   
\m
\v 21 ثَامْغَارْثْ ثُويُورْ غَارْ شَاوُولْ، ؤُشَا ثژْرَا إِ-ث يَارْجفْ أَطَّاسْ. ثنَّا أَسْ: ”خْزَارْ، ثَايَّا نّشْ ثسْڒَا غَارْ ثْمِيجَّا نّشْ ؤُ نشّْ سبّْڒغْ ثُوذَارْثْ إِنُو، سْڒِيغْ غَارْ وَاوَاڒنْ إِ ذ أَيِي ثنِّيذْ.  
\v 22 خنِّي ڒخُّو مَاشَا سڒْ غَارْ ثْمِيجَّا ن ثَايَّا نّشْ! نشّْ أَذْ أَشْ قدّْمغْ إِجّْ ن ؤُڒقِّيمْ ن وغْرُومْ. أشّْ حِيمَا أَذْ ثتّْوَاسّْجْهذذْ خْمِي غَا ثطّْفذْ أَبْرِيذْ.“  
\v 23 \add مَاشَا\add* نتَّا يُوڭِي، إِنَّا: ”نشّْ وَارْ تّتّغْ!“ \add مَاشَا\add* إِمْسخَّارنْ نّسْ ؤُڒَا ذ ثَامْغَارْثْ حْصَارنْ ث أَڒَامِي إِسْڒَا نتَّا غَارْسنْ، ؤُشَا نتَّا إِكَّارْ زِي ثمُّورْثْ، إِقِّيمْ خْ قَامَا. \f ◼ \fr 28:‏23 \ft \+bd ’غَارْسنْ‘\+bd* - س ثْعِيبْرَانِيثْ ’غَارْ ثْمِيجَّا نْسنْ‘.\f*  
\v 24 ثَامْغَارْثْ ثُوغَا غَارسْ إِجّْ ن ؤُعجْمِي إِمْسڒْ ذِي ثَادَّارْثْ ؤُشَا ثْغَارْصْ أَسْ ذغْيَا. نتَّاثْ ثكْسِي أَوْرنْ، ثڭّْوَا أَرشْثِي ؤُ ثڭَّا زَّايسْ أَغْرُومْ بْڒَا أَنْثُونْ.\f ◼ \fr 28:‏24 \ft \+bd ’أَمْوَا‘\+bd* - نِيغْ ’أَينْذُوزْ‘ نِيغْ ’يُوڭُّو‘.\f*  
\v 25 نتَّاثْ ثْقدّمْ \add أَيَا\add* إِ شَاوُولْ ذ إِمْسخَّارنْ نّسْ ؤُشَا شِّينْ نِيثْنِي. أَوَارْنِي أَيَا كَّارنْ ؤُ أَرڭّْوْحنْ ذِي دْجِيڒثْ نِّي.   
\b  
\b  
\m  
\c 29
\s1 ذَاوُوذْ ذ ڒْبَاشَاثْ ن إِفِيلِيسْطِينِييّنْ  
\m
\v 1 إِفِيلِيسْطِينِييّنْ سّْمُوننْ مَارَّا ڒْعسْكَارْ نْسنْ غَارْ أَفِيقْ ؤُشَا إِسْرَائِيل ثُوغَا إِوْثَا إِقِيضَانْ نّسْ غَارْ ثَاڒَا نِّي \add إِدْجَانْ\add* غَارْ يَازْرَاعِيلْ.  
\v 2 ؤُشَا ڒْبَاشَاثْ \add ن ثْندَّامْ\add* ن إِفِيلِيسْطِينِييّنْ ژْوَانْ غَارْ ذِينْ س ڒْمْيَاوَاثْ ذ ڒُوڒُوفْ نْسنْ ؤُشَا إِژْوَا ذَاوُوذْ ذ يرْيَازنْ نّسْ أَكْ-ذ أَخِيشْ غَارْ ؤُغزْذِيسْ أَنڭَّارُو.  
\v 3 \add خنِّي\add* نَّانْ ڒْحُوكَّامْ ن إِفِيلِيسْطِينِييّنْ: ”مِينْ ذَا تّڭّنْ إِعِيبْرَانِييّنْ-أَ؟“ يَارَّا-د أَخِيشْ خْ ڒْحُوكَّامْ ن إِفِيلِيسْطِينِييّنْ: ”مَا وَا وَارْ إِدْجِي ذ ذَاوُوذْ، أَمْسخَّارْ ن شَاوُولْ، أَجدْجِيذْ ن إِسْرَائِيل، ونِّي ثُوغَا غَارِي إِدْجَانْ أَسڭّْوَاسْ ذ وَاسّْ؟ زڭْ وَاسّْ إِ غَارِي د-يعْذُو أَڒْ أَسّْ-أَ نشّْ وَارْ ذَايسْ ؤُفِيغْ ؤُڒَا ذ إِجّْ ن ڒْعِيبْ.“   
\m
\v 4 فُّوڭّْمنْ خَاسْ أَطَّاسْ ڒْحُوكَّامْ ن إِفِيلِيسْطِينِييّنْ. نَّانْ أَسْ ڒْحُوكَّامْ ن إِفِيلِيسْطِينِييّنْ: ”سكّْ أَرْيَازْ أَذْ إِعْقبْ، حِيمَا أَذْ إِذْوڒْ غَارْ ومْشَانْ نّسْ نِّي إِ ذ أَسْ ثسّشْنذْ. وَارْ إِزمَّارْ أَكِيذْنغْ إِهْوَا غَارْ ؤُمنْغِي، حِيمَا خنِّي وَارْ إِذِّيكّْوِيڒْ ذ ڒعْذُو نّغْ ذڭْ ؤُمنْغِي. مَاغَارْ س مِينْزِي إِزمَّارْ وَانِيثَا أَذْ إِصْڒحْ أَكْ-ذ سِيذِيسْ نّسْ؟ مَا وَارْ إِدْجِي أَكْ-ذ إِزدْجِيفنْ ن يرْيَازنْ-أَ؟ \x ◘ \xo 29:‏4 \xt 1 إِم. 12‏:‏20\x*  
\v 5 مَا وَانِيثَا وَارْ إِدْجِي ذ ذَاوُوذْ ونِّي خْغنّْجنْثْ ذ شضْحنْثْ س نُّوبْثَاثْ، نَّانْثْ: ’شَاوُولْ نتَّا إِغْڒبْ خْ ڒُوڒُوفْ نّسْ، \add مَاشَا\add* ذَاوُوذْ نتَّا خْعشْرَا ن ڒُوڒُوفْ نّسْ؟‘ “ \x ◘ \xo 29:‏5 \xt 1 صم. 18‏:‏7\x*   
\m
\v 6 ؤُشَا إِڒَاغَا-د أَخِيشْ إِ ذَاوُوذْ إِنَّا أَسْ: ”\add س ثِيذتّْ أَمْ\add* إِدَّارْ سِيذِي، شكْ ذ أَصْذِيقْ. ؤُفُوغْ نّشْ ذ وعْقَابْ نّشْ أَكِيذِي ذِي ڒْعسْكَارْ أَقَا أَثنْ مْلِيحْ ذِي ثِيطَّاوِينْ إِنُو، مَاغَارْ نشّْ وَارْ ذَايكْ ؤُفِيغْ ؤُڒَا ذ شَا ن ڒْغشّْ زڭْ وَاسّْ إِ غَارِي د-ثُوسِيذْ أَڒْ أَسّْ-أَ. \add مَاشَا\add* شكْ وَارْ ثدْجِيذْ مْلِيحْ ذِي ثِيطَّاوِينْ ن ڒْبَاشَاثْ \add ن ثْندَّامْ\add*.  
\v 7 خنِّي ڒخُّو، عْقبْ، ؤُيُورْ ذِي ڒهْنَا، \add حِيمَا\add* وَارْ ثتّڭّذْ قَاعْ شَا ن ڒْغشّْ ذِي ثِيطَّاوِينْ ن ڒْبَاشَاثْ \add ن ثْندَّامْ\add* ن إِفِيلِيسْطِينِييّنْ.“  
\v 8 \add خنِّي\add* إِنَّا ذَاوُوذْ إِ أَخِيشْ: ”مَاغَارْ مِينْ ڭِّيغْ؟ مِينْ ثُوفِيذْ ذڭْ ؤُمْسخَّارْ نّشْ زڭْ وَاسّْ \add أَمزْوَارُو\add* إِ ذ أَيِي ثُوغَا زَّاثْ إِ وُوذمْ نّشْ أَڒْ أَسّْ-أَ، أَڒَامِي وَارْ رُوحغْ أَكِيذْومْ أَذْ منْغغْ أَكْ-ذ ڒْعذْيَانْ ن سِيذِي إِنُو، أَجدْجِيذْ؟“  
\v 9 أَخِيشْ يَارَّا-د، إِنَّا إِ ذَاوُوذْ: ”نشّْ سّْنغْ ت، مِينْزِي شكْ ذ لمْلِيحْ ذِي ثِيطَّاوِينْ إِنُو أَمْ يِيجّْ ن لْمَالَاكْ ن أَربِّي، مَاشَا ڒْحُوكَّامْ ن إِفِيلِيسْطِينِييّنْ نَّانْ: ’نتَّا وَارْ أَكِيذْنغْ إِتّفّغْ غَارْ ؤُمنْغِي.‘  
\v 10 س ؤُينِّي كَّارْ ثِيوشَّا زِيشْ س إِمْسخَّارنْ ن سِيذِي نّشْ، إِنِّي أَكِيذكْ د-يُوسِينْ. مَاڒَا ثكَّارمْ س وَاسّْ زِيشْ ؤُشَا إِصْبحْ ڒْحَاڒْ، فّْغمْ \add خنِّي\add*.“  
\v 11 ذَاوُوذْ إِكَّارْ زِيشْ، نتَّا ذ يرْيَازنْ نّسْ، حِيمَا أَذْ ؤُيُورنْ ذِي صّْبحْ، أَذْ د -عقْبنْ غَارْ ثمُّورْثْ ن إِفِيلِيسْطِينِييّنْ. إِفِيلِيسْطِينِييّنْ \add مَاشَا\add* فّْغنْ، ڭعّْذنْ غَارْ يَازْرَاعِيلْ.   
\b  
\b  
\m  
\c 30
\s1 ذَاوُوذْ إِنْثَاقمْ زڭْ إِعَامَالِيقِييّنْ  
\m
\v 1 \add ؤُمِي\add* د-يُوسَا ذَاوُوذْ ذ يرْيَازنْ نّسْ غَارْ صِيقْلَاغْ ذڭْ وَاسّْ وِيسّْ ثْڒَاثَا، ثُوغَا إِمْسَارْ، أَقَا أَيْثْ ن عَامَالِيقْ كشّْضنْ لْجَانُوبْ ؤُڒَا ذ صِيقْلَاغْ. نِيثْنِي وْثِينْ صِيقْلَاغْ، قّْذنْ أَسْ ثِيمسِّي  
\v 2 ؤُشَا حبّْسنْ ثِيمْغَارِينْ نِّي ذِينْ \add إِدْجَانْ\add*. وَارْ نْغِينْ ؤُڒَا ذ إِجّْ، أَمژْيَانْ نِيغْ ذ أَمقّْرَانْ، مَاشَا إِوْينْ ثنْ ؤُشَا ؤُيُورنْ أَبْرِيذْ نْسنْ.  
\v 3 يُوسَا-د ذَاوُوذْ أَكْ-ذ يرْيَازنْ نّسْ غَارْ ثنْذِينْثْ، ؤُشَا خْزَارْ، أَقَا ثتّْوَاسّشْمضْ \add ثنْذِينْثْ\add* س ثْمسِّي ؤُ ثِيمْغَارِينْ ذ إِحنْجِيرنْ ذ ثْحنْجِيرِينْ ثُوغَا تّْوَاحوّْسنْ.  
\v 4 ذَاوُوذْ ذ ڒْڭنْسْ إِ غَارسْ \add إِدْجَانْ\add* سّْڭعّْذنْ ثْمِيجَّا نْسنْ، سْغُوينْ أَڒَامِي وَارْ ذَايْسنْ إِقِّيمْ جّهْذْ حِيمَا أَذْ سْغُوينْ.  
\v 5 ؤُڒَا ذ ثْنَاينْ ن ثمْغَارِينْ ن ذَاوُوذْ تّْوَاحوّْسنْثْ، أَخِينُوعَامْ زِي يَازْرَاعِيلْ ؤُ أَبِيجَايِيلْ زِي كَارْمِيلْ.  
\v 6 ثُوغَا ذَاوُوذْ ثتّْوَاحْصَارذْ أَطَّاسْ، مِينْزِي ڒْڭنْسْ ثُوغَا إِسَّاوَاڒْ مَاحنْذْ أَذْ ث أَرجْمنْ، مَاغَارْ ڒعْمُورْ ن مَارَّا ڒْڭنْسْ ثُوغَا أَرزْڭنْ، \add كُوڒْ\add* أَرْيَازْ خْ \add ثْخسَّارْثْ\add* ن إِحنْجِيرنْ نّسْ ذ ثْحنْجِيرِينْ نّسْ. \add مَاشَا\add* ذَاوُوذْ إِسّجْهذْ إِخفْ نّسْ ذِي سِيذِي، أَربِّي نّسْ.   
\m
\v 7 إِنَّا ذَاوُوذْ إِ ؤُكهَّانْ أَبْيَاثَارْ، مِّيسْ ن أَخِيمَالِيكْ: ”أَوِي-د \add ذَا\add* غَارِي أَپَالْطُو \add ن ؤُكهَّانْ\add*!“ ؤُ أَبْيَاثَارْ يِيوِي-د أَپَالْطُو \add ن ؤُكهَّانْ\add* غَارْ ذَاوُوذْ.  
\v 8 \add خنِّي\add* إِسّقْسَا ذَاوُوذْ إِ سِيذِي: ”مَا أَذْ ضْفَارغْ بَانْذِييَّا-يَا؟ مَا أَذْ خَاسنْ حَارْثغْ؟“ سِيذِي يَارَّا-د خَاسْ: ”ضْفَارْ إِ-ثنْ، مَاغَارْ شكْ أَذْ خَاسنْ ثْحَارْثذْ ؤُ أَذْ ثْفكّذْ \add إِمحْبَاسْ\add* نِيشَانْ.“  
\v 9 إِفّغْ-د ذَاوُوذْ، نتَّا ذ ستَّا-مْيَا ن يرْيَازنْ نِّي ثُوغَا غَارسْ. \add ؤُمِي\add* د-إِوْضنْ نِيثْنِي أَڒْ ثِيغْزَارْثْ ن بَاسُورْ، بدّنْ \add ذِينْ\add* إِنِّي إِقِّيمنْ غَارْ ضفَّارْ،  
\v 10 \add مَاشَا\add* ذَاوُوذْ إِقِّيمْ إِضفَّارْ \add بَانْذِييَّا نِّي\add*، نتَّا ذ أَربْعَا-مْيَا ن يرْيَازنْ أَكِيذسْ. مِيثَايْنْ ن يرْيَازنْ، إِنِّي ثُوغَا يُوحْڒنْ أَطَّاسْ مَاحنْذْ أَذْ ژْوَانْ ثِيغْزَارْثْ ن بَاشُورْ، قِّيمنْ بدّنْ \add ذِينْ\add*.   
\m
\v 11 نِيثْنِي ؤُفِينْ إِجّْ ن ورْيَازْ ذ أَمِيصْرِي ذڭْ إِيَّارْ ؤُشَا إِوْينْ ث غَارْ ذَاوُوذْ. نِيثْنِي وْشِينْ أَسْ أَغْرُومْ ؤُ نتَّا إِشَّا ؤُ نِيثْنِي وْشِينْ أَسْ \add عَاوذْ\add* أَمَانْ مَاحنْذْ أَذْ إِسُو.  
\v 12 أَرْنِينْ أَسْ إِشْثْ ن ثسْغَارْثْ ن إِجّْ ن وغْرُومْ ن ثَازَارْثْ يُوژْغنْ ذ ثْنَاينْ ن إِغْرُومنْ ن زّْبِيبْ ؤُ نتَّا إِشَّا، إِذْوڒْ أَسْ-د بُوحْبڒْ نّسْ، مَاغَارْ نتَّا ثُوغَا وَارْ إِشِّي وَارْ إِسْوِي ثْڒَاثَا ن وُوسَّانْ ذ ثْڒَاثَا ن دْجِييَاڒِي.  
\v 13 \add خنِّي\add* إِنَّا أَسْ ذَاوُوذْ: ”وِي شكْ يِيڒَانْ ؤُ مَانِيسْ شكْ؟“ \add خنِّي\add* إِنَّا ؤُحُوذْرِي أَمِيصْرِي: ”نشّْ ذ إِجّْ ن ؤُمْسخَّارْ ن إِجّْ ن ورْيَازْ ن عَامَالِيقْ ؤُ سِيذِي إِنُو إِجَّا أَيِي، ڒَامِي هڒْشغْ ثْڒَاثَا ن وُوسَّانْ زڭْ وَامِي.  
\v 14 نشِّينْ ثُوغَا نْكشّضْ \add ثَامُّورْثْ ن\add* لْجَانُوبْ ن إِكَارِيثِييِّينْ، ثنِّي غَارْ يَاهُوذَا، ؤُڒَا ذ \add ثَامُّورْثْ ن\add* لْجَانُوبْ ن كَالِيبْ، ؤُ نشِّينْ نسّشْمضْ صِيقْلَاغْ س ثْمسِّي.“  
\v 15 ذَاوُوذْ إِنَّا أَسْ: ”مَا ثْزمَّارذْ أَذْ أَيِي ثْنذْهذْ غَارْ بَانْذِييَّا-يَا ن إِخوَّاننْ؟“ نتَّا إِنَّا: ”جَادْجْ أَيِي غَارْ أَربِّي، أَقَا شكْ وَارْ ذ أَيِي ثْنقّذْ ؤُ وَارْ ذ أَيِي ثسّْعدُّوذْ إِ سِيذِي إِنُو! خنِّي نشّْ أَذْ شكْ نذْهغْ غَارْ بَانْذِييَّا-يَا.“  
\v 16 ؤُشَا إِنْذهْ إِ-ث ذِينْ، ؤُ خْزَارْ، نِيثْنِي ثُوغَا قِّيمنْ تّْوَابزّْعنْ خْ مَارَّا ثَامُّورْثْ، شِّينْ، سْوِينْ ؤُ شضْحنْ زِي سِّيبّثْ ن ثْكشَّاضْثْ ثَامقّْرَانْثْ إِ ثُوغَا د-إِوْينْ زِي ثمُّورْثْ ن إِفِيلِيسْطِينِييّنْ ؤُ زِي ثمُّورْثْ ن يَاهُوذَا.   
\m
\v 17 ذَاوُوذْ إِوْثَا خَاسنْ زِي ثْبَامْبَاسْثْ أَڒْ ثَامذِّيثْ ن وَاسّْ إِ-ت-إِ-د-إِضْفَارنْ ؤُشَا ؤُڒَا ذ إِجّنْ زَّايْسنْ وَارْ إِنْجِيمْ، مْغِيرْ أَربْعَا-مْيَا ن إِحُوذْرِييّنْ نِّي إِنْيِينْ خْ إِڒغْمَانْ، أَروْڒنْ.  
\v 18 \add أَمُّو\add* د-إِفكّْ ذَاوُوذْ مَارَّا مِينْ كّْسنْ أَيْثْ ن عَامَالِيقْ. ذَاوُوذْ إِفكّْ-د ؤُڒَا ذ ثْنَاينْ ن ثمْغَارِينْ نّسْ.  
\v 19 زڭْ ؤُمژْيَانْ أَڒْ أَمقّْرَانْ، زڭْ إِحنْجِيرنْ ذ ثْحنْجِيرِينْ، زِي ثْكشَّاضْثْ ؤُ زِي مَارَّا مِينْ زَّايْسنْ كّْسنْ، وَارْ إِودَّارْ وَالُو. مَارَّا يَارَّا إِ-ث-إِ-د ذَاوُوذْ.  
\v 20 إِكْسِي ذَاوُوذْ عَاوذْ مَارَّا ؤُدْجِي ذ إِفُونَاسنْ ذ ثْفُونَاسِينْ. نذْهنْ \add ثنْ\add* غَارْ زَّاثْ إِ ڒكْسِيبثْ \add ن يِيخفْ\add* نْسنْ، نَّانْ: ”ثَا ذ ثَاكشَّاضْثْ ن ذَاوُوذْ.“   
\m
\v 21 \add ؤُمِي\add* د-يِيوضْ ذَاوُوذْ غَارْ مِيثَاينْ ن يرْيَازنْ، إِنِّي ثُوغَا يُوحْڒنْ أَطَّاسْ حِيمَا أَذْ ضْفَارنْ ذَاوُوذْ \add عَاذْ\add*، إِنِّي إِجَّا ذَاوُوذْ غَارْ ثغْزَارْثْ ن بَاشُورْ، أَقَا فّْغنْ-د نِيثْنِي غَارْ ؤُمْسَاڭَارْ أَكْ-ذ ذَاوُوذْ ؤُ أَكْ-ذ ڒْڭنْسْ نِّي ثُوغَا غَارسْ. ذَاوُوذْ إِقَارّبْ-د غَارْسنْ ؤُشَا إِسّقْسَا خْ ؤُمدُّورْ نْسنْ.  
\v 22 \add خنِّي\add* يَارَّا-د كُوڒْ أَرْيَازْ وَارْ إِحْڒِينْ ذ ونِّي وَارْ إِسكّْوِينْ جَارْ يرْيَازنْ نِّي ثُوغَا د-إِفّْغنْ أَكْ-ذ ذَاوُوذْ، نَّانْ: ”مَاغَارْ نِيثْنِي وَارْ كِيذْنغْ فِّيغنْ، خْ ؤُينِّي وَارْ ذ أَسنْ نتِّيشْ وَالُو زِي ثْكشَّاضْثْ إِ د-نْفكّْ، مْغِيرْ إِ \add كُوڒْ\add* أَرْيَازْ ثَامْغَارْثْ نّسْ ذ إِحنْجِيرنْ نّسْ. ذ إِنَا زمَّارنْ نِيثْنِي أَذْ أَوْينْ ؤُشَا أَذْ \add كِيذْسنْ\add* أَرڭّْوْحنْ.“  
\v 23 \add مَاشَا\add* ذَاوُوذْ إِنَّا: ”وَارْ إِعدّڒْ أَذْ ثڭّمْ أَمنِّي، أَيْثْمَا، أَقَا سِيذِي ذ ونِّي ذ أَنغْ إِوْشِينْ \add أَيَا\add* ؤُ نتَّا إِحْضَا أَنغْ ؤُ إِوْشَا بَانْذِييَّا إِ ذ أَنغْ د-إِوْضَانْ ذڭْ ؤُفُوسْ نّغْ.  
\v 24 وِي غَارْومْ إِ غَا إِسْڒنْ غَارْ وَاوَاڒْ نْومْ؟ مَاغَارْ ثَاسْغَارْثْ ن ونِّي إِفّْغنْ غَارْ ؤُمنْغِي \add أَذْ ثِيڒِي\add* أَمْ ثسْغَارْثْ ن ونِّي إِقِّيمنْ غَارْ ڒخْزِينْ. نِيثْنِي أَذْ \add ت\add* بْضَانْ \add جْمِيعْ\add*.“  
\v 25 أَمُّو إِ ت ثقِّيمْ زڭْ وَاسّْ نِّي، مِينْزِي نتَّا إِڭَّا إِ-ت ذ إِشْثْ ن ثوْصيّثْ ذ إِشْثْ ن لْفَارِيضَا ذِي إِسْرَائِيل أَڒْ أَسّْ-أَ.   
\b  
\m  
\s1 ذَاوُوذْ إِسّكّْ ثِيرْزفِينْ إِ إِمْغَارنْ ن يَاهُوذَا  
\m
\v 26 \add ؤُمِي\add* يَارڭّْوحْ ذَاوُوذْ غَارْ صِيقْلَاغْ، إِسّكّْ نتَّا \add ثِيرْزفِينْ\add* زِي ثْكشَّاضْثْ غَارْ إِمْغَارنْ ن يَاهُوذَا، إِمدُّوكَّاڒْ نّسْ، \add أَمْ إِ ذ أَسنْ\add* إِنَّا: ”ثَا ذ إِشْثْ ن لْبَارَاكَا إِ كنِّيوْ زِي ثْكشَّاضْثْ ن ڒْعذْيَانْ ن سِيذِي“.  
\v 27 إِسّكّْ \add إِ إِمْغَارنْ\add* ذِي بَايْثْ-إِلْ، إِ يِينِّي ذِي رَامَاثْ ذِي لْجَانُوبْ، إِ يِينِّي ذِي يَاتِّيرْ،  
\v 28 إِ يِينِّي ذِي عَارُوعِيرْ، إِ يِينِّي ذِي سِيفْمُوثْ، إِ يِينِّي ذِي إِشِيثِيمُوعَا،  
\v 29 إِ يِينِّي ذِي رَاخِيلْ، إِ يِينِّي \add ثُوغَا إِزدّْغنْ\add* ذِي ثْندَّامْ ن إِيَارْحَامْثِيلِييّنْ، إِ يِينِّي \add إِزدّْغنْ\add* ذِي ثْندَّامْ ن إِقِينِييّنْ،  
\v 30 إِ يِينِّي ذِي حُورْمَا، إِ يِينِّي ذِي كُورْ-عَاشَانْ، إِ يِينِّي ذِي عَاثَاكْ،  
\v 31 إِ يِينِّي ذِي حَابْرُونْ ؤُ غَارْ مَارَّا إِمُوشَانْ مَانِي ثُوغَا إِكَّا ذَاوُوذْ، نتَّا أَكْ-ذ إِرْيَازنْ نّسْ.   
\b  
\b  
\m  
\c 31
\s1 ڒْموْثْ ن شَاوُولْ  
\m
\v 1 مّنْغنْ إِفِيلِيسْطِينِييّنْ أَكْ-ذ إِسْرَائِيل. إِرْيَازنْ ن إِسْرَائِيل أَروْڒنْ زَّاثْ إِ وُوذمْ ن إِفِيلِيسْطِينِييّنْ ؤُشَا وْضَانْ ذ إِمتَّانْ خْ ثمُّورْثْ ن إِذُورَارْ ن جِيلْبُوعَا. \x ◘ \xo 31:‏1 \xt [1 إِم. 10‏:‏1‏-‏12]\x*  
\v 2 إِفِيلِيسْطِينِييّنْ ضْفَارنْ شَاوُولْ ذ أَرَّاوْ نّسْ بْڒَا قطُّو ؤُشَا إِفِيلِيسْطِينِييّنْ نْغِينْ يُونَاثَانْ ذ أَبِينَاذَابْ ذ مَالْكِيشُوعَا، أَرَّاوْ ن شَاوُولْ.  
\v 3 إِذْوڒْ ؤُمنْغِي أَكْ-ذ شَاوُولْ إِوْعَارْ. إِمْجبَّاذنْ، إِرْيَازنْ س ڒْقوْسْ، ؤُفِينْ ث ؤُ نتَّا ثُوغَا إِتّڭّْوذْ أَطَّاسْ زڭْ إِمْجبَّاذنْ \add ن ڒْقوْسْ\add*.   
\m
\v 4 \add خنِّي\add* إِنَّا شَاوُولْ إِ ؤُحمَّاڒْ ن ڒسْنَاحْ نّسْ: ”سُوفّغْ-د سِّيفْ نّشْ، سْنُوقّبْ أَيِي زَّايسْ! نِيغْ أَذْ ثَاغْ أَذْ د-أَسنْ إِنِّي وَارْ إِتّْوَاخثْننْ، مَاحنْذْ أَذْ أَيِي سّْنُوقّْبنْ ؤُ أَذْ زَّايِي سْثهْزَانْ.“ \add مَاشَا\add* أَحمَّاڒْ ن ڒسْنَاحْ نّسْ وَارْ إِخْسْ \add أَذْ ت إِڭّْ\add*، مَاغَارْ نتَّا ثُوغَا إِڭّْوذْ أَطَّاسْ. \add خنِّي\add* إِكْسِي شَاوُولْ سِّيفْ ؤُشَا إِجَّا إِخفْ نّسْ أَذْ خَاسْ إِوْضَا.  
\v 5 ؤُمِي أَحمَّاڒْ ن ڒسْنَاحْ إِژْرَا، أَقَا شَاوُولْ إِمُّوثْ، إِڭَّا ؤُڒَا ذ نتَّا أَذْ إِوْضَا س يِيخفْ نّسْ خْ سِّيفْ نّسْ ؤُشَا إِمُّوثْ أَكِيذسْ.  
\v 6 أَمُّو إِ إِمُّوثْ شَاوُولْ ذڭْ وَاسّْ نِّي، \add إِمُونْ\add* أَكْ-ذ ثْڒَاثَا ن إِحنْجِيرنْ نّسْ ؤُ أَكْ-ذ ؤُحمَّاڒْ ن ڒسْنَاحْ نّسْ \add ؤُڒَا أَكْ-ذ\add* مَارَّا إِرْيَازنْ نّسْ.   
\m
\v 7 \add ؤُمِي\add* ژْرِينْ يرْيَازنْ ن إِسْرَائِيل، إِنِّي ثُوغَا غَارْ ؤُغزْذِيسْ نّغْنِي ن ڒوْضَا ن ثغْزُورْثْ ذ إِنِّي ثُوغَا خْ ؤُجمَّاضْ ن لْ-ؤُرْذُونْ، أَقَا إِرْيَازنْ ن إِسْرَائِيل أَروْڒنْ ؤُ أَقَا شَاوُولْ ذ ثْڒَاثَا ن إِحنْجِيرنْ نّسْ تّْوَانْغنْ، سمْحنْ نِيثْنِي ذِي ثْندَّامْ نْسنْ ؤُشَا أَروْڒنْ. \add ڒخْذنِّي\add* ؤُسِينْ-د إِفِيلِيسْطِينِييّنْ ؤُشَا ذوْڒنْ زدّْغنْ ذَايْسنْثْ.  
\v 8 ثِيوشَّا نّسْ، ؤُمِي د-ؤُسِينْ إِفِيلِيسْطِينِييّنْ، حِيمَا أَذْ كشّْضنْ إِنِّي إِتّْوَانْغنْ، إِمْسَارْ، أَقَا ؤُفِينْ شَاوُولْ ذ ثْڒَاثَا ن إِحنْجِيرنْ نّسْ، إِنِّي ثُوغَا إِوْضَانْ خْ وذْرَارْ ن جِيلْبُوعَا.  
\v 9 نِيثْنِي قسّنْ أَسْ أَزدْجِيفْ، سَّارْخُونْ أَسْ ڒسْنَاحْ ؤُشَا سّكّنْ \add إِرقَّاسنْ\add* ذِي ثمُّورْثْ ن إِفِيلِيسْطِينِييّنْ، حِيمَا أَذْ سِّيوْضنْ ڒخْبَارْ أَصبْحَانْ غَارْ ثَادَّارْثْ ن ڒخْيَاڒَاثْ ن لْ-أَصْنَامْ نْسنْ ؤُ جَارْ ڒْڭنْسْ. \x ◘ \xo 31:‏9 \xt 1 إِم. 10‏:‏9\x*  
\v 10 ڒسْنَاحْ ن شَاوُولْ سَّارْسنْ ث ذِي ثَادَّارْثْ \add ن زَّاوشْثْ\add* ن ’عَاشْثَارُوثِينْ‘، ؤُ ڒْخشْبثْ نّسْ ؤُيْڒنْ ت غَارْ ڒْحِيضْ ن بَايْثْ-شَانْ.   
\m
\v 11 \add ؤُمِي\add* إِمزْذَاغْ ن يَابِيشْ-جِيلْعَاذْ سْڒَانْ مِينْ ڭِّينْ إِفِيلِيسْطِينِييّنْ ذِي شَاوُولْ،  
\v 12 كَّارنْ مَارَّا إِرْيَازنْ إِمحْضنْ، ؤُيُورنْ دْجِيڒثْ ثْمُونْ ؤُشَا كْسِينْ ڒْخشْبثْ ن شَاوُولْ ذ ڒْخشْبَاثْ ن إِحنْجِيرنْ نّسْ زِي ڒْحِيضْ ن بَايْثْ-شَانْ ؤُشَا إِوْضنْ غَارْ يَابِيشْ ؤُشَا سّْشمْضنْ ثنْثْ ذِينِّي.  
\v 13 خنِّي كْسِينْ إِغْسَانْ نْسنْ، نضْڒنْ ثنْ سَاذُو ثَاشجَّارْثْ ن ثْمَارِيسْثْ ن يَابِيشْ ؤُشَا ژُومّنْ سبْعَا ن وُوسَّانْ. \f ◼ \fr 31:‏13 \ft \+bd ’ثَاشجَّارْثْ ن ثْمَارِيسْثْ‘\+bd* - س ثْلَاثِينِيثْ ’ثَامَارِيخْ‘.\f*   