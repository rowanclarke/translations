\q1 Codaa jixotediwece catiwedi laaleÉĄĖķenali 
\q1 micataÉĄĖķa daÉĄĖķa jiditedini. 
\q1 Jaotace me Ee NoenoÉĄĖķodi, 
\q1 idiaaÉĄĖķidi jaotace me yoiigi. 
\q1  
\v 11 AÉĄĖķaleeÉĄĖķica ane leeditibige daÉĄĖķa iiÉĄĖķaxi lipecaÉĄĖķawa 
\q1 oteÉĄĖķexaaÉĄĖķaÉĄĖķa nioxoa 
\q1 anodaaÉĄĖķee me yakadi me yowooÉĄĖķodi ĮĪoniotagodi AneotedoÉĄĖķoji, 
\q1 igaataÉĄĖķa inatawece etidowooÉĄĖķodi, 
\q1 niÉĄĖķina ane daÉĄĖķaxa me iwikodadipi 
\q1 codaa me niÉĄĖķina ane daÉĄĖķaxa me ÉĄĖķoneÉĄĖķaÉĄĖķa. 
\q1  
\v 12 IgaataÉĄĖķa jiwikodetibigiwaji 
\q1 codaa jixomaÉĄĖķateetedice niÉĄĖķinoa ane daÉĄĖķa iÉĄĖķenaÉĄĖķateda loenataka, 
\q1 codaa aÉĄĖķalee nalaÉĄĖķatibigiji ane libeyaceÉĄĖķeco, 
\q1 codaa aÉĄĖķalee jiloikatiditibigiwaji.ââ 
\m  
\v 13 NiÉĄĖķijo AneotedoÉĄĖķoji me eetetece ica gela anigotedoÉĄĖķowa me dinilakidetedoÉĄĖķogi, ikee niÉĄĖķijo oxiiÉĄĖķodi ane domiÉĄĖķigotedoÉĄĖķowa me dinilakidetedoÉĄĖķogi me daÉĄĖķadiaaÉĄĖķica jaoÉĄĖķa. NiÉĄĖķina ane daÉĄĖķadiaaÉĄĖķica jaoÉĄĖķa, codaa moxiiÉĄĖķodi, jeÉĄĖķele me ixomaÉĄĖķatijo. 
\c 9  
\s1 NiÉĄĖķica anodaaÉĄĖķejinaÉĄĖķa mewi me joÉĄĖķeeÉĄĖķatalo AneotedoÉĄĖķoji 
\p  
\v 1 Digawini, niÉĄĖķijo AneotedoÉĄĖķoji meote niÉĄĖķijo odoejegi anigote me dinilakidetetege oko, ikeetediogi niÉĄĖķica ane leeditibige me eetibigiwaji niÉĄĖķina modoÉĄĖķetetalo niÉĄĖķijo oko, codaa ikeetediogi niÉĄĖķijo oko anodaaÉĄĖķee moyoe niÉĄĖķijo aneiticoace modoÉĄĖķetetalo.  
\v 2 Odaa joÉĄĖķodabiteÉĄĖķetini niÉĄĖķijo lopegedi anijoa iniwataale letiidi. Ica odoejegi le beÉĄĖķeneÉĄĖķegi niiÉĄĖķeticogi we, one liboonaÉĄĖķadi, âNopegedi-le anoiomaÉĄĖķaditema AneotedoÉĄĖķojiâ. NiÉĄĖķini lopegedi-le ada noledaÉĄĖķaxi, acaaÉĄĖķaca nameeja, icaaÉĄĖķicoa paontedi anoibootalo AneotedoÉĄĖķoji.  
\v 3 Codaa onada aca lipegeteÉĄĖķe ane iomaÉĄĖķaditiwage niÉĄĖķidiwa iniwataale letiidi niÉĄĖķijo nopegedi. Ica eledi le aneneÉĄĖķegi diiÉĄĖķetiwece catiwedi ane liboonaÉĄĖķadi, âNopegedi-le aneite AneotedoÉĄĖķoji.â  
\v 4 Catiwedi niÉĄĖķini eledi nopegedi-le, adi aca nameeja oolo aneite moyalegi ica najidi ane liditege lanigi, codaa adi aca iwokodaÉĄĖķaxi aneo me nalaÉĄĖķatibigoÉĄĖķoji maleekoka dinilakidetedoÉĄĖķogi AneotedoÉĄĖķoji. NaÉĄĖķadi iwokodaÉĄĖķaxi onileÉĄĖķeta oolo. Catinedi naÉĄĖķadi iwokodaÉĄĖķaxi ada aca boote anei moyotete ica niweenigi AneotedoÉĄĖķoji ane yajigotediogi loiigi niÉĄĖķijo jotigide, anodita âManÃĄâ. Codaa catinedi adiaaÉĄĖķadi naÉĄĖķadi iwokodaÉĄĖķaxi idi niÉĄĖķijo ligiilaÉĄĖķadi ArÃĢo anidioka limedi me dione, icaaÉĄĖķicoa itiwataale wetiadi ane liciaceekawa taaboa ane diniditelogo liiÉĄĖķenatakaneÉĄĖķeco AneotedoÉĄĖķoji.  
\v 5 Ditibigimedi naÉĄĖķadi iwokodaÉĄĖķaxi idoa itoataale aanjotedi noenataka oolo, anoditalo âQuerubinsâ. NiÉĄĖķidoa querubins oikee AneotedoÉĄĖķoji miniwa. Oixaketedice labadi oyapoÉĄĖķoditini libato naÉĄĖķadi iwokodaÉĄĖķaxi. NiÉĄĖķidi ditibigimedi naÉĄĖķadi iwokodaÉĄĖķaxi one liboonaÉĄĖķadi âBaanco aneite AneotedoÉĄĖķoji me iwikode oko.â Natigide aÉĄĖķalee jakataÉĄĖķa me jeloÉĄĖķotaÉĄĖķa anodaaÉĄĖķee ica nopegedi. 
\p  
\v 6 NiÉĄĖķidiaaÉĄĖķidi naÉĄĖķa igo niÉĄĖķicoa iniwataale letiidi niÉĄĖķijo nopegedi, niÉĄĖķijoa sacerdotitedi dakatiobece inoatawece nokododi catiwedi niÉĄĖķijo odoejegi le niÉĄĖķijo nopegedi. Dakatiobece mowote libakedi moyaxawa noiigi modoÉĄĖķetetalo AneotedoÉĄĖķoji.  
\v 7 Pida ijotawece niÉĄĖķijo ane lacilodi-sacerdotitedi me dakatiobece minitaÉĄĖķa eledi nopegedi-le anoyatigi me âNopegedi-le ane itedibiga AneotedoÉĄĖķojiâ, codaa onidateci nicaaÉĄĖķabi onidateci me dakatio. NiÉĄĖķina me dakatio, idioka limedi me yadeegitedio eijeeÉĄĖķagi lawodi anoyeloadi. Ibootalo AneotedoÉĄĖķoji niÉĄĖķijoa lawodi eijeeÉĄĖķagi eotibige AneotedoÉĄĖķoji me ixomaÉĄĖķateetedice epaaÉĄĖķaÉĄĖķa libeyaceÉĄĖķeco, codaa me libeyaceÉĄĖķeco niÉĄĖķijo noiigi.  
\v 8 LeeÉĄĖķodi me ijokijota ica lacilo-sacerdotitedi me dakatio, AneotedoÉĄĖķoji Liwigo ikee niÉĄĖķidi noiigi maleedaÉĄĖķa yakadi me dakatiobece aneite AneotedoÉĄĖķoji. NiÉĄĖķijo maleeÉĄĖķica ica nopegedi, dinoxoco ica lapoagi miditaÉĄĖķa ica aneite AneotedoÉĄĖķoji.  
\v 9 Ica nopegedi jotigide, nikeetoÉĄĖķowa ica ÉĄĖķoligi aneote AneotedoÉĄĖķoji natigide mejoÉĄĖķota lodoe iniaaÉĄĖķiniwa AneotedoÉĄĖķoji. NiÉĄĖķijoa eijedi inaaÉĄĖķinoa eletidi niboonaÉĄĖķa ica noiigi anoyajigotalo AneotedoÉĄĖķoji niÉĄĖķica jotigide aÉĄĖķica loniciwaÉĄĖķa daÉĄĖķa iwilegi laaleÉĄĖķenali oko anoyemaa modoÉĄĖķetetalo AneotedoÉĄĖķoji.  
\v 10 Icoa nakataÉĄĖķa jotigide inoka odiiÉĄĖķaxinaÉĄĖķatece ica anoyakadi mowacipeta codaa moyeligo, codaa anodaaÉĄĖķee me niwilecaÉĄĖķa. InaaÉĄĖķinoa lakataÉĄĖķa anetiÉĄĖķodiiÉĄĖķaxitece anodaaÉĄĖķee me idowetaÉĄĖķateloco ÉĄĖķodolaadi. NiÉĄĖķinoa nakataÉĄĖķa aÉĄĖķaleeÉĄĖķica niwalÃģ niÉĄĖķijo AneotedoÉĄĖķoji naÉĄĖķa dinilakidetacedoÉĄĖķogi. 
\p  
\v 11 Pida Cristo jiÉĄĖķijoa menagi. JiÉĄĖķiniaaÉĄĖķiniwa niÉĄĖķicoa sacerdoti ÉĄĖķoneÉĄĖķegi ane nadeegi inoa anele. NiÉĄĖķica nopegedi analeeÉĄĖķite me diba daÉĄĖķaxa mele caticedi niÉĄĖķijo oxiiÉĄĖķodi nopegedi, codaa aÉĄĖķica libeyacaÉĄĖķajegi. IgaataÉĄĖķa aÉĄĖķoneleegiwa loenatagi niÉĄĖķica nopegedi, codaa aÉĄĖķicatigi niÉĄĖķina iiÉĄĖķo.  
\v 12 NiÉĄĖķijo naÉĄĖķa yakagiditedeloco niÉĄĖķini nopegedi, odaa ja dakatedio miditaÉĄĖķa aneite AneotedoÉĄĖķoji. Onijoteci me dakatedio, codaa ayadeegitedio lawodi waxigida oteÉĄĖķexaaÉĄĖķaÉĄĖķa waca-lionigi. Pida yadeegitedio epaa lawodi me yajigote AneotedoÉĄĖķoji, niÉĄĖķijoa lawodi ane nadooÉĄĖķodi madataÉĄĖķa nicenaÉĄĖķanaÉĄĖķate. JiÉĄĖķidaa eotedibige AneotedoÉĄĖķoji me yakadi me iwilegi ÉĄĖķobeyaceÉĄĖķeco codaa meote midioka limedi me ÉĄĖķodewiÉĄĖķa.  
\v 13 NiÉĄĖķica jotigide oibake lawodi waxigida codaa me alolanaÉĄĖķa, icaaÉĄĖķica lajimaÉĄĖķa waaca lioneke anoyalegi, odaa joÉĄĖķoilaagaÉĄĖķaditiogi oko abeyacaÉĄĖķaÉĄĖķa moiwilegitema loolatedi icoa libeyaceÉĄĖķeco, owotibige moyakadi modoÉĄĖķetetalo AneotedoÉĄĖķoji.  
\v 14 Pida lawodi Cristo daÉĄĖķaxa meliodi loniciwaÉĄĖķa. Cristo aÉĄĖķica libeyacaÉĄĖķajegi codaa aÉĄĖķica libatiigi. Codaa Liwigo, ane daÉĄĖķa yeleo, yaxawa me dinibooteta AneotedoÉĄĖķoji. Lawodi iwilegitema ÉĄĖķodaaleÉĄĖķena niÉĄĖķinoa ÉĄĖķodoenataka ane beyagi, niÉĄĖķinoa anowote me ÉĄĖķodeleo. ĮĪodiwilegi eotedibige me jakataÉĄĖķa me jaoÉĄĖķa ÉĄĖķobakeditema AneotedoÉĄĖķoji, ane ewikegi. 
\p  
\v 15 LeeÉĄĖķodi Cristo me dinibooteta AneotedoÉĄĖķoji, jiÉĄĖķiniaaÉĄĖķiniwa ane itedigi liwigotigi, AneotedoÉĄĖķoji inaaÉĄĖķoko, odaa jeÉĄĖķeote gela nimaweneÉĄĖķegi me dinilakidetetege AneotedoÉĄĖķoji inaaÉĄĖķoko. JoaniÉĄĖķidaaÉĄĖķeote AneotedoÉĄĖķoji niÉĄĖķijo ane enidite me nepilidi, eotedibige moyakadi modibatege inoa anele anakaa ligegi AneotedoÉĄĖķoji me yajigotediogi, niÉĄĖķinoa ane daÉĄĖķa daateda. AneotedoÉĄĖķoji yakadi me yajigo niÉĄĖķinoa anele igaataÉĄĖķa niÉĄĖķijo Jesus naÉĄĖķa yeleo, odaa ja noÉĄĖķatedicoace oko me itelogo libeyaceÉĄĖķeco anowote niÉĄĖķijo maleeÉĄĖķijo niÉĄĖķijo odoejegi nimaweneÉĄĖķegi me dinilakidetetege AneotedoÉĄĖķoji. 
\p  
\v 16 NiÉĄĖķina me dinilakidetedoÉĄĖķogi AneotedoÉĄĖķoji liciagi niÉĄĖķijo nakatigi midi niÉĄĖķina oko ane yeleo. NiÉĄĖķina me yeleo niÉĄĖķina oko ane dinepie. NigidiaaÉĄĖķidi niÉĄĖķicoa ane nepilidi joÉĄĖķoiigita eledi oko anepaa yemaa me yajigota maleediÉĄĖķicatibige me yeleo. Odaa odibatege niÉĄĖķicoa ane nepilidi idokidata nige yeleo niÉĄĖķijo oko.  
\v 17 NiÉĄĖķida nakatigi aÉĄĖķica ane yaxawa niÉĄĖķijo anonibeotege modibatege ane nepilidi niÉĄĖķina oko analeedaÉĄĖķa yeleo. NiÉĄĖķida nakatigi idoka diniwaloe niÉĄĖķina naÉĄĖķa yeleo niÉĄĖķini ane dinepie, igaataÉĄĖķa nigidiaaÉĄĖķidi odaa niÉĄĖķina eledi joÉĄĖķoyakadi modibatege niÉĄĖķicoa ane nepilidi niÉĄĖķijo ane yeleo.  
\v 18 JoaniÉĄĖķidaa leeÉĄĖķodi niÉĄĖķijo odoejegi anigotedoÉĄĖķowa me dinilakidetedoÉĄĖķogi AneotedoÉĄĖķoji, niÉĄĖķijo jotigide idoka diniwaloe niÉĄĖķina monadooÉĄĖķodi lawodi eijedi.  
\v 19 Odoejegi MoisÃĐs me yeloÉĄĖķoditiogi noiigi inoatawece liiÉĄĖķenatakaneÉĄĖķeco AneotedoÉĄĖķoji ane iiÉĄĖķete me iditedini. NiÉĄĖķidiaaÉĄĖķidi naÉĄĖķa dibatalo lawodi wacawaanigi inaa waxigida, odaa ja yawanaÉĄĖķaditege ninyoÉĄĖķodi, odaa niÉĄĖķidiaaÉĄĖķidi ja ibake aca nawodigije ane liboonaÉĄĖķadi âhissopoâ icaaÉĄĖķica waxacoco lamodi anowo me ixagodi. Odaa ja dibatalo ijoa lawodi yawanaÉĄĖķaditege ninyoÉĄĖķodi, datikata naÉĄĖķada nawodigije, odaa ja iticoÉĄĖķoteloco notaÉĄĖķanaÉĄĖķaxi aniwotelogo niiÉĄĖķenatakaneÉĄĖķeco, codaa iticoÉĄĖķoteloco iditawece noiigi.  
\v 20 Odaa jeÉĄĖķee, âNiÉĄĖķidiwa lawodi joaniÉĄĖķidiaa ane ikee AneotedoÉĄĖķoji meote anigotedaÉĄĖķawa me dinilakidetedaÉĄĖķagitiwaji. DinilakidetedaÉĄĖķagi AneotedoÉĄĖķoji mawii niÉĄĖķina ane iiÉĄĖķetedaÉĄĖķawa.â  
\v 21 IdaaÉĄĖķaÉĄĖķigota MoisÃĐs me iticoÉĄĖķoteloco lawodi lopegedi AneotedoÉĄĖķoji codaa inoatawece anoibake modoÉĄĖķetetalo AneotedoÉĄĖķoji.  
\v 22 Ewi niÉĄĖķijo jotigide AneotedoÉĄĖķoji iiÉĄĖķe loiigi me domoÉĄĖķoiwilegitalo icoatawece niÉĄĖķicoa lanodi anoibake modoÉĄĖķetetalo. Oibake eijeeÉĄĖķagi lawodi noÉĄĖķoiwilegi. Idoka yakaditeda AneotedoÉĄĖķoji me ixomaÉĄĖķateetedice libeyaceÉĄĖķeco oko niÉĄĖķina monadooÉĄĖķodi lawodi eijedi. 
\s1 LeeÉĄĖķodi Cristo me yeleo, odaa ja yakadi AneotedoÉĄĖķoji me iwilegi ÉĄĖķobeyaceÉĄĖķeco 
\p  
\v 23 NiÉĄĖķinoa lanodi niÉĄĖķini nopegedi anoiwilegitalo lawodi eijedi owote me liwigo niÉĄĖķicoa anidiwa digoida ditibigimedi. Leeditibige moiwilegita lawodi eijedi niÉĄĖķinoa enodi digoina iiÉĄĖķo. Pida icoa enodi digoida ditibigimedi oyopotibige lawodi ane daÉĄĖķaxa mele me yapitaÉĄĖķadi.  
\v 24 IgaataÉĄĖķa Cristo adakatediwece nopegedi ane loenatagi ÉĄĖķoneleegiwa. NiÉĄĖķijo nopegedi onowote me liwigo niÉĄĖķica digoida ditibigimedi ane dakatediwece. Idiaa dakatediwece ditibigimedi lodoe AneotedoÉĄĖķoji me dipokotedoÉĄĖķoloco natigide.  
\v 25 Inoatawece nicaaÉĄĖķape ica nisacerdoti-lacilo judeutedi dakatiwece AneotedoÉĄĖķoji liÉĄĖķeladi. Dakatiobece niÉĄĖķica diimigi-le AneotedoÉĄĖķoji ane iomaÉĄĖķaditedice mepaaÉĄĖķite, odaa yadeegitediobeci lawodi eijedi. Pida Cristo boÉĄĖķonijotece me dakatedio me diniboote AneotedoÉĄĖķoji.  
\v 26 DaÉĄĖķaleetiÉĄĖķidaaÉĄĖķee daÉĄĖķanagawini, idioka limedi me dawikode niÉĄĖķijo maleekoka yoeteda AneotedoÉĄĖķoji niÉĄĖķina iiÉĄĖķo codaa niÉĄĖķina natigide. Pida aniÉĄĖķidaaÉĄĖķee. Natigide, ja dinojogotedini icoa owidijedi nokododi, odaa ja dinikee digoina iiÉĄĖķo onijoteci me dinikee me dinajigo me yeleo eotedibige me noÉĄĖķa libeyaceÉĄĖķeco oko.  
\v 27 Inatawece oko icota me nigo, odaa onidateci me yeleo niÉĄĖķina oko. Odaa AneotedoÉĄĖķoji ja iwi niÉĄĖķica anigoteta.  
\v 28 JiÉĄĖķidaaÉĄĖķee Cristo monijoteci me dinajigo moyeloadi. Yeleo eotedibige me noÉĄĖķa libeyaceÉĄĖķeco eliodi oko. AÉĄĖķaleeÉĄĖķenagi daÉĄĖķa yeleotacedeloco oko libeyaceÉĄĖķeco. Pida dopitedijo meote me newiÉĄĖķatace ijotawece niÉĄĖķijo anonibeotege nige dopitacedijo. 
\c 10  
\p  
\v 1 Icoa najoinaÉĄĖķaneÉĄĖķeco judeutedi micataÉĄĖķa daÉĄĖķa liwa niÉĄĖķinoa anele AneotedoÉĄĖķoji ane niwakateetedibigoÉĄĖķoji, codaa aliciagi micataÉĄĖķa doÉĄĖķoka liwigo. Odaa inoatawece nicaaÉĄĖķape onigodi eijedi leeÉĄĖķodi libeyaceÉĄĖķeco, codaa owote anodaa niiÉĄĖķenatakaneÉĄĖķeco. Pida lemeÉĄĖķegi niÉĄĖķinoa eijedi aÉĄĖķica loniciwaÉĄĖķa deÉĄĖķeo me iÉĄĖķenaÉĄĖķatibigiwaji, codaa aÉĄĖķeo me diÉĄĖķica libatiigi, niÉĄĖķina oko anoyemaa mototalo AneotedoÉĄĖķoji.  
\v 2 NiÉĄĖķina oko anodoÉĄĖķetetalo AneotedoÉĄĖķoji daaditiÉĄĖķicata libatiigi oditaÉĄĖķa ewi, agotaÉĄĖķalee odeemitetece me dinilaagetee, codaa taÉĄĖķaÉĄĖķa oika monigodi inoa eijedi leeÉĄĖķotedi libeyaceÉĄĖķeco.  
\v 3 Pida aniÉĄĖķidaaÉĄĖķee. NiÉĄĖķina monigodi eijedi, eotibige idokida ina oko monalaÉĄĖķatibige inoa libeyaceÉĄĖķeco inoatawece nicaaÉĄĖķape.  
\v 4 IgaataÉĄĖķa lawodi alolanadi, waxigidatedi aÉĄĖķica loniciwaÉĄĖķa me noÉĄĖķa libeyaceÉĄĖķeco oko. 
\p  
\v 5 JoaniÉĄĖķidaa leeÉĄĖķodi maleeka doletibige Cristo menagi niÉĄĖķina iiÉĄĖķo, odaa meeteta AneotedoÉĄĖķoji, 
\q1 âAÉĄĖķemaani niÉĄĖķina oko monigodi eijedi leeÉĄĖķotedi libeyaceÉĄĖķeco oteÉĄĖķexaaÉĄĖķaÉĄĖķa niÉĄĖķinoa niboonaÉĄĖķataÉĄĖķawa niÉĄĖķina oko. 
\q1 Pida idi yolaadi ane oenitomi me jiÉĄĖķeladetigi. 
\q1  
\v 6 AÉĄĖķeo maniniitibeci niÉĄĖķina oko moyalegi niÉĄĖķinoa eijedi 
\q1 maditaÉĄĖķa ÉĄĖķanameeja wetiÉĄĖķa, 
\q1 oteÉĄĖķexaaÉĄĖķaÉĄĖķa niÉĄĖķina monigodi niÉĄĖķinoa eijedi. 
\q1  
\v 7 Odaa meji, 
\q1 âIte Ee ina, ja idigo, InoenoÉĄĖķodi, 
\q1 janagi me jaote anemaani. 
\q1 JiÉĄĖķidaaÉĄĖķee moiditeloco aneetici maditaÉĄĖķa ÉĄĖķadotaÉĄĖķanaÉĄĖķaxi.ââ 
\m  
\v 8 NiÉĄĖķijo Cristo neÉĄĖķeetetece niÉĄĖķijoa lotaÉĄĖķa baanaÉĄĖķa jidiiÉĄĖķatedini, mee, âAÉĄĖķemaani niÉĄĖķina oko monigodi eijedi modoletibige monoÉĄĖķa libeyaceÉĄĖķeco, oteÉĄĖķexaaÉĄĖķaÉĄĖķa niÉĄĖķinoa liboonaÉĄĖķataÉĄĖķawa niÉĄĖķina oko, oteÉĄĖķexaaÉĄĖķaÉĄĖķa niÉĄĖķina moyalegi niÉĄĖķinoa eijedi maditaÉĄĖķa ÉĄĖķanameeja wetiÉĄĖķa. AÉĄĖķaniniitibeci niÉĄĖķina oko mowote niÉĄĖķida loenatagi.â JiÉĄĖķidaa ligegi, idaaÉĄĖķida monigodi eijedi anodaaÉĄĖķee icoa niiÉĄĖķenatakaneÉĄĖķeco me ikeetiogi.  
\v 9 Odaa jeÉĄĖķee Cristo, âIte Ee ina, ja idigo, InoenoÉĄĖķodi. Janagi me jaote anemaani.â JiÉĄĖķidaaÉĄĖķee Cristo me yaaÉĄĖķadi niÉĄĖķijo ligileÉĄĖķegi oxiiÉĄĖķodi monigodi eijedi modoletibige monoÉĄĖķa libeyaceÉĄĖķeco niÉĄĖķidi oko, odaa jeÉĄĖķeote gela lakatigi niÉĄĖķijo naÉĄĖķa yajigo epaa lolaadi.  
\v 10 LeeÉĄĖķodi Jesus Cristo meote ane yemaa AneotedoÉĄĖķoji, odaa yajigo epaa lolaadi moyeloadi, odaa onijoteci me yeleo leeÉĄĖķotedi libeyaceÉĄĖķeco oko, ÉĄĖķodawalacetetege ica ÉĄĖķobeyaceÉĄĖķegi eote moko nepilidi. 
\p  
\v 11 Inoatawece nokododi niÉĄĖķina sacerdoti judeu icotio meote ane libakedi, odaa elioditibece monigodi eijedi modoletibige monoÉĄĖķa libeyaceÉĄĖķeco oko. Pida lemeÉĄĖķegi niÉĄĖķijoa eijedi ayakadi me noÉĄĖķa libeyaceÉĄĖķeco oko.  
\v 12 Pida Jesus, ane ĮĪonisacerdoti ÉĄĖķoneÉĄĖķegi, onijoteci me dinibootedio moyeloadi leeÉĄĖķotedi libeyaceÉĄĖķeco oko, odaa niÉĄĖķijo loenatagi idioka limedi me diniwaloe. Odaa niÉĄĖķidiaaÉĄĖķidi ja nicotedi liwai libaaÉĄĖķadi AneotedoÉĄĖķoji.  
\v 13 Odaa jiÉĄĖķidiaaÉĄĖķite Jesus me walite nigepaaÉĄĖķicota AneotedoÉĄĖķoji meote me ipoditedeloco neloÉĄĖķododipi.  
\v 14 JiÉĄĖķidaaÉĄĖķee Jesus onijoteci me yeleotedeloco libeyaceÉĄĖķeco oko, odaa jiÉĄĖķidaa leeÉĄĖķodi meote midioka limedi me iÉĄĖķenaÉĄĖķa niÉĄĖķina oko anakaa iomaÉĄĖķaditedicoace mepaa nepilidi. 
\p  
\v 15-16 Odaa ica AneotedoÉĄĖķoji Liwigo nikeetoÉĄĖķowa niÉĄĖķidaaÉĄĖķee. IgaataÉĄĖķa odoejegi mee, 
\q1 ââJiÉĄĖķidaaÉĄĖķejigota me idinilakidetege ane jao niÉĄĖķinoa nokododi,â 
\q1 mee ĮĪoniotagodi AneotedoÉĄĖķoji, 
\q1 âIdejate iiÉĄĖķenatakaneÉĄĖķeco catiwedi laaleÉĄĖķenali, 
\q1 codaa jaote midioka limedi moyowo iiÉĄĖķenatakaneÉĄĖķeco.ââ 
\m  
\v 17 NiÉĄĖķidiaaÉĄĖķidi mee, 
\q1 âAÉĄĖķalee jemaa daÉĄĖķa nalaÉĄĖķatibigiji niÉĄĖķicoa libeyaceÉĄĖķeco, 
\q1 oteÉĄĖķexaaÉĄĖķaÉĄĖķa niÉĄĖķijo me deÉĄĖķetidadiwaÉĄĖķadi.â 
\m  
\v 18 Enice niÉĄĖķina AneotedoÉĄĖķoji naÉĄĖķa noÉĄĖķa libeyaceÉĄĖķeco oko, aÉĄĖķalee leeditibige doÉĄĖķonigodi eijedi leeÉĄĖķotedi libeyaceÉĄĖķeco. 
\s1 JakataÉĄĖķa miniÉĄĖķa jipecaÉĄĖķatege AneotedoÉĄĖķoji 
\p  
\v 19 Enice, inioxoadipi, abo ÉĄĖķodaaleÉĄĖķena me jakaÉĄĖķatio aneite AneotedoÉĄĖķoji leeÉĄĖķodi Jesus me nadooÉĄĖķoditedoÉĄĖķoloco lawodi.  
\v 20 Eote gela ÉĄĖķonaigi mejoÉĄĖķotalo AneotedoÉĄĖķoji. MicataÉĄĖķa niÉĄĖķica naigi daÉĄĖķa igotece madataÉĄĖķa aca lipegeteÉĄĖķe epoacajo minitaÉĄĖķa AneotedoÉĄĖķoji liÉĄĖķeladi. Jesus, anewikegi, jiÉĄĖķiniaaÉĄĖķiniwa niÉĄĖķijo naigi leeÉĄĖķodi me yajigo epaa lolaadi moyaaÉĄĖķadi, digo majotaÉĄĖķa naÉĄĖķajo lipegeteÉĄĖķe epoacajo me daa.  
\v 21 Odaa ini ica ÉĄĖķonisacerdoti ÉĄĖķoneÉĄĖķegi ane dowediteloco AneotedoÉĄĖķoji loiigi.  
\v 22 Enice iniÉĄĖķa jipecaÉĄĖķatege AneotedoÉĄĖķoji, jinaÉĄĖķa jikanaÉĄĖķa ÉĄĖķodaaleÉĄĖķena daÉĄĖķa ÉĄĖķodinaale, pida ejiwaÉĄĖķataÉĄĖķa ajawienaÉĄĖķa. Lawodi Jesus noÉĄĖķa moko nilaagedi, odaa ÉĄĖķodapiditema inoatawece ÉĄĖķobeyaceÉĄĖķeco, micataÉĄĖķa niÉĄĖķina ninyoÉĄĖķodi ane yapidi me yapitaÉĄĖķadi ÉĄĖķodolaadi.  
\v 23 Idioka limedi me inibeoonaÉĄĖķatege ica ÉĄĖķonaÉĄĖķajegi AneotedoÉĄĖķoji ane ligegitedoÉĄĖķowa, me daÉĄĖķa jawienaÉĄĖķateda, igaataÉĄĖķa AneotedoÉĄĖķoji idioka limedi meote niÉĄĖķina ane ligegi.  
\v 24 Eleditace, jowooÉĄĖķa niÉĄĖķica anodaaÉĄĖķee me jakataÉĄĖķa me jaxawanaÉĄĖķa me idatawece idinemaanaÉĄĖķatiwage, codaa me jaxawanaÉĄĖķa inatawece mowote anele.  
