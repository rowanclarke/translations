\id PHP Rough: Sekoumady. Rework: Jun 99. Checked with team: Oct 99. Printed: Oct 00.
\h قِلِثِ
\toc1 عَلَ شَ مَسٍنيِ عَننَبِ ثْلُ نَشَن سّبّ قِلِثِ دَنشَنِيَتْي حَمَ مَ
\toc2 قِلِثِ
\mt1 عَلَ شَ مَسٍنيِ
\mt1 عَننَبِ ثْلُ نَشَن سّبّ
\mt1 قِلِثِ دَنشَنِيَتْي حَمَ مَ
\imt1 مَسٍنيِ ندٍ يِ كِتَابُي شَ قٍ رَ
\ip يِ كِتَابُي قِندِشِ بَتَاشّ نَن نَ عِسَ شَ شّيرَ ثْلُ نَشَن سّبّ عِسَيَنكَيٍ مَ نَشٍيٍ نُ سَبَتِشِ قِلِثِ تَا كُي. سِنفٍ ثْلُ نُ بَرَ كَوَندِ تِ مّننِ عَلَكٌ مِشِيٍ شَ دَنشَنِيَ عِسَ مَ. عٍ شَ دَنشَنِيَ نَشَ سَبَتِ عَ قَنيِ رَ، هَن عٍ ثْلُ مَلِ عَ شَ وَلِ كُي يِرٍ فبّتّ. نَ تَرُشُي سّبّشِ عِسَ شَ شّيرَيٍ شَ تَرُشُي كُي، سٌرَ ١٦.
\ip ثْلُ تٌ بَلَن فٍيلِ رْ مَ عَ شَ دَنشَنِيَ شَ قٍ رَ، عَلَ نَشَ عَ نِيَ عَ شَ بَتَاشّيٍ سّبّ دَنشَنِيَتْي حَمَ ندٍيٍ مَ. ثْلُ نَشَ بَتَاشّ كٍرٍن سّبّ قِلِثِ دَنشَنِيَتْييٍ مَ. عَ نَشَ عٍ رَلِمَنِيَ عَلَكٌ عٍ شَ لُ عَلَ سَفٌي، عٍ مَن شَ قِندِ مِسَالِ قَنيِ رَ نَشَن نْمَ عَ نِيَدٍ مِشِ فبّتّيٍ شَ بِرَ عِسَ قْشْ رَ. ثْلُ نَشَ عٍ رَتُ عَ عٍ مُ نْمَ عٍ يّتّ رَكِسِدٍ عٍ شَ قٍ قَنيِ سَابُي رَ، قٌ عِسَ سَابُي رَ نَشَن عَ يّتّ بَشِ سّرّشّ رَ دُنِحَ بِرِن بّ.
\ip تٌ عِسَيَنكَيٍ مَن نْمَ لِمَنِيَ سْتْدٍ يِ كِتَابُي سَابُي رَ. عَلَ شَ مَسٍنيِ شَشِلِ قَنيِ نُن سّنبّ قِمَ مِشِيٍ مَ عٍ نَ عٍ بْحّ رَبِ عَ بّ. عَلَ شَ وٌن مَلِ عَلَكٌ وٌن شَ سّيوّ كٌلٌن نَشَن قَتَنشِ عَلَتَلَ رَ. عَمِنَ.
\mt1 عَلَ شَ مَسٍنيِ
\mt1 عَننَبِ ثْلُ نَشَن سّبّ
\mt1 قِلِثِ دَنشَنِيَتْي حَمَ مَ
\cl سٌرَ
\c 1
\s1 شّيبُي
\p 
\v 1 ﭑ تَن ثْلُ نُن تِمٌتٍ، نَشٍيٍ قِندِشِ عَلَ شَ مِشِ سُفَندِشِ عِسَ شَ كٌنيِيٍ رَ، مُشُ بَرَ وٌ شّيبُ، عَلَ شَ مِشِ سُفَندِشِ شَ سّنِيّنتْي نَشٍيٍ نَ قِلِثِ، عَ نُن وٌ شَ يَرٍرَتِيٍ نُن وٌ مَلِمَيٍ.
\v 2 وٌن بَبَ عَلَ نُن عَ شَ مِشِ سُفَندِشِ مَرِفِ عِسَ شَ هِننّ نُن بْحّسَ قِ وٌ مَ.
\p 
\v 3 تّمُي بِرِن ﭑ نَ رَتُ وٌ مَ، ﭑ عَلَ تَنتُمَ نّ.
\v 4 ﭑ عَلَ مَشَندِ مَ وٌ بّ سّيوّ رَ تّمُي بِرِن،
\v 5 بَرِ مَ وٌ بَرَ ﭑ مَلِ عَلَ شَ مَسٍنيِ كَوَندِقٍ رَ كَبِ عَ قْلّ هَن يَكْسِ.
\v 6 ﭑ عَ كٌلٌن، عَلَ، نَشَن وَلِ قَنيِ قْلْشِ وٌ تَفِ، عَ قَمَ نّ عَ رَكَمَلِدٍ عَ شَ مِشِ سُفَندِشِ عِسَ قَ لْشْي.
\v 7 عَ لَن نّ يِ شَشِلِ شَ لُ ﭑ بّ بَرِ مَ وٌ رَقَن ﭑ مَ. شَ ﭑ نَ فٍيلِ كُي، شَ ﭑ نَ عَلَ شَ شِبَارُ قَنيِ شُنمَفٍرٍ سٌقٍ كَوَندِ رَ، عَلَ هِننّمَ نّ وٌن بِرِن نَ.
\v 8 عَلَ عَ كٌلٌن ﭑ وٌ شَنُشِ عَلْ عَ شَ مِشِ سُفَندِشِ عِسَ وٌ شَنُشِ كِ نَشّ.
\p 
\v 9 ﭑ عَلَ مَشَندِ مَ نّ وٌ بّ عَلَكٌ وٌ شَ شَنُنتٍيَ شُن شَ مَسَ قٍ كٌلٌنيِ نُن قَهَامُي تِلِنشِ رَ،
\v 10 عَلَكٌ وٌ شَ نْ عَ كٌلٌندٍ قٍ نَشَن تِدٍ فبٌ. نَ كُي، وٌ بْحّ شَ قِيشّ، مَرَكْرْ سِ يٌ نَشَ لُ وٌ مَ عَلَ شَ مِشِ سُفَندِشِ قَ لْشْي.
\v 11 نَ لْشْي عِسَ قَمَ نّ وٌ مَتِنشِندٍ عَلَكٌ عَلَ شَ مَتْشْ، عَ سّنبّ شَ كٌلٌن.
\s1 ثْلُ نُن كَوَندِتِيٍ
\p 
\v 12 ﭑ نفَشَكٍرٍنيِيٍ، وٌ شَ عَ كٌلٌن، تْورّ نَشَن ﭑ لِشِ، نَ بَرَ عِنيِلَ عِسَ مَسٍنيِ وَلِ رَ سْونّيَ،
\v 13 بَرِ مَ مَنفّ شَ سْورِيٍ نُن مِشِيٍ بِرِن بَرَ عَ كٌلٌن ﭑ نَ فٍيلِ كُي عَلَ شَ مِشِ سُفَندِشِ شَ قٍ نَن مَ.
\v 14 ﭑ نفَشَكٍرٍنيِيٍ بَرَ لِمَنِيَ مَرِفِ شَ قٍ مَ ﭑ مَ حَشَنكَتّ سَابُي رَ. يَكْسِ عٍ مُ فَاشُمَ قٍقٍ يَ رَ، عٍ عَلَ شَ مَسٍنيِ كَوَندِ مَ سّنبّ رَ.
\p 
\v 15 نْندِ نَن عَ رَ، ندٍيٍ نَ عَلَ شَ مِشِ سُفَندِشِ شَ قٍ كَوَندِقٍ مِلّ نُن تْونّ نَن مَ، كْنْ ندٍيٍ قَن نَ كَوَندِ تِقٍ بْحّ قَنيِ نَن نَ.
\v 16 نٍيٍ عَ رَبَقٍ شَنُنتٍيَ نَن نَ، بَرِ مَ عٍ عَ كٌلٌن عَ ﭑ قِندِشِ شِبَارُ قَنيِ شُنمَفٍرٍ سٌ نَن نَ.
\v 17 بٌورٍيٍ عَلَ شَ مِشِ سُفَندِشِ شَ قٍ كَوَندِ مَ عٍ شَ يّتّ عِفبٌحَ نَن نَ. عٍ بْحّ مُ قِيشّ. عٍ حْشْ عَ مَ عَ عٍ نْمَ ﭑ مَ فٍيلِ حَشَنكَتّ شُن مَسَدٍ عٍ شَ كَوَندِ رَ.
\v 18 قٍقٍ مُ عَ رَ. شَ عٍ بْحّ قِيشّ، شَ عٍ بْحّ مُ قِيشّ، عٍ نَ عَلَ شَ مِشِ سُفَندِشِ شَ قٍ مَسٍنقٍ. يِ قِندِ مَ سّيوّ نَن نَ ﭑ بّ تٌ نُن تِنَ،
\v 19 بَرِ مَ ﭑ عَ كٌلٌن قٍ نَشٍيٍ بَرَ ﭑ لِ، عٍ قِندِ مَ كِسِ نَن نَ ﭑ بّ وٌ شَ عَلَ مَشَندِ سَابُي رَ نُن عَ شَ مِشِ سُفَندِشِ عِسَ شَشِلِ شَ مَلِ سَابُي رَ.
\p 
\v 20 ﭑ عَ كٌلٌن ﭑ قٍ بِرِن نَبَمَ عَلَكٌ ﭑ نَشَ يَافِ قٍقٍ رَ. ﭑ شَ لِمَنِيَ يَكْسِ عَلْ تّمُي دَنفِشِ عَلَكٌ عَلَ شَ مِشِ سُفَندِشِ شَ مَتْشْي سْتْ ﭑ مَ سِمَيَ شَ نَ مُ ﭑ مَ قَشّ سَابُي رَ.
\v 21 ﭑ مَ دُنِحّءِفِرِ كُي، ﭑ بِرَ مَ نّ عَلَ شَ مِشِ سُفَندِشِ قْشْ رَ. ﭑ مَ قَشّ قِندِ مَ قٍ قَنيِ نَن نَ ﭑ بّ،
\v 22 كْنْ شَ ﭑ لُ دُنِحَ، ﭑ نْمَ نّ وَلِ فبٍفبٍ رَبَدٍ عَلَ بّ. عَوَ، ﭑ مُنسٍ رَبَمَ؟ ﭑ مُ عَ كٌلٌن.
\v 23 نَ قٍ نَ ﭑ بّندُنقٍ يِرٍ قِرِن. عَ شْلِ ﭑ مَ ﭑ شَ كٍلِ بٍ، ﭑ شَ سِفَ عَلَ شَ مِشِ سُفَندِشِ يِرٍ. نَ قَن دَنفِ قٍ بِرِن نَ.
\v 24 كْنْ عَ لَنمَ ﭑ شَ لُ دُنِحَ وٌ تَن مَ قٍ رَ.
\v 25 ﭑ بَرَ عَ كٌلٌن ﭑ لُمَ نّ وٌ يَ مَ عَلَكٌ وٌ شَ سِفَ يَرٍ، وٌ مَن شَ سّيوَ دَنشَنِيَ كُي.
\v 26 ﭑ نَ فبِلٍن وٌ يِرٍ، وٌ شَ مَتْشْي عَلَ شَ مِشِ سُفَندِشِ عِسَ بّ، نَ شُن قَمَ مَسَدٍ ﭑ مَ قٍ رَ.
\p 
\v 27 وٌ حّرّ كِ شَ لَن عَلَ شَ مِشِ سُفَندِشِ شَ شِبَارُ قَنيِ مَ تُن، عَلَكٌ شَ ﭑ نَ وٌ يَ مَ بَ، شَ ﭑ مُ نَ بَ، ﭑ نْمَ عَ كٌلٌندٍ شَشِلِ كٍرٍن نَن نَ وٌ بّ، وٌ بِرِن وَلِقٍ دَنشَنِيَ كٍرٍن نَن نَ، دَنشَنِيَ نَشَن قَتَنشِ عَلَ شَ شِبَارُ قَنيِ رَ.
\v 28 وٌ نَشَ فَاشُ وٌ فٍرٍقَيٍ يَ رَ. وٌ شَ لِمَنِيَ قِندِشِ تْنشُمَ نَن نَ عٍ بّ عٍ لْيقٍ رَ، وٌ قَن شَ عَ كٌلٌن وٌ كِسِمَ نّ.
\v 29 نَ كِسِ كٍلِشِ عَلَ نَن مَ، بَرِ مَ عَ بَرَ هِننّ وٌ رَ دْشْ قِرِن؛ وٌ دَنشَنِيَقٍ عَلَ شَ مِشِ سُفَندِشِ مَ، عَ نُن وٌ مَن تْورْقٍ عَ بّ،
\v 30 عَلْ وٌ ﭑ قَن تٌ تْورْ رَ كِ نَشّ. عَلْ وٌ مَن بَرَ عَ مّ كِ نَشّ، هَن يَ ﭑ نَ نَ تْورّ نَن كُي.
\c 2
\s1 عِسَ شَ مِسَالِ
\p 
\v 1 عَلَ شَ مِشِ سُفَندِشِ تٌ مَدُندُي ندٍ قِمَ وٌ مَ، عَ شَ شَنُنتٍيَ تٌ لِمَنِيَ ندٍ قِمَ وٌ مَ، لَنيِ تٌ نَ وٌ نُن عَلَ شَشِلِ سّنِيّنشِ تَفِ، شَنُنتٍيَ نُن كِنِكِنِ ندٍ تٌ نَ وٌ يِ رَ،
\v 2 وٌ شَ ﭑ مَ حّلّشِنيِ رَكَمَلِ. وٌ لُ لَنيِ كُي. شَشِلِ كٍرٍن، شَنُنتٍيَ كٍرٍن، نُن حّرّ كِ كٍرٍن نَن شَ لُ وٌ تَفِ.
\v 3 وٌ نَشَ قٍقٍ رَبَ تْونّ كُي. وٌ نَشَ وٌ يّتّ رَقِسَ وٌ بٌورٍيٍ بّ. وٌ ندٍ بَ وٌ شَ قٍ رَ، وٌ عَ سَ وٌ بٌورٍ فبٍ شُن يّتّ مَفٌرٍ كُي.
\v 4 وٌ نَشَ وٌ يّتّ شَ مُنَقَنيِ قٍن. وٌ وٌ بٌورٍيٍ نَن مَ مُنَقَنيِ قٍن.
\p 
\v 5 وٌ يُفٍ شَ لُ عَلْ عَلَ شَ مِشِ سُفَندِشِ عِسَ.
\q1 
\v 6 كَبِ عَبَدَن، عَ نُ نَ عَلَ كّحَ نّ،
\q1 كْنْ عَ مُ تِن عَ شَ عَ يّتّ تِدٍ سَ عَلَ عِلَنيِ.
\q1 
\v 7 عَ نَشَ دِحّ عَ يّتّ بِرِن مَ،
\q1 عَ تِن لُدٍ كٌنيِ كّحَ مَ،
\q1 عَ بَرِ دُنِحَ مَ عَلْ عَدَ مَدِ،
\q1 مِشِيٍ قَن نَشَ عَ كٌلٌن عَدَ مَدِ رَ.
\q1 
\v 8 عَ نَشَ عَ يّتّ مَفٌرٌ،
\q1 عَ شَ عَلَ سَفٌ رَبَ،
\q1 هَن عَ نَشَ تِن قَشّ رَ وُرِ مَفَلَنبُشِ مَ.
\q1 
\v 9 نَ نَن عَ تٌشِ عَلَ نَشَ عَ بِنيَ،
\q1 عَ عَ شِلِ فبٌ دَنفِ شِلِ بِرِن نَ،
\q1 
\v 10 عَلَكٌ نَشٍيٍ نَ كٌورٍ،
\q1 نَشٍيٍ نَ بْشِ،
\q1 نَشٍيٍ نَ بْشِ بُن مَ،
\q1 عٍ نَ عِسَ شِلِ مّ تّمُي نَشّ،
\q1 عٍ بِرِن شَ عٍ شِنبِ سِن عَ بُن،
\q1 
\v 11 عٍ شَ عَ قَلَ،
\q1 «عَلَ شَ مِشِ سُفَندِشِ عِسَ نَن نَ مَرِفِ رَ.»
\q1 نَ شَ قِندِ مَتْشْي رَ بَبَ عَلَ بّ.
\b
\p 
\v 12 ﭑ شَنُنتٍنيِيٍ، وٌ بَرَ ﭑ شُي سُشُ ﭑ نُ نَ وٌ تَفِ تّمُي نَشّ. يَكْسِ قَن، وٌ شَ عَلَ شَ يَامَرِيٍ رَبَتُ ﭑ شَنبِ دَنفِقٍ عَ سِنفٍ رَ. وٌ شَ فَاشُ عَلَ يَ رَ، وٌ شَ وَكِلِ وٌ شَ كِسِ شَ قٍ رَ.
\v 13 عَلَ نَن قٍ رَفِرِ مَ وٌ مَ عَلَكٌ وٌ حَنِفٍ شَ لَن عَ فبٍ مَ، وٌ شَ عَ وَشْنقٍ رَبَ.
\v 14 وٌ نّ قٍقٍ رَبَمَ وٌ نَشَ وٌ يَشَسٍرِ مَسَ، وٌ نَشَ سْنشْ،
\v 15 عَلَكٌ نْندِ نُن سّنِيّنيِ شَ لُ وٌ بّ، وٌ تَن عَلَ شَ دِيٍ نَشٍيٍ يَنبَمَ عَلْ تّ دّشّ يِ دُنِحَ مِشِ حَاشِ تِنشِنتَرٍيٍ يَ مَ،
\v 16 وٌ نّ كِسِ مَسٍنيِ تِمَ تّمُي نَشّ. نَ كُي، ﭑ مَتْشْي سْتْمَ عَلَ شَ مِشِ سُفَندِشِ قَ لْشْي، بَرِ مَ ﭑ مُ دُنِحَ عِفِرِشِ تْورّ كُي قُقَقُ رَ.
\v 17 هَلِ ﭑ قَشَ وٌ بّ، ﭑ مَ دُنِحّءِفِرِ قَمَ قِندِدٍ وٌ بّ سّرّشّ نَن نَ نَشَن سَمَ وٌ شَ دَنشَنِيَ سّرّشّ شُن مَ. نَ ﭑ نَسّيوَ مَ نّ.
\v 18 وٌ قَن شَ سّيوَ، وٌن بِرِن شَ سّيوَ.
\s1 تِمٌتٍ نُن عٍثَقٌرٌدِتٍ
\p 
\v 19 ﭑ بَرَ ﭑ شَشِلِ تِ مَرِفِ عِسَ رَ عَ شَ ﭑ مَلِ عَلَكٌ ﭑ شَ تِمٌتٍ شّي وٌ مَ، عَلَكٌ عَ شَ ﭑ نَلِمَنِيَ وٌ شَ شِبَارُ رَ.
\v 20 مِشِ يٌ مُ نَ ﭑ يِ رَ، وٌ شَ قٍ رَقَن نَشَن مَ عَلْ عَ تَن.
\v 21 بِرِن وَ مَ عٍ يّتّ كَن شَ فٍينِ نَن شْن مَ، عٍ مُ نَ عَلَ شَ مِشِ سُفَندِشِ عِسَ شَ فٍينِ شَ قٍنقٍ.
\v 22 وٌ عَ كٌلٌن تِمٌتٍ بَرَ عَ تُننَبّشِ تْورّ كُي عَلَ شَ شِبَارُ قَنيِ شَ قٍ رَ. كَبِ عَ نَشَ وَلِ قْلْ ﭑ سّيتِ مَ تّمُي نَشّ، عَ بَرَ لُ عَلْ دِ نَشَن بِرَ مَ عَ بَبَ قْشْ رَ.
\v 23 نَ كُي، عَ شْلِ ﭑ مَ ﭑ شَ عَ شّي وٌ يِرٍ، ﭑ مَ قٍ مَكّنّنمَ تّمُي نَشّ.
\v 24 ﭑ عَ كٌلٌن عَ فبٍ مُ لُشِ، عَلَ شَ عَ رَفِرِ ﭑ شَ قَ وٌ يِرٍ.
\p 
\v 25 كْنْ ﭑ مَ مَحْشُنيِ مَ، قٌ ﭑ شَ ﭑ نفَشَكٍرٍنيِ عٍثَقٌرٌدِتٍ شّي وٌ يِرٍ. عَ بَرَ ﭑ مَلِ كِ قَنيِ رَ عَلَ شَ قٍ فٍرٍ مَسٌ كُي، عَلْ وٌ عَ شّيشِ ﭑ مَ قٍ نَشَن مَ.
\v 26 وٌ تٌ شْلِ بَرَ عَ سُشُ كِ قَنيِ. عَ بَرَ كْنتْقِلِ بَرِ مَ وٌ بَرَ عَ شَ قُرٍ قٍ مّ.
\v 27 عَ قُرَ نّ عَ حَاشِ رَ. عَ فبٍ مُ نُ لُشِ عَ شَ قَشَ، كْنْ عَلَ نَشَ كِنِكِنِ عَ مَ. عَلَ نَشَ كِنِكِنِ ﭑ قَن مَ، عَلَكٌ نَ سُننُنيِ نَشَ سَ ﭑ مَ تْورّ شُن.
\v 28 نَ نَ عَ رَ ﭑ بَرَ فبَتَ عَ شّيقٍ رَ وٌ مَ عَلَكٌ وٌ شَ حّلّشِن عَ تٌقٍ رَ، ﭑ قَن بْحّ ندٍدِ شَ سَ.
\v 29 وٌ شَ عَ رَ سّنّ مَرِفِ شِلِ رَ سّيوّ كُي. وٌ شَ يِ مِشِ مْولِ بِنيَ،
\v 30 بَرِ مَ عَ مُ تٌندِ قٍقٍ يٌ رَ عَلَ شَ مِشِ سُفَندِشِ شَ وَلِ كُي، هَلِ عَ قِندِ عَ بّ قَشّ رَ. عَ بَرَ ﭑ مَلِ وٌ تَن مُ نُ نْمَ ﭑ مَلِدٍ نَشٍيٍ رَ.
\c 3
\s1 كِسِ سْتْقٍ
\p 
\v 1 يَكْسِ، ﭑ نفَشَكٍرٍنيِيٍ، وٌ شَ سّيوَ وٌ مَرِفِ رَ. ﭑ مُ تَفَنمَ فبِلٍندٍ قٍيٍ تَفِ رَبَدٍ وٌ بّ، ﭑ نَشٍيٍ سّبّشِ وٌ مَ تّمُي دَنفِشِ، عَلَكٌ نَ شَ وٌ رَتَنفَ.
\v 2 وٌ شَ وٌ يّتّ رَتَنفَ مِشِ حَاشِيٍ مَ، وَلِ كٌبِ رَبَيٍ نَشٍيٍ وَ مَ قِنّ رَوَلِقٍ تُن مِشِ سُننَقٍ مَ.
\v 3 وٌن تَن نَن نَ مِشِ سُننَشِيٍ رَ عَ نْندِ كِ مَ، وٌن تَن نَشٍيٍ عَلَ بَتُمَ عَ شَشِلِ سّنِيّنشِ سَابُي رَ، نَشٍيٍ سّيوَ مَ عِسَ عَلَ شَ مِشِ سُفَندِشِ شَ قٍ رَ، نَشٍيٍ مُ عٍ شَشِلِ تِمَ عٍ يّتّ رَ.
\p 
\v 4 شَ ﭑ وَ، ﭑ قَن نْمَ ﭑ شَشِلِ تِدٍ ﭑ يّتّ رَ. شَ مِشِ ندٍ عَ مَحْشُنشِ نّ عَ عَ نْمَ عَ شَشِلِ تِدٍ عَ يّتّ رَ، ﭑ دَنفِ نَ كَنيِ رَ ثٌن!
\v 5 ﭑ سُننَشِ عَ شِ سٌلٌمَسَشَن لْشْي نّ، عِسِرَيِلَكَ نَن ﭑ نَ، نَشَن كٍلِشِ بُنيَمِن بْنسْي، عٍبُرُ يَتِ يَتِ نَن لَنشِ ﭑ مَ ﭑ بَرِ كِ مَ.
\v 6 ﭑ نُ بِرَشِ عَلَ شَ سّرِيّ قْشْ رَ عَ قَرِ سّنِ كِ نّ، ﭑ نُ قَ عِسَ شَ دَنشَنِيَتْييٍ حَشَنكَتَ. مَرَكْرْ سِ حَاشِ يٌ مُ نُ نَ ﭑ مَ.
\p 
\v 7 كْنْ يَكْسِ، ﭑ تٌ بَرَ دَنشَنِيَ عَلَ شَ مِشِ سُفَندِشِ مَ، ﭑ نُ سٍ نَشَن بِرِن مَحْشُنشِ قٍ قَنيِيٍ رَ، عٍ تِدٍ يٌ مُ نَ ﭑ بّ سْنْن.
\v 8 مَرِفِ عِسَ كٌلٌنقٍ نَن تِدٍ فبٌ نٍيٍ بِرِن بّ. عَلَ شَ مِشِ سُفَندِشِ سْتْقٍ دَنفِ نَ قٍ بِرِن نَ، ﭑ بَرَ نَشٍيٍ لُ عَ شَ قٍ رَ. نَ قٍيٍ بَرَ لُ ﭑ بّ عَلْ قٍيٍ قُقَقُ عَلَكٌ ﭑ شَ عِسَ شَ مُنَقَنيِ سْتْ.
\v 9 ﭑ شَ لُ عَ تَن نَن مَ قٍ، بَرِ مَ ﭑ يّتّ سّنبّ مُ نْمَ ﭑ قِندِدٍ مِشِ تِنشِنشِ رَ. ﭑ مُ نْمَ عَلَ شَ سّرِيّ بِرِن نَبَتُدٍ. كْنْ شَ ﭑ بَرَ دَنشَنِيَ عَلَ شَ مِشِ سُفَندِشِ مَ، عَلَ تَن نْمَ نّ ﭑ مَتِنشِندٍ. عَلَ نَن مِشِ مَتِنشِنمَ دَنشَنِيَ سَابُي رَ.
\v 10 نَ كُي، ﭑ وَ مَ نَشَن شْن، ﭑ شَ عِسَ كٌلٌن. ﭑ شَ عَ شَ مَرَكٍلِ سّنبّ كٌلٌن، ﭑ مَن شَ تْورْ عَلْ عَ تْورْشِ كِ نَشّ. ﭑ وَ مَ لُقٍ نّ عَلْ عِسَ نُ نَ كِ نَشّ عَ قَشَ تّمُي،
\v 11 عَلَكٌ ﭑ قَن شَ كٍلِ قَشّ مَ.
\p 
\v 12 ﭑ عَ كٌلٌن ﭑ مُ نُ فّ نَ بِرِن سْتْدٍ سِندٍن، ﭑ مَ قٍ مُ فّشِ كَمَلِدٍ. كْنْ ﭑ شَ سِفَ يَرٍ عَلَكٌ عِسَ ﭑ سُفَندِشِ قٍ نَشَن مَ، ﭑ قَن شَ عَ شَ قٍ سُشُ.
\v 13 ﭑ نفَشَكٍرٍنيِيٍ، ﭑ عَ كٌلٌن ﭑ مُ فّشِ عَ سُشُدٍ سِندٍن، كْنْ ﭑ قٍ كٍرٍن نَن نَبَمَ؛ ﭑ مُ ﭑ كٌبٍ رَتٌمَ، ﭑ سِفَمَ يَرٍ نَن تُن مَ.
\v 14 ﭑ بِرَ مَ نّ ﭑ مَ وَلِ قْشْ رَ، عَلَكٌ ﭑ شَ سَرٍ سْتْ كٌورٍ مَنفّ عَلَ وٌن شِلِشِ نَشَن مَ عَ شَ مِشِ سُفَندِشِ عِسَ سَابُي رَ.
\p 
\v 15 وٌن تَن نَشٍيٍ شَ دَنشَنِيَ بَرَ تِلِن، عَ لَنمَ نَ مَحْشُنيِ نَن شَ لُ وٌن بِرِن يِ رَ. كْنْ شَ عَ سَ لِ مِشِ ندٍ مُ لَنشِ نَ قٍ مَ، عَلَ قَمَ نَ قَن قِيشّدٍ نَ كَنيِ بّ.
\v 16 وٌن شَ سِفَ يَرٍ عَلْ وٌن دَرِشِ عَ رَ كِ نَشّ.
\p 
\v 17 ﭑ نفَشَكٍرٍنيِيٍ، وٌ شَ ﭑ قْشِ رَبَ. مِشِ نَشٍيٍ حّرّ كِ لُشِ عَلْ مُشُ فبٍ، نٍيٍ نَن شَ قِندِ مِسَالِ رَ وٌ بّ.
\v 18 عَلَ شَ مِشِ سُفَندِشِ يَشُييٍ بَرَ وُيَ، نَشٍيٍ مُ لَمَ عَ شَ سّرّشّ رَ وُرِ مَفَلَنبُشِ مَ. ﭑ حَن بَرَ نَ قَلَ وٌ بّ سَنيَ وُيَشِ، كْنْ يَكْسِ ﭑ عَ مَسٍنمَ نّ وٌ بّ ﭑ يَيٍ رَ.
\v 19 عٍ بَرَ لْي. عٍ يّتّ وَشْنقٍ بَرَ قِندِ عٍ شَ عَلَ رَ. عٍ نَشَن عِتٍمَ، نَ نَن قَمَ عٍ رَفٌرٌدٍ. عٍ بِرَ مَ يِ دُنِحَ فبَنسَن نَن قْشْ رَ.
\v 20 كْنْ وٌن تَن شْنيِ نَ عَرِيَننَ نَن نَ، وٌن نَكِسِمَ مَرِفِ عِسَ كٍلِمَ دّننَشّ قَقٍ رَ وٌن قْشْ رَ. وٌن نَ نَ نَن مَمّقٍ.
\v 21 عَ قَمَ نّ وٌن قَتٍ مَكِنِكِنِشِيٍ مَسَرَدٍ، عٍ شَ لُ نْرّ كُي عَلْ عَ فبٍ. عَ نَ رَبَمَ عَ سّنبّ نَن نَ، نَشَن دَنفِ سّنبّ بِرِن نَلَنشِ رَ.
\c 4
\s1 مَرَ سِ دْنشْييٍ
\p 
\v 1 ﭑ نفَشَكٍرٍنيِيٍ، عَ شْلِ ﭑ مَ ﭑ شَ سِفَ وٌ شّيبُدٍ. ﭑ بَرَ حّلّشِن وٌ شَ قٍ رَ، نَشَن بَرَ عَ نِيَ ﭑ شَ بِنيّ سْتْ. ﭑ شَنُنتٍنيِيٍ، وٌ بِرَ مَرِفِ قْشْ رَ عَلْ وٌ دَرِشِ عَ رَ كِ نَشّ.
\p 
\v 2 عٍوٌدِيٍ نُن سِنتِكٍ، يَندِ وٌ شَ لَن وٌ بٌرٍ مَ مَرِفِ شَ قٍ كُي.
\v 3 ﭑ مَلِمَ قَنيِ، ﭑ بَرَ عِ مَشَندِ، عِ شَ عٍ مَلِ، بَرِ مَ عٍ قَن بَرَ ﭑ مَلِ ﭑ مَ كَوَندِ تِقٍ فٍرٍ مَسٌ كُي. كِلٍمٍنتِ قَن بَرَ ﭑ مَلِ، عَلْ ﭑ وَلِبٌورٍيٍ نَشٍيٍ شِلِيٍ سّبّشِ كِسِ بُكِ كُي.
\p 
\v 4 وٌ سّيوَ مَرِفِ رَ تّمُي بِرِن. ﭑ مَن شَ عَ قَلَ وٌ بّ، وٌ شَ سّيوَ.
\v 5 وٌ شَ بْحّ بّشِ شَ مَكّنّن بِرِن بّ. مَرِفِ مُ بُمَ قَقٍ رَ سْنْن.
\v 6 وٌ نَشَ كْنتْقِلِ قٍقٍ رَ، وٌ شَ عَلَ مَشَندِ قٍ بِرِن كُي، وٌ شَ عَ مَيَندِ، وٌ شَ عَ تَنتُ.
\v 7 نَ كُي، عَلَ بْحّسَ نُن شَشِلِسَ قِمَ نّ وٌ مَ نَشَن مْولِ مُ تٌمَ يِ دُنِحَ قَرِ. عَ نَ رَبَمَ عَ شَ مِشِ سُفَندِشِ عِسَ نَن سَابُي رَ.
\p 
\v 8 دْنشْي رَ، وٌ شَ وٌ شَشِلِ دْشْ يِ قٍيٍ نَن شْن مَ؛ قٍ نَشَن يٌ قِندِ نْندِ رَ، نَشَن يٌ قِندِ سْوبّ رَ، نَشَن يٌ تِنشِن، نَشَن يٌ سّنِيّن، نَشَن يٌ قَن، نَشَن يٌ قِندِ سّرِيّ رَ، نَشَن يٌ رَقَن عَلَ مَ. وٌ شَ وٌ شَشِلِ دْشْ يِ قٍيٍ نَن شْن بِنيّ نُن تَنتُي نَ نَشٍيٍ كُي.
\v 9 ﭑ نَشَن مَسٍنشِ وٌ بّ، وٌ نَشَن تٌشِ ﭑ مَ مِسَالِ كُي، وٌ بِرَ نَ قْشْ رَ. نَ كُي، بْحّسَ مَنفّ لُمَ نّ وٌ سّيتِ مَ.
\s1 شّيبُي
\p 
\v 10 ﭑ بَرَ مَرِفِ تَنتُ وٌ شَ قٍ رَ بَرِ مَ وٌ مَن بَرَ وٌ حْشْ سَ ﭑ شْن. سِنفٍ وٌ نُ بَرَ وَ ﭑ مَلِقٍ، كْنْ عَلَ مُ عَ رَفِرِ.
\v 11 ﭑ مُ يِ قَلَشِ شّ بَرِ مَ ﭑ هَيِ تٌ نَ سٍ ندٍ مَ. ﭑ بَرَ ﭑ مَتِنكَن ﭑ شَ وَ سَ سٌ سٍ نَشَن نَ ﭑ يِ رَ.
\v 12 شَ سٍسٍ يٌ مُ نَ ﭑ يِ رَ، شَ سٍ فبٍفبٍ نَ ﭑ يِ رَ، عَ بِرِن قَن. شَ كَامّ ﭑ سُشُشِ، شَ ﭑ لُفَشِ، ﭑ بَرَ وَ سَ عَ بِرِن نَ. شَ ﭑ بَننَشِ، شَ ﭑ تْورْشِ، ﭑ بَرَ سّيوَ عَ بِرِن نَ.
\v 13 ﭑ نْمَ قٍ بِرِن نَ ﭑ مَرِفِ سَابُي رَ، نَشَن سّنبّ قِمَ ﭑ مَ.
\v 14 كْنْ وٌ قَن قٍ قَنيِ نَن نَبَشِ ﭑ بّ ﭑ مَلِقٍ رَ ﭑ مَ تْورّ كُي.
\p 
\v 15 قِلِثِكَيٍ، وٌ عَ كٌلٌن، كَبِ ﭑ نَشَ كٍلِ مَسٍدٌن بْشِ عِنيِلَ عِسَ كَوَندِ تِقٍ رَ، دَنشَنِيَتْي حَمَ يٌ مُ ﭑ مَلِ قٍ ندٍ رَ قٌ وٌ تَن.
\v 16 وٌ تَن نَن نَ رَبَشِ. وٌ نَشَ ﭑ مَلِ سَنيَ قِرِن ﭑ نُ نَ تّسَلٌنِكِ تّمُي نَشّ.
\v 17 ﭑ مُ نَ سٍسٍ قٍنقٍ ﭑ يّتّ بّ. عَ شْلِ ﭑ مَ وٌ تَن نَن شَ قٍ قَنيِ سْتْ عَ كُي.
\v 18 ﭑ هَيِ نَ نَشَن بِرِن مَ، ﭑ بَرَ عَ سْتْ. وٌ نَشَن نَسَنبَشِ ﭑ مَ عٍثَقٌرٌدِتٍ سَابُي رَ، عَ بَرَ ﭑ وَ سَ هَن عَ بَرَ دَنفِ عَ عِ. نَ سّرّشّ بَرَ رَقَن عَلَ مَ، عَ عَ كّنّن.
\v 19 ﭑ مَرِفِ عَلَ قَمَ قٍ بِرِن قِدٍ وٌ مَ وٌ هَيِ نَ نَشَن مَ. قّيرّ بِرِن نَ عَ تَن نَن يِ رَ، عَ نَ بِرِن نَبَمَ عَ شَ مِشِ سُفَندِشِ عِسَ نَن سَابُي رَ.
\v 20 عَلَ تَنتُ، عَلَ تَنتُ. عَلَ نَشَن قِندِ وٌن بَبَ رَ، وٌن عَ تَنتُمَ نّ هَن دُنِحَ رَحْنيِ.
\p 
\v 21 وٌ شَ عِسَ شَ سّنِيّنتْي بِرِن شّيبُ.
\v 22 سّنِيّنتْي بِرِن نَشٍيٍ نَ ﭑ سّيتِ مَ، عَ فبٍنفبٍنيِ نَشٍيٍ وَلِقٍ مَنفّ سٍسَرٍ شْنيِ، عٍ بَرَ وٌ شّيبُ.
\v 23 مَرِفِ عِسَ، عَلَ شَ مِشِ سُفَندِشِ، شَ هِننّ وٌ بِرِن نَ.
