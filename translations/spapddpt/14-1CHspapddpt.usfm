\v 23 \w Pero|strong="H3588"\w* \w David|strong="H1732"\w* \w no|strong="H3808"\w* \w tomó|strong="H5375"\w* \w el|strong="H3588"\w* censo \w de|strong="H3588"\w* \w los|strong="H1121"\w* \w que|strong="H3588"\w* \w eran|strong="H3808"\w* menores \w de|strong="H3588"\w* 20 \w años|strong="H8141"\w*, \w por|strong="H3588"\w* \w cuanto|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* dijo \w que|strong="H3588"\w* \w Él|strong="H3588"\w* multiplicaría \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* \w como|strong="H3588"\w* las \w estrellas|strong="H3556"\w* del \w cielo|strong="H8064"\w*.   
