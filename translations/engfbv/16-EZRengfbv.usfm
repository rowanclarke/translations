\v 10 \w In|strong="H4430"\w* this way \w they|strong="H1768"\w* \w can|strong="H1768"\w* \w offer|strong="H7127"\w* \w sacrifices|strong="H5208"\w* \w that|strong="H1768"\w* \w are|strong="H1768"\w* \w acceptable|strong="H5208"\w* \w to|strong="H4430"\w* \w the|strong="H1768"\w* God \w of|strong="H4430"\w* \w heaven|strong="H8065"\w*, \w and|strong="H4430"\w* \w pray|strong="H6739"\w* \w for|strong="H1768"\w* \w the|strong="H1768"\w* \w lives|strong="H2417"\w* \w of|strong="H4430"\w* \w the|strong="H1768"\w* \w king|strong="H4430"\w* \w and|strong="H4430"\w* \w his|strong="H1768"\w* \w sons|strong="H1123"\w*.
\v 11 Further \w I|strong="H4481"\w* declare \w that|strong="H1768"\w* if \w any|strong="H3606"\w* man interferes \w with|strong="H5648"\w* \w this|strong="H1836"\w* \w decree|strong="H2942"\w*, \w a|strong="H3068"\w* beam \w is|strong="H1768"\w* \w to|strong="H5922"\w* \w be|strong="H1005"\w* ripped \w from|strong="H4481"\w* \w his|strong="H5922"\w* \w house|strong="H1005"\w* \w and|strong="H1005"\w* \w set|strong="H7761"\w* \w in|strong="H5922"\w* \w the|strong="H3606"\w* ground, \w and|strong="H1005"\w* \w he|strong="H1768"\w* \w is|strong="H1768"\w* \w to|strong="H5922"\w* \w be|strong="H1005"\w* \w impaled|strong="H2211"\w* \w on|strong="H5922"\w* top \w of|strong="H4481"\w* \w it|strong="H5922"\w*. \w His|strong="H5922"\w* own \w house|strong="H1005"\w* \w shall|strong="H3606"\w* \w be|strong="H1005"\w* turned into \w a|strong="H3068"\w* pile \w of|strong="H4481"\w* rubble \w for|strong="H5922"\w* disobeying \w this|strong="H1836"\w* \w decree|strong="H2942"\w*.
\v 12 May God \w who|strong="H1768"\w* chose \w the|strong="H3606"\w* city \w of|strong="H1005"\w* \w Jerusalem|strong="H3390"\w* \w as|strong="H3606"\w* \w the|strong="H3606"\w* place \w where|strong="H1768"\w* \w he|strong="H1768"\w* would \w be|strong="H1005"\w* honored, \w destroy|strong="H2255"\w* \w any|strong="H3606"\w* \w king|strong="H4430"\w* \w or|strong="H4430"\w* \w people|strong="H5972"\w* \w who|strong="H1768"\w* try \w to|strong="H2942"\w* \w alter|strong="H8133"\w* \w what|strong="H1768"\w* \w I|strong="H1768"\w* \w have|strong="H7761"\w* said \w or|strong="H4430"\w* \w who|strong="H1768"\w* \w destroy|strong="H2255"\w* \w this|strong="H1791"\w* \w Temple|strong="H1005"\w*. \w I|strong="H1768"\w*, \w Darius|strong="H1868"\w*, \w issue|strong="H7761"\w* \w this|strong="H1791"\w* \w decree|strong="H2942"\w*. Let it \w be|strong="H1005"\w* faithfully \w carried|strong="H5648"\w* \w out|strong="H5648"\w*.
\p 
