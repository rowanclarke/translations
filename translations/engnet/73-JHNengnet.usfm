\p \w He|strong="G2532"\w* \w found|strong="G2147"\w* \w in|strong="G1722"\w* \w the|strong="G1722"\w* \w temple|strong="G2413"\w* courts \w those|strong="G3588"\w* \w who|strong="G3588"\w* \w were|strong="G3588"\w* \w selling|strong="G4453"\w* \w oxen|strong="G1016"\w* \w and|strong="G2532"\w* \w sheep|strong="G4263"\w* \w and|strong="G2532"\w* \w doves|strong="G4058"\w*, \w and|strong="G2532"\w* \w the|strong="G1722"\w* \w money|strong="G2773"\w* \w changers|strong="G2773"\w* \w sitting|strong="G2521"\w* \w at|strong="G1722"\w* tables.  
