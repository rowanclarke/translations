\id JUD Ika New Testament 2009 
\h Judu 
\toc1 Ẹkụkwọ-Ozi Judu De 
\toc2 Judu 
\toc3 Jud 
\mt2 Ẹkụkwọ-Ozi 
\mt1 Judu 
\mt2 De 
\c 1  
\p  
\v 1 Mmẹ wụ Judu de ẹhụhụọ-ozini. M wụ igbọn Jesu Kristi. M wụzịkwọ nwẹnẹ Jemisi. M rị e dejẹnni ndị ahụn wẹ kpọ, hụn rị Chuku-Nẹdi obi, hụn Jesu Kristi dọnmẹ:  
\v 2 omikẹn, udọn lẹ ihiẹn-ọsụsụọ ya rịnị ọnụ mmagi-mmagi. 
\s1 Lụnị Nị Ụzọ-Jesu Ọgụn 
\p  
\v 3 Ndị rị m obi, o te dụka m nị m de ni ụnụ banyeni nzụọfụha hụn ẹnyi ile nwọn, kanị a hụn m'a nwan n'ọ rị mkpa nị m deni ụnụ hụn m'e gi kasị ọnụ obi, nị ọnụ shikẹnmẹ ọnwụn chẹdọn Ụzọ nke okukwe hụ hụn Osolobuẹ wegụụ che ẹka ndị nke ẹ. 
\s1 Ndị A Kuzi Ntụ A Banhangụọ 
\p  
\v 4 Makẹni, o nwẹghọ ndị ghalẹni a tụ egun Osolobuẹ hụn gigụụ nzuzue banhan imẹ ẹnyi. Ndịnị e gbehutọgụọ ozi ẹfọma Osolobuẹ, kẹni wẹ gi ẹ kpumẹ eje-obibi wẹ. O tekẹmẹkẹ wẹ detọ ikpe-ọmụma hụn rịnị nị wẹ imẹ Ẹhụhụọ-nsọ. Ndịnị ara gbayedẹ Jizọs' Kraịstị hụn ịya sụọ wụ Di-nwọnni-ẹnyi lẹ Onyẹ-nwọnni-ẹnyi. 
\s1 Osolobuẹ A Marịngụọ Ye Ndị Njọ Afụnfụn 
\p  
\v 5 M chọ nị m nyanhan nị ụnụ ihiẹn ndịnị, ọsụọn'a nị ụnụ a marịngụọ wẹ ọhụnma-ọhụnma. M chọ nị m nyanhan nị ụnụ kẹ Di-nwọnni-ẹnyi dọn gha alị Ijiptu zụọpụha ndị Izrẹlụ, kanị, omẹgụụ, ọ nọ tikpọ ndị hụn kwerilẹni. 
\p  
\v 6 Nyanhanzịkwọ nị ihiẹn mẹ ndị mmọn-ozi hụ te rị nsọ hụn nọdịlẹni ebe wẹ sị wẹ nọdị, hụn la ọnọdị wẹ tọ: nyanhan nị nị Osolobuẹ e kẹngụọ wẹ nwan ẹgbụn itẹbitẹ tọ imẹ eje ishi, e che okinkin-ikpe hụn jẹnkọ d'a rị okẹn Ụhụọhịn hụ. 
\p  
\v 7 Nyanhan nị ihiẹn mẹ eje-alị ndị ahụn wụ Sọdọmụ lẹ Gomọra lẹ obodo ndị ọzọ hụn nọkunmẹ ni wẹ. Ndị rị imẹ alị ndị hụ mẹ kẹ ndị mmọn-ozi hụ—bu enwẹn wẹ che imẹ ughẹrẹ lẹ ụrụ, ya wẹ nọ narịn afụnfụn ọkụn-itẹbitẹ. Wẹ nọ wụrụ ihiẹn wẹ gi a dọ ịhịan ẹka-ntịn. 
\s1 Enwẹn Wẹ Kẹ W'e E Lee, E Ledan Ọkịkị 
\p  
\v 8 Bụ ẹrịra kẹ ndị nkuzi-ụghanị gi nwan a hụnsọnmẹ ọhụn a han wẹ e mẹ ihiẹn ẹhụ wẹ gi a rụhụ, e legberi ọkịkị, e kutọ ndị ọghọ rị ẹhụ. 
\p  
\v 9 Kanị, Maịkẹlụ hụn wụ onyẹ-isi ndị mmọn-ozi e mẹdẹni ẹnịna ogẹn o gi sọn Ekwensụ zụọ ozun Mozizi: egun Osolobuẹ anịn'a kutọ Ekwensụ—ihiẹn ọ gwa Ekwensụ wụ, “Di-nwọnni-ẹnyi a jụgbọ ị!” 
\p  
\v 10 Kanị ndịnị e kutọ ihiẹn ọwụlẹ wẹ ghọtalẹni. Wẹ nọhụ kẹ anụ-ọfịa nwọnlẹni uche, w'a ra leban ihiẹn ẹnya—bụ hụn wẹ ghọtahụ wẹ lebanlẹni ẹnya, ịya e tikpọ wẹ. 
\s1 A Rịzịolẹ Wẹ Ẹjẹ-ọnọdị 
\p  
\v 11 Okẹn nsọngbu rịnị wẹ! E sọnmẹgụọ wẹ ụzọ Keni ogbu ọchụ; e gigụọ wẹ ifiri erere la enwẹn wẹ tọnị mmẹfie Balam egho a sụọ; e nupụgụọ wẹ isi kẹ Kora; a na wẹ ntikpọ kẹ ịya, makẹni Osolobuẹ k'e tikpọ wẹ.  
\v 12 Ntụpọ kẹ ndịnị wụ ebe ụnụ n'e rigbama Oriri ihiẹn-ọsụsụọ ụnụ; egun arịzị wẹ ẹnya ebe wẹ n'e sọn ụnụ e ri—ndị-ndu rị e lepụ enwẹn wẹ sụọ ẹnya kẹ wẹ wụ! Orukpu ufere bukọ ghalẹni e zue mirin kẹ wẹ wụ; osisi ghalẹni a mị mkpụrụ ogẹn wẹ gi a ghọ mkpụrụ, osisi wẹ huepụ, hụn nwụnhụnnị, nwụnhụnchanrịn!  
\v 13 Wẹ nọhụ kẹ eje ebiri-ohimin, ihiẹn ifẹnrẹn wẹ rị a gbọshi elu kẹ ụfọfọ ebiri-ohimin; kokisẹ ụzọ ohu ghalẹni e ru kẹ wẹ wụ, hụn Osolobuẹ kwademẹtọnị eje-ishi itẹbitẹ! 
\s1 Ikpe-ọmụma Hụn Rị E Cheni Wẹ 
\p  
\v 14 Ẹnọkụ, hụn rị agbọ nke ẹsa—wẹ gha ẹka Adam gụnma—e bugụọ amụma tọnị wẹ: ọ sị, 
\q1 “Lee ẹ, 
\q1 Di-nwọnni-ẹnyi lala 
\q2 ya lẹ ndị nsọ a nnụ ole-lẹ-ole. 
\q1  
\v 15 Ọ lala 
\q2 d'e kin onyẹ ọwụlẹ ikpe, 
\q2 d'a ma wẹ ile ikpe— 
\q1 ikpe eje-ihiẹn ile wẹ gi eje-agụngụn wẹ mẹ 
\q1 lẹ eje-oku ile jọgbu enwẹn ẹ, 
\q2 hụn ndị-njọ ghalẹni a gbaye Osolobuẹ 
\q2 gi kuja oku ẹ!” 
\s1 Eje-Agụngụn Wẹ 
\p  
\v 16 Ogẹn ile kẹ ndịnị gi e dẹnwịnnwịn; w'a ra kinbehi ikpe; w'e mẹsọnmẹ eje-ihiẹn ndị rị a gụnnị wẹ; w'e kukarị enwẹn wẹ, e gi ọnụ-ọma a tụnarịn ịhịan ihiẹn wẹ. 
\s1 Mkpịnsịn-ẹka Lẹ Ndụnmọdụn 
\p  
\v 17 Kanị, o mẹ nke ụnụ umunẹ m, nyanhankwọ nị ihiẹn ndị-ozi ahụn pụ-ichẹn Nna-ẹnyi wụ Jizọs' Kraịstị tumẹ gwatọ ọnụ.  
\v 18 Wẹ gwa ụnụ nị “Ndị-ẹmụ k'a pụha ogẹn ịkpazụụn, ndị k'e mẹsọnmẹ eje-ihiẹn rị a gụnnị wẹ.”  
\v 19 Uwẹ wụ ndịnị ihiẹn-ụwa rị ẹnya, hụn nwọnlẹni Mmọn-nsọ, ndị hụn e buhẹ nkebe. 
\p  
\v 20 Kanị, nke ọnụ umunẹ m, e mẹ ni nị ụnụ e sue imẹ Okukwe ahụn rịchanrịn nsọ ọnụ rị e sọn, e sue kẹ ụlọ wẹ n'a tụn; e mẹ ni ekpere kẹ Mmọn-nsọ dọn chọ.  
\v 21 E dọnmẹ ni enwẹn ụnụ hụn ụnụ e gi rịsọnmẹ ndị ihiẹn wẹ a sụọ Osolobuẹ, kẹ ụnụ dọn rị e che omikẹn Di-nwọnni-ẹnyi wụ Jizọs' Kraịstị, hụn k'e wẹhẹ ni ọnụ ndụn itẹbitẹ. 
\p  
\v 22 E mẹ ni ni ndị obi-ẹbụọ omikẹn,  
\v 23 ọnụ a dọkpụnpụha ndị ọzọ imẹ ọkụn hụ kẹni ụnụ gi ẹ zụọfụha wẹ. Nke ndị ọzọ, e gi ni egun e mẹ ni wẹ omikẹn—ka zedẹ ni izize ẹwuru wẹ yi hụn ẹhụ wẹ mẹrụgụụ. 
\s1 Ekpere Ịja-mma 
\p  
\v 24 Nke Osolobuẹ, onyẹ hụ hụn k'e ri-ẹka kwọndọn ụnụ makẹ ọnụ gha a dan, mẹ ọnụ wụrụ ndị nwọnlẹni ntụpọ, ụnụ e gi ịghọghọ turu ihun ẹ ebẹhụ Ọghọ rị,  
\v 25 Onyẹ hụ ịya sụọ wụ Chuku, Onyẹ nzụọpụha ẹnyi, ọghọ ya rịn'a ghahanị Jizọs' Kraịstị Di-nwọnni-ẹnyi—ọghọ lẹ ikpẹn lẹ ikẹn lẹ ọkịkị; k'ọ rịn'a nị ogẹn d'e bidọn, ya rịn'a kikẹnni lẹ jẹnrin ejẹn! Isẹẹ.