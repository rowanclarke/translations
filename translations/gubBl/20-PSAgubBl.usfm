\id PSA - Guajajara Bible -Brazil 2007 (DBL 2013)
\h ZEGAR HAW
\toc1 Zegar haw
\toc2 Salmos
\toc3 Sl
\mt1 ZEGAR HAW
\c 1
\ms1 PAPE PITÀI HAW
\mr ZEGAR HAW 1-41
\s1 Turywete haw azeharomo har
\q1 
\v 1 Hurywete putar
\q1 Ikatu 'ym ma'e wapureruze'egaw rehe uzekaiw 'ym ma'e a'e wà nehe.
\q1 Hurywete putar Tupàn iputar 'ymar wazàwe wiko 'ym ma'e a'e wà nehe no.
\q1 Hurywete putar Tupàn rehe uze'eg urywahyahy ma'e wanehe we oho 'ym ma'e a'e wà nehe no.
\q1 
\v 2 Tupàn Tuweharupi Wiko Ma'e ze'eg umurywete kar a'e teko a'e wà.
\q1 Ima'enukwaw a'e ze'eg rehe 'aromo wà, pyhaw wà no.
\q1 
\v 3 A'e teko wiko ywyra ài wà. Ma'e'yw yrykaw iwyr rehe har ài wanekon wà.
\q1 I'a haw 'ar mehe,
\q1 Huwer nuxinig kwaw.
\q1 A'e teko hemiapo ikatu upaw rupi wà.
\b
\q1 
\v 4 Ikatu 'ym ma'e nuiko kwaw wazàwe wà.
\q1 Nuzawy kwaw arozpirer uxinig ma'e ywytu hemiraha wà.
\q1 
\v 5 A'e rupi, zepykaw 'ar mehe nehe, Tupàn uzepyk putar ikatu 'ym ma'e iapo har wanehe a'e wà nehe.
\q1 Upyta putar muite Tupàn heruzar har wanuwi wà nehe.
\q1 
\v 6 Aze teko weruzar katu Tupàn Tuweharupi Wiko Ma'e a'e wà, Tupàn weruze'eg a'e teko a'e wà. Uzapo ikatu ma'e wanupe.
\q1 Ikatu 'ym ma'e uhem putar iaiw paw pe wà nehe. Oho putar màno haw pe iahykaw rehe wà nehe.
\c 2
\s1 Tuwihawete Tupàn hemixak kwer a'e
\q1 
\v 1 — Xiàmàtyry'ym Tupàn zane nehe, i'i teko uzeruzar 'ym ma'e wà. Màràzàwe tuwe uze'eg nezewe wà.
\q1 Màràzàwe tuwe ima'enukwaw e iàmàtyry'ymaw rehe wà.
\q1 
\v 2 Wanuwihawete uzemuàgà'ym wà.
\q1 Waneruze'egar umume'u Tupàn Tuweharupi Wiko Ma'e iàmàtyry'ym àwàm wà.
\q1 — Xiàmàtyry'ym tuwihawete Tupàn hemixak kwer nehe, i'i uzeupeupe wà no.
\b
\q1 
\v 3 Uze'eg nezewe wà.
\q1 — Wiko zanezar romo a'e wà.
\q1 Ximumaw wakàgaw nehe. Ximumaw zanereruze'egaw nehe, i'i uzeupeupe wà.
\q1 
\v 4 Wenaw ywak rehe har rehe wapyk mehe,
\q1 Zanezar upuka wanehe a'e, wanehe uze'eg urywahyahy no.
\q1 
\v 5 Na'e wikwahy kury, wanupe uze'eg pà kury.
\q1 Umukyze kar wekwahy haw pupe wà.
\q1 
\v 6 Nezewe i'i Tupàn. — Amuapyk kar tuwihawete heremiruze'eg ihe, henaw rehe ihe,
\q1 Xiàw pe ihe, ywytyr heremimonokatu karer rehe ihe, i'i Tupàn.
\b
\q1 
\v 7 Uze'eg a'e tuwihawete kury. — Amume'u putar Tupàn Tuweharupi Wiko Ma'e hemimume'u kwer ihe nehe.
\q1 Nezewe i'i Tupàn Tuweharupi Wiko Ma'e ihewe. — Ereiko hera'yr romo ne.
\q1 Kutàri aiko neru romo ihe.
\q1 
\v 8 Aze erenoz ihewe nehe, amono putar teko ywy nànànar newe ihe wà nehe.
\q1 Ywy paw nema'e romo wiko putar nehe no.
\q1 
\v 9 Erezuhazuhaw putar ywyràihàg itaper iapo pyrer pupe ne wà nehe.
\q1 Erezukazuka putar ywy'a ài ne wà nehe, i'i Tupàn ihewe, i'i tuwihawete.
\b
\q1 
\v 10 Peinu heze'eg kury, tuwihawete wà.
\q1 Pezekaiw katu ko ze'eg rehe nehe, pureruze'eg ma'e wà.
\q1 
\v 11 Pemuwete katu Tupàn Tuweharupi Wiko Ma'e pekyze haw rupi nehe.
\q1 Peryryryryz henataromo pepenàràg rehe peapyk pà nehe.
\q1 
\v 12 Aze napezapo kwaw a'e ma'e nehe, wikwahy putar na'arewahy nehe. A'e rupi pemàno putar nehe.
\q1 — Urepyro pe nehe, aze amo i'i Tupàn pe wà nehe, hurywete putar wà nehe.
\c 3
\s1 Tupàn pe ze'egaw upytywà haw henoz taw
\d Wa'yr Àmixàràw wi uzàn mehe Tawi uzapo 'aw zegar haw a'e.
\q1 
\v 1 O Tupàn Tuweharupi Wiko Ma'e.
\q1 Heta tetea'u heàmàtyry'ymar wà. Hekutyr uwak ma'e heta tetea'u wà.
\q1 
\v 2 Uze'eg uzeupeupe herehe wà.
\q1 — Tupàn nupytywà kwaw tuwihawete a'e nehe, i'i nerehe uze'eg pà wà.
\b
\q1 
\v 3 U'yw wi purumimaw upyro zauxiapekwer màno haw wi a'e wà. Nezewegatete, ne Tupàn Tuweharupi Wiko Ma'e, hepyro katu 'ymaw wi ne.
\q1 Ereityk heàmàtyry'ymar ne wà.
\q1 Hemukàg wi pe ne no.
\q1 
\v 4 — Ezur hepytywà pà nehe, a'e Tupàn Tuweharupi Wiko Ma'e pe.
\q1 Wenaw wi ywytyr ikatuahy ma'e wemimonokatu kwer wi uwazar heze'eg ihewe a'e.
\b
\q1 
\v 5 A'aw ihe. Aker katu ihe no.
\q1 Ame'e wi heker ire, ta'e Tuweharupi Wiko Ma'e uzekaiw katu herehe a'e xe.
\q1 
\v 6 Heta tetea'u heàmàtyry'ymar wà. Nakyze kwaw wanuwi ihe.
\q1 Umàmàn heywyr herehe ipuruzuka wer pà wà.
\b
\q1 
\v 7 Ezur nehe, Tupàn Tuweharupi Wiko Ma'e. Hepyro nehe, hezar.
\q1 Ereàmàtyry'ym heàmàtyry'ymar ne wà.
\q1 Eremuigo kar ikatu 'ym ma'e ikàg 'ym ma'e romo ne wà. Eremumaw wakàgaw no.
\q1 
\v 8 Ne ereiko waneitykar romo ne.
\q1 Emono neze'egatu teko neremiaihu wanehe nehe, o Tupàn Tuweharupi Wiko Ma'e.
\c 4
\s1 Tupàn hepytywà har a'e
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 O Tupàn hemukàg kar har ne,
\q1 Ewazar heze'eg nerenoz mehe nehe.
\q1 Zawaiw katu hereko awer ihewe. Hepytywà pe a'e 'ar mehe.
\q1 Hepuhareko pe nehe. Einu newe heze'eg mehe nehe.
\b
\q1 
\v 2 Pe, awa upuner ma'e, pe. Màràn 'ar pemumaw putar herehe peze'eg zemueteahy pà nehe. Awa upuner ma'e wà.
\q1 Màràn 'ar pemumaw putar heityk pyrer iamutar pà nehe, herehe penemu'em pà nehe,
\q1 Ze'eg azeharomo har 'ym imume'u pà herehe nehe.
\b
\q1 
\v 3 Pema'enukwaw ko ma'e rehe nehe. Tupàn Tuweharupi Wiko Ma'e wereko katu uzehe uzeruzar katu ma'e a'e wà.
\q1 Herenu a'e, aze aze'eg izupe ihe.
\q1 
\v 4 Peryryryryz pekyze pà ikatu 'ym ma'e iapo re pepytu'u pà nehe.
\q1 Pema'enukwaw penemiapo kwer rehe nehe. Pe zutyka'i peker haw pe peneko mehe,
\q1 Pema'enukwaw ikatu 'ym ma'e penemiapo kwer rehe nehe.
\q1 
\v 5 Pemono ma'e Tupàn pe ize'eg rupi nehe.
\q1 Pezeruzar Tupàn Tuweharupi Wiko Ma'e rehe nehe.
\b
\q1 
\v 6 Heta tetea'u teko ko ma'e imume'u har wà.
\q1 — Emur wi neze'egatu urerehe nehe, Tupàn Tuweharupi Wiko Ma'e.
\q1 — Ikatu ma'e, ere urewe urerehe neme'e mehe nehe, i'i izupe wà.
\q1 
\v 7 Temi'u tetea'u hereko har hurywete a'e wà.
\q1 Herurywete wera'u wanuwi ihe, ta'e ne hemurywete kar pe ne xe.
\b
\q1 
\v 8 He'aw mehe aker zeàmàtyry'ym 'ymaw rehe ihe.
\q1 Ta'e ne, o Tupàn Tuweharupi Wiko Ma'e, hemuigo kar pe muite ikatu 'ymaw wi ne xe.
\c 5
\s1 Tupàn pe ze'egaw uzemonokatu haw
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 O Tupàn Tuweharupi Wiko Ma'e. Einu heze'eg nehe.
\q1 Ezeapyaka katu hekuhem mehe nehe.
\q1 
\v 2 Heruwihawete, Hezar. — Hepytywà pe nehe, a'e newe. A'e rupi hepytywà pe nehe,
\q1 Ta'e aze'eg newe ihe xe, Tupàn.
\q1 
\v 3 Ku'em mehe erenu heze'eg mehe ne.
\q1 Kwarahy ihem mehe aze'eg newe.
\q1 Àro heze'eg neremiwazar ràm ihe.
\b
\q1 
\v 4 Nereiko kwaw Tupàn ikatu 'ymaw iputar har romo.
\q1 Neremuigo kar kwaw ikatu 'ym ma'e nezepyr ne wà.
\q1 
\v 5 Neremuigo kar kwaw amo wanuwi wiko wera'u ma'e neruwake ne wà.
\q1 Naneakatuwawahy kwaw ikatu 'ym ma'e iapo har wanehe.
\q1 
\v 6 Eremumaw hemu'em ma'e ne wà.
\q1 Puruzuka ma'e wà, hemu'em ma'e wà no, iro newe wà.
\b
\q1 
\v 7 Apuner katu pe neràpuz huwake
\q1 Hereixe haw rehe ihe, ta'e heamutar katu pe ne xe.
\q1 Apuner nerenataromo hepenàràg rehe heapykaw rehe ihe, nemuwete katu pà ihe,
\q1 Neràpuzuhu imonokatu pyrer kutyr heme'e pà ihe no.
\q1 
\v 8 O Tupàn Tuweharupi Wiko Ma'e, hepytywà pe neremiapo putar haw iapo mehe nehe.
\q1 Emukatu nerape ihewe nehe.
\q1 Tuwe heàmàtyry'ymar wexak nereko haw herehe we wà nehe.
\q1 
\v 9 Ni amo nupuner kwaw waze'eg rehe uzeruzar haw rehe wà.
\q1 Xo purumumaw paw rehe zo ima'enukwaw wà.
\q1 — Nekatuahy, i'i mua'u amo pe wà.
\q1 Hemu'em upytu'u 'ym pà wà. — Xiuka nehe, i'i wiwi uzeupe wà.
\q1 
\v 10 Emume'u wanehe nezepyk àwàm nehe, o Tupàn.
\q1 Ezepyk wanehe nehe. Ipurapo wer ikatu 'ym ma'e rehe amo wanupe wà. Tuwe wanemimutar weraha iaiw paw pe wà nehe.
\q1 Emuhem kar nereko haw wi ne wà nehe,
\q1 Ta'e uzawy tetea'u neze'eg a'e wà xe.
\q1 Na'ipureruzar wer kwaw nerehe wà.
\b
\q1 
\v 11 Neruwake uzeàmim ma'e hurywete putar wà nehe.
\q1 Uzegar putar tuweharupi urywete haw rehe wà nehe, ta'e ne erepyro ne wà xe.
\q1 Hurywete neamutar katu har wà.
\q1 
\v 12 Ne, o Tupàn Tuweharupi Wiko Ma'e ne, eremono neze'egatu teko nereruzar har wanehe ne.
\q1 Nekatu haw nuzawy kwaw u'yw wi wamimaw wanupe.
\c 6
\s1 Ima'eahy ma'e uze'eg Tupàn pe
\d Zegar har Tawi hemiapo kwer
\q1 
\v 1 O Tupàn Tuweharupi Wiko Ma'e, emume'u zo heremiapo kwer ikatu 'ym ma'e nekwahy mehe nehe.
\q1 Herehe ezepyk zo nekwahy haw uhua'u ma'e rupi nehe.
\q1 
\v 2 Hepuhareko pe nehe, ta'e nahekàg kwaw ihe xe.
\q1 Hemukatu pe nehe, ta'e hema'eahy ihe xe.
\q1 
\v 3 Herekwe uzemumikahy a'e.
\q1 O Tupàn, ma'e 'ar mehe erezur putar hemukatu pà nehe.
\b
\q1 
\v 4 Ezur hepyro pà màno haw wi nehe, o Tupàn Tuweharupi Wiko Ma'e.
\q1 Heamutar katu pe ne. A'e rupi hepyro hemàno àwàm wi nehe.
\q1 
\v 5 Ta'e umàno ma'e kwer wapyta haw pe har na'ima'enukwaw kwaw nerehe wà xe.
\q1 Ni amo a'e pe har nupuner kwaw nekatu haw imume'u haw rehe wà.
\q1 
\v 6 Hekene'o hezai'o re ihe.
\q1 Tuweharupi pyhaw herupaw tynehem herehaykwer pupe a'e.
\q1 Hezai'o haw umuàkym heàkàg iwy pe har.
\q1 
\v 7 Heàmàtyry'ymar ipuruzuka wer herehe wà.
\q1 A'e rupi hereha hezun hezai'o tetea'u haw rehe.
\q1 A'e rupi zawaiw katu ma'e hexakaw ihewe.
\b
\q1 
\v 8 Pe ikatu 'ym ma'e iapo har wà, petyryk ihewi nehe.
\q1 Tupàn Tuweharupi Wiko Ma'e herenu hezai'o mehe a'e.
\q1 
\v 9 — Hepytywà pe nehe, aze a'e izupe, wenu heze'eg a'e.
\q1 Uzekaiw heze'eg rehe.
\q1 
\v 10 Heàmàtyry'ymar imaranugar putar wà nehe. Ukyzeahy putar wà nehe no.
\q1 Na'arewahy uzàn putar wà nehe. Nukwaw kwaw wemiapo ràm wà nehe.
\c 7
\s1 Tupàn pe ze'egaw ikatu haw henoz taw
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 O Tupàn Tuweharupi Wiko Ma'e hezar, aexak hepyro haw nerehe we ihe.
\q1 Hepyro pe nehe. Hepyro pe ihewe ikatu 'ym ma'e rehe ipurapo wer ma'e paw wanuwi nehe.
\q1 
\v 2 Zàwàruhu iriàw her ma'e upyhyk wemiar ipei'ài'àg pà a'e wà.
\q1 Heàmàtyry'ymar ipurupyhyk wer herehe zàwàruhu ài wà. Hepyhyk kar pe zo wanupe nehe.
\q1 Tuwe naiko kwaw hepyro har hereko 'ymar romo nehe.
\b
\q1 
\v 3 O Tupàn Tuweharupi Wiko Ma'e, Hezar, aze wyzài ikatu 'ym ma'e iapo har romo aiko,
\q1 Tuwe heàmàtyry'ymar hepyhyk wà nehe. Aipo amo ikatu 'ym ma'e azapo ihe.
\q1 
\v 4 Aipo azapo ikatu 'ym ma'e hemyrypar wanupe.
\q1 Aipo azepyk e amo heàmàtyry'ymar rehe.
\q1 
\v 5 Aze agwer ma'e iapo har romo aiko, tuwe heàmàtyry'ymar ur heraikweromo wà nehe.
\q1 Tuwe hepyhyk wà nehe. Tuwe hereityk ywy rehe hezuka re wà nehe.
\q1 Tuwe ywy imuku'i pyrer rehe hemàno re hereityk wà nehe.
\b
\q1 
\v 6 O Tupàn Tuweharupi Wiko Ma'e, epu'àm nekwahy pà nehe.
\q1 Eho heàmàtyry'ymar wakwahy haw kutyr nehe.
\q1 Epu'àm hepytywà pà nehe,
\q1 Ta'e erezapo kar ikatu ma'e ne xe.
\q1 
\v 7 Emono'og teko ywy nànànar paw nezeywyr ne wà nehe.
\q1 Ereruze'eg ne wà nehe.
\q1 
\v 8 O Tupàn Tuweharupi Wiko Ma'e, ereiko teko paw wanemiapo kwer imume'u har romo ne.
\q1 Emume'u ikatu ma'e romo hereko haw nehe.
\q1 Ta'e naiko kwaw ikatu 'ym ma'e iapo har romo ihe xe. Ikatu ma'e romo aiko.
\q1 
\v 9 Emumaw ikatu 'ym ma'e wakatu 'ymaw nehe.
\q1 Emekuzar ikatu ma'e wanemiapo kwer nehe, wanupe nehe.
\q1 Ta'e ne Tupàn ne xe,
\q1 Teko wanemiapo kwer imume'u har ikatu ma'e romo ereiko ne xe. Eremume'u katu urema'enukwaw paw ne. Eremume'u katu ureremimutar no.
\b
\q1 
\v 10 Tupàn nuzuawy kwaw u'yw wi purumim ma'e a'e. Hemim a'e.
\q1 Upyro imunar 'ym ma'e hemu'em 'ym ma'e azeharomo har a'e wà.
\q1 
\v 11 Tupàn wiko teko wanemiapo kwer imume'u har ikatuahy ma'e romo a'e.
\q1 Tuweharupi umume'u teko ikatu 'ym ma'e iapo har wanehe uzepyk àwàm a'e.
\q1 
\v 12 Aze nuzemumikahy kwaw wemiapo kwer rehe wà nehe, aze nupytu'u kwaw ikatu 'ym ma'e iapo re wà nehe,
\q1 Tupàn umuaime putar utakihepuku nehe.
\q1 Umuàgà'ym uwyrapar u'yw imomor àwàm.
\q1 
\v 13 Upyhyk putar a'e puruzuka haw opo pe nehe.
\q1 Omomor u'yw tata iapo pyrer nehe.
\b
\q1 
\v 14 Ikatu 'ym ma'e ima'enukwaw wemiapo ràm ikatu 'ym ma'e rehe a'e wà. Pexak wanemiapo nehe.
\q1 Ipurapo wer xiroxiroahy àwàm rehe wà. Hemu'em wemiapo rehe wà no.
\q1 
\v 15 Teko uzapo ywykwar ywy pupe ohoete ma'e wemiar wapyhyk pà wà. Teko ikatu 'ym ma'e ipurupyhyk wer amo teko wanehe wà no.
\q1 A'e ae u'ar a'e ywykwar zàwenugar pupe wà no.
\q1 
\v 16 A'e rupi wakatu 'ymaw uzepyk uzar wanehe a'e wà.
\q1 Wapurukutukaw ukutuk uzar a'e wà no.
\b
\q1 
\v 17 Ihe amume'u Tupàn ikatu haw izupe ihe, ta'e uzepyk ikatu 'ym ma'e wanehe a'e xe.
\q1 Azegar Tupàn Tuweharupi Wiko Ma'e hezar ywate wera'u har pe ihe, ikatu haw rehe ihe.
\c 8
\s1 Tupàn ikàg wera'u haw, teko wakatu haw no
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 O Tupàn Tuweharupi Wiko Ma'e, Urezar ne.
\q1 Teko ywy nànànar wexak nehua'u haw wà.
\q1 Nekatu haw imume'u haw uhem ywak rehe.
\q1 
\v 2 Kwarearer uzegar nehua'u haw rehe wà. Te kwarera'i uzegar hehe wà no.
\q1 Erezapo tàpuztàtà nezepyro kar pà neàmàtyry'ymar wanuwi ne,
\q1 Eremumaw nerehe ipureityk wer ma'e ne.
\b
\q1 
\v 3 Ame'e ywak neremiapo kwer rehe. Ame'e zahy ywak rehe neremimupyta kwer rehe. Ame'e zahytata ywak rehe
\q1 Neremimupyta kwer wanehe. Wanehe heme'e mehe aze'eg nezewe hezeupe.
\q1 
\v 4 Màràzàwe tuwe nema'enukwaw teko wanehe. Na'ikàg kwaw wà.
\q1 Màràzàwe tuwe umàno ma'e ràm wanehe erezekaiw.
\b
\q1 
\v 5 Nezewe rehe we erezapo teko ikàg ma'e romo ne wà. Xo ne zo nekàg wera'u teko wanuwi ne.
\q1 Kàgaw eremono teko wanupe. Nuzawy kwaw tuwihawete wà.
\q1 
\v 6 Teko eremuigo kar ma'e neremiapo kwer paw wazar romo ne wà.
\q1 Ma'e paw wanuwi ikàg wera'u wà.
\q1 
\v 7 Wiko àràpuhàràn wazar romo wà no. Wiko tapi'ak wazar romo wà. Wiko miar wazar romo wà no.
\q1 
\v 8 Wiko wiràmiri wazar romo wà. Wiko pira wazar romo wà no. Wiko yryhu pupe har wazar romo paw rupi wà no.
\b
\q1 
\v 9 O Tupàn Tuweharupi Wiko Ma'e, urezar,
\q1 Teko ywy nànànar wexak nehua'u haw wà.
\c 9
\s1 Zegar haw Tupàn ikatuahy haw rehe har
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 O Tupàn Tuweharupi Wiko Ma'e, amume'u putar nekatu haw hepy'a pupe azeharomoete nehe.
\q1 Amume'u putar ma'e ikatuahy ma'e neremiapo kwer paw ihe wà nehe no.
\q1 
\v 2 Herurywete putar nerehe ihe nehe. Hemurywete kar putar pe ne nehe.
\q1 Azegar putar nekatu haw rehe nehe, Tupàn Ywate Wera'u Har.
\b
\q1 
\v 3 Nezur mehe heàmàtyry'ymar uzàn newi wà.
\q1 U'ar wà, umàno wà.
\q1 
\v 4 Ereiko pureruze'eg ma'e ikatu ma'e romo.
\q1 Ereapyk nerenaw rehe. Eremume'u katu teko wanemiapo kwer.
\q1 Hekatu haw eremume'u.
\q1 
\v 5 Eremume'u nerehe uzeruzar 'ym ma'e wanemiapo kwer. Eremumaw teko ikatu 'ym ma'e ne wà.
\q1 Teko na'ima'enukwaw pixik kwaw a'e teko wanehe wà nehe.
\q1 
\v 6 Ereityk tawhu zaneàmàtyry'ymar waneko haw ne wà.
\q1 Eremumaw tuwe ne wà.
\q1 Ni amo nuzapo wi kwaw wà nehe. Ni amo na'ima'enukwaw kwaw wanehe wà nehe.
\b
\q1 
\v 7 Tupàn Tuweharupi Wiko Ma'e wiko putar tuwihawete romo tuweharupi nehe, upytu'u 'ym pà nehe.
\q1 Wapyk uwenaw rehe. Umume'u teko wanemiapo kwer.
\q1 
\v 8 Tupàn weruze'eg ywy rehe har ukatu haw rehe wà.
\q1 Umume'u teko wanemiapo kwer iawy 'ym pà a'e.
\q1 
\v 9 Tupàn Tuweharupi Wiko Ma'e wiko purumimaw romo teko wanupe a'e, aze amo upuraraw kar ma'erahy wanupe a'e wà.
\q1 Uzekaiw wanehe ma'erahy ipuraraw mehe wà.
\q1 
\v 10 O Tupàn Tuweharupi Wiko Ma'e. Nekwaw har uzeruzar nerehe wà.
\q1 — Hepytywà pe nehe, aze amo i'i newe, nereityk kwaw ne wà xe.
\b
\q1 
\v 11 Pezegar Tupàn Tuweharupi Wiko Ma'e Zeruzarez pe har wanuwihawete ikatu haw rehe nehe.
\q1 Pemume'u hemiapo kwer teko ywy nànànar wanupe nehe.
\q1 
\v 12 Ta'e Tupàn ima'enukwaw ma'erahy ipuraraw har wanehe a'e xe.
\q1 Naheharaz kwaw wakuhem awer wanuwi a'e.
\q1 Uzepyk wanupe ma'erahy ipuraraw kar har wanehe no.
\b
\q1 
\v 13 O Tupàn Tuweharupi Wiko Ma'e, hepuhareko pe nehe.
\q1 Herehe iakatuwawahy 'ym ma'e upuraraw kar ma'erahy ihewe wà.
\q1 Herexak pe ipuraraw kar mehe ne. Hepyro pe hemàno haw wi.
\q1 
\v 14 A'e rupi apu'àm iteko Zeruzarez tawhu pe har wanenataromo ihe.
\q1 A'e rupi amume'u nekatu haw wanupe.
\q1 Herurywete ta'e hepyro pe màno haw wi ne xe.
\b
\q1 
\v 15 Teko nerehe uzeruzar 'ym ma'e uzapo ywykwar teko watym àwàm romo wà.
\q1 A'e ae u'ar ipupe wà. Uzapo miar zuka haw zàwenugar wà. A'e re miar zuka haw upyhyk uwapo arer wà.
\q1 
\v 16 Teko ukwaw Tupàn Tuweharupi Wiko Ma'e a'e wà, ta'e umume'u katu teko wanemiapo kwer a'e xe.
\q1 Ikatu 'ym ma'e u'ar wemiapo kwer miar zuka haw zàwenugar pupe a'e wà.
\q1 
\v 17 Ikatu 'ym ma'e a'e wà, Tupàn iputar 'ymar upaw rupi a'e wà no,
\q1 Oho putar umàno ma'e kwer wapyta haw pe wà nehe.
\b
\q1 
\v 18 Teko heharaz hemetarer 'ym ma'e wanuwi wà. Amo 'ar mehe amo ima'enukwaw putar wanehe wà nehe.
\q1 Ma'erahy ipuraraw har nuàro kwaw upyro àwàm ko 'ar rehe wà. Amo 'ar mehe uhem putar wapyro àwàm wà nehe.
\q1 
\v 19 Epu'àm o Tupàn Tuweharupi Wiko Ma'e.
\q1 Emupytu'u kar teko neàmàtyry'ym ire ne wà nehe.
\q1 Emuapyk kar nerehe uzeruzar 'ym ma'e nerenataromo ne wà nehe. Emume'u wanemiapo kwer nehe. Ezepyk ikatu 'ym ma'e wanehe nehe.
\q1 
\v 20 O Tupàn Tuweharupi Wiko Ma'e, emukyze kar a'e teko ne wà nehe.
\q1 Teko romo zutyka'i wanekon wà. Na'ikàg kwaw ne ài wà. Ekwaw kar wakàg 'ymaw wanupe nehe.
\c 10
\s1 Ze'egaw Tupàn ikatu haw henoz taw
\q1 
\v 1 O Tupàn Tuweharupi Wiko Ma'e, màràzàwe tuwe ereiko muite urewi.
\q1 Màràzàwe tuwe erezeàmim urewi ma'erahy ipuraraw mehe.
\q1 
\v 2 — Aiko wera'u amo wanuwi ihe, i'i ikatu 'ym ma'e wà. Uzapo ikatu 'ym ma'e wà, ma'e hereko 'ymar wanupe wà. Wanemu'emaw nuzuawy kwaw miar zuka haw.
\q1 Tuwe u'ar wemiapo kwer miar zuka haw zàwenugar pupe wà nehe.
\b
\p 
\v 3 Iaiw ma'e uze'egatu wemimutar ikatu 'ym ma'e rehe wà.
\q1 — Na'ikàg kwaw a'e, i'i teko amo wanehe imunar ma'e wà, Tupàn Tuweharupi Wiko Ma'e rehe uze'eg pà wà.
\q1 Uze'eg zemueteahy hehe wà.
\q1 
\v 4 Awa ikatu 'ym ma'e nuzekaiw kwaw Tupàn rehe.
\q1 — Aiko wera'u amo wanuwi, i'i.
\q1 A'e rupi — Tupàn na'ikàg kwaw a'e, i'i uzeupe.
\q1 
\v 5 Aze awa iaiw ma'e uzapo amo ma'e a'e, ikatuahy hemiapo kwer izupe a'e.
\q1 Wiko hemetarer katu ma'e romo. A'e awa nupuner kwaw Tupàn ima'enukwaw paw ikwaw paw rehe a'e.
\q1 Uze'eg urywahyahy wàmàtyry'ymar wanehe.
\q1 
\v 6 — Nazawy pixik kwaw ma'e iapo mehe ihe nehe, i'i uzeupe.
\q1 — Nazawaiw pixik kwaw heremiapo ràm ihewe nehe, i'i uzeupe.
\q1 
\v 7 Izuru tynehem ze'egaiaiw pupe a'e. Temu'emaw pupe tynehem no. Umume'u iaiw ma'e amo pe wemiapo ràm tuweharupi no.
\q1 Uze'eg xo iaiw paw rehe zo a'e. Xo ikatu 'ymaw rehe zo uze'eg a'e.
\b
\q1 
\v 8 Uzeàmim teko waneko haw huwake a'e.
\q1 Uwàro a'e pe, teko ikatu 'ym ma'e iapo pixik 'ymar wazuka pà.
\q1 
\v 9 Nuzawy kwaw zàwàruhu iriàw a'e. Wàro uzeàmimaw pupe.
\q1 Ume'e ikàg 'ym ma'e wanehe. Uzeàmim teko wanàro pà wazuka pà.
\q1 Wàro ma'erahy ipuraraw par wà.
\q1 Na'e upyhyk wemipyhyk ràm miar zuka haw zàwenugar pupe wà. Umutyk heraha a'e wi wà.
\q1 
\v 10 Uzuhazuhaw wamu'ar kar pà wà. Ikàg wera'u wemipyhyk wi a'e.
\q1 A'e rupi weityk wà.
\q1 
\v 11 Teko ikatu 'ym ma'e uze'eg nezewe uzeupe.
\q1 — Tupàn na'ikàg kwaw a'e.
\q1 Uzeàpumi a'e. Nuexak kwaw ma'e a'e.
\b
\q1 
\v 12 Epu'àm nehe, o Tupàn Tuweharupi Wiko Ma'e. Ezepyk a'e teko ikatu 'ym ma'e wanehe nehe.
\q1 Nereharaz zo ma'erahy ipuraraw par wanuwi nehe.
\q1 
\v 13 — Tupàn na'ikàg kwaw a'e, i'i teko ikatu 'ym ma'e.
\q1 — Tupàn nuzepyk kwaw herehe a'e nehe, i'i uzeupe. Màràzàwe tuwe uze'eg nezewe uzeupe.
\b
\q1 
\v 14 Ne, Tupàn, erexak ma'erahy ipuraraw paw ne. Erekwaw teko wazemumikahy haw no.
\q1 Nepurupytywà wer wanehe tuweharupi.
\q1 Ikàg 'ym ma'e uzeruzar nerehe wà.
\q1 Tuweharupi erepytywà ma'e hereko 'ymar ne wà.
\b
\q1 
\v 15 Hezar, emumaw ikatu 'ym ma'e wakàgaw nehe, iaiw ma'e wapuner haw nehe.
\q1 Ezepyk wanehe wanemiapo kwer ikatu 'ym ma'e hekuzaromo nehe.
\q1 Xo iapo re wapytu'u re zo epytu'u wanehe nezepyk ire nehe.
\q1 
\v 16 Tupàn Tuweharupi Wiko Ma'e wiko putar tuwihawete romo tuweharupi nehe.
\q1 Omono kar putar uzeruzar 'ym ma'e uiwy wi wà nehe.
\b
\q1 
\v 17 O Tupàn Tuweharupi Wiko Ma'e. Ereinu putar ma'erahy ipuraraw par ne wà nehe, newe waze'eg mehe ne wà nehe.
\q1 Eremukàg kar putar ne wà nehe. Nukyze kwaw wà nehe.
\q1 
\v 18 Aze ma'erahy ipuraraw har uhapukaz newe wà nehe, erenu putar ne wà nehe.
\q1 Aze hemetarer 'ym ma'e uhapukaz newe wà nehe, erenu putar ne wà nehe. — Ikatu ma'e romo peiko, ere putar wanupe nehe.
\q1 Nezewe mehe teko a'e wà nehe, amo 'ar mehe umàno ma'e ràm wà nehe,
\q1 Numuhàmuhàz pixik kwaw purumukyze kar haw a'e wà nehe.
\c 11
\s1 Tupàn wiko hemonokatu har romo
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 Aiko Tupàn Tuweharupi Wiko Ma'e rehe we ihe,
\q1 A'e rupi nuzeapo kwaw ikatu 'ym ma'e ihewe nehe.
\q1 — Ezàn zeàmim wiràmiri ài ywytyr rehe nehe,
\q1 
\v 2 ta'e ikatu 'ym ma'e umuàgà'ym uwyrapar a'e wà xe.
\q1 Ta'e umuàgà'ym u'yw uzeàmimaw pupe wiko mehe a'e wà xe,
\q1 Awa ikatu ma'e wazywà pà a'e wà xe.
\q1 
\v 3 Teko ikatu ma'e nupuner kwaw ma'e iapo haw rehe.
\q1 Ta'e heta ikatu 'ymaw ywy nànàn taw nànàn a'e xe, i'i ru'u ihewe wà.
\b
\q1 
\v 4 Tupàn Tuweharupi Wiko Ma'e wiko wàpuzuhu ikatuahy ma'e pupe.
\q1 Henaw ywak rehe hin.
\q1 Wexak teko paw wà.
\q1 Ukwaw wanemiapo.
\q1 
\v 5 Amo teko weruzar Tupàn Tuweharupi Wiko Ma'e a'e wà. Tupàn ume'e wanehe a'e. Ume'e ikatu 'ym ma'e wanehe no.
\q1 Teko upurumuahy ma'e wà, upuruzuka ma'e wà no,
\q1 Iro tuwe izupe wà.
\b
\q1 
\v 6 Tupàn weityk ma'ezu ukaz ma'e purumuahy ma'e a'e, ikatu 'ym ma'e wanehe a'e. Tàtàpyz weityk wanehe no.
\q1 Uzepyk wanehe ywytu haku ma'e wamur kar pà wanehe. Ukaz wà.
\q1 
\v 7 Tupàn Tuweharupi Wiko Ma'e uzapo ikatu ma'e a'e. Uzamutar katu imunar 'ym ma'e hemu'em 'ym ma'e wà.
\q1 Teko Tupàn heruzar har wiko putar ipyr wà nehe.
\c 12
\s1 Urepyro pe ikatu 'ym ma'e wanuwi
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 Urepyro pe nehe, o Tupàn Tuweharupi Wiko Ma'e.
\q1 Ta'e naheta kwaw teko imunar 'ym ma'e hemu'em 'ym ma'e wà xe.
\q1 Teko nerehe uzeruzar ma'e ukàzym ywy wi wà.
\q1 
\v 2 Teko paw hemu'em uzeupeupe wà.
\q1 — Nekatuahy, i'i mua'u amo amo wanupe wà.
\b
\q1 
\v 3 O Tupàn Tuweharupi Wiko Ma'e, emupytu'u kar nezewe uze'eg ma'e waze'eg ire ne wà nehe.
\q1 — Aiko wera'u amo wanuwi ihe, i'i amo wà. Emuze'eg kar zo ne wà nehe.
\q1 
\v 4 — Uruityk putar amogwer ureze'eg pupe nehe,
\q1 I'i wà.
\q1 — Ni amo na'uremupytu'u kar kwaw ureze'eg ire wà nehe, i'i wà.
\q1 — Ni amo nupuner kwaw ma'e iapo kar haw rehe urewe wà, i'i wà.
\b
\q1 
\v 5 Tupàn Tuweharupi Wiko Ma'e uze'eg a'e kury.
\q1 — Azapo putar ma'e ihe kury.
\q1 Ta'e teko upuraraw kar ma'erahy waiko hemetarer 'ym ma'e wanupe wà xe.
\q1 Ipuraraw par ikuhem ma'erahy wi wà.
\q1 Heràro waiko wà, a'e rupi azekaiw putar wanehe ihe nehe, i'i Tupàn Tuweharupi Wiko Ma'e.
\b
\q1 
\v 6 Pepuner Tupàn Tuweharupi Wiko Ma'e ze'eg rehe pezeruzar haw rehe.
\q1 Ize'eg nuzawy kwaw itaxig parat ikatuahy ma'e a'e.
\q1 Aze teko umupyràn parat tata pupe 7 haw tykwer imunyryk pà izuwi wà nehe, naheta kwaw ikatu 'ymaw a'e parat inuromo nehe. Tupàn ze'eg nuzawy kwaw parat 7 haw imukatu pyrer a'e.
\q1 
\v 7 O Tupàn Tuweharupi Wiko Ma'e, ezekaiw katu urerehe nehe,
\q1 Uremunyryk kar pà ikatu 'ym ma'e wanuwi nehe.
\q1 
\v 8 Ta'e ikatu 'ym ma'e wata oho waiko ywy nànàn a'e wà xe.
\q1 Ma'e ikatu 'ym ma'e ikatuahy teko paw wanupe.
\c 13
\s1 Zeruzar haw Tupàn puruamutar haw rehe
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 O Tupàn Tuweharupi Wiko Ma'e, nereharaz hewi ne. Màràn mehe nema'enukwaw wi putar herehe nehe.
\q1 Aipo nanema'enukwaw pixik kwaw herehe nehe.
\q1 Màràn 'ar eremumaw putar neruwa ihewi ipyk pà nehe.
\q1 
\v 2 Màràn 'ar amumaw putar ko ma'erahy ipuraraw pà nehe. Hepy'a tynehem hezemumikahy haw pupe, 'aromo, pyhaw.
\q1 Màràn 'ar amumaw putar nezewe nehe.
\q1 Heàmàtyry'ymar hemuzàn kar tuweharupi wà. Màràn 'ar amumaw putar nezewe nehe.
\b
\q1 
\v 3 O Tupàn Tuweharupi Wiko Ma'e, eme'e herehe kury. Ewazar heze'eg ihewe kury.
\q1 Emur nekàgaw ihewe nehe. Nezewe mehe namàno kwaw nehe.
\q1 
\v 4 Nezewe mehe heàmàtyry'ymar nahurywete kwaw wà nehe, ta'e na'ar kwaw ihe nehe xe.
\q1 — Xityk kwez zane, ni'i kwaw wà nehe.
\b
\q1 
\v 5 Heamutar katu pe ne. Azeruzar heamutar katu haw rehe.
\q1 Hepy'a hurywete putar nehe, ta'e hepyro putar pe ne nehe xe.
\q1 
\v 6 Amuzàg putar zegar haw newe nehe, o Tupàn Tuweharupi Wiko Ma'e pe,
\q1 Ta'e nekatuahy ihewe ne xe.
\c 14
\s1 Ikatu 'ymaw, purupyro haw no
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 Ma'e kwaw 'ymar uze'eg nezewe uzeupe wà.
\q1 — Tupàn na'ikàg kwaw a'e, i'i wà.
\q1 Upaw rupi wiko ikatu 'ym ma'e romo wà.
\q1 Uzapo iaiw ma'e oho waiko wà.
\q1 Naheta kwaw ni pitài ikatu ma'e iapo har wà.
\q1 
\v 2 Tupàn Tuweharupi Wiko Ma'e wapyk ywak rehe teko paw wanehe ume'e pà.
\q1 — Aipo heta amo ikatu ma'e wà, i'i uzeupe.
\q1 — Aipo heta amo hemuwete katu har wà, i'i uzeupe.
\q1 
\v 3 Teko paw upiaw wà. Iaiw upaw rupi wà.
\q1 Wakatu 'ymaw zuawyawygatu wà.
\q1 Naheta kwaw ikatu ma'e iapo har wà.
\q1 Azeharomoete naheta kwaw wà.
\b
\q1 
\v 4 Tupàn Tuweharupi Wiko Ma'e upuranu wemiruze'eg wanehe.
\q1 — Aipo a'e teko ikatu 'ym ma'e paw nukwaw pixik kwaw ma'e wà. Aipo wiko ma'e kwaw par 'ym romo upaw rupi wà.
\q1 Tuweharupi imunar heremiaihu wama'e rehe wà.
\q1 Nuze'eg kwaw ihewe wà, i'i wanupe.
\q1 
\v 5 Uryryryryz putar ukyze pà a'e wà nehe.
\q1 Amo weruzar ize'eg wà. Tupàn wiko a'e teko wamyrypar romo a'e.
\q1 
\v 6 Ma'e hereko 'ymar wàro ikatu ma'e wà. Ikatu 'ym ma'e umuaiw wanemiàro wà.
\q1 Tupàn Tuweharupi Wiko Ma'e upyro teko ikatu ma'e a'e wà, katu 'ymaw wi a'e wà.
\b
\q1 
\v 7 Tuwe Tupàn uputar Zeruzarez wi purupyro haw Izaew wanupe tur àwàm a'e.
\q1 Tupàn Tuweharupi Wiko Ma'e umukatu putar Zako izuapyapyr waneko haw a'e nehe.
\q1 Hurywete a'e ma'e izeapo mehe wà nehe. Wiko putar hurywete ma'e romo a'e mehe wà nehe.
\c 15
\s1 Tupàn Hàpuzuhu pupe wiko ma'e
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 O Tupàn Tuweharupi Wiko Ma'e. Mo upuner neràpuzuhu pupe weko haw rehe.
\q1 Mo upuner ywytyr nerenaw ikatuahy ma'e pe upyta haw rehe.
\b
\q1 
\v 2 Xo ikatu ma'e romo wiko ma'e zo upuner.
\q1 Xo ikatu ma'e iapo har zo upuner.
\q1 Xo ze'eg azeharomoete har imume'u har zo upuner. Xo uze'eg mehe hemu'em 'ym ma'e zo upuner.
\q1 
\v 3 Nuze'eg zemueteahy kwaw amo wanehe.
\q1 Nuzapo kar kwaw ikatu 'ym ma'e umyrypar wanupe.
\q1 Numume'u kwaw temu'emaw uzeake wiko ma'e wanehe.
\b
\q1 
\v 4 Tupàn hemityk kwer na'ikatu kwaw izupe wà.
\q1 Wereko katu Tupàn Tuweharupi Wiko Ma'e heruzar har wà.
\q1 Uzapo tuwe ma'e wemimume'u kwer rupi katete. Aze hekuzar katu izupe, nezewe rehe we uzapo a'e.
\q1 
\v 5 Omono wemetarer amo pe wemetarer imemyr henoz 'ym pà.
\q1 Nupyhyk kwaw temetarer teko ikatu ma'e rehe ikatu 'ym ma'e imume'u haw hekuzaromo a'e.
\b
\q1 Agwer ikatu ma'e iapo har wiko katu putar tuweharupi nehe.
\c 16
\s1 Tupàn wiko herehe we tuweharupi
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 Ezekaiw katu herehe nehe, Tupàn,
\q1 Ta'e hepyro har romo ereiko ne xe.
\q1 
\v 2 Nezewe aze'eg Tupàn Tuweharupi Wiko Ma'e pe ihe.
\q1 — Ereiko hezar romo ne.
\q1 Hema'e ikatu ma'e paw eremur ihewe, a'e izupe.
\b
\q1 
\v 3 Teko uze'egatu Tupàn rehe uzeruzar katu ma'e wanehe wà.
\q1 Hereko wer tuwe wainuinuromo ihe.
\q1 
\v 4 Tupàn a'ua'u imuwete har wà,
\q1 Upuraraw kar ma'erahy tetea'u uzeupe wà.
\q1 Nazakook kwaw ma'eruwy kwer tupàn a'ua'u wanupe a'e teko wainuinuromo ihe.
\q1 Namuwete katu kwaw wazar tupàn a'ua'u ihe wà.
\b
\q1 
\v 5 Ne Tupàn Tuweharupi Wiko Ma'e ne. Xo ne zo urereko ihe.
\q1 Hereko àwàm nepo pe tuz.
\q1 Erexak kar heremiapo ràm ihewe.
\q1 
\v 6 Ikatuahy tuwe ma'e ihewe neremiapo.
\q1 Azeharomoete ikatuahy a'e.
\b
\q1 
\v 7 Amume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw ihe, ta'e wiko hereruze'egar romo a'e xe.
\q1 Pyhaw hepy'a umume'u heremiapo kwer ikatu 'ym ma'e ihewe a'e.
\q1 
\v 8 Akwaw tuwe Tupàn Tuweharupi Wiko Ma'e tuweharupi herehe we heko haw ihe.
\q1 Wiko heruwake a'e. Ni amo nahemuryryryryz kar kwaw wà nehe.
\q1 
\v 9 A'e rupi hepy'a hurywete ihe. Aiko hurywete ma'e romo ihe.
\q1 Nakyze kwaw ma'e wi.
\q1 
\v 10 Ne Tupàn, hepyro pe màno haw ipuner haw wi ne.
\q1 Azapo tuwe neremiapo putar haw ihe.
\q1 A'e rupi nahemuezyw kar kwaw pe umàno ma'e kwer wapyta haw pe ne nehe.
\q1 
\v 11 Hemuata kar pe pe purumuigo kar ma'e rupi ne.
\q1 Herehe we nereko haw hemynehem kar turywete haw pupe.
\q1 Hemurywete kar tuweharupi no.
\c 17
\s1 Teko ikatu ma'e wenoz Tupàn ikatu haw izupe
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 O Tupàn Tuweharupi Wiko Ma'e. Ikatu 'ym ma'e wanehe nezepykaw ainoz newe.
\q1 Einu heze'eg nehe. Ezapo ma'e hereminozgwer rupi nehe. Hepy'a ikatu a'e ma'e henoz mehe.
\q1 Einu katu nehe, ta'e naheremu'em kwaw ihe xe.
\q1 
\v 2 Emume'u ikatu ma'e romo hereko haw nehe,
\q1 Ta'e erekwaw ikatu ma'e iapo haw ne xe.
\b
\q1 
\v 3 Erekwaw hepy'a ne.
\q1 Pyhaw ereme'e herehe.
\q1 Azeharomoete ereme'egatu herehe.
\q1 Nerexak kwaw ni pitài ikatu 'ym ma'e iputar haw hepy'a pe.
\q1 Aze ma'e iro newe, namume'u kwaw a'e ma'e newe ihe. Amogwer umume'u iro ma'e newe wà.
\q1 
\v 4 Naiko kwaw wazàwe ihe.
\q1 Tuweharupi aruzar neze'eg.
\q1 Aexak puruzuka ma'e wanemiapo kwer ikatu 'ym ma'e. Ihe nazapo kwaw ma'e wazàwe ihe.
\q1 
\v 5 Tuweharupi ata nerape rupi.
\q1 Nerape wi napiaw kwaw.
\b
\q1 
\v 6 Aze'eg newe, Tupàn, ta'e erewazar heze'eg ihewe ne xe.
\q1 Herenu pe nehe. Ezeapyaka katu heze'eg rehe nehe.
\q1 
\v 7 Exak kar heamutar katu haw ihewe nehe, hepyro har.
\q1 Neruwake hereko mehe heàmàtyry'ymar nupuner kwaw ikatu 'ym ma'e iapo haw rehe ihewe wà.
\q1 
\v 8 Hepyro pe ikatu 'ymaw wi nehe,
\q1 Nereha romo hereko mehe mo nehe.
\q1 
\v 9 Hemim pe nepepo wy pe teko ikatu 'ym ma'e wanuwi nehe. Nezewe mehe nupuner kwaw hezuka haw rehe wà nehe.
\b
\q1 Heàmàtyry'ymar tynehem purehe iakatuwawahy 'ymaw pupe wà. Umàmàn heywyr wà, heàmàtyry'ym pà wà.
\q1 
\v 10 Napuhareko kwaw ni pitài wà. Uze'eg ukatu wera'u haw rupi wà no.
\q1 
\v 11 Ur heraikweromo heruwake wà.
\q1 Umàmàn heywyr wà kury.
\q1 Wàro hereitykaw 'ar waiko wà.
\q1 
\v 12 Nuzawy kwaw zàwàruhu iriàw uzeàmim ma'e kwer wà. Heràro waiko wà.
\q1 Uzemuàgà'ym hepei'ài'àg àwàm rehe wà.
\b
\q1 
\v 13 Epu'àm nehe, Tupàn Tuweharupi Wiko Ma'e. Eho heàmàtyry'ymar wakutyr nehe.
\q1 Emumaw ne wà nehe.
\q1 Hepyro pe ikatu 'ym ma'e wanuwi nehe, netakihe puku pupe nehe.
\q1 
\v 14 O Tupàn Tuweharupi Wiko Ma'e nekàgaw rupi hepyro pe wanuwi nehe. Azeharomoete. Upyhyk wemimutar upaw rupi wiko mehe we a'e wà. Hemunyryk kar pe wanuwi ne nehe.
\q1 Ezepyk a'e teko wanehe ma'erahy neremimonokatu kwer ipuraraw kar pà wanupe nehe.
\q1 Tuwe heta tetea'u zepyk àwàm wana'yr wanupe nehe no.
\q1 Tuwe heta we zepyk àwàm wanemimino wanupe nehe no.
\b
\q1 
\v 15 Ihe uruexak putar ihe nehe, ta'e aiko katu ihe xe.
\q1 Heme'e mehe, herehe we nereko haw hemynehem putar herurywete haw pupe nehe.
\c 18
\s1 Tawi, tuwihawete ikàg ma'e
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 O Tupàn Tuweharupi Wiko Ma'e uruamutar katu tuwe ihe.
\q1 Ereiko hekàgaw romo ne.
\q1 
\v 2 Tupàn Tuweharupi Wiko Ma'e wiko hepyro har romo. Tupàn Tuweharupi Wiko Ma'e wiko hemukàg kar har romo no.
\q1 Tupàn hezar wiko itahu hemimaw romo.
\q1 Ni amo nupuner kwaw ikatu 'ym ma'e iapo haw rehe ihewe wà nehe, ta'e aiko hehe we ihe xe.
\q1 Hepyk u'yw wi purupykaw ài a'e.
\q1 Uzàmàtyry'ym heàmàtyry'ymar hepyro pà.
\q1 
\v 3 Aze'eg Tupàn pe hepytywà àwàm henoz pà izupe ihe.
\q1 A'e ae hepyro heàmàtyry'ymar wanuwi a'e.
\q1 Pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe.
\b
\q1 
\v 4 Hemàno àwàm heàpixipixi iko kyhàhàm ài a'e.
\q1 Hemumaw pàwàm ur he'aromo ykotok uhua'u ma'e ài no.
\q1 
\v 5 Hemàno haw heàpixipixi ukyhàhàm pupe a'e.
\q1 Hetym àwàm uzapo miar zuka haw zàwenugar hepyhyk pà a'e no.
\q1 
\v 6 Hemàno àwàm wi hekyze katu mehe aze'eg Tupàn Tuweharupi Wiko Ma'e pe ihe.
\q1 — Hepytywà pe nehe, a'e izupe.
\q1 Weinu heze'eg wàpuz ywak rehe har pe hin mehe.
\q1 Wenu hepytywà àwàm henoz mehe a'e.
\b
\q1 
\v 7 Na'e ywy uryryryryz tuwe uzemuaiw pà a'e.
\q1 Ywytyr ipy uryryryryz uwauwak pà a'e wà no,
\q1 Ta'e wikwahy Tupàn a'e xe.
\q1 
\v 8 Uhem tàtàxiner ipygwar wi a'e.
\q1 Tàtàpyzgwer uhem izuru wi, ta'e ma'e hapy har uhem izuru wi xe.
\q1 
\v 9 Uwàpytymawok ywak uwezyw pà a'e.
\q1 Ywàkun upy wy pe wereko wezyw mehe.
\q1 
\v 10 Uwewe amo kerumin Tupàn henaw rehe uzekaiw ma'e ikupe pe.
\q1 Na'arewahy oho ywytu rupi.
\q1 
\v 11 Uzepyk ipytunaw pupe.
\q1 Ywàkun ipihun ma'e 'y tetea'u hereko har izywyr upu'àm wà.
\q1 
\v 12 Tàtàpuzgwer a'e wà, àmàntàtà ita zàwenugar a'e no, uhem àmàn iweraw paw wi a'e wà, iweraw paw Tupàn henataromo har wi a'e wà.
\q1 Waxaw a'e ywàkun ipihun ma'e oho wà.
\b
\q1 
\v 13 Na'e Tupàn Tuweharupi Wiko Ma'e wànoànog ywak rehe kury.
\q1 Teko wenu Tupàn Ywate Wera'u Har ize'eg wà kury.
\q1 
\v 14 Omomor u'yw.
\q1 Umuhàmuhàz wàmàtyry'ymar wà.
\q1 Àmàn iweraw paw heny katu ma'e pupe umuzàn kar a'e wà.
\q1 
\v 15 Ne Tupàn Tuweharupi Wiko Ma'e ne, neàmàtyry'ymar wanehe nezepyk mehe,
\q1 Nekwahy haw rupi wakutyr neànoànog mehe,
\q1 Ywy yryhu wy pe har uzeupir a'e.
\q1 Ita ywy wy pe har uzexak kar a'e no.
\b
\q1 
\v 16 Tupàn ywak rehe har upyho opo ihewe. Hepyhyk a'e.
\q1 Yryhu wi hepyro.
\q1 
\v 17 Hepyro Tupàn heàmàtyry'ymar ikàg ma'e wanuwi,
\q1 Herehe iakatuwawahy 'ym ma'e wanuwi.
\q1 A'e paw ikàg wera'u ihewi wà. Nezewe rehe we hepyro wanuwi a'e.
\q1 
\v 18 Hereko haw ihewe zawaiw katu mehe, heàmàtyry'ym wà a'e wà.
\q1 Tupàn Tuweharupi Wiko Ma'e hepyk wanuwi a'e mehe.
\q1 
\v 19 Hemunyryk ikatu 'ymaw wi.
\q1 Hepyro ta'e heamutar katu a'e xe.
\b
\q1 
\v 20 Tupàn Tuweharupi Wiko Ma'e umekuzar katu putar hereko haw a'e nehe, ta'e aiko imunar 'ym ma'e romo hemu'em 'ym ma'e romo ihe xe.
\q1 Uzapo ikatu ma'e ihewe, ta'e nazapo kwaw ikatu 'ym ma'e ihe xe.
\q1 
\v 21 Tuweharupi aruzar Tupàn Tuweharupi Wiko Ma'e ze'eg ihe.
\q1 Napytu'u pixik kwaw heruzar ire.
\q1 
\v 22 Azapo ma'e ize'eg rupi upaw rupi.
\q1 Nazuhaw pixik kwaw ize'eg kwehe arer.
\q1 
\v 23 Tupàn Tuweharupi Wiko Ma'e ukwaw ikatu 'ym ma'e heremiapo 'ymaw a'e.
\q1 Ukwaw muite ikatu 'ym ma'e wi hetyrykaw no.
\q1 
\v 24 A'e rupi umekuzar heremiapo kwer a'e, ta'e naiko kwaw imunar ma'e romo ihe xe.
\q1 Ukwaw ikatu 'ym ma'e iapo har romo hereko 'ymaw a'e.
\b
\q1 
\v 25 Ne Tupàn Tuweharupi Wiko Ma'e neretyryk kwaw ikatu ma'e nerehe uzeruzar ma'e wanuwi ne.
\q1 Nekatuahy ikatuahy ma'e wanupe no.
\q1 
\v 26 Ereiko ikatuahy ma'e romo ikatu 'ymaw wi utyryk ma'e wanupe.
\q1 Ereiko ikatu 'ym ma'e wàmàtyry'ymar romo.
\q1 
\v 27 Erepyro ma'e hereko 'ymar ne wà.
\q1 Emuigo kar amogwer wanuwi wiko wera'u ma'e ma'e hereko 'ymar romo ne wà.
\q1 
\v 28 Ne, Tupàn Tuweharupi Wiko Ma'e, erekwaw kar ma'e ihewe ne.
\q1 Ne, hezar, eremumaw ipytunaw rehe hereko haw ne.
\q1 
\v 29 Eremur nekàgaw ihewe heàmàtyry'ymar waàmàtyry'ym kar pà ihewe.
\q1 Eremur nepuner haw ihewe wakàgaw heityk kar pà ihewe no.
\b
\q1 
\v 30 A'e Tupàn heremimume'u kwer a'e, uzapo ma'e paw ikatuahy ma'e romo a'e.
\q1 Uzapo tuwe ma'e wemimume'u kwer a'e no.
\q1 Nuzawy kwaw u'yw wi purumimaw a'e,
\q1 Ikàgaw hekar har wanupe a'e.
\q1 
\v 31 Tupàn Tuweharupi Wiko Ma'e wiko zanezar romo a'e. Naheta kwaw amo.
\q1 Xo Tupàn zo wiko zanepyro har romo.
\q1 
\v 32 A'e ae hemukàg kar har romo hekon a'e.
\q1 Hemunyryk kar ikatu 'ymaw wi wyzài ywy rehe heho mehe.
\q1 
\v 33 Hemuata katu kar hemu'ar kar 'ym pà a'e.
\q1 Hemonokatu ywytyr rehe no.
\q1 
\v 34 Hemu'e zeàmàtyry'ymawhu rehe a'e.
\q1 Nezewe mehe apuner heywyrapar ikàg wera'u ma'e pupe u'yw imomor haw rehe.
\b
\q1 
\v 35 Ne, hezar, ereiko u'yw wi hepykaw ài ne.
\q1 Hepytywà pe ne, a'e rupi hekàg ihe kury.
\q1 Nekàgaw hemuigo kar wikuwe ma'e romo.
\q1 
\v 36 Nahepyhyk kar kwaw pe heàmàtyry'ymar wanupe.
\q1 Ni pitài haw na'ar kwaw ihe.
\q1 
\v 37 Aha heàmàtyry'ymar wanaikweromo wapyhyk pà heràro 'ym mehe ihe wà.
\q1 Xo wamumaw ire zo apytu'u.
\q1 
\v 38 Azuhazuhaw ihe wà. Nupuner kwaw upu'àm wi haw rehe wà.
\q1 Heremityk kwer romo wiko hepy iwy pe wà.
\q1 
\v 39 Eremur nekàgaw ihewe waàmàtyry'ym mehe ne.
\q1 Eremur waneitykaw ihewe no.
\q1 
\v 40 Eremuzàn kar wamono ihewi ne wà.
\q1 Amumaw herehe iakatuwawahy 'ym ma'e ihe wà.
\q1 
\v 41 Uhapukaz wà. — Urepytywà pe nehe, i'i wà.
\q1 Ni amo nupuner kwaw wapyro haw rehe wà.
\q1 Uze'eg Tupàn Tuweharupi Wiko Ma'e pe wà. Nuwazar kwaw waze'eg wanupe.
\q1 
\v 42 Azuhazuhaw ihe wà.
\q1 Uzeapo ywy imuku'i pyrer romo wà. Ywytu weraha a'e ywy imuku'i pyrer.
\q1 Apyrog wanehe. Nuzawy kwaw to'om pe rupi heta ma'e ihewe wà.
\b
\q1 
\v 43 Aze teko ipytu'u wer heremiruze'eg romo wiko re wà nehe, neremupytu'u kar kwaw ne wà.
\q1 Hemuigo kar pe teko ywy nànànar wanuwihawete romo nehe.
\q1 Teko amo 'ar mehe heremigwaw 'ym a'e wà, wiko ihewe uma'ereko ma'e romo ko 'ar rehe a'e wà kury.
\q1 
\v 44 Teko amo ae ywy rehe har uzeamumew herenataromo wà.
\q1 Aze aze'eg wanupe, weruzar heze'eg wà.
\q1 
\v 45 Uhem wakàgaw wanuwi.
\q1 Uryryryryz wàpuz tàtà ma'e wi uhem pà wà.
\b
\q1 
\v 46 Tuwe Tupàn Tuweharupi Wiko Ma'e wikuwe awyzeharomo a'e nehe.
\q1 Pemume'u hepyro har ikatu haw nehe.
\q1 Tupàn wiko hepyro har romo a'e. Pemume'u uhua'u haw nehe.
\q1 
\v 47 Umur heàmàtyry'ymar waneitykaw ihewe a'e.
\q1 Weruzar kar heze'eg teko paw wanupe no.
\q1 
\v 48 Hemunyryk kar heàmàtyry'ymar wanuwi.
\b
\q1 Ne, hezar, eityk kar heàmàtyry'ymar ihewe ne wà nehe.
\q1 Hemunyryk kar pe awa puruzuka ma'e wanuwi nehe no.
\q1 
\v 49 A'e rupi, Tupàn Tuweharupi Wiko Ma'e, amume'u putar nekàgaw teko ywy nànànar wanupe nehe.
\q1 Amuzàg putar zegar haw nekatu haw imume'u haw newe nehe no.
\b
\q1 
\v 50 Ne, Tupàn, eremur iàmàtyry'ymar waneitykaw uhua'u ma'e tuwihawete neremiruze'eg pe ne.
\q1 Erexak kar nepuruamutar katu haw neremixak kwer pe no,
\q1 Tawi pe, izuapyapyr wanupe no, tuweharupi nehe.
\c 19
\s1 Ywak umume'u Tupàn ipuràg eteahy haw a'e
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 Ywak umume'u Tupàn ikàgaw a'e, ipuràgaw a'e no.
\q1 Umume'u hemiapo kwer no.
\q1 
\v 2 Amo 'ar mehe umume'u a'e ma'e 'ar ur ma'e ràm pe no.
\q1 Pyhaw ipytunaw umume'u amo ipytunaw pe no.
\q1 
\v 3 Ni amo nuze'eg kwaw wà.
\q1 Ni amo nuenu kwaw ma'e wà.
\q1 
\v 4 Na'e ze'eg ywate har uhàuhàz ywy nànàn.
\q1 Ize'eg uhem ywy nànàn.
\b
\q1 Tupàn uzapo tàpuz ywate kwarahy pe a'e.
\q1 
\v 5 Kwarahy uhem wàpuz wi urywete romo hemireko ma'e ràm ài a'e.
\q1 Nuzawy kwaw uzàn ma'e uzàn àwàm rehe uzypyrog ma'e.
\q1 
\v 6 Kwarahy uhem ywak rehe ipehegwer rehe a'e.
\q1 Oho inugwer pehegwer pe kury.
\q1 Ni amo ma'e nupuner kwaw haku haw wi uzeàmimaw rehe wà.
\b
\q1 
\v 7 Tupàn Tuweharupi Wiko Ma'e ze'eg ikatuahy a'e.
\q1 Umur ukàgaw ipyahu ma'e zanewe.
\q1 Ikatu ipureruze'egaw rehe zanezeruzar haw.
\q1 Ukwaw kar ma'e wyzài ma'e kwaw par 'ym wanupe.
\q1 
\v 8 Tupàn purumu'e haw ikatuahy a'e.
\q1 Umurywete kar teko wapy'a pe wà.
\q1 Uzekwaw katu ipurumu'e haw.
\q1 Zanewe ukwaw kar ma'e a'e.
\q1 
\v 9 Ikatu Tupàn imuwete katu haw.
\q1 Nupaw pixik kwaw nehe.
\q1 Ipureruze'egaw ikatuahy.
\q1 Ze'eg azeharomoete har rehe upureruze'eg tuweharupi.
\q1 
\v 10 Ipurumu'e haw ikatu wera'u itazu or wi a'e.
\q1 Aze heta or ikatuahy ma'e tetea'u newe nehe, Tupàn ipurumu'e haw ikatu wera'u putar a'e temetarer wi newe nehe.
\q1 Hete katu wera'u hàir wi.
\q1 Hàir ikatuahy ma'e wi hete katu wera'u a'e.
\q1 
\v 11 Hezar, nepurumu'e haw umur ma'e kwaw paw ihewe. Aiko neremiruze'eg romo.
\q1 Erezapo ikatu ma'e ihewe, aze aruzar neze'eg ihe.
\b
\q1 
\v 12 Mo upuner wemiawy kwer hexakaw rehe.
\q1 Hemukatu pe nehe, hezar, heremiawy kwer heremixak 'ym wanuwi nehe.
\q1 
\v 13 Hemunyryk kar pe ikatu 'ygwer wi nehe,
\q1 Heremimutar rupi heremiapo kwer wi nehe.
\q1 Emuigo kar zo hezar romo nehe.
\q1 Nezewe mehe naiko kwaw nereruzar 'ymar romo ihe nehe.
\q1 Naiko kwaw iaiw ma'e romo nezewe ihe nehe.
\q1 
\v 14 Einu heze'eg nehe. Ekwaw hema'enukwaw paw nehe.
\q1 Tuwe eremuawyze heze'eg nehe, hema'enukwaw paw nehe no, o Tupàn Tuweharupi Wiko Ma'e, hemimar hepyro har.
\c 20
\s1 Ze'egaw ukàgaw henoz taw
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 O tuwihawete, tuwe Tupàn Tuweharupi Wiko Ma'e uwazar neze'eg ma'erahy ipuraraw mehe har newe nehe,
\q1 Tuwe Tupàn Zako izar nepyro nehe.
\q1 
\v 2 Tuwe Tupàn umur kar nepytywà haw wàpuzuhu wi nehe.
\q1 Tuwe ur ywytyr Xiàw her ma'e wi nepytywà pà nehe.
\q1 
\v 3 Tuwe Tupàn ima'enukwaw neremimono kwer paw wanehe nehe.
\q1 Tuwe ma'ea'yr hapy haw rehe ukaz ma'e kwer paw ikatu izupe nehe.
\q1 
\v 4 O Tuwihawete, tuwe Tupàn umur neremimutar newe nehe.
\q1 Tuwe neremiapo putar haw paw uzeapo katu wà nehe.
\q1 
\v 5 A'e rupi uruhapukaz putar izeapo katu awer rehe nehe.
\q1 Urupir katu putar tuwe pàn nerer hereko har nehe, neremiapo kwer ikatu ma'e rehe urema'enukwaw katu pà nehe.
\q1 Urumume'u putar Tupàn urezar ikatu haw nehe.
\q1 O Tuwihawete, tuwe Tupàn umur neremimutar paw newe nehe.
\b
\q1 
\v 6 Tupàn Tuweharupi Wiko Ma'e umur iàmàtyry'ymar waneitykaw tuwihawete wemixak kwer pe a'e. Akwaw imur awer ihe.
\q1 Uwazar ywak ikatu ma'e wi a'e.
\q1 Umur iàmàtyry'ymar waneitykaw izupe ukàgaw rupi.
\q1 
\v 7 Amo uzeruzar ywyramawa zeàmàtyry'ymawhu pe har wanehe wà.
\q1 Amo uzeruzar weimaw kawaru wanehe wà.
\q1 Zane zazeruzar Tupàn Tuweharupi Wiko Ma'e Zanezar rehe zane.
\q1 
\v 8 Uzepyapi putar u'ar pà wà nehe.
\q1 Zane zapu'àm wi putar zanekàg romo zane nehe.
\b
\q1 
\v 9 O Tupàn Tuweharupi Wiko Ma'e, emur tuwihawete iàmàtyry'ymar waneityk àwàm izupe nehe.
\q1 Eze'eg urewe urepytywà àwàm newe henoz mehe nehe.
\c 21
\s1 Tawi umume'u Tupàn ikatu haw izupe, ta'e weityk kar iàmàtyry'ymar izupe a'e
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 O Tupàn Tuweharupi Wiko Ma'e. Tuwihawete hurywete a'e, ta'e eremur nekàgaw izupe ne xe.
\q1 Hurywete a'e, ta'e ereityk kar iàmàtyry'ymar izupe ne wà xe.
\q1 
\v 2 Erezapo hemimutar izupe ne.
\q1 Hemimutar eremono izupe no.
\q1 
\v 3 Eremuhem kar nezeake ne, ikatuahy ma'e imono pà izupe ne.
\q1 Eremono àkàg rehe har or iapo pyrer iàkàg rehe no.
\q1 
\v 4 — Hemuigo kar pe ne, i'i newe.
\q1 Eremono hekuwe àwàm tuweharupi àràm izupe ne.
\b
\q1 
\v 5 Tuwihawete ikàg a'e, ipuràg eteahy a'e, ta'e erepytywà ne xe.
\q1 Eremur ikàgaw izupe. Erekwaw kar her teko tetea'u wanupe no.
\q1 
\v 6 Neze'egatu hehe tuz putar tuweharupi nehe.
\q1 Hehe we nereko haw umurywete kar tuwe a'e.
\q1 
\v 7 Tuwihawete uzeruzar Tupàn Tuweharupi Wiko Ma'e rehe a'e.
\q1 Tupàn Ywate Wera'u Har uzamutar katu tuwihawete a'e.
\q1 A'e rupi wiko putar tuwihawete romo tuweharupi nehe.
\q1 
\v 8 Tuwihawete upyhyk putar wàmàtyry'ymar a'e wà nehe.
\q1 Upyhyk putar tuwihawete rehe iakatuwawahy 'ym ma'e wà nehe, upuner haw pupe wà nehe.
\q1 
\v 9 Uzexak kar putar wàmàtyry'ymar wamumaw pà tata ài nehe, wanemiapo kwer rehe uzepyk mehe nehe.
\b
\q1 Ukwahy haw rupi umumaw putar wà nehe.
\q1 Tata pupe wapy putar wà nehe.
\q1 
\v 10 Ni pitài uhem putar umàno haw wi wà nehe.
\q1 Tuwihawete uzuka putar wazuapyapyr paw rupi a'e wà nehe.
\q1 
\v 11 Iàmàtyry'ymar umume'u ikatu 'ym ma'e izupe wemiapo ràm wà, izuka àwàm imume'u pà wà.
\q1 Nupuner kwaw ikatu 'ym ma'e iapo haw rehe izupe wà nehe.
\q1 
\v 12 Omomor putar u'yw wakutyr nehe,
\q1 Wamuzàn kar pà nehe.
\b
\q1 
\v 13 O Tupàn Tuweharupi Wiko Ma'e, urumume'u putar nekatu haw newe ta'e nekàg tuwe ne.
\q1 Urumume'u putar nekatu haw newe ta'e nepuner haw uhua'u a'e.
\c 22
\s1 Uzemumikahy zepe, nezewe rehe we umume'u Tupàn ikatu haw no
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 Tupàn hezar, Tupàn hezar. Màràzàwe tuwe eretyryk ihewi ne.
\q1 Màràzàwe tuwe erepyta muite ihewi ne.
\q1 Màràzàwe tuwe naherenu kwaw pe hepytywà àwàm henoz mehe ne, newe herehapukaz mehe ne.
\q1 
\v 2 Tupàn hezar. Aenoz newe 'aromo ihe.
\q1 Nerewazar kwaw heze'eg ihewe.
\q1 Uruenoz pyhaw no.
\q1 Napuner kwaw hepytu'u haw rehe.
\q1 
\v 3 Ne nekatuahy ne.
\q1 Ereapyk nerenaw rehe.
\q1 Teko Izaew izuapyapyr paw umume'u nekatu haw newe wà.
\q1 
\v 4 Ureipy omono uzeruzar haw nerehe wà. Uzeruzar tuwe nerehe wà.
\q1 A'e mehe erepyro ne wà.
\q1 
\v 5 Urepytywà pe nehe, i'i newe wà. A'e rupi erepyro ikatu 'ymaw wi ne wà.
\q1 Uzeruzar nerehe wà. Nereityk kwaw ne wà.
\b
\q1 
\v 6 Aiko amirikur romo ihe. Naiko kwaw awa romo.
\q1 Teko paw upuka herehe wà. Uze'eg zemueteahy herehe wà.
\q1 
\v 7 Teko herexakar paw uze'eg urywahyahy herehe wà.
\q1 Uwapeku wexak kar ihewe uwàkàg heruwaruwak pà hemaranugar haw imume'u pà ihewe wà.
\q1 
\v 8 — Aipo erezeruzar Tupàn Tuweharupi Wiko Ma'e rehe ne,
\q1 I'i ihewe wà.
\q1 — Màràzàwe tuwe nanepyro kwaw a'e.
\q1 Aze nekatu izupe, màràzàwe tuwe nanepytywà kwaw a'e, i'i ihewe wà.
\b
\q1 
\v 9 Ne Tupàn hererur ko ywy rehe hezexak kar mehe ne.
\q1 Hekwarer mehe erezekaiw katu herehe.
\q1 
\v 10 Hemono newe hezexak kar mehe wà. Erezekaiw katu herehe.
\q1 Hezexak kar haw henataromo ereiko Tupàn hezar romo ne.
\b
\q1 
\v 11 Etyryk zo ihewi nehe,
\q1 Ta'e ma'erahy namuite kwaw ihewi a'e xe.
\q1 Naheta kwaw hepytywà àràm ihewe wà.
\q1 
\v 12 Heàmàtyry'ymar tetea'u umàmàn heywyr wà. Nuzawy kwaw tapi'ak awa wà.
\q1 Upaw rupi umàmàn heywyr wà.
\q1 Wiko tapi'ak awa ikàg ma'e Màxà ywy rehe har ài wà.
\q1 
\v 13 Zàwàruhu iriàw ài uzurupeka wà.
\q1 Okororo hekutyr opor pà wà.
\q1 
\v 14 Hekàgaw uhem ihewi kury.
\q1 Aiko 'y ywy rehe izakook pyrer ài.
\q1 Hekàgwer paw uhem wenaw wi wà.
\q1 Hepy'a nuzawy kwaw iraity imupyràn pyrer a'e.
\q1 
\v 15 He'az uxinigahy ywy ku'i kwer ài a'e.
\q1 Heapeku uzemog hezuru i'aromo.
\q1 Hereityk pe umàno ma'e kwer ài ywy rehe ne.
\q1 
\v 16 Teko ikatu 'ym ma'e iapo har umàmàn waiko heywyr wà.
\q1 Ur hekutyr zawar ài wà.
\q1 Umu'i hepo hepy rehe we wà.
\q1 
\v 17 Amo upuner hekàgwer paw wapapar haw rehe wà.
\q1 Heàmàtyry'ymar ume'e herehe wà. Hekàg 'ymaw umurywete kar a'e wà xe.
\q1 
\v 18 Umuza'aza'ak hema'e uzeinuinuromo wà, ipyhyk pà wà.
\q1 Omomor ita'i ma'e ipapar haw hereko har hekamirpuku izar ràm hexaexak pà wà no.
\b
\q1 
\v 19 O Tupàn Tuweharupi Wiko Ma'e, etyryk zo ihewi nehe.
\q1 Ezur na'arewahy hepytywà pà nehe.
\q1 
\v 20 Hepyro pe takihepuku wi nehe.
\q1 Tuwe a'e zawar zàwenugar nahezuka kwaw wà nehe.
\q1 
\v 21 Hemunyryk kar pe 'aw zàwàruhu iriàw wanuwi nehe.
\q1 Napuner kwaw hezepyro haw rehe 'aw tapi'ak awa hehaite ma'e wanuwi ihe.
\b
\q1 
\v 22 A'e re amume'u putar neremiapo kwer heremiaihu wanupe nehe.
\q1 Amume'u putar nekatu haw teko wanupe wazemono'og mehe ihe nehe. Nezewe aze'eg putar wanupe nehe.
\b
\q1 
\v 23 — Pe Tupàn Tuweharupi Wiko Ma'e wi ukyze ma'e wà, pemume'u ikatu haw nehe.
\q1 Zako izuapyapyr wà, pemuwete katu Tupàn nehe.
\q1 Teko Izaew izuapyapyr wà, pemuwete katu Tupàn Tuweharupi Wiko Ma'e nehe, a'e putar wanupe nehe.
\q1 
\v 24 — Nuityk kwaw ma'e hereko 'ymar a'e wà.
\q1 Naheharaz kwaw ma'erahy wanemipuraraw kwer wi.
\q1 Nuzeàmim kwaw wanuwi.
\q1 — Urepytywà pe nehe, aze i'i izupe wà, uwazar waze'eg wanupe a'e, a'e putar wanupe nehe.
\b
\q1 
\v 25 O Tupàn Tuweharupi Wiko Ma'e, teko paw wazemono'og mehe,
\q1 Amume'u putar nekatu haw ihe nehe, neremiapo kwer imume'u pà ihe nehe.
\q1 Newi ukyze ma'e wainuinuromo,
\q1 Azuka putar ma'ea'yr nerenataromo heze'eg awer rupi katete ihe wà nehe.
\q1 
\v 26 Ma'e hereko 'ymar u'u putar a'e ma'ea'yr ho'o kwer a'e wà nehe. Uhyk putar wanupe nehe.
\q1 Tupàn Tuweharupi Wiko Ma'e imuwete katu har umume'u putar ikatu haw wà nehe.
\q1 Tuwe uhyk wama'e wanupe tuweharupi nehe.
\q1 Tuwe hurywete wà nehe.
\b
\q1 
\v 27 Teko ywy nànànar ima'enukwaw putar Tupàn Tuweharupi Wiko Ma'e rehe wà nehe.
\q1 Teko ywy rehe har paw uzewyr putar izupe wà nehe.
\q1 Teko hexakaw paw hereko har umuwete katu putar wà nehe.
\q1 
\v 28 Ta'e Tupàn Tuweharupi Wiko Ma'e wiko tuwihawete romo a'e xe.
\q1 Weruze'eg teko ywy nànànar wanereko wà no.
\q1 
\v 29 Teko amo wanuwi wiko wera'u ma'e paw uzeamumew putar henataromo wà nehe.
\q1 Teko paw umuwete katu putar wà nehe.
\q1 Azeharomoete umàno ma'e ràm paw umuwete katu putar wà nehe.
\q1 
\v 30 Teko amo 'ar mehe àràm wiko putar hemiruze'eg romo wà nehe.
\q1 Uze'eg putar uzuapyapyr wanupe Tupàn Zanezar rehe wà nehe.
\q1 
\v 31 Uzexak kar ma'e ràm a'e wà nehe, wenu putar hemiapo kwer imume'u haw a'e wà nehe.
\q1 — Tupàn upyro wemiaihu a'e wà, i'i putar amo wà nehe.
\c 23
\s1 Tupàn wiko àràpuhàràn imono'ogar ài
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 Tupàn Tuweharupi Wiko Ma'e wiko àràpuhàràn imono'ogar ài ihewe a'e.
\q1 Uhyk putar ma'e ihewe nehe.
\q1 
\v 2 Hemupytu'u kar ka'api'i ikyr ma'e rehe.
\q1 Hereraha ykotok heta 'ymaw pe.
\q1 
\v 3 Hemukàg kar wiwi a'e,
\q1 Pe ikatu ma'e rupi hemuata kar pà a'e no,
\q1 Hemimume'u kwer rupi katete a'e no.
\b
\q1 
\v 4 Aze ata ywyàpyznaw tatainy hereko 'ymar rupi nehe, màno haw zàwenugar rupi nehe,
\q1 Nakyze kwaw ma'e wi ihe nehe,
\q1 Ta'e ne Tupàn Tuweharupi Wiko Ma'e ereiko herehe we ne xe.
\q1 Erezekaiw katu herehe. Heho àwàm erexak kar ihewe no.
\b
\q1 
\v 5 Erezapo mai'u hawhu ihewe.
\q1 Heàmàtyry'ymar upuner herexakaw rehe a'e mai'u haw pe wà.
\q1 Hemuixe kar pe nereminoz imuwete wera'u pyr ài.
\q1 Eremynehem tuwe hekanek ihewe.
\q1 
\v 6 Azeharomoete nekatu haw nehe, nepuruamutar haw nehe no,
\q1 Upyta putar heinuinuromo herekuwe mehe nehe. Akwaw herehe we ipyta àwàm ihe.
\q1 'Ar nànàn herekuwe mehe
\q1 Aiko putar neràpuz me, o Tupàn Tuweharupi Wiko Ma'e.
\c 24
\s1 Mo upuner oho haw rehe Tupàn Hàpuzuhu pe
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 Ywak a'e, hehe har paw a'e wà no, Tupàn Tuweharupi Wiko Ma'e wiko wazar romo upaw rupi katete a'e.
\q1 Ywy a'e, hehe wiko ma'e paw a'e wà no, Tupàn wiko wazar romo a'e no.
\q1 
\v 2 Tupàn uzapo ywy yryhu rehe.
\q1 Omono iwy pe har yryhu iwy pe no.
\b
\q1 
\v 3 Mo upuner ywytyr Tupàn Tuweharupi Wiko Ma'e henaw rehe uzeupir haw rehe wà.
\q1 Mo upuner hàpuzuhu imonokatu ma'e pupe upyta haw rehe wà.
\q1 
\v 4 Xo ikatu ma'e iapo har zo upuner wà. Xo ikatu ma'e rehe ima'enukwaw ma'e upuner wà.
\q1 Xo tupàn a'ua'u wamuwete 'ymar zo upuner wà.
\q1 Xo wemiapo ràm imume'u mua'u 'ymar zo upuner wà.
\q1 
\v 5 Tupàn Tuweharupi Wiko Ma'e omono putar uze'egatu a'e teko rehe nehe.
\q1 Teko wanemiapo kwer imume'u haw 'ar mehe ipyro har umume'u putar ikatu haw a'e nehe.
\q1 
\v 6 Tupàn Tuweharupi Wiko Ma'e imuwete katu har wiko nezewe wà.
\q1 Zako izar imuwete katu har nezewe wanekon wà.
\b
\q1 
\v 7 Pewàpytymawok ukenawhu nehe.
\q1 Ukenawhu kwehe arer pewàpytymawok nehe.
\q1 Tuwihawete ikàg ma'e ipuràg eteahy ma'e wixe putar a'e nehe.
\q1 
\v 8 Mo wiko Tuwihawete Ikàg Ma'e romo a'e.
\q1 Tupàn Tuweharupi Wiko Ma'e wiko tuwihawete ikàg ma'e romo a'e. Upuner a'e. Ikàg tuwe a'e no.
\q1 Tuweharupi Wiko Ma'e zeàmàtyry'ymawhu pe ikàg ma'e romo hekon a'e.
\b
\q1 
\v 9 Pewàpytymawok ukenawhu nehe.
\q1 Ukenawhu kwehe arer pewàpytymawok nehe.
\q1 Tuwihawete puner haw puràg eteahy haw hereko har wixe putar nehe.
\q1 
\v 10 Mo wiko a'e Tuwihawete Ikàg Ma'e romo a'e, Tupàn ipuràg wera'u ma'e romo a'e.
\q1 Wiko tuwe Puner Haw Hereko Har romo a'e.
\q1 Wiko Tuwihawete Ikàg Ma'e romo ipuràg wera'u ma'e romo a'e.
\c 25
\s1 Wenoz upytywà àwàm, omonokatu haw no
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 O Tupàn Tuweharupi Wiko Ma'e, newe aze'eg nezewe ihe.
\q1 
\v 2 Hezar, nerehe azeruzar.
\b
\q1 Hepyro pe maranugar haw wi nehe, hemunyryk pe heretykaw wi nehe.
\q1 Emurywete kar zo heàmàtyry'ymar ne wà nehe, iaiw ma'e ihewe uzeapo ma'e rehe ne wà nehe.
\q1 
\v 3 Nerehe uzeruzar ma'e na'imaranugar kwaw wà nehe, ta'e nuzeityk kar kwaw wà xe.
\q1 Aze amo upytu'u e neze'eg heruzar ire wà nehe, amo weityk putar a'e teko a'e wà nehe.
\b
\q1 
\v 4 O Tupàn Tuweharupi Wiko Ma'e, nerape rehe hemu'e pe nehe.
\q1 Ekwaw katu kar ihewe nehe.
\q1 
\v 5 Hemu'e pe neze'eg azeharomoete har rehe hereko àwàm rehe nehe, ta'e ne ereiko hezar romo ne xe.
\q1 Ereiko hepyro har romo ne no.
\q1 Azeruzar nerehe tuweharupi ihe.
\q1 
\v 6 O Tupàn Tuweharupi Wiko Ma'e, nema'enukwaw nekatu haw rehe nehe, nepuruamutar katu haw rehe nehe no.
\q1 Kwehe erexak kar nekatu haw teko wanupe.
\q1 
\v 7 Nereharaz ikatu 'ym ma'e heremiapo kwer hekwarer mehe arer wi nehe, heremiawy kwer hekwarer mehe arer wi nehe no.
\q1 Erepuruamutar katu ne. Nekatuahy no.
\q1 A'e rupi nema'enukwaw herehe nehe, o Tupàn Tuweharupi Wiko Ma'e.
\b
\q1 
\v 8 Tupàn Tuweharupi Wiko Ma'e uzepyk ikatu 'ym ma'e wanehe. Ikatuahy a'e.
\q1 A'e rupi wexak kar wanape ràm ikatu 'ym ma'e iapo har wanupe a'e.
\q1 
\v 9 Tupàn umuata kar ikàg 'ym ma'e a'e wà, pe ikatu ma'e rupi a'e wà.
\q1 Umu'e wemimutar rehe wà no.
\q1 
\v 10 Nutyryk kwaw wemiaihu wanuwi a'e. Wexak kar wanape ràm wanupe upuruamutar katu haw rehe,
\q1 Aze a'e teko uzapo ma'e uze'eg Tupàn pe imume'u pyrer rupi wà,
\q1 Aze weruzar ize'eg wà.
\b
\q1 
\v 11 O Tupàn Tuweharupi Wiko Ma'e, ezapo ma'e ze'eg neremimume'u kwer rupi nehe.
\q1 Emunàn heremiapo kwer ikatu 'ym ma'e nehe, ta'e heta tetea'u a'e wà xe.
\b
\q1 
\v 12 Tupàn wi ukyze ma'e wà nehe,
\q1 Uzemu'e putar wape ràm Tupàn inuromo wà nehe.
\q1 
\v 13 Ikatuahy putar waneko àwàm nehe.
\q1 Wana'yr wiko putar ywy Tupàn hemimume'u kwer izar romo wà nehe.
\q1 
\v 14 Aze teko ukyze izuwi wà, Tupàn Tuweharupi Wiko Ma'e wiko wamyrypar romo a'e.
\q1 Umu'e a'e teko uze'eg iapo katu pyrer rehe wà no.
\b
\q1 
\v 15 Tuweharupi ame'e Tupàn Tuweharupi Wiko Ma'e rehe,
\q1 Ta'e hepyro ikatu 'ymaw wi a'e xe.
\q1 
\v 16 O Tupàn, eme'e herehe hepuhareko pà nehe, ta'e heàmàtyry'ymar upuraraw kar ma'erahy ihewe wà xe.
\q1 Ni amo hepyro a'e wà.
\q1 
\v 17 Epyro hepy'a heremipuraraw haw wi nehe.
\q1 Hemunyryk kar ikatu 'ymaw nànàn nehe no.
\q1 
\v 18 Exak hezemumikahy haw nehe. Eme'e ma'erahy heremipuraraw rehe nehe no.
\q1 Emunàn heremiapo kwer ikatu 'ym ma'e paw nehe.
\b
\q1 
\v 19 Eme'e heàmàtyry'ymar wanehe nehe. Heta tetea'u wà.
\q1 Herehe wakatuwawahy 'ymaw uhua'u a'e wà.
\q1 
\v 20 Ezekaiw herehe hepyro pà nehe. Hemumaranugar kar zo pe hereityk àwàm wi nehe,
\q1 Ta'e aekar hepyro àwàm nerehe we ihe xe.
\q1 
\v 21 Nahemunar kwaw ihe. Naheremu'em kwaw ihe.
\q1 Tuwe hekatu haw hepyro nehe, ta'e azeruzar nerehe ihe xe.
\b
\q1 
\v 22 O Tupàn, epyro neremiaihu Izaew ne wà nehe. Ikatu 'ym ma'e wanupe uzeapo ma'e wi epyro ne wà nehe.
\c 26
\s1 Teko ikatu ma'e ize'egaw Tupàn pe
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 O Tupàn Tuweharupi Wiko Ma'e, emume'u ikatu ma'e romo hereko haw nehe,
\q1 Ta'e azapo ikatu ma'e ihe xe.
\q1 Azeruzar katu nerehe no.
\q1 
\v 2 Eme'egatu herehe nehe. Heagaw pe nehe, Tupàn Tuweharupi Wiko Ma'e.
\q1 Ekwaw heremimutar nehe. Ekwaw hema'enukwaw paw nehe no.
\q1 
\v 3 Ta'e nepuruamutar katu haw wexak kar heho àwàm ihewe ne xe.
\q1 Neze'eg azeharomoete har wexak kar heata àwàm ihewe no.
\b
\q1 
\v 4 Nata kwaw hemu'em ma'e wainuromo ihe.
\q1 Naiko kwaw ikatu ma'e romo uzemume'u mua'u ma'e wainuromo ihe.
\q1 
\v 5 Nazemono'og kwaw iaiw ma'e wanehe we.
\q1 Ikatu 'ym ma'e wanupi nata kwaw ihe.
\b
\q1 
\v 6 O Tupàn Tuweharupi Wiko Ma'e, apuez hepo hekatu haw hexak kar pà ihe.
\q1 Ata ma'ea'yr hapy haw nerenataromo har izywyr ihe,
\q1 Nemuwete katu har wainuromo ihe.
\q1 
\v 7 Uruzegar newe, ta'e nekatuahy urewe ne xe.
\q1 Urumume'u neremiapo kwer ikatuahy ma'e no.
\q1 
\v 8 O Tupàn Tuweharupi Wiko Ma'e.
\q1 Azamutar katu neràpuz nereko haw ihe, tàpuzuhu nekàgaw ihyape katu haw henaw ihe.
\b
\q1 
\v 9 Hemumaw zo pe amogwer ikatu 'ym ma'e iapo har wainuromo nehe.
\q1 Erezepyk putar puruzuka ma'e wanehe nehe. Hepyro a'e nezepykaw wi nehe,
\q1 
\v 10 Hepyro ikatu 'ym ma'e tuweharupi iapo har wanehe nezepykaw wi nehe.
\q1 Upyhyk teko wanemetarer wà, tuwihaw wanenataromo wemu'emaw hekuzaromo wà.
\q1 
\v 11 Ihe azapo ikatu ma'e ihe.
\q1 Hepuhareko pe hepyro pà nehe.
\b
\q1 
\v 12 Ikatu 'ymaw nahemumaw pixik kwaw nehe.
\q1 Teko Tupàn Tuweharupi Wiko Ma'e ikatu haw rehe wazemono'og mehe, amume'u putar ikatu haw nehe.
\c 27
\s1 Tupàn wiko hepytywà har romo
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 Tupàn Tuweharupi Wiko Ma'e wiko tatainy ài ihewe. Hepyro har romo hekon a'e.
\q1 Mo wi akyze putar nehe.
\q1 Tupàn hepyro ikatu 'ymaw nànàn a'e.
\q1 Nakyze kwaw ni amo wanuwi nehe.
\b
\q1 
\v 2 Heàmàtyry'ymar ikatu 'ym ma'e hekutyr wanur mehe,
\q1 Hezuka haw rehe uzeagaw mehe,
\q1 Uzepyapi u'ar pà wà.
\q1 
\v 3 Aze zauxiapekwer tetea'u uzemono'og heywyr umàmàn pà wà nehe,
\q1 Nakyze kwaw wanuwi nehe.
\q1 Aze heàmàtyry'ym heàmàtyry'ymar wà nehe,
\q1 Azeruzar wiwi Tupàn rehe nehe.
\b
\q1 
\v 4 Xo pitài ma'e zo ainoz Tupàn Tuweharupi Wiko Ma'e pe. Xo a'e ma'e zo aputar ihe.
\q1 Tuwe hemuigo kar wàpuz me nehe.
\q1 Tuwe amumaw he'ar paw hàpuz me hereko pà nehe,
\q1 Ikatu haw ikwaw pà nehe,
\q1 Ima'ekwaw paw rehe hemu'e pà nehe no.
\q1 
\v 5 Aze zawaiw katu hereko haw nehe, hemim putar uzeàmimaw pe nehe.
\q1 Hemonokatu wàpuzuhu pupe nehe.
\q1 Ita 'aromo hemono putar ikatu 'ymaw wi hepyro pà nehe.
\q1 
\v 6 Nezewe mehe aityk putar heàmàtyry'ymar ihe wà nehe, heywyr har ihe wà nehe.
\q1 Ahapukaz putar herurywete haw rehe nehe.
\q1 Hàpuzuhu pe ma'ea'yr wazuka mehe nehe, azegar putar azeharomoete nehe. Amume'u putar Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe.
\b
\q1 
\v 7 O Tupàn Tuweharupi Wiko Ma'e, herenu pe nerenoz mehe nehe.
\q1 Hepuhareko pe heze'eg iwazar pà nehe.
\q1 
\v 8 — Ezur hemuwete katu pà nehe, ere ihewe.
\q1 — Aha putar nemuwete katu pà nehe, o Tupàn Tuweharupi Wiko Ma'e, a'e newe.
\q1 
\v 9 Ezeàmim zo ihewi nehe.
\b
\q1 Eikwahy zo ihewe nehe.
\q1 Hemono kar zo pe nezewi nehe.
\q1 O Tupàn hepyro har, ereiko hepytywà har romo.
\q1 Etyryk zo ihewi nehe. Ihewi eho zo nehe.
\q1 
\v 10 Aze heru utyryk ihewi nehe, aze hehy utyryk ihewi nehe no, nezewe rehe we Tupàn
\q1 Tuweharupi Wiko Ma'e uzekaiw katu putar herehe nehe.
\b
\q1 
\v 11 O Tupàn Tuweharupi Wiko Ma'e, hemu'e pe neremimutar iapo haw rehe nehe.
\q1 Hemuata kar pe ikatu ma'e rupi nehe,
\q1 Ta'e heta tetea'u heàmàtyry'ymar a'e wà xe.
\q1 
\v 12 Hemono zo pe heàmàtyry'ymar wapo pe nehe.
\q1 Hemu'em herehe a'e wà.
\q1 Umume'u hemuahy àwàm wà no.
\b
\q1 
\v 13 Tupàn Tuweharupi Wiko Ma'e wexak kar putar ukatu haw herekuwe mehe nehe.
\q1 Akwaw tuwe ikatu haw hexak kar àwàm ihe nehe.
\q1 
\v 14 Ezeruzar Tuweharupi Wiko Ma'e rehe nehe.
\q1 Ezeruzar katu nekyze 'ym pà nehe.
\q1 Ezeruzar Tupàn Tuweharupi Wiko Ma'e rehe nehe.
\c 28
\s1 Uze'eg Tupàn pe zepytywà haw henoz tà
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 O Tupàn Tuweharupi Wiko Ma'e, herehe uzekaiw katu ma'e, uruenoz iteko ihe.
\q1 Herenoz pe herehapukaz mehe nehe.
\q1 Aze nerewazar kwaw heze'eg ihewe nehe,
\q1 Aiko putar umàno ma'e kwer waneta haw pe wezyw ma'e wainuromo ihe nehe.
\q1 
\v 2 Hepytywà àwàm henoz mehe, herehapukaz mehe herenu katu pe nehe.
\q1 Apyho hepo neràpuzuhu imonokatu pyrer kutyr hepytywà àwàm henoz mehe ihe.
\q1 
\v 3 Ezepyk zo herehe iaiw ma'e wainuromo nehe,
\q1 Ikatu 'ym ma'e iapo har wainuromo nehe.
\q1 — Uruiko nemyrypar romo ure, i'i mua'u ihewe wà.
\q1 Tynehem wapy'a katu 'ymaw pupe wà.
\b
\q1 
\v 4 Ezepyk a'e teko wanehe wanemiapo kwer hekuzaromo nehe,
\q1 Ikatu 'ym ma'e paw hekuzaromo nehe.
\q1 Emono wanemiapo kwer hekuzar wanupe nehe, ikatu 'ym ma'e wanupe nehe.
\q1 
\v 5 Na'ipurukwaw wer kwaw Tupàn Tuweharupi Wiko Ma'e hemiapo kwer rehe wà.
\q1 Nume'e kwaw hemiapo kwer ikàg ma'e wà.
\q1 A'e rupi uzepyk putar wanehe nehe.
\q1 Umumaw putar azeharomoete a'e wà nehe. Nuzewyr kwaw wà nehe.
\b
\q1 
\v 6 Tuwe teko umume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw wà nehe.
\q1 Wenu herehapukaz mehe hepytywà àwàm henoz mehe a'e.
\q1 
\v 7 Tuweharupi Wiko Ma'e wiko hekàgaw romo a'e. Wiko u'yw wi hemimaw ài no.
\q1 Azeruzar katu tuwe hehe ihe.
\q1 Tuweharupi Wiko Ma'e hepytywà a'e.
\q1 A'e rupi hepy'a hurywete a'e.
\q1 A'e rupi amuzàg zegar haw ikatu haw rehe izupe ihe.
\b
\q1 
\v 8 Tupàn Tuweharupi Wiko Ma'e wiko wemiaihu wakàgaw romo a'e.
\q1 Tuweharupi Wiko Ma'e upyro tuwihawete wemixak kwer a'e, iàmàtyry'ymar wanuwi a'e.
\q1 
\v 9 O Tupàn, epyro neremiaihu wà nehe.
\q1 Ezapo ikatu ma'e neremiruze'eg wanupe nehe no.
\q1 Eiko àràpuhàràna'yr wamono'ogar zàwenugar neremiaihu wanupe nehe.
\q1 Ezekaiw katu wanehe tuweharupi nehe.
\c 29
\s1 Tupàn ikàg ma'e umuànoànog kar àmàn a'e
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 Tupàn heko haw pe har wà, pemume'u ikatu haw nehe.
\q1 Pemume'u ipuràg eteahy haw nehe. Ipuner haw pemume'u nehe.
\q1 
\v 2 Pemume'u Tupàn ikàgaw nehe, ipuràgaw nehe no.
\q1 Pezeamumew Tupàn Tuweharupi Wiko Ma'e ikatuahy ma'e henataromo nehe,
\q1 Peme izexak kar mehe nehe.
\b
\q1 
\v 3 Teko weinu Tuweharupi Wiko Ma'e 'y 'aromo ize'eg mehe wà.
\q1 Tupàn ikàg ma'e umuànoànog kar àmàn a'e.
\q1 Teko weinu ize'eg yryhu 'aromo a'e wà.
\q1 
\v 4 Tupàn Tuweharupi Wiko Ma'e ize'eg tynehem ikàgaw pupe a'e. Tynehem ipuner haw pupe a'e no.
\q1 
\v 5 Ize'eg uzuhaw ywyràkàxigyw a'e wà.
\q1 Uzuhazuhaw te ywyràkàxigyw Irimano ywytyr rehe har a'e wà.
\q1 
\v 6 Omopoopor kar ywytyr Irimano her ma'e tapi'aka'yr ài wà.
\q1 Ywytyr Eremon her ma'e omopoopor tapi'aka'yr awa ài a'e.
\q1 
\v 7 Tupàn Tuweharupi Wiko Ma'e ize'egaw umuhyape katu kar àmàn iweraw paw a'e.
\q1 
\v 8 Ize'eg umuryryryryz kar ywyxiguhu.
\q1 Umuryryz ywyxiguhu Kanez her ma'e.
\q1 
\v 9 Ize'egaw umutuhug ywyra kawar her ma'e wà.
\q1 O'ok huwer ywyra wi.
\q1 A'e 'ar mehe we, hàpuzuhu pupe, teko paw uhapukaz wà.
\q1 — Tuwe teko umume'u Tupàn ikatuahy haw a'e wà nehe, i'i wà.
\b
\q1 
\v 10 Tupàn Tuweharupi Wiko Ma'e upyta 'y typya'u ma'e i'aromo tuwihawete romo.
\q1 Tuwihawete romo upureruze'eg putar tuweharupi nehe.
\q1 
\v 11 Tupàn Tuweharupi Wiko Ma'e umur ukàgaw wemiaihu wanupe.
\q1 Umur uze'egatu wanehe. Umur ikatuahy ma'e paw wanupe.
\c 30
\s1 Màno haw wi ipyro pyrer umume'u Tupàn ikatu haw izupe
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 O Tupàn Tuweharupi Wiko Ma'e, amume'u nekatu haw, ta'e hepyro pe ne xe.
\q1 Neremupuka kar kwaw heàmàtyry'ymar herehe ne wà.
\q1 
\v 2 O Tuweharupi Wiko Ma'e hezar, ahapukaz newe ihe. — Hepytywà pe nehe, a'e newe.
\q1 A'e rupi hemukatu pe ne.
\q1 
\v 3 Hepyro pe hemàno àwàm wi ne.
\q1 A'e 'ar mehe aiko umàno ma'e kwer waneta haw pe oho ma'e ràm wainuromo ihe.
\q1 Hemuigo kar wi pe ne.
\q1 
\v 4 Pezegar Tupàn Tuweharupi Wiko Ma'e pe nehe, ikatu haw rehe nehe.
\q1 Pe, hemiaihu hehe uzeruzar ire upytu'u 'ym ma'e wà.
\q1 Pema'enukwaw Tupàn ikatuahy ma'e hemiapo kwer rehe nehe.
\q1 Pemume'u peme hemiapo kwer ikatu haw izupe nehe.
\q1 
\v 5 Neremumaw kwaw 'ar tetea'u nekwahy pà ne.
\q1 Nekatu haw nupytu'u pixik kwaw.
\q1 Amo upuner pytun gatu imumaw paw rehe uzai'o pà ma'e rehe a'e wà.
\q1 Iku'em mehe ur wi hurywete haw.
\b
\q1 
\v 6 — Nuzeapo kwaw ikatu 'ym ma'e ihewe nehe, a'e hezeupe.
\q1 — Ni amo nahereityk kwaw wà nehe, a'e hezeupe.
\q1 
\v 7 O Tupàn Tuweharupi Wiko Ma'e, nekatu ihewe.
\q1 Ereiko taw imuàtà pyrer ywytyruhu rehe har ài ihewe, heàmàtyry'ymar wanuwi hepyro pà.
\q1 Ihewe nezeàmim mehe
\q1 Akyze tuwe ihe.
\q1 
\v 8 O Tupàn Tuweharupi Wiko Ma'e, uruwenoz ihe.
\q1 — Hepytywà pe nehe, a'e newe.
\q1 
\v 9 Aze àmàno nehe, na'ikatu kwaw newe nehe.
\q1 Aipo umàno ma'e kwer upuner nekatu haw imume'u haw rehe wà.
\q1 Nerepuir kwaw neremiaihu wanuwi. Aipo umàno ma'e kwer upuner nepuir 'ymaw imume'u haw rehe wà.
\q1 
\v 10 O Tupàn, herenu pe hepuhareko pe nehe.
\q1 Hepytywà pe nehe, o Tupàn Tuweharupi Wiko Ma'e.
\b
\q1 
\v 11 Hemupytu'u kar pe hezai'o re. Hemupynyk kar pe turywete haw rehe kury.
\q1 Eremunyryk zemumikahy haw ihewi ne.
\q1 Hemono pe turywete haw inuromo no.
\q1 
\v 12 A'e rupi napytu'u kwaw hezegar ire nehe.
\q1 Azegar putar newe nekatu haw rehe nehe.
\q1 O Tuweharupi Wiko Ma'e, ereiko hezar romo.
\q1 Nekatu haw amume'u putar newe tuweharupi nehe.
\c 31
\s1 Tupàn rehe zeruzar haw
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 O Tupàn Tuweharupi Wiko Ma'e. Aha newe hepyro àwàm hekar pà ihe.
\q1 Hemunyryk kar pe hereityk àwàm rehe hemaranugar àwàm wi nehe.
\q1 Nekatuahy ne. Hepytywà àwàm ainoz newe.
\q1 
\v 2 Herenu pe hepyro pà na'arewahy kury.
\q1 Eiko itahu ài hemimaw romo nehe.
\q1 Eiko hepyro har romo nehe no.
\q1 
\v 3 Ereiko itahu hemimaw ài ne. Ereiko tàpuz imuàtà pyr heàmàtyry'ymar wanuwi hemimaw romo.
\q1 Hemuata katu kar pe nehe, hemu'e pe nehe, neremimume'u kwer rupi katete nehe.
\q1 
\v 4 Hemu'ar kar zo miar zuka haw zàwenugar pupe nehe, heàmàtyry'ymar wanemiapo kwer pupe nehe,
\q1 Ta'e ereiko hemimaw romo ne xe.
\q1 
\v 5 Amono hereko haw nepo pe.
\q1 O Tuweharupi Wiko Ma'e, hepyro putar pe nehe,
\q1 Ta'e ne Tupàn ereiko puruwi upuir 'ym ma'e romo ne xe.
\b
\q1 
\v 6 Tupàn ua'u wamuwete har iro newe wà.
\q1 Xo nerehe zo azeruzar ihe.
\q1 
\v 7 Heamutar katu pe ne, a'e rupi herurywete ihe. Herurywete azeharomoete ihe.
\q1 Apuraraw ma'erahy ihe.
\q1 Ipuraraw mehe herexak pe ne.
\q1 Erekwaw ikatu 'ym ma'e ihewe uzeapo ma'e.
\q1 
\v 8 Nahepyhyk kar kwaw pe heàmàtyry'ymar wanupe ne.
\q1 Hemonokatu pe ikatu 'ymaw wi.
\b
\q1 
\v 9 O Tupàn Tuweharupi Wiko Ma'e, hepuhareko pe nehe, ta'e apuraraw ma'erahy iteko ihe xe.
\q1 Hereha ikene'o, ta'e azai'o tetea'u ihe xe.
\q1 Hekene'o heretekwer rehe.
\q1 Uhem hekàgwer herekwe wi.
\q1 
\v 10 Hezemumikahy haw umumaw hekàgaw ihewi.
\q1 Herehaykwer weraha hekwarahy ràm ihewi no.
\q1 Nahekàg kwaw ta'e apuraraw ma'erahy tetea'u ihe xe.
\q1 Te hekagwer upaw wewer ihewi.
\b
\q1 
\v 11 Heàmàtyry'ymar upuka herehe wà.
\q1 Heruwake wiko ma'e uze'eg urywahyahy herehe wà no.
\q1 Heremigwaw ukyze ihewi wà.
\q1 Nahu rupi herexak mehe uzàn ihewi wà.
\q1 
\v 12 Upaw rupi heharaz ihewi wà.
\q1 Aiko umàno ma'e kwer zàwenugar romo wanupe ihe. Aiko ma'e heityk pyrer zàwenugar romo.
\q1 
\v 13 Aenu heàmàtyry'ymar wanewowo mehe ihe wà.
\q1 Teko heruwake har tetea'u umume'u hezuka àwàm waiko wà.
\q1 Umume'u hereityk àwàm uzeupeupe wà.
\q1 — Ma'e zapuner iapo haw rehe izuka pà nehe, i'i uzeupeupe wà.
\b
\q1 
\v 14 Ihe azeruzar nerehe o Tuweharupi Wiko Ma'e.
\q1 Ereiko hezar romo.
\q1 
\v 15 Tuweharupi erezekaiw katu herehe.
\q1 Hepyro pe heàmàtyry'ymar wanuwi,
\q1 Herehe ipurupyhyk wer ma'e wanuwi.
\q1 
\v 16 — Ikatu ihewe, ere ihewe nehe, herehe neme'e mehe nehe. Aiko neremiruze'eg romo ihe.
\q1 Hepyro pe nehe, ta'e heamutar katu pe ne xe.
\q1 
\v 17 O Tupàn Tuweharupi Wiko Ma'e, uruenoz iteko ihe.
\q1 Hepyro hereityk àwàm rehe hemaranugar haw wi nehe.
\q1 Tuwe ikatu 'ym ma'e imaranugar uzeityk awer rehe wà nehe.
\q1 Tuwe wezyw uze'eg 'ym pà umàno ma'e kwer wapyta haw pe wà nehe.
\q1 
\v 18 Hemu'em ma'e romo wanekon a'e wà. Tuwe nuze'eg wi kwaw wà nehe.
\q1 — Aiko wera'u amo wanuwi ihe, i'i wà. — Aiko ikàg wera'u ma'e romo pewi ihe, i'i wà.
\q1 Uze'eg zemueteahy teko Tupàn heruzar har wanehe wà.
\b
\q1 
\v 19 Eremonokatu ikatuahy ma'e newi ukyze ma'e wanupe.
\q1 Teko paw upuner nekatu haw hexakaw rehe wà.
\q1 Erezekaiw katu nerehe uzeruzar ma'e wanehe ne.
\q1 Teko paw upuner nezekaiw haw hexakaw rehe wà.
\q1 
\v 20 Ereiko wainuromo ne.
\q1 A'e rupi erepyro ikatu 'ym ma'e iapo har wanuwi ne wà.
\q1 Aze ipurapo wer ikatu 'ym ma'e rehe wanupe wà, wamim katu haw pupe erezumim ne wà, wàmàtyry'ymar wanemiapo iaiw ma'e wi ne wà.
\b
\q1 
\v 21 Tuwe pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe.
\q1 Heàmàtyry'ymar heywyr wamàmàn mehe, heàmàtyry'ym mehe,
\q1 Tupàn wexak kar tuwe heamutar katu haw a'e.
\q1 
\v 22 Akyze ihe.
\q1 — Hemono kar uzewi a'e, a'e hezeupe. Herenu herehapukaz mehe a'e.
\q1 — Hepytywà pe nehe, a'e izupe.
\q1 Wenu heze'eg mehe.
\b
\q1 
\v 23 Ezamutar katu Tupàn Tuweharupi Wiko Ma'e nehe, hemiaihu uzeruzar ire upytu'u 'ym ma'e wà.
\q1 Uzekaiw katu uzeruzar ma'e wanehe a'e.
\q1 Uzepyk amo wanuwi wiko wera'u ma'e wanehe, ta'e na'ikatu kwaw izupe wà xe.
\q1 
\v 24 Pekàg nehe, pekyze zo nehe.
\q1 Pe, Tupàn Tuweharupi Wiko Ma'e rehe uzeruzar ma'e paw rupi pe wà.
\c 32
\s1 Umume'u wemiapo kwer ikatu 'ym ma'e. Na'e Tupàn umunàn izuwi
\b
\q1 
\v 1 Aze Tupàn umunàn hemiapo kwer ikatu 'ym ma'e amo wi nehe,
\q1 Aze o'ok hemiapo kwer rehe ima'enukwaw paw izuwi nehe, hurywete putar a'e teko a'e nehe.
\q1 
\v 2 Aze Tupàn Tuweharupi Wiko Ma'e numume'u kwaw ikatu 'ym ma'e neremiapo kwer nehe, nerurywete putar nehe.
\q1 Ikatu 'ym ma'e iapo har 'ym hurywete putar wà nehe no.
\b
\q1 
\v 3 Ikatu 'ym ma'e heremiapo kwer Tupàn pe imume'u 'ym mehe we ihe,
\q1 Hekene'o ihe, hezai'o tetea'u pà 'ar katu ihe.
\q1 
\v 4 'Aromo nehe, pyhaw nehe no, herehe erezepyk, o Tupàn.
\q1 Zuwiri ukàzym hakuahy haw kwarahy mehe har rehe a'e.
\q1 Nezewegatete hekàgaw upaw ihewi a'e.
\q1 
\v 5 A'e rupi amume'u ikatu 'ym ma'e heremiapo kwer newe ihe.
\q1 Namim kwaw hekatu 'ymaw newi.
\q1 — Amume'u putar heremiapo kwer Tupàn pe ihe nehe, a'e hezeupe.
\q1 A'e rupi eremunàn ikatu 'ymaw paw ihewi ne.
\b
\q1 
\v 6 Nezewe mehe, tuwe neamutar katu har paw uze'eg newe wà nehe,
\q1 Ma'erahy ipuraraw mehe wà nehe.
\q1 Nezewe mehe, ma'erahyhu ykotok ài tur mehe nehe,
\q1 Nuhem kwaw a'e teko wanupe nehe.
\q1 
\v 7 Ereiko hemimaw romo ne.
\q1 Hepyro ma'erahy wi.
\q1 Azegar tuwe nepurupyro haw rehe ihe,
\q1 Ta'e hepyk heàmàtyry'ymar wanuwi ne xe.
\q1 
\v 8 Tupàn Tuweharupi Wiko Ma'e uze'eg ihewe.
\q1 — Urumu'e putar pe neho àwàm rehe ihe nehe.
\q1 Aexak kar putar neho àwàm nehe. Akwaw kar putar neremiapo ràm nehe no.
\q1 
\v 9 Kawaru a'e, kawaràn a'e no, ma'e kwaw par 'ym romo wanekon a'e wà. Eiko zo wazàwe nehe.
\q1 Ximuata kar waàkàg rehe har pupe zane, wahàm pupe zane.
\q1 Xo nezewe mehe zo oho zaneremimutar rupi wà.
\q1 
\v 10 Ikatu 'ym ma'e iapo har a'e wà, upuraraw ma'erahy tetea'u a'e wà.
\q1 Aze teko uzeruzar Tupàn Tuweharupi Wiko Ma'e rehe wà,
\q1 Tupàn uzekaiw katu wanehe upuruamutar katu haw inuromo a'e.
\q1 
\v 11 Pe ikatu ma'e paw rupi pe wà, penurywete nehe.
\q1 Penurywete tuwe Tuweharupi Wiko Ma'e hemiapo kwer rehe nehe.
\q1 Pe Tupàn heruzar har pe wà, pezegar penurywete romo nehe.
\c 33
\s1 Zegar haw Tupàn ikatu haw imume'u haw
\q1 
\v 1 Pe Tupàn heruzar har paw rupi pe wà,
\q1 Penurywete Tupàn Tuweharupi Wiko Ma'e hemiapo kwer rehe nehe.
\q1 Pe Tupàn heruzar har paw pe wà, pemume'u Tupàn ikatu haw nehe.
\q1 
\v 2 Pemupu wioràwiràn Tupàn Tuweharupi Wiko Ma'e ikatu haw imume'u pà nehe.
\q1 Pemuzàg zegar haw Tupàn ikatu haw imume'u haw nehe, wioràwiràn 10 ihàm hereko har imupu pà nehe.
\q1 
\v 3 Pemuzàg zegar haw ipyahu ma'e Tupàn pe nehe.
\q1 Pemupu pewioràwiràn pezegar pà wahyhaw rupi nehe.
\b
\q1 
\v 4 Tupàn Tuweharupi Wiko Ma'e ze'eg azeharomoete har romo a'e.
\q1 Zapuner hemiapo nànàn zanezeruzar haw rehe zane.
\q1 
\v 5 Tupàn Tuweharupi Wiko Ma'e uzamutar katu ikatu ma'e a'e. Uzamutar katu ikatu haw no.
\q1 Ywy tynehem ipuruamutar katu haw pupe a'e.
\b
\q1 
\v 6 Uze'eg Tupàn Tuweharupi Wiko Ma'e ywak iapo pà a'e.
\q1 Umume'u wemimutar kwarahy iapo pà, zahy iapo pà no, zahytata iapo pà no.
\q1 
\v 7 Omono'og Tupàn yryhu paw pitài yryhu romo iapo pà.
\q1 Omonokatu 'y yryhu rehe har imonokatu haw pupe no.
\q1 
\v 8 Tuwe ywy paw ukyze Tupàn Tuweharupi Wiko Ma'e wi nehe.
\q1 Tuwe ywy rehe har paw ukyze izuwi wà nehe.
\q1 
\v 9 Ta'e uze'eg ywy iapo pà a'e xe.
\q1 Umume'u ma'e paw wazexak kar àwàm. Na'arewahy ma'e paw uzexak kar a'e wà.
\b
\q1 
\v 10 Tupàn Tuweharupi Wiko Ma'e umumaw ywy nànànar wanemiapo putar haw a'e.
\q1 Nuzapo kar kwaw wanemimutar a'e teko wanupe a'e.
\q1 
\v 11 Aze Tupàn Tuweharupi Wiko Ma'e umume'u amo ma'e wemiapo ràm a'e, a'e ma'e nukàzym pixik kwaw nehe.
\q1 Hemiapo putar haw nupaw pixik kwaw nehe.
\q1 
\v 12 Aze amo ywy rehe har wereko Tuweharupi Wiko Ma'e uzar romo wà, hurywete wà.
\q1 Aze Tupàn wexaexak amo teko wà, wemiaihu romo wamuigo kar pà wà, hurywete a'e teko wà.
\b
\q1 
\v 13 Tupàn Tuweharupi Wiko Ma'e ume'e ywy rehe ywak rehe wiko mehe a'e.
\q1 Wexak teko paw wà.
\q1 
\v 14 Weko haw pe wiko mehe
\q1 Ume'e ywy rehe har nànàn a'e.
\q1 
\v 15 Tupàn uzapo teko ima'enukwaw ma'e romo a'e wà.
\q1 Ukwaw wanemiapo kwer upaw rupi a'e.
\b
\q1 
\v 16 Amo tuwihawete nuweityk kwaw amo tuwihawete zauxiapekwer ikàg ma'e wamono kar pà ikutyr.
\q1 Hemiruze'eg zauxiapekwer nuweityk kwaw inugwer ukàgaw rupi wà.
\q1 
\v 17 Kawaru zeàmàtyry'ymawhu pe har nuweityk kwaw a'e tuwihawete wà.
\q1 Wakàgaw uhua'u ma'e nupuner kwaw wyzài teko wapyro haw rehe wà.
\q1 
\v 18 Xo Tupàn Tuweharupi Wiko Ma'e zo upyro izuwi ukyze ma'e a'e wà.
\q1 Xo a'e zo omonokatu ipuruamutar katu haw rehe uzeruzar ma'e wà.
\q1 
\v 19 Upyro wamàno haw wi wà.
\q1 Umuigo kar wiwi temi'u heta 'ym mehe wà no.
\b
\q1 
\v 20 Xiàro Tupàn Tuweharupi Wiko Ma'e hemiapo ràm ikatu ma'e zane.
\q1 Wiko zanepytywà har romo a'e. Nuzawy kwaw u'yw wi zanemimaw ài no.
\q1 
\v 21 Zanepy'a hurywete
\q1 Tupàn Tuweharupi Wiko Ma'e hemiapo kwer rehe zane.
\q1 Zazeruzar hehe ta'e ikatuahy a'e xe.
\b
\q1 
\v 22 O Tupàn Tuweharupi Wiko Ma'e, tuwe nepuruamutar haw wiko ureinuinuromo nehe,
\q1 Ta'e xiàro neremiapo ràm ikatu ma'e zane xe.
\c 34
\s1 Tupàn ikatu haw
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 Tuweharupi amume'u putar Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe.
\q1 'Ar nànàn hezuru umume'u putar ikatu haw nehe.
\q1 
\v 2 Amume'u putar ikatu haw nehe, ta'e uzapo ikatuahy ma'e a'e xe.
\q1 Ma'erahy ipuraraw par wenu putar ko heze'eg wà nehe. Hurywete putar henu mehe wà nehe.
\q1 
\v 3 Pemume'u Tupàn Tuweharupi Wiko Ma'e uhua'u haw herehe we nehe.
\q1 Pemume'u ikatu haw heinuinuromo nehe.
\b
\q1 
\v 4 — Hepytywà pe nehe, a'e Tupàn Tuweharupi Wiko Ma'e pe ihe. Uwazar heze'eg ihewe a'e.
\q1 Hepyro ma'e wi hekyze haw wi upaw rupi a'e.
\q1 
\v 5 Aze teko ikatu 'ym ma'e upuraraw kar ma'erahy amo wanupe wà, ipuraraw par ume'e hehe wà. Hurywete hexak mehe wà.
\q1 Nuzemumikahy pixik kwaw wà nehe, ta'e Tupàn nupuir pixik kwaw wanuwi a'e nehe xe.
\q1 
\v 6 Ihe aiko ma'erahy ipuraraw par romo ihe. Ahapukaz ihe.
\q1 Tupàn Tuweharupi Wiko Ma'e herenu a'e. Hepyro heremipuraraw wi a'e.
\q1 
\v 7 Tupàn Tuweharupi Wiko Ma'e heko haw pe har upyta Tupàn wi ukyze ma'e wanuwake a'e.
\q1 Umunyryk kar ikatu 'ymaw wanuwi wi a'e.
\b
\q1 
\v 8 Ne ae ezeagaw Tupàn Tuweharupi Wiko Ma'e ikatu haw ikwaw paw rehe nehe.
\q1 Aze Tupàn omonokatu amo teko nehe, hurywete putar a'e teko a'e nehe.
\q1 
\v 9 Tuwe Tupàn pe uzemonokatu ma'e paw ukyze izuwi wà nehe,
\q1 Ta'e uhyk putar ma'e izuwi ukyze ma'e wanupe nehe xe.
\q1 
\v 10 Te naheta kwaw temi'u zàwàruhu iriàw wanupe. Ima'uhez a'e wà.
\q1 Uhyk putar ma'e teko wanupe nehe, aze a'e teko uze'eg Tupàn Tuweharupi Wiko Ma'e pe wà nehe, — Urepytywà pe nehe, u'e pà izupe wà.
\b
\q1 
\v 11 Pezur pezeapyaka katu pà nehe, hemyrypar kwàkwàmo wà.
\q1 Apumu'e putar Tupàn Tuweharupi Wiko Ma'e wi pekyze àwàm rehe nehe.
\q1 
\v 12 Aze pepurumumaw wer kwarahy tetea'u wanehe peneko pà nehe,
\q1 Aze penurywete wer kwarahy tetea'u rehe nehe,
\q1 
\v 13 pezeagaw ikatu 'ym ma'e imume'u 'ymaw rehe nehe.
\q1 Penemu'em zo nehe.
\q1 
\v 14 Petyryk ikatu 'ym ma'e wi nehe. Pezapo ikatu ma'e peho peiko nehe.
\q1 Pekar zeàmàtyry'ym 'ymaw rehe peneko àwàm nehe. Pezapo ma'e paw katu haw hexak pà nehe.
\b
\q1 
\v 15 Tupàn uzekaiw katu teko imunar 'ym ma'e wanehe hemu'em 'ym ma'e wanehe a'e.
\q1 Weinu a'e wà, aze a'e teko wenoz ma'e izupe a'e wà.
\q1 
\v 16 Wiko ikatu 'ym ma'e iapo har waàmàtyry'ymar romo a'e.
\q1 A'e rupi, wamàno re amo teko heharaz wanuwi na'arewahy wà.
\q1 
\v 17 Amo teko weruzar Tupàn Tuweharupi Wiko Ma'e wà.
\q1 Aze a'e teko wenoz Tupàn a'e wà, a'e wenu waze'eg mehe wà.
\q1 Upyro ma'erahy paw wi wà.
\q1 
\v 18 Tupàn upyta uzemumikahy ma'e wanuwake a'e.
\q1 Upyro teko upyro àwàm hàro re upytu'u ma'e a'e wà.
\b
\q1 
\v 19 Ikatu ma'e upuraraw ma'erahy tetea'u wà.
\q1 Tuweharupi Wiko Ma'e upyro a'e teko ma'erahy nànàn wà.
\q1 
\v 20 Upyro tuwe a'e wà, waàmàtyry'ymar wanuwi wamunyryk kar pà a'e wà.
\q1 Nuzuhaw kwaw ni pitài wàkàgwer wà.
\q1 
\v 21 Wakatu 'ymaw uzuka kar putar teko ikatu 'ym ma'e wà nehe.
\q1 Aze amo na'iakatuwawahy kwaw ikatu ma'e wanehe wà nehe, Tupàn uzepyk putar a'e teko wanehe nehe.
\q1 
\v 22 Tupàn Tuweharupi Wiko Ma'e upyro wemiruze'eg wamàno haw wi wà.
\q1 — Hepyro pe nehe, aze amo i'i izupe wà nehe, Tupàn nuzepyk kwaw a'e teko wanehe nehe.
\c 35
\s1 Tupàn pe ze'egaw upytywà haw henoz taw
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 O Tupàn Tuweharupi Wiko Ma'e, ezàmàtyry'ym heàmàtyry'ymar ne wà nehe.
\q1 Eityk herehe ipureityk wer ma'e ne wà nehe.
\q1 
\v 2 Epyhyk u'yw wi nemimaw nehe. Epyhyk nekamir tàtà ma'e nehe no.
\q1 Ezur hepytywà pà nehe.
\q1 
\v 3 Epyhyk nepurukutukaw ipuku ma'e nehe. Epyhyk itazy puruzuka haw nehe no.
\q1 Ezàmàtyry'ym herehe ipuruzuka wer ma'e ne wà nehe.
\q1 Hepyro har romo nereko haw emume'u ihewe nehe.
\q1 
\v 4 Tuwe amo weityk
\q1 Herehe ipuruzuka wer ma'e a'e wà nehe.
\q1 Tuwe wiko ikàg 'ym ma'e wazàwe wà nehe.
\q1 Tuwe hezuka àwàm imume'u har uzàn oho umaranugar romo wà nehe.
\q1 
\v 5 Tuwe nuzawy kwaw ka'akyr ywytu hemiraha wà nehe,
\q1 Tupàn Tuweharupi Wiko Ma'e heko haw pe har wakutyr tur mehe wà nehe.
\q1 
\v 6 Tuwe wanape ràm uzeapo hexak katu pyr 'ym nehe.
\q1 Tuwe ihym wapy iwype nehe, Tupàn Tuweharupi Wiko Ma'e heko haw pe har wanaikweromo iho mehe nehe.
\q1 
\v 7 Uzapo e miar zuka haw zàwenugar a'e wà, herehe ipuruzuka mehe a'e wà xe.
\q1 Uzapo ywykwaruhu ohoete ma'e hepyhyk àwàm romo wà.
\q1 
\v 8 Nezewe rehe we, wamàno haw uhem putar wanupe hàro 'ym mehe nehe.
\q1 Wanemiapo kwer miar zuka haw zàwenugar upyhyk putar a'e teko a'e wà nehe.
\q1 U'ar putar ywykwar pupe wà nehe. Uzezuka kar putar ipupe wà nehe.
\b
\q1 
\v 9 A'e mehe herurywete putar ihe nehe,
\q1 Tupàn hemiapo kwer rehe ihe nehe.
\q1 Hemurywete kar putar nehe, ta'e hepyro màno haw wi a'e xe.
\q1 
\v 10 Hepy'a paw pupe aze'eg putar newe ihe nehe.
\q1 — O Tupàn Tuweharupi Wiko Ma'e, naheta kwaw nezàwenugar a'e wà.
\q1 Aze ikàg ma'e uzàmàtyry'ym ikàg 'ym ma'e oho wà, erepytywà ikàg 'ym ma'e ne wà.
\q1 Erepyro hemetarer 'ym ma'e ne wà. Erezekaiw ma'e hereko 'ymar wanehe.
\q1 Erepyro a'e teko imunar ma'e wapo wi ne wà.
\b
\q1 
\v 11 Awa ikatu 'ym ma'e hemu'em tuwihaw wanenataromo heremiapo kwer imume'u mehe wà.
\q1 Umume'u mua'u ikatu 'ym ma'e heremiapo kwer wà. Nazapo kwaw a'e ikatu 'ym ma'e ihe.
\q1 
\v 12 Uzapo ikatu 'ym ma'e ihewe heremiapo kwer ikatu ma'e hekuzaromo wà.
\q1 A'e rupi hezemumikahy haw umynehem hepy'a a'e.
\q1 
\v 13 Wama'eahy mehe amunehew kamir umàno ma'e kwer tymaw rehe har ihe.
\q1 Apytu'u hemai'u re ihe, ta'e azemumikahy wama'eahy haw rehe ihe xe.
\q1 Azeamumew Tupàn henataromo, izupe heze'eg pà wamukatu àwàm henoz tà.
\q1 
\v 14 Wanehe Tupàn pe heze'eg awer nuzawy kwaw hemyrypar rehe heze'eg awer. Nuzawy kwaw herywyr rehe heze'eg awer.
\q1 Ata hezeamumew pà umàno ma'e kwer itymaw rehe har ài ihe.
\q1 Nazawy kwaw uhy imàno awer rehe uzai'o ma'e ihe.
\b
\q1 
\v 15 Na'e ma'erahy apuraraw ihe. A'e teko hurywete hema'erahy rehe wà.
\q1 Upyta heywyr herehe upukapuka pà wà.
\q1 Teko heremigwaw 'ym ukwaukwar herehe wà.
\q1 Hemuahyahy kar wà no.
\q1 
\v 16 Nuzawy kwaw uzemumyz 'ym ma'e rehe upuka ma'e wà. Upuka nezewe herehe uze'eg urywahyahy pà wà.
\q1 Ume'eahy herehe wà, na'iakatuwawahy kwaw herehe wà.
\q1 
\v 17 O hezar, màràn 'ar eremumaw putar wanehe neme'e e pà nehe.
\q1 Hepyro wanuwi nehe, heàmàtyry'ym mehe nehe.
\q1 Hepyro a'e zàwàruhu iriàw zàwenugar wanuwi nehe.
\q1 
\v 18 A'e mehe amume'u putar nekatu haw teko tetea'u wanenataromo ihe nehe.
\q1 Teko tetea'u wamyter pe aze'eg putar nekatuahy haw rehe nehe.
\b
\q1 
\v 19 Emurywete kar zo heàmàtyry'ymar hemu'em ma'e
\q1 Heretykaw rehe ne wà nehe.
\q1 Amo teko na'iakatuwawahy e kwaw herehe wà.
\q1 Emupuka kar zo herehe ne wà nehe.
\q1 Emupytu'u hemuaiw pawer rehe wapuka re ne wà nehe.
\q1 
\v 20 Nuze'eg kwaw uzemuryparypar ma'e ài wà.
\q1 Hemu'em tetea'u katu haw
\q1 Iputar har wanehe wà.
\q1 
\v 21 — Uzapo ikatu 'ym ma'e a'e, i'i mua'u tuwihaw wanenataromo herehe uhapukaz tà wà.
\q1 — Uruexak ikatu 'ym ma'e neremiapo kwer ure, i'i mua'u wà.
\b
\q1 
\v 22 Ne o Tupàn Tuweharupi Wiko Ma'e erexak wanemu'em mehe ne wà.
\q1 A'e rupi epytu'u zo wakatu 'ymaw imume'u re nehe.
\q1 Eiko zo muite ihewi nehe.
\q1 
\v 23 Eme'e, hezar, hekatu haw imume'u pà nehe.
\q1 Epu'àm, hezar, heremiapo kwer ikatu haw rehe neze'eg pà nehe.
\q1 
\v 24 O Tupàn Tuweharupi Wiko Ma'e, nekatuahy ne.
\q1 A'e rupi emume'u ikatu 'ym ma'e iapo 'ymar romo hereko haw nehe.
\q1 O hezar, emurywete kar zo heàmàtyry'ymar
\q1 Herehe ne wà nehe.
\q1 
\v 25 Emuze'eg kar zo nezewe ne wà nehe.
\q1 — Ximumaw zane. Nezewe haw xiputar zane, i'i wer wà.
\q1 Tuwe ni'i kwaw nezewe wà nehe.
\b
\q1 
\v 26 Eityk ma'erahy heremipuraraw rehe hurywete ma'e ne wà nehe. Tuwe maranugar haw upyk a'e teko wà nehe.
\q1 — Zaiko wera'u izuwi zane, i'i amo wà.
\q1 Tuwe wamaranugar haw upyk a'e teko wà nehe.
\q1 Tuwe iaiw paw upyk wà nehe no.
\q1 
\v 27 Amo teko uputar hekatu haw imume'u àwàm wà nehe.
\q1 Tuwe a'e teko uhapukaz urywete haw rehe wà nehe.
\q1 Tuwe uze'eg nezewe tuweharupi wà nehe.
\q1 — Tupàn Tuweharupi Wiko Ma'e uhua'u a'e.
\q1 Hurywete a'e no, ta'e oho katu hemiruze'eg heko haw a'e no xe, tuwe i'i wà nehe.
\q1 
\v 28 Na'e amume'u putar nekatuahy haw ihe nehe.
\q1 Aze'eg putar nekatu haw rehe nehe, 'ar nàn nehe.
\c 36
\s1 Teko wakatu 'ymaw, Tupàn ikatu haw
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 Ikatu 'ymaw nuzuawy kwaw
\q1 Uze'eg ma'e iaiw ma'e ipy'a pe a'e.
\q1 Iaiw ma'e nuzemu'e kwaw Tupàn wi ukyze haw rehe.
\q1 
\v 2 — Aiko wera'u amo wanuwi ihe, i'i uzeupe.
\q1 — Tupàn nuexak kwaw heremiapo kwer ikatu 'ym ma'e a'e nehe.
\q1 Nuzepyk kwaw herehe nehe, i'i uzeupe.
\q1 
\v 3 Ize'egaw na'ikatu kwaw a'e. Tynehem temu'emaw pupe.
\q1 Nukwaw katu kwaw ma'e a'e. Na'ipurapo wer kwaw ikatu ma'e rehe.
\q1 
\v 4 U'aw uker haw rehe iaiw ma'e wemiapo ràm rehe uma'enukwaw pà.
\q1 Pe ikatu 'ym ma'e rupi wata iko.
\q1 Nuweityk pixik kwaw ikatu 'ym ma'e.
\b
\q1 
\v 5 O Tupàn Tuweharupi Wiko Ma'e, nepuruamutar katu haw uhem ywak rehe a'e.
\q1 Puruwi netyryk pixik 'ymaw oho ywàkun pe no.
\q1 
\v 6 Nekatu haw ikàg ywytyruhu ài.
\q1 Neze'eg typya'u yryhu ài.
\q1 O Tupàn Tuweharupi Wiko Ma'e, erezekaiw teko wanehe ne. Erezekaiw ma'ea'yr wanehe no.
\q1 
\v 7 Ikatuahy nepuruamutar haw.
\q1 Nepepo iwype uruexak urepyro haw.
\q1 
\v 8 Eremur temi'u tetea'u urewe ne. Ikatuahy a'e temi'u urewe.
\q1 Nekatu haw nuzawy kwaw yrykaw urewe.
\q1 Uremui'u kar pe a'e 'y pupe ne.
\q1 
\v 9 Ereiko ma'e paw wamuigo kar har romo.
\q1 Ereiko tatainy zàwenugar romo no, a'e rupi xixak tatainy zane.
\b
\q1 
\v 10 O Tupàn, ezamutar katu wiwi nekwaw par ne wà nehe.
\q1 Ezapo wiwi ikatu ma'e teko nereruzar har wanupe nehe no.
\q1 
\v 11 Tuwe amogwer wanuwi wiko wera'u ma'e nuzypyrog kwaw herehe wà nehe. Tuwe ikatu 'ym ma'e nuzypyrog kwaw herehe wà nehe no.
\q1 Tuwe nahemuzàn kar kwaw wà nehe.
\q1 
\v 12 Pe pe wanekon u'ar ma'e kwer romo wà. Amo weityk wà.
\q1 Nupuner kwaw upu'àmaw rehe wà.
\c 37
\s1 Ikatu 'ym ma'e wahykaw, ikatu ma'e wahykaw no
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 Nema'enukwawahy zo ikatu 'ym ma'e wanehe nehe.
\q1 Ikatu 'ym ma'e iapo har wanehe nerewyrowyroahy zo nehe.
\q1 
\v 2 Ukàzym putar na'arewahy ka'a uxinig ma'e kwer ài wà nehe,
\q1 Ka'akyr umàno ma'e kwer ài wà nehe.
\b
\q1 
\v 3 Ezeruzar Tupàn Tuweharupi Wiko Ma'e rehe ikatu ma'e iapo pà nehe.
\q1 Eiko katu tuwe ywy imume'u pyrer rehe nehe.
\q1 
\v 4 Tuwe nerurywete Tupàn Tuweharupi Wiko Ma'e inuromo nehe.
\q1 Umur putar neremimutar nepy'a pe har newe upaw rupi nehe.
\b
\q1 
\v 5 Ezemonokatu nereko haw Tupàn Tuweharupi Wiko Ma'e ipo pe nehe.
\q1 Ezeruzar hehe nehe. Nepytywà putar nehe.
\q1 
\v 6 Neremu'em 'ymaw nehe, nemunar 'ymaw nehe no, umuigo kar putar tatainy ài nehe.
\q1 Umuhyape katu kar putar nekatu haw nehe, kwarahy wapyter pe hin mehe har ài nehe.
\b
\q1 
\v 7 Aze amo wiko hemetarer katu ma'e romo wà nehe, eikwahy zo wanupe nehe.
\q1 Nerewyrowyroahy zo ikatu 'ym ma'e rehe ipurapo wer ma'e wanehe nehe, aze uzapo a'e ma'e wà nehe.
\q1 Eàrogatu uzeapo ma'e ràm nehe. Ta'e Tupàn Tuweharupi Wiko Ma'e uzepyk putar wanehe nehe.
\b
\q1 
\v 8 Eikwahy zo nehe, nepuruzukaiw zo nehe.
\q1 Nerehaite zo nehe, ta'e nereko haw iaiw putar newe nehe xe.
\q1 
\v 9 Tupàn Tuweharupi Wiko Ma'e rehe uzeruzar ma'e
\q1 Wiko katu putar ywy imume'u pyrer rehe wà nehe.
\q1 Ikatu 'ym ma'e uzemumaw putar wà nehe.
\b
\q1 
\v 10 Nan kwehe tete teko ikatu 'ym ma'e ukàzym putar wà nehe.
\q1 Erekar putar eho nehe wà nehe. Nerexak kwaw wà nehe.
\q1 
\v 11 Amo wanuwi wiko wera'u 'ym ma'e wiko putar katu haw rehe wà nehe, ywy imume'u pyrer rehe wà nehe.
\q1 Hurywete putar wà nehe. Heta tetea'u putar ma'e wanupe nehe no. Wiko putar zeàmàtyry'ym 'ymaw rehe wà nehe.
\b
\q1 
\v 12 Ikatu 'ym ma'e umume'u wemiapo ràm iaiw ma'e a'e wà, ikatu ma'e wanupe wemiapo ràm a'e wà.
\q1 Ume'e wanehe iakatuwawahy 'ym pà wà.
\q1 
\v 13 Zanezar upuka iko teko ikatu 'ym ma'e wanehe,
\q1 Ta'e ukwaw wa'ar ihem etea'i haw a'e xe.
\q1 
\v 14 Ikatu 'ym ma'e wenuhem utakihepuku wà. Umuapar uwyrapar wà no.
\q1 Ipuruzuka wer zepe hemetarer 'ym ma'e wanehe wà, ma'e hereko 'ymar wanehe wà no.
\q1 Ipurumumaw wer hemu'em 'ym ma'e wanehe imunar 'ym ma'e wanehe wà no.
\q1 
\v 15 Ipuruzuka wer zepe wanehe wà. Amo uzuka putar a'e ikatu 'ym ma'e a'e wà nehe, watakihepuku pupe a'e wà nehe.
\q1 Uwyrapar uzuhaw putar wà nehe no.
\b
\q1 
\v 16 Aze amo nuwereko kwaw ma'e tetea'u a'e, aze wiko ikatu ma'e romo a'e,
\q1 Hereko haw ikatu wera'u hemetarer katu ma'e heko haw wi a'e, aze hemetarer katu ma'e wiko ikatu 'ym ma'e romo a'e.
\q1 
\v 17 Ikatu 'ym ma'e wakàgaw upaw putar nehe.
\q1 Tupàn Tuweharupi Wiko Ma'e umunyryk kar ikatu ma'e ikatu 'ymaw wi wà nehe.
\b
\q1 
\v 18 Tupàn Tuweharupi Wiko Ma'e uzekaiw ikatu ma'e wanehe tuweharupi a'e.
\q1 Ywy imume'u pyrer rehe wanekon putar awyzeharupi wà nehe.
\q1 
\v 19 Kwarahy ikatu 'ym ma'e mehe nupuraraw kwaw ma'erahy wà nehe.
\q1 Heta putar wanemi'u ràm wanupe ma'uhez taw uhua'u ma'e mehe nehe.
\b
\q1 
\v 20 Ikatu 'ym ma'e umàno putar wà nehe.
\q1 Tupàn Tuweharupi Wiko Ma'e iàmàtyry'ymar ukàzym putar ma'eputyr ka'a pe har ài wà nehe.
\q1 Tàtàxiner ài ukàzym putar wà nehe.
\b
\q1 
\v 21 Ikatu 'ym ma'e wenoz temetarer imekuzar pyr a'e wà. Numuzewyr kwaw izar pe wà.
\q1 Ikatu ma'e hurywete ma'e imono mehe amo pe wà.
\q1 
\v 22 Tupàn omono uze'egatu amo teko wanehe.
\q1 A'e teko wiko putar katu haw rehe ywy imume'u pyrer rehe wà nehe.
\q1 Omono uze'egaiw amo wanehe. Umumaw putar a'e teko wà nehe.
\b
\q1 
\v 23 Tupàn Tuweharupi Wiko Ma'e umuata katu kar teko pe ikatu ma'e rupi wà.
\q1 Aze teko ikatu izupe wà nehe, Tupàn omonokatu putar a'e teko a'e wà nehe.
\q1 
\v 24 Aze u'ar wà nehe, nupyta kwaw ywy rehe wà nehe,
\q1 Ta'e Tupàn upytywà putar a'e wà nehe xe, wamupu'àm kar pà a'e wà nehe xe.
\b
\q1 
\v 25 Kwehe mehe aiko kwàkwàmo romo ihe. Hetua'uhez tuwe ihe kury.
\q1 Nezewe rehe we naexak pixik kwaw awa ikatu ma'e Tupàn hemityk kwer ihe.
\q1 Naexak pixik kwaw ta'yr temi'u henoz mehe nahu rupi ihe wà.
\q1 
\v 26 Amo pe ma'e imono e haw ikatu izupe. Temetarer imono haw ikatu izupe no.
\q1 Ta'yr umurywete kar u wà no.
\b
\q1 
\v 27 Etyryk katu 'ymaw wi nehe. Xo ikatu ma'e zo ezapo nehe.
\q1 Nezewe mehe ereiko putar ywy imume'u pyrer rehe tuweharupi nehe.
\q1 
\v 28 Ta'e Tupàn Tuweharupi Wiko Ma'e uzamutar katu katu haw a'e xe. Uzamutar katu iawy har 'ym no.
\q1 Nutyryk kwaw wemiruze'eg uzeruzar katu ma'e wanuwi.
\q1 Uzekaiw katu wemiaihu wanehe.
\q1 Umumaw putar ikatu 'ym ma'e wazuapyapyr wà nehe.
\q1 
\v 29 Teko ikatu ma'e wereko putar ywy imume'u pyrer wà nehe.
\q1 Tuweharupi hehe wanekon putar wà nehe.
\b
\q1 
\v 30 Umume'u ma'e ma'e kwaw katu har ài wà. Tuweharupi uze'eg ikatu ma'e rehe wà no.
\q1 Uze'eg ikatuahy ma'e rehe wà.
\q1 
\v 31 Omonokatu uzar Tupàn ze'eg upy'a pe wà.
\q1 Nutyryk pixik kwaw ize'eg wi wà.
\b
\q1 
\v 32 Ikatu 'ym ma'e ume'e ikatu ma'e wanehe wà.
\q1 Uzeagaw wazuka haw rehe wà.
\q1 
\v 33 Nezewe rehe we Tupàn Tuweharupi Wiko Ma'e nomono kwaw ikatu ma'e a'e wà nehe, ikatu 'ym ma'e wapo pe a'e wà nehe.
\q1 Aze tuwihaw umume'u kar ikatu ma'e wanemiapo kwer wà nehe,
\q1 Tupàn numuzepyk kar kwaw tuwihaw wà nehe, a'e ikatu ma'e wanehe wà nehe.
\b
\q1 
\v 34 Pezeruzar Tupàn Tuweharupi Wiko Ma'e rehe nehe.
\q1 Peruzar ize'eg nehe no.
\q1 Umur putar ywy imume'u pyrer peme a'e nehe. Nezewe mehe peiko putar ikàg ma'e ikwaw pyr romo nehe.
\q1 Tupàn umumaw putar ikatu 'ym ma'e a'e wà nehe. Pexak putar wamumaw mehe pe wà nehe.
\b
\q1 
\v 35 Aexak amo awa iaiw ma'e purupe ma'erahy ipuraraw par ihe.
\q1 Ikàg wera'u teko paw wanuwi a'e. Nuzawy kwaw ywyràkàxigyw Irimano ywytyr rehe har a'e.
\q1 
\v 36 Amo 'ar mehe akwaw huwake ihe. Naexak kwaw, ta'e ukàzym a'e xe.
\q1 Aekar zepe ihe. Naexak kwaw.
\b
\q1 
\v 37 Eme'egatu ikatu ma'e wanehe nehe. Eme'e imunar 'ym ma'e hemu'em 'ym ma'e wanehe nehe.
\q1 Heta wazuapyapyr zeàmàtyry'ym 'ymaw iamutar har wanupe wà. Erexak putar waneta haw nehe.
\q1 
\v 38 Teko Tupàn ze'eg heruzar 'ymar wà nehe,
\q1 Uzemumaw kar putar paw rupi wà nehe.
\q1 Wazuapyapyr ukàzym putar wà nehe no.
\b
\q1 
\v 39 Tupàn Tuweharupi Wiko Ma'e upyro ikatu ma'e ikatu 'ymaw wi wà.
\q1 Uzekaiw katu wanehe ma'erahy ipuraraw mehe.
\q1 
\v 40 Tupàn Tuweharupi Wiko Ma'e upytywà wà, wapyro pà wà.
\q1 — Uremunyryk kar pe ikatu 'ymaw wi nehe, i'i izupe wà.
\q1 A'e rupi upyro ikatu 'ym ma'e wanuwi wà.
\c 38
\s1 Tupàn ipurupytywà haw ma'erahy ipuraraw mehe
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 O Tupàn Tuweharupi Wiko Ma'e, ezepyk zo herehe nekwahy mehe nehe.
\q1 Ihewe nekwahy mehe, ezepyk zo herehe nehe.
\q1 
\v 2 Neru'yw purumuahy kar ma'e hekutuk a'e wà.
\q1 Herehe nezepykaw nepo pe har ipuhuz katu ihewe.
\q1 
\v 3 Erekwahy ihewe ne, a'e rupi hema'eahy ihe.
\q1 Heretekwer nànàn hema'eahy
\q1 Heremiapo kwer ikatu 'ym ma'e rehe.
\q1 
\v 4 Azeapypyk iteko hekatu 'ymaw 'y zàwenugar pupe.
\q1 Heremiapo kwer ipuhuz katu wera'u ihewe.
\b
\q1 
\v 5 Hekutuk awer hezun inem pà a'e wà,
\q1 Ta'e azapo ma'e ma'e kwaw par 'ym ài ihe xe.
\q1 
\v 6 Umàno etea'i ma'e ài aiko. Azeamumew ihe.
\q1 Zi'itahy te kwarahy heixe mehe azai'o hepytu'u 'ym pà no.
\q1 
\v 7 Hema'eahy tuwe ihe.
\q1 Herakuahy haw nuzawy kwaw tata ihewe.
\q1 
\v 8 Nazawy kwaw umàno etea'i ma'e ihe. Azemumikahy no.
\q1 Hepy'a uzemumikahy.
\q1 Hekuhekuhem herahy haw wi no.
\b
\q1 
\v 9 O hezar, erekwaw heremimutar ne,
\q1 Ta'e erenu herekuhemaw paw ne xe.
\q1 
\v 10 Hepy'a unununuk na'arewahy a'e. Nahekàg kwaw ihe.
\q1 Hereha nahuhàg kwaw ihe no.
\q1 
\v 11 Hemyrypar nuhem kwaw heruwake a'e wà,
\q1 Ta'e hepereperew ihe xe.
\q1 Te heànàm utyryk ihewi wà.
\q1 
\v 12 Herehe ipuruzuka wer ma'e uzapo hepyhyk àwàm wà, hepyhyk pà wà.
\q1 Herehe ipurukutuk wer ma'e umume'u heaiw àwàm ihewe wà.
\q1 Nupytu'u kwaw ikatu 'ym ma'e ihewe iapo àwàm rehe uma'enukwaw pà wà.
\q1 
\v 13 A'e rupi azemuigo kar mua'u ma'erenu 'ymar romo wanupe ihe. Nainu mua'u kwaw waze'eg.
\q1 Uze'eg 'ym ma'e romo azeapo mua'u wanupe. A'e rupi naze'eg kwaw wanupe ihe.
\q1 
\v 14 Aiko ze'eg iwazar 'ymar ài ihe,
\q1 Ma'e henu 'ymar ài ihe.
\b
\q1 
\v 15 Nezewe rehe we azeruzar nerehe, o Tupàn Tuweharupi Wiko Ma'e.
\q1 Ne, Tupàn hezar, ereze'eg putar ihewe nehe.
\q1 
\v 16 Emurywete kar zo heàmàtyry'ymar heaiw paw rehe ne wà nehe.
\q1 Tuwe he'ar haw na'ikatu kwaw wanupe nehe.
\q1 
\v 17 Ta'e a'ar etea'i ihe xe.
\q1 Ma'erahy heremipuraraw nupaw pixik kwaw a'e.
\q1 
\v 18 Amume'u heremiapo kwer ikatu 'ym ma'e newe ihe,
\q1 Ta'e heremiapo kwer hemuzemumikahy kar a'e xe.
\q1 
\v 19 Heàmàtyry'ymar ikàg a'e wà. Huhàg a'e wà no.
\q1 Heta tetea'u teko herehe iakatuwawahy 'ym e ma'e a'e wà.
\q1 
\v 20 Amo teko uzapo ikatu 'ym ma'e ihewe ikatu ma'e hekuzaromo a'e wà.
\q1 Wiko heàmàtyry'ymar romo a'e wà, ta'e ikatu ma'e iapo haw rehe azeagaw ihe xe.
\b
\q1 
\v 21 O Tupàn Tuweharupi Wiko Ma'e epuir zo ihewi nehe.
\q1 Etyryk zo ihewi nehe, hezar.
\q1 
\v 22 Hepytywà pe kutàri, o hezar, hepyro har.
\c 39
\s1 Ma'erahy ipuraraw mehe umume'u wemiapo kwer
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 Aze'eg nezewe hezeupe ihe.
\q1 — Azekaiw katu hereko àwàm rehe ihe nehe.
\q1 Nezewe mehe heapeku nuzapo kar kwaw ikatu 'ym ma'e ihewe nehe.
\q1 Teko ikatu 'ym ma'e heywyr waneko mehe nehe,
\q1 Naze'eg kwaw ihe nehe, a'e hezeupe.
\q1 
\v 2 Naze'eg kwaw ihe. Namume'u kwaw ni pitài ze'eg ihe.
\q1 Ni katu haw rehe naze'eg kwaw ihe.
\q1 Nezewe rehe we apuraraw wera'u ma'erahy ihe.
\q1 
\v 3 Hepy'a uzemumikahy tuwe no.
\q1 Hema'enukwaw mehe azemumikahy wera'u ihe.
\q1 A'e rupi azypyrog hepuranu haw rehe Tupàn rehe kury.
\q1 
\v 4 — O Tupàn Tuweharupi Wiko Ma'e, màràn kwarahy amumaw putar hereko pà ihe rihi.
\q1 Ekwaw kar hekwarahy heta tetea'u 'ym àwàm ihewe nehe.
\q1 Màràn mehe àmàno putar nehe, a'e izupe.
\b
\q1 
\v 5 Hereko haw ihewe nemur awer na'ipuku kwaw a'e.
\q1 Hereko haw ipuku haw pixika'i nerenataromo.
\q1 Azeharomoete teko waneko haw nuzawy kwaw pytuhemaw a'e.
\q1 
\v 6 Wata oho waiko kwe rupi ma'e i'àg ài wà.
\q1 Aze uzeagaw ma'e iapo haw rehe wà, uzeagaw e wà.
\q1 Omono'og temetarer uzeupe wà. Nukwaw kwaw wemetarer izar ràm wà.
\b
\q1 
\v 7 Hezar, ma'e apuner hàro haw rehe kury.
\q1 Xo ne zo ereiko heremiàro romo ne.
\q1 
\v 8 Emunàn ikatu 'ym ma'e paw ihewi nehe.
\q1 Emuze'eg urywahyahy kar zo iranaiw ma'e herehe ne wà nehe.
\q1 
\v 9 Naze'eg kwaw.
\q1 Namume'u kwaw ma'e, ta'e ne ereiko ko ma'erahy ihewe ipuraraw kar arer romo ne xe.
\q1 
\v 10 Hezar, epytu'u herehe nezepyk ire nehe,
\q1 Ta'e hepetepetek awer wi àmàno etea'i ihe xe.
\q1 
\v 11 Eremume'u ureremiapo kwer ikatu 'ym ma'e urewe.
\q1 Nezewe erezepyk urerehe, ureremiapo kwer ikatu 'ym ma'e hekuzaromo.
\q1 Ereiko pànàmiràn ài ne, ureremiamutar katu pe ne. Eremumaw a'e ma'e urewi.
\q1 Azeharomoete teko wiko pytuhemaw ài wà.
\b
\q1 
\v 12 O Tupàn Tuweharupi Wiko Ma'e, herenu pe newe heze'eg mehe nehe.
\q1 Ezeapyaka katu ma'e newe henoz mehe nehe.
\q1 Epytu'u zo ihewe neze'eg ire hezai'o mehe.
\q1 Amumaw xo màràn 'ar zo neràpuz me upyta ma'e romo ihe,
\q1 Heipy wazàwe ihe.
\q1 
\v 13 Epytu'u herehe neme'egatu re nehe.
\q1 Nezewe mehe apuner putar herurywete haw pixika'i ma'e hereko haw rehe ihe nehe,
\q1 Heho 'ym mehe we hemàno 'ym mehe we nehe.
\c 40
\s1 Umuzàg zegar haw Tupàn ikatu haw imume'u pà
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 — Tupàn Tuweharupi Wiko Ma'e hepytywà putar a'e nehe, a'e hezeupe. Àrogatu hepytywà àwàm ihe.
\q1 Uzeapyaka herehe. Wenu izupe hepytywà àwàm henoz mehe.
\q1 
\v 2 Hepyro ywykwar iaiw ma'e wi.
\q1 Herenuhem to'om heta haw wi.
\q1 Hemuapyk katu itahu rehe.
\q1 Uzapokatu heata haw.
\q1 
\v 3 Hemu'e zegar haw ipyahu ma'e imuzàgaw rehe a'e,
\q1 Tupàn Zanezar ikatu haw rehe zegar haw rehe a'e.
\q1 Teko tetea'u ukyze putar Tupàn Tuweharupi Wiko Ma'e wi wà nehe, a'e zegar haw henu mehe wà nehe.
\q1 Uzeruzar putar hehe wà nehe.
\b
\q1 
\v 4 Hurywete putar Tupàn Tuweharupi Wiko Ma'e rehe uzeruzar ma'e wà nehe.
\q1 Hurywete putar tupàn a'ua'u wanekar 'ymar wà nehe.
\q1 Hurywete putar tupàn a'ua'u wamuwete katu har wainuromo uzemono'og 'ym ma'e wà nehe.
\q1 
\v 5 O Tupàn Tuweharupi Wiko Ma'e urezar.
\q1 Erezapo ma'e uhua'u ma'e urewe ne wà.
\q1 Naheta kwaw amo nezàwenugar wà.
\q1 Eremume'u ikatuahy ma'e urewe neremiapo ràm.
\q1 Aze mo heze'eg wer a'e ma'e nànàn,
\q1 Napuner iwer mo, ta'e heta tetea'u a'e wà xe.
\q1 Teko nupuner kwaw wapapar haw rehe wà.
\b
\q1 
\v 6 Nereputar kwaw nerenataromo ma'ea'yr izuka pyr ne wà.
\q1 Nereputar kwaw arozràn newe imur pyr no.
\q1 Ma'ea'yr nerenataromo hapy pyr nerenoz kwaw ne wà.
\q1 — Pemur ma'e ihewe penemiapo kwer hekuzaromo nehe, nere kwaw teko wanupe.
\q1 Eremur hereapyakwar ihewe ne, ma'e henu kar pà ihewe ne.
\q1 
\v 7 A'e rupi aze'eg nezewe newe. — Aiko aiko xe ihe, a'e newe.
\q1 — Neze'eg ihewe imur pyrer eremuapyk kar pape neze'eg hereko har rehe ne.
\q1 
\v 8 O hezar, neremimutar iapo haw hemurywete kar a'e.
\q1 Amonokatu neze'eg hepy'a pe ihe, a'e newe.
\b
\q1 
\v 9 O Tupàn Tuweharupi Wiko Ma'e, neremiaihu paw wazemono'og mehe, amume'u ze'eg puràg wanupe ihe.
\q1 Amume'u nepurupyro haw wanupe ihe.
\q1 Napytu'u pixik kwaw imume'u re nehe. Erekwaw hepytu'u àwàm ne.
\q1 
\v 10 Namonokatu kwaw nepurupyro haw imume'u haw hezeupe ihe nehe. Amume'u putar teko wanupe nehe.
\q1 Tuweharupi aze'eg puruwi netyryk 'ymaw rehe ihe. Erepuner teko wapyro haw rehe. Amume'u nepuner haw tuweharupi no.
\q1 Neremiaihu wazemono'og mehe napyta kwaw heze'eg 'ym pà ihe.
\q1 Amume'u nepuruamutar haw ihe. Puruwi netyryk 'ymaw amume'u no.
\b
\q1 
\v 11 O Tupàn Tuweharupi Wiko Ma'e, nerepytu'u pixik kwaw ikatu ma'e romo nereko re ihewe nehe. Akwaw nepytu'u 'ym àwàm ihe.
\q1 Nepuruamutar haw a'e nehe, puruwi netyryk 'ymaw a'e nehe no, uzekaiw katu herehe tuweharupi a'e wà nehe.
\s1 Hepytywà pe nehe, Tupàn
\q1 
\v 12 Zawaiw katu haw tetea'u umàmàn heywyr wà.
\q1 Napuner kwaw wapapar haw rehe.
\q1 Heremiapo kwer ikatu 'ym ma'e hepyhyk a'e wà.
\q1 Uhem etea'i ma'e hexakaw ihewi kury.
\q1 Heremiapo kwer ikatu 'ym ma'e heta tetea'u wera'u he'aw heàkàg rehe har wanuwi wà.
\q1 A'e rupi azemumikahy ihe.
\b
\q1 
\v 13 O Tupàn Tuweharupi Wiko Ma'e, hepyro pe nehe.
\q1 Hepytywà pe kury.
\b
\q1 
\v 14 Tuwe amo weityk herehe ipuruzuka wer ma'e wà nehe, ikàg 'ym ma'e romo wamuigo kar pà wà nehe.
\q1 Tuwe hema'erahy rehe hurywete ma'e uzàn umaranugar romo wà nehe.
\q1 
\v 15 Tuwe herehe uze'eg urywahyahy ma'e u'ar iaiw paw rehe wà nehe.
\q1 Tuwe uzeapo he'o ma'e romo wà nehe no.
\b
\q1 
\v 16 Nemuwete katu har a'e wà nehe, tuwe hurywete paw rupi wà nehe. Tuwe nekatuahy wanupe nehe.
\q1 Nepurupytywà haw rehe hurywete ma'e wà nehe, tuwe uze'eg nezewe tuweharupi wà nehe.
\q1 — Uhua'u tuwe Tupàn Tuweharupi Wiko Ma'e a'e, tuwe i'i wà nehe.
\q1 
\v 17 Aiko hemetarer 'ym ma'e romo ihe. Ma'e hereko 'ymar romo aiko.
\q1 Ne, hezar, erezekaiw katu herehe ne. Hepytywà pe iko.
\q1 Ereiko hepyro har romo no.
\q1 Tuwe hepytywà haw na'iàrew kwaw nehe, hezar.
\c 41
\s1 Ima'eahy ma'e uze'eg Tupàn pe
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 Hurywete ma'e hereko 'ymar wapytywà har wà.
\q1 Tupàn Tuweharupi Wiko Ma'e upytywà putar a'e wà nehe no,
\q1 Waneko haw zawaiw katu mehe a'e wà nehe.
\q1 
\v 2 Tupàn Tuweharupi Wiko Ma'e upyro putar wà nehe. Uzekaiw putar waneko haw rehe nehe.
\q1 Umurywete kar putar ywy imume'u pyrer rehe wà nehe.
\q1 Nomono kwaw waàmàtyry'ymar wapo pe wà nehe. Nupuir kwaw wanuwi nehe.
\q1 
\v 3 Wanupaw rehe wama'eahy mehe nehe,
\q1 Tupàn Tuweharupi Wiko Ma'e upytywà putar wà nehe.
\q1 Omono wi putar wanuhàgaw wanupe nehe.
\b
\q1 
\v 4 Aze'eg nezewe Tupàn pe ihe.
\q1 — O Tupàn Tuweharupi Wiko Ma'e, azapo ikatu 'ym ma'e ihe, neze'eg ihaw pà ihe.
\q1 Hepuhareko pe hemukatu pà nehe, a'e izupe.
\q1 
\v 5 Heàmàtyry'ymar uze'eg zemueteahy herehe wà.
\q1 — Tuwe umàno nehe, i'i herehe wà. — Tuwe teko heharaz izuwi wà nehe, i'i herehe wà.
\q1 
\v 6 Aze amo wainuromo har ur herexak pà,
\q1 Numume'u kwaw ze'eg azeharomoete har.
\q1 Wexak hema'eahy haw no.
\q1 Na'e umume'u a'e ma'e oho iko amogwer wanupe.
\q1 
\v 7 Herehe iakatuwawahy 'ym ma'e uze'eg zemueteahy herehe wà, uwewowewo pà wà.
\q1 — Iaiw wera'u ma'e uzeapo putar izupe nehe, i'i uzeupe herehe wà.
\q1 
\v 8 Nezewe i'i wà.
\q1 — Ima'eahy tuwe a'e,
\q1 Nupu'àm wi pixik kwaw nehe, i'i herehe wà.
\q1 
\v 9 Te hemyrypar heremiamutar katu wera'u wiko nezewe a'e no.
\q1 Azeruzar tuwe hehe ihe.
\q1 Umai'u heràpuz me a'e.
\q1 Te a'e wiko heàmàtyry'ymar romo a'e xe.
\b
\q1 
\v 10 O Tupàn Tuweharupi Wiko Ma'e, hepuhareko pe nehe.
\q1 Emumaw hema'eahy haw hemukàg wi kar pà nehe.
\q1 Nezewe mehe apuner putar heàmàtyry'ymar wanehe hezepykaw rehe nehe.
\q1 
\v 11 Nahereityk kwaw wà nehe.
\q1 Nezewe mehe newe hekatu haw akwaw putar ihe nehe.
\q1 
\v 12 Hepytywà putar pe nehe, ta'e azapo ikatu ma'e ihe xe.
\q1 Hemuigo kar putar pe nepyr tuweharupi nehe no.
\b
\q1 
\v 13 Tuwe teko umume'u Tupàn Tuweharupi Wiko Ma'e Izaew wazar ikatu haw wà nehe.
\q1 Tuwe umume'u ikatu haw kutàri wà nehe. Tuwe umume'u ikatu haw tuweharupi wà nehe no.
\q1 Amez, amez. Azeharomoete nehe, azeharomoete nehe.
\c 42
\ms1 PAPE MOKOZ HAW
\mr 42–72
\s1 Awa uiwy wi muite wiko ma'e uze'eg Tupàn pe
\d Zegar haw Kora wanemiapo kwer
\q1 
\v 1 Arapuha iziwez 'y yrykaw pupe har pupe a'e.
\q1 Nezewegatete hereko wer nepyr, o Tupàn.
\q1 
\v 2 Neputar haw nuzawy kwaw heiwez haw ihewe.
\q1 Màràn mehe apuner putar nepyr heho haw rehe nehe.
\q1 
\v 3 Azai'o 'aromo ihe. Azai'o pyhaw no.
\q1 Herehaykwer uzeapo heremi'u romo.
\q1 Heàmàtyry'ymar upuranu herehe tuweharupi wà.
\q1 — Ma'e pe hekon Tupàn nezar a'e, i'i ihewe wà.
\b
\q1 
\v 4 Hereko awer rehe hema'enukwaw mehe hahy hepy'a ihewe.
\q1 Hema'enukwaw Tupàn Hàpuzuhu pe teko tetea'u wanupi heho awer rehe ihe.
\q1 Aexak kar ureho àwàm teko wanupe.
\q1 Uruata oroho ure paw rupi ure.
\q1 Urerurywete oroho uruzegar pà Tupàn ikatu haw imume'u pà.
\b
\q1 
\v 5 Màràzàwe tuwe azemumikahy kury.
\q1 Màràzàwe tuwe naherurywete kwaw.
\q1 Àro Tupàn ihe. Ikatu haw amume'u wiwi putar ihe nehe.
\q1 Hepyro har romo hekon. Wiko hezar romo.
\b
\q1 
\v 6-7 Hepy'a nuzawy kwaw awa imumaw pyrer ipy'a ihe.
\q1 A'e rupi hema'enukwaw Tupàn rehe.
\q1 Ykotok yryhu pe har wànoànog a'e.
\q1 'Y ywytyr Eremon pe har ywytyr Mizar pe har wezyw ypu rupi a'e.
\q1 Wànoànog uwyrykahy mehe yrykaw Zotàw pe.
\q1 Hezemumikahy haw herehe Tupàn hemimur karer
\q1 Nuzawy kwaw ykotok a'e.
\q1 
\v 8 Tuwe wexak kar heamutar katu haw ihewe 'aromo nehe.
\q1 Pyhaw amuzàg ikatu haw rehe zegar haw ihe.
\q1 Aze'eg Tupàn hemuigo kar har pe.
\q1 
\v 9 Apuranu Tupàn itahu hemimar rehe ihe.
\q1 — Màràzàwe tuwe nereharaz ihewi.
\q1 Màràzàwe tuwe heàmàtyry'ymar
\q1 Upuraraw kar ma'erahy ihewe wà, a'e izupe.
\q1 
\v 10 Te hekagwer hahy ihewe,
\q1 Heàmàtyry'ymar herehe waze'eg zemueteahy mehe.
\q1 Tuweharupi upuranu herehe wà.
\q1 — Ma'e pe hekon Tupàn nezar a'e, i'i ihewe wà.
\b
\q1 
\v 11 Màràzàwe tuwe azemumikahy ihe.
\q1 Màràzàwe tuwe naherurywete kwaw.
\q1 Nezewe rehe we àro Tupàn ikatu ma'e hemiapo ràm ihe.
\q1 Amume'u ikatu haw teko wanupe ihe no.
\q1 Wiko hepyr har romo hezar romo a'e.
\c 43
\s1 Awa uiwy wi muite wiko ma'e uze'eg Tupàn pe
\q1 
\v 1 O Tupàn, emume'u hekatu haw nehe.
\q1 Emume'u ikatu ma'e romo hereko haw nehe,
\q1 A'e teko nemuwete 'ymar wanupe nehe.
\q1 Hemunyryk kar hemu'em ma'e wanuwi nehe, ikatu 'ym ma'e wanuwi hemunyryk kar nehe.
\q1 
\v 2 Ne, o Tupàn, ereiko herehe uzekaiw ma'e romo ne.
\q1 Màràzàwe tuwe erepuir ihewi.
\q1 Màràzàwe tuwe aiko ma'erahy ipuraraw pà tuweharupi.
\q1 Màràzàwe tuwe heàmàtyry'ymar upuraraw kar ma'erahy ihewe wà.
\b
\q1 
\v 3 Emur kar neratainy ihewe nehe. Emur kar neze'eg azeharomoete har nehe no.
\q1 Hemu'e putar heho àwàm rehe wà nehe.
\q1 Hemuzewyr kar putar Xiàw ywytyr nerenaw ikatuahy ma'e pe wà nehe.
\q1 Hereraha putar neràpuzuhu nereko haw pe wà nehe.
\q1 
\v 4 A'e mehe, o Tupàn, aha putar ma'ea'yr hapy haw nerenataromo har pe nehe,
\q1 Ta'e hemurywete kar pe tuwe ne xe.
\q1 Amupu putar hewioràwiràn nehe.
\q1 Amuzàg putar nekatu haw rehe zegar haw nehe no, o Tupàn hezar.
\b
\q1 
\v 5 Màràzàwe tuwe azemumikahy ihe.
\q1 Màràzàwe tuwe naherurywete kwaw.
\q1 Nezewe rehe we àro putar Tupàn ikatu ma'e hemiapo ràm ihe nehe.
\q1 Amume'u putar ikatu haw teko wanupe ihe nehe no.
\q1 Wiko hepyro har romo hezar romo a'e.
\c 44
\s1 Wiko ikàg 'ym ma'e romo wà, nezewe rehe we uzeruzar Tupàn rehe wà
\d Zegar haw Kora wanemiapo kwer
\q1 
\v 1 O Tupàn, uruenu
\q1 Ureipy wanemimume'u kwer ure.
\q1 Uruenu neremiapo kwer uhua'u ma'e
\q1 Ureipy waneko mehe arer ure, kwehe arer ure.
\q1 
\v 2 Eremuhem kar teko nemuwete 'ymar ne wà. Eremupyta kar neremiaihu waiwy rehe ne wà, wanekuzaromo ne wà.
\q1 Umume'u a'e ma'e urewe wà.
\q1 Erezepyk teko amo ae ywy rehe har wanehe. Eremukàg kar neremiaihu ne wà.
\q1 Umume'u a'e ma'e urewe wà.
\q1 
\v 3 Nupyhyk kwaw a'e ywy utakihe pupe wà.
\q1 Nuweityk kwaw a'e ywy rehe har ukàgaw rupi wà.
\q1 Weityk nepuner haw rupi wà, nekàgaw rupi wà.
\q1 Nereko haw ihyape katu haw rupi weityk wà.
\q1 Nezewe erexak kar neremiaihu wamutar katu haw ne, neremiaihu wanupe ne.
\b
\q1 
\v 4 Ereiko heruwihawete romo. Hezar romo ereiko.
\q1 Eremur wàmàtyry'ymar waneitykaw neremiaihu wanupe ne.
\q1 
\v 5 Uruityk ureàmàtyry'ymar nepuner haw pupe ure wà.
\q1 Urumumaw urekutyr ur ma'e ure wà, ta'e ereiko urerehe we ne xe.
\q1 
\v 6 Nazeruzar kwaw heywyrapar rehe.
\q1 Hetakihepuku numur kwaw heàmàtyry'ymar waneitykaw ihewe.
\q1 
\v 7 Xo ne zo urepyro ureàmàtyry'ymar wanuwi.
\q1 Xo ne zo ereityk urerehe iakatuwawahy 'ym ma'e wà.
\q1 
\v 8 Urumume'u putar nekatu haw izi'itahy te kwarahy heixe mehe nehe.
\q1 Urumume'u putar neremiapo kwer ikatu haw tuweharupi nehe no.
\b
\q1 
\v 9 Ko 'ar rehe, o Tupàn, eretyryk urewi kury.
\q1 Urereityk kar pe ureàmàtyry'ymar wanupe.
\q1 Nereho kwaw zauxiapekwer wanupi zeàmàtyry'ymawhu pe ne.
\q1 
\v 10 Uremuzàn kar pe ureàmàtyry'ymar wanuwi.
\q1 Weraha urema'e paw urewi wà.
\q1 
\v 11 Urereko pe àràpuhàràn ài ne, uzuka àwàm me oho ma'e ài ne.
\q1 Uremuhàmuhàz kar pe amo ywy wanehe.
\q1 
\v 12 Ereme'eg neremiaihu temetarer pixika'i ma'e pupe ne wà.
\q1 Nuzawy kwaw ma'e hekuzar katu 'ym ma'e newe a'e wà.
\q1 
\v 13 Teko ureywy huwake har wexak neremiaihu pe neremiapo kwer wà.
\q1 A'e rupi uze'eg zemueteahy urerehe wà. Uze'eg urywahyahy urerehe wà no.
\q1 
\v 14 Erezapo ikatu 'ym ma'e urewe no. A'e rupi amogwer ywy rehe har uze'eg urywahyahy urerehe wà.
\q1 Amogwer teko upuka urerehe wà.
\q1 
\v 15 Awa ikàg 'ym ma'e zàwe aiko tuweharupi ihe. Hemaranugar haw hepyk.
\q1 
\v 16 Heàmàtyry'ymar uze'eg urywahyahy herehe wà no. Aenu herehe waze'eg urywahyahy mehe ihe wà.
\q1 Amo teko ima'enukwaw herehe uzepyk àwàm rehe wà. Aenu herehe waze'eg zemueteahy mehe ihe wà no.
\b
\q1 
\v 17 Na'urereharaz kwaw newi ure.
\q1 Nuruzuhaw kwaw neze'eg neremiaihu wanupe neremimume'u kwer ure.
\q1 Nezewe rehe we a'e ma'e paw uzeapo urewe a'e.
\q1 
\v 18 Nurutyryk kwaw newi ure.
\q1 Nurupytu'u kwaw neze'eg heruzar ire ure.
\q1 
\v 19 Ne urezuhaw pe urerezar pà àzàg yryhu pe har wainuromo ne.
\q1 Urerezar pe pytunahy haw inuromo no.
\q1 
\v 20 Aze mo urupytu'u urezar imuwete re,
\q1 Aze mo uruze'eg amo tupàn a'ua'u wanupe,
\q1 
\v 21 erekwaw mo ureremiapo kwer,
\q1 Ta'e erekwaw teko wama'enukwaw paw wapy'a pe har ne wà xe.
\q1 
\v 22 Tuweharupi amo ipuruzuka wer urerehe a'e wà, ta'e urumuwete katu ure xe.
\q1 Urereko àràpuhàràn wazuka àwàm mehe oho ma'e ài wà.
\b
\q1 
\v 23 Eme'e nehe, hezar. Màràzàwe tuwe ereker iko ne.
\q1 Epu'àm nehe. Urewi netyryk ire epytu'u nehe.
\q1 
\v 24 Màràzàwe tuwe erezeàmim urewi.
\q1 Màràzàwe tuwe nereharaz ma'erahy ureremipuraraw wi. Màràzàwe tuwe nerexak kwaw ma'erahy ureremipuraraw.
\b
\q1 
\v 25 Uruiko heityk pyrer romo. Uru'ar ywy rehe.
\q1 Urereityk a'e wà, ywyku'i pupe uremomor pà wà.
\q1 
\v 26 Epu'àm urepytywà pà nehe.
\q1 Urepyro pe nehe, ta'e ureamutar katu pe ne xe.
\c 45
\s1 Umuzàg zegar haw Tuwihawete zereko mehe har wà
\d Zegar haw Kora wanemiapo kwer
\q1 
\v 1 Ze'eg ipuràg eteahy ma'e umynehem kar hepy'a,
\q1 Ko zegar haw tuwihawete pe imuapyk mehe pape rehe.
\q1 Heapeku nuzawy kwaw ze'eg imuapykar ikatu ma'e ikair haw a'e.
\b
\q1 
\v 2 O Tuwihawete, ereiko ipuràg eteahy wera'u ma'e amo awa paw wanuwi ne.
\q1 Erekwaw neze'egatu haw teko wanuwa rupi no.
\q1 Tuweharupi Tupàn omono uze'egatu nerehe a'e.
\q1 
\v 3 Emono netakihepuku iapirer pupe neku'aw rehe nehe,
\q1 O tuwihawete ikàg ma'e, upuner ma'e, ipuràg eteahy ma'e,
\q1 
\v 4 Nekàgaw a'e, nepuràg eteahy haw a'e no, eremunehew kamir ài ne. Nezewe eho neàmàtyry'ymar wàmàtyry'ym pà nehe.
\q1 Epyro neze'eg azeharomoete har neàmàtyry'ymar wanuwi nehe. Epyro nekatu haw wanuwi nehe no.
\q1 Nekàgaw weityk putar zauxiapekwer tetea'u a'e wà nehe.
\q1 
\v 5 Haime neru'yw apyr.
\q1 Ukutuk neàmàtyry'ymar wazà'à.
\q1 Teko ywy nànànar u'ar nepy huwake wà.
\b
\q1 
\v 6 Pureruze'egaw newe Tupàn hemimur kwer nupaw pixik kwaw nehe.
\q1 O Tuwihawete, ereruze'eg neremiaihu nekatu haw rupi ne wà,
\q1 
\v 7 Erezamutar katu ikatu haw ne. Naneakatuwawahy kwaw ikatu 'ymaw rehe.
\q1 A'e rupi Tupàn nezar nerexak tuwihawete romo nemuigo kar pà a'e.
\q1 Nemurywete kar tuwe tuweharupi.
\q1 Nerurywete wera'u amogwer tuwihawete wanuwi upaw rupi ne.
\q1 
\v 8 Nekamir hyàkwenahy a'e, ta'e heta kàpuhàg hekuzar wera'u ma'e hehe a'e xe.
\q1 Heta kàpuhàg miha her ma'e aroe her ma'e hehe a'e.
\q1 Xi'àm ipy har wà, wioràwiràn imupu har wà no, upy uxi'àm newe wà, uwioràwiràn umupu newe wà no, hàpuzuhu ita marupi her ma'e pupe imupuràg pyrer pupe wà.
\q1 
\v 9 Heta kuzà neràpuzuhu pe wà. Heta tuwihawete wanazyr a'e kuzà wainuinuromo wà.
\q1 Neremireko wapyk nerenaw awyze har rehe a'e.
\q1 Neremireko umunehew uzemupuràg eteahy kar haw or ikatu ma'e iapo pyrer a'e.
\b
\q1 
\v 10 O tuwihawete hemireko ràm, ezeapyaka katu heze'eg pureruze'egaw rehe nehe.
\q1 — Nereharaz neremiaihu wanuwi nehe, neànàm wanuwi nehe.
\q1 
\v 11 Nepuràg eteahy ne. A'e rupi tuwihawete neputar a'e nehe.
\q1 Wiko nezar romo a'e. Eruzar ize'eg nehe.
\q1 
\v 12 O tuwihawete hemireko ràm, teko Xir tawhu pe har werur putar ma'e imur e pyràm newe wà nehe.
\q1 Teko hemetarer katu ma'e tetea'u ipurumurywete kar wer putar nerehe wà nehe, a'e newe.
\b
\q1 
\v 13 Tuwihawete hemireko ràm wiko tàpuzuhu pupe a'e. Ipuràg eteahy hemireko ràm.
\q1 Upyahaw or inemo romo iapo pyrer hopoz iapo pà wà.
\q1 
\v 14 Umunehew kar topoz ipuràg eteahy ma'e izupe wà.
\q1 Kuzàwaza wà, hemireko ràm imyrypar wà, oho hupi wà, tuwihawete pe heraha mehe wà.
\q1 Weraha hemireko ràm imyrypar izupe wà no.
\q1 
\v 15 Uhem tuwihawete hàpuzuhu pe urywete romo wà.
\q1 Ikatuahy wanupe a'e.
\b
\q1 
\v 16 O tuwihawete, eremuzàg putar nera'yr tetea'u ne wà nehe.
\q1 Wiko putar tuwihawete romo wà nehe, neipy wazàwe wà nehe.
\q1 Ne, o tuwihawete, eremuigo kar putar nera'yr
\q1 Ywy nànànar wanuwihaw romo ne wà nehe.
\q1 
\v 17 Ko hezegar haw umuma'enukwaw kar nekatu haw teko wanupe tuweharupi nehe.
\q1 Teko paw umume'u putar nekàgaw tuweharupi wà nehe.
\c 46
\s1 Tupàn wiko zanerehe we
\d Zegar haw Kora wanemiapo kwer
\q1 
\v 1 Tupàn wiko uremimaw romo a'e. Wiko urekàgaw romo no.
\q1 Zanepytywà putar tuwe ma'erahy ipuraraw mehe nehe.
\q1 
\v 2 A'e rupi nazakyze kwaw nehe.
\q1 Aze ywy uryryryryz nehe, aze yryhu pupe ywytyruhu u'ar nehe, iwy pe oho pà nehe,
\q1 Nezewe rehe we nazakyze kwaw nehe.
\q1 
\v 3 Aze heta ykotok uhua'u ma'e yryhu rehe nehe,
\q1 Aze ywytyr uryryryryz nehe, nezewe rehe we nazakyze kwaw nehe.
\b
\q1 
\v 4 Heta amo yrykawhu tawhu Tupàn heko haw pe har wamurywete kar har a'e.
\q1 A'e tawhu a'e, — Tupàn Ywate Wera'u Har hàpuzuhu imonokatu pyrer, za'e izupe.
\q1 
\v 5 Tupàn wiko a'e tawhu pupe.
\q1 Teko nuityk pixik kwaw a'e tawhu wà nehe.
\q1 Ku'em mehe izi'itahy Tupàn upytywà putar a'e tawhu a'e nehe.
\q1 
\v 6 Amo ae ywy rehe har ukyze tuwe wà.
\q1 Tuwihawete wanemiaihu uzemumaw wà.
\q1 Wànoànog Tupàn, ywy upaw no.
\b
\q1 
\v 7 Tupàn Ikàg Wera'u Ma'e wiko zanemyrypar romo a'e.
\q1 Tupàn Zako izar wiko zanemimaw romo a'e.
\b
\q1 
\v 8 Pezur nehe, pexak Tupàn Tuweharupi Wiko Ma'e hemiapo kwer nehe.
\q1 Pexak Tupàn hemiapo kwer teko wamupytuhegatu kar har ywy rehe har nehe.
\q1 
\v 9 Umumaw zeàmàtyry'ymawhu ywy nànànar nehe.
\q1 Uzuhaw ywyrapar paw. Purukutukaw uzeaikaikaw no.
\q1 Wapy u'yw wi purumimaw tata pupe no.
\q1 
\v 10 Uze'eg nezewe teko wanupe. — Pepytu'u pezeàmàtyry'ym ire nehe.
\q1 Pekwaw Tupàn romo hereko haw nehe.
\q1 Aiko teko ywy nànànar wanuwihawete romo.
\q1 Aiko ywy nànànar wazar romo no.
\b
\q1 
\v 11 Tupàn Ikàg Wera'u Ma'e wiko zanemyrypar romo.
\q1 Zako izar wiko zanemimaw romo.
\c 47
\s1 Tupàn wiko ywy nànànar waneruze'egar romo
\d Zegar haw Kora wanemiapo kwer
\q1 
\v 1 Pezepopetek penurywete romo nehe, teko paw wà.
\q1 Pemuzàg ikatu haw rehe zegar haw Tupàn pe wahyhaw rupi nehe.
\q1 
\v 2 Tuwe teko ukyze Tupàn Tuweharupi Wiko Ma'e ywate wera'u har wi a'e wà nehe.
\q1 Wiko tuwihawete uhua'u ma'e romo a'e, ywy nànànar waneruze'egar romo a'e.
\b
\q1 
\v 3 Tupàn weityk kar teko amo ywy rehe har zanewe a'e wà.
\q1 Weruze'eg kar teko ywy nànànar zanewe wà no.
\q1 
\v 4 Wexaexak ywy zanereko haw zanewe a'e.
\q1 Ikatuahy a'e ywy hemiaihu wanupe,
\q1 Hemiamutar katu wanupe.
\b
\q1 
\v 5 Tupàn uzeupir oho wenaw pe.
\q1 Izeupir mehe teko uhapukaz urywete romo wà. Upy uxi'àm oho urywete haw rehe wà no.
\q1 
\v 6 Pemuzàg zegar haw Tupàn ikatu haw rehe nehe.
\q1 Pemuzàg zegar haw Zaneruwihawete pe nehe.
\q1 
\v 7 Pemume'u Tupàn ikatu haw pezegar pà nehe,
\q1 Ta'e wiko teko ywy rehe har paw wanuwihawete romo a'e xe.
\b
\q1 
\v 8 Wapyk Tupàn wenaw ikatu ma'e rehe a'e.
\q1 Wiko teko paw wanuwihaw romo.
\q1 
\v 9 Teko wanuwihaw uzemono'og wà,
\q1 Àmàrààw izar hemiaihu wainuinuromo wà.
\q1 Tupàn wiko tuwihawete wakàgaw ywy rehe har paw wazar romo a'e.
\q1 Wiko ma'e paw teko paw wazar romo no.
\c 48
\s1 Zeruzarez wiko Tupàn ima'e romo
\d Zegar haw Kora wanemiapo kwer
\q1 
\v 1 Tupàn Tuweharupi Wiko Ma'e uhua'u a'e.
\q1 Aze teko heko haw pe har tawhu pe har umume'u ikatu haw a'e wà, ikatuahy.
\q1 Ywytyr Xiàw her ma'e imonokatu pyrer rehe ikatu haw imume'u haw ikatuahy no.
\q1 
\v 2 Ywytyr Tupàn ima'e a'e, iaiha a'e, ipuràg eteahy no.
\q1 Tawhu tuwihawete ikàg ma'e henaw a'e, umurywete kar teko ywy nànànar a'e wà.
\q1 
\v 3 Tupàn omonokatu teko tawhu pupe a'e wà, tàpuz imuàtà pyrer pupe a'e wà.
\q1 Wexak kar wamonokatu haw wanupe a'e.
\b
\q1 
\v 4 Amo tuwihawete uzemono'og wà,
\q1 Xiàw ywytyr iàmàtyry'ymaw rehe ur pà wà.
\q1 
\v 5 Tawhu hexak mehe ipytuhegatu wà.
\q1 Uzàn na'arewahy a'e wi ukyze pà wà.
\q1 
\v 6 Ukyze wà. Ukyze tuwe wà.
\q1 Nuzawy kwaw kuzà umemyrahy mehe har wà.
\q1 
\v 7 Wiko kanuhu pupe har
\q1 Ykotok uhua'u ma'e inuinuromo har zàwe wà.
\b
\q1 
\v 8 Xinu Tupàn Tuweharupi Wiko Ma'e hemiapo kwer rehe ze'eg awer zane.
\q1 Kutàri xixak tawhu zanezar ikàg wera'u ma'e henaw rehe
\q1 Uzeapo ma'e kwer no.
\q1 Omonokatu tawhu tuweharupi.
\q1 
\v 9 Uruiko neràpuzuhu pupe, o Tupàn,
\q1 Nepuruamutar haw rehe urema'enukwaw pà ure.
\q1 
\v 10 Teko paw umume'u nekatu haw wà.
\q1 Nekàgaw teko ywy nànànar ukwaw wà.
\q1 Ta'e erepureruze'eg iko nekatu haw rupi xe.
\q1 
\v 11 Penurywete nehe, teko Zeruzarez pe har wà.
\q1 O Tupàn, nepureruze'egaw ikatuahy.
\q1 Teko tawhu Zuta ywy rehe har pe har wà, penurywete ipureruze'egaw ikatu ma'e rehe nehe.
\b
\q1 
\v 12 Tupàn hemiaihu wà, peata Zeruzarez tawhu izywyr nehe.
\q1 Pepapar hàpuzaiha tawhu izywyr har pe wà nehe.
\q1 
\v 13 Peme'egatu pàrirogaw wanehe nehe.
\q1 Peme'e tuwe tàpuz imuàtà pyrer teko wazemonokatu haw wanehe nehe.
\q1 Nezewe mehe pepuner nezewe peze'eg pà pezuapyapyr wanupe nehe.
\q1 
\v 14 — Tupàn wiko putar zanezar romo tuweharupi nehe, peze putar wanupe nehe.
\q1 — Wexak kar putar zanerape ràm zaneho àwàm zanewe tuweharupi nehe, peze putar wanupe nehe.
\c 49
\s1 Teko paw rupi umàno putar wà nehe
\d Zegar haw Kora wanemiapo kwer
\q1 
\v 1 Pe teko paw pe wà, pezeapyaka katu ko ze'eg rehe nehe.
\q1 Peinu nehe, ywy nànànar wà.
\q1 
\v 2 Teko hemetarer katu ma'e pe wà,
\q1 Teko hemetarer 'ym ma'e pe wà no, peinu heze'eg nehe.
\q1 
\v 3 Aiko ma'e kwaw katu har romo ihe.
\q1 Amume'u putar a'e ma'e ma'e kwaw par ài nehe.
\q1 
\v 4 Azekaiw katu putar ze'eg xirogatu ma'e wanehe nehe.
\q1 Ze'eg xirogatu ma'e amume'u putar purupe ihe nehe, hewioràwiràn imupumupu mehe ihe nehe.
\b
\q1 
\v 5 Aze hereko haw zawaiw katu ihewe,
\q1 Heàmàtyry'ymar iaiw ma'e heywyr wamàmàn mehe, nakyze kwaw wanuwi ihe.
\q1 
\v 6 A'e iaiw ma'e uzeruzar wemetarer rehe wà.
\q1 Wiko wera'u amo wanuwi wà, ta'e hemetarer katuahy wà xe.
\q1 
\v 7 Ni amo nupuner kwaw uzepyro haw rehe wà.
\q1 Ni amo nupuner kwaw weko haw imekuzar haw rehe Tupàn pe wà,
\q1 
\v 8 ta'e temetarer ko ywy rehe har
\q1 Nuhyk kwaw amo teko heko haw hekuzaromo a'e xe.
\q1 
\v 9 Aze amo teko hemetarer katu a'e nehe, nezewe rehe we umàno putar amo 'ar mehe nehe.
\q1 — Aiko putar tuweharupi nehe, nupuner kwaw u'e haw rehe.
\b
\q1 
\v 10 Teko ma'e kwaw katu har umàno a'e wà. Teko paw wexak wamàno haw wà.
\q1 Iranaiw ma'e umàno a'e wà no. Ma'e kwaw par 'ym umàno a'e wà no.
\q1 Upaw rupi katete wezar wemetarer amo wanupe wà.
\q1 
\v 11 Watymaw uzeapo wapyta haw romo.
\q1 Upyta a'e pe tuweharupi wà.
\q1 Aze wereko ywy tetea'u wikuwe mehe wà, nezewe rehe we uzetym kar wà.
\b
\q1 
\v 12 Teko ikàg wera'u ma'e wà, te teko hemetarer katu wera'u ma'e wà no, nupuner kwaw umàno àwàm wi uhemaw rehe wà.
\q1 Ma'ea'yr umàno wà.
\q1 Nezewegatete a'e teko umàno putar a'e wà nehe no.
\b
\q1 
\v 13 Peme'e uzeapo ma'e ràm rehe nehe, uzehe uzeruzar ma'e wanupe uzeapo ma'e ràm rehe nehe.
\q1 Amo hurywete wemetarer uhua'u ma'e rehe wà.
\q1 Pexak wanupe uzeapo ma'e ràm iahykaw rehe àràm nehe.
\q1 
\v 14 Wamono'ogar weraha àràpuhàràn a'e wà. Nezewegatete teko wamàno haw weraha a'e teko a'e wà no.
\q1 Weraha wà.
\q1 Umàno putar àràpuhàràn izuka pyràm ài wà.
\q1 Iku'em mehe ikatu ma'e weityk putar a'e teko wà.
\q1 Wanetekwer inem putar umàno ma'e kwer wapyta haw pe wà nehe, muite waneko awer wi wà nehe.
\q1 
\v 15 Tupàn hepyro putar màno haw ikàgaw wi nehe,
\q1 Ta'e hemuixe kar putar weko haw pe nehe xe.
\b
\q1 
\v 16 Aze amo uzeapo hemetarer katu ma'e romo nehe, pezekaiw zo hehe nehe.
\q1 Tuweharupi hemetarer uhua'u wera'u oho iko. Pezemumikahy zo hemetarer tetea'u rehe nehe,
\q1 
\v 17 ta'e umàno mehe nupuner kwaw ni pitài wemetarer heraha haw rehe nehe xe.
\q1 Hemetarer noho kwaw hupi itym àwàm mehe nehe.
\q1 
\v 18 Upuner weko haw rehe urywete haw rehe.
\q1 Teko upuner ikatu haw ikàgaw rehe uze'egatu haw rehe wà no.
\q1 
\v 19 Nezewe rehe we umàno mehe uzemono'og putar oho uwipy wainuinuromo nehe.
\q1 Ipytunahy haw nupaw pixik kwaw a'e pe nehe.
\b
\q1 
\v 20 Teko ikàg wera'u ma'e
\q1 Nuhem kwaw umàno àwàm wi a'e wà.
\q1 Nezewe rehe we umàno putar ma'ea'yr ài wà nehe.
\c 50
\s1 Tupàn imuwete katu haw
\d Zegar haw Azaw hemiapo kwer
\q1 
\v 1 Tupàn, o Tupàn Tuweharupi Wiko Ma'e uze'eg iko ywy nànànar wanenoz pà a'e.
\q1 Wenoz teko ywy ipehegwer rehe har wà.
\q1 Wenoz teko inugwer ipehegwer rehe har wà no.
\q1 
\v 2 Tupàn heiny katu kwarahy ài pe pe Zeruzarez pe a'e.
\q1 Tawhu ikatuahy ma'e pe a'e, Ipuràg eteahy ma'e pe a'e.
\b
\q1 
\v 3 Tupàn Zanezar ur iko a'e. Nur kwaw uze'eg 'ym pà nehe.
\q1 Nur kwaw wànoànog 'ym pà nehe.
\q1 Tata ma'e imumaw har ur henataromo.
\q1 Ywytuaiw ur iko izywyr no.
\q1 
\v 4 Wenoz ywak iko. Wenoz ywy iko no.
\q1 Wexak kar putar wemiaihu wanemiapo kwer imume'u haw nehe, wanupe nehe.
\q1 
\v 5 — Pemono'og herehe uzeruzar ma'e pe wà nehe, i'i wanupe.
\q1 — Pemono'og uze'egaw herehe we iapo katu arer pe wà nehe, i'i.
\q1 — Uzuka kar ma'ea'yr herenataromo wà, herehe uzeruzar haw hexak kar pà ihewe wà, i'i wanupe.
\q1 
\v 6 Ywak umume'u Tupàn ikatu haw.
\q1 Umume'u teko wanemiapo kwer imume'u har romo heko haw no.
\b
\q1 
\v 7 Nezewe uze'eg Tupàn Tuweharupi Wiko Ma'e wemiaihu wanupe kury. — Pezeapyaka katu, heremiaihu, heremimume'u ràm rehe nehe.
\q1 Amume'u putar penemiapo kwer ikatu 'ym ma'e nehe, teko Izaew izuapyapyr wà.
\q1 Aiko Tupàn romo ihe, pezar romo aiko ihe.
\q1 
\v 8 Naze'egahy kwaw peme ma'ea'yr herenataromo izuka pyrer wanehe ihe nehe,
\q1 Ma'e ihewe imur pyrer wanehe ihe nehe.
\q1 
\v 9 Naputar kwaw tapi'ak awa peko pe har ihe wà.
\q1 Naputar kwaw àràpuhàrànete peneimaw wainuinuromo har ihe wà,
\q1 
\v 10 Ta'e miar ka'a pe har wiko hereimaw romo a'e wà xe.
\q1 Tapi'ak tetea'u ywytyruhu rehe har paw wiko hema'e romo wà no.
\q1 
\v 11 Wiràmiri ywytyr rehe har paw wiko hereimaw romo wà.
\q1 Miar katu pe har paw wiko hema'e romo wà.
\q1 
\v 12 Aze mo hema'uhez, nainoz iwer mo ma'e peme ihe.
\q1 Ta'e aiko ywy izar romo ihe xe. Aiko ywy rehe har paw wazar romo ihe no.
\q1 
\v 13 Aipo a'u putar tapi'ak awa ho'o kwer ihe nehe.
\q1 Aipo a'u putar àràpuhàrànete huwykwer ihe nehe.
\q1 
\v 14 Tuwe hekatu haw imume'u haw pemur ihewe imur pyr romo nehe.
\q1 Tuwe pemur ma'e penemimume'u kwer paw ihewe imur pyr romo nehe. Aiko Tupàn Ywate Wera'u Har romo ihe.
\q1 
\v 15 Aze herenoz pe ma'erahy ipuraraw paw 'ar mehe nehe,
\q1 Apupyro putar ihe nehe.
\q1 A'e mehe pemume'u putar hekatu haw nehe, i'i Tupàn wemiaihu wanupe.
\b
\q1 
\v 16 Nezewe rehe we uze'eg Tupàn ikatu 'ym ma'e wanupe kury.
\q1 — Mo umume'u kar heze'eg peme.
\q1 Mo pemuze'eg kar heremimume'u kwer rehe wà.
\q1 
\v 17 Aze hepurumukatu wer penemiapo rehe peme, napeputar kwaw imukatu haw.
\q1 Aze azapo kar ma'e peme, naperuzar kwaw heze'eg.
\q1 
\v 18 Aze pexak amo imunar ma'e, pezemuryparypar hehe we.
\q1 Peata peho peiko awa wemireko 'ym puhe oho ma'e wanehe we, kuzà umen 'ym puhe oho ma'e wanehe we.
\q1 
\v 19 Pezemuàgà'ym tuweharupi ikatu 'ym ma'e amo wanupe imume'u àwàm rehe.
\q1 Penemu'em wanupe peze'eg rehe pema'enukwaw 'ym pà no.
\q1 
\v 20 Tuweharupi peze'eg zemueteahy penywyr wanehe.
\q1 Penemu'em wanehe purupe no.
\q1 
\v 21 Pezapo a'e ikatu 'ym ma'e peho. Naze'eg kwaw ihe.
\q1 — Wiko zanezàwe a'e, peze herehe.
\q1 Ko 'ar rehe amume'u putar pekatu 'ymaw ihe nehe kury.
\q1 Aexak kar putar penemiawy kwer nehe no.
\b
\q1 
\v 22 Peneharaz ihewi. Pema'enukwaw katu penemiapo kwer rehe nehe.
\q1 Aze napema'enukwaw kwaw wanehe nehe, apumumaw putar ihe nehe.
\q1 Ni amo nupuner kwaw pepyro haw rehe wà nehe.
\q1 
\v 23 Aze amo teko werur ma'e ihewe nehe, hekatu haw rehe nehe, a'e teko hemuwete katu iko a'e.
\q1 Apyro putar herape rupi wata ma'e upaw rupi ihe wà nehe.
\c 51
\s1 Uzemumikahy haw, ikatu 'ymaw imunànaw no
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 O Tupàn, hepuhareko pe nehe, ta'e erepuruamutar katu ne xe.
\q1 Erepurupuhareko katu ne,
\q1 A'e rupi emunàn heremiapo kwer ikatu 'ym ma'e paw ihewi nehe.
\q1 
\v 2 Hemukatu hekatu 'ymaw wi paw rupi nehe.
\q1 Emunàn heremiapo kwer ikatu 'ym ma'e ihewi nehe no.
\b
\q1 
\v 3 Akwaw katu heremiawy kwer ihe.
\q1 Heremiapo kwer ikatu 'ym ma'e uzekwaw kar ihewe tuweharupi.
\q1 
\v 4 Azapo ikatu 'ym ma'e newe. Xo nekutyr zo azapo ikatu 'ym ma'e.
\q1 Azapo neremimutar 'ym.
\q1 Heremiapo kwer neremimume'u ikatu.
\q1 Nekatu herehe nezepyk mehe, ta'e heaiw ihe xe.
\q1 
\v 5 Hezexak kar haw henataromo nahekatu kwaw azeharomoete ihe.
\q1 Hehy hie pupe hemuigo kar awer 'ar henataromo aiko ikatu 'ym ma'e iapo har romo no.
\b
\q1 
\v 6 Ereputar teko ikatu ma'e ne wà.
\q1 Emynehem kar hepy'a nema'ekwaw paw pupe nehe.
\q1 
\v 7 Ezo'ok hekatu 'ymaw ihewi nehe. A'e mehe hekatu putar nehe.
\q1 Hemukatu nehe. A'e mehe hexigatu wera'u putar hoko hawer wi nehe.
\q1 
\v 8 Einu kar wi teko hurywete ma'e ihewe ne wà nehe. Einu kar ikatu ma'e rehe wazegar mehe ne wà nehe.
\q1 Hezuhazuhaw pe ne. Hemu'i pe no.
\q1 Nezewe rehe we herurywete wi putar nehe.
\q1 
\v 9 Ezeàpumi heremiapo kwer ikatu 'ym ma'e hexak 'ym pà nehe.
\q1 Emunàn hekatu 'ymaw paw rupi nehe.
\q1 
\v 10 O Tupàn, hemuigo kar pe ipy'a ikatu ma'e hereko har romo nehe.
\q1 Hemuigo kar pe ikatu ma'e iapo har romo nehe, neremimutar iapo har romo nehe.
\q1 
\v 11 Hemono kar zo pe newi nehe.
\q1 Emunyryk zo nerekwe ikatuahy ma'e ihewi nehe.
\q1 
\v 12 Hemurywete kar wi pe nerehe we hepyro àwàm rehe nehe.
\q1 Neremimutar rehe hepureruzar wer haw emupyta kar hepy'a pupe nehe. Ezapo kar neremiapo putar haw herekwe pe nehe.
\q1 
\v 13 A'e mehe amu'e putar ikatu 'ym ma'e iapo har neze'eg rehe ihe wà nehe.
\q1 A'e rupi uzewyr putar newe wà nehe.
\b
\q1 
\v 14 O Tupàn hepyro har, hepyro pe màno haw wi nehe.
\q1 A'e mehe amume'u putar nekatu haw herurywete pà ihe nehe.
\q1 
\v 15 O hezar, emume'u kar ze'eg ikatu ma'e ihewe nehe.
\q1 A'e mehe amume'u putar nekatu haw nehe.
\b
\q1 
\v 16 Nereputar kwaw ma'ea'yr heremizuka ràm ne wà.
\q1 Ma'ea'yr nemuwete katu haw rehe hapy pyr na'ikatu kwaw newe wà.
\q1 
\v 17 O Tupàn, herekwe wiko wera'u 'ym ma'e amono newe imono pyr romo ma'ea'yr izuka pyr zàwenugar romo ihe.
\q1 Nereityk kwaw teko wiko wera'u 'ym ma'e ne wà. Teko wemiapo ikatu 'ym ma'e wi uzemumikahy ma'e eremur kar nezeupe ne wà.
\b
\q1 
\v 18 O Tupàn, epytywà Zeruzarez pe har nekatu haw rupi nehe.
\q1 Emupu'àm wi Zeruzarez ipàrirogaw heityk pyrer nehe.
\q1 
\v 19 A'e mehe aze teko uzuka kar ma'ea'yr nemuwete pà neze'eg awer rupi katete wà nehe, eremuawyze putar ne wà nehe.
\q1 Ereputar putar ma'e nemuwete haw hapy pyr nehe no.
\q1 Teko uzuka kar putar tapi'aka'yr awa wazuka haw rehe nerenataromo har rehe wà nehe.
\c 52
\s1 Tupàn ikatu haw imume'u haw
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 Awa ikàg ma'e ne. Màràzàwe tuwe eremume'u nekatu 'ymaw amo wanupe ne. — Hekatu 'ymaw ipuràg ihewe, ere wanupe.
\q1 Tupàn ipuruamutar haw nupaw pixik kwaw nehe.
\q1 
\v 2 Eremume'u amogwer teko wamumaw pàwàm iko nezeupe.
\q1 Neapeku nuzawy kwaw takihe haime katu ma'e purukixi ma'e a'e.
\q1 
\v 3 Ikatu 'ymaw ikatu wera'u newe ikatu haw wi a'e.
\q1 Temu'emaw ikatu wera'u newe ze'eg azeharomoete har wi a'e.
\q1 
\v 4 Hemu'em ma'e romo ereiko. Neze'eg nuzawy kwaw takihe.
\q1 Erekutuk teko ne wà. Wakutukaw ikatu newe.
\q1 
\v 5 A'e rupi Tupàn nemumaw putar azeharomoete a'e nehe.
\q1 Nepyhyk putar nehe, neràpuz nereko haw wi nereityk pà nehe.
\q1 Tupàn nezo'ok putar ywy wikuwe ma'e hereko har wi nehe.
\q1 
\v 6 Teko Tupàn heruzar har wexak putar nezo'okaw a'e wà nehe. A'e rupi ukyze putar wà nehe.
\q1 Upuka putar nerehe wà nehe, nerehe uze'eg pà wà nehe.
\q1 
\v 7 — Peme'e ko awa rehe nehe. — Hepyro pe nehe, ni'i kwaw Tupàn pe a'e.
\q1 Uzeruzar wemetarer uhua'u ma'e rehe uma'e tetea'u rehe.
\q1 Wekar uzepyro àwàm ukatu 'ymaw pupe, i'i putar nerehe wà nehe.
\b
\q1 
\v 8 Ihe aiko uri 'yw ikyr katu ma'e ài ihe.
\q1 Herezuz tekoko Tupàn hàpuz huwake.
\q1 Tuweharupi azeruzar ipuruamutar haw rehe hepytu'u 'ym pà.
\q1 
\v 9 O Tupàn, tuweharupi amume'u putar nekatu haw ihe nehe, ta'e neremiapo kwer ikatu a'e xe.
\q1 Neremiaihu nerehe uzeruzar ire upytu'u 'ym ma'e wainuinuromo amume'u putar nekatu haw ihe nehe.
\c 53
\s1 Iaiw haw, zepyro haw no
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 Nezewe uze'eg iranaiw ma'e uzeupe a'e wà.
\q1 — Na'ikàg kwaw Tupàn, i'i wà.
\q1 Upaw rupi uzeapo ipihe ma'e iapo har romo wà.
\q1 Uzapo iaiw ma'e oho waiko wà.
\q1 Naheta kwaw ni pitài ikatu ma'e iapo har wà.
\b
\q1 
\v 2 Ywak rehe wapyk mehe Tupàn ume'e teko paw wanehe.
\q1 Wekar amo ikatu ma'e iko.
\q1 — Aipo heta amo hemuwete katu har, i'i uzeupe uzehe upuranu pà.
\q1 
\v 3 Upaw rupi upytu'u hehe uzeruzar ire wà.
\q1 Wakatu 'ymaw paw uzuawyawygatu wà.
\q1 Naheta kwaw ni pitài ikatu ma'e iapo har wà.
\q1 Azeharomoete naheta pixik kwaw wà.
\b
\q1 
\v 4 Tupàn upuranu purehe a'e.
\q1 — Aipo a'e teko ikatu 'ym ma'e nukwaw kwaw ma'e wà.
\q1 Tuweharupi imunar heremiaihu wama'e rehe wà.
\q1 Nuze'eg kwaw ihewe wà no, i'i Tupàn.
\q1 
\v 5 Uryryryryz putar ukyze pà a'e wà nehe.
\q1 Nuryryryryz pixik kwaw nezewe a'e 'ym mehe wà,
\q1 Ta'e Tupàn umuhàmuhàz wàmàtyry'ymar wàkàgwer a'e wà xe.
\q1 Weityk wà.
\q1 A'e rupi Izaew ipurumuzàmuzàg weityk putar upaw rupi katete wà.
\b
\q1 
\v 6 Tuwe Tupàn uputar Izaew wapyro àwàm Zeruzarez wi ur ma'e ràm a'e nehe.
\q1 Zako izuapyapyr hurywete putar wà nehe,
\q1 Ta'e Tupàn umukatu putar waneko haw a'e nehe xe.
\c 54
\s1 Tupàn pe upytywà haw henoz taw
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 O Tupàn, hepyro pe nekàgaw pupe nehe.
\q1 Hemunyryk kar pe katu 'ymaw wi nekàgaw pupe nehe.
\q1 
\v 2 Einu, o Tupàn, newe heze'egaw nehe.
\q1 Ezeapyaka katu heze'eg rehe nehe.
\q1 
\v 3 Ta'e amo wanuwi wiko wera'u ma'e uhem wà waiko heàmàtyry'ym pà a'e wà xe.
\q1 Ipuruzukaiw ma'e ipuruzuka wer herehe wà.
\q1 A'e teko nuzekaiw kwaw Tupàn rehe wà.
\b
\q1 
\v 4 Akwaw Tupàn hepytywà har romo heko haw ihe.
\q1 Heàmàtyry'ymar waneitykar romo heko haw akwaw no.
\q1 
\v 5 Tuwe Tupàn umuzewyr kar heàmàtyry'ymar wakatu 'ymaw a'e nehe, wakutyr a'e nehe.
\q1 Tupàn nutyryk kwaw wemiaihu wanuwi.
\q1 A'e rupi umumaw putar heàmàtyry'ymar a'e wà nehe.
\b
\q1 
\v 6 O Tupàn Tuweharupi Wiko Ma'e. Azuka kar putar ma'ea'yr neruwa rupi ihe wà nehe, ta'e heporomono wer wanehe newe ihe xe.
\q1 Amume'u putar nekatu haw nehe, ta'e nekatuahy ne xe.
\q1 
\v 7 Erezo'ok ma'erahy heremipuraraw paw ihewi.
\q1 Aexak heàmàtyry'ymar waneityk awer no.
\c 55
\s1 Awa ma'erahy ipuraraw par uze'eg Tupàn pe
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 O Tupàn, herenu pe newe heze'eg mehe nehe.
\q1 Ezapo tuwe ma'e hereminoz nehe.
\q1 
\v 2 Ezeapyaka katu herehe nehe. Ewazar heze'eg nehe.
\q1 Ma'erahy heremipuraraw nahemupytu'u kar kwaw a'e.
\q1 
\v 3 Aryryryryz ihe, heàmàtyry'ymar hezuka àwàm imume'u haw henu mehe ihe.
\q1 Ihewe heàmàtyry'ymar wanemiapo ikatu 'ym ma'e a'e, hezuhaw a'e.
\q1 Umu'ar kar iaiw haw herehe wà.
\q1 Wikwahy ihewe wà. Na'iakatuwawahy kwaw herehe wà no.
\q1 
\v 4 Hepy'a tynehem hekyze haw pupe.
\q1 Hemàno haw wi hekyze haw u'ar herehe a'e.
\q1 
\v 5 Akyze tuwe ihe. Aryryryryz teko.
\q1 Hekyze haw uzeapo hezar romo.
\q1 
\v 6 Na'e aze'eg ihe.
\q1 — Aze mo apuner hewewe haw rehe pykahu ài, awewe mo hepytu'u àwàm me.
\q1 
\v 7 Àzàn mo muite xe wi.
\q1 Ywyxiguhu rehe aikuwe mo.
\q1 
\v 8 Na'arewahy aikar mo hemimaw ywytu wi ihe,
\q1 Ywytuaiw wi ihe, a'e hezeupe ihe.
\q1 
\v 9 Hezar, emumaw a'e teko wanemiapo putar haw nehe. Emuaiw uzeupeupe waze'egaw nehe no,
\q1 Ta'e aexak puruzuka haw tawhu pe ihe xe. Aexak zeàmàtyry'ymaw a'e pe ihe no.
\q1 
\v 10 'Aromo, pyhaw no, a'e teko wata oho waiko pàrirogaw iapyr wà, pàrirogaw tawhu izywyr har rehe wà.
\q1 Tawhu tynehem iaiw paw pupe. Tynehem ma'erahy pupe no.
\q1 
\v 11 Heta tetea'u ma'emumaw paw tawhu pe.
\q1 Ma'eme'egaw tynehem purehe imunar ma'e pupe. Tynehem purupe hemu'em ma'e pupe no.
\b
\q1 
\v 12 Herehe uze'eg urywahyahy ma'e a'e, nuiko kwaw heàmàtyry'ymar romo a'e.
\q1 Aze mo wiko, apuner mo henu haw rehe hezàn 'ym pà ihe.
\q1 Herehe uze'eg zemueteahy ma'e nuiko kwaw hekutyr har romo a'e.
\q1 Aze mo wiko, azeàmim mo izuwi ihe.
\q1 
\v 13 Ne hemyrypar ne, ereiko herehe uze'eg urywahyahy ma'e romo ne.
\q1 Ne herehe we har ne, herupi wata ma'e ne, ereiko herehe uze'eg zemueteahy ma'e romo ne.
\q1 
\v 14 Izypy mehe zaha teko wanupi Tupàn imuwete katu pà hàpuzuhu pupe.
\q1 Zaze'eg zanezeupeupe ikatu haw rupi zane no.
\b
\q1 
\v 15 Tuwe màno haw ur na'arewahy heàmàtyry'ymar wanehe nehe.
\q1 Tuwe wikuwe putar umàno ma'e kwer wapyta haw pe oho mehe wà nehe, ta'e ikatu 'ymaw upyta wanàpuz me xe.
\q1 Upyta wapy'a pupe no.
\q1 
\v 16 Aze'eg Tupàn Tuweharupi Wiko Ma'e pe hepytywà àwàm henoz pà izupe.
\q1 Hepyro a'e.
\q1 
\v 17 Ku'em mehe ihe, kwarahy wapyter pe hin mehe ihe no, pyhaw ihe no,
\q1 Azai'o heremipuraraw rehe heze'eg pà ihe.
\q1 Herenu a'e.
\q1 
\v 18 Hererur hekutuk kar 'ym pà zeàmàtyry'ymawhu wi a'e.
\q1 Heàmàtyry'ymar heta tetea'u wà. Nezewe rehe we hepyro wanuwi a'e.
\q1 
\v 19 Tupàn, 'Ar ipy henataromo har, pureruze'eg ma'e a'e, herenu a'e.
\q1 Weityk heàmàtyry'ymar a'e wà.
\q1 Ta'e na'ipurumukatu wer kwaw weko haw rehe a'e wà xe.
\q1 Nukyze kwaw Tupàn wi wà.
\b
\q1 
\v 20 Herehe we arer kwehe arer uzàmàtyry'ym umyrypar wà.
\q1 Nuzapo kwaw ma'e uze'eg umyrypar wanupe wemimume'u kwer rupi a'e.
\q1 
\v 21 Ize'eg ikatu wera'u tapi'ak kamykwer ikawer wi a'e.
\q1 Nezewe rehe we ipy'a pe heta purehe iakatuwawahy 'ymaw.
\q1 Ize'eg ihym wera'u ma'e kawer wi a'e.
\q1 Nezewe rehe we omonohok ma'e takihe haime katu ma'e ài.
\b
\q1 
\v 22 Aze zawaiw katu nereko haw nehe, emume'u Tupàn Tuweharupi Wiko Ma'e pe nehe. Nepytywà putar nehe.
\q1 Numu'ar kar pixik kwaw weruzar har wà.
\q1 
\v 23 Ne, o Tupàn, ereityk putar
\q1 Puruzuka ma'e umàno ma'e kwer wapyta haw iwy pe nehe.
\q1 Numumaw kwaw ukwarahy iku'aw har wiko pà wà nehe.
\q1 Ihe zote azeruzar putar nerehe nehe.
\c 56
\s1 Tupàn wiko herehe we
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 Hepuhareko pe nehe, o Tupàn,
\q1 Ta'e heàmàtyry'ym waiko a'e wà xe.
\q1 Heàmàtyry'ymar herekar waiko tuweharupi wà.
\q1 
\v 2 Heàmàtyry'ym waiko 'ar rehe katu wà.
\q1 Heàmàtyry'ymar heta tetea'u wà.
\b
\q1 
\v 3 Hekyze mehe azeruzar nerehe ihe,
\q1 O Tupàn Upuner Wera'u Ma'e.
\q1 
\v 4 Azeruzar Tupàn rehe. Amume'u hemimume'u kwer ikatu haw no.
\q1 Azeruzar hehe. Nakyze kwaw ma'e wi nehe.
\q1 Teko nupuner kwaw ikatu 'ym ma'e ihewe iapo haw rehe wà. Na'ikàg kwaw Tupàn zàwe wà.
\q1 
\v 5 Heàmàtyry'ymar umuaiw hema'ereko haw ihewe 'ar rehe katu wà.
\q1 Xo ikatu 'ym ma'e ihewe wemiapo ràm rehe zo ima'enukwaw wà.
\q1 
\v 6 Uzeàmim muite teko wanuwi uzemono'og pà wà.
\q1 Ume'e heremiapo rehe wà.
\q1 Hezuka haw 'ar wàro waiko wà.
\q1 
\v 7 O Tupàn, ezepyk a'e teko wanehe wakatu 'ymaw hekuzaromo nehe.
\q1 Eityk a'e teko nekwahy haw pupe ne wà nehe.
\b
\q1 
\v 8 Erekwaw hereko haw. Ma'erahy apuraraw teko.
\q1 Erexak herehaykwer paw rupi ne.
\q1 Aipo neremuapyk kwaw herehaykwer nepape rehe.
\q1 
\v 9 Aenoz hepytywà àwàm newe.
\q1 Henoz mehe heàmàtyry'ymar uzàn putar oho newi wà nehe.
\q1 Pitài ma'e akwaw ihe: Tupàn wiko herehe we a'e.
\q1 
\v 10 Amume'u Tupàn Tuweharupi Wiko Ma'e hemimume'u kwer ikatu haw ihe.
\q1 
\v 11 Azeruzar hehe. Nakyze kwaw ma'e wi nehe.
\q1 Teko nupuner kwaw ikatu 'ym ma'e iapo haw rehe ihewe a'e wà, ta'e na'ikàg kwaw Tupàn zàwe a'e wà xe.
\b
\q1 
\v 12 O Tupàn, amono putar ma'e heremimume'u kwer newe ihe nehe.
\q1 Amono putar ma'e newe nekatu haw imume'u haw romo nehe.
\q1 
\v 13 Ta'e hepyro pe hemàno haw wi ne xe.
\q1 Hemunyryk pe hereitykaw wi ne no.
\q1 Nezewe, o Tupàn, ata neruwarupi ihe.
\q1 Ata tatainy purumuigo kar ma'e rehe we no.
\c 57
\s1 Tupàn wiko zanemimar romo a'e
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 Hepuhareko pe nehe, o Tupàn.
\q1 Hepuhareko pe nehe, ta'e aikar hepyro àwàm nerehe ihe xe.
\q1 Aexak hepyro haw nepepo i'àg rehe. Apyta a'e pe.
\q1 Xo ikatu 'ymaw iho re zo ahem a'e wi.
\q1 
\v 2 Aze'eg Tupàn Ywate Wera'u Har pe hepytywà àwàm henoz pà izupe.
\q1 Aenoz Tupàn ihe. Hepytywà ikatu 'ym ma'e wi hemunyryk kar pà a'e.
\q1 
\v 3 Uwazar putar heze'eg ywak rehe wiko mehe. Hepyro putar nehe.
\q1 Weityk putar hekutyr ur ma'e ràm wà nehe.
\q1 Tupàn wexak kar putar upuruamutar haw ihewe nehe. Wexak kar putar puruwi utyryk 'ymaw ihewe nehe no.
\q1 
\v 4 Heàmàtyry'ymar umàmàn heywyr wà.
\q1 Nuzawy kwaw zàwàruhu iriàw wà. Ipuru'u wer herehe wà.
\q1 Wanàz nuzawy kwaw purukutukaw wà. Nuzawy kwaw u'yw wà no.
\q1 Wapeku nuzawy kwaw takihepuku haime ma'e wà.
\b
\q1 
\v 5 O Tupàn, exak kar nehua'u haw ywak rehe har nehe, purupe nehe.
\q1 Tuwe nekàgaw nepuràg eteahy haw heiny katu ywy nànàn nehe no.
\b
\q1 
\v 6 Heàmàtyry'ymar uzapo ma'e hepyhyk pà wà, hezuka pà wà.
\q1 Azemumikahy hekyze pà ihe.
\q1 Uzapo ywykwaruhu herape rupi hetym àwàm romo wà.
\q1 Iapo har zote u'ar wemiapo kwer pupe wà no.
\b
\q1 
\v 7 Hepy'a pe azeruzar katu nerehe, o Tupàn. Hekàg tuwe ihe.
\q1 Amuzàg putar zegar haw nekatu haw imume'u pà nehe.
\q1 
\v 8 Eme'e nehe, hepy'a.
\q1 Eme'e nehe, hewioràwiràn. Epu'àm nehe, hewioràw zàwenugar.
\q1 Amume'e kar putar kwarahy ihe nehe.
\q1 
\v 9 Hezar, amume'u putar nekatu haw ywy nànànar wainuinuromo nehe.
\q1 Amume'u putar nekàgaw amogwer teko wainuinuromo nehe.
\q1 
\v 10 Nepuruamutar haw uhua'u a'e.
\q1 Uhem ywak rehe. Puruwi netyryk 'ymaw uhem ywàkun rehe.
\b
\q1 
\v 11 O Tupàn, exak kar nehua'u haw ywak rehe har purupe nehe.
\q1 Tuwe nekàgaw nepuràg eteahy haw heny katu ywy nànàn nehe no.
\c 58
\s1 Tupàn uzepyk putar ikatu 'ym ma'e iapo har wanehe nehe
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 Pe tuwihaw wà, aipo penemu'em teko wanemiapo kwer imume'u mehe.
\q1 Aipo xo ikatu 'ym ma'e wanehe pezekaiw.
\q1 
\v 2 Azeharomoete napekatu kwaw. Xo ikatu 'ym ma'e iapo àwàm rehe pema'enukwaw.
\q1 Pezapo iaiw ma'e teko ko ywy rehe har wanupe.
\b
\q1 
\v 3 Ikatu 'ym ma'e umumaw u'ar ikatu 'ym ma'e iapo pà wà.
\q1 Uzexak kar awer 'ar henataromo xo temu'emaw zo umume'u oho waiko wà.
\q1 
\v 4 Nuzawy kwaw mozaiw wà. Tynehem puruzuka haw pupe wà.
\q1 Uwàpytym wapyakwar moz ma'e henu 'ymar ài wà.
\q1 
\v 5 A'e moz na'ipurenu wer kwaw moz imugakwaw par rehe ize'eg mehe wà.
\b
\q1 
\v 6 O Tupàn. Ezuhaw ikatu 'ym ma'e wanàz nehe.
\q1 O Tupàn Tuweharupi Wiko Ma'e, ezo'ok wanàz nehe, a'e zàwàruhu iriàw ipuruzukaiw ma'e wanuwi nehe.
\q1 
\v 7 Tuwe ikatu 'ym ma'e ukàzym 'y ywy rehe izakook pyrer ài wà nehe.
\q1 Tuwe uzezuhazuhaw ka'api'i pe rupi hezuz ma'e kwer ài wà nehe.
\q1 
\v 8 Tuwe ukàzym amu'a to'om inuromo har ài wà nehe.
\q1 Tuwe wiko kwarer umàno ma'e kwer romo uzexak kar ma'e ài wà nehe.
\q1 A'e kwarer nuexak pixik kwaw kwarahy a'e.
\q1 
\v 9 Uzeapo ma'e ikwaw 'ym mehe we
\q1 Ikatu 'ym ma'e uzemonohok kar ka'akyr ài wà.
\q1 Wanekuwe mehe we
\q1 Tupàn omono kar putar uzewi upytuhemaw pupe wekwahy haw ukaz ma'e rupi nehe.
\b
\q1 
\v 10 Ikatu ma'e hurywete putar wà nehe,
\q1 Ikatu 'ym ma'e iapo har wanehe Tupàn izepyk mehe wà nehe.
\q1 Ikatu ma'e uhez putar upy ikatu 'ym ma'e wanuwykwer pupe wà nehe.
\q1 
\v 11 Paw rupi uze'eg putar nezewe wà nehe. — Azeharomoete Tupàn uzapo ikatu ma'e a'e, ikatu ma'e wanupe a'e.
\q1 Azeharomoete heta Tupàn ywy rehe har wanemiapo kwer imume'u har a'e, i'i putar wà nehe.
\c 59
\s1 Tupàn hepyro putar heàmàtyry'ymar wanuwi nehe
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 O hezar, hepyro pe heàmàtyry'ymar wanuwi nehe.
\q1 Hemunyryk kar pe herehe ipuruzuka wer ma'e wanuwi nehe.
\q1 
\v 2 Hepyro pe awa ikatu 'ym ma'e wanuwi nehe.
\q1 Hemunyryk kar pe a'e puruzuka ma'e wanuwi nehe.
\q1 
\v 3 O Tupàn Tuweharupi Wiko Ma'e, eme'e kury.
\q1 Heràro herereko hezuka àwàm rehe a'e wà.
\q1 Awa purupe ma'erahy ipuraraw kar har uzemono'og waiko hezuka àwàm imume'u pà wà.
\q1 Nazapo kwaw ikatu 'ym ma'e wanupe hezezuka kar pà ihe.
\q1 Nazezuka kar kwaw teko wanupe heaiw paw hekuzaromo.
\q1 
\v 4 Nazapo kwaw ikatu 'ym ma'e.
\q1 Nezewe rehe we uzàn hekutyr wà, ta'e herehe ipuruzuka wer wà xe.
\q1 
\v 5 O Tupàn Tuweharupi Wiko Ma'e Ikàg Wera'u Ma'e ne, epu'àm ezuwà hepytywà pà nehe.
\q1 Ne ae exak nehe, o Tupàn Izaew Wazar.
\q1 Eme'e teko amo ae ywy rehe har nerehe uzeruzar 'ym ma'e wanehe nezepyk pà nehe.
\q1 Epuhareko zo a'e neàmàtyry'ymar iaiw ma'e ne wà nehe.
\b
\q1 
\v 6 Pyhaw uzewyr wà.
\q1 Umàmàn tawhu iwyr wà. Okororo zawar ài wà.
\q1 
\v 7 Wapeku nuzawy kwaw takihepuku wà.
\q1 Uhapukaz tawhu pe har wazuka àwàm imume'u pà wà, wanehe uze'eg zuawygatu pà wà.
\q1 — Teko nazanerenu kwaw a'e wà, i'i uzeupeupe wà.
\b
\q1 
\v 8 O Tupàn Tuweharupi Wiko Ma'e erepuka wanehe.
\q1 Ereze'eg urywahyahy teko nerehe uzeruzar 'ym ma'e nànàn.
\q1 
\v 9 O Tupàn, azeruzar nekàgaw rehe ihe.
\q1 Ereiko hemimaw romo ne.
\b
\q1 
\v 10 Tupàn hezar ur putar heàwàxi pà upuruamutar katu haw rupi a'e nehe.
\q1 Wexak kar putar heàmàtyry'ymar waneitykaw ihewe a'e nehe.
\q1 
\v 11 O hezar, ezuka zo heàmàtyry'ymar na'arewahy ne wà nehe.
\q1 Aze erezuka na'arewahy ne wà nehe, heànàm heharaz putar wakatu 'ymaw wi a'e wà nehe.
\q1 O urezar, uremimaw zàwenugar, emuhàmuhàz heàmàtyry'ymar nekàgaw pupe nehe. Eityk wamumaw pà ne wà nehe.
\b
\q1 
\v 12 Tuweharupi uze'eg mehe heàmàtyry'ymar uzapo ikatu 'ym ma'e a'e wà.
\q1 Wiko wera'u amo wanuwi a'e wà. Tuwe waneko wera'u haw upaw nehe.
\q1 Omono ze'egaiw amo teko wanehe wà. Hemu'em wà no.
\q1 
\v 13 A'e rupi ainoz ko ma'e newe ihe kury. — Emumaw a'e teko nekwahy mehe ne wà nehe. Azeharomoete.
\q1 Tuwe uzezuka kar upaw rupi wà nehe.
\q1 Nezewe mehe ukwaw putar Tupàn Izaew waneruze'egar romo heko haw a'e wà nehe.
\q1 Ukwaw putar teko paw Tupàn hemiruze'eg romo waneko haw a'e wà nehe no.
\b
\q1 
\v 14 Pyhaw heàmàtyry'ymar uzewyr wà.
\q1 Umàmàn wà tawhu izywyr wà. Uzemuakyr zawar ài wà.
\q1 
\v 15 Wata oho tawhu rupi zawar ài wà,
\q1 Wemi'u ràm hekar pà wà.
\q1 Uze'eg a'e wà, aze wanemi'u nuhyk kwaw wanupe.
\b
\q1 
\v 16 Nezewe rehe we ihe azegar putar nekàgaw rehe ihe nehe.
\q1 Ku'em mehe amume'u putar nepuruamutar katu haw wahy haw rupi nehe,
\q1 Ta'e ereiko hemimaw romo ne xe.
\q1 Ma'erahy ipuraraw mehe apuner hezeàmimaw rehe nerehe ihe.
\q1 
\v 17 Amume'u putar nekatu haw ihe nehe, o Tupàn, herehe uzekaiw ma'e.
\q1 Ereiko hemimaw romo.
\q1 Ereiko Tupàn heamutar katu har romo.
\c 60
\s1 Urereityk Tupàn a'e
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 O Tupàn, eretyryk urewi ne. Urereityk pe ne.
\q1 Erekwahy urewe a'e 'ar mehe.
\q1 Ko 'ar rehe erezur wi urewe.
\q1 
\v 2 Eremuryryryryz kar ywy ne, ipe'a pà ne.
\q1 Erewàpytym a'e ywykwar ne wà kury,
\q1 Ta'e uzekazeka iko a'e xe.
\q1 
\v 3 Erepuraraw kar ma'erahy tetea'u neremiaihu wanupe.
\q1 Eremur win urewe i'u kar pà urewe.
\q1 A'e rupi uruata kwerupi ureka'u pà ure.
\q1 
\v 4 Ereupir pànuhu nerer hereko har newi ukyze ma'e wanenataromo. — Peraha ko pànuhu zeàmàtyry'ymawhu pe nehe, ere wanupe.
\q1 Nezewe mehe upuner weitykaw wi uhemaw rehe wà.
\q1 
\v 5 Urepyro pe nekàgaw pupe nehe.
\q1 Erewazar newe ureze'eg ma'e henoz mehe nehe.
\q1 Nezewe mehe erepyro putar teko neremiamutar ne wà nehe.
\b
\q1 
\v 6 Nezewe uze'eg Tupàn wàpuzuhu pupe a'e.
\q1 — Heàmàtyry'ymar waneityk mehe azaikaikaw putar Xikez tawhu ihe nehe. Azaikaikaw putar ywyàpyznaw Xukot her ma'e nehe no.
\q1 Amono putar ipehegwer izaikaikaw pyrer heremiaihu wanupe nehe.
\q1 
\v 7 Zireaz wiko hema'e romo a'e. Manaxe wiko hema'e romo a'e no.
\q1 Eparai nuzawy kwaw u'yw wi heàkàg imimaw.
\q1 Zuta nuzawy kwaw tuwihawete ipokokaw ihewe no.
\q1 
\v 8 Moaw wiko putar zapepo zàwenugar ài hezepuez taw ài nehe. Aityk putar hexapat Enom ywy rehe nehe no.
\q1 Nezewe teko ukwaw putar a'e ywy hema'e romo heko haw a'e wà nehe.
\q1 — Zazegar putar Tupàn heitykaw rehe nehe, i'i ru'u Piri ywy rehe har uzeupeupe wà.
\q1 Aipo uzegar putar azeharomoete hereitykaw imume'u pà wà nehe, i'i Tupàn.
\b
\q1 
\v 9 O Tupàn. Mo hereraha putar tawhu pupe nehe, pàrirogaw aiha katu ma'e zauxiapekwer wanuwi purumimaw hereko har pupe nehe.
\q1 Mo hereraha putar Enom ywy rehe nehe.
\q1 
\v 10 Aipo eretyryk tuwe urewi.
\q1 Aipo nereho kwaw zauxiapekwer urerehe uzekaiw ma'e wainuromo nehe.
\q1 
\v 11 Urepytywà pe ureàmàtyry'ymar waneityk mehe nehe,
\q1 Ta'e teko nupuner kwaw urepytywàgatu haw rehe wà nehe xe.
\q1 
\v 12 Aze Tupàn wiko zanerehe we nehe, xityk putar zaneàmàtyry'ymar zane wà nehe.
\q1 Tupàn weityk putar zaneàmàtyry'ymar a'e wà nehe.
\c 61
\s1 Ikàgaw Tupàn rehe we
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 O Tupàn herenu pe hezai'oahy mehe nehe.
\q1 Einu newe heze'egaw nehe.
\q1 
\v 2 Aiko muite hereko haw wi iaiw haw inuromo ihe.
\q1 Aenoz hepytywà àwàm iteko ihe.
\b
\q1 Hereraha pe amo hemim àwàm me nehe.
\q1 
\v 3 Ta'e ereiko herehe uzekaiw ma'e romo ne xe.
\q1 Ereiko hepyro har ikàg ma'e heàmàtyry'ymar wanuwi.
\q1 
\v 4 Tuwe aiko neràpuzuhu pupe he'ar nànàn nehe.
\q1 Nezewe mehe erezekaiw katu putar herehe nehe, wiràmiri upepo iwy pe umemyr wanehe izekaiw haw ài nehe.
\q1 
\v 5 O Tupàn, erenu heremiapo ràm heremimume'u kwer.
\q1 Eremono neze'egatu nereruzar har newi ukyze ma'e wanehe. Agwer ma'e eremur herehe no.
\b
\q1 
\v 6 Eremumaw kar kwarahy tetea'u tuwihawete pe nehe.
\q1 Tuwe umumaw kwarahy tetea'u wiko pà nehe.
\b
\q1 
\v 7 O Tupàn, tuwe eremono neze'egatu hehe tuweharupi tuwihawete romo heko mehe nehe.
\q1 Ezekaiw katu hehe nepuruamutar haw inuromo nehe, teko wanuwi netyryk 'ymaw inuromo nehe no.
\b
\q1 
\v 8 Nezewe mehe amuzàg putar nekatu haw rehe zegar haw tuweharupi ihe nehe.
\q1 Tuweharupi amono putar ma'e newe heremimume'u kwer rupi katete ihe nehe.
\c 62
\s1 Xo Tupàn inuromo zo hepy'a upytu'u
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 Xo Tupàn inuromo zo hepy'a upytu'u.
\q1 Umur hepyro haw ihewe a'e.
\q1 
\v 2 Xo a'e zo wiko itahu hemimar ài a'e. Xo a'e zo hepyro.
\q1 Hemim heàmàtyry'ymar wanuwi.
\q1 Nahereityk pixik kwaw heàmàtyry'ymar wà nehe.
\b
\q1 
\v 3 Awa na'ikàg kwaw a'e. Nuzawy kwaw pàri heityk pyrer.
\q1 Pezàmàtyry'ym a'e awa tuweharupi. Màràn mehe pepytu'u putar iàmàtyry'ym ire nehe.
\q1 
\v 4 Pepurumunyryk kar wer hehe tuwihawete romo heko haw wi pe.
\q1 Penemu'emaw ikatu peme.
\q1 Pemume'u mua'u ikatu ma'e hehe peze'eg mehe.
\q1 Pepy'a pupe zote pemono ze'egaiw hehe.
\b
\q1 
\v 5 Xo Tupàn inuromo zo hepy'a upytu'u ihe.
\q1 Xo a'e zo àro ihe.
\q1 
\v 6 Xo a'e zo wiko itahu hemimar ài a'e. Xo a'e zo hepyro.
\q1 Hemim heàmàtyry'ymar wanuwi.
\q1 Nahereityk pixik kwaw wà nehe.
\q1 
\v 7 Xo Tupàn inuromo zo heta hepyro àwàm. Xo a'e zo wexak hekatu haw.
\q1 Wiko itahu hemimar ikàg ma'e ài.
\b
\q1 
\v 8 Heremiaihu wà, pezeruzar tuweharupi Tupàn rehe nehe.
\q1 Pemume'u ma'erahy penemipuraraw paw izupe nehe,
\q1 Ta'e a'e wiko zanemimaw romo a'e xe.
\q1 
\v 9 Teko a'e wà, hemetarer 'ym ma'e wà, hemetarer katu ma'e wà no,
\q1 Nuzawy kwaw pytuhemaw wà.
\q1 Aze mo upyta ma'epuhuz taw hexak kar haw rehe wà,
\q1 Naheta iwer mo wapuhuz taw wà.
\q1 Wapuhuz taw ipixika'i wera'i pytuhemaw wi wà.
\q1 
\v 10 Pezeruzar zo puruzuka haw rehe nehe.
\q1 — Hemunar putar ma'e rehe temetarer tetea'u imono'og pà nehe,
\q1 Peze zo pezeupe nehe.
\q1 Aze penemetarer uhua'u wewer tuweharupi nehe, nezewe rehe we pezeruzar zo hehe nehe.
\b
\q1 
\v 11 Aenu Tupàn Zanezar ize'eg mehe. Aenu wiwi ize'eg mehe no. — Aiko kàgaw izar romo ihe, i'i.
\q1 
\v 12 Aiko puruamutar haw izar romo no, i'i.
\q1 Umekuzar wanemiapo kwer
\q1 Teko wanupe pitàitàigatu a'e.
\c 63
\s1 Tupàn wiko 'y ài uzeruzar ma'e wanupe
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 O Tupàn, ereiko hezar romo ne.
\q1 Hereko wer tuwe nerenataromo ihe.
\q1 Azeharomoete hereko wer nerehe we. Herekwe neputar a'e.
\q1 Neputar haw nuzawy kwaw heiwez haw.
\q1 Nazawy kwaw ywy uxinig ma'e kwer 'y hereko 'ymar. Uruputar 'y ài ihe.
\q1 
\v 2 Hepuruexak wer nerehe neràpuzuhu pupe.
\q1 Hepuruexak wer nekàgaw rehe. Nepuràg eteahy haw rehe hepuruexak wer.
\q1 
\v 3 Heamutar katu pe ne. Heamutar katu haw ikatu wera'u ihewi a'e, herekuwe haw wi a'e.
\q1 A'e rupi amume'u putar nekatu haw nehe.
\q1 
\v 4 Herekuwe mehe we aze'eg putar nekatu haw rehe ihe nehe.
\q1 Aupir putar hepo newe heze'eg pà nehe.
\q1 
\v 5 Ikatu ma'e ihewe neremimur nuzawy kwaw temi'u hete katu ma'e.
\q1 Uhyk ihewe.
\q1 A'e rupi amuzàg nekatu haw rehe zegar haw herurywete haw rupi newe ihe.
\b
\q1 
\v 6 He'aw mehe, hema'enukwaw nerehe ihe.
\q1 Amumaw pytun gatu nerehe hema'enukwaw pà.
\q1 
\v 7 Ta'e hepytywà pe tuweharupi ne xe.
\q1 Azegar herurywete haw rupi nepepo wy pe ihe.
\q1 
\v 8 Nepo awyze har hepyhyk katu a'e.
\q1 Urupyhyk katu ihe no.
\b
\q1 
\v 9 Herehe ipuruzuka wer ma'e a'e wà nehe,
\q1 Wezyw putar umàno ma'e kwer wapyta haw pe a'e wà nehe.
\q1 
\v 10 Zauxiapekwer uzuka putar a'e teko zeàmàtyry'ymawhu pe a'e wà nehe.
\q1 Zawar zàwenugar hehaite ma'e u'u putar wanetekwer wà nehe.
\q1 
\v 11 Tuwihawete hurywete putar a'e nehe, ta'e Tupàn umur iàmàtyry'ymar waneitykaw izupe a'e xe.
\q1 Teko Tupàn her rehe wemiapo ràm imume'u har hurywete putar a'e wà nehe.
\q1 Tupàn uwàpytym putar hemu'em ma'e wazuru a'e wà nehe.
\c 64
\s1 Hepyro pe heàmàtyry'ymar wanuwi, Tupàn
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 O Tupàn, herenu pe newe heze'eg mehe nehe,
\q1 Ta'e zawaiw katu hereko haw kury xe.
\q1 Hepyro pe nehe,
\q1 Ta'e akyze heàmàtyry'ymar wanuwi ihe xe.
\q1 
\v 2 Ikatu 'ym ma'e umume'u hezuka àwàm uzeupeupe wà. Hepyro pe wanuwi nehe.
\q1 Awa iaiw ma'e uzemono'og ikatu 'ym ma'e iapo àwàm rehe wà. Ezekaiw katu herehe wanuwi hemunyryk kar pà nehe.
\b
\q1 
\v 3 Teko ikatu 'ym ma'e umuaime katu uwapeku takihepuku ài wà.
\q1 U'yw ài uwako'ok uze'eg iaiw ma'e wà no. Waze'eg tynehem puruzuka haw pupe.
\q1 
\v 4 Umuhàmuhàz wemu'emaw iaiw ma'e na'arewahy wà.
\q1 Umumaw teko ikatu ma'e wemu'emaw iro ma'e pupe wà no.
\q1 
\v 5 Uzemurywete ikatu 'ym ma'e wemiapo ràm imume'u pà uzeupeupe wà.
\q1 Umume'u puruzuka haw imono àwàm rehe wà no.
\q1 — Ni amo nupuner kwaw zanerexakaw rehe wà, i'i uzeupeupe wà.
\q1 
\v 6 Wanemiapo ràm imume'u haw tynehem ikatu 'ymaw pupe.
\q1 — Ximume'u ikatu 'ym ma'e zaneremiapo ràm kwez kury.
\q1 Teko nukwaw pixik kwaw iapo arer wà nehe, i'i uzeupeupe wà. Teko nukwaw kwaw amo teko wama'enukwaw paw wà. Nukwaw kwaw wanemiapo putar haw wà.
\q1 
\v 7 Tupàn omomor putar u'yw wakutyr a'e nehe.
\q1 Na'arewahy uzywà putar a'e wà nehe.
\q1 
\v 8 Tupàn umumaw putar a'e teko waze'eg hekuzaromo a'e wà nehe.
\q1 A'e teko wanexakar uweruwaruwak putar uwàkàg wà nehe, wanehe uze'eg urywahyahy pà wà.
\b
\q1 
\v 9 Na'e teko paw ukyze putar wà nehe.
\q1 Ima'enukwaw putar Tupàn hemiapo kwer rehe wà nehe.
\q1 Uze'eg putar hemiapo kwer ikàg ma'e rehe wà nehe no.
\q1 
\v 10 Tupàn Tuweharupi Wiko Ma'e umurywete kar teko ize'eg heruzar har a'e wà.
\q1 A'e teko wexak upyro haw Tupàn inuromo wà.
\q1 A'e paw umume'u putar ikatu haw wà nehe.
\c 65
\s1 Umume'u Tupàn ikatu haw ma'e itym myr i'a kwer ipo'o mehe wà
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 O Tupàn, tuwe teko umume'u nekatu haw ywytyr Xiàw her ma'e rehe wà nehe.
\q1 Tuwe omono wemimume'u kwer newe wà nehe no.
\q1 
\v 2 Erewazar waze'eg wanupe ne.
\q1 A'e rupi ur putar nemuwete pà wà nehe,
\q1 
\v 3 Ta'e ikatu 'ym ma'e iapo har romo wanekon wà xe.
\q1 Ikatu ma'e ureremiapo 'ym uremuigo kar heityk pyrer romo.
\q1 Nezewe rehe we eremunàn ureremiawy kwer.
\q1 
\v 4 Neremixamixak kwer hurywete tuwe a'e wà.
\q1 Ererur a'e neremixamixak kwer ne wà, neràpuzuhu pupe wamuigo kar pà ne wà.
\q1 Ure urerurywete putar ikatu ma'e neràpuz me har rehe ure nehe.
\q1 Nema'e ikatu ma'e neràpuzuhu pe har ikatuahy urewe.
\b
\q1 
\v 5 O Tupàn, erewazar ureze'eg urewe ne,
\q1 Uremuigo kar pà ureàmàtyry'ymar waneitykar romo ne.
\q1 Erezapo ikatuahy ma'e urepyro pà ne no.
\q1 Teko ywy nànànar a'e wà,
\q1 Te teko yryhu muite wera'u ma'e wi ur ma'e a'e wà, uzeruzar nerehe upaw rupi katete a'e wà.
\q1 
\v 6 Eremuapyk ywytyr wanenaw rehe nekàgaw rupi ne wà.
\q1 Nezewe erexak kar nepuner haw uhua'u ma'e purupe.
\q1 
\v 7 Eremupytu'u kar yryhu ikotok ire ne.
\q1 Eremumaw ikotok iànoànogaw no. Eremupytu'u kar teko waneiheihem ire ne wà.
\q1 
\v 8 Ywy nànànar ukyze newi wà,
\q1 Neremiapo kwer uhua'u ma'e iapo awer ikwaw mehe wà.
\q1 Wexak neremiapo kwer ikatuahy ma'e wà.
\q1 A'e rupi uhapukaz urywete haw rupi ywy nànàn wà.
\b
\q1 
\v 9 Eremugyr kar àmàn. Nezewe mehe erexak kar ywy rehe nezekaiw paw purupe.
\q1 Eremukatu ywy.
\q1 Hezuz ma'e tetea'u hehe. Ne, o Tupàn, eremugyr kar àmàn.
\q1 Nezewe mehe eremynehem yrykaw 'y pupe.
\q1 Ywy umuezuz temi'u a'e, ta'e eremuàgà'ym a'e rupi ne xe.
\q1 
\v 10 Eremugyr kar àmàn tetea'u ko rehe.
\q1 A'e 'y umuàkym ywy.
\q1 Eremuàkym ywy àmàn pupe.
\q1 A'e rupi hezuz itym pyrer a'e.
\b
\q1 
\v 11 Nekatuahy. A'e rupi heta tetea'u temi'u hezuz ma'e.
\q1 Aze erekwaw amo ywy rehe, heta tetea'u temi'u a'e ywy rehe hezuz ma'e.
\q1 
\v 12 Ka'api'i rehe heta tetea'u ma'ea'yr wà.
\q1 Ywytyr tynehem turywete haw pupe.
\q1 
\v 13 Àràpuhàràn upyk ywy katu wà.
\q1 Ywyàpyznaw tynehem arozràn pupe.
\q1 Heiheihem urywete haw rupi wà. Uzegar urywete haw rupi wà no.
\c 66
\s1 Tupàn imuwete haw
\d Zegar haw
\q1 
\v 1 Tuwe teko ywy nànànar umume'u Tupàn ikatu haw urywete haw rehe uhapukaz taw pupe wà nehe.
\q1 
\v 2 Pemuzàg zegar haw ikatu haw rehe har izupe nehe.
\q1 Pemono ikatu haw rehe imume'u haw ipuràg eteahy ma'e nehe, izupe nehe.
\q1 
\v 3 Peze'eg nezewe Tupàn pe nehe.
\q1 — Neremiapo kwer umupytuhegatu kar teko a'e wà.
\q1 Nekàgaw uhua'u tuwe no.
\q1 Te neàmàtyry'ymar ukyze newi uzeamumew pà nerenataromo wà.
\q1 
\v 4 Ywy nànànar nemuwete katu wà.
\q1 Umuzàg zegar haw nekatu haw rehe wà no.
\q1 Teko paw umuzàg zegar haw nerer ikatu haw rehe a'e wà, peze Tupàn pe nehe.
\b
\q1 
\v 5 Pezur Tupàn hemiapo kwer hexak pà nehe.
\q1 Pepytuhegatu ikatuahy ma'e teko wanupe iapo pyrer hexak mehe nehe.
\q1 
\v 6 Uzapo yryhu ywy uxinig ma'e romo a'e.
\q1 Zaneipy wahaw yrykawhu upy rehe wata pà wà.
\q1 Zanerurywete katu hemiapo kwer rehe.
\q1 
\v 7 Upureruze'eg putar tuweharupi upuner haw rupi nehe.
\q1 Ume'egatu teko ywy nànànar wanehe, weha pupe a'e.
\q1 Tuwe ni amo nuzàmàtyry'ym kwaw Tupàn a'e wà nehe.
\b
\q1 
\v 8 Tuwe ywy nànànar paw umume'u zanezar ikatu haw wà nehe.
\q1 Tuwe umuzàg zegar haw ikatu haw rehe har wahy haw rupi wà nehe.
\q1 
\v 9 Zanemuikuwe kar a'e.
\q1 Nazanemu'ar kar kwaw.
\b
\q1 
\v 10 O Tupàn, ureagaw pe ne.
\q1 Teko umukatu parat tata pupe imupyràn pà wà. Nezewegatete uremukatu pe ureagaw pà ne.
\q1 
\v 11 Uremu'ar kar pe purupyhykaw pupe.
\q1 Ereraha kar ma'e ipuhuz katu ma'e urekupe pe ne no.
\q1 
\v 12 Eremupyrog kar ureàmàtyry'ymar urerehe ne wà.
\q1 Oroho tata rupi. 'Y rupi oroho no.
\q1 Ko 'ar rehe kury, urererur pe uremimaw pe muite ureàmàtyry'ymar wanuwi ne kury.
\b
\q1 
\v 13 Araha putar ma'ea'yr hapy paw pyràm neràpuz me ihe nehe.
\q1 Amono putar heremimume'u kwer newe nehe.
\q1 
\v 14 Amume'u ma'e newe imono pyràm ma'erahy ipuraraw mehe ihe.
\q1 Amono putar tuwe a'e ma'e newe nehe.
\q1 
\v 15 Araha putar àràpuhàràn hawitu ma'e kuzà ihe wà nehe, ma'ea'yr hapy haw rehe hapy pyràm romo ihe wà nehe.
\q1 Azuka kar putar tapi'ak awa ihe wà nehe. Àràpuhàrànete azuka kar putar ihe wà nehe no.
\q1 Wanàtàxiner uzeupir putar ywak rehe nehe.
\b
\q1 
\v 16 Pe Tupàn wi ukyze ma'e paw pe wà, pezur pezeapyaka katu pà nehe.
\q1 Amume'u putar Tupàn ihewe hemiapo kwer peme ihe nehe.
\q1 
\v 17 Ahapukaz ihe, hepytywà àwàm henoz pà ihe.
\q1 Na'e amume'u ikatu haw hezegar pà.
\q1 
\v 18 Aze mo amonokatu hema'enukwaw paw ikatu 'ym ma'e hepy'a pe,
\q1 Ne hezar naherenu iwer mo pe ne.
\q1 
\v 19 Herenu katu zote Tupàn a'e.
\q1 Uwazar heze'eg awer ihewe.
\q1 
\v 20 Amume'u Tupàn ikatu haw ihe, ta'e wenu katu hereminozgwer tuweharupi a'e xe.
\q1 Nahekyty'ym kwaw a'e.
\q1 Heamutar katu a'e.
\c 67
\s1 Umume'u Tupàn ikatu haw ma'e itym myr ipo'o mehe wà
\d Zegar haw
\q1 
\v 1 O Tupàn, urepuhareko pe nehe. Emur neze'egatu urerehe nehe.
\q1 Eme'e urerehe nekatu haw rupi nehe.
\q1 
\v 2 Nezewe mehe ywy nànànar ukwaw putar neremiapo putar haw wà nehe.
\q1 Nepurupyro haw uzexak kar putar teko paw wanupe nehe.
\b
\q1 
\v 3 Tuwe teko ywy nànànar umume'u nekatu haw wà nehe, o Tupàn.
\q1 Tuwe teko paw umume'u nekatu haw wà nehe.
\b
\q1 
\v 4 Tuwe hurywete paw rupi wà nehe. Tuwe uzegar urywete haw rupi wà nehe no.
\q1 Ta'e eremume'u katu teko wanemiapo kwer ne xe.
\q1 Eremuata kar teko ywy nànànar katu haw rupi ne wà no.
\b
\q1 
\v 5 Tuwe teko ywy nànànar umume'u nekatu haw wà nehe, o Tupàn.
\q1 Tuwe teko paw umume'u nekatu haw wà nehe.
\b
\q1 
\v 6 Ywy umur hezuz ma'e kwer a'e.
\q1 Tupàn Zanezar umur uze'egatu zanerehe.
\q1 
\v 7 Umur uze'egatu zanerehe.
\q1 Tuwe teko ywy nànànar ukyze izuwi wà nehe.
\c 68
\s1 Tupàn weityk wàmàtyry'ymar wà
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 Tupàn upu'àm wàmàtyry'ymar wamuhàmuhàz pà a'e.
\q1 Hehe iakatuwawahy 'ym ma'e uzàn henatar wi wà.
\q1 Tupàn weityk a'e wà.
\q1 
\v 2 Umuhàmuhàz tàtàxiner ài wà. Ukàzym tàtàxiner ywytu rehe.
\q1 Iraity typyràn tata huwake a'e.
\q1 Nezewegatete ikatu 'ym ma'e upaw Tupàn henataromo wà.
\q1 
\v 3 Ikatu ma'e hurywete wà. Hurywete henataromo wiko mehe wà.
\q1 Umuzàg zegar haw wà, ta'e tynehem turywete haw pupe wà xe.
\b
\q1 
\v 4 Pezegar Tupàn pe ikatu haw imume'u pà nehe.
\q1 Pemume'u her ikatu haw pezegar pà nehe.
\q1 Pemukatu ywàkun ikupe pe ur ma'e ràm hape ràm nehe.
\q1 Tupàn Tuweharupi Wiko Ma'e her romo a'e. Penurywete henataromo peneko mehe nehe.
\b
\q1 
\v 5 Tupàn a'e, tàpuzuhu imonokatu pyrer pupe wikuwe ma'e a'e, uzekaiw tu 'ym ma'e ihy 'ym ma'e wanehe a'e.
\q1 Upyro kuzà imen umàno ma'e a'e wà no.
\q1 
\v 6 Omono waneko àwàm heko haw 'ym ma'e wanupe no.
\q1 Umuhem kar imunehew pyrer wà.
\q1 A'e rupi wiko katu urywete haw rupi wà.
\q1 Tuwihawete romo heko haw iputar 'ymar wà nehe, wiko putar ywyxiguhu rehe wà nehe.
\b
\q1 
\v 7 O Tupàn, neremiaihu waneraha mehe,
\q1 Ywyxiguhu rehe neata mehe,
\q1 
\v 8 Ywy uryryryryz a'e.
\q1 Ywak uzakook àmàn a'e no,
\q1 Ta'e ne Tupàn Xinaz rehe har ne xe, Izaew wazar ne xe, erezur a'e pe ne xe.
\q1 
\v 9 Eremugyr kar àmàn tetea'u ne.
\q1 Eremupyahu kar neywy ikatu 'ym ma'e no.
\q1 
\v 10 Neremiaihu uzapo weko haw ko ywy rehe wà.
\q1 Erezekaiw katu ma'e hereko 'ymar wanehe nekatu haw rupi.
\b
\q1 
\v 11 Eremume'u neremimutar purupe a'e 'ar mehe.
\q1 A'e rupi kuzà tetea'u weraha ko neze'eg teko wanupe a'e wà.
\q1 
\v 12 — Tuwihawete a'e wà, wanemiruze'eg zauxiapekwer a'e wà no, uzàn oho waiko wà kury, i'i wà.
\q1 Wàpuz me kuzà uzaikaikaw ma'e wàmàtyry'ymar wanuwi ipyro pyrer wà.
\q1 
\v 13 A'e kuzà nuzawy kwaw pykahu parat pupe iwàiwàn pyrer wà, pykahu pepo or ikatu ma'e ài heny katu ma'e hereko har wà.
\q1 Màràzàwe tuwe amo zauxiapekwer upyta àràpuhàràn hawitu ma'e wamono'ogaw pupe wà,
\q1 Zeàmàtyry'ymawhu 'ar mehe wà.
\q1 
\v 14 Tupàn Ikàg Wera'u Ma'e umuhàmuhàz tuwihawete wamono a'e wà.
\q1 A'e 'ar mehe ukyr àmàn huwixàgatu ma'e xig ma'e ywytyr Xaramon her ma'e rehe.
\b
\q1 
\v 15 Aiha katu ywytyr Màxà her ma'e.
\q1 Heta tetea'u iapyr izupe.
\q1 
\v 16 Apuranu a'e ywytyruhu wanehe. — Màràzàwe tuwe peme'e ywytyr rehe, Tupàn weko àwàm romo hemixak kwer rehe.
\q1 Penewyrowyro hexak mehe nehe, a'e wanupe.
\q1 Tupàn Tuweharupi Wiko Ma'e wiko putar a'e pe tuweharupi nehe.
\b
\q1 
\v 17 Tupàn Zanezar ur Xiàw ywytyr wi weko àwàm imonokatu pyrer pe a'e,
\q1 Ywyramawa zeàmàtyry'ymaw rehe har tetea'u wainuinuromo a'e.
\q1 
\v 18 Uzeupir ywate wera'u har pe.
\q1 Weraha teko wemipyhyk kwer tetea'u uzeupi uzeupir mehe wà.
\q1 Te awa Tupàn heruzar 'ymar weraha ma'e imono pyràm izupe wà.
\q1 Tupàn Tuweharupi Wiko Ma'e wiko putar a'e pe nehe.
\b
\q1 
\v 19 Tuwe teko umume'u zanezar ikatu haw wà nehe.
\q1 Tuweharupi weraha ipuhuz katu ma'e zanekupe pe har zanerekuzaromo a'e.
\q1 Tupàn wiko zanepyro har romo a'e.
\q1 
\v 20 Zanezar wiko Tupàn purupyro ma'e romo.
\q1 Wiko Tuweharupi Wiko Ma'e romo, zanezar romo hekon.
\q1 Zanepyro zanemàno haw wi.
\q1 
\v 21 Upemok putar wàmàtyry'ymar waàkàg a'e wà nehe,
\q1 Ikatu 'ygwer inuromo heko wiwi wer ma'e waàkàg a'e wà nehe.
\q1 
\v 22 Tupàn Zanezar uze'eg nezewe zanewe.
\q1 — Amuzewyr kar putar peàmàtyry'ymar Màxà ywytyr wi ihe wà nehe.
\q1 Ywy yryhu iwyr har wi amuzewyr kar putar wamuwà ihe wà nehe.
\q1 
\v 23 Nezewe mehe pezahak putar wanuwykwer pupe nehe.
\q1 Zawar peneimaw upuner wanuwykwer i'u haw rehe wemimutar rupi katu wà nehe no, i'i Tupàn.
\b
\q1 
\v 24 O hezar heruwihawete, teko paw wexak neàmàtyry'ymar wanerur haw rehe neata haw wà.
\q1 Wexak neràpuzuhu pupe neixe haw wà no.
\q1 
\v 25 Uzegar ma'e ràgypy oho wà. Xi'àm ipy har wà, uzegar ma'e wà no, oho wanaikweromo wà.
\q1 Kuzàtàigwer upyta wamyter pe ipu ma'e ipew ma'e imupumupu pà wà.
\q1 
\v 26 Pemume'u Tupàn ikatu haw hemiaihu wainuromo nehe, wazemono'og mehe nehe.
\q1 Pe Izaew izuapyapyr paw wà, pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe.
\q1 
\v 27 Mezàmi izuapyapyr ràgypy ur wà.
\q1 Pixika'i wera'i amo Izaew ta'yr wazuapyapyr imono'og pyrer wanuwi a'e. Na'e ur Zuta izuapyapyr wanuwihaw wà, wemiaihu wanerur pà wà.
\q1 A'e re ur Zemurom wanuwihaw Napitari wanuwihaw wanehe we wà.
\b
\q1 
\v 28 Exak kar nepuner haw nehe, o Tupàn.
\q1 Erezapo ikatu ma'e urewe a'e nepuner haw rupi.
\q1 
\v 29 Zeruzarez pe, neràpuzuhu pupe,
\q1 Tuwihawete werur ma'e newe wà.
\q1 
\v 30 A'e pe neapyk mehe emume'u Ezit ywy imumaw pàwàm nehe. Nuzawy kwaw zàwàruhu takwar inuromo har.
\q1 O Tupàn, emume'u amogwer ywy wamumaw pàwàm nehe.
\q1 Nuzawy kwaw tapi'ak awa tetea'u wana'yr wainuromo har wà.
\q1 Neze'eg henu mehe uzeamumew putar nerenataromo wà nehe. Werur putar parat tetea'u newe wà nehe.
\q1 Emuhàmuhàz teko zeàmàtyry'ymawhu iputar har ne wà nehe.
\q1 
\v 31 Tuwihawete ze'eg herur har ur putar Ezit ywy wi wà nehe.
\q1 Exio ywy rehe har ur putar opo hupir pà a'e wà nehe no. Uze'eg putar newe wà nehe, o Tupàn.
\b
\q1 
\v 32 Pemuzàg zegar haw Tupàn pe nehe, teko ywy nànànar wà.
\q1 Pezegar zanezar ikatu haw imume'u pà nehe.
\q1 
\v 33 Pemume'u ikatu haw nehe, kawaru ku'az har ywak rehe har, ywak kwehe arer rehe har.
\q1 Pezeapyaka katu zanezar ize'eg mehe nehe. Ikàg ize'eg.
\q1 
\v 34 Pemume'u Tupàn ipuner haw nehe.
\q1 Ikàgaw ipuràg eteahy haw Izaew wanehe tuz.
\q1 Ikàgaw ywak rehe hin.
\q1 
\v 35 Ikatuahy Tupàn henaw pe heko haw.
\q1 Tupàn Izaew wazar omono ukàgaw wemiaihu wanupe.
\b
\q1 Tupàn ikatu haw pemume'u nehe.
\c 69
\s1 Amo awa iàmàtyry'ym pyr uze'eg Tupàn pe
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 O Tupàn, hepyro pe nehe,
\q1 Ta'e azeapypyk etea'i 'y pupe ihe kury xe.
\q1 
\v 2 Apyta tekoko to'om ohoete ma'e pupe.
\q1 Naheta kwaw ywytàtà hepu'àmaw romo.
\q1 'Y ohoete ma'e pupe aixe.
\q1 'Y hereraha hezuka etea'i pà uwyryk mehe a'e.
\q1 
\v 3 Heze'eg myaw ihe, ta'e ahapukaz tetea'u ihe xe.
\q1 He'az uxinigahy ihewi.
\q1 Hereha ikene'o, ta'e aikar tuwe hezar tuweharupi ihe xe.
\q1 Àro hepyro àwàm.
\b
\q1 
\v 4 Amo na'iakatuwawahy e kwaw herehe a'e wà. Heta tetea'u wà.
\q1 Waneta haw uhua'u wera'u he'aw heàkàg rehe har wanuwi wà.
\q1 Heàmàtyry'ymar umume'u temu'emaw herehe wà.
\q1 Ikàg a'e wà. Ipuruzuka wer herehe wà.
\q1 — Nemunar ma'e rehe. Emuzewyr kar a'e ma'e izarer pe nehe, i'i ihewe wà. Nahemunar kwaw ma'e rehe ihe.
\b
\q1 
\v 5 O Tupàn, napuner kwaw heremiapo kwer ikatu 'ym ma'e imimaw rehe newi ihe.
\q1 Erekwaw iranaiw ma'e romo hereko awer.
\q1 
\v 6 O hezar, tupàn Tuweharupi Wiko Ma'e ikàg wera'u ma'e.
\q1 Emumaranugar kar zo nerehe uzeruzar ma'e ne wà nehe,
\q1 Heremiapo kwer rehe ne wà nehe.
\q1 O Tupàn Izaew wazar ne,
\q1 Erur kar zo heaiw paw nemuwete katu har wanupe nehe.
\q1 
\v 7 Teko uze'eg zemueteahy herehe a'e wà, ta'e aiko neremiruze'eg romo ihe xe.
\q1 Hemaranugar ihe no.
\q1 
\v 8 Aiko amo ae ywy rehe har ài heryky'yr wanupe ihe, herywyr wanupe ihe.
\q1 Aiko ikwaw pyr 'ym ài heànàm wanupe.
\b
\q1 
\v 9 Neràpuzuhu iamutar katu haw ukaz hepy'a pe tata ài.
\q1 Nerehe uze'eg zemueteahy ma'e wanemiapo kwer iaiw ma'e u'ar herehe wà.
\q1 
\v 10 Apytu'u hemai'u re 'ar tetea'u imumaw pà ihe. Azemuigo kar ikàg 'ym ma'e ài.
\q1 Uze'eg zemueteahy herehe wà.
\q1 
\v 11 Amunehew kamir umàno ma'e kwer rehe zai'o haw rehe har ihe.
\q1 Upuka herehe wà.
\q1 
\v 12 Uze'eg herehe nahu rupi wà.
\q1 Uka'u ma'e uzapo ze'eg puràg herehe har wà. Umume'u umyrypar wanupe herehe upuka pà wà.
\b
\q1 
\v 13 Nezewe rehe we, o Tupàn Tuweharupi Wiko Ma'e, aze'eg newe.
\q1 O Tupàn, ewazar heze'eg ihewe 'ar newe ikatu ma'e rehe nehe,
\q1 Ta'e heamutar katu pe ne xe.
\q1 Hepyro pe nehe neze'eg awer rupi katete nehe.
\q1 
\v 14 Hemukàzym kar zo pe to'om pupe nehe.
\q1 Hepyro pe heàmàtyry'ymar wanuwi nehe.
\q1 Hemunyryk kar pe màno haw 'y typya'u ma'e zàwenugar wi nehe.
\q1 
\v 15 Hereraha kar zo pe ykotok pe nehe.
\q1 Hemukàzym kar zo pe 'y typya'u ma'e pupe nehe.
\q1 Tuwe tywypaw nahemukun kwaw nehe.
\b
\q1 
\v 16 O Tupàn Tuweharupi Wiko Ma'e. Ewazar heze'eg ihewe nehe, ta'e nekatu ne xe, ta'e erepuruamutar katu ne xe.
\q1 Hepytywà pe nehe, ta'e nepurupuhareko haw uhua'u a'e xe.
\q1 
\v 17 Ezeàmim zo neremiruze'eg wi nehe, ihewi nehe.
\q1 Ewazar heze'eg ihewe kury, ta'e apuraraw ma'erahy tetea'u ihe kury xe.
\q1 
\v 18 Ezur hepyro pà nehe.
\q1 Hepyro heàmàtyry'ymar wanuwi nehe.
\b
\q1 
\v 19 Erexak heàmàtyry'ymar wanereko paw rupi ne wà.
\q1 Erekwaw herehe waze'eg zemueteahy awer ne.
\q1 Hemaranugar awer erekwaw. Erekwaw ma'e ikàg 'ym ma'e ài hereko awer no.
\q1 
\v 20 Herehe waze'eg zemueteahy awer upei'ài'àg hepy'a a'e.
\q1 Nàro kwaw hepyro àwàm kury.
\q1 — Aze ru'u amo hepuhareko putar wà nehe, a'e wanupe. Àro e hepuhareko àwàm.
\q1 Ni amo nahepuhareko kwaw wà.
\q1 — Aze ru'u amo hemurywete kar putar wà wà nehe, a'e wanupe. Àro e hemurywete kar àwàm.
\q1 Ni amo nuhem kwaw heruwake wà.
\q1 
\v 21 Hema'uhez mehe umur puruzuka haw ihewe heremi'u romo wà.
\q1 Heiwez mehe umur win hazahy ma'e ihewe wà.
\b
\q1 
\v 22 Tuwe wamai'u hawhu umuaiw waneko haw nehe.
\q1 Tuwe tupàn a'ua'u wamuwete haw rehe wanurywete haw umumaw wà nehe.
\q1 
\v 23 Emuigo kar hehàpyhà 'ym ma'e romo ne wà nehe.
\q1 Ezo'ok wakàgaw paw wanuwi nehe no.
\q1 
\v 24 Ezakook nekwahy haw wanehe 'y ài nehe.
\q1 Tuwe nekwahy haw uhem wanupe tata ài nehe.
\q1 
\v 25 Tuwe wanemiruze'eg zauxiapekwer waneko haw uzeapo teko heta 'ymaw romo nehe.
\q1 Tuwe naheta kwaw ni pitài zauxiapekwer wikuwe ma'e wanàpuzràn pupe wà nehe.
\q1 
\v 26 Erezepyk amo teko wanehe. A'e zauxiapekwer oho a'e teko wanaikweromo wà.
\q1 Erekutuk amo teko ne wà. A'e zauxiapekwer uze'eg urywahyahy neremikutuk kwer wanehe wà.
\q1 
\v 27 Uzapo ikatu 'ym ma'e wà. A'e rupi ezepyk wanehe nehe.
\q1 Epyro zo ne wà nehe.
\q1 
\v 28 Emunàn kar waner pape wikuwe ma'e waner hereko har wi ne wà nehe.
\q1 Emuapyk kar zo waner pape teko ikatu ma'e waner hereko har rehe ne wà nehe.
\b
\q1 
\v 29 Apuraraw ma'erahy iteko. Nàro kwaw hepyro haw.
\q1 O Tupàn, hemupu'àm pe nehe. Hepyro pe nehe.
\q1 
\v 30 Amume'u putar Tupàn ikatu haw amo zegar haw imuzàg pà nehe.
\q1 Amume'u putar uhua'u haw nehe, ta'e ikatuahy ihewe xe.
\q1 
\v 31 Nezewe haw ikatu wera'u putar Tupàn Tuweharupi Wiko Ma'e pe nehe,
\q1 Henataromo tapi'ak awa tua'u ma'e izuka haw wi nehe.
\q1 
\v 32 Aze ma'erahy ipuraraw par wexak a'e ma'e wà nehe, hurywete putar wà nehe.
\q1 Tupàn imuwete katu har hurywete putar wà nehe.
\q1 
\v 33 Ta'e Tupàn Tuweharupi Wiko Ma'e wenu ma'e hereko 'ymar a'e wà xe.
\q1 — Napupytywà kwaw nehe, ni'i kwaw zemunehew paw pe imunehew pyrer wanupe.
\b
\q1 
\v 34 Pemume'u Tupàn ikatu haw nehe, o ywak, o ywy, o yryhu.
\q1 O ywak rehe har paw wà, o ywy rehe har paw wà, o yryhu pupe har wà.
\q1 
\v 35 Upyro putar Tupàn Zeruzarez tawhu nehe.
\q1 Umupu'àm kar wi tawhu Zuta ywy rehe arer wà nehe no.
\q1 Hemiaihu wikuwe putar a'e pe wà nehe. Wiko putar ywy imume'u pyrer izar romo wà nehe.
\q1 
\v 36 Tupàn hemiruze'eg wazuapyapyr wiko putar ko ywy izar romo wà nehe.
\q1 Iamutar katu har wikuwe putar hehe nehe.
\c 70
\s1 Tupàn purupytywà haw henoz taw
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 O Tupàn, hepyro pe nehe.
\q1 Hepytywà pe kury, Tupàn Tuweharupi Wiko Ma'e.
\q1 
\v 2 Tuwe amo weityk
\q1 Herehe ipuruzuka wer ma'e paw a'e wà nehe.
\q1 Tuwe uzeapo ikàg 'ym ma'e romo wà nehe.
\q1 Tuwe hema'erahy rehe hurywete ma'e uzàn umaranugar romo wà nehe.
\q1 
\v 3 Tuwe herehe uze'eg urywahyahy ma'e
\q1 U'ar iaiw paw pupe wà nehe.
\q1 Tuwe he'o ma'e romo uzeapo wà nehe no.
\b
\q1 
\v 4 Tuwe nemuwete har paw hurywete wà nehe.
\q1 Tuwe hurywete katu wà nehe.
\q1 Tuwe nepurupytywà haw iamutar katu har uze'eg nezewe tuweharupi wà nehe.
\q1 — Uhua'u tuwe Tupàn a'e, tuwe i'i wà nehe.
\b
\q1 
\v 5 Aiko hemetarer 'ym ma'e romo ihe. Naheta kwaw ma'e ihewe, o Tupàn.
\q1 Ereiko hepytywà har romo.
\q1 Hepyro har romo ereiko.
\q1 Neàrew zo hepytywà mehe nehe, o Tupàn Tuweharupi Wiko Ma'e.
\c 71
\s1 Tua'uhez uze'eg Tupàn pe
\q1 
\v 1 O Tupàn Tuweharupi Wiko Ma'e, ereiko hemimaw zàwenugar romo ne.
\q1 Nahemumaranugar pixik kar kwaw pe ne, ta'e nahereityk kar kwaw heàmàtyry'ymar wanupe ne xe.
\q1 
\v 2 Hepytywà pe hepyro pà nehe, ta'e nekatuahy ne xe.
\q1 Herenu pe hepyro pà nehe.
\q1 
\v 3 O Tupàn, eiko itahu hemimaw romo nehe.
\q1 Eiko tàpuztàtà ài hemunyryk kar pà ikatu 'ymaw wi nehe.
\q1 Ereiko itahu hemimar zàwenugar romo tàpuztàtà zàwenugar hepyro har romo ne.
\b
\q1 
\v 4 O hezar, hemunyryk kar ikatu 'ym ma'e wanuwi nehe.
\q1 Hemunyryk kar awa upuruzuka ma'e wanuwi nehe, iaiw ma'e wanuwi nehe no.
\q1 
\v 5 O Hezar, Azeruzar nerehe.
\q1 Hekwarer mehe arer we azeruzar nerehe, o Tupàn Tuweharupi Wiko Ma'e.
\q1 
\v 6 He'ar nànàn azemupu'àm kar newe ihe.
\q1 Hemim pe hezexak kar mehe arer we ne.
\q1 Amume'u putar nekatu haw tuweharupi ihe nehe.
\b
\q1 
\v 7 Teko tetea'u wexak hereko haw wà. Hekatu. A'e rupi wiko hezàwe wà no.
\q1 Ta'e ereiko hepyro har ikàg ma'e romo heàmàtyry'ymar wanuwi ne xe.
\q1 
\v 8 Amumaw 'ar katu nekatu haw imume'u pà ihe.
\q1 Amume'u nekàgaw. Nepuràg eteahy haw amume'u no.
\q1 
\v 9 — Aityk putar ihe kury, ta'e tua'uhez a'e kury xe, ere zo herehe nehe.
\q1 — Atyryk putar izuwi kury, ta'e na'ikàg kwaw a'e kury xe, ere zo herehe nehe.
\q1 
\v 10 Heàmàtyry'ymar ipuruzuka wer herehe wà.
\q1 Uze'eg hekutyr wà. Umume'u hezuka àwàm wà no.
\q1 
\v 11 — Tupàn weityk a'e awa a'e, i'i wà.
\q1 — Zaha haikweromo ipyhyk pà nehe,
\q1 Ta'e naheta kwaw ipyro har a'e xe, i'i wà.
\b
\q1 
\v 12 O Tupàn, etyryk zo ihewi nehe.
\q1 Hepytywà pe kutàri kury, Hezar.
\q1 
\v 13 Tuwe amo weityk heàmàtyry'ymar wà nehe.
\q1 Tuwe umumaw wà nehe.
\q1 Tuwe herehe ipurumumaw wer ma'e uzeityk kar wà nehe.
\q1 Tuwe imaranugar wà nehe.
\b
\q1 
\v 14 Tuweharupi uruàro ihe.
\q1 Tuweharupi amume'u wera'u putar nekatu haw nehe.
\q1 
\v 15 Amume'u putar nekatu haw.
\q1 Amumaw putar 'ar katu nehe, nepurupyro haw rehe heze'eg pà nehe.
\q1 — Màràzàwe tuwe erepyro teko ne wà, a'e newe. Nakwaw kwaw ihe. Nezewe rehe we amume'u putar nepurupyro haw nehe.
\q1 
\v 16 Amume'u putar nepuner haw nehe, o Hezar Tuweharupi Wiko Ma'e.
\q1 Amume'u putar neremiaihu wanuwi nepuir 'ymaw nehe.
\q1 Xo neremiaihu waneityk 'ymaw zo amume'u putar nehe.
\b
\q1 
\v 17 Kwàkwàmo romo hereko haw 'ar henataromo hemu'e pe herereko ne.
\q1 Amume'u wiwi neremiapo ikatuahy ma'e aha iteko ihe.
\q1 
\v 18 O Tupàn. Hetua'uhez ihe kury. He'aw xig no.
\q1 Nezewe rehe we etyryk zo ihewi nehe, O Tupàn.
\q1 Amume'u putar nepuner haw nekàgaw ko teko wanupe ihe nehe,
\q1 Wazuapyapyr wanupe ihe nehe no.
\q1 Epyta herehe we imume'u mehe nehe.
\b
\q1 
\v 19 Nerepuir kwaw neremiaihu ne wà. Nekatu haw, o Tupàn, uhem te ywak rehe.
\q1 Erezapo uhua'u ma'e ne.
\q1 Ni amo nuzapo kwaw agwer ma'e wà. Naheta kwaw amo nezàwenugar wà.
\q1 
\v 20 Erepuraraw kar ma'erahy ihewe. Hemuzemumikahy kar pe no.
\q1 Eremur wi putar nekàgaw ihewe nehe.
\q1 Hepyro putar pe tywypaw wi nehe.
\q1 
\v 21 Hemuigo kar putar ikàg wera'u ma'e romo. Teko tetea'u ukwaw putar heremiapo kwer wà nehe.
\q1 Tuweharupi hemurywete kar putar pe nehe.
\b
\q1 
\v 22 Amume'u nekatu haw imume'u àwàm newe. Amupu putar hewioràwiràn imume'u mehe nehe.
\q1 O hezar, amume'u putar nekatu haw nehe, ta'e ereiko puruwi utyryk 'ym ma'e romo ne xe.
\q1 Amupu putar hewioràwiràn zegar haw imuzàg pà newe nehe, o Tupàn ikatuahy ma'e Izaew wazar.
\q1 
\v 23 Zegar haw rehe newe hewioràwiràn imupu mehe,
\q1 Azegar putar herurywete romo nehe.
\q1 Azeharomoete azegar putar wahy haw rupi nehe, ta'e hepyro pe ne xe.
\q1 
\v 24 Amumaw putar 'ar katu nekatu haw rehe heze'eg pà nehe,
\q1 Ta'e ikatu 'ym ma'e rehe ihewe ipurapo wer ma'e a'e wà xe, uzeityk kar uzemumaw kar pà a'e wà xe.
\c 72
\s1 Tupàn pe ze'egaw tuwihawete rehe
\d Zegar haw Xàrumàw hemiapo kwer
\q1 
\v 1 O Tupàn, emu'e tuwihawete nehe.
\q1 Nezewe mehe ukwaw putar pureruze'egaw nekatu haw rupi nehe.
\q1 Emono nekatu haw izupe nehe.
\q1 
\v 2 Nezewe mehe weruze'egatu putar neremiaihu a'e wà nehe, wanehe umunar 'ym pà wà nehe.
\q1 Wiko putar hemetarer 'ym ma'e wanuwihawete ikatuahy ma'e romo nehe.
\q1 
\v 3 Tuwe uhyk temi'u nehe, tuwe uhyk ma'e nehe no, teko ko ywy rehe har wanupe nehe,
\q1 Ta'e teko uzapo ikatu ma'e waiko wà xe.
\q1 
\v 4 Tuwe tuwihawete na'imunar kwaw wama'e rehe teko waneruze'eg mehe nehe.
\q1 Tuwe upytywà ma'e hereko 'ymar wà nehe no.
\q1 Tuwe weityk teko wanemetarer rehe imunar ma'e wà nehe no.
\q1 
\v 5 Tuwe tuwihawete wikuwe wiwi kwarahy heta we mehe nehe, zahy heta we mehe nehe no.
\q1 Tuwe nupytu'u kwaw teko wanuwihawete romo wiko re nehe.
\q1 
\v 6 Tuwe tuwihawete nuzawy kwaw àmàn ko rehe ukyr ma'e nehe.
\q1 Tuwe nuzawy kwaw àmàn yrykaw romo uzeapo ma'e kwer nehe. Umukatu ywy a'e.
\q1 
\v 7 Tuwe ipureruze'egatu haw hezuz ma'eputyr ài hekuwe mehe nehe.
\q1 Tuwe teko wiko katu tuweharupi wà nehe, zahy ihyape 'ym mehe nehe.
\b
\q1 
\v 8 Ipureruze'egaw uzypyrog putar pitài yryhu pe nehe. Oho putar inugwer yryhu pe nehe.
\q1 Uzypyrog putar yrykawhu Ewparat her ma'e pe nehe. Oho putar ywy iahykaw pe nehe no.
\q1 
\v 9 Teko ywyxiguhu rehe har uzeamumew putar henataromo wà nehe.
\q1 Iàmàtyry'ymar wiko putar ikàg 'ym ma'e romo ipy huwake wà nehe no.
\q1 
\v 10 Tuwihawete Epàn ywy rehe har umur putar ma'e izupe wà nehe. Yrypypo'o rehe har nezewegatete wà no.
\q1 Tuwihawete Araw ywy rehe har wà nehe no, tuwihawete Exio rehe har wà nehe no, umur putar ma'e izupe wà nehe no.
\q1 
\v 11 Tuwihawete paw uzeamumew putar henataromo wà nehe.
\q1 Teko ywy nànànar weruzar putar ize'eg wà nehe no.
\b
\q1 
\v 12 — Urepytywà pe nehe, aze hemetarer 'ym ma'e i'i izupe wà nehe, tuwihawete upytywà putar a'e wà nehe.
\q1 Aze nuhyk kwaw ma'e amo wanupe nehe, aze naheta kwaw wapytywà har nehe, tuwihawete upytywà putar a'e teko a'e wà nehe no.
\q1 
\v 13 Upuhareko ikàg 'ym ma'e wà. Upuhareko ma'e hereko 'ymar wà no.
\q1 Upyro amo wamàno haw wi wà, aze naheta kwaw wapytywà haw wanupe.
\q1 
\v 14 Upyro imunar ma'e wanuwi wà. Puruzuka ma'e wanuwi upyro wà no.
\q1 Tuwihawete uzamutar katu a'e teko a'e wà.
\b
\q1 
\v 15 Tuwe tuwihawete wikuwe nehe.
\q1 Tuwe Araw ywy rehe har werur itazu or izupe wà nehe.
\q1 Tuwe teko uze'eg Tupàn pe tuweharupi wà nehe. — Epytywàgatu tuwihawete nehe, tuwe i'i izupe wà nehe.
\q1 Tuwe Tupàn uzapo ikatu ma'e izupe tuweharupi nehe.
\q1 
\v 16 Tuwe heta tetea'u arozràn ywy rehe nehe. Tuwe uhyk teko wanupe nehe.
\q1 Tuwe arozràn ipo'o pyrer upyk ywytyr wà nehe.
\q1 Tuwe ipo'o pyrer heta haw nuzawy kwaw ywytyr Irimano ywy rehe har ipo'o pyrer heta haw nehe.
\q1 Tuwe tawhu tynehem teko wapupe wà nehe.
\q1 Tuwe waneta haw nuzawy kwaw ka'api'i ywy katu rehe har heta haw wà nehe.
\q1 
\v 17 Tuwe teko naheharaz pixik kwaw tuwihawete her wi wà nehe.
\q1 Tuwe her ikwaw paw nukàzym kwaw kwarahy heta we mehe nehe.
\q1 Tuwe teko paw wenoz Tupàn ze'egatu izupe wà nehe.
\q1 Uzapo ikatu ma'e tuwihawete pe a'e. Tuwe uzapo ikatu ma'e teko wanupe nezewegatete nehe no.
\b
\q1 
\v 18 Pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw, Izaew wazar ikatu haw nehe,
\q1 Ta'e a'e ikatuahy ma'e iapo har romo hekon a'e xe.
\q1 
\v 19 Pemume'u her ikatu haw tuweharupi nehe.
\q1 Tuwe ikàgaw ipuràg eteahy haw umynehem ywy a'e nehe.
\q1 Azeharomoete. Azeharomoete.
\b
\q1 
\v 20 Upaw Tawi Zexe ta'yr Tupàn pe ze'egaw xe kury.
\c 73
\ms1 PAPE NA'IRUZ HAW
\mr 73–89
\s1 Tupàn ikatu haw
\d Zegar haw Azaw hemiapo kwer
\q1 
\v 1 Azeharomoete Tupàn ikatu teko Izaew izuapyapyr wanupe a'e.
\q1 Ikatu teko ipy'a ikatuahy ma'e Tupàn heruzar katu ma'e wanupe.
\q1 
\v 2-3 Herewyrowyroahy ihe, amo wanuwi wiko wera'u ma'e wanehe. Herewyrowyroahy ikatu 'ym ma'e wanehe ihe no, ta'e aexak waneko haw ikatu ma'e ihe xe.
\q1 A'e rupi apytu'u tària'i Tupàn rehe hezeruzar ire ihe,
\q1 Ta'e hewyrowyroahy wanehe ihe xe.
\b
\q1 
\v 4 Ikatu 'ym ma'e nupuraraw kwaw ma'erahy wà.
\q1 Ikàg a'e wà. Huhàgatu a'e wà no.
\q1 
\v 5 Nupuraraw kwaw ma'erahy amogwer wazàwe wà.
\q1 Nuzemumikahy kwaw amogwer wazàwe wà.
\q1 
\v 6 A'e rupi umunehew amo wanuwi wiko wera'u haw mu'yr ài wà.
\q1 Umunehew puruzuka haw kamirànàm ài wà no.
\q1 
\v 7 Wapy'a tynehem ikatu 'ymaw pupe wà.
\q1 Xo ikatu 'ym ma'e iapo àwàm rehe zo ima'enukwaw wà.
\q1 
\v 8 Ze'eg urywahyahy haw ikatu wanupe. Xo ikatu 'ym ma'e zo umume'u wà.
\q1 Wiko wera'u amo wanuwi wà. Umume'u amo wanehe umunar àwàm uzeupe wà.
\q1 
\v 9 Uze'eg zemueteahy Tupàn ywak rehe har rehe wà.
\q1 Uzapo kar ma'e ywy rehe har wanupe wiko wera'u haw rupi wà.
\q1 
\v 10 Nezewe Tupàn hemiaihu mua'u oho a'e teko wanekar pà wà.
\q1 Uzeruzar waze'eg rehe wà no.
\q1 
\v 11 — Tupàn nukwaw kwaw ko ma'e a'e nehe.
\q1 Ywate Wera'u Har nuexak pixik kwaw ko zaneremiapo kwer a'e nehe, i'i uzeupe wà.
\q1 
\v 12 Nezewe wanekon ikatu 'ym ma'e wà.
\q1 Heta tetea'u ma'e wanupe. Tuweharupi hemetarer katu wera'u oho waiko wà.
\b
\q1 
\v 13 Na'ikatu kwaw katu 'ygwer wi hetyrykaw ihe.
\q1 Màràzàwe tuwe amonokatu hepo iaiw paw wi.
\q1 
\v 14 O Tupàn, erepuraraw kar ma'erahy ihewe 'ar katu rehe.
\q1 Tuweharupi ku'em mehe erezepyk herehe.
\q1 
\v 15 Aze mo aze'eg ikatu 'ym ma'e wazàwe,
\q1 Iaiw ma'e azapo mo neremiaihu wanupe.
\q1 
\v 16 A'e rupi azeagaw ko ma'e ikwaw pà ihe.
\q1 Zawaiw katu wera'u ikwaw paw ihewe.
\q1 
\v 17 Na'e amo 'ar mehe neràpuzuhu pupe heixe mehe
\q1 Akwaw ikatu 'ym ma'e wanupe uzeapo ma'e ràm iahykaw rehe har ihe.
\q1 
\v 18 Eremupu'àm ywy ihym ma'e rehe ne wà.
\q1 Eremu'ar kar umumaw pàwàm me ne wà.
\q1 
\v 19 Na'arewahy eremumaw ikatu 'ym ma'e ne wà.
\q1 Iaiw wamumaw paw.
\q1 
\v 20 Teko heharaz upuahu awer wi ku'em mehe ume'e mehe wà.
\q1 Nezewegatete, o hezar, nanema'enukwaw kwaw a'e teko wanehe ne.
\b
\q1 
\v 21 Hepy'a tynehem iro haw pupe a'e mehe.
\q1 Aikwahy ihe.
\q1 
\v 22 Napuner kwaw neremiapo kwer ikatu haw ikwaw paw rehe.
\q1 Aiko miar ài ma'e kwaw 'ymar romo ihe.
\q1 
\v 23 Nezewe rehe we aiko nerehe we tuweharupi.
\q1 Hepyhyk pe hepo rehe ne.
\q1 
\v 24 Hereruze'eg pe herape ràm ikwaw kar pà ihewe.
\q1 Iahykaw rehe hemur kar putar pe nepyr tuwihaw ài herereko pà nehe.
\q1 
\v 25 Ne ywak rehe har ne, xo ne urereko ihe.
\q1 A'e rupi naputar kwaw amo ma'e ywy rehe har ihe.
\q1 
\v 26 Apuner ma'e kwaw par 'ym romo hereko haw rehe nehe.
\q1 Apuner hetekwer ikàg 'ym ma'e romo hereko haw rehe nehe no.
\q1 Nezewe rehe we Tupàn wiko putar hekàgaw romo nehe. Naputar kwaw amo ma'e ihe nehe.
\b
\q1 
\v 27 Newi utyryk ma'e ràm umàno putar azeharomoete a'e wà nehe.
\q1 Eremumaw putar nerehe uzeruzar ire upytu'u ma'e ràm ne wà nehe no.
\q1 
\v 28 Ihe naiko kwaw wazàwe ihe. Tupàn huwake hereko haw ikatuahy ihewe.
\q1 Tupàn Tuweharupi Wiko Ma'e azapo hemimaw romo ihe.
\q1 Amume'u hemiapo kwer paw rupi no.
\c 74
\s1 O Tupàn, nema'enukwaw neremiaihu wanehe nehe
\d Zegar haw Azaw hemiapo kwer
\q1 
\v 1 O Tupàn, màràzàwe tuwe eretyryk tuwe urewi.
\q1 Màràzàwe tuwe erekwahy àràpuhàràn neremimono'og zàwenugar wanupe.
\q1 
\v 2 Nema'enukwaw katu neremiaihu wanehe nehe.
\q1 Kwehe mehe erexarexak neremiruze'eg romo ne wà.
\q1 Erepyro amo wanupe uma'ereko e ma'e romo waneko haw wi wà, neremiaihu romo wamuigo kar pà ne wà.
\q1 Nema'enukwaw Xiàw ywytyr rehe nereko awer rehe ne.
\q1 
\v 3 Ezur 'aw ma'e imuaiw pyrer tetea'u rehe neata pà nehe.
\q1 Ureàmàtyry'ymar umumaw ma'e neràpuzuhu pupe har paw wà.
\b
\q1 
\v 4 Neàmàtyry'ymar uhapukaz urywete haw rupi neràpuzuhu pupe wà.
\q1 Umupu'àm pàn uwer hereko har a'e pe wà, tàpuzuhu izar romo weko haw hexak kar pà purupe wà.
\q1 
\v 5 Nuzawy kwaw zepe'aw imono'ogar wà.
\q1 Nuzawy kwaw ywyra itazy pupe imonohonohokar wà no.
\q1 
\v 6 Umumaw ma'e ywyra iapo pyrer ipuràg eteahy ma'e
\q1 A'e pe har paw rupi wà.
\q1 
\v 7 Weityk neràpuzuhu tata imunyk pà hehe wà.
\q1 Umuaiw nerenaw nemuwete katu haw wà.
\q1 
\v 8 — Xiuhauhaw xe har paw rupi zane wà nehe, i'i uzeupeupe wà. Uzuhazuhaw wà.
\q1 Umunyk tata nemuwete haw Izaew ywy rehe har nànàn wà.
\b
\q1 
\v 9 Ureràro ma'e purumupytuhegatu kar haw ure. Ni amo nuzapo kwaw urewe wà.
\q1 Naheta kwaw Tupàn ze'eg imume'u har ko 'ar rehe wà.
\q1 Màràn kwarahy urumumaw putar nezewe ure nehe. Ni amo nukwaw kwaw wà.
\q1 
\v 10 O Tupàn. Màràn mehe ureàmàtyry'ymar upytu'u putar urerehe uze'eg urywahyahy re wà nehe.
\q1 Aipo uze'eg zemueteahy putar nerehe tuweharupi upytu'u 'ym pà wà nehe.
\q1 
\v 11 Màràzàwe tuwe nanepurupytywà wer kwaw urerehe ne.
\q1 Màràzàwe tuwe erepyta ma'e iapo 'ym pà.
\b
\q1 
\v 12 Ne Tupàn, ereiko ureruwihawete romo izypy mehe arer we te ko 'ar rehe ne.
\q1 Urepytywà pe tetea'u ureàmàtyry'ymar waneityk mehe ne.
\q1 
\v 13 Nekàgaw uhua'u ma'e rupi eremuza'aza'ak yryhu.
\q1 Erezuhaw miar uhua'u ma'e yryhu pupe har waàkàg ikamikamik pà ne wà.
\q1 
\v 14 Erekamikamik àzàg Erewiàtà her ma'e iàkàg ne wà no.
\q1 Eremono hetekwer miar ywyxiguhu rehe har wanupe wanemi'u romo.
\q1 
\v 15 Erewàpytymawok ytyzuzàmaw ne wà. Eremuyryk kar yrykaw ne wà no.
\q1 Yrykawhu eremuxinig kar ne wà no.
\q1 
\v 16 Erezapo 'ar. Erezapo pytunaw no.
\q1 Eremono kwarahy henaw rehe. Zahytata eremono wanenaw pe wà no.
\q1 
\v 17 Erezapo ywy iahykaw.
\q1 Eremugyr kar àmàn. Eremuhyape katu kar kwarahy no.
\b
\q1 
\v 18 O Tupàn Tuweharupi Wiko Ma'e, nema'enukwaw katu neàmàtyry'ymar nerehe uze'eg urywahyahy mehe ne wà nehe. Nuzeruzar kwaw nerehe wà.
\q1 Uze'eg zemueteahy nerer rehe wà. Nema'enukwaw wanemiapo kwer rehe nehe.
\q1 
\v 19 Imunar neremiaihu wama'e rehe wà. Emono zo neremiaihu a'e teko wanupe ne wà nehe.
\q1 Upuraraw kar ma'erahy neremiaihu wanupe wà. Nereharaz zo neremiaihu ipetepetek pyrer wanuwi nehe.
\q1 
\v 20 Nema'enukwaw neze'egaw neremiapo katu kwer rehe nehe,
\q1 Ta'e heta puruzuka haw ko ywy nàn a'e xe.
\q1 
\v 21 Tuwe ikatu 'ym ma'e numuigo kar kwaw neremiaihu ma'e hereko 'ymar romo wà nehe. Upuraraw kar ma'erahy waiko neremiaihu wanupe wà.
\q1 Hemetarer 'ym ma'e wà nehe, ma'e hereko 'ymar wà nehe no, tuwe umume'u nekatu haw wà nehe.
\b
\q1 
\v 22 Epu'àm, o Tupàn. Epyro nerer nehe, ikatu 'ym ma'e wanuwi nehe. Eityk neàmàtyry'ymar ne wà nehe.
\q1 Teko ma'e kwaw par 'ym uze'eg urywahyahy nerehe 'ar nànàgatu wà. Nema'enukwaw waze'eg rehe.
\q1 
\v 23 Nereharaz zo neàmàtyry'ymar wanehapukaz taw wi nehe. Heiheihem tuweharupi wekwahy haw rupi wà.
\q1 Nereharaz zo waneiheihemaw wi nehe. Einu ne wà nehe.
\c 75
\s1 Tupàn wiko teko wanemiapo kwer imume'u har ikatuahy ma'e romo a'e
\d Zegar haw Azaw hemiapo kwer
\q1 
\v 1 Urumume'u nekatu haw uruiko, o Tupàn, urumume'u nekatu haw uruiko.
\q1 Nehua'u haw urumume'u.
\q1 Urumume'u neremiapo kwer ikatuahy ma'e no.
\b
\q1 
\v 2 Nezewe uze'eg Tupàn. — Amume'u katu 'ar teko wanemiapo kwer imume'u àwàm kwez ihe.
\q1 A'e 'ar mehe amume'u putar wanemiapo kwer hekatu haw rupi ihe nehe.
\q1 
\v 3 Aze ywy uryryryryz nehe,
\q1 Aze hehe har umàno etea'i wà nehe,
\q1 Namuhem kar kwaw ywy iwype har henaw wi ihe nehe.
\q1 
\v 4 — Pemume'u zo pepuner haw nehe, a'e ikatu 'ym ma'e wanupe.
\q1 — Aiko wera'u amo wanuwi ihe, peze zo nehe, a'e wanupe.
\q1 
\v 5 — Pepytu'u pekàgaw rehe peze'eg ire nehe.
\q1 Pepytu'u tuwihaw ài peze'eg ire nehe, a'e wanupe, i'i Tupàn.
\b
\q1 
\v 6 Teko wanemiapo kwer imume'u haw a'e, nur kwaw kwarahy ihemaw wi a'e. Kwarahy heixe haw wi nur kwaw a'e.
\q1 Nur kwaw kwarahy heixe haw awyze har kutyr har wi a'e. Kwarahy ihemaw awyze har kutyr har wi nur kwaw a'e.
\q1 
\v 7 Tupàn a'e ae wiko imume'u har romo a'e.
\q1 Weityk amo wà.
\q1 Upir amo wà no.
\q1 
\v 8 Tupàn Tuweharupi Wiko Ma'e wereko amo kanekpuku opo pe.
\q1 Tynehem win zàwenugar pupe a'e. Ikwahy haw pupe tynehem.
\q1 U'u kar ipor ikatu 'ym ma'e wanupe.
\q1 Paw rupi i'un wà.
\b
\q1 
\v 9 Ihe aze'eg putar Tupàn Zako izar rehe tuweharupi ihe nehe.
\q1 Amuzàg putar zegar haw ikatu haw rehe nehe no.
\q1 
\v 10 Uzuhaw putar ikatu 'ym ma'e wakàgaw nehe.
\q1 Tupàn heruzar har wakàgaw uhua'u wera'u putar nehe.
\c 76
\s1 Tupàn ikàg ma'e romo a'e
\d Zegar haw Azaw hemiapo kwer
\q1 
\v 1 Teko Zuta ywy rehe har ukwaw katu Tupàn wà.
\q1 Izaew ywy rehe har ukwaw katu her wà.
\q1 
\v 2 Hàpuz Zeruzarez pe hin.
\q1 Wiko Xiàw ywytyr rehe.
\q1 
\v 3 Tupàn uzuhazuhaw wàmàtyry'ymar wapuruzuka haw paw a'e pe a'e:
\q1 U'yw wà, u'yw wi purumimaw wà, takihepuku wà.
\b
\q1 
\v 4 Nekàgatu tuwe nereiny romo, o Tupàn.
\q1 Nekatuahy tuwe ywytyruhu wi nezewyr mehe.
\q1 Ereityk neàmàtyry'ymar a'e ywytyruhu rehe ne wà.
\q1 
\v 5 Ereraha kar a'e zauxiapekwer ipuruzukaiw ma'e wama'e paw ne.
\q1 Uker waiko umàno ma'e kwer waker haw rehe a'e wà kury,
\q1 Ta'e nupuner kwaw uzepyro haw rehe wà xe.
\q1 
\v 6 O Tupàn Zako izar, wanehe nezepyk mehe kawaru a'e wà,
\q1 Kawaru ku'az har a'e wà no, wiko umàno ma'e kwer ài wà.
\b
\q1 
\v 7 Teko upaw rupi katete ukyze newi wà.
\q1 Ni amo nupuner kwaw nerenataromo weko haw rehe nekwahy mehe wà.
\q1 
\v 8 Ywak rehe nereko mehe erekwaw kar ikatu 'ym ma'e wanehe nezepyk àwàm purupe ne.
\q1 Ywy rehe har ukyze wà, uze'eg 'ym pà wà.
\q1 
\v 9 Erepu'àm teko ikatu 'ym ma'e wanehe nezepyk pà,
\q1 Ma'erahy ipuraraw par ywy rehe har paw wapyro pà.
\b
\q1 
\v 10 Te teko wakwahy haw umuhua'u kar nekatu haw rehe ze'egaw no.
\q1 Teko zeàmàtyry'ymawhu pe umàno 'ym ma'e uzapo putar mynykawhu neze'eg rupi wà nehe.
\q1 
\v 11 Pemono penemimume'u kwer Tupàn Tuweharupi Wiko Ma'e Zanezar pe nehe.
\q1 Tuwe teko ko ywy huwake har paw weraha izupe imono pyr wà nehe.
\q1 Tuwe omono Tupàn pe wà nehe. Tuwe ukyze izuwi wà nehe no.
\q1 
\v 12 Tuwihaw amo wanuwi wiko wera'u ma'e a'e wà, Tupàn umuigo kar ma'e hereko 'ymar romo a'e wà.
\q1 Umukyze kar tuwe ywy rehe har wanuwihawete wà no.
\c 77
\s1 Tupàn zanemurywete kar zanezemumikahy mehe a'e
\d Zegar haw Azaw hemiapo kwer
\q1 
\v 1 Ahapukaz katu Tupàn pe ihe.
\q1 Herenu herehapukaz mehe a'e.
\q1 
\v 2 Ma'erahy ipuraraw mehe aze'eg zanezar pe.
\q1 Pyhaw aupir hepo izupe heze'eg pà.
\q1 Nezewe rehe we naherurywete kwaw ihe.
\q1 
\v 3 Tupàn rehe hema'enukwaw mehe azypyrog hekuhem pà ihe.
\q1 Azypyrog ma'e rehe hema'enukwaw pà. A'e mehe azemumikahy.
\b
\q1 
\v 4 Tupàn nahemuger kar kwaw a'e.
\q1 Napuner kwaw heze'egaw rehe, ta'e azemumikahy ihe xe.
\q1 
\v 5 Hema'enukwaw he'ar upaw ma'e kwer rehe,
\q1 Hekwarahy kwehe mehe upaw ma'e kwer rehe no.
\q1 
\v 6 Amumaw pytun tetea'u ma'e rehe hema'enukwaw katu pà.
\q1 Azypyrog hema'enukwaw pà, na'e apuranu hezehe no.
\b
\q1 
\v 7 Aipo zanezar utyryk putar tuwe zanewi tuweharupi nehe.
\q1 Aipo nazanekatu pixik kwaw izupe nehe.
\q1 
\v 8 Aipo upytu'u zaneamutar katu re.
\q1 Aipo weityk zanewe wemimume'u kwer.
\q1 
\v 9 Aipo Tupàn upytu'u ikatu ma'e romo wiko re.
\q1 Aipo ikwahy haw upyta ipurupuhareko haw hekuzaromo, a'e hezeupe.
\q1 
\v 10 Na'e aze'eg nezewe hezeupe.
\q1 — Tupàn Ywate Wera'u Har na'ipurupytywà wer kwaw zanerehe kwehe mehe arer zàwe a'e. Azeharomoete nezewe haw na'ikatu kwaw zanewe, a'e hezeupe.
\b
\q1 
\v 11 O Tupàn Tuweharupi Wiko Ma'e. Hema'enukwaw putar neremiapo kwer ikatuahy ma'e rehe ihe nehe.
\q1 Hema'enukwaw putar neremiapo kwer kwehe mehe iapo pyrer rehe nehe.
\q1 
\v 12 Hema'enukwaw putar neremiapo kwer paw rehe nehe.
\q1 Amume'u putar ma'e neremiapo kwer hezeupe nehe no.
\b
\q1 
\v 13 O Tupàn neremiapo paw ikatu a'e.
\q1 Naheta kwaw amo tupàn ikàg ma'e urezar zàwenugar wà.
\q1 
\v 14 Ereiko Tupàn purumupytuhegatu kar haw iapo har romo ne.
\q1 Erexak kar nepuner haw ywy nànànar wainuinuromo.
\q1 
\v 15 Nekàgaw rupi erepyro neremiaihu ne wà.
\q1 Erepyro Zako izuapyapyr ne wà. Zuze izuapyapyr erepyro ne wà no.
\b
\q1 
\v 16 O Tupàn, nerexak mehe 'y ukyze a'e.
\q1 'Y yryhu pe har ohoete ma'e uryryryryz a'e no.
\q1 
\v 17 Ywàkun umugyr kar àmàn.
\q1 Ywak wànoànog.
\q1 Iweraw paw uhyape katu ywy nànàn.
\q1 
\v 18 Àmàn neremimuànoànogaw uhàuhàz ywy nànàn no.
\q1 Àmàn iweraw paw uhyape katu ywy nànàn no.
\q1 Tupàn umuryryz kar ywy. Ywy uryryryryz a'e.
\b
\q1 
\v 19 Ereata yryhu myteromo.
\q1 Erezapo nerape yryhu ohoete ma'e rupi.
\q1 Ni amo nuexak kwaw nepyporer a'e wà.
\q1 
\v 20 Àràpuhàràn wamono'ogar weraha weimaw pe ikatu ma'e rupi wà.
\q1 Nezewegatete eremuata kar neremiaihu pe ikatu ma'e rupi ne wà no, Moizez pe ne wà, Àràw pe ne wà no.
\c 78
\s1 Tupàn uze'eg wemiaihu wanupe
\d Zegar haw Azaw hemiapo kwer
\q1 
\v 1 Heremiaihu wà, peinu katu hepurumu'e haw nehe.
\q1 Pezekaiw katu heze'eg rehe nehe.
\q1 
\v 2 Ta'e aze'eg putar peme ze'eg xirogatu ma'e rupi ihe nehe xe.
\q1 Amume'u putar ma'e kwehe mehe uzeapo ma'e kwer ikwaw 'ym pyrer peme ihe nehe.
\q1 
\v 3 Xinu a'e ma'e zaneipy zanewe wanemimume'u kwer zane.
\q1 A'e rupi xikwaw.
\q1 
\v 4 Naxiumim kwaw a'e ma'e zanera'yr wanuwi nehe.
\q1 Zaze'eg putar zanezuapyapyr wanupe nehe, tupàn Tuweharupi Wiko Ma'e ipuner haw rehe nehe,
\q1 Hemiapo kwer ikàg ma'e rehe nehe, hemiapo kwer ikatuahy ma'e rehe nehe.
\b
\q1 
\v 5 Omono uze'eg heruzar kar pyràm teko Izaew wanupe.
\q1 Umume'u ma'e wemiapo kàràm Zako izuapyapyr wanupe.
\q1 — Pemu'e pena'yr ko ze'eg heruzar pyràm wanehe nehe,
\q1 I'i zaneipy wanupe.
\q1 
\v 6 — Nezewe mehe pezuapyapyr ukwaw putar wà nehe.
\q1 Nezewe mehe wazuapyapyr umu'e putar wa'yr a'e wà nehe no.
\q1 
\v 7 Nezewe mehe uzeruzar putar Tupàn rehe a'e wà nehe no.
\q1 Naheharaz kwaw hemiapo kwer wi wà nehe.
\q1 Tuweharupi weruzar putar ma'e hemiapo kàràm wà nehe.
\q1 
\v 8 Nuiko kwaw peipy wazàwe wà nehe.
\q1 Peipy hehaite wà. Nuweruzar katu kwaw Tupàn ze'eg wà.
\q1 Tupàn rehe wazeruzar haw na'ikàg pixik kwaw a'e.
\q1 Upytu'u hehe uzeruzar ire wà.
\b
\q1 
\v 9 Awa Eparai izuapyapyr wà,
\q1 Wereko ywyrapar opo pe wà, opo pe u'yw wereko wà no.
\q1 Uzàn oho zeàmàtyry'ymawhu 'ar mehe wà.
\q1 
\v 10 Izaew izuapyapyr nuzapo kwaw ma'e ze'eg Tupàn pe wemimume'u pyrer rupi katu wà.
\q1 Na'ipureruzar wer kwaw ize'eg rehe wà.
\q1 
\v 11 Heharaz Tupàn hemiapo kwer purumupytuhegatu kar ma'e kwer wi wà.
\q1 Wexak iapo mehe wà. Nezewe rehe we heharaz hemiapo kwer wi wà.
\q1 
\v 12 Tupàn uzapo purumupytuhegatu kar ma'e waipy wanenataromo
\q1 Ywytyr heta 'ymaw Zuwà her ma'e rehe Ezit ywy rehe a'e.
\q1 
\v 13 Uzaikaikaw yryhu.
\q1 Umuata kar Izaew izuapyapyr yryhu myteromo wà.
\q1 Upir 'y pàrirogaw aiha ma'e ài.
\q1 
\v 14 'Aromo wexak kar wanape ràm wanupe ywàkun pupe wiko pà.
\q1 Pyhaw wexak kar weko haw tata heny kwer pupe no.
\q1 
\v 15 Umuza'aza'ak itahu ywyxiguhu rehe no.
\q1 Wenuhem 'y ywy iwype har tetea'u teko wanupe wamui'u kar pà no.
\q1 
\v 16 Umuhem kar 'y itahu wi.
\q1 A'e 'y uwyryk yrykawhu ài.
\b
\q1 
\v 17 Nezewe rehe we zaneipy uzapo wiwi ikatu 'ym ma'e oho waiko Tupàn ikutyr wà.
\q1 Upytu'u Ywate Wera'u Har ze'eg heruzar ire ywyxiguhu rehe wà.
\q1 
\v 18 Wagaw tuwe Tupàn wà.
\q1 Wenoz wemi'u ràm wemimutar izupe wà.
\q1 
\v 19 Uze'eg zemueteahy hehe wà.
\q1 — Aipo Tupàn upuner temi'u imur haw rehe zanewe ywyxiguhu rehe a'e.
\q1 
\v 20 Umuza'aza'ak itahu azeharomoete.
\q1 'Y uzypyrog tuwe yrykawhu ài uwyryk pà.
\q1 Aipo upuner typy'ak zanewe imur haw rehe a'e.
\q1 Aipo upuner ma'ero'okwer imur haw rehe wemiaihu wanupe, i'i wà.
\q1 
\v 21 Tupàn Tuweharupi Wiko Ma'e wikwahy a'e ma'e henu mehe a'e.
\q1 Uzàmàtyry'ym wemiaihu oho tata pupe wà.
\q1 Wanupe ikwahy haw uhua'u wera'u kury,
\q1 
\v 22 Ta'e nuzeruzar kwaw hehe wà xe.
\q1 — Nupuner kwaw zanepyro haw rehe nehe, i'i izupe wà.
\b
\q1 
\v 23 Nezewe rehe we Tupàn uze'eg ywak rehe.
\q1 — Ewàpytymawok neruken nehe, i'i izupe.
\q1 
\v 24 Umur typy'ak ywate har wemiaihu wanupe.
\q1 Umu'ar kar temi'u mana her ma'e wanupe i'u kar pà.
\q1 
\v 25 Nezewe u'u Tupàn heko haw pe har watypy'ak wà.
\q1 Umur Tupàn temi'u tetea'u wanupe. Uhyk tuwe wanupe.
\q1 
\v 26 Na'e umur kar ywytu kwarahy hemaw wi ywak wi kury.
\q1 Upuner haw rupi umuhem kar ywytu kwarahy hemaw awyze har rehe har no.
\q1 
\v 27 Umu'ar wiràmiri tetea'u teko wanehe wà.
\q1 Wiràmiri nuzawy kwaw ywy imuku'i pyrer ywàkun romo uzeapo ma'e kwer, ta'e heta tetea'u a'e wà xe.
\q1 Waneta haw nuzawy kwaw ywyxig yryhu izywyr har waneta haw.
\q1 
\v 28 U'ar wiràmiri teko waker haw rehe wà,
\q1 Wanàpuzràn izywyr wà.
\q1 
\v 29 Na'e Izaew ipurumuzàmuzàg u'u wà.
\q1 Uhyk wanupe wà, ta'e Tupàn omono wanemimutar paw wanupe a'e xe.
\q1 
\v 30 Wamai'u mehe we,
\q1 Ihyk 'ym mehe we,
\q1 
\v 31 Wikwahy Tupàn wanupe.
\q1 Uzuka awa ikàg wera'u ma'e wà.
\q1 Uzuka kwàkwàmo Izaew wainuromo har ikatu wera'u ma'e wà.
\b
\q1 
\v 32 Teko wexak a'e purumupytuhegatu kar ma'e paw wà.
\q1 Nezewe rehe we uzapo wiwi ikatu 'ym ma'e oho waiko wà.
\q1 Na'izeruzar wer kwaw Tupàn rehe wà.
\q1 
\v 33 A'e rupi umumaw wà.
\q1 Waneko haw nuzawy kwaw pytuhemaw.
\q1 Nuzawy kwaw iaiw ma'e na'arewahy uzeapo ma'e kwer.
\q1 
\v 34 Tupàn uzuka amo wà.
\q1 Na'e amo uzewyr izupe wà.
\q1 Uzemumikahy wemiapo kwer rehe wà.
\q1 Uze'eg Tupàn pe wemu'em 'ym pà wà.
\q1 
\v 35 Na'e ima'enukwaw Tupàn rehe wà. — Itahu zanemimaw zàwenugar romo hekon a'e, i'i wà.
\q1 — Tupàn Ywate Wera'u Har wiko zanepyro har romo a'e, i'i wà.
\q1 
\v 36 Waze'eg awer paw temu'emaw romo a'e wà.
\q1 Umume'u a'e ma'e paw Tupàn pe wemu'em pà wà.
\q1 
\v 37 Nuputar kwaw Tupàn upy'a pe azeharomoete wà.
\q1 Nuzapo kwaw ma'e uze'eg awer rupi katete wà. Kwehe mehe Tupàn uzapokatu a'e ze'egaw wanehe we a'e. Uzuhaw wà kury.
\q1 
\v 38 Nezewe rehe we Tupàn upuhareko wemiaihu wà.
\q1 Numumaw kwaw wà.
\q1 Umunàn wanemiapo kwer wanuwi uweharaz tà.
\q1 Tuweharupi umuakuir wekwahy haw a'e.
\q1 Umumaw wekwahy haw a'e.
\q1 
\v 39 Ima'enukwaw amo 'ar mehe umàno ma'e ràm romo waneko haw.
\q1 Nuzawy kwaw ywytu wà. Ywytu oho. Nuzewyr kwaw.
\b
\q1 
\v 40 Teko upytu'u tetea'u Tupàn ze'eg heruzar ire ywyxiguhu rehe wà.
\q1 Umuzemumikahy kar tetea'u Tupàn a'e wà no.
\q1 
\v 41 Wagaw tetea'u wà.
\q1 Umuzemumikahy kar Izaew wazar ikatuahy ma'e wà no.
\q1 
\v 42 Heharaz ipuner haw uhua'u ma'e wi wà.
\q1 Upyro Tupàn a'e teko waàmàtyry'ymar wanuwi wà. Heharaz wapyro awer 'ar wi wà no.
\q1 
\v 43 Heharaz hemiapo kwer ikatuahy ma'e wi wà.
\q1 Heharaz purumupytuhegatu kar haw Zuwà ywytyr heta 'ymaw rehe Ezit ywy rehe iapo pyrer wi wà no.
\q1 
\v 44 Uzapo 'y yrykawhu pe har tuwykwer romo.
\q1 Nezewe mehe naheta kwaw 'y i'u pyr Ezit ywy rehe har wanupe.
\q1 
\v 45 Omono kar meru tetea'u wanupe waputupyk pà wà.
\q1 Zu'i tetea'u umuaiw wama'etymaw wà no.
\q1 
\v 46 Omono kar tukur tetea'u wanupe wà no.
\q1 U'u tukur arozràn ipo'o pyràm upaw rupi wà. Umuaiw ko pe hezuz ma'e paw wà.
\q1 
\v 47 Umumaw wanemitygwer uwà tyw àmàntàtà pupe.
\q1 Umumaw ma'ywa pi her ma'e tyw imuwixàgahy pà no.
\q1 
\v 48 Waneimaw tapi'ak a'e wà, àràpuhàràn hawitu ma'e a'e wà no, umàno paw rupi wà no.
\q1 Ta'e àmàntàtà ukyr wanehe xe. Àmàn uwerawerawahy wanehe no.
\q1 
\v 49 Umumaw a'e ma'e paw wikwahy haw rupi wà.
\q1 Wikwahy tuwe wamumaw mehe.
\q1 Omono ze'egaiw wanehe. Ikwahy haw ur màno haw herur har ài a'e.
\q1 
\v 50 Numuakuir kwaw wikwahy haw.
\q1 Nupyro kwaw màno haw wi wà.
\q1 Uzuka ma'eahy haw iaiw ma'e pupe wà.
\q1 
\v 51 Tàpuz nànàn Ezit ywy rehe
\q1 Tupàn uzuka wana'yr ipy paw wà.
\b
\q1 
\v 52 A'e re wiko àràpuhàràn zàwenugar romo.
\q1 Weraha wemiaihu Izaew Ezit ywy wi wà.
\q1 Umuata kar ywyxiguhu rehe.
\q1 
\v 53 Numuzeapo kar kwaw ikatu 'ym ma'e wanupe waneraha mehe.
\q1 Hemiaihu nukyze kwaw ma'e wi wà.
\q1 Yryhu upyk waàmàtyry'ymar wazuka pà wà.
\q1 
\v 54 Tupàn weraha wemiaihu uiwy imonokatu pyrer pe.
\q1 A'e ae umuhem kar teko ywytyruhu wanuwi wà. A'e re weraha wemiaihu a'e ywytyruhu wanupe wà.
\q1 
\v 55 Umuhem kar a'e ywy rehe har a'e wi wà, wemiaihu wanenataromo wà.
\q1 Hemiaihu wixe a'e ywy rehe wà.
\q1 Uzaikaikaw a'e ywy ipegegwer wamono pà Izaew ta'yr wazuapyapyr wanupe.
\q1 Umuigo kar Izaew waàmàtyry'ymar wanàpuzgwer wapupe wà.
\b
\q1 
\v 56 Nezewe rehe we Izaew upytu'u Tupàn Ywate Wera'u Har ze'eg heruzar ire wà.
\q1 Wagaw uzar wà.
\q1 Nuweruzar kwaw hemiapo karer wà.
\q1 
\v 57 Nuzawy kwaw uwipy wà. Nuzeruzar kwaw Tupàn rehe wà.
\q1 Nuweruzar kwaw ize'eg wà.
\q1 Aze ywyrapar na'ikatu kwaw, u'yw a'e ywyrapar wi imuhem kar pyr nuzywà kwaw ma'e. A'e teko wiko u'yw ma'ekutuk 'ym ma'e ài wà.
\q1 
\v 58 A'e teko umuikwahy kar Tupàn ma'ea'yr hapy haw iapo pà tupàn a'ua'u wanupe wà.
\q1 Umuwete katu tupàn a'ua'u a'e wà. A'e rupi Tupàn hewyrowyroahy wikwahy pà a'e.
\q1 
\v 59 A'e ma'e hexak mehe wikwahy Tupàn.
\q1 Utyryk tuwe wemiaihu wanuwi.
\q1 
\v 60 A'e 'ym mehe wiko tàpuzràn pupe wemiapo kwer teko wainuinuromo Xiro pe a'e.
\q1 Wikwahy mehe wezar wàpuzràn.
\q1 
\v 61 Weraha kar uze'eg imuapyk pyrer hyru wàmàtyry'ymar wanupe a'e.
\q1 Ize'eg hyru wexak kar ipuner haw ipuràg eteahy haw teko wanupe. — Peraha nehe, i'i wemiaihu waàmàtyry'ymar wanupe.
\q1 
\v 62 Wikwahy wemiaihu wanupe.
\q1 A'e rupi uzuka kar wemiaihu waàmàtyry'ymar wanupe wà.
\q1 
\v 63 Kwàkwàmogwer umàno zeàmàtyry'ymawhu pe wà.
\q1 A'e rupi naheta kwaw imen ràm kuzàwaza kwer wanupe wà.
\q1 
\v 64 Zauxiapekwer uzuka xaxeto utakihe puku pupe wà. Na'e zauxiapekwer uze'eg nezewe wanemireko kwer wanupe wà.
\q1 — Aze pezai'o pemener wamàno awer rehe nehe, uruzuka putar ure nehe no, i'i wanupe wà.
\b
\q1 
\v 65 Na'e Tupàn Zanezar nuzawy kwaw uker ire ume'e ma'e.
\q1 Nuzawy kwaw awa ipuruzukaiw ma'e win pupe imuhaite pyrer a'e. Heiheihem a'e.
\q1 
\v 66 Umuzàn kar wàmàtyry'ymar wamono wà.
\q1 Weityk wà. Umumaranugar kar wà no. Imaranugar putar tuweharupi wà nehe.
\q1 
\v 67 Utyryk Zuze izuapyapyr wanuwi.
\q1 Nuexaexak kwaw Eparai izuapyapyr wà.
\q1 
\v 68 Nan kwaw nezewe. Wexaexak Zuta izuapyapyr wà.
\q1 Wexaexak ywytyr Xiàw wemiamutar.
\q1 
\v 69 Heta heko haw izupe ywate a'e. Uzapo tàpuzuhu ywy rehe har weko haw ywate har ài.
\q1 Umuàtà wàpuzuhu ywy ài.
\q1 Ni amo nuweityk pixik kwaw wà nehe.
\b
\q1 
\v 70 Na'e Tupàn wexak wemiruze'eg Tawi.
\q1 Wenuhem pari àràpuhàràn hawitu ma'e wamono'ogaw wi.
\q1 
\v 71 Wiko àràpuhàràn rehe uzekaiw ma'e romo a'e 'ar mehe,
\q1 Umuigo kar Izaew wanuwihawete romo.
\q1 Nuzawy kwaw àràpuhàràn mono'ogar ài Tupàn wemiaihu wanupe.
\q1 
\v 72 Tawi uzekaiw katu wanehe.
\q1 Weruze'egatu uma'ekwaw katu haw rupi wà no.
\c 79
\s1 O Tupàn, urepuhareko pe ne nehe
\d Zegar haw Azaw hemiapo kwer
\q1 
\v 1 O Tupàn, nerehe uzeruzar 'ym ma'e wixe neywy rehe wà.
\q1 Umuaiw neràpuzuhu imonokatu pyrer wà no.
\q1 Weityk tàpuz Zeruzarez pe har paw wà no.
\q1 
\v 2 Weityk neremiruze'eg wanetekwer ywy rehe wà.
\q1 Weityk newi upuir pixik 'ym ma'e wà, wiràmiri wanemi'u ràm romo wà.
\q1 Omono miar hehaite ma'e wanupe wanemi'u ràm romo wà no.
\q1 
\v 3 Uzakook neremiaihu wanuwykwer ywy rehe 'y ài wà.
\q1 Uwyryk wanuwykwer 'y ài Zeruzarez tawhu nàn.
\q1 Ni pitài nuikuwe kwaw amogwer wanetekwer watym àràm romo wà.
\b
\q1 
\v 4 Ywy ko ywy huwake har rehe har uze'eg zemueteahy urerehe wà.
\q1 Upuka urerehe uze'eg urywahyahy pà wà.
\q1 
\v 5 O Tupàn Tuweharupi Wiko Ma'e, màràn kwarahy eremumaw putar urewe nekwahy pà nehe.
\q1 Aipo nerepytu'u pixik kwaw nehe.
\q1 Aipo nekwahy haw ukaz wiwi putar tata ài nehe.
\q1 
\v 6 O Tupàn, eikwahy teko amo ywy rehe har nemuwete katu 'ym ma'e wanupe nehe.
\q1 Eikwahy nereityk àràm wanupe nehe.
\q1 
\v 7 Ta'e uzuka ureànàm a'e wà xe.
\q1 Umuaiw ureywy wà no.
\q1 
\v 8 Ezepyk zo urerehe ureipy wanemiapo kwer hekuzaromo nehe.
\q1 Urepuhareko pe nehe kury,
\q1 Ta'e uruzemumikahy tuwe urepyro haw hàro 'ym pà ure xe.
\b
\q1 
\v 9 Urepytywà pe nehe, o Tupàn urepyro har.
\q1 Aze na'urepyro kwaw pe nehe,
\q1 Aze neremunàn kwaw ureremiapo kwer ikatu 'ym ma'e nehe, teko uze'eg zemueteahy putar nerehe wà nehe.
\q1 
\v 10 — Ma'e pe hekon Tupàn pezar a'e, i'i putar amogwer ywy rehe har urewe wà nehe.
\q1 Màràzàwe tuwe erepuranu kar amogwer ywy rehe har urerehe nezewe wà.
\q1 O Tupàn tuwe uruexak wanehe nezepyk àwàm nehe,
\q1 Ta'e uzakook neremiruze'eg wanuwykwer a'e wà xe.
\q1 
\v 11 Einu zemunehew paw pe har wakuhem mehe ne wà nehe.
\q1 Nepuner haw uhua'u ma'e rupi
\q1 Epyro ureàmàtyry'ymar wanemizuka ràm ne wà nehe no.
\b
\q1 
\v 12 O hezar, ezepyk amogwer ywy rehe har wanehe 7 haw nehe.
\q1 Aze uzapo ikatu 'ym ma'e newe pitài haw wà nehe, ezepyk wanehe 7 haw nehe.
\q1 
\v 13 Na'e ure neremiaihu romo wiko ma'e ure,
\q1 Àràpuhàràn zàwenugar neremimono'og ure, ure nehe,
\q1 Urezuapyapyr a'e wà nehe no,
\q1 Urumume'u putar nekatu haw tuweharupi ure nehe.
\q1 Nekatu haw rehe zegar haw urumuzàg putar newe ure nehe no.
\c 80
\s1 O Tupàn, exak kar urepuhareko haw urewe ne nehe
\d Zegar haw Azaw hemiapo kwer
\q1 
\v 1 Urereinu pe nehe,
\q1 Izaew wanupe àràpuhàràn wamono'ogar zàwenugar.
\q1 Ezeapyaka katu urerehe nehe, urerehe uzekaiw ma'e àràpuhàràn wanehe uzekaiw ma'e zàwenugar.
\q1 Ne nerenawhu rehe wapyk ma'e ne, nerenawhu kerumin wa'aromo hin ma'e rehe har ne,
\q1 
\v 2 Exak kar Eparai izuapyapyr wamutar katu haw purupe nehe.
\q1 Exak kar Mezàmi izuapyapyr wamutar katu haw purupe nehe no. Exak kar Manaxe izuapyapyr wamutar katu haw purupe nehe no.
\q1 Exak kar nepuner haw urewe nehe.
\q1 Ezur urepyro pà nehe.
\b
\q1 
\v 3 Uremuigo kar wi pe temi'u hereko har romo ma'e hereko har romo nehe, o Tupàn.
\q1 Exak kar nepurupuhareko katu haw urewe nehe. Nezewe mehe urepyro putar pe nehe.
\b
\q1 
\v 4 Màràn kwarahy eremumaw putar neremiaihu waze'eg rehe nekwahy pà nehe,
\q1 O Tupàn Tuweharupi Wiko Ma'e Ikàg Wera'u Ma'e.
\q1 
\v 5 Eremur tehaykwer typy'ak romo iapo pyrer urewe ureremi'u romo ne.
\q1 Eremynehem kanek tehaykwer pupe i'u kar pà urewe no.
\q1 
\v 6 — Pezeàmàtyry'ym Izaew waywy rehe nehe, ere ureywy huwake har wanupe.
\q1 Eremuze'eg kar urywahyahy urerehe ne wà no.
\b
\q1 
\v 7 Uremuigo kar wi temi'u hereko har romo ma'e hereko har romo nehe, o Tupàn Ikàg Wera'u Ma'e.
\q1 Exak kar nepurupuhareko katu haw urewe nehe. Nezewe mehe urepyro putar pe nehe.
\b
\q1 
\v 8 Teko Izaew izuapyapyr wà, nuzawy kwaw ma'e'yw uwà'yw her ma'e wà.
\q1 Ererur i'yw Ezit ywy wi ne.
\q1 Eremuhem kar amogwer teko ko ywy wi ne wà. Erezutym uwà'yw waywy rehe.
\q1 
\v 9 Eremukatu ywy izupe.
\q1 Hapo wixe ywy pupe.
\q1 Uhàuhàz hapo ywy rehe.
\q1 
\v 10 Upyk ywytyr u'àg pupe.
\q1 Hàkàgwer aiha wera'u ywyràkàxigyw aiha wera'u ma'e wi a'e.
\q1 
\v 11 Omono kar wàkàgwer yryhu Mezitehàn her ma'e pe no,
\q1 Yrykawhu Ewparat pe no.
\q1 
\v 12 Màràzàwe tuwe ereityk pari i'yw izywyr har.
\q1 Ko 'ar rehe pe rupi wata ma'e upuner uwà rehe imunar haw rehe wà kury.
\q1 
\v 13 Tazahu ka'a pe har upyropyrog i'yw rehe imumaw pà wà.
\q1 Miar hehaite ma'e u'u paw rupi wà.
\b
\q1 
\v 14 Ezewyr urewe nehe, Tupàn Ikàg Wera'u Ma'e.
\q1 Ywak rehe nereko mehe eme'e urerehe nehe.
\q1 Ezur ma'ywa'yw uwà'yw her ma'e ipyro pà nehe, neremiaihu wapyro pà nehe.
\q1 
\v 15 Ne ae erezutym a'e uwà'yw ne.
\q1 Epyro ezuwà nehe. Eremuezuz katu tuwe i'yw.
\q1 Ezur ipyro pà nehe.
\b
\q1 
\v 16 Ureàmàtyry'ymar omonohok hapy pà tata pupe wà.
\q1 Nekwahy haw rupi eme'e a'e teko wanehe wamumaw pà nehe.
\q1 
\v 17 Ezekaiw katu teko neremixamixak kwer wanehe nehe.
\q1 Epyro a'e teko neremimueta tetea'u kwer ne wà nehe no.
\q1 
\v 18 Nurutyryk wi kwaw newi nehe.
\q1 Uremuigo katu kar pe nehe. Nezewe mehe urumume'u putar nekatu haw ure nehe.
\b
\q1 
\v 19 Uremuigo kar wi pe temi'u hereko har romo ma'e hereko har romo nehe, o Tupàn Tuweharupi Wiko Ma'e, Ikàg Wera'u Ma'e.
\q1 Exak kar nepuruamutar katu haw urewe nehe, urepyro pà nehe.
\c 81
\s1 Tupàn ikatu haw rehe zegar haw
\d Zegar haw Azaw hemiapo kwer
\q1 
\v 1 Pezegar penurywete haw rupi Tupàn zanepyro har pe nehe.
\q1 Pemuzàg ikatu haw rehe zegar haw Zako izar pe nehe.
\q1 
\v 2 Pezypyrog zegar haw imuzàg pà nehe. Pemupumupu ipu ma'e ipew ma'e nehe no.
\q1 Pemupu wioràwiràn zegar haw hurywete ma'e rehe pezegar pà nehe.
\q1 Wioràwiràn pixika'i ma'e pemupu zegar haw imuzàg pà penurywete haw rupi nehe.
\q1 
\v 3 Pezupy ma'e'ak kwer xi'àm romo iapo pyrer mynykaw pe teko wamono'og pà nehe.
\q1 Zahy ipyahu mehe pezupy nehe. Zahy huahu mehe pezupy nehe no.
\q1 
\v 4 Tupàn uzapo kar ko ma'e Izaew wanupe.
\q1 Zako izar umume'u ko ma'e iapo àwàm peme a'e.
\q1 
\v 5 Umur ko ze'eg teko Izaew izuapyapyr wanupe a'e,
\q1 Ezit ywy rehe har waàmàtyry'ym mehe a'e.
\b
\q1 Aenu amo heremigwaw 'ym ize'eg mehe ihe.
\q1 
\v 6 Nezewe i'i a'e 'ar mehe a'e.
\q1 — Azo'ok penemiraha ipuhuz katu ma'e pekupe wi ihe. Kok ywy imuàtà pyrer pupe tynehem ma'e peraha peiko a'e mehe.
\q1 Apupyro a'e ma'e penemiupir wi ihe.
\q1 
\v 7 Ma'erahy ipuraraw mehe herenoz pe pe.
\q1 Ihe apupyro ihe.
\q1 Ywytuaiw pupe hezeàmimaw pe hereko mehe
\q1 Awazar peze'eg peme.
\q1 Apuagaw ytyzuzàmaw Merima her ma'e pe ihe.
\q1 
\v 8 Heremiaihu wà, pezeapyaka katu heze'eg rehe nehe.
\q1 O Izaew wà, aze mo herenu pe, herurywete mo ihe.
\q1 
\v 9 Peiko pixik zo amo tupàn ua'u imuwete har romo nehe.
\q1 Pemuwete katu zo amo nehe. Xo ihe zo hemuwete katu pe nehe.
\q1 
\v 10 Aiko Tuweharupi Wiko Ma'e pezar romo ihe.
\q1 Apupyro Ezit ywy wi ihe.
\q1 Pezurupeka nehe, amono putar penemi'u ràm peme nehe.
\b
\q1 
\v 11 — Nezewe rehe we heremiaihu na'ipurenu wer kwaw herehe wà.
\q1 Izaew izuapyapyr nahereruzar kwaw wà.
\q1 
\v 12 A'e rupi amuata kar wi wanape rupi hereruzar katu 'ymaw rehe ihe wà.
\q1 Azapo kar wanemimutar wanupe.
\q1 
\v 13 Aze mo heremiaihu herenu wà, ikatu mo ihewe.
\q1 Aze mo Izaew izuapyapyr hereruzar wà, herurywete mo ihe.
\q1 
\v 14 Aityk mo waàmàtyry'ymar na'arewahy ihe wà.
\q1 Azepyk mo wakutyr ur ma'e wanehe paw rupi ihe wà no.
\q1 
\v 15 Herehe iakatuwawahy 'ym ma'e uzeamumew mo herenataromo wà, ta'e aiko wazar romo ihe xe.
\q1 Wanehe hezepykaw nupaw pixik kwaw nehe.
\q1 
\v 16 Amono mo arozràn ikatu wera'u ma'e peme ihe.
\q1 A'u kar mo hàir kaiwer parer pupe.
\q1 Te uhyk mo peme, i'i Tupàn.
\c 82
\s1 Tupàn wiko teko paw wanemiapo kwer imume'u har romo a'e
\d Zegar haw Azaw hemiapo kwer
\q1 
\v 1 Tupàn wapyk wenawhu amogwer tuwihaw ywate har wazemono'ogaw pe har rehe a'e.
\q1 Wainuinuromo umume'u uzeapo ma'e ràm wanupe.
\q1 
\v 2 — Pepytu'u ikatu 'ymaw rupi pureruze'eg ire nehe.
\q1 Pepytu'u teko ikatu 'ym ma'e wamyrypar romo peneko re nehe.
\q1 
\v 3 Pezekaiw katu ma'e hereko 'ymar wanehe nehe, tu 'ym ma'e wanehe ihy 'ym ma'e wanehe nehe no.
\q1 Pekatu ma'erahy ipuraraw par wanupe nehe, ma'e hereko 'ymar wanupe nehe no.
\q1 
\v 4 Pepytywà ikàg 'ym ma'e pe wà nehe. Pepytywà hemetarer 'ym ma'e pe wà nehe no.
\q1 Pepyro a'e teko teko ikatu 'ym ma'e wanuwi pe wà nehe.
\q1 
\v 5 — Ma'e kwaw par 'ym romo peiko.
\q1 Napekwaw pixik kwaw ma'e. Peiko pytunahy haw rehe.
\q1 Naperuze'egatu kwaw ywy rehe har pe wà.
\q1 
\v 6 Nezewe aze'eg peme. — Peiko tupàn romo.
\q1 Pe paw peiko Tupàn Ywate Wera'u Har ta'yr romo.
\q1 
\v 7 Nezewe rehe we pemàno putar wyzài awa ài nehe. Wyzài tuwihaw ta'yr umàno wà.
\q1 Nezewegatete peneko haw upaw putar nehe no, a'e ihe, a'e wanupe.
\b
\q1 
\v 8 O Tupàn, ezur ywy rehe har waneruze'eg pà nehe,
\q1 Ta'e ywy nànànar paw wiko nema'e romo wà xe.
\c 83
\s1 O Tupàn, eityk neàmàtyry'ymar ne wà nehe
\d Zegar haw Azaw hemiapo kwer
\q1 
\v 1 O Tupàn, epyta zo urewe neze'eg 'ym pà nehe.
\q1 Epytu'u zo neze'eg ire nehe. Epytu'u zo ikatu ma'e urewe iapo re nehe, o Tupàn.
\q1 
\v 2 Eme'egatu kury. Neàmàtyry'ymar uzemumymumyz waiko wà kury.
\q1 Nerehe iakatuwawahy 'ym ma'e uwak putar nekutyr wà nehe kury.
\q1 
\v 3 Umume'u neremiaihu wanupe wemiapo ràm ikatu 'ym ma'e waiko wà.
\q1 Ipurapo wer ikatu 'ym ma'e rehe neremipyro kwer wanupe wà.
\q1 
\v 4 Nezewe uze'eg wà. — Pezur nehe.
\q1 Ximumaw teko Izaew izuapyapyr zane wà nehe.
\q1 Nezewe amogwer teko heharaz putar waner wi wà nehe. Na'ima'enukwaw pixik kwaw wanehe wà nehe, i'i wà.
\q1 
\v 5 Waàmàtyry'ymar uzemono'og wemiapo ràm ikatu 'ym ma'e imume'u pà uzeupeupe wà.
\q1 Neàmàtyry'ymar paw umume'u neàmàtyry'ym àwàm uzeupeupe wà. Na'aw neàmàtyry'ymar waner xe wà:
\q1 
\v 6 Teko Enom izuapyapyr wà. Teko Izimaew izuapyapyr wà.
\q1 Teko Moaw izuapyapyr wà. Teko Agar izuapyapyr wà.
\q1 
\v 7 Teko Zemaw izuapyapyr wà. Teko Amon izuapyapyr wà. Teko Amarek izuapyapyr wà.
\q1 Teko Piri ywy rehe har wà. Teko Xir tawhu pe har wà.
\q1 
\v 8 Teko Axir her ma'e uzemono'og Iro izuapyapyr wapyr wà.
\q1 Ikàg uzeinuiromo Amon izuapyapyr wanehe we wà, Moaw wanehe we wà no.
\q1 
\v 9 O Tupàn, kwehe mehe eremumaw Minià izuapyapyr ne wà. Ezapo nezewe haw a'e teko wanupe nehe no.
\q1 Kwehe mehe erezuka kar Xi ne. Erezuka kar Zamim yrykawhu Kizom her ma'e huwake no. Ezapo nezewe haw a'e teko wanupe nehe no.
\q1 
\v 10 Eremumaw a'e zauxiapekwer Enor ywy rehe ne wà.
\q1 Wanetekwer inem ywy rehe wà.
\q1 
\v 11 Kwehe mehe erezuka kar Orew Zeew rehe we ne.
\q1 Ezapo nezewe haw zauxiapekwer wanuwihaw wanupe nehe no.
\q1 Eityk wanuwihaw paw rupi ne wà nehe, Zema heityk awer zàwe nehe, Xaramun heityk awer zàwe nehe no.
\q1 
\v 12 A'e tuwihaw uze'eg nezewe uzeupeupe wà.
\q1 — Xipyhyk Izaew waywy nehe, Tupàn ima'e ipyhyk pà nehe, i'i uzeupeupe wà.
\b
\q1 
\v 13 O Hezar, emuhàmuhàz a'e teko ywyku'i ài nehe.
\q1 Ywytu weraha ka'akyr uxinig ma'e muite a'e. Eraha a'e teko nezewe ne wà nehe no.
\q1 
\v 14 Tata wapy ka'a a'e.
\q1 Tatareny uhua'u ma'e ukaz ywytyr rehe no.
\q1 
\v 15 Nezewe eho wanaikweromo ywytuaiw ài nehe.
\q1 Emukyze kar nekwahy haw ywytuaiw zàwenugar wi ne wà nehe.
\q1 
\v 16 O Tupàn Tuweharupi Wiko Ma'e, emumaranugar ne wà nehe.
\q1 Nezewe mehe, — Ereiko ikàg wera'u ma'e romo ne, i'i putar newe wà nehe.
\q1 
\v 17 Tuwe ereityk wamumaranugar kar pà ne wà nehe. Tuwe na'ikàg pixik kwaw wà nehe.
\q1 Tuwe umàno maranugar haw uhua'u ma'e wy pe wà nehe.
\q1 
\v 18 Tuwe ukwaw Tupàn Tuweharupi Wiko Ma'e romo nereko haw wà nehe. Xo ne zo ereiko Tupàn Tuweharupi Wiko Ma'e romo ne.
\q1 Ereiko Ywate Wera'u Har ywy nànànar waneruze'egar romo ne. Tuwe ukwaw nereko haw wà nehe.
\c 84
\s1 Aexaka'u Tupàn Hàpuzuhu ihe
\d Zegar haw Kora wanemiapo kwer
\q1 
\v 1 Azamutar katu tuwe neràpuzuhu ihe,
\q1 O Tupàn Ikàg Wera'u Ma'e.
\q1 
\v 2 Hereko wer tuwe a'e pe ihe.
\q1 Amonokatu hereha Tupàn Tuweharupi Wiko Ma'e hàpuzuhu izywyr katu haw pe ihe.
\q1 Hahy haw rupi azegar herurywete haw rupi Tupàn Wikuwe Ma'e pe.
\q1 
\v 3 O Tupàn Ikàg Wera'u Ma'e, heruwihawete, hezar.
\q1 Ma'ea'yr hapy haw neràpuzuhu pe har huwake
\q1 Pitàwà uzapo waity wà.
\q1 Wiràmiri uzapo weko haw a'e pe wà.
\q1 Uzekaiw umemyr wanehe a'e pe wà.
\q1 
\v 4 Hurywete neràpuzuhu pe wiko ma'e wà.
\q1 Umuzàg zegar haw nekatu haw rehe tuweharupi wà.
\q1 
\v 5 Hurywete teko wà, aze eremur nekàgaw wanupe,
\q1 Aze iho wer pe Xiàw ywytyr kutyr har rehe nemuwete katu pà wà.
\q1 
\v 6 Ywyàpyznaw Tehaykwer her ma'e rupi waho mehe,
\q1 Tynehem ytyzuzàmaw pupe a'e ywyàpyznaw a'e.
\q1 Àmàn ipy upyk katu haw pupe no.
\q1 
\v 7 Waho mehe wakàgaw uhua'u wera'u oho iko.
\q1 Wexak putar Tupàn amogwer tupàn wazar Zeruzarez pe a'e wà nehe.
\b
\q1 
\v 8 Ezeapyaka katu heze'eg rehe nehe, o Tupàn Tuweharupi Wiko Ma'e Ikàg Wera'u Ma'e.
\q1 Herenu pe nehe, o Zako Izar.
\q1 
\v 9 O Tupàn, emono neze'egatu nehe, urerehe uzekaiw ma'e rehe nehe,
\q1 Tuwihawete neremixak kwer rehe nehe.
\b
\q1 
\v 10 Aze amumaw pitài 'ar neràpuzuhu pupe hereko pà ihe,
\q1 Ikatu wera'u ihewe 1.000 'ar amo me hereko pà imumaw paw wi ihewe.
\q1 Aze apyta Tupàn hezar hàpuzuhu hukenaw huwake ihe, ikatu wera'u ihewe ikatu 'ym ma'e wanàpuz me hereko haw wi a'e.
\q1 
\v 11 Tupàn Tuweharupi Wiko Ma'e wiko tatainy romo zanewe. Wiko Zanemimaw romo.
\q1 Uzamutar katu ikatu ma'e iapo har wà. Umuwete ikatu ma'e iapo har wà no.
\q1 Omono ikatu ma'e paw wanupe a'e.
\b
\q1 
\v 12 O Tupàn Ikàg Wera'u Ma'e,
\q1 Hurywete tuwe nerehe uzeruzar ma'e wà.
\c 85
\s1 Tupàn umuigo kar Izaew ma'e tetea'u hereko har romo wà
\d Zegar haw Kora wanemiapo kwer
\q1 
\v 1 O Tupàn Tuweharupi Wiko Ma'e, nekatuahy neywy pe ne.
\q1 Eremuigo kar wi Izaew izuapyapyr temi'u hereko har romo ma'e hereko har romo ne wà.
\q1 
\v 2 Eremunàn neremiaihu wanemiapo kwer ikatu 'ym ma'e paw ne.
\q1 Nereme'e kwaw wakatu 'ymaw rehe.
\q1 
\v 3 Erepytu'u wanupe nekwahy re.
\q1 Ereityk nekwahy haw tata zàwenugar.
\b
\q1 
\v 4 Uremuigo kar wi pe temi'u hereko har romo ma'e hereko har romo nehe, o Tupàn urepyro har.
\q1 Epytu'u neremiaihu wanehe nekwahy re nehe.
\q1 
\v 5 Aipo nerepytu'u pixik kwaw urerehe nekwahy re nehe.
\q1 Aipo nekwahy haw nupaw pixik kwaw nehe.
\q1 
\v 6 Emur wi nekàgaw urewe nehe.
\q1 Nezewe mehe eremurywete kar wi putar neremiaihu ne wà nehe.
\q1 
\v 7 O Tupàn Tuweharupi Wiko Ma'e exak kar nepuruamutar katu haw urewe nehe.
\q1 Emur urepyro àwàm urewe nehe no.
\b
\q1 
\v 8 Ihe ainu putar Tupàn Tuweharupi Wiko Ma'e ize'eg mehe ihe nehe.
\q1 — Peneko haw ikatuahy putar nehe,
\q1 Aze napezewyr kwaw pene'o haw pe nehe,
\q1 I'i zanewe hemiaihu wanupe a'e, zanewe hehe uzeruzar ire upytu'u 'ym ma'e wanupe a'e.
\q1 
\v 9 Azeharomoete aze teko ukyze izuwi wà, aze umuwete katu wà, Tupàn ipurupyro wer a'e teko wanehe a'e.
\q1 Nezewe mehe heko haw purupyro ma'e upyta putar zaneywy rehe nehe.
\q1 
\v 10 Mokoz teko uzeàwàxi wà. Nezewegatete Tupàn ipuruamutar haw uwàxi putar puruwi ityryk 'ymaw a'e nehe.
\q1 Nezewegatete ikatu haw uzemono'og putar wamuigo katu kar haw inuromo nehe no.
\q1 
\v 11 Teko Tupàn wi utyryk 'ym ma'e hezuz putar ywy wi ywyra ài wà nehe.
\q1 Tupàn ikatuahy haw ume'e putar ywak wi ywy rehe nehe no.
\q1 
\v 12 Tupàn umur putar ikatuahy ma'e zanewe nehe.
\q1 Zaneywy umuezuz kar putar temi'u tetea'u nehe.
\q1 
\v 13 Tupàn ikatu haw oho putar henataromo nehe.
\q1 Umukatu putar hape ràm izupe nehe.
\c 86
\s1 Upytywà haw henoz taw ma'erahy ipuraraw mehe
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 O Tupàn Tuweharupi Wiko Ma'e, herenu pe heze'eg ihewe iwazar pà nehe,
\q1 Ta'e nahekàg kwaw ihe xe, ta'e naheta kwaw ma'e ihewe xe.
\q1 
\v 2 Hepyro pe hemàno haw wi nehe, ta'e azeruzar nerehe hepytu'u 'ym pà ihe xe.
\q1 Azeharomoete, hepyro pe nehe, ta'e aiko neremiruze'eg romo ihe xe,
\q1 Ta'e azeruzar nerehe ihe xe.
\q1 
\v 3 Ereiko hezar romo.
\q1 Hepuhareko pe nehe, hezar,
\q1 Ta'e amumaw 'ar katu newe heze'eg pà ihe xe.
\q1 
\v 4 O hezar, emurywete kar hepy'a nehe.
\q1 Aiko neremiruze'eg romo ihe, ta'e hema'enukwaw paw uzeupir newe xe.
\q1 
\v 5 O hezar, nekatuahy ne. Teko wanemiapo kwer ikatu 'ym ma'e imunànar romo ereiko.
\q1 Erezamutar katu newe uze'eg ma'e paw ne wà.
\q1 
\v 6 O Tupàn Tuweharupi Wiko Ma'e, herenu pe newe heze'eg mehe nehe.
\q1 Aze ahapukaz hepytywà àwàm henoz pà newe nehe, herenu pe nehe.
\q1 
\v 7 Ma'erahy ipuraraw mehe uruenoz ihe,
\q1 Ta'e erewazar heze'eg ihewe ne xe.
\q1 
\v 8 Naheta kwaw amo tupàn nezàwenugar wà, hezar.
\q1 Ni amo nupuner kwaw ikàg ma'e iapo haw rehe nezàwe wà.
\q1 
\v 9 Erezapo teko paw rupi ne wà. A'e paw ur putar wà nehe.
\q1 Uzeamumew putar nerenataromo wà nehe.
\q1 Umume'u putar nehua'u haw wà nehe,
\q1 
\v 10 Ta'e nehua'u ne xe.
\q1 Nekàg no.
\q1 Xo ne zo ereiko Tupàn romo.
\q1 
\v 11 O Tupàn Tuweharupi Wiko Ma'e, hemu'e pe heremiapo ràm rehe nehe.
\q1 A'e mehe ureruzar putar azeharomoete ihe nehe.
\q1 Hemu'e pe neremiruze'eg ikatu ma'e romo hereko haw rehe nehe.
\q1 
\v 12 Hezar, Tupàn, amume'u putar nekatu haw wahy haw rupi nehe.
\q1 Tuweharupi amume'u putar nehua'u haw nehe no.
\q1 
\v 13 Heamutar katu pe ne.
\q1 Uhua'u heamutar katu haw.
\q1 Hepyro pe hemàno haw wi hetym àwàm ohoete ma'e wi ne.
\q1 
\v 14 O Tupàn, teko amo wanuwi wiko wera'u ma'e heàmàtyry'ym waiko wà.
\q1 Teko purupe ma'erahy ipuraraw kar har wà,
\q1 Nerehe uzekaiw 'ym ma'e wà, ipuruzuka wer herehe wà.
\q1 
\v 15 Ne, hezar, ereiko Tupàn purupuhareko ma'e romo puruamutar katu ma'e romo ne.
\q1 Iàrew purehe nezepykaw. Nekatuahy. Neretyryk kwaw neremiruze'eg wanuwi.
\q1 
\v 16 Eme'e wi herehe nehe. Hepuhareko pe nehe.
\q1 Emur nekàgaw ihewe hepyro pà nehe, ta'e aiko neremiruze'eg romo ihe xe.
\q1 Aiko hehy zàwe.
\q1 A'e wiko neremiruze'eg romo a'e no.
\q1 
\v 17 O Tupàn Tuweharupi Wiko Ma'e, ezapo ma'e ihewe nekatu haw hexak kar pà ihewe nehe.
\q1 Nezewe mehe herehe iakatuwawahy 'ym ma'e wexak putar hepytywà arer romo nereko haw wà nehe, wexak putar hemurywete kar arer romo nereko haw wà nehe no.
\q1 Hexak mehe imaranugar putar wà nehe.
\c 87
\s1 Zeruzarez wiko Tupàn tawhu romo a'e
\d Zegar haw Kora wanemiapo kwer
\q1 
\v 1 Tupàn Tuweharupi Wiko Ma'e uzapo uma'e
\q1 Tawhu ywytyr imonokatu pyrer rehe a'e.
\q1 
\v 2 Uzamutar katu wera'u Zeruzarez tawhu
\q1 Amogwer tawhu Izaew ywy rehe har wanuwi upaw rupi a'e.
\q1 
\v 3 O teko tawhu Tupàn ima'e rehe har wà, ezeapyaka katu ko ma'e ikatuahy ma'e rehe nehe.
\q1 Tupàn umume'u ko ma'e nerehe a'e.
\q1 
\v 4 — Aze teko amo ywy rehe har hereruzar wà nehe, amuapyk putar a'e ywy her hepape rehe amogwer tawhu ikatu ma'e waner wanehe we ihe nehe.
\q1 Na'aw waner heremimuapyk ràm xe wà kury: Ezit, Mawiron.
\q1 Teko Piri ywy rehe har wà, Xir tawhu pe har wà no, Exio ywy rehe har wà no, wiko putar ikatu ma'e romo herenataromo wà nehe.
\q1 Areko katu putar a'e teko paw Zeruzarez pe ihe wà nehe, uzexak ma'e kwer ài ihe wà nehe, i'i Tupàn.
\b
\q1 
\v 5 Nezewe teko uze'eg putar Zeruzarez rehe wà nehe. — Teko paw wiko a'e pe wiko ma'e kwer romo a'e wà, i'i putar wà nehe.
\q1 — Tupàn Ywate Wera'u Har uzapo putar a'e tawhu a'e nehe, tawhu ikàg ma'e romo a'e nehe.
\q1 
\v 6 Tupàn Tuweharupi Wiko Ma'e umuapyk putar teko waner pape rehe wà nehe.
\q1 Upaw rupi wiko putar Zeruzarez pe har romo wà nehe.
\q1 
\v 7 A'e pe wiko ma'e upynyk putar nezewe uzegar pà wà nehe.
\q1 — Ereiko Zanemurywete kar har romo, Zeruzarez, i'i putar wà nehe.
\c 88
\s1 Ma'erahy ipuraraw par uze'eg Tupàn pe
\d Zegar haw Kora wanemiapo kwer
\q1 
\v 1 O Tupàn Tuweharupi Wiko Ma'e, hezar, hepyro har,
\q1 'aromo, pyhaw no, neruwarupi, ahapukaz hezemumikahy pà ihe.
\b
\q1 
\v 2 Herenu pe newe heze'eg mehe nehe.
\q1 Ezeapyaka herehe hepytywà àwàm henozahy mehe nehe no.
\q1 
\v 3 Ta'e ma'erahy he'aromo u'ar ma'e kwer heta tetea'u a'e wà xe.
\q1 A'e rupi aiko hemàno haw huwake ihe kury.
\q1 
\v 4 Aiko teko umàno tària'i ma'e paw wazàwe ihe.
\q1 Hekàgaw paw uhem ihewi.
\q1 
\v 5 Hereityk umàno ma'e kwer wainuinuromo a'e wà.
\q1 Aiko zauxiapekwer umàno ma'e kwer tywypaw pe heityk pyrer wazàwe ihe.
\q1 Nereharaz amo teko wanuwi wanehe nezekaiw ire nepytu'u pà.
\q1 Aiko wazàwe ihe.
\q1 
\v 6 Hereityk pe umàno ma'e kwer wapyta haw pe ne. Ipytun a'e pe.
\q1 Ohoete ywykwar.
\q1 
\v 7 Nereikwahy haw ipuhuz katu herehe.
\q1 Ykotok yryhu pe har ài hezuhazuhaw a'e.
\q1 
\v 8 Eremunyryk kar hemyrypar ihewi ne wà.
\q1 Hemuro kar pe wanupe no.
\q1 Aiko imunehew pyrer uhemaw rehe upuner 'ym ma'e ài.
\q1 
\v 9 Apuraraw ma'erahy tetea'u ihe. Te, naexak katu kwaw ma'e ihe kury.
\q1 O Tupàn Tuweharupi Wiko Ma'e, 'ar nànàn aze'eg newe.
\q1 Aupir hepo newe heze'eg pà.
\b
\q1 
\v 10 Aipo erezapo putar purumupytuhegatu kar haw umàno ma'e kwer wapyro pà nehe.
\q1 Aipo upu'àm putar nekatu haw imume'u pà wà nehe.
\q1 
\v 11 Aipo uze'eg nepuruamutar katu haw rehe umàno ma'e kwer wapyta haw pe wà.
\q1 Aipo a'e ma'e imumaw paw pe uze'eg puruwi netyryk 'ymaw rehe wà nehe.
\q1 
\v 12 Aipo teko wexak neremiapo kwer purumupytuhegatu kar haw ipytunahy mehe wà.
\q1 Aipo teko wexak putar puruwi netyryk 'ymaw ywy ma'e wi heharaz taw rehe wà nehe.
\b
\q1 
\v 13 O Tupàn Tuweharupi Wiko Ma'e, aze'eg newe hepytywà àwàm henoz pà ihe.
\q1 Tuweharupi ku'em mehe aze'eg newe.
\q1 
\v 14 Màràzàwe tuwe hereityk pe ne.
\q1 Màràzàwe tuwe erezeàmim ihewi.
\q1 
\v 15 Hekwàkwàmo romo hereko mehe arer we apuraraw ma'erahy ihe. Màno haw huwake ata aha.
\q1 Hekene'o herehe nezepyk awer ipuhuz taw rehe.
\q1 
\v 16 Nekwahy haw u'ar herehe.
\q1 Wikwahy ma'e romo nereko haw u'ar he'ar romo. Heàmàtyry'ym awer iaiw ma'e hemumaw tària'i.
\q1 
\v 17 Umumaw 'ar katu heywyr umàmàn pà wà. Nuzawy kwaw àmàn ywy ipy kar wà.
\q1 Umàmàn heywyr paw rupi katete wà.
\q1 
\v 18 Eremunyryk kar hemyrypar ihewi ne wà. Utyryk heruwake wiko ma'e ihewi wà no.
\q1 Xo ipytunahy haw zo heta ihewe kury.
\c 89
\s1 Tupàn ikàg wera'u ma'e ikatu haw rehe zegar haw
\d Zegar haw Età hemiapo kwer
\q1 
\v 1 O Tupàn Tuweharupi Wiko Ma'e, tuweharupi azegar putar nepuruamutar katu haw rehe nehe.
\q1 Amume'u putar puruwi netyryk 'ymaw teko wanupe nehe no, wapurumuzàmuzàg wanupe nehe no.
\q1 
\v 2 Akwaw nepuruamutar katu haw ipaw pixik 'ym àwàm ihe.
\q1 Puruwi netyryk 'ymaw ikàg ywak ài.
\q1 
\v 3 Nezewe ereze'eg kwez ne. — Aexaexak heremiaihu Tawi ihe.
\q1 Azapokatu heze'egaw hehe we no.
\q1 Amume'u ko ma'e heremiapo ràm izupe.
\q1 
\v 4 — Tuweharupi amo nezuapyapyr wiko putar tuwihawete romo a'e wà nehe.
\q1 Azekaiw katu putar tuwihawete romo waneko haw rehe tuweharupi nehe, a'e newe kwehe mehe.
\b
\q1 
\v 5 O Tupàn Tuweharupi Wiko Ma'e, ywak uzegar ikatuahy ma'e neremiapo kwer rehe a'e.
\q1 Nereko haw pe har uzemono'og ma'e kwer uzegar puruwi netyryk 'ymaw rehe wà no.
\q1 
\v 6 O Tuweharupi Wiko Ma'e, naheta kwaw amo nezàwenugar ywak rehe wà.
\q1 Ywak rehe har paw neawy a'e wà.
\q1 
\v 7 Nereko haw pe har nemuwete katu wà.
\q1 Neruwake har neywyr har paw ukyze tuwe newi wà.
\b
\q1 
\v 8 O Tupàn Tuweharupi Wiko Ma'e Ikàg Wera'u Ma'e.
\q1 Ni amo na'ikàg kwaw ne ài wà.
\q1 Erezapo neremimume'u kwer upaw rupi, o Tupàn Tuweharupi Wiko Ma'e.
\q1 
\v 9 Ereiko yryhu ikàg ma'e izar romo.
\q1 Eremupytu'u kar ykotok uhua'u ma'e.
\q1 
\v 10 Erezuhaw àzàg Haw her ma'e izuka pà ne.
\q1 Nekàgaw uhua'u ma'e rupi ereityk neàmàtyry'ymar ne wà.
\q1 
\v 11 Ereiko ywak izar romo. Ywy izar romo ereiko no.
\q1 Erezapo ywy. Ywy rehe har paw erezapo ne wà no.
\q1 
\v 12 Erezapo ma'e kwarahy heixe haw awyze kutyr har paw rupi ne wà. Erezapo ma'e kwarahy ihemaw awyze kutyr har paw rupi ne wà no.
\q1 Tamor ywytyr a'e, Eremon ywytyr a'e no, umume'u nekatu haw urywete haw rupi a'e wà.
\q1 
\v 13 Erepuner azeharomoete ne.
\q1 Nekàgaw uhua'u tuwe no.
\q1 
\v 14 Nepureruze'eg mehe teko na'imunar kwaw ma'e rehe wà. Nahemu'em kwaw wà. Nekatu haw rupi erepureruze'eg iko ne.
\q1 Neretyryk kwaw puruwi. Ma'e paw iapo mehe erepuruamutar katu ne.
\b
\q1 
\v 15 Hurywete teko zegar haw pupe nemuwete katu har wà. Hurywete nepyr wiko ma'e wà.
\q1 Nuzuawy kwaw tatainy rehe wiko ma'e wà.
\q1 
\v 16 'Ar katu umumaw nerehe urywete romo wà.
\q1 Umume'u nekatu haw wà, ta'e nekatuahy wanupe ne xe.
\s1 Tupàn Tawi pe hemimume'u kwer
\q1 
\v 17 Ne, o Tupàn, ereiko urekàgaw ipuràg ma'e romo ne. Nekatu haw rupi ereityk kar urewe ne wà.
\q1 
\v 18 Erexarexak urerehe uzekaiw ma'e ne.
\q1 Ne, Tupàn, Izaew wazar ikatuahy ma'e ne,
\q1 Ne eremur ureruwihawete urewe ne.
\q1 
\v 19 Kwehe mehe aexak ma'e hepuahu pe har zàwenugar ihe.
\q1 Nezewe ereze'eg neremiruze'eg nerehe uzeruzar ire upytu'u 'ym ma'e wanupe.
\q1 — Apytywà amo zauxiapekwer ikwaw katu pyr ihe.
\q1 Amono pureruze'egaw awa teko wainuinuromo har ihe, heremixamixak kwer pe ihe.
\q1 
\v 20 Aexaexak heremiruze'eg Tawi penuwihawete romo ihe.
\q1 Azakook uri kawer ihewe imur katu pyrer hehe no, tuwihawete romo heko haw hexak kar pà purupe no.
\q1 
\v 21 Hekàgaw upyta putar hehe tuweharupi nehe.
\q1 Hepuner haw umukàg kar putar nehe.
\q1 
\v 22 Iàmàtyry'ymar nuweityk pixik kwaw wà nehe.
\q1 Ikatu 'ym ma'e nuweityk pixik kwaw wà nehe.
\q1 
\v 23 Amumamumaw putar iàmàtyry'ymar ihe wà nehe.
\q1 Azuka putar hehe iakatuwawahy 'ym ma'e ihe wà nehe no.
\q1 
\v 24 Natyryk pixik kwaw Tawi wi ihe nehe. Azamutar katu ihe nehe.
\q1 Wereko putar hekàgaw nehe, a'e rupi weityk putar wàmàtyry'ymar tuweharupi a'e wà nehe.
\q1 
\v 25 Amuhua'u putar ipureruze'egaw nehe.
\q1 Uzypyrog putar Mezitehàn yryhu pe. Oho putar Ewparat yrykawhu pe nehe.
\q1 
\v 26 A'e mehe uze'eg putar nezewe ihewe nehe.
\q1 — Ereiko heru romo. Hezar romo ereiko no.
\q1 Ereiko herehe uzekaiw ma'e romo. Itahu hemimaw zàwenugar romo ereiko no, i'i putar ihewe nehe.
\q1 
\v 27 Areko katu putar hera'yr ipy ài ihe nehe.
\q1 Amuigo kar putar amo tuwihawete paw wanuwi ikàg wera'u ma'e romo ihe nehe no.
\q1 
\v 28 Azamutar katu putar tuweharupi nehe.
\q1 Heze'eg izupe heremimume'u kwer nazuhaw pixik kwaw nehe.
\q1 
\v 29 Tuweharupi heta putar izuapyapyr izupe wà nehe.
\q1 Aze heta ywak nehe, amo izuapyapyr wiko putar tuwihawete romo wà nehe.
\b
\q1 
\v 30 Aze izuapyapyr uzuhaw heze'eg wà nehe,
\q1 Aze nuiko kwaw heze'egaw rehe wà nehe,
\q1 
\v 31 aze nuzekaiw kwaw heremiapo putar haw rehe wà nehe,
\q1 Aze nomonokatu kwaw heremiapo karer wà nehe,
\q1 
\v 32 A'e mehe azepyk putar wanehe wanemiapo kwer ikatu 'ym ma'e rehe ihe nehe.
\q1 Apuraraw kar putar ma'erahy wanupe wanemiawy kwer hekuzaromo nehe.
\q1 
\v 33 Nezewe rehe we napytu'u kwaw Tawi iamutar katu re ihe nehe.
\q1 Azapo putar ma'e heze'eg izupe heremimume'u kwer rupi katete ihe nehe.
\q1 
\v 34 Nazuhaw kwaw heze'egaw hehe we heremiapo katu kwer nehe.
\q1 Azapo putar heremimume'u kwer tuweharupi nehe.
\q1 
\v 35 Xo pitài haw rupi amume'uahy ko ma'e ihe. Amume'uahy ko ma'e herer ikatuahy ma'e rehe.
\q1 Azapo putar a'e ma'e heze'eg awer rupi katete ihe nehe. — Naheremu'em pixik kwaw Tawi pe, a'e ihe.
\q1 
\v 36 Tuweharupi heta putar izuapyapyr izupe wà hehe.
\q1 Kwarahy ihyape mehe nehe, azekaiw katu putar izuapyapyr tuwihawete romo wiko ma'e wanehe ihe nehe.
\q1 
\v 37 Zahy upyta ywak rehe a'e. Nuzawy kwaw ywy rehe uzeapo ma'e hexakar a'e. Nezewegatete Tawi ipureruze'egaw nupaw kwaw a'e nehe no.
\q1 Zahy ywak rehe har nuzuawy kwaw ko heze'eg henu katu har a'e.
\s1 Tuwihawete heitykaw
\q1 
\v 38 Erekwahy tuwihawete neremixak kwer pe ne.
\q1 Eretyryk izuwi Nerezekaiw kwaw hehe.
\q1 
\v 39 Erezuhaw neze'egaw neremiruze'eg rehe we neremiapo katu kwer.
\q1 Ereityk iàkà rehe har tuwihawete romo hexakar haw ywy rehe.
\q1 
\v 40 Ereityk pàrirogawhu tawhu neremimonokatu kwer izywyr har.
\q1 Erezuhazuhaw tàpuztàtà a'e pe har wà no.
\q1 
\v 41 A'e pe ukwaw ma'e imunar ma'e a'e tawhu pe har nànàn wà.
\q1 Teko a'e tawhu huwake wiko ma'e uze'eg urywahyahy hehe wà.
\q1 
\v 42 Ereityk kar tawhu waàmàtyry'ymar wanupe.
\q1 Eremurywete kar heityk arer ne wà.
\q1 
\v 43 Eremuaiw tuwihawete ikàgaw.
\q1 Ereityk kar zauxiapekwer wanupe zeàmàtyry'ymawhu pe.
\q1 
\v 44 Erezo'ok ipuner haw tuwihawete wi.
\q1 Ereityk henaw no.
\q1 
\v 45 Eremutua'uhez i'ar 'ym mehe we.
\q1 Erezapo heko haw maranugarahy haw romo.
\s1 — Hepyro pe nehe, i'i Tupàn pe
\q1 
\v 46 Màràn 'ar eremumaw putar nezeàmim pà nehe, o Tupàn Tuweharupi Wiko Ma'e.
\q1 Aipo tuweharupi ereiko putar urewi utyryk ma'e romo nehe.
\q1 Màràn 'ar nekwahy haw umumaw putar tata ài ukaz pà nehe.
\q1 
\v 47 Nema'enukwaw hereko haw rehe nehe. Iaikwera'i a'e.
\q1 Teko neremiapo kwer paw umàno putar amo 'ar mehe wà nehe. Nema'enukwaw wamàno àwàm rehe nehe.
\q1 
\v 48 Mo wikuwe putar tuweharupi nehe.
\q1 Mo uhem putar umàno haw wi nehe. Mo upuner utym àwàm wi uhemaw rehe nehe.
\b
\q1 
\v 49 O hezar, kwehe mehe erezapo ma'e ureamutar katu haw hexak kar pà urewe ne. Màràzàwe tuwe nerezapo kwaw agwer ma'e urewe kury.
\q1 Kwehe mehe eremume'u neremiapo ràm Tawi pe. Màràzàwe tuwe neremume'u kwaw neremiapo ràm urewe kury.
\q1 
\v 50 Heàmàtyry'ymar uze'eg zemueteahy waiko herehe wà. Aiko neremiruze'eg romo.
\q1 Nema'enukwaw herehe waze'egaw rehe nehe. Nerehe uzeruzar 'ym ma'e uzapo ikatu 'ym ma'e tetea'u ihewe wà.
\q1 
\v 51 O Tupàn Tuweharupi Wiko Ma'e, neàmàtyry'ymar uze'eg zemueteahy tuwe tuwihawete neremixak kwer rehe wà.
\q1 Wyzài taw pe iho mehe uze'eg zemueteahy hehe wà.
\b
\q1 
\v 52 Ximume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw tuweharupi nehe.
\q1 Azeharomoete. Azeharomoete.
\c 90
\ms1 PAPE 4 HAW
\mr 90–106
\s1 Tupàn, teko wà no
\d Moizez uze'eg Tupàn pe
\q1 
\v 1 Urezar, tuweharupi ereiko uremimaw romo ne.
\q1 
\v 2 Ywytyr iapo 'ym mehe we, ywy ywak iapo pà nezypyrog 'ym mehe we, ereiko Tupàn romo tuweharupi ne.
\q1 Nerezypyrog kwaw Tupàn romo nereko pà.
\q1 Nupaw pixik kwaw Tupàn romo nereko haw nehe. Tuweharupi ereiko Tupàn romo.
\q1 
\v 3 Ereze'eg nezewe teko neremiapo kwer wanupe.
\q1 — Peiko wi izypy mehe arer zàwenugar romo nehe, ere wanupe.
\q1 Eremuigo kar wi ywyku'i romo ne wà.
\q1 
\v 4 1.000 kwarahy nuzawy kwaw pitài 'ar newe.
\q1 Nuzawy kwaw 'ar karumehe arer. Upaw a'e 'ar.
\q1 1.000 kwarahy nuzawy kwaw pitài or pyhaw har. Na'arewahy upaw.
\q1 
\v 5 Eremumaw teko waneko haw ne wà.
\q1 Nuzuawy kwaw awa ipuahu haw. Na'arewahy upaw.
\q1 Waneko haw nuzawy kwaw ka'a ku'em mehe hezuz ma'e.
\q1 
\v 6 Itua'u. Iputyr kury.
\q1 Karuk mehe uxinig umàno pà.
\q1 
\v 7 Uremumaw pe nekwahy haw pupe ne.
\q1 Nekwahy haw uremukyze kar.
\q1 
\v 8 Eremuapyk urekatu 'ymaw nezenataromo hexak pà ne.
\q1 Ereme'egatu ureremiapo kwer ikatu 'ym ma'e imim pyrer rehe neratainy pupe.
\b
\q1 
\v 9 Erekwahy. A'e rupi eremumaw ure 'ar na'arewahy.
\q1 Urereko haw upaw pytuhemaw ài.
\q1 
\v 10 Xo 70 kwarahy ru'u zo urumumaw uruiko pà.
\q1 Ikàg wera'u ma'e uhem 80 kwarahy pe wà.
\q1 A'e kwarahy werur xo urekene'o haw zo urewe. Xo ma'erahy ipuraraw paw zo werur urewe.
\q1 Na'iàrew kwaw urereko haw iahykaw. Na'e urukàzym.
\q1 
\v 11 Mo ukwaw nekwahy haw ikàgaw uhua'u haw wà. Nekwahy haw umukyze kar teko wà.
\q1 Mo ukwaw a'e newi wakyze haw wà.
\q1 
\v 12 Uremu'e pe nehe. Nezewe mehe urukwaw putar ure'ar heta tetea'u 'ymaw ure nehe.
\q1 Nezewe mehe urepy'a ukwaw katu putar ma'e nehe.
\b
\q1 
\v 13 Eme'e wi urerehe, o Tupàn Tuweharupi Wiko Ma'e.
\q1 Màràn mehe erepytu'u putar urewe nekwahy re nehe.
\q1 Epuhareko neremiruze'eg ne wà nehe.
\q1 
\v 14 Ku'em mehe eremur ureamutar katu haw urewe temi'u ài nehe, te uhyk putar urewe nehe.
\q1 Nezewe mehe uruzegar putar urereko mehe tuweharupi nehe.
\q1 Urerurywete putar ure'ar nànàn nehe no.
\q1 
\v 15 Amo 'ar mehe uremuzemumikahy kar pe ne.
\q1 A'e 'ar mehe urupuraraw ma'erahy tetea'u.
\q1 Nezewegatete uremurywete kar tuwe pe ko 'ar rehe nehe kury.
\q1 
\v 16 Tuwe neremiruze'eg wexak ma'e neremiapo uhua'u ma'e wà nehe.
\q1 Tuwe urezuapyapyr wexak nepuner haw ikatuahy ma'e wà nehe no.
\q1 
\v 17 O Tupàn urezar, ezakook neze'egatu urerehe nehe.
\q1 Emukatu ureremiapo ràm paw rupi nehe.
\q1 Azeharomoete, ezapokatu ureremiapo ràm paw rupi nehe.
\c 91
\s1 Tupàn wiko zanemonokatu har romo
\q1 
\v 1 Aze amo wekar weko katu haw Tupàn Ywate Wera'u Har inuromo nehe, aze uzeàmim Tupàn Ikàg
\q1 Wera'u Ma'e i'àg purumim ma'e iwy pe nehe,
\q1 
\v 2 A'e teko upuner nezewe u'e haw rehe Tupàn Tuweharupi Wiko Ma'e pe nehe, — Ereiko herehe uzekaiw ma'e romo ne.
\q1 Hepyro har romo ereiko no.
\q1 Ereiko hezar romo ne. Azeruzar nerehe ihe, i'i putar izupe nehe.
\q1 
\v 3 Tupàn nepyro putar ma'erahy newe uzeapo ma'e ràm uzeàmim ma'e kwer wi nehe.
\q1 Uzekaiw putar nerehe ma'eahy haw puruzuka ma'e wi nepyro pà nehe.
\q1 
\v 4 Nepyk putar upepo pupe nehe.
\q1 Ipepo iwype nuzeapo kwaw ikatu 'ym ma'e newe nehe.
\q1 Tupàn puruwi utyryk 'ymaw nerehe uzekaiw putar nehe. Nepyro putar ikatu 'ym ma'e wi u'yw wi purumimaw ài nehe.
\q1 
\v 5 Nerekyze kwaw ma'erahy pyhaw har wi nezuka haw pyhaw har wi nehe.
\q1 Nerekyze kwaw nezuka haw nerehe imunar haw 'aromo har wi nehe no.
\q1 
\v 6 Nerekyze kwaw ma'eahy haw ipytunaw rehe uhàz ma'e wanuwi nehe.
\q1 Nerekyze kwaw puruzuka ma'e kwarahy wapyter pe hin mehe har wanuwi nehe no.
\q1 
\v 7 Aze uzuka 1.000 teko neruwake har wà nehe,
\q1 Aze uzuka 10000 neywyr har wà nehe,
\q1 Nezewe rehe we nuzeapo kwaw ikatu 'ym ma'e newe nehe.
\q1 
\v 8 Ereme'e putar nehe.
\q1 Erexak putar ikatu 'ym ma'e wanehe izepykaw nehe.
\b
\q1 
\v 9 — Eiko herehe uzekaiw ma'e romo nehe, ere Tupàn Tuweharupi Wiko Ma'e pe.
\q1 — Eiko hepyro har romo nehe, ere Ywate Wera'u Har pe.
\q1 
\v 10 A'e rupi ni amo ikatu 'ym ma'e nanekutuk kwaw nehe.
\q1 Ni amo ikatu 'ymaw nuhem kwaw neràpuz huwake nehe.
\q1 
\v 11 Tupàn umuzekaiw kar putar weko haw pe har nerehe a'e wà nehe.
\q1 Ne'ar nànàn nepyro putar nezuka haw wi wà nehe.
\q1 
\v 12 Nepyhyk putar nepo rehe wà nehe.
\q1 Nezewe mehe ni nepy nuzemuahy kar kwaw ita rehe nehe.
\q1 
\v 13 Nepy pupe erezuhazuhaw putar zàwàruhu iriàw ne wà nehe.
\q1 Erepyrog putar moz wanehe nehe no, zàwàruhu iriàw ipuruzukaiw ma'e wazuka pà nehe, mozaiw puruzuka ma'e wazuka pà nehe no.
\q1 
\v 14 Nezewe uze'eg Tupàn. — Apyro putar heamutar katu har ihe wà nehe.
\q1 Azekaiw putar Tupàn Tuweharupi Wiko Ma'e romo hereko haw ikwaw par wanehe ihe nehe no.
\q1 
\v 15 Herenoz putar wà nehe. Awazar putar waze'eg wanupe nehe.
\q1 Aiko putar wanehe we ma'erahy ipuraraw mehe nehe.
\q1 Apyro putar ihe wà nehe. Amuawate kar putar amogwer teko wanupe ihe wà nehe no.
\q1 
\v 16 Amono putar waneko haw ipukua'u ma'e wanupe wanemiapo kwer hekuzaromo nehe.
\q1 Aexak kar putar wapyro har romo hereko haw wanupe nehe no, i'i Tupàn.
\c 92
\s1 Tupàn ikatu haw imume'u haw rehe zegar haw
\q1 
\v 1 O Tupàn Tuweharupi Wiko Ma'e. Neremimur kwer ikatu haw imume'u haw ikatuahy urewe.
\q1 Zegar haw nekatu haw rehe har imuzàgaw ikatuahy urewe no, o Ywate Wera'u Har.
\q1 
\v 2 Ku'em mehe nepuruamutar haw imume'u haw ikatuahy urewe.
\q1 Pyhaw puruwi netyryk 'ymaw imume'u haw ikatuahy urewe no.
\q1 
\v 3 Urumupu urewioràwiràn 10 ihàm hereko har newe urezegar mehe.
\q1 Urumupu urewioràwiràn irir her ma'e zegar haw newe imuzàg mehe no.
\q1 
\v 4 O Tupàn Tuweharupi Wiko Ma'e. Neremiapo ikàg ma'e hemurywete kar a'e.
\q1 Azegar herurywete haw rupi neremiapo kwer rehe no.
\b
\q1 
\v 5 Azeharomoete erezapo uhua'u ma'e ne wà, o Tupàn Tuweharupi Wiko Ma'e.
\q1 Zawaiw katu tuwe nema'enukwaw paw ikwaw paw urewe.
\q1 
\v 6 Na'aw amo ma'e iranaiw ma'e hemigwaw 'ym xe a'e.
\q1 Ma'e kwaw par 'ym nupuner kwaw ko ma'e ikwaw paw rehe a'e wà.
\q1 
\v 7 Ikatu 'ym ma'e iapo har hezuz ka'a ài wà.
\q1 Iaiw ma'e upuner hemetarer katu haw rehe wà.
\q1 Nezewe rehe we eremumaw putar ne wà nehe.
\q1 
\v 8 Ne, Tupàn Tuweharupi Wiko Ma'e, ne, ereiko amo wa'aromo tuweharupi upaw rupi ne. Ereiko ma'e wa'aromo upaw rupi ne no.
\q1 
\v 9 Neàmàtyry'ymar umàno putar wà nehe. Urukwaw wamàno àwàm ure.
\q1 Ereityk putar ikatu 'ym ma'e paw rupi ne wà nehe.
\b
\q1 
\v 10 Hemukàg kar pe tapi'ak awa hehaite ma'e ài hemuigo kar pà ne.
\q1 Eremur neze'egatu herehe hemurywete kar pà no.
\q1 
\v 11 Aexak heàmàtyry'ymar waneityk awer ihe.
\q1 Aenu ikatu 'ym ma'e wanehapukaz mehe ihe wà no.
\b
\q1 
\v 12 Teko nemuwete katu har iputyr putar inàzàràn 'yw ài wà nehe.
\q1 Iaiha putar ywyràkàxigyw Irimano ywytyr rehe har ài wà nehe.
\q1 
\v 13 Nuzawy kwaw ma'e'yw Tupàn Tuweharupi Wiko Ma'e heko haw pe itym pyrer wà.
\q1 Iputyr ywy zanezar hàpuzuhu huwake har rehe wà.
\q1 
\v 14 Utua'uhez mehe i'a wi wi putar wà nehe.
\q1 Tuweharupi ikàg putar wà nehe. Tynehem putar ukàgaw pupe wà nehe.
\q1 
\v 15 Ipurumume'u wer putar Tupàn Tuweharupi Wiko Ma'e ikatuahy haw rehe wà nehe. Tupàn wiko itahu zàwenugar heàmàtyry'ymar wanuwi hemimar romo a'e.
\q1 Nuiko pixik kwaw ikatu 'ym ma'e romo.
\c 93
\s1 Tupàn wiko paw rupi ma'e waneruze'egar romo
\q1 
\v 1 Tupàn Tuweharupi Wiko Ma'e wiko tuwihawete romo a'e. Umunehew ukàgaw kamirpuku ài.
\q1 Ipuner haw upyk uzar no.
\q1 Umuàtà ywy henaw rehe izypy mehe.
\q1 Ni amo nupuner kwaw imunyryk kar haw rehe henaw wi wà nehe.
\q1 
\v 2 O hezar, 'ar izypy mehe arer henataromo ereiko tuwe tuwihawete romo. Izypy mehe ereiko.
\q1 Tuweharupi ereiko putar nehe no.
\b
\q1 
\v 3 O Tupàn Tuweharupi Wiko Ma'e, yryhu ohoete ma'e uze'eg iko.
\q1 Ykotok okororoahy a'e.
\q1 
\v 4 Tupàn Tuweharupi Wiko Ma'e upureruze'eg iko ywak rehe upuner haw rupi.
\q1 Ikàgaw uhua'u wera'u yryhu ipuruzukaiw ma'e wi a'e.
\q1 Upuner wera'u ykotok yryhu rehe har wanuwi.
\b
\q1 
\v 5 O Tupàn Tuweharupi Wiko Ma'e, ikatuahy neze'eg.
\q1 A'e rupi teko upuner hehe uzeruzar haw rehe wà. Eremonokatu neràpuzuhu. Ikatuahy putar tuweharupi nehe.
\c 94
\s1 Tupàn wiko teko wanemiapo kwer imume'u har ikatuahy ma'e romo
\q1 
\v 1 O Tupàn Tuweharupi Wiko Ma'e, ereiko Tupàn purehe uzepyk ma'e romo ne.
\q1 Exak kar nekwahy haw purupe nehe.
\q1 
\v 2 Ereiko teko paw wanemiapo kwer imume'u har romo.
\q1 Epu'àm kury. Ezepyk amo wanuwi wiko wera'u ma'e wanehe nehe, ta'e na'ikatu kwaw a'e wà xe.
\q1 
\v 3 Ikatu 'ym ma'e umumaw kwarahy tetea'u urywete romo wà.
\q1 Màràzàwe tuwe neremupytu'u kar kwaw ne wà, o Tupàn Tuweharupi Wiko Ma'e.
\q1 
\v 4 Màràn mehe upytu'u putar wiko wera'u re wà nehe.
\q1 Màràn mehe upytu'u putar wemiapo kwer ikatu 'ym ma'e imume'u re wà nehe.
\b
\q1 
\v 5 O Tupàn Tuweharupi Wiko Ma'e. A'e teko uzuhazuhaw neremiaihu a'e wà.
\q1 Imunar neremiruze'eg wama'e wanehe wà.
\q1 
\v 6 Uzuka kuzà imen umàno ma'e kwer wà. Uzuka kwarer tu 'ym ma'e wà, ihy 'ym ma'e wà. Uzuka kuzàtài tu 'ym ma'e wà, ihy 'ym ma'e wà no.
\q1 Uzuka amo ae ywy rehe arer ureywy rehe wiko ma'e wà no.
\q1 
\v 7 Uze'eg nezewe uzeupe wà. — Tuweharupi Wiko Ma'e nume'e kwaw zanerehe a'e.
\q1 Tupàn Izaew wazar nukwaw kwaw zaneremiapo kwer a'e, i'i wà.
\b
\q1 
\v 8 Pezeagaw ko ma'e ikwaw pà nehe, iranaiw ma'e wà.
\q1 Màràn mehe peiko putar ma'e kwaw par romo nehe.
\q1 
\v 9 Tupàn Tuweharupi Wiko Ma'e wiko zaneapyakwar iapo arer romo a'e.
\q1 Aipo nupuner kwaw ma'e henu haw rehe a'e.
\q1 A'e wiko zanereha iapo arer romo.
\q1 Aipo nupuner kwaw ma'e hexakaw rehe.
\q1 
\v 10 Tupàn Tuweharupi Wiko Ma'e umume'u ywy nànànar wanemiapo kwer ikatu 'ym ma'e a'e, iapo har wanupe a'e.
\q1 Uzepyk putar wanehe nehe no.
\q1 Tupàn Tuweharupi Wiko Ma'e umu'e teko paw wà,
\q1 Ta'e ukwaw katu ma'e paw rupi a'e xe.
\q1 
\v 11 Tupàn Tuweharupi Wiko Ma'e ukwaw teko wama'enukwaw paw upaw rupi a'e.
\q1 Nuzawy kwaw ma'e heityk pyrer izupe.
\b
\q1 
\v 12 O Tupàn Tuweharupi Wiko Ma'e, hurywete neremimu'e wà.
\q1 Neze'eg rehe neremimu'e hurywete wà.
\q1 
\v 13 Upuraraw ma'erahy amo 'ar mehe wà. Eremupytu'u kar putar a'e 'ar mehe wà nehe.
\q1 Ikatu 'ym ma'e wanupe erewàpytymawok putar tywypaw nehe.
\q1 
\v 14 Tupàn Tuweharupi Wiko Ma'e nupuir kwaw wemiaihu wanuwi nehe.
\q1 Nuezar kwaw ipytywà pyr 'ym romo wà nehe.
\q1 
\v 15 Tuwihaw weruze'egatu putar teko a'e wà nehe.
\q1 Teko ikatu ma'e paw uzeruze'eg kar putar wanupe wà nehe.
\b
\q1 
\v 16 Mo upu'àm heruwake wà, ikatu 'ym ma'e wakutyr wà.
\q1 Mo upyta heruwake ikatu 'ym ma'e iapo har wakutyr wà.
\q1 
\v 17 Aze mo Tupàn Tuweharupi Wiko Ma'e nahepytywà iwer mo,
\q1 Aha mo hemàno haw pe.
\q1 
\v 18 O Tupàn Tuweharupi Wiko Ma'e, hemàno haw 'ar uhem etea'i mehe,
\q1 Nepuruamutar katu haw hemupu'àm kar he'ar 'ym mehe we.
\q1 
\v 19 Hezemumikahy mehe, ma'erahy ipuraraw mehe, hemurywete kar pe ne.
\q1 Hemupytu'u kar pe hezai'o re ne.
\b
\q1 
\v 20 Nereputar kwaw tuwihaw ikatu 'ym ma'e neruwake ne wà,
\q1 Ta'e — Ikatu haw, i'i mua'u teko wanupe wà xe, ikatu 'ymaw rehe uze'eg pà wà.
\q1 
\v 21 Uzemono'ono'og teko ikatu ma'e wama'e rehe umunar pà wà.
\q1 Umume'u teko ikatu 'ym ma'e iapo 'ymar wazuka àwàm wà no.
\q1 
\v 22 Tupàn Tuweharupi Wiko Ma'e hemunyryk kar heàmàtyry'ymar wanuwi.
\q1 Nuzawy kwaw itahu ihewe. Hemim ikatu 'ymaw wi.
\q1 
\v 23 Uzepyk putar tuwihaw ikatu 'ym ma'e wanehe nehe,
\q1 Ta'e uzapo ikatu 'ym ma'e teko wanupe wà xe.
\q1 Tupàn Tuweharupi Wiko Ma'e Zanezar umumaw putar a'e tuwihaw a'e wà nehe,
\q1 Wanemiapo kwer iaiw ma'e hekuzaromo a'e wà nehe.
\c 95
\s1 Zegar haw Tupàn ikatu haw imume'u haw
\q1 
\v 1 Pezur pe paw rupi ty wà. Ximume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe.
\q1 Zazegar zanerurywete haw rupi Tupàn itahu zanemimar zàwenugar pe nehe. Zanepyro a'e.
\q1 
\v 2 Zaha henataromo hemimur kwer ikatu haw imume'u pà nehe.
\q1 Ximuzàg zegar haw ikatu haw rehe har nehe,
\q1 
\v 3 ta'e Tuweharupi Wiko Ma'e wiko Tupàn ikàg ma'e romo a'e xe.
\q1 Wiko tuwihawete romo amogwer tupàn wanuwi upuner wera'u ma'e romo a'e.
\q1 
\v 4 Wiko ywy rehe har paw wazar romo.
\q1 Ywykwar oho etea'u ma'e izar romo hekon, ywytyruhu iaiha wera'u ma'e izar romo hekon no.
\q1 
\v 5 Wiko wemiapo kwer yryhu izar romo.
\q1 Wemiapo kwer ywy izar romo hekon no.
\b
\q1 
\v 6 Pezur nehe. Peapyk pepenàràg rehe Tupàn Tuweharupi Wiko Ma'e imuwete katu pà nehe.
\q1 Zapyk zanepenàràg rehe zaneapo arer henataromo nehe.
\q1 
\v 7 Wiko Tupàn Zanezar romo a'e.
\q1 Zaiko hemiaihu hemiruze'eg romo zane.
\q1 Zaiko heimaw àràpuhàràn ài izupe. Uzekaiw zanerehe.
\b
\q1 Peinu katu ize'eg kutàri kury.
\q1 
\v 8 — Peiko zo hereruzar katu har 'ym romo nehe.
\q1 Kwehe mehe peipy wiko hereruzar katu har 'ym romo Merima pe wà. Peiko zo wazàwe nehe.
\q1 Maxa ywy rehe ywyxiguhu rehe waneko mehe nuweruzar kwaw heze'eg wà. — Zeàmàtyry'ymaw, i'i Merima zaneze'eg rupi. — Puragaw paw, i'i Maxa zaneze'eg rupi.
\q1 
\v 9 Heragaw a'e pe wà. Nuzapo kwaw heremimutar wà.
\q1 Azapo ikatu ma'e tetea'u wanupe ihe. Nezewe rehe we nahereruzar kwaw wà.
\q1 
\v 10 A'e teko umumaw 40 kwarahy hemuikwahy kar pà wà.
\q1 A'e rupi aze'eg nezewe wanupe. — Teko hereruzar 'ymar wà.
\q1 Na'ipureruzar wer kwaw heze'eg rehe wà, a'e wanupe.
\q1 
\v 11 Aikwahy a'e mehe ihe. A'e rupi amume'uahy ko ma'e wanupe.
\q1 — Napeixe pixik kwaw ywy heremimume'u kwer rehe nehe.
\q1 Napepytu'u pixik kwaw a'e pe hepyr nehe, a'e wanupe.
\c 96
\s1 Tupàn, zanezar ikatu haw imume'u haw
\q1 
\v 1 Pemuzàg zegar haw ipyahu ma'e Tupàn Tuweharupi Wiko Ma'e pe nehe.
\q1 Pezegar Tuweharupi Wiko Ma'e pe nehe, teko ywy nànànar wà.
\q1 
\v 2 Pezegar Tuweharupi Wiko Ma'e pe nehe. Pemume'u her ikatu haw nehe.
\q1 Tuweharupi pemume'u zanepyro awer nehe.
\q1 
\v 3 Peze'eg ikàgaw rehe ipuràg eteahy haw rehe ywy nànànar wanupe nehe.
\q1 Pemume'u hemiapo kwer ikatuahy ma'e teko paw wanupe nehe.
\q1 
\v 4 Uhua'u Tupàn Tuweharupi Wiko Ma'e a'e. A'e rupi ximume'u ikatu haw nehe.
\q1 Tuwe teko ukyze wera'u izuwi amogwer tupàn wanuwi upaw rupi wà nehe,
\q1 
\v 5 Ta'e amo ywy rehe har umuwete ywyra tupàn a'ua'u romo iapo pyrer a'e wà xe.
\q1 Tupàn Tuweharupi Wiko Ma'e uzapo ywak a'e. Tupànete romo hekon a'e.
\q1 
\v 6 Ikàgaw ipuràg eteahy haw umàmàn izywyr.
\q1 Ipuner haw ipuràg eteahy haw umynehem hàpuzuhu.
\b
\q1 
\v 7 Pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe, teko ywy nànànar paw wà.
\q1 Pemume'u ikàgaw ipuràg eteahy haw nehe. Ipuner haw pemume'u nehe no.
\q1 
\v 8 Pemume'u ipuràg eteahy haw ikatu haw rehe we nehe.
\q1 Perur ma'e izupe imono pyràm nehe. Peixe katu ywy pehegwer hàpuzuhu huwake har pupe nehe.
\q1 
\v 9 Pezeamumew Tupàn Tuweharupi Wiko Ma'e ikatuahy ma'e henataromo nehe,
\q1 Izexak kar mehe nehe.
\q1 Peryryryryz henataromo nehe, ywy nànànar wà.
\b
\q1 
\v 10 Pe ywy nànànar, peze'eg nezewe nehe.
\q1 — Tupàn Tuweharupi Wiko Ma'e wiko tuwihawete romo a'e.
\q1 Umuàtà ywy henaw rehe kwehe mehe.
\q1 Ni amo nupuner kwaw imunyrykaw rehe henaw wi wà.
\q1 Umume'u katu teko wanemiapo kwer ukatu haw rupi nehe, peze nehe.
\q1 
\v 11 Nerurywete nehe, ywy. Nerurywete nehe, ywak.
\q1 Ekororo nehe, yryhu. Pekororo nehe, yryhu pupe har paw wà.
\q1 
\v 12 Penurywete nehe, ywy katu paw. Penurywete nehe, ywy katu haw pe har paw wà.
\q1 A'e mehe ywyra ka'a pe har uhapukaz putar Tupàn Tuweharupi Wiko Ma'e henataromo urywete romo wà nehe,
\q1 
\v 13 Ta'e ur putar Tupàn ywy nànànar waneruze'eg pà nehe xe.
\q1 Ukatu haw rupi weruze'eg putar wà nehe.
\q1 Uzepyk putar ikatu 'ym ma'e iapo har paw wanehe nehe, wapuner haw rehe wanemetarer rehe ume'e 'ym pà nehe, ywy rehe har waneruze'eg mehe nehe.
\c 97
\s1 Tupàn wiko ywy nànànar wazar romo a'e
\q1 
\v 1 Tupàn Tuweharupi Wiko Ma'e wiko tuwihawete romo a'e.
\q1 Nerurywete nehe, ywy. Penurywete nehe, yrypypo'o yryhu rehe har wà.
\q1 
\v 2 Heta ywàkun izywyr. Ipytunahy huwake.
\q1 Umuigo kar wemiruze'eg imunar 'ym ma'e romo hemu'em 'ym ma'e romo wà. Upureruze'eg ukatu haw rupi.
\q1 
\v 3 Amo tata oho henataromo a'e.
\q1 Wapy iàmàtyry'ymar izywyr har oho iko wà.
\q1 
\v 4 Hemiapo kwer àmàn iweraw paw uhyape katu ywy nànàn.
\q1 Ywy wexak iweraw paw. A'e rupi uryryryryz.
\q1 
\v 5 Ywytyr typyràn iraity ài Tupàn Tuweharupi Wiko Ma'e henataromo wà,
\q1 Ywy paw izar henataromo wà.
\q1 
\v 6 Ywak umume'u ikatu haw.
\q1 Teko ywy nànànar wexak ikàgaw ipuràg eteahy haw rehe we wà.
\b
\q1 
\v 7 Tupàn a'ua'u wanagapaw wamuwete har imaranugar wà.
\q1 Uzar tupàn a'ua'u wanagapaw wanehe uze'egatu ma'e imaranugar wà.
\q1 Amogwer tupàn paw uzeamumew Tupàn Tuweharupi Wiko Ma'e henataromo wà.
\q1 
\v 8 Teko Zeruzarez tawhu pe har hurywete wà.
\q1 Teko tawhu Zuta ywy rehe har pe har hurywete wà no,
\q1 Ta'e eremume'u katu teko wanemiapo kwer ne xe, o Tupàn Tuweharupi Wiko Ma'e.
\q1 
\v 9 O Tupàn Tuweharupi Wiko Ma'e, Ywate Wera'u Har, ereruze'eg teko ywy nànànar wanereko ne wà.
\q1 Ereiko amogwer tupàn wa'aromo ne.
\b
\q1 
\v 10 Tupàn Tuweharupi Wiko Ma'e uzamutar katu ikatu 'ymaw rehe iakatuwawahy 'ym ma'e a'e wà.
\q1 Uzekaiw wemiaihu wanehe wamàno haw wi wapyro pà.
\q1 Upyro ikatu 'ym ma'e wakàgaw wi wà.
\q1 
\v 11 Tupàn ikatu haw tatainy zàwenugar uhyape katu imunar 'ym ma'e wanehe, hemu'em 'ym ma'e wanehe.
\q1 Turywete haw uhyape katu ikatu ma'e wanape ràm.
\q1 
\v 12 Amo teko weruzar katu Tupàn a'e wà. Tuwe Tupàn Tuweharupi Wiko Ma'e wiko wanurywete haw romo nehe.
\q1 Tuwe teko umume'u Tupàn imonokatu pyrer ikatu haw wà nehe.
\c 98
\s1 Tupàn weityk wàmàtyry'ymar paw ukàgaw rupi a'e
\q1 
\v 1 Pemuzàg amo zegar haw ipyahu ma'e Tupàn Tuweharupi Wiko Ma'e pe nehe,
\q1 Ta'e uzapo ikatuahy ma'e a'e xe.
\q1 Weityk wàmàtyry'ymar paw
\q1 Ukàgaw rupi upuner haw ikatu ma'e rupi a'e wà.
\q1 
\v 2 Tupàn Tuweharupi Wiko Ma'e umume'u wàmàtyry'ymar waneityk awer. Upuner teko wapyro haw rehe a'e.
\q1 Ukwaw kar upuner haw teko ywy nànànar wanupe.
\q1 
\v 3 Upuruamutar katu a'e. Nutyryk kwaw wemiaihu wanuwi.
\q1 A'e rupi uzapo ma'e uze'eg Izaew wanupe imume'u pyrer rupi katete a'e.
\q1 Te ywy muite wera'u ma'e rehe har wexak Tupàn Zanezar wàmàtyry'ymar waneityk awer wà.
\b
\q1 
\v 4 Pezegar Tupàn Tuweharupi Wiko Ma'e pe penurywete haw rupi nehe, teko ywy nànànar wà.
\q1 Pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe, zegar haw wamuzàg pà nehe, penurywete haw rupi penehapukaz pà nehe.
\q1 
\v 5 Pemuzàg zegar haw Tupàn Tuweharupi Wiko Ma'e ikatu haw rehe har nehe, wioràwiràn imupu pà nehe.
\q1 Pemupu wioràwiràn irir her ma'e pezegar mehe nehe.
\q1 
\v 6 Pexi'àm pezupy nehe. Pezupy tapi'ak i'ak kwer xi'àm romo iapo pyrer nehe.
\q1 Pezegar penurywete haw rupi Tupàn Tuweharupi Wiko Ma'e Zaneruwihawete henataromo nehe.
\b
\q1 
\v 7 Eànoànog nehe, yryhu. Pekororo nehe, yryhu pupe har paw wà.
\q1 Ezegar nehe, ywy. Pezegar nehe, ywy rehe har paw wà.
\q1 
\v 8 Pezepopetepetek nehe, yrykawhu.
\q1 Ywytyr, pezegar penurywete haw rupi Tupàn Tuweharupi Wiko Ma'e henataromo nehe,
\q1 
\v 9 Ta'e ur putar ywy rehe har waneruze'eg pà a'e nehe xe.
\q1 Weruze'eg putar ywy nànànar ukatu haw rupi nehe.
\q1 Waneruze'egaw ikatuahy putar nehe.
\c 99
\s1 Tupàn wiko tuwihawete ikàg wera'u ma'e romo a'e
\q1 
\v 1 Tupàn Tuweharupi Wiko Ma'e wiko tuwihawete romo a'e.
\q1 Teko uryryryryz wà.
\q1 Wapyk wenaw kerumin wa'aromo har rehe.
\q1 Ywy uryryryryz.
\q1 
\v 2 Tupàn Tuweharupi Wiko Ma'e ikàg Zeruzarez tawhu pupe.
\q1 Weruze'eg teko ywy nànànar wanereko wà.
\q1 
\v 3 Tuwe teko paw umume'u ikatu haw nehe, ta'e uhua'u a'e xe.
\q1 Her purumukyze kar har rehe uze'eg putar wà nehe.
\q1 Tupàn Tuweharupi Wiko Ma'e wiko imonokatu pyrer romo a'e.
\b
\q1 
\v 4 O tuwihawete ikàg ma'e, erezamutar katu ikatu haw ne.
\q1 Eremur nekatu haw Izaew wanupe.
\q1 Ereruze'egatu kar teko tuwihaw wanupe ne wà. Neremu'emu'em kar kwaw a'e tuwihaw ne wà. Neremumunar kar kwaw ne wà no.
\q1 
\v 5 Pemume'u Tuweharupi Wiko Ma'e Zanezar ikatu haw nehe.
\q1 Peapyk pepenàràg rehe henaw henataromo nehe,
\q1 Ta'e imonokatu pyrer romo hekon a'e xe.
\b
\q1 
\v 6 Moizez wiko xaxeto romo Tupàn henataromo Àràw rehe we a'e.
\q1 Xamuew umuwete katu Tupàn a'e no.
\q1 Uze'eg Tupàn Tuweharupi Wiko Ma'e pe wà. Uwazar waze'eg wanupe a'e.
\q1 
\v 7 Ywàkun upu'àm ma'e pupe wiko mehe uze'eg Izaew wanupe kwehe mehe.
\q1 Izaew weruzar ize'eg wà. Weruzar hemiapo putar haw wà. A'e 'ym mehe Tupàn omono a'e ze'eg Izaew wanupe.
\b
\q1 
\v 8 O Tuweharupi Wiko Ma'e urezar. Erewazar neremiaihu waze'eg wanupe.
\q1 Teko wanemiapo kwer ikatu 'ym ma'e imunànar romo nereko haw erexak kar purupe.
\q1 Erexak kar teko wanehe nezepykaw wanemiapo kwer ikatu 'ym ma'e hekuzaromo no.
\q1 
\v 9 Pemume'u Tupàn Tuweharupi Wiko Ma'e Zanezar ikatu haw nehe.
\q1 Pemuwete katu henaw ywytyr imonokatu pyrer rehe har huwake nehe no,
\q1 Ta'e Tupàn Tuweharupi Wiko Ma'e, Zanezar, imonokatu pyrer romo hekon a'e xe.
\c 100
\s1 Tupàn ikatu haw rehe zegar haw
\q1 
\v 1 Pemuzàg zegar haw Tupàn Tuweharupi Wiko Ma'e pe nehe,
\q1 Ywy nànànar wà.
\q1 
\v 2 Pemuwete katu Tupàn Tuweharupi Wiko Ma'e penurywete haw rupi nehe.
\q1 Pezegar pezuwà henataromo nehe.
\q1 
\v 3 Pema'enukwaw Tuweharupi Wiko Ma'e rehe nehe, Zanezar romo heko haw rehe nehe.
\q1 Zaneapo a'e. Zanezar romo hekon.
\q1 Zaiko hemiaihu romo. Zaiko àràpuhàràn hemimono'og ài. Wiko zanemono'ogar ài a'e.
\q1 
\v 4 Peixe tàpuzuhu hukenaw wanupi Tupàn hemimur kwer ikatu haw imume'u pà nehe.
\q1 Peixe tàpuzuhu izywyr katu haw rehe ikatu haw imume'u pà nehe.
\q1 Pemume'u Tupàn ikatu haw nehe. Pemume'u hemimur kwer ikatu haw izupe nehe no.
\q1 
\v 5 Tupàn Tuweharupi Wiko Ma'e ikatuahy a'e.
\q1 Ipuruamutar katu haw nupaw pixik kwaw nehe.
\q1 Nutyryk pixik kwaw puruwi nehe.
\c 101
\s1 Tuwihawete umume'u wemiapo ràm Tupàn pe
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 Azegar Tupàn puruwi ipuir 'ymaw rehe. Azegar ikatu haw rehe no.
\q1 Amuzàg zegar haw newe, o Tupàn Tuweharupi Wiko Ma'e.
\q1 
\v 2 Hepureruze'eg mehe naheremu'em kwaw ihe nehe, nahemunar kwaw ma'e rehe nehe.
\q1 Màràn mehe erezur putar heàwàxi pà nehe.
\b
\q1 Aiko putar ikatu ma'e romo heràpuz me nehe.
\q1 
\v 3 Namuixe kar pixik kwaw ikatu 'ymaw nehe.
\q1 Naheakatuwawahy kwaw teko Tupàn wi utyryk ma'e kwer wanemiapo kwer rehe ihe.
\q1 Nazapo kwaw ikatu 'ym ma'e wainuromo nehe.
\q1 
\v 4 Amunyryk kar putar ma'e rehe imunar haw rehe hema'enukwaw paw hezewi nehe, heremu'emaw rehe hema'enukwaw paw hezewi nehe.
\q1 Napokok pixik kwaw ikatu 'ymaw rehe nehe.
\q1 
\v 5 Amumaw putar amogwer wanehe wakupe kutyr uze'eg zemueteahy ma'e ihe wà nehe. Namuigo kar kwaw amo wanuwi wiko wera'u ma'e herenataromo ihe wà nehe.
\q1 Ikàg ma'e ikatu 'ym ma'e nuhem kwaw heruwake wà nehe.
\q1 
\v 6 Aputar Tupàn rehe uzeruzar tuwe ma'e ihe wà.
\q1 Amuigo kar putar heràpuzuhu pe wà nehe.
\q1 Ikatu ma'e romo wiko ma'e upuner putar ihewe uma'ereko haw rehe wà nehe.
\b
\q1 
\v 7 Ni amo hemu'em ma'e nuiko kwaw heràpuzuhu pupe wà nehe.
\q1 Ni amo ikatu ma'e romo wiko mua'u ma'e nuiko kwaw herenataromo wà nehe.
\q1 
\v 8 'Ar nànàn amumaw putar zaneywy rehe har ikatu 'ym ma'e ihe wà nehe.
\q1 Amuhem kar putar ikatu 'ym ma'e iapo har paw tawhu Tupàn Tuweharupi Wiko Ma'e henaw wi ihe wà nehe.
\c 102
\s1 Awa ma'erahy ipuraraw par uze'eg Tupàn pe
\q1 
\v 1 O Tupàn Tuweharupi Wiko Ma'e, einu newe heze'egaw nehe.
\q1 Herenu pe newe herehapukaz mehe nehe, hepytywà àwàm henoz mehe nehe.
\q1 
\v 2 Ezeàmim zo ihewi
\q1 Ma'erahy ipuraraw mehe nehe.
\q1 Herenu pe newe heze'eg mehe nehe.
\q1 Na'arewahy ewazar heze'eg ihewe nehe.
\b
\q1 
\v 3 Hereko haw ukàzym iko tàtàxiner ài.
\q1 Heretekwer ukaz iko tata pupe har ài.
\q1 
\v 4 Aiko ka'api'i imonohok pyrer imuku'iku'i pyrer ài. Uhem hekàgaw ihewi paw rupi.
\q1 Nahemai'u wer kwaw.
\q1 
\v 5 Hekuhemahy iteko.
\q1 Xo hepir zo, xo hekàgwer zo heta ihewe. Hero'o kwer upaw.
\q1 
\v 6 Aiko wiràmiri hehaite ma'e ywyxiguhu rehe har ài.
\q1 Aiko pypy tàpuz teko heta 'ymaw pe har ài.
\q1 
\v 7 Napuner kwaw heker haw rehe.
\q1 Aiko wiràmiri tàpuz 'aromo har imyrypar 'ym ma'e ài.
\q1 
\v 8 Heàmàtyry'ymar umumaw 'ar katu herehe uze'eg zemueteahy pà wà.
\q1 Herehe uze'eg urywahyahy ma'e a'e wà, umume'u herer a'e wà, iaiw paw purehe imono mehe a'e wà.
\q1 
\v 9-10 Erekwahy ihewe ne.
\q1 Herehe wikwahy ma'e romo ereiko ne.
\q1 A'e rupi tàtàpyzgwer uzeapo heremi'u ràm romo.
\q1 Herehaykwer wixe heremi'u ràm inuinuromo, ta'e hepyhyk pe muite hereityk pà ne xe.
\q1 
\v 11 Hereko haw nuzawy kwaw ma'e 'àg kwarahy heixe mehe har.
\q1 Aiko ka'api'i uxinixinig ma'e ài.
\q1 
\v 12 Ne Tupàn Tuweharupi Wiko Ma'e ereiko putar tuwihawete romo tuweharupi nehe.
\q1 Teko wiko ma'e ràm wà, ima'enukwaw putar nerehe wà nehe.
\q1 
\v 13 Erepu'àm putar Zeruzarez ipuhareko pà nehe.
\q1 Ipuhareko haw 'ar uhem kwez kury.
\q1 'Ar ikatu ma'e uhem tuwe kwez kury.
\q1 
\v 14 Amo weityk tawhu imumaw pà wà.
\q1 Nezewe rehe we neremiruze'eg uzamutar Zeruzarez wà.
\q1 Amo uzukazuka wà,
\q1 Nezewe rehe we upuhareko wà.
\q1 
\v 15 Teko ywy nànànar ukyze putar Tupàn Tuweharupi Wiko Ma'e wi wà nehe.
\q1 Tuwihawete ywy nànànar ukyze putar ikàgaw wi wà nehe.
\q1 
\v 16 Tupàn Tuweharupi Wiko Ma'e uzapo wi putar Zeruzarez a'e nehe.
\q1 A'e 'ar mehe wexak kar putar ukàgaw upuràg eteahy haw paw nehe.
\q1 
\v 17 Wenu putar wemiaihu heityk pyrer wà nehe.
\q1 Uzeapyaka putar izupe waze'eg mehe wà no.
\b
\q1 
\v 18 Tuwe ko ze'eg uzemuapyk pape rehe nehe.
\q1 Nezewe mehe zanezuapyapyr ukwaw putar Tupàn Tuweharupi Wiko Ma'e hemiapo kwer wà nehe.
\q1 Nezewe mehe uzexak kar ma'e ràm umume'u putar ikatu haw a'e wà nehe no.
\q1 
\v 19 Tupàn Tuweharupi Wiko Ma'e ume'e ywy rehe wenaw ywate har imonokatu pyrer rehe wapyk mehe.
\q1 Ywak rehe wiko mehe ume'e ywy rehe.
\q1 
\v 20 Wenu imunehew pyrer wakuhem mehe wà.
\q1 Zaneàmàtyry'ymar umume'u amo zaneànàm wamàno àwàm wà. Tupàn upyro a'e izuka pyràm wà.
\q1 
\v 21 A'e rupi teko Zeruzarez pe har umume'u putar Tupàn ikatu haw wà nehe.
\q1 Umume'u putar her a'e pe wà nehe.
\q1 
\v 22 Teko ywy nànànar a'e wà nehe, wanuwihaw a'e wà nehe no, uzemono'og putar a'e pe imuwete katu pà a'e wà nehe.
\q1 
\v 23 Kwàkwàmo romo aikuwe ihe rihi. Nezewe rehe we Tupàn o'ok hekàgaw ihewi.
\q1 Umuaikwera'i kar hereko haw ihewi.
\q1 
\v 24 O hezar, hereraha zo pe kury.
\q1 Xo hereko haw iku'aw har zo amumaw.
\q1 Hezar, ereikuwe putar tuweharupi nehe.
\q1 
\v 25 Izypy mehe erezapo ywy.
\q1 Nepo pupe erezapo ywak.
\q1 
\v 26 Ywy a'e nehe, ywak a'e nehe no, upaw putar a'e wà nehe.
\q1 Ne nerepaw pixik kwaw nehe.
\q1 Ywy ywak izemàner putar kamir ài wà nehe.
\q1 Aze kamir owok, xityk.
\q1 Nezewegatete ereityk putar ywy ywak ne wà nehe no.
\q1 
\v 27 Nerezeapo pixik kwaw amo ae ma'e romo. Tuweharupi ereiko nezàwegatete.
\q1 Nereko haw nupaw pixik kwaw nehe.
\q1 
\v 28 Zanera'yr wiko putar ikatu 'ym ma'e wi ukyze 'ym pà wà nehe.
\q1 Erezekaiw putar wazuapyapyr wanehe tuweharupi ne wà nehe.
\c 103
\s1 Tupàn ikatu haw rehe zegar haw
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 O Tupàn Tuweharupi Wiko Ma'e. Tuwe hepy'a umume'u tuwe nekatu haw nehe.
\q1 Tuwe amume'u Tupàn ikatuahy haw hekàgaw nànàn nehe.
\q1 
\v 2 Tuwe hepy'a paw umume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe.
\q1 Tuwe nahereharaz kwaw ni pitài teko wanehe ize'egatu wi nehe.
\q1 
\v 3 Tupàn Tuweharupi Wiko Ma'e umunàn heremiapo kwer ikatu 'ym ma'e paw a'e.
\q1 Hemukatu hema'eahy haw nànàn no.
\q1 
\v 4 Hepyro hemàno haw wi.
\q1 Umur uze'egatu herehe heamutar katu pà, ikatu ma'e ihewe imur pà no.
\q1 
\v 5 Hemurywete kar ikatu ma'e tetea'u imur pà ihewe.
\q1 A'e rupi aikuwe kwàkwàmo ài. Hekàg wiràhu ài.
\b
\q1 
\v 6 Upureruze'eg mehe Tupàn Tuweharupi Wiko Ma'e upuhareko temetarer 'ym ma'e wà.
\q1 Numumunar kar kwaw amo teko a'e teko wama'e rehe wà.
\q1 
\v 7 Kwehe mehe umume'u wemiapo ràm Moizez pe.
\q1 Wexak kar wemiapo ikàg ma'e teko Izaew wanupe no.
\q1 
\v 8 Tupàn Tuweharupi Wiko Ma'e ikatuahy a'e.
\q1 Upurupuhareko a'e no. Iàrew purupe ikwahy haw. Upuruamutar katu no.
\q1 
\v 9 Nuiko kwaw tuweharupi zaneremiapo kwer ikatu 'ym ma'e imume'u pà a'e.
\q1 Ikwahy haw upaw putar amo 'ar mehe nehe.
\q1 
\v 10 Xiapo ikatu 'ym ma'e zane. Nezewe rehe we Tupàn Tuweharupi Wiko Ma'e nuzepyk kwaw zanerehe a'e, ikatu 'ym ma'e iapo har wanehe uzepykaw zàwe a'e.
\q1 Numekuzar kwaw zaneremiapo kwer ikatu 'ym ma'e zanerehe uzepykaw pupe a'e.
\q1 
\v 11 Ywak muitea'u ywy 'aromo tuz a'e.
\q1 Nezewegatete izuwi ukyze ma'e wamutar katu haw uhua'u wera'u wanemiapo kwer ikatu 'ym ma'e wi a'e no.
\q1 
\v 12 Kwarahy ihemaw muitea'u heixe haw wi a'e.
\q1 Nezewegatete umunyryk kar zaneremiapo kwer ikatu 'ym ma'e muitea'u zanewi a'e no.
\q1 
\v 13 Awa wereko katu tuwe wa'yr wà.
\q1 Nezewegatete Tupàn Tuweharupi Wiko Ma'e wereko katu tuwe izuwi ukyze ma'e wà no.
\q1 
\v 14 Ukwaw zaneapo awer a'e xe.
\q1 Ima'enukwaw ywyku'i romo zanereko haw rehe.
\b
\q1 
\v 15 Zanereko haw nuzawy kwaw ka'api'i.
\q1 Hezuz a'e. Iputyr ka'akyr kaiwer pe har ài.
\q1 
\v 16 Na'e ur ywytu kury. Ukàzym iputyr.
\q1 A'e re ni amo nuexak pixik kwaw iputyr kwer wà nehe.
\q1 
\v 17 Aze teko umuwete katu Tupàn Tuweharupi Wiko Ma'e izuwi ukyze katu pà wà, Tupàn uzamutar katu a'e teko a'e wà. Wamutar katu haw nupaw pixik kwaw nehe.
\q1 Tupàn ikatu haw nupaw pixik kwaw nehe.
\q1 Omono wana'yr wanupe. Omono wa'yr wapurumuzàmuzàg wanupe no.
\q1 
\v 18 Omono putar teko wanupe nehe, ze'eg awer Tupàn rehe we iapo katu pyrer heruzar har wanupe nehe.
\q1 Weruzar katu ize'eg wà.
\b
\q1 
\v 19 Tupàn Tuweharupi Wiko Ma'e umuapyk katu wenaw ywak rehe. Tuwihawete romo hekon a'e.
\q1 Weruze'eg teko paw a'e wà, ma'e paw a'e wà.
\q1 
\v 20 Pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe, heko haw pe har ikàg ma'e wà, heko haw pe har upuner ma'e wà.
\q1 Peinu katu ize'eg mehe.
\q1 Peruzar ize'eg no.
\q1 
\v 21 Pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe, heko haw pe har ywate har paw wà,
\q1 Hemiruze'eg wà, hemiapo putar haw iapo har wà.
\q1 
\v 22 Pemume'u Tuweharupi Wiko Ma'e ikatu haw nehe,
\q1 Wikuwe ma'e paw wà, ipureruze'egaw nànànar wà.
\q1 O herekwe, emume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe.
\c 104
\s1 Zaneapo har ikatu haw rehe zegar haw
\q1 
\v 1 O Tupàn Tuweharupi Wiko Ma'e, tuwe hepy'a umume'u nekatu haw nehe.
\q1 O Tuweharupi Wiko Ma'e Hezar, nehua'u ne.
\q1 Eremunehew nekàgaw kamir ài. Eremunehew nepuner haw nepuràg eteahy haw rehe we no, neremyhar ài no.
\q1 
\v 2 Erezepyk tatainy pupe.
\q1 Eremuapyk ywak neràpuzràn ài.
\q1 
\v 3 Erezapo neràpuz 'y ywate har rehe.
\q1 Ereata ywàkun rehe ywyramawa zeàmàtyry'ymawhu pe har ài.
\q1 Erewewe ywytu nepepo romo iapo pà.
\q1 
\v 4 Emuigo kar ywytu neze'eg purupe heraha har romo.
\q1 Erezapo àmàn iweraw paw neremiruze'eg romo no.
\b
\q1 
\v 5 Eremuapyk katu ywy iwy pe har i'aromo.
\q1 A'e rupi ni amo numunyryk pixik kwaw henaw wi wà nehe.
\q1 
\v 6 Teko upyk ma'e zewàwànaw pupe wà.
\q1 Nezewegatete erepyk ywy yryhu pupe.
\q1 'Y upyta ywytyruhu 'aromo.
\q1 
\v 7 Neze'egahy henu mehe 'y uhem a'e wi.
\q1 Imono kar mehe uzàn oho a'e wi.
\q1 
\v 8 'Y uwyryk oho ywytyr wamyteromo.
\q1 Wezyw ywyàpyznaw rupi no,
\q1 Weko àwàm neremimuàgy'ygwer pe no.
\q1 
\v 9 — Eixe zo pe pe nehe, ere 'y pe.
\q1 Nezewe mehe nupyk wi kwaw ywy.
\b
\q1 
\v 10 Erezapo ytyzuzàmaw ywyàpyznaw wanehe wà.
\q1 Eremuyryk kar yrykawhu ywytyr wamyteromo.
\q1 
\v 11 Miar paw uwi'u a'e 'y pupe wà.
\q1 Zumen hehaite ma'e uwi'u wà. Uhyk wanupe.
\q1 
\v 12 Yrykaw iwy rehe wiràmiri uzapo waity wà.
\q1 Uzegar ywyra hàkà rehe wà.
\b
\q1 
\v 13 Eremugyr kar àmàn ywak wi ywytyr rehe.
\q1 Tynehem ywy neremimur kwer ikatu ma'e pupe.
\q1 
\v 14 Eremuezuz ka'api'i tapi'ak wanupe.
\q1 Eremuezuz arozràn purupe amo wanemi'u ràm inuinuromo.
\q1 A'e rupi teko omono'og wemi'u ràm ywy wi wà.
\q1 
\v 15 Eremuezuz kar ma'e ywy wi ne. Teko uzapo ma'ywa uwà her ma'e wà, win romo iapo pà wà. Hurywete i'u mehe wà.
\q1 Omono'og uri kawer wà. Upurumurywete kar a'e.
\q1 Uzapo arozràn wà, typy'ak romo iapo pà wà. Ikàg i'u mehe wà.
\q1 
\v 16 Àmàn tetea'u ukyr ywyra Tupàn Tuweharupi Wiko Ma'e hemiapo kwer rehe.
\q1 Ukyr ywyràkàxigyw Irimano ywy rehe har Tupàn hemitygwer rehe no.
\q1 
\v 17 Wiràmiri uzapo waity hehe wà.
\q1 Kàràw uzapo weko haw ywyra pin 'yw her ma'e rehe wà.
\q1 
\v 18 Àràpuhàrànete hehaite ma'e wiko ywytyruhu apyr wà.
\q1 Tapixi uzeàmim itahu kwar pupe wà.
\b
\q1 
\v 19 Erezapo zahy ne. Uhyahu u'ar katu mehe.
\q1 Kwarahy ukwaw u'ar mehe wixe haw no.
\q1 
\v 20 Erezapo pytun no.
\q1 Miar hehaite ma'e paw uhem wà pyhaw wà.
\q1 
\v 21 Zàwàruhu iriàw ipyahu ma'e okororo wemi'u ràm hekar mehe wà.
\q1 Wekar wemi'u ràm Tupàn hemimur kwer oho waiko wà.
\q1 
\v 22 Kwarahy ihem mehe uzewyr oho wà.
\q1 U'aw oho weko haw pe wà.
\q1 
\v 23 Na'e teko uma'ereko oho wà.
\q1 Xo kwarahy heixe etea'i mehe upytu'u wà.
\b
\q1 
\v 24 O Tupàn Tuweharupi Wiko Ma'e, erezapo ma'e tetea'u ne wà.
\q1 Nema'ekwaw katu haw rupi erezapo ne wà.
\q1 Ywy tynehem neremiapo kwer wapupe a'e.
\q1 
\v 25 Pe pe tuz yryhu no. Uhua'u tuwe a'e.
\q1 Ma'ea'yr uhua'u ma'e wiko ipupe wà. Pixika'i ma'e wiko ipupe wà no.
\q1 Teko nupuner kwaw wapapar haw rehe wà, ta'e heta tetea'u tuwe a'e wà xe.
\q1 
\v 26 Kanuhu wata oho waiko yryhu rehe wà. Pirahu àzàg zàwenugar Erewiàtà her ma'e uzemaraz ipupe no.
\q1 'Y pe har uhua'u ma'e neremiapo kwer romo a'e.
\q1 
\v 27 A'e ma'ea'yr paw neràro wà,
\q1 Ta'e eremono wanemi'u wanupe 'ar katu mehe ne xe.
\q1 
\v 28 Eremono wanemi'u ràm wanupe.
\q1 U'u wà. Uhyk wanupe wà.
\q1 
\v 29 Neruwa imim mehe ukyze wà.
\q1 Wapytuhem ire wamupytu'u kar mehe, umàno a'e wà.
\q1 Uzewyr ywyku'i romo weko haw pe wà. Kwehe mehe wiko ywyku'i romo wà. Uzewyr wi putar a'e pe wà nehe no.
\q1 
\v 30 Aze eremupytuhem kar ne wà, uzexak kar wà.
\q1 Nezewe mehe eremono ma'e wikuwe ma'e ipyahu ma'e ywy rehe ne wà.
\b
\q1 
\v 31 Tuwe Tupàn Tuweharupi Wiko Ma'e ikàgaw nupaw kwaw nehe. Tuwe ipuràg eteahy haw uhyape katu tuweharupi nehe.
\q1 Tuwe hurywete wemiapo kwer rehe nehe.
\q1 
\v 32 Tupàn Tuweharupi Wiko Ma'e ume'e ywy rehe. Ywy uryryryryz a'e.
\q1 Opokok ywytyr wanehe. Uhem tàtàxiner wanuwi.
\b
\q1 
\v 33 Amuzàg putar zegar haw Tupàn Tuweharupi Wiko Ma'e ikatu haw rehe herekwe mehe we ihe nehe.
\q1 Amumaw putar he'ar paw hezar pe hezegar pà nehe.
\q1 
\v 34 Tuwe Tuweharupi Wiko Ma'e hurywete hezegar haw henu mehe nehe,
\q1 Ta'e herurywete haw ur izuwi a'e xe.
\q1 
\v 35 Tuwe teko Tupàn rehe ipurukwaw wer 'ym ma'e ukàzym ywy wi a'e wà nehe.
\q1 Tuwe ikatu 'ym ma'e iapo har upytu'u weko re wà nehe. Tuwe hepy'a umume'u nekatu haw nehe, o Tupàn Tuweharupi Wiko Ma'e.
\b
\q1 Pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe.
\q1 Azeharomoete.
\c 105
\s1 Tupàn, hemiaihu wà no
\q1 
\v 1 Pemume'u Tupàn Tuweharupi Wiko Ma'e hemimur kwer ikatu haw izupe nehe.
\q1 Uhua'u haw pemume'u nehe.
\q1 Pemume'u hemiapo kwer teko ywy nànànar wanupe nehe.
\q1 
\v 2 Pezegar Tupàn pe nehe. Pemuzàg zegar haw izupe ikatu haw rehe nehe.
\q1 Peze'eg hemiapo kwer ikatuahy ma'e rehe nehe.
\q1 
\v 3 Penurywete her ikatu ma'e rehe nehe.
\q1 Tuwe Tupàn Tuweharupi Wiko Ma'e imuwete katu har paw hurywete wà nehe.
\q1 
\v 4 Pekar pepytywà àwàm Tupàn inuromo nehe.
\q1 Peiko inuromo tuweharupi nehe.
\q1 
\v 5-6 Pe Àmàrààw Tupàn hemiruze'eg izuapyapyr pe,
\q1 Pe Zako Tupàn hemixak kwer izuapyapyr paw pe,
\q1 Pema'enukwaw Tupàn hemiapo kwer wanehe upaw rupi nehe.
\q1 Uzapo purumupytuhegatu kar awer uhua'u ma'e. Uzapo purumupytuhegatu kar awer ikatuahy ma'e.
\q1 Umume'u zaneàmàtyry'ymar wanehe zepyk àwàm no.
\q1 
\v 7 Wiko Tuweharupi Wiko Ma'e romo Tupàn Zanezar romo a'e.
\q1 Teko ywy nànànar ukwaw hemiapo putar haw wà.
\q1 
\v 8 Tuweharupi ima'enukwaw putar uze'eg awer iapo katu pyrer rehe nehe.
\q1 Uzapo putar wemimume'u kwer teko wanupe a'e nehe, wana'yr wanupe a'e nehe no, wana'yr wazuapyapyr wanupe a'e nehe no.
\q1 
\v 9 Uzapo putar ma'e uze'egaw Àmàrààw rehe we iapo katu pyrer rupi katete nehe.
\q1 Umume'uahy wemiapo ràm Izak pe. Uzapo putar a'e ma'e nehe no.
\q1 
\v 10 Uzapokatu uze'egaw Zako rehe we
\q1 Tuweharupi àràm a'e no.
\q1 
\v 11 A'e 'ar mehe uze'eg Tupàn nezewe a'e.
\q1 — Amono putar Kànàà ywy newe nehe.
\q1 Tuweharupi ereiko putar izar romo nehe, i'i izupe.
\b
\q1 
\v 12 Tupàn hemiaihu naheta tete kwaw a'e 'ar mehe wà.
\q1 Wiko amo ae ywy rehe arer romo ywy imume'u pyrer rehe wixe mehe wà.
\q1 
\v 13 Wata oho waiko màràmàràn ywy rehe wà.
\q1 Ukwaw oho waiko màràmàràn tuwihawete wapureruze'egaw wanupi wà.
\q1 
\v 14 — Pezapo zo ikatu 'ym ma'e heremiaihu wanupe nehe, i'i a'e tuwihawete wanupe.
\q1 Uzepyk amo tuwihawete wanehe, ta'e upuraraw kar ma'erahy hemiaihu wanupe wà xe.
\q1 
\v 15 Uze'eg nezewe wanupe. — Pepokok zo heremiruze'eg heremixamixak kwer wanehe nehe.
\q1 Pepuraraw kar zo ma'erahy heze'eg imume'u har wanupe nehe, i'i wanupe.
\q1 
\v 16 Umur kar ma'uhez haw uhua'u ma'e ywy imume'u pyrer rehe har wanupe.
\q1 Wezar wemiaihu temi'u 'ym wà.
\q1 
\v 17 Na'e omono kar amo awa Zuze her ma'e a'e teko wanenataromo a'e.
\q1 A'e 'ym mehe tyky'yr ume'eg Zuze uma'ereko e ma'e romo amo awa amo ae ywy rehe har wanupe wà.
\q1 
\v 18 Uzàpixipixi ipy kyhàhàmtàtà pupe zemunehew paw pe imono mehe wà.
\q1 Omono tàtà ma'e ita per iapo pyrer iazu'yw rehe wà.
\q1 
\v 19 Umume'u Zuze uzeapo ma'e ràm a'e. Xo a'e ma'e izeapo re zo uhem zemunehew paw wi.
\q1 Tupàn Tuweharupi Wiko Ma'e ze'eg wexak kar Zuze ikatu haw.
\q1 
\v 20 A'e rupi Ezit ywy rehe har wanuwihawete umuhem kar Zuze zemunehew paw wi zauxiapekwer wanupe.
\q1 Ywy tetea'u rehe har wanuwihawete umuigo kar imunehew pyr 'ym romo wà kury.
\q1 
\v 21 Umuigo kar a'e ywy rehe har paw waneruze'egar romo.
\q1 Wiko Ezit ywy rehe har paw wanuwihaw romo.
\q1 
\v 22 Tuwihawete umur upuner haw Zuze pe. — Erepuner amogwer tuwihaw wanupe ma'e iapo kar haw rehe nehe, i'i izupe.
\q1 — Erepuner amogwer pureruze'eg ma'e waneruze'egaw rehe nehe no, i'i izupe.
\b
\q1 
\v 23 A'e re Zako Zuze tu oho Ezit pe.
\q1 Upyta a'e ywy rehe wiko pà.
\q1 
\v 24 Tupàn Tuweharupi Wiko Ma'e umuzàg kar ta'yr tetea'u wemiaihu wanupe wà.
\q1 A'e rupi ikàg wera'u wàmàtyry'ymar wanuwi wà.
\q1 
\v 25 Uma'ereko Ezit ywy rehe har wapy'a pe. A'e rupi na'iakatuwawahy kwaw Tupàn hemiaihu wanehe wà.
\q1 Umuemu'em kar Ezit ywy rehe har Izaew Tupàn hemiruze'eg wanupe wà no.
\b
\q1 
\v 26 Na'e omono kar Tupàn wemiruze'eg Moizez Ezit ywy rehe har wanuwihawete pe kury.
\q1 Omono kar tyky'yr wemixak kwer Àràw hupi no.
\q1 
\v 27 Uzapo purumupytuhegatu kar haw Ezit ywy rehe wà.
\q1 Uzapo ikatuahy ma'e a'e pe wà.
\q1 
\v 28 Na'e umupytunahy kar Tupàn ywy.
\q1 Nezewe rehe we Ezit ywy rehe har nuweruzar kwaw ize'eg wà.
\q1 
\v 29 Yrykawhu uzapo ma'eruwy kwer romo.
\q1 Uzuka pira paw wà.
\q1 
\v 30 Tynehem Ezit ywy zu'i pupe.
\q1 Te tuwihawete hàpuzuhu pupe wixe wà.
\q1 
\v 31 Uze'eg Tupàn wanupe.
\q1 Na'e meru tetea'u a'e wà, kyw tetea'u a'e wà no, umynehem a'e ywy paw uzepupe a'e wà kury.
\q1 
\v 32 Numugyr kar kwaw àmàn. Umugyr kar àmàn ita romo iapo pyrer. Uweraweraw a'e ywy rehe.
\q1 
\v 33 Umumaw Tupàn uwà tyw. Ma'ywa pi her ma'e tyw umumaw no.
\q1 Weityk ywyra paw wà.
\q1 
\v 34 Uze'eg wi Tupàn. A'e rupi ur tukur tetea'u wà kury.
\q1 Teko nupuner kwaw wapapar haw rehe wà, ta'e heta tetea'u wà xe.
\q1 
\v 35 Tukur u'u ma'e itym pyrer Ezit ywy rehe har paw rupi wà.
\q1 U'u temi'u ipo'o pyrer imono'og pyrer paw wà.
\q1 
\v 36 — Ikatuahy zanera'yr ipy wà, i'i Ezit ywy rehe har wa'yr ipy wanehe wà.
\q1 Uzuka Tupàn wana'yr ipy upaw rupi a'e wà.
\b
\q1 
\v 37 Na'e wenuhem Tupàn Izaew izuapyapyr Ezit ywy wi wà kury.
\q1 Weraha Izaew parat wà. Or weraha wà no.
\q1 Ikàg paw rupi wà. Na'ima'eahy kwaw wà.
\q1 
\v 38 Hurywete Ezit ywy rehe har Izaew a'e wi wahem mehe wà
\q1 Ta'e ukyze wanuwi wà xe.
\q1 
\v 39 Tupàn umupu'àm amo ywàkun wemiaihu wa'aromo.
\q1 Pyhaw tata upu'àm ma'e wexak kar waho àwàm wanupe no.
\q1 
\v 40 Wenoz ma'ero'o kwer Tupàn pe wà.
\q1 Umur kar pykahu zàwenugar wanupe wà. Umu'ar kar typy'ak ywak wi no. Uhyk wanupe.
\q1 
\v 41 Upei'àg amo itahu. Uhem 'y itahu wi.
\q1 Uwyryk ywyxiguhu rehe yrykawhu ài.
\q1 
\v 42 Uzapo agwer ma'e ta'e ima'enukwaw uze'eg awer ikatuahy ma'e rehe xe.
\q1 Kwehe mehe uzapokatu a'e uze'egaw wemiruze'eg Àmàrààw rehe we.
\b
\q1 
\v 43 Nezewe Tupàn wenuhem wemiaihu wemixamixak kwer Ezit ywy wi a'e wà.
\q1 Uzegar a'e wi uhem mehe urywete haw rehe uhapukaz pà wà.
\q1 
\v 44 Tupàn omono amo ae teko waywy Izaew wanupe.
\q1 — Pepyhyk wako nehe, i'i wanupe.
\q1 
\v 45 — Nezewe mehe peruzar putar heze'eg nehe, i'i wanupe.
\q1 — Nezewe mehe pezapo putar heremiapo putar haw nehe, i'i wanupe. Pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe.
\b
\q1 Azeharomoete.
\c 106
\s1 Tupàn ikatu Izaew wanupe
\q1 
\v 1 Azeharomoete.
\q1 Pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe,
\q1 Ta'e ikatuahy a'e xe, ta'e ipuruamutar katu haw nupaw pixik kwaw a'e nehe xe.
\q1 
\v 2 Mo upuner hemiapo kwer ikatuahy ma'e imume'u haw rehe wà.
\q1 Mo upuner ikatu haw imume'u katu haw rehe wà.
\q1 
\v 3 Hurywete teko wà, aze wiko tuwe ikatu 'ym ma'e iapo 'ymar romo wà.
\q1 Hurywete ikatu ma'e tuweharupi iapo har wà.
\b
\q1 
\v 4 Nema'enukwaw herehe nehe, o Tupàn Tuweharupi Wiko Ma'e,
\q1 Neremiaihu wanehe neze'egatu imono mehe nehe.
\q1 Wapyro mehe hepyro pe nehe no.
\q1 
\v 5 Tuwe aexak neremiaihu waneko katu mehe ihe wà nehe.
\q1 Tuwe herurywete neremiruze'eg wainuinuromo wanurywete mehe ihe nehe.
\q1 Hurywete a'e wà, ta'e neremiaihu romo wanekon wà xe.
\b
\q1 
\v 6 Uruzapo ikatu 'ym ma'e ureipy wazàwe ure.
\q1 Na'urekatu kwaw. Ureaiw ure.
\q1 
\v 7 Ezit ywy rehe wiko mehe ureipy nukwaw kwaw Tupàn hemiapo kwer ikatuahy ma'e wà.
\q1 Kwarahy nànàn wexak kar wamutar katu haw wanupe.
\q1 Heharaz ipuruamutar katu haw wi wà.
\q1 Yryhupiràg huwake wiko mehe upytu'u Tupàn Ikàg Wera'u Ma'e ize'eg heruzar ire wà.
\q1 
\v 8 Nezewe rehe we wexak kar ukàgaw uhua'u ma'e wanupe.
\q1 Upyro a'e wà, ta'e umume'u wapyro àwàm wanupe a'e 'ym mehe a'e xe.
\q1 
\v 9 Uze'eg Tupàn Tuweharupi Wiko Ma'e. A'e rupi Yryhupiràg uxinig a'e.
\q1 Wahaw teko yryhu wà.
\q1 Nuzawy kwaw ywy uxinig ma'e wanupe.
\q1 
\v 10 Upyro wemiaihu wà, wanehe iakatuwawahy 'ym ma'e wapo wi wà.
\q1 Upyro waàmàtyry'ymar wanuwi wà.
\q1 
\v 11 'Y umim waàmàtyry'ymar wà.
\q1 Ni pitài nuzenuhem kwaw wà. Umàno paw rupi wà.
\q1 
\v 12 Na'e hemiaihu uzeruzar Tupàn hemimume'u kwer rehe wà.
\q1 Umuzàg zegar haw ikatu haw rehe har wà.
\b
\q1 
\v 13 Nan kwehe tete heharaz Tupàn hemiapo kwer wi wà.
\q1 Uzapo ma'e oho ize'eg henoz 'ym pà wà.
\q1 
\v 14 Ywyxiguhu rehe wanemimutar uzeapo wanuwihaw romo.
\q1 Wagaw Tupàn wà.
\q1 
\v 15 A'e rupi omono wanemimutar wanupe.
\q1 Omono kar amo ma'eahy haw iaiw ma'e wanupe no.
\b
\q1 
\v 16 A'e pe wanàpuzràn wanenaw rehe
\q1 Hewyrowyroahy Moizez rehe wà.
\q1 Hewyrowyroahy Àràw rehe wà, Tupàn Tuweharupi Wiko Ma'e hemiruze'eg ikatu ma'e rehe wà no.
\q1 
\v 17 Na'e uzepe'a ywy Nàtà imukun pà kury.
\q1 Umukun Àmiràw no. Umukun iànàm wà no.
\q1 
\v 18 Tupàn umuezyw tata wanemiruze'eg wanehe.
\q1 Wapy a'e teko ikatu 'ym ma'e wà.
\b
\q1 
\v 19 Xinaz ywytyr rehe umupyràn Izaew itazu or wà, tapi'aka'yr hagaw paw iapo pà wà.
\q1 Umuwete katu a'e or imupyràn pyrer tupàn ua'u romo iapo pyrer wà.
\q1 
\v 20 Weityk Tupàn ikàgaw ipuràg eteahy haw wà. Umuwete katu ma'ea'yr ka'api'i i'u har hagapaw wà.
\q1 
\v 21 Heharaz Tupàn zanepyro har wi wà.
\q1 Heharaz Ezit ywy rehe hemiapo kwer ikatuahy ma'e wi wà.
\q1 
\v 22 Azeharomoete uzapo ikatuahy ma'e a'e pe.
\q1 Azeharomoete uzapo purumupytuhegatu kar haw Yryhupiràg pe no.
\q1 
\v 23 Wikwahy Tupàn Izaew wanupe. Uze'eg nezewe. — Amumaw putar Izaew paw ihe wà nehe, i'i.
\q1 Hemiruze'eg hemixak kwer Moizez uze'eg oho henataromo kury.
\q1 — Ezuka zo ne wà nehe, i'i izupe. A'e rupi nuzuka kwaw wà.
\q1 
\v 24 A'e re amo 'ar mehe
\q1 Naheixe wer kwaw Kànàà ywy ikatuahy ma'e rehe wà,
\q1 Ta'e nuzeruzar kwaw Tupàn hemimume'u kwer rehe wà xe.
\q1 
\v 25 Upyta wàpuzràn pupe wà. Uzypyrog uze'eg zemueteahy pà wà.
\q1 Na'ipurenu wer kwaw Tupàn Tuweharupi Wiko Ma'e rehe wà.
\q1 
\v 26 Na'e Tupàn Tuweharupi Wiko Ma'e umume'u tuwe ma'e wanupe kury.
\q1 — Pemàno putar ywyxiguhu rehe nehe, i'i wanupe.
\q1 
\v 27 — Amuhàmuhàz putar pezuapyapyr teko herehe uzeruzar 'ym ma'e wainuinuromo ihe wà nehe, i'i wanupe.
\q1 — Amumàno kar putar amo ae ywy rehe ihe wà nehe, i'i wanupe.
\b
\q1 
\v 28 Na'e Tupàn hemiaihu uzemono'og wà Peor ywytyr rehe wà kury,
\q1 Tupàn ua'u Ma'aw her ma'e imuwete katu pà wà kury.
\q1 Uzuka kar ma'ea'yr tupàn a'ua'u wikuwe 'ym ma'e wanupe wà. A'e re u'u wano'o kwer wà.
\q1 
\v 29 A'e ma'e iapo haw hexak mehe wikwahy Tupàn.
\q1 A'e rupi umur kar ma'eahy haw iaiw ma'e wanupe.
\q1 
\v 30 Pinez uzepyk ikatu 'ym ma'e iapo arer rehe a'e.
\q1 A'e mehe upytu'u ma'eahy haw.
\q1 
\v 31 — Ikatu Pinez, i'i Tupàn izupe.
\q1 — Ikatu Pinez, i'i putar teko paw tuweharupi wà nehe.
\b
\q1 
\v 32 A'e re oho ytyzuzàmaw Merima her ma'e pe wà.
\q1 Umuikwahy kar wi teko Tupàn wà.
\q1 Uzepyk Tupàn Moizez rehe teko wakatu 'ymaw hekuzaromo kury.
\q1 
\v 33 Umuikwahy kar tuwe teko Moizez wà.
\q1 A'e rupi umume'u iro haw a'e.
\b
\q1 
\v 34 Nuzuka kwaw Tupàn rehe uzeruzar 'ym ma'e
\q1 Tupàn Tuweharupi Wiko Ma'e ze'eg rupi wà.
\q1 
\v 35 Wiko oho wainuinuromo wà. Uzerekoreko wanehewehewe wà.
\q1 Uzapo iaiw ma'e wanemiapo zàwenugar wà.
\q1 
\v 36 Tupàn hemiaihu umuwete katu tupàn a'ua'u wà.
\q1 A'e rupi Tupàn uzuka wà.
\q1 
\v 37 Uzuka kar wa'yr tupàn a'ua'u wanenataromo wà.
\q1 Uzuka kar wazyr wanenataromo wà no.
\q1 
\v 38 Uzuka kwarer ikatu 'ym ma'e iapo pixik 'ymar kuzàtài ikatu ma'e wanehe we wà.
\q1 Wa'yr wazyr uzuka tupàn a'ua'u
\q1 Kànàà ywy rehe har wazar wanupe wà.
\q1 A'e rupi ywy uzeapo iaiw ma'e romo Tupàn henataromo a'e, ta'e kwarer wanuwykwer kuzàtài wanuwykwer heta hehe a'e xe.
\q1 
\v 39 A'e ma'e iapo mehe uzemuaiw kar Tupàn henataromo wà.
\q1 Upytu'u Tupàn heruzar ire wà.
\b
\q1 
\v 40 Na'e Tupàn Tuweharupi Wiko Ma'e wikwahy wemiaihu wanupe kury.
\q1 Iroahy tuwe izupe wà.
\q1 
\v 41 A'e rupi weityk uzeruzar 'ym ma'e wapo pe wamono pà wà kury.
\q1 Uzeruzar 'ym ma'e wiko wazar romo wà kury.
\q1 
\v 42 Waàmàtyry'ymar upuraraw kar ma'erahy wanupe wà.
\q1 Uzapo Izaew a'e teko wanemiapo putar haw tuweharupi wà kury.
\q1 
\v 43 Tupàn upyro tetea'u zepe wemiaihu wà.
\q1 Nezewe rehe we nuweruzar kwaw uzar wà.
\q1 Tuweharupi wixe wera'u ikatu 'ymaw pupe wà.
\q1 
\v 44 Nezewe rehe we aze wenoz upytywà haw Tupàn pe wà, wenu waze'eg a'e.
\q1 Uzewyr wanupe aze upuraraw ma'erahy wà.
\q1 
\v 45 Ima'enukwaw wemimume'u kwer rehe, ta'e hemiaihu romo wanekon a'e wà xe.
\q1 Uzewyr uze'eg awer wi, ta'e uzamutar katu a'e wà xe.
\q1 
\v 46 Tupàn uma'ereko wazar wapy'a pe a'e.
\q1 A'e rupi wazar upuhareko wemipyhyk kwer a'e wà.
\b
\q1 
\v 47 O Tupàn Tuweharupi Wiko Ma'e urezar, urepyro pe nehe.
\q1 Uremunyryk kar pe urereraha nerehe uzeruzar 'ym ma'e wamyter wi nehe.
\q1 Urereraha pe, urereruzewyr pà ureywy pe nehe.
\q1 Nezewe mehe urumume'u putar neremiapo ikatu haw newe nehe.
\q1 Urerurywete haw rupi urumume'u putar nerer ikatu ma'e ikatu haw nehe.
\b
\q1 
\v 48 Ximume'u Tupàn Tuweharupi Wiko Ma'e Izaew wazar ikatu haw nehe.
\q1 Pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw ko 'ar rehe nehe. Pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw tuweharupi nehe no.
\q1 Tuwe teko ywy nànànar uze'eg nezewe wà nehe. — Azeharomoete, tuwe i'i wà nehe.
\q1 Pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe.
\c 107
\ms1 PAPE 5 HAW
\mr 107–150
\s1 Ximume'u Tupàn ikatu haw, ta'e ikatuahy a'e xe
\q1 
\v 1 Pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe, ta'e ikatuahy a'e xe.
\q1 Ipuruamutar katu haw nupaw pixik kwaw nehe.
\q1 
\v 2 Tuwe hemipyro kwer paw
\q1 Umume'u Tuweharupi Wiko Ma'e ikatu haw wà nehe.
\q1 Upyro waàmàtyry'ymar wapo wanuwi a'e wà.
\q1 
\v 3 Pemur kar amo teko waywy wi a'e.
\q1 Kwarahy heixe haw awyze har wi pemur kar. Kwarahy hemaw awyze har wi pemur kar. Kwarahy hemaw wi pemur kar. Kwarahy heixe haw wi pemur kar no.
\b
\q1 
\v 4 Amo peipy wata e oho waiko ywyxiguhu rehe wà.
\q1 Nuexak kwaw tawhu weko àwàm wà.
\q1 
\v 5 Ima'uhez wà. Iziwez wà no.
\q1 Upytu'u ikatu ma'e hàro re wà.
\q1 
\v 6 Ma'erahy ipuraraw mehe uhapukaz upytywà àwàm henoz pà wà.
\q1 Tupàn Tuweharupi Wiko Ma'e upyro ma'erahy wi wà.
\q1 
\v 7 Weruata pe ikatu ma'e rupi wà.
\q1 Weraha tawhu ikatu ma'e pe wà, waneko àwàm me wà.
\q1 
\v 8 — Nepuruamutar katu haw ikatu, tuwe i'i Tupàn Tuweharupi Wiko Ma'e pe wà.
\q1 Tuwe umume'u hemiapo kwer ikatuahy ma'e wà nehe. Uzapo a'e ma'e wanupe a'e.
\q1 
\v 9 Omono 'y iziwez ma'e wanupe.
\q1 Omono ikatu ma'e ima'uhez ma'e wanupe.
\b
\q1 
\v 10 Amo wiko ipytunaw rehe wà. Wiko ipytunahy haw rehe wà.
\q1 Upuraraw ma'erahy waiko wà. Amo wàpixi a'e teko kyhàhàmtàtà pupe wà,
\q1 
\v 11 Ta'e upytu'u Tupàn Ywate Wera'u Har ze'eg heruzar ire a'e wà xe.
\q1 Upytu'u ipurumu'e haw rehe uzekaiw ire wà no.
\q1 
\v 12 Ikene'o uma'ereko haw ipuhuz katu ma'e rehe wà.
\q1 U'ar oho waiko wà. Ni amo nupytywà kwaw wà.
\q1 
\v 13 Ma'erahy ipuraraw mehe uhapukaz upytywà àwàm henoz pà wà.
\q1 Tupàn Tuweharupi Wiko Ma'e upyro ma'erahy wi wà.
\q1 
\v 14 Upyro wamàno àwàm ipytunahy haw zàwenugar wi wà.
\q1 Omonohonohok kyhàhàmtàtà waàpixipixi haw no, ipegegwera'i romo no.
\q1 
\v 15 Tuwe umume'u Tupàn Tuweharupi Wiko Ma'e ipuruamutar katu haw ikatu haw izupe nehe.
\q1 Tuwe umume'u hemiapo kwer ikatu haw nehe no. Uzapo a'e ma'e wanupe a'e.
\q1 
\v 16 Weityk uken itazu morog iapo pyrer a'e.
\q1 Uzukazuka itaper ipegegwer romo no.
\b
\q1 
\v 17 Amo ima'eahy a'e wà,
\q1 Ta'e uzapo ikatu 'ym ma'e a'e wà xe.
\q1 Upuraraw ma'erahy ta'e iaiw a'e wà xe.
\q1 
\v 18 Ihuhuk wer temi'u hexak mehe wà.
\q1 Umàno tària'i wà.
\q1 
\v 19 Ma'erahy ipuraraw mehe uhapukaz upytywà àwàm henoz pà wà.
\q1 Tupàn Tuweharupi Wiko Ma'e upyro ma'erahy wi wà.
\q1 
\v 20 Umukatu uze'eg rupi wà.
\q1 Upyro wamàno haw wi wà.
\q1 
\v 21 Tuwe umume'u Tupàn Tuweharupi Wiko Ma'e ipuruamutar haw ikatu haw izupe wà nehe.
\q1 Tuwe umume'u hemiapo kwer ikatuahy ma'e wà nehe no.
\q1 
\v 22 Tuwe uzuka ma'ea'yr Tupàn henataromo wà nehe, hemiapo kwer ikatu haw imume'u pà izupe wà nehe.
\q1 Tuwe umuzàg zegar haw purumurywete kar haw izupe wà nehe no.
\q1 Tuwe umume'u hemiapo kwer upaw rupi wà nehe.
\b
\q1 
\v 23 Amo wata oho yryhu rehe kanuhu pupe wà.
\q1 Omono'og wemetarer yryhu rehe uma'ereko pà wà.
\q1 
\v 24 Wexak Tupàn Tuweharupi Wiko Ma'e hemiapo kwer wà.
\q1 Wexak hemiapo kwer ikatuahy ma'e yryhu rehe iapo pyrer wà.
\q1 
\v 25 Uze'eg Tupàn a'e.
\q1 Na'e ywytu uzypyrog ur pà a'e kury.
\q1 Umuhua'u ykotok kury.
\q1 
\v 26 Na'e ykotok upir katu kanuhu wà.
\q1 A'e re kanuhu wezyw katu oho 'y iwy pe wà no.
\q1 Awa ukyze tuwe
\q1 A'e ikatu 'ymaw inuromo wà.
\q1 
\v 27 Uzepyapi oho waiko wata pà uka'u ma'e ài wà.
\q1 Ukwaw katu yryhu rehe uma'ereko haw wà. Nezewe rehe we umàno tària'i wà.
\q1 
\v 28 A'e rupi ma'erahy ipuraraw mehe uhapukaz upytywà àwàm henoz pà wà.
\q1 A'e rupi Tupàn Tuweharupi Wiko Ma'e upyro a'e ma'erahy wi wà.
\q1 
\v 29 Umupytu'u kar ykotok ire.
\q1 Upytu'u ykotok wànog ire.
\q1 
\v 30 Hurywete a'e awa wà, ta'e upytu'u ykotok ire xe.
\q1 Nezewe Tupàn weraha waho àwàm me wà.
\q1 
\v 31 Tuwe umume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw wà nehe, ipuruamutar katu haw ikatu haw wà nehe.
\q1 Tuwe umume'u hemiapo kwer ikatuahy ma'e wà nehe. Uzapo a'e ma'e wanupe a'e.
\q1 
\v 32 Teko wazemono'og mehe pemume'u Tupàn uhua'u haw nehe.
\q1 Pemume'u ikatu haw tuwihaw wazemono'og mehe nehe.
\q1 
\v 33 Uzapo Tupàn yrykawhu ywyxiguhu romo a'e.
\q1 Ytyzuzàmaw uzapo ywy uxinig ma'e romo no.
\q1 
\v 34 Uzapo ywy katu ywy xa heta tetea'u ma'e romo no,
\q1 Ta'e iaiw a'e pe wiko ma'e a'e wà xe.
\q1 
\v 35 Uzapo ywyxiguhu ypawhu romo.
\q1 Ywy uxinig ma'e kwer rehe uzapo ytyzuzàmaw no.
\q1 
\v 36 Umuigo kar teko ima'uhez tetea'u ma'e a'e pe wà.
\q1 A'e teko uzapo tawhu wà. Wiko a'e pe wà.
\q1 
\v 37 Uzutym ma'eà'yz ko pe wà. Uzapo uwà tyw a'e pe wà no.
\q1 Hezuz katu a'e ma'eà'yz wà. Teko opo'o i'a kwer tetea'u wà.
\q1 
\v 38 Tupàn omono uze'egatu wemiaihu wanehe a'e.
\q1 Wa'yr tetea'u umuzàg wà.
\q1 Numumaw kar pixik kwaw tapi'ak a'e pe wà.
\q1 
\v 39 Zauxiapekwer amo ywy rehe har ur a'e pe wà. Weityk Tupàn hemiaihu wà, ma'e hereko 'ymar romo wamuigo kar pà wà. Upuraraw ma'erahy wà.
\q1 Uzemumikahy wà. Ipuhuz katu wanupe.
\q1 
\v 40 Tuwihaw Tupàn hemiaihu waneityk arer wà, iro Tupàn pe wà. Wexak kar Tupàn wikwahy haw wanupe kury.
\q1 Umuata e kar a'e tuwihaw waneraha ywyxiguhu teko heta 'ymaw rehe wà.
\q1 
\v 41 Upyro ma'e hereko 'ymar wanemipuraraw wi wà.
\q1 Umueta tetea'u kar wana'yr wà, wanazyr wà no. Heta tetea'u àràpuhàràn imono'og pyrer ài wà.
\q1 
\v 42 Teko ikatu ma'e wexak a'e ma'e wà. Hurywete hexak mehe wà.
\q1 Tupàn umupytu'u kar teko ikatu 'ym ma'e paw waze'eg ire wà.
\b
\q1 
\v 43 Aze ma'e kwaw katu har romo ereiko nehe, nema'enukwaw katu ko ma'e rehe nehe.
\q1 Ezeagaw Tupàn Tuweharupi Wiko Ma'e ipuruamutar katu haw ikwaw pà nehe.
\c 108
\s1 Tupàn iàmàtyry'ymar waneityk awer rehe zegar haw
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 Hepy'a ikàg, o Tupàn, ikàg tuwe a'e.
\q1 Amuzàg putar zegar haw nekatu haw imume'u pà nehe.
\q1 Eme'e kury, hepy'a.
\q1 
\v 2 Hewioràwiràn, eme'egatu nehe. Eme'egatu nehe no, hewioràwiràn irir her ma'e.
\q1 Amume'egatu kar putar kwarahy ihe nehe.
\q1 
\v 3 O Tupàn Tuweharupi Wiko Ma'e, amume'u putar neremimur kwer ikatu haw teko ywy nànànar wainuromo nehe.
\q1 Amume'u putar nekatu haw amogwer teko wainuinuromo nehe no.
\q1 
\v 4 Nepuruamutar katu haw ywak 'aromo hin a'e.
\q1 Puruwi netyryk pixik 'ymaw uhem ywàkun pe.
\b
\q1 
\v 5 O Tupàn, exak kar nehua'u haw ywate har nehe.
\q1 Tuwe nekàgaw uhyape katu ywy nànàn nepuràg eteahy haw rehe we nehe.
\q1 
\v 6 Urepyro pe nekàgaw rupi nehe.
\q1 Ewazar ureze'egaw newe ureremimume'u kwer urewe nehe.
\q1 Nezewe mehe erepyro putar teko neremiamutar katu ne wà nehe.
\q1 
\v 7 Tupàn uze'eg nezewe wàpuzuhu pe a'e.
\q1 — Heàmàtyry'ymar waneityk mehe nehe, azaikaikaw putar Xikez tawhu ihe nehe.
\q1 Apei'ài'àg putar ywyàpyznaw Xukot her ma'e nehe no. Amono putar ipegegwer heremiaihu wanupe nehe.
\q1 
\v 8 Aiko Zireaz izar romo ihe. Aiko Manaxe izar romo ihe no.
\q1 Eparai nuzawy kwaw heàkàg imimawtàtà a'e.
\q1 Zuta nuzawy kwaw ywyraihàg tuwihawete romo hereko haw hexak kar haw hepo pe har.
\q1 
\v 9 Moaw nuzawy kwaw kawaw hezepuez haw.
\q1 Aityk putar hexapat Enom rehe nehe.
\q1 Nezewe aexak kar putar a'e ywy izar romo hereko haw ihe nehe, purupe ihe nehe.
\q1 Azegar putar Piri ywy rehe har waneityk awer rehe nehe, i'i Tupàn.
\q1 
\v 10 O Tupàn, mo hereraha putar tawhu pàrirogaw aiha ma'e hereko har pupe nehe.
\q1 Mo hereraha putar Enom pe nehe.
\q1 
\v 11 Aipo urereityk pe azeharomoete ne.
\q1 Aipo nereata kwaw zauxiapekwer uremyrypar wanehe we.
\q1 
\v 12 Urepytywà pe ureàmàtyry'ymar waàmàtyry'ym mehe nehe.
\q1 Aze xo awa zo urepytywà nehe, nurupuner kwaw waneitykaw rehe nehe.
\q1 
\v 13 Aze Tupàn wiko zaneinuinuromo nehe, xityk putar zaneàmàtyry'ymar zane wà nehe.
\q1 Weityk putar zaneàmàtyry'ymar a'e wà nehe.
\c 109
\s1 Awa iàmàtyry'ym pyrer uze'eg Tupàn pe
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 Amume'u nekatu haw, o Tupàn.
\q1 Epyta zo neze'eg 'ym pà nehe.
\q1 
\v 2 Ikatu 'ym ma'e a'e wà, hemu'em ma'e a'e wà no. Uze'eg hekutyr a'e wà.
\q1 Umume'u temu'emaw herehe wà.
\q1 
\v 3 Umume'u mua'u iaiw ma'e heremiapo kwer wà.
\q1 Heàmàtyry'ym e wà.
\q1 
\v 4 Aiko wamyrypar romo ihe. Umekuzar hekatu haw ikatu 'ym ma'e pupe wà.
\q1 Nezewe rehe we aze'eg newe ikatu ma'e wanupe neremiapo ràm henoz tà ihe.
\q1 
\v 5 Omono ikatu 'ym ma'e ikatu ma'e hekuzaromo wà.
\q1 Omono purehe iakatuwawahy 'ymaw puruamutar haw hekuzaromo wà.
\b
\q1 
\v 6 O Tupàn, exaexak amo awa imunar ma'e hemu'em ma'e nehe. Emuigo kar a'e awa tàmuz romo heàmàtyry'ymar wanehe zepykaw imume'u mehe nehe.
\q1 Tuwe heàmàtyry'ymar iàmàtyry'ymar wiko hemiapo kwer ikatu 'ym ma'e imume'u har romo nehe.
\q1 
\v 7 Hemiapo kwer imume'u mehe, tuwe tàmuz uzepyk hehe wà nehe.
\q1 — Te Tupàn pe neze'egaw iaiw a'e no, tuwe i'i tàmuz izupe wà nehe.
\q1 
\v 8 Tuwe heàmàtyry'ymar umàno na'arewahy nehe.
\q1 Tuwe amo teko wiko hekuzaromo nehe.
\q1 
\v 9 Tuwe ta'yr wiko tu 'ym ma'e romo wà nehe.
\q1 Tuwe hemireko wiko imen 'ym ma'e romo nehe no.
\q1 
\v 10 Tuwe ta'yr wiko hàpuz 'ym ma'e romo wà nehe. Tuwe wiko temetarer nahu rupi henoz tar romo wà nehe.
\q1 Tuwe amo umuhem kar ta'yr wanàpuz heityk pyrer wi wà nehe, waneko haw wi wà nehe.
\q1 
\v 11 Tuwe tuwihaw o'ok heàmàtyry'ymar ima'e paw izuwi wà nehe, inewer haw imekuzar pà wà nehe.
\q1 Umumaw kwarahy tetea'u uma'ereko katu pà uma'e imono'og pà.
\q1 Tuwe amo ae ywy rehe har upyro ima'e izuwi a'e wà nehe.
\q1 
\v 12 Tuwe ni amo teko na'ikatu kwaw izupe wà nehe.
\q1 Tuwe ni amo nuzekaiw kwaw ta'yr wanehe tazyr wanehe imàno re wà nehe.
\q1 
\v 13 Tuwe izuapyapyr paw umàno na'arewahy wà nehe.
\q1 Tuwe teko paw heharaz her wi tàrityka'i wà nehe no.
\q1 
\v 14 Tuwe Tupàn Tuweharupi Wiko Ma'e naheharaz pixik kwaw ihy hemiapo kwer ikatu 'ym ma'e wi nehe.
\q1 Tuwe ima'enukwaw izypy wanemiapo kwer ikatu 'ym ma'e rehe upytu'u 'ym pà tuweharupi nehe.
\q1 
\v 15 Tuwe Tupàn Tuweharupi Wiko Ma'e ima'enukwaw wanemiapo kwer ikatu 'ym ma'e rehe nehe.
\q1 Tuwe teko heharaz iapo arer wanuwi wà nehe.
\b
\q1 
\v 16 A'e awa na'ipurapo wer pixik kwaw ikatu ma'e rehe a'e.
\q1 Upuraraw kar ma'erahy ma'e hereko 'ymar wanupe, hemetarer 'ym ma'e wanupe no, hemi'u 'ym ma'e wanupe no. Uzuka wà no.
\q1 
\v 17 Teko wanehe ze'egaiw imono haw ikatu izupe.
\q1 Tuwe a'e ze'egaiw u'ar a'e awa rehe nehe.
\q1 Teko wanehe ze'egatu imume'u haw na'ikatu kwaw izupe.
\q1 Tuwe ni amo nomono kwaw ze'egatu hehe wà nehe.
\q1 
\v 18 Ze'egaiw imono haw nazawaiw kwaw izupe. Nuzawy kwaw ukamir imunehew paw izupe.
\q1 Tuwe uze'egaiw uzewyr hehe u'ar pà 'y ài nehe.
\q1 Tuwe umuàkym ikàg wer uri kawer ài nehe.
\q1 
\v 19 Tuwe ze'egaiw nuhem pixik kwaw izuwi nehe.
\q1 Tuwe ze'egaiw upyk a'e awa ikamir ài nehe.
\q1 Tuwe uzàpixipixi uzar iku'aw har ài nehe.
\q1 
\v 20 O Tupàn Tuweharupi Wiko Ma'e, emekuzar heàmàtyry'ymar wanemiapo kwer nezewe nehe.
\q1 Ezepyk herehe uze'eg zemueteahy ma'e wanehe nehe.
\b
\q1 
\v 21 O hezar Tupàn Tuweharupi Wiko Ma'e,
\q1 Hepytywà pe neze'eg awer rupi katete nehe, hepyro pà nehe,
\q1 Ta'e nekatuahy ne xe, ta'e erepuruamutar katu ne xe.
\q1 
\v 22 Hemetarer 'ym ma'e romo aiko. Naheta kwaw ma'e ihewe.
\q1 Ikutuk pyrer ài aiko hepy'a pe.
\q1 
\v 23 Kwarahy heixe etea'i mehe ukàzym ma'e'àg oho.
\q1 Nezewegatete akàzym teko ihe. Ywytu hereraha herereko tukur ài.
\q1 
\v 24 Hepenàràg uryryryryz iko ta'e azekwaku tetea'u hemai'u 'ym pà ihe xe.
\q1 Heretekwer ukàzym oho iko ta'e heagaiwahy ihe xe.
\q1 
\v 25 Amogwer uze'eg urywahyahy herehe herexak mehe wà.
\q1 Weruwaruwak uwàkàg herehe upukapuka mehe wà.
\b
\q1 
\v 26 Hepytywà pe nehe, o Tupàn Tuweharupi Wiko Ma'e hezar.
\q1 Hepyro pe nehe, ta'e heamutar katu pe ne xe.
\q1 
\v 27 Tuwe heàmàtyry'ymar
\q1 Ukwaw hepyro har romo nereko haw a'e wà nehe.
\q1 
\v 28 Upuner ze'egaiw herehe imur haw rehe wà. Ne eremur neze'egatu herehe nehe.
\q1 Tuwe heàmàtyry'ymar uzeityk kar oho amo wanupe wà nehe.
\q1 Ihe neremiruze'eg ihe, tuwe herurywete ihe nehe.
\q1 
\v 29 Tuwe iaiw haw tetea'u u'ar heàmàtyry'ymar wanehe nehe.
\q1 Tuwe maranugar haw upyk kamir ài wà nehe no.
\b
\q1 
\v 30 Amume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw izupe wahy haw rupi nehe.
\q1 Amume'u putar ikatu haw teko wazemono'og mehe nehe,
\q1 
\v 31 ta'e weityk hemetarer 'ym ma'e waàmàtyry'ymar a'e wà xe,
\q1 A'e hemetarer 'ym ma'e wapyro pà wamàno haw pe wamono kar har wanuwi a'e xe.
\c 110
\s1 Tuwihawete Tupàn hemixak kwer
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 Tupàn Tuweharupi Wiko Ma'e uze'eg tuwihawete hezar pe.
\q1 — Eapyk heawyze har rehe nehe.
\q1 Amono putar neàmàtyry'ymar nepy iwy pe ihe wà nehe, i'i izupe.
\q1 
\v 2 O tuwihawete, Tupàn Tuweharupi Wiko Ma'e umuhàmuhàz putar nepuner haw a'e nehe.
\q1 Uzypyrog imuhàmuhàz tà Zeruzarez pe nehe. — Eiko neàmàtyry'ymar wazar romo nehe, i'i.
\q1 
\v 3 Amo 'ar mehe ereàmàtyry'ym putar ne wà nehe, o tuwihawete.
\q1 A'e 'ar mehe teko neremiruze'eg ur putar newe zauxiapekwer romo wiko pà wà nehe.
\q1 Zuwiri uzexak kar izi'itahy a'e.
\q1 Nezewegatete uzemono'og putar kwàkwàmo oho ywytyr newe imonokatu pyrer rehe wà nehe, neàwàxi pà wà nehe.
\q1 
\v 4 Tupàn Tuweharupi Wiko Ma'e umume'u ko ma'e wemiapo ràm a'e.
\q1 Nuzewyr kwaw uze'eg awer wi nehe.
\q1 — Ereiko putar xaxeto romo tuweharupi nehe,
\q1 Mekizetek haikweromo har romo nereko pà nehe, i'i Tupàn.
\q1 
\v 5 O tuwihawete, Tupàn wiko neawyze har rehe.
\q1 Weityk putar amogwer tuwihawete wikwahy haw 'ar mehe wà nehe.
\q1 
\v 6 Umume'u putar teko ywy nànànar wanemiapo kwer paw rupi nehe.
\q1 Upyk putar ywy zeàmàtyry'ymawhu pe har umàno ma'e kwer wanetekwer wapupe nehe.
\q1 Weityk putar ywy nànànar wanuwihawete wà nehe.
\q1 
\v 7 Pe rupi tuwihawete uwi'u putar 'y yrykaw pe har pupe a'e nehe.
\q1 Upu'àm putar teko paw waneitykar romo wiko pà nehe.
\c 111
\s1 Tupàn ikatu haw imume'u haw
\q1 
\v 1 Azeharomoete.
\q1 Pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe.
\q1 Hepy'a pupe tuwe amume'u putar Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe,
\q1 Teko Tupàn heruzar har wainuinuromo nehe, teko wazemono'ono'ogaw pe nehe.
\q1 
\v 2 Ikatuahy hemiapo kwer.
\q1 Hemiapo kwer rehe hurywete ma'e ipurukwaw katu wer hehe wà.
\q1 
\v 3 Heta puràg eteahy haw hemiapo kwer nànàn. Heta uhua'u haw hemiapo kwer nànàn no.
\q1 Teko wanupe ikatuahy haw nupaw pixik kwaw nehe.
\q1 
\v 4 Tupàn Tuweharupi Wiko Ma'e nazanemueharaz kar kwaw wemiapo kwer ikatuahy ma'e wi a'e.
\q1 Ikatu a'e. Upurupuhareko katu no.
\q1 
\v 5 Omono temi'u teko wanupe, aze a'e teko ukyze izuwi wà.
\q1 Naheharaz pixik kwaw uze'egaw teko wanehe we wemiapo katu kwer wi nehe.
\q1 
\v 6 Tupàn Tuweharupi Wiko Ma'e wexak kar ukàgaw teko Izaew wanupe a'e,
\q1 Amo ae teko waywy imono pà Izaew wanupe a'e.
\b
\q1 
\v 7 Tuweharupi uzapo ma'e uze'eg rupi katete, wemiaihu wanuwi upuir 'ym pà.
\q1 Zapuner ize'eg nànàn zanezeruzar haw rehe.
\q1 
\v 8 Nupaw pixik kwaw ize'eg nehe, ta'e azeharomoete a'e xe.
\q1 Ikatu a'e no.
\q1 
\v 9 Tupàn umuhem kar wemiaihu zemunehew paw zàwenugar wi a'e wà.
\q1 Uzapokatu uze'egaw upaw 'ym ma'e ràm wanehe we.
\q1 Wiko ikatuahy ma'e imonokatu pyrer romo a'e. Upuner a'e no.
\q1 
\v 10 Aze amo heko wer ma'e kwaw katu har romo nehe, tuwe ukyze Tupàn Tuweharupi Wiko Ma'e wi nehe, amo ma'e iapo 'ym mehe we nehe.
\q1 Aze teko weruzar ize'eg wà, Tupàn ukwaw katu kar ma'e a'e teko wanupe.
\q1 Tuwe teko umume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw tuweharupi wà nehe.
\c 112
\s1 Tupàn heruzar har hurywete wà
\q1 
\v 1 Azeharomoete.
\q1 Pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe.
\q1 Hurywete Tupàn wi ukyze ma'e wà. Aze Tupàn ze'eg heruzar haw ikatu amo teko wanupe, hurywete a'e teko wà.
\q1 
\v 2 Awa ikatu ma'e ta'yr ikàg putar ywy rehe wà nehe.
\q1 Tupàn omono putar uze'egatu izuapyapyr wanupe nehe.
\q1 
\v 3 Uhyk ma'e hàpuz me. Uhyk hemetarer izupe no.
\q1 Tuweharupi ikatu a'e.
\q1 
\v 4 Tatainy uhyape katu ipytun mehe.
\q1 Nezewegatete teko ikatu ma'e ukwaw kar ikatu ma'e iapo haw amo teko wanupe wà no, ikatuahy ma'e wanupe wà, purupuhareko ma'e wanupe wà no, imunar 'ym ma'e hemu'em 'ym ma'e wanupe wà no.
\q1 
\v 5 Aze amo upuhareko amogwer wà, aze omono ma'e imekuzar pyr wanupe, hurywete putar a'e nehe.
\q1 Aze uma'eme'eg imunar 'ym pà, aze uma'eme'eg kar hemu'em 'ym pà, hurywete a'e.
\q1 
\v 6 Ikatu ma'e nuzewyr kwaw hemetarer 'ym ma'e romo weko awer pe wà.
\q1 Teko ima'enukwaw putar her tuweharupi wà nehe.
\q1 
\v 7 Nukyze kwaw ikatu 'ym ma'e imume'u haw henu haw wi a'e.
\q1 Izeruzar haw ikàg a'e, ta'e uzeruzar Tupàn Tuweharupi Wiko Ma'e rehe a'e xe.
\q1 
\v 8 Nuzemumikahy kwaw. Nukyze kwaw.
\q1 Ukwaw katu wàmàtyry'ymar waneityk àwàm.
\q1 
\v 9 Omono e ma'e hemetarer 'ym ma'e wanupe.
\q1 Ikatu haw upyta putar tuweharupi nehe.
\q1 Upuner a'e. Teko paw umuwete wà.
\q1 
\v 10 Ikatu 'ym ma'e wexak heko haw wà. Wikwahy hexak mehe wà.
\q1 Ume'e hehe iakatuwawahy 'ym pà wà. A'e re uzemumaw wà.
\q1 Ikatu 'ym ma'e wàro e ikatu ma'e uzeapo ma'e ràm wà.
\c 113
\s1 Ximume'u Tupàn ikatu haw, ta'e ikatuahy a'e xe
\q1 
\v 1 Azeharomoete.
\q1 Pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe. Tuweharupi Wiko Ma'e hemiruze'eg wà, pemume'u her ikatu haw nehe.
\q1 
\v 2 Tuwe teko umume'u Tupàn Tuweharupi Wiko Ma'e her ikatu haw wà nehe,
\q1 Ko 'ar rehe wà nehe, tuweharupi wà nehe no.
\q1 
\v 3 Tuwe teko uzypyrog Tupàn Tuweharupi Wiko Ma'e ikatu haw imume'u pà kwarahy ihem mehe wà nehe.
\q1 Tuwe nupytu'u kwaw kwarahy heixe 'ym mehe we wà nehe.
\q1 
\v 4 Tupàn Tuweharupi Wiko Ma'e weruze'eg teko ywy nànànar wà.
\q1 Ikàgaw a'e, ipuràg eteahy haw a'e, ywak i'aromo hin a'e.
\b
\q1 
\v 5 Naheta kwaw amo Tupàn Tuweharupi Wiko Ma'e Zanezar zàwenugar wà.
\q1 Wapyk wenaw rehe ywate a'e.
\q1 
\v 6 Uzemu'àm ywak rehe har rehe ume'e pà, ywy rehe har hexak pà no.
\q1 
\v 7 Upyro hemetarer 'ym ma'e maranugar haw wi wà.
\q1 Umunyryk kar ma'e hereko 'ymar wama'uhez haw wi wà.
\q1 
\v 8 Umuigo kar a'e teko tuwihaw wanehe we har romo wà,
\q1 Wemiaihu wanuwihaw wanehe we har romo wà.
\q1 
\v 9 Umuwete kar kuzà imemyr 'ym ma'e hàpuz me har wanupe.
\q1 Umurywete kar a'e kuzà a'e, imumemyr kar pà a'e.
\q1 Pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe.
\b
\q1 Azeharomoete.
\c 114
\s1 Ezit ywy wi wahem awer
\q1 
\v 1 Zako izuapyapyr a'e wà, teko Izaew her ma'e a'e wà, uhem Ezit ywy rehe kwehe mehe a'e wà.
\q1 Nuiko kwaw a'e ywy rehe harete romo wà.
\q1 
\v 2 A'e wi uhem mehe Zuta izuapyapyr uzeapo teko Tupàn hemixamixak romo wà.
\q1 Tupàn wiko Izaew wazar romo a'e 'ar mehe.
\b
\q1 
\v 3 Yryhupiràg nuzuawy kwaw miar hehaite ma'e a'e. Miar uzàn awa hexak mehe.
\q1 Nezewegatete Yryhupiràg uhem oho Tupàn wi a'e no. Yrykawhu Zotàw her ma'e upytu'u uwyryk ire.
\q1 
\v 4 Ywytyruhu opoopor àràpuhàràn hawitu ma'e ài wà.
\q1 Ywytyr opoopor àràpuhàràna'yr ài wà.
\b
\q1 
\v 5 Ma'e uzeapo nemuzàn kar pà a'e, yryhu.
\q1 Ne Zotàw yrykaw ne, màràzàwe tuwe ne'y upytu'u uwyryk ire.
\q1 
\v 6 O ywytyruhu wà, màràzàwe tuwe pepor àràpuhàràn ài.
\q1 Ywytyr wà, màràzàwe tuwe pepor àràpuhàràna'yr ài.
\q1 
\v 7 Eryryryryz zanezar tur mehe nehe, ywy.
\q1 Eryryryryz Tupàn Zako izar henataromo nehe,
\q1 
\v 8 Ta'e uzapo itahu ytyzuzàmaw romo a'e wà xe.
\q1 Uzapo ita 'yzygwar romo wà no.
\c 115
\s1 Tupànete ikatu haw imume'u haw
\q1 
\v 1 Tuwe teko umume'u xo nekatu haw zo wà nehe, o Tupàn Tuweharupi Wiko Ma'e.
\q1 Tuwe numume'u kwaw urekatu haw wà nehe,
\q1 Ta'e erepuruamutar katu ne xe, ta'e neretyryk kwaw puruwi ne xe.
\q1 
\v 2 Màràzàwe tuwe amogwer ywy rehe har upuranu zanerehe nezewe wà.
\q1 — Ma'e pe hekon pezar Tupàn a'e, i'i wà.
\q1 
\v 3 — Tupàn Zanezar wiko ywak rehe a'e.
\q1 Uzapo wemimutar paw a'e,
\q1 Uru'e wanupe.
\q1 
\v 4 Teko amogwer ywy rehe har umupyràn parat a'e wà, or a'e wà no, uzar tupàn a'ua'u wanagapaw waapo pà wà.
\q1 Awa uzapo a'e tupàn a'ua'u wà.
\q1 
\v 5 Heta wazuru wanupe. Nuze'eg kwaw wà.
\q1 Heta waneha wanupe. Nuexak kwaw ma'e wà.
\q1 
\v 6 Heta wapyakwar wanupe. Nuenu kwaw ma'e wà.
\q1 Heta waxi wanupe. Nuwetun kwaw ma'e wà.
\q1 
\v 7 Heta wapo wanupe. Nupuner kwaw ma'e ipyhykaw rehe wà.
\q1 Heta wapy wanupe. Nuwata kwaw wà.
\q1 Ni amo ze'eg nuhem kwaw wazuru wi.
\q1 
\v 8 Tuwe a'e tupàn a'ua'u iapo arer
\q1 Wiko wemiapo kwer wazàwe wà nehe.
\q1 Tuwe wanehe uzeruzar ma'e wiko wazàwe wà nehe.
\b
\q1 
\v 9 O Izaew izuapyapyr wà, pezeruzar Tupàn Tuweharupi Wiko Ma'e rehe nehe.
\q1 Pepytywà a'e. Pepyro a'e no.
\q1 
\v 10 Xaxeto Tupàn henataromo har wà, pezeruzar Tupàn Tuweharupi Wiko Ma'e rehe nehe.
\q1 Pepytywà a'e. Pepyro a'e no.
\q1 
\v 11 Pezeruzar Tupàn Tuweharupi Wiko Ma'e rehe nehe, izuwi ukyze ma'e paw wà.
\q1 Pepytywà a'e. Nuzawy kwaw u'yw wi pemimaw a'e no.
\q1 
\v 12 Tupàn Tuweharupi Wiko Ma'e ima'enukwaw zanerehe. Umur putar uze'egatu zanerehe nehe.
\q1 Umur putar uze'egatu teko Izaew wanehe nehe no.
\q1 Umur putar uze'egatu xaxeto Tupàn henataromo har nànàn nehe no.
\q1 
\v 13 Omono putar uze'egatu teko wanehe nehe, aze wiko izuwi ukyze ma'e romo wà nehe.
\q1 Teko ikàg ma'e hemetarer katu ma'e wà. Teko hemetarer 'ym ma'e wà no. Omono putar uze'egatu a'e teko nànàn nehe.
\b
\q1 
\v 14 Tuwe Tupàn Tuweharupi Wiko Ma'e umuzàg kar pena'yr tetea'u peme wà nehe.
\q1 Tuwe umueta tetea'u kar nezuapyapyr wà nehe no.
\q1 
\v 15 Tuwe Tupàn Tuweharupi Wiko Ma'e omono uze'egatu penehe nehe.
\q1 Ywak iapo arer romo ywy iapo arer romo hekon a'e.
\b
\q1 
\v 16 Xo Tupàn Tuweharupi Wiko Ma'e zo wiko ywak izar romo a'e.
\q1 Ywy omono teko wanupe.
\q1 
\v 17 Umàno ma'e kwer numume'u kwaw Tupàn Tuweharupi Wiko Ma'e ikatu haw a'e wà,
\q1 Ta'e wezyw uze'eg 'ym ma'e wapyta haw pe a'e wà xe.
\q1 
\v 18 Zane wikuwe ma'e ximume'u Tupàn Tuweharupi Wiko Ma'e hemiapo kwer ikatu haw zane, ko 'ar rehe, tuweharupi nehe no.
\q1 Pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe.
\b
\q1 Azeharomoete.
\c 116
\s1 Tupàn hepyro màno haw wi
\q1 
\v 1 Azamutar katu Tupàn Tuweharupi Wiko Ma'e ihe,
\q1 Ta'e herenu a'e xe.
\q1 Wenu uzeupe heze'eg mehe a'e.
\q1 
\v 2 Herenu a'e.
\q1 Hepytywà àwàm henoz taw nànàn herenu a'e.
\q1 
\v 3 Màno haw nuzawy kwaw heàmàtyry'ymar a'e wà. Heàmàtyry'ymar ipuruàpixipixi wer herehe kyhàhàm pupe wà.
\q1 Amàno etea'i ihe. Iaiw haw tywypaw pe har hemukyze wera'u kar a'e.
\q1 Akyzeahy tuwe ihe. Azemumikahy azeharomoete no.
\q1 
\v 4 Na'e aze'eg Tupàn Tuweharupi Wiko Ma'e pe ma'e henoz tà.
\q1 — Aze ikatu newe nehe, hepyro pe hemàno haw wi nehe,
\q1 O Tupàn Tuweharupi Wiko Ma'e, a'e izupe.
\b
\q1 
\v 5 Tupàn Tuweharupi Wiko Ma'e ikatuahy purupe a'e. Nupuir kwaw wemiaihu wanuwi a'e.
\q1 Zanezar zanepuhareko a'e.
\q1 
\v 6 Aze teko nupuner kwaw wàmàtyry'ymar wanuwi uzepyro haw rehe wà, Tupàn Tuweharupi Wiko Ma'e uzekaiw katu a'e teko wanehe a'e.
\q1 Ikatu 'ym ma'e ihewe izeapo tària'i mehe hepyro a'e.
\q1 
\v 7 Ezeruzar wiwi Tupàn Tuweharupi Wiko Ma'e rehe nehe, a'e hezeupe,
\q1 Ta'e ikatuahy ihewe tuweharupi a'e xe.
\b
\q1 
\v 8 Hepyro Tupàn hemàno haw wi.
\q1 Hemupytu'u kar hezai'o re.
\q1 Hepyro iaiw haw ihewe uzeapo ma'e wi a'e.
\q1 
\v 9 A'e rupi ata teko ywy wikuwe ma'e hereko har rehe ihe.
\q1 Tuweharupi azapo Tupàn Tuweharupi Wiko Ma'e hemimutar aha iteko ihe.
\q1 
\v 10 — Hezuhazuhaw azeharomoete a'e wà, a'e hezeupe.
\q1 Nezewe rehe we napytu'u kwaw hezeruzar ire.
\q1 
\v 11 Akyze ihe, a'e rupi aze'eg nezewe.
\q1 — Teko nupuner kwaw ni amo teko wanehe uzeruzar haw rehe wà, a'e ihe.
\q1 Nezewe rehe we napytu'u kwaw Tupàn rehe hezeruzar ire.
\b
\q1 
\v 12 Ma'e apuner Tupàn Tuweharupi Wiko Ma'e pe imono haw rehe
\q1 Ihewe hemimur kwer paw hekuzaromo ihe.
\q1 
\v 13 Araha putar win Tupàn Tuweharupi Wiko Ma'e pe imono pyràm romo nehe,
\q1 Ta'e herurywete hepyro awer rehe ihe xe.
\q1 
\v 14 — Hemiaihu paw wazemono'og mehe
\q1 Amono putar heremimume'u kwer izupe ihe nehe.
\b
\q1 
\v 15 Tupàn Tuweharupi Wiko Ma'e uzemumikahy a'e,
\q1 Aze amo hemiaihu umàno a'e.
\q1 
\v 16 O Tupàn Tuweharupi Wiko Ma'e, aiko neremiruze'eg romo ihe.
\q1 Hehy weruzar neze'eg wikuwe mehe a'e. Aruzar neze'eg izàwegatete ihe no.
\q1 Hepyro pe hemàno haw wi ne.
\q1 
\v 17 Amono putar ma'e newe nehe, ta'e herurywete neremiapo kwer rehe ihe xe.
\q1 Aze'eg putar newe nehe.
\q1 
\v 18-19 Neremiaihu paw wazemono'og mehe,
\q1 Neràpuzuhu izywyr katu haw pe Zeruzarez pe wazemono'og mehe nehe,
\q1 Amono putar heremimume'u kwer newe nehe.
\b
\q1 Pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe.
\c 117
\s1 Ximume'u Tupàn Zanezar ikatu haw izupe nehe
\q1 
\v 1 Pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe, teko ywy nànànar wà.
\q1 Tuwe teko paw umume'u ikatu haw wà nehe.
\q1 
\v 2 Ureamutar katu haw ikàg a'e.
\q1 Nupuir pixik kwaw urewi nehe.
\b
\q1 Pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe.
\c 118
\s1 Pemume'u Tupàn ikatu haw izupe nehe
\q1 
\v 1 Pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw izupe nehe, ta'e ikatuahy a'e xe.
\q1 Nupaw pixik kwaw zaneamutar katu haw nehe.
\q1 
\v 2 Tuwe teko Izaew izuapyapyr uze'eg nezewe wà nehe.
\q1 — Nepuruamutar katu haw nupaw pixik kwaw nehe, tuwe i'i izupe wà nehe.
\q1 
\v 3 Tuwe xaxeto Tupàn henataromo har uze'eg nezewe wà nehe.
\q1 — Nepuruamutar katu haw nupaw pixik kwaw nehe, tuwe i'i izupe wà nehe.
\q1 
\v 4 Tuwe izuwi ukyze ma'e paw uze'eg nezewe wà nehe.
\q1 — Nepuruamutar katu haw nupaw pixik kwaw nehe, tuwe i'i izupe wà nehe.
\b
\q1 
\v 5 Ma'erahy ipuraraw mehe aze'eg Tupàn Tuweharupi Wiko Ma'e pe wahy haw rupi ihe.
\q1 Uwazar heze'eg ihewe hemuhem kar pà ma'erahy wi a'e.
\q1 
\v 6 Tupàn Tuweharupi Wiko Ma'e wiko herehe we a'e. Nakyze kwaw.
\q1 Ma'enugar ikatu 'ym ma'e upuner teko ihewe iapo haw rehe.
\q1 
\v 7 Tupàn Tuweharupi Wiko Ma'e wiko herehe we a'e. A'e ae hepytywà a'e.
\q1 A'e rupi aexak putar heàmàtyry'ymar waneityk mehe ihe wà nehe.
\q1 
\v 8 Tupàn Tuweharupi Wiko Ma'e rehe zanezeruzar haw
\q1 Ikatu wera'u teko wanehe zanezeruzar haw wi.
\q1 
\v 9 Tuweharupi Wiko Ma'e rehe zanezeruzar haw
\q1 Ikatu wera'u teko ikàg ma'e hemetarer katu ma'e wanehe zanezeruzar haw wi no.
\b
\q1 
\v 10 Heta tetea'u heàmàtyry'ymar heywyr har wà.
\q1 Amumaw a'e teko Tupàn Tuweharupi Wiko Ma'e ikàgaw rupi ihe wà.
\q1 
\v 11 Umàmàn heywyr wà.
\q1 Amumaw a'e teko Tupàn Tuweharupi Wiko Ma'e ikàgaw rupi ihe wà.
\q1 
\v 12 Uzemono'ono'og heywyr hàiru ài wà.
\q1 Nezewe rehe we ukaz tata pupe ywyra àkàgwer uxinig ma'e kwer ài wà.
\q1 Amumaw a'e teko Tupàn Tuweharupi Wiko Ma'e ikàgaw rupi ihe wà.
\q1 
\v 13 Heàmàtyry'ymahy wà,
\q1 Ta'e ipureityk wer tuwe herehe wà xe.
\q1 Tupàn Tuweharupi Wiko Ma'e hepytywà a'e.
\q1 
\v 14 Tupàn Tuweharupi Wiko Ma'e hemukàg kar a'e. Hemuigo kar upuner ma'e romo a'e.
\q1 Hepyro a'e.
\b
\q1 
\v 15 Tupàn hemiaihu uhapukaz wàmàtyry'ymar waneityk awer rehe wà. Penu waze'eg mehe pe wà nehe. Wàpuzràn wanenaw pe uhapukaz nezewe wà.
\q1 — Tupàn Tuweharupi Wiko Ma'e uzapo uhua'u ma'e upuner haw rupi a'e.
\q1 
\v 16 Upuner haw rupi uzapo uhua'u ma'e.
\q1 Tupàn Tuweharupi Wiko Ma'e ipuner haw weityk zaneàmàtyry'ymar wà, i'i wà.
\b
\q1 
\v 17 Nàmàno kwaw nehe.
\q1 Aikuwe wiwi putar nehe.
\q1 Amume'u putar Tupàn Tuweharupi Wiko Ma'e hemiapo kwer ihe nehe.
\q1 
\v 18 Uzepyk tuwe herehe a'e.
\q1 Nezewe rehe we nahemumàno kar kwaw.
\b
\q1 
\v 19 Pewàpytymawok Tupàn Hàpuzuhu hukenaw ihewe nehe.
\q1 Aixe putar hupi nehe. Amume'u putar Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe.
\b
\q1 
\v 20 Tuweharupi Wiko Ma'e wiko 'àg uken izar romo a'e.
\q1 Xo teko Tupàn heruzar har zo upuner hupi wixe haw rehe wà.
\b
\q1 
\v 21 O Tupàn, uruamutar katu ihe, ta'e herenu pe ne xe.
\q1 Ereityk heàmàtyry'ymar ne wà no.
\b
\q1 
\v 22 Tàpuz iapo har weityk amo ita wà.
\q1 Iahykaw rehe a'e ita ikàg wera'u amo ita wanuwi a'e.
\q1 
\v 23 Tupàn Tuweharupi Wiko Ma'e uzapo a'e ma'e a'e.
\q1 Ikatuahy hemiapo kwer.
\q1 
\v 24 Ko 'ar rehe Tupàn Tuweharupi Wiko Ma'e weityk wàmàtyry'ymar wamono wà.
\q1 Tuwe ko 'ar uzeapo zanemuryw kar har romo nehe. Tuwe zanerurywete nehe.
\q1 
\v 25 Urepyro pe nehe, o Tuweharupi Wiko Ma'e, urepyro pe nehe.
\q1 Uremuigo kar pe temi'u hereko har romo ma'e hereko har romo nehe, o Tupàn.
\b
\q1 
\v 26 Aze amo ur Tupàn Tuweharupi Wiko Ma'e her rehe nehe, tuwe Tupàn omono uze'egatu hehe nehe.
\q1 Xe Tupàn tàpuzuhu pe uruiko mehe oromono ureze'egatu penehe paw rupi ure.
\q1 
\v 27 Tuweharupi Wiko Ma'e wiko Tupàn romo a'e. Zaneratainy romo hekon.
\q1 Pezypyrog mynykawhu iapo pà ywyra hàkàgwer hereko pà pepo pe nehe.
\q1 Peata ma'ea'yr hapy haw izywyr nehe.
\b
\q1 
\v 28 Ereiko hezar romo ne. Amume'u putar nekatu haw nehe.
\q1 Ereiko hezar romo. Amume'u putar nehua'u haw nehe no.
\b
\q1 
\v 29 Pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe, izupe nehe, ta'e ikatu a'e xe.
\q1 Ipuruamutar katu haw nupaw pixik kwaw nehe.
\c 119
\s1 Tupàn Ze'eg ikatuahy zanewe
\q1 
\v 1 Hurywete teko a'e wà,
\q1 Aze ni amo nupuner kwaw wanemiapo kwer ikatu 'ym ma'e imume'u haw rehe wà.
\q1 Hurywete Tupàn Tuweharupi Wiko Ma'e ze'eg heruzar har wà.
\q1 
\v 2 Hurywete hemiapo karer heruzar har wà.
\q1 Hurywete wà, aze weruzar tuwe upy'a pupe wà.
\q1 
\v 3 Hurywete ikatu 'ym ma'e iapo 'ymar wà.
\q1 Hurywete Tupàn hape rupi wata ma'e wà.
\q1 
\v 4 Eremur neze'eg urewe.
\q1 Ereruzar kar tuwe urewe.
\q1 
\v 5 Hepureruzar wer neremiapo putar haw rehe ihe.
\q1 Hepurapo wer neremiapo putar haw rehe hepytu'u 'ym pà.
\q1 
\v 6 Aze amuwete neremiapo kar paw nehe,
\q1 Nahemaranugar kwaw nehe.
\q1 
\v 7 Nepurumu'e haw ikwaw wewer mehe nehe,
\q1 Amume'u putar nekatu haw hepy'a katu pe nehe.
\q1 
\v 8 Aruzar putar neze'eg nehe.
\q1 Etyryk pixik zo ihewi nehe.
\s1 Amonokatu neze'eg hepy'a pe
\q1 
\v 9 Ma'e kwàkwàmo uzapo putar weko haw imonokatu pà Tupàn pe a'e.
\q1 Weruzar putar Tupàn hemiapo karer nehe.
\q1 
\v 10 Azeagaw nereruzar pà hepy'a pupe azeharomoete ihe.
\q1 Hemupytu'u kar zo pe neremiapo kar iapo re nehe.
\q1 
\v 11 Amonokatu neze'eg hepy'a pe, hehe hema'enukwaw katu pà.
\q1 Nezewe mehe nazapo kwaw ikatu 'ym ma'e nekutyr ihe.
\q1 
\v 12 Amume'u nekatu haw, o Tupàn Tuweharupi Wiko Ma'e.
\q1 Hemu'e pe neze'eg rehe nehe.
\q1 
\v 13 Tuweharupi amume'u
\q1 Neremiapo kar wahy haw rupi ihe.
\q1 
\v 14 Herurywete wera'u neremiapo kar heruzar mehe.
\q1 Ikatu wera'u ihewe temetarer tetea'u wi a'e.
\q1 
\v 15 Azemu'e neze'eg rehe.
\q1 Ame'e nepurumu'e haw rehe no.
\q1 
\v 16 Neze'eg hemurywete kar a'e.
\q1 Napytu'u kwaw neze'egaw rehe hema'enukwaw ire.
\s1 Exak kar neze'eg ihewe
\q1 
\v 17 Hezar, aiko neremiruze'eg romo.
\q1 Herereko katu pe nehe. Nezewe mehe apuner putar hereko haw rehe nehe.
\q1 Apuner putar neze'egaw heruzar haw rehe nehe no.
\q1 
\v 18 Hemuehazawok neze'eg azeharomoete har
\q1 Ikatuahy ma'e hexak kar pà ihewe nehe.
\q1 
\v 19 Namumaw kwaw kwarahy tetea'u xe ywy rehe nehe.
\q1 Emim zo neremiapo kar ihewi nehe.
\q1 
\v 20 Hepy'a uzemumikahy heremiapo rehe hema'enukwaw pà ihe, tuweharupi,
\q1 Ta'e hepurukwaw wer neremimutar rehe ihe xe.
\q1 
\v 21 Ereze'egahy amo wanuwi wiko wera'u ma'e wanupe.
\q1 Neremiapo kar wi utyryk ma'e wiko neze'egaiw iwy pe wà.
\q1 
\v 22 Hepyro pe heàmàtyry'ymar waze'eg zemueteahy haw wi nehe, waze'eg uryweteahy haw wi nehe no,
\q1 Ta'e tuweharupi aruzar nepurumu'e haw ihe xe.
\q1 
\v 23 Aze tuwihaw uzemono'og wà nehe, aze umume'u hezuka àwàm uzeupeupe wà nehe,
\q1 Nezewe rehe we ihe neremiruze'eg ihe,
\q1 Hema'enukwaw putar neze'eg rehe ihe nehe.
\q1 
\v 24 Nepurumu'e haw rehe hema'enukwaw paw ikatu ihewe.
\q1 Hema'enukwaw paw nuzawy kwaw hereruze'egar a'e wà.
\s1 Hemu'e pe neremiapo kar rehe nehe
\q1 
\v 25 Hema'enukwaw paw hereityk a'e wà. Ywyw a'ar ihe.
\q1 Hemukàg wi kar neremimume'u kwer rupi katete nehe.
\q1 
\v 26 Amume'u heremiapo kwer paw rupi ihe. Erewazar heze'eg ihewe.
\q1 Hemu'e pe neremiapo kar rehe nehe.
\q1 
\v 27 Exak kar neze'eg heruzar haw ihewe nehe.
\q1 Hema'enukwaw katu putar nepurumu'e haw ikatuahy ma'e rehe nehe.
\q1 
\v 28 Hezemumikahy haw hemumaw iko a'e.
\q1 Emur nekàgaw ihewe neremimume'u kwer rupi katete nehe.
\q1 
\v 29 Hemuata kar zo pe pe ikatu 'ym ma'e rupi nehe.
\q1 Ikatu 'ym ma'e iapo haw wi hepyro pe nehe. Nekatu haw rupi hemu'e pe neze'eg rehe nehe.
\q1 
\v 30 Aruzar putar Tupàn ze'eg tuweharupi ihe nehe, a'e hezeupe kwehe mehe.
\q1 Azekaiw tuwe neremiapo putar haw rehe.
\q1 
\v 31 O Tupàn Tuweharupi Wiko Ma'e, Tuweharupi azapo ma'e nepurumu'e haw rupi ihe.
\q1 Hemumaranugar kar zo pe heretykaw rehe nehe.
\q1 
\v 32 Na'arewahy aha neremiapo kar heruzar pà ihe.
\q1 Nezewe mehe eremur putar ma'e ikwaw katu wera'u haw ihewe nehe.
\s1 Aruzar putar neze'eg ihe nehe
\q1 
\v 33 O Tupàn Tuweharupi Wiko Ma'e, hemu'e pe nehe. Nezewe mehe akwaw putar neze'eg ihe nehe.
\q1 Nezewe mehe aruzar putar tuweharupi nehe.
\q1 
\v 34 Ekwaw kar ma'e ihewe nehe. A'e mehe aruzar putar neze'eg nehe.
\q1 Azapo putar ma'e neze'eg rupi katete herahy haw hepy'a pe nehe.
\q1 
\v 35 Exak kar herape ràm ihewe neremiapo kar ikwaw kar pà nehe,
\q1 Ta'e herurywete heruzar mehe ihe xe.
\q1 
\v 36 Ema'ereko hepy'a pe nehe. Nezewe mehe hepureruzar wer putar nepurumu'e haw rehe ihe nehe.
\q1 Nezewe mehe naputar kwaw temetarer tetea'u ihe nehe, ma'e tetea'u ihe nehe.
\q1 
\v 37 Hemuma'enukwaw kar zo pe hekuzar 'ym ma'e rehe nehe.
\q1 Nekatu ihewe neremimume'u kwer rupi katete nehe.
\q1 
\v 38 Aiko neremiruze'eg romo ihe. Ezapo ma'e ihewe neremimume'u kwer nehe.
\q1 Eremume'u a'e ma'e newi ukyze ma'e wanupe no.
\q1 
\v 39 Hepyro teko herehe uze'eg zemueteahy haw wi nehe. Hemukyze kar a'e wà.
\q1 Nerezawy kwaw teko wanemiapo kwer imume'u mehe ne.
\q1 
\v 40 Hepureruzar wer tuwe neze'eg rehe ihe.
\q1 Hemukàg wi nehe, ta'e nekatuahy ne xe.
\s1 Herurywete neremiapo kar rehe
\q1 
\v 41 O Tupàn Tuweharupi Wiko Ma'e, exak kar heamutar katu haw ihewe nehe.
\q1 Hepyro pe heàmàtyry'ymar wanuwi neremimume'u kwer rupi katete nehe.
\q1 
\v 42 Nezewe mehe akwaw putar herehe uze'eg zemueteahy ma'e waze'eg iwazar haw ihe nehe,
\q1 Ta'e azeruzar neze'eg rehe ihe xe.
\q1 
\v 43 Hepytywà pe ze'eg azeharomoete har imume'u kar pà ihewe tuweharupi nehe.
\q1 Ta'e azeruzar teko wanemiapo kwer neremimume'u rehe ihe xe.
\q1 
\v 44 Tuweharupi aruzar putar neze'eg nehe.
\q1 Azapo putar ma'e neze'eg rupi katete 'ar nànàn nehe no.
\q1 
\v 45 Aiko putar ma'erahy wi màno haw wi utyryk ma'e ài nehe,
\q1 Ta'e azeagaw nepurumu'e haw heruzar pà ihe xe.
\q1 
\v 46 Amume'u putar neremiapo putar haw tuwihawete wanupe nehe.
\q1 Nahemaranugar kwaw wanuwi nehe.
\q1 
\v 47 Neremiapo kar hemurywete kar a'e,
\q1 Ta'e azamutar katu ihe xe.
\q1 
\v 48 Amuwete neremiapo kar ihe. Azamutar katu ihe no.
\q1 Hema'enukwaw katu neze'eg rehe.
\s1 Neze'eg àro
\q1 
\v 49 Aiko neremiruze'eg romo ihe.
\q1 Nema'enukwaw ihewe neremimume'u kwer rehe nehe. Àro ma'e, ta'e eremume'u a'e ma'e ne xe.
\q1 
\v 50 Ma'erahy ipuraraw mehe hemurywete kar pe ne,
\q1 Ta'e neremimume'u kwer umur wi nekàgaw ihewe xe.
\q1 
\v 51 Amo wanuwi wiko wera'u ma'e uze'eg zemueteahy waiko herehe tuweharupi wà.
\q1 Nezewe rehe we natyryk kwaw neze'eg wi ihe.
\q1 
\v 52 Hema'enukwaw, o Tupàn Tuweharupi Wiko Ma'e, neremimume'u kwer kwehe arer rehe.
\q1 Hemupytu'u kar hezai'o re.
\q1 
\v 53 Aikwahy teko ikatu 'ym ma'e
\q1 Neze'eg izuhazuhaw har wanexak mehe ihe.
\q1 
\v 54 Hereko haw ko ywy rehe har na'ipuku kwaw.
\q1 Nezewe mehe herekuwe mehe azapo zegar haw neremiapo kar ikatu haw imume'u haw ihe.
\q1 
\v 55 Pyhaw hema'enukwaw nerehe, o Tupàn Tuweharupi Wiko Ma'e.
\q1 Hema'enukwaw katu neze'eg rehe.
\q1 
\v 56 Hereko haw nànàn azapo amo ma'e ihe:
\q1 Aruzar neremiapo kar ihe.
\s1 Aruzar putar neze'eg nehe
\q1 
\v 57 Xo ne zo urereko ihe, o Tupàn Tuweharupi Wiko Ma'e. Naheta kwaw amo.
\q1 Amume'u putar ko ma'e newe kury. — Aruzar putar neze'eg nehe, a'e tuwe newe kury.
\q1 
\v 58 Hepy'a pe wahy haw rupi ainoz ko ma'e newe.
\q1 Hepuhareko pe neremimume'u kwer rupi katete nehe.
\q1 
\v 59 Hema'enukwaw tuweharupi heremiapo ràm rehe.
\q1 Amume'u ko ma'e kury. Ata putar nepurumu'e haw rupi nehe.
\q1 
\v 60 Nàro kwaw amo 'ar ihe.
\q1 Na'arewahy kutàri azeagaw neremiapo kar heruzar pà ihe.
\q1 
\v 61 Teko ikatu 'ym ma'e ipurupyhyk wer herehe wà, a'e rupi uzeagaw hepyhyk pà wà.
\q1 Nezewe rehe we naheharaz kwaw neze'eg wi ihe.
\q1 
\v 62 Apu'àm pyaze mehe nekatu haw imume'u pà ihe, ta'e nepurumu'e haw ikatuahy ihewe a'e xe.
\q1 
\v 63 Aiko newi ukyze ma'e paw wamyrypar romo ihe.
\q1 Aiko neze'eg heruzar har paw wamyrypar romo no.
\q1 
\v 64 O Tupàn Tuweharupi Wiko Ma'e, ywy tynehem nepuruamutar haw pupe a'e.
\q1 Hemu'e pe neremiapo kar rehe nehe.
\s1 Azeruzar neremiapo kar rehe
\q1 
\v 65 O Tupàn Tuweharupi Wiko Ma'e, erezapo tuwe ma'e neremimume'u kwer rupi katete ne.
\q1 Ikatu ma'e romo ereiko ihewe ko 'ar rehe. Aiko neremiruze'eg romo ihe.
\q1 
\v 66 Emur ma'e kwaw katu haw ihewe nehe. Ekwaw kar ma'e ihewe nehe.
\q1 Azeruzar neremiapo kar rehe.
\q1 
\v 67 Amo 'ar mehe erezepyk herehe. A'e 'ym mehe ata pe ikatu 'ym ma'e rupi.
\q1 Ko 'ar rehe aruzar neze'eg kury.
\q1 
\v 68 O Tupàn, nekatu ne. Erezapo ikatu ma'e no.
\q1 Hemu'e pe neremiapo kar rehe nehe.
\q1 
\v 69 Amo wanuwi wiko wera'u ma'e umume'u wemu'emaw hekutyr wà.
\q1 Hepy'a pe wahy haw rupi aruzar neremiapo kar ihe.
\q1 
\v 70 Tàtàahy a'e teko upy'a pe wà. Nuzekaiw kwaw neze'eg rehe wà.
\q1 Ihe herurywete neze'eg rehe ihe.
\q1 
\v 71 Ikatuahy herehe nezepyk awer.
\q1 Nezewe mehe azemu'e neremiapo kar rehe, te akwaw ihe.
\q1 
\v 72 Ze'eg neremimur kwer ikatu wera'u temetarer ywy nànànar paw wi ihewe,
\q1 Ma'e ywy nànànar paw wi ihewe.
\s1 Hema'enukwaw katu neze'eg rehe
\q1 
\v 73 O Tupàn, heapo pe nepo pupe ne. Hemonokatu pe no.
\q1 Emur ma'e kwaw paw ihewe nehe. Nezewe mehe azemu'e putar neze'eg rehe nehe.
\q1 
\v 74 Newi ukyze ma'e hurywete herexak mehe wà,
\q1 Ta'e azeruzar neze'eg rehe ihe xe.
\q1 
\v 75 O Tupàn Tuweharupi Wiko Ma'e, akwaw neremimume'u kwer ikatu haw ihe.
\q1 Erezepyk herehe, ta'e nerepuir kwaw neremiaihu wanuwi xe.
\q1 
\v 76 Aenoz ko ma'e newe ihe. Heamutar katu pe ne. Tuwe heamutar katu haw hemupytu'u kar hezemumikahy re nehe.
\q1 Eremume'u hemupytu'u kar àwàm ihewe amo 'ar mehe. Aiko neremiruze'eg romo.
\q1 
\v 77 Hepuhareko pe nehe. Nezewe mehe aikuwe putar nehe.
\q1 Neze'eg rehe hema'enukwaw paw ikatu ihewe.
\q1 
\v 78 Tuwe amo wanuwi wiko wera'u ma'e imaranugar wà nehe,
\q1 Ta'e umume'u temu'emaw hekutyr wà xe.
\q1 Ihe ihe, hema'enukwaw putar nepurumu'e haw rehe nehe.
\q1 
\v 79 Tuwe newi ukyze ma'e ur uzemyrypar pà herehe we wà nehe.
\q1 Tuwe neremiapo kar kwaw par ur hepytywà pà wà nehe no.
\q1 
\v 80 Tuwe aruzar tuwe neremiapo kar ihe nehe.
\q1 A'e mehe nahemaranugar pixik kwaw nezewe heremiapo rehe ihe nehe.
\s1 Teko upuner neze'eg rehe uzeruzar haw rehe wà
\q1 
\v 81 O Tupàn, hepyro pe heàmàtyry'ymar wanuwi nehe.
\q1 Hekene'o hepyro àwàm hàro pà.
\q1 Azeruzar neze'eg rehe.
\q1 
\v 82 Hereha ikene'o, ta'e ume'e tetea'u iko xe.
\q1 Àro neremimume'u kwer iteko ihe xe.
\q1 Apuranu nerehe kury. — Màràn mehe erezur putar hemupytu'u kar pà hezemumikahy re nehe.
\q1 
\v 83 Xityk uwà hyru izemàner ma'e zane, ta'e na'ikatu kwaw a'e xe.
\q1 Naiko kwaw izemàner ma'e romo ihe. Naheharaz kwaw neremiapo kar wi ihe.
\q1 
\v 84 Màràn mehe apytu'u putar hàro re nehe.
\q1 Màràn mehe erezepyk putar ma'erahy ihewe ipuraraw kar har wanehe nehe.
\q1 
\v 85 Amo wanuwi wiko wera'u ma'e nuweruzar kwaw neze'eg wà.
\q1 Uzapo ywykwaruhu hepyhyk àwàm romo wà. Ipurupyhyk wer herehe miar ài wà.
\q1 
\v 86 Neremiapo kar paw ikatu wà. Teko upuner wanehe uzeruzar haw rehe wà.
\q1 Hepytywà pe nehe, ta'e hemu'em ma'e upuraraw kar ma'erahy ihewe wà xe.
\q1 
\v 87 Hezuka tària'i wà.
\q1 Nezewe rehe we naityk kwaw neremiapo kar ihe.
\q1 
\v 88 Heamutar katu pe ne. A'e rupi hepyro pe hemàno haw wi nehe.
\q1 A'e rupi apuner putar neremiapo kar heruzar haw rehe nehe.
\s1 Neze'eg wiko putar tuweharupi nehe
\q1 
\v 89 O Tupàn Tuweharupi Wiko Ma'e, neze'eg nupaw pixik kwaw nehe.
\q1 Ikàgaw nuzawy kwaw ywak ikàgaw a'e.
\q1 
\v 90 Erezapo ywy. Upyta a'e pe.
\q1 Puruwi netyryk 'ymaw nuzeapo pixik kwaw amo ae ma'e romo a'e nehe. Nuzawy kwaw ywy a'e.
\q1 
\v 91 Ma'e paw upyta wenaw rehe
\q1 Neze'eg awer heruzar katu pà wà,
\q1 Ta'e ma'e paw nereruzar a'e wà xe.
\q1 
\v 92 Aze mo neze'eg nahemurywete kar iwer, amàno mo kwehe mehe ihe,
\q1 Ta'e apuraraw ma'erahy tetea'u ihe xe.
\q1 
\v 93 Naheharaz pixik kwaw nepurumu'e haw wi nehe,
\q1 Ta'e eremonokatu hereko haw nepurumu'e haw rupi ne xe.
\q1 
\v 94 Hepyro pe heàmàtyry'ymar wanuwi nehe, ta'e aiko neremiruze'eg romo ihe xe.
\q1 Azeagaw neremiapo kar heruzar pà tuweharupi ihe.
\q1 
\v 95 Ikatu 'ym ma'e wàro hezuka àwàm 'ar waiko wà.
\q1 Nezewe rehe we hema'enukwaw putar neze'eg rehe nehe.
\q1 
\v 96 Ma'e paw wakatu haw upaw putar nehe.
\q1 Neremiapo kar nupaw kwaw nehe.
\s1 Azamutar katu neze'eg ihe
\q1 
\v 97 Azamutar katu tuwe neze'eg ihe.
\q1 Amumaw 'ar katu hehe hema'enukwaw pà.
\q1 
\v 98 Neremiapo kar upyta herehe we tuweharupi.
\q1 A'e rupi akwaw wera'u ma'e heàmàtyry'ymar wanuwi ihe.
\q1 
\v 99 Akwaw wera'u ma'e hemu'e arer paw wanuwi ihe,
\q1 Ta'e hema'enukwaw nepurumu'e haw rehe ihe xe.
\q1 
\v 100 Akwaw wera'u ma'e awa tua'uhez ma'e wanuwi ihe,
\q1 Ta'e aruzar neremiapo kar ihe xe.
\q1 
\v 101 Nata kwaw pe ikatu 'ymaw piar rupi ihe,
\q1 Ta'e hepureruzar wer neze'eg rehe ihe xe.
\q1 
\v 102 Napytu'u kwaw neremiapo putar haw heruzar ire,
\q1 Ta'e hemu'e pe ne xe.
\q1 
\v 103 Neze'eg hete katu tuwe a'e.
\q1 Hete katu wera'u hàir wi.
\q1 
\v 104 Akwaw katu ma'e ihe, ta'e aruzar neze'eg xe.
\q1 A'e rupi naheakatuwawahy kwaw temu'emaw piar nànàn ihe.
\s1 Neze'eg tatainy ài hekon
\q1 
\v 105 Neze'eg nuzawy kwaw tatainy herape ràm rehe uhyape katu ma'e.
\q1 Nuzawy kwaw tatainy hereko haw rehe herape zàwenugar rehe uhyape katu ma'e.
\q1 
\v 106 Azapo putar heremimume'u kwer ihe nehe.
\q1 Aruzar putar nepurumu'e haw ikatu ma'e nehe no.
\q1 
\v 107 O Tupàn Tuweharupi Wiko Ma'e, ma'erahy heremipuraraw iaiw ihewe a'e.
\q1 Hemuigo kar wiwi pe neremimume'u kwer rupi katete nehe.
\q1 
\v 108 O Tupàn Tuweharupi Wiko Ma'e, einu heze'eg nekatu haw heremimume'u ràm nehe.
\q1 Hemu'e pe neremiapo kar rehe nehe.
\q1 
\v 109 Tuweharupi amo uzeagaw hezuka pà a'e wà.
\q1 Nezewe rehe we naheharaz kwaw neze'eg wi.
\q1 
\v 110 Teko ikatu 'ym ma'e uzapo miar zuka haw zàwenugar hepyhyk àwàm wà.
\q1 Nezewe rehe we nazuhaw kwaw neremiapo kar ihe.
\q1 
\v 111 Nepurumu'e haw nuzuawy kwaw temetarer tetea'u a'e. Areko putar tuweharupi nehe.
\q1 Umurywete kar hepy'a.
\q1 
\v 112 — Aruzar putar Tupàn hemiapo putar tuweharupi ihe nehe, a'e tuwe hezeupe.
\q1 Herekuwe mehe we napytu'u kwaw heruzar ire nehe.
\s1 Azamutar nepurumu'e haw ihe
\q1 
\v 113 Naheakatuwawahy kwaw nerehe uzeruzar mua'u ma'e wanehe ihe.
\q1 Azamutar katu neze'eg.
\q1 
\v 114 Ereiko hemimaw romo. Ereiko u'yw wi hemimaw zàwenugar romo no.
\q1 Eremume'u ma'e ihewe neremiapo ràm. Àro a'e ma'e iteko ihe.
\q1 
\v 115 Petyryk ihewi nehe, ikatu 'ym ma'e iapo har wà.
\q1 Aruzar putar Tupàn hezar hemiapo kar nehe.
\q1 
\v 116 Emur nekàgaw ihewe neremimume'u kwer rupi nehe. A'e rupi aikuwe wiwi putar nehe.
\q1 Àro ikatu ma'e ihewe neremiapo ràm ihe. Hemuzemumikahy kar zo pe a'e ma'e iapo 'ym pà nehe.
\q1 
\v 117 Hepytywà pe nehe. Nezewe mehe ni amo nahezuka kwaw wà nehe.
\q1 Azekaiw putar neremiapo putar haw rehe tuweharupi nehe.
\q1 
\v 118 Ereityk neze'eg heruzar 'ymar paw ne wà,
\q1 Ta'e hemu'em wemiapo ràm imume'u mehe wà xe.
\q1 
\v 119 Ereityk ikatu 'ym ma'e paw ma'e heityk pyrer ài ne wà.
\q1 A'e rupi azamutar katu nepurumu'e haw ihe.
\q1 
\v 120 Aryryryryz nerenataromo.
\q1 Akyze neremimume'u kwer wi.
\s1 Tuweharupi azapo ma'e neremimu'e rupi
\q1 
\v 121 Tuweharupi azapo ikatu ma'e iawy 'ym pà.
\q1 Hemono zo pe heàmàtyry'ymar wapo pe nehe.
\q1 
\v 122 Aiko neremiruze'eg romo. Emume'u hepytywà àwàm ihewe kury.
\q1 Emupytu'u kar amo wanuwi wiko wera'u ma'e ne wà nehe, nezewe mehe nupuraraw kar kwaw ma'erahy ihewe wà nehe.
\q1 
\v 123 Hereha ikene'o ta'e ame'e tetea'u ihe xe.
\q1 Àro tetea'u hepyro àwàm iteko ihe.
\q1 Àro neremimume'u kwer iapo àwàm no.
\q1 
\v 124 Herereko katu pe nepuruamutar katu haw rupi nehe.
\q1 Hemu'e pe neremiapo kar rehe nehe.
\q1 
\v 125 Aiko neremiruze'eg romo. A'e rupi emur ma'e kwaw paw ihewe nehe.
\q1 Nezewe mehe apuner putar nepurumu'e awer ikwaw paw rehe ihe nehe.
\q1 
\v 126 O Tupàn Tuweharupi Wiko Ma'e, aze erezapo ma'e na'arewahy nehe kury, ikatu putar nehe kury, ta'e teko nuweruzar kwaw neze'eg ko 'ar rehe wà xe.
\q1 
\v 127 Azamutar katu neremiapo kar ihe.
\q1 Ikatu wera'u ihewe itazu or wi a'e.
\q1 Ikatu wera'u ihewe or ikatuahy ma'e wi.
\q1 
\v 128 A'e rupi ata nepurumu'e awer rupi.
\q1 Temu'emaw rupi teko waata haw iro ihewe.
\s1 Neze'eg imume'u katu haw werur tatainy purupe
\q1 
\v 129 Neremiapo kar ikatuahy.
\q1 A'e rupi aruzar tuwe iteko ihe.
\q1 
\v 130 Neze'eg imume'u katu haw nuzawy kwaw tatainy herur haw purupe.
\q1 Ukwaw kar ma'e teko ma'e kwaw par 'ym wanupe.
\q1 
\v 131 Azurupeka hepytuhem pà.
\q1 Aputar neremiapo kar heruzar haw amo ma'e wanuwi upaw rupi katete ihe.
\q1 
\v 132 Ereme'egatu neamutar katu har wanehe wapuhareko katu pà.
\q1 Eme'e wi herehe nezewegatete nehe no.
\q1 
\v 133 Hemonokatu pe neremimume'u kwer rupi nehe.
\q1 Ikatu 'ymaw emuigo kar zo hezar romo nehe.
\q1 
\v 134 Hepyro pe ihewe ikatu 'ym ma'e iapo har wanuwi nehe.
\q1 Nezewe mehe apuner putar neremiapo kar heruzar haw rehe nehe.
\q1 
\v 135 Emur neze'egatu herehe nehe, herehe we nereko pà nehe.
\q1 Hemu'e pe neze'eg rehe nehe.
\q1 
\v 136 Herehaykwer uwyryk yrykawhu ài,
\q1 Ta'e amogwer nuweruzar kwaw neze'eg wà xe.
\s1 Neremimume'u kwer ikatuahy
\q1 
\v 137 Nekatuahy, o Tupàn Tuweharupi Wiko Ma'e.
\q1 Neze'eg ikatuahy.
\q1 
\v 138 Nepurumu'e awer urewe neremimur kwer ikatu tuwe a'e.
\q1 Ikatuahy tuwe a'e.
\q1 
\v 139 Hekwahy haw herapy tata ài,
\q1 Ta'e heàmàtyry'ymar nuzekaiw kwaw neze'eg rehe wà xe.
\q1 
\v 140 Ikàg tuwe neremiapo ràm imume'u pyrer.
\q1 Ihe neremiruze'eg ihe, azamutar katu a'e neremimume'u kwer ihe.
\q1 
\v 141 Aiko hemetarer pixika'i ma'e romo. Teko nuzekaiw kwaw herehe wà.
\q1 Nezewe rehe we nahereharaz kwaw nepurumu'e haw wi.
\q1 
\v 142 Nekatu haw nupaw pixik kwaw nehe.
\q1 Neze'eg azeharomoete tuweharupi.
\q1 
\v 143 Azemumikahy tuwe ma'erahy ipuraraw pà ihe.
\q1 Neremiapo kar hemurywete kar a'e.
\q1 
\v 144 Nepurumu'e awer ikatu tuweharupi.
\q1 Ekwaw kar ma'e ihewe nehe. Nezewe mehe aikuwe wiwi putar nehe.
\s1 Àro ma'e neze'eg rupi izeapo àwàm
\q1 
\v 145 Hepy'a nàn ahapukaz newe.
\q1 Ewazar heze'eg ihewe nehe, o Tupàn Tuweharupi Wiko Ma'e.
\q1 Nezewe mehe aruzar putar neremiapo kar nehe.
\q1 
\v 146 Aze'eg newe hepytywà àwàm henoz pà.
\q1 Hepyro pe heàmàtyry'ymar wanuwi nehe.
\q1 A'e mehe aruzar putar neremiapo putar haw nehe.
\q1 
\v 147 Kwarahy ihem 'ym mehe we aze'eg newe hepytywà àwàm henoz pà, ta'e azeruzar neremimume'u kwer rehe ihe xe.
\q1 Àro neremiapo ràm iteko.
\q1 
\v 148 Naker kwaw.
\q1 Amumaw pytun gatu heme'e pà, ta'e hema'enukwaw katu wer neze'eg rehe ihe xe.
\q1 
\v 149 Herenu pe nehe, o Tupàn Tuweharupi Wiko Ma'e, ta'e heamutar katu pe ne xe.
\q1 Hemuigo kar wiwi nehe, aze ereputar tuwe nezewe haw nehe.
\q1 
\v 150 Teko iaiw ma'e herehe ipuruàmàtyry'ym wer ma'e uhem waiko heruwake wà.
\q1 Teko neze'eg heruzar pixik 'ymar romo wanekon wà.
\q1 
\v 151 Ne Tupàn Tuweharupi Wiko Ma'e ereiko heruwake ne.
\q1 Neremiapo kar paw azeharomoete a'e wà.
\q1 
\v 152 Kwehe akwaw nepurumu'e haw ihe.
\q1 Eremur purupe ne, ta'e neremumaw pixik kwaw nehe xe.
\s1 Neze'eg paw rupi katete azeharomoete a'e
\q1 
\v 153 O Tupàn, eme'e ma'erahy heremipuraraw rehe nehe.
\q1 Hepytywà pe nehe, ta'e naityk kwaw neze'eg ihe xe.
\q1 
\v 154 Eityk heàmàtyry'ymar ne wà nehe, ihewi wamunyryk kar pà ne wà nehe.
\q1 Hemuigo kar wiwi pe neremimume'u kwer rupi nehe.
\q1 
\v 155 Nerepyro kwaw ikatu 'ym ma'e ma'erahy wi ne wà,
\q1 Ta'e nuzekaiw kwaw neze'eg rehe wà xe.
\q1 
\v 156 Uhua'u nepurupuhareko haw, o Tupàn Tuweharupi Wiko Ma'e.
\q1 Hemuigo kar wiwi neremimutar rupi nehe.
\q1 
\v 157 Heta tetea'u heàmàtyry'ymar wà. Heta tetea'u ihewe ma'erahy ipuraraw kar har wà no.
\q1 Ihe napytu'u kwaw neremiapo kar heruzar ire ihe.
\q1 
\v 158 Nerehe uzeruzar 'ym ma'e wanehe heme'e mehe hehuhuk wer ihe.
\q1 Ta'e nuweruzar kwaw neze'eg wà xe.
\q1 
\v 159 Eme'e herehe kury. Azamutar katu nepurumu'e awer ihe, o Tupàn Tuweharupi Wiko Ma'e.
\q1 Hemuigo kar wiwi pe nehe, ta'e heamutar katu pe ne xe.
\q1 
\v 160 Neze'eg paw azeharomoete.
\q1 Neremiapo kar ikatu. Nupaw pixik kwaw nehe.
\s1 Amuawate neremiapo kar
\q1 
\v 161 Ikàg ma'e heàmàtyry'ym e a'e wà.
\q1 Amuwete neremiapo kar.
\q1 
\v 162 Herurywete tuwe neremimume'u kwer wanehe.
\q1 Herurywete temetarer tetea'u ma'e hexak arer ài ihe.
\q1 
\v 163 Temu'emaw iro ihewe. Naheakatuwawahy kwaw hehe.
\q1 Azamutar katu neze'eg.
\q1 
\v 164 Tuweharupi 7 haw amume'u nekatu haw,
\q1 Ta'e neremimume'u kwer ikatuahy a'e xe.
\q1 
\v 165 Neze'eg iamutar katu har ikàg a'e wà.
\q1 Naheta kwaw ma'e a'e teko wamu'ar kar har wà.
\q1 
\v 166 Àro hepyro àwàm heàmàtyry'ymar wanuwi ihe, o Tupàn Tuweharupi Wiko Ma'e,
\q1 Ta'e aruzar neremiapo kar ihe xe.
\q1 
\v 167 Aruzar nepurumu'e awer.
\q1 Azamutar katu tuwe nepurumu'e awer hepy'a pupe ihe.
\q1 
\v 168 Aruzar neremiapo kar. Neremiapo putar haw aruzar no.
\q1 Erexak heremiapo kwer upaw rupi.
\s1 Neze'eg hemurywete kar a'e
\q1 
\v 169 Tuwe hepytywà àwàm henoz taw uhem newe nehe, o Tupàn Tuweharupi Wiko Ma'e.
\q1 Emur ma'e kwaw katu haw ihewe neremimume'u kwer rupi nehe.
\q1 
\v 170 Tuwe newe heze'egaw uhem nerenataromo nehe.
\q1 Hepyro pe heàmàtyry'ymar wanuwi
\q1 Neremimume'u kwer rupi nehe.
\q1 
\v 171 Amume'u putar nekatu haw tuweharupi nehe,
\q1 Ta'e hemu'e pe neze'eg rehe ne xe.
\q1 
\v 172 Azegar putar neze'eg rehe nehe, ta'e neremiapo kar ikatu a'e xe.
\q1 
\v 173 O Tupàn, tuwe nepo uzemuàgà'ym hepytywà pà nehe,
\q1 Ta'e aruzar neremiapo kar ihe xe.
\q1 
\v 174 O Tupàn Tuweharupi Wiko Ma'e, aputar tuwe hepytywà àwàm ihe.
\q1 Hepytywà pe nehe. Neze'eg inuromo aexak herurywete haw.
\q1 
\v 175 Hemuigo kar wiwi pe nehe, o Tupàn. Nezewe mehe apuner putar nekatu haw imume'u pà nehe.
\q1 Tuwe nepurumu'e haw hepytywà nehe.
\q1 
\v 176 Ata e aha teko àràpuhàràn hawitu ma'e ukàzym ma'e kwer ài.
\q1 O Tupàn Tuweharupi Wiko Ma'e, aiko neremiruze'eg romo ihe.
\q1 Ezur hepiaromo nehe, ta'e naheharaz kwaw neremiapo kar wi ihe xe.
\c 120
\s1 Upytywà àwàm henoz taw Tupàn pe
\q1 
\v 1 Hezemumikahy mehe aze'eg Tupàn Tuweharupi Wiko Ma'e pe ihe, hepytywà àwàm henoz pà ihe.
\q1 Uwazar heze'eg ihewe a'e.
\q1 
\v 2 O Tuweharupi Wiko Ma'e, hemunyryk kar pe
\q1 Hemu'em ma'e wanuwi nehe, hemu'em tuwe ma'e wanuwi nehe.
\b
\q1 
\v 3 Pe hemu'em ma'e pe. Ma'e Tupàn uzapo putar peme a'e nehe.
\q1 Ma'e uzapo putar penehe uzepyk pà nehe.
\q1 
\v 4 Upyro putar u'yw haime ma'e amo zauxiapekwer wi nehe. Pezywà putar ipupe penehe uzepyk pà nehe.
\q1 Upyhyk putar tàtàpyzgwer imono pà penehe nehe, penehe uzepyk pà nehe.
\b
\q1 
\v 5 Peinuromo hereko haw upuraraw kar ma'erahy ihewe
\q1 Mezek ywy rehe hereko haw ài,
\q1 Kenar ywy rehe hereko haw ài.
\q1 
\v 6 Amumaw kwarahy tetea'u amo teko wainuinuromo ihe.
\q1 A'e teko na'iakatuwawahy kwaw puruàmàtyry'ym 'ymaw rehe wà.
\q1 
\v 7 Zeàmàtyry'ym 'ymaw rehe heze'eg mehe,
\q1 — Uruputar zeàmàtyry'ymawhu, i'i a'e teko wà.
\c 121
\s1 Tupàn wiko zanemonokatu har romo a'e
\q1 
\v 1 Ame'e ywytyr rehe hepuranu pà.
\q1 — Ma'e wi ur putar hepytywà àwàm nehe, a'e hezeupe.
\q1 
\v 2 Hepytywà àwàm ur putar Tupàn Tuweharupi Wiko Ma'e wi nehe.
\q1 Ywak iapo arer romo ywy iapo arer romo hekon a'e.
\b
\q1 
\v 3 Nanemu'ar kar kwaw a'e nehe.
\q1 Nerehe uzekaiw ma'e romo hekon a'e. Tuweharupi ume'e iko.
\q1 
\v 4 Wiko teko Izaew wanehe uzekaiw ma'e romo a'e.
\q1 Nuker pixik kwaw. Ni nuker wewera'i pixik kwaw a'e.
\q1 
\v 5 Tupàn Tuweharupi Wiko Ma'e uzekaiw putar nerehe nehe.
\q1 Tuweharupi neruwake hekon nepyro pà.
\q1 
\v 6 'Ar romo kwarahy nanemuahy kwaw nehe.
\q1 Pyhaw zahy nanemuahy kwaw nehe no.
\q1 
\v 7 Tupàn Tuweharupi Wiko Ma'e uzekaiw putar nerehe ikatu 'ym ma'e wi paw nepyro pà a'e nehe.
\q1 Omonokatu putar nereko haw ikatu 'ymaw wi nehe.
\q1 
\v 8 Neho mehe uzekaiw putar nerehe nehe.
\q1 Nezewyr mehe uzekaiw putar nerehe nehe no, ko 'ar rehe nehe, tuweharupi nehe no.
\c 122
\s1 Zeruzarez tawhu ikatuahy a'e
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 — Zaha Tupàn Tuweharupi Wiko Ma'e hàpuzuhu pe nehe, i'i ihewe wà.
\q1 Herurywete waze'eg mehe.
\q1 
\v 2 Zaiko xe
\q1 Zeruzarez pe zane kury.
\b
\q1 
\v 3 Zeruzarez a'e, tawhu iapo wi pyrer romo a'e.
\q1 Teko uzemono'og wà xe wà.
\q1 
\v 4 Izaew ta'yr wazuapyapyr
\q1 Uzeupir xe wà.
\q1 Umume'u Tupàn Tuweharupi Wiko Ma'e hemiapo kwer ikatu haw wà wà,
\q1 Ta'e a'e umume'u kar wanupe a'e xe.
\q1 
\v 5 Tàmuzgwer uzemono'og xe teko wanemiapo kwer imume'u pà wà.
\q1 Tuwihawete umume'u wemiaihu wanemiapo kwer xe no.
\b
\q1 
\v 6 Peze'eg Tupàn pe zeàmàtyry'ym 'ymaw Zeruzarez tawhu pe har henoz tà izupe nehe.
\q1 — O Zeruzarez, tuwe neamutar katu har wiko katu wà nehe.
\q1 
\v 7 A'e tawhu pàrirogaw aiha ma'e hereko har a'e, tuwe heta zeàmàtyry'ym 'ymaw xe nehe.
\q1 Tuwe zauxiapekwer amo ae ywy rehe har nuixe kwaw tàpuzuhu nerehe har pupe teko wazuka pà wà nehe, a'e newe.
\q1 
\v 8 Azamutar katu heywy rehe har ihe wà. Herehe we har azamutar katu ihe wà no.
\q1 A'e rupi aze'eg nezewe Zeruzarez pe ihe. — Tuwe zeàmàtyry'ym 'ymaw upyta nerehe nehe, a'e newe.
\q1 
\v 9 Azamutar katu Tupàn Tuweharupi Wiko Ma'e Zanezar hàpuzuhu ihe.
\q1 A'e rupi aze'eg izupe Zeruzarez heko katu haw imur kar pà izupe ihe.
\c 123
\s1 O Tupàn, hepuhareko katu pe nehe
\q1 
\v 1 O Tupàn Tuweharupi Wiko Ma'e, ame'e nekutyr ywate.
\q1 Ywak rehe ereapyk nerenaw rehe.
\q1 
\v 2 Awa omono temi'u awa uma'ereko e ma'e wanupe a'e.
\q1 Kuzà omono temi'u kuzà uma'ereko e ma'e wanupe no.
\q1 Nezewegatete urume'e nerehe, o Tupàn Tuweharupi Wiko Ma'e urezar.
\q1 Urepuhareko pe nehe. Uruàro urepuhareko àwàm uruiko.
\q1 
\v 3 Urepuhareko pe nehe, o Tuweharupi Wiko Ma'e.
\q1 Urepuhareko pe nehe, ta'e teko na'uremuawate kwaw wà xe.
\q1 
\v 4 Tuweharupi hemetarer katu ma'e na'uremuawate kwaw wà.
\q1 Amo wanuwi wiko wera'u ma'e uze'eg urywahyahy urerehe wà no.
\c 124
\s1 Tupàn wiko wemiaihu wapyro har romo a'e
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 Aze mo Tupàn Tuweharupi Wiko Ma'e nuiko iwer zanemyrypar romo,
\q1 Ma'e uzeapo mo zanewe.
\q1 Teko Izaew izuapyapyr wà, pewazar heze'eg ihewe nehe.
\b
\q1 
\v 2 Teko uwazar nezewe wà.
\q1 — Aze mo Tupàn Tuweharupi Wiko Ma'e nuiko iwer mo zanemyrypar romo,
\q1 Zaneàmàtyry'ymar zanekutyr wanur mehe,
\q1 
\v 3 Zanemukun mo zanereko we mehe wà xe.
\q1 Wikwahy mehe uzewyr mo zanekutyr wà.
\q1 
\v 4 'Y zanereraha mo muite a'e.
\q1 Tynehemaw zanepyk mo no.
\q1 
\v 5 Zamàno mo 'y uwyrykahy ma'e pupe, i'i teko wà.
\b
\q1 
\v 6 Ximume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw izupe nehe.
\q1 Nazanemumaw kar kwaw zaneàmàtyry'ymar wanupe a'e mehe.
\q1 
\v 7 Uzemi'i kar ma'e upyhyk wiràmiri ipyhykaw pupe a'e. Zaiko ipyhykaw wi uhem ma'e kwer ài.
\q1 Upen ipyhykaw. Nazanepyhyk kwaw a'e.
\q1 
\v 8 Zanepytywà haw ur Tupàn Tuweharupi Wiko Ma'e wi.
\q1 Uzapo ywak a'e. Uzapo ywy no.
\c 125
\s1 Tupàn rehe uzeruzar ma'e wiko ikàg ma'e romo a'e wà
\q1 
\v 1 Tupàn Tuweharupi Wiko Ma'e rehe uzeruzar ma'e
\q1 Wiko Xiàw ywytyr ài wà.
\q1 Teko nupuner kwaw Xiàw heitykaw rehe wà.
\q1 Ikàg tuweharupi a'e.
\q1 
\v 2 Heta ywytyruhu Zeruzarez izywyr.
\q1 Nezewegatete Tupàn Tuweharupi Wiko Ma'e wiko wemiaihu waiwyr a'e,
\q1 Ko 'ar rehe, tuweharupi nehe no.
\b
\q1 
\v 3 Amo 'ar mehe ikatu 'ym ma'e upytu'u putar Tupàn hemiaihu waywy izar romo wiko re wà nehe.
\q1 Aze mo nupytu'u iwer, a'e mehe mo te ikatu ma'e uzypyrog mo ikatu 'ym ma'e iapo pà wà no.
\b
\q1 
\v 4 O Tupàn Tuweharupi Wiko Ma'e, nekatu ikatu ma'e wanupe nehe,
\q1 Neremiapo kar heruzar har wanupe nehe.
\q1 
\v 5 Ikatu 'ym ma'e wanehe nezepyk mehe nehe,
\q1 Ezepyk nerape wi utyryk ma'e kwer wanehe nehe no.
\b
\q1 Tuwe zeàmàtyry'ym 'ymaw tuz teko Izaew wanehe nehe.
\c 126
\s1 Tupàn uzapo uhua'u ma'e wemiaihu wanupe
\q1 
\v 1 Tupàn Tuweharupi Wiko Ma'e zanemuzewyr kar zanereruwà Zeruzarez pe a'e.
\q1 A'e 'ar mehe uzeapo ma'e kwer nuzawy kwaw zanepuahu haw zanewe.
\q1 
\v 2 Zapuka tetea'u zanezegar pà zanerurywete haw rupi.
\q1 Na'e amogwer ywy rehe har uze'eg nezewe wà.
\q1 — Tupàn Tuweharupi Wiko Ma'e uzapo uhua'u ma'e a'e teko wanupe a'e, i'i wà.
\q1 
\v 3 Azeharomoete, Tupàn Tuweharupi Wiko Ma'e uzapo uhua'u ma'e zanewe a'e.
\q1 A'e rupi zanerurywete zane.
\b
\q1 
\v 4 Àmàn neremimugyr kar uwyryk yrykawhu uxinig ma'e rupi a'e.
\q1 Nezewegatete o Tuweharupi Wiko Ma'e, uremuigo kar pe temi'u hereko har romo ma'e hereko har romo nehe.
\q1 
\v 5 Teko ma'e tym mehe uzai'o ma'e a'e wà,
\q1 Hurywete putar ipo'o mehe wà nehe.
\q1 
\v 6 Ma'eà'yz itym pyràm heraha har uzai'o ma'e wà,
\q1 Uzewyr putar uzegar pà urywete romo wà nehe.
\q1 Werur putar arozràn haryw uzywa rehe wà nehe.
\c 127
\s1 Tupàn omono uze'egatu tàpuz me har wanehe
\q1 
\v 1 Aze Tupàn Tuweharupi Wiko Ma'e nuzapo kwaw tàpuz,
\q1 Iapo har uma'ereko e iapo mehe wà.
\q1 Aze Tuweharupi Wiko Ma'e nuzekaiw kwaw tawhu rehe,
\q1 Zauxiapekwer ume'e e hehe uzekaiw mehe wà.
\q1 
\v 2 Aze amo uma'ereko tetea'u wemi'u ràm imono'og pà,
\q1 Aze upu'àm izi'itahy, aze u'aw wi oho xo pyaze mehe, uma'ereko e a'e.
\q1 Ta'e Tupàn omono temi'u wemiamutar katu wanupe a'e xe.
\q1 Te waker mehe Tupàn uzapo ikatu ma'e wemiaihu pe.
\b
\q1 
\v 3 Zanera'yr a'e wà, wiko Tupàn Tuweharupi Wiko Ma'e hemimur kwer romo a'e wà.
\q1 Ze'egatu haw romo wanekon wà.
\q1 
\v 4 Aze ta'yr uzexak kar awa pe ipyahu mehe we wà,
\q1 A'e ta'yr nuzawy kwaw u'yw zauxiapekwer ipo pe har wà.
\q1 
\v 5 Hurywete awa agwer u'yw tetea'u wanereko har a'e.
\q1 Iàmàtyry'ymar nuweityk kwaw wà nehe,
\q1 Tuwihaw wanenataromo waneko mehe wà nehe.
\c 128
\s1 Tupàn umekuzar weruzar har wà
\q1 
\v 1 Hurywete Tupàn Tuweharupi Wiko Ma'e wi ukyze ma'e a'e,
\q1 Hemimutar rupi wiko ma'e a'e.
\q1 
\v 2 Aze ereiko izàwe nehe, neremimono'og ràm uhyk putar newe nehe.
\q1 Nerurywete putar nehe no.
\q1 Ikatu ma'e uzeapo putar newe nehe.
\q1 
\v 3 Nereko haw pe neremireko wiko putar uwà 'yw i'a tetea'u ma'e ài newe nehe.
\q1 Nera'yr nuzawy kwaw uri tyw ipyahu ma'e ywyrapew nemai'u mehe har izywyr wà nehe.
\q1 
\v 4 Tupàn Tuweharupi Wiko Ma'e wi ukyze ma'e
\q1 Wiko putar nezewe azeharomoete nehe, ze'egatu ipyhyk pà nehe.
\b
\q1 
\v 5 Tuwe Tupàn Tuweharupi Wiko Ma'e Xiàw ywytyr rehe har
\q1 Umur uze'egatu nerehe nehe.
\q1 Tuwe ne'ar nànàn erexak Zeruzarez ikàg wera'u haw nehe no.
\q1 
\v 6 Tuwe erexak neremimino ne wà nehe.
\b
\q1 Tuwe zeàmàtyry'ym 'ymaw teko Izaew izuapyapyr wanehe tuz a'e nehe.
\c 129
\s1 Teko ipuruàmàtyry'ym wer Izaew wanehe a'e wà. Nezewe rehe we nuweityk kwaw wà
\q1 
\v 1 Teko Izaew izuapyapyr wà,
\q1 Pekwarer mehe arer we peàmàtyry'ymar upuraraw kar ma'erahy peme wà.
\q1 Pemume'u wanemiapo kwer nehe.
\q1 
\v 2 Nezewe i'i teko wà.
\q1 — Urekwarer mehe arer we ureàmàtyry'ymar upuraraw kar tuwe ma'erahy urewe wà.
\q1 Nezewe rehe we na'urereityk kwaw wà.
\q1 
\v 3 Ywy heruwaruwakaw uzapo perew zàwenugar ywy rehe.
\q1 Nezewegatete ureàmàtyry'ymar uzapo perew iaiw ma'e urekupe pe wà.
\q1 
\v 4 Tupàn Tuweharupi Wiko Ma'e ikatu a'e.
\q1 Zanepyro a'e, zanezar ikatu 'ym ma'e wanuwi a'e, i'i teko wà.
\b
\q1 
\v 5 Tuwe amo weityk Zeruzarez rehe iakatuwawahy 'ymar wà nehe.
\q1 Tuwe uzàn weityk arer wanuwi wà nehe.
\q1 
\v 6 Tuwe wiko ka'akyr tàpuz 'aromo hezuz ma'e ài wà nehe.
\q1 Ka'akyr uxinig o'ok 'ym mehe we a'e.
\q1 
\v 7 Teko nomono'og kwaw a'e ka'akyr wà.
\q1 Nuzàpixipixi kwaw wà. Nueraha kwaw wàpuz me wà. Weityk wà.
\q1 
\v 8 Tuwe teko a'e teko wanuwake ukwaw ma'e nuze'eg kwaw nezewe wà nehe.
\q1 — Tuwe Tupàn umur uze'egatu penehe nehe.
\q1 Ure oromono ureze'egatu penehe Tupàn Tuweharupi Wiko Ma'e her rehe ure, tuwe ni'i kwaw wanupe wà nehe.
\c 130
\s1 Aenoz hepytywà àwàm Tupàn pe ihe
\q1 
\v 1 O Tupàn Tuweharupi Wiko Ma'e,
\q1 Ma'erahy iaiw ma'e ipuraraw mehe uruenoz ihe.
\q1 
\v 2 Herenu pe newe heze'eg mehe wahy haw rupi nehe, o hezar.
\q1 Herenu pe hepytywà àwàm newe hereminoz nehe.
\q1 
\v 3 Aze eremuapyk ureremiapo kwer ikatu 'ym ma'e pape rehe,
\q1 Mo upuner nezepyk àwàm wi uhemaw rehe wà nehe.
\q1 
\v 4 Ne eremunàn ureremiapo kwer ikatu 'ym ma'e ne.
\q1 A'e rupi urukyze newi.
\b
\q1 
\v 5 Àrogatu hepytywà àwàm iteko Tupàn Tuweharupi Wiko Ma'e henataromo ihe.
\q1 Azeruzar ize'eg rehe.
\q1 
\v 6 Tawhu rehe uzekaiw ma'e zauxiapekwer wàro iku'emaw wà.
\q1 Àro wera'u hezar ihe.
\q1 Wàro kwarahy ihemaw wà. Àro wera'u hezar ihe.
\b
\q1 
\v 7 Teko Izaew izuapyapyr wà, pezeruzar Tupàn Tuweharupi Wiko Ma'e rehe nehe,
\q1 Ta'e nupytu'u kwaw teko wamutar katu re a'e xe.
\q1 Tuweharupi ipurupyro wer purehe.
\q1 
\v 8 Upyro putar wemiaihu Izaew a'e wà nehe,
\q1 Wapyro pà wanemiapo kwer ikatu 'ym ma'e wi a'e wà nehe.
\c 131
\s1 Naiko wera'u kwaw ihe, i'i Tawi Tupàn pe
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 O Tupàn Tuweharupi Wiko Ma'e. — Aiko wera'u amo wanuwi ihe, na'e kwaw.
\q1 Apytu'u amogwer wanuwi hekàg wera'u haw imume'u re.
\q1 Naikar kwaw uhua'u ma'e aha iteko kury.
\q1 Aze ma'e zawaiw katu wera'u ihewe, nazeagaw kwaw iapo pà ihe. Naputar kwaw ma'e kury, aze napuner kwaw a'e ma'e hereko haw rehe.
\q1 
\v 2 Kwarera'i ukamu re upytu'u mehe upyta uker pà uhy izywa rehe.
\q1 Nezewegatete naherehaite kwaw.
\b
\q1 Apytu'u nerehe we ihe no.
\q1 
\v 3 Teko Izaew izuapyapyr wà, pezeruzar Tupàn Tuweharupi Wiko Ma'e rehe nehe.
\q1 Ko 'ar rehe, tuweharupi nehe no.
\c 132
\s1 Tupàn hemimume'uahy kwer Tawi pe
\q1 
\v 1 O Tupàn Tuweharupi Wiko Ma'e, nema'enukwaw Tawi rehe nehe.
\q1 Nema'enukwaw hemipuraraw kwer nànàn nehe no.
\q1 
\v 2 Nema'enukwaw hemimume'u kwer rehe nehe.
\q1 Nema'enukwaw ko newe hemimume'uahy kwer rehe nehe.
\q1 Tuweharupi Wiko Ma'e Zako izar ikàg ma'e romo ereiko.
\q1 
\v 3 — Naha kwaw heràpuz me nehe. Napytu'u kwaw nehe.
\q1 
\v 4 Na'aw kwaw nehe. Naker kwaw nehe.
\q1 
\v 5 Tupàn Tuweharupi Wiko Ma'e hen àwàm hexak 'ym mehe we napytu'u kwaw nehe.
\q1 Tupàn Zako izar ikàg ma'e hàpuz ràm hexak 'ym mehe we naker kwaw nehe.
\b
\q1 
\v 6 Merez taw pe urereko mehe uruenu Tupàn Ze'eg Hyru rehe ze'egaw ure.
\q1 Uruexak hyru oroho ywy katu Zar her ma'e rehe.
\q1 
\v 7 Na'e uruze'eg nezewe. — Zaha Tupàn Tuweharupi Wiko Ma'e hàpuz me nehe.
\q1 Ximuwete katu henaw henataromo nehe, uru'e ure.
\q1 
\v 8 O Tupàn Tuweharupi Wiko Ma'e, ezur neràpuzuhu pe nehe, neze'eg hyru herur pà nehe.
\q1 Neze'eg hyru wexak kar nekàgaw purupe a'e.
\q1 Upyta a'e pe tuweharupi a'e.
\q1 
\v 9 Tuwe xaxeto nerenataromo har uzapo ikatu ma'e tuweharupi wà nehe.
\q1 Tuwe neremiruze'eg newi upuir pixik 'ym ma'e heiheihem urywete haw rupi wà nehe.
\q1 
\v 10 O Tupàn Tuweharupi Wiko Ma'e, eremume'u neremiapo ràm neremiruze'eg Tawi pe.
\q1 A'e rupi, eityk zo tuwihawete neremixak kwer nehe kury.
\q1 
\v 11 Eremume'uahy neremiapo ràm Tawi pe. Nerezewyr kwaw neze'eg awer wi nehe.
\q1 Nezewe ereze'eg izupe.
\q1 — Amuigo kar putar amo nera'yr tuwihawete romo nehe.
\q1 Wiko putar tuwihawete neraikweromo a'e nehe.
\q1 
\v 12 Aze nera'yr umuwete heze'eg wà nehe,
\q1 Aze weruzar heremiapo karer wà nehe,
\q1 Wana'yr wiko putar tuwihawete romo tuweharupi wà nehe no, ere ihewe.
\b
\q1 
\v 13 Tupàn Tuweharupi Wiko Ma'e wexak Xiàw ywytyr a'e.
\q1 Uputar a'e ywytyr wàpuz ràm hen àwàm romo.
\q1 
\v 14 — Aiko putar xe tuweharupi nehe.
\q1 Hepureruze'eg wer teko wanehe xe ihe nehe.
\q1 
\v 15 Amono putar ma'e tetea'u Zeruzarez pe har wanupe nehe. Uhyk putar tuwe a'e pe har wanupe nehe.
\q1 Amono putar temi'u tetea'u hemetarer 'ym ma'e wanupe nehe.
\q1 
\v 16 Amono putar heze'egatu xaxeto wanemiapo nànàn nehe.
\q1 A'e pe har uzegar putar uhapukaz pà urywete haw rupi wà nehe.
\q1 
\v 17 Amuigo kar putar amo Tawi izuapyr tuwihawete ikàg ma'e romo xe ihe nehe.
\q1 Tuweharupi amuigo kar putar a'e tuwihawete heremixak kwer izuapyapyr ihe wà nehe, tuwihawete romo ihe wà nehe.
\q1 
\v 18 Amumaranugar kar putar iàmàtyry'ymar ihe wà nehe. Tuwihawete ikàg rehe har heny katu a'e.
\q1 Nezewegatete a'e Tawi izuapyr ipureruze'egaw ipuràg eteahy putar nehe, ikàg wera'u putar nehe, i'i Tupàn.
\c 133
\s1 Teko uzeinuinuromo haw ikatu Tupàn pe
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 Aze Tupàn hemiaihu wiko uzeinuinuromo uzeàmàtyry'ym 'ym pà wà nehe,
\q1 Aze amo wereko amo uwywyr ài wà nehe, ikatuahy putar nezewe haw wanupe nehe.
\q1 Hurywete putar wà nehe.
\q1 
\v 2 Nezewe waneko haw nuzawy kwaw uri kawer kàpuhàg inuromo har Àràw àkàg rehe izakook pyrer a'e.
\q1 Uwyryk iamutaw rehe.
\q1 Ikamirpuku rehe uwyryk no.
\q1 
\v 3 Nezewe waneko haw nuzawy kwaw zuwiri Eremon ywytyr rehe har.
\q1 U'ar Xiàw ywytyr nànàn no,
\q1 Ta'e Tupàn Tuweharupi Wiko Ma'e omono uze'egatu Xiàw ywytyr rehe a'e xe.
\q1 Umuigo kar putar teko a'e pe tuweharupi wà nehe.
\c 134
\s1 Ximume'u Tupàn ikatu haw izupe nehe
\q1 
\v 1 Pezur Tupàn Tuweharupi Wiko Ma'e ikatu haw imume'u pà nehe,
\q1 Hemiruze'eg paw wà,
\q1 Hàpuzuhu pe pyhaw uma'ereko ma'e paw wà.
\q1 
\v 2 Peupir pepo Tupàn pe peze'eg pà hàpuzuhu pupe nehe.
\q1 Pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe.
\q1 
\v 3 Tupàn Tuweharupi Wiko Ma'e Zeruzarez pe har a'e,
\q1 Ywak iapo arer ywy iapo arer a'e,
\q1 Tuwe umur uze'egatu penehe a'e nehe.
\c 135
\s1 Tupàn ikatu haw rehe zegar haw
\q1 
\v 1 Pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe.
\q1 Pemume'u Tuweharupi Wiko Ma'e ikatu haw nehe,
\q1 Hemiruze'eg wà,
\q1 
\v 2 Hàpuz me wiko ma'e wà.
\q1 Zanezar hàpuzuhu pupe wiko ma'e wà.
\q1 
\v 3 Pemume'u Tuweharupi Wiko Ma'e ikatu haw nehe, ta'e ikatu a'e xe.
\q1 Pemuzàg zegar haw her ikatu haw rehe nehe, ta'e uzapo ikatu ma'e wemiruze'eg wanupe a'e xe.
\q1 
\v 4 Tupàn Tuweharupi Wiko Ma'e wexak Zako kwehe mehe a'e, wemiruze'eg romo imuigo kar pà a'e.
\q1 Wexaexak teko Izaew wemiaihu romo wemiamutar katu romo wamuigo kar pà wà.
\b
\q1 
\v 5 Akwaw Tupàn Tuweharupi Wiko Ma'e uhua'u haw ihe.
\q1 Zanezar wiko amogwer tupàn wa'aromo upaw rupi a'e.
\q1 
\v 6 Tupàn Tuweharupi Wiko Ma'e uzapo wemimutar ywak rehe a'e,
\q1 Ywy rehe a'e no,
\q1 Yryhu pupe a'e, yryhu ohoete ma'e pupe a'e no.
\q1 
\v 7 Werur ywàkun ywy iahykaw wi.
\q1 Umuàgà'ym iweraw paw àmànuhu pe ywytuhu pe.
\q1 Umuhem kar ywytu imonokatu haw wi no.
\q1 
\v 8 A'e ae uzuka Ezit ywy rehe har wana'yr ipy paw a'e wà.
\q1 Awa wana'yr ipy uzuka wà. Ma'ea'yr wana'yr ipy uzuka wà no.
\q1 
\v 9 Uzapo purumupytuhegatu kar haw a'e pe.
\q1 Uzapo ma'e hemixak pyr 'ym a'e pe no, tuwihawete rehe uzepyk pà, hemiruze'eg wanehe uzepyk pà no.
\q1 
\v 10 Tupàn Tuweharupi Wiko Ma'e umumaw teko amo ae ywy rehe har tetea'u wà.
\q1 Uzuka tuwihawete ikàg ma'e wà no.
\q1 
\v 11 Uzuka Xeom Amohe ywy rehe har wanuwihawete a'e.
\q1 Uzuka Og Màxà izuapyapyr wanuwihawete a'e no.
\q1 Uzuka Kànàà ywy rehe har wanuwihawete paw a'e wà no.
\q1 
\v 12 A'e tuwihawete waywy a'e, Tupàn omono wemiaihu Izaew wanupe a'e.
\q1 Izaew wiko putar izar romo wà nehe.
\b
\q1 
\v 13 O Tupàn Tuweharupi Wiko Ma'e, teko paw ukwaw putar Tupàn romo nereko haw a'e wà nehe.
\q1 Teko kwarahy ur ma'e ràm nànàn ima'enukwaw putar nerehe wà nehe no.
\q1 
\v 14 Tupàn Tuweharupi Wiko Ma'e uzekaiw putar teko Izaew wanehe a'e wà nehe.
\q1 Upuhareko putar wemiruze'eg wà nehe no.
\b
\q1 
\v 15 Tupàn amo ae ywy rehe har wazar a'e wà, teko uma'e itaxig parat a'e wà, wanagapaw romo waapo pà a'e wà. Wiko itazu or iapo pyrer romo a'e wà no.
\q1 Awa uzapo opo pupe wà.
\q1 
\v 16 Heta wazuru wanupe. Nuze'eg kwaw wà.
\q1 Heta waneha wanupe. Nuexak kwaw ma'e wà.
\q1 
\v 17 Heta wapyakwar wanupe. Nuenu kwaw ma'e wà.
\q1 Nupuner kwaw upytuhemaw rehe wà.
\q1 
\v 18 A'e tupàn a'ua'u iapo arer a'e wà nehe,
\q1 Wanehe uzeruzar ma'e a'e wà nehe no, tuwe wiko wemiapo kwer zàwegatete wà nehe.
\b
\q1 
\v 19 Pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe, teko Izaew izuapyapyr wà.
\q1 Xaxeto Tupàn henataromo har wà, pemume'u Tuweharupi Wiko Ma'e ikatu haw nehe.
\q1 
\v 20 Erewi izuapyapyr wà, pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe.
\q1 Izuwi ukyze ma'e paw wà, pemume'u ikatu haw nehe.
\q1 
\v 21 Pemume'u Tuweharupi Wiko Ma'e ikatu haw Xiàw ywytyr rehe nehe.
\q1 Pemume'u ikatu haw heko haw pe Zeruzarez tawhu pe nehe.
\q1 Pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe.
\c 136
\s1 Pemume'u Tupàn ikatu haw izupe nehe
\q1 
\v 1 Pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw izupe nehe. Ta'e ikatu a'e xe.
\q1 Ipuruamutar katu haw nupaw pixik kwaw nehe.
\q1 
\v 2 Ikàg wera'u amogwer tupàn wanuwi a'e. Pemume'u ikatu haw izupe nehe.
\q1 Ipuruamutar katu haw nupaw pixik kwaw nehe.
\q1 
\v 3 Ikàg wera'u amogwer teko wazar wanuwi no. Pemume'u ikatu haw izupe nehe.
\q1 Ipuruamutar katu haw nupaw pixik kwaw nehe.
\q1 
\v 4 Xo Tuweharupi Wiko Ma'e zo uzapo purumupytuhegatu kar haw a'e.
\q1 Ipuruamutar katu haw nupaw pixik kwaw nehe.
\q1 
\v 5 Uma'ekwaw katu haw rupi uzapo ywak kwehe mehe a'e.
\q1 Ipuruamutar katu haw nupaw pixik kwaw nehe.
\q1 
\v 6 Tupàn umuapyk ywy 'y typya'u ma'e i'aromo a'e.
\q1 Ipuruamutar katu haw nupaw pixik kwaw nehe.
\q1 
\v 7 Uzapo kwarahy. Zahy uzapo no.
\q1 Ipuruamutar katu haw nupaw pixik kwaw nehe.
\q1 
\v 8 Umuigo kar kwarahy 'ar rehe uhyape katu ma'e romo.
\q1 Ipuruamutar katu haw nupaw pixik kwaw nehe.
\q1 
\v 9 Umuigo kar zahy pytunaw rehe uhyape katu ma'e romo zahytata wanehe we a'e no.
\q1 Ipuruamutar katu haw nupaw pixik kwaw nehe.
\b
\q1 
\v 10 Ezit ywy rehe har wanàpuz nànàn Tupàn uzuka ta'yr ipy a'e wà.
\q1 Ipuruamutar katu haw nupaw pixik kwaw nehe.
\q1 
\v 11 Umuhem kar teko Izaew izuapyapyr waneruwà Ezit ywy wi wà.
\q1 Ipuruamutar katu haw nupaw pixik kwaw nehe.
\q1 
\v 12 Upyro a'e wi opo ikàg ma'e pupe uzywa upuner ma'e pupe wà.
\q1 Ipuruamutar katu haw nupaw pixik kwaw nehe.
\q1 
\v 13 Umuza'aza'ak Yryhupiràg mokoz pehegwer romo a'e.
\q1 Ipuruamutar katu haw nupaw pixik kwaw nehe.
\q1 
\v 14 Umuata kar teko Izaew waneraha yryhu myteromo wà.
\q1 Ipuruamutar katu haw nupaw pixik kwaw nehe.
\q1 
\v 15 A'e pe yryhu pupe uzeapypyk Ezit ywy rehe har wanuwihawete a'e. Hemiruze'eg zauxiapekwer paw uzeapypyk wà no.
\q1 Ipuruamutar katu haw nupaw pixik kwaw nehe.
\b
\q1 
\v 16 Tupàn wexak kar waho àwàm wemiaihu wanupe ywyxiguhu rehe.
\q1 Ipuruamutar katu haw nupaw pixik kwaw nehe.
\q1 
\v 17 Uzuka tuwihawete ikàg ma'e wà.
\q1 Ipuruamutar katu haw nupaw pixik kwaw nehe.
\q1 
\v 18 Uzuka tuwihawete ikwaw katu pyr wà no.
\q1 Ipuruamutar katu haw nupaw pixik kwaw nehe.
\q1 
\v 19 Uzuka Xeom Amohe ywy rehe har wanuwihawete.
\q1 Ipuruamutar katu haw nupaw pixik kwaw nehe.
\q1 
\v 20 Uzuka Og Màxà izuapyapyr wanuwihawete.
\q1 Ipuruamutar katu haw nupaw pixik kwaw nehe.
\q1 
\v 21 Omono a'e tuwihawete waywy wemiaihu wanupe.
\q1 Ipuruamutar katu haw nupaw pixik kwaw nehe.
\q1 
\v 22 Omono a'e ywy a'e, wemiruze'eg Izaew izuapyapyr wanupe a'e.
\q1 Ipuruamutar katu haw nupaw pixik kwaw nehe.
\b
\q1 
\v 23 Amo tuwihawete zanereityk a'e wà. Tupàn naheharaz kwaw zanewi a'e mehe a'e.
\q1 Ipuruamutar katu haw nupaw pixik kwaw nehe.
\q1 
\v 24 Zanepyro zaneàmàtyry'ymar wanuwi.
\q1 Ipuruamutar katu haw nupaw pixik kwaw nehe.
\q1 
\v 25 Omono temi'u teko wanupe. Opoz ma'ea'yr wà. Opoz miar wà no.
\q1 Ipuruamutar katu haw nupaw pixik kwaw nehe.
\q1 
\v 26 Pemume'u Tupàn ywak rehe har ikatu haw izupe nehe.
\q1 Ipuruamutar katu haw nupaw pixik kwaw nehe.
\b
\c 137
\s1 Izaew izuapyapyr wexaka'u uiwy a'e wà
\q1 
\v 1 Yrykawhu Mawiron ywy rehe har iwyr rehe zaneapyk mehe,
\q1 Zazai'o Zeruzarez rehe zanema'enukwaw mehe zane.
\q1 
\v 2 Ximuzaiko zanewioràwiràn irir her ma'e
\q1 Ywyra a'e pe har rehe.
\q1 
\v 3 A'e ywy rehe har zanereraha imunehew pyr romo wà.
\q1 — Pezegar nehe, i'i zanewe wà.
\q1 Nezewe uze'eg wà.
\q1 — Pemuzàg zegar haw Xiàw parer nehe, i'i zanewe wà.
\q1 
\v 4 Amo ae ywy rehe zanereko mehe
\q1 Nazapuner kwaw Tupàn Tuweharupi Wiko Ma'e pe zegar haw imuzàgaw rehe zane.
\q1 
\v 5 Aze hereharaz newi nehe, o Zeruzarez,
\q1 Tuwe namupu pixik kwaw hewioràwiràn nehe.
\q1 
\v 6 Aze nahema'enukwaw katu kwaw nerehe nehe, tuwe napuner pixik kwaw hezegar haw rehe nehe,
\q1 Aze nahema'enukwaw kwaw hemurywete kar arer ikàg wera'u ma'e hereko haw rehe.
\b
\q1 
\v 7 O Tupàn Tuweharupi Wiko Ma'e, nema'enukwaw Enom izuapyapyr wanemiapo kwer ikatu 'ym ma'e rehe nehe.
\q1 Iaiw ma'e uzapo Zeruzarez heityk awer 'ar rehe wà.
\q1 Nema'enukwaw waze'eg rehe nehe.
\q1 — Peityk tàpuz Zeruzarez pe har wamumaw pà upaw rupi pe wà nehe, i'i wà.
\b
\q1 
\v 8 Mawiron, amo nemumaw putar wà nehe. Urereityk pe pe.
\q1 Amo peneityk putar nezewegatete a'e wà nehe no. Hurywete putar peneityk àràm wà nehe.
\q1 
\v 9 Upyhyk putar kwarer pena'yr wà nehe, kuzàtàigwer penazyr wà nehe no.
\q1 Ukamikamik putar itahu rehe wà nehe.
\c 138
\s1 Ze'egaw Tupàn ikatu haw imume'u haw
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 O Tupàn Tuweharupi Wiko Ma'e, amume'u nekatu haw newe hepy'a nàn ihe.
\q1 Amuzàg zegar haw nekatu haw rehe amogwer tupàn wanenataromo upaw rupi.
\q1 
\v 2 Apyk hepenàràg rehe neràpuzuhu ikatu ma'e henataromo ihe,
\q1 Ta'e heamutar katu pe ne xe, ta'e nahetyryk pixik kwaw pe xe.
\q1 Amume'u nerer ikatu haw no,
\q1 Ta'e erexak kar nerer ma'e paw wa'aromo ipyta haw ne xe.
\q1 Erexak kar neremimume'u ma'e paw wa'aromo ipyta haw ne no.
\q1 
\v 3 Newe heze'eg mehe erewazar heze'eg ihewe.
\q1 Nekàgaw pupe hemukàg kar wera'u no.
\b
\q1 
\v 4 O Tupàn Tuweharupi Wiko Ma'e, ywy nànànar wanuwihawete paw umume'u putar nekatu haw wà nehe,
\q1 Neremiapo ràm imume'u haw henu mehe wà nehe.
\q1 
\v 5 Ne Tuweharupi Wiko Ma'e ne.
\q1 A'e tuwihawete umuzàg putar neremiapo kwer ikatu haw rehe zegar haw wà nehe, ta'e nekàgaw nepuràg eteahy haw uhua'u a'e xe.
\q1 
\v 6 Ereiko muite ywate ne.
\q1 Nezewe rehe we erezekaiw teko ikàg 'ym ma'e wanehe.
\q1 Amo wanuwi wiko wera'u ma'e nupuner kwaw newi uzeàmimaw rehe wà.
\b
\q1 
\v 7 Ikatu 'ym ma'e ihewe izeapo etea'i mehe
\q1 Hepyro pe ne.
\q1 Nekàgaw hepyro heàmàtyry'ymar herehe wakatuwawahy 'ymaw wi.
\q1 Hepyro nepuner haw pupe.
\q1 
\v 8 Erezapo putar ma'e neremimume'u kwer paw rupi nehe.
\q1 O Tupàn Tuweharupi Wiko Ma'e, nepuruamutar haw nupaw pixik kwaw nehe.
\q1 Erezypyrog nema'ereko haw iapo pà. Epytu'u zo iapo re nehe.
\c 139
\s1 Tupàn ukwaw ma'e upaw rupi a'e, wiko ywy nànàn no
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 O Tupàn Tuweharupi Wiko Ma'e, ereme'e herehe. Hekwaw pe ne.
\q1 
\v 2 Erekwaw heremiapo upaw rupi.
\q1 Muite ereiko ihewi. Nezewe rehe we erekwaw hema'enukwaw paw upaw rupi.
\q1 
\v 3 Herexak pe herereko hema'ereko mehe.
\q1 Herexak pe hepytu'u mehe no.
\q1 Erekwaw heremiapo.
\q1 
\v 4 Heze'eg 'ym mehe we
\q1 Erekwaw heremimume'u ràm.
\q1 
\v 5 Ereiko heywyr upaw rupi.
\q1 Hepyro pe ikatu 'ymaw wi nekàgaw pupe.
\q1 
\v 6 Màràzàwe tuwe hekwaw katu pe nezewe. Nakwaw kwaw ihe.
\q1 Nema'ekwaw paw uhua'u a'e. Napuner kwaw ikwaw paw rehe ihe.
\b
\q1 
\v 7 Ma'e pe apuner heho haw rehe nerekwe wi hehem pà nehe.
\q1 Aze hehem wer neruwa wi nehe, ma'e pe àzàn putar nehe.
\q1 
\v 8 Aze azeupir ywak rehe nehe, ereiko putar a'e pe nehe.
\q1 Aze awezyw umàno ma'e kwer wapyta haw pe nehe, ereiko putar a'e pe nehe no.
\q1 
\v 9 Aze awewe kwarahy ihemaw kutyr nehe,
\q1 Aze azapo hereko haw muite xe wi kwarahy heixe haw kutyr nehe,
\q1 
\v 10 nezewe rehe we nepo hereraha putar nehe.
\q1 Nezewe rehe we hepytywà pe a'e pe nehe.
\q1 
\v 11 — Pytunaw, hemim pe nehe, apuner mo he'e haw rehe izupe.
\q1 — Tatainy heywyr har, eiko pytunahy haw romo nehe, apuner mo he'e haw rehe izupe.
\q1 
\v 12 Herexak putar pe nezewe rehe we nehe, ta'e ipytunaw na'ipytun kwaw newe xe.
\q1 Erexak katu ma'e pyhaw no.
\q1 Nuzawy kwaw 'aromo neremixak a'e.
\q1 Tatainy a'e, ipytunaw a'e no, uzuawygatu newe wà.
\b
\q1 
\v 13 Erezapo heretekwer rehe har paw.
\q1 Heapo hehy hie pe hereko mehe we.
\q1 
\v 14 Amume'u nekatu haw ihe, ta'e heapo awer xiroxirogatu a'e xe.
\q1 Neremiapo kwer ikatuahy upaw rupi.
\q1 Akwaw katu ko ma'e ihe.
\q1 
\v 15 Herexak pe hekàgwer izeapoapo mehe we ne.
\q1 Herexak pe hehy hie pe heapoapo mehe we no.
\q1 Teko naherexak kwaw a'e pe heapo mehe wà.
\q1 
\v 16 Herexak pe hezexak kar 'ym mehe we ne.
\q1 He'ar ihewe neremimume'u kwer paw
\q1 Eremuapyk nepape rehe ne wà.
\q1 A'e 'ar nuhem kwaw imume'u mehe wà rihi.
\q1 
\v 17 O Tupàn, heta tetea'u nema'enukwaw paw wà.
\q1 Zawaiw katu nema'enukwaw paw ikwaw paw urewe.
\q1 
\v 18 Aze mo apapar ihe wà, waneta haw uhua'u wera'u mo ywyxig waneta haw wi wà.
\q1 Azypyrog mo wapapar pà. Apapar wiwi mo aha iteko no.
\q1 Nezewe rehe we napuner iwer mo a'e paw wapapar haw rehe.
\q1 
\v 19 O Tupàn, aze mo eremumaw ikatu 'ym ma'e ne wà, herurywete mo ihe.
\q1 Aze mo awa ipuruzukaiw ma'e utyryk ihewi wà, herurywete mo ihe.
\q1 
\v 20 Uze'eg zemueteahy nerehe wà.
\q1 Iaiw ma'e umume'u nerer rehe uze'eg mehe wà.
\q1 
\v 21 O Tupàn Tuweharupi Wiko Ma'e, naheakatuwawahy kwaw tuwe nerehe iakatuwawahy 'ym ma'e wanehe ihe.
\q1 Neàmàtyry'ymar iroahy ihewe wà.
\q1 
\v 22 Naheakatuwawahy kwaw wanehe. Naheakatuwawahy kwaw wanehe azeharomoete.
\q1 Wiko heàmàtyry'ymar romo wà.
\b
\q1 
\v 23 O Tupàn, eme'e herehe nehe. Ekwaw hepy'a nehe.
\q1 Heragaw pe hema'enukwaw paw ikwaw pà nehe.
\q1 
\v 24 Ekar ikatu 'ym ma'e iapo haw herehe nehe.
\q1 Hereraha pe nehe, tuweharupi hereko àwàm piar rupi nehe.
\c 140
\s1 Tupàn poromonokatu haw henoz taw
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 O Tupàn Tuweharupi Wiko Ma'e, hepyro pe ikatu 'ym ma'e wanuwi nehe.
\q1 Hemunyryk kar pe awa upuruzuka ma'e wanuwi nehe.
\q1 
\v 2 Tuweharupi umume'u ikatu 'ym ma'e wemiapo ràm waiko wà.
\q1 Tuweharupi uzàmàtyry'ym kar amo amo wanupe wà.
\q1 
\v 3 Waapeku nuzawy kwaw mozaiw iapeku.
\q1 Waze'eg nuzawy kwaw puruzuka haw mozaiw zuru pe har no.
\q1 
\v 4 O Tupàn Tuweharupi Wiko Ma'e, hepyro pe teko ikatu 'ym ma'e wakàgaw wi nehe.
\q1 Hemunyryk kar pe awa ipuruzukaiw ma'e wanuwi nehe.
\q1 Umume'u hereityk àwàm waiko tuweharupi wà.
\q1 
\v 5 Awa amo wanuwi wiko wera'u ma'e uzapo miar zuka haw zàwenugar hepyhyk pà wà.
\q1 Umuzaiko kyhapari herape rupi wà.
\q1 Omono hezuka àwàm heho àwàm rupi wà.
\b
\q1 
\v 6 Aze'eg nezewe Tuweharupi Wiko Ma'e pe. — Ereiko hezar romo ne, a'e izupe.
\q1 — O Tuweharupi Wiko Ma'e, einu heze'eg newe hepytywà àwàm henoz mehe nehe.
\q1 
\v 7 Tupàn Wiko Ma'e hezar, hepyro har ikàg ma'e,
\q1 Erezekaiw herehe zeàmàtyry'ymawhu pe hereko mehe ne.
\q1 
\v 8 O Tupàn Tuweharupi Wiko Ma'e, emono zo wanemimutar ikatu 'ym wanupe nehe.
\q1 Emuzeapo kar zo wanemiapo putar haw iaiw ma'e nehe.
\q1 
\v 9 Hereityk zo pe heàmàtyry'ymar wanupe nehe.
\q1 Umume'u iaiw ma'e herehe uzeapo ma'e ràm a'e wà. Tuwe a'e iaiw ma'e u'ar imume'u arer wanehe nehe.
\q1 
\v 10 Tuwe u'ar tata hàtàpyzgwer wanehe nehe.
\q1 Tuwe amo weityk a'e teko 'yzygwar pupe wà nehe.
\q1 Tuwe nupuner pixik kwaw a'e wi uhemaw rehe wà nehe.
\q1 
\v 11 Tuwe hemu'em ma'e nuiko kwaw ikàg ma'e romo wà nehe.
\q1 Tuwe ikatu 'ymaw wekar awa ipuruzukaiw ma'e oho wà nehe. Tuwe umumaw a'e awa wà nehe.
\q1 
\v 12 O Tupàn Tuweharupi Wiko Ma'e, erezekaiw hemetarer 'ym ma'e wanehe ne. Akwaw nezekaiw paw ihe.
\q1 Erepytywà ma'e hereko 'ymar ne wà no.
\q1 
\v 13 Teko nereruzar har a'e wà nehe, umume'u putar nekatu haw a'e wà nehe.
\q1 Wiko putar nepyr tuweharupi wà nehe.
\c 141
\s1 Tupàn pe ze'egaw karuk mehe har
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 O Tupàn Tuweharupi Wiko Ma'e, uruenoz iteko ihe. Ezur na'arewahy hepytywà pà nehe.
\q1 Herenu pe newe heze'eg mehe hepytywà àwàm henoz mehe nehe.
\q1 
\v 2 Einu heze'eg nehe. Tuwe nuzawy kwaw yhyk hyàkwegatu ma'e newe nehe.
\q1 Aupir hepo nerenataromo newe heze'eg mehe. Tuwe nuzawy kwaw ma'e newe imono pyr karuketea'i mehe har newe nehe.
\b
\q1 
\v 3 O Tupàn Tuweharupi Wiko Ma'e, eiko hezuru izar romo nehe.
\q1 Emume'u kar zo ikatu 'ym ma'e ihewe nehe.
\q1 
\v 4 Ema'ereko hepy'a pe nehe, nezewe mehe nahepurapo wer kwaw ikatu 'ym ma'e rehe nehe.
\q1 Aze ata teko iaiw ma'e wanupi nehe, ezapo kar zo ikatu 'ym ma'e ihewe nehe.
\q1 Hemunyryk kar pe wakatu 'ymaw wi nehe.
\q1 Hemono kar zo pe wapynykawhu pe nehe.
\q1 
\v 5 Aze amo Tupàn heruzar har umume'u heremiapo kwer ikatu 'ym ma'e ihewe nehe, aze uzepyk herehe nehe, ikatu putar ihewe nehe.
\q1 Nezewe wiko mo hemyrypar ài ihewe.
\q1 Aze iaiw ma'e umume'u heremiapo kwer ikatuahy ma'e wà nehe, na'ikatu kwaw ihewe wà nehe.
\q1 Tuweharupi aze'eg Tupàn pe imuzepyk kar pà iaiw ma'e wanehe ihe.
\q1 
\v 6 Amo 'ar mehe zauxiapekwer weityk putar wanuwihaw ita iaiha ma'e wi wà nehe.
\q1 A'e 'ar mehe teko ukwaw putar heze'eg awer ikatu haw wà. Azeharomoete heze'eg awer.
\q1 
\v 7 Teko omowomowok zepe'aw imonohonohok pà wà.
\q1 Nezewegatete zauxiapekwer umuhàmuhàz putar a'e tuwihaw wakàgwer wà nehe no, watym àwàm huwake wà nehe no.
\q1 
\v 8 Tupàn Tuweharupi Wiko Ma'e hezar, azeruzar wiwi nerehe.
\q1 Aekar hepyro àwàm iteko no.
\q1 Hemumàno kar zo pe nehe.
\q1 
\v 9 Hepyro pe kyhapari imuzaiko pyrer hepyhyk àwàm wi nehe.
\q1 Hemunyryk pe puruzuka haw ikatu 'ym ma'e wanuwi nehe no.
\q1 
\v 10 Tuwe ikatu 'ym ma'e u'ar wemiapo kwer puruzuka haw zàwenugar pupe wà nehe.
\q1 Tuwe ahem a'e wi hemàno 'ym pà nehe.
\c 142
\s1 Uze'eg Tupàn pe upytywà àwàm henoz pà izupe a'e
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 Aze'eg Tupàn Tuweharupi Wiko Ma'e pe hepytywà àwàm henoz pà ihe.
\q1 — Hepytywà pe nehe, a'eahy izupe.
\q1 
\v 2 Aze wyzài ma'e na'ikatu kwaw ihewe, amume'u izupe.
\q1 Aze amo ikatu 'ym ma'e uzeapo ihewe, amume'u izupe.
\q1 
\v 3 Aze apytu'u wewera'i hema'ereko haw iapo re,
\q1 A'e ae ukwaw ikatu ma'e ihewe iapo kar haw a'e.
\q1 Heàmàtyry'ymar uzapo hepyhyk àwàm
\q1 Herape rupi wà.
\q1 
\v 4 Ame'e hezeake.
\q1 Naexak kwaw hepytywà har.
\q1 Naheta kwaw hepyro har wà.
\q1 Naheta kwaw herehe uzekaiw ma'e wà.
\b
\q1 
\v 5 O Tupàn Tuweharupi Wiko Ma'e, ahapukaz newe hepytywà àwàm henoz pà ihe.
\q1 O Tupàn, ereiko herehe uzekaiw ma'e romo ne.
\q1 Naputar kwaw amo ma'e hereko haw ihe. Xo ne zo uruputar ihe.
\q1 
\v 6 Herenu pe hepytywà àwàm henoz mehe nehe,
\q1 Ta'e hemàno àwàm uhem etea'i ihewe xe.
\q1 Hepyro pe heàmàtyry'ymar wanuwi nehe,
\q1 Ta'e ikàg wera'u ihewi a'e wà xe.
\q1 
\v 7 Hemunyryk kar pe ma'erahy heremipuraraw wi nehe.
\q1 Amume'u putar nekatu haw neremiaihu wazemono'og mehe ihe nehe,
\q1 Ta'e nekatu ihewe tuweharupi ne xe.
\c 143
\s1 Tupàn rehe zeruzar haw
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 O Tupàn Tuweharupi Wiko Ma'e, herenu pe newe heze'eg mehe nehe.
\q1 Ezeapyaka katu hereminoz rehe nehe.
\q1 Ewazar heze'eg ihewe nehe, ta'e neretyryk kwaw neremiaihu wanuwi ne xe. Nekatuahy ne.
\q1 
\v 2 Aiko neremiruze'eg romo ihe. Ezepyk zo herehe heremiapo kwer hekuzaromo nehe.
\q1 Xo ne zo nekatu. Naheta kwaw amo ikatu 'ym ma'e iapo 'ymar a'e wà.
\b
\q1 
\v 3 Heàmàtyry'ymar herekar tuweharupi a'e.
\q1 A'e mehe hereityk tuwe a'e.
\q1 Hemunehew kar zemunehew paw tatainy hereko 'ymar pupe.
\q1 Aiko teko kwehe umàno ma'e kwer wazàwe ihe.
\q1 
\v 4 A'e rupi apytu'u wewera'i hezeagaw re ihe kury.
\q1 Hepy'a ukyze tuwe hemàno àwàm wi.
\b
\q1 
\v 5 'Ar upaw ma'e kwer wanehe hema'enukwaw.
\q1 Hema'enukwaw neremiapo kwer paw wanehe.
\q1 Nahereharaz kwaw neremiapo kwer wanuwi.
\q1 
\v 6 Aupir hepo nerenataromo newe heze'eg mehe.
\q1 Aiko ywy uxinig ma'e ài. Uputar tuwe 'y a'e. Nezewegatete uruputar tuwe ihe no.
\b
\q1 
\v 7 O Tupàn Tuweharupi Wiko Ma'e, ewazar heze'eg ihewe na'arewahy nehe,
\q1 Ta'e nàro kwaw ikatu ma'e ihe kury xe.
\q1 Ezeàmim zo ihewi nehe.
\q1 Nezewe mehe naiko kwaw
\q1 Umàno ma'e kwer wapyta haw pe wezyw ma'e wazàwe ihe nehe.
\q1 
\v 8 Azeruzar nerehe.
\q1 Emume'u nepuruamutar katu haw ihewe tuweharupi nehe.
\q1 Heze'eg uzeupir newe.
\q1 Exak kar herape ràm ihewe nehe.
\b
\q1 
\v 9 O Tupàn Tuweharupi Wiko Ma'e, hepyro pe heàmàtyry'ymar wanuwi nehe,
\q1 Ta'e aexak herehe nezekaiw paw neinuromo ihe xe.
\q1 
\v 10 Ereiko hezar romo.
\q1 Hemu'e pe neremimutar iapo haw rehe nehe.
\q1 Tuwe nerekwe ikatu ihewe nehe.
\q1 Tuwe hereraha pe ikatu ma'e rupi nehe.
\q1 
\v 11 Hemuigo kar wiwi neremimume'u kwer rupi nehe, o Tupàn Tuweharupi Wiko Ma'e.
\q1 Nekatu ne. A'e rupi hepyro pe ma'erahy heremipuraraw wi nehe.
\q1 
\v 12 Ezuka heàmàtyry'ymar ne wà nehe, ta'e heamutar katu pe ne xe.
\q1 Emumaw herehe ipuruzuka wer ma'e ne wà nehe, ta'e aiko neremiruze'eg romo ihe xe.
\c 144
\s1 Tuwihawete uze'eg Tupàn pe
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 Tupàn Tuweharupi Wiko Ma'e wiko itahu zàwenugar hemimaw romo a'e. Pemume'u ikatu haw nehe.
\q1 Hemuàgà'ym zeàmàtyry'ymawhu pe a'e.
\q1 Hemu'e heàmàtyry'ymar waàmàtyry'ymaw rehe.
\q1 
\v 2 Itahu zàwenugar hemimaw romo hekon a'e. Tàpuz imuàtà pyrer hepyro har romo no.
\q1 Hemim ikatu 'ymaw wi. Hemunyryk kar zemunehew paw zàwenugar wi no.
\q1 Hemim u'yw wi purumimaw zàwe.
\q1 Azeruzar hehe ihe, herehe izekaiw haw rehe ihe.
\q1 Omono ywy nànànar hepuner haw iwy pe wà.
\b
\q1 
\v 3 O Tupàn Tuweharupi Wiko Ma'e. Teko umàno amo 'ar mehe upaw rupi a'e wà. Nuiko kwaw ikàg ma'e romo wà.
\q1 Màràzàwe tuwe nema'enukwaw wanehe. Màràzàwe tuwe erezekaiw wanehe.
\q1 
\v 4 Teko nuzawy kwaw pytuhemaw wà.
\q1 Waneko haw nuzawy kwaw ma'e'àg kwerupi ukwaw ma'e wà.
\b
\q1 
\v 5 O Tuweharupi Wiko Ma'e, ewàpytymawok ywak newezyw pà nehe.
\q1 Epokok ywytyruhu wanehe nehe. A'e mehe ywàtàxiner uhem putar wanuwi nehe.
\q1 
\v 6 Emur kar iweraw paw neàmàtyry'ymar wamuhàmuhàz pà nehe.
\q1 Emomor neru'yw wamuzàn kar pà nehe no.
\q1 
\v 7 Ereiko ywate. Epyho nepo nehe.
\q1 Herenuhem pe yryhu ohoete ma'e wi hepyro pà nehe.
\q1 Hepyro pe nerehe uzeruzar 'ym ma'e wapuner haw wi nehe,
\q1 
\v 8 ta'e numume'u pixik kwaw ze'eg azeharomoete har a'e wà xe.
\q1 Hemu'em wà. Umume'u mua'u uze'eg wà.
\b
\q1 
\v 9 Amuzàg putar amo zegar haw ipyahu ma'e newe nehe, o Tupàn.
\q1 Amupu putar hewioràwiràn 10 ihàm hereko har nehe, nekatu haw rehe hezegar pà nehe.
\q1 
\v 10 Ereityk kar waàmàtyry'ymar tuwihawete wanupe ne wà.
\q1 Erepyro neremiruze'eg Tawi imàno haw wi no.
\q1 
\v 11 Hepyro pe heàmàtyry'ymar purupe ma'erahy ipuraraw par wanuwi nehe.
\q1 Hemunyryk kar pe nerehe uzeruzar 'ym ma'e wapuner haw wi nehe, ta'e numume'u pixik kwaw ze'eg azeharomoete har a'e wà xe.
\q1 Hemu'em wà.
\q1 Umume'u mua'u uze'eg wà.
\b
\q1 
\v 12 Zanera'yr wà nehe, tuwe wiko ma'e itym pyrer ikàg ma'e ài wakwàkwàmo mehe wà nehe.
\q1 Tuwe zanerazyr wiko izita ita iapo pyrer
\q1 Tàpuzuhu henataromo har ài tàpuzuhu imupuràg eteahy kar har ài wà nehe.
\q1 
\v 13 Tuwe tàpuz zaneremi'u ràm hyruhu tynehem temi'u tetea'u pupe nehe.
\q1 Tuwe zanereimaw zaneko pe har imemymemyr tetea'u wà nehe no.
\q1 
\v 14 Tuwe tapi'ak uzemueta tetea'u wà nehe.
\q1 Tuwe tapi'ak kuzà nuexak kar kwaw umemyr umàno ma'e kwer romo wà nehe.
\q1 Tuwe teko naheiheihem kwaw uzemumikahy haw rehe nahu rupi zanereko haw pe wà nehe.
\b
\q1 
\v 15 Hurywete teko amo ywy rehe har wà, aze wereko a'e ma'e paw wà.
\q1 Hurywete amo teko wà, aze wereko Tuweharupi Wiko Ma'e uzar romo wà.
\c 145
\s1 Tupàn ikatu haw rehe zegar haw
\d Zegar haw Tawi hemiapo kwer
\q1 
\v 1 Hezar heruwihawete, amume'u putar nehua'u haw nehe.
\q1 Tuweharupi amume'u putar nekatu haw newe nehe.
\q1 
\v 2 Tuweharupi amume'u putar nekatu haw newe nehe.
\q1 Amume'u putar nekatu haw purupe tuweharupi nehe no.
\q1 
\v 3 Tupàn Tuweharupi Wiko Ma'e uhua'u a'e. Tuwe teko umume'u ikatu haw wà nehe.
\q1 Teko nupuner kwaw uhua'u haw ikwaw paw rehe wà.
\b
\q1 
\v 4 O Tupàn, awakwer umume'u putar neremiapo kwer wa'yr wanenataromo wà nehe.
\q1 Teko paw umume'u putar neremiapo kwer ikàg ma'e wà nehe.
\q1 
\v 5 Uze'eg putar nekàgaw rehe nepuràg eteahy haw rehe wà nehe. Uze'eg putar tuwihawete upuner ma'e romo nereko haw rehe wà nehe no.
\q1 Hema'enukwaw putar neremiapo kwer ikatuahy ma'e wanehe nehe.
\q1 
\v 6 Uze'eg putar neremiapo kwer ikàg ma'e wanehe wà nehe.
\q1 Amume'u putar nehua'u haw nehe.
\q1 
\v 7 Uze'eg putar nekatu haw uhua'u ma'e rehe wà nehe.
\q1 Uzegar putar urywete haw rupi puruwi nepuir pixik 'ymaw rehe nehe.
\b
\q1 
\v 8 Tupàn Tuweharupi Wiko Ma'e ikatu a'e.
\q1 Upurupuhareko katu tuwe no. Iàrew wikwahy pà.
\q1 Upuruamutar katu tuweharupi.
\q1 
\v 9 Tupàn Tuweharupi Wiko Ma'e ikatu teko paw wanupe.
\q1 Uzekaiw katu wemiapo kwer paw wanehe no.
\b
\q1 
\v 10 O Tupàn Tuweharupi Wiko Ma'e, ma'e wikuwe ma'e paw umume'u putar nekatu haw wà nehe.
\q1 Neremiaihu nerehe uzeruzar ire upytu'u 'ym ma'e wà nehe no, umume'u putar nekatu haw newe wà nehe no.
\q1 
\v 11 Teko paw uze'eg putar nepureruze'egaw ikàgaw rehe wà nehe, ipuràg eteahy haw rehe wà nehe no.
\q1 Umume'u putar nepuner haw purupe wà nehe.
\q1 
\v 12 Nezewe mehe ywy nànànar ukwaw putar neremiapo kwer ikàg ma'e wà nehe.
\q1 Ukwaw putar nepureruze'egaw uhua'u haw wà nehe, ipuràg eteahy haw wà nehe no, ikàgaw wà nehe no.
\q1 
\v 13 Nepureruze'egaw nupaw pixik kwaw nehe.
\q1 Ereiko putar tuwihawete romo tuweharupi nehe.
\b
\q1 Tupàn Tuweharupi Wiko Ma'e uzapo ma'e uze'eg rupi katete tuweharupi a'e.
\q1 Wyzài ma'e iapo mehe nupuir kwaw wemiaihu wanuwi a'e.
\q1 
\v 14 Upytywà teko a'e wà, aze waneko haw zawaiw katu wanupe.
\q1 Umupu'àm u'ar ma'e kwer wà.
\q1 
\v 15 Ma'e wikuwe ma'e paw ume'e hehe hemiapo ràm ikatu ma'e hàro pà wà.
\q1 Omono temi'u a'e ma'e wanànàn, aze ima'uhez wà no.
\q1 
\v 16 Wamumai'u mehe,
\q1 Ukatu haw rupi umuhyk kar wama'e wanemi'u rehe we a'e, wikuwe ma'e nànàn a'e.
\q1 
\v 17 Tupàn Tuweharupi Wiko Ma'e ikatuahy wyzài ma'e iapo mehe.
\q1 Wyzài ma'e iapo mehe nupuir kwaw wemiaihu wanuwi a'e.
\q1 
\v 18 Upyta wemiaihu paw wanuwake a'e,
\q1 Aze wenoz tuwe upytywà àwàm izupe wemu'em 'ym pà wà nehe.
\q1 
\v 19 Tupàn omono wanemimutar wanupe upaw rupi a'e, aze ukyze izuwi a'e wà.
\q1 Wenu wanehapukaz mehe màno haw wi wapyro pà wà.
\q1 
\v 20 Aze amo uzamutar katu Tuweharupi Wiko Ma'e wà, uzekaiw wanehe a'e wà.
\q1 Umumaw putar ikatu 'ym ma'e wà.
\q1 
\v 21 Amume'u putar Tupàn Tuweharupi Wiko Ma'e ikatu haw tuweharupi nehe.
\q1 Tuwe wikuwe ma'e paw umume'u her ikatu ma'e ikatu haw tuweharupi wà nehe no.
\c 146
\s1 Tupàn Zaneruwihawete tuweharupi har ikatu haw imume'u haw
\q1 
\v 1 Pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe.
\b
\q1 Tuwe hepy'a umume'u tuwe nekatu haw nehe, o Tuweharupi Wiko Ma'e.
\q1 
\v 2 Amumaw putar hekwarahy paw hezar ikatu haw imume'u pà ihe nehe.
\q1 Amuzàg putar zegar haw ikatu haw rehe herekuwe mehe we ihe nehe.
\b
\q1 
\v 3 Pezeruzar zo teko ikàg ma'e hemetarer katu ma'e wanehe nehe.
\q1 Pezeruzar zo teko wanehe nehe.
\q1 Ta'e umàno ma'e ràm romo wanekon a'e wà xe.
\q1 Nupuner kwaw upurupyro haw rehe wà.
\q1 
\v 4 Umàno mehe uzewyr putar ywy rehe wà.
\q1 A'e 'ar mehe we wanemiapo putar haw upaw tuwe.
\b
\q1 
\v 5 Hurywete teko Zako izar wi upytywà haw ipyhykar wà.
\q1 Hurywete uzar Tuweharupi Wiko Ma'e rehe uzeruzar ma'e wà.
\q1 
\v 6 Ywak iapo arer romo hekon a'e. Ywy iapo arer romo no.
\q1 Yryhu iapo arer romo hekon, wanehe har paw iapo arer romo no.
\q1 Tuweharupi Wiko Ma'e uzapo tuwe ma'e wemimume'u kwer rupi katete tuweharupi a'e.
\q1 
\v 7 Aze ikàg ma'e imunar ikàg 'ym ma'e wama'e rehe nehe, Tupàn uzekaiw a'e ikàg 'ym ma'e wanehe a'e.
\q1 Omono temi'u ima'uhez ma'e wanupe no.
\q1 Tupàn Tuweharupi Wiko Ma'e umuhem kar imunehew pyrer zemunehew paw wi a'e wà xe.
\q1 
\v 8 Umupyhàgatu kar hehàpyhà 'ym ma'e wà.
\q1 Tupàn Tuweharupi Wiko Ma'e upir u'ar ma'e kwer wà no.
\q1 Aze teko weruzar Tupàn wà, Tupàn uzamutar katu a'e teko a'e wà.
\q1 
\v 9 Tupàn Tuweharupi Wiko Ma'e uzekaiw amo ae ywy rehe arer zaneywy rehe wiko ma'e wanehe.
\q1 Upytywà kuzà imen umàno ma'e kwer wà. Upytywà kwarer a'e wà, kuzàtài a'e wà no, aze wanu umàno wanuwi wà, aze wahy umàno wanuwi wà.
\q1 Aze ikatu 'ym ma'e umume'u wemiapo ràm wà, Tupàn nuzapo kar kwaw wanupe a'e.
\q1 
\v 10 Tupàn Tuweharupi Wiko Ma'e wiko putar tuwihawete romo tuweharupi nehe.
\q1 O Zeruzarez, nezar wiko putar tuwihawete romo tuweharupi nehe.
\b
\q1 Pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe.
\c 147
\s1 Tupàn Ikàg Wera'u Ma'e ikatu haw imume'u haw
\q1 
\v 1 Pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe.
\b
\q1 Ikatu zanezar pe ikatu haw rehe zanezegar haw.
\q1 Imume'u haw zanemurywete a'e, ikatu a'e no.
\q1 
\v 2 Tupàn Tuweharupi Wiko Ma'e uzapo wi Zeruzarez tawhu hereko a'e.
\q1 Werur wi wemiaihu waneruwà wanereko a'e pe wà.
\q1 Uhàuhàz hemiaihu amo ae ywy nàn ipyhyk pyrer romo wà.
\q1 
\v 3 Umukatu uzemumikahy tuwe ma'e wà.
\q1 Omono muhàg wakutuk awer rehe a'e, wakixi awer rehe a'e.
\b
\q1 
\v 4 A'e ae umume'u zahytata waneta àwàm kwehe mehe a'e.
\q1 Omono waner wanupe pitàitàigatu wà no.
\q1 
\v 5 Tupàn Zanezar a'e, uhua'u a'e. Upuner a'e no.
\q1 Ni amo nupuner kwaw ima'ekwaw paw ikwaw paw rehe wà.
\q1 
\v 6 Tupàn Tuweharupi Wiko Ma'e umukàg ikàg 'ym ma'e wà.
\q1 Ukamik ikatu 'ym ma'e ywy rehe wà.
\b
\q1 
\v 7 Pemuzàg zegar haw Tupàn Tuweharupi Wiko Ma'e pe ikatu haw imume'u pà nehe.
\q1 Pemupu pewioràwiràn zanezar pe ikatu haw rehe zegar haw imuzàg pà nehe.
\q1 
\v 8 Upyk ywak ywàkun pupe a'e.
\q1 Umugyr kar àmàn ywy rehe.
\q1 Umuezuz kar ka'api'i ywytyruhu rehe.
\q1 
\v 9 Omono temi'u ma'ea'yr wanupe.
\q1 Opoz zàpuuna'ya'yr wemi'u henoz mehe wà.
\b
\q1 
\v 10 Kawaru ikàg ma'e nuiko kwaw Tupàn imurywete kar har romo wà.
\q1 Zauxiapekwer ukyze 'ym ma'e numurywete kar kwaw Tupàn wà.
\q1 
\v 11 Izuwi ukyze ma'e a'e wà, a'e ae umurywete kar a'e wà.
\q1 Ipuruamutar katu haw rehe uzeruzar ma'e a'e wà, a'e ae umurywete kar a'e wà.
\b
\q1 
\v 12 Emume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe, o Zeruzarez tawhu.
\q1 Emume'u nezar ikatu haw nehe, o Xiàw ywytyr,
\q1 
\v 13 Ta'e umukàg tawhu hukenaw a'e xe.
\q1 Omono uze'egatu teko a'e pe har wanehe no.
\q1 
\v 14 Numuixe kar kwaw waàmàtyry'ymar waywyzaw rupi wà.
\q1 Omono arozràn ikatu wera'u ma'e wemiaihu wanupe wanemi'u ràm romo.
\b
\q1 
\v 15 Tupàn Tuweharupi Wiko Ma'e umume'u wemiapo putar haw purupe a'e.
\q1 Aze iho wer amo me, uhem na'arewahy a'e pe.
\q1 
\v 16 Umugyr kar àmànxig àràpuhàràn hawitu zàwenugar.
\q1 Umuhàmuhàz zuwiri huwixàg ma'e ywyku'i ài.
\q1 
\v 17 Umur kar àmànita a'e, 'y tàtà huwixàg ma'e ikaika pyrer a'e.
\q1 Tuwixàgaw imur mehe ni amo teko nupuner kwaw izupe wà.
\q1 
\v 18 Umume'u wemimutar.
\q1 Na'e 'y tàtà huwixàgahy ma'e typyràn na'arewahy. Umur kar ywytu. Umuyryk kar 'y.
\b
\q1 
\v 19 Tuweharupi Wiko Ma'e umume'u uze'eg Zako izuapyapyr wanupe.
\q1 Omono wemiapo putar haw Izaew wanupe. Omono uze'eg wanupe no.
\q1 
\v 20 Nuzapo pixik kwaw agwer ma'e amo ae ywy rehe har wanupe.
\q1 Amogwer ywy rehe har nukwaw kwaw ize'eg wà.
\b
\q1 Pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe.
\c 148
\s1 Teko ywy nànànar wà, ma'e upaw rupi no, umume'u Tupàn ikatu haw izupe wà
\q1 
\v 1 Pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe.
\b
\q1 Ywak rehe har paw wà,
\q1 Pemume'u Tuweharupi Wiko Ma'e ikatu haw ywate nehe.
\q1 
\v 2 Pe Tupàn Tuweharupi Wiko Ma'e heko haw pe har paw pe wà, pemume'u ikatu haw nehe.
\q1 Pe zauxiapekwer zàwenugar ywate har paw pe wà, pemume'u ikatu haw nehe.
\q1 
\v 3 Kwarahy, zahy. Pemume'u Tuweharupi Wiko Ma'e ikatu haw nehe.
\q1 Zahytata heny katu ma'e paw, pemume'u Tupàn ikatu haw nehe.
\q1 
\v 4 Tuwe ywak ywate har umume'u ikatu haw nehe.
\q1 Tuwe 'y ywak i'aromo har umume'u ikatu haw nehe.
\b
\q1 
\v 5 Tuwe a'e paw umume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw wà nehe,
\q1 Ta'e uze'eg waapo pà a'e xe.
\q1 
\v 6 Umume'u wanen àwàm. Upyta tuweharupi wenaw rehe wà.
\q1 Nupuner kwaw heruzar 'ymaw rehe wà.
\q1 
\v 7 Pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe, ywy rehe har paw wà.
\q1 Pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe, miar yryhu pe har uhua'u ma'e wà, yryhu ohoete haw no.
\q1 
\v 8 Àmàn iweraw paw, àmànita, àmànxig huwixàg ma'e, ywàkun, ywytuaiw.
\q1 Peiko Tupàn ze'eg heruzar har romo. Pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe.
\q1 
\v 9 Ywytyr wà, ywytyruhu wà,
\q1 Ka'ahu wà, ma'ywa'yw wà no, pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe.
\q1 
\v 10 Ma'ea'yr teko waneimaw wà, miar hehaite ma'e wà no, pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe.
\q1 Wiràmiri wà, ma'e wie rehe ywy rehe wata ma'e wà, pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe.
\b
\q1 
\v 11 Tuwihawete wà, teko ywy nànànar wà no,
\q1 Tuwihaw paw wà,
\q1 Tàmuzgwer paw wà no, pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe.
\q1 
\v 12 Kwàkwàmo wà, kuzàwaza wà, awa tua'uhez ma'e wà, kuzà ihya'uhez ma'e wà,
\q1 Kwarearer wà, kuzàtàigwer wà, pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe.
\q1 
\v 13 Tuwe umume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw upaw rupi wà nehe,
\q1 Ta'e ikàg wera'u amo wanuwi a'e xe.
\q1 Ikàgaw a'e, ipuràg eteahy haw a'e no, ywy 'ar amo ywak 'aromo hin a'e wà.
\q1 
\v 14 Umukàg kar teko wemiaihu wà.
\q1 A'e rupi hemiruze'eg izuwi upuir 'y ma'e paw umume'u ikatu haw wà.
\q1 Teko Izaew izuapyapyr Tupàn hemiamutar katu wà, umume'u putar ikatu haw wà nehe.
\b
\q1 Pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe.
\c 149
\s1 Tupàn ikatu haw rehe zegar haw
\q1 
\v 1 Pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe.
\b
\q1 Pemuzàg zegar haw ipyahu ma'e Tupàn Tuweharupi Wiko Ma'e pe nehe.
\q1 Imuwete katu har wazemono'ogaw pe, pemume'u Tupàn ikatu haw nehe.
\q1 
\v 2 O teko Izaew izuapyapyr wà, penurywete peapo arer rehe nehe.
\q1 Penurywete penuwihawete rehe nehe, o teko Zeruzarez pe har wà.
\q1 
\v 3 Pemume'u ikatu haw pepynyk pà nehe.
\q1 Pemume'u ikatu haw imupu pyr imupumupu pà nehe. Pemume'u ikatu haw pewioràwiràn imupumupu pà nehe,
\b
\q1 
\v 4 ta'e Tupàn Tuweharupi Wiko Ma'e hemiaihu ikatu izupe a'e wà xe.
\q1 Umuigo kar ikàg 'ym ma'e wàmàtyry'ymar waneityk arer romo wà.
\q1 
\v 5 Tuwe Tupàn hemiaihu hurywete wàmàtyry'ymar waneityk awer rehe wà nehe.
\q1 Tuwe uzegar urywete haw rupi upynykaw pe wà nehe.
\q1 
\v 6 Tuwe umume'u Tupàn ikatu haw wahy haw rupi wà nehe,
\q1 Takihepuku haime katu ma'e opo pe heraha pà wà nehe,
\q1 
\v 7 ywy nànànar waneityk àwàm rehe wà nehe,
\q1 Teko nànàn uzepyk àwàm rehe wà nehe.
\q1 
\v 8 Tuwe uzàpixipixi wanuwihawete kyhàhàm pupe wà nehe.
\q1 Tuwe kyhàhàm tàtà pupe uzàpixipixi wanàmuz wà nehe.
\q1 
\v 9 Tuwe uzepyk ywy nànànar Tupàn ze'eg rupi katete wà nehe.
\q1 Nezewe Tupàn hemiaihu weityk putar wàmàtyry'ymar wà nehe.
\b
\q1 Pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe.
\c 150
\s1 Pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw izupe nehe
\q1 
\v 1 Pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe.
\b
\q1 Pemume'u Tupàn ikatu haw hàpuzuhu pupe nehe.
\q1 Pemume'u ikàgaw ywak rehe hexak pyr nehe.
\q1 
\v 2 Pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw nehe, ta'e uzapo uhua'u ma'e a'e xe.
\q1 Pemume'u uhua'u haw ikatu haw nehe.
\q1 
\v 3 Pemume'u Tupàn ikatu haw xi'àm tapi'ak i'ak kwer iapo pyrer ipy pà nehe.
\q1 Pemume'u Tupàn ikatu haw pewioràwiràn imupu pà nehe. Pemume'u Tupàn ikatu haw pewioràwiràn pixika'i ma'e imupu pà nehe.
\q1 
\v 4 Pemume'u Tupàn ikatu haw ipuipu ma'e imupu pà nehe. Pemume'u Tupàn Tuweharupi Wiko Ma'e ikatu haw pepynyk pà nehe.
\q1 Pemume'u ikatu haw pewioràwiràn imupu pà nehe. Pemume'u ikatu haw xi'àm ipy pà nehe.
\q1 
\v 5 Pemume'u Tupàn ikatu haw kawawpew imupu pà nehe.
\q1 Pemume'u ikatu haw kawawpew imupuahy pà nehe.
\q1 
\v 6 Wikuwe ma'e paw wà, pemume'u Tuweharupi Wiko Ma'e ikatu haw nehe.
\b
\q1 Pemume'u Tupàn ikatu haw nehe. 
