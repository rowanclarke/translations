\v 10 \x - \xo 19.10 \xt Mat 18. 11.\x*\wj \+w Hlang|strong="G0444"\+w* \+w Capa|strong="G5207"\+w* ha \+w pawk|strong="G2064"\+w* he aka \+w poci|strong="G0622"\+w* \+w te|strong="G3588"\+w* \+w toem|strong="G2212"\+w* ham \+w neh|strong="G2532"\+w* \+w khang|strong="G4982"\+w* ham rhoe \+w pai|strong="G1063"\+w* ni,” \wj* a \w ti|strong="G2036"\w*.   
\s1 Tangka Nuettahnah  
\p
