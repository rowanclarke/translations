\c 10  
\p
\v 1 \w The|strong="H3205"\w* following \w are|strong="H1121"\w* \w the|strong="H3205"\w* \w genealogies|strong="H8435"\w*\f + \fr 10:1 \ft These genealogies are repeated in \xt 1 Chronicles 1:5-27\ft .\f* \w of|strong="H1121"\w* \w the|strong="H3205"\w* \w sons|strong="H1121"\w* \w of|strong="H1121"\w* \w Noah|strong="H5146"\w*: \w Shem|strong="H8035"\w*, \w Ham|strong="H2526"\w*, \w and|strong="H1121"\w* \w Japheth|strong="H3315"\w*. \w They|strong="H3205"\w* \w had|strong="H3205"\w* \w sons|strong="H1121"\w* \w born|strong="H3205"\w* \w to|strong="H3205"\w* \w them|strong="H1121"\w* after \w the|strong="H3205"\w* \w flood|strong="H3999"\w*.   
\p
\v 2 \w The|strong="H1121"\w* \w sons|strong="H1121"\w*\f + \fr 10:2 \ft Note that “sons” throughout this chapter can also mean “descendants.”\f* \w of|strong="H1121"\w* \w Japheth|strong="H3315"\w*: \w Gomer|strong="H1586"\w*, \w Magog|strong="H4031"\w*, \w Madai|strong="H4074"\w*, \w Javan|strong="H3120"\w*, \w Tubal|strong="H8422"\w*, \w Meshech|strong="H4902"\w*, \w and|strong="H1121"\w* \w Tiras|strong="H8494"\w*.   
\p
\v 3 \w The|strong="H1121"\w* \w sons|strong="H1121"\w* \w of|strong="H1121"\w* \w Gomer|strong="H1586"\w*: Ashkenaz, \w Riphath|strong="H7384"\w*, \w and|strong="H1121"\w* \w Togarmah|strong="H8425"\w*.   
\p
\v 4 \w The|strong="H1121"\w* \w sons|strong="H1121"\w* \w of|strong="H1121"\w* \w Javan|strong="H3120"\w*: Elishah, \w Tarshish|strong="H8659"\w*, \w Kittim|strong="H3794"\w*, \w and|strong="H1121"\w* \w Dodanim|strong="H1721"\w*.\f + \fr 10:4 \ft “Dodanim”: the Septuagint takes the spelling to be Rodanim, as does the parallel passage in \xt 1 Chronicles 1:7\ft . Note that the last two names at least are probably those of a group of people rather than a personal name.\f*  
\v 5 \w The|strong="H6504"\w* \w descendants|strong="H4940"\w* \w of|strong="H4940"\w* these ancestors \w spread|strong="H6504"\w* throughout \w the|strong="H6504"\w* coastal areas, \w each|strong="H1471"\w* group having \w their|strong="H1471"\w* own \w language|strong="H3956"\w*, \w with|strong="H6504"\w* \w their|strong="H1471"\w* \w families|strong="H4940"\w* developing into different \w nations|strong="H1471"\w*.   
\p
