\p
\v 9 \w God|strong="H8064"\w* \w said|strong="H3651"\w*, “\w Let|strong="H1961"\w* \w the|strong="H7200"\w* \w waters|strong="H4325"\w* \w below|strong="H8478"\w* \w the|strong="H7200"\w* \w sky|strong="H8064"\w* collect \w together|strong="H6960"\w* \w in|strong="H4725"\w* \w one|strong="H7200"\w* \w place|strong="H4725"\w* \w so|strong="H3651"\w* \w that|strong="H7200"\w* \w the|strong="H7200"\w* \w land|strong="H3004"\w* \w may|strong="H1961"\w* \w appear|strong="H7200"\w*.” \w And|strong="H8064"\w* \w so|strong="H3651"\w* \w it|strong="H3651"\w* \w was|strong="H1961"\w*.  
