\v 24 \w Joab|strong="H3097"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Sarvia, \w comenzó|strong="H2490"\w* \w a|strong="H3068"\w* contar, pero \w no|strong="H3808"\w* \w acabó|strong="H3615"\w*, \w pues|strong="H1961"\w* \w por|strong="H5921"\w* \w eso|strong="H2063"\w* \w hubo|strong="H1961"\w* una explosión \w de|strong="H5921"\w* \w ira|strong="H7110"\w* \w contra|strong="H5921"\w* \w Israel|strong="H3478"\w*. \w Así|strong="H2063"\w* \w el|strong="H5921"\w* \w número|strong="H4557"\w* \w no|strong="H3808"\w* \w fue|strong="H1961"\w* colocado \w en|strong="H5921"\w* \w el|strong="H5921"\w* registro \w de|strong="H5921"\w* \w las|strong="H5921"\w* crónicas \w del|strong="H5921"\w* \w rey|strong="H4428"\w* \w David|strong="H1732"\w*.   
\s1 Otros funcionarios del rey David  
\p
