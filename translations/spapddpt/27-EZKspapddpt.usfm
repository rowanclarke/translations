\p \w Tal|strong="H3651"\w* \w fue|strong="H1961"\w* \w la|strong="H1931"\w* \w visión|strong="H4758"\w* \w de|strong="H5921"\w* \w la|strong="H1931"\w* \w apariencia|strong="H4758"\w* \w de|strong="H5921"\w* \w la|strong="H1931"\w* \w gloria|strong="H3519"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*. \w Cuando|strong="H3117"\w* \w la|strong="H1931"\w* \w vi|strong="H7200"\w*, \w caí|strong="H5307"\w* \w sobre|strong="H5921"\w* \w mi|strong="H5921"\w* \w rostro|strong="H6440"\w*. \w Entonces|strong="H3117"\w* \w oí|strong="H8085"\w* una \w voz|strong="H6963"\w* \w que|strong="H1931"\w* \w hablaba|strong="H1696"\w*.   
\c 2  
\s1 Encomienda al sacerdote Ezequiel  
\p
\v 1 \w Me|strong="H5921"\w* \w dijo|strong="H1696"\w*: \wj \+w Hijo|strong="H1121"\+w* \+w de|strong="H5921"\+w* \+w hombre|strong="H1121"\+w*, \+w ponte|strong="H5975"\+w* \+w en|strong="H5921"\+w* \+w pie|strong="H7272"\+w* \+w y|strong="H5921"\+w* \+w hablaré|strong="H1696"\+w* \+w contigo|strong="H5921"\+w*.\wj*  
