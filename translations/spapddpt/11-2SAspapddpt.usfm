\v 9 \w Y|strong="H3068"\w* el \w rey|strong="H4428"\w* le dijo: \w Vé|strong="H3212"\w* \w en|strong="H3212"\w* \w paz|strong="H7965"\w*. Así que se \w levantó|strong="H6965"\w* y se \w fue|strong="H3212"\w* \w a|strong="H3068"\w* \w Hebrón|strong="H2275"\w*.
\p 
\v 10 Pero Absalón \w envió|strong="H7971"\w* mensajeros\f + \fr 15:10 \ft Lit. espías.\f* por \w todas|strong="H3605"\w* las \w tribus|strong="H7626"\w* de \w Israel|strong="H3478"\w*, \w a|strong="H3068"\w* \w decir|strong="H8085"\w*: Al \w oír|strong="H8085"\w* \w el|strong="H3605"\w* \w sonido|strong="H6963"\w* de \w la|strong="H3605"\w* \w corneta|strong="H7782"\w*, dirán: ¡Absalón \w reina|strong="H4427"\w* en \w Hebrón|strong="H2275"\w*!
\v 11 Con Absalón salieron \w de|strong="H1697"\w* Jerusalén 200 hombres como invitados, \w que|strong="H3808"\w* en su ingenuidad \w iban|strong="H1980"\w* \w sin|strong="H3808"\w* \w saber|strong="H3045"\w* \w algo|strong="H1697"\w* \add del motivo\add*.
\v 12 Mientras \w ofrecía|strong="H2076"\w* \w los|strong="H1961"\w* \w sacrificios|strong="H2077"\w*, Absalón \w envió|strong="H7971"\w* \w a|strong="H3068"\w* buscar \w a|strong="H3068"\w* Ahitofel \w gilonita|strong="H1526"\w*, \w consejero|strong="H3289"\w* \w de|strong="H5971"\w* \w David|strong="H1732"\w*, desde Gilo su \w ciudad|strong="H5892"\w*. La conspiración \w fue|strong="H1961"\w* fuerte, \w pues|strong="H1961"\w* aumentaba el \w pueblo|strong="H5971"\w* \w a|strong="H3068"\w* favor \w de|strong="H5971"\w* Absalón.
\p 
\v 13 Entonces un \w mensajero|strong="H5046"\w* \w fue|strong="H1961"\w* \w a|strong="H3068"\w* \w David|strong="H1732"\w* y \w dijo|strong="H5046"\w*: ¡\w Los|strong="H1961"\w* corazones de \w los|strong="H1961"\w* hombres de \w Israel|strong="H3478"\w* \w se|strong="H1961"\w* van tras Absalón!
\p 
\v 14 \w David|strong="H1732"\w* dijo \w a|strong="H3068"\w* \w todos|strong="H3605"\w* sus esclavos \w que|strong="H3588"\w* \w estaban|strong="H1961"\w* \w con|strong="H5921"\w* \w él|strong="H5921"\w* \w en|strong="H5921"\w* Jerusalén: ¡\w Levántense|strong="H6965"\w* \w y|strong="H3588"\w* huyamos, \w porque|strong="H3588"\w* \w ninguno|strong="H3808"\w* \w de|strong="H5921"\w* \w nosotros|strong="H3605"\w* \w escapará|strong="H6413"\w* \w de|strong="H5921"\w* Absalón! ¡Dense prisa \w en|strong="H5921"\w* salir, \w no|strong="H3808"\w* \w sea|strong="H1961"\w* \w que|strong="H3588"\w* \w se|strong="H1961"\w* apresure, \w nos|strong="H5921"\w* \w alcance|strong="H5381"\w* \w y|strong="H3588"\w* derrame \w la|strong="H5921"\w* calamidad \w sobre|strong="H5921"\w* \w nosotros|strong="H3605"\w*, \w y|strong="H3588"\w* destruya \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w* \w a|strong="H3068"\w* filo \w de|strong="H5921"\w* \w espada|strong="H2719"\w*!
\p 
\v 15 \w Los|strong="H3605"\w* esclavos contestaron \w al|strong="H4428"\w* \w rey|strong="H4428"\w*: ¡\w Mira|strong="H2009"\w*, tus esclavos \w están|strong="H2009"\w* para \w cualquier|strong="H3605"\w* \w cosa|strong="H3605"\w* \w que|strong="H3605"\w* nuestro \tl ʼadón\tl* \w el|strong="H3605"\w* \w rey|strong="H4428"\w* disponga!
\p 
\v 16 Entonces \w el|strong="H3605"\w* \w rey|strong="H4428"\w* \w salió|strong="H3318"\w* con \w toda|strong="H3605"\w* su \w casa|strong="H1004"\w* tras \w él|strong="H3605"\w*. Pero \w el|strong="H3605"\w* \w rey|strong="H4428"\w* \w dejó|strong="H5800"\w* \w a|strong="H3068"\w* \w diez|strong="H6235"\w* mujeres \w concubinas|strong="H6370"\w* para \w que|strong="H3605"\w* cuidaran \w la|strong="H3605"\w* \w casa|strong="H1004"\w*.
\v 17 \w El|strong="H3605"\w* \w rey|strong="H4428"\w* \w salió|strong="H3318"\w* con \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* tras \w él|strong="H3605"\w*, y \w se|strong="H5971"\w* detuvieron \w en|strong="H3318"\w* \w la|strong="H3605"\w* última casa.
\v 18 \w Todos|strong="H3605"\w* sus esclavos \w pasaron|strong="H5674"\w* \w a|strong="H3068"\w* su \w lado|strong="H3027"\w*: \w Todos|strong="H3605"\w* \w los|strong="H5921"\w* cereteos, \w los|strong="H5921"\w* peleteos \w y|strong="H5921"\w* \w los|strong="H5921"\w* geteos, 600 hombres \w que|strong="H5921"\w* \w seguían|strong="H5921"\w* tras \w él|strong="H5921"\w* \w desde|strong="H5921"\w* Gat, \w pasaron|strong="H5674"\w* \w delante|strong="H6440"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w*.
