\id MIC
\h Maika
\toc1 Ko E Tohi  Ľae PalŇćfita Ko Maika
\toc2 Maika
\toc3 Maik
\mt2 KO E TOHI
\mt3  ĽAE PALŇĆFITA KO
\mt1 MAIKA
\cl KO E VAHE
\c 1
\cd \it 1  ĽOku fakahńĀ  Ľe Maika  Ľae houhau  Ľoe  ĽOtua kia Sńďkope koe Ľuhi ko  Ľene tauhi tamapua. 10  ĽOku enginaki ke nau fakatomala.\it*
\p 
\v 1 Ko e folofola  Ľa Sihova  Ľaia na Ľe hoko kia Maika, ko e tangata Molesi,  Ľi he ngaahi  Ľaho  Ľo Sotami, mo  ĽAhasi, mo Hesekaia, ko e ngaahi tu Ľi  Ľo Siuta,  Ľaia na Ľa ne mamata ai na Ľe kau ki Samńďlia mo SelŇęsalema.
\q1 
\v 2 Fanongo  Ľakimoutolu  Ľae kakai kotoa pńď;
\q2 fakafanongo  Ľe mńĀmani, mo ia kotoa pńď  Ľoku  Ľi ai:
\q1 pea tuku ke talatalaaki Ľi  Ľakimoutolu  Ľe he  ĽEiki ko e  ĽOtua,
\q2 ko e  ĽEiki mei hono fale tapu.
\q1 
\v 3 He vakai,  Ľoku hńĀ Ľele mai  Ľa Sihova mei hono potu,
\q2 pea te ne hńĀ Ľele mai mo tu Ľu  Ľi he potu mńĀ Ľolunga  Ľo mńĀmani.
\q1 
\v 4 Pea  Ľe vela  Ľo vai  Ľae ngaahi mo Ľunga  Ľi lalo  Ľiate ia,
\q2 pea  Ľe mafahi  Ľae ngaahi tele Ľa,
\q2 hangńď ko e pulu  Ľi he  Ľao  Ľoe afi,
\q2 pe hangńď ko e vai  Ľoku lilingi  Ľi ha potu tahifohifo.
\b
\q1 
\v 5 ‚Äú ĽOku hoko  Ľae ngaahi me Ľa ni, koe Ľuhi ko e angahala  Ľa Sńďkope,
\q2 pea koe Ľuhi ko e ngaahi hia  Ľae fale  Ľo  ĽIsileli.
\q1 Ko e hńĀ  Ľae angahala  Ľa Sńďkope?
\q2  ĽIkai ko Samńďlia?
\q1 Pea ko e hńĀ  Ľae ngaahi potu MńĀ Ľolunga  Ľo Siuta?
\q2  ĽIkai ko SelŇęsalema?
\q1 
\v 6 Ko ia te u ngaohi  Ľa Samńďlia ke hangńď ha puke  Ľoe ngoue,
\q2 pea hangńď ko e ngaahi va Ľa  Ľakau  Ľoku tŇć  Ľi he ngoue vaine:
\q1 pea te u lilingi  Ľae ngaahi maka  Ľo ia ki he tele Ľa,
\q2 pea te u fakahńĀ  Ľa hono ngaahi tu Ľunga.
\q1 
\v 7 Pea ko e ngaahi tamapua kuo tongi  Ľi ai,  Ľe laiki,
\q2 pea ko e ngaahi totongi kotoa pńď  Ľo ia,  Ľe tutu  Ľaki  Ľae afi,
\q2 pea ko e ngaahi tamapua ko ia te u fakalala:
\q1 he na Ľa ne tńĀnaki ia mei he totongi  Ľoe muitau,
\q2 pea  Ľe foki ia ki he totongi  Ľoe muitau.‚ÄĚ
\b
\q1 
\v 8 Ko ia te u tangilńĀulau mo  Ľioho,
\q2 te u  Ľalu veteki pe mo telefua:
\q2 te u tangi  Ľo hangńď ha fanga siakali,
\q2 pea tangi mamahi  Ľo hangńď ko e fanga lulu.
\q1 
\v 9 He ko hono lavea  Ľoku ta Ľefa Ľafakamo Ľui;
\q2 he kuo hoko ia  Ľo a Ľu ki Siuta,
\q1 kuo ne hoko ki he matapńĀ  Ľo hoku kakai,
\q2  Ľio, ki SelŇęsalema.
\q1 
\v 10 ‚ÄĆ ĽOua na Ľa fakahńĀ ia  Ľi Kati,
\q2  Ľoua  Ľaupito na Ľa mou tangi:
\q2  Ľi he fale  Ľo  ĽAfala, ke ke tekefili  Ľi he efu.
\q1 
\v 11 Mole atu  Ľa koe  Ľoku nofo  Ľi Safila, mo e mńĀ  Ľa ho telefua:
\q2 na Ľe  Ľikai ke hŇę mai  Ľae kakai  Ľo Senani  Ľi he tangi  Ľa Petesili;
\q2 te ne ma Ľu meiate kimoutolu  Ľa hono tu Ľunga.
\q1 
\v 12 He na Ľe tatali  Ľamanaki pe ki he lelei  Ľae kau nofo  Ľi Maloti:
\q2 ka na Ľe hoko  Ľae kovi meia Sihova, ki he matapńĀ  Ľo SelŇęsalema.
\q1 
\v 13 ‚ÄĆ ĽE!  ĽA koe  Ľoku nofo  Ľi Lakisi, no Ľotaki  Ľae saliote ki he manu ve Ľe vave:
\q2 ko e kamata Ľanga ia  Ľoe angahala ki he  Ľofefine  Ľa Saione:
\q2 he ko e ngaahi angahala  Ľa  ĽIsileli, na Ľe  Ľilo  Ľiate koe.
\q1 
\v 14 Ko ia te ke ange  Ľae ngaahi foaki ki Molesiti-Kati:
\q2  Ľe hoko  Ľae ngaahi fale  Ľo  ĽAkisipi, ko e loi ki he ngaahi tu Ľi  Ľo  ĽIsileli.
\q1 
\v 15 Ka te u  Ľomai ha foha hoko kiate koe,  Ľa koe  Ľoku nofo  Ľi Malesa:
\q2 te ne ha Ľu ki  ĽAtulami, ko e nńĀunau  Ľo  ĽIsileli.
\q1 
\v 16 Fakatekefua mo kosi koe,
\q2 koe Ľuhi ko ho Ľo fńĀnau fakapelepele Ľi;
\q1 fakalahi ho tula hangńď ko e  Ľikale;
\q2 he kuo nau  Ľalu ki he pŇćpula meiate koe.
\b
\c 2
\cd \it 1 Ki he fakamńĀlohi. 4 Ko e tangilńĀulau. 7 Ko e valoki ki he ta Ľetotonu mo e tauhi tamapua. 12 Ko e tala Ľofa ki he toe  Ľomi  Ľo Sńďkope.\it*
\q1 
\v 1 Mala Ľia kiate kinautolu  Ľoku fakatupu hia,
\q2 mo filio Ľi kovi  Ľi honau mohenga!
\q1  ĽOka maama  Ľae pongipongi,  Ľoku nau fai ia,
\q2 koe Ľuhi  Ľoku  Ľi he mńĀlohi  Ľa honau nima.
\q1 
\v 2 Pea  Ľoku nau faka Ľamu ki he ngaahi ngoue, pea fa Ľao fakamńĀlohi ia;
\q2 mo e ngaahi fale, pea  Ľave ia;
\q2  Ľoku pehńď  Ľenau fakamńĀlohi  Ľae tangata mo hono fale,
\q2  Ľio,  Ľae tangata mo hono tofi Ľa.
\q1 
\v 3 Ko ia  Ľoku pehńď  Ľe Sihova;
\q1 ‚ÄúVakai,  Ľoku ou fakatupu ha kovi ki he fńĀnau ni,
\q2  Ľaia  Ľe  Ľikai hao mei ai homou kia:
\q2 pea  Ľe  Ľikai te mou  Ľalu mo e fielahi;
\q2 he  Ľoku kovi  Ľae kuonga ni.
\p 
\v 4 ¬∂  ĽI he  Ľaho ko ia,  Ľe fokotu Ľu  Ľe ha taha ha lea fakatńĀtńĀ kiate kimoutolu,
\q2 pea tangi  Ľaki  Ľae tangi mamahi, pea pehńď,
\q2 ‚ÄėKuo tau maumau  Ľaupito:
\q2 kuo ne fakakehe  Ľae tofi Ľa  Ľo hoku kakai:  Ľa  Ľene  Ľave ia meiate au!
\q2  ĽI he Ľene tafoki atu, kuo ne vahevahe hotau ngaahi ngoue.‚Äô‚ÄĚ
\q1 
\v 5 Ko ia  Ľe  Ľikai toe kiate koe ha ni Ľihi, ke lńę ha afo  Ľi he talotalo  Ľi he fakataha  Ľo Sihova.
\q1 
\v 6 ‚ÄĆ ĽOku nau pehńď kiate kinautolu  Ľoku kikite,
\q2 ‚Äú ĽOua na Ľa mou kikite:‚ÄĚ
\q1 ‚Äú ĽE  Ľikai te nau kikite kiate kinautolu,
\q2 pea  Ľe  Ľikai te nau mńĀ.‚ÄĚ
\q1 
\v 7 ‚ÄĆ ĽA koe kuo ui ko e fale  Ľo Sńďkope,
\q2 ‚Äú ĽOku  Ľapi Ľapi końĀ  Ľae LaumńĀlie  Ľo Sihova?
\q2 Ko e ngaahi me Ľa ni, ko  Ľene ngńĀue?
\q2  ĽIkai  Ľoku hoko lelei  Ľa  Ľeku ngaahi lea kiate ia  Ľoku  Ľeve Ľeva totonu?‚ÄĚ
\q1 
\v 8 ‚Äú ĽIo, kuo tu Ľu hake ki mui ni  Ľa hoku kakai kiate au, hangńď ha fili:
\q2  Ľoku mou hamusi  Ľae kofutu Ľa mo e kofu loto meiate kinautolu  Ľoku  Ľalu atu  Ľi he melino, hangńď ko e kau tangata ta Ľepoto ki he tau.
\q1 
\v 9 Kuo mou kapusi  Ľae kau fefine  Ľo hoku kakai mei honau ngaahi fale lelei;
\q2 mei he Ľenau fńĀnau, kuo mou  Ľave hoku nńĀunau  Ľo lauikuonga.
\q1 
\v 10 Mou tu Ľu hake  Ľo  Ľalu;
\q2 he  Ľoku  Ľikai ko homou mńĀlŇćlŇć Ľanga eni;
\q2 koe Ľuhi  Ľoku  Ľuli ia  Ľe fai  Ľae faka Ľauha,
\q2  Ľio,  Ľae faka Ľauha lahi.
\q1 
\v 11 Kapau  Ľoku ai ha tangata  Ľoku  Ľeve Ľeva  Ľi he laumńĀlie mo e loi,
\q2 pea ne pehńď, ‚ÄúTe u kikite kiate koe ki he uaine, mo e kava mńĀlohi;‚ÄĚ
\q2 ko e mo Ľoni  Ľe hoko ia ko e palŇćfita ki he kakai ni.
\q1 
\v 12 Ko e mo Ľoni te u tńĀnaki  Ľa ho Ľo kńĀtoa,  Ľe Sńďkope;
\q2 ko e mo Ľoni te u tńĀnaki  Ľae toenga  Ľo  ĽIsileli;
\q1 te u fakataha  Ľakinautolu,  Ľo hangńď ko e fanga sipi  Ľo Posila,
\q2 hangńď ko e fanga sipi  Ľi he loto ĽńĀ sipi:
\q2  Ľe lahi  Ľae patatŇę ko e me Ľa  Ľi he \add tokolahi  Ľoe \add*kau tangata.‚ÄĚ
\q1 
\v 13 Kuo  Ľalu hake  Ľi honau  Ľao  Ľaia  Ľoku fakaava:
\q2 kuo nau movete mo laka atu  Ľi he matapńĀ, pea kuo nau hŇę ai kitua ĽńĀ:
\q2 pea  Ľe mu Ľomu Ľa  Ľa honau tu Ľi  Ľiate kinautolu,
\q2 pea mo Sihova  Ľi honau  Ľao.
\c 3
\cd \it 1 Ko e anga fakamamahi  Ľae ngaahi hou Ľeiki. 5 Ko e loi  Ľae kau palŇćfita. 8 Ko  Ľena nofo fakafiemńĀlie fakatou Ľosi.\it*
\p 
\v 1 Pea ne u pehńď,
\q2 ‚Äú ĽOku ou kole, fanongo  Ľakimoutolu  Ľae kau mńĀtu Ľa  Ľa Sńďkope,
\q2 pea mo kimoutolu  Ľae hou Ľeiki  Ľoe fale  Ľo  ĽIsileli;
\q2  Ľikai  Ľoku ngali mo kimoutolu ke  Ľilo  Ľae fakamaau?
\q1 
\v 2 ‚ÄĆ ĽAkimoutolu  Ľoku fehi Ľa ki he lelei,
\q2 kae manako ki he kovi;
\q2  Ľaia  Ľoku fohi honau kili meiate kinautolu,
\q2 pea mo honau kakano mei honau ngaahi hui.
\q1 
\v 3 ‚ÄĆ ĽAkimoutolu  Ľoku kai  Ľae kakano  Ľo hoku kakai foki,
\q2 pea fohi  Ľa honau kili meiate kinautolu;
\q2 pea  Ľoku nau fesi Ľi honau ngaahi hui,
\q2 mo tu Ľutu Ľu fakaikiiki  Ľakinautolu,  Ľo hangńď ka teu ki he kulo,
\q2 pea hangńď ko e kakano  Ľi he loto kulo.
\q1 
\v 4 Pea te nau toki tangi kia Sihova,
\q2 ka  Ľe  Ľikai te ne tokanga Ľi kinautolu:
\q1 ko e mo Ľoni  Ľe fakafufŇę  Ľe ia  Ľa hono fofonga meiate kinautolu  Ľi he kuonga ko ia,
\q2  Ľo hangńď ko  Ľenau ngńĀue kovi  Ľi he Ľenau ngaahi faianga.‚ÄĚ
\p 
\v 5 ¬∂  ĽOku pehńď  Ľe Sihova ki he kau palŇćfita,  Ľaia  Ľoku fakahńď Ľi  Ľa hoku kakai;  Ľakinautolu  Ľoku u Ľu  Ľaki honau nifo, pea kalanga, ‚ÄúFiemńĀlie;‚ÄĚ pea ko ia  Ľoku  Ľikai ke ai ki honau ngutu,  Ľio,  Ľoku nau te u tau kiate ia:
\q1 
\v 6 ‚ÄúKo ia  Ľe  Ľiate kimoutolu  Ľae pŇć, ke  Ľoua na Ľa mou ma Ľu ha me Ľa hńĀ mai;
\q2 pea  Ľe po Ľuli kiate kimoutolu ke  Ľoua na Ľa mou kikite;
\q2 pea  Ľe tŇć  Ľae la ĽńĀ ki he kau palŇćfita,
\q2 pea  Ľe po Ľuli  Ľae  Ľaho kiate kinautolu.
\q1 
\v 7 Pea  Ľe toki mńĀ  Ľae kau kikite,
\q2 pea puputu Ľu  Ľae kau faka Ľilo me Ľa:
\q1  Ľio, ko e mo Ľoni, te nau  Ľufi Ľufi kotoa pńď honau loungutu;
\q2 he  Ľoku  Ľikai ha tali mei he  ĽOtua.
\q1 
\v 8 Ka ko e mo Ľoni  Ľoku ou pito  Ľi he mńĀlohi mei he LaumńĀlie  Ľo Sihova,
\q2 pea mo e fakamaau, mo e fa Ľa fai,
\q2 ke fakahńĀ kia Sńďkope  Ľene hia,
\q2 pea ki  ĽIsileli  Ľa  Ľene angahala.
\q1 
\v 9 ‚ÄĆ ĽOku ou kole, fanongo ki ai,  Ľakimoutolu  Ľae kau mńĀtu Ľa  Ľi he fale  Ľo Sńďkope,
\q2 mo e hou Ľeiki  Ľoe fale  Ľo  ĽIsileli,
\q2  Ľaia  Ľoku fehi Ľa ki he fakamaau,
\q2 mo liliu  Ľae me Ľa totonu kotoa pńď.
\q1 
\v 10 ‚ÄĆ ĽOku nau langa  Ľa Saione  Ľaki  Ľae toto,
\q2 mo SelŇęsalema  Ľi he angahala.
\q1 
\v 11 Ko e kau mńĀtu Ľa  Ľi ai  Ľoku fakamaau ke ma Ľu  Ľae foaki,
\q2 pea ko e kau taula Ľeiki  Ľo ia  Ľoku ako ke ma Ľu totongi,
\q2 pea  Ľoku kikite  Ľae kau palŇćfita ke ma Ľu pa Ľanga;
\q1 ka  Ľoku nau falala kia Sihova, mo pehńď,
\q2 ‚Äú ĽIkai  Ľoku  Ľiate kitautolu  Ľa Sihova?
\q2  ĽE  Ľikai ha kovi  Ľe hoko kiate kitautolu.‚ÄĚ
\q1 
\v 12 Ko ia, koe Ľuhi ko kimoutolu,  Ľe keli  Ľa Saione  Ľo hangńď ko e ngoue,
\q2 pea  Ľe hoko  Ľa SelŇęsalema ko e ngaahi tu Ľunga,
\q2 pea mo e mo Ľunga  Ľoe fale, ke hangńď ko e ngaahi potu mńĀ Ľolunga  Ľoe vao  Ľakau.
\b
\c 4
\cd \it 1 Ko e nńĀunau, 3 Mo e melino, 8 Mo e pule; 11 Pea mo e ikuna  Ľae siasi.\it*
\q1 
\v 1 Ka  Ľe hoko  Ľo pehńď  Ľi he ngaahi  Ľaho  Ľamui,
\q2  Ľe fokotu Ľuma Ľu  Ľae mo Ľunga  Ľoe fale  Ľo Sihova  Ľi he tumutumu  Ľoe ngaahi mo Ľunga,
\q2 pea  Ľe hakeaki Ľi ia ke mńĀ Ľolunga  Ľi he ngaahi tafungofunga;
\q2 pea  Ľe tafe atu ki ai  Ľae kakai.
\q1 
\v 2 Pea  Ľe ha Ľu  Ľae kakai tokolahi mo nau pehńď,
\q2 ‚ÄúHa Ľu ke tau  Ľalu hake ki he mo Ľunga  Ľo Sihova,
\q2 pea ki he fale  Ľoe  ĽOtua  Ľo Sńďkope;
\q2 pea te ne akonaki Ľi  Ľakitautolu  Ľi hono ngaahi hala,
\q2 pea te tau  Ľeve Ľeva  Ľi hono ngaahi hala.‚ÄĚ
\q1 He ko e fono  Ľe  Ľalu atu mei Saione,
\q2 mo e folofola  Ľa Sihova mei SelŇęsalema.
\q1 
\v 3 Pea te ne fakamaau  Ľi he lotolotonga  Ľoe ngaahi kakai,
\q2 mo valoki Ľi  Ľae ngaahi pule Ľanga mńĀlohi  Ľoku mama Ľo atu;
\q2 pea te nau tuki  Ľenau ngaahi heletńĀ, ko e ngaahi huo toho,
\q2 pea mo  Ľenau ngaahi tao, ko e ngaahi hele  Ľauhani:
\q1  Ľe  Ľikai hiki  Ľe ha pule Ľanga  Ľae heletńĀ ki ha pule Ľanga,
\q2 pea  Ľe  Ľikai te nau toe ako ki he tau.
\q1 
\v 4 Ka te nau nofo taki taha  Ľae tangata  Ľi he malumalu  Ľo hono vaine, mo e malumalu  Ľo hono fiki;
\q2 pea  Ľe  Ľikai ha ni Ľihi ke fakamanavahńď Ľi  Ľakinautolu:
\q2 he ko e fofonga  Ľo Sihova  Ľoe ngaahi kautau kuo ne folofola ai.
\v 5 He ko e kakai kotoa pńď  Ľe  Ľeve Ľeva taki taha  Ľi he hingoa  Ľo hono  ĽOtua,
\q2 pea te mau  Ľeve Ľeva  Ľi he huafa  Ľo Sihova ko homau  ĽOtua  Ľo lauikuonga mo ta Ľengata.
\q1 
\v 6 ‚ÄĆ ĽOku pehńď  Ľe Sihova, ‚Äú ĽI he  Ľaho ko ia,
\q2 te u tńĀnaki  Ľaia na Ľe lotolotoua,
\q2 pea te u fakataha  Ľaia na Ľe kapusi kitu Ľa,
\q2 pea mo ia kuo u fakamamahi;
\q2 
\v 7 Pea te u ngaohi ia ko e toenga  Ľaia na Ľe lotolotoua,
\q2 pea ko e pule Ľanga mńĀlohi  Ľaia na Ľe si Ľaki ki he mama Ľo:
\q2 pea  Ľe pule  Ľa Sihova kiate kinautolu  Ľi he mo Ľunga ko Saione,  Ľo ngata mei heni,  Ľo a Ľu  Ľo ta Ľengata.‚ÄĚ
\q1 
\v 8 Pea ko koe,  Ľe fale le Ľo  Ľo Iteli, ko e potu mńĀlohi  Ľoe  Ľofefine  Ľo Saione,
\q2  Ľe hoko kiate koe,
\q2  Ľio,  Ľae  Ľuluaki pule:
\q2  Ľe hoko  Ľae pule Ľanga ki he  Ľofefine  Ľo SelŇęsalema.
\q1 
\v 9 Ko eni, ko e hńĀ  Ľoku ke tangi kalanga ai?
\q2  ĽOku  Ľikai ha tu Ľi kiate koe?
\q2 Kuo  Ľauha ho Ľo tangata ako fono?
\q2 He ko e mamahi kuo ne ma Ľu koe,  Ľo hangńď ha fefine langńĀ.
\q1 
\v 10 ‚ÄĆ ĽIo, te ke mamahi, pea ke feinga ke fńĀ Ľele Ľi,  Ľe  Ľofefine  Ľo Saione,
\q2  Ľo hangńď ha fefine  Ľoku langńĀ:
\q2 he ko eni, te ke toki  Ľalu atu  Ľi he kolo,
\q2 pea te ke nofo  Ľi he ngoue,
\q2 pea te ke  Ľalu,  Ľio, ki Papilone;
\q1  Ľe fakahaofi koe  Ľi ai;
\q2  Ľe huhu Ľi koe  Ľi ai  Ľe Sihova, mei he nima  Ľo ho ngaahi fili.
\q1 
\v 11 Kuo fakataha ni foki  Ľae ngaahi pule Ľanga kiate koe,  Ľaia  Ľoku nau pehńď,
\q2 ‚ÄúKe faka Ľuli Ľi ia,
\q2 pea ke sio hotau mata ki Saione.‚ÄĚ
\q1 
\v 12 Ka  Ľoku  Ľikai te nau  Ľilo  Ľae ngaahi fakakaukau  Ľa Sihova,
\q2 pea  Ľoku  Ľikai te nau poto  Ľi he Ľene ngaahi filio Ľi:
\q2 he te ne tńĀnaki  Ľakinautolu  Ľo hangńď ko e ngaahi Ňę koane ki he feleoko.
\q1 
\v 13 Tu Ľu, pea ke haha,  Ľe  Ľofefine  Ľo Saione:
\q2 he te u ngaohi ho nifo, ko e ukamea,
\q2 mo ho ngeesiva Ľe, ko e palasa;
\q1 pea te ke laiki  Ľae ngaahi kakai tokolahi:
\q1 pea te u fakatapui ki he  ĽOtua,  Ľenau koloa tupu,
\q2 mo  Ľenau koloa, kia Sihova  Ľo mńĀmani kotoa pńď.
\b
\c 5
\cd \it 1 Ko e  Ľalo Ľi  Ľo Kalaisi. 4 Hono pule Ľanga. 8  ĽA  Ľene ikuna.\it*
\q1 
\v 1 Ko eni, ke ke tńĀnaki fakataha koe  Ľi he ngaahi matatau,
\q2  Ľe  Ľofefine  Ľoe ngaahi matatau:
\q1 kuo ne fakanofo mai  Ľae tau kiate kitautolu:
\q2 te nau taa Ľi  Ľae fakamaau  Ľo  ĽIsileli,  Ľaki  Ľae me Ľa tńĀ  Ľi hono kou Ľahe.
\q1 
\v 2 Ka ko koe Petelihema Efalata,
\q2 neongo  Ľoku ke si Ľi hifo  Ľi he ngaahi toko afe  Ľo Siuta,
\q2 ka  Ľe ha Ľu ia meiate koe kiate au,  Ľaia  Ľe pule  Ľi  ĽIsileli,
\q2  Ľaia kuo talu mei mu Ľa  Ľene hńĀ Ľele atu, mei he kamata Ľanga.‚ÄĚ
\q1 
\v 3 Ko ia te ne tukuange  Ľakinautolu, kae Ľoua ke hoko  Ľae kuonga  Ľe fńĀ Ľele  Ľaia na Ľe langńĀ:
\q2 pea  Ľe toki foki atu ki he fńĀnau  Ľa  ĽIsileli  Ľae toe  Ľo hono kńĀinga.
\q1 
\v 4 Pea te ne tu Ľu  Ľo kai  Ľi he mńĀlohi  Ľo Sihova,
\q2  Ľi he nńĀunau  Ľoe huafa  Ľo Sihova ko hono  ĽOtua;
\q2 pea te nau nofoma Ľu: koe Ľuhi  Ľe toki hoko ia  Ľo lahi,  Ľo a Ľu ki he ngaahi ngata Ľanga  Ľo mńĀmani.
\q1 
\v 5 Pea ko e tangata ni  Ľe hoko ko e melino;  Ľoka hoko mai  Ľae  ĽAsilia ki hotau fonua,
\q2 pea  Ľoka ne ka laka ia  Ľi hotau ngaahi fale faka Ľei Ľeiki,
\q2 te tau fokotu Ľu kiate ia  Ľae kau tauhi sipi  Ľe toko fitu,
\q2 mo e kau tangata tu Ľu ki mu Ľa  Ľe toko valu.
\q1 
\v 6 Pea te nau maumau  Ľaki  Ľae heletńĀ  Ľae fonua  Ľo  ĽAsilia,
\q2 pea mo e fonua  Ľo Nimilote,  Ľi hono ngaahi hŇę Ľanga:
\q1  Ľe pehńď  Ľene fakahaofi kitautolu mei he  ĽAsilia,
\q2  Ľoka ne ka ha Ľu ia ki hotau fonua,
\q2 pea  Ľoka ne ka tu Ľu ia  Ľi hotau ngaahi mata fonua.
\q1 
\v 7 Pea ko e toenga  Ľo Sńďkope  Ľe  Ľi he lotolotonga  Ľoe ngaahi kakai,
\q2 hangńď ko e hahau meia Sihova,
\q2 hangńď ko e  Ľuha  Ľi he mohuku,
\q2  Ľaia  Ľoku  Ľikai ke tatali ki he tangata,
\q2 pe tupu koe Ľuhi ko e ngaahi foha  Ľoe tangata.
\q1 
\v 8 Pea ko e toenga  Ľo Sńďkope  Ľe  Ľi he lotolotonga  Ľoe kau Senitaile,
\q2  Ľi he ha Ľoha Ľonga  Ľoe ngaahi kakai,
\q2  Ľo hangńď ha laione  Ľi he lotolotonga  Ľoe fanga manu  Ľoe vao  Ľakau,
\q2 hangńď ha laione mui  Ľi he lotolotonga  Ľoe fanga sipi;
\q2  Ľaia, ka ne ka laka atu ia  Ľoku ne malaki hifo mo haehae foki,
\q2 pea  Ľe  Ľikai ha taha  Ľe fakahaofi.
\q1 
\v 9 ‚ÄĆ ĽE hiki hake ho nima ki ho ngaahi fili,
\q2 pea  Ľe motuhi ho kau fili kotoa pńď.
\q1 
\v 10 ‚ÄĆ ĽOku pehńď  Ľe Sihova, ‚Äú ĽE hoko  Ľo pehńď  Ľi he  Ľaho ko ia,
\q2 te u motuhi ho Ľo fanga hoosi mei ho lotolotonga,
\q2 pea te u maumau Ľi ho Ľo ngaahi saliote.
\q1 
\v 11 Pea te u motuhi  Ľae ngaahi kolo  Ľo ho fonua,
\q2 mo holoki hifo ho ngaahi potu mńĀlohi kotoa pńď:
\q1 
\v 12 Pea te u motuhi mei ho nima  Ľae kau fie mana loi,
\q2 pea  Ľe  Ľikai te ke kei ma Ľu  Ľae kau kikite loi:
\q1 
\v 13 Pea mo ho Ľo ngaahi tamapua kuo tongi foki te u motuhi, mo ho Ľo ngaahi tamapua tu Ľuma Ľu meiate koe;
\q2 pea  Ľe  Ľikai te ke toe lotu ki he ngńĀue  Ľa ho nima.
\q1 
\v 14 Pea te u ta Ľaki mei ho lotolotonga  Ľae ngaahi vao tapu:
\q2  Ľe pehńď  Ľeku faka Ľauha ho ngaahi kolo.
\q1 
\v 15 Pea te u fai  Ľae tautea  Ľi he  Ľita mo e lili ki he hiteni,
\q2  Ľi he anga ko ia  Ľoku te Ľeki ai te nau fanongo ai.‚ÄĚ
\c 6
\cd \it 1 Ko e fakamaau  Ľe he  ĽEiki, ko e me Ľa  Ľi he ta Ľe Ľofa, 6 Mo e ta Ľe Ľilo, 10 Mo e fai ta Ľetotonu, 16 Pea mo e tauhi tamapua.\it*
\p 
\v 1 Mou fanongo mai ki he me Ľa  Ľoku folofola ki ai  Ľa Sihova;
\q1 ‚ÄúTu Ľu hake, pea ke fai  Ľi he  Ľao  Ľoe ngaahi mo Ľunga,
\q2 pea ke fanongo  Ľae ngaahi tafungofunga ki ho le Ľo.
\q1 
\v 2 Fanongo  Ľakimoutolu  Ľae ngaahi mo Ľunga ki he fakamaau  Ľae  ĽEiki,
\q2 mo kimoutolu  Ľae ngaahi tu Ľunga mńĀlohi  Ľo mńĀmani;
\q2 he  Ľoku ai  Ľae fakamaau  Ľae  ĽEiki mo hono kakai,
\q2 pea te ne fakamatala mo  ĽIsileli.
\q1 
\v 3 ‚ÄĆ ĽE hoku kakai, Ko e hńĀ kuo u fai kiate koe?
\q2 Pea kuo u fakafiu Ľi ko e  Ľi he hńĀ?
\q2 Fakamatala mai!
\q1 
\v 4 He ne u  Ľomi koe mei he fonua ko  ĽIsipite,
\q2 pea ne u huhu Ľi koe mei he fale  Ľoe kau tamaio Ľeiki,
\q2 pea ne u fekau  Ľa MŇćsese, mo  ĽElone, mo Miliami ke  Ľalu  Ľi ho  Ľao.
\q1 
\v 5 ‚ÄĆ ĽE hoku kakai, manatu eni ki he me Ľa na Ľe fakakaukau ki ai  Ľe Pelaki, ko e tu Ľi  Ľo Moape,
\q2 pea mo ia na Ľe tali  Ľaki  Ľe Pelami ko e foha  Ľo Peoli, mei Sitimi,  Ľo a Ľu ki Kilikali;
\q2 koe Ľuhi ke mou  Ľilo  Ľae mńĀ Ľoni Ľoni  Ľa Sihova.‚ÄĚ
\b
\q1 
\v 6 Te u  Ľunu Ľunu atu mo e ha kia Sihova,
\q2 mo fakatŇćmape Ľe au  Ľi he  Ľao  Ľoe  ĽOtua MńĀ Ľolunga?
\q1 Te u  Ľalu ki hono  Ľao mo e ngaahi feilaulau tutu,
\q2 mo e fanga  Ľuhiki pulu  Ľoku taha ta Ľu?
\q1 
\v 7 ‚ÄĆ ĽE fiemńĀlie  Ľa Sihova  Ľi he ngaahi toko afe  Ľoe sipitangata,
\q2 pe  Ľi he ngaahi vaitafe lolo  Ľe taha mano?
\q1  ĽE  Ľatu  Ľeku  Ľuluaki, koe Ľuhi ko  Ľeku ngaahi hia;
\q2  Ľae fua  Ľo hoku sino, koe Ľuhi ko e angahala  Ľa hoku laumńĀlie?
\q1 
\v 8 Kuo ne fakahńĀ kiate koe,  Ľe tangata  Ľaia  Ľoku lelei;
\q2 pea ko e hńĀ  Ľoku  Ľamanaki  Ľe Sihova  Ľiate koe, ka koe Ľuhi ke ke fai totonu
\q2 mo ke loto ki he  Ľofa, mo ke  Ľa Ľeva mo ho  ĽOtua  Ľi he angavaivai?
\b
\q1 
\v 9 Ko e le Ľo  Ľo Sihova  Ľoku ui ki he kolo,
\q2 pea  Ľe mamata ki ho huafa \add  Ľe he tangata \add*poto:
\q1 ‚ÄúFanongo  Ľakimoutolu ki he me Ľa tńĀ,
\q2 pea mo ia kuo ne tu Ľutu Ľuni ia.
\q1 
\v 10 ‚ÄĆ ĽOku kei  Ľi he fale  Ľoe angahala  Ľae koloa  Ľoe angahala,
\q2 mo e me Ľa fua nounou  Ľaia  Ľoku fakalielia?
\q1 
\v 11 Te u lau  Ľakinautolu ko e ma Ľa ka  Ľoku  Ľi ai  Ľae ngaahi me Ľa fakamamafa kńĀkńĀ,
\q2 pea mo e kato me Ľa fakamamafa kńĀkńĀ?
\q1 
\v 12 He  Ľoku pito  Ľi he fakamńĀlohi  Ľae kau tangata koloa Ľia  Ľi ai,
\q2 pea kuo lea loi  Ľae kakai  Ľo ia;
\q2 pea  Ľoku kńĀkńĀ  Ľa honau  Ľelelo  Ľi honau ngutu.
\q1 
\v 13 Ko ia foki te u fakamamahi Ľi koe  Ľi ho fa Ľa taa Ľi,
\q2  Ľi he ngaohi koe ke lala, koe Ľuhi ko ho Ľo ngaahi angahala.
\q1 
\v 14 Te ke kai, ka  Ľe  Ľikai te ke mńĀkona,
\q2 pea  Ľe  Ľi ho lotolotonga  Ľa ho Ľo fakahifo ki lalo;
\q2 pea te ke puke ka  Ľe  Ľikai te ke fakahaofi;
\q2 pea ko ia  Ľoku ke fakahaofi, te u tukuange ki he heletńĀ.
\q1 
\v 15 Te ke tŇętuu Ľi ka  Ľe  Ľikai te ke tu Ľusi;
\q2 te ke malaki  Ľae  Ľolive, ka  Ľe  Ľikai te ke takai koe  Ľaki  Ľae lolo;
\q2 pea mo e uaine melie, ka  Ľe  Ľikai te ke inu uaine.
\q1 
\v 16 He kuo ma Ľu pe  Ľae ngaahi fono  Ľa  ĽOmili,
\q2 pea mo e ngaahi ngńĀue  Ľae fale  Ľo  ĽEhapi,
\q2 pea  Ľoku mou  Ľeve Ľeva  Ľi he Ľenau ngaahi fakakaukau;
\q2 koe Ľuhi ke u ngaohi kimoutolu ke lala,
\q2 pea mo e kakai  Ľo ia ko e faka Ľise Ľisa:
\q2 ko ia te mou fua ai  Ľae manuki  Ľa hoku kakai.‚ÄĚ
\b
\c 7
\cd \it 1  ĽOku lńĀunga  Ľae Siasi ko e me Ľa  Ľi hono tokosi Ľi, 3 Mo hono lahi  Ľoe kovi. 5 Ka  Ľoku  Ľikai te ne falala ki he tangata ka ki he  ĽOtua. 8  ĽOku ne ikuna hono ngaahi fili. 14  ĽOku fakafiemńĀlie Ľi ia  Ľe he  ĽOtua,  Ľaki  Ľae ngaahi tala Ľofa, 16 Mo e veuveuki  Ľoe ngaahi fili, 18 Pea mo  Ľene  Ľalo Ľofa.\it*
\q1 
\v 1 ‚ÄĆ ĽOiau  Ľeku mamahi!
\q2 He  Ľoku ou hangńď kuo  Ľosi  Ľae tńĀnaki  Ľoe ngaahi fua  Ľoe fa Ľahita Ľu mafana, hangńď ko e toenga kńĀlepi  Ľoe to Ľukai:
\q2  Ľoku  Ľikai ha fuhinga kńĀlepi ke kai:
\q2 na Ľe holi hoku loto ki he  Ľuluaki to Ľukai.
\q1 
\v 2 Kuo  Ľauha  Ľae kau mńĀ Ľoni Ľoni mei mńĀmani:
\q2 pea  Ľoku  Ľikai ha kau angatonu  Ľi he kakai:
\q2  Ľoku nau toitoi kotoa pńď ki he toto;
\q2  Ľoku nau taki taha tuli  Ľa hono tokoua mo e kupenga.
\q1 
\v 3 Koe Ľuhi ke nau fai fakamńĀtoato  Ľi he kovi  Ľaki  Ľae ongo nima  Ľosi pe,
\q2  Ľoku  Ľeke  Ľe he hou Ľeiki, pea  Ľeke mo e fakamaau ki he me Ľa foaki;
\q2 pea mo e tangata mńĀ Ľolunga  Ľoku ne fakahńĀ hono loto kovi pea pehńď,
\q2  Ľoku nau  Ľufi Ľufi ia.
\q1 
\v 4 Ko e lelei lahi  Ľiate kinautolu  Ľoku hangńď ko e  Ľakau talatala pe:
\q2 ko ia  Ľoku fungani angatonu  Ľoku mńĀsila  Ľi he  Ľa talatala:
\q1  Ľoku hoko mai  Ľae  Ľaho  Ľo ho kau le Ľo,
\q2 pea mo ho  Ľa Ľahi;
\q2 ko eni  Ľe hoko  Ľenau puputu Ľu.
\q1 
\v 5 ‚ÄĆ ĽOua na Ľa mou falala ki he kaume Ľa,
\q2  Ľoua na Ľa mou falala ki ha takimu Ľa:
\q2 le Ľohi  Ľae matapńĀ  Ľo ho ngutu,
\q2 meiate ia  Ľoku fa Ľaki ki ho fatafata.
\q1 
\v 6 He  Ľoku fakaongokovi Ľi  Ľe he foha  Ľa  Ľene tamai;
\q2  Ľoku tu Ľu hake  Ľae ta Ľahine ki he Ľene fa Ľńď,
\q2  Ľae ta Ľahine  Ľi he fono, ki he Ľene fa Ľńď  Ľi he fono;
\q2 ko e ngaahi fili  Ľoe tangata,  Ľae kau tangata  Ľi hono fale.
\q1 
\v 7 Ko ia te u hanga kia Sihova;
\q2 te u tatali ki he  ĽOtua  Ľo  Ľeku fakamo Ľui;
\q2  Ľe fanongo mai kiate au  Ľa hoku  ĽOtua.
\q1 
\v 8 ‚ÄĆ ĽOua na Ľa ke viki kiate au,  Ľe hoku fili:
\q2  Ľo kau ka hinga te u toetu Ľu hake:
\q2  Ľo kau ka nofo  Ľi he po Ľuli,  Ľe hoko  Ľa Sihova ko e maama kiate au.
\q1 
\v 9 Te u kńĀtaki  Ľae houhau  Ľo Sihova,
\q2 he kuo u fai angahala kiate ia,
\q2 ke  Ľoua ke ne fakamatala ma Ľaku, mo fai  Ľae fakamaau koe Ľuhi ko au;
\q2 te ne  Ľomi au ki he maama,
\q2 pea te u mamata ki he Ľene mńĀ Ľoni Ľoni.
\q1 
\v 10 Pea  Ľe toki mamata ai  Ľa hoku fili,
\q2 pea  Ľe  Ľufi Ľufi  Ľi he mńĀ  Ľaia na Ľe pehńď mai kiate au,
\q2 ‚ÄėKoma ĽńĀ Sihova ko ho  ĽOtua?‚Äô
\q1  ĽE sio  Ľa hoku mata kiate ia:
\q2 ko eni,  Ľe malaki hifo ia  Ľo hangńď ko e pelepela  Ľi he ngaahi hala.
\q1 
\v 11 ‚ÄĆ ĽI he  Ľaho ko ia  Ľe langa ho ngaahi  ĽńĀ,
\q2  Ľi he  Ľaho ko ia  Ľe hiki ke mama Ľo  Ľae fono.
\q1 
\v 12 ‚ÄĆ ĽI he  Ľaho ko ia  Ľe ha Ľu ia,  Ľio, kiate koe mei  ĽAsilia, pea mei he ngaahi kolo kuo teu,
\q2 pea mei he potu mńĀlohi  Ľo a Ľu ki he vaitafe,
\q2 pea mei he tahi ki he tahi,
\q2 pea mei he mo Ľunga ki he mo Ľunga.
\q1 
\v 13 Ka neongo ia  Ľe lala  Ľae fonua koe Ľuhi ko kinautolu  Ľoku nofo ai,
\q2 ko e fua  Ľo  Ľenau faianga.
\q1 
\v 14 Fafanga Ľi  Ľa ho Ľo kakai  Ľaki  Ľae me Ľa tńĀ,
\q2  Ľae kakai  Ľo ho tofi Ľa,
\q2  Ľaia  Ľoku nofo ngaongao  Ľi he vao  Ľakau  Ľi he lotolotonga  Ľo Kameli:
\q2 tuku ke nau kai  Ľi Pesani mo Kiliati,
\q2  Ľo hangńď ko e ngaahi  Ľaho  Ľi mu Ľa.
\q1 
\v 15 ‚Äú ĽO fakatatau mo e ngaahi  Ľaho  Ľo ho Ľo ha Ľu mei he fonua ko  ĽIsipite, te u fakahńĀ kiate ia,
\q2  Ľae ngaahi me Ľa fakaofo.‚ÄĚ
\q1 
\v 16 ‚ÄĆ ĽE mamata  Ľe he ngaahi pule Ľanga, pea te nau ofo  Ľi he Ľenau mńĀlohi kotoa pńď:
\q2 te nau  Ľai honau nima ki honau ngutu;
\q2  Ľe tuli  Ľa honau telinga.
\q1 
\v 17 Te nau  Ľemo  Ľae efu, hangńď ha ngata,
\q2 te nau ngaolo mei honau ngaahi luo hangńď ko e kelemutu  Ľoe fonua:
\q2 te nau manavahńď kia Sihova ko hotau  ĽOtua,
\q2 pea te nau ilifia koe Ľuhi ko koe.
\q1 
\v 18 Ko hai ha  ĽOtua  Ľoku hangńď ko koe, ke fakamolemole  Ľae hia,
\q2 pea ke laka atu  Ľi he angahala  Ľi he toenga  Ľo hono tofi Ľa?
\q1  ĽOku  Ľikai te ne ma Ľu  Ľa hono houhau  Ľo ta Ľengata,
\q2 he  Ľoku ne fiefia  Ľi he  Ľalo Ľofa.
\q1 
\v 19 ‚ÄĆ ĽE toe foki mai ia, te ne manava Ľofa kiate kitautolu;
\q2 te ne iku Ľi  Ľetau ngaahi hia;
\q2 pea te ke lńę  Ľenau ngaahi angahala kotoa pńď, ki he loloto  Ľoe tahi.
\q1 
\v 20 Te ke fakapapau  Ľae mo Ľoni kia Sńďkope,
\q2 pea mo e  Ľalo Ľofa kia  ĽEpalahame,
\q2  Ľaia na Ľa ke fuakava ki he Ľemau ngaahi tamai talu mei he ngaahi  Ľaho  Ľi mu Ľa. 
