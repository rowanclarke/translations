\v 51 Whenever \w the|strong="H7126"\w* \w tabernacle|strong="H4908"\w* \w is|strong="H4191"\w* \w to|strong="H3381"\w* \w move|strong="H5265"\w*, \w the|strong="H7126"\w* \w Levites|strong="H3881"\w* \w are|strong="H2114"\w* \w to|strong="H3381"\w* \w take|strong="H3381"\w* \w it|strong="H7126"\w* \w down|strong="H3381"\w*, \w and|strong="H6965"\w* whenever \w it|strong="H7126"\w* \w is|strong="H4191"\w* \w to|strong="H3381"\w* \w be|strong="H4191"\w* \w pitched|strong="H2583"\w*, \w the|strong="H7126"\w* \w Levites|strong="H3881"\w* \w are|strong="H2114"\w* \w to|strong="H3381"\w* \w set|strong="H5265"\w* \w it|strong="H7126"\w* \w up|strong="H6965"\w*. \w Any|strong="H4191"\w* \w outsider|strong="H2114"\w* \w who|strong="H3881"\w* \w goes|strong="H3381"\w* \w near|strong="H7126"\w* \w it|strong="H7126"\w* \w must|strong="H4191"\w* \w be|strong="H4191"\w* \w put|strong="H4191"\w* \w to|strong="H3381"\w* \w death|strong="H4191"\w*.   
