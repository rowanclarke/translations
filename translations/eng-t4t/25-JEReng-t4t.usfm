\v 31 “\w Send|strong="H7971"\w* \w this|strong="H3541"\w* \w message|strong="H3068"\w* \w to|strong="H3068"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w people|strong="H3808"\w* \add from Judah\add* \w who|strong="H3605"\w* \w are|strong="H3068"\w* \w there|strong="H3605"\w* \add in Babylon\add*. Say \w that|strong="H3605"\w* \w this|strong="H3541"\w* \w is|strong="H3068"\w* \w what|strong="H3541"\w* \w Yahweh|strong="H3068"\w* \w says|strong="H3541"\w* \w about|strong="H5921"\w* \w Shemaiah|strong="H8098"\w*, \w the|strong="H3605"\w* \w man|strong="H3605"\w* \w from|strong="H5921"\w* Nehelam: ‘\w I|strong="H3541"\w* \w did|strong="H3068"\w* \w not|strong="H3808"\w* \w appoint|strong="H7971"\w* \w him|strong="H5921"\w*, \w but|strong="H3808"\w* \w he|strong="H3068"\w* \w has|strong="H3068"\w* deceived \w you|strong="H3605"\w* \w and|strong="H3068"\w* caused \w you|strong="H3605"\w* \w to|strong="H3068"\w* believe \w the|strong="H3605"\w* \w lies|strong="H8267"\w* \w that|strong="H3605"\w* \w he|strong="H3068"\w* \w prophesied|strong="H5012"\w*.  
\v 32 \w So|strong="H3651"\w*, \w I|strong="H3588"\w* \w will|strong="H3068"\w* \w punish|strong="H6485"\w* \w him|strong="H5921"\w* \w and|strong="H3068"\w* \w his|strong="H3068"\w* \w family|strong="H2233"\w*. \w He|strong="H3588"\w* \w has|strong="H3068"\w* incited \w you|strong="H3588"\w* \w to|strong="H1696"\w* rebel \w against|strong="H5921"\w* \w me|strong="H7200"\w*. \w Because|strong="H3588"\w* \w of|strong="H3068"\w* \w that|strong="H3588"\w*, \w all|strong="H7200"\w* \w of|strong="H3068"\w* \w his|strong="H3068"\w* \w descendants|strong="H2233"\w* \w will|strong="H3068"\w* \w soon|strong="H3588"\w* die. \w I|strong="H3588"\w* \w will|strong="H3068"\w* \w do|strong="H6213"\w* \add many\add* \w good|strong="H2896"\w* \w things|strong="H2896"\w* \w for|strong="H3588"\w* \add you\add*, \w my|strong="H3068"\w* \w people|strong="H5971"\w*, \w but|strong="H3588"\w* \w he|strong="H3588"\w* \w and|strong="H3068"\w* \w his|strong="H3068"\w* \w descendants|strong="H2233"\w* \w will|strong="H3068"\w* \w not|strong="H3808"\w* \w see|strong="H7200"\w* \w those|strong="H5921"\w* \w things|strong="H2896"\w*, \add because they will be dead\add*. \add That will surely happen because I\add*, \w Yahweh|strong="H3068"\w*, \w have|strong="H1961"\w* \w said|strong="H1696"\w* \w it|strong="H5921"\w*!’”   
\c 30  
\s1 Yahweh promised to bring his people back  
\p
\v 1 \w Yahweh|strong="H3068"\w* \w gave|strong="H1961"\w* \w me|strong="H1961"\w* another \w message|strong="H1697"\w*. \w He|strong="H3068"\w* \w said|strong="H1697"\w*,  
\v 2 “\add I\add*, \w Yahweh|strong="H3068"\w*, \w the|strong="H3605"\w* \w God|strong="H3068"\w* whom \w the|strong="H3605"\w* Israeli \w people|strong="H1696"\w* \add say they belong to\add*, \w am|strong="H3068"\w* \w telling|strong="H1696"\w* \w you|strong="H3605"\w* \w that|strong="H3605"\w* \w you|strong="H3605"\w* \w should|strong="H3068"\w* \w write|strong="H3789"\w* \w down|strong="H3789"\w* \w everything|strong="H3605"\w* \w that|strong="H3605"\w* \w I|strong="H3541"\w* \w have|strong="H3068"\w* \w said|strong="H1696"\w* \w to|strong="H1696"\w* \w you|strong="H3605"\w*.  
\v 3  \add I want you to know that\add* \w some|strong="H3117"\w* \w day|strong="H3117"\w* \w I|strong="H3588"\w* \w will|strong="H3068"\w* free \w my|strong="H5414"\w* \w people|strong="H5971"\w*, \add the people of\add* \w Israel|strong="H3478"\w* \w and|strong="H3063"\w* \w Judah|strong="H3063"\w*, \w from|strong="H7725"\w* \w being|strong="H5971"\w* slaves \add in Babylon\add*. \w I|strong="H3588"\w* \w will|strong="H3068"\w* \w bring|strong="H7725"\w* \w them|strong="H5414"\w* \w back|strong="H7725"\w* \w to|strong="H7725"\w* \w this|strong="H5414"\w* land \w that|strong="H3588"\w* \w I|strong="H3588"\w* \w gave|strong="H5414"\w* \w to|strong="H7725"\w* \w their|strong="H3068"\w* ancestors, \w and|strong="H3063"\w* \w this|strong="H5414"\w* land \w will|strong="H3068"\w* belong \w to|strong="H7725"\w* \w them|strong="H5414"\w* \w again|strong="H7725"\w*. \add That will surely happen because\add* \w I|strong="H3588"\w*, \w Yahweh|strong="H3068"\w*, \w have|strong="H3068"\w* \w said|strong="H5002"\w* \w it|strong="H5414"\w*.”   
\p
\v 4 \w Yahweh|strong="H3068"\w* \w gave|strong="H1696"\w* \add to me\add* another \w message|strong="H1697"\w* \w concerning|strong="H1697"\w* \add the people of\add* \w Israel|strong="H3478"\w* \w and|strong="H3063"\w* \w Judah|strong="H3063"\w*.  
