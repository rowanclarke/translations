\v 11 \w But|strong="H4428"\w* \w the|strong="H5002"\w* \w people|strong="H1471"\w* \w of|strong="H4428"\w* any country \w who|strong="H3068"\w* \w do|strong="H5647"\w* \w what|strong="H5921"\w* \w the|strong="H5002"\w* \w King|strong="H4428"\w* \w of|strong="H4428"\w* Babylon wants \w them|strong="H5921"\w* \w to|strong="H3068"\w* \w do|strong="H5647"\w* \w will|strong="H3068"\w* \w remain|strong="H3427"\w* \w in|strong="H3427"\w* \w their|strong="H3068"\w* own country \w and|strong="H3068"\w* \w be|strong="H3068"\w* able \w to|strong="H3068"\w* plant \w their|strong="H3068"\w* crops [MTY] \add as they always have done. That will surely happen because I\add*, \w Yahweh|strong="H3068"\w*, \w have|strong="H3068"\w* \w said|strong="H5002"\w* \w it|strong="H5921"\w*.”   
\b  
\p
\v 12  \add After I gave that message to those ambassadors,\add* \w I|strong="H1697"\w* \w gave|strong="H1696"\w* \w the|strong="H3605"\w* \w same|strong="H1697"\w* \w message|strong="H1697"\w* \w to|strong="H1696"\w* \w King|strong="H4428"\w* \w Zedekiah|strong="H6667"\w* \w of|strong="H4428"\w* \w Judah|strong="H3063"\w*. \add I said to him,\add* “If \w you|strong="H3605"\w* want \w to|strong="H1696"\w* remain \w alive|strong="H2421"\w*, \w do|strong="H5647"\w* \w what|strong="H1697"\w* \w the|strong="H3605"\w* \w King|strong="H4428"\w* \w of|strong="H4428"\w* Babylon \w and|strong="H3063"\w* \w his|strong="H3605"\w* officials want \w you|strong="H3605"\w* \w to|strong="H1696"\w* \w do|strong="H5647"\w* [MET].  
\v 13  \add It would be foolish for you not to do that, because the result would be that\add* \w you|strong="H3808"\w* \w and|strong="H3068"\w* \w your|strong="H3068"\w* \w people|strong="H5971"\w* \w would|strong="H3068"\w* \w die|strong="H4191"\w* \w by|strong="H3068"\w* \add your enemies’\add* \w swords|strong="H2719"\w* \w or|strong="H3808"\w* \w by|strong="H3068"\w* \w famine|strong="H7458"\w* \w or|strong="H3808"\w* \w diseases|strong="H1698"\w*, \w which|strong="H3068"\w* \w Yahweh|strong="H3068"\w* \w will|strong="H3068"\w* \w cause|strong="H5971"\w* \w any|strong="H4191"\w* \w nation|strong="H1471"\w* \w to|strong="H1696"\w* experience \w that|strong="H5971"\w* refuses \w to|strong="H1696"\w* allow \w the|strong="H5647"\w* \w King|strong="H4428"\w* \w of|strong="H4428"\w* Babylon \w to|strong="H1696"\w* \w rule|strong="H4428"\w* \w them|strong="H5647"\w*.  
\v 14 \w Do|strong="H5647"\w* \w not|strong="H3808"\w* \w pay|strong="H8085"\w* \w attention|strong="H8085"\w* \w to|strong="H8085"\w* \w those|strong="H1992"\w* \w prophets|strong="H5030"\w* \w who|strong="H5030"\w* \w say|strong="H1697"\w* \w to|strong="H8085"\w* \w you|strong="H3588"\w*, ‘\w The|strong="H8085"\w* \w King|strong="H4428"\w* \w of|strong="H4428"\w* Babylon \w will|strong="H4428"\w* \w not|strong="H3808"\w* conquer \w your|strong="H8085"\w* country.’ \w They|strong="H1992"\w* \w are|strong="H1992"\w* \w liars|strong="H8267"\w*.  
\v 15  \add This is what\add* \w Yahweh|strong="H3068"\w* \w says|strong="H5002"\w*: ‘\w I|strong="H3588"\w* \w have|strong="H3068"\w* \w not|strong="H3808"\w* appointed \w those|strong="H1992"\w* \w prophets|strong="H5030"\w*. \w They|strong="H1992"\w* \w are|strong="H1992"\w* saying \w that|strong="H3588"\w* \w I|strong="H3588"\w* [MTY] \w gave|strong="H7971"\w* \w them|strong="H1992"\w* messages, \w but|strong="H3588"\w* \w they|strong="H1992"\w* \w are|strong="H1992"\w* \w lying|strong="H8267"\w*. \w So|strong="H4616"\w*, \add if you believe them,\add* \w I|strong="H3588"\w* \w will|strong="H3068"\w* expel \w you|strong="H3588"\w* \w from|strong="H7971"\w* \w this|strong="H3588"\w* land. \w And|strong="H3068"\w* \w you|strong="H3588"\w* \w and|strong="H3068"\w* \w all|strong="H7971"\w* \w those|strong="H1992"\w* \w prophets|strong="H5030"\w* \w will|strong="H3068"\w* die \add in Babylon\add*!’ ”   
\p
\v 16 \w Then|strong="H1696"\w* \w I|strong="H3588"\w* \w spoke|strong="H1696"\w* \w to|strong="H1696"\w* \w the|strong="H3605"\w* \w priests|strong="H3548"\w* \w and|strong="H3068"\w* \w the|strong="H3605"\w* \w other|strong="H2088"\w* \w people|strong="H5971"\w*, \w and|strong="H3068"\w* \w I|strong="H3588"\w* \w said|strong="H1696"\w*, “\w This|strong="H2088"\w* \w is|strong="H3068"\w* \w what|strong="H1697"\w* \w Yahweh|strong="H3068"\w* \w says|strong="H3541"\w*: ‘\w Do|strong="H3068"\w* \w not|strong="H2088"\w* believe \w your|strong="H3068"\w* \w prophets|strong="H5030"\w* \w who|strong="H3605"\w* \w tell|strong="H1696"\w* \w you|strong="H3588"\w* \w that|strong="H3588"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* gold \w items|strong="H3627"\w* \add that were taken\add* \w from|strong="H7725"\w* \w my|strong="H8085"\w* \w temple|strong="H1004"\w* \add by soldiers from Babylon\add* \w will|strong="H3068"\w* \w soon|strong="H6258"\w* \w be|strong="H1697"\w* \w returned|strong="H7725"\w* \w from|strong="H7725"\w* Babylon, \w because|strong="H3588"\w* \w what|strong="H1697"\w* \w they|strong="H1992"\w* \w are|strong="H1992"\w* \w prophesying|strong="H5012"\w* \w is|strong="H3068"\w* \w a|strong="H3068"\w* \w lie|strong="H8267"\w*.  
\v 17 \w Do|strong="H5647"\w* \w not|strong="H8085"\w* \w pay|strong="H8085"\w* \w attention|strong="H8085"\w* \w to|strong="H1961"\w* \w what|strong="H4100"\w* \w they|strong="H4100"\w* say. Surrender \w to|strong="H1961"\w* \w the|strong="H8085"\w* \w king|strong="H4428"\w* \w of|strong="H4428"\w* Babylon. \w If|strong="H1961"\w* \w you|strong="H4100"\w* \w do|strong="H5647"\w* \w that|strong="H8085"\w*, \w you|strong="H4100"\w* \w will|strong="H1961"\w* \w remain|strong="H1961"\w* \w alive|strong="H2421"\w*. \add If you do not do that\add* [RHQ], \w this|strong="H2063"\w* entire \w city|strong="H5892"\w* \w will|strong="H1961"\w* \w be|strong="H1961"\w* \w destroyed|strong="H2723"\w*.  
\v 18 \w If|strong="H3426"\w* \w they|strong="H1992"\w* \w are|strong="H1992"\w* \w really|strong="H1992"\w* \w prophets|strong="H5030"\w* \w who|strong="H3068"\w* \w speak|strong="H1697"\w* \w messages|strong="H1697"\w* \w from|strong="H3068"\w* \w me|strong="H4994"\w*, \w tell|strong="H4994"\w* \w them|strong="H1992"\w* \w to|strong="H3068"\w* \w plead|strong="H6293"\w* \w to|strong="H3068"\w* \w me|strong="H4994"\w*, \w the|strong="H3068"\w* Commander \w of|strong="H4428"\w* \w the|strong="H3068"\w* \w armies|strong="H6635"\w* \w of|strong="H4428"\w* angels, \w that|strong="H3068"\w* \add the soldiers from Babylon\add* \w will|strong="H3068"\w* \w not|strong="H1115"\w* \w be|strong="H3426"\w* \w allowed|strong="H3068"\w* \w to|strong="H3068"\w* take away \w to|strong="H3068"\w* Babylon \w the|strong="H3068"\w* valuable \w items|strong="H3627"\w* \w that|strong="H3068"\w* \add still\add* \w remain|strong="H3498"\w* \w in|strong="H3068"\w* \w the|strong="H3068"\w* \w temple|strong="H1004"\w* \w and|strong="H3063"\w* \w in|strong="H3068"\w* \w the|strong="H3068"\w* \w king|strong="H4428"\w*’s \w palace|strong="H1004"\w* \w and|strong="H3063"\w* \w in|strong="H3068"\w* \add the other palaces in\add* \w Jerusalem|strong="H3389"\w*.  
\v 19  \add I say this\add* \w because|strong="H3588"\w* \w the|strong="H5921"\w* \add huge\add* \w pillars|strong="H5982"\w* \add that are in front of the temple\add* \w and|strong="H3068"\w* \w the|strong="H5921"\w* large water tank \w and|strong="H3068"\w* \w the|strong="H5921"\w* \add ten water\add* carts \w and|strong="H3068"\w* \w all|strong="H5921"\w* \w the|strong="H5921"\w* \w other|strong="H2063"\w* \w items|strong="H3627"\w* \w that|strong="H3588"\w* \w are|strong="H3068"\w* \w used|strong="H3627"\w* \add for offering sacrifices are still in this city\add*.  
\v 20 \w King|strong="H4428"\w* \w Nebuchadnezzar|strong="H5019"\w* \w of|strong="H1121"\w* Babylon left \w those|strong="H3605"\w* \w things|strong="H3605"\w* here \w when|strong="H1121"\w* \w he|strong="H3605"\w* \w exiled|strong="H1540"\w* \w Jehoiachin|strong="H3204"\w*, \w the|strong="H3605"\w* \w king|strong="H4428"\w* \w of|strong="H1121"\w* \w Judah|strong="H3063"\w*, \w to|strong="H3389"\w* Babylon, along \w with|strong="H3389"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \add other\add* \w leaders|strong="H2715"\w* \w of|strong="H1121"\w* \w Jerusalem|strong="H3389"\w* \w and|strong="H1121"\w* \add the leaders of other places in\add* \w Judah|strong="H3063"\w*.  
\v 21  \add I\add*, \w the|strong="H5921"\w* Commander \w of|strong="H4428"\w* \w the|strong="H5921"\w* \w armies|strong="H6635"\w* \w of|strong="H4428"\w* angels, \w the|strong="H5921"\w* \w God|strong="H3068"\w* \w whom|strong="H3588"\w* \w the|strong="H5921"\w* Israeli \add people worship\add*, \w say|strong="H3478"\w* \w this|strong="H3541"\w* \w about|strong="H5921"\w* \w all|strong="H5921"\w* \w those|strong="H5921"\w* valuable \w things|strong="H3627"\w* \w that|strong="H3588"\w* \w are|strong="H3478"\w* \w still|strong="H3588"\w* \w outside|strong="H5921"\w* \w the|strong="H5921"\w* \w temple|strong="H1004"\w* \w and|strong="H3063"\w* \w in|strong="H5921"\w* \w the|strong="H5921"\w* \w palace|strong="H1004"\w* \w of|strong="H4428"\w* \w the|strong="H5921"\w* \w king|strong="H4428"\w* \w of|strong="H4428"\w* \w Judah|strong="H3063"\w* \w and|strong="H3063"\w* \w in|strong="H5921"\w* \add other places in \add*\w Jerusalem|strong="H3389"\w*:  
\v 22 \w They|strong="H3117"\w* \w will|strong="H3068"\w* \add all\add* \w be|strong="H1961"\w* \w carried|strong="H5927"\w* \w away|strong="H7725"\w* \w to|strong="H5704"\w* Babylon. \w And|strong="H3068"\w* \w they|strong="H3117"\w* \w will|strong="H3068"\w* stay \w there|strong="H8033"\w* \w until|strong="H5704"\w* \w I|strong="H3117"\w* \w say|strong="H7725"\w* \w that|strong="H3117"\w* \w they|strong="H3117"\w* \w should|strong="H3068"\w* \w be|strong="H1961"\w* \w brought|strong="H5927"\w* \w back|strong="H7725"\w* \w to|strong="H5704"\w* Jerusalem. \w Then|strong="H1961"\w* \w they|strong="H3117"\w* \w will|strong="H3068"\w* \w be|strong="H1961"\w* bought \w back|strong="H7725"\w* \w here|strong="H2088"\w*. \add That is what I,\add* \w Yahweh|strong="H3068"\w*, \w say|strong="H7725"\w*.’ ”   
\c 28  
\s1 Jeremiah condemned Hananiah  
\p
\v 1 \w When|strong="H1961"\w* \w Zedekiah|strong="H6667"\w* \w had|strong="H3068"\w* \w been|strong="H1961"\w* \w the|strong="H3605"\w* \w King|strong="H4428"\w* \w of|strong="H1121"\w* \w Judah|strong="H3063"\w* \w for|strong="H3068"\w* \w more|strong="H1961"\w* \w than|strong="H4428"\w* three \w years|strong="H8141"\w*, late \w in|strong="H8141"\w* \w the|strong="H3605"\w* ◄summer/hot season►, \w Azzur|strong="H5809"\w*’s \w son|strong="H1121"\w* \w Hananiah|strong="H2608"\w*, \w a|strong="H3068"\w* \w prophet|strong="H5030"\w* \w from|strong="H1121"\w* \w Gibeon|strong="H1391"\w* \add city\add*, spoke \w to|strong="H3068"\w* \w me|strong="H5869"\w* \w in|strong="H8141"\w* \w the|strong="H3605"\w* \add courtyard of the\add* \w temple|strong="H1004"\w*, \w while|strong="H1961"\w* \add all\add* \w the|strong="H3605"\w* \w priests|strong="H3548"\w* \w and|strong="H1121"\w* \w other|strong="H3605"\w* \w people|strong="H5971"\w* \w were|strong="H1961"\w* listening. \w He|strong="H1931"\w* said,  
\v 2 “\w This|strong="H3541"\w* \w is|strong="H3068"\w* \w what|strong="H3541"\w* \w the|strong="H3541"\w* Commander \w of|strong="H4428"\w* \w the|strong="H3541"\w* \w armies|strong="H6635"\w* \w of|strong="H4428"\w* angels, \w the|strong="H3541"\w* \w God|strong="H3068"\w* whom \add we\add* Israelis \add worship\add*, \w says|strong="H3541"\w*: ‘\w I|strong="H3541"\w* \w will|strong="H3068"\w* cause \w the|strong="H3541"\w* \w king|strong="H4428"\w* \w of|strong="H4428"\w* Babylon \w to|strong="H3478"\w* stop ruling/controlling [MET] \add all of you\add*.  
\v 3 ◄\w Within|strong="H1004"\w* \w two|strong="H3947"\w* \w years|strong="H8141"\w*/\w Before|strong="H4480"\w* \w two|strong="H3947"\w* \w years|strong="H8141"\w* \w have|strong="H3068"\w* ended►, \w I|strong="H3117"\w* \w will|strong="H3068"\w* \w cause|strong="H7725"\w* \w to|strong="H7725"\w* \w be|strong="H5750"\w* \w brought|strong="H7725"\w* \w bring|strong="H7725"\w* \w back|strong="H7725"\w* \w to|strong="H7725"\w* \w this|strong="H2088"\w* \w temple|strong="H1004"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* valuable \w things|strong="H3605"\w* \w that|strong="H3605"\w* \w King|strong="H4428"\w* \w Nebuchadnezzar|strong="H5019"\w*’s \add soldiers\add* \w took|strong="H3947"\w* \w from|strong="H4480"\w* \w this|strong="H2088"\w* \w temple|strong="H1004"\w* \w and|strong="H3068"\w* \w took|strong="H3947"\w* \w to|strong="H7725"\w* Babylon.  
\v 4 \w And|strong="H1121"\w* \w I|strong="H3588"\w* \w will|strong="H3068"\w* \w also|strong="H3068"\w* \w cause|strong="H7725"\w* \w King|strong="H4428"\w* \w Jehoiachin|strong="H3204"\w* \w to|strong="H7725"\w* \w be|strong="H3068"\w* \w brought|strong="H7725"\w* \w back|strong="H7725"\w* \w here|strong="H2088"\w*, \w and|strong="H1121"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \add other\add* \w people|strong="H1121"\w* \w who|strong="H3605"\w* \w were|strong="H1121"\w* captured \w and|strong="H1121"\w* taken \w to|strong="H7725"\w* Babylon. \w The|strong="H3605"\w* \w king|strong="H4428"\w* \w of|strong="H1121"\w* Babylon \w has|strong="H3068"\w* \add forced you to do what he wants, like someone\add* puts \w a|strong="H3068"\w* \w yoke|strong="H5923"\w* \add on the neck of an ox to force it to do what he\add* wants [MET] \w it|strong="H3588"\w* \w to|strong="H7725"\w* \w do|strong="H3068"\w*. \w But|strong="H3588"\w* \w I|strong="H3588"\w* \w will|strong="H3068"\w* \w cause|strong="H7725"\w* \w that|strong="H3588"\w* \w to|strong="H7725"\w* end. \add That will happen because\add* \w I|strong="H3588"\w*, \w Yahweh|strong="H3068"\w*, \w have|strong="H3068"\w* \w said|strong="H5002"\w* \w it|strong="H3588"\w*.’ ”   
\p
\v 5 \w I|strong="H3068"\w* replied \w to|strong="H3068"\w* \w Hananiah|strong="H2608"\w* \w in|strong="H3068"\w* front \w of|strong="H1004"\w* \add all\add* \w the|strong="H3605"\w* \w priests|strong="H3548"\w* \w and|strong="H3068"\w* \w other|strong="H3605"\w* \w people|strong="H5971"\w* \w who|strong="H3605"\w* \w were|strong="H5971"\w* \w standing|strong="H5975"\w* outside \w the|strong="H3605"\w* \w temple|strong="H1004"\w*.  
