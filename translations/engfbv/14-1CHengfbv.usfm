\p 
\v 9 \w The|strong="H1121"\w* \w sons|strong="H1121"\w* \w of|strong="H1121"\w* \w Cush|strong="H3568"\w*: \w Seba|strong="H5434"\w*, \w Havilah|strong="H2341"\w*, \w Sabta|strong="H5454"\w*, \w Raamah|strong="H7484"\w*, \w and|strong="H1121"\w* \w Sabteca|strong="H5455"\w*. \w The|strong="H1121"\w* \w sons|strong="H1121"\w* \w of|strong="H1121"\w* \w Raamah|strong="H7484"\w*: \w Sheba|strong="H7614"\w* \w and|strong="H1121"\w* \w Dedan|strong="H1719"\w*.
\p 
\v 10 \w Cush|strong="H3568"\w* \w was|strong="H1961"\w* \w the|strong="H3205"\w* \w father|strong="H3205"\w* \w of|strong="H3205"\w* \w Nimrod|strong="H5248"\w*, \w who|strong="H1931"\w* \w became|strong="H3205"\w* \w the|strong="H3205"\w* world's \w first|strong="H2490"\w* tyrant.
\p 
\v 11 \w Mizraim|strong="H4714"\w* \w was|strong="H4714"\w* \w the|strong="H3205"\w* \w father|strong="H3205"\w* \w of|strong="H3205"\w* \w the|strong="H3205"\w* Ludites, \w Anamites|strong="H6047"\w*, \w Lehabites|strong="H3853"\w*, \w Naphtuhites|strong="H5320"\w*,
