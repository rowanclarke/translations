\p
\v 12 \w Timná|strong="H8555"\w* \w fue|strong="H1961"\w* \w concubina|strong="H6370"\w* \w de|strong="H1121"\w* Elifaz, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Esaú|strong="H6215"\w*, la cual le dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* \w Amalec|strong="H6002"\w*. Tales \w fueron|strong="H1961"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Ada|strong="H5711"\w*, esposa \w de|strong="H1121"\w* \w Esaú|strong="H6215"\w*.   
\p
\v 13 Estos \w son|strong="H1961"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Reuel|strong="H7467"\w*: Nahat, \w Zera|strong="H2226"\w*, Sama y Miza. Tales \w fueron|strong="H1961"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Bosemat, esposa \w de|strong="H1121"\w* \w Esaú|strong="H6215"\w*.   
\p
\v 14 Estos \w fueron|strong="H1961"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Oholibama, esposa \w de|strong="H1121"\w* \w Esaú|strong="H6215"\w*, \w hija|strong="H1323"\w* \w de|strong="H1121"\w* \w Aná|strong="H6034"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Zibeón|strong="H6649"\w*. Ella le dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* Jeús, \w Jaalam|strong="H3281"\w* y \w Coré|strong="H7141"\w*.   
\p
\v 15 Estos fueron \w los|strong="H1121"\w* jeques \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Esaú|strong="H6215"\w*.  
\p \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Elifaz, \w primogénito|strong="H1060"\w* \w de|strong="H1121"\w* \w Esaú|strong="H6215"\w*: \w los|strong="H1121"\w* jeques \w Temán|strong="H8487"\w*, Omar, Zefo, Cenaz,  
\v 16 \w Coré|strong="H7141"\w*, \w Gatam|strong="H1609"\w* y \w Amalec|strong="H6002"\w*. Estos son \w los|strong="H1121"\w* jeques provenientes \w de|strong="H1121"\w* Elifaz en la tierra \w de|strong="H1121"\w* Edom, \w los|strong="H1121"\w* cuales fueron \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Ada|strong="H5711"\w*.   
\p
\v 17 Estos son \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Reuel|strong="H7467"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Esaú|strong="H6215"\w*: \w los|strong="H1121"\w* jeques Nahat, \w Zera|strong="H2226"\w*, Sama y Miza. Tales son \w los|strong="H1121"\w* jeques provenientes \w de|strong="H1121"\w* \w Reuel|strong="H7467"\w* en tierra \w de|strong="H1121"\w* Edom. Estos fueron \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Bosemat, esposa \w de|strong="H1121"\w* \w Esaú|strong="H6215"\w*.   
\p
\v 18 Estos son \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Oholibama, esposa \w de|strong="H1121"\w* \w Esaú|strong="H6215"\w*: \w los|strong="H1121"\w* jeques \w Jeús|strong="H3266"\w*, \w Jaalam|strong="H3281"\w* y \w Coré|strong="H7141"\w*. Estos son \w los|strong="H1121"\w* jeques procedentes \w de|strong="H1121"\w* Oholibama, esposa \w de|strong="H1121"\w* \w Esaú|strong="H6215"\w*, \w hija|strong="H1323"\w* \w de|strong="H1121"\w* \w Aná|strong="H6034"\w*.   
\p
\v 19 Tales fueron \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Esaú|strong="H6215"\w*. \w Él|strong="H1931"\w* \w es|strong="H1931"\w* Edom, y tales fueron \w sus|strong="H1931"\w* jeques.   
\p
\v 20 Estos son \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Seír|strong="H8165"\w* \w el|strong="H1121"\w* hurrita, \w habitantes|strong="H3427"\w* \w de|strong="H1121"\w* aquella tierra: \w Lotán|strong="H3877"\w*, \w Sobal|strong="H7732"\w*, \w Zibeón|strong="H6649"\w*, \w Aná|strong="H6034"\w*,  
\v 21 \w Disón|strong="H1789"\w*, Ezer y Disán. Tales fueron \w los|strong="H1121"\w* jeques \w de|strong="H1121"\w* \w los|strong="H1121"\w* hurritas, \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Seír|strong="H8165"\w* en la tierra \w de|strong="H1121"\w* Edom.   
\p
\v 22 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Lotán|strong="H3877"\w* \w fueron|strong="H1961"\w*: \w Hori|strong="H2753"\w* y Hemam. \w Timná|strong="H8555"\w* \w fue|strong="H1961"\w* hermana \w de|strong="H1121"\w* \w Lotán|strong="H3877"\w*.   
