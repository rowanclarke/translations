\v 4 \w Your|strong="H3068"\w* \w actions|strong="H4611"\w* \w stop|strong="H3808"\w* \w you|strong="H5414"\w* \w from|strong="H7725"\w* coming \w back|strong="H7725"\w* \w to|strong="H7725"\w* \w your|strong="H3068"\w* \w God|strong="H3068"\w* \w for|strong="H3588"\w* \w a|strong="H3068"\w* \w spirit|strong="H7307"\w* \w of|strong="H3068"\w* prostitution \w is|strong="H3068"\w* \w within|strong="H7130"\w* \w you|strong="H5414"\w* \w and|strong="H3068"\w* \w you|strong="H5414"\w* \w do|strong="H3068"\w* \w not|strong="H3808"\w* \w know|strong="H3045"\w* \w the|strong="H3588"\w* \w Lord|strong="H3068"\w*.  
