\id JOB
\h أَيُوبْ
\toc1 أَيُوبْ
\toc2 أَيُوبْ
\toc3 أَيُوبْ
\mt1 أَيُوبْ
\c 1
\s1 أَرْيَازْ أَيُوبْ
\m 
\v 1 ثُوغَا ذِينْ إِجّْ ن ورْيَازْ ذِي ثمُّورْثْ ن عُوصْ قَّارنْ أَسْ أَيُوبْ. أَرْيَازْ-أَ ثُوغَا إِكْمڒْ ذ أَمْسڭّذْ، إِتّڭّْوذْ زِي أَربِّي ؤُ إِتّْحيَّاذْ خْ مِينْ إِدْجَانْ ذ أَعفَّانْ. \x ◘ \xo 1:‏1 \xt أَيُوبْ 2‏:‏3\x*
\v 2 تّْوَارْونْ أَسْ-د سبْعَا ن إِحنْجِيرنْ ذ ثْڒَاثَا ن ثْحنْجِيرِينْ. \x ◘ \xo 1:‏2 \xt أَيُوبْ 42‏:‏13\x*
\v 3 ثَاحِيمَارْثْ ن ڒْمَاڒْ نّسْ ذَايسْ سبْعَا-أَڒَافْ ن وُودْجِي ؤُ ثڒْثْ-أَڒَافْ ن إِڒغْمَانْ ذ خمْسَا-مْيَا ن ثْيُويَاوِينْ ن إِينْذُوزنْ ذ خمْسَا-مْيَا ن ثغْيَاڒْ، \add أَرْنِي غَارسْ\add* أَبَارُّو ن إِسمْغَانْ. أَرْيَازْ-أَ ثُوغَا ذ أَمقّْرَانْ خْ مَارَّا أَرَّاوْ ن شَّارْقْ.
\m 
\v 4 إِحنْجِيرنْ نّسْ نُّومنْ تّڭّنْ إِجّْ ن ؤُمنْسِي، كُوڒْ  إِجّْ \add زَّايْسنْ\add* \add س نُّوبثْ نّسْ\add* ذڭْ وَاسّْ نّسْ ذِي ثَادَّارْثْ نّسْ. سّكّنْ، عَارْضنْ ؤُڒَا خْ ثْڒَاثَا ن سُويثْمَاثْسنْ أَذْ كِيذْسنْ شّنْثْ ؤُ أَذْ كِيذْسنْ سْونْثْ.
\v 5 ڒَامِي عْذُونْ وُوسَّانْ ن زَّارْذثْ أَوَارْنِي نّْضنْ \add زِي ثَادَّارْثْ غَارْ ثَادَّارْثْ نّغْنِي\add*، إِسّكّْ أَيُوبْ حِيمَا أَذْ ثنْ إِسّْقدّسْ. زِيشْ غَارْ ثُوفُّوثْ إِكَّارْ ؤُشَا يِيوِي ذِينْ ثِيغَارْصِي ن وشْمَاضْ أَنشْثْ لْعَاذَاذْ ن مَارَّا \add أَرَّاونْ نّسْ\add*. مَاغَارْ أَيُوبْ إِنَّا: ”أَذْ ثَاغْ خْضَانْ أَرَّاونْ إِنُو ؤُ حيّْذنْ خْ أَربِّي ذڭْ وُوڒْ نْسنْ.“ أَمُّو إِ إِڭَّا أَيُوبْ ڒبْذَا. \x ◘ \xo 1:‏5 \xt إِشا. 29‏:‏1\x*
\b
\s1 شِّيطَانْ إِتّْشثْشَا زِي أَيُوبْ
\m 
\v 6 ذڭْ إِجّْ ن وَاسّْ ؤُسِينْ-د أَرَّاوْ ن أَربِّي حِيمَا أَذْ بدّنْ زَّاثْ إِ سِيذِي، ؤُشَا يُوسَا-د ؤُڒَا ذ شِّيطَانْ ذِي ڒْوسْطْ نْسنْ.
\v 7 إِنَّا سِيذِي إِ شِّيطَانْ: ”مَانِيسْ إِ د-ثُوسِيذْ شكْ؟“ يَارَّا-د شِّيطَانْ خْ سِيذِي، إِنَّا: ”ؤُسِيغْ-د زڭْ وثْلَاعْ خْ ثمُّورْثْ، كِّيغْ ت مَارَّا.“ \x ◘ \xo 1:‏7 \xt 1 بُط. 5‏:‏8\x*
\v 8 إِنَّا سِيذِي إِ شِّيطَانْ: ”مَا ثحْضِيذْ أَمْسخَّارْ إِنُو أَيُوبْ؟ أَمْ نتَّا وَارْ إِدْجِي خْ ثمُّورْثْ: ذ أَرْيَازْ إِكْمڒْ، إِڭُّورْ نِيشَانْ، إِتّڭّْوذْ أَربِّي ؤُ إِتّْحيَّاذْ خْ مِينْ إِدْجَانْ ذ أَعفَّانْ!“
\m 
\v 9 يَارَّا-د شِّيطَانْ خْ سِيذِي، إِنَّا: ”مَا أَمنِّي وَاهَا إِتّڭّْوذْ أَيُوبْ أَربِّي؟
\v 10 مَا وَارْ إِدْجِي ذ شكْ، ونِّي إِڭِّينْ إِجّْ ن ؤُسڒْقِي إِ نتَّا ذ ثَادَّارْثْ نّسْ ذ مَارَّا مِينْ غَارسْ؟ أَقَا ثْبَارْكذْ ثِيمڭَّا ن إِفَاسّنْ نّسْ ؤُشَا ڒْمَاڒْ نّسْ إِمْغَارْ أَطَّاسْ ذِي ثمُّورْثْ.
\v 11 سْوِيژّضْ مْغِيرْ أَفُوسْ نّشْ \add غَارسْ\add*، حَاذَا مَارَّا مِينْ إِدْجَانْ نّسْ، مَا \add خنِّي\add* س ثِيذتّْ أَذْ إِبعّذْ خْ وُوذمْ نّشْ؟“
\m 
\v 12 \add خنِّي\add* إِنَّا سِيذِي إِ شِّيطَانْ: ”خْزَارْ، مَارَّا مِينْ غَارسْ أَقَا-ث ذڭْ ؤُفُوسْ نّشْ. مْغِيرْ وَارْ ذ أَسْ سْوِيژِّيضْ أَفُوسْ نّشْ وَاهَا!“ \add خَاسْ ؤُشَا\add* يُويُورْ شِّيطَانْ زِي زَّاثْ ن وُوذمْ ن سِيذِي.
\b
\s1 أَيُوبْ إِتّمْعَاڒَا أَكْ-ذ ؤُجَارّبْ ن شِّيطَانْ
\m 
\v 13 ذڭْ وَاسّْ مِينْ ذِي ثُوغَا إِحنْجِيرنْ نّسْ ذ يسِّيسْ تّتّنْ ؤُ سسّنْ بِينُو ذِي ثَادَّارْثْ ن ؤُمَاثْسنْ أَمنْزُو، إِمْسَارْ،
\v 14 أَقَا يُوسَا-د \bd إِجّْ ن ؤُرقَّاسْ\bd* غَارْ أَيُوبْ، إِنَّا: ”إِفُونَاسنْ ثُوغَا شَارّْزنْ ؤُ ثِيغْيَاڒْ هدَّانْثْ خْ ؤُغزْذِيسْ نْسنْ.
\v 15 \add خنِّي\add* هجْمنْ أَيْثْ ن شَابَا، كْسِينْ ثنْ ؤُشَا نْغِينْ إِحُوذْرِييّنْ س ڒقْضعْ ن سِّيفْ. مْغِيرْ نشّْ وَاهَا إِنجْمنْ، حِيمَا أَذْ أَشْ ث عَاوْذغْ.“
\m 
\v 16 ؤُمِي ثُوغَا وَا عَاذْ إِسَّاوَاڒْ، يُوسَا-د \bd إِجّْ نّغْنِي\bd*، إِنَّا: ”ثِيمسِّي ن أَربِّي ثوْضَا-د زڭْ ؤُجنَّا ؤُشَا ثَارْغَا ذڭْ وُودْجِي ذ إِحُوذْرِييّنْ ؤُشَا ثشَّا إِ-ثنْ. مْغِيرْ نشّْ وَاهَا إِنجْمنْ، حِيمَا أَذْ أَشْ ث عَاوْذغْ.“
\m 
\v 17 ؤُمِي ثُوغَا وَا عَاذْ إِسَّاوَاڒْ، يُوسَا-د \bd إِجّْ نّغْنِي\bd*، إِنَّا: ”أَيْثْ ن إِكَالْذَانِييّنْ سّْبدّنْ ثْڒَاثَا ن بَانْذِييَّاثْ، هجْمنْ خْ إِڒغْمَانْ، كْسِينْ ثنْ ؤُشَا نْغِينْ إِحُوذْرِييّنْ س ڒقْضعْ ن سِّيفْ. مْغِيرْ نشّْ وَاهَا إِنجْمنْ، حِيمَا أَذْ أَشْ ث عَاوْذغْ.“
\m 
\v 18 ؤُمِي ثُوغَا وَا عَاذْ إِسَّاوَاڒْ، يُوسَا-د \bd إِجّْ نّغْنِي\bd*، إِنَّا: ”إِحنْجِيرنْ نّشْ ذ يسِّيشْ شِّينْ ؤُ سْوِينْ بِينُو ذِي ثَادَّارْثْ ن ؤُمَاثْسنْ أَمنْزُو.
\v 19 ؤُشَا خْزَارْ، يُوسَا-د إِجّْ ن ؤُسمِّيضْ إِوْعَارْ خْ ثِيوَا ن ڒخْڒَا، إِڒْقفْ أَربْعَا ن ثْغمُّورَا ن ثَادَّارْثْ ؤُشَا ثوْضَا \add ثَادَّارْثْ\add* خْ إِحُوذْرِييّنْ ذ ثْحُوذْرِييِّينْ ؤُشَا مُّوثنْ نِيثْنِي. مْغِيرْ نشّْ وَاهَا إِنجْمنْ، حِيمَا أَذْ أَشْ ث عَاوْذغْ.“
\m 
\v 20 \add خنِّي\add* إِكَّارْ أَيُوبْ، إِشَارّڭْ أَسڒْهَامْ نّسْ، إِحفّْ أَزدْجِيفْ نّسْ، إِوْضَا خْ ثمُّورْثْ ؤُشَا إِبنْذقْ،
\v 21 إِنَّا: ”ذ أَعَارْيَانْ إِ د-ؤُسِيغْ زڭْ ؤُعذِّيسْ ن يمَّا ؤُ ذ أَعَارْيَانْ إِ ذِينْ إِ غَا ذوْڒغْ. سِيذِي إِوْشَا، سِيذِي إِكّسْ، أَذْ إِتّْوَابَاركْ إِسمْ ن سِيذِي.“ \x ◘ \xo 1:‏21 \xt أَمب. 5‏:‏14؛ 1 تِيم. 6‏:‏7\x*
\v 22 ذِي مَانْ أَيَا مَارَّا وَارْ إِخْضِي أَيُوبْ شَا ؤُ وَارْ إِنِّي مِينْ وَارْ إِعدّْڒنْ خْ أَربِّي.
\b
\b
\c 2
\s1 شِّيطَانْ يَارْنِي أَشثْشِي خْ أَيُوبْ
\m 
\v 1 ذڭْ إِجّْ ن وَاسّْ ؤُسِينْ-د أَرَّاوْ ن أَربِّي، حِيمَا أَذْ بدّنْ زَّاثْ إِ سِيذِي، ؤُشَا يُوسَا-د ؤُڒَا ذ شِّيطَانْ ذِي ڒْوسْطْ نْسنْ مَاحنْذْ أَذْ إِسّْبدّْ إِخفْ نّسْ زَّاثْ إِ سِيذِي.
\v 2 إِنَّا سِيذِي إِ شِّيطَانْ: ”مَانِيسْ إِ د-ثُوسِيذْ شكْ؟ شِّيطَانْ يَارَّا-د خْ سِيذِي، إِنَّا: ”ؤُسِيغْ-د زڭْ وثْلَاعْ خْ ثمُّورْثْ، كِّيغْ ت مَارَّا.“
\v 3 إِنَّا سِيذِي إِ شِّيطَانْ: ”مَا ثحْضِيذْ أَمْسخَّارْ إِنُو أَيُوبْ؟ أَمْ نتَّا وَارْ إِدْجِي خْ ثمُّورْثْ: ذ أَرْيَازْ إِكْمڒْ، إِڭُّورْ نِيشَانْ، إِتّڭّْوذْ أَربِّي ؤُ إِتّْحيَّاذْ خْ مِينْ إِدْجَانْ ذ أَعفَّانْ! عَاذْ يَارْنِي إِتّطّفْ ذِي ڒصْفَايثْ نّسْ، خْ مِينِّي شكْ ذ أَيِي ثْعَارّْنذْ حِيمَا أَذْ ث صَارْضغْ خْ وَالُو.“
\m 
\v 4 يَارَّا-د شِّيطَانْ خْ سِيذِي، إِنَّا: ”ثِيڒْمشْثْ س ثڒْمشْثْ، \add وَاهْ،\add* مَارَّا مِينْ غَارسْ غَارْ بْنَاذمْ، أَذْ ث إِوْشْ إِ ثُوذَارْثْ نّسْ.
\v 5 سْوِيژّضْ مْغِيرْ أَفُوسْ نّشْ \add غَارسْ\add* ؤُشَا حَاذَا إِغْسَانْ نّسْ ذ ويْسُومْ نّسْ، مَا \add خنِّي\add* نتَّا س ثِيذتّْ وَارْ ذَايكْ إِتّْشقَّافْ ذڭْ وُوذمْ نّشْ؟“
\m 
\v 6 \add خنِّي\add* إِنَّا سِيذِي إِ شِّيطَانْ: ”خْزَارْ، نتَّا ذڭْ ؤُفُوسْ نّشْ، مَاشَا أجّْ إِ-ث أَذْ إِدَّارْ!“
\b
\s1 ثِيحبَّا يوْعَارنْ ڒقّْفنْثْ أَيُّوبْ
\m 
\v 7 \add خَاسْ ؤُشَا\add* يُويُورْ شِّيطَانْ زِي زَّاثْ ن وُوذمْ ن سِيذِي ؤُشَا إِوْثَا أَيُوبْ س ثْحبَّا ثِيعفَّانِينْ، زِي ثْڒقَّا ن إِضَارنْ نّسْ أَڒْ ثْقِيشّثْ ن ؤُشقُّوفْ \add ن ؤُزدْجِيفْ\add* نّسْ.
\v 8 نتَّا إِكْسِي أَشدْجِيقْ ن ثْقدُّوحْثْ، حِيمَا أَذْ زَّايسْ إِحكّْ إِخفْ نّسْ، ؤُشَا إِقِّيمْ ذِي ڒْوسْطْ ن يِيغّضْ.
\v 9 ثنَّا أَسْ ثمْغَارْثْ نّسْ: ”مَا عَاذْ ثتّطّْفذْ ذِي ڒصْفَايثْ نّشْ؟ إِنِي أَسْ إِ أَربِّي: ’ذ ونِّي نتَّا!‘، ؤُشَا مّثْ!“
\v 10 نتَّا مَاشَا إِنَّا أَسْ: ”أَمْ مَامّشْ سَّاوَاڒنْثْ ثمْغَارِينْ ثِيبُوهَاڒِييِّينْ ثسَّاوَاڒذْ ؤُڒَا ذ شمْ أَمْ يِيشْثنْ زَّايْسنْثْ. مَا نشِّينْ نْكسِّي ڒْخَارْ زِي أَربِّي، \add مَاشَا\add* وَارْ نْكسِّي خنِّي ؤُڒَا ذ ڒْغَارْ؟“ س مَارَّا مَانْ أَيَا أَيُوبْ وَارْ إِخْضِي شَا س إِينْشِيشنْ نّسْ.
\b
\s1 ثَارْزفْثْ ن إِمدُّوكّْوَاڒْ ن أَيُوبْ
\m 
\v 11 سْڒِينْ ثْڒَاثَا ن إِمدُّوكَّاڒْ ن أَيُوبْ مَارَّا مِينْ خَاسْ إِكِّينْ ذ ڒْغَارْ ؤُ نِيثْنِي ؤُسِينْ-د كُوڒْ إِجّْ زِي ثمُّورْثْ نّسْ: إِلِيفَازْ زِي ثَايْمَانْ، بِيلْذَاذْ زِي شُوحَا ؤُ صُوفَارْ زِي نَاعْمَاثْ. ڭِّينْ أَذْ ذِينْ ؤُيُورنْ، حِيمَا أَذْ كِيذسْ سّْحِيسّْفنْ ؤُ حِيمَا أَذْ ذَايسْ ڭّنْ ؤُڒْ.
\v 12 زِي ڒَاڭّْوَاجْ سّْڭعّْذنْ ثَامُوغْڒِي نْسنْ، مَاشَا وَارْ ت عْقِيڒنْ شَا. نِيثْنِي سّْڭعّْذنْ ثْمِيجَّا نْسنْ ؤُشَا رُونْ. كُوڒْ إِجّْ إِشَارّڭْ أَسڒْهَامْ نّسْ ؤُشَا سُّويْسنْ إِغّضْ غَارْ ؤُجنَّا ثِيوَا إِ إِزدْجِيفنْ نْسنْ.
\v 13 قِّيمنْ غَارسْ خْ ثمُّورْثْ، سبْعَا ن وُوسَّانْ ذ سبْعَا ن دْجِييَاڒِي. ؤُڒَا ذ إِجّنْ وَارْ إِسِّيوڒْ ؤُڒَا ذ إِجّْ ن وَاوَاڒْ غَارسْ، مَاغَارْ ژْرِينْ، أَقَا ڒحْرِيقْ نّسْ ثُوغَا ذ أَمقّْرَانْ أَطَّاسْ.
\b
\b
\c 3
\s1 أَشثْشِي ن أَيُوبْ
\m 
\v 1 أَوَارْنِي مَانْ أَيَا يَارْزمْ أَيُوبْ أَقمُّومْ نّسْ، إِنْعڒْ أَسّْ \add ن وخْڒَاقْ\add* نّسْ. \x ◘ \xo 3:‏1 \xt إِرْم. 15‏:‏10؛ 20‏:‏14\x*
\m 
\v 2 \bd أَيُوبْ\bd* إِطّفْ ذڭْ وَاوَاڒْ، إِنَّا:
\b
\m 
\v 3 أَذْ إِفْنَا أَسّْ إِ ذِي د-تّْوَاخڒْقغْ،
\m ؤُڒَا ذ دْجِيڒثْ إِ ذِي نَّانْ:
\m ’إِجّْ ن ورْيَازْ إِتّْوَاكْسِي.‘
\m 
\v 4 أجّْ أَسّْ نِّي أَذْ إِذْوڒْ ذ ثَادْجسْثْ،
\m عمَّارْصْ وَارْ خَاسْ إِتّْسّقْسِي أَربِّي
\m زڭْ ؤُجنَّا،
\m ؤُ وَارْ خَاسْ ثتّْشعْشِيعْ ثْفَاوْثْ ن ؤُزِيڒْ \add عَاذْ\add*.
\m 
\v 5 إِڒِي ثَادْجسْثْ ذ ثِيڒِي ن ڒْموْثْ أَذْ خَاسْ أَرْزُونْثْ،
\m أجّْ إِسيْنُوثنْ أَذْ زذْغنْ ثِيوَا نّسْ.
\m إِڒِي أَذْ خَاسْ وْضَانْثْ ثْكبَّاسِينْ س ؤُزِيڒْ! \f ◼ \fr 3:‏5 \ft \bd ’ثِيكبَّاسِينْ‘\bd* - خْمِي إِ غَا د-ثذْوڒْ ثْفُوشْثْ ؤُ ثْزِيرِي ثبُّومْبسْ نقَّارْ: ’أَقَا ذِينْ ثِيكبَّاسِينْ‘.\f*
\b
\m 
\v 6 أَذْ ثكّسْ ثْكبَّاسْثْ يُودْجْغنْ دْجِيڒثْ نِّي،
\m أجّْ \add دْجِيڒثْ نِّي\add* وَارْ ثْفَارّحْ
\m جَارْ وُوسَّانْ ن ؤُسڭّْوَاسْ،
\m أجّْ إِ-ت وَارْ د-ثتِّيسْ
\m ذِي ڒحْسَابْ ن إِيُورنْ.
\m 
\v 7 خْزَارْ، أجّْ دْجِيڒثْ نِّي
\m عمَّارْصْ وَارْ د-ثتِّيرُووْ،
\m وَارْ ذَايسْ إِتِّيذفْ ؤُسْڒِيوْڒوْ.
\m 
\v 8 أجّْ إِنِّي إِسّْفطّْحنْ أَسّْ،
\m أَذْ ث نعْڒنْ،
\m إِنِّي إِتّْحَاكَانْ أَذْ سّكَّارنْ ’لِيبِييَاثَانْ‘. \f ◼ \fr 3:‏8 \ft \bd ’إِنِّي إِسّْفطّْحنْ أَسّْ‘\bd* - إِخْسْ أَذْ يِينِي إِنِّي إِڭِّينْ ثَاسحَّارْثْ ذ ثَاڭزَّانْثْ ذ عْڒَامْ كُوڒْ ثِيمسْڒَايِينْ ثِيبَارْشَانِينْ وَارْ إِحّْڒِينْ، ؤُڒَا ذ إِنِّي إِتِّيرَارنْ أَكْ-ذ ڒْهَايْشثْ ’لِيبِييَاثَانْ‘. \bd ’لِيبِييَاثَانْ‘\bd* - أَقَا-ث ذ إِسمْ ن إِشْثْ ن ڒْهَايْشثْ ذ ثَامقّْرَانْثْ. أَذْ ثَاغْ ڒْهَايْشثْ-أَ ذ إِجّْ ن ؤُمذْيَا ن ثْڭلْذِيثْ ن مِيصْرَا، ثَامُّورْثْ ن فِيرْعُونْ. ذِي ڒْوقْثْ نِّي أَڒْ إِ ڒخُّو أَقَا ذِينْ إِوْذَانْ ذِي سِينْ ؤُ ذِي ذْزَايرْ إِنِّي إِتَّامْننْ أَقَا ڒْحَايْشثْ نِّي ذ ڒعْذُو ن ثْفُوشْثْ ذ ثْزِيرِي. تّْخَارّْصنْ أَقَا ڒْهَايْشثْ ثڭَّا أَذْ ثْصَارْذْ ثَافُوشْثْ ذ ثْزِيرِي. س ؤُينِّي ؤُمِي ثمْسَارْ إِشْثْ ن ثْبَارّْشنْثْ ن ثْفُوشْثْ نِيغْ ن ثْزِيرِي، فّْغنْ-د نِيثْنِي بَارَّا حِيمَا أَذْ ڭّنْ إِجّْ ن دّْرِيزْ ذ أَمقّْرَانْ س ثَادْجُونِينْ ذ عْڒَامْ كُوڒْ ن ڒقْشُوعْ ن نّْحَاسْ حِيمَا أَذْ أَژّْڒنْ خْ ڒْهَايْشثْ مَاحنْذْ أَذْ ثْبَانْ ثْفُوشْثْ ذ ثْزِيرِي عَاوذْ. إِسمْ ’لِيبِييَاثَانْ‘ نُوفَا إِ-ث عَاوذْ ذِي أَيُوبْ 40‏:25.\f*
\m 
\v 9 أجّْ أَذْ تّْوَاكبّْسنْ إِثْرَانْ ن ثُوفُّوثْ نّسْ،
\m أجّْ إِ-ث أَذْ إِرَاجَا ثَافَاوْثْ، ڒَامِي وَارْ ذِينْ ثدْجِي.
\m أجّْ أَبْڒِيونْ ن ثْفَاوْثْ نْ ڒفْجَارْ
\m وَارْ ت ژَترّنْ! \f ◼ \fr 3:‏9 \ft \bd ’أَبْرِيونْ ن ؤُثفُّو‘\bd* - ذِي ثِيمُّورَا ن شَّارْقْ-أَمڒْوَاسُو حسّْبنْ أَيْثْ ن شِّيعْرْ ثَافُوشْثْ أَمْ إِشْثْ ن ثِيطّْ غَارسْ أَبْرِيونْ ذ ثِيمِّيوِينْ. أَقَا أَيُّوبْ إِقَّارْ ذڭْ وَاوَاڒْ-أَ أَقَا حْسنْ ثَافَاوْثْ ن ثْفُوشْثْ غَارْ ؤُثفُّو ن وَاسّْ عمَّارْصْ وَارْ د-ثَارقّْ خْ وَاسّْ ن ثْڒَاڒِيثْ نّسْ.\f*
\b
\m 
\v 10 مَاغَارْ نتَّا وَارْ إِبلّعْ ثِيوُّورَا
\m ن ؤُعذِّيسْ \add ن يمَّا\add*،
\m وَارْ إِفَّارْ ڒغْبنْ زَّاثْ إِ ثِيطَّاوِينْ إِنُو.
\m 
\v 11 مَايمِّي وَارْ مُّوثغْ
\m ڒَْامِي ذ أَيِي ثُوغَا ذڭْ ؤُعذِّيسْ \add ن يمَّا\add*،
\m مَايمِّي وَارْ سُّوفّْغغْ بُوحْبڒْ،
\m ڒَْامِي د-فّْغغْ زڭْ ؤُعذِّيسْ \add ن يمَّا\add*؟
\m 
\v 12 مَايمِّي ذ أَيِي رَاجَانْ إِفَادّنْ
\m ؤُ مَايمِّي إِبَّاشْ،
\m حِيمَا أَذْ \add ذَايْسنْ\add* طّضغْ؟
\b
\m 
\v 13 خنِّي إِڒِي أَذْ زّْڒغْ ڒخُّو، أَذْ سّْقَارغْ.
\m إِڒِي أَذْ طّْصغْ.
\m خنِّي بَالَاكْ أَذْ غَارِي ثِيڒِي ڒْهُوذْنثْ
\m 
\v 14 \add جْمِيعْ\add* أَكْ-ذ إِجدْجِيذنْ
\m ذ إِمْشَاوَارنْ ن ثمُّورْثْ،
\m إِنِّي إِبْنَانْ إِ يِيخفْ نْسنْ أَرّْوِينَاثْ إِخْڒَانْ،
\m 
\v 15 نِيغْ \add جْمِيعْ\add* أَكْ-ذ ڒْحُوكَّامْ
\m نِّي غَارْ إِدْجَا وُورغْ،
\m إِنِّي إِشُّورنْ ثُوذْرِينْ نْسنْ س نُّوقَارْثْ،
\m 
\v 16 نِيغْ نشّْ وَارْ تِّيڒِيغْ \add عَاذْ\add*
\m أَمْ يِيجّْ ن وغْرَايْ \add ن ثمْغَارْثْ\add* سّْنُوفَّارنْ ث،
\m أَمشْنَاوْ إِسيْمَانْ
\m نِّيعمَّارْصْ وَارْ إِژْرِينْ ثَافَاوْثْ.
\b
\m 
\v 17 ذِينِّي سّْبدّنْ إِعفَّاننْ زِي صّْذعْ،
\m ذِينِّي تَّاريَّاحنْ
\m إِنِّي ؤُمِي إِفْنَا جّهْذْ نْسنْ.
\m 
\v 18 ذِينِّي تَّاريَّاحنْ إِمحْبَاسْ \add مُوننْ\add*،
\m وَارْ قِّيمنْ تّسْڒَانْ \add عَاذْ\add*
\m إِ ثْمِيجَّا ن إِمْزيَّارنْ \add ن إِسمْغَانْ\add*.
\m 
\v 19 أَقَا ذِينْ أَمژْيَانْ ذ ؤُمقّْرَانْ،
\m إِسْمغْ إِنُّوفْسڒْ ذِينْ زِي بَابْ نّسْ.
\b
\m 
\v 20 مَايمِّي ثمّوْشْ ثْفَاوْثْ إِ ڒْمسْكِينْ،
\m ؤُ ثُوذَارْثْ إِ يِينِّي
\m ؤُمِي إِتّْوَاسَّارْزڭْ ڒعْمَارْ نْسنْ،
\m 
\v 21 \add إِ يِينِّي\add* إِتّْمژْرنْ ذِي ڒْموْثْ،
\m مَاشَا وَارْ ت ؤُفِينْ،
\m إِنِّي إِغزَّانْ خْ \add ڒْموْثْ\add* كْثَارْ
\m خْ ڒكْنُوزْ إِنُّوفَارنْ،
\m 
\v 22 إِنِّي إِفَارّْحنْ أَطَّاسْ
\m أَڒَامِي ذوْڒنْ نڭّْزنْ،
\m ؤُ تّْغبَّانْ مژْرِي خْمِي تَّافنْ أَنْضڒْ؟
\m 
\v 23 \add مَايمِّي ثمّوْشْ ثْفَاوْثْ\add* إِ ورْيَازْ
\m ونِّي ؤُمِي إِتّْوَاسّْنُوفَّارْ وبْرِيذْ نّسْ،
\m \add إِ ورْيَازْ\add* ونِّي خفْ إِبلّعْ أَربِّي
\m زِي مَارَّا إِغزْذِيسنْ؟
\b
\m 
\v 24 مِينْزِي ذڭْ ومْشَانْ ن وغْرُومْ إِنُو
\m إِتَّاسْ-د ؤُوحْوحْ إِنُو،
\m إِغُويَّانْ إِنُو تّْوَازدْجْعنْ أَمْ وَامَانْ. \x ◘ \xo 3:‏24 \xt إِزهد. 42‏:‏4\x*
\m 
\v 25 مِينْزِي ثُوغَا تّْنخْڒَاعغْ
\m ؤُ أَمنِّي د-إِفّغْ
\m مِينْ زِي ثُوغَا تّڭّْوذغْ، وْضِيغْ ذَايسْ.
\m 
\v 26 وَارْ غَارِي ڒْهُوذْنثْ، وَارْ أَرْسِيغْ شَا
\m ؤُ وَارْ تَّاريِّيحغْ.
\m أَقَا ؤُسِينْ-د إِمْخُومْبَارْ.
\b
\b
\c 4
\s1 ڒْحَارْضْ أَمزْوَارُو ن إِلِيفَازْ: كْسِي أَوبّخْ ن أَربِّي!
\m 
\v 1 \add خنِّي\add* يَارَّا-د \bd إِلِيفَازْ\bd*، ونِّي د-يُوسِينْ زِي ثَايْمَانْ، إِنَّا:
\b
\m 
\v 2 مَاڒَا \add حذْ\add* يَارْزُو
\m مَاحنْذْ أَذْ كِيكْ إِسِّيوڒْ،
\m مَا وَارْ ثتّْوَاشضْنذْ قَاعْ \add س مَانْ أَيَا\add*؟
\m \add مَاشَا\add* مَانْ ونْ إِزمَّارنْ
\m أَذْ إِسّْبدّْ ڒْهَارْذْ \add نّسْ\add*؟
\m 
\v 3 خْزَارْ، ثسّْغَارذْ أَطَّاسْ \add ن إِوْذَانْ\add*
\m ؤُ إِفَاسّنْ يَارْخُونْ ثسّْمحْضذْ إِ-ثنْ.
\m 
\v 4 ونِّي إِنْقَارْضنْ،
\m ثسّْبدّذْ إِ-ث س وَاوَاڒْ نّشْ،
\m ؤُ إِفَادّنْ إِفشْڒنْ
\m ثوْشِيذْ أَسنْ جّهْذْ \add عَاوذْ\add*.
\m 
\v 5 مَاشَا ڒخُّو إِمْسَارْ أَيَا إِ شكْ،
\m ثتّْوَاشضْنذْ قَاعْ،
\m \add ڒخُّو\add* إِڒْقفْ إِ شكْ أَيَا ؤُشَا ثَارجْفذْ.
\b
\m 
\v 6 مَا وَارْ ثدْجِي ثِيڭّْوُوذِي \add زِي أَربِّي\add*
\m ذ ڒَامَانْ نّشْ
\m ؤُ ڒصْفَايثْ ن إِبْرِيذنْ نّشْ ذ ڒَايَاسْ نّشْ؟
\m 
\v 7 خمّْ مَاشَا!
\m مَانْ ونْ إِتّْوَاهلّْكنْ أَمْ إِدْجَا ذ أَمزْذَاڭْ
\m ؤُ مَانِي تّْوَاثحَّانْ إِنِّي إِڭُّورنْ نِيشَانْ؟
\m 
\v 8 ژْرِيغْ أَقَا إِنِّي إِشَارّْزنْ دّدْجْ
\m ذ يِينِّي إِزَارّْعنْ ڒغْبنْ،
\m أَذْ ث مْجَارنْ \add عَاوذْ\add*. \x ◘ \xo 4:‏8 \xt أَيُوبْ 15‏:‏35؛ إِزهد. 7‏:‏15؛ أَوڒن. 22‏:‏8؛ إِشا. 59‏:‏4؛ حُوش. 10‏:‏13؛ ڭال. 6‏:‏7، 8\x*
\m 
\v 9 أَذْ هلّْكنْ زڭْ ؤُسُوضِي ن نّفْسْ ن أَربِّي،
\m أَذْ فْنَانْ س ؤُسُوضِي زڭْ ونْزَارنْ نّسْ. \x ◘ \xo 4:‏9 \xt إِشا. 11‏:‏4\x*
\m 
\v 10 زّْهِيرْ ن ويْرَاذْ
\m ذ ثْمِيجَّا ن يِيزمْ أَمژْيَانْ \add أَذْ تّْوَاسّْبدّنْ\add*
\m ؤُ ثِيغْمَاسْ ن وَايْرَاذنْ إِمژْيَاننْ
\m أَذْ تّْوَارْژَانْثْ.
\m 
\v 11 أَذْ إِهلّكْ وَايْرَاذْ،
\m مِينْزِي وَارْ يُوفِي زَّارْذثْ،
\m ثَارْوَا ن ثَايْرَاذْثْ أَذْ تّْوَابزّْعنْ.
\b
\m 
\v 12 ذِي ثْنُوفّْرَا يِيوضْ أَيِي-د إِجّْ ن وَاوَاڒْ،
\m أَمزُّوغْ إِنُو إِطّفْ زَّايسْ ڒحْمِيسْ،
\m 
\v 13 \add أَمْ ثُوغَا غَارّْقغْ\add*
\m ذڭْ إِخَارِّيصنْ إِسِّيڭّْوِيذنْ
\m زڭْ إِوحَّانْ ن دْجِيڒثْ،
\m ڒَْامِي د-إِوْضَا يِيضصْ يُودْجْغنْ خْ إِوْذَانْ.
\m 
\v 14 ثڒْقفْ أَيِي ثِيڭّْوُوذِي ذ ثَارْجِيجِيثْ،
\m مَارَّا إِغْسَانْ إِنُو نّْخڒْعنْ.
\m 
\v 15 إِجّْ ن بُوحْبڒْ إِحْرَارَا خْ ؤُغمْبُوبْ إِنُو،
\m إِسّْبدّْ أَشُوَّافْ ذِي أَرِّيمثْ إِنُو.
\m 
\v 16 نتَّا إِبدّْ،
\m \add مَاشَا\add* وَارْ عْقِيڒغْ خْ ثفْرَاسْ نّسْ.
\m إِجّْ ن وَادُّوذْ \add إِبدّْ\add* زَّاثْ إِ ثِيطَّاوِينْ إِنُو.
\m \add خنِّي\add* سْڒِيغْ إِ ثْمِيجَّا ثتّمْثِيمْ، ثقَّارْ:
\b
\m 
\v 17 ’مَا \add إِزمَّارْ\add* إِجّْ ن بْنَاذمْ
\m أَذْ يِيڒِي إِسڭّذْ خْ أَربِّي؟
\m مَا \add إِزمَّارْ\add* إِجّْ ن ورْيَازْ
\m أَذْ يِيڒِي إِصْفَا خْ ونِّي ث إِڭِّينْ؟‘
\m 
\v 18 خْزَارْ، وَارْ إِتّْشِيڒِي
\m ؤُڒَا خْ إِمْسخَّارنْ نّسْ،
\m إِڭَّا ڒْعِيبْ \add عَاذْ\add* أَكْ-ذ لْمَالَاكَاثْ نّسْ
\m ؤُمِي ودَّارنْثْ. \x ◘ \xo 4:‏18 \xt أَيُوبْ 15‏:‏15؛ 2 بُط. 2‏:‏4\x*
\m 
\v 19 مَاهُو إِنِّي إِزدّْغنْ ذِي ثُوذْرِينْ ن ؤُشَاڒْ،
\m إِنِّي غَارْ ثدْجَا ثْعجَّاجْثْ ذ ذْسَاسْ نْسنْ.
\m أَقَا أَذْ تّْوَاڒبْزنْ أَمزْوَارْ خْ ثْشِينْذَا.
\m 
\v 20 زِي ثُوفُّوثْ ن صّْبحْ أَڒْ ثَامذِّيثْ
\m أَذْ تّْوَافَارْثْكنْ.
\m بْڒَا إِ إِوْشَا \add بْنَاذمْ\add* ثَايْنِيثْ \add إِ مَانْ أَيَا\add*،
\m أَذْ فْنَانْ إِ ڒبْذَا.
\m 
\v 21 مَا وَارْ د-ثتّْوَاقْڒعْ غَارْسنْ
\m ثسْغُونْثْ ن ؤُقِيضُونْ نْسنْ \add ن أَرِّيمثْ\add*؟
\m أَذْ مّْثنْ، \add مَاشَا\add* وَارْ إِدْجِي ذِي ثِيغِيثْ.
\b
\b
\c 5
\m 
\v 1 ڒَاغَا مَاشَا! مَا ذِينْ شَا ن يِيجّنْ
\m إِ خَاكْ د غَا يَارّنْ؟
\m غَارْ مَانْ زڭْ إِمْقدَّاسنْ إِ غَا ثْسوْضذْ؟
\m 
\v 2 مِينْزِي أَخيّقْ إِنقّْ أَبُوهَاڒِي،
\m ؤُ ثُوسْمِي ثْنقّْ أَقُوبَّانِي.
\m 
\v 3 ژْرِيغْ إِجّْ ن ؤُبُوهَاڒِي إِضْڒقْ إِ وژْوَارْ،
\m \add مَاشَا\add* خْ إِشْثْ ن ڒْغفْڒثْ
\m ثُوغَا إِتّْخصَّا أَذْ نعْڒغْ ثَازذِّيغْثْ نّسْ.
\m 
\v 4 إِڭّْوجنْ إِحنْجِيرنْ نّسْ خْ ؤُسنْجمْ،
\m تّْوَادّْزنْ غَارْ ثوَّارْثْ \add ن ثنْذِينْثْ\add*
\m ؤُشَا وَارْ ثُوغِي ذِينْ وِي ثنْ إِ غَا إِفكّنْ،
\m 
\v 5 \add ؤُمِي\add* إِشَّا ؤُمهْيُوفْ صَّابثْ نّسْ
\m - \add وَاهْ، وَانِيثَا\add* إِسُّوفّغْ إِ-ث-إِ-د \add عَاذْ\add*
\m زڭْ إِسنَّاننْ -
\m ؤُ إِسَارْضْ ؤُخوَّانْ أَڭْڒَا نْسنْ.
\b
\m 
\v 6 مَاغَارْ وَارْ إِدْجِي زِي ثْعجَّاجْثْ
\m إِ زِي د-إِتّكّْ ڒْغَارْ
\m ؤُ زِي ثمُّورْثْ وَارْ د-ثْغمِّي ثَامَارَا،
\m 
\v 7 مَاشَا بْنَاذمْ
\m ذ ونِّي د-إِتّْوَاخڒْقنْ إِ ثَامَارَا،
\m أَمْ ڭعّْذنْثْ ثْشعَّاڒِينْ ن ثْمسِّي
\m مَاحنْذْ أَذْ ضْوِينْثْ.
\m 
\v 8 مْڒِي ؤُفِيغْ أَذْ أَرْزُوغْ غَارْ أَربِّي،
\m أَذْ سِّيوْضغْ ثَامسْڒَاشْثْ إِنُو غَارْ أَربِّي،
\m 
\v 9 ونِّي إِتّڭّنْ ثِيمسْڒَايِينْ ثِيمقّْرَانِينْ،
\m وَارْ ذِينْ وِي ثنْثْ إِ غَا إِفهْمنْ،
\m \add إِتّڭّْ\add* لْمُوعْجِيزَاثْ
\m إِ وَارْ إِزمَّارْ أَذْ تّْوَاحسْبنْثْ. \x ◘ \xo 5:‏9 \xt أَيُوبْ 9‏:‏10؛ إِزهد. 72‏:‏18؛ رُوم. 11‏:‏33\x*
\m 
\v 10 إِسَّاكّْوَاضْ أَنْژَارْ خْ وُوذمْ ن ثمُّورْثْ،
\m ؤُشَا إِسّكَّا أَمَانْ خْ وُوذمْ ن إِيَّارنْ، \x ◘ \xo 5:‏10 \xt إِزهد. 104‏:‏10\x*
\m 
\v 11 حِيمَا أَذْ إِسّْڭعّذْ إِمْوَاضْعنْ،
\m ؤُشَا إِنِّي إِشضْننْ أَذْ ثنْ سُّوعْڒَانْ غَارْ ڒَامَانْ. \x ◘ \xo 5:‏11 \xt 1 صم. 2‏:‏7؛ إِزهد. 113‏:‏7، 8\x*
\b
\m 
\v 12 نتَّا إِسّْبطّڒْ
\m إِخَارِّيصنْ ن إِحْرَايْمِييّنْ،
\m \add أَڒَامِي\add* إِفَاسّنْ نْسنْ
\m وَارْ زمَّارنْ أَذْ ڭّنْ وَالُو. \x ◘ \xo 5:‏12 \xt نَاح. 4‏:‏9؛ إِزهد. 33‏:‏10؛ إِشا. 8‏:‏10\x*
\m 
\v 13 إِمِيغِيسنْ إِمنّعْ إِ-ثنْ
\m ذِي ثحْرَايْمشْثْ نْسنْ،
\m إِتّْوَاسّْبطّڒْ شّْوَارْ ن إِحْرَايْمِييّنْ. \x ◘ \xo 5:‏13 \xt 1 كُور. 3‏:‏19\x*
\m 
\v 14 ذڭْ ؤُزِيڒْ مّْسَاڭَارنْ أَكْ-ذ ثَادْجسْثْ
\m ؤُشَا ذِي طّْحَا ن ؤُزِيڒْ
\m تّْفَافَانْ أَمْ تّْفَافَانْ \add ذِي\add* دْجِيڒثْ. \x ◘ \xo 5:‏14 \xt أَعَوذ. 28‏:‏29\x*
\m 
\v 15 نتَّا إِسّنْجَامْ زِي سِّيفْ \add إِ د-إِتّفّْغنْ\add*
\m زڭْ ؤُقمُّومْ نْسنْ،
\m ؤُڒَا ذ أَمزْڒُوضْ زڭْ ؤُفُوسْ ن ونِّي إِجهْذنْ.
\m 
\v 16 أَمُّو إِ يدْجَا ڒَايَاسْ إِ ؤُمزْڒُوضْ
\m ؤُشَا دّدْجْ أَذْ إِبلّعْ أَقمُّومْ نّسْ. \x ◘ \xo 5:‏16 \xt إِزهد. 107‏:‏42\x*
\b
\m 
\v 17 خْزَارْ، سّعْذْ ن ورْيَازْ
\m ونِّي إِسڭّمْ أَربِّي.
\m \add س ؤُيَا\add* وَارْ ثسّحْقِيرِي شَا
\m تَّارْبِييّثْ ن ؤُمْزمَّارْ خْ كُوڒْشِي! \x ◘ \xo 5:‏17 \xt أَوڒن. 3‏:‏11، 12؛ عبر. 12‏:‏5؛ يَاع. 1‏:‏12؛ أَسَا. 3‏:‏19\x*
\m 
\v 18 مَاغَارْ نتَّا إِسّْيزِّيمْ أَيِي
\m س إِجّْ ن ؤُيزِّيمْ إِتّقّْسنْ
\m ؤُشَا \add خنِّي\add* إِتّْشدَّا،
\m إِشَّاثْ ؤُشَا \add خنِّي\add* إِفَاسّنْ نّسْ سّْڭنْفَانْ. \x ◘ \xo 5:‏18 \xt أَعَوذ. 32‏:‏39؛ 1 صم. 2‏:‏6؛ حُوش. 6‏:‏1\x*
\m 
\v 19 ذِي ستَّا ن ڒحْصَارَاثْ أَذْ شكْ إِفكّْ،
\m ذِي ثنِّي وِيسّْ سبْعَا وَارْ شكْ إِڒقّفْ ڒْغَارْ. \x ◘ \xo 5:‏19 \xt إِزهد. 91\x*
\m 
\v 20 ذِي ڒَاژْ أَذْ شكْ إِسّنْجمْ زِي ڒْموْثْ،
\m ذڭْ ؤُمنْغِي زِي ثِييِّيثَا ن سِّيفْ.
\m 
\v 21 أَذْ ثِيڒِيذْ ذِي ڒَامَانْ
\m زَّاثْ إِ ؤُركُّوضْ ن يِيڒسْ،
\m وَارْ ثتّڭّْوذذْ شَا زڭْ وَاردّدْجْ
\m مَاڒَا يُوسَا-د.
\b
\m 
\v 22 خْ وَاردّدْجْ ذ ڒَاژْ
\m ثْزمَّارذْ أَذْ ثْضحْشذْ،
\m زِي ڒوْحُوشْ ن ڒخْڒَا ن ثمُّورْثْ
\m وَارْ ثتّڭّْوذذْ،
\m 
\v 23 مَاغَارْ ثْقضْعذْ ڒْعَاهْذْ أَكْ-ذ إِژْرَا ن ييَّارْ،
\m \add خنِّي\add* ڒوْحُوشْ ن ڒخْڒَا
\m أَذْ كِيذكْ دَّارنْ ذِي ڒهْنَا. \x ◘ \xo 5:‏23 \xt حُوش. 2‏:‏20\x*
\m 
\v 24 أَذْ ثَارْڭْبذْ أَقَا ڒهْنَا ذ أَقِيضُونْ نّشْ،
\m أَذْ ثْبقّْشذْ ثَازذِّيغْثْ نّشْ،
\m أَذْ ثَافذْ وَارْ شكْ إِتّْخصِّي وَالُو.
\m 
\v 25 شكْ أَذْ ثسّْنذْ أَقَا أَرَّاوْ نّشْ أَطَّاسْ،
\m ؤُ دُّورّْيثْ نّشْ
\m أَمْ وفْسُو \add أَزِيزَا\add* ن ثمُّورْثْ.
\m 
\v 26 أَذْ ثَاذْفذْ غَارْ ونْضڒْ ذِي ثوْسَارْ،
\m أَمْ مَامّشْ سّْڭعّْذنْ
\m إِجّْ ن ؤُعُورِّيشْ ن ثْقبِّيضِينْ ن إِمنْذِي
\m \add غَارْ ؤُنذْرَارْ\add* ذِي ڒْحَاڒْ نّسْ.
\b
\m 
\v 27 خْزَارْ، مَانْ أَيَا، أَقَا نشِّينْ نَارْزُو ذَايسْ،
\m أَمُّو إِ ثدْجَا!
\m سڒْ غَارسْ، سّنْ إِ-ث ذڭْ يِيخفْ نّشْ!
\b
\b
\c 6
\s1 ثَامْوَارِّيثْ ن أَيُوبْ خْ إِلِيفَازْ: أَفقُّوسْ نّسْ
\m 
\v 1 يَارَّا-د \bd أَيُوبْ\bd*، إِنَّا:
\b
\m 
\v 2 أَ، مْڒِي وزْننْ ڒْهمّْ إِنُو،
\m مْڒِي جِّينْ أَذْ إِڭعّذْ
\m خْ ڒْمِيزَانْ س ثْنَاينْ ن طَّاوْيَاثْ
\m ؤُڒَا ذ ڒغْبنْ إِنُو أَكِيذسْ إِمُونْ!
\m 
\v 3 مَاغَارْ ڒخُّو أَقَا-ث إِذْقڒْ خْ يجْذِي ن ڒبْحُورْ،
\m خْ ؤُيَا \add تّفّْغنْ\add* وَاوَاڒنْ إِنُو
\m نْهْڒَا أَخمّمْ. \x ◘ \xo 6:‏3 \xt أَوڒن. 27‏:‏3 \x*
\m 
\v 4 مَاغَارْ \add نُّوغنْثْ\add* ذَايِي فْڒِيثْشَاثْ
\m ن ؤُمْزمَّارْ خْ كُوڒْشِي،
\m أَڒَامِي بُوحْبڒْ إِنُو إِسسّْ أَرّْهَاجْ نْسنْثْ.
\m إِنخْڒِيعنْ زِي أَربِّي كَّارنْ-د أَكِيذِي. \x ◘ \xo 6:‏4 \xt إِزهد. 38‏:‏2، 3\x*
\b
\m 
\v 5 مَا إِسّْحُونْذْرُوثْ وغْيُوڒْ ن ڒخْڒَا
\m غَارْ أَرْبِيعْ أَزِيزَا؟
\m نِيغْ إِسّْمُوهْرُوثْ ؤُفُونَاسْ غَارْ هدُّو نّسْ؟
\m 
\v 6 مَاشَّا بْڒَا أَڒذِّي
\m مَا أَذْ ت يشّْ \add بْنَاذمْ\add* بْڒَا ثَامدْجَاحْثْ؟
\m نِيغْ أَقَا ذِينْ أَڒذِّي
\m ذِي ڒْمحّْ أَشمْڒَاڒْ ن ثْمدْجَاتْشْ؟
\m 
\v 7 مِينْ يُوڭِي ڒعْمَارْ إِنُو أَذْ ث إِحَاذَا،
\m \add ڒخُّو\add* أَيَا مَارَّا إِ نشّْ
\m أَمْ مَاشَّا إِغُومّنْ.
\b
\m 
\v 8 مْڒِي د غَا يَاسْ مِينْ تَّارغْ
\m إِوَا، إِوْشَا أَربِّي مِينْ سِيتِّيمغْ.
\m 
\v 9 مْڒِي ثُوغَا إِخْسْ سِيذِي مَاحنْذْ أَذْ أَيِي إِڒْبزْ،
\m مَاحنْذْ أَذْ إِسَّارْخُو أَفُوسْ نّسْ
\m ؤُ مَاحنْذْ أَذْ أَيِي إِقسّْ.
\m 
\v 10 مَانْ أَيَا أَذْ أَيِي يِيڒِي عَاذْ ذ أَفوّجْ،
\m أَذْ أَيِي إِنْعشْ ذِي ڒحْرِيقْ نِّي
\m وَارْ \add خَافِي\add* إِسّْعِيزِّي شَا،
\m مَاغَارْ وَارْ نْكَارغْ شَا
\m أَوَاڒنْ ن ؤُمْقدَّاسْ.
\b
\m 
\v 11 مِينْ إِعْنَا جّهْذْ إِنُو،
\m أَقَا زمَّارغْ أَذْ رَاجِيغْ \add عَاذْ\add*؟
\m نِيغْ مِينْ إِعْنَا ؤُنڭَّارُو إِنُو،
\m ونِّي خْ تّخْسغْ
\m أَذْ زُّوڭَارْثغْ ثُوذَارْثْ إِنُو \add عَاذْ\add*؟
\m 
\v 12 مَا جّهْذْ إِنُو أَمْ جّهْذْ ن إِژْرَا؟
\m مَا أَيْسُومْ إِنُو أَمْ نّْحَاسْ؟
\m 
\v 13 مَا وَارْ دْجِيغْ قَاعْ بْڒَا ثْوِيزَا س يِيخفْ إِنُو،
\m مَا وَارْ خَافِي إِتّْوَاكّسْ ؤُفكِّي قَاعْ؟
\b
\m 
\v 14 ونِّي ؤُمِي إِقْضعْ ڒَايَاسْ \add إِتّْخصَّا أَسْ\add*
\m ثَامخْسِيوْثْ إِشُووَّارنْ
\m زڭْ ؤُمدُّوكّڒْ نّسْ،
\m مَاڒَا لَّا، \add إِزمَّارْ\add* أَذْ يجّْ ثِيڭّْوُوذِي
\m زڭْ ؤُمْزمَّارْ خْ كُوڒْشِي.
\m 
\v 15 أَيْثْمَا بَاننْ-د ذ إِغدَّارنْ
\m أَمْ ثْغزْرِينْ \add ذڭْ إِذُورَارْ\add*،
\m أَمْ ثَاسُّوثْ ن ثْغزْرِينْ نِّي إِعدُّونْ ذغْيَا،
\m 
\v 16 \add أَمْ ثِيغزْرِينْ\add* ثِينِّي إِتّْبَارّشْننْ س وجْرِيسْ،
\m نِّي ذِي إِسّْنُوفَّارْ وذْفڒْ \add إِخفْ نّسْ\add*.
\m 
\v 17 ذڭْ وُوسَّانْ نِّي ذِي ذوْڒنْثْ
\m حْصَارنْثْ، بدّنْثْ،
\m خْمِي حمَّانْثْ، تَّاژْغنْثْ،
\m إِمْحَا ومْشَانْ نْسنْثْ.
\b
\m 
\v 18 إِبْرِيذنْ ن ثشْڒِي نْسنْ فَارْغنْ،
\m ڭعّْذنْ ذِي ڒعْوِينْ ؤُشَا ودَّارنْ.
\m 
\v 19 إِمْسبْرِيذنْ زِي ثَايْمَا
\m قِّيمنْ تّْمژْرِينْ ذَايْسنْثْ،
\m إِكَارَابَاننْ زِي شَابَا تّْرَاجَانْ ثنْثْ.
\m 
\v 20 نِيثْنِي تّْوَاشمْثنْ
\m ذڭْ ؤُثشْڒِي نِّي غَارْسنْ.
\m ؤُسِينْ-د غَارْ ثْغزْرِينْ \add ذڭْ إِذُورَارْ\add*
\m ؤُشَا بَارّْقنْ.
\m 
\v 21 س ثِيذتّْ، ڒخُّو ثْذوْڒمْ ذ وَالُو،
\m ثژْرِيمْ أَرْژِييّثْ إِنُو ؤُشَا ثڭّْوذمْ.
\b
\m 
\v 22 مَا نِّيغْ: ’أَوْيمْ أَيِي-د \add شَا\add*!‘
\m نِيغْ: ’وْشمْ أَيِي ثِيرْزِيفِينْ زڭْ وَاڭْڒَا نْومْ!‘
\m 
\v 23 نِيغْ: ’فكّْ أَيِي زڭْ ؤُفُوسْ ن ونِّي إِحصَّارنْ!‘
\m نِيغْ: ’فْذِي أَيِي زڭْ ؤُفُوسْ ن أَيْثْ ن بُو-ڒخْشُونثْ!‘
\b
\m 
\v 24 سْغَارْ أَيِي، \add خنِّي\add* أَذْ سّغْذغْ،
\m سْشنْ أَيِي مِينْ ذِي ودَّارغْ!
\m 
\v 25 مَامّشْ جهّْذنْ وَاوَاڒنْ يشْنَانْ،
\m \add مَاشَا\add* مِينْ خفْ أَوبّخْ نْومْ؟
\m 
\v 26 مَا ثتّْخَارّْصمْ ذڭْ وَاوَاڒنْ،
\m مَاحنْذْ أَذْ \add أَيِي\add* ثتّْوبّْخمْ \add زَّايْسنْ\add*؟
\m مَا \add خنِّي\add* أَوَاڒنْ
\m ن ونِّي ؤُمِي قضْعنْ ڒَايَاسْ
\m أَمْ ڒعْوِينْ إِ كنِّيوْ؟
\m 
\v 27 عَاذْ خْ يِيجّْ ن ؤُنِيبُو أَيُوجِيڒْ
\m أَذْ خَاسْ ثنْضَارمْ ثَاقدُّوحْثْ
\m ؤُ عَاذْ خْ يِيجّْ ن ؤُمدُّوكّڒْ نْومْ
\m أَذْ خَاسْ ثڭّمْ ثَامعْمُوتْشْ.
\b
\m 
\v 28 خنِّي ڒخُّو، مَاڒَا ثخْسمْ،
\m حْضَامْ خَافِي مْلِيحْ،
\m نشّْ وَارْ خَاومْ سّْخَارِّيقغْ
\m ذڭْ ؤُغمْبُوبْ \add نْومْ\add*.
\m 
\v 29 قدْجْبمْ \add أَيِي\add*،
\m وَارْ إِعدّڒْ أَذْ \add ذَايِي\add* يِيڒِي دّدْجْ.
\m قدْجْبمْ \add أَيِي\add* عَاوذْ،
\m ثَاسڭْذَا إِنُو ثْبدّْ عَاذْ \add نِيشَانْ\add*.
\m 
\v 30 مَا أَقَا ذِينْ ڒْغشّْ خْ يِيڒسْ إِنُو؟
\m مَا وَارْ إِتّْڒذِّي وَانغْ إِنُو
\m خْ مِينْ وَارْ إِحْڒِينْ؟
\b
\b
\c 7
\s1 أَيُوبْ يَارْنِي ذِي ثمْوَارِّيثْ نّسْ إِ إِلِيفَازْ: مَا وَارْ إِدَّارْ بْنَاذمْ ثُوذَارْثْ ثقْسحْ؟
\m 
\v 1 مَا وَارْ \add ذِينْ\add* إِدْجِي ؤُمنْغِي إِتّْخصَّا
\m أَذْ ث إِمّْنغْ بْنَاذمْ خْ ثمُّورْثْ،
\m مَا وَارْ دْجِينْ وُوسَّانْ نّسْ
\m أَمْ وُوسَّانْ ن ؤُشوَّاڒْ؟
\m 
\v 2 أَمْ مَامّشْ إِتّْمژْرِي إِمْسغْ غَارْ ثِيڒِي،
\m أَمُّو إِتّْرَاجَا ؤُشوَّاڒْ ڒْمُونثْ،
\m 
\v 3 س ؤُيَا ذوْڒنْ إِيُورنْ شُّورنْ
\m س ؤُبَارّقْ ذ ثَاسْغَارْثْ إِنُو
\m ؤُ دْجْيَاڒِي شُّورنْثْ س ثَامَارَا
\m بْضَانْ أَيِي ثنْثْ.
\b
\m 
\v 4 خْمِي تّزّْڒغْ تّطّْصغْ، قَّارغْ
\m ’مڒْمِي زمَّارغْ أَذْ كَّارغْ،
\m \add مڒْمِي\add* إِ غَا ثعْذُو دْجِيڒثْ؟‘
\m جِّيوْنغْ س ڒحْوڒْ أَڒْ ذ يفُّو ڒْحَاڒْ.
\m 
\v 5 أَرِّيمثْ إِنُو ثْيَارْضْ ذڭْ إِكشَّاونْ
\m ؤُ ذِي ثقْشُورِينْ ن ؤُشَاڒْ،
\m ثِيڒْمشْثْ إِنُو ثْقطَّا ؤُ ثتّْڭيّحْ.
\m 
\v 6 ذغْيَا خْ ؤُمكُّوكْ ن ؤُخيَّاضْ
\m عدُّونْ وُوسَّانْ إِنُو،
\m عدُّونْ بْڒَا ڒَايَاسْ.
\b
\m 
\v 7 عْقڒْ، أَقَا ثُوذَارْثْ إِنُو
\m ذ أَسُوضِي ن نّفْسْ \add وَاهَا\add*
\m ؤُ ثِيطّْ إِنُو وَارْ ثْژَارّْعمَّارْصْ عَاذْ
\m مِينْ إِصبْحنْ. \x ◘ \xo 7:‏7 \xt أَيُوبْ 8‏:‏9؛ 14‏:‏1، 2، 3؛ 16‏:‏22؛ إِزهد. 90‏:‏5، 6، 9؛ 102‏:‏12؛ 103‏:‏15؛ 144‏:‏4؛ إِشا. 40‏:‏6؛ يَاع. 4‏:‏14؛ 1 بُط. 1‏:‏24\x*
\m 
\v 8 ثِيطّْ ن ونِّي ذ أَيِي إِتّْوَاڒَانْ،
\m وَارْ ذ أَيِي ثْژَارّْ عَاذْ.
\m ثِيطَّاوِينْ نّشْ أَذْ خَافِي إِڒِينْثْ،
\m \add مَاشَا\add* نّشْ وَارْ ذَا تِّيڒِيغْ عَاذْ.
\m 
\v 9 \add أَمْ مَامّشْ\add* إِتّْذُورُّوقْ ؤُسيْنُو، إِعدُّو،
\m أَمُّو إِ غَا إِهْوَا ذِي ڒَاخَارْثْ،
\m وَارْ \add زَّايسْ\add* د-إِتّْڭعِّيذْ عَاذْ.
\m 
\v 10 عمَّارْصْ وَارْ د-إِتّْعِيقِّيبْ
\m غَارْ ثَادَّارْثْ نّسْ،
\m عمَّارْصْ وَارْ خَاسْ إِتّعْقِيڒْ ومْشَانْ نّسْ.
\m 
\v 11 أَمُّو إِ وَارْ تّقّْنغْ أَقمُّومْ إِنُو،
\m أَذْ سِّيوْڒغْ ذِي ڒحْصَارثْ ن بُوحْبڒْ إِنُو،
\m أَذْ شثْشِيغْ ذِي ثَارْزُوڭِي ن ڒعْمَارْ إِنُو.
\b
\m 
\v 12 مَا نشّْ ذ ڒبْحَارْ نِيغْ ذ ڒْهَايْشثْ،
\m أَقَا شكْ ثسّْبدّذْ خَافِي أَعسَّاسْ؟
\m 
\v 13 مَاڒَا نِّيغْ نشّْ: ’ثَاسُّوثْ أَذْ أَيِي ثْعزَّا،
\m قَامَا إِنُو أَذْ خَافِي ثسّهْونْ أَشثْشِي إِنُو!‘،
\m 
\v 14 أَمُّو إِذْ أَيِي ثتّْغزِّيذْ س ثِيرْجِيوِينْ
\m ؤُ س إِوحَّانْ ثسَّاڭّْوَاذذْ أَيِي،
\m 
\v 15 أَڒَامِي إِذْوڒْ ڒعْمَارْ إِنُو
\m إِتِّيخْضَارْ أَجيّفْ،
\m \add إِتِّيخْضَارْ\add* ڒْموْثْ خْ ييْسَانْ إِنُو.
\m 
\v 16 نشّْ تّْعِيفِّيغْ \add مَانْ أَيَا\add*،
\m وَارْ تّخْسغْ أَذْ دَّارغْ إِ ڒبْذَا.
\m أَرْخُو زَّايِي، مَاغَارْ ؤُسَّانْ إِنُو
\m \add أَمْ\add* أَسُوضِي ن نّفْسْ \add وَاهَا\add*.\x ◘ \xo 7:‏16 \xt إِزهد. 62‏:‏10؛ 144‏:‏4\x*
\b
\m 
\v 17 مِينْ إِعْنَا بْنَاذمْ أَقَا شكْ ثْحسّْبذْ ث
\m ذ أَمقّْرَانْ \add أَمُّو\add*،
\m أَقَا ثڒْهِيذْ أَكِيذسْ س وُوڒْ نّشْ؟ \x ◘ \xo 7:‏17 \xt إِزهد. 8‏:‏5؛ 144‏:‏3؛ عبر. 2‏:‏6\x*
\m 
\v 18 أَقَا شكْ ثَارزّْفذْ غَارسْ قَاعْ \add أَ\add*ثفُّو،
\m ثْقدْجْبذْ إِ-ث قَاعْ ثَازحْزِيهْثْ؟
\m 
\v 19 مشْحَاڒْ عَاذْ
\m وَارْ زَّايِي ثتّكّْسذْ \add ثِيطَّاوِينْ\add*،
\m وَارْ ذ أَيِي ثَارخُّوذْ
\m حِيمَا أَذْ سّْغڒْيغْ إِكُوفَّانْ إِنُو؟
\b
\m 
\v 20 مَا خْضِيغْ؟ مِينْ ذ أَشْ إِ غَا ڭّغْ إِ شكْ،
\m \add إِ شكْ\add* \add أَ-يْ-\add*أَعسَّاسْ ن بْنَاذمْ؟
\m مَايمِّي ذ أَيِي ثسّْبدّذْ
\m ذ ثَاحْجُورْثْ زَّاثكْ،
\m ؤُ ذوْڒغْ ذ دّْقڒْ إِ يِيخفْ إِنُو؟
\m 
\v 21 مَايمِّي وَارْ \add ذ أَيِي\add* ثْغفَّارذْ
\m أَخطُّو إِنُو،
\m ؤُ وَارْ ثْعدُّوذْ خْ ڒْمُوعْصِييّثْ إِنُو؟
\m مَاغَارْ ذغْيَا أَذْ زّْڒغْ ذِي ثْعجَّاجْثْ
\m ؤُ شكْ أَذْ خَافِي ثَارْزُوذْ،
\m \add مَاشَا\add* وَارْ تِّيڒِيغْ \add عَاذْ\add*.
\b
\b
\c 8
\s1 ڒْهَارْذْ أَمزْوَارُو ن بِيلْذَاذْ
\m 
\v 1 \add خَاسْ ؤُشَا\add* يَارَّا-د \bd بِيلْذَاذْ\bd*، ونِّي د-يُوسِينْ زِي شُوحَا، إِنَّا:
\b
\m 
\v 2 مشْحَاڒْ إِ غَا ثكّذْ ثسَّاوَاڒذْ أَمُّو،
\m أَذْ إِڒِينْ وَاوَاڒنْ ن ؤُقمُّومْ نّشْ
\m \add أَمشْنَاوْ\add* أَسمِّيضْ ن ثْهَارْيَاضْثْ.
\m 
\v 3 مَا أَذْ إِسّْفَارْغْ أَربِّي ثَاسْغَارْثْ،
\m نِيغْ أَذْ إِسّْفَارْغْ
\m ؤُمْزمَّارْ خْ كُوڒْشِي ثَاسڭْذَا؟ \x ◘ \xo 8:‏3 \xt أَعَوذ. 32‏:‏4؛ 2 إِم. 19‏:‏7؛ دَان. 9‏:‏14\x*
\m 
\v 4 مَاڒَا أَكِيذسْ خْضَانْ إِحنْجِيرنْ نّشْ،
\m أَقَا إِسّكّْ إِ-ثنْ ذڭْ ؤُفُوسْ ن ؤُخطُّو نْسنْ.
\b
\m 
\v 5 مَاڒَا شكْ ثَارزُّوذْ أَربِّي س جّهْذْ،
\m ثتّْزَاوْڭذْ أَحِينِّي
\m غَارْ ؤُمْزمَّارْ خْ كُوڒْشِي، \x ◘ \xo 8:‏5 \xt أَيُوبْ 22‏:‏23\x*
\m 
\v 6 مَاڒَا ثدْجِيذْ ذ أَمزْذَاڭْ ؤُ ثْسڭّْمذْ،
\m خنِّي أَذْ أَشْ إِوْشَا ثَايْنِيثْ نِيشَانْ،
\m أَذْ إِعْذڒْ ثَازذِّيغْثْ نّشْ إِ شكْ.
\m 
\v 7 \add وَاخَّا\add* ثَامزْوَارُوثْ نّشْ
\m أَذْ ثِيڒِي ذ ثُوقْڒِيتْشْ،
\m ثَانڭَّارُوثْ نّشْ أَذْ ثِيڒِي ثمْغَارْ أَطَّاسْ.
\b
\m 
\v 8 وَاهْ، سقْسَا خنِّي غَارْ جِّيڒْ إِعْذُونْ،
\m حكَّارْ ذِي ڒجْذُوذْ نْسنْ. \x ◘ \xo 8:‏8 \xt أَعَوذ. 4‏:‏32\x*
\b
\m 
\v 9 مَاغَارْ نشِّينْ ن إِضنَّاضْ \add وَاهَا\add*،
\m وَارْ نسِّينْ وَالُو،
\m مَاغَارْ ؤُسَّانْ نّغْ خْ ثمُّورْثْ أَمْ ثِيڒِي. \x ◘ \xo 8:‏9 \xt أَمز. 47‏:‏9؛ 1 إِم. 29‏:‏15؛ أَيُوبْ 7‏:‏5، 6، 7؛ إِزهد. 39‏:‏13؛ 102‏:‏12؛ 144‏:‏4\x*
\m 
\v 10 مَا وَارْ شكْ سّڒْمِيذنْ نِيثْنِي،
\m مَا وَارْ غَاركْ سِّيوِيڒنْ،
\m مَا وَارْ د-سُّوفُّوغنْ أَوَاڒنْ
\m زڭْ وُوڒْ نْسنْ؟
\b
\m 
\v 11 مَا إِغمِّي ؤُغَانِيمْ ن بَابِيرُوسْ
\m بْڒَا سّبْخثْ،
\m مَا إِمقَّارْ ؤُغَانِيمْ غَارْ ثْمَا ن إِغْزَارْ
\m بْڒَا أَمَانْ؟
\m 
\v 12 خْمِي إِتّْنوَّارْ، وَارْ إِمْجَارْ عَاذْ،
\m إِتَّاژغْ قْبڒْ مَارَّا أَرْبِيعْ نّغْنِي. \x ◘ \xo 8:‏12 \xt إِزهد. 129‏:‏6؛ إِرْم. 17‏:‏6\x*
\m 
\v 13 أَمُّو إِ دْجَانْ إِمسْرَاقْ
\m ن مَارَّا إِنِّي إِتُّونْ أَربِّي،
\m ڒَْايَاسْ ن ؤُمْنَافقْ أَذْ إِفْنَا. \f ◼ \fr 8:‏13 \ft \bd ’أَمْنَافقْ‘\bd* - بْنَاذمْ نِّي إِتّڭّنْ س ثْنَاينْ ن وُوذْمَاونْ.\f*  \x ◘ \xo 8:‏13 \xt أَيُوبْ 11‏:‏20؛ 18‏:‏14؛ إِزهد. 112‏:‏10؛ أَوڒن. 10‏:‏28\x*
\m 
\v 14 مِينْ خفْ إِعمّذْ، أَذْ إِتّْوَاقْضعْ،
\m مِينْ خفْ إِتّْشَاڒْ،
\m أَذْ د-إِبَانْ ذ أَخْمَاڒْ ن قُونْذْعَا.
\m 
\v 15 أَذْ إِسنّذْ خْ ثَادَّارْثْ نّسْ،
\m \add مَاشَا\add* وَارْ ثتّْبذِّي،
\m أَذْ ذَايسْ إِشبَّارْ،
\m \add مَاشَا\add* وَارْ ثتّْغِيمِي ثْبدّْ.
\b
\m 
\v 16 نتَّا ذ أَزِيزَا ذِي ثْفَاوْثْ ن ثْفُوشْثْ،
\m ڒفْرُوعْ نّسْ إِمژْيَاننْ تّْبزَّاعنْ
\m خْ وحْوِيشْ نّسْ.
\m 
\v 17 إِژوْرَانْ نّسْ مُّوذنْ إِخفْ نْسنْ
\m خْ إِجّْ ن ؤُعُورِّيشْ ن يژْرَا،
\m إِتَّارْجَا إِشْثْ ن ثَادَّارْثْ ن يژْرَا \add إِ يِيخفْ نّسْ\add*.
\m 
\v 18 \add مَاڒَا\add* نتَّا إِقدْجعْ إِ-ث
\m زڭْ ومْشَانْ نّسْ،
\m أَذْ ث إِنْكَارْ \add ومْشَانْ\add* نِّي، \add أَذْ يِينِي\add*:
\m ’عمَّارْصْ وَارْ شكْ ژْرِيغْ!‘
\m 
\v 19 خْزَارْ، ثَا ثدْجَا ذ ڒفْرَاحثْ
\m ن وبْرِيذْ \add ن ثُوذَارْثْ\add* نّسْ
\m ؤُ إِنّغْنِي أَذْغمْينْ زڭْ ؤُشَاڒْ.
\b
\m 
\v 20 خْزَارْ، أَربِّي وَارْ إِنطَّارْ
\m ونِّي إِكمْڒنْ
\m \add مَاشَا\add* وَارْ إِتِّيشْ \add أَ\add*فُوسْ إِ إِعفَّاننْ.
\m 
\v 21 عَاذْ أَذْ إِشُّورْ أَقمُّومْ نّشْ
\m س ثْضحَّاشْثْ،
\m ؤُ إِينْشِيشنْ نّشْ س ؤُسْڒِيوْڒوْ.
\m 
\v 22 إِمشْرَاهْ نّشْ أَذْ يَارْضنْ ڒفْضِيحثْ
\m ؤُ أَقِيضُونْ ن إِعفَّاننْ وَارْ إِتِّيڒِي عَاذْ.
\b
\b
\c 9
\s1 ثَامْوَارِّيثْ ن أَيُوبْ خْ بِيلْذَاذْ
\m 
\v 1 يَارَّا-د \bd أَيُوبْ\bd*، إِنَّا:
\b
\m 
\v 2 سّْنغْ نِيشَانْ، أَقَا أَمُّو إِ ثدْجَا،
\m مَاغَارْ مَامّشْ غَا يِيڒِي بْنَاذمْ
\m ذ أَمْسڭّذْ غَارْ أَربِّي؟ \x ◘ \xo 9:‏2 \xt إِزهد. 143‏:‏2\x*
\m 
\v 3 مَاڒَا نتَّا إِخْسْ أَكِيذسْ إِمْشَارّعْ،
\m إِڒِي نتَّا وَارْ إِزمَّارْ أَذْ خَاسْ د-يَارّْ
\m ؤُڒَا ذ إِشْثْ ن ثْوَاڒَا خْ وَاڒفْ ن ثْوَاڒَاوِينْ.
\m 
\v 4 نتَّا ذ أَمِيغِيسْ ن وُوڒْ
\m ذ بُو-ثْزمَّارْ إِجهْذنْ،
\m مَانْ ونْ إِزمَّارنْ
\m أَذْ إِسّقْسحْ إِخفْ نّسْ ضِيدّْ نّسْ
\m ؤُشَا أَذْ إِقِّيمْ إِدَّارْ ذِي ڒَامَانْ؟
\b
\m 
\v 5 نتَّا ذ ونِّي إِسّْمُوطُّوينْ إِذُورَارْ
\m أَمْ وَارْ ت تِّيشِينْ \add إِوْذَانْ\add*،
\m ذ ونِّي ثنْ إِسّْنقْڒَابنْ
\m ذڭْ وغْضَابْ نّسْ،
\m 
\v 6 نتَّا ذ ونِّي إِسّنْهزَّانْ ثَامُّورْثْ
\m زڭْ ومْشَانْ نّسْ،
\m ذ ونِّي إِڭِّينْ إِپِيلَارنْ نّسْ أَذْ أَرْجِيجنْ،
\m 
\v 7 نتَّا ذ ونِّي إِتَّامَارنْ ثَافُوشْثْ
\m أَڒَامِي وَارْ د-ثنْقِيرْ،
\m ذ ونِّي إِتّْشمَّاعنْ إِثْرَانْ!
\b
\m 
\v 8 نتَّا س يِيخفْ نّسْ وَاهَا
\m إِتّْبزَّاعْ إِجنْوَانْ،
\m نتَّا إِصُورُّوفْ ثِيوَا
\m ن ثْعُورَارْ \add نْ ڒمْوَاجْ\add* ن وَامَانْ. \x ◘ \xo 9:‏8 \xt أَمز. 1‏:‏6\x*
\m 
\v 9 نتَّا ذ ونِّي إِڭِّينْ \add أَوْرَافْ ن إِثْرَانْ\add*
\m ن دُّوبْ \add أَمقّْرَانْ\add* ذ ؤُرْيُونْ،
\m \add أَڭْرَاوْ ن\add* سبْعَا ن إِثْرَانْ
\m ذ إِخَامّنْ ن لْجَانُوبْ،
\m 
\v 10 نتَّا ذ ونِّي إِڭِّينْ
\m ثِيمسْڒَايِينْ ثِيمقّْرَانِينْ،
\m - وَارْ إِزمَّارْ \add بْنَاذمْ\add* أَذْ ثنْثْ إِفْهمْ -
\m ؤُڒَا ذ ڒعْجَايبْ بْڒَا ڒحْسَابْ. \x ◘ \xo 9:‏10 \xt أَيُوبْ 5‏:‏9؛ إِزهد. 72‏:‏18؛ 77‏:‏15؛ 86‏:‏10؛ رُوم. 11‏:‏33\x*
\b
\m 
\v 11 خْزَارْ، نتَّا إِعدُّو خَافِي، وَارْ ث ژَترّغْ،
\m إِژكّْوَا، نشّْ وَارْ كِيذسْ تَّاشِيغْ.
\m 
\v 12 خْزَارْ، مَاڒَا إِخْضفْ نتَّا،
\m مَانْ ونْ إِ ث غَا إِمنْعنْ؟
\m مَانْ ونْ إِزمَّارنْ أَذْ أَسْ يِينِي:
\m ’مِينْ ذِينْ ثتّڭّذْ شكْ؟‘
\m 
\v 13 أَربِّي وَارْ إِتَّارِّي أَغْضَابْ نّسْ
\m أَذْ د-إِذْوڒْ،
\m سَاذُو نّسْ ؤُضَارنْ إِمْعَاوَاننْ ن ’رَاهَابْ‘. \f ◼ \fr 9:‏13 \ft \bd ’رَاهَابْ‘\bd* - إِخْسْ أَذْ يِينِي: ’ونِّي إِسَّاڭّْوَاذنْ‘. ’رَاهَابْ‘ ذ إِسمْ ن ڒْهَايْشثْ. ڒْهَايْشثْ-أَ أَقَا-ت ذ ثَامُّورْثْ ن مِيصْرَا، ثنِّي أَمْ ڒحْوشْ ذِي ڒبْحَارْ (إِخْسْ أَذْ يِينِي: ’إِغْزَارْ ن نِيلْ‘) إِسَّاڭّْوَاذْ ڒڭْنُوسْ س جّهْذْ نّسْ شِّيطَانِي.\f*
\m 
\v 14 مَامّشْ إِ غَا ڭّغْ أَذْ خَاسْ د-أَرّغْ،
\m مَامّشْ إِ غَا فَارْزغْ
\m أَوَاڒنْ إِنُو \add مْلِيحْ\add* زَّاثسْ؟
\m 
\v 15 وَاخَّا نشّْ ذ أَمْسڭّذْ،
\m وَارْ زمَّارغْ أَذْ خَاسْ د-أَرّغْ،
\m \add مَاشَا\add* أَذْ زَاوْڭغْ ڒْقَاضِي إِنُو
\m مَاحنْذْ أَذْ خَافِي إِحِينّْ،
\b
\m 
\v 16 مَاڒَا خَافِي د-يَارّْ ڒَامِي ڒَاغِيغْ،
\m وَارْ تّْغِيڒغْ أَقَا نتَّا أَذْ إِسڒْ
\m غَارْ ثْمِيجَّا إِنُو.
\m 
\v 17 أَقَا نتَّا إِڒبّزْ أَيِي س إِشْثْ ن ثْحَارْيَاضْثْ
\m ؤُ يَارنِّي ذڭْ إِيزِّيمنْ إِنُو بَاطڒْ.
\m 
\v 18 نتَّا وَارْ ذ أَيِي إِتّجِّي أَذْ أَرّغْ نّفْسْ،
\m مَاشَا إِسّْجَاوَانْ أَيِي س ثَارْزُوڭِي.
\m 
\v 19 مَاڒَا ثقِّيمْ \add ثْمسْڒَاشْثْ\add* ذِي جّهْذْ،
\m أَقَا نتَّا إِجْهذْ قَاعْ،
\m مَاڒَا ذِي شّْرعْ، \add إِقَّارْ\add*:
\m ’وِي ذ أَيِي غَا إِعَارْضنْ؟‘
\m 
\v 20 وَاخَّا نشّْ ذ أَمْسڭّذْ،
\m \add عَاذْ\add* أَقمُّومْ إِنُو أَذْ خَافِي إِحْكمْ،
\m وَاخَّا نشّْ بْڒَا ڒْعِيبْ،
\m \add عَاذْ\add* نتَّا أَذْ أَيِي إِعيّبْ.
\b
\m 
\v 21 وَاخَّا نشّْ بْڒَا ڒْعِيبْ \add إِ دْجِيغْ\add*،
\m وَارْ سِّينغْ ڒعْمَارْ إِنُو \add نِيشَانْ\add*،
\m ثُوذَارْثْ إِنُو حسّْبغْ ت ذ وَالُو.
\m 
\v 22 خْ ؤُيَا إِ غَا إِنِيغْ: ’قَاعْ ذ إِشْثْ!
\m أَمْ ونِّي إِدْجَانْ بْڒَا ڒْعِيبْ
\m أَمْ ونِّي إِدْجَانْ ذ أَعفَّانْ،
\m نتَّا أَذْ ثنْ إِقْضَا س ثْنَاينْ إِذْسنْ!‘ \x ◘ \xo 9:‏22 \xt أَمب. 9‏:‏2، 3؛ مـَال. 3‏:‏14\x*
\m 
\v 23 مَاڒَا أَركُّوضْ إِنقّْ ذڭْ إِشْثْ ن ثشْثِي،
\m \add خنِّي\add* نتَّا إِسْثهزَّا
\m زِي ڒقْضعْ ن ڒَايَاسْ إِ إِمزْذَاڭنْ.
\m 
\v 24 ثَامُّورْثْ أَذْ ثمّوْشْ
\m ذڭْ ؤُفُوسْ ن ؤُعفَّانْ.
\m إِغمْبَابْ ن ڒْقُوضَاثْ نّسْ إِتّْڒحّفْ أَسنْ.
\m مَاڒَا وَارْ \add ث إِڭِّي\add* نتَّا، مَانْ ونْ خنِّي؟
\b
\m 
\v 25 ذغْيَا خْ ونِّي إِتَّازّْڒنْ
\m أَقَا تّْقدْجِيقنْ وُوسَّانْ إِنُو،
\m أَروْڒنْ غَارْ ذِينْ، وَارْ ثْوِيڒِينْ ڒْخَارْ. \x ◘ \xo 9:‏25 \xt أَيُوبْ 7‏:‏6، 7\x*
\m 
\v 26 كِّينْ أَمْ ثْغَارُّوبَا ن ؤُغَانِيمْ،
\m أَمْ ؤُڭِيذرْ إِحوّْمنْ خْ زَّارْذثْ.
\m 
\v 27 مَاڒَا نِّيغْ: ’أَذْ تُّوغْ أَشثْشِي إِنُو،
\m أَذْ بدّْڒغْ أَغمْبُوبْ \add إِشضْننْ\add* إِنُو،
\m أَذْ سّْفِيرْنِينغْ!‘،
\m 
\v 28 \add أَمُّو إِ\add* تّڭّْوذغْ زِي مَارَّا ڒحْرِيقْ إِنُو.
\m نشّْ سّْنغْ شكْ وَارْ زَّايِي ثتّْبَارِّيذْ.
\b
\m 
\v 29 نشّْ ذ أَعفَّانْ،
\m مَايمِّي سّْحِيسِّيفغْ إِ وَالُو؟
\m 
\v 30 مَاڒَا سِّيرْذغْ س وَامَانْ ن وذْفڒْ،
\m أَذْ سِّيزذْڭغْ إِفَاسّنْ إِنُو س لِّيخِييَا، \x ◘ \xo 9:‏30 \xt إِرْم. 2‏:‏22\x*
\m 
\v 31 \add عَاذْ\add* أَذْ أَيِي ثْنثْيذْ
\m ذڭْ وحْفُورْ يَارْصُوذنْ،
\m أَڒْ ذ أَيِي غَا إِعِيفّْ وَارُّوضْ إِنُو.
\m 
\v 32 مَاغَارْ نتَّا وَارْ إِدْجِي ذ بْنَاذمْ أَمْ نشّْ،
\m ونِّي خفْ زمَّارغْ أَذْ د-أَرّغْ،
\m خْمِي نتَّاوضْ غَارْ ثَادَّارْثْ ن شّْرعْ
\m أَكْ-ذ وَايَاوْيَا. \x ◘ \xo 9:‏32 \xt أَمب. 6‏:‏10؛ إِرْم. 49‏:‏19\x*
\m 
\v 33 وَارْ \add ذِينْ\add* إِدْجِي ڒْعَاذڒْ جَارْ أَنغْ،
\m ونِّي إِزمَّارنْ أَذْ إِسَّارْسْ أَفُوسْ نّسْ
\m خَانغْ س ثْنَاينْ إِذْنغْ.
\b
\m 
\v 34 أجّْ إِ-ث أَذْ خَافِي إِكْسِي أَعْمُوذْ نّسْ،
\m وَارْ ذ أَيِي إِسّْنخْڒِيعْ \add عَاذْ\add* ؤُهُوذِّي نّسْ، \x ◘ \xo 9:‏34 \xt أَيُوبْ 13‏:‏20؛ 33‏:‏7\x*
\m 
\v 35 \add خنِّي\add* أَذْ سِّيوْڒغْ
\m نْهْڒَا أَذْ زَّايسْ ڭّْوذغْ،
\m مَاغَارْ نشّْ وَارْ دْجِيغْ أَمُّو إِ يِيخفْ إِنُو.
\b
\b
\c 10
\s1 أَيُوبْ إِسِّيوڒْ أَكْ-ذ بِيلْذَاذْ خْ لْغَارَاضْ ن أَربِّي س ؤُودّبْ
\m 
\v 1 إِتّْعِيفِّي ڒعْمَارْ إِنُو زِي ثُوذَارْثْ إِنُو،
\m أَذْ بَارّْحغْ أَشثْشِي إِنُو
\m أَمُّو وَاهَا بْڒَا أَمْنَاعْ،
\m أَذْ سِّيوْڒغْ غَارْ ثَارْزُوڭِي ن ڒعْمَارْ إِنُو.
\m 
\v 2 نشّْ أَذْ إِنِيغْ إِ أَربِّي:
\m ’وَارْ ذ أَيِي تّڭّْ ذ أَعفَّانْ،
\m سْشنْ أَيِي، مَايمِّي أَكِيذِي ثتّْمنْغِيذْ.
\b
\m 
\v 3 مَا غَاركْ ڒفْضڒْ أَقَا شكْ ثْحصَّارذْ \add أَيِي\add*،
\m أَقَا ثْنطَّارضْ ڒْخذْمثْ ن إِفَاسّنْ نّشْ،
\m \add أَمْ\add* ثتّڭّذْ ثَافَاوْثْ
\m خْ إِخَارِّيصنْ ن إِعفَّاننْ؟
\m 
\v 4 مَا غَاركْ ثِيطَّاوِينْ ن بْنَاذمْ،
\m مَا ثتّْوَاڒِيذْ شكْ
\m أَمْ مَامّشْ تّْوَاڒَانْ إِوْذَانْ؟ \f ◼ \fr 10:‏4 \ft \bd ’بْنَاذمْ‘\bd* - س ثْعِيبْرَانِيثْ ’أَيْسُومْ‘.\f*
\m 
\v 5 مَا ؤُسَّانْ نّشْ أَمْ وُوسَّانْ ن بْنَاذمْ؟
\m مَا إِسڭّْوُوسَا نّشْ
\m أَمْ يِيسڭّْوُوسَا ن ورْيَازْ،
\m 
\v 6 أَقَا شكْ ثَارزُّوذْ
\m \add أَمُّو\add* خْ ڒْمُوعْصِييّثْ إِنُو،
\m ثتّْبقّْشذْ ذِي دّْنُوبْ إِنُو؟
\m 
\v 7 وَاخَّا شكْ ثسّْنذْ
\m أَقَا نشّْ وَارْ دْجِيغْ ذ أَعفَّانْ،
\m وَارْ ذِينْ ونِّي إِ غَا إِفكّنْ زڭْ ؤُفُوسْ نّشْ.
\b
\m 
\v 8 إِفَاسّنْ نّشْ خڒْقنْ أَيِي، ڭِّينْ أَيِي،
\m أَقَا تّنّْضنْ أَيِي،
\m ؤُشَا \add ڒخُّو\add* شكْ ثْصَارْضذْ أَيِي.
\m 
\v 9 عْقڒْ أَقَا شكْ ثڭِّيذْ أَيِي أَمْ ثَارِّيسْثْ،
\m ؤُ غَارْ ثْعجَّاشْثْ ثخْسذْ أَذْ أَيِي ثَارّذْ. \x ◘ \xo 10:‏9 \xt أَمز. 2‏:‏7؛ 3‏:‏19\x*
\m 
\v 10 مَا وَارْ ذ أَيِي ثْزدْجْعذْ أَمْ ؤُغِي،
\m أَمْ كِيسُو ثجِّيذْ أَيِي أَذْ شّْرغْ؟ \x ◘ \xo 10:‏10 \xt إِزهد. 139‏:‏15، 16\x*
\m 
\v 11 س ثڒْمشْثْ ذ ويْسُومْ ثسّْيَارْضذْ أَيِي،
\m س إِغْسَانْ ذ إِژوْرَانْ ثمُّوذذْ أَيِي.
\m 
\v 12 ثُوذَارْثْ ذ ثْمخْسِيوْثْ إِشُووَّارنْ
\m ثوْشِيذْ أَيِي ثنْثْ،
\m أَحطُّو نّشْ إِحْضَا بُوحْبڒْ إِنُو.
\b
\m 
\v 13 ثْخمّْڒذْ أَيَا ذڭْ وُوڒْ نّشْ،
\m نشّْ سّْنغْ بلِّي أَيَا ثُوغَا-ث غَاركْ ذِي ڒْبَاڒْ.
\m 
\v 14 مَاڒَا خْضِيغْ، شكْ أَذْ أَيِي ثحْضِيذْ،
\m وَارْ ذ أَيِي ثتّْبَارِّيذْ زِي ڒْمُوعْصِييّثْ إِنُو.
\m 
\v 15 مَاڒَا ڭِّيغْ ڒْغَارْ، ؤُشْثْ خَافِي!
\m مَاڒَا نشّْ ذ أَمْسڭّذْ \add إِ دْجِيغْ\add*،
\m وَارْ زمَّارغْ أَذْ سّْڭعّْذغْ أَزدْجِيفْ إِنُو.
\m جِّيوْنغْ س ڒفْضِيحثْ،
\m تَّاشِيغْ أَكْ-ذ ڒمْحَاينْ إِنُو.
\m 
\v 16 مَاڒَا سّْڭعّْذغْ إِخفْ إِنُو،
\m أَذْ أَيِي ثْنيْمَارذْ أَمْ وَايْرَاذْ إِزهَّارنْ،
\m \add ڒبْذَا\add* ثتّْنقْڒَابذْ خَافِي س ڒْغفْڒثْ. \x ◘ \xo 10:‏16 \xt إِشا. 38‏:‏13؛ إِڭجذ. 3‏:‏10\x*
\m 
\v 17 معْلِيكْ ؤُفِيغْ أَذْ خَافِي ثسّْبدّذْ \add ڒبْذَا\add*
\m إِشهَّاذنْ نّغْنِي،
\m أَذْ ثَارْنِيذْ عَاذْ ذڭْ وغْضَابْ نّشْ خَافِي،
\m إِعسَّاسنْ إِ إِخدْجْفنْ \add إِجّْ إِ ونّغْنِي\add* ڒبْذَا،
\m \add وَاهْ،\add* أَذْ غَارِي \add ثْنذْهذْ\add* إِجّْ ن ڒْعسْكَارْ.
\b
\m 
\v 18 مَايمِّي ذ أَيِي ثجِّيذْ أَذْ د-فّْغغْ
\m زڭْ ؤُعذِّيسْ ن يمَّا؟
\m مْڒِي سُّوفّْغغْ بُوحْبڒْ،
\m وَارْ ذ أَيِي ثْژَارْ ؤُڒَا ذ إِشْثْ ن ثِيطّْ!‘ \x ◘ \xo 10:‏18 \xt أَيُوبْ 3‏:‏11\x*
\m 
\v 19 معْلِيكْ ؤُفِيغْ أَخْمِي وَارْ إِڒِيغْعمَّارْصْ،
\m مّكْسِيغْ غَارْ ونْضڒْ
\m زڭْ ؤُعذِّيسْ \add ن يمَّا\add*.
\m 
\v 20 مَا وَارْ دْجِينْ وُوسَّانْ \add ن ثُوذَارْثْ\add* إِنُو ؤُذْرُوسنْ؟
\m مْڒِي ذ أَيِي إِجَّا، أَذْ خَافِي إِنّقْڒبْ
\m مَاحنْذْ أَذْ فَارْهغْ شْوَايْثْ \add عَاوذْ\add*،
\m 
\v 21 قْبڒْ إِ غَا ؤُيُورغْ - وَارْ ذِيكّْوِيڒغْ \add عَاذْ\add* -
\m غَارْ ثمُّورْثْ ن ثَادْجسْثْ ذ ثِيڒِي ن ڒْموْثْ،
\m 
\v 22 \add غَارْ\add* ثمُّورْثْ ذ ثَابَارْشَانْثْ أَمْ ثْمذِّيثْ،
\m \add أَمْ\add* ثِيڒِي ن ڒْموْثْ، وَارْ \add ذِينْ\add* إِتّْبِينْ وَالُو،
\m مَانِي ثڭَّا ثْفَاوْثْ أَمْ ثْمذِّيثْ.
\b
\b
\c 11
\s1 ڒْهَارْدْ أَمزْوَارُو ن صُوفَارْ
\m 
\v 1 \add خنِّي\add* يَارَّا-د \bd صُوفَارْ\bd*، ونِّي د-يُوسِينْ زِي نَاعْمَا، إِنَّا:
\b
\m 
\v 2 مَا أَذْ قِّيمنْ وَاطَّاسْ ن وَاوَاڒنْ
\m بْڒَا ثَامْوَارِّيثْ،
\m ؤُ مَا أَذْ غَارسْ يِيڒِي
\m إِ يِيجّْ ن بُو-ؤُقمُّومْ ڒْحقّْ \add ڒبْذَا\add*؟
\m 
\v 3 مَا إِزمَّارْ ڒْهَارْذْ نّشْ
\m أَذْ إِسّْغذْ إِوْذَانْ،
\m \add أَڒَامِي\add* \add ثْزمَّارذْ\add* أَذْ ثسْثهْزِيذْ
\m بْڒَا شكْ إِ غَا إِسّحْشمْ ؤُڒَا ذ إِجّْ؟
\m 
\v 4 شكْ ثنِّيذْ: ’ثصْفَا ثْغُورِي إِنُو،
\m أَقَا أَيِي ذ أَمزْذَاڭْ ذِي ثِيطَّاوِينْ نّشْ!‘
\m 
\v 5 ؤُهْ، مْڒِي أَربِّي \add سِيمَانْثْ نّسْ\add* إِسَّاوَاڒْ،
\m مْڒِي يَارزّمْ إِينْشِيشنْ نّسْ قِيبَاتْشْ نّشْ.
\m 
\v 6 مْڒِي نتَّا ذ أَشْ إِ غَا إِسّْشنْ
\m ثِيمسْڒَايِينْ إِخمّْڒنْ ن ثِيغِيثْ،
\m مَاغَارْ نِيثنْثِي سكّْوَانْثْ دُّوبلْ إِ ؤُفكِّي.
\m سّنْ، أَقَا أَربِّي
\m أَذْ إِتُّو أَطَّاسْ ن ڒْمُوعْصِييّثْ نّشْ
\m ذِي ثِيزِي نّشْ.
\b
\m 
\v 7 مَا ثْزمَّارذْ أَذْ ثْبقّْشذْ
\m ذِي مُومُّو ن أَربِّي؟
\m مَا ثْزمَّارذْ أَذْ ثَاذْفذْ
\m غَارْ ڒكْمَارثْ ن ؤُمْزمَّارْ خْ كُوڒْشِي؟
\m 
\v 8 \add أَقَا-ثنْ\add* ذِي ڒُوعْڒَاثْ ن ؤُجنَّا!
\m مِينْ ثخْسذْ أَذْ ثڭّذْ \add عَاذْ\add*؟
\m \add ثِيغِيثْ\add* ثُودْجغْ خْ ڒَاخَارْثْ!
\m مِينْ ثْزمَّارذْ أَذْ \add زَّايسْ\add* ثسّْنذْ؟
\m 
\v 9 ڒعْبَارْ نّسْ يُوعْڒَا أَطَّاسْ خْ ثمُّورْثْ،
\m ثِيرُو نّسْ \add ثعْذُو أَطَّاسْ\add* خْ ثْمِيرِيوْثْ ن ڒبْحَارْ.
\b
\m 
\v 10 مَاڒَا إِعْذُو نتَّا، إِبلّعْ \add خْ شَا ن يِيجّنْ\add*
\m ؤُشَا إِڒَاغَا \add أَسْ\add* إِ دّعْوثْ،
\m مَانْ ونْ إِ ث غَا إِسّْبدّنْ؟
\m 
\v 11 مَاغَارْ نتَّا إِسّنْ إِغشَّاشنْ،
\m إِتّْوَاڒَا ڒْغشّْ بْڒَا مَا ث إِحْضَا. \x ◘ \xo 11:‏11 \xt إِزهد. 10‏:‏11، 14؛ 35‏:‏22\x*
\m 
\v 12 \add مَاشَا مَاڒَا\add* أَبُوهَاڒِي
\m \add إِزمَّارْ\add* أَذْ يَافْ ڒفْهَامثْ،
\m \add خنِّي\add* أَغْيُوڒْ ن ڒخْڒَا \add إِزمَّارْ\add*
\m أَذْ إِذْوڒْ ذ بْنَاذمْ. \x ◘ \xo 11:‏12 \xt أَيُوبْ 5‏:‏8؛ 22‏:‏21؛ أَمب. 3‏:‏18\x*
\b
\m 
\v 13 مَاڒَا شكْ ثْعذْڒذْ ؤُڒْ نّشْ،
\m \add خنِّي\add* بزّعْ إِفَاسّنْ نّشْ غَارسْ.
\m 
\v 14 مَاڒَا إِرْصقْ ڒْغشّْ غَارْ ؤُفُوسْ نّشْ،
\m سَاڭّْوجْ إِ-ث،
\m وَارْ تّجِّي دّدْجْ أَذْ إِزْذغْ ذِي ثْقِيذُونِينْ نّشْ،
\m 
\v 15 مَاغَارْ خنِّي ثْزمَّارذْ
\m أَذْ ثسّْڭعّْذذْ ؤُذمْ نّشْ بْڒَا ڒْعِيبْ،
\m أَذْ ثْبدّذْ نِيشَانْ، وَارْ تّڭّْوذذْ شَا.
\b
\m 
\v 16 مَاغَارْ أَذْ ثتُّوذْ ڒغْبنْ نّشْ،
\m \add عمَّارْصْ وَارْ\add* ذَايسْ ثتّْخمِّيمذْ \add عَاذْ\add*
\m أَمْ \add عمَّارْصْ وَارْ ثتّْخمِّيمذْ عَاذْ\add*
\m غَارْ وَامَانْ إِعْذُونْ.
\m 
\v 17 أَبْرِيذْ ن ثُوذَارْثْ نّشْ أَذْ يَارْغْ
\m ثِيوَا خْ طّْحَا ن ؤُزِيڒْ،
\m وَاخَّا ذِينْ ثَادْجسْثْ،
\m أَذْ ثِيڒِي أَمْ ثفُّوثْ. \x ◘ \xo 11:‏17 \xt إِزهد. 37‏:‏6؛ 112‏:‏4\x*
\m 
\v 18 أَذْ ثَاشِيذْ إِخفْ نّشْ ذِي ڒَامَانْ،
\m مِينْزِي أَقَا ذِينْ ڒَايَاسْ،
\m أَذْ ثخْزَارذْ \add ذڭْ ونّضْ\add*،
\m أَذْ ثطّْصذْ ذِي ڒْهُوذْنثْ. \x ◘ \xo 11:‏18 \xt لَاوِي 26‏:‏5\x*
\m 
\v 19 أَذْ ثزّْڒذْ نْهْڒَا \add شكْ\add* إِسّْنخْڒعْ ؤُڒَا ذ إِجّْ،
\m ؤُشَا أَطَّاسْ إِ شكْ إِ غَا زَاوْڭنْ
\m زَّاثْ إِ وُوذمْ نّشْ. \x ◘ \xo 11:‏19 \xt لَاوِي 26‏:‏6؛ إِزهد. 3‏:‏6؛ 4‏:‏9؛ أَوڒن. 3‏:‏24\x*
\m 
\v 20 \add مَاشَا\add* ثِيطَّاوِينْ ن إِعفَّاننْ
\m أَذْ دَّارْغْڒنْثْ،
\m قَاعْ ثَاروْڒَا أَذْ أَسنْ ثْودَّارْ،
\m أَذْ مژْرنْ أَذْ ذڒْقنْ إِ بُوحْبڒْ. \x ◘ \xo 11:‏20 \xt أَيُوبْ 8‏:‏13، 14؛ 18‏:‏14\x*
\b
\b
\c 12
\s1 ثَامْوَارِّيثْ ن أَيُوبْ خْ صُوفَارْ
\m 
\v 1 يَارَّا-د \bd أَيُوبْ\bd*، إِنَّا:
\b
\m 
\v 2 ذ ثِيذتّْ، كنِّيوْ ذ إِجّْ ن دَّارْبْ ن ڒْڭنْسْ،
\m أَقَا ثِيغِيثْ أَذْ ثمّثْ أَكِيذْومْ!
\m 
\v 3 نشّْ غَارِي ڒعْقڒْ أَمْ كنِّيوْ،
\m نشّْ وَارْ وطِّيغْ ذڭْ ؤُمْقُوذِّي أَكِيذْومْ.
\m وِي وَارْ إِسِّيننْ \add مَارَّا\add* أَيَا؟
\b
\m 
\v 4 نشّْ أَمْ ونِّي إِدْجَانْ إِ ثْسضْحَاشْ
\m إِ ؤُمدُّوكّڒْ نّسْ،
\m \add نشّْ\add* ذ ونِّي ثُوغَا إِتّْڒَاغَانْ غَارْ أَربِّي
\m ؤُشَا \add خنِّي\add* نتَّا إِسْڒَا غَارِي،
\m \add نشّْ\add* ذ أَمْسڭّذْ ذ نِيشَانْ،
\m أَقَا ذوْڒغْ ذ ڒْقشْعثْ ن ثْسضْحَاشْثْ. \x ◘ \xo 12:‏4 \xt أَيُوبْ 16‏:‏10؛ 17‏:‏2؛ 21‏:‏3؛ 30‏:‏1؛ أَوڒن. 14‏:‏2 \x*
\m 
\v 5 ’ڒْْحڭْرَا ذ ثَاسْغَارْثْ ن ونِّي إِتّْوَارْژَانْ!‘،
\m أَمُّو إِ إِتّْخَارَّاصنْ يِينِّي
\m ؤُمِي إِتّْغِيڒْ أَقَا أَثنْ ذِي ڒَامَانْ،
\m \add إِتّْغِيڒْ أَسنْ\add* أَيَا إِتّْرَاجَا
\m إِنِّي إِتّْنقْرَاضنْ ذڭْ إِضَارنْ \add نْسنْ\add*.
\m 
\v 6 إِقِيضَانْ ن إِمْثحَّايّنْ أَرْسَانْ،
\m ؤُ إِنِّي إِسعَّارنْ أَربِّي
\m غَارْسنْ أَطَّاسْ ن ڒَامَانْ.
\m \add مَاشَا\add* وِي إِزمَّارنْ
\m أَذْ يَاوِي أَربِّي س ؤُفُوسْ نّسْ؟ \x ◘ \xo 12:‏6 \xt أَيُوبْ 21‏:‏7؛ إِزهد. 73‏:‏11، 12؛ إِرْم. 12‏:‏1؛ حَاب. 1‏:‏3، 4\x*
\b
\m 
\v 7 سقْسَا خنِّي ڒْمَاڒْ،
\m أَذْ أَشْ \add ث\add* سّْڒمْذنْ،
\m إِجْضَاضْ ن ؤُجنَّا أَذْ شكْ \add ث\add* حَاجَانْ.
\m 
\v 8 نِيغْ خزَّارغْ مْلِيحْ غَارْ ثمُّورْثْ،
\m نتَّاثْ أَذْ شكْ ثسّْغَارْ،
\m ؤُڒَا ذ إِسڒْمَانْ ن ڒبْحَارْ
\m أَذْ أَشْ \add ث\add* عَاوْذنْ.
\m 
\v 9 مَانْ ونْ وَارْ إِسِّيننْ مَارَّا أَيَا،
\m أَقَا أَفُوسْ ن سِيذِي إِ ث إِڭِّينْ؟
\m 
\v 10 نتَّا ذ ونِّي ذڭْ ؤُفُوسْ نّسْ إِدْجَا
\m ڒعْمَارْ ن مَارَّا مِينْ إِدَّارنْ،
\m ؤُڒَا ذ بُوحْبڒْ ن كُوڒْ أَرِّيمثْ ن بْنَاذمْ.
\b
\m 
\v 11 مَا وَارْ إِتّْقدْجِيبْ ؤُمزُّوغْ أَوَاڒنْ،
\m أَمْ إِتّْقَاسَا وَانغْ مَاشَّا؟ \x ◘ \xo 12:‏11 \xt أَيُوبْ 6‏:‏30؛ 34‏:‏3\x*
\m 
\v 12 غَارْ إِوسُّورَا \add إِ ثدْجَا\add* ثِيغِيثْ
\m ؤُ ذِي ثُوذَارْثْ ثَازِيرَارْثْ \add ثدْجَا\add* ڒفْهَامثْ؟
\m 
\v 13 نتَّا غَارسْ \add إِ ثدْجَا\add* ثِيغِيثْ ذ جّهْذْ \add س ثِيذتّْ\add*،
\m نتَّا غَارسْ \add إِ يدْجَا\add*
\m شّْوَارْ ذ ڒفْهَامثْ \add نِيشَانْ\add*.
\b
\m 
\v 14 خْزَارْ، \add مَاڒَا\add* نتَّا إِهدّمْ،
\m وَارْ إِبنِّي ؤُڒَا ذ إِجّْ \add عَاوذْ\add*،
\m مَاڒَا نتَّا إِبلّعْ خْ شَا ن يِيجّنْ،
\m وَارْ ذ أَسْ يَارزّمْ عَاذْ. \x ◘ \xo 12:‏14 \xt أَيُوبْ 9‏:‏12؛ 11‏:‏10؛ أَسَا. 3‏:‏7\x*
\m 
\v 15 خْزَارْ، مَاڒَا نتَّا إِسّْبدّْ أَمَانْ،
\m أَذْ أَژْغنْ نِيثْنِي،
\m مَاڒَا يَارْخُو أَسنْ،
\m أَذْ سّنْقڒْبنْ ثَامُّورْثْ.
\m 
\v 16 نتَّا غَارسْ جّهْذْ ذ ؤُفكِّي،
\m نّسْ ذ ونِّي إِودَّارنْ
\m ؤُڒَا ذ ونِّي إِسّْودَّارنْ.
\b
\m 
\v 17 نتَّا إِتّجَّا إِرْيَازنْ ن شّْوَارْ
\m ڭُّورنْ س ڒحْفَا،
\m ڒْْقُوضَاثْ إِتَّارَّا إِ-ثنْ ذ إِبُوهَاڒِييّنْ. \x ◘ \xo 12:‏17 \xt 2 صم. 15‏:‏31؛ 17‏:‏14، 23؛ إِشا. 19‏:‏12؛ 29‏:‏14؛ 1 كُور. 1‏:‏19\x*
\m 
\v 18 أَزِييَّارْ ن إِجدْجِيذنْ إِسّْبطّڒْ إِ-ث
\m ؤُ \add خنِّي\add* نتَّا إِتّْشدَّا إِ-ثنْ
\m س إِجّْ ن وبْيَاسْ زِي ثجْعِينَّا نْسنْ.
\m 
\v 19 نتَّا إِندّهْ إِكهَّاننْ س ڒحْفَا،
\m أَيْثْ ن جّهْذْ إِغطّرْ إِ-ثنْ.
\m 
\v 20 إِتّكّسْ أَوَاڒْ إِ إِرْيَازنْ إِتّْوَاقدْجْبنْ،
\m إِ إِوسُّورَا إِتّكّسْ أَسنْ ڒفْهَامثْ. \x ◘ \xo 12:‏20 \xt أَيُوبْ 32‏:‏9؛ إِشا. 3‏:‏2، 3\x*
\m 
\v 21 أَسحْقَارْ إِتّْزدْجَاعْ إِ-ث خْ ثَارْوَا ن ثَاصِيڒثْ،
\m إِ أَيْثْ ن بُو-ڒخْشُونثْ إِسَّارخُّو أَسنْ أَبْيَاسْ. \x ◘ \xo 12:‏21 \xt إِزهد. 107‏:‏40\x*
\b
\m 
\v 22 إِمُوشَانْ يُودْجْغنْ ن ثَادْجسْثْ إِتّْعَارَّا خَاسنْ،
\m ذ ثِيڒِي ن ڒْموْثْ إِسُّوفُّوغْ إِ-ت غَارْ ثْفَاوْثْ. \x ◘ \xo 12:‏22 \xt مت. 10‏:‏26؛ 1 كُور. 4‏:‏5\x*
\m 
\v 23 ڒڭْنُوسْ إِسّمْغَارْ إِ-ثنْ ؤُشَا إِغطّرْ إِ-ثنْ،
\m نتَّا إِتّْبزَّاعْ ڒڭْنُوسْ ؤُشَا إِندّحْ إِ-ثنْ.\x ◘ \xo 12:‏23 \xt إِزهد. 107‏:‏38\x*
\m 
\v 24 إِتّكّسْ ڒفْهَامثْ
\m إِ إِزدْجِيفنْ ن ڒْڭنْسْ خْ ثمُّورْثْ،
\m إِجَّا إِ-ثنْ تّثْلِيعنْ ذِي ڒخْڒَا
\m مَانِي وَارْ \add دْجِينْ\add* إِبْرِيذْ\add أنْ\add*. \x ◘ \xo 12:‏24 \xt إِزهد. 107‏:‏4، 40\x*
\m 
\v 25 نِيثْنِي تّمْهَافَانْ ذَا ذ ذِيهَا ذِي ثَادْجسْثْ،
\m مَانِي وَارْ ثدْجِي ثْفَاوْثْ،
\m نتَّا إِتّجَّا إِ-ثنْ
\m أَذْ مّْهَافَانْ أَمْ يِيمسْشَارْ\add أنْ\add*.
\b
\b
\c 13
\s1 أَيُوبْ يَارنِّي ذڭْ وَاوَاڒْ نّسْ إِ صُوفَارْ
\m 
\v 1 خْزَارْ، قَاعْ مَانْ أَيَا ثژْرَا إِ-ث ثِيطّْ إِنُو،
\m إِسْڒَا إِ-ث ؤُمزُّوغْ إِنُو، إِفْهمْ أَسْ مْلِيحْ.
\m 
\v 2 مِينْ ثسّْنمْ كنِّيوْ،
\m سّْنغْ ث ؤُڒَا ذ نشّْ،
\m وَارْ وطِّيغْ شَا ذڭْ ؤُسمْقُوذِّي أَكِيذْومْ.
\b
\m 
\v 3 مَاشَا نشّْ خْسغْ أَذْ سِّيوْڒغْ
\m غَارْ ؤُمْزمَّارْ خْ كُوڒْشِي،
\m مژْرغْ أَذْ وْثغْ \add ثَامسْڒَاشْثْ إِنُو\add*
\m زَّاثْ إِ أَربِّي.
\m 
\v 4 مَاشَا كنِّيوْ ثسُّوفُّوغمْ إِخَارِّيقنْ،
\m مَارَّا كنِّيوْ ذ إِضْبِيبنْ إِخْوَانْ. \x ◘ \xo 13:‏4 \xt أَيُوبْ 16‏:‏2\x*
\m 
\v 5 أَخْ، مْڒِي ثسّغْذمْ كنِّيوْ مَارَّا!
\m أَيَا أَذْ ثِيڒِي ذ ثِيغِيثْ إِ كنِّيوْ. \x ◘ \xo 13:‏5 \xt أَوڒن. 17‏:‏28\x*
\m 
\v 6 سْڒمْ خنِّي مَامّشْ غَا وْثغْ
\m خْ يِيخفْ إِنُو،
\m حكَّارمْ خْ ؤُمْشَارَّاعْ ن إِينْشِيشنْ إِنُو!
\b
\m 
\v 7 مَا ثخْسمْ أَذْ ثِينِيمْ ڒْغشّْ
\m إِ ڒفْضڒْ ن أَربِّي،
\m \add مَا ثخْسمْ\add* أَذْ ثسِّيوْڒمْ إِخَارِّيقنْ
\m ذِي ثِيزِي نّسْ؟ \x ◘ \xo 13:‏7 \xt أَيُوبْ 17‏:‏5؛ 32‏:‏21؛ 36‏:‏4\x*
\m 
\v 8 مَا ثْزمَّارمْ أَذْ ثوْثمْ ثَامسْڒَاشْثْ
\m ذِي طّْوعْ نّسْ؟
\m مَا \add ثخْسمْ\add* أَذْ ثْشَارّْعمْ إِ أَربِّي؟
\m 
\v 9 مَا مْلِيحْ إِ كنِّيوْ،
\m مَاڒَا نتَّا أَذْ كنِّيوْ إِقدْجبْ؟
\m مَا ثخْسمْ أَذْ زَّايسْ ثسْثهْزَامْ
\m أَمْ مَامّشْ سْثهزَّانْ \add إِوْذَانْ\add*
\m زڭْ إِجّْ ن بْنَاذمْ؟
\m 
\v 10 نتَّا أَذْ كنِّيوْ إِوبّخْ،
\m مَاڒَا كنِّيوْ ثتّڭّمْ
\m س وُوذْمَاونْ س ثْنُوفّْرَا.
\m 
\v 11 مَا وَارْ كنِّيوْ إِسّْنخْڒِيعْ ؤُعُودْجِي نّسْ،
\m مَا وَارْ د خَاومْ ثْوطِّي ثِيڭّْوُوذِي زَّايسْ؟
\b
\m 
\v 12 أَوَاڒنْ نْومْ إِ ڒِيذَارثْ
\m أَقَا أَثنْ ذ ڒمْثُوڒْ نْ وَالُو،
\m ڒڭْعُوذِي نْومْ ذ ڒڭْعُوذِي ن ؤُبدْجَاعْ.
\m 
\v 13 سغْذمْ زَّاثِي، مَاحنْذْ أَذْ سِّيوْڒغْ،
\m أجّْ أَذْ خَافِي د-يَاسْ مِينْ \add إِ د غَا يَاسْ\add*.
\m 
\v 14 مَايمِّي غَا طّْفغْ أَيْسُومْ \add ن أَرِّيمثْ\add* إِنُو
\m جَارْ ثغْمَاسْ إِنُو،
\m \add مَايمِّي إِ\add* غَا طّْفغْ ثُوذَارْثْ إِنُو
\m ذڭْ ؤُفُوسْ إِنُو؟
\m 
\v 15 خْزَارْ، نتَّا إِخْسْ أَذْ أَيِي إِنغْ،
\m نشّْ أَذْ ث رَاجِيغْ،
\m \add مَاشَا\add* أَذْ وْثغْ خْ إِبْرِيذنْ إِنُو زَّاثسْ. \x ◘ \xo 13:‏15 \xt إِزهد. 23‏:‏4؛ أَوڒن. 14‏:‏32\x*
\m 
\v 16 ذ وَا إِ ذ أَيِي غَا إِذْوڒْ ذ أَسنْجمْ إِنُو،
\m مَاشَا أَمْنَافقْ وَارْ د-إِتِّيسْ
\m زَّاثْ إِ ؤُغمْبُوبْ نّسْ. \f ◼ \fr 13:‏16 \ft \bd ’أَمْنَافقْ‘\bd* - بْنَاذمْ نِّي إِتّڭّنْ س ثْنَاينْ ن وُوذْمَاونْ.\f*
\b
\m 
\v 17 سْڒمْ مْلِيحْ غَارْ ڒْهَارْذْ إِنُو،
\m س إِمزُّوغنْ \add يَارزْمنْ\add* غَارْ ؤُشَارّحْ إِنُو.
\m 
\v 18 خْزَارْ، نشّْ إِوْيغْ دّعْوثْ س ؤُستّفْ،
\m سّْنغْ أَذْ تّْوَاسڭّْذغْ.
\m 
\v 19 مَانْ ونْ \add إِزمَّارنْ\add* أَذْ كِيذِي إِمْشَارّْعنْ؟
\m خنِّي أَذْ سغْذغْ ذغْيَا،
\m أَذْ سُّوفّْغغْ بُوحْبڒْ.
\b
\m 
\v 20 مْغِيرْ وَارْ ذ أَيِي تّڭّْ ثْنَاينْ ن ڒحْوَايجْ،
\m خنِّي وَارْ زَّايكْ تّْنُوفَّارِيغْ: \x ◘ \xo 13:‏20 \xt أَيُوبْ 9‏:‏34؛ 33‏:‏7\x*
\m 
\v 21 أَفُوسْ نّشْ سِيڭّْوجْ إِ-ث خَافِي،
\m وَارْ ذ أَيِي سْنخْڒِيعْ س ؤُهُوذِّي نّشْ!
\m 
\v 22 ڒَاغَا \add شكْ\add*، نشّْ أَذْ \add خَاكْ\add* د-أَرّغْ،
\m نِيغْ نشّْ أَذْ سِّيوْڒغْ
\m ؤُ شكْ أَذْ خَافِي د-ثَارّذْ!
\b
\m 
\v 23 مشْحَاڒْ خَافِي ن ڒْمُوعْصِييّثْ ذ دّنْبْ؟
\m سْشنْ أَيِي أَخطُّو إِنُو ذ دّنْبْ إِنُو.
\m 
\v 24 مَايمِّي ثسّْنُوفَّارذْ أَغمْبُوبْ نّشْ،
\m ثْحسّْبذْ أَيِي ذ ڒعْذُو نّشْ؟ \x ◘ \xo 13:‏24 \xt أَيُوبْ 16‏:‏9؛ 19‏:‏11؛ 33‏:‏10؛ إِڭجذ. 2‏:‏5\x*
\m 
\v 25 مَا ثخْسذْ أَذْ ثسّنْخڒْعذْ
\m ثَافَارْشْثْ إِ إِعَارّنْ ؤُسمِّيضْ سَّا غَارْ ذَا،
\m مَا ثخْسذْ أَذْ ثضْفَارذْ إِغدْجْ يُوژْغنْ؟
\b
\m 
\v 26 مَاغَارْ ثتَّارِيذْ خَافِي
\m ثِيمسْڒَايِينْ ثِيمَارْزَاڭِينْ،
\m ثْبطِّيذْ أَيِي دّْنُوبْ ن ثمْژِي إِنُو. \x ◘ \xo 13:‏26 \xt إِزهد. 25‏:‏7\x*
\m 
\v 27 ثسّْرُوسِيذْ إِضَارنْ إِنُو ذڭْ ؤُكشُّوضْ،
\m شكْ ثْحطِّيذْ مَارَّا إِمسْرَاقْ إِنُو.
\m ثْحطِّيذْ ثِيڒقَّا ن إِضَارنْ إِنُو، \x ◘ \xo 13:‏27 \xt أَيُوبْ 33‏:‏11\x*
\m 
\v 28 ن ونِّي إِڭِّينْ أَمْ ؤُكشُّوضْ،
\m شِّينْ ث إِكشَّاونْ، \add خنِّي\add* يَارشَّا،
\m أَمْ وَارُّوضْ إِشَّا إِ-ث ثْشِينْذَا.
\b
\b
\c 14
\s1 أَيُوبْ إِسِّيوڒْ أَكْ-ذ صُوفَارْ خْ ڒْموْثْ
\m 
\v 1 بْنَاذمْ إِ د-إِتّْوَاخڒْقنْ
\m زِي ثمْغَارْثْ،
\m أَقَا ؤُسَّانْ \add ن ثُوذَارْثْ\add* نّسْ ؤُذْرُوسنْ
\m ؤُ نتَّا إِشُّورْ س ڒحْوڒْ. \x ◘ \xo 14:‏1 \xt إِزهد. 90‏:‏5، 6، 9؛ 102‏:‏12؛ 103‏:‏15؛ 144‏:‏4؛ يَاع. 4‏:‏14\x*
\m 
\v 2 نتَّا إِغمِّي أَمْ ثْنوَّاشْثْ،
\m خنِّي إِتّْوَاقْضعْ.
\m إِتّْرَاكّْوَاڒْ أَمْ ثِيڒِي، وَارْ إِتّْغِيمِي. \x ◘ \xo 14:‏2 \xt أَيُوبْ 8‏:‏9؛ إِزهد. 90‏:‏6، 10؛ 102‏:‏12؛ 103‏:‏15؛ 144‏:‏4؛ إِشا. 40‏:‏6؛ 1 بُط. 1‏:‏24\x*
\m 
\v 3 وَاخَّا أَمنِّي ثَارزْمذْ
\m ثِيوَا نّسْ ثِيطَّاوِينْ نّشْ،
\m ثتَّاوْيذْ أَيِي-د ذِي دّعْوثْ أَكِيذكْ. \x ◘ \xo 14:‏3 \xt أَيُوبْ 7‏:‏17، 18؛ 10‏:‏20\x*
\b
\m 
\v 4 مَانْ ونْ إِزمَّارنْ أَذْ إِسُّوفّغْ
\m إِجّْ ن ؤُمزْذَاڭْ زڭْ ؤُمخْمُوجْ؟
\m ؤُڒَا ذ إِجّْ! \x ◘ \xo 14:‏4 \xt أَمز. 5‏:‏3؛ إِزهد. 51‏:‏7؛ يُوح. 3‏:‏6؛ رُوم. 5‏:‏12؛ أَفا. 2‏:‏3\x*
\m 
\v 5 مَارَا ؤُسَّانْ نّسْ ؤُرِينْ،
\m ڒْْقدّْ ن إِيُورنْ نّسْ \add أَقَا إِتّْوَاسّنْ\add* غَاركْ
\m ؤُشَا ثڭِّيذْ أَسْ ڒحْذُوذْ نّسْ
\m نِّي وَارْ ذ أَسْ إِعدّڒْ أَذْ ثنْ إِعْذُو، \x ◘ \xo 14:‏5 \xt أَيُوبْ 7‏:‏1\x*
\m 
\v 6 نقْڒبْ \add خنِّي\add* خَاسْ مَاحنْذْ أَذْ يَاريّحْ،
\m أَڒَامِي إِزمَّارْ أَذْ يَارّْ مژْرِي
\m أَمْ يِيجّْ ن ؤُشوَّاڒْ ذڭْ وَاسّْ نّسْ. \x ◘ \xo 14:‏6 \xt أَيُوبْ 7‏:‏1، 2، 16، 19؛ 10‏:‏20\x*
\b
\m 
\v 7 مَاغَارْ إِ ثْشجَّارْثْ أَقَا ذِينْ عَاذْ ڒَايَاسْ!
\m مَاڒَا ثتّْوَاقسّْ،
\m أَذْ ثسُّوفّغْ عَاوذْ \add ڒفْرُوعْ\add*،
\m ڒفْرُوعْ نّسْ وَارْ تّْبذِّينْ زڭْ ؤُغمِّي.
\m 
\v 8 وَاخَّا إِوْسَارْ وژْوَارْ نّسْ ذِي ثمُّورْثْ،
\m إِمُّوثْ جّْذعْ نّسْ ذڭْ ؤُشَاڒْ،
\m 
\v 9 أَذْ ثغْمِي ثْشجَّارْثْ \add عَاوذْ\add*
\m خْمِي غَا ثَاشَا أَكْ-ذ وَامَانْ،
\m أَذْ ثسُّوفّغْ \add عَاوذْ\add* ڒفْرُوعْ
\m أَمْ إِشْثْ ن ثْشجَّارْثْ ژُّونْ ت بحْڒَا.
\b
\m 
\v 10 \add مَاشَا مَاڒَا\add* إِمُّوثْ إِجّْ ن ورْيَازْ، إِفنَّا،
\m \add مَاڒَا\add* إِفّغْ أَسْ بُوحْبڒْ إِ بْنَاذمْ،
\m مَانِي إِدْجَا خنِّي؟
\m 
\v 11 أَمَانْ تّفّْغنْ-د زِي ڒبْحَارْ،
\m إِغْزَارْ إِتَّاژغْ ؤُ إِخكّْوَا.
\m 
\v 12 إِزّڒْ بْنَاذمْ ذِينْ، وَارْ إِتّكَّارْ عَاذْ.
\m أَڒْ وَارْ تِّيڒِينْ عَاذْ إِجنْوَانْ، وَارْ ذ تّْفِيقِينْ،
\m وَارْ تّْوَاسّكَّارنْ زڭْ إِضصْ نْسنْ.
\b
\m 
\v 13 أَخْ، مْڒِي ذ أَيِي غَا ثَارّذْ غَارْ ڒَاخَارْثْ،
\m أَذْ أَيِي ثسّْنُوفَّارذْ
\m أَڒْ غَا إِحيّذْ وغْضَابْ نّشْ،
\m مْڒِي ذ أَيِي ثُورِيذْ إِجّْ ن ڒْمِيجَاڒْ إِمْثنْ،
\m \add حِيمَا\add* أَذْ أَيِي ثِيذَارذْ \add عَاوذْ\add*!
\m 
\v 14 مَاڒَا إِجّْ ن ورْيَازْ إِمُّوثْ،
\m مَا أَذْ د-إِذْوڒْ غَارْ ثُوذَارْثْ؟
\m \add خنِّي\add* أَذْ قِّيمغْ تّْرَاجِيغْ
\m مَارَّا ؤُسَّانْ ن ؤُمنْغِي إِنُو،
\m أَڒْ د-يُوسَا ؤُفكِّي إِنُو.
\m 
\v 15 مَاڒَا \add خنِّي\add* شكْ ثْڒَاغِيذْ،
\m نشّْ أَذْ شكْ د-أَرّغْ
\m ؤُشَا شكْ أَذْ ثمّژْڒذْ
\m غَارْ ڒْخذْمثْ ن إِفَاسّنْ نّشْ.
\m 
\v 16 مَاشَا ڒخُّو ثْحسّْبذْ إِصُورَافْ إِنُو،
\m وَارْ ثْمنّْعذْ \add لْغَاضَابْ نّشْ\add* خْ دّْنُوبْ إِنُو. \x ◘ \xo 14:‏16 \xt أَيُوبْ 31‏:‏4؛ 34‏:‏21؛ إِزهد. 56‏:‏9؛ 139‏:‏2، 3، 4؛ أَوڒن. 5‏:‏21؛ إِرْم. 32‏:‏19\x*
\b
\m 
\v 17 أَخطُّو إِنُو إِتّْوَاشمّعْ ذِي ثْشمُّوسْثْ،
\m غَارْ ڒْمُوعْصِييّثْ إِنُو ثَارْنِيذْ \add ذَايسْ\add* كْثَارْ.
\m 
\v 18 وَاهْ، أَذْرَارْ إِوطَّانْ، إِفسِّي،
\m جَارْفْ إِحْرُودْجذْ زڭْ ومْشَانْ نّسْ،
\m 
\v 19 أَمَانْ تّدّْزنْ إِژْرَا،
\m إِغزْرَانْ نّسْ تّكّْسنْ أَشَاڒْ ن ثمُّورْثْ،
\m أَمُّو إِ ثَاردّْدْجذْ ڒَايَاسْ ن بْنَاذمْ.
\b
\m 
\v 20 شكْ ثَارنِّيذْ ذَايسْ إِ ڒبْذَا، \add خنِّي\add* يُويُورْ.
\m ثتّْبدَّاڒذْ ؤُذمْ نّسْ
\m ؤُشَا ثسّكّذْ إِ-ث.
\m 
\v 21 \add مَاڒَا\add* إِحنْجِيرنْ نّسْ طّْفنْ شَّانْ،
\m نتَّا وَارْ ث إِسِّينْ،
\m \add مَاڒَا\add* ثنْ ذدْجنْ،
\m وَارْ كِيذْسنْ إِتِّيشِي.
\m 
\v 22 مَاشَا أَرِّيمثْ نّسْ ثتّْنزْبَارْ
\m ذِي طّْوعْ ن يِيخفْ نّسْ \add وَاهَا\add*،
\m ؤُ ڒعْمَارْ نّسْ إِتّشْضِينْ
\m ذِي طّْوعْ نّسْ.
\b
\b
\c 15
\s1 ڒْهَارْدْ وِيسّْ ثْنَاينْ ن إِلِيفَازْ خْ ؤُعفَّانْ
\m 
\v 1 \add خنِّي\add* يَارَّا-د \bd إِلِيفَازْ\bd*، ونِّي د-يُوسِينْ زِي ثَايْمَانْ، إِنَّا:
\b
\m 
\v 2 مَا إِتَّارَّا-د إِجّْ ن ؤُمِيغِيسْ س ثُوسّْنَا إِخْوَانْ؟
\m مَا أَذْ إِشُّورْ أَعذِّيسْ نّسْ س ؤُسمِّيضْ
\m إِ د-إِتَّاسنْ زِي مَانِيسْ د-ثْنقَّارْ ثْفُوشْثْ؟
\m 
\v 3 مَا إِتّْشَارَّاعْ س ڒْهَارْذْ وَارْ إِنفّْعنْ،
\m س وَاوَاڒنْ نِّي وَارْ إِتَّاكّْوَاضنْ؟
\m 
\v 4 شكْ ثَارْژِيذْ ثِيڭّْوُوذِي \add ن أَربِّي\add*،
\m ثكّْسذْ ثَاژَادْجِيثْ زَّاثْ إِ وُوذمْ ن أَربِّي.
\m 
\v 5 مَاغَارْ أَقمُّومْ نّشْ إِسَّارْڭبْ
\m ڒْمُوعْصِييّثْ نّشْ،
\m أَقَا إِتّعْجِيبْ أَشْ ڒْهَارْذْ س ثْحْرَايْمشْثْ
\m س يِيڒسْ \add نّشْ\add*.
\m 
\v 6 أَقمُّومْ نّشْ أَذْ شكْ إِحْكمْ،
\m وَارْ إِدْجِي نشّْ،
\m إِينْشِيشنْ نّشْ أَذْ خَاكْ شهْذنْ.
\b
\m 
\v 7 مَا شكْ ذ بْنَاذمْ ذ أَمزْوَارُو
\m نِّي د-إِتّْوَاخڒْقنْ؟
\m نِيغْ ثتّْوَارْوذْ قْبڒْ ثِيوْرِيرِينْ؟
\m 
\v 8 مَا ثسّْحسّذْ إِ وڭْرَاوْ
\m ن إِمْشَاوَارنْ إِمْثِيقَّانْ ن أَربِّي،
\m مَا ثْجبّْذذْ ثِيغِيثْ غَاركْ؟ \x ◘ \xo 15:‏8 \xt رُوم. 11‏:‏34\x*
\m 
\v 9 مِينْ ثسّْنذْ شكْ، نشِّينْ وَارْ ث نسِّينْ؟
\m مِينْ ثْفهّْمذْ شكْ، أَقَا إِنْقصْ غَارْنغْ؟
\m 
\v 10 ؤُڒَا جَارْ أَنغْ ذ أَمْشَايْبُو ذ ؤُوسَّارْ،
\m نِيثْنِي ذ إِمْغَارنْ ذڭْ وُوسَّانْ خْ بَابَاشْ. \x ◘ \xo 15:‏10 \xt أَيُوبْ 32‏:‏7\x*
\b
\m 
\v 11 مَا أَسْفوّجْ ن أَربِّي ذْرُوسْ غَاركْ،
\m نِيغْ إِجّْ ن وَاوَاڒْ سِّيوْڒنْ ث أَكِيذكْ س ثرْغغْ؟
\m 
\v 12 مَايمِّي شكْ إِسّثْلَاعْ وُوڒْ نّشْ،
\m مَايمِّي قدْجْعنْثْ ثِيطَّاوِينْ نّشْ،
\m 
\v 13 أَقَا ثسّْنقْڒَابذْ بُوحْبڒْ نّشْ خْ أَربِّي،
\m \add أَڒَامِي\add* ثسُّوفُّوغذْ \add مَارَّا\add* أَوَاڒنْ نِّي
\m زڭْ ؤُقمُّومْ نّشْ؟
\b
\m 
\v 14 مِينْ إِعْنَا بْنَاذمْ أَقَا نتَّا أَذْ يِيڒِي ذ أَمزْذَاڭْ،
\m \add مِينْ إِعْنَا\add* ونِّي د-إِتّْوَاخڒْقنْ زِي ثمْغَارْثْ،
\m أَقَا نتَّا أَذْ يِيڒِي ذ أَمْسڭّذْ؟ \x ◘ \xo 15:‏14 \xt 1 إِج. 8‏:‏46؛ 2 إِم. 6‏:‏36؛ أَيُوبْ 14‏:‏4؛ إِزهد. 14‏:‏3؛ أَوڒن. 20‏:‏9؛ أَمب. 7‏:‏20؛ 1 يُوح. 1‏:‏8، 10\x*
\m 
\v 15 خْزَارْ، إِمْقدَّاسنْ نّسْ وَارْ خَاسنْ إِتّْشِيڒْ،
\m ؤُڒَا ذ إِجنْوَانْ وَارْ دْجِينْ صْفَانْ ذِي ثِيطَّاوِينْ نّسْ! \x ◘ \xo 15:‏15 \xt أَيُوبْ 4‏:‏18؛ 25‏:‏5\x*
\m 
\v 16 أَهْثَاثْ عَاذْ إِجّْ ن نّْعِي ن بْنَاذمْ
\m ذ بُو-ؤُفسَّاذْ،
\m ونِّي إِسسّنْ مِينْ وَارْ إِحْڒِينْ أَمْ وَامَانْ!
\b
\m 
\v 17 نشّْ خْسغْ أَذْ أَشْ \add ث\add* سّشْنغْ، سڒْ-د غَارِي،
\m \add خنِّي\add* أَذْ عَاوْذغْ مِينْ ژْرِيغْ،
\m 
\v 18 مِينْ عَاوْذنْ إِمِيغِيسنْ،
\m أَمْ وَارْ فَّارنْ \add شَا\add* ن ڒجْذُوذْ نْسنْ.
\m 
\v 19 إِ نِيثْنِي وَاهَا ؤُمِي ثمّوْشْ ثمُّورْثْ،
\m ؤُڒَا ذ إِجّْ ن ڒْبَارَّانِي وَارْ خَاسْ إِعْذُو.
\b
\m 
\v 20 مَارَّا ؤُسَّانْ إِ إِدَّارْ ؤُعفَّانْ،
\m إِمَارّثْ إِخفْ نّسْ،
\m ڒْْقدّْ ن إِسڭّْوُوسَا
\m إِ إِتّْوَاخمّْڒنْ إِ بُو-ڒخْشُونثْ،
\m أَقَا إِنُوفَّارْ خَاسْ.
\m 
\v 21 \add يُوذفْ-د\add* ڒْحسّْ ن إِغُويَّانْ إِسّْنخْڒَاعنْ
\m غَارْ إِمزُّوغنْ نّسْ.
\m \add عَاذْ ذِي ڒْوقْثْ ن\add* ڒهْنَا أَذْ خَاسْ إِوْضَا ؤُمْثحَّايْ. \x ◘ \xo 15:‏21 \xt 1 تس. 5‏:‏3\x*
\m 
\v 22 نتَّا وَارْ إِتّْرِيجِي أَذْ د-إِعْقبْ زِي ثَادْجسْثْ،
\m \add مَاشَا\add* أَقَا نتَّا إِتّْوَاڭّْ إِ سِّيفْ.
\m 
\v 23 نتَّا إِتّمْهَافَا ذَا ذ ذِيهَا خْ وغْرُومْ.
\m ’\add أَ،\add* مَانِي \add إِ يدْجَا\add*؟‘
\m نتَّا إِسّنْ أَقَا إِتّْرَاجَا إِ-ث
\m وَاسّْ ذ أَبَارْشَانْ ذغْيَا. \x ◘ \xo 15:‏23 \xt أَيُوبْ 18‏:‏12؛ إِزهد. 109‏:‏10\x*
\m 
\v 24 ضِّيقثْ ذ ڒحْصَارثْ سَّاڭّْوَاذنْثْ نتَّا،
\m أَرْنِينْثْ إِ-ث أَمْ يِيجّْ ن ؤُجدْجِيذْ
\m إِوْجذْ إِ ؤُمنْغِي.
\b
\m 
\v 25 مَاغَارْ غَارْ أَربِّي
\m إِسّْوِيژَّاضْ نتَّا أَفُوسْ نّسْ،
\m أَكْ-ذ ؤُمْزمَّارْ خْ كُوڒْشِي
\m إِمنّعْ \add ثَاغنَّانْثْ\add* ثَامقّْرَانْثْ. \x ◘ \xo 15:‏25 \xt أَسَا. 13‏:‏5\x*
\m 
\v 26 س يِيرِي إِمحْضنْ إِتَّازّڒْ غَارسْ،
\m \add إِنُّوفْرَارْ\add* غَارْ ضفَّارْ
\m ن ثْسدَّارِييِينْ نْسنْ \add ن ؤُعسْكَارِي\add*
\m س إِبُوطُوننْ إِڭْذَارنْ.
\m 
\v 27 مَاغَارْ إِڒحّفْ إِ ؤُغمْبُوبْ نّسْ س ثَاذُونْثْ،
\m إِڭَّا ثَاذُونْثْ إِ ثجْعِينَّا نّسْ.
\m 
\v 28 إِزدّغْ ذِي ثْندَّامْ إِتّْوَاهذْمنْ،
\m \add ذِي\add* ثُوذْرِينْ وَارْ ذَايْسنْثْ إِزدّغْ
\m \add عَاذْ\add* ؤُڒَا ذ إِجّْ،
\m ثِينِّي يُورَانْ مَاحنْذْ أَذْ ذوْڒنْثْ ذ ڒْخِيرْبَاثْ.
\m 
\v 29 نتَّا وَارْ إِذِّيكّْوِيڒْ ذ بُو-وَاڭْڒَا،
\m أَڭْڒَا نّسْ وَارْ إِتّْغِيمِي،
\m مَاڒَا مِينْ د-إِكْسبْ
\m وَارْ يَارنِّي خْ ثمُّورْثْ.
\m 
\v 30 نتَّا وَارْ إِنجّمْ إِ ثَادْجسْثْ،
\m أَشعَّاڒْ \add ن ثْمسِّي\add* أَذْ يشّْ ڒفْرُوعْ نّسْ،
\m أَذْ إِفْنَا س ڒعْوِينْ ن ؤُقمُّومْ نّسْ.
\b
\m 
\v 31 أجّْ إِ-ث وَارْ إِتّْشِيڒِي خْ ڒْغشّْ،
\m مَاغَارْ \add خنِّي\add* إِ غَا ثِيڒِي
\m ؤُڒَا ذ ڒْمُونثْ نّسْ ذ ڒْغشّْ.
\m 
\v 32 مَاڒَا وَارْ د-يُوسِي \add عَاذْ\add* وَاسّْ نّسْ،
\m أَذْ إِتّْوَاكمّڒْ \add عَاذْ\add*،
\m مَاغَارْ ثَاسطَّا ن ثِينِي نّسْ وَارْ ثْزيْزِيوْ. \x ◘ \xo 15:‏32 \xt أَيُوبْ 22‏:‏16؛ إِزهد. 55‏:‏24\x*
\m 
\v 33 أَذْ إِسّغْضڒْ أَضِيڒْ وَارْ إِسّْنذْينْ نّسْ
\m أَمْ يِيشْثْ ن ثْزَايَارْثْ،
\m أَذْ إِمّنْضَارْ نُّووَارْ نّسْ أَمْ ثْزِيثُونْثْ. \f ◼ \fr 15:‏33 \ft \bd ’نتَّا‘\bd* - إِخْسْ أَذْ يِينِي ’أَربِّي‘.\f*
\m 
\v 34 مَاغَارْ أَبَارُّو ن إِمْنَافْقنْ
\m أَقَا-ث بْڒَا ڒْغِيدْجثْ
\m ؤُ ثِيمسِّي ثتّتّْ إِقِيضَانْ \add إِ إِشُّورنْ\add* س ڒْغشّْ. \f ◼ \fr 15:‏34 \ft \bd ’أَمْنَافقْ‘\bd* - بْنَاذمْ نِّي إِتّڭّنْ س ثْنَاينْ ن وُوذْمَاونْ.\f*
\m 
\v 35 أَقَا أَثنْ س دّيْسثْ زِي ثَامَارَا،
\m تُّورْونْ ڒْغشّْ،
\m ڒخْذعْ أَقَا-ث ذڭْ ؤُعذِّيسْ نْسنْ. \x ◘ \xo 15:‏35 \xt إِزهد. 7‏:‏15؛ إِشا. 59‏:‏4؛ حُوش. 10‏:‏13\x*
\b
\b
\c 16
\s1 أَيُوبْ إِڒَاغَا خْ أَربِّي أَمْ د-إِتَّارَّا خْ إِلِيفَازْ
\m 
\v 1 \add خَاسْ ؤُشَا\add* يَارَّا-د \bd أَيُوبْ\bd*، إِنَّا:
\b
\m 
\v 2 مَانَاوْيَا سْڒِيغْ أَسْ أَطَّاسْ،
\m كنِّيوْ مَارَّا إِذْومْ
\m ثسّْبطّْڒمْ أَيِي أَفوّجْ. \x ◘ \xo 16:‏2 \xt أَيُوبْ 13‏:‏4\x*
\m 
\v 3 مَا أَذْ قْضَانْ وَاوَاڒنْ إِخْوَانْ؟
\m نِيغْ مِينْ شكْ إِعَارّْننْ \add عَاذْ\add*
\m أَذْ د-ثَارّذْ أَوَاڒْ؟
\m 
\v 4 ؤُڒَا ذ نشّْ \add زمَّارغْ\add*
\m أَذْ سِّيوْڒغْ أَمْ كنِّيوْ،
\m مَاڒَا أَقَا كنِّيوْ ذڭْ ومْشَانْ إِنُو.
\m إِڒِي أَذْ مُوذغْ أَوَاڒنْ خَاومْ
\m ؤُ أَذْ خَاومْ هزّغْ أَزدْجِيفْ إِنُو.
\m 
\v 5 أَذْ كنِّيوْ سّْمحْضغْ س ؤُقمُّومْ إِنُو
\m ؤُ أَفوّجْ ن إِينْشِيشنْ إِنُو
\m أَذْ أَومْ يَاوِي ڒفْسَاسثْ.
\b
\m 
\v 6 مَاڒَا سِّيوْڒغْ، وَارْ خَافِي إِتّجِّي ڒحْڒِيقْ إِنُو
\m ؤُ مَاڒَا سّغْذغْ، مَا أَذْ خَافِي إِحيّذْ؟
\m 
\v 7 ڒخُّو إِسِّيحڒْ أَيِي نتَّا،
\m ثسَّارْجْفذْ شكْ مَارَّا ثَاوَاشُونْثْ إِنُو.
\m 
\v 8 شكْ ثسّْذُورُويذْ أَيِي س ثقْشُورْثْ \add ن ثڒْمشْثْ\add*،
\m ثنِّي ذ ثَاشهَّاذْثْ خَافِي،
\m ؤُشَا ثكَّارْ خَافِي \add أَرِّيمثْ\add* إِنُو ثَامُوسْرِيوْثْ،
\m ثتّْشثْشَا زَّايِي ذڭْ ؤُغمْبُوبْ إِنُو.
\m 
\v 9 أَغْضَابْ نّسْ إِمزّقْ، إِضفَّارْ أَيِي-د.
\m نتَّا إِتّْغزَّا غَارِي ثِيغْمَاسْ.
\m أَغْرِيمْ إِنُو إِسّْقطَّاعْ-د غَارِي ثِيطَّاوِينْ. \x ◘ \xo 16:‏9 \xt أَيُوبْ 10‏:‏16، 17؛ 13‏:‏24\x*
\b
\m 
\v 10 نِيثْنِي تّْشَارَّاڭنْ أَقمُّومْ نْسنْ خَافِي،
\m شَّاثنْ أَيِي س ڒْحڭْرَا غَارْ ؤُقَابْسِي،
\m تّكَّارنْ خَافِي تّْمُوننْ.
\m 
\v 11 إِسلّمْ أَيِي أَربِّي
\m إِ يِيجّْ ن مِّيسْ ن ڒْمُوعْصِييّثْ،
\m إِعَارّنْ أَيِي ذڭْ ؤُفُوسْ ن إِعفَّاننْ.
\b
\m 
\v 12 ثُوغَا أَيِي ذِي ڒْهُوذْنثْ،
\m مَاشَا نتَّا يَارْژَا أَيِي،
\m إِشبَّارْ أَيِي ذڭْ إِجِيمَانْ، إِڒْبزْ أَيِي.
\m إِسّْبدّْ أَيِي ذ ثَاحْجُورْثْ إِ يِيخفْ نّسْ. \x ◘ \xo 16:‏12 \xt أَيُوبْ 7‏:‏20؛ إِڭجذ. 3‏:‏12\x*
\m 
\v 13 إِمْجبَّاذنْ \add نّسْ\add* \add ن ڒْقوْسْ\add* نّْضنْ أَيِي-د،
\m نتَّا إِسّْنُوقُّوبْ أَيِي ثِيژَّاڒْ بْڒَا أَهَاوڒْ،
\m إِتّْزدْجَاعْ غَارْ ثمُّورْثْ إِژِي إِنُو، \f ◼ \fr 16:‏13 \ft \bd ’ثِيژَّاڒْ‘\bd* - نِيغْ ’ثِيڭژْڒِينْ‘.\f*
\m 
\v 14 يَارژَّا أَيِي ثَارژِّيثْ
\m أَوَارْنِي إِ ثْرژِّيثْ نّغْنِي،
\m إِعْرفْ-د خَافِي أَمْ بُو-ثغْرُوضْثْ.
\b
\m 
\v 15 خيّْضغْ ثَاخَانْشثْ \add ن وشْضَانْ\add*
\m إِ ثڒْمشْثْ إِنُو،
\m إِشّْ إِنُو سّْوسّْخغْ ذِي ثْعجَّاشْثْ. \x ◘ \xo 16:‏15 \xt أَيُوبْ 30‏:‏19\x*
\m 
\v 16 أَغمْبُوبْ إِنُو إِزْوغْ زڭْ إِمطَّاونْ،
\m ثِيڒِي نْ ڒْموْثْ أَقَا-ت خْ وَابْڒِيونْ إِنُو،
\m 
\v 17 وَاخَّا وَارْ يَارْسِي لْعُونْفْ خْ إِفَاسّنْ إِنُو
\m ؤُ ثَاژَادْجِيثْ إِنُو ثصْفَا.
\b
\m 
\v 18 \add ؤُهْ\add* ثَامُّورْثْ، وَارْ دَّاڒْ إِذَامّنْ إِنُو،
\m وَارْ تّجِّي إِغُويَّانْ إِنُو
\m أَذْ أَفنْ أَمْشَانْ \add إِ أَرَّاحثْ\add*!
\m 
\v 19 خْزَارْ، ؤُڒَا ذ ڒخُّو،
\m أَشهَّاذْ إِنُو ذڭْ ؤُجنَّا،
\m أَمْشَافعْ إِنُو خْ ڒڭْعُوذِي.
\m 
\v 20 إِمدُّوكَّاڒْ إِنُو ذ يِينِّي زَّايِي إِسْثْهزَّانْ،
\m \add مَاشَا\add* ثتّْرُو ثِيطّْ إِنُو غَارْ أَربِّي.
\m 
\v 21 أجّْ-إِ-ث أَذْ إِوّثْ دّعْوثْ
\m خْ ورْيَازْ غَارْ أَربِّي،
\m أَمْ إِجّْ ن مِّيسْ ن بْنَاذمْ
\m خْ ؤُمدُّوكّڒْ نّسْ. \x ◘ \xo 16:‏21 \xt أَيُوبْ 31‏:‏35؛ أَمب. 6‏:‏10؛ إِشا. 45‏:‏9؛ رُوم. 9‏:‏20\x*
\m 
\v 22 مَاغَارْ ذْرُوسْ ن إِسڭّْوُوسَا
\m إِ-د غَا يَاسنْ \add عَاذْ\add*،
\m قْبڒْ  إِ غَا ؤُيُورغْ أَبْرِيذْ
\m وَارْ زَّايسْ تّْعِيقِّيبغْ.
\b
\b
\c 17
\s1 أَيُوبْ إِسِّيوڒْ أَكْ-ذ إِلِيفَازْ خْ ڒمْحَايمْ نّسْ
\m 
\v 1 بُوحْبڒْ إِنُو يَارْجفْ،
\m ؤُسَّانْ إِنُو \add إِنڭُّورَا\add* خسْينْ،
\m \add مْغِيرْ\add* إِمضْڒَانْ ذ أَيِي إِقِّيمنْ.
\m 
\v 2 س ثِيذتّْ، إِنِّي إِسْثهْزَانْ أَقَا أَثنْ غَارِي،
\m ؤُ ثِيطّْ إِنُو ثسّْعدُّو دْجِيڒثْ
\m جَارْ إِخَارِّيصنْ نْسنْ إِمَارْزَاڭنْ!
\b
\m 
\v 3 أڭّْ إِخفْ نّشْ ذ أَضْمَانْ إِ نشّْ \add ذِينْ\add* غَاركْ.
\m مَانْ ونْ \add خنِّي\add* إِ غَا إِوْثنْ \add أَفُوسْ نّسْ\add*
\m ذڭْ ؤُفُوسْ إِنُو \add إِ مَانْ أَيَا\add*؟ \x ◘ \xo 17:‏3 \xt 2 كُور. 5‏:‏19\x*
\m 
\v 4 مَاغَارْ شكْ ثكّْسذْ
\m \add مَارَّا\add* ڒفْهَامثْ خْ وُوڒْ نْسنْ،
\m خْ ؤُيَا شكْ وَارْ ثنْ ثسّْعُودْجِيذْ شَا.
\m 
\v 5 وِي غَا إِغْذَارنْ إِمدُّوكَّاڒْ نّسْ
\m ذِي طّْوعْ ن ثْكشَّاضْثْ،
\m ثِيطَّاوِينْ ن إِحنْجِيرنْ نّسْ أَذْ نْعذْمنْثْ.
\b
\m 
\v 6 نتَّا إِڭَّا أَيِي ذ لْمَاثَالْ جَارْ ڒڭْنُوسْ،
\m أَڒَامِي ذوْڒغْ أَمْ يِيجّنْ
\m سُّوسُوفنْ أَسْ خْ ؤُغمْبُوبْ. \x ◘ \xo 17:‏6 \xt أَيُوبْ 30‏:‏9\x*
\m 
\v 7 س ؤُيَا إِ ثعْمشْ ثِيطّْ إِنُو زڭْ وشْضَانْ،
\m مَارَّا إِغزْذِيسنْ إِنُو أَقَا أَثنْ أَمْ ثِيڒِي.
\m 
\v 8 إِنِّي إِڭُّورنْ نِيشَانْ
\m تّْنخْڒَاعنْ زِي مَانْ أَيَا،
\m أَمزْذَاڭْ إِتّْنقْڒَابْ خْ ؤُمْنَافقْ.
\m 
\v 9 أَمْسڭّذْ إِمنّعْ ذڭْ وبْرِيذْ نّسْ،
\m ونِّي غَارْ إِدْجَا إِفَاسّنْ إِمزْذَاڭنْ،
\m يَارنِّي ذِي جّْهذْ.
\b
\m 
\v 10 مَاشَا مَارَّا كنِّيوْ، ذوْڒمْ-د،
\m أَستِّيوْ-د ذَا،
\m مَاغَارْ وَارْ ؤُفِيغْ
\m ؤُڒَا ذ إِجّْ ن ؤُمِيغِيسْ جَارْ أَومْ. \x ◘ \xo 17:‏10 \xt أَيُوبْ 6‏:‏29\x*
\m 
\v 11 عْذُونْ وُوسَّانْ إِنُو،
\m تّْوَاقضْعنْ إِنْوَاينْ إِنُو،
\m مَارَّا مژْرِي ن وُوڒْ إِنُو. \x ◘ \xo 17:‏11 \xt أَيُوبْ 7‏:‏6؛ 9‏:‏25\x*
\m 
\v 12 دْجِيڒثْ تّڭّنْ ت ذ أَسّْ،
\m \add قَّارنْ:\add* أَقَا ثَافَاوْثْ ثتَّاذسْ-د
\m خْمِي د غَا ثوْضَا ثَادْجسْثْ.
\b
\m 
\v 13 مَاڒَا سِّيثْمغْ \add عَاذْ\add*، \add سِّيثِيمغْ\add*
\m أَقَا ڒَاخَارْثْ أَذْ ثِيڒِي ذ ثَادَّارْثْ إِنُو،
\m أَذْ بزّْعغْ ثَاسُّوثْ إِنُو ذِي ثَادْجسْثْ.
\m 
\v 14 غَارْ \add وحْفُورْ ن\add* ثُورْصُوضِي ڒَاغِيغْ:
\m ’شكْ ذ بَابَا!‘،
\m غَارْ إِكشَّا: ’يمَّا!‘ ذ: ’ؤُتْشْمَا!‘
\m 
\v 15 مَانِي إِدْجَا خنِّي ڒَايَاسْ إِنُو؟
\m ڒَايَاسْ إِنُو،
\m مَانْ ونْ \add إِزمَّارنْ\add* أَذْ ث إِژَارْ؟
\m 
\v 16 أَذْ هْوَانْ غَارْ طّْرُوفَا ن ڒَاخَارْثْ،
\m خْمِي إِ غَا نَافْ نْمُونْ أَرَّاحثْ ذڭْ ؤُشَاڒْ. \x ◘ \xo 17:‏16 \xt أَيُوبْ 3‏:‏17، 18، 19؛ 30‏:‏23، 24\x*
\b
\b
\c 18
\s1 ڒْهَارْدْ وِيسّْ ثْنَاينْ ن بِيلْذَاذْ: أَنڭَّارُو ن بْنَاذمْ ذ أَعفَّانْ
\m 
\v 1 \add خَاسْ ؤُشَا\add* يَارَّا-د \bd بِيلْذَاذْ\bd*، ونِّي د-يُوسِينْ زِي شُوحَا، إِنَّا:
\b
\m 
\v 2 أَڒْ مڒْمِي \add عَاذْ ثَارزُّومْ\add*
\m أَذْ ثطّْفمْ \add إِجّْ ن بْنَاذمْ\add* خْ وَاوَاڒنْ نّسْ؟
\m مَاڒَا ثْفهْممْ، \add خنِّي\add* أَوَارْنِي إِ ؤُيَا أَذْ نسِّيوڒْ.
\m 
\v 3 مَايمِّي ذ أَنغْ إِتّْوَاڭّْ أَمْ ڒْمَاڒْ
\m ؤُ نتّْوَاحْصَارْ ذِي بُوحْبڒْ
\m ذِي ثِيطَّاوِينْ نْومْ؟
\b
\m 
\v 4 \add شكْ، أَ يَارْيَازْ\add* ونِّي إِتّْمزّْقنْ إِخفْ نّسْ
\m ذڭْ ؤُخيّقْ نّسْ!
\m مَا أَذْ جّنْ ثمُّورْثْ \add ذِي سِّيبّثْ نّشْ\add*،
\m أَذْ إِتّْوَاسّْمُوطِّي جَّارْفْ
\m زڭْ ومْشَانْ نّسْ \add ذِي سِّيبّثْ نّشْ\add*؟ \f ◼ \fr 18:‏4 \ft \bd ’إِخفْ نّسْ‘\bd* - س ثْعِيبْرَانِيثْ ’ڒعْمَارْ نّسْ‘.\f*  \x ◘ \xo 18:‏4 \xt أَيُوبْ 13‏:‏14\x*
\m 
\v 5 وَاهْ، ثَافَاوْثْ ن إِعفَّاننْ أَذْ ثخْسِي،
\m أَشعَّاڒْ ن ثْمسِّي ن \add ؤُعفَّانْ\add*
\m وَارْ إِتّڭّْ ثَافَاوْثْ \add عمَّارْصْ عَاذْ\add*.
\m 
\v 6 ثَافَاوْثْ ذِي ثْقِيذُونْثْ نّسْ أَذْ ثبَّارْشنْ،
\m ڒفْنَارْ نّسْ ثِيوَا نّسْ أَذْ ث سّْخسْينْ.
\m 
\v 7 تَّارْجِيجنْ إِصُورَافْ نّسْ إِجهْذنْ،
\m شّْوَارْ \add ن يِيخفْ\add* نّسْ أَذْ ث إِغْضڒْ.
\b
\m 
\v 8 مَاغَارْ س إِضَارنْ نّسْ أَذْ إِنَّاغْ ذڭْ ؤُصنَّاجْ،
\m أَذْ يُويُورْ خْ ثْرَاشَّا، مُّوذنْ ت إِ ثْنيْمَارْثْ.
\m 
\v 9 ثَاخْشفْثْ أَذْ ث ثمْنعْ زڭْ ؤُنِيرْزْ،
\m ڒْْفخْ أَذْ ذَايسْ ثطّفْ. \x ◘ \xo 18:‏9 \xt أَيُوبْ 5‏:‏5\x*
\m 
\v 10 ثنُّوفَّارْ ثسْغُونْثْ \add ن ڒْفخْ\add* ذِي ثمُّورْثْ،
\m ڒْفخْ أَقَا-ت خْ وبْرِيذْ.
\m 
\v 11 سِّيڭّْوذنْ ث إِنخْڒِيعنْ
\m زِي مَارَّا إِغزْذِيسنْ،
\m ضفَّارنْ ث غَارْ إِضَارنْ نّسْ. \x ◘ \xo 18:‏11 \xt أَيُوبْ 15‏:‏21؛ إِرْم. 6‏:‏25؛ 46‏:‏5؛ 49‏:‏29\x*
\b
\m 
\v 12 إِتّْوَاحْصَارْ ذَايسْ جّهْذْ نّسْ،
\m أَضيّعْ إِتّْرَاجَا إِ-ث غَارْ ؤُغزْذِيسْ نّسْ. \x ◘ \xo 18:‏12 \xt أَيُوبْ 15‏:‏23\x*
\m 
\v 13 \add أَرْژِييّثْ\add* أَذْ ثشّْ
\m \add مَارَّا\add* إِغزْذِيسنْ ن أَرِّيمثْ نّسْ،
\m إِغزْذِيسنْ \add ن أَرِّيمثْ نّسْ\add*
\m أَذْ ثنْ يشّْ إِجّْ ن ڒحْڒَاشْ إِنقّنْ.
\m 
\v 14 مِينْخفْ ثُوغَا إِتّْشڒْ،
\m إِتّْوَاقْڒعْ زِي ثْقِيضُونْثْ نّسْ.
\m ثْندّهْ إِ-ث أَرْژِييّثْ
\m غَارْ ؤُجدْجِيذْ ن إِنخْڒِيعنْ. \x ◘ \xo 18:‏14 \xt أَيُوبْ 8‏:‏13، 14؛ 11‏:‏20؛ أَوڒن. 10‏:‏28\x*
\m 
\v 15 إِوْذَانْ نِّي وَارْ دْجِينْ ذ يِينِّي نّسْ،
\m زدّْغنْ ذڭْ ؤُقِيضُونْ نّسْ،
\m ڒشْبَارِييّثْ ثتّْوَازُوزَّارْ
\m خْ ثْزذِّيغْثْ نّسْ.
\b
\m 
\v 16 سَاذُو نتَّا تَّاژْغنْ إِژوْرَانْ نّسْ،
\m زِي سنّجْ تّْوَاقسّنْ ڒفْرُوعْ نّسْ.
\m 
\v 17 ڒِيذَارثْ نّسْ أَذْ ثتّْوَاكّسْ زِي ثمُّورْثْ،
\m وَارْ ذ أَسْ إِتّْغِيمِي \add عَاذْ\add* إِسمْ ذڭْ وبْرِيذنْ. \x ◘ \xo 18:‏17 \xt إِزهد. 109‏:‏13؛ أَوڒن. 10‏:‏7\x*
\m 
\v 18 أَذْ ث عَارْننْ زِي ثْفَاوْثْ غَارْ ثَادْجسْثْ،
\m أَذْ سّْثوّْجنْ زِي دُّونشْثْ. \f ◼ \fr 18:‏18 \ft \bd ’زِي دُّونشْثْ‘\bd* - نِيغْ ’زڭْ ؤُمَاضَالْ‘.\f*
\m 
\v 19 وَارْ غَارسْ إِتِّيڒِي وَارَّاوْ
\m نِيغْ جَّاذِيرَا ذِي ڒْڭنْسْ نّسْ،
\m وَارْ إِتّْغِيمِي ؤُڒَا ذ إِجّْ أَذْ إِدَّارْ
\m ذِي ثْزذِّيغِينْ نّسْ. \x ◘ \xo 18:‏19 \xt إِشا. 14‏:‏22؛ إِرْم. 22‏:‏30\x*
\b
\m 
\v 20 خْ وَاسّْ نّسْ أَذْ أَرْجِيجنْ إِنِّي إِزدّْغنْ
\m غَارْ مَانِي ثْغدْجِي ثْفُوشْثْ،
\m إِنِّي إِزدّْغنْ غَارْ مَانِيسْ إِ د-ثْنقَّارْ ثْفُوشْثْ
\m أَذْ ثنْ ثطّفْ ثِيڭّْوُوذِي.
\m 
\v 21 وَاهْ، أَمُّو إِ ثتّمْسَارْ
\m إِ ثْزذِّيغِينْ ن إِمقْجَاحنْ،
\m وَا ذ أَمْشَانْ ن يِينِّي وَارْ إِسِّيننْ أَربِّي.
\b
\b
\c 19
\s1 ثَامْوَارِّيثْ ن أَيُوبْ خْ بِيلْذَاذْ خْ ؤُسِيثمْ نّسْ ذِي أَربِّي
\m 
\v 1 يَارَّا-د \bd أَيُوبْ\bd*، إِنَّا:
\b
\m 
\v 2 مشْحَاڒْ عَاذْ إِ غَا ثكّمْ
\m ثْشضْنمْ ڒعْمَارْ إِنُو،
\m أَذْ أَيِي ثْڒبْزمْ س وَاوَاڒنْ؟
\m 
\v 3 \add ڒخُّو\add* عَاذْ وِيسّْعشْرَا ن ثْوَاڒَاوِينْ
\m تّكّْوَارمْ أَيِي،
\m وَارْ ثتّْسضْحِيمْ
\m ؤُمِي ذ أَيِي د-ثْغطّْڒمْ أَوَاڒْ.
\m 
\v 4 مَاڒَا س ثِيذتّْ ودَّارغْ،
\m أَذْ إِقِّيمْ ؤُودَّارْ إِنُو إِ إِخفْ إِنُو.
\m 
\v 5 مَاڒَا س ثِيذتّْ ثخْسمْ أَذْ خَافِي ثسّْڭعّْذمْ
\m إِخفْ نْومْ س شِّيكِي،
\m أَذْ أَيِي ثسّْقنْعمْ س ڒفْضِيحثْ إِنُو، \f ◼ \fr 19:‏5 \ft \bd ’أَذْ خَافِي ثسّْڭَاعّْذمْ إِخفْ نْومْ س شِّيكِيلْ‘\bd* - نِيغْ: ’أَذْ خَافِي ثڭّمْ أَيَازِيضْ‘.\f*
\m 
\v 6 سْنمْ خنِّي، أَقَا أَربِّي إِنّقْڒبْ خَافِي،
\m ؤُشَا إِنّضْ أَيِي-د س ثْرَاشَّا نّسْ.
\b
\m 
\v 7 خْزَارْ، سْغُويُّوغْ: ’ڒخْشُونثْ!‘،
\m مَاشَا وَارْ خَافِي د-يَارِّي ؤُڒَا ذ إِجّْ،
\m تّْڒَاغِيغْ إِ ثْوِيزَا،
\m مَاشَا ڒْحقّْ وَارْ \add ذِينْ\add* إِدْجِي.
\m 
\v 8 أَبْرِيذْ إِنُو إِقّنْ إِ-ث،
\m أَڒَامِي وَارْ زمَّارغْ أَذْ عْذُوغْ،
\m ثَادْجسْثْ إِسُّو ت خْ إِمسْرَاقْ إِنُو.
\m 
\v 9 ڒْعزّْ إِنُو إِكشّضْ إِ-ث زَّايِي،
\m ؤُ تَّاجْ إِ إِدْجَانْ خْ ؤُزدْجِيفْ إِنُو إِكّسْ إِ-ث.
\m 
\v 10 نتَّا يَاردّدْجْ أَيِي زِي مَارَّا إِغزْذِيسنْ،
\m أَذْ تّْوَاهلّْكغْ!
\m إِقْڒعْ ڒَايَاسْ إِنُو أَمْ يِيشْثْ ن ثْشجَّارْثْ. \f ◼ \fr 19:‏10 \ft \bd ’ثَاشجَّارْثْ‘\bd* - نِيغْ ’أَدَّاڭْ‘ (’إِدَّاڭنْ‘).\f*
\m 
\v 11 أَغْضَابْ نّسْ يَارْغَا ذَايِي،
\m نتَّا إِحسّبْ أَيِي
\m أَمْ \add إِجّْ زڭْ\add* إِغْرِيمنْ نّسْ. \x ◘ \xo 19:‏11 \xt أَيُوبْ 13‏:‏24؛ 16‏:‏9؛ 33‏:‏10؛ إِڭجذ. 2‏:‏5\x*
\b
\m 
\v 12 مُوننْثْ فّْغنْثْ-د بَانْذِييَّاثْ نّسْ،
\m سّْوجْذنْثْ-إِ-د أَبْرِيذْ نْسنْثْ غَارِي
\m ؤُشَا قُووَّارنْثْ إِ ثْقِيضُونْثْ إِنُو.
\m 
\v 13 أَيْثْمَا إِسِّيڭّْوجْ إِ-ثنْ خَافِي،
\m إِنِّي ذ أَيِي إِسّْننْ ذوْڒنْ ذ مِيدّنْ خَافِي. \x ◘ \xo 19:‏13 \xt إِزهد. 31‏:‏12؛ 38‏:‏12؛ 69‏:‏9؛ 88‏:‏9\x*
\m 
\v 14 إِنِّي ذ أَيِي إِتّعْنَانْ جِّينْ أَيِي،
\m إِنِّي ذ أَيِي إِسّْننْ تُّونْ أَيِي.
\m 
\v 15 إِمْسخَّارنْ ن ثَادَّارْثْ إِنُو ذ ثِييَّا إِنُو
\m حسّْبنْ أَيِي ذ ڒْبَارَّانِي،
\m نشّْ ذ أَغْرِيبْ جَارْ ثِيطَّاوِينْ نْسنْ.
\b
\m 
\v 16 ڒَاغِيغْ إِ ؤُمْسخَّارْ إِنُو،
\m \add مَاشَا\add* وَارْ خَافِي د-يَارِّي،
\m ثُوغَا إِتّْخصَّا أَذْ ث حشّْمغْ
\m س ؤُقمُّومْ إِنُو.
\m 
\v 17 ڒعْوِينْ ن ثمْوَارِّيثْ ن نّفْسْ إِنُو
\m إِسّْعِيفّْ ثَامْغَارْثْ إِنُو،
\m أَرْصُوضغْ إِ أَيْثْمَا.
\m 
\v 18 عَاذْ إِحْرَامنْ إِمژْيَاننْ سّحْقَارنْ أَيِي.
\m مَاڒَا كَّارغْ بدّغْ، تّمْعَارَّانْ خَافِي
\m س وَاوَاڒنْ نْسنْ. \x ◘ \xo 19:‏18 \xt أَيُوبْ 30‏:‏1\x*
\m 
\v 19 مَارَّا إِمّدُّوكَّاڒْ إِنُو إِعِيزّنْ
\m شَارّْهنْ أَيِي،
\m إِنِّي تّخْسغْ، نّْقڒْبنْ خَافِي. \x ◘ \xo 19:‏19 \xt إِزهد. 41‏:‏10؛ 55‏:‏14، 15\x*
\m 
\v 20 غَارْ ثڒْمشْثْ ذ ويْسُومْ إِنُو
\m ڒسّْقنْ إِغْسَانْ إِنُو.
\m نشّْ نجْمغْ
\m أَكْ-ذ ثِيڒْمشْثْ ن ثغْمَاسْ إِنُو \add وَاهَا\add*. \x ◘ \xo 19:‏20 \xt أَيُوبْ 30‏:‏30؛ إِزهد. 102‏:‏6؛ إِڭجذ. 4‏:‏8\x*
\b
\m 
\v 21 حِينّمْ خَافِي، حِينّمْ خَافِي، \add أَ\add* كنِّيوْ،
\m إِمدُّوكَّاڒْ إِنُو!
\m مَاغَارْ أَفُوسْ ن أَربِّي إِڒْقفْ أَيِي.
\m 
\v 22 مَايمِّي ذ أَيِي ثْضَافَّارمْ
\m أَمْ ت إِتّڭّْ أَربِّي،
\m ؤُ مَايمِّي وَارْ تّْجِيوِينمْ أَيْسُومْ إِنُو؟
\m 
\v 23 مْڒِي ؤُرَانْ أَوَاڒنْ إِنُو،
\m مْڒِي تّْوَازمّمنْ ذڭْ إِجّْ ن وذْلِيسْ!
\m 
\v 24 مْڒِي تّْوَانقْشنْ
\m س بْلُومَا ن وُوزَّاڒْ ؤُ س ڒخْفِيفْ
\m ذِي جَّارْفْ إِ ڒبْذَا.
\m 
\v 25 نشّْ سّْنغْ: ’أَمفْذِي إِنُو إِدَّارْ
\m ؤُ نتَّا أَذْ د-إِكَّارْ ذ أَنڭَّارْ خْ ؤُشَاڒْ.‘
\b
\m 
\v 26 ؤُ أَوَارْنِي ڒَامِي إِ غَا ثتّْوَاڒْبزْ
\m ثڒْمشْثْ إِنُو أَمُّو،
\m أَذْ ژَترغْ أَربِّي زِي أَرِّيمثْ إِنُو.
\m 
\v 27 أَذْ ث ژَترغْ زَّاثِي،
\m ثِيطَّاوِينْ إِنُو أَذْ ث ژَترنْثْ،
\m وَارْ إِدْجِي مِيدّنْ.
\m غَارسْ إِ تّْمژْرنْثْ ثِيژَّاڒْ إِنُو
\m غَارْ ذَاخڒْ إِنُو. \f ◼ \fr 19:‏27 \ft \bd ’ثِيژَّاڒْ‘\bd* - نِيغْ ’ثِيڭژْڒِينْ‘.\f*
\m 
\v 28 وَاخَّا أَمنِّي كنِّيوْ أَذْ ثِينِيمْ:
\m ’مَامّشْ إِ نْزمَّارْ أَذْ ث نضْفَارْ؟‘
\m \add مَاغَارْ\add* أَژْوَارْ ن ثْمسْڒَاشْثْ إِتّْوَافْ ذَايِي.
\m 
\v 29 ڭّْوذمْ زِي سِّيفْ،
\m مَاغَارْ س سِّيفْ \add أَذْ د-يَاسْ\add* وسْعَارْ
\m خْ دّْنُوبْ إِنقّنْ،
\m مَاحنْذْ أَذْ ثسّْنمْ أَقَا \add أَذْ يِيڒِي\add* ڒْحُوكْمْ.
\b
\b
\c 20
\s1 ڒْهَارْدْ وِيسّْ ثْنَاينْ ن صُوفَارْ خْ ڒفْڒحْ ذ ڒْحُوكْمْ
\m 
\v 1 \add خنِّي\add* يَارَّا-د \bd صُوفَارْ\bd*، ونِّي د-يُوسِينْ زِي نَاعْمَا، إِنَّا:
\b
\m 
\v 2 إِخَارِّيصنْ إِنُو تّْغِيمَانْ
\m ذكّْوَاڒنْ-د غَارِي
\m زِي سِّيبّثْ ن ؤُقدْجقْ
\m \add إِ وَارْ إِتّْبذِّينْ\add* ذِي \add ڒْْبَاڒْ\add* إِنُو.
\m 
\v 3 سْڒِيغْ إِجّْ ن ؤُوبّخْ إِ ذ أَيِي إِسّْبهْذَاڒنْ،
\m \add مَاشَا\add* بُوحْبڒْ أَذْ خَافِي د-يَارّْ
\m س ڒفْهَامثْ إِنُو.
\m 
\v 4 \add إِوَا\add* ثسّْنذْ أَيَا،
\m أَقَا-ث ذِينْ زڭْ وشْحَاڒْ ؤُيَا،
\m زڭْ وَامِي إِتّْوَاسَّارْسْ بْنَاذمْ خْ ثمُّورْثْ،
\m 
\v 5 أَقَا أَسْڒِيوْڒوْ ن إِعفَّاننْ
\m إِتّكّْ ذْرُوسْ \add وَاهَا\add*،
\m ڒفْرَاحثْ ن ؤُمْنَافقْ \add مْغِيرْ\add* إِشْثْ ن ثْزحْزِيحْثْ. \x ◘ \xo 20:‏5 \xt إِزهد. 37‏:‏35، 36\x*
\b
\m 
\v 6 وَاخَّا ثتّْڭعَّاذْ نّْفَاخثْ نّسْ أَڒْ إِجنْوَانْ،
\m وَاخَّا إِتّْحَاذَا أَزدْجِيفْ نّسْ أَڒْ إِسيْنُوثنْ،
\m 
\v 7 أَمْ مَامّشْ إِسُوفْغَانْ نّسْ
\m أَذْ قْضَانْ إِ ڒبْذَا،
\m أَذْ إِقْضَا ؤُڒَا ذ نتَّا إِ ڒبْذَا.
\m إِنِّي ث إِژْرِينْ، أَذْ إِنِينْ: ’مَانِي إِدْجَا نتَّا؟‘
\m 
\v 8 أَمْ إِشْثْ ن ثِيرْجَا أَذْ إِضُووْ،
\m أَڒَامِي وَارْ إِتّْوِيفْ \add عَاذْ\add*،
\m أَذْ إِتّْوَاسّثْلعْ أَمْ إِجّْ ن ڒوْحِييْ ن دْجِيڒثْ.
\m 
\v 9 ثِيطّْ إِ ث إِژْرِينْ وَارْ \add ث\add* ثْژَارّْ عَاوذْ،
\m ؤُ أَمْشَانْ نّسْ وَارْ ث إِژَارّْ \add عمَّارْصْ\add*.
\m 
\v 10 إِحنْجِيرنْ نّسْ أَذْ سّْجِيوْننْ إِمزْڒَاضْ،
\m \add أَمُّو\add* إِ د غَا يَارّنْ
\m إِفَاسّنْ نّسْ أَڭْڒَا نّسْ.
\m 
\v 11 إِخْسَانْ نّسْ إِشُّورنْ س ثمْژِي،
\m أَذْ زّْڒنْ أَكِيذسْ ذڭْ ؤُشَاڒْ.
\b
\m 
\v 12 مَاڒَا ڒْغَارْ ذڭْ ؤُقمُّومْ نّسْ ذ \add أَ\add*مِيژِيذْ،
\m مَاڒَا إِسّْنُوفَّارْ إِ-ث سَاذُو إِڒسْ نّسْ،
\m 
\v 13 مَاڒَا إِحْضَا إِ-ث، وَارْ إِخْسْ أَذْ خَاسْ إِحيّذْ،
\m \add مَاشَا\add* إِمنّعْ إِ-ث ذڭْ وَانغْ نّسْ،
\m 
\v 14 \add خنِّي\add* أَذْ ثْبدّڒْ مَاشَّا نّسْ
\m ذڭْ ؤُعذِّيسْ نّسْ،
\m ذِي ذَاخڒْ نّسْ أَذْ ثذْوڒْ
\m ذ أَرّْهَاجْ ن ثْرفْسِيوِينْ.
\m 
\v 15 إِصَارْضْ أَڭْڒَا، \add مَاشَا\add* أَذْ ث-إِ-د-إِعُوقّْ \add عَاوذْ\add*.
\m أَذْ ث-إِ-د-إِنْضَارْ أَربِّي
\m غَارْ بَارَّا زڭْ ؤُعذِّيسْ نّسْ.
\m 
\v 16 أَرّْهَاجْ ن ثْرفْسِيوِينْ أَذْ ث إِطّضْ،
\m إِڒسْ ن ؤُفِيغَارْ أَذْ ث إِنغْ.
\b
\m 
\v 17 وَارْ إِژَارّْ إِغزْرَانْ،
\m ثِيغزْرَاثِينْ ذ ثَارْيَاوِينْ
\m \add إِتَّازّْڒنْ\add* س ثَامّنْثْ ذ ؤُغِي.
\m 
\v 18 أَذْ د-يَارّْ ڒفْضڒْ ن ؤُمَارّثْ نّسْ،
\m وَارْ ث إِسّغْڒَايْ،
\m وَارْ إِنڭّزْ س ڒفْرَاحثْ
\m زِي سِّيبّثْ ن وَاڭْڒَا إِ د-إِكْسبْ،
\m 
\v 19 مَاغَارْ إِذدْجْ إِمزْڒَاضْ،
\m إِجَّا إِ-ثنْ بْڒَا ثْوِيزَا،
\m يُوشَارْ ثَادَّارْثْ نِّي وَارْ إِسّْبدّْ،
\m 
\v 20 مَاغَارْ وَارْ إِسِّينْ ڒْهُوذْنثْ ذِي ذَاخڒْ نّسْ،
\m \add س ؤُيَا\add* وَارْ إِنجّمْ
\m س \add مَارَّا\add* مِينْ ذِي ثُوغَا إِمّژْرِي.
\b
\m 
\v 21 وَارْ إِتّْشطِّي وَالُو إِ ؤُمرْعِيقْ نّسْ،
\m خْ ؤُيَا وَارْ إِتّْغِيمِي زّْهَارْ نّسْ إِبدّْ.
\m 
\v 22 مَاڒَا غَارسْ أَفيّضْ إِمُونْ، أَذْ إِتّْوَاحْسَارْ،
\m أَذْ خَاسْ يِيڒِي \add ؤُ\add*فُوسْ ن كُوڒْ ڒْمسْكِينْ.
\m 
\v 23 أَيَا أَذْ يِيڒِي حِيمَا أَذْ إِشُّورْ أَعذِّيسْ نّسْ،
\m \add وَاهْ، أَربِّي\add* أَذْ خَاسْ إِسّكّْ
\m ڒْْحَاذُوقْ ن وغْضَابْ نّسْ،
\m أَذْ ث يَارّْ أَذْ خَاسْ إِوّثْ \add أَمْ ونْژَارْ\add*
\m \add ؤُشَا أَذْ ث يَارّْ أَذْ إِشُوكّْ\add* ذِي أَرِّيمثْ نّسْ.
\m 
\v 24 وَاخَّا أَذْ يَارْوڒْ زِي ڒسْنَاحْ ن وُوزَّاڒْ،
\m أَذْ ث إِسّْنُوقّبْ ڒْقوْسْ ن نّْحَاسْ.
\m 
\v 25 إِجبّذْ \add إِجّنْ زَّايسْ فْڒِيثْشَا\add*،
\m أَقَا ثفّغْ-د زِي أَرِّيمثْ نّسْ،
\m ڒْْمَاشَامْ يَارقّنْ \add إِتّفّغْ-د\add*
\m زڭْ إِژِي نّسْ،
\m \add وَاهْ\add* إِنخْڒِيعنْ أَذْ خَاسْ كّنْ.
\b
\m 
\v 26 ثَادْجسْثْ ثكْمڒْ ثتّْحَامَا
\m غَارْ ثْخُوبَايْ نّسْ إِنُوفَّارنْ،
\m ثِيمسِّي وَارْ ت إِسِّيغْ ؤُڒَا ذ إِجّْ،
\m أَذْ ث ثشّْ، أَذْ ثَارّْ مژْرِي
\m أَكْ-ذ يِينِّي إِشطّنْ ذِي ثْقِيضُونْثْ نّسْ.
\m 
\v 27 أَجنَّا أَذْ إِعَارَّا ڒْمُوعْصِييّثْ نّسْ،
\m ثَامُّورْثْ أَذْ خَاسْ ثْغوّغْ.
\m 
\v 28 ڒْغِيدْجثْ ن ثَادَّارْثْ نّسْ أَذْ ثْرَاحْ،
\m أَذْ ثَازّڒْ ذڭْ وَاسّْ ن وغْضَابْ نّسْ.
\b
\m 
\v 29 وَا ذ مِينْ إِ د-إِكَّارنْ
\m إِ إِعفَّاننْ زِي أَربِّي،
\m ثَاسْغَارْثْ إِ ذ أَسْ إِنَّا أَربِّي.
\b
\b
\c 21
\s1 ثَامْوَارِّيثْ ن أَيُوبْ خْ صُوفَارْ: ڒفْڒحْ ن ورْيَازْ أَعفَّانْ
\m 
\v 1 \add خنِّي\add* يَارَّا-د \bd أَيُوبْ\bd*، إِنَّا:
\b
\m 
\v 2 سْڒمْ مْلِيحْ إِ وَاوَاڒنْ إِنُو،
\m حِيمَا أَذْ أَومْ إِڒِينْ إِ ؤُسْفوّجْ.
\m 
\v 3 كْسِيمْ أَيِي، \add خنِّي\add* أَذْ سِّيوْڒغْ،
\m ؤُ أَوَارْنِي ڒَامِي سِّيوْڒغْ،
\m ثْزمَّارمْ أَذْ ثْعفَّارمْ.
\m 
\v 4 مَا أَشثْشِي إِنُو خْ إِجّْ ن بْنَاذمْ؟
\m نِيغْ مَايمِّي وَارْ ذ أَيِي د-إِكَّارْ
\m أَذْ يِيڒِي بُوحْبڒْ إِنُو بْڒَا تَّاسِيعْ ن ڒْخَاضَارْ؟
\m 
\v 5 قڒْبمْ-د غَارِي ؤُشَا جْعَارمْ،
\m سَارْسمْ أَفُوسْ خْ ؤُقمُّومْ.
\m 
\v 6 \add مَاڒَا\add* خمّغْ \add وَاهَا\add* ذڭْ ؤُيَا، تّْنخْڒِيعغْ
\m ؤُ ثْمنّعْ ثَارْجِيجِيثْ أَرِّيمثْ إِنُو.
\b
\m 
\v 7 مَايمِّي تّْغِيمَانْ إِعفَّاننْ دَّارنْ،
\m \add مَايمِّي\add* دَّاكّْوَاڒنْ إِوسُّورَا،
\m تّْمَارْنِينْ عَاذْ ذِي جّهْذْ نْسنْ؟ \x ◘ \xo 21:‏7 \xt إِزهد. 17‏:‏10؛ 73‏:‏12؛ إِرْم. 12‏:‏1؛ حَاب. 1‏:‏16\x*
\m 
\v 8 ثَارْوَا نْسنْ تّْغِيمَانْ بدّنْ
\m زَّاثْ إِ ؤُغمْبُوبْ نْسنْ، أَقَا أَثنْ غَارْسنْ،
\m ؤُ \add إِحنْجِيرنْ\add* إِغدُّوثنْ نْسنْ
\m زَّاثْ إِ ثِيطَّاوِينْ نْسنْ. \f ◼ \fr 21:‏8 \ft \bd ’أَرَا‘\bd* - س ثْعِيبْرَانِيثْ ’زَّارِيعثْ‘.\f*
\m 
\v 9 ثُوذْرِينْ نْسنْ أَقَا أَثنْثْ
\m ذِي ڒهْنَا نْهْڒَا أَنخْڒِيعْ،
\m أَعْمُوذْ ن أَربِّي وَارْ ثنْ إِشِّيثْ.
\m 
\v 10 أَفُونَاسْ نّسْ إِتَّارَّا ؤُ وَارْ إِخطِّي،
\m ثَافُونَاسْثْ نّسْ ثتَّارُو،
\m عمَّارْصْ وَارْ ثْغطّڒْ أَعذِّيسْ.
\m 
\v 11 تّجَّانْ إِمژْيَاننْ نْسنْ
\m ڭُّورنْ أَمْ يِيشْثْ ن ثْحِيمَارْثْ،
\m إِحنْجِيرنْ نْسنْ \add تّجَّانْ ثنْ\add* نڭّْزنْ.
\b
\m 
\v 12 نِيثْنِي سّْڭعَّاذنْ \add ثْمِيجَّا نْسنْ\add*
\m غَارْ ؤُبنْذِيرْ ذ ڒْڭَامْبْرِي،
\m فَارّْحنْ غَارْ ثْمِيجَّا ن ثمْجَا.
\m 
\v 13 سّْعدُّونْ ؤُسَّانْ نْسنْ ذِي زّْهَارْ،
\m \add مَاشَا\add* هكّْوَانْ غَارْ ڒَاخَارْثْ
\m ذڭْ ورْمَاشْ ن وَابْڒِيونْ.
\m 
\v 14 قَّارنْ إِ أَربِّي: ’حيّذْ خَانغْ،
\m مَاغَارْ وَارْ ذ أَنغْ إِعْجِيبْ
\m أَذْ نسّنْ إِبْرِيذنْ نّشْ. \x ◘ \xo 21:‏14 \xt أَيُوبْ 22‏:‏17\x*
\m 
\v 15 مَانْ ونْ إِدْجَانْ ذ أَمْزمَّارْ خْ كُوڒْشِي
\m مَاحنْذْ أَذْ أَسْ نْسخَّارْ؟
\m مَانْ لْفَايْذَا إِ غَارْنغْ
\m مَاڒَا نْزِييَّارْ خَاسْ \add س ثْژَادْجِيثْ نّغْ\add*؟‘ \x ◘ \xo 21:‏15 \xt ؤُف. 5‏:‏2؛ مـَال. 3‏:‏14\x*
\m 
\v 16 خْزَارْ، زّْهَارْ نْسنْ وَارْ إِدْجِي ذڭْ ؤُفُوسْ نْسنْ.
\m شّْوَارْ ن إِعفَّاننْ إِڭّْوجْ خَافِي. \x ◘ \xo 21:‏16 \xt أَيُوبْ 22‏:‏18\x*
\b
\m 
\v 17 مشْحَاڒْ ن ثْوَاڒَاوِينْ
\m ثْخسِّي \add خنِّي\add* إِ إِعفَّاننْ ثْفَاوْثْ \add نْسنْ\add*،
\m ؤُشَا إِڒقّفْ إِ-ثنْ ؤُضيّعْ،
\m \add مشْحَاڒْ ن ثْوَاڒَاوِينْ\add* إِبطَّا نتَّا
\m \add خَاسنْ ڒحْڒِيقْ\add* ذڭْ وغْضَابْ نّسْ، \x ◘ \xo 21:‏17 \xt أَيُوبْ 20‏:‏29؛ إِزهد. 11‏:‏6، 7\x*
\m 
\v 18 \add أَڒَامِي\add* إِ غَا ذوْڒنْ
\m أَمْ ؤُڒُومْ زَّاثْ إِ ؤُسمِّيضْ،
\m أَمْ إِغدْجْ ثخْضفْ إِ-ث ثْحَارْيَاضْثْ؟
\m 
\v 19 \add مَا ثقَّارمْ\add*: ’أَربِّي إِتّْخمّڒْ \add لْعِيقَابْ\add*
\m \add إِ\add* ڒْمُوعْصِييّثْ نّسْ إِ إِحنْجِيرنْ نّسْ!‘
\m أجّْ إِ-ث أَذْ أَسْ ت إِخدْجصْ
\m أَڒْ غَا يَاشَا نتَّا \add سِيمَانْثْ نّسْ\add*!
\m 
\v 20 أجّْ ثِيطَّاوِينْ نّسْ
\m أَذْ ژَترنْثْ أَهلّكْ نّسْ،
\m \add أجّْ إِ-ث\add* أَذْ إِسُو \add س يِيخفْ نّشْ\add*
\m زڭْ وسْعَارْ ن ؤُمْزمَّارْ خْ كُوڒْشِي.
\m 
\v 21 مَاغَارْ مَامّشْ إِ غَا يَارْضَا عَاذْ
\m ذِي \add أَيْثْبَابْ ن\add* ثَادَّارْثْ نّسْ
\m أَوَارْنِي \add إِ ڒْموْثْ\add* نّسْ،
\m مَاڒَا ثتّْوَاڭّْ \add عَاذْ\add* قدَّا ن إِيُورنْ نّسْ؟ \f ◼ \fr 21:‏21 \ft \bd ’أَوَارْنِي \bdit إِ ڒْموْثْ\bdit* نّسْ‘\bd* - س ثْعِيبْرَانِيثْ ’أَوَارْنِي أَسْ‘.\f*
\b
\m 
\v 22 مَا زمَّارنْ أَذْ سّْڒمْذنْ
\m ثُوسّْنَا إِ أَربِّي،
\m ونِّي إِحكّْمنْ
\m خْ يِينِّي إِدْجَانْ ذڭْ ؤُجنَّا يُوعْڒَانْ؟ \x ◘ \xo 21:‏22 \xt إِشا. 40‏:‏13؛ رُوم. 11‏:‏34؛ 1 كُور. 2‏:‏16\x*
\m 
\v 23 أَقَا ذِينْ إِجّنْ إِمُّوثْ ذِي زّْهَارْ إِمُونْ،
\m أَمْ \add إِدَّارْ عَاذْ\add* قَاعْ ذِي ڒهْنَا ؤُ ذِي ڒْهُوذْنثْ.
\m 
\v 24 \add أَمْ\add*عمَّارنْ ڒمْذَاوذْ نّسْ س ؤُغِي
\m ؤُ إِتّْوَابزّڭْ وَاذُوفْ ن يغْسَانْ نّسْ.
\m 
\v 25 ونّغْنِي إِمُّوثْ س ڒعْمَارْ ذ أَمَارْزَاڭْ،
\m وَارْ د-يِيوِي ڒِيقِّي إِ وَالُو ن ڒْخَارْ.
\m 
\v 26 مُوننْ زّْڒنْ نِيثْنِي ذڭْ ؤُشَاڒْ
\m ؤُ إِكشَّاونْ ذْڒِينْ ثنْ. \x ◘ \xo 21:‏26 \xt أَيُوبْ 17‏:‏14\x*
\b
\m 
\v 27 خْزَارْ، سّْنغْ إِخَارِّيصنْ نْومْ،
\m ؤُڒَا ذ ثِيمعْمَاتْشْ نِّي زِي ذ أَيِي ثْذڒْممْ،
\m 
\v 28 خْمِي ثقَّارمْ:
\m ’مَانِي ثدْجَا ثَادَّارْثْ ن ؤُمْشنّعْ
\m \add إِتّْمژْرِينْ ذِي صُّولْطَا\add*،
\m مَانِي ثدْجَا ثْقِيضُونْثْ \add س ثْزذِّيغِينْ\add*،
\m ثَازذِّيغْثْ ن ؤُعفَّانْ؟‘
\m 
\v 29 مَاعمَّارْصْ وَارْ ثسّقْسِيمْ إِمْسبْرِيذنْ؟
\m أَقَا إِشيَّارنْ نْسنْ إِتّْقَارَّانْ
\m وَارْ ثْزمَّارمْ أَذْ ثنْ ثنْكَارمْ:
\m 
\v 30 مَاغَارْ أَعفَّانْ أَذْ إِتّْوَاحْضَا
\m ذڭْ وَاسّْ ن أَرْژِييّثْ،
\m ذڭْ وَاسّْ ن ؤُذُوقّزْ \add ن ؤُفُوڭمْ\add*
\m أَذْ تّْوَاوْينْ نِيثْنِي \add ذِي ڒَامَانْ\add*. \x ◘ \xo 21:‏30 \xt أَوڒن. 16‏:‏4\x*
\m 
\v 31 مَانْ ونْ إِ ث غَا إِسّشْننْ أَبْرِيذْ نّسْ
\m ذڭْ ؤُغمْبُوبْ نّسْ؟
\m مَاڒَا إِڭَّا \add شَا ن ثُوعفّْنَا\add*،
\m وِي \add ث\add* إِ غَا إِخدْجْصنْ؟
\b
\m 
\v 32 نتَّا مَاشَا أَذْ إِتّْوَاكْسِي
\m غَارْ ونْضڒْ نّسْ \add ذ أَمقّْرَانْ\add*
\m ؤُ غَارْ ثوْرِيرْثْ ن ونْضڒْ نّسْ
\m إِتّْعسّْ نتَّا \add س يِيخفْ نّسْ\add*.
\m 
\v 33 تّْعجِيبنْ أَسْ إِبُورْسَا ن ثغْزُورْثْ،
\m ضفَّارنْ ث مَارَّا إِوْذَانْ
\m ؤُ إِنِّي ذ أَسْ إِتِّيزْوَارنْ،
\m وَارْ زمَّارنْ أَذْ ثنْ حسْبنْ.
\b
\m 
\v 34 مَامّشْ ثخْسمْ أَذْ أَيِي ثْعزَّامْ
\m س \add وَاوَاڒنْ\add* إِخْوَانْ؟
\m زِي ثمْوَارِّيثْ نْومْ وَارْ إِتّْغِيمِي \add وَالُو\add*
\m مْغِيرْ ڒغْضَارْ \add وَاهَا\add*.
\b
\b
\c 22
\s1 ڒْهَارْذْ وِيسّْ ثْڒَاثَا ن إِلِيفَازْ خْ دّنْبْ ذ وذْوَاڒْ غَارْ أَربِّي
\m 
\v 1 \add خنِّي\add* يَارَّا-د \bd إِلِيفَازْ\bd*، ونِّي د-يُوسِينْ زِي ثَايْمَانْ، إِنَّا:
\b
\m 
\v 2 مَا إِزمَّارْ بْنَاذمْ أَذْ إِنْفعْ أَربِّي؟
\m ونِّي إِڭِّينْ س ڒعْقڒْ إِنفّعْ
\m \add مْغِيرْ\add* إِ يِيخفْ نّسْ.
\m 
\v 3 مَا أَقَا-ث ذ لْفَايْذَا إِ ؤُمْزمَّارْ خْ كُوڒْشِي
\m أَقَا شكْ ثْسڭّْذذْ،
\m نِيغْ ذ ڒفْضڒْ مَاڒَا شكْ ثڭُّورذْ
\m ذڭْ إِبْرِيذنْ نّشْ س ڒصْفَايثْ؟
\m 
\v 4 مَا إِوْثِي إِ شكْ
\m زِي سِّيبّثْ ن ثِيڭّْوُوذِي نّشْ \add زَّايسْ\add*،
\m نِيغْ أَذْ يَاذفْ أَكِيذكْ غَارْ ثَادَّارْثْ ن شّْرعْ؟
\m 
\v 5 مَا وَارْ ثدْجِي ثُوعفّْنَا نّشْ
\m ذ ثَامقّْرَانْثْ،
\m ؤُ ڒْمُوعْصِييَّاثْ نّشْ
\m \add مَا وَارْ دْجِينْثْ\add* نْهْڒَا أَسْبذِّي؟
\b
\m 
\v 6 مَاغَارْ ثْحوّْسذْ دِّييّثْ
\m زڭْ أَيْثْمَاشْ بَاطڒْ،
\m ثكّْسذْ أَرُّوضْ
\m إِ يِينِّي س ذْرُوسْ ن ورُّوضْ وَاهَا. \x ◘ \xo 22:‏6 \xt ؤُف. 22‏:‏26، 27؛ أَعَوذ. 24‏:‏6، 10‏-‏13؛ أَيُوبْ 31‏:‏1‏-‏34\x*
\m 
\v 7 ونِّي يُوحْڒنْ وَارْ ذ أَسْ ثوْشِيذْ أَذْ إِسُو،
\m ونِّي إِدْجُوزنْ ثْقضْعذْ أَسْ أَغْرُومْ.
\m 
\v 8 \add مَاشَا\add* مَاڒَا ذِينْ أَرْيَازْ س ؤُغِيڒْ إِجْهذْ،
\m \add خنِّي\add* ثَامُّورْثْ أَقَا-ت إِ وَانِيثَا،
\m أَذْ ذَايسْ إِزْذغْ شَا ن ورْيَازْ ن شَّانْ.
\m 
\v 9 ثِيجَّاڒْ ثْسكّذْ ثنْثْ س إِفَاسّنْ خْوَانْ،
\m إِغَادْجنْ ن ؤُيُوجِيڒْ تّْوَاڒبْزنْ.
\b
\m 
\v 10 خْ ؤُيَا نّْضنْثْ أَشْ ڒفْخُوخْ،
\m ؤُشَا ثوْضَاذْ-د خَاكْ ثِيڭّْوُوذِي.
\m 
\v 11 نِيغْ وَارْ ثتّْوِيڒِيذْ ثَادْجسْثْ،
\m ذ ڒْحمْڒثْ ن وَامَانْ نِّي شكْ يذْڒِينْ؟
\b
\m 
\v 12 مَا وَارْ إِدْجِي أَربِّي يُوعْڒَا ذڭْ ؤُجنَّا؟
\m خْزَارْ إِثْرَانْ \add نِّي إِدْجَانْ\add* سنّجْ قَاعْ،
\m مَامّشْ عُودْجنْ!
\m 
\v 13 \add مَاشَا\add* ثقَّارذْ: ’مِينْ إِسّنْ أَربِّي؟
\m مَا إِزمَّارْ أَذْ إِحْكمْ \add نِيشَانْ\add*
\m زڭْ ؤُسيْنُو إِبُّومْبْسنْ؟
\m 
\v 14 إِسيْنُوثنْ ذ أَڒحّفْ إِ نتَّا
\m أَڒَامِي وَارْ إِتّْوِيڒِي،
\m ؤُ خْ ڒْقُوبّثْ ن ؤُجنَّا إِڭُّورْ نتَّا.‘
\b
\m 
\v 15 مَا ثخْسذْ أَذْ ثضْفَارضْ أَمسْرُوقْ ن وشْحَاڒْ ؤُيَا،
\m أَمسْرُوقْ نِّي كِّينْ يرْيَازنْ
\m \add إِشُّورنْ\add* س ڒْمُوعْصِييّثْ،
\m 
\v 16 إِنِّي إِتّْوَاكّْسنْ أَمْ وَارْ د-يِيوِيضْ \add عَاذْ\add*
\m ڒْمِيجَاڒْ نْسنْ،
\m \add ؤُمِي\add* ثْفيّضْ ڒْحمْڒثْ ذْسَاسْ نْسنْ،
\m 
\v 17 إِنِّي إِنَّانْ إِ أَربِّي: ’أَڭّْوجْ خَانغْ!‘
\m مِينْ إِزمَّارْ ؤُمْزمَّارْ خْ كُوڒْشِي
\m أَذْ يڭّْ \add عَاذْ\add* إِ نِيثْنِي؟ \x ◘ \xo 22:‏17 \xt أَيُوبْ 21‏:‏14\x*
\m 
\v 18 إِوَا، وَاخَّا نتَّا إِشُّورْ
\m ثُوذْرِينْ نْسنْ س ڒْخَارْ!
\m شّْوَارْ ن إِعفَّاننْ إِڭّْوجْ خَافِي. \x ◘ \xo 22:‏18 \xt أَيُوبْ 21‏:‏16\x*
\b
\m 
\v 19 ژْرِينْ ت إِمْسڭَّاذنْ ؤُشَا فَارْحنْ،
\m أَمزْذَاڭْ إِسْثهْزَا زَّايْسنْ. \x ◘ \xo 22:‏19 \xt إِزهد. 107‏:‏42\x*
\m 
\v 20 ’أَغْرِيمْ نّغْ إِتّْوَاكحّضْ
\m ؤُ مِينْ زَّايْسنْ إِقِّيمنْ ثشَّا إِ-ث ثْمسِّي.‘
\b
\m 
\v 21 قّنْ غَارسْ، أَذْ غَاركْ ثِيڒِي ڒْهُوذْنثْ،
\m س ؤُيَا أَذْ غَاركْ د-يَاسْ مِينْ إِصبْحنْ.
\m 
\v 22 كْسِي خنِّي ثَاغُورِي زڭْ ؤُقمُّومْ نّسْ،
\m أڭّْ أَوَاڒنْ نّسْ ذڭْ وُوڒْ نّشْ.
\m 
\v 23 مَاڒَا ثْذوْڒذْ-د
\m غَارْ ؤُمْزمَّارْ خْ كُوڒْشِي،
\m أَذْ ثتّْوَاسّْبدّذْ.
\m سِيڭّْوجْ مِينْ وَارْ إِسڭّْذنْ
\m خْ ثْقِيضُونِينْ نّشْ. \x ◘ \xo 22:‏23 \xt أَيُوبْ 8‏:‏5، 6\x*
\m 
\v 24 سَارْسْ ؤُرغْ إِقُّورنْ ذڭْ ؤُشَاڒْ،
\m ؤُرغْ زِي ؤُفِيرْ جَارْ إِژْرَا ن ثْغزْرَاثِينْ.
\b
\m 
\v 25 \add خنِّي\add* أَمْزمَّارْ خْ كُوڒْشِي
\m أَذْ يِيڒِي \add أَمشْنَاوْ\add* ؤُرغْ إِقُّورنْ نّشْ،
\m \add أَمشْنَاوْ\add* إِذُورَارْ يُوعْڒَانْ ن نُّوقَارْثْ إِ شكْ!
\b
\m 
\v 26 مَاغَارْ خنِّي أَذْ ثْفَارْحضْ
\m زڭْ ؤُمْزمَّارْ خْ كُوڒْشِي،
\m أَذْ ثسّْڭعّْذذْ أَغمْبُوبْ نّشْ
\m غَارْ أَربِّي.
\m 
\v 27 أَذْ أَسْ ثتَّارذْ س ثْژَادْجِيثْ يُودْجْغنْ
\m ؤُ نتَّا أَذْ أَشْ إِسڒْ،
\m ؤُ شكْ أَذْ ثْكمّْڒذْ لْوُوعُوذْ نّشْ.
\m 
\v 28 مَاڒَا ثكّْسذْ أَوَاڒْ،
\m خنِّي أَذْ أَشْ د-ثفّغْ \add ثْمسْڒَاشْثْ\add*،
\m ؤُ ثَافَاوْثْ أَذْ ثَارغْ ذڭْ إِبْرِيذنْ نّشْ.
\m 
\v 29 مَاڒَا سّهْوَانْ نِيثْنِي إِجّنْ، أَذْ ثِينِيذْ:
\m ’سْڭعّذْ \add أَزدْجِيفْ نّشْ\add*!‘،
\m نتَّا أَذْ إِسّنْجمْ
\m ونِّي إِسّْهكّْوَانْ ثِيطَّاوِينْ نّسْ. \x ◘ \xo 22:‏29 \xt أَوڒن. 29‏:‏23\x*
\m 
\v 30 نتَّا أَذْ إِسّنْجمْ
\m ونِّي وَارْ إِدْجِينْ بْڒَا ڒْعِيبْ،
\m مِينْزِي نتَّا أَذْ إِنْجمْ
\m س ثزْذُوڭِي ن إِفَاسّنْ نّشْ!
\b
\b
\c 23
\s1 ثَامْوَارِّيثْ ن أَيُوبْ خْ إِلِيفَازْ ذ وذْفَاعْ نّسْ زَّاثْ إِ أَربِّي
\m 
\v 1 يَارَّا-د \bd أَيُوبْ\bd*، إِنَّا:
\b
\m 
\v 2 ؤُڒَا ذ أَسّْ-أَ أَشثْشِي إِنُو ذ أَغنَّانْ،
\m إِسّذْقڒْ أَفُوسْ إِنُو خْ ؤُنفّسْ إِنُو.
\m 
\v 3 مْڒِي سّْنغْ، مَانِي زمَّارغْ أَذْ ث أَفغْ،
\m مَاحنْذْ أَذْ أَوْضغْ غَارْ ثْزذِّيغْثْ نّسْ.
\m 
\v 4 \add خنِّي\add* أَذْ بزّْعغْ زَّاثسْ دّعْوثْ،
\m أَذْ شُّورغْ أَقمُّومْ إِنُو
\m س وَاوَاڒنْ إِ ؤُشَارّعْ.
\m 
\v 5 أَذْ سّْنغْ أَوَاڒنْ إِ خَافِي د غَا يَارّْ،
\m أَذْ فهْمغْ مِينْ إِ ذ أَيِي غَا يِينِي.
\b
\m 
\v 6 مَا إِتّْخصَّا أَسْ أَذْ إِمْشَارّعْ أَكِيذِي
\m س جّْهذْ أَمقّْرَانْ؟
\m لَّ، أجّْ إِ-ث أَذْ أَيِي إِوْشْ \add ثَايْنِيثْ وَاهَا\add*.
\m 
\v 7 ذِينِّي أَذْ كِيذسْ إِمْشَارّعْ ونِّي إِشْنَانْ
\m ؤُ \add أَمُّو\add* نشّْ أَذْ نُّوفْسْڒغْ إِ ڒبْذَا زِي ڒْقَاضِي إِنُو.
\m 
\v 8 \add مَاشَا\add* خْزَارْ، مَاڒَا ؤُيُورغْ غَارْ شَّارْقْ،
\m \add أَمُّو\add* وَارْ ذِينْ إِدْجِي نتَّا،
\m ؤُ مَاڒَا \add ؤُيُورغْ\add* غَارْ ڒْغَارْبْ،
\m \add أَمُّو\add* وَارْ ذ أَسْ تّْحكَّارغْ.
\m 
\v 9 مَاڒَا غَارسْ شْغڒْ ذِي شَّامَالْ،
\m وَارْ ث تّْوِيڒِيغْ،
\m \add مَاڒَا\add* إِنّقْڒبْ-د غَارْ لْجَانُوبْ،
\m وَارْ ث ژَترّغْ.
\b
\m 
\v 10 مَاشَا نتَّا إِسّنْ أَبْرِيذْ إِ ڭُّورغْ،
\m إِتّْقدْجبْ أَيِي، أَذْ فّْغغْ أَمْ وُورغْ.
\m 
\v 11 إِمْنعْ ؤُضَارْ إِنُو ذِي جُّورَّاثْ نّسْ،
\m أَبْرِيذْ نّسْ ضْفَارغْ ث، وَارْ زَّايسْ فِّيغغْ. \x ◘ \xo 23:‏11 \xt أَيُوبْ 31‏:‏4‏-‏8\x*
\m 
\v 12 ثَاوْصِييّثْ زڭْ ؤُقمُّومْ نّسْ
\m وَارْ زَّايسْ أَرْخُوغْ.
\m أَوَاڒنْ ن ؤُقمُّومْ نّسْ خمّْڒغْ ثنْ،
\m مَاهُو مِينْ خفْ تّْوَاوصِّيغْ.
\m 
\v 13 \add مَاشَا\add* مَاڒَا نتَّا ضِيدّْ ن شَا ن يِيجّنْ،
\m مَانْ ونْ إِ ث غَا إِمنْعنْ زِي مَانْ أَيَا؟
\m مِينْ إِخْسْ ڒعْمَارْ نّسْ، أَذْ ث يڭّْ. \x ◘ \xo 23:‏13 \xt إِزهد. 115‏:‏3\x*
\b
\m 
\v 14 مَاغَارْ نتَّا إِسّقْفَاڒْ مِينْ إِ ذ أَيِي يُورَا،
\m ؤُ أَقَا ذِينْ أَطَّاسْ ن ثْمسْڒَايِينْ
\m أَمْ ثِينَا غَارسْ \add ذِي ڒْبَاڒْ\add*.
\m 
\v 15 خْ ؤُيَا تّْنخْڒَاعغْ زَّاثْ إِ ؤُغمْبُوبْ نّسْ،
\m أَقَا فهْمغْ ت مْلِيحْ،
\m ؤُ تّڭّْوذغْ زَّايسْ.
\m 
\v 16 \add مَاغَارْ\add* أَربِّي إِسّفْشِيڒْ ؤُڒْ إِنُو،
\m أَمْزمَّارْ خْ كُوڒْشِي إِسّْنخْڒَاعْ أَيِي.
\m 
\v 17 مَاغَارْ وَارْ تّْنخْڒِيعغْ زِي ثَادْجسْثْ،
\m ؤُڒَا زڭْ وُوذمْ إِنُو
\m نِّي إِتّْڒحّفْ س ثُوبَّارْشنْثْ.
\b
\b
\c 24
\s1 أَيُوبْ إِسّقْسَا إِلِيفَازْ خْ مِينْ ث إِشْقَانْ إِ أَربِّي إِنِّي إِتّْوَاحْصَارنْ
\m 
\v 1 مَايمِّي وَارْ تّْوَاسّْنُوفَّارنْثْ
\m ڒْْمِيجَاڒَاثْ \add ن ؤُخدْجصْ\add*
\m س ؤُفُوسْ ن ونِّي إِدْجَانْ ذ أَمْزمَّارْ خْ كُوڒْشِي،
\m \add مَايمِّي\add* وَارْ تّْوِيڒِينْ إِنِّي ث إِسّْننْ
\m ؤُسَّانْ نّسْ \add ن نّقْمثْ\add*؟
\m 
\v 2 نِيثْنِي سّْمُوطُّوينْ ڒهْذُوذْ،
\m تَّاشَارنْ ثَاحِيمَارْثْ ؤُشَا أَركّْوْسنْ ت. \x ◘ \xo 24:‏2 \xt أَعَوذ. 19‏:‏14؛ 27‏:‏17؛ أَوڒن. 22‏:‏28؛ 23‏:‏10\x*
\m 
\v 3 أَغْيُوڒْ ن إِيُوجِيڒنْ سَّاڭّْوَاجنْ ث،
\m تّْحوّْسنْ أَفُونَاسْ ن ثَاجَّاتْشْ.
\m 
\v 4 نِيثْنِي عَارّْننْ إِمزْڒَاضْ زڭْ وبْرِيذْ.
\m إِنِّي إِتّْوَاحْصَارنْ ذِي ثمُّورْثْ
\m تّْنُوفَّارنْ جْمِيعْ. \x ◘ \xo 24:‏4 \xt أَوڒن. 28‏:‏28\x*
\b
\m 
\v 5 خْزَارْ، أَقَا أَثنْ أَمْ يِيغْيَاڒْ ن ڒخْڒَا.
\m تّفّْغنْ غَارْ ڒْخذْمثْ نْسنْ،
\m أَرزُّونْ ثَانيْمَارْثْ.
\m ڒخْڒَا إِوْشَا أَسْ مَاشَّا إِ إِحنْجِيرنْ نْسنْ.
\m 
\v 6 ذڭْ إِيَّارْ حتّْشنْ ڒحْثِيشْ نّسْ،
\m ڒقّْضنْ ذڭْ ؤُمَارْجعْ ن ؤُضِيڒْ نْ إِعفَّاننْ.
\m 
\v 7 سّْعدُّونْ دْجِيڒثْ ذ إِعَارْيَاننْ، نْهْڒَا أَرُّوضْ،
\m وَارْ غَارْسنْ بُو دُّورِي ذِي ثصْمضْ.
\m 
\v 8 زڭْ ونْژَارْ إِشَّاثنْ زڭْ إِذُورَارْ تُّوفّنْ،
\m تّْشبَّارنْ ذِي جَّارْفْ
\m مَاغَارْ وَارْ غَارْسنْ أَذُورِّي.
\b
\m 
\v 9 زڭْ إِفَّانْ ن \add يمَّاثْسنْ\add* تّكّْسنْ أَيُوجِيڒْ،
\m ؤُشَا تّطّْفنْ أَضْمَانْ زڭْ ؤُمزْڒُوضْ.
\m 
\v 10 ڭُّورنْ ذ إِعَارْيَاننْ، نْهْڒَا أَرُّوضْ،
\m أَمْ دْجُوژنْ أَربُّونْ إِشوَّافنْ \add ن إِمنْذِي\add*. \x ◘ \xo 24:‏10 \xt لَاوِي 19‏:‏13\x*
\m 
\v 11 جَارْ ڒحْيُوضْ تّْعسَّارنْ زّشْثْ،
\m عفّْسنْ خْ ثْسِيرْثْ ن ؤُضِيرْ،
\m مَاشَا تّْغِيمَانْ فُّوذنْ. \x ◘ \xo 24:‏11 \xt أَعَوذ. 25‏:‏4؛ يَاع. 5‏:‏4\x*
\m 
\v 12 زِي ثنْذِينْثْ إِتّفّغْ-د ڒْحسّْ
\m ن ؤُسغْنفْ ن يرْيَازنْ،
\m ڒعْمَارْ ن يِينِّي إِسُّوفّْغنْ بُوحْبڒْ
\m إِسْغُويُّو ذڭْ ؤُجنَّا.
\m \add وَاخَّا أَمنِّي\add* أَربِّي وَارْ إِحطِّي
\m مِينْ وَارْ إِحْڒِينْ.
\b
\m 
\v 13 إِنّغْنِي ذ إِمْغوّْغنْ خْ ثْفَاوْثْ،
\m وَارْ سِّيننْ إِبْرِيذنْ نّسْ،
\m وَارْ تّْغِيمِينْ ذِي ثِيبْرِيذِينْ نّسْ.
\m 
\v 14 قْبڒْ \add د-ثُوسَا\add* ثْفَاوْثْ، إِتّكَّارْ ؤُقتَّاڒْ،
\m إِنقّْ ڒْمسْكِينْ ذ ؤُمزْڒُوضْ
\m ؤُ ذِي دْجِيڒثْ إِڭَّا أَمْ ؤُخوَّانْ. \x ◘ \xo 24:‏14 \xt إِزهد. 10‏:‏8، 9\x*
\m 
\v 15 ثِيطّْ ن ؤُزنَّايْ ثْحطَّا ثَادْجسْثْ.
\m إِقَّارْ: ’ؤُڒَا ذ إِشْثْ ن ثِيطّْ وَارْ ذ أَيِي ثْحطِّي!‘
\m إِڒحّفْ إِ ؤُغمْبُوبْ نّسْ. \x ◘ \xo 24:‏15 \xt إِزهد. 10‏:‏11؛ أَوڒن. 7‏:‏8، 9\x*
\b
\m 
\v 16 ذِي ثَادْجسْثْ تَّاذْفنْ غَارْ ثُوذْرِينْ.
\m س وَاسّْ تّْنُوفَّارنْ،
\m وَارْ سِّيننْ وَالُو خْ ثْفَاوْثْ. \x ◘ \xo 24:‏16 \xt أَيُوبْ 38‏:‏15؛ يُوح. 3‏:‏20\x*
\m 
\v 17 مَاغَارْ ثُوفُّوثْ \add ثْبَانْ\add* أَسنْ-د أَمْ ثِيڒِي ن ڒْموْثْ،
\m مَاغَارْ سّْننْ إِنخْڒِيعنْ ن ثِيڒِي ن ڒْموْثْ.
\b
\m 
\v 18 نتَّا ذ أَفْسُوسْ \add أَمْ ؤُكُوفُّو\add*
\m خْ وُوذمْ ن وَامَانْ إِ يدْجَا.
\m ثتّْوَانْعڒْ ثسْغَارْثْ نْسنْ خْ ثمُّورْثْ.
\m وَارْ إِتّطّفْ \add عَاذْ\add* أَبْرِيذْ
\m غَارْ إِمَارْجَاعنْ ن ؤُضِيڒْ.
\m 
\v 19 ڒَاژَاغْ ذ ڒحْمُو قطَّانْ
\m خْ وَامَانْ ن وذْفڒْ،
\m \add أَمُّو إِ ثتّكّسْ\add* ڒَاخَارْثْ ؤُڒَا ذ إِنِّي إِخْضَانْ.
\m 
\v 20 أَعذِّيسْ ن يمَّاسْ أَذْ ث إِتُّو،
\m إِكشَّاونْ أَذْ زَّايسْ أَرّنْ مژْرِي.
\m عمَّارْصْ وَارْ ث تِّيذَارنْ \add عَاذْ\add*.
\m إِتّْوَارْژْ ڒْغشّْ أَمْ \add إِشْثْ ن ثْفْروْثْ ن\add* ؤُكشُّوضْ،
\m 
\v 21 \add أَمُّو ؤُڒَا ذ\add* ونِّي إِتّڭّنْ ڒْغَارْ
\m ذِي ثمْغَارْثْ بْڒَا ثَارْوَا،
\m ذِي ثنِّي وَارْ إِتِّيرْونْ،
\m ؤُڒَا ذ ونِّي إِتّڭّنْ
\m مِينْ وَارْ إِحْڒِينْ أَكْ-ذ ثَاجَّاتْشْ.
\b
\m 
\v 22 س جّهْذْ نّسْ إِسّْبدَّا
\m إِنِّي غَارْ ثدْجَا صُّولْطَا.
\m إِبدّْ وَانِيثَا، \add مَاشَا\add* وَارْ إِسِّينْ نِيشَانْ
\m أَقَا ثُوذَارْثْ نّسْ ذِي ڒَامَانْ.
\m 
\v 23 نتَّا إِوْشَا أَسْ ڒَامَانْ،
\m \add أَڒَامِي\add* غَارسْ د-ثُوذفْ تِّيقّثْ،
\m \add عَاذْ\add* ثِيطَّاوِينْ نّسْ
\m أَقَا أَثنْثْ خْ وبْرِيذْ نْسنْ.
\m 
\v 24 تّْوَاسُّوعْڒَانْ إِ يِيجّْ ن ڒْحَاڒْ ذ أَقُوضَاضْ،
\m خنِّي وَارْ دْجِينْ \add عَاذْ\add*.
\m أَذْ هْوَانْ، أَذْ تّْوَاكّْسنْ
\m أَمْ مَارَّا \add إِوْذَانْ\add*،
\m أَمْ إِخْفَاونْ ن ؤُغدُّويْ \add ن يِيرْذنْ\add*
\m أَذْ تّْوَاقسّنْ.
\m 
\v 25 مَا وَارْ إِدْجِي أَمنِّي؟
\m مَانْ ونْ إِ ذ أَيِي غَا إِطّْفنْ إِخَارِّيقنْ،
\m \add مَانْ ونْ إِ غَا\add* إِسّبْضڒْ ڒْهَارْذْ إِنُو؟
\b
\b
\c 25
\s1 ڒْحَارْضْ وِيسّْ ثْڒَاثَا ن بِيلْذَاذْ
\m 
\v 1 \add خَاسْ ؤُشَا\add* يَارَّا-د \bd بِيلْذَاذْ\bd*، إِ د-يُوسِينْ زِي شُوحَا، إِنَّا:
\b
\m 
\v 2 صُّولْطَا ذ جّهْذْ إِسَّاڭّْوَاذنْ
\m أَقَا أَثنْ غَارسْ،
\m نتَّا إِتّڭّْ ڒهْنَا ذِي ڒُوعْڒَا نّسْ.
\m 
\v 3 مَا إِزمَّارْ أَذْ حسْبنْ
\m مشْحَاڒْ إِ غَارسْ ن ڒْعسْكَارْ؟
\m خْ مَانْ وَارْ ثتّْڭعّذْ ثْفَاوْثْ نّسْ؟
\m 
\v 4 مَامّشْ \add خنِّي\add* \add إِزمَّارْ\add* بْنَاذمْ
\m أَذْ يِيڒِي ذ أَمْسڭّذْ زَّاثْ إِ أَربِّي،
\m مَامّشْ إِزمَّارْ
\m ونِّي د-إِتّْوَارْونْ زِي ثمْغَارْثْ
\m أَذْ يِيڒِي ذ أَمزْذَاڭْ؟ \x ◘ \xo 25:‏4 \xt أَيُوبْ 4‏:‏17، 18، 19؛ 15‏:‏14، 15، 16\x*
\m 
\v 5 خْزَارْ، عَاذْ ثَازِيرِي سِيمَانْثْ نّسْ
\m وَارْ ثتّْوسّڭْ س ڒصْفَايثْ،
\m إِثْرَانْ وَارْ صْفِينْ ذِي ثِيطَّاوِينْ نّسْ. \x ◘ \xo 25:‏5 \xt أَيُوبْ 15‏:‏15\x*
\m 
\v 6 أَهْثَا عَاذْ بْنَاذمْ، \add ونِّي\add* ذ أَوكِّي،
\m ؤُ مِّيسْ ن بْنَاذمْ، \add ونِّي\add* ذ أَكشَّاوْ. \x ◘ \xo 25:‏6 \xt أَيُوبْ 4‏:‏19؛ إِزهد. 22‏:‏7\x*
\b
\b
\c 26
\s1 ثَامْوَارِّيثْ ن أَيُوبْ خْ بِيلْذَاذْ: ڒمْغَارثْ ن أَربِّي
\m 
\v 1 \add خَاسْ ؤُشَا\add* يَارَّا-د \bd أَيُوبْ\bd*، إِنَّا:
\b
\m 
\v 2 مَامّشْ ثڭِّيذْ ثوْشِيذْ أَفُوسْ
\m إِ ونِّي وَارْ غَارْ إِدْجِي جّهْذْ،
\m \add مَامّشْ\add* ثْبدّذْ غَارْ ؤُغِيڒْ
\m ن ونِّي وَارْ غَارْ ثدْجِي ثْزمَّارْ!
\m 
\v 3 زعْمَا أَقَا ثوْشِيذْ أَوصِّي إِسبْحنْ
\m إِ ونِّي وَارْ غَارْ ثدْجِي ثِيغِيثْ،
\m \add مَامّشْ\add* إِ ثسَّارْڭْبذْ أَطَّاسْ \add ن ثْوَاڒَاوِينْ\add*
\m مُومُّو \add ن ثْمسْڒَاشْثْ\add*!
\m 
\v 4 إِ ؤُمِي ثْعَاوْذذْ \add ڒخُّو\add* أَوَاڒنْ نّشْ؟
\m مَانْ نّفْسْ د-إِفّْغنْ زَّايكْ؟
\b
\m 
\v 5 ڒخْيَاڒَاثْ \add ن إِمتَّانْ\add* فسّْينْ
\m سَاذُو وَامَانْ ذ إِمزْذَاغْ نْسنْ.
\m 
\v 6 ذ أَعَارْيَانْ ثزّڒْ زَّاثسْ ڒَاخَارْثْ،
\m وَارْ \add ذِينْ\add* ثدْجِي ثْقبَّارْثْ إِ \add ثسْرَافْثْ ن\add* ؤُهلّكْ. \x ◘ \xo 26:‏6 \xt إِزهد. 139‏:‏8، 11؛ أَوڒن. 15‏:‏11؛ عبر. 4‏:‏13\x*
\m 
\v 7 إِبزّعْ \add أَجنَّا\add* ذِي شَّامَالْ
\m ثِيوَا ڒْخَاوِي ن \add وُوذمْ ن وَامَانْ\add*،
\m يُويڒْ ثَامُّورْثْ غَارْ وَالُو. \x ◘ \xo 26:‏7 \xt إِزهد. 104‏:‏2 \x*
\b
\m 
\v 8 نتَّا إِتّْشدَّا أَمَانْ ذڭْ إِسيْنُوثنْ نّسْ،
\m \add مَاشَا\add* وَارْ إِتَّارژِّي أَسيْنُو سْوَادَّايْ.
\m 
\v 9 إِسّْذُورُّويْ ؤُذمْ ن ڒْعَارْشْ نّسْ،
\m إِتّْبزَّاعْ خَاسْ أَسيْنُو نّسْ. \x ◘ \xo 26:‏9 \xt أَيُوبْ 9‏:‏8؛ إِزهد. 104‏:‏2، 3\x*
\m 
\v 10 يَارْشمْ ثَاقُورَاشْثْ خْ وُوذمْ ن وَامَانْ،
\m أَڒْ ثْمَا ن ثْفَاوْثْ أَكْ-ذ ثَادْجسْثْ. \x ◘ \xo 26:‏10 \xt أَمز. 1‏:‏9؛ أَيُوبْ 38‏:‏8؛ إِزهد. 33‏:‏7؛ 104‏:‏9؛ أَوڒن. 8‏:‏29؛ إِرْم. 5‏:‏22\x*
\b
\m 
\v 11 إِپِيلَارنْ ن ؤُجنَّا تَّارْجِيجِينْ،
\m تّْنخْڒَاعنْ زڭْ ؤُودّبْ نّسْ.
\m 
\v 12 س جّهْذْ نّسْ إِسّْهَاجْ ڒبْحَارْ،
\m س ڒفْهَامثْ نّسْ إِڒْبزْ رَاهَابْ. \x ◘ \xo 26:‏12 \xt إِشا. 51‏:‏15\x*
\m 
\v 13 س أَرُّوحْ نّسْ إِتِّيسِّيقْ ؤُجنَّا
\m \add أَمْ وُوذمْ ن ثنِّي وَارْ إِتّْڒحِّيفنْ\add*،
\m أَفُوسْ نّسْ إِسّْنُوقّبْ
\m أَفِيغَارْ إِتّحْڒُودْجُوضنْ س ثَازْڒَا. \x ◘ \xo 26:‏13 \xt إِزهد. 33‏:‏6\x*
\b
\m 
\v 14 خْزَارْ، مَانْ أَيَا \add وَاهَا\add*
\m إِخفْ ن إِبْرِيذنْ نّسْ،
\m نسْڒَا \add مْغِيرْ\add* ثَاحسّشْثْ
\m ن \add شَا ن\add* وَاوَاڒنْ زَّايسْ.
\m وِي إِزمَّارنْ \add خنِّي\add*
\m أَذْ إِسّنْ أَجَّاجْ ن جّْهذْ نّسْ؟
\b
\b
\c 27
\s1 ڒْهَارْدْْ ن أَيُوبْ خْ إِعفَّاننْ
\m 
\v 1 يَارْنِي إِسّْڭعّذْ \bd أَيُوبْ\bd* ڒْهَارْذْ ن لْمَاثَالْ نّسْ، إِنَّا:
\b
\m 
\v 2 س ثِيذتّْ أَمْ إِدَّارْ أَربِّي
\m نِّي إِ ذ أَيِي إِكّْسنْ ثَاسْغَارْثْ إِنُو،
\m أَمْزمَّارْ خْ كُوڒْشِي
\m نِّي إِسَّارْزَاڭنْ ڒعْمَارْ إِنُو،
\m 
\v 3 مِينْ غَا يكّْ نّفْسْ عَاذْ ذَايِي
\m ؤُ أَرُّوحْ ن أَربِّي \add عَاذْ\add* ذڭْ ونْزَارنْ إِنُو،
\m 
\v 4 وَارْ قَّارنْ إِينْشِيشنْ إِنُو ڒْغشّْ
\m ؤُ إِڒسْ إِنُو وَارْ إِقَّارْ إِخَارِّيقنْ!
\m 
\v 5 إِڭّْوجْ خَافِي أَذْ ڭّغْ كنِّيوْ
\m ذِي ثْسيَّارسْثْ ن ثِيذتّْ.
\m أَڒْ غَا سُّوفّْغغْ بُوحْبڒْ إِنُو،
\m وَارْ تّجِّيغْ أَذْ خَافِي كّْسنْ أَسڭّذْ إِنُو.
\m 
\v 6 أَذْ طّْفغْ ذِي ثْسڭْذَا إِنُو،
\m وَارْ زَّايسْ أَرخُّوغْ شَا.
\m ؤُڒْ إِنُو وَارْ ذ أَسْ يَارخُّو
\m ؤُڒَا خْ إِجّنْ زڭْ وُوسَّانْ إِنُو.
\m 
\v 7 مْڒِي د-إِبَانْ ڒعْذُو إِنُو ذ أَعفَّانْ،
\m ونِّي أَكِيذِي إِتّْمنْغَانْ
\m ذ مِّيسْ ن ڒْمُوعْصِييّثْ.
\b
\m 
\v 8 مَاغَارْ مَانْ ڒَايَاسْ ن ؤُمْنَافقْ،
\m خْمِي غَا ثتّْوَاقْضعْ \add ثُوذَارْثْ نّسْ\add*،
\m خْمِي زَّايسْ إِ غَا إِقْڒعْ أَربِّي ڒعْمَارْ نّسْ؟ \x ◘ \xo 27:‏8 \xt مت. 16‏:‏26؛ لك. 12‏:‏20\x*
\m 
\v 9 مَا أَذْ إِسڒْ أَربِّي إِ إِغُويَّانْ نّسْ،
\m خْمِي خَاسْ د غَا إِوْضَا ڒْحصْرَانْ؟ \x ◘ \xo 27:‏9 \xt أَيُوبْ 35‏:‏12؛ إِزهد. 18‏:‏42؛ 109‏:‏7؛ أَوڒن. 1‏:‏28؛ 28‏:‏9؛ إِشا. 1‏:‏15؛ إِرْم. 14‏:‏12؛ حِز. 8‏:‏18؛ مِيخَا 3‏:‏4؛ يُوح. 9‏:‏31؛ يَاع. 4‏:‏3\x*
\m 
\v 10 مَا أَذْ إِفَارْحْ غَارْ ؤُمْزمَّارْ خْ كُوڒْشِي؟
\m مَا أَذْ إِڒَاغَا خْ أَربِّي مڒْمِي مَا؟
\m 
\v 11 نشّْ أَذْ أَومْ سّْڒمْذغْ خْ ؤُفُوسْ ن أَربِّي،
\m مِينْ إِعوّڒْ ؤُمْزمَّارْ خْ كُوڒْشِي،
\m وَارْ ث سّْنُوفَّارغْ.
\m 
\v 12 خْزَارْ، كنِّيوْ مَارَّا إِذْومْ ثژْرِيمْ \add ث\add*.
\m مَايمِّي ثَارنّْيمْ
\m ثسُّوفُّوغمْ مِينْ إِبطّْڒنْ \add ثقَّارمْ\add*:
\b
\m 
\v 13 ”ثَا ذ ثَاسْغَارْثْ ن بْنَاذمْ أَعفَّانْ غَارْ سِيذِي،
\m ثَاسْغَارْثْ ن أَيْثْ ن بُو-ڒخْشُونثْ
\m نِّي إِ غَا طّْفنْ زڭْ ؤُمْزمَّارْ خْ كُوڒْشِي: \x ◘ \xo 27:‏13 \xt أَيُوبْ 20‏:‏29\x*
\m 
\v 14 خْمِي غَا مَّارنْينْ إِحنْجِيرنْ نّسْ،
\m إِ سِّيفْ ؤُمِي ؤُرِينْ.
\m إِغدُّوثنْ نّسْ وَارْ تّْيَاوَاننْ أَغْرُومْ، \f ◼ \fr 27:‏14 \ft \bd ’إِغدُّوثنْ‘\bd* - إِخْسْ أَذْ يِينِي ’إِحنْجِيرنْ نّسْ‘.\f*  \x ◘ \xo 27:‏14 \xt أَعَوذ. 28‏:‏41؛ حُوش. 9‏:‏13\x*
\m 
\v 15 وِي زَّايسْ إِ غَا يَاروْڒنْ
\m أَذْ تّْوَانضْڒنْ س طَّاعُونْ،
\m ثِيجَّاڒْ نّسْ وَارْ تّْرُونْثْ شَا. \x ◘ \xo 27:‏15 \xt إِزهد. 78‏:‏64\x*
\m 
\v 16 وَاخَّا إِجَارُّووْ نُّوقَارْثْ أَنشْثْ ن ؤُشَاڒْ،
\m ؤُ إِسّوْجَاذْ أَرُّوضْ أَنشْثْ ن ؤُشَاڒْ،
\m 
\v 17 \add إِوَا، وَاخَّا\add* أَذْ ث إِسّوْجذْ،
\m أَمْسڭّذْ أَذْ زَّايسْ يَارْضْ
\m ؤُشَا أَمزْذَاڭْ أَذْ إِبْضَا نُّوقَارْثْ. \x ◘ \xo 27:‏17 \xt أَوڒن. 28‏:‏8؛ أَمب. 2‏:‏26\x*
\m 
\v 18 أَذْ إِبْنَا ثَادَّارْثْ نّسْ أَمْ ثْشِينْذَا،
\m أَمشْنَاوْ ثَانْوَالْثْ
\m إِ إِسّْبدَّا ؤُعسَّاسْ \add إِ يِيخفْ نّسْ\add*.
\b
\m 
\v 19 أَذْ \add ذَايسْ\add* إِطّصْ ذ بُو-وَاڭْڒَا،
\m \add مَاشَا\add* وَارْ يَارنِّي ذڭْ وَاڭْڒَا نّسْ.
\m مَاڒَا يَارْزمْ ثِيطَّاوِينْ نّسْ،
\m وَارْ ذِينْ إِتّْغِيمِي \add عَاذْ\add* وَالُو. \x ◘ \xo 27:‏19 \xt إِزهد. 49‏:‏18\x*
\m 
\v 20 إِنخْڒِيعنْ أَذْ خَاسْ أَرنْينْ
\m أَمْ \add إِغزْرَانْ ن\add* وَامَانْ،
\m ثَاحَارْيَاضْثْ أَذْ ث-إِ-د-ثقْضعْ س دْجِيڒثْ. \x ◘ \xo 27:‏20 \xt أَيُوبْ 15‏:‏21؛ 18‏:‏11\x*
\m 
\v 21 أَسمِّيضْ زِي شَّارْقْ أَذْ ث إِكْسِي،
\m إِوَا ذِينِّي إِتّْرَاحْ،
\m أَذْ ث-إِ-د-إِقْڒعْ زڭْ ومْشَانْ نّسْ.
\m 
\v 22 \add أَربِّي\add* أَذْ إِسِّيوضْ مَارَّا أَيَا
\m خْ ؤُزدْجِيفْ نّسْ، وَارْ خَاسْ إِسّْعِيزِّي شَا.
\m أَذْ يَارْوڒْ ذغْيَا زِي \add ثشْثِي ن\add* ؤُفُوسْ نّسْ.
\m 
\v 23 \add إِوْذَانْ\add* أَذْ خَاسْ وّْثنْ ذڭْ إِفَاسّنْ نْسنْ
\m \add أَمْ زَّايسْ سْثْهزَّانْ\add*
\m ؤُشَا أَذْ خَاسْ صفَّارنْ
\m زڭْ ومْشَانْ \add ن ثْزذِّيغْثْ\add* نّسْ.“
\b
\b
\c 28
\s1 ڒْهَارْدْ ن أَيُوبْ خْ ثِيغِيثْ
\m 
\v 1 س ثِيذتّْ، أَقَا ذِينْ أَمْشَانْ
\m مَانِي ثتّْوَافْ نُّوقَارْثْ،
\m ؤُڒَا ذِينْ أَمْشَانْ إِ وُورغْ
\m مَانِي ث سِّيزْذِيڭنْ.
\m 
\v 2 ؤُزَّاڒْ تَّاوْينْ ث-إِ-د زڭْ ؤُشَاڒْ
\m ؤُ زڭْ وژْرُو سّْفسّْينْ نّْحَاسْ.
\m 
\v 3 إِڭَّا \add بْنَاذمْ\add* قطُّو إِ ثَادْجسْثْ،
\m نتَّا يَارزُّو ذِي مْكُوڒْ أَمْشَانْ مَانِي مَا،
\m \add خْ\add* وژْرُو \add إِ د-إِتّفّْغنْ\add*
\m زِي ثُوبَّارْشنْثْ ذ ثِيڒِي ن ڒْموْثْ.
\m 
\v 4 يَارْزمْ إِجّْ ن وخْجِيضْ
\m بْڒَا إِ غَا يِيڒِي حذْ \add أَكِيذسْ\add*.
\m تّْوَاتُّونْ زڭْ إِضَارنْ \add ن يِينِّي سنّجْ نْسنْ\add*،
\m ؤُيْڒنْ تّْرَاحنْ ثَاسنْ-د
\m بْڒَا إِ غَا يَارَّا أَسنْ-د حذْ ڒْبَاڒْ.
\b
\m 
\v 5 إِتّفّغْ-د وغْرُومْ زِي ثمُّورْثْ،
\m \add أَمْ\add* سْوَادَّايْ نّسْ \add مَارَّا\add*
\m أَخْمِي س ثْمسِّي إِنّقْڒبْ.
\m 
\v 6 إِژْرَا نّسْ ذ أَمْشَانْ مَانِي تَّافنْ صَافِّيرْ،
\m ذَايسْ إِ ثدْجَا ؤُڒَا ذ ثَاعجَّاشْثْ ن وُورغْ.
\m 
\v 7 أَجْضِيضْ إِتّْكشَّاضنْ وَارْ إِسِّينْ
\m أَمسْرُوقْ إِ غَارسْ إِدْجَانْ،
\m ثِيطّْ ن ؤُجْضِيذْ أَمسّْغُويْ أَمُوقْضِيعْ ن ثِيطَّاوِينْ
\m عمَّارْصْ وَارْ ث ثحْضِي.
\m 
\v 8 إِيْرَاذنْ إِمژْيَاننْ إِنفّْخنْ
\m وَارْ ذَايسْ ؤُيُورنْ،
\m ؤُڒَا ذ أَيْرَاذْ إِزهَّارنْ وَارْ ث إِتّْشُوقِي.
\b
\m 
\v 9 \add مَاشَا بْنَاذمْ\add* إِسَارّحْ أَفُوسْ نّسْ
\m غَارْ سّدْجَاحْ إِقسْحنْ،
\m إِسّْنقْڒَابْ إِذُورَارْ كُوڒْشِي.
\m 
\v 10 ذِي ڒجْرُوفْ إِقَّازْ إِغزْرَانْ،
\m ثِيطّْ نّسْ ثتّْوَاڒَا مَارَّا مِينْ إِغْڒَانْ.
\m 
\v 11 إِحوّقْ إِ إِغزْرَانْ
\m أَڒَامِي \add أَمَانْ\add* وَارْ قِّيمنْ تّفّْغنْ-د،
\m مِينْ \add ذَايسْ\add* إِنُوفَّارنْ
\m إِتَّاوْيِي ث-إِ-د غَارْ ثْفَاوْثْ.
\m 
\v 12 ثِيغِيثْ \add مَاشَا\add*، مَانِي ثتّْوَافْ؟
\m ؤُ مَانِي ثدْجَا ثْزذِّيغْثْ نْ ڒفْهَامثْ؟
\b
\m 
\v 13 بْنَاذمْ وَارْ إِسِّينْ ڒْقِيمثْ نّسْ،
\m وَارْ ثتّْوِيفْ \add ثِيغِيثْ\add*
\m ذِي ثمُّورْثْ ن يِينِّي إِدَّارنْ.
\m 
\v 14 \add أَمَانْ\add* إِهوْڒنْ قَّارنْ:
\m ’ذَايْنغْ وَارْ ثدْجِي شَا!‘،
\m ڒبْحَارْ إِقَّارْ: ’غَارِي وَارْ ذَا ثدْجِي شَا!‘ \x ◘ \xo 28:‏14 \xt أَيُوبْ 28‏:‏22\x*
\m 
\v 15 وَارْ إِزمَّارْ أَذْ إِمّوْشْ
\m وُورغْ إِقُّورنْ
\m ذڭْ ومْشَانْ نّسْ،
\m سُّومْ نّسْ وَارْ زمَّارنْ
\m أَذْ ث وزْننْ س نُّوقَارْثْ. \x ◘ \xo 28:‏15 \xt أَوڒن. 3‏:‏14؛ 8‏:‏11، 19؛ 16‏:‏16\x*
\m 
\v 16 وَارْ زمَّارنْ أَذْ وزْننْ \add سُّومْ نّسْ\add*
\m س وُورغْ إِغْڒَانْ زِي ؤُفِيرْ،
\m س وژْرُو ن ؤُنِيكْسْ إِغْڒَانْ ذ صَافِّيرْ أَزِيزَا.
\b
\m 
\v 17 وَارْ زمَّارنْ
\m أَذْ مّْقُودَّانْ ڒْقِيمثْ نّسْ
\m أَكْ-ذ وُورغْ نِيغْ كْرِيسْثَالْ،
\m نِيغْ أَذْ ت بدّْڒنْ
\m س إِشْثْ ن ڒْقشْعثْ ن وُورغْ إِتّْوَاصفَّانْ.
\m 
\v 18 وَارْ تّعْقِيڒنْ \add عَاذْ\add* خْ ثْيَاقُوثِينْ
\m ذ وژْرُو ن ؤُكْرِيسْثَالْ،
\m مَاغَارْ ثْوَافِيثْ ن ثِيغِيثْ ثُوعّْڒَا
\m خْ \add ثْوَافِيثْ\add* ن ڒْمَارْجَانْ.
\m 
\v 19 ڒعْقِيقْ أَزڭّْوَاغْ زِي كُوشْ
\m وَارْ ذَايسْ يَارْوِيسْ،
\m وَارْ ثْزمَّارْ أَذْ ثتّْوَاوْزنْ \add ثِيغِيثْ\add*
\m س وُورغْ إِصْفَانْ إِغْڒَانْ.
\m 
\v 20 مَانِيسْ د-ثُوسَا \add خنِّي\add* ثِيغِيثْ
\m ؤُ مَانِي ثدْجَا ثْزذِّيغْثْ ن ڒفْهَامثْ؟ \x ◘ \xo 28:‏20 \xt أَيُوبْ 28‏:‏12\x*
\b
\m 
\v 21 أَقَا-ت ثْنُوفَّارْ خْ ثِيطَّاوِينْ
\m ن مَارَّا مِينْ إِدَّارنْ،
\m ثتّْوَاڒحّفْ خْ إِجْضَاضْ ن ؤُجنَّا.
\m 
\v 22 أَهلّكْ ذ ڒْموْثْ قَّارنْ:
\m ’س إِمزُّوغنْ نّغْ نسْڒَا خَاسْ ڒخْبَارْ!‘ \x ◘ \xo 28:‏22 \xt أَيُوبْ 28‏:‏14\x*
\m 
\v 23 أَربِّي إِفهّمْ أَبْرِيذْ نّسْ،
\m نتَّا إِسّنْ ثَازذِّيغْثْ نّسْ،
\m 
\v 24 مَاغَارْ إِتّْوَاڒَا أَڒْ ثِينڭُّورَا ن ثمُّورْثْ،
\m إِژَارّْ مَارَّا مِينْ إِدْجَانْ سَاذُو إِجنْوَانْ.
\b
\m 
\v 25 ؤُمِي إِڭَّا إِ ؤُسمِّيضْ جّهْذْ نّسْ،
\m \add ؤُمِي\add* إِعْبَارْ ڒعْبَارْ ن وَامَانْ، \x ◘ \xo 28:‏25 \xt أَوڒن. 8‏:‏29\x*
\m 
\v 26 ؤُمِي إِڭَّا إِ ونْژَارْ قطُّو،
\m إِجّْ ن وبْرِيذْ إِ وَاسَّامْ ن وَاجَّاجنْ،
\m 
\v 27 خنِّي إِژْرَا إِ-ت، إِسَّارْڭبْ إِ-ت،
\m ؤُشَا إِسّْبدّْ إِ-ت ذڭْ ومْشَانْ نّسْ
\m ؤُشَا إِبقّشْ ذَايسْ،
\m 
\v 28 ؤُشَا إِنَّا إِ بْنَاذمْ:
\m ’خْزَارْ، ثِيڭّْوُوذِي زِي سِيذِي ذ ثِيغِيثْ
\m أَبعّذْ خْ مِينْ إِدْجَانْ ذ أَعفَّانْ،
\m ذ ڒفْهَامثْ.‘ \f ◼ \fr 28:‏28 \ft \bd ’سِيذِي‘\bd* - س ثْعِيبْرَانِيثْ ’سِيذِي إِنُو‘.\f*  \x ◘ \xo 28:‏28 \xt إِزهد. 111‏:‏10؛ أَوڒن. 1‏:‏7؛ 9‏:‏10\x*
\b
\b
\c 29
\s1 أَيُوبْ إِسِّيوڒْ خْ مَامّشْ ثُوغَا ثُوذَارْثْ نّسْ قْبڒْ
\m 
\v 1 ؤُشَا يَارْنِي إِسّْڭعّذْ \bd أَيُوبْ\bd* ڒْهَارْذْ ن لْمَاثَالْ نّسْ، إِنَّا:
\b
\m 
\v 2 مْڒِي دْجِيغْ أَمْ ذڭْ ؤُينِّي ن إِيُورنْ إِعْذُونْ
\m أَطَّاسْ زڭْ وَامِي،
\m أَمْ ذڭْ ؤُينِّي ن وُوسَّانْ
\m ڒَْامِي ذ أَيِي ثُوغَا إِحطَّا أَربِّي،
\m 
\v 3 ڒَامِي إِڭَّا ڒفْنَارْ نّسْ
\m أَذْ يَارغْ خْ ؤُزدْجِيفْ إِنُو،
\m ؤُ ثُوغَا ڭُّورغْ ذِي ثَادْجسْثْ س ثْفَاوْثْ نّسْ.
\m 
\v 4 \add مْڒِي\add* دْجِيغْ أَمْ ذڭْ وُوسَّانْ ن ثمْژِي إِنُو،
\m ؤُمِي أَمُونِي ذِي ڒَامَانْ أَكْ-ذ أَربِّي
\m ثُوغَا إِبدّْ خْ ثْقِيضُونْثْ إِنُو،
\m 
\v 5 ؤُمِي أَمْزمَّارْ خْ كُوڒْشِي
\m ثُوغَا-ث عَاذْ أَكِيذِي،
\m ؤُ إِحنْجِيرنْ إِنُو \add عَاذْ\add* نّْضنْ أَيِي-د،
\m 
\v 6 ؤُمِي إِصُورَافْ إِنُو ثُوغَا عُومّنْ ذِي ثْرُوسِّي،
\m ؤُ ثَاصْضَارْثْ ثُوغَا ثتّْزدْجَاعْ زَّاثِي
\m ثِيغزْرَاثِينْ ن زّشْثْ!
\b
\m 
\v 7 ؤُمِي د-فّْغغْ غَارْ ثوَّارْثْ ن ثنْذِينْثْ،
\m جِّيغْ سّْبدّنْ أَيِي ڒْكُورْسِي إِنُو ذڭْ وَازَّايْ،
\m 
\v 8 نُّوفَارنْ إِحُوذْرِييّنْ ڒَامِي ذ أَيِي ژْرِينْ،
\m ؤُ إِمشَّايْبُوثنْ كَّارنْ، قِّيمنْ بدّنْ.
\m 
\v 9 ڒْحُوكَّامْ منْعنْ أَوَاڒنْ نْسنْ
\m ؤُ سَّارْسنْ أَفُوسْ خْ ؤُقمُّومْ نْسنْ.
\m 
\v 10 ثْمِيجَّا ن ڒْحُوكَّامْ ثسْقَارْ،
\m إِڒْسقْ إِڒسْ نْسنْ غَارْ وَانغْ نْسنْ.
\b
\m 
\v 11 مَاڒَا إِسْڒَا أَيِي ؤُمزُّوغْ، إِسّمْغَارْ أَيِي،
\m مَاڒَا ثژْرَا أَيِي ثِيطّْ، ثشْهذْ خْ ڒْخَاضَارْ إِنُو.
\m 
\v 12 مَاغَارْ سّْنجْمغْ ڒْمسْكِينْ نِّي إِسْغُوينْ،
\m أَيُوجِيڒْ نِّي وَارْ غَارسْ ثُوغِي
\m ونِّي ث إِ غَا إِعَاوْننْ. \x ◘ \xo 29:‏12 \xt إِزهد. 72‏:‏12؛ أَوڒن. 21‏:‏13\x*
\m 
\v 13 ڒْخَاضَارْ ن ونِّي ثُوغَا عْڒَاينْ أَذْ إِهلّكْ،
\m ثُوسَا-د خَافِي،
\m ؤُڒْ نْ ثَاجَّاتْشْ ڭِّيغْ ث إِسْڒِيوْڒوْ س ڒفْرَاحثْ.
\m 
\v 14 يَارْضغْ ثَاسڭْذَا ؤُ \add ثَاسڭْذَا\add* ثسّْيَارْضْ أَيِي.
\m ثُوغَا شّْرعْ إِنُو أَمْ ؤُسڒْهَامْ ؤُ أَمْ أَرژّثْ. \x ◘ \xo 29:‏14 \xt إِشا. 59‏:‏17؛ أَفا. 6‏:‏10‏-‏17؛ 1 تس. 5‏:‏8\x*
\b
\m 
\v 15 ثُوغَا أَيِي ذ ثِيطَّاوِينْ إِ إِذَارْغَاڒنْ،
\m ؤُڒَا ذ إِضَارنْ إِ إِقِيضَارنْ.
\m 
\v 16 ثُوغَا أَيِي ذ بَابَاثْسنْ إِ إِمزْڒَاضْ،
\m ؤُشَا دّعْوثْ ن ونِّي وَارْ سِّينغْ،
\m بقّْشغْ ت.
\m 
\v 17 أَرْژِيغْ ثِيغْمَاسْ ن ثغْمَارْثْ
\m ن ونِّي إِڭِّينْ مِينْ وَارْ إِسڭّْذنْ
\m ؤُشَا كّْسغْ زَّارْذثْ إِ ثغْمَاسْ نّسْ.
\b
\m 
\v 18 نِّيغْ: ’أَذْ سُّوفّْغغْ بُوحْبڒْ إِنُو
\m خْ ڒْعُوشّْ إِنُو،
\m أَذْ دَّارغْ ثُوذَارْثْ ثَازِيرَارْثْ
\m أَمْ ؤُجْضِيذْ ن فُونِيكْسْ.‘
\m 
\v 19 إِژوْرَانْ إِنُو بزّْعغْ ثنْ أَڒْ أَمَانْ
\m ؤُ ذِي دْجِيڒثْ إِقِّيمْ نّْذَا خْ ڒفْرُوعْ إِنُو.
\m 
\v 20 ثُوغَا ڒْعزّْ إِنُو إِقِّيمْ أَكِيذِي \add ڒبْذَا\add*،
\m ڒْقوْسْ إِنُو إِسْهڒْ ذڭْ ؤُفُوسْ إِنُو \add ڒبْذَا\add*.
\b
\m 
\v 21 سْڒِينْ-د غَارِي، رَاجَانْ،
\m سْقَارنْ ذِي طّْوعْ ن شّْوَارْ إِنُو.
\m 
\v 22 أَوَارْنِي وَاوَاڒْ إِنُو
\m وَارْ سِّيوْڒنْ ثْوَاڒَا نّغْنِي،
\m أَوَاڒنْ إِنُو ؤُذُومنْ خَاسنْ.
\m 
\v 23 نِيثْنِي رَاجَانْ أَيِي أَمْ \add رَاجَانْ\add* أَنْژَارْ،
\m أَرْزْمنْ أَقمُّومْ نْسنْ
\m أَمْ ث أَرزْمنْ غَارْ ونْژَارْ ن ثفْسُوثْ.
\m 
\v 24 \add مَاڒَا\add* سْفَارْنِينغْ غَارْسنْ،
\m وَارْ زمَّارنْ \add عَاذْ\add* أَذْ تِّيقّنْ،
\m \add مَاشَا\add* ثَافَاوْثْ ن ؤُغمْبُوبْ إِنُو
\m وَارْ زْمِيرنْ أَذْ كِيذسْ مّْعَاڒَانْ.
\m 
\v 25 إِخْضَارغْ أَسنْ أَبْرِيذْ،
\m بدّغْ أَسنْ غَارْ ؤُزدْجِيفْ،
\m زذْغغْ أَمْ ؤُجدْجِيذْ جَارْ ڒْعسْكَارْ،
\m أَمْ ونِّي إِتّْعزَّانْ إِنِّي إِشضْننْ.
\b
\b
\c 30
\s1 أَيُوبْ إِسِّيوڒْ خْ ڒمْحَايمْ نّسْ ن يِيضَا
\m 
\v 1 ڒخُّو مَاشَا ثُوغَا ضحّْشنْ خَافِي إِحُوذْرِييّنْ
\m نِّي إِدْجَانْ ذ إِمژْيَاننْ خَافِي ذڭْ وُوسَّانْ،
\m إِنِّي بَابَاثْسنْ وَارْ غَارِي سكّْوِينْ
\m مَاحنْذْ أَذْ ثنْ ڭّغْ
\m غَارْ يِيطَانْ إِ إِدْجَانْ خْ وُودْجِي إِنُو.
\m 
\v 2 مِينْ غَا ڭّغْ \add خنِّي\add* س جّهْذْ ن إِفَاسّنْ نْسنْ؟
\m أَقَا إِفْنَا \add جّهْذْ نْسنْ\add* زِي سِّيبّثْ ن ثوْسَارْ.
\m 
\v 3 زِي ڒْقِيدْجثْ ؤُ زِي ڒَاژْ ذوْڒنْ إِسْرِيونْ،
\m تّْمغْزَازنْ ذِي ڒْوَاطَا يُوژْغنْ
\m ذِي ثُوبَّارْشنْثْ \add ثشُّورْ\add*
\m س ؤُردّدْجْ ذ ؤُربّجْ.
\m 
\v 4 نِيثْنِي ڒقّْضنْ ڒبْزَارْ أَمدْجَاحْ جَارْ شْبَارْقْ،
\m إِژوْرَانْ ن ؤُززُّو ذ أَغْرُومْ نْسنْ.
\b
\m 
\v 5 ؤُژّْڒنْ خَاسنْ زِي ثْمُونثْ \add ن إِوْذَانْ\add*،
\m كّْوَارنْ ثنْ أَمْ يِيخوَّاننْ،
\m 
\v 6 حِيمَا أَذْ زذْغنْ ذِي ثغْزُورِينْ إِسَّاڭّْوَاذنْ،
\m ذڭْ إِفْرَانْ ن ؤُشَاڒْ ؤُ ذِي ڒجْرُوفْ.
\m 
\v 7 سْغُويُّونْ جَارْ شْبَارْقْ،
\m سَاذُو ثِيزڭّْوَارِينْ سّْمُونَانْ.
\m 
\v 8 ثَارْوَا ن إِبُوهَاڒِييّنْ ذ ثَارْوَا بْڒَا إِسمْ،
\m ذ إِنِّي ؤُژّْڒنْ خَاسنْ زِي ثمُّورْثْ س ؤُزدْجَاضْ.
\b
\m 
\v 9 ڒخُّو مَاشَا أَقَا أَيِي
\m ذڭْ إِزْڒِي نْسنْ ن ثْژَاوَارْثْ،
\m ذوْڒغْ أَسنْ إِ ڒْهَارْذْ. \f ◼ \fr 30:‏9 \ft \bd ’إِزْڒِي نْسنْ ثْژَاوَارْثْ‘\bd* - س ثْعِيبْرَانِيثْ ’أَزنْزُونْ نْسنْ‘.\f*  \x ◘ \xo 30:‏9 \xt أَيُوبْ 17‏:‏6؛ إِزهد. 69‏:‏13؛ إِڭجذ. 3‏:‏14، 63\x*
\m 
\v 10 شَارّْهنْ أَيِي، تَّاڭّْوَاجنْ خَافِي،
\m وَارْ تّْسضْحِينْ شَا
\m مَاحنْذْ أَذْ سُّوسْفنْ خْ ؤُغمْبُوبْ إِنُو. \x ◘ \xo 30:‏10 \xt أَيُوبْ 19‏:‏19\x*
\m 
\v 11 مَاغَارْ نتَّا إِسّفْسِي أَسْغُونْ \add ن ثْقِيضُونْثْ\add* إِنُو
\m ؤُشَا إِسّهْوَا أَيِي.
\m نِيثْنِي نْضَارنْ سّْرِيمثْ \add نْسنْ\add* زَّاثِي. \f ◼ \fr 30:‏11 \ft \bd ’زَّاثِي‘\bd* - س ثْعِيبْرَانِيثْ ’زَّاثْ إِ ؤُغمْپُوبْ إِنُو‘.\f*
\m 
\v 12 غَارْ ؤُغزْذِيسْ أَفُوسِي \add إِنُو\add*
\m كَّارنْ-د خَافِي إِغذِّيونْ ن ثَارَّاوْثْ،
\m عَارّْننْ إِضَارنْ إِنُو،
\m سّْڭعَّاذنْ خَافِي إِمسْرَاقْ ن أَرْژِييّثْ نْسنْ.
\b
\m 
\v 13 أَبْرِيذْ إِنُو أَرْژِينْ ث،
\m أَرنّْينْ ثَامَارَا خْ ثَامَارَا إِنُو
\m وَاخَّا نِيثْنِي سِيمَانْثْ نْسنْ
\m وَارْ غَارْسنْ إِدْجِي وِي ذ أَسنْ غَا إِوْشنْ أَفُوسْ.
\m 
\v 14 أَخْمِي د-تَّاسنْ
\m زڭْ إِجّْ ن ؤُنُوقِّيبْ ذ مِيرِيوْ،
\m تَّاكّْوَاضنْ أَمْ ڒمْوَاجْ يَاردّْدْجنْ.
\m 
\v 15 تّْوَاكبّنْ-د خَافِي إِنخْڒِيعنْ،
\m أَمْ ؤُسمِّيضْ ضفَّارنْ نِيثْنِي شَّانْ إِنُو،
\m إِضْوَا زّْهَارْ إِنُو أَمْ يِيجّْ ن ؤُسيْنُو.
\b
\m 
\v 16 \add س ؤُيَا\add* إِفسِّي ڒخُّو ڒعْمَارْ إِنُو ذَايِي،
\m ؤُسَّانْ ن ڒغْبنْ منّْعنْ أَيِي.
\m 
\v 17 ذِي دْجِيڒثْ إِسّْنُوقُّوبْ أَيِي
\m إِغْسَانْ إِنُو إِ ذَايِي إِدْجَانْ،
\m ڒحْرِيقْ إِ ذ أَيِي إِتّْغزَّانْ وَارْ يَارسِّي.
\m 
\v 18 إِتّْوَابدّڒْ وَارُّوذْ إِنُو
\m س جّهْذْ \add نّسْ\add* أَمقّْرَانْ
\m أَڒَامِي وَارْ خَافِي تّعْقِيڒنْ \add عَاذْ\add*.
\m إِشَارْفْ أَيِي أَمْ ثْمَا إِ إِنّْضنْ
\m إِ وَارْزمْ ن يِيرِي ذڭْ وَارُّوضْ.
\m 
\v 19 إِنْضَارْ أَيِي ذڭْ ؤُبدْجَاعْ،
\m ذوْڒغْ أَمْ ؤُشَاڒْ ذ يِيغّضْ.
\b
\m 
\v 20 سْغُويُّوغْ غَاركْ،
\m \add مَاشَا\add* شكْ وَارْ خَافِي د-ثتَّارِّيذْ،
\m نشّْ بدّغْ ذَا
\m ؤُشَا شكْ ثقِّيمذْ ثْحطِّيذْ ذَايِي.
\m 
\v 21 شكْ ثْذوْڒذْ أَيِي أَمْ يِيجّْ ن بُو-ڒخْشُونثْ،
\m ثتّْذَارَّاشذْ خَافِي س ؤُفُوسْ نّشْ إِجهْذنْ.
\m 
\v 22 شكْ ثسّْڭعَّاذذْ أَيِي
\m ؤُ ثْندّْهذْ أَيِي ذڭْ ؤُسمِّيضْ،
\m ثسّفْرَاغذْ \add قَاعْ\add* أَدُّوذْ إِنُو.
\m 
\v 23 مَاغَارْ نشّْ سّْنغْ
\m أَقَا شكْ أَذْ أَيِي ثْنذْهذْ غَارْ ڒْموْثْ،
\m غَارْ ثَادَّارْثْ مَانِي تّْمُوننْ
\m مَارَّا إِنِّي إِدَّارنْ. \x ◘ \xo 30:‏23 \xt عبر. 9‏:‏27\x*
\b
\m 
\v 24 مَا وَارْ إِنطَّارْ \add بْنَاذمْ\add* أَفُوسْ \add نّسْ\add*
\m مَاڒَا إِوْضَا \add حذْ\add*،
\m مَا وَارْ إِسْغُويُّو وَالُو قَاعْ
\m غَارْ أَرْژِييّثْ \add نّسْ\add*؟
\m 
\v 25 مَا وَارْ رُوغْ خْ ونِّي ثُوغَا غَارْ إِدْجَا
\m وُوسَّانْ ن ثَامَارَا،
\m مَا وَارْ إِشْضِينْ بُوحْبڒْ إِنُو خْ ؤُمزْڒُوضْ؟ \x ◘ \xo 30:‏25 \xt إِزهد. 35‏:‏13، 14؛ رُوم. 12‏:‏15\x*
\m 
\v 26 ؤُمِي سِّيثْمغْ غَارْ مِينْ إِصبْحنْ،
\m أَقَا يُوسَا-د مِينْ إِدْجَانْ ذ أَعفَّانْ،
\m ؤُمِي رَاجِيغْ ثَافَاوْثْ، ثُوسَا-د ثَادْجسْثْ.
\m 
\v 27 أَذَانْ إِنُو تّْننَّانْ، وَارْ أَرْسِينْ،
\m إِوْضنْ-د وُوسَّانْ ن ثَامَارَا غَارِي.
\b
\m 
\v 28 نشّْ أَذْ ؤُيُورغْ ذڭْ وشْضَانْ،
\m بْڒَا ڒهْمُو \add ن ثْفُوشْثْ\add*.
\m أَذْ كَّارغْ ذڭْ وڭْرَاوْ \add ن ڒْڭنْسْ\add*
\m ؤُشَا أَذْ قِّيمغْ سْغُويُّوغْ ذڭْ ؤُجنَّا.
\m 
\v 29 إِ وُوشَّاننْ ن ڒخْڒَا
\m ذوْڒغْ ذ ؤُمَاثْسنْ زَّايْسنْ،
\m إِ يسِّيسْ ن نّْعَامثْ ذ أَمْعَاشَارْ. \x ◘ \xo 30:‏29 \xt إِزهد. 102‏:‏7\x*
\m 
\v 30 ثِيڒْمشْثْ إِنُو ثذْوڒْ خَافِي
\m ذ أَكَارْكُوشْ أَبَارْشَانْ،
\m زِي ثْمسِّي شمّْضنْ إِغْسَانْ إِنُو. \x ◘ \xo 30:‏30 \xt إِزهد. 119‏:‏83؛ إِڭجذ. 4‏:‏8؛ 5‏:‏10\x*
\m 
\v 31 ثذْوڒْ \add ثِيرَارْثْ ن\add* ڒْڭَامْبْرِي إِنُو إِ وشْضَانْ،
\m ثَامْجَا إِنُو إِ ڒْحسّْ ن إِمطَّاونْ.
\b
\b
\c 31
\s1 أَيُوبْ إِشفّعْ بلِّي وَارْ ذَايسْ بُو ڒْعِيبْ
\m 
\v 1 نشّْ ڭِّيغْ ڒْعَاهْذْ
\m أَكْ-ذ ثِيطَّاوِينْ إِنُو،
\m مَامّشْ إِ غَا خْزَارغْ \add خنِّي\add* ذِي ثعْزَارشْثْ؟ \x ◘ \xo 31:‏1 \xt إِزهد. 7‏:‏4‏-‏6؛ 15‏:‏1‏-‏5\x*
\m 
\v 2 مَاغَارْ مِينْ \add إِدْجَانْ خنِّي\add* ثَاسْغَارْثْ
\m ن أَربِّي زِي سنّجْ،
\m نِيغْ ثَاسْغَارْثْ ن ڒْوَارْثْ ن ؤُمْزمَّارْ خْ كُوڒْشِي
\m زڭْ \add إِجنْوَانْ\add* يُوعْڒَانْ؟
\m 
\v 3 مَا وَارْ إِدْجِي أَضيّعْ إِكَّارْ-د إِ ؤُعفَّانْ،
\m أَرْژِييّثْ إِ يِينِّي إِتّڭّنْ ڒْمُوعْصِييّثْ؟
\m 
\v 4 مَا وَارْ إِتّْوِيڒِي نتَّا إِبْرِيذنْ إِنُو،
\m مَا وَارْ إِحسّبْ نتَّا ڒْقدّْ
\m ن مَارَّا إِصُورَافْ إِنُو؟ \x ◘ \xo 31:‏4 \xt 2 إِم. 16‏:‏9؛ أَيُوبْ 34‏:‏21؛ أَوڒن. 5‏:‏21؛ 15‏:‏3؛ إِرْم. 32‏:‏19\x*
\b
\m 
\v 5 مَاڒَا ثُوغَا ؤُيُورغْ ذِي ڒخْذعْ،
\m نِيغْ إِقدْجقْ ؤُضَارْ إِنُو غَارْ ڒْغشّْ،
\m 
\v 6 أجّْ سِيذِي أَذْ أَيِي إِوْزنْ \add خنِّي\add*
\m ذِي ڒْمِيزَانَاثْ إِسڭّْذنْ،
\m \add أَڒَامِي\add* إِ غَا إِسّنْ أَربِّي ڒصْفَايثْ إِنُو.
\m 
\v 7 مَاڒَا إِصُورَافْ إِنُو فّْغنْ زڭْ وبْرِيذْ،
\m ؤُڒْ إِنُو إِضْفَارْ ثِيطَّاوِينْ إِنُو
\m ؤُشَا \add خنِّي\add* إِڒْصقْ ڒْعِيبْ ذڭْ إِفَاسّنْ إِنُو،
\m 
\v 8 \add خنِّي\add* أَذْ زَارْعغْ نشّْ،
\m \add مَاشَا\add* إِجّنْ نّغْنِي أَذْ إِشّْ،
\m ؤُ مِينْ غَارِي د-إِغمَّاينْ أَذْ إِتّْوَاقْڒعْ!
\b
\m 
\v 9 مَاڒَا ؤُڒْ إِنُو إِتّْوَاغْوَا غَارْ إِشْثْ ن ثمْغَارْثْ،
\m نِيغْ ثُوغَا تّْحَامِيغْ
\m غَارْ ثوَّارْثْ ن وَاجَّارْ إِنُو، \x ◘ \xo 31:‏9 \xt أَيُوبْ 24‏:‏15؛ أَوڒن. 7‏:‏25\x*
\m 
\v 10 أجّْ \add خنِّي\add* ثَامْغَارْثْ إِنُو
\m أَذْ ثحْرِي \add إِمنْذِي\add* إِ يِيجّنْ نّغْنِي،
\m \add جّمْ\add* إِنّغْنِي أَذْ خَاسْ أَضَارنْ.
\m 
\v 11 مَاغَارْ أَيَا ذ ڒفْضِيحثْ،
\m ذ إِشْثْ ن لْجَارِيمَا \add إِ خَاسْ إِ غَا وْثنْ\add* ڒْقُوضَاثْ.
\m 
\v 12 مَاغَارْ أَيَا ذ ثِيمسِّي ثتّتّْ أَڒْ أَهلّكْ،
\m ثْقدْجعْ مَارَّا ڒْغِيدْجثْ إِنُو.
\b
\m 
\v 13 مَاڒَا سّْحقَّارغْ ڒْحقّْ
\m ن إِسْمغْ إِنُو ذ ثَايَّا إِنُو،
\m ڒَْامِي ثُوغَا تّمْشُوبُّوشنْ أَكِيذِي،
\m 
\v 14 مِينْ إِ غَا ڭّغْ \add خنِّي\add* مَاڒَا سِيذِي إِكَّارْ،
\m مَاڒَا نتَّا إِقدْجبْ أَيِي،
\m مِينْ خَاسْ د غَا يَارّغْ \add خنِّي\add*؟ \x ◘ \xo 31:‏14 \xt إِزهد. 44‏:‏22\x*
\m 
\v 15 ونِّي ذ أَيِي إِڭِّينْ ذڭْ ؤُعذِّيسْ ن يمَّا،
\m مَا وَارْ ث إِڭِّي ؤُڒَا ذ نتَّا؟
\m مَا وَارْ إِدْجِي ذ إِجّْ ونِّي ذ أَنغْ د-إِخڒْقنْ
\m ذڭْ ؤُعذِّيسْ ن يمَّاثْنغْ؟ \x ◘ \xo 31:‏15 \xt أَيُوبْ 34‏:‏19؛ أَوڒن. 14‏:‏31؛ 17‏:‏5\x*
\b
\m 
\v 16 مَاڒَا قمّْحغْ أَمژْرِي ن إِمزْڒَاضْ
\m نِيغْ سّْرُوغْ ثِيطَّاوِينْ ن ثَاجَّاتْشْ،
\m 
\v 17 مَاڒَا نشّْ مْغِيرْ شِّيغْ
\m أَڒقُّوزْ ن وغْرُومْ إِنُو،
\m أَمْ وَارْ زَّايسْ إِشِّي ؤُيُوجِيڒْ،
\m 
\v 18 - مَاغَارْ زِي ثمْژِي إِيْمَا نتَّا غَارِي
\m أَمْ إِيْمَا غَارْ بَابَاسْ،
\m زڭْ ؤُعذِّيسْ ن يمَّا نذْهغْ ت -
\b
\m 
\v 19 مَاڒَا ژْرِيغْ إِجّنْ إِتّْوَاهلّكْ
\m مِينْزِي وَارْ غَارسْ إِدْجِي وَارُّوضْ،
\m نِيغْ مِينْزِي وَارْ ذِينْ إِدْجِي دُّورِي إِ ؤُمزْڒُوضْ،
\m 
\v 20 مَاڒَا \add عمَّارْصْ\add* وَارْ ذ أَيِي بَارْكنْثْ
\m ثجْعِينَّاثِينْ نّسْ،
\m مِينْزِي إِڭَّا أَذْ إِسِّيحْمَا إِخفْ نّسْ
\m س وَادْجَاسْ \add ن ثْضُوفْثْ\add* ن إِزْمَارنْ إِنُو،
\m 
\v 21 مَاڒَا أَفُوسْ إِنُو إِهُودّْ خْ ؤُيُوجِيڒْ،
\m مِينْزِي ژْرِيغْ أَقَا ذِينْ ثْوِيزَا إِ نشّْ
\m غَارْ ثوَّارْثْ \add ن ثنْذِينْثْ\add*، \f ◼ \fr 31:‏21 \ft \bd أَفسَّارْ\bd* - ذِي ثوَّارْثْ ن ثنْذِينْثْ أَقَا ذِينْ أَمْشَانْ ن ڒْقُوضَاثْ. مَاڒَا نِيثْنِي وَارْ شَارّْعنْ نِيشَانْ، إِخْسْ أَذْ يِينِي إِخْضَارنْ نِيثْنِي طَّارْفْ ن بُو-وَاڭْڒَا نِيغْ ن ينِّي غَارْسنْ صُّولْطَا، أَقَا-ثنْ ذوْڒنْ حصَّارنْ إِ إِمزْڒَاذْ ذِي ثوُّورَا ن ثنْذِينْثْ.\f*
\m 
\v 22 أجّْ \add خنِّي\add* أَذْ أَيِي ثوْضَا
\m ثغْرُوضْثْ إِنُو زڭْ إِجِيمَانْ،
\m أَذْ أَيِي يَارْژْ ؤُغِيڒْ إِنُو زڭْ يِيغسْ!
\m 
\v 23 مَاغَارْ أَذْ خَافِي د-إِوْضَا
\m ؤُنخْڒِيعْ أَمقّْرَانْ،
\m إِشْثْ ن ڒْمُوصِيبثْ زِي غَارْ أَربِّي،
\m وَارْ زمَّارغْ أَذْ ڭّغْ وَالُو
\m زَّاثْ إِ ؤُعُودْجِي نّسْ.
\b
\m 
\v 24 مَاڒَا ڭِّيغْ ؤُرغْ ذ أَثشْڒِي إِنُو،
\m نِيغْ نِّيغْ إِ وُورغْ إِغْڒَانْ أَطَّاسْ:
\m ’شكْ ذ ڒَامَانْ إِنُو!‘، \x ◘ \xo 31:‏24 \xt مك. 10‏:‏24؛ 1 تِيم. 6‏:‏17\x*
\m 
\v 25 مَاڒَا فَارْحغْ ؤُمِي إِمْغَارْ وَاڭْڒَا إِنُو،
\m ؤُمِي أَفُوسْ إِنُو إِطّفْ أَطَّاسْ \add ذ أَڭْڒَا\add*، \x ◘ \xo 31:‏25 \xt إِزهد. 62‏:‏11\x*
\m 
\v 26 مَاڒَا ژْرِيغْ ثَافَاوْثْ \add ن ثْفُوشْثْ\add* خْمِي ثتّْوسّڭْ،
\m نِيغْ ثَازِيرِي خْمِي ثڭُّورْ ذِي ثِيسِّيقْثْ \add نّسْ\add*، \x ◘ \xo 31:‏26 \xt أَعَوذ. 4‏:‏19\x*
\m 
\v 27 ؤُشَا إِتّْوَاغْوَا وُوڒْ إِنُو س ثْنُوفّْرَا،
\m ؤُشَا أَقمُّومْ إِنُو، إِسُّوذمْ إِ-ث ؤُفُوسْ إِنُو،
\m 
\v 28 \add خنِّي\add* إِڒِي ؤُڒَا ذ مَانْ أَيَا ذ ڒْمُوعْصِييّثْ
\m أَذْ ت وْشنْ إِ ڒْقُوضَاثْ،
\m مَاغَارْ \add خنِّي\add* أَذْ نْكَارغْ أَربِّي
\m نِّي إِدْجَانْ سنّجْ.
\b
\m 
\v 29 مَاڒَا فَارْحغْ إِ أَرْژِييّثْ
\m ن ونِّي ذ أَيِي إِشَارّْهنْ،
\m فَارْحغْ ؤُمِي ث إِڒْقفْ ڒْغَارْ! \x ◘ \xo 31:‏29 \xt أَوڒن. 17‏:‏5\x*
\m 
\v 30 نشّْ \add مَاشَا\add* وَارْ جِّيغْ أَنغْ إِنُو أَذْ إِخْضَا،
\m ؤُمِي كّْوَارغْ ڒعْمَارْ نّسْ س نّعْڒثْ! \x ◘ \xo 31:‏30 \xt مت. 5‏:‏44؛ رُوم. 12‏:‏14\x*
\b
\m 
\v 31 مَاڒَا إِرْيَازنْ نِّي إِدْجَانْ ذڭْ ؤُقِيضُونْ إِنُو
\m وَارْ قَّارنْ:
\m ’مَانْ ونْ وَارْ إِتّْوَاسّْجِيوْننْ
\m زڭْ يِينِّي إِكْسِينْ زڭْ ويْسُومْ نّسْ؟‘
\m 
\v 32 ؤُڒَا ذ إِجّْ ن ڒْبَارَّانِي
\m وَارْ إِسّنْسْ \add ذِي بَارَّا\add* خْ وبْرِيذْ،
\m \add مَاغَارْ\add* إِ ؤُمْسبْرِيذْ أَرْزْمغْ ثِيوُّورَا إِنُو.\x ◘ \xo 31:‏32 \xt عبر. 13‏:‏2؛ 1 بُط. 4‏:‏9\x*
\b
\m 
\v 33 مَاڒَا نشّْ، أَمْ أَذَامْ، ذْڒِيغْ أَخطُّو إِنُو،
\m ؤُمِي سّْنُوفَّارغْ ڒْمُوعْصِييّثْ إِنُو
\m ذڭْ وحْسِينْ إِنُو، \f ◼ \fr 31:‏33 \ft \bd ’أَحْسِينْ‘\bd* - نِيغْ ’أَبحْرُورْ‘.\f*
\m 
\v 34 مِينْزِي ڭّْوذغْ زِي ڒْغَاشِي أَمقّْرَانْ،
\m نِيغْ إِسّْنخْڒعْ أَيِي ؤُسحْقَارْ ن ڒْوَاشُونْ إِنُو،
\m أَڒَامِي قِّيمغْ سّغْذغْ،
\m وَارْ فِّيغغْ \add عَاذْ\add* زِي ثوَّارْثْ \add غَارْ بَارَّا\add* ...
\b
\m 
\v 35 مْڒِي غَارِي إِجّنْ ونِّي ذ أَيِي غَا إِسْڒنْ.
\m خْزَارْ، أَشمِّيعْ إِنُو
\m - أَمْزمَّارْ خْ كُوڒْشِي أَذْ خَافِي د-يَارّْ -
\m ؤُڒَا ذ أَذْلِيسْ إِتّْوَانّْضنْ نِّي ث يُورَا
\m ورْيَازْ نِّي كِيذِي إِتّمْشُوبُّوشنْ. \x ◘ \xo 31:‏35 \xt 1 Jh\x*
\m 
\v 36 معْلِيكْ ؤُفِيغْ مَا وَارْ ث أَربُّوغْ
\m خْ ثْغَارْضْثْ إِنُو،
\m أَذْ ث قّْنغْ \add إِ ؤُزدْجِيفْ إِنُو\add* أَمْ يِيجّْ ن تَّاجْ.
\m 
\v 37 إِوَا، أَذْ أَسْ إِنِيغْ ڒْقدّْ ن إِصُورَافْ إِنُو،
\m أَذْ غَارسْ د-قَارّْبغْ أَمْ يِيجّْ ن ڒْحَاكمْ.
\b
\m 
\v 38 مَاڒَا ڒعْرَاصِي إِنُو إِسْغُويْ خَافِي،
\m إِعيَّاذنْ نّسْ أَذْ رُونْ
\m أَكْ-ذ وَايَاوْيَا \add مَارَّا\add*،
\m 
\v 39 مَاڒَا شِّيغْ صَّابثْ نّسْ نْهْڒَا أَخدْجصْ،
\m نِيغْ ڭِّيغْ ڒعْمَارْ ن إِخمَّاسنْ نّسْ
\m إِضْڒقْ إِ بُوحْبڒْ،
\m 
\v 40 أجّْ \add خنِّي\add* أَذْ إِغْمِي شْبَارْقْ أَكْ-ذ إِسنَّاننْ
\m ذڭْ ومْشَانْ ن يِيرْذنْ،
\m ؤُڒَا ذ ڒعْشُوبْ يَارْصُوذنْ
\m ذڭْ ومْشَانْ ن إِمنْذِي.
\b
\m أَقَا ذَا إِ قْضَانْ وَاوَاڒنْ ن أَيُوبْ.
\b
\b
\c 32
\s1 ڒْهَارْدْ أَمزْوَارُو ن إِلِيهُو: ثَامزْوَارُوثْ
\m 
\v 1 \add خنِّي\add* سّْبدّنْ ثْڒَاثَا ن يرْيَازنْ نِّي مَاحنْذْ أَذْ د-أَرّنْ خْ أَيُوبْ، مِينْزِي ثُوغَا ذ أَمْسڭّذْ جَارْ ثِيطَّاوِينْ \add ن يِيخفْ\add* نّسْ.
\v 2 \add خَاسْ ؤُشَا\add* يَارْغَا لْغَاضَابْ ن إِلِيهُو، مِّيسْ ن بَارَاخْيِيلْ، زِي \add ثمُّورْثْ ن\add* بُوزْ، زِي ڒَادْجْ ن رَامْ. يَارْغَا لْغَاضَابْ نّسْ خْ أَيُوبْ مِينْزِي إِڭَّا وَانِيثَا إِخفْ نّسْ ذ أَمْسڭّذْ خْ أَربِّي.
\v 3 يَارْغَا لْغَاضَابْ نّسْ ؤُڒَا خْ ثْڒَاثَا ن إِمدُّوكَّاڒْ نّسْ، مَاغَارْ نِيثْنِي، \add وَاخَّا\add* وَارْ ؤُفِينْ مِينْ زِي \add خَاسْ\add* إِ د غَا يَارّنْ، أَرِّينْ ڒْعِيبْ ذِي أَيُوبْ.
\b
\m 
\v 4 إِلِيهُو \add مَاشَا\add* ثُوغَا إِرَاجَا س وَاوَاڒنْ قِيبَاتْشْ إِ أَيُوبْ، مِينْزِي نِيثْنِي ثُوغَا مْغَارنْ خَاسْ.
\v 5 \add ؤُمِي\add* إِژْرَا إِلِيهُو، أَقَا ثْڒَاثَا ن يرْيَازنْ نِّي وَارْ ؤُفِينْ مِينْ زِي د غَا يَارّنْ \add عَاذْ\add*، يَارْغَا ؤُخيّقْ نّسْ.
\v 6 ؤُشَا إِطّفْ \bd إِلِيهُو\bd*، مِّيسْ ن بَارَاخِيلْ، زِي بُوزْ، ذڭْ وَاوَاڒْ، إِنَّا:
\b
\m نشّْ ذ أَمژْيَانْ ذڭْ إِسڭّْوُوسَا
\m ؤُ كنِّيوْ ذ إِمشَّايْبُوثنْ.
\m خْ ؤُيَا رَاجِيغْ ؤُ بُّورّْنغْ
\m مَاحنْذْ أَذْ أَومْ سّشْنغْ ثُوسّْنَا إِنُو. \x ◘ \xo 32:‏6 \xt أَيُوبْ 32‏:‏4، 7؛ 15‏:‏10\x*
\m 
\v 7 نشّْ نِّيغْ:
\m ’أجّْ \add إِنِّي إِمْغَارنْ ذڭْ\add* وُوسَّانْ أَذْ سِّيوْڒنْ،
\m \add أجّْ\add* ڒْقدّْ أَمقّْرَانْ
\m ن إِسڭّْوُوسَا \add ن ؤُمشَّايْبُو\add* أَذْ إِسَّارْڭبْ ثِيغِيثْ.‘
\b
\m 
\v 8 س ثِيذتّْ، بُوحْبڒْ إِزْذغْ ذِي بْنَاذمْ،
\m أَسُوضِي ن نّفْسْ ن ؤُمْزمَّارْ خْ كُوڒْشِي
\m إِتِّيشْ أَسنْ ڒفْهَامثْ. \x ◘ \xo 32:‏8 \xt أَيُوبْ 12‏:‏13؛ 38‏:‏36؛ أَوڒن. 2‏:‏6؛ أَمب. 2‏:‏26؛ دَان. 1‏:‏17؛ 2‏:‏21\x*
\m 
\v 9 إِنِّي إِمْغَارنْ ذڭْ إِسڭّْوُوسَا
\m وَارْ ذَايْسنْ ثدْجِي ثِيغِيثْ،
\m إِوسُّورَا وَارْ فهّْمنْ إِ شّْرعْ. \x ◘ \xo 32:‏9 \xt أَيُوبْ 12‏:‏12\x*
\m 
\v 10 س ؤُيَا قَّارغْ: ’سْڒمْ-د غَارِي،
\m \add خنِّي\add* ؤُڒَا ذ نشّْ أَذْ سّشْنغْ ثُوسّْنَا إِنُو.‘
\b
\m 
\v 11 خْزَارْ، رَاجِيغْ أَوَاڒنْ نْومْ،
\m سّْحسّغْ غَارْ ڒفْهَامثْ نْومْ،
\m أَمْ ثُوغَا ثَارزُّومْ خْ وَاوَاڒنْ \add إِسڭّْمنْ\add*.
\m 
\v 12 نشّْ حْضِيغْ كنِّيوْ مْلِيحْ،
\m أَقَا ذَا، ؤُڒَا ذ إِجّنْ ثُوغَا إِزمَّارْ
\m أَذْ إِسّقْنعْ أَيُوبْ،
\m ؤُڒَا ذ إِجّنْ زَّايْومْ وَارْ إِزمَّارْ
\m أَذْ د-يَارّْ خْ وَاوَاڒنْ نّسْ.
\m 
\v 13 \add س ؤُيَا\add* وَارْ قَّارمْ:
\m ’نشِّينْ نُوفَا ثِيغِيثْ!
\m أَربِّي إِزمَّارْ أَذْ ث إِنْضَارْ،
\m وَارْ إِدْجِي بْنَاذمْ.‘
\m 
\v 14 وَارْ دْجِينْ وَاوَاڒنْ نّسْ خَافِي
\m ؤُ س وَاوَاڒنْ نْومْ وَارْ خَاسْ د-أَرِّيغْ.
\b
\m 
\v 15 تّْوَارْنَانْ نِيثْنِي، وَارْ د-تَّارِّينْ عَاذْ،
\m أَوَاڒنْ تّْوَاكّْسنْ زَّايْسنْ.
\m 
\v 16 ڒَاجِيغْ، \add مَاشَا\add* وَارْ سِّيوْڒنْ،
\m مَاغَارْ سّْبدّنْ \add أَوَاڒْ\add*،
\m وَارْ د-تَّارِّينْ عَاذْ.
\m 
\v 17 ؤُڒَا ذ نشّْ خْسغْ
\m أَذْ د-أَرّغْ ذِي نُّوبثْ إِنُو،
\m ؤُڒَا ذ نشّْ أَذْ سّشْنغْ ثُوسّْنَا إِنُو.
\b
\m 
\v 18 مَاغَارْ شُّورغْ س وَاوَاڒنْ،
\m إِحسَّارْ أَيِي بُوحْبڒْ ذِي ذَاخڒْ إِنُو.
\m 
\v 19 خْزَارْ، أَعذِّيسْ إِنُو إِتّڭّْ
\m أَمْ \add ثْزِييَّاثْ ن\add* بِينُو
\m وَارْ يَارْزِيمنْ \add عَاذْ\add*،
\m أَمْ ثْخُونْشَايْ ن يِيڒمْ ن جْذِيذْ،
\m أَقَا إِتّڭّْ أَخْمِي إِ غَا إِدُّوقّزْ.
\m 
\v 20 أَذْ سِّيوْڒغْ، حِيمَا أَذْ فْسُوسغْ،
\m أَذْ أَرْزْمغْ إِينْشِيشنْ إِنُو، أَذْ د-أَرّغْ.
\m 
\v 21 وَارْ تّڭِّيغْ س وُوذْمَاونْ أَكْ-ذ ؤُڒَا ذ إِجّْ،
\m وَارْ سِّيوْڒغْ ؤُڒَا أَكْ-ذ إِجّْ ن بْنَاذمْ
\m س وَاوَاڒنْ إِمِيژِيذنْ.
\m 
\v 22 مَاغَارْ وَارْ زمَّارغْ أَذْ ڭّغْ
\m س وَاوَاڒنْ إِمِيزِيضنْ،
\m مَاغَارْ \add خنِّي\add* أَذْ أَيِي إِكّسْ
\m ونِّي إِ ذ أَيِي إِڭِّينْ.
\b
\b
\c 33
\s1 إِلِيهُو يَارنِّي ذِي ڒْحَارْضْ أَمزْوَارُو نّسْ
\m 
\v 1 سڒْ ڒخُّو غَارْ ڒْهَارْذْ إِنُو، أَيُوبْ،
\m أوْشْ أَمزُّوغْ إِ وَاوَاڒنْ إِنُو مَارَّا.
\m 
\v 2 خْزَارْ، أَرْزْمغْ أَقمُّومْ إِنُو،
\m إِسَّاوَاڒْ يِيڒسْ إِنُو سَاذُو وَانغْ إِنُو.
\m 
\v 3 تّفّْغنْ وَاوَاڒنْ إِنُو
\m زِي ڒصْفَايثْ ن وُوڒْ إِنُو،
\m ثُوسّْنَا ثقُّورْ أَذْ خَاسْ هَارّْذنْ
\m إِينْشِيشنْ إِنُو.
\b
\m 
\v 4 أَرُّوحْ ن أَربِّي إِڭَّا أَيِي،
\m أَسُوضِي ن نّفْسْ ن ؤُمْزمَّارْ خْ كُوڒْشِي
\m إِوْشَا أَيِي ثُوذَارْثْ.
\m 
\v 5 مَاڒَا ثْزمَّارذْ، أَرّْ-د خَافِي.
\m سَارْسْ أَيِي \add ثَامسْڒَاشْثْ\add*، بدّْ \add زَّاثِي\add*!
\m 
\v 6 خْزَارْ، نشّْ أَمْ شكْ زَّاثْ إِ أَربِّي،
\m ؤُڒَا ذ نشّْ تّْوَاڭّغْ زڭْ ؤُبدْجَاعْ. \x ◘ \xo 33:‏6 \xt أَيُوبْ 9‏:‏35؛ 23‏:‏10\x*
\m 
\v 7 خْزَارْ، أَهُوذِّي إِنُو
\m وَارْ شكْ إِسِّيڭّْوِيذْ شَا،
\m وَارْ خَاكْ تّْزيَّارغْ شَا أَطَّاسْ.
\b
\m 
\v 8 س ثِيذتّْ، أَقَا ثنِّيذْ \add ث\add*
\m ذڭْ إِمزُّوغنْ إِنُو،
\m سْڒِيغْ إِ ڒْحسّْ ن وَاوَاڒنْ\add -أَ\add*: \x ◘ \xo 33:‏8 \xt أَيُوبْ 10‏:‏7؛ 16‏:‏17؛ 23‏:‏10، 11؛ 27‏:‏5\x*
\m 
\v 9 ’نشّْ ذ أَمزْذَاڭْ، بْڒَا دّنْبْ،
\m ذ أَفُورِّي \add إِ دْجِيغْ\add*،
\m وَارْ ذَايِي شَا ن ڒْمُوعْصِييّثْ.
\m 
\v 10 خْزَارْ، نتَّا يَارزُّو سِّيبّثْ
\m حِيمَا أَذْ زَّايِي إِشثْشَا،
\m إِحسّبْ أَيِي ذ ڒعْذُو نّسْ. \x ◘ \xo 33:‏10 \xt أَيُوبْ 13‏:‏24؛ 16‏:‏9؛ 19‏:‏11\x*
\m 
\v 11 إِضَارنْ إِنُو إِقّنْ إِ-ثنْ غَارْ ؤُكشُّوضْ،
\m إِحطَّا مَارَّا إِمسْرَاقْ إِنُو.‘ \x ◘ \xo 33:‏11 \xt أَيُوبْ 13‏:‏27؛ 14‏:‏16\x*
\m 
\v 12 خْزَارْ، أَذْ أَشْ إِنِيغْ،
\m وَارْ ثدْجِيذْ شَا ذ أَمْسڭّذْ ذڭْ ؤُيَا،
\m مَاغَارْ أَربِّي ذ أَمقّْرَانْ خْ بْنَاذمْ.
\b
\m 
\v 13 مِينْ خفْ كِيذسْ ثتّمْعَارِّيذْ؟
\m أَقَا نتَّا وَارْ إِتّڭّْ ڒحْسَابْ
\m إِ مَارَّا ثِيمڭَّا نّسْ!
\m 
\v 14 مَاغَارْ أَربِّي إِسَّاوَاڒْ إِشْثْ ن ثْوَاڒَا،
\m \add وَاهْ،\add* ثْنَاينْ ن ثْوَاڒَاوِينْ،
\m \add مَاشَا\add* بْنَاذمْ وَارْ إِحطِّي:
\m 
\v 15 ذِي ثِيرْجَا، س إِجّْ ن ڒوْحِييْ ذِي دْجِيڒثْ،
\m خْمِي د-إِوطَّا يِيضصْ يُودْجْغنْ خْ إِوْذَانْ،
\m ذڭْ ؤُنُوذمْ ذِي ڒشْثُو.
\m 
\v 16 \add خنِّي\add* يَارزّمْ نتَّا
\m أَمزُّوغْ ن إِوْذَانْ،
\m إِتّْشمّعْ \add س ؤُشمِّيعْ نّسْ\add*
\m خْ ؤُودّبْ نْسنْ،
\m 
\v 17 حِيمَا أَذْ إِسّْحيّذْ بْنَاذمْ
\m خْ ثْمڭِّيثْ نّسْ \add ثَاعفَّانْثْ\add*،
\m حِيمَا أَذْ إِسّْبدّْ نّْفَاخثْ خْ ورْيَازْ.
\m 
\v 18 نتَّا إِمنّعْ ڒعْمَارْ نّسْ زِي ثُورْصُوضِي،
\m ثُوذَارْثْ نّسْ زڭْ ؤُهلّكْ س لَانْسَا.
\b
\m 
\v 19 إِجيّحْ إِ-ث ڒحْرِيقْ ذِي قَامَا نّسْ
\m ؤُڒَا ذ أَمنْغِي ڒبْذَا ذڭْ إِغْسَانْ نّسْ.
\m 
\v 20 ثُوذَارْثْ نّسْ ثَارَّا إِ-ث إِتّْعِيفَّا أَغْرُومْ
\m ؤُ ڒعْمَارْ نّسْ \add يَارَّا إِ-ث إِتّْعِيفَّا\add*
\m مَاشَّا إِصبْحنْ أَطَّاسْ. \x ◘ \xo 33:‏20 \xt إِزهد. 107‏:‏18\x*
\m 
\v 21 إِقطَّا ويْسُومْ نّسْ زڭْ وُوذمْ \add نّسْ\add*،
\m إِخْسَانْ نّسْ نِّي وَارْ تّْوَاژْرِينْ \add عمَّارْصْ\add*،
\m أَقَا تّْبَاننْ ڒخُّو.
\m 
\v 22 إِتّْقَارَّابْ ڒعْمَارْ نّسْ غَارْ ثُورْصُوضِي،
\m ثُوذَارْثْ نّسْ غَارْ إِجَارَّاينْ ن ڒْموْثْ.
\b
\m 
\v 23 مَاڒَا خنِّي ذِينْ إِجّْ ن لْمَالَاكْ
\m إِبدّْ أَسْ-د غَارْ ؤُغزْذِيسْ،
\m إِجّْ ن ڒْعَاذڒْ، إِجّنْ زڭْ وَاڒفْ،
\m حِيمَا أَذْ إِسّْشنْ إِ بْنَاذمْ ثَاسڭْذَا نّسْ،
\m 
\v 24 \add خنِّي\add* أَذْ خَاسْ إِحِينّْ، أَذْ يِينِي:
\m ’فكّْ إِ-ث، أَڒَامِي نتَّا
\m وَارْ إِهكّْوِي غَارْ ثُورْصُوضِي \add ذڭْ ونْضڒْ\add*،
\m أَقَا نشّْ ؤُفِيغْ أَصْڒَاحْ \add خَاسْ\add*!‘
\b
\m 
\v 25 خنِّي أَذْ ثْنعْنعْ أَرِّيمثْ نّسْ
\m كْثَارْ زِي طّْرِي ن ثمْژِي،
\m أَذْ د-إِذْوڒْ غَارْ وُوسَّانْ ن ثمْژِي نّسْ.
\m 
\v 26 نتَّا أَذْ إِتَّارْ أَربِّي س ثُوثْرَا يُودْجْغنْ
\m ؤُ نتَّا أَذْ خَاسْ يَارْضَا،
\m أَڒَامِي وَانِيثَا أَذْ إِژَارْ ؤُذمْ نّسْ
\m ذڭْ ؤُسْڒِيوْڒوْ \add ن ڒفْرَاحثْ\add*،
\m ؤُ \add أَمُّو\add* إِ غَا يَارّْ نتَّا
\m إِ بْنَاذمْ ثَاسڭْذَا نّسْ. \x ◘ \xo 33:‏26 \xt إِزهد. 50‏:‏15؛ إِشا. 58‏:‏9\x*
\m 
\v 27 أَذْ إِغنّجْ إِ يوْذَانْ، أَذْ يِينِي:
\m ’نشّْ خْضِيغْ، سّْفَارْغغْ مِينْ إِسڭّْذنْ،
\m \add مَاشَا\add* نتَّا وَارْ زَّايِي \add ت\add* يخْڒِيفْ.
\m 
\v 28 إِفكّْ أَربِّي ڒعْمَارْ إِنُو
\m زِي ثُورْصُوضِي \add ذڭْ ونْضڒْ\add*،
\m ثُوذَارْثْ إِنُو ثْخزَّارْ
\m \add أَمُّو ذ وَامُّو\add* ذِي ثْفَاوْثْ.‘
\b
\m 
\v 29 خْزَارْ، مَارَّا أَيَا إِتّڭّْ إِ-ث أَربِّي،
\m ثْنَاينْ نِيغْ ثْڒَاثَا ن ثْوَاڒَاوِينْ
\m أَكْ-ذ ورْيَازْ،
\m 
\v 30 حِيمَا أَذْ إِسّعْقبْ ڒعْمَارْ نّسْ
\m زِي ثُورْصُوضِي \add ذڭْ ونْضڒْ\add*،
\m \add حِيمَا\add* أَذْ ث يَارّْ يَارقّْ س ثْفَاوْثْ ن ثُوذَارْثْ. \x ◘ \xo 33:‏30 \xt إِزهد. 56‏:‏14\x*
\m 
\v 31 حْضَا، أَيُوبْ! سڒْ-د غَارِي!
\m سْقَارْ، خنِّي نشّْ أَذْ سِّيوْڒغْ.
\m 
\v 32 مَاڒَا غَاركْ أَوَاڒنْ \add وجْذنْ\add*،
\m أَرّْ-د \add خَافِي\add*،
\m سِيوڒْ، مَاغَارْ غَارِي س ڒْخَاضَارْ
\m أَذْ خَاكْ بَارِّيغْ.
\m 
\v 33 مَاڒَا لَّا، سڒْ-د غَارِي!
\m سْقَارْ، ؤُ أَذْ أَشْ سّْغَارغْ ثِيغِيثْ.
\b
\b
\c 34
\s1 ڒْهَارْذْ وِيسّْ ثْنَاينْ ن إِلِيهُو خْ مَامّشْ إِتّڭّْ أَربِّي ڒبْذَا س ڒْحقّْ
\m 
\v 1 إِطّفْ \bd إِلِيهُو\bd* \add عَاوذْ\add* ذڭْ وَاوَاڒْ، إِنَّا:
\b
\m 
\v 2 سْڒمْ-د غَارْ وَاوَاڒنْ إِنُو، \add أَ\add* إِمِيغِيسنْ،
\m وْشمْ أَيِي أَمزُّوغْ،
\m \add أَ كنِّيوْ\add*، أَيْثْ ن ثُوسّْنَا.
\m 
\v 3 مَاغَارْ أَمزُّوغْ إِنبّشْ ذڭْ وَاوَاڒنْ،
\m \add أَمْ مَامّشْ\add* إِتّْقَاسَا وَانغْ مَاشَّا. \x ◘ \xo 34:‏3 \xt أَيُوبْ 12‏:‏11\x*
\m 
\v 4 جّمْ أَنغْ أَذْ نِيخْضَارْ جَارْ أَنغْ
\m مِينْ إِدْجَانْ نِيشَانْ،
\m جّمْ أَنغْ أَذْ نسّنْ جَارْ أَنغْ
\m مِينْ إِدْجَانْ ذ أَصبْحَانْ.
\b
\m 
\v 5 مَاغَارْ أَيُوبْ إِنَّا: ’نشّْ ذ أَمْسڭّذْ،
\m أَربِّي إِكّسْ أَيِي ثَاسْغَارْثْ إِنُو! \x ◘ \xo 34:‏5 \xt أَيُوبْ 27‏:‏2\x*
\m 
\v 6 وَاخَّا غَارِي ڒْحقّْ،
\m \add عَاذْ\add* تّْغِيمغْ تّْبَانغْ
\m أَمْ يِيجّْ ن بُو-إِخَارِّيقنْ!
\m \add أَيزِّيمْ ن\add* فْڒِيثْشَا إِ ذَايِي إِدْجَا،
\m وَارْ إِزمَّارْ أَذْ إِتّْوَاسّْڭنْفَا
\m أَمْ وَارْ ذِينْ إِدْجِي ؤُعذِّي.‘ \x ◘ \xo 34:‏6 \xt أَيُوبْ 6‏:‏4\x*
\m 
\v 7 مَانْ ونْ إِدْجَانْ ذ أَرْيَازْ أَمْ أَيُوبْ،
\m ونِّي إِسسّنْ أَسْثهْزِي أَمْ وَامَانْ؟
\m 
\v 8 نتَّا إِڭُّورْ ذڭْ وبْرِيذْ أَمْ إِتّْعَاشَارْ
\m إِنِّي إِتّڭّنْ ڒْمُوعْصِييّثْ،
\m إِڭُّورْ أَكْ-ذ إِرْيَازنْ إِعفَّاننْ.
\m 
\v 9 مَاغَارْ إِنَّا: ’وَارْ إِنفّعْ وَالُو إِ بْنَاذمْ،
\m مَاڒَا نتَّا ذ أَمَارْضِي غَارْ أَربِّي.‘
\b
\m 
\v 10 س ؤُيَا سْڒمْ-د غَارِي،
\m \add كنِّيوْ\add* إِرْيَازنْ إِ ذِي ثدْجَا ڒفْهَامثْ:
\m ’إِڭّْوجْ خْ أَربِّي مَاحنْذْ أَذْ يڭّْ ثُوعفّْنَا،
\m ؤُڒَا خْ ؤُمْزمَّارْ خْ كُوڒْشِي
\m مَاحنْذْ أَذْ يڭّْ مِينْ إِفَارْغنْ.‘ \x ◘ \xo 34:‏10 \xt أَعَوذ. 32‏:‏4؛ 2 إِم. 19‏:‏7؛ أَيُوبْ 8‏:‏3؛ 36‏:‏23؛ إِزهد. 92‏:‏16؛ رُوم. 9‏:‏14\x*
\m 
\v 11 مَاغَارْ نتَّا إِخْڒفْ زِي بْنَاذمْ
\m عْلَاحْسَابْ ثِيمڭَّا نّسْ،
\m ؤُ أَمْ مَامّشْ إِدْجَا وبْرِيذْ ن ورْيَازْ،
\m \add أَمُّو\add* إِ ذ أَسْ غَا يَارّْ أَذْ ث يَافْ. \x ◘ \xo 34:‏11 \xt إِزهد. 62‏:‏13؛ أَوڒن. 24‏:‏12؛ إِرْم. 17‏:‏10؛ 32‏:‏19؛ حِز. 7‏:‏27؛ 33‏:‏20؛ مت. 16‏:‏27؛ رُوم. 2‏:‏6؛ 1 كُور. 3‏:‏8؛ 2 كُور. 5‏:‏10؛ أَفا. 6‏:‏8؛ كُول. 3‏:‏25؛ 1 بُط. 1‏:‏17؛ أَسَا. 22‏:‏12\x*
\b
\m 
\v 12 س ثِيذتّْ،عمَّارْصْ وَارْ إِتّڭّْ
\m أَربِّي ثُوعفّْنَا،
\m أَمْزمَّارْ خْ كُوڒْشِي وَارْ إِسّْفَارِّيغْ شّْرعْ.
\m 
\v 13 مَانْ ونْ ث إِوكّْڒنْ خْ ثمُّورْثْ،
\m مَانْ ونْ إِسَّارْسنْ مَارَّا دُّونشْثْ؟
\m 
\v 14 مَاڒَا نتَّا أَذْ خَاسْ إِسّْنقْڒبْ ؤُڒْ نّسْ،
\m مَاڒَا أَذْ غَارسْ د-يَاوِي عَاوذْ
\m بُوحْبڒْ نّسْ ذ نّفْسْ نّسْ، \x ◘ \xo 34:‏14 \xt إِزهد. 104‏:‏29؛ أَمب. 12‏:‏7\x*
\m 
\v 15 مَارَّا بْنَاذمْ ذ ڒْمَاڒْ
\m أَذْ سُّوفّْغنْ بُوحْبڒْ
\m ؤُ بْنَاذمْ أَذْ إِعْقبْ غَارْ ؤُشَاڒْ. \x ◘ \xo 34:‏15 \xt أَمز. 3‏:‏19؛ أَمب. 12‏:‏7\x*
\b
\m 
\v 16 مَاڒَا ذَايكْ ڒفْهَامثْ، سڒْ \add خنِّي\add* إِ مَانْ أَيَا،
\m أوْشْ أَمزُّوغْ نّشْ
\m إِ ڒْحسّْ ن وَاوَاڒنْ إِنُو.
\m 
\v 17 مَا إِزمَّارْ ونِّي إِشَارّْهنْ ڒْحقّْ
\m أَذْ إِحْكمْ،
\m نِيغْ ثخْسذْ شكْ أَذْ ثذْعِيذْ
\m خْ ونِّي إِدْجَانْ ذ أَمْسڭّذْ ذ أَمقّْرَانْ؟ \x ◘ \xo 34:‏17 \xt أَمز. 18‏:‏25؛ أَيُوبْ 5‏:‏18؛ 8‏:‏3؛ 21‏:‏22؛ رُوم. 3‏:‏5\x*
\m 
\v 18 مَا أَذْ إِنِينْ إِ ؤُجدْجِيذْ:
\m ’\add شكْ\add* وَارْ ثْسكّْوِيذْ وَالُو!‘
\m ؤُ إِ ثَارْوَا ن ثَاصِيڒثْ: ’\add كنِّيوْ\add* ذ إِعفَّاننْ‘؟
\m 
\v 19 \add مَامّشْ خنِّي\add* إِ ونِّي
\m وَارْ إِسِّيزْوِيڒِينْ ڒْحُوكَّامْ
\m ؤُ وَارْ إِتّْرِيحْ أَكْ-ذ بُو-وَاڭْڒَا خْ ؤُمزْڒُوضْ،
\m مَاغَارْ مَارَّا نِيثْنِي
\m ذ ڒْخذْمثْ ن إِفَاسّنْ نّسْ. \x ◘ \xo 34:‏19 \xt أَعَوذ. 10‏:‏17؛ 2 إِم. 19‏:‏7؛ أَيُوبْ 37‏:‏24؛ ڒخ. 10‏:‏34؛ رُوم. 2‏:‏11؛ ڭال. 2‏:‏6؛ أَفا. 6‏:‏9؛ كُول. 3‏:‏25؛ 1 بُط. 1‏:‏17\x*
\m 
\v 20 مُّوثنْ ذڭْ ورْمَاشْ ن وَابْڒِيونْ،
\m ذڭْ وزْينْ ن دْجِيڒثْ.
\m تّْوَانْهزّنْ نِيثْنِي، ڒْڭنْسْ \add نِّي\add*،
\m ؤُشَا هلّْكنْ.
\m ونِّي غَارْ ثدْجَا صُّولْطَا
\m إِتّْوَاعَارّنْ غَارْ ؤُغزْذِيسْ،
\m بْڒَا \add مَا إِحَاذَا إِ-ث\add* ؤُفُوسْ \add ن بْنَاذمْ\add*.
\b
\m 
\v 21 مَاغَارْ ثِيطَّاوِينْ نّسْ خزَّارنْثْ
\m غَارْ إِبْرِيذنْ ن مْكُوڒْ إِجّْ،
\m نتَّا إِتّْوَاڒَا مْلِيحْ مَارَّا إِصُورَافْ نْسنْ. \x ◘ \xo 34:‏21 \xt 2 إِم. 16‏:‏9؛ أَيُوبْ 31‏:‏4؛ إِزهد. 34‏:‏16؛ أَوڒن. 5‏:‏21؛ 15‏:‏3؛ إِرْم. 16‏:‏17؛ 32‏:‏19\x*
\m 
\v 22 وَارْ ثدْجِي ثُوبَّارْشنْثْ
\m ؤُ وَارْ ثدْجِي ثِيڒِي ن ڒْموْثْ،
\m مَانِي زمَّارنْ أَذْ نُّوفَّارنْ
\m إِنِّي إِتّڭّنْ ڒْغَارْ. \x ◘ \xo 34:‏22 \xt إِزهد. 139‏:‏12؛ عَام. 9‏:‏2، 3؛ عبر. 4‏:‏13\x*
\m 
\v 23 وَارْ ذ أَسْ إِتّْخصِّي أَذْ إِخْزَارْ
\m ذِي بْنَاذمْ أَطَّاسْ ن ڒْوقْثْ،
\m قْبڒْ  إِ د غَا يَاذفْ غَارْ دّعْوثْ
\m زَّاثْ إِ ؤُغمْبُوبْ ن أَربِّي.
\b
\m 
\v 24 إِڒبّزْ جّْوَاحڒْ بْڒَا أَسقْسِي
\m ؤُشَا إِڭَّا إِنّغْنِي ذڭْ ومْشَانْ نْسنْ.
\m 
\v 25 مَاغَارْ نتَّا إِسّنْ ثِيمڭَّا نْسنْ،
\m إِسّْنقْڒَابْ إِ-ثنْ ذِي دْجِيڒثْ ؤُشَا تّْوَاڒبْزنْ.
\m 
\v 26 إِشَّاثْ إِ-ثنْ جَارْ إِعفَّاننْ،
\m ذڭْ إِجّْ ومْشَانْ
\m مَانِي تّْبدَّانْ \add إِوْذَانْ\add* تّْوَاڒَانْ،
\m 
\v 27 مِينْزِي نِيثْنِي حيّْذنْ خَاسْ،
\m وَارْ تّْحكِّيرنْ مَارَّا إِبْرِيذنْ نّسْ، \x ◘ \xo 34:‏27 \xt إِزهد. 28‏:‏5؛ إِشا. 5‏:‏12\x*
\m 
\v 28 مَاحنْذْ أَذْ خَاسْ إِسِّيوضْ
\m ثْغُويِّيثْ ن إِمزْڒَاضْ،
\m ؤُ مَاحنْذْ أَذْ إِسْثَاجبْ
\m إِ إِغُويَّانْ ن ڒْمُوسَاكِينْ.
\b
\m 
\v 29 مَاڒَا نتَّا يِيوِي-د ڒْهُوذْنثْ،
\m مَانْ ونْ ذَايسْ إِ غَا إِڭّنْ ڒْعِيبْ؟
\m مَاڒَا إِسّْنُوفَّارْ أَغمْبُوبْ نّسْ،
\m وِي ث غَا إِژَارنْ؟
\m \add إِحكّمْ\add* ڒَا خْ ڒْڭنْسْ أَمْ خْ بْنَاذمْ،
\m 
\v 30 حِيمَا وَارْ إِحكّمْ ؤُڒَا ذ إِجّْ ن بْنَاذمْ
\m إِ إِتّڭّنْ س ثْنَاينْ ن وُوذْمَاونْ،
\m ؤُ حِيمَا وَارْ تِّيڒِينْثْ \add عَاذْ\add* ثْخشِيفِينْ إِ ڒْڭنْسْ.
\m 
\v 31 مْڒِي إِنَّا \add بْنَاذمْ نِّي\add* إِ أَربِّي
\m ’سّْڭعّْذغْ إِخفْ إِنُو،
\m وَارْ تّْعِيوِيذغْ أَذْ ڭّغْ ڒْغَارْ.
\m 
\v 32 مِينْ وَارْ تّْوِيڒِيغْ، سْغَارْ أَيِي ث شكْ!
\m مَاڒَا ڭِّيغْ مِينْ وَارْ إِسڭّْذنْ،
\m وَارْ ث تّڭّغْ عَاذْ.‘
\b
\m 
\v 33 مَا إِتّْخصَّا أَذْ إِخْڒفْ نتَّا
\m أَمْ مَامّشْ ث ثخْسذْ شكْ؟
\m أَقَا ثسّحْقَارذْ \add ث\add*!
\m أَقَا ثخْسذْ أَذْ ثِيخْضَارذْ س يِيخفْ نّشْ،
\m نشّْ \add مَاشَا\add* لَّا!
\m مَاڒَا \add إِتّْغِيڒْ أَشْ\add* أَقَا ثسّْنذْ ت، إِنِي ت!
\m 
\v 34 إِرْيَازنْ س ڒفْهَامثْ أَذْ أَيِي إِنِينْ،
\m أَمْ \add قَاعْ\add* أَرْيَازْ أَمِيغِيسْ إِتّسْڒَا-د غَارِي،
\m 
\v 35 أَقَا أَيُوبْ وَارْ إِسِّيوڒْ س ثُوسّْنَا،
\m أَقَا أَوَاڒنْ نّسْ بْڒَا ڒفْهَامثْ \add إِ يدْجَانْ\add*.
\m 
\v 36 إِوَا، أجّْ أَيُوبْ أَذْ إِتّْوَاقدْجبْ أَڒْ أَنڭَّارْ،
\m مِينْزِي إِتَّارَّا-د
\m أَمْ إِرْيَازنْ \add شُّورنْ س\add* ڒْمُوعْصِييّثْ.
\m 
\v 37 مَاغَارْ إِ دّنْبْ نّسْ يَارنِّي \add عَاذْ\add* أَعذِّي،
\m جَارْ أَنغْ إِشَّاثْ شَامْخَا س إِفَاسّنْ
\m ؤُ تّْمَارنْينْ وَاوَاڒنْ نّسْ
\m ضِيدّْ إِ أَربِّي.
\b
\b
\c 35
\s1 ڒْهَارْدْ وِيسّْ ثْڒَاثَا ن إِلِيهُو: ثَاسڭْذَا ن بْنَاذمْ وَارْ ثْنفّعْ زَّاثْ إِ أَربِّي
\m 
\v 1 يَارَّا-د \bd إِلِيهُو\bd*، إِنَّا:
\m 
\v 2 مَا إِتّْغِيڒْ أَشْ أَيَا نِيشَانْ، أَقَا ثقَّارذْ:
\m ’ثَاسڭْذَا إِنُو كْثَارْ خْ ثنِّي ن أَربِّي‘؟
\m 
\v 3 مَاغَارْ ثنِّيذْ: ’مَانْ ڒفْضڒْ غَاركْ؟
\m مِينْ ذ أَيِي د غَا إِكَّارنْ
\m أَقَا نشّْ وَارْ تّڭّغْ دّْنُوبْ؟‘ \x ◘ \xo 35:‏3 \xt أَيُوبْ 34‏:‏9\x*
\m 
\v 4 أَذْ خَاكْ د-أَرّغْ،
\m ؤُڒَا خْ إِمدُّوكَّاڒْ نّشْ \add أَكِيذكْ\add*.
\b
\m 
\v 5 خْزَارْ أَجنَّا، ؤُ خْزَارْ،
\m حكَّارْ إِسيْنُوثنْ ثِيوَا نّشْ قَاعْ!
\m 
\v 6 مَاڒَا ثخْضِيذْ،
\m مِينْ إِ ذ أَسْ ثتّڭّذْ س مَانْ أَيَا؟
\m مَاڒَا إِعذِّيينْ نّشْ ذ أَطَّاسْ،
\m مِينْ زَّايسْ إِ ذ أَسْ إِ غَا ثَاوْيذْ؟
\m 
\v 7 مَاڒَا شكْ ذ أَمْسڭّذْ،
\m مِينْ إِ ذ أَسْ ثتِّيشذْ \add س ؤُيَا\add*،
\m نِيغْ مِينْ إِتّطّفْ نتَّا زڭْ ؤُفُوسْ نّشْ؟ \x ◘ \xo 35:‏7 \xt أَيُوبْ 22‏:‏2؛ إِزهد. 16‏:‏2؛ رُوم. 11‏:‏35\x*
\m 
\v 8 أَقَا ثُوعفّْنَا نّشْ
\m \add ثْڒقّفْ\add* أَرْيَازْ أَمْ شكْ \add وَاهَا\add*،
\m ؤُ ثَاسڭْذَا نّشْ \add ثتِّيڒِي\add*
\m ذِي طّْوعْ ن إِجّْ ن مِّيسْ ن بْنَاذمْ \add وَاهَا\add*.
\b
\m 
\v 9 سْغُويُّونْ زڭْ وَاطَّاسْ ن ڒحْصَارَاثْ،
\m تّْڒَاغَانْ غَارْ ثْوِيزَا
\m زِي سِّيبّثْ ن ؤُغِيڒْ ن أَيْثْ ن بُو-صُّولْطَا.
\m 
\v 10 \add مَاشَا\add* ؤُڒَا ذ إِجّنْ إِقَّارْ:
\m ’مَانِي إِدْجَا أَربِّي، ونِّي ذ أَيِي إِڭِّينْ،
\m ونِّي إِتِّيشنْ إِزْڒَانْ ن ؤُصبّحْ ذِي دْجِيڒثْ،
\m 
\v 11 ونِّي ذ أَنغْ إِسّڒْمَاذنْ
\m س ڒْمَاڒْ ن ثمُّورْثْ،
\m ذ ونِّي ذ أَنغْ إِتّڭّنْ ذ إِمِيغِيسنْ
\m س إِجْضَاضْ ن ؤُجنَّا؟‘
\m 
\v 12 ذِينِّي سْغُويُّونْ نِيثْنِي،
\m \add مَاشَا\add* نتَّا وَارْ د-إِتَّارِّي،
\m زِي سِّيبّثْ ن نّْفَاخثْ ن إِعفَّاننْ. \x ◘ \xo 35:‏12 \xt أَيُوبْ 27‏:‏9؛ أَوڒن. 1‏:‏28؛ 15‏:‏29؛ إِشا. 1‏:‏15؛ إِرْم. 11‏:‏11؛ يُوح. 9‏:‏31\x*
\m 
\v 13 س ثِيذتّْ، أَربِّي وَارْ إِتّسْڒِي
\m غَارْ \add إِغُويَّانْ\add* إِبطّْڒنْ،
\m أَمْزمَّارْ خْ كُوڒْشِي وَارْ \add كِيذسْ\add* إِڒهِّي.
\b
\m 
\v 14 وَاخَّا شكْ ثقَّارذْ،
\m أَقَا شكْ وَارْ ث ثتّْوِيڒِيذْ،
\m ثتّْغِيمَا ثْمسْڒَاشْثْ \add عَاذْ\add* زَّاثْ إِ وُوذمْ نّسْ.
\m رَاجَا ث خنِّي.
\m 
\v 15 مَاڒَا ڒخُّو أَخيّقْ نّسْ
\m وَارْ إِشِّيثْ عَاذْ،
\m مَا \add خنِّي\add* نتَّا وَارْ إِسِّينْ
\m خْ ؤُعذِّي إِمْغَارْ؟ \x ◘ \xo 35:‏15 \xt أَيُوبْ 11‏:‏6\x*
\m 
\v 16 أَيُوبْ إِشَارّڭْ أَقمُّومْ نّسْ بَاطڒْ،
\m إِتّڭّْ أَوَاڒنْ إِمقّْرَاننْ نْهْڒَا ثُوسّْنَا.
\b
\b
\c 36
\s1 ڒْهَارْدْ وِيسّْ أَربْعَا ن إِلِيهُو خْ ؤُجَارّبْ ذ وعْقَابْ غَارْ أَربِّي
\m 
\v 1 يَارْنِي \bd إِلِيهُو\bd* \add ذڭْ وَاوَاڒْ\add*، إِنَّا:
\b
\m 
\v 2 صْبَارْ شْوَايْثْ أَكِيذِي،
\m \add خنِّي\add* نشّْ أَذْ أَشْ سّشْنغْ،
\m أَقَا ذِينْ عَاذْ ڒسْبَابْ \add كْثَارْ\add*
\m ذِي طّْوعْ ن \add ثْمسْڒَاشْثْ ن\add* أَربِّي.
\m 
\v 3 نشّْ أَذْ د-أَوْيغْ ثُوسّْنَا إِنُو
\m زِي ڒَاڭّْوَاجْ،
\m أَذْ نعْمغْ ثَاسڭْذَا
\m ن ونِّي ذ أَيِي د-إِخڒْقنْ.
\m 
\v 4 مَاغَارْ س ثِيذتّْ،
\m أَوَاڒنْ إِنُو وَارْ دْجِينْ ذ إِخَارِّيقنْ،
\m أَقَا \add ذَا\add* زَّاثكْ ونِّي ذ بُو-ثُوسّْنَا س ثِيذتّْ.
\b
\m 
\v 5 خْزَارْ، أَربِّي إِمْغَارْ أَطَّاسْ،
\m \add مَاشَا\add* وَارْ إِسّحْقِيرِي \add حذْ\add*،
\m إِمْغَارْ جّْهذْ ن ڒفْهَامثْ \add نّسْ\add*. \x ◘ \xo 36:‏5 \xt أَيُوبْ 9‏:‏4؛ 12‏:‏13، 16؛ 37‏:‏23؛ 38‏:‏23\x*
\m 
\v 6 أَعفَّانْ وَارْ ث إِتّجِّي أَذْ إِدَّارْ،
\m \add مَاشَا\add* إِ إِمزْڒَاضْ إِتَّاغْ أَسنْ ثَاسْغَارْثْ \add نْسنْ\add*.
\m 
\v 7 نتَّا وَارْ إِسّْحيِّيذْ ثِيطَّاوِينْ نّسْ
\m خْ ؤُمْسڭّذْ،
\m \add مَاشَا\add* إِسّْغِيمِي ثنْ إِ ڒبْذَا
\m خْ ڒْعَارْشْ أَكْ-ذ إِجدْجِيذنْ،
\m \add ؤُشَا أَمُّو\add* إِ غَا تّْوَاسُّوعْڒَانْ. \x ◘ \xo 36:‏7 \xt إِزهد. 33‏:‏18؛ 34‏:‏16؛ 113‏:‏8\x*
\b
\m 
\v 8 مَاڒَا تّْوَاوْثنْ نِيثْنِي ذِي ڒڭْيُوضْ،
\m تّْوَاحبّْسنْ ذِي سّْنَاسڒْ نْ ڒغْبنْ،
\m 
\v 9 \add خنِّي\add* إِسّْشنْ أَسنْ ثِيمڭَّا نْسنْ
\m ذ إِعذِّيينْ نْسنْ،
\m أَقَا مْغَارنْ أَطَّاسْ.
\m 
\v 10 يَارزّمْ أَمزُّوغْ نْسنْ إِ ؤُوبّخْ،
\m إِقَّارْ أَسنْ أَذْ د-ذوْڒنْ
\m زِي ڒْمُوعْصِييّثْ \add نْسنْ\add*.
\b
\m 
\v 11 مَاڒَا سْڒِينْ ؤُ سخَّارنْ أَسْ،
\m أَذْ سّْقفْڒنْ ذڭْ وفْڒَاحْ ؤُسَّانْ نْسنْ
\m ؤُ ذِي زّْهَارْ إِسڭّْوُوسَا نْسنْ.
\m 
\v 12 \add مَاشَا\add* مَاڒَا وَارْ سْڒِينْ،
\m أَذْ تّْوَاهلّْكنْ س لَانْسَا،
\m أَذْ سُّوفّْغنْ بُوحْبڒْ
\m أَمْ وَارْ غَارْسنْ ثدْجِي بُو ثُوسّْنَا.
\b
\m 
\v 13 نِيثْنِي إِنِّي إِسّْنِيعْمِيڒنْ ذڭْ وُوڒْ \add نْسنْ\add*،
\m تّْستَّافنْ أَغْضَابْ،
\m وَارْ ثتَّارنْ أَعَاونْ
\m مَاڒَا نتَّا إِشَارْفْ إِ-ثنْ.
\m 
\v 14 ڒعْمَارْ نْسنْ أَذْ إِمّثْ
\m ؤُمِي نِيثْنِي \add عَاذْ\add* ذِي ثمْژِي،
\m \add مَاغَارْ\add* دَّارنْ جَارْ إِمثْليّنْ. \x ◘ \xo 36:‏14 \xt أَيُوبْ 22‏:‏16\x*
\m 
\v 15 أَذْ إِفكّْ أَمزْڒُوضْ ذِي ڒغْبنْ نّسْ،
\m ذِي دّدْجْ أَذْ يَارْزمْ أَمزُّوغْ نْسنْ.
\b
\m 
\v 16 أَمُّو إِ غَا إِعَارّنْ ؤُڒَا ذ شكْ
\m زڭْ وُوضُوفْ ن ڒحْصَارثْ،
\m غَارْ تَّاسِيعْ مَانِي وَارْ إِتِّيڒِي عَاذْ ؤُنذْقفْ،
\m مَانِي إِ غَا ثِيڒِي طَّابْڒَا نّشْ
\m ثشُّورْ \add س مَاشَّا\add* إِ ذَايسْ ثَاذُونْثْ. \x ◘ \xo 36:‏16 \xt إِزهد. 23‏:‏5\x*
\m 
\v 17 \add مَاشَا\add* شكْ ثنُّوغذْ
\m ذِي شّْرعْ أَكْ-ذ ؤُعفَّانْ،
\m \add مَاشَا\add* دّعْوثْ ذ ثنْفُوتْشْ
\m تَّاسنْثْ-إِ-د أَكْ-ذ وَايَاوَايَا.
\m 
\v 18 حْضَا أَقَا أَسْعَارْ
\m وَارْ شكْ إِتّْغَارِّي إِ ؤُسْثهْزِي
\m ؤُ ڒْقدّْ ن دّيّثْ
\m وَارْ شكْ إِسُّوفُّوغْ زڭْ وبْرِيذْ.
\b
\m 
\v 19 مَا إِغُويَّانْ نّشْ
\m أَذْ شكْ سَّارنْ زِي ڒحْصَارثْ،
\m نِيغْ مَارَّا مِينْ ثتّڭّذْ
\m س مَارَّا ثِيزمَّارْ نّشْ؟
\m 
\v 20 وَارْ تّْمژْرِي ذِي دْجِيڒثْ،
\m خْمِي غَا تّْوَاكّْسنْ ڒڭْنُوسْ
\m زڭْ ومْشَانْ نْسنْ.
\m 
\v 21 حْضَا إِخفْ نّشْ، وَارْ ڭُّورْ
\m خْ ؤُغزْذِيسْ مَانِي إِتّْوَافّْ ڒْغشّْ،
\m أَقَا شكْ أَذْ ثِيخْذَارذْ أَيَا خْ وَاضَارْ.
\b
\m 
\v 22 خْزَارْ، أَربِّي إِسّْعُودْجْ س جّهْذْ نّسْ،
\m مَانْ ونْ إِدْجَانْ ذ أَمْسڒْمَاذْ أَمْ نتَّا؟
\m 
\v 23 مَانْ ونْ إِ ذ أَسْ إِسّْشَاننْ أَبْرِيذْ؟
\m نِيغْ مَانْ ونْ إِ ذ أَسْ إِنَّانْ:
\m ’شكْ ثڭِّيذْ ڒْغشّْ‘؟ \x ◘ \xo 36:‏23 \xt أَعَوذ. 32‏:‏4؛ 2 إِم. 19‏:‏7؛ أَيُوبْ 8‏:‏3؛ 34‏:‏10؛ رُوم. 9‏:‏14\x*
\m 
\v 24 عْقڒْ أَذْ ثسّْعُودْجِيذْ
\m ڒْْخذْمثْ \add ن إِفَاسّنْ\add* نّسْ،
\m \add ڒْْخذْمثْ نّسْ\add* إِ زِي تّْغنَّاجنْ إِوْذَانْ.
\m 
\v 25 كُوڒْ بْنَاذمْ إِتّْوَاڒَا ت،
\m زِي ڒَاڭّْوَاجْ تّْوَاڒَانْ \add ت\add* إِوْذَانْ.
\b
\m 
\v 26 خْزَارْ، أَربِّي ذ أَمقّْرَانْ،
\m وَارْ نْزمَّارْ أَذْ أَسْ نفْهمْ،
\m ڒْْقدّْ ن إِسڭّْوُوسَا نّسْ
\m وَارْ نْزمَّارْ أَذْ \add ذَايسْ\add* نَارْزُو. \x ◘ \xo 36:‏26 \xt إِزهد. 90‏:‏2؛ 92‏:‏9؛ 93‏:‏2؛ 102‏:‏13؛ إِشا. 63‏:‏16؛ إِڭجذ. 5‏:‏19؛ دَان. 6‏:‏27؛ عبر. 1‏:‏12\x*
\m 
\v 27 مَاغَارْ نتَّا إِجبّذْ
\m ثُوذِّيمِينْ ن وَامَانْ،
\m ثِينِّي د-إِتّْوَاكّْسنْ زِي ثَايُّوثْ
\m \add خنِّي\add* ذوْڒنْثْ ذ أَنْژَارْ،
\m 
\v 28 \add أَنْژَارْ\add* نِّي زِي تّْنسْنِيسِينْ إِسيْنُوثنْ،
\m \add أَنْژَارْ\add* نِّي د إِوطَّانْ
\m س ؤُفيّضْ خْ إِوْذَانْ.
\m 
\v 29 مَانْ ونْ إِتّْحَاكَانْ \add عمَّارْصْ\add*
\m ذڭْ ؤُبزّعْ ن إِسيْنُوثنْ،
\m ؤُڒَا ذ ڒْحسّْ إِسّڭّْوَاذنْ
\m زِي ثخْزَانْثْ نّسْ؟
\b
\m 
\v 30 خْزَارْ، إِتّْبزّعْ ثَافَاوْثْ نّسْ
\m ثِيوَا ن يِيخفْ نّسْ،
\m إِتّْڒحَّافْ \add زَّايسْ\add*
\m طّْڒُوفَا يُودْجْغنْ قَاعْ ن ڒبْحَارْ. \x ◘ \xo 36:‏30 \xt إِزهد. 8‏:‏2\x*
\m 
\v 31 مَاغَارْ س ؤُيَا إِتّْشَارّعْ ڒڭْنُوسْ.
\m إِتِّيشّْ مَاشَّا س وَاطَّاسْ. \x ◘ \xo 36:‏31 \xt أَيُوبْ 37‏:‏13\x*
\m 
\v 32 إِتّْشُورَّا إِفَاسّنْ نّسْ س ثْفَاوْثْ،
\m إِوصَّا ت أَذْ ثڒْقفْ ثَانْذَايْثْ.
\m 
\v 33 أَضَارْضحْ \add ن وَاسَّامنْ\add* إِتّْبَارّحْ زَّايسْ،
\m ؤُڒَا ذ ثَاحِيمَارْثْ \add ثتّْبَارّحْ\add*
\m أَقَا نتَّا أَذْ د-يَاسْ.
\b
\b
\c 37
\s1 أَكمّڒْ ن ڒْهَارْذْ وِيسّْ أَربْعَا ن إِلِيهُو: ڒمْغَارثْ ن أَربِّي ذِي طَّابِيعَا
\m 
\v 1 وَاهْ، س ؤُيَا إِتَّارْجِيجْ وُوڒْ  إِنُو،
\m إِنطُّو زڭْ ومْشَانْ نّسْ.
\m 
\v 2 سْڒمْ مْلِيحْ إِ زّْهِيرْ ن ثْمِيجَّا نّسْ،
\m إِ وجْذَابْ \add ن وَاجَّاجْ\add* إِ د-إِتّكّنْ
\m زڭْ ؤُقمُّومْ نّسْ. \x ◘ \xo 37:‏2 \xt إِزهد. 29‏:‏3\x*
\m 
\v 3 إِسّكّْ إِ-ث سَاذُو مَارَّا أَجنَّا،
\m ؤُشَا \add إِسّكّْ\add* ثَافَاوْثْ نّسْ
\m أَڒْ إِنڭُّورَا ن ثمُّورْثْ.
\m 
\v 4 أَوَارْنِي أَسْ إِزهَّارْ س ثْمِيجَّا \add إِجهْذنْ\add*،
\m إِهمْهمْ س ثْمِيجَّا ن لْعَاضَامَا نّسْ
\m ؤُ وَارْ إِمنّعْ \add أَسَّامنْ\add*،
\m مَاڒَا ثتّْوَاسڒْ ثْمِيجَّا نّسْ.
\m 
\v 5 أَربِّي إِدَّارْذِيحْ س ثْمِيجَّا نّسْ
\m س ثبْرِيذْثْ ن ڒعْجبْ،
\m إِتّڭّْ ڒحْوَايجْ ثِيمقّْرَانِينْ،
\m نشِّينْ وَارْ أَسنْثْ نْفهّمْ. \x ◘ \xo 37:‏5 \xt أَيُوبْ 5‏:‏9؛ 9‏:‏10؛ 36‏:‏26\x*
\b
\m 
\v 6 مَاغَارْ إِقَّارْ إِ وذْفڒْ:
\m ’وْضَا غَارْ ثمُّورْثْ!‘،
\m ؤُشَا \add خنِّي\add* أَذْ د-يَاسْ ونْژَارْ،
\m أَنْژَارْ إِشَّاثنْ س إِغزْرَانْ نّسْ إِجهْذنْ. \x ◘ \xo 37:‏6 \xt إِزهد. 147‏:‏16\x*
\m 
\v 7 نتَّا إِتّْشمّعْ أَفُوسْ ن مْكُوڒْ بْنَاذمْ،
\m حِيمَا مَارَّا إِوْذَانْ أَذْ سّْننْ،
\m أَقَا ذ ڒخْذَايمْ نّسْ.
\m 
\v 8 ڒوْحُوشْ تّْنُوفَّارنْ ذِي ڒمْرَاڭحْ
\m ؤُ تّْغِيمَانْ ذڭْ إِفْرَانْ نْسنْ.
\m 
\v 9 ثتَّاسْ-د ثْحَارْيَاضْثْ زْ
\m أڭْ وخَّامْ نّسْ ن ذَاخڒْ
\m ؤُ أَكْ-ذ ؤُسمِّيضْ ن شَّامَالْ
\m \add ثتَّاسْ-د\add* ؤُڒَا ذ ثسْمضْ.
\m 
\v 10 س ؤُسُوضِي ن نّفْسْ \add نّسْ\add*
\m إِتَّاوِي-د أَربِّي أَجْرِيسْ،
\m جمْذنْ وَاطَّاسْ ن وَامَانْ. \x ◘ \xo 37:‏10 \xt أَيُوبْ 38‏:‏29، 30؛ إِزهد. 147‏:‏17، 18\x*
\b
\m 
\v 11 وَاهْ، إِتّْعمَّارْ إِسيْنُوثنْ س ثُوفّثْ،
\m إِتّْبزّعْ أَسيْنُو ن ثْفَاوْثْ نّسْ.
\m 
\v 12 وَانِيثَا إِتّْرَاحْ إِتَّاسْ-د،
\m مَامّشْ ث إِندّهْ نتَّا،
\m حِيمَا أَذْ ڭّنْ مَارَّا
\m مِينْ إِ ذ أَسنْ يُومُورْ
\m خْ وُوذمْ ن ثمُّورْثْ، خْ ثمُّورْثْ.
\m 
\v 13 أَذْ ثَافْ أَذْ ث ثْژَارذْ أَمْ يِيجّْ ن وعْمُوذْ،
\m نِيغْ أَمْ إِ \add ڒفْضڒْ\add* ن ثمُّورْثْ،
\m نِيغْ أَمْ \add وسْشَانْ ن\add* ثْمخْسَا إِشُووَّارنْ. \x ◘ \xo 37:‏13 \xt ؤُف. 9‏:‏18، 23؛ 1 صم. 12‏:‏18، 19؛ عِز. 10‏:‏9؛ أَيُوبْ 36‏:‏31\x*
\b
\m 
\v 14 أوْشْ أَمزُّوغْ إِ مَانْ أَيَا، \add أَ\add* أَيُوبْ،
\m بدّْ، \add سْقَارْ\add*، ؤُ حْضَا خْ ڒعْجَايبْ ن أَربِّي.
\m 
\v 15 مَا ثسّْنذْ
\m مَامّشْ إِ خَاسنْ إِضبَّارْ أَربِّي،
\m مَامّشْ إِسّْرُوغَا ثْفَاوْثْ ن ؤُسيْنُو نّسْ؟
\m 
\v 16 مَا ثسّْنذْ
\m مَامّشْ تّحْرَارَانْ إِسيْنُوثنْ،
\m \add مَا ثسّْنذْ\add* ڒعْجَايبْ
\m ن ونِّي غَارْ ثدْجَا ثُوسّْنَا ثْمُونْ.
\b
\m 
\v 17 شكْ، ونِّي ؤُمِي إِحمَّا وَارُّوضْ،
\m مَاڒَا نتَّا إِسَّارْسَا ثَامُّورْثْ
\m س أَرِّيحْ ن لْجَانُوبْ،
\m 
\v 18 مَا ثْبزّْعذْ أَكِيذسْ ڒْقُوبّثْ ن ؤُجنَّا،
\m ثنِّي \add ذِينْ\add* إِبدّنْ
\m أَمْ يِيشْثْ ن ثِيسِيثْ إِفسْينْ؟ \x ◘ \xo 37:‏18 \xt أَمز. 1‏:‏6\x*
\m 
\v 19 سَارْڭبْ أَنغْ شكْ مِينْ إِ ذ أَسْ غَا نِينِي،
\m مَاغَارْ نشِّينْ وَارْ \add نْزمَّارْ\add*
\m أَذْ نْفسَّارْ وَالُو مْلِيحْ زَّاثسْ
\m زِي سِّيبّثْ ن ثَادْجسْثْ.
\m 
\v 20 مَا أَذْ أَسْ هَاجَانْ، أَقَا سِّيوْڒغْ \add أَمُّو\add*؟
\m مَاڒَا شَا ن يِيجّنْ أَذْ \add ت\add* يِينِي،
\m أَذْ إِتّْوَاصَارْضْ نِيشَانْ. \f ◼ \fr 37:‏20 \ft \bd ’أَذْ إِتّْوَاصَارْذْ نِيشَانْ‘\bd* - إِخْسْ أَذْ يِينِي س لْغَاضَابْ ن سِيذِي.\f*
\b
\m 
\v 21 ڒخُّو وَارْ إِتّْوِيڒِي \add بْنَاذمْ\add* ثَافَاوْثْ،
\m ثنِّي يَارقّنْ ذڭْ إِسيْنُوثنْ،
\m \add مَاشَا\add* مَاڒَا إِعْذُو ؤُسُوضِي ن ؤُسمِّيضْ،
\m أَقَا إِفَارّضْ إِ-ثنْ.
\m 
\v 22 زِي شَّامَالْ إِتَّاسْ-د وُورغْ،
\m ثِيسِّيقْثْ إِسَّاڭّْوَاذنْ \add ثَارْسَا\add* خْ أَربِّي.
\m 
\v 23 أَمْزمَّارْ خْ كُوڒْشِي،
\m ونِّي وَارْ نْزمَّارْ أَذْ ث نَافْ،
\m ونِّي ذ أَمقّْرَانْ ذِي جّهْذْ،
\m نتَّا وَارْ إِتّْذدْجِي ڒْحقّْ
\m ذ ثْسڭْذَا إِفيّْضنْ. \x ◘ \xo 37:‏23 \xt أَيُوبْ 9‏:‏4؛ 12‏:‏13، 16؛ 36‏:‏5؛ إِزهد. 99‏:‏4\x*
\m 
\v 24 س ؤُيَا تّڭّْوذنْ زَّايسْ إِوْذَانْ،
\m نتَّا وَارْ إِخزَّارْ
\m غَارْ يِينِّي \add إِحسّْبنْ إِخفْ نْسنْ\add* ذ إِمِيغِيسنْ.
\b
\b
\c 38
\s1 أَربِّي إِسِّيوڒْ أَكْ-ذ أَيُوبْ خْ وخْڒَاقْ ن مَارَّا مِينْ إِدْجَانْ
\m 
\v 1 أَوَارْنِي أَسْ يَارَّا-د \bd سِيذِي\bd* خْ أَيُوبْ زِي ثْحَارْيَاضْثْ، إِنَّا:
\b
\m 
\v 2 مَانْ ونْ إِسّْبَارّْشْننْ أَشَاوَارْ،
\m س وَاوَاڒنْ بْڒَا ثُوسّْنَا؟ \x ◘ \xo 38:‏2 \xt أَيُوبْ 42‏:‏3\x*
\m 
\v 3 بْيسْ \add خنِّي\add* ثِيجْعِينَّاثِينْ نّشْ أَمْ ورْيَازْ.
\m نشّْ خْسغْ أَذْ شكْ سّقْسِيغْ
\m ؤُ شكْ، أَرّْ-د خَافِي!
\b
\m 
\v 4 مَانِي شكْ ثُوغَا
\m ؤُمِي ڭِّيغْ نشّْ ذْسَاسْ ن ثَامُّورْثْ؟
\m إِنِي ث مَاڒَا غَاركْ ڒفْهَامثْ \add س ثِيذتّْ\add*. \x ◘ \xo 38:‏4 \xt أَوڒن. 8‏:‏29\x*
\m 
\v 5 مَانْ ونْ إِڭِّينْ ڒعْبَارْ نّسْ،
\m \add وَاهْ،\add* شكْ ثسّْنذْ ت،
\m \add مَا وَارْ إِدْجِي أَمنِّي\add*؟
\m مَانْ ونْ خَاسْ إِمحْضنْ أَفِيڒُو ن ڒعْبَارْ؟
\m 
\v 6 مِينْ خفْ هْوَانْ ذْسُوسَا نّسْ،
\m نِيغْ مَانْ ونْ إِسَّارْسنْ
\m أَژْرُو ن ثغْمَارْثْ نّسْ،
\m 
\v 7 ؤُمِي إِثْرَانْ ن صّْبهْ
\m غنّْجنْ \add جْمِيعْ\add* س ڒفْرَاحثْ،
\m ؤُمِي سْڒِيوْڒونْ
\m مَارَّا أَرَّاونْ ن أَربِّي؟
\b
\m 
\v 8 مَانْ ونْ إِبلّْعنْ ڒبْحَارْ س ثوُّورَا،
\m ؤُمِي د-إِدُّوقّزْ
\m ؤُشَا إِفّغْ-د زڭْ ؤُعذِّيسْ ن يمَّاسْ، \x ◘ \xo 38:‏8 \xt أَمز. 1‏:‏9؛ أَيُوبْ 26‏:‏10؛ إِزهد. 33‏:‏7؛ 104‏:‏9؛ أَوڒن. 8‏:‏29؛ إِرْم. 5‏:‏22\x*
\m 
\v 9 ؤُمِي ذ أَسْ ڭِّيغْ إِسيْنُوثنْ ذ أَرُّوضْ نّسْ،
\m إِجّْ ن ؤُسيْنُو إِبُّومْبسْ ذ أَمنْذِيڒْ
\m مَاحنْذْ أَذْ ذَايسْ ث سّهْنُونّْضغْ،
\m 
\v 10 ؤُمِي ذ أَسْ أَرْژِيغْ أَفْرَايْ إِنُو
\m \add أَمْ إِجّْ ن وحْفُورْ يُودْجْغنْ\add*،
\m ؤُ ؤُمِي ذ أَسْ ڭِّيغْ أَعْمُوذْ
\m إِ ؤُبلّعْ ذ ثوُّورَا،
\m 
\v 11 نِّيغْ: ’أَڒْ ذَا إِ د غَا ثَاسذْ، وَارْعدُّو.
\m ذَانِيثَا أَذْ ثتّْوَاسّْبدّْ
\m نّْفَاخثْ ن ڒمْوَاجْ نّشْ.‘
\b
\m 
\v 12 مَا ثُومُورذْ شكْ \add أَثفُّو ن\add* صّْبحْ
\m ذڭْ وُوسَّانْ نّشْ؟
\m مَا ثسّْشَانذْ إِ ثْفَاوْثْ ن ڒفْجَارْ
\m أَمْشَانْ نّسْ،
\m 
\v 13 مَاحنْذْ أَذْ ثطّفْ أَفْرِيونْ ن ثمُّورْثْ،
\m أَڒَامِي أَذْ زَّايسْ زّرْزنْ إِعفَّاننْ؟
\m 
\v 14 أَذْ ثذْوڒْ \add ثمُّورْثْ\add*
\m أَمْ ثَارِّيسْثْ \add سَاذُو\add* طَّابعْ،
\m \add مَارَّا ثِيمسْڒَايِينْ\add*
\m أَذْ \add خَاسْ\add* تّْوَاسّْبدّنْثْ \add عَاوذْ\add*
\m أَمْ مَامّشْ إِ ثدْجَا إِجّْ ن وَارُّوضْ.
\m 
\v 15 إِعفَّاننْ أَذْ أَسنْ ثتّْوَاكّسْ
\m ثْفَاوْثْ نْسنْ
\m ؤُ أَغِيڒْ إِتّْوَاسّْڭعّْذنْ
\m أَذْ إِتّْوَارْژْ.
\b
\m 
\v 16 مَا ثِيوْضذْ غَارْ ڒْعُونْصَارَاثْ ن ڒبْحَارْ،
\m مَا ثُويُورذْ \add عمَّارْصْ\add* خْ وُوذمْ
\m ن \add ثمُّورْثْ\add* ن \add وَامَانْ\add* إِهوْڒنْ؟
\m 
\v 17 مَا تّْوَاعَارَّانْثْ
\m ثوُّورَا ن ڒْموْثْ إِ شكْ،
\m مَا ثژْرِيذْ ثِيوُّورَا ن ثِيڒِي ن ڒْموْثْ؟
\m 
\v 18 مَا ثتَّاوِي-د ڒفْهَامثْ نّشْ
\m أَڒْ إِنڭُّورَا ن ثمُّورْثْ؟
\m إِنِي ث مَاڒَا ثسّْنذْ أَيَا مَارَّا.
\m 
\v 19 مَانِي إِدْجَا وبْرِيذْ غَارْ ثْزذِّيغْثْ ن ثْفَاوْثْ؟
\m ؤُ ثَادْجسْثْ، مَانِي ثدْجَا ثْزذِّيغْثْ نّسْ،
\m 
\v 20 حِيمَا أَذْ ثْزمَّارذْ أَذْ ت ثْنذْهذْ
\m غَارْ ومْشَانْ نّسْ،
\m ؤُ أَذْ ثسّْنذْ مْلِيحْ إِمسْرَاقْ
\m غَارْ ثَادَّارْثْ نّسْ؟
\m 
\v 21 شكْ أَقَا ثسّْنذْ مَانْ أَيَا \add نِيغْ\add*،
\m مِينْزِي شكْ ثُوغَا ثْخڒْقذْ، \add نِيغْ لَّا؟\add*
\m ؤُ \add مَا وَارْ إِدْجِي\add*
\m ڒْْقدّْ ن وُوسَّانْ نّشْ ذ أَطَّاسْ؟
\b
\m 
\v 22 مَا ثُوذْفذْ غَارْ إِخَّامنْ
\m ن ڒخْزنْ ن وذْفڒْ،
\m \add مَا\add* ثژْرِيذْ ڒهْرِيثْ ن ثبْرُورِي،
\m 
\v 23 نِّي خْ شطَّارغْ إِ ڒْوقْثْ ن ڒحْصَارثْ،
\m إِ وَاسّْ ن ڭَارَّا ذ ؤُمنْغِي؟
\m 
\v 24 مَانِي إِدْجَا وبْرِيذْ إِتّْبطَّانْ ثِيفَاوْثْ،
\m ؤُڒَا ذ \add أَبْرِيذْ\add* إِ زِي إِتّْوَابزّعْ
\m ؤُسمِّيضْ ن شَّارْقْ خْ ثمُّورْثْ؟
\m 
\v 25 مَانْ ونْ إِفدْجقْ ڒْمِيزَابْ
\m إِ ڒْحمْڒثْ ن ونْژَارْ،
\m ؤُڒَا ذ أَبْرِيذْ إِ وَاسَّامْ ن وَاجَّاجنْ
\m 
\v 26 حِيمَا أَذْ إِسّكّْ أَنْژَارْ خْ ثمُّورْثْ
\m نِّي ذِي وَارْ \add إِزْذِيغْ\add* حذْ،
\m خْ ڒخْڒَا إِ وَارْ ذِي \add إِزْذِيغْ\add* ؤُڒَا ذ إِجّْ،
\m 
\v 27 حِيمَا أَذْ إِسَّارْوَا
\m جّْوَايهْ إِخْڒَانْ ؤُ إِتّْوَاخْڒَانْ
\m ؤُ حِيمَا أَذْ إِسّغْمِي أَرْبِيعْ ذ طّْرِي؟ \x ◘ \xo 38:‏27 \xt إِزهد. 107‏:‏35\x*
\b
\m 
\v 28 مَا أَنْژَارْ غَارسْ شَا ن بَابَاسْ،
\m نِيغْ مَانْ ونْ إِ د-إِتّجَّانْ
\m ثُوذِّيمِينْ ن نّْذَا؟
\m 
\v 29 زِي مَانْ أَعذِّيسْ إِ زِي د-إِفّغْ وجْرِيسْ،
\m ؤُ نّْذَا إِجرْسنْ ن ؤُجنَّا،
\m وِي إِ-ث-إِ-د-يُورْونْ؟
\m 
\v 30 دَّاكّْوَاڒنْ وَامَانْ أَمْ وژْرُو
\m ؤُشَا إِجَارْسْ وُوذمْ ن \add وَامَانْ\add* إِهوْڒنْ.
\b
\m 
\v 31 مَا ثْزمَّارذْ أَذْ ثْشدّذْ
\m أَڭْرَاوْ ن سبْعَا ن يثْرَانْ،
\m نِيغْ ثْفسّْيذْ سّْنَاسڒْ \add ن يثْرَانْ\add* ن ؤُرِييُونْ؟ \x ◘ \xo 38:‏31 \xt أَيُوبْ 9‏:‏9؛ عَام. 5‏:‏8\x*
\m 
\v 32 مَا ثْزمَّارذْ أَذْ د-ثسُّوفّْغذْ
\m إِثْرَانْ ن زُوذْيَاكْ غَارْ ڒْحَاڒْ نْسنْ،
\m ؤُڒَا ذ دُّوبْ \add أَمقّْرَانْ\add* أَكْ-ذ ثَارْوَا نّسْ؟
\m 
\v 33 مَا ثسّْنذْ إِزرْفَانْ ن ؤُجنَّا،
\m نِيغْ ثْزمَّارذْ أَذْ ثْضبَّارذْ
\m خْ ؤُقَارِّي نْسنْ ذِي ثمُّورْثْ؟ \x ◘ \xo 38:‏33 \xt إِرْم. 31‏:‏35\x*
\b
\m 
\v 34 مَا ثْزمَّارذْ أَذْ ثسّْڭعّْذذْ
\m غَارْ إِسيْنُوثنْ ثْمِيجَّا نّشْ،
\m أَڒَامِي شكْ إِ غَا ثْذڒْ
\m إِشْثْ ن ڒْحمْڒثْ ن وَامَانْ؟
\m 
\v 35 مَا ثْزمَّارذْ أَذْ ثسّكّذْ أَسَّامنْ
\m مَاحنْذْ أَذْ قدْجْقنْ،
\m أَذْ أَشْ إِنِينْ: ’أَقَا-نغْ ذَا‘؟
\m 
\v 36 مَانْ ونْ إِسَّارْسنْ ثِيغِيثْ
\m ذِي ذَاخڒْ \add ن بْنَاذمْ\add*؟
\m نِيغْ مَانْ ونْ إِوْشِينْ ڒفْهَامثْ إِ ڒعْقڒْ؟ \x ◘ \xo 38:‏36 \xt أَيُوبْ 32‏:‏8؛ أَمب. 2‏:‏26؛ دَان. 1‏:‏17\x*
\m 
\v 37 مَانْ ونْ إِفَارّْزنْ إِسيْنُوثنْ س ڒعْقڒْ،
\m إِغَارَّافنْ \add ن وَامَانْ\add* ن ؤُجنَّا
\m وِي ثنْ إِتّْزدْجَاعنْ،
\m 
\v 38 أَڒَامِي إِتّْوَافْسِييْ ؤُشَاڒْ،
\m إِذْوڒْ ذ أَبدْجَاعْ،
\m ؤُشَا ڒسْقنْ إِبُورْسَا ن ثمُّورْثْ؟
\b
\m 
\v 39 مَا ثْزمَّارذْ
\m أَذْ ثطّْفذْ زَّارْذثْ إِ ثَايْرَاذْثْ،
\m نِيغْ أَذْ ثسّڒْهُوذْ
\m ڒَْاژْ ن وَايْرَاذنْ إِمژْيَاننْ، \x ◘ \xo 38:‏39 \xt إِزهد. 104‏:‏21\x*
\m 
\v 40 ڒَامِي نُوفَّارنْ ذڭْ إِفْرَانْ نْسنْ،
\m ؤُ تّْحَامَانْ زِي ڒمْرَاڭحْ نْسنْ؟
\m 
\v 41 مَانْ ونْ إِسّوْجَاذنْ
\m إِ ؤُبَاغڒْ مَاشَّا نّسْ،
\m خْمِي سْغُويُّونْ إِمژْيَاننْ نّسْ
\m غَارْ أَربِّي،
\m خْمِي تّمْهَافَانْ نْهْڒَا مَاشَّا؟ \x ◘ \xo 38:‏41 \xt إِزهد. 147‏:‏9؛ مت. 6‏:‏26\x*
\b
\b
\c 39
\m 
\v 1 مَا ثسّْنذْ مڒْمِي تَّارْونْثْ
\m ثْغَايْذِينْ ن ثْصُوضَارْ؟
\m مَا ثْحطِّيذْ ثِيرْوَا ن ثُوذَاذِينْ؟ \x ◘ \xo 39:‏1 \xt إِزهد. 29‏:‏9\x*
\m 
\v 2 مَا ثْزمَّارذْ أَذْ ثْحسْبذْ
\m إِيُورنْ ن ثْكسِّيثْ نْسنْثْ،
\m مَا ثسّْنذْ ڒْحَاڒْ ن ثِيرْوَا نْسنْثْ؟
\m 
\v 3 نِيثنْثِي تّقْوِيسنْثْ،
\m تَّارْونْثْ إِمژْيَاننْ نْسنْثْ،
\m ڒوْجعْ نْ ثَارُوثْ نْسنْثْ سُّوفُّوغنْ ثنْ.
\m 
\v 4 محْضنْ إِمژْيَاننْ نْسنْثْ،
\m مقَّارنْ ذِي ڒخْڒَا،
\m تّفّْغنْ غَارْ بَارَّا
\m ؤُ وَارْ غَارْسنْثْ تّْعِيقِّيبنْ.
\b
\m 
\v 5 مَانْ ونْ يَارْخُونْ إِ وغْيُوڒْ ن ڒخْڒَا
\m ؤُ ثِيسَارِّيفِينْ ن وغْيُوڒْ ن ڒخْڒَا،
\m مَانْ ونْ ثنْثْ إِفسْينْ؟
\m 
\v 6 نشّْ وْشِيغْ أَسْ ثَانزْرُوفْثْ ذ ثَادَّارْثْ،
\m ڒوْضَا أَمدْجَاحْ ذ ثِيزذِّيغِينْ نّسْ. \x ◘ \xo 39:‏6 \xt أَيُوبْ 24‏:‏5؛ إِرْم. 2‏:‏24\x*
\m 
\v 7 نتَّا إِضحّشْ
\m خْ ڒْغَاشِي إِنْهوْڒنْ ن ثنْذِينْثْ،
\m وَارْ إِتّسْڒِي إِغُويَّانْ
\m ن يِينِّي إِزيَّارنْ \add إِسمْغَانْ\add*.
\m 
\v 8 جّْوَايهْ ن إِذُورَارْ
\m ذ دّْمَانِي نّسْ ن ثَاروْسَا،
\m يَارزُّو \add ذَايْسنْ\add* خْ قَاعْ مِينْ إِدْجَانْ ذ أَزِيزَا.
\b
\m 
\v 9 مَا أَذْ إِخْسْ إِغَايْضْ ن ڒخْڒَا
\m أَكْ-ذ وَاشَّاونْ ذ إِزِيرَارنْ
\m أَذْ خَاكْ إِسخَّارْ؟
\m مَا أَذْ إِسّنْسْ غَارْ ڒْمذْوذْ نّشْ؟
\m 
\v 10 مَا ثْزمَّارذْ أَذْ ثْمنْعذْ
\m إِغَايْضْ ن ڒخْڒَا
\m أَكْ-ذ وَاشَّاونْ ذ إِزِيرَارنْ
\m س وسْغُونْ نّسْ غَارْ ؤُعيّذْ \add ن وشْرَازْ\add*؟
\m مَا أَذْ إِشَارْزْ ثِييْسَارِينْ أَوَارْنِي أَشْ؟
\m 
\v 11 مَا ثتّْشَاڒذْ خَاسْ،
\m مِينْزِي نتَّا إِجْهذْ أَطَّاسْ،
\m مَا أَذْ أَسْ ثجِّيذْ ڒْخذْمثْ نّشْ؟
\m 
\v 12 مَا أَذْ خَاسْ ثتّشْڒذْ
\m أَذْ \add غَاركْ\add* د-يَارّْ زَّارِيعثْ نّشْ،
\m أَذْ ت يَاوِي غَارْ ؤُنذْرَارْ نّشْ؟
\b
\m 
\v 13 أَفْرِيونْ ن نّْعَامثْ شَّاثنْ س ڒْخَاضَارْ.
\m مَاشَا مَا أَقَا-ثنْ ذ أَفْرِيونْ
\m ذ وَارِّيشْ إِذَاڒْفنْ ن ؤُبلَّارْجْ؟ \f ◼ \fr 39:‏13 \ft \bd ’نّْعَامثْ‘\bd* - نِيغْ ’ثَانْهَالْثْ‘ (ثِينْهَالِينْ)\f*
\m 
\v 14 مَاغَارْ ثتّجَّا ثِيمدْجَاڒِينْ نّسْ
\m ذڭْ ؤُشَاڒْ ن ثمُّورْثْ،
\m ثتّجَّا إِ-ثنْثْ تّحْمَانْثْ ذڭْ إِجْذِي.
\m 
\v 15 ثتّتُّو أَقَا إِجّْ ن ؤُضَارْ
\m إِزمَّارْ أَذْ ثنْثْ إِڒْبزْ،
\m أَقَا ڒوْحُوشْ ن ڒخْڒَا
\m زمَّارنْ أَذْ خَاسنْثْعفْسنْ.
\m 
\v 16 نتَّاثْ ثْقسّحْ ذڭْ إِمژْيَاننْ نّسْ
\m أَخْمِي وَارْ دْجِينْ نّسْ.
\m بَاطڒْ إِ ثتّڭّْ ثِيزمَّارْ نّسْ،
\m مَاغَارْ نتَّاثْ وَارْ ثْكسِّي س ومْنُوسْ،
\m 
\v 17 مَاغَارْ أَربِّي إِجَّا إِ-ت أَذْ ثتُّو ثِيغِيثْ،
\m وَارْ ذ أَسْ إِوْشِي بُو ثسْغَارْثْ ذِي ڒفْهَامثْ.
\m 
\v 18 \add مَاشَا\add* مَاڒَا ثكْسِي ذڭْ ؤُضَارْ نّسْ،
\m ثسّْڭعَّاذْ إِخفْ نّسْ،
\m ثْضحّشْ خْ ؤُيِيسْ ذ ونِّي خَاسْ إِنْيِينْ.
\b
\m 
\v 19 مَا ثْزمَّارذْ أَذْ ثوْشذْ جّهْذْ إِ ؤُيِيسْ؟
\m مَا ثْزمَّارذْ أَذْ ثسّْيَارْضذْ
\m إِجِيمَانْ نّسْ س سّْبِيبْ؟
\m 
\v 20 مَا ثْزمَّارذْ أَذْ ث يَارّْ إِنطُّو
\m أَمْ ؤُبُورْخسْ؟
\m ڒْْعزّْ ن ؤُسْنحْنحْ نّسْ
\m إِسَّاڭّْوَاذْ أَطَّاسْ.
\m 
\v 21 خبّْشنْ \add إِيْسَانْ\add* س إِضَارنْ نْسنْ
\m \add أَمْ تّْرَاجَانْ\add* ذِي ڒوْضَا ن ثغْزُورْثْ،
\m إِفَارْحْ \add ؤُيِيسْ\add* س جّهْذْ نّسْ،
\m إِتّفّغْ، مَاحنْذْ أَذْ إِمّڒْقَا
\m أَكْ-ذ ڒسْنَاحْ.
\m 
\v 22 إِضحّشْ خْ مَارَّا مِينْ إِسَّاڭّْوَاذنْ،
\m وَارْ إِتّْنخْڒِيعْ زِي وَالُو،
\m وَارْ إِذِّيكّْوِيڒْ غَارْ ضفَّارْ زِي سِّيفْ.
\m 
\v 23 إِتّْقَارْقُوبْ وقْرَابْ ن فْڒِيثْشَاثْ
\m سنّجْ نّسْ،
\m لَانْسَا ذ فْڒِيثْشَا تِّيسِّيقنْ.
\m 
\v 24 س دّْرِيزْ \add ن ثْشضْيِينْ\add* ذ زّْعَامثْ
\m إِصَارّضْ ثَامُّورْثْ،
\m وَارْ إِزمَّارْ أَذْ إِتّْوَاسّْبدّْ
\m غَارْ ؤُسُوضِي ن ؤُيِيشّْ ن إِشَارِّي.
\m 
\v 25 غَارْ ثْمِيجَّا ن ؤُسُوضِي ذڭْ ؤُيِيشّْ ن إِشَارِّي
\m إِسّْنحْنِيحْ: ’هههْ!‘
\m إِتَّاشَا أَكْ-ذ ؤُمنْغِي زِي ڒَاڭّْوَاجْ،
\m زّْڭَا ن ڒْحُوكَّامْ ذ إِغُويَّانْ ن ؤُمنْغِي.
\b
\m 
\v 26 مَا إِطَّاوْ ڒْبَازْ زِي ڒفْهَامثْ نّشْ،
\m أَقَا إِتّْبزَّاعْ أَفْرِيونْ نّسْ غَارْ لْجَانُوبْ؟
\m 
\v 27 مَا إِسّْڭعَّاذْ ؤُڭِيذَارْ إِخفْ نّسْ
\m سنّجْ قَاعْ س ڒُومُورْ نّشْ،
\m إِتّڭّْ ڒْعُوشّْ نّسْ ذِي ڒُوعْڒَا؟ \x ◘ \xo 39:‏27 \xt إِرْم. 49‏:‏16؛ عُوب. 4\x*
\m 
\v 28 إِزدّغْ ؤُ إِسّْنُوسَا خْ جَّارْفْ،
\m خْ ؤُشنْقُوبْ ن جَّارْفْ، أَقَا-ث ذ لْبُورْجْ \add نّسْ\add*.
\m 
\v 29 سّنِّي إِحطَّا زَّارْذثْ،
\m ثِيطَّاوِينْ نّسْ خزَّارنْثْ إِ-ت-د
\m زِي ڒَاڭّْوَاجْ.
\m 
\v 30 إِمژْيَاننْ نّسْ سكّْفنْ إِذَامّنْ
\m ؤُ مَانِي دْجَانْ إِنِّي إِتّْوَانْغنْ، أَقَا-ث ذِينْ \add إِ يدْجَا\add*. \x ◘ \xo 39:‏30 \xt مت. 24‏:‏28؛ لك. 17‏:‏37\x*
\b
\b
\c 40
\s1 سِيذِي إِسِّيوڒْ أَكْ-ذ أَيُوبْ
\m 
\v 1 يَارْنِي يَارَّا-د \bd سِيذِي\bd* خْ أَيُوبْ، إِنَّا:
\b
\m 
\v 2 مَا إِخْسْ ونِّي إِتّمْشَارَّاعنْ
\m أَكْ-ذ ؤُمْزمَّارْ خْ كُوڒْشِي أَذْ \add ث\add* إِسڭّمْ؟
\m أجّْ ونِّي إِخْسنْ أَذْ إِذْعَا أَربِّي،
\m أَذْ د-يَارّْ!
\b
\m 
\v 3 \add خنِّي\add* يَارَّا-د \bd أَيُوبْ\bd* خْ سِيذِي، إِنَّا:
\b
\m 
\v 4 خْزَارْ، نشّْ ذْرُوسْ،
\m مِينْ زمَّارغْ أَذْ خَاكْ د-أَرّغْ؟
\m نشّْ أَذْ ڭّغْ أَفُوسْ إِنُو خْ ؤُقمُّومْ إِنُو. \x ◘ \xo 40:‏4 \xt إِزهد. 39‏:‏10\x*
\m 
\v 5 أَقَا سِّيوْڒغْ إِشْثْ ن ثْوَاڒَا،
\m \add مَاشَا\add* وَارْ د-تَّارِّيغْ \add عَاذْ\add*.
\m ثْوَاڒَا وِيسّْ ثْنَاينْ وَارْ \add ذ أَسْ\add* أَرنِّيغْ!
\b
\m 
\v 6 \add خَاسْ ؤُشَا\add* يَارْنِي يَارَّا-د \bd سِيذِي\bd* خْ أَيُوبْ زِي ثْحَارْيَاضْثْ، إِنَّا:
\b
\m 
\v 7 بْيسْ \add خنِّي\add* ثِيجْعِينَّاثِينْ نّشْ أَمْ ورْيَازْ.
\m نشّْ خْسغْ أَذْ شكْ سّقْسِيغْ
\m ؤُ شكْ، أَرّْ-د خَافِي!
\m 
\v 8 مَا ثخْسذْ س ثِيذتّْ أَذْ ثَارْژذْ ڒْحُوكْمْ إِنُو؟
\m مَا ثخْسذْ أَذْ غَارِي د-ثَارّذْ ڒْعِيبْ،
\m مَاحنْذْ أَذْ ثْبَانذْ شكْ ذ أَمْسڭّذْ؟ \x ◘ \xo 40:‏8 \xt إِزهد. 51‏:‏6؛ رُوم. 3‏:‏4\x*
\m 
\v 9 مَا غَاركْ أَغِيڒْ أَمْ أَربِّي؟
\m مَا ثْزمَّارذْ أَذْ ثدَّارْذْحذْ
\m أَمْ وَاجَّاجْ س ثْمِيجَّا \add نّشْ\add*؟
\b
\m 
\v 10 قّنْ خنِّي إِخفْ نّشْ
\m س لْعَاضَامَا ذ ؤُعُودْجِي،
\m أَرْضْ س ثِيسِّيقْثْ ذ ڒْعزّْ.
\m 
\v 11 أجّْ أَذُوقّزْ ن ؤُفُوڭمْ نّشْ أَذْ إِزدْجعْ،
\m خْزَارْ غَارْ كُوڒْ بُو نّْفَاخثْ،
\m ؤُشَا سهْوَا إِ-ث!
\m 
\v 12 خْزَارْ مْلِيحْ غَارْ مْكُوڒْ بُو-نّْفَاخثْ،
\m سهْوَا إِ-ث،
\m ڒْْبزْ إِعفَّاننْ ذڭْ ومْشَانْ نْسنْ.
\m 
\v 13 فَّارْ إِ-ثنْ مَارَّا أَمْ مُوننْ ذڭْ ؤُشَاڒْ،
\m شْفنْ إِغمْبَابْ نْسنْ
\m ذِي ثْنُوفّْرَا \add سَاذُو ثَامُّورْثْ\add*.
\m 
\v 14 خنِّي ؤُڒَا ذ نشّْ أَذْ شكْ سّمْغَارغْ،
\m مِينْزِي أَفُوسْ نّشْ أَفُوسِي إِسّنْجمْ إِ شكْ.
\b
\m 
\v 15 خْزَارْ مَاشَا ڒْوحْشْ، \add ’بهِيمُوثْ‘\add*،
\m ونِّي ڭِّيغْ أَمْ مَامّشْ شكْ ڭِّيغْ.
\m إِتّتّْ أَرْبِيعْ أَمْ ؤُفُونَاسْ.
\m 
\v 16 خْزَارْ جّهْذْ نّسْ ذِي ثجْعِينَّاثِينْ نّسْ،
\m ڒْْعزّْ نّسْ ذڭْ إِژوْرَانْ نّسْ ن ؤُعذِّيسْ!
\m 
\v 17 مَاڒَا إِخْسْ، أَذْ إِڭّْ أَكنَّاسْ نّسْ
\m أَمْ ثْشجَّارْثْ ن ثنْڭلْثْ،
\m إِژوْرَانْ ن ثْمصَّاضِينْ نّسْ
\m محْضنْ مُّوذنْ.
\m 
\v 18 إِخْسَانْ نّسْ تّڭّنْ
\m أَمْ يِيقُوذَاسْ ن نّْحَاسْ،
\m أَمْ بَارَّاثْ ن وُوزَّاڒْ
\m إِضَارنْ ذ إِغَادْجنْ نّسْ.
\b
\m 
\v 19 نتَّا ذ أَمزْوَارُو ن إِبْرِيذنْ ن أَربِّي.
\m ونِّي ث يڭِّينْ، إِوْشَا أَسْ سِّيفْ نّسْ.
\m 
\v 20 إِوَا، إِذُورَارْ تَّاوْينْ أَسْ-د أَرْبِيعْ،
\m مَارَّا ڒوْحُوشْ ن ييَّارْ تِّيرَارنْ ذِينِّي.
\m 
\v 21 إِبُّوزّڒْ سَاذُو إِ ثْشجُّورَا إِتّڭّنْ ثِيڒِي،
\m ذڭْ ؤُذُورِّي ن ؤُغَانِيمْ، ذِي سّبْخثْ.
\m 
\v 22 أَذْ خَاسْ دُّورْينْثْ ثْشجُّورَا إِ إِتِّيشنْ ثِيڒِي،
\m كُوڒْ إِشْثْ س ثِيڒِي نّسْ،
\m ثِينمْرَاتْشْ ن ثْغزْرَاثِينْ تّنّْضنْثْ أَسْ-د.
\m 
\v 23 خْزَارْ، مَاڒَا إِهَاجْ يغْزَارْ، وَارْ إِتَّارْجِيجِي،
\m إِتّْغِيمَا يَارْسَا مَاڒَا ڒْحمْڒثْ ن لْ-ؤُرْذُونْ
\m ثُوذفْ أَسْ-د غَارْ ؤُقمُّومْ.
\m 
\v 24 مَا إِزمَّارْ \add بْنَاذمْ\add* أَذْ ث إِطّفْ
\m \add أَمْ إِخزَّارْ نتَّا نِيشَانْ\add* ذِي ثِيطَّاوِينْ نّسْ،
\m أَذْ أَسْ إِسّْنُوقّبْ ثِينْزَارْثْ س ثسْغُونِينْ؟
\b
\m 
\v 25 مَا ثْزمَّارذْ أَذْ ثْجبْذذْ ’لِيبِييَاثَانْ‘
\m س ثْسنَّارْثْ ن ويْمَارْ،
\m نِيغْ أَذْ ثسّهْوِيذْ إِڒسْ نّسْ
\m ذڭْ ؤُفِيڒُو \add ن ويْمَارْ\add*؟
\m 
\v 26 مَا ثْزمَّارذْ أَذْ أَسْ ثڭّذْ
\m ثَاخَاذنْثْ ن ؤُغَانِيمْ ذِي ثنْزَارْثْ نّسْ،
\m نِيغْ أَذْ ثسّْنُوقّْبذْ
\m أَغسْمِيرْ نّسْ س ؤُغَانْتْشُو؟
\m 
\v 27 مَا أَذْ زَّايكْ إِتَّارْ أَحِينِّي؟
\m مَا أَذْ إِسِّيوڒْ أَكِيذكْ
\m س وَاوَاڒنْ إِمِيزِيضنْ؟
\m 
\v 28 مَا أَذْ يڭّْ أَكِيذكْ ڒْعَاهْذْ؟
\m مَا ثْزمَّارذْ أَذْ ث ثكْسِيذْ
\m ذ إِسْمغْ إِ ڒبْذَا؟
\m 
\v 29 مَا ثْزمَّارذْ أَكِيذسْ ثتِّيرَارذْ
\m أَمْ أَكْ-ذ إِجّْ ن ؤُجْضِيضْ،
\m نِيغْ أَذْ ث ثقّْنذْ إِ ثحْرَامِينْ نّشْ؟
\b
\m 
\v 30 مَا زمَّارنْ إِنيْمَارنْ
\m أَذْ ذَايسْ سبّبنْ؟
\m مَا زمَّارنْ أَذْ ث بْضَانْ
\m جَارْ أَيْثْ ن كنْعَانْ؟
\m 
\v 31 مَا ثْزمَّارذْ أَذْ ثجُّوذْ
\m ثِيڒْمشْثْ نّسْ س فْڒِيثْشَاثْ،
\m نِيغْ س لَانْسَا ن إِسڒْمَانْ أَزدْجِيفْ نّسْ؟
\m 
\v 32 سَارْسْ خَاسْ أَفُوسْ نّشْ،
\m خمّْ غَارْ ؤُمنْغِي،
\m وَارْ ث تّڭِّيذْعمَّارْصْ عَاذْ.
\b
\b
\c 41
\m 
\v 1 خْزَارْ، \add قَاعْ\add* أَرَاجِي أَذْ إِفْشڒْ،
\m مْغِيرْ ثَامُوغْڒِي نّسْ
\m ثسّعْڭَازْ \add بْنَاذمْ\add*.
\b
\m 
\v 2 وَارْ إِدْجِي ؤُڒَا ذ إِجّنْ أَمُّو ذ أَزعَّامْ
\m أَڒَامِي ث إِ غَا إِهْوڒْ،
\m مَانْ ونْ \add خنِّي\add* إِزمَّارنْ
\m أَذْ إِقِّيمْ إِبدّْ
\m زَّاثْ إِ ؤُغمْبُوبْ إِنُو؟
\m 
\v 3 مَانْ ونْ إِ ذ أَيِي إِوْشِينْ \add شَا\add* ذ أَمزْوَارُو،
\m أَڒَامِي ذ أَيِي إِتّْخصَّا
\m أَذْ غَارسْ ث-إِ-د-أَرّغْ؟
\m مَارَّا مِينْ إِدْجَانْ سَاذُو إِجنْوَانْ إِنُو! \x ◘ \xo 41:‏3 \xt ؤُف. 19‏:‏5؛ أَعَوذ. 10‏:‏14؛ إِزهد. 24‏:‏1؛ 50‏:‏12؛ رُوم. 11‏:‏35؛ 1 كُور. 10‏:‏26، 28\x*
\b
\m 
\v 4 نشّْ وَارْ تّسْقَارِيغْ خْ إِضَارنْ نّسْ،
\m خْ ڒمْغَارثْ ن جّهْذْ \add نّسْ\add*
\m ؤُ خْ ؤُشُووَّارْ ن وَادُّوذْ نّسْ.
\m 
\v 5 مَانْ ونْ إِزعّْمنْ أَذْ إِقجّعْ
\m ثَاقْشُورْثْ ن وَارُّوضْ نّسْ،
\m مَانْ ونْ إِزعّْمنْ أَذْ د-إِقَارّبْ
\m غَارْ ثْيُويَا ن ڒسْذُوذْ ن ثغْمَاسْ
\m ن إِغسْمَارْ نّسْ؟
\m 
\v 6 مَانْ ونْ إِزمَّارنْ
\m أَذْ يَارْزمْ ثِيوُّورَا
\m غَارْ ؤُغمْبُوبْ نّسْ؟
\m مِينْ إِنّْضنْ إِ ثغْمَاسْ نّسْ
\m مْغِيرْ ذ أَنخْڒِيعْ.
\b
\m 
\v 7 ڒسْذُوذْ ن ثْسدَّارِييِينْ
\m خْ وعْرُورْ نّسْ شنّْعنْ،
\m \add كُوڒْ  إِجّْ زَّايْسنْ\add* إِتّْوَابلّعْ
\m س طَّابعْ إِقّْننْ نِيشَانْ.
\m 
\v 8 إِجّنْ إِقّْننْ \add نِيشَانْ\add* غَارْ إِجّْ ن نّغْنِي،
\m وَارْ إِزمَّارْ أَذْ ذِينْ د-يَاذفْ
\m أَرِّيحْ جَارْ أَسنْ.
\m 
\v 9 ڒسّْقنْ ذڭْ وَايَاوْيَا،
\m ؤُذْفنْ ذڭْ إِخفْ نْسنْ
\m مَاحنْذْ وَارْ ثمّْسبْضِينْ.
\b
\m 
\v 10 مَاڒَا إِعْضسْ، ثتّْشعْشِيعْ ثْفَاوْثْ،
\m ثِيطَّاوِينْ نّسْ ڭِّينْثْ
\m أَمْ وَابْڒِيونْ ن ثْفَاوْثْ نْ ڒفْجَارْ.
\m 
\v 11 زڭْ ؤُجقْمِيمْ نّسْ
\m تّفّْغنْ-د إِصفْضَاونْ،
\m ثِيفطُّوثِينْ ن ثْمسِّي دُّوقُّوزنْثْ \add زَّايسْ\add*.
\m 
\v 12 دّخَّانْ إِتّْفوَّارْ
\m زڭْ إِخُوبَاشْ ن ونْزَارنْ نّسْ،
\m أَمْ زڭْ إِجّْ ن ؤُطنْجِيرْ إِتّْننَّانْ
\m س ؤُغَانِيمْ إِدُّوخُّوننْ.
\m 
\v 13 ثْوَارِّيثْ ن نّفْسْ نّسْ ثسّكَّارَا
\m ثِيمسِّي ذِي ڒفْحمْ،
\m زڭْ ؤُحرْقُومْ نّسْ
\m إِتّفّغْ-د ؤُحَاذُوقْ ن ثْمسِّي.
\b
\m 
\v 14 جّهْذْ إِزْذغْ ذڭْ إِجِيمَانْ نّسْ،
\m غَارْ زَّاثْ نّسْ إِنطُّو ؤُنخْڒِيعْ.
\m 
\v 15 طّْرُوفَا ن ويْسُومْ \add ن ؤُعذِّيسْ\add* نّسْ
\m مّْڒسْقنْ،
\m أَمْ خَاسنْ فسْينْ،
\m وَارْ زمَّارنْ أَذْ تّْوَانْهزّنْ.
\m 
\v 16 ؤُڒْ نّسْ إِقْسحْ أَمْ وژْرُو،
\m إِقْسحْ أَمْ ثصْضَارْثْ ن سْوَادَّايْ ن ثْسِيرْثْ.
\m 
\v 17 خْمِي إِسّْڭعَّاذْ إِخفْ نّسْ،
\m تّْنخْڒَاعنْ إِنِّي إِجهْذنْ،
\m زڭْ ؤُقزّبْ خطَّانْ ذِي ثنْذَايْثْ.
\b
\m 
\v 18 مَاڒَا إِڒْقفْ إِ-ث شَا ن يِيجّنْ س سِّيفْ،
\m وَارْ إِتِّيڒِي، \add وَارْ إِدْجِي س\add* ؤُحْرِيشْ،
\m ڒَْا س لَانْسَا ؤُڒَا س فْڒِيثْشَا.
\m 
\v 19 ؤُزَّاڒْ غَارسْ أَمْ ؤُڒُومْ،
\m نّْحَاسْ أَمْ ؤُكشُّوضْ يَارْشَانْ.
\m 
\v 20 فْڒِيثْشَا ن ڒْقوْسْ وَارْ ث ثسّْثوّجْ،
\m إِژْرَا ن إِدْجِييْ دَّاكّْوَاڒنْ زَّاثسْ ذ أَقشْقَاشْ.
\m 
\v 21 إِذبُّوزنْ إِحسّبْ إِ-ثنْ أَمْ ؤُقشْقَاشْ،
\m إِضحّشْ خْ ؤُزبْزبْ ن ؤُحْرِيشْ.
\b
\m 
\v 22 غَارْ وَادَّايْ ن \add ؤُعذِّيسْ نّسْ\add*
\m أَقَا ذِينْ إِشقْفَانْ إِقضْعنْ،
\m إِتّْجَارَّا ڒمْوَاسْ إِقضْعنْ نِّي
\m \add أَمْ ثڒْوِيحْثْ إِتّحْڒُودْجُوضنْ إِ ؤُسَارْوثْ\add*
\m ثِيوَا ن ؤُبدْجَاعْ.
\m 
\v 23 إِڭَّا ڒَادْجَاغْ أَذْ إِسّْثخْثخْ أَمْ ثيْذَارْثْ،
\m إِتّڭّْ ڒبْحَارْ أَمْ ؤُمقْرَاجْ إِتّْهَاجَانْ.
\m 
\v 24 إِتّجَّا أَوَارْنِي أَسْ جُّورّثْ
\m ثَارقّْ ذ أَمسْرَاقْ،
\m \add أَمَانْ\add* إِهوْڒنْ تّْبَاننْ
\m أَمْ ؤُشُوَّافْ ن ؤُمشَّايْبُو.
\m 
\v 25 وَارْ ذِينْ إِدْجِي ؤُڒَا ذ إِجّْ خْ ثمُّورْثْ
\m يَارْوسْ ذَايسْ،
\m إِتّْوَاڭّْ حِيمَاعمَّارْصْ وَارْ إِتّڭّْوذْ.
\m 
\v 26 إِنْضَارْ ثِيطَّاوِينْ نّسْ خْ مَارَّا وِي يُوعْڒَانْ،
\m أَقَا-ث ذ أَجدْجِيذْ خْ مَارَّا
\m إِيْرَاذنْ إِمژْيَاننْ إِنفّْخنْ.
\b
\b
\c 42
\s1 أَيُوبْ إِنْعمْ إِ أَربِّي
\m 
\v 1 \bd أَيُوبْ\bd* يَارَّا-د خْ سِيذِي، إِنَّا:
\b
\m 
\v 2 ”نشّْ سّْنغْ
\m أَقَا شكْ ثْزمَّارذْ إِ كُوڒْشِي
\m وَارْ إِسّْبطِّيڒْ ؤُڒَا ذ إِجّْ ن ونْوَايْ نّشْ.
\m 
\v 3 \add شكْ ثقَّارذْ:\add*
\m ’مَانْ ونْ إِسّْبَارّْشْننْ بْڒَا ثُوسّْنَا
\m شّْوَارْ \add ن أَربِّي\add*؟‘
\m س ؤُيَا سِّيوْڒغْ خْ مِينْ وَارْ فْهِيمغْ،
\m خْ ثْمسْڒَايِينْ نِّي ذِي تّْبهْثغْ أَطَّاسْ،
\m وَارْ ثنْثْ سِّينغْ.“ \x ◘ \xo 42:‏3 \xt أَيُوبْ 38‏:‏2؛ إِزهد. 40‏:‏6؛ 131‏:‏1؛ 139‏:‏6\x*
\b
\m 
\v 4 ”سڒْ مَاشَا ؤُشَا أَذْ سِّيوْڒغْ،
\m خْسغْ أَذْ شكْ سّقْسِيغْ
\m ؤُشَا \add خنِّي\add* شكْ أَذْ أَيِي \add خَاسْ\add* ثسَّارْڭْبذْ.
\m 
\v 5 س ؤُمزُّوغْ خَاكْ إِ سْڒِيغْ \add وَاهَا\add*،
\m مَاشَا ڒخُّو ثِيطّْ إِنُو ثژْرِي شكْ.
\m 
\v 6 خْ ؤُيَا تّْعِيفِّيغْ إِخفْ إِنُو ؤُشَا نْذمّغْ،
\m قِّيمغْ ذِي ثْعجَّاجْثْ ذ يِيغّضْ.“
\b
\s1 أَربِّي إِذبَّارْ خْ وصْڒَاحْ ذ ؤُسْڭنْفِي
\m 
\v 7 أَوَارْنِي ڒَامِي ثُوغَا إِسِّيوِيڒْ سِيذِي أَوَاڒنْ-أَ أَكْ-ذ أَيُوبْ، إِنَّا سِيذِي إِ إِلِيفَازْ زِي ثَايْمَانْ: ”لْغَاضَابْ إِنُو يَارْغَا خَاكْ ؤُ خْ ثْنَاينْ ن إِمدُّوكَّاڒْ نّشْ، مَاغَارْ كنِّيوْ وَارْ خَافِي ثسِّيوْڒمْ شَا نِيشَانْ أَمْ مَامّشْ خَافِي إِسِّيوڒْ ؤُمْسخَّارْ إِنُو أَيُوبْ.
\v 8 خنِّي ڒخُّو، كْسِيمْ كنِّيوْ سبْعَا ن إِفُونَاسنْ إِمژْيَاننْ ذ سبْعَا ن إِشَارِّييّنْ، ؤُشَا ؤُيُورمْ غَارْ ؤُمْسخَّارْ إِنُو أَيُوبْ ؤُشَا قدّْممْ ثنْ ذ ثَاغَارْصْثْ ن وشْمَاضْ إِ يِيخفْ نْومْ. جّمْ أَمْسخَّارْ إِنُو أَيُوبْ أَذْ خَاومْ إِژَّادْجْ. مَاغَارْ نشّْ أَذْ سّْڭعّْذغْ أَغمْبُوبْ نّسْ \add إِ وسْثَاجبْ\add*، حِيمَا وَارْ تّڭّغْ أَكِيذْومْ أَمْ ثُوبُّوهڒْيَا نْومْ، مِينْزِي كنِّيوْ وَارْ خَافِي ثسِّيوِيڒمْ نِيشَانْ أَمْ مَامّشْ خَافِي إِسِّيوِيڒْ ؤُمْسخَّارْ إِنُو أَيُوبْ.“
\b
\m 
\v 9 \add خنِّي\add* إِفّغْ إِلِيفَازْ زِي ثَايْمَانْ، بِيلْذَاذْ زِي شُوحَا ذ صُوفَارْ زِي نَاعْمَاثْ ؤُشَا ڭِّينْ نِيثْنِي أَمْ مَامّشْ ذ أَسنْ إِنَّا سِيذِي. سِيذِي إِسّْڭعّذْ أَغمْبُوبْ ن أَيُوبْ \add إِ ؤُسْثَاجبْ ن ثْژَادْجِيثْ نّسْ\add*.
\v 10 أَوَارْنِي ڒَامِي ثُوغَا إِتّْژَادْجْ أَيُوبْ ذِي طّْوعْ ن إِمدُّوكَّاڒْ نّسْ، إِنّقْڒبْ سِيذِي ثَامحْبَاسْثْ ن أَيُوبْ إِ ذِي إِدْجَا نتَّا \add زِي سِّيبّثْ ن ڒهْڒَاشْ نّسْ\add*، ؤُشَا يَارْنِي سِيذِي ذِي مَارَّا أَڭْڒَا ن أَيُوبْ ثْنَاينْ ن ثْسقَّارْ.
\m 
\v 11 ؤُسِينْ-د غَارسْ مَارَّا أَيْثْمَاسْ ذ مَارَّا سُويثْمَاسْ ذ مَارَّا إِنِّي ث إِسّْننْ زِيشْ. نِيثْنِي شِّينْ أَكِيذسْ أَغْرُومْ ذِي ثَادَّارْثْ نّسْ ؤُشَا سّشْننْ أَسْ أَزِيدْجزْ نْسنْ ؤُشَاعزَّانْ ث خْ مَارَّا ڒْغَارْ خَاسْ د-إِغْضڒْ سِيذِي. إِوْشَا أَسْ كُوڒْ إِجّنْ زَّايْسنْ إِجّْ ن ڒوْزنْ ن نُّوقَارْثْ ؤُڒَا ذ إِشْثْ ن ثْخَاذنْثْ ن وُورغْ.
\b
\m 
\v 12 إِبَاركْ سِيذِي ثَانڭَّارُوثْ ن أَيُوبْ كْثَارْ زِي ثْمزْوَارُوثْ نّسْ، مَاغَارْ ثُوغَا غَارسْ أَربْعَا-أَڒَافْ ن وُودْجِي ذ ستَّا-أَڒَافْ ن إِڒغْمَانْ ذ وَاڒفْ ن إِفُونَاسنْ ن ثغْنَاشْثْ ذ وَاڒفْ ن ثغْيَاڒْ.
\m 
\v 13 ثُوغَا غَارسْ سبْعَا ن إِحنْجِيرنْ ذ ثْڒَاثَا ن يسِّيسْ. \x ◘ \xo 42:‏13 \xt أَيُوبْ 1‏:‏2\x*
\m 
\v 14 ثَامزْوَارُوثْ إِڭَّا أَسْ يَامِيمَا، وِيسّْ ثْنَاينْ قَّارنْ أَسْ قَاصِيعَا ذ وِيسّْ ثْڒَاثَا قَّارنْ أَسْ قَارْنْ-هَافُّوكْ.
\v 15 وَارْ ؤُفِينْ ذِي مَارَّا ثَامُّورْثْ ثِيحْرَامِينْ شْنَانْثْ أَمْ يسِّيسْ ن أَيُوبْ. بَابَاثْسنْثْ إِوْشَا أَسنْثْ ثَاسْغَارْثْ جَارْ أَيْثْمَاثْسنْثْ.
\m 
\v 16 أَيُوبْ إِدَّارْ أَوَارْنِي إِ ؤُيَا مْيَا ؤُ-ربْعِينْ ن إِسڭّْوُوسَا. نتَّا إِژْرَا إِحنْجِيرنْ نّسْ ذ إِحنْجِيرنْ ن إِحنْجِيرنْ نّسْ \add غَارسْ أَڒْ\add* جِّيڒْ وِيسّْ أَربْعَا.
\b
\m 
\v 17 أَيُوبْ إِمُّوثْ أَوَارْنِي ڒَامِي إِوْسَارْ أَطَّاسْ ؤُ ثُوغَا إِجِّيونْ ؤُسَّانْ \add ن ثُوذَارْثْ نّسْ\add*. 
