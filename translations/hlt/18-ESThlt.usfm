\v 11 \w Haman|strong="H2001"\w* loh \w amih|strong="H9908"\w* \w taengah|strong="H9997"\w* \w a|strong="H9909"\w* \w khuehtawn|strong="H6239"\w* \w thangpomnah|strong="H3519"\w* \w khaw|strong="H9999"\w*, \w amah|strong="H9909"\w* \w koca|strong="H1121"\w* a \w cungkuem|strong="H7230"\w* \w khaw|strong="H9999"\w*, \w manghai|strong="H4428"\w* loh \w a|strong="H9909"\w* \w pomsang|strong="H1431"\w* \w boeih|strong="H3605"\w* \w te|strong="H0853"\w* \w khaw|strong="H9999"\w*, \w amah|strong="H9909"\w* te \w mangpa|strong="H8269"\w* rhoek \w neh|strong="H9999"\w* \w manghai|strong="H4428"\w* kah \w sal|strong="H5650"\w* \w lakah|strong="H5921"\w* a \w ludoeng|strong="H5375"\w* \w te|strong="H0834"\w* a \w tae|strong="H5608"\w*.  
\v 12 Te \w phoeiah|strong="H9999"\w* \w Haman|strong="H2001"\w* loh, “\w Esther|strong="H0635"\w* \w manghainu|strong="H4436"\w* loh, \w manghai|strong="H4428"\w* \w neh|strong="H5973"\w* \w buhkoknah|strong="H4960"\w* a \w saii|strong="H6213"\w* \w te|strong="H0413"\w* a tloe \w khue|strong="H0935"\w* \w pawh|strong="H3808"\w*, \w kai|strong="H9901"\w* \w bueng|strong="H0518"\w* ni \w dawk|strong="H3588"\w* n'khue. \w Thangvuen|strong="H4279"\w* \w ham|strong="H9997"\w* \w khaw|strong="H1571"\w*, \w kai|strong="H0589"\w* he \w amah|strong="H9907"\w* \w loh|strong="H9997"\w* \w manghai|strong="H4428"\w* \w neh|strong="H5973"\w* n'\w khue|strong="H7121"\w* pueng.  
