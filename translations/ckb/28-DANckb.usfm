\id DAN - Biblica® Open Kurdi Sorani Standard Version
\h دانیال
\toc1 دانیال
\toc2 دانیال
\toc3 دانیال
\mt1 دانیال
\c 1
\s1 مەشقپێکردنی دانیال لە بابل
\p 
\v 1 لە ساڵی سێیەمی پاشایەتی یەهۆیاقیمی پاشای یەهودا، نەبوخودنەسری پاشای بابل هاتە ئۆرشەلیم و گەمارۆی دا.
\v 2 پەروەردگاریش یەهۆیاقیمی پاشای یەهودای دایە دەستی، لەگەڵ هەندێک لە قاپوقاچاغەکانی پەرستگای خودا. ئیتر یەهۆیاقیم و پیاوە گەورەکانی بۆ خاکی بابل ڕاپێچ کران، نەبوخودنەسریش قاپوقاچاغەکانی لە گەنجینەی پەرستگای خوداوەندی خۆی دانا.
\p 
\v 3 پاشا فەرمانی بە ئەشپەنەزی سەرۆکی دیوان کرد کە لە نەوەی ئیسرائیل لە توخمی پاشا و پیاوماقوڵەکان
\v 4 چەند گەنجێک بهێنێت کە تەندروستییان باش بێت، ڕوخساریان جوان بێت، لە هەموو بوارەکانی زانیاری کارامە بن، ئامادەییان تێدابێت بۆ فێربوونی هەموو شتێک، زوو تێبگەن، شایانی ئیشکردن بن لە کۆشکی پاشا، بۆ ئەوەی فێری زمان و ڕۆشنبیری بابلییەکان بکرێن.
\v 5 پاشا لە خوانی خۆیەوە بەشی ڕۆژانەی خواردن و شەرابی بۆ دابین کردن، فەرمانی کرد بۆ ماوەی سێ ساڵ مەشقیان پێ بکرێت، دوای ئەوە خزمەتی پاشا دەکەن.
\p 
\v 6 لەنێو ئەوانەدا هەندێکیان لە نەوەی یەهودا بوون: دانیال و حەنەنیا و میشائیل و عەزەریا.
\v 7 سەرۆکی کاربەدەستانیش ناوی نوێی لێنان، بۆ دانیال، بێلتەشەسر؛ بۆ حەنەنیا، شەدرەخ؛ بۆ میشائیل، مێشەخ؛ بۆ عەزەریاش، عەبێدنەگۆ.
\p 
\v 8 بەڵام دانیال لە دڵی خۆیدا بڕیاری دابوو کە خۆی بە خواردن و شەرابی پاشایەتییەوە گڵاو نەکات، جا داوای لە سەرۆکی کاربەدەستان کرد کە دەرفەتی پێبدات بۆ ئەوەی خۆی گڵاو نەکات.
\v 9 خوداش وای لە سەرۆکی کاربەدەستان کرد کە چاکە و میهرەبانی بە دانیال ببەخشێت.
\v 10 بەڵام سەرۆکی کاربەدەستان بە دانیالی گوت: «من لە پاشای گەورەم دەترسم، ئەوەی خواردن و خواردنەوەی ئێوەی دیاری کردووە. ئەگەر ببینێ ڕوخسارتان لە ڕوخساری گەنجە هاوتەمەنەکانتان لاوازترە، پاشا بەهۆی ئێوەوە سەرم دەبڕێت.»
\p 
\v 11 دانیالیش بەو سەرپەرشتیارەی گوت کە سەرۆکی کاربەدەستان بەسەر دانیال و حەنەنیا و میشائیل و عەزەریاوە داینابوو:
\v 12 «تکایە بۆ دە ڕۆژ خزمەتکارەکانت تاقی بکەوە: تەنها ڕووەکمان بدەرێ بیخۆین و ئاومان بدەرێ بیخۆینەوە.
\v 13 پاشان ڕوخساری ئێمە لەگەڵ ڕوخساری ئەو گەنجانە بەراورد بکە کە خواردنی پاشایەتی دەخۆن، ئینجا بەگوێرەی ئەوەی دەیبینی ئاوامان لەگەڵ بکە.»
\v 14 ئەویش بەمە ڕازی بوو و دە ڕۆژ تاقی کردنەوە.
\p 
\v 15 لە کۆتایی دە ڕۆژەکەدا دەرکەوت ڕوخساریان باشتر و تەندروستترە لە هەموو ئەو گەنجانەی لە خواردنەکانی پاشایەتییان دەخوارد.
\v 16 ئینجا سەرپەرشتیارەکەیان خواردنە تایبەت و شەرابەکەی هەڵدەگرت و لە جیاتی ئەوە ڕووەکی دەدانێ.
\p 
\v 17 بەڵام ئەو چوار گەنجە، خودا زانین و تێگەیشتنی دانێ لە هەموو جۆرە ڕۆشنبیری و زانیارییەک، دانیالیش لە هەموو بینین و خەونێک تێدەگەیشت.
\p 
\v 18 لە کۆتایی ئەو ماوەیەی کە پاشا دیاری کردبوو بیانهێننە بەردەمی، سەرۆکی کاربەدەستان ئەوانی هێنایە بەردەم نەبوخودنەسر.
\v 19 پاشا قسەی لەگەڵدا کردن، لەنێو هەموویاندا کەس نەبوو وەک دانیال و حەنەنیا و میشائیل و عەزەریا. لەبەر ئەوە چوونە ڕیزی خزمەتکارانی پاشا.
\v 20 پاشا لە هەموو بابەتێکی دانایی و تێگەیشتن پرسیاری لێکردن، بینی ئەوان دە هێندە لە سەرووی هەموو جادووگەر و ئەفسونگەرانی هەموو پاشایەتییەکەی ئەون.
\p 
\v 21 دانیالیش هەتا ساڵی یەکەمی کۆرشی پاشا لەوێ مایەوە.
\c 2
\s1 خەونی نەبوخودنەسر
\p 
\v 1 نەبوخودنەسر پاشا لە ساڵی دووەمی پاشایەتییەکەی چەند خەونێکی بینی کە بووە هۆی بێزاربوونی و خەوی لێ زڕا.
\v 2 جا پاشا فەرمانی دا جادووگەر و ئەفسونگەر و بەخت خوێنەوەرەوە و ئەستێرەناسەکان بانگ بکەن، بۆ ئەوەی پێی بڵێن کە چ خەونێکی بینیوە. کاتێک هاتن و لەبەردەم پاشادا وەستان،
\v 3 پاشا پێی گوتن: «خەونێکم بینیوە هەراسانی کردووم و دەمەوێ بزانم لێکدانەوەکەی چییە.»
\p 
\v 4 ئەستێرەناسەکان بە زمانی ئارامی بە پاشایان گوت: «ئەی پاشا، هەتاهەتایە بژیت! خەونەکە بە بەندەکانت بڵێ هەتا بۆت لێکبدەینەوە.»
\p 
\v 5 پاشا وەڵامی ئەستێرەناسەکانی دایەوە: «ئەوە بڕیاری کۆتایی منە: ئەگەر خەونەکە و لێکدانەوەکەیم پێ نەڵێن، پارچەپارچە دەکرێن و ماڵەکانتان دەبێتە کەلاوە.
\v 6 بەڵام ئەگەر خەونەکەتان پێ گوتم و لێکتاندایەوە، لە منەوە دیاری و پاداشت و ڕێزێکی گەورەتان دەست دەکەوێت. کەواتە خەونەکەم پێ بڵێن و بۆم لێکبدەنەوە.»
\p 
\v 7 دووبارە وەڵامیان دایەوە: «با پاشا خەونەکە بە بەندەکانی بڵێت هەتا بۆت لێکبدەینەوە.»
\p 
\v 8 ئینجا پاشا وەڵامی دایەوە: «من لەوە دڵنیام ئێوە دەتانەوێت کات بەدەستبهێنن، چونکە دەزانن ئەوە بڕیاری کۆتایی منە:
\v 9 ئەگەر خەونەکەم پێ نەڵێن، یەک سزاتان هەیە. ئێوە لەسەر درۆ و قسەی پووچ ڕێککەوتوون هەتا لەبەردەمم بیڵێن، هەتا بارودۆخەکە دەگۆڕێت. لەبەر ئەوە خەونەکەم پێ بڵێن، ئینجا من ئەوە دەزانم کە ئێوە دەتوانن خەونەکەم بۆ لێکبدەنەوە.»
\p 
\v 10 ئەستێرەناسەکانیش وەڵامی پاشایان دایەوە: «هیچ کەسێک لەسەر زەوی نییە ئەم داوایەی پاشا جێبەجێ بکات! هەرگیز هیچ پاشایەکی گەورەی خاوەن دەسەڵات شتێکی وای لە جادووگەر و ئەفسونگەر و ئەستێرەناس داوا نەکردووە.
\v 11 ئەوەی کە پاشا داوای دەکات زۆر قورسە. هیچ کەس ناتوانێت بۆ پاشا ئاشکرای بکات، جگە لە خوداوەندەکان، ئەوانیش نشینگەیان لەگەڵ مرۆڤدا نییە.»
\p 
\v 12 ئەوە پاشای زۆر تووڕە کرد و ڕقی هەستا، فەرمانی دا هەموو داناکانی بابل لەناوببردرێن.
\v 13 ئینجا فەرمان دەرچوو بۆ کوشتنی داناکان، بەدوای دانیال و هاوڕێکانیشیدا هاتن بۆ ئەوەی بیانکوژن.
\p 
\v 14 کاتێک ئەریۆکی سەرۆکی پاسەوانانی پاشا چوو بۆ ئەوەی داناکانی بابل بکوژێت، دانیال بە دانایی و ڕێزەوە قسەی لەگەڵ کرد،
\v 15 لە فەرماندەی پاسەوانانی پرسی: «بۆچی فەرمانەکەی پاشا ئەوەندە توندە؟» ئەریۆکیش بابەتەکەی بۆ دانیال ڕوونکردەوە.
\v 16 لێرەدا دانیال چووە ژوورەوە و داوای لە پاشا کرد کاتی پێبدات، بۆ ئەوەی لێکدانەوەی خەونەکە بۆ پاشا دەربخات.
\p 
\v 17 ئینجا دانیال گەڕایەوە ماڵەکەی خۆی و بابەتەکەی لە هاوڕێیەکانی گەیاند، لە حەنەنیا و میشائیل و عەزەریا،
\v 18 بۆ ئەوەی لەبارەی ئەم نهێنییە داوای بەزەیی لە خودای ئاسمان بکەن، هەتا خۆی و هاوڕێیەکانی لەگەڵ سەرجەم داناکانی بابل لەناونەچن.
\v 19 لە شەودا، بە بینینێک نهێنییەکە بۆ دانیال ئاشکرا کرا، دانیالیش ستایشی خودای ئاسمانی کرد،
\v 20 گوتی:
\q1 «ستایش بۆ ناوی خودا لە ئەزەلەوە و بۆ هەتاهەتایە،
\q2 چونکە دانایی و توانا هی ئەوە.
\q1 
\v 21 ئەو کات و ساتەکان دەگۆڕێت،
\q2 پاشایان لادەدات و پاشایان دادەنێت،
\q1 دانایی بە داناکان دەبەخشێت و
\q2 زانایان فێری تێگەیشتن دەکات.
\q1 
\v 22 ئەو قووڵایی و نهێنییەکان ئاشکرا دەکات،
\q2 ئەو دەزانێت چی لە تاریکیدا شاردراوەتەوە،
\q2 ڕووناکی لەلای ئەو نیشتەجێیە.
\q1 
\v 23 ئەی خودای باوباپیرانم، سوپاس و ستایشی تۆ دەکەم:
\q2 تۆ دانایی و هێزت پێدام،
\q1 تۆ وات کرد ئەوەی داوامان لێ کردی لەلای منەوە زانراو بێت،
\q2 تۆ وات کرد ئێمە خەونەکەی پاشا بزانین.»
\s1 دانیال خەونەکەی لێکدەداتەوە
\p 
\v 24 دوای ئەوە دانیال چوو بۆ لای ئەریۆک، ئەوەی پاشا دەستنیشانی کرد بۆ لەناوبردنی داناکانی بابل، پێ گوت: «داناکانی بابل لەناومەبە. بمبە لای پاشا، من خەونەکەی بۆ لێکدەدەمەوە.»
\p 
\v 25 ئینجا ئەریۆک بە پەلە دانیالی بردە لای پاشا و گوتی: «پیاوێکم لە نەوە ڕاپێچکراوەکانی یەهودا دۆزیوەتەوە کە دەتوانێت واتای خەونەکە بە پاشا بڵێت.»
\p 
\v 26 پاشا لە دانیالی پرسی، کە ناوی بێلتەشەسر بوو: «ئایا دەتوانی ئەو خەونەم پێ بڵێی کە بینیومە و هەروەها لێکی بدەیتەوە؟»
\p 
\v 27 دانیال وەڵامی دایەوە: «ئەو نهێنییەی پاشا داوای کردووە نە دانا و نە ئەفسونگەر و نە جادووگەر و نە فاڵگرەوە ناتوانن بۆ پاشا لێکی بدەنەوە.
\v 28 بەڵام خودایەک لە ئاسمان هەیە نهێنییەکان ئاشکرا دەکات، ئەو بە نەبوخودنەسری پاشای ڕاگەیاند لە ڕۆژانی داهاتوودا چی دەبێت. کاتێک تۆ لەسەر جێگاکەت بووی، ئەمە بوو ئەو خەون و بینینەی هاتە ناو مێشکت:
\p 
\v 29 «ئەی پاشا، کاتێک تۆ لەسەر جێگاکەت ڕاکشابووی، بیرت بە لای داهاتوودا چوو، ئاشکراکەری نهێنییەکان بۆی دەرخستی چی ڕوودەدات.
\v 30 سەبارەت بە ئاشکراکردنی ئەم نهێنییە بۆ من، لەبەر ئەوە نەبوو کە من داناییەکی زیاترم هەبێت لە پیاوەکانی دیکە، بەڵکو ئەمە لەبەر تۆ بوو، ئەی پاشا، تاکو لێکدانەوەکەی بزانیت و هەروەها لە بیرکردنەوەکانت تێبگەیت.
\p 
\v 31 «ئەی پاشا، تۆ تەماشات کرد و پەیکەرێکی گەورەت لەبەردەمت بینی، پەیکەرێکی زۆر گەورە و درەوشاوە، دیمەنی سەرسوڕهێنەر بوو.
\v 32 سەری پەیکەرەکە لە زێڕی بێگەرد بوو، سنگ و قۆڵەکانی لە زیو بوو، سک و ڕانەکانی لە بڕۆنز بوو،
\v 33 قاچەکانی لە ئاسن بوون و پێیەکانی بەشێکی لە ئاسن و بەشێکیشی لە قوڕی سوورکراوە بوو.
\v 34 کاتێک تەماشات دەکرد، بەردێک بڕایەوە بەبێ ئەوەی دەستی مرۆڤی بەرکەوێت، لە پێیەکانی پەیکەرەکەی دا کە لە ئاسن و قوڕی سوورکراوە بوون و وردوخاشی کردن.
\v 35 ئینجا ئاسن و قوڕە سوورکراوەکە و بڕۆنز و زیو و زێڕەکە پێکەوە وردوخاش بوون و وەک پووشی سەر جۆخینیان\f + \fr 2:35 \ft جۆخین یان سەرخەرمان ئەو زەوییە تەرخانکراوەیە کە لەلایەن وەرزێر و جوتیارەوە بەکارهێنراوە بۆ کوتانی دانەوێڵە لەسەری لەدوای کۆکردنەوەی لە کێڵگە.‏\f* لێهات لە هاویندا، با هەڵیگرت بەبێ ئەوەی شوێنەواری بمێنێت. بەڵام ئەو بەردەی لە پەیکەرەکەی دا، بوو بە کێوێکی گەورە و هەموو زەوی گرتەوە\f + \fr 2:35 \ft ئارامی: هەموو زەوی پڕکردەوە.‏\f*.
\p 
\v 36 «ئەمە خەونەکە بوو، ئێستاش با بۆ پاشا لێکی بدەینەوە.
\v 37 تۆ، ئەی پاشا، پاشای پاشایانی. خودای ئاسمان پاشایەتی و دەسەڵات و توانا و ڕێزی پێ بەخشیویت.
\v 38 مرۆڤ و گیانلەبەری دەشتودەر و باڵندەی ئاسمان لەژێر دەستی تۆن، لە هەرکوێیەک بن، تۆی بەسەر هەموویاندا زاڵ کردووە. تۆ ئەم سەرەی کە لە زێڕە.
\p 
\v 39 «پاش تۆ، پاشایەتییەکی دیکە هەڵدەستێتەوە، پایەی لە تۆ نزمترە، دوای ئەوە سێیەم پاشایەتی لە بڕۆنزە، بەسەر هەموو زەویدا زاڵ دەبێت.
\v 40 پاشان پاشایەتی چوارەم دێت، وەک ئاسن ڕەقە، چونکە ئاسن دەکوتێت و هەموو شتێک وردوخاش دەکات، وەک ئەو ئاسنەی تێکدەشکێنێت، ئەمیش هەموو ئەوانی دیکە وردوخاش دەکات و تێکیان دەشکێنێت.
\v 41 هەروەک بینیت پێیەکان و پەنجەکان بەشێکیان لە قوڕی سوورکراوە و بەشێکیان لە ئاسن بوون، پاشایەتییەکە بەم شێوەیە دابەشکراو دەبێت، بەڵام هەندێک هێزی ئاسنی تێدا دەبێت، هەروەک بینیت ئاسنەکە تێکەڵ بە قوڕی سوورکراوە بوو.
\v 42 هەروەک پەنجەی پێیەکان بەشێکیان لە ئاسن و بەشێکیان لە قوڕی سوورکراوە بوو، جا بەشێک لە پاشایەتییەکە بەهێز و بەشێکیش ناسک دەبێت.
\v 43 هەروەک بینیت ئاسنەکە تێکەڵ بە قوڕە سوورکراوەکە بوو، ئینجا ئەوان تێکەڵ بە وەچەی خەڵکی دەبن، بەڵام ئەمە بە ئەوەوە نانووسێت، هەروەک ئاسن تێکەڵ بە قوڕ نابێت.
\p 
\v 44 «لە سەردەمی ئەم پاشایانەدا خودای ئاسمان پاشایەتییەک دادەمەزرێنێت کە هەرگیز لەناوناچێت، بۆ گەلی دیکە بەجێناهێڵدرێت، هەموو ئەو پاشایەتییانە وردوخاش دەکات و کۆتاییان پێدەهێنێت، ئەو هەتاهەتایە بە چەسپاوی دەمێنێتەوە.
\v 45 ئەمە واتای بینینەیە کە بەردێک لە چیاوە بڕا، بەڵام بە دەستی مرۆڤ نا، ئاسن و بڕۆنز و قوڕی سوورکراوە و زێڕ و زیوەکەی وردوخاش کرد.
\p «خودای گەورە ئەوەی بە پاشا نیشاندا کە لە داهاتوودا ڕوودەدات. خەونەکە ڕاستە و لێکدانەوەکەشی جێی متمانەیە.»
\p 
\v 46 ئینجا نەبوخودنەسر بەسەر ڕوویدا کەوت و کڕنۆشی بۆ دانیال برد، فەرمانی دا دیاری و بخووری پێشکەش بکەن.
\v 47 پاشا بە دانیالی گوت: «بەڕاستی خودای ئێوە خودای خودایانە و گەورەی پاشایانە و ئاشکراکەری نهێنییەکانە، چونکە تۆ توانیت ئەم نهێنییە ئاشکرا بکەیت.»
\p 
\v 48 ئینجا پاشا دانیالی لە پلەیەکی بەرز دانا و دیاری زۆری پێ بەخشی. دەسەڵاتی پێدا بەسەر هەموو هەرێمی بابل و کردییە سەرۆکی هەموو داناکان.
\v 49 سەرباری ئەمەش، لەسەر داوای دانیال پاشا شەدرەخ و مێشەخ و عەبێدنەگۆی دەستنیشان کرد بۆ بەڕێوەبردنی هەرێمی بابل، بەڵام دانیال خۆی لە دیوانی پاشا مایەوە.
\c 3
\s1 پەیکەرە زێڕەکە و کوورە ئاگرەکە
\p 
\v 1 نەبوخودنەسری پاشا پەیکەرێکی لە زێڕ دروستکرد، درێژییەکەی شەست باڵ\f + \fr 3:1 \ft شەست باڵ: نزیکەی 27 مەتر.‏\f* و پانییەکەی شەش باڵ\f + \fr 3:1 \ft شەش باڵ: نزیکەی 2,7 مەتر.‏\f* بوو، لە دەشتی دورا لە هەرێمی بابل داینا.
\v 2 پاشان نەبوخودنەسر پاشا ناردی بەدوای میر\f + \fr 3:2 \ft لە دەسەڵاتی ئیمپراتۆریەتی بابلی میری میرنشینەکان وەک فەرمانبەر لەلایەن ئیمپراتۆرەوە دانراوە.‏\f* و فەرمانڕەوا و پارێزگار و ڕاوێژکار و خەزنەدار و قازی و دادوەر، هەروەها تەواوی کاربەدەستانی دیکەی هەرێمەکان تاوەکو بێن بۆ پەردە هەڵدانەوە لەسەر ئەو پەیکەرەی کە نەبوخودنەسر پاشا داینا.
\v 3 ئیتر میر و فەرمانڕەوا و پارێزگار و ڕاوێژکار و خەزنەدار و قازی و دادوەر، هەروەها تەواوی کاربەدەستانی دیکەی هەرێمەکان هاتن بۆ پەردە هەڵدانەوە لەسەر ئەو پەیکەرەی نەبوخودنەسری پاشا داینا، لەبەردەم ئەو پەیکەرەی نەبوخودنەسری پاشا داینا وەستان.
\p 
\v 4 ئینجا جاڕدەر بە دەنگی بەرز جاڕی دا: «ئەی گەلان و نەتەوەکان و خەڵکی هەموو زمانەکان! فەرمانتان پێکراوە،
\v 5 کاتێک دەنگی کەڕەنا و شمشاڵ و سەمتور و ساز و قیسارە و دووزەلە و هەموو جۆرەکانی مۆسیقا دەبیستن، دەبێت بچنە سەر چۆک و کڕنۆش بۆ ئەو پەیکەرە زێڕینە ببەن کە نەبوخودنەسری پاشا دایناوە.
\v 6 هەرکەسێک نەچێتە سەر چۆک و کڕنۆش نەبات، هەر ئەو کاتە فڕێدەدرێتە ناو کوورەی ئاگری داگیرساو.»
\p 
\v 7 لەبەر ئەوە هەر کاتێک هەموو گەلان گوێیان لە دەنگی کەڕەنا و شمشاڵ و سەمتور و ساز و قیسارە و هەموو جۆرەکانی مۆسیقا بووایە، هەموو گەلان و نەتەوەکان و خەڵکی هەموو زمانەکان دەچوونە سەر چۆک و کڕنۆشیان بۆ پەیکەرە زێڕینەکە دەبرد کە نەبوخودنەسری پاشا داینابوو.
\p 
\v 8 لەو کاتەدا چەند ئەستێرەناسێک هاتنە پێشەوە و سکاڵایان لە جولەکەکان کرد،
\v 9 بە نەبوخودنەسر پاشایان گوت: «ئەی پاشا، بۆ هەتاهەتایە هەر بژی!
\v 10 ئەی پاشا، تۆ فەرمانت دەرکرد کە هەرکەسێک گوێی لە دەنگی کەڕەنا و شمشاڵ و سەمتور و ساز و قیسارە و دووزەلە و هەموو جۆرەکانی مۆسیقا بێت، دەبێت بچیتە سەر چۆک و کڕنۆش بۆ پەیکەرە زێڕینەکە ببات،
\v 11 ئەوەی نەچێتە سەر چۆک و کڕنۆش نەبات، ئەوا فڕێدەدرێتە ناو کوورەی ئاگری داگیرساو.
\v 12 بەڵام چەند پیاوێکی جولەکە هەن کە تۆ بەسەر کاروبارەکانی هەرێمی بابلەوە داتناون، شەدرەخ و مێشەخ و عەبێدنەگۆ. ئەو پیاوانە هیچ گوێت پێ نادەن. ئەی پاشا، خوداوەندەکانی تۆ ناپەرستن و کڕنۆش بۆ ئەو پەیکەرە زێڕینە نابەن کە داتناوە.»
\p 
\v 13 نەبوخودنەسر زۆر بە قینەوە تووڕە بوو، فەرمانی دا کە شەدرەخ و مێشەخ و عەبێدنەگۆ بهێنن. ئینجا ئەو پیاوانەیان هێنایە بەردەم پاشا.
\v 14 نەبوخودنەسریش پێی گوتن: «ئەی شەدرەخ و مێشەخ و عەبێدنەگۆ، ئایا ڕاستە ئێوە خوداوەندەکانم ناپەرستن و کڕنۆش بۆ ئەو پەیکەرە زێڕە نابەن کە دامناوە؟
\v 15 ئێستا کاتێک گوێتان لە دەنگی کەڕەنا و شمشاڵ و سەمتور و ساز و قیسارە و دووزەلە و هەموو جۆرەکانی مۆسیقا دەبێت، ئەگەر ئامادە بن بچنە سەر چۆک و کڕنۆش بۆ ئەو پەیکەرە ببەن کە دروستم کردووە، زۆر باشە. بەڵام ئەگەر کڕنۆش نەبەن، هەر لەو کاتەدا فڕێدەدرێنە ناو کوورەی ئاگری داگیرساو. ئیتر ئەو خوداوەندە کێیە لە دەستم ڕزگارتان دەکات؟»
\p 
\v 16 شەدرەخ و مێشەخ و عەبێدنەگۆ وەڵامی پاشایان دایەوە: «ئەی نەبوخودنەسر، پێویستمان بەوە نییە لەسەر ئەم بابەتە وەڵامت بدەینەوە.
\v 17 ئەی پاشا، ئەگەر بمانخەیتە ناو کوورەی ئاگری داگیرساویشەوە، ئەو خودایەی دەیپەرستین دەتوانێت ڕزگارمان بکات، ئەو لە دەستی تۆ دەربازمان دەکات.
\v 18 ئەی پاشا، تەنانەت ئەگەر ڕزگاریشی نەکردین، دەمانەوێ تۆ بزانیت، ئێمە خوداوەندەکانی تۆ ناپەرستین و کڕنۆش بۆ پەیکەرە زێڕینەکەش نابەین کە داتناوە.»
\p 
\v 19 ئینجا نەبوخودنەسر زۆر لە شەدرەخ و مێشەخ و عەبێدنەگۆ تووڕە بوو، ڕوخساری گۆڕا. فەرمانی دا کە کوورەکە حەوت جار زیاتر گەرم بکەن لەوەی کە هەمیشە گەرم دەکرێت،
\v 20 هەروەها فەرمانی بە هەندێک لە بەهێزترین سەربازی سوپاکەی کرد کە شەدرەخ و مێشەخ و عەبێدنەگۆ پەلبەست بکەن و فڕێیان بدەنە ناو کوورەی ئاگری داگیرساو.
\v 21 ئیتر ئەو پیاوانە بە کراس و شەرواڵ و سەر کراس و جلوبەرگەکانیانەوە پەلبەست کران و فڕێدرانە ناو کوورەی ئاگری داگیرساو.
\v 22 فەرمانەکەی پاشا زۆر توند بوو، کوورەکە زۆر گەرم کرابوو، بڵێسەی ئاگرەکە ئەو پیاوانەی کوشت کە شەدرەخ و مێشەخ و عەبێدنەگۆیان بردە ناو کوورەکە.
\v 23 ئەو سێ پیاوەش بە پەلبەستکراوی کەوتنە ناو کوورە ئاگرە داگیرساوەکە.
\p 
\v 24 لەو کاتەدا نەبوخودنەسر سەری سوڕما و بە پەلە هەستا و بە ڕاوێژکارەکانی گوت: «ئایا سێ پیاوی پەلبەستکراومان فڕێنەدایە ناو ئاگرەکە؟»
\p ئەوانیش وەڵامیان دایەوە: «ڕاستە، ئەی پاشا.»
\p 
\v 25 ئەویش گوتی: «تەماشا بکەن! من چوار پیاو دەبینم دەست و پێ کراوە بەناو ئاگرەکەدا دێن و دەچن، هیچ ئەزیەتیان پێ نەگەیشتووە، ڕوخساری چوارەمیان لە کوڕی خوداوەندەکان دەچێت.»
\p 
\v 26 نەبوخودنەسر لە دەرگای کوورە ئاگرە داگیرساوەکە نزیک بووەوە و هاواری کرد: «ئەی شەدرەخ و مێشەخ و عەبێدنەگۆ! ئەی بەندەکانی خودای هەرەبەرز، وەرنە دەرەوە! وەرنە ئێرە!»
\p ئینجا شەدرەخ و مێشەخ و عەبێدنەگۆ لەناو ئاگرەکە هاتنە دەرەوە.
\v 27 میر و فەرمانڕەوا و پارێزگار و ڕاوێژکارانی پاشا کۆبوونەوە، ئەو پیاوانەیان بینی کە ئاگرەکە هیچ هێزێکی لەسەر لەشیان نەبووە، تاڵە مووێکی سەریان نەسووتاوە، ڕەنگی شەرواڵەکانیان نەگۆڕاوە، بۆنی ئاگرەکەشیان نەگرتووە.
\p 
\v 28 ئینجا نەبوخودنەسر گوتی: «ستایش بۆ خودای شەدرەخ و مێشەخ و عەبێدنەگۆ، ئەوەی فریشتەکەی خۆی نارد و بەندەکانی خۆی ڕزگار کرد، ئەوانەی پشتیان بەو بەست و فەرمانی پاشایان شکاند، گیانی خۆیان بەخشی بۆ ئەوەی کڕنۆش بۆ خودایەکی دیکە بێجگە لە خوداکەیان نەبەن و نەیپەرستن.
\v 29 لەبەر ئەوە من فەرمان دەکەم خەڵکی هەر نەتەوە و زمانێک بە خراپە باسی خوداکەی شەدرەخ و مێشەخ و عەبێدنەگۆ بکەن، پارچەپارچە دەکرێن و ماڵەکانیان دەبێتە کەلاوە، چونکە هیچ خودایەکی دیکە نییە بتوانێت ئاوا ڕزگار بکات.»
\p 
\v 30 دوای ئەوە پاشا پایەی شەدرەخ و مێشەخ و عەبێدنەگۆی لە هەرێمی بابلدا بەرزکردەوە.
\c 4
\s1 دارێک لە خەونی نەبوخودنەسر
\pmo 
\v 1 لە نەبوخودنەسری پاشاوە،
\pmo بۆ هەموو گەل و نەتەوە و خەڵکی هەموو زمانەکان کە لە هەموو زەویدا نیشتەجێن:
\pmo هەر سەرکەوتوو بن!
\b
\pm 
\v 2 بە باشم زانی ئەو نیشانە و پەرجووانە\f + \fr 4:2 \ft پەرجوو: موعجیزە.‏\f* ڕابگەیەنم کە خودای هەرەبەرز لەگەڵ مندا کردی.
\qm1 
\v 3 نیشانەکانی چەند گەورەن و
\qm2 کارە پەرجووەکانی چەند بەهێزن!
\qm1 پاشایەتییەکەی پاشایەتی هەتاهەتاییە و
\qm2 دەسەڵاتیشی بۆ نەوە دوای نەوەیە.
\pm 
\v 4 من نەبوخودنەسرم، لە ماڵەکەم بێ خەم بووم و لەناو کۆشکەکەمدا ئاسوودە بووم.
\v 5 خەونێکم بینی منی ترساند، کاتێک لەناو نوێنەکەم ڕاکشابووم، ئەو شتانەی بە مێشکمدا هاتن و بینینەکەم منیان تۆقاند.
\v 6 ئینجا فەرمانم کرد هەموو داناکانی بابل بهێننە بەردەمم بۆ لێکدانەوەی خەونەکەم.
\v 7 کاتێک جادووگەر و ئەفسونگەر و ئەستێرەناس و فاڵگرەوە هاتن، خەونەکەم بۆ گێڕانەوە، بەڵام نەیانزانی لێکی بدەنەوە.
\v 8 لە کۆتاییدا دانیال هاتە بەردەمم، ئەوەی ناوی بێلتەشەسرە، کە ناوی خوداوەندەکەمە، ڕۆحی خوداوەندە پیرۆزەکانی تێدایە، خەونەکەم بۆی گێڕایەوە.
\pm 
\v 9 گوتم: «بێلتەشەسر، گەورەی جادووگەران، لەبەر ئەوەی کە دەزانم ڕۆحی خوداوەندە پیرۆزەکانت تێدایە، هیچ نهێنییەک بۆ تۆ قورس نییە. ئەوە خەونەکەمە، بۆم لێکبدەوە.
\v 10 کە لەناو نوێنەکەم ڕاکشابووم، ئەم بینینانەم بۆ ئاشکرا کرا: تەماشام کرد، لەبەردەمم دارێکی زۆر بەرز لە ناوەڕاستی خاکەکەیە.
\v 11 دارەکە گەشەی کرد و بەهێز بوو، بەرزی گەیشتە ئاسمان، لەوپەڕی زەوی دەبینرا.
\v 12 گەڵاکانی جوان بوو، بەروبوومی زۆر بوو، بەشی هەمووان خواردنی تێدابوو. گیانلەبەرانی دەشتودەر لەژێر سێبەرەکەیدا بوون، باڵندەکانی ئاسمان لە لقەکانیدا نیشتەجێ بوون، هەموو بوونەوەر لێیان خوارد.
\pm 
\v 13 «لەو بینینانەی بۆم ئاشکرا کران کاتێک لەناو نوێنەکەم ڕاکشابووم، تەماشام کرد، فریشتەیەکی پیرۆز لە ئاسمانەوە هاتە خوارەوە.
\v 14 بە دەنگێکی بەرز هاواری کرد: ”دارەکە ببڕنەوە و لقەکانی بشکێنن، گەڵاکانی بوەرێنن و بەرەکەی پەرتوبڵاو بکەنەوە. با گیانلەبەران لە ژێری و باڵندە لە لقەکانی هەڵبێن.
\v 15 بەڵام با بنەدارەکە و ڕەگەکەی کە بە ئاسن و بڕۆنز بەستراون لەناو گژوگیای زەوی بمێننەوە.
\pm «”با بە شەونمی ئاسمان تەڕ بێت، با لەگەڵ گیانلەبەران لەنێو گژوگیای زەوی بژیێت.
\v 16 با مێشکی لە مرۆڤەوە بگۆڕێت و مێشکی ئاژەڵی بدرێتێ، هەتا حەوت ساڵی بەسەردا تێدەپەڕێت.\f + \fr 4:16 \ft ئارامی: حەوت کاتی بەسەردا تێبپەڕێت.‏\f*
\pm 
\v 17 «”ئەو بڕیارە لەلایەن فریشتەکانەوە ڕاگەیەنرا، ئەو حوکمە بە پیرۆزەکان دراوە، بۆ ئەوەی زیندووان بزانن کە خودای هەرەبەرز دەسەڵاتدارە بەسەر پاشایەتی مرۆڤدا، هەروەها دەیداتە هەر یەکێک بیەوێت، پایە نزمترین کەسی لەسەر دادەنێت.“
\pm 
\v 18 «من نەبوخودنەسر پاشام، ئەم خەونەم بینی. ئێستا تۆ ئەی بێلتەشەسر، لێکی بدەوە، چونکە هەموو دانایانی پاشایەتییەکەم ناتوانن بۆمی لێک بدەنەوە. بەڵام تۆ دەتوانیت، چونکە ڕۆحی خوداوەندە پیرۆزەکانت تێدایە.»
\s1 دانیال خەونەکە لێک دەداتەوە
\pm 
\v 19 لەو کاتەدا دانیال کە ناوی بێلتەشەسر بوو، بۆ ماوەیەک واقی وڕما و بیرکردنەوەکانی ترساندی، پاشاش گوتی: «بێلتەشەسر، با خەونەکە و لێکدانەوەکەی نەتترسێنن.»
\pm بێلتەشەسریش وەڵامی دایەوە: «گەورەم، خۆزگە خەونەکە بۆ نەیارانت و لێکدانەوەکەشی بۆ دوژمنانت بووایە!
\v 20 ئەو دارەی کە بینیت گەورە و بەهێز بوو، بەرزییەکەی گەیشتە ئاسمان، لە هەموو زەوییەوە دەبینرا،
\v 21 گەڵاکانی جوان بوون، بەروبوومی زۆر بوو، بەشی هەمووان خواردنی تێدابوو، لە ژێریدا گیانلەبەرانی دەشتودەر نیشتەجێ بوون و لە لقەکانیدا باڵندەکانی ئاسمان نیشتەجێ بوون.
\v 22 ئەی پاشا، ئەو دارە تۆیت! تۆ گەورە بوویت و بەهێز بوویت، گەورەییت زیادی کردووە و گەیشتووەتە ئاسمان، دەسەڵاتیشت هەتا ئەوپەڕی زەوی.
\pm 
\v 23 «ئەی پاشا تۆ فریشتەیەکت بینی، پیرۆزێک لە ئاسمانەوە هاتە خوارەوە و گوتی: ”دارەکە ببڕنەوە و لەناوی ببەن، بەڵام واز لە بنەدارەکەی بهێنن، بە ئاسن و بڕۆنز بەستراوەتەوە، لەنێو گژوگیای زەویدا بێت، ڕەگەکانی لە زەویدا بمێنێتەوە. با بە شەونمی ئاسمان تەڕ بێت، با لەگەڵ ئاژەڵی کێوی بژیێت، هەتا حەوت ساڵی بەسەردا تێدەپەڕێت.“
\pm 
\v 24 «ئەی پاشا، ئەمە لێکدانەوەکەیەتی، ئەمە بڕیاری خودای هەرەبەرزە کە بەسەر پاشای گەورەمدا دێت:
\v 25 لەنێو خەڵکدا دەردەکرێیت و لەگەڵ ئاژەڵی کێوی دەژیت، وەک گا گژوگیات دەرخوارد دەدرێت و بە شەونمی ئاسمان تەڕ دەکرێیت و حەوت ساڵ بەسەرتدا تێدەپەڕێت هەتا دان بەوەدا دەنێیت کە هەرەبەرزەکە دەسەڵاتدارە لە پاشایەتی مرۆڤدا و دەیدات بەوەی خواستی خۆیەتی.
\v 26 ئەو فەرمانەی درا بە وازهێنان لە بنەدارەکە و ڕەگەکانی دارەکە، واتا پاشایەتییەکەت بۆ خۆت دەگەڕێتەوە، کاتێک دان بەوەدا دەنێیت کە ئاسمان دەسەڵاتدارە.
\v 27 ئەی پاشا، لەبەر ئەوە با ڕاوێژەکەم لەلات پەسەند بێت: واز لە گوناه و تاوان بهێنە، چاکە بکە و لەگەڵ هەژارەکان میهرەبان بە، بەڵکو ئاسوودەییت بەردەوام بێت.»
\s1 هاتنە دی خەونەکە
\pm 
\v 28 هەموو ئەم شتانە بەسەر نەبوخودنەسری پاشادا هات.
\v 29 پاش دوازدە مانگ کاتێک لە سەربانی کۆشکی پاشایەتی بابلدا هاتوچۆی دەکرد،
\v 30 پاشا گوتی: «ئایا ئەمە بابلی مەزن نییە کە بۆ ماڵی پاشایەتی بە هێزی توانای خۆم و بۆ شانازی شکۆمەندی خۆم بنیادم نا؟»
\pm 
\v 31 هێشتا وشەکە لە دەمی پاشادا بوو، دەنگێک لە ئاسمانەوە هات و گوتی: «ئەی نەبوخودنەسری پاشا، بڕیار لەسەر تۆ دراوە: پاشایەتیت لێ دەستێنرێتەوە.
\v 32 لەنێو خەڵکدا دەردەکرێیت و لەگەڵ ئاژەڵی کێوی دەژیت، وەک گا گژوگیات دەرخوارد دەدرێت. حەوت ساڵ بەسەرتدا تێدەپەڕێت هەتا دان بەوەدا دەنێیت کە هەرەبەرزەکە دەسەڵاتدارە لە پاشایەتی مرۆڤدا و دەیدات بەوەی خواستی خۆیەتی.»
\pm 
\v 33 هەر لەو کاتەدا کارەکە بەسەر نەبوخودنەسردا جێبەجێ بوو. لەنێو خەڵک دەرکرا و وەک گا گیای خوارد. لاشەکەی بە شەونمی ئاسمان تەڕ بوو هەتا مووی وەک پەڕی هەڵۆ درێژ بوو و نینۆکەکانی وەک باڵندە.
\b
\pm 
\v 34 لە کۆتایی ماوەکەدا، من نەبوخودنەسرم، چاوم بۆ ئاسمان هەڵبڕی و هۆشم گەڕایەوە. ئینجا سوپاس و ستایشی هەرەبەرزەکەم کرد و شکۆدارم کرد کە بۆ هەتاهەتایە زیندووە.
\q1 دەسەڵاتەکەی دەسەڵاتی هەتاهەتاییە و
\q2 پاشایەتییەکەی بۆ نەوە دوای نەوەیە.
\q1 
\v 35 هەموو دانیشتووانی زەوی
\q2 وەک هیچ دانراون.
\q1 ئەو بە خواستی خۆی دەکات
\q2 لەگەڵ هێزەکانی ئاسمان و
\q2 دانیشتووانی زەوی.
\q1 کەس نییە دەستی بگرێت
\q2 یان پێی بڵێت، «چی دەکەیت؟»
\pm 
\v 36 لەو کاتەدا هۆشم گەڕایەوە، شانازی پاشایەتییەکەم بۆم گەڕایەوە لەگەڵ شکۆمەندی و گەورەییم. ڕاوێژکاران و گەورە پیاوەکانم داوایان کردمەوە، لەسەر پاشایەتییەکەم جێگیر بووم و گەورەییم زۆر زیادی کرد.
\v 37 ئێستاش من نەبوخودنەسرم، سوپاس و ستایشی پاشای ئاسمان دەکەم و شکۆداری دەکەم، ئەوەی هەموو کارەکانی ڕاستن و ڕێگاکانی دادپەروەرن، ئەوانەی بە لووتبەرزییەوە هەڵسوکەوت بکەن ئەو دەتوانێت زەلیلیان بکات.
\c 5
\s1 نووسراوەکەی سەر دیوار
\p 
\v 1 بێلشەسری پاشا خوانێکی گەورەی بۆ هەزار گەورە پیاوەکەی سازکرد و شەرابی لەگەڵیان خواردەوە.
\v 2 لەو کاتەی کە بێلشەسر شەرابەکەی دەنۆشی فەرمانی دا ئەو قاپوقاچاغە زێڕ و زیوە بهێنن کە نەبوخودنەسری باوکی\f + \fr 5:2 \ft باوک: دەشێت باپیرە گەورەی بێت.‏\f* لەو پەرستگایەی لە ئۆرشەلیمە دەریهێنابوون، بۆ ئەوەی پاشا و گەورە پیاو و ژن و کەنیزەکانی پێی بخۆنەوە.
\v 3 ئینجا ئەو قاپوقاچاغە زێڕەیان هێنا کە لە پەرستگای ماڵی خودا لە ئۆرشەلیمەوە دەرهێنرابوو، پاشا و گەورە پیاو و ژن و کەنیزەکانی پێیان خواردەوە.
\v 4 شەرابیان دەخواردەوە و ستایشی خوداوەندە زێڕ و زیو و بڕۆنز و ئاسن و دار و بەردینەکانیان دەکرد.
\p 
\v 5 لەناکاو پەنجەکانی دەستێکی مرۆڤانە دەرکەوت و لەسەر گەچی دیوارەکەی کۆشکی پاشا لەتەنیشت چرادانەکە دەستی بە نووسین کرد، پاشاش تەماشای دەستەکەی کرد کە دەینووسی.
\v 6 ئینجا ڕەنگی پاشا پەڕی و بیرکردنەوەکانی تۆقاندیان و قاچەکانی هێزیان لێ برا و ئەژنۆکانی کەوتنە لەرزین.
\p 
\v 7 پاشا بە دەنگی بەرز هاواری کرد کە ئەفسونگەر و ئەستێرەناس و فاڵگرەوەکان بهێننە ژوورەوە. پاشا بەم دانایانەی بابلی گوت: «هەر پیاوێک ئەو نووسینە بخوێنێتەوە و بۆم لێکبداتەوە، ئەوا جلی ڕەنگی ئەرخەوانی لەبەر دەکرێت، ملوانکەی زێڕیش لە ملی دەکرێت و لە پاشایەتییەکەدا دەبێتە سێیەم دەسەڵاتدار.»
\p 
\v 8 ئینجا هەموو داناکانی پاشا چوونە ژوورەوە، بەڵام نەیانتوانی نووسینەکە بخوێننەوە و بۆ پاشا لێکی بدەنەوە.
\v 9 لەبەر ئەوە بێلشەسر زۆر ترسا و ڕەنگی گۆڕا و گەورە پیاوەکانیش شڵەژان.
\p 
\v 10 بەڵام شاژنی دایک لەبەر دەنگی پاشا و گەورە پیاوانی چووە هۆڵی خوانەکە، شاژن بە پاشای گوت: «ئەی پاشا، هەتاهەتایە هەر بژی! با بیرکردنەوەکانت نەتترسێنن و ڕەنگت نەگۆڕێت!
\v 11 لە پاشایەتییەکەتدا پیاوێک هەیە ڕۆحی خودا پیرۆزەکانی تێدایە، لە سەردەمی باوکت ڕووناکبیری و زیرەکی و داناییەکی وەک دانایی خوداوەندەکانی تێدا بەدی کراوە. نەبوخودنەسری پاشای باوکت کردی بە گەورەی جادووگەر و ئەفسونگەر و ئەستێرەناس و فاڵگرەوەکان.
\v 12 ئەو پیاوە دانیالە، کە پاشا ناوی لێناوە بێلتەشەسر، کە ڕۆحێکی تەواو و زانین و زیرەکی و لێکدانەوەی خەون و هەڵهێنانی مەتەڵ و چارەسەرکردنی گیروگرفتی تێدا بینراوە. با ئێستا دانیال بانگ بکرێت و لێکی بداتەوە.»
\p 
\v 13 ئینجا دانیال هێنرایە بەردەم پاشا، پاشاش پێی گوت: «ئایا تۆ ئەو دانیالەی کە لە نەوە ڕاپێچکراوەکانی یەهودایت، ئەوەی پاشای باوکم لە یەهوداوە هێنای؟
\v 14 بیستوومە کە ڕۆحی خوداوەندەکان و ڕووناکبیری و زیرەکی و دانایی تەواوت تێدایە.
\v 15 ئێستاش دانا و ئەفسونگەرەکان بۆ بەردەمم هێنرانە ژوورەوە، بۆ ئەوەی ئەم نووسینە بخوێننەوە و پێم بڵێن مەبەستی چییە، بەڵام نەیانتوانی لێکی بدەنەوە.
\v 16 من بیستوومە کە تۆ دەتوانیت شت لێکبدەیتەوە و نهێنییە شاراوەکان ئاشکرا بکەیت. ئەگەر ئێستا توانیت ئەو نووسینە بخوێنیتەوە و بۆم لێکبدەیتەوە، ئەوا جلی ڕەنگ ئەرخەوانیت لەبەر دەکرێت و ملوانکەی زێڕیش لە ملت دەکرێت و لە پاشایەتییەکەدا دەبیتە سێیەم دەسەڵاتدار.»
\p 
\v 17 دانیالیش وەڵامی پاشای دایەوە: «با دیارییەکانت بۆ خۆت بن و پاداشتەکانت بە کەسێکی دیکە بدە، بەڵام من نووسینەکە بۆ پاشا دەخوێنمەوە و بۆی لێکدەدەمەوە.
\p 
\v 18 «ئەی پاشا، خودای هەرەبەرز پاشایەتی و گەورەیی و شکۆمەندی و هێزی دایە نەبوخودنەسری باوکت.
\v 19 بەهۆی ئەو گەورەییەی کە پێیدا، هەموو گەلان و نەتەوەکان و خەڵکی هەموو زمانەکان لەبەردەمی دەتۆقین و دەلەرزین. ئەوەی ویستی کوشتی و ئەوەی ویستی بە زیندوویی هێشتییەوە و ئەوەی ویستی بەرزی کردەوە و ئەوەی ویستی نزمی کردەوە.
\v 20 بەڵام کاتێک دڵی بە فیز بوو و کەللە ڕەق بوو، لە تەختی پاشایەتی هێنرایە خوارەوە و شکۆیەکەی لێسەنرایەوە.
\v 21 لەنێو خەڵکدا دەرکرا و مێشکی وەک مێشکی ئاژەڵی لێهات، لەگەڵ کەرەکێوی دەژیا و وەک گا گژوگیای دەخوارد، لەشی بە شەونمی ئاسمان تەڕ بوو، هەتا دانی بەوەدا نا کە خودای هەرەبەرز دەسەڵاتی لەسەر پاشایەتی مرۆڤدا هەیە، دەیدات بەوەی خواستی خۆیەتی.
\p 
\v 22 «بەڵام تۆ ئەی بێلشەسری کوڕی، لەگەڵ ئەوەی هەموو ئەمەت زانی، خۆتت نزم نەکردووەتەوە.
\v 23 بەڵکو خۆتت لە پەروەردگاری ئاسمان بە بەرزتر زانی، قاپوقاچاغەکانی پەرستگاکەی ئەویان هێنایە بەردەمت و تۆش خۆت و گەورە پیاوان و ژنەکانت و کەنیزەکانت تێیاندا شەرابتان خواردەوە. ستایشی بتە زێڕ و زیو و بڕۆنز و ئاسن و دار و بەردەکانت کرد، کە نابینن و تێناگەن و نازانن. بەڵام خودا ئەوەی هەناسەی تۆ و هەموو ڕێگاکانت بە دەستی ئەوە، ئەوت شکۆدار نەکرد.
\v 24 لەبەر ئەوە ئەو دەستە لەلای ئەوەوە نێردرا و ئەم نووسینەی نووسی.
\p 
\v 25 «ئەمە ئەو نووسینەیە کە نووسراوە:
\pc مەنێ\f + \fr 5:25 \ft واتا ژمێردراوە.‏\f*، مەنێ، تەقێل\f + \fr 5:25 \ft بە واتای شاقل یان کێشراو دێت.‏\f* و پەرسین\f + \fr 5:25 \ft کۆی (پەرس)، بە واتای نیوە شاقل یان خاکی فارس یان دابەشکراو دێت.‏\f*.
\p 
\v 26 «ئەمەش لێکدانەوەی وشەکانە:
\qm1 مەنێ: خودا ڕۆژانی پاشایەتییەکەی تۆی ژمارد و کۆتایی پێ هێنا.
\qm1 
\v 27 تەقێل: بە تەرازووەکان کێشرایت و نەقوستان دەرچوویت.
\qm1 
\v 28 پەرس: پاشایەتییەکەت دابەش کرا و درایە ماد و فارس.»
\p 
\v 29 ئینجا بێلشەسر فەرمانی دا جلی ڕەنگی ئەرخەوانی لەبەر دانیال بکەن و ملوانکەی زێڕیش لە ملی بکەن و جاڕبدەن کە لە پاشایەتییەکەدا بووە سێیەم دەسەڵاتدار.
\p 
\v 30 هەر لەو شەوەدا بێلشەسری پاشای بابلییەکان کوژرا،
\v 31 داریوشی ماد لە تەمەنی شەست و دوو ساڵیدا دەستی بەسەر پاشایەتییەکەدا گرت.
\c 6
\s1 دانیال لەناو چاڵی شێرەکان
\p 
\v 1 داریوش پێی باش بوو سەد و بیست میر بەسەر پاشایەتییەکەوە دابنێت، بەسەر هەموو پاشایەتییەکەوە بن.
\v 2 لە سەرووی ئەوانیشەوە سێ وەزیر، یەکێکیان دانیال بوو، بۆ ئەوەی میرەکان هەژماردەکان بخەنە بەردەمیان تاکو پاشا زیانی پێ نەگات.
\v 3 ئەوە بوو دانیال لە هەموو وەزیر و میرەکان پێشکەوتووتر بوو، چونکە توانایەکی نائاسایی هەبوو، پاشاش پلانی هەبوو کە لەسەر هەموو پاشایەتییەکە دایبنێت.
\v 4 لەبەر ئەوە وەزیر و میرەکان هەوڵیان دا هۆیەک ببیننەوە بۆ سکاڵاکردن لە دژی دانیال سەبارەت بە بەڕێوەبردنی کاروباری پاشایەتییەکە، بەڵام نەیانتوانی هیچ گەندەڵییەک لە دانیال ببیننەوە، چونکە دەستپاک بوو و گەندەڵی و کەمتەرخەمی تێدا نەبوو.
\v 5 ئینجا ئەو پیاوانە گوتیان: «هیچ هەڵەیەک لەم دانیالەدا نابینینەوە، تەنها ئەگەر لەبارەی شەریعەتی\f + \fr 6:5 \ft مەبەستی لە شەریعەتی موسایە.‏\f* خوداکەیەوە نەبێت.»
\p 
\v 6 جا ئەو وەزیر و میرانە لەلای پاشا کۆبوونەوە و پێیان گوت: «ئەی داریوش پاشا، هەتاهەتایە هەر بژی!
\v 7 هەموو وەزیرەکانی پاشایەتییەکە و فەرمانڕەوا و میر و ڕاوێژکار و پارێزگارەکان ڕاوێژیان کرد وابکەن پاشا فەرمانێک دەربکات و بڕیارەکە جێبەجێ بکات کە هەرکەسێک بۆ ماوەی سی ڕۆژ هەر داوایەک لە خوداوەندێک یان مرۆڤێک بکات، جگە لە تۆ، ئەی پاشا، با فڕێبدرێتە ناو چاڵی شێرەکان.
\v 8 ئێستاش ئەی پاشا فەرمانەکە دەربکە و ئیمزای لەسەر بکە، بۆ ئەوەی هەروەک یاساکانی ماد و فارس نەگۆڕ بێت کە پووچەڵ نابێتەوە.»
\v 9 ئیتر داریوشی پاشا فەرمانەکەی نووسی و ئیمزای کرد.
\p 
\v 10 کە دانیال بە ئیمزاکردنی فەرمانەکەی زانی، گەڕایەوە ماڵەوە، چووە ژوورەکەی سەرەوە کە پەنجەرەکەی ڕووەو ئۆرشەلیم دەکرایەوە. سێ جار لە ڕۆژێکدا چووە سەر چۆک و لەبەردەم خوداکەی نوێژی کرد و سوپاسی کرد، هەروەک پێش ئەوە دەیکرد.
\v 11 ئینجا ئەو پیاوانە پێکەوە کۆبوونەوە، بینییان دانیال لەبەردەم خوداکەیدا نوێژ دەکات و دەپاڕێتەوە.
\v 12 دەستبەجێ چوونە لای پاشا و سەبارەت بە فەرمانە پاشایەتییەکەی قسەیان کرد: «ئەی پاشا، ئایا تۆ فەرمانێکت ئیمزا نەکرد کە هەرکەسێک بۆ ماوەی سی ڕۆژ لە هەر خوداوەندێک یان مرۆڤێک داوایەک بکات جگە لە تۆ ئەی پاشا، فڕێدەدرێتە ناو چاڵی شێرەکانەوە؟»
\p پاشا گوتی: «فەرمانەکە ڕاستە و هەروەک یاساکانی ماد و فارس وایە کە پووچەڵ نابێتەوە.»
\p 
\v 13 ئەوانیش وەڵامیان دایەوە و لەبەردەم پاشا گوتیان: «ئەو دانیالەی لە نەوە ڕاپێچکراوەکانی یەهودایە، ئەی پاشا، هیچ گوێی نە بە تۆ و نە بەو فەرمانەی کە ئیمزات کردووە نەداوە، بەڵکو ڕۆژانە سێ جار نوێژ دەکات.»
\v 14 کە پاشا گوێی لەم قسەیە بوو زۆر دڵتەنگ بوو، مکوڕ بوو لەسەر ئەوەی دانیال دەرباز بکات و هەتا خۆر ئاوابوون هەوڵی دا ڕزگاری بکات.
\p 
\v 15 بەڵام ئەو پیاوانە لەلای پاشا کۆبوونەوە و بە پاشایان گوت: «ئەی پاشا، لە یادت نەچێت کە یاساکانی ماد و فارس ئەوەیە کە هەر فەرمان و بڕیارێک پاشا دەریبکات، ناگۆڕدرێت.»
\p 
\v 16 ئینجا پاشا فەرمانی دا، دانیالیان هێنا و فڕێیان دایە ناو چاڵی شێرەکان. پاشا بە دانیالی گوت: «با خوداکەت کە تۆ بە بەردەوامی خزمەتی دەکەیت، ئەو ڕزگارت بکات.»
\p 
\v 17 بەردێک هێنرا و لەسەر دەمی چاڵەکە دانرا، پاشا بە مۆری خۆی و مۆری گەورە پیاوانی مۆری کرد، بۆ ئەوەی کەس هەوڵ نەدات دانیال ڕزگار بکات.
\v 18 ئیتر پاشا گەڕایەوە کۆشکەکەی و بەبێ خواردن و ڕابواردن شەوی بەسەربرد و خەوی لێ زڕا.
\p 
\v 19 بەیانی زوو پاشا هەستا و بە پەلە چووە لای چاڵی شێرەکان.
\v 20 کاتێک لە چاڵەکە نزیک بووەوە، بە دەنگێکی پڕ لە ئازارەوە بانگی دانیالی کرد و گوتی: «ئەی دانیال، بەندەی خودای زیندوو! ئایا ئەو خودایەی بەردەوام دەیپەرستیت توانی لە شێرەکان ڕزگارت بکات؟»
\p 
\v 21 دانیالیش وەڵامی دایەوە: «ئەی پاشا، هەتاهەتایە هەر بژی!
\v 22 خوداکەم فریشتەکەی خۆی نارد و دەمی شێرەکانی داخست، هیچ زیانیان پێ نەگەیاندم، چونکە لەبەردەم ئەو بێتاوان بووم. ئەی پاشا، لەبەردەم تۆشدا هیچ تاوانێکم نەکردووە.»
\p 
\v 23 پاشا دڵی خۆش بوو، فەرمانی دا دانیال لە چاڵەکە سەربخەن. دانیال لە چاڵەکەوە سەرخرا و هیچ زیانێکی پێ نەگەیشتبوو، چونکە پشتی بە خودای خۆی بەست.
\p 
\v 24 ئینجا پاشا فەرمانی دا، ئەو پیاوانەیان هێنا کە سکاڵایان لە دانیال کرد و فڕێیان دانە ناو چاڵی شێرەکان، خۆیان و ژن و منداڵەکانیان. هێشتا نەگەیشتبوونە بن چاڵەکە، شێرەکان پەلاماریان دان و هەموو ئێسکەکانیان تێکشکاندن.
\p 
\v 25 دوای ئەوە داریوشی پاشا ئەمەی بۆ هەموو گەل و نەتەوە و خەڵکی هەموو زمانەکان نووسی کە لە هەموو زەویدا نیشتەجێن:
\pmo هەر سەرکەوتوو بن!
\b
\pm 
\v 26 لە منەوە فەرمان دەرچووە بەوەی کە لە هەموو ناوچەکانی ژێر دەسەڵاتی مندا، دەبێت خەڵک لە خودای دانیال بترسن و ڕێزی لێ بگرن.
\q1 لەبەر ئەوەی ئەو خودای زیندووە و
\q2 بۆ هەتاهەتایە دەمێنێت،
\q1 پاشایەتییەکەی لەناو ناچێت و
\q2 دەسەڵاتی بێ کۆتاییە.
\q1 
\v 27 ئەو ڕزگار دەکات و دەرباز دەکات،
\q2 نیشانە و کاری سەرسوڕهێنەر دەکات
\q2 لە ئاسمان و لەسەر زەوی.
\q1 ئەو دانیالی لە چنگی شێرەکان
\q2 ڕزگار کرد.
\p 
\v 28 ئیتر دانیال لە پاشایەتی داریوش و لە پاشایەتی کۆرشی فارسی سەرکەوتوو بوو.
\c 7
\s1 چوار گیانلەبەری گەورە لە خەوندا
\p 
\v 1 لە ساڵی یەکەمی بێلشەسری پاشای بابل، کاتێک دانیال لەسەر جێگاکەی ڕاکشابوو خەونێکی بینی و چەند بینینێک بە مێشکیدا هات، ئینجا پوختەی خەونەکەی نووسییەوە.
\p 
\v 2 دانیال گوتی: «لە بینینەکەمدا لە شەو تەماشام دەکرد چوار بایەکەی ئاسمان دەریای گەورەیان هەژاند.
\v 3 لە دەریاکەوە چوار گیانلەبەری گەورە هاتنە دەرەوە، هەریەکەیان لەوەی دیکە جیاواز بوو.
\p 
\v 4 «یەکەمیان وەک شێر بوو و دوو باڵی هەڵۆ ئاسای هەبوو. تەماشام کرد هەتا باڵەکانی لێکرایەوە و لەسەر زەوی هەڵستێنرا، وەک مرۆڤ لەسەر دوو پێ ڕاوەستابوو، دڵی مرۆڤی پێدرا.
\p 
\v 5 «هەر لەو کاتەدا گیانلەبەری دووەم لە شێوەی ورچ لەسەر یەک لا بەرزبووەوە، سێ پەراسوو لەنێو ددانەکانی بوو، پێی گوترا: ”هەستە و گۆشتی زۆر بخۆ!“
\p 
\v 6 «پاش ئەمە تەماشام کرد یەکێکی دیکە وەک پڵنگ وابوو، لەسەر پشتی چوار باڵی باڵندەی هەبوو. گیانلەبەرەکە چوار سەری هەبوو، دەسەڵاتی حوکمدانی پێدرابوو.
\p 
\v 7 «پاش ئەمە لە بینینی شەودا تەماشام کرد گیانلەبەری چوارەم ترسناک و تۆقێنەر و زۆر بەهێز بوو. ددانی ئاسنین و گەورەی هەبوو، نێچیرەکانی خوارد و تێکی شکاندن و پاشماوەکەی بە پێیەکانی پانکردەوە. ئەو لە هەموو گیانلەبەرەکانی پێش خۆی جیاوازتر بوو، دە شاخی\f + \fr 7:7 \ft شاخ: لە زمان و کەلتوری عیبریدا شاخ هێمای توانایە، لێرە و لە 24‏:8. بڕوانە \xt دانیال 7‏:7‏-8 و ئاشکراکردن 5‏:6 و 12‏:3.‏\xt*\ft ‏\f* هەبوو.
\p 
\v 8 «لە شاخەکان ڕامابووم، شاخێکی دیکەی بچووک لەنێوانیانەوە دەرهات و سێ شاخەکەی پێش خۆی هەڵتەکاند. ئەم شاخە چاوی وەک چاوی مرۆڤی تێدابوو، لەگەڵ دەمێک کە بە فیزەوە قسەی دەکرد.
\p 
\v 9 «کاتێک تەماشام دەکرد
\q1 «تەختەکان دانران و
\q2 خودای جاویدانی\f + \fr 7:9 \ft ئارامی: دێرینی ڕۆژان. مەبەستی لە خودای ئەزەلییە، ناوێکی تایبەتە بۆ خودا کە لە ئەزەلەوە هەیە.‏\f* دانیشت،
\q1 جلەکانی وەک بەفر سپی بوون و
\q2 مووی سەریشی وەک خوری بێگەرد وابوو.
\q1 تەختەکەشی بڵێسەی ئاگری بوو،
\q2 چەرخەکانیشی ئاگری داگیرساو بوو.
\q1 
\v 10 ڕووبارێکی ئاگرین تێدەپەڕی،
\q2 لەبەردەمیەوە دەڕۆیشت.
\q1 بە هەزاران هەزار خزمەتیان دەکرد و
\q2 بە دەیان هەزار دەیان هەزار لەبەردەمیدا ڕاوەستابوون.
\q1 ئینجا دادگا دانیشت و
\q2 کتێبەکان کرانەوە.
\p 
\v 11 «لەو کاتەدا بەردەوام بووم لە سەرنجدان لەبەر قسە بە فیزەکان کە شاخەکە دەیکرد. تەماشام دەکرد هەتا گیانلەبەرەکە کوژرا و کەلاکەکەی لەناوچوو، فڕێدرایە ناو ئاگرە داگیرساوەکە.
\v 12 گیانلەبەرەکانی دیکەش دەسەڵاتیان لێسەنرایەوە، بەڵام بۆ ماوەیەک تەمەن درێژییان پێدرا.
\p 
\v 13 «لە بینینەکەی شەودا تەماشام کرد، بەسەر هەوری ئاسمانەوە یەکێکی وەک کوڕی مرۆڤ بوو هات، گەیشتە لای خودای جاویدانی و بردیانە بەردەمی.
\v 14 ئینجا دەسەڵات و شکۆ و پاشایەتی پێدرا، بۆ ئەوەی هەموو گەلان و نەتەوەکان و خەڵکی هەموو زمانەکان بیپەرستن. دەسەڵاتەکەی دەسەڵاتێکی هەتاهەتاییە کە بەسەرناچێت، پاشایەتییەکەی لەناو ناچێت.
\s1 لێکدانەوەی خەونەکە
\p 
\v 15 «بەڵام من، کە دانیالم ڕۆحم لە ناخمدا واقی وڕما بوو و ئەو بینینانەی بە مێشکمدا هات منیان ترساند.
\v 16 جا لە یەکێک لە ڕاوەستاوەکان نزیک بوومەوە و لە هەموو ئەمەدا داوای لێکدانەوەم لێکرد.
\p «ئەویش لێکدانەوەی خەونەکەی پێ گوتم:
\v 17 ”ئەو چوار گیانلەبەرە گەورەیە چوار پاشان کە لەسەر زەوی پەیدا دەبن.
\v 18 بەڵام گەلی پیرۆزی خودای هەرەبەرز پاشایەتییەکە بەدەستدەهێنن و بۆ هەتاهەتایە خاوەنداریێتی دەکەن. بەڵێ، بۆ هەتاهەتایە.“
\p 
\v 19 «ئینجا ویستم لێکدانەوەی گیانلەبەرەکەی چوارەم بزانم کە لەگەڵ هەموویان جیاواز بوو، زۆر ترسناک بوو، ددانەکانی لە ئاسن بوون و چنگەکانی لە بڕۆنز، نێچیرەکانی خوارد و تێکیشکاندن و پاشماوەکەی بە پێیەکانی پانکردەوە.
\v 20 هەروەها ویستم لەبارەی ئەو دە شاخەی سەری و ئەو شاخەی تریش بزانم کە لە کاتی دەرکەوتنی سێ لە شاخەکانی دیکە لەبەردەمی کەوتنە خوارەوە، ئەو شاخە چاوی هەبوو، دەمێکیش کە بە فیزەوە قسەی دەکرد و دیمەنەکەی لە شاخەکانی دیکە زەبەلاحتر بوو.
\v 21 تەماشام دەکرد و ئەو شاخە لە دژی گەلە پیرۆزەکە دەجەنگا و ئەوانی بەزاند،
\v 22 هەتا خودای جاویدانی هات و حوکمی دەرکرد لە بەرژەوەندی گەلە پیرۆزەکەی خودای هەرەبەرز، کاتی هات بۆ ئەوەی خاوەنداریێتی پاشایەتییەکە بکەن.
\p 
\v 23 «ئەویش بەم جۆرەی گوت: ”گیانلەبەری چوارەم پاشایەتییەکی چوارەم دەبێت لەسەر زەوی، جیاواز لە سەرجەم پاشایەتییەکان، ئینجا هەموو زەوی دەخوات و پێی لێ دەنێت و تێکی دەشکێنێت.
\v 24 دە شاخەکەش دە پاشان کە لەم پاشایەتییەدا هەڵدەستن. یەکێکی دیکە لەدوای ئەوان هەڵدەستێت لەوانی پێش خۆی جیاواز دەبێت و سێ پاشا زەلیل دەکات.
\v 25 لە دژی خودای هەرەبەرز قسە دەکات و پیرۆزەکانی سەرکوت دەکات و هەوڵ دەدات کاتی جەژنەکان و فەرزەکانی تەورات بگۆڕێت. گەلە پیرۆزەکە بۆ سێ ساڵ و نیو\f + \fr 7:25 \ft ئارامی: کاتێک و دوو کاتێک و نیو کات.‏\f* دەدرێنە دەستی ئەو.
\p 
\v 26 «”جا دادگا دادەنیشێت و دەسەڵاتەکەی لێ دادەماڵن بۆ ئەوەی بە تەواوی کۆتایی پێ بێت و لەناوبچێت.
\v 27 پاشایەتییەکە و دەسەڵات و گەورەیی پاشایەتییەکە لەژێر هەموو ئاسماندا دەدرێتە گەلە پیرۆزەکە، گەلی خودای هەرەبەرز. پاشایەتییەکەی پاشایەتی هەتاهەتاییە و هەموو دەسەڵاتداران دەیپەرستن و گوێڕایەڵی دەبن.“
\p 
\v 28 «هەتا ئێرە کۆتایی بابەتەکەیە. من دانیالم، بیرکردنەوەکانم زۆر منیان ترساند و ڕەنگم گۆڕا، بەڵام بابەتەکەم لە دڵی خۆمدا هەڵگرت.»
\c 8
\s1 بەران و تەگە لە بینینەکە
\p 
\v 1 من کە دانیالم، لە ساڵی سێیەمی پاشایەتی بێلشەسر، لەپاش ئەو بینینەی کە ماوەیەک لەمەوپێش بۆم ئاشکرا کرابوو، بینینێکی دیکەشم بۆ ئاشکرا کرا.
\v 2 لە بینینەکەمدا سەیرم کرد لە قەڵای شوشم، ئەوەی لە هەرێمی ئیلامە. لە بینینەکەدا لەلای نۆکەندی ئولای بووم.
\v 3 چاوم هەڵبڕی و بینیم بەرانێک لەلای نۆکەندەکە ڕاوەستاوە و دوو قۆچی هەیە، هەردوو قۆچەکە درێژ بوون، یەکێکیان لەوەی دیکەیان درێژتر بوو، هەرچەندە دواتر سەری دەرهێنابوو.
\v 4 بینیم بەرانەکە بەلای ڕۆژئاوا و باکوور و باشووردا قۆچ دەوەشێنێت، هیچ گیانلەبەرێکیش لە ڕووی نەوەستایەوە، هیچ لە دەستی دەرباز نەبوو، ئەوەی پێی خۆشبوو کردی و مەزن بوو.
\p 
\v 5 لەو کاتەدا کە ڕامابووم تەگەیەک\f + \fr 8:5 \ft نێری، سابرێن.‏\f* لە ڕۆژئاواوە بەسەر زەویدا دەهات و پێیەکانی بەر زەوی نەدەکەوت، تەگەکە شاخێکی بەرزی هەبوو لەنێوان هەردوو چاوی.
\v 6 چووە لای ئەو بەرانەی کە دوو قۆچی هەبوو، ئەوەی بینیم لەلای نۆکەندەکە وەستابوو، زۆر بە تووڕەییەوە هێرشی کردە سەری.
\v 7 بینیم گەیشتە سەر بەرانەکە و بەربووە سەری و لە بەرانەکەی دا، دوو قۆچەکەی شکاند. بەرانەکە هێزی ئەوەی نەبوو لەبەردەمی ڕابوەستێت، تەگەکە فڕێیدایە سەر زەوی و پێی لێنا، بەرانەکە کەسی نەبوو لە دەستی دەربازی بکات.
\v 8 ئینجا تەگەکە زۆر خۆی بە زل زانی، بەڵام کاتێک لەخۆبایی بوو شاخە گەورەکەی شکا، لە جێی ئەو شاخەش چوار شاخی گەورەتر بەرەو چوار بایەکەی ئاسمان دەرچوون.
\p 
\v 9 لە یەکێک لەوانەوە شاخێکی بچکۆلە دەرکەوت، ڕووەو باشوور و ڕۆژهەڵات و خاکە دڵگیرەکە\f + \fr 8:9 \ft مەبەستی لە خاکی ئیسرائیلە.‏\f* گەشەی کرد.
\v 10 زۆر بەهێز بوو، تەنانەت گەیشتە هێزەکانی ئاسمانیش، هەندێک لە هێز و ئەستێرەکانی فڕێدایە خوارەوە بۆ سەر زەوی و پێی لێنان.
\v 11 خۆی بە گەورە زانی تاوەکو خۆی یەکسان بکات بە خودای سوپاسالاری ئاسمان. قوربانی ڕۆژانە لەکارخرا و پیرۆزگاکەی وێران کرا.
\v 12 لەبەر یاخیبوون، سوپا پیرۆزەکان و پێشکەشکردنی قوربانی ڕۆژانە درانە دەستی شاخەکە. ڕاستی خرایە ژێر پێ، شاخەکەش لە هەموو ئەوەدا سەرکەوتوو بوو کە کردی.
\p 
\v 13 ئینجا گوێم لە فریشتەیەکی پیرۆز بوو قسەی دەکرد، فریشتەیەکی پیرۆزی دیکە بەوی دەگوت: «ڕووداوەکانی ئەم بینینە کەی دێنە دی؟ هەتا کەی قوربانی ڕۆژانە لەکاردەخەن؟ هەتا کەی یاخیبوون بەردەوام دەبێت لە کاولبوونی پیرۆزگا و پێشێلکردنی سوپا پیرۆزەکە؟»
\p 
\v 14 ئەویش پێی گوتم: «دوو هەزار و سێ سەد بەیانی و ئێوارە، ئینجا پیرۆزگا دەگەڕێتەوە باری پیرۆزی خۆی.»
\s1 لێکدانەوەی بینینەکە
\p 
\v 15 من دانیالم، هێشتا خەریکی سەیرکردنی بینینەکەم و هەوڵدەدەم کە لێی تێبگەم، ئەوەتا یەکێک لە شێوەی پیاوێک لەبەردەمم ڕاوەستاوە.
\v 16 گوێم لە دەنگی مرۆڤێک بوو لەلای نۆکەندی ئولایەوە بانگی کرد و گوتی: «ئەی جبرائیل\f + \fr 8:16 \ft جبرائیل: لە زمانی عیبری بە واتای پیاوی خودا دێت.‏\f*، واتای بینینەکە لەم پیاوە بگەیەنە.»
\p 
\v 17 ئەویش هاتە ئەو شوێنەی کە لێی ڕاوەستابووم، کاتێک هات ترسام و بەسەر ڕوومدا کەوتم. پێی گوتم: «ئەی کوڕی مرۆڤ، بزانە کە بینینەکە سەبارەت بە سەردەمی کۆتاییە.»
\p 
\v 18 کاتێک قسەی لەگەڵم دەکرد کەوتبوومە خەونێکی قووڵەوە و ڕووم ڕووەو زەوی بوو. ئینجا دەستی لێدام و هەڵیستاندمە سەر پێ.
\p 
\v 19 گوتی: «من پێت دەڵێم کە لە کاتی تووڕەیی چی ڕوودەدات، چونکە بینینەکە سەبارەت بە سەردەمی کۆتایی دیاریکراوە.
\v 20 ئەو بەرانەی کە بینیت دوو قۆچی هەبوو، ئەوە پاشاکانی ماد و فارسە.
\v 21 تەگەکە پاشای یۆنانە، ئەو قۆچە گەورەیەش کە لەنێوان هەردوو چاوی بوو یەکەمین پاشایە.
\v 22 بەڵام ئەو چوار قۆچەی کە لە شوێنی قۆچە شکێنراوەکە پەیدابوون، ئەوا چوار پاشایەتی لە نەتەوەکەی ئەوەوە پەیدا دەبن، بەڵام هەمان هێزی ئەویان نابێت.
\p 
\v 23 «لە دوایین پاشایەتییان، کاتێک یاخیبوون لە دژی خودا دەگاتە ئەوپەڕی، پاشایەکی ڕوو وشک و فێڵباز پەیدا دەبێت.
\v 24 هێزی زۆر دەبێت، بەڵام نەک بە هێزی خۆی، لە ڕادەبەدەر وێرانکاری دەکات و سەرکەوتوو دەبێت لە هەرچی بیەوێت بیکات. تواناداران و گەلە پیرۆزەکە لەناودەبات.
\v 25 بە تەڵەکەبازی وا دەکات فێڵبازی سەرکەوتوو بێت، دڵی لەخۆبایی دەبێت. کاتێک لە ئاسوودەییدا زۆران لەناودەبات و لە دژی میری میران دەوەستێتەوە. لەگەڵ ئەوەشدا تێکدەشکێنرێت، بەڵام بەبێ هێزی مرۆڤانە.
\p 
\v 26 «ئەو بینینەی ئێوارە و بەیانی کە بە تۆ درا ڕاستە، بەڵام تۆ بینینەکە بە نهێنی بهێڵەوە، چونکە بۆ داهاتووی دوورە.»
\p 
\v 27 من کە دانیالم، بۆ چەند ڕۆژێک بێهێز و لاواز بووم، ئینجا هەستام و دەستم کردەوە بە کاروبارەکانی پاشا. واقم وڕمابوو لە بینینەکە، لە سەرووی تێگەیشتنەوە بوو.
\c 9
\s1 نزای دانیال
\p 
\v 1 لە ساڵی یەکەمی داریوشی کوڕی ئەحەشوێرۆش\f + \fr 9:1 \ft لە زمانی یۆنانی: کسەرکسیس.‏\f* لە نەوەی مادەکان کە بووە بە فەرمانڕەوای شانشینی بابلییەکان،
\v 2 لە ساڵی یەکەمی پاشایەتییەکەی ئەو، من کە دانیالم لە نووسراوە پیرۆزەکانەوە\f + \fr 9:2 \ft بڕوانە یەرمیا 25‏:11‏-12.‏\f* بەپێی فەرمایشتی یەزدان بۆ یەرمیای پێغەمبەر تێگەیشتم کە ماوەی کاولبوونی ئۆرشەلیم حەفتا ساڵ دەبێت.
\v 3 منیش ڕووم لە خودای پەروەردگار کرد، بە نوێژ و پاڕانەوەوە داوام دەکرد، بە ڕۆژوو و بە پۆشینی جلوبەرگی گوش\f + \fr 9:3 \ft لە کاتی ماتەمگێڕان و تۆبەکردندا جلوبەرگی لە گوش دروستکراویان لەبەرکردووە کە ئەزیەتی پێستیانی داوە.‏\f* و بە خۆڵەمێش بەسەرخۆدا کردن.
\p 
\v 4 نزام بۆ یەزدانی پەروەردگارم کرد و دانم پێدا نا:
\pm «ئەی پەروەردگار، خودای مەزن و سامناک، ئەی ئەوەی پەیمانی خۆشەویستییەکەت دەبەیتەسەر بۆ ئەوانەی کە تۆیان خۆشدەوێت و فەرمانەکانت بەجێدەگەیەنن،
\v 5 گوناهمان کرد و تاوانمان کرد، خراپەمان کرد و یاخی بووین، لە فەرمانەکان و یاساکانی تۆ لاماندا.
\v 6 گوێمان لە بەندە پێغەمبەرەکانت نەگرت، ئەوانەی بە ناوی تۆوە قسەیان بۆ پاشا و میر و باوباپیرانمان و هەموو گەلی خاکەکە کرد.
\pm 
\v 7 «ئەی پەروەردگار، تۆ ڕاستودروستیت، بەڵام ئەمڕۆ شەرمەزاری لەسەر ڕوخساری ئێمەیە، بۆ پیاوانی یەهودا و دانیشتووانی ئۆرشەلیم، بۆ هەموو ئیسرائیلە، نزیک و دوورەکان لە هەموو ئەو خاکانەی بۆ ئەوێ دەرتکردووین، لەبەر ئەو ناپاکییەی لەگەڵ تۆدا کردمان.
\v 8 ئەی یەزدان، شەرمەزاری لەسەر ڕوخساری ئێمەیە، لە پاشا و میر و باوباپیرانمان، چونکە دەرهەق بە تۆ گوناهمان کرد.
\v 9 خودای پەروەردگارمان بە بەزەیی و بەخشندەیە، هەرچەندە ئێمە لێی یاخی بووین.
\v 10 گوێڕایەڵی یەزدانی پەروەردگارمان نەبووین بۆ ئەوەی بە ڕێگای فێرکردنەکانیدا بڕۆین، کە لە ڕێگەی بەندە پێغەمبەرەکانییەوە پێیداین.
\v 11 هەموو ئیسرائیل سەرپێچی فێرکردنەکانی تۆیان کرد، لایاندا و گوێڕایەڵبوونی تۆیان ڕەتکردەوە.
\pm «لەبەر ئەوە ئەو نەفرەت و سوێندەت بەسەرماندا ڕژاند کە لە تەوراتی موسای بەندەی خودا نووسرابوو، چونکە دەرهەق بە تۆ گوناهمان کرد.
\v 12 ئەو ئاگادارکردنەوانەت هێنایە دی کە لەسەر ئێمە و ئەو دادوەرانەمان فەرمووبووت کە دادوەرییان بۆمان دەکرد، بۆ ئەوەی بەڵایەکی گەورەمان بەسەردا بهێنیت. لەژێر ئاسماندا شتی وا ڕووینەدابێت، وەک ئەوەی بەسەر ئۆرشەلیم هات.
\v 13 هەروەک ئەوەی لە تەوراتی موسادا نووسرابوو هەموو ئەم بەڵایانە بەسەرماندا هات، بەڵام لە تاوانەکانمان نەگەڕاینەوە و سەرنجمان نەدایە ڕاستییەکەی تۆ، بۆ ئەوەی ڕەزامەندی یەزدانی پەروەردگارمان بەدەستبهێنین.
\v 14 جا یەزدان مکوڕ بوو کە بەڵاکەمان بەسەربهێنێت، چونکە یەزدانی پەروەردگارمان لە هەموو کارەکانی کە کردی ڕاستودروستە، ئێمەش گوێڕایەڵی نەبووین.
\pm 
\v 15 «ئێستاش ئەی خودای پەروەردگارمان، کە بە دەستێکی بەهێزەوە گەلی خۆتت لە خاکی میسرەوە هێنایە دەرەوە، ناوێکت بۆ خۆت دروستکرد وەک ئەوەی ئەمڕۆ هەیە، ئێمە گوناهمان کرد و خراپەمان کرد.
\v 16 ئەی پەروەردگار، بەپێی هەموو ڕاستودروستییەکەت، تکایە تووڕەیی و هەڵچوونەکەت لەسەر شارەکەت، ئۆرشەلیم، دابمرکێنەوە کە کێوی پیرۆزی خۆتە. بەهۆی گوناهەکانمان و تاوانەکانی باوباپیرانمان ئۆرشەلیم و گەلەکەت لەلای هەموو ئەوانەی لە دەوروبەرمانن ڕیسوا بوون.
\pm 
\v 17 «ئێستاش ئەی خودای ئێمە، گوێ لە نزاکانی خزمەتکارەکەت و لە پاڕانەوەکەی بگرە. ئەی پەروەردگار، لە پێناوی خۆت ڕووت بەسەر پیرۆزگا کاولەکەتدا بدرەوشێنەوە.
\v 18 ئەی خودای من، گوێت شل بکە و ببیستە، چاوەکانت بکەرەوە و کەلاوەکانمان و ئەو شارە ببینە کە ناوی تۆی هەڵگرتووە. لەبەر ڕاستودروستی خۆمان نییە کە پاڕانەوەکانمان دەخەینە بەردەمت، بەڵکو لەبەر بەزەییە زۆرەکەتە.
\v 19 ئەی پەروەردگار گوێ بگرە! ئەی پەروەردگار لێخۆشبە! ئەی پەروەردگار گوێ شل بکە و دەستبەکار بە! ئەی خودای من، لەبەر خۆت دوای مەخە، چونکە شارەکەت و گەلەکەت ناوی تۆیان هەڵگرتووە.»
\s1 حەفتا هەفتە
\p 
\v 20 لەو کاتەدا من قسەم دەکرد و نزام دەکرد، دانم بە گوناهی خۆم و بە گوناهی ئیسرائیلی گەلەکەمدا دەنا و سەبارەت بە کێوە پیرۆزەکەی پاڕانەوەکەم دەخستە بەردەم یەزدانی پەروەردگارم،
\v 21 هێشتا لە نزاکەمدا بووم، جبرائیل، ئەو پیاوەی کە پێشتر لە بینینێکی دیکەدا بۆم ئاشکرا کرابوو، لە کاتی قوربانی ئێوارە بە خێرایی فڕی و هاتە لام.
\v 22 تێیگەیاندم و پێی گوتم: «ئەی دانیال، من ئێستا هاتم بۆ ئەوەی تێتبگەیەنم و بۆت ڕوون بکەمەوە.
\v 23 هەرکە دەستت بە پاڕانەوە کرد، وەڵامێک دەرچوو، منیش هاتووم پێت بڵێم، چونکە تۆ خۆشەویستی. لەبەر ئەوە لە پەیامەکە ڕابمێنە و لە بینینەکە تێبگە.
\p 
\v 24 «بڕیار دراوە حەفتا ”هەفتە“\f + \fr 9:24 \ft دەشێت مەبەستی لە هەر هەفتەیەک حەوت ساڵ بێت.‏\f* بەسەر گەلەکەت و بەسەر شارە پیرۆزەکەتدا بچێت بۆ کۆتایی پێهێنانی یاخیبوون، نەهێشتنی گوناه، کەفارەتی تاوان، هێنانی ڕاستودروستی هەتاهەتایی، تەواوکردنی بینین و پەیامی پێغەمبەر و هەروەها دەستنیشانکردنی هەرەپیرۆز\f + \fr 9:24 \ft دەقی عیبری مەبەستی لە شوێن یان کەسە.‏\f*.
\p 
\v 25 «جا بزانە و تێبگە کە لە دەرچوونی بڕیارەکە بۆ نوێکردنەوە و بنیادنانەوەی ئۆرشەلیم، هەتا هاتنی پاشای دەستنیشانکراو\f + \fr 9:25 \ft بە زمانی عیبری پێی دەگوترێ \tl مەشیخ‏\tl* یان \tl مەشیح‏\tl*.‏\f*، حەوت ”هەفتە“ و شەست و دوو ”هەفتە“ی پێ دەچێت. ئۆرشەلیم بە شەقامەکان و شوورابەندیەوە بنیاد دەنێتەوە، سەرباری ئەوەی کاتەکە تەنگانەیە.
\v 26 پاش شەست و دوو ”هەفتە“ دەستنیشانکراوەکە\f + \fr 9:26 \ft بە زمانی عیبری پێی دەگوترێ \tl مەشیخ‏\tl* یان \tl مەشیح‏\tl*.‏\f* دەکوژرێت و هیچی نابێت. سوپای پاشایەکی دیکە دێت و شارەکە و پیرۆزگاکە وێران دەکات. کۆتاییەکەی وەک لافاوێک دێت و هەتا کۆتایی جەنگ بەردەوام دەبێت، بڕیاری کاولکردنی دراوە.
\v 27 ئەم فەرمانڕەوایە لە یەک ”هەفتە“دا لەگەڵ زۆردا پەیمانی بەهێز دەبەستێت. لە ناوەڕاستی ئەو ”هەفتەیە“دا کۆتایی بە قوربانی و پێشکەشکراوەکان دەهێنێت، لەسەر لووتکەی پەرستگا قێزەونی وێرانکەر دادەنێت، بۆ ئەوەی سزای حوکمی کۆتایی لەسەر ئەم وێرانکەرەدا بڕژێتەوە.»
\c 10
\s1 پیاوێک لە بینینی دانیال
\p 
\v 1 لە ساڵی سێیەمی کۆرشی پاشای فارس، پەیامێک بۆ دانیال ئاشکرا کرا، کە ناونرابوو بێلتەشەسر. پەیامێکی ڕاست بوو سەبارەت بە جەنگی گەورە. تێگەیشتنی پەیامەکە لە ڕێگەی بینینێکەوە بۆی هات.
\p 
\v 2 لەو ڕۆژانەدا، من کە دانیالم سێ هەفتەی تەواو شیوەنم گێڕا.
\v 3 هیچ خواردنێکی خۆشم نەخوارد، گۆشت و شەراب نەچووە دەممەوە، بۆنم لە خۆم نەدا هەتا سێ هەفتەکە تەواو بوو.
\p 
\v 4 لە ڕۆژی بیست و چواری مانگی یەکدا کاتێک لەسەر کەناری ڕووبارە گەورەکە بووم کە دجلەیە،
\v 5 سەرم هەڵبڕی و تەماشام کرد، پیاوێک کەتانی لەبەردا بوو، پشتێنێکی زێڕی ئوفازیشی لە کەمەری بەستبوو.
\v 6 لەشی وەک زەبەرجەد، ڕووی وەک شێوەی بروسکە، چاوەکانی وەک چرای ئاگر، قۆڵ و قاچەکانی وەک بریسکەی بڕۆنزی سافکراو بوون و هەروەها دەنگیشی وەک دەنگی خەڵکێکی ئێجگار زۆر بوو.
\p 
\v 7 من کە دانیالم، بە تەنها من بینینەکەم بۆ ئاشکرا کرا، ئەو پیاوانەی لەگەڵمدا بوون نەیانبینی، بەڵام ترسێکی گەورە لەسەریان نیشت، ڕایانکرد و خۆیان شاردەوە.
\v 8 جا من بە تەنها مامەوە و تەماشای ئەم بینینە گەورەیەم دەکرد. هێزم تێدا نەما و ڕووم ڕەنگی مردووی لێ نیشت، لە پەلوپۆ کەوتم.
\v 9 گوێم لە قسەکانی بوو، لەو کاتەش کە گوێم لێی دەگرت، چوومە ناو خەوێکی قووڵەوە، ڕووشم ڕووەو زەوی بوو.
\p 
\v 10 دەستێکم بەرکەوت و بە لەرزەوە لەسەر دەست و ئەژنۆم داینام.
\v 11 پێی گوتم: «ئەی دانیال، ئەی پیاوە خۆشەویستەکە! ئەو قسەیەی کە پێت دەڵێم لێی تێبگە و هەستە سەر پێت، چونکە من ئێستا نێردراوم بۆ لای تۆ.» کە بەم شێوەیە قسەی لەگەڵ کردم، بە لەرزەوە هەستامە سەر پێ.
\p 
\v 12 پێی گوتم: «ئەی دانیال، مەترسە. لەبەر ئەوەی هەر لە یەکەم ڕۆژەوە کە مکوڕ بوویت تێبگەیت و لەبەردەم خوداکەت خۆتت زەلیل کرد، پاڕانەوەکەت بیسترا، منیش لەبەر ئەمانە هاتووم.
\v 13 سەرۆکی ڕۆحە پیسەکانی شانشینی فارس ماوەی بیست و یەک ڕۆژ بەرەنگارم بووەوە، ئینجا میکائیل کە یەکێک لە سەرۆک فریشتەکانە بۆ هاریکاریم هات، چونکە من لەوێ لەلای پاشای فارس دواخرابووم.
\v 14 جا هاتووم بۆ ئەوەی ئەوەت تێبگەیەنم کە لە ڕۆژی کۆتایی بەسەر گەلەکەتدا دێت، چونکە بابەتی بینینەکە ڕۆژانی داهاتووە.»
\p 
\v 15 کاتێک ئەو قسانەی لەگەڵمدا دەکرد، سەرم دانەواند و بێدەنگ بووم.
\v 16 ئینجا فریشتەکە، کە لە شێوەی مرۆڤ بوو، دەستی لە لێوەکانم دا، منیش دەمم کردەوە و قسەم کرد. بەوەم گوت کە لەبەردەممدا وەستابوو: «گەورەم، بە بینینەکە ئازارێکی زۆرم چێژت و لە پەلوپۆ کەوتم.
\v 17 ئەی گەورەم، من خزمەتکاری تۆم، چۆن قسەت لەگەڵ بکەم؟ من ئێستا هێزم لێ بڕاوە و هەناسەم تێدا نەماوە.»
\p 
\v 18 دووبارە ئەوەی لە مرۆڤ دەچوو دەستی لێم دا و هێزی هێنایەوە بەرم.
\v 19 گوتی: «مەترسە، ئەی پیاوە خۆشەویستەکە. ئاشتیت لەسەر بێت! ئازابە و بەهێزبە!»
\p کاتێک قسەی لەگەڵدا کردم، بەهێز بووم و گوتم: «با گەورەم قسە بکات، چونکە بەهێزت کردم.»
\p 
\v 20 ئەویش گوتی: «ئایا دەزانیت بۆچی هاتمە لات؟ ئێستاش دەگەڕێمەوە و لەگەڵ سەرۆکی ڕۆحە پیسەکانی فارس دەجەنگم، دوای ئەوەی من دەڕۆم سەرۆکی ڕۆحە پیسەکانی یۆنان دێت.
\v 21 بەڵام ئێستا ئەوەت پێ دەڵێم کە لە پەڕتووکی ڕاستیدا نووسراوە. کەس لە دژی ئەم سەرۆکانە پشتگیریم ناکات، جگە لە میکائیلی سەرۆکتان.
\c 11
\nb 
\v 1 لە ساڵی یەکەمی داریوشی مادی، لەگەڵی وەستام تاکو پشتگیری لێ بکەم و بیپارێزم.
\s1 پاشاکانی باشوور و باکوور
\p 
\v 2 «ئێستاش ڕاستیت پێ دەڵێم: سێ پاشای دیکە لە فارس پەیدا دەبن، پاشان چوارەمیان لە هەموویان دەوڵەمەندتر دەبێت. سامانەکەی بۆ بەدەستهێنانی هێز بەکاردەهێنێت، هەمووان لە دژی شانشینی یۆنان دەورووژێنێت.
\v 3 ئینجا پاشایەکی بە توانا پەیدا دەبێت و زۆر زاڵ دەبێت، چی پێ خۆش بێت دەیکات.
\v 4 بەڵام ئیمپراتۆریەتەکە لەوپەڕی هێزیدا تێکدەشکێت و بەسەر چوار لای زەویدا دابەش دەبێت، بەڵام نەک بۆ نەوەکانی، بەڵکو بۆ خەڵکی دیکە دەبێت، دەسەڵاتی پێشتری نامێنێت، چونکە ئیمپراتۆریەتەکەی بنبڕ دەبێت.
\p 
\v 5 «دوای ئەمە پاشای باشوور\f + \fr 11:5 \ft پاشای باشوور: مەبەستی لە پاشای میسر.‏\f* بەهێز دەبێت، بەڵام یەکێک لە میرەکانی لەو بەهێزتر دەبێت و بە دەسەڵاتێکی گەورەوە زاڵ دەبێت.
\v 6 پاش چەند ساڵێک پەیمان دەبەستن، کچی پاشای باشوور بۆ پەیمان بەستنەکە دێتە لای پاشای باکوور، بەڵام کچەکە هێزی نامێنێت، پاشای باشووریش نە خۆی و نە هێزی بەردەوام نابن. لەو کاتەدا کچەکە و باوکی و ئەوانەی هێنایان و لەگەڵ ئەوەش کە پشتگیری دەکرد بە دەستەوە دەدرێن.
\p 
\v 7 «ئینجا یەکێک لە بنەماڵەی کچەکە لە شوێنی ئەو هەڵدەستێتەوە. بەر لە سوپای پاشای باکوور دەگرێت و دەچێتە ناو قەڵاکەی، لێیان دەدات و سەرکەوتوو دەبێت.
\v 8 بت و پەیکەرە داڕێژراوەکان و قاپوقاچاغە بەنرخەکانیان کە لە زێڕ و زیو دروستکرابوون دەباتە میسر. دوای ئەمە ماوەی چەند ساڵێک واز لە پاشای باکوور دەهێنێت.
\v 9 ئینجا پاشای باکوور هێرش دەباتە سەر شانشینی پاشای باشوور، بەڵام دەگەڕێتەوە خاکەکەی خۆی.
\v 10 کوڕەکانی دەوروژێن و ئاپۆرەی سوپایەکی گەورە کۆدەکەنەوە کە وەک لافاوێکی بەهێز ڕادەماڵێت، بڵاو دەبێتەوە و بەردەوام دەبێت، هەتا شەڕ دەهێنێتە سەر قەڵای پاشای باشوور.
\p 
\v 11 «ئیتر پاشای باشوور ڕقی هەڵدەستێت و هێرش دەکاتە سەر پاشای باکوور، کە وا خەریکە سوپایەکی زۆر گەورەی کۆدەکاتەوە، بەڵام دەشکێنرێت.
\v 12 کاتێک سوپاکە ڕادەماڵرێت، پاشای باشوور بەفیز دەبێت و دەیان هەزار دەکوژێت، بەڵام سەرناکەوێت،
\v 13 چونکە پاشای باکوور دەگەڕێتەوە، سوپایەکی زۆرتر لەوەی جاری یەکەم کۆدەکاتەوە، پاش چەند ساڵێک بە سوپایەکی گەورە و چەک و تفاقێکی زۆرەوە پێشدەکەوێت.
\p 
\v 14 «لەو کاتەدا خەڵکانێکی زۆر لە دژی پاشای باشوور ڕادەپەڕن، بۆ بەدیهێنانی بینینەکە توندڕەوەکان لە گەلەکەت یاخی دەبن، بەڵام دەکەون.
\v 15 ئینجا پاشای باکوور دێت و مەتەرێزێک لێدەدات و شارە قەڵابەندەکە داگیر دەکات. هێزەکانی باشوور لەبەردەمیدا خۆیان ڕاناگرن، تەنانەت باشترین سەربازیشیان بەرگە ناگرێت.
\v 16 پاشای باکوور ئەوەی بیەوێ دەیکات، کەسیش نابێت بەرەنگاری بێتەوە. لەناو خاکە دڵگیرەکەدا\f + \fr 11:16 \ft مەبەستی لە خاکی ئیسرائیلە.‏\f* ڕادەوەستێت و هەمووی لەژێر دەستی ئەودا دەبێت.
\v 17 مکوڕ دەبێت لەسەر ئەوەی بە هەموو دەسەڵاتی پاشایەتییەکەیەوە بێت و پەیمان لەگەڵ پاشای باشوور ببەستێت. کچەکەی دەداتێ بۆ ئەوەی پاشایەتی باشوور تێکبدات، بەڵام پیلانەکانی سەرناکەون و سوودمەند نابن.
\v 18 پاشان ڕوو دەکاتە کەنارەکان و زۆریان داگیر دەکات، بەڵام فەرماندەیەک کۆتایی بە لووتبەرزییەکەی دەهێنێت، بەڵکو لووتبەرزییەکەی بەسەر خۆیدا دەداتەوە.
\v 19 ئینجا دەگەڕێتەوە قەڵاکانی خاکەکەی خۆی، بەڵام ساتمە دەکات و دەکەوێت، ئیتر نامێنێت.
\p 
\v 20 «جێنشینەکەی باجگرێک دەنێرێت بۆ بەردەوام بوونی شکۆمەندی پاشایەتییەکەی. لە ماوەیەکی کورتدا تێکدەشکێت، بەڵام نە بە تووڕەیی و نە بە جەنگ.
\p 
\v 21 «ئینجا ناکەس بەچەیەک شوێنی دەگێڕێتەوە کە شکۆمەندی پاشایەتی نەدراوەتێ. کاتێک خەڵکی بە ئاسوودەیی دەژین لەناکاو دێت و بە فێڵ دەست بەسەر پاشایەتییەکەدا دەگرێت.
\v 22 چەندین سوپای زەبەلاح لە بەرامبەر ئەو تێکدەشکێن و ڕادەماڵرێن، هەروەها میری پەیمانیش.
\v 23 هەرکە پەیمانێک دەبەستێت، فێڵ لە هاوپەیمانەکەی دەکات، بە خەڵکێکی کەمەوە دەگاتە دەسەڵات.
\v 24 کاتێک هەرێمە دەوڵەمەندەکان لە ئارامیدان بەسەریاندا دەدات، ئەوە دەکات کە نە باوک و نە باپیرانی کردوویانە. تاڵانی و دەستکەوت و سامان بەسەر شوێنکەوتووانیدا دابەش دەکات. پیلان بۆ داگیرکردنی قەڵاکان دادەڕێژێت، بەڵام تەنها بۆ ماوەیەک دەبێت.
\p 
\v 25 «بە سوپایەکی گەورە و بە ئازایەتییەوە هێزەکەی لە دژی پاشای باشوور دەوروژێنێت، پاشای باشووریش بە سوپایەکی گەورە و بەهێزەوە خۆی بۆ جەنگ ئامادە دەکات، بەڵام بەرگە ناگرێت، چونکە پیلان لە دژی دەگێڕن.
\v 26 ئەوانەی لە خواردنە خۆشەکانی دەخۆن، دەیشکێنن و سوپاکەی ڕادەماڵرێت، زۆر کەس دەکوژرێن.
\v 27 ئەم دوو پاشایەش دڵیان لەلای خراپەیە، لەسەر یەک مێز دادەنیشن و درۆ بۆ یەکتری دەکەن، بەڵام سەرناکەون، چونکە کۆتایی لە کاتی دیاریکراودا دێت.
\v 28 پاشای باکوور بە دەستکەوتێکی زۆرەوە دەگەڕێتەوە خاکەکەی خۆی، بەڵام لە دڵەوە لە دژی پەیمانە پیرۆزەکەیە. دژایەتییەکە دەکات، ئینجا دەگەڕێتەوە خاکەکەی خۆی.
\p 
\v 29 «لە کاتی دیاریکراودا دەگەڕێتەوە و هێرش دەباتەوە بۆ باشوور، بەڵام ئەم جارەیان وەک جاری یەکەم نابێت.
\v 30 لە کەنارەکانی ڕۆژئاواوە کەشتییەکان دێنە سەری، ئینجا کۆڵدەدات. دەگەڕێتەوە و لە پەیمانە پیرۆزەکە تووڕە دەبێت، ئەوانەش پاداشت دەکات کە وازیان لە پەیمانە پیرۆزەکە هێناوە.
\p 
\v 31 «سوپاکەی ئەو دێن و پیرۆزگای قەڵابەند گڵاو دەکەن، قوربانی ڕۆژانە دادەماڵن و قێزەونی وێرانکەر دادەنێن.
\v 32 ئەوانەی پەیمان دەشکێنن بە فێڵ هەڵیاندەخەڵەتێنێت، بەڵام ئەو گەلەی خودای خۆیان دەناسن بەهێز دەبن و دژایەتی ئەو دەکەن.
\p 
\v 33 «تێگەیشتووان خەڵکێکی زۆر فێر دەکەن، هەرچەندە بۆ ماوەیەک بە شمشێر و ئاگر دەکوژرێن یان تاڵان و ڕاپێچ دەکرێن.
\v 34 کاتێک دەکەون بە کەمی یارمەتی دەدرێن، زۆر کەسیش بەبێ دڵسۆزی دەچنە ڕیزیان.
\v 35 هەندێک لە تێگەیشتووان ساتمە\f + \fr 11:35 \ft پێ هەڵکەوتن یان تووشبوون بە بەڵایەک کە لە کەوتن نزیکیان بکاتەوە.‏\f* دەکەن، بۆ پوختەبوون و پاکبوونەوە و بێ لەکە بوونیان هەتا کاتی کۆتایی، چونکە لە کاتی دیاریکراو دێت.
\s1 ئەو پاشایەی خۆی بە گەورە دەزانێت
\p 
\v 36 «پاشا بە ویستی خۆی دەکات. خۆی بە گەورە و بە زل دەزانێت لەسەر هەموو خودایەک، کفری ترسناک لە دژی خودای خودایان دەکات. هەتا کاتی تەواوبوونی تووڕەییەکە سەرکەوتوو دەبێت، چونکە ئەوەی بڕیاری لەسەر دراوە هەر دەبێت پیادە بکرێت.
\v 37 نە گوێ بە خوداوەندەکانی باوباپیرانی دەدات و نە بەوەی ژن دایهێناوە\f + \fr 11:37 \ft لەوانە مەبەستی لە تەمووزی خوداوەند بێت، کە لە ئەندێشەی ئەو سەردەمە ئەو خوداوەندە توانای منداڵ بەخشینی هەبووە بە ژنان.‏\f*، گوێ بە هیچ خوداوەندێک نادات. بەڵکو خۆی لە هەموویان بە گەورەتر دەزانێت.
\v 38 لە جیاتی ئەوان ڕێز لە خوداوەندی قەڵاکان دەگرێت، خوداوەندێکە کە باوباپیرانی نەیانناسیوە، بە زێڕ و زیو و بەردی گرانبەها و دیاری بە نرخ ڕێزی لێ دەگرێت.
\v 39 بە یارمەتی ئەو خوداوەندە بێگانەیە پەلاماری قەڵا پتەوەکان دەدات. زۆر ڕێز لەوانە دەگرێت کە دەچنە ژێر باڵی. دەیانکاتە فەرمانڕەوای خەڵکێکی زۆر، خاکەکە بە پاداشت دابەش دەکات.
\p 
\v 40 «لە کاتی کۆتاییدا پاشای باشوور جەنگی لەگەڵدا بەرپا دەکات، پاشای باکووریش بە گالیسکە و سوار و بە کەشتیگەلی زۆرەوە وەک ڕەشەبا لە دژی هەڵدەکات. پەلاماری چەندین وڵات دەدات، وەک لافاو ڕایاندەماڵێت.
\v 41 هەروەها پەلاماری خاکە دڵگیرەکە دەدات. زۆر کەس دەکوژرێن، بەڵام ئەدۆم و مۆئاب و میرەکانی عەمۆنییەکان لە دەستی دەرباز دەبن.
\v 42 دەسەڵاتی خۆی بەسەر زۆر وڵاتدا بڵاو دەکاتەوە، میسریش ڕزگاری نابێت.
\v 43 دەست بەسەر گەنجینەکانی زێڕ و زیو و هەموو سامانی میسردا دەگرێت، لیبییەکان و کوشییەکانیش ملکەچی دەبن.
\v 44 بەڵام چەند هەواڵێکی ترسناکی لە ڕۆژهەڵات و باکوورەوە پێ دەگات و ئەو دەهەژێنێت، بە تووڕەییەکی زۆرەوە بەڕێدەکەوێت بۆ کاولکردن و قڕکردنی خەڵکانێکی زۆر.
\v 45 چادری شاهانەی لەنێوان دەریاکان و کێوی دڵگیری پیرۆز هەڵدەدات. بەڵام دەگاتە کۆتایی خۆی، کەسیش یارمەتی نادات.
\c 12
\s1 ڕۆژانی کۆتایی
\p 
\v 1 «لەو کاتەدا میکائیلی سەرۆکی گەورەی فریشتەکان هەڵدەستێت، ئەوەی گەلەکەت دەپارێزێت. کاتێکی ئەوەندە تەنگ دەبێت کە لەوەتەی نەتەوە دروستبووە هەتا ئەو کاتە شتی وا نەبووبێت. بەڵام لەو کاتەدا هەرکەسێک لە گەلەکەی تۆ ناوی لە پەڕتووکەکە نووسرابێت، دەرباز دەبێت.
\v 2 زۆر لەوانەی لەناو خۆلی زەویدا نوستوون هەڵدەستنەوە، هەندێکیان بۆ ژیانی هەتاهەتایی و هەندێکی دیکەشیان بۆ سەرشۆڕی و سووکایەتی هەتاهەتایی.
\v 3 تێگەیشتووان وەک ڕووناکی ئاسمان دەدرەوشێنەوە، ئەوانەش کە خەڵکێکی زۆریان بۆ ڕاستودروستی گەڕاندووەتەوە بۆ هەتاهەتایە وەک ئەستێرەن.
\p 
\v 4 «تۆش ئەی دانیال، هەتا سەردەمی کۆتایی وشەکان بە نهێنی بهێڵەوە و تۆمارەکە بپێچەوە. خەڵکێکی زۆر لێرە و لەوێ دەگەڕێن بۆ ئەوەی زانیاری زیاتر بەدەستبهێنن.»
\b
\p 
\v 5 ئینجا من کە دانیالم، تەماشام کرد بینیم دوو فریشتەی دیکە ڕاوەستاون، یەکێکیان لەسەر ئەو کەنارەی ڕووبارەکە، ئەوی دیکەیان لەسەر کەنارەکەی دیکە.
\v 6 یەکێکیان بەو پیاوەی گوت کە کەتانی لەبەردا بوو، ئەوەی لەسەر ئاوی ڕووبارەکە بوو: «کەی ڕووداوە سەرسوڕهێنەرەکان تەواو دەبێت؟»
\p 
\v 7 ئەو پیاوەی کە کەتانی لەبەردا بوو، ئەوەی لەسەر ئاوی ڕووبارەکە بوو، دەستی ڕاست و دەستی چەپی بەرەو ئاسمان بەرزکردەوە. گوێم لێ بوو سوێندی بەوە خوارد کە هەتاهەتایە زیندووە: «تاکو سێ ساڵ و نیو\f + \fr 12:7 \ft عیبری: سەردەمێک و دوو سەردەم و نیو، بڕوانە \xt 7‏:25‏\xt*\ft .‏\f*. کاتێک هێزی گەلە پیرۆزەکە بە تەواوی شکێنرا، هەموو ئەمانەش تەواو دەبێت.»
\p 
\v 8 من گوێم لێبوو، بەڵام تێنەگەیشتم، ئیتر گوتم: «گەورەم، کۆتایی هەموو ئەمانە چییە؟»
\p 
\v 9 ئەویش گوتی: «دانیال، تۆ بڕۆ، چونکە هەتا کاتی کۆتایی وشەکان لە پەڕتووکی داخراودا بە نهێنی هێڵدراوەتەوە.
\v 10 خەڵکانێکی زۆر پاک دەبنەوە و بێ لەکە و پوختە دەبن، بەڵام خراپەکاران لە خراپە بەردەوام دەبن. کەس لە خراپەکاران تێناگات، بەڵام تێگەیشتووان تێدەگەن.
\p 
\v 11 «لە کاتی داماڵینی قوربانی ڕۆژانە هەتا دانانی قێزەونی وێرانکەر، هەزار و دوو سەد و نەوەد ڕۆژ دەخایەنێت.
\v 12 خۆزگە دەخوازرێ بەوەی چاوەڕێ دەکات و دەگاتە هەزار و سێ سەد و سی و پێنج ڕۆژ.
\p 
\v 13 «بەڵام تۆ، بڕۆ هەتا کاتی هاتنی کۆتایی پشوو بدە، لە کۆتایی ڕۆژگار هەڵدەستیتەوە بۆ وەرگرتنی میراتی خۆت.»
