\id MAT - Yaouré NT [yre] -Côte d'Ivoire 1999 (web version -2013 bd)
\h Matie
\toc1 Zozi Crizi -le 'wɩ 'nɔnnɔn nɛn Matie -a crɛn -tɛ
\toc2 Matie
\toc3 Mt
\mt2 Zozi Crizi -le 'wɩ 'nɔnnɔn nɛn
\mt1 Matie
\mt2 -a crɛn -tɛ
\c 1
\s1 Zozi Crizi tranun 'tɔ nɛn 'gʋ
\r (Lk 3.23-38)
\p 
\v 1 Zozi Crizi a David kluda min -a, ɛn e ya "nyian Abraam kluda min -a. Zozi tranun 'tɔ nɛn 'gʋ.
\qm1 
\v 2 Abraam Izak -ya.
\qm1 Ɛn Izak Zago 'ya.
\qm1 Ɛn Zago Zuda 'lee 'e "bʋɩnun yaa.
\qm1 
\v 3 Ɛn Zuda 'lee Tama bɛ, o Faras 'lee Zara -ya.
\qm1 Ɛn Faras Esrɔm -ya.
\qm1 Ɛn Esrɔm Aram -ya.
\qm1 
\v 4 Ɛn Aram Aminada -ya.
\qm1 Ɛn Aminada Naashɔn -ya.
\qm1 Ɛn Naashɔn Salmɔn -ya.
\qm1 
\v 5 Ɛn Salmɔn 'lee 'e nan Rab bɛ, o Boazɩ -ya.
\qm1 Ɛn Boazɩ 'lee 'e nan Rut bɛ, o Yobedi -ya.
\qm1 Ɛn Yobedi Jese -ya.
\qm1 
\v 6 Ɛn Jese David nɛn e drɛ mingɔnnɛn -a bɛ, -a -ya.
\p Ɛn David Salomɔn -ya 'o 'vale Uri -le -cale -a.
\qm1 
\v 7 Ɛn Salomɔn Robɔam -ya.
\qm1 Ɛn Robɔam Abia -ya.
\qm1 Ɛn Abia Asa -ya.
\qm1 
\v 8 Ɛn Asa Zozafa -ya.
\qm1 Ɛn Zozafa Zoram -ya.
\qm1 Ɛn Zoram Ozia -ya.
\qm1 
\v 9 Ɛn Ozia Zoatan -ya.
\qm1 Ɛn Zoatan Akaz -ya.
\qm1 Ɛn Akaz Ezekia -ya.
\qm1 
\v 10 Ɛn Ezekia Manase -ya.
\qm1 Ɛn Manase Amɔn -ya.
\qm1 Ɛn Amɔn Zozia -ya.
\qm1 
\v 11 Ɛn Zozia Zekonia 'lee 'e "bʋɩnun yaa. E o yaa tʋ nɛn o -ko Izraɛl 'nɔn 'a Babilɔn bɛ -a man.
\p 
\v 12 Zɩ o -kʋ Babilɔn "bɛ -sru "bɛ, ɛn Zekonia Salatiɛl -ya.
\qm1 Ɛn Salatiɛl Zorobabɛl -ya.
\qm1 
\v 13 Ɛn Zorobabɛl Abiudi -ya.
\qm1 Ɛn Abiudi Eliakim -ya.
\qm1 Ɛn Eliakim Azo -ya.
\qm1 
\v 14 Ɛn Azo Sadoci -ya.
\qm1 Ɛn Sadoci Akim -ya.
\qm1 Ɛn Akim Eliu -ya.
\qm1 
\v 15 Ɛn Eliu Eleaza -ya.
\qm1 Ɛn Eleaza Matan -ya.
\qm1 Ɛn Matan Zago -ya.
\qm1 
\v 16 Ɛn Zago Zozɛfʋ nɛn e cɩ Mari -sran -a bɛ, -a -ya.
\qm1 Mari Zozi nɛn waa laabo min 'sizan 'wɩ 'ji Crizi bɛ -a -ya.
\p 
\v 17 Klu pɛɛnɔn zɩɛ -a "nɛn "nɛn 'gʋ:
\p -E e "sia Abraam da -trilii, -e 'e bɔ David man bɛ, e ya klu -fuda sinjɛn.
\p -E e "sia David da -trilii, -e 'e bɔ tʋ nɛn o -ko Izraɛl 'nɔn 'a Babilɔn bɛ -a man bɛ, e ya klu -fuda sinjɛn.
\p -E e "sia tʋ nɛn o -ko Izraɛl 'nɔn 'a Babilɔn -trilii, -e 'e bɔ min 'sizan 'wɩ 'ji Crizi man bɛ, e ya klu -fuda sinjɛn.
\s1 Bali "e 'nan, o "ta -daa Zozi 'yalɛ
\r (Lk 2.1-7)
\p 
\v 18 Zɩ Zozi 'yanan wɩ cɩ 'gʋ: Mari a Zozɛfʋ 'tɔ da 'nan -e 'e 'pa. Wa'a tian 'o cin -tɔlɛ lɩ 'lee -kɔnnɛn -a dɩ, ɛn Mari 'e 'pɔn 'si Bali lei man.
\p 
\v 19 Zozɛfʋ nɛn, e "ta -daa Mari 'palɛ bɛ, e ya min tɩglɩ 'a. E 'ka "vale 'nan 'e Mari 'ci bɔala dɩ -le "wɛan, yaa nrɔn 'e 'ji 'nan e "cɛan "man 'e yɔɔdɩ.
\v 20 E -fʋ 'e 'ci "nrɔnnan 'wɩ zɩɛ -a da, ɛn Bali -le 'pasianɔn nɛn laji bɛ -a -tʋ -ta "va "nyrinvla. E -yrɛ 'nan: «David kluda min Zozɛfʋ, te Mari 'padɩ "klan 'e 'i 'tɛ dɩ! 'Nɛn nɛn -a -pɔn cɩ "man "bɛ, e "sia Bali lei va.
\v 21 Mari "ta -daa 'nɛn 'klɔnmɔn -yalɛ. 'Nɛn zɩɛ 'i 'tɔ 'pa Zozi. -Yɛɛ "ta -daa 'yee minnun 'silɛ 'wɩ 'wlidɩ "ji.»
\p 
\v 22 'Wɩ pɛɛnɔn zɩɛ, e drɛ 'wɩ nɛn Bali 'lewei vɩzan -a 'vɩ 'e 'cɛn bɛ -a 'lɛ sɔɔdɩ -a. Kɔɔ yaa 'vɩ 'nan:
\q1 
\v 23 «"I 'yiɔ! Nɔnbɛ "nɛn,
\q1 ya'a tian 'kɔnnɛn -tɔlɛ dɩɛ,
\q1 'e 'pɔn "sia,
\q1 -e 'e 'nɛn 'klɔnmɔn -ya,
\q1 waa 'tɔ "paa Emanuɛl.»
\m Emanuɛl -ci nɛn 'nan, Bali a -kaa 'va.
\p 
\v 24 Zɩ Zozɛfʋ fuʋ bɛ, 'wɩ nɛn Bali -le 'pasiazan -a 'vɩ bɛ yaa drɛ, e -kʋ Mari -a 'yee "kɔnnɛn, ɛn yaa 'pa.
\v 25 'Pian wa'a 'o cin -tɔlɛ lɩ 'lee 'kɔnnɛn -a "fo 'lɔɔ ɛn Mari Zozi 'ya dɩ.
\c 2
\s1 'Wɩ 'tɔnɔn 'si -kɔɔbli ɛn o -ta Zozi bɔlɛ
\p 
\v 1 O Zozi 'ya Bɛtelɛm 'fla Zude 'lɛglɔn 'ji, te Erodi 'bɛ cɩ Zuif 'nɔn -le mingɔnnɛn -a.
\p Zɩ waa -ya bɛ, ɛn 'wɩ 'tɔnɔn nɛn o mlɛn crɛnnun -kɔnnɛn "paala bɛ, o 'si yidɛ wluan "nan 'zia, ɛn o -ta Zeruzalɛm. Zɩ o 'bɔla Zeruzalɛm bɛ,
\v 2 ɛn waa laabʋ minnun lɔ 'nan: «Zuif 'nɔn 'le mingɔnnɛn nɛn, o "sia -a -yanan 'gʋɛ, e ya nyin zia? Kʋ -yee mlɛn crɛn 'yɩ yidɛ wluan "nan zia, ɛn kʋ -ta -a bɔlɛ.»
\p 
\v 3 Zɩ mingɔnnɛn Erodi 'wɩ zɩɛ -a 'man bɛ, -a ci srɛ. Ɛn Zeruzalɛm 'nɔn pɛɛnɔn "le 'ci srɛ "nyian.
\v 4 Tɔɔn e Bali -pannɔn 'tanɔn 'lee 'fluba 'ci vɩnɔn laabʋ, ɛn yaa laabʋ -wlɔ 'nan: «Nyin zia nɛn, o min 'sizan 'wɩ 'ji Crizi -yaa?»
\v 5 O -yrɛ 'nan: «Waa -yaa Bɛtelɛm, Zude 'lɛglɔn 'ji. Kɔɔ 'wɩ nɛn Bali 'lewei vɩzan -a crɛn -tɛ 'e 'cɛn bɛ -nyrɛn 'gʋ:
\q1 
\v 6 ‹Bɛtelɛm 'nɔn,
\q1 'ka fla a Zude 'lɛglɔn 'ji 'fla "wɛnnɛn 'a,
\q1 'pian e ya 'fla nɛn
\q1 -a 'tɔ -taa vɩlɛ bɛ -a.
\q1 Kɔɔ 'ka 'va nɛn
\q1 o -taa Minsan -yalɛ,
\q1 -yɛɛ si -kɔɔnman 'mɛn minnun Izraɛl 'nɔn lɛ.› »
\p 
\v 7 "Bɛ -sru ɛn Erodi 'wɩ 'tɔnɔn zɩɛ o laabʋ 'e yɔɔdɩ, ɛn yaa laabʋ -wlɔ 'nan: «Tʋ "kɔ "man 'sɛzɛ nɛn, ka mlɛn crɛn zɩɛ -a 'yɩ?» Ɛn waa 'vɩ -yrɛ.
\v 8 -A -nan nɛn e 'o 'pa 'sia Bɛtelɛm, yaa 'vɩ -wlɛ 'nan: «-Te ka 'bɔla 'nan nun bɛ, 'ka 'nɛn zɩɛ -a -wɛɛ tɩglɩ! Ɛn -te kaa 'yɩ bɛ, 'ka 'ta "mɛn "vɩ, -e "an -kʋʋ -a bɔ.»
\p 
\v 9 Zɩ e cɛɛn 'wɩ zɩɛ -a vɩdɩ man -wlɛ "bɛ, ɛn o -kʋdɩ "sia. "Wɛɛ -kɔn -kʋnan -sia bɛ, ɛn o mlɛn crɛn -tʋwli "nɛn, waa 'yɩ yidɛ wluan "nan 'zia bɛ -a 'yɩ "nyian. E -trɔa o 'lɛ, ɛn e -kʋ -tɔlɛ 'kɔn nɛn 'nɛn 'bɔ cɩ -ji bɛ -a ta lou.
\v 10 Zɩ o mlɛn crɛn zɩɛ -a 'yɩ bɛ, ɛn o 'ci nran 'sia 'kpa tɩglɩ.
\v 11 O wla 'kɔn zɩɛ -a -ji, ɛn o 'nɛn 'lee 'e "bʋ Mari 'yɩ. O "po sɔɔn, ɛn o 'nɛn zɩɛ -a 'bɔ. O 'wee -trɔ flu, ɛn o fɛnun -nɔn -yrɛ. -Siganun 'lee -laziglɔnun 'lee fɛnun nɛn waa laabo mire bɛ, -a 'bɔ nɛn waa -nɔn -yrɛ.
\p 
\v 12 "Bɛ -sru "bɛ, ɛn Bali 'wɩ tin 'ba 'wɩ 'tɔnɔn zɩɛ -wlɛ "nyrinvla. Yaa 'vɩ -wlɛ 'nan: «Te 'ka li "nyian 'ka da Erodi -va dɩ.» Zɩ o fuʋ bɛ, o -si pee 'sia, ɛn o -kʋ 'wee 'lɛglɔn 'ji.
\s1 Zozɛfʋ 'lee Mari -ta Zozi 'a min tiidii "trɛda
\p 
\v 13 Zɩ 'wɩ 'tɔnɔn "o -kʋʋ bɛ, ɛn Bali -le 'pasiazan -ta Zozɛfʋ -va nyrinvla. E -yrɛ 'nan: «Erodi a "va 'nan 'e 'nɛn 'gʋɛ -a -tɛa. -Yee "wɛan 'i 'wluan, 'i 'nɛn 'lee 'e "bʋ 'sia -e 'ka 'kʋ tada min tiidii "trɛda Ezipti 'lɛglɔn 'ji. 'Ka 'fʋ -nan nun -trilii, -te mɛin laabʋ 'vaa -e 'ka 'ta.»
\p 
\v 14 Ɛn Zozɛfʋ wluan, e 'nɛn 'lee e "bʋ 'sia, ɛn o Ezipti 'lɛglɔn 'ji si 'sia 'pei -man.
\v 15 Zɩ o 'bɔla 'nan nun bɛ, o -fʋ -nan nun -trilii, ɛn Erodi -ka.
\p 'Wɩ nɛn Minsan -a 'vɩ 'e 'cɛn 'e 'lewei vɩzan lɛ bɛ, zɩ e 'lɛ sɔɔ zɩɛ. Kɔɔ yaa 'vɩ 'nan: «Ezipti 'lɛglɔn 'ji nɛn 'an 'pɩ cɩ, ɛn maan laabʋ.»
\s1 O nannannun -tɛɛ Bɛtelɛm
\p 
\v 16 Zɩ Erodi -a 'yɩ 'nan, 'wɩ 'tɔnɔn 'e see paa bɛ, 'bli 'fɔ "ji -wlidɩ. Ɛn e minnun 'pa 'sia 'nan 'o 'kʋ Bɛtelɛm 'lee 'e "srɔn 'flanun pɛɛnɔn da, -e nannannun pɛɛnɔn nɛn o lɛ 'bɔ "fli 'lee o nɛn o lɛ 'ka tian bɔlɛ "fli "dɩɛ, 'o o -tɛɛ. Tʋ nɛn 'wɩ 'tɔnɔn 'a 'vɩ Erodi lɛ bɛ -a da nɛn 'e 'ci nrɔn ɛn e lɛ "fli 'wɩ 'vɩ.
\p 
\v 17 'Wɩ nɛn Bali 'lewei vɩzan Zeremi -a 'vɩ 'e 'cɛn bɛ, zɩ e 'lɛ sɔɔ zɩɛ. Kɔɔ yaa 'vɩ 'nan:
\q1 
\v 18 «O -paandɩ 'lee wu maan Rama 'fla.
\q1 Rashɛl 'bɛ 'yee 'nɛnnun -wua.
\q1 'Yee 'nɛnnun kaa,
\q1 e 'ka "vale 'wee "sii dɩ,
\q1 kɔɔ o 'ka "nyian -nan dɩ.»
\s1 Zozɛfʋ 'lee Mari 'si Zozi 'a Ezipti 'lɛglɔn 'ji
\p 
\v 19 Zɩ Erodi -ka bɛ, ɛn Bali -le 'pasiazan 'wɩ tin 'ba "nyian Zozɛfʋ lɛ nyrinvla Ezipti 'lɛglɔn 'ji.
\v 20 E 'nan -yrɛ 'nan: «'I 'wluan! 'I 'nɛn 'lee 'e "bʋ 'sia -e 'ka li waa 'ka da Izraɛl 'lɛglɔn 'ji! Kɔɔ minnun nɛn waa -wɛɛman 'nan 'o 'nɛn 'gʋɛ -a -tɛa "bɛ, o pɛɛnɔn kaa.»
\p 
\v 21 Zozɛfʋ wluan, e 'nɛn 'lee 'e "bʋ 'sia, ɛn o Izraɛl 'lɛglɔn 'ji si 'sia.
\v 22 'Pian zɩ yaa 'man 'nan Akelausi 'bɛ 'tɔ mingɔnnɛn -a Zude 'lɛglɔn da 'e "tɩ Erodi "pa 'ji bɛ, tɔɔn Zude 'lɛglɔn 'bɔ 'ji -nyrandɩ "klan -a -tɛ "nyian. -A -nan nɛn Bali 'wɩ tin 'ba -yrɛ "nyrinvla, ɛn e Galile 'lɛglɔn 'ji si 'sia.
\v 23 Zɩ o 'bɔla 'nan nun bɛ, ɛn o -kʋ -nyɛnlɛa 'fla nɛn waa laabo Nazarɛtɩ bɛ -a da.
\p 'Wɩ nɛn Bali 'lewei vɩnɔn -a 'vɩ 'e 'cɛn bɛ, zɩ e 'lɛ sɔɔ zɩɛ. Kɔɔ waa 'vɩ 'nan: «Waa laabo Nazarɛtɩ min.»
\c 3
\s1 Zan minnun -batize drɛ
\r (Mk 1.2-6; Lk 3.1-9; Zan 1.19-23)
\p 
\v 1 Tʋ zɩɛ -a man nɛn min -batize drɛzan Zan 'bɔla Zude "bui "da ɛn yaa vɩdɩ 'sia minnun lɛ 'nan:
\v 2 «'Ka 'si 'wɩ 'wlidɩ "drɛdɩ man -e 'ka 'fli -nɔn Bali lɛ! Bali -le mingɔnnɛn -blɩdɩ 'bɔ -kogo.»
\v 3 Zan -le 'wɩ nɛn Bali 'lewei vɩzan Ezai -a 'vɩ 'li. Yaa 'vɩ 'nan:
\q1 «Min -tʋ wei 'bɛ "we "bui "da.
\q1 Min zɩɛ yaa ve 'nan:
\q1 ‹'Ka Minsan -le -si ta drɛ!
\q1 'Ka -yee -sinun ta -sɛn 'e cin va!› »
\p 
\v 4 -Wi nɛn waa laabo Shamo bɛ, -a "cɛsɔ nɛn Zan da, ɛn -wi 'kɔlɛ nɛn 'e 'tɔdɩ "da -a -tiɛn. Srɔ 'lee -srɔ 'nyrɔn nɛn yaa -ble fɛ -a.
\v 5 Min "kaga "kʋ "va. O -mienun "sia Zeruzalɛm, ɛn o -mienun "sia Zude 'lɛglɔn 'ji, ɛn o -mienun "sia 'yi nɛn waa laabo Zudan bɛ -a "srɔn 'lɛglɔn 'ji.
\v 6 O pɛɛnɔn 'ta ɛn o 'wee 'wɩ 'wlidɩnun 'vɩ Bali lɛ 'wein minnun pɛɛnɔn yiɛ man, te Zan o -batize dra Zudan -va.
\p 
\v 7 'Pian zɩ Zan -a 'yɩ 'nan Farizɛn 'nɔn 'lee Saduze 'nɔn a -tanan 'e 'va "kaga -e 'e o -batize drɛ bɛ, ɛn yaa 'vɩ -wlɛ 'nan: «Min -wlidɩnun! -Tɩɛ 'vɩ 'cɛɛ 'nan 'ka 'si Bali -le nyran -blɩdɩ nɛn e "ta -daa "bɛ -a wlu?
\v 8 'Ka -kɔɔn 'ka drɛ wɩ -a 'nan, ka 'si 'wɩ 'wlidɩ "drɛdɩ man.
\v 9 'Pian te 'ka vɩ 'e "tun 'nan, ka 'si 'wɩ 'ji Abraam a 'ka "tra -a -le "wɛan dɩ! Maan ve 'cɛɛ 'nan, -kɔlɛnun nɛn 'lagʋɛ, Bali -kɔlaman o drɛdɩ -a Abraam kludanɔn 'a.
\p 
\v 10 'Ka "trɔɛn "tɔ -kɔnnɛn 'gʋɛ -yrɛ: 'Bɛ nɛn 'gʋɛ yibanun 'cɛndɩ -le "wɛan bɛ, -saanɛn lɛ a 'e "trandɩ 'va. Yiba "nɛn e baa, te -a 'blʋ 'ka "yi "dɩɛ, waa "cɛan, -e 'o tuʋ 'tɛ 'va.
\p 
\v 11 "An 'ka -batize drɛ 'yi 'a, -a -kɔɔndɩ -a 'nan, ka 'si 'wɩ 'wlidɩ "drɛdɩ man. 'Pian min -tʋ "ta -daa 'e 'fɔla "da, ɛn -a 'plɛblɛ "mlian 'an da. An 'ka -yee -manwua "tun "da baa "fluzan -a dɩ. Min zɩɛ -yɛɛ 'ka -batize dra Bali lei 'lee 'tɛ 'a.
\v 12 -Yee -klu "a 'e 'lɔ -e 'e fɛ 'lee 'e -flu 'cɛn 'e cin man. Yaa 'wlɛ -sɛan 'trɛbɔ -ji. 'Pian yaa -flu 'tɛ 'ble 'tɛ nɛn ya'a 'driman 'mlɔnmlɔn dɩɛ -a va.»
\s1 Zan Zozi -batize drɛ
\r (Mk 1.9-11; Lk 3.21-22; Zan 1.29-34)
\p 
\v 13 "Bɛ -sru Zozi 'si Galile 'lɛglɔn 'ji, ɛn e -ta Zan va 'yi nɛn waa laabo Zudan bɛ -a man. E -ta 'nan -e 'yee -batize drɛ.
\v 14 Zan "e -yrɛ 'nan: «-Cɛjɛ! 'I 'bɔ nɛn yiɛ 'an -batize dra bɛ, yiɛ ve 'pian 'mɛn 'nan, 'mɛin -batize drɛ?»
\p 
\v 15 Ɛn Zozi "e -yrɛ 'nan: «'I 'wɩ "man -e 'i drɛ, kɔɔ e ya 'wɩ "yi "a -e 'wɩ nɛn e cɩ Bali ci 'sɔa bɛ 'kʋ drɛ.» Ɛn Zan 'ka 'wɩ 'pee vɩlɛ "nyian dɩ.
\p 
\v 16 Zɩ Zan Zozi -batize drɛ bɛ, Zozi "ɛ 'si 'yia, tɔɔn labli 'lɛ 'sʋ, ɛn e Bali lei 'yɩ -sɔɔnlanan 'e da "le -plablo -le 'wɩ 'zʋ.
\v 17 Ɛn wei -tʋ wɩɩ laji. E 'nan: «Min 'labɛ, e ya 'an 'pɩ nɛn maan ye "yi ɛn -yee 'wɩ 'an 'ci "nranman bɛ -a.»
\c 4
\s1 Satan Zozi 'man -tan 'nan 'e 'wɩ 'wlidɩ "drɛ
\r (Mk 1.12-13; Lk 4.1-13)
\p 
\v 1 "Bɛ -sru, ɛn Bali lei -kʋ Zozi 'a "bui "da, -e Satan 'e man -tan -le "wɛan.
\v 2 Zɩ e fɛ 'sɔn yi -fuba sinjɛn bodrun funnin bɛ, ɛn dra -a -tɛdɩ 'sia.
\v 3 -A -nan nɛn Satan nɛn min man -tanzan -a bɛ e pli "man, ɛn e -yrɛ 'nan: «-Te i ya Bali -pɩ -a bɛ, 'i 'wɩ 'tʋ vɩ -e -kɔlɛnun 'labɛ 'o lila -blɩfɛ -a!»
\v 4 Ɛn Zozi "e -yrɛ 'nan: «E ya 'e 'crɛn -tɛdɩ 'nan:
\q1 ‹-Blɩfɛ 'saza 'man "cɛɛ min "belia dɩ.
\q1 'Pian weinun pɛɛnɔn nɛn
\q1 e "sia Bali 'le bɛ,
\q1 -a da 'ta wʋdɩ man nɛn min "belia.› »
\p 
\v 5 "Bɛ -sru Satan -kʋ Zozi 'a Zeruzalɛm, ɛn e -kʋ -a -tɔlɛ Bali -pan 'kɔn 'win -ji lou.
\v 6 -A -nan nɛn e 'nan Zozi lɛ 'nan: «-Te i ya Bali -pɩ -a bɛ, 'i 'sʋ -e 'i -sɔɔnla, kɔɔ e ya 'e 'crɛn -tɛdɩ 'nan:
\q1 ‹Bali -a ve 'yee 'pasianɔn nɛn
\q1 laji bɛ -wlɛ 'nan,
\q1 'wei 'kun 'o 'lɔ lou,
\q1 "tɔgɔ 'i 'cɛin 'e 'lɛ wʋ
\q1 -kɔlɛ -mie ji -le "wɛan.› »
\p 
\v 7 Zozi "e -yrɛ 'nan: «-Cɛjɛ, ma'an dra dɩ. Kɔɔ e ya "nyian 'e 'crɛn -tɛdɩ 'nan:
\q1 ‹Te blamin 'e Bali nɛn
\q1 Minsan -a bɛ -a man -tan dɩ!› »
\p 
\v 8 "Bɛ -sru, ɛn Satan -kʋ Zozi 'a "nyian pɔn loulou "tʋ -win -ji. -A -nan nɛn e mingɔnnɛn trɛnun pɛɛnɔn nɛn 'trɛda bɛ -a kɔɔn -yrɛ 'o 'vale 'wee fɛnyian -a.
\v 9 Ɛn "e -yrɛ 'nan: «-Te i "po sɔɔnla 'an 'wlu -e 'yian bɔ bɛ, mingɔnnɛn trɛnun pɛɛnɔn 'labɛ, maan -nɔan 'yiɛ.»
\p 
\v 10 Tɔɔn Zozi "e -yrɛ 'nan: «Satan, 'i -pli 'i -sru! E ya 'e 'crɛn -tɛdɩ 'nan:
\q1 ‹Bali nɛn Minsan -a bɛ,
\q1 -a 'bɔ nɛn min 'e bɔ,
\q1 ɛn -a -tʋwli "cɛ "nɛn min 'e 'su!› »
\p 
\v 11 -A -nan nɛn Satan 'si -a "srɔn, tɔɔn Bali -le 'pasianɔn nɛn laji bɛ, o pli "man, ɛn waa 'su.
\s1 Zozi 'le 'nyranman pou sianan
\r (Mk 1.14-15; Lk 4.14-15)
\p 
\v 12 Zɩ Zozi 'a 'man 'nan o Zan -fɔ -pʋ 'kuin bɛ, ɛn e 'li 'e da Galile.
\v 13 Ya'a 'fʋlɛ Nazarɛtɩ dɩ, 'pian e -kʋ -nyɛnlɛa Kapanamo. 'Fla zɩɛ e ya Galile 'yi -dan "srɔn. E ya Zabulɔn 'lee Nefʋtali 'lɛglɔn 'ji.
\v 14 'Wɩ nɛn Bali 'lewei vɩzan Ezai -a 'vɩ 'e 'cɛn bɛ, zɩ e 'lɛ sɔɔ zɩɛ. Kɔɔ yaa 'vɩ 'nan:
\q1 
\v 15 «Zabulɔn 'lee Nefʋtali 'lɛglɔn 'ji 'nɔn!
\q1 Ka ya 'trɛ nɛn
\q1 e ya Galile 'yi -dan "srɔn "bɛ
\q1 -a da 'nɔn 'a.
\q1 Ɛn ka ya 'lɛglɔn nɛn
\q1 e ya Zudan 'yi -sru "bɛ -a -ji 'nɔn 'a.
\q1 Galile nɛn minnun nɛn
\q1 o 'ka Zuif 'nɔn 'a dɩɛ
\q1 o -nyɛanla 'nan bɛ
\q1 -a -nan 'nɔn nɛn kaa!
\q1 'Ka "trɔɛn "tɔ 'wɩ 'gʋɛ -yrɛ!
\q1 
\v 16 Minnun nɛn 'o -nyrandɩ klun tiidii 'va bɛ,
\q1 o 'tɛ 'san -dan 'yɩ.
\q1 Ɛn minnun nɛn o cɩ -ka -lɔ bɛ,
\q1 'tɛ 'san -sɛn o da.»
\p 
\v 17 Tʋ zɩɛ -a man nɛn Zozi Bali -le 'wɩ vɩdɩ 'sia. Yaa 'vɩ 'nan: «'Ka 'si 'wɩ 'wlidɩ "drɛdɩ man -e 'ka 'fli -nɔn Bali lɛ! Bali -le mingɔnnɛn -blɩdɩ 'bɔ 'kogo.»
\s1 Zozi -srunɔn tɛdɛ
\r (Mk 1.16-20; Lk 5.1-11)
\p 
\v 18 Yi -tʋ da nɛn Zozi a ciɩnan Galile 'yi 'plo da, ɛn e min "fli 'yɩ, te o ya 'wee pɔ -tɛ "se 'wɛɛnnan 'yi 'va. Pɔ -tɛnɔn nɛn waa. Simɔn nɛn waa laabo Piɛri bɛ 'lee 'e "bʋɩ Andre nɛn.
\v 19 Ɛn e 'nan -wlɛ 'nan: «'Ka -sɔɔnla 'an -sru! An -taa 'ka drɛlɛ minnun nɛn o min laabo 'an -sru "bɛ waa.»
\v 20 'Nun tɔɔn o 'wee "senun 'tʋɩ, ɛn o sɔɔnla Zozi -sru.
\p 
\v 21 "Yɛɛ -kʋ "nyian 'e 'lɛ bɛ, te e min "fli "pee ye. Zebede -pɩ Zaji 'lee 'e "bʋɩ Zan nɛn, o ya 'o 'fɔdɩ -klʋ -ji 'o 'vale 'o "tɩ Zebede -a, te o 'wee "senun -peeman. Zozi o laabʋ.
\v 22 'Nun tɔɔn min "fli zɩɛ o 'si 'wee -klʋ -ji, o 'si 'o "tɩ -sru, ɛn o sɔɔnla Zozi -sru.
\s1 Zozi ciɩ Bali -le 'wɩ vɩdɩ -a Galile 'lɛglɔn 'ji
\r (Mk 1.39; Lk 4.44)
\p 
\v 23 Zozi ciɩ Galile 'lɛglɔn pɛɛnɔn 'ji. E 'wɩ paa minnun ji Zuif 'nɔn 'le cin yɩ 'kɔnnun -ji. E Bali 'le 'wɩ 'nɔnnɔn 'vɩ -yee mingɔnnɛn -blɩdɩ da. Minnun pɛɛnɔn nɛn -cɛ cɩ o man 'lee minnun pɛɛnɔn nɛn o man "yaaman bɛ e 'o beli.
\v 24 -A -nan nɛn waa 'tɔ 'wɩdɩ 'man Siri 'lɛglɔn pɛɛnɔn 'ji, ɛn minnun -ta o pɛɛnɔn nɛn o cɩ see -blɩnan -cɛ 'tɔ 'tʋdʋ pɛɛnɔn 'lɔ bɛ waa -yrɛ. Min -mienun man 'bɛ "yaaman, ɛn -yʋ -wlidɩ 'bɛ cɩ min -mienun -sru, ɛn -tʋwli "cɛ 'bɛ cɩ min -mienun man, ɛn min -mienun a 'o -srandɩ "tra, o pɛɛnɔn zɩɛ o -ta waa -yrɛ, ɛn e o beli.
\v 25 -A -nan nɛn min "kaga 'kpa -sɔɔnla -a -sru. O -mienun "sia Galile 'lɛglɔn 'bɔ 'ji, ɛn o -mienun "sia 'lɛglɔn 'tʋ nɛn waa laabo 'Fla 'fu bɛ -a -ji, ɛn o -mienun "sia Zeruzalɛm, ɛn o -mienun "sia Zude, ɛn o -mienun "sia 'yi nɛn waa laabo Zudan bɛ -a -sru 'flanun da.
\c 5
\s1 Zozi Bali -le 'wɩ 'vɩ pɔn da
\r (Lk 6.20-26)
\p 
\v 1 Zɩ Zozi min "kaga zɩɛ o 'yɩ bɛ, -a -nan nɛn e pɔn tri, e -nyran, ɛn -a -srunɔn pli "man.
\v 2 Ɛn e 'wɩ "paadɩ 'sia o ji. Yaa 'vɩ -wlɛ 'nan:
\s1 -Tɩ man nɛn Bali -le -fɛa cɩ?
\p 
\v 3 «Minnun nɛn waa -tɔa 'o 'fli 'lɔ 'nan, -te Bali 'ka 'palɛ 'o 'va dɩɛ, wa'a 'kɔlaman fɛ -tʋ drɛdɩ -a dɩɛ, Bali -le -fɛa a o man, kɔɔ -wɛɛ cɩ Bali -le mingɔnnɛn trɛdanɔn 'a.
\p 
\v 4 Minnun nɛn o cɩ -trunnan 'o 'man wɩnun lɔ bɛ, Bali -le -fɛa a o man, kɔɔ Bali o "siiman.
\p 
\v 5 Minnun nɛn o cɩ min -trɔɔ -a bɛ, Bali -le -fɛa a o man, kɔɔ 'trɛ nɛn Bali -a 'vɩ bɛ -wɛɛ cɩ -a da 'nɔn 'a.
\p 
\v 6 Minnun nɛn Bali -le 'wɩ tɩglɩ drɛdɩ dra o -tɛa "bɛ, Bali -le -fɛa a o man, kɔɔ Bali o ci -taa "tra 'wɩ zɩɛ -a drɛdɩ -a.
\p 
\v 7 Minnun nɛn min nyrinda -sɛan "o da bɛ, Bali -le -fɛa a o man, kɔɔ Bali o nyrinda "sia.
\p 
\v 8 Minnun nɛn o 'wɩ dra 'o 'ci 'fɩdaa 'a bɛ, Bali -le -fɛa a o man, kɔɔ o -taa Bali yɩlɛ.
\p 
\v 9 Minnun nɛn waa -wɛɛman 'nan minnun yei 'e 'fʋ -trɔɔ bɛ, Bali -le -fɛa a o man, kɔɔ Bali -taa "o laabʋlɛ 'yee 'nɛnnun.
\p 
\v 10 Minnun nɛn o cɩ 'tɛ 'panan o da Bali ci 'sɔ wɩ drɛdɩ -le "wɛan bɛ, Bali -le -fɛa a o man, kɔɔ -wɛɛ cɩ Bali -le mingɔnnɛn trɛdanɔn 'a.
\p 
\v 11 -Te o 'ka "srɔnman 'mɛn "wɛan oo, -te o 'tɛ "paa 'ka da 'mɛn "wɛan oo, -te o 'wɩ 'wlidɩ 'tɔ 'tʋdʋ pɛɛnɔn ve 'ka man 'wlu 'a 'mɛn "wɛan oo, Bali -le -fɛa a 'ka man!
\v 12 'Ka 'ci 'e "nran 'e 'ciɩla "da, kɔɔ 'ka 'kopa -kɔan -dan laji. Bali 'lewei vɩnɔn nɛn 'ka 'lɔ 'e 'flin bɛ, 'wɩ 'tʋwli zɩɛ minnun -wee drɛ.»
\s1 Zozi -srunɔn a 'trɛda "le -wɛ -le 'wɩ 'zʋ
\r (Mk 9.50; Lk 14.34-35)
\p 
\v 13 «Ka ya 'trɛda "le -wɛ -le 'wɩ 'zʋ. -Te -wɛ 'nɔnnɔn 'si "man "bɛ, -mɛ "a nɛn waa dra 'nɔnnɔn? E 'ka fɛ -tʋ drɛvɛ -a "nyian "fo "dɩ. Waa wɛɛnman, -e minnun 'o "taanla "da.»
\s1 Zozi -srunɔn a 'trɛda "le 'tɛ 'san -le 'wɩ 'zʋ
\r (Mk 4.21; Lk 8.16)
\p 
\v 14 «Ka ya 'trɛda "le 'tɛ 'san -le 'wɩ 'zʋ. 'Fla nɛn pɔn da lou "bɛ, e 'ka 'e yɔɔdɩ dɩ, -a -tʋwli "nɛn "nyian 'cee vɛ -a.
\v 15 Ɛn wa'a -kannɛn -fɔa "nɛn -e 'o yɔɔ -pɔ wlu dɩ. 'Pian waa -tɔala fɛnan 'wein da, -e 'e min pɛɛnɔn nɛn 'kuin bɛ o va drɛ 'wein.
\v 16 'Wɩ 'tʋwli zɩɛ -a 'bɔ nɛn 'cee vɛ -a, minnun pɛɛnɔn 'o 'ka 'san yɩ! Ɛn 'wɩ "yi "nɛn kaa dra bɛ 'o yɩ, -e 'o 'ka "tɩ "nɛn laji bɛ -a 'tɔ drɛ -dan.»
\s1 Zozi 'ta Bali -le -pei 'lɛ sɔɔlɛ
\r (Lk 16.17)
\p 
\v 17 «Te -a -cin 'e 'kɔn 'ka 'ji 'nan, an -ta Moizi -le -pei klu -sɛnlɛa ji dɩ! Te -a -cin 'e 'kɔn 'ka 'ji "nyian 'nan, an -ta Bali 'lewei vɩnɔn wei klu -sɛnlɛa ji dɩ! Ma'an 'talɛ 'wɩnun zɩɛ -a klu -sɛnlɛa ji dɩ, an -ta 'nan -e 'an o 'lɛ sɔɔ 'pian.
\v 18 Maan ve 'cɛɛ 'wɩ tɩglɩ 'a 'nan, -te labli 'lee 'trɛ 'ka tian 'nyanlɛ dɩɛ, te -pei -le 'wɩ "wɛnnɛn 'tʋwli "cɛ 'ka 'sia "da "dɩ -trilii, -e 'wɩ pɛɛnɔn nɛn -pei -a 'vɩ bɛ 'e 'lɛ sɔɔ.
\v 19 -Yee "wɛan min nɛn e Bali -le -pei "wɛnnɛn 'tʋwli srɛ bɛ, ɛn e 'wɩ paa minnun ji 'nan, 'o drɛ "le 'yee 'wɩ 'zʋ bɛ, Bali -le mingɔnnɛn trɛda bɛ, min zɩɛ -yɛɛ -kɔan min "wɛnnɛn 'a. 'Pian min nɛn e 'ta 'wʋla Bali -le -pei da, ɛn yaa "paaman minnun ji 'nan 'o 'ta wʋla "da "bɛ, Bali -le mingɔnnɛn trɛda bɛ, min zɩɛ -yɛɛ -kɔan min -dan a.
\v 20 -Yee "wɛan maan ve 'cɛɛ 'nan, -te 'ka drɛ wɩ "yinun 'ka 'mlinlɛ 'fluba 'ci vɩnɔn 'lee Farizɛn 'nɔn 'le vɛ da dɩɛ, ka'a -ko Bali -le mingɔnnɛn 'trɛda "fo "dɩ.»
\s1 'Wɩ 'wlidɩ pɛɛnɔn a -tʋwli
\r (Lk 12.57-59)
\p 
\v 21 «Kaa 'man 'nan, waa 'vɩ -kaa tranun lɛ 'nan:
\q1 ‹Te blamin 'e drɛ min -tɛzan -a dɩ!
\q1 Min nɛn e min -tɛ bɛ,
\q1 o -ko -a tin 'banɔn 'cɛin -da.›
\m 
\v 22 'Pian 'an 'bɔ, "an "ve 'cɛɛ 'nan, min nɛn 'bli 'fɔ "ji 'e "bʋɩ man bɛ, o -ko -a tin 'banɔn 'cɛin -da. Ɛn min nɛn yaa 'vɩ 'e "bʋɩ lɛ -blʋzan bɛ, o -ko -a tin 'banɔn -dandan cɛin -da. Ɛn min nɛn yaa 'vɩ 'e "bʋɩ lɛ klinzan bɛ, e ya "le 'o -fɔ 'tɛ nɛn -a va yra yɩdɩ 'leda "ka "dɩɛ, -a va.
\p 
\v 23 -Te i -kʋ Bali -panvɛ -a Bali -pannan, ɛn -a -cin -trɔa 'i 'ji 'nan, 'wɩ a 'ka 'vale 'i "bʋɩ -tʋ -a 'ka yei "bɛ,
\v 24 'i Bali -panvɛ zɩɛ -a 'tʋɩla Bali -pannan bɛ, -e 'i 'kʋ 'i "bʋɩ zɩɛ -a va. 'I 'ka yei "sɛn 'e cin va 'vaa -e 'i 'ta 'yie 'sraga bʋ Bali lɛ.
\p 
\v 25 -Te min -tʋ 'i 'sanman drɛ, ɛn ka "ta -ko -a tin 'balɛ bɛ, 'i 'fɔ 'e 'flin 'i 'ka yei "sɛn 'e cin va, "tɔgɔ 'yei 'nɔn tin 'bazan lɛ, -e tin 'bazan 'e 'i 'fɔ -pʋ 'kuin.
\v 26 Maan ve 'yiɛ 'wɩ tɩglɩ 'a 'nan, "yiɛ vɩnan i bɔla -pʋ 'kɔn zɩɛ -a -ji bɛ, te i cɛɛn -yee "lala pɛɛnɔn bɔladɩ man.»
\s1 Wa'a min nan 'lee min -sran -wɛɛman dɩ
\r (Mk 9.43-48)
\p 
\v 27 «Kaa 'man 'nan, Bali "e 'nan:
\q1 ‹Te blamin 'e min nan -wɛɛ "dɩ,
\q1 ɛn te 'e min -sran -wɛɛ "dɩ!›
\m 
\v 28 'Pian 'an 'bɔ, "an "ve 'cɛɛ 'nan, min nɛn e min nan -nanjɛɛn, ɛn -a 'bli bʋ "man "bɛ, te yaa wɛɛ 'va.
\p 
\v 29 -Yee "wɛan maan ve 'cɛɛ 'nan, -te 'i 'pɛ "yi "da yiɛ 'bɛ -maan i 'wɩ 'wlidɩ "dra bɛ, 'i 'si "ji -e 'i tuʋ -kɔɔbli! Kɔɔ -te 'i 'man 'mɛn -tʋwli "cɛ srɛ bɛ, -a "yi "mlian 'i 'bɔ po -fɔdɩ 'tɛ nɛn -a va yra yɩdɩ 'leda "ka "dɩɛ, -a va da.
\v 30 Ɛn -te 'i 'pɛ "yi 'bɛ -maan i 'wɩ 'wlidɩ "dra bɛ, 'i 'cɛn -e 'i tuʋ -kɔɔbli! Kɔɔ -te 'i 'man 'mɛn -tʋwli "cɛ srɛ bɛ, -a "yi "mlian 'i 'bɔ po -fɔdɩ 'tɛ nɛn -a va yra yɩdɩ 'leda "ka "dɩɛ, -a va da.»
\s1 Min nan bɔladɩ da wɩ
\r (Lk 16.18)
\p 
\v 31 «Bali -a 'vɩ "nyian 'nan:
\q1 ‹-Te min "ta 'e nan bɔala bɛ,
\q1 'fluba nɛn yaa -kɔɔnman 'nan yaa 'bɔla bɛ,
\q1 'e 'nɔn -yrɛ 'vaa -e 'e bɔla.›
\m 
\v 32 'Pian 'an 'bɔ, "an "ve 'cɛɛ 'nan, min nɛn e nan 'bɔla, te -kɔnnɛn -wɛɛdɩ man "cɛɛ dɩɛ, te min zɩɛ -yɛɛ vɩnan 'e -kɔnnɛn -wɛɛ -kɔnnɛn pee 'padɩ -a. Ɛn min nɛn e lɩ zɩɛ -a 'pa bɛ, te Bali 'lɛ zia bɛ e min nan wɛɛ.»
\s1 Zozi -srunɔn 'ka 'wɩ 'ji -pɛ wuanla Bali 'tɔ da dɩ
\p 
\v 33 «Kaa 'man 'nan, waa 'vɩ -kaa tranun lɛ 'nan:
\q1 ‹Te blamin 'e 'wlu man -pɛ wluan Bali 'tɔ da dɩ!
\q1 'Pian 'wɩ oo 'wɩ nɛn
\q1 'e 'pɛ wluan 'ji Minsan Bali 'tɔ bɛ,
\q1 yaa 'lɛ sɔɔman -kpɔ.›
\m 
\v 34 'Pian 'an 'bɔ, "an "ve 'cɛɛ 'nan, te 'ka fɛ -tʋ -ji -pɛ wluan "fo "dɩ! Ɛn te 'ka labli drɛ 'cee 'wɩ nan yɩzan -a "fo "dɩ, kɔɔ e ya Bali -le mingɔnnɛn pɛin -a.
\v 35 Te 'ka 'trɛ drɛ 'cee 'wɩ nan yɩzan -a "fo "dɩ, kɔɔ e ya Bali cɛin -trɔanan "a. Te 'ka Zeruzalɛm 'trɛ drɛ 'cee 'wɩ nan yɩzan -a "fo "dɩ, kɔɔ e ya Bali nɛn mingɔnnɛn -dan a bɛ -a 'fla -a.
\v 36 Ɛn te 'ka vɩnan 'wɩ 'e 'bɔ 'ka man 'wɩ 'tʋ -ji, -e 'ka 'wulo 'e 'kʋ -ji dɩ, kɔɔ ka'a 'kɔlaman 'ka 'wulo "jɛ pou -tʋwli "cɛ liladɩ -a 'fuvu dɩ, ɛn ka'a 'kɔlaman -a liladɩ -a tiidii "dɩ.
\v 37 -Te e ya -inyan -a bɛ, 'ka vɩ -inyan! -Te e ya -cɛjɛ -a bɛ, 'ka vɩ -cɛjɛ! 'Wɩ pɛɛnɔn nɛn cɛɛ ve -a -sru "bɛ, 'e "sia Satan nɛn e 'wɩ 'wlidɩ "paa 'nyranman -a bɛ -a va.»
\s1 Zozi -srunɔn 'ka 'wɩ 'lɛji tɔa dɩ
\r (Lk 6.29-30)
\p 
\v 38 «Kaa 'man 'nan waa 'vɩ 'nan:
\q1 ‹-Te min 'i yiɛ -wi bɛ,
\q1 'i -yee vɛ -wi!
\q1 Ɛn -te min 'i 'shɛ 'sʋ bɛ,
\q1 'i -yee vɛ 'sʋ!›
\m 
\v 39 'Pian 'an 'bɔ, "an "ve 'cɛɛ 'nan, te 'ka 'wɩ 'lɛji -tɔ 'wɩ 'wlidɩ "drɛzan lɛ dɩ. -Te min 'pa 'fɔ 'i 'pɛ "yi "da 'klanbo "da bɛ, 'i 'pɛ bʋ davɛ -kɔɔn "nyian -yrɛ!
\v 40 -Te min a "va 'nan 'e 'ko 'yia tin 'bazan cɛin -da, 'yie -tralɛ 'sidɩ -le "wɛan bɛ, 'i 'ta sɔ nɛn -a 'wɩ cɩ 'i man bɛ, 'i 'nɔn -yrɛ "nyian!
\v 41 -Te min -tʋ -trɔ -tɔ 'i 'win -ji -sa -a, 'nan 'i 'kʋ -a kilo -tʋ da bɛ, 'i 'pa "da "nyian -tʋ!
\v 42 -Te min fɛ laabʋ 'i 'lɔ bɛ, 'i 'nɔn -yrɛ. Ɛn te 'i koda -tɔ min nɛn e -ta fɛ 'fɛlɛ 'i 'lɔ bɛ -yrɛ "dɩ!»
\s1 Zozi -srunɔn 'o 'nanmannɔn ye "yi
\r (Lk 6.27-28, 32-36)
\p 
\v 43 «Kaa 'man 'nan waa 'vɩ 'nan:
\q1 ‹Blamin 'e bɔɛzan -tʋ yɩ "yi,
\q1 'pian 'e 'nan 'e 'nanmanzan man!›
\m 
\v 44 'Pian 'an 'bɔ, "an "ve 'cɛɛ 'nan, 'ka 'ka 'nanmannɔn yɩ "yi, ɛn "nyian bɛ 'ka Bali trʋ 'ba minnun nɛn o 'tɛ "paa 'ka da bɛ, -wee 'wɩ man!
\v 45 'Wɩnun zɩɛ -a 'bɔ nɛn 'ka drɛ, -e 'ka 'kɔn 'ka "tɩ nɛn laji bɛ -yee 'nɛnnun tɩglɩ 'a. Kɔɔ e yidɛ wuanla 'wɩ 'wlidɩ "drɛnɔn 'lee 'wɩ "yi "drɛnɔn da, ɛn e laa -fɛan min -wlidɩnun 'lee min tɩglɩnun da.
\v 46 -Te minnun nɛn o 'ka ye "yi "bɛ, o 'saza nɛn ka o ye "yi "bɛ, te -a -cin 'e 'kɔn 'ka 'ji 'nan Bali -a man "yi "dra 'cɛɛ dɩ! 'Sukɔlɛ 'sinɔn nɛn 'wɩ 'wlidɩ "drɛnɔn 'a bɛ, 'wɩ 'bɔ zɩɛ -nyrɛn "o "dra.
\v 47 Ɛn -te 'ka "bʋɩnun 'saza nɛn ka 'o 'tɔ bo bɛ, ka'a 'wɩ -dan drɛlɛ "fo "dɩ. Kɔɔ minnun nɛn wa'a Bali tɔa dɩɛ, 'wɩ 'tʋwli zɩɛ -a 'bɔ nɛn "o "dra.
\v 48 'Ka 'kɔn tɩglɩ "le zɩ 'ka "tɩ Bali nɛn laji bɛ e cɩ tɩglɩ bɛ -yee 'wɩ 'zʋ.»
\c 6
\s1 O fɛ -nɔan seenɔn lɛ 'kɔ?
\p 
\v 1 «Fɛ oo fɛ nɛn ka "ta -a dra Bali lɛ bɛ, te 'ka -wɛɛ 'nan 'ka dra minnun yiɛ lɛ 'nan -e 'o 'ka 'tɔ "yi "vɩ dɩ! Kɔɔ -te 'wɩ zɩɛ -a -cin a 'ka 'ji bɛ 'ka "tɩ "nɛn laji bɛ ya'a man "yi 'dra 'cɛɛ "fo "dɩ.
\p 
\v 2 -Yee "wɛan fɛ oo fɛ nɛn yia -nɔan seezan lɛ bɛ, te 'i 'nan wɩ fuila "man "dɩ! 'Wɩ zɩɛ -a 'bɔ nɛn minnun nɛn o 'wɩ dra min yiɛ lɛ bɛ, waa dra cin yɩ 'kuin, ɛn waa dra "nyian -guada. Waa -nan wɩ ve 'nan -e minnun 'e 'o 'tɔ "yi "vɩ -le "wɛan. Maan ve 'cɛɛ 'wɩ tɩglɩ 'a 'nan, o 'o -kopa 'yɩ 'va.
\v 3 'Pian 'yie vɛ bɛ, -te "yiɛ "lala -nɔn seezan lɛ bɛ, te min pee 'e 'nan yɩ dɩ!
\v 4 'I drɛ zɩɛ 'dʋ -e -a 'wɩ 'e 'fʋ 'e yɔɔdɩ, -e 'i "tɩ "nɛn e fɛ yɔɔdɩ -tɔa "bɛ, 'yei -ko 'pa.»
\s1 Bali trʋ 'badɩ da wɩ
\p 
\v 5 «Ɛn -te ka ya Bali trʋ 'banan bɛ, te 'ka drɛ "le minnun nɛn o 'wɩ dra min yiɛ lɛ bɛ, -wee 'wɩ 'zʋ dɩ! O Bali trʋ 'badɩ ye "yi 'o 'tɔdɩ lou cin yɩ 'kuin 'lee -guada, 'nan -e minnun 'e 'o yɩ -le "wɛan. Maan ve 'cɛɛ 'wɩ tɩglɩ 'a 'nan, o 'wee -kopa 'yɩ 'va.
\v 6 'Pian 'yie vɛ bɛ, -te i ya "va 'nan i Bali trʋ "baa bɛ, 'i wla 'yie 'kɔn "bʋ "ji, 'i 'lɛ wʋ, -e 'i "tɩ "nɛn e cɩ fɛ yɔɔdɩ 'bɔ zɩɛ -a -nan bɛ, 'i trʋ 'ba. -Te i ya -a drɛnan zɩɛ, 'i "tɩ "nɛn e 'wɩ yɔɔdɩ ye bɛ, yei -ko "paa.
\p 
\v 7 -Te ka ya Bali trʋ 'banan bɛ, te 'ka 'wɩ "kaga "vɩ "le minnun nɛn wa'a Bali tɔa dɩɛ, -wee 'wɩ 'zʋ dɩ. E ya 'o 'ji "le 'nan 'wee tin "kaga 'padɩ man nɛn Bali 'e "trɔɛn -tɔa 'wlɛ.
\v 8 Te 'ka drɛ "le -wee 'wɩ 'zʋ dɩ! Kɔɔ 'ka "tɩ "nɛn laji bɛ, "cɛɛ vɩnan 'ka fɛnun laabʋ -yrɔ "bɛ, te e 'ka 'man wɩnun 'bɔ -tɔa 'va.»
\s1 Bali trʋ 'badɩ
\r (Lk 11.2-4)
\p 
\v 9 «Zɩ kɔ 'ka Bali trʋ 'ba bɛ -nyrɛn 'gʋ, 'ka vɩ 'nan:
\q1 'Kʋ "tɩ Bali nɛn laji bɛ,
\q1 'i drɛ -e minnun 'o 'i 'tɔ drɛ -dan.
\q1 
\v 10 'Yie mingɔnnɛn -blɩdɩ 'e 'ta.
\q1 Ɛn 'i drɛ -e minnun 'o 'i 'ci 'sɔ wɩ drɛ 'trɛda,
\q1 "le zɩ e dra laji bɛ, -yee 'wɩ 'zʋ.
\q1 
\v 11 'I 'kʋe cɛɛgʋ -blɩfɛ nɛn kʋ cɩ "va "bɛ, -a -nɔn 'kʋɛ.
\q1 
\v 12 'Wɩnun nɛn kʋa dra 'yiɛ -wlidɩ "bɛ 'i 'cɛ 'kʋɛ,
\q1 "le zɩ minnun 'wɩ dra 'kʋɛ -wlidɩ kʋa "cɛa -wlɛ "bɛ -yee 'wɩ 'zʋ.
\q1 
\v 13 Te 'i 'kʋ 'tʋɩ -e Satan 'e 'kʋ 'man yɩ dɩ.
\q1 'Pian 'i 'kʋ 'si -yrɔ.
\q1 [Mingɔnnɛn -blɩdɩ, 'lee 'plɛblɛ, 'lee 'tɔ -dan a 'li 'e 'cɛn 'yie vɛ -a, -trilii. Amɛn!]
\m 
\v 14 'Wɩ 'wlidɩ "nɛn minnun -a dra 'cɛɛ bɛ, -te kaa "cɛa -wlɛ "bɛ, 'ka "tɩ "nɛn laji bɛ, 'wɩnun nɛn kaa drɛ -yrɛ "wlidɩ "bɛ, e "cɛa "nyian 'cɛɛ.
\v 15 'Pian -te minnun 'wɩ drɛ 'cɛɛ, ɛn ka'a 'cɛlɛ -wlɛ "dɩɛ, 'ka "tɩ "nɛn laji bɛ, 'wɩnun nɛn kaa drɛ -yrɛ "wlidɩ "bɛ, ya'a "nyian "e cɛa 'cɛɛ dɩ.»
\s1 Fɛ 'sɔndɩ
\p 
\v 16 «-Te ka ya fɛ 'sɔnnan bɛ, te 'ka 'fli ta drɛ -trɔdrɔ "le minnun nɛn o 'wɩ dra min yiɛ lɛ bɛ, -wee 'wɩ 'zʋ dɩ. 'O 'fli ta dra -trɔdrɔ, -e 'o -kɔɔn "minnun lɛ 'nan, 'o ya fɛ 'sɔnnan. Maan ve 'cɛɛ 'wɩ tɩglɩ 'a 'nan, o 'wee -kopa 'yɩ 'va.
\v 17 -Te i ya fɛ 'sɔnnan bɛ, 'i yra "foe, ɛn 'i -laziglɔ -sɛn 'i da,
\v 18 -e minnun 'o vɩlɛ o -kɔnnɛn "yɩ 'nan i ya fɛ 'sɔnnan dɩ. 'I "tɩ "nɛn e cɩ fɛ yɔɔdɩ 'bɔ zɩɛ -a -nan bɛ, -yɛɛ -nan ye 'i 'lɔ, -e 'yei -ko 'pa.»
\s1 Zozi -srunɔn 'o -wɛɛ 'nan 'o yɩfɛnun 'e 'kɔn Bali "srɔn
\r (Lk 12.33-34; 11.34-36; 16.13)
\p 
\v 19 «Te 'ka fɛnun tre 'ka yɩfɛ -a 'trɛ 'gʋɛ -a da dɩ! Fadrʋnɛn 'lee mɔnnɛnnun o srɛman, ɛn crinnɔn 'kɔn "fɔan, -e 'o "koola.
\v 20 'Pian 'ka fɛnun tre 'ka yɩfɛ -a laji. Fadrʋnɛn 'lee mɔnnɛnnun 'ka 'nan nun -e 'o fɛ srɛ dɩ, ɛn crinnɔn 'ka 'nan nun -e 'o crin wʋ dɩ.
\v 21 Fɛ nɛn yaa -maan 'lɔɔ 'an 'wɩ zɩɛ -a 'vɩ bɛ, -yɛɛ cɩ 'nan, fɛnan nɛn min yɩfɛ cɩ 'e pladɩ bɛ, -a -nan nɛn min -le ci "nrɔndɩ pɛɛnɔn -kɔan.
\p 
\v 22 Min yiɛ 'bɛ -maan min fɛnan ye. -Te 'i yiɛ a "ji 'kpa bɛ, 'tɛ 'san -sɛan 'i da, yia -tɔa.
\v 23 'Pian -te 'i yiɛ 'ka fɛnan ye dɩɛ, 'tɛ 'san -sɛan 'i da, yi'a tɔa dɩ. I ya tʋ pɛɛnɔn man klun va. -Te fɛ -tʋ -si -tɔ 'tɛ 'san -lɔ ɛn i -fʋ klun va bɛ, te i ya klun tiidii -dan 'va!
\p 
\v 24 Min -tʋwli 'ka 'kɔlaman -e 'e drɛ min "fli 'suzan 'a dɩ. Kɔɔ -te yaa 'vɩ 'nan 'e dra bɛ, e "naan -a -tʋ man -e 'e -tʋ yɩ "yi. Ɛn -te 'bɛ "cɛɛ dɩɛ, e kɔamlan -a -tʋ man, -e 'e -tʋ drɛ 'e 'pɛla koda. -A -tʋwli "nɛn "nyian 'cee vɛ -a, ka'a 'kɔlaman -e 'ka Bali 'lee "lala yɩ "yi 'e cin -a dɩ.»
\s1 Zozi -srunɔn yi -tɛala Bali da
\r (Lk 12.22-31)
\p 
\v 25 «-Yee "wɛan nɛn maan ve 'cɛɛ 'nan, te 'ka 'fʋ 'ka 'ci "nrɔnnan 'cee 'trɛda da dɩ! -Yɛɛ cɩ "le: ‹-Mɛ "nɛn kʋa -ble? -Mɛ "nɛn kʋa -mlian? Kʋa dra 'kɔ, -e 'kʋ 'man sɔnun yɩ?› 'Pian -a -cin 'e 'kɔn 'ka 'ji 'nan, 'belidɩ nɛn 'ka 'lɔ bɛ -a "yi "mlian -blɩfɛ da, ɛn 'ka 'kɔlɛ nɛn 'ka da bɛ, -a 'kpa "mlian sɔnun da.
\p 
\v 26 'Ka 'ci "nrɔn "lomannun da! Wa'a 'saa 'fɔa dɩ, ɛn wa'a 'saa 'tɛa dɩ, ɛn wa'a 'saa 'sɛan 'trɛbɔnun -ji dɩ. 'Pian 'ka "tɩ "nɛn laji bɛ e -blɩfɛ -nɔan -wlɛ. -A -cin 'e 'kɔn 'ka 'ji 'nan Bali 'lɛ bɛ 'ka "yi "mlian o da!
\v 27 'Cee ci "nrɔndɩ 'cee 'trɛda da bɛ, ya'a 'kɔlaman -e 'e yi -tʋwli "cɛ 'pa 'cee 'belidɩ da "fo "dɩ.
\p 
\v 28 Sɔnun nɛn 'kɔ ka 'wʋ 'ka man bɛ te 'ka 'ci "nrɔn -a 'wɩ 'a dɩ! Lunun nɛn 'o -fui -tɛa "lua bɛ, 'ka 'ci "nrɔn o da! Wa'a 'nyranman paa dɩ, ɛn wa'a 'nanwlɛ 'taan dɩ.
\v 29 'Pian maan ve 'cɛɛ 'nan, Salomɔn nɛn e ya mingɔnnɛn -dan tʋ a 'li bɛ, -yee sɔ -tʋ fɛnyian 'ka 'mlinlɛ lu -fuinun zɩɛ -a -tʋwli "le fɛnyian da dɩ.
\v 30 Lu -fui "nɛn 'bɛ cɩ lua, "trɛ wɛɛ "cɛan -e 'wɛɛ 'fɔ 'tɛ 'va bɛ, -te Bali 'bɛ 'man drɛvɛ wɛɛ fɛnyian zɩɛ bɛ, 'lɔɔ kaa "nun? 'Cee yi -tɛradɩ Bali da a "wɛnnɔn.
\p 
\v 31 -Yee "wɛan te 'ka 'fʋ 'ka 'ci "nrɔnnan -a laabʋdɩ -a 'nan: ‹-Mɛ "nɛn kʋa -ble? -Mɛ "nɛn kʋa -mlian? Kʋa dra 'kɔ, -e 'kʋ 'man sɔnun yɩ?›
\v 32 Ci "nrɔndɩ nun zɩɛ e ya minnun nɛn wa'a Bali tɔa dɩɛ, -wee vɛ -a. 'Ka "tɩ "nɛn laji bɛ yaa -tɔa 'nan fɛnun zɩɛ -a 'wɩ a 'ka man.
\v 33 'Ka -wɛɛ 'e tɛdɛ 'nan, Bali 'e mingɔnnɛn -blɩ 'ka da, ɛn 'ka -wɛɛ "nyian 'nan, 'ka Bali ci 'sɔ wɩ dra. "Bɛ -sru -e Bali 'e fɛ pɛɛnɔn zɩɛ -a drɛ 'cɛɛ.
\v 34 "Trɛ "tʋ 'lee 'e 'ci wɩ, ɛn yi -tʋ 'lee 'yee "koe "nyan. -Yee "wɛan te 'ka 'ci "nrɔn "trɛ "wɩ da dɩ!»
\c 7
\s1 Zozi -srunɔn 'ka min 'tɔ 'tɛa dɩ
\r (Lk 6.37, 38, 41-42)
\p 
\v 1 «Te 'ka min 'tɔ 'tɛ dɩ, "tɔgɔ tʋ nɛn Bali 'trɛdanɔn 'le 'wɩ tin "baa bɛ, 'e tin -tɛ 'ka da!
\v 2 Kɔɔ Bali 'cee tin "baa "le zɩ ka minnun -le vɛ 'pa bɛ -yee 'wɩ 'zʋ. Zɩ i 'wɩ dra 'i bɔɛzan -tʋ -va bɛ, -a da nɛn Bali "yie "dra.
\p 
\v 3 -Mɛ "le "wɛan nɛn i yiba -flunɛn ye 'i bɔɛzan -tʋ yiɛ -goei, te 'i 'bɔ 'le vɛ nɛn yiba -dan 'bɔ cɩ 'bɛ 'ji bɛ, yi'a 'bɛ 'ye dɩ?
\v 4 'I 'bɔ nɛn yiba -dan cɩ 'i 'yiɛ -goei "bɛ, -mɛ "le "wɛan nɛn "yiɛ "ve 'i bɔɛzan lɛ 'nan: ‹'I 'tɔ -e 'an yiba -flu 'si 'i 'yiɛ -goei!›
\v 5 -Blʋzan, 'i yiba -dan 'si 'i 'yiɛ -goei 'vaa, -e 'i fɛnan yɩ 'wein. "Bɛ -sru i -kɔlaman yiba -flu 'sidɩ -a 'i bɔɛzan -tʋ yiɛ -goei.
\p 
\v 6 Te 'ka Bali -le fɛnun -nɔn -plɛnnun lɛ dɩ, "tɔgɔ 'o li 'o da -e 'o 'ka 'wi "cɛɛn 'e cin man! Ɛn te 'ka 'cee -siga -fɔla 'srunun lɛ dɩ, "tɔgɔ 'o 'tran "da!»
\s1 Zozi -srunɔn Bali trʋ "baa 'nan 'e 'pa 'o 'va
\r (Lk 11.9-13)
\p 
\v 7 «'Ka fɛ trʋ 'ba, waa -nɔan 'cɛɛ! 'Ka fɛ -wɛɛ, kaa ye! 'Ka 'kɔn 'tɛ, waa 'lɛ "so 'cɛɛ!
\v 8 Kɔɔ min nɛn e fɛ trʋ "baa bɛ, waa -nɔan -yrɛ. Min nɛn e fɛ -wɛɛman bɛ, yaa ye. Ɛn min nɛn e 'kɔn -tɛa "bɛ, waa 'lɛ "so -yrɛ.
\p 
\v 9 Min -tʋ 'ka 'ka yei, -te 'yee 'nɛn -blɩfɛ trʋ 'ba -yrɔ, -e 'e 'kɔlɛ -nɔn -yrɛ "dɩ.
\v 10 Ɛn min -tʋ 'ka 'ka yei, -te -yee 'nɛn pɔ trʋ 'ba -yrɔ, -e 'e -mlɛn -nɔn -yrɛ "nyian dɩ.
\v 11 Ka ya -wlidɩ, 'pian ka fɛ "yi -tɔa -e 'ka -nɔn 'cee 'nɛnnun lɛ. 'Ka "tɩ "nɛn laji bɛ, -a ci "yi "mlian 'ka da, -yee "wɛan 'ka -tɔ 'nan, e fɛ "yi -nɔan minnun nɛn waa laabo -yrɔ "bɛ -wlɛ!
\p 
\v 12 'Wɩ pɛɛnɔn nɛn ka ya "va 'nan minnun 'o drɛ 'cɛɛ bɛ, -a 'wɩ 'bɔ -tʋwli zɩɛ -nyrɛn 'ka -wee "drɛ! 'Wɩ zɩɛ -a 'bɔ nɛn Moizi -le -pei -a 'vɩ 'nan blamin 'e drɛ. Ɛn -a -tʋwli "nɛn "nyian Bali 'lewei vɩnɔn -a 'vɩ 'nan blamin 'e drɛ.»
\s1 -Si nɛn min -a "siala -e 'e 'beli bɛ, e ya -tʋwli
\r (Lk 13.23-24)
\p 
\v 13 «'Kɔn -yrɛ "fɩɩnɛn bɛ -a -ji nɛn 'ka -wla -e 'ka 'belidɩ yɩ! Kɔɔ 'kɔn -yrɛ nɛn min -wlamlan 'ji, te -a 'le 'srannan "nɛn -kadɩ -a bɛ e ya -dan, ɛn -a -si a -gbagbla. -Si zɩɛ -a da ta wʋdɩ nɛn min "kaga -a ye "yi.
\v 14 'Pian 'kɔn -yrɛ nɛn min -wlamlan 'ji -e 'e 'belidɩ yɩ bɛ e ya "fɩɩnɔn, ɛn -a -si a "wɛnnɔn. -Yee "wɛan min "soglo 'nɛn 'bɛ 'ta wʋla "da.»
\s1 Yiba 'kpa 'lee yiba -wlidɩ
\r (Mt 12.33-35; Lk 6.43-44)
\p 
\v 15 «'Ka yiɛ 'tɔ 'ka 'fli -va, minnun nɛn waa ve 'nan Bali 'lewei vɩnɔn nɛn waa, 'pian te o 'ka 'a dɩɛ -wee "wɛan. 'O 'fli dra 'ka yei "le 'blanun -le 'wɩ 'zʋ, "tɔgɔ te plɔ winun nɛn waa.
\v 16 O drɛ wɩnun man nɛn ka o -kɔnnɛn "ye. Kɔɔ kaa -tɔa 'nan wa'a -lomin naan -tɛin "man dɩ, ɛn wa'a -wɛn bɛwlɛ 'naan "trɔɛn 'fɔn lei man dɩ.
\v 17 Yiba "nɛn e ya 'kpa bɛ -a 'blʋ a "yi, ɛn yiba "nɛn e ya -wlidɩ "bɛ -a 'blʋ a -wlidɩ.
\v 18 Yiba "nɛn e ya 'kpa bɛ -a 'blʋ 'ka 'wlidɩ "dɩ, ɛn yiba "nɛn e ya -wlidɩ "bɛ -a 'blʋ 'ka "yi "dɩ.
\v 19 Yiba "nɛn e baa te -a 'blʋ 'ka "yi "dɩɛ, waa "cɛan -e 'o 'fɔ 'tɛa.
\v 20 -Yee "wɛan minnun zɩɛ, o drɛ wɩnun man nɛn 'ka -taa "o -tɔlɛ.»
\s1 Zozi -srunɔn tɩglɩ
\r (Lk 6.46; 13.27)
\p 
\v 21 «'An laabʋdɩ Minsan, Minsan bɛ, -a 'saza 'ka 'ko min -a Bali -le mingɔnnɛn trɛda dɩ. 'Pian min nɛn yaan "tɩ "nɛn laji bɛ -a ci 'sɔ wɩ dra bɛ, -yɛɛ ko -nan nun.
\v 22 Yi nɛn an 'trɛdanɔn 'le tin "baa bɛ, min "kaga -taa -a vɩlɛ 'mɛn 'nan: ‹Minsan, Minsan! Kʋ Bali 'lewei 'vɩ 'i 'tɔ da, ɛn kʋ -yʋ -wlidɩ "pin minnun -sru 'i 'tɔ da, ɛn kʋ 'lɛbo "fɔ wɩnun drɛ 'i 'tɔ da.›
\v 23 'Pian maan ve -wlɛ 'nan: ‹Ma'an 'ka 'tɔa "fo "dɩ, 'ka 'si 'an "srɔn "kɔɔbli, ka ya 'wɩ 'wlidɩ "drɛnɔn 'a.›
\p 
\v 24 -Yee "wɛan nɛn, 'wɩnun nɛn maan ve 'cɛɛ 'gʋɛ, -te min nɛn yaa 'man, ɛn yaa ta 'ta 'wʋ bɛ, te -a san a "le 'nan 'wɩ 'tɔzan nɛn e 'yee 'kɔn -klu cɛɛn 'e trʋdɩ, ɛn yaa -pʋ -fɔ 'plɛblɛ bɛ, -yee 'wɩ 'zʋ.
\v 25 Fulɔ fɛɛn, ɛn laa 'fɛn, ɛn 'yi yrʋ, -a pɛɛnɔn -sɛn 'kɔn zɩɛ -a man, ɛn ya'a 'wilɛ dɩ, e ya 'e 'tɔdɩ -kli -le "wɛan.
\v 26 'Pian min nɛn e 'wɩnun nɛn maan ve 'gʋɛ -a 'man, ɛn ya'a 'ta wʋlɛ "da "dɩɛ, -a san a "le 'nan -blʋzan nɛn e 'yee 'kɔn 'tɔ nyrɛn va bɛ, -yee 'wɩ 'zʋ.
\v 27 Fulɔ fɛɛn, ɛn laa 'fɛn, ɛn 'yi yrʋ, -a pɛɛnɔn -sɛn 'kɔn zɩɛ -a man, ɛn e wiila 'nan "fo.»
\p 
\v 28 Zɩ Zozi cɛɛn 'wɩnun zɩɛ -a vɩdɩ man bɛ, -yee 'wɩ "paadɩ minnun pɛɛnɔn zɩɛ o 'kan,
\v 29 kɔɔ -yee 'wɩ "paadɩ 'ka "le 'fluba 'ci vɩnɔn 'le vɛ zʋ dɩ. 'Pian yaa "paaman "le min nɛn Bali -kɔladɩ -nɔn -yrɛ "bɛ, -yee 'wɩ 'zʋ.
\c 8
\s1 Zozi -kogobe 'tɛzan -tʋ beli
\r (Mk 1.40-44; Lk 5.12-14)
\p 
\v 1 Zɩ Zozi 'si pɔn da bɛ, ɛn min "kaga sɔɔnla -a -sru.
\v 2 -A -nan nɛn -kogobe 'tɛzan -tʋ pli "man, e "po sɔɔn "wlu, ɛn e -yrɛ 'nan: «Minsan, maan -tɔa 'nan, -te i wɩɩ "man "bɛ, i -kɔlaman i -kogobe "sia 'an man, -e 'an drɛ 'saun Bali 'lɛ.»
\p 
\v 3 Zozi 'e 'pɛ 'sʋ "ji, e klɛ "man, ɛn e -yrɛ 'nan: «An "we "man, 'I drɛ 'saun Bali 'lɛ!» 'Nun tɔɔn -kogobe 'bɔ 'si "man, ɛn e drɛ 'saun Bali 'lɛ.
\p 
\v 4 -A -nan nɛn Zozi "e -yrɛ 'nan: «Te 'i -nan sɛɛ wʋ min -tʋ lɛ 'mlɔnmlɔn dɩ! 'Pian 'i 'kʋ Bali -panzan -tʋ -va, -e 'yei 'nanjɛn! "Bɛ -sru -e 'i 'sraga bʋ Bali lɛ, "le zɩ Moizi -a crɛn -tɛ Bali -le 'fluba 'ji bɛ -yee 'wɩ 'zʋ. Tɔɔn -e minnun pɛɛnɔn 'o -kɔnnɛn "yɩ 'nan i beli.»
\s1 Rɔm min nɛn 'sounjanun tazan 'a bɛ, e pli Zozi man
\r (Lk 7.1-10; Zan 4.46-54)
\p 
\v 5 Zozi Kapanamo si 'sia. Zɩ e 'bɔla 'fla zɩɛ -a da bɛ, ɛn 'sounjanun tazan -tʋ pli "man. Yaa trʋ 'ba
\v 6 -a vɩdɩ -a 'nan: «Minsan, 'yian 'suzan 'beli! -Cɛ -fɔ "man, ɛn e -sran "tra. E ya 'e nyinnandɩ "kɔnnɛn, ɛn e ya 'e yra yɩnan -wlidɩ.»
\p 
\v 7 Zozi "e -yrɛ 'nan: «An "ta "lo, -e 'an -cɛ 'si "man.»
\p 
\v 8 Ɛn 'sounjanun tazan "e -yrɛ 'nan: «Minsan, an 'ka min nɛn i -wlamlan -yee 'kuin bɛ -a dɩ, kɔɔ Zuif min "cɛɛ man dɩ. 'Pian 'i 'wɩ 'tʋ vɩ, -e 'an 'suzan 'e 'beli.
\v 9 'An 'bɔ 'gʋɛ, 'an 'tanɔn 'bɛ 'an "paala, ɛn 'mɛn 'sounjanun bɛ mɛɛn 'o "paala. -Te maan 'vɩ -a -tʋ lɛ 'nan: ‹'I 'kʋ›, -e 'e 'kʋ. Ɛn -te maan 'vɩ -a pee lɛ 'nan: ‹'I 'ta›, -e 'e 'ta. Ɛn -te maan 'vɩ 'mɛn nɔan lɛ 'nan: ‹'I 'wɩ 'gʋɛ -a drɛ bɛ›, yaa dra.»
\p 
\v 10 Zɩ Zozi 'wɩnun zɩɛ -a 'man bɛ, 'wɩ -a 'kan, ɛn minnun nɛn -a -sru "bɛ, e -wlɛ 'nan: «An 'wɩ tɩglɩ ve 'cɛɛ! Ma'an tian min -tʋ yɩlɛ Izraɛl 'nɔn 'va, te e yi -tɛala 'an da tɩglɩ zɩɛ dɩ.
\v 11 Maan 'lɛ "cɛan 'cɛɛ 'nan, min "kaga "sia yidɛ wluan "nan 'lee yidɛ 'fɔ -nan "va, o -taa -e 'o "fɛdi -blɩ Bali fla 'o 'vale Abraam 'lee Izak 'lee Zago nun -a.
\v 12 'Pian minnun nɛn Bali o 'si "va 'e tɛdɛ 'yee mingɔnnɛn trɛdavɛ -a bɛ, Izraɛl 'nɔn nɛn. Bali -taa -wee 'tu wʋlɛ klun va bei. Fɛnan nɛn -wuɔdɩ 'lee 'shɛ da -blɩdɩ cɩ bɛ -a -nan.»
\p 
\v 13 Tɔɔn Zozi "e 'sounjanun tazan zɩɛ -yrɛ 'nan: «'I 'kʋ 'yie "kɔnnɛn. 'Wɩ nɛn, i yi -tɛra "da "bɛ 'e 'lɛ sɔɔ 'yiɛ!» Tʋ 'bɔ 'lein zɩɛ -a wlu nɛn 'sounjanun tazan 'suzan bɛ, e beli.
\s1 Zozi Piɛri 'sɛa 'lee -cɛ -tɛnɔn "kaga beli
\r (Mk 1.29-34; Lk 4.38-41)
\p 
\v 14 "Bɛ -sru ɛn Zozi 'kʋ Piɛri -le "kɔnnɛn. Yaa nan "bʋ 'yɩ 'e nyinnandɩ 'kɔlɛ 'tɔndɔn 'lɔ.
\v 15 E klɛ -a -pɛla man, ɛn -a 'kɔlɛ 'ji 'e 'trɔ -fɔ. 'Nun tɔɔn lɩ zɩɛ e wluan lou, ɛn e fɛ -nɔn -yrɛ.
\p 
\v 16 Zɩ funninmlan 'pla bɛ, ɛn minnun -ta minnun nɛn -yʋ -wlidɩnun cɩ o -sru "bɛ o "kaga "a Zozi lɛ. Yaa 'vɩ -yʋ -wlidɩnun lɛ 'nan, 'o 'si minnun -sru, ɛn e -cɛ -tɛnɔn pɛɛnɔn beli.
\v 17 'Wɩ nɛn Bali 'lewei vɩzan Ezai -a 'vɩ 'e 'cɛn bɛ, zɩ e 'lɛ sɔɔ zɩɛ. Kɔɔ yaa 'vɩ 'nan:
\q1 «E 'kʋe yra yɩdɩ 'si 'kʋ man,
\q1 ɛn e 'kʋ 'man -cɛ pɛɛnɔn 'si 'kʋ man.»
\s1 Zozi -sru 'ta wʋdɩ
\r (Lk 9.57-60)
\p 
\v 18 Zɩ Zozi min "kaga 'yɩ 'e "srɔn "bɛ, ɛn yaa 'vɩ 'e -srunɔn lɛ 'nan: «-Kaa kʋ 'yi -sru.»
\v 19 -A -nan nɛn 'fluba 'ci vɩzan -tʋ pli "man, ɛn yaa 'vɩ Zozi lɛ 'nan: «Bali -le 'wɩ "paazan, fɛnan pɛɛnɔn nɛn i -ko bɛ, kʋɛ 'ko 'yia.»
\p 
\v 20 Ɛn Zozi "e -yrɛ 'nan: «-Canjannɛnnun nyinnan a, ɛn "lomannun "kɔɛ "a, 'pian Blamin -pɩ "le "fɛ -tʋ -nan "ka -e 'e 'wulo 'pla 'nan dɩ.»
\p 
\v 21 Ɛn -a -sruzan 'pee -a 'vɩ -yrɛ 'nan: «Minsan, 'i 'si -nɔn 'mɛn -e 'an 'kʋ 'an "tɩ "wʋ 'vaa, -e 'an 'ta.»
\p 
\v 22 Zozi "e 'vɩ -yrɛ 'pian 'nan: «'I -sɔɔnla 'an -sru! Minnun nɛn Bali "le 'va o cɩ 'o 'kadɩ bɛ, 'i o 'tʋɩ 'o 'wee min wʋ.»
\s1 Zozi fulɔ 'plɛblɛ 'tʋ ta -tɔ
\r (Mk 4.35-41; Lk 8.22-25)
\p 
\v 23 Zozi 'fɔ -klʋ -ji 'o 'vale 'e -srunɔn 'a, ɛn o -kʋdɩ 'sia.
\v 24 Tɔɔn fulɔ 'plɛblɛ 'tʋ "fɛɛndɩ 'sia 'yi zɩɛ -a yiɛ da, ɛn 'yi 'sɛndɩ 'sia -klʋ -ji. Tʋ zɩɛ -a wlu bɛ, te Zozi "e "yi -tɛa.
\v 25 -A -nan nɛn -a -srunɔn pli "man, waa fuʋ, ɛn o -yrɛ 'nan: «Minsan, 'i 'pa 'kʋ 'va, 'kʋ 'nan "ta -nyaan!»
\p 
\v 26 Ɛn Zozi "e -wlɛ 'nan: «-Mɛ "klan 'bɛ 'ka -tɛa? 'Cee yi -tɛradɩ Bali da a "wɛnnɔn!» -A -nan nɛn e wluan, ɛn e paan fulɔ 'lee 'yi da 'plɛblɛ. Tɔɔn fɛnan -tɔ flɩɩ.
\p 
\v 27 'Wɩ zɩɛ e minnun pɛɛnɔn 'kan, ɛn waa laabʋ 'nan: «-Mɛ "sʋ -man min 'bɛ cɩ zɩɛ, ɛn 'bɛ 'wɩ tin "baa fulɔ 'lee 'yi lɛ -e 'o drɛla "da.»
\s1 Zozi 'yʋ -wlidɩ "pin min "fli -sru Gadara 'lɛglɔn 'ji
\r (Mk 5.1-20; Lk 8.26-39)
\p 
\v 28 Zɩ Zozi 'bɔla 'yi -sru Gadara 'lɛglɔn 'ji bɛ, ɛn min "fli "nɛn -yʋ -wlidɩnun cɩ o -sru "bɛ, o -ta -a 'lɛ. Min -yrɛ nɛn waa bo -kɔlɛ -ji bɛ -a -mie ji nɛn o nyian. O nyran wo -wlidɩ "le "wɛan, min -tʋ 'ka 'ciala fɛ zɩɛ -a -nan dɩ.
\v 29 Tɔɔn o -paandɩ 'sia 'nan: «Bali -pɩ! -Mɛ "nɛn 'yie 'nan 'e dra 'kʋɛ? I -ta 'tɛ 'palɛ 'kʋ da 'va? Tʋ nɛn Bali -a kɔɔn bɛ ya'a tian bɔlɛ dɩ.»
\p 
\v 30 Tʋ zɩɛ -a wlu bɛ te 'sru 'pa 'tʋ a 'e 'blɩnan. 'Srunun 'bɔ 'ka o man -kɔɔbli dɩ.
\v 31 Ɛn -yʋ -wlidɩnun toba -fɔ Zozi lɛ. Waa 'vɩ -yrɛ 'nan: «-Te i 'kʋ 'pin bɛ, 'i 'kʋ 'pa 'sia 'sru 'pa 'labɛ -a va.»
\p 
\v 32 Zozi "e -wlɛ 'nan: «'Ka 'kʋ!» Tɔɔn o 'si min "fli zɩɛ o -sru, ɛn o -fɔ 'srunun -sru. 'Sru 'pa 'tʋ zɩɛ, o flan 'sia pɔn 'sɛan man zia, o -sɛn 'yia. Ɛn o pɛɛnɔn kaa "fo.
\v 33 Minnun nɛn o 'srunun 'bɔ 'ta -pian "bɛ, "o "sɛn 'wʋ 'ji flan -a. O 'bɔla 'ji 'fla, ɛn 'wɩ nɛn e drɛ o yiɛ man bɛ, 'lee 'wɩ nɛn e drɛ minnun nɛn -yʋ -wlidɩnun "cɩ o -sru "bɛ -wlɛ "bɛ, waa -nan 'sinan 'pa.
\v 34 Ɛn 'flanɔn pɛɛnɔn 'kʋ Zozi 'lɛ. Zɩ waa 'yɩ bɛ, ɛn o toba -fɔ -yrɛ 'nan, 'e 'si 'wee 'lɛglɔn 'ji.
\c 9
\s1 Zozi min -srandɩ "tra "tʋ beli
\r (Mk 2.1-12; Lk 5.17-25)
\p 
\v 1 -A -nan nɛn Zozi 'fɔ -klʋ -ji "nyian, e 'yi cɛɛn, ɛn e 'bɔla Kapanamo. 'Fla zɩɛ -a da nɛn e -nyɛanla.
\v 2 Tɔɔn minnun -ta min -tʋ nɛn e -sran "tra "bɛ -a -yrɛ "se "ji. Zɩ Zozi -wee yi -tɛradɩ 'e da 'yɩ bɛ, ɛn e 'nan min -srandɩ "tra zɩɛ -yrɛ 'nan: «'An bee, nyɛn 'e 'si 'i 'ji! 'Wɩnun nɛn yia drɛ 'wlidɩ "bɛ, maan fui!»
\p 
\v 3 'Wɩ zɩɛ -a da nɛn 'fluba 'ci vɩnɔn -mienun -a 'vɩ 'o 'ji 'nan: «Min 'labɛ, e Bali srɔn!»
\p 
\v 4 Zɩ Zozi -wee ci "nrɔndɩ 'yɩ bɛ, ɛn yaa laabʋ -wlɔ 'nan: «-Mɛ "le "wɛan nɛn ci "nrɔndɩ -wlidɩ zɩɛ, e ya 'ka 'ji?
\v 5 -Te maan 'vɩ -yrɛ 'nan: ‹'Wɩnun nɛn yia drɛ 'wlidɩ "bɛ, maan fui›, 'bɛ a -tʋ. Ɛn -te maan 'vɩ -yrɛ 'nan: ‹'I 'wluan, 'i 'tɔ lou, 'i 'ta wʋ›, 'bɛ a -tʋ. 'Wɩ "fli zɩɛ -a "cɛn "vɩdɩ 'bɛ cɩ 'plɛblɛ?
\v 6 'Pian an "ta -a -ci -kɔɔnman 'cɛɛ 'nan, Bali -kɔladɩ -nɔn Blamin -pɩ lɛ, -e 'e min -le 'wɩ -wlidɩnun fui 'trɛda.» -A -nan nɛn yaa 'vɩ min -srandɩ "tra zɩɛ -yrɛ 'nan: «'I 'wluan! 'I 'yie nyinnan "davɛ 'sia! 'I 'kʋ 'yie "kɔnnɛn!»
\p 
\v 7 'Nun tɔɔn e wluan lou, ɛn e 'yee "kɔnnɛn "si 'sia.
\v 8 Zɩ min "kaga 'wɩ zɩɛ -a -nan 'yɩ bɛ, "klan -sɛn o ji, ɛn o Bali 'tɔ bɔdɩ 'sia, kɔɔ e -kɔladɩ zɩɛ -a -nɔn blamin lɛ.
\s1 Zozi Matie laabʋ
\r (Mk 2.13-17; Lk 5.27-32)
\p 
\v 9 Zozi 'si fɛ zɩɛ -a -nan. "Yɛɛ -kʋ 'e 'lɛ bɛ, ɛn e min -tʋ nɛn waa laabo Matie bɛ -a 'yɩ. 'Sukɔlɛ 'sizan nɛn, ɛn e ya 'yee 'nyranman 'bɔ zɩɛ -a 'panan. Ɛn Zozi "e -yrɛ 'nan: «'I -sɔɔnla 'an -sru!» Matie wluan, ɛn e sɔɔnla -a -sru.
\p 
\v 10 "Bɛ -sru Zozi 'lee 'e -srunɔn a 'o -nyrandɩ -blɩfɛ -sru 'kuin. Ɛn 'sukɔlɛ 'sinɔn "kaga 'lee 'wɩ 'wlidɩ "drɛnɔn 'ta, o -nyran fɛ -sru o va.
\v 11 Zɩ Farizɛn 'nɔn -a -nan 'yɩ bɛ, ɛn waa laabʋ Zozi -srunɔn lɔ 'nan: «-Mɛ "le "wɛan nɛn 'ka 'san fɛ -ble 'o 'vale 'sukɔlɛ 'sinɔn 'lee 'wɩ 'wlidɩ "drɛnɔn 'a?»
\p 
\v 12 Zozi 'wɩ zɩɛ -a 'man, ɛn e 'nan Farizɛn 'nɔn lɛ 'nan: «Minnun nɛn -cɛ 'ka o man dɩɛ, wa'a -dɔdrɔ -sru -wɛɛman dɩ. 'Pian minnun nɛn -cɛ cɩ o man bɛ, -wɛɛ -dɔdrɔ -sru -wɛɛman.
\v 13 'Ka 'ci "nrɔn 'wɩ nɛn Bali -a 'vɩ bɛ -a da. E 'nan:
\q1 ‹Min nyrinda 'e 'sɛn 'ka da!›
\m 'Bɛ cɩ 'wɩ "yi "a, 'pian 'sraga bʋdɩ bɛ 'bɛ a 'e "tun. 'Ka -wɛɛ 'nan 'ka 'wɩ zɩɛ -a -ci maan 'kpa! 'Wɩ 'bɔ zɩɛ -yee "wɛan nɛn an -ta. An -ta 'nan -e 'an 'wɩ 'wlidɩ "drɛnɔn laabʋ, -e 'o 'si 'wɩ 'ji. Ma'an 'talɛ minnun nɛn o cɩ tɩglɩ bɛ -wee "wɛan dɩ.»
\s1 Zozi 'le 'wɩ "paadɩ a "le fɛ -trɛ -le 'wɩ 'zʋ
\r (Mk 2.18-22; Lk 5.33-39)
\p 
\v 14 "Bɛ -sru Zan -srunɔn 'ta Zozi 'va, ɛn waa laabʋ -yrɔ 'nan: «-Mɛ "wɛan nɛn 'kʋ 'vale Farizɛn 'nɔn 'a, kʋ fɛ "sɔan, te 'i -srunɔn 'ka "o "fɛ sɔan dʋʋ?»
\p 
\v 15 Ɛn Zozi "e -wlɛ 'nan: «-Te minnun a lɩ 'pa "fɛdi drɛnan bɛ, tʋ nɛn lɩ -trɛ 'pazan a o yei "bɛ, o man 'ka 'kɔan 'yuo dɩ. 'Pian tʋ nɛn e 'ka "nyian o yei "dɩɛ, -a -nan nɛn o -kɔlaman o fɛ "sɔan.
\p 
\v 16 Ɛn "nyian bɛ, -a -cin 'e 'tɔ 'ka 'ji 'nan, wa'a sɔ -trɛ 'fʋɩ 'sia -e 'o 'pa sɔ ceje 'fʋɩ bʋnan dɩ. -Te 'bɛ "cɛɛ dɩɛ, sɔ -trɛ zɩɛ e sɔ ceje 'fʋɩ bʋnan "paa "va te e srɛ.
\v 17 Wa'a 'wɛn -trɛ sɛan -wi 'kɔlɛ tre cejenun -ji dɩ. -Te 'bɛ "cɛɛ dɩɛ -wi 'kɔlɛ tre cejenun fɛaman, -e -wɛn 'e 'sran, te 'o srɛ. 'Pian o -wɛn -trɛ -sɛan -wi 'kɔlɛ tre 'trɛnun -ji, -e -wɛn 'lee -wi 'kɔlɛ 'trenun 'o vɩlɛ 'e srɛ dɩ.»
\s1 'Plɛblɛ a Zozi 'lɔ fɛ pɛɛnɔn da
\r (Mk 5.21-43; Lk 8.40-56)
\p 
\v 18 Zozi a 'wɩnun zɩɛ -a vɩnan -wlɛ, tɔɔn ɛn min tazan -tʋ -ta. E "po sɔɔn "wlu, ɛn e -yrɛ 'nan: «'An 'lu "sia -kanan 'nun -naagʋ. 'Pian 'i yra 'si, 'i 'ta 'i 'pɛ 'pla "da, -e 'e 'fuʋ!»
\v 19 Zozi wluan, ɛn e sɔɔnla -a -sru 'o 'vale 'e -srunɔn 'a.
\p 
\v 20 Tɔɔn lɩmɔn -tʋ nɛn nyɛn -sɛanla "man -a -nan lɛ -fuda "fli 'bɔ, te ya'a 'nyan dɩɛ, e pli Zozi man 'e koda zia, ɛn e klɛ -yee sɔ 'lɛbo "man.
\v 21 Kɔɔ yaa 'vɩ 'e 'ji 'nan: «-Te an -kɔla an klɛ 'e "tun -yee sɔ man bɛ an "belia.»
\p 
\v 22 Zozi 'e 'man lila, yaa 'yɩ, ɛn e -yrɛ 'nan: «'An 'lu, nyɛn 'e 'si 'i 'ji! 'Yie yi -tɛradɩ 'an da 'i beli.» 'Nun tɔɔn lɩmɔn zɩɛ e beli.
\p 
\v 23 Zɩ Zozi 'bɔla min tazan zɩɛ -yee "kɔnnɛn "bɛ, e 'bei 'fɛnnɔn 'lee min "kaga 'yɩ. O -ta -wuɔlɛ -cɛda.
\v 24 Ɛn e -wlɛ 'nan: «'Ka bɔla! Nɔnbɛ 'labɛ ya'a 'kalɛ dɩ, 'pian e ya yi -tɛnan.» Ɛn waa sɛɛ wʋdɩ 'sia.
\v 25 Zɩ o cɛɛn minnun bɔɔladɩ man bɛ, ɛn Zozi wlala, e nɔnbɛ zɩɛ -a 'kun 'e 'pɛ man, ɛn nɔnbɛ 'bɔ wluan lou.
\v 26 'Wɩ zɩɛ e fuila "man 'lɛglɔn pɛɛnɔn 'ji.
\s1 Zozi yiɛ 'winɔn "fli "beli
\p 
\v 27 Zɩ Zozi 'si fɛ zɩɛ -a -nan bɛ, ɛn yiɛ 'winɔn "fli sɔɔnla -a -sru -paandɩ -a. O -paanman 'nan: «David kluda min Zozi, 'kʋ nyrinda 'e 'sɛn 'i da!»
\p 
\v 28 Zɩ e 'bɔla "kɔnnɛn "bɛ, ɛn yiɛ 'winɔn 'bɔ pli "man. Zozi 'a laabʋ -wlɔ 'nan: «Ka yi -tɛala "da 'nan, an -kɔlaman 'padɩ -a 'ka 'va?»
\p Ɛn waa wun -fɔ -yrɛ 'nan: «-Inyan, Minsan!»
\p 
\v 29 -A -nan nɛn 'e 'pɛ klɛ o yiɛ man, ɛn e 'nan -wlɛ 'nan: «'Wɩ nɛn ka yi -tɛra "da "bɛ, 'e 'lɛ sɔɔ 'cɛɛ.»
\v 30 Ɛn o yiɛ 'lɛ 'sʋ. Zozi 'wɩ 'pla -wlɛ, yaa 'vɩ -wlɛ 'nan: «Te 'ka -nan sɛɛ wʋ min lɛ dɩ.»
\v 31 'Pian o -kʋ, ɛn waa 'sinan 'pa 'lɛglɔn pɛɛnɔn 'ji.
\s1 Zozi bobo -tʋ beli
\r (Lk 11.14-15)
\p 
\v 32 Zɩ min "fli zɩɛ o -kʋ bɛ, ɛn minnun -ta min -tʋ nɛn -yʋ -wlidɩ -a drɛ bobo -a bɛ -a Zozi lɛ.
\v 33 Zozi -yʋ -wlidɩ zɩɛ -a -pin -a -sru, ɛn e 'wɩdɩ 'sia. 'Wɩ zɩɛ e minnun 'lɛbo "fɔ, ɛn waa vɩdɩ 'sia 'nan: «Kʋ'a tian 'wɩ 'gʋɛ -a tɛdɛ -nan yɩlɛ Izraɛl 'lɛglɔn 'ji 'mlɔnmlɔn dɩ.»
\p 
\v 34 'Pian Farizɛn 'nɔn "o 'vɩ 'nan: «-Yʋnun tazan -le 'plɛblɛ 'a nɛn e -yʋnun -pian "minnun -sru.»
\s1 Minnun nyrinda -sɛn Zozi da
\r (Mk 6.34; Lk 10.2)
\p 
\v 35 Zozi ciɩ 'fla -dandannun 'lee 'fla "wɛnnɛnnun pɛɛnɔn da. E 'wɩ paa minnun ji -wee cin yɩ 'kɔnnun -ji. E 'wɩ 'nɔnnɔn 'vɩ -wlɛ 'nan, Bali -le mingɔnnɛn -blɩdɩ 'bɔ -kogo. Minnun pɛɛnɔn nɛn -cɛ cɩ o man 'lee minnun pɛɛnɔn nɛn o man "yaaman bɛ, e 'o 'beli.
\v 36 Zɩ e minnun 'yɩ "kaga "bɛ, ɛn o nyrinda -sɛn "da. Kɔɔ e o 'yɩ bɛ, o "koe 'ka 'o da dɩ, ɛn o ya 'fogo 'fogo "le 'blanun nɛn o -sru "pinzan "ka -e 'e o 'lɛ bʋ tɩglɩ dɩɛ -wee 'wɩ 'zʋ.
\v 37 -A -nan nɛn yaa 'vɩ 'e -srunɔn lɛ 'nan: «'Saa 'bɛ tran "kaga "bɛ, 'pian -a -tɛnɔn a "wɛnnɔn.
\v 38 -Yee "wɛan 'ka Minsan nɛn fei zɩɛ e cɩ -yee vɛ -a bɛ -a trʋ 'ba 'nan, 'e -a -tɛnɔn 'pa 'sia -e 'o -yee 'saa bɛ -a -tɛ!»
\c 10
\s1 Zozi minnun 'si "va 'yee 'pasianɔn 'a
\r (Mk 3.13-19; Lk 6.12-16)
\p 
\v 1 Zozi 'e -srunɔn 'fuda "fli "bɛ o cin 'yɩ, ɛn e -kɔladɩ -nɔn -wlɛ 'nan, 'o -yʋ -wlidɩnun -pin minnun -sru, ɛn "nyian 'o minnun pɛɛnɔn nɛn -cɛ cɩ o man 'lee minnun pɛɛnɔn nɛn o man "yaaman bɛ o 'beli.
\p 
\v 2 Min -fuda "fli "nɛn Zozi o 'si "va 'yee 'pasianɔn 'a bɛ, o 'tɔ nɛn 'gʋ: Simɔn nɛn waa laabo "nyian Piɛri bɛ, 'lee 'e "bʋɩ Andre, 'lee Zebede -pɩ Zaji 'lee 'e "bʋɩ Zan,
\v 3 'lee Filipʋ, 'lee Batelemi, 'lee Toma, 'lee Matie nɛn e ya 'e tɛdɛ 'sukɔlɛ 'sizan 'a bɛ, 'lee Alife -pɩ Zaji, 'lee Tade,
\v 4 'lee Simɔn -tʋ nɛn waa laabo "nyian Zelo bɛ, 'lee Zudazi Karioti. Min nɛn e "ta -daa Zozi 'nɔnlɛ 'e 'nanmannɔn lɛ bɛ, -nyrɛn. Minnun zɩɛ o 'bɔ nɛn Zozi o 'si "va 'yee 'pasianɔn 'a.
\s1 'Wɩ nɛn kɔ Zozi 'le 'pasianɔn 'o drɛ bɛ Zozi -a 'vɩ -wlɛ
\r (Mk 6.7-13; Lk 9.2-6)
\p 
\v 5 Min -fuda "fli zɩɛ, o nɛn Zozi o 'pa 'sia. 'Wɩ nɛn yaa 'pla -wlɛ 'vaa, ɛn e o 'pa 'sia bɛ -nyrɛn 'gʋ. E -wlɛ 'nan: «Te 'ka 'kʋ minnun nɛn o 'ka Zuif 'nɔn 'a dɩɛ o va dɩ! Ɛn te 'ka 'kʋ Samari 'nɔn 'le 'flanun da dɩ!
\v 6 'Ka 'kʋ 'pian Izraɛl 'nɔn 'va. -Wɛɛ cɩ 'blanun nɛn o 'san bɛ waa!
\v 7 'Ka 'kʋ Bali -le 'wɩ vɩ -wlɛ! 'Ka vɩ -wlɛ 'nan: ‹Bali -le mingɔnnɛn -blɩdɩ 'bɔ 'kogo.›
\v 8 Minnun nɛn 'cɛ cɩ o man bɛ, 'ka o 'beli! Minnun nɛn o -ka bɛ, 'ka o 'fuʋ! 'Ka 'kogobe 'si minnun man -e 'o drɛ 'saun Bali 'lɛ! 'Ka 'yʋ -wlidɩnun -pin minnun -sru! 'Ka 'wɩ pɛɛnɔn zɩɛ -a drɛ minnun lɛ 'e "tun! Te 'ka fɛ -tʋ 'si "man "dɩ, kɔɔ an 'plɛblɛ zɩɛ -a -nɔn 'cɛɛ 'e "tun.
\v 9 Te 'ka -siga 'lee "lala 'sia 'ka -tiɛn "ji dɩ!
\v 10 Te 'ka 'pada 'sia dɩ! Ɛn te 'ka 'tralɛ 'sia "fli "dɩ! Te 'ka 'manwua pee 'sia dɩ! Ɛn te 'ka "tonyrin pee 'sia dɩ! Kɔɔ -a -nɔan da nɛn -e 'nyranman 'pazan 'e 'yee -pan yɩ.
\p 
\v 11 -Te 'fla -dan da nɛn ka 'bɔla oo, -te 'fla "wɛnnɛn da nɛn ka 'bɔla oo, min nɛn e ya 'fla zɩɛ -a da, e "we "man -e 'e 'ka 'pɛ 'kun bɛ, -a 'bɔ nɛn 'ka -wɛɛ. 'Ka 'fʋ -a san va -trilii -e 'cee -kʋ yi 'e bɔ.
\v 12 -Te ka wla 'kɔn 'tʋ -ji bɛ, 'ka 'kɔn zɩɛ -a -ji 'nɔn 'tɔ bʋ!
\v 13 -Te 'kɔn zɩɛ -a -ji 'nɔn 'ka 'pɛ 'kun bɛ, 'cee -fɛa 'e 'fʋdɩ -trɔɔ -nɔn -wlɛ. 'Pian -te wa'a 'ka 'pɛ 'kunlɛ dɩɛ, 'cee -fɛa "nɛn 'e 'fʋ 'e "tun.
\v 14 Minnun nɛn wa'a 'ka 'pɛ 'kunlɛ dɩ, ɛn wa'a o "trɔɛn "tɔlɛ 'ka 'wei lɛ dɩɛ, 'ka 'pɛ 'e 'si -wee 'wɩ 'ji -e 'ka 'si 'o fla, -te 'bɛ "cɛɛ dɩɛ, 'ka 'si 'wee "kɔnnɛn -e 'ka 'kʋ!
\v 15 Maan ve 'cɛɛ 'wɩ tɩglɩ 'a 'nan, yi nɛn Bali minnun -le tin "baa bɛ, 'fla zɩɛ -a da 'nɔn 'o yra ye 'plɛblɛ. E "mlian Sodɔm 'nɔn 'lee Gomɔr 'nɔn 'le yra yɩdɩ da.»
\s1 Minnun -taa 'tɛ 'palɛ Zozi 'le 'pasianɔn da
\r (Mk 13.9-13; Lk 12.11-19; 21.12-19)
\p 
\v 16 «'Ka "trɔɛn "tɔ 'wɩ 'gʋɛ -yrɛ! An "ta 'ka "paa -sia 'trɛdanɔn 'va, 'pian ka ya o yei "le 'nan 'blanun nɛn plɔ winun yei "bɛ -wee 'wɩ 'zʋ. -Yee "wɛan 'wɩ 'tɔdɩ -a nɛn 'ka 'ta wʋ o yei, ɛn 'ka 'kɔn o va -trɔɔ.
\v 17 'Pian 'ka yiɛ 'tɔ 'ka 'fli -va minnun -le "wɛan! Kɔɔ o -taa 'ka -nɔnlɛ tin 'banɔn lɛ, -e 'o 'ka 'sɔn -ngble -a Zuif 'nɔn 'le cin yɩ 'kɔnnun -ji.
\v 18 'Mɛn "wɛan o -ko 'ka 'a -kɔnmandannun 'lɛ, ɛn o -ko 'ka 'a mingɔnnɛnnun 'lɛ. Fɛ zɩɛ -a -nan nɛn ka 'mɛn 'wɩ 'nɔnnɔn vɩ. Ka dra 'mɛn 'wɩ 'nan yɩnɔn 'a o 'lɛ, ɛn ka dra "nyian 'mɛn 'wɩ 'nan yɩnɔn 'a minnun o 'ka Zuif 'nɔn 'a dɩɛ o 'lɛ.
\v 19 'Pian -te o 'ka 'nɔn -wlɛ "bɛ, 'wɩ nɛn kɔ 'ka vɩ bɛ, te -a nyɛn 'e 'kɔn 'ka 'ji dɩ. Kɔɔ -te -a tʋ 'bɔ bɛ, 'wɩ zɩɛ -a -cin -tɔa 'ka 'ji.
\v 20 -Yɛɛ cɩ 'nan 'ka "tɩ Bali lei 'bɛ 'wɩ "paa 'ka 'le, -e 'ka vɩ. Cɛɛ "cɛɛ tin 'baa dɩ!
\p 
\v 21 Tʋ -tʋ -taa "bɔlɛ bɛ, "bʋɩ -mie 'e 'bɔ 'fli "bʋɩ -nɔan "minnun lɛ 'nan 'o -tɛ. Ɛn "nyian 'nɛn "tɩ -mie 'yee 'nɛn -nɔan "minnun lɛ 'nan 'o -tɛ. 'Nɛnnun -mienun wuanla 'o "tɩ 'lee 'o "bʋ "man 'nan minnun 'e o -tɛɛ.
\v 22 'Mɛn "wɛan bɛ, minnun pɛɛnɔn -taa 'nanlɛ 'ka man. 'Pian min nɛn e -tɔ 'plɛblɛ 'trilii, ɛn e 'bɔla -a 'le 'sran "nan "bɛ, e "sia 'wɩ 'ji.
\v 23 -Te minnun a 'tɛ 'panan 'ka da 'fla 'tʋ da bɛ, 'ka 'si 'bɛ 'nan, -e 'ka 'kʋ 'fla 'pee da. Maan ve 'cɛɛ 'wɩ tɩglɩ 'a 'nan, ka'a 'cɛan ciɩdɩ man Izraɛl 'fla pɛɛnɔn da Bali -le 'wɩ vɩdɩ -a 'vaa -e 'an 'bɔ Blamin -pɩ -tadɩ 'e 'bɔ dɩ.
\p 
\v 24 Maan ve "nyian 'cɛɛ 'nan, 'wɩ -tranlazan 'ka 'mlian 'wɩ "paazan da dɩ. Ɛn min 'suzan 'ka 'mlian 'e plazan "da dɩ.
\v 25 -Yee "wɛan te 'wɩ 'e 'ka 'kan dɩ. 'Wɩ nɛn waa drɛ 'wɩ "paazan lɛ bɛ, waa dra "nyian -a -tranlazan "lɛ. Ɛn 'wɩ nɛn waa drɛ min plazan "lɛ bɛ waa dra "nyian -a 'suzan lɛ. Ɛn "nyian bɛ "kɔnnɛnzan ceje 'bɔ bɛ minnun -a laabʋ -yʋnun tazan Bɛlzebul, -yee "wɛan 'wɩ nɛn o -taa -a vɩlɛ -yee "kɔnnɛn 'nɔn man bɛ, e "mlianla "da!»
\s1 Te 'ka "klan min lɔ dɩ!
\r (Lk 12.2-9)
\p 
\v 26 «Pian minnun nɛn o 'wɩnun zɩɛ -a dra 'cɛɛ bɛ, te 'ka "klan -wlɔ "dɩ! Kɔɔ 'wɩ nɛn e ya tian 'e yɔɔdɩ minnun man bɛ, -a ta -taa "bɔlɛa. Ɛn 'wɩ pɛɛnɔn nɛn minnun 'ka tian -a tɔa dɩɛ, -a -ci -taa 'silɛ -wlɛ.
\v 27 -Yee "wɛan 'wɩ nɛn maan ve 'cɛɛ klun tiidii 'va bɛ, 'ka vɩ yidɛa, ɛn 'wɩ nɛn maan ve 'cɛɛ 'sure -ji bɛ, 'ka trɔan -tɔ -guada.
\p 
\v 28 Ɛn te 'ka "klan minnun lɔ dɩ! O -kɔlaman min po -tɛdɩ -a, te wa'a 'kɔlaman -a lei -tɛdɩ -a dɩ. 'Pian 'ka "klan Bali lɔ! Kɔɔ e -kɔlaman min po -tɛdɩ -a, ɛn e -kɔlaman min lei -tɛdɩ -a. Yaa dra 'tɛ nɛn ya'a 'driman 'mlɔnmlɔn dɩɛ -a va.
\v 29 -A -cin 'e 'kɔn 'ka 'ji 'nan, "loman "wɛnwɛnnɛnnun nɛn min 'ka o taan "lala "kaga 'va dɩɛ, 'ka "tɩ Bali yiɛ a o da. -A -tʋ 'ka 'sia "va -e 'e 'tria te Bali 'bɔ "cɛɛ 'vɩ dɩ.
\v 30 Ɛn 'cee vɛ bɛ, 'ka 'wulo "jɛ pɛɛnɔn nɛn 'ka 'win -ji bɛ, Bali -a pou "nɛn -tɔa.
\v 31 -Yee "wɛan te "klan -tʋ 'e 'kɔn 'ka 'ji 'mlɔnmlɔn dɩ, Bali 'ka "siala e -cia "lomannun "da.
\p 
\v 32 Min nɛn yaa 'lɛ "cɛan minnun 'lɛ 'nan, 'e ya 'an -sruzan 'a bɛ, maan 'lɛ "cɛan "nyian 'an "tɩ "nɛn laji bɛ -a 'lɛ 'nan, min 'gʋɛ 'an -sruzan nɛn.
\v 33 'Pian min nɛn e 'ka "vale 'e ve minnun yiɛ man 'nan, 'e ya 'an -sruzan 'a dɩɛ, an 'bɔ "nyian "an "ve 'an "tɩ "nɛn laji bɛ -a 'lɛ 'nan, 'an -sruzan "cɛɛ dɩ.»
\s1 Minnun "cɛan 'e cin man Zozi -le "wɛan
\r (Lk 12.51-53; 14.26-27; 17.33)
\p 
\v 34 «Te 'e 'kɔn 'ka 'ji 'nan, an -ta 'trɛda 'nan -e 'ka 'man 'e 'fɔla -trɔɔ dɩ! Ma'an 'talɛ 'nan -e 'ka 'man 'e 'fɔla -trɔɔ dɩ, 'pian an -ta 'wɩ 'fɔlɛa 'ka man.
\v 35 Kɔɔ an -ta 'wɩ 'fɔlɛa 'nɛn -klɔnmɔn 'lee 'e "tɩ yei, ɛn an -ta 'wɩ 'fɔlɛa nɔnbɛ 'lee 'e "bʋ yei, ɛn "nyian bɛ an -ta 'wɩ 'fɔlɛa 'nɛn "bʋ 'lee 'e 'pɩ nan yei.
\v 36 Ɛn min 'bɔ 'mangulinun 'bɛ -taa "drɛlɛ -a 'nanmannɔn 'a.
\p 
\v 37 Min nɛn e "tɩ ye "yi, -te "bɛ "cɛɛ dɩ, 'e "bʋ ye "yi e "mlian 'an da bɛ, ya'a nyɛnlɛ 'an -sruzan 'a dɩ. Ɛn min nɛn e 'pɩ ye "yi, -te "bɛ "cɛɛ dɩ, e 'lu ye "yi e "mlian 'an da bɛ, ya'a nyɛnlɛ 'an -sruzan 'a dɩ.
\v 38 Min nɛn e ya "vale 'e -sɔɔnmlan 'an -sru "bɛ, 'e 'wɩ yra yɩdɩ man, ɛn 'e 'wɩ -kadɩ man yiba "plan da! -Te ya'a drɛlɛ zɩ dɩɛ, ya'a nyɛnlɛ 'an -sruzan 'a dɩ.
\v 39 Min nɛn e ya 'e 'ladɩ 'yee 'trɛda da bɛ, ya'a ye dɩ. 'Pian min nɛn 'e 'pɛ 'si 'yee 'trɛda da "fo, ɛn 'e 'fli -nɔn 'mɛn bɛ, yaa ye.»
\s1 Min nɛn e 'ka 'pɛ 'kun bɛ Bali -a -ko "paa
\r (Zan 13.20; Lk 10.16; Mk 9.41)
\p 
\v 40 «Min nɛn e 'ka 'pɛ 'kun bɛ, te yaan 'pɛ 'kun. Ɛn min nɛn yaan 'pɛ 'kun bɛ, te e min nɛn yaan 'pa 'sia bɛ -a -pɛ 'kun.
\v 41 Min nɛn e Bali 'lewei vɩzan -pɛ 'kun 'nan e ya Bali 'lewei vɩzan -a -le "wɛan bɛ, Bali -a san -ko "paa "le Bali 'lewei vɩzan -le 'wɩ 'zʋ. Ɛn min nɛn e min tɩglɩ 'pɛ 'kun 'nan e ya min tɩglɩ 'a -le "wɛan bɛ, Bali -a san -ko "paa "le min tɩglɩ 'le 'wɩ 'zʋ.
\v 42 'An -sruzan nɛn minnun 'ka -a siala fɛ -tʋ -a dɩɛ, min nɛn e 'yi 'kulenɛn 'tʋ -nɔn -yrɛ 'nan e ya 'an -sruzan 'a -le "wɛan bɛ, maan ve 'cɛɛ 'wɩ tɩglɩ 'a 'nan, Bali -a -ko "paa 'wɩ nɛn yaa drɛ bɛ -a man.»
\c 11
\p 
\v 1 Zɩ Zozi cɛɛn 'wɩnun pɛɛnɔn zɩɛ -a vɩdɩ man 'e -srunɔn 'fuda "fli "lɛ bɛ, ɛn e 'si fɛ zɩɛ -a -nan. E -kʋ 'wɩ "paadɩ -a minnun ji 'lee Bali -le 'wɩ vɩdɩ -a minnun lɛ fɛ zɩɛ -a "srɔn 'flanun da.
\s1 Min -batize drɛzan Zan minnun 'pa 'sia Zozi 'va
\r (Lk 7.18-35)
\p 
\v 2 Tʋ zɩɛ -a wlu bɛ, te Zan a -pʋ 'kuin. 'Wɩnun nɛn Crizi -a dra bɛ yaa 'man, ɛn 'e -srunɔn 'pa 'sia "va,
\v 3 'nan o laabʋ -yrɔ 'nan: «Yiɛ cɩ min nɛn kʋa 'man 'nan e -taa "bɛ -a, -baa kʋa pee man -pɛan tian?»
\p 
\v 4 Ɛn Zozi "e -wlɛ 'nan: «'Ka 'kʋ! 'Wɩnun nɛn kaa 'man bɛ, 'lee 'wɩnun nɛn kaa -nan 'yɩ bɛ, 'ka 'sinan 'pa Zan lɛ.
\v 5 'Wɩnun zɩɛ -nyrɛn 'gʋ: An yiɛ 'winɔn yiɛ 'lɛ 'sʋ. Minnun nɛn o -sran "tra "bɛ an o wluan lou. An -kogobe 'si -kogobe 'tɛnɔn man. An "trɔɛn "winɔn "trɔɛn 'lɛ 'sʋ. Minnun nɛn o -ka bɛ an o fuʋ. Ɛn an Bali -le 'wɩ 'nɔnnɔn 'vɩ 'yalɛ -tɛnɔn lɛ.
\v 6 Min nɛn e yi -tɛra an da ɛn -a -pɛ -sru 'ka tɔalɛ 'mlɔnmlɔn dɩɛ, Bali -le -fɛa a -a san man.»
\p 
\v 7 Zɩ Zan -le 'pasianɔn zɩɛ o lidɩ 'sia 'o da bɛ, ɛn Zozi Zan -le 'wɩ vɩdɩ 'sia minnun nɛn -nan bɛ -wlɛ. Yaa laabʋ -wlɔ 'nan: «-Mɛ "le "wɛan nɛn ka -kʋ Zan -nanjɛnlɛ "bui "da? -Cɛan nɛn fulɔ cɩ -a nyɔɔnnan bɛ, -a yɩnan "cɛɛ ka -kʋ dɩ.
\v 8 Ɛn -mɛ "le "wɛan nɛn ka -kʋ "mɛn? Min nɛn e sɔ fɛnyian 'wʋ 'e da bɛ, -a yɩnan "cɛɛ ka -kʋ dɩ. Kɔɔ kaa -tɔa 'nan sɔ fɛnyian fɛnyian bɛ, mingɔnnɛn -le 'kuin nɛn waa ye.
\v 9 'Ka 'ci nrɔn 'nan Bali 'lewei vɩzan nɛn, -yee "wɛan nɛn ka -kʋ. 'Wɩ 'kpa nɛn! 'Pian maan ve 'cɛɛ 'nan, Zan -dan "mlian Bali 'lewei vɩzan da.
\v 10 Kɔɔ e ya 'e 'crɛn -tɛdɩ Bali -le 'fluba 'ji 'nan:
\q1 ‹'An 'bɔ Bali,
\q1 an 'mɛn min -tʋ -tɔala 'i 'lɛ,
\q1 -yɛɛ 'i 'lɛ si dra.›
\m Min nɛn Bali -a 'vɩ bɛ Zan nɛn.
\v 11 Maan ve 'cɛɛ 'wɩ tɩglɩ 'a 'nan, 'trɛda blamin -tʋ -dan 'ka 'mlian min -batize drɛzan Zan da dɩ. 'Pian minnun nɛn o ya Bali -le mingɔnnɛn trɛdavɛ -a bɛ, o va min "wɛnnɛn -dan "mlian Zan da.
\v 12 Tʋ nɛn min -batize drɛzan Zan Bali -le 'wɩ vɩdɩ 'sia, 'trilii -e 'e bɔ cɛɛgʋ yi -a bɛ, minnun a 'o 'tɔdɩ lou 'nan te Bali -le mingɔnnɛn -blɩdɩ 'e 'kʋ 'e 'lɛ dɩ. Ɛn minnun 'bɔ nɛn -wee 'wɩ a 'tɔndɔn zɩɛ, o ya "va 'nan 'e drɛ 'wee vɛ -a.
\v 13 Bali -le mingɔnnɛn -blɩdɩ pou siadɩ bɛ, Bali 'lewei vɩnɔn pɛɛnɔn -a 'vɩ 'e 'cɛn, ɛn 'wɩ zɩɛ e ya 'e 'crɛn -tɛdɩ "nyian Moizi -le -pei 'fluba 'ji. Ɛn Zan "e 'wɩ 'tʋwli zɩɛ -a 'vɩ "nyian.
\v 14 'Wɩnun zɩɛ -te ka yi -tɛala "da 'nan 'wɩ 'kpa nɛn bɛ, maan ve 'cɛɛ 'nan, Eli nɛn Bali 'lewei vɩnɔn -a 'vɩ 'nan e -taa 'vaa -e Bali -le mingɔnnɛn -blɩdɩ 'e pou sia bɛ -a 'bɔ nɛn Zan -a.
\v 15 Min nɛn 'wɩ man "trɔɛn "cɩ -a -wulo -man bɛ 'e man.
\p 
\v 16 -Naagʋnɔn bɛ an o -kɔɔnman -tɩnun man? O ya "le nannannun nɛn o ya srɔan -tɛnan -guada bɛ, -wee 'wɩ 'zʋ. -A -mienun -a ve 'o bɔɛnun lɛ 'nan:
\v 17 ‹Kʋ -pʋ -tɛ 'cɛɛ, 'pian ka'a 'tanlɛ dɩ. "Drenun nɛn o min -wulo -man -taa "bɛ kʋa -fɔ 'cɛɛ, 'pian ka'a 'wuɔlɛ dɩ›.
\v 18 Fɛ nɛn maan 'vɩ zɩɛ -yɛɛ cɩ 'nan, zɩ Zan -ta bɛ, e fɛ 'sɔn, ɛn ya'a -wɛn mlinlɛ dɩ, 'pian minnun -a 'vɩ "man 'nan: ‹-Yʋ -wlidɩ 'bɛ cɩ -a -sru.›
\v 19 'Bɛ nɛn 'gʋɛ 'an 'bɔ Blamin -pɩ -ta, "an "fɛ -ble, ɛn "an "wɛn -mlian, ɛn minnun -a 'vɩ 'an man 'nan: ‹Fɛ -blɩ -lagu nɛn 'maan, ɛn -wɛn -tɛzan nɛn 'maan.› Ɛn "nyian minnun -a 'vɩ 'an man 'nan: ‹'Sukɔlɛ 'sinɔn 'lee 'wɩ 'wlidɩ "drɛnɔn bee nɛn 'maan.› 'Pian 'an drɛ wɩnun 'bɛ Bali -le 'wɩ 'tɔdɩ -ci -kɔɔnman.»
\s1 'Flanun nɛn -a danɔn 'ka yi -tɛlɛa Zozi da dɩɛ, Zozi 'wɩ 'pla -wlɛ
\r (Lk 10.13-15)
\p 
\v 20 "Bɛ -sru ɛn Zozi 'wɩ 'tɔ 'flanun nɛn e 'lɛbo "fɔ wɩ "kaga drɛ "da "bɛ o man, kɔɔ wa'a 'wɩlɛ "man -e 'o 'si 'o drɛ wɩ -wlidɩnun man dɩ. Yaa 'vɩ -wlɛ 'nan:
\v 21 «Koraze 'nɔn, 'wɩ -taa "bɔlɛ 'ka man! Bɛzaida 'nɔn, 'wɩ -taa "bɔlɛ 'ka man! 'Lɛbo "fɔ wɩnun nɛn o drɛ 'ka fla 'gʋɛ, "te o drɛ Tir 'lee Sidɔn 'flanun da bɛ, "te o 'tɛ 'yie 'wi 'o da -a -nan 'mɔn, ɛn "te 'o -cɛ bʋ sɔ cɛɛn 'o man -a -nan 'mɔn. -A -ci -kɔɔndɩ nɛn 'nan o 'si 'o drɛ wɩ -wlidɩnun man.
\v 22 -Yee "wɛan maan ve 'cɛɛ 'nan, yi nɛn Bali minnun -le tin "baa bɛ, 'cee yra yɩdɩ 'plɛblɛ "mlian Tir 'nɔn 'lee Sidɔn 'nɔn 'le vɛ da.
\v 23 Ɛn kaa nɛn ka cɩ Kapanamo 'nɔn 'a bɛ, e ya 'ka 'ji 'nan ka -ko Bali va laji? -Cɛjɛ, 'pian Bali 'ka -sɔɔnmlan -kanɔn 'va. Kɔɔ 'lɛbo "fɔ wɩnun nɛn o drɛ 'ka 'va 'gʋɛ, "te o drɛ Sodɔm 'nɔn fla bɛ, "te 'fla zɩɛ e ya -nan tian cɛɛgʋ yi -a.
\v 24 -Yee "wɛan maan ve 'cɛɛ 'nan, yi nɛn Bali minnun -le tin "baa bɛ, 'cee yra yɩdɩ 'plɛblɛ "mlian Sodɔm 'nɔn 'le vɛ da.»
\s1 Zozi 'e "tɩ 'tɔ 'bɔ
\r (Lk 10.21-22)
\p 
\v 25 Tʋ zɩɛ -a man nɛn, Zozi Bali trʋ 'ba. Yaa 'vɩ 'nan: «'An "tɩ, yiɛ cɩ labli 'san -a, ɛn yiɛ cɩ 'trɛ 'san -a. Mɛin 'tɔ "yi "ve 'nan, 'wɩnun nɛn yia yɔɔ minnun nɛn 'o 'fli "siala 'wɩ 'tɔnɔn -a bɛ o man bɛ, yia ta 'bɔla minnun nɛn 'o 'fli drɛ nannannun -a bɛ -wlɛ.
\v 26 'Wɩ 'kpa nɛn, kɔɔ 'wɩ nɛn e cɩ 'i 'ci 'sɔ 'a bɛ, -a 'bɔ nɛn yia drɛ.
\p 
\v 27 Fɛ pɛɛnɔn 'pɛba a 'e wʋdɩ 'an 'lɔ, 'an "tɩ yiɛ drɛ zɩ. 'An "tɩ 'saza 'bɛ 'an 'bɔ nɛn an cɩ -a -pɩ -a bɛ 'an -tɔa. Ɛn 'an 'bɔ nɛn an cɩ -a -pɩ -a bɛ 'an 'saza 'bɛ 'an "tɩ -tɔa. Ɛn "nyian 'an 'bɔ nɛn an cɩ -a -pɩ -a bɛ, min nɛn an ya "va 'nan 'an ta bɔala -yrɛ "bɛ, -a san 'bɛ 'an "tɩ -tɔa.
\p 
\v 28 'Ka pɛɛnɔn, 'ka 'ta 'an 'va! 'Ka "koe "a 'e 'nyandɩ, kɔɔ -trɔ nɛn 'ka 'win -ji bɛ -a cibɛn a, -yee "wɛan 'ka 'ta 'an 'va -e 'an 'ka 'trɔa.
\v 29 'Ka 'wɩ "man -e 'an drɛ 'ka 'tazan -a! 'Ka -sɔɔnla 'an -sru -e 'ka 'wɩ -tranla 'an 'va! Ma'an 'tɛ 'paa 'ka da dɩ, ɛn "nyian bɛ, an 'ka 'tʋdʋ pɛɛnɔn "siala min -a. 'An 'va zia bɛ, 'ka 'ci yra "tra.
\v 30 Kɔɔ -si nɛn maan -kɔɔnmlan 'cɛɛ -e 'ka 'sia bɛ, e ya 'ka 'sia -si -a. Ɛn -trɔ nɛn maan -nɔan 'cɛɛ -e 'ka 'sia bɛ, e ya 'fogo 'fogo.»
\c 12
\s1 Zozi 'wɩ tin 'ba Zuif 'nɔn 'le 'flinla "yi man
\r (Mk 2.23-28; Lk 6.1-5)
\p 
\v 1 "Bɛ -sru 'flinla "yi -tʋ da bɛ, ɛn Zozi 'lee 'e -srunɔn fei -tʋ 'cɛndɩ 'sia 'ji. Tʋ zɩɛ -a wlu bɛ, te dra -a -srunɔn -tɛa. Fɛ 'wlɛ nɛn fei zɩɛ -a da bɛ, waa cɛɛn, ɛn waa -blɩdɩ 'sia.
\v 2 Zɩ Farizɛn 'nɔn -a -nan 'yɩ bɛ, ɛn waa 'vɩ Zozi lɛ 'nan: «"I 'yiɔ 'i -srunɔn 'a! 'Wɩ nɛn wa'a dra -cee 'flinla "yi da dɩɛ, -a 'bɔ nɛn o cɩ -a drɛnan bɛ.»
\p 
\v 3 Ɛn Zozi -a laabʋ -wlɔ 'nan: «'Wɩ nɛn -kaa tra David -a drɛ 'o 'vale 'yee minnun -a bɛ, ka'a tian -a ta vɩlɛ dʋʋ? Te dra o -tɛa "bɛ,
\v 4 e wla Bali -le 'kuin, ɛn 'kpɔun nɛn waa 'pla Bali -le vɛ -a bɛ, yaa 'sia, yaa blɩ, ɛn e 'yee minnun "le "nɔn, 'pian te -a 'kpɔun 'bɔ zɩɛ Bali -pannɔn 'saza 'bɛ -ble.
\v 5 Ɛn "nyian bɛ, kaa ta 'vɩ Bali -le 'fluba 'ji 'nan, 'flinla "yi da bɛ, Bali -pannɔn 'ko 'nyranman 'palɛ Bali -pan 'kuin. 'Flinla "yi 'srɔɛn nɛn waa srɛ zɩɛ, 'pian o ya Bali -pan 'kuin -le "wɛan bɛ, min -tʋ 'ka 'wɩ 'tɔa o man dɩ.
\v 6 Maan ve 'cɛɛ 'nan, fɛ nɛn 'bɛ -dan "mlian Bali -pan 'kɔn da bɛ, 'bɛ a 'gʋ.
\v 7 E ya 'e 'crɛn -tɛdɩ Bali -le 'fluba 'ji 'nan:
\q1 ‹Min nyrinda 'e 'sɛn 'ka da!
\q1 'Bɛ cɩ 'wɩ "yi "a,
\q1 'pian 'sraga bʋdɩ bɛ,
\q1 'bɛ a 'e "tun.›
\m "Te ka 'wɩ zɩɛ -a -ci 'man bɛ, 'mɛn minnun nɛn wa'a 'wɩ 'wlidɩ "tʋ drɛlɛ 'labɛ dɩɛ, "te ka'a 'wɩ 'tɔa o man "fo "dɩ.
\v 8 Fɛ nɛn maan 'vɩ zɩɛ -yɛɛ cɩ 'nan, 'an 'bɔ Blamin -pɩ mɛɛn cɩ 'flinla "yi san -a.»
\s1 Min -tʋ nɛn -a -pɛla 'ka 'e man bɛ Zozi -a beli
\r (Mk 3.1-6; Lk 6.6-11)
\p 
\v 9 Zozi 'si fɛ zɩɛ -a -nan, ɛn e -kʋ -wee cin yɩ 'kuin.
\v 10 'Kɔn zɩɛ -a -ji bɛ, min -tʋ nɛn -a -pɛla 'ka 'e man bɛ, e ya -nan. -A -nan nɛn minnun 'wɩ 'gʋɛ -a laabʋ Zozi 'lɔ 'nan -e 'o -kɔla 'wɩ 'tɔdɩ -a "man "le "wɛan. O -yrɛ 'nan: «-Cee -pei -tɔ wɩ -a -si -nɔn 'nan min 'e 'cɛ 'si min man 'flinla "yi da?»
\p 
\v 11 Ɛn Zozi -a 'vɩ -wlɛ 'nan: «Min -tʋ 'ka 'ka yei, -te -yee 'bla a -tʋwli "cɛ, ɛn e -tɛ -klu -ji 'flinla "yi da bɛ, -e 'e vɩlɛ 'e 'si dɩ.
\v 12 Blamin 'wɩ a e -cia 'bla da. -Yee "wɛan -a -si a min lɔ -e 'e 'wɩ "yi "drɛ min lɛ 'flinla "yi da.»
\p 
\v 13 Ɛn Zozi -a 'vɩ min nɛn -a -pɛla 'ka 'e man bɛ -yrɛ 'nan: «'I 'pɛ 'sʋ "ji!» Min zɩɛ 'e 'pɛ 'sʋ "ji, ɛn -a -pɛ zɩɛ e drɛ "plɔnblɔn "le -a -pɛ -tʋ -le 'wɩ 'zʋ.
\v 14 Zɩ e 'wɩ zɩɛ -a drɛ bɛ, ɛn Farizɛn 'nɔn 'bɔla bei. O -kʋ 'o cin yɩlɛ. Waa 'pla "da 'nan, 'o Zozi 'man -wɛɛ -e 'o -tɛ.
\s1 Bali 'suzan nɛn Bali -a 'si "va "bɛ Zozi nɛn
\r (Mk 3.7-12; Lk 6.17-19)
\p 
\v 15 'Wɩ nɛn -a -cin cɩ Farizɛn 'nɔn 'ji 'nan 'o dra bɛ, Zozi -a -kɔnnɛn 'yɩ, ɛn e 'si fɛ zɩɛ -a -nan, e -kʋ. Min "kaga "kʋla -a -sru, ɛn minnun nɛn 'o 'man "yaaman bɛ, e -cɛ 'si o pɛɛnɔn man,
\v 16 'pian e 'wɩ 'pla -wlɛ 'klagla 'nan, te 'wee 'tɔ fuila "man "dɩ!
\v 17 'Wɩ nɛn Bali 'lewei vɩzan Ezai -a 'vɩ 'e 'cɛn bɛ, zɩ e 'lɛ sɔɔ zɩɛ. Kɔɔ yaa 'vɩ 'nan:
\v 18 «Bali "e 'nan:
\q1 ‹'An 'suzan nɛn maan 'si "va "bɛ, -nyrɛn "bɛ.
\q1 Maan ye "yi ɛn -yee 'wɩ 'an 'ci "nranman.
\q1 An 'mɛn lei 'saun -nɔan -yrɛ.
\q1 Zɩ an min "siala min tɩglɩ 'a 'an 'lɛ bɛ,
\q1 -yɛɛ ve 'lɛglɔn pɛɛnɔn 'ji 'nɔn lɛ.
\q1 
\v 19 Ya'a ve -sa -a dɩ, ɛn ya'a -paanman -a vɩdɩ -a dɩ.
\q1 Ɛn "nyian bɛ,
\q1 ya'a ve -guada -trilii dɩ.
\q1 
\v 20 Maan ve 'cɛɛ 'nan,
\q1 -cɛan nɛn e ya 'e 'widɩ bɛ,
\q1 'an 'suzan zɩɛ,
\q1 ya'a sʋʋmlan "nɛn "dɩ.
\q1 Ɛn 'tɛ nɛn e cɛɛn "dridɩ man bɛ,
\q1 ya'a 'driman dɩ.
\q1 Yaa dra -blɛblɛ zɩɛ -trilii,
\q1 -e zɩ an min "siala min tɩglɩ 'a 'an 'lɛ bɛ,
\q1 minnun pɛɛnɔn 'o -ci man.
\q1 
\v 21 'Trɛdanɔn pɛɛnɔn yiɛ 'fo -yrɛ 'nan,
\q1 -yɛɛ min "sia 'wɩ 'ji.› »
\s1 Zozi 'wɩ 'pla Farizɛn 'nɔn lɛ
\r (Mk 3.22-30; Lk 11.14-23; 12.10; 6.43-45)
\p 
\v 22 "Bɛ -sru ɛn minnun -ta min -tʋ nɛn -yʋ -wlidɩ "a -a -sru "bɛ, -a Zozi lɛ. Min zɩɛ -yʋ -wlidɩ 'bɔ -a yiɛ 'wi, ɛn yaa drɛ bobo -a. Zozi -a beli, ɛn e wɩɩ, ɛn e fɛnan yɩ.
\v 23 'Wɩ nɛn Zozi -a drɛ bɛ, e minnun pɛɛnɔn 'plo 'fɔ, ɛn waa 'vɩ 'o cin yei 'nan: «Min 'labɛ e -kɔan David kluda min -a 'kpagba.»
\p 
\v 24 Zɩ Farizɛn 'nɔn 'wɩ nɛn minnun -a 'vɩ bɛ -a 'man bɛ, ɛn waa 'vɩ -wlɛ 'nan: «-Yʋnun tazan Bɛlzebul -le 'plɛblɛ 'a nɛn min 'labɛ e -yʋ -wlidɩnun -pian "minnun -sru.»
\p 
\v 25 'Wɩ nɛn Farizɛn 'nɔn 'ji bɛ, Zozi -a -tɔ, ɛn e 'nan -wlɛ 'nan: «-Te 'lɛglɔn 'tʋ -ji minnun cɛɛn 'e cin man, ɛn o ya -kuli -tanan 'o cin man bɛ, 'lɛglɔn zɩɛ e -wia. -Te 'fla -tʋ da 'nɔn 'bɛ cɩ 'wɩ 'tʋwli zɩɛ -a drɛnan oo, 'fla zɩɛ ya'a 'mɔan dɩ, -e 'e -wi. Ɛn -te 'kɔn 'tʋwli 'lɛ "nɛn 'nɔn 'bɛ cɩ 'wɩ 'tʋwli zɩɛ -a drɛnan oo, "kɔnnɛn zɩɛ e -wia.
\v 26 -A -tʋwli "nɛn "nyian Satan 'lee -yee -yʋnun -le vɛ -a. "Te -wɛɛ cɛɛn 'e cin man, ɛn o ya -kuli -tannan 'o cin yei "bɛ, "te -yee mingɔnnɛn trɛ -wi -a -nan 'mɔn.
\p 
\v 27 Kaa 'vɩ 'an man 'nan, Bɛlzebul 'bɛ 'plɛblɛ -nɔan 'mɛn ɛn an -yʋ -wlidɩ -pian "minnun -sru, 'lɔɔ 'cee 'nɛnnun -le vɛ bɛ cɛɛ ve -nɔn? 'Wɩ nɛn kaa ve 'an man, -te ka'a ve 'cee 'nɛnnun man dɩɛ, yaa -kɔɔnman 'nan -tin a 'e 'tɛdɩ 'ka da.
\v 28 'Pian 'mɛn vɛ bɛ, Bali lei 'bɛ 'plɛblɛ -nɔan 'mɛn, ɛn an -yʋnun -pian "minnun -sru. 'Wɩ zɩɛ -yɛɛ -kɔɔnman 'nan Bali -le mingɔnnɛn -blɩdɩ 'bɔla 'ka 'va.
\v 29 Ɛn "nyian bɛ, maan ve 'cɛɛ 'nan, Satan nɛn e ya min 'plɛblɛ 'a bɛ, waa "kuan waa -yrɩman 'vaa, ɛn min -kɔlaman 'e -wlamlan -yee 'kuin -e 'e -yee fɛnun "koola.
\p 
\v 30 Min nɛn e 'ka 'an 'va dɩɛ, te -a pei a 'e 'padɩ 'an man. Ɛn min nɛn ya'a 'paa 'an 'va -e 'kʋ fɛ tre 'e cin man dɩɛ, yaa fuimlan "man.
\v 31 E ya "le 'an 'wɩ 'pla 'cɛɛ 'nan, 'wɩ 'wlidɩ pɛɛnɔn nɛn min -a dra bɛ, Bali -kɔlaman -a 'cɛdɩ -a min lɛ. Ɛn "nyian -te min Bali srɔn bɛ, Bali -kɔlaman -a 'cɛdɩ -a min lɛ. 'Pian 'wɩ nɛn Bali lei 'saun -a dra bɛ, min nɛn e "we "man -wlidɩ "bɛ, Bali 'ka -a cɛa -a san lɛ 'li "fo "dɩ.
\v 32 Min nɛn e 'wɩ 'wlidɩ 'vɩ 'an 'bɔ Blamin -pɩ man bɛ, waa "cɛa -yrɛ. 'Pian min nɛn e 'wɩ 'wlidɩ 'vɩ Bali lei 'saun man bɛ, -te -a yiɛ a "man 'trɛda 'gʋ oo, -te e -ka oo, wa'a cɛa -yrɛ "fo "dɩ.
\p 
\v 33 O yiba 'kpa -tɔa 'e 'blʋ man. -Te yiba "a "yi "bɛ, -a 'blʋ -kɔan "yi, ɛn -te yiba "a -wlidɩ "bɛ, -a 'blʋ -kɔan -wlidɩ.
\v 34 Min -wlidɩnun! 'Wɩ "yi 'ka 'kɔlaman -e 'e 'bɔla 'ka 'le dɩ, kɔɔ 'ka 'ci wɩ a -wlidɩ. -Yɛɛ cɩ 'nan 'wɩ nɛn 'e fadɩ min -ji bɛ -yɛɛ bɔala min 'le.
\v 35 Min nɛn -a ci wɩ a "yi "bɛ, -a 'le nɛn 'wɩ "yi bɔala, ɛn min nɛn -a ci wɩ a -wlidɩ "bɛ, -a 'le nɛn 'wɩ 'wlidɩ bɔala.
\v 36 Maan ve 'cɛɛ 'nan, yi nɛn Bali minnun -le tin "baa bɛ, 'wɩ pɛɛnɔn nɛn min a 'bɔla 'e 'le bɛ, yi zɩɛ -a da nɛn min -a -ci ve.
\v 37 Kɔɔ 'wɩ pɛɛnɔn nɛn min -a 'vɩ bɛ, -yɛɛ -tin -tɛa "min da, ɛn -yɛɛ min -le tin dra 'nɔnnɔn.»
\s1 Zozi 'ka 'wɩlɛ "man -e 'e 'lɛbo "fɔ wɩ drɛ dɩ
\r (Mk 8.11-12; Lk 11.16, 29-32)
\p 
\v 38 "Bɛ -sru ɛn 'fluba 'ci vɩnɔn -mienun 'lee Farizɛn 'nɔn -mienun 'wɩ laabʋ Zozi 'lɔ. O -yrɛ 'nan: «Bali -le 'wɩ "paazan, 'i 'wɩ 'tʋ drɛ -e 'e -ci -kɔɔn 'kʋɛ 'nan i "sia Bali va!»
\p 
\v 39 Ɛn Zozi "e 'nan -wlɛ 'nan: «-Naagʋnɔn, ka ya min -wlidɩnun -a, ka cɛɛn Bali man, ɛn ka ya "va 'nan, 'an 'wɩ 'tʋ drɛ -e 'e -kɔɔn 'nan 'an "sia Bali va. 'Pian maan ve 'cɛɛ 'nan, Bali 'ka "nyian 'wɩ 'nɔan -kɔɔn "vɛ pee dra 'ka 'va 'gʋ dɩ, -te ya'a 'silɛa 'wɩ nɛn e 'bɔ Bali 'lewei vɩzan Zonazi man bɛ -a dɩɛ.
\v 40 'Wɩ nɛn e 'bɔ Zonazi man bɛ -nyrɛn 'gʋ. E yi drɛ pɔ -dan tʋ pɔn -ji yaaga. 'Wɩ 'tʋwli zɩɛ e bɔa 'an 'bɔ Blamin -pɩ man, an yi dra 'trɛ 'ji yaaga.
\p 
\v 41 Yi nɛn Bali minnun -le tin "baa bɛ, Ninivi 'nɔn 'bɛ 'wɩ -tɔa -naagʋnɔn man. Kɔɔ zɩ Zonazi Bali -le 'wɩ 'vɩ Ninivi 'nɔn lɛ bɛ, o 'si 'wɩ 'wlidɩ "drɛdɩ man, ɛn o -sɔɔnla Bali -sru.
\v 42 Ɛn "nyian bɛ, lɩmɔn -tʋ nɛn 'li e ya mingɔnnɛn -a 'trɛda "tre 'zia bɛ, yi nɛn Bali minnun -le tin "baa bɛ, -yɛɛ 'wɩ -tɔa -naagʋnɔn man. Kɔɔ e 'si 'trɛda fɛnan -kɔɔbli 'nan, 'nan -e 'e Salomɔn -le 'wɩ 'tɔdɩ yɩ. Maan ve 'cɛɛ 'nan, min nɛn -a -dan "mlian Salomɔn da bɛ, e ya 'gʋ.»
\s1 -Yʋ -wlidɩ "lidɩ 'e da
\r (Lk 11.24-26)
\p 
\v 43 «-Te -yʋ -wlidɩ 'si min -tʋ -sru "bɛ, e -cia "wʋdɩ -a fɛnan -kadɩnun -nan. E -cia "fɛnan -wɛɛdɩ -a 'nan -e 'e -nyran nan, 'pian -te ya'a yɩlɛ dɩɛ,
\v 44 -e 'e vɩ 'nan: ‹An lia 'an da 'mɛn 'kɔn nɛn an cɩ "nɛn "ji bɛ, -a -ji.› -Te e -ta, te -a -nan a e "koodɩ, te fɛnun a 'e wʋʋladɩ "da, ɛn -a -ci a 'e "tun "bɛ,
\v 45 tɔɔn e -ko 'e -sru, -e 'e -yʋ -wlidɩ 'sɔravli "nɛn o -wlidɩ "mlian "da "bɛ o 'pa 'e 'va, -e 'o 'ta -nyran 'kɔn zɩɛ -a -ji. "Yɛɛ 'le 'sran bɛ, min zɩɛ -yee -kɔndɩ -wlidɩ "mlian -a tɛdɛ vɛ da "fo. 'Wɩ -tʋwli zɩɛ -yɛɛ dra -naagʋnɔn lɛ.»
\s1 -Tɩ nɛn Zozi -a "siala 'e drɩ 'a?
\r (Mk 3.31-35; Lk 8.19-21)
\p 
\v 46 Zozi 'fʋ tin 'banan minnun zɩɛ -wlɛ, ɛn -a "bʋ 'lee -a "bʋɩnun -ta. O -fʋ 'o 'tɔdɩ bei, ɛn o 'nan 'o ya "vale 'o 'wɩ tin "baa -yrɛ.
\v 47 Ɛn minnun nɛn o cɩ Zozi wei mannan bɛ, o va min -tʋ -kʋ -a vɩlɛ -yrɛ 'nan: «'I "bʋ 'lee 'i "bʋɩnun a bei, o ya "vale 'o tin "baa 'yiɛ.»
\p 
\v 48 'Pian Zozi "e min zɩɛ -yrɛ 'nan: «-Tɩnun 'bɛ cɩ 'an "bʋ "a, ɛn -tɩnun 'bɛ cɩ 'an "bʋɩnun -a?»
\v 49 Zɩ e 'wɩ zɩɛ -a 'vɩ bɛ, -a -nan nɛn 'e 'pɛ 'sʋ "ji 'e -srunɔn da, ɛn e 'nan: «"Ka 'yiɔ, 'an "bʋ 'lee 'an "bʋɩnun nɛn 'gʋ.
\v 50 Fɛ nɛn an 'wɩ zɩɛ -a 'vɩ bɛ, -yɛɛ cɩ 'nan min nɛn yaan "tɩ "nɛn laji bɛ -a ci 'sɔ wɩ dra bɛ, -yɛɛ cɩ 'an "bʋ "a, ɛn -yɛɛ cɩ 'an "blu -a, ɛn -yɛɛ cɩ 'an "bʋɩ -a.»
\c 13
\s1 'Saa 'fɔzan man -kɔnnɛn
\r (Mk 4.1-9; Lk 8.4-8)
\p 
\v 1 Yi -tʋwli zɩɛ -a da bɛ, Zozi 'si 'kuin, ɛn e -kʋ -nyɛnlɛa Galile 'yi 'plo man.
\v 2 Minnun a trenan "man "kaga, -yee "wɛan e -kʋ -fɔlɛ -klʋ -ji, ɛn e -nyran. Minnun pɛɛnɔn "o -fʋʋ 'yi 'plo da,
\v 3 ɛn e 'wɩ "paadɩ 'sia o ji -kɔnnɛnnun -fɔdɩ -a -wlɛ. E 'nan -wlɛ 'nan:
\p «Min -tʋ 'bɛ 'kʋ 'saa 'fɔlɛ.
\v 4 "Yɛɛ -kɔn -a wɛɛnnan bɛ, ɛn -a 'wlɛ plɔɛn 'sran si man. "Lomannun -ta, ɛn waa blɩ.
\v 5 -A 'wlɛ -mie -sran "nyian puo da, fɛnan nɛn 'trɛ 'ka "kaga "dɩɛ, -a -nan. E bɔdɩ 'sia tada, kɔɔ 'trɛ 'ka "da "kaga "dɩ.
\v 6 'Pian zɩ yidɛ "ɛ bɔla "ji "bɛ, 'saa zɩɛ e 'tɛ blɩ, ɛn e -ka, -a "sɛin 'ka 'kʋlɛ -kɔɔbli dɩ -le "wɛan.
\v 7 Ɛn -a 'wlɛ -mie -sran "nyian fɛnan nɛn -tɛin -taa "bɔlɛ bɛ -a -nan. -Tɛin zɩɛ e 'tu, yaa -maan 'saa 'ka bɔlɛ dɩ.
\v 8 Ɛn -a 'wlɛ -mie -sran 'trɛ "yi "da, e 'bɔ, e -sɛn "da. 'Saa bɛ -tʋ 'wlɛ a "man -yaa tʋ, ɛn -a bɛ -tʋ 'wlɛ a "man -fuba 'shɛɛdʋ, ɛn -a bɛ -tʋ 'wlɛ a "man -fuba yaaga.
\v 9 Min nɛn 'wɩ man "trɔɛn "cɩ -a -wulo -man bɛ, -a san 'e man!»
\s1 -Mɛ "le "wɛan nɛn Zozi 'wɩ tin 'ba -kɔnnɛn "ji?
\r (Mk 4.10-12; Lk 8.9-10)
\p 
\v 10 Zozi -srunɔn pli Zozi man, ɛn waa laabʋ -yrɔ 'nan: «-Mɛ "le "wɛan nɛn i 'wɩ tin 'ba minnun 'labɛ -wlɛ -kɔnnɛn "ji?»
\p 
\v 11 Ɛn Zozi "e -wlɛ 'nan: «Kaa 'gʋɛ, 'ka lɛ nɛn Bali 'yee 'wɩ yɔɔdɩ nɛn 'e min "paala 'a bɛ -a -ci 'si. 'Pian minnun nɛn o 'ka 'an -sru "dɩɛ, "o 'wɩ pɛɛnɔn maan -kɔnnɛn "ji.
\v 12 'Wɩ 'kpa nɛn, kɔɔ min nɛn e ya -yrɔ "bɛ, -a lɛ nɛn waa -nɔan, -e 'e -tɔ 'e 'ciɩla "da. 'Pian min nɛn -yee "ka "dɩɛ, -a "tiɛnnɛn nɛn yaa -tɔa "bɛ, waa "sia -yrɔ.
\v 13 'Wɩ zɩɛ -yee "wɛan nɛn an 'wɩ tin "baa minnun 'labɛ -wlɛ -kɔnnɛn "ji, kɔɔ o yiɛ a "ji fɛnan yɩ vɛ -a, 'pian wa'a fɛnan ye dɩ. Ɛn 'wɩ man "trɔɛn "a o -wulo -man, 'pian wa'a 'wɩ maan dɩ, ɛn waa 'wɩ 'ci maan dɩ.
\v 14 'Wɩ nɛn Bali 'lewei vɩzan Ezai -a 'vɩ bɛ, -yɛɛ 'bɔ o man. Yaa 'vɩ nan:
\q1 ‹'Ka "trɔɛn -tɔa 'wɩ lɛ 'kpa tɩglɩ,
\q1 'pian ka'a -ci maan dɩ.
\q1 Ka fɛnan -nanjɛan 'kpa tɩglɩ,
\q1 'pian ka'a -kɔnnɛn 'ye dɩ.
\q1 
\v 15 -Yɛɛ cɩ 'nan minnun 'labɛ 'o 'bli da -tɔ 'plɛblɛ,
\q1 'o 'fli "trɔɛn drɛ "yuyu,
\q1 ɛn 'o yiɛ 'lɛ 'wʋ 'o 'bɔ 'a.
\q1 Waa drɛ zɩɛ 'nan,
\q1 -e 'o vɩlɛ 'o fɛnan yɩ dɩ,
\q1 ɛn -e 'o vɩlɛ 'o 'wɩ man dɩ,
\q1 ɛn -e 'o vɩlɛ 'o 'wɩ 'ci man dɩ.
\q1 'Wɩ pɛɛnɔn zɩɛ waa drɛ 'nan,
\q1 "tɔgɔ 'o -sɔɔnla 'an -sru
\q1 -e 'an o 'si 'wɩ 'ji.›
\m 
\v 16 'Pian kaa nɛn ka cɩ 'an -srunɔn 'a 'gʋɛ, Bali -le -fɛa a 'ka man, kɔɔ 'ka yiɛ fɛnan ye, ɛn 'ka "trɔɛn 'wɩ 'ci maan.
\v 17 Maan ve 'cɛɛ 'wɩ tɩglɩ 'a 'nan, Bali 'lewei vɩnɔn "kaga, 'lee minnun nɛn o 'ta 'wʋla Bali wei da bɛ o "kaga -a man wɛɛ 'nan, fɛ nɛn kaa ye bɛ "o "ye, 'pian wa'a -kɔlalɛ -a yɩdɩ -a dɩ. Ɛn "nyian waa man wɛɛ 'nan, 'wɩ nɛn kaa maan 'gʋɛ "o maan, 'pian wa'a -kɔlalɛ -a mandɩ -a dɩ.»
\s1 Zozi 'saa 'fɔzan man -kɔnnɛn "ci 'vɩ
\r (Mk 4.13-20; Lk 8.11-15)
\p 
\v 18 «Kaa nɛn ka cɩ 'an -srunɔn 'a bɛ, -kɔnnɛn "nɛn maan -fɔ 'saa 'fɔzan man bɛ, an "ta -a -ci ve 'cɛɛ.
\v 19 Min -mienun -le vɛ bɛ, 'wɩ nɛn e 'bɔ 'saa 'wlɛ nɛn e -sran -si man bɛ -a man bɛ, -yɛɛ bɔa "nyian -wee "man. 'O "trɔɛn "tɔ Bali -le mingɔnnɛn -blɩdɩ min da 'wɩ lɛ, 'pian o "trɔɛn "yuyu 'tan. Tɔɔn ɛn Bali 'nanmanzan 'ta 'wɩnun nɛn -a -cin -fɔla o ji bɛ, -a "koolɛ.
\v 20 Min -mienun -le vɛ bɛ, 'wɩ nɛn e 'bɔ 'saa 'wlɛ nɛn e -sran puo da bɛ, -a man bɛ, -yɛɛ bɔa "nyian -wee "man. O Bali -le 'wɩ maan, 'nun tɔɔn o "we "man ci "nrandɩ -a.
\v 21 'Pian o 'ka 'o 'tɔdɩ "da 'plɛblɛ dɩ, -Te 'wɩ 'tɔndɔn bɔdɩ "sia o man, ɛn minnun 'tɛ 'padɩ 'sia o da 'nan o wɩɩ Bali -le 'wɩ man -le "wɛan bɛ, tɔɔn -e 'o 'pɛ 'si Bali -le 'wɩ -sru.
\v 22 Min -mienun -le vɛ bɛ, 'wɩ nɛn e 'bɔ 'saa 'wlɛ nɛn e -sran fɛnan nɛn -tɛin -taa "bɔlɛ bɛ, -a -nan bɛ, -yɛɛ bɔa -wee "man. O Bali -le 'wɩ maan, 'pian -wee ci "nrɔndɩ 'trɛda fɛnun da, 'lee -wee "lala yɩdɩ "yi "bʋʋ "bɛ, e -si -tɔa Bali wei lɔ -e 'e 'nyranman 'pa o man.
\v 23 'Pian min -mienun -le vɛ bɛ, 'wɩ nɛn e 'bɔ 'saa 'wlɛ nɛn e -sran 'trɛ "yi "da bɛ, -a man bɛ, -yɛɛ bɔa "o man. O Bali -le 'wɩ maan, o "we "man, tɔɔn 'nyranman nɛn Bali wei -a 'padɩ "siala o man bɛ -a "nɛn bɔala -dan. Te o drɛ "le 'nan 'saa nɛn -a bɛ -tʋwli 'wlɛ a "man -yaa tʋ, ɛn -a -tʋwli 'wlɛ a "man -fuba 'shɛɛdʋ, ɛn -a -tʋwli 'wlɛ a "man -fuba yaaga bɛ, -yee 'wɩ 'zʋ.»
\s1 Zozi -kɔnnɛn "fɔ lu 'wlɛ -wlidɩ "da
\p 
\v 24 Zozi -kɔnnɛn "pee -fɔ "nyian -wlɛ. E 'nan: «Bali -le mingɔnnɛn -blɩdɩ min da bɛ, -nyrɛn 'gʋ. E ya "le min -tʋ 'bɛ 'yee fei 'pa, ɛn e 'saa 'fɔ "da.
\v 25 'Pian, zɩ -pei 'tan, ɛn minnun a yi -tɛnan bɛ, min zɩɛ -a 'nanmanzan 'ta, e lu -wlidɩ 'wlɛ wɛɛn fei zɩɛ -a da, ɛn e -kʋ.
\v 26 'Saa zɩɛ e 'bɔ, e -sɛn "da, ɛn lu -wlidɩ "e 'bɔ 'wʋ "nyian.
\p 
\v 27 Minnun nɛn 'o yiɛ -tɔa "fei 'bɔ 'va te waa man dra bɛ, o -ta -a vɩlɛ fei san lɛ 'nan: ‹'Kʋ 'san, 'saa 'saza nɛn yia -fɔ 'yie fei. E drɛ 'kɔ, ɛn lu -wlidɩ 'bɔ 'ji?›
\p 
\v 28 Ɛn e 'nan -wlɛ 'nan: ‹'An 'nanmanzan 'bɛ drɛ.› Ɛn -yee minnun 'bɔ -a 'vɩ -yrɛ 'nan: ‹Kʋ "ta -ko -a "sʋʋlɛa?›
\p 
\v 29 Ɛn e 'nan -wlɛ 'nan: ‹-Cɛjɛ, te 'ka drɛ dɩ! "Tɔgɔ "cɛɛ vɩ 'nan ka lu -wlidɩ 'sʋla bɛ, 'ka 'saa 'pa 'va.
\v 30 'Ka o 'tʋɩ 'o trʋ 'e cin va -trilii, -e 'saa 'tɛ tʋ 'e bɔ. 'Saa 'tɛ tʋ -man bɛ, maan ve 'saa 'tɛnɔn lɛ 'nan, 'o lu 'wlɛ -wlidɩ "sʋʋla 'e 'flin, 'wɛɛ -yrɩ, -e 'wɛɛ 'tɛ 'blɩ. Ɛn 'saa bɛ, 'wɛɛ 'tɛ, -e 'wɛɛ 'sɛn 'mɛn 'trɛbɔ -ji.› »
\s1 Fei fɛ 'wlɛ 'tʋ man -kɔnnɛn 'lee 'mannyan man -kɔnnɛn
\r (Mk 4.30-32; Lk 13.18-21)
\p 
\v 31 Zozi -kɔnnɛn "pee -fɔ "nyian -wlɛ. E 'nan: «Bali -le mingɔnnɛn -blɩdɩ min da bɛ, -nyrɛn 'gʋ. E ya "le min -tʋ 'bɛ fei fɛ 'wlɛ "wɛnnɛn 'tʋ 'si, ɛn yaa -fɔ 'yee fei.
\v 32 Fei fɛ 'wlɛ zɩɛ -a "wɛnnɛn "mlian fei fɛ 'wlɛ pɛɛnɔn nɛn min -a -fɔa "fei bɛ -a da. 'Pian -te waa -fɔ ɛn e 'bɔ bɛ, -a -dan "mlian fei 'wlɛ pɛɛnɔn da. E dra "le yiba 'zʋ, te "lomannun a o "kɔɛ "tɔnan -a plan -ji.»
\p 
\v 33 Ɛn e -kɔnnɛn "pee -fɔ "nyian -wlɛ. E 'nan: «Bali -le mingɔnnɛn -blɩdɩ min da bɛ, -nyrɛn 'gʋ. E ya "le lɩmɔn -tʋ 'bɛ -fari puu "sonun yaaga 'si, e 'mannyan "wɛnnɔn 'wʋ "va, ɛn yaa baa. 'Mannyan zɩɛ e -fari -pʋ 'bɔ siiman 'e pɛɛnɔn.»
\s1 -Mɛ "le "wɛan nɛn Zozi 'wɩ tin 'ba -kɔnnɛn "ji?
\r (Mk 4.33-34)
\p 
\v 34 -Kɔnnɛn "ji nɛn Zozi wɩ pɛɛnɔn zɩɛ -a 'vɩ minnun "kaga "nɛn 'o cin 'yɩ bɛ -wlɛ. Ya'a 'wɩ 'tʋ vɩlɛ -wlɛ te e 'ka -kɔnnɛn "ji dɩ.
\v 35 Zozi -a drɛ zɩɛ 'nan, -e 'wɩ nɛn Bali 'lewei vɩzan -a 'vɩ bɛ, 'e 'lɛ sɔɔ. Bali 'lewei vɩzan -a 'vɩ 'nan:
\q1 «-Kɔnnɛn "ji nɛn an 'wɩ tin "baa minnun lɛ.
\q1 'Wɩnun nɛn o -fʋ 'e yɔɔdɩ
\q1 'trɛda pou sianan "trilii
\q1 -e 'e 'bɔ cɛɛgʋ yi -a bɛ,
\q1 maan ve minnun lɛ.»
\s1 Zozi lu 'wlɛ -wlidɩ "man -kɔnnɛn "ci 'vɩ
\p 
\v 36 "Bɛ -sru, Zozi minnun "kaga zɩɛ o 'tʋɩ, ɛn e -kʋ "kɔnnɛn 'o 'vale 'e -srunɔn 'a. -A -srunɔn pli "man, ɛn o 'nan -yrɛ 'nan: «-Kɔnnɛn "nɛn yia -fɔ lu 'wlɛ -wlidɩ "da bɛ, 'i -ci vɩ 'kʋɛ!»
\p 
\v 37 Ɛn Zozi "e 'nan -wlɛ 'nan: «Min nɛn, e 'saa 'fɔ bɛ, 'an 'bɔ Blamin -pɩ nɛn.
\v 38 Fei 'bɔ bɛ, 'trɛda nɛn. 'Saa 'wlɛ bɛ, minnun nɛn o 'ta wʋla Bali -sru "bɛ o nɛn. Lu 'wlɛ 'wlidɩ "bɛ, minnun nɛn o 'ta wʋla Satan -sru "bɛ o nɛn.
\v 39 Min zɩɛ -a 'nanmanzan nɛn e lu 'wlɛ 'wlidɩ wɛɛn bɛ, Satan nɛn. 'Saa 'tɛ tʋ bɛ, yi nɛn Bali 'trɛdanɔn -le tin "baa bɛ -nyrɛn. Ɛn 'saa -tɛnɔn bɛ, Bali -le 'pasianɔn nɛn laji bɛ o nɛn.
\v 40 O lu 'wlɛ 'wlidɩ 'tɛ blɩ, 'wɩ 'tʋwli zɩɛ -yɛɛ dra yi nɛn Bali 'trɛdanɔn -le tin "baa bɛ -a da.
\v 41 'Wɩ nɛn e -taa "drɛlɛ bɛ -nyrɛn 'gʋ: 'An 'bɔ Blamin -pɩ 'an 'mɛn 'pasianɔn nɛn laji bɛ o "paa -sia. 'Wɩ 'wlidɩ "drɛnɔn, 'lee minnun nɛn waa dra -e min 'e 'wɩ 'wlidɩ "drɛ bɛ, 'mɛn 'pasianɔn o bo "va minnun nɛn Bali mingɔnnɛn -ble o da bɛ o yei.
\v 42 O minnun zɩɛ o -sɛan 'tɛ -dan 'va. Fɛnan nɛn -wuɔdɩ 'lee 'shɛ da -blɩdɩ cɩ bɛ -a -nan.
\v 43 Tɔɔn -e minnun nɛn o 'ta 'wʋla Bali -sru "bɛ, o ta 'e 'sʋ 'o "tɩ "le mingɔnnɛn trɛda, te o -san a "le yidɛ 'san -le 'wɩ 'zʋ. Min nɛn 'wɩ man "trɔɛn "cɩ -a -wulo -man bɛ -a san 'e man!»
\s1 Zozi -kɔnnɛn "fɔ -gan da
\p 
\v 44 Zozi "e 'nan: «Bali -le mingɔnnɛn -blɩdɩ min da bɛ -nyrɛn 'gʋ. E ya "le 'nan -gan -tʋ nɛn 'e yɔɔdɩ fei -tʋ da. Min -tʋ -kʋ, e -gan zɩɛ -a 'yɩ, ɛn "e yɔɔ "nyian. -A ci "nranman "bʋʋ -le "wɛan, e 'yee fɛnun pɛɛnɔn 'tan, ɛn e -kʋ fei zɩɛ -a 'lɔlɛ -a man "lala -a.»
\p 
\v 45 Ɛn e -kɔnnɛn "pee -fɔ "nyian -wlɛ. E 'nan: «Bali -le mingɔnnɛn -blɩdɩ min da bɛ, -nyrɛn 'gʋ. E ya "le 'flɛ 'tanzan -tʋ 'bɛ cɩ fɛ -tʋ nɛn -a 'flɛ a "le -siga -zʋ bɛ -a -mie -wɛɛnan 'nan -e 'e 'lɔ.
\v 46 Fɛ zɩɛ yaa -tʋ 'yɩ te -a 'flɛ a 'kpa tɩglɩ. E -kʋ, e 'yee fɛnun pɛɛnɔn 'tan, ɛn e -ta -a 'lɔlɛ -a man "lala -a.»
\s1 Zozi -kɔnnɛn "fɔ pɔ -tɛ "se "da
\p 
\v 47 Zozi -kɔnnɛn "pee -fɔ "nyian -wlɛ. E 'nan: «Bali -le mingɔnnɛn -blɩdɩ min da bɛ, -nyrɛn 'gʋ. E ya "le min -tʋ 'bɛ 'kʋ 'yee "se 'wɛɛnlɛ 'yi 'va. "Se zɩɛ pɔ 'tɔ 'tʋdʋ pɛɛnɔn 'sɛn -ji.
\v 48 Zɩ e 'fa bɛ, minnun -a klan 'yi 'plo da, o -nyran, ɛn waa fa bʋdɩ 'sia. Pɔ 'kpa nun nɛn "va "bɛ, -wɛɛ -sɛn -pɔ -ji, ɛn -a -wlidɩnun bɛ, -wɛɛ wɛɛn.
\v 49 'Wɩ 'tʋwli zɩɛ -yɛɛ dra yi nɛn Bali 'trɛdanɔn 'le tin "baa bɛ, -a da. Bali -le 'pasianɔn nɛn laji bɛ, o -taa "min -wlidɩnun bʋlɛ "va minnun nɛn o 'ta 'wʋla Bali -sru "bɛ o yei.
\v 50 O minnun zɩɛ o -sɛan 'tɛ -dan 'va. Fɛnan nɛn -wuɔdɩ 'lee 'shɛ da -blɩdɩ cɩ bɛ -a -nan.»
\p 
\v 51 Ɛn Zozi -a laabʋ 'e -srunɔn 'lɔ 'nan: «Ka 'wɩ pɛɛnɔn zɩɛ -a -ci 'man?»
\p O -yrɛ 'nan: «-Inyan!»
\p 
\v 52 Ɛn e -wlɛ 'nan: «Kaa 'vɩ 'kpa. Maan ve 'cɛɛ 'nan, min nɛn e Bali -le 'fluba -tɔa ɛn e -sɔɔnla 'an -sru "bɛ, te e drɛ "le "kɔnnɛn san ceje -le 'wɩ 'zʋ. E 'wɩ cejenun 'lee 'wɩ 'trɛnun "paaman 'yee "kɔnnɛn 'nɔn 'ji.»
\s1 Zozi 'kʋ Nazarɛtɩ
\r (Mk 6.1-6; Lk 4.16-30)
\p 
\v 53 Zɩ Zozi cɛɛn -kɔnnɛn "nun zɩɛ -a -fɔdɩ man bɛ, ɛn e 'si 'nan,
\v 54 e -kʋ 'e fla. Zɩ e 'bɔla -nan nun bɛ, e 'wɩ "paadɩ 'sia -wee cin yɩ 'kuin. Min pɛɛnɔn 'plo 'fɔ ɛn o 'nan: «-Tɩɛ 'wɩ 'tɔdɩ paa "ji? Ɛn yaa dra 'kɔ 'lɔɔ ɛn e 'lɛbo "fɔ wɩnun dra?
\v 55 Min nɛn e cɩ -a bɛ, kʋa -tɔa. Yiba "nyaanzan nɛn 'gʋɛ -a -pɩ nɛn. Ɛn Mari 'bɛ cɩ -a "bʋ "a. Ɛn -a "bʋɩnun nɛn Zaji 'lee Zozɛfʋ 'lee Simɔn 'lee Zud -a.
\v 56 Ɛn "nyian bɛ, -a "blunun pɛɛnɔn a -kaa fla 'gʋ. -Yee 'wɩ 'tɔdɩ 'lee 'lɛbo "fɔ wɩnun drɛdɩ 'labɛ nyin zia nɛn yɛɛ 'si?»
\v 57 'Wɩ zɩɛ ya'a o ci 'sɔlɛ dɩ. -Yee "wɛan nɛn wa'a 'wɩlɛ "man -e 'o yi -tɛra "da "dɩ.
\p -A -nan nɛn Zozi "e 'nan -wlɛ 'nan: «-Te Bali 'lewei vɩzan a 'e fla, ɛn -te 'bɛ "cɛɛ dɩ 'nan e ya 'yee "kɔnnɛn "bɛ, minnun yiɛ 'ka "naan "man "dɩ.»
\p 
\v 58 Minnun 'ka yi -tɛlɛa Zozi da dɩ -le "wɛan, ya'a 'lɛbo "fɔ wɩ "kaga "drɛlɛ fɛ zɩɛ -a -nan dɩ.
\c 14
\s1 Min -batize drɛzan Zan -kanan wɩ nɛn 'gʋ
\r (Mk 6.14-29; Lk 9.7-9)
\p 
\v 1 Tʋ zɩɛ -a man nɛn, mingɔnnɛn Erodi nɛn e Galile 'lɛglɔn "paala bɛ, e Zozi 'le 'wɩ 'man.
\v 2 Yaa 'vɩ 'e 'wlunɔn lɛ 'nan: «Min 'labɛ min -batize drɛzan Zan nɛn! E wluan -kanɔn 'va, -yee "wɛan 'plɛblɛ a -yrɔ ɛn e 'lɛbo "fɔ wɩnun dra.»
\p 
\v 3 'Wɩ nɛn e drɛ 'lɔɔ ɛn Zan 'bɔ 'ka bɛ, -nyrɛn 'gʋ: Erodi 'bɛ 'vɩ 'nan o Zan 'kun, o -yrɩ, -e 'o -fɔ -pʋ 'kuin. Erodi 'e "bʋɩ Filipʋ nan nɛn waa laabo Erodia bɛ -a 'si 'e 'lɔ, ɛn yaa 'pa.
\v 4 'Wɩ zɩɛ e 'nan Zan man, tʋ pɛɛnɔn man bɛ te yaa ve Erodi lɛ 'nan: «-A -si 'ka 'i 'lɔ -e 'i "bʋɩ nan 'pa dɩ.»
\v 5 -Yee "wɛan Erodi a "va 'nan 'e Zan -tɛa. 'Pian "klan a "ji minnun "le "wɛan, kɔɔ min pɛɛnɔn Zan "siala Bali 'lewei vɩzan -a.
\p 
\v 6 Erodi -ya yi "fɛdi drɛdɩ 'bɔ. Yi zɩɛ -a da bɛ Erodia 'lu "dre 'tan minnun nɛn Erodi o laabʋ "fɛdi da bɛ o 'lɛ. -Yee "dre 'tandɩ Erodi ci 'sɔ "fo.
\v 7 -Yee "wɛan e -tɔ 'e 'wei da nɔnbɛ zɩɛ -yrɛ. Yaa 'vɩ -yrɛ 'nan: «Fɛ oo fɛ nɛn i ya "va "bɛ, 'i vɩ 'mɛn, maan -nɔan 'yiɛ.»
\p 
\v 8 -A "bʋ 'wɩ wʋʋ "ji, ɛn e 'nan Erodi lɛ 'nan: «Min -batize drɛzan Zan -wulo -va nɛn an cɩ. 'I -nɔn 'mɛn -naagʋ "plɛdi da!»
\v 9 'Wɩ zɩɛ e trun -fɔ mingɔnnɛn Erodi man. 'Pian e -tɔ 'e wei da 'va, ɛn "nyian bɛ minnun nɛn "fɛdi da bɛ -wee "wɛan, ya'a 'kɔlaman -e 'e vɩ -cɛjɛ dɩ. -A -nan nɛn e wɩɩ "man,
\v 10 ɛn e min 'pa 'sia 'nan 'e 'kʋ Zan -wulo 'cɛn -pʋ 'kuin.
\v 11 Yaa cɛɛn, ɛn e -ta -a "plɛdi da. Waa -nɔn nɔnbɛ zɩɛ -yrɛ, ɛn e -kʋ -a 'e "bʋ "lɛ.
\p 
\v 12 "Bɛ -sru, Zan -srunɔn 'ta Zan -kadɩ 'silɛa, ɛn o -kʋ -a wʋlɛ. 'Wɩ nɛn e 'bɔ "man "bɛ, ɛn o -kʋ -a 'sinan 'palɛ Zozi lɛ.
\s1 Zozi 'blɩfɛ -nɔn min -kpi 'soolu lɛ
\r (Mk 6.30-44; Lk 9.10-17; Zan 6.1-13)
\p 
\v 13 Zɩ Zozi 'wɩ zɩɛ -a 'man bɛ, e -fɔ -klʋ -ji, ɛn e 'si fɛ zɩɛ -a -nan. E ya 'vale 'e -kɔan fɛnan nɛn e cɩ flɩɩ bɛ -a -nan. 'Pian min "kaga -a -kɔnnɛn 'yɩ, o 'si 'fla, ɛn o -kʋla -a -sru 'o 'cɛin ji.
\v 14 Zɩ e sɔɔnla -klʋ -ji bɛ, e minnun 'yɩ "kaga, ɛn o nyrinda -sɛn "da. -A -nan nɛn -cɛnɔn nɛn minnun zɩɛ o yei "bɛ e o beli.
\p 
\v 15 Zɩ funninmlan "ta "paala bɛ, ɛn -a -srunɔn pli "man, o -yrɛ 'nan: «-Pei "ta taan, min 'ka 'nyɛanla 'gʋ dɩ. -Yee "wɛan 'i vɩ minnun lɛ 'nan, 'o 'kʋ 'fla -e 'o 'wee -blɩfɛnun 'lɔ, o -blɩ.»
\p 
\v 16 Ɛn Zozi -a 'vɩ 'e -srunɔn lɛ 'nan: «O -kɔlaman o -fo 'gʋ, 'ka 'blɩfɛ -nɔn -wlɛ 'ka 'bɔa!»
\p 
\v 17 Ɛn o 'nan -yrɛ 'nan: «'Kpɔun 'soolu 'lee pɔ 'fiili "cɛ "nɛn 'kʋ 'lɔ 'gʋ.»
\p 
\v 18 Ɛn Zozi "e 'nan: «'Ka 'ta -a 'mɛn!»
\v 19 "Bɛ -sru ɛn yaa 'vɩ minnun "kaga zɩɛ -wlɛ 'nan, 'o -nyran lu da. E 'kpɔun 'soolu 'lee pɔ "fli zɩɛ -a 'si, 'e yra -tɔ laji, e Bali muo "fɔ. "Bɛ -sru e 'kpɔunnun 'bɔ "nɛn jɛɛn, ɛn yaa -nɔn 'e -srunɔn lɛ 'nan 'o -pli "minnun 'bɔ man.
\v 20 O pɛɛnɔn -a blɩ, o 'kan. -A plɔɛn nɛn e -fʋ bɛ, waa tre 'e cin man, e saannɛn -fuda "fli 'fa.
\v 21 Minnun nɛn waa blɩ bɛ, o "nɛn bɔa -kpi 'soolu, te wa'a nannannun 'lee lɩmɔnnun "nrɔnlɛ dɩ.
\s1 Zozi 'ta 'wʋ 'yi yiɛ da
\r (Mk 6.45-52; Zan 6.15-21)
\p 
\v 22 "Bɛ -sru, ɛn e -tɔ 'e -srunɔn man 'nan, 'o 'fɔ -klʋ -ji 'o 'trɔa 'e 'lɛ 'yi -sru. E -fɔla "da 'nan -e 'e -si -nɔn minnun 'bɛ -wlɛ.
\v 23 Zɩ minnun -nyan -nan bɛ, e pɔn -tʋ tri ɛn e -kʋ Bali trʋ 'balɛ 'e 'saza. Funninmlan 'pla te e ya fɛ zɩɛ -nan 'e 'tʋwli.
\v 24 Tʋ zɩɛ -a man bɛ, te -klʋ -sru 'bɔ 'kɔɔbli. 'Pian te -klʋ 'bɔ a 'e yra yɩnan 'yi nɛn e 'blʋ -fɔa "bɛ -yrɔ, kɔɔ fulɔ "fɛɛnman o da zia.
\p 
\v 25 Zɩ tʋ 'cɛn mannɛn 'wɩdɩ 'sia bɛ, ɛn Zozi 'kʋla o -sru 'ta wʋdɩ -a 'yi yiɛ da.
\v 26 Zɩ -a -srunɔn -a 'yɩ, te e ya 'ta wʋnan 'yi yiɛ da bɛ, o ci nrɔn 'nan: «Min lei nɛn!» "Klan o -tɛa "le "wɛan o -paandɩ 'sia 'plɛblɛ.
\p 
\v 27 Ɛn Zozi "e -wlɛ 'nan: «'Ka 'fʋ flɩɩ. Maan nɛn, te 'ka "klan dɩ!»
\p 
\v 28 Ɛn Piɛri "e 'nan -yrɛ 'nan: «Minsan, -te bii nɛn bɛ, 'yian laabʋ -e 'an 'lʋ 'i 'va 'ta wʋdɩ -a 'yi yiɛ da.»
\p 
\v 29 Ɛn e -yrɛ 'nan: «'I 'ta!»
\p Piɛri 'si -klʋ -ji, ɛn e 'ta wʋladɩ 'sia 'yi 'yiɛ da te e -ko Zozi 'va.
\v 30 'Pian zɩ yaa 'yɩ 'nan fulɔ "fɛɛnman 'plɛblɛ bɛ, "klan -sɛn "ji, ɛn e -wladɩ 'sia 'yi 'wlu. -A -nan nɛn e -paandɩ 'sia. E 'nan: «Minsan, 'yian 'sʋ 'yi 'lɔ.»
\p 
\v 31 'Nun tɔɔn Zozi 'e 'pɛ 'sʋ "ji, yaa 'kun, ɛn e 'nan -yrɛ 'nan: «'Yie yi -tɛradɩ 'an da a "wɛnnɔn. -Mɛ "le "wɛan nɛn 'i 'ci -fɔɔdɩ 'sia?»
\p 
\v 32 -A -nan nɛn o -fɔ -klʋ -ji, ɛn fulɔ "fɛɛndɩ 'le 'tɔ.
\v 33 Tɔɔn ɛn -a -srunɔn 'o "po sɔɔn "wlu, waa 'vɩ -yrɛ 'nan: «-A -sa 'ka "fo "dɩ, Bali -pɩ nɛn yia.»
\s1 Zozi -cɛ -tɛnɔn beli Jenezarɛt
\r (Mk 6.53-56)
\p 
\v 34 O 'yi zɩɛ -a cɛɛn 'ji, ɛn o 'bɔla Jenezarɛt 'lɛglɔn 'ji.
\v 35 Minnun nɛn o -nyɛanla fɛ zɩɛ -a -nan bɛ, zɩ o Zozi 'yɩ bɛ, waa -kɔnnɛn 'yɩ. -A -nan nɛn o minnun 'pa 'sia 'o "srɔn 'flanun da, ɛn minnun -ta -cɛ -tɛnɔn pɛɛnɔn 'a -yrɛ.
\v 36 Ɛn o toba -fɔ Zozi lɛ 'nan 'e 'si -nɔn 'wlɛ -e 'o klɛ -yee sɔ 'lɛbo "tun "man. Minnun pɛɛnɔn nɛn o -kɔla klɛdɩ -a -yee sɔ 'lɛbo "man bɛ, -cɛ 'si o man "fo.
\c 15
\s1 Zuif 'nɔn tranun kluda wɩ
\r (Mk 7.1-13)
\p 
\v 1 "Bɛ -sru, ɛn Farizɛn 'nɔn -mienun 'lee 'fluba 'ci vɩnɔn -mienun 'si Zeruzalɛm, o -ta Zozi 'va, ɛn waa laabʋ -yrɔ 'nan:
\v 2 «-Mɛ "le "wɛan nɛn 'i -srunɔn 'ka 'ta 'wʋla -kaa tranun kluda wɩnun da dɩ? "Wɛɛ fɛnun -blɩ bɛ, wa'a 'o 'pɛ -man foeman "le zɩ -kaa tranun -a 'vɩ bɛ -yee 'wɩ 'zʋ dɩ.»
\p 
\v 3 Ɛn Zozi "e 'nan -wlɛ 'nan: «'Ka 'bɔ "nun, -mɛ "le "wɛan nɛn -kaa tranun kluda wɩ 'tɔ 'ji bɛ, ka'a 'ta 'wʋla Bali -le -pei -tɔ wɩnun da dɩ?
\v 4 Bali "e 'nan: ‹'I "tɩ 'lee 'i "bʋ "bɛ, 'i yiɛ 'e 'nan o man.› Ɛn yaa 'vɩ "nyian 'nan: ‹Min nɛn e wɩɩ -wlidɩ 'e "tɩ "lɛ, -te 'bɛ "cɛɛ dɩ e wɩɩ -wlidɩ 'e "bʋ "lɛ bɛ, -a san zɩɛ 'o -tɛ.›
\v 5 'Pian 'ka 'bɔ "ka "paaman minnun ji 'nan, min nɛn yaa 'vɩ 'e "tɩ -te 'bɛ "cɛɛ dɩ 'e "bʋ "lɛ 'nan: ‹"Lala nɛn 'an 'ci nrɔn 'nan 'an "paa -a 'ka 'va bɛ, an "ta -a -nɔan Bali lɛ.›
\v 6 -A san zɩɛ -te -a yiɛ 'ka 'nanlɛ 'e "tɩ 'lee 'e "bʋ "man dɩɛ, ya'a fɛ -tʋ dra dɩ. 'Wɩ zɩɛ yaa -kɔɔnman 'nan, ka Bali wei klu -sran 'ji 'ka tranun kluda wɩ -a.
\v 7 Wei "flivli 'nɔn! 'Wɩ nɛn Bali 'lewei vɩzan Ezai -a 'vɩ 'ka man bɛ, 'wɩ 'kpa nɛn. Yaa 'vɩ 'nan:
\q1 
\v 8 ‹Bali "e 'nan:
\q1 Minnun 'labɛ,
\q1 waan 'tɔ "yi "ve 'o 'le lou,
\q1 'pian o jinun bɛ,
\q1 o ya 'o 'sidɩ 'an man -kɔɔbli.
\q1 
\v 9 -Wee 'an 'sudɩ bɛ -a "nɛn "ka "dɩ.
\q1 Kɔɔ -peinun nɛn blamin a -tɔ bɛ,
\q1 -a 'bɔ nɛn waa "paaman minnun ji 'nan
\q1 -yɛɛ cɩ Bali -le -si -a.› »
\s1 -Mɛ "wɩ 'bɛ min "tri -tɔa Bali 'lɛ?
\r (Mk 7.14-23)
\p 
\v 10 "Bɛ -sru ɛn Zozi minnun laabʋ 'e "srɔn "kogo, ɛn e 'nan -wlɛ 'nan: «'Ka "trɔɛn "tɔ -e 'ka 'wɩ 'gʋɛ -a -ci man 'kpa!
\v 11 Fɛ nɛn e "sia bei -e 'e -wla "min ji bɛ, ya'a min "tri 'tɔa Bali 'lɛ dɩ. 'Pian fɛ nɛn e "sia min ji -e 'e bɔla bei "bɛ, -yɛɛ min "tri -tɔa Bali 'lɛ.»
\p 
\v 12 Tɔɔn ɛn -a -srunɔn pli "man, ɛn o 'nan -yrɛ 'nan: «'Wɩ nɛn yia 'vɩ 'gʋɛ, e wla Farizɛn 'nɔn man. Yia -tɔa zɩ?»
\p 
\v 13 Ɛn Zozi -a 'vɩ 'e -srunɔn lɛ 'nan: «Fɛ pɛɛnɔn nɛn 'an "tɩ "nɛn laji bɛ, -yɛɛ "cɛɛ 'wlɛ 'fɔ 'trɛ 'ji dɩɛ, o -taa -a "sʋʋlɛa.
\v 14 'Ka o 'tʋɩ zɩɛ! Yiɛ 'winɔn nɛn waa, ɛn o ya "vale 'o -si -kɔɔnman minnun nɛn o yiɛ a 'e 'widɩ bɛ -wlɛ. -Te yiɛ 'wizan -tʋ a -si -kɔɔnnan yiɛ 'wizan -tʋ lɛ bɛ, o "flinɔn -tɛa "klu -ji.»
\p 
\v 15 Ɛn Piɛri -a 'vɩ Zozi lɛ 'nan: «-Kɔnnɛn "nɛn yia -fɔ 'nan min "tri -tɔa Bali 'lɛ bɛ, 'i -ci vɩ 'kʋɛ.»
\p 
\v 16 Ɛn Zozi "e 'nan -yrɛ 'nan: «'Ka 'bɔ "nyian, "ka "ya wo tian minnun nɛn wa'a 'wɩ 'ci maan dɩɛ waa?
\v 17 -Mɛ drɛ ka'a 'wɩ 'ci maan dɩ? Fɛ pɛɛnɔn nɛn e -wlamlan min 'le bɛ, e -ko min -pɔn -ji, ɛn -a 'bɔ 'a nɛn o -fɔa "lua.
\v 18 'Pian fɛ pɛɛnɔn nɛn e bɔala min 'le bɛ, e "sia min souba ji, -yɛɛ min "tri -tɔa Bali 'lɛ.
\v 19 Kɔɔ min souba ji nɛn ci "nrɔndɩ -wlidɩ pɛɛnɔn "sia: min -tɛdɩ a -tʋ, min nan -wɛɛdɩ a -tʋ, min -sran -wɛɛdɩ a -tʋ, nyinnandɩ lɩ 'lee -kɔnnɛn -a te wa'a 'o cin 'palɛ dɩɛ e ya -tʋ, crin wʋdɩ a -tʋ, 'wlu 'sɛndɩ minnun man a -tʋ, 'wɩdɩ min man -wlidɩ "a -tʋ.
\v 20 'Wɩnun zɩɛ -a drɛdɩ 'bɛ min "tri -tɔa Bali 'lɛ. 'Pian -te min fɛ -blɩ 'e 'pɛ -man "tri "a bɛ, ya'a min "tri 'tɔa Bali 'lɛ dɩ.»
\s1 -Pɛn lɩ -tʋ yi -tɛra Zozi da
\r (Mk 7.24-30)
\p 
\v 21 Zozi 'si fɛ zɩɛ -a -nan, ɛn e -kʋ Tir 'lee Sidɔn 'lɛglɔn 'ji.
\v 22 'Lɛglɔn zɩɛ -a -ji 'nɔn bɛ Zuif 'nɔn "cɛɛ waa dɩ. -A -nan lɩmɔn -tʋ 'bɛ 'ta Zozi 'lɛ, ɛn e paan -yrɛ. E 'nan -yrɛ 'nan: «Minsan, David kluda min, 'an nyrinda 'e 'sɛn 'i da. -Yʋ -wlidɩ "a see 'panan 'an 'lu man.»
\p 
\v 23 'Pian Zozi 'ka 'wɩ 'tʋ 'silɛ "da "man "dɩ. Ɛn -a -srunɔn pli "man, o toba -fɔ Zozi lɛ 'nan: «'I fɛ -tʋ drɛ -e lɩ 'gʋɛ 'e li 'e da, kɔɔ -a -nan 'mɔn te e -paanman -kaa -sru.»
\p 
\v 24 Ɛn Zozi "e 'nan -wlɛ 'nan: «Izraɛl 'nɔn 'saza 'va nɛn Bali 'an 'pa 'sia. -Wɛɛ cɩ "le 'blanun nɛn -si 'san -wlɔ "bɛ -wee 'wɩ 'zʋ.»
\p 
\v 25 'Pian lɩ zɩɛ e -ta 'e "po sɔɔnla Zozi 'wlu ɛn e -yrɛ 'nan: «Minsan 'i yra 'si, 'i 'pa 'an 'va!»
\p 
\v 26 Zozi "e -yrɛ 'nan: «E 'ka 'wɩ "yi "a -e min 'e 'yee 'nɛnnun -blɩfɛ 'si 'e -nɔn -plɛnnun lɛ dɩ.»
\p 
\v 27 Ɛn lɩ zɩɛ e 'nan: «'Wɩ 'kpa nɛn, Minsan! 'Pian -plɛnnun bɛ, o "tɩ 'nɛan plɔɛn nɛn e -sɛanla bɛ, -nyrɛn waa -ble.»
\p 
\v 28 Tɔɔn Zozi "e -yrɛ 'nan: «'Yie yi -tɛradɩ Bali da a -dan. 'Wɩ nɛn i cɩ "va "bɛ 'e 'lɛ sɔɔ 'yiɛ!» Tʋ 'bɔ 'lein zɩɛ -a wlu nɛn -a 'lu beli.
\s1 Zozi min "kaga beli
\r (Mk 7.31-37)
\p 
\v 29 "Bɛ -sru Zozi 'si fɛ zɩɛ -a -nan, ɛn e -kʋ Galile 'yi man. E pɔn -tʋ tri, ɛn e -nyran "da.
\v 30 Ɛn minnun -tadɩ 'sia "va "kaga. O -ta 'o 'lɔ le minnun nɛn o "tun "bo bɛ waa, 'lee yiɛ 'winɔn, 'lee minnun nɛn o man mɛn -mie -ka o man bɛ waa, 'lee bobonun, 'lee -cɛ -tɛnɔn "kaga "pee "nyian. O -ta waa ɛn o o -sran -a 'lɛ, ɛn e o pɛɛnɔn beli.
\v 31 Bobonun wɩɩ, minnun nɛn o man mɛn -mie -ka o man bɛ e drɛ "plɔnblɔn 'e "pa 'ji, minnun nɛn o "tun "bo bɛ o 'ta 'wʋ, yiɛ 'winɔn fɛnan 'yɩ, zɩ minnun 'wɩ zɩɛ -a -nan 'yɩ bɛ, o 'plo 'fɔ, ɛn o Izraɛl 'nɔn 'le Bali 'tɔ bɔdɩ 'sia.
\s1 Zozi 'kpɔun pli min -kpi sinjɛn man
\r (Mk 8.1-10)
\p 
\v 32 Zozi 'e -srunɔn laabʋ, ɛn e 'nan -wlɛ 'nan: «Min "kaga 'labɛ, o nyrinda -sɛan 'an da, kɔɔ o yi yaaga nɛn 'an "srɔn 'gʋ, ɛn o -blɩfɛ "ka "nyian dɩ. An 'ka "va 'nan 'an o lia 'o da 'o 'ci le dra -a dɩ, "tɔgɔ o "koe 'e 'si 'o da -sia.»
\p 
\v 33 -A -srunɔn "e -yrɛ 'nan: «Fɛnan nɛn -kaa cɩ 'gʋɛ, min 'ka 'nyɛanla 'nan dɩ. Nyin zia nɛn kʋ -blɩfɛ "kaga "ye -e 'kʋ -nɔn min "kaga zɩɛ -wlɛ o 'kanvɛ -a?»
\p 
\v 34 Ɛn Zozi -a laabʋ -wlɔ 'nan: «-Blɩfɛ "cɛ "nɛn 'ka 'lɔ?»
\p Ɛn o -yrɛ 'nan: «'Kpɔun 'sɔravli 'lee pɔnɛn "wɛnwɛnnɛn -mie nɛn 'kʋ 'lɔ.»
\p 
\v 35 Tɔɔn Zozi "e 'nan minnun lɛ 'nan 'o -nyran "tra.
\v 36 E 'kpɔun 'sɔravli 'lee pɔnɛnnun zɩɛ -a 'si, e Bali muo "fɔ, ɛn yaa "nɛn jɛɛn. "Bɛ -sru yaa -nɔn 'e -srunɔn lɛ, ɛn waa pli minnun man.
\v 37 O pɛɛnɔn -a blɩ, o 'kan. -A plɔɛn nɛn e -fʋ bɛ, waa tre 'e cin man, e saannɛn 'sɔravli 'fa.
\v 38 Minnun nɛn waa blɩ bɛ, o "nɛn bɔa -kpi sinjɛn, te wa'a nannannun 'lee lɩmɔnnun "nrɔnlɛ dɩ.
\v 39 Zɩ Zozi 'si -nɔn minnun lɛ o -kʋ bɛ, ɛn e -fɔ -klʋ -ji, e Magadan 'lɛglɔn 'ji si 'sia.
\c 16
\s1 Zuif 'nɔn 'tanɔn 'ka Zozi -le 'wɩ 'ci maan dɩ
\r (Mk 8.11-21; Lk 12.54-56)
\p 
\v 1 Farizɛn 'nɔn 'lee Saduze 'nɔn pli Zozi man, ɛn o 'tan "man 'wɩ 'tʋ laabʋdɩ -a -yrɔ. Waa 'vɩ -yrɛ 'nan, 'e 'lɛbo "fɔ wɩ -tʋ drɛ laji -e 'o -tɔ 'nan Bali -le 'plɛblɛ a -yrɔ.
\p 
\v 2 Ɛn Zozi "e 'nan -wlɛ 'nan: [«-Te funninmlan 'pla te laji a 'tɛndɛn bɛ, kaa ve 'nan, "trɛ "bɛ fɛnan -kɔan 'e siadɩ "da.
\v 3 Ɛn bodrun -te fɛnan a -suglɔɔ bɛ, kaa ve 'nan, cɛɛgʋ laa -fɛan. 'Wɩ nɛn e "ta dra laji bɛ, kaa -tɔa. 'Pian 'wɩ nɛn 'bɛ cɩ drɛnan 'ka 'bɔ yiɛ man 'gʋɛ, ka'a 'bɛ 'ci maan dɩ.]
\v 4 -Naagʋnɔn, ka ya min -wlidɩnun -a, ka cɛɛn Bali man, ɛn ka ya "va 'nan, 'an 'wɩ 'tʋ drɛ -e 'e -kɔɔn 'nan Bali -le 'plɛblɛ a 'an 'lɔ. 'Pian maan ve 'cɛɛ 'nan, Bali 'ka "nyian 'wɩ 'nɔan -kɔɔn "vɛ pee dra 'ka 'va 'gʋ dɩ, -te ya'a 'silɛa 'wɩ nɛn e 'bɔ Bali 'lewei vɩzan Zonazi man bɛ -a dɩɛ.» Ɛn e o 'tʋɩ, e -kʋ.
\s1 Zozi 'wɩ 'pla 'e -srunɔn lɛ Farizɛn 'nɔn 'le 'wɩ "paadɩ da
\r (Mk 8.14-21)
\p 
\v 5 Te -a -srunɔn "ta -ko 'yi -sru 'zianun bɛ, o ci 'san 'kpɔun siadɩ man.
\v 6 Zɩ o 'bɔla 'nan nun bɛ, ɛn Zozi "e -wlɛ 'nan: «'Ka yiɛ 'tɔ 'ka 'fli -va 'kpa Farizɛn 'nɔn 'lee Saduze 'nɔn 'le 'mannyan 'le "wɛan.»
\p 
\v 7 -A -srunɔn 'o 'ci nrɔn, ɛn waa 'vɩ 'o cin yei 'nan: «-Ka'a talɛ 'kpɔun -a dɩ, -yee "wɛan nɛn e 'wɩ zɩɛ -a 'vɩ.»
\p 
\v 8 Zozi -a -kɔnnɛn 'yɩ, ɛn e 'nan -wlɛ 'nan: «'Cee yi -tɛradɩ Bali da a "wɛnnɔn. -Mɛ "le "wɛan nɛn 'ka 'ci nrɔn 'nan, ka'a 'talɛ 'kpɔun -a dɩ, -yee "wɛan nɛn an 'wɩ zɩɛ -a 'vɩ.
\v 9 'Wɩ klɔ 'ka 'ka 'ji dʋʋ? -A -cin 'e 'tɔ 'ka 'ji 'nan, an 'kpɔun 'soolu pli min -kpi 'soolu man, waa blɩ o 'kan. -A plɔɛn nɛn e -fʋ bɛ e saannɛn 'fa wɛa?
\v 10 Ɛn -a cin 'e 'tɔ 'ka 'ji "nyian 'nan, an 'kpɔun 'sɔravli pli min -kpi sinjɛn man, waa blɩ o 'kan. -A plɔɛn nɛn e -fʋ bɛ e saannɛn 'fa wɛa?
\v 11 'Cee 'wɩ 'ci mandɩ a 'plɛblɛ. Ma'an 'kpɔun -le 'wɩ vɩlɛ 'cɛɛ dɩ. 'Pian maan 'vɩ 'cɛɛ 'nan, 'ka yiɛ 'tɔ 'ka 'fli -va Farizɛn 'nɔn 'lee Saduze 'nɔn 'le 'mannyan 'le "wɛan.»
\p 
\v 12 Ɛn -a -srunɔn -a -ci 'man "mɛn 'nan, 'mannyan nɛn waa -sɛan 'kpɔun -va bɛ, -yee "wɛan "cɛɛ e 'nan 'o yiɛ 'tɔ 'o 'fli -va dɩ. 'Pian Farizɛn 'nɔn 'lee Saduze 'nɔn -le 'wɩ "paadɩ nɛn yaa ve.
\s1 Min nɛn Zozi cɩ -a bɛ Piɛri -a 'vɩ
\r (Mk 8.27-30; Lk 9.18-21)
\p 
\v 13 Zɩ Zozi 'bɔla Sezare Filipʋ 'lɛglɔn 'ji bɛ, ɛn yaa laabʋ 'e -srunɔn 'lɔ 'nan: «'An 'bɔ Blamin -pɩ bɛ minnun "o 'nan, -tɩ nɛn 'maan?»
\p 
\v 14 Ɛn o 'nan -yrɛ 'nan: «Min -mienun "o 'vɩ 'nan, min -batize drɛzan Zan nɛn e -ka bɛ, -nyrɛn 'yia. Ɛn min plɔɛn "o 'vɩ 'nan, Bali 'lewei vɩzan Eli nɛn 'li bɛ, -nyrɛn 'yia. Ɛn o -mienun "o 'vɩ 'nan Bali 'lewei vɩzan Zeremi nɛn 'li bɛ, -nyrɛn 'yia. Ɛn -te 'bɛ "cɛɛ dɩɛ, Bali 'lewei vɩnɔn nɛn 'li bɛ -a -tʋ 'bɛ fuʋ, -nyrɛn 'yia.»
\p 
\v 15 Ɛn yaa laabʋ 'e -srunɔn 'lɔ 'nan: «Kaa "nun, "ka 'vɩ 'nan, -tɩ nɛn 'maan?»
\p 
\v 16 Simɔn Piɛri "e -yrɛ 'nan: «I ya Crizi nɛn Bali -a 'pa 'sia -e 'e minnun 'si 'wɩ 'ji bɛ -a. Bali nɛn -a yiɛ cɩ "man "bɛ -a -pɩ nɛn 'yia.»
\p 
\v 17 Ɛn Zozi "e 'nan: «Zonas -pɩ Simɔn, 'yie 'wɩ a "yi. Kɔɔ blamin "cɛɛ 'wɩ zɩɛ -a -cin -tɔ 'i 'ji dɩ, 'pian 'an "tɩ "nɛn laji bɛ -yɛɛ -cin -tɔ 'i 'ji.
\v 18 Maan ve 'yiɛ 'nan, 'i 'tɔ nɛn Piɛri, -a -ci puo. Ɛn puo zɩɛ -a da nɛn an -taa 'mɛn -leglizi -tɔlɛa. Fɛ -tʋ 'ka 'trɛ 'gʋɛ -a da -e 'e -leglizi zɩɛ -a -wi dɩ.
\v 19 Bali -le mingɔnnɛn trɛ bɛ, maan -lagle 'wlɛ -nɔan 'yiɛ. Fɛ oo fɛ nɛn yia ve "man "cɛjɛ 'trɛ 'gʋɛ -a da bɛ, te o -cɛjɛ 'vɩ "man laji. Ɛn fɛ oo fɛ nɛn yia "kuan 'i 'pɛ "fli "a 'trɛ 'gʋɛ -a da bɛ, te waa 'kun o -pɛ "fli "a laji.»
\p 
\v 20 -A -nan nɛn Zozi 'e -srunɔn "trɔɛn nyuɔn 'klagla. Yaa 'vɩ -wlɛ 'nan, te 'o -nan sɛɛ wʋ min lɛ 'nan, min nɛn Bali -a 'si "va -e 'e minnun 'si 'wɩ 'ji bɛ -nyrɛn 'yaa dɩ.
\s1 Zozi 'e 'kanan 'lee 'e wluandɩ -kanɔn 'va wɩ 'vɩ
\r (Mk 8.31-33; Lk 9.22)
\p 
\v 21 -E 'e 'sia tʋ zɩɛ -a man bɛ, -a -nan nɛn 'wɩ nɛn e "ta -daa "bɔlɛ Zozi man bɛ yaa vɩdɩ 'sia 'e -srunɔn lɛ. E 'nan -wlɛ 'nan: «An -ko Zeruzalɛm. Min cejenun, 'lee Bali -pannɔn 'tanɔn 'lee 'fluba 'ci vɩnɔn 'tɛ "kaga "paa 'an da. Waan -tɛa, -a yi yaagazan da -e 'an 'wluan -kanɔn 'va.»
\p 
\v 22 -A -nan nɛn Piɛri -a laabʋ 'o "fli yei, ɛn e 'wɩ pladɩ 'sia -yrɛ 'klagla. Yaa 'vɩ -yrɛ 'nan: «Minsan, 'wɩ zɩɛ te 'an man 'i da "fo "dɩ, te Bali 'e -si -nɔn dɩ.»
\p 
\v 23 Zozi 'e yra -tɔ Piɛri da, ɛn e -yrɛ 'nan: «Satan! 'I 'si 'an -sru! Te 'i 'si -tɔ 'an 'lɔ dɩ! 'Wɩ nɛn 'i 'ci "nrɔnman "da "bɛ, -a da "cɛɛ Bali e ci "nrɔnman dɩ. Blamin -le ci "nrɔndɩ nɛn 'i 'wulo -ji.»
\s1 Zozi -sru 'ta wʋdɩ
\r (Mk 8.34–9.1; Lk 9.23-27)
\p 
\v 24 "Bɛ -sru ɛn Zozi -a 'vɩ 'e -srunɔn lɛ 'nan: «Min nɛn e ya "vale 'e dra 'an -sruzan 'a bɛ, 'e 'wɩ yra yɩdɩ man, ɛn 'e 'wɩ 'kadɩ man yiba "plan da, -e 'e -sɔɔnla 'an -sru.
\v 25 Kɔɔ min nɛn e cɩ 'e 'ladɩ 'yee 'trɛda da bɛ, ya'a ye dɩ. 'Pian min nɛn 'e 'pɛ 'si 'yee 'trɛda da "fo ɛn yaa -nɔn 'mɛn bɛ, -a san 'bɛ 'belidɩ nɛn ya'a 'nyaan dɩɛ -a ye.
\v 26 Ɛn -te min 'trɛda fɛ pɛɛnɔn 'yɩ, te 'belidɩ 'ka -yrɔ "dɩɛ, -a -ci nɛn 'nɔn? Fɛ -tʋ 'ka 'trɛ 'gʋɛ -a da -e min 'e 'yee 'belidɩ ta pan wʋ -a dɩ.
\v 27 'Wɩ pɛɛnɔn zɩɛ maan -cin -tɔ 'ka 'ji, kɔɔ tʋ nɛn an -ta pee wo bɛ, 'an 'bɔ Blamin -pɩ, an -taa 'an "tɩ "le 'tɛ 'san da 'kʋ 'vale 'mɛn 'pasianɔn nɛn laji bɛ waa. Tʋ zɩɛ -a man nɛn min -tʋ 'e drɛ wɩ man -kopa ye.
\v 28 Maan ve 'cɛɛ 'wɩ tɩglɩ 'a 'nan, 'ka pɛɛnɔn nɛn 'an 'lɛ 'gʋɛ, ka'a 'cɛan -kaadɩ man 'vaa -e 'ka yɩ 'nan, 'an 'bɔ Blamin -pɩ mingɔnnɛn -blɩdɩ 'sia dɩ.»
\c 17
\s1 Zozi -srunɔn yaaga Zozi 'yɩ 'yee 'tɛ 'san wlu
\r (Mk 9.2-13; Lk 9.28-36)
\p 
\v 1 Yi 'shɛɛdʋ, "bɛ -sru ɛn Zozi 'kʋ pɔn loulou "tʋ da 'o 'vale Piɛri 'lee Zaji 'lee 'e "bʋɩ Zan -a.
\v 2 Zozi 'kɔlɛ lila o yiɛ man. -A yra 'bidɩ 'sia "le yidɛ 'le 'wɩ 'zʋ, ɛn -yee sɔ drɛ 'fuvu 'yrɩyrɩ.
\v 3 Ɛn o Moizi 'lee Eli 'yɩ -a "srɔn, te o -sɛɛ "wo 'o 'vale Zozi 'a.
\p 
\v 4 -A -nan nɛn Piɛri -a 'vɩ Zozi lɛ 'nan: «Minsan, e drɛ 'wɩ "yi "a ɛn -kaa ta 'gʋ. -Te 'i wɩɩ "man "bɛ, an segle pannɛn yaaga -tɔa. -A -tʋ -kɔan 'yie vɛ, -a -tʋ -kɔan Moizi -le vɛ, ɛn -a -tʋ -kɔan Eli -le vɛ -a.»
\p 
\v 5 E -fʋ 'wɩ zɩɛ -a tin 'banan, ɛn "lolu -koei "nɛn e ya 'fuvu 'yrɩyrɩ bɛ, e -trɔa o da. -A -nan nɛn wei -tʋ wɩɩ "lolu -koei zɩɛ -a va. Yaa 'vɩ 'nan: «Min 'labɛ, e ya 'an 'pɩ nɛn maan ye "yi "bɛ -a. E ya 'an 'bli 'pa "da "nɛn -a. 'Ka "trɔɛn "tɔ -a wei lɛ!»
\p 
\v 6 Zɩ -a -srunɔn wei zɩɛ -a 'man bɛ, "klan -sɛn o ji, o tɛɛla 'o 'kɔlɛnɛn, ɛn 'o yra blula.
\v 7 'Pian Zozi pli o man, e klɛ o man, ɛn e -wlɛ 'nan: «Te 'ka "klan dɩ! 'Ka 'wluan lou!»
\v 8 -A -nan nɛn 'o 'wulo wluan lou, ɛn o Zozi 'yɩ 'e 'saza.
\p 
\v 9 Zɩ o ya 'sinan pɔn da -e 'o -sɔɔn "ji "bɛ, ɛn e 'wɩ 'pla 'e -srunɔn lɛ. Yaa 'vɩ -wlɛ 'nan: «'Wɩ nɛn ka "sia -a -nan yɩnan 'gʋɛ, te 'ka -nan sɛɛ wʋ min lɛ dɩ, -trilii -e 'an 'bɔ Blamin -pɩ 'an 'wluan -kanɔn 'va.»
\p 
\v 10 -A -nan nɛn -a -srunɔn 'wɩ laabʋ -yrɔ. Waa laabʋ 'nan: «-Mɛ "le "wɛan nɛn 'fluba 'ci vɩnɔn "o 'nan, Eli 'bɛ -taa 'e 'flin 'vaa -e min 'sizan 'wɩ 'ji 'e 'ta?»
\p 
\v 11 Ɛn Zozi "e 'nan -wlɛ 'nan: «-Wee tin a 'nɔnnɔn. Eli 'bɛ -taa 'e 'flin, -e 'e fɛnun pɛɛnɔn -tɔɔla 'e "pa 'ji.
\v 12 'Pian maan ve 'cɛɛ 'nan, Eli -ta 'va, ɛn wa'a 'silɛa min -a dɩ. 'Wɩ nɛn o cɩ "va "bɛ, waa drɛ -yrɛ. 'Wɩ 'tʋwli zɩɛ -yɛɛ bɔa 'an 'bɔ Blamin -pɩ man, 'an yra ye -wlɔ.»
\v 13 -A -nan nɛn -a -srunɔn -a -ci 'man 'nan, min -batize drɛzan Zan -le 'wɩ nɛn yaa 'vɩ.
\s1 Zozi -yʋ -wlidɩ 'si 'nɛn 'tʋ -sru
\r (Mk 9.14-29; Lk 9.37-43)
\p 
\v 14 Minnun nɛn o cɩ Zozi 'pɛnnan bɛ, Zozi 'lee 'e -srunɔn yaaga 'bɔ o man, ɛn min -tʋ -ta 'e "po "sran Zozi 'wlu, ɛn e 'nan -yrɛ 'nan:
\v 15 «Minsan, 'an 'pɩ nyrinda 'e 'sɛn 'i da! -Tʋwli "cɛ a "man, ɛn e ya 'e yra yɩnan -yrɔ "wlidɩ. Tʋ -mie man bɛ, yaa -tɛa 'tɛ 'va, ɛn tʋ -mie man bɛ yaa -tɛa 'yi 'va.
\v 16 An -ta -a 'i -srunɔn lɛ, wa'a -kɔlalɛ -a 'belidɩ -a dɩ.»
\p 
\v 17 Zozi "e 'nan -wlɛ 'nan: «-Naagʋnɔn, 'cee yi -tɛradɩ Bali da "ka "dɩ, ɛn ka 'wɩ 'wlidɩ "dra. 'An "koe -nyaan 'ka man 'e "tun. Tʋ wɛa nɛn maan dra "nyian 'ka 'va? 'Ka 'ta 'nɛn 'bɔ 'a 'gʋ!»
\v 18 Ɛn Zozi 'a 'vɩ 'yʋ -wlidɩ zɩɛ -yrɛ 'nan: «'I 'si 'nɛn 'gʋɛ -a -sru.» E 'si -a -sru ɛn 'nɛn zɩɛ e beli 'nun.
\p 
\v 19 "Bɛ -sru, zɩ Zozi 'lee 'e -srunɔn 'fʋ 'o 'saza bɛ, ɛn waa laabʋ -yrɔ 'nan: «-Mɛ "le "wɛan nɛn kʋ'a -kɔlalɛ -yʋ -wlidɩ zɩɛ -a -pindɩ -a dɩ?»
\p 
\v 20 Ɛn Zozi "e 'nan -wlɛ 'nan: «'Cee yi -tɛradɩ Bali da a "wɛnnɔn, -yee "wɛan ka'a -kɔlalɛ -a drɛdɩ -a dɩ. Maan ve 'cɛɛ 'wɩ tɩglɩ 'a 'nan, -te 'cee yi -tɛradɩ Bali da a "wɛnnɔn "le fei fɛ 'wlɛ "wɛnnɛn -tʋ -le 'wɩ 'zʋ bɛ, kaa ve pɔn 'labɛ -yrɛ 'nan: ‹'I 'sʋra fɛ 'gʋɛ -a -nan 'i 'trɔa -miɛn›, yaa dra. 'Wɩ 'tʋ 'ka 'kɔan, te ka'a 'kɔlaman -a drɛdɩ -a dɩ.
\v 21 ['Pian -yʋ -wlidɩ zɩɛ, min fɛ "sɔan, e Bali trʋ "baa 'vaa ɛn e -kɔlaman -a -pindɩ -a min -sru.»]
\s1 Zozi 'e 'kanan 'lee 'e wluannan -kanɔn 'va wɩ 'vɩ "nyian
\r (Mk 9.30-32; Lk 9.43-45)
\p 
\v 22 Yi -tʋ da te Zozi 'lee 'e -srunɔn a ciɩnan Galile 'lɛglɔn 'ji, ɛn Zozi -a 'vɩ -wlɛ 'nan: «'An 'bɔ Blamin -pɩ bɛ, o "ta -daa 'an -nɔnlɛ minnun lɛ,
\v 23 -e 'waan 'tɛ. -A yi yaagazan da -e 'an 'wluan -kanɔn 'va.» 'Wɩ zɩɛ yaa -srunɔn 'ta drɛ 'trɔdrɔ 'kpa.
\s1 Zozi 'lee Piɛri 'sukɔlɛ -pan 'wʋ
\p 
\v 24 Lɛ -tʋdʋ pɛɛnɔn man bɛ Zuif 'nɔn nɛn -klɔnmɔnnun -a bɛ, o "lala -nɔan Bali -pan 'kɔn 'le vɛ -a. -Yee "wɛan yi -tʋ da, zɩ Zozi 'lee 'e -srunɔn 'bɔla Kapanamo bɛ, minnun nɛn o "lala zɩɛ -a "sia bɛ, o pli Piɛri man, ɛn waa laabʋ -yrɔ 'nan: «"Lala nɛn minnun -a -nɔan Bali -pan 'kɔn 'le vɛ -a bɛ, 'ka 'san "e -nɔan?»
\p 
\v 25 Piɛri "e 'nan: «-Inyan, yaa -nɔan.»
\p "Bɛ -sru ɛn e wla 'kuin. -A -nan nɛn Zozi 'fɔ 'e 'flin, e 'wɩ 'gʋɛ -a laabʋ -yrɔ. Yaa laabʋ -yrɔ 'nan: «Simɔn, 'i 'ci "nrɔn 'wɩ 'gʋɛ -a da. Mingɔnnɛnnun nɛn 'trɛ 'gʋɛ -a da bɛ, -tɩnun lɔ nɛn o 'sukɔlɛ "sia? 'O 'bɔ 'le "kɔnnɛn 'nɔn 'lɔ nɛn waa "sia, -baa min peenun lɔ nɛn waa "sia?»
\p 
\v 26 Ɛn e 'nan Zozi lɛ 'nan: «Min peenun lɔ nɛn waa "sia.»
\p Zozi "e 'nan -yrɛ 'nan: «'Wɩ 'kpa nɛn, wa'a sia 'o 'bɔ 'le "kɔnnɛn 'nɔn 'lɔ dɩ.
\v 27 'Pian -te kʋa drɛ ɛn 'wɩ 'nan o man bɛ, e 'ka "yi "dɩ. -Yee "wɛan 'i 'kʋ 'yi man, 'i -kopa -fɔla 'yia. Pɔ tɛdɛ nɛn e -kopa zɩɛ -a "siala bɛ 'i -tɛ. 'I yiɛ 'tɔ -a 'le! 'Lein 'wlɛ nɛn -nan bɛ, 'i 'si -e 'i -nɔn -wlɛ 'mɛn vɛ 'lee 'yie vɛ -a.»
\c 18
\s1 -Tɩɛ cɩ Zozi -sruzan -dan a?
\r (Mk 9.33-37; Lk 9.46-48)
\p 
\v 1 Tʋ zɩɛ -a man nɛn, Zozi -srunɔn pli "man, ɛn waa laabʋ -yrɔ 'nan: «-Tɩɛ cɩ min -dan a Bali -le mingɔnnɛn trɛda?»
\p 
\v 2 Zozi 'nɛn "wɛnnɛn 'tɔ laabʋ, yaa -tɔ o yei.
\v 3 Ɛn e 'nan -wlɛ 'nan: «Maan ve 'cɛɛ 'wɩ tɩglɩ 'a 'nan, -te ka'a lilɛa -e 'ka 'fli drɛ "le nannannun -le 'wɩ 'zʋ dɩɛ, ka'a 'ko Bali -le mingɔnnɛn trɛda dɩ.
\v 4 'Pian min nɛn 'e 'fli drɛ "wɛnnɔn bɛ, Bali -le mingɔnnɛn trɛda, e ya min -dan a.
\p 
\v 5 Ɛn min oo min nɛn e min nɛn "le 'nɛn "wɛnnɛn 'zʋ -gʋ -a 'kun tɩglɩ 'mɛn "wɛan bɛ, te 'an 'bɔ nɛn yaan 'kun tɩglɩ.»
\s1 'Ka drɛ "yi -e 'ka vɩlɛ 'ka 'si Zozi -sru "dɩ!
\r (Mk 9.42-48; Lk 17.1-2)
\p 
\v 6 «Minnun nɛn o yi -tɛala 'an da "le nannannun -le 'wɩ 'zʋ bɛ, min oo min nɛn yaa drɛ ɛn -a -tʋwli "cɛ 'si 'an -sru "bɛ, -a "yi mlin -e 'o 'kɔlɛbu -dan -fɔ -a 'klan -e 'o -fɔ jemie -va.
\p 
\v 7 'Wɩ -taa "bɔlɛ 'trɛdanɔn 'gʋɛ o man, kɔɔ -wɛɛ dra -e 'mɛn minnun 'o 'si 'an -sru. 'Wɩnun nɛn waa -maan 'lɔɔ -e min 'e 'si 'an -sru "bɛ, o ya 'trɛda "kaga. 'Pian min nɛn yaa drɛ ɛn 'mɛn min -tʋ 'si 'an -sru "bɛ, 'wɩ -taa "bɔlɛ -a san man.
\v 8 -Yee "wɛan maan ve 'cɛɛ 'nan, -te 'i 'pɛ, -te 'bɛ "cɛɛ dɩ 'i 'cɛin 'bɛ -maan i 'wɩ 'wlidɩ "dra bɛ, 'i 'cɛn -e 'i tuʋ -kɔɔbli. Kɔɔ -te i -kʋ Bali va 'i 'pɛ ponɛn 'a, -te 'bɛ "cɛɛ dɩ 'i cɛin ponɛn 'a 'i man bɛ, -a "yi mlin 'i 'pɛ "fli 'lee 'i 'cɛin "fli 'o 'fʋ 'i man -e 'wei 'tuʋ 'tɛ 'va bɛ, -a da.
\v 9 Ɛn -te 'i yiɛ 'bɛ -maan 'i 'wɩ 'wlidɩ "dra bɛ, 'i 'si "ji, -e 'i tuʋ -kɔɔbli. Kɔɔ -te i -kʋ Bali va yiɛ 'tʋwli "a bɛ, 'bɛ "yi mlin 'i yiɛ "fli 'o 'fʋ "ji, -e 'wei 'tuʋ 'tɛ 'va bɛ -a da.
\p 
\v 10 'Ka drɛ "yi! Minnun nɛn o yi -tɛala 'an da "le nannannun -le 'wɩ 'zʋ bɛ, te 'ka o drɛ 'ka 'pɛla koda dɩ! Kɔɔ maan ve 'cɛɛ 'nan, Bali -le 'pasianɔn nɛn o yiɛ -tɔa "minnun zɩɛ o va bɛ o ya bodrun funnin 'o 'tɔdɩ 'an "tɩ "nɛn laji bɛ -a 'lɛ. 'Wɩ nɛn e bɔa "minnun zɩɛ o man bɛ -e 'o -nan 'sinan 'pa -yrɛ.»
\s1 -Te min 'wɩ 'wlidɩ drɛ bɛ, waa dra 'kɔ?
\r (Lk 15.3-7)
\p 
\v 11 [«'An 'bɔ Blamin -pɩ an -ta 'nan -e 'an minnun nɛn o 'san bɛ o 'si 'wɩ 'ji.]
\p 
\v 12 'Ka 'ci "nrɔn 'wɩ 'gʋɛ -a da! Min -tʋ -le 'bla a -yaa tʋ, ɛn -a -tʋ 'san "va. Yaa dra 'kɔ? Maan ve 'cɛɛ 'nan, 'bla -fuba 'sɔrasiɛn 'wlɛ 'sɔrasiɛn bɛ e 'o "tʋe zɩɛ, -e 'e 'kʋ 'bla -tʋ nɛn e 'san bɛ -a -wɛɛ.
\v 13 -Te yaa 'yɩ bɛ, -a ci "nranman. Ci "nran zɩɛ e -ciala 'bla -fuba 'sɔrasiɛn 'wlɛ 'sɔrasiɛn nɛn wa'a 'sanlɛ dɩɛ, -wee ci "nran nɛn waa -nɔan min lɛ bɛ -a da.
\v 14 'Ka "tɩ "nɛn laji bɛ, 'wɩ 'tʋwli zɩɛ -a 'bɔ nɛn yaa dra. -A ci 'sɔ "cɛɛ 'nan, minnun nɛn o yi -tɛala 'an da "le nannannun -le 'wɩ 'zʋ bɛ, o -tʋwli "cɛ 'e 'san "va "dɩ.
\p 
\v 15 -Te 'i bɔɛzan -tʋ nɛn e ya 'an -sruzan 'a "le 'yie 'wɩ 'zʋ 'nan e 'wɩ 'wlidɩ drɛ 'yiɛ bɛ, 'i 'kʋ "va -e 'ka 'nan wɩ vɩ 'ka "fli yei. -Te yei wei 'man bɛ, te yiɛ drɛ ɛn 'ka yei "sɛn 'e cin va.
\v 16 'Pian -te e 'ka "va 'nan 'yei wei maan "dɩɛ, 'i min -tʋ 'pa 'i 'va, -te 'bɛ "cɛɛ dɩ 'i min "fli 'pa 'i 'va, -e 'ka 'kʋ 'wɩ zɩɛ -a -pɛ 'pa 'e cin man o yiɛ man.
\v 17 -Te e 'ka "vale 'e 'o 'wei maan "dɩɛ, 'i 'wɩ zɩɛ -a 'pla -leglizinɔn lɛ. Ɛn -te e 'ka "vale 'e -leglizinɔn wei maan "dɩɛ, 'i "bʋɩ zɩɛ -a 'sia 'siɛn "le min nɛn e 'ka Bali -le 'nɛnnun va dɩɛ, -yee 'wɩ 'zʋ.
\p 
\v 18 Maan ve 'cɛɛ 'wɩ tɩglɩ 'a 'nan, fɛ oo fɛ nɛn kaa ve "man "cɛjɛ 'trɛ 'gʋɛ -a da bɛ, te o -cɛjɛ 'vɩ "man laji. Ɛn fɛ oo fɛ nɛn kaa "kuan 'ka 'pɛ "fli "a 'trɛ 'gʋɛ -a da bɛ, te waa 'kun o -pɛ "fli "a laji.
\p 
\v 19 Ɛn maan ve "nyian 'cɛɛ 'wɩ tɩglɩ 'a 'nan, -te ka ya min "fli ɛn 'ka 'ci drɛ -tʋwli, ka 'wɩ 'tʋ laabʋ 'an "tɩ "nɛn laji bɛ -yrɔ "bɛ, yaa -nɔan 'cɛɛ.
\v 20 Kɔɔ -te min "fli, min yaa 'o cin yɩ 'nan -e 'waan 'tɔ drɛ -dan bɛ, an ya o yei.»
\s1 -Mɛ "le "wɛan nɛn Zozizan 'e bɔɛzan man wɩ "cɛa?
\r (Lk 17.4)
\p 
\v 21 Ɛn Piɛri -a laabʋ -yrɔ 'nan: «Minsan, min nɛn e ya 'i -sruzan 'a "le 'mɛn 'wɩ 'zʋ bɛ, -te e 'wɩ 'wlidɩ drɛ 'mɛn bɛ, maan "cɛa -yrɛ 'e 'pa -a wɛa? 'An 'cɛ -yrɛ -trilii 'e 'pa -a 'sɔravli?»
\p 
\v 22 Zozi "e -yrɛ 'nan: «Yi'a dra 'e 'pa 'sɔravli "cɛ "dɩ, 'pian 'i drɛ -trilii -fuba 'sɔravli 'pa 'sɔravli.
\p 
\v 23 Fɛ -le "wɛan nɛn an 'wɩ zɩɛ -a 'vɩ bɛ, -nyrɛn 'gʋ: Bali -le mingɔnnɛn -blɩdɩ min da bɛ, e ya "le 'nan mingɔnnɛn -tʋ 'bɛ 'vɩ 'e 'wlunɔn lɛ 'nan, 'yee fiɛnnun nɛn o da bɛ, 'o 'ta -e 'e "nrɔn!
\v 24 Zɩ yaa "nrɔndɩ 'sia bɛ, ɛn o -ta min -tʋ -a -yrɛ. 'Bɛ 'ta fiɛn bɔa -mlinyɔn (1.000.000) "kaga.
\v 25 Min zɩɛ fɛ -tʋ 'ka -yrɔ -e 'e -yee "lala 'bɔ bɔla dɩ. -A -nan nɛn mingɔnnɛn zɩɛ e 'nan, 'o min 'bɔ 'tan, 'o -a nan 'lee 'yee 'nɛnnɛnnun -tan. Ɛn "nyian bɛ, o -a yɩfɛ pɛɛnɔn 'tan -e 'o 'yee "lala -mie bɔla.
\p 
\v 26 Min zɩɛ e "po -sɔɔn mingɔnnɛn bɛ -a 'wlu, ɛn e -yrɛ 'nan: ‹'An 'san, 'i yra 'si! 'I tʋ -kɔɔn 'mɛn "nyian! An 'yie "lala -wɛɛ "man -blɛblɛ -e 'an pɛɛnɔn bɔla 'yiɛ.›
\v 27 -A nyrinda -sɛn mingɔnnɛn zɩɛ -a da, ɛn e fiɛn pɛɛnɔn 'bɔ 'cɛ -yrɛ, ɛn e 'si "man.
\p 
\v 28 "Yɛɛ -kʋ bɛ, min -tʋ nɛn o 'nyranman -tʋwli "paa 'e cin va bɛ yaa 'yɩ. -Yee "lala "wɛnnɛn a 'bɛ 'lɔ fiɛn -ji. Yaa -blɔ man sɔ 'kun, ɛn e 'nan -yrɛ 'nan: ‹'Mɛn "lala nɛn 'i 'lɔ bɛ, 'i -nɔn 'mɛn!›
\p 
\v 29 Min zɩɛ e "po -sɔɔn "wlu, ɛn e toba -fɔdɩ 'sia, -yrɛ. E 'nan: ‹'I yra 'si! 'I tʋ -kɔɔn 'mɛn! An 'yie "lala -wɛɛ "man -blɛblɛ -e 'an pɛɛnɔn bɔla 'yiɛ.›
\p 
\v 30 'Pian ya'a 'wɩlɛ "man "fo "dɩ. E -kʋ -a -fɔlɛ -pʋ 'kuin. Min zɩɛ, e 'cɛn -yee "lala -nɔndɩ man 'vaa ɛn 'e bɔla.
\p 
\v 31 -A bɔɛnun -mienun nɛn o 'nyranman "paa waa 'e cin va bɛ, waa -nan 'yɩ. 'Wɩ zɩɛ e o 'kan ɛn o -kʋ -a 'sinan 'palɛ mingɔnnɛn lɛ.
\p 
\v 32 -A -nan nɛn mingɔnnɛn 'e 'suzan zɩɛ -a laabʋ "nyian, ɛn e 'nan -yrɛ 'nan: ‹'An 'suzan, i ya 'tɛɛ -wlidɩ! I toba -fɔ 'mɛn -yee "wɛan fiɛn nɛn 'i da bɛ, maan pɛɛnɔn 'cɛ 'yiɛ.
\v 33 'I bɔɛzan nyrinda "sia paan "le 'mɛin nyrinda 'si bɛ -yee 'wɩ -zʋ!›
\v 34 'Bli 'fɔ mingɔnnɛn zɩɛ -a ji -wlidɩ, ɛn yaa -nɔn minnun lɛ 'nan 'o 'kʋ 'tɛ 'pa "da -pʋ 'kuin. E cɛɛn -yee "lala -nɔndɩ man 'vaa ɛn 'e bɔla.
\p 
\v 35 -A -tʋwli "nɛn "nyian 'cee vɛ -a. -Te ka'a cin man wɩ 'cɛlɛ 'ka 'ci 'fɩdaa 'a dɩɛ, 'an "tɩ "nɛn laji bɛ 'wɩ 'tʋwli zɩɛ -nyrɛn yaa dra 'cɛɛ.»
\c 19
\s1 Zozi 'wɩ tin 'ba lɩ bɔladɩ da
\r (Mk 10.1-12; Lk 16.18)
\p 
\v 1 Zɩ Zozi cɛɛn 'wɩnun zɩɛ -a "paadɩ man 'e -srunɔn 'ji bɛ, e 'si Galile, ɛn e -kʋ Zude 'lɛglɔn 'fʋɩ nɛn Zudan 'yi -sru 'zia bɛ -a -ji.
\v 2 Min "kaga "kʋla -a -sru, ɛn minnun nɛn -cɛ cɩ o man bɛ e o beli.
\p 
\v 3 -A -nan nɛn Farizɛn 'nɔn pli "man. O 'wɩ laabʋ -yrɔ -a wei 'kundɩ -le "wɛan. Waa laabʋ -yrɔ 'nan: «-Cee -pei -tɔ wɩ -a -si -nɔn 'nan min -kɔlaman 'e nan bɔala 'wɩ pɛɛnɔn 'ji 'e "tun?»
\p 
\v 4 Ɛn Zozi "e 'nan -wlɛ 'nan: «'Wɩ nɛn e ya 'e 'crɛn -tɛdɩ Bali -le 'fluba 'ji bɛ, ka'a ta vɩlɛ dʋʋ? E ya 'e 'crɛn -tɛdɩ 'nan, 'trɛda pou sianan "bɛ, Bali -klɔnmɔn drɛ 'o 'vale lɩmɔn -a.
\v 5 Ɛn Bali -a 'vɩ "nyian 'nan:
\q1 ‹-Klɔnmɔn "sia 'e "tɩ 'lee 'e "bʋ "srɔn,
\q1 -e 'e lɛa 'e nan man,
\q1 te o drɛ min -tʋwli "a.›
\m 
\v 6 O 'ka "nyian "le min "fli "le 'wɩ 'zʋ dɩ, 'pian te o drɛ min -tʋwli "a. Min "fli zɩɛ Bali o 'pa 'e cin man. Te min 'e o 'cɛn 'e cin man "fo "dɩ!»
\p 
\v 7 Ɛn Farizɛn 'nɔn -a laabʋ -yrɔ "nyian 'nan: «-Mɛ "le "wɛan nɛn Moizi -a crɛn -tɛ "mɛn 'nan, min -kɔlaman 'e nan bɔala, 'pian yaa 'fluba dra -e 'e -nɔn -yrɛ 'vaa -e 'e bɔla?»
\p 
\v 8 Zozi "e 'nan -wlɛ 'nan: «'Ka "trɔɛn "a "yuyu, -yee "wɛan nɛn Moizi -si -nɔn 'cɛɛ 'nan 'ka lɩ bɔla. 'Pian 'trɛda pou sianan "bɛ, 'wɩ zɩɛ e 'ka -nan dɩ.
\v 9 'An 'bɔ maan ve 'cɛɛ 'nan, min oo min nɛn 'e nan 'bɔla, te -kɔnnɛn -wɛɛdɩ man "cɛɛ dɩ, ɛn e lɩ pee 'pa bɛ, te e 'wɩ 'wlidɩ drɛ 'e nan 'tʋɩdɩ -a ɛn e lɩ pee wɛɛ.»
\p 
\v 10 Ɛn -a -srunɔn 'a 'vɩ -yrɛ 'nan: «-Te 'wɩ zɩɛ -yɛɛ cɩ -klɔnmɔn 'lee lɩmɔn yei "bɛ, "te e ya 'wɩ "yi "a -e min 'e vɩlɛ 'e lɩ 'pa dɩ!»
\p 
\v 11 Zozi "e 'nan -wlɛ 'nan: «'Wɩ nɛn an "sia -a vɩnan 'gʋɛ, min pɛɛnɔn 'ka -a -ci maan dɩ, 'pian minnun nɛn Bali -a -ci 'si -wlɛ "bɛ, -wɛɛ -ci maan.
\v 12 Min -mienun a bɛ, o "bʋ "o -ya te o 'ka -klɔnmɔn -a dɩ. Ɛn min -mienun a bɛ, min 'bɛ o "saa -e 'o 'si -klɔnmɔn -va. Ɛn min -mienun a bɛ, o 'ka "vale 'o lɩ "paa dɩ -e 'o Bali -le 'nyranman 'pa 'kpa. Min nɛn e 'wɩ 'ci maan "bɛ 'e man.»
\s1 Zozi -fɛa 'vɩ nannannun man
\r (Mk 10.13-16; Lk 18.15-17)
\p 
\v 13 Minnun a -tanan nannannun -a Zozi lɛ, -e 'e 'pɛ 'pla o da, -e 'e Bali trʋ 'ba -wlɛ 'nan Bali 'e -fɛa vɩ o man. -A -nan nɛn -a -srunɔn 'si -tɔ -wlɔ 'nan 'o 'li 'o da.
\p 
\v 14 Ɛn Zozi "e 'nan -wlɛ 'nan: «'Ka nannannun 'tʋɩ 'o 'ta 'an 'va, te 'ka 'si -tɔ -wlɔ "dɩ! Kɔɔ minnun nɛn "le -wee 'wɩ 'zʋ bɛ, Bali -le mingɔnnɛn trɛ a -wee vɛ -a.»
\v 15 'E 'pɛ 'pla o da. "Bɛ -sru ɛn e -kʋ fɛ pee -nan.
\s1 -Gobonɛn fɛzan -tʋ -le 'wɩ
\r (Mk 10.17-31; Lk 18.18-30)
\p 
\v 16 Yi -tʋ da bɛ, -gobonɛn 'tʋ pli Zozi man, ɛn e 'wɩ 'gʋɛ -a laabʋ -yrɔ. Yaa laabʋ -yrɔ 'nan: «Bali -le 'wɩ "paazan! 'Wɩ "yi "kɔ "nɛn maan dra, -e an 'belidɩ nɛn ya'a 'nyaan dɩɛ -a yɩ?»
\p 
\v 17 Zozi "e -yrɛ 'nan: «-Mɛ "le "wɛan nɛn yia laabo 'an 'lɔ 'nan, 'wɩ "cɛn 'bɛ cɩ "yi -e 'i drɛ? Bali -tʋwli 'bɛ cɩ "yi. -Te i ya "vale 'i 'belidɩ nɛn ya'a 'nyaan dɩɛ, -a ye bɛ, 'i 'ta wʋla -yee -pei -tɔ wɩnun da.»
\p 
\v 18 Ɛn -gobo zɩɛ yaa laabʋ Zozi 'lɔ 'nan: «-Yee -pei -tɔ wɩnun 'bɔ "cɛn?»
\p Ɛn Zozi "e 'nan -yrɛ 'nan: «Te 'i drɛ min -tɛzan -a dɩ! Te 'i min nan -wɛɛ "dɩ! Te 'i crin wʋ dɩ! Te 'i 'wlu -sɛn min man dɩ!
\v 19 'I yiɛ 'e 'nan 'i "tɩ 'lee 'i "bʋ "man! Ɛn 'i bɔɛzan -tʋ yɩ "yi "le 'yie 'wɩ 'zʋ!»
\p 
\v 20 -Gobonɛn bɛ, e 'nan Zozi lɛ 'nan: «'Wɩ pɛɛnɔn zɩɛ -a da nɛn an 'ta wʋla. -Mɛ "wɩ 'bɛ klɩ 'an man "nyian?»
\p 
\v 21 Ɛn Zozi "e 'nan -yrɛ 'nan: «-Te i ya "vale 'yie 'wɩ 'e 'kɔn tɩglɩ Bali 'lɛ bɛ, 'i 'kʋ, fɛnun nɛn 'i 'lɔ bɛ, 'i -tan, -e 'i man "lala -pli 'yalɛ -tɛnɔn man. E ya "le i ya 'i yɩfɛ planan "laji. "Bɛ -sru -e 'i -sɔɔnla 'an -sru.»
\p 
\v 22 Zɩ -gobonɛn 'wɩnun zɩɛ -a 'man bɛ, -a 'ta drɛ -trɔdrɔ, ɛn e -kʋdɩ 'sia. -A yɩfɛnun a "kaga "le "wɛan.
\p 
\v 23 Ɛn Zozi 'a 'vɩ 'e -srunɔn lɛ 'nan: «Maan ve 'cɛɛ 'wɩ tɩglɩ 'a 'nan, fɛzan -le drɛdɩ Bali -le mingɔnnɛn trɛdavɛ -a bɛ, e ya 'plɛblɛ.
\v 24 Ɛn maan ve "nyian 'cɛɛ 'nan, -wi -dan nɛn waa laabo shamo bɛ, ya'a -kɔlaman -wladɩ -a 'mɛnzrɛn -yrɛ ji dɩ. -A -tʋwli "nɛn "nyian fɛnɔn 'le vɛ -a. Drɛdɩ Bali -le mingɔnnɛn trɛdavɛ -a bɛ, e ya -wlɔ 'plɛblɛ 'wlidɩ.»
\p 
\v 25 Zɩ -a -srunɔn 'wɩnun zɩɛ -a 'man bɛ, e wla o man -wlidɩ, ɛn waa laabʋ -yrɔ 'nan: «-Te 'bɛ a zɩɛ, -tɩɛ -kɔlaman -e 'e 'si 'wɩ 'ji "mɛn?»
\p 
\v 26 Zozi o -nanjɛɛn, ɛn e 'nan -wlɛ 'nan: «Min 'ka 'kɔlaman 'e 'fli 'sidɩ -a 'wɩ 'ji dɩ, 'pian Bali -kɔlaman 'wɩ pɛɛnɔn drɛdɩ -a.»
\p 
\v 27 -A -nan nɛn Piɛri "e -yrɛ 'nan: «Kʋ 'si fɛ pɛɛnɔn -sru, ɛn kʋ sɔɔnla 'i -sru. -Mɛ "nɛn "kʋ "ye -ji?»
\p 
\v 28 Ɛn Zozi e 'nan -wlɛ 'nan: «Maan ve 'cɛɛ 'wɩ tɩglɩ 'a 'nan, tʋ nɛn fɛnun pɛɛnɔn dra 'e 'trɛ, te 'an 'bɔ Blamin -pɩ an ya 'an -nyrandɩ 'mɛn tin 'ba pɛin -dan da bɛ, kaa nɛn ka 'ta 'wʋla 'an -sru "bɛ, ka -kɔan 'ka -nyrandɩ "nyian mingɔnnɛn pɛin -fuda "fli "da, ɛn cɛɛ Izraɛl 'lɛglɔn 'fuda "fli "le tin "baa.
\v 29 Ɛn min oo min nɛn 'mɛn "wɛan e 'si 'e 'fla, -te 'bɛ "cɛɛ dɩ e 'si 'e "bʋɩnun -sru, -te 'bɛ "cɛɛ dɩ e 'si 'e "blunun -sru, -te 'bɛ "cɛɛ dɩ e 'si 'e "tɩ 'lee 'e "bʋ -sru, -te 'bɛ "cɛɛ dɩ e 'si 'e nan 'lee 'yee 'nɛnnun -sru, -te 'bɛ "cɛɛ dɩ e 'si 'yee -yɔ -sru "bɛ, -a san zɩɛ yaa pɛɛnɔn zɩɛ -a ye 'e 'pa -a -yaa tʋ. Ɛn 'belidɩ nɛn ya'a 'nyaan dɩɛ, e dra -yee vɛ -a.
\v 30 Minnun nɛn o -trɔa 'si 'lɛ bɛ, o "kaga -taa "fɔlɛa "da, ɛn minnun nɛn o -fɔla "da "bɛ, o "kaga -taa "drɛlɛ -si 'lɛnɔn 'a.»
\c 20
\s1 'Nyranman 'panɔn 'man -kɔnnɛn
\p 
\v 1 Zɩ Zozi 'wɩ zɩɛ -a 'vɩ bɛ, ɛn e -kɔnnɛn "tʋ -fɔ -wlɛ. Yaa 'vɩ -wlɛ 'nan: «Bali -le mingɔnnɛn -blɩdɩ min da bɛ, -nyrɛn 'gʋ, e ya "le fei san -tʋ 'bɛ 'bɔla bodrun puunɔn ɛn e minnun -wɛɛdɩ 'sia 'nan -e 'o 'kʋ 'nyranman 'pa 'yee rɛzɛn fei.
\v 2 E min -mienun 'yɩ, ɛn o wei drɛ waa -tʋ 'nan yi -tʋ nyranman -pan nɛn 'e -nɔan -wlɛ. Ɛn o -kʋ 'yee fei zɩɛ -a da.
\p 
\v 3 E 'bɔla "nyian te bodrun yidɛ wluan loulou 'kpa. Ɛn e min -mienun 'yɩ 'o -nyrandɩ -guada, te 'nyranman 'ka -wlɔ -e 'o 'pa dɩ.
\v 4 Ɛn "e 'nan -wlɛ 'nan: ‹'Ka 'kʋ 'nyranman 'pa 'mɛn fei! Maan man -ko "paa 'cɛɛ.›
\v 5 -A -nan nɛn minnun zɩɛ o -kʋ -yee rɛzɛn fei.
\p Fei san zɩɛ e 'bɔla "nyian te yidɛ 'bɔ min -win -ji 'sɛzɛ, ɛn e 'bɔla "nyian te funninmlan yidɛ tɛɛnla. Minnun nɛn e 'bɔ o man bɛ, 'wɩ 'tʋwli zɩɛ -nyrɛn yaa 'vɩ -wlɛ.
\v 6 Zɩ yidɛ 'pla plɔ da bɛ, ɛn e 'bɔla "nyian, e 'bɔ min -mienun man -guada, ɛn yaa laabʋ -wlɔ 'nan: ‹-Mɛ "le "wɛan nɛn ka -fʋ 'ka -nyrandɩ bodrun 'trilii funninmlan, ɛn ka'a 'nyranman 'tʋ 'palɛ dɩ?›
\p 
\v 7 O 'nan -yrɛ 'nan: ‹Min -tʋ 'ka 'kʋ 'silɛ 'nan 'kʋ 'yee 'nyranman 'pa dɩ.›
\p Ɛn fei san "e 'nan -wlɛ 'nan: ‹'Ka 'kʋ 'nyranman 'pa 'mɛn rɛzɛn fei!›
\p 
\v 8 Zɩ funninmlan 'pla bɛ, ɛn fei san zɩɛ e min nɛn e yiɛ -tɔa 'yee 'nyranman 'panɔn 'va bɛ -a laabʋ. E 'nan -yrɛ 'nan: ‹'I 'nyranman 'panɔn pɛɛnɔn laabʋ -e 'i o -ko 'pa. 'I 'sia minnun nɛn o -fɔla "da "bɛ o da -e 'i 'le 'sran minnun nɛn o -trɔa -si 'lɛ bɛ o da.›
\p 
\v 9 -A -nan nɛn minnun nɛn o -kʋ 'nyranman 'palɛ te yidɛ 'pla plɔ da bɛ o -ta, ɛn e yi -tʋ nyranman man "lala -nɔn o pɛɛnɔn lɛ.
\v 10 Yaa drɛ zɩɛ -trilii ɛn e 'bɔ minnun nɛn o -trɔa -si 'lɛ bɛ o da. -A -cin a o ji 'nan 'o -kopa -taa 'ciɩlɛa "da, 'pian yi -tʋ nyranman man "lala nɛn waa 'yɩ 'o pɛɛnɔn.
\p 
\v 11 -A -nan nɛn o 'wɩ 'blɩdɩ 'sia fei san va.
\v 12 Waa 'vɩ -yrɛ 'nan: ‹Minnun nɛn o -ta 'e -fɔla "da 'gʋɛ, wa'a 'mɔnlɛ 'nyranman 'panan "fo "dɩ. 'Kʋ 'bɔ nɛn kʋ 'nyranman 'pa yi -tʋ "fo, ɛn kʋ -fʋ yidɛa "trilii bɛ, i 'kʋ 'pan 'bɔ waa 'e cin man. -Mɛ "le "wɛan yaa drɛ zɩ?›
\p 
\v 13 Ɛn fei san 'wɩ 'si "va o va min -tʋ lɛ. Yaa 'vɩ -yrɛ 'nan: ‹'An bee! Ma'an 'wɩ 'wlidɩ "drɛlɛ 'yiɛ dɩ. Yi -tʋ nyranman "lala da nɛn 'kʋ wei -tria, -njɛɛ dʋʋ?
\v 14 -Yɛɛ cɩ 'yie vɛ -a, 'i 'si -e 'i 'kʋ. Min nɛn e -fɔla "da "bɛ, -te maan -ko "paa "le 'yie 'wɩ 'zʋ oo, e "siala 'an 'bɔ 'a.
\v 15 'Wɩ nɛn e 'sɔ 'an 'ji bɛ, -a 'bɔ nɛn maan dra 'an yɩfɛ -a. -Te an "yi drɛ min lɛ bɛ, -mɛ drɛ -a 'wɩ "naan 'i man?› »
\p 
\v 16 Ɛn Zozi 'a 'le 'sran -wlɛ 'nan: «Minnun nɛn o -fɔla "da "bɛ, zɩ o -taa "drɛlɛ -si 'lɛnɔn 'a zɩɛ, ɛn minnun nɛn o -trɔa -si 'lɛ bɛ, zɩ o -taa "fɔlɛa "da zɩɛ.»
\s1 Zozi 'e 'kanan 'lee 'e wluandɩ -kanɔn 'va wɩ 'pa yaagazan 'vɩ
\r (Mk 10.32-34; Lk 18.31-34)
\p 
\v 17 Zozi 'lee 'e -srunɔn a -kʋnan Zeruzalɛm. -A -nan nɛn Zozi 'e -srunɔn 'fuda "fli laabʋ 'o 'saza, ɛn e 'nan -wlɛ 'nan:
\v 18 «-Kaa "ta -ko Zeruzalɛm 'gʋɛ, minnun 'an 'bɔ Blamin -pɩ -nɔan Bali -pannɔn 'tanɔn 'lee 'fluba 'ci vɩnɔn lɛ. O tin -tɛa 'an da -e 'an 'ka -a 'wɩ 'ji.
\v 19 Waan -nɔan "minnun nɛn o 'ka Zuif 'nɔn 'a dɩɛ -wlɛ. Minnun zɩɛ waan sɛɛ wo, waan -sɔan -ngble -a, ɛn waan -pɛinman yiba "plan da -e 'an 'ka. 'Pian -a yi yaagazan da bɛ, -e 'an 'wluan -kanɔn 'va.»
\s1 Zaji 'lee 'e "bʋɩ Zan bɛ, o "bʋ "fɛ -tʋ -si laabʋ Zozi 'lɔ
\r (Mk 10.35-45; Lk 22.24-27)
\p 
\v 20 "Bɛ -sru ɛn Zebede nan pli Zozi man 'o 'vale -yee 'nɛnnun -a. E "po sɔɔn Zozi 'wlu 'nan -e 'e 'wɩ 'tʋ -si laabʋ -yrɔ.
\p 
\v 21 Ɛn Zozi 'a laabʋ -yrɔ 'nan: «-Mɛ 'va nɛn i cɩ?»
\p Lɩ zɩɛ e 'nan Zozi lɛ 'nan: «'Mɛn 'nɛnnun "fli 'gʋɛ, tʋ nɛn i dra mingɔnnɛn -a bɛ, 'i 'wɩ "man -e 'o -nyran 'i "srɔn. -A -tʋ 'e -nyran 'i 'pɛ "yi "da, -e -a -tʋ 'e -nyran 'i 'pɛ bʋ da.»
\p 
\v 22 Ɛn Zozi "e 'nan -wlɛ 'nan: «'Wɩ nɛn ka cɩ -a laabʋnan bɛ, ka'a 'ci tɔa dɩ. 'Wɩ yɩdɩ nɛn e "ta -daa "bɔlɛ 'an man bɛ, 'ka 'wulo "sɔa "wlu?»
\p Ɛn -yee 'nɛnnun 'bɔ -a 'vɩ -yrɛ 'nan: «-Inyan, 'kʋ 'wulo "sɔa "wlu.»
\p 
\v 23 Zozi "e 'nan -wlɛ 'nan: «'Wɩ 'kpa nɛn, 'wɩ nɛn e "ta -daa "bɔlɛ 'an man 'gʋɛ e bɔa "nyian "cee "man. 'Pian -nyrandɩ 'an 'pɛ "yi 'lee 'an 'pɛ bʋ da bɛ, 'an 'bɔ "cɛɛ -si -nɔan "min lɛ dɩ. Minnun nɛn 'an "tɩ -a pla o 'tɔ man bɛ -wee vɛ 'bɛ cɩ -a.»
\p 
\v 24 Zozi -srunɔn 'fu nɛn o -fʋ bɛ, zɩ o 'wɩ zɩɛ -a 'man bɛ, ɛn 'bli 'fɔ o ji Zan 'lee 'e "bʋɩ Zaji man.
\v 25 -A -nan nɛn Zozi o pɛɛnɔn laabʋ, ɛn e 'nan -wlɛ 'nan: «Kaa -tɔa 'nan, 'trɛda mingɔnnɛnnun min "paala -sa wɩ -a. Ɛn minnun nɛn o cɩ min -dandannun -a bɛ, o -va -ble minnun da.
\v 26 'Pian te 'wɩ zɩɛ -nyrɛn 'e 'kɔn 'ka yei "dɩ. Min oo min nɛn e ya "vale 'e dra min -dan a 'ka yei "bɛ, 'e 'fli 'pla 'ka pɛɛnɔn 'wlu o 'sudɩ -a!
\v 27 Ɛn min oo min nɛn e ya "vale 'e dra 'ka 'tazan -a bɛ, 'e 'fli drɛ 'ka pɛɛnɔn 'le nɔan -a!
\v 28 'Wɩ 'tʋwli zɩɛ -a 'bɔ nɛn an 'bɔ Blamin -pɩ maan drɛ. Ma'an 'talɛ 'nan -e minnun 'waan 'su dɩ, 'pian an -ta 'nan -e 'an minnun 'su. Ɛn an -ta 'nan -e 'an 'ka -e min "kaga 'o 'sʋ Satan -le 'plɛblɛ 'lɔ.»
\s1 Zozi yiɛ 'winɔn "fli yiɛ 'lɛ 'sʋ
\r (Mk 10.46-52; Lk 18.35-43)
\p 
\v 29 Zɩ Zozi 'lee 'e -srunɔn 'si Zeriko bɛ, min "kaga 'kpa sɔɔnla o -sru.
\v 30 Yiɛ 'winɔn "fli "a 'o -nyrandɩ -si man, waa 'man 'nan Zozi a ciɩnan, ɛn o -paandɩ 'sia. O paan 'nan: «Minsan, David kluda min, 'kʋ nyrinda 'e 'sɛn 'i da!»
\p 
\v 31 Ɛn minnun paan o da 'nan 'o 'lɛbo 'pla da. 'Pian yiɛ 'winɔn zɩɛ o paan "nyian 'plɛblɛ 'kpa. O paan 'nan: «Minsan, David kluda min, 'kʋ nyrinda 'e 'sɛn 'i da!»
\p 
\v 32 Zozi 'tɔ, e o laabʋ, ɛn e 'nan -wlɛ 'nan: «Ka ya "vale 'an drɛ 'cɛɛ 'kɔ?»
\p 
\v 33 O 'nan -yrɛ 'nan: «Minsan, kʋ ya "vale 'i 'kʋ yiɛ 'lɛ 'sʋ!»
\p 
\v 34 O nyrinda -sɛn Zozi da, -a -nan nɛn 'e 'pɛ klɛ o yiɛ man, 'nun tɔɔn o yiɛ 'lɛ 'sʋ, ɛn o sɔɔnla -a -sru.
\c 21
\s1 Zozi 'bɔla Zeruzalɛm
\r (Mk 11.1-11; Lk 19.28-40; Zan 12.12-19)
\p 
\v 1 Zozi 'lee 'e -srunɔn a -plinan Zeruzalɛm. O 'bɔ 'fla nɛn waa laabo Befaze bɛ -a "srɔn. 'Fla zɩɛ e ya Olivie pɔn man. Ɛn Zozi 'e -srunɔn "fli 'pa 'sia 'o 'lɛ.
\v 2 Yaa 'vɩ -wlɛ 'nan: «'Ka 'kʋ 'fla nɛn 'ka 'lɛ bɛ -a da! -Te 'ka 'bɔla 'nan nun bɛ, ka -aflumun "bʋ "tʋ 'lee -yee 'nɛn ye 'o 'baa -tɔdɩ. 'Ka o baa 'sʋ -e 'ka 'ta waa 'mɛn!
\v 3 -Te min -tʋ 'wɩ laabʋ 'ka 'lɔ bɛ, 'ka vɩ -a san lɛ 'nan: ‹Minsan "e 'nan -aflumun 'wɩ a 'e man.› 'Nun tɔɔn 'e 'pɛ sia "da -e 'ka 'ta -a.»
\p 
\v 4 'Wɩ pɛɛnɔn zɩɛ, e drɛ 'wɩ nɛn Bali 'lewei vɩzan -a 'vɩ 'e 'cɛn bɛ -a 'lɛ sɔɔdɩ -a. Kɔɔ yaa 'vɩ 'nan:
\q1 
\v 5 «'Ka vɩ Zeruzalɛm 'nɔn lɛ 'nan:
\q1 "Ka 'yiɔ, 'cee mingɔnnɛn a -tanan 'ka 'va!
\q1 E -taala 'e man -trɔɔ.
\q1 E ya 'e -nyrandɩ -aflumun da.
\q1 -Aflumun nɛn e -trɔ "siala bɛ,
\q1 -a 'nɛn da nɛn e ya 'e -nyrandɩ.»
\p 
\v 6 Zozi -srunɔn "fli zɩɛ o 'kʋ, ɛn 'wɩ nɛn yaa 'vɩ -wlɛ "bɛ waa drɛla "da.
\v 7 O -ta -aflumun "bʋ 'lee -yee 'nɛn 'a, o 'wee sɔnun -sɛn "da, ɛn Zozi -nyran "da.
\v 8 Minnun "kaga 'wee sɔnun paala -a 'lɛ. Ɛn min -mienun yiba "pɛnɛnnun cɛɛn, ɛn waa 'pla -a 'lɛ. Zɩ "o min -dan "siala zɩɛ.
\v 9 Min "kaga yra -a 'lɛ, ɛn min "kaga -fɔla "da -a koda, te o pɛɛnɔn plaman 'e cin va. Waa ve 'nan:
\q1 «-Fɛavɛa o! -Fɛavɛa o!
\q1 David kluda min -le -fɛavɛa o!
\q1 Bali -le -fɛa 'e 'kɔn min nɛn
\q1 Minsan -a 'pa 'sia bɛ -a man.
\q1 Bali 'tɔ 'e drɛ -dan laji lou!»
\p 
\v 10 Zɩ e 'bɔla Zeruzalɛm bɛ, -wee pladɩ Zeruzalɛm 'si "fo, ɛn 'flanɔn pɛɛnɔn 'man nyɔɔn -a laabʋdɩ -a 'nan: «-Tɩ nɛn min 'bɔ 'labɛ -a?»
\p 
\v 11 Minnun "kaga "nɛn waa si -fɔ bɛ, o 'nan: «Zozi nɛn! Bali 'lewei vɩzan nɛn, e "sia Nazarɛtɩ Galile 'lɛglɔn 'ji.»
\s1 Zozi fɛnun -tannɔn 'pin Bali -pan 'kuin
\r (Mk 11.15-19; Lk 19.45-48; Zan 2.13-17)
\p 
\v 12 "Bɛ -sru ɛn Zozi 'kʋ Bali -pan 'kuin. Minnun nɛn o ya Bali -pan fɛnun -tannan 'lee minnun nɛn o ya -a 'lɔnan Bali -pan 'kuin bɛ, e o -pin. E "lala ta -fɔɔnɔn 'le 'tablonun 'lee -plablo -tannɔn 'le pɛinnun fuila "man.
\v 13 Ɛn e 'nan -wlɛ 'nan: «E ya e 'crɛn -tɛdɩ Bali -le 'fluba 'ji 'nan, Bali "e 'nan: ‹'Mɛn 'kɔn -kɔan 'an trʋ 'ba 'kɔn 'a.› 'Pian kaa drɛ 'cee crin wʋnan -a.»
\p 
\v 14 "Bɛ -sru ɛn yiɛ 'winɔn 'lee minnun nɛn o "tun "bo bɛ, o pli Zozi man Bali -pan 'kuin, ɛn e o beli.
\v 15 Bali -pannɔn 'tanɔn 'lee 'fluba 'ci vɩnɔn 'wɩ -dandan nɛn Zozi cɩ -a drɛnan bɛ -a -nan 'yɩ. Ɛn o nannannun 'yɩ "nyian te o plaman Bali -pan 'kuin -a vɩdɩ -a 'nan: «Bali David kluda min 'tɔ drɛ -dan!»
\p -A 'wɩ 'nan o man,
\v 16 ɛn o 'wɩ 'pla Zozi lɛ. Waa 'vɩ -yrɛ 'nan: «'Wɩ nɛn o cɩ -a vɩnan 'labɛ, yi'a maan dʋʋ?»
\p Ɛn Zozi "e 'nan -wlɛ 'nan: «Maan maan. -Mɛ "le "wɛan nɛn ka 'wɩ zɩɛ -a laabʋ 'an 'lɔ? 'Wɩ nɛn 'e 'crɛn -tɛdɩ Bali -le 'fluba 'ji bɛ ka'a tian -a ta vɩlɛ dʋʋ? Kɔɔ e ya 'e 'crɛn -tɛdɩ 'nan:
\q1 ‹Yia drɛ ɛn nannannun 'lee 'nyɔnmlin 'nɛnnun 'i 'tɔ "yi 'vɩ.› »
\p 
\v 17 -A -nan nɛn e o 'tʋɩ, ɛn e 'si Zeruzalɛm. E -kʋ 'fla nɛn waa laabo Betani bɛ -a da, e 'nyin 'nan nun.
\s1 Yiba "tʋ nɛn ya'a 'baa dɩɛ Zozi -a -tɛ
\r (Mk 11.12-14, 20-25)
\p 
\v 18 Tʋ cɛɛn bodrun ɛn Zozi Zeruzalɛm si 'sia "nyian. "Yɛɛ -kɔn -kʋnan 'sia bɛ, -a -nan nɛn dra -a -tɛdɩ 'sia.
\v 19 E fijie yiba 'yɩ 'si man, ɛn e pli "man 'nan -e 'e 'blʋ -mie 'cɛn 'e -blɩ. 'Pian -a 'la 'saza nɛn yaa 'yɩ "da, ɛn e 'nan fijie yiba zɩɛ -yrɛ 'nan: «Te 'i 'blʋ -tʋwli 'e ba 'i man 'li "fo "dɩ!» 'Nun tɔɔn fijie yiba 'bɔ 'ka.
\p 
\v 20 Zɩ -a -srunɔn 'wɩ zɩɛ -a -nan 'yɩ bɛ, o 'lɛbo "fɔ, ɛn o 'nan -yrɛ 'nan: «E drɛ 'kɔ, ɛn fijie yiba "ka 'nun zɩɛ?»
\p 
\v 21 Zozi "e 'nan -wlɛ 'nan: «Maan ve 'cɛɛ 'wɩ tɩglɩ 'a 'nan, -te ka yi -tɛala Bali da bɛ, ɛn "nyian -te ka'a 'ci -fɔɔman dɩɛ, 'wɩ nɛn maan drɛ fijie yiba 'labɛ -yrɛ "bɛ, 'ka 'pɛ "sɔa -a drɛdɩ -a. Ɛn "nyian -te kaa 'vɩ pɔn 'labɛ -yrɛ 'nan: ‹'I 'sʋra 'gʋ, 'i 'kʋ -trɔa jemie -va bɛ›, yaa dra.
\v 22 -Te ka yi -tɛala Bali da, ɛn ka fɛ -tʋ laabʋ -yrɔ -a trʋ 'badɩ -a bɛ, kaa ye.»
\s1 Zozi 'le -kɔladɩ "sia nyin zia?
\r (Mk 11.27-33; Lk 20.1-8)
\p 
\v 23 "Bɛ -sru ɛn Zozi 'kʋ Bali -pan 'kuin, e 'wɩ "paadɩ 'sia minnun -ji. -A -nan nɛn Bali -pannɔn 'tanɔn 'lee min cejenun -ta, ɛn waa laabʋ -yrɔ 'nan: «-Kɔladɩ "cɛn "a nɛn i 'wɩnun zɩɛ -a drɛ? Ɛn -tɩɛ -si -nɔn 'yiɛ?»
\p 
\v 24 Zozi "e 'nan -wlɛ 'nan: «An 'bɔ "nyian an "ta 'wɩ 'tʋwli "cɛ laabo 'ka 'lɔ. -Te kaa -sru 'vɩ 'mɛn bɛ, -kɔladɩ nɛn an 'wɩnun zɩɛ -a drɛ 'a bɛ, maan -ci "sia 'cɛɛ.
\v 25 -Tɩɛ Zan 'pa 'sia 'nan 'e 'ta min -batize drɛ? Minnun 'bɛ 'pa 'sia, -baa Bali 'bɛ 'pa 'sia? 'Ka vɩ 'mɛn!»
\p -A -nan nɛn waa vɩdɩ 'sia 'o cin yei 'nan: «-Te -kaa 'vɩ 'nan: ‹Bali 'bɛ 'pa 'sia bɛ›, e -taa -a laabʋlɛ -kaa 'lɔ 'nan: ‹-Mɛ "le "wɛan nɛn ka'a yi -tɛala 'wɩ nɛn Zan -a 'vɩ bɛ -a da dɩ?›
\v 26 Ɛn -te -kaa 'vɩ 'nan: ‹Minnun 'bɛ 'pa 'sia bɛ›, minnun pɛɛnɔn -taa 'wunlɛa -kaa man, kɔɔ o pɛɛnɔn Zan "siala Bali 'lewei vɩzan -a.»
\p 
\v 27 -A -nan nɛn waa 'vɩ Zozi lɛ 'nan: «Kʋ'a san -tɔa dɩ.»
\p Ɛn Zozi "e 'vɩ "nyian -wlɛ 'nan: «An 'bɔ "nyian min nɛn e -si -nɔn 'mɛn ɛn an 'wɩnun zɩɛ -a drɛ bɛ, ma'an -ci sia 'cɛɛ dɩ.»
\s1 Zozi -kɔnnɛn "fɔ 'nɛn 'klɔnmɔn "fli "man
\p 
\v 28 «'Ka 'ci "nrɔn 'wɩ 'gʋɛ -a da! Min -tʋ a, ɛn 'yee 'nɛn 'klɔnmɔnnun a 'fiili. Yi -tʋ da bɛ yaa 'vɩ -a ceje 'nɛnzan lɛ 'nan: ‹'Mɛn 'nɛn 'i 'kʋ 'nyranman 'pa cɛɛgʋ 'mɛn rɛzɛn fei.›
\p 
\v 29 -Yee 'nɛn zɩɛ e 'nan -yrɛ 'nan: ‹Ma'an 'ko dɩ›. 'Pian "bɛ -sru -a ci lila, ɛn e -kʋ.
\p 
\v 30 'Wɩ 'tʋwli zɩɛ yaa 'vɩ "nyian 'yee 'nɛn 'fɔla "dazan lɛ. 'Nɛn zɩɛ e wɩɩ "man. Yaa 'vɩ 'e "tɩ "lɛ 'nan: ‹'An "tɩ, maan 'man›, 'pian "bɛ -sru ya'a 'kʋlɛ dɩ.
\p 
\v 31 'Nɛnnun "fli zɩɛ o yei "bɛ, -tɩɛ 'e "tɩ "ci 'sɔ wɩ drɛ?»
\p Minnun tanɔn nɛn o cɩ 'wɩ zɩɛ -a mannan bɛ, o -yrɛ 'nan: «'Nɛn ceje 'nɛnzan nɛn.»
\p Ɛn Zozi "e 'nan -wlɛ "nan: «Maan ve 'cɛɛ 'wɩ tɩglɩ 'a 'nan, 'sukɔlɛ 'sinɔn 'lee -kɔnnɛn -wɛɛnɔn -tɔala 'ka 'lɛ -wladɩ -a Bali -le mingɔnnɛn trɛda.
\v 32 Zan -ta -si tɩglɩ -kɔɔnlɛ 'cɛɛ, ɛn ka'a yi -tɛlɛa 'wɩ nɛn yaa 'vɩ bɛ -a da dɩ. 'Pian 'sukɔlɛ 'sinɔn 'lee -kɔnnɛn -wɛɛnɔn yi -tɛra "da. 'Wɩ zɩɛ kaa -nan 'yɩ, 'pian ka'a 'wɩlɛ "man -e 'ka yi -tɛra 'wɩ nɛn Zan -a 'vɩ bɛ -a da, -e 'ka 'si 'wɩ 'wlidɩ "drɛdɩ man dɩ.»
\s1 Zozi -kɔnnɛn "fɔ rɛzɛn fei 'panɔn man
\r (Mk 12.1-12; Lk 20.9-19)
\p 
\v 33 «'Ka "trɔɛn "tɔ -kɔnnɛn "pee lɛ: Min -tʋ 'bɛ 'yee rɛzɛn fei 'pa, e -klɔn 'bʋ "man, e rɛzɛn 'blʋnan drɛ, ɛn e fɛ -tʋ drɛ, min -tɔa "da -e 'e fei 'bɔ 'ta -pin. "Bɛ -sru e fei zɩɛ -a -pɛba 'wʋ minnun lɔ 'nan 'o 'nyranman 'pa "da, te o 'yee vɛ -nɔan. Yaa drɛ zɩɛ, ɛn e -kʋ 'lɛglɔn 'kɔɔbli 'tʋ da.
\v 34 Zɩ rɛzɛn nan tʋ 'bɔ bɛ, ɛn min zɩɛ 'e 'sunɔn 'pa 'sia minnun nɛn o 'nyranman "paa 'yee rɛzɛn fei bɛ o va, 'nan 'nyranman nɛn waa 'pa bɛ 'o 'yee vɛ -nɔn.
\p 
\v 35 Fei 'panɔn zɩɛ waa 'sunɔn 'bɔ kuun. Waa -tʋ -sɔn, waa -tʋ -tɛ, ɛn waa yaagazan -tɛ -kɔlɛnun -a.
\v 36 Fei san zɩɛ e 'sunɔn 'pa 'sia "nyian. O "kaga "mlian minnun nɛn o -kʋ 'e tɛdɛ bɛ o da. 'Wɩ 'tʋwli zɩɛ -a 'bɔ nɛn fei 'panɔn -a drɛ -wlɛ.
\p 
\v 37 "Bɛ -sru ɛn 'e 'pɩ 'pa 'sia o va. 'E 'ci nrɔn 'nan, o yiɛ -taa 'nanlɛ 'e 'pɩ man.
\p 
\v 38 'Pian zɩ fei 'panɔn -yee 'nɛn zɩɛ -a 'yɩ bɛ, ɛn waa 'vɩ 'o cin yei 'nan: ‹Min 'labɛ -yɛɛ 'e "tɩ -zia -ble. -Kaa -tɛ, -e -zia zɩɛ 'e drɛ -cee vɛ -a.›
\v 39 -A -nan nɛn waa 'kun, o ciɩ 'a -klɔn -sru, ɛn waa -tɛ.
\p 
\v 40 Maan laabo 'ka 'lɔ 'nan, -te fei san zɩɛ e -ta bɛ, yaa dra 'yee fei 'panɔn lɛ 'kɔ?»
\p 
\v 41 Ɛn minnun tanɔn nɛn o cɩ 'wɩ zɩɛ -a mannan bɛ, o 'nan -yrɛ 'nan: «Min -wlidɩnun zɩɛ, e o -tɛɛman "le 'nan plɔannɔn 'le 'wɩ 'zʋ. "Bɛ -sru -e 'e 'yee fei -pɛba wʋ min peenun lɔ. Yaa -pɛba wo minnun nɛn -te o 'nyranman 'pa, o -yee vɛ -nɔan 'e tʋ man bɛ -wlɔ.»
\p 
\v 42 Ɛn Zozi -a 'le 'sran -wlɛ 'nan: «'Wɩ nɛn 'e 'crɛn -tɛdɩ Bali -le 'fluba 'ji bɛ, ka'a ta vɩlɛ dʋʋ? Kɔɔ e ya 'e 'crɛn -tɛdɩ 'nan:
\q1 ‹-Kɔlɛ nɛn 'kɔn 'tɔnɔn -a tuʋ 'o 'pɛla koda bɛ,
\q1 -yɛɛ drɛ 'kɔn 'pʋ -fɔ -kɔlɛ -a.
\q1 Minsan 'bɛ drɛ,
\q1 ɛn -kɔlɛ zɩɛ 'e drɛ 'kɔn 'pʋ -fɔ -kɔlɛ -a.
\q1 'Wɩ nɛn Minsan -a drɛ bɛ,
\q1 e min 'plo -fɔa.›
\p 
\v 43 Maan 'nan 'an ve 'cɛɛ 'nan, mingɔnnɛn -blɩdɩ Bali va bɛ Bali -taa -a 'silɛ 'ka 'lɔ. Yaa -nɔan 'lɛglɔn 'pee -ji 'nɔn nɛn, o 'ta 'wʋla -a wei da bɛ -wlɛ.
\v 44 [Kɔɔ e ya 'e 'crɛn -tɛdɩ Bali -le 'fluba 'ji "nyian 'nan:
\q1 ‹Min nɛn e -tria -kɔlɛ zɩɛ -a da bɛ, e -wia. Ɛn -te -kɔlɛ zɩɛ e -tria min da bɛ, yaa pɔlɛ "bo.› »]
\p 
\v 45 Zɩ Bali -pannɔn 'tanɔn 'lee Farizɛn 'nɔn -kɔnnɛnnun zɩɛ -a 'man bɛ, waa -tɔ 'nan 'wee 'wɩ nɛn Zozi -a ve.
\v 46 Ɛn o ya "vale 'nan 'o "kuan. 'Pian minnun -le "wɛan "klan a o ji, kɔɔ minnun zɩɛ o Zozi "siala Bali 'lewei vɩzan -a.
\c 22
\s1 Lɩ 'pa "fɛdi man -kɔnnɛn
\r (Lk 14.16-24)
\p 
\v 1 "Bɛ -sru ɛn Zozi -kɔnnɛn pee -fɔ "nyian -wlɛ. Yaa 'vɩ -wlɛ 'nan:
\v 2 «Bali -le mingɔnnɛn -blɩdɩ min da bɛ, -nyrɛn 'gʋ. E ya "le mingɔnnɛn -tʋ 'bɛ "ta 'e 'pɩ -le lɩ 'pa "fɛdi dra.
\v 3 Minnun nɛn e "fɛdi zɩɛ -a 'wɩ 'vɩ -wlɛ "bɛ, e 'e 'sunɔn 'pa 'sia 'nan 'o 'kʋ o laabʋ. 'Pian wa'a 'wɩlɛ "man -e 'o -ta "fɛdi da dɩ.
\p 
\v 4 Ɛn e 'e 'sunɔn 'pee 'pa 'sia "nyian. E 'nan -wlɛ 'nan, 'o vɩ minnun zɩɛ -wlɛ 'nan: ‹An cɛɛn -a drɛdɩ man. An trinun tɛɛ, ɛn an 'blanun tɛɛ. -A pɛɛnɔn 'man, -yee "wɛan 'ka 'ta "fɛdi da!›
\p 
\v 5 'Pian o 'wɩ zɩɛ -a -fɔla 'o "trɔɛn -sru. O -mie -kʋ 'wee fei, ɛn o -mie -kʋ 'wee 'flɛ 'tanlɛ.
\v 6 Ɛn o -mienun -a 'sunɔn 'bɔ kuun, o o -sɔn, ɛn o o tɛɛ.
\p 
\v 7 'Bli 'fɔ mingɔnnɛn zɩɛ a ji -wlidɩ. E 'yee 'sounjanun 'pa 'sia 'nan 'o min -tɛnɔn zɩɛ o -tɛɛ, ɛn 'o -wee 'fla 'tɛ 'blɩ.
\p 
\v 8 "Bɛ -sru ɛn e 'nan 'e 'sunɔn lɛ 'nan: ‹An cɛɛn lɩ 'pa "fɛdi fɛnun drɛdɩ man. 'Pian minnun nɛn maan 'vɩ -wlɛ "bɛ, o 'ka "fɛdi zɩɛ -a da 'nɔn 'a dɩ.
\v 9 -Yee "wɛan 'ka 'kʋ -si -plannun da. Minnun pɛɛnɔn nɛn ka bɔa "o man bɛ, 'ka vɩ -wlɛ 'nan 'o 'ta lɩ 'pa "fɛdi da.›
\v 10 Mingɔnnɛn 'sunɔn zɩɛ waa drɛla "da. Minnun pɛɛnɔn nɛn o 'bɔ o man bɛ, o -ta waa. Min -wlidɩ oo, min "yi oo, o pɛɛnɔn 'ta, ɛn o 'kɔn zɩɛ -a -ci 'fa.
\p 
\v 11 Mingɔnnɛn wlala o va 'nan -e 'e minnun nɛn o -ta "fɛdi da bɛ o yɩ. E min -tʋ 'yɩ o yei te lɩ 'pa "fɛdi da sɔ 'ka "da "dɩ.
\v 12 Ɛn e 'nan -yrɛ 'nan: ‹'An bee, lɩ 'pa "fɛdi da sɔ 'ka 'i da dɩ. E drɛ 'kɔ, ɛn i ya 'gʋ?› Min zɩɛ ya'a -kɔlalɛ 'wɩ 'tʋ 'sidɩ -a "da "dɩ.
\p 
\v 13 -A -nan nɛn mingɔnnɛn -a 'vɩ 'e 'sunɔn lɛ 'nan: ‹'Ka min 'labɛ -a 'kun, 'ka cɛin 'lee -a -pɛ -yrɩ, -e 'ka tuʋ klun va bei, fɛnan nɛn -wuɔdɩ 'lee 'shɛ da -blɩdɩ cɩ bɛ -a -nan.› »
\p 
\v 14 Ɛn Zozi -a 'le 'sran -wlɛ 'nan: «Minnun nɛn Bali o laabʋ bɛ, o ya "kaga. 'Pian minnun nɛn Bali o "sia "va 'yee vɛ -a bɛ, o ya "wɛnnɔn.»
\s1 'Sukɔlɛ -pan wʋdɩ da wɩ
\r (Mk 12.13-17; Lk 20.20-26)
\p 
\v 15 "Bɛ -sru ɛn Farizɛn 'nɔn 'kʋ 'o cin yɩlɛ. Waa 'pla "da 'nan 'o Zozi 'kun 'e wei man.
\v 16 -A -nan nɛn o 'wee minnun 'lee Erodi -le minnun 'pa 'sia 'nan 'o 'wɩ laabʋ Zozi 'lɔ. Waa laabʋ -yrɔ 'nan: «Bali -le 'wɩ "paazan, kʋa -tɔa 'nan i ya 'wɩ tɩglɩ vɩzan -a, ɛn i Bali -sru 'ta wʋdɩ "paaman minnun ji 'e tɩglɩ da. Yi'a 'klanman min lɔ 'wɩ tɩglɩ 'ci 'sidɩ -a -yrɛ dɩ. Ɛn yi'a min bo "va "dɩ.
\v 17 -Yee "wɛan kʋa laabo 'i 'lɔ 'nan: ‹-A -si a -kaa 'lɔ -e -kaa 'sukɔlɛ -pan wʋ Rɔm 'nɔn 'le mingɔnnɛn Seza lɛ, -baa te -ka'a drɛ dɩ? 'Wɩ nɛn "yie 'ji bɛ, 'i vɩ 'kʋɛ!› »
\p 
\v 18 'Pian 'wɩ nɛn -a -cin cɩ o ji bɛ Zozi -a -kɔnnɛn 'yɩ. Ɛn e 'nan -wlɛ 'nan: «Wei "flivli 'nɔn! Ka ya 'an 'man -wɛɛnan -wlidɩ!
\v 19 "Lala nɛn ka 'sukɔlɛ -pan wo -a bɛ, 'ka 'lein 'wlɛ -tʋ 'si "va -e 'ka -kɔɔn 'mɛn!» -A -nan nɛn o 'lein 'wlɛ -tʋ kɔɔn -yrɛ.
\v 20 Ɛn Zozi -a laabʋ -wlɔ 'nan: «-Tɩ -wulo -fodo nɛn 'gʋ? Ɛn -tɩ 'tɔ 'crɛn nɛn 'gʋ?»
\p 
\v 21 O 'nan -yrɛ 'nan: «Rɔm 'nɔn 'le mingɔnnɛn Seza nɛn.»
\p Ɛn Zozi "e 'nan -wlɛ 'nan: «Fɛ nɛn Seza -le vɛ -a bɛ, 'cɛɛ 'nɔn Seza lɛ! Ɛn fɛ nɛn Bali -le vɛ -a bɛ, 'cɛɛ 'nɔn Bali lɛ!»
\p 
\v 22 'Wɩ zɩɛ -a mandɩ o 'plo 'fɔ, -a -nan nɛn o 'si Zozi "srɔn, ɛn o -kʋ.
\s1 Minnun nɛn o -kaa bɛ o wuanla -kanɔn 'va
\r (Mk 12.18-27; Lk 20.27-40)
\p 
\v 23 Yi 'bɔ 'lein zɩɛ -a da bɛ, Saduze 'nɔn -mie pli Zozi man. Saduze 'nɔn "o "ve 'nan -te min -ka bɛ, ya'a 'wuanla -kanɔn 'va dɩ. Zɩ o pli "man "bɛ, ɛn waa laabʋ -yrɔ 'nan:
\v 24 «Bali -le 'wɩ "paazan, Moizi "e 'nan: ‹-Te min lɩ 'pa, ɛn -a san zɩɛ e -ka, te wa'a tian 'nɛn 'yalɛ 'o 'vale 'e nan 'bɔ 'a dɩɛ, -yee -cale zɩɛ -a "bʋɩ 'e 'pa, -e 'e "bʋɩ klu bɔla!›
\v 25 Bali -le 'wɩ "paazan, min -tʋ a 'li 'kʋ 'va bɛ 'yee 'nɛn 'klɔnmɔn a 'sɔravli. -A tɛdɛ lɩ 'pa. Wa'a tian 'nɛn 'yalɛ 'e nan zɩɛ -a dɩ, ɛn e -ka. -A klu 'ka 'fʋlɛ dɩ, -yee "wɛan -a -suannɛn 'e "bʋɩ -cale zɩɛ -a 'pa.
\v 26 'Wɩ 'tʋwli zɩɛ -yɛɛ 'bɔ "nyian -yee "man, ɛn -yɛɛ 'bɔ -a yaagazan man. E drɛ zɩɛ -trilii, ɛn o 'sɔravli cɛɛn -kaadɩ man.
\v 27 "Bɛ -sru ɛn lɩ 'bɔ -ka.
\v 28 Tʋ nɛn minnun wuanla -kanɔn 'va bɛ, lɩ zɩɛ e -kɔan -tɩ nan -a? Kɔɔ o 'sɔravli 'bɔ -a 'pa lɩ -a.»
\p 
\v 29 Ɛn Zozi "e 'nan -wlɛ 'nan: «Ka'a tian 'wɩ 'tʋ -ci manlɛ "fo "dɩ. 'Wɩ nɛn 'e 'crɛn -tɛdɩ Bali -le 'fluba 'ji bɛ, ka'a -ci maan dɩ, ɛn Bali -le 'plɛblɛ bɛ, ka'a tɔa dɩ.
\v 30 Kɔɔ tʋ nɛn minnun wuanla -kanɔn 'va bɛ, -klɔnmɔnnun 'ka lɩ paa dɩ, ɛn lɩmɔnnun 'ka -kɔnnɛn paa dɩ. O -kɔan "le Bali -le 'pasianɔn nɛn laji bɛ -wee 'wɩ 'zʋ.
\v 31 -Te -a -cin a 'ka 'ji 'nan, minnun nɛn o kaa bɛ wa'a 'wuanla -kanɔn 'va dɩɛ, te ka ya 'ka 'fli see "paanan. 'Wɩ 'nɛn Bali -a 'vɩ 'yee 'fluba 'ji bɛ, ka'a tian -a ta vɩlɛ dʋʋ?
\v 32 Kɔɔ yaa 'vɩ 'nan: ‹An ya Abraam -le Bali -a, ɛn an ya Izak -le Bali -a, ɛn an ya Zago 'le Bali -a.› Tʋ nɛn Bali 'wɩ zɩɛ -a ve bɛ, te -kaa tranun zɩɛ o kaa -a -nan 'mɔn. 'Pian Bali "le 'va bɛ, o yiɛ a "man tian, kɔɔ Bali a minnun nɛn o yiɛ cɩ "man "bɛ -wee Bali -a, e 'ka minnun nɛn o kaa bɛ -wee Bali -a dɩ.»
\p 
\v 33 Minnun nɛn o cɩ 'wɩ zɩɛ -a mannan bɛ, Zozi 'le 'wɩ "paadɩ o 'plo 'fɔ.
\s1 -Mɛ "wɩ 'bɛ cɩ Bali -le -pei -tɔ wɩ -dan a?
\r (Mk 12.28-31; Lk 10.25-28)
\p 
\v 34 Farizɛn 'nɔn -a 'man 'nan Zozi Saduze 'nɔn klɩ 'wɩ 'a. -A -nan nɛn o -ta 'o cin yɩlɛ Zozi man.
\v 35 Ɛn o va min -tʋ nɛn e Bali -le -pei -tɔ wɩnun -tɔa 'kpa tɩglɩ bɛ, e 'wɩ laabʋ Zozi 'lɔ 'nan -e 'e wei man.
\v 36 Yaa laabʋ -yrɔ 'nan: «Bali -le 'wɩ "paazan, Bali -le -pei -tɔ wɩ pɛɛnɔn bɛ, -a "cɛn 'bɛ cɩ "va -dan?»
\p 
\v 37 Ɛn Zozi "e 'nan -yrɛ 'nan:
\q1 « ‹'I Minsan 'bɔ nɛn 'yie Bali -a bɛ, -a yɩ "yi 'i 'bli pɛɛnɔn 'a!
\q1 'I yɩ "yi 'yie 'wɩ drɛdɩ pɛɛnɔn 'a!
\q1 Ɛn 'i yɩ "yi 'i 'ci "nrɔndɩ pɛɛnɔn 'a.›
\m 
\v 38 'Wɩ zɩɛ -yɛɛ cɩ Bali -le -pei -tɔ wɩ tɛdɛ -a, ɛn -yɛɛ cɩ "va -a -dan a.
\v 39 Ɛn -a "flizan nɛn o cin 'sia 'a bɛ, -nyrɛn 'gʋ:
\q1 ‹'I bɔɛzan -tʋ yɩ "yi
\q1 "le 'yie 'wɩ 'zʋ!›
\m 
\v 40 'Wɩ "fli zɩɛ, -wɛɛ cɩ 'wɩ pɛɛnɔn nɛn Bali -le -pei -tɔ wɩnun -a 'vɩ bɛ -a -wulo -a, ɛn -wɛɛ cɩ 'wɩ pɛɛnɔn nɛn Bali 'lewei vɩnɔn -a 'vɩ bɛ -a -wulo -a.»
\s1 -Tɩ -pɩ nɛn Crizi -a?
\r (Mk 12.35-37; Lk 20.41-44)
\p 
\v 41 "Bɛ -sru ɛn Zozi -a laabʋ Farizɛn 'nɔn pɛɛnɔn nɛn 'o cin 'yɩ bɛ -wlɔ 'nan:
\v 42 «Crizi nɛn Bali -a 'si "va -e 'e min 'si 'wɩ 'ji bɛ, -tɩ -pɩ nɛn? "Cee 'ji min nɛn e cɩ -a bɛ, 'ka vɩ 'mɛn!»
\p Ɛn o 'nan -yrɛ 'nan: «David -pɩ nɛn!»
\p 
\v 43 Ɛn Zozi -a laabʋ -wlɔ 'nan: «-Te Crizi a David -pɩ -a bɛ, -mɛ "le "wɛan nɛn zɩ Bali lei 'saun 'ta 'tɔ David man bɛ, yaa laabʋ 'e 'san? Kɔɔ David -a 'vɩ 'nan:
\q1 
\v 44 ‹Minsan Bali -a 'vɩ 'an 'san lɛ 'nan:
\q1 'I -nyran 'an 'pɛ "yi "da -trilii,
\q1 -e 'an 'cɛn 'i 'nanmannɔn 'klɩdɩ man.›
\m 
\v 45 -Te David 'bɔ Crizi laabo 'e 'san bɛ, e drɛ 'kɔ ɛn 'bɛ -kɔan David kluda min -a?»
\p 
\v 46 Min -tʋ 'ka -kɔlalɛ 'wɩ 'tʋ 'sidɩ -a "da -yrɛ "dɩ. "Bɛ -sru min -tʋ 'ka "nyian 'wɩ laabʋlɛ Zozi 'lɔ 'nan -e 'e wei 'kun dɩ.
\c 23
\s1 Te 'ka 'wɩ drɛ "le Farizɛn 'nɔn 'le 'wɩ 'zʋ dɩ!
\r (Mk 12.38-40; Lk 20.45-46)
\p 
\v 1 "Bɛ -sru ɛn Zozi 'wɩ tin 'badɩ 'sia 'e -srunɔn 'lee minnun pɛɛnɔn lɛ.
\v 2 Yaa 'vɩ -wlɛ 'nan: «'Fluba 'ci vɩnɔn 'lee Farizɛn 'nɔn 'bɛ Moizi -le -pei -tɔ wɩnun "paaman 'ka 'ji.
\v 3 -Yee "wɛan 'wɩ pɛɛnɔn nɛn waa ve 'cɛɛ bɛ, 'ka 'ta wʋla "da! 'Pian te 'ka 'ta wʋla o drɛ wɩnun da dɩ! Kɔɔ 'wɩnun nɛn waa "paaman 'ka 'ji bɛ, -a da "cɛɛ 'o 'bɔ "o 'ta wʋla dɩ.
\p 
\v 4 'Wɩnun nɛn o ya 'plɛblɛ bɛ, -a 'bɔ nɛn waa -tɛa 'e cin da -e 'o vɩ minnun lɛ 'nan 'o 'ta wʋla "da. 'Pian o 'ka "vale o "paa o va -a drɛnan dɩ.
\v 5 -Wee 'wɩ pɛɛnɔn drɛdɩ bɛ, e ya min yiɛ 'lɛ. 'Fluba nɛn waa crɛn -tɛa, -e 'o 'pa o nyrɛnbɔn da bɛ, 'lee -nyrɛn waa crɛn -tɛa -e 'o 'pa 'o 'pɛ -da bɛ, 'lee sɔ 'lɛbo "nɛn 'e -plimlan bɛ, -wee vɛ "mlianla "da.
\v 6 -Te e ya "fɛdi da -a oo, ɛn -te e ya cin yɩ 'kuin -a oo, -nyran "nan 'kpagba nɛn waa 'sidɩ ye "yi.
\v 7 Waa ye "yi "le 'nan min 'e 'o 'tɔ bʋ -guada, ɛn waa ye "yi "le 'nan min 'e 'o laabʋ 'fluba "paazan.
\p 
\v 8 'Pian 'cee ve bɛ, te 'ka -wɛɛ 'nan min -tʋ 'e 'ka laabʋ 'fluba "paazan dɩ! Kɔɔ 'ka pɛɛnɔn ka drɛ "bʋɩnun -a, ɛn Bali -tʋwli 'bɛ cɩ 'wɩ "paazan -a 'ka 'ji.
\v 9 Ɛn "nyian bɛ, 'trɛ 'gʋɛ -a da bɛ, te 'ka min -tʋ bɔ -a laabʋdɩ -a 'nan 'ka "tɩ "dɩ, kɔɔ 'ka "tɩ "a laji lou, Bali nɛn.
\v 10 Te 'ka -wɛɛ 'nan min -tʋ 'e 'ka laabʋ 'e 'tazan dɩ! Kɔɔ Crizi -tʋwli 'bɛ cɩ 'ka 'tazan -a.
\v 11 'Ka 'va min -dan 'e drɛ 'ka pɛɛnɔn 'suzan 'a.
\v 12 Min nɛn 'e 'fli drɛ -dan bɛ, Bali -a dra "wɛnnɔn. Ɛn min nɛn 'e 'fli drɛ "wɛnnɔn bɛ, Bali -a dra -dan.»
\s1 Zozi 'wɩ 'pla 'fluba 'ci vɩnɔn 'lee Farizɛn 'nɔn lɛ
\r (Mk 12.40; Lk 20.47; 11.39-52)
\p 
\v 13 «'Fluba 'ci vɩnɔn 'lee Farizɛn 'nɔn, ka 'wɩ dra min yiɛ 'lɛ! 'Wɩ -taa "bɔlɛ 'ka man! Kɔɔ ka -si -tɔ minnun lɔ 'nan te 'o 'kʋ Bali va dɩ. 'Ka 'bɔ, ka 'ka "vale 'ka -wla "wo Bali -le mingɔnnɛn trɛda dɩ, ɛn minnun nɛn o ya "vale "o -wlamlan 'nan bɛ, ka -si 'lɛ 'wʋ -wlɔ.
\p 
\v 14 ['Fluba 'ci vɩnɔn 'lee Farizɛn 'nɔn, ka 'wɩ dra min yiɛ 'lɛ! 'Wɩ -taa "bɔlɛ 'ka man! Kɔɔ ka -calenun -le fɛnun "sia 'o 'lɔ -dawli -a. "Bɛ -sru -e 'ka Bali trʋ 'ba -plɔun 'nan -e minnun 'o 'ka "sia min tɩglɩ 'a. 'Wɩnun zɩɛ -yee "wɛan Bali -wee tin "paa 'plɛblɛ.]
\p 
\v 15 'Fluba 'ci vɩnɔn 'lee Farizɛn 'nɔn, ka 'wɩ dra min yiɛ 'lɛ! 'Wɩ -taa "bɔlɛ 'ka man! Kɔɔ ka -ko min -wɛɛlɛ 'trɛda fɛ -kɔɔbli 'nan, 'nan -e 'o 'ta wʋla 'cee -pei -tɔ wɩnun da. Ɛn -te ka min 'yɩ bɛ, 'cee 'wɩ "paadɩ a limlan min -wlidɩ "a "fo. -Yee -kɔndɩ -wlidɩ -ciala 'cee vɛ da 'e 'pa -a "fli.
\p 
\v 16 'Ka yiɛ a 'e 'widɩ, ɛn ka ya "vale 'ka -si -kɔɔnman minnun lɛ. -Yee "wɛan 'wɩ -taa "bɔlɛ 'ka man! Kaa paa minnun ji 'nan, -te min 'e 'pɛ wluan Bali -pan 'kɔn da bɛ, ya'a fɛ -tʋ dra min lɛ dɩ. 'Pian -te min 'e 'pɛ wluan -siga nɛn Bali -pan 'kuin bɛ -a da bɛ, -yɛɛ cɩ 'wɩ -dan a. -A san -a 'ta ta wo -kpɔ.
\v 17 -Blʋnɔn nɛn kaa, ɛn 'ka yiɛ a 'e 'widɩ! -Siga bɛ e ya fɛ -tʋ -a, 'pian Bali -pan 'kuin nɛn e dra 'saun Bali 'lɛ. Ka'a tɔa zɩɛ dʋʋ?
\p 
\v 18 Ɛn ka paa minnun ji "nyian 'nan, -te min 'e 'pɛ wluan Bali -pan "davɛ da bɛ, ya'a fɛ 'tʋ dra min lɛ dɩ. 'Pian -te min 'e 'pɛ wluan 'sraga bʋvɛ nɛn Bali -pan "davɛ da bɛ, -a da bɛ, e ya 'wɩ -dan a. -A san -a 'ta ta wo -kpɔ.
\v 19 Yiɛ 'winɔn! 'Sraga bʋvɛ bɛ e ya fɛ -tʋ -a, 'pian Bali -pan "davɛ da nɛn e dra 'saun Bali 'lɛ. Ka'a tɔa zɩɛ dʋʋ?
\v 20 Min nɛn 'e 'pɛ wluan Bali -pan "davɛ da bɛ, te 'e 'pɛ wluan Bali -pan "davɛ 'lee 'sraga bʋvɛ pɛɛnɔn nɛn "da "bɛ -a da.
\v 21 Min nɛn 'e 'pɛ wluan Bali -pan 'kɔn da bɛ, te 'e 'pɛ wluan Bali nɛn e -nyɛanla 'ji bɛ -a da.
\v 22 Ɛn min nɛn 'e 'pɛ wluan labli man bɛ, te 'e 'pɛ wluan Bali -le mingɔnnɛn pɛin man, ɛn "nyian te 'e 'pɛ wluan Bali da kɔɔ -yɛɛ cɩ 'e -nyrandɩ pɛin zɩɛ -a da.
\p 
\v 23 'Fluba 'ci vɩnɔn 'lee Farizɛn 'nɔn, ka 'wɩ dra min yiɛ 'lɛ! 'Wɩ -taa "bɔlɛ 'ka man! Ka fɛ pɛɛnɔn 'fuzan -nɔan Bali lɛ. Ɛn "nyian fɛ 'finvinnun pɛɛnɔn bɛ, kaa -fuzan -nɔan Bali lɛ, -nyrɛn "le sinwlɛnun nɛn waa laabo manti 'lee anɛti 'lee -cimɛn bɛ -wee 'wɩ 'zʋ. 'Pian -pei -tɔ wɩnun nɛn o cɩ -dan "le 'cɛɛ drɛ bɛ cɛɛ "tʋe. 'Wɩ tɩglɩ drɛdɩ a -tʋ, ɛn min nyrinda 'sidɩ a -tʋ, ɛn yi -tɛradɩ Bali da a -tʋ, 'wɩnun zɩɛ -nyrɛn kaa dra 'e tɛdɛ paan 'vaa -e 'ka pee drɛ "bɛ -sru!
\v 24 'Ka yiɛ a 'e 'widɩ, ɛn ka ya "vale 'ka -si -kɔɔnman minnun lɛ. -Te 'nyrɔndrʋ "wɛnnɛn 'fɔ 'ka 'blɩfɛ va bɛ, kaa "sia "va. 'Pian -wi -dandan nɛn waa laabo shamo bɛ, cɛɛ "mɛan te ka'a -kɔnnɛn 'ye dɩ.
\p 
\v 25 'Fluba 'ci vɩnɔn 'lee Farizɛn 'nɔn, ka 'wɩ dra min yiɛ 'lɛ! 'Wɩ -taa "bɔlɛ 'ka man! Kɔɔ ka 'kulenɛn 'lee -pɔ man "foeman fɛnyian, 'pian fɛnun nɛn kaa -ble -ji bɛ, crinnan fɛnun 'lee fɛnun nɛn kaa "sia minnun lɔ 'ka 'bɔ 'ci 'sɔ wɩnun da bɛ -nyrɛn.
\v 26 Farizɛn 'nɔn, 'ka yiɛ a 'e 'widɩ! 'Ka -wɛɛ 'nan 'ka 'ci 'e drɛ tɩglɩ 'vaa -e 'ka 'kulenɛn 'lee -pɔ man "foe.
\p 
\v 27 'Fluba 'ci vɩnɔn 'lee Farizɛn 'nɔn, ka 'wɩ dra min yiɛ 'lɛ! 'Wɩ -taa "bɔlɛ 'ka man! Kɔɔ ka ya "le min -yrɛnun nɛn o trɔɛ 'wʋ "man "bɛ -wee 'wɩ 'zʋ. O man bei "a fɛnyian, 'pian te o ci a 'e fadɩ min 'wlɛ 'lee fɛ fʋlɩdɩ pɛɛnɔn 'a.
\v 28 'Ka 'bɔ "nyian, minnun 'ka ye min tɩglɩnun -a, 'pian te ka 'ka 'bɛ 'a dɩ. Ka 'wɩ dra min yiɛ 'lɛ, ɛn 'ka 'ci a 'e fadɩ 'wɩ 'wlidɩ 'tɔ 'tʋdʋ pɛɛnɔn 'a.
\p 
\v 29 'Fluba 'ci vɩnɔn 'lee Farizɛn 'nɔn, ka 'wɩ dra min yiɛ 'lɛ! 'Wɩ -taa "bɔlɛ 'ka man! Kɔɔ Bali 'lewei vɩnɔn nɛn -kaa tranun o tɛɛ bɛ, ka 'kɔn drɛ o -yrɛ da. Ɛn "nyian ka min tɩglɩnun -yrɛ da drɛ fɛnyian fɛnyian.
\v 30 "Cɛɛ vɩ 'nan kaa 'kɔn 'wɩnun zɩɛ -a drɛnan bɛ, te kaa ve 'nan: ‹"Te tʋ nɛn 'kʋ tranun yiɛ a "man, kʋ ya -nan bɛ, "te kʋ'a 'palɛ o va -e 'kʋ Bali 'lewei vɩnɔn -tɛɛ "dɩ.›
\v 31 Ɛn 'wɩnun zɩɛ -a vɩdɩ -a -kɔɔnman 'nan kaa 'vɩ 'ka 'fli -a 'nan 'ka tranun 'bɛ Bali 'lewei vɩnɔn tɛɛ.
\v 32 'Wɩnun nɛn 'ka tranun -a drɛ 'li bɛ, -te ka ya "va, "ka "drɛ 'e 'ciɩla -wee vɛ da!
\p 
\v 33 Ka ya min -wlidɩnun -a! Bali -le tin -tɛa 'ka da -kpɔ. Te -a -cin 'e 'kɔn 'ka 'ji 'nan, 'tɛ nɛn ya'a 'driman dɩɛ e 'ka "bluman dɩ!
\v 34 -Yee "wɛan 'ka "trɔɛn "tɔ 'wɩ 'gʋɛ -yrɛ 'kpa! 'An "ta -daa Bali 'lewei vɩnɔn 'lee 'wɩ 'tɔnɔn 'lee 'fluba 'ci vɩnɔn 'palɛ -sia 'cɛɛ. Ka o -mie -tɛa "va, ɛn ka o -mie -tɛa "o -pɛindɩ -a yiba "plan da, ɛn ka o -mie -sɔan -ngble -a 'cee cin yɩ 'kɔnnun -ji. Ka 'tɛ "paa o -mienun da 'flanun da, te wa'a 'o 'wulo da ye 'ka 'lɔ dɩ.
\v 35 'Wɩnun zɩɛ -a drɛdɩ 'bɛ -maan -e minnun nɛn wa'a 'wɩ 'wlidɩ "drɛlɛ dɩ, ɛn 'ka tranun o tɛɛ bɛ, o -ka wɩ 'e 'pa 'ka da zia. Abɛl nɛn min tɩglɩ 'a bɛ, -a da nɛn 'ka tranun -a 'sia -trilii, ɛn e 'bɔ Barashi -pɩ Zakari nɛn kaa -tɛ Bali -pan 'kɔn 'lee Bali -pan "davɛ yei "bɛ -a da.
\v 36 Maan ve 'cɛɛ 'wɩ tɩglɩ 'a 'nan, 'wɩ pɛɛnɔn zɩɛ -yee "wɛan bɛ, Bali -le tin -tɛa 'ka -naagʋnɔn da.»
\s1 Zozi 'wuɔ Zeruzalɛm 'nɔn 'le "wɛan
\r (Lk 13.34-35)
\p 
\v 37 «Zeruzalɛm 'nɔn, 'cee 'wɩ "naan 'an man -wlidɩ! Ka Bali 'lewei vɩnɔn tɛɛ, ɛn minnun nɛn Bali o 'pa 'sia 'cɛɛ bɛ, ka o tɛɛ -kɔlɛnun -a. Maan man -wɛɛ 'e 'pa -a "kaga 'nan 'an 'ka treman 'e cin man "le zɩ mɛin "bʋ 'yee 'nɛnnun treman 'e -pɛba wlu bɛ -yee 'wɩ 'zʋ. 'Pian ka'a 'wɩlɛ "man "dɩ.
\v 38 -Yee "wɛan an "ta 'an 'pɛ "sia 'ka -sru, -e 'cee Bali -pan 'kɔn 'e 'fʋ 'e "tun.
\v 39 Maan ve 'cɛɛ 'nan, ka'a "nyian 'an yɩ pee wo dɩ, -trilii -e 'ka vɩ 'nan: ‹Bali -le -fɛa 'e 'kɔn min nɛn e -taa Minsan 'tɔ da bɛ -a man.› »
\c 24
\s1 Zozi Bali -pan 'kɔn 'wi wɩ 'vɩ
\r (Mk 13.1-2; Lk 21.5-6)
\p 
\v 1 "Bɛ -sru Zozi 'bɔla Bali -pan 'kuin, ɛn e -kʋdɩ 'sia. -A -nan nɛn -a -srunɔn pli "man, ɛn o 'nan -yrɛ 'nan: «"I 'yiɔ, Bali -pan 'kɔn a -miɛn!»
\v 2 Ɛn Zozi "e 'nan -wlɛ 'nan: «-A pɛɛnɔn 'labɛ 'ka -nanjɛn! Maan ve 'cɛɛ 'wɩ tɩglɩ 'a 'nan, 'kɔn 'labɛ e -wia. -A -kɔlɛ pɛɛnɔn fuimlan "man, -a -tʋ 'ka 'fo 'e bɔɛzan -tʋ da dɩ.»
\s1 'Wɩ yɩdɩ -dandan bɔa minnun man 'vaa -e 'trɛda -nyan tʋ 'e bɔ
\r (Mk 13.3-13; Lk 21.7-19)
\p 
\v 3 Zɩ Zozi 'bɔla Olivie pɔn da bɛ, e -nyran, ɛn -a -srunɔn -a laabʋ -yrɔ 'nan: «'Wɩ nɛn i "sia -a vɩnan 'gʋɛ, tʋ "cɛn "man nɛn e dra? Ɛn "nyian -mɛ "wɩ 'bɛ dra 'vaa -e 'kʋ -tɔ 'nan 'i 'ta tʋ 'bɔ? Ɛn -mɛ "wɩ 'bɛ dra 'vaa -e 'kʋ -tɔ 'nan 'trɛ 'nyan tʋ 'bɔ?»
\p 
\v 4 Ɛn Zozi "e 'nan -wlɛ 'nan: «'Ka yiɛ 'tɔ 'ka 'fli -va! Te min -tʋ 'e 'ka see "paa -e 'ka 'si -si tɩglɩ da dɩ!
\v 5 Fɛ nɛn maan ve zɩɛ -yɛɛ cɩ 'nan, min "kaga -taa "talɛ 'an 'tɔ da. Waa ve 'o 'fli man 'nan, min nɛn Bali -a 'si "va "bɛ -nyrɛn 'waa, -e min "kaga 'o -sɔɔnla o -sru.
\v 6 Ka -kuli -tan wɩnun maan, ɛn ka 'fla -kɔɔbli -kɔɔbli da -kuli wɩnun maan. Te 'o 'ka 'cɛn nyɛn -a dɩ! Kɔɔ 'wɩnun zɩɛ -wɛɛ dra 'e 'flin, 'pian 'trɛda -nyan tʋ "cɛɛ dɩ.
\v 7 'Lɛglɔn 'tʋ -ji 'nɔn -taa 'wunlɛa 'lɛglɔn 'tʋ -ji 'nɔn man, ɛn mingɔnnɛn trɛ -tʋ -taa 'wunlɛa mingɔnnɛn trɛ -tʋ man. Dra minnun -tɛɛman fɛ "kaga "nan, ɛn 'trɛ 'nyɔɔnman fɛ "kaga "nan.
\v 8 -A pɛɛnɔn zɩɛ e ya "le 'nan 'nɛn 'yadɩ -le ci -yaa pou sianan "wɛnnɛn 'zʋ.
\p 
\v 9 Tʋ zɩɛ -a man nɛn minnun 'ka "kuundɩ "siala, te o 'tɛ "paa 'ka da, ɛn te o 'ka -tɛɛman. 'Lɛglɔn pɛɛnɔn 'ji 'nɔn "naan 'ka man, ka drɛ 'an -srunɔn 'a -le "wɛan.
\v 10 Ɛn "nyian min "kaga "sia 'an -sru. 'O cin man wlɛ -fɔa, te o "naan 'o cin man.
\v 11 Minnun nɛn o 'wlu wɩ "sia -e 'o vɩ, te waa ve 'nan o ya Bali 'lewei vɩnɔn 'a bɛ, o bɔala 'trɛda "kaga. Ɛn o min "kaga see "paaman.
\v 12 'Wɩ 'wlidɩ "drɛdɩ faa "da 'trɛda -le "wɛan, min "kaga "le min yɩdɩ "yi 'e 'le -tɔa.
\v 13 'Pian min nɛn e -tɔ 'plɛblɛ -trilii, ɛn e 'bɔ -a 'le 'srannan "bɛ, e "sia 'wɩ 'ji.
\v 14 Bali -le mingɔnnɛn -blɩdɩ min da bɛ, 'wɩ 'nɔnnɔn nɛn. Ɛn 'wɩ zɩɛ minnun -a fuimlan "man 'trɛda 'nɔn pɛɛnɔn 'va, -e 'lɛglɔn 'tʋdʋ pɛɛnɔn 'o man. "Bɛ -sru 'vaa -e 'trɛda -nyan tʋ 'e bɔ.»
\s1 Tʋ nɛn 'wɩ yɩdɩ "mlianla "da "bɛ, Zozi -a 'wɩ 'vɩ
\r (Mk 13.14-23; Lk 21.20-24; 17.23-24)
\p 
\v 15 «Bali 'lewei vɩzan Daniɛl -a 'vɩ 'nan, 'wɩ 'wlidɩ "nɔnnɔan -taa "drɛlɛ Bali -le 'kuin. Min nɛn e 'fluba 'gʋɛ -a ta ve bɛ 'e 'ci man 'kpa! Tʋ nɛn 'wɩ zɩɛ kaa -nan 'yɩ Bali -pan 'kuin bɛ,
\v 16 minnun nɛn o cɩ Zude 'lɛglɔn 'ji bɛ, 'o flan 'bli, 'o 'kʋ pɔnnun yei!
\v 17 Ɛn -te min a bei "bɛ, te 'e -wla 'yee 'kuin -e 'e 'kʋ fɛ -tʋ 'sia dɩ!
\v 18 Ɛn -te min a fei bɛ, te 'e li 'e da 'fla -e 'e 'kʋ 'yee -tralɛ 'si 'yee 'kuin dɩ!
\v 19 Lɩmɔnnun nɛn o -pɔn cɩ 'o man tʋ zɩɛ -a man bɛ, 'lee lɩmɔnnun nɛn 'nɛn 'nyɔn -mlian -wlɔ tʋ zɩɛ -a man bɛ, -wee yra yɩdɩ "mlianla "da.
\v 20 -Yee "wɛan 'ka Bali trʋ 'ba 'nan, te 'wɩ zɩɛ 'e 'tria laa 'fɛn tʋ -man dɩ, ɛn te 'e 'tria 'cee 'flinla "yi da dɩ!
\v 21 Kɔɔ 'wɩ yɩdɩ -kɔan -dan 'kpa tʋ zɩɛ -a man. Zɩ Bali 'trɛ drɛ 'li -e 'e bɔ cɛɛgʋ yi -a bɛ, -a sʋman 'wɩ yɩdɩ 'ka tian drɛlɛ dɩ. Ɛn 'wɩ yɩdɩ zɩɛ -a pee 'ka 'dra "nyian 'li 'trɛda "fo "dɩ.
\v 22 Yinun nɛn 'wɩnun zɩɛ o dra "da "bɛ, Bali -a -mie cɛɛn "da. -Te ya'a 'wɩ zɩɛ -a drɛlɛ dɩɛ, "te min -tʋ -wulo 'ka -taa bɔlɛa "va "dɩ. 'Pian minnun nɛn e o 'si "va 'yee vɛ -a bɛ, -wee "wɛan e yinun -mie cɛɛn "da.
\p 
\v 23 -Te min -tʋ -a 'vɩ 'cɛɛ 'nan, min 'sizan 'wɩ 'ji Crizi a 'gʋ, -te 'bɛ "cɛɛ dɩ, Crizi a -miɛn bɛ, te 'ka yi -tɛra "da "fo "dɩ!
\v 24 Kɔɔ minnun nɛn o 'wlu -sɛan 'nan 'wɛɛ cɩ Crizi -a bɛ, o -taa "kɔnlɛ 'trɛda. Ɛn minnun nɛn o 'wlu wɩnun ve, te waa ve 'nan Bali 'lewei vɩnɔn nɛn waa bɛ, o -taa "kɔnlɛ "nyian. O -taa 'lɛbo "fɔ wɩ -dandan 'lee -cɛ -srɔn "wɩ -dandan drɛlɛ. Waa dra 'nan -te 'o 'pɛ 'sɔ 'a bɛ -e 'o minnun nɛn Bali o 'si "va 'yee vɛ -a bɛ, o 'si -si tɩglɩ da.
\v 25 'Wɩnun zɩɛ maan -cin -trɔa 'ka 'ji 'nan, te 'ka yiɛ a 'ka 'fli -va.
\p 
\v 26 -Yee "wɛan -te min -a 'vɩ 'cɛɛ 'nan, Crizi a "bui "da bɛ, te 'ka 'kʋ -nan dɩ. Ɛn -te waa 'vɩ 'cɛɛ 'nan, e ya 'kɔn 'tʋ -ji bɛ, te 'ka yi -tɛra "da "dɩ.
\v 27 Kɔɔ tʋ nɛn 'an 'bɔ Blamin -pɩ 'an -taa "man "bɛ, e dra "le laa -paan 'zʋ. Laa -paan, 'e 'wlei -wlei -fɔa, e "sia yidɛ wluan "nan 'zia, -e 'e 'kʋ yidɛ 'fɔ -nan "va 'zia. 'Trɛda 'nɔn pɛɛnɔn -a -nan ye.
\v 28 -Kaa -tɔa 'wein 'nan fɛnan nɛn -wi -kadɩ cɩ 'e pladɩ bɛ, -a ta lou "nɛn -wi pɛa "blɩ "lomannun 'o 'ble.»
\s1 Blamin -pɩ -tadɩ da wɩ
\r (Mk 13.24-27; Lk 21.25-28)
\p 
\v 29 «-Te 'wɩ yɩdɩ -dan zɩɛ, e cɛɛn -nyandɩ man bɛ, 'nun tɔɔn yidɛ yra klun -tɔala, mlɛn 'bidɩ 'e 'le -tɔa, mlɛn crɛnnun "sia laji, o -tɛɛmlan "tra, ɛn laji fɛnun pɛɛnɔn nɛn 'plɛblɛ a -wlɔ "bɛ, o "sia 'o 'klu -ji.
\p 
\v 30 Tɔɔn minnun pɛɛnɔn -a -kɔnnɛn ye laji 'nan 'an 'bɔ Blamin -pɩ -tadɩ 'bɔ "mɛn. "Bɛ -sru 'trɛda 'nɔn pɛɛnɔn 'an 'bɔ Blamin -pɩ ye -tanan "lolu -koei "da laji, -e 'o 'wuɔdɩ 'sia. 'Plɛblɛ -dan -kɔan 'an 'lɔ, ɛn 'tɔ -dan -kɔan 'an 'lɔ.
\v 31 Bali -le 'bei -dan "we, -e 'an 'bɔ Blamin -pɩ, 'an 'mɛn 'pasianɔn nɛn laji bɛ o 'pa 'sia 'trɛda fɛ pɛɛnɔn 'nan. Minnun pɛɛnɔn nɛn an o 'si "va 'mɛn vɛ -a bɛ, 'mɛn 'pasianɔn o cin ye. Fɛ -tʋ -nan 'ka 'fʋ 'trɛda, te wa'a min 'silɛ 'bɛ 'nan dɩ.»
\s1 'Ka 'man 'e 'kɔn 'e wʋʋdɩ tʋ pɛɛnɔn man Blamin -pɩ -tadɩ -le "wɛan
\r (Mk 13.28-33; Lk 21.29-33)
\p 
\v 32 «'Wɩ nɛn e dra fijie yiba "lɛ bɛ, 'e drɛ 'cee 'wɩ -kɔɔn "manvɛ -a! -Te -a 'la nrindɩ 'sia "da "bɛ, kaa -tɔa 'nan 'munmun tʋ a -tanan bɔdɩ -a -kogo.
\v 33 -A -tʋwli "nɛn "nyian, 'an 'bɔ Blamin -pɩ -tadɩ -le vɛ -a. -Te ka 'wɩnun nɛn maan 'vɩ 'cɛɛ bɛ, -a 'yɩ drɛnan bɛ, 'ka -tɔ 'nan 'an 'tadɩ a bɔnan 'kogo!
\v 34 Maan ve 'cɛɛ 'wɩ tɩglɩ 'a 'nan, 'ka -naagʋnɔn 'gʋɛ, ka'a 'cɛan -kaadɩ man 'vaa, -e 'wɩnun zɩɛ 'o drɛ dɩ.
\v 35 Labli 'lee 'trɛ 'nyan tʋ a, 'pian 'an wei -fo -nan 'li 'trilii.
\p 
\v 36 Tʋ nɛn an -taa "man "bɛ, blamin -tʋ 'ka -a tɔa "fo "dɩ. Ɛn Bali -le 'pasianɔn nɛn laji bɛ, wa'a tɔa "fo "dɩ, ɛn 'an 'bɔ Blamin -pɩ ma'an tɔa "fo "dɩ, 'pian 'an "tɩ 'bɛ -tɔa 'e 'tʋwli.
\p 
\v 37 Tʋ nɛn 'an 'bɔ Blamin -pɩ -taa "bɛ, 'wɩnun dra "le zɩ e drɛ Noe tʋ va bɛ -yee 'wɩ 'zʋ.
\v 38 Kɔɔ Noe tʋ va 'li te laa -dan 'ka tian 'fɛnlɛ 'trɛda dɩɛ, minnun fɛ blɩ, o -wɛn mlin, o lɩ 'pa, o -kɔnnɛn 'pa. Waa drɛ zɩɛ -trilii ɛn Noe wla -klu -dan -ji, te waa dra tian.
\v 39 'Wɩ 'tʋ -cin 'ka o ji dɩ. O -fʋ -a drɛdɩ man zɩɛ -trilii ɛn laa -dan o -nan -nyan "fo. 'Wɩ 'tʋwli zɩɛ -yɛɛ dra 'an 'bɔ Blamin -pɩ -ta tʋ -man.
\v 40 Tʋ zɩɛ -a man bɛ, min "fli -kɔan "fei, 'mɛn 'pasianɔn nɛn laji bɛ waa -tʋ "siala -e 'o -tʋ 'tʋɩ.
\v 41 Ɛn "nyian bɛ, lɩmɔn "fli -kɔan 'saa 'sɔnnan, 'mɛn 'pasianɔn nɛn laji bɛ waa -tʋ "siala -e 'o -tʋ 'tʋɩ.
\p 
\v 42 -Yee "wɛan 'ka 'man 'e 'kɔn 'e wʋʋdɩ tʋ pɛɛnɔn man! Kɔɔ yi nɛn 'ka 'san -taa "da "bɛ, ka'a tɔa dɩ.
\v 43 'Ka 'ci "nrɔn 'wɩ 'gʋɛ -a da! Tʋ nɛn crinzan -taa "min crin wʋlɛ -pei -man bɛ, "te 'kɔn san -a -tɔa "bɛ, "te -a yiɛ 'fo "man "trilii, ɛn ya'a 'we "man -e crinzan 'e -yee fɛnun "koola dɩ.
\v 44 'Kɔn san 'ka crinzan -ta tʋ tɔa dɩ. -A -tʋwli "nɛn "nyian 'cee vɛ -a, Blamin -pɩ -le -tadɩ bɔa 'ka man kligli, -yee "wɛan 'ka 'man 'e 'kɔn 'e wʋʋdɩ tʋ pɛɛnɔn man!»
\s1 Min man -kɔan 'e wʋʋdɩ 'kɔ?
\r (Lk 12.42-46)
\p 
\v 45 «Min 'suzan "cɛn 'bɛ 'ta wʋla 'e 'san wei da 'wɩ 'tɔdɩ -a? Min 'suzan nɛn -a tazan 'yee 'kɔn 'pɛba 'wʋ -yrɔ, ɛn yaa 'vɩ -yrɛ 'nan, 'e -blɩfɛ -nɔn min 'sunɔn -mienun lɛ 'e tʋ -man bɛ, -nyrɛn.
\v 46 Min 'suzan zɩɛ -te -a tazan 'bɔ "man 'wɩ zɩɛ -a drɛnan bɛ -yee vɛ a "yi.
\v 47 Maan ve 'cɛɛ 'wɩ tɩglɩ 'a 'nan, -a tazan -a -tɔa 'e yɩfɛ pɛɛnɔn da.
\p 
\v 48 'Pian -te min 'suzan -wlidɩ "nɛn bɛ, zɩ 'e 'ci "nrɔnman 'gʋ. Yaa ve 'nan: ‹'An 'tazan a 'mɔnnan.›
\v 49 Tɔɔn -e 'e 'tɛ 'padɩ 'sia minnun nɛn 'e yiɛ -tɔa "o va bɛ o da, te e ya 'e 'fɔdɩ -wɛn -tɛnɔn -sru, o fɛnun -ble waa, te o -wɛn -mlian "waa.
\v 50 Tɔɔn yi nɛn -a -cin 'ka "ji 'nan 'e 'tazan -taa "dɩɛ, -e 'bɛ bɔla kligli,
\v 51 -e -a tazan 'e "nɛn "jɛɛnla 'ji -wlidɩ. E 'wɩ "nɛn -kɔɔnman -yrɛ "le zɩ o 'wɩ "nɛn -kɔɔnman minnun nɛn o 'wɩ dra min yiɛ lɛ bɛ -wlɛ "bɛ, -yee 'wɩ 'zʋ fɛnan nɛn -wuɔdɩ 'lee 'shɛ da -blɩdɩ cɩ bɛ -a -nan.»
\c 25
\s1 Nɔnbɛ "fu man -kɔnnɛn
\p 
\v 1 Ɛn Zozi -kɔnnɛn pee -fɔ "nyian -wlɛ. E 'nan: «Bali -le mingɔnnɛn -blɩdɩ min da bɛ, -nyrɛn 'gʋ. E ya "le nɔnbɛ "fu 'bɛ 'wee -kannɛnnun 'sia, ɛn o -kʋ lɩmɔn -tʋ nɛn e "ta -kɔnnɛn "paa bɛ -yee 'kuin. Min nɛn e "ta lɩ "paa bɛ waa -pɛndɩ 'sia, kɔɔ -wɛɛ -ko o 'palɛ -sia 'o 'lɔ le 'wee -kannɛnnun -a.
\v 2 Nɔnbɛnun zɩɛ -a 'soolu a "va "bɛ -blʋnɔn nɛn waa, ɛn -a 'soolu a "va "bɛ 'wɩ 'tɔnɔn nɛn waa.
\v 3 -A 'soolu nɛn -blʋnɔn 'a bɛ, o 'wee -kannɛnnun 'sia, 'pian wa'a 'kunlɛ -a 'yi man dɩ.
\v 4 Ɛn -a 'soolu nɛn 'wɩ 'tɔnɔn 'a bɛ o 'wee -kannɛnnun 'sia, ɛn o 'kun -a 'yi -mie man.
\p 
\v 5 Min nɛn e "ta lɩ "paa bɛ, zɩ e ya 'mɔnnan bɛ, ɛn yi -fɔla nɔnbɛnun zɩɛ o da.
\p 
\v 6 Zɩ bada -tɔ bɛ, ɛn minnun pladɩ 'sia. O pla 'nan: ‹Min nɛn e "ta lɩ "paa bɛ, e ya -tanan. 'Ka 'kʋ -a 'si 'sia.›
\p 
\v 7 -A -nan nɛn nɔnbɛnun zɩɛ o wluan lou, ɛn o 'wee -kannɛnnun drɛ 'kpa.
\v 8 Nɔnbɛnun 'soolu nɛn -blʋnɔn 'a bɛ, waa 'vɩ 'o "luenun lɛ 'nan: ‹'Ka "kʋe 'cee -kannɛn 'yi 'nɔn, kɔɔ 'kʋe -kannɛnnun "ta "driman!›
\p 
\v 9 'Pian nɔnbɛnun nɛn 'wɩ 'tɔnɔn 'a bɛ, o 'nan -wlɛ 'nan: ‹-Cɛjɛ, kʋ'a 'we "man "dɩ. Ya'a 'bɔa 'kʋe vɛ 'lee 'cee vɛ -a dɩ. 'Ka 'kʋ 'cee vɛ 'lɔ -kannɛn 'yi -tanzan -va!›
\p 
\v 10 Ɛn nɔnbɛnun zɩɛ o -kʋ -a 'lɔlɛ. Tʋ zɩɛ -a wlu nɛn min nɛn e "ta lɩ "paa bɛ e 'bɔla. Ɛn nɔnbɛnun 'soolu nɛn o man cɩ 'e wʋʋdɩ bɛ, o -kʋ lɩ 'pa "fɛdi da. -A -nan nɛn minnun 'kɔn 'lɛ 'wʋ o da.
\p 
\v 11 "Bɛ -sru ɛn nɔnbɛnun nɛn -blʋnɔn 'a bɛ, o -ta. O 'kɔn -tɛ, te o -paanman 'nan: ‹'Kʋ 'san, 'kʋ 'san, 'i yra 'si, 'i 'kɔn 'lɛ 'sʋ 'kʋɛ!›
\p 
\v 12 'Pian lɩ 'pazan zɩɛ ya'a 'wɩlɛ "man "dɩ. E 'nan -wlɛ 'nan: ‹Ma'an 'ka 'tɔa dɩ.› »
\p 
\v 13 Ɛn Zozi -a 'le 'sran -wlɛ 'nan: «'Wɩ zɩɛ -a bɔdɩ 'ka man -le "wɛan bɛ, 'ka 'man 'e 'kɔn 'e wʋʋdɩ tʋ pɛɛnɔn man, kɔɔ tʋ nɛn an -taa "man "bɛ, ka'a tɔa dɩ.»
\s1 Zozi -kɔnnɛn pee -fɔ minnun nɛn 'o man cɩ 'o wʋʋdɩ bɛ o man
\r (Lk 19.12-17)
\p 
\v 14 «Bali -le mingɔnnɛn -blɩdɩ min da bɛ, -nyrɛn 'gʋ. E ya "le min -tʋ 'bɛ "ta -ko 'ta wʋnan. Min zɩɛ 'e 'sunɔn laabʋ, ɛn 'e yɩfɛ pɛɛnɔn -pɛba 'wʋ -wlɔ.
\v 15 E -siga 'wlɛ 'soolu 'nɔn -a -tʋ lɛ, ɛn yaa -nɔn -a -tʋ lɛ "nyian 'wlɛ "fli, ɛn yaa -nɔn -a yaagazan lɛ 'wlɛ 'tʋ. Zɩ min -tʋ -kɔlaman 'e 'pɛ man liladɩ -a bɛ, -a da nɛn yaa -nɔn -wlɛ. Ɛn e -kʋ.
\p 
\v 16 'Nun tɔɔn min nɛn e -siga 'wlɛ 'soolu 'yɩ bɛ, 'e 'pɛ man lila -siga zɩɛ -a, ɛn -a man 'pa "nyian -siga 'wlɛ 'soolu.
\v 17 Min nɛn e -siga 'wlɛ "fli 'yɩ bɛ, 'wɩ 'tʋwli zɩɛ -a 'bɔ nɛn "e drɛ. -Yee vɛ man 'pa -siga 'wlɛ "fli.
\v 18 Min nɛn e -siga 'wlɛ -tʋwli 'yɩ bɛ, e -klu cɛɛn, ɛn yaa yɔɔ "ji.
\p 
\v 19 -A -nan 'mɔn 'trilii, ɛn o tazan zɩɛ e -ta. -A -nan nɛn 'e 'sunɔn zɩɛ o laabʋ 'nan -e 'o 'nyranman nɛn waa 'pa bɛ -a -sru "vɩ 'yrɛ.
\v 20 Min nɛn e -siga 'wlɛ 'soolu 'yɩ bɛ, e -ta 'e 'lɔ le -siga 'wlɛ 'soolu -a "nyian. Ɛn e 'nan 'e 'san lɛ 'nan: ‹'An 'san, -siga 'wlɛ 'soolu nɛn yia -nɔn 'mɛn bɛ, maan drɛ ɛn -a man 'pa "nyian -siga 'wlɛ 'soolu. -Nyrɛn 'gʋ.›
\p 
\v 21 -A -nan nɛn -a tazan "e 'nan -yrɛ 'nan: ‹I muo, yia drɛ 'kpa. I ya 'an 'suzan 'kpa -a. Fɛ "wɛnnɛn nɛn maan -pɛba 'wʋ 'i 'lɔ 'gʋɛ, i 'wɩ "yi drɛ 'a. -Yee "wɛan an fɛ -dan -pɛba wo 'i 'lɔ. 'I 'ta -e 'kʋ 'ci 'e "nran 'e cin va.›
\p 
\v 22 Min nɛn e -siga 'wlɛ "fli 'yɩ bɛ, e -ta ɛn e 'nan 'e 'san lɛ 'nan: ‹'An 'san, -siga 'wlɛ "fli "nɛn yia -nɔn 'mɛn bɛ, maan drɛ ɛn -a man 'pa "nyian -siga 'wlɛ "fli. -Nyrɛn 'gʋ.›
\p 
\v 23 -A -nan nɛn -a tazan "e 'nan -yrɛ 'nan: ‹I muo, yia drɛ 'kpa. I ya 'an 'suzan 'kpa -a. Fɛ "wɛnnɛn nɛn maan -pɛba 'wʋ 'i 'lɔ 'gʋɛ, i 'wɩ "yi drɛ 'a. -Yee "wɛan an fɛ -dan -pɛba wo 'i 'lɔ. 'I 'ta -e 'kʋ 'ci 'e "nran 'e cin va.›
\p 
\v 24 "Bɛ -sru min nɛn e -siga 'wlɛ -tʋ 'yɩ bɛ, e -ta ɛn e 'nan 'e 'san lɛ 'nan: ‹'An 'san, maan -tɔa 'nan, i ya min nɛn -yee 'wɩ a 'tɔndɔn bɛ -a. -Te min 'yie 'nyranman 'pa bɛ, -a ta -trɔn pɛɛnɔn nɛn yaa ye bɛ, yia "sia -yrɔ.
\v 25 "Klan -fʋ 'an 'ji 'nan te 'yie -siga 'e 'san 'an 'lɔ dɩ, -yee "wɛan an -kʋ -a yɔɔlɛ 'trɛ 'ji. -Nyrɛn 'gʋ, 'i 'si.›
\p 
\v 26 Ɛn -a tazan zɩɛ e 'nan -yrɛ 'nan: ‹I ya 'an 'suzan -wlidɩ "a, ɛn kɔanzan nɛn yia. -Te -a -cin a 'i 'ji 'nan, min 'mɛn 'nyranman "paa, maan ta -trɔn pɛɛnɔn "sia -a san lɔ bɛ,
\v 27 -mɛ "le "wɛan nɛn yi'a -kʋlɛ 'mɛn -siga 'palɛa fɛnan nɛn -a man "paa bɛ -a -nan dɩ? Yia dra paan zɩɛ, -te an -ta bɛ, -e 'an 'kʋ 'mɛn -siga 'si 'o 'vale 'e 'man 'pa 'a.
\p 
\v 28 'Ka -siga 'labɛ -a 'si -yrɔ, -e 'ka -nɔn min nɛn -siga -fu a -yrɔ "bɛ -yrɛ!
\v 29 Kɔɔ min nɛn fɛ a -yrɔ "kaga "bɛ -a lɛ nɛn waa -nɔan, -e -yee vɛ 'e 'pa "da. 'Pian min nɛn fɛ 'ka -yrɔ "kaga "dɩɛ, -a "tiɛnnɛn nɛn -yrɔ "bɛ, waa "sia.
\v 30 'An 'suzan 'gʋɛ, -a -pɛ 'ka 'fɔala 'e man dɩ, 'ka 'ta -a tuʋ klun va bei, fɛnan nɛn -wuɔdɩ 'lee 'shɛ da -blɩdɩ cɩ bɛ -a -nan.› »
\s1 Blamin -pɩ 'trɛdanɔn 'le tin "baa tʋ -fɔla "da "ji
\p 
\v 31 «Tʋ nɛn 'an 'bɔ Blamin -pɩ an -taa 'kʋ 'vale 'mɛn 'pasianɔn nɛn laji bɛ waa bɛ, an -taa 'mɛn 'tɛ 'san da, -e 'an -nyran 'mɛn mingɔnnɛn pɛin -da.
\v 32 'Lɛglɔn pɛɛnɔn 'jinɔn 'o cin ye 'an 'lɛ, -e 'an o 'cɛn 'e cin man "fli. Maan dra "le zɩ 'bla -sru "pinzan 'yee 'blanun 'lee 'yee bonun "cɛan 'e cin man bɛ -yee 'wɩ 'zʋ.
\v 33 E 'blanun -sɛan 'e 'pɛ "yi "da, -e 'e bonun -sɛn 'e 'pɛ bʋ da.
\p 
\v 34 Tɔɔn 'an 'bɔ mingɔnnɛn maan ve 'an 'pɛ "yi "danɔn lɛ 'nan: ‹Kaa 'gʋɛ, 'an "tɩ -fɛa 'vɩ 'ka man! 'Ka 'ta! Mingɔnnɛn trɛ nɛn 'an "tɩ -a man drɛ 'trɛda pou sianan "bɛ, e drɛ 'cee vɛ -a. 'Ka 'si!
\v 35 Fɛ -le "wɛan nɛn maan -nɔn 'cɛɛ bɛ, te dra 'an -tɛa "bɛ, ka fɛ -nɔn 'mɛn. Ɛn te 'yi dra 'an -tɛa "bɛ, ka 'yi 'nɔn 'mɛn, ɛn te an 'lʋ 'ka 'va 'pɛn -a bɛ, kaan 'kun 'ka 'pɛ "fli "a.
\v 36 Ɛn te sɔ 'ka 'an da dɩɛ, ka sɔ 'wʋ 'an man, ɛn te 'an 'man "yaaman bɛ, 'ka yiɛ 'tɔ 'an 'va. Ɛn te an ya -pʋ 'kuin bɛ, ka 'lʋ 'an 'nanjɛnlɛ.›
\p 
\v 37 Tɔɔn -e min tɩglɩnun zɩɛ 'o laabʋ 'an 'lɔ 'nan: ‹Minsan, tʋ "cɛn "man nɛn kʋi 'yɩ te dra 'i -tɛa ɛn kʋ fɛ -nɔn 'yiɛ? Ɛn tʋ "cɛn "man nɛn kʋi 'yɩ te 'yi dra 'i -tɛa ɛn kʋ 'yi 'nɔn 'yiɛ?
\v 38 Tʋ "cɛn "man nɛn i 'lʋ 'kʋ 'va 'pɛn -a, ɛn kʋi 'kun 'kʋ 'pɛ "fli "a? Tʋ "cɛn "man nɛn i ya 'i plʋdɩ, ɛn kʋ sɔ 'wʋ 'i da?
\v 39 Tʋ "cɛn "man nɛn kʋi 'yɩ te 'i 'man "yaaman, ɛn 'kʋ yiɛ 'tɔ 'i 'va? Tʋ "cɛn "man nɛn kʋi 'yɩ te i ya -pʋ 'kuin ɛn kʋ 'lʋ 'i 'nanjɛnlɛ?›
\p 
\v 40 Tɔɔn 'an 'bɔ mingɔnnɛn, maan ve -wlɛ 'nan: ‹Maan ve 'cɛɛ 'wɩ tɩglɩ 'a 'nan, tʋ nɛn ka ya 'wɩnun zɩɛ -a drɛnan 'an "bʋɩnun 'gʋɛ o va min "wɛnnɛn 'tʋ lɛ bɛ, te 'an lɛ nɛn ka cɩ -a drɛnan.›
\p 
\v 41 "Bɛ -sru maan ve minnun nɛn 'an 'pɛ bʋ da bɛ -wlɛ 'nan: ‹'Ka -pli 'ka -sru "kɔɔbli! Bali wei a 'e pladɩ 'ka man. 'Ka 'kʋ 'tɛ nɛn ya'a 'driman dɩɛ, -a va. Bali -a man drɛ Satan 'lee 'yee 'pasianɔn 'le vɛ -a.
\v 42 Fɛ -le "wɛan nɛn an 'wɩ zɩɛ -a 'vɩ bɛ, te dra 'an -tɛa "bɛ, ka'a fɛ -nɔnlɛ 'mɛn dɩ. Ɛn te 'yi dra 'an -tɛa "bɛ, ka'a 'yi 'nɔnlɛ 'mɛn dɩ.
\v 43 Ɛn te an 'lʋ 'ka 'va 'pɛn -a bɛ, ka'an 'kunlɛ 'ka 'pɛ "fli "a dɩ. Ɛn te sɔ 'ka 'an da dɩɛ, ka'a sɔ wʋlɛ 'an man dɩ. Ɛn te 'an 'man "yaaman bɛ, ka'a yiɛ -tɔlɛ 'an 'va dɩ. Ɛn te an ya -pʋ 'kuin bɛ, ka'a 'lʋlɛ 'an 'nanjɛnlɛ dɩ.›
\p 
\v 44 Tɔɔn -e "o laabʋ 'an 'lɔ "nyian 'nan: ‹Minsan, tʋ "cɛn "man nɛn kʋi 'yɩ te dra 'i -tɛa? Ɛn tʋ "cɛn "man nɛn kʋi 'yɩ te 'yi dra 'i -tɛa? Ɛn tʋ "cɛn "man nɛn i 'lʋ 'kʋ 'va 'pɛn -a? Ɛn tʋ "cɛn "man nɛn i ya 'i plʋdɩ? Ɛn tʋ "cɛn "man nɛn kʋi 'yɩ te 'i 'man "yaaman? Ɛn tʋ "cɛn "man nɛn kʋi 'yɩ te i ya -pʋ 'kuin? Ɛn tʋ "cɛn "man nɛn kʋ'a 'palɛ 'i 'va dɩ?›
\p 
\v 45 Tɔɔn -e 'an vɩ -wlɛ 'nan: ‹Maan ve 'cɛɛ 'wɩ tɩglɩ 'a 'nan, tʋ nɛn ka 'ka 'wɩnun zɩɛ -a drɛnan 'an "bʋɩnun 'gʋɛ o va min "wɛnnɛn 'tʋ lɛ dɩɛ, te 'an 'bɔ lɛ nɛn ka 'ka -a drɛnan dɩ.›
\p 
\v 46 Minnun zɩɛ, wɛɛ -ko yra yɩdɩ nɛn -a 'leda "ka "dɩɛ -a va. 'Pian minnun nɛn o cɩ min tɩglɩnun -a bɛ, 'belidɩ nɛn ya'a 'nyaan dɩɛ, e ya -wee vɛ -a.»
\c 26
\s1 Zuif 'nɔn 'tanɔn 'o 'ci 'pa 'nan 'o Zozi 'tɛ
\r (Mk 14.1-2; Lk 22.1-2; Zan 11.45-53)
\p 
\v 1 Zɩ Zozi cɛɛn 'wɩ pɛɛnɔn zɩɛ -a vɩdɩ man bɛ, ɛn yaa 'vɩ 'e -srunɔn lɛ 'nan:
\v 2 «Kaa -tɔa 'nan, e -fʋ yi -tʋ -a "fli -e -kaa tranun -le 'sidɩ nɔanba -ji "fɛdi drɛdɩ 'e bɔ. Yi zɩɛ -a da nɛn 'an 'bɔ Blamin -pɩ waan -nɔan "minnun lɛ, -e 'waan 'tɛ 'an -pɛindɩ -a yiba "plan da.»
\p 
\v 3 Tʋ zɩɛ -a wlu bɛ te Bali -pannɔn 'tanɔn 'lee min cejenun a 'o cin yɩnan Bali -pannɔn 'tazan nɛn waa laabo Kaifa bɛ -yee -klɔn -ji.
\v 4 -A -nan nɛn waa 'pla "da 'nan 'o Zozi 'kun ci 'cɛn 'a -e 'o -tɛ.
\v 5 'Pian waa 'vɩ 'o cin yei 'nan: «Te -kaa drɛ "fɛdi yi da dɩ! "Tɔgɔ minnun 'o -nan yɩ -e 'o 'wluan -kaa man.»
\s1 Lɩmɔn -tʋ 'wɩ "yi drɛ Zozi lɛ
\r (Mk 14.3-9; Zan 12.1-8)
\p 
\v 6 Zozi a 'fla nɛn waa laabo Betani bɛ -a da. E ya Simɔn nɛn -kogobe a "nɛn "man "bɛ -yee 'kuin.
\v 7 O ya fɛnun -blɩnan, -a -nan nɛn lɩmɔn -tʋ pli Zozi man 'e 'lɔ le -laziglɔ nɛn -a 'flɛ a 'plɛblɛ 'kpa bɛ -a -pɔnɛn 'tʋ -a. Ɛn yaa -sɛndɩ 'sia Zozi 'win -ji.
\p 
\v 8 Zɩ -a -srunɔn 'wɩ zɩɛ -a -nan 'yɩ bɛ, -a 'wɩ 'nan o man, ɛn o 'nan: «-Mɛ "le "wɛan nɛn e -laziglɔ 'kpa bɛ -a srɛ 'e "tun?
\v 9 -Laziglɔ 'labɛ yaa -taan paan 'flɛ 'plɛblɛ 'a, -e 'e man "lala -pli 'yalɛ -tɛnɔn man.»
\p 
\v 10 Zozi 'wɩ zɩɛ -a 'man, ɛn e 'nan -wlɛ 'nan: «-Mɛ "le "wɛan nɛn ka 'wɩ -tɔa lɩ 'gʋɛ -a man? E 'wɩ "yi drɛ 'mɛn.
\v 11 'Yalɛ -tɛnɔn a 'ka 'va tʋ pɛɛnɔn man, 'pian "an 'ka 'wo 'ka 'va tʋ pɛɛnɔn man dɩ.
\v 12 -Laziglɔ nɛn yaa -sɛn 'an da 'gʋɛ, 'an 'man nɛn yaa drɛ 'nan -e 'waan wʋ -a.
\v 13 Maan ve 'cɛɛ 'wɩ tɩglɩ 'a 'nan, fɛnan pɛɛnɔn nɛn minnun Bali -le 'wɩ 'nɔnnɔn ve 'trɛda bɛ, 'wɩ nɛn lɩ 'gʋɛ yaa drɛ bɛ, waa -nan 'sinan "paa, ɛn -yɛɛ -maan 'lɔɔ -e lɩ 'bɔ 'cin 'e 'fɔla minnun ji.»
\s1 Zudazi 'e pei -fɔ Zuif 'nɔn 'tanɔn 'va
\r (Mk 14.10-11; Lk 22.3-6)
\p 
\v 14 "Bɛ -sru ɛn Zozi -srunɔn 'fuda "fli 'va min -tʋ nɛn waa laabo Zudazi Karioti bɛ, e -kʋ Bali -pannɔn 'tanɔn 'va,
\v 15 ɛn e 'nan -wlɛ 'nan: «-Te an Zozi 'nɔn 'cɛɛ bɛ, -mɛ "nɛn kaa -nɔan 'mɛn?» -A -nan nɛn o 'lein 'wlɛ -fuba yaaga 'nɔn -yrɛ.
\v 16 Yi zɩɛ -a da nɛn Zudazi -a man -wɛɛdɩ 'sia 'nan, tʋ "yi 'e 'pla -e 'e Zozi 'nɔn Zuif 'nɔn 'tanɔn 'bɔ lɛ.
\s1 Zozi 'lee 'e -srunɔn Zuif 'nɔn 'le 'si nɔanba -ji "fɛdi blɩ
\r (Mk 14.12-26; Lk 22.7-23)
\p 
\v 17 'Kpɔun nɛn 'mannyan 'ka "va "dɩɛ, Zuif 'nɔn -a "fɛdi -ble 'flɛ 'tʋ. Zɩ 'flɛ zɩɛ e 'bɔ bɛ, -a yi tɛdɛ da nɛn Zozi -srunɔn -ta -a laabʋlɛ -yrɔ 'nan: «Nyin zia nɛn i ya "vale 'kʋ 'kʋ -kaa tranun 'sidɩ nɔanba -ji "fɛdi bɛ -cee vɛ man drɛ?»
\p 
\v 18 Ɛn Zozi min -tʋ 'tɔ 'vɩ -wlɛ 'nan 'o 'kʋ "va. Yaa 'vɩ -wlɛ 'nan: «'Ka 'kʋ Zeruzalɛm, -e 'ka vɩ -yrɛ 'nan: ‹Bali -le 'wɩ "paazan "e 'nan, 'kʋ vɩ 'yiɛ 'nan, 'yee tʋ 'bɔ 'kogo. 'Yie 'kuin nɛn 'e -kaa tranun 'sidɩ nɔanba -ji "fɛdi -ble 'o 'vale 'e -srunɔn 'a.› »
\v 19 'Wɩ nɛn Zozi -a 'vɩ -wlɛ "bɛ -a -srunɔn -a drɛla "da, ɛn o "fɛdi zɩɛ -a man drɛ.
\p 
\v 20 Zɩ funninmlan 'pla bɛ, ɛn Zozi 'lee 'e -srunɔn 'fuda "fli "nyran fɛnun -sru.
\v 21 O ya fɛnun -blɩnan ɛn Zozi "e 'nan -wlɛ 'nan: «Maan ve 'cɛɛ 'wɩ tɩglɩ 'a 'nan, min -tʋ a 'ka yei 'gʋ, -yɛɛ 'an -nɔan "minnun lɛ.»
\p 
\v 22 'Wɩ zɩɛ e o ta drɛ 'trɔdrɔ "fo, ɛn waa laabʋdɩ 'sia -yrɔ "tʋdʋ 'nan: «Minsan, 'an 'bɔ nɛn?»
\p 
\v 23 Ɛn Zozi "e 'nan -wlɛ 'nan: «Min nɛn 'kʋ 'vale -a 'kʋ 'pɛ wla 'pɔ -tʋwli "ji 'gʋɛ, -a san 'bɛ 'an -nɔan "minnun lɛ.
\v 24 'Wɩ 'kpa nɛn, 'an 'bɔ Blamin -pɩ an -kaa, zɩ waa crɛn -tɛ Bali -le 'fluba 'ji zɩɛ. 'Pian min nɛn yaan 'bɔ Blamin -pɩ -nɔan "minnun lɛ bɛ, 'wɩ -taa "bɔlɛ -a san man. E ya paan -a san -le 'wɩ "yi "a -e 'o vɩlɛ o -ya dɩ.»
\p 
\v 25 -A -nan nɛn Zudazi nɛn e "ta -daa -a -nɔnlɛ Zuif 'nɔn 'tanɔn lɛ bɛ, yaa 'si "va. Yaa laabo -yrɔ 'nan: «Bali -le 'wɩ "paazan, 'an 'bɔ nɛn?»
\p Ɛn Zozi "e 'nan -yrɛ 'nan: «'Yiɛ 'bɛ 'vɩ 'i 'bɔ 'a.»
\p 
\v 26 O -fʋ fɛnun zɩɛ -a -blɩnan, ɛn Zozi 'kpɔun 'si, e Bali muo "fɔ, yaa "nɛn jɛɛn, ɛn yaa -nɔn 'e -srunɔn lɛ. E 'nan -wlɛ 'nan: «'Ka 'si, 'ka -blɩ! -Nyrɛn 'gʋɛ, 'an 'kɔlɛ nɛn.»
\p 
\v 27 "Bɛ -sru e 'kulenɛn nɛn rɛzɛn -wɛn cɩ -ji bɛ -a 'si, e Bali muo "fɔ, ɛn yaa -nɔn 'e -srunɔn lɛ. E 'nan -wlɛ 'nan: «'Ka mlin 'ka pɛɛnɔn!
\v 28 -Nyrɛn 'gʋɛ, 'an nyɛn nɛn. -A 'bɔ nɛn Bali "ta -a "sia -e 'e blamin 'lee 'e 'bɔ yei "sɛn 'e cin va. E "ta -sɛanla 'nan -e Bali 'e min "kaga "le 'wɩ 'wlidɩ 'fui.
\v 29 Maan ve 'cɛɛ 'nan, ma'an "nyian rɛzɛn -wɛn 'mlian dɩ, -trilii -e yi nɛn -kaa pee -mlian 'e cin va 'an "tɩ "le mingɔnnɛn trɛda bɛ 'e bɔ.»
\p 
\v 30 Zɩ o cɛɛn fɛnun -blɩdɩ man bɛ, o Bali 'tɔ bɔ "dre "fɔ. "Bɛ -sru ɛn o -kʋ Olivie pɔn da.
\s1 Zozi -a 'vɩ 'nan Piɛri "sia 'e -sru
\r (Mk 14.26-31; Lk 22.31-34)
\p 
\v 31 Tɔɔn Zozi "e 'nan -wlɛ 'nan: «Cɛɛgʋ -pei 'gʋɛ -a man bɛ, 'ka pɛɛnɔn 'ci -taa "srɛlɛ, -e 'ka 'si 'an -sru. Kɔɔ e ya 'e 'crɛn -tɛdɩ Bali -le 'fluba 'ji 'nan:
\q1 ‹Bali "e 'nan,
\q1 e 'bla -sru "pinzan -tɛa
\q1 -e 'blanun 'o fuila "man.›
\m 
\v 32 'Pian "bɛ -sru, -te an wluan 'kanɔn 'va bɛ, an -tɔala 'ka 'lɛ Galile 'lɛglɔn 'ji.»
\p 
\v 33 Ɛn Piɛri "e 'nan -yrɛ 'nan: «-Te 'yie "wɛan min pɛɛnɔn 'ci srɛman -e 'o 'si 'i -sru "bɛ, 'an 'tʋwli 'gʋɛ, ma'an 'sia 'i -sru 'li "fo "dɩ.»
\p 
\v 34 -A -nan nɛn Zozi "e 'nan -yrɛ 'nan: «Maan ve 'yiɛ 'wɩ tɩglɩ 'a 'nan, -pei 'bɔ 'gʋɛ -a man bɛ, yia ve 'e 'pa -a yaaga 'nan, yi'an 'tɔa dɩ, 'vaa -e mannɛn tɛdɛ 'e 'wɩ.»
\p 
\v 35 Ɛn Piɛri -a 'vɩ -yrɛ 'nan: «-Te e ya 'nan kʋɛ -kaa 'kʋ 'vale 'yia oo, ma'an dra zɩɛ "fo "dɩ.» Ɛn -a -srunɔn pɛɛnɔn "o 'wɩ 'tʋwli zɩɛ -a 'vɩ "nyian.
\s1 Zozi 'kʋ Bali trʋ 'balɛ Zezemani
\r (Mk 14.32-42; Lk 22.39-46)
\p 
\v 36 "Bɛ -sru Zozi 'lee 'e -srunɔn 'kʋ fei nɛn waa laabo Zezemani bɛ -a da. Ɛn e 'nan -wlɛ 'nan: «'Ka 'nyran 'gʋ! An "ta 'sia 'ka "srɔn -e 'an Bali trʋ 'ba.»
\v 37 E Piɛri 'lee Zebede -pɩ "fli "fɔ 'e -sru, ɛn o -kʋ waa. -A -nan nɛn Zozi 'ta drɛdɩ 'sia 'trɔdrɔ te "klan -a -tɛa.
\v 38 Ɛn e 'nan -wlɛ 'nan: «'An 'ta nɛn e drɛ 'trɔdrɔ 'gʋɛ, e "mlianla 'an da. 'Ka 'fʋ 'gʋ, -e -kaa yi 'sɔn 'e cin va!»
\p 
\v 39 E pli 'e 'lɛ "wɛnnɔn, e blula "tra, ɛn e Bali trʋ 'badɩ 'sia. Yaa 'vɩ 'nan: «'An "tɩ, 'i yra 'si! -Te i "we "man "bɛ, 'kulenɛn nɛn 'wɩ yɩdɩ cɩ -ji e -taa 'labɛ, 'i drɛ -e 'e "paala 'an man! 'Pian te 'e drɛ 'an 'ci 'sɔ wɩ -a dɩ, 'i 'bɔ 'ci 'sɔ wɩ nɛn 'e drɛ!»
\p 
\v 40 "Bɛ -sru ɛn e 'li 'e da 'e -srunɔn yaaga zɩɛ o va. E 'bɔ o man te o ya yi -tɛnan, e Piɛri fuʋ, ɛn yaa 'vɩ -yrɛ 'nan: «Ka'a -kɔlalɛ 'padɩ -a 'an 'va -e 'ka yi 'sɔn tʋ "wɛnnɛn 'gʋɛ -a wlu dʋʋ?
\v 41 'Ka yi 'sɔn -e 'ka Bali trʋ 'ba, "tɔgɔ 'wɩ 'wlidɩ 'e 'ka 'man yɩ! Blamin a "va 'nan 'e 'wɩ "yi "dra, 'pian -a 'plɛblɛ 'ka -yrɔ "dɩ.»
\p 
\v 42 Zozi 'li -bei "flizan 'wʋ 'e da, ɛn e Bali trʋ 'ba "nyian. Yaa 'vɩ 'nan: «'An "tɩ, 'i yra 'si! -Te i 'ka "vale 'i "we "man -e 'kulenɛn nɛn 'wɩ yɩdɩ cɩ -ji e -taa 'labɛ, e "paala 'an man dɩɛ, 'i 'ci 'sɔ wɩ nɛn 'e drɛ!»
\p 
\v 43 E 'li 'e da, ɛn e 'bɔ o man "nyian yi -tɛnan, kɔɔ o "koe "nyan.
\p 
\v 44 Zozi o 'tʋɩ "nyian, ɛn e -kʋ Bali trʋ 'balɛ. -A cɛin yaagazan nɛn te e 'wɩ 'tʋwli zɩɛ -a ve Bali lɛ.
\p 
\v 45 -A -nan nɛn e 'li 'e da 'e -srunɔn 'va, ɛn yaa laabʋ -wlɔ 'nan: «Ka yi -tɛa tian, te ka "flianla 'ka man -a -trɔɔ? Maan ve 'cɛɛ 'nan, -a tʋ 'bɔ "mɛn. Tʋ nɛn, minnun 'an 'bɔ Blamin -pɩ -nɔan 'wɩ 'wlidɩ "drɛnɔn lɛ bɛ, e 'bɔ.
\v 46 'Ka 'wluan lou, -e -kaa kʋ! Min nɛn e "ta 'an -nɔan "minnun lɛ bɛ, e ya -plinan 'kogo.»
\s1 Zuif 'nɔn 'tanɔn Zozi 'kun
\r (Mk 14.43-50; Lk 22.47-53; Zan 18.3-12)
\p 
\v 47 Zozi 'fʋ 'wɩ zɩɛ -a vɩnan, tɔɔn ɛn Zudazi nɛn -a -srunɔn 'fuda "fli 'bɔ 'va min -tʋ -a bɛ, e 'bɔla. -Wɛɛ cɩ 'o 'vale min "kaga "a, ɛn sɛnnun 'lee yibanun a -wlɔ. Bali -pannɔn 'tanɔn 'lee min cejenun 'bɛ o 'pa 'sia.
\v 48 Zudazi -a 'vɩ 'e 'cɛn minnun zɩɛ -wlɛ 'nan: «Min nɛn an -atu -tɛ "man "bɛ, te Zozi nɛn. -A 'bɔ nɛn 'ka 'kun!»
\v 49 -Yee "wɛan zɩ o 'bɔla bɛ, tɔɔn ɛn e pli Zozi man. E 'nan: «'An 'san, mɛin 'tɔ bo.» -A -nan nɛn e -atu -tɛ "man.
\p 
\v 50 Ɛn Zozi "e 'nan -yrɛ 'nan: «'An bee, 'wɩ nɛn i -ta "man "bɛ, 'i drɛ!» Tɔɔn minnun nɛn e -ta waa bɛ, o Zozi 'kun.
\p 
\v 51 -A -nan nɛn Zozi -sruzan -tʋ 'yee sɛn 'sʋ 'ji, ɛn e Bali -pannɔn 'tazan 'suzan 'tʋ "trɔɛn cɛɛn.
\p 
\v 52 'Pian Zozi "e 'nan -yrɛ 'nan: «'I 'yie sɛn wʋ 'e 'kɔlɛ 'ji! Maan ve 'yie 'nan, minnun pɛɛnɔn nɛn o sɛn "siala min man bɛ, sɛn "nɛn "nɛn o -kaala.
\v 53 'I 'tɔ 'nan, "te an ya "va 'nan min 'e 'pa 'an va bɛ, maan ve 'an "tɩ "lɛ 'nan, 'e 'yee 'pasianɔn nɛn laji bɛ, o 'pa 'sia 'mɛn. O 'kɔn -kuli 'pa 'tʋdʋ -fuda 'fiili, -e 'waan 'ta kuli -tan.
\v 54 'Pian -te 'wɩ zɩɛ e drɛ bɛ, 'wɩ nɛn e ya 'e 'crɛn -tɛdɩ Bali -le 'fluba 'ji bɛ, ya'a 'kɔlaman -e 'e 'lɛ sɔɔ dɩ. Kɔɔ e ya 'e 'crɛn -tɛdɩ 'nan, zɩ 'e drɛ zɩɛ.»
\p 
\v 55 Ɛn Zozi 'a 'vɩ min "kaga zɩɛ -wlɛ 'nan: «-Mɛ "le "wɛan nɛn ka -ta 'an 'kunlɛ 'ka 'lɔ le sɛnnun 'lee yibanun -a "le ka -ta crinzan -sru? Tʋ pɛɛnɔn man an ya Bali -pan 'kuin, te an Bali -le 'wɩ "paaman 'ka 'ji, ɛn ka'an 'kunlɛ dɩ.
\v 56 'Pian 'wɩ pɛɛnɔn zɩɛ, e drɛ -e 'wɩnun nɛn Bali 'lewei vɩnɔn -a crɛn -tɛ 'e 'cɛn bɛ 'e 'lɛ sɔɔ.»
\p -A -nan nɛn Zozi -srunɔn pɛɛnɔn 'wi "man -a -sru, ɛn o flan bli.
\s1 Minnun -kʋ Zozi 'a tin 'banɔn 'lɛ
\r (Mk 14.53-65; Lk 22.54-55, 63-71; Zan 18.12-14, 19-24)
\p 
\v 57 Minnun nɛn o Zozi 'kun bɛ, o -kʋ Zozi 'a Bali -pannɔn 'tazan nɛn waa laabo Kaifa bɛ, -yee "kɔnnɛn. 'Fluba 'ci vɩnɔn 'lee min cejenun 'o cin 'yɩ fɛ zɩɛ -a -nan.
\v 58 Piɛri -fʋ -kɔɔbli, te e -kʋla Zozi -sru. E -kʋ zɩɛ -trilii, ɛn e 'bɔla Bali -pannɔn 'tazan -le "kɔnnɛn. E wla -yee -klɔn -ji, ɛn e -nyran -a 'sunɔn yei, 'wɩ nɛn e bɔa Zozi man bɛ -a -nan yɩdɩ -le "wɛan.
\p 
\v 59 Bali -pannɔn 'tanɔn 'lee tin 'banɔn pɛɛnɔn a "va 'nan o 'wlu wɩ -tʋ "paa Zozi da, -e 'o -kɔla -a -tɛdɩ -a -le "wɛan.
\v 60 Min "kaga 'wlu 'sɛn Zozi man, 'pian 'wɩ pɛɛnɔn zɩɛ ya'a tin -tɛlɛ Zozi da "fo "dɩ.
\p "Bɛ -sru min "fli "ta ɛn "o 'vɩ 'nan:
\v 61 «Min 'labɛ e 'nan: ‹'An -kɔlaman Bali -pan 'kɔn 'widɩ -a, -e 'an pee -tɔ yi yaaga 'wlu.› »
\p 
\v 62 -A -nan nɛn Bali -pannɔn 'tazan wluan lou, ɛn yaa 'vɩ Zozi lɛ 'nan: «'Wɩ nɛn minnun -a ve 'i man bɛ, yi'a sia "va "dʋʋ?»
\v 63 Zozi 'ka -a 'silɛ "da -yrɛ "dɩ.
\p Ɛn Bali -pannɔn 'tazan -a 'vɩ -yrɛ 'nan: «'I 'pɛ wluan Bali nɛn -a yiɛ cɩ "man "bɛ -a 'lɛ! Maan laabo 'i 'lɔ 'nan, min 'sizan 'wɩ 'ji nɛn yia? Bali -pɩ nɛn yia? 'Wɩ zɩɛ 'i -ci 'si 'kʋɛ!»
\p 
\v 64 Ɛn Zozi "e 'nan -yrɛ 'nan: «-Nyrɛn, yia 'vɩ 'i 'bɔ 'a bɛ. Maan ve 'cɛɛ 'nan, -e 'e 'sia cɛɛgʋ yi 'gʋɛ -a da bɛ, kaan 'bɔ Blamin -pɩ ye 'an -nyrandɩ 'plɛblɛ pɛɛnɔn 'san Bali -pɛ "yi "da. Ɛn "bɛ -sru kaan ye "nyian laji, te an ya -tanan "lolu -koei "da.»
\p 
\v 65 -A vɩdɩ zɩɛ e Bali -pannɔn 'tazan ta kli, ɛn 'e 'ta sɔnun 'fʋɩ bʋdɩ 'sia. -A -nan nɛn e 'nan: «E Bali srɔn! -Kaa 'ka "nyian -yee 'wɩ 'nan yɩzan pee -va "fo "dɩ. "Srɔn nɛn e "sia -a wʋnan bɛ, kaa 'man 'ka 'bɔ 'a.
\v 66 "Ka "ve -ji 'nɔn?»
\p Ɛn minnun -a 'si "va -yrɛ 'nan: «E 'sɔ -ka vɛ -a.»
\p 
\v 67 'Wɩ zɩɛ -a da nɛn, o 'le 'yi 'sɛndɩ 'sia -a yra, ɛn o -fɔlɛ wʋʋdɩ "va 'sia. Min -mienun 'pa -fɔa -a yra, te waa laabo -yrɔ 'nan:
\v 68 «'Yie 'nan min 'sizan 'wi 'ji nɛn 'yia. -Yee "wɛan -te i ya Bali 'lewei vɩzan a bɛ, min nɛn e fɛ tuʋ 'yiɛ bɛ, 'i -kɔɔn 'kʋɛ.»
\s1 Piɛri yɔɔ "da 'nan 'e 'ka Zozi -sruzan 'a dɩ
\r (Mk 14.66-72; Lk 22.56-62; Zan 18.15-18, 25-27)
\p 
\v 69 Tʋ zɩɛ -a wlu bɛ, te Piɛri a tian 'e -nyrandɩ -klɔn -ji. -A -nan nɛn nɔan lɩmɔn -tʋ pli "man, ɛn e 'nan -yrɛ 'nan: «Bii 'gʋɛ Galile min Zozi -sruzan 'tʋ nɛn 'yia.»
\p 
\v 70 'Pian Piɛri yɔɔ "da min pɛɛnɔn yiɛ man. E 'nan: «'Wɩ nɛn i cɩ "vale 'i ve bɛ, ma'an tɔa dɩ.»
\p 
\v 71 Ɛn Piɛri -klɔn -yrɛ "nɛn -si 'sia, -a -nan nɛn nɔan lɩmɔn pee -a 'yɩ, ɛn yaa 'vɩ minnun nɛn fɛ zɩɛ -a -nan bɛ -wlɛ 'nan: «Min 'lagʋɛ, e ya Nazarɛtɩ min Zozi -sruzan 'tʋ -a.»
\p 
\v 72 Piɛri yɔɔ "da "nyian, yaa -ci -pɛ wluan, ɛn e 'nan: «Min 'labɛ, ma'an tɔa "fo "dɩ.»
\p 
\v 73 "Bɛ -sru "nyian, minnun nɛn fɛ zɩɛ -a -nan bɛ, o pli Piɛri man ɛn o 'nan -yrɛ 'nan: «'Wɩ 'kpa nɛn. 'I 'bɔ 'gʋɛ, -a -sruzan -tʋ nɛn 'yia. 'Yie 'wɩdɩ -a kɔɔn "man zɩɛ.»
\p 
\v 74 -A -nan nɛn Piɛri "e 'nan: «-Te 'wlu nɛn maan -sɛan "bɛ, Bali 'e 'wɩ "nɛn -kɔɔn 'mɛn. Maan 'vɩ 'cɛɛ 'nan, ma'an min 'labɛ -a tɔa "fo "dɩ.»
\p 'Nun tɔɔn ɛn mannɛn wɩɩ.
\v 75 'Wɩ nɛn Zozi -a 'vɩ Piɛri lɛ bɛ, ɛn -a -cin -trɔa Piɛri ji. Kɔɔ Zozi -a 'vɩ -yrɛ 'nan: «'Vaa -e mannɛn tɛdɛ 'e 'wɩ bɛ, te yia 'vɩ 'e 'pa -a yaaga 'nan yi'an 'tɔa dɩ.» -A -nan nɛn Piɛri 'bɔla bei, ɛn e -wuɔdɩ 'sia 'wɩ 'nanmandɩ -a.
\c 27
\s1 Minnun -kʋ Zozi 'a Rɔm min -kɔnmandan Pilati 'lɛ
\r (Mk 15.1; Lk 23.1; Zan 18.28)
\p 
\v 1 Zɩ tʋ cɛɛn bodrun bɛ, ɛn Bali -pannɔn 'tanɔn 'lee min cejenun pɛɛnɔn 'wei 'pa 'e cin man 'nan 'o Zozi 'tɛ.
\v 2 O Zozi yrɩ, "bɛ -sru ɛn o -kʋ -a -nɔnlɛ Rɔm min -kɔnmandan Pilati lɛ. Mingɔnnɛnnun tazan nɛn Rɔm bɛ, -yɛɛ Pilati -tɔ 'nan 'e 'lɛglɔn 'bɔ 'pla.
\s1 Zudazi -ka -nan wɩ
\r (Drɛwɩ 1.16-20)
\p 
\v 3 Zudazi 'bɔ nɛn, e Zozi -nɔn minnun lɛ bɛ, zɩ yaa 'yɩ 'nan minnun tanɔn tin -tɛ Zozi da 'nan 'e -ka -a 'wɩ 'ji bɛ, -a -nan nɛn 'wɩ 'nandɩ "man 'sia, ɛn e -kʋ 'lein 'wlɛ 'fuba yaaga bɛ -a -nɔnlɛ Bali -pannɔn 'tanɔn 'lee min cejenun lɛ 'e "pa 'ji.
\v 4 E 'nan -wlɛ 'nan: «An 'wɩ 'wlidɩ drɛ min nɛn ya'a 'wɩ 'tʋ drɛlɛ -wlidɩ "dɩɛ, -a -nɔndɩ -a 'cɛɛ.»
\p -A -nan nɛn minnun zɩɛ o 'nan Zudazi lɛ 'nan: «"Kʋe 'man wɩ 'ka 'ji dɩ. 'I 'bɔ 'lɔ wɩ nɛn.»
\p 
\v 5 Tɔɔn Zudazi 'lein 'wlɛnun zɩɛ -a -sran Bali -pan 'kuin, ɛn e -kʋ 'e 'blɔ wʋlɛ baa -ji.
\p 
\v 6 Bali -pannɔn 'tanɔn 'lein 'wlɛnun zɩɛ -a koola, ɛn o 'nan: «-A -si 'ka -kaa 'lɔ -e -kaa "lala 'gʋɛ -a -sɛn Bali -pan 'kuin "lala -va dɩ, kɔɔ "lala nɛn yaa -maan blamin nyɛn -sran bɛ -nyrɛn.»
\v 7 'Wɩ nɛn 'kɔ 'o drɛ "lala zɩɛ -a bɛ, o wei drɛ "da -tʋwli. -A -nan nɛn o -kʋ fei 'lɔlɛ -pɔ -tɔzan -tʋ -lɔ. Fei zɩɛ waa 'lɔ 'nan -e 'e drɛ -pɛnnɔn 'le min wʋnan -a.
\v 8 'Bɛ nɛn -kaa cɩ cɛɛgʋ yi -a 'gʋɛ, minnun fei zɩɛ -a laabo nyɛn fei, kɔɔ "lala zɩɛ -yɛɛ -maan blamin nyɛn -sran.
\p 
\v 9 'Wɩ nɛn Bali 'lewei vɩzan Zeremi -a 'vɩ 'e 'cɛn bɛ, zɩ e 'lɛ sɔɔ zɩɛ. Kɔɔ yaa 'vɩ 'nan:
\q1 «'Lein 'wlɛ 'fuba yaaga nɛn waa 'si min nɛn Izraɛl 'nɔn 'a 'flɛ 'tan bɛ
\q1 -a manvɛ nɛn.
\q1 
\v 10 Ɛn "lala -tʋwli zɩɛ
\q1 -a 'bɔ nɛn waa -nɔn -pɔ -tɔzan -le fei man.
\q1 Zɩ Minsan -a 'vɩ 'mɛn zɩɛ.»
\s1 Zozi a Rɔm min -kɔnmandan Pilati 'lɛ
\r (Mk 15.2-15; Lk 23.2-5, 13-25; Zan 18.29–19.16)
\p 
\v 11 Zɩ minnun 'bɔla Zozi 'a -kɔnmandan 'lɛ bɛ, ɛn -kɔnmandan 'wɩ laabʋ -yrɔ. Yaa laabʋ -yrɔ 'nan: «Zuif 'nɔn 'le mingɔnnɛn nɛn 'yia?»
\p Zozi "e 'nan -yrɛ 'nan: «-Nyrɛn, yia 'vɩ 'i 'bɔ 'a bɛ.»
\p 
\v 12 'Wɩnun nɛn Bali -pannɔn 'tanɔn 'lee min cejenun -a 'vɩ Zozi man bɛ, Zozi 'ka 'wɩ 'tʋ 'silɛ "da "fo "dɩ.
\v 13 -A -nan nɛn Pilati "e 'nan -yrɛ 'nan: «'Wɩ pɛɛnɔn nɛn waa "paa 'i da bɛ, yi'a maan dʋʋ?»
\v 14 'Pian Zozi 'ka 'wɩ 'tʋ 'silɛ "da -yrɛ "fo "dɩ. 'Wɩ zɩɛ e -kɔnmandan 'kan 'e 'ciɩla "da.
\p 
\v 15 Lɛ -tʋdʋ pɛɛnɔn man bɛ, -te Zuif 'nɔn tranun -le 'sidɩ nɔanba -ji "fɛdi drɛdɩ 'bɔ bɛ, -kɔnmandan "sia -pʋ 'kɔnzan 'tʋ man. -Pʋ 'kɔnzan nɛn minnun cɩ "va 'nan 'o 'si man bɛ, -a man nɛn e "sia.
\v 16 Lɛ 'bɔ zɩɛ -a -ji bɛ, te min -tʋ nɛn e 'wɩ 'wlidɩ -dan drɛ -a 'wɩ a 'e fuiladɩ "man "bɛ e ya -pʋ 'kuin. Min zɩɛ waa laabo Barabazi.
\v 17 -Yee "wɛan zɩ minnun a 'o cin yɩdɩ bɛ, ɛn Pilati -a laabʋ -wlɔ 'nan: «Barabazi 'lee Zozi nɛn waa laabo min 'sizan 'wɩ 'ji bɛ, -tɩ man nɛn 'an 'si o "fli yei?»
\v 18 Pilati -a -tɔa 'nan minnun tanɔn "naan Zozi man 'e "tun, -yee "wɛan nɛn o -ta Zozi 'a 'yrɛ.
\p 
\v 19 Pilati a 'e -nyrandɩ 'yee tin 'ba pɛin -da tin -sru, ɛn -a nan min 'pa 'sia -yrɛ. E 'nan: «Min 'labɛ ya'a 'wɩ 'tʋ drɛlɛ -wlidɩ "dɩ. Te 'i 'pɛ wʋ -yee 'wɩ 'ji dɩ. Kɔɔ paan 'pei -man nyrin nɛn maan -tɛ bɛ, 'an "koe 'nyan -yee "wɛan 'kpa tɩglɩ.»
\p 
\v 20 Tʋ zɩɛ -a wlu bɛ, Bali -pannɔn 'tanɔn 'lee min cejenun -a 'vɩ minnun lɛ 'nan, 'o vɩ 'nan Barabazi man nɛn Pilati 'e 'si -e 'e Zozi 'tɛ.
\p 
\v 21 -Yee "wɛan nɛn zɩ -kɔnmandan -a laabʋ -wlɔ "nyian 'nan: «Min "fli 'gʋɛ o yei "bɛ, -tɩ man nɛn 'an 'si?»
\p Ɛn o pɛɛnɔn -a 'vɩ 'nan: «Barabazi man nɛn 'i 'si.»
\p 
\v 22 Pilati -a laabʋ -wlɔ 'nan: «Zozi nɛn waa laabo min 'sizan 'wɩ 'ji bɛ, 'an drɛ -yrɛ 'kɔ?»
\p Ɛn o pɛɛnɔn -a 'vɩ -yrɛ 'nan: «'I -pɛin yiba "plan da.»
\p 
\v 23 -A -nan nɛn Pilati -a laabʋ -wlɔ 'nan: «'Wɩ 'wlidɩ "cɛn "nɛn yaa drɛ -yee "wɛan 'an -pɛin yiba "plan da?»
\p Ɛn o pɛɛnɔn paan "nyian 'kpa 'plɛblɛ. Waa 'vɩ 'nan: «'I -pɛin yiba "plan da!»
\p 
\v 24 Pilati -a 'yɩ 'nan, 'e 'ka o 'klɩnan 'wɩ 'a dɩ, te minnun plaman "bʋʋ. -A -nan nɛn e 'yi 'si, 'e 'pɛ -man foe minnun pɛɛnɔn yiɛ man, ɛn e 'nan -wlɛ 'nan: «Mɛɛn "cɛɛ vɩ 'nan o min 'lagʋɛ -a -tɛ dɩ. -Te e -ka bɛ, 'ka 'bɔ 'lɔ 'wɩ nɛn.»
\p 
\v 25 Ɛn minnun wɩɩ "man o pɛɛnɔn. Waa 'vɩ 'nan: «-A -ka wɩ 'e 'pa 'kʋ da, ɛn 'e 'pa 'kʋe 'nɛnnun da.»
\p 
\v 26 -A -nan nɛn Pilati 'si Barabazi man, ɛn yaa 'vɩ 'yee 'sounjanun lɛ 'nan, 'o Zozi 'sɔn -ngble -a, -e 'o 'kʋ -a -pɛin yiba "plan da.
\s1 'Sounjanun Zozi sɛɛ 'wʋ
\r (Mk 15.16-20; Zan 19.2-3)
\p 
\v 27 -Kɔnmandan -le 'sounjanun -kʋ Zozi 'a -kɔnmandan -le -klɔn -ji. Ɛn o 'sounjanun pɛɛnɔn cin 'yɩ "man.
\v 28 O -yee sɔnun 'sʋ 'e da, ɛn o mingɔnnɛn -tralɛ -gblɔ 'tɛndɛn 'tʋ 'wʋ "da.
\v 29 O lei 'tan, ɛn waa 'wʋ -a -wulo -man "le mingɔnnɛn kle 'zʋ. Ɛn o -cɛan -kɔ -tʋ -nɔn -a -pɛ "yi "lɛ, "le -yee mingɔnnɛn "tonyrin -zʋ. -A -nan nɛn 'o "po -sɔɔnladɩ 'sia "wlu, te waa sɛɛ wo. Waa ve -yrɛ 'nan: «Zuif 'nɔn 'le mingɔnnɛn, 'tɩɩ 'tɔ bo!»
\v 30 O 'le 'yi -sɛan "da, ɛn "nyian o -cɛan -kɔ "sia -yrɔ, -e 'o 'lɛ wʋla -a -win -ji.
\v 31 Zɩ o cɛɛn -a sɛɛ wʋdɩ man bɛ, ɛn o mingɔnnɛn -tralɛ zɩɛ -a 'sʋ "da. O -yee sɔnun 'wʋ 'e da, ɛn o -kʋ -a 'nan -e 'o -pɛin yiba "plan da.
\s1 Zozi -pɛinnan yiba "plan da
\r (Mk 15.21-32; Lk 23.26-43; Zan 19.17-27)
\p 
\v 32 'Sounjanun -kʋdɩ 'sia Zozi 'a, ɛn 'o cin 'yɩ Sirene min -tʋ nɛn waa laabo Simɔn bɛ -a. 'Sounjanun 'tɔ Simɔn zɩɛ -a -sru "sa -a, 'nan 'e Zozi 'le yiba "plan 'sia.
\p 
\v 33 O 'bɔla fɛnan nɛn waa laabo Gɔlgota bɛ -a -nan. Gɔlgota -ci nɛn 'nan, min -wulo klo.
\v 34 -Wɛn nɛn waa baa fɛ -tʋ nyrannyrandɩ -a bɛ, waa -nɔn -yrɛ 'nan 'e mlin. 'Pian zɩ yaa -nanjɛɛn 'e 'le bɛ, ya'a 'wɩlɛ "man -e 'e mlin dɩ.
\p 
\v 35 Waa -pɛin yiba "plan da, "bɛ -sru ɛn o -yee sɔnun pli 'o cin yei. Waa drɛ 'lein 'wlɛ 'tuʋladɩ da. ['Wɩ nɛn Bali 'lewei vɩzan -a 'vɩ 'e 'cɛn bɛ, zɩ e 'lɛ sɔɔ zɩɛ. Kɔɔ yaa 'vɩ 'nan:
\q1 «O 'mɛn sɔnun pli 'o cin yei,
\q1 ɛn o 'mɛn sɔ -gblɔ 'sia
\q1 'lein 'wlɛ 'tuʋladɩ da.»]
\p 
\v 36 "Bɛ -sru ɛn 'sounjanun -nyran, te o Zozi 'nanjɛan.
\v 37 'Wɩ nɛn -yee "wɛan o Zozi -pɛin yiba "plan da bɛ, waa crɛn -tɛ ɛn waa 'pa -a -wulo da lou. Waa crɛn -tɛ 'nan:
\qc «Min 'gʋɛ Zozi nɛn,
\qc e ya Zuif 'nɔn 'le mingɔnnɛn -a.»
\p 
\v 38 O 'wɩ 'wlidɩ "drɛnɔn "fli pɛin "nyian yiba "plan da. Waa -tʋ pɛin yiba "plan da Zozi 'pɛ "yi "da, ɛn waa -tʋ pɛin yiba "plan da -a -pɛ bʋ da.
\p 
\v 39 Minnun nɛn o -ciala fɛ zɩɛ -a -nan bɛ, o Zozi "srɔnman, te 'o 'wulo nyɔɔnman.
\v 40 Waa ve 'nan: «Yiɛ "cɛɛ 'vɩ 'nan 'i Bali -pan 'kɔn -wia -e 'i pee -tɔ yi yaaga 'wlu 'gʋ dʋʋ? -Te i ya Bali -pɩ -a bɛ, 'i 'fli 'si 'wɩ 'ji, -e 'i 'si yiba "plan 'labɛ -a da!»
\p 
\v 41 Bali -pannɔn 'tanɔn 'lee 'fluba 'ci vɩnɔn 'lee min cejenun "o sɛɛ 'wʋ "nyian. "O 'vɩ 'nan:
\v 42 «E min peenun 'si 'wɩ 'ji, 'pian ya'a 'kɔlaman 'e 'fli 'sidɩ -a 'wɩ 'ji dɩ. -Te e ya Izraɛl 'nɔn 'le mingɔnnɛn -a bɛ, 'e 'si yiba "plan da 'e -sɔɔnla -e 'kʋ yi -tɛra "da.
\v 43 E yi -tɛra Bali da 'nan Bali "paa 'e 'va, ɛn yaa 'vɩ 'nan 'e ya Bali -pɩ -a. -Yee "wɛan -te Bali -a ye "yi "bɛ, Bali 'e 'si 'wɩ "mɛn!»
\p 
\v 44 'Wɩ 'wlidɩ "drɛnɔn nɛn minnun o pɛin yiba "plan da Zozi "srɔn "bɛ, "o Zozi srɔn "nyian 'wɩ 'tʋwli zɩɛ -a vɩdɩ -a.
\s1 Zozi 'ka -nan
\r (Mk 15.33-41; Lk 23.44-49; Zan 19.28-30)
\p 
\v 45 Zɩ yidɛ 'bɔ min -win -ji 'sɛzɛ bɛ, ɛn klun -trɔa 'lɛglɔn pɛɛnɔn 'ji. E -fʋ zɩɛ -trilii ɛn funninmlan yidɛ tɛɛnla.
\v 46 Zɩ funninmlan yidɛ tɛɛnla bɛ, ɛn Zozi paan 'kpa 'plɛblɛ. Yaa 'vɩ 'e fla wei -ji 'nan: «Eli, Eli lama sabatani?» 'Wɩ zɩɛ -a -ci nɛn 'nan: «'Mɛn Bali, 'mɛn Bali, -mɛ "le "wɛan nɛn 'i 'pɛ 'si 'an -sru?»
\p 
\v 47 Min -mienun nɛn fɛ zɩɛ -a -nan bɛ, waa 'man, ɛn o 'nan: «E ya Eli laabʋnan.»
\p 
\v 48 'Nun tɔɔn 'sounja min -tʋ flan bli, e -kʋ sɔ 'silɛ, yaa 'wʋ -wɛn 'wlɛ 'cɛn 'va, yaa 'wʋ 'cɛan -kɔ "nɛn, ɛn yaa 'pa Zozi 'lɛbo "nɛn 'nan -e 'e 'yi flɔn "ji.
\v 49 'Pian 'sounja -mienun "o 'vɩ 'nan: «'I 'tɔ -e -kaa -nan yɩ, -te Eli -taa -a 'silɛ 'wɩ 'ji -o.»
\p 
\v 50 Zozi paan "nyian 'kpa 'plɛblɛ, ɛn 'e yiɛ 'lɛ 'wʋ.
\p 
\v 51 'Nun tɔɔn sɔ -dan nɛn 'e 'tindɩ Bali -pan 'kuin bɛ, e 'fʋɩ 'bʋ 'ji "fli. E 'fʋɩ bʋdɩ 'sia lou, ɛn yaa -sɛn "tra. 'Trɛ nyɔɔn, ɛn puo -kɔlɛnun 'fʋɩ bʋʋ.
\v 52 Min -yrɛnun 'lɛ sʋʋ, ɛn Bali -le minnun "kaga wluan 'kanɔn 'va,
\v 53 te o bɔala 'yrɛ -ji. 'Pian zɩ Zozi wluan 'kanɔn 'va bɛ, -a -nan nɛn o -kʋ 'o 'fli -kɔɔnlɛ. 'O 'fli kɔɔn min "kaga "lɛ Zeruzalɛm nɛn Bali -le 'fla 'saun -a bɛ -a da.
\p 
\v 54 'Sounjanun tazan 'lee 'yee minnun nɛn 'o yiɛ 'tɔ Zozi 'va bɛ, zɩ 'trɛ nyɔɔn waa -nan 'yɩ bɛ, ɛn 'wɩ pɛɛnɔn nɛn e drɛ waa -nan 'yɩ bɛ, -a "klan o -tɛdɩ 'sia. -A -nan nɛn waa 'vɩ 'nan: «'Wɩ 'kpa nɛn, min 'labɛ Bali -pɩ nɛn.»
\p 
\v 55 Fɛ 'bɔ zɩɛ -a -nan bɛ, lɩmɔn "kaga "a 'o 'tɔdɩ -kɔɔbli, te o yiɛ a -nan nun. Lɩmɔnnun nɛn o sɔɔnla Zozi -sru Galile, te o 'nyranman "paa Zozi lɛ bɛ o 'bɔ nɛn.
\v 56 Lɩmɔnnun zɩɛ, Madala lɩ Mari a o va, ɛn Zaji 'lee Zozɛfʋ "bʋ Mari a o va, ɛn Zebede -pɩnun "bʋ "a o va.
\s1 Zozi wʋ -nan
\r (Mk 15.42-47; Lk 23.50-56; Zan 19.38-42)
\p 
\v 57 Zɩ funninmlan 'pla bɛ, ɛn fɛzan -tʋ nɛn e 'sia Arimate bɛ e -ta. Waa laabo Zozɛfʋ. Zozi -sruzan 'tʋ nɛn.
\v 58 E -kʋ toba -fɔlɛ Pilati lɛ 'nan 'e Zozi pa -nɔn 'yrɛ. Ɛn Pilati -a 'vɩ 'yee minnun lɛ 'nan 'o -nɔn -yrɛ.
\v 59 Zozɛfʋ Zozi 'kadɩ zɩɛ -a 'si, e sɔ -trɛdrɛ 'pa "man,
\v 60 ɛn e -kʋ -a wʋlɛ. Yaa 'wʋ min -yrɛ -trɛ nɛn waa cɛɛn puo -kɔlɛ ji bɛ -a -ji. Waa cɛɛn paan -a 'bɔ 'fli -le vɛ -a. "Bɛ -sru e -kɔlɛ -dan blu, yaa -tɔ -yrɛ zɩɛ -a "nɛn, ɛn e -kʋ.
\v 61 Tʋ zɩɛ -a wlu bɛ, te Madala lɩ Mari 'lee Mari -tʋ a -nan. O -fʋ 'o -nyrandɩ -yrɛ 'bɔ 'lɛ "nɛn.
\s1 'Sounjanun 'o yiɛ 'tɔ Zozi 'yrɛ -va
\p 
\v 62 Zɩ tʋ cɛɛn bɛ, Bali -pannɔn 'tanɔn 'lee Farizɛn 'nɔn 'kʋ Pilati -va. Zuif 'nɔn 'le 'flinla "yi da nɛn o -kʋ. -Yɛɛ cɩ Saba yi -a.
\v 63 O 'nan -yrɛ 'nan: «'Kʋ 'san, 'wɩ 'tʋ -cin -trɔa 'kʋ 'ji, -yee "wɛan nɛn kʋ -ta. 'Wluzan 'labɛ, te -a yiɛ a tian "man "bɛ, e 'nan, -te e -ka bɛ, e yi dra yaaga -e 'e 'wluan 'kanɔn 'va.
\v 64 -Yee "wɛan kʋi trʋ "baa 'nan 'i vɩ 'yie minnun lɛ -e 'o yiɛ 'tɔ -a -yrɛ -va -trilii yi yaaga. 'I drɛ zɩɛ "tɔgɔ Zozi -srunɔn 'o 'kʋ Zozi pa 'si -yrɛ -ji, -e 'o 'wlu 'sɛn minnun lɛ 'nan e wluan -kanɔn 'va. 'Wlu zɩɛ 'bɛ 'cibɛn -taa 'mlinlɛ -a tɛdɛ da.»
\p 
\v 65 -A -nan nɛn Pilati "e 'nan -wlɛ 'nan: «'Sounja 'pa 'tʋ 'labɛ, maan -nɔan 'cɛɛ. 'Ka 'kʋ waa, -e 'o yiɛ 'tɔ -yrɛ 'bɔ 'va "le zɩ ka cɩ "va "bɛ -yee 'wɩ 'zʋ.»
\v 66 O -kʋ, o -yrɛ 'bɔ "kɔnnɛn 'pla, ɛn o 'sounjanun -tɔ -a 'lɛ "nɛn.
\c 28
\s1 Zozi wluan -kanɔn 'va
\r (Mk 16.1-11; Lk 24.1-12; Zan 20.1-18)
\p 
\v 1 'Mɔnnɛn yi nɛn 'bɛ cɩ Zuif 'nɔn 'le 'flinla "yi -sru "yi -a. 'Mɔnnɛn yi zɩɛ, -a bodrun puunɔn nɛn Madala lɩ Mari 'lee Mari -tʋzan bɛ, o -kʋ -yrɛ da.
\p 
\v 2 'Nun tɔɔn 'trɛ nyɔɔn 'kpa 'plɛblɛ. Minsan -le 'pasiazan -tʋ 'bɛ 'si laji, e -kɔlɛ nɛn waa -tɔ -yrɛ "nɛn "bɛ -a 'sinan, ɛn e -nyran "da.
\v 3 E "bia "le zɩ laa 'e 'wlei -wlei -fɔa e "bia bɛ -yee 'wɩ 'zʋ. Ɛn -yee sɔ a 'fuvu, -a -kɔɔn "manvɛ "ka "dɩ.
\v 4 Nyɛn 'sounjanun cɛɛn, ɛn o nyɔɔndɩ 'sia. -A -nan nɛn o tɛɛla "tra. O drɛ "le minnun nɛn o kaa bɛ -wee 'wɩ 'zʋ.
\p 
\v 5 Ɛn Bali -le 'pasiazan tin 'badɩ 'sia lɩmɔnnun lɛ. Yaa 'vɩ -wlɛ 'nan: «Te "klan 'e 'ka 'tɛ dɩ! Maan -tɔa 'nan, ka ya Zozi nɛn waa -tɛ yiba "plan da bɛ -a -wɛɛnan.
\v 6 E 'ka 'gʋ dɩ. E wluan -kanɔn 'va "le zɩ yaa 'vɩ 'e 'cɛn bɛ -yee 'wɩ 'zʋ. 'Ka 'ta, -e 'ka yiɛ 'tɔ fɛnan nɛn waa 'pla bɛ -a -nan.
\v 7 "Bɛ -sru 'ka 'kʋ "nyiandʋ -a vɩ -a -srunɔn lɛ. 'Ka vɩ -wlɛ 'nan: E wluan 'kanɔn 'va, e -trɔa 'ka 'lɛ Galile, ka bɔa "man "nan nun. 'Wɩ nɛn an -ta -a vɩlɛ 'cɛɛ bɛ, -nyrɛn zɩɛ.»
\p 
\v 8 Lɩmɔnnun zɩɛ o 'si "nyiandʋ -yrɛ da. Nyɛn o cɛɛn, 'pian ci "nrandɩ -dan a -wlɔ, ɛn o -kʋ flan 'blidɩ -a. 'Wɩ zɩɛ o "ta -ko -a 'sinan 'panan Zozi -srunɔn lɛ.
\v 9 'Nun tɔɔn Zozi 'bɔla o 'lɛ, ɛn e 'nan -wlɛ 'nan: «An 'ka 'tɔ bo.» Lɩmɔnnun pli Zozi man, o "po sɔɔn "wlu, ɛn waa cɛin 'kun -a bɔdɩ -a.
\v 10 -A -nan nɛn Zozi "e 'nan -wlɛ 'nan: «Te "klan 'e 'ka 'tɛ dɩ! 'Ka 'kʋ -a vɩ 'an -srunɔn nɛn o drɛ "le 'an "bʋɩnun -zʋ bɛ -wlɛ. 'Ka vɩ -wlɛ 'nan 'o 'kʋ Galile. O bɔa 'an man -nan nun.»
\s1 Bali -pannɔn "lala -nɔn 'sounjanun lɛ 'nan -e 'o 'wlu 'sɛn
\p 
\v 11 Te lɩmɔnnun a -kʋnan -sia bɛ, -a -nan nɛn 'sounja -mienun 'bɔla Zeruzalɛm 'fla. 'Wɩ pɛɛnɔn nɛn e drɛ bɛ, waa 'sinan 'pa Bali -pannɔn 'tanɔn lɛ.
\v 12 Bali -pannɔn 'tanɔn zɩɛ 'o cin 'yɩ 'o 'vale min cejenun -a, ɛn o 'wɩ 'pla "da. -A -nan nɛn o "lala "kaga "nɔn 'sounjanun lɛ,
\v 13 ɛn o 'nan -wlɛ 'nan: «'Ka vɩ 'nan, Zozi -srunɔn 'ta Zozi pa crin wʋlɛ -pei -man, te ka ya yi -tɛnan.
\v 14 'Wɩ zɩɛ -te -kɔnmandan -a 'man bɛ, kʋ toba -fɔa -yrɛ, -e 'kʋ 'wɩ 'si 'ka man.»
\v 15 'Sounjanun "lala zɩɛ -a 'si, ɛn 'wɩ nɛn Bali -pannɔn 'tanɔn -a 'vɩ -wlɛ "bɛ, waa drɛla "da. 'Wɩ nɛn waa 'vɩ zɩɛ Zuif 'nɔn -a ve tian cɛɛgʋ yi -a.
\s1 Zozi 'e 'fli kɔɔn 'e -srunɔn lɛ
\r (Mk 16.14-18; Lk 24.36-49; Zan 20.19-23; Drɛwɩ 1.6-8)
\p 
\v 16 Zozi -srunɔn 'fuda -tʋ -kʋ Galile, pɔn nɛn Zozi -a kɔɔn -wlɛ "bɛ -a da.
\v 17 Zɩ o Zozi 'yɩ bɛ, o "po sɔɔn "wlu -a bɔdɩ -a. 'Pian te o va min -mienun 'o 'ci -fɔɔman.
\p 
\v 18 Zozi pli 'e -srunɔn man, ɛn e 'wɩ tin 'ba -wlɛ. Yaa 'vɩ -wlɛ 'nan: «Bali 'plɛblɛ 'nɔn 'mɛn fɛ pɛɛnɔn da laji, ɛn yaa -nɔn 'mɛn fɛ pɛɛnɔn da 'trɛda.
\v 19 'Ka 'kʋ, 'ka 'lɛglɔn pɛɛnɔn 'ji 'nɔn drɛ 'an -srunɔn 'a! 'Ka o -batize drɛ -kaa "tɩ Bali 'lee 'e 'pɩ 'lee 'yee lei 'saun 'tɔ da.
\v 20 Ɛn 'wɩ pɛɛnɔn nɛn maan paa 'ka 'ji bɛ, 'ka "paa o ji, -e 'o 'ta wʋla "da "le "wɛan. Ɛn -a -cin 'e 'kɔn 'ka 'ji 'nan, an -fo 'ka 'va yi pɛɛnɔn man 'li 'trilii, -e 'trɛ 'nyan tʋ 'e bɔ.»
