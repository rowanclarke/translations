\v 37  \w I|strong="H8478"\w* \w will|strong="H1285"\w* make \w you|strong="H8478"\w* \w pass|strong="H5674"\w* \w under|strong="H8478"\w* \w the|strong="H8478"\w* shepherd’s \w staff|strong="H7626"\w*, \w and|strong="H1285"\w* \w I|strong="H8478"\w* \w will|strong="H1285"\w* \w bring|strong="H5674"\w* \w you|strong="H8478"\w* \w into|strong="H5674"\w* \w the|strong="H8478"\w* \w bond|strong="H4562"\w* \w of|strong="H7626"\w* \w the|strong="H8478"\w* \w covenant|strong="H1285"\w*.  
