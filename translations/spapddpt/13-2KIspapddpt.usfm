\v 27 \w Y|strong="H3068"\w* él dijo: Si \nd \w Yavé|strong="H3068"\w*\nd* no \w te|strong="H4480"\w* \w salva|strong="H3467"\w*, ¿\w de|strong="H4480"\w* dónde \w te|strong="H4480"\w* \w salvo|strong="H3467"\w* \w yo|strong="H4480"\w*? ¿\w Con|strong="H4480"\w* algo \w del|strong="H4480"\w* granero \w o|strong="H3068"\w* \w del|strong="H4480"\w* \w lagar|strong="H3342"\w*?
\v 28 \w Y|strong="H3068"\w* \w el|strong="H1121"\w* \w rey|strong="H4428"\w* agregó: ¿\w Qué|strong="H4100"\w* tienes?
\p \w Y|strong="H3068"\w* ella respondió: \w Esta|strong="H2063"\w* mujer me dijo: \w Entrega|strong="H5414"\w* \w a|strong="H3068"\w* tu \w hijo|strong="H1121"\w* \w para|strong="H5414"\w* \w que|strong="H4100"\w* \w lo|strong="H4100"\w* comamos \w hoy|strong="H3117"\w*, y \w mañana|strong="H4279"\w* comeremos \w el|strong="H1121"\w* mío.
\v 29 \w Cocimos|strong="H1310"\w*, pues, \w a|strong="H3068"\w* mi \w hijo|strong="H1121"\w* y lo comimos. Al \w día|strong="H3117"\w* siguiente le dije: \w Entrega|strong="H5414"\w* \w a|strong="H3068"\w* tu \w hijo|strong="H1121"\w* \w para|strong="H5414"\w* \w que|strong="H3117"\w* lo comamos, pero ella escondió \w a|strong="H3068"\w* su \w hijo|strong="H1121"\w*.
\p 
\v 30 \w Cuando|strong="H1961"\w* \w el|strong="H1931"\w* \w rey|strong="H4428"\w* \w escuchó|strong="H8085"\w* \w las|strong="H5921"\w* \w palabras|strong="H1697"\w* \w de|strong="H5921"\w* \w la|strong="H1931"\w* mujer, mientras \w pasaba|strong="H5674"\w* \w por|strong="H5921"\w* \w el|strong="H1931"\w* \w muro|strong="H2346"\w*, \w rasgó|strong="H7167"\w* \w sus|strong="H1931"\w* ropas. \w Ciertamente|strong="H2009"\w* \w llevaba|strong="H1961"\w* ropa áspera \w sobre|strong="H5921"\w* \w su|strong="H1931"\w* cuerpo.
\v 31 \w Entonces|strong="H3117"\w* dijo: ¡\w Así|strong="H3541"\w* \w me|strong="H5921"\w* \w haga|strong="H6213"\w* \nd ʼElohim\nd*, \w y|strong="H5921"\w* \w aun|strong="H3254"\w* \w me|strong="H5921"\w* \w añada|strong="H3254"\w*, \w si|strong="H5921"\w* \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w de|strong="H5921"\w* Eliseo, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Safat, \w permanece|strong="H5975"\w* \w hoy|strong="H3117"\w* \w sobre|strong="H5921"\w* \w él|strong="H5921"\w*!
\p 
\v 32 Eliseo \w estaba|strong="H3427"\w* \w sentado|strong="H3427"\w* \w en|strong="H3588"\w* \w su|strong="H1931"\w* \w casa|strong="H1004"\w*. \w Los|strong="H3427"\w* \w ancianos|strong="H2205"\w* \w estaban|strong="H3427"\w* \w sentados|strong="H3427"\w* \w con|strong="H3588"\w* \w él|strong="H1931"\w* \w cuando|strong="H3588"\w* \w el|strong="H1931"\w* rey \w envió|strong="H7971"\w* \w a|strong="H3068"\w* uno \w de|strong="H3588"\w* \w sus|strong="H1931"\w* \w hombres|strong="H1121"\w*. \w Pero|strong="H3588"\w* \w antes|strong="H6440"\w* \w que|strong="H3588"\w* \w el|strong="H1931"\w* \w mensajero|strong="H4397"\w* llegara \w a|strong="H3068"\w* \w él|strong="H1931"\w*, Eliseo dijo \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w ancianos|strong="H2205"\w*: ¿\w Vieron|strong="H7200"\w* \w como|strong="H3588"\w* \w este|strong="H2088"\w* \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* \w homicida|strong="H7523"\w* \w envió|strong="H7971"\w* \w a|strong="H3068"\w* cortarme \w la|strong="H1931"\w* \w cabeza|strong="H7218"\w*? Observen \w cuando|strong="H3588"\w* llegue \w el|strong="H1931"\w* emisario, cierren \w la|strong="H1931"\w* \w puerta|strong="H1817"\w* \w e|strong="H3068"\w* impídanle \w la|strong="H1931"\w* entrada. ¿\w No|strong="H3808"\w* \w se|strong="H1931"\w* escucha tras \w él|strong="H1931"\w* \w el|strong="H1931"\w* \w ruido|strong="H6963"\w* \w de|strong="H3588"\w* \w los|strong="H3427"\w* pasos \w de|strong="H3588"\w* \w su|strong="H1931"\w* \tl ʼadón\tl*?
\p 
\v 33 \w Aún|strong="H5750"\w* \w hablaba|strong="H1696"\w* \w con|strong="H5973"\w* ellos, \w cuando|strong="H4100"\w* \w ciertamente|strong="H2009"\w* \w el|strong="H5973"\w* \w mensajero|strong="H4397"\w* bajaba hacia \w él|strong="H5973"\w*, y Eliseo \w dijo|strong="H1696"\w*: Reconozco \w que|strong="H4100"\w* \w esta|strong="H2063"\w* desgracia \w es|strong="H2063"\w* \w de|strong="H5973"\w* parte \w de|strong="H5973"\w* \nd \w Yavé|strong="H3068"\w*\nd*. ¿\w Para|strong="H5973"\w* \w qué|strong="H4100"\w* \w espero|strong="H3176"\w* \w más|strong="H5750"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*?
\c 7
\s1 Fin del sitio de Samaria
\p 
\v 1 Eliseo dijo: \w Escuchen|strong="H8085"\w* la \w Palabra|strong="H1697"\w* \w de|strong="H1697"\w* \nd \w Yavé|strong="H3068"\w*\nd*: \wj ¡\w Mañana|strong="H4279"\w* \w a|strong="H3068"\w* esta \w hora|strong="H6256"\w*, una medida \w de|strong="H1697"\w* flor \w de|strong="H1697"\w* harina \add se venderá\add* \w por|strong="H1697"\w* 11 gramos \w de|strong="H1697"\w* plata, \w y|strong="H3541"\w* dos \w medidas|strong="H5429"\w* \w de|strong="H1697"\w* \w cebada|strong="H8184"\w* \w por|strong="H1697"\w* 11 gramos \w de|strong="H1697"\w* plata en la \w puerta|strong="H8179"\w* \w de|strong="H1697"\w* \w Samaria|strong="H8111"\w*!\wj*
\p 
\v 2 Entonces, \w el|strong="H5921"\w* oficial \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* cual \w se|strong="H1961"\w* apoyaba \w el|strong="H5921"\w* \w rey|strong="H4428"\w*, \w respondió|strong="H6030"\w* \w al|strong="H5921"\w* varón \w de|strong="H5921"\w* \nd ʼElohim\nd*: \w Aun|strong="H3808"\w* \w si|strong="H2005"\w* \nd \w Yavé|strong="H3068"\w*\nd* abre ventanas \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w cielo|strong="H8064"\w*, ¿podría suceder \w esto|strong="H2088"\w*?
\p \w Y|strong="H3068"\w* \w él|strong="H5921"\w* \w respondió|strong="H6030"\w*: \w Mira|strong="H7200"\w*, \w tú|strong="H6213"\w* \w lo|strong="H1697"\w* \w mirarás|strong="H7200"\w* \w con|strong="H5921"\w* tus propios \w ojos|strong="H5869"\w*, pero \w no|strong="H3808"\w* comerás \w de|strong="H5921"\w* ello.
\s1 Cuatro leprosos en la entrada a Samaria sitiada
\p 
\v 3 \w Había|strong="H1961"\w* cuatro \w leprosos|strong="H6879"\w* \w en|strong="H5704"\w* la entrada \w de|strong="H5704"\w* la \w puerta|strong="H6607"\w*. \w Se|strong="H1961"\w* dijeron: ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* \w nos|strong="H4100"\w* quedamos \w aquí|strong="H6311"\w* \w hasta|strong="H5704"\w* \w morir|strong="H4191"\w*?
\v 4 Si decidimos entrar \w en|strong="H3212"\w* la \w ciudad|strong="H5892"\w*, la hambruna \w está|strong="H3427"\w* \w en|strong="H3212"\w* \w ella|strong="H8033"\w* y \w moriremos|strong="H4191"\w* \w allí|strong="H8033"\w*. Si nos quedamos \w aquí|strong="H6311"\w*, también \w moriremos|strong="H4191"\w*. \w Ahora|strong="H6258"\w* \w pues|strong="H6258"\w*, \w vayamos|strong="H3212"\w* y pasemos al \w ejército|strong="H4264"\w* de \w los|strong="H3427"\w* sirios. Si nos dejan \w vivir|strong="H2421"\w*, \w viviremos|strong="H2421"\w*. Si nos matan, no haremos \w más|strong="H4191"\w* \w que|strong="H6258"\w* \w morir|strong="H4191"\w*.
\p 
\v 5 Se \w levantaron|strong="H6965"\w* \w al|strong="H5704"\w* alba \w para|strong="H5704"\w* ir \w al|strong="H5704"\w* \w campamento|strong="H4264"\w* \w de|strong="H5704"\w* los sirios. \w Cuando|strong="H5704"\w* llegaron \w a|strong="H3068"\w* la parte exterior del \w campamento|strong="H4264"\w* \w de|strong="H5704"\w* los sirios, nadie \w estaba|strong="H2009"\w* \w allí|strong="H8033"\w*.
\s1 El triunfo de \nd ʼAdonay\nd* sobre los sirios
\p 
\v 6 \w Porque|strong="H5921"\w* \nd ʼAdonay\nd* produjo \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w campamento|strong="H4264"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* sirios \w estruendo|strong="H6963"\w* \w de|strong="H5921"\w* carruajes, \w ruido|strong="H6963"\w* \w de|strong="H5921"\w* \w caballos|strong="H5483"\w* \w y|strong="H5921"\w* estrépito \w de|strong="H5921"\w* un \w gran|strong="H1419"\w* \w ejército|strong="H2428"\w*. Cada uno dijo \w a|strong="H3068"\w* su compañero: ¡\w Ciertamente|strong="H2009"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* tomó \w a|strong="H3068"\w* sueldo \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* hititas \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w* \w para|strong="H5921"\w* \w que|strong="H5921"\w* vengan \w contra|strong="H5921"\w* \w nosotros|strong="H5921"\w*!
\v 7 \w Por|strong="H5127"\w* \w lo|strong="H1931"\w* \w cual|strong="H1931"\w* \w se|strong="H1931"\w* \w levantaron|strong="H6965"\w*, \w huyeron|strong="H5127"\w* al llegar \w la|strong="H1931"\w* noche y abandonaron \w sus|strong="H1931"\w* tiendas, \w caballos|strong="H5483"\w* y \w asnos|strong="H2543"\w*. \w Dejaron|strong="H5800"\w* \w el|strong="H1931"\w* \w campamento|strong="H4264"\w* tal \w como|strong="H1931"\w* estaba y \w huyeron|strong="H5127"\w* para salvar \w sus|strong="H1931"\w* \w vidas|strong="H5315"\w*.
\p 
\v 8 \w Cuando|strong="H5704"\w* estos \w leprosos|strong="H6879"\w* llegaron \w a|strong="H3068"\w* la parte exterior \w del|strong="H8354"\w* \w campamento|strong="H4264"\w*, \w entraron|strong="H3212"\w* \w en|strong="H5704"\w* una tienda, comieron \w y|strong="H5704"\w* \w bebieron|strong="H8354"\w*. Sacaron \w de|strong="H5704"\w* \w allí|strong="H8033"\w* \w plata|strong="H3701"\w*, \w oro|strong="H2091"\w* \w y|strong="H5704"\w* ropas, \w y|strong="H5704"\w* \w fueron|strong="H3212"\w* \w y|strong="H5704"\w* los \w escondieron|strong="H2934"\w*. \w Luego|strong="H7725"\w* regresaron \w y|strong="H5704"\w* \w entraron|strong="H3212"\w* \w en|strong="H5704"\w* otra tienda. También \w llevaron|strong="H5375"\w* cosas \w de|strong="H5704"\w* \w allí|strong="H8033"\w*, \w fueron|strong="H3212"\w* \w y|strong="H5704"\w* las \w escondieron|strong="H2934"\w*.
\p 
\v 9 \w Después|strong="H5704"\w* \w se|strong="H1931"\w* dijeron \w el|strong="H1931"\w* uno \w al|strong="H5704"\w* \w otro|strong="H2088"\w*: \w No|strong="H3808"\w* \w es|strong="H1931"\w* bueno \w lo|strong="H1931"\w* \w que|strong="H1931"\w* \w hacemos|strong="H6213"\w*. \w Este|strong="H2088"\w* \w es|strong="H1931"\w* \w día|strong="H3117"\w* \w de|strong="H5704"\w* buenas noticias, pero \w nosotros|strong="H1931"\w* \w callamos|strong="H2814"\w*. \w Si|strong="H3808"\w* nos quedamos \w hasta|strong="H5704"\w* \w la|strong="H1931"\w* \w mañana|strong="H1242"\w*, nuestra \w iniquidad|strong="H5771"\w* nos \w alcanzará|strong="H4672"\w*. \w Vayamos|strong="H3212"\w*, entremos \w e|strong="H3068"\w* informemos \w en|strong="H5704"\w* \w la|strong="H1931"\w* \w casa|strong="H1004"\w* del \w rey|strong="H4428"\w*.
\p 
\v 10 Fueron \w y|strong="H3588"\w* \w llamaron|strong="H7121"\w* al centinela \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w ciudad|strong="H5892"\w*. Le informaron: Fuimos al \w campamento|strong="H4264"\w* \w de|strong="H3588"\w* \w los|strong="H1992"\w* sirios. \w Ciertamente|strong="H3588"\w* \w allí|strong="H8033"\w* \w no|strong="H3588"\w* hay hombre, ni alguna \w voz|strong="H6963"\w* \w de|strong="H3588"\w* hombre, \w sino|strong="H3588"\w* \w caballos|strong="H5483"\w* \w y|strong="H3588"\w* \w asnos|strong="H2543"\w* atados, \w y|strong="H3588"\w* \w las|strong="H1992"\w* tiendas intactas.
\v 11 Entonces los centinelas \w gritaron|strong="H7121"\w* y lo anunciaron en la \w casa|strong="H1004"\w* \w real|strong="H4428"\w*.
\p 
\v 12 \w El|strong="H3588"\w* \w rey|strong="H4428"\w* \w se|strong="H3045"\w* \w levantó|strong="H6965"\w* \w de|strong="H4480"\w* \w noche|strong="H3915"\w* \w y|strong="H3588"\w* \w dijo|strong="H5046"\w* \w a|strong="H3068"\w* sus esclavos: \w Ahora|strong="H4994"\w* les diré \w lo|strong="H6213"\w* \w que|strong="H3588"\w* planearon \w los|strong="H3588"\w* sirios: \w Saben|strong="H3045"\w* \w que|strong="H3588"\w* estamos \w hambrientos|strong="H7457"\w*. \w Salieron|strong="H3318"\w* \w del|strong="H4480"\w* \w campamento|strong="H4264"\w* \w para|strong="H3588"\w* \w esconderse|strong="H2247"\w* \w en|strong="H4480"\w* \w el|strong="H3588"\w* \w campo|strong="H4264"\w* \w y|strong="H3588"\w* dijeron: \w Cuando|strong="H3588"\w* \w salgan|strong="H3318"\w* \w de|strong="H4480"\w* \w la|strong="H3588"\w* \w ciudad|strong="H5892"\w*, \w los|strong="H3588"\w* agarraremos \w vivos|strong="H2416"\w* \w y|strong="H3588"\w* entraremos \w en|strong="H4480"\w* \w la|strong="H3588"\w* \w ciudad|strong="H5892"\w*.
\p 
\v 13 Uno \w de|strong="H4480"\w* sus esclavos dijo: \add Deja que algunos hombres \add*\w tomen|strong="H3947"\w* \w cinco|strong="H2568"\w* \w de|strong="H4480"\w* \w los|strong="H3605"\w* \w caballos|strong="H5483"\w* \w que|strong="H4480"\w* quedan y enviémoslos. \w Veamos|strong="H7200"\w*, \w los|strong="H3605"\w* \add caballos\add* \w que|strong="H4480"\w* quedan \w en|strong="H4480"\w* \w ella|strong="H4480"\w* van \w a|strong="H3068"\w* correr \w la|strong="H3605"\w* misma suerte \w que|strong="H4480"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w multitud|strong="H1995"\w* \w de|strong="H4480"\w* israelitas \w que|strong="H4480"\w* \w ya|strong="H4994"\w* pereció.
\p 
\v 14 Entonces \w tomaron|strong="H3947"\w* \w dos|strong="H8147"\w* carruajes con \w caballos|strong="H5483"\w*. \w El|strong="H4264"\w* \w rey|strong="H4428"\w* los \w envió|strong="H7971"\w* tras \w el|strong="H4264"\w* \w ejército|strong="H4264"\w* de los sirios y dijo: \w Vayan|strong="H3212"\w* y \w vean|strong="H7200"\w*.
\v 15 \w Fueron|strong="H3212"\w* tras \w ellos|strong="H3605"\w* \w hasta|strong="H5704"\w* \w el|strong="H3605"\w* \w Jordán|strong="H3383"\w*. \w Ciertamente|strong="H2009"\w*, \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w camino|strong="H1870"\w* \w estaba|strong="H2009"\w* \w lleno|strong="H4392"\w* \w de|strong="H5704"\w* ropas \w y|strong="H5704"\w* utensilios \w que|strong="H5704"\w* \w los|strong="H3605"\w* sirios dejaron \w en|strong="H5704"\w* su apuro. \w Volvieron|strong="H7725"\w* \w los|strong="H3605"\w* \w mensajeros|strong="H4397"\w* \w e|strong="H3068"\w* informaron \w al|strong="H5704"\w* \w rey|strong="H4428"\w*.
\v 16 Entonces \w el|strong="H4264"\w* \w pueblo|strong="H5971"\w* \w salió|strong="H3318"\w* y tomó \w el|strong="H4264"\w* despojo del \w campamento|strong="H4264"\w* \w de|strong="H5971"\w* \w los|strong="H1961"\w* sirios. Así, una medida \w de|strong="H5971"\w* flor \w de|strong="H5971"\w* harina \w o|strong="H3068"\w* dos \w medidas|strong="H5429"\w* \w de|strong="H5971"\w* \w cebada|strong="H8184"\w* \w fueron|strong="H1961"\w* vendidas \w por|strong="H1697"\w* 11 gramos \w de|strong="H5971"\w* plata, según la \w Palabra|strong="H1697"\w* \w de|strong="H5971"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\p 
\v 17 \w El|strong="H5921"\w* \w rey|strong="H4428"\w* había colocado \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w puerta|strong="H8179"\w* \w al|strong="H5921"\w* oficial \w en|strong="H5921"\w* cuya \w mano|strong="H3027"\w* \w se|strong="H5921"\w* apoyaba. \w El|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w lo|strong="H5921"\w* pisoteó \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w puerta|strong="H8179"\w*, \w y|strong="H5921"\w* \w murió|strong="H4191"\w*, tal \w como|strong="H5921"\w* \w habló|strong="H1696"\w* \w el|strong="H5921"\w* varón \w de|strong="H5921"\w* \nd ʼElohim\nd* quien \w habló|strong="H1696"\w* cuando \w el|strong="H5921"\w* \w rey|strong="H4428"\w* bajaba \w hacia|strong="H5921"\w* \w él|strong="H5921"\w*.
\v 18 \w Sucedió|strong="H1961"\w* \w como|strong="H1961"\w* el varón \w de|strong="H6256"\w* \nd ʼElohim\nd* \w habló|strong="H1696"\w* \w al|strong="H6256"\w* \w rey|strong="H4428"\w*: \wj ¡\w Mañana|strong="H4279"\w* \w a|strong="H3068"\w* \w esta|strong="H1961"\w* \w hora|strong="H6256"\w*, una medida \w de|strong="H6256"\w* flor \w de|strong="H6256"\w* harina \add se venderá\add* \w por|strong="H4428"\w* 11 gramos \w de|strong="H6256"\w* plata, y dos \w medidas|strong="H5429"\w* \w de|strong="H6256"\w* \w cebada|strong="H8184"\w* \w por|strong="H4428"\w* 11 gramos \w de|strong="H6256"\w* plata en la \w puerta|strong="H8179"\w* \w de|strong="H6256"\w* \w Samaria|strong="H8111"\w*!\wj*
\p 
\v 19 \w Y|strong="H3068"\w* \w el|strong="H6213"\w* oficial \w que|strong="H3808"\w* \w respondió|strong="H6030"\w* al varón \w de|strong="H1697"\w* \nd ʼElohim\nd*: \w Aun|strong="H3808"\w* \w si|strong="H2005"\w* \nd \w Yavé|strong="H3068"\w*\nd* abra ventanas en \w el|strong="H6213"\w* \w cielo|strong="H8064"\w*, ¿podría suceder \w esto|strong="H2088"\w*? \w Y|strong="H3068"\w* Eliseo \w respondió|strong="H6030"\w*: \w Mira|strong="H7200"\w*, \w tú|strong="H6213"\w* \w lo|strong="H1697"\w* \w verás|strong="H7200"\w* con tus propios \w ojos|strong="H5869"\w*, pero \w no|strong="H3808"\w* comerás \w de|strong="H1697"\w* ello,
\v 20 le \w sucedió|strong="H1961"\w* \w así|strong="H3651"\w*, \w pues|strong="H3651"\w* el \w pueblo|strong="H5971"\w* lo atropelló en la \w puerta|strong="H8179"\w*, y \w murió|strong="H4191"\w*.
\c 8
\s1 Eliseo en Damasco
\p 
\v 1 Eliseo \w habló|strong="H1696"\w* \w a|strong="H3068"\w* aquella mujer, cuyo \w hijo|strong="H1121"\w* resucitó, \w y|strong="H1571"\w* le \w dijo|strong="H1696"\w*: \w Levántate|strong="H6965"\w* \w y|strong="H1571"\w* \w vete|strong="H3212"\w*, tú \w y|strong="H1571"\w* tu \w casa|strong="H1004"\w*, \w y|strong="H1571"\w* \w vive|strong="H2421"\w* donde puedas. \w Porque|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w llamó|strong="H7121"\w* al \w hambre|strong="H7458"\w*, \w la|strong="H1571"\w* \w cual|strong="H3588"\w* vendrá \w también|strong="H1571"\w* sobre \w esta|strong="H6965"\w* tierra \w por|strong="H3588"\w* \w siete|strong="H7651"\w* \w años|strong="H8141"\w*.
\v 2 \w La|strong="H1931"\w* mujer \w se|strong="H1931"\w* \w levantó|strong="H6965"\w* \w e|strong="H3068"\w* \w hizo|strong="H6213"\w* \w conforme|strong="H1931"\w* \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w palabra|strong="H1697"\w* del varón \w de|strong="H1697"\w* \nd ʼElohim\nd*. \w Se|strong="H1931"\w* \w fue|strong="H3212"\w* con \w los|strong="H1931"\w* \w de|strong="H1697"\w* \w su|strong="H1931"\w* \w casa|strong="H1004"\w*, y vivió \w como|strong="H1931"\w* extranjera \w en|strong="H3212"\w* tierra \w de|strong="H1697"\w* \w los|strong="H1931"\w* \w filisteos|strong="H6430"\w* durante \w siete|strong="H7651"\w* \w años|strong="H8141"\w*.
\p 
\v 3 \w Sucedió|strong="H1961"\w* \w al|strong="H4428"\w* terminar \w los|strong="H1961"\w* \w siete|strong="H7651"\w* \w años|strong="H8141"\w* \w que|strong="H1961"\w* la mujer \w volvió|strong="H7725"\w* de la tierra de \w los|strong="H1961"\w* \w filisteos|strong="H6430"\w*, y \w salió|strong="H3318"\w* \w para|strong="H1961"\w* implorar \w al|strong="H4428"\w* \w rey|strong="H4428"\w* \w que|strong="H1961"\w* le entregara su \w casa|strong="H1004"\w* y su tierra.
\v 4 \w El|strong="H3605"\w* \w rey|strong="H4428"\w* \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Giezi|strong="H1522"\w*, esclavo del varón de \nd ʼElohim\nd*: Cuéntame \w ahora|strong="H4994"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* prodigios \w que|strong="H4994"\w* Eliseo \w hizo|strong="H6213"\w*.
\p 
\v 5 \w Sucedió|strong="H1961"\w* \w que|strong="H1931"\w*, mientras \w él|strong="H1931"\w* contaba \w al|strong="H5921"\w* \w rey|strong="H4428"\w* \w cómo|strong="H1961"\w* resucitó \w al|strong="H5921"\w* \w muerto|strong="H4191"\w*, llegó allí \w la|strong="H1931"\w* mujer \w cuyo|strong="H1931"\w* \w hijo|strong="H1121"\w* resucitó, \w a|strong="H3068"\w* implorar \w al|strong="H5921"\w* \w rey|strong="H4428"\w* \w que|strong="H1931"\w* \w le|strong="H1931"\w* devolviera \w su|strong="H1931"\w* \w casa|strong="H1004"\w* \w y|strong="H5921"\w* \w su|strong="H1931"\w* tierra.
\p Entonces dijo \w Giezi|strong="H1522"\w*: \w Rey|strong="H4428"\w*, \tl ʼadón\tl* \w mío|strong="H5921"\w*, \w ésta|strong="H2063"\w* \w es|strong="H1931"\w* \w la|strong="H1931"\w* mujer \w y|strong="H5921"\w* \w este|strong="H2088"\w* \w es|strong="H1931"\w* \w su|strong="H1931"\w* \w hijo|strong="H1121"\w*, \w al|strong="H5921"\w* \w cual|strong="H1931"\w* Eliseo dio \w vida|strong="H2421"\w*.
\v 6 \w Entonces|strong="H3117"\w* \w el|strong="H3605"\w* \w rey|strong="H4428"\w* \w preguntó|strong="H7592"\w* \w a|strong="H3068"\w* \w la|strong="H3605"\w* mujer, \w y|strong="H5704"\w* \w ella|strong="H3605"\w* le \w contó|strong="H5608"\w*.
\p \w Así|strong="H6258"\w* \w que|strong="H6258"\w* \w el|strong="H3605"\w* \w rey|strong="H4428"\w* le asignó un funcionario, \w y|strong="H5704"\w* le dijo: Restituye \w todo|strong="H3605"\w* \w lo|strong="H5704"\w* \w que|strong="H6258"\w* era \w de|strong="H5704"\w* \w ella|strong="H3605"\w*, \w y|strong="H5704"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* producto del \w campo|strong="H7704"\w* \w desde|strong="H5704"\w* \w el|strong="H3605"\w* \w día|strong="H3117"\w* \w cuando|strong="H3117"\w* salió del país \w hasta|strong="H5704"\w* \w ahora|strong="H6258"\w*.
\p 
\v 7 Eliseo fue \w a|strong="H3068"\w* \w Damasco|strong="H1834"\w*. \w Ben-adad|strong="H1130"\w*, \w rey|strong="H4428"\w* \w de|strong="H5704"\w* Siria, estaba \w enfermo|strong="H2470"\w* \w y|strong="H5704"\w* le dijeron: El varón \w de|strong="H5704"\w* \nd ʼElohim\nd* vino \w aquí|strong="H2008"\w*.
