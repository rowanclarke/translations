\id 1CO
\h Korineto I.
\toc1 Korineto I.
\toc2 Korineto I.
\toc3 Korineto I.
\mt1 Korineto I.
\c 1
\s1 O KA EPISETOLE
\q1 
\v 1 O PAULO, i kohoia i lunaolelo na Iesu Kristo, no ka manao ana mai o ke Akua, o maua me Sosetene, kekahi hoahanau;
\q1 
\v 2 Na ka ekalesia o ke Akua ma Korineto, na ka poe i hoomaemaeia iloko o Kristo Iesu, a i hooliloia i poe haipule, a na ka poe a pau ma na wahi a pau loa i hea aku i ka inoa o Iesu Kristo, i ko lakou Haku a me ko kakou.
\q1 
\v 3 E alohaia mai oukou, a e maluhia hoi e ke Akua, e ko kakou Makua, a e ka Haku e Iesu Kristo.
\b
\q1 
\v 4 Ke aloha mau aku nei au i ko'u Akua, no oukou, no ka lokomaikai o ke Akua i haawiia mai ia oukou ma o Iesu Kristo la.
\q1 
\v 5 No ka mea, ua waiwai oukou ia ia i na mea a pau, i na olelo a pau, a me ka naauao i na mea a pau;
\q1 
\v 6 No ka hooiaio ana o ka olelo a Kristo iwaena o oukou;
\q1 
\v 7 No ia mea, aole oukou i nele i kekahi haawina; e kali ana i ka hoike ana mai o ko kakou Haku, o Iesu Kristo:
\q1 
\v 8 Nana no oukou e hooku paa, a hiki aku i ka hopena, i hewa ole oukou i ka la o ko kakou Haku o Iesu Kristo.
\q1 
\v 9 He Akua malama, ka mea i hea mai ia oukou, i poe hoa no kana Keiki, no Iesu Kristo, ko kakou Haku.
\b
\q1 
\v 10 Ke noi aku nei au ia oukou, e na hoahanau, ma ka inoa o ko kakou Haku o Iesu Kristo, i olelo oukou a pau i ka mea hookahi, i ole oukou e mokuahana; a i pili pu oukou me ka naau hookahi, a me ka lokahi o ka manao.
\q1 
\v 11 E na hoahanau o'u, ua haiia mai ia'u no oukou, na ka poe ohua o Keloe; ua kuee oukou.
\q1 
\v 12 Ke hai aku nei au i keia, ua olelo ae kela mea keia mea o oukou, No Paulo wau; a no Apolo wau; a no Kepa wau; a no Kristo wau.
\q1 
\v 13 Ua maheleia anei o Kristo? I kaulia anei o Paulo ma ke kea no oukou? Ua bapetizoia anei oukou iloko o ka inoa o Paulo?
\q1 
\v 14 Ke aloba aku nei au i ke Akua no ka mea, aole au i bapetizo aku i kekahi mea o oukou, o Kerisepo laua o Gaio wale no:
\q1 
\v 15 O olelo paha auanei kekahi, ua bapetizo aku au iloko o ko'u inoa iho.
\q1 
\v 16 Ua bapetizo no hoi au i ko ka hale o Setepana; a o na mea e, aole au i ike i ko'u bapetizo ana i kekahi mea e.
\b
\q1 
\v 17 Aole i hoouna mai o Kristo ia'u e bapetizo, aka, e hai i ka euanelio; aole ma ke akamai i ka olelo, o hooliloia ke kea o Kristo i mea ole.
\b
\q1 
\v 18 No ka mea, o ka olelo no ke kea, he mea lapuwale ia i ka poe make; aka, ia kakou, i ka poe ola, oia ka mana o ke Akua.
\q1 
\v 19 No ka mea, ua palapalaia mai, E hoopau au i ke akamai o ka poe akamai, a e hoolilo au i ka naauao o ka poe naauao i mea ole.
\q1 
\v 20 Auhea ka mea akamai? Auhea ke kakaolelo? Auhea ka mea hoopaapaa o keia ao? Aole anei i hoolilo ke Akua i ke akamai o keia ao, i mea lapuwale?
\q1 
\v 21 No ka mea, i ke akamai o ke Akua, aole i ike aku ko ke ao nei i ke Akua, ma ko lakou naauao ana; alaila manao iho la ke Akua, ma ka lapuwale o ka haiolelo ana, e hoola i ka poe manaoio.
\q1 
\v 22 Ke noi mai nei na Iodaio i hoailona; ke imi mai nei hoi na Helene i ke akamai:
\q1 
\v 23 Aka, ke hai aku nei makou ia Kristo i kaulia ma ke kea, he mea hina no na Iudaio, a he mea lapuwale no na Helene;
\q1 
\v 24 Aka, i ka poe i heaia mai, i na Iudaio a me na Helene, o Kristo no ka mana o ke Akua a me ke akamai o ke Akua.
\q1 
\v 25 No ka mea, o ka lapuwale o ke Akua, ua oi aku ia mamua o ke akamai o kanaka; a o ka nawaliwali o ke Akua mamua o ka ikaika o kanaka.
\b
\q1 
\v 26 E na hoahanau, ua ike oukou i ko oukou heaia mai; aole koho nui ia ka poe akamai ma ke kino, aole i nui ka poe maiau, aole i nui na'lii:
\q1 
\v 27 Aka, ua koho mai ke Akua i ka poe naaupo o keia ao, i hoohilahila ia i ka poe akamai: ua koho mai hoi ke Akua i ka poe nawaliwali o keia ao, i hoohilahila ia i ka poe ikaika:
\q1 
\v 28 A me ke kuaaina hoi ka ke Akua i koho mai ai a me ka mea hoowahawahaia, a me na mea i ike ole ia i anai aku oia i na mea i ikeia;
\q1 
\v 29 I ole o hookiekie kekahi kanaka imua i ke alo o ke Akua.
\q1 
\v 30 Nana mai no ko oukou iloko o Kristo Iesu, o ka mea i lilo no kakou i akamai, i mea hoopono, i mea hoomaemae, a i mea hoolapanai mai ke Akua mai.
\q1 
\v 31 E like me ka palapala ana mai, O ka mea kaena, e kaena oia ma ka Haku.
\c 2
\b
\q1 
\v 1 E NA hoahanau, i ko'u hele ana aku io oukou la, e hai aku i ka olelo a ke Akua, aole au i hele aku me ka hoohanohano olelo, a me ka hoakamai.
\q1 
\v 2 No ka mea ua paa ko'u aole e hoike i kekahi mea e ae iwaena o oukou, ia Iesu Kristo wale no, a me kona make ana ma ke kea.
\q1 
\v 3 Ua noho pu no wau me oukou, me ka nawaliwali, a me ka makau, a me ka haalulu nui.
\q1 
\v 4 A o ka'u olelo, a me ka'u ao ana aku, aole ia ma ka olelo maalea a ko ke kanaka akamai, aka, ma ka olelo hoakaka a ka Uhane, a me ka mana:
\q1 
\v 5 I paa ko oukou manaoio, ma ka mana o ke Akua, aole ma ke akamai o kanaka.
\b
\q1 
\v 6 He akamai no hoi ka makou e olelo nei i ka poe i oo; aole nae oia ke akamai o ko keia ao, aole hoi o na'lii o keia ao, o na mea e pau wale aua;
\q1 
\v 7 Aka, ke hai aku nei makou i ke akamai o ko Akua, i ka mea huna i ike ole ia, a ke Akua i hoopaa ai mamua o ka hookumu ana mai o ke ao nei, i mea e nani ai kakou.
\q1 
\v 8 Aole i ike kekahi alii o keia ao ia mea; no ka mea, ina ua ike lakou, ina aole lakou i kau ma ke kea i ka Haku nona ka nani.
\q1 
\v 9 Ua like hoi me ka mea i palapalaia, Aole i ike ka maka, aole i lohe ka pepeiao, aole hoi i komo iloko o ka naau o kanaka, na mea a ke Akua i hoomakaukau ai no ka poe i aloha aku ia ia.
\q1 
\v 10 Ua hoike mai no hoi ke Akua ia mau mea ia makou, ma kona Uhane, no ka mea, ke nana pono nei ka Uhane i na mea a pau, i na mea hohonu hoi a ke Akua.
\q1 
\v 11 Owai ke kanaka ike i na mea o ke kanaka? o ka uhane o ke kanaka wale no, o ka mea iloko oua; pela no aole i ike ke kanaka i na mea o ke Akua, o ka Uhane o ke Akua wale no.
\q1 
\v 12 Ua loaa hoi ia makou ka Uhane, na ke Akua mai, aole ka manao o ko ke ao nei; i mea e ike ai makou i na mea i haawi wale ia mai na makou e ke Akua.
\q1 
\v 13 Oia hoi ka makou e hai aku nei, aole ma ka olelo a ko ke kanaka akamai i ao mai ai, aka, ma ka ka Uhane Hemolele i ao mai ai, me ka hoakaka ana i ko ka Uhane ma na mea o ka Uhane.
\q1 
\v 14 Aka, o ke kanaka ma ko kino, aole e loaa ia ia na mea o ka Uhane o ke Akua; no ka mea, ua lapuwale ia mau mea ia ia, aole hoi e hiki ia ia ke hoomaopopo aku; no ka mea, ma ka Uhane wale no e ikeia'i lakou.
\q1 
\v 15 O ka mea hoi ma ka Uhane, ua ike no ia i na mea a pau, aole hoi oia i ike maopopo ia e kekahi.
\q1 
\v 16 Owai ka mea i ike i ka manao o ka Haku? Owai hoi ka mea e ao aku ia ia? Aka, ua loaa ia makou ka manao o Kristo.
\c 3
\b
\q1 
\v 1 E NA hoahanau, aole e hiki ia'u ke olelo aku ia oukou, me he poe ma ka Uhane la, aka, me he poe ma ke kino, me he poe kamalii la iloko o Kristo.
\q1 
\v 2 Ua hanai aku au ia oukou i ka waiu, aole i ka ai; no ka mea, aole oukou i hiki mamua, aole hoi e hiki i keia wa.
\q1 
\v 3 Ma ko ke kino no oukou a hiki i keia wa; no ka mea, i ka oukou paonioni ana, a me ka paio, a me ka mokuahana, aole anei oukou ma ko ke kino, a hele hoi ma ko ke kanaka?
\q1 
\v 4 No ka mea, i ka olelo ana a kekahi, No Paulo wau; a o kekahi, No Apolo wau; aole anei oukou ma ko ke kino?
\q1 
\v 5 Heaha hoi o Paulo, heaha o Apolo, aole anei o laua na kumu i manaoio aku ai oukou, e like me ka haawi ana mai o ka Haku no kela kanaka no keia kanaka?
\q1 
\v 6 Na'u no i kanu, a na Apolo no i hookahe ka wai; aka, na ke Akua no i hooulu.
\q1 
\v 7 Nolaila, he mea ole ka mea nana i kanu, he mea ole ka mea nana i hookahe ka wai; aka, he mea io ke Akua ka mea nana i hooulu.
\q1 
\v 8 O ka mea nana i kanu, a me ka mea nana i hookahe ka wai, hookahi no laua; a e loaa no i kela kanaka i keia kauaka kona uku, e like me kana hana ana.
\q1 
\v 9 No ka mea, he poe hoahana makou no ke Akua; o oukou no ko ke Akua mahinaai; o oukou ko ke Akua hale.
\b
\q1 
\v 10 Ma ka lokomaikai o ke Akua i haawiia mai no'u, e like me ka luna akamai i ka hana, ua hoonoho wau i ke kumu, a ke kukulu nei kekahi mea e maluna iho. E ao hoi na kanaka a pau i ko lakou kukulu ana maluna.
\q1 
\v 11 No ka mea, aole e hiki i ke kanaka ke hoonoho i kumu e ae, o ka mea i hoonohoia wale no; oia o Iesu Kristo.
\q1 
\v 12 Ina e kukulu kekahi kanaka maluna o keia kumu, he gula paha, he kala, he pohaku maikai, he laau, he mauu, he opala;
\q1 
\v 13 E maopopo auanei ka hana a kela mea keia mea; e hoakaka mai ana no kela la, no ka mea, maloko o ke ahi e hoomaopopoia mai ai ia mea. Na ke ahi no e hoao ke ano o ka hana a na kanaka a pau.
\q1 
\v 14 Ina e mau ka hana a kekahi i kukulu ai maluna iho, e loaa ia ia ka uku.
\q1 
\v 15 Ina e pau ka hana a kekahi i ke ahi, e nele no ia; aka, e hoolaia mai no nae oia, e like me ka mea mai waena mai o ke ahi.
\b
\q1 
\v 16 Aole anei oukou i ike, o oukou no ka luakini o ke Akua, a ua noho ka Uhane o ke Akua iloko o oukou?
\q1 
\v 17 Ina e hoino mai kekahi i ka luakini o ke Akua, e hoino mai no ke Akua ia ia; no ka mea, ua laa ka luakini o ke Akua; oia hoi oukou.
\b
\q1 
\v 18 Mai hoopunipuni kekahi ia ia iho. Ina i manaoia kekahi o oukou, ua naauao ma na mea o keia ao, he pono no e lilo ia i naaupo, i naauao io ai oia.
\q1 
\v 19 No ka mea, o ko ke ao nei naauao, he naaupo ia i ke Akua. Penei ka palapala ana, Ua paa ia ia ka poe akamai maloko o ko lakou maalea iho.
\q1 
\v 20 A penei hoi, Ua ike no ka Haku i ka manao o ka poe akamai, he lapuwale.
\q1 
\v 21 Nolaila, mai kaena kekahi i na kanaka; no ka mea, no oukou no na mea a pau;
\q1 
\v 22 Ina o Paulo, ina o Apolo, ina o Kepa, ina o ko ke ao nei, ina o ke ola, ina o ka make, ina o na mea o neia wa, ina o na mea e hiki mai ana; no oukou no na mea a pau loa;
\v 23 A na Kristo oukou, a na ke Akua o Kristo.
\c 4
\b
\q1 
\v 1 E PONO i kanaka ke manao mai ia makou, he poe lawehana no Kristo, he poe puuku hoi no na mea pohihihi o ke Akua.
\q1 
\v 2 Eia hoi, ua kauohaia mai na puuku, i pololei lakou.
\q1 
\v 3 He mea liilii loa ia'u, ke ahewaia mai a ke aponoia mai au e oukou, a me kanaka. He oiaio, aole au i ahewa, aole hoi i apono ia'u iho.
\q1 
\v 4 Aole au i ike pono i ko'u hewa, aole nae au i aponoia mai ilaila. Na ka Haku no wau e hookolokolo mai.
\q1 
\v 5 No ia mea, mai hoohewa e i kekahi mea, a hiki mai ka Haku, nana no e hoomaopopo mai na mea i hunaia o ka pouli, a e hoike mai hoi na manao o na naau; alaila e loaa mai i kela kanaka a i keia kanaka ka hoomaikaiia, mai ke Akua mai.
\b
\q1 
\v 6 E na hoahanau, no oukou no ke hoopili nei au ia mau mea io'u nei, a me Apolo; i aoia oukou ma o maua nei aole e hookiekie ka manao maluna o ka mea i palapalaia, i ole oukou e kaena aku i kekahi maluna o kekahi.
\q1 
\v 7 Owai ka mea i hoopakela ia oe? Heaha hoi kau mea i haawi ole ia mai nau? A ina i haawi wale ia mai ia, no ke aha la oe e kaena ai ia, me he mea la i haawi ole ia mai?
\q1 
\v 8 Ano la, ua maona oukou, ano la, ua waiwai oukou; ua nohoalii no hoi oukou a kaawale makou; ua makemake no nae au i nohoalii io oukou, i nohoalii pu ai makou me oukou.
\q1 
\v 9 No ka mea, ke manao nei au, ua hoolilo mai ke Akua ia makou i na lunaolelo, i poe lalo loa, e like me na mea i ahewaia e make. No ka mea, he poe makou i hoikeia i ko ke ao nei, a i na anela, a i na kanaka.
\q1 
\v 10 He poe naaupo makou no Kristo, he poe naauao oukou iloko o Kristo; ua nawaliwali makou, ua ikaika oukou; ua mahaloia mai oukou, ua hoowahawahaia mai makou.
\q1 
\v 11 A hiki i keia hora, ua pololi makou, ua makewai, ua olohelohe, ua hana ino ia mai, ua kuewa wale no.
\q1 
\v 12 Ke hooikaika nei makou i ka hana, me ko makou lima; a ahiahiia mai, hoomaikai aku no makou: a hoomaauia mai, ua hoomanawanui no makou;
\q1 
\v 13 A i olelo hoino ia mai, nonoi aku no makou: ua hooliloia mai makou e like me ka opala o ke ao nei, a me ka pelapela o na mea a pau, a hiki i keia wa.
\b
\q1 
\v 14 Aole au e palapala aku i keia mau mea e hoohilahila ia oukou, aka, ke ao aku nei au ia oukou, e like me a'u poe keiki aloha.
\q1 
\v 15 Ina paha he umi tausani kumu a oukou maloko o Kristo, aole hoi he nui na makua o oukou; no ka mea, ma ka euanelio, owau no ka mea nana oukou i hanau ai iloko o Kristo Iesu.
\q1 
\v 16 Nolaila ea, ke nonoi aku nei au ia oukou, e lilo oukou i poe hoolike me au.
\q1 
\v 17 No keia mea, ua hoouna aku au ia Timoteo io oukou la, oia hoi ka'u keiki aloha, ua paa loa hoi oia ma ka Haku, nana oukou e paipai aku i na aoao o'u ma o Kristo la, e like me ka'u no ana aku i na wahi a pau, i kela ekalesia i keia ekalesia.
\q1 
\v 18 Ke haanou mai nei kekahi poe me ka manao iho, aole au e hiki aku io oukou la.
\q1 
\v 19 Aka, e hele koke aku no au io oukou la, ke ae mai ka Haku, a e ike auanei au, aole i ka olelo a ka poe i haanou, aka, i ka ikaika io.
\q1 
\v 20 No ka mea, aole ma ka olelo ke aupuni o ke Akua, ma ka mana no.
\q1 
\v 21 Heaha ko oukou makemake? E hele paha wau io oukou la me ka laau hahau, me ke aloha paha, a me ka manao akahai?
\c 5
\b
\q1 
\v 1 U A loheia ma na wahi a pau he moe kolohe iwaena o oukou, he moe kolohe ike ole ia iwaena o ko na aina e, i lawe kekahi i ka wahine a kona makuakane.
\q1 
\v 2 Ua haanon oukou, aole hoi i kanikau, i laweia'ku ai ka mea i hana i keia, mai o oukou aku.
\q1 
\v 3 Oiaio, ua mamao au ma ke kino, aka, aia no nae ka uhane me oukou, a e like me ka mea e noho pu ana, ua hoohewa e aku au i ka mea nana i hana pela keia hana:
\q1 
\v 4 Ma ka inoa o ko kakou Haku o Iesu Kristo, i ka wa a oukou e akoa koa ai, o ko'u uhane pu kekahi, me ka mana o ko kakou Haku o Iesu Kristo,
\q1 
\v 5 E haawi i kela mea ia Satana, i mea e hoopau ai i ke kino, i hoolaia'i hoi ka uhane, i ka la o ka Haku o Iesu.
\q1 
\v 6 Aole i maikai ko oukou kaena ana. Aole anei oukou i ike, o kahi mea hu uuku, ke hoohu ae la ia i ka popo palaoa a pau?
\q1 
\v 7 No ia mea, e kiola oukou iwaho i ua mea hu kahiko la, i lilo oukou i popo hou i hu ole ai oukou. No ka mea, ua mohaiia o Kristo, ko kakou moliaola no kakou.
\q1 
\v 8 No ia mea, e malama kakou i ka ahaaina, aole nae me ka hu kahiko, aole hoi me ka mea hu o ka hoomauhala, a me ka hewa; aka, me ka mea hu ole o ka manao maikai a me ka oiaio.
\b
\q1 
\v 9 Ua palapala aku no wau ia oukou, ma kekahi palapala, mai hoolauna aku me ka poe moe kolohe:
\q1 
\v 10 Aole nae me ka poe moe kolohe o keia ao, a me ka poe makee, a me ka poe alunu, a me ka poe hoomana kii: no ka mea, ina pela, ina ua pono ia oukou ke hele mawaho o ke ao nei.
\q1 
\v 11 Ke palapala aku nei au ia oukou, ina i kapaia'ku kekahi, he hoahanau, a ua moe kolohe ia, a ua makee, a ua hoomanakii, a ua ahiahi, a ua ona, ua alunu; mai hoolauna aku oakou, aole hoi e ai pu me ka mea i hana pela.
\q1 
\v 12 Heaha hoi ka'u e hoohewa ai i ka poe mawaho? Aole anei oukou e hoohewa i ka poe maloko?
\q1 
\v 13 Aka, o ka poe mawaho, na ke Akua no lakou e hoohewa mai. No ia mea, e hoolei oukou i kela mea hewa, mai o oukou aku.
\c 6
\b
\q1 
\v 1 I NA i loaa i kekahi o oukou i mea e hoopii ai i kekahi, ua aa anei ia e hookolokoloia mai e ka poe hoomaloko, aole hoi e ka poe haipule?
\q1 
\v 2 Aole anei oukou i ike, na ka poe haipale no e hookolokolo i ko ke ao nei? A ina na oukou e hookolokolo i ko ke ao nei, aole anei e pono ia oukou na hookolokolo liilii loa?
\q1 
\v 3 Aole anei oukou i ike, na kakou no e hookolokolo aku i na anela? No ke aha hoi aole i na mea o keia ola ana?
\q1 
\v 4 Ina he hookolokolo ka oukou ma na mea o keia ao, ke hoonoho nei anei oukou i ka poe i hoowahawahaia e ka ekalesia, na lakou e hookolokolo mai?
\q1 
\v 5 Ke olelo aka nei au i keia mea, i hilahila ai oukou. He oiaio anei, aohe kanaka naauao iwaena o oukou? aole hookahi, i hiki ia ia ke hooponopono mawaena o kona poe hoahanau iho?
\q1 
\v 6 Aka, na hoopii kekahi hoahanau i kekahi hoahanau, a oia hoi imua o ka poe hoomaloka.
\q1 
\v 7 No ia mea, he oiaio no, ua hewa oukou, no ko oukou hoopii ana, kekahi i kekahi. No ke aha la oukoa i hoomanawanui ole ai i ka hewa? No ke aha la oukou i ae ole aku ai i ka lawehala ana o ka oukou?
\q1 
\v 8 Aka, ua hana hewa oukou, a ua lawehala i ka na hoahanau.
\q1 
\v 9 Aole anei oukou i ike, aole e loaa ke aupuni o ke Akua i ka poe hewa? Mai kuhi hewa oukou; aole ka poe moe ipo, aole ka poe hoomana kii, aole ka poe moe i ka hai, aole ka poe moe aikane, aole ka poe Sodomi,
\q1 
\v 10 Aole ka poe aihue, aole ka poe makee, aole ka poe ona, aole ka poe akiaki, aole ka poe alunu, aole e loaa ia lakou ke aupuni o ke Akua.
\q1 
\v 11 A pela no kekahi poe o oukou; aka, ua holoiia oukou, na huikalaia, ua hoaponoia ma ka inoa o ka Haku o Iesu, a ma ka Uhane o ko kakou Akua.
\b
\q1 
\v 12 Ua ku i ke kanawai na mea a pau na'u, aole hoi e pono no'u na mea a pau. Ua ku i ke kanawai na mea a pau na'u, aole hoi e lanakila mai kekahi mea maluna iho o'u.
\q1 
\v 13 Na ka opu ka ai, a no ka ai ka opu; aka, na ke Akua no e hoopau i kela, a me keia. Aole no ka moe kolohe ke kino, no ka Haku no; a o ka Haku no ke kino.
\q1 
\v 14 Na ke Akua no i hoala mai ka Haku, nana hoi kakou e hoala mai ma kona mana iho.
\q1 
\v 15 Aole anei oukou i ike, o ko oukou mau kino, oia na lala o Kristo? E lawe anei au i na lala o Kristo, a e hoolilo ia mau mea i lala no ka wahine hookamakama? Aole loa.
\q1 
\v 16 Aole anei oukou i ike, o ka mea hoopili aku i ka wahine hookamakama, hookahi o laua kino? No ka mea, ua olelo mai ia, E lilo mai elua i hookahi io.
\q1 
\v 17 Aka, o ka mea pili i ka Haku, hookahi no ia uhane.
\q1 
\v 18 E holo hoi oukou mai loko aku o ka moe kolohe. O na hewa a pau a ke kanaka e hana'i, ua kaawale ke kino, aka, o ka mea moe kolohe, ua hana hewa ia i kona kino iho.
\q1 
\v 19 Aole anei oukou i ike i ko oukou kino, oia ka luakini o ka Uhane Hemolele iloko o oukou; oia ka oukou i loaa, mai ke Akua mai, aole hoi na oukou oukou iho?
\q1 
\v 20 Ua kuaiia oukou me ke kumukuai; no ia mea, e hoonani aku ai oukou i ke Akua, me ko oukou kino, a me ko oukou uhane, na ke Akua no ia mau mea.
\c 7
\b
\q1 
\v 1 MA na mea a oukou i palapala mai ai ia'u; he mea maikai no ke kane, aole e hoopili aku i ka wahine.
\q1 
\v 2 Aka, o moe kolohe auanei, ua pono no i kela kane i keia kane kana wahine iho, a ua pono no i kela wahine i keia wahine, kana kane iho.
\q1 
\v 3 E pono no e ae lokomaikai aku ke kane i ka wahine, a pela no ka wahine i ke kane.
\q1 
\v 4 No ka mea, aole na ka wahine kona kino iho, na ke kane no; aole hoi na ke kane kona kino iho, na ka wahine no.
\q1 
\v 5 Mai hoonele wale oukou i kekahi i kekahi, aia wale no ma ka like o ka manao, a i mea hoi e lilo loa ai i ka hookeai a me ka pule; a e hui hou no, i hoowalewale ole mai ai o Satana ia oukou, no ko oukou hiki ole i ka hoomanawanui.
\q1 
\v 6 Ke olelo aku nei au i keia no ka manao no, aole no ke kauoha aku.
\q1 
\v 7 Ke makemake nei au, i like na kanaka a pau me au nei Aka, ua loaa i kela kanaka, i keia kanaka kona makana ponoi, na ke Akua mai, okoa no hoi ke ano o kekahi, okoa ke ano o kekahi.
\b
\q1 
\v 8 Ke olelo aku nei au i ka poe i mare ole ia, a me na wahinekanemake, he mea pono no lakou ke hoomau e like me au nei.
\q1 
\v 9 Aka, i hiki ole ia lakou ke hoomanawanui, e mare no lakou; no ka mea, ua maikai ka mare, aole ke kuko.
\q1 
\v 10 Ke hauoha aku nei au i ka poe i mareia, aole na'u, na ka Haku no, Mai haalele ka wahine i kana kane:
\q1 
\v 11 A ina ua haalele, e noho mare ole ia oia, a e maliu hou aku paha i ke kane: aole hoi e kipaku ke kane i ka wahine.
\q1 
\v 12 Ke olelo aku nei au i ka poe i koe, aole na ka Haku mai; Ina he wahine hoomaloka ka kekahi hoahanau kane, a manao ka wahine e noho pu me ia, mai kipaku ke kane ia ia.
\q1 
\v 13 A o ka wahine hoi, ke hoomaloka kana kane, a manao no ke kane e noho pu me ia, mai kipaku ka wahine ia ia.
\q1 
\v 14 No ka mea, ua huikalaia ke kane hoomaloka i ka wahine, a me ka wahine hoomaloka hoi, ua huikalaia oia i ke kane. Ina aole pela, ina ua haumia na keiki a oukou; aka, ano la, ua huikalaia.
\q1 
\v 15 A ina na ka hoomaloka ka haalele, e haalele no. Aole i paa ka hoahanau kane a me ka hoahanau wahine i keia mau mea. Aka, ua ao mai ke Akua ia kakou ma ke kuikahi.
\q1 
\v 16 Pehea oe i ike ai, e ka wahine, e ola paha kau kane ia oe? Pehea hoi oe i ike ai, e ke kane, e ola paha kau wahine ia oe?
\b
\q1 
\v 17 E like hoi me ka ka Haku haawi ana mai i kela kanaka i keia kanaka, e like no me ka ke Akua hea ana mai i kela kanaka i keia kanaka, pela no ia e hele ai; a pela no au e kauoha aku nei ma na ekalesia a pau.
\q1 
\v 18 Ina i heaia'ku kekahi i okipoepoeia; mai huna oia i kona okipoepoe ana: ina i heaia'ku kekahi i okipoepoe ole ia; mai okipoepoeia oia.
\q1 
\v 19 He mea ole ke okipoepoeia, he mea ole ke okipoepoe ole ia, aka, o ka malama ana i na kanawai o ke Akua.
\q1 
\v 20 E noho no kela kanaka keia kanaka ma ka mea ana i hana'i i ka wa i heaia mai ai oia.
\q1 
\v 21 Ina i heaia mai oe, e hookanwa ana, mai manao oe ia mea; aka, ina e hiki ke kuu wale ia mai oe, e hele no.
\q1 
\v 22 No ka mea, o ke kauwa i heaia mai e ka Haku, oia ka ka Haku i kuu ai. Pela hoi o ka mea paa ole i heaia mai, oia hoi ke kauwa a Kristo.
\q1 
\v 23 Ua kuaiia oukou me ke kumu, mai lilo oukou i poe hahai i kanaka.
\q1 
\v 24 E na hoahanau, e noho no kela kanaka keia kanaka me ke Akua, ma ka mea ana i heaia mai ai.
\b
\q1 
\v 25 No ka poe puupaa, aole na ka Haku mai ka'u kauoha. Ke hai aku nei no hoi au i ko'u manao, e like me ka mea i malama pono, no ka loaa ana mai o ka lokomaikai o ka Haku.
\q1 
\v 26 Ke manao nei au, he mea maikai keia, no ka popilikia o keia wa, he mea maikai no ke kane ke noho wale pela.
\q1 
\v 27 A i paa oe i ka wahine, ea, mai imi oe i ka mea e wehe ai. A i kaawale oe i ka wahine, mai imi oe i wahine nau.
\q1 
\v 28 Aka, ina i mare oe, aole oe i hewa; a ina i mare ka wahine puupaa, aole ia i hewa; aka hoi, e loaa auanei i ua poe la ka pilikia ma ke kino; aka, ke kuu aku nei au ia oukou.
\q1 
\v 29 Ke olelo aku nei no hoi au i keia, e na hoahanau, ma keia hope aku ka wa pilikia; nolaila, o ka mea wahine, e lilo ia i mea like me ka mea wahine ole:
\q1 
\v 30 A o ka mea uwe, e like me ka mea uwe ole; a o ka poe olioli, e like me ka poe olioli ole; a o ka poe kuai, e like me ka poe nele;
\q1 
\v 31 A o ka poe malama i na mea o keia ao, e like me ka poe malama ole. No ka mea, e nalo ae ana ke ano o keia ao.
\q1 
\v 32 O ko'u makemake keia, i ole oukou e pilikia ma ka manao. O ka mea i mare ole ia, ua manao no ia i ko ka Haku, i ka mea e lealea mai ai ka Haku.
\q1 
\v 33 A o ka mea i mareia, manao no ia i na mea o keia ao, i mea e lealea mai ai ka wahine.
\q1 
\v 34 Ua okoa no ka wahine i mareia, okoa ka wahine puupaa. O ka wahine i mare ole ia, ua manao no ia i na mea o ka Haku, i laa ia ma ke kino, a me ka naau; a o ka mea i mareia, manao no ia i na mea o keia ao, i mea e lealea ai ke kane,
\q1 
\v 35 Ke olelo aku nei au i keia i mea e pono ai oukou; aole e hoohihia ai oukou, no ka pono nae, i malama oukou i ka Haku, me ka ikaika a me ka hihia ole.
\b
\q1 
\v 36 Aka, ina e manao kekahi, ua pono ole kana hana ana i kana kaikamahine puupaa, ina i hala kona wa i oo ai, a ina pono pela, e hana no ia i kona makemake, aole ia i hewa; e mare lakou.
\q1 
\v 37 Aka, o ka mea ku paa ma ka naau, aole hoi i pilikia, a ua lanakila hoi maluna o kona makemake iho, a ua manao pono maloko o kona naau, e malama pela i kana kaikamahine, ua pono no kana hana ana.
\q1 
\v 38 Nolaila, o ka mea haawi ma ka mare, ua hana pono ia, a o ka mea haawi ole ma ka mare, ua hana pono loa ia.
\b
\q1 
\v 39 Ua paa ka wahine, i ka wa a pau e ola ana kana kane; aka, ina i make kana kane, ua pono ia ke mare aku i ka mea ana e makemake ai; iloko hoi o ka Haku.
\q1 
\v 40 I ko'u manao hoi, ua oi aku kona pomaikai, ke noho ia pela; a ke manao nei au, ua loaa ia'u ka Uhane o ke Akua.
\c 8
\b
\q1 
\v 1 MA na mea i kaumahaia na na kii, ua ike no kakou, ua naauao no kakou a pau. He mea hookiekie ka naauao: o ke aloha nae ka mea e nui ai ka ikaika.
\q1 
\v 2 Ina i manao kekahi, ua akamai ia, aole ia e akamai iki e like me ke akamai e pono ai oia.
\q1 
\v 3 Aka, ina i aloha aku kekahi i ke Akua, ua ikea mai oia e ia.
\q1 
\v 4 Ma ka ai ana i na mea i kaumahaia na na kii, ua ike no kakou, he mea ole ke kii, ma ka honua nei, aole hoi he Akua e ae, hookahi wale no.
\q1 
\v 5 He mea no nae i kapaia, he Akua, ma ka lani paha, ma ka hopua paha, no ka mea, ua nui na'kua, a ua nui na haku:
\q1 
\v 6 Aka, ia kakou, hookahi no Akua, o ka Makua, a nana mai na mea a pau, a ia ia hoi kakou nei: hookaihi no Haku, o Iesu Kristo, ma ona la na mea a pau, a ma ona la hoi kakou.
\b
\q1 
\v 7 Aka, aole i na kanaka a pau keia ike; no ka mea, i keia wa no, me ka manao i na kii, ai no kekahi poe me he mea la i mohaiia na ke kii; a no ka nawaliwali o ko lakou naau, ua haumia.
\q1 
\v 8 Aole hoi kakou e aponoia e ke Akua no ka ai; no ka mea, ina e ai kakou, aole e oi ko kakou maikai ilaila; a i ai ole kakou, aole e oi ko kakou ino ilaila.
\q1 
\v 9 E malama hoi oukou, o lilo auanei keia pono o oukou, i mea e hihia ai, no ka poe hawawa.
\q1 
\v 10 Ina i ike mai kekahi ia oe, i ka mea naauao, e noho ana e ai iloko o ka heiau o ke kii, aole anei e eueu ka manao o ke kanaka hawawa, e ai i na mea i mohaiia na na kii?
\q1 
\v 11 Alaila, no kou naauao ana, e make no ka hoahanau hawawa, nona i make ai o Kristo.
\q1 
\v 12 A i ka oukou hana hewa ana pela i na hoahanau, a i ko oukou hoeha ana i ko lakou naau nawaliwali, ua hana hewa oukou ia Kristo.
\q1 
\v 13 No ia mea, ina o ka io ka mea e hewa ai ko'u hoahanau, ma keia hope aku, aole loa au e ai hou i ka io, o hoolilo au i ko'u hoahanau i ka hewa.
\c 9
\b
\q1 
\v 1 A OLE anei au he lunaolelo? Aole anei au ho kanaka kuokoa? Aole anei au i ike ia Iesu Kristo, i ko kakou Haku? Aole anei oukou ka'u i hana maloko o ka Haku?
\q1 
\v 2 Ina aole au he lunaolelo ia hai, he oiaio no, ia oukou no; no ka mea, o oukou no ka hoailona o ka'u lunaolelo ana maloko o ka Haku.
\b
\q1 
\v 3 Eia ka'u olelo i ka poe hoohewa mai ia'u.
\q1 
\v 4 Aole anei e pono ia makou ke ai a me ka inu?
\q1 
\v 5 Aole anei e pono ia makou, ke kono mai i kaikuwahine, a i wahine na makou, e like me kekahi o na lunaolelo, a me na kaikuaana o ka Haku, a me Kepa?
\q1 
\v 6 O maua wale no a me Barenaba, aole anei e hiki ia maua ke hooki i ka hana?
\q1 
\v 7 Owai ka mea hele i ke kaua me ka uku ole ia mai? Owai ka mea kanu i ka malawaina, a ai ole i kona hua? Owai hoi ka i hanai i na holoholona, a ai ole i ka waiu o na holoholona?
\q1 
\v 8 He olelo kanaka anei keia mea a'u e olelo nei? Aole anei i olelo mai ke kanawai i keia mau mea?
\q1 
\v 9 No ka mea, ua palapalaia mai ma ke kanawai o Mose, Mai hoopani i ka waha o ka bipi nana e hehi i ka palaoa. Ke malama nei anei ke Akua i na bipi?
\q1 
\v 10 Ke olelo mai nei anei oia ia mea no kakou wale no? Ua palapalaia no kakou no, i lana ai ka manao o ka mea mahiai i kona mahi ai ana; a o ka mea hoiliili me ka manaolana e loaa ia ia ka mea i lana ai kona manao.
\q1 
\v 11 Ina makou i lulu aku i ko ka Uhane maluna o oukou, he mea nui anei ke hoiliili makou i ko oukou mea na ke kino?
\q1 
\v 12 Ina i loaa keia pono maluna o oukou na kekahi poe e, aole anei he oiaio, na makou kekahi? Aole nae makou i lawe i keia pono; ua hoomanawanui no makou i na mea a pau, o keakeaia ka euanelio a Kristo ia makou.
\q1 
\v 13 Aole anei oukou i ike i ka poe hana ma na mea laa, ua ai lakou i na mea laa? a me ka poe lawelawe ma ke kuahu, ua ai lakou i ko ko kuahu?
\q1 
\v 14 Pela no hoi i kauoha mai ai ka Haku, o ka poe hai aku i ka euanelio, e ola no lakou ma ka euanelio.
\q1 
\v 15 Aole hoi au i lawe i kekahi o keia mau mea; aole hoi au i palapala aku i keia, i hanaia mai ia'u pela; no ka mea, he mea maikai ia'u ka make, he mea ino ke hoonele mai kekahi ia'u i keia kaena ana.
\q1 
\v 16 A ina i hai aku au i ka euanelio, aole i loaa ia'u ka mea e kaena ai; no ka mea, ua kauia mai keia hana maluna o'u; auwe hoi au, ke hai ole aku au i ka euanelio.
\q1 
\v 17 A ina e hana au i keia mea me ka makemake, ua loaa ia'u ka uku; aka, ina me ka makemake ole, ua haawiia mai he oihana na'u.
\q1 
\v 18 Heaha hoi ka'u e ukuia mai? Eia, i ka'u ao ana aku, hai aku no au i ka euanelio a Kristo me ka uku ole ia mai, o lawe hewa au i ka'u pono ma ka euanelio.
\b
\q1 
\v 19 He kanaka kuokoa an, aka hoi, na hookauwa aka no wau na na kanaka a pau, i loaa nui mai lakou ia'u.
\q1 
\v 20 A iwaena au o na Iudaio, ua like au me ka Iudaio, i loaa'i ia'u na Iudaio: a iwaena au o ka poe ma ke kanawai, ma ke kanawai hoi au, i loaa'i ia'u ka poe ma ke kanawai.
\q1 
\v 21 A iwaena au o ka poe kanawai ole, na like hoi au me ka mea kanawai ole, i loaa'i ia'u ka poe ka nawai ole. (Aole hoi au i haalele i ko ke Akua kanawai, ma ke kanawai o Kristo waa.)
\q1 
\v 22 Iwaena au o ka poe makau wale, ua like me ka mea makau wale hoi wau, i loaa'i ia'u ka poe makau wale Iwaena o na kanaka a pau, lilo ae la au i na mea a pau, i ola io ai kekahi ia'u.
\q1 
\v 23 Ke hana nei no hoi au i keia, no ka euanelio, i loaa pu ai ia'a ko laila hope.
\b
\q1 
\v 24 Aole anei oukou i ike i ka poe kukini, holo no lakou a pau, aka, hookahi wale no e loaa ka uku? Ma ka loaa oukou e kukini ai.
\q1 
\v 25 O ka poe a pau i hooikaika i ka uku, ua pakiko no lakou ma na mea a pau. Ma ka lei mae wale lakou; aka, ma ka lei mae ole kakou.
\q1 
\v 26 No ia mea, ke holo nei au me ke kulanalana ole; ke mokomoko nei au, aole hoi e like me ka mea e mokomoko ana i ka makani.
\q1 
\v 27 Ke uumi nei au i kuu kino a lanakila maluna iho, o lilo paha wau i ke apono ole ia, mahope o kuu ao ana aku ia hai.
\c 10
\b
\q1 
\v 1 E NA hoahanau e, aole o'u ma kemake, e naaupo oukou i na kupuna o kakou. Maloko o ke ao lakou a pau, a pau no hoi lakou i ka hele mawaena o ke kai;
\q1 
\v 2 Maloko o ke ao, a maloko o ke kai, ua pau loa lakou i ka bapetizoia iloko o Mose.
\q1 
\v 3 A ai no hoi lakou i kela ai lani.
\q1 
\v 4 A inu no hoi lakou i kela wai lani; no ka mea, inu no lakou i ko ia pohaku lani i hahai mahope o lakou, a o ua pohaka la, oia o Kristo.
\q1 
\v 5 Aka, aole i lealea mai ke Akua i ka nui o lakou; no ka mea, ua lukuia lakou ma ka waouahele.
\q1 
\v 6 He hoailona keia mau mea no kakou, i mea o kuko ole ai kakou i na mea hewa, e like me ko lakou kuko ana.
\q1 
\v 7 Mai lilo oukou i poe hoomanakii, e like me kekahi o lakou; e like hoi me ka mea i palapalaia, Noho iho la na kanaka e ai, a e inu, a ku mai la lakou e hula.
\q1 
\v 8 Mai moe kolohe kakou e like me ko lakou moe kolohe ana, a make iho la i ka la hookahi, he iwakaluakumamakolu tausani.
\q1 
\v 9 Mai aa aku ia Kristo, e like me ka aa ana aku o kekahi poe o lakou, a ua lakuia mai lakou e ka poe nahesa.
\q1 
\v 10 Mai ohuma oukou, e like me ka ohumu ana o kekahi o lakou, a ua lukuia lakou e ka mea make.
\q1 
\v 11 Ua loohia mai lakou i keia mau mea, i hoailona; a ua palapalaia mai i mea e naauao ai kakou, ka poe e ola nei, i keia hope o ke ao.
\q1 
\v 12 No ia mea, o ke kanaka i manao ua kupaa ia, e ao hoi ia o hina.
\q1 
\v 13 Aole a oukou hoowalewale e ae, o na mea maoli wale no; a he malama no ko ke Akua; aole ia e kuu mai ia oukou i ka hoowalewaleia ma kahi hiki ole ia oukou ko ku paa; aka, ke hoowalewaleia oukou, e hoomakaukau no kela i kahi o pakele ai, i hiki ia oukou ke ku paa.
\b
\q1 
\v 14 No ia mea, o o'u pokii e, e haaleto loa i ka hoomanakii.
\q1 
\v 15 Ke olelo aku nei au ia oukou me he poe naauao la. E manao pono oukou i na mea a'u e olelo aku nei.
\q1 
\v 16 O ke kiaha laa a kakou e hoolaa nei, aole anei oia ka lawe pu ana i ke koko o Kristo? A o ka berena no hoi a kakou e wawahi nei, aole anei ia ka lawe pu ana i ke kino o Kristo?
\q1 
\v 17 No ka mea, o kakou he nui loa, hookahi no ka kakou berena, hookahi hoi kino: no ka mea, ua ai pu kakou a pau, i kela berena hookahi.
\q1 
\v 18 E nana hoi i ka Iseraela ma ke kino; o ka poe ai i ka mohai, aole anei lakou na hoalawehana i ko ke kuaha?
\q1 
\v 19 Pehea hoi au e olelo aka nei? Ho mea io anei ke kii? He mea io anei ka mea i kaumahaiana ke kii?
\q1 
\v 20 O na mea a na lahuikanaka e i kaumaha aku ai, ke kaumaha nei lakou na ka poe daimonio, aole na ko Akua. Aole o'u makemake e lilo oukou i poe lawe pu i ko na daimonio.
\q1 
\v 21 Aole e hiki ia oukou ke inu pu 1 ke kiaha o ka Haku a me ke kiaha o na daimonio. Aole e hiki la oukou ke pili pu aku i ka papapaina a ka Haku me ka papapaina a na daimonio.
\q1 
\v 22 E hoolili anei kakou i ka Haku? Ua oi aku anei ko kakou ikaika i kona?
\b
\q1 
\v 23 Ua ku i ke kanawai na mea a pau na'u, aole nae e pono na mea a pau. Ua ku i ke kanawai na mea a pau na'u aole hoi he mea e naauao ai na mea a pau.
\q1 
\v 24 Mai imi aku kekahi kanaka i kona iho; e imi no na kanaka a pau i ko hai pono.
\q1 
\v 25 O na mea a pau i kuaiia ma kahi kuai, e ai ia mea, me ka ninaninau ole aku, no ka lunamanao.
\q1 
\v 26 No ka mea, na ka Haku no ka honua, a me ko laila mea i piha ai.
\q1 
\v 27 Ina e kono mai kekahi o ka poe hoomaloka ia oe, a manao oe e hele, o ka mea i waihoia imua ou, e ai, aole hoi me ka ninaninau aku, no ka lunamanao.
\q1 
\v 28 Aka, ina e olelo mai kekahi ia oe, Eia ka ke kii, mai ai oe, no ke kanaka nana i hai mai, a no ka lunamanao. No ka mea, na ka Haku no ka honua, a me ko laila mea i piha ai.
\q1 
\v 29 Ke i aku nei au, No ka lunamanao, aole hoi no kou iho, aka no ko kai no. No ke aha la e hoohewaia mai ko'u pono e ka lunamanao o hai.
\q1 
\v 30 No ka mea, ina e ai au me ke aloha aku, no ke aha la e olelo ino ia mai au ma ka mea a'u e haawi aku ai i ke aloha?
\q1 
\v 31 Nolaila, ina e ai oukou, a ina e inu oukou, a o na mea a pau a oukou e hana'i, e hana oukou i na mea a pau me ka hoonani aku i ke Akua.
\q1 
\v 32 Mai hoohihia aku oukou i na Iudaio, aole hoi i na Helene, aole hoi i ka ekalesia o ke Akua.
\q1 
\v 33 E like me au nei, e hooluolu aku i kanaka a pau, ma na mea a pau, aole hoi mo ka imi ana i ko'u pono iho, aka, i ko na kanaka he nui loa, i ola lakou.
\c 11
\b
\q1 
\v 1 E HAHAI mai oukou ia'u, e like me au ia Kristo.
\b
\q1 
\v 2 E na hoahanau, ke hoomaikai aku nei au ia oukou i ko oukou hoomanao ana mai ia'u ma na mea a pau, a me ko oukou malama ana i na oihana, e like me ko'u haawi ana aku ia oukou.
\q1 
\v 3 Ke makemake nei au e ike oukou, o Kristo no ke poo o na kanaka a pau; a o ke kane, oia ke poo o ka wahiue; a o ke Akua hoi, oia ko Kristo poo.
\q1 
\v 4 O kela Kane keia kane e pule ana, a e wanana ana me ka uhiia o ke poo, ua hoohilahila ia i kona poo.
\q1 
\v 5 A o kela wahine keia wahine, e pule ana, a e wanana ana me ka uhi ole ia o ke poo, ua hoohilahila ia i kona poo; no ka mea, ua like no ia me ke amuia.
\q1 
\v 6 No ka mea, ina aole e uhiia ka wahine, e amuia oia; aka, ina he mea hilahila i ka wahine, ke amuia a ke akoia, alaila, e uhiia oia.
\q1 
\v 7 Aole hoi e pono ke uhiia ko ke kane poo, no ka mea, oia ka mea like, a me ka nani o ke Akua; aka, o ka wahine, oia ka nani o ke kane.
\q1 
\v 8 Aole na ka wahine mai ke kane; na ke kane mai ka wahine.
\q1 
\v 9 Aole hoi i hanaia ke kane na ka wahine; o ka wahine no ua ke kane.
\q1 
\v 10 Nolaila he pono no i ka wahine e uhiia kona poo, no na anela.
\q1 
\v 11 Aole hoi he kane wale no me ka wahine ole; aole he wahine wale no me ke kane ole iloko o ka Haku.
\q1 
\v 12 E like me ka wahine, na ke kane mai, pela no ke kane, no ka wahine mai ia; a na ke Akua mai na mea a pau.
\q1 
\v 13 O oukou iho e noonoo pono; he mea maikai anei no ka wahine, ke pule i ke Akua, me ka uhi ole ia?
\q1 
\v 14 Aole anei i ao mai na mea maoli ia oukou, ina e loloa ka lauoho o ke kane, he mea hilahila ia nona?
\q1 
\v 15 Aka ina i loloa ka lauoho o ka wihine, he mea ia e nani ai; no ka mea, na haawiia mai kona lauoho i uhi nona.
\q1 
\v 16 Aka, ina i manao kekahi e hoopaapaa, aole pela ko makou aoao, aole hoi ko na ekalesia o ke Akua.
\b
\q1 
\v 17 I keia mea a'u o hai aku nei, aole au e hoomaikai aku ia oukou, no ka mea, i ko oukou akoakoa ana, aole no ka pono, no ka hewa no:
\q1 
\v 18 No ka mea, eia ka mua, i ko oukou akoakoa ana ma ka ekalesia, he lohe ko'u, ua ku e oukou i kekahi i kekahi; a ke manao nei kahi naau o'u he oiaio.
\q1 
\v 19 E oiaio no, e hiki mai no ka manao ku e iwaena o oukou; i maopopo mai ka poe i aponoia iwaena o oukou.
\q1 
\v 20 I ko oukou akoakoa ana i kahi hookahi, aole ia e ai i ka ahaaina a ka Haku;
\q1 
\v 21 No ka mea, i ka oukou ahaaina ana, ai wikiwiki no kola mea keia mea i kana ai iho, a ua poloii kekahi, a ua ona kekahi.
\q1 
\v 22 Aole anei o oukou hale, malaila e ai ai, a e inu ai? Ke hoonwahawaha nei anei oukou i ka ekalesia o ke Akua, me ka hoohilahila i ka poe nele? Pehea la wau e olelo aku ai ia oukou? E hoomaikai anei au ia oukou i keia? Aole au e hoomaikai.
\q1 
\v 23 No ka mea, ua loaa ia'u na ka Haku mai, ka mea a'u i haawi aku ai na oukou. O ka Haku o Iesu, i ka po ana i kumakaiaia'i, lalau aku la ia i ka berena:
\q1 
\v 24 A pau ka hoalohaloha ana, wawahi iho la ia, i aku la, E lawe oukou, e ai; eia no ko'u kino i wawahiia no oukou. E hana oukou i keia me ka hoomanao mai ia'u.
\q1 
\v 25 Pela no hoi ke kiaha, mahope o ka ai ana, i aku la, O keia kiaha, o ke kauoha hou ia iloko o ko'u koko. E hana oukou i keia, i ko oukou wa e inu ai, me ka hoomanao mai ia'u.
\q1 
\v 26 No ka mea, i na wa a pau loa a oukou e ai ai i keia berena, a o inu hoi i keia kiaha, e hai aku ana oukou i ka make o ka Haku, a hiki hou mai ia.
\q1 
\v 27 Nolaila, o ka mea e ai i keia berena, a e inu i ko ke kiaha o ka Haku, me ka pono ole, ua hewa ia i ke kino a me ke koko o ka Haku.
\q1 
\v 28 E noonoo ke kanaka ia ia iho, a pela ia e ai ai i ka berena, a e inu ai hoi i ko ke kiaha.
\q1 
\v 29 No ka mea, o ke kanaka nana e ai, a e inu hoi me ka pono ole, ua ai no ia a ua inu i ka hoahewaia nona iho, no kona hoomaopopo ole ana i ke kino o ka Haku.
\q1 
\v 30 Nolaila, ua nui loa ka poe o oukou i nawaliwali, a i maimai, a ua nui no ka poe i moe.
\q1 
\v 31 Ina i hookolokolo kakou ia kakou iho, alaila, aole kakou e hoahewaia mai.
\q1 
\v 32 Aka, i ko kakou hoahewaia ua hahania kakou e ka Haku, i ole ai kakou e hoahewa pu ia me ko ke ao nei.
\q1 
\v 33 No ia mea, e o'u hoahanau e, i ko oukou akoakoa ana e ai ai, e kakali oukou i kekahi i kekahi.
\q1 
\v 34 A ina e pololi kekahi, e ai ia ma kona wahi iho; i ole oukou e hoohewaia, i ko oukou akoakoa ana. A o na mea e ae, a hiki aku an, na'u no ia e hooponopono aku.
\c 12
\b
\q1 
\v 1 E NA hoahanau e, aole o'u makemake e naaupo oukou ma na mea o ka Uhane.
\q1 
\v 2 Ua ike no hoi oukou, he lahuikanaka e oukou, i hooliloia mamuli o na kii leo ole, ma kahi a oukou i kaiia'ku ai.
\q1 
\v 3 No ia mea, ke hoike aku nei au ia oukou, aole he kanaka hoohiki ino ia Iesu, ke olelo oia ma ka Uhane o ke Akua. Aole he kanaka e hiki ia ia ke olelo aku ia Iesu, he Haku, ke olelo ole ia ma ka Uhane Hemolele.
\b
\q1 
\v 4 Ua nui no ke ano o na haawina, aka, hookahi no Uhane.
\q1 
\v 5 Ua nui no ke ano o na oihana, aka, hookahi no Haku.
\q1 
\v 6 Ua nui no ko ano o na hana mana, aka, hookahi no Akua nana i hana na mea a pau.
\q1 
\v 7 Ua haawiia mai i kela kanaka i keia kanaka na oihana a ka Uhane i mea e pono ai.
\q1 
\v 8 No ka mea, ua baawiia mai i kekahi e ka Uhane, ka olelo akamai; a i kekahi ka olelo hoonaauao, na ka Uhane hookahi no;
\q1 
\v 9 A i kekahi, ka manaoio, na ka Uhane hookahi no; a i kekahi, ka oihana hoola, na ka Uhane hookahi no;
\q1 
\v 10 A i kekahi, kahana i na hana mana; a i kekahi, ka wanana; a i kekahi, ka ike maopopo i na uhane; a i kekahi, ka olelo i na olelo e; a i kekahi ka hoomaopopo i na olelo e.
\q1 
\v 11 Na kela Uhane hookahi i hana ia mau mea a pau, e haawi aku ana i kela kanaka i keia kanaka, e like me kona makemake.
\b
\q1 
\v 12 E like me ke kino, hookahi no ia, a he nui kona mau lala, a o na lala a pau he nui, no ke kino hookahi, hookahi no kino lakou: pela no o Kristo.
\q1 
\v 13 Na ka Uhane hookahi kakou a pau, i bapetizoia mai iloko o ke kino hookahi, o na Iudaio, a me na Helene, o ka poe i hoopaala, a me ka poe paa ole; ua hooinuia mai kakou a pau iloko o ka Uhane hookahi.
\q1 
\v 14 O ke kino, aole ia he lala hookahi, he nui no.
\q1 
\v 15 Ina paha e olelo ka wawae, Aole au he lima, nolaila, aole no ke kino wau; no ia mea, aole anei ia no ke kino?
\q1 
\v 16 A ina paha e olelo ka pepeiao, Aole au he maka, nolaila, aole no ke kino wau; no ia mea, aole anei ia no ke kino?
\q1 
\v 17 Ina he maka wale no ke kino a pau, alaila, mahea la ka lohe? A ina he lohe wale no, alaila, mahea la ka honi ana?
\q1 
\v 18 Ua hoonoho mai ko Akua i na lala a pau iloko o ke kino e like me kona makemake iho.
\q1 
\v 19 A ina paha hookahi wale no lala o lakou a pau, alaila, mahea la ke kino?
\q1 
\v 20 Ano la, he nui no na lala, aka, hookahi no kino.
\q1 
\v 21 Aole boi e hiki i ka maka, ko olelo i ka lima, Aole o'u hemahema ke lilo oe: aole hoi pela ke poo i ka wawae, Aole o'u hemahema ke lilo oe.
\q1 
\v 22 Aka, he oiaio no, o na lala o ke kino i manaoia, he hemahema, he mau mea ia e pono ai.
\q1 
\v 23 A o na mea hoi o ke kino i mahalo ole ia e kakou, ke kahiko nui nei kakou ia mau mea, a ua nui aku ka maikai o ko kakou lala ino.
\q1 
\v 24 No ka mea, aole i hemahema ko kakou lala maikai; aka, ua hui pu mai ke Akua i na mea o ke kino, a ua haawi mai hoi i ka mahalo nui ia i na lala i hemahema:
\q1 
\v 25 I ole ai e ku e na mea o ke kino, i malama like hoi na lala kekahi i kekahi.
\q1 
\v 26 A ina poino kekahi lala, ua poino pu no na lala a pau; a ina i hoomaikaiia kekahi lala, ua olioli pu na lala a pau.
\q1 
\v 27 O oukou no ke kino o Kristo, a pakahi na lala.
\q1 
\v 28 A ua hoonoho mai ke Akua i na mea maloko o ka ekalesia, o ka mua, o na lunaolelo; o ka lua, o na kaula; o ke kolu, o na kumu; a mahope, na mea hana mana; alaila, ka oihana hoola, a me na mea kokua, a me na luna, a me ka olelo i na olelo e.
\q1 
\v 29 He poe lunaolelo anei na mea a pau? He poe kaula anei ua mea a pau? He poe kumu anei na mea a pau? He poe hana mana anei na mea a pau?
\q1 
\v 30 Ua loaa anei i na mea a pau ka oihana hoola? He poe olelo i na olelo e na mea a pau? He poe hoike ano anei ua mea a pau?
\q1 
\v 31 E imi oukou i na oihana i oi; aka, na'u no e kuhikuhi aku ia oukou i ka aoao maikai loa.
\c 13
\b
\q1 
\v 1 I NA i olelo au i ka olelo a na kanaka a me na anela, a i loaa ole ke aloha, ua like au me ke keleawe kanikani a me ke kumebala walaau.
\q1 
\v 2 A ina ia'u ka wanana, a ina i ike au i na mea pohihihi a pau, a me na mea a pau e naauao ai; a ina ia'u ka manaoio e hiki ai ke hoonee i na kuahiwi, a i loaa ole hoi ke aloha, he mea ole wau.
\q1 
\v 3 A ina e manawalea aku au i ko'u waiwai a pau, a haawi hoi i ko'u kino i ke ahi, a i loaa ole ia'u ke aloha, aole o'u mea e pono ai ilaila.
\q1 
\v 4 O ke aloha, ua hoomanawanui, a na lokomaikai; aole paonioni aku ke aloha; aole haanui ke aloha, aole haakei,
\q1 
\v 5 Aole hoi e hoohiehie, aole imi i kona mea iho, aole hiki wawe ka huhu, aole noonoo ino;
\q1 
\v 6 Aole i hauoli i ka hewa, aka, ua hauoli i ka pono.
\q1 
\v 7 Ua ahonui i na mea a pau, na manao oiaio i na mea a pau, ua manaolana i na mea a pau, ua hoomanawanui i na mea a pau.
\q1 
\v 8 He mea pau ole ke aloha. Ina he wanana, e pau ia; ina he olelo e, e pau ia; ina he akamai, e hoopauia hoi oia.
\q1 
\v 9 No ka mea, ua ike pohihihi kakou, a ua wanana pohihihi aku.
\q1 
\v 10 Aka, i ka wa e hiki mai ai ka mea hemolele, alaila, e pau ka mea pohihihi i ka liloia.
\q1 
\v 11 I ko'u wa kamalii, olelo wau e like me ke kamalii, a ike au e like me ke kamalii, a manao wau e like me ke kamalii; aka, i ko'u wa i lilo ai i kanaka makua, alaila, haalele au i na mea o kamalii.
\q1 
\v 12 I keia wa, ke ike powehiwehi nei kakou, me he aniaui la; i kela wa aku, he maka no, he maka. I keia wa, ua ike powehiwehi au, aka, i kela wa aku, e ike maoli aku au, e like me ka'u i ikeia mai ai.
\q1 
\v 13 Ke mau nei keia mau mea ekolu, o ka manaoio, o ka manaolana, a me ke aloha. O ke aloha nae ka i oi o keia mau mea.
\c 14
\b
\q1 
\v 1 E HAHAI oukou mamuli o ke aloha, a e iini oukou i na oihana o ka Uhane, e iini nui nae ma ka wanana ana aku.
\q1 
\v 2 O ka mea olelo i ka olelo e, aole ia i olelo i kanaka, aka, i ke Akua no; no ka mea, aohe mea nana e lohe pono; aka, ma ka uhane, ua olelo ia i na mea pohihihi.
\q1 
\v 3 O ka mea wanana aku, olelo no ia i kanaka, ma ka mea e naauao ai, a me ka mea e ikaika ai, a me ka mea e oluolu ai.
\q1 
\v 4 O ka mea olelo i ka olelo e, ua hoonaauao oia ia ia iho; aka, o ka mea wanana aku, ua hoonaauao ia i ka ekalesia.
\q1 
\v 5 Ua makemake au e olelo oukou a pau i ka olelo e, e aho no nae ke wanana aku oukou a pau; no ka mea, ua oi ka mea wanana mamua o ka mea olelo i ka olelo e, ke hoakaka ole ia, i loaa ka naauao i ka ekalesia.
\q1 
\v 6 E na hoahanau e, ina e hele aku au io oukou la, me ka olelo i ka olelo e, pehea la e pono ai oukou in'u, ke olelo ole aku au ma ka hoike ana, a ma ka hoonaauao ana, a ma ka wanana ana, a ma ke ao ana aku?
\q1 
\v 7 A o na mea kani, oia ole, o ka ohe, o ka lira paha, ina aole i hoomaopopoia ke kani ana, pehea la e ikea ai ke ano o ka hookiokio ana, a me ka hookanikani ana?
\q1 
\v 8 Ina i kani maopopo ole ka pu, owai la ka mea hoomakaukau ia ia iho no ke kaua?
\q1 
\v 9 Pela no hoi oukou, ina aole oukou e olelo ma ka waha i na mea maopopo ke lohe ia, pehea la e ikea ai ka mea i oleloia? no ka mea, e olelo no oukou i ka makani.
\q1 
\v 10 Manomano paha na olelo ma ke ao nei, aole i koe kekahi me ke ano ole.
\q1 
\v 11 Aka, ina aole au i ike i ke ano o ka olelo, e lilo no wau i mea naaupo i ka mea nana e olelo mai; a e lilo no ka mea e olelo ana, i naaupo ia'u.
\q1 
\v 12 Pela hoi, me oukou e iini nei i na oihana o ka Uhane, e iini oukou, i pakela ae oukou i ka hoonaauao aku i ka ekalesia.
\q1 
\v 13 Nolaila, o ka mea olelo i ka olelo e, e pule ia, i hiki ia ia ke hoakaka aku.
\q1 
\v 14 No ka mea, ina e pule au ma ka olelo e, ua pule kuu uhane, aka, o ko'u naau ike, ua hua ole ia.
\q1 
\v 15 Heaha la hoi? E pule no wau ma ka uhane, a e pule no hoi ma ka naau ike. E hiraeni no wau ma ka uhane, a e himeni no ma ka naau ike.
\q1 
\v 16 Ina e hoomaikai aku oe me ka uhane wale no, pehea la e hiki ai i ka mea e noho ana ma ka naaupo, ke olelo, Amene, i kau hoomaikaf ana aku; no ka mea, aole ia i loho i ka mea au i olelo ai.
\q1 
\v 17 Ua pono nae kau hoomaikai ana, aka, aole kela i hoonaauaoia.
\q1 
\v 18 Ke aloha aku nei au i ke Akua, e pakela ana au mamua o oukou a pau ma ka olelo i na olelo e:
\q1 
\v 19 Aka, ma ka aha ekalesia, no ka hoonaauao ia hai, ua oi aku ko'u make make o olelo i na huaolelo elima ma ke ano maopopo, i na huaolelo he umi tausani ma ka olelo e.
\b
\q1 
\v 20 E na hoahanau e, mai lilo oukou i kamalii ma ka naauao; ma ka hewa no e kamalii ai, aka, ma ka naauao e lilo oukou i kanaka makua.
\q1 
\v 21 Ua palapalaia ma ke kanawai, Me na olelo e, a me na lehelehe e, e olelo aku ai au i keia poe kanaka; aole nae lakou e hoolohe mai ia'u ma ia mea, wahi a ka Haku.
\q1 
\v 22 No ia mea, he hoailona ka olelo e, aole no ka poe manaoio, aka, no ka poe manaoio ole: a o ka wanana, aole ia na ka poe hoomaloka, na ka poe manaoio no.
\q1 
\v 23 Nolaila, ina i akoakoaia ka ekalesia a pau ma kahi hookahi, a olelo lakou a pau ma ka olelo ano e, a i komo mai hoi ka poe naaupo paha, a hoomaloka paha, aole anei lakou e olelo ae, Ua hehena oukou?
\q1 
\v 24 Aka, ina wanana na mea a pau, a hele mai kekahi mea hoomaloka, a naaupo paha, ua aoia oia e na mea a pau, ua ahewaia oia e na mea a pau.
\q1 
\v 25 Pela e hoomaopopoia mai ai na mea huna o kona naau; a e hoomana aku ia i ke Akua, me ka moe o kona alo ilalo, a e hai aku no hoi ia i ka oiaio o ko ke Akua noho pu ana me oukou.
\b
\q1 
\v 26 Pehea la hoi, e na hoahanau? I ko oukou akoakoa ana, he himeni no ka kela mea keia mea, a he manao no, a he olelo ano e, he wanana, a he olelo hoakaka. E pono no e hanaia na mea a pau ma ka mea e naauao ai.
\q1 
\v 27 Ina e olelo kekahi ma ka olelo e, i elua wale no laua e olelo, a ina ekolu, ua nui loa ia; e pakahi hoi lakou, a na kekahi e hoakaka mai.
\q1 
\v 28 Aka, ina aole mea nana e hoakaka mai, e noho malie ia maloko o ka ekalesia; a e olelo oia ia ia iho, a i ke Akua hoi.
\q1 
\v 29 A o na kau la hoi, e olelo lakou, i elua, a i ekolu paha, a e nana mai hoi ka poe i koe.
\q1 
\v 30 Ina he mea i hoikeia mai na kekahi e noho ana, e pono no i ka mea mua e noho malie.
\q1 
\v 31 No ka mea, e pono ia oukou a pau ke wanana pakahi aku, i naauao na kanaka a pau, i oluolu hoi na kanaka a pau.
\q1 
\v 32 No ka mea, o ka mea a ka Uhane iloko o ke kaula, ua malama no ia i ke kaula.
\q1 
\v 33 Aole na ke Akua mai ka uluaoa, o ke kuikahi no kana, a pela no ma na halawai haipule a pau.
\b
\q1 
\v 34 E noho malie no ka oukou wahine ma ka aha ekalesia, no ka mea, aole i aeia mai ia lakou e olelo; e hoolohe wale no lakou, e like me ka ke kanawai i olelo mai ai.
\q1 
\v 35 A ina manao lakou e aoia, e ninau lakou i ka lakou kane, ma ko lakou wahi iho; no ka mea, he mea hilahila ke olelo ka wahine ma ka ekalesia.
\q1 
\v 36 Mai o oukou mai anei ka olelo a ke Akua i hele mai ai? I hele aku anei ia io oukou la wale no?
\b
\q1 
\v 37 Ina i manao kekahi o oukou, he kaula paha ia, he mea ike i ka mea o ka uhane paha, e pono ia ia ke ae mai i ka oiaio o ka olelo a'u e palapala aku nei, o ke kauoha keia a ka Haku.
\q1 
\v 38 Aka, ina e naaupo kekahi, e naaupo no.
\b
\q1 
\v 39 No ia mea, e na hoahanau, e iini oukou ma ka wanana, aole hoi e papa aku i ka olelo ana ma ka olelo e.
\q1 
\v 40 E hana i na mea a pau ma ka maikai, a me ka hoonohonoho pono.
\c 15
\b
\q1 
\v 1 KE hai hou aku nei au ia oukou, e na hoahanau, i ka euanelio a'u i ao aku ai ia oukou mamua, i ka mea a oukou i malama mai ai, a malaila no hoi oukou e ku nei.
\q1 
\v 2 Oia hoi ko oukou mea e ola'i, ke manao mau oukou i na mea a'u i hai aku ai ia oukou, ke ole hoi i makehewa ko oukou manaoio.
\q1 
\v 3 No ka mea, haawi mua aku au ia oukou i ka mea a'u i loaa mai, i ka make ana o Kristo no ko kakou hewa, e like me ka ka palapala hemolele:
\q1 
\v 4 A kanuia oia, a i ka po ekolu, ala hou mai oia, e like me ka ka palapala hemolele:
\q1 
\v 5 A ikeia oia e Kepa, alaila, e ka poe umikumamalua:
\q1 
\v 6 A mahope iho, ikeia oia e na hoahauau elima haneri a keu, i ka wa hookahi. A ke ola la no ka nui o lakou i keia manawa, a o kekahi poe, ua moe.
\q1 
\v 7 A mahope iho, ikeia oia e Iakobo, alaila e ka poe lunaolelo a pau.
\q1 
\v 8 Owau no ka i ike hope loa aku ia ia, me he keiki hanau hapa la.
\q1 
\v 9 No ka mea, wau no ka mea liilii loa o ka poe lunaolelo. Aole hoi e pono ke kapaia mai au, he lunaolelo, no ka mea, ua hoomainoino aku au i ka ekalesia o ke Akua.
\q1 
\v 10 Aka, ua lilo wau i ko'u mea i lilo ai, ma ka lokomaikai wale o ke Akua; aole hoi i makehewa kona lokomaikai mai maluna o'u; no ka mea, ua pakela aku ko'u hoikaika ana mamua o lakou a pau. Aole hoi wan, o ka lokomaikai no o ke Akua iloko o'u.
\q1 
\v 11 A ina owau paha, o lakou paha, pela no inakou e ao aku nei, a pela no hoi oukou i manaoio mai ai.
\b
\q1 
\v 12 A ina i haiia o Kristo, i hoalaia oia, mai ka make mai, pehea la e olelo nei kekahi poe o oukou, Aohe ala ana, mai ka make mai?
\q1 
\v 13 Ina aohe ala ana, mai ka make mai, ina aole i ala o Kristo;
\q1 
\v 14 A ina aole i ala o Kristo, ina ua makehewa ka inakou ao ana aku, a ua makehewa hoi ka oukou manaoio ana mai.
\q1 
\v 15 A ina ua loaa hoi makou, he poe hoike wahahee i ke Akua; no ka mea, ua hoike makou ma o ke Akua la, i kona hoala ana mai ia Kristo: aole hoi ia i hoala mai ia ia, ke ala ole ka poe make.
\q1 
\v 16 No ka mea, ina aole ala ka poe make, ina aole i hoalaia o Kristo.
\q1 
\v 17 A ina aole i hoalaia o Kristo, ua makehewa ko oukou manaoio ana; a ke noho nei no hoi oukou iloko o ko oukou hewa.
\q1 
\v 18 Alaila, ua make ka poe i moe iloko o Kristo.
\q1 
\v 19 Ina ma keia ola ana wale no ka lana ana o ko kakou manao iloko o Kristo, ua oi aku ka kakou poino i ko na kanaka a pau.
\b
\q1 
\v 20 Aka, ua ala io no o Kristo, mai ka make mai, a ua lilo oia i hua mua o ka poe i moe.
\q1 
\v 21 No ka mea, mai ke kanaka mai ka make, a pela no, mai ke kanaka mai ke alahouana, mai ka make mai.
\q1 
\v 22 E like me ka make ana o na kanaka a pau ma o Adamu la, pela no e hoolaia mai ai na kanaka a pau ma o Kristo la.
\q1 
\v 23 O kela mea keia mea, ma kona wa pono; o Kristo ka hua mua; alaila, o ko Kristo poe, i kona wa e hiki mai ai.
\q1 
\v 24 Oia hoi ka hope, i ka wa e hoihoi ia i ke aupuni i ke Akua, i ka Makua; i kona wa e hoopau ai i na oihana alii, a me ka ikaika, a me ka mana.
\q1 
\v 25 No ka mea, ia ia no ke aupuni, a hiki i ka wa e waiho ai ia i na enemi a pau malalo iho o kona mau wawae.
\q1 
\v 26 A o ka enemi hope loa, o ka make, e hoopauia no ia.
\q1 
\v 27 No ka mea, ua waiho no ia i na mea a pau malalo iho o kona mau wawae. A i kana olelo ana, Ua pau na mea i ka waihoia malalo iho ona, ua maopopo no he okoa ka mea nana i waiho mai na mea a pau malalo iho ona.
\q1 
\v 28 A i ka wa e lilo ai na mea a pau malalo iho ona, alaila, o ke Keiki hoi kekahi, e malama aku no ia i ka mea, nana i hoolilo mai na mea a pau malalo iho ona, i mau loa ka maopopo ana, o ke Akua wale no.
\b
\q1 
\v 29 A i ole loa e ala mai ka poe make, pehea la e hana'i ka poe i bapetizoia'i no ka poe make? No ke aha la i bapetizoia'i lakou no ka poe make?
\q1 
\v 30 A no ke aha la makou e aneane popilikia, i kola hora i keia hora?
\q1 
\v 31 He oiaio, ma kuu olioli ana no oukou iloko o Kristo Iesu, ko kakou Haku, ua make au i keia ia i keia la.
\q1 
\v 32 Heaha ko'u pono e loaa mai, i ko'u hakaka ana ma ko ke kanaka, me na ilio hae ma Epeso, ke ala ole mai ka poe make? E ai kakou, a e inu; no ka mea, apopd e make ana kakou.
\q1 
\v 33 E ao o hoopunipuniia oukou; o ka launa aku i ka hewa, ka mea e ino ai ka noho pono ana.
\q1 
\v 34 E ala oukou i ka pono, mai hana hewa; no ka mea, ua naaupo kekahi poe i ka ke Akua. Ke olelo aku nei au i keia, i mea e hilahila ai oukou.
\b
\q1 
\v 35 E ninau mai auanei kekahi, Pehea la e hoalaia mai ai ka poe make? E hele mai lakou me ke kino hea?
\q1 
\v 36 Ke, he lapuwale; aole e houluia ka mea au e lulu nei, ke make ole ia.
\q1 
\v 37 O ka mea au e lulu nei, aole oe i lulu i ke kino e hiki mai ana, o ka hua wale no, o ka huita paha, he mea e paha.
\q1 
\v 38 A na ke Akua no e haawi mai i ke kino no ia mea, e like me kona makemake iho; no kela hua keia hua i kona kino iho.
\q1 
\v 39 O na io a pau, aole ia he io hookahi. He io kanaka kahi, a he io koloholona kahi, a o ko ka ia kahi, a he io manu kahi.
\q1 
\v 40 He kino ano lani kahi, a he kino ano honua kahi; okoa hoi ka mani o ke kino lani, okoa ka naui o ko ka honua.
\q1 
\v 41 Okoa ka naui o ka la, okoa ka tani o ka mahina, okoa ka naui o na hoku; no ka mea, ua oi ka nani o kekahi hoku i kekahi hoku.
\q1 
\v 42 Pela no ke ala ana mai o ka poe make. Ua kanuia oia ma ka palaho, ua hoalaia mai oia ma ka palaho ole.
\q1 
\v 43 Ua kanuia oia ma ka hoinoia, ua hoalaia mai oia ma ka nani; ua kanuia oia ma ka nawaliwali, ua hoalaia mai oia ma ka mana.
\q1 
\v 44 Ua kanuia oia, he kino maoli, ua hoalaia mai oia, he kino uhane. He kino maoli kekahi kino, a he kino uhane kekahi.
\q1 
\v 45 Pela hoi ka palapala ana mai, O ke kanaka mua, o Adamu, ua hanaia oia, he kanaka ola; a o Adamu hope, he uhane hoola ia.
\q1 
\v 46 Aka hoi, o ka mea ma ka uhane, aole oia ka mua, o ka mea no ma ke kino; a mahope ka mea ma ka uhane.
\q1 
\v 47 O ke kanaka mua, no ka lepo ia, a he lepo. A o ke kanaka hope, oia ka Haku, mai ka lani mai.
\q1 
\v 48 E like me ka lepo, pela no ka poe mai ka lepo mai; e like hoi me ka lani, pela no ka poe mai ka lani mai.
\q1 
\v 49 A e like me ko kakou lawe ana i ke ano o ko ka lepo, pela no kakou e lawe ai i ke ano o ko ka lani.
\b
\q1 
\v 50 Ke olelo nei au i keia, e na hoahanau, aole e hiki i ka io a me ke koko ke noho aku ma ke aupuni o ke Akua; aole hoi ka palaho ma kahi palaho ole.
\q1 
\v 51 Eia hoi, ke hai aku nei au ia oukou i ka mea pohihihi. Aole kakou a pau e moe, e ano hou ia mai no kakou,
\q1 
\v 52 Ma ke sekona, ma ka amo ana no o ka maka, i ke kani ana o ka pu; no ka mea, e kani io no ka pu, a e hoala palaho ole ia mai ka poe make, a e ano hou ia mai kakou a pau.
\q1 
\v 53 No ka mea, e hookomo keia palaho i ka palaho ole, a me keia make i ka make ole i pono ai.
\q1 
\v 54 A i ka wa e hookomo ai keia palaho i ka palaho ole, a me keia make i ka make ole; alaila, e ko ai ka olelo i kakauia, Ua aleia ka make e ka lanakila.
\q1 
\v 55 E ka make, auhea kou huelo awa? e ka luapo, auhea kou lanakila ana?
\q1 
\v 56 Eia ka huelo awa o ka make, o ka hewa; a eia ka mea e nui ai ka hewa, o ke kanawai.
\q1 
\v 57 E hoomaikaiia hoi ke Akua, ka mea nana i haawi mai ia kakou ka lanakila, ma ko kakou Haku, ma o Iesu Kristo la.
\q1 
\v 58 No ia mea, e na hoahanau, e kupaa oukou, me ka naueue ole, me ka hoomau i ka oukou hana nui ana i ka hana a ka Haku, no ka mea, ua ike no oukou, aole i make hewa ka oukou hana ana ma ka Haku.
\c 16
\b
\q1 
\v 1 MA ka manawalea ana no ka poe hoano, e like me ka'u i kauoha aku ai i na ekalesia ma Galatia, pela no oukou e hana'i.
\q1 
\v 2 I ka la mua o ka hebedoma, e hoana e kela mea keia mea o oukou i kana iho, e like me kona hoopomaikaiia mai, i hoiliili ole ai oukou i ko'u wa e hiki aku ai.
\q1 
\v 3 A hiki aku au, alaila, o na mea a oukou e manao ai ma ka palapala, na'u no lakou e hoouna aku, e lawe i ko oukou manawalea i Ierusalema.
\q1 
\v 4 A ina he pono ke hele au, e hele pu lakou me au.
\q1 
\v 5 I ko'u wa e hele aku ai mawaena o Makedonia, e hele no wau io oukou la; no ka mea, e hele ana au ma Makedonia.
\q1 
\v 6 A e noho paha, a pau ka hooilo me oukou, a na oukou wau e kai aku i ko'u wahi e hele ai.
\q1 
\v 7 No ka mea, aole au e ike aku ia oukou i keia hele ana; ke manao nei no nae au e noho iki me oukou, ina e ae mai ka Haku pela.
\q1 
\v 8 E noho no au ma Epeso, a hiki i ka Penetekota.
\q1 
\v 9 No ka mea, ua weheia mai no'u, he puka nui, a ua hamama loa, a ua nui no hoi ka poe enemi.
\b
\q1 
\v 10 Ina e hiki aku o Timoteo, e malama oukou, i noho pu ia me oukou, me ka makau ole; no ka mea, ke hana nei ia i ka hana a ka Haku e like me au nei.
\q1 
\v 11 Mai hoowahawaha kekahi ia ia; e alakai mai ia ia me ka maluhia i hiki io'u nei; no ka mea, e kakali no au ia ia, me na hoahanau.
\q1 
\v 12 A o A polo hoi ka hoahanau, ua makemake nui au e hele aku ia io oukou la, me na hoahanau; aole nae ia o kona manao ke hele aku io oukou la, i keia wa; aka, e hele aku no ke loaa ia ia ka wa pono.
\b
\q1 
\v 13 E makaala oukou, e kupaa ma ka manaoio, e hookanaka, e ikaika hoi.
\q1 
\v 14 E hanaia ko oukou mea a pau me ke aloha.
\b
\q1 
\v 15 Ke nonoi aku nei au ia oukou, e na hoahanau, (no ko oukou ike ana i na ohna o Setepana, oia ka hua mua ma Akai a, a ua hoolilo lakou ia lakou iho i poe hookauwa aku na ka poe hoano;)
\q1 
\v 16 E malama oukou i ka poe like mo ia, a me ka poe a pau i kokua pu, a i hana pu hoi me makou.
\q1 
\v 17 Ua olioli au i ka hiki ana o Setepana, a me Foretunato, a me Akaiko; no ka mea, uapani lakou i ko oukou hakahaka.
\q1 
\v 18 Ua hoomaha mai lakou i ko'u naau a me ko oukou; nolaila, e ike mai oukou i ka poe hana pela.
\b
\q1 
\v 19 Ke aloha aku nei na ekalesia ma Asia ia oukou. Ke aloha nui aku nei o Akula a me Perisekila ia oukou maloko o ka Haku, a me ka ekalesia iloko o ko laua hale.
\q1 
\v 20 Ke aloha aku nei na hoahanau a pau ia oukou. E aloha oukou kekahi i kekahi, me ka honi hemolele.
\b
\q1 
\v 21 Eia ke aloha o Paulo, me ko'u lima iho.
\q1 
\v 22 Ina aole e aloha kekahi i ka Haku ia Iesu Kristo, e hoomainoinoia oia, i ka wa e hiki mai ai ka Haku.
\q1 
\v 23 Me oukou no ke aloha o ka Haku o Iesu Kristo.
\q1 
\v 24 O ke aloha o'u me oukou a pau iloko o Iesu Kristo. Amene. 
