\c 8
\s1 Victorias de David
\p 
\v 1 \w Después|strong="H1961"\w* de \w esto|strong="H3651"\w* \w aconteció|strong="H1961"\w* \w que|strong="H1961"\w* \w David|strong="H1732"\w* derrotó \w a|strong="H3068"\w* \w los|strong="H1961"\w* \w filisteos|strong="H6430"\w* y \w los|strong="H1961"\w* sometió. \w David|strong="H1732"\w* \w tomó|strong="H3947"\w* la rienda de la ciudad principal de la \w mano|strong="H3027"\w* de \w los|strong="H1961"\w* \w filisteos|strong="H6430"\w*.
\p 
\v 2 También derrotó \w a|strong="H3068"\w* \w Moab|strong="H4124"\w* y \w los|strong="H1961"\w* \w midió|strong="H4058"\w* con cordel. \w Los|strong="H1961"\w* hacía tenderse \w en|strong="H5221"\w* tierra: \w dos|strong="H8147"\w* \w cordeles|strong="H2256"\w* \w para|strong="H1961"\w* \w morir|strong="H4191"\w*, y un cordel \w para|strong="H1961"\w* \w vivir|strong="H2421"\w*. \w Los|strong="H1961"\w* moabitas \w fueron|strong="H1961"\w* esclavos de \w David|strong="H1732"\w* y pagaron \w tributo|strong="H4503"\w*.
\p 
\v 3 \w David|strong="H1732"\w* derrotó \w a|strong="H3068"\w* \w Hadad-ezer|strong="H1909"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Rehob|strong="H7340"\w*, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* Soba, cuando éste \w iba|strong="H3212"\w* \w a|strong="H3068"\w* establecer su dominio hasta \w el|strong="H1121"\w* \w río|strong="H5104"\w* Éufrates.
\v 4 \w David|strong="H1732"\w* le capturó 1.700 \w jinetes|strong="H6571"\w* y 20.000 \w hombres|strong="H6571"\w* \w de|strong="H4480"\w* infantería. \w David|strong="H1732"\w* \w desjarretó|strong="H6131"\w* \w los|strong="H3605"\w* caballos \w de|strong="H4480"\w* \w los|strong="H3605"\w* carruajes y dejó solo \w para|strong="H4480"\w* 100 carruajes.
\p 
\v 5 Cuando los sirios de \w Damasco|strong="H1834"\w* \w fueron|strong="H1732"\w* \w a|strong="H3068"\w* ayudar \w a|strong="H3068"\w* \w Hadad-ezer|strong="H1909"\w*, \w rey|strong="H4428"\w* de Soba, \w David|strong="H1732"\w* \w mató|strong="H5221"\w* \w a|strong="H3068"\w* 22.000 \w hombres|strong="H8147"\w* de los sirios
