\v 37 \w Those|strong="H2063"\w* \w are|strong="H2403"\w* \w the|strong="H8451"\w* regulations \w for|strong="H2077"\w* \w the|strong="H8451"\w* \w offerings|strong="H8002"\w* \w that|strong="H4503"\w* \w are|strong="H2403"\w* \w to|strong="H4503"\w* \w be|strong="H2403"\w* completely burned \w on|strong="H5930"\w* \w the|strong="H8451"\w* altar, \w the|strong="H8451"\w* \w offerings|strong="H8002"\w* made \w from|strong="H2403"\w* grain, \w the|strong="H8451"\w* \w offerings|strong="H8002"\w* \w to|strong="H4503"\w* enable people \w to|strong="H4503"\w* become acceptable \w to|strong="H4503"\w* God again, \w the|strong="H8451"\w* \w offerings|strong="H8002"\w* \w for|strong="H2077"\w* when people \w are|strong="H2403"\w* guilty \w of|strong="H2077"\w* not giving \w to|strong="H4503"\w* \w Yahweh|strong="H3068"\w* \w the|strong="H8451"\w* things \w that|strong="H4503"\w* \w are|strong="H2403"\w* required \w to|strong="H4503"\w* \w be|strong="H2403"\w* given \w to|strong="H4503"\w* him, \w the|strong="H8451"\w* \w offerings|strong="H8002"\w* given when \w the|strong="H8451"\w* priests \w are|strong="H2403"\w* appointed, \w and|strong="H5930"\w* \w the|strong="H8451"\w* \w offerings|strong="H8002"\w* \w to|strong="H4503"\w* maintain fellowship \w with|strong="H2077"\w* \w Yahweh|strong="H3068"\w*.
