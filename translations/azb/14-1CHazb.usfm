\id 1CH Azeri-N: Azerbaijani Bible 2008
\h BİRİNCİ SALNAMƏLƏR
\toc1 Birinci Salnamələr Kitabi
\toc2 Birinci Salnamələr
\toc3 1Saln
\mt1 BİRİNCİ SALNAMƏLƏR
\mt2 KİTABI
\imt1 GİRİŞ
\ip \bk «1 və 2 Salnamələr»\bk* adlanan iki kitab \bk «Şamuel»\bk* və \bk «Padşahlar»\bk* Kitablarındakı hadisələri yenidən başqa nöqteyi-nəzərdən işıqlandırır. \bk «1 Salnamələr»\bk* Kitabı İsrail tarixinin yazılmasının iki əsas məqsədini göstərir:
\ip İsrail və Yəhuda padşahlığının başına gəlmiş bəlalara baxmayaraq, Allah İsrail xalqına verdiyi vədlərinə sadiq olub Yəhudada yaşayanlar vasitəsilə Öz xalqı üçün niyyətini həyata keçirirdi. Müəllif bunu Davud və Süleymanın nailiyyətlərində, Yehoşafat, Xizqiya və Yoşiyanın islahatlarında, həmçinin xalqın Allaha sadiqliyində görürdü.
\ip Yerusəlim məbədində xalqın Allaha səcdə etməsi, xüsusilə kahinlərlə Levililərin ibadət xidməti təsvir olunur. Süleyman məbədi tikdi, amma Davud məbədin təməlini və mərasimlərin əsasını qoydu.
\iot Kitabın məzmunu
\io2 1:1–9:44 Nəsil şəcərələri və siyahılar
\io2 10:1-14 Şaulun ölümü
\io2 11:1–29:30 Davudun padşahlığı
\io3 11:1–22:1 Bəlalar və nailiyyətlər
\io3 22:2–29:30 Məbədi tikmək üçün hazırlıq
\c 1
\s1 Adəm və onun nəsilləri
\r (Yar. 5:1-32)
\p 
\v 1 Adəm, Şet, Enoş,
\v 2 Qenan, Mahalalel, Yered,
\v 3 Xanok, Metuşelah, Lemek,
\v 4 Nuh, Sam, Ham və Yafəs.
\s1 Nuhun nəsilləri
\r (Yar. 10:1-32; 11:10-26)
\p 
\v 5 Yafəsin oğulları: Qomer, Maqoq, Maday, Yavan, Tuval, Meşek və Tiras.
\v 6 Qomerin oğulları: Aşkenaz, Rifat və Toqarma.
\v 7 Yavanın oğulları: Elişa, Tarşiş, Kittim və Rodanim.
\p 
\v 8 Hamın oğulları: Kuş, Misrayim, Put və Kənan.
\v 9 Kuşun oğulları: Seva, Xavila, Savta, Raama və Savteka. Raamanın oğulları: Səba və Dedan.
\v 10 Kuşun Nəmrud adlı bir oğlu da oldu. O, yer üzündə ilk qüdrətli adam oldu.
\v 11 Misrayimin nəsilləri bunlardır: Ludlular, Anamlılar, Lehavlılar, Naftuhlular,
\v 12 Patroslular, Filiştlilərin əcdadı olan Kasluhlular, həmçinin Kaftorlular.
\v 13 Kənanın nəsilləri bunlardır: ilk oğlu Sidon, Xet,
\v 14 həmçinin Yevuslular, Emorlular, Qirqaşlılar,
\v 15 Xivlilər, Arqlılar, Sinlilər,
\v 16 Ervadlılar, Semarlılar və Xamatlılar.
\p 
\v 17 Samın oğulları: Elam, Aşşur, Arpakşad, Lud, Aram, Us, Xul, Geter və Meşek.
\v 18 Arpakşaddan Şelah törədi və Şelahdan Ever törədi.
\v 19 Everin iki oğlu oldu: birinin adı Peleq \f + \fr 1:19 \fq Peleq \ft – ibrani dilində \fq bölünmə.\f* idi, çünki onun dövründə yer üzü bölündü. Qardaşının adı Yoqtan idi.
\v 20 Yoqtandan Almodad, Şelef, Xasarmavet, Yerah,
\v 21 Hadoram, Uzal, Diqla,
\v 22 Eval, Avimael, Səba,
\v 23 Ofir, Xavila və Yovav törədi. Bunların hamısı Yoqtanın oğulları idi.
\p 
\v 24 Sam, Arpakşad, Şelah,
\v 25 Ever, Peleq, Reu,
\v 26 Seruq, Naxor, Terah,
\v 27 İbram, yəni İbrahim.
\s1 İbrahimin nəsilləri
\r (Yar. 25:12-16; 36:1-19)
\p 
\v 28 İbrahimin oğulları: İshaq və İsmail.
\v 29 Onların oğulları bunlardır: İsmailin ilk oğlu Nevayot, sonra Qedar, Adbeel, Mivsam,
\v 30 Mişma, Duma, Massa, Xadad, Tema,
\v 31 Yetur, Nafiş və Qedma. Bunlar İsmailin oğullarıdır.
\p 
\v 32 İbrahimin cariyəsi Qeturanın doğduğu oğullar bunlardır: Zimran, Yoqşan, Medan, Midyan, İşbaq və Şuah. Yoqşanın oğulları: Səba və Dedan.
\v 33 Midyanın oğulları: Efa, Efer, Xanok, Avida və Eldaa. Bunların hamısı Qeturanın övladlarıdır.
\p 
\v 34 İbrahimdən İshaq törədi. İshaqın oğulları: Esav və İsrail.
\v 35 Esavın oğulları: Elifaz, Reuel, Yeuş, Yalam və Qorah.
\v 36 Elifazın oğulları: Teman, Omar, Sefi, Qatam, Qenaz, Timna və Amaleq.
\v 37 Reuelin oğulları: Naxat, Zerah, Şamma və Mizza.
\s1 Seirin nəsilləri
\r (Yar. 36:20-30)
\p 
\v 38 Seirin oğulları: Lotan, Şoval, Siveon, Ana, Dişon, Eser və Dişan.
\v 39 Lotanın oğulları: Xori və Homam, Lotanın bacısı Timna.
\v 40 Şovalın oğulları: Alvan, Manaxat, Eval, Şefo və Onam. Siveonun oğulları: Ayya və Ana.
\v 41 Ananın oğlu Dişon. Dişonun oğulları: Xamran, Eşban, İtran və Keran.
\v 42 Eserin oğulları: Bilhan, Zaavan və Yaaqan. Dişanın oğulları: Us və Aran.
\s1 Edomun padşahları və başçıları
\r (Yar. 36:31-43)
\p 
\v 43 İsraillilərə bir kəs padşahlıq etməzdən əvvəl Edom ölkəsində padşahlıq edən adamlar bunlardır: Beor oğlu Bela. Onun şəhəri Dinhava idi.
\v 44 Bela öldü və onun yerinə Bosradan olan Zerah oğlu Yovav padşah oldu.
\v 45 Yovav öldü və onun yerinə Temanlıların torpağından olan Xuşam padşah oldu.
\v 46 Xuşam öldü və onun yerinə Moav çölündə Midyanlıları qıran Bedad oğlu Hadad padşah oldu. Onun şəhəri Avit idi.
\v 47 Hadad öldü və onun yerinə Masreqadan olan Samla padşah oldu.
\v 48 Samla öldü və onun yerinə Rexovot-Hannahardan olan Şaul padşah oldu.
\v 49 Şaul öldü və onun yerinə Akbor oğlu Baal-Xanan padşah oldu.
\v 50 Baal-Xanan öldü və onun yerinə Hadad padşah oldu. Onun şəhəri Pau idi. Onun arvadının adı Me-Zahav qızı Matred qızı Mehetavel idi.
\p 
\v 51 Hadad öldü və bunlar Edomun başçıları oldu: başçı Timna, başçı Alva, başçı Yetet,
\v 52 başçı Oholivama, başçı Ela, başçı Pinon,
\v 53 başçı Qenaz, başçı Teman, başçı Mivsar,
\v 54 başçı Maqdiel, başçı İram. Edomun başçıları bunlardır.
\c 2
\s1 İsrailin oğulları
\p 
\v 1 İsrailin oğulları bunlardır: Ruven, Şimeon, Levi, Yəhuda, İssakar, Zevulun,
\v 2 Dan, Yusif, Binyamin, Naftali, Qad və Aşer.
\s1 Yəhudanın nəsilləri
\p 
\v 3 Yəhudanın oğulları: Er, Onan və Şela. Onun bu üç oğlu Kənanlı Bat-Şuadan doğuldu. Yəhudanın ilk oğlu Er Rəbbin gözündə pis adam idi və Rəbb onu öldürdü.
\v 4 Yəhudanın gəlini Tamar ona Peresi və Zerahı doğdu. Yəhudanın cəmisi beş oğlu var idi.
\p 
\v 5 Peresin oğulları: Xesron və Xamul.
\v 6 Zerahın oğulları: Zimri, Etan, Heman, Kalkol və Dara. Bunlar cəmisi beş nəfər idi.
\v 7 \x * \xo 2:7 \xt Yeşua 7:1 \x* Karminin oğlu həsr olunmuş şeydə xainlik edib İsraili bəlaya salan Akan idi.
\v 8 Etanın oğlu Azarya idi.
\s1 Davudun əcdadları
\p 
\v 9 Xesronun oğulları: Yeraxmeel, Ram və Kalev.
\v 10 Ramdan Amminadav törədi və Amminadavdan Yəhudalıların rəhbəri Naxşon törədi.
\v 11 Naxşondan Salmon törədi və Salmondan Boaz törədi.
\v 12 Boazdan Oved törədi və Oveddən Yessey törədi.
\v 13 Yesseyin oğulları bunlar idi: ilk oğlu Eliav, ikincisi Avinadav, üçüncüsü Şimea,
\v 14 dördüncüsü Netanel, beşincisi Radday,
\v 15 altıncısı Osem, yeddincisi Davud.
\v 16 Onların bacıları Seruya və Aviqail idi. Seruyanın üç oğlu var idi: Avişay, Yoav və Asahel.
\v 17 Aviqail Amasanı doğdu. Amasanın atası İsmailli Yeter idi.
\s1 Xesronun başqa nəsilləri
\p 
\v 18 Xesron oğlu Kalevin arvadı Azuva və Yeriot ona övladlar doğdu. Kalevin Azuvadan olan oğulları bunlardır: Yeşer, Şovav və Ardon.
\v 19 Azuva öldü. Kalev Efratı arvad aldı və o da Kalevə Xuru doğdu.
\v 20 Xurdan Uri törədi. Uridən Besalel törədi.
\p 
\v 21 Bundan sonra Xesron altmış yaşında ikən Gileadın atası olan Makirin qızını aldı və onunla yaxınlıq etdi; o, Xesrona Sequvu doğdu.
\v 22 Sequv Yairin atası idi. Yairin Gilead torpağında iyirmi üç şəhəri var idi.
\v 23 Amma Geşurlular və Aramlılar onlardan Xavvot-Yairi aldılar, bundan başqa, Qenatı və onun qəsəbələrini də – cəmisi altmış şəhəri aldılar. Bunların hamısı Gileadın atası olan Makirin nəsilləri idi.
\v 24 Xesron Kalev-Efratada öldükdən sonra Xesronun arvadı Aviya ona Teqoanın atası Aşxuru doğdu.
\p 
\v 25 Xesronun ilk oğlu Yeraxmeelin oğulları: ilk oğlu Ram, Buna, Oren, Osem və Axiya.
\v 26 Yeraxmeelin başqa bir arvadı var idi, onun adı Atara idi. Onamın anası o idi.
\v 27 Yeraxmeelin ilk oğlu Ramın oğulları: Maas, Yamin və Eqer.
\v 28 Onamın oğulları: Şammay və Yada. Şammayın oğulları: Nadav və Avişur.
\v 29 Avişurun arvadının adı Avihayil idi. O, Avişura Axbanı və Molidi doğdu.
\v 30 Nadavın oğulları: Seled və Appayim. Seled oğulsuz öldü.
\v 31 Appayimin oğlu İşi idi. İşinin oğlu Şeşan idi. Şeşanın oğlu Axlay idi.
\v 32 Şammayın qardaşı Yadanın oğulları: Yeter və Yonatan. Yeter oğulsuz öldü.
\v 33 Yonatanın oğulları: Pelet və Zaza. Bunlar Yeraxmeelin nəsilləri idi.
\p 
\v 34 Şeşanın oğulları yox idi, yalnız qızları var idi. Şeşanın bir Misirli qulu var idi, onun adı Yarxa idi.
\v 35 Şeşan qulu Yarxaya qızını arvad olmaq üçün verdi. Arvadı ona Attayı doğdu.
\v 36 Attaydan Natan törədi. Natandan Zavad törədi.
\v 37 Zavaddan Eflal törədi. Eflaldan Oved törədi.
\v 38 Oveddən Yehu törədi. Yehudan Azarya törədi.
\v 39 Azaryadan Xeles törədi. Xelesdən Eleasa törədi.
\v 40 Eleasadan Sismay törədi. Sismaydan Şallum törədi.
\v 41 Şallumdan Yeqamya törədi. Yeqamyadan Elişama törədi.
\p 
\v 42 Yeraxmeelin qardaşı Kalevin oğulları: Zifin atası ilk oğlu Meşa, Xevronun atası Mareşa.
\v 43 Xevronun oğulları: Qorah, Tappuah, Reqem və Şema.
\v 44 Şemadan Yorqoamın atası olan Raxam törədi. Reqemdən Şammay törədi.
\v 45 Şammayın oğlu Maon idi. Maon Bet-Suru tikdi.
\v 46 Kalevin cariyəsi Efa Xaranı, Mosanı və Qazezi doğdu. Xaran Qazezin atası idi.
\v 47 Yahdayın oğulları: Regem, Yotam, Geşan, Pelet, Efa və Şaaf.
\v 48 Kalevin cariyəsi Maaka Şeveri və Tirxananı doğdu.
\v 49 O həm də Madmannanın atası Şaafı, Makbenanın və Giveanın atası Şevanı doğdu. Kalevin qızı Aksa idi.
\v 50 Bunlar Kalevin nəsilləri idi.
\p Efratanın ilk oğlu Xurun oğulları bunlardır: Qiryat-Yearimin atası Şoval,
\v 51 Bet-Lexemin atası Salma, Bet-Qaderin atası Xaref.
\v 52 Qiryat-Yearimin atası Şovalın nəsilləri bunlardır: Haroelilər, Manaxatlıların yarısı.
\v 53 Qiryat-Yearimin sakinləri: Yeterlilər, Putlular, Şumalılar, Mişralılar. Bunların arasından Soralılar və Eştaollular çıxdılar.
\v 54 Salmanın nəsilləri: Bet-Lexemlilər, Netofalılar, Atrot-Bet-Yoavlılar, Manaxatlıların yarısı və Soralılar.
\v 55 Yabesdə yaşayan mirzələrin nəsilləri: Tirealılar, Şimealılar, Sukalılar. Bunlar Bet-Rekavın atası Xammatın nəslindən olan Qenlilərdir.
\c 3
\s1 Davudun oğulları
\p 
\v 1 Davudun Xevronda doğulan oğulları bunlardır: ilk oğlu İzreelli Axinoamdan doğulan Amnon, ikincisi Karmelli Aviqaildən doğulan Daniel,
\v 2 üçüncüsü Geşur padşahı Talmayın qızı Maakadan doğulan Avşalom, dördüncüsü Haqqitdən doğulan Adoniya,
\v 3 beşincisi Avitaldan doğulan Şefatya, altıncısı arvadı Eqladan doğulan İtream.
\v 4 \x * \xo 3:4 \xt 2Şam. 5:4-5; 1Pad. 2:11; 1Saln. 29:27 \x* Davudun bu altı oğlu Xevronda doğuldu. Davud orada yeddi il altı ay padşahlıq etdi, Yerusəlimdə isə otuz üç il padşahlıq etdi.
\v 5 \x * \xo 3:5 \xt 2Şam. 11:3 \x* Davudun Yerusəlimdə doğulan oğulları bunlardır: Ammielin qızı Bat-Şevadan doğulan dörd oğlu: Şimea, Şovav, Natan və Süleyman,
\v 6 daha doqquz oğlu: İvxar, Elişua, Elpelet,
\v 7 Noqah, Nefeq, Yafia,
\v 8 Elişama, Elyada və Elifelet.
\v 9 Cariyələrdən doğulan oğullarından başqa Davudun bütün oğulları bunlardır. Tamar da onların bacısıdır.
\s1 Yəhuda padşahları
\p 
\v 10 Süleymanın oğlu Rexavam, onun oğlu Aviya, onun oğlu Asa, onun oğlu Yehoşafat,
\v 11 onun oğlu Yehoram, onun oğlu Axazya, onun oğlu Yoaş,
\v 12 onun oğlu Amasya, onun oğlu Azarya, onun oğlu Yotam,
\v 13 onun oğlu Axaz, onun oğlu Xizqiya, onun oğlu Menaşşe,
\v 14 onun oğlu Amon, onun oğlu Yoşiya.
\v 15 Yoşiyanın oğulları: ilk oğlu Yoxanan, ikincisi Yehoyaqim, üçüncüsü Sidqiya, dördüncüsü Şallum.
\v 16 Yehoyaqimin oğulları: onun oğlu Yekonya, \f + \fr 3:16 \fq Yekonya \ft – başqa adı Yehoyakin.\f* onun oğlu Sidqiya.
\s1 Yekonyanın nəsilləri
\p 
\v 17 Əsir aparılmış Yekonyanın oğulları: Şealtiel,
\v 18 Malkiram, Pedaya, Şenassar, Yeqamya, Hoşama və Nedavya.
\v 19 Pedayanın oğulları: Zerubbabil və Şimey. Zerubbabilin oğulları: Meşullam və Xananya, onların bacısı Şelomit,
\v 20 daha beş oğlu: Xaşuva, Ohel, Berekya, Xasadya və Yuşav-Xesed.
\v 21 Xananyanın nəsilləri: Pelatya, Yeşaya, Refayanın oğulları, Arnanın oğulları, Avdiyanın oğulları, Şekanyanın oğulları.
\v 22 Şekanyanın oğlu Şemaya idi. Şemayanın altı oğlu: Xattuş, İqal, Bariah, Nearya və Şafat.
\v 23 Nearyanın üç oğlu: Elyoenay, Xizqiya və Azriqam.
\v 24 Elyoenayın yeddi oğlu: Hodavya, Elyaşiv, Pelaya, Aqquv, Yoxanan, Delaya və Anani.
\c 4
\s1 Yəhudanın nəsilləri
\p 
\v 1 Yəhudanın oğulları: Peres, Xesron, Karmi, Xur və Şoval.
\v 2 Şovalın oğlu Reayadan Yaxat törədi; Yaxatdan Axumay və Lahad törədi. Bunlar Soralıların nəsilləri idi.
\v 3 Etamın oğulları bunlardır: İzreel, İşma və İdbaş. Onların bacısının adı Haslelponidir.
\v 4 Penueldən Qedor, Ezerdən isə Xuşa törədi. Bunlar Bet-Lexemin atası Efratanın ilk oğlu Xurun övladlarıdır.
\v 5 Teqoanın atası Aşxurun iki arvadı var idi: Xela və Naara.
\v 6 Naara ona bunları doğdu: Axuzzam, Xefer, Temeni və Axaştari. Bunlar Naaranın oğulları idi.
\v 7 Xelanın oğulları: Seret, İsxar, Etnan və Qos.
\v 8 Qosdan Anuv, Soveva və Harum oğlu Axarxelin nəsilləri törədi.
\p 
\v 9 Yabes qardaşlarından daha hörmətli idi. Anası «onu ağrı ilə doğdum» deyib adını Yabes qoymuşdu.
\v 10 Yabes İsrailin Allahını çağırıb dedi: «Kaş Sən mənə xeyir-dua verəydin! Torpaqlarımı genişləndir, mənə kömək ol və əzab çəkməyim deyə məni şərdən qoru». Allah da istədiyi şeyi ona verdi.
\p 
\v 11 Şuxanın qardaşı Keluvdan Mexir törədi. Mexirdən Eşton törədi.
\v 12 Eştondan Bet-Rafa, Paseahın və İr-Naxaşın atası Texinna törədi. Bunlar Rekalılardır.
\v 13 Qenazın oğulları: Otniel və Seraya. Otnielin oğulları Xatat və
\v 14 Ofranın atası olan Meonotay. Serayadan Ge-Xaraşimin \f + \fr 4:14 \fq Ge-Xaraşim \ft – ibrani dilində \fq ustalar vadisi.\f* atası Yoav törədi. Bu şəhərin sakinləri ustalar olduğuna görə belə adlanırdı.
\v 15 Yefunnenin oğlu Kalevin oğulları: İru, Ela və Naam. Elanın oğlu Qenaz idi.
\v 16 Yehallelelin oğulları: Zif, Zifa, Tirya və Asarel.
\v 17 Ezranın oğulları: Yeter, Mered, Efer, Yalon. Meredin arvad aldığı firon qızı Bityanın oğulları: Məryəm, Şammay və Eştemoanın atası İşbah.
\v 18 Yəhudalı arvadı isə bunları doğdu: Qedorun atası Yered, Sokonun atası Xever və Zanoahın atası Yequtiel.
\v 19 Naxamın bacısı Hodiyanın arvadı idi. Onun oğullarından Qarmili Qeila və Maakalı Eştemoa törədi.
\v 20 Şimeonun oğulları: Amnon, Rinna, Ben-Xanan və Tilon. İşinin oğulları: Zoxet və Ben-Zoxet.
\v 21 Yəhudanın oğlu Şelanın nəsilləri: Lexanın atası Er, Mareşanın atası Laada və Bet-Aşbeada olan incə kətan toxuyanların nəsilləri,
\v 22 Yoqim və Kozevalılar, Yoaş və Saraf. Bunlar Moavda arvad aldılar və Lexemə qayıtdılar. Bu, qədim hadisələrdir.
\v 23 Onlar dulusçu idi, Netaimdə və Gederada yaşayırdılar. Padşah üçün iş görərək orada qalırdılar.
\s1 Şimeonun nəsilləri
\p 
\v 24 Şimeonun oğulları: Nemuel, Yamin, Yariv, Zerah və Şaul.
\v 25 Şaulun oğlu Şallum, onun oğlu Mivsam, onun oğlu Mişma.
\v 26 Mişmanın oğulları: onun oğlu Xammuel, onun oğlu Zakkur, onun oğlu Şimey.
\v 27 Şimeyin on altı oğlu və altı qızı var idi, lakin qohumlarının oğulları çox deyildi və onların bütün nəsli Yəhuda oğulları qədər çoxalmadı.
\p 
\v 28 Onlar bu yerlərdə yaşayırdı: Beer-Şeva, Molada, Xasar-Şual,
\v 29 Bilha, Esem, Tolad,
\v 30 Betuel, Xorma, Ziqlaq,
\v 31 Bet-Markavot, Xasar-Susim, Bet-Biri və Şaarayim. Davudun padşahlıq etdiyi dövrə qədər onların şəhərləri bunlardır.
\v 32 Onların qəsəbələri bunlardır: Etam, Ayin, Rimmon, Token və Aşan – cəmi beş şəhər.
\v 33 Bu şəhərlərin ətrafında Baala qədər olan bütün kəndlər də onların yaşadıqları yerlərdir. Onların nəsil şəcərəsi belədir:
\v 34 Meşovav, Yamlek, Amasya oğlu Yoşa,
\v 35 Yoel, Asiel oğlu Seraya oğlu Yoşivya oğlu Yehu,
\v 36 Elyoenay, Yaaqova, Yeşoxaya, Asaya, Adiel, Yesimiel, Benaya,
\v 37 Şemaya oğlu Şimri oğlu Yedaya oğlu Allon oğlu Şifi oğlu Ziza.
\v 38 Bu adları çəkilənlər nəsil rəhbərləri idi və onların nəsilləri artıb çoxalmışdı.
\v 39 Onlar sürüləri üçün otlaq axtarmaqdan ötrü Qedorun yaxınlığına, dərənin şərq tərəfinə qədər getdilər.
\v 40 Bol və yaxşı otlaq tapdılar, ölkə də geniş, sakit və dinc idi. Onlardan əvvəl orada Hamlılar yaşayırdı.
\v 41 Bu adları yazılanlar Yəhuda padşahı Xizqiyanın dövründə gəlib öz çadırlarında olan Hamlıları və orada olan Maonluları qırdılar. Onları tamamilə məhv edib yerlərində yaşadılar, çünki orada sürüləri üçün otlaq var idi. Bu günə qədər də belədir.
\v 42 Həmin Şimeonlulardan beş yüz nəfər Seir dağına getdi. İşinin oğulları Pelatya, Naarya, Refaya və Uzziel onlara başçılıq edirdi.
\v 43 Onlar sağ qalan Amaleqli qaçanları qırdılar. Onlar bu günə qədər də orada yaşayır.
\c 5
\s1 Ruvenin nəsilləri
\p 
\v 1 \x * \xo 5:1 \xt Yar. 35:22; 49:3-4 \x* İsrailin ilk oğlu Ruven idi, amma atasının yatağını murdarladığı üçün onun ilk oğulluq haqqı İsrailin oğlu Yusifin nəslinə verildi və Ruvenin nəsli şəcərədə ilk oğul kimi sayılmadı.
\v 2 \x * \xo 5:2 \xt Yar. 49:8-10 \x* Ancaq Yəhuda qardaşları arasında daha güclü oldu və hökmdar onun nəslindən çıxdı. İlk oğulluq haqqı isə Yusifin idi.
\v 3 İsrailin ilk oğlu Ruvenin oğulları: Xanok, Pallu, Xesron və Karmi.
\v 4 \x * \xo 5:4 \xt 2Pad. 15:29 \x* Yoelin nəsli: onun oğlu Şemaya, onun oğlu Qoq, onun oğlu Şimey,
\v 5 onun oğlu Mikeya, onun oğlu Reaya, onun oğlu Baal,
\v 6 onun oğlu Beera. Onu Aşşur padşahı Tiqlat-Pileser sürgünə aparmışdı. Beera Ruvenlilərin başçısı idi.
\v 7 Nəsil şəcərələrinə görə onların qohumları bunlar idi: başçı Yeiel, Zəkəriyyə,
\v 8 Yoel oğlu Şema oğlu Azaz oğlu Bela. O, Aroerdə yaşayırdı, torpağı Nevoya və Baal-Meona qədər uzanırdı.
\v 9 Şərqə tərəf Fərat çayının bu tayındakı çölün başlanğıc yerinə qədər torpaqlar onun idi, çünki Gilead torpağında çoxlu heyvanları var idi.
\v 10 Şaulun dövründə bu adamlar Həcərlilərlə müharibə edib onları məğlub etdi və Gileadın şərqindəki bütün torpaqlarda Həcərlilərin çadırlarında yaşadı.
\s1 Qadın nəsilləri
\p 
\v 11 Qadlılar Salkaya qədər uzanan Başan torpağında Ruvenlilərin qarşısında yaşadı.
\v 12 Başanda başçı Yoel, köməkçisi Şafam, sonra Yanay və Şafat idi.
\v 13 Öz nəsillərindən olan qohumları bunlardır: Mikael, Meşullam, Şeva, Yoray, Yakan, Ziya və Ever – cəmi yeddi nəfər.
\v 14 Bunlar Buz oğlu Yaxdo oğlu Yeşişay oğlu Mikael oğlu Gilead oğlu Yaroah oğlu Xuri oğlu Avixayilin oğulları idi.
\v 15 Quni oğlu Avdiel oğlu Axi onların nəsil başçısı idi.
\v 16 Onlar Gileadda, Başanda və onun qəsəbələrində, Şaronun sərhədlərinə qədər uzanan bütün otlaq torpaqlarında yaşadı.
\v 17 Yəhuda padşahı Yotamın və İsrail padşahı Yarovamın dövründə onların hamısı nəsil şəcərələrində qeyd olundu.
\s1 İsraillilərin Həcərlilərlə müharibəsi
\p 
\v 18 Ruvenlilərdən, Qadlılardan, Menaşşe qəbiləsinin yarısından olan, qalxan və qılınc daşıyan, ox atan, döyüş üçün təlim görmüş və döyüşməyi bacaran igid adamlar qırx dörd min yeddi yüz altmış nəfər idi.
\v 19 Onlar Həcərlilərdən olan Yeturun, Nafişin və Nadavın nəsilləri ilə müharibə etdi.
\v 20 İsraillilər düşmənləri ilə döyüşdə kömək aldıqları üçün Həcərliləri və onlarla olanların hamısını məğlub etdilər, çünki İsraillilər döyüş zamanı Allahı çağırdılar və Ona güvəndikləri üçün Allah onları eşitdi.
\v 21 Onlar düşmənlərinin heyvanlarını – əlli min dəvəsini, iki yüz əlli min qoyun-keçisini, iki min eşşəyini ələ keçirdi və yüz min adamını götürüb apardı.
\v 22 Həlak olanlar çox oldu, çünki bu döyüş Allahdan idi. Onlar sürgün olunan zamana qədər Həcərlilərin yerlərində yaşadı.
\s1 İordan çayının şərqində yaşayan Menaşşelilərin nəsilləri
\p 
\v 23 Menaşşe qəbiləsinin yarısının nəsilləri də həmin torpaqda yaşadı. Onlar çoxalıb Başandan Baal-Xermona, Senirə və Xermon dağına qədər uzanan torpağa yayıldılar.
\v 24 Onların nəsil başçıları bunlardır: Efer, İşi, Eliel, Azriel, Yeremya, Hodavya və Yaxdiel. Bunlar igid döyüşçülər, adlı-sanlı adamlar və nəsil başçıları idi.
\v 25 Amma onlar atalarının Allahına qarşı xainlik etdilər və onların önündə Allahın məhv etdiyi ölkə xalqlarının allahlarına sitayiş edib xəyanət etdilər.
\v 26 \x * \xo 5:26 \xt 2Pad. 15:19 \x* \x * \xo 5:26 \xt 2Pad. 15:29 \x* \x * \xo 5:26 \xt 2Pad. 17:6 \x* Onda İsrailin Allahı Aşşur padşahı Pulda, yəni Tiqlat-Pileserdə niyyət oyandırdı, o da Ruvenliləri, Qadlıları və Menaşşe qəbiləsinin yarısını əsir aparıb Xalaha, Xavora, Haraya və Qozan çayının sahilində yerləşdirdi. Onlar bu günə qədər də oradadır.
\c 6
\s1 Levinin nəsilləri
\p 
\v 1 Levinin oğulları: Gerşon, Qohat və Merari.
\v 2 Qohatın oğulları: Amram, İshar, Xevron və Uzziel.
\v 3 Amramın övladları: Harun, Musa və Məryəm. Harunun oğulları: Nadav, Avihu, Eleazar və İtamar.
\p 
\v 4 Eleazardan Pinxas törədi. Pinxasdan Avişua törədi.
\v 5 Avişuadan Buqqi törədi. Buqqidən Uzzi törədi.
\v 6 Uzzidən Zerahya törədi. Zerahyadan Merayot törədi.
\v 7 Merayotdan Amarya törədi. Amaryadan Axituv törədi.
\v 8 Axituvdan Sadoq törədi. Sadoqdan Aximaas törədi.
\v 9 Aximaasdan Azarya törədi. Azaryadan Yoxanan törədi.
\v 10 Yoxanandan Azarya törədi. Yerusəlimdə Süleymanın tikdiyi məbəddə Azarya kahin idi.
\v 11 Azaryadan Amarya törədi. Amaryadan Axituv törədi.
\v 12 Axituvdan Sadoq törədi. Sadoqdan Şallum törədi.
\v 13 Şallumdan Xilqiya törədi. Xilqiyadan Azarya törədi.
\v 14 Azaryadan Seraya törədi. Serayadan Yehosadaq törədi.
\v 15 Navuxodonosorun vasitəsilə Rəbb Yəhudalıları və Yerusəlimliləri sürgün etdiyi zaman Yehosadaq da sürgün olundu.
\p 
\v 16 \x * \xo 6:16 \xt Çıx. 6:16-19 \x* Levinin oğulları: Gerşon, Qohat və Merari.
\v 17 Gerşonun oğullarının adları belədir: Livni və Şimey.
\v 18 Qohatın oğulları: Amram, İshar, Xevron və Uzziel.
\v 19 Merarinin oğulları: Maxli və Muşi. Nəsillərinə görə Levililərin övladları bunlardır.
\v 20 Gerşonun nəsli: onun oğlu Livni, onun oğlu Yaxat, onun oğlu Zimma,
\v 21 onun oğlu Yoah, onun oğlu İddo, onun oğlu Zerah, onun oğlu Yeatray.
\v 22 Qohatın nəsli: onun oğlu Amminadav, onun oğlu Qorah, onun oğlu Assir,
\v 23 onun oğlu Elqana, onun oğlu Evyasaf, onun oğlu Assir,
\v 24 onun oğlu Taxat, onun oğlu Uriel, onun oğlu Uzziya və onun oğlu Şaul.
\v 25 Elqananın oğulları: Amasay, Aximot və Elqana.
\v 26 Elqananın nəsli: onun oğlu Sofay, onun oğlu Naxat,
\v 27 onun oğlu Eliav, onun oğlu Yeroxam, onun oğlu Elqana.
\v 28 Şamuelin oğulları: ilk oğlu Yoel və ikincisi Aviya.
\v 29 Merarinin nəsli: onun oğlu Maxli, onun oğlu Livni, onun oğlu Şimey, onun oğlu Uzza,
\v 30 onun oğlu Şima, onun oğlu Haqqiya, onun oğlu Asaya.
\s1 Rəbbin evində olan musiqiçilər və kahinlər
\p 
\v 31 Əhd sandığı rahatlıq yerinə qoyulduqdan sonra Rəbbin evində musiqi xidməti üzərində Davudun qoyduğu adamlar bunlardır.
\v 32 Süleyman Yerusəlimdə Rəbbin məbədini tikənə qədər onlar müqəddəs məskən olan Hüzur çadırının önündə ilahi oxumaqla xidmət edirdilər və növbələrinə görə öz xidmətlərində dayanırdılar.
\v 33 Orada xidmət edənlər və onların oğulları bunlardır: Qohatın nəslindən ilahi oxuyan Heman. Onun nəsil şəcərəsi belədir: Yoel oğlu Şamuel oğlu
\v 34 Elqana oğlu Yeroxam oğlu Eliel oğlu Toah oğlu
\v 35 Suf oğlu Elqana oğlu Maxat oğlu Amasay oğlu
\v 36 Elqana oğlu Yoel oğlu Azarya oğlu Sefanya oğlu
\v 37 Taxat oğlu Assir oğlu Evyasaf oğlu Qorah oğlu
\v 38 İshar oğlu Qohat oğlu Levi oğlu İsrail oğlu.
\v 39 Sağında xidmət edən qohumu Asəf. Onun nəsil şəcərəsi belədir: Berekya oğlu Şima oğlu
\v 40 Mikael oğlu Baaseya oğlu Malkiya oğlu
\v 41 Etni oğlu Zerah oğlu Adaya oğlu
\v 42 Etan oğlu Zimma oğlu Şimey oğlu
\v 43 Yaxat oğlu Gerşon oğlu Levi oğlu.
\v 44 Sol tərəfində xidmət edən qohumları Merarinin nəslindən Etan. Onun nəsil şəcərəsi belədir: Qişi oğlu Avdi oğlu Malluk oğlu
\v 45 Xaşavya oğlu Amasya oğlu Xilqiya oğlu
\v 46 Amsi oğlu Bani oğlu Şemer oğlu
\v 47 Maxli oğlu Muşi oğlu Merari oğlu Levi oğlu.
\v 48 Onların qohumları olan Levililər müqəddəs məskən olan Allah evinin bütün xidmət işlərinə təyin olunmuşdu.
\p 
\v 49 Harunun və onun nəslinin öhdəsinə isə bu işlər qoyulmuşdu: yandırma qurbangahında və buxur qurbangahında təqdim gətirilməsi, Ən Müqəddəs yerə aid hər iş – İsraillilərin günahlarını kəffarə etmək üçün Allahın qulu Musanın əmr etdiyi bütün işlər.
\v 50 Harunun nəsli budur: onun oğlu Eleazar, onun oğlu Pinxas, onun oğlu Avişua,
\v 51 onun oğlu Buqqi, onun oğlu Uzzi, onun oğlu Zerahya,
\v 52 onun oğlu Merayot, onun oğlu Amarya, onun oğlu Axituv,
\v 53 onun oğlu Sadoq, onun oğlu Aximaas.
\s1 Levililərə verilən şəhərlər
\p 
\v 54 Levililərin öz torpaqlarında yaşadığı yerlər bunlardır: ilk püşk Qohat nəslindən olan Harunun övladlarına düşdüyü üçün onlara
\v 55 Yəhuda torpağında olan Xevronu və onun ətrafındakı otlaqları verdilər.
\v 56 Ancaq bu şəhərin çölünü və kəndlərini Yefunne oğlu Kalevə verdilər.
\v 57 Harunun nəslinə bu şəhərləri verdilər: sığınacaq şəhəri olan Xevron, Livna ilə otlaqları, Yattir, Eştemoa ilə otlaqları,
\v 58 Xilenlə otlaqları, Devirlə otlaqları,
\v 59 Aşanla otlaqları, Bet-Şemeşlə otlaqları,
\v 60 Binyamin qəbiləsinin torpağından Geva ilə otlaqları, Alemetlə otlaqları, Anatotla otlaqları. Onların bütün şəhərləri nəsillərinə görə on üç şəhərdir.
\p 
\v 61 Digər Qohat övladlarına isə Menaşşe qəbiləsinin yarısının torpağından püşkə görə on şəhər verildi.
\v 62 Gerşon övladlarına nəsillərinə görə İssakar qəbiləsinin, Aşer qəbiləsinin, Naftali qəbiləsinin və Başanda olan Menaşşe qəbiləsinin torpağından on üç şəhər verildi.
\v 63 Merari övladlarına nəsillərinə görə Ruven, Qad və Zevulun qəbilələrinin torpağından püşklə on iki şəhər verildi.
\v 64 İsrail övladları Levililərə bu şəhərləri və onların otlaqlarını verdilər.
\v 65 Yəhuda, Şimeon və Binyamin qəbilələrinin torpağından adları göstərilən bu şəhərləri püşkə görə verdilər.
\p 
\v 66 Qohat nəslindən bəzilərinə Efrayim qəbiləsinə aid şəhərləri verdilər.
\v 67 Efrayimin dağlıq bölgəsində sığınacaq şəhəri olan Şekemlə otlaqları, Gezerlə otlaqları,
\v 68 Yoqmeamla otlaqları, Bet-Xoronla otlaqları,
\v 69 Ayyalonla otlaqları, Qat-Rimmonla otlaqları.
\v 70 Menaşşe qəbiləsinin yarısının torpağından Anerlə otlaqları, Bileamla otlaqları Qohat nəslinin qalanına verildi.
\p 
\v 71 Gerşon nəslinə bu yerlər verildi: oğullarına Menaşşe qəbiləsinin yarısının torpağından Başandakı Qolanla otlaqları, Aştarotla otlaqları,
\v 72 İssakar qəbiləsinin torpağından Qedeşlə otlaqları, Davratla otlaqları,
\v 73 Ramotla otlaqları, Anemlə otlaqları,
\v 74 Aşer qəbiləsinin torpağından Maşalla otlaqları, Avdonla otlaqları,
\v 75 Xuqoqla otlaqları, Rexovla otlaqları,
\v 76 Naftali qəbiləsinin torpağından Qalileyada olan Qedeşlə otlaqları, Xammonla otlaqları, Qiryatayimlə otlaqları.
\p 
\v 77 Merari nəslinin digər adamlarına bu yerlər verildi: Zevulun qəbiləsinin torpağından Rimmono ilə otlaqları, Tavorla otlaqları,
\v 78 Yerixonun qarşısındakı, İordan çayının şərq tərəfində olan Ruven qəbiləsinin torpağından səhradakı Beserlə otlaqları, Yahsa ilə otlaqları,
\v 79 Qedemotla otlaqları, Mefaatla otlaqları,
\v 80 Qad qəbiləsinin torpağından Gileaddakı Ramotla otlaqları, Maxanayimlə otlaqları,
\v 81 Xeşbonla otlaqları, Yazerlə otlaqları.
\c 7
\s1 İssakarın nəsilləri
\p 
\v 1 İssakarın oğulları: Tola, Pua, Yaşuv və Şimron – cəmisi dörd nəfər.
\v 2 Tolanın oğulları: Uzzi, Refaya, Yeriel, Yaxmay, İvsam və Şamuel. Bunlar Tolanın nəsil başçıları idi. Davudun dövründə onların nəslindən olan igid döyüşçülər iyirmi iki min altı yüz nəfər idi.
\v 3 Uzzinin nəsli: İzrahya və onun oğulları: Mikael, Avdiya, Yoel, İşşiya – cəmisi beş nəfər. Onların hamısı başçı idi.
\v 4 Bunlardan başqa nəsil şəcərələrinə görə döyüşə bilən dəstələrdə otuz altı min nəfər var idi, çünki onların çoxlu arvadları və oğulları var idi.
\v 5 İssakarın bütün nəsilləri arasında igid döyüşçülər olan qohumları nəsil şəcərəsinə görə cəmisi səksən yeddi min nəfər idi.
\s1 Binyaminin nəsilləri
\p 
\v 6 Binyaminin oğulları: Bela, Beker və Yediael – cəmisi üç nəfər.
\v 7 Belanın oğulları: Esbon, Uzzi, Uzziel, Yerimot və İri – cəmisi beş nəfər nəsil başçısı. Onların nəslindən olan igid döyüşçülər nəsil şəcərələrinə görə iyirmi iki min otuz dörd nəfər idi.
\v 8 Bekerin oğulları: Zemira, Yoaş, Eliezer, Elyoenay, Omri, Yeremot, Aviya, Anatot və Alemet. Bunların hamısı Bekerin oğulları idi.
\v 9 Nəsil başçılarının şəcərəsinə görə onların igid döyüşçüləri iyirmi min iki yüz nəfər idi.
\v 10 Yediaelin nəsli: Bilhan və onun oğulları Yeuş, Binyamin, Ehud, Kenaana, Zetan, Tarşiş və Axişaxar.
\v 11 Bunların hamısı Yediaelin nəsil başçıları idi. Onlardan döyüşə bilən igid döyüşçülər on yeddi min iki yüz nəfər idi.
\v 12 İrin nəsilləri: Şuflular və Xuflular. Xuşlular isə Axerin nəslindən idi.
\s1 Naftalinin nəsilləri
\p 
\v 13 Naftalinin oğulları: Yaxasiel, Quni, Yeser, Şallum. Bunlar Bilhanın nəsilləri idi.
\s1 Menaşşenin nəsilləri
\p 
\v 14 Menaşşenin oğulları: Aramlı cariyəsinin doğduğu Asriel, həmin qadının doğduğu Gileadın atası Makir.
\v 15 Makir Xuflulardan və Şuflulardan bir arvad aldı. Onun bacısının adı Maaka idi. Selofxad isə onların qohumu idi. Onun yalnız qızları var idi.
\v 16 Makirin arvadının da adı Maaka idi. O, bir oğul doğub adını Pereş qoydu. Pereşin qardaşının adı Şereş idi, onun oğulları isə Ulam və Reqem idi.
\v 17 Ulamın oğlu Bedan idi. Menaşşe oğlu Makir oğlu Gileadın nəsli bunlardır.
\v 18 Onun bacısı Hammoleket İşhodu, Aviezeri və Maxlanı doğdu.
\v 19 Şemidanın oğulları: Axyan, Şekem, Liqxi və Aniam.
\s1 Efrayimin nəsilləri
\p 
\v 20 Efrayimin nəsli: Şutelah, onun oğlu Bered, onun oğlu Taxat, onun oğlu Eleada, onun oğlu Taxat,
\v 21 onun oğlu Zavad, onun oğlu Şutelah. Efrayimin başqa oğulları Ezer və Eleadı o torpağın yerli sakinləri olan Qatlılar öldürdü, çünki onların heyvanlarını oğurlamağa getmişdilər.
\v 22 Ataları Efrayim uzun müddət onlara yas tutdu və qohumları ona təsəlli vermək üçün gəldi.
\v 23 Sonra o, arvadının yanına girdi, qadın hamilə oldu və bir oğul doğdu. Atası onun adını Beria \f + \fr 7:23 \fq Beria \ft – ibrani dilində \fq bəla içində.\f* qoydu, çünki evinə bəla üz vermişdi.
\v 24 Onun Şeera adlı qızı da var idi. O, Aşağı və Yuxarı Bet-Xoronu, Uzzen-Şeeranı tikdi.
\v 25 Efrayimin başqa oğlu Refah, onun oğlu Reşef, onun oğlu Telah, onun oğlu Taxan,
\v 26 onun oğlu Ladan, onun oğlu Ammihud, onun oğlu Elişama,
\v 27 onun oğlu Nun, onun oğlu Yeşua.
\v 28 Onların mülkləri və yaşadıqları yerlər bunlardır: Bet-Ellə qəsəbələri, şərq tərəfdə Naaran, qərb tərəfdə Gezerlə qəsəbələri, Şekemlə qəsəbələri, Ayya ilə qəsəbələri,
\v 29 həm də Menaşşelilərin torpağına yaxın olan Bet-Şeanla qəsəbələri, Taanakla qəsəbələri, Megiddo ilə qəsəbələri, Dorla qəsəbələri. İsrail oğlu Yusifin nəsli bu yerlərdə yaşadı.
\s1 Aşerin nəsilləri
\p 
\v 30 Aşerin övladları: İmna, İşva, İşvi, Beria və onların bacısı Serah.
\v 31 Berianın oğulları: Xever və Birzayitin atası olan Malkiel.
\v 32 Xever bunların atası idi: Yaflet, Şomer, Xotam və onların bacısı Şua.
\v 33 Yafletin oğulları bunlardır: Pasak, Bimhal və Aşvat.
\v 34 Şemerin oğulları: Axi, Rohqa, Xubba və Aram.
\v 35 Onun qardaşı Helemin oğulları: Sofah, İmna, Şeleş və Amal.
\v 36 Sofahın oğulları: Suah, Xarnefer, Şual, Beri, İmra,
\v 37 Beser, Hod, Şamma, Şilşa, İtran və Beera.
\v 38 Yeterin oğulları: Yefunne, Pispa və Ara.
\v 39 Ullanın oğulları: Arah, Xanniel və Risya.
\v 40 Aşerin nəslindən olan bu adamların hamısı nəsil başçıları, seçilmiş adamlar, igid döyüşçülər və baş rəislər idi. Onlardan döyüşə bilən adamlar nəsil şəcərələrinə görə iyirmi altı min nəfər idi.
\c 8
\s1 Binyaminin nəsilləri
\p 
\v 1 Binyaminin oğulları bunlardır: ilk oğlu Bela, ikincisi Aşbel, üçüncüsü Axrah,
\v 2 dördüncüsü Noxa, beşincisi Rafa.
\v 3 Belanın oğulları bunlardır: Addar, Gera, Avihud,
\v 4 Avişua, Naaman, Axoah,
\v 5 Gera, Şefufan və Xuram.
\v 6 Gevada yaşayanların nəsil başçıları olan, sonra isə Manaxata köçürülən Ehudun oğulları bunlardır:
\v 7 Naaman, Axiya və onları köçürən Gera. Geradan Uzza və Axixud törədi.
\v 8 Şaxarayim arvadları Xuşim və Baaranı boşadıqdan sonra Moav ölkəsində övlad atası oldu,
\v 9 arvadı Xodeş ona bunları doğdu: Yovav, Sivya, Meşa, Malkam,
\v 10 Yeus, Sakya və Mirma. Onun bu oğulları nəsil başçıları idi.
\v 11 Xuşim isə ona Avituvu və Elpaalı doğmuşdu.
\v 12 Elpaalın oğulları: Ever, Mişam və Şamed. Şamed Ono ilə Lodu, onun qəsəbələrini tikdi.
\v 13 Ayyalonda yaşayanların nəsil başçıları Beria və Şema idi. Onlar Qatda yaşayanları qovdu.
\v 14 Berianın oğulları: Axyo, Şaşaq, Yeremot,
\v 15 Zevadya, Arad, Eder,
\v 16 Mikael, İşpa və Yoxa.
\v 17 Elpaalın oğulları: Zevadya, Meşullam, Xizqi, Xever,
\v 18 İşmeray, İzlia və Yovav.
\v 19 Şimeyin oğulları: Yaqim, Zikri, Zavdi,
\v 20 Elienay, Silletay, Eliel,
\v 21 Adaya, Beraya və Şimrat.
\v 22 Şaşaqın oğulları: İşpan, Ever, Eliel,
\v 23 Avdon, Zikri, Xanan,
\v 24 Xananya, Elam, Antotiya,
\v 25 İfdeya və Penuel.
\v 26 Yeroxamın oğulları: Şamşeray, Şexarya, Atalya,
\v 27 Yaareşya, İlyas və Zikri.
\v 28 Bunlar nəsil şəcərələrinə görə nəsil başçıları idi və Yerusəlimdə yaşadılar.
\s1 Padşah Şaulun əcdadları və nəsilləri
\p 
\v 29 Giveonun atası Yeiel Giveonda yaşayırdı və arvadının adı Maaka idi.
\v 30 İlk oğlu Avdon idi, o biriləri isə bunlar idi: Sur, Qiş, Baal, Nadav,
\v 31 Qedor, Axyo, Zeker,
\v 32 Şimanın atası Miqlot. Onlar qohumlarının yanında, Yerusəlimdə qohumları ilə birgə yaşayırdı.
\v 33 Nerdən Qiş törədi və Qişdən Şaul törədi. Şauldan Yonatan, Malki-Şua, Avinadav və Eşbaal \f + \fr 8:33 \fq Eşbaal \ft – başqa adı İş-Boşet.\f* törədi.
\v 34 Yonatanın oğlu Merib-Baal \f + \fr 8:34 \fq Merib-Baal \ft – başqa adı Mefiboşet.\f* idi. Merib-Baaldan Mikeya törədi.
\v 35 Mikeyanın oğulları: Piton, Melek, Tarea və Axaz.
\v 36 Axazdan Yehoadda törədi. Yehoaddadan Alemet, Azmavet və Zimri törədi. Zimridən Mosa törədi.
\v 37 Mosadan Bina törədi. Binanın oğlu Rafa, onun oğlu Elasa, onun oğlu Asel.
\v 38 Aselin altı oğlu var idi, onların adları belədir: Azriqam, Bokru, İsmail, Şearya, Avdiya və Xanan. Bunların hamısı Aselin oğulları idi.
\v 39 Onun qardaşı Eseqin oğulları: ilk oğlu Ulam, ikincisi Yeuş və üçüncüsü Elifelet.
\v 40 Ulamın oğulları oxatan igid döyüşçülər idi. Oğulları və nəvələri çox idi: yüz əlli nəfər. Bunların hamısı Binyaminin nəslindəndir.
\c 9
\s1 Yerusəlimin sakinləri
\p 
\v 1 Beləcə bütün İsraillilər nəsil şəcərələrində qeyd olunmuşdu və bunlar İsrail padşahlarının kitabında yazılmışdır.
\p Yəhudalılar xainliklərinə görə Babilə sürgün olunmuşdu.
\v 2 \x * \xo 9:2 \xt Ezra 2:27; Neh. 7:73 \x* İlk dəfə mülklərinə qayıdıb yaşayanlar İsraillilərdən bəzi adamlar, kahinlər, Levililər və məbəd qulluqçuları idi.
\v 3 Yerusəlimdə isə Yəhudalılardan, Binyaminlilərdən, Efrayimlilərdən və Menaşşelilərdən olan bu adamlar yaşadı.
\v 4 Yəhudanın oğlu Peresin nəslindən: Bani oğlu İmri oğlu Omri oğlu Ammihud oğlu Utay.
\v 5 Şelanın nəslindən: ilk oğlu Asaya və onun oğulları.
\v 6 Zerahın nəslindən: Yeuel və onun qohumları. Hamısı birlikdə altı yüz doxsan nəfər idi.
\v 7 Binyaminin nəslindən: Hassenua oğlu Hodavya oğlu Meşullam oğlu Sallu,
\v 8 Yeroxam oğlu İvniya, Mikri oğlu Uzzi oğlu Ela və İvniya oğlu Reuel oğlu Şefatya oğlu Meşullam.
\v 9 Onlar qohumları ilə birgə nəsil şəcərələrinə görə doqquz yüz əlli altı nəfər idi. Bunların hamısı nəsil başçıları idi.
\p 
\v 10 Kahinlərdən: Yedaya, Yehoyariv, Yakin,
\v 11 Allah məbədinin rəisi Axituv oğlu Merayot oğlu Sadoq oğlu Meşullam oğlu Xilqiya oğlu Azarya,
\v 12 Malkiya oğlu Paşxur oğlu Yeroxam oğlu Adaya və İmmer oğlu Meşillemit oğlu Meşullam oğlu Yaxzera oğlu Adiel oğlu Maasay.
\v 13 Bunlar nəsil başçıları idi. Onlar qohumları ilə birgə – Allah evinin xidməti işində bacarıqlı olan bu adamlar min yeddi yüz altmış nəfər idi.
\p 
\v 14 Levililərdən: Merarinin nəslindən Xaşavya oğlu Azriqam oğlu Xaşşuv oğlu Şemaya,
\v 15 Baqbaqqar, Xereş, Qalal, Asəf oğlu Zikri oğlu Mikeya oğlu Mattanya,
\v 16 Yedutun oğlu Qalal oğlu Şemaya oğlu Avdiya və Netofalıların kəndlərində yaşayan Elqana oğlu Asa oğlu Berekya.
\p 
\v 17 Qapıçılar: Şallum, Aqquv, Talmon, Aximan və onların qohumları. Şallum onların başçısı idi.
\v 18 Onlar bu günə qədər də məbədin şərq tərəfdəki padşah qapısında keşik çəkirlər. Levililərin düşərgə qapıçıları bunlardır.
\v 19 Qorah oğlu Evyasaf oğlu Qore oğlu Şallum və onun Qorah nəslindən olan qohumları məbədin astana keşikçilərinin xidmət işinə başçılıq edirdi. Əvvəllər onların babaları Rəbbin düşərgəsinin girəcək yerinin keşiyini çəkirdi.
\v 20 Eleazar oğlu Pinxas onların başçısı idi və Rəbb onunla idi.
\v 21 Hüzur çadırının girişində Meşelemya oğlu Zəkəriyyə qapıçı idi.
\v 22 Astana keşikçisi olmaq üçün seçilən bütün bu adamlar iki yüz on iki nəfər idi. Onlar öz kəndlərində nəsil şəcərələrində qeyd edilmişlər. Onları vəzifələrinə Davud və görücü Şamuel təyin etmişdi.
\v 23 Bu adamlar və onların nəsilləri çadırın və Rəbbin məbədinin qapılarında keşik çəkirdi.
\v 24 Bu qapıçılar məbədin dörd tərəfində – şərq, qərb, şimal və cənub qapılarında dururdu.
\v 25 Öz kəndlərində yaşayan qohumları vaxtaşırı yeddi günlüyə onların yanına gəlməli idi.
\v 26 Allah evinin otaqlarının və xəzinələrinin keşiyini çəkmək Levili olan qapıçıların dörd nəfər rəisinin öhdəsində idi.
\v 27 Onlar gecə də Allah evinin ətrafında qalırdı, çünki onun keşiyini çəkmək və hər səhər qapıları açmaq onların işi idi.
\p 
\v 28 Onların bəzisi xidmət üçün olan qablara baxırdı: bunları sayıb içəri gətirir və sayıb bayıra aparırdılar.
\v 29 Bəziləri isə başqa əşyalar, bütün təqdis olunmuş şeylər və un, şərab, yağ, kündür, ətriyyatlar üzərində nəzarətçi qoyulmuşdu.
\v 30 Kahinlərdən bəzisi ətriyyatlardan qatışıq maddə hazırlayırdı.
\v 31 Kökələr bişirilməsi Qorah nəslindən olan Şallumun ilk oğlu olan Levili Mattityanın öhdəsində idi.
\v 32 Onların Qohat nəslindən olan qohumlarından bəzisinə isə hər Şənbə günü çörək hazırlanması tapşırılmışdı.
\p 
\v 33 Levililərin nəsil başçıları olan ilahiçilər başqa xidmətdən azad olub məbədin otaqlarında qalırdılar, çünki onlar gecə-gündüz öz işləri ilə məşğul olmalı idi.
\v 34 Bunlar nəsil şəcərələrinə görə Levililərin nəsil başçıları idi və Yerusəlimdə yaşayırdılar.
\s1 Padşah Şaulun əcdadları və nəsilləri
\r (1Saln. 8:29-38)
\p 
\v 35 Giveonun atası Yeiel Giveonda yaşayırdı və arvadının adı Maaka idi.
\v 36 İlk oğlu Avdon idi, o biriləri isə bunlar idi: Sur, Qiş, Baal, Ner, Nadav,
\v 37 Qedor, Axyo, Zəkəriyyə və Miqlot.
\v 38 Miqlotdan Şima törədi. Onlar qohumlarının yanında, Yerusəlimdə qohumları ilə birgə yaşayırdılar.
\v 39 Nerdən Qiş törədi. Qişdən Şaul törədi. Şauldan Yonatan, Malki-Şua, Avinadav və Eşbaal törədi.
\v 40 Yonatanın oğlu Merib-Baal idi. Merib-Baaldan Mikeya törədi.
\v 41 Mikeyanın oğulları: Piton, Melek, Taxrea və Axaz.
\v 42 Axazdan Yehoadda \f + \fr 9:42 \fq Yehoadda \ft – ibrani mətnində \fq Yara, \ft 1Saln. 8:36 görə \fq Yehoadda \ft yazılır.\f* törədi. Yehoaddadan Alemet, Azmavet və Zimri törədi. Zimridən Mosa törədi.
\v 43 Mosadan Bina törədi. Binanın oğlu Rafa, onun oğlu Elasa, onun oğlu Asel.
\v 44 Aselin altı oğlu var idi, onların adları belədir: Azriqam, Bokru, İsmail, Şearya, Avdiya və Xanan. Bunların hamısı Aselin oğulları idi.
\c 10
\s1 Şaulla oğullarının ölümü
\r (1Şam. 31:1-13)
\p 
\v 1 Filiştlilər İsraillilərlə döyüşdü. İsraillilər Filiştlilərin önündən qaçdılar və qırılanlar Gilboa dağında qaldı.
\v 2 Filiştlilər Şaulla oğullarını təqib edib Şaulun oğulları Yonatanı, Avinadavı və Malki-Şuanı öldürdülər.
\v 3 Döyüş Şaulun ətrafında şiddətlənəndə oxatanlar onu tapdılar və yaraladılar.
\v 4 Şaul öz silahdarına dedi: «Qılıncını çək, məni vur, yoxsa bu sünnətsizlər gəlib mənimlə əylənəcəklər». Lakin silahdarı çox qorxduğundan bunu etmək istəmədi. Ona görə də Şaul qılıncını götürüb özünü onun üstünə yıxdı.
\v 5 Şaulun öldüyünü görəndə silahdarı da özünü qılıncının üstünə yıxıb Şaulla birgə öldü.
\v 6 Beləcə Şaul və üç oğlu öldü, bütün nəsli də onunla birgə öldü.
\v 7 Dərədə olan bütün İsraillilər öz ordularının qaçdığını və Şaulla oğullarının öldüyünü görəndə şəhərlərini qoyub qaçdılar. Filiştlilər gəlib o yerlərdə yaşadı.
\p 
\v 8 Ertəsi gün Filiştlilər öldürülənləri soymaq üçün gələndə Gilboa dağında Şaulla oğullarının meyitini tapdılar.
\v 9 Onun paltarlarını soyundurdular, başını və silahlarını götürdülər, öz bütlərinin məbədinə və xalqa xoş xəbər vermək üçün Filiştlilərin ölkəsinin hər tərəfinə qasid göndərdilər.
\v 10 Şaulun silahlarını öz allahlarının məbədinə qoydular və başını Daqon məbədinə mıxladılar.
\v 11 Yaveş-Gilead əhalisi Filiştlilərin Şaula etdiklərini eşidəndə
\v 12 onların bütün igidləri qalxıb Şaulla oğullarının cəsədini götürərək Yaveşə gətirdilər. Onların sümüklərini götürüb Yaveşdə olan palıd ağacının altında basdırdılar və yeddi gün oruc tutdular.
\p 
\v 13 \x * \xo 10:13 \xt 1Şam. 13:8-14; 15:1-24 \x* \x * \xo 10:13 \xt Lev. 19:31; 20:6; 1Şam. 28:7-8 \x* Beləcə Şaul Rəbbə qarşı xainlik etdiyi üçün öldü. O, Rəbbin sözünə əməl etməyib cindara müraciət etdi,
\v 14 amma Rəbdən məsləhət istəmədi. Ona görə də Rəbb onu öldürdü və padşahlığı Yesseyin oğlu Davuda verdi.
\c 11
\s1 Davudun taxta çıxması
\r (2Şam. 5:1-10)
\p 
\v 1 Bütün İsraillilər Xevrona, Davudun yanına toplaşıb dedilər: «Bax biz sənin sümüyündən, sənin ətindənik.
\v 2 Əvvəlki vaxtlarda, Şaul padşahımız olanda da İsrailliləri yürüşlərə aparan və gətirən sən idin. Allahın Rəbb sənə demişdi ki, xalqım İsrailə sən çobanlıq edəcəksən, xalqım İsrail üzərində sən hökmdar olacaqsan».
\v 3 İsrailin bütün ağsaqqalları Xevrona, padşahın yanına gəldilər. Davud Xevronda, Rəbbin önündə onlarla əhd bağladı və onlar Şamuel vasitəsilə Rəbbin söylədiyi sözə görə Davudu İsrail üzərində padşah olmaq üçün məsh etdilər.
\s1 Davudun Yerusəlimi paytaxt şəhərinə çevirməsi
\p 
\v 4 \x * \xo 11:4 \xt Yeşua 15:63; Hak. 1:21 \x* Davud və bütün İsraillilər Yerusəlimə gəldilər. O vaxt şəhər Yevus adlanırdı və burada Yevuslular yaşayırdı.
\v 5 Onlar Davuda dedilər: «Sən buraya girə bilməzsən». Ancaq Davud indi «Davudun şəhəri» adlanan Sion qalasını aldı.
\v 6 Davud dedi: «Yevusluları hamıdan əvvəl kim məğlub etsə, rəis və ordu başçısı o olacaq». Seruya oğlu Yoav hamıdan əvvəl Yevusa qalxdı və buna görə də o, başçı oldu.
\v 7 Davud qalada məskən saldı və buna görə onu «Davudun şəhəri» adlandırdılar.
\v 8 O, qala yamacından qalanın ətrafına qədər bütün yerləri tikdi. Yoav isə şəhərin qalan hissəsini bərpa etdi.
\v 9 Davud getdikcə yüksəlirdi, çünki Ordular Rəbbi onunla idi.
\s1 Davudun igid döyüşçüləri
\r (2Şam. 23:8-39)
\p 
\v 10 Davudun igid döyüşçülərinin başçıları bütün İsraillilərlə birgə Rəbbin sözünə görə Davudu İsrail üzərində padşah etmək üçün onun padşahlığında şücaət göstərirdilər.
\v 11 Davudun igid döyüşçülərinin siyahısı belədir: «otuz igid»in başçısı olan Xakmoni oğlu Yaşoveam. O, bir hücumda üç yüz nəfəri nizəsi ilə vurub öldürdü.
\v 12 Ondan sonra «üç igid»dən biri olan Axoahlı Dodo oğlu Eleazar idi.
\v 13 Filiştlilər döyüşmək üçün Pas-Dammimdə toplaşanda o da Davudla birgə orada idi. Orada arpa əkilən bir tarla sahəsi var idi. Xalq Filiştlilərin önündən qaçdı.
\v 14 Lakin Eleazar və döyüşçüləri bu sahənin ortasında durub oranı qorudular və Filiştliləri qırdılar. Rəbb İsrailliləri xilas edib böyük zəfər qazandırdı.
\p 
\v 15 Otuz başçı arasından «üç igid» qayaya, Davudun yanına, Adullam mağarasına enib gəldi. Filiştlilərin ordusu Refaim vadisində ordugah qurmuşdu.
\v 16 Bu zaman Davud qalada idi, Filiştlilərin bir keşikçi dəstəsi isə Bet-Lexemdə idi.
\v 17 Davud həsrət çəkərək dedi: «Kaş ki biri Bet-Lexem darvazasının yanındakı quyudan mənə içmək üçün su gətirəydi!»
\v 18 Bu üç nəfər Filiştlilərin ordugahını yararaq darvazanın yanında olan Bet-Lexem quyusundan su çəkdilər və onu götürüb Davuda gətirdilər. Lakin Davud suyu içmək istəmədi və Rəbbə təqdim olaraq yerə tökdü.
\v 19 O dedi: «Allahım bunu etməkdən məni uzaq eləsin. Bu adamların qanını içəcəyəmmi? Axı canlarını təhlükəyə salaraq bu suyu gətirdilər». Buna görə də bu suyu içmək istəmədi. Bunları «üç igid» etmişdi.
\p 
\v 20 Yoavın qardaşı Avişay bu «üç igid»in başçısı idi. O, nizəsini qaldırıb üç yüz nəfəri qırdı. Buna görə də onun adı «üç igid»in adı qədər şöhrətləndi.
\v 21 Əslində «üç igid»dən ikiqat artıq şöhrəti var idi və onlara başçı oldu, lakin «üç igid» kimi deyildi.
\p 
\v 22 Yehoyada oğlu Benaya da böyük işlər görmüş igid adam idi. O, Qavseeldən gəlmişdi. Benaya iki Moavlı igidi öldürdü. O, qarlı gündə çuxura enib bir şir öldürdü.
\v 23 O həm də boyu beş qulac olan bir Misirlini öldürdü. Misirlinin əlində toxucu dəzgahının əriş ağacı boyda nizə var idi. Benaya onun üstünə dəyənəklə getdi, nizəni Misirlinin əlindən çəkib aldı və onu öz nizəsi ilə öldürdü.
\v 24 Bunları Yehoyada oğlu Benaya etdi, buna görə də onun «üç igid» qədər şöhrəti var idi.
\v 25 O, «otuz igid»dən daha şöhrətli idi, lakin «üç igid» kimi deyildi. Davud onu öz mühafizəçilərinə başçı qoydu.
\p 
\v 26 Ordunun igid döyüşçüləri bunlardır: Yoavın qardaşı Asahel, Bet-Lexemli Dodo oğlu Elxanan,
\v 27 Harorlu Şammot, Pelonlu Xeles,
\v 28 Teqoalı İqqeş oğlu İra, Anatotlu Aviezer,
\v 29 Xuşalı Sibbekay, Axoahlı İlay,
\v 30 Netofalı Mahray, Netofalı Baana oğlu Xeled,
\v 31 Binyamin övladlarından Givealı Rivay oğlu Yetay, Piratonlu Benaya,
\v 32 Qaaş vadisindən olan Xuray, Aravalı Aviel,
\v 33 Baxarumlu Azmavet, Şaalvonlu Elyaxba,
\v 34 Gizonlu Haşemin oğulları, Hararlı Şage oğlu Yonatan,
\v 35 Hararlı Sakar oğlu Axiam, Ur oğlu Elifal,
\v 36 Mekeralı Xefer, Pelonlu Axiya,
\v 37 Karmelli Xesro, Ezbay oğlu Naaray,
\v 38 Natanın qardaşı Yoel, Haqri oğlu Mivxar,
\v 39 Ammonlu Seleq, Seruya oğlu Yoavın silahdarı olan Beerotlu Naxray,
\v 40 Yeterli İra, Yeterli Qarev,
\v 41 Xetli Uriya, Axlay oğlu Zavad,
\v 42 Ruvenlilərin başçısı Ruvenli Şiza oğlu Adina və onunla birgə otuz nəfər,
\v 43 Maaka oğlu Xanan və Metenli Yehoşafat,
\v 44 Aşteratlı Uzziya, Aroerli Xotamın oğulları Şama və Yeiel,
\v 45 Şimri oğlu Yediael və qardaşı Tisli Yoxa,
\v 46 Maxavlı Eliel və Elnaamın oğulları Yerivay, Yoşavya və Moavlı Yetma,
\v 47 Eliel, Oved və Mesovalı Yaasiel.
\c 12
\s1 Davuda qoşulan döyüşçülər
\p 
\v 1 Davud, Qiş oğlu Şauldan gizlənən vaxt bir neçə nəfər Ziqlaqa, Davudun yanına gəldi. Onlar döyüşdə ona kömək edən igidlər arasında idi.
\v 2 Binyamin nəslindən, Şaulun qohumlarından olan bu adamlar ox-kamanla silahlanıb sağ və sol əllə sapanddan daş atmağı və kamanla ox atmağı bacarırdı. Onların adları belədir:
\v 3 onların başçısı olan Givealı Şemaanın oğulları, Axiezer və Yoaş, Azmavetin oğulları Yeziel və Pelet, Beraka və Anatotlu Yehu,
\v 4 «otuz igid»dən biri olan və onlara başçılıq edən Giveonlu İşmaya, Yeremya, Yaxaziel, Yoxanan, Gederalı Yozavad,
\v 5 Eluzay, Yerimot, Bealya, Şemarya, Xaruflu Şefatya,
\v 6 Qorahın nəslindən olan Elqana, İşşiya, Azarel, Yoezer, Yaşoveam,
\v 7 Qedorlu Yeroxam oğulları Yoela və Zevadya.
\p 
\v 8 Qadlılardan sipər və nizə işlədə bilən, döyüşməyi bacaran igidlər Davudun tərəfinə keçdilər və çöldəki qalaya gəldilər. Onların üzləri şir üzü kimi idi və dağlardakı ceyranlar kimi qaça bilirdilər.
\v 9 Bu başçıların adları belədir: Ezer, ikincisi Avdiya, üçüncüsü Eliav,
\v 10 dördüncüsü Mişmanna, beşincisi Yeremya,
\v 11 altıncısı Attay, yeddincisi Eliel,
\v 12 səkkizincisi Yoxanan, doqquzuncusu Elzavad,
\v 13 onuncusu Yeremya, on birincisi Makbannay.
\v 14 Bunlar Qadlılardan olan qoşun başçıları idi. Ən zəifi yüz adamın, ən güclüsü isə min adamın qabağına çıxa bilərdi.
\v 15 Onlar birinci ayda, İordan çayı bütün sahilləri boyu daşanda onu keçib vadilərdə yaşayanların hamısını şərqə və qərbə tərəf qovdular.
\p 
\v 16 Binyaminlilərdən və Yəhudalılardan da Davudun yanına, qalaya adamlar gəldi.
\v 17 Davud onları qarşılamağa çıxdı və onlara dedi: «Əgər mənə kömək üçün sülhlə gəlmisinizsə, gözüm üstə yeriniz var, ancaq zorakılıq etmədiyim halda məni düşmənlərimə təslim etmək üçün gəlmisinizsə, atalarımızın Allahı bunu görsün və hökm etsin».
\v 18 Ruh «otuz igid»in başçısı Amasayın üzərinə endi və o dedi:
\q1 «Ey Davud, biz səninləyik,
\q1 Ey Yessey oğlu, biz sənin tərəfindəyik.
\q1 Sülh, sülh olsun sənə və sənə kömək edənə,
\q1 Çünki Allahın sənə kömək edir».
\p Davud onları götürüb dəstə başçıları təyin etdi.
\p 
\v 19 Davud Filiştlilərlə birgə müharibə etmək üçün Şaulun üstünə gələndə Menaşşelilərdən də bəzisi Davudun tərəfinə keçdi, ancaq Filiştlilərə kömək etmədilər. Çünki Filiştlilərin ağaları məsləhətləşib «Davud bizim başımızı verib ağası Şaulla barışacaq» dedilər və onu geri göndərdilər.
\v 20 Davud Ziqlaqa gedərkən onun tərəfinə keçən Menaşşelilər bunlardır: Adnah, Yozavad, Yediael, Mikael, Yozavad, Elihu və Silletay. Onların hamısı Menaşşelilər arasında minbaşı idi.
\v 21 Onlar quldur dəstəsinə qarşı döyüşdə Davuda kömək etdilər, çünki onların hamısı igid adamlar idi. Sonra onlar qoşun başçıları oldu.
\v 22 Beləcə gündən-günə Davuda kömək etmək üçün onun yanına döyüşçülər gəlirdi və onun ordusu Allah ordusu qədər böyük oldu.
\s1 Davudu padşah etmək üçün gələn adamlar
\p 
\v 23 Rəbbin sözünə görə Şaulun padşahlığını Davuda vermək üçün onun yanına, Xevrona gələn silahlanmış döyüşçülərin sayı belədir:
\v 24 Yəhudalılardan altı min səkkiz yüz nəfər sipər və nizə ilə silahlanmış əsgər;
\v 25 Şimeonlulardan döyüş üçün yeddi min yüz nəfər igid döyüşçü;
\v 26 Levililərdən dörd min altı yüz nəfər;
\v 27 Harun evinin rəhbəri Yehoyada və onunla birgə üç min yeddi yüz nəfər;
\v 28 gənc və igid bir döyüşçü olan Sadoq və onun nəslindən olan iyirmi iki başçı;
\v 29 Şaulun qohumları olan Binyaminlilərin əksəriyyəti o vaxta qədər Şaul sülaləsinə sadiq qaldığı üçün onlardan yalnız üç min nəfər;
\v 30 Efrayimlilərdən iyirmi min səkkiz yüz nəfər igid və öz nəsillərinin adlı-sanlı adamları;
\v 31 Menaşşe qəbiləsinin yarısının arasından gəlib Davudu padşah etmək üçün təyin olunmuş on səkkiz min nəfər;
\v 32 İssakarlılardan dövrün vəziyyətinə görə İsrailə nə etmək lazım gəldiyini bilən adamlar – iki yüz nəfər başçı və onların əmri altında olan bütün qohumları;
\v 33 Zevulunlulardan döyüşməyi bacaran, bütün silahlarla döyüş nizamını qura bilən və sidq ürəkdən kömək edən əlli min nəfər;
\v 34 Naftalililərdən min başçı, onlarla birgə sipər və nizəsi olan otuz yeddi min nəfər;
\v 35 Danlılardan döyüş nizamını qura bilən iyirmi səkkiz min altı yüz nəfər;
\v 36 Aşerlilərdən döyüşməyi bacaran və döyüş nizamını qura bilən qırx min nəfər;
\v 37 İordan çayının o tayında yaşayan Ruvenlilərdən, Qadlılardan və Menaşşe qəbiləsinin yarısından döyüş üçün hər cür silahı olan yüz iyirmi min nəfər.
\p 
\v 38 Döyüşməyi bacaran bu könüllü döyüşçülərin hamısı Davudu bütün İsrail üzərində padşah etmək üçün Xevrona gəldi. İsraillilərin qalan hissəsi də Davudu yekdilliklə padşah etmək niyyətində idi.
\v 39 Döyüşçülər orada üç gün Davudla birgə qaldılar və yeyib-içdilər, çünki qohumları onlar üçün hazırlıq görmüşdü.
\v 40 İssakara, Zevuluna və Naftaliyə qədər yayılmış yaxınları da onlara eşşəklər, dəvələr, qatırlar və öküzlər üstündə ərzaq – yaxşı un, sıxılmış əncir, kişmiş, şərab, yağ, mal-qara və qoyun-keçi gətirmişdi. O zaman İsraildə şadlıq var idi.
\c 13
\s1 Davud Əhd sandığını Qiryat-Yearimdən köçürür
\r (2Şam. 6:1-11)
\p 
\v 1 Davud minbaşılar, yüzbaşılar və bütün başçılarla məsləhətləşdi.
\v 2 O bütün İsrail camaatına dedi: «Əgər bu iş sizə xoş gəlsə və Allahımız Rəbbin iradəsi ilə olsa, İsrailin hər tərəfində yaşayan soydaşlarımıza, onlarla birgə otlağı olan şəhərlərdə yaşayan kahinlərə və Levililərə xəbər göndərək ki, bizim yanımıza toplansınlar.
\v 3 Sonra Allahımızın sandığını yanımıza qaytaraq, axı Şaulun dövründə biz ona məhəl qoymurduq».
\v 4 Bütün camaat «belə edək» dedi, çünki bütün xalqın nəzərində bu iş doğru idi.
\p 
\v 5 \x * \xo 13:5 \xt 1Şam. 7:1-2 \x* Davud Allahın sandığını Qiryat-Yearimdən gətirmək üçün Misirdəki Şixor çayından Xamat keçidinə qədər uzanan torpaqda yaşayan bütün İsrailliləri topladı.
\v 6 \x * \xo 13:6 \xt Çıx. 25:22 \x* Davud bütün İsraillilərlə birgə «keruvlar üzərində taxt quran Rəbb» çağırılan Allahın sandığını Yəhudaya məxsus olan Baalatdan, yəni Qiryat-Yearimdən çıxartmaq üçün oraya getdi.
\v 7 Allahın sandığını bir təzə arabaya qoyub Avinadavın evindən apardılar. Arabanı Uzza və Axyo sürürdü.
\v 8 Davud və bütün İsraillilər Allahın hüzurunda həvəslə ilahi oxuyur, liralarla, çənglərlə, dəflərlə, sinclərlə və kərənaylarla çalıb oynayırdılar.
\p 
\v 9 Kidonun xırman yerindən keçəndə öküzlər büdrədi. Buna görə də Uzza əl uzadıb sandığı tutdu.
\v 10 Uzza əlini uzadaraq sandığa toxunduğu üçün Rəbb qəzəblənib onu vurdu. Beləcə Uzza orada Allahın önündə öldü.
\v 11 Davud Rəbbin Uzzanı vurmasından çox məyus oldu. O yerə bu günə qədər Peres-Uzza \f + \fr 13:11 \fq Peres-Uzza \ft – ibrani dilində \fq Uzzanın cəzası.\f* deyilir.
\v 12 Həmin gün Davud Allahdan qorxub dedi: «Allahın sandığını necə yanıma gətirə bilərəm?»
\v 13 Buna görə də Davud sandığı öz yanına – Davudun şəhərinə gətirmədi, onu yolundan döndərib Qatlı Oved-Edomun evinə qoydu.
\v 14 \x * \xo 13:14 \xt 1Saln. 26:4-5 \x* Allahın sandığı üç ay Oved-Edomun evində – onun ailəsinin yanında qaldı. Rəbb Oved-Edomun ailəsinə və ona məxsus hər şeyə bərəkət verdi.
\c 14
\s1 Davudun Yerusəlimdə padşahlıq etməsi
\r (2Şam. 5:11-16)
\p 
\v 1 Sur padşahı Xiram Davudun yanına qasidlər və ona saray tikmək üçün sidr ağacları, bənnalar və dülgərlər göndərdi.
\v 2 Onda Davud başa düşdü ki, Rəbb onu İsrail üzərində padşah kimi möhkəmləndirmiş və xalqı İsrailin xatirinə onun padşahlığını yüksəltmişdi.
\p 
\v 3 Davud Yerusəlimdə başqa arvadlar aldı, yenə oğullar və qızlar atası oldu.
\v 4 Onun Yerusəlimdə doğulan oğullarının adları belədir: Şammua, Şovav, Natan, Süleyman,
\v 5 İvxar, Elişua, Elpelet,
\v 6 Noqah, Nefeq, Yafia,
\v 7 Elişama, Beelyada və Elifelet.
\s1 İki döyüşdə Filiştlilər üzərində qələbə
\r (2Şam. 5:17-25)
\p 
\v 8 Filiştlilər eşitdilər ki, Davud bütün İsrail üzərində padşah olmaq üçün məsh edilmişdir. Onda hamısı Davudu axtarmağa çıxdı. Davud bunu eşidib onlarla qarşılaşmağa çıxdı.
\v 9 Filiştlilər gəlib Refaim vadisini talayırdılar.
\v 10 Davud Allahdan soruşdu: «Filiştlilərin qarşısına çıxımmı? Onları mənə təslim edəcəksənmi?» Rəbb ona cavab verdi: «Çıx, onları sənə təslim edəcəyəm».
\p 
\v 11 Davud Baal-Perasimə çıxıb Filiştliləri qırdı. Davud dedi: «Sellər bəndləri dağıtdığı kimi Allah da mənim əlimlə düşmənlərimi dağıtdı». Buna görə də o yerin adını Baal-Perasim\f + \fr 14:11 \fq Baal-Perasim \ft – ibrani dilində \fq dağıtma ağası.\f* qoydular.
\v 12 Filiştlilər qaçanda öz allahlarının bütlərini orada qoydular. Davudun əmri ilə bunlar odda yandırıldı.
\p 
\v 13 Filiştlilər yenə o vadini taladılar.
\v 14 Davud yenə Allahdan soruşdu və Allah ona dedi: «Onların arxasınca çıxma, onların ətrafına dolanıb balzam ağaclarının qabağında bu düşmənlərin üstünə gəl.
\v 15 Balzam ağaclarının başından addım səsləri eşidəndə döyüşə çıx, çünki o zaman Allah sənin qarşınca Filiştlilərin ordusunu məğlub etmək üçün çıxacaq».
\v 16 Davud Allahın ona buyurduğu kimi etdi və onlar Giveondan Gezerə qədər Filiştlilərin ordusunu qırdılar.
\v 17 Davudun şöhrəti bütün ölkələrə yayıldı və Rəbb onun qorxusunu bütün millətlərin ürəyinə saldı.
\c 15
\s1 Allahın sandığını Yerusəlimə gətirmək üçün hazırlıq görülür
\p 
\v 1 Davud özü üçün Davudun şəhərində evlər tikdi və Allahın sandığı üçün də yer hazırlayıb çadır qurdu.
\v 2 \x * \xo 15:2 \xt Qanun. 10:8 \x* Onda Davud dedi: «Levililərdən başqa heç kəs Allahın sandığını daşıya bilməz, çünki Rəbbin sandığını daşımaq və Ona əbədi olaraq xidmət etmək üçün Rəbb onları seçdi».
\v 3 Davud Rəbbin sandığını onun üçün hazırladığı yerə çıxarmaq üçün bütün İsrailliləri Yerusəlimə yığdı.
\v 4 Davud Harunun nəslindən olan adamları və Levililəri topladı:
\v 5 Qohat nəslindən başçı Uriel və onun yüz iyirmi nəfər qohumu;
\v 6 Merarinin nəslindən başçı Asaya və onun iki yüz iyirmi nəfər qohumu;
\v 7 Gerşon nəslindən başçı Yoel və onun yüz otuz nəfər qohumu;
\v 8 Elisafan nəslindən başçı Şemaya və onun iki yüz nəfər qohumu;
\v 9 Xevron nəslindən başçı Eliel və onun səksən nəfər qohumu;
\v 10 Uzziel nəslindən başçı Amminadav və onun yüz on iki nəfər qohumu.
\v 11 Davud kahin olan Sadoqu və Evyatarı, Levili olan Urieli, Asayanı, Yoeli, Şemayanı, Elieli və Amminadavı çağırıb
\v 12 onlara dedi: «Siz Levililər arasında nəsil başçılarısınız. Siz və qohumlarınız özünüzü təqdis edin və İsrailin Allahı Rəbbin sandığını onun üçün hazırladığım yerə çıxarın.
\v 13 Çünki keçən dəfə siz onu daşımadığınıza və lazım olduğu kimi Allahımız Rəbbi axtarmadığımıza görə O bizi cəzalandırdı».
\p 
\v 14 İsrailin Allahı Rəbbin sandığını çıxarmaq üçün kahinlərlə Levililər özlərini təqdis etdilər.
\v 15 \x * \xo 15:15 \xt Çıx. 25:14 \x* Rəbbin sözünə görə, Musanın əmr etdiyi kimi Levililər Allahın sandığının şüvüllərini çiyinlərinə qoyub onu daşıdılar.
\p 
\v 16 Davud Levililərin başçılarına əmr etdi ki, şadlıq etmək üçün öz qohumları arasından musiqi alətlərində – çənglərdə, liralarda və sinclərdə çalıb-oxuyan ilahiçilər təyin etsinlər.
\v 17 Levililər bu adamları təyin etdilər: Yoel oğlu Heman, onun qohumlarından Berekya oğlu Asəf – qohumları Merari nəslindən Quşaya oğlu Etan,
\v 18 onların köməkçisi olan Zəkəriyyə, Ben, Yaaziel, Şemiramot, Yexiel, Unni, Eliav, Benaya, Maaseya, Mattitya, Elifelehu, Miqneya, qapıçılar Oved-Edom və Yeiel.
\v 19 İlahiçilər Heman, Asəf və Etan yüksək səsli tunc sinclər,
\v 20 Zəkəriyyə, Aziel, Şemiramot, Yexiel, Unni, Eliav, Maaseya, Benaya Alamot ahəngi üzrə çənglər,
\v 21 Mattitya, Elifelehu, Miqneya, Oved-Edom, Yeiel və Azazya Şeminit ahəngi üzrə lira çalmalı idi.
\v 22 Levililərin rəhbəri Kenanya musiqiyə rəhbərlik edirdi, çünki onun bu işdə bacarığı var idi;
\v 23 Berekya və Elqana sandığın yanında qapıçı idi;
\v 24 kahinlər Şevanya, Yehoşafat, Netanel, Amasay, Zəkəriyyə, Benaya və Eliezer Allahın sandığı önündə kərənay çalırdılar; Oved-Edom və Yexiya sandığın yanında qapıçı idi.
\s1 Allahın sandığı Yerusəlimə gətirilir
\r (2Şam. 6:12-22)
\p 
\v 25 Davud, İsrail ağsaqqalları və minbaşılar şadlıq etməklə Rəbbin Əhd sandığını Oved-Edomun evindən gətirməyə getdilər.
\v 26 Rəbbin Əhd sandığını daşıyan Levililər yeddi buğa və yeddi qoç qurban kəsdilər, çünki Allah onlara kömək edirdi.
\v 27 Davud incə kətandan cübbə geyinmişdi, sandığı daşıyan bütün Levililər, ilahiçilər və ilahiçilərin rəhbəri olan Kenanya da belə geyinmişdi. Davudun əynində kətan efod da var idi.
\v 28 Bütün İsraillilər səs-küylə şeypur, kərənay, sinc çalaraq çənglərin və liraların yüksək səsi altında Rəbbin Əhd sandığını çıxartdılar.
\p 
\v 29 Rəbbin Əhd sandığı Davudun şəhərinə gətiriləndə Şaulun qızı Mikal pəncərədən baxdı, padşah Davudu tullanıb rəqs edən gördü və ürəyində ona kinayə etdi.
\c 16
\p 
\v 1 Allahın sandığını gətirib onun üçün Davudun qurduğu çadırın ortasına qoydular. Allahın önündə yandırma və ünsiyyət qurbanları təqdim etdilər.
\v 2 Davud yandırma və ünsiyyət qurbanlarını təqdim edib qurtarandan sonra Rəbbin adı ilə xalqa xeyir-dua verdi.
\v 3 O bütün İsraillilərə – kişilərin və qadınların hər birinə bir kömbə çörək, bir parça ət və bir üzüm lavaşanası payladı.
\p 
\v 4 Davud İsrailin Allahı Rəbbi çağırıb Ona şükür və həmd etmək üçün Levililərdən xidmət edən bu adamları Rəbbin sandığının önünə qoydu.
\v 5 Başçı Asəf, onun köməkçisi Zəkəriyyə, çəng və lira çalan Yeiel, Şemiramot, Yexiel, Mattitya, Eliav, Benaya, Oved-Edom və Yeiel, sincləri yüksək səslə çalan Asəf,
\v 6 Allahın Əhd sandığı önündə həmişə kərənaylar çalan kahinlər Benaya və Yaxaziel.
\v 7 O gün Davud ilk dəfə olaraq Rəbbə şükür etmək işini Asəflə yoldaşlarına tapşırdı.
\s1 Allaha həsr olunan məzmur
\r (Zəb. 105:1-15; 96:1-13; 106:47-48)
\q1 
\v 8 \x * \xo 16:8 \xt Zəb. 105:1; Yeş. 12:4 \x* «Rəbbə şükür edin, ismini çağırın,
\q1 Əməllərini xalqlar arasında elan edin!
\q1 
\v 9 Onu ilahilərlə tərənnüm edin,
\q1 Bütün xariqələrini bəyan edin!
\q1 
\v 10 Onun müqəddəs adı ilə fəxr edin,
\q1 Ey Rəbbi axtaranlar, ürəkləriniz qoy sevinsin!
\q1 
\v 11 Rəbbi, Onun qüvvətini arayın,
\q1 Daim hüzurunu axtarın.
\q1 
\v 12 Etdiyi xariqələri,
\q1 Möcüzələri, dilindən çıxan hökmləri xatırlayın,
\q1 
\v 13 Ey Onun qulu İsrail nəsli,
\q1 Ey Yaqub övladları, ey Onun seçdikləri!
\b
\q1 
\v 14 Allahımız Rəbb Odur,
\q1 Hökmü bütün yer üzərindədir.
\q1 
\v 15 \x * \xo 16:15 \xt Yar. 12:7 \x* \x * \xo 16:15 \xt Yar. 26:3 \x* Əbədi olaraq – min nəslə qədər əhdini,
\q1 Əmr etdiyi sözü,
\q1 
\v 16 İbrahimlə kəsdiyi əhdini,
\q1 İshaqa and içərək verdiyi vədini unutmaz.
\q1 
\v 17 \x * \xo 16:17 \xt Yar. 28:13 \x* Bunu qayda kimi Yaqub üçün təsdiq etdi,
\q1 Bu əbədi əhdi İsrail üçün etdi,
\q1 
\v 18 Dedi: “Övladlarının payına düşən mülk kimi
\q1 Kənan torpağını sənə verəcəyəm”.
\b
\q1 
\v 19 O zaman sayca onlar az idilər,
\q1 Azsaylı olaraq ölkədə qərib idilər.
\q1 
\v 20 Ölkədən-ölkəyə,
\q1 Məmləkətdən-məmləkətə köçürdülər.
\q1 
\v 21 \x * \xo 16:21 \xt Yar. 20:3-7 \x* Rəbb heç kimi onlara əzab verməyə qoymadı,
\q1 Onlara görə padşahları tənbeh etdi.
\q1 
\v 22 Dedi: “Məsh elədiklərimə dəyməyin,
\q1 Peyğəmbərlərimə pislik etməyin”.
\b
\q1 
\v 23 Ey bütün dünya, Rəbbə ilahi oxuyun,
\q1 Xilaskar olduğunu gündən-günə müjdələyin.
\q1 
\v 24 Ehtişamını millətlərə elan edin,
\q1 Xariqələrini bütün xalqlara bəyan edin!
\q1 
\v 25 Axı Rəbb əzəmətlidir, bol həmdə layiqdir,
\q1 O bütün allahlardan daha zəhmlidir.
\q1 
\v 26 Bütün özgə xalqların allahları bütlərdir,
\q1 Lakin göyləri yaradan Rəbdir.
\q1 
\v 27 Ehtişam və əzəmət hüzurunda olar,
\q1 Sevinclə qüdrət Onun yerindədir.
\b
\q1 
\v 28 Ey xalqların tayfaları, Rəbbə verin –
\q1 Ehtişamı, qüdrəti Rəbbə verin,
\q1 
\v 29 \x * \xo 16:29 \xt Zəb. 29:2; 96:8-9 \x* Adına layiq ehtişamı Rəbbə verin,
\q1 Hüzuruna girib təqdimlər verin.
\q1 Müqəddəslik zinəti ilə Rəbbə səcdə edin.
\q1 
\v 30 Ey bütün dünya, Onun hüzurunda lərzəyə gəlin!
\q1 O, dünyanı sarsılmaz və möhkəm qurub.
\q1 
\v 31 Göylər sevinsin, yer üzü şad olsun!
\q1 Millətlərə belə elan edin:
\q1 “Rəbb hökmranlıq edir”.
\q1 
\v 32 Dənizin və dənizdəki canlıların səsi ucalsın,
\q1 Çöllər və çöldə yaşayanlar fərəhlənsin,
\q1 
\v 33 Meşədəki bütün ağaclar mədh söyləsin
\q1 Rəbbin hüzurunda!
\q1 O, dünyanın hökmünü vermək üçün gəlir.
\b
\q1 
\v 34 \x * \xo 16:34 \xt 2Saln. 5:13; 7:3; Ezra 3:11; Zəb. 100:5; 106:1; 107:1; 118:1; 136:1; Yer. 33:11 \x*
\q1 Rəbbə şükür edin, ona görə ki yaxşıdır,
\q1 Çünki məhəbbəti əbədidir.
\q1 
\v 35 Deyin: “Ey qurtarıcımız Allah, bizi qurtar,
\q1 Bizi millətlərin arasından topla və azad et.
\q1 Müqəddəs isminə şükür edək,
\q1 Biz fəxrlə Sənə həmd söyləyək”.
\q1 
\v 36 Alqış olsun İsrailin Allahı Rəbbə
\q1 Əzəldən sonsuza qədər!»
\p Bütün xalq «Amin!» söylədi və Rəbbə həmd etdi.
\s1 Rəbbin Əhd sandığının önündə və Giveonda xidmət edənlər
\p 
\v 37 Davud orada – Rəbbin Əhd sandığının önündə bu adamları qoydu: hər günün işinə görə sandığın önündə daim xidmət edən Asəf və onun yoldaşları,
\v 38 Oved-Edom və onun altmış səkkiz nəfər yoldaşı, qapıçılar Yedutun oğlu Oved-Edom və Xosa.
\v 39 O, Giveonda olan səcdəgahda, Rəbbin məskəni önündə, kahin Sadoqu və onun kahin yoldaşlarını qoydu ki,
\v 40 Rəbbin İsrailə əmr etdiyi Qanunda yazılanların hamısına görə daim səhər və axşam Rəbbə yandırma qurbanları üçün düzəldilən qurbangahda Ona yandırma qurbanları versinlər.
\v 41 Onlarla birgə Hemanı, Yedutunu və adları çəkilən başqa seçilmiş adamları təyin etdi ki, Rəbbə şükür etsinlər, çünki Onun məhəbbəti əbədidir.
\v 42 Heman, Yedutun və həmin adamların əlində Allaha yüksək səslə musiqi çalmaq üçün kərənaylar, sinclər və başqa alətlər var idi. Yedutunun oğulları isə qapıçı oldular.
\v 43 \x * \xo 16:43 \xt 2Şam. 6:19-20 \x* Bütün xalq – hər kəs evinə getdi, Davud da öz evinə xeyir-dua vermək üçün geri qayıtdı.
\c 17
\s1 Allahın Davuda vədi
\r (2Şam. 7:1-17)
\p 
\v 1 Davud sarayında yaşayan vaxt peyğəmbər Natana dedi: «Mən sidr ağacından tikilən bir sarayda yaşayıram, Rəbbin Əhd sandığı isə çadır altındadır».
\v 2 Natan Davuda dedi: «Ürəyindəki niyyəti həyata keçir, çünki Allah səninlədir».
\p 
\v 3 Lakin gecə Natana Allahın bu sözü nazil oldu:
\v 4 «Get qulum Davuda söylə ki, Rəbb belə deyir: “Yaşamaq üçün Mənə evi sən tikməyəcəksən,
\v 5 çünki İsraili çıxartdığım gündən bu günə qədər heç bir evdə yaşamadım, yalnız çadırdan çadıra, məskəndən məskənə gəzdim.
\v 6 Bütün İsraillilərlə birgə gəzdiyim yerlərdə xalqımın qayğısına qalmağı buyurduğum İsrail hakimlərindən birinə ‹Niyə Mənə sidr ağacından bir ev tikmədiniz?› deyə bir söz söyləmişəmmi?”
\v 7 İndi qulum Davuda söylə ki, Ordular Rəbbi belə deyir: “Mən səni otlaqlarda qoyun otararkən götürüb xalqım İsrailə hökmdar etdim.
\v 8 Getdiyin hər yerdə səninlə oldum, qarşından bütün düşmənlərini qırıb atdım. İndi isə adını dünyadakı böyüklərin adı kimi məşhur edəcəyəm.
\v 9 Xalqım İsrail üçün bir yer təyin edəcəyəm, o kök atıb bu yerdə yaşayacaq və bir daha sarsılmayacaq. Şər adamlar əvvəllər – xalqım İsraillilərə hakimlər təyin etdiyim günlərdən bəri etdikləri kimi yenə də onu qırıb-çatmayacaq.
\v 10 Bütün düşmənlərini əzəcəyəm. Sənə bildirirəm ki, Rəbb sənə bir ev tikəcək.
\v 11 \x * \xo 17:11 \xt Zəb. 132:11; Həv. 2:30 \x* Ömrün başa çatıb ataların kimi dünyadan getdiyin zaman yerinə sənin övladını – oğullarından birini çıxaracağam və onun padşahlığını möhkəmləndirəcəyəm.
\v 12 O Mənim üçün ev tikəcək və Mən onun taxtını əbədi möhkəm edəcəyəm.
\v 13 \x * \xo 17:13 \xt 2Şam. 7:14; 2Kor. 6:18; İbr. 1:5; Vəhy 21:7 \x* Mən ona Ata, o isə Mənə oğul olacaq. Lütfümü səndən əvvəl olan adamdan geri aldığım kimi ondan geri almayacağam.
\v 14 Onu Öz evimin və padşahlığımın üzərinə əbədi olaraq qoyacağam, onun taxtı əbədi möhkəm qalacaq”».
\v 15 Natan Davuda bütün bu sözləri və bütün bu vəhyi nəql etdi.
\s1 Davudun duası
\r (2Şam. 7:18-29)
\p 
\v 16 Padşah Davud içəri keçib Rəbbin önündə diz çökərək dedi: «Ya Rəbb Allah, mən kiməm və nəslim kimdir ki, Sən məni bu yerə çıxartdın?
\v 17 Ey Allah, Sənin gözündə bu da kiçik göründü, hələ bu qulunun nəslinin gələcəyi haqqında xəbər verdin. Mənə yüksək bir adam kimi baxırsan, ya Rəbb Allah!
\v 18 Bu quluna izzət verdiyin üçün Davud Sənə daha nə deyə bilər? Sən ki bu qulunu tanıyırsan.
\v 19 Ya Rəbb, qulundan ötrü və Öz istəyinə görə bu böyük işlərin hamısını etdin ki, bütün əzəmətini göstərəsən.
\v 20 Ya Rəbb, qulaqlarımızla eşitdiklərimizin hamısına görə Sənin kimisi heç yoxdur və Səndən başqa Allah yoxdur.
\v 21 Yer üzərində xalqın İsrail kimi bir millət varmı? Ey Allah, Sən onu Özünə xalq etmək üçün satın almağa getdin. Sən Misirdən satın aldığın xalqının önündən millətləri qovaraq böyük və xariqəli işlərlə Özünə şöhrət qazandın.
\v 22 Əbədi olaraq xalqın İsraili Özün üçün xalq olaraq müəyyən etdin və Sən, ya Rəbb, onların Allahı oldun.
\p 
\v 23 İndi isə, ya Rəbb, bu qulun və onun nəsli haqqında söylədiyin söz əbədi olaraq yerinə yetsin və dediyinə əməl et.
\v 24 Qoy adın əbədi olaraq qalsın və izzətlənsin, “İsrailin Allahı Ordular Rəbbi İsraili saxlayan Allahdır” desinlər. Qulun Davudun nəsli də Sənin önündə möhkəm qalsın.
\v 25 Çünki, Sən ey Allahım, “sənə ev tikəcəyəm” deyərək bunu quluna çatdırdın və buna görə qulun önündə dua etməyə cəsarət tapdı.
\v 26 Ya Rəbb, Sən Allahsan və indi də quluna bu yaxşı şeyi vəd etdin.
\v 27 Əbədi olaraq Sənin önündə olsun deyə bu qulunun nəslinə xeyir-dua vermək Sənə xoş göründü. Sən, ya Rəbb, ona xeyir-dua verdiyin üçün o əbədi olaraq xeyir-dua almışdır».
\c 18
\s1 Davudun qələbələri
\r (2Şam. 8:1-18)
\p 
\v 1 Bundan sonra Davud Filiştliləri məğlub edib özünə tabe etdi və Qatı, onun qəsəbələrini Filiştlilərdən aldı.
\v 2 O, Moavlıları da məğlub etdi və Moavlılar Davuda tabe olub xərac verdilər.
\p 
\v 3 Sova padşahı Hadadezer Fərat çayının ətrafındakı yerlərdə hakimiyyətini bərpa etməyə gedəndə Davud Xamatda onu məğlub etdi.
\v 4 O, Hadadezerin min döyüş arabasını aldı, yeddi min süvarisini, iyirmi min piyada əsgərini əsir etdi və atlardan yüzə qədərini döyüş arabası üçün saxlayaraq qalan atların ayaq vətərini kəsdi.
\v 5 Dəməşqdə yaşayan Aramlılar Sova padşahı Hadadezerə kömək etməyə gələndə Davud onlardan iyirmi iki min nəfəri qırdı.
\v 6 Davud Dəməşq Aramına hərbi dəstələr yerləşdirdi və Aramlılar ona tabe olub xərac verdilər. Rəbb Davuda getdiyi hər yerdə zəfər qazandırdı.
\v 7 O, Hadadezerin zabitlərinin gəzdirdiyi qızıl qalxanları götürüb Yerusəlimə gətirdi.
\v 8 \x * \xo 18:8 \xt 1Pad. 7:40-47; 2Saln. 4:11-18 \x* Davud Hadadezerin şəhərləri olan Tivxatdan və Kundan çoxlu tunc aldı. Sonralar Süleyman ondan tunc hovuzu, sütunları və tunc qabları düzəltdi.
\p 
\v 9 Xamat padşahı Tou eşitdi ki, Davud Sova padşahı Hadadezerin bütün ordusunu məğlub edib.
\v 10 O, Davudu salamlamaq və Hadadezeri döyüşdə məğlub etdiyinə görə təbrik etmək üçün oğlu Hadoramı onun yanına göndərdi, çünki Hadadezer Tou ilə həmişə müharibə etmişdi. Hadoram hər cür qızıl-gümüş və tunc əşyalar gətirdi.
\v 11 Padşah Davud bütün millətlərdən – Edomlulardan, Moavlılardan, Ammonlulardan, Filiştlilərdən və Amaleqlilərdən alıb gətirdiyi qızıl-gümüşlə birgə bunları da Rəbbə həsr etdi.
\p 
\v 12 \x * \xo 18:12 \xt Zəb. 60 başlıq \x* Seruya oğlu Avişay Duz vadisində Edomlulardan on səkkiz min nəfəri qırdı.
\v 13 O, Edoma hərbi dəstələr yerləşdirdi və bütün Edomlular Davuda tabe oldular. Rəbb Davuda getdiyi hər yerdə zəfər qazandırdı.
\s1 Davudun əyanları
\p 
\v 14 Davud bütün İsrailin padşahı oldu. O bütün xalqına ədalət və salehliklə hökmranlıq edirdi.
\p 
\v 15 Seruya oğlu Yoav ordu başçısı idi; Axilud oğlu Yehoşafat salnaməçi idi;
\v 16 Axituv oğlu Sadoq və Evyatar oğlu Avimelek kahin idi; Şavşa mirzə idi;
\v 17 Yehoyada oğlu Benaya Keretlilər və Peletlilərin başçısı idi; Davudun oğulları padşahın baş məmurları idi.
\c 19
\s1 Ammonlular və Aramlılar üzərində qələbə
\r (2Şam. 10:1-19)
\p 
\v 1 Bir müddət sonra Ammonluların padşahı Naxaş öldü və yerinə oğlu padşah oldu.
\v 2 Davud dedi: «Naxaşın oğlu Xanuna yaxşılıq edəcəyəm, çünki atası mənə yaxşılıq etdi». Davud qasidlər göndərdi ki, atasına görə Xanuna başsağlığı versin. Lakin Davudun adamları Ammon ölkəsinə, onun yanına gələndə
\v 3 Ammonluların başçıları Xanuna dedilər: «Sən elə bilirsən ki, Davud bu başsağlığı verən adamları sənin atana hörməti olduğu üçün göndərib? Bəlkə onun adamları bu torpaqdan keçməklə onu yoxlayıb öyrənmək, sonra da ələ keçirmək üçün sənin yanına gəliblər».
\v 4 Xanun Davudun adamlarını tutub saqqallarını qırxdıraraq paltarlarını oturacaq yerinə qədər aşağıdan kəsdirdi və onları geri göndərdi.
\v 5 Bu adamlar barədə Davuda xəbər çatdı. Davud onları qarşılamaq üçün qasidlər göndərdi, çünki bu adamlar çox utanırdı. Padşah dedi: «Saqqalınız çıxana qədər Yerixoda qalın, sonra qayıdarsınız».
\p 
\v 6 Xanun və Ammonlular Davudun yanında nifrət qazandıqlarını görəndə Aram-Naharayimdən, Aram-Maakadan, Sovadan özlərinə muzdla döyüş arabaları və atlılar tutmaq üçün min talant gümüş göndərdilər.
\v 7 Özləri üçün otuz iki min araba, Maaka padşahını və onun qoşunlarını muzdla tutdular, onlar da gəlib Medvanın önündə ordugah qurdular. Ammonlular öz şəhərlərindən yığılıb döyüşə gəldilər.
\v 8 Davud bunu eşidib Yoavla bütün igidlər ordusunu onların üstünə göndərdi.
\v 9 Ammonlular çıxıb şəhərin girişində, gələn padşahlar isə ayrıca çöldə döyüş üçün düzüldü.
\p 
\v 10 Yoav öndən və arxadan düşmənlərin ona qarşı düzüldüklərini görəndə bütün İsrailin seçmə döyüşçülərindən bəzisini ayırıb Aramlılara qarşı düzdü.
\v 11 Xalqın qalan hissəsinə isə qardaşı Avişayı başçı qoydu və onlar Ammonluların qarşısında düzüldü.
\v 12 Yoav dedi: «Əgər Aramlılar məndən güclü çıxarsa, sən mənə kömək edərsən, əgər Ammonlular səndən güclü çıxarsa, mən sənə kömək edərəm.
\v 13 Möhkəm ol. Gəl xalqımız naminə və Allahımızın şəhərləri naminə igidlik göstərək. Qoy Rəbb gözündə xoş olanı etsin».
\v 14 Yoav və yanındakı qoşun vuruşmaq üçün Aramlıların qarşısına yaxınlaşdı. Aramlılar Yoavın önündən qaçdı.
\v 15 Ammonlular da Aramlıların qaçdığını görəndə Yoavın qardaşı Avişayın qabağından qaçıb şəhərə girdilər. Sonra Yoav Yerusəlimə gəldi.
\p 
\v 16 Aramlılar İsraillilərin önündə məğlub olduqlarını görəndə qasidlər göndərib Fərat çayının o tayındakı Aramlıları döyüşə çıxartdılar. Onların başçısı Hadadezerin ordu başçısı Şofak idi.
\v 17 Bunu Davuda xəbər verdilər. O bütün İsrailliləri toplayıb İordan çayını keçdi və Aramlıların qarşısına gəlib qoşununu onlara qarşı düzdü. Davud öz qoşununu Aramlıların önünə çıxartdı və Aramlılar onunla vuruşdu.
\v 18 Aramlılar İsraillilərin qabağından qaçdı. Davud Aramlılardan yeddi min araba döyüşçüsünü və qırx min piyadanı qırdı, ordu başçısı Şofakı da öldürdü.
\v 19 Hadadezerin adamları İsraillilərin önündə məğlub olduqlarını görəndə Davudla sülh bağladılar və ona tabe oldular. Aramlılar bir daha Ammonlulara kömək etmək istəmədi.
\c 20
\s1 Ammonluların darmadağın edilməsi
\r (2Şam. 11:1; 12:26-31)
\p 
\v 1 \x * \xo 20:1 \xt 2Şam. 11:1 \x* Bahar gələndə padşahlar müharibəyə çıxan vaxt Yoav ordusunu səfərə çıxardı. O, Ammonluların ölkəsini viran etdi və gəlib Rabbanı mühasirəyə aldı. Davud isə Yerusəlimdə qaldı. Yoav Rabbanı vurub dağıtdı.
\v 2 Davud onların padşahının başından tacını götürdü. Tac qızıldan olub çəkisi bir talant idi. Onun üzərində qiymətli daş var idi. Bu tac Davudun başına qoyuldu. Davud bu şəhərdən çoxlu qənimət apardı.
\v 3 O, şəhərdə olan xalqı köçürdü və əllərinə mişar, dəmir, külüng və balta verib ağır işlərə qoydu. Davud Ammonluların bütün şəhərlərində belə edəndən sonra xalqın hamısı ilə birgə Yerusəlimə qayıtdı.
\s1 İsraillilərin Filiştli nəhənglərə qarşı döyüşü
\r (2Şam. 21:15-22)
\p 
\v 4 Bundan sonra Gezerdə Filiştlilərlə döyüş oldu. O zaman Xuşalı Sibbekay Rafa övladlarından \f + \fr 20:4 \fq Rafa övladları \ft – nəhəng adamlar.\f* Sippayı öldürdü. Beləcə Filiştlilər tabe oldu.
\v 5 \x * \xo 20:5 \xt 1Şam. 17:4-7 \x* Filiştlilərlə daha bir döyüşdə Yair oğlu Elxanan Qatlı Qolyatın qardaşı Laxmini öldürdü. Onun əlindəki nizənin sapı toxucu dəzgahının əriş ağacı boyda idi.
\v 6 Qatda bir də döyüş oldu. Orada Rafa övladlarından digər ucaboy bir adam var idi. Bu adamın əlləri və ayaqları altı barmaqlı idi və cəmi iyirmi dörd barmağı var idi.
\v 7 O, İsrailə meydan oxudu. Onu Davudun qardaşı Şimanın oğlu Yonatan öldürdü.
\v 8 Bunlar Rafa övladlarından olub Qatda doğulmuşdu. Onlar Davudun və onun adamlarının əli ilə qırıldı.
\c 21
\s1 Davudun xalqı siyahıya alması
\r (2Şam. 24:1-25)
\p 
\v 1 Şeytan İsraillilərə qarşı qalxdı və Davudu İsrailliləri siyahıya almağa təhrik etdi.
\v 2 Davud Yoava və xalqın başçılarına dedi: «Gedin, Beer-Şevadan Dana qədər İsrailliləri siyahıya alın və siyahını mənə gətirin ki, onların sayını bilim».
\v 3 Yoav dedi: «Rəbb xalqını olduğundan yüz qat artıq etsin. Ancaq, ağam padşah, onların hamısı ağamın qulları deyilmi? Nə üçün ağam bunu istəyir? Nə üçün bu, İsrailə cəza gətirsin?»
\v 4 Lakin padşahın sözü Yoava üstün gəldi. Yoav çıxıb bütün İsraili dolaşdı və sonra Yerusəlimə gəldi.
\v 5 O, xalqın siyahısını Davuda verdi. Bütün İsraildə qılınc çəkən bir milyon yüz min nəfər, Yəhudada isə qılınc çəkən dörd yüz yetmiş min nəfər adam var idi.
\v 6 Ancaq Yoav onların arasında Levililəri və Binyaminliləri siyahıya almadı, çünki padşahın sözündən acığı gəlmişdi.
\p 
\v 7 Bu iş Allahın gözündə pis oldu və O, İsrailə cəza verdi.
\v 8 Davud Allaha dedi: «Bu işi görməklə böyük günah etdim. İndi isə, yalvarıram, bu qulunun təqsirindən keç, çünki çox ağılsızlıq etmişəm».
\v 9 Rəbb Davudun görücüsü Qada dedi:
\v 10 «Get, Davuda söylə ki, Rəbb belə deyir: “Sənə üç şey təklif edirəm, özün üçün bunların birini seç ki, sənə edim”».
\v 11 Qad Davudun yanına gəlib ona dedi: «Rəbb belə deyir: “Özün üçün seç:
\v 12 ya üç il aclıq olacaq ya üç ay düşmənlərin səni təqib edəcək və onların qılıncı səni vuracaq ya da üç gün Rəbbin qılıncı olan vəba ölkənin üzərinə gələcək və Rəbbin mələyi İsrailliləri hər yerdə qıracaq”. İndi qərar ver görək məni göndərənə nə cavab verim?»
\v 13 Davud Qada dedi: «Mənim üçün çox çətindir. İnsan əlinə düşüncə qoy Rəbbin əlinə düşüm, çünki Onun rəhmi çox böyükdür».
\p 
\v 14 Beləcə Rəbb İsrail üzərinə vəba göndərdi və İsraillilərdən yetmiş min nəfər həlak oldu.
\v 15 Allah Yerusəlimin əhalisini həlak etmək üçün bir mələk göndərdi. Mələk onları həlak edərkən Rəbb bunu görüb bu bəlaya görə təəssüfləndi və həlak edən mələyə dedi: «Bəsdir, əl saxla!» Rəbbin mələyi Yevuslu Ornanın xırmanının yanında dayandı.
\v 16 Davud başını qaldırıb Rəbbin mələyini gördü. Mələk əlindəki sıyrılmış qılıncı Yerusəlimin üzərinə uzadaraq yerlə göyün arasında dayanmışdı. Çula bürünən Davud və ağsaqqallar üzüstə yerə qapandı.
\v 17 Davud Allaha dedi: «Xalqı siyahıya almağı əmr edən mən deyildimmi? Mən günah etdim və həqiqətən, pis iş gördüm, bəs bu yazıq xalq nə edib? Ya Rəbb Allahım, qoy Sənin əlin mənim və ata nəslimin əleyhinə qalxsın, amma Öz xalqına vəba göndərmə».
\s1 Davud Ornanın xırman yerində qurbangah düzəldir
\p 
\v 18 Rəbbin mələyi Davuda söyləmək üçün Qada dedi: «Qoy Davud çıxıb Yevuslu Ornanın xırmanında Rəbbə bir qurbangah düzəltsin».
\v 19 Rəbbin adı ilə Qadın söylədiyi sözə görə Davud çıxdı.
\v 20 Ornan geri dönüb mələyi gördü. Onunla birgə olan dörd oğlu gizləndi, Ornan isə yenə də buğda döyürdü.
\v 21 Davud Ornanın yanına gələndə Ornan baxıb Davudu gördü, xırmandan çıxdı və ona yerə qədər təzim etdi.
\v 22 Davud Ornana dedi: «Bu xırmanını mənə ver ki, burada Rəbb üçün qurbangah tikim, onu mənə tam dəyərinə sat. Beləcə xalqın üzərinə gələn vəba dayansın».
\v 23 Ornan Davuda dedi: «Götür, havayı sənin olsun, ağam padşah gözündə xoş olanı etsin. Mən yandırma qurbanı olaraq öküzləri, odun yerinə vəlləri və taxıl təqdimi kimi buğdanı verirəm, bunların hamısını verirəm».
\v 24 Padşah Davud Ornana dedi: «Yox, mütləq tam dəyərinə satın alacağam, çünki sənin malını Rəbb üçün götürmərəm, havayı malı yandırma qurbanı vermərəm».
\v 25 Buna görə də Davud bu yer üçün Ornana çəkisi altı yüz şekel qızıl verdi.
\v 26 Davud orada Rəbbə bir qurbangah düzəldib yandırma qurbanları və ünsiyyət qurbanları təqdim etdi. O, Rəbbi çağırdı, Rəbb də yandırma qurbanlarının gətirildiyi qurbangaha göydən od göndərib ona cavab verdi.
\v 27 Rəbb mələyə əmr etdi, o da qılıncını qınına qoydu.
\p 
\v 28 Davud Yevuslu Ornanın xırmanında Rəbbin ona cavab verdiyini gördükdə orada qurban kəsdi.
\v 29 Musanın səhrada düzəltdiyi Rəbbin məskəni və yandırma qurbanları üçün düzəldilən qurbangah o vaxt Giveondakı səcdəgahda idi.
\v 30 Ancaq Davud Allahdan soruşmaq üçün Onun hüzuruna gedə bilmədi, çünki Rəbbin mələyinin qılıncından qorxurdu.
\c 22
\p 
\v 1 Buna görə də Davud dedi: «Rəbb Allahın evi burada olsun, burada İsrail üçün yandırma qurbanları gətirilən qurbangah da olsun».
\s1 Davud məbədin tikilməsinə hazırlıq görür
\p 
\v 2 Davud İsrail torpağında olan qəriblərin yığılmasını əmr etdi və Allah evinin tikilişinə yonma daşlar düzəltmək üçün onların arasından daşyonanlar təyin etdi.
\v 3 Davud qapı taylarının mıxları və rəzələri üçün çoxlu dəmir hazırladı. Həmçinin çoxluğuna görə çəkiyə gəlməz tunc hazırladı
\v 4 və saysız-hesabsız sidr ağacları da yığdı. Çünki Sidonlular və Surlular Davuda çoxlu sidr ağacları gətirmişdi.
\v 5 Davud öz-özünə dedi: «Oğlum Süleyman cavandır, təcrübəsi yoxdur, Rəbbə tikiləcək məbəd isə əzəmətli olmalı, şöhrəti və izzəti bütün ölkələrə yayılmalıdır. Buna görə onun üçün hazırlıq görməliyəm». Beləliklə, Davud ölümündən əvvəl çoxlu hazırlıq işləri gördü.
\s1 Davud Süleymana məbəd tikməyi vəsiyyət edir
\p 
\v 6 Davud oğlu Süleymanı çağırdı və İsrailin Allahı Rəbb üçün məbəd tikməyi ona vəsiyyət etdi.
\v 7 \x * \xo 22:7 \xt 2Şam. 7:1-16; 1Saln. 17:1-14 \x* Davud Süleymana dedi: «Ey oğlum, mənim ürəyimdə Allahım Rəbbin adına məbəd tikmək istəyi vardı.
\v 8 Ancaq mənə Rəbbin bu sözü nazil oldu: “Sən çoxlu qan tökdün və böyük müharibələr etdin. Sən Mənim adıma məbəd tikməyəcəksən, çünki önümdə yerə çoxlu qan tökmüsən.
\v 9 Sənin bir oğlun olacaq. O, dinc yaşayacaq, onu ətrafındakı bütün düşmənlərindən qoruyacağam. Onun adı Süleyman olacaq. Onun dövründə İsrailə sülh və əmin-amanlıq verəcəyəm.
\v 10 O Mənim adıma məbəd tikəcək. O Mənə oğul olacaq, Mən də ona ata olacağam. Onun padşahlıq taxtını İsrail üzərində əbədi olaraq möhkəmlədəcəyəm”.
\v 11 İndi, oğlum, qoy Rəbb sənə yar olsun, sənin barəndə söylədiyi kimi Allahın Rəbbin məbədini uğurla tikəsən.
\v 12 Ancaq Rəbb səni İsrailə hökm etmək üçün qoyanda sənə müdriklik və həssaslıq versin ki, Allahın Rəbbin verdiyi Qanuna əməl edəsən.
\v 13 \x * \xo 22:13 \xt Yeşua 1:6-9 \x* Əgər İsrail barədə Rəbbin Musaya əmr etdiyi qaydalara və hökmlərə əməl etsən, uğur qazanacaqsan. Möhkəm və cəsarətli ol, qorxma və ruhdan düşmə.
\v 14 Bax böyük cəhdlə Rəbbin məbədi üçün yüz min talant qızıl, bir milyon talant gümüş, çox olduğu üçün çəkiyə gəlməz tunc və dəmir yığdım, həmçinin ağaclar və daşlar hazırladım. Sən də bunların üstünə əlavə et.
\v 15 Sənin yanında çoxlu işçilər – daşyonanlar, bənnalar, dülgərlər,
\v 16 hər cür qızıl, gümüş, tunc və dəmir işini bacaran ustalar var. Onların sayı-hesabı yoxdur. Buyur, işə başla, Rəbb sənə yar olsun».
\p 
\v 17 Davud İsrailin bütün başçılarına oğlu Süleymana kömək etməyi vəsiyyət edib dedi:
\v 18 «Allahınız Rəbb sizinlə deyilmi? O, ölkədə yaşayanları mənim ixtiyarıma verməklə sizə hər tərəfdən dinclik vermədimi? Ölkə Rəbbə və Onun xalqına tabe edilib.
\v 19 İndi ürəyinizi və canınızı Allahınız Rəbbi axtarmağa yönəldin. Rəbb Allahın Müqəddəs məkanını tikməyə başlayın ki, Rəbbin Əhd sandığını və Allahın müqəddəs əşyalarını Rəbbin adına tikilmiş məbədə gətirəsiniz».
\c 23
\p 
\v 1 \x * \xo 23:1 \xt 1Pad. 1:1-40 \x* Davud qocalıb yaşa dolanda oğlu Süleymanı İsrail üzərində padşah etdi.
\s1 Levililər və onların vəzifələri
\p 
\v 2 Davud İsrailin bütün başçılarını, kahinləri və Levililəri topladı.
\v 3 Otuz yaşında və bundan yuxarı yaşda olan Levililər siyahıya alındı. Onlardan kişilərin sayı otuz səkkiz min nəfər idi.
\v 4 Bunlardan iyirmi dörd min nəfəri Rəbbin məbədində xidmət üçün qoyuldu. Altı min məmur və hakim,
\v 5 dörd mini isə qapıçı oldu. Dörd min nəfər Davudun bu məqsədlə düzəltdiyi musiqi alətləri ilə Rəbbi həmd etmək üçün qoyuldu.
\v 6 Levinin Gerşon, Qohat və Merari nəsillərinə görə Davud onları bölmələrə ayırdı.
\p 
\v 7 Gerşonun nəslindən: Ladan və Şimey.
\v 8 Ladanın oğulları: ilk oğlu Yexiel, Zetam və Yoel – üç nəfər.
\v 9 Şimeyin oğulları: Şelomit, Xaziel və Haran – üç nəfər. Bunlar Ladanın nəsil başçıları idi.
\v 10 Şimeyin oğulları: Yaxat, Ziza, Yeuş və Beria. Bu dördü Şimeyin oğulları idi.
\v 11 Yaxat ilk oğlu, Ziza isə ikincisi idi. Ancaq Yeuşun və Berianın oğulları çox deyildi. Onlar birlikdə bir nəsil kimi siyahıya alındı.
\p 
\v 12 Qohatın oğulları: Amram, İshar, Xevron və Uzziel – dörd nəfər.
\v 13 \x * \xo 23:13 \xt Çıx. 28:1 \x* Amramın oğulları: Harun və Musa. Harun ən müqəddəs şeyləri təqdis etmək üçün təyin olundu. Onun nəsli əbədi olaraq Rəbbin önündə buxur yandırmaq, Rəbbə xidmət etmək və həmişə Onun adı ilə xeyir-dua vermək üçün təyin olundu.
\v 14 Allah adamı Musaya gəlincə, onun nəsli Levi qəbiləsi arasında siyahıya alındı.
\v 15 Musanın oğulları: Gerşom və Eliezer.
\v 16 Gerşomun ilk oğlu Şevuel.
\v 17 Eliezerin ilk oğlu Rexavya. Eliezerin başqa oğlu yox idi, amma Rexavyanın oğulları olduqca çox idi.
\v 18 İsharın ilk oğlu Şelomit.
\v 19 Xevronun oğulları: ilk oğlu Yeriya, ikincisi Amarya, üçüncüsü Yaxaziel və dördüncüsü Yeqameam.
\v 20 Uzzielin oğulları: ilk oğlu Mikeya və ikincisi İşşiya.
\p 
\v 21 Merarinin oğulları: Maxli və Muşi. Maxlinin oğulları: Eleazar və Qiş.
\v 22 Eleazar öləndə onun oğlu yox idi, ancaq qızları var idi və əmiləri Qişin oğulları onları arvad aldılar.
\v 23 Muşinin oğulları: Maxli, Eder və Yeremot – üç nəfər.
\v 24 Bunlar adları ilə siyahıya düşən Levililərin ailə başçılarıdır. Rəbbin məbədinin xidmət işini görən Levililər iyirmi yaşında və bundan yuxarı yaşda idi.
\p 
\v 25 Davud demişdi: «İsrailin Allahı Rəbb xalqına dinclik vermişdir və əbədi olaraq Yerusəlimdə məskən salacaq.
\v 26 \x * \xo 23:26 \xt Qanun. 10:8 \x* Levililər müqəddəs məskəni və onun bütün xidmət əşyalarını daha daşımayacaq».
\v 27 Buna görə də Davudun son sözlərinə görə iyirmi yaşında və bundan yuxarı yaşda olan Levililər siyahıya alındı.
\v 28 \x * \xo 23:28 \xt Say. 3:5-9 \x* Onların vəzifəsi Rəbbin məbədində Harunun nəslindən olan kahinlərin yanında dayanıb bu xidmət işlərini görmək idi: həyətlərə və otaqlara baxmaq, bütün müqəddəs əşyaları təmizləmək, Allahın evində xidmət etmək,
\v 29 təqdim çörəklərinə, təqdim üçün verilən una, mayasız qoğallara, onların yoğrulmasına və bişməsinə, hər cür ölçü qablarına baxmaq,
\v 30 hər səhər durub Rəbbə şükür və həmd etmək, hər axşam da elə etmək,
\v 31 Şənbə günlərində, Təzə Ay mərasimlərində, bayramlarda əmr edilən qaydalara görə düzgün sayda daim Rəbbin önündə yandırma qurbanları təqdim etmək.
\v 32 Beləcə Levililər Hüzur çadırının, Müqəddəs yerin xidmətlərinə, Rəbbin evinin xidmətlərində qohumları Harun nəslinə xidmət etməyə cavabdeh idilər.
\c 24
\s1 Kahinlər və onların xidmət qaydaları
\p 
\v 1 Harun nəslinin bölükləri bunlardır. Harunun oğulları: Nadav, Avihu, Eleazar və İtamar.
\v 2 \x * \xo 24:2 \xt Lev. 10:1-2 \x* Ancaq Nadav və Avihu atalarından əvvəl öldü və oğulları da yox idi. Buna görə də Eleazar və İtamar kahin oldu.
\v 3 Davud, Eleazar nəslindən Sadoq və İtamar nəslindən Aximelek onları xidmət işlərinə görə növbələrə ayırdı.
\v 4 Eleazar nəsli arasında İtamar nəslindən daha çox nəsil başçısı tapıldı. Onlar belə ayrıldı: Eleazar nəslindən nəsil başçısı on altı nəfər, İtamar nəslindən nəsil başçısı səkkiz nəfər.
\v 5 Beləcə onlar püşklə eyni qayda ilə ayrıldı, çünki həm Eleazar nəslindən, həm də İtamar nəslindən Müqəddəs yerdə və Allahın önündə durmaq üçün başçılar var idi.
\v 6 Padşahın, rəislərin, kahin Sadoqun, Evyatar oğlu Aximelekin, kahinlərin və Levililərin nəsil başçılarının önündə Levili mirzə Netanel oğlu Şemaya onları qeydə aldı. Bir nəsil Eleazar üçün, o biri İtamar üçün alındı.
\p 
\v 7 Birinci püşk Yehoyarivə, ikincisi Yedayaya,
\v 8 üçüncüsü Xarimə, dördüncüsü Seorimə,
\v 9 beşincisi Malkiyaya, altıncısı Miyaminə,
\v 10 \x * \xo 24:10 \xt Luka 1:5 \x* yeddincisi Haqqosa, səkkizincisi Aviyaya,
\v 11 doqquzuncusu Yeşuaya, onuncusu Şekanyaya,
\v 12 on birincisi Elyaşivə, on ikincisi Yaqimə,
\v 13 on üçüncüsü Xuppaya, on dördüncüsü Yeşevaya,
\v 14 on beşincisi Bilqaya, on altıncısı İmmerə,
\v 15 on yeddincisi Xezirə, on səkkizincisi Happissesə,
\v 16 on doqquzuncusu Petahyaya, iyirmincisi Yezekelə,
\v 17 iyirmi birincisi Yakinə, iyirmi ikincisi Qamula,
\v 18 iyirmi üçüncüsü Delayaya, iyirmi dördüncüsü Maazyaya çıxdı.
\v 19 İsrailin Allahı Rəbbin əmr etdiyi kimi babaları Harunun vasitəsilə onlara verilən qaydalarına görə, Rəbbin məbədinə girmək üçün xidmət işinə görə növbələri belə idi.
\s1 Qalan Levililərin siyahısı
\p 
\v 20 Levililərin qalan bölmələri bunlardır: Amramın nəslindən Şuvael, Şuvaelin nəslindən Yexdeya.
\v 21 Rexavyanın nəslindən ilk oğlu İşşiya.
\v 22 İsharın nəslindən Şelomot, Şelomotun nəslindən Yaxat.
\v 23 Xevronun oğulları: ilk oğlu Yeriya, ikincisi Amarya, üçüncüsü Yaxaziel, dördüncüsü Yeqameam.
\v 24 Uzzielin nəslindən Mikeya, Mikeyanın nəslindən Şamir.
\v 25 Mikeyanın qardaşı İşşiya, İşşiyanın nəslindən Zəkəriyyə.
\v 26 Merarinin oğulları: Maxli, Muşi, onun nəslindən Yaaziya.
\v 27 Merari nəslindən olan Yaaziyanın oğulları: Şoham, Zakkur və İvri.
\v 28 Maxlinin nəslindən Eleazar. Onun oğlu yox idi.
\v 29 Qişin nəslindən Yeraxmeel.
\v 30 Muşinin oğulları: Maxli, Eder və Yerimot. Bunlar nəsillərinə görə Levililərin bölükləridir.
\v 31 Onlar da qohumları olan Harun nəsli kimi padşah Davudun, Sadoqun, Aximelekin, kahinlərin və Levililərin nəsil başçılarının önündə püşk atdılar. Böyük nəsil başçıları da, qohumları olan kiçik nəsil başçıları da eyni qayda ilə püşk atdılar.
\c 25
\s1 Məbəddə olan musiqiçilər
\p 
\v 1 Davud və ordu başçıları, Asəfin, Hemanın və Yedutunun nəslindən liralarla, çənglərlə və sinclərlə peyğəmbərlik etsinlər deyə xidmət üçün ayırdılar. Bu xidmət işini görənlərin siyahısı budur:
\v 2 Asəfin nəslindən: onun oğulları Zakkur, Yusif, Netanya, Asarela. Asəfin başçılığı altında olan oğulları padşahın əmrinə görə peyğəmbərlik edirdilər.
\v 3 Yedutunun nəslindən: onun oğulları Gedalya, Seri, Yeşaya, Xaşavya, Mattitya. Ataları Yedutunun başçılığı altında olan bu altı nəfər Rəbbə şükür və həmd edərək lira ilə peyğəmbərlik edirdi.
\v 4 Hemanın nəslindən: onun oğulları Buqqiya, Mattanya, Uzziel, Şevuel, Yerimot, Xananya, Xanani, Eliata, Giddalti, Romamti-Ezer, Yoşbeqaşa, Malloti, Hotir və Maxaziot.
\v 5 Bunların hamısı padşahın görücüsü Hemanın oğulları idi, çünki Hemanı yüksəltmək barədə Allahın verdiyi sözə görə Allah ona on dörd oğul və üç qız vermişdi.
\v 6 Onların hamısı Rəbbin məbədində atalarının başçılığı altında Allah evinin xidməti üçün sinclər, çənglər və liralar çalıb ilahi oxuyurdu. Asəf, Yedutun və Heman isə padşahın başçılığı altında idi.
\v 7 Rəbbə ilahi oxumaq öyrədilmiş qohumları ilə birgə bütün bunu bacaranlar iki yüz səksən səkkiz nəfər idi.
\v 8 Hamısı – böyüyü də, kiçiyi də, müəllimi də, şagirdi də eyni qayda ilə vəzifələri üçün püşk atdı.
\p 
\v 9 Birinci püşk Asəfin nəslindən olan Yusifə çıxdı. İkincisi qohumları və oğulları ilə birgə Gedalyaya çıxdı. Onlar on iki nəfər idi.
\v 10 Üçüncüsü oğulları və qohumları ilə birgə Zakkura çıxdı. Onlar on iki nəfər idi.
\v 11 Dördüncüsü oğulları və qohumları ilə birgə İsriyə çıxdı. Onlar on iki nəfər idi.
\v 12 Beşincisi oğulları və qohumları ilə birgə Netanyaya çıxdı. Onlar on iki nəfər idi.
\v 13 Altıncısı oğulları və qohumları ilə birgə Buqqiyaya çıxdı. Onlar on iki nəfər idi.
\v 14 Yeddincisi oğulları və qohumları ilə birgə Yesarelaya çıxdı. Onlar on iki nəfər idi.
\v 15 Səkkizincisi oğulları və qohumları ilə birgə Yeşayaya çıxdı. Onlar on iki nəfər idi.
\v 16 Doqquzuncusu oğulları və qohumları ilə birgə Mattanyaya çıxdı. Onlar on iki nəfər idi.
\v 17 Onuncusu oğulları və qohumları ilə birgə Şimeyə çıxdı. Onlar on iki nəfər idi.
\v 18 On birincisi oğulları və qohumları ilə birgə Azarelə çıxdı. Onlar on iki nəfər idi.
\v 19 On ikincisi oğulları və qohumları ilə birgə Xaşavyaya çıxdı. Onlar on iki nəfər idi.
\v 20 On üçüncüsü oğulları və qohumları ilə birgə Şuvaelə çıxdı. Onlar on iki nəfər idi.
\v 21 On dördüncüsü oğulları və qohumları ilə birgə Mattityaya çıxdı. Onlar on iki nəfər idi.
\v 22 On beşincisi oğulları və qohumları ilə birgə Yeremota çıxdı. Onlar on iki nəfər idi.
\v 23 On altıncısı oğulları və qohumları ilə birgə Xananyaya çıxdı. Onlar on iki nəfər idi.
\v 24 On yeddincisi oğulları və qohumları ilə birgə Yoşbeqaşaya çıxdı. Onlar on iki nəfər idi.
\v 25 On səkkizincisi oğulları və qohumları ilə birgə Xananiyə çıxdı. Onlar on iki nəfər idi.
\v 26 On doqquzuncusu oğulları və qohumları ilə birgə Mallotiyə çıxdı. Onlar on iki nəfər idi.
\v 27 İyirmincisi oğulları və qohumları ilə birgə Eliataya çıxdı. Onlar on iki nəfər idi.
\v 28 İyirmi beşincisi oğulları və qohumları ilə birgə Hotirə çıxdı. Onlar on iki nəfər idi.
\v 29 İyirmi ikincisi oğulları və qohumları ilə birgə Giddaltiyə çıxdı. Onlar on iki nəfər idi.
\v 30 İyirmi üçüncüsü oğulları və qohumları ilə birgə Maxaziota çıxdı. Onlar on iki nəfər idi.
\v 31 İyirmi dördüncüsü oğulları və qohumları ilə birgə Romamti-Ezerə çıxdı. Onlar on iki nəfər idi.
\c 26
\s1 Məbədin qapıçıları
\p 
\v 1 Qapıçıların bölükləri belədir: Qorah nəslindən, Asəfin övladlarından olan Qore oğlu Meşelemya.
\v 2 Meşelemyanın oğulları: ilk oğlu Zəkəriyyə, ikincisi Yediael, üçüncüsü Zevadya, dördüncüsü Yatniel,
\v 3 beşincisi Elam, altıncısı Yehoxanan, yeddincisi Elyehoenay.
\v 4 \x * \xo 26:4 \xt 2Şam. 6:11; 1Saln. 13:14; 27:23 \x* Oved-Edomun oğulları: ilk oğlu Şemaya, ikincisi Yehozavad, üçüncüsü Yoah, dördüncüsü Sakar, beşincisi Netanel,
\v 5 altıncısı Ammiel, yeddincisi İssakar, səkkizincisi Peulletay, çünki Allah Oved-Edoma xeyir-dua vermişdi.
\v 6 Onun oğlu Şemayanın da oğulları oldu və onlar nəsil başçıları oldu, çünki igid adamlar idi.
\v 7 Şemayanın oğulları: Otni, Refael, Oved və Elzavad. Qohumları Elihu və Semakya da igid adamlar idi.
\v 8 Bunların hamısı Oved-Edomun nəslindən idi. Özləri, oğulları və qohumları xidmət işində bacarıqlı və igid adamlar idi. Hamısı birlikdə altmış iki nəfər idi. Onlar Oved-Edomdan idi.
\v 9 Meşelemyanın oğullarından və qohumlarından olan igid adamlar on səkkiz nəfər idi.
\v 10 Merari nəslindən olan Xosanın oğulları: ilk oğlu olmadığı halda atasının böyük başçı qoyduğu Şimri,
\v 11 ikincisi Xilqiya, üçüncüsü Tevalya, dördüncüsü Zəkəriyyə. Xosanın bütün oğulları və qohumları on üç nəfər idi.
\p 
\v 12 Bu adamların başçılıq etdiyi qapıçı bölükləri başqa qohumları kimi Rəbbin məbədində xidmət etmək üçün vəzifələrinə təyin olundular.
\v 13 Böyüyü də, kiçiyi də ata nəsillərinə görə hər qapı üçün püşk atdı.
\v 14 Şelemya üçün püşk Şərq qapısına düşdü. Onun oğlu ağıllı məsləhətçi olan Zəkəriyyə üçün də püşk atdılar. Onun püşkü Şimal qapısına düşdü.
\v 15 Oved-Edom üçün püşk Cənub qapısına, oğulları üçün isə anbar evinə düşdü.
\v 16 Şuppim və Xosa üçün püşk Qərb qapısına və yuxarı qalxan yolda olan Şalleket qapısına düşdü. Bunların hamısı növbə ilə beləcə keşik çəkirdi.
\v 17 Şərq qapısı üçün altı Levili, Şimal qapısı üçün gündə dörd Levili, Cənub qapısı üçün gündə dörd Levili və hər iki anbar üçün iki Levili.
\v 18 Qərb tərəfdə olan həyət üçün isə yolda dördü, həyətdə ikisi dururdu.
\v 19 Bunlar Qorah və Merari nəsillərindən olan qapıçı bölmələridir.
\s1 Xəzinə nəzarətçiləri və başqa məmurlar
\p 
\v 20 Allah evinin xəzinələrinə və təqdis olunan şeylərin xəzinələrinə nəzarət edən Levililər – onların qohumları bunlardır:
\v 21 Gerşonlulardan olan Ladanın nəslindən Ladanın nəsil başçısı Gerşonlu Yexieli,
\v 22 Rəbbin məbədinin xəzinələrinə nəzarət edən Yexielinin oğulları Zetam və onun qardaşı Yoel.
\v 23 Amramın, İsharın, Xevronun və Uzzielin nəsillərindən
\v 24 Musa oğlu Gerşomun nəslindən olan Şevuel xəzinələr üzərində baş nəzarətçi idi.
\v 25 Gerşomun qardaşı Eliezerin nəsli: onun oğlu Rexavya, onun oğlu Yeşaya, onun oğlu Yoram, onun oğlu Zikri, onun oğlu Şelomit.
\v 26 Şelomit və onun qohumları bütün təqdis olunan şeylər xəzinələri üzərində nəzarətçi idi. Bu şeyləri padşah Davud, minbaşı və yüzbaşı olan nəsil və ordu başçıları təqdis etmişdi.
\v 27 Müharibələrdə ələ keçirilən təqdis olunmuş qənimətin bir hissəsini Rəbbin məbədini təmin etmək üçün ayırmışdılar.
\v 28 Hər kəsin təqdis etdiyi şeylər – görücü Şamuelin, Qiş oğlu Şaulun, Ner oğlu Avnerin və Seruya oğlu Yoavın təqdis etdiyi şeylərin hamısı Şelomitin və onun qohumlarının nəzarəti altında idi.
\p 
\v 29 İshar nəslindən Kenanya və onun oğulları İsrail üzərində məmur və hakim olub məbəddən kənardakı işlərə baxırdı.
\v 30 Xevronun nəslindən igid adamlar olan Xaşavya və onun qardaşları – min yeddi yüz nəfər Rəbbə ibadət işi və padşahın xidmət işi üçün İordan çayının qərb tayında yaşayan İsraillilər üzərində məmur idi.
\v 31 Xevronun nəslindən olan Yeriya Xevronluların nəsil başçısı idi. Davudun padşahlığının qırxıncı ilində onların nəsil şəcərələrinə baxıldı və Gileadın Yazer şəhərində onların arasında igid adamlar tapıldı.
\v 32 Yeriyanın nəsil başçıları olan qohumları igid adamlar idi və sayları iki min yeddi yüz nəfər idi. Padşah Davud Allahın və padşahın xidmət işi üçün Ruvenlilər, Qadlılar və Menaşşe qəbiləsinin yarısı üzərində onları məmur qoydu.
\c 27
\s1 Qoşun başçılarının aylıq növbələri
\p 
\v 1 İlin hər ayında bir bölmə növbə çəkirdi. Hər bölmədə iyirmi dörd min nəfər var idi. Bu bölmələrin bütün işlərində padşaha xidmət edən İsraillilərin nəsil başçılarının, minbaşıların, yüzbaşıların və məmurların siyahısı budur:
\v 2 birinci ay üçün birinci bölməyə Zavdiel oğlu Yaşoveam başçılıq edirdi. Onun bölməsində iyirmi dörd min nəfər var idi.
\v 3 O, Peres nəslindən idi və birinci ay üçün bütün ordu başçılarının böyüyü idi.
\v 4 İkinci ayın bölməsinə Axoahlı Doday başçılıq edirdi. Miqlot onun köməkçisi idi və onun bölməsində iyirmi dörd min nəfər var idi.
\v 5 Üçüncü ay üçün üçüncü qoşun başçısı kahin Yehoyadanın oğlu Benaya idi. Onun bölməsində iyirmi dörd min nəfər var idi.
\v 6 «Otuz igid»dən biri və «otuz igid»in başçısı olan Benaya budur. Oğlu Ammizavad onun köməkçisi idi.
\v 7 Dördüncü ay üçün dördüncü başçı Yoavın qardaşı Asahel idi, ondan sonra oğlu Zevadya idi. Onun bölməsində iyirmi dörd min nəfər var idi.
\v 8 Beşinci ay üçün beşinci başçı İzrahlı Şamhut idi. Onun bölməsində iyirmi dörd min nəfər var idi.
\v 9 Altıncı ay üçün altıncı başçı Teqoalı İqqeşin oğlu İra idi. Onun bölməsində iyirmi dörd min nəfər var idi.
\v 10 Yeddinci ay üçün yeddinci başçı Efrayimlilərdən Pelonlu Xeles idi. Onun bölməsində iyirmi dörd min nəfər var idi.
\v 11 Səkkizinci ay üçün səkkizinci başçı Zerah nəslindən Xuşalı Sibbekay idi. Onun bölməsində iyirmi dörd min nəfər var idi.
\v 12 Doqquzuncu ay üçün doqquzuncu başçı Binyaminlilərdən Anatotlu Aviezer idi. Onun bölməsində iyirmi dörd min nəfər var idi.
\v 13 Onuncu ay üçün onuncu başçı Zerah nəslindən Netofalı Mahray idi. Onun bölməsində iyirmi dörd min nəfər var idi.
\v 14 On birinci ay üçün on birinci başçı Efrayimlilərdən Piratonlu Benaya idi. Onun bölməsində iyirmi dörd min nəfər var idi.
\v 15 On ikinci ay üçün on ikinci başçı Otnielin nəslindən Netofalı Xelday idi. Onun bölməsində iyirmi dörd min nəfər var idi.
\s1 İsrail qəbilələri üzərində olan başçılar
\p 
\v 16 İsrail qəbilələri üzərində olan başçılar bunlardır: Ruvenlilərin başçısı Zikri oğlu Eliezer; Şimeonluların başçısı Maaka oğlu Şefatya;
\v 17 Levililərin başçısı Qemuel oğlu Xaşavya, Harun nəslinin başçısı Sadoq;
\v 18 Yəhudalıların başçısı Davudun qardaşlarından biri Elihu; İssakarlıların başçısı Mikael oğlu Omri;
\v 19 Zevulunluların başçısı Avdiya oğlu İşmaya; Naftalililərin başçısı Azriel oğlu Yerimot;
\v 20 Efrayimlilərin başçısı Azazya oğlu Huşə; Menaşşelilərin yarısının başçısı Pedaya oğlu Yoel;
\v 21 Gileadda olan Menaşşelilərin yarısının başçısı Zəkəriyyə oğlu İddo; Binyaminlilərin başçısı Avner oğlu Yaasiel;
\v 22 Danlıların başçısı Yeroxam oğlu Azarel. Bunlar İsrail qəbilələrinin başçılarıdır.
\p 
\v 23 \x * \xo 27:23 \xt Yar. 15:5; 22:17; 26:4 \x* Davud iyirmi yaşında və bundan aşağı yaşda olanları hesaba almadı, çünki Rəbb İsraili göydəki ulduzlar qədər çoxaldacağını vəd etmişdi.
\v 24 \x * \xo 27:24 \xt 2Şam. 24:1-15; 1Saln. 21:1-14 \x* Seruya oğlu Yoav siyahıya almağa başladı, ancaq bunu başa çatdırmadı. Bu siyahıyaalmadan ötrü Rəbbin qəzəbi İsrail üzərinə gəldi və siyahıyaalma padşah Davudun salnamələr kitabına daxil olmadı.
\s1 Padşahın nəzarətçiləri və məsləhətçiləri
\p 
\v 25 Padşahın anbarlarına nəzarət edən Adiel oğlu Azmavet; tarlalarda, şəhərlərdə, kəndlərdə və qalalarda olan anbarlara nəzarət edən Uzziya oğlu Yonatan;
\v 26 tarlada çalışan əkinçilərin üzərində nəzarətçi Keluv oğlu Ezri;
\v 27 üzüm bağlarına nəzarət edən Ramalı Şimey; üzüm bağlarındakı şərab anbarlarına yığılan üzüm məhsuluna nəzarət edən Şifemli Zavdi;
\v 28 yamaclı-düzənlikli bölgədə olan zeytunluqlar və firon ənciri ağaclarına nəzarət edən Gederli Baal-Xanan; yağ anbarlarına nəzarət edən Yoaş;
\v 29 Şaron düzənliyində otlayan mal-qaraya baxan Şaronlu Şitray; dərələrdə olan mal-qaraya baxan Adlay oğlu Şafat;
\v 30 dəvələrə baxan İsmailli Ovil; eşşəklərə baxan Meronotlu Yexdeya;
\v 31 qoyun-keçiyə baxan Həcərli Yaziz. Bunların hamısı padşah Davudun mülklərinə baxan rəislər idi.
\p 
\v 32 Davudun əmisi Yonatan məsləhətçi idi. O çox ağıllı və savadlı idi. Xakmoni oğlu Yexiel padşah oğullarının tərbiyəçisi idi.
\v 33 Axitofel padşahın məsləhətçisi idi. Arklı Xuşay padşahın həmsöhbəti idi.
\v 34 Axitofeldən sonra yerinə Benaya oğlu Yehoyada və Evyatar oldu. Padşahın ordu başçısı isə Yoav idi.
\c 28
\s1 Məbədin tikilişi barədə Davudun son məsləhətləri
\p 
\v 1 Davud İsrailin bütün başçılarını – qəbilə başçılarını, padşaha xidmət edən bölmələrin başçılarını, minbaşıları və yüzbaşıları, padşahla oğullarının bütün mülkünə və heyvanlarına baxanların başçılarını, saray xidmətçilərini, sərkərdələri və bütün igid adamları Yerusəlimə topladı.
\p 
\v 2 \x * \xo 28:2 \xt 2Şam. 7:1-16; 1Saln. 17:1-14 \x* Padşah Davud ayağa qalxıb dedi: «Ey qardaşlarım və xalqım, məni dinləyin! Ürəyimdə Allahımızın kətili və Rəbbin Əhd sandığı üçün bir rahatlıq evi tikmək arzusu var idi və onu tikmək üçün hazırlıq gördüm.
\v 3 Ancaq Allah mənə dedi: “Sən Mənim adıma məbəd tikməyəcəksən, çünki sən hərb adamısan və qan tökmüsən”.
\v 4 Lakin İsrailin Allahı Rəbb İsrail üzərində əbədi olaraq padşah olmaq üçün bütün nəslimdən məni seçdi, çünki hökmdar olmaq üçün O, Yəhudanı və Yəhuda qəbiləsindən mənim nəslimi seçdi. Bütün İsrail üzərində padşah etmək üçün nəslimin arasında mən xoşuna gəldim.
\v 5 Rəbbin mənə verdiyi çoxlu oğul arasından da İsrail üzərində Rəbbin padşahlıq taxtında oturmaq üçün oğlum Süleymanı seçdi.
\v 6 Rəbb mənə dedi: “Oğlun Süleyman da həmin adamdır ki, Mənim məbədimi və həyətlərimi tikəcək, çünki onu Özümə oğul seçdim və Mən ona Ata olacağam.
\v 7 Əgər bu gün olduğu kimi əmrlərimə və hökmlərimə əməl etməkdə sadiq olsa, onun padşahlığını əbədi olaraq möhkəmləndirəcəyəm”.
\p 
\v 8 İndi isə bütün İsraillilərin, Rəbbin camaatının gözü önündə və Allahımız eşidərkən belə tapşırıram: “Allahınız Rəbbin bütün əmrlərinə əməl edin, onları öyrənin ki, bu nemətli torpaqda qalasınız və sizdən sonra övladlarınıza onu əbədi miras verəsiniz”.
\p 
\v 9 Sən də, oğlum Süleyman, atanın Allahını tanı, səmimi qəlbdən və həvəslə Ona qulluq et, çünki Rəbb bütün ürəkləri sınayır və ağılların bütün istəklərini bilir. Əgər Onu axtarsan, sən Onu tapacaqsan. Əgər Onu tərk etsən, O da səni əbədi olaraq atacaq.
\v 10 İndi bax Rəbb səni Müqəddəs məkan olan bir ev tikmək üçün seçmişdir, sən də möhkəm ol və bu işi gör».
\p 
\v 11 Davud oğlu Süleymana eyvanın, onun evlərinin, xəzinələrinin, yuxarı otaqların, iç otaqların, Kəffarə yerinin, fikrində olan bütün bunların təsvirini və
\v 12 Ruhun vasitəsilə ona aşkar olmuş bütün bunların təsvirini verdi: Rəbbin məbədinin həyətləri, ətrafdakı bütün otaqlar, Allah məbədinin xəzinələri, təqdis olunan şeylərin xəzinələri,
\v 13 kahinlərin və Levililərin bölükləri, Rəbbin məbədində hər cür xidmət işi, Rəbbin məbədində olan bütün xidmət əşyaları,
\v 14 hər cür xidmət üçün işlədilən bütün qızılın çəkisinə görə qızıl əşyalar, hər cür xidmət üçün işlədilən gümüşün çəkisinə görə gümüş əşyalar,
\v 15 hər çıraqdanın və onun çıraqlarının çəkisinə görə qızıl çıraqdanlar və onların qızıl çıraqları, hər cür xidmət üçün çəkisinə görə gümüş çıraqdanlar və onların çıraqları,
\v 16 təqdis çörəkləri qoyulan masalar üçün hər masanın çəkisinə görə qızıl, hər gümüş masa üçün gümüş,
\v 17 xalis qızıldan olan çəngəllər, piyalələr və dolçalar, hər kasanın çəkisinə görə qızıl kasalar, hər kasanın çəkisinə görə gümüş kasalar,
\v 18 çəkisinə görə xalis qızıldan buxur qurbangahı. Davud həm də qanadlarını açıb Əhd sandığını örtən Rəbbin arabası olan qızıl keruvların təsvirini verdi.
\v 19 Davud dedi: «Bunların hamısının təsviri bütün təfsilatı ilə yazılı şəkildə Rəbb tərəfindən mənə aşkar edildi».
\p 
\v 20 Davud oğlu Süleymana dedi: «Möhkəm və cəsarətli ol, bu işi gör, qorxma və ruhdan düşmə, çünki Rəbb Allah, mənim Allahım səninlədir. O, Rəbbin məbədinin bütün xidmət işi sona çatmamış səni atmaz və tərk etməz.
\v 21 Allah məbədinin bütün xidməti üçün kahinlərin və Levililərin bölükləri hazır durub. Sənin yanında bütün işlər üçün hər cür xidməti bacaran könüllü adamlar da var. Rəislər və bütün xalq sənin hər əmrini gözləyir».
\c 29
\s1 Məbədə gətirilən nəzirlər
\p 
\v 1 \x * \xo 29:1 \xt 1Saln. 22:5 \x* Padşah Davud bütün camaata dedi: «Allahın yeganə seçdiyi oğlum Süleyman cavan və təcrübəsizdir, bu iş isə böyükdür, çünki bu bina insan üçün deyil, Rəbb Allah üçün olacaq.
\v 2 Bütün səyimlə Allahımın məbədindən ötrü qızıl şeylər üçün qızıl, gümüş şeylər üçün gümüş, tunc şeylər üçün tunc, dəmir şeylər üçün dəmir, ağac şeylər üçün ağac, damarlı əqiq daşları və onların sağanaqları, cilalı və cürbəcür rəngli daşlar, hər cür qiymətli daşlar və çoxlu mərmər daşlar hazırlamışam.
\v 3 Bundan başqa, Allahımın məbədini tikməyə həvəsim naminə müqəddəs məbəd üçün hazırladığım hər şeydən əlavə nə qədər qızıl-gümüş xəzinəm varsa, onu da Allahım Rəbbin məbədi üçün verirəm:
\v 4 Ofir qızılından üç min talant qızılı, yeddi min talant xalis gümüşü evlərin divarını örtmək üçün,
\v 5 qızıl şeylər üçün qızılı, gümüş şeylər üçün gümüşü ustaların düzəldəcəyi bütün işlər üçün verirəm. Kim bu gün Rəbbə könüllü nəzir təqdim etmək istəyir?»
\p 
\v 6 Nəsil başçıları, İsrail qəbilələrinin başçıları, minbaşılar, yüzbaşılar və padşahın işləri üzərində olan rəislər könüllü gəlib
\v 7 Allah məbədinin xidməti üçün beş min talant və on min darik qızıl, on min talant gümüş, on səkkiz min talant tunc və yüz min talant dəmir verdilər.
\v 8 Kimdə qiymətli daşlar var idisə, onları Gerşon nəslindən olan Yexielin nəzarəti altında olan Rəbbin məbədinin xəzinəsinə verirdi.
\v 9 Xalq onların könüllü nəzir verməsinə sevindi, çünki bütün qəlbi ilə Rəbbə nəzir təqdim etmişdilər. Padşah Davud da çox sevindi.
\s1 Davudun duası
\p 
\v 10 Davud bütün camaatın gözü önündə Rəbbə alqış edib dedi: «Ey atamız İsrailin Allahı Rəbb, əzəldən sonsuza qədər Sənə alqış olsun!
\v 11 \x * \xo 29:11 \xt Mat. 6:13 \x* Ya Rəbb, əzəmət, qüdrət, calal, zəfər və şöhrət Sənə məxsusdur, çünki göydə və yerdə olan hər şey Sənindir. Ya Rəbb, padşahlıq Sənindir və Hökmdar olaraq hər şeydən ucasan.
\v 12 Var-dövlətlə şöhrət Səndən gəlir və Sən hər şeyə hökmranlıq edirsən. Hər kəsi yüksəltmək və gücləndirmək üçün qüdrət və güc Sənin əlindədir.
\v 13 İndi, ey Allahımız, biz Sənə şükür edirik və izzətli adına həmd edirik.
\p 
\v 14 Ancaq mən kiməm və xalqım nədir ki, bu cür könüllü nəzirlər verə bilək? Çünki hər şey Səndəndir və əlindən aldığımızı Sənə verdik.
\v 15 Biz bütün atalarımız kimi Sənin önündə bir qərib və qonağıq. Günlərimiz yer üzündə kölgə kimidir və heç nəyə ümidimiz yoxdur.
\v 16 Ya Rəbb Allahımız, Sənin müqəddəs adına məbəd tikmək üçün hazırladığımız bütün bu var-dövlət Sənin əlinlə verilib, bunların hamısı Sənindir.
\v 17 Bilirəm ki, ey Allahım, Sən ürəyi sınayırsan və düzlüyü sevirsən. Mən bütün bu şeyləri ürəyimin düzlüyü ilə könüllü olaraq təqdim etdim, indi də burada olan xalqının Sənə könüllü nəzir verdiyini sevinclə gördüm.
\v 18 Ya Rəbb, atalarımız İbrahimin, İshaqın və İsrailin Allahı! Xalqının ürəyindəki istəklərində bunu əbədi olaraq qoruyub saxla və onların ürəyini Özünə tərəf yönəlt.
\v 19 Oğlum Süleymana sadiq bir ürək ver ki, Sənin əmrlərinə, göstərişlərinə və qanunlarına əməl etsin, bütün bu işləri görsün, tikintisinə hazırlıq gördüyüm bu binanı tiksin».
\p 
\v 20 Davud bütün camaata dedi: «İndi Allahınız Rəbbə həmd edin». Bütün camaat atalarının Allahı Rəbbə həmd etdi. Onlar əyilib Rəbbə səcdə, padşaha isə təzim etdilər.
\s1 Süleymanın taxta çıxması
\p 
\v 21 Ertəsi gün Rəbbə qurbanlar kəsdilər və Rəbbə yandırma qurbanı olaraq min baş buğa, min baş qoç, min baş quzu, onların içmə təqdimlərini və bütün İsrail üçün çoxlu qurbanlar təqdim etdilər.
\v 22 O gün onlar böyük sevinclə Rəbbin önündə yeyib-içdilər. Sonra ikinci dəfə Davud oğlu Süleymanı padşah etdilər. Rəbb üçün onu hökmdar və Sadoqu kahin olaraq məsh etdilər.
\v 23 \x * \xo 29:23 \xt 1Pad. 2:12 \x* Süleyman atası Davudun yerinə padşah olaraq Rəbbin taxtında oturdu və uğur qazandı. Bütün İsraillilər ona itaət etdi.
\v 24 Bütün rəislər, igid adamlar, həm də Davudun bütün oğulları padşah Süleymana tabe oldu.
\v 25 Rəbb Süleymanı bütün İsraillilərin gözündə çox ucaltdı və özündən əvvəl İsraildə heç bir padşahın malik olmadığı padşahlıq əzəmətini ona verdi.
\s1 Davudun ölümü
\p 
\v 26 Beləliklə, Yessey oğlu Davud bütün İsrail üzərində padşahlıq etdi.
\v 27 \x * \xo 29:27 \xt 2Şam. 5:4-5; 1Saln. 3:4 \x* Onun İsrail üzərində padşahlıq etdiyi müddət qırx il idi; yeddi il Xevronda və otuz üç il Yerusəlimdə padşahlıq etdi.
\v 28 O, uzun ömür sürüb sərvət və şöhrətdən doymuş halda xoş bir qocalıq çağında öldü və yerinə oğlu Süleyman padşah oldu.
\v 29 Padşah Davudun əvvəldən axıra qədər bütün işləri görücü Şamuelin kitabında, peyğəmbər Natanın kitabında və görücü Qadın kitabında yazılmışdır.
\v 30 Bu kitablarda həm Davudun padşahlığı və qüdrəti, həm də onun, İsrailin və bütün dünya padşahlıqlarının başına gələn əhvalatlar barədə yazılmışdır. 
