\c 4
\p 
\v 1 \w Le|strong="H3478"\w* \w roi|strong="H4428"\w* \w Salomon|strong="H8010"\w* \w fut|strong="H3478"\w* donc \w roi|strong="H4428"\w* \w sur|strong="H5921"\w* \w tout|strong="H3605"\w* \w Israël|strong="H3478"\w*.
\v 2 \w Et|strong="H1121"\w* \w voici|strong="H1121"\w* quels \w étaient|strong="H1121"\w* \w ses|strong="H1121"\w* dignitaires: \w Azaria|strong="H5838"\w*, \w fils|strong="H1121"\w* \w du|strong="H1121"\w* \w sacrificateur|strong="H3548"\w* \w Tsadok|strong="H6659"\w*,
\v 3 Élihoreph \w et|strong="H1121"\w* Achija, \w fils|strong="H1121"\w* \w de|strong="H1121"\w* Shisha, \w étaient|strong="H1121"\w* \w secrétaires|strong="H5608"\w*; Jéhoshaphat, \w fils|strong="H1121"\w* d'Achilud, \w était|strong="H1121"\w* \w archiviste|strong="H2142"\w*;
\v 4 \w Bénaja|strong="H1141"\w*, \w fils|strong="H1121"\w* \w de|strong="H1121"\w* \w Jéhojada|strong="H3077"\w*, \w chef|strong="H1121"\w* \w de|strong="H1121"\w* l'\w armée|strong="H6635"\w*; \w Tsadok|strong="H6659"\w* \w et|strong="H1121"\w* \w Abiathar|strong="H6659"\w* \w étaient|strong="H1121"\w* \w sacrificateurs|strong="H3548"\w*;
\v 5 \w Azaria|strong="H5838"\w*, \w fils|strong="H1121"\w* \w de|strong="H1121"\w* \w Nathan|strong="H5416"\w*, \w était|strong="H4428"\w* surintendant; \w et|strong="H1121"\w* \w Zabud|strong="H2071"\w*, \w fils|strong="H1121"\w* \w de|strong="H1121"\w* \w Nathan|strong="H5416"\w*, principal officier, \w ami|strong="H7463"\w* \w du|strong="H1121"\w* \w roi|strong="H4428"\w*;
\v 6 Achishar, grand-maître \w de|strong="H1121"\w* \w la|strong="H5921"\w* \w maison|strong="H1004"\w*; \w et|strong="H1121"\w* Adoniram, \w fils|strong="H1121"\w* d'\w Abda|strong="H5653"\w*, \w commis|strong="H1121"\w* \w sur|strong="H5921"\w* \w les|strong="H1121"\w* \w impôts|strong="H4522"\w*.
\v 7 Or \w Salomon|strong="H8010"\w* \w avait|strong="H4428"\w* \w douze|strong="H8147"\w* \w intendants|strong="H5324"\w* \w préposés|strong="H5324"\w* \w sur|strong="H5921"\w* \w tout|strong="H3605"\w* \w Israël|strong="H3478"\w*, \w et|strong="H3478"\w* \w ils|strong="H1961"\w* entretenaient \w le|strong="H3478"\w* \w roi|strong="H4428"\w* \w et|strong="H3478"\w* \w sa|strong="H4428"\w* \w maison|strong="H1004"\w*; \w et|strong="H3478"\w* \w chacun|strong="H1004"\w* \w était|strong="H1961"\w* \w chargé|strong="H1961"\w* \w de|strong="H4428"\w* \w cet|strong="H3605"\w* \w entretien|strong="H3557"\w* \w pendant|strong="H3478"\w* \w un|strong="H3478"\w* \w mois|strong="H2320"\w* \w de|strong="H4428"\w* \w l|strong="H8141"\w*'\w année|strong="H8141"\w*.
\v 8 Voici \w leurs|strong="H2022"\w* \w noms|strong="H8034"\w*: \w le|strong="H8034"\w* \w fils|strong="H8034"\w* \w de|strong="H2022"\w* \w Hur|strong="H1133"\w*, \w dans|strong="H8034"\w* \w la|strong="H2022"\w* \w montagne|strong="H2022"\w* d'Éphraïm;
\v 9 Le fils de \w Déker|strong="H1128"\w* à \w Makats|strong="H4739"\w*, \w Saalbim|strong="H8169"\w*, Beth-Shémèsh et Élon de Beth-Hanan;
\v 10 \w Le|strong="H3605"\w* \w fils|strong="H1136"\w* \w de|strong="H3605"\w* Hésed à Arubboth; \w il|strong="H3605"\w* \w avait|strong="H3605"\w* \w Soco|strong="H7755"\w* \w et|strong="H7755"\w* \w tout|strong="H3605"\w* \w le|strong="H3605"\w* \w pays|strong="H3605"\w* \w de|strong="H3605"\w* \w Hépher|strong="H2660"\w*.
\v 11 \w Le|strong="H1961"\w* \w fils|strong="H1323"\w* d'\w Abinadab|strong="H1125"\w* \w avait|strong="H1961"\w* \w toute|strong="H3605"\w* \w la|strong="H1961"\w* \w contrée|strong="H5299"\w* \w de|strong="H1323"\w* \w Dor|strong="H1756"\w*; \w il|strong="H8010"\w* \w eut|strong="H8010"\w* Taphath, \w fille|strong="H1323"\w* \w de|strong="H1323"\w* \w Salomon|strong="H8010"\w*, \w pour|strong="H1323"\w* \w femme|strong="H1323"\w*.
\v 12 \w Baana|strong="H1195"\w*, \w fils|strong="H1121"\w* d'Achilud, \w avait|strong="H1121"\w* \w Thaanac|strong="H8590"\w*, \w et|strong="H1121"\w* \w Méguiddo|strong="H4023"\w*, \w et|strong="H1121"\w* \w tout|strong="H3605"\w* \w le|strong="H1121"\w* \w pays|strong="H1121"\w* \w de|strong="H1121"\w* Beth-Shéan, \w qui|strong="H1121"\w* \w est|strong="H1121"\w* \w vers|strong="H5704"\w* \w Tsarthan|strong="H6891"\w*, \w au-dessous|strong="H6891"\w* \w de|strong="H1121"\w* \w Jizréel|strong="H3157"\w*, \w depuis|strong="H5704"\w* Beth-Shéan jusqu'\w à|strong="H1121"\w* Abel-Méhola, \w et|strong="H1121"\w* jusqu'\w au|strong="H1121"\w* \w delà|strong="H5676"\w* \w de|strong="H1121"\w* \w Jokméam|strong="H3361"\w*.
\v 13 \w Le|strong="H1121"\w* \w fils|strong="H1121"\w* \w de|strong="H1121"\w* \w Guéber|strong="H1127"\w* \w était|strong="H5892"\w* \w à|strong="H1121"\w* \w Ramoth|strong="H7433"\w* \w de|strong="H1121"\w* \w Galaad|strong="H1568"\w*; \w il|strong="H5892"\w* \w avait|strong="H1121"\w* \w les|strong="H1121"\w* \w bourgs|strong="H2333"\w* \w de|strong="H1121"\w* \w Jaïr|strong="H2971"\w*, \w fils|strong="H1121"\w* \w de|strong="H1121"\w* \w Manassé|strong="H4519"\w*, \w en|strong="H5892"\w* \w Galaad|strong="H1568"\w*; \w il|strong="H5892"\w* \w avait|strong="H1121"\w* \w aussi|strong="H1121"\w* \w la|strong="H1121"\w* \w contrée|strong="H2256"\w* d'Argob, \w en|strong="H5892"\w* Bassan, \w soixante|strong="H8346"\w* \w grandes|strong="H1419"\w* \w villes|strong="H5892"\w* \w à|strong="H1121"\w* \w murailles|strong="H2346"\w* \w et|strong="H1121"\w* \w à|strong="H1121"\w* \w barres|strong="H1280"\w* d'\w airain|strong="H5178"\w*.
\v 14 Achinadab, \w fils|strong="H1121"\w* d'\w Iddo|strong="H5714"\w*, \w à|strong="H1121"\w* \w Mahanaïm|strong="H4266"\w*;
\v 15 Achimaats, \w en|strong="H3947"\w* \w Nephthali|strong="H5321"\w*; \w lui|strong="H1931"\w* \w aussi|strong="H1571"\w* \w prit|strong="H3947"\w* \w pour|strong="H3947"\w* \w femme|strong="H1323"\w* \w une|strong="H3947"\w* \w fille|strong="H1323"\w* \w de|strong="H1323"\w* \w Salomon|strong="H8010"\w*, \w Basmath|strong="H1315"\w*.
\v 16 \w Baana|strong="H1195"\w*, \w fils|strong="H1121"\w* \w de|strong="H1121"\w* Cushaï, \w en|strong="H1121"\w* Asser \w et|strong="H1121"\w* \w à|strong="H1121"\w* Aloth;
\v 17 Jéhoshaphat, \w fils|strong="H1121"\w* \w de|strong="H1121"\w* \w Paruach|strong="H6515"\w*, \w en|strong="H1121"\w* \w Issacar|strong="H3485"\w*;
\v 18 Shimeï, \w fils|strong="H1121"\w* d'Éla, \w en|strong="H1121"\w* \w Benjamin|strong="H1144"\w*;
\v 19 \w Guéber|strong="H1398"\w*, \w fils|strong="H1121"\w* d'Uri, \w au|strong="H1121"\w* \w pays|strong="H1121"\w* \w de|strong="H1121"\w* \w Galaad|strong="H1568"\w*, \w le|strong="H1121"\w* \w pays|strong="H1121"\w* \w de|strong="H1121"\w* \w Sihon|strong="H5511"\w*, \w roi|strong="H4428"\w* \w des|strong="H1121"\w* \w Amoréens|strong="H4428"\w* \w et|strong="H1121"\w* d'\w Og|strong="H5747"\w*, \w roi|strong="H4428"\w* \w de|strong="H1121"\w* Bassan; \w et|strong="H1121"\w* \w il|strong="H4428"\w* \w était|strong="H4428"\w* \w seul|strong="H1121"\w* \w intendant|strong="H5333"\w* \w de|strong="H1121"\w* \w ce|strong="H1121"\w* pays-là.
\v 20 \w Juda|strong="H3063"\w* \w et|strong="H3478"\w* \w Israël|strong="H3478"\w* \w étaient|strong="H3478"\w* \w comme|strong="H3220"\w* \w le|strong="H3478"\w* \w sable|strong="H2344"\w* \w qui|strong="H3478"\w* \w est|strong="H3478"\w* \w sur|strong="H5921"\w* \w le|strong="H3478"\w* \w bord|strong="H3478"\w* \w de|strong="H7227"\w* \w la|strong="H5921"\w* \w mer|strong="H3220"\w*, tant \w ils|strong="H3478"\w* \w étaient|strong="H3478"\w* \w en|strong="H3478"\w* \w grand|strong="H7227"\w* \w nombre|strong="H7227"\w*; \w ils|strong="H3478"\w* \w mangeaient|strong="H3478"\w*, \w buvaient|strong="H8354"\w* \w et|strong="H3478"\w* \w se|strong="H3478"\w* \w réjouissaient|strong="H8056"\w*.
\v 21 Et Salomon dominait sur tous les royaumes, depuis le fleuve jusqu'au pays des Philistins et à la frontière d'Égypte; ils apportaient des présents, et furent assujettis à Salomon tout le temps de sa vie.
\v 22 Or les vivres de Salomon étaient, pour chaque jour: trente cores de fleur de farine et soixante cores de farine;
\v 23 Dix bœufs gras et vingt bœufs des pâturages, et cent moutons, sans les cerfs, les gazelles, les daims et les volailles engraissées.
\v 24 Car il dominait sur tous les pays de ce côté-ci du fleuve, depuis Thiphsach jusqu'à Gaza, sur tous les rois de ce côté-ci du fleuve; et il avait la paix avec tous ses alentours, de tous côtés.
\v 25 Et Juda et Israël habitaient en sécurité, chacun sous sa vigne et sous son figuier, depuis Dan jusqu'à Béer-Shéba, pendant toute la vie de Salomon.
\v 26 Salomon avait aussi quarante mille attelages de chevaux pour ses chars et douze mille cavaliers.
\v 27 Or les intendants pourvoyaient de vivres, chacun durant son mois, le roi Salomon et tous ceux qui s'approchaient de la table du roi Salomon; ils ne laissaient rien manquer.
\v 28 Ils faisaient aussi venir de l'orge et de la paille pour les chevaux de trait et les coursiers, chacun selon sa charge, au lieu où ils étaient.
\v 29 Et Dieu donna à Salomon de la sagesse, une fort grande intelligence, et un esprit aussi vaste que le sable qui est sur le bord de la mer.
\v 30 Et la sagesse de Salomon surpassait la sagesse de tous les Orientaux, et toute la sagesse des Égyptiens.
\v 31 Il était plus sage qu'aucun homme; plus qu'Éthan l'Ézrachite, et Héman, Calcol et Darda, les fils de Machol; et sa réputation se répandit parmi toutes les nations d'alentour.
\v 32 Il prononça trois mille sentences, et ses cantiques furent au nombre de mille et cinq.
\v 33 Il \w a|strong="H3068"\w* aussi parlé des arbres, depuis le cèdre qui est au Liban jusqu'à l'hysope qui sort de la muraille; il \w a|strong="H3068"\w* aussi parlé des animaux, des oiseaux, des reptiles et des poissons.
\v 34 Et, de tous les peuples, on venait pour entendre la sagesse de Salomon, de la part de tous les rois de la terre, qui avaient entendu parler de sa sagesse.
\c 5
\p 
\v 1 Hiram, \w roi|strong="H5704"\w* \w de|strong="H3117"\w* Tyr, envoya \w de|strong="H3117"\w* \w ses|strong="H3117"\w* \w serviteurs|strong="H5647"\w* \w vers|strong="H4467"\w* \w Salomon|strong="H8010"\w*, \w quand|strong="H5704"\w* \w il|strong="H3117"\w* \w eut|strong="H8010"\w* appris qu'\w on|strong="H3117"\w* \w l|strong="H4503"\w*'\w avait|strong="H1961"\w* oint \w pour|strong="H5704"\w* \w roi|strong="H5704"\w* \w à|strong="H5704"\w* \w la|strong="H3117"\w* \w place|strong="H3117"\w* \w de|strong="H3117"\w* \w son|strong="H3117"\w* \w père|strong="H3117"\w*; car Hiram \w avait|strong="H1961"\w* \w toujours|strong="H3117"\w* aimé David.
\v 2 \w Et|strong="H3117"\w* \w Salomon|strong="H8010"\w* envoya \w vers|strong="H3117"\w* Hiram, \w pour|strong="H3899"\w* \w lui|strong="H8010"\w* \w dire|strong="H8010"\w*:
\v 3 Tu sais \w que|strong="H6629"\w* David, \w mon|strong="H6629"\w* père, n'\w a|strong="H3068"\w* pu bâtir une maison \w au|strong="H6643"\w* nom \w de|strong="H6629"\w* l'Éternel son Dieu, \w à|strong="H6629"\w* \w cause|strong="H6629"\w* \w de|strong="H6629"\w* \w la|strong="H6643"\w* guerre dont ses ennemis l'environnaient, jusqu'\w à|strong="H6629"\w* \w ce|strong="H6629"\w* \w que|strong="H6629"\w* l'Éternel \w les|strong="H3967"\w* eût mis sous ses pieds.
