\id PRO  
\h تَالِيٍ 
\toc1 عَلَ شَ تَالِيٍ 
\toc2 تَالِيٍ 
\toc3 تَا 
\mt1 عَلَ شَ تَالِيٍ 
\imt1 مَسٍنيِ قْلّ 
\ip عِسِرَيِلَ مَنفّ دَوُدَ تٌ قَشَ، عَلَتَلَ نَشَ عَ شَ دِ سُلٍمَنِ سُفَندِ عَ شَ قِندِ عِسِرَيِلَ مَنفّ رَ. نَ كُي سُلٍمَنِ نَشَ عَلَ مَشَندِ عَ شَ عَ مَلِ عِسِرَيِلَ يَمَرِدٍ. عَ نُ وَ مَ لْننِ نَن شْن عَلَكٌ عَ شَ نْ نَ وَلِ رَبَدٍ عَ رَبَ كِ مَ. نَ مَشَندِ نَشَ عَلَتَلَ مَكّنّن، عَ قَ نَ دُبَ سُشُ. سُلٍمَنِ تٌ قِندِ لْننِلَ بٍلٍبٍلٍ رَ عَلَ سَابُي رَ، دُنِحَ بِرِن نَشَ نَ كٌلٌن عَ مَ، عٍ نُ قَ سِفَ عَ شَ مَرَ سِ قٍندٍ. 
\ip نَ تّمُي عَننَبِ سُلٍمَنِ نَشَ عَ شَ قٍ كٌلٌنيِ قِندِ سّبّلِ رَ عَلَ شَشِلِ سّنِيّنشِ سَابُي رَ. عَ شَ كِتَابُي سّبّشِ كِ نَشّ، عَ قِندِ تَالِ وْيّنيِيٍ نَن نَ. نَ سّبّ كِ تٌقَن، عَ مَن لْننِ بٍلٍبٍلٍ مَسٍنمَ تٌ دَنشَنِيَتْييٍ بّ. 
\ip يِ تَالِيٍ مَسٍنيِ هَفِفّيٍ مَسٍنمَ مِشِ بّ عَلْ؛ 
\ili وْيّن قَنيِ تِدٍ نَن فبٌ عَدَ مَدِيٍ تَفِ. 
\ili لَنفٌيحَ قِندِ مَ تْورّ نَن نَ مِشِ بّ. 
\ili عَلَ شَ سّرِيّ مِشِ مَلِمَ دُنِحّءِفِرِ كُي. 
\ili تُننَشْنّيَ قِندِ مَ نّ سٍتَرٍحَ رَ، تُننَبّشِيَ قِندِ مَ هَرِفٍ رَ. 
\ili يّتّ عِفبٌحَ مُ قَن، يّتّ مَفٌرٍ نَن قَن. 
\ili لَنيِ شَ لُ دٍنبَيَ كُي. 
\ili دِيٍ شَ شُرُ عَلَ شَ سّرِيّ رَ. 
\ili وُلٍ نُن شْنّ وْيّنيِ مُ قَن حَمَ بّ. 
\ili عَدَ مَدِيٍ لَنمَ عٍ شَ فَاشُ عَلَ يَ رَ. 
\ip عَلَ شَ عَ شَ مَسٍنيِ رَ سٌ وٌن بْحّ كُي، عَلَكٌ وٌن شَ عَ سَفٌ كٌلٌن، وٌن مَن شَ عَ رَبَتُ وٌن مَ دُنِحّءِفِرِ كُي. نَ بِرِن قِندِ مَ مَرَ سِ قَنيِ نَن نَ وٌن بّ دُنِحَ نُن عَلِفِيَمَ. عَمِنَ. 
\mt1 عَلَ شَ تَالِيٍ 
\c 1  
\s1 يِ كِتَابُي سّبّشِ قٍ نَشَن مَ 
\p  
\v 1 عِسِرَيِلَ مَنفّ دَوُدَ شَ دِ سُلٍمَنِ، شَ تَالِيٍ نَن يَ؛ 
\q1  
\v 2 عٍ سّبّشِ نّ مِشِيٍ بّ عَلَكٌ عٍ شَ لْننِ، عٍ شَ رَ سِ، 
\q1 شَشِلِ قَنيِ شَ لُ عٍ بّ،  
\v 3 شُرُي قَنيِ شَ لُ عٍ يِ، 
\q1 عٍ شَ بِرَ تِنشِنيِ، نْندِ، نُن قٍ قَنيِ قْشْ رَ. 
\q1  
\v 4 شَشِلِ قَنيِ مُ نَشٍيٍ يِ، نٍيٍ شَ نَ سْتْ، 
\q1 مَحْشُنيِ قَنيِ شَ لُ قٌنِكٍيٍ بّ، 
\q1 عٍ شَ قٍ قَنيِيٍ كٌلٌن، عٍ لَن عٍ شَ نَشٍيٍ رَبَ. 
\b  
\q1  
\v 5 لْننِلَ شَ عَ تُلِ مَتِ 
\q1 عَلَكٌ عَ شَ قٍ كٌلٌنيِ شُن شَ مَسَ. 
\q1 شَشِلِمَ شَ عَ تُلِ مَتِ، 
\q1 عَلَكٌ عَ شَ حّرّ كِ قَنيِ كٌلٌن، 
\q1  
\v 6 تَالِ كُي قِيشّقٍ شَ سْونّيَ عٍ بّ، 
\q1 عٍ شَ قَهَامُي سْتْ لْننِلَيٍ شَ مَسٍنيِيٍ نُن تَالِيٍ مَ. 
\q1  
\v 7 عَلَتَلَ شَ يَرَفَاشُي قِندِشِ لْننِ قْلّ نَن نَ. 
\q1 شَشِلِتَرٍيٍ نَن يٌمَ لْننِ نُن مَرَ سِ مَ. 
\q1  
\v 8 ﭑ مَ دِ، عِ عِ تُلِ مَتِ عِ بَبَ شَ مَرَ سِ رَ، 
\q1 عِ نَشَ تٌندِ عِ نفَ شَ شُرُي رَ، 
\q1  
\v 9 بَرِ مَ شُنمَسٍ تٌقَنيِ نَن قِندِ مَ عَ رَ عِ شُنيِ مَ، 
\q1 كْن مَفٌرٍ نَن عَ رَ عِ كْنيِ مَ. 
\b  
\q1  
\v 10 ﭑ مَ دِ، عِ نَشَ تِن يُنُبِتْييٍ شَ عِ رَتَنتَن. 
\q1  
\v 11 شَ عٍ عَ قَلَ، «بِرَ مُشُ قْشْ رَ، 
\q1 وٌن شَ سَ كِرَ مَدْشْ مِشِيٍ بّ، وٌن شَ عٍ قَشَ، 
\q1 وٌن شَ فَنتَنيِ تٍ مِشِيٍ بّ 
\q1 نَشٍيٍ مُ قٍقٍ رَبَشِ وٌن نَ، 
\q1  
\v 12 وٌن شَ عٍ شُن نَكَنَ، 
\q1 عَلْ فَبُرِ عَ رَبَمَ كِ نَشّ مِشِيٍ رَ 
\q1 نَشٍيٍ سِفَمَ عَلِفِيَمَ. 
\q1  
\v 13 وٌن قَمَ نَاقُلِ سْتْدٍ نَ كُي، 
\q1 وٌن مَ بَنشِيٍ رَقٍمَ نّ سٍ قَنيِيٍ رَ. 
\q1  
\v 14 لُ مُشُ يَ مَ عَلَكٌ عِ شَ ندٍ سْتْ، 
\q1 وٌن مَ كْبِرِ مَلَندٍ شَ قِندِ كٍرٍن نَ.» 
\b  
\q1  
\v 15 ﭑ مَ دِ، عِ نَشَ بِرَ نَ مِشِ مْولِ قْشْ رَ، 
\q1 عِ نَشَ لُ نَ كِرَ شْن مَ، 
\q1  
\v 16 بَرِ مَ عٍ قٍ حَاشِ نَن تُن نَبَمَ، 
\q1 عٍ فبَتَشِ مِشِ نِي بَدٍ. 
\q1  
\v 17 فَنتَنيِ مُ تٍمَ شْنِ يَ شْرِ، 
\q1  
\v 18 كْنْ عٍ تَن فَنتَنيِ تٍمَ عٍ يّتّ كَن سُشُسٍ نَن نَ. 
\q1 عٍ عٍ يّتّ نَن نِي بَقٍ عٍ يّتّ رَ. 
\q1  
\v 19 بِرَقٍ فٍينِ تِنشِنتَرٍ قْشْ رَ، 
\q1 نُن مِشِ نِي بَقٍ، 
\q1 نَ كِرَ مْولِ قِندِ مَ فَنتَنيِ نَن نَ. 
\b  
\q1  
\v 20 شَشِلِمَيَ شِلِ تِمَ كِرَ شُنيِيٍ رَ، 
\q1 عَ عَ شُي رَ مِنِمَ تَا مَلَندٍيٍ. 
\q1  
\v 21 عَ شِلِ تِمَ حَمَ تَفِ، 
\q1 عَ وْيّنمَ تَا سٌدٍ دّيٍ رَ. 
\q1  
\v 22 عَ نَشّ، «عِ تَن شَشِلِتَرٍ، 
\q1 عِ بِرَ مَ شَشِلِتَرٍحَ قْشْ رَ هَن مُن تّمُي؟ 
\q1 مِشِ مَيٍلٍيٍ يٌمَ مِشِ مَ هَن مُن تّمُي؟ 
\q1 شَشِلِتَرٍيٍ قٍ كٌلٌنيِ شْنمَ هَن مُن تّمُي؟ 
\q1  
\v 23 وٌ فبِلٍن قَ رَ ﭑ مَ مَرَ سِيٍ مَ. 
\q1 ﭑ نَ ﭑ شَشِلِ لُمَ نّ وٌ مَ، 
\q1 ﭑ قَهَامُي قِمَ نّ وٌ مَ ﭑ مَ مَسٍنيِ شَ قٍ رَ. 
\q1  
\v 24 ﭑ بَرَ وٌ شِلِ، كْنْ وٌ مُ ﭑ مَ شِلِ رَتِنشِ. 
\q1 ﭑ بَرَ ﭑ بّلّشّ عِتَلَ وٌ بّ، كْنْ وٌ بَرَ تٌندِ. 
\q1  
\v 25 وٌ تٌ بَرَ تٌندِ ﭑ مَ مَرَ سِيٍ بِرِن نَ، 
\q1 وٌ تٌ مُ تِنشِ ﭑ مَ سّرِيّ رَ، 
\q1  
\v 26 ﭑ قَن قَمَ نّ يٍلٍدٍ وٌ مَ وٌ شَ تْورّ كُي. 
\q1 فَاشُي نَ وٌ بْحّيٍ رَ مِنِ عَ عِ، ﭑ مُ وٌ مَلِمَ قٍقٍ مَ. 
\q1  
\v 27 فَاشُي قَمَ نّ وٌ لِدٍ عَلْ تُرُننَادّ قٌيٍ، 
\q1 تْورّ قَمَ نّ وٌ سُشُدٍ عَلْ قٌيٍ شُنفبٍ. 
\q1 نَ تْورّ نُن كْنتْقِلِ نَ وٌ لِ تّمُي نَشّ، 
\q1  
\v 28 وٌ ﭑ شِلِمَ نّ، كْنْ ﭑ مُ وٌ شَ شِلِ رَتِنمَ. 
\q1 وٌ ﭑ قٍنمَ نّ، كْنْ وٌ مُ ﭑ تٌمَ، 
\q1  
\v 29 بَرِ مَ وٌ بَرَ شَشِلِمَيَ شْن، 
\q1 وٌ بَرَ تٌندِ عَلَتَلَ شَ يَرَفَاشُي رَ. 
\q1  
\v 30 عٍ مُ نُ وَ مَ ﭑ مَ مَرَ سِيٍ شْن، 
\q1 عٍ مُ نُ وَ مَ ﭑ مَ سّرِيّ سُشُقٍ. 
\q1  
\v 31 نَ كُي عٍ قَمَ عٍ شَ وَلِ سَرٍ سْتْدٍ، 
\q1 عٍ قَمَ عٍ حّرّ كِ رَحْنيِ تٌدٍ. 
\q1  
\v 32 شَشِلِتَرٍحَ نَن قَمَ شَشِلِتَرٍيٍ فَندٍ. 
\q1 لْننِتَرٍحَ نَن قَمَ لْننِتَرٍيٍ فَندٍ. 
\q1  
\v 33 كْنْ نَشَن تَن عَ تُلِ مَتِمَ ﭑ نَ، 
\q1 نَ كَنيِ لُمَ نّ كَنتَرِ كُي عَ شْنيِ، 
\q1 عَ لُ بْحّسَ كُي، عَ مُ فَاشُمَ تْورّ يَ رَ.» 
\c 2  
\s1 شَشِلِمَيَ قَن عَدَ مَدِيٍ بّ 
\q1  
\v 1 ﭑ مَ دِ، شَ عِ ﭑ مَ مَسٍنيِيٍ سُشُ، 
\q1 شَ عِ ﭑ مَ سّرِيّ رَبَتُ، 
\q1  
\v 2 شَ عِ عِ تُلِ مَتِ لْننِ رَ، شَ نْندِ رَقَن عِ بْحّ مَ، 
\q1  
\v 3 شَ عِ شَشِلِ قَنيِ قٍن، شَ عِ نْندِ مَشِلِ، 
\q1  
\v 4 شَ عِ عَ قٍن عَلْ فبٍتِ، شَ عِ عَ قٍن عَ قَنيِ رَ 
\q1 عَلْ بَننَيَ قٍنمَ كِ نَشّ، 
\q1  
\v 5 نَ كُي، عِ عَلَتَلَ شَ يَرَفَاشُي كٌلٌنمَ نّ، 
\q1 عِ عَلَ شَ قٍ قَهَامُمَ نّ، 
\q1  
\v 6 بَرِ مَ عَلَتَلَ نَن لْننِ قِمَ، 
\q1 شَشِلِ قَنيِ نُن نْندِ مِنِمَ عَ كّرّ عِ. 
\q1  
\v 7 عَ قٍ قَنيِ فبٍفبٍ رَفَتَمَ تِنشِنتْييٍ بّ. 
\q1 عَ نْندِ قَلّ مَكَنتَمَ. 
\q1  
\v 8 عَ مِشِ تِنشِنشِ مَكَنتَمَ، 
\q1 عَ عَ شَنُنتٍنيِيٍ رَتَنفَمَ كِرَ شْن مَ. 
\q1  
\v 9 نَ كُي، عِ نْندِ نُن تِنشِنيِ كٌلٌنمَ نّ، 
\q1 كِرَ تِنشِنشِ نَشٍيٍ مِشِ تِمَ قٍ قَنيِ مَ. 
\b  
\q1  
\v 10 لْننِ قَمَ عِ بْحّ نَن مَ، 
\q1 قٍ كٌلٌنيِ حْشُنمَ عِ بّ، 
\q1  
\v 11 شَشِلِ قَنيِ عِ رَتَنفَمَ، 
\q1 نْندِ عِ مَكَنتَمَ، 
\q1  
\v 12 عَ عِ رَتَنفَمَ كِرَ حَاشِ مَ، 
\q1 عَ عِ رَتَنفَمَ وْيّن كٌبِ قَلّ مَ، 
\q1  
\v 13 نَشٍيٍ فبِلٍنمَ تِنشِنيِ كِرَ قْشْ رَ، 
\q1 نَشٍيٍ حّرّ مَ دِ مِ كُي، 
\q1  
\v 14 قٍ حَاشِ رَقَنشِ نَشٍيٍ مَ، 
\q1 نَشٍيٍ حّلّشِنشِ كٌبِحَ رَ، 
\q1  
\v 15 نَشٍيٍ شَ كِرَ مُ تِنشِن، 
\q1 نَشٍيٍ حّرّ كِ مُ قَن. 
\b  
\q1  
\v 16 لْننِ عِ رَتَنفَمَ نّ فِنّ حَاشِ مَ، 
\q1 لَنفٌي فِنّ شَ دّ عِحْشُنيِ مَ، 
\q1  
\v 17 نَشَن عَ شَ شّمّ سِنفٍ قِنسِرِوَلِمَ، 
\q1 نَشَن نّيمُمَ عَ مَرِفِ عَلَ شَ سَاتّ مَ. 
\q1  
\v 18 عَ شَ وَلِ كٌبِ عَ رَبِرَ مَ نّ، 
\q1 عَ حّرّ كِ عَ شَنِن عَلِفِيَمَ. 
\q1  
\v 19 مِشِ نَشٍيٍ بِرَ مَ عَ قْشْ رَ، 
\q1 عٍ مُ فبِلٍنمَ سْنْن، عٍ مُ كِسِ سْتْمَ. 
\q1  
\v 20 عَ لَنمَ عِ شَ عِ حّرّ مِشِ قَنيِيٍ نَن مَ كِرَ رَ، 
\q1 عِ شَ تِنشِنتْييٍ شَ كِرَ سُشُ. 
\q1  
\v 21 مِشِ تِنشِنشِيٍ لُمَ نّ يِ بْشِ مَ، 
\q1 مِشِ هَفِفّيٍ مُ كٍلِمَ بٍ، 
\q1  
\v 22 كْنْ مِشِ حَاشِيٍ تَن حْنمَ نّ يِ بْشِ مَ، 
\q1 تِنشِنتَرٍيٍ كٍرِ مَ نّ. 
\c 3  
\s1 عَلَ شَ سّرِيّ قَن 
\q1  
\v 1 ﭑ مَ دِ، عِ نَشَ نّيمُ ﭑ مَ مَرَ سِيٍ مَ، 
\q1 عِ بْحّ شَ ﭑ مَ سّرِيّ رَبَتُ، 
\q1  
\v 2 بَرِ مَ عٍ قَمَ عِ شَ سِمَيَ شْن نَكُيَدٍ بْحّسَ كُي. 
\q1  
\v 3 عِ نَشَ دُفُتّفّحَ نُن نْندِ رَبّحِن، 
\q1 عِ شَ عٍ شِرِ عِ كْن مَ، عِ شَ عٍ سّبّ عِ سٌندٌنيِ مَ. 
\q1  
\v 4 عِ قَمَ هِننّ نُن شَشِلِ قَنيِ سْتْدٍ نَ كِ نّ، 
\q1 عَلَ نُن عَدَ مَدِيٍ يَ عِ. 
\q1  
\v 5 عِ يّتّ تَشُ عَلَتَلَ رَ عِ بْحّ بِرِن نَ، عِ نَشَ لَ عِ يّتّ رَ. 
\q1  
\v 6 عِ شَ عَلَ كٌلٌن عِ شَ كِرَ بِرِن شْن، 
\q1 عَ تَن نَن قَمَ حّرّ كِ قَنيِ مَسٍندٍ عِ بّ. 
\q1  
\v 7 عِ نَشَ عِ شَشِلِ تِ عِ يّتّ رَ، 
\q1 عِ شَ فَاشُ عَلَتَلَ يَ رَ، 
\q1 عِ شَ فبِلٍن قٍ حَاشِ قْشْ رَ. 
\q1  
\v 8 نَ قِندِ مَ يَلَنيِ نَن نَ عِ قَتٍ بّ، 
\q1 عَ سّنبّ قِ عِ شْرِيٍ مَ. 
\q1  
\v 9 عَلَتَلَ بِنيَ عِ هَرِفٍ رَ، 
\q1 عِ شَ دَشَمُي سِنفٍ قِ عَ مَ. 
\q1  
\v 10 نَ نَن عَ نِيَمَ بَلٌي نُن مِنسٍ فبٌ عِ يِ رَ، 
\q1 عِ شَ سَفَيٍ بِرِن نَقٍ. 
\b  
\q1  
\v 11 ﭑ مَ دِ، عِ نَشَ تٌندِ عَلَتَلَ شَ مَتِنشِنيِ رَ، 
\q1 عِ شَ عَ شَ مَرَ سِيٍ سُشُ، 
\q1  
\v 12 بَرِ مَ عَلَتَلَ مَرَ سِ قِمَ نّ عَ شَنُنتٍنيِيٍ مَ، 
\q1 عَلْ بَبَيٍ عٍ شَ دِ مَتِنشِنمَ مَرَقَنيِ كُي كِ نَشّ. 
\b  
\q1  
\v 13 سّيوّ نَ مِشِ بّ نَشَن شَشِلِمَيَ سْتْشِ، 
\q1 سّيوّ نَ عَدَ مَ بّ نَشَن قَهَامُي سْتْ. 
\q1  
\v 14 شَشِلِمَيَ شَ فٍينِ فبٌ فبٍتِ بّ، 
\q1 عَ تِدٍ دَنفِ شّيمَ رَ. 
\q1  
\v 15 عَ قَن فّمّ تٌقَنيِ بّ، 
\q1 عَ تِدٍ دَنفِ عِ وَشْنسٍ بِرِن نَ. 
\q1  
\v 16 شَشِلِمَيَ قِندِ مَ سِمَيَ شْنكُيٍ نَن نَ، 
\q1 عَ قِندِ بَننَيَ نُن شُننَكٍلِ رَ. 
\q1  
\v 17 شَشِلِمَيَ كِرَ قَن، 
\q1 عَ بْحّسَ قِمَ عَدَ مَدِيٍ مَ. 
\q1  
\v 18 عَ قِندِشِ سِمَيَ وُرِ نَن نَ عَ سُشُمَيٍ بّ. 
\q1 مِشِ نَشٍيٍ كَنكَنمَ لْننِ مَ، نٍيٍ سّيوَ مَ نّ. 
\q1  
\v 19 عَلَتَلَ بْشِ يَءِلَنشِ لْننِ نَن نَ، 
\q1 عَ كٌورٍ يَءِلَنشِ شَشِلِ قَنيِ نَن نَ. 
\q1  
\v 20 عَ شَ لْننِ نَن يٍ رَ مِنِشِ بْشِ مَ، 
\q1 عَ شَ شَشِلِ قَنيِ نَن يٍ رَفَتَشِ نُشُييٍ كُي. 
\b  
\q1  
\v 21 ﭑ مَ دِ، سّرِيّ نُن نْندِ رَفَتَ عِ بْحّ كُي، 
\q1 عٍ نَشَ مَكُيَ عِ رَ. 
\q1  
\v 22 عٍ سِمَيَ نُن هِننّ قِمَ نّ عِ مَ، 
\q1  
\v 23 عِ شَ دُنِحّءِفِرِ سْونّيَمَ نّ، عِ مُ دِنكٌنمَ. 
\q1  
\v 24 عِ نَ عِ سَ، عِ مُ فَاشُمَ، عِ شِمَ نّ عَ قَنيِ رَ. 
\q1  
\v 25 عِ نَشَ فَاشُ فبَلٌي يَ رَ، 
\q1 عِ نَشَ فَاشُ مِشِ حَاشِيٍ شَ فٍرٍ يَ رَ، 
\q1  
\v 26 بَرِ مَ عَلَتَلَ نَن نَ عِ شَ شَشِلِسَ رَ. 
\q1 عَ عِ رَتَنفَمَ نّ فَنتَنيِ بِرِن مَ. 
\b  
\q1  
\v 27 عِ نَشَ تٌندِ مِشِ مَلِدٍ 
\q1 عِ نْمَ نَشَن نَ. 
\q1  
\v 28 عِ نَشَ عَ قَلَ عِ بٌورٍ بّ، «سِفَ، تِنَ عِ قَ،» 
\q1 شَ عَ مَلِ شَ قّيرّ نَ عِ بّ تٌ. 
\q1  
\v 29 عِ نَشَ عِ دّقَنبٌورٍ يَنقَ. 
\q1  
\v 30 عِ نَشَ مِشِ تْوحّفّ، نَشَن مُ قٍ حَاشِ يٌ رَبَشِ عِ رَ. 
\q1  
\v 31 عِ نَشَ فٍرٍ سٌي تْونّ، عِ نَشَ بِرَ عَ حّرّ كِ قْشْ رَ. 
\q1  
\v 32 عَلَتَلَ مِشِ حَاشِ شْنمَ، 
\q1 كْنْ تِنشِنتْي تَن نَقَن عَ مَ. 
\b  
\q1  
\v 33 عَلَتَلَ مِشِ حَاشِ شَ بَنشِ دَنكَمَ نّ، 
\q1 كْنْ عَ بَرَكّ سَمَ نّ تِنشِنتْي سَبَتِدٍ مَ. 
\q1  
\v 34 عَلَ يّتّ عِفبٌي عِفٌرٌ مَ نّ، 
\q1 كْنْ عَ هِننّمَ مِشِ مَفٌرٌشِ تَن نَ. 
\q1  
\v 35 شَشِلِمَيٍ نْرْ مَ نّ، 
\q1 كْنْ شَشِلِتَرٍيٍ تَن يَافِ نَن سْتْمَ. 
\c 4  
\s1 عَ بَبَ شَ مَسٍنيِ 
\q1  
\v 1 ﭑ مَ دِيٍ، وٌ وٌ تُلِ مَتِ وٌ بَبَ شَ مَرَ سِ رَ، 
\q1 وٌ وٌ حّنفِ سَ نَ شْن مَ عَلَكٌ وٌ شَ شَشِلِ سْتْ، 
\q1  
\v 2 بَرِ مَ ﭑ نَ لْننِ قَنيِ نَن قِقٍ وٌ مَ يِ كِ. 
\q1 وٌ نَشَ تٌندِ ﭑ مَ مَسٍنيِ رَ. 
\q1  
\v 3 دِ قَنيِ نَن نُ ﭑ نَ ﭑ بَبَ بّ. 
\q1 دِ كٍرٍنيِ نَن نُ ﭑ نَ ﭑ نفَ بّ. 
\b  
\q1  
\v 4 ﭑ بَبَ نُ ﭑ نَسِمَ يِ وْيّنيِ نَن نَ، عَ نَشّ، 
\q1 «عِ شَ ﭑ مَ مَسٍنيِ رَفَتَ عِ بْحّ كُي، 
\q1 عِ شَ ﭑ مَ سّرِيّ سُشُ عَلَكٌ عِ شَ سِمَيَ سْتْ. 
\q1  
\v 5 عِ شَ لْننِ قٍن، شَشِلِ قَنيِ شَ لُ عِ بّ. 
\q1 عِ نَشَ نّيمُ ﭑ مَ مَسٍنيِ مَ، 
\q1 عِ نَشَ نّيمُ ﭑ مَ سّرِيّ مَ. 
\q1  
\v 6 عِ نَشَ عٍ رَبّحِن، عٍ عِ مَكَنتَمَ نّ. 
\q1 ﭑ مَ سّرِيّ شَ رَقَن عِ مَ، عَ عِ رَتَنفَمَ نّ.» 
\q1  
\v 7 لْننِ قْلّ نَن يِ كِ؛ 
\q1 عِ شَ لْننِ قٍن، عِ شَ قٍ بِرِن نَبَ عَلَكٌ عِ شَ شَشِلِ سْتْ. 
\q1  
\v 8 شَ عِ شَشِلِمَيَ بِنيَ، عَ عِ عِتٍمَ نّ. 
\q1 شَ عِ عَ سُشُ، عَ عِ شُننَكٍلِمَ نّ. 
\q1  
\v 9 عَ قِندِ مَ شُنمَسٍ تٌقَنيِ نَن نَ عِ شُنيِ مَ، 
\q1 عَ قِندِ دِيَمَن شَ يَنبّ رَ عِ بّ. 
\q1  
\v 10 ﭑ مَ دِ، شَ عِ عِ تُلِ مَتِ ﭑ مَ مَسٍنيِ رَ، 
\q1 عِ شَ سِمَيَ شْن كُيَمَ نّ. 
\q1  
\v 11 ﭑ بَرَ شَشِلِمَيَ كِرَ مَسٍن عِ بّ، 
\q1 ﭑ بَرَ عِ تِ كِرَ تِنشِنشِ شْن مَ. 
\q1  
\v 12 شَ عِ عِ حّرّ مَ نَ كِرَ نَن مَ، عِ مُ تْورْ مَ. 
\q1 شَ عِ عِ فِمَ نَ كِرَ نَن شْن مَ، عِ مُ دِنكٌنمَ. 
\q1  
\v 13 لْننِ سُشُ، عِ نَشَ عَ رَبٌلٌ، عِ نَشَ عَ رَبّحِن، 
\q1 بَرِ مَ عَ قِندِ مَ سِمَيَ نَن نَ عِ بّ. 
\q1  
\v 14 عِ نَشَ بِرَ مِشِ حَاشِ قْشْ رَ، 
\q1 عِ نَشَ مِشِ كٌبِ شَ كِرَ سُشُ. 
\q1  
\v 15 عِ نَشَ حّرّ نَ شْن، عِ نَشَ عِ مَكْرّ نَ رَ. 
\q1 عِ كٌبٍ سٌ نَ رَ، عِ دَنفِ. 
\q1  
\v 16 مِشِ حَاشِيٍ مُ نْمَ شِدٍ عٍ مُ قٍ حَاشِ رَبَ. 
\q1 شِ شْلِ مُ نْمَ عٍ سُشُدٍ عٍ مُ مِشِ رَتَنتَن. 
\q1  
\v 17 قٍ حَاشِ قِندِشِ عٍ شَ دٌنسٍ نُن مِنسٍ نَن نَ. 
\q1  
\v 18 تِنشِنتْي شَ كِرَ نْرْ مَ نّ، 
\q1 عَ يَنبّ نَءِيَلَنيِ رَ مِنِمَ نّ عَلْ سٌفٍ. 
\q1  
\v 19 كْنْ مِشِ حَاشِيٍ شَ كِرَ لُشِ نّ عَلْ دِ مِ، 
\q1 عٍ مُ قٍ كٌلٌن نَشَن قَمَ عٍ رَبِرَدٍ. 
\b  
\q1  
\v 20 ﭑ مَ دِ، عِ عِ حّنفِ سَ ﭑ مَ مَسٍنيِ شْن مَ، 
\q1 عِ عِ تُلِ مَتِ ﭑ مَ مَرَ سِ رَ. 
\q1  
\v 21 عٍ مَتٌ تّمُي بِرِن، عِ عٍ رَفَتَ عِ سٌندٌنيِ كُي، 
\q1  
\v 22 بَرِ مَ عٍ قِندِ مَ سِمَيَ نَن نَ مِشِيٍ بّ، 
\q1 نَشٍيٍ عٍ قَهَامُمَ. 
\q1 عٍ قِندِ مَ يَلَنيِ نَن نَ عٍ قَتٍ بّ. 
\q1  
\v 23 عِ بْحّ كَنتَ دَنفِقٍ سٍ بِرِن نَ، 
\q1 بَرِ مَ سِمَيَ كٍلِمَ عَ تَن نَن مَ. 
\q1  
\v 24 وُلٍ نَشَ مِنِ عِ دّ عِ، 
\q1 عِ نَشَ مِشِ مَدَشُ عِ شَ وْيّنيِ رَ. 
\q1  
\v 25 عِ نّ وْيّنمَ مِشِ بّ، عِ عِ يَ تِ عَ رَ، 
\q1 عِ نَشَ عِ يَ رَ سِفَ يِرٍ فبّتّ. 
\q1  
\v 26 عِ حّنفِ سَ عِ حّرّ كِ شْن مَ، 
\q1 عِ لُ كِرَ قَنيِ شْن مَ. 
\q1  
\v 27 عِ نَشَ بِنيَ يِرٍقَنيِ مَ، 
\q1 عِ نَشَ بِنيَ كْولَ مَ. 
\q1 عِ نَشَ عِ سَنيِ تِ كِرَ حَاشِ شْن مَ. 
\c 5  
\s1 يّنّ شَ كَنَرِ 
\q1  
\v 1 ﭑ مَ دِ، مّينِ ﭑ مَ لْننِ مَ، 
\q1 عِ عِ تُلِ مَتِ ﭑ مَ شَشِلِ قَنيِ رَ، 
\q1  
\v 2 عَلَكٌ عِ شَ قَهَامُي سْتْ، 
\q1 عِ دّ شَ وْيّنيِ شْرِ قَلَ. 
\q1  
\v 3 لَنفٌي شَ وْيّنيِيٍ حْشُن عَلْ كُمِ، 
\q1 عَ مَسَلَشُن عَلْ سُلٌحِ، 
\q1  
\v 4 كْنْ عَ رَحْنيِ شْنْ عَلْ مٍلِ، 
\q1 عَ شّحّن عَلْ سَنتِدّفّمَ دّ قِرِنيِ. 
\q1  
\v 5 عَ سَنيِيٍ عَ شُن تِمَ فبَلٌي رَ، 
\q1 عَ شَ كِرَ مِشِ شَنِنمَ عَلِفِيَمَ نّ. 
\q1  
\v 6 عَ مُ لُمَ سِمَيَ كِرَ شْن مَ. 
\q1 عَ لْيشِ، كْنْ عَ مُ عَ كٌلٌن. 
\q1  
\v 7 يَكْسِ، ﭑ مَ دِ، عِ عِ تُلِ مَتِ ﭑ نَ، 
\q1 عِ نَشَ عِ مَكُيَ ﭑ مَ مَسٍنيِ رَ. 
\q1  
\v 8 عِ مَكُيَ لَنفٌي شَ كِرَ رَ، 
\q1 عِ نَشَ عِ مَكْرّ عَ شَ بَنشِ نَادّ رَ، 
\q1  
\v 9 عَلَكٌ بِنيّ نَشَ بَ عِ مَ، 
\q1 شّمّ يَ عِشَرَشِ نَشَ قَ عِ شَ دُنِحّءِفِرِ كَنَ. 
\q1  
\v 10 شَ نَ مُ عَ رَ مِشِ فبّتّيٍ نَن لُفَمَ عِ هَرِفٍ رَ، 
\q1 عِ شَ وَلِ تْنّ لُ بٌورٍيٍ بّ، 
\q1  
\v 11 عِ عِ شَ سِمَيَ رَحْن تْورّ كُي، 
\q1 عِ قَتٍ بِرِن بَ عِ مَ عَ حَاشِ رَ. 
\q1  
\v 12 عِ عَ قَلَمَ نّ كْرّ، 
\q1 «ﭑ نَ مَرَ سِ شْن مُنقٍ رَ؟ 
\q1 ﭑ بْحّ تٌندِ نَ سّرِيّ رَ مُنقٍ رَ؟ 
\q1  
\v 13 مُنقٍ رَ ﭑ مُ ﭑ تُلِ مَتِ ﭑ كَرَ مْشْييٍ رَ، 
\q1 ﭑ مُ ﭑ تُلِ مَتِ ﭑ نَسِمَيٍ رَ؟ 
\q1  
\v 14 ﭑ قَ نَ تْورّ بِرِن دْنشْي نَن كُي يِ كِ حَمَ يَ شْرِ.» 
\b  
\q1  
\v 15 يٍ مِن، نَشَن مِنِمَ عِ يّتّ شَ كْلْنيِ رَ. 
\q1  
\v 16 عِ نَشَ تِن عِ شَ كْلْنيِ يٍ شَ فٌرٌ مِشِيٍ بُن مَ، 
\q1 عِ نَشَ تِن عِ شَ يٍ شَ مَكَنَ تَا كُي. 
\q1  
\v 17 نَ يٍ شَ قِندِ عِ كٍرٍن نَن فبٍ رَ، 
\q1 عِ تَن نُن شْحّيٍ نَشَ نَ عِتَشُن. 
\q1  
\v 18 بَرَكّ شَ لُ عِ شَ كْلْنيِ مَ، 
\q1 عِ شَ سّيوَ عِ شَ فِنّ رَ عِ 
\q1 نَشَن قُتِ عِ قٌنِكٍ رَ. 
\q1  
\v 19 عِ شَ فِنّ تٌقَن عَلْ بٌلٍ، عَ قَن عَلْ شٍلِ. 
\q1 عَ شَ مَرَقَنيِ شَ لُ عِ بْحّ كُي، 
\q1 عِ شَ عَ مَشَنُ تّمُي بِرِن. 
\q1  
\v 20 ﭑ مَ دِ، عِ بِرَ مَ مِشِ فبّتّ شَ فِنّ قْشْ رَ مُنقٍ رَ؟ 
\q1 مُنقٍ رَ عِ فِنّ شِحّ سُنبُمَ 
\q1 عِ فبٍ مُ نَشَن نَ؟ 
\b  
\q1  
\v 21 عَلَتَلَ عَدَ مَ حّرّ كِ بِرِن كٌلٌن. 
\q1 عَ عَدَ مَ شَ كِرَ بِرِن تٌمَ. 
\q1  
\v 22 مِشِ حَاشِ شَ وَلِ حَاشِيٍ نَن عَ سُشُشِ، 
\q1 عَ شَ يَنفٌي نَن قِندِشِ فَنتَنيِ رَ عَ بّ. 
\q1  
\v 23 عَ شَ شُرُتَرٍحَ نَن عَ نِيَمَ عَ قَشَ، 
\q1 عَ شَ دَشُحَ نَن عَ نِيَمَ عَ بْنْ. 
\c 6  
\s1 تُننَشْنّ نُن لَنفٌيحَ 
\q1  
\v 1 ﭑ مَ دِ، شَ عِ عِ يّتّ تَانِشِ عِ بٌورٍ ندٍ بّ، 
\q1 عِ قِندِشِ هَمِلُ رَ عَ بّ عٍ نُن مِشِ فبّتّ تَفِ، 
\q1  
\v 2 شَ عِ عِ يّتّ رَشّتّنشِ عِ شَ وْيّنيِ ندٍ رَ، 
\q1 شَ عِ عِ يّتّ شِرِشِ نَ لَايِدِ مْولِ رَ، 
\q1  
\v 3 ﭑ مَ دِ، عِ شَ قٍ بِرِن نَبَ عِ يّتّ رَ مِنِدٍ عَ كُي، 
\q1 شَ نَ مُ عَ رَ عِ لُمَ نّ عِ بٌورٍ سَفٌي. 
\q1 سِفَ، عِ عِ قٍلٍن عِ بٌورٍ بّ، عِ شَ عَ مَيَندِ. 
\q1  
\v 4 عِ نَشَ شِ دٍ، نَ رَبَ كٍرٍن نَ. 
\q1  
\v 5 عِ عِ يّتّ رَتَنفَ يِ قٍ مْولِ مَ، 
\q1 عَلْ شٍلِ عَ يّتّ رَتَنفَمَ كٌيِنمَ بّلّشّ مَ كِ نَشّ، 
\q1 عَلْ شْنِ قَن عَ يّتّ رَتَنفَمَ فَنتَنيِ مَ كِ نَشّ. 
\b  
\q1  
\v 6 تُننَشْنّ، سِفَ دٌندٌلِ يِرٍ. 
\q1 مَرَ سِ قٍن عَ رَ، عَلَكٌ عِ شَ قِندِ شَشِلِمَ رَ. 
\q1  
\v 7 مَنفّ مُ نَ دٌندٌلِ بّ، 
\q1 كُنتِفِ نُن يَرٍرَتِ قَن مُ عَ بّ، 
\q1  
\v 8 كْنْ عَ وَلِمَ سٌفٌقُرٍ تّمُي، 
\q1 عَلَكٌ عَ شَ بَلٌي سْتْ عَ نَشَن دٌنمَ حّمّ رَ. 
\q1  
\v 9 عِ تَن تُننَشْنّ، عِ عِ سَمَ هَن مُن تّمُي؟ 
\q1 عِ كٍلِمَ شِشْلِ مَ تّمُي مُندُن؟ 
\q1  
\v 10 شِشْلِ نَ عِ سُشُ، عِ نَ كِنسْن، عِ نَ عِ سَ، 
\q1  
\v 11 سٍتَرٍحَ قَن قَمَ نّ عِ سُشُدٍ تّرّننَ رَ، 
\q1 عَلْ مُحّتِ مِشِ تّرّننَمَ كِ نَشّ. 
\q1 كَامّ عِ سُشُمَ نّ، عَلْ سْورِ مِشِ سُشُمَ كِ نَشّ. 
\q1  
\v 12 قُيَنتٍ مُ تِنشِن، عَ وُلٍ رَحّرّ مَ عَ دّ عِ نّ. 
\q1  
\v 13 عَ لُمَ عَ يَ مَفِرَ رَ، 
\q1 عَ نُ مِشِ مَكٍبٍنتِن عَ سَنيِيٍ نُن عَ بّلّشّيٍ رَ وُلٍ تْنشُمَ رَ. 
\q1  
\v 14 قٍ حَاشِ نَ عَ شَشِلِ كُي، 
\q1 عَ فٍرٍ مَسٌمَ تّمُي بِرِن. 
\q1  
\v 15 نَ كُي كَسَرّ قَمَ نّ عَ سُشُدٍ، 
\q1 عَ عَ شُن نَكَنَ كٍرٍنيِ رَ. 
\b  
\q1  
\v 16 قٍ سٍننِ نَ عَلَتَلَ نَشٍيٍ شْنشِ، 
\q1 عَ مُ تِنمَ نٍيٍ رَ قٍقٍ مَ؛ 
\q1  
\v 17 يّتّ عِفبٌي شَ مِشِ مَتٌ كِ، 
\q1 وُلٍ مِنِمَ دّ نَشَن كُي، 
\q1 بّلّشّ نَشَن نِي بَمَ قُقَقُ رَ، 
\q1  
\v 18 بْحّ نَشَن قٍ تِنشِنتَرٍ مَحْشُنمَ، 
\q1 سَنيِ نَشٍيٍ عٍ فِمَ سِفَقٍ رَ قٍ كٌبِ رَبَدٍ، 
\q1  
\v 19 سٍيدٍ نَشَن وُلٍ قَلَمَ، 
\q1 عَ نُن مِشِ نَشَن نفَشَكٍرٍنمَيٍ تَفِ عِسٌمَ. 
\b  
\q1  
\v 20 ﭑ مَ دِ، عِ بَبَ شَ سّرِيّ رَفَتَ، 
\q1 عِ نَشَ تٌندِ عِ نفَ شَ مَرَ سِ رَ. 
\q1  
\v 21 عٍ شَ لُ عِ بْحّ كُي تّمُي بِرِن، عٍ شِرِ عِ كْن مَ. 
\q1  
\v 22 عٍ عِ رَحّرّ مَ نّ عِ شَ دُنِحّءِفِرِ كُي، 
\q1 عٍ عِ مَكَنتَ عِ شَ سَدٍ مَ، عٍ عِ رَ سِ عِ كٍلِ تّمُي. 
\q1  
\v 23 نَ سّرِيّ قِندِشِ لَنثُي نَن نَ، 
\q1 نَ شَرَنيِ كِرَ مَسٍنمَ نّ عِ بّ، 
\q1 نَ مَرَ سِ عِ شُن تِمَ سِمَيَ كِرَ نَن شْن مَ. 
\q1  
\v 24 عٍ عِ رَتَنفَمَ فِنّ كٌبِ مَ، 
\q1 نُن شْحّ فِنّ دّ عِحْشُنشِ مَ. 
\q1  
\v 25 عِ نَشَ وَ نَ فِنّ شْن مَ عَ شَ تٌقَنيِ مَ، 
\q1 عِ نَشَ تِن عَ شَ نْ عِ رَ عَ يَيٍ رَ. 
\q1  
\v 26 لَنفٌي فِنّ نَشَن مُ نَ شّمّ تَا، عَ مِشِ قِندِ مَ سٍتَرٍ نَن نَ، 
\q1 كْنْ فِنّ يّنّلَ نَشَن دْشْشِ شّمّ ندٍ شْن، عَ مِشِ قَشَمَ نّ. 
\q1  
\v 27 مِشِ ندٍ نْمَ تّ تٌنفٌدٍ، عَ عَ سَ عَ يُبَ كُي، 
\q1 عَ قَ لُ عَ شَ دٌنمَ مُ فَن؟ 
\q1  
\v 28 مِشِ ندٍ نْمَ عَ حّرّدٍ تّ وٌلٍ تَفِ، 
\q1 عَ قَ لُ عَ سَنيِ مُ فَن؟ 
\q1  
\v 29 نَ مَنِيَمَ نّ عَلْ شّمّ نَشَن يَبُمَ فِنّ شّمّ تَا عِدْشْي رَ. 
\q1 شّمّ يٌ دِن نَ فِنّ رَ، عَ قَمَ حَشَنكَتّ نَن سْتْدٍ. 
\q1  
\v 30 مِشِ مُ يٌمَ مُحّتِ مَ، 
\q1 نَشَن مُحّ تِشِ عَ شَ كَامّ مَ، 
\q1  
\v 31 كْنْ عَ نَ سُشُ قٌ عَ شَ مُحَقٍ سَرٍ قِ، 
\q1 هَلِ نَ قِندِ عَ شَ نَاقُلِ بِرِن نَ. 
\q1  
\v 32 كْنْ شَشِلِتَرٍ نَن تُن يّنّ رَبَمَ فِنّ رَ. 
\q1 عَ عَ شُن نَكَنَ نَ قٍ مْولِ رَ. 
\q1  
\v 33 عَ قٍ شْرْشْي سْتْمَ نّ يَافِ كُي، 
\q1 نَشَن مُ فبِلٍنمَ عَ قْشْ رَ سْنْن، 
\q1  
\v 34 بَرِ مَ تْونّ شّمّ بْحّ رَتٍمَ نّ عَ حَاشِ رَ. 
\q1 فِنّ كَنيِ مُ كِنِكِنِمَ عَ فبٍ حْشْي لْشْي. 
\q1  
\v 35 عَ بْحّ مُ فٌرٌ مَ كْبِرِ رَ. 
\q1 هَلِ عِ عَ فبٍفبٍ قِ عَ مَ، عَ مُ عَ رَ سُشُمَ. 
\c 7  
\s1 يّنّلَ شَ فَنتَنيِ 
\q1  
\v 1 ﭑ مَ دِ، ﭑ مَ وْيّنيِ رَفَتَ عِ بْحّ كُي، 
\q1 ﭑ مَ سّرِيّ شَ لُ عِ سٌندٌنيِ مَ. 
\q1  
\v 2 ﭑ مَ سّرِيّ سُشُ عَلَكٌ عِ شَ سِمَيَ سْتْ، 
\q1 ﭑ مَ شَرَنيِ شَ رَقَن عِ مَ عَلْ عِ يَ قِرِنيِيٍ. 
\q1  
\v 3 ﭑ مَ سّرِيّ شِرِ عِ بّلّشّسٌلٍيٍ رَ، عَ سّبّ عِ سٌندٌنيِ مَ. 
\q1  
\v 4 لْننِ شَ قِندِ عِ مَافِنّ رَ، 
\q1 شَشِلِ قَنيِ شَ قِندِ عِ بَرِ مِشِ رَ. 
\q1  
\v 5 ﭑ مَ سّرِيّ عِ رَتَنفَمَ نّ لَنفٌي مَ، 
\q1 عٍ عِ رَتَنفَمَ نّ يّنّلَ شّمّ تَا عِدْشْي مَ. 
\b  
\q1  
\v 6 لْشْي ندٍ، ﭑ نُ نَ ﭑ مَ بَنشِ كُي، 
\q1 ﭑ تَندٍ مَتٌمَ وُندّرِ رَ. 
\q1  
\v 7 ﭑ نَشَ شَشِلِتَرٍ ندٍ تٌ، 
\q1 سّفّتَلَ نَشَن شَ قَهَامُي مُ فبٌ. 
\q1  
\v 8 عَ نَشَ كِرَ سُشُ نَشَن دَنفِمَ لَنفٌي فِنّ شَ بَنشِ دّ رَ. 
\q1 عَ نُ بَرَ عَ شُن تِ مّننِ رَ. 
\q1  
\v 9 نُنمَرٍ تّمُي نَن نُ عَ رَ، 
\q1 كْي نُ بَرَ سٌ، كُيٍ نُ بَرَ عِقْورْ. 
\b  
\q1  
\v 10 فِنّ ندٍ نَشَ سَ عَ رَلَن، 
\q1 عَ مَشِرِشِ لَنفٌي فِنّ كِ، 
\q1 عَ نُ وَ مَ نَ شّمّ مَدَشُقٍ نّ. 
\q1  
\v 11 فِنّ مُرُتَشِ نَن عَ رَ، 
\q1 نَشَن وْيّن شُي عِتٍ، عَ مِشِ مَتَندِ. 
\q1  
\v 12 عَ حّرّ مَ تَا كُي شّمّ قٍنقٍ رَ. 
\q1  
\v 13 عَ نَشَ نَ شّمّ سُشُ، 
\q1 عَ عَ مَسُنبُ، عَ عَ قَلَ عَ بّ يّتّ عِفبٌحَ رَ، 
\q1  
\v 14 «ﭑ لَايِدِ تٌنفٌ نّ عَلَ بّ، 
\q1 ﭑ بَرَ نَ رَكَمَلِ سّرّشّ رَ تٌ. 
\q1  
\v 15 ﭑ مِنِشِ عِ قٍندٍ نَ نَن مَ. 
\q1 يَكْسِ ﭑ بَرَ عِ تٌ. 
\q1  
\v 16 مِسِرَ سَدٍ دُفِ مَحِنفِشِ نَ ﭑ سَدٍ مَ، 
\q1  
\v 17 عَ نُن لَبُندّ شِرِ قَنيِ مْولِ بِرِن نَ. 
\q1  
\v 18 قَ بٍ، وٌن شَ يّنّ رَبَ هَن فّيسّفّ، 
\q1 وٌن شَ وٌن وَشْنيِ بِرِن نَبَ، 
\q1  
\v 19 بَرِ مَ ﭑ مَ شّمّ مُ نَ بَنشِ، 
\q1 عَ سِفَشِ بِيَاسِ شْنكُيٍ. 
\q1  
\v 20 عَ بَرَ كْبِرِ فبٍفبٍ شَنِن عَ شُن مَ، 
\q1 عَ مُ قَمَ قٌ يِ كِكٍ حْن.» 
\b  
\q1  
\v 21 عَ نَشَ نْ نَ شّمّ رَ عَ شَ كْوتَ سَابُي رَ، 
\q1 عَ نَشَ نْ عَ رَ عَ شَ دّ عِحْشُنيِ رَ. 
\q1  
\v 22‏-23 شّمّ نَشَ بِرَ عَ قْشْ رَ كٍرٍن نَ، 
\q1 عَلْ نِنفٍ نَشَن سِفَقٍ نِنفٍ قَشَدٍ، 
\q1 عَلْ شٍلِ نَشَن عَ سَنيِ رَ سٌقٍ يّلّ كُي، 
\q1 عَلْ شْنِ نَشَن تِقٍ فَنتَنيِ مَ، 
\q1 هَن تَنبّ قَ عَ بْحّ سْشْ، عَ قَشَ، 
\q1 عَ مُ عَ كٌلٌن عَ شَ سِمَيَ دَنمَ مّننِ نّ. 
\q1  
\v 24 يَكْسِ ﭑ مَ دِيٍ، وٌ وٌ تُلِ مَتِ ﭑ نَ، 
\q1 وٌ ﭑ مَ مَسٍنيِ رَ مّ. 
\q1  
\v 25 عِ بْحّ نَشَ عِ مَدَشُ عِ شَ بِرَ نَ فِنّ مْولِ قْشْ رَ، 
\q1 عِ نَشَ عِ حّرّ عَ شَ كِرَ رَ، 
\q1  
\v 26 بَرِ مَ عَ بَرَ مِشِ فبٍفبٍ قَشَ، 
\q1 عَ بَرَ سّنبّمَيٍ يَتِ رَبِرَ. 
\q1  
\v 27 عَ شَ بَنشِ قِندِشِ قَشّ كِرَ نَن نَ، 
\q1 مِشِ فٌرٌ مَ عَلِفِيَمَ دّننَشّ رَ. 
\c 8  
\s1 لْننِ نَشَن قَتَنمَ عَلَ رَ 
\q1  
\v 1 لْننِ مُ مِشِ شِلِمَ شّ؟ 
\q1 شَشِلِ قَنيِ مُ عَ يّتّ مَسٍنمَ شّ؟ 
\q1  
\v 2 عَ شَ مَسٍنيِ تِمَ يِرٍ عِتٍشِ قَرِ، 
\q1 عَ وْيّنمَ كِرَ دّ رَ نُن كِرَ رَلَندٍيٍ. 
\q1  
\v 3 عَ عَ شُي عِتٍمَ تَا سٌدٍ دّ رَ مِشِ دَنفِمَ دّننَشّ. 
\q1 عَ نَشّ،  
\v 4 «عَدَ مَدِيٍ، ﭑ نَ وٌ تَن نَن مَشِلِقٍ، 
\q1 مَسٍنيِ نَ ﭑ يِ رَ عِبُنَدَ مَ بِرِن بّ. 
\q1  
\v 5 شَشِلِتَرٍ شَ شَشِلِ سْتْ، لْننِتَرٍ شَ لْننِ قٍن. 
\q1  
\v 6 وٌ وٌ تُلِ مَتِ ﭑ مَ مَسٍنيِ هَفِفّ رَ، 
\q1 مَسٍنيِ تِنشِنشِ نَشَن مِنِمَ ﭑ دّ عِ. 
\q1  
\v 7 ﭑ نَ نْندِ نَن قَلَقٍ وٌ بّ يِ كِ. 
\q1 تِنشِنتَرٍيَ مُ رَقَن ﭑ مَ قٍقٍ مَ. 
\q1  
\v 8 ﭑ مَ وْيّنيِ بِرِن تِنشِن، 
\q1 وُلٍ نُن سّنِيّنتَرٍحَ يٌ مُ نَ عٍ يَ مَ. 
\q1  
\v 9 نٍيٍ قِيشّ شَشِلِمَ بّ، عٍ تِنشِن لْننِلَيٍ بّ. 
\q1  
\v 10 وٌ شَ ﭑ مَ لْننِ قٍن دَنفِ فبٍتِ رَ، 
\q1 وٌ شَ عَ كٌلٌن شَشِلِ قَنيِ تِدٍ فبٌ شّيمَ قَنيِ بّ، 
\q1  
\v 11 قَهَامُي تِدٍ دَنفِ فّمّ تٌقَنيِ رَ. 
\q1 سٍسٍ مُ نَ نَشَن تِدٍ دَنفِمَ نٍيٍ رَ.» 
\b  
\q1  
\v 12 «ﭑ تَن لْننِ، ﭑ سٌمَ قٍ كُي، ﭑ عَ تَفِ رَبَ. 
\q1  
\v 13 شَ عَلَتَلَ شَ يَرَفَاشُي نَ عِ بّ، 
\q1 عِ قٍ حَاشِ نَن شْنمَ. 
\q1 يّتّ عِفبٌحَ، قٍ حَاشِيٍ، نُن وْيّن كٌبِيٍ، 
\q1 ﭑ نٍيٍ نَن شْنمَ. 
\q1  
\v 14 ﭑ فبٍ نَن نَ مَرَ سِ نُن نْندِ رَ، 
\q1 شَشِلِ قَنيِ نُن سّنبّ كَنيِ نَن ﭑ نَ. 
\q1  
\v 15 ﭑ تَن نَن مَنفّيٍ رَحّرّ مَ، 
\q1 مَنفّ نَشٍيٍ يَامَرِ تِمَ تِنشِنيِ رَ. 
\q1  
\v 16 ﭑ تَن نَن بْشِ يَرٍرَتِيٍ رَحّرّ مَ، 
\q1 ﭑ كُنتِفِيٍ تِمَ عَدَ مَدِيٍ يَ مَ. 
\q1  
\v 17 ﭑ مِشِ نَن شَنُمَ، نَشَن ﭑ شَنُ. 
\q1 نَشٍيٍ ﭑ قٍنمَ، نٍيٍ ﭑ تٌمَ نّ. 
\q1  
\v 18 بَننَيَ نُن بِنيّ نَ ﭑ تَن نَن يِ رَ، 
\q1 هَرِفٍ نَشَن مُ كَنَمَ. 
\q1  
\v 19 ﭑ نَشَن قِمَ مِشِ مَ عَ قَن شّيمَ قَنيِ بّ، 
\q1 عَ شَ فٍينِ دَنفِ فبٍتِ رَ. 
\q1  
\v 20 ﭑ نَن ﭑ حّرّ مَ نْندِ كِرَ نَن شْن مَ، 
\q1 تِنشِنيِ نَ دّننَشّ، 
\q1  
\v 21 عَلَكٌ ﭑ شَنُنتٍنيِ شَ هَرِفٍ سْتْ كّ رَ، 
\q1 قٍ قَنيِ شَ لُ عٍ يِ رَ دُنِحّءِفِرِ كُي.» 
\b  
\q1  
\v 22 «عَلَتَلَ نَشَ ﭑ دَا عَ شَ وَلِ بِرِن قْلّ رَ. 
\q1  
\v 23 ﭑ نُ نَ كَبِ قْلّ، بٍينُن بْشِ شَ دَا. 
\q1  
\v 24 ﭑ بَرِ تّمُي بَا مُ نُ نَ، دُلٌنيِ مُ نُ نَ. 
\q1  
\v 25 ﭑ بَرِ نّ بٍينُن فٍيَيٍ شَ مِنِ، 
\q1  
\v 26 بٍينُن بْشِ نُن قْتْنيِ شَ دَا. 
\q1  
\v 27 عَ تٌ نُ كٌورٍ دَاقٍ، ﭑ نُ نَ. 
\q1 عَ تٌ نُ كٌورٍ وَلَشّ عِتَلَقٍ، ﭑ نُ نَ. 
\q1  
\v 28 عَ تٌ نُ نُشُي تِقٍ كٌورٍ مَ، ﭑ نُ نَ. 
\q1 عَ تٌ نُ يٍ رَ مِنِقٍ سّنبّ رَ بْشِ بُن، ﭑ نُ نَ. 
\q1  
\v 29 عَ تٌ نُ نَانِنيِ سَقٍ بَا بّ 
\q1 عَلَكٌ يٍ نَشَ قَ بَنبَرَن حّ، ﭑ نُ نَ. 
\q1 عَ تٌ نُ دُنِحَ بُنيِ دْشْقٍ، ﭑ نُ نَ. 
\q1  
\v 30 ﭑ قَن نُ نَ عَ قّ مَ عَ مَلِقٍ رَ، 
\q1 لْشْ يٌ لْشْ ﭑ قِندِ عَ بّ سّيوّ نَن نَ، 
\q1 ﭑ قَ ﭑ حّلّشِن عَ يَ عِ تّمُي بِرِن. 
\q1  
\v 31 ﭑ حّلّشِنشِ عَ شَ دُنِحَ دَاشِ نَن نَ، 
\q1 عَ قِندِشِ ﭑ بّ سّيوّ رَ لُقٍ رَ عَدَ مَدِيٍ تَفِ.» 
\b  
\q1  
\v 32 «يَكْسِ ﭑ مَ دِيٍ، وٌ وٌ تُلِ مَتِ ﭑ نَ، 
\q1 سّيوّ نَ مِشِ بّ نَشَن بِرَ مَ ﭑ مَ كِرَ قْشْ رَ. 
\q1  
\v 33 وٌ وٌ تُلِ مَتِ ﭑ مَ شَرَنيِ رَ، 
\q1 وٌ شَ قِندِ لْننِلَيٍ رَ. 
\q1 وٌ نَشَ عَ رَبٌلٌ دٍ. 
\q1  
\v 34 سّيوّ نَ مِشِ بّ نَشَن عَ تُلِ مَتِمَ ﭑ نَ، 
\q1 نَشَن لُمَ ﭑ سّيتِ مَ تّمُي بِرِن، 
\q1 نَشَن ﭑ مَمّمَ نَادّ رَ. 
\q1  
\v 35 ﭑ كٌلٌنمَ بَرَ كِسِ، عَلَتَلَ بَرَ هِننّ نَ كَنيِ رَ. 
\q1  
\v 36 كْنْ ﭑ فٍرٍقَ تَن بَرَ عَ يّتّ بْنْ، 
\q1 ﭑ شْنمِشِ نَ قَشّ قٍنقٍ نَ كِ نّ.» 
\c 9  
\s1 شَشِلِمَيَ نُن لْننِتَرٍحَ 
\q1  
\v 1 لْننِ بَرَ عَ شَ بَنشِ تِ قَنيٍ سٌلٌقٍرٍ قَرِ. 
\q1  
\v 2 عَ بَرَ شُرُ سٍ ندٍ قَشَ، عَ وّنِ يَءِلَن، 
\q1 عَ شَ دْشْ تٍيبِلِ رَ عَ دّفٍدٍ. 
\q1  
\v 3 عَ بَرَ شّيرَيٍ شّي تَا كُي مِشِ شِلِقٍ رَ، 
\q1  
\v 4 «وٌ تَن شَشِلِتَرٍيٍ نُن قَهَامُتَرٍ، 
\q1 وٌ قَ بٍ. 
\q1  
\v 5 وٌ شَ قَ ﭑ مَ تَامِ دٌن، 
\q1 وٌ شَ قَ ﭑ مَ وّنِ قَنيِ مِن. 
\q1  
\v 6 وٌ شَ فبِلٍن قٍ حَاشِيٍ قْشْ رَ، 
\q1 وٌ شَ بِرَ شَشِلِمَ شَ كِرَ قْشْ رَ.» 
\q1  
\v 7 مِشِ يٌ نَشَن كَتَمَ يّتّ عِفبٌي مَتِنشِندٍ، 
\q1 عَ مَرَحَاشُي نَن سْتْمَ. 
\q1 مِشِ يٌ نَشَن كَتَمَ مِشِ حَاشِ رَ سِدٍ، 
\q1 عَ كٌنبِ نَن سْتْمَ. 
\q1  
\v 8 شَ عِ شُرُتَرٍ رَ سِ، عَ عِ شْنمَ نّ. 
\q1 شَ عِ شَشِلِمَ رَ سِ، عَ عِ شَنُمَ نّ. 
\q1  
\v 9 عِ نَشَن قَلَمَ لْننِلَ بّ، 
\q1 عَ ندٍ نَن سَمَ عَ شَ لْننِ شُن. 
\q1 عِ نَشَن مَسٍنمَ تِنشِنتْي بّ، 
\q1 عَ ندٍ نَن سَمَ عَ شَ تِنشِنيِ شُن. 
\b  
\q1  
\v 10 لْننِ قْلْمَ عَلَتَلَ شَ يَرَفَاشُي نَن مَ. 
\q1 قَهَامُي سْتْمَ عَلَ سّنِيّنتْي كٌلٌنقٍ نَن مَ. 
\q1  
\v 11 عِ شَ دُنِحّءِفِرِ شْن كُيَمَ نّ لْننِ رَ، 
\q1 عِ شَ سِمَيَ حّ كْنتِ شُن مَسَمَ نّ قَهَامُي رَ. 
\q1  
\v 12 شَشِلِمَ لْننِ سَرٍ نَن سْتْمَ، 
\q1 كْنْ مِشِ نَشَن يٌمَ عَ بٌورٍ مَ، نَ تْورّ نَن تُن سْتْمَ. 
\b  
\q1  
\v 13 شَشِلِتَرٍحَ لُشِ نّ عَلْ فِنّ نَشَن دّ وُيَ، 
\q1 عَ مُ شُرُ، عَ مُ قٍ كٌلٌن. 
\q1  
\v 14 عَ دْشْمَ عَ شَ بَنشِ سٌدٍ دّ نَن نَ 
\q1 دْشْسٍ مَ نَشَن نَ يِرٍ عِتٍشِ، 
\q1  
\v 15 عَلَكٌ عَ شَ دَنفِ مِشِيٍ شِلِ عَ شُي عِتٍشِ رَ، 
\q1 نَشٍيٍ نَ عٍ حّرّقٍ كِرَ تِنشِنشِيٍ شْن مَ. 
\q1  
\v 16 عَ عَ قَلَمَ مِشِيٍ بّ نَشٍيٍ مُ قَهَامُي سْتْشِ، 
\q1 «وٌ تَن شَشِلِتَرٍيٍ، وٌ قَ بٍ. 
\q1  
\v 17 مِنسٍ مُحَشِ حْشُن، 
\q1 تَامِ دٌنشِ دُنشُي رَ، نَ قَن حْشُن.» 
\q1  
\v 18 عٍ مُ عَ كٌلٌن قَشّ دِ مِ نَن مّننِ رَ. 
\q1 مِشِ نَشٍيٍ عَ شَ شِلِ رَتِنمَ، 
\q1 نٍيٍ شُن تِشِ عَلِفِيَمَ نَن نَ. 
\c 10  
\s1 تَالِ وْيّنيِيٍ 
\d  
\v 1 سُلٍمَنِ شَ تَالِيٍ 
\q1 دِ شَشِلِمَ، عَ بَبَ رَ سّيوَ مَ نّ، 
\q1 كْنْ دِ لْننِتَرٍ قِندِ مَ نِمِسّ نَن نَ عَ نفَ بّ. 
\q1  
\v 2 هَرِفٍ سْتْ كِ حَاشِ مُ سٍسٍ فَسَمَ مِشِ مَ، 
\q1 كْنْ تِنشِنيِ نَن سِمَيَ قِمَ مِشِ مَ. 
\q1  
\v 3 عَلَتَلَ مُ مِشِ تِنشِنشِ لُمَ كَامّ رَ، 
\q1 كْنْ عَ تٌندِ مَ نّ مِشِ حَاشِ وَشْنقٍ رَ. 
\q1  
\v 4 بّلّشّ وَلِتَرٍ سٍتَرٍحَ نَن بّندُنمَ مِشِ مَ، 
\q1 بّلّشّ وَكِلِشِ بَننَيَ نَن قِمَ مِشِ مَ. 
\q1  
\v 5 دِ نَشَن وَكِلِمَ شّ شَبَ تّمُي عَ قِندِشِ شَشِلِمَ نَن نَ، 
\q1 كْنْ دِ نَشَن شِمَ شّ شَبَ تّمُي عَ قِندِشِ يَافِ نَن نَ عَ بَبَ بّ. 
\q1  
\v 6 بَرَكّ نَ مِشِ تِنشِنشِ قْشْ رَ، 
\q1 فبَلٌي بِرَ نّ تِنشِنتَرٍيٍ قْشْ رَ. 
\q1  
\v 7 تِنشِنتْي شِلِ قِندِ مَ دُبَ نَن نَ، 
\q1 كْنْ مِشِ حَاشِ شِلِ لْيمَ نّ. 
\q1  
\v 8 لْننِلَ تِنمَ لُدٍ سّرِيّ بُن مَ، 
\q1 كْنْ لْننِتَرٍ شَ وْيّنيِ عَ شُن نَكَنَمَ نّ. 
\q1  
\v 9 مِشِ نَشَن حّرّ مَ نْندِ رَ، 
\q1 عَ حّرّ مَ كَنتَرِ نَن كُي، 
\q1 كْنْ مِشِ نَشَن مُ عَ حّرّ مَ تِنشِنيِ رَ، 
\q1 نَ تَن قَمَ رَيَرَبِدٍ نّ. 
\q1  
\v 10 مِشِ نَشَن نْندِ نْشُنمَ عَ بٌورٍيٍ مَ، عَ عٍ تْورْقٍ نّ. 
\q1 دّ كَنيِ شَشِلِتَرٍ عَ شُن نَكَنَمَ نّ. 
\q1  
\v 11 وْيّنيِ تِنشِنشِ تِنشِنتْي شَ سِمَيَ شْن كُيَمَ نّ، 
\q1 كْنْ مِشِ حَاشِ تَن دّ فبَلٌي رَ مِنِمَ نّ. 
\q1  
\v 12 فبّسّنشْننّيَ فٍرٍ رَكٍلِمَ نّ، 
\q1 كْنْ مَرَقَنيِ دِحّمَ نّ قٍ كَنَشِ بِرِن مَ. 
\q1  
\v 13 لْننِ نَن نَ شَشِلِمَ نّنيِ بُن مَ، 
\q1 كْنْ فبٍندٍفٍلَ نَن سِنمَ شَشِلِتَرٍ قَرِ مَ. 
\q1  
\v 14 قٍ كٌلٌنيِ رَفَتَشِ لْننِلَيٍ يِ رَ، 
\q1 كْنْ لْننِتَرٍ شَ وْيّنيِ قٍ نَن تُن كَنَمَ. 
\q1  
\v 15 بَننَ مِشِ هَرِفٍ قِندِشِ عَ كَنتَ سٍ نَن نَ، 
\q1 كْنْ سٍتَرٍحَ نَن مِسِكِينّ شُن نَكَنَمَ. 
\q1  
\v 16 تِنشِنتْي شَ فٍينِ قِندِشِ سِمَيَ نَن نَ، 
\q1 مِشِ حَاشِ سَرٍ قِندِشِ حَشَنكَتّ نَن نَ. 
\q1  
\v 17 مِشِ نَشَن شُرُي قَهَامُمَ، عَ تِشِ سِمَيَ كِرَ نَن شْن، 
\q1 كْنْ نَشَن مّيمَ نَ مَرَ سِ رَ، عَ بْنْمَ نّ. 
\q1  
\v 18 وُلٍ قَلّ فبّسّنشْننّيَ رَفَتَمَ نّ، 
\q1 شَشِلِتَرٍ نَن مِشِ تْوحّفّمَ. 
\q1  
\v 19 وْيّنيِ رَوُيَقٍ نْمَ مِشِ قِندِدٍ يُنُبِتْي رَ، 
\q1 كْنْ شَشِلِمَ تَن عَ دّ سُشُمَ نّ. 
\q1  
\v 20 تِنشِنتْي شَ وْيّنيِ تِدٍ فبٌ فبٍتِ بّ، 
\q1 كْنْ مِشِ حَاشِ بْحّ تِدٍ شُرُن. 
\q1  
\v 21 تِنشِنتْي شَ مَرَ سِ مِشِ رَحّرّ مَ نّ، 
\q1 كْنْ شَشِلِتَرٍ قَشَمَ لْننِتَرٍحَ نَن كُي. 
\q1  
\v 22 عَلَتَلَ شَ بَرَكّ نَن مِشِ بَننَمَ، 
\q1 مِشِ سّنبّ مُ سٍسٍ سَمَ نَ قَرِ. 
\q1  
\v 23 قٍ حَاشِ رَقَن مِشِ كٌبِ مَ، 
\q1 كْنْ لْننِ رَقَن شَشِلِمَ مَ. 
\q1  
\v 24 مِشِ حَاشِ هّنمّمَ قٍ نَشَن نَ، نَ نَن عَ لِمَ. 
\q1 مِشِ تِنشِنشِ وَشْنقٍ، عَلَ نَن نَ نَبَمَ عَ بّ. 
\q1  
\v 25 قٍ شْرْشْي نَ قَ، مِشِ حَاشِ يٌ مُ تِمَ، 
\q1 كْنْ تِنشِنتْي تَن تِمَ نّ عَبَدَن. 
\q1  
\v 26 مُلُشُنيِ قٍ نَشَن نِيَمَ مِشِ حِنيِ رَ، 
\q1 تُورِ قٍ نَشَن نِيَمَ مِشِ يَ رَ، 
\q1 تُننَشْنّ قَن نَ نَن نِيَمَ عَ شّيمَ رَ. 
\q1  
\v 27 عَلَتَلَ شَ يَرَفَاشُي سِمَيَ نَن قِمَ مِشِ مَ، 
\q1 كْنْ مِشِ حَاشِيٍ شَ سِمَيَ شْن مُ كُيَ. 
\q1  
\v 28 مِشِ تِنشِنشِيٍ شَ تِنَ قِندِ مَ عٍ بّ سّيوّ نَن نَ، 
\q1 كْنْ مِشِ حَاشِيٍ شَ تِنَ قِندِ مَ عٍ بّ تْورّ نَن نَ. 
\q1  
\v 29 عَلَتَلَ شَ كِرَ قِندِشِ كَنتَرِ نَن نَ مِشِ تِنشِنشِيٍ بّ، 
\q1 كْنْ عَ قِندِشِ هَلَكِ نَن نَ تِنشِنتَرٍيٍ بّ. 
\q1  
\v 30 تِنشِنتْي مُ بِرَ مَ قٍقٍ مَ، 
\q1 كْنْ مِشِ حَاشِ مُ لُمَ بْشِ مَ. 
\q1  
\v 31 مِشِ تِنشِنشِ دّ لْننِ نَن مَسٍنمَ، 
\q1 كْنْ وُلٍ قَلّ نّنيِ بٌلٌنمَ نّ. 
\q1  
\v 32 تِنشِنتْي دّ قٍ قَنيِ نَن قَلَمَ، 
\q1 كْنْ مِشِ حَاشِ قٍ حَاشِ نَن قَلَمَ. 
\c 11  
\s1 سِكٍيلِ كَمَلِتَرٍ 
\q1  
\v 1 عَلَتَلَ سِكٍيلِ كَمَلِتَرٍ نَن شْنشِ، 
\q1 كْنْ سِكٍيلِ كَمَلِشِ رَقَن عَ مَ. 
\q1  
\v 2 يّتّ عِفبٌحَ قِندِ مَ يَافِ نَن نَ، 
\q1 كْنْ يّتّ مَفٌرٍ قِندِ مَ لْننِ نَن نَ. 
\q1  
\v 3 تِنشِنيِ تِنشِنتْي رَحّرّ مَ نّ، 
\q1 كْنْ تِنشِنتَرٍيَ يَنقَنتٍ هَلَكِمَ نّ. 
\q1  
\v 4 نَاقُلِ مُ مِشِ مَلِمَ عَلَ شَ كِيتِ لْشْي، 
\q1 تِنشِنيِ فبَنسَن نَن مِشِ رَتَنفَمَ نَ قَشّ مَ. 
\q1  
\v 5 تِنشِنيِ تِنشِنتْي رَحّرّ مَ نّ كِرَ قَنيِ شْن، 
\q1 كْنْ حَاشُحَ مِشِ حَاشِ هَلَكِمَ نّ. 
\q1  
\v 6 تِنشِنيِ تِنشِنتْي رَكِسِمَ نّ، 
\q1 يَنقَنتٍ تَن لُمَ مِلّ فَنتَنيِ نَن كُي. 
\q1  
\v 7 مِشِ حَاشِ نَ قَشَ، سٍسٍ مُ سْونّيَمَ عَ بّ سْنْن. 
\q1 عَ شَ نَاقُلِ مُ سّنبّ يٌ قِمَ عَ مَ نَ تّمُي. 
\q1  
\v 8 تِنشِنتْي رَتَنفَمَ نّ حَشَنكَتّ مَ، 
\q1 مِشِ حَاشِ تَن لُمَ نَ حَشَنكَتّ نَن كُي. 
\q1  
\v 9 مِشِ كٌبِ عَ بٌورٍ شُن نَكَنَمَ عَ شَ وْيّنيِيٍ نَن نَ، 
\q1 كْنْ تِنشِنتْي رَتَنفَمَ نّ عَ شَ لْننِ سَابُي رَ. 
\q1  
\v 10 تِنشِنتْييٍ نَ هّيرِ سْتْ، تَا حّلّشِنمَ نّ. 
\q1 مِشِ حَاشِ نَ قَشَ، بِرِن بَرَ فٍينِ. 
\q1  
\v 11 تِنشِنتْييٍ مُنَقَنيِ رَقَمَ نّ عَ شَ تَا مَ، 
\q1 مِشِ حَاشِيٍ تَن تَا شُن نَكَنَمَ عٍ شَ وْيّنيِيٍ نَن نَ. 
\q1  
\v 12 لْننِتَرٍ يٌمَ نّ عَ بٌورٍ مَ، 
\q1 لْننِلَ تَن لُمَ سَبَرِ نَن كُي. 
\q1  
\v 13 نَاقِشِ فُندٌ مَكّنّنمَ نّ، 
\q1 دُفُتّفّ تَن عَ سُتُرَ مَ نّ. 
\q1  
\v 14 مَرَ سِتَرٍحَ حَمَ رَبِرَ مَ نّ، 
\q1 كْنْ مَرَ سِمَ وُيَشِ تَن قِندِ مَ كِسِ نَن نَ عٍ بّ. 
\q1  
\v 15 مِشِ يٌ تَانِ مِشِ بّ قٍ ندٍ مَ، عَ قَمَ نّ نِمِسَدٍ. 
\q1 تٌندِقٍ نَ رَبَدٍ، نَ نَن قِسَ. 
\q1  
\v 16 فِنّ قَنيِيٍ بِنيّ سْتْمَ نّ، 
\q1 كْنْ شّمّ حَاشِ نَاقُلِ نَن تُن سْتْمَ. 
\q1  
\v 17 شّمّ قَنيِ حّرّ كِ عَ مَلِمَ نّ، 
\q1 كْنْ شّمّ حَاشِ تْورّ نَن بّندُنمَ عَ يّتّ مَ. 
\q1  
\v 18 مِشِ حَاشِ شَ فٍينِ قَمَ نّ عَ مَدَشُدٍ. 
\q1 تِنشِنتْي تَن شَ فٍينِ قِندِ مَ سَرٍ قَنيِ نَن نَ عَ بّ. 
\q1  
\v 19 تِنشِنتْي كِسِمَ نّ، 
\q1 كْنْ تِنشِنتَرٍ قَشّ نَن سْتْمَ. 
\q1  
\v 20 بْحّ حَاشِ مُ رَقَن عَلَتَلَ مَ، 
\q1 عَ وَ مَ تِنشِنيِ نَن شْن. 
\q1  
\v 21 مِشِ حَاشِ قَمَ نّ قٍ حَاشِ سْتْدٍ، 
\q1 كْنْ تِنشِنتْي تَن كِسِمَ نّ. 
\q1  
\v 22 فِنّ تٌقَنيِ شَشِلِتَرٍ لُمَ نّ عَلْ 
\q1 شُرُندّ شّيمَ دَاشِ شْسّ حْي رَ. 
\q1  
\v 23 تِنشِنتْي قَمَ نّ قٍ قَنيِ سْتْدٍ، 
\q1 كْنْ شْنّ نَن لُمَ مِشِ حَاشِ تَن بّ. 
\q1  
\v 24 مِشِ نَشَن بّلّشّ يٍلٍقُ كِ تِدٍ، عَ بَننَيَ سْتْمَ نّ، 
\q1 كْنْ مِشِ كُمَشِ تَن قِندِ مَ سٍتَرٍ نَن نَ. 
\q1  
\v 25 مِشِ نَشَن عَ هَرِفٍ عِتَشُنمَ، عَ قَمَ نّ هَرِفٍ سْتْدٍ. 
\q1 يٍ شْلِ مُ لُمَ مِشِ مَ نَشَن عَ بٌورٍ كِمَ يٍ رَ. 
\q1  
\v 26 حَمَ مِشِ دَنكَمَ نّ نَشَن تٌندِ مَ بَلٌي مَتِدٍ، 
\q1 عٍ دُبَمَ نّ مِشِ بّ نَشَن تِنمَ حَمَ شَ ندٍ سْتْ. 
\q1  
\v 27 قٍ قَنيِ رَبَيٍ، قٍ قَنيِ سْتْمَ نّ، 
\q1 كْنْ قٍ حَاشِ رَبَيٍ، قٍ حَاشِ نَن سْتْمَ. 
\q1  
\v 28 مِشِ نَشَن عَ شَشِلِ تِمَ عَ شَ نَاقُلِ رَ، 
\q1 عَ قَمَ نّ بِرَدٍ، 
\q1 تِنشِنتْي تَن لُمَ نّ عَلْ بُرّشّ نَشَن مُ لِسِمَ. 
\q1  
\v 29 مِشِ نَشَن تْورّ بّندُنمَ عَ شَ دٍنبَيَ مَ، 
\q1 قٍ قُقَقُ نَن قَمَ قِندِدٍ عَ كّ رَ. 
\q1 لْننِتَرٍ قَمَ لُدٍ نّ لْننِلَ شَ يَامَرِ بُن مَ. 
\q1  
\v 30 تِنشِنتْييٍ كِسِمَ نّ، 
\q1 لْننِلَيٍ مِشِيٍ مَسْتْمَ نّ. 
\q1  
\v 31 شَ تِنشِنتْي عَ سَرٍ سْتْ دُنِحَ مَ، 
\q1 مِشِ حَاشِ نُن يُنُبِتْي قَن عَ سْتْمَ نّ. 
\c 12  
\s1 مَرَ سِ تِدٍ 
\q1  
\v 1 مِشِ يٌ تِنمَ مَرَ سِ رَ، نَ وَ مَ لْننِ نَن شْن، 
\q1 نَشَن تَن مُ تِنمَ نَ رَ، دَشُي نَن عَ رَ. 
\q1  
\v 2 عَلَتَلَ هِننّمَ نّ مِشِ قَنيِ رَ، 
\q1 عَ مِشِ كٌبِ تَن حَشَنكَتَ. 
\q1  
\v 3 حَاشُحَ مُ شِلِ شُنفبٍ قِمَ مِشِ مَ، 
\q1 كْنْ سٍسٍ مُ عَ نِيَمَ تِنشِنتْي سَنكٍيٍ شَ تَلَ. 
\q1  
\v 4 فِنّ قَنيِ قِندِ مَ عَ شَ مْرِ شَ شُننَكٍلِ نَن نَ، 
\q1 فِنّ حَاشِ تَن لُمَ نّ عَلْ كُلِ نَشَن نَ حِنيِ كُي. 
\q1  
\v 5 مِشِ تِنشِنشِيٍ شَ مَحْشُنيِ قَن، 
\q1 كْنْ مِشِ حَاشِ شَ مَرَ سِ مِشِ مَدَشُمَ نّ. 
\q1  
\v 6 مِشِ حَاشِ شَ وْيّنيِ مِشِ قَشَمَ نّ، 
\q1 كْنْ تِنشِنتْي تَن شَ وْيّنيِ مِشِ رَكِسِمَ نّ. 
\q1  
\v 7 مِشِ حَاشِيٍ شَ قٍ قَمَ نّ كَنَدٍ، 
\q1 كْنْ سٍسٍ مُ مِشِ تِنشِنشِيٍ شَ دٍنبَيَيٍ تٌمَ. 
\q1  
\v 8 حَمَ لْننِلَيٍ مَتْشْمَ نّ، 
\q1 كْنْ بْحّ حَاشِ كَنيِيٍ، عٍ يٌمَ نّ نٍيٍ مَ. 
\q1  
\v 9 يّتّ مَفٌرٍ، مَلِمَ كٍرٍن ثٍتِ نَ نَشَن بّ، 
\q1 عَ قِسَ يّتّ عِفبٌي بّ، بَلٌي مُ نَ نَشَن يِ رَ. 
\q1  
\v 10 تِنشِنتْي مّينِمَ نّ عَ شَ شُرُ سٍ مَ، 
\q1 كْنْ مِشِ حَاشِ تَن يَ عِشَرَ. 
\q1  
\v 11 بْشِ رَوَلِ بَلٌي سْتْمَ نّ، 
\q1 كْنْ لْننِتَرٍ بِرَ مَ قٍ قُقَقُ نَن قْشْ رَ. 
\q1  
\v 12 مِشِ حَاشِ هَرِفٍ قٍنمَ تِنشِنتَرٍيَ رَ، 
\q1 كْنْ تِنشِنتْي سَنكٍيٍ تَن سِفَمَ بْشِ سُشُ رَ نّ. 
\q1  
\v 13 قٍ حَاشِ قِندِ مَ فَنتَنيِ نَن نَ مِشِ حَاشِ بّ، 
\q1 كْنْ تِنشِنتْي عَ يّتّ رَتَنفَمَ نّ نَ تْورّ مَ. 
\q1  
\v 14 وْيّن قَنيِ قِندِ مَ شُننَكٍلِ نَن نَ مِشِ بّ، 
\q1 عَلْ مِشِ تٌ عَ شَ وَلِ سَرٍ سْتْمَ. 
\q1  
\v 15 لْننِتَرٍ عَ مَحْشُنشِ عَ عَ شَشِلِ قَن، 
\q1 لْننِلَ تَن مَرَ سِ نَن قٍنمَ. 
\q1  
\v 16 لْننِتَرٍ بْحّ تٍ رَقُرَ، 
\q1 لْننِلَ تَن مُ كٌنبِ يَابِمَ. 
\q1  
\v 17 تِنشِنتْي نْندِ نَن قَلَمَ عَ بٌورٍ شُن، 
\q1 كْنْ سٍيدٍ بَ حَاشِ وُلٍ نَن تُن مَدْشْمَ. 
\q1  
\v 18 مِشِ دّ وُيَشِ شَ وْيّنيِ مِشِ مَشْنْمَ نّ عَلْ سَنتِدّفّمَ، 
\q1 كْنْ لْننِلَ تَن شَ وْيّنيِ مِشِ نَن نَيَلَنمَ. 
\q1  
\v 19 نْندِ قَلّ شَ مَسٍنيِ مُ مَسَرَ مَ، 
\q1 كْنْ وُلٍ قَلّ شَ مَسٍنيِ لُمَ نّ مَسَرَ رَ. 
\q1  
\v 20 مَءِقُي نَن نَ مِشِ حَاشِ بْحّ كُي، 
\q1 سّيوّ نَ مِشِ بّ، نَشَن فٍرٍ رَشُبٍنمَ. 
\q1  
\v 21 قٍ حَاشِ يٌ مُ تِنشِنتْي لِمَ، 
\q1 كْنْ مِشِ حَاشِيٍ نَ نَن تُن سْتْمَ. 
\q1  
\v 22 عَلَتَلَ وُلٍ قَلّيٍ شْنمَ نّ، 
\q1 عَ هِننّمَ نّ نْندِ قَلّيٍ رَ. 
\q1  
\v 23 لْننِلَ عَ شَ لْننِ مَسٍن تّمُي كٌلٌن، 
\q1 لْننِتَرٍ تَن عَ شَ دَشُحَ نَن عِقَلَمَ عَ شُي عِتٍشِ رَ. 
\q1  
\v 24 تُننَبّشِلَيٍ قِندِ مَ مَنفّيٍ نَن نَ، 
\q1 كْنْ تُننَشْنّيٍ قِندِ مَ كٌنيِيٍ رَ. 
\q1  
\v 25 كْنتْقِلِ لُمَ نّ مِشِ لَهَلّ مَسَرَ رَ، 
\q1 وْيّن قَنيِ تَن عَ بْحّ رَ سّيوَ مَ نّ. 
\q1  
\v 26 تِنشِنتْي كِرَ تِنشِنشِ مَسٍنمَ نّ عَ بٌورٍ بّ، 
\q1 مِشِ حَاشِ تَن عَ بٌورٍ رَلْيمَ نّ. 
\q1  
\v 27 كٌيِنمَ تُننَشْنّ مُ عَ شَ تْوكّ فَنمَ، 
\q1 كْنْ تُننَبّشِلَ مّينِمَ نّ عَ سْتْسٍيٍ مَ. 
\q1  
\v 28 سِمَيَ نَ كِرَ تِنشِنشِ نَن شْن مَ. 
\q1 قَشّ مُ قُلَمَ نَ كِرَ رَ. 
\c 13  
\s1 شُرُتَرٍ تٌندِ مَ مَرَ سِ سُشُقٍ 
\q1  
\v 1 دِ لْننِلَ عَ تُلِ مَتِمَ عَ بَبَ شَ مَرَ سِ نَن نَ، 
\q1 كْنْ شُرُتَرٍ مُ عَ تُلِ مَتِمَ مَرَ سِ رَ. 
\q1  
\v 2 مِشِ قَنيِ شَ وْيّنيِيٍ قٍ قَنيِ نَن نَمِنِمَ، 
\q1 كْنْ يَنقَنتٍ تَن وَ مَ فٍرٍ نَن شْن. 
\q1  
\v 3 مِشِ نَشَن عَ دّ سُشُمَ، عَ شُن نَكٍلِمَ نّ، 
\q1 نَشَن دّ وُيَشِ، نَ تَن عَ شُن نَكَنَمَ نّ. 
\q1  
\v 4 تُننَشْنّ شَ قٍقٍ مُ سْونّيَمَ، 
\q1 كْنْ تُننَبّشِ هَرِفٍ فبٍفبٍ سْتْمَ نّ. 
\q1  
\v 5 وُلٍ مُ رَقَن تِنشِنتْي مَ، 
\q1 كْنْ مِشِ حَاشِ تَن عَ يّتّ رَيَافِمَ نّ. 
\q1  
\v 6 تِنشِنيِ تِنشِنتْي مَكَنتَمَ نّ، 
\q1 قٍ حَاشِ يُنُبِتْي تَن نَهَلَكِمَ نّ. 
\q1  
\v 7 مِشِ ندٍ عَ يّتّ قِندِ مَ بَننَ نَن نَ، 
\q1 كْنْ سٍسٍ مُ عَ يِ رَ. 
\q1 بٌورٍ تَن عَ يّتّ قِندِ مَ سٍتَرٍ نَن نَ، 
\q1 كْنْ هَرِفٍ فبٍفبٍ نَ عَ يِ رَ. 
\q1  
\v 8 بَننَ شَ كْبِرِ عَ شُن سَرَ مَ مِشِ كٌبِيٍ مَ، 
\q1 كْنْ مِشِ كٌبِيٍ مُ سٍسٍ قٍنمَ سٍتَرٍ رَ. 
\q1  
\v 9 تِنشِنتْي لُشِ نّ عَلْ لَنثُي دّشّشِ، 
\q1 مِشِ حَاشِ تَن شَ لَنثُي شُبٍنمَ نّ. 
\q1  
\v 10 يّتّ عِفبٌحَ فٍرٍ نَن نَبُلَمَ، 
\q1 كْنْ مَرَ سِ رَ مّقٍ قِندِ مَ لْننِ نَن نَ. 
\q1  
\v 11 هَرِفٍ نَشَن سْتْمَ تِنشِنتَرٍيَ كُي، عَ سِفَمَ شُرُن نَ نّ، 
\q1 كْنْ هَرِفٍ نَشَن سْتْمَ دْيِ دْيِ تِنشِنيِ كُي، نَ سِفَمَ فبٌ رَ نّ. 
\q1  
\v 12 شَ مِشِ مُ عَ وَشْنقٍ سْتْمَ، عَ تْورْ مَ نّ، 
\q1 كْنْ شَ عَ سْتْ، عَ سّيوَ مَ نّ دُنِحّءِفِرِ كُي. 
\q1  
\v 13 مِشِ نَشَن يٌمَ مَرَ سِ مَ، عَ نَ سَرٍ سْتْمَ نّ، 
\q1 نَشَن تَن مَرَ سِ بِنيَمَ، نَ قَمَ نّ سَرٍ قَنيِ سْتْدٍ. 
\q1  
\v 14 شَشِلِمَ شَ مَرَ سِ قِندِ مَ سِمَيَ نَن نَ، 
\q1 عَ مِشِ رَتَنفَمَ فَنتَنيِ حَاشِ مَ. 
\q1  
\v 15 قَهَامُي قِندِ مَ هِننّ نَن نَ مِشِ بّ، 
\q1 كْنْ مِشِ حَاشِ تَن شَ كِرَ شْرْشْ. 
\q1  
\v 16 شَشِلِمَ عَ شَ لْننِ رَوَلِمَ، 
\q1 كْنْ شَشِلِتَرٍ دَشُحَ نَن تُن قُنقُنمَ. 
\q1  
\v 17 شّيرَ تِنشِنتَرٍ قِندِ مَ تْورّ نَن سَابُي رَ، 
\q1 شّيرَ تِنشِنشِ تَن قَمَ يَلَنيِ نَن نَ. 
\q1  
\v 18 مِشِ نَشَن تٌندِ مَ مَرَ سِ رَ، عَ سٍتَرٍحَ نُن يَافِ سْتْمَ نّ، 
\q1 كْنْ نَشَن مَرَ سِ رَ مّمَ، عَ بِنيّ نَن سْتْمَ. 
\q1  
\v 19 عَ حْشُن، مِشِ وَشْنقٍ نَ رَبَ عَ بّ، 
\q1 كْنْ شَشِلِتَرٍ مُ تِنمَ فبِلٍندٍ عَ وَشْنقٍ حَاشِ قْشْ رَ. 
\q1  
\v 20 مِشِ نَ لُ شَشِلِمَ قْشْ رَ، عَ قَن شَشِلِ سْتْمَ نّ، 
\q1 كْنْ لْننِتَرٍيٍ شَ مَلَن بٌورٍحَ، قِندِ مَ تْورّ نَن تُن نَ. 
\q1  
\v 21 يُنُبِتْي سَرٍ قِندِ مَ قٍ حَاشِ نَن نَ، 
\q1 تِنشِنتْي تَن سَرٍ قِندِ مَ هّيرِ نَن نَ. 
\q1  
\v 22 مِشِ قَنيِ كّ لُمَ عَ شَ مَمَدِيٍ نَن بّ، 
\q1 يُنُبِتْي تَن كّ لُمَ تِنشِنتْييٍ نَن بّ. 
\q1  
\v 23 بَلٌي فبٍفبٍ مِنِمَ نّ سٍتَرٍ شَ شّ مَ، 
\q1 كْنْ تِنشِنتَرٍيَ لُمَ نّ كَسَرَ رَ. 
\q1  
\v 24 بَبّ نَشَن مُ عَ شَ دِ شُرُ مَ لُشُسِنيِ رَ، 
\q1 نَ دِ مُ رَقَن عَ مَ. 
\q1 بَبّ نَشَن عَ شَ دِ شُرُ مَ، 
\q1 نَ دِ رَقَن عَ مَ. 
\q1  
\v 25 تِنشِنتْي وَ سَمَ نّ بَلٌي رَ، 
\q1 كْنْ تِنشِنتَرٍ تَن لُمَ كَامّ رَ نّ. 
\c 14  
\s1 فِنّ لْننِلَ 
\q1  
\v 1 فِنّ لْننِلَ سّنبّ قِمَ نّ عَ شَ دٍنبَيَ مَ، 
\q1 كْنْ فِنّ لْننِتَرٍ عَ شَ دٍنبَيَ شُن نَكَنَمَ نّ. 
\q1  
\v 2 مِشِ نَشَن عَ حّرّ مَ عَ تِنشِنشِ رَ، عَ فَاشُمَ نّ عَلَ يَ رَ، 
\q1 كْنْ نَشَن عَ حّرّ مَ تِنشِنتَرٍيَ رَ، نَ نَن يٌمَ عَلَ مَ. 
\q1  
\v 3 يّتّ عِفبٌي شَ وْيّنيِ قِندِ مَ بْنبْي نَن نَ عَ بّ، 
\q1 لْننِلَ تَن شَ وْيّنيِ عَ مَكَنتَمَ نّ. 
\q1  
\v 4 شَ نِنفٍ مُ بْشِ بُشَمَ، سَفَ مُ رَقٍمَ. 
\q1 نِنفٍ شَ وَلِ عَ نِيَمَ نّ مِشِ شَ بَلٌي فبٍفبٍ سْتْ. 
\q1  
\v 5 سٍيدٍ قَنيِ مُ وُلٍ قَلَمَ، 
\q1 سٍيدٍ حَاشِ تَن وُلٍ نَن تُن قُنقُنمَ. 
\q1  
\v 6 مِشِ مَيٍلٍ لْننِ قٍنمَ نّ، كْنْ عَ مُ عَ سْتْمَ. 
\q1 لْننِ كٌلٌنقٍ مُ شْرْشْ شَشِلِمَ بّ. 
\q1  
\v 7 عِ شَ عِ مَكُيَ شَشِلِتَرٍيٍ رَ، 
\q1 بَرِ مَ عِ مُ لْننِ يٌ سْتْمَ عٍ رَ. 
\q1  
\v 8 لْننِلَ عَ حْشْ سَمَ نّ عَ حّرّ كِ شْن مَ، 
\q1 لْننِتَرٍ تَن عَ يّتّ مَدَشُمَ نّ. 
\q1  
\v 9 شَشِلِتَرٍ يٌمَ يُنُبِ تٌنفٌقٍ مَ، 
\q1 كْنْ تِنشِنتْي عَلَ شَ هِننّ نَن قٍنمَ. 
\q1  
\v 10 مِشِ عَ يّتّ شَ تْورّ كٌلٌن عَ بْحّ كُي، 
\q1 عَ مُ عَ شَ سّيوّ مَسٍنمَ مِشِ فبّتّ بّ. 
\q1  
\v 11 مِشِ حَاشِيٍ شَ دٍنبَيَ هَلَكِمَ نّ، 
\q1 تِنشِنتْييٍ تَن شَ دٍنبَيَ قَنمَ نّ. 
\q1  
\v 12 مِشِ حْشْ عَ مَ عَ عَ حّرّ كِ قَن، 
\q1 عَ قَ لِ كْرّ عَ نَ فبَلٌي كِرَ نَن شْن مَ. 
\q1  
\v 13 مِشِ نْمَ يٍلٍدٍ عَ دّ رَ، عَ تْورْشِ عَ بْحّ كُي. 
\q1 سّيوّ نْمَ مَقِندِدٍ تْورّ رَ. 
\q1  
\v 14 مِشِ حَاشِ يٌ، مِشِ قَنيِ يٌ، 
\q1 عٍ بِرِن عٍ شَ وَلِ سَرٍ سْتْمَ نّ. 
\q1  
\v 15 شَشِلِتَرٍ لَمَ نّ مِشِ بِرِن شَ مَسٍنيِ رَ، 
\q1 كْنْ شَشِلِمَ كِرَ مَتٌمَ نّ بٍينُ عَ شَ بِرَ نَ قْشْ رَ. 
\q1  
\v 16 شَشِلِمَ فَاشُمَ نّ عَلَ يَ رَ، عَ قَ فبِلٍن قٍ حَاشِ قْشْ رَ، 
\q1 كْنْ شَشِلِتَرٍ تَن سٌمَ نّ نَ قٍ حَاشِ كُي مَقُرٍن. 
\q1  
\v 17 مِشِ نَشَن بْحّ تٍمَ مَقُرٍن، عَ دَشُحَ نَن نَبَمَ. 
\q1 مِشِ مَدَشُي مُ رَقَن مِشِ يٌ مَ. 
\q1  
\v 18 دَشُحَ قِندِ مَ نّ شَشِلِتَرٍ كّ رَ، 
\q1 شَشِلِمَيٍ تَن لْننِ نَن سْتْمَ. 
\q1  
\v 19 مِشِ حَاشِيٍ قَمَ نّ عٍ شِنبِ سِندٍ تِنشِنتْييٍ بُن مَ، 
\q1 عٍ كَنتَرِ نَن قٍنمَ تِنشِنتْييٍ شْنيِ. 
\q1  
\v 20 سٍتَرٍ رَحَاشُ بِرِن مَ، هَلِ عَ دْشْبٌورٍ، 
\q1 كْنْ بَننَ رَقَن مِشِ فبٍفبٍ مَ. 
\q1  
\v 21 مِشِ نَشَن يٌمَ عَ نفَشَكٍرٍنيِ مَ، عَ بَرَ يُنُبِ سْتْ، 
\q1 كْنْ نَشَن كِنِكِنِ تْورْ مِشِ مَ، نَ بَرَ سّيوّ سْتْ. 
\q1  
\v 22 مِشِ نَشٍيٍ قٍ حَاشِ مَحْشُنمَ، نٍيٍ بْنْمَ نّ. 
\q1 كْنْ نَشٍيٍ قٍ قَنيِ مَحْشُنمَ، 
\q1 نَ كَنيِيٍ مَرَقَنيِ نُن نْندِ نَن تٌمَ. 
\q1  
\v 23 فٍينِ نَ وَلِ بِرِن كُي، 
\q1 كْنْ وْيّنيِ فبَنسَن قِندِ مَ سٍتَرٍحَ نَن نَ. 
\q1  
\v 24 بَننَيَ نَن نَ لْننِلَ سَرٍ رَ، 
\q1 دَشُحَ نَن تُن لُمَ لْننِتَرٍ تَن يِ رَ. 
\q1  
\v 25 سٍيدٍ نْندِ قَلّ مِشِ نِي رَتَنفَمَ نّ، 
\q1 كْنْ وُلٍ قَلّ مِشِ مَدَشُمَ تُن. 
\q1  
\v 26 مِشِ نَشَن فَاشُ عَلَتَلَ يَ رَ، 
\q1 عَ تَن نُن عَ شَ دِيٍ لُمَ نّ كَنتَرِ كُي. 
\q1  
\v 27 عَلَتَلَ شَ يَرَفَاشُي سِمَيَ قِمَ نّ مِشِ مَ، 
\q1 عَلَكٌ عٍ شَ رَتَنفَ فَنتَنيِ مَ نَشَن قِندِ مَ قَشّ رَ. 
\q1  
\v 28 حَمَ شَ فبٌي قِندِ مَ مَنفّ شَ شُننَكٍلِ نَن نَ، 
\q1 كْنْ حَمَ شَ شُرُنيِ قِندِ مَ مَنفّ شَ شُننَفٌرٍ نَن نَ. 
\q1  
\v 29 شَشِلِمَ بْحّ تٍ شْنْ، 
\q1 كْنْ شَشِلِتَرٍ عَ شَ دَشُحَ مَسٍنمَ نّ عَ شَ بْحّ تٍ سَابُي رَ. 
\q1  
\v 30 بْحّسَ قِندِ مَ سِمَيَ نَن نَ، 
\q1 كْنْ مِلّ تَن قِندِ مَ قُرٍ نَن نَ. 
\q1  
\v 31 نَشَن سٍتَرٍ تْورْ مَ، نَ بَرَ يٌ سٍتَرٍ دَا مَنفّ مَ، 
\q1 كْنْ نَشَن كِنِكِنِ سٍتَرٍ مَ، نَ بَرَ عَ دَا مَنفّ مَتْشْ. 
\q1  
\v 32 مِشِ حَاشِ شَ حَاشُحَ عَ شُن نَكَنَمَ نّ، 
\q1 كْنْ تِنشِنتْي كَنتَرِ سْتْمَ نّ هَلِ قَشّ يَ عِ. 
\q1  
\v 33 لْننِ نَ شَشِلِمَ بْحّ كُي، 
\q1 شَشِلِتَرٍ يَتِ نْمَ نَ تٌدٍ. 
\q1  
\v 34 تِنشِنيِ بْشِ رَ سِفَمَ نّ يَرٍ، 
\q1 يُنُبِ تَن حَمَ رَيَافِمَ نّ. 
\q1  
\v 35 وَلِكّ لْننِلَ رَقَن مَنفّ مَ، كْنْ عَ وَلِكّ يَافِتَرٍ تَن شْنمَ نّ. 
\c 15  
\s1 يَابِ بْرْشْشِ 
\q1  
\v 1 يَابِ بْرْشْشِ مِشِ بْحّ رَفٌرٌ مَ نّ، 
\q1 كْنْ وْيّن شْنّ تَن مِشِ بْحّ رَتٍمَ نّ. 
\q1  
\v 2 شَشِلِمَ شَ وْيّنيِ عَ نِيَمَ نّ شَشِلِ قَنيِ شَ رَقَن مِشِيٍ مَ، 
\q1 كْنْ شَشِلِتَرٍ شَ وْيّنيِ دَشُحَ نَن تُن مَسٍنمَ. 
\q1  
\v 3 عَلَتَلَ مِشِ بِرِن مَتٌمَ، 
\q1 مِشِ حَاشِ نُن مِشِ قَنيِ. 
\q1  
\v 4 وْيّن قَنيِ مِشِ رَيَلَنمَ، 
\q1 كْنْ وْيّن شْنّ مِشِ شَشِلِ تْورْ مَ نّ. 
\q1  
\v 5 شَشِلِتَرٍ يٌمَ نّ عَ بَبَ شَ مَرَ سِ مَ، 
\q1 شَشِلِمَ تَن نَ مَرَ سِ نَن سُشُمَ. 
\q1  
\v 6 هَرِفٍ قَنيِ نَ تِنشِنتْي شْنيِ، 
\q1 كْنْ تْورّ فبَنسَن نَن قِندِ مَ تِنشِنتَرٍ سَرٍ رَ. 
\q1  
\v 7 لْننِلَيٍ شَ وْيّنيِيٍ شَشِلِ قِمَ نّ مِشِ مَ، 
\q1 كْنْ قٍ قَنيِ يٌ مُ نَ لْننِتَرٍيٍ بْحّ كُي. 
\q1  
\v 8 عَلَتَلَ مِشِ حَاشِ شَ سّرّشّ شْنمَ، 
\q1 كْنْ عَ تِنشِنتْي شَ دُبَ سُشُمَ نّ. 
\q1  
\v 9 عَلَتَلَ مِشِ حَاشِ شَ كِرَ شْنمَ، 
\q1 كْنْ مِشِ نَشَن بِرَ مَ تِنشِنيِ قْشْ رَ عَ رَقَن عَ مَ. 
\q1  
\v 10 كِرَ قَنيِ بّحِنقٍ قِندِ مَ حَشَنكَتّ نَن نَ. 
\q1 شُرُتَرٍحَ مِشِ شُن تِمَ قَشّ كِرَ نَن مَ. 
\q1  
\v 11 عَلَتَلَ تٌ قٍ بِرِن كٌلٌن، 
\q1 هَلِ نَشَن نَبَمَ عَلِفِيَمَ نُن يَهَننَمَ، 
\q1 عَ عِبُنَدَ مَ بْحّ قَن كٌلٌن. 
\q1  
\v 12 يّتّ عِفبٌي مُ وَ مَ مَرَ سِ شْن مَ، 
\q1 عَ مُ سِفَمَ لْننِلَ يِرٍ. 
\q1  
\v 13 بْحّ سّيوَشِ مِشِ لَهَلّ قَنمَ، 
\q1 كْنْ بْحّ تْورْشِ مِشِ لَهَلّ كَنَمَ نّ. 
\q1  
\v 14 شَشِلِمَ لْننِ نَن قٍنمَ، 
\q1 كْنْ شَشِلِتَرٍ دَشُ وْيّنيِ نَن تُن قَلَمَ. 
\q1  
\v 15 هَلِ مِسِكِينّ تْورْ عَ شَ سِمَيَ كُي، 
\q1 شَ عَ بْحّ سّيوَشِ، نَ قِندِ مَ نّ بَلٌي رَ عَ بّ. 
\q1  
\v 16 سٍتَرٍ عَلَ يَرَفَاشُي، 
\q1 قَن بَننَ شَشِلِ عِقُشِ بّ. 
\q1  
\v 17 بَندٍ حِحّ دٌنقٍ شَنُنتٍيَ كُي، 
\q1 نَ قَن سُبٍ دٌنقٍ بّ فبّسّنشْننّيَ كُي. 
\q1  
\v 18 بْحّ رَتٍ فٍرٍ شْرّ عِسْشْمَ نّ، 
\q1 بْحّ رَفٌرٍ سْنشْي رَشِنبٍلِمَ نّ. 
\q1  
\v 19 تُننَشْنّ شَ كِرَ مَبَلَنشِ تُنبٍيٍ نَن نَ، 
\q1 كْنْ تِنشِنتْي شَ كِرَ حّرّ حْشُن. 
\q1  
\v 20 دِ لْننِشِ قِندِ مَ سّيوّ نَن نَ عَ بَبَ بّ، 
\q1 كْنْ دِ لْننِتَرٍ يٌمَ نّ عَ نفَ مَ. 
\q1  
\v 21 شَشِلِتَرٍحَ رَقَن لْننِتَرٍ مَ، 
\q1 كْنْ شَشِلِمَ شَ كِرَ تِنشِن. 
\q1  
\v 22 مَرَ سِتَرٍحَ وَلِ كَنَمَ نّ، 
\q1 كْنْ مَرَ سِ فبٍفبٍ وَلِ نَن سْونّيَمَ. 
\q1  
\v 23 سّيوّ نَ مِشِ بّ نَشَن قَتَ عَ بٌورٍ يَابِدٍ. 
\q1 وْيّنيِ تِدٍ فبٌ نَشَن قَلَشِ عَ قَلَ كِ مَ نُن عَ قَلَ تّمُي مَ. 
\q1  
\v 24 شَشِلِمَ شَ كِرَ عَ رَتٍمَ نّ كٌورٍ مَ، 
\q1 عَ عَ مَلِ عَ شَ عَلِفِيَمَ كِرَ مَتَنفَ. 
\q1  
\v 25 عَلَتَلَ يّتّ عِفبٌي شَ بَنشِ رَبِرَ مَ نّ، 
\q1 كْنْ عَ كَاحّ فِنّ شَ بْشِ مَكَنتَمَ نّ. 
\q1  
\v 26 مَحْشُن كٌبِ رَحَاشُ عَلَتَلَ مَ، 
\q1 كْنْ وْيّن قَنيِ تَن سّنِيّن. 
\q1  
\v 27 مِلَنتٍ قِندِ مَ نّ تْورّ رَ عَ شَ دٍنبَيَ بّ، 
\q1 كْنْ نَشَن مُ وَ مَ فٍينِ تِنشِنتَرٍ شْن، 
\q1 نَ كَنيِ كِسِ نَن سْتْمَ. 
\q1  
\v 28 تِنشِنتْي قٍ مَتٌمَ نّ عَ قَنيِ رَ بٍينُ عَ شَ يَابِ ندٍ قِ، 
\q1 كْنْ قٍ حَاشِ مَقُرَ مِنِدٍ مِشِ حَاشِ دّ عِ. 
\q1  
\v 29 عَلَتَلَ مَكُيَ مِشِ حَاشِيٍ رَ، 
\q1 كْنْ عَ عَ تُلِ مَتِمَ تِنشِنتْييٍ شَ مَشَندِ رَ. 
\q1  
\v 30 شّيرَ يَ عِيَلَنشِ مِشِ بْحّ رَ سّيوَ مَ نّ، 
\q1 شّيرَيَ قَنيِ سّنبّ نَن قِمَ مِشِ مَ. 
\q1  
\v 31 مِشِ نَشَن عَ تُلِ مَتِمَ كِسِ مَرَ سِ رَ، 
\q1 نَ كَنيِ لُمَ نّ لْننِلَيٍ يَ مَ. 
\q1  
\v 32 نَشَن تٌندِ مَ مَرَ سِ رَ مّدٍ، 
\q1 نَ يٌشِ عَ يّتّ نَن مَ، 
\q1 كْنْ نَشَن تِنمَ مَرَ سِ رَ مّدٍ، 
\q1 نَ كَنيِ شَ لْننِ نَن شُن مَسَمَ. 
\q1  
\v 33 عَلَ شَ يَرَفَاشُي قِندِ مَ لْننِ نَن نَ مِشِ بّ. 
\q1 يّتّ مَفٌرٍ قَمَ بِنيّ نَن نَ. 
\c 16  
\s1 عَلَ شَ مَرَفِرِ 
\q1  
\v 1 عَدَ مَدِ نَتّ تٌنفٌمَ عَ بْحّ كُي، 
\q1 كْنْ مَرَفِرِ نَ عَلَ نَن بّلّشّ. 
\q1  
\v 2 عَدَ مَ تَن بّ، عَ شَ كِرَ بِرِن قَن، 
\q1 كْنْ كِيتِ سَ مَنفّ عَلَ عَ بْحّ كٌلٌن. 
\q1  
\v 3 وَلِ بِرِن تَشُ عَلَتَلَ رَ، عَلَكٌ عَ شَ سْونّيَ. 
\q1  
\v 4 عَلَتَلَ قٍ بِرِن يَءِلَنشِ قٍ ندٍ نَن مَ. 
\q1 هَلِ مِشِ حَاشِ دَاشِ فبَلٌي لْشْي نَن مَ قٍ رَ. 
\q1  
\v 5 عَلَتَلَ يّتّ عِفبٌي شْنشِ. 
\q1 حَشَنكَتّ نَن عَ مَمّقٍ. 
\q1  
\v 6 يُنُبِ شَقَرِ مَ هِننّ نُن دُفُتّفّيَ نَن سَابُي رَ. 
\q1 عَلَتَلَ شَ يَرَفَاشُي مِشِ رَتَنفَمَ قٍ حَاشِ نَن مَ. 
\q1  
\v 7 مِشِ حّرّ كِ نَ رَقَن عَلَتَلَ مَ، 
\q1 عَ عَ نِيَمَ نّ فٍرٍ شَ حْن نَ كَنيِ نُن عَ يَشُييٍ تَفِ. 
\q1  
\v 8 سٍ دٌندٌرٌنتِ سْتْشِ تِنشِنيِ رَ 
\q1 نَ نَن قِسَ سٍ فبٍفبٍ سْتْشِ بّ تِنشِنتَرٍيَ كُي. 
\q1  
\v 9 مِشِ نَتّ تٌنفٌمَ عَ شَ قٍ رَبَشِ مَ، 
\q1 كْنْ نَ قٍيٍ رَفِرِ مَنفّ نَ عَلَتَلَ نَن نَ. 
\q1  
\v 10 مَنفّ شَ مَسٍنيِ تِدٍ فبٌ، 
\q1 عَ شَ كِيتِ شَ تِنشِن. 
\q1  
\v 11 عَلَتَلَ نَ سِكٍيلِ تِنشِنشِ نَن بّ، 
\q1 عَ شَ وَلِ نَن نَ سٍ مَنِيَسٍ كَمَلِشِ رَ. 
\q1  
\v 12 قٍ حَاشِ مُ رَقَن مَنفّيٍ مَ، 
\q1 بَرِ مَ تِنشِنيِ نَن مَنفّ كِبَنيِ مَبَنبَنمَ. 
\q1  
\v 13 مَنفّيٍ شَ هِننّ نَ تِنشِنتْييٍ بّ، 
\q1 نْندِ قَلّ رَقَن عٍ مَ. 
\q1  
\v 14 مَنفّ شَ بْحّتٍ مِشِ قَشَمَ نّ، 
\q1 كْنْ لْننِلَ قَتَ مَنفّ بْحّ رَفٌرٌدٍ. 
\q1  
\v 15 مَنفّ شَ حّلّشِنيِ قِندِ مَ سِمَيَ نَن نَ، 
\q1 عَ شَ هِننّ لُمَ نّ عَلْ نُشُي نَشٍيٍ تُنّ يٍ رَ مِنِمَ. 
\q1  
\v 16 لْننِ سْتْي قَن شّيمَ سْتْي بّ، 
\q1 شَشِلِ قَنيِ سْتْي قَن فبٍتِ سْتْي بّ. 
\q1  
\v 17 تِنشِنتْي شَ كِرَ مُ سِفَمَ قٍ حَاشِ مَ. 
\q1 مِشِ نَشَن عَ حّنفِ سَشِ عَ حّرّ كِ شْن مَ، نَ كِسِمَ نّ. 
\q1  
\v 18 يّتّ عِفبٌحَ مِشِ نَن شُن نَكَنَمَ، 
\q1 يّتّ عِتٍيَ مِشِ نَن نَلْيمَ. 
\q1  
\v 19 لُقٍ يّتّ مَفٌرٍيٍ يَ مَ، نَ قَن 
\q1 نَاقُلِ عِتَشُنقٍ بّ يّتّ عِفبٌييٍ يَ مَ. 
\q1  
\v 20 هّيرِ نَ مِشِ بّ نَشَن عَ حّنفِ سَمَ قٍ رَبَ كِيٍ شْن مَ. 
\q1 سّيوّ نَ مِشِ بّ نَشَن عَ شَشِلِ تِمَ عَلَتَلَ رَ. 
\q1  
\v 21 مِشِ سَبَرِشِ قِندِ مَ شَشِلِمَ نَن نَ. 
\q1 وْيّن حْشُنمّ شَشِلِ قِمَ نّ مِشِ مَ. 
\q1  
\v 22 شَشِلِ قَنيِ سِمَيَ نَن قِمَ شَشِلِمَ مَ، 
\q1 شَشِلِتَرٍحَ قِندِ مَ حَشَنكَتّ نَن نَ شَشِلِتَرٍ بّ. 
\q1  
\v 23 شَشِلِمَ عَ حّنفِ سَمَ عَ شَ مَسٍنيِ مَ، 
\q1 عَلَكٌ لْننِ قَنيِ شَ مِنِ عَ دّ كُي. 
\q1  
\v 24 وْيّن قَنيِ قِندِشِ كُمِ نَن نَ، 
\q1 نَشَن شَشِلِ نُن قَتٍ رَيَلَنمَ. 
\q1  
\v 25 عَدَ مَ عَ مَحْشُن نّ عَ شَ كِرَ قَنشِ، 
\q1 كْنْ عَ رَحْنيِ عَ شُن تِمَ قَشّ نَن نَ. 
\q1  
\v 26 وَلِكّ شَ كَامّ نَن عَ تُتُنمَ وَلِ مَ. 
\q1  
\v 27 قُيَنتٍ قٍ حَاشِ مَحْشُنمَ نّ، 
\q1 عَ شَ مَسٍنيِ مِشِ فَن. 
\q1  
\v 28 مِشِ كٌبِ فٍرٍ شْرّ عِسْشْمَ نّ، 
\q1 نَاقِشِ دّقَنمَيٍ تَفِ عِسٌمَ. 
\q1  
\v 29 مِشِ كٌبِ عَ بٌورٍ رَتَنتَنمَ نّ، 
\q1 عَ نَ تِ كِرَ حَاشِ شْن مَ. 
\q1  
\v 30 مِشِ نَشَن تْنشُمَ مَسٍنمَ عَ يَ نُن عَ دّ رَ، 
\q1 عَ وَ مَ قٍ حَاشِ ندٍ نَن نَبَقٍ. 
\q1  
\v 31 شُنسّشّ قِيشّ قِندِ مَ بِنيّ نَن نَ، 
\q1 نَشَن سْتْمَ كِرَ تِنشِنشِ شْن مَ. 
\q1  
\v 32 دِحّ مِشِ قَن فٍرٍ سٌي بّ، 
\q1 يّتّ سُشُي تِدٍ دَنفِ تَا سُشُقٍ رَ. 
\q1  
\v 33 مِشِ كَندَ بُنمَ قٍ ندٍ مَ، 
\q1 كْنْ قٍ بِرِن نَفِرِ مَنفّ نَ عَلَتَلَ نَن نَ. 
\c 17  
\s1 لَنتَرٍيَ 
\q1  
\v 1 تَامِ شُنتُنيِ سْتْقٍ بْحّسَ كُي 
\q1 نَ نَن قِسَ سُبٍ فبٍفبٍ سْتْقٍ بّ لَنتَرٍيَ نَ دّننَشّ. 
\q1  
\v 2 وَلِكّ شَشِلِمَ سّنبّ فبٌ دَنفِقٍ وَلِ كَنيِ شَ دِ رَ، 
\q1 نَشَن قٍ مَيَافِشِ رَبَمَ. 
\q1 نَ وَلِكّ مْولِ تَن كّ سْتْمَ نّ نَ دٍنبَيَ كُي. 
\q1  
\v 3 شّيمَ نُن فبٍتِ مَتٌسٍ نَ تّ نَن نَ، 
\q1 كْنْ عَلَتَلَ نَن عَدَ مَ بْحّ مَتٌمَ. 
\q1  
\v 4 قٍ كٌبِ رَبَ وْيّن تِنشِنتَرٍ رَ مّمَ، 
\q1 عَ عَ تُلِ مَتِمَ وُلٍ قَلّ رَ. 
\q1  
\v 5 مِشِ نَشَن يٌمَ سٍتَرٍيٍ مَ، 
\q1 نَ بَرَ سٍتَرٍ دَا مَرِفِ يٍلٍبُ. 
\q1 مِشِ نَشَن يٍلٍمَ عَ بٌورٍ شَ تْورّ مَ، 
\q1 نَ حَشَنكَتّ نَن سْتْمَ. 
\q1  
\v 6 مَمَدِيٍ قِندِشِ قٌرِيٍ شَ سّيوّ نَن نَ، 
\q1 بَبَيٍ قَن قِندِشِ عٍ شَ دِيٍ شَ سّيوّ نَن نَ. 
\q1  
\v 7 مَنفّ شَ وْيّنيِ مُ لَن شَشِلِتَرٍ دّ عِ، 
\q1 وُلٍ مُ لَن مَنفّ دّ عِ. 
\q1  
\v 8 كِ تِقٍ نَادّيٍ رَبِمَ نّ، عَ قٍ بِرِن سْونّيَمَ نّ. 
\q1  
\v 9 دِحّقٍ كٌنبِ مَ عَ مَرَقَنيِ نَن نَ فبٌمَ، 
\q1 كْنْ نَ عِقَلَقٍ عَ شَنُنتٍنمَيٍ تَفِ عِسٌمَ. 
\q1  
\v 10 تَنتَنيِ مَسٍنقٍ لْننِلَ بّ عَ قَهَامُي قِمَ نّ عَ مَ، 
\q1 دَنفِقٍ لْننِتَرٍ بْنبْقٍ لُشُسِنيِ يَ كّمّ رَ. 
\q1  
\v 11 مِشِ حَاشِ نَشَن مَنفّ مَتَندِ مَ تُن، 
\q1 سْورِ كِنِكِنِتَرٍ نَن شّيمَ عَ شِلِ مَ. 
\q1  
\v 12 نَرَلَنقٍ سُبٍ شَاحّ رَ، نَشَن شَ دِيٍ بَشِ عَ يِ، 
\q1 نَ قِسَ نَرَلَنقٍ شَشِلِتَرٍ رَ، نَشَن حّرّ مَ عَ شَ شَشِلِتَرٍحَ كُي. 
\q1  
\v 13 مِشِ نَشَن قٍ قَنيِ حْشْمَ قٍ حَاشِ رَ، 
\q1 قٍ حَاشِ مُ مَكُيَمَ نَ شَ بَنشِ رَ. 
\q1  
\v 14 فٍرٍ قْلْقٍ لُشِ نّ عَلْ بٌفٌنِ عِبْوقٍ. 
\q1 نَ كُي بٍينُن سْنشْي شَ مِنِ، كٍلِ نَا. 
\q1  
\v 15 مِشِ نَشَن نْندِ قِمَ قٍ كٌبِ رَبَمَ، 
\q1 نُن مِشِ نَشَن تِنشِنتْي تْوحّفّمَ، 
\q1 عٍ مُ رَقَن عَلَتَلَ مَ. 
\q1  
\v 16 هَلِ كْبِرِ لُ لْننِتَرٍ يِ رَ، 
\q1 عَ مُ نَ رَوَلِمَ لْننِ سْتْقٍ رَ. 
\q1  
\v 17 مِشِ عَ دّقَنبٌورٍ شَنُمَ تّمُي بِرِن، 
\q1 عَ عَ نفَشَكٍرٍنيِ مَلِمَ عَ تْورْ تّمُي. 
\q1  
\v 18 لْننِتَرٍ نَشَن شَشِلِ مُ نَ، 
\q1 نَ نَن فبَنسَن تَانِمَ عَ بٌورٍ بّ. 
\q1  
\v 19 فٍرٍ رَقَن مِشِ يٌ مَ، 
\q1 يُنُبِ قَن نَقَن نَ كَنيِ مَ. 
\q1 مِشِ نَشَن عَ يّتّ عِفبٌمَ، 
\q1 شُننَكَنّ نَن عَ لِمَ. 
\q1  
\v 20 مِشِ يٌ مَدَشُي تِمَ، نَ مُ هّيرِ سْتْمَ، 
\q1 مِشِ يٌ وْيّن كٌبِ قَلَمَ، نَ تْورْ مَ نّ. 
\q1  
\v 21 مِشِ يٌ دِ لْننِتَرٍ بَرِ، نَ قَمَ نّ تْورْدٍ. 
\q1 مِشِ يٌ دِ شَشِلِتَرٍ سْتْ، نَ مُ سّيوَ مَ. 
\q1  
\v 22 بْحّ سّيوَشِ، سٍرِ قَنيِ نَ عَ رَ، 
\q1 شَشِلِ سُننُنشِ تَن شْرِيٍ نَن شُن نَكَنَمَ. 
\q1  
\v 23 مِشِ حَاشِ سٍيٍ رَ سُشُمَ فُندٌ رَ، 
\q1 عَلَكٌ كِيتِ تِنشِنشِ شَ مَقِندِ. 
\q1  
\v 24 لْننِ مَكْرّ شَشِلِمَ رَ، 
\q1 كْنْ شَشِلِتَرٍ يَ تِشِ قٍ مَكُيَشِ نَن نَ. 
\q1  
\v 25 دِ شَشِلِتَرٍ قِندِ مَ تْورّ نَن نَ عَ بَبَ بّ، 
\q1 عَ قِندِ شْنّ رَ عَ نفَ بّ. 
\q1  
\v 26 عَ مُ لَن كْبِرِ شَ بَ تِنشِنتْي يِ رَ، 
\q1 عَ مُ لَن كُنتِفِ شَ بْنبْ عَ شَ تِنشِنيِ شَ قٍ رَ. 
\q1  
\v 27 شَشِلِمَ عَ دّ نَن سُشُمَ، عَ بْحّ مُ تٍمَ. 
\q1  
\v 28 شَشِلِتَرٍ نْمَ عَ مَحْشُندٍ لْننِلَ رَ شَ عَ دُندُشِ، 
\q1 عَ نْمَ عَ مَحْشُندٍ قَهَامُلَ رَ شَ عَ سَبَرِشِ. 
\c 18  
\s1 بٌورٍتَرٍ 
\q1  
\v 1 بٌورٍتَرٍ عَ وَشْنقٍ فبَنسَن نَن قٍنمَ، 
\q1 عَ يٌ مَرَ سِ بِرِن مَ. 
\q1  
\v 2 شَشِلِتَرٍ مُ وَ مَ شَشِلِ قَنيِ شْن، 
\q1 عَ وَ مَ عَ يّتّ شَ مَحْشُنيِ نَن تُن مَسٍنقٍ. 
\q1  
\v 3 مِشِ حَاشِيٍ يٌمَ مِشِيٍ مَ، 
\q1 عٍ يٌمَ عٍ مَ هَن عٍ سَ يَافِ. 
\q1  
\v 4 عَدَ مَ شَ وْيّنيِ تِلِن عَلْ بَا، 
\q1 عَ لْننِ رَ مِنِمَ نَشَن لُشِ عَلْ دُلٌنيِ يٍ قَنيِ. 
\q1  
\v 5 نْندِ قِقٍ مِشِ حَاشِ مَ، عَ مُ قَن. 
\q1 عَ مُ لَنمَ تِنشِنتْي شَ تْوحّفّ. 
\q1  
\v 6 لْننِتَرٍ سْنشْي شْرّ عِسْشْمَ، 
\q1 عَ بْنبْي سْتْمَ عَ دّ سَابُي رَ. 
\q1  
\v 7 شَشِلِتَرٍ دّ عَ شُن نَكَنَمَ نّ، 
\q1 عَ نّنيِ قِندِشِ فَنتَنيِ نَن نَ عَ نِي بّ. 
\q1  
\v 8 نَاقِشِ شَ مَسٍنيِ لُشِ نّ عَلْ دٌنسٍ حْشُنمّ، 
\q1 نَشَن فٌرٌ مَ مِشِ قُرِ كُي. 
\q1  
\v 9 تُننَشْنّ نُن كَسَرّ رَبَ، 
\q1 نٍيٍ نفَ كٍرٍن، عٍ بَبَ كٍرٍن. 
\q1  
\v 10 عَلَتَلَ قِندِشِ كَنتَرِ سّنبّمَ نَن نَ، 
\q1 تِنشِنتْي لُمَ نَشَن نِينِ بُن مَ. 
\q1  
\v 11 نَاقُلِ قِندِشِ بَننَ شَ كَنتَرِ نَن نَ، 
\q1 عَ حْشْ عَ مَ تّتّ نَ عَ رَ 
\q1 نَشَن مُ نْمَ كَنَدٍ. 
\q1  
\v 12 فبَلٌي نَ يّتّ عِفبٌحَ شَنبِ رَ، 
\q1 كْنْ نْرّ نَ يّتّ مَفٌرٍ قْشْ رَ. 
\q1  
\v 13 مِشِ نَشَن يَابِ قِمَ بٍينُ عَ شَ مِشِ شُي رَ مّ، 
\q1 عَ دَشُحَ مَسٍنمَ نّ، عَ عَ يّتّ رَيَافِ. 
\q1  
\v 14 شَشِلِ لِمَنِيَشِ مِشِ مَلِمَ نّ عَ شَ قُرٍ كُي، 
\q1 كْنْ لِمَنِيَ بَشِ نَشَن يِ، 
\q1 نَ مُ كٍلِمَ سْنْن. 
\q1  
\v 15 لْننِلَ كَتَمَ سٍ كٌلٌندٍ، 
\q1 عَ عَ تُلِ مَتِمَ مَسٍنيِ قَنيِ رَ. 
\q1  
\v 16 كِرَ رَبِشِ مِشِ بّ نَشَن كِ تِمَ، 
\q1 مَنفّيٍ يَتِ تٌقٍ سْونّيَمَ نّ نَ كَنيِ بّ. 
\q1  
\v 17 مِشِ نَشَن سِنفٍ عَ يّتّ شُن مَقَلَمَ قٍ كُي، 
\q1 عَ لُمَ نّ عَلْ نْندِ نَ عَ تَن نَن بّ، 
\q1 كْنْ عَ كَلَمُتِ مَشْرِنيِ شْرْشْي تِمَ نّ عَ مَ. 
\q1  
\v 18 قٍ لُقٍ عَلَ مَ عَ سْنشْي حْنمَ نّ، 
\q1 عَ فٍرٍ حْن سّنبّمَيٍ تَفِ. 
\q1  
\v 19 مِشِ كٌنبِشِ شَ بْحّ شْرْشْي لُمَ نّ عَلْ تَا مَكَنتَشِ. 
\q1 نَ سْنشْي مْولِ شْرْشْ دَنفِقٍ فٍيلِ كٌندٌنيِ رَ. 
\q1  
\v 20 عَدَ مَ شَ مَسٍنيِ نْمَ عَ بَلٌي قِدٍ عَ مَ، 
\q1 عَ هَيِ قَنمَ نّ عَ شَ وْيّنيِ سَابُي رَ. 
\q1  
\v 21 قَشّ نُن سِمَيَ قَتَنمَ مِشِ شَ وْيّنيِ نَن نَ. 
\q1 وْيّنلَ عَ سَرٍ سْتْمَ نّ. 
\q1  
\v 22 فِنّ سْتْقٍ قِندِشِ هّيرِ نَن نَ، 
\q1 نَشَن قَتَنشِ عَلَتَلَ رَ. 
\q1  
\v 23 سٍتَرٍ مَيَندِ تِمَ، 
\q1 كْنْ سٍ كَنيِ عَ يَابِمَ عَ شْرْشْي نَن نَ. 
\q1  
\v 24 شَ مِشِ بٌورٍيٍ وُيَ، نَ نْمَ قِندِدٍ تْورّ رَ عَ بّ، 
\q1 كْنْ بٌورٍ ندٍ نَ نَ نَشَن قَن عَ نفَشَكٍرٍنيِ بّ. 
\c 19  
\s1 سٍتَرٍ تِنشِنشِ 
\q1  
\v 1 سٍتَرٍ تِنشِنشِ قَن شَشِلِتَرٍ وُلٍ قَلّ بّ. 
\q1  
\v 2 فبَتَقٍ رَ عِ مُ نَشَن كٌلٌن، عَ مِشِ رَتَنتَنمَ نّ. 
\q1  
\v 3 عَدَ مَدِ عَ يّتّ شُن نَكَنَمَ نّ عَ شَ دَشُحَ رَ، 
\q1 كْنْ عَ قَ عَ بْحّ رَتٍ عَلَتَلَ تَن مَ نَ شُننَكَنّ شَ قٍ رَ. 
\q1  
\v 4 بَننَيَ عَ نِيَمَ نّ مِشِ شَ بٌورٍ فبٍفبٍ سْتْ، 
\q1 كْنْ سٍتَرٍحَ دّقَنبٌورٍحَ كَنَمَ نّ. 
\q1  
\v 5 تْوحّفّتِ قَمَ نّ حَشَنكَتّ سْتْدٍ، 
\q1 وُلٍ قَلّ مُ كِسِمَ. 
\q1  
\v 6 مِشِ فبٍفبٍ كَتَمَ عٍ يّتّ رَقَندٍ كِنِكِنِنتٍيٍ مَ، 
\q1 بِرِن بِرَ مَ نّ مِشِ قْشْ رَ نَشَن كِ تِمَ. 
\q1  
\v 7 سٍتَرٍ مُ رَقَن عَ نفَشَكٍرٍنيِيٍ يَتِ مَ، 
\q1 عَ مُ رَقَن عَ بٌورٍيٍ قَن مَ. 
\q1 عَ نَ عٍ مَشَندِ، عٍ مُ عٍ تُلِ مَتِمَ عَ رَ. 
\q1  
\v 8 مِشِ نَشَن شَشِلِ قٍنمَ، عَ قٍ قَنيِ رَبَمَ نّ عَ يّتّ بّ. 
\q1 مِشِ نَشَن قَهَامُي قٍنمَ، عَ شَ قٍ سْونّيَمَ نّ. 
\q1  
\v 9 تْوحّفّتِ قَمَ نّ حَشَنكَتّ سْتْدٍ، 
\q1 هَلَكِ بِرَ مَ نّ وُلٍ قَلّ قْشْ رَ. 
\q1  
\v 10 نَاقُلِ مُ لَن شَشِلِتَرٍ يِ رَ، 
\q1 عَلْ عَ تٌ مُ لَن كٌنيِ قَن شَ كُنتِفِيٍ يَامَرِ. 
\q1  
\v 11 لْننِلَ بْحّ تٍ شْنْ، عَ مُ كٌنبِ رَفبِلٍنمَ. 
\q1 نَ كُي عَ بِنيّ سْتْمَ نّ. 
\q1  
\v 12 مَنفّ شَ شْنّ مَنِيَ يّتّ شَاحّ رَ، 
\q1 عَ شَ هِننّ قَن مَنِيَ شِنِ رَ بُرّشّ شِندٍ مَ. 
\q1  
\v 13 دِ شَشِلِتَرٍ كْنتْقِلِ نَن بّندُنمَ عَ بَبَ مَ، 
\q1 فِنّ شَ سْنشْي شُنشُرِ لُشِ نّ عَلْ يٍ 
\q1 نَشَن لُمَ مِنِ رَ قّحّ يَلٍ دِ كُي، عَ مُ عَ عِتِمَ. 
\q1  
\v 14 مِشِ بَنشِ نُن هَرِفٍ سْتْمَ عٍ بَبَ كّ رَ، 
\q1 كْنْ عَلَ نَن فِنّ شَشِلِمَ قِمَ شّمّ مَ. 
\q1  
\v 15 تُننَشْنّ مِشِ لُمَ نّ شِشْلِ كُي، 
\q1 عَ كَامّ نَن تُن سْتْمَ. 
\q1  
\v 16 مِشِ نَشَن عَلَ شَ سّرِيّ رَبَتُمَ، 
\q1 عَ عَ يّتّ رَتَنفَمَ نّ قَشّ مَ، 
\q1 كْنْ نَشَن مُ عَ حّنفِ سَمَ عَ حّرّ كِ شْن مَ، 
\q1 عَ قَشَمَ نّ. 
\q1  
\v 17 سٍتَرٍ كِقٍ نَ مَنِيَشِ عَلَتَلَ دٌنِقٍ نَن نَ. 
\q1 عَلَ قَمَ نّ نَ دٌنِ رَفبِلٍندٍ عَ مَ. 
\q1  
\v 18 عِ شَ قٍ بِرِن نَبَ عِ شَ دِ شُرُقٍ رَ عَلَكٌ عَ شَ كِسِ، 
\q1 شَ نَ مُ عَ رَ، عَ قَشَمَ نّ. 
\q1  
\v 19 مِشِ نَشَن لُمَ شْنْ رَ، عَ نَ سَرٍ قِمَ نّ. 
\q1 شَ عِ عَ مَلِ كٍرٍن، عَ مَن فبِلٍنمَ نّ نَ مَ. 
\q1  
\v 20 عِ شَ عِ تُلِ مَتِ مَرَ سِ رَ، عِ شَ تِن عٍ شَ عِ شَرَن، 
\q1 عَلَكٌ عِ شَ قِندِ شَشِلِمَ رَ. 
\q1  
\v 21 مَحْشُن فبٍفبٍ نَ مِشِ بْحّ كُي، 
\q1 كْنْ عَلَتَلَ وَشْنقٍ نَن كَمَلِمَ. 
\q1  
\v 22 عَدَ مَدِ وَ مَ عَ بٌورٍ شَ دُفُتّفّحَ عَ مَ. 
\q1 سٍتَرٍ قِسَ وُلٍ قَلّ بّ. 
\q1  
\v 23 عَلَتَلَ شَ يَرَفَاشُي مِشِ رَكِسِمَ نّ. 
\q1 نَ مِشِ نَ عَ سَ كْي رَ، عَ مُ هَنمّمَ تْورّ يٌ رَ. 
\q1  
\v 24 تُننَشْنّ عَ دٌنسٍ تٌنفٌمَ نّ عَ بّلّشّ، 
\q1 كْنْ عَ مُ وَكِلِمَ عَ رَ سٌقٍ رَ عَ دّ عِ. 
\q1  
\v 25 مِشِ مَيٍلٍ بْنبْ، عَلَكٌ شَشِلِتَرٍ شَ شَشِلِ سْتْ. 
\q1 شَشِلِمَ نَ رَ سِ، عَلَكٌ عَ شَشِلِ شُن شَ مَسَ. 
\q1  
\v 26 دِ نَشَن عَ بَبَ كَسَرَ مَ، عَ عَ نفَ كٍرِ، 
\q1 مِشِ رَيَافِشِ نَ عَ رَ. 
\q1  
\v 27 ﭑ مَ دِ، شَ عِ مُ مَرَ سِ رَ مّمَ، 
\q1 عِ بَرَ عِ يّتّ مَكُيَ قٍ كٌلٌنيِ رَ. 
\q1  
\v 28 سٍيدٍ وُلٍ قَلّ يٌمَ سّرِيّ نَن مَ، 
\q1 تِنشِنتَرٍيَ نَن مِنِمَ مِشِ حَاشِ دّ عِ. 
\q1  
\v 29 مِشِ مَيٍلٍ حَشَنكَتَمَ نّ، 
\q1 لْننِتَرٍ بْنبْمَ نّ. 
\c 20  
\s1 سِيسِلَ شَ شَشِلِتَرٍحَ 
\q1  
\v 1 وّنِ مِشِ رَيَافِمَ، 
\q1 بٍيرٍ مِشِ مَدَشُمَ نّ. 
\q1 سِيسِلَ مُ نْمَ قِندِدٍ شَشِلِمَ رَ. 
\q1  
\v 2 مَنفّ بْحّ تٍشِ مَنِيَ يّتّ شَاحّ رَ. 
\q1 مِشِ نَشَن مَنفّ رَشْنْمَ، نَ بَرَ عَ يّتّ تْورْ. 
\q1  
\v 3 مِشِ بِنيَشِ مُ تِنمَ فٍرٍ رَ، 
\q1 كْنْ شَشِلِتَرٍ بِرَ مَ سْنشْي نَن قْشْ رَ. 
\q1  
\v 4 مِشِ تُننَشْنْشِ مُ يِرٍ بُشَمَ عَ وَشَتِ. 
\q1 شّ شَبَ تّمُي عَ بَلٌي قٍنمَ نّ، كْنْ عَ مُ سٍسٍ تٌمَ. 
\q1  
\v 5 مَرَ سِ تِلِن عَلْ يٍ نَشَن نَ بَا مَ. 
\q1 قَهَامُي كَنيِ نَ بِرِن مَتٌمَ نّ. 
\q1  
\v 6 مِشِ فبٍفبٍ دُفُتّفّحَ قَلَمَ عٍ يّتّ شُن مَ، 
\q1 كْنْ دُفُتّفّ يَتِ يَتِ تٌمَ دُنِحَ مَ؟ 
\q1  
\v 7 تِنشِنتْي حّرّ مَ تِنشِنيِ نَن نَ، 
\q1 سّيوّ نَ عَ شَ دِيٍ بّ. 
\q1  
\v 8 مَنفّ كِيتِسَ قَتَ مِشِ بْحّ حَاشِ تٌدٍ. 
\q1  
\v 9 ندٍ نْمَ عَ قَلَدٍ، «قٍ حَاشِ يٌ مُ ﭑ بْحّ مَ، 
\q1 ﭑ سّنِيّنشِ، يُنُبِ يٌ مُ نَ ﭑ مَ؟» 
\q1  
\v 10 سِكٍيلِ تِنشِنتَرٍ مُ رَقَن عَلَتَلَ مَ. 
\q1  
\v 11 قٌنِكٍ شَ حّرّ كِ تِنشِنشِ عَ بْحّ كِ مَسٍنمَ نّ. 
\q1  
\v 12 تُلِ نَشَن قٍ مّمَ، يَ نَشَن سٍ تٌمَ، 
\q1 عَلَتَلَ نَن نَ بِرِن دَاشِ. 
\q1  
\v 13 شِشْلِ نَشَ رَقَن عِ مَ دٍ، 
\q1 شَ نَ مُ عَ رَ عِ قِندِ مَ سٍتَرٍ نَن نَ. 
\q1 عِ يَ لَنمَ عَ شَ رَ سّفّ، عَلَكٌ عِ شَ بَلٌي سْتْ عَ قَنيِ رَ. 
\q1  
\v 14 سَرٍ سٌ نَن عَ قَلَمَ يُلّ بّ، 
\q1 «نَ سَرٍ مُ قَن ﭑ بّ قٍوٌ،» 
\q1 كْنْ عَ قَ كٍلِ نَ شُن مَ عَ يّتّ مَتْشْقٍ رَ. 
\q1  
\v 15 شّيمَ نُن فّمّ تٌقَنيِ فبٍفبٍ نَ دُنِحَ، 
\q1 كْنْ لْننِلَ شَ وْيّنيِ تِدٍ فبٌ عٍ بِرِن بّ. 
\q1  
\v 16 مِشِ شَ سّيكّ سٍ رَ سُشُ عَ نَشَن تَانِ شْحّ بّ، 
\q1 شَ نَ مُ عَ رَ عَ نَشَن تَانِ لَنفٌي بّ. 
\q1  
\v 17 دٌنسٍ نَشَن سْتْ وُلٍ رَ، عَ قْلّ عَ حْشُن، 
\q1 كْنْ عَ رَحْنيِ عَ لُشِ نّ عَلْ فّمّ شْرِ عِ دّ عِ. 
\q1  
\v 18 مَرَ سِ قَنيِ نَن وَلِ سْونّيَمَ. 
\q1 حَمَ نَشَ فٍرٍ سٌ مَرَ سِ شَنبِ. 
\q1  
\v 19 نَاقِشِ لَنلَنتٍيَ كَنَمَ نّ. 
\q1 عِ نَشَ لَ مِشِ رَ نَشَن دّ وُيَ. 
\q1  
\v 20 مِشِ نَ يٌ عَ نفَ نُن عَ بَبَ مَ، 
\q1 عَ دُنِحَ عِفِرِ مَ دِ مِ نَن كُي. 
\q1  
\v 21 هَرِفٍ نَشَن سْتْمَ مَقُرٍنيِ رَ، نَ مُ بُمَ. 
\q1  
\v 22 عِ نَشَ عَ قَلَ، «ﭑ نَن ﭑ فبٍحْشْمَ نّ.» 
\q1 عِ شَشِلِ تِ عَلَتَلَ نَن نَ، عَ عِ رَكِسِمَ نّ. 
\q1  
\v 23 عَلَتَلَ مُ وَ مَ مَنِيَ سٍ تِنشِنتَرٍ شْن مَ. 
\q1 سِكٍيلِ تِنشِنتَرٍ مُ قَن. 
\q1  
\v 24 عَلَتَلَ نَن عَدَ مَدِ شُن تِمَ كِرَ ندٍ رَ. 
\q1 عِبُنَدَ مَ تَن مُ نْمَ نَ قَهَامُدٍ. 
\q1  
\v 25 لَايِدِ تٌنفٌقٍ عَلَ بّ مَقُرٍن مَقُرٍن مَحْشُنيِ فبٍفبٍ شَنبِ، 
\q1 نَ قِندِشِ فَنتَنيِ نَن نَ عَدَ مَدِ بّ. 
\q1  
\v 26 مَنفّ لْننِلَ قَتَ مِشِ حَاشِيٍ مَيٍفٍتِدٍ، 
\q1 عَ تِ عٍ قَرِ عَ شْرْشْي رَ. 
\q1  
\v 27 عَلَتَلَ شَشِلِ قِمَ عَدَ مَدِ مَ، عَ قِندِ عَ بّ لَنثُي رَ، 
\q1 عَلَكٌ عَ شَ عَ يّتّ بْحّ مَتٌ عَ قَنيِ رَ. 
\q1  
\v 28 شَنُنتٍيَ نُن دُفُتّفّحَ مَنفّ كَنتَمَ نّ. 
\q1 مَنفّ كِبَنيِ سَبَتِمَ نّ مَنفّ شَ شَنُنتٍيَ سَابُي رَ. 
\q1  
\v 29 قٌنِكٍ سّنبّ قِندِشِ عَ شَ شُننَكٍلِ نَن نَ. 
\q1 شّمْشِ شُنسّشّ قِيشّ قِندِشِ عَ شَ بِنيّ نَن نَ. 
\q1  
\v 30 بْنبْي قِندِشِ كٌبِحَ سٍرِ نَن نَ، 
\q1 لُشُسِنيِ عَدَ مَ شَشِلِ مَتِنشِنمَ نّ. 
\c 21  
\s1 عَلَتَلَ مَنفّ رَحّرّقٍ 
\q1  
\v 1 عَلَتَلَ نَن مَنفّ بْحّ رَحّرّ مَ، 
\q1 عَلْ عَ شُرٍ رَحّرّ مَ كِ نَشّ عَ وَشْنكِ رَ. 
\q1  
\v 2 عَدَ مَدِ حْشْ عَ مَ عَ شَ كِرَ بِرِن تِنشِن، 
\q1 كْنْ عَلَتَلَ نَن مِشِ بْحّ مَتٌمَ سِكٍيلِ رَ. 
\q1  
\v 3 وٌ شَ بِرَ نْندِ نُن تِنشِنيِ قْشْ رَ. 
\q1 نَ رَقَن عَلَتَلَ مَ دَنفِقٍ سّرّشّ رَ. 
\q1  
\v 4 يّتّ عِفبٌحَ نُن قٍ حَاشِ رَبَقٍ، 
\q1 نَ بِرِن قِندِشِ يُنُبِ نَن نَ. 
\q1  
\v 5 وَكِلِلَ هَرِفٍ شُن مَسَمَ نّ، 
\q1 كْنْ فبَتَ فبٍفبٍ قِندِ مَ تْورّ نَن نَ. 
\q1  
\v 6 هَرِفٍ نَشَن سْتْشِ وُلٍ رَ، 
\q1 عَ مُ بُمَ، عَ مِشِ شَنِنمَ نّ عَلِفِيَمَ. 
\q1  
\v 7 مِشِ حَاشِيٍ شُن نَكَنَمَ نّ، 
\q1 بَرِ مَ عٍ مُ تِنشِنيِ رَبَتُمَ. 
\q1  
\v 8 مِشِ كٌبِ مُ تِنشِن، 
\q1 كْنْ مِشِ قَنيِ عَ حّرّ مَ كِرَ تِنشِنشِ شْن مَ. 
\q1  
\v 9 لُقٍ رَ بَنشِ قَرِ مَ، 
\q1 عَ قِسَ لُقٍ رَ فِنّ فٍرٍ سٌي سّيتِ مَ بَنشِ كُي. 
\q1  
\v 10 مِشِ حَاشِ وَ مَ قٍ حَاشِ نَن تُن شْن مَ. 
\q1 عَ مُ كِنِكِنِمَ مِشِ يٌ مَ، هَلِ دْشْبٌورٍ. 
\q1  
\v 11 شَشِلِتَرٍ نَ عَ تٌ عٍ مِشِ مَيٍلٍ حَشَنكَتَمَ، 
\q1 عَ شَشِلِ دِ سْتْمَ نّ، 
\q1 كْنْ شَشِلِمَ تَن قَهَامُي سْتْمَ لْننِ نَن كُي. 
\q1  
\v 12 عَلَ نَشَن تِنشِن، عَ مِشِ حَاشِ مَتٌمَ نّ، 
\q1 عَ عٍ شُن نَكَنَ. 
\q1  
\v 13 مِشِ نَشَن تٌندِ مَ عَ تُلِ مَتِدٍ سٍتَرٍ وَ شُي رَ، 
\q1 عَ قَن قَمَ نّ وَدٍ، مِشِ مُ عَ تُلِ مَتِمَ عَ رَ. 
\q1  
\v 14 بْحّتٍ كِقٍ فُندٌ رَ، عَ بْحّ رَفٌرٌ مَ نّ. 
\q1 مِشِ كِقٍ سُتُرّ رَ، عَ شَ شْنّ مَفٌرٌ مَ نّ. 
\q1  
\v 15 حّرّقٍ تِنشِنيِ كُي، نَ قِندِشِ سّيوّ نَن نَ تِنشِنتْي بّ، 
\q1 كْنْ نَ حّرّ كِ مْولِ مُ رَقَن مِشِ حَاشِ مَ. 
\q1  
\v 16 مِشِ نَشَن فبِلٍنمَ كِرَ قَنيِ قْشْ رَ، 
\q1 نَ قَمَ نّ لُدٍ مِشِ قَشَشِيٍ يَ مَ. 
\q1  
\v 17 مِشِ نَشَن بِرَ مَ عَ وَشْنقٍ فبَنسَن قْشْ رَ، 
\q1 نَ لُمَ نّ سٍتَرٍحَ كُي. 
\q1 مِشِ نَشَن وّنِ نُن دٌنسٍ قَنيِ تُن قٍنمَ، 
\q1 نَ مُ بَننَمَ. 
\q1  
\v 18 مِشِ حَاشِ قِندِ مَ تِنشِنتْي شُنسَرٍ نَن نَ، 
\q1 يَنقَنتٍ قِندِ مِشِ قَنيِ شُنسَرٍ رَ. 
\q1  
\v 19 لُقٍ رَ فبٍنفبٍرٍنيِ مَ، 
\q1 عَ قِسَ لُقٍ رَ فِنّ قِتِنّتْي سّيتِ مَ. 
\q1  
\v 20 هَرِفٍ قَنيِ نُن تُرٍ فبٍفبٍ نَ لْننِلَ شْنيِ، 
\q1 كْنْ لْننِتَرٍ بَرَ عَ فبٍ بِرِن دٌن. 
\q1  
\v 21 مِشِ نَشَن بِرَ مَ تِنشِنيِ نُن هِننّ قْشْ رَ، 
\q1 عَ سِمَيَ، كِيتِ قَنيِ، نُن بِنيّ سْتْمَ نّ. 
\q1  
\v 22 لْننِلَ نْمَ نّ نْدٍ تَا مَكَنتَشِ رَ، 
\q1 عَ عٍ شَ تّتّ رَبِرَ عٍ شَشِلِ نُ تِشِ نَشَن نَ. 
\q1  
\v 23 مِشِ نَشَن قَتَ عَ دّ سُشُدٍ، نَ مُ تْورْ مَ. 
\q1  
\v 24 يّتّ عِفبٌي يٌمَ نّ مِشِيٍ مَ، 
\q1 عَ قٍ بِرِن سُشُمَ نَ شَشِلِ نَن نَ. 
\q1  
\v 25 مِشِ تُننَشْنْشِ وَشْنقٍ عَ قَشَمَ نّ، 
\q1 بَرِ مَ عَ مُ تِنمَ وَلِدٍ. 
\q1  
\v 26 لْشْي بِرِن مِشِ تُننَشْنْشِ مِلَمَ نّ عَ وَشْنسٍ مَ. 
\q1 تِنشِنتْي تَن مِشِ كِمَ عَ فبٍ سٍ بِرِن نَن نَ. 
\q1  
\v 27 مِشِ حَاشِ شَ سّرّشّ مُ رَقَن عَلَ مَ. 
\q1 شَ عَ سَ عَ بَ مَحْشُنيِ كٌبِ رَ، عَلَتَلَ شَ شْنّ شُن مَسَمَ نّ. 
\q1  
\v 28 سٍيدٍ وُلٍ قَلّ هَلَكِمَ نّ، 
\q1 كْنْ سٍيدٍ نْندِ قَلّ شَ سِمَيَ نَن بُمَ. 
\q1  
\v 29 مِشِ حَاشِ عَ يَتَفِ عِقْورْ مَ، 
\q1 كْنْ تِنشِنتْي قٍ تِنشِنشِ نَن نَبَمَ. 
\q1  
\v 30 لْننِ يٌ مُ نَ، قَهَامُي يٌ مُ نَ، مَرَ سِ يٌ مُ نَ، 
\q1 نَشَن سّنبّ فبٌ عَلَتَلَ بّ. 
\q1  
\v 31 سٌي مَشِرِ مَ فٍرٍ سٌ لْشْي نّ، 
\q1 كْنْ شُننَكٍلِ قَتَنمَ عَلَتَلَ نَن نَ. 
\c 22  
\s1 شِلِ قَنيِ 
\q1  
\v 1 شِلِ قَنيِ قَن نَاقُلِ بّ، 
\q1 بِنيّ تِدٍ دَنفِ شّيمَ نُن فبٍتِ تِدٍ رَ. 
\q1  
\v 2 بَننَ نُن سٍتَرٍ بِرِن لَن، 
\q1 بَرِ مَ عَلَتَلَ نَن عٍ بِرِن دَا. 
\q1  
\v 3 شَشِلِمَ نَ قٍ شْرْشْي تٌ، عَ عَ يّتّ نَن نَتَنفَمَ عَ مَ. 
\q1 شَشِلِتَرٍ تَن نَ قٍ شْرْشْي تٌ، عَ سٌمَ عَ كُي نّ كٍرٍن نَ، 
\q1 عَ قَ حَشَنكَتّ سْتْ. 
\q1  
\v 4 يّتّ مَفٌرٍ نَشَن فَاشُمَ عَلَتَلَ يَ رَ، 
\q1 عَ بَننَيَ، بِنيّ، نُن سِمَيَ سْتْمَ نّ. 
\q1  
\v 5 تُنبٍيٍ نُن فَنتَنيِيٍ نَ تِنشِنتَرٍ شَ كِرَ شْن مَ، 
\q1 كْنْ مِشِ نَشَن مّينِمَ عَ يّتّ مَ، عَ عَ مَكُيَمَ نّ مّننِ رَ. 
\q1  
\v 6 قٌنِكٍ مَتِنشِن كِرَ قَنيِ رَ، 
\q1 عَلَكٌ عَ نَشَ فبِلٍن نَ قْشْ رَ عَ مْ تّمُي. 
\q1  
\v 7 بَننَ سٍتَرٍ يَمَرِ مَ نّ، 
\q1 دٌنِ تٌنفٌي قَن قِندِ دٌنِقَ شَ كٌنيِ رَ. 
\q1  
\v 8 مِشِ حَاشِ تْورّ نَن سْتْمَ عَ سَرٍ رَ، 
\q1 عَ سّنبّ قَمَ نّ كَنَدٍ. 
\q1  
\v 9 هِننّنتٍ بَرَكَمَ نّ، 
\q1 بَرِ مَ عَ تْورْ مِشِيٍ كِمَ عَ شَ دٌنسٍ رَ. 
\q1  
\v 10 مِشِ مَيٌي كٍرِ، عَلَكٌ حْشْنسْسْي شَ حْن. 
\q1 نَ تّمُي فبّسّنشْننّيَ نُن كٌنبِيٍ دَنمَ نّ. 
\q1  
\v 11 بْحّ شَ سّنِيّنيِ رَقَن مِشِ نَشَن مَ، 
\q1 وْيّن قَنيِيٍ نَن مِنِمَ نَ دّ عِ، 
\q1 عَ قَ قِندِ مَنفّ دّقَنبٌورٍ رَ. 
\q1  
\v 12 عَلَتَلَ نْندِ نَن مَكَنتَمَ، 
\q1 كْنْ عَ يَنقَنتٍ شَ وْيّنيِ شُن نَكَنَمَ نّ. 
\q1  
\v 13 مِشِ تُننَشْنْشِ نَن عَ قَلَمَ، 
\q1 «يّتّ شَاحّشِ نَ تَندٍ، ﭑ نَ مِنِ كّنّ مَ، عَ ﭑ قَشَمَ نّ.» 
\q1  
\v 14 فَنتَنيِ نَن نَ لَنفٌي فِنّ شَ وْيّنيِ رَ. 
\q1 عَلَتَلَ شْنْشِ مِشِ نَشَن مَ، نَ سُشُمَ نَ فَنتَنيِ كُي. 
\q1  
\v 15 شَشِلِتَرٍحَ نَشَن نَ دِ مّدِ بْحّ كُي، 
\q1 عَ بَمَ شُرُ لُشُسِنيِ نَن سَابُي رَ. 
\q1  
\v 16 مِشِ نَشَن سٍتَرٍ تْورْ مَ فٍينِ ندٍ شَ قٍ رَ، 
\q1 نُن مِشِ نَشَن بَننَ كِمَ، 
\q1 نَ قِرِنيِ قِندِ مَ قُشَرِلَ نَن نَ. 
\s1 لْننِلَ شَ تَالِيٍ 
\q1  
\v 17 عِ عِ تُلِ مَتِ لْننِلَيٍ شَ مَرَ سِ رَ، 
\q1 عِ بْحّ رَبِ ﭑ مَ مَسٍنيِيٍ بّ. 
\q1  
\v 18 عَ لَن عِ شَ عٍ رَفَتَ عِ سٌندٌنيِ كُي، 
\q1 عٍ نَشَ مَكُيَ عِ دّ رَ. 
\q1  
\v 19 ﭑ وَ مَ عِ رَ سِقٍ نّ تٌ لْشْي، 
\q1 عَلَكٌ عِ شَ عِ يّتّ تَشُ عَلَتَلَ رَ. 
\q1  
\v 20 ﭑ بَرَ تَالِ تٌنفٌ سَشَن سّبّ عِ مَ، 
\q1 نَشٍيٍ قِندِشِ مَرَ سِ نُن لْننِ رَ عِ بّ، 
\q1  
\v 21 عَلَكٌ عِ شَ نْندِ شْرِ يَتِ كٌلٌن، 
\q1 عِ قَن شَ سَ نَ عِبَ عِ شّيمَ بّ. 
\b  
\q1  
\v 22 عِ نَشَ سٍتَرٍ رَهَلَكِ عِ شَ كْبِرِ سْتْ، 
\q1 عِ نَشَ تْورْ مِشِ تْوحّفّ، 
\q1  
\v 23 بَرِ مَ عَلَتَلَ تَن عٍ شُن مَقَلَمَ نّ، 
\q1 عَ قَ تْورْ مِشِيٍ يَشُييٍ تْورْ. 
\b  
\q1  
\v 24 عِ نَشَ بِرَ مِشِ بْحّ فبٍ قْشْ رَ، 
\q1 نَشَن شْنْشِ تّمُي بِرِن، 
\q1  
\v 25 شَ نَ مُ عَ رَ عِ قَن دَرِ مَ نّ نَ مْولِ رَ، 
\q1 نَ قَ قِندِ فَنتَنيِ رَ 
\q1 عِ سُشُمَ نَشَن نَ. 
\b  
\q1  
\v 26 عِ نَشَ لُ مِشِيٍ يَ مَ نَشٍيٍ تَانِمَ عٍ بٌورٍيٍ بّ، 
\q1 نَشٍيٍ سٍ دْشْمَ سّيكّ رَ مِشِيٍ بّ، 
\q1  
\v 27 شَ نَ مُ عَ رَ عٍ عِ شَ سَدٍ رَ مِنِمَ نّ عِ بُن مَ، 
\q1 عَ قَ لِ كْبِرِ مُ نَ عِ يِ رَ عِ شَ عَ قِ. 
\b  
\q1  
\v 28 عِ نَشَ عِ بَبَيٍ شَ نَانِنيِ مَتْنشُمَ سَشِ بَ عٍ يِرٍ دٍ. 
\b  
\q1  
\v 29 وَلِكّ نَشَن قَتَ عَ شَ وَلِ رَ، 
\q1 مَنفّيٍ نَن هَيِ لُمَ عَ مَ. 
\q1 عَ مُ وَلِمَ سٍتَرٍيٍ بّ. 
\c 23  
\s1 نَاقُلِ شَ فَنتَنيِ 
\q1  
\v 1 وٌ نُن كُنتِفِ نَ دْشْ وٌ دّفٍدٍ، 
\q1 عِ شَ عِ حّنفِ سَ عِ رَبَ كِ شْن مَ دٍ. 
\q1  
\v 2 شَ كَامّ نَ عِ مَ، عِ نَشَ عَ فبٍفبٍ دٌن. 
\q1  
\v 3 عِ نَشَ مِلّ نَ دٌنسٍ قَنيِ مَ، 
\q1 بَرِ مَ عَ نْمَ عِ مَدَشُدٍ. 
\b  
\q1  
\v 4 عِ نَشَ عِ يّتّ رَتَفَن نَاقُلِ قٍنقٍ مَ. 
\q1 كْبِرِ شْلِ نَشَ قِندِ عِ شَشِلِ وَشْنقٍ بِرِن نَ. 
\q1  
\v 5 شَ عِ عِ يَ تِ بَننَيَ رَ، 
\q1 عَ لْيمَ عِ مَ عَلْ سّفّ 
\q1 نَشَن تٍمَ كُيٍ مَ كِ نَشّ، عَ سِفَ. 
\b  
\q1  
\v 6 عِ نَشَ مِشِ حَاشِ شَ تَامِ دٌن، 
\q1 عِ نَشَ مِلَ عَ شَ دٌنسٍ قَنيِ مَ. 
\q1  
\v 7 نَ مِشِ مْولِ وَ مَ عِ مَدَشُقٍ نّ. 
\q1 عَ عَ قَلَمَ عِ بّ، «عِ دّفٍ، عِ مِن،» 
\q1 كْنْ مَرَقَنيِ يٌ مُ نَ عَ بْحّ كُي عِ بّ. 
\q1  
\v 8 عِ قَمَ نّ نَ دٌنسٍ بْشُندٍ، 
\q1 عِ شَ وْيّن قَنيِ قِندِ وْيّن قُقَقُ رَ. 
\b  
\q1  
\v 9 عِ نَشَ مَسٍنيِ تِ شَشِلِتَرٍ بّ، 
\q1 بَرِ مَ عَ يٌمَ نّ عِ شَ وْيّن قَنيِ بِرِن مَ. 
\b  
\q1  
\v 10 عِ نَشَ نَانِنيِ تْنشُمَ قٌرِ تَلَ. 
\q1 عِ نَشَ سٌ كِرِدِيٍ شَ شّ رَ، 
\q1  
\v 11 بَرِ مَ عٍ شُنمَقَلَمَ سّنبّ فبٌ، 
\q1 عَ عٍ فبٍحْشْمَ نّ. 
\b  
\q1  
\v 12 عِ بْحّ رَبِ شَرَنيِ بّ، 
\q1 عِ عِ تُلِ مَتِ مَرَ سِ قَنيِ رَ. 
\b  
\q1  
\v 13 عِ نَشَ تَفَن قٌنِكٍ مَتِنشِندٍ، 
\q1 شُرُ لُشُسِنيِ مُ عَ قَشَمَ. 
\q1  
\v 14 شَ عِ عَ شُرُ لُشُسِنيِ رَ، 
\q1 عِ بَرَ عَ نِي مَكَنتَ. 
\b  
\q1  
\v 15 ﭑ مَ دِ، شَ لْننِ قَنيِ لُ عِ بْحّ كُي، 
\q1 سّيوّ بَرَ لُ ﭑ تَن قَن بْحّ كُي. 
\q1  
\v 16 ﭑ بْحّ حّلّشِنمَ نّ عِ شَ وْيّن تِنشِنشِيٍ رَ. 
\b  
\q1  
\v 17 عِ نَشَ يُنُبِتْييٍ تْونّ، 
\q1 عِ شَ فَاشُ عَلَتَلَ نَن يَ رَ، 
\q1  
\v 18 عَلَكٌ عِ شَ شُننَكٍلِ سْتْ يَرٍ. 
\b  
\q1  
\v 19 ﭑ مَ دِ، عِ تُلِ مَتِ عَ قَنيِ رَ، 
\q1 عِ شَ شَشِلِ سْتْ، 
\q1 عِ بْحّ شَ لُ كِرَ تِنشِنشِ قَرِ. 
\q1  
\v 20 عِ نَشَ لُ سِيسِلَيٍ يَ مَ، 
\q1 شَ نَ مُ عَ رَ نَشٍيٍ شَ دٌنسٍ شْلِ دَنفِ عَ عِ. 
\q1  
\v 21 نَ مِشِ مْولِيٍ قِندِ مَ نّ سٍتَرٍيٍ رَ، 
\q1 عٍ شَ تُننَشْنّيَ عَ نِيَمَ نّ دُنكٌبِ فبَنسَن نَفٌرٌ عٍ مَ. 
\b  
\q1  
\v 22 عِ عِ تُلِ مَتِ عِ بَبَ رَ نَشَن عِ بَرِشِ، 
\q1 عِ نَشَ يٌ عِ نفَ مَ عَ نَ قٌرِ. 
\q1  
\v 23 نْندِ، لْننِ، شَرَنيِ، نُن شَشِلِ قَنيِ قٍن، 
\q1 عِ نَشَ مّي عٍ رَ. 
\q1  
\v 24 تِنشِنتْي بَبَ سّيوَ مَ نّ، 
\q1 شَشِلِمَ بَبَ حّلّشِنمَ نّ. 
\q1  
\v 25 عِ شَ قٍ بِرِن نَبَ عَلَكٌ عِ بَبَ نُن عِ نفَ شَ سّيوَ، 
\q1 عِ بَرِ مِشِيٍ شَ لُ حّلّشِنيِ كُي. 
\b  
\q1  
\v 26 ﭑ مَ دِ، عِ عِ بْحّ رَبِ ﭑ بّ، 
\q1 عِ شَ عِ يَ تِ ﭑ حّرّ كِ مِسَالِ رَ. 
\q1  
\v 27 لَنفٌي فِنّ قِندِشِ فَنتَنيِ نَن نَ، 
\q1 فِنّ يّنّشِ عِ رَبِرَ مَ نّ. 
\q1  
\v 28 نَ فِنّ مْولِ عِ يَنقَمَ نّ عَلْ مُحّتِ، 
\q1 عَ عَ نِيَمَ نّ شّمّ فبٍفبٍ شَ قِندِ يَنقَنتٍيٍ رَ. 
\b  
\q1  
\v 29 ندٍ تْورّ نُن نِمِسّ سْتْمَ؟ 
\q1 ندٍ لُمَ فٍرٍ نُن كَلَمُي يَ مَ؟ 
\q1 ندٍ بْنبْي قُقَقُ سْتْمَ؟ 
\q1 ندٍ يَ فبٍيلِمَ نّ سٌي؟ 
\q1  
\v 30 سِيسِلَيٍ نَن لُمَ نَ مْولِ سْتْقٍ رَ، 
\q1 بٍيرٍ مْولِ بِرِن حْشُنشِ نَشٍيٍ بّ. 
\q1  
\v 31 عِ نَشَ عِ يَ تِ وّنِ فبٍيلِ رَ، 
\q1 نَشَن مِن مُ شْنْ. 
\q1  
\v 32 عَ مِشِ شِنمَ نّ عَلْ بْشِمَسٍ، 
\q1 عَ عِ بُن عَلْ تَلِ. 
\q1  
\v 33 عِ يَيٍ سٍيٍ تٌمَ نَشٍيٍ مُ نَ دُنِحَ، 
\q1 عِ شَشِلِ عِقُمَ نّ. 
\q1  
\v 34 عِ لُمَ نّ قَ عَلْ شّمّ نَشَن سَشِ كُنكُي كُي بَا مْرْنيِيٍ قَرِ. 
\q1  
\v 35 سِيسِلَ نَن عَ قَلَمَ، «عٍ بَرَ ﭑ بْنبْ، 
\q1 كْنْ سٍسٍ مُ ﭑ تٌشِ. 
\q1 ﭑ شُنُمَ مُن تّمُي؟ 
\q1 ﭑ مَن وَ مَ بٍيرٍ ندٍ شْن.» 
\c 24  
\s1 مِلَقٍ مِشِ حَاشِيٍ مَ 
\q1  
\v 1 عِ نَشَ مِلَ مِشِ حَاشِيٍ مَ، 
\q1 عِ نَشَ تِن لُقٍ عٍ يَ مَ. 
\q1  
\v 2 عٍ بْحّ كٌبِ، عٍ شَ وْيّنيِ شْرْشْ. 
\b  
\q1  
\v 3 لْننِ بَنشِ تِمَ نّ، 
\q1 شَشِلِ قَنيِ دٍنبَيَ رَ سَبَتِ عَ كُي. 
\q1  
\v 4 قٍ كٌلٌنيِ عَ نِيَمَ نّ عٍ شَ هَرِفٍ سْتْ، 
\q1 هَرِفٍ هَفِفّ نَشَن مَنِيّ مُ نَ. 
\b  
\q1  
\v 5 لْننِلَ سّنبّ فبٌ، 
\q1 شَشِلِمَ سّنبّ شُن مَسَمَ نّ. 
\q1  
\v 6 عِ هَيِ نَ مَرَ سِمَ عَلَكٌ قٍ شَ سْونّيَ، 
\q1 شُننَكٍلِ سْتْمَ مَرَ سِمَيٍ نَن سَابُي رَ. 
\b  
\q1  
\v 7 لْننِ شْرْشْ شَشِلِتَرٍ بّ، 
\q1 وْيّنيِ يٌ مُ نَ 
\q1 عَ نَشَن قَلَمَ مَلَنيِ كُي. 
\b  
\q1  
\v 8 مِشِ نَشَن قٍ حَاشِ شَبُمَ، 
\q1 عَ شِلِ نّ كْوتَ حَاشِ شَبُي. 
\q1  
\v 9 شَشِلِتَرٍحَ قِندِشِ يُنُبِ نَن نَ. 
\q1 عَدَ مَدِيٍ مِشِ مَيٍلٍ شْنمَ. 
\b  
\q1  
\v 10 شَ لِمَنِيَ بَمَ عِ يِ رَ تْورّ كُي، 
\q1 عِ سّنبّ مُ فبٌ. 
\b  
\q1  
\v 11 مِشِيٍ رَتَنفَ نَشٍيٍ نَ سَيَ كِرَ شْن مَ، 
\q1 عٍ بَ مِشِيٍ يِ رَ نَشٍيٍ وَ مَ عٍ قَشَقٍ. 
\q1  
\v 12 شَ عِ عَ قَلَمَ، «مُشُ مُ نُ عَ كٌلٌن،» 
\q1 نَشَن بْحّيٍ مَ قٍ كٌلٌن، عَ مُ نَ تٌمَ؟ 
\q1 نَشَن حّنفِ سَشِ عِ شَ سِمَيَ شْن مَ، 
\q1 نَ مُ عِ قُرِ عِقٍ كٌلٌن؟ 
\q1 عَ مُ كَنكَن سَرٍ رَفبِلٍنمَ عَ مَ شّ؟ 
\b  
\q1  
\v 13 ﭑ مَ دِ، كُمِ ندٍ دٌن، 
\q1 بَرِ مَ سٍ حْشُنمّ نَن عَ رَ، عَ قَن عِ قَتٍ بّ. 
\q1  
\v 14 كْنْ عِ شَ عَ كٌلٌن شَشِلِ لُمَ نّ عَلْ كُمِ. 
\q1 شَ عِ عَ سْتْ، عِ شُننَكٍلِ لِمَ نّ يَرٍ، 
\q1 عِ شَشِلِ تِمَ نَشَن نَ، نَ مُ كَنَمَ. 
\b  
\q1  
\v 15 عِ نَشَ فَنتَنيِ عِتَلَ تِنشِنتْي بّ، 
\q1 عِ نَشَ عَ شْنيِ كَنَ. 
\q1  
\v 16 تِنشِنتْي نْمَ بِرَدٍ سَنمَيَ سٌلٌقٍرٍ، عَ مَن كٍلِ. 
\q1 كْنْ مِشِ حَاشِ بِرَ مَ نّ تْورّ كُي كٍرٍنيِ رَ. 
\b  
\q1  
\v 17 عِ نَشَ حّلّشِن عِ يَشُي شَ بِرّ رَ، 
\q1 عِ بْحّ نَشَ رَقَن عِ مَ عِ نَ عَ تٌ تْورْ رَ، 
\q1  
\v 18 شَ نَ مُ عَ رَ عَلَتَلَ عِ شَ مَحْشُنيِ كٌبِ تٌمَ نّ، 
\q1 عَ قَ عَ شَ شْنّ رَفبِلٍن عِ يَشُي قْشْ رَ. 
\b  
\q1  
\v 19 عِ نَشَ شْنْ قٍ حَاشِ رَبَيٍ مَ، عِ نَشَ عٍ تْونّ. 
\q1  
\v 20 مِشِ حَاشِ مُ قٍ قَنيِ لِمَ يَرٍ، 
\q1 عٍ شَ لَنثُي قَمَ نّ شُبٍندٍ. 
\b  
\q1  
\v 21 ﭑ مَ دِ، عِ شَ فَاشُ عَلَتَلَ يَ رَ، عِ شَ مَنفّيٍ بِنيَ، 
\q1 عِ نَشَ لُ مَتَندِلَيٍ يَ مَ، 
\q1  
\v 22 بَرِ مَ هَلَكِ نَن قَمَ عٍ رَتّرّننَدٍ. 
\q1 ندٍ عَ كٌلٌن عَلَ هَلَكِ نَشَن دُ سُمَ عٍ شُن نَ؟ 
\d  
\v 23 لْننِلَ فبّتّيٍ شَ تَالِيٍ نَن يَ؛ 
\q1 وٌ نَشَ مِشِ رَقِسَ عَ بٌورٍ بّ كِيتِ كُي. 
\q1  
\v 24 مِشِ نَشَن عَ قَلَمَ مِشِ حَاشِ بّ، «عِ تِنشِن،» 
\q1 حَمَ بِرِن قَمَ نّ نَ كَنيِ دَنكَدٍ، 
\q1 سِ بِرِن شْنْمَ نّ عَ مَ. 
\q1  
\v 25 كْنْ مِشِ نَشَن مِشِ حَاشِ كَلَمُمَ نْندِ كُي، 
\q1 نَ كَنيِ بَرَ قٍ قَنيِ رَبَ، عَ قَمَ نّ بَرَكّ سْتْدٍ. 
\b  
\q1  
\v 26 يَابِ تِنشِنشِ حْشُن نّ عَلْ شَنُنتٍنيِ شَ شّيبُي. 
\b  
\q1  
\v 27 قّنتّن عِ شَ وَلِ مَ، عِ قٍ رَبَ بَلٌي سْتْقٍ رَ، 
\q1 نَ تّمُي عِ قَ دٍنبَيَ رَ سَبَتِ. 
\b  
\q1  
\v 28 عِ نَشَ عِ دْشْبٌورٍ تْوحّفّ. 
\q1 وُلٍ نَشَ مِنِ عِ دّ كُي. 
\q1  
\v 29 عِ نَشَ عَ قَلَ، 
\q1 «عَ نَشَن نَبَشِ ﭑ نَ، قٌ ﭑ قَن نَ رَبَ عَ رَ، 
\q1 ﭑ عَ شَ وَلِ كٌبِ سَرٍ رَفبِلٍنمَ نّ عَ مَ.» 
\b  
\q1  
\v 30 ﭑ بَرَ دَنفِ تُننَشْنّ ندٍ شَ شّ رَ، 
\q1 عَ نُن شَشِلِتَرٍ ندٍ شَ سَنسِ يِرٍ رَ. 
\q1  
\v 31 ﭑ تُنبٍيٍ نُن حٌوفٍ حَاشِيٍ نَن تُن تٌ نَا. 
\q1 تّتّ قَن نُ بِرَشِ. 
\q1  
\v 32 ﭑ نَشَ نَ قٍ مَحْشُن هَن عَ نَشَ قِندِ شَشِلِ رَ ﭑ بّ؛ 
\q1  
\v 33 شِشْلِ نَ عِ سُشُ، عِ كِنسْن قْلْ، عِ عِ بّلّشّيٍ قِندِفِلِن عِ مَ، 
\q1  
\v 34 سٍتَرٍحَ قَ دُتُن عِ مَ عَلْ مُحّتِ حَاشِ. 
\c 25  
\s1 قٍ نْشُنشِ 
\d  
\v 1 سُلٍمَنِ شَ تَالِ ندٍيٍ نَن يَ، يُدَ مَنفّ شٍسٍكِيَ نَشٍيٍ سّبّ؛ 
\q1  
\v 2 عَلَ قٍيٍ نْشُنمَ، مَنفّيٍ كَتَمَ عٍ قَهَامُدٍ. 
\q1  
\v 3 كٌورٍ شَ مَءِتٍيَ نُن بْشِ شَ تِلِنيِ مُ كٌلٌنمَ. 
\q1 مَنفّ سٌندٌن مَ قٍ قَن مُ نْمَ كٌلٌندٍ. 
\b  
\q1  
\v 4 شَ فبٍتِ فبِ بَ، عَ نْمَ قِندِدٍ سٍ تٌقَنيِ رَ. 
\q1  
\v 5 شَ مِشِ حَاشِ بَ مَنفّ رَبِلِنيِ، 
\q1 عَ شَ مَنفّيَ سَبَتِمَ نّ تِنشِنيِ سَابُي رَ. 
\b  
\q1  
\v 6 عِ نَشَ عِ يّتّ عِفبٌ مَنفّ يَ شْرِ، 
\q1 عِ نَشَ عِ يّتّ قِندِ مِشِ شُنفبٍ رَ. 
\q1  
\v 7 عَ قِسَ كُنتِفِ نَن شَ عِ شِلِ عِ شَ دْشْ يِرٍ ندٍ، 
\q1 دِنّ عَ شَ عِ رَكٍلِ مِشِ شُنفبٍ ندٍ بّ. 
\b  
\q1  
\v 8 عِ نَ قٍ ندٍ تٌ، عِ نَشَ فبَتَ سِفَقٍ رَ كِيتِ بَنشِ، 
\q1 بَرِ مَ شَ قٍ فبّتّ مِنِمَ عِ مُ نَشَن كٌلٌن، 
\q1 نَ نْمَ عِ رَيَافِدٍ عِ دْشْبٌورٍ يَ شْرِ. 
\b  
\q1  
\v 9 قٍ نَ سٌ وٌ نُن عِ دْشْبٌورٍ تَفِ، 
\q1 عِ نَشَ مِشِ فبّتّ شَ فُندٌ مَكّنّن، 
\q1  
\v 10 شَ نَ مُ عَ رَ مِشِ ندٍ نَ نَ كٌلٌن، 
\q1 عَ عِ رَيَافِمَ نّ، 
\q1 عِ قَ شِلِ كَنّ سْتْ عَبَدَن. 
\b  
\q1  
\v 11 وْيّنيِ قَلَشِ عَ كِ مَ، 
\q1 عَ تٌقَن عَلْ شّيمَ نُن فبٍتِ. 
\b  
\q1  
\v 12 شَشِلِمَ شَ مَرَ سِ تِدٍ فبٌ شَشِلِ قٍنيِ بّ، 
\q1 عَلْ شُرُندّ نَشَن يَءِلَنشِ شّيمَ قَنيِ رَ. 
\b  
\q1  
\v 13 دُفُتّفّ شّيرَ حْشُن عَ شّيمَ بّ، 
\q1 عَلْ قٌيٍ قَنيِ نَشَن قَمَ وَلِكّيٍ مَ شّ شَبَ تّمُي. 
\q1  
\v 14 مِشِ نَشَن عَ قَلَمَ عَ سٍتَرٍيٍ كِمَ، كْنْ عَ مُ عَ رَبَمَ، 
\q1 نَ كَنيِ لُشِ نّ عَلْ نُشُي نُن قٌيٍ نَشَن مُ قَمَ يٍ رَ. 
\b  
\q1  
\v 15 تُننَبّشِيَ عَ نِيَمَ نّ مَنفّ شَ نَتّ مَسَرَ، 
\q1 وْيّن حْشُنمّ سّنبّ فبٌ هَن عَ نْمَ شْرِ رَفِرَدٍ. 
\b  
\q1  
\v 16 عِ نَ كُمِ تٌ، نَشَن عِ رَلِمَ، نَ نَن كْن. 
\q1 شَ عَ رَدَنفِ يّ، عِ عَ بْشُنمَ نّ. 
\q1  
\v 17 عِ نَشَ عِ دْشْبٌورٍ شْنيِ سِفَقٍ رَدِفَن، 
\q1 شَ نَ مُ عَ رَ عِ شَ قٍ قَمَ نّ رَحَاشُدٍ عَ مَ. 
\b  
\q1  
\v 18 عِ دْشْبٌورٍ تْوحّفّقٍ شْنْ 
\q1 عَلْ سَنتِدّفّمَ شَاحّشِ، عَلْ تَنبّ رَ مٍلُشِ. 
\q1  
\v 19 عِ شَشِلِ تِقٍ يَنقَنتٍ رَ، نَ لُشِ نّ 
\q1 عَلْ حِنيِ كَنَشِ، عَلْ سَنيِ مَبّنشِ. 
\b  
\q1  
\v 20 مِشِ نَشَن سِفِ سَمَ مِشِ سُننُنشِ يَ شْرِ، 
\q1 نَ مَنِيَ مِشِ رَ 
\q1 نَشَن شِنبٍلِ دُفِ بَمَ قُرٍ مَ مَ شِنبٍلِ تّمُي. 
\q1 عَ شَ سُننُنيِ شُن نَن تُن مَسَمَ عَلْ مِشِ نَ فبّنفبّ سَ قِ يَ عِ. 
\b  
\q1  
\v 21 شَ كَامّ نَ عِ يَشُي مَ، دٌنسٍ سٌ عَ يِ رَ. 
\q1 شَ يٍ شْلِ نَ عَ مَ، يٍ سٌ عَ يِ رَ، عَ شَ عَ مِن. 
\q1  
\v 22 شَ عِ نَ وَلِ مْولِ رَبَ عَ بّ، 
\q1 نَ لُشِ نّ عَلْ عِ بَرَ تّ وٌلٍ دْشْ عَ شُن مَ. 
\q1 عَلَتَلَ نَن عِ فبٍحْشْمَ. 
\q1  
\v 23 قٌيٍ نَشَن كٍلِمَ كْولَ مَ، 
\q1 نَ قَمَ نّ تُنّ رَ. 
\q1 نّنيِ نَشَن نَاقِشِيَ قَلَمَ، 
\q1 نَ مِشِ يَتَفِ عِ شْنْمَ نّ. 
\q1  
\v 24 لُقٍ رَ بَنشِ قَرِ مَ، 
\q1 نَ قِسَ لُقٍ رَ فِنّ قِتِنّتْي سّيتِ مَ بَنشِ كُي. 
\q1  
\v 25 شِبَارُ قَنيِ نَشَن كٍلِشِ يِرٍ مَكُيٍ، 
\q1 عَ مَنِيَ يٍ شِنبٍلِ رَ مِشِ تَفَنشِ بّ. 
\q1  
\v 26 تِنشِنتْي نَشَن نَتّ تٌنفٌمَ، 
\q1 عَ شَ بِرَ مِشِ حَاشِ قْشْ رَ، 
\q1 نَ مَنِيَشِ يٍ دُلٌنيِ نَن نَ نَشَن بَرَ دُندَ، 
\q1 عَ يٍ مُ قَن سْنْن. 
\q1  
\v 27 كُمِ دٌنقٍ عَ رَدَنفِ عَ عِ، نَ مُ قَن. 
\q1 بِنيّ قٍنقٍ عِ يّتّ رَ، نَ قَن مُ قَن. 
\q1  
\v 28 مِشِ نَشَن مُ نْمَ عَ يّتّ رَشَندٍ عَ نَ شْنْ، 
\q1 نَ لُشِ نّ عَلْ تَا كَنَشِ نَشَن تّتّ بَرَ بِرَ. 
\c 26  
\s1 لْننِتَرٍ نُن بِنيّ 
\q1  
\v 1 كُيٍ مُ شِنبٍلِمَ سٌفٌقُرٍ رَ، 
\q1 تُنّ مُ قَمَ مَالٍ شَبَ تّمُي، 
\q1 نَ كِ عَ مُ لَن لْننِتَرٍ شَ بِنيّ سْتْ. 
\q1  
\v 2 دَنكّ مُ مِشِ قَنيِ سُشُمَ. 
\q1 نَ قٍ لُمَ نّ عَلْ شْنِ نَشَن مُ دْشْمَ، كٌيِنمَ شَ عَ فْنْ. 
\b  
\q1  
\v 3 سٌي بْنبْمَ نّ عَلَكٌ عَ شَ عَ فِ، 
\q1 كَرَقٌي رَ سٌمَ نّ سٌقَلٍ دّ عِ عَلَكٌ مِشِ شَ عَ رَحّرّ، 
\q1 شَشِلِتَرٍ قَن شُرُ مَ نّ وُرِ رَ عَلَكٌ عَ شَ مَتِنشِن. 
\b  
\q1  
\v 4 عِ نَشَ شَشِلِتَرٍ يَابِ عَ مَحْشُن كِ رَ، 
\q1 شَ نَ مُ عَ رَ وٌ بِرِن لَن. 
\q1  
\v 5 عِ شَ شَشِلِتَرٍ يَابِ عَ مَحْشُن كِ مَ، 
\q1 شَ نَ مُ عَ رَ عَ عَ يّتّ قِندِ مَ شَشِلِمَ نَن نَ. 
\b  
\q1  
\v 6 مِشِ نَشَن شَشِلِتَرٍ شّيمَ مَسٍنيِ ندٍ تِدٍ، 
\q1 نَ بَرَ عَ يّتّ تْورْ. 
\q1  
\v 7 تَالِ وْيّنيِ نَشَن مِنِمَ شَشِلِتَرٍ دّ عِ، 
\q1 نَ لُشِ نّ عَلْ مَبّنيِ سَنيِ 
\q1 نَشَن سّنبّ مُ نَ. 
\q1  
\v 8 شَشِلِتَرٍ بِنيَقٍ لُشِ نّ عَلْ فّمّ سَقٍ لَاتِ كُي. 
\q1  
\v 9 تَالِ وْيّنيِ نَشَن مِنِمَ شَشِلِتَرٍ دّ عِ، 
\q1 نَ لُشِ نّ عَلْ لُشُسِنيِ 
\q1 نَشَن نَ سِيسِلَ بّلّشّ عِ. 
\q1  
\v 10 مِشِ نَشَن وَلِ سٌمَ شَشِلِتَرٍ يِ رَ، 
\q1 شَ نَ مُ عَ رَ مِشِ يِ رَ عَ مُ نَشَن كٌلٌن، 
\q1 نَ لُشِ نّ عَلْ سْورِ نَشَن تَنبّ وٌلِمَ حَمَ مَبِرِ. 
\q1  
\v 11 شَشِلِتَرٍ نَشَن فبِلٍنمَ عَ شَ دَشُحَ مَ، 
\q1 نَ لُشِ نّ عَلْ بَرٍ نَشَن فبِلٍنمَ عَ شَ بْشُنيِ دٌن نَ. 
\q1  
\v 12 شَشِلِتَرٍ قَن قِسَ مِشِ بّ نَشَن عَ يّتّ قِندِشِ لْننِلَ رَ. 
\q1 قٍ سْونّيَمَ نّ نَ شَشِلِتَرٍ بّ دَنفِقٍ نَ يّتّ عِفبٌي رَ. 
\b  
\q1  
\v 13 مِشِ تُننَشْنْشِ نَن عَ قَلَمَ، 
\q1 «يّتّ نَ كِرَ رَ، يّتّ نَ تَا كُي.» 
\q1  
\v 14 نَادّ رَبِمَ، عَ مَن نَفَلِمَ، 
\q1 عَلْ تُننَشْنّ نَشَن عَ يَ رَبِمَ عَ شَ سَدٍ مَ، عَ مَن شِ. 
\q1  
\v 15 مِشِ تُننَشْنْشِ عَ دٌنسٍ سُشُمَ عَ بّلّشّ رَ، 
\q1 كْنْ عَ مُ عَ رَ سٌمَ عَ دّ عِ تُننَشْنْيَ سَابُي رَ. 
\q1  
\v 16 مِشِ تُننَشْنْشِ عَ يّتّ رَقِسَ شَشِلِمَ سٌلٌقٍرٍ بّ 
\q1 نَشٍيٍ يَابِ قِمَ شَشِلِمَيَ رَ. 
\b  
\q1  
\v 17 دَنفِ مِشِ نَشَن عَ يّتّ رَ سٌمَ فٍرٍ كُي نَشَن مُ عَ مَتٌشِ، 
\q1 نَ مَنِيَ مِشِ رَ نَشَن بَرٍ سُشُمَ عَ تُلِيٍ مَ. 
\q1  
\v 18‏-19 مِشِ نَشَن عَ بٌورٍ مَدَشُ، عَ قَ عَ قَلَ، «بٍرٍ نَن نُ عَ رَ،» 
\q1 نَ مَنِيَ دَشُي رَ نَشَن تّ مَشِرِ مَ تَنبّ مَ، عَ عَ وٌلِ. 
\q1  
\v 20 شَ يٍفٍ مُ نَ، تّ شُبٍنمَ نّ. 
\q1 شَ مِشِ كٍرٍن عَ سَبَرِ، سْنشْي دَنمَ نّ. 
\q1  
\v 21 تِفٍ قِندِ مَ نّ تّ وٌلٍ رَ، يٍفٍ قِندِ تّ رَ. 
\q1 سْنشْلَ قَن فٍرٍ رَبِرَ مَ نَ كِ نّ. 
\q1  
\v 22 نَاقِشِ شَ مَسٍنيِ لُشِ نّ عَلْ دٌنسٍ حْشُنمّ، 
\q1 نَشَن فٌرٌ مَ مِشِ قُرِ كُي. 
\q1  
\v 23 مِشِ حَاشِ نَشَن وْيّن حْشُنمّ قَلَمَ، 
\q1 نَ لُشِ نّ عَلْ بِرِكِ تٌ حَاشِيٍ سٍ قِيشّ مَسٌمَ نَشٍيٍ مَ. 
\b  
\q1  
\v 24 مِشِ حَاشِ عَ بٌورٍ مَدَشُمَ وْيّن حْشُنمّ رَ، 
\q1 كْنْ يَنقَنتٍيَ نَ عَ بْحّ كُي. 
\q1  
\v 25 هَلِ عَ وْيّنيِ حْشُن، عِ نَشَ لَ عَ رَ دٍ، 
\q1 بَرِ مَ كٌبِحَ نَ عَ سٌندٌنيِ كُي. 
\q1  
\v 26 عَ شَ شْننَنتٍيَ نْشُنشِ عَ شَ مَيٍندٍنيِ سَابُي رَ، 
\q1 كْنْ عَ شَ كٌبِحَ قَمَ نّ مِنِدٍ كّنّ مَ مِشِيٍ تَفِ. 
\b  
\q1  
\v 27 مِشِ نَشَن يِلِ فٍمَ فَنتَنيِ رَ، 
\q1 عَ تَن نَن قَمَ بِرَدٍ عَ كُي. 
\q1 مِشِ نَشَن فّمّ وٌلِمَ، 
\q1 نَ فّمّ فبِلٍنمَ عَ تَن نَن مَ. 
\q1  
\v 28 وُلٍ قَلّ تْوحّفّتْي نَن شْنمَ، 
\q1 مِشِ نَشَن عَ بٌورٍ مَتْشْمَ وُلٍ رَ، 
\q1 نَ كَسَرّ نَن تُن نَبَمَ. 
\c 27  
\s1 تِنَ شَ قٍ 
\q1  
\v 1 عِ نَشَ عِ يّتّ مَتْشْ تِنَ شَ قٍ رَ، 
\q1 بَرِ مَ عِ مُ عَ كٌلٌن نَشَن قَمَ رَبَدٍ. 
\q1  
\v 2 عِ نَشَ عِ يّتّ مَتْشْ، عَ لُ مِشِ فبّتّ نَن شَ عِ مَتْشْ. 
\q1 مِشِ فبّتّ شَ مَتْشْي قِسَ عِ يّتّ شَ مَتْشْي بّ. 
\b  
\q1  
\v 3 كٌتٍ نَن فّمّ رَ، مّيّنيِ قَن بِنيَ، 
\q1 كْنْ شَشِلِتَرٍ شَ فبّسّنشْننّيَ شْرْشْ عَ بِرِن بّ. 
\b  
\q1  
\v 4 بْحّ شَ تٍ شْرْشْ، شْنّ قَن مَفَاشُ، 
\q1 كْنْ ندٍ نْمَ تِدٍ تْونّ تَن يَ رَ؟ 
\b  
\q1  
\v 5 مَرَكْرْ سِ رَ مِنِقٍ كّنّ مَ مِشِ شَ تَنتَنيِ شَ قٍ رَ، 
\q1 نَ قِسَ مَرَكْرْ سِ نْشُنقٍ مَرَقَنيِ شَ قٍ رَ. 
\q1  
\v 6 عِ شَنُنتٍنيِ شَ مَرَكْرْ سِ شْنْ، كْنْ لَ نَ رَ. 
\q1 عِ يَشُي تَن عِ مَدَشُمَ نّ وْيّنيِ حْشُنمّ رَ. 
\q1  
\v 7 مِشِ لُفَشِ مُ وَ مَ هَلِ كُمِ شْن، 
\q1 كْنْ كَامّتْي تَن، هَلِ سٍ شْنّ نَن عَ رَ، 
\q1 عَ حْشُن عَ بّ. 
\b  
\q1  
\v 8 شّمّ نَشَن عَ مَكُيَمَ عَ شْنيِ رَ، 
\q1 نَ مَنِيَ شْنِ رَ نَشَن عَ مَكُيَمَ عَ تّي رَ. 
\b  
\q1  
\v 9 لَبُندّ نُن سُرَيِ بْحّ رَ سّيوَ مَ نّ، 
\q1 عَلْ عِ شَنُنتٍنيِ شَ مَرَ سِ قَنيِ. 
\q1  
\v 10 عِ نَشَ عِ دّقَنبٌورٍ رَبٌلٌ، 
\q1 عِ نَشَ عِ بَبَ دّقَنبٌورٍ رَبٌلٌ. 
\q1 عِ نَشَ عِ بَرِبٌورٍ شِلِ عِ شَ تْورّ مَ. 
\q1 عِ دْشْبٌورٍ مَكْرّشِ قِسَ عِ نفَشَكٍرٍنيِ مَكُيَشِ بّ. 
\b  
\q1  
\v 11 ﭑ مَ دِ، بِرَ لْننِ قْشْ رَ عَلَكٌ ﭑ بْحّ شَ رَقَن ﭑ مَ. 
\q1 نَ كُي ﭑ نْمَ نّ مِشِ يَابِدٍ نَشَن وَ مَ ﭑ نَيَافِقٍ. 
\b  
\q1  
\v 12 شَشِلِمَ عَ يّتّ رَتَنفَمَ قٍ شْرْشْي مَ، 
\q1 كْنْ شَشِلِتَرٍ تَن سٌمَ نّ نَ كُي، عَ قَ حَشَنكَتّ سْتْ. 
\b  
\q1  
\v 13 مِشِ شَ سّيكّ سٍ رَ سُشُ عَ نَشَن تَانِ شْحّ بّ، 
\q1 شَ نَ مُ عَ رَ عَ نَشَن تَانِ لَنفٌي بّ. 
\b  
\q1  
\v 14 عِ نَ عِ دْشْبٌورٍ شّيبُ عِ شُي عِتٍشِ رَ فّيسّفّ فبٍ رَ، 
\q1 عِ بَرَ عَ بْحّ رَحَاشُ عَ مَ عِ تَن مَبِرِ. 
\b  
\q1  
\v 15 فِنّ قِتِنّتْي لُشِ نّ عَلْ تُنّ دِ نَشَن قّيحّنمَ قَ رَ. 
\q1  
\v 16 نَ فِنّ مْولِ رَشَنقٍ، نَ مَنِيَمَ قٌيٍ رَشَنقٍ رَ، 
\q1 عَ سُشُقٍ شْرْشْ عَلْ تُرٍ سُشُقٍ عِ بّلّشّ رَ. 
\b  
\q1  
\v 17 وُرٍ نَن وُرٍ رَلُفَنمَ. 
\q1 مِشِ عَ بٌورٍ رَكَمَلِمَ نّ. 
\b  
\q1  
\v 18 مِشِ نَشَن مّينِمَ شْرّ بِلِ مَ، عَ عَ بٌفِ دٌنمَ نّ. 
\q1 مِشِ نَشَن مّينِمَ عَ كَرَ مْشْ مَ، عَ بِنيّ سْتْمَ نّ. 
\b  
\q1  
\v 19 عَدَ مَ يَتَفِ نَ كِ نَشّ، نَ نَن مِنِمَ يٍ شْورَ. 
\q1 عَدَ مَ يَتِ نَ كِ نَشّ، نَ تٌمَ نّ عَ بْحّ كُي. 
\b  
\q1  
\v 20 عَلِفِيَمَ مُ وَ سَمَ مِشِ قَشَشِيٍ رَ، 
\q1 عَدَ مَ قَن مُ وَ سَمَ عَ وَشْنسٍ رَ. 
\b  
\q1  
\v 21 شّيمَ نُن فبٍتِ مَتٌمَ تّ رَ، 
\q1 كْنْ مِشِ مَكِيتِمَ عَ شِلِ نَن مَ. 
\q1  
\v 22 عِ نَ مَالٍ دِن، عَ لَفِ بَمَ نّ عَ مَ، 
\q1 كْنْ شَشِلِتَرٍحَ مُ بَمَ شَشِلِتَرٍ بْحّ كُي. 
\b  
\q1  
\v 23 عِ شَ عِ شَ شُرُ سٍ بِرِن كٌلٌن عَ قَنيِ رَ، عِ شَ مّينِ عٍ مَ، 
\q1  
\v 24 بَرِ مَ بَننَيَ مُ بُمَ تّمُي بِرِن، 
\q1 شُننَكٍلِ قَن مُ بُمَ عَبَدَن. 
\q1  
\v 25 شُرُ سٍيٍ نَ فّ عٍ بَلٌدٍ حٌوفٍ رَ نَشَن تٌمَ قِيلِ مَ نُن فٍيَ قَرِ، 
\q1  
\v 26 يّشّييٍ شَبٍ يَءِلَن دُفِ رَ عِ بّ، 
\q1 سِ كٌنتٌنيِ قِندِ كْبِرِ رَ عِ شّ سَرَ مَ نَشَن نَ، 
\q1  
\v 27 سِ شِحّ قِندِ عِ شَ دٍنبَيَ نُن عِ شَ كٌنيِيٍ بَلٌ سٍ رَ. 
\c 28  
\s1 مِشِ حَاشِ شَ فَاشُي 
\q1  
\v 1 مِشِ حَاشِيٍ لُمَ نّ فَاشُي كُي، 
\q1 عٍ عٍ فِمَ نّ هَلِ مِشِ مُ عٍ قْشْ رَ. 
\q1 تِنشِنتْييٍ تَن مُ فَاشُمَ، 
\q1 عٍ سُو سَ عَلْ يّتّ. 
\q1  
\v 2 مَنفّ دِيٍ وُيَ حَمَ مَتَندِلَ يَ مَ، 
\q1 كْنْ مَنفّ شَشِلِمَ قَتَ حَمَ رَشَندٍ. 
\b  
\q1  
\v 3 سٍتَرٍ نَشَن عَ بٌورٍ سٍتَرٍيٍ تْورْ مَ، 
\q1 نَ مَنِيَ تُنّ وُندٍ رَ نَشَن شّ كَنَمَ. 
\q1  
\v 4 سّرِيّ مَتَندِ مِشِ حَاشِ مَتْشْمَ نّ، 
\q1 سّرِيّ رَبَتُي تَن شْنْمَ نّ مِشِ كٌبِ مَ. 
\q1  
\v 5 مِشِ حَاشِيٍ مُ سّرِيّ كٌلٌن، 
\q1 كْنْ عَلَتَلَ قٍنمَيٍ عَ قَهَامُمَ نّ عَ قَنيِ رَ. 
\q1  
\v 6 سٍتَرٍ تِنشِنشِ قِسَ بَننَ تِنشِنتَرٍ بّ. 
\q1  
\v 7 سّرِيّ بَتُلَ قِندِشِ دِ شَشِلِ قَنيِ نَن نَ، 
\q1 كْنْ وَ سَتَرٍ تَن عَ بَبَ رَيَافِمَ نّ. 
\q1  
\v 8 مِشِ نَشَن عَ شَ نَاقُلِ شُن مَسَمَ رِبَ رَ، 
\q1 عَ شَ بَننَيَ فبِلٍنمَ نّ كِنِكِنِنتٍ مَ. 
\b  
\q1  
\v 9 مِشِ نَشَن تٌندِ مَ عَ تُلِ مَتِدٍ سّرِيّ رَ، 
\q1 عَلَ مُ عَ شَ دُبَ سُشُمَ قٍوٌ. 
\q1  
\v 10 مِشِ نَشَن تِنشِنتْييٍ رَتَنتَنمَ، 
\q1 عَ بِرَ مَ عَ يّتّ كَن شَ فَنتَنيِ نَن كُي، 
\q1 تِنشِنتْي تَن قَ كّ قَنيِ سْتْدٍ. 
\q1  
\v 11 بَننَ مِشِ حْشْ عَ مَ عَ شَ لْننِ فبٌ، 
\q1 كْنْ سٍتَرٍ شَشِلِمَ نْمَ نّ نَ كَنيِ رَ. 
\q1  
\v 12 تِنشِنتْييٍ شُن نَ رَكٍلِ، حَمَ حّلّشِنمَ نّ، 
\q1 كْنْ تِنشِنتَرٍ شُن نَ رَكٍلِ، حَمَ عَ نْشُنمَ نّ. 
\b  
\q1  
\v 13 مِشِ نَشَن عَ شَ يُنُبِيٍ نْشُنمَ، عَ شَ قٍ مُ سْونّيَمَ، 
\q1 كْنْ مِشِ نَشَن عَ تِمَ عَ شَ يُنُبِيٍ رَ، عَ فبِلٍن عٍ قْشْ رَ، عَلَ كِنِكِنِمَ عَ مَ. 
\q1  
\v 14 سّيوّ نَ مِشِ بّ نَشَن فَاشُمَ عَلَ يَ رَ، 
\q1 كْنْ بْحّ شْرْشْي كَنيِ لُمَ تْورّ نَن كُي. 
\b  
\q1  
\v 15 مِشِ حَاشِ نَشَن حَمَ سٍتَرٍ يَمَرِ مَ، 
\q1 عَ لُشِ نّ عَلْ يّتّ مَفَاشُشِ نُن وُلَءِ سُبٍ شَاحّ. 
\q1  
\v 16 مَنفّ شَشِلِتَرٍ مِشِ تْورْ مَ نّ، 
\q1 كْنْ مَنفّ نَشَن نَاقُلِ تِنشِنتَرٍ شْنمَ، 
\q1 نَ سِمَيَ شْنكُيٍ سْتْمَ نّ. 
\b  
\q1  
\v 17 مِشِ نَشَن عَ كٌلٌن عَ بْحّ كُي عَ قَشّ تِشِ، 
\q1 نَ لُمَ عَ فِ رَ نّ هَن عَلِفِيَمَ. 
\q1 مِشِ يٌ نَشَ نَ كَنيِ مَلِ. 
\q1  
\v 18 مِشِ نَشَن حّرّ مَ تِنشِنيِ رَ، نَ كِسِمَ نّ، 
\q1 كْنْ قِلَنكَقُي تَن بِرَ مَ نّ كٍرٍنيِ رَ. 
\b  
\q1  
\v 19 مِشِ نَشَن عَ شَ بْشِ رَوَلِمَ، نَ بَلٌي سْتْمَ نّ، 
\q1 كْنْ نَشَن بِرَ مَ قٍ قُقَقُ قْشْ رَ، نَ سٍتَرٍحَ نَن سْتْمَ. 
\q1  
\v 20 مِشِ دُفُتّفّشِ بَرَكّ سْتْمَ نّ، 
\q1 كْنْ نَشَن فبَتَمَ بَننَيَ رَ، عَ حَشَنكَتَمَ نّ. 
\q1  
\v 21 عَ مُ لَن مِشِ شَ مِشِ رَقِسَ عَ بٌورٍ بّ، 
\q1 كْنْ مِشِ ندٍ قٍ حَاشِ رَبَمَ تَامِ شُنتُنيِ شَ قٍ رَ. 
\q1  
\v 22 مِلَنتٍ فبَتَمَ بَننَيَ رَ، 
\q1 كْنْ عَ مُ عَ كٌلٌن عَ تْورّ نَن تُن سْتْمَ. 
\q1  
\v 23 مِشِ نَشَن مَرَ سِ شْرْشْي قِمَ مِشِ ندٍ مَ، 
\q1 نَ هِننّ نَن سْتْمَ دَنفِقٍ مِشِ رَ 
\q1 نَشَن لُمَ وْيّن حْشُنمّ فبَنسَن قَلَ رَ مِشِيٍ بّ. 
\q1  
\v 24 مِشِ نَشَن عَ بَبَ نُن عَ نفَ مُحَمَ، 
\q1 عَ قَ عَ قَلَ «عَ مُ حَاشُ،» 
\q1 نَ بَرَ قِندِ كَسَرَتِ رَ. 
\q1  
\v 25 مِشِ نَشَن مِلَمَ هَرِفٍ مَ، 
\q1 نَ قِندِ مَ فٍرٍ سٌي نَن نَ، 
\q1 كْنْ نَشَن بَرَ عَ يّتّ تَشُ عَلَتَلَ رَ، 
\q1 نَ حَن بَرَ هّيرِ فبٍفبٍ سْتْ. 
\q1  
\v 26 مِشِ نَشَن لَشِ عَ يّتّ كَن شَشِلِ رَ، 
\q1 نَ بَرَ قِندِ شَشِلِتَرٍ رَ، 
\q1 كْنْ مِشِ نَشَن حّرّ مَ شَشِلِ قَنيِ رَ، 
\q1 نَ كَنيِ كِسِمَ نّ. 
\q1  
\v 27 مِشِ نَشَن سٍتَرٍ كِمَ، نَ مُ تْورْ مَ، 
\q1 كْنْ نَشَن سٍتَرٍ كُمَمَ، نَ دَنكّ نَن سْتْمَ. 
\q1  
\v 28 مِشِ حَاشِيٍ شُن نَ رَكٍلِ، حَمَ عَ نْشُنمَ نّ، 
\q1 كْنْ مِشِ حَاشِيٍ نَ هَلَكِ، تِنشِنتْييٍ تَن شُن نَكٍلِمَ نّ. 
\c 29  
\s1 مَرَكْرْ سِ تِدٍ 
\q1  
\v 1 مِشِ نَشَن تٌندِ مَ مَرَكْرْ سِ رَ، 
\q1 نَ كَنيِ حَشَنكَتَمَ نّ كٍرٍنيِ رَ. 
\q1  
\v 2 تِنشِنتْي نَ سّنبّ سْتْ، حَمَ سّيوَ مَ نّ، 
\q1 كْنْ تِنشِنتَرٍ نَ قِندِ مَنفّ رَ، حَمَ تْورْ مَ نّ. 
\b  
\q1  
\v 3 لْننِ رَقَن مِشِ نَشَن مَ، نَ عَ بَبَ رَ سّيوَ مَ نّ، 
\q1 كْنْ نَشَن بِرَ مَ لَنفٌيحَ قْشْ رَ، نَ فَنمَ نّ عَ هَرِفٍ رَ. 
\b  
\q1  
\v 4 مَنفّ بْشِ رَ سَبَتِمَ تِنشِنيِ نَن نَ، 
\q1 كْنْ مَنفّ نَشَن كْبِرِ قٍنمَ عَ يّتّ بّ، 
\q1 نَ بْشِ شُن نَكَنَمَ نّ. 
\b  
\q1  
\v 5 مِشِ نَشَن عَ بٌورٍ تَمِشِيَمَ، 
\q1 عَ نَ يّلّ عِتَلَقٍ عَ بٌورٍ نَن بّ. 
\q1  
\v 6 مِشِ حَاشِ شَ يُنُبِ قِندِشِ فَنتَنيِ نَن نَ عَ بّ، 
\q1 كْنْ تِنشِنتْي شُن نَكٍلِمَ نّ سّيوّ كُي. 
\b  
\q1  
\v 7 تِنشِنتْي كَتَمَ نّ تِنشِنيِ شَ رَبَ سٍتَرٍيٍ بّ، 
\q1 كْنْ مِشِ حَاشِ مُ مّينِمَ سٍتَرٍيٍ مَ قٍقٍ مَ. 
\b  
\q1  
\v 8 مِشِ مَيٍلٍيٍ عَ نِيَمَ نّ تَاكَيٍ شَ شْنْ، 
\q1 كْنْ شَشِلِمَيٍ تَن حَمَ بْحّ رَفٌرٌ مَ نّ. 
\q1  
\v 9 شَ كِيتِ لُ شَشِلِمَ نُن شَشِلِتَرٍ تَفِ، 
\q1 نَ شَشِلِتَرٍ سْنشْي رَتٍمَ نّ تُن، 
\q1 بْحّسَ شَ كَنَ. 
\q1  
\v 10 قَشّتِيٍ تِنشِنتْي شْنمَ، 
\q1 كْنْ مِشِ تِنشِنشِيٍ عٍ بٌورٍ مَكَنتَمَ نّ. 
\q1  
\v 11 شَشِلِتَرٍ بْحّ شَ تٍ مَقُرَ، 
\q1 كْنْ شَشِلِمَ تَن عَ يّتّ سُشُمَ نّ. 
\b  
\q1  
\v 12 مَنفّ نَ بِرَ وُلٍ قْشْ رَ، عَ شَ مِشِ بِرِن قِندِ مَ نّ مِشِ حَاشِيٍ رَ. 
\q1  
\v 13 قٍ كٍرٍن نَ سٍتَرٍ نُن مِشِ كٌبِ تَفِ؛ عَلَتَلَ نَن عٍ بِرِن دَا. 
\q1  
\v 14 مَنفّ نَشَن سٍتَرٍ مَكِيتِمَ نْندِ رَ، 
\q1 نَ شَ كِبَنيِ مَبَنبَنمَ نّ عَبَدَن. 
\b  
\q1  
\v 15 دِ شُرُقٍ لُشُسِنيِ رَ، نَ عَ نِيَمَ نّ عَ شَشِلِ سْتْ، 
\q1 كْنْ دِ لُقٍ عَ يّتّ يِ رَ، نَ قِندِ مَ يَافِ نَن نَ عَ نفَ بّ. 
\b  
\q1  
\v 16 مِشِ حَاشِيٍ نَ سّنبّ سْتْ، يُنُبِيٍ فبٌمَ نّ، 
\q1 كْنْ تِنشِنتْييٍ قَمَ نّ عٍ شُننَفٌرٍ تٌدٍ. 
\b  
\q1  
\v 17 عِ شَ دِ مَتِنشِن عَلَكٌ عِ شَ لُ بْحّسَ كُي، عَ حّرّ كِ شَ عِ رَ سّيوَ. 
\b  
\q1  
\v 18 شَ حَمَ مُ عَلَ شَ قٍ تٌمَ، 
\q1 عٍ بِرَ مَ عٍ يّتّ وَشْنقٍ نَن تُن قْشْ رَ. 
\q1 سّيوّ نَ مِشِ بّ نَشَن عَلَ شَ سّرِيّ رَبَتُمَ. 
\q1  
\v 19 وْيّنيِ شَ مُ كٌنيِ مَتِنشِنمَ. 
\q1 هَلِ عَ نَ مّ، عَ مُ عَ رَبَتُمَ. 
\b  
\q1  
\v 20 شَشِلِتَرٍ قِسَ مِشِ بّ، 
\q1 نَشَن حّنفِ مُ سَمَ عَ شَ وْيّنيِ شْن مَ. 
\b  
\q1  
\v 21 كٌنيِ نَشَن كَنيِ بَرَ عَ كَنَ كَبِ عَ دِ مّدِ تّمُي، 
\q1 نَ قِندِ مَ تْورّ نَن نَ عَ كَنيِ بّ. 
\q1  
\v 22 بْحّتٍ نَن فٍرٍ رَ مِنِمَ، عَ قِندِ يُنُبِيٍ رَ. 
\q1  
\v 23 يّتّ عِفبٌحَ مِشِ رَيَافِمَ نّ، 
\q1 كْنْ يّتّ مَفٌرٍ مِشِ شُن نَكٍلِمَ نّ. 
\b  
\q1  
\v 24 مِشِ نَشَن كَقُمَ مُحّتِ مَ، نَ بَرَ عَ يّتّ فَن. 
\q1 عَ عَ كٌلٌن دَنكّ نَ سٍيدٍ تِنشِنتَرٍ بّ، 
\q1 كْنْ عَ نْندِ نْشُنمَ نّ. 
\q1  
\v 25 فَاشُقٍ مِشِ يَ رَ، نَ قِندِ مَ فَنتَنيِ نَن نَ، 
\q1 كْنْ نَشَن عَ يّتّ تَشُمَ عَلَتَلَ رَ، عَ كِسِمَ نّ. 
\q1  
\v 26 مِشِ فبٍفبٍ مَنفّ شَ هِننّ قٍنمَ، 
\q1 كْنْ عَلَتَلَ نَن مِشِ بِرِن مَكِيتِمَ نْندِ رَ. 
\q1  
\v 27 مِشِ حَاشِيٍ رَحَاشُ تِنشِنتْييٍ مَ، 
\q1 تِنشِنتْييٍ رَحَاشُ مِشِ حَاشِيٍ مَ. 
\c 30  
\s1 عَفُرُ شَ مَسٍنيِ 
\d  
\v 1 يَكٍ شَ دِ عَفُرُ شَ مَسٍنيِ نَن يَ عَ نَشَن مَسٍنشِ عِتِيّلِ نُن عُكَلَ بّ؛ 
\q1  
\v 2 ﭑ مَ لْننِ مُ فبٌ عَلْ بٌورٍيٍ، 
\q1 ﭑ مُ فّشِ قَهَامُي فبٍفبٍ سْتْدٍ. 
\q1  
\v 3 ﭑ مُ قِندِشِ لْننِلَ رَ، 
\q1 ﭑ مُ لْننِ سْتْشِ عَلَ شَ سّنِيّنتْييٍ شَ قٍ رَ. 
\q1  
\v 4 ندٍ تٍشِ كٌورٍ، عَ مَن نَشَ فٌرٌ؟ 
\q1 ندٍ قٌيٍ مَلَنشِ عَ بّلّشّيٍ كُي؟ 
\q1 ندٍ يٍ رَفَتَشِ عَ شَ سٌسٍيٍ كُي؟ 
\q1 ندٍ دُنِحَ نَانِنيِيٍ سَشِ؟ 
\q1 عَ شِلِ دِ؟ عَ شَ دِ شِلِ دِ؟ 
\q1 عِ نَ كٌلٌن؟ 
\b  
\q1  
\v 5 عَلَ شَ مَسٍنيِ بِرِن قِندِشِ نْندِ نَن نَ، 
\q1 عَ قِندِ كَنتَرِ رَ مِشِ بّ نَشَن لَمَ عَ رَ. 
\q1  
\v 6 عِ نَشَ سٍ سَ نَ مَسٍنيِ شُن مَ، 
\q1 عَلَكٌ عَلَ نَشَ عِ سُشُ، عَ قَ عِ شَ وُلٍ تٌ. 
\b  
\q1  
\v 7 ﭑ وَ مَ قٍ قِرِن مَشْرِنقٍ عِ مَ بٍينُن ﭑ شَ قَشَ. 
\q1 عِ نَشَ تٌندِ. 
\q1  
\v 8 مَدَشُحَ نُن وُلٍ مَكُيَ ﭑ نَ. 
\q1 عِ نَشَ ﭑ قِندِ سٍتَرٍ رَ، عِ نَشَ ﭑ قِندِ بَننَ رَ. 
\q1 بَلٌي فبَنسَن قِ ﭑ مَ، نَشَن ﭑ وَ سَمَ. 
\q1  
\v 9 شَ ﭑ سَ سٍ فبٍفبٍ سْتْ، 
\q1 ﭑ فَاشُمَ نّ ﭑ نَشَ نّيمُ عِ مَ، 
\q1 ﭑ قَ عَ قَلَ، «ندٍ نَ عَلَتَلَ رَ؟» 
\q1 شَ ﭑ سَ لُ سٍتَرٍحَ قَن كُي، 
\q1 ﭑ فَاشُمَ نّ ﭑ نَشَ مُحّ تِ، 
\q1 ﭑ قَ عِ تَن ﭑ مَرِفِ عَلَ شِلِ كَنَ. 
\b  
\q1  
\v 10 عِ نَشَ كٌنيِ شِلِ كَنَ عَ كَنيِ بّ، 
\q1 عَلَكٌ عَ نَشَ عِ دَنكَ، نَ هَاكّ لُ عِ مَ. 
\q1  
\v 11 مِشِ ندٍيٍ عٍ بَبَ دَنكَمَ، عٍ عٍ نفَ قِنسِرِوَلِ. 
\q1  
\v 12 مِشِ ندٍيٍ عٍ يّتّ قِندِ مَ سّنِيّنتْييٍ رَ، 
\q1 كْنْ عٍ مُ نْمَ سّنِيّنتَرٍحَ بَدٍ عٍ مَ. 
\q1  
\v 13 مِشِ ندٍيٍ عٍ يّتّ عِتٍمَ، 
\q1 عٍ عَ مَحْشُن عٍ دَنفِ مِشِ بِرِن نَ. 
\q1  
\v 14 مِشِ ندٍيٍ نَ نَشٍيٍ لُشِ عَلْ سُبٍ شَاحّيٍ 
\q1 نَشٍيٍ وَ مَ سٍتَرٍيٍ قَشَقٍ، عٍ شَ عٍ بَ دُنِحَ. 
\b  
\q1  
\v 15 دِ قِرِن نَ نِسِ بّ نَشٍيٍ عَ قَلَمَ، 
\q1 «ﭑ كِ، ﭑ كِ.» 
\b  
\q1 سٍ سَشَن نَ نَ، شَ نَ مُ عَ رَ، سٍ نَانِ، 
\q1 نَشٍيٍ مُ وَ سَمَ، نَشٍيٍ مُ عَ قَلَمَ، «نَ لَن.» 
\q1  
\v 16 عٍ تَن نَن يَ؛ عَلِفِيَمَ، فِنّ دِبَرِتَرٍ، 
\q1 فبٍنفبٍرٍنيِ، نُن تّ. 
\q1 نٍيٍ سٍسٍ مُ عَ قَلَمَ، «نَ لَن.» 
\b  
\q1  
\v 17 مِشِ نَشَن يٌمَ عَ بَبَ مَ، 
\q1 نَشَن مُ عَ نفَ شُي رَبَتُمَ، 
\q1 شَاشَيٍ كٍلِمَ نّ فُلُنبَ يِرٍ عٍ عَ يَيٍ سَكُن، 
\q1 سّفّ يْرّيٍ قَ عَ دٌندٍ. 
\b  
\q1  
\v 18 سٍ سَشَن نَ نَ، شَ نَ مُ عَ رَ، سٍ نَانِ، 
\q1 ﭑ مُ نَشٍيٍ قَهَامُمَ عٍ شَ تِلِنيِ شَ قٍ رَ. 
\q1  
\v 19 عٍ تَن نَن يَ؛ سّفّ شَ كِرَ كٌورٍ مَ، 
\q1 بْشِمَسٍ شَ كِرَ قَنيٍ قَرِ، 
\q1 كُنكُي شَ كِرَ بَا مَ، 
\q1 شّمّ شَ كِرَ فِنّدِ مّدِ شْنيِ. 
\q1  
\v 20 فِنّ يّنّلَ شَ وَلِ نَن يَ؛ 
\q1 عَ نَ فّ عَ دّفٍدٍ، عَ عَ دّ رَشَ، عَ قَ عَ قَلَ، 
\q1 «ﭑ مُ قٍ حَاشِ يٌ رَبَشِ.» 
\b  
\q1  
\v 21 سٍ سَشَن نَ نَ، شَ نَ مُ عَ رَ، سٍ نَانِ، 
\q1 نَشٍيٍ مُ نْمَ لُدٍ دُنِحَ قَرِ. 
\q1  
\v 22 عٍ تَن نَن يَ؛ كٌنيِ قِندِقٍ مَنفّ رَ، 
\q1 شَشِلِتَرٍ قِندِقٍ بَننَ رَ، 
\q1  
\v 23 فِنّ مَشَنُتَرٍ دْشْقٍ شّمّ تَا، 
\q1 كٌنيِ فِنّ نَشَن قِندِقٍ عَ كَنيِ كّ تٌنفٌي رَ. 
\b  
\q1  
\v 24 سُبٍ نَانِ نَ نَشٍيٍ شُرُن دُنِحَ سُبٍيٍ بِرِن بّ، 
\q1 كْنْ عٍ شَ لْننِ دَنفِ عَ بِرِن نَ. 
\q1  
\v 25 عٍ تَن نَن يَ؛ دٌندٌلِ نَشَن سّنبّ مُ فبٌ، 
\q1 كْنْ عٍ بَلٌي قٍنمَ عَ قٍن وَشَتِ. 
\q1  
\v 26 يٍرٍ مَنِيّ ندٍ نَشَن سّنبّ مُ فبٌ، 
\q1 كْنْ عَ يِلِ فٍمَ فّمّ لٌنفٌرِ يِفِيَ سْتْدٍ. 
\q1  
\v 27 مَنفّ مُ نَ كَتٌي بّ، 
\q1 كْنْ عٍ عٍ حّرّ مَ شُنلَندٍ كِ مَ. 
\q1  
\v 28 كَسَ نَشَن نْمَ تٌنفٌدٍ بّلّشّ رَ، 
\q1 كْنْ عَ تٌمَ مَنفّ شَ بَنشِ كُي. 
\b  
\q1  
\v 29 سٍ سَشَن نَ نَ، شَ نَ مُ عَ رَ، سٍ نَانِ، 
\q1 نَشٍيٍ حّرّ كِ تٌقَن. 
\q1  
\v 30 عٍ تَن نَن يَ؛ يّتّ نَشَن سّنبّ فبٌ، عَ سُو سَ سُبٍ بِرِن بّ، 
\q1  
\v 31 كٌنكٌرٍ نَشَن حّرّ مَ عَ شُن نَكٍلِشِ رَ، 
\q1 سِ كٌنتٌنيِ، نُن مَنفّ، سْورِيٍ نَ نَشَن قْشْ رَ. 
\b  
\q1  
\v 32 شَ عِ بَرَ عِ يّتّ عِفبٌ شَشِلِتَرٍحَ كُي، 
\q1 شَ عِ بَرَ وَ قٍ حَاشِ ندٍ رَبَقٍ، 
\q1 عِ شَ فبِلٍن نَ قْشْ رَ، 
\q1  
\v 33 بَرِ مَ شِحّ نَ بْنبْ، عَ بِنيَمَ نّ، 
\q1 حْي نَ دِن، وُلِ مِنِمَ نّ، 
\q1 شْنّ شُن نَ مَسَ، عَ قِندِ مَ نّ فٍرٍ رَ. 
\c 31  
\s1 مَنفّ لٍمُوٍلِ شَ مَرَ سِ 
\d  
\v 1 مَنفّ لٍمُوٍلِ شَ مَسٍنيِ نَن يَ عَ نفَ نَشَن قِ عَ مَ مَرَ سِ رَ؛ 
\q1  
\v 2 ﭑ مَ دِ، عِ تُلِ مَتِ ﭑ نَ، 
\q1 ﭑ مَ دِ قَنيِ، ﭑ نَشَن بَرِشِ، 
\q1 ﭑ نَشَن سْتْ عَلَ سَابُي رَ. 
\q1  
\v 3 عِ نَشَ عِ سّنبّ قِ فِنّ حَاشِيٍ مَ، 
\q1 نَشٍيٍ قَتَ مَنفّيٍ رَلْيدٍ. 
\q1 عِ نَشَ بِرَ نَ فِنّ مْولِ قْشْ رَ. 
\b  
\q1  
\v 4 مَنفّ لٍمُوٍلِ، عَ مُ لَنمَ مَنفّيٍ شَ وّنِ مِن. 
\q1 بٍيرٍ شْلِ مُ لَنمَ عَ شَ مَنفّ سُشُ، 
\q1  
\v 5 شَ نَ مُ عَ رَ عٍ نّيمُمَ نّ عٍ يّتّ شَ سّرِيّ مَ، 
\q1 عٍ قَ تْورْ مِشِ يَنقَ. 
\q1  
\v 6 نَ مِنسٍ مْولِ شَ سٌ مِشِيٍ نَن يِ، 
\q1 نَشٍيٍ نَ سَيَ كِرَ شْن مَ، 
\q1 عَلَكٌ عٍ شَ نّيمُ عٍ شَ قٍ شْرْشْي بِرِن مَ. 
\q1  
\v 7 نَشَن وّنِ مِنشِ عَ نّيمُمَ نّ عَ شَ سٍتَرٍحَ مَ، 
\q1 عَ مُ رَتُمَ عَ شَ تْورّ مَ سْنْن. 
\q1  
\v 8 عِ شَ دّتَرٍ شُنمَقَلَ، 
\q1 عِ شَ مِسِكِينّ مَلِ. 
\q1  
\v 9 عِ شُي رَ مِنِ، كِيتِ سَ نْندِ رَ. 
\q1 عِ شَ تْورْ مِشِ نُن سٍتَرٍ شُنمَقَلَ. 
\s1 فِنّ قَنيِ 
\q1  
\v 10 ندٍ نْمَ فِنّ قَنيِ سْتْدٍ؟ 
\q1 عَ تِدٍ فبٌ دِيَمَن بّ. 
\q1  
\v 11 عَ شَ مْرِ لَشِ عَ رَ، 
\q1 عَ قِندِشِ هَرِفٍ قَنيِ نَن نَ عَ بّ تّمُي بِرِن. 
\q1  
\v 12 عَ قٍ قَنيِ رَبَمَ عَ شَ مْرِ بّ، 
\q1 عَ مُ قٍ حَاشِ يٌ رَبَمَ عَ رَ عَ شَ دُنِحّءِفِرِ كُي. 
\q1  
\v 13 عَ يّشّي شَبٍ نُن فّسّ قُتٍ قٍنمَ، 
\q1 عَ نٍيٍ رَقَلَمَ سٌسٍيٍ رَ. 
\q1 نَ وَلِ رَقَن عَ مَ. 
\q1  
\v 14 عَ لُمَ عَلْ يُلّ شَ كُنكُي، 
\q1 عَ سَ بَلٌي قٍنمَ يِرٍ مَكُيٍ عَ قَ عَ رَ. 
\q1  
\v 15 عَ كُرُنمَ نّ عَلَكٌ عَ شَ كُرِ سٌ عَ شَ دٍنبَيَ بّ، 
\q1 عَ مَن وَلِ سٌ عَ شَ وَلِكّ فِنّيٍ يِ رَ. 
\q1  
\v 16 عَ بْشِ مَتٌمَ نّ، عَ قَ نَ سَرَ. 
\q1 عَ فٍينِ نَشَن سْتْمَ عَ نَ سَرَ مَ سَنسِ نَن نَ، عَ عَ سِ. 
\q1  
\v 17 عَ تُننَبّشِ، عَ وَلِمَ سّنبّ رَ. 
\q1  
\v 18 عَ عَ كٌلٌن عَ شَ وَلِ سْونّيَمَ نّ. 
\q1 عَ لَنثُي رَدّشّمَ نّ، عَ وَلِ كْي قَن نَ. 
\q1  
\v 19 عَ يّشّي شَبٍ قِندِ مَ نّ فّسّ رَ، 
\q1 عَ فّسّ قِندِ مَ سٌسٍ رَ. 
\b  
\q1  
\v 20 عَ سٍتَرٍ كِمَ، عَ مِسِكِينّ مَلِمَ. 
\q1  
\v 21 عَ مُ فَاشُمَ حّمّ يَ رَ، 
\q1 بَرِ مَ عَ شِنبٍلِ دٌنمَ قَنيِيٍ يَءِلَنشِ عَ شَ دٍنبَيَ بّ. 
\q1  
\v 22 عَ سَدٍ دُفِ يَءِلَنمَ، 
\q1 عَ دُفِ تٌقَنيِ دّفّمَ عَ يّتّ بّ. 
\q1  
\v 23 تَا كُنتِفِ نَن عَ شَ مْرِ رَ، 
\q1 عَ دْشْشِ قٌرِيٍ يَ مَ. 
\q1  
\v 24 عَ سٌسٍيٍ دّفّمَ، عَ عٍ مَتِ. 
\q1 عَ بّلّتِيٍ قَن يَءِلَنمَ، 
\q1 يُلّيٍ نٍيٍ وَقُمَ عَ مَ. 
\b  
\q1  
\v 25 عَ سّنبّ فبٌ، مِشِيٍ عَ بِنيَمَ. 
\q1 عَ مُ فَاشُمَ قٍقٍ مَ. 
\q1  
\v 26 عَ لْننِ مَسٍنمَ مِشِيٍ بّ، 
\q1 عَ مَن عٍ شَرَن عَ قَنيِ رَ. 
\q1  
\v 27 عَ عَ حّنفِ سَمَ عَ شَ دٍنبَيَ شْن مَ، 
\q1 عَ مُ وَلِتَرٍحَ كٌلٌن. 
\q1  
\v 28 عَ شَ دِيٍ عَ مَتْشْمَ، 
\q1 عَ شَ مْرِ عَ تَنتُمَ يِ وْيّنيِ رَ؛ 
\q1  
\v 29 «فِنّ قَنيِيٍ نَ نَ دٍ، 
\q1 كْنْ عِ مَنِيّ مُ نَ عٍ يَ مَ.» 
\q1  
\v 30 قَتٍ شَ تٌقَنيِ مِشِ مَدَشُمَ نّ، عَ مُ بُمَ. 
\q1 تَنتُي نَ فِنّ نَن بّ نَشَن فَاشُمَ عَلَتَلَ يَ رَ. 
\q1  
\v 31 وٌ شَ نَ فِنّ شَ وَلِ قَنيِ سَرٍ قِ عَ مَ، 
\q1 وٌ شَ نَ فِنّ مْولِ مَتْشْ تَا كُي.