\c 38
\s1 Enfermedad del rey Ezequías
\p 
\v 1 \w En|strong="H3588"\w* \w aquellos|strong="H1992"\w* \w días|strong="H3117"\w* Ezequías cayó \w enfermo|strong="H2470"\w* \w de|strong="H3588"\w* \w muerte|strong="H4191"\w*. \add El\add* \w profeta|strong="H5030"\w* \w Isaías|strong="H3470"\w*, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Amoz, \w fue|strong="H3808"\w* \w a|strong="H3068"\w* \w él|strong="H3588"\w* \w y|strong="H3588"\w* le dijo: \nd \w Yavé|strong="H3068"\w*\nd* dice: \wj \w Ordena|strong="H6680"\w* tu \w casa|strong="H1004"\w*, \w porque|strong="H3588"\w* \w morirás|strong="H4191"\w* \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w vivirás|strong="H2421"\w*.\wj*
