\mt1 Esdras  
\c 1  
\s1 Regreso del cautiverio  
\p
\v 1 \w El|strong="H3605"\w* \w año|strong="H8141"\w* primero \w de|strong="H1697"\w* \w Ciro|strong="H3566"\w*, \w rey|strong="H4428"\w* \w de|strong="H1697"\w* \w Persia|strong="H6539"\w*, para \w que|strong="H1571"\w* se cumpliera \w la|strong="H1571"\w* \w Palabra|strong="H1697"\w* \w de|strong="H1697"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w por|strong="H1697"\w* \w boca|strong="H6310"\w* \w de|strong="H1697"\w* \w Jeremías|strong="H3414"\w*, \nd \+w Yavé|strong="H3068"\+w*\nd* \w despertó|strong="H5782"\w* \w el|strong="H3605"\w* \w espíritu|strong="H7307"\w* \w de|strong="H1697"\w* \w Ciro|strong="H3566"\w*, \w rey|strong="H4428"\w* \w de|strong="H1697"\w* \w Persia|strong="H6539"\w*, para \w que|strong="H1571"\w* se proclamara en \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w reino|strong="H4438"\w* \w por|strong="H1697"\w* \w pregón|strong="H6963"\w* \w y|strong="H1571"\w* \w por|strong="H1697"\w* escrito:   
\p
\v 2 \w Ciro|strong="H3566"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Persia|strong="H6539"\w*, dice: \w Todos|strong="H3605"\w* \w los|strong="H5921"\w* \w reinos|strong="H4467"\w* \w de|strong="H5921"\w* \w la|strong="H1931"\w* tierra \w me|strong="H5921"\w* fueron \w dados|strong="H5414"\w* \w por|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*, ʼElohim\nd* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w cielos|strong="H8064"\w*. \w Él|strong="H1931"\w* \w mismo|strong="H1931"\w* \w me|strong="H5921"\w* encomendó \w que|strong="H1931"\w* \w le|strong="H1931"\w* construya \w Casa|strong="H1004"\w* \w en|strong="H5921"\w* Jerusalén.  
\v 3 \w El|strong="H1931"\w* \w que|strong="H4310"\w* \w de|strong="H5973"\w* \w entre|strong="H5973"\w* ustedes pertenezca \w a|strong="H3068"\w* \w su|strong="H1931"\w* \w pueblo|strong="H5971"\w*, \w sea|strong="H1961"\w* \w su|strong="H1931"\w* \nd ʼElohim\nd* \w con|strong="H5973"\w* \w él|strong="H1931"\w*. \w Suba|strong="H5927"\w* \w a|strong="H3068"\w* Jerusalén y reconstruya \w la|strong="H1931"\w* \w Casa|strong="H1004"\w* \w de|strong="H5973"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w el|strong="H1931"\w* \nd ʼElohim\nd* \w de|strong="H5973"\w* \w Israel|strong="H3478"\w*. \w Él|strong="H1931"\w* \w es|strong="H1931"\w* \w el|strong="H1931"\w* \nd ʼElohim\nd* \w que|strong="H4310"\w* \w está|strong="H1931"\w* \w en|strong="H5973"\w* Jerusalén.  
\v 4 \w Y|strong="H3068"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H1931"\w* \w que|strong="H1931"\w* \w quedó|strong="H7604"\w*, \w en|strong="H5973"\w* \w cualquier|strong="H3605"\w* \w lugar|strong="H4725"\w* \w donde|strong="H8033"\w* viva, \w que|strong="H1931"\w* \w lo|strong="H1931"\w* ayuden \w sus|strong="H1931"\w* vecinos \w con|strong="H5973"\w* \w plata|strong="H3701"\w*, \w oro|strong="H2091"\w*, bienes y ganado, \w junto|strong="H5973"\w* \w con|strong="H5973"\w* una ofrenda \w voluntaria|strong="H5071"\w* \w para|strong="H5973"\w* \w la|strong="H1931"\w* \w Casa|strong="H1004"\w* \w del|strong="H5973"\w* \nd ʼElohim\nd* \w que|strong="H1931"\w* \w está|strong="H1931"\w* \w en|strong="H5973"\w* Jerusalén.   
\p
\v 5 Entonces se \w levantaron|strong="H6965"\w* \w los|strong="H3605"\w* \w jefes|strong="H7218"\w* de \w familia|strong="H1004"\w* de \w Judá|strong="H3063"\w* y \w Benjamín|strong="H1144"\w*, \w los|strong="H3605"\w* \w sacerdotes|strong="H3548"\w* y \w los|strong="H3605"\w* \w levitas|strong="H3881"\w*, \w todos|strong="H3605"\w* \w aquellos|strong="H3605"\w* cuyo \w espíritu|strong="H7307"\w* \nd ʼElohim\nd* \w despertó|strong="H5782"\w* para \w que|strong="H3605"\w* subieran \w a|strong="H3068"\w* reconstruir \w la|strong="H3605"\w* \w Casa|strong="H1004"\w* de \nd \+w Yavé|strong="H3068"\+w*\nd* en Jerusalén.  
\v 6 \w Todos|strong="H3605"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* estaban \w alrededor|strong="H5439"\w* \w de|strong="H5921"\w* \w ellos|strong="H3027"\w* \w los|strong="H5921"\w* animaron \w con|strong="H5921"\w* objetos \w de|strong="H5921"\w* \w plata|strong="H3701"\w*, \w oro|strong="H2091"\w*, bienes, ganado \w y|strong="H5921"\w* cosas preciosas, \w además|strong="H5921"\w* \w de|strong="H5921"\w* \w lo|strong="H5921"\w* \w que|strong="H5921"\w* fue dado \w como|strong="H5921"\w* una ofrenda voluntaria.   
\p
\v 7 \w También|strong="H3318"\w* el \w rey|strong="H4428"\w* \w Ciro|strong="H3566"\w* \w sacó|strong="H3318"\w* los utensilios \w de|strong="H5414"\w* la \w Casa|strong="H1004"\w* \w de|strong="H5414"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* que \w Nabucodonosor|strong="H5019"\w* llevó \w de|strong="H5414"\w* Jerusalén y \w puso|strong="H5414"\w* \w en|strong="H3318"\w* el \w templo|strong="H1004"\w* \w de|strong="H5414"\w* sus \tl ʼelohim\tl*.  
\v 8 \w Ciro|strong="H3566"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Persia|strong="H6539"\w*, \w los|strong="H5921"\w* \w sacó|strong="H3318"\w* \w por|strong="H5921"\w* \w medio|strong="H3027"\w* \w del|strong="H5921"\w* \w tesorero|strong="H1489"\w* \w Mitrídates|strong="H4990"\w*, quien \w los|strong="H5921"\w* entregó \w en|strong="H5921"\w* \w mano|strong="H3027"\w* \w de|strong="H5921"\w* Sesbasar, \w el|strong="H5921"\w* \w jefe|strong="H5387"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*.   
\p
\v 9 Esta fue su \w cuenta|strong="H4557"\w*: 30 tazones de \w oro|strong="H2091"\w*, 1.000 tazones de \w plata|strong="H3701"\w*, 29 \w cuchillos|strong="H4252"\w*,  
\v 10 30 \w tazas|strong="H3713"\w* de \w oro|strong="H2091"\w*, 410 \w tazas|strong="H3713"\w* de \w plata|strong="H3701"\w* de otra clase y otros 1.000 utensilios.   
\p
\v 11 \w Todos|strong="H3605"\w* \w los|strong="H3605"\w* utensilios \w de|strong="H5973"\w* \w oro|strong="H2091"\w* y \w de|strong="H5973"\w* \w plata|strong="H3701"\w* \w fueron|strong="H5927"\w* 5.400. Sesbasar \w lo|strong="H3605"\w* transportó \w todo|strong="H3605"\w* cuando \w los|strong="H3605"\w* \w del|strong="H5973"\w* \w cautiverio|strong="H1473"\w* \w de|strong="H5973"\w* Babilonia regresaron \w a|strong="H3068"\w* Jerusalén.   
\c 2  
\s1 El regreso de los deportados  
\p
\v 1 Estas son las personas \w de|strong="H1121"\w* la \w provincia|strong="H4082"\w* \w que|strong="H1121"\w* \w subieron|strong="H5927"\w* \w de|strong="H1121"\w* la cautividad, \w de|strong="H1121"\w* \w los|strong="H1121"\w* deportados \w que|strong="H1121"\w* \w Nabucodonosor|strong="H5020"\w*, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* Babilonia, llevó \w a|strong="H3068"\w* Babilonia. Regresaron \w a|strong="H3068"\w* Jerusalén y \w Judá|strong="H3063"\w*, cada uno \w a|strong="H3068"\w* su \w ciudad|strong="H5892"\w*.  
\v 2 \w Los|strong="H5973"\w* \w que|strong="H5971"\w* regresaron \w con|strong="H5973"\w* \w Zorobabel|strong="H2216"\w* fueron: \w Jesuá|strong="H3442"\w*, \w Nehemías|strong="H5166"\w*, \w Seraías|strong="H8304"\w*, \w Reelaías|strong="H7480"\w*, Mardoqueo, \w Bilsán|strong="H1114"\w*, \w Mispar|strong="H4558"\w*, Bigvai, \w Rehum|strong="H7348"\w* y \w Baana|strong="H1196"\w*.  
\p \w El|strong="H5973"\w* \w número|strong="H4557"\w* \w de|strong="H5973"\w* las personas \w del|strong="H5973"\w* \w pueblo|strong="H5971"\w* \w de|strong="H5973"\w* \w Israel|strong="H3478"\w* era \w de|strong="H5973"\w* \w los|strong="H5973"\w* hijos \w de|strong="H5973"\w*:  
\v 3 Paros, 2.172;  
\v 4 Sefatías, 372;  
\v 5 Ara, 775;  
\v 6 Pajat-moab, \w Jesuá|strong="H3442"\w* y \w Joab|strong="H3097"\w*, 2.812;  
\v 7 \w Elam|strong="H5867"\w*, 1.254;  
\v 8 Zatu, 945;  
\v 9 Zacai, 760;  
\v 10 \w Bani|strong="H1137"\w*, 642;  
\v 11 Bebai, 623;  
\v 12 \w Azgad|strong="H5803"\w*, 1.222;  
\v 13 Adonicam, 666;  
\v 14 Bigvai, 2.056;  
\v 15 \w Adín|strong="H5720"\w*, 454;  
\v 16 Ater y \w de|strong="H1121"\w* Ezequías, 98;  
\v 17 Bezai, 323;  
\v 18 Jora, 112;  
\v 19 \w Hasum|strong="H2828"\w*, 223;  
\v 20 Gibar, 95;  
\v 21 Belén, 123;  
\v 22 Netofa, 56;  
\v 23 Anatot, 128;  
\v 24 Azmavet, 42;  
\v 25 Quiriat-jearim, Cafira y Beerot, 743;  
\v 26 \w Ramá|strong="H7414"\w* y \w de|strong="H1121"\w* Geba, 621;  
\v 27 los \w hombres|strong="H8147"\w* de Micmas, 122;  
\v 28 los hombres de Bet-ʼEl y de \w Hai|strong="H5857"\w*, 223;  
\v 29 \w Nebo|strong="H5015"\w*, 52;  
\v 30 Magbis, 156;  
\v 31 \w Elam|strong="H5867"\w*, 1.254;  
\v 32 \w Harim|strong="H2766"\w*, 320;  
\v 33 \w Lod|strong="H3850"\w*, \w Hadid|strong="H2307"\w* y Ono, 725;  
\v 34 \w Jericó|strong="H3405"\w*, 345;  
\v 35 y \w de|strong="H1121"\w* Senaa, 3.630.   
\p
\v 36 \w Los|strong="H1121"\w* \w sacerdotes|strong="H3548"\w* fueron \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w*: \w Jedaías|strong="H3048"\w*, la \w familia|strong="H1004"\w* \w de|strong="H1121"\w* \w Jesuá|strong="H3442"\w*, 973;  
\v 37 Imer, 1.052;  
\v 38 Pasur, 1.246;  
\v 39 \w Harim|strong="H2766"\w*, 1.017.   
\p
\v 40 \w Los|strong="H1121"\w* \w levitas|strong="H3881"\w* fueron \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w*: \w Jesuá|strong="H3442"\w*, \w Cadmiel|strong="H6934"\w* y Hodovías, 74.   
\p
\v 41 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w cantores|strong="H7891"\w* \w de|strong="H1121"\w* Asaf, 128.   
\p
\v 42 \w Los|strong="H1121"\w* \w porteros|strong="H7778"\w* fueron \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w*: Salum, Ater, \w Talmón|strong="H2929"\w*, Acub, Hatita y Sobai; \w el|strong="H3605"\w* total, 139.   
\p
\v 43 \w Los|strong="H1121"\w* servidores del Templo fueron \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w*: Ziha, Hasufa, Tabaot,  
\v 44 Queros, Siaha, Padón,  
\v 45 Lebana, Hagaba, Acub,  
\v 46 Hagab, Samlai, \w Hanán|strong="H2605"\w*,  
\v 47 Gidel, Gahar, Reaía,  
\v 48 \w Rezín|strong="H7526"\w*, Necoda, Gazam,  
\v 49 Uza, Paseah, Besai,  
\v 50 Asena, \w de|strong="H1121"\w* \w los|strong="H1121"\w* Meunim, Nefusim,  
\v 51 Bacbuc, Hacufa, Harhur,  
\v 52 Bazlut, Mehída, Harsa,  
\v 53 Barcos, \w Sísara|strong="H5516"\w*, Tema,  
\v 54 Nezía y Hatifa.   
\p
\v 55 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* esclavos \w de|strong="H1121"\w* \w Salomón|strong="H8010"\w* fueron \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w*: Sotai, Soferet, Peruda,  
\v 56 Jaala, Darcón, Gidel,  
\v 57 Sefatías, Hatil, Poqueret-hazebaim y Ami.  
\v 58 \w Todos|strong="H3605"\w* \w los|strong="H1121"\w* servidores del Templo y \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* esclavos \w de|strong="H1121"\w* \w Salomón|strong="H8010"\w* fueron 392.   
\p
\v 59 \w Éstos|strong="H1992"\w* \w son|strong="H3808"\w* \w los|strong="H1992"\w* \w que|strong="H3808"\w* \w subieron|strong="H5927"\w* de Tel-mela, \w Tel-harsa|strong="H8521"\w*, Querub, Addán \w e|strong="H3068"\w* Imer, \w aunque|strong="H3808"\w* \w ellos|strong="H1992"\w* \w no|strong="H3808"\w* \w pudieron|strong="H3201"\w* demostrar la \w casa|strong="H1004"\w* de \w sus|strong="H1992"\w* antepasados \w ni|strong="H3808"\w* \w su|strong="H1992"\w* \w linaje|strong="H2233"\w*, \w si|strong="H3808"\w* \w eran|strong="H3808"\w* de \w Israel|strong="H3478"\w*:  
\v 60 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Delaía, \w Tobías|strong="H2900"\w*, y Necoda fueron 652.   
\p
\v 61 \w De|strong="H5921"\w* \w los|strong="H1121"\w* \w sacerdotes|strong="H3548"\w* fueron \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* Habaía, \w Cos|strong="H6976"\w*, \w y|strong="H5921"\w* Barzilai, quien \w tomó|strong="H3947"\w* una esposa \w de|strong="H5921"\w* \w entre|strong="H5921"\w* \w las|strong="H5921"\w* \w hijas|strong="H1323"\w* \w de|strong="H5921"\w* Barzilai \w galaadita|strong="H1569"\w* \w y|strong="H5921"\w* fue \w llamado|strong="H8034"\w* \w con|strong="H5921"\w* \w el|strong="H5921"\w* \w nombre|strong="H8034"\w* \w de|strong="H5921"\w* \w ellas|strong="H5921"\w*.  
\v 62 Éstos \w buscaron|strong="H1245"\w* su registro \w entre|strong="H3808"\w* los antepasados, pero \w no|strong="H3808"\w* pudieron ser hallados, \w por|strong="H4480"\w* \w lo|strong="H3808"\w* cual fueron declarados impuros y excluidos \w del|strong="H4480"\w* \w sacerdocio|strong="H3550"\w*.   
\p
\v 63 El gobernador les dijo \w que|strong="H3808"\w* \w no|strong="H3808"\w* debían comer \w de|strong="H5704"\w* las cosas \w más|strong="H5704"\w* \w sagradas|strong="H6944"\w* \w hasta|strong="H5704"\w* \w que|strong="H3808"\w* \w se|strong="H3808"\w* levantara \w sacerdote|strong="H3548"\w* \w para|strong="H5704"\w* usar el Urim \w y|strong="H5704"\w* Tumim.   
\p
\v 64 \w Toda|strong="H3605"\w* \w la|strong="H3605"\w* \w congregación|strong="H6951"\w* en conjunto era de 42.360,  
\v 65 sin contar sus esclavos y esclavas, los cuales eran 7.337. Tenían 200 \w cantores|strong="H7891"\w* y cantoras.  
\v 66 Sus \w caballos|strong="H5483"\w* eran 736; sus mulas, 245;  
\v 67 sus \w camellos|strong="H1581"\w*, 435; \w asnos|strong="H2543"\w*, 6.720.   
\p
\v 68 Cuando llegaron \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w en|strong="H5921"\w* Jerusalén, algunos \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w jefes|strong="H7218"\w* \w de|strong="H5921"\w* \w familia|strong="H1004"\w* dieron ofrendas voluntarias \w para|strong="H5921"\w* reedificar \w la|strong="H5921"\w* \w Casa|strong="H1004"\w* \w de|strong="H5921"\w* \nd ʼElohim\nd* \w en|strong="H5921"\w* su mismo sitio.  
\v 69 Según sus recursos, aportaron \w para|strong="H5414"\w* la \w obra|strong="H4399"\w* 488 kilogramos \w de|strong="H2568"\w* \w oro|strong="H2091"\w*, 2.750 kilogramos \w de|strong="H2568"\w* \w plata|strong="H3701"\w* y 100 \w túnicas|strong="H3801"\w* \w sacerdotales|strong="H3548"\w*.   
\p
\v 70 \w Los|strong="H3427"\w* \w sacerdotes|strong="H3548"\w* y \w levitas|strong="H3881"\w*, parte \w del|strong="H4480"\w* \w pueblo|strong="H5971"\w*, \w cantores|strong="H7891"\w*, \w porteros|strong="H7778"\w* y servidores \w del|strong="H4480"\w* Templo vivieron \w en|strong="H4480"\w* sus \w ciudades|strong="H5892"\w*, y \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* \w en|strong="H4480"\w* sus respectivas \w ciudades|strong="H5892"\w*.   
\c 3  
\s1 Construcción del altar  
\p
\v 1 Cuando \w llegó|strong="H5060"\w* \w el|strong="H1121"\w* \w mes|strong="H2320"\w* \w séptimo|strong="H7637"\w* y \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w estaban|strong="H5971"\w* en las \w ciudades|strong="H5892"\w*, \w el|strong="H1121"\w* \w pueblo|strong="H5971"\w* \w se|strong="H5971"\w* reunió \w como|strong="H5060"\w* un solo \w hombre|strong="H1121"\w* en Jerusalén.   
\p
\v 2 Entonces \w Jesuá|strong="H3442"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Josadac, \w se|strong="H5921"\w* \w levantó|strong="H6965"\w* \w y|strong="H5921"\w* sus hermanos \w los|strong="H1121"\w* \w sacerdotes|strong="H3548"\w*, \w y|strong="H5921"\w* \w Zorobabel|strong="H2216"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Salatiel, \w con|strong="H5921"\w* sus hermanos. \w Edificaron|strong="H1129"\w* \w el|strong="H5921"\w* \w altar|strong="H4196"\w* \w del|strong="H5921"\w* \nd ʼElohim\nd* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w para|strong="H5921"\w* ofrecer \w holocaustos|strong="H5930"\w* \w sobre|strong="H5921"\w* \w él|strong="H5921"\w*, \w como|strong="H5921"\w* \w está|strong="H6965"\w* \w escrito|strong="H3789"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w Ley|strong="H8451"\w* \w de|strong="H5921"\w* \w Moisés|strong="H4872"\w*, \w el|strong="H5921"\w* varón \w de|strong="H5921"\w* \nd ʼElohim\nd*.  
\v 3 \w Aunque|strong="H3588"\w* tenían temor \w de|strong="H5921"\w* \w las|strong="H5921"\w* poblaciones \w de|strong="H5921"\w* aquellos campos, erigieron \w el|strong="H5921"\w* \w altar|strong="H4196"\w* \w sobre|strong="H5921"\w* sus \w basas|strong="H4350"\w* \w y|strong="H3588"\w* ofrecieron \w holocaustos|strong="H5930"\w* \w sobre|strong="H5921"\w* \w él|strong="H5921"\w* \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w tanto|strong="H5921"\w* \w por|strong="H5921"\w* \w la|strong="H5921"\w* \w mañana|strong="H1242"\w* \w como|strong="H3588"\w* \w al|strong="H5921"\w* llegar \w la|strong="H5921"\w* noche.   
\p
\v 4 También celebraron la \w fiesta|strong="H2282"\w* \w de|strong="H1697"\w* Las \w Cabañas|strong="H5521"\w*, como \w está|strong="H3789"\w* \w escrito|strong="H3789"\w*, \w holocaustos|strong="H5930"\w* \w cada|strong="H3117"\w* \w día|strong="H3117"\w* \w por|strong="H1697"\w* \w número|strong="H4557"\w*, según la \w ordenanza|strong="H4941"\w*.  
\v 5 Además de esto, \add ofrecieron\add* \w el|strong="H3605"\w* \w holocausto|strong="H5930"\w* \w continuo|strong="H8548"\w*, las lunas \w nuevas|strong="H2320"\w* y \w todas|strong="H3605"\w* las fiestas solemnes de \nd \+w Yavé|strong="H3068"\+w*\nd*, y \w lo|strong="H3605"\w* \w que|strong="H5071"\w* \w cada|strong="H3605"\w* uno ofrecía como ofrenda \w voluntaria|strong="H5071"\w* \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.  
\v 6 Desde el primer \w día|strong="H3117"\w* del \w mes|strong="H2320"\w* \w séptimo|strong="H7637"\w* \w comenzaron|strong="H2490"\w* \w a|strong="H3068"\w* ofrecer \w holocaustos|strong="H5930"\w* \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w aunque|strong="H3808"\w* \w no|strong="H3808"\w* estaban colocados los \w cimientos|strong="H3245"\w* del \w Templo|strong="H1964"\w* de \nd \+w Yavé|strong="H3068"\+w*\nd*.   
\p
