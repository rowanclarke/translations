\id ZEC
\h Zacarías
\toc1 Zacarías
\toc2 (Zacarías)
\toc3 Zac.
\mt1 Zacarías
\c 9
\s1 Israel aents aidaun apuji atin pachisa etsegkamu
\p 
\v 9 ¡Yaakat Jerusalégnumia aidautigmek shiig aneastajum!
\q1 ¡Shiig aneakjum kantamatajum!
\q1 ¡Amina apujum burro tsakatnum entsatkau minitjamui!
\q1 Imanchauch wajakin, pegkejam, pegkegchaun takachu,
\q1 amina yaimpak depetmitkagmaktatus minawai.
\q1 
\v 10 Efraín wegantu aidaun carroji aidaunak,
\q1 flecha akenka nagkimtai aidaujai ashí tsaiktatui,
\q1 dutikak Jerusalégnumia caballo aidaunashkam ijinattawai.
\q1 Israel nugkanmak ashí depetmaktatui,
\q1 nunik ashí tikich aents aidaush agkan batsamsatnume titatui.
\q1 Tuja niig nayants jinagbau aina imanui nagkamas,
\q1 namak Eufratesa aatus ashí nugkanum inamjatnai,
\q1 nii inabaujig nagkatkauk achatnai.
\s1 Apajuí niina aentsji aidaun yainka ataktu inantaitin
\p 
\v 11 Tuke Pujuu chichaak:
\q1 “Jerusalégkah, wi amejai numpai chichaman
\q1 umikuitag nuna betek umiakun,
\q1 yumigmat taimu yumi atsaig ashí
\q1 jinaajum chimpigjum nunak jiijan uwemtijattajime.
\q1 
\v 12 Achija yajuakam tikich nugkanum batsatutigmek
\q1 yaakat shiig peeja umikbauwa nuwi waketjattagme.
\q1 Yamaik atum waitiajum nuna nagkaesau,
\q1 pegkegnum yumigsattajime,
\q1 nuadui shiig aneasjum batsamsattajume.
\q1 
\v 13 Judá wegantu aidauk arcojai betek,
\q1 tuja Israel wegantu aidauk flechajai betek,
\q1 tuja Jerusalégnak puyagjai betek awajsattajai,
\q1 dutikan ditajai griego aents aidaunak ijinattajai”, tawai.
\q1 
\v 14 Tuke Pujuu ditan jetektajum tusa titata nunak,
\q1 dita nagki akenbaujig peemjai betek agtinai,
\q1 Apajuí kachun umpuag tsumujinia dasenum pachitkau wetinai.
\q1 
\v 15 Tuke Pujuu ashí senchigtina nunú
\q1 niina aentsji aidaunak kuitamkatnai,
\q1 dutikamu asag dita shiwaaji aidaunak depetuk
\q1 najakag ashí amukagtinai.
\q1 Aatus depetmakaju asag, shiig aneenak
\q1 altar ukatkatasa numpa tsapanum aimka jutaya
\q1 imatika aimak vinon umuinak nampejag shiig aneenak pampainiagtinai.
\b
\q1 
\v 16 Nunú tsawan jegakuig, mina aentsug aidaunak,
\q1 uwija kuitamin uwigjin ayamjina numamtuk
\q1 wi ayamjukan uwemtikjatnaitjai,
\q1 dutika ai dita nugken waketug batsamsag
\q1 kaya pegkeg winchamtin juki atsejutai najanamu winchantuwama iman agtinai.
\q1 
\v 17 ¡Yajauwajah, nuwauch aidau,
\q1 uchi datsauch aidau shiig yuwawag senchigtin
\q1 shiig aneas dakunkut juju nugkanum batsatbau!
\c 10
\p Text to get InDesign to put correct chapter number.
