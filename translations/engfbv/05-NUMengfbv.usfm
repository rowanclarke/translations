\c 31
\p 
\v 1 \w The|strong="H3068"\w* \w Lord|strong="H3068"\w* \w told|strong="H1696"\w* \w Moses|strong="H4872"\w*,
\v 2 “Punish \w the|strong="H1121"\w* \w Midianites|strong="H4084"\w* because \w of|strong="H1121"\w* what \w they|strong="H5971"\w* \w did|strong="H3478"\w* \w to|strong="H3478"\w* \w the|strong="H1121"\w* \w Israelites|strong="H3478"\w*. After \w that|strong="H5971"\w* \w you|strong="H5971"\w* \w will|strong="H5971"\w* join \w your|strong="H3478"\w* forefathers \w in|strong="H3478"\w* death.”
\p 
\v 3 \w Moses|strong="H4872"\w* \w instructed|strong="H1696"\w* \w the|strong="H5921"\w* \w people|strong="H5971"\w*, “\w Have|strong="H1961"\w* \w some|strong="H5971"\w* \w of|strong="H3068"\w* \w your|strong="H3068"\w* \w men|strong="H5971"\w* get ready \w for|strong="H5921"\w* \w battle|strong="H6635"\w*, \w so|strong="H1961"\w* \w they|strong="H3068"\w* can \w go|strong="H5971"\w* \w and|strong="H4872"\w* attack \w the|strong="H5921"\w* \w Midianites|strong="H4080"\w* \w and|strong="H4872"\w* carry \w out|strong="H5414"\w* \w the|strong="H5921"\w* \w Lord|strong="H3068"\w*'s punishment \w on|strong="H5921"\w* \w them|strong="H5414"\w*.
