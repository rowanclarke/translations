\id 3JN 3jn - Quechua Huallaga Huánuco Bible -Peru 2010 (DBL -2013) 
\h 3 JUAN 
\toc1 3 Juan 
\toc2 3 Juan 
\toc3 3Juan 
\mt1 3 Juan 
\ili ¿Llapan willacojcunatachu pachächishun? 
\ili ¿Alli willacuyta willacur purejcunata yanapashwanchu? 
\im \bd ¿Pitaj isquirbiran?\bd* Apóstol Juanmi isquirbiran. Jutinta mana isquirbirpis cay cartachöga quiquinmi «mayur ermänu» cashanta niycan. 
\im \bd ¿Picunapätaj isquirbiran?\bd* Cay cartata Juan isquirbiran Gayo jutiyoj ermänupämi. Pay caran Juanpa amïgunmi. 
\im \bd ¿Imaytaj isquirbiran?\bd* Cay cartatapis isquirbiran 1 Juan y 2 Juan cartata isquirbishan wichallanmi. Waquin yarpan wata 90 d.C. wichan isquirbishantami. 
\im \bd ¿Imataj caycan cay librucho?\bd* Ishcay carta apachishancho niycashannömi cay cartachöpis niycan ermänu-pura alli ricanacur cuyanacunanpaj. Cay cartata Juan apaycächin Gayo jutiyoj amïgunmanmi. Juc-läpita chayaj ermänucunata payga allimi pachächej (1–5). Diótrefes jutiyoj runapämi ichanga llaquicun. Juc-läpita chayaj ermänucunata payga manashi pachächejchu. Chayno juc ermänucuna pachächinantapis manashi dëjajchu (9–11). 
\ip Ushanantanaga Juan niycan watucoj aywananpaj cashantami (13–15). 
\c 1  
\s1 Carta gallaycunan 
\p  
\v 1 Fiyupa cuyanacushä Gayo: 
\p Noga mayur ermänumi cartata apaycächimö.\x * \xo 1:1 \xt Hech. 19.29; Rom. 16.23; 1Cor. 1.14\x* 
\p  
\v 2 Ermänu, Tayta Diosta amatarmi ruwacö ima rurashayquichöpis alli cananpaj, mana gueshyanayquipaj. 
\s1 Gayopaj alli rimashan 
\p  
\v 3 Ermänunchicuna chayamurmi willamasha Jesucristo yachachishannölla goyaycashayquita. Chaymi fiyupa cushicushcä.\x * \xo 1:3 \xt 2Juan 4\x* 
\v 4 Wamräcuna chayno Tayta Diosman rasunpa yäracuptenga noga fiyupami cushicö. 
\p  
\v 5 Cuyay ermänu, Jesucristupa willacuyninta willacur purej ermänucunata yanapar allitami ruraycanqui.  
\v 6 Paycunaga cayman chayamur shuntacashanchömi cuyapäcoj cashayquita willapasha. Paycunata yanapaycullay purir mana pishëpacunanpaj ari. Chayno ruraptiqui Tayta Diospis amatarmi cushiconga.  
\v 7 Paycunaga Jesucristupa alli willacuyninta willacurmi purircaycan. Tayta Diosman mana yäracojcunaga manami yanapanchu.  
\v 8 Chaymi noganchi yanapäshun Jesucristupa alli willacuyninta may-chaychöpis willacunanpaj. Chayno yanaparga willacäshiycanchïmi. 
\s1 Diotrefespäwan Demetriupaj rimashan 
\p  
\v 9 Nogaga willacojcunata yanapänapaj cashanta tantiyachirmi ermänunchïcunaman cartata apachimö. Diotrefesmi ichanga mandaj cayta munaywan manacajman churamashpan mana chasquishachu.  
\v 10 Chaypitami shamorga piñacushaj. Payga manacajman churamar nogacunapa washäta rimasha. Manami chayllawanchu usharäcun. Chaypa ruquenga ermänunchi chayajcunatapis manami pachächinchu. Pachächiyta munajcunatapis michan. Waquintaga inlisyapita gargun. 
\p  
\v 11 Cuyashä ermänu, ama paynöga canquichu. Chaypa ruquin allillata ruray. Allita ruraj cäga Diospami. Mana allita ruraj cajmi ichanga Diosta mana rejsinchu.\x * \xo 1:11 \xt 1Juan 2.29; 3.6, 9–10\x* 
\v 12 Demetriupämi ichanga llapan runacunapis parlan Jesucristupa willacuynin nishanno cawaycashanta. Nogacunapis paytaga ricashcä Tayta Dios munashanno cawashantami. Gamga musyanquinami nogacuna rimashä rasunpa cashanta. 
\s1 Carta ushanan 
\p  
\v 13 Noga willapänäpäga achcami caycan. Ichanga cartallachöga manami llapanta isquirbimömanchu.  
\v 14 Manapis aycällatanami watucoj shamushaj tincur parlanapaj.\x * \xo 1:14 \xt 2Juan 12\x* 
\p  
\v 15 Alli goyaycullay ari. Caycho caycaj rejsinacushanchi ermänucunami wamayäshunqui. Gamna wamayäcuynëta waquin ermänucunata willaycullay ari.