\id JOL - Guajajara Bible -Brazil 2007 (DBL 2013)
\h ZOEW
\toc1 Zoew
\toc2 Joel
\toc3 Jl
\mt1 ZOEW
\c 1
\p 
\v 1 Tupàn Tuweharupi Wiko Ma'e umume'u ko ze'eg Zoew Petuwew ta'yr pe a'e.
\s1 Tukur ma'e itym myr imumaw har wà, ywy ixinigawhu a'e no
\q1 
\v 2 — Peme'egatu nehe, tua'uhez kwer wà.
\q1 Pezeapyaka katu nehe, Zuta ywy rehe har wà.
\q1 Uzeapo putar amo iaiwahy ma'e nehe.
\q1 Nuzeapo pixik kwaw agwer iaiw paw ko 'ar 'ym mehe we. Nuzeapo pixik kwaw zaneipy wa'ar rehe no.
\q1 
\v 3 Pemume'u uzeapo ma'e kwer pena'yr wanupe nehe.
\q1 Pemume'u uzeapo ma'e kwer pena'yr wanupe nehe, peze pena'yr wanupe nehe.
\q1 Nezewegatete wana'yr umume'u putar wa'yr wanupe a'e wà nehe no.
\q1 
\v 4 Ur tukur tetea'u xe wà. Waneta haw nuzawy kwaw ywàkun tetea'u wà.
\q1 U'u ma'e itym pyrer ma'etymaw nànàn wà.
\q1 Tukur izypy mehe ur ma'e kwer nu'u kwaw hezuz ma'e paw rupi wà.
\q1 Na'e ur amo tukur ywàkun zàwenugar wà. U'u ikurer wà.
\b
\q1 
\v 5 Peme'egatu nehe, uka'u ma'e wà.
\q1 Peme'egatu pezai'o pà nehe.
\q1 Peiko win iputar har romo.
\q1 Tukur umumaw uwà paw wà.
\q1 Naheta kwaw win ipyahu ma'e penemi'u ràm romo nehe kury.
\q1 
\v 6 Ur tukur wà.
\q1 Nuzawy kwaw zauxiapekwer ikàg ma'e tetea'u wà.
\q1 Wixe heywy rehe wà.
\q1 Wanàz nuzawy kwaw zàwàruhu iriàw wanàz wà.
\q1 Haime katu zàwàruhu iriàw kuzà hàz ài wà.
\q1 
\v 7 Umumaw uwà tyw zaneko pe har wà.
\q1 Umumaw ma'e'yw pi her ma'e zaneko pe har wà no.
\q1 O'ok ywyra ape kwer ywyra wi wà.
\q1 Upyta xo hàkà xig ma'e zo.
\q1 
\v 8 Pezai'o kuzàwaza opoz pihun ma'e imunehew par ài nehe,
\q1 umen ràm imàno awer rehe uzai'o ma'e ài nehe.
\q1 
\v 9 Xaxeto Tupàn pe uma'ereko ma'e wà,
\q1 uzai'o waiko Tupàn Tuweharupi Wiko Ma'e hàpuzuhu pupe wà.
\q1 Ta'e teko nuerur kwaw temi'u a'e pe wà kury xe.
\q1 Ta'e nuerur kwaw win a'e pe wà kury xe.
\q1 
\v 10 Tukur umuaiw ko paw wà.
\q1 Umuaiw ywy paw wà no.
\q1 Teko ywy rehe har paw uzai'o waiko wà.
\q1 Ta'e umuaiw tukur arozràn a'e wà xe.
\q1 Ta'e uwà 'yw uxinig a'e wà xe. Ta'e uri 'yw uxinig a'e wà no xe.
\q1 
\v 11 Pezemumikahy nehe, ko pe uma'ereko ma'e wà.
\q1 Pezai'o nehe, uwà tyw wanehe uzekaiw ma'e wà,
\q1 ta'e naheta kwaw arozràn xirik her ma'e a'e kury xe.
\q1 Ta'e naheta kwaw arozràn xewar her ma'e a'e no xe.
\q1 Tukur umumaw temi'u ipo'o pyràm upaw rupi katete wà.
\q1 
\v 12 Uxinig uwà 'yw wà. Uxinig pi 'yw wà no.
\q1 Uxinig homà 'yw wà no. Uxinig inàzàràn 'yw wà no. Uxinig maxà 'yw wà no.
\q1 Ma'e'yw paw uxinig wà. Teko uzemumikahy wà.
\b
\q1 
\v 13 Xaxeto wà, Tupàn henataromo ma'ea'yr zuka har wà,
\q1 pemunehew pàn ma'eryru iapo pyr pezemumikahy haw hexak kar pà nehe. Pezai'o nehe.
\q1 Tupàn hezar hemiruze'eg wà, pezur tàpuzuhu izywyr katu haw pe nehe.
\q1 Pemumaw pytun paw pezai'o pà nehe.
\q1 Ta'e naheta kwaw temi'u imur pyrer zanezar hàpuz me xe. Naheta kwaw uwà imur pyrer zanezar hàpuz me no.
\q1 
\v 14 Pemono'og teko Tupàn Hàpuzuhu pe pe wà nehe.
\q1 — Ximumaw amo 'ar zanemai'u 'ym pà nehe, zanekwaku pà nehe, peze wanupe nehe.
\q1 Pemono'og teko Zuta ywy rehe har paw wanuwihaw pe wà nehe,
\q1 Tupàn Tuweharupi Wiko Ma'e Zanezar hàpuzuhu pe pe wà nehe.
\q1 Peze'eg Tupàn pe nehe, pepytywà àwàm henoz pà nehe.
\b
\q1 
\v 15 Kwa. Tupàn Tuweharupi Wiko Ma'e i'ar uhem wà iko.
\q1 A'e 'ar mehe Tupàn Ikàg Wera'u Ma'e werur putar ma'emumaw haw nehe.
\q1 Teko ukyze katu putar a'e 'ar mehe nehe.
\b
\q1 
\v 16 Nazapuner kwaw zaneko wapyro haw rehe.
\q1 Tukur umumaw zanema'etymaw paw wà. Xixak wamumaw paw ma'e iapo 'ym pà zane.
\q1 Tupàn Zanezar hàpuzuhu pe naheta kwaw turywete haw, naheta kwaw mynykaw no.
\q1 
\v 17 Ko uxinig ma'e rehe nahezuz kwaw ma'eà'yz.
\q1 Teko nopo'o kwaw arozràn wà.
\q1 Tàpuz arozràn imonokatu haw u'ar uzekazeka pà wà.
\q1 
\v 18 Tapi'ak uze'eg waiko wà. Ta'e ima'uhez wà xe.
\q1 Tapi'ak awa wata kwerupi wà, ko rupi wà, he'o pà wà.
\q1 Ta'e naheta kwaw ka'api'i wanemi'u ràm romo xe.
\q1 Àràpuhàràn awa hawitu ma'e umàno waiko wà no.
\q1 
\v 19 Ahapukaz newe, Tupàn Tuweharupi Wiko Ma'e.
\q1 Ywyra uxinig paw wà. Ka'api'i uxinig paw wà no.
\q1 Nuzawy kwaw tata hemiapy kwer wà.
\q1 
\v 20 Te miar wenoz upytywà àwàm newe wà no.
\q1 Ta'e typaw yrykaw a'e xe.
\q1 Ywy nànàn ixinig awer umumaw ka'api'i.
\c 2
\s1 Tukur wà, Tupàn Tuweharupi Wiko Ma'e i'ar no
\q1 
\v 1 Pezupy pexi'àm ywytyr Xiàw her ma'e rehe nehe.
\q1 Pehapukaz ywytyr Tupàn henaw rehe nehe. — Na'ikatuahy kwaw zanewe kury, peze nehe.
\q1 Peryryryryz pekyze pà nehe, Zuta ywy rehe har wà.
\q1 Ta'e uhem Tupàn Tuweharupi Wiko Ma'e 'ar wà iko a'e xe.
\q1 
\v 2 Ipytun putar a'e 'ar mehe nehe. Nuzawy kwaw kwarahy heta 'ymaw nehe.
\q1 Ywàkun ipihunahy putar a'e 'ar mehe wà nehe.
\b
\q1 Tukur ur zauxiapekwer tetea'u ikàg ma'e wazàwe wà.
\q1 Nuzawy kwaw ywàkun ywytyr ipykaw wà.
\q1 Ko 'ar 'ym mehe we teko nuexak pixik kwaw agwer ma'e wà.
\q1 Ko 'ar henataromo nuexak pixik kwaw agwer ma'e wà nehe no.
\q1 
\v 3 Tukur u'u ma'e paw wà.
\q1 Tata wapy ma'e a'e. Umumaw ma'e a'e.
\q1 Tukur nuzawy kwaw tata wà. Wahem 'ym mehe we ywy ikatuahy Tupàn reko haw ài a'e.
\q1 Xe wi waho re ywy nuzawy kwaw ywyxiguhu.
\q1 Tukur umumaw ma'e paw wà.
\q1 
\v 4 Nuzawy kwaw kawaru wà.
\q1 Uzàn kawaru zeàmàtyry'ymaw pe har wazàwe wà.
\q1 
\v 5 Opoopor wà waiko ywytyr apyr wà.
\q1 Wànoànog ywyramawa zeàmàtyry'ymaw pe har wazàwe wà.
\q1 Ywyra àkàgwer uxinig ma'e opoopok tata pupe.
\q1 Nezewegatete opoopok a'e tukur ur mehe wà no.
\q1 Nuzawy kwaw zauxiapekwer tetea'u zeàmàtyry'ymaw pe uzemuàgà'ym ma'e kwer wà.
\q1 
\v 6 Ur waiko wà. Teko paw uryryryryz wà.
\q1 Wanuwy ukàzym wapir wi wakyze haw rehe.
\q1 
\v 7 Upuràmàtyry'ym zauxiapekwer ukyze 'ym ma'e wazàwe wà.
\q1 Uzàn wà. Uzeupir pàrirogaw rehe wà.
\q1 Ur wiwi waiko wà, upytu'u 'ym pà wà.
\q1 Wata zuawygatu wà.
\q1 
\v 8 Nuzemuàzààzàn kwaw wà.
\q1 Pitàitàigatu wata wape rupi wà.
\q1 Tuweharupi wata waiko oho haw rupi wà.
\q1 Naheta kwaw wazuka àwàm. Naheta kwaw wamupytu'u kar àwàm.
\q1 
\v 9 Uzàmàtyry'ym tawhu pe har wà wà.
\q1 Uzeupir pàrirogaw rehe wà.
\q1 Wixe ukenaw rupi ma'e rehe imunar ma'e ài wà.
\q1 
\v 10 Wata oho waiko upytu'u 'ym pà wà. Ywy uryryryryz iko a'e.
\q1 Ywak uryryryryz iko a'e no.
\q1 Kwarahy upytu'u uhyape katu re.
\q1 Zahy upytu'u uhyape katu re.
\q1 Zahytata upytu'u uhyape katu re wà no.
\q1 
\v 11 Tupàn Tuweharupi Wiko Ma'e uze'egahy wahyhaw rupi
\q1 wemiruze'eg zauxiapekwer wanupe kury.
\q1 Umume'u katu wanemiapo ràm wanupe.
\q1 Heta tetea'u zauxiapekwer wà.
\q1 Nukyze kwaw ma'e wi wà.
\q1 Iaiw tuwe Tupàn Tuweharupi Wiko Ma'e i'ar a'e.
\q1 Ni amo nupuner kwaw hehe wà nehe.
\s1 Tupàn uzamutar katu wemiaihu a'e wà
\q1 
\v 12 Tupàn Tuweharupi Wiko Ma'e uze'eg iko kury.
\q1 Pezewyr ihewe pepy'a pupe azeharomoete nehe.
\q1 Pemumaw amo 'ar pemai'u 'ym pà nehe. Pezai'o pezemumikahy pà penemiapo kwer rehe nehe.
\q1 
\v 13 Aze pepurexak kar wer pekatu 'ymaw rehe pezemumikahy haw rehe ihewe nehe, aze pepytu'u wer ikatu 'ym ma'e iapo re nehe, pemu'i zo pekamir nehe.
\q1 Pemu'i pepy'a nehe,
\q1 i'i iko Tupàn peme.
\b
\q1 Pezewyr Tupàn Tuweharupi Wiko Ma'e Zanezar pe nehe.
\q1 Ta'e ikatuahy a'e xe. Ta'e upurupuhareko a'e xe.
\q1 Iàrew tuwe ikwahy haw. Upuruamutar katu no.
\q1 Na'izepyk wer kwaw purehe. Ipurapo wer ikatu ma'e rehe purupe.
\q1 
\v 14 Aze ru'u Tupàn Tuweharupi Wiko Ma'e Zanezar
\q1 nuzapo kwaw uze'eg awer nehe.
\q1 Aze ru'u omono putar uze'egatu wemiaihu wanehe nehe. Aze ru'u umur putar temi'u ipo'o àwàm ikatuahy ma'e wanupe nehe.
\q1 Nezewe mehe pepuner putar temi'u imono haw rehe izupe nehe.
\q1 Nezewe mehe pepuner putar uwà imono haw rehe izupe nehe no.
\b
\q1 
\v 15 Pezupy pexi'àm Xiàw ywytyr rehe nehe.
\q1 Pemume'u amo 'ar pemai'u 'ym àwàm nehe.
\q1 Penoz teko wà nehe. Pemono'og teko Tupàn Hàpuzuhu pupe wà nehe.
\q1 
\v 16 Pemono'og teko paw pe wà nehe.
\q1 — Pezemukatu Tupàn henataromo peho pà nehe, peze wanupe nehe.
\q1 Tuwe teko paw ur wà nehe, tua'uhez ma'e wà nehe, ihya'u ma'e wà nehe no, kwarearer wà nehe, kuzàtàigwer wà nehe no, kuzà wamemyr ukamu ma'e wà no.
\q1 Tuwe uzereko romo ma'e uhem wàpuz wi wà nehe.
\q1 Tuwe a'e teko paw oho Tupàn Hàpuzuhu pe wà nehe.
\q1 
\v 17 Pe, xaxeto
\q1 Tupàn Hàpuzuhu izywyr katu haw pe ma'e Tupàn Tuweharupi Wiko Ma'e pe iapo har,
\q1 pezai'o nehe. Peze'eg Tupàn pe nehe.
\q1 — O Tupàn, ezepyk zo neremiaihu wanehe ne nehe.
\q1 Uremumaranugar kar zo amo teko wanenataromo nehe.
\q1 Nezewe mehe nuze'eg urywahyahy kwaw urerehe wà nehe.
\q1 — Ma'e pe hekon Tupàn pezar a'e, ni'i kwaw urewe wà nehe, peze izupe nehe.
\s1 Tupàn omono wi uze'egatu ywy rehe
\p 
\v 18 Na'e Tupàn Tuweharupi Wiko Ma'e wexak kar wemiaihu a'e ywy rehe har wamutar haw a'e kury. Upuhareko wemiruze'eg wà.
\v 19 Uwazar waze'eg wanupe kury.
\q1 Amono putar arozràn peme ihe nehe kury. Amono putar win peme nehe no, uri kawer nehe no.
\q1 Nezewe mehe pemai'u putar nehe. Penewykàtà putar nehe.
\q1 Namuze'eg urywahyahy kar pixik kwaw amo teko penehe ihe wà nehe.
\q1 
\v 20 Amono kar putar tukur muite pewi ihe wà nehe. A'e tukur kwarahy heixe haw awyze har kutyr har wi ur ma'e kwer ihe wà nehe.
\q1 Tukur amogwer wanenataromo ur ma'e ràm aityk putar Yryhu Umàno Ma'e Kwer her ma'e pupe wà nehe.
\q1 Tukur amogwer wanaikweromo ur ma'e ràm aityk putar yryhu Mezitehàn pupe wà nehe.
\q1 Tukur umàno ma'e kwer u'au'ar uzehezehe wà nehe, ywytyr iapo pà wà nehe. Inem putar wà nehe. Ipihe putar wà nehe.
\q1 Uhua'u ma'e azapo putar ihe nehe. Ta'e ihe Tupàn Tuweharupi Wiko Ma'e azapo ma'e uhua'u ma'e ihe xe.
\q1 
\v 21 Penurywete nehe, o ywy ka'api'i heta haw wà. Pekyze zo nehe.
\q1 Ta'e ihe Tupàn Tuweharupi Wiko Ma'e azapo ma'e uhua'u ma'e ihe xe.
\q1 
\v 22 Pekyze zo nehe, miar hehaite ma'e wà.
\q1 Ta'e ka'api'i ikyr katu putar a'e nehe xe.
\q1 Ma'ywa'yw i'a putar wà nehe no.
\q1 Heta putar ma'e'a pi her ma'e tetea'u nehe. Heta putar uwà tetea'u nehe no.
\q1 
\v 23 Penurywete nehe, Zeruzarez pe har wà.
\q1 Ta'e ihe Tupàn Tuweharupi Wiko Ma'e pezar ihe xe, azapo uhua'u ma'e ihe xe.
\q1 Amugyr kar àmàn i'ar mehe katete ihe.
\q1 Àmàn i'ar mehe amugyr kar ihe.
\q1 Àmàn tetea'u kwehe arer zàwenugar amugyr putar nehe.
\q1 
\v 24 Pepo'o putar arozràn xirik tetea'u nehe.
\q1 Heta putar win tetea'u nehe no. Heta putar uri kawer tetea'u nehe no.
\q1 
\v 25 Amuzewyr kar putar ma'e pewi ukàzym ma'e kwer paw ihe nehe.
\q1 Amur kar tukur tetea'u ywàkun zàwenugar peiwy rehe ihe.
\q1 Nuzawy kwaw zauxiapekwer tetea'u wà. Umuaiw arozràn paw uwà paw uri paw wà.
\q1 
\v 26 Pereko putar penemi'u ràm tetea'u nehe. Napepuner kwaw a'e ma'e paw i'u haw rehe nehe.
\q1 Pemume'u putar Tupàn Tuweharupi Wiko Ma'e pezar ikatu haw nehe.
\q1 Ta'e umur ma'e ikatuahy ma'e tetea'u peme a'e xe.
\q1 Heremiaihu na'imaranugar wi pixik kwaw wà nehe.
\q1 
\v 27 Pekwaw putar penehe we hereko haw nehe.
\q1 Pekwaw putar Tupàn Tuweharupi Wiko Ma'e pezar romo hereko haw nehe no.
\q1 Pekwaw putar amo ae tupàn heta 'ymaw nehe no.
\q1 Heremiaihu na'imaranugar wi pixik kwaw wà nehe,
\q2 i'i Tupàn.
\s1 Tupàn Tuweharupi Wiko Ma'e i'ar
\q1 
\v 28 Tupàn Tuweharupi Wiko Ma'e uze'eg wi wemiaihu wanupe.
\q1 A'e ma'e izeapo pawire azakook putar herekwe penehe upaw rupi ihe nehe.
\q1 Pena'yr a'e wà nehe, penazyr a'e wà nehe, umume'u putar heze'eg a'e wà nehe.
\q1 Tua'uhez ma'e upuahu putar wà nehe. Kwàkwàmo wexak putar ma'e upuahu haw pe har zàwenugar wà nehe.
\q1 
\v 29 Azakook putar herekwe uma'ereko e ma'e awa wanehe nehe.
\q1 Azakook putar herekwe uma'ereko e ma'e kuzà wanehe a'e 'ar rehe nehe no.
\q1 
\v 30 Amuzexak kar putar ma'e purumupytuhegatu kar haw ywak rehe nehe, ywy rehe nehe no.
\q1 Teko wexak putar tuwykwer wà nehe. Teko wexak putar tata wà nehe no. Teko wexak putar tàtàxin ywàkun zàwenugar wà nehe no.
\q1 
\v 31 Kwarahy upytu'u putar uhyape katu re nehe.
\q1 Zahy uzexak kar putar tuwykwer ài nehe.
\q1 A'e ma'e paw uzeapo putar nehe, Tupàn Tuweharupi Wiko Ma'e i'ar iaiw ma'e ihem 'ym mehe nehe,
\q2 i'i Tupàn.
\q1 
\v 32 — Hepytywà pe nehe, aze amo i'i wà nehe, Tupàn upyro putar a'e teko a'e wà nehe. Ta'e Tupàn Tuweharupi Wiko Ma'e umume'uahy ko ma'e a'e xe. — Teko izuka pyràm 'ym paw wiko putar ywytyr Xiàw rehe wà nehe. Apyro putar heremixamixak kwer ihe wà nehe, i'i Tupàn.
\c 3
\s1 Tupàn umume'u putar teko ywy nànànar wanemiapo kwer ikatu 'ym ma'e
\p 
\v 1 Tupàn Tuweharupi Wiko Ma'e uze'eg nezewe. — A'e 'ar rehe amukatu putar Zeruzarez pe har waneko haw ihe nehe, Zuta ywy rehe har waneko haw ihe nehe no.
\v 2 Na'e amono'og putar teko paw ywy nànànar ihe wà nehe. Araha putar ywyàpyznaw Zuzapa her ma'e pe ihe wà nehe. A'e pe amume'u putar wanemiapo kwer ikatu 'ym ma'e nehe. Nezewe azapo putar nehe, ta'e uzapo ikatu 'ym ma'e tetea'u Izaew heremixamixak kwer wanupe a'e wà xe. Umuhàmuhàz Izaew izuapyapyr màràmàràn ywy rehe wà. Umuza'aza'ak heywy wà no.
\v 3 Omomor ita'i ma'e papar haw hereko har wà, heremiaihu imunehew pyrer wazar ràm hexaexak pà wà. Ume'eg kwarer amo pe uma'ereko e ma'e romo wà. Ume'eg kuzàtài amo pe uma'ereko e ma'e romo wà no. Omono wanekuzarer kuzàwyzài wanupe wapuhe oho awer rehe wà. Ume'eg kar win tetea'u wà no.
\p 
\v 4 Teko Xir tawhu pe har wà, teko Xitom tawhu pe har wà, teko Piri ywy rehe har wà, ma'e peputar nehe. Ma'e amono putar peme nehe. Aipo pezepyk wer herehe. Aze a'e rupi nehe, ihe azemuàgà'ym penehe hezepyk àwàm rehe ihe nehe no.
\v 5 Ta'e pemunar hema'e rehe pe xe. Parat, or no. Pemonokatu a'e temetarer a'e ita hekuzar katu ma'e tupàn a'ua'u pezar wanàpuzuhu pe.
\v 6 Peraha teko Zuta ywy rehe har wà. Peraha Zeruzarez pe har wà. Muitea'u waiwy wi peraha wà. Peme'eg Kere ywy rehe har wanupe uma'ereko e ma'e romo wà.
\v 7 Arur wi putar heremiaihu a'e ywy muitea'u har wi ihe wà nehe. Iaiw ma'e pezapo wanupe. A'e rupi iaiw ma'e azapo putar peme nezewegatete ihe nehe no.
\v 8 Amo upyhyk putar pena'yr penazyr a'e wà nehe. Ume'eg putar Zuta rehe har wanupe uma'ereko e ma'e romo wà nehe. Azapo kar putar a'e ma'e ihe nehe. Zuta ume'eg putar pena'yr Xawe izuapyapyr wanupe wà nehe. Muitea'u waiwy xe wi. Ihe Tupàn Tuweharupi Wiko Ma'e amume'u ko ma'e teko ihe kury, i'i Tupàn.
\b
\q1 
\v 9 — Pemume'u ko ma'e teko ywy nànànar wanupe nehe.
\q1 Pezemuàgà'ym zeàmàtyry'ym àwàm rehe nehe.
\q1 Tupàn uzàmàtyry'ym amogwer teko a'e wà nehe.
\q1 Penoz zauxiapekwer wà nehe.
\q1 Tuwe zauxiapekwer paw uhem wà wà nehe.
\q1 Tuwe uzemuàgà'ym zeàmàtyry'ym àwàm rehe wà nehe.
\q1 
\v 10 Pema'ema'e ywy imuwamuwakaw takihepuku romo iapo pà nehe.
\q1 Pema'ema'e petakiheapar purukutukaw romo iapo pà nehe.
\q1 Tuwe te ikàg 'ym ma'e uzemume'u ikàg ma'e romo wà nehe.
\q1 
\v 11 Pezur na'arewahy nehe, teko ywy ko ywy huwake har pe har wà.
\q1 Pezemono'ono'og ywyàpyznaw rehe nehe.
\q1 Tuwe puràmàtyry'ym 'ym ma'e uzeapo zauxiapekwer romo wà nehe.
\b
\q1 
\v 12 Pezemuàgà'ym nehe, teko ywy nànànar wà.
\q1 Pezur ywyàpyznaw Zuzapa her ma'e pe nehe.
\q1 Ta'e ihe Tupàn Tuweharupi Wiko Ma'e ihe xe,
\q1 azepyk putar teko ko ywy huwake har wanehe upaw rupi ihe nehe xe.
\q1 
\v 13 A'e ywy rehe har uzapo ikatu 'ym ma'e tetea'u a'e wà.
\q1 A'e rupi amonohok kar putar ihe wà nehe.
\q1 Teko omonohok arozràn xirik ipo'o haw 'ar mehe wà. Nezewegatete amonohok putar a'e teko ihe wà nehe no.
\q1 Teko upyropyrog uwà rehe zapepohu pupe itykwer imuy'e pà izuwi wà. Nezewegatete amupyropyrog kar putar a'e teko ihe wà nehe no,
\q2 i'i Tupàn.
\b
\q1 
\v 14 Teko tetea'u ur putar ywyàpyznaw Zepykaw her ma'e pe wà nehe. A'e re amo ae teko ur putar a'e pe wà nehe no.
\q1 Tupàn Tuweharupi Wiko Ma'e i'ar uhem etea'i.
\q1 Ur putar ywyàpyznaw Zepykaw her ma'e pe nehe.
\q1 
\v 15 Kwarahy upytu'u uhyape katu re.
\q1 Zahy upytu'u uhyape katu re no.
\q1 Zahytata upytu'u uhyape katu re wà no.
\s1 Tupàn omono putar uze'egatu wemiaihu wanehe
\q1 
\v 16 Tupàn Tuweharupi Wiko Ma'e uze'eg wahyhaw rupi ywytyr Xiàw pe kury.
\q1 Ize'egaw nuzawy kwaw àmàn iànoànogaw.
\q1 Zeruzarez pe har wenu ize'egaw iànoànogaw waiko wà.
\q1 Ywak ywy uryryryryz wà.
\q1 Tupàn uzekaiw katu Izaew izuapyapyr wanehe wà, wàmàtyry'ymar wanuwi wapyro pà wà.
\q1 
\v 17 Nezewe pekwaw putar Tupàn Tuweharupi Wiko Ma'e pezar romo hereko haw nehe.
\q1 Aiko Xiàw pe ihe, ywytyr ihewe imonokatu pyrer pe ihe.
\q1 Zeruzarez uzeapo putar tawhu ikatuahy ma'e romo nehe.
\q1 Teko amo ae ywy rehe har nupyro pixik kwaw a'e tawhu wà nehe.
\q1 
\v 18 A'e 'ar rehe uwà tyw upyk putar ywytyr paw wà nehe.
\q1 Tapi'ak umai'u putar ywytyr nànàn wà nehe no.
\q1 'Y tetea'u uwyryk putar yrykaw Zuta ywy rehe har wanupi nehe.
\q1 Amo yrykawhu uhem putar heràpuzuhu wi nehe.
\q1 Umuhàmuhàz putar 'y ywyàpyznaw Akaz her ma'e nànàn nehe.
\q1 
\v 19 Ezit ywy uzeapo putar teko heta 'ymaw romo nehe.
\q1 Enom ywy uzeapo putar ywyxiguhu romo nehe,
\q1 ta'e a'e ywy rehe har wixe Zuta ywy rehe a'e wà xe,
\q1 teko ikatu 'ym ma'e iapo 'ymar wazuka pà a'e wà xe.
\q1 
\v 20-21 Azepyk putar a'e teko wazuka arer wanehe nehe.
\q1 Azepyk putar a'e ma'e iapo arer wanehe nehe. Tuweharupi heta putar teko Zuta ywy rehe wà nehe, Zeruzarez pe wà nehe no.
\p Upaw. 
