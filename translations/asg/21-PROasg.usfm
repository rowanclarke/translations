\id PRO PRO - Cishingini Agwara Kambari [asg] KATAGARDA KA ANSA Katagarda ka ANSA ANS
\toc3 An
\toc2 Ansa
\toc1 Katagarda ka Ansa
\mt1 Katagarda ka Ansa
\imt1 Kuɓa̱yuwa̱
\im Katagarda ka Ansa, katagarda kaꞋa ka na o ɓolongi kuyotsongusu ku kuyongo ku ma̱riki n ku kutoni. Kuyotsongusu ka ki ta̱ uɗiki n ansa n cicoꞋo tsu mogono Sulemanu. Kuyotsongusu ka ku pece ta̱ cicoꞋo n tsulau, a̱ ida̱shi i ma̱riki n i gbani-gbani, a na a yaꞋin kadanshi ke le n uye kakau. Kadanshi ka̱ a̱bunda̱i ki ta̱ a kadanshi ki ili i na yi a̱ kugita̱sa̱ anana m makpaꞋa. Katagarda ka ka̱ gita̱ ta̱ n kuciɓaka uma, Wovon u Ka̱shile ɗaɗa ugiti u kuyeve. 1:7 Ili i na i ɗikai lo katagarda ka, ka lyaꞋa ta̱ kelime n kuyaꞋan kadanshi ka na ki ida̱shi i kutoni i ɗa koci ba, ama ili i na a kiwanai kene n kuyongo ku ma̱riki. IcuꞋu i kadanshi ka wawaꞋa ka nampa ko yotsongu icuꞋu i kuyeve ku nlum mi Isaraila n cau, tsu na vuza vu cicoꞋo u kuyaꞋan a makyan ma na ili i yoku i ɗa̱nga̱i. Ukuna u nampa wa wi ta̱ a kadanshi ki ida̱shi i kpaꞋa, n i tsulaga. U yoku kpamu wi ta̱ a kadanshi ki ida̱shi a̱ ka̱tsuma̱ ka uma, ko kpamu ida̱shi yu usuɓi. Ukuna wa̱ a̱bunda̱i wi ta̱ a kadanshi, vu goyo ka̱ci ka̱ nu, uka̱ni u ka̱ɗu, n kuɗika aza a unambi n a̱shi a singai n ida̱shi i ma̱riki a̱ ka̱tsa̱ma̱ ka̱ a̱ja̱Ꞌa̱.
\iot Ili i na yi punu u udari a katagarda ka nampa
\io1 Kucikpa ku ansa 1:1-9; 18
\io1 Ansa Sulemanu 10:1-22; 16
\io1 Kadanshi ka ansa kamangankupa, 22:16-24; 34
\io1 Ansa kadanshi o yoku a Sulemanu 25:1-29; 27
\io1 Kadanshi ka Agur 30:1-31
\io1 Kadanshi ko yoku ka ku yotsongusu 31:1-31
\c 1
\s1 Ugiti u kuyeve
\p 
\v 1 Ansa a Sulemanu kolobo ka Dawuda mogono mi Isaraila.
\q1 
\v 2 Na ɗa ansa a na a̱ kuɓa̱nka̱ wu,
\q2 vu yeve cicoꞋo n odoki a singai,
\q2 ka̱ta̱ e yeve kudansa i na yi usokongi
\q1 
\v 3 adama a na a̱ ciya̱,
\q2 kuyotsongusu ku cicoꞋo,
\q2 n usuɓi, n afada a mayun,
\q2 n ili i na yi mayin,
\q1 
\v 4 a zuwa vuza vu unambi u kuyeve,
\q2 wo okpo n kuyeve,
\q2 o yotsongusu a̱ɗa̱nga̱ni tsu na
\q2 a kuyaꞋan kusheshe ku singai.
\q1 
\v 5 YaꞋan vuza vu cicoꞋo u pana ka̱ta̱ u doku ciya̱ kuyeve,
\q2 vuza vu uyevi kpamu
\q2 u ciya̱ uɓa̱nki
\q1 
\v 6 adama a na e yeve i na ansa i a kadanshi,
\q2 kadanshi ka aza o cicoꞋo n iteꞋe i le.
\q1 
\v 7 Wovon u Vuzavaguɗu u ɗaɗa ugiti u kuyeve,
\q2 ama kalau ka goyo ta̱ cicoꞋo n odoki.
\s1 Odoki u ka̱ɗa̱nga̱ni
\q1 
\v 8 Pana, Maku ma̱va̱, pana kadanshi ke esheku a̱ nu,
\q2 kpamu ka̱ta̱ vu ka̱sukpa̱ odoki a̱na̱ku a̱ nu ba,
\q1 
\v 9 adama a na kuyotsongu ku le
\q2 ki ta̱ o ku doku wu tsugbayin,
\q2 ka̱ta̱ okpo ili kuɗeku i singai a kuɗeku ku nu.
\q1 
\v 10 Maku ma̱va̱, ɗa baci aza a unushi a kparasai nu,
\q2 ka̱ta̱ vu ushuku ba.
\q1 
\v 11 Ɗa baci a danai, <<Ta̱wa̱ tsu gbaɓa kaci,
\q2 tsu una vuma yoku,
\q2 tsu bana tsu bopo tsu una aza a babu unushi,
\q1 
\v 12 YaꞋan tsu soɗongu le ra̱ka̱-ra̱ka̱ tsu kasaun,
\q2 tsa aza a na a̱ gida̱la̱i a kubana e kpenle.
\q1 
\v 13 ka̱ta̱ ci ciya̱ uciyi n a̱bunda̱i,
\q2 ci shatangu iꞋuwa i tsu n ucanuku u gbani,
\q1 
\v 14 ta̱wa̱ vu gbaɓa ka̱ci n a̱tsu,
\q2 ka̱ta̱ tsu pece ili i na tsu bokoi.>>
\q1 
\v 15 Maku ma̱va̱, ka̱ta̱ vu gbaɓa ka̱ci ka̱ nu n icuꞋu i uma a nanlo ba,
\q2 yaꞋan daꞋangi n ele,
\q1 
\v 16 adama a na i ta̱ m moloko a̱ ubuta̱ u kuyaꞋan ka gbani-gbani,
\q2 i ta̱ ufoɓi ayin tutu adama a munuka.
\v 17 Gbani ɗa azuku maza
\q2 a̱ a̱shi a manunu ma na a cigai kuka̱na̱.
\q1 
\v 18 ama icuꞋu i uma a nanlo,
\q2 ka̱ci ke le kaꞋa a tsu zuwaka maza.
\q2 e ci reme ili ba, wuma u le ɗa koci.
\q1 
\v 19 Ta ukocishi wu uye
\q2 wa aza a̱ kutsa̱n ki ikebe i nannai,
\q1 kutsa̱n ka ki ta̱ o ku okpo ma̱giti mu ukpa̱ me le.
\q2 Ci coꞋo ci ta̱ e meɗevile.
\s1 Kadanshi a ukuna u ku iwan cicoꞋo
\q1 
\v 20 Panai, cicoꞋo ci ta̱ e meɗevile a uye n kuden,
\v 21 ci ta̱ e meɗevile n utsura a̱ utsutsu i likuci, n ubuta̱ u na uma dem a tsu yaꞋan oɓolo.
\v 22 <<Ali wannai ɗa, a̱ɗa̱ aza a na yi n ugboji ba,
\q2 yi ta̱ o kuyongo nannai ko ugboji?
\q1 Ali wanai ɗai, a̱ɗa̱ aza o kugoyi,
\q2 yi ta̱ a kupana uyoꞋo wu ulami u na yi a kuyaꞋan,
\q2 a̱ɗa̱ a lau i iwain kuyeve?
\q1 
\v 23 Ishi baci i zuwa atsuvu i pana uɓarangi u va̱.
\q2 Mi ishi a̱ ku tsuwa̱nka̱ ɗa̱ n ayinviki a̱ va̱,
\q2 ka̱ta̱ n zuwa ɗa̱ i yeve kadanshi ka̱ va̱.
\q1 
\v 24 Adama a na n ɗeke ta̱, ɗa̱ i iwain kupana,
\q2 n ɗengusa̱i ekiye a̱ va̱ wa̱ a̱ ɗa̱ ama ko vuza u zuwaka ba,
\q1 
\v 25 I iwain kutono odoki a̱ va̱ ra̱ka̱,
\q2 kpamu i ciga uɓarangi ɗa̱ u va̱ ba.
\v 26 Mi ta̱ o ku zoꞋoso ɗa̱,
\q2 a makyan ma atakaci,
\q1 mi ta̱ a kuyaꞋanka ɗa̱ ulami,
\q2 a makyan ma na ma̱dukpa̱ ma̱ ta̱wa̱i ɗa̱,
\q1 
\v 27 Ayin a na baci atakaci a̱ ta̱wa̱i ɗa̱
\q2 tsu kabatalikpau,
\q2 a ayin a na yi o kusoꞋo atakaci n awuya.
\q1 
\v 28 Ka̱ta̱ i ɗeke mu,
\q2 ama mi a̱ ku ushuku ɗa̱ ba.
\q1 yi ta̱ a̱ ku la̱nsa̱ mu a̱ ubuta̱ dem,
\q2 ama yi a̱ kuciya̱ mu ba.
\q1 
\v 29 Adama a na i iwan ta̱ kuyeve ugaꞋin u kuyeve ba,
\q2 kpamu i zagba i pana wovon u Vuzavaguɗu ba.
\q1 
\v 30 Yi ushuku n odoki a̱ va̱ ba,
\q2 i iwain uɓarangi u va̱.
\q1 
\v 31 Adama a nannai yi ta̱ a̱ kuciya̱ katsupu ku ulinga u ɗa̱,
\q2 yi ta̱ a̱ kucuwa̱ n una̱mgbuka̱tsuma̱ u ɗa̱.
\v 32 Aza a unambi u kuyeve a tsu kuwa̱ ta̱, adama a na a̱ ushuku n cicoꞋo ba,
\q2 Alau tamkpamu a̱ tsu kuwa̱ ta̱ adama a na a zuwaka ba.
\q1 
\v 33 Ama yaba dem vu na baci u panakai mu,
\q2 wi ta̱ a̱ kuda̱sa̱ngu m ma̱ta̱na̱.
\q1 Ko ili tana yi a̱ kuciya̱ yi ba,
\q2 babu kpamu ili i na i kuneke yi wovon.>>
\c 2
\s1 Ugain u cicoꞋo
\p 
\v 1 Maku ma̱ va̱,
\q1 ushuku n kadanshi ka̱ va̱.
\q2 ka̱ ta̱ vu sokongu kadanshi ka̱ va̱,
\q1 
\v 2 Zuwa atsuvu a ukuna u cicoꞋo,
\q2 vu yaꞋan moloko ma na vu yeve i ɗa.
\q1 
\v 3 Mayun,
\q2 folono uyevi ka̱ta̱ vu la̱nsa̱ kuyeve,
\q1 
\v 4 la̱nsa̱ ku ɗa tsa azurufa,
\q2 vu la̱nsa̱ tsu na a̱ tsu la̱nsa̱ uciyi u na wi usokongi.
\q1 
\v 5 Ka̱ta̱ vu yeve wovon u Vuzavaguɗu,
\q2 ka̱ta̱ vu ciya̱ kuyeve ku Ka̱shile.
\q1 
\v 6 Adama a na Vuzavaguɗu ɗa u tsu neke cicoꞋo,
\q2 kuyeve n cicoꞋo kpamu,
\q2 a una̱ u ni u ɗa ku tsu uta̱.
\q1 
\v 7 U tsu neke ta̱ aza a na
\q2 i o kutono mejege cicoꞋo,
\q2 a̱yi ɗa ma̱ra̱ga̱ wa aza
\q2 a na i o kutono derere.
\q1 
\v 8 Adama a na utsu la̱na̱ ta̱
\q2 ukuna wa afada a mayun,
\q2 u tsu ere ta̱ uye wa aza a na i a kuciga yi.
\q1 
\v 9 Yi ta̱ e kuyeve ukuna wu usuɓi n afada n ukuna u mejege,
\q2 n uye u na u gaꞋin dem.
\q1 
\v 10 Adama a na vi ta̱ a̱ kuciya̱ cicoꞋo a̱ ka̱ɗu ka̱ nu,
\q2 kuyeve kpamu ki ta̱ e kuneke wu ma̱za̱nga̱.
\q1 
\v 11 Kula̱na̱ ku nu ki ta̱ e ku ere wu
\q2 kuyeve ku nu ki ta̱ o kutono n avu.
\q1 
\v 12 CicoꞋo ci ta̱ a̱ ku uta̱ka̱ wu a ka gbani-gbani.
\q2 a uma a kadanshi ka kavama.
\q1 
\v 13 Aza a na a̱ ka̱sukpa̱i uye u mayun,
\q2 adama a na o yongo a uye u ka̱yimbi,
\q1 
\v 14 aza a na a tsu pana uyoꞋo u kuyaꞋan ka gbani-gbani,
\q2 a̱ ma̱za̱nga̱ n ka gbani-gbani.
\q1 
\v 15 aza a na uye u le wi magaba ba,
\q2 aza a na uye u le u modoruko u ɗa.
\q1 
\v 16 CicoꞋo ci ta̱ e kere wu we ekiye a kashakanlai, vuza wi ukuna u na u kparasa wu n una̱ wu uyoꞋo u ni.
\q1 
\v 17 vuza na u ka̱sukpa̱i vali vu ni a ayin a utsura a̱ ni,
\q2 vuza na u tsu koɗo uzuwakpani u na u yaꞋin e kelime ka̱ Ka̱shile.
\q1 
\v 18 Adama a na kpaꞋa ku ni uye wu ukpa̱ u ɗa,
\q2 uye u ni a kubana a ubuta̱ wa̱ ukpisa̱ u ɗa.
\q1 
\v 19 Vuza na baci de dem u banai ubuta̱ u ni, u tsu bono ba.
\q2 Wi o ku doku kubono a uye u wuma ba.
\q1 
\v 20 Adama a nannai, mayun ɗa vu tono uye,
\q2 u na uma a singai o tonoi,
\q2 vu tono uye wa aza a usuɓi.
\q1 
\v 21 Uma a na i a kuyaꞋan ukuna u mejege,
\q2 e le ɗa aza a na a̱ kuda̱sa̱ngu a iɗika ya.
\v 22 Ama i ta̱ a ku una aza a gbani-gbani punu a i ɗika ya,
\q2 aza a na i m ma̱riki ba, i ta̱ a ku takpa le punu.
\c 3
\s1 Odoki adama A̱ɗa̱nga̱ni
\p 
\v 1 Maku ma̱va̱, ka̱ta̱ vu cinukpa n kuyotsongusu kuva ba̱.
\q2 ama ka̱sukpa̱ ka̱ɗu ka̱ nu ke reme wila̱ u va̱.
\q1 
\v 2 Ku yotsongusu ku va̱ ki ta̱ a ku neke wu ma̱ta̱na̱ n wuma wu ugaɗi.
\q1 
\v 3 Ka̱ta̱ vu ushuku vu ka̱sukpa̱ kamayun n kasingai ba, shiya le a̱ kuɗeku ku nu,
\q2 ɗana le kpamu a̱ ka̱ɗu ka̱ nu.
\q1 
\v 4 Ɗa baci vu yaꞋin nanai,
\q2 Ka̱shile ki ta a kuyaꞋan ma̱za̱nga̱ n avu.
\q2 Vi ta̱ a̱ kuciya̱ ulyaꞋi a̱ ka̱tsuma̱ kuyongo kuna vi a kuyaꞋan n uma.
\q1 
\v 5 Ushuku n Vuzavaguɗu n ka̱ɗu ka̱ nu dem.
\q2 Ka̱ta̱ vu piꞋisa a kuyeve ku nu ba.
\q1 
\v 6 Ciɓa n Vuzavaguɗu a ili i na vi a kuyaꞋan dem,
\q2 a̱yi tana wi ta̱ a ku yotsongu wu uye u singai.
\v 7 Ka̱ta̱ vu ɗika ka̱cika̱nu vuza vu cicoꞋo ɗa ba,
\q2 pana wovon u Vuzavaguɗu
\q2 vu ka̱sukpa̱ ka gbani-gbani.
\q1 
\v 8 Ɗa baci vu yaꞋan nanai, wi ta̱ o kokpo an a̱guma̱ a singai,
\q2 a na o ku potsotongu untsu a̱ nu ka̱ta̱ a̱ ɓa̱nka̱ mɓa̱la̱ n nu.
\q1 
\v 9 Neke Ka̱shile tsugbayin ni na vi n i ɗa,
\q2 n umaci wi ili yu ugiti i kashina i nu ra̱ka̱.
\q1 
\v 10 Ɗa baci vu yaꞋan nanai, mpon nu mi ta̱ a kushana n ili i kulyaꞋa.
\q2 Vi ta̱ mini mi inabi ma̱ a̱bunda̱i, ali vu kpa̱ɗa̱ kuciya̱ ubuta̱ una va̱ kutsuwa̱n maꞋan ra̱ka̱.
\q1 
\v 11 Maku ma̱va̱, ka̱ta̱ vu goyo udansuki u Vuzavaguɗu ba,
\q2 ka̱ta̱ kpamu vu iwan u ɓarangi u ba.
\q1 
\v 12 Adama a na Vuzavaguɗu u tsu ɓarangu ta̱ aza ana u cigai,
\q2 u teku tsuna kesheku ka tsu ɓarangu maku ma na u cigai.
\q1 
\v 13 Vuza ma̱za̱nga̱ ɗa vuza na u ciya̱i cicoꞋo,
\q2 n vuza na kpamu u ciya̱i kuyeve.
\q1 
\v 14 Adama ana kodokpotsu ko cicoꞋo ka̱ ni ka laꞋa ta̱ ka azurufa,
\q2 ugaꞋin u ni u laꞋa ta̱ kazanariya.
\q1 
\v 15 U laꞋa ta̱ katali ku ugaꞋin ikebe, babu ili i na a ku gisangu n a̱yi.
\q1 
\v 16 Ugboji u tsu doku ta̱ wuma wu ugaɗi,
\q2 tsu udukuyan n tsugbayin.
\q1 
\v 17 Uye uni uye wu uyoꞋo uɗa, ra̱ka̱ vu le tana u ma̱ta̱na̱ uɗa.
\q1 
\v 18 Aza ana i n ugboji,
\q2 ita̱ m ma̱za̱nga̱,
\q1 cicoꞋo ci ta̱ a kuneke le wuma.
\q1 
\v 19 Vuzavaguɗu u yaꞋin aduniya n cicoꞋo ci ni,
\q2 n kuyeve ku ni kpamu u yaꞋin gaɗi.
\q1 
\v 20 N kuyeve kuni ɗa nyeneke mu uga̱vi n ɓa̱yuwa̱i,
\q2 eleshu kpamu o yoꞋo mini i ɗika.
\q1 
\v 21 Maku ma̱va̱, reme ugboji u nu n kuyeve ku nu.
\q1 ka̱ta̱ vu ka̱sukpa̱ le a̱ ka̱sukpa̱ wu ba.
\q1 
\v 22 I ta̱ a ku okpo wu wuma,
\q2 n ugaꞋin tsu ucanuku wu ili i singai wa̱ nu.
\q1 
\v 23 Ta va kuyaꞋan nwalu a uye u nu nannai m ma̱ta̱na̱
\q2 vi tana a̱ kuta̱ɗa̱tsa̱ ba.
\q1 
\v 24 Ɗa baci vu vaki, vi a kupana wovon ba,
\q2 ɗa baci vu vaki alavu a̱ nu i ta̱ o ku yokpo.
\q1 
\v 25 Ka̱ta̱ vu pana wovon wa atakaci a na a̱ kuta̱wa̱ wu makyan me te ba.
\q2 ko kpamu atakaci a na a kuciya̱ aza gbani-gbani tsu wunla̱ ba.
\q1 
\v 26 Vuzavaguɗu wi ta̱ a ku ere wu,
\q2 wi a ku ka̱sukpa̱ wu vu a za a maza ba.
\q1 
\v 27 YaꞋanka aza ana a cigai u ba̱nki kasingai,
\q2 a makyan mana baci vi a kufuɗa ra̱ku.
\q1 
\v 28 Ka̱ta̱ vu dana vutoku nu,
\q2 <<Wala biꞋi sai makpaꞋa vu bono,
\q2 ka̱ta̱ n neke wu,>> wana ɗa tana vi ni i ɗa lo.
\q1 
\v 29 Ka̱ta̱ vu sheshe ke vutoku vu nu kagbanigbani ba,
\q2 vuza̱ nu na yi ida̱shi i singai n koɓolo.
\q1 
\v 30 Ka̱ta̱ vu yaꞋan kanana n vuza babu u kuna ba,
\q2 babu tana u nusaka wu.
\q1 
\v 31 Ka̱ta̱ vu yaꞋan cisheꞋe n aza kuyaꞋan ka gbani-gbani ba,
\q2 ko vu zagba uye u yoku u le ba.
\q1 
\v 32 Adama ana Vuzavaguɗu u iwan ta̱ aza ana a kuyaꞋan ka gbani-gbani,
\q2 ama u ci ciga ta̱ aza a kamayun a̱ ka̱ɗu.
\q1 
\v 33 Una̱wuya u Ka̱shile wita̱ a kpaꞋa ku vuza gbani-gbani,
\q2 ama u tsu zuwaka ta̱ kpaꞋa a ka za a usuɓi una̱singai.
\q1 
\v 34 U tsu goyo ta̱ aza izoshi i kugoyi,
\q2 ama u ci neke ta̱ kasingai wa aza uremi u kaci.
\q1 
\v 35 Vuza vu cicoꞋo u tsu ciya̱ ta̱ tsugbayin,
\q2 ama kalau ki ta̱ o kusoꞋo wono.
\c 4
\s1 Odoki o cicoꞋo wa̱ a̱ɗa̱nga̱ni
\q1 
\v 1 Muku n va̱, panai odoki ana Dada ɗa̱ u piꞋisakai ɗa̱.
\q2 zuwa ugboji, vi ta̱ kpamu a̱ kuciya̱ ku yeve.
\q1 
\v 2 Adama ana n mi ta̱ e kuneke ɗa̱ odoki a singai, ka̱ta̱ i ka̱sukpa̱ ku piꞋisa ku va̱ ba.
\q1 
\v 3 A ayin ana mi ishi maku a kpaꞋa ku Dada va̱,
\q2 mpa maku mo mogono maꞋan, maku mu ucigi maꞋa wa̱ a̱na̱ku a̱va̱,
\q1 
\v 4 u piꞋisakai mu ɗa udanai mu,
\q2 <<Reme kadanshi ka̱va̱ n ka̱ɗu ka̱ nu,
\q2 tono wila̱ u va̱ vi ta̱ a̱ kuciya̱ wuma.
\q1 
\v 5 La̱nsa̱ cicoꞋo, la̱nsa̱ kuyeve,
\q2 ka̱ta̱ vu cinukpa ko vu iwan kaꞋa,
\q1 
\v 6 Ka̱ta̱ vu ka̱sukpa̱ cicoꞋo ba, ci ta̱ tana e ku ere wu,
\q2 ciga tsu ɗa, tsu ɗa ci ta̱ tana feu a kula̱na̱ wu.
\q1 
\v 7 Ugiti u cicoꞋo u ɗanna, ciya̱ cicoꞋo, n ili i na vu ciya̱i dem,
\q2 ciya̱ ku yeve.
\q1 
\v 8 Ciga tsu ɗa, ci ta̱ a kuneke wu tsugbayin.
\q2 oɓongu tsu ɗa, ci ta̱ tana kpamu a kuneke wu tsugbayin.
\q1 
\v 9 Wi ta̱ a ku okpo wu ma̱kuꞋun ma tsugbayin a kaci ka̱ nu,
\q2 ma̱kuꞋun ma singai ma ku cikpa kpamu.>>
\q1 
\v 10 Pana, maku ma̱va̱, ushuku n ili i na n danai,
\q2 a̱ya̱ a wuma a̱ nu kpamu i ta̱ o ko okpo a̱ ka̱bunda̱i.
\q1 
\v 11 N piꞋisa ka wu ta̱ ɗe, uye u cicoꞋo,
\q2 n tonoi n avu a uye u na wi mejege.
\q1 
\v 12 Vu yaꞋan baci nwalu n cicoꞋo, babu ili i na ya ku kpada wu uye,
\q2 a makyan mana vi a ilaɗi, vi a kuta̱ɗa̱tsa̱ ba.
\q1 
\v 13 Reme odoki a nanlo a n utsura, ka̱ta̱ vu ka̱sukpa̱ a ɗa ba,
\q2 reme a ɗa mayin, adama ana wuma uɗa wa̱ nu.
\q1 
\v 14 Ka̱ta̱ vu uwa a uye wa aza gbani-gbani ba,
\q2 ka̱ta̱ kpamu vu yaꞋan nwalu a uye wa aza a na a kuyaꞋan gbani-gbani ba.
\q1 
\v 15 Katsukpa, ka̱ta̱ vu wala a uɗa ba,
\q2 kpatala vu ka̱sukpa̱ u ɗa, ka̱ta̱ vu yaꞋan nwalu n nu kau.
\q1 
\v 16 Adama ana aza a gbani-gbani a nanlo a tsu lata ba,
\q2 sai a yaꞋan kagbanigbani, alavu a tsu ka̱na̱ a̱shi e le ba,
\q2 sai a zuwa vuza yoku u ta̱ɗa̱tsa̱.
\q1 
\v 17 Kagbanigbani ka ɗaɗa ilikulya i le,
\q2 vishili kpamu vu ɗaɗa ili i kusoꞋo i le.
\q1 
\v 18 Uye wa aza a usuɓi wita̱ uteku tsu ku uta̱ ku kutashi ku kanna ku ɗa,
\q2 kutashi kuna ku tsu ka̱na̱ kudokusu ali wa akana kanna a kaci mayin.
\q1 
\v 19 Uye wa aza gbani-gbani wita̱ u teku tsu ka̱yimbi ka kpaɓam,
\q2 a̱ tsu yeve i na i tsu zuwa le ku ta̱ɗa̱tsa̱ ba.
\q1 
\v 20 Maku ma̱va̱, pana i na mi a kudansa,
\q2 zuwa atsuvu mayin vu pana kadanshi ka̱ va̱.
\q1 
\v 21 PiꞋisa kaꞋa ka̱ta̱ vu ka̱sukpa̱ ka ka̱ uta̱ a kusheshe ku nu ba,
\q2 zuwa kaꞋa a ka̱ɗu ka̱ nu,
\q1 
\v 22 adama ana wuma u ɗa, wa aza ana i a̱ kula̱nsa̱ le.
\q2 n upoci wi ikyamba i vuma ra̱ka̱.
\q1 
\v 23 Ere ka̱ɗu ka̱ nu n utsura u nu ra̱ka̱,
\q2 adama ana a̱ ka̱tsa̱ma̱ ka̱ ni ka wuma u tsu uta̱ tsu mini.
\q1 
\v 24 Vu ka̱sukpa̱ kadanshi ka a uwa,
\q2 ka̱ta̱ kpamu vu yaꞋan daꞋin n kadanshi ku una̱ ure, ure.
\q1 
\v 25 Ka̱sukpa̱ a̱shi a̱ nu a inda magaba mayin,
\q2 a ukuna u kadanshi ka̱ nu mayun ɗa.
\q1 
\v 26 Vu yeve ana vu yeve ta̱ ili i na vi a kuyaꞋan,
\q2 ili i na vi a kuyaꞋan ra̱ka̱ kpamu yi ta̱ o ku okpo mayin.
\q1 
\v 27 Ka̱ta̱ vu katsukpa usingai ko u gula̱ ba,
\q2 takpa kune ku nu a uye u ka gbani-gbani.
\c 5
\s1 Udansuki adama tsugbani
\p 
\v 1 Maku ma̱ku ma̱va̱, zuwa atsuvu vu pana ugboji u va̱,
\q2 ɓa̱yuwa̱ atsuvu vu pana kuyeve ku va̱,
\q1 
\v 2 adama ana vu yaꞋan ili dem n ka̱ɗu ida̱shi,
\q2 ka̱ta̱ una̱ u nu kpamu u yotsongu ana vi ta̱ n uyevi.
\q1 
\v 3 Adama ana nlebu mu una̱ n kashakanlai ugan ba n yaꞋan uyoꞋo ci ishigi,
\q2 kpamu kadanshi ka̱ni ka laꞋa ta̱ mani n leku,
\q1 
\v 4 ama a ukocishi kuyongo ni i ɗa, okono aɗa,
\q2 wi ta̱ a kusapa wu tsu kotokobi ku una̱ ure ka alyu.
\q1 
\v 5 Ene a̱ ni a ukpisa̱ u ɗa i a kubana,
\q2 uye uni wita̱ a kubanka wu ubuta̱ wi ida̱shi wa̱ a̱kpisa̱.
\q1 
\v 6 Ili i bura yi n uye u wuma ba,
\q2 uye u ni magaba ma wi ba,
\q2 a̱yi tana u yeve ana ta uɗa wi nannai ba.
\q1 
\v 7 Gogo na maku ma̱va̱, pana ka mu,
\q2 ka̱ta̱ vu ka̱sukpa̱ kadanshi ka una̱ u va̱ ba.
\q1 
\v 8 YaꞋan daꞋin n uye u ni,
\q2 ka̱ta̱ vu bana ɗevu n utsutsu u kpaꞋa ku ni ba,
\q1 
\v 9 ka̱ta̱ utsura u nu u kotso wa aza yoku ba,
\q2 vu kuwa̱ a̱ ka̱ɗa̱nga̱ni ekiye aza babu asuvayali.
\q1 
\v 10 Omoci tana a̱ kupura̱ utsura wi ikyamba i nu,
\q2 mele ma̱ nu ma bana ta̱ a kpaꞋa ku vuza yoku gbani.
\q1 
\v 11 Ka̱ta̱ a ukoci u wuma u nu vu ka̱na̱ ci inka a̱ ka̱tsuma̱ ku usuɗukpi,
\q2 a makyan mana mɓa̱la̱ n takumai i kyamba i nu,
\q1 
\v 12 Vi ta̱ a kudana, <<Yiɗa̱i i zuwai ɗa n kpa̱ɗa̱i ku ɗika udansuki?
\q2 Yiɗa̱i i zuwai ɗa ka̱ɗu ka̱va̱ ko goyoi uɓarangi?
\q1 
\v 13 N zuwa atsuvu u malum ma̱va̱ ba.
\q2 m bonoko ka̱ɗu ka̱va̱ kpamu we ele ba.
\q1 
\v 14 Ɗanna n yawa ta̱ ɗevu n ku kuwa̱,
\q2 gogo na mi ta̱ ɗevu n kuyaꞋan wono a̱ ka̱tsa̱ma̱ ka uma.>>
\q1 
\v 15 YaꞋan kamayun u vuka vunu,
\q2 vu cigai a̱yi koci.
\q1 
\v 16 Derere ɗa a̱shi mini mi ikyamba ma̱ nu, ma̱ ka̱na̱ ku uwa̱ mini ubuta̱ dem?
\q2 Ko kpamu wo okpo ma yaba dem?
\q1 
\v 17 Ka̱sukpa̱ okpo ma̱ nu koci,
\q2 vi e kupece n komoci ba.
\q1 
\v 18 Ka̱sukpa̱ mini ma̱ nu mo okpo n una̱singai,
\q2 yaꞋan ma̱za̱nga̱ n vuka vu nu ka̱ɗa̱nga̱ni.
\q1 
\v 19 UgaꞋin u ku ene an mereꞋe,
\q2 ka̱sukpa̱ mani ma ni ma yawai makyan dem,
\q2 ka̱sukpa̱ ucigi u ni kpamu u reme wu.
\q1 
\v 20 Maku ma̱va̱ yiɗa̱i i kuzuwa vuka vuza cishakanlai ulya kaci ka̱ nu?
\q2 Yiɗa̱i i kuzuwa vu oɓongu vuka vuza yoku?
\q1 
\v 21 Adama ana uye u wuma u vuma, e keteshe ka i a̱ a̱shi a Vuzavaguɗu,
\q2 Vuzavaguɗu tana u tsu kondo ta̱ uye u ni dem.
\q1 
\v 22 Unushi u vuza gbani-gbani maza maꞋa wa̱ ni,
\q2 awin a unushi u ni a tsu remei ta̱ mayin.
\q1 
\v 23 Utsu kuwa̱ ta̱ adama ukpa̱ɗi u ku reme ka̱cika̱ni
\q2 tsulau tsa a̱bunda̱i tsu ni tsu ɗa tsa a ku unai.
\c 6
\s1 Udansuki adama a tsulau
\q1 
\v 1 Maku ma̱va̱ vu saꞋawa ta̱ ku okpo magan adama a ka̱ja̱ ka̱ nu ubuta̱ u ku isa kutan?
\q2 Vu saꞋawa ta̱ ku shuku vu tsupaka komoci kutan kuna u lyaꞋi?
\q1 
\v 2 Ɗa baci kadanshi ka̱nu ka saꞋwai ku ka̱na̱ wu,
\q2 ko kadanshi ku una̱ u nu ko okpoi nu maza,
\q1 
\v 3 Gogo na maku ma̱va̱, ili i na va kuyaꞋan i ɗana,
\q2 adama ana vu isa ka̱cika̱nu.
\q1 vu uwa ta̱ tana ɗe ekiye a vuza yoku,
\q2 bana vu goyo ka̱cika̱nu a kelime ka̱ni.
\q2 vu oꞋusoi n ufolu ka̱u.
\q1 
\v 4 vu sa̱nka̱ ka̱ci ka̱ nu alavu,
\q2 ko agbaɗiki a̱ a̱shi a̱ nu.
\q1 
\v 5 Utuka̱ ka̱cika̱nu uteku tsuna manunu ma̱ tsu fa̱ta̱tsa̱ a ubuta̱ u maza,
\q2 uteku tsuna mesheun ma tsu fa̱ta̱tsa̱ ekiye a vuza vu kutambu.
\q1 
\v 6 Ka̱sukpa̱ vuza vu ukpa̱ɗi u piꞋisa
\q2 ubuta̱ wa̱ a̱riga̱nla̱.
\q1 
\v 7 I m mogono ba,
\q2 ko vuzagbayin,
\q2 ko vuza tsugono.
\q1 
\v 8 N nanai dem a tsu ɓolongu ta̱ ili i kulyaꞋa adama a̱ ka̱cika̱le,
\q2 a tsu foɓuso ta̱ a ayin vikyaꞋa adama a̱ lyushi.
\q1 
\v 9 Ali wana ɗai vi a kulyaꞋa kelime n ivaꞋin, avu vuza wonvoli?
\q2 Wanai ɗa vi a̱ kuɗa̱nga̱ alavu?
\q1 
\v 10 Megeshe kenu alavu, megeshe kenu agbaɗiki,
\q2 megeshe kenu mo oɓongu me ekiye adama ana vu uvuka.
\q1 
\v 11 Nanai ɗa unambi u kufa̱ba̱na̱ wu an vuza ma̱ga̱la̱ka̱,
\q2 ka̱ta̱ unambi kpamu u ta̱wa̱ wu tsu koboki.
\q1 
\v 12 Ka̱ka̱ra̱shi ko vuma gbani-gbani,
\q2 u tsu ka̱ra̱sa̱ ta̱ n kadanshi ka kavama a una̱ u ni,
\q1 
\v 13 Utsu yaꞋan ta̱ iyoci n a̱shi a̱ ni,
\q2 u ka̱na̱ kadanshi n izumgbi i ene a̱ni
\q2 a kuyaꞋan ulinga n ka̱jivu ka̱ ni u sokongi.
\q1 
\v 14 A̱ ka̱ɗu ka̱ni tana we a kusheshe ka gbani-gbani,
\q2 a ayin dem u ka̱na̱ ku kuɗa̱ngusa̱ vishili.
\q1 
\v 15 Adama a nannai atakaci i ta̱ a ku ka̱na̱ yi gogo lo.
\q2 m megeshe kenu ɗa i a ku una yi.
\b
\q1 
\v 16 Ili i ta̱li yi ta̱ lo ali i cindere, i na Vuzavaguɗu u iwain,
\q2 i na wi a ku kyala ba
\q2 kindi ku kugoyi na yo okpoi ili yi unata wa̱ ni.
\q1 
\v 17 Ele ɗa, kindi ku kugoyi,
\q2 n Kelentsu ka a uwa,
\q2 N ekiye aza munuka ma aza babu unushi.
\q1 
\v 18 N ka̱ɗu kana ka tsu sheshe ka gbani-gbani,
\q2 N kune ku kuyaꞋan kagbanigbani gogoꞋo,
\q1 
\v 19 M magan ma a uwa vuzana utsu dansa u kuna wa uwa,
\q2 N vuza na u tsu ɗa̱ngusa̱ vishili wi itoku i ni.
\s1 Udansuki adama tsugbani
\q1 
\v 20 Maku ma̱va̱, ɓa̱na̱ odoki a Dada nu
\q2 ka̱ta̱ kpamu vu ka̱sukpa̱ ku yotsongusu ka̱ a̱na̱vu ba.
\q1 
\v 21 Shiya le a̱ ka̱ɗu ka̱nu ayin dem,
\q2 shiya le e kuɗeku kunu.
\q1 
\v 22 Ayin ana baci vu walai, i ta̱ a kutono n avu,
\q2 ayin ana baci vu vaki, i ta̱ a ku inda wu,
\q2 ayin ana baci vu ɗa̱nga̱i, i ta̱ a kuyaꞋan kadanshi n avu.
\q1 
\v 23 Adama ana odoki a nampa ma̱kuni maꞋa,
\q2 kuyotsongusu ku nampa kpamu kutashi ku ɗa,
\q1 udansuki n ugbari kpamu
\q2 uye u wuma u ɗa,
\q1 
\v 24 wita̱ a ku kanza wu ubuta̱ u vuka vu gbani-gbani,
\q2 n ubuta̱ wu una̱ wu uyoꞋo u vuka vu vuza.
\q1 
\v 25 Ka̱ta̱ vu cikala ugaꞋin u vuka vu vuza yoku a̱ ka̱ɗu ka̱ nu ba,
\q2 ko kpamu vu ka̱sukpa̱ a̱shi a̱ ni a ɗika asuvu a̱ nu ba,
\q1 
\v 26 A tsu ciya̱ ta̱ kashakanlai n ikebe yi ilikulyaꞋa koci,
\q2 ama vuka vu vuza yoku tsu la̱nsa̱ ta̱ wuma u vuma.
\q1 
\v 27 Vuma wita̱ a kufuɗa ku kimba̱ a kina a̱ ma̱ka̱nga̱ ma̱ ni,
\q2 babu na motogu ma̱ni ma̱ kula̱?
\q1 
\v 28 Vuma wita̱ a kufuɗa ku wala a gaɗi va̱ a̱ga̱ruwa̱shi akina
\q2 ka̱ta̱ u kpa̱ɗa̱ ku kula̱ adasukpatsu a ene a̱ni?
\q1 
\v 29 Ta wi nanai u vuza na u vaki n vuka vu vutoku ni,
\q2 vuza na u yaꞋin nanai dem, wi a kulaka ba.
\q1 
\v 30 Uma a tsu neke koboki wono ba,
\q2 ɗa baci a cinai ni u yaꞋin uboki adama kambulu.
\q1 
\v 31 N nanai dem ɗa baci e reme ni, mayun ɗa u tsupa kucindere,
\q2 ko ɗa baci, u ku zuwa u namba uciyi u kpaꞋa uni ra̱ka̱.
\q1 
\v 32 Ama vuma na u vaki n vuka vu vuza yoku wi mayin ba,
\q2 a̱yi na baci de dem u yaꞋin nanai wu una ta̱ ka̱cika̱ni.
\q1 
\v 33 I ta̱ a ku lapai, ka̱ta̱ e nekei wono,
\q2 wono u na wa kukotso ba.
\q1 
\v 34 Adama ana cisheꞋe tsu tsu ɗengusa̱ ta̱ wupa u vali,
\q2 u tsu ka̱sukpa̱ ba makyan ma na wi a kutsupa.
\q1 
\v 35 Wi a ku isa katsupu ba,
\q2 babu ka̱bunda̱i ka kuneꞋe kana ka ku vaꞋanku wupa u ni ba.
\c 7
\s1 Udansuki adama tsugbani
\q1 
\v 1 Maku ma̱va̱, reme kadanshi ka̱va̱
\q2 ka̱ta̱ kpamu vu zuwa wila̱ u va̱ a̱ ka̱ɗu ka̱ nu.
\q1 
\v 2 Tono wila̱ u va̱, vi ta̱ a̱ ciya̱ wuma,
\q2 ere ku yotsongusu ku va̱ an maku ma ka̱shi ma̱ nu.
\q1 
\v 3 Shiya le ekiye a̱ nu,
\q2 ɗana le a magbaganla ma̱ ka̱ɗu ma̱ nu.
\q1 
\v 4 Dana ugboji a vu ɗa taku va̱,
\q2 ka̱ta̱ vu dana kpamu kuyeve kumaci ku nu,
\q1 
\v 5 i ta̱ a ku ere wu ubuta̱ u tsugbani,
\q2 n ubuta̱ u vuka vu vuza yoku vu na vi n una̱ wu uyoꞋo.
\q1 
\v 6 Kanna ko yoku mi a ku indana,
\q2 n tsu katusu ka kpaꞋa ka̱ va̱.
\q1 
\v 7 Ɗa me enei a̱ ka̱tsuma̱ ka za a babu kusheshe,
\q2 ɗa n zukai vuza yoku a̱ ka̱tsuma̱ ko kolobo,
\q2 ka̱ɗa̱nga̱ni koyoku ka na ki babu ma̱riki.
\q1 
\v 8 A̱yi nwalu a uye ugbayin ɗevu n ubuta̱ u na wi ida̱shi.
\q2 a nwalu a uye a kubana a kpaꞋa ku ni,
\q1 
\v 9 n kulivi, makyan mana kanna ki a̱ kuyikpa̱,
\q2 a makyan ma na ka̱yimbi ka kayin ka̱ gita̱i.
\q1 
\v 10 Ɗa u cinai ni,
\q2 u lapulai ka̱cika̱ni tsu kashakanlai o kufoɓuso tsuna u kuya̱nsa̱ yi.
\q1 
\v 11 A̱yi tana vuza motonu ɗa, kpamu n ugbamiwasuvu,
\q2 makyan dem ene a̱ ni i a ida̱shi a kpaꞋa ba.
\q1 
\v 12 Makyan mo yoku a uye, makyan mo yoku kpamu a̱ suvu a likuci,
\q2 ubuta̱ dem una uye u kpatalai, ta ɗe vi a kucinai.
\q1 
\v 13 Ɗa woɓongi ni,
\q2 n kindi ku ugoyi ɗa u danai ni.
\q1 
\v 14 <<Mi ta̱ n ka̱ɗiva̱ ka ida̱shi ma̱ta̱na̱ a kpaꞋa,
\q2 anna mi ta̱ a kushatangu uzuwakpani uva̱.
\q1 
\v 15 I ɗaɗa i zuwai ɗa mu uta̱i adama ana n gasa n avu,
\q2 n ciga ta̱ me ene wu, ɗa tana me enei nu na.
\q1 
\v 16 N pala ta̱ a̱ga̱da̱ a̱va̱
\q2 n arikinla a tsuzogu tsa aza Masar.
\q1 
\v 17 N bufangu ɗe ili ma̱gula̱ni a̱ga̱da̱ va̱,
\q2 n muru vu ma̱gula̱ni, n alosu koɓolo n sinamon.
\q1 
\v 18 Ta̱wa̱, tsu pana uyoꞋo wu ucigi, tsu panakpanai ali usana,
\q2 ta̱wa̱ tsu oɓongbonoi a̱ ka̱tsuma̱ ka maciganai.
\q1 
\v 19 Vali va̱ wi punu a kpaꞋa ba,
\q2 u yaꞋan ta̱ nwalu n daꞋangi.
\q1 
\v 20 U ɗika ta̱ ikebe ya a̱bunda̱i,
\q2 wi a kubono a kpaꞋa ba, sai kanna ka na wotoi u pecei.>>
\q1 
\v 21 Ɗa u kondoi le n a̱guma̱ a̱ni,
\q2 n una̱ wu uyoꞋo u ni ɗa u doroi ni.
\q1 
\v 22 Gogolo ɗa u tonoi ni
\q2 tsu kanaka kana a ku banka ubuta̱ u ku kiɗa,
\q1 tsu mesheun ma na mi a ka ɗikpangusu a kubana a maza.
\q2 
\v 23 Ubuta̱ u na kaya ka sovoi ni ali a̱ ka̱ɗu ka̱ni,
\q1 wita̱ lo tsu manunu mana mo moloko a ku uwa a maza,
\q2 a̱yi u yeve ana n wuma u ni u ɗa u ku tsupaka ba.
\q1 
\v 24 Gogo na, muku n va̱, panakai mu,
\q2 zuwai atsuvu i pana kadanshi ka̱ una̱ u va̱.
\q1 
\v 25 Ka̱ta̱ yu ushuku n icuꞋu i vuka vu nanlo,
\q2 u zuwa ka̱ɗu ka̱ ɗa̱ ka cikala kuyongo kuni ba,
\q2 ka̱ ta̱ i tono uye u ni ba.
\q1 
\v 26 Adama ana a̱yi ɗa wu una uma n a̱bunda̱i,
\q2 u zuwai uma n a̱bunda̱i ukpa̱
\q2 ali i kukece ba.
\q1 
\v 27 KpaꞋa ku ni uye u kubana a kpaꞋa ku ukpisa̱ uɗa,
\q2 u na u gida̱la̱ a kubana a kasaun.
\c 8
\s1 Una̱singai wu ugboji
\q1 
\v 1 panai, ugboji wita̱ a̱ meɗevile,
\q2 kuyeve a ku ɗengusa̱ ka̱la̱ka̱tsu ka̱ ni.
\q1 
\v 2 A nsasan, n uye,
\q2 a uɓon u na nsanji n gasai, talo u shamgbai.
\q1 
\v 3 a̱ ka̱kina̱ ku utsutsu u na u uwai a likuci,
\q2 a utsutsu u likuci a̱ meɗevile n ka̱la̱ka̱tsu kagbayin.
\q1 
\v 4 <<A̱ɗa̱ ali, a̱ ɗa̱ ɗa mi a meɗevile,
\q2 meɗevile ma̱ va̱ a u yabadem ɗa.
\q1 
\v 5 A̱ɗa̱ aza unambi u kusheshe, piꞋisai kuyaꞋan ugboji,
\q2 a̱ ɗa̱ alau, la̱nsa̱i kuyeve.
\q1 
\v 6 Zuwai atsuvu i pana, adama ana mita̱ a kudana ɗa̱ ili singai,
\q2 ili i na baci de dem n dansai i singai i ɗa.
\q1 
\v 7 Kadanshi kana n dansai mayun ɗa,
\q2 kagbanigbani, ili yu unata i ɗa a una̱ u a̱va̱.
\q1 
\v 8 Kadanshi ku una̱ u va̱ ra̱ka̱ kasingai kaꞋa,
\q2 koyoku ki punu ka na ki usokongi ba, ko a uwa.
\q1 
\v 9 Ra̱ka̱ vu le i ta̱ gaɗi u vuza kuyeve,
\q2 derere ɗa kpamu a ubuta̱ wa aza ana i n kuyeve.
\q1 
\v 10 Zagba odoki a̱ va̱, una̱ wa azurufa,
\q2 kuyeve kpamu una̱ u kazanariya kasingai,
\q1 
\v 11 adama ana ugboji u lata̱ idolu i singai tsuloboi,
\q2 ili i na vu laꞋi n kuciga ra̱ka̱, wi ku gisanku n a̱yi ba.
\b
\q1 
\v 12 <<Mpa, ugboji, mi ta̱ n ugboji,
\q2 mi ta̱ n kuyeve koɓolo n ma̱riki.
\q1 
\v 13 Wovon u Ka̱shile, u ɗaɗa vu iwan kagbanigbani,
\q2 ugbamukaci, n a̱ra̱ɗi, n uye u kagbanigbani.
\q2 n kadanshi ka kuya̱nsa̱, n iwan ta̱ kaꞋa.
\q1 
\v 14 Mita̱ n odoki n ugboji,
\q2 mi ta̱ n kuyeve, n utsura.
\q1 
\v 15 N ɓa̱nka̱ ta̱ ngono ubuta̱ u tsugono u le,
\q2 a yaꞋin a fada kpamu a zuwa odoki a singai.
\q1 
\v 16 N uɓa̱nki u va̱ uɗa ngono ra̱ka̱ mi a kulyaꞋa tsugono,
\q2 ta feu aza kelime n a yaꞋin afada i nanai.
\q1 
\v 17 N ciga ta̱ aza ana a cigai mu,
\q2 aza ana a̱ la̱nsa̱i mu ita̱ a̱ kuciya̱ mu.
\q1 
\v 18 Uciyi n tsugbayin wi ta̱ wa a̱va̱,
\q2 uciyi u babu uteku n wu usuɓi.mayun ɗa.
\q1 
\v 19 Ili i na vu ciya̱i wa̱ a̱ va̱ u laꞋa ta̱ kazanariya ka singai,
\q2 i laꞋa ta̱ azurufa a singai.
\q1 
\v 20 N wala ta̱ a uye wu usuɓi,
\q2 a uye u kamayun,
\q1 
\v 21 n neke uciyi wa aza ana a cigai mu,
\q2 n shatangu mpon le kpamu n uciyi.
\b
\q1 
\v 22 <<Mpa ɗa vuza vu ugiti vuna Vuzavaguɗu u gita̱i kuyaꞋan,
\q2 kafu u yaꞋan ili dem.
\q1 
\v 23 A yaꞋan mu ta̱ ali n ayin ugiti,
\q2 kafu u gita̱ wa aduniya.
\q1 
\v 24 A matsa mu ta̱ mala mu uga̱vi,
\q2 makyan mana babu a̱shi a̱ mini.
\q1 
\v 25 Kafu a yaꞋan nsansa,
\q2 ɗa a yaꞋan mu a ginda,
\q1 
\v 26 kafu uyaꞋan aduniya n akamba
\q2 ko kafu na utuka̱ kayala ku ugiti.
\q1 
\v 27 Mpa mi ta̱ lo ayin ana u yaꞋin gaɗi,
\q2 a na u pecei uteku u mini,
\q1 
\v 28 a na u yaꞋin eleshu gaɗi,
\q2 ɗa kpamu u zuwai uga̱vi wa nɗolu,
\q1 
\v 29 a na u zuwakai malaꞋa u teku,
\q2 adama ana ka̱ta̱ mini ma laza ubuta̱ u na a zuwa ni ba,
\q1 kpamu, a na u zuwai u teku wu uduniya.
\q2 
\v 30 Mpa ugboji mi ta̱ koɓolo n a̱yi, tsu kafuɗi ku ulinga.
\q1 mpa ɗa makyan dem u tsu pana u yoꞋo,
\q2 a yin tutu n tsu yaꞋan ta̱ ma̱za̱nga̱ n a̱yi.
\q1 
\v 31 Mi ta̱ ma̱za̱nga̱ n aduniya a̱ni ra̱ka̱,
\q2 mi ta̱ kpamu a kupana u yoꞋo vuma lima̱.
\b
\q1 
\v 32 <<Gogo na, a̱ɗa̱nga̱ni a va̱ panai kadanshi ka̱ va̱,
\q2 yaꞋin tsu na n danai, vi ta̱ tana a kuyaꞋan ma̱za̱nga̱.
\q1 
\v 33 Panai, odoki a̱ va̱ adama ana i gbojo,
\q2 ka̱ta̱ i iwan a ɗa ba.
\q1 
\v 34 Vuza vu una̱singai ɗa vuza na u panakai mu,
\q2 wi kashani utsutsu kanna dem,
\q2 a ku vana utsutsu u ku wala u va̱.
\q1 
\v 35 Adama ana vuza na baci dem u ciya̱i mu, u ciya̱ ta̱ wuma.
\q2 iyoci i kuciya̱ mapasa ma singai ubuta̱ u Vuzavaguɗu ɗa.
\q1 
\v 36 Ama vuza na baci dem u kpa̱ɗi kuciya̱ mu, u foro ta̱ ka̱cika̱ni,
\q2 vuza na baci de dem u iwain mu, u ciga ta̱ ukpa̱Ꞌa̱.>>
\c 9
\s1 Ugboji n tsulau
\q1 
\v 1 Ugboji u maꞋa ta̱ kpaꞋa ku ni
\q2 u sheꞋwei nshilya n cindere n ni.
\q1 
\v 2 U zuwai a kiɗai i nyama adama a̱ ka̱ɗiva̱, u foɓusoi ma̱kya̱n a̱ ni,
\q2 ɗa kpamu u foɓusoi ka̱ɗiva̱ ka̱ ni.
\q1 
\v 3 U suku ta̱ agbashi a̱ ni a̱ ma̱ci,
\q2 adama ana u ɗekushe a kusan ku u gaɗi a likuci.
\q1 
\v 4 <<Ka̱sukpa̱ a̱ ɗa̱ na yi aza ugboji ba.>>
\q2 kpatalai na,
\q2 wa aza unambi wu u ka̱ni wa asuvu.
\q1 
\v 5 <<Ta̱wa̱i i lyaꞋa ilikulya i va̱,
\q2 soꞋi ma̱kya̱n ma na n foɓusoi.
\q1 
\v 6 Ka̱sukpa̱ unambi u kusheshe, adama ana i ciya̱ wuma,
\q2 yaꞋin nwalu a uye wu u yeve.>>
\b
\q1 
\v 7 <<Yabadem na baci u dansukai vuza vu kugoyi, wi ta̱ a kuronoko ka̱cika̱ni kugoyi.
\q2 vuzana kpamu u dansuka vuza gbani-gbani, a̱yi ɗa u kuciya̱ mɓa̱la̱.
\q1 
\v 8 Ko kenu ka̱ ta̱ vu dansuka vuza vu kugoyi ba, adama ana wita̱ a ku iwan wu.
\q2 Ama vu dansuka baci vuza vu ugboji, a̱ yi tana wi ta̱ a kuciga wu.
\q1 
\v 9 Neke vuza vu ugboji odoki, ka̱ta̱ a̱yi tana udoku ugboji,
\q2 PiꞋisaka vuza vu usuɓi, ka̱ta̱ a̱yi tana udoku n kuyeve.
\q1 
\v 10 Wovon u Ka̱shile u ɗa u giti ugboji,
\q2 kpamu kuyeve ku Vuza ciɗa nanlo ɗaɗa kuyeve.
\q1 
\v 11 Adama a̱ va̱, ayin a̱ nu i ta̱ o ku doku kuyimkpa,
\q2 ka̱ta̱ o doku wu kpamu a̱ya̱ a wuma a̱ nu.
\q1 
\v 12 Vi baci nu ugboji, vi ta̱ nu ugboji adama a̱ ka̱cika̱nu,
\q2 ama, vi baci n kugoyi, a vu ɗa koci vi a ku takacika.>>
\q1 
\v 13 Kalau ka vuka, za kadanshi n a̱bunda̱i,
\q2 vuza vu unambi u kusheshe ɗa, u yeve ili ba.
\q1 
\v 14 U tsu da̱sa̱ngu ta̱ u tsutsu u kpaꞋa ku ni,
\q2 a kakuba ki ida̱shi ka̱ ni ku ugaɗi ka likuci,
\q1 
\v 15 a kuɗeke aza ana i a nwalu,
\q2 aza ana kusheshe ku le ki a ubuta̱ wu ulinga u le.
\q1 
\v 16 Utsu dana ta̱, <<A̱ɗa̱ aza unambi u kusheshe ta̱wa̱i na.>>
\q2 wa aza unambi wu uka̱ni u ka̱ɗu kpamu utsu dana ta̱.
\q1 
\v 17 <<Mini mu uboki ma tsu yokpo ta̱,
\q2 ilikulyaꞋa i na a tsu lyaꞋa usokongi wita̱ n uyoꞋo.>>
\q1 
\v 18 Ama aza ana a uwai ekiye a̱ ni, e yeve a na a̱kpisa̱ a ɗa i a ubuta̱ wa ba.
\q2 kpamu omoci a̱ ni, i ta̱ a̱ ku gida̱la̱ kubana ubuta̱ wi ida̱shi ya a̱kpisa̱.
\c 10
\s1 Ansa a Sulemanu
\p 
\v 1 Ansa a Sulemanu a ɗa na,
\q1 maku mu ugboji ma tsu zuwa ta̱ Dada ni ma̱za̱nga̱,
\q2 ama kalau ka maku, ili yu una̱mgbi u ka̱tsuma̱ i ɗa wa a̱na̱ku a̱ ni.
\q1 
\v 2 Uciyi una o ɓolongi a uye u gbanigbani, u tsu neke i li ba,
\q2 ama ida̱shi yu usuɓi u tsu utuka̱ ta̱ vuma ukpa̱.
\q1 
\v 3 Vuzavaguɗu wi a̱ kuka̱sukpa̱ vuza vu usuɓi a̱ ka̱tsuma̱ ka kambulu ba
\q2 ama u tsu sa̱nka̱ ta̱ kusheshe ka aza a gbani-gbani ku shana.
\q1 
\v 4 Tsurogo tsu tsu zuwa ta̱ vuma unambi,
\q2 ama kuyaꞋan ku ulinga ku tsu tuka̱ ta̱ n uciyi.
\q1 
\v 5 A̱yi na u ɓolongi ili i kashina n lyushi a̱yi ɗa vuza vu ugboji.
\q2 ama a̱yi na u latai a ayin a vikyaꞋa a̱yi ɗa vuza na u tsu tuka̱ n wono.
\q1 
\v 6 Una̱singai wita̱ a kaci ka vuza vu usuɓi,
\q2 ama u vuza gbani-gbani u tsu sokongu ta̱ u kuna u vishili u ni.
\q1 
\v 7 Kuciɓasa ku vuza vu usuɓi una̱singai u ɗa,
\q2 ama kula ku vuza gbani-gbani ki i ta̱ a̱ ku na̱mgba̱.
\q1 
\v 8 Vuza vu ugboji, a̱yi ɗa u tsu ushuku n odoki,
\q2 ama vuza kadanshi ka tsulau wi ta̱ a̱ ku na̱mgba̱.
\q1 
\v 9 Vuza na dem wi an nwalu a̱ ka̱tsuma̱ ku usuɓi, utsu yaꞋan ta̱ nwalu n ni m ma̱ta̱na̱.
\q2 ama vuza vu unambi usuɓi a tsu yeve yi ta̱.
\q1 
\v 10 Vuza na u tsu reme ka mayun, u tsu tuka̱ ta̱ n atakaci,
\q2 ama vuza na udanshi kamayun utsu tuka̱ ta̱ m ma̱ta̱na̱
\q1 
\v 11 Kadanshi ka vuza vu usuɓi ka̱shi ka̱ mini ma wuma maꞋa,
\q2 ama kadanshi ka vuza gbani-gbani ka tsu sokongu ta̱ u kuna u vishili u ni.
\q1 
\v 12 Tsurala tsu zuwa ta̱ vishili,
\q2 ama ucigi u tsu cinukpa ta̱ nu unushi ra̱ka̱.
\q1 
\v 13 Uma ugboji a tsu dansa ta̱ ka̱ ma̱riki,
\q2 ama uma a gbanigbani u gaꞋan ta̱ atakaci ka le.
\q1 
\v 14 Vuza vu ugboji u tsu ɓolongu ta̱ ku yeve,
\q2 ama una̱ u kalau u tsu tuka̱ ta̱ nu u kpa̱.
\q1 
\v 15 Udukuyan, mashilya maꞋa ma vuza vu uciyi,
\q2 ama unambi munuka maꞋa ma vu za vu unambi.
\q1 
\v 16 Katsupu ka kuyaꞋan kasingai kaɗa wuma,
\q2 ama katsupu ka vuza vu unushi ka ɗa atakaci.
\q1 
\v 17 A̱yi vuzana u tsu ushuku n ugbari n odoki, wi ta̱ a ku ciya̱ wuma,
\q2 ama a̱ yi vuzana u tsu inwan ugbari wi ta̱ a̱ kupuwa̱nka̱.
\q1 
\v 18 Vuza na dem u tsu sokongu tsurala, kayaꞋin ka uwa kaꞋa,
\q2 vuzana kpamu dem u tsu la̱nga̱sa̱ ula uma kalau kaꞋa.
\q1 
\v 19 Kadanshi ka yimkpa baci a̱ bunda̱i ɗa vuma u tsu ciya̱ unushi,
\q2 ama vuza vu ugboji ɗa baci vi, sai vu paɗa bini.
\q1 
\v 20 Kadanshi ka vuza vu usuɓi, ki ta̱ an azurufa ana a zagbai,
\q2 ama ka̱ɗu ka vuza gbani-gbani ki nu ugaꞋin ba ko kenu.
\q1 
\v 21 Kadanshi vuza vu usuɓi ku tsu lyaꞋatangu uma n a̱bunda̱i,
\q2 ama kalau ka tsu kuwa̱ ta̱ adama unambi wu usuɓi.
\q1 
\v 22 Una̱singai u Vuzavaguɗu u tsu tuka̱ ta̱ n uciyi,
\q2 ama ka̱bunda̱i ku ulinga ko tsu doku uciyi ba.
\q1 
\v 23 U kalau, kuyaꞋan ku ka gbani-gbani, ili yu ugulani u ɗai,
\q2 ama u vuza kuyeve, ugboji u tsu yokpo ta̱.
\q1 
\v 24 I na vu za gbani-gbani wi o wovon, i ɗa i kuciya̱i
\q2 ama i na vuza vu usuɓi u cigai i ɗaɗa a ku ciya̱.
\q1 
\v 25 Ayin a na baci kabatalikpau ka gbanigbani ka lazai, i o kudoku ku ene aza a gbanigbani ba,
\q2 ama vuza usuɓi u tsu shamgba ta̱ n utsura ali a kubana u teku.
\q1 
\v 26 Ka̱ta̱ vu zuwa korogo ka yaꞋanka wu ili ba,
\q2 ta lo wa ko okpo wu tsu mini ma kalam a anga ko kpamu tsu ka̱nga̱ a̱ a̱shi a̱ nu.
\q1 
\v 27 Wovon u Ka̱shile u tsu doku ta̱ wuma wu ugaɗi,
\q2 ama wuma u vuza gbani-gbani wi ta̱ gbati.
\q1 
\v 28 A̱pa̱ a vuza vu usuɓi ma̱za̱nga̱ maꞋa,
\q2 ama a̱pa̱ aza vuza gbani-gbani a̱ tsu tuka̱ n ili ba.
\q1 
\v 29 Uye u Vuzavaguɗu mashilya ma ku ere maꞋa u vuza vu usuɓi,
\q2 ama ili munuka i ɗa ubuta̱ wa aza kuyaꞋan ka gbani-gbani.
\q1 
\v 30 Aza usuɓi i ta̱ a kuciya̱ ukanji ayin tutu,
\q2 ama a̱ ku ka̱sukpa̱ aza gbani-gbani iɗika ya ba.
\q1 
\v 31 Aza usuɓi a tsu dansa ta̱ ugboji,
\q2 ama kelentsu kana ka tsu dansa a uwa ki ta̱ a kuyaꞋan ugbati.
\q1 
\v 32 Kelentsu ka vuza vu usuɓi ka yeve ta̱ i na i gaꞋin,
\q2 ama una̱ u vuza gbani-gbani, wi ni yoku ba sai kadanshi ka gbani-gbani koci.
\c 11
\q1 
\v 1 Vuzavaguɗu u tsu iwan ta̱ vuza kagisamkpatsu ka a uwa,
\q2 ama u tsu pana ta̱ uyoꞋo wa za agisamkpatsu a mayun.
\q1 
\v 2 A̱ra̱ɗi a̱ tsu tuka̱ ta̱ n wono,
\q2 ama vuza babu a̱ra̱ɗi vuza vu ugboji ɗa.
\q1 
\v 3 UgaꞋin wa aza kamayun a ka̱ɗu, u tsu tono ta̱ n ele,
\q2 ama aza unambi u kamayun a tsu una ta̱ ka̱cika̱le adama a ka gbani-gbani ke le.
\q1 
\v 4 Udukuyan u tsu yongo n ugaꞋin a kanna ka ku kiɗa ka afada ba,
\q2 ama ida̱shi yu usuɓi i tsu utuka̱ ta̱ vuma ubuta̱ wu ukpa̱.
\q2 
\v 5 U kuna wu usuɓi wa aza babu unushi u tsu tono a̱ n ele a uye u magaba,
\q2 ama aza a gbani-gbani a tsu yikpa̱ ta̱ adama ka a gbani-gbani ke le.
\q1 
\v 6 Usuɓi wa aza ka mayun a̱ɗa̱ u tsu utuka̱ le ta̱,
\q2 ama aza iyaꞋanshi m modoruko o tsu okpo le ta̱ maza.
\q1 
\v 7 Vuza gbani-gbani u tsu kuwa̱ ta̱ n kusheshe ku ni dem,
\q2 ka̱ta̱ a̱pa̱ a utsura a̱ ni ra̱ka̱ a̱ na̱mgba̱.
\q1 
\v 8 A̱ tsu utuka̱ ta̱ vuza vu usuɓi atakaci,
\q2 ka̱ta̱ a ɗa o bono u vuza gbani-gbani.
\q1 
\v 9 Aza gbani-gbani n una̱ u le u ɗa a tsu una a za le,
\q2 ama aza usuɓi a ubuta̱ u kuyeve ku le u ɗa a tsu laꞋaka.
\q1 
\v 10 Vuza vu usuɓi u laꞋaka ba ci, likuci i tsu i yaꞋan ta̱ ma̱za̱nga̱,
\q2 ɗa baci vuza gbani-gbani u kuwa̱i, uma a tsu yaꞋan ta̱ feu ma̱za̱nga̱.
\q1 
\v 11 Likuci i ci ciya̱ ta̱ tsugbayin adama una̱singai a uma usuɓi,
\q2 ama a tsu fa̱da̱ ta̱ likuci adama una̱ u uma a gbani-gbani.
\q1 
\v 12 Ukuna u tsulau u ɗa vu goyo toku nu,
\q2 vuza ugboji u tsu paɗa ta̱ bini.
\q1 
\v 13 Vuza kadanshi ka a̱bunda̱i n kula̱nga̱su u tsu sokongu kakuna ba.
\q2 Ama vuma vu usuɓi u su sokongu ta̱ ka kuna.
\q1 
\v 14 A ubuta̱ una wi babu vuza kelime, uduniya u tsu yikpa̱ ta̱,
\q2 ama ka̱bunda̱i ka aza kuneke odoki ka tsu tuka̱ ta̱ uduniya ida̱shi i ma̱ta̱na̱.
\q1 
\v 15 Ɗa baci vu ushuki ko okpo magan adama komoci vi ta̱ o ko kpo n wono,
\q2 ama vuzana u iwain wi ta̱ a kulaka.
\q1 
\v 16 Vuka vu usuɓi u su ciya̱ ta̱ tsugbayin,
\q2 ama aza asuvu a yali udukuyan u ɗa koci a ku ciya̱.
\q1 
\v 17 Vuma vu usuɓi u tsu ciya̱ ka̱ ta̱ ka̱cika̱ni u gaꞋin,
\q2 ama vuza gbani-gbani u tsu ronoko ta̱ ka̱cika̱ni atakaci.
\q1 
\v 18 Aza gbani-gbani a tsu ciya̱ ili i makara ba,
\q2 ama uma u usuɓi a tsu ciya̱ ta̱ uciyi u mayun.
\q1 
\v 19 Usuɓi usingai u tsu la̱nsa̱ka̱ ta̱ vuza wuma,
\q2 ama vuza na u dakaki kula̱nsa̱ ka gbani-gbani wi ta̱ a ku kuwa̱.
\q1 
\v 20 Vuzavaguɗu u tsu iwan ta̱ aza kusheshe ku gbani-gbani,
\q2 
\v 21 ama u tsu ka̱sukpa̱ ta̱ a aza usuɓi a laꞋaka.
\q1 
\v 22 UgaꞋin u vuka dem wi baci n ka̱ɗu kasingai ba,
\q2 wi ta̱ tsu makawani ma azanari a vunu vu ma̱gurusunu.
\q1 
\v 23 Kusheshe ku uma usuɓi, kuɗa kasingai,
\q2 ama kusheshe ka̱ a̱ɗu ka aza a gbani-gbani ku ɗa wupa ayin tutu.
\q1 
\v 24 Aza o yoku a tsu neke ta̱ kuneꞋe ba̱ri, ka̱ta̱ tana uciyi u le u yimkpa,
\q2 ama aza o yoku a tsu neke vuza ko kenu ba, ama ka̱ta̱ okpo nu unambi.
\q1 
\v 25 Vuza na u tsu neke ba̱ri, u ku okpo ta̱ vuza vu uciyi,
\q2 ɓa̱nka̱ otoku a̱ nu, a vu feu i ta̱ a ku ɓa̱nka̱ wu.
\q1 
\v 26 Uma a tsu yaꞋanka ta̱ vuzana u sokongi ishina una̱,
\q2 ama una̱singai u ɗa u vuza na u dengei.
\q1 
\v 27 Vuza na u la̱nsa̱i ugaꞋin u tsu ciya̱ ta̱ kasingai,
\q2 ama vuza na u la̱nsa̱i una̱mgbi, wi ta̱ a kuciya̱ u ɗa.
\q1 
\v 28 Vuza na dem u nekei ka̱ɗu wu udukuyan u ni wi ta̱ a ku yikpa̱,
\q2 ama vuza vu usuɓi wi ta̱ o kutopo uteku tsa a̱vuku a̱ ta̱ku a ka̱kina̱ ka mini.
\q1 
\v 29 Aza na a̱ tsu tuka̱ n atakaci a i kpaꞋa le, a u kotsushi utsu ciya̱ ili yi uka̱ni ba.
\q2 kpamu kalau ki ta̱ o ku okpo kagbashi ka vuza vu ugboji.
\q1 
\v 30 Usuɓi u neke ta̱ vuma wuma,
\q2 vuza na wi n ugboji, kpamu utsu isa ta̱ wuma.
\q2 
\v 31 Ɗa baci aza usuɓi a̱ ciya̱i u peci u le aduniya,
\q2 ni ɗa tamkpamu wo ku okpo wa aza unushi u gbani-gbani.
\c 12
\q1 
\v 1 Vuza na baci dem u cigai ugbari u ciga ta̱ kuyeve,
\q2 ama vuza na u iwain ugbari kalau ka.
\q1 
\v 2 Vuma vu usuɓi u tsu la̱nsa̱ ta̱ uɓa̱nki u Ka̱shile,
\q2 ama Ka̱shile ka tsu una ta̱ vuza vu kusheshe ku gbani-gbani.
\q1 
\v 3 Vuma u tsu ciya̱ katsura a ubuta̱ u ka gbani-gbani ba,
\q2 ama ma̱giti ma aza usuɓi ma ci shamgba ta̱ n utsura mayin.
\q1 
\v 4 Vuka vu usuɓi ili i ma̱za̱nga̱ i ɗa u vali ni,
\q2 ama vuka vu na vu tsu neke vali ni wono, u tsu okpo ta̱ an ketele ku ushami i kyamba i ni.
\q1 
\v 5 Kusheshe ka aza usuɓi kusheshe ku mayun ku ɗa,
\q2 ama odoki aza a gbani-gbani modoruko ma koci.
\q1 
\v 6 Odoki a vuza gbani-gbani o tsu okpo ta̱ an maza,
\q2 ama kadanshi ka vuza vu usuɓi ka tsu tuka̱ le ta̱.
\q1 
\v 7 A tsu una ta̱ vuza gbani-gbani ra̱kura̱ka̱,
\q2 ama kpaꞋa ku vuza vu usuɓi ki ta̱ a ku shamgba n utsura mayin.
\q1 
\v 8 A tsu cikpa ta̱ vuma vu usuɓi adama ugboji u ni,
\q2 ama a tsu goyo ta̱ vuza ka̱ɗu ka a gbani-gbani.
\q1 
\v 9 U ku laꞋa ta̱ n kugaꞋan n unambi u nu, vi a̱ kula̱nsa̱ ili i kulya,
\q2 An va ku bonoko ka̱cika̱nu avu ili i yoku i ɗa.
\q2 tana ili i na va kulyaꞋa i laꞋa ta̱ utsura u nu.
\q1 
\v 10 Vuma vu usuɓi u tsu la̱na̱ ta̱ ma̱ta̱na̱ mi ilikuzuwa i ni,
\q2 ama vuza gbani-gbani ili i tsu bankai ba
\q1 
\v 11 Kacimbi kana kaci yaꞋan ulinga ka̱u,
\q2 utsu yaꞋan ta̱ n ilikulya ya a̱bunda̱i,
\q2 tsulau tsu a̱ la̱nga̱sa̱ makyan adama ulinga u gbani.
\q1 
\v 12 Vuma gbani-gbani kusheshe ku ni ku ɗa u yaꞋan ka gbani-gbani,
\q2 ama vuza usuɓi u tsu sheshe ta̱ ka singai.
\q1 
\v 13 Kadanshi ka vuza gbani-gbani ka tsu okpoi ta̱ maza,
\q2 ama vuza vu usuɓi u tsu utuka̱ ta̱ ka̱cika̱ni a̱ ka̱tsuma̱ ka atakaci.
\q1 
\v 14 Katsupu ka vuma dem ki ta̱ a ubuta̱ u kadanshi ka̱ni n ulinga u ni,
\q2 wi ta̱ a̱ kuciya̱ ili i na i gaꞋin ni.
\q1 
\v 15 Kalau ke ce ene ta̱ uye u wuma u ni derere ɗa,
\q2 ama vuza vu ugboji u tsu pana ta̱ odoki.
\q1 
\v 16 Kalau ka tsu yotsongu ta̱ wupa u ni gogolo,
\q2 ama vuza vu ugboji u tsu keɓece koyoku ba.
\q1 
\v 17 Vuza na u tsu dansa kamayun wi ta̱ a kusala usuɓi,
\q2 ama kayaꞋin ka uwa ka tsu dansa ta̱ a uwa.
\q1 
\v 18 Kadanshi kana a yaꞋin babu kusheshe,
\q2 ka tsu tuka̱ ta̱ n usa̱n tsu usapi u kotokobi,
\q2 ama kelentsu ka vuza vu ugboji ka tsu tuka̱ ta̱ n ma̱ta̱na̱.
\q1 
\v 19 Kamayun ki ta̱ a kugeshe a li a kubana u teku,
\q2 ama u kuna wa uwa gogolo u tsu kotso ta̱.
\q1 
\v 20 Ukuna wa uwa u ɗa u tsu shatangu ka̱ɗu ka aza gbani-gbani,
\q2 ama ukuna u ma̱za̱nga̱ u ɗa wa aza ana a tsu neke odoki a singai.
\q1 
\v 21 Ko ka gbani-gbani ka kuciya̱ vuza vu usuɓi ba,
\q2 ama atakaci a̱bunda̱i a ɗa a kuciya̱ vuza gbani-gbani.
\q1 
\v 22 Vuzavaguɗu u tsu iwan ta̱ vuza kadanshi ka a uwa,
\q2 ama u tsu pana ta̱ uyoꞋo wa aza a na a ci yaꞋan kamayun.
\q1 
\v 23 Vuza vu usuɓi u tsu sokongu ta̱ kuyeve ku ni,
\q2 ama kalau ka tsu utuka̱ ta̱ n tsulau tsu ni e keteshe.
\q1 
\v 24 Ulinga wa a wuya utsu neke ta̱ utsura,
\q2 ama tsurogo ci ta̱ a kuzuwa wu vu okpo ka gbashi.
\q1 
\v 25 Una̱mgbi u ka̱ɗu, u tsu sa̱nka̱ ta̱ vuma ma̱za̱nga̱,
\q2 ama kadanshi ko odoki ka tsu zuwa ta̱ wuma ma̱za̱nga̱.
\q1 
\v 26 Vuza vu usuɓi u tsu neke ta̱ ka̱ja̱Ꞌa̱ ka̱ ni odoki a singai,
\q2 ama ulinga u vuza gbani-gbani u tsu zuwa ta̱ u puwa̱nka̱.
\q1 
\v 27 Vi baci korogo, vi a̱ kuciya̱ ili i na vi a̱ kula̱nsa̱ ba,
\q2 ama vu yaꞋan baci ulinga ka̱u, vi ta̱ a̱ kuciya̱ udukuyan.
\q1 
\v 28 Ukuna wu usuɓi, uye u wuma u ɗa,
\q2 nwalu a̱ ka̱tsuma̱ ku u ɗa u tsu banka vuza ukpisa̱ ba.
\c 13
\q1 
\v 1 Maku mu ugboji ma tsu isa ta̱ ugbari u Dada ni,
\q2 ama maku ma kugoyi ma tsu pana kadanshi ba.
\q1 
\v 2 Vuma vu usuɓi u ci lyaꞋa ta̱ ili a u tsura wu una̱ u ni,
\q2 ama vuma vu unambi wu usuɓi u tsu bonoko ta̱ a̱pa̱ a̱ ni a ubuta̱ u vishili.
\q1 
\v 3 YaꞋan ci coꞋo n ili i na vi a kudansa, adama ana vu isa wuma u nu.
\q2 Vuma vu na u kpa̱ɗa̱i kuyaꞋan cicoꞋo n kadanshi ka̱ ni ba,
\q2 u tsu uka ta̱ ka̱cika̱ni muna.
\q1 
\v 4 Vuza vu ukpa̱ɗi u tsu ciga ta̱ udukuyan,
\q2 ama u ci ciya̱ ili i yoku ba.
\q2 ama kayaꞋin ku ulinga
\q2 ki ta̱ a kuciya̱ ili i na wi a kuciga ba̱ri.
\q1 
\v 5 Vuza vu usuɓi u tsu iwan ta̱ ukuna wa a uwa,
\q2 ama vuza gbani-gbani u tsu yaꞋan ta̱ ili i wono n i kugoyi.
\q1 
\v 6 Usuɓi u tsu ere ta̱ vuza vu babu unushi,
\q2 ama ka gbani-gbani ka tsu vakangu ta̱ vuza vu u nushi.
\q1 
\v 7 Vuza yoku utsu ɗika ta̱ ka̱cika̱ni vuza vu uciyi ɗa, kpamu tana wi n ili ba,
\q2 vuza yoku u ɗika ta̱ ka̱cika̱ni a̱yi vuza vu unambi ɗa,
\q2 kpamu tana a̱yi vuza vu uciyi ɗa ka̱u.
\q1 
\v 8 Uciyi u vuma wita̱ a kufuɗa ku isa wuma u ni,
\q2 ama vuza vu unambi babu vuza na u tsu gbandarasa yi.
\q1 
\v 9 Kutashi ka aza usuɓi ku tsu akana ta̱ ka̱u,
\q2 ama kutashi ka aza gbani-gbani u kimushi u ɗa u ci yaꞋan.
\q1 
\v 10 Ugbamukaci vishili vuɗa utsu tuka̱ koci,
\q2 ama a̱ tsu ciya̱ ta̱ ugboji ubuta̱ wa aza ana a tsu pana odoki.
\q1 
\v 11 Udukuyan u na a̱ ciya̱i n uye usingai ba, u tsu puwa̱nka̱ ta̱ gogoꞋo,
\q2 ama vuza na de dem u ɓolongi ikebe kenu kenu i tsu ka̱na̱ ta̱ kudokusu.
\q1 
\v 12 Ku zuwa ku ka̱ɗu kuna a takpai a kubana kelime ku tsu zuwa ta̱ ka̱ɗu ka̱ ka̱na̱ mɓa̱la̱.
\q2 ama mali mana a̱ ciwa̱ta̱ngi mita̱ tsu maɗanga ma wuma.
\q1 
\v 13 Vuza na baci de dem u goyoi odoki wita̱ a ku saꞋawa odoki a̱ni,
\q2 ama vuzana baci de dem u tonoi odoki a wita̱ a̱ kuciya̱ katsupu.
\q1 
\v 14 Kuyotsongu ku vuza vu ugboji, kuɗolu ku mini ma wuma ma a,
\q2 vuza na utsu bonoko vuma a ubuta̱ u maza mu ukpa̱.
\q1 
\v 15 Kuyeve ku singai kutsu tuka̱ ka̱ ta̱ mapasa ma singai,
\q2 ama uye wa a za gbani-gbani wi ta̱ n utsura.
\q1 
\v 16 Vuza vu ugboji u ci yeve ta̱ ili i na wi a kuyaꞋan,
\q2 ama kalau ka tsu yotsongu ta̱ tsulau cini e keteshe.
\q1 
\v 17 Kalingata ka gbani-gbani ka tsu uwa ta̱ atakaci,
\q2 ama kalingata ka mayun ka tsu tuka̱ ta̱ n ma̱ta̱na̱.
\q1 
\v 18 Vuza na baci de dem u iwain kushuku n odoki, u tsu okpo ta̱ n wono n unambi,
\q2 ama vuzana baci dem wu ushuki n odoki utsu ciya̱ ta̱ tsugbayin.
\q1 
\v 19 Ili i singai i ɗa vuma u ciya̱ ili i na u kuɓa̱nka̱ ka̱cika̱ni,
\q2 alau a tsu iwan ta̱ ku ka̱sukpa̱ ka gbani-gbani.
\q1 
\v 20 A̱ yi na wi nwalu koɓolo n aza ugboji
\q2 utsu doku ta̱ n ugboji,
\q2 ama ka̱ja̱Ꞌa̱ ka a lau wita̱ a kulyaꞋa kelime n ku na̱mgba̱.
\q1 
\v 21 Ka gbani-gbani ko tsu tono ta̱ aza unushi,
\q2 ama una̱singai u ɗa katsupu ka vuza vu usuɓi.
\q1 
\v 22 Vuma vu usuɓi wita̱ a̱ kuciya̱ udukuyan, ali u ka̱sukpa̱ka̱ ntsukaya n ni,
\q2 ama udukuyan wa aza unushi wita̱ o ku okpo wa aza usuɓi.
\q1 
\v 23 Kashina ka vuza vu unambi i ta̱ a kufuɗa kuneke ilikulya n a̱bunda̱i,
\q2 ama unambi u kamayun ka tsu pura̱ngu ta̱ uɗa ra̱ka̱.
\q1 
\v 24 A̱ yi na utsu gbara maku ma̱ ni ba, u ciga ma ba,
\q2 ama a̱yi na u cigai maku ma̱ ni u tsu gbara ta̱ maku ma̱ ni mayin.
\q1 
\v 25 Vuma vu usuɓi u tsu lyaꞋa ta̱ ilikulya ali u cuwa̱,
\q2 ama vuma gbani-gbani, n kambulu kaꞋa utsu yongo ayin tutu.
\c 14
\q1 
\v 1 Vuka vu ugboji vu tsu maꞋa ta̱ kpaꞋa ku ni,
\q2 ama kalau ka tsu fa̱da̱ ta̱ kpaꞋa ku ni n ekiye a̱ ni.
\q1 
\v 2 Vuza na u tsu yaꞋan kamayun a̱ yi ɗa u tsu pana wovon u Ka̱shile,
\q2 ama a̱ yi vuza vu modoruko kugoyo ku ɗa u tsu goyoi.
\q1 
\v 3 Kadanshi ka kalau mashashau ma a kucina̱ ku ni,
\q2 ama kadanshi ka vuza vu ugboji ka tsu ere yi ta̱.
\q1 
\v 4 Ubuta̱ u na wi babu anaka a vicimba, teɗai a̱ kuciya̱ ilikulyaꞋa?
\q2 Ama ubuta̱ u na wi n obomburon a vicimba, i ta̱ a̱ kuciya̱ ilikulya ya a̱bunda̱i.
\q1 
\v 5 Ngan n vuza vu usuɓi, mayun ɗa.
\q2 ama vuza vu ngan ma a uwa, u tsu ka̱ra̱ka̱ ta̱ n a uwa.
\q1 
\v 6 Vuza kugoyi u tsu la̱nsa̱ ta̱ ugboji ama u su ciya̱ ba,
\q2 ama kuyeve ki na atakaci u keyevi ba.
\q1 
\v 7 YaꞋan daꞋangi n kalau,
\q2 adama ana wi n ili i na wa ku yotsongu ba.
\q1 
\v 8 Ugboji u keyevi u ɗaɗa u yeve uye wa nwalu n ni,
\q2 ama tsulau tsu kalau tsu tsu vakangi ta̱.
\q1 
\v 9 Kalau ka tsu yaꞋan ta̱ ugulani n unushi,
\q2 ama vuza vu usuɓi n ka̱ɗu ka u tsu folono a cinukpa kai unushi.
\q1 
\v 10 Ka̱ɗu dem ke yeve ta̱ una̱mgbi u ka̱tsuma̱ u ni,
\q2 kpamu babu vuzana u kufuɗa ku yeve ma̱za̱nga̱ ma̱ ni.
\q1 
\v 11 KpaꞋa ku vuza gbani-gbani ki ta̱ a ku fa̱da̱,
\q2 ama kpaꞋa ku vuza vu usuɓi ki ta̱ o kutopo.
\q1 
\v 12 Ili i na vuma u sheshei ku dana i ɗa uye u singai,
\q2 wi ta̱ a kubanka yi ukpa̱.
\q1 
\v 13 Ko a ka̱tsuma̱ ki izoshi, gaꞋan ba una̱mgbi u ka̱tsuma̱ wi ta̱ punu.
\q2 ma̱za̱nga̱ ma laza baci, una̱mgbi u ka̱tsuma̱ wi ta̱ punu.
\q1 
\v 14 Vuma gbani-gbani a tsu tsupai ki ta̱ n ka gbani-gbani ka̱ ni,
\q2 vuza singai kpamu a tsu tsupai ki ta̱ n kasingai ka̱ ni.
\q1 
\v 15 Kalau ka tsu ushuku ta̱ n ili dem,
\q2 ama vuza vu ugboji u tsu indana ta̱ mayin kafu u yaꞋan ili i yoku.
\q1 
\v 16 Vuma vu ugboji, utsu pana ta̱ wovon u Ka̱shile,
\q2 ama kalau ka tsu yaꞋan ta̱ ili gogoꞋo babu cicoꞋo.
\q1 
\v 17 Vuza vu wupa u tsu yaꞋan ta̱ kakuna n tsulau,
\q2 ka̱ta̱ a iwan vuza kusheshe ku gbani-gbani.
\q1 
\v 18 Vuza vu unambi u kusheshe u tsu ciya̱ ta̱ ili u teku u tsulau u ni,
\q2 ama vuza vu usuɓi katsupu ka̱ni kuyeve ku ɗa.
\q1 
\v 19 Mayun vuza gbani-gbani wi ta̱ a̱ ku kuɗa̱ngu e kelime ka vuza vu usuɓi,
\q2 vuza ka gbani-gbani kpamu a utsutsu u vuza vu usuɓi.
\q1 
\v 20 Babu vuza na wi a kuciga vuza vu unambi,
\q2 ama vuza vu uciyi wi ta̱ n a̱ja̱Ꞌa̱ n a̱bunda̱i.
\q1 
\v 21 A̱yi vuzana u goyoi vutoku ni, u yaꞋan ta̱ unushi,
\q2 ama vuza vu una̱singai u ɗa vuzana u ɓa̱nka̱i vuza vu unambi.
\q1 
\v 22 Vuza na u tsu foɓuso ka gbani-gbani, uye u ɗa wi a̱ ku ka̱sukpa̱ ba?
\q2 Ama ucigi n usuɓi wi ta̱ o ku okpo u vuzana wi o kufoɓuso ili i singai.
\q1 
\v 23 YaꞋan ulinga vi ta̱ ili i wuma,
\q2 ama vu da̱sa̱ngu baci a kadanshi vi ta̱ o ku okpo vuza vu unambi.
\q1 
\v 24 Katsupu ka vuza vu ugboji udukuyan u ɗa,
\q2 ama katsupu ka kalau tsulau tsu ɗa.
\q1 
\v 25 Vuza kamayun u ciꞋisa ta̱ wuma,
\q2 ama ka yaꞋan ka uwa za modoruko ɗa.
\q1 
\v 26 A̱yi vuzana wi n wovon u u Vuzavaguɗu wi ta̱ a̱ kuciya̱ ida̱shi i ma̱ta̱na̱,
\q2 kpamu Vuzavaguɗu wi ta̱ o ku okpo ubuta̱ u kusheɗeku u muku n ni.
\q1 
\v 27 Wovon u Vuzavaguɗu u ɗaɗa ubuta̱ u wuma,
\q2 u ɗa u ku zuwa vuma u pasa maza mu u kpa̱.
\q1 
\v 28 Tsugbayin tsu mogono tsu ɗaɗa ka̱bunda̱i ka uma a na wi na a ɗa,
\q2 ama uma i lo baci ba, tsugono gbani ɗa.
\q1 
\v 29 Vuma na u tsu na̱mgba̱ ka̱tsuma̱ ba, wi ta̱ n kuyeve,
\q2 ama vuza vu una̱mgbi u ka̱tsuma̱ u tsu tuka̱ ta̱ tsulau tsu ni e keteshe.
\q1 
\v 30 Ka̱ɗu ki ida̱shi ka̱ tsu neke ta̱ wuma i kyamba,
\q2 ama cisheꞋe tsu tsu shamatangu ta̱ etele.
\q1 
\v 31 A̱yi vuza na u doroi vuza vu unambi, u goyo ta̱ Vuzavaguɗu,
\q2 ama vuza na baci de dem u ɓa̱nka̱i vuza vu unambi, u cikpa ta̱ Ka̱shile.
\q1 
\v 32 A za gbani-gbani, e le ɗa a tsu vakangu ka̱cikele n ka gbani-gbani ke le,
\q2 ama aza usuɓi a tsu ere ta̱ ka̱cikele n ka singai ke le.
\q1 
\v 33 Ugboji wi ta̱ ida̱shi u vuza kuyeve dem,
\q2 a li a̱ ka̱tsa̱ma̱ ka wuma u alau feu u tsu yotsongu ta̱ ka̱cika̱ni.
\q1 
\v 34 Usuɓi u tsu neke ta̱ uduniya tsugbayin,
\q2 ama u nushi u tsu neke ta̱ uduniya wono.
\q1 
\v 35 Mogono ma tsu pana ta̱ u yoꞋo u kagbashi ku ugboji,
\q2 ama wupa u ni wi ta̱ ubuta̱ u vuza na u tsu yaꞋan ili wono.
\c 15
\q1 
\v 1 Wushuki u singai u tsu ta̱na̱ta̱ngu ta̱ ka̱ɗu,
\q2 ama kadanshi ku usuɗukpi ka tsu ɗa̱ngusa̱ ta̱ ka̱ɗu.
\q1 
\v 2 Kelentsu ka vuza vu ugboji ke tsu neke ta̱ kuyeve,
\q2 ama una̱ u kalau u tsu tsuwa̱n tsulau.
\q1 
\v 3 A̱shi a Vuzavaguɗu i ta̱ a ubuta̱ dem,
\q2 a kinda aza a singai n aza a gbani-gbani.
\q1 
\v 4 Kelentsu kana ka̱ tsu dansa kasingai, ki ta̱ u teku tsu maɗanga ma wuma,
\q2 ama kelentsu ka a uwa ka tsu una ta̱ ayinviki asingai.
\q1 
\v 5 Kalau ka tsu goyo ta̱ ugbari u Dada ni,
\q2 ama vuzana dem u tsu zuwa atsuvu u pana odoki, vuza vu ugboji ɗa.
\q1 
\v 6 KpaꞋa ka aza usuɓi ki ta̱ n uciyi wa̱ bunda̱i,
\q2 ama uciyi u vuza gbani-gbani u tsu tuka̱ le ta̱ n atakaci.
\q1 
\v 7 Una̱u u vuza vu ugboji u tsu dansa ta̱ u kuna u kuyeve,
\q2 ama ka̱ɗu ka kalau ka tsu yaꞋan nanai ba.
\q1 
\v 8 Vuzavaguɗu u tsu iwan ta̱ alyuka a vuza gbani-gbani.
\q2 Ama kavasa ka vuza singai ka tsu zuwai ta̱ ma̱za̱nga̱.
\q1 
\v 9 Vuzavaguɗu u tsu iwan ta̱ uye u uma a gbani-gbani,
\q2 ama u ci ciga ta̱ aza na a tsuyaꞋan kasingai.
\q1 
\v 10 Ɗa baci vu nusai, mayun ɗa a takacika wu,
\q2 a̱yi na u iwain kulapulu wita̱ a ku kuwa̱.
\q1 
\v 11 Ukpa̱ n munuka mi ta̱ a ubuta̱ u Ka̱shile,
\q2 teɗai tamkpamu a̱ɗu a uma a̱ lima̱.
\q1 
\v 12 Vuza vu kugoyi u tsu ciga a dansukai ba,
\q2 u tsu bana u vuza vu ugboji ba.
\q1 
\v 13 Ka̱ɗu ka̱ ma̱za̱nga̱ ka̱ tsu tuka̱ ta̱ n i meshe,
\q2 ama una̱mgbi u ka̱ɗu ka̱tsu una ta̱ ayinviki.
\q1 
\v 14 Uma ugboji a tsu la̱nsa̱ ta̱ kuyeve,
\q2 ama ilikulyaꞋa i kalau i ɗa ɗa tsulau.
\q1 
\v 15 Wuma wa aza unambi ra̱ka̱ wi ta̱ tukpa n atakaci,
\q2 ama a̱ɗu aza ma̱za̱nga̱ a makyan dem ita̱ a̱ ka̱tsuma̱ ka kupana uyoꞋo.
\q1 
\v 16 U lata̱ vu okpo n unambi n wovon u Vuzavaguɗu,
\q2 ana va kuciya̱ udukuyan wa̱ a̱bunda̱i koɓolo n atakaci.
\q1 
\v 17 U lata̱ vu lyaꞋa tsuwaꞋa tsu babu mkpaɗi ucigi de wi baci lo,
\q2 ana va ku takuma i nyama i singai tsurala ci baci lo.
\q1 
\v 18 Vuza vu usuɗukpi u ka̱ɗu u tsu ɗa̱ngusa̱ ta̱ vishili,
\q2 
\v 19 Uye u vuza vu wonvoli tukpa ɗa u ɗa wi n awana,
\q2 ama uye u vuza vu usuɓi a̱ ka̱ɗu uba̱rukpi uɗa wi.
\q1 
\v 20 Maku mu ugboji u tsu zuwa ta̱ esheku a̱ ni u pana uyoꞋo
\q2 ama kalau ka tsu goyo ta̱ a̱na̱ku ni.
\q1 
\v 21 Tsulau ili i ma̱za̱nga̱ i kajarishi i ɗa,
\q2 ama vuza na wi n kuyeve u tsu yaꞋan ta̱ ili ni derere.
\q1 
\v 22 Ɗa baci odoki i lo ba, ka kuna ka tsu na̱mgba̱ ta̱
\q2 ama n odoki a̱bunda̱i, a tsu ciya̱ ta̱ u lyaꞋi.
\q1 
\v 23 Yaba dem u tsu pana ta̱ uyoꞋo u wu ushuki u kadanshi kasingai,
\q2 ili singai i ɗa a yaꞋan kadanshi ka singai a ayin ana agaꞋin.
\q1 
\v 24 Uma ugboji a tsu tono ta̱ uye u na u kubanka le ubuta̱ u wuma,
\q2 adama ana wu utuka̱ le a ubuta̱ wu ukpa̱.
\q1 
\v 25 Vuzavaguɗu u tsu fa̱da̱ ta̱ kpaꞋa ku vuza vu ugbamukaci,
\q2 ama u tsu kanza ta̱ kureꞋe ku kagapa.
\q1 
\v 26 Vuzavaguɗu u tsu iwan ta̱ kusheshe ku vuza gbani-gbani,
\q2 ama u tsu yaꞋan ta̱ ma̱za̱nga̱ n kadanshi ka a singai.
\q1 
\v 27 Vuza kalyaꞋa, u tsu ronoko to kpaꞋa ku ni atakaci,
\q2 ama a̱yi vuza na u iwain kalyaꞋa wi ta̱ a kuyongo n wuma.
\q1 
\v 28 Ka̱ɗu ka vuza vu usuɓi ka tsu sheshe ta̱ kafu kushuku kadanshi,
\q2 ama kelentsu ka vuza gbani-gbani ka tsu dansa ta̱ ka gbani-gbani.
\q1 
\v 29 Vuzavaguɗu u tsu yongo ta̱ daꞋangi n vuma gbani-gbani,
\q2 ama u tsu pana ta̱ kavasa ka vuma vu usuɓi.
\q1 
\v 30 Imeshi i tsu zuwa ta̱ vuma u yaꞋan ma̱za̱nga̱,
\q2 kpamu arabali a singai a tsu tuka̱ ta̱ n ma̱ta̱na̱ i kyamba.
\q1 
\v 31 Vuza na dem u pana odoki a wuma,
\q2 wi ta̱ o kuyongo a̱ ka̱tsuma̱ ka aza ugboji.
\q1 
\v 32 Vuza na dem u iwain ugbari, ka̱cika̱ni kaꞋa u goyoi,
\q2 ama vuza na baci de dem wu ushuki n kulapu, wi ta̱ a ku ciya̱ kuyeve.
\q1 
\v 33 Wovon u Ka̱shile kuyotsongu su ku ugboji ku ɗa,
\q2 kpamu sai vu goyo ka̱cika̱nu, yeve ka̱ta̱ vu ciya̱ tsugbayin.
\c 16
\q1 
\v 1 Kusheshe ku ka̱ɗu ku vuma ku ɗa,
\q2 ama ku ushuku,
\q2 ku Vuzavaguɗu ku ɗa.
\q1 
\v 2 E kene ku vuma, ili i na u yaꞋin dem derere ɗa,
\q2 ama Vuzavaguɗu ɗa kashatangi.
\q1 
\v 3 Zuwa ka Vuzavaguɗu ulinga u nu,
\q2 ofoɓuso a̱ nu tana i ta̱ a̱ kuciya̱ ulyaꞋi.
\q1 
\v 4 Ili i na Vuzavaguɗu u yaꞋin dem derere ɗa,
\q2 ko vuza gbani-gbani adama a kanna ka atakaci.
\q1 
\v 5 Vuzavaguɗu u tsu iwan ta̱ vuza na de dem wi n ugbamukaci
\q2 we a̱ ku ka̱sukpa̱ le a laꞋaka ubuta̱ wa atakaci ba.
\q1 
\v 6 A ubuta̱ wu ucigi n kuyaꞋan kasingai, a tsu cinukpaka ta̱ vuma u nushi,
\q2 kpamu ubuta̱ wovon u Vuzavaguɗu,
\q2 vuma u tsu katsukpa ta̱ ka gbani-gbani.
\q1 
\v 7 Makyan ma na vu yaꞋin ili i na Vuzavaguɗu wi a kuciga,
\q2 vi ta̱ a kufuɗa kubonoko irala i nu yo okpo a̱ja̱Ꞌa̱.
\q1 
\v 8 U laꞋa ta̱ n kugan vu ciya̱ kenu a uye u singai,
\q2 ana va ku ɓolongu n a̱bunda̱i n uye u kalyaꞋa.
\q1 
\v 9 Vuma u tsu sheshe ta̱ a̱ ka̱ɗu ka̱ ni,
\q2 ama Ka̱shile ka ka tsu shatangu.
\q1 
\v 10 Kadanshi a una̱ u mogono ki ta̱ tsu a kaka a̱ Ka̱shile,
\q2 ayin dem u tsu kiɗa ta̱ a fada derere.
\q1 
\v 11 Vuzavaguɗu u ciga ta̱ kagisamkpatsu ka singai,
\q2 ka̱ta̱ kpamu ka wina dem ko okpo derere.
\q1 
\v 12 Ngono n tsu iwan ta̱ ka gbani-gbani,
\q2 adama ana ka singai kaɗa ka tsu zuwa tsugono tsu tsurukpa.
\q1 
\v 13 Mogono ma tsu pana ta̱ uyoꞋo u kadanshi ka singai,
\q2 u tsu ciga ta̱ aza kudansa kamayun ka̱u.
\q1 
\v 14 Wupa u mogono u kutuka̱ n ukpa̱ u ɗa,
\q2 ama vuza na wi n ugboji u tsu yaꞋan ta̱ moloko mana u ta̱na̱ta̱ngu mogono ka̱ɗu.
\q1 
\v 15 Kasingai ka mogono tsu keleshu kaꞋa kana ka tsu tuka̱ m mini ma gaɗi n lyushi,
\q2 wuma wi ta̱ punu.
\q1 
\v 16 U laꞋa ta̱ kugaꞋan vu ciya̱ ugboji, ana va kuciya̱ kazanariya,
\q2 u laꞋa ta̱ n kugaꞋan vu zagba kuyeve ana vaku zagba azurufa.
\q1 
\v 17 Uye u vuza vu usuɓi u tsu katsukpa ta̱ ka gbani-gbani,
\q2 vuzana u lapulai uye u ni, wuma u ni uɗa wi e ku ere.
\q1 
\v 18 Ugbamukaci u tsu tuka̱ ta̱ n ukpa̱,
\q2 kugoyi kpamu ku tsu vakangu ta̱ vuza.
\q1 
\v 19 U laꞋa ta̱ vo okpo vuza vu unambi vuza vu usuɓi,
\q2 ana va ku okpo a̱ ka̱tsuma̱ ka aza ugbamukaci, ali na vu ciya̱ ili a̱ ka̱tsuma̱ ke le.
\q1 
\v 20 A̱yi na dem wu ushuki n odoki, wi ta̱ a ku laꞋa ka,
\q2 vuza vu una̱singai u ɗa a̱ yi na wu ushuki n Vuzavaguɗu.
\q1 
\v 21 Vuza vu ugboji a tsu ɗekei ta̱ vuza kuyeve,
\q2 adama ana kadanshi ku uyoꞋo ka ɗaɗa uma a tsu laꞋa n ku ciga.
\q1 
\v 22 Ugboji ka̱shi ka vuma ka a ubuta̱ wa aza ana i nu ɗa,
\q2 ama tsulau tsu tsu tuka̱ ta̱ alau n atakaci.
\q1 
\v 23 Vuma vu ugboji u tsu sheshe ta̱ kafu u dansa,
\q2 ka̱ta̱ tana ka danshi ka̱ ni ka̱ ciya̱ wu ushuki.
\q1 
\v 24 Kadanshi ku uyoꞋo ka tsu yaꞋan ta̱ an kabashi ki ishigi,
\q2 n uyoꞋo a̱ ka̱ɗu, a̱ ku tuka̱ n ma̱ta̱na̱ i kyamba.
\q1 
\v 25 A kene ku vuma, wi ta̱ n uye u na u laꞋi n mayin,
\q2 ama a ukocishi, ukpa̱ u ɗa.
\q1 
\v 26 Kambulu ka tsu zuwa ta̱ vuza zamalinga u dakaka u linga,
\q2 adama ana u ciga ta̱ u cuwa̱ta̱ngu ka̱cika̱ni.
\q1 
\v 27 Vuma gbani-gbani u tsu sheshe ta̱ kuyaꞋan kagbani-gbani,
\q2 kadanshi ka̱ ni kpamu ka tsu ka̱na̱ ta̱ ku tasa a na akina.
\q1 
\v 28 Vuza vu babu kamayun u tsu ɗa̱ngusa̱ ta̱ vishili,
\q2 vuza kuyun u tsu pece ta̱ a̱ja̱Ꞌa̱ ni ana i ɗeɗevu.
\q1 
\v 29 Aza kavama, a tsu doro ta̱ a̱ za̱ ni,
\q2 a li u vakangi ubuta̱ u wa atakaci.
\q1 
\v 30 A̱ yi na u tsu yaꞋan iyoci n a̱shi, modoruko maꞋa wi a kuciga kuyaꞋan,
\q2 vuza na u tsu yaꞋan iyoci n una̱ uni, ka gbani-gbani kaꞋa wi a kuciga ku yaꞋan.
\q1 
\v 31 Ka̱nji ka̱ri, okokolo a tsugbayin a ɗa,
\q2 katsupu kaꞋa a wuma u vuza vu usuɓi.
\q1 
\v 32 U lata̱ n kugaꞋan vu okpo vuza vu u ka̱ni u ka̱ɗu, ana va ku okpo vuza vu utsura,
\q2 u laꞋa ta̱ kpamu n kugaꞋan vu fuɗa ka̱cika̱ni, u laꞋa u likuci.
\q1 
\v 33 Uma a tsuyaꞋan ta̱ kazagba adama ana e yeve i na i gaꞋin,
\q2 ama Vuzavaguɗu a̱ yi ɗa ka zagbi.
\c 17
\q1 
\v 1 U laꞋa ta̱ n kugaꞋan vu lyaꞋa tsuwa babu kusan n ka̱ɗu ida̱shi
\q1 an va kulyaꞋa tsuwa tsu ka̱ɗiva̱ a kpaꞋa ku vishili.
\q1 
\v 2 Kagbashi ku ugboji, ki ta̱ a kulyaꞋa tsugono
\q2 a kpaꞋa ku maku ma na ma tsu tuka̱ n wono,
\q2 ali u ciya̱ upecu wi ili yi uka̱ni derere tsu vuza te punu a kpaꞋa ka.
\p 
\v 3 Azanariya n azurufa n akina a tsu kondo le,
\q2 ta Vuzavaguɗu u tsu kondo ka̱ɗu nannai.
\q1 
\v 4 Vuza gbani-gbani, u tsu zuwaka ta̱ atsuvu wi ili i gbani-gbani,
\q2 kayaꞋin ka uwa ka tsu bonoko ta̱ n asuvu a̱ ni u vuza na u tsu dansa u kuna u kavama.
\q1 
\v 5 Vuza na baci de dem ugoyi vuza vu unambi, u shika ta̱ Ka̱shile ka na ka yaꞋin ni,
\q2 vuza na u yaꞋin ma̱za̱nga̱ adama una̱mgbi u vutoku wi a kulaka ubuta̱ wa atakaci ba.
\q1 
\v 6 U gaꞋin wu nkoshi ntsukaya n ɗa,
\q2 ugaꞋin u muku kpamu i sheku i le i ɗa.
\q1 
\v 7 Kadanshi kasingai ka tsu untsa n kalau ba,
\q2 ko tana a uwa untsa n vuza kelime.
\q1 
\v 8 KalyaꞋa ki ta̱ an katali ki ili mereve a a̱shi a vuza na u nekei a ɗa,
\q2 ubuta̱ u na u kpatalai dem derere ɗa.
\q1 
\v 9 Vuza na u cinukpai u nushi, ucigi u ɗa wi a kula̱nsa̱,
\q2 ama vuza na u tsu reme u nushi a̱ ka̱ɗu, u tsu pece ta̱ a̱ja̱Ꞌa̱ e ɗeɗevu.
\q1 
\v 10 Uɓarangi u kute u yawa ta̱ vuza na wi n kuyeve u yeve
\q2 n ulapi u kalau amangatawun.
\q1 
\v 11 Vuma gbani-gbani u tsu zuwa ta̱ kaci o kugoyi koci,
\q2 i ta̱ a ku suꞋuku yi n vuza unambi wa asuvu a yali ka̱ta̱ a lapai.
\q1 
\v 12 U kulaꞋa ta̱ n ugaꞋin vuza u gasa m ma̱kunzukunzu vuza wupa,
\q2 vuza na e pecei ni n muku n ni,
\q2 an vuza wa ku gasa n kalau a̱ ka̱tsuma̱ ka tsulau tsu ni.
\q1 
\v 13 Vuza na u tsupai kasingai n ka gbani-gbani,
\q2 ka gbanigbani ki a̱ ku ka̱sukpa̱ kpaꞋa ku ni ba.
\q1 
\v 14 Ugiti u vishili, wi ta̱ an kuyene ku mini ku na ku peciki,
\q2 sai a shamkpa maꞋan ali babu ma lyaꞋa kelime.
\q1 
\v 15 Vuza na wu utukai vuza vu unushi,
\q2 n vuza na u takacikai vuza vu usuɓi
\q2 dem vu le ili yu unata i ɗa u Vuzavaguɗu.
\q1 
\v 16 Gbani ɗa a una ikebe adama ana a̱ la̱nsa̱ka̱ kalau kuyeve,
\q2 adama a na wo okpoi a̱ yi vuza vu usuɓi ɗa ba.
\q1 
\v 17 Ka̱ja̱Ꞌa̱ ka tsu yaꞋan ta̱ ucigi ayin tutu,
\q2 vutoku kpamu adama a̱ ma̱ ɓa̱nka̱na̱i maꞋa a matsai ni.
\q1 
\v 18 Vuza vu babu kusheshe ɗa koci,
\q2 u kuɗika a̱miki a kutan ku vutoku vu ni.
\q1 
\v 19 A̱ yi na wi a kuciga unushi, vishili vu ɗa wi a kuciga,
\q2 A̱ yi na kpamu u maꞋin mashilya mu ugaɗi u ka̱ra̱i n a̱yi wi ta̱ a̱ kula̱nsa̱ ka̱ ka̱cika̱ni munuka.
\q1 
\v 20 Vuma vu ka̱ɗu ka gbani-gbani u ci ciya̱ kulya ku kelime ba,
\q2 vuza na de dem u tsu dansa a uwa u tsu uwa ta̱ atakaci.
\q1 
\v 21 Ili ya atakaci ɗa vuma u matsa maku kalau,
\q2 dada vu kalau u tsu yongo n ma̱za̱nga̱ ba.
\q1 
\v 22 Ka̱ɗu ka ma̱za̱nga̱, a̱guma̱ asingai ɗa,
\q2 ama ka̱ɗu ku una̱mgbuka̱tsuma̱ u tsu ɗekpetengu ta̱ vuma.
\q1 
\v 23 Vuma gbani-gbani u ciꞋisa ta̱ kalya u sokongi
\q2 adama ana u sabasa afada a mayun.
\q1 
\v 24 Vuza vu kuyeve, u tsu sheshe ta̱ ka kuna ku ugboji,
\q2 ama kalau ki ta̱ a kindi ku kavama.
\q1 
\v 25 Kalau ka maku ili ya atakaci ɗa u dada ni,
\q2 ili yu una̱mgbuka̱tsuma̱ i ɗa kpamu u vuza na u matsai ni.
\q1 
\v 26 Wi n ugaꞋin a yaꞋanka vuza vu babu unushi afada ba,
\q2 ko a faba vuzagbayin adama a kamayun ka̱ ni.
\q1 
\v 27 Vuza na u tsu dansa ke nu, keyevi kaꞋa,
\q2 kpamu a̱yi na wi n ka̱ɗu ka̱ yuwu keyevi kaꞋa.
\q1 
\v 28 Ko kalau feu u paɗa baci bini, a tsu ɗikai ta̱ vuza vu ugboji ɗa,
\q2 ɗa baci u paɗai bini udansai ka kuna ba,
\q2 uma i ta̱ a kuɗika yi keyevi.
\c 18
\q1 
\v 1 Vuza na u tsuyaꞋan cija̱Ꞌa̱ ba,
\q2 utsu la̱nsa̱ ta̱ u ciya̱ kulyaꞋa ku kelime ku ni koci,
\q2 u tsu iwan ta̱ n odoki ana i a singai.
\q1 
\v 2 Kalau ka tsu pana uyoꞋo u ciya̱ kuyeve ba,
\q2 ama u tsu pana ta̱ uyoꞋo u dansa kusheshe ku ni koci.
\q1 
\v 3 Makyan mana ka gbani-gbani ka̱ ta̱wa̱i, kugoyi feu ki ta̱ ta̱wa̱,
\q2 koɓolo n unambi u kasingai, i ta̱ a̱ kuciya̱ kugoyi.
\q1 
\v 4 Kadanshi ku una̱ u vuma, ki ta̱ n uga̱vi tsu mini,
\q2 ka̱shi ku ugboji tankpamu ki ta̱ uteku tsu kuɗolu ku mini mana mi e kuyene.
\q1 
\v 5 U gaꞋan vu yaꞋanka vuma gbani-gbani kasingai,
\q2 ko vu sa̱nka̱ vuza vu babu unushi usuɓi ba.
\q1 
\v 6 Kadanshi ka kalau ka tsu tuka̱ ta̱ n kunani,
\q2 una̱ u ni u tsu ronokoi ta̱ ulapi.
\q1 
\v 7 Kadanshi ka kalau ka tsu unai ta̱,
\q2 una̱ u ni u tsu okpoi ta̱ maza.
\q1 
\v 8 Kadanshi ka vuza kuyun, ki ta̱ tsu ilikulya yu uyoꞋo,
\q2 a kugida̱la̱ a ku uwa a i kyamba.
\q1 
\v 9 Ka iwain ku ulinga,
\q2 ka̱ja̱Ꞌa̱ ka vuza kula̱nga̱su kaꞋa.
\q1 
\v 10 Kula ku Vuzavaguɗu tsu mashilya mu utsura ma a,
\q2 vuma vu usuɓi u tsu suma ta̱ u uwa u da̱sa̱ngu n ma̱ta̱na̱.
\q1 
\v 11 U vuza vu uciyi, udukuyan u ni tsu likuci yi nshilya n ɗa.
\q2 a kusheshe ku ni, udukuyan uni u ka̱ra̱Ꞌi tsu mashilya mu ugaɗi.
\q1 
\v 12 Ugbamukaci u tsu vakangu ta̱ vuza,
\q2 ama uka̱ni u kaci u tsu tuka̱ ta̱ n ucikpi.
\q1 
\v 13 Vuza na baci wu ushuki kadanshi babu u pana,
\q2 tsulau tsu ɗa n ili i wono i ni.
\q1 
\v 14 Ayinviki ki a vuma i ta̱ a ku fuɗa kugbama a̱ suvu nu mɓa̱la̱,
\q2 ama vuma na ayinviki a̱ ni a takpai a̱pa̱, ka̱ ni ko kotso ta̱.
\q1 
\v 15 Ka̱ɗu ka vuza ugboji ayin tutu ki ta̱ a̱ kula̱nsa̱ uye u kudoku kuyeve,
\q2 atsuvu a vuza vu ugboji a̱ tsu la̱nsa̱ ta̱ kuyeve ayin tutu.
\q1 
\v 16 KuneꞋe ku tsu ɓa̱yuwa̱ ka̱ ta̱ utsutsu,
\q2 ali ku banka wu ubuta̱ u ku ene uma gbagbaꞋin.
\q1 
\v 17 Vuzana u tuka̱i kadanshi ka̱ ni n ugiti, u tsu okpo ta̱ adanshi a̱ yi ɗa vuza kamayun,
\q2 sai ayin ana vuza yoku wu uta̱i u yaꞋankai ni kece biꞋi.
\q1 
\v 18 Kazagba kaꞋa ka̱ tsu tuka̱ kananai uteku,
\q2 a̱yi ɗa u tsu pece a̱ ka̱tsuma̱ ka aza utsura.
\q1 
\v 19 Ɓa̱nka̱ aza̱ nu ele tana i ta̱ a ku ere wu tsu mashilya mu utsura,
\q2 ama vu shilika̱ baci n ele, i ta̱ a ku ɓa̱ya̱ngu ku utsutsu.
\q1 
\v 20 Adama a katsupu ka kadanshi ka̱nu,
\q2 tsu nanai tsu ɗa vi a̱ kuciya̱ wuma.
\q1 
\v 21 Ukpa̱ n wuma wi ta̱ a utsura u kelentsu ka̱ nu,
\q2 aza ana a cigai kaꞋa i ta̱ a kulaꞋa uciyi u le.
\q1 
\v 22 Vuza na u ciya̱i vuka, u ciya̱ ta̱ ili singai,
\q2 urotu wu uciyi mapasa ma singai maꞋan u Vuzavaguɗu.
\q1 
\v 23 Vuza vu unambi u tsu yaꞋan ta̱ kadanshi n ka̱la̱ka̱tsu ka̱ kula̱nsa̱ asuvayali,
\q2 ama vuza vu uciyi u tsu neke ta̱ wu ushiki babu asuvayali.
\q1 
\v 24 Cija̱Ꞌa̱ tsu yoku tsu tsu geshe ba,
\q2 ama cija̱Ꞌa̱ tsu yoku ci ta̱ n kamayun ali ka laꞋi ka̱ aza̱ nu.
\c 19
\q1 
\v 1 U laꞋa ta̱ n kugaꞋan vuza vu unambi a̱ ka̱tsuma̱ ku unambi u ni n kamayun,
\q2 ana a kudana wo okpo ta̱ kalau vuza vu kadanshi ka a uwa.
\q1 
\v 2 U gaꞋan vuma u yongo babu kuyeve ba,
\q2 ko kpamu vu okpo vuza na u tsu ci yaꞋan ili gogoꞋo vu la̱nga̱sa̱ uye.
\q1 
\v 3 Ayin a na baci tsulau tsu vuma tsu vakangi vuma,
\q2 ka̱ta̱ ka̱ɗu ka̱ ni ka ka̱na̱ wupa n Vuzavaguɗu.
\q1 
\v 4 Uciyi u tsu ɓolongu ta̱ a̱ja̱Ꞌa̱ n a̱bunda̱i,
\q2 ama ka̱ja̱Ꞌa̱ ka na vuza vu unambi wi n kaꞋa u tsu iwain ta̱.
\q1 
\v 5 Vuza magaꞋan ma a uwa wi a ku saꞋwa ku laꞋaka a ubuta̱ wa atakaci ba,
\q2 ta feu kayaꞋin ka uwa nanai, a̱ yi feu wi a̱ ku ka̱sukpa̱ ba.
\q1 
\v 6 Yaba dem u tsu la̱nsa̱ ta̱ mapasa ma singai a̱ ubuta̱ u vuza na u tsu neke ba̱ri,
\q2 yaba dem u ciga ta̱ wo okpo ka̱ja̱Ꞌa̱ ka vuza na u ci neke kuneꞋe ka̱u.
\q1 
\v 7 Ɗa baci a̱ za̱ni a iwain ni adama unambi u ni,
\q2 ni ɗai tamkpamu vuma va u ku kotsoꞋo so n a̱ja̱Ꞌa̱ ni?
\q1 Ko ni ɗai baci u folonoi le, babu vuza na u kupana ka yi.
\q1 
\v 8 A̱ yi vuzana u ciya̱i ugboji, wuma u ni u ɗa u cigai,
\q2 a̱ yi vuzana u we erei kuyeve kpamu wi ta̱ a̱ ku ba̱ruwa̱.
\q1 
\v 9 MagaꞋan ma a uwa mi a ku laꞋaka a ubuta̱ wa atakaci ba,
\q2 ta feu nannai kayaꞋin ka a uwa ki ta̱ a̱ ku kuwa̱.
\q1 
\v 10 U gaꞋan kalau ka yaꞋan ida̱shi ma̱za̱nga̱ ba,
\q2 nannai kpamu u laꞋa ta̱ n gbani-gbani kagbashi ka lyaꞋa tsugono wu ngono.
\q1 
\v 11 Ugboji u vuma u tsu neke yi ta̱ uka̱ni u ka̱ɗu,
\q2 ucikpi u ni uɗa u cinukpa n unushi.
\q1 
\v 12 Wupa u mogono wita̱ tsu yura̱ i kawu,
\q2 ama kasingai ka̱ ni ka̱ tsu tuka̱ ta̱ n una̱singai tsu ciza.
\q1 
\v 13 Kalau ka maku ka tsu ronoko ta̱ dada vu ni atakaci,
\q2 vuka vu vishili vi ta̱ tsu uɗa̱kpi u mini.
\q1 
\v 14 KpaꞋa n uciyi ili yi uka̱ni i ɗa a ubuta̱ wi isheku,
\q2 ama vuka vu ma̱riki a ubuta̱ u Vuzavaguɗu ɗa,
\q1 
\v 15 Wonvoli u tsu zuwa ta̱ vuma alavu a̱bunda̱i,
\q2 vuza na u tsu iwan ulinga tamkpamu wita̱ a kutakacika.
\q1 
\v 16 Vuza na u tsu ere kadanshi, wuma u ni u ɗa wi e ku ere,
\q2 ama vuza na u tsu kpa̱ɗa̱ ku zuka n uye u ni, wita̱ a̱ ku kuwa̱.
\q1 
\v 17 Vuza na baci de dem u tsu yaꞋan kasingai u vuza vu unambi, Vuzavaguɗu ɗa wi e kuneke kutan,
\q2 wi ta̱ kpamu a̱ kuciya̱ katsupu a ili i na u yaꞋin.
\q1 
\v 18 Gbara maku ma̱ nu, adama ana n tsu nannai uzuwi u ka̱ɗu wita̱ punu,
\q2 ka̱ ta̱ vu ɓa̱nka̱ una̱mgbi u ni ba.
\q1 
\v 19 Vuza vu usuɗukpi u ka̱ɗu wi ta̱ a ku soꞋo atakaci,
\q2 ɗa baci vu utukai ni kute, sai vu doku kpamu vu utuka̱i.
\q1 
\v 20 Zuwa atsuvu vu pana odoki, ka̱ta̱ vu isa kuyotsongusu,
\q2 adama ana kanna ko yoku vi ta̱ o ku okpo vuza vu ugboji.
\q1 
\v 21 Kusheshe ku ka̱ɗu ku vuma ki ta̱ n a̱bunda̱i,
\q2 ama kusheshe ku Vuzavaguɗu ku ɗa koci ki a kushana.
\q1 
\v 22 I na a cigai u vuma i ɗaɗa ucigi,
\q2 u laꞋa ta̱ n ku gaꞋan n vuza vu unambi an vuza na u tsu dansa a uwa.
\q1 
\v 23 Wovon u Vuzavaguɗu u tsu neke ta̱ wuma,
\q2 ka̱ ta̱ tana vuza u ciya̱ ku uvuka,
\q2 babu ili i na i kuciya̱i.
\q1 
\v 24 Kowonvoni ka tsu uka ta̱ kukiye a̱ mevene ma kusan,
\q2 ama wi a kufuɗa wa banka una̱ u ni ba.
\q1 
\v 25 Gbara vuza kugoyi, vuza vu unambi u kusheshe wi ta̱ a kuyaꞋan ugboji,
\q2 dansuka keyevi, wita̱ o kudoku n kuyeve.
\q1 
\v 26 Vuza na baci de dem u takacikai Dada ni ɗa kpamu u lokoi a̱na̱ku ni a kpaꞋa,
\q2 maku maꞋan mana ma tsu tuka̱ n wono n kugoyi.
\q1 
\v 27 Maku ma̱va̱ ɗa baci vu ka̱sukpa̱i kupana kuyotsongusu,
\q2 vita̱ a kucinukpa n ili i na vu yevei ɗe.
\q1 
\v 28 MagaꞋan ma a uwa u tsu yaꞋan ka ta̱ afada a mayun kavama,
\q2 vuma gbani-gbani u shatangu ta̱ una̱ u ni n kawuya ci ilikulya.
\q1 
\v 29 A foɓuso ta̱ atakaci adama aza a kavama,
\q2 macaka kpamu adama a kalau.
\c 20
\q1 
\v 1 Ma̱kya̱n ili modoruko i ɗa, ili ku soꞋo yu utsura i tuka̱ n vishili i ɗa,
\q2 Yaba dem vu na ma vakangi wi nu ugboji ba.
\q1 
\v 2 Usuɗukpi u wupa u mogono u tsu zuwa ta̱ kujeꞋe ke ki ikyamba, uteku tsu yura̱ i kawu,
\q2 yaba dem vu na u zuwai ni wupa wi ta̱ a ku kuwa̱.
\q1 
\v 3 Ili i tsugbayin i ɗa vuma wu utuka̱ ka̱cika̱ni ubuta̱ u vishili.
\q1 
\v 4 Vuza wonvoli u tsu cimba kashina n lyushi ba,
\q2 ka̱ta̱ ayin a vukyaꞋa a yawa baci wo okpo lekeɗi.
\q1 
\v 5 Kusheshe ku ka̱ɗu ku vuma ki ta̱ an mini mu uga̱vi,
\q2 vuza na wi n kuyeve ɗa koci wi a kurono maꞋa.
\q1 
\v 6 Uma n a̱bunda̱i a tsu sala ta̱ ukuna wu ucigi u le,
\q2 ama yayi wa kufuɗa kuciya̱ vuma vu usuɓi?
\q1 
\v 7 Vuza usuɓi u ci yaꞋan ta̱ nwalu n singai,
\q2 aza una̱singai a ɗa muku n na mi a̱ kuta̱wa̱ n ka̱ca̱pa̱ ka̱ni.
\q1 
\v 8 Mogono ma na mi ida̱shi a kakuba ka afada,
\q2 n a̱shi a̱ ni ɗa wi a̱ ku utuka̱ aza gbani-gbani ra̱ka̱.
\q1 
\v 9 Ya yi wa kufuɗa wa dana, <<Mpa n ciɗatangu ta̱ ka̱ɗu ka̱va̱,
\q2 m buwa nu unushi u yoku ba>>?
\q1 
\v 10 Kagisamkpatsu ka uwa n ka modoruko,
\q2 ra̱ka̱ vu le ili yu unata i ɗa u Vuzavaguɗu.
\q1 
\v 11 A tsu yeve ta̱ muku n kenken a ubuta̱ wu ukuna wi ili i na u tsu yaꞋansa,
\q2 i ta̱ a kufuɗa kuyeve ko kuyongo ku le ku singai ku ɗa, ko ku mejege.
\q1 
\v 12 Atsuvu adama a kupana, a̱shi kpamu adama e ku ene,
\q2 Vuzavaguɗu ɗa u yaꞋin le ra̱ka̱.
\q1 
\v 13 Ka̱ta̱ vo okpo vuza va alavu ayin tutu ba, adama ana talo unambi wi a̱ ku ka̱na̱ wu.
\q2 ɓa̱yuwa̱ a̱shi a̱ nu, vi ta̱ a̱ kuciya̱ ilikulya ya a̱bunda̱i.
\q1 
\v 14 <<Katsuli ka tsu dana ta̱ ili ya i gaꞋan ba, ko kenu,>>
\q2 ama makyan ma na baci u lazai, ka̱ ta̱ u yaꞋan a̱ra̱ɗi u dana u ciya̱ ta̱ ili i singai.
\q1 
\v 15 Azanariya n atali a singai i ta̱ lo gbani,
\q2 ama una̱ u na u tsu dansa ka kuyeve, u laꞋa le ta̱ n ku gaꞋan ra̱ka̱.
\q1 
\v 16 Isai motogu ma vuza na u shamgbai tsu magan mo komoci ka na kalyaꞋi kutan,
\q2 remei ucanuku u ni wo okpo magan adama o komoci ka.
\q1 
\v 17 Ilikulya i na a̱ ciya̱i a uye wa a uwa yi ta̱ n uyoꞋo u kulya ka̱u,
\q2 ama a ukocishi wita̱ o ku okpo an kayala a una̱.
\q1 
\v 18 N odoki a ɗa kakuna ka tsu gaꞋan,
\q2 la̱nsa̱ odoki a ugboji kafu vu bana kuvon.
\q1 
\v 19 Vuza na u tsu ka̱ra̱Ꞌa̱ n udansai a uwa, u tsu palukpa ta̱ ili i na yi u sokongi,
\q2 adama nanai, yaꞋan dangi n vuza vu motonu ma̱ a̱bunda̱i.
\q1 
\v 20 Ɗa baci vuza u shikai dada ni ko a̱na̱kpa̱ ni,
\q2 ma̱kuni ma̱ ni mi ta̱ a̱ ku kuwa̱ e mere ma ka̱yimbi.
\q1 
\v 21 Ili yu uka̱ni i na a̱ ciya̱i gogoꞋo a ugiti,
\q2 wi o ku okpo wu una̱singai a ukocishi ba.
\q1 
\v 22 Ka̱ta̱ vu dana, <<Mi ta̱ a kutsupa ka gbani-gbani,>>
\q2 Ama ka̱sukpa̱ Vuzavaguɗu, a̱ yi ɗa u ku wawa wu.
\q1 
\v 23 Kagisamkpatsu ka a uwa ili yu unata i ɗa u Vuzavaguɗu,
\q2 kagisamkpatsu ka uwa ka gaꞋan ba.
\q1 
\v 24 Nwalu n vuma dem, Vuzavaguɗu ɗa u foɓusoi,
\q2 ni ɗai vuma u kufuɗa kuyeve uye una wi o kutono?
\q1 
\v 25 Maza maꞋa u vuma u reme ili i yoku babu kusheshe
\q2 ka̱ta̱ n ka̱ca̱pa̱ kpamu u ciɓa n uzuwakpani u ni.
\q1 
\v 26 Mogono mu ugboji ma tsu utuka̱ ta̱ uma a gbani-gbani,
\q2 ka̱ta̱ kpamu u takacika le babu asuvayali.
\q1 
\v 27 Ayinviki a vuma kutashi ku ɗa ku Vuzavaguɗu,
\q2 u tsu la̱na̱ ta̱ ali a̱ ka̱ɗu ka̱ ni n kusheshe ku ni.
\q1 
\v 28 Ucigi koɓolo n kamayun ka tsu kanza ta̱ mogono,
\q2 kakuba ko tsugono ka̱ ni ka shamgba a ubuta̱ wu ucigi.
\q1 
\v 29 UgaꞋin wa a̱ɗa̱nga̱ni wi ta̱ a utsura u le,
\q2 ama ugaꞋin wu nkoshi tankpamu wu ɗa ɗa ka̱nji ka̱ri.
\q1 
\v 30 Ulapi wu usuɗukpi u tsu utuka̱ ta̱ ka gbani-gbani,
\q2 u tsu ciɗatangu ta̱ ka̱ɗu n kusheshe ra̱ka̱.
\c 21
\q1 
\v 1 Ka̱ɗu ko mogono ki ta̱ tsu mini mo kuɗolu
\q2 a kukiye ku Vuzavaguɗu,
\q2 Vuzavaguɗu tsu vadalukpai ta̱ ubuta̱ una wi a kuciga dem.
\q1 
\v 2 Vuma wi ta̱ a kusheshe uye u ni mayin ɗa wi,
\q2 ama Vuzavaguɗu utsu gisanku ta̱ ka̱ɗu.
\q1 
\v 3 KuyaꞋan kamayun n usuɓi,
\q2 u laꞋa ta̱ alyuka wishi ubuta̱ u Vuzavaguɗu.
\q1 
\v 4 Ugbamukaci n a̱ra̱ɗi,
\q2 ɗaɗa ma̱kuni ma aza gbanigbani.
\q2 na lo va tana unushi uɗa.
\q1 
\v 5 Kusheshe ku ma̱riki kpamu ku tsu neke ta̱ uciyi wa a̱bunda̱i,
\q2 ama vuza na u sheshe gogoꞋo u tsu okpo ta̱ n unambi.
\q1 
\v 6 Uciyi u na uma a ciya̱i ubuta̱ wa elentsu a uwa,
\q2 u tsu kotso ta̱ an ka̱nga̱,
\q2 kpamu u tsu banka ta̱ vuma ubuta̱ wu ukpa̱.
\q1 
\v 7 Unambi wu usuɓi wa a za gbanigbani wi ta̱ a ku pura̱ngu le u lazaka,
\q2 a dama na a iwain ta̱ kuyaꞋan ili i na yi i ma̱riki.
\q1 
\v 8 Uye u vuza vu u nushi u tsu yongo ta̱ n o kondo,
\q2 ama ka̱ɗu ka vuza vu babu unushi ka ci yaꞋan ta̱ kamayun.
\q1 
\v 9 U kulaꞋa ta̱ n kugaꞋan vu da̱sa̱ngu a kunu ku kenu pulai,
\q2 ana va kuda̱sa̱ngu asuvu a kpaꞋa ku gbayin n vuka vu vishili.
\q1 
\v 10 Ka̱ɗu ka vuza gbanigbani ka ci sheshe ta̱ kuyaꞋan kagbanigbani,
\q2 u tsu pana asuvayali a vuza na i a ida̱shi ɗeɗevu ba.
\q1 
\v 11 Makyan mana baci a takacikai aza a kugoyi,
\q2 vuza vu unambi u kusheshe feu u ci ciya̱ ta̱ ugboji.
\q2 makyan ma na a yaꞋankai vuza vu ugboji kadanshi,
\q2 utsu doku ta̱ n kuyeve.
\q1 
\v 12 Ka̱shile, vuza vu usuɓi, u tsu zuwa ta̱ a̱shi a kpaꞋa ku vuza ka gbani-gbani,
\q2 utsu goyo ta̱ aza gbani-gbani ali a̱ na̱mgba̱.
\q1 
\v 13 Vuma u kpanduku baci atsuvu a̱ ni adama a̱ ma̱shi ma vuza vu unambi,
\q2 a̱yi feu wita̱ a kuyaꞋan ma̱shi ma̱ kula̱nsa̱ uɓa̱nki,
\q2 ama wi tana feu a̱ kuciya̱ wushiki ba.
\q1 
\v 14 KuneꞋe ku usokongi ku tsu loko ta̱ wupa,
\q2 kalya kpamu ka vaꞋanku ta̱ wupa u gbayin.
\q1 
\v 15 Ukuna u ma̱za̱nga̱ uɗa u vuza vu usuɓi,
\q2 a yaꞋan afada a mayun,
\q2 ama u vuza gbani-gbani, ili yi una̱mgbi u ka̱tsuma̱ i ɗa.
\q1 
\v 16 Vuma na u puwa̱nka̱i a ubuta̱ u cicoꞋo,
\q2 wi ta̱ a kuvuka o koɓolo ka a̱kpisa̱.
\q1 
\v 17 Vuza na de dem u cigai kupana ku uyoꞋo, wi ta̱ o ku okpo vuza vu unambi,
\q2 vuza na de dem u cigai ma̱kya̱n n maniꞋin,
\q2 wi a ku saꞋawa ku okpo vuza vu udukuyan ba.
\q1 
\v 18 A tsu takacika ta̱ vuza gbanigbani adama na isa vuza vu usuɓi,
\q2 vuza vu babu kamayun kpamu
\q2 adama ana isa vuza kamayun a̱ ka̱ɗu.
\q1 
\v 19 U lata̱ n kugaꞋan vu da̱sa̱ngu a ka kamba,
\q2 ana va kuda̱sa̱ngu n vuka vu wupa n vishili.
\q1 
\v 20 A kpaꞋa ku vuza vu cicoꞋo ubuta̱ u kufoɓo ilikulya m mani ma singai u ɗa.
\q2 ama kalau ka tsu lyaꞋa ta̱ ili i ni i na wi n i ɗa ra̱ka̱.
\q1 
\v 21 Ya ba dem vu na u la̱nsa̱i usuɓi koɓolo n ucigi,
\q2 u ci ciya̱ ta̱ wuma, n uciyi n tsugbayin.
\q1 
\v 22 Vuza vu cicoꞋo vi te u tsu lyaꞋa ta̱ likuci i gbangam,
\q2 vuna a fuɗi o kuvon i a kpaꞋa ku ni,
\q2 ali u ɓoso mashilya mana i a kukeɗeke a̱pa̱.
\q1 
\v 23 Vuza na de dem u ka̱na̱i una̱ u ni n kelentsu ka̱ ni,
\q2 u tsu ere ta̱ ka̱cika̱ni a ubuta̱ wa atakaci.
\q1 
\v 24 Vuza vu ugbamukaci n vuza va a̱ra̱ɗi,
\q2 vuza ku kugoyi ɗa kula kuni,
\q2 u tsuyaꞋan ta̱ ili n kugoyi n a̱ra̱ɗi.
\q1 
\v 25 Mali ma vuza wono mi ta̱ o ku okpo ukpa̱ uni,
\q2 adama ana ekiye a̱ ni a iwan ta̱ ku yaꞋan u linga.
\q1 
\v 26 Kanna lakam uma a gbanigbani a tsu dakaka ta̱ adama a na a yaꞋan modoruko,
\q2 ama vuza vu usuɓi u tsu dakaka ta̱ adama na u neke ba̱ri.
\q1 
\v 27 Alyuka a vuza gbanigbani ili yu unata i ɗa,
\q2 be le kuneꞋe ku na a̱ tuka̱i n kusheshe ku gbanigbani.
\q1 
\v 28 MagaꞋan ma uwa mita̱ a ku takacika,
\q2 ama i ta̱ a ku ɗesukpa̱ vuza na u tsu dansa kasingai.
\q1 
\v 29 Uma a gbanigbani a tsu ɗika ta̱ ka̱cika̱le e yeve ta̱ ili ra̱ka̱,
\q2 ama a za usuɓi a tsu sheshe ta̱ u kuna wi na a kuyaꞋan.
\q1 
\v 30 Babu ugboji, ko kuyeve, ko odoki
\q2 a na a kulaꞋa Ka̱shile.
\q1 
\v 31 A tsu foɓo so ta̱ ko odoku adama a kanna ka kuvon,
\q2 ama ulyai u Ka̱shile u ɗa.
\c 22
\q1 
\v 1 Kula ku usingai ku laꞋa ta̱ udukuyan wa a̱bunda̱i,
\q2 mapasa ma singai ma laꞋa ta̱ uciyi wa azurufa n wa azanariya.
\q1 
\v 2 Vuza vu uciyi n vuza vu unambi ili i te i ɗa,
\q2 adama a na Ka̱shile kaꞋa ka yaꞋin le dem.
\q1 
\v 3 Vuza vu usuɓi u ce ene ta̱ kawuya ka̱ta̱ u sheɗeku,
\q2 ama kalau ka tsu uka ta̱ ka̱ci ka̱ ni ka̱ta̱ ta na u takacika.
\q1 
\v 4 U ka̱ni u kaci n wovon u Ka̱shile,
\q2 udukuyan u ɗa n tsugbayin n wuma.
\q1 
\v 5 Awana n maza i ta̱ uye wa aza a gbani-gbani,
\q2 vuza na dem u foɓusoi ka̱ɗu ka̱ ni wi ta̱ a ku yaꞋan daꞋangi n a̱ le.
\q1 
\v 6 Yotsongu maku uye u na wa ku tono,
\q2 ko u kutsa ba ci wi a kucinukpa nu ɗa ba.
\q1 
\v 7 Vuza vu uciyi u tsu lyaꞋaka ta̱ vuza vu unambi tsugono,
\q2 vuza kutan kpamu kagbashi kaꞋa e kiye a ka nekei.
\q1 
\v 8 Ya ba dem vu na uca̱Ꞌi ka agbanigbani, wi ta̱ ku kyaꞋa kagbanigbani,
\q2 kpamu kalangu ka modoruko ka ni ki ta̱ o ku koɗo.
\q1 
\v 9 Ya ba dem na u tsu neke ba̱ri wita̱ a ku ciya̱ una̱singai,
\q2 adama ana ilikulya i ni i ɗa u tsu pece ke aza unambi.
\q1 
\v 10 Utuka̱ vuza kugoyi, yeve ka̱ta̱ vishili vu kotso,
\q2 ka̱ta̱ vishili n ishikushi i kotso.
\q1 
\v 11 A̱yi na u tsuyaꞋan kasingai ka̱ta̱ u dansa mayin,
\q2 wita̱ o ku okpo ka̱ja̱Ꞌa̱ ko mogono.
\q1 
\v 12 A̱shi a̱ Ka̱shile i ta̱ a kinda kuyeve,
\q2 ama u tsu taɗuku ta̱ kadanshi ka gbanigbani.
\q1 
\v 13 Korogo ka tsu dana ta̱, <<Kawu wita̱ lo pulai.
\q2 muꞋuta̱ baci wita̱ a ku una mu uye.>>
\q1 
\v 14 Una̱ u kashakanlai kpenle ku uga̱vi ku ɗa,
\q2 vuza na Ka̱shile ki a wupa n a̱yi wita̱ a ku yikpa̱ a ku ɗa.
\q1 
\v 15 Tsulau cita̱ ugbaɓurangi n ka̱ɗu ka maku,
\q2 ama mashashau mu ugbari mi ta̱ o ku lokoi u ɗa.
\q1 
\v 16 Vuza na de dem u takacikai vuza vu unambi adama ana u doku udukuyan u ni,
\q2 ko kpamu u nekei vuza vu udukuyan ili, wi ta̱ a ku okpo n unambi.
\q1 
\v 17 Zuwa atsuvu vu pana kadanshi ka vuza vu ugboji,
\q2 ka̱ta̱ vu yaꞋan cicoꞋo a̱ ka̱ɗu ka̱ nu,
\q1 
\v 18 adama ana, wita̱ a kugaꞋan, ɗa baci vu zuwai le a̱ nu,
\q2 ɗa dem vu le a̱ ciya̱i ida̱shi una̱ u nu.
\q1 
\v 19 Adama ana kamayun ka̱ nu ko yongo u Vuzavaguɗu,
\q2 n yotsongu wu ta̱ e le anana.
\q1 
\v 20 Kadanshi ka kamangankupa kaꞋa na kana n ɗana kai nu,
\q2 kadanshi ko odoki n kuyeve ba,
\q1 
\v 21 adama ana n yotsongu wu ili i na yi kamayun,
\q2 adama ana vu neke wushuki u mayun.
\q1 
\v 22 Ka̱ta̱ vu ya̱nsa̱ vuza vu unambi, adama ana wi nu unambi ba,
\q2 ko kpamu vu doro aza unambi ubuta̱ wa afada,
\q1 
\v 23 adama ana Vuzavaguɗu u tsu shamgba ta̱ adama e le,
\q2 ka̱ta̱ wu una wuma u vuza na u ya̱nsa̱i le.
\q1 
\v 24 Ka̱ta̱ vu yaꞋan cija̱Ꞌa̱ n vuza wupa ba,
\q2 ka̱ta̱ vu gbaɓa ka̱cika̱nu n ka yaꞋin ka̱ vishili ba,
\q1 
\v 25 Talo va tono uye u ni
\q2 ka̱ta̱ vu uka ka̱cika̱nu a maza.
\q1 
\v 26 Ka̱ta̱ vu ushuku ku tsupa ka vuza kutan ba,
\q2 ko kpamu vu okpo magan adama vuza kutan ba,
\q1 
\v 27 adama ana ɗa baci vi n ili i na vu kutsupaka ba,
\q2 i ta̱ a ku ɗika kajiba ki ivaꞋin ka nu a laza ka.
\q1 
\v 28 Ka̱ta̱ vu takpa katali ka kureꞋe ka aza a cau,
\q2 kana ikaya i nu i shikpa̱i ba.
\q1 
\v 29 Vu tsu e ene ta̱ kafuɗi ku ulinga ubuta̱ wu ulinga u ni?
\q2 U tsu shamgba ta̱ e kelime ko ngono,
\q2 ama wa ku shamgba u yaꞋanka aza ana e yevei ni ulinga ba.
\c 23
\q1 
\v 1 Ɗa baci vu da̱sa̱ngi kulyaꞋa ilikulya n mogono,
\q2 la̱na̱ ka̱ta̱ vindana mayin i na yi e kelime ka̱ nu.
\q1 
\v 2 Avu vuza kalya ɗa baci,
\q2 to, reme ka̱cika̱nu,
\q1 
\v 3 Ka̱ta̱ vu yaꞋan mali mi ilikulya i ni ba,
\q2 adama ana i ɗaɗa cico tsu nu ba.
\q1 
\v 4 Ka̱ta̱ vu takacika ka̱cika̱nu adama a kula̱nsa̱ udukuyan ba,
\q2 gbojo ko ka̱cika̱nu adama ana vu suma kaꞋa,
\q2 
\v 5 adama ana, ayin ana baci de dem vu la̱na̱i u ɗa wi ta̱ o ku kotso,
\q2 adama ana sawu ɗa o tsu topo evelyu,
\q2 a tsu imkpi tsu shafu gaɗi a Ka̱shile.
\q1 
\v 6 Ka̱ta̱ vulya ilikulya i vuza vu ulyopi ba,
\q2 ka̱ta̱ vu yaꞋan mali mi ilikulya yu uyoꞋo i ni ba,
\q1 
\v 7 adama na a̱yi vuza cico ci na wa kuna ɗa.
\q2 Ka̱ta̱ u dana<<LyaꞋi n i soꞋi.>>Ama ka̱ɗu ka̱ ni ki lo koɓolo n a̱ɗa̱ ba.
\q1 
\v 8 Vi ta̱ a kushama i kenu i na vu lyaꞋi va,
\q2 ka̱ta̱ vu la̱nga̱sa̱ kadanshi ka singai ka̱ nu.
\q1 
\v 9 Ka̱ta̱ vu yaꞋan kadanshi atsuvu a kalau ba,
\q2 adama na wita̱ a kugoyo ugboji u kadanshi ka̱ nu.
\q1 
\v 10 Ka̱ta̱ vu muɗa̱ urotu u kureꞋe wi iɗika u tsumani ba
\q2 ko kpamu vu pasa visa ashina a mkpan ba,
\q1 
\v 11 adama ana kishi ke le, vuza vu utsura ɗa,
\q2 wita̱ a ku shamgba adama e le ka̱ta̱ u shilika̱ n na vu.
\q1 
\v 12 Zuwa asuvu, ka̱ta̱ vu pana kuyotsongu,
\q2 vu zuwa atsuvu a̱ nu kpamu ubuta̱ u kadanshi ku ugboji.
\q1 
\v 13 Ka̱ta̱ vu ka̱sukpa̱ ku gbara maku ba,
\q2 adama na ko niniɗai baci vu lapai ni wi a ku kuwa̱ ba.
\q1 
\v 14 Adama na ɗa baci vu lapai ni n kafabatsu,
\q2 vu ɓa̱nka̱ ta̱ wuma u ni ubuta̱ wa atakaci a munuka.
\q1 
\v 15 Maku ma̱va̱, ɗa baci vu gbojoi,
\q2 ka̱ɗu ka̱va̱ feu ki ta̱ o ku yokpo.
\q1 
\v 16 Wuma u va̱ u kuyaꞋan ta̱ ma̱za̱nga̱,
\q2 ɗa baci una̱u nu udanshi kasingai.
\q1 
\v 17 Ka̱ta̱ vu yaꞋan tsurala tsu vuza vu unushi ba,
\q2 ama ayin tutu vu yongo n tsurala tsu wovon u Ka̱shile.
\q1 
\v 18 Ɗa baci vu yaꞋan nanai, vi ta̱ a ku yaꞋan ma̱za̱nga̱ a ayin a kelime,
\q2 kpamu Ka̱shile ki ta̱ a ku yaꞋan kawu i na vu cigai u yaꞋan ka wu.
\q1 
\v 19 Maku ma̱va̱, zuwa atsuvu mayin vu pana adama na vu ciya̱ ugboji,
\q2 ka̱ta̱ vu zuwa ka̱ɗu ka nu uye u singai.
\q1 
\v 20 Ka̱ta̱ vu gbaɓa ka̱cika̱nu n osoꞋi ba,
\q2 ko kpamu aza kalya ba,
\q1 
\v 21 adama na osoꞋi koɓolo n aza kalya a i ta̱ o kokpo aza unambi,
\q2 ka̱ta̱ agbaɗiki a pala le n akashi.
\q1 
\v 22 Pana kadanshi ka eshevu a̱ yi na u neke nu wuma,
\q2 kpamu ka̱ta̱ vu goyo a̱na̱ku a̱ nu a ayin a na u kuci ba.
\q1 
\v 23 Tsula kamayun ka̱ ta̱ vu denge ba,
\q2 ka̱ta̱ kpamu vu ciya̱ ugboji n ugbari n kuyeve.
\q1 
\v 24 Muku mu usuɓi n tsu zuwa ta̱ i sheku e le ma̱za̱nga̱.
\q1 
\v 25 YaꞋan i na dada nu n a̱na̱kpa̱ nu a kuyaꞋan ma̱za̱nga̱,
\q2 ka̱ta̱ kpamu vu ka̱sukpa̱ a̱na̱kpa̱ nu a na a maci nu feu a yaꞋan ma̱za̱nga̱.
\q1 
\v 26 Maku ma̱ va̱, neke mu ka̱ɗu ka̱ nu,
\q2 ka̱ta̱ vu ka̱sukpa̱ a̱shi a̱ nu o tono uye u va̱.
\q1 
\v 27 Adama ana kashakanlai kpenle ku ɗa ku uga̱vi,
\q2 vuka vu vuza kpamu uye wa atakaci u ɗa.
\q1 
\v 28 U tsu vaku ta̱ a ku vana an vuza maga̱lka̱,
\q2 ka̱ta̱ u ka̱na̱ ku doku ka̱bunda̱i ka aza tsugbani.
\q1 
\v 29 Ya yi ɗa wi a malapa mu? Ya yi ɗa wi u na̱mgbi u ka̱tsuma̱?
\q2 Ya yi ɗa u tsu zama vishili babu unushi? Ya yi ɗa u tsu ka̱na̱ mololo an deꞋen ni?
\q1 Ya yi ɗa vuza na wi n muna babu munla̱i?
\q2 Ya yi ɗa tsu yongo n a̱shi a shili?
\q1 
\v 30 A̱yi ɗa vuza na u ci geshe ubuta̱ u kusoꞋo ku ma̱ra̱,
\q2 Aza na u tsu ka̱na̱ kusoꞋo ma̱ra̱ icuꞋu kakau.
\q1 
\v 31 Ka̱ta̱ vu ka̱sukpa̱ ma̱ra̱ ma la̱nga̱sa̱ wu ba,
\q2 ko ana mo okpoi ushili n ugaꞋin u kene,
\q2 nu uyoꞋo u kusoꞋo.
\q1 
\v 32 Ka̱ta̱ u koci u ka̱na̱ kuluma yi an koko,
\q2 a mataɗaka an kudyaɓu.
\q1 
\v 33 Ka̱ta̱ a̱shi a̱ nu a ka̱na̱ kene ili kakawu,
\q2 ka̱ta̱ vu ka̱na̱ kusheshe u kuna n kadanshi ka kavama.
\q1 
\v 34 Ka̱ta̱ vokpo an vuma na u vaki a mala,
\q2 ko an vuma na wi a̱ ka̱ta̱la̱la̱ gaɗi vu maɗanga ma kpantsu a mini.
\q1 
\v 35 Ka̱ta̱ vu dana, ai vuza yoku u lapa mu ta̱, <<Ama u foro mu ba,
\q2 a lapa mu ta̱ ama n pana n ɓa̱la̱ ba.
\q1 Wanai ɗa ma ku jimgba n soꞋo ma yoku.>>
\c 24
\q1 
\v 1 Ka̱ta̱ vu yaꞋanka uma a kavama tsurala ba,
\q2 ko vu yaꞋan mali ma kuyongo n a̱ le ba,
\q1 
\v 2 adama na ka̱ɗu ke le, ka ci sheshe i yoku ba, sai vishili,
\q2 una̱u u le kpamu sai kavama.
\q1 
\v 3 N ugboji u ɗa a maꞋin kpaꞋa,
\q2 n ubuta̱ u kuyeve u ɗa kpamu ɗa kushamgba yi,
\q1 
\v 4 n ubuta̱ u kuyeve u ɗa a shatangi unu
\q2 n ucanuku u singai ra̱ka̱ n uciyi.
\q1 
\v 5 Vuza vu ugboji u tsu yaꞋan ta̱ n utsura,
\q2 keyevi kpamu ka tsu lyaꞋa ta̱ kelime n kudoku n utsura,
\q1 
\v 6 adama na ubuta̱ wu ugboji u uma u ɗa a tsuyaꞋan kuvon,
\q2 kpamu ubuta̱ wa odoki u uma u ɗa a ci ciya̱ u lyaꞋi.
\q1 
\v 7 Ugboji wi ta̱ n atakaci a kuyeve ubuta̱ u kalau,
\q2 a u ubuta̱ u kadanshi uma a tsu fuɗa a dansa u kuna u ma̱riki ba.
\q1 
\v 8 Ya ba dem na u tsu sheshe kuyaꞋan ka gbani-gbani,
\q2 a ku ɗekei ta̱, mogono ma vishili.
\q1 
\v 9 Kusheshe kuyaꞋan ka gbani-gbani, u nushi u ɗa,
\q2 vuza kugoyi kpamu ili yu unata i ɗa ubuta̱ u uma.
\q1 
\v 10 Ɗa baci vu oꞋoi a kanna ka atakaci,
\q2 mayun ɗa an vi nu utsura ba.
\q1 
\v 11 Isa aza na i a kurono a ku banka ubuta̱ u munuka,
\q2 Geshe aza na i a katambalusa a ku bana u kpiꞋisa̱.
\q1 
\v 12 Ɗa baci vu danai, <<Mpa n yeve ili nampa ya ba,
\q2 adama nanai mpa, ili i bura mu ba.>> Ciɓai an Ka̱shile ka yevei i na ci yaꞋan, kpamu u yeve ta̱ i na ci a kusheshe,
\q2 ashe wa ku tsupa ka tsu derere vi na tsuyaꞋan va ba?
\q1 
\v 13 Maku ma̱va̱, lyaꞋa ishigi, adama i ɗa yi ta̱ n ugain.
\q2 kpamu kuɗa̱kpa̱ ku kabashi ki ishigi ko tsu yokpo ta̱ una̱.
\q1 
\v 14 Yeve an ta ugboji wi a̱ ka̱ɗu ka̱ nu nanai,
\q2 ɗa ba ci vu ciya̱i u ɗa, vi ta̱ a kuyongo n a̱pa̱ kelime,
\q2 kpamu a̱pa̱ a̱ nu i a ku puwa̱nka̱ ba.
\q1 
\v 15 Ka̱ta̱ vu vaꞋanku a kavaꞋawan tsu vuma gbanigbani, a kpaꞋa ku vuza vu usuɓi,
\q2 ka̱ta̱ vu la̱nga̱sa̱ kpaꞋa ku vuza vu usuɓi ba,
\q1 
\v 16 adama na vuza vu usuɓi u su yikpa̱ ta̱ ku cindere ka̱ta̱ u ɗa̱nga̱ kpamu,
\q2 ama u na̱mgbi u te u tsuna ta̱ aza gbanigbani.
\q1 
\v 17 Ka̱ta̱ vu yaꞋan ma̱za̱nga̱, adama ili gbanigbani i na i ciya̱i vu rala nu ba,
\q2 kpamu ka̱ta̱ vu yaꞋan ma̱za̱nga̱ a ayin ana u fa̱ta̱tsa̱i u yikpa̱i ba,
\q1 
\v 18 talo, Vuzavaguɗu wa kene, ka̱ta̱ u na̱mgba̱ ka̱tsuma̱,
\q2 ka̱ta̱ kucikpa u vadalukpa wupa u ni.
\q1 
\v 19 Ka̱ta̱ vu takacika ka̱cika̱nu adama vuza gbanigbani ba,
\q2 kpamu ka̱ta̱ vu yaꞋan tsura tsa aza gbanigbani ba,
\q1 
\v 20 adama na vuma gbanigbani wi n a̱pa̱m kelime ba,
\q2 kutashi ku vuza gbanigbani ki ta̱ a ku kima̱.
\q1 
\v 21 Maku ma̱ va̱ pana wovon u Ka̱shile n mogono,
\q2 kpamu ka̱ta̱ vu gbaɓa ka̱cika̱nu n a̱ka̱ra̱shi ba,
\q1 
\v 22 adama ana kawuya ki ta̱ a̱ ku ɗa̱nga̱ n moloko we le,
\q2 ya yi u yevei uteku u munuka ma na dem vu le a ku tuka̱?
\s1 Kadanshi ka a̱bunda̱i ka aza ugboji
\p 
\v 23 Nava feu kadanshi ka aza ugboji ka.
\q1 
\v 24 Ya ba dem vu na baci de dem u danai vuza gbanigbani, <<Avu vu nusa ba,>>
\q2 uma i ta̱ a kuyaꞋan kai una̱, ka̱ta̱ uduniya kpamu e ne unata u ni,
\q1 
\v 25 Ama aza na de dem u tsu dansuka vuma gbanigbani wita̱ a kuciya̱ una̱u usingai,
\q2 una̱u usingai wa a̱bunda̱i wi ta̱ a ku cipa̱ wa̱ le.
\q1 
\v 26 Vuza dem u danshi kamayun
\q2 u yotsongu ta̱ cija̱Ꞌa̱ ci singai.
\q1 
\v 27 Lapula biꞋi ulinga u nu ra̱ka̱ pulai,
\q2 kotso ku lapula ili ya ashina i nu ra̱ka̱,
\q2 ka̱ta̱ yeve a ukocishi vu maꞋa kpaꞋa ku nu.
\q1 
\v 28 Ka̱ta̱ vu neke ngaꞋan adama vu toku nu babu ili ba,
\q2 ka̱ta̱ vu dansa a uwa ba.
\q1 
\v 29 Ka̱ta̱ vu dana <<Mpa sai n tsupa u teku tsu na u yaꞋan kai mu ba,
\q2 n ku tsupa ta̱ i na u yaꞋankai mu.>>
\q1 
\v 30 N wala ta̱ n kashina ka korogo,
\q2 n kashina ka vuza vu babu ugboji,
\q1 
\v 31 ɗa menei ka ka shana ta̱ na a wana,
\q2 i ɗika ya kpamu i shanai n mita̱,
\q2 kpamu nshilya n ni n ɓosoi a li iɗika.
\q1 
\v 32 A na menei, ɗa n sheshei u kuna wa,
\q2 ɗa n ciya̱i odoki a nampa.
\q1 
\v 33 Ɗa baci alavu n agbaɗiki a laꞋi nu gan,
\q2 ayin kenu, vo oɓongu ekiye nu adama na vu vuka,
\q1 
\v 34 nanai ɗa unambi wa kufa̱ba̱na̱ wu i li, an vuza ma̱ga̱la̱ka̱,
\q2 ka̱ta̱ kpamu u ɗa u ka̱na̱ wu an koboki.
\c 25
\s1 Ansa o yoku a Sulemanu
\p 
\v 1 Nava feu ansa a Sulemanu a ɗa a na uma Hizekiya mogono ma Yahuda ma pura̱i.
\q1 
\v 2 U Ka̱shile tsugbayin tsu ni tsu ɗa a pala ka kuna,
\q2 ama u mogono tsugbayin tsu ni tsu ɗa u palakpusa ka kuna.
\q1 
\v 3 U teku tsu na gaɗi wi daꞋangi n iɗika,
\q2 ta a̱ɗu an ngono i na atakaci a ku palakpusa nanai.
\q1 
\v 4 Utuka̱ unata u azurufa wa,
\q2 ka̱ta̱ kawakana tamkpamu ka ciya̱ azurufa ana wa ku yaꞋanka u linga,
\q1 
\v 5 u tuka̱ n vuza gbanigbani e kelime ka mogono,
\q2 ka̱ta̱ kakuba ka tsugono ka̱ ni ka ciya̱ ushikpi wu usuɓi.
\q1 
\v 6 Ka̱ta̱ vu utuka̱ kacika̱nu e keteshe e kelime ko mogono
\q2 ko a ubuta̱ wa za a gbagbaꞋin ba,
\q1 
\v 7 adama ana u ku lata̱ n ugaꞋin e ɗeke wu, <<Avu ta̱wa̱ gaɗi na,>>
\q2 an a ku neke wu wono ubuta̱ wa aza a̱ gba̱ra̱-gba̱ra̱.
\q2 I na a̱shi a̱ nu enei,
\q2 
\v 8 ka̱ta̱ vu yaꞋan moloko ma ku banka ubuta̱ wa afada ba,
\q1 adama a na ka̱ta̱ a ukocishi vu namba ili i na va ku yaꞋan ba,
\q2 ɗa baci vutoku nu u nekei nu wono.
\q1 
\v 9 Da̱sa̱ngi i panakpanai n tovu,
\q2 kpamu ka̱ta̱ vu utuka̱ vutoku nu e keteshe ba,
\q1 
\v 10 adama ana ka̱ta̱ aza ana i a kupana ka̱ɗa̱ a zuwa ɗa̱ yo okpo n wono ba,
\q2 ta lo tsugbayin tsu nu tsa yikpa̱.
\q1 
\v 11 Kadanshi kana ka̱ uta̱i ɗe, derere ɗa ka ki,
\q2 tsu ugaꞋin u kazanariya a gaɗi va azurufa.
\q1 
\v 12 Kupana ko odoki a vuza vu ugboji,
\q2 u laꞋa ta̱ ucanuku u tsuloboi u na a kalai n azanari koci.
\q1 
\v 13 Kalingata ku usuɓi,
\q2 ka tsu zuwa ta̱ ka̱ɗu ka aza u suki a̱ ni ma̱za̱nga̱,
\q2 u teku tsu katali ku uta̱ni a ayin usuɗukpi.
\q1 
\v 14 Vuma na u yaꞋin uzuwukpani u na wa ku neke kuneꞋe, kpamu u ciya̱ u neke ba,
\q2 wi ta̱ tsu wunla̱i n eleshu a babu mini.
\q1 
\v 15 N uka̱ni u ka̱ɗu u ɗa a tsu fuɗa a lyaꞋa vuza vu utsura,
\q2 kelentsu kasingai kpamu ka tsu ɓoso ta̱ etele.
\q1 
\v 16 vu ciya̱ baci ishigi, lyaꞋa i ɗa u teku wu u tsura u nu,
\q2 ta lo i ɗa ya laꞋa wu a̱bunda̱i ka̱ta̱ vu shama i ɗa.
\q1 
\v 17 Ka̱ta̱ vu dakaka kubana a kpaꞋa ku tovu ba,
\q2 ta lo wa koꞋo n avu ka̱ta̱ u iwan wu.
\q1 
\v 18 Vuma na dem wu ushuki ku okpo magan ma a uwa u vutoku ni
\q2 wi ta̱ o ku okpo an kalangu ka kuvon ko kotokobi, ko kaya ka alyu.
\q1 
\v 19 Ku ushuku kutono vuza babu usuɓi a ayin atakaci
\q2 wi ta̱ a ku okpo an kanga ka na ka shamai, ko kpamu nwalu n kune kuna ku koɗoi.
\q1 
\v 20 Vuza na baci de dem u yaꞋankai vuza vu una̱mgbi u ka̱tsa̱ma̱ vishipa
\q2 wi ta̱ an vuza na o foɗoi motogu a ayin uta̱ni,
\q2 ko kpamu tsu mini ma kalam ko kakpaɗi a̱ kuntsu.
\q1 
\v 21 Ɗa baci vu enei vurala nu a kambulu, neke yi ilikulya u lyaꞋa n mini kpamu u soꞋo,
\q1 
\v 22 nanai ɗa va ku dyaɓa a̱ga̱ruwa̱shi akina a kaci ka̱ ni,
\q2 ka̱ta̱ Vuzavaguɗu tana u zuwa ka wu una̱singai.
\q1 
\v 23 Tsu na wunla̱ u kasana u tsu tuka̱ n mini,
\q2 ta feu una̱ u vuza gbani-gbani u tsu ka̱ra̱ka̱ n wupa nanai.
\q1 
\v 24 U ku laꞋa ta̱ n ugaꞋin vu da̱sa̱ngu a kunu ku kenu pulai vu kpaꞋa,
\q2 ana va da̱sa̱ngu a kpaꞋa n vuka vu vishili.
\q1 
\v 25 Tsu mini ma̱ ta̱ku a ka̱ɗu ka vu za kakuli,
\q2 ta kadanshi kasingai ki iɗika i daꞋangi ki nanai.
\q1 
\v 26 Vuza vu usuɓi na u ka̱sukpa̱i ka gbani-gbani ka lyai ni,
\q2 wi ta̱ an ka̱shi ka mini ma na ma̱ na̱mgba̱i, ko kayinva ka mini ma tsukono.
\q1 
\v 27 U gaꞋan vu lyaꞋa ishigi n a̱bunda̱i ba,
\q2 ta feu kula̱nsa̱ ku tsugbayin ki nanai.
\q1 
\v 28 Vuma na baci u fuɗa u remei ka̱cika̱ni ba,
\q2 wi ta̱ an likuci i na o ɓosoi mashilya ma̱ ni.
\c 26
\q1 
\v 1 Uteku tsu mini mu uta̱ni a ayin a kpandari,
\q2 ta tsugbayin tsu kpa̱ɗi kugaꞋan n kalau nanai.
\q1 
\v 2 Una̱wuya wi a kulya vuza babu unushi ba.
\q2 wi ta tsu nnu n na n tsu imkpa gaɗi,
\q2 an nwalu babu kucipa̱ iɗika.
\q1 
\v 3 A yaꞋan ta̱ mashashau a dama majaki, iryangama kpamu adama odoku,
\q2 ama kalangu adama alau.
\q1 
\v 4 Ka̱ta̱ vu ushuku kalau n kadanshi ka tsulau tsu ni ba,
\q2 ta lo va ta̱wa̱ vo okpo tsu ni.
\q1 
\v 5 Ushuku kalau, derere n tsulau tsu ni,
\q2 ta lo wa ta̱wa̱ we ene ka̱cika̱ni vuza vu ugboji.
\q1 
\v 6 Ya ba dem vu na u tsu neke kalau a kaka
\q2 u gbatya ta̱ njuvu n ene a̱ ni, kpamu ɗa u la̱nsa̱ka̱i kaci ka̱ ni atakaci.
\q1 
\v 7 Uteku tsu na ene a ma̱kuta̱ i upinda̱ri
\q2 ta ansa i una̱ u kalau nannai,
\q1 
\v 8 Uteku tsu na a tsu kpa̱ɗa̱ kushiya katali a ka̱vimgba̱tsu,
\q2 nanai ɗa feu a tsu kpa̱ɗa̱ ku neke kalau tsugbayin nannai.
\q1 
\v 9 Ansa a una̱ u kalau,
\q2 i ta̱ tsu kawana a kukiye, ka na ko soꞋi ki a ku yaꞋanka ugulani.
\q1 
\v 10 Uteku tsu katain ka na ka tsu yaꞋan matawuka babu ku zuwaka, ali ka̱ta̱ u yaꞋanka uma n a̱bunda̱i muna,
\q2 nannai ɗa vuza na u ɗikai kalau ulinga wi, ta feu vuza na u ɗikai ka̱ka̱ra̱shi wi nannai.
\q1 
\v 11 Uteku tsu na meshe ma tsu shama ka̱ta̱ u bono u peɗe,
\q2 ta kalau ka tsu doku su tsulau tsu ni nannai.
\q1 
\v 12 Vu ene baci vuza na we enei ka̱cika̱ni vuza vu ugboji ɗa,
\q2 kalau ki ta̱ n a̱pa̱ a na a laꞋi ni.
\q1 
\v 13 Korogo ka tsu dana ta̱, <<Mi a̱ ku uta̱ ba, Kawu wi ta̱ lo uye.
\q2 Ka̱di ki ta̱ lo a uye u gbayin.>>
\q1 
\v 14 Uteku tsu na ka̱kpa̱ga̱ ka tsu ka̱na̱ kukpatala n ko obonoi utsutsu,
\q2 ta korogo ka tsu ka̱na̱ ku baꞋinkpusa a kajiba ka̱ ni nannai.
\q1 
\v 15 Korogo ka tsu uka ta̱ kukiye a mevene ma kusan,
\q2 ama ka̱ta̱ u kpa̱ɗa̱ kufuɗa ku banka una̱.
\q1 
\v 16 Korogo ka ce ene ta̱ ka̱cika̱ni,
\q2 vuza vu ugboji ɗa ali u laꞋa uma e cindere usuɓi.
\q1 
\v 17 A̱yi na u cinai vishili vu na vu burai ni ba ɗa u ukai una̱,
\q2 wita̱ tsu vuma na u tsu reme mesheꞋe a kutsuvu.
\q1 
\v 18 Tsu kajarishi ka na ka tsuyaꞋan ugulani n akina n aya koɓolo n ukpa̱,
\q1 
\v 19 ta a̱yi vuma na u doroi vutoku ni,
\q2 ɗa udanai, <<Ai, mpa ugulani u ɗa koci mi a kuyaꞋan.>>
\q1 
\v 20 Nɗanga mi lo baci ba, ɗa akina a tsu kima̱,
\q2 kpamu vuza kuyun wi lo baci ba, vishili vu feu vu tsu kotso ta̱.
\q1 
\v 21 Tsu na cikina tsu yongo n a̱ga̱ruwa̱shi usuɗukpi wa akina, n tsu na nɗanga kpamu n tsu yongo akina,
\q2 ta vuza kula̱nsa̱ ku vishili u tsu yongo nanai.
\q1 
\v 22 Kadanshi ka vuza kuyun ci ilikulya yi uyoꞋo ɗa ki,
\q2 ka tsu laza ta̱, ka̱ta̱ ka uwa a ka̱tsuma̱ ki ikyamba.
\q1 
\v 23 Una̱ wu uyoꞋo koɓolo n ka̱ɗu ka gbani-gbani,
\q2 ki ta̱ tsu mogbodo ma ciꞋin mana a paɗarai n azurufa.
\q1 
\v 24 Vuza cisheꞋe u tsu sokongu ta̱ cisheꞋe tsu ni n una̱ wu uyo,
\q2 ama ka̱ɗu ka̱ni ki ta̱ ushani tukpa n ka gbani-gbani.
\q1 
\v 25 A makyan ma na baci udansai kadanshi ka singai,
\q2 ka̱ ta̱ vu ushuku n a̱yi ba,
\q2 adama ana ka̱ɗu ka̱ ni tukpa ɗa ka ki n kusheshe ki ili yi unata.
\q1 
\v 26 Ko ana wo okpoi wi ta̱ a kusokongu tsurala ci ni n ugboji,
\q2 ama ka gbani-gbani ka̱ ni ki ta̱ a̱ ku uta̱ e keteshe a̱ ka̱tsuma̱ ko oɓolo a u uma.
\q1 
\v 27 Ya ba dem vu na u ga̱va̱i kpenle adama a ka gbani-gbani, wi ta̱ a ku yikpa̱ punu a ku ɗa,
\q2 a̱yi vuza na kpamu u gindalukpai katali, a̱yi ɗa ka ka ku tsugba.
\q1 
\v 28 KayaꞋin ka uwa ka ci iwan ta̱ vuza na u yaꞋankai a uwa,
\q2 ka̱ta̱ vuza vu una̱ uyoꞋo tamkpamu u yaꞋan ta̱ koli.
\c 27
\q1 
\v 1 Ka̱ta̱ vu keɗe a̱pa̱m n makpaꞋa ba,
\q2 adama ana vu yeve u teku tsu na makpaꞋa va uku uta̱ ba.
\q1 
\v 2 Ka̱ta̱ vu cikpa ka̱cika̱nu ba,
\q2 ka̱sukpa̱ uma a cikpa wu, ama ba avu nu una̱ u nu ba.
\q1 
\v 3 Katali ki ta̱ n a̱miki, kayala feu ta nanai,
\q2 ama atakaci a na kalau ka tsu rono a laꞋa le ta̱ a̱miki dem.
\q1 
\v 4 Wupa ili gbanigbani i ɗa, u tsuna ta̱,
\q2 ama dem n nanai u yawa tsurala ba.
\q1 
\v 5 U laꞋa ta̱ vu dansuka vuza e keteshe,
\q2 an va ku yotsongi cigai u sokongi.
\q1 
\v 6 Ka̱ja̱Ꞌa̱ ko ana u la̱nga̱shi nu ka̱ɗu,
\q2 vurala vu ɗa ko ana wo oɓongi nu n a̱bunda̱i.
\q1 
\v 7 Vuza vu ucuwi u tsu cikala n ku soꞋo ishigi ba,
\q2 ama u vuza kambulu ko ili yo okono i ɗa, uyoꞋo u ɗa wi a kupana.
\q1 
\v 8 Tsuna manunu ma tsu ka̱sukpa̱ cikinda ci ni,
\q2 ta feu vuza na u ka̱sukpa̱i kpaꞋa ku ni feu wi nanai.
\q1 
\v 9 Ili ma̱gula̱ni n mani ma ma̱gula̱ni ma tsu neke ta̱ ma̱za̱nga̱ a̱ ka̱ɗu,
\q2 ama ma̱za̱nga̱ ma cija̱Ꞌa̱ mi ta̱ ubuta̱ wa odoki a singai.
\q1 
\v 10 Ka̱ta̱ vu iwan ka̱ja̱Ꞌa̱ ka̱ nu ba, ko ka̱ja̱Ꞌa̱ ka Dada vu nu ba,
\q2 kpamu ka̱ta̱ vu bana a kpaꞋa ku tovu, a kanna kana vi nu una̱mgbi u ka̱tsuma̱ ba.
\q1 u laꞋa ta̱ n kugaꞋan n vuza na yi ida̱shi ɗeɗevu
\q2 n toku nu vu na wi daꞋangi.
\q1 
\v 11 Gbojo, maku ma̱va̱ adama ana ka̱ɗu ka̱va̱ ka yaꞋan ma̱za̱nga̱,
\q2 adama ana n neke wu ushuki u vuza na u goyoi mu.
\q1 
\v 12 Vuza vu ugboji u tsu ene ta̱ ka gbani-gbani ka̱ ta̱ u suma,
\q2 ama vuza vu unambi wu ugboji u tsu bana ta̱ ka̱ta̱ tana u takacika.
\q1 
\v 13 Isa motogu ma vuza na wu ushuki ku okpo magan mo komoci,
\q2 n ma vuza na wu ushuki ku okpo magan ma kashakanlai.
\q1 
\v 14 Vuza na baci de dem u jimgbasai vutoku n kacaꞋa n usana,
\q2 derere ɗa n ishikushi i ni.
\q1 
\v 15 Vuka vu vishili,
\q2 vita̱ an kacaꞋa ki ijaꞋashi i mini,
\q1 
\v 16 ɗa baci vu danai vi ta̱ a ku sa̱nka̱i, ka̱ta̱ wo okpo an usa̱nki u wunla̱
\q2 ko tsu ku reme ku mani ma agujiyan n kataka ka kukiye.
\q1 
\v 17 Tsu na vuyum vu tsu gboro vuyum
\q2 ta feu vuma n vuma o tsu ɓa̱nka̱na̱i nanai.
\q1 
\v 18 Vuza na u tsu la̱na̱ maɗanga ma ma̱biri u tsu lyaꞋa ta̱ umaci u ni,
\q2 ama vuza na u tsu la̱na̱ vuzagbayin vu ni, wi ta̱ a̱ kuciya̱ tsugbayin.
\q1 
\v 19 Tsu na vuma u tsu inda ka̱cika̱ni a mini,
\q2 ta feu ka̱ɗu ka vuma ka tsu yotso vuma nanai.
\q1 
\v 20 Asaun n ukpisa̱ a tsu cuwa̱ ba
\q2 ta feu a̱shi a uma a̱ tsu kpa̱ɗa̱ kucuwa̱ nanai.
\q1 
\v 21 Azanariya n azurufa n akina aɗa a tsu kondo a ɗa,
\q2 ta feu vuma nanai a tsu kondoi ta̱ ubuta̱ u kucikpa u ni.
\q1 
\v 22 Jara kalau n mashin a̱ ma̱suku
\q2 tsu kiya ku ilya,
\q2 dem n nanai tsulau tsu ni ci a ku kotso ba.
\q1 
\v 23 La̱na̱ ushiga wi ili kuzuwa i nu,
\q2 ka̱ta̱ kpamu vu yeve ma̱ta̱na̱ ma anaka a̱ nu,
\q1 
\v 24 adama ana uciyi u tsu geshe ali a kubana u teku ba,
\q2 ta feu tsugono ci nanai, tsu ci geshe ali n tsukaya ba.
\q1 
\v 25 A tsu kana ta̱ mita̱ ka̱ta̱ masavu mo topo
\q2 a tsu ɓolongu ta̱ kpamu a̱vuku adama anaka,
\q1 
\v 26 a tsu tsuyaꞋan ta̱ aminya n cileme tsa nlala,
\q2 a tsu cimba ta̱ kpamu kashina n ikebe ya nraɗika.
\q1 
\v 27 I ta̱ a kuciya̱ mani ma nraɗika ma kulyaꞋa ba̱ri,
\q2 mana ma ku lyaꞋatangu kpaꞋa ku nu
\q2 koɓolo n a kabashi n nkere n nu.
\c 28
\q1 
\v 1 Vuma gbanigbani u tsu ka̱na̱ ta̱ ilaɗi gbani, babu vuza na wi a kusaɓa yi,
\q2 ama aza usuɓi a tsu shamgba ta̱ ba̱ri an kawu.
\q1 
\v 2 Iɗika yi baci a kuyaꞋan kagbanigbani, ɗa i tsu ka̱na̱ kusabaꞋa ngono,
\q2 ama ubuta̱ u na baci mogono mi n ugboji n kuyeve,
\q2 iɗika i tsu shamgba ta̱ ka̱ta̱ i geshe.
\q1 
\v 3 Vuza tsugono na utsu doro uma a̱ ni,
\q2 wita̱ an mini ma atali ma na ma tsu la̱nga̱sa̱ ili kashina.
\q1 
\v 4 A̱yi na u tsu iwan kutono wila̱, wita̱ koɓolo n aza a gbanigbani,
\q2 ama ɗa baci vi a kutono wila̱ a vu vurala va aza gbanigbani ɗa.
\q1 
\v 5 Uma gbanigbani e yeve kasingai ba,
\q2 ama aza kutoni ku Yesu e yeve ta̱ ka mayin.
\q1 
\v 6 Ulata̱ vokpo vuza vu unambi vu kasingai,
\q2 an va kokpo vuza vu uciyi vu gbanigbani.
\q1 
\v 7 A̱yi na u tsu tono wila̱, maku mu ugboji maꞋa,
\q2 ama ka̱je ka ka̱ka̱ra̱shi u tsu ronoko ta̱ dada ni wono.
\q1 
\v 8 Ɗa baci vu ciya̱i udukuyan ubuta̱ u gbanigbani,
\q2 udukuyan wa wita̱ a ku bono ubuta̱ wa aza na i a kuyaꞋan ka a za unambi kasingai.
\q1 
\v 9 Ɗa baci vuma u iwain kutono wila̱ u Ka̱shile,
\q2 ko kavasa ka̱ ni feu, ili yu unata i ɗa.
\q1 
\v 10 Aza na a tsu zuwa uma usuɓi a yaꞋan unushi
\q2 i ta̱ a ku yikpa̱ e kpenle kuna a̱ga̱pa̱i,
\q2 ama aza babu u nushi i ta̱ a kuciya̱ ili singai.
\b
\q1 
\v 11 Aza uciyi a ci ɗika ta̱ ka̱cika̱ le aza ugboji,
\q2 ama vuzavunambi vu ugboji u yeve ta̱ i na igain.
\p 
\v 12 Ɗa baci vuza vu usuɓi u ciya̱i ulyai, ya ba dem u tsu yaꞋan ta̱ ma̱za̱nga̱.
\q2 Ama ɗa baci vuza gbanigbani u ciya̱i ulyai, uma a̱ tsu la̱nsa̱ta̱ ubuta̱ a sheɗeku.
\q1 
\v 13 Aza na a tsu sokongu unushi u le, wa kuciya̱ ulyai ba,
\q2 ama ya ba dem vuna u dansai ɗa u ka̱sukpa̱i u ɗa, i ta̱ a ku pana asuvu ayali a̱ ni.
\q1 
\v 14 Aza a na a tsu pana wovon u Ka̱shile ayin tutu, a tsu yongo ta̱ n ma̱ta̱na̱,
\q2 ama ɗa baci u yaꞋan ugbamukaci wita̱ a kuna̱mgba̱.
\q1 
\v 15 Tsugono tsu gbanigbani cita̱ an maza ma gbanigbani ubuta̱ wa aza unambi,
\q2 an kawu ko kakunzu ka munuka.
\q1 
\v 16 Mogono ma na mi n kuyeve ba, wita̱ a ku doro uma a̱ ni,
\q2 ama vuza na u iwain kalya wita̱ a kuciya̱ wuma wu ugaɗi.
\q1 
\v 17 Vuza ma̱ga̱la̱ka̱ na wi n mpasa n uma ekiye ni, a ku takacikayi, wita̱ a ku ka̱na̱ ilaɗi a li ukpisa̱ u ni.
\q2 Ka̱ta̱ i ɓa̱nka̱i ba.
\q1 
\v 18 Ɗa baci vu yaꞋan ku usuɓi, vi ta̱ a kuda̱sa̱ngu n ma̱ta̱na̱,
\q2 ama vuza gbanigbani i ta̱ a kunai babu usa̱n.
\q1 
\v 19 Kacimbi kana ka tsu yaꞋan ulinga wa a̱bunda̱i, ka ci ciya̱ ta̱ ilikulya ya a̱bunda̱i,
\q2 ama vuza na u tsu ciga gbani, wita̱ a kuroko ka̱cika̱ni unambi.
\q1 
\v 20 Vuza vu usuɓi wita̱ a kuciya̱ uciyi wa a̱bunda̱i
\q2 ama vuza na u tsu la̱nsa̱ uciyi gogo, wita̱ a ku uwa atakaci.
\q1 
\v 21 KuyaꞋan ku kazagba kugan ba,
\q2 ama dem n nanai adama ilikulya, vuma wita̱ a ku fuɗa wa yaꞋan unushi.
\q1 
\v 22 Aza ulyopi a ci ciga ta̱ a ciya̱ uciyi gogo,
\q2 ka̱ta̱ u kpa̱ɗa̱ kuyeve a na a okpo aza unambi babu usa̱n ba.
\q1 
\v 23 Ya ba dem vu na u dansukai toku wita̱ a kuciya̱ ucikpi a ayin ukoci,
\q2 ka̱ta̱ ula vuza na u yaꞋankai ni una̱ wu uyoꞋo.
\q1 
\v 24 Vuza na de dem ubokoi ucanuku u dada ni n a̱kpa̱ ni
\q2 ɗa u danai, <<Ai na lo i yoku i ɗa ba.>>
\q2 a̱yi n vuza ma̱ga̱lka̱ derere ɗa i.
\q1 
\v 25 Kutsa̱n ku tsu tuka̱ta̱ n vishili,
\q2 ama vuza na u tsu keɗike Ka̱shile ma̱ka̱nga̱, wita̱ a kuciya̱ uciyi wa a̱bunda̱i.
\q1 
\v 26 Aza na e ci keɗike ka̱cika̱ le a̱pa̱ alawu a ɗa,
\q2 ama ya ba dem vuna u walai n ugboji wita̱ a kulaka.
\q1 
\v 27 Ya ba dem vuna u cineke aza unambi ba̱ri, wi a kunamba ba ili ba,
\q2 ama a̱yi na u tsu yimba̱ku a̱shi a̱ ni we e le, i ta̱ a kila̱kpa̱i.
\q1 
\v 28 Ɗa baci aza gbanigbani i a kulya tsugono, uma a tsu sheɗeku ta̱.
\q2 ama ayin na baci tsugono tsuta̱ ekiye e le uma usuɓi o tsu doku ta̱.
\c 29
\q1 
\v 1 Vuza na baci de dem wi n ugbamukaci, ɗa u kpa̱ɗa̱i ku pana udansuki,
\q2 i ta̱ a kuɓosoyi, ali ula uteku tsu na a ku fuɗa a lapula.
\q1 
\v 2 Aza usuɓi i baci a tsugono, uma a tsu pana ta̱ uyoꞋo.
\q2 Ama ɗa baci aza a gbanigbani i o tsugono, uma a tsu ka̱na̱ ta̱ mololo.
\q1 
\v 3 Vuma na u ci ciga ugboji, u tsu zuwa ta̱ dada ni ma̱za̱nga̱,
\q2 ama koto ni ka ashakanlai, ka̱ tsu la̱nga̱sa̱ ta̱ udukuyan u ni.
\q1 
\v 4 Mogono mu usuɓi ma tsu zuwa ta̱ iɗika i ni i gan,
\q2 ama vuza na u tsu la̱nsa̱ kalya, u tsu la̱nga̱sa̱ ta̱ i ɗika i ni.
\q1 
\v 5 Vuza na u tsu yaꞋanka toku ni una̱ wu uyoꞋo,
\q2 maza ma u tsu shikpa̱ka̱ a ene e le.
\q1 
\v 6 Unushi u vuza gbanigbani u tsokpo ta̱ maza wa̱ni,
\q2 ama vuza vu usuɓi u tsu laꞋaka ta̱, ka̱ta̱ worokpo n ma̱za̱nga̱.
\q1 
\v 7 Vuza vu usuɓi u tsu dama ta̱ adama aza unambi,
\q2 ama, vuza gbanigbani u tsu yeve n ka nanlo ba.
\q1 
\v 8 Aza a gbanigbani a tsu zuwa ta̱ likuci ra̱ka̱ i dagaza,
\q2 ama aza usuɓi a tsu vaꞋanka ta̱ uma a̱ɗu.
\q1 
\v 9 Ɗa baci vuza vu ugboji u bankai kalau ubuta̱ wa afada,
\q2 ka̱ta̱ kalau ka ka̱na̱ izoshi n wupa, ka̱ta̱ kadanshi ka kpa̱ɗa̱ ku kotso.
\q1 
\v 10 Aza a̱ ma̱ga̱lka̱ a ci ciga aza a babu unushi ba,
\q2 ama aza usuɓi a tsu la̱nsa̱ ta̱ uteku tsuna a ɓa̱nka̱ le.
\q1 
\v 11 Alau a tsutuka̱ta̱ tsulau ci le e keteshe,
\q2 ama aza ugboji a tsu sokongu ta̱ ci le.
\q1 
\v 12 Ɗa baci monogo mushuku yi n kadanshi ka aza uwa,
\q2 ana ntaji a̱ ni ra̱ka̱ ita̱ a kokpo aza a gbanigbani.
\q1 
\v 13 Aza unambi n aza kalya dem vu le kete ka i,
\q2 Vuzavaguɗu ɗa u nekei le a̱shi adama e kene.
\q1 
\v 14 Ɗa baci mogono ma yaꞋankai vuza vu unambi afada a singai,
\q2 tsugono tsu ni ci ta̱ a kugeshe ali ntsukaya.
\q1 
\v 15 Ugbari u maku u tsu tuka̱ta̱ n ugboji,
\q2 ama maku magbanigbani ma tsu neke ta̱ a̱na̱kpa̱ ni wono.
\q1 
\v 16 Ɗa baci aza a gbanigbani i o tsugono, kagbanigbani ka tsu yimkpa ta̱,
\q2 ama aza usuɓi i ta̱ a kuzuwa le a yikpa̱.
\q1 
\v 17 Gbara muku n nu, i ta̱ a ku neke wu ma̱ta̱na̱ ma ka̱ɗu
\q2 ka̱ta̱ a zuwa wu ma̱za̱nga̱.
\q1 
\v 18 Ɗa baci ubuta̱ wi babu kadanshi ka Ka̱shile, uma a tsu yaꞋanta̱ ida̱shi kavama.
\q2 Ama vuza ma̱ta̱na̱ ɗa a̱yi na u tonoi wila̱ u Ka̱shile.
\q1 
\v 19 Kadanshi ku una̱ koci ka kugbara kagbashi ba,
\q2 adama na wita̱ a kupana ka̱ta̱ uyeve ama wa ku yaꞋan ili ba.
\q1 
\v 20 Ka̱shile ka tsu kuɓa̱nka̱ ta̱ kalau gogo,
\q2 u laꞋa vuza kadanshi gogo babu cico.
\q1 
\v 21 Vuza na baci uleꞋeshei kagbashi tun a̱yi kenu,
\q2 a ukoci wita̱ a kuɗika ka̱cika̱ni maku makpaꞋa.
\q1 
\v 22 A za na a tsu yaꞋan wupa gogo, a tsu ɗengusa̱ta̱ vishili,
\q2 ka̱ta̱ kpamu a yaꞋan unushi wa a̱bunda̱i.
\q1 
\v 23 A̱ra̱ɗi a vuma a tsu tuka̱i ta̱ n kugoyi,
\q2 ama ma̱riki mita̱ a kutuka̱ n tsugbayin.
\q1 
\v 24 Vuma na de dem u yaꞋan cija̱Ꞌa̱ n koboki, u ciga wuma u ni ba.
\q2 ɗa baci a ɗeke ni tsugan ubuta̱ wa afada, u kupaɗa ta̱ bini.
\q1 
\v 25 Kupana ku wovon u vuma, maza maꞋa
\q2 ama vuza na uzuwakai Ka̱shile a̱pa̱m u kuciya̱ ta̱ ma̱ta̱na̱.
\q1 
\v 26 Uma n a̱bunda̱i a̱ tsu la̱nsa̱ ta̱ ucigi ubuta̱ wa ngono,
\q2 ama afada usuɓi, a Ka̱shile ka a ɗa i.
\q1 
\v 27 I na vuza vu usuɓi u cigai ba, i ɗa kayan ka uwa,
\q2 i na tankpamu vuza gbanigbani u cigai ba, i ɗa vuza vu usuɓi.
\c 30
\s1 Akaka a Agu
\p 
\v 1 Akaka a Agu kolobo ka Yake.
\q1 Vuma va u danai, Vuzavaguɗu Ka̱shile moꞋuta̱
\q2 Mpa moꞋuta̱, Vuzavaguɗu, utsura u va̱ u kotso ta̱.
\q1 
\v 2 Mayun mpa n lata̱ ya ba dem tsulau.
\q2 mi n kuyeve tsu uma.
\q1 
\v 3 Mpa n la̱nsa̱ kuyeve ku ugboji ba,
\q2 mpa kpamu n yeve vuza ciɗa vu nanlo ba.
\q1 
\v 4 Ya yi u sawai ku kumba gaɗi ɗa u cipa̱i?
\q2 Ya yi u sawai kureme wunla̱ a kataka ka kukiye ka ni?
\q1 Ya yi u sawai ku ka̱ta̱la̱ mini a kuminya ku ni?
\q2 Ya yi kpamu u shikpa̱i uteku wu uduniya?
\q1 Ya yi a ci ɗeke kula ku ni, kpamu ya yi a ci ɗeke kula ku maku ma̱ ni?
\q2 Dana mu, vu yeve ba ci.
\q1 
\v 5 Kadanshi ka Ka̱shile ra̱ka̱ mayun ɗa,
\q2 ma̱ra̱ga̱ ma a, wa aza na a̱ la̱nsa̱i kusheɗeku wa̱ a̱ ni.
\q1 
\v 6 Ka̱ta̱ vu doku kadanshi ka̱ ni ba,
\q2 ta lo wa ku dansuka wu ka̱ta̱ vokpo kayan ka uwa.
\q1 
\v 7 Vuzavaguɗu i li ire i ɗa n la̱nsa̱i wa̱ nu,
\q2 yaꞋan ka mu i ɗa kafu n kuwa̱.
\q1 
\v 8 Takpa ukuna wa uwa u bana dangi n mpa,
\q2 ka̱ta̱ vu neke mu uciyi ko unambi ba,
\q2 ama neke mu ilikulya derere n ucigi u va̱,
\q1 
\v 9 ta lo ma cuwa̱ ka̱ta̱ n cinukpa n a̱vu,
\q2 ka̱ta̱ n dana <<Ya yi Vuzavaguɗu>>
\q1 ko kpamu n namba ka̱ta̱ n boko,
\q2 ka̱ta̱ n la̱nga̱sa̱ kula ku ka Ka̱shile ka̱ va̱.
\b
\q1 
\v 10 Ka̱ta̱ vu la̱nga̱sa̱ kagbashi kula ubuta̱ u vuzagbayin vu ni ba,
\q2 ta lo va yaꞋan unushi u na a kila̱kpa̱ wu.
\q1 
\v 11 N kukece ta̱ ili gbaniꞋgbani i na̱shi i na uma a ci yaꞋan,
\q2 aza yoku a ci shika ta̱ ishekpu i le
\q2 ka̱ta̱ a̱ kpa̱ɗa̱ ku cikpa ina̱kpu i le.
\q1 
\v 12 Aza yoku a ce ene ta̱ ka̱cika̱le i ta̱ ciɗa,
\q2 ashe tana i ta̱ nu unata.
\q1 
\v 13 Aza yoku i ta̱ na a̱ra̱ɗi,
\q2 a ci ɗika ta̱ ka̱cika̱le e le va ili yoku i ɗa.
\q1 
\v 14 Aza yoku anga e le otokobi a ɗa,
\q2 atakpamkpatsu e le kpamu mawun ɗa,
\q1 adama na okotsotongu aza unambi uduniya ra̱ka̱,
\q2 n ofoloni ra̱ka̱ a ka̱tsuma̱ ka uma.
\q1 
\v 15 Kutsa̱n ki ta̱ n nkere nre. A ci ɗeke le ta̱.
\q2 Nemu koɓolo n Nemu.
\q1 Ili tatsu yi ta̱ lo i na i ci cuwa̱ ba,
\q2 Ali i na̱shi i na i ci dana <<U yawa mu ta̱ ba.>>
\q1 
\v 16 E le ɗa, asaun, n ka̱tsa̱ma̱ ka madari ma na ma maci ba,
\q2 n iɗika i na ka̱ta̱ i cuwa̱i n mini ba,
\q2 n akina a na a sawai ku dana, <<U yawa mu ta̱ ba,>>
\q1 
\v 17 A̱shi a na o goyoi dada
\q2 ɗa a iwain kucikpa mma
\q1 agawun a kuyene i ta̱ a kuta̱sa̱ a ɗa
\q2 ka̱ta̱ asakali a takuma le.
\q1 
\v 18 I li itatsu ɗa yi a ku neke mu mereve,
\q2 a li i na̱shi i na n yeve ba
\q1 
\v 19 u teku tsu na kajimba ka tsu wala gaɗi,
\q2 u teku tsu na koko ka tsu wala a katali,
\q1 u teku tsu na kpantsu ku tsu wala a mini,
\q2 n uteku tsu na mavali ma tsu yaꞋan n mekere.
\q1 
\v 20 Na ɗa u teku tsu na kashakanlai ki
\q2 u lyaꞋa ba ci ka̱ta̱ u gboro una̱
\q2 ka̱ta̱ u dana, <<Mpa n yaꞋan u nushi ba.>>
\q1 
\v 21 I li yi ta̱ lo i na̱shi
\q2 i na vuza u duniya u ku fuɗa ku yaꞋan ahankuri i ɗa ba,
\q1 
\v 22 kagbashi ɗa baci kokpoi mogono,
\q2 n kalau a yaꞋan na baci ka̱cuwa̱i n ilikulya,
\q1 
\v 23 ɗa baci vuka vu unambi u mapasa u ciya̱i vali,
\q2 n kagbashi ka na ka gadai a̱na̱ku a̱ ni.
\q1 
\v 24 I li i kenu i na̱shi feu yi ta̱ lo u duniya,
\q2 ama i ta̱ n ugboji ka̱u,
\q1 
\v 25 Ojuno i nu utsura ba,
\q2 ama a tsu la̱nsa̱ ta̱ ilikulya i le n lyushi
\q1 
\v 26 Rema nnama n ɗa n na mi babu utsura,
\q2 ama dem n nanai a ci maꞋa ta̱ i uwa i le a tali,
\q1 
\v 27 Akyun i n mogono ba,
\q2 ama dem n nanai a tsu wala ta̱ magaba,
\q1 
\v 28 Karagba, vi ta̱ a kufuɗa vu ka̱na̱i n ekiye,
\q2 dem n nanai a tsu uwa ta̱ a kefeku ka mogono.
\q1 
\v 29 Ili i tatsu yi ta̱ lo,
\q2 ali i na̱shi i na i tsu wala n atankama.
\q1 
\v 30 E le ɗa kawu, a̱ yi na ulai ya ba dem mgbayin a ka̱tsuma̱ ka nnama,
\q2 a̱ yi na u tsu kpatala adama a vu toku ba,
\q1 
\v 31 n kepen ki isali n ma̱ga̱ji,
\q2 koɓolo n mogono ma na mi koɓolo n osoji a̱ ni.
\q1 
\v 32 Ɗa baci vi ɗe a tsulau, a ku yaꞋanka ka̱cika̱ nu a̱ra̱ɗi
\q2 ko kpamu a fama an foɓo adama kagbani-gbani,
\q2 to pala una̱ u nu n kukiye.
\q1 
\v 33 tsu na kukuciwa ku mani ku tsu tuka̱ n maniꞋin,
\q2 u pinda̱ri u vunu kpamu u zuwa mpasa mu uta̱ a vunu,
\q2 ta feu wupa u tsu tuka̱ n vishili nanai.
\c 31
\s1 Kadanshi ka mogono Lemuwelu
\p 
\v 1 Na ɗa kadanshi ka mogono Lemuwelu. Kana a̱na̱ku a̱ ni o yotsongi ni.
\q1 
\v 2 Yiɗa̱i vi a kuyaꞋan maku ma̱ va̱? Yiɗa̱i vi a kuyaꞋan maku ma̱ va̱, maku ma̱ va̱ ma na n matsai?
\q2 Yiɗa̱i vi a kuyaꞋan, maku ma a kucina ma va̱?
\q1 
\v 3 Ka̱ta̱ vu neke katsura ka̱ nu ubuta̱ wa a̱ma̱ci ba,
\q2 ko kpamu vu bonoko ugboji u nu wa aza na a tsu takacika ngono.
\q1 
\v 4 Ugain u ɗa a vu Lemuwelu,
\q2 Ugan mogono ma soꞋo ma̱ra̱ ba,
\q2 ko ngono n soꞋo ma̱ra̱ mu utsura ba,
\q1 
\v 5 ta lo a ta̱wa̱ a cinukpa n wila̱ u na o tonoi,
\q2 ka̱ta̱ a iwan kamayun ka uma a na o doroi.
\q1 
\v 6 Neke vuza na wi a ku kuwa̱ ma̱ra̱ mu utsura,
\q2 ma̱kya̱n tamkpamu wa aza na i nu una̱mgbi u ka̱tsuma̱,
\q1 
\v 7 ka̱sukpa̱i le o soꞋo ka̱ta̱ a cinukpa n unambi u le
\q2 a̱ kpa̱ɗa̱ ku ciɓa n atakaci e le kpamu.
\q1 
\v 8 YaꞋan kadanshi adama ebebe a na a tsu dansa ba,
\q2 na aza na i na a̱ɓa̱nki ba.
\q1 
\v 9 Ɓa̱yuwa̱ una̱ adama na vu dansa afada asingai,
\q2 ɓa̱nka̱ aza unambi n ofoloni.
\s1 Vuka vu na vu tsu pana wovon u Ka̱shile
\q1 
\v 10 Yayi wa kufuɗa ku ciya̱ vuka vu usuɓi?
\q2 U lata̱ kazanariya ugain.
\q1 
\v 11 Vali ni u tsu ushuku ta̱ n a̱yi,
\q2 ka̱ta̱ tana u ciya̱ ili ra̱ka̱ i na u cigai.
\q1 
\v 12 U tsu yaꞋankai ta̱ kasingai, ba ka gbani-gbani ba,
\q2 a ayin a wuma a̱ ni dem.
\q1 
\v 13 U tsu la̱nsa̱ ta̱ tsugbere tsu tsuzogu ka̱ta̱ u yaꞋan kuca n ekiye a̱ ni n ma̱ta̱na̱.
\q1 
\v 14 Wi ta̱ an kpantsu ka aza tsulaga,
\q2 u tsu tuka̱ ta̱ n ilikulya i ni dangi.
\q1 
\v 15 U tsu ɗa̱nga̱ ta̱ n kpasani
\q2 ka̱ta̱ u yaꞋanka aza a kpaꞋa ilikulya
\q2 ka̱ta̱ u buka kpamu abara a̱ ni.
\q1 
\v 16 U tsu la̱na̱ ta̱ kashina mayin kafu u tsula,
\q2 n atakaci ulinga a̱ ni a ɗa u tsu shikpa̱ kashina ka nɗanga.
\q1 
\v 17 U tsu zuwa ta̱ ka̱ɗu
\q2 ka̱ta̱ u yaꞋan ulinga n utsura.
\q1 
\v 18 U tsu yeve ta̱, ɗa baci kodokpotsu ka uwa ni.
\q2 ma̱kuni ma̱ ni ma tsu yongo ta̱ a kutasa ali kayin washi.
\q1 
\v 19 Na ekiye a̱ ni a ɗa u tsu ka̱na̱ tsugbere
\q2 na ekiye a̱ ni a ɗa kpamu u tsu yaꞋan kucaꞋa.
\q1 
\v 20 U tsu neke ta̱ aza unambi ba̱ri,
\q2 koɓolo n ofoloni feu nanai.
\q1 
\v 21 U tsu pana wovon u a yaꞋan uta̱ni ba,
\q2 adama na muku n ni ra̱ka̱ mita̱ ntogu mu uta̱ni.
\q1 
\v 22 U tsu caꞋa ka ta̱ ka̱cika̱ni mayaga ma a̱ga̱da̱,
\q2 aminya a̱ ni tsugbere tsu ɗa tsu singai tsu mini ma garula.
\q1 
\v 23 Vali ni vuza vu uyevi ɗa o koɓolo ka uma
\q2 ɗa baci u da̱sa̱ngi koɓolo n tsugbayin tsu likuci.
\q1 
\v 24 U tsu caꞋa ta̱ aminya a tsugbere ka̱ta̱ u denge.
\q2 U tsu denke ta̱ a za tsulaga aɗambura.
\q1 
\v 25 Uciyi koɓolo n usuɓi u ɗa aminya a̱ ni,
\q2 wi ta̱ o ku zoꞋoso a a yaꞋan e kelime.
\q1 
\v 26 U tsu yaꞋan ta̱ kadanshi n ugboji,
\q2 kuyotsongu ku ni ku singai ku ɗa.
\q1 
\v 27 U tsu la̱na̱ ta̱ muku ni mayin,
\q2 a̱ yi ili bura yi n wonvoli ba.
\q1 
\v 28 Muku ni n tsu ɗa̱ngu ta̱ ka̱ta̱ a cikpai
\q2 vali ni feu u tsu cikpai ta̱.
\q1 
\v 29 U tsu dana ta̱, <<A̱ma̱ci n a̱bunda̱i a tsu yaꞋan ta̱ i na a cikpa le,
\q2 ama avu vu laꞋa le ta̱ dem.>>
\q1 
\v 30 KuyaꞋan ku gaye u kuna u gbani u ɗa,
\q2 ama vuka vu na vu tsu pana wovon u Ka̱shile, a̱ yi ɗa ili ku cikpa.
\q1 
\v 31 Neke ni katsupu ka atakaci ulinga a̱ ni,
\q2 ka̱ta̱ ugain wu ulinga u ni kpamu wu utuka̱i e keteshe.
