\id MAL
\h مَالَاخِي 
\toc1 مَالَاخِي 
\toc2 مَالَاخِي 
\toc3 مـَال. 
\mt1 مَالَاخِي  
\c 1
\s1 ثَايْرِي ن سِيذِي إِ إِسْرَائِيل  
\m
\v 1 ڒْحُوكْمْ إِسَّاڭّْوَاذنْ. أَوَاڒْ ن سِيذِي إِ إِسْرَائِيل س ؤُفُوسْ ن مَالَاخِي.   
\b  
\m
\v 2 ”نشّْ ثُوغَا تّخْسغْ شكْ، إِقَّارْ سِيذِي، مَاشَا كنِّيوْ ثقَّارمْ: ’مَانِي ذ أَنغْ ثخْسذْ؟‘ مَا وَارْ إِدْجِي عِيسُو ذ ؤُمَاسْ ن يَاعْقُوبْ، إِقَّارْ سِيذِي، ؤُ نشّْ تّخْسغْ يَاعْقُوبْ، \x ◘ \xo 1:‏2 \xt رُوم. 9‏:‏13\x*  
\v 3 \add مَاشَا\add* شَارْهغْ عِيسُو. نشّْ أَرِّيغْ إِذُورَارْ نّسْ ذ إِشْثْ ن ثمُّورْثْ إِتّْوَاردّْدْجنْ ؤُڒَا ذ ثَاسْغَارْثْ نّسْ إِ وُوشَّاننْ ن ڒخْڒَا.  
\v 4 وَاخَّا إِذُومْ إِقَّارْ: ’نشِّينْ نتّْوَاردّدْجْ، \add مَاشَا\add* أَذْ نبْنَا ڒْخِيرْبَاثْ عَاوذْ!‘، أَمُّو إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ: نِيثْنِي أَذْ بْنَانْ \add عَاوذْ\add*، \add مَاشَا\add* نشّْ أَذْ هذْمغْ ؤُ أَذْ أَسنْ ڒَاغَانْ ’ثَامُّورْثْ ن ؤُعفَّانْ‘، ؤُ \add عَاوذْ\add*: ’ڒْڭنْسْ ونِّي خْ إِسخّضْ سِيذِي إِ ڒبْذَا!‘  
\v 5 ثِيطَّاوِينْ نْومْ أَذْ ث ژَترنْ ؤُ كنِّيوْ أَذْ ثِينِيمْ: ’ذ أَمقّْرَانْ سِيذِي ثِيوَا إِ ثمُّورْثْ ن إِسْرَائِيل!‘ “   
\b  
\m  
\s1 ذْرُوسْ ن ؤُوقَّارْ إِ ثْقدَّاسْثْ ن سِيذِي جَارْ ڒْڭنْسْ  
\m
\v 6 ”مِّيسْ إِتّْوقَّارْ بَابَاسْ ذ ؤُمْسخَّارْ بَابْ نّسْ. مَاڒَا نشّْ أَقَا ذ بَابَا، مَانِي إِقِّيمْ \add خنِّي\add* ڒوْقَارْ إِ نشّْ؟ مَاڒَا نشّْ أَقَا ذ سِيذِي، مَانِي ثقِّيمْ ثِيڭّْوُوذِي نِّي زَّايِي؟، إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ، إِ كنِّيوْ، \add أَ\add* إِكهَّاننْ، إِنِّي إِسّحْقَارنْ إِسمْ إِنُو. \add مَاشَا\add* كنِّيوْ ثقَّارمْ: ’مِينْ زِي نسّحْقَارْ نشِّينْ إِسمْ نّشْ؟‘  
\v 7 كنِّيوْ ثتَّاوْيمْ-د أَغْرُومْ إِخمْجنْ خْ ؤُعَالْطَارْ إِنُو، ثقَّارمْ: ’مِينْ زِي إِ شكْ نسّْخمّجْ؟‘ مِينْ زِي أَقَا كنِّيوْ ثقَّارمْ: ’ثَازوْضَا ن سِيذِي ذ ثَامحْقُورْثْ.‘  
\v 8 مَاغَارْ ؤُمِي كنِّيوْ ثتَّاوْيمْ مِينْ إِدْجَانْ ذ أَضَارْغَاڒْ إِ ثَاغَارْصْثْ، مَا وَارْ إِدْجِي أَيَا ذ ڒْغَارْ؟ ؤُ خْمِي غَا ثَاوْيمْ كنِّيوْ مِينْ إِدْجَانْ ذ أَقجْذَاحْ نِيغْ مِينْ إِهڒْشنْ، مَا وَارْ إِدْجِي أَيَا ذ ڒْغَارْ! سِيوضْ أَيَا إِشْثْ ن ثْوَاڒَا غَارْ لْوَالِي. مَا شكْ أَذْ أَسْ د-ثَاسذْ خْ ڒْخَاضَارْ نِيغْ نتَّا أَذْ يِيڒِي مْلِيحْ أَكِيذكْ؟، إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ.“   
\m
\v 9 ”\add خنِّي\add* ڒخُّو، أَرْزُومْ ؤُذمْ ن أَربِّي، \add حِيمَا\add* نتَّا أَذْ خَانغْ إِحِينّْ. \add مَاشَا\add* مَانْ أَيَا إِتّْوَاڭّْ زَّايْومْ! مَا أَذْ يِيڒِي س نّيّثْ ثشْنَا إِ يِيجّْ زَّايْومْ؟، إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ.  
\v 10 مَانْ ونْ زَّايْومْ إِ غَا إِبلّْعنْ \add خنِّي\add* ثِيوُّورَا، \add أَڒَامِي\add* نِيثْنِي وَارْ تّسْرِيقِّينْ \add عَاذْ\add* أَعَالْطَارْ إِنُو بَاطڒْ. نشّْ وَارْ ذَايْومْ تِّيفغْ أَرْضَا، إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ، ؤُ \add ؤُڒَا ذ\add* ثَاوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* زڭْ ؤُفُوسْ نْومْ وَارْ د-ثتِّيسْ خْ ڒْخَاضَارْ إِنُو. \x ◘ \xo 1:‏10 \xt إِشا. 1‏:‏11؛ إِرْم. 6‏:‏20؛ عَام. 5‏:‏21، 22\x*  
\v 11 مَاغَارْ زِي مَانِي د ثْنقَّارْ ثْفُوشْثْ أَڒْ مَانِي ثْغدْجِي، أَذْ يِيڒِي يِيسمْ إِنُو ذ أَمقّْرَانْ جَارْ ڒڭْنُوسْ ؤُ ذِي كُوڒْ أَمْشَانْ أَذْ أَوْينْ ثَاوْهِيبْثْ ن ڒبْخُورْ إِ يِيسمْ إِنُو ؤُڒَا ذ إِشْثْ ن ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add*، مَاغَارْ إِسمْ إِنُو ذ أَمقّْرَانْ جَارْ ڒڭْنُوسْ، إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ.  
\v 12 مَاشَا كنِّيوْ ثسّْعِيدْجِيثمْ \add إِسمْ نِّي\add* أَمْ ثقَّارمْ: ’ثَازوْضَا ن سِيذِي إِنُو ثخْمجْ ؤُ ڒْغِيدْجثْ نّسْ، \add إِخْسْ أَذْ يِينِي\add* مَاشَّا نّسْ، ذ ثَامحْقُورْثْ!‘  
\v 13 كنِّيوْ ثقَّارمْ \add عَاوذْ\add*: ’خْزَارْ، مَانْ\add أَ\add* أَمْنُوسْ- أَ!‘، مَاشَا كنِّيوْ \add سِيمَانْثْ نْومْ\add* ثْسُوضْممْ خَاسْ، إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ. كنِّيوْ ثتَّاوْيمْ-د مِينْ إِتّْوَاشَارنْ، ؤُ مِينْ إِتّْقجْذْحنْ ذ مِينْ إِهڒْشنْ ثتّْوَايمْ-د أَمْ ثوْهِيبْثْ. مَا أَذْ أَيِي إِعْجبْ مَانْ أَيَا زڭْ ؤُفُوسْ نْومْ؟، إِقَّارْ سِيذِي.  
\v 14 إِتّْوَانْعڒْ ؤُغشَّاشْ، ونِّي غَارْ إِدْجَا إِجّْ ن ڒْمَاڒْ ذ أَوْثمْ ذِي ثْحِيمَارْثْ نّسْ ؤُشَا إِوَاعْذْ \add إِ-ث\add* ؤُ \add خنِّي\add* إِغَارْصْ إِ يِيجّْ ن ڒْمَاڒْ ذ أَنعْضُوبْ إِ سِيذِي! مَاغَارْ نشّْ ذ إِجّْ ن ؤُجدْجِيذْ ذ أَمقّْرَانْ، إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ، ؤُ إِسمْ إِنُو ذ أَمقّْرَانْ جَارْ ڒڭْنُوسْ.“   
\b  
\b  
\m  
\c 2
\s1 أَعْڒَامْ غَارْ إِكهَّاننْ  
\m
\v 1 ”ڒخُّو، إِ كنِّيوْ \add ثدْجَا\add* ثوْصِييّثْ-أَ، \add أَ\add* إِكهَّاننْ.  
\v 2 مَاڒَا كنِّيوْ وَارْ ثسْڒِيمْ ؤُ وَارْ ت ثْكسِّيمْ غَارْ وُوڒْ، مَاحنْذْ أَذْ ثْشنّْعمْ إِسمْ إِنُو، إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ، \add خنِّي\add* نشّْ أَذْ سّكّغْ نّعْڒثْ جَارْ أَومْ ؤُ أَذْ نعْڒغْ لْبَارَاكَاثْ نْومْ، \add وَاهْ،\add* أَقَا نعْڒغْ ثنْ ڒخُّو، مِينْزِي كنِّيوْ وَارْ ت ثْكسِّيمْ غَارْ وُوڒْ. \x ◘ \xo 2:‏2 \xt لَاوِي 26‏:‏14؛ أَعَوذ. 28‏:‏15\x*  
\v 3 خْزَارْ، نشّْ أَذْ كنِّيوْ عَاقْبغْ ذِي زَّارِيعثْ ؤُ أَذْ زُوزَّارغْ أَمسَّاڒْ خْ إِغمْبَابْ نْومْ، أَمسَّاڒْ ن ڒعْيُوذَاثْ نْومْ، ؤُ س مَانْ أَيَا أَذْ كنِّيوْ أَوْينْ سّنِّي.  
\v 4 \add خنِّي\add* أَذْ ثسّْنمْ كنِّيوْ، أَقَا ذ نشّْ إِ غَارْومْ د-إِسّكّنْ ثَاوْصيّثْ-أَ، حِيمَا أَذْ ثِيڒِي ذ ڒْعَاهْذْ إِنُو أَكْ-ذ لَاوِي، إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ.  
\v 5 ڒْعَاهْذْ إِنُو أَكِيذسْ ثُوغَا ذ ثُوذَارْثْ \add ؤُ\add* ذ ڒهْنَا. نشّْ وْشِيغْ أَسْ ثنْ أَڒَامِي غَا إِڭّْوذْ نتَّا ؤُ نتَّا ثُوغَا إِتّڭّْوذْ زَّايِي ؤُ إِتّنخْڒَاعْ زڭْ يِيسمْ إِنُو.  
\v 6 شَّارِيعَا ن ثِيذتّْ ثُوغَا-ت ذڭْ ؤُقمُّومْ نّسْ ؤُ وَارْ إِتّْوِيفْ مِينْ وَارْ إِسڭّْذنْ خْ إِينْشِيشنْ نّسْ. نتَّا يُويُورْ أَكِيذِي ذِي ڒهْنَا ؤُ ذِي ڒصْفَايثْ ؤُ يَارَّا أَطَّاسْ ثُوبنْ زِي ڒْمُوعْصِييّثْ نْسنْ.  
\v 7 مَاغَارْ أَقَا إِتّْخصَّا إِينْشِيشنْ ن ؤُكهَّانْ أَذْ حْضَانْ ثُوسّْنَا ؤُ زڭْ ؤُقمُّومْ نّسْ ثتّْوَارزُّو شَّارِيعَا، مَاغَارْ نتَّا ذ أَمْسكِّي ن سِيذِي ن ڒْعسْكَارَاثْ.“   
\m
\v 8 ”\add مَاشَا\add* كنِّيوْ \add مَاشَا\add* ثْحيّْذمْ خْ وبْرِيذْ، ثسّنْقَارْضمْ أَطَّاسْ زِي ثْغُورِي ن شَّارِيعَا، ثَاردّْدْجمْ ڒْعَاهْذْ ن لَاوِي، إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ.  
\v 9 ؤُڒَا ذ نشّْ أَرِّيغْ كنِّيوْ ثتّْوَاعِيفّمْ ؤُ وَارْ ثدْجِيمْ زَّاثْ إِ مَارَّا ڒْڭنْسْ، مِينْزِي كنِّيوْ وَارْ ثحْضِيمْ إِبْرِيذنْ إِنُو ؤُ ثتّڭّمْ س وُوذْمَاونْ ذِي ثْمسْڒَاشْثْ ن ؤُسڒْمذْ ن شَّارِيعَا.“   
\b  
\m  
\s1 سِيذِي إِشَارّهْ أَدْجَافْ  
\m
\v 10 ”مَا نشِّينْ وَارْ غَارْنغْ مَارَّا مْغِيرْ إِجّْ ن بَابَا؟ مَا وَارْ ذ أَنغْ د-إِخْڒقْ مْغِيرْ إِجّْ ن أَربِّي؟ مَايمِّي خنِّي نشِّينْ نْغدَّارْ إِجّْ ونّغْنِي، أَڒَامِي نسّفْسَاذْ ڒْعَاهْذْ ن ڒجْذُوذْ نّغْ؟  
\v 11 يَاهُوذَا أَقَا إِغْذَارْ، ثتّْوَاڭّْ إِشْثْ ن جّْعِيفشْثْ ذِي إِسْرَائِيل ؤُ ذِي ؤُرْشَالِيمْ، مَاغَارْ يَاهُوذَا إِسّْعِيدْجثْ مِينْ إِقدّْسنْ ن سِيذِي إِ إِتّخْسْ نتَّا، مَاغَارْ يَاهُوذَا إِمْڒشْ يدْجِيسْ ن إِجّْ ن أَربِّي ذ أَغْرِيبْ. \f ◼ \fr 2:‏11 \ft \+bd ’إِ إِتّخْسْ نتَّا‘\+bd* - إِخْسْ أَذْ يِينِي ’إِسْرَائِيل‘ أَمْ ثمْغَارْثْ ن أَربِّي نِّي زَّايسْ إِتّْوَاخْضَارنْ. ذِي ڒْوقْثْ ن مَالَاخِي ثُوغَا يَاهُوذَا ذ إِسْرَائِيل ذ إِجّنْ، مِينْزِي 10 ن ثْقبَّاڒْ ن إِسْرَائِيل وَارْ د-ذْوِيڒنْثْ شَا غَارْ ثمُّورْثْ ن إِسْرَائِيل. مْغِيرْ شَا زَّايْسنْثْ ذوْڒنْثْ-إِ-د أَكْ-ذ يَاهُوذَا ؤُشَا زدّْغنْ جَارْ أَيْثْ ن يَاهُوذَا ذ بِينْيَامِينْ. ذِي ڒْوقْثْ نِّي ثُوغَا وَارْ غَارْسنْ ثدْجِي ثسْغَارْثْ نْسنْ ن زِيشْ ؤُمِي إِبْضَا يَاشُووَا ثَامُّورْثْ ن كنْعَانْ جَارْ 12 إِحنْجِيرنْ ن يَاعْقُوبْ.\f*  
\v 12 سِيذِي أَذْ إِثحَّا مَارَّا وِي إِتّڭّنْ مَانْ أَيَا زڭْ إِقِيضَانْ ن يَاعْقُوبْ، وِي إِتّْڒَاغَانْ ذ ونِّي د إِتَّارَّانْ، \add عَاذْ\add* ؤُڒَا ذ ونِّي إِتّْوهّْبنْ ثَاوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* إِ سِيذِي نْ ڒْعسْكَارَاثْ.“\f ◼ \fr 2:‏12 \ft \+bd ’أَذْ إِثحَّا‘\+bd* - س ثْعِيبْرَانِيثْ ’أَذْ إِقْضعْ‘.\f*   
\m
\v 13 ”ثَامسْڒَاشْثْ وِيسّْ ثْنَاينْ إِ ثتّڭّمْ، أَقَا كنِّيوْ ثدَّاڒمْ أَعَالْطَارْ ن سِيذِي س إِمطَّاونْ، س ثْغُويِّيثْ ؤُ س سْقِينْفثْ، مِينْزِي وَارْ ذِينْ \add ثدْجِي\add* عَاذْ ثيْنِيثْ \add زَّايسْ\add* إِ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* ؤُ وَارْ ت إِقبّڒْ عَاذْ س أَرْضَا زڭْ ؤُفُوسْ نْومْ.  
\v 14 كنِّيوْ ثقَّارمْ: ’مَايمِّي؟‘ مِينْزِي سِيذِي ثُوغَا ذ شَّاهذْ جَارْ شكْ ذ ثمْغَارْثْ ن ثمْژِي نّشْ، ثنِّي ثغْذَارذْ شكْ، \add وَاخَّا\add* نتَّاثْ ذ ثَاعْشِيرْثْ نّشْ ؤُڒَا ذ ثَامْغَارْثْ ن ڒْعَاهْذْ نّشْ.  
\v 15 ؤُڒَا ذ إِجّنْ زڭْ ونِّي غَارْ إِدْجَا \add عَاذْ\add* بُوحْبڒْ، وَارْ إِڭِّي مَانْ أَيَا! ؤُ مِينْ ثُوغَا \add إِڭَّا\add* وَانِيثَا؟ وَانِيثَا ثُوغَا يَارزُّو زَّارِيعثْ ن أَربِّي! س ؤُيَا، حْضَامْ \add خْ\add* بُوحْبڒْ نْومْ ؤُ أجّْ إِ-ث وَارْ إِغدَّارْ ثَامْغَارْثْ ن طمْزِي نّشْ.  
\v 16 مَاغَارْ: ’\add نتَّا إِقَّارْ\add*، أَقَا إِشَارْهْ إِ-ت، \add ؤُشَا خنِّي:\add* أَدْجَافْ!‘، إِقَّارْ سِيذِي، أَربِّي ن إِسْرَائِيل، ’\add أَمُّو إِ\add* إِدَّاڒْ نتَّا ڒْغشّْ س وَارُّوضْ نّسْ!‘، إِنَّا سِيذِي ن ڒْعسْكَارَاثْ. س ؤُيَا حْضَامْ خْ بُوحْبڒْ نْومْ، وَارْ تّْغدَّارمْ شَا!   
\m
\v 17 كنِّيوْ ثسَّاهَاڒمْ سِيذِي س وَاوَاڒنْ نْومْ. كنِّيوْ ثقَّارمْ: ’مِينْ زِي ث نسَّاهَاڒْ نشِّينْ؟‘ مَاغَارْ كنِّيوْ ثقَّارمْ: ’قَاعْ ونِّي إِتّڭّنْ ڒْغَارْ، إِصْبحْ ذِي ثِيطَّاوِينْ ن سِيذِي ؤُ نِيثْنِي ؤُسِينْ أَسْ-د خْ ڒْخَاضَارْ!‘، نِيغْ: ’مَانِي إِدْجَا أَربِّي ن ڒْحُوكْمْ؟‘ “   
\b  
\b  
\m  
\c 3
\s1 ثَاوَاسِيثْ ن لْمَالَاكْ ن ڒْعَاهْذْ  
\m
\v 1 ”خْزَارْ، نشّْ أَذْ سّكّغْ لْمَالَاكْ إِنُو إِنُو، ونِّي إِ غَا إِسّْوجْذنْ أَبْرِيذْ زَّاثْ إِ وُوذمْ إِنُو. ذغْيَا أَذْ د-يَاسْ غَارْ زَّاوشْثْ ثَامقّْرَانْثْ نّسْ، سِيذِي، ونِّي ثَارزُّومْ كنِّيوْ، لْمَالَاكْ ن ڒْعَاهْذْ، ونِّي \add ذ أَومْ\add* د-إِتَّاسنْ خْ ڒْخَاضَارْ نْومْ. خْزَارْ، نتَّا أَذْ د-يَاسْ!، إِنَّا سِيذِي ن ڒْعسْكَارَاثْ. \x ◘ \xo 3:‏1 \xt مت. 11‏:‏10؛ مك. 1‏:‏2؛ لك. 1‏:‏76؛ 7‏:‏27؛ إِشا. 40‏:‏3 \x*  
\v 2 \add مَاشَا\add* مَانْ ونْ إِ غَا يَارْبُونْ أَسّْ ن ثْوَاسِيثْ نّسْ ؤُ مَانْ ونْ إِ غَا إِقِّيمنْ إِبدّْ، خْمِي إِ د غَا إِبَانْ نتَّا؟ مَاغَارْ نتَّا أَمْ ثْمسِّي ن ؤُسفْسَايْ ؤُ أَمْ لِّيخِييَّا ن إِغسَّاڒنْ.  
\v 3 نتَّا أَذْ إِقِّيمْ، \add أَمْ\add* ونِّي إِسّفْسِييّنْ ؤُ إِتّْصفَّانْ نُّوقَارْثْ. نتَّا أَذْ إِسِّيزْذِيڭْ إِحنْجِيرنْ ن لَاوِي ؤُ أَذْ ثنْ إِصفَّا أَمْ وُورغْ ؤُ أَمْ نُّوقَارْثْ، ؤُ نِيثْنِي أَذْ وهّْبنْ إِشْثْ ن ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* ذِي ثْسڭْذَا.   
\m
\v 4 \add خنِّي\add* أَذْ د-ثَاسْ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* ن يَاهُوذَا ذ ؤُرْشَالِيمْ خْ ڒْخَاضَارْ ن سِيذِي أَمْ ذڭْ وُوسَّانْ ن زِيشْ، أَمْ ذڭْ إِسڭّْوُوسَا إِعْذُونْ.  
\v 5 نشّْ أَذْ كنِّيوْ أَذْسغْ، حِيمَا أَذْ خَاومْ حكْمغْ ؤُ أَذْ شهْذغْ س ثَازْڒَا خْ إِسحَّارنْ ذ إِمْزنَّاينْ ؤُ خْ يِينِّي إِتّْجَادْجَانْ ژُورْ ؤُ خْ يِينِّي إِحصَّارنْ ڒْمُونثْ ن ؤُشوَّاڒْ، \add ؤُ خْ ينِّي\add* إِحصَّارنْ ثَاجَّاتْشْ ذ ؤُيُوجِيڒْ ؤُ وَارْ زَّايِي تّڭّْوذنْ شَا، إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ.“\x ◘ \xo 3:‏5 \xt ؤُف. 20‏:‏7؛ 22‏:‏22؛ أَعَوذ. 24‏:‏17؛ عَام. 2‏:‏7\x*   
\b  
\m  
\s1 أَڒَاغِي إِ تُّوبثْ  
\m
\v 6 ”مَاغَارْ نشّْ، سِيذِي، وَارْ بدّْڒغْ شَا ؤُ كنِّيوْ، أَيْثْ ن يَاعْقُوبْ، وَارْ ثفْنَامْ. \x ◘ \xo 3:‏6 \xt إِزهد. 33‏:‏11؛ أَوڒن. 19‏:‏21؛ إِشا. 14‏:‏26، 27؛ 25‏:‏9؛ 46‏:‏10\x*  
\v 7 زڭْ وُوسَّانْ ن ڒجْذُوذْ نْومْ كنِّيوْ ثْحيّْذمْ خْ ثْوصَّا إِنُو ؤُ كنِّيوْ وَارْ ثنْثْ ثحْضِيمْ شَا. ذوْڒمْ-د غَارِي، خنِّي أَذْ د غَارْومْ ذوْڒغْ نشّْ، إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ. مَاشَا كنِّيوْ ثقَّارمْ: ’س مِينْ زِي إِ د غَا نذْوڒْ؟‘ \x ◘ \xo 3:‏7 \xt زَاك. 1‏:‏3\x*   
\m
\v 8 مَا إِزمَّارْ بْنَاذمْ أَذْ يَاشَارْ أَربِّي؟ أَقَا كنِّيوْ ثتَّاشَارمْ أَيِي ؤُ ثقَّارمْ: ’س مِينْ زِي شكْ نتَّاشَارْ؟‘ \add زِي\add* ڒعْشُورْ ذ ثوْهِيبْثْ ن ؤُسْڭعّذْ!  
\v 9 كنِّيوْ ثتّْوَانعْڒمْ س يِيشْثْ ن نّعْڒثْ، مِينْزِي كنِّيوْ ثتَّاشَارمْ أَيِي، \add وَاهْ،\add* ڒْڭنْسْ مَارَّا.  
\v 10 أَوْيمْ-د مَارَّا ڒعْشُورْ ذڭْ وخَّامْ ن ڒخْزنْ، مَاحنْذْ أَذْ ثِيڒِي مَاشَّا ذِي ثَادَّارْثْ إِنُو ؤُ قدْجْبمْ أَيِي زَّايسْ، إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ، مَا نشّْ \add خنِّي\add* وَارْ ذ أَومْ أَرزّْمغْ ثِيبُورْجَاثِينْ ن ؤُجنَّا ؤُ أَذْ خَاومْ زدْجْعغْ لْبَارَاكَا، أَڒْ ذِينْ غَا يِيڒِي كْثَارْ زِي مِينْ إِتّْوَاحْذَاجنْ.  
\v 11 أَبُورْخسْ أَذْ ث سِّيڭّْوذغْ ذِي طّْوعْ نْومْ، مَاحنْذْ نتَّا وَارْ إِتّْجيّحْ صَّابثْ ن وُوذمْ ن ثمُّورْثْ نْومْ ؤُ مَاحنْذْ ثَازَايَارْثْ ذڭْ وحْوِيشْ وَارْ ثتَّاوِي ڒْغِيدْجثْ إِ وَارْ يِيوِيضنْ، إِنَّا سِيذِي ن ڒْعسْكَارَاثْ.  
\v 12 مَارَّا ڒڭْنُوسْ أَذْ إِنِينْ: ’ذ أَمِيمُونْ إِ كنِّيوْ!‘، مَاغَارْ كنِّيوْ أَذْ ثِيڒِيمْ ذ إِشْثْ ن ثمُّورْثْ يَارْضَانْ، إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ.“   
\b  
\m  
\s1 إِمْسڭَّاذنْ ذ لْكُوفَّارْ  
\m
\v 13 ”أَوَاڒنْ نْومْ ذوْڒنْ قسْحنْ خَافِي أَطَّاسْ، إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ. كنِّيوْ ثقَّارمْ: ’مِينْ إِ خَاكْ نقَّارْ نشِّينْ؟‘ \x ◘ \xo 3:‏13 \xt أَيُوبْ 21‏:‏14، 15\x*  
\v 14 كنِّيوْ ثقَّارمْ: ’أَقَا بَاطڒْ إِ نتّْسخَّارْ إِ أَربِّي، مَاغَارْ مَانْ ڒفْضڒْ إِ زِي نحْضَا ثَاسخَّارْثْ نّسْ ؤُ أَقَا نُويُورْ \add ذڭْ ورُّوضْ\add* أَبَارْشَانْ زَّاثْ إِ وُوذمْ ن سِيذِي ن ڒْعسْكَارَاثْ؟  
\v 15 خنِّي ڒخُّو، نْحسّبْ أَيْثْ نّْفَاخثْ ذ أَمِيمُونْ. عَاذْ إِنِّي إِتّڭّنْ ثَاعفَّانْثْ، تّْوَابنَّانْ. نِيثْنِي تّْجَارَّابنْ \add عَاذْ\add* أَربِّي، \add وَاخَّا أَمنِّي\add* نجّْمنْ.‘  
\v 16 خنِّي إِنِّي إِتّڭّْوذنْ سِيذِي مّْسَاوَاڒَانْ \add أَمُّو\add*: ’سِيذِي إِتَّارَّا ثَايْنِيثْ ؤُ إِتّسْڒَا. أَذْ إِتّْوَارِي إِجّْ ن وذْلِيسْ ن ڒِيذَارثْ زَّاثْ إِ وُوذمْ نّسْ، ذِي طّْوعْ ن يِينِّي إِتّڭّْوذنْ سِيذِي ؤُ تِّيذَارنْ إِسمْ نّسْ.‘  
\v 17 نِيثْنِي أَذْ إِڒِينْ نّشْ، إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ، ذڭْ وَاسّْ إِ غَا ڭّغْ ؤُ نشّْ أَذْ ثنْ سّْعِيزّغْ أَمْ إِسّْعِيزّْ إِجّْ ن ورْيَازْ مِّيسْ نِّي إِ ذ أَسْ إِتّْسخَّارنْ.  
\v 18 خنِّي كنِّيوْ أَذْ ثْژَارمْ عَاوذْ ڒْفَارْقْ جَارْ ؤُمْسڭّذْ ذ ونِّي إِتّڭّنْ ثُوعفّْنَا، جَارْ ونِّي إِتّْسخَّارنْ إِ أَربِّي ذ ونِّي إِ وَارْ ذ أَسْ إِتّْسخَّارنْ.“   
\m
\v 19 ”مَاغَارْ خْزَارْ، أَسّْ نِّي أَذْ د-يَاسْ، يَارقّْ أَمْ ثفْقُونْثْ. \add خنِّي\add* مَارَّا أَيْثْ ن نّْفَاخثْ ذ إِعفَّاننْ أَذْ إِڒِينْ أَمْ ؤُڒُومْ ؤُشَا أَسّْ إِ د غَا يَاسنْ أَذْ ثنْ إِسَّارغْ، إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ. \add أَسّْ نِّي\add* وَارْ إِتّجِّي وژْوَارْ ؤُڒَا ذ ثَاسطَّا. \x ◘ \xo 3:‏19 \xt يُووِ. 2‏:‏10، 31؛ 3‏:‏15؛ إِشا. 13‏:‏6‏-‏13؛ 24‏:‏23؛ Am. 8‏:‏9؛ مت. 24‏:‏29؛ ڒخ. 2‏:‏20؛ أَسَا. 6‏:‏12‏-‏13\x*  
\v 20 إِ كنِّيوْ \add مَاشَا\add*، إِنِّي إِتّڭّْوذنْ إِسمْ إِنُو، أَذْ د-ثنْقَارْ ثْفُوشْثْ ن ثْسڭْذَا ؤُ أَذْ يِيڒِي ؤُڭنْفُو سَاذُو وَافْرِيونْ نّسْ ؤُ كنِّيوْ أَذْ ثفّْغمْ ؤُ أَذْ ثڭّمْ إِنڭِّيزنْ ن ڒفْرَاحثْ أَمْ يِيعجْمِييّنْ \add إِ د-يُوسِينْ\add* زِي ڒْكُورِي. \f ◼ \fr 3:‏20 \ft \+bd ’أَمْوَا‘\+bd* - نِيغْ ’أَينْذُوزْ‘ نِيغْ ’يُوڭُّو‘.\f*  
\v 21 كنِّيوْ أَذْ ثْعفْسمْ خْ إِعفَّاننْ، مِينْزِي نِيثْنِي أَذْ ذوْڒنْ ذ إِغّضْ سَاذُو ثِيسِي ن إِضَارنْ نْومْ، ذڭْ وَاسّْ نِّي إِ غَا ڭّغْ نشّْ، إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ.“   
\b  
\m
\v 22 خمّمْ غَارْ شَّارِيعَا ن مُوسَا، أَمْسخَّارْ إِنُو، ثنِّي إِ ذ أَسْ ؤُمُورغْ ذڭْ \add وذْرَارْ ن\add* هُورِيبْ خْ مَارَّا إِسْرَائِيل، ثِيوصَّا ذ لْفَارَايِيضْ.\x ◘ \xo 3:‏22 \xt أَعَوذ. 6‏:‏3\x*   
\m
\v 23 خْزَارْ، نشّْ أَذْ أَومْ د-سّكّغْ أَنَابِي إِلِييَا، قْبڒْ د غَا يَاسْ وَاسّْ أَمقّْرَانْ ذ إِسِّيڭّْوِيذنْ ن سِيذِي. \x ◘ \xo 3:‏23 \xt مت. 11‏:‏14؛ 17‏:‏11، 12، 13؛ مك. 9‏:‏11، 12، 13؛ لك. 1‏:‏7\x*  
\v 24 نتَّا أَذْ يَارّْ ؤُڒْ ن إِبَابَاثنْ غَارْ إِحنْجِيرنْ \add نْسنْ\add* ذ وُوڒْ ن إِحنْجِيرنْ غَارْ إِبَابَاثنْ نْسنْ، مَاحنْذْ نشّْ وَارْ د- تِّيسغْ ؤُ أَذْ حَارّْمغْ ثَامُّورْثْ قَاعْ \add إِ ؤُثحِّي\add*.“   