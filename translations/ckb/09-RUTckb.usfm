\id RUT - Biblica® Open Kurdi Sorani Standard Version
\h ڕائووس
\toc1 ڕائووس
\toc2 ڕائووس
\toc3 ڕائووس
\mt1 ڕائووس
\c 1
\s1 ناعۆمی و ڕائووس
\p 
\v 1 لە سەردەمی فەرمانڕەوایەتی ڕابەرەکان، قاتوقڕییەک لە خاکەکە سەریهەڵدا. لە بێت‌لەحمی یەهوداوە پیاوێک خۆی و ژنەکەی و دوو کوڕەکەی کۆچیان کرد و پەنایان بۆ وڵاتی مۆئاب برد.
\v 2 ناوی پیاوەکە ئەلیمەلەخ بوو، ناوی ژنەکەشی ناعۆمی بوو، ناوی دوو کوڕەکەشی مەحلۆن و کیلیۆن بوو، لە ئەفراتییەکانی\f + \fr 1:2 \ft ئەفراتی دەگەڕێتەوە بۆ هۆزی ئەفرایم، دووەم کوڕی یوسف. بڕوانە \xt پەیدابوون 41‏:52‏\xt*\ft ‏.‏\f* بێت‌لەحمی یەهودا بوون. ئیتر هاتن بۆ وڵاتی مۆئاب و لەوێ ژیان.
\p 
\v 3 لەوێ ئەلیمەلەخی مێردی ناعۆمی مرد، ناعۆمی و دوو کوڕەکەی مانەوە و
\v 4 دوو ژنی مۆئابیان هێنا، یەکێکیان ناوی عۆرپا بوو ئەوەی دیکەیان ڕائووس. لەوێ بۆ ماوەی دە ساڵ مانەوە.
\v 5 ئینجا مەحلۆن و کیلیۆن مردن، ئیتر ناعۆمی بەبێ کوڕ و مێرد مایەوە.
\p 
\v 6 دوای ئەوەی ناعۆمی لە وڵاتی مۆئابدا بیستی کە خودا گەلەکەی خۆی بەسەرکردووەتەوە و نانی داوە پێیان، خۆی و بووکەکانی هەستان و وڵاتی مۆئابیان بەجێهێشت.
\v 7 لەگەڵ دوو بووکەکەی ئەو شوێنەی بەجێهێشت کە لێی دەژیا و ئەو ڕێگایەیان گرتەبەر کە دەیگەڕاندنەوە بۆ خاکی یەهودا.
\p 
\v 8 ناعۆمی بە بووکەکانی گوت: «با هەریەکەتان بگەڕێتەوە بۆ ماڵی دایکی خۆی. خودا پاداشتی ئەو چاکەیەتان بداتەوە کە لەگەڵ من و کوڕەکانمدا کردتان.
\v 9 خودا هەریەکەتان لە ماڵی مێردی خۆی بحەسێنێتەوە.»
\p ئینجا ماچی کردن و ئەوانیش بە دەنگی بەرز گریان.
\v 10 پێیان گوت: «ئێمەش لەگەڵت دێین بۆ لای گەلەکەت.»
\p 
\v 11 ناعۆمی گوتی: «کچەکانم بگەڕێنەوە. بۆچی لەگەڵ من دێن؟ ئایا سکم کوڕی تێدا ماوە بۆ ئەوەی ببن بە مێردتان؟
\v 12 بگەڕێنەوە و بڕۆن، چونکە پیر بووم و ناتوانم شوو بکەمەوە. وا گوتیشم ئومێدی ئەوە هەبوو کە ئەمشەو شوو بکەمەوە و چەند کوڕێکیشم بوو،
\v 13 ئایا چاوەڕێیان دەکەن هەتا گەورە دەبن؟ ئایا لەبەر ئەوان خۆتان دەبەستنەوە و شوو ناکەنەوە؟ نا کچەکانم. من لە ئێوە زیاتر خەفەت دەخۆم، چونکە خودا خراپەی بەسەرم هێنا.»
\p 
\v 14 ئینجا دیسان بە دەنگی بەرز گریان. عۆرپا خەسووی ماچکرد، بەڵام ڕائووس بە توندی لە باوەشی گرت.
\p 
\v 15 ناعۆمی گوتی: «ئەوەتا عۆرپای هێوەرژنت\f + \fr 1:15 \fq هێوەرژنت \ft یان هەوگیانت.‏\f* گەڕایەوە بۆ لای گەلەکەی و خوداوەندەکانی. تۆش لەگەڵ ئەو بگەڕێوە.»
\p 
\v 16 بەڵام ڕائووس گوتی: «زۆرم لێ مەکە بەجێت بهێڵم و وازت لێ بهێنم، چونکە بۆ کوێ بچیت دەچم و لە هەرکوێ بمێنیتەوە دەمێنمەوە. گەلی تۆ گەلی منە و خودای تۆ خودای منە.
\v 17 لەکوێ بمریت لەوێ دەمرم و هەر لەوێش بە خاک دەسپێردرێم. با یەزدان توندترین سزام بدات، ئەگەر جگە لە مردن شتێک من لە تۆ جیا دەکاتەوە.»
\v 18 کە بینی سوورە لەسەر ئەوەی لەگەڵیدا بڕوات، ئیتر زۆری لێ نەکرد.
\p 
\v 19 ئینجا هەردووکیان ڕۆیشتن هەتا چوونە ناو بێت‌لەحم. کاتێک گەیشتنە بێت‌لەحم شارۆچکەکە هەمووی لەبەر ئەوان خرۆشا و گوتیان: «ئایا ئەمە ناعۆمییە؟»
\p 
\v 20 ئەویش پێی گوتن: «پێم مەڵێن ”ناعۆمی“\f + \fr 1:20 \ft واتا (هۆی خۆشی و شادییەکەم).‏\f*، بەڵکو پێم بڵێن ”مارا“\f + \fr 1:20 \ft لە زمانی عیبری \tl ناعۆمی‏\tl* بە واتای خوێن شیرین دێت، هەروەها (مارا) بە واتای تاڵ.‏\f* چونکە خودای هەرە بەتوانا ژیانی زۆر تاڵ کردم.
\v 21 من بە پڕی ڕۆیشتم و خودا بە بەتاڵی منی هێنایەوە. بۆچی بە ناعۆمی بانگم دەکەن؟ ئەوەتا یەزدان کۆستی خستم، هەرە بەتوانا تووشی خراپەی کردم.»
\p 
\v 22 ئیتر ناعۆمی و ڕائووسی مۆئابی بووکی، لە وڵاتی مۆئابەوە هاتنەوە و لە سەرەتای دروێنەی جۆ چوونە ناو بێت‌لەحمەوە.
\c 2
\s1 چاوپێکەوتنی ڕائووس لەگەڵ بۆعەز
\p 
\v 1 ئەوە بوو مێردەکەی ناعۆمی خزمێکی هەبوو بە ناوی بۆعەز، کە پیاوماقوڵی هەمان تیرەی ئەلیمەلەخ بوو.
\p 
\v 2 ڕائووسی مۆئابی بە ناعۆمی گوت: «بهێڵە با بچم بۆ کێڵگە و لەدوای هەرکەسێک کە لەگەڵم میهرەبان بێت، پاشماوەی گوڵەجۆ هەڵبگرمەوە.»
\p ئەویش پێی گوت: «کچم بڕۆ.»
\v 3 ڕائووسیش ڕۆیشت و بەدوای دروێنەکەرەکاندا لە کێڵگەیەک گوڵەجۆی هەڵگرتەوە. وا ڕێککەوت کێڵگەکە هی بۆعەز بوو کە لە تیرەی ئەلیمەلەخ بوو.
\p 
\v 4 لەو کاتەدا بۆعەز لە بێت‌لەحمەوە هات و بە دروێنەکەرەکانی گوت: «یەزدان یارمەتیتان بدات.»
\p ئەوانیش گوتیان: «با بەرەکەتی یەزدانت لەسەر بێت.»
\p 
\v 5 بۆعەز بە خزمەتکارەکەی گوت کە کرابوو بە سەرکار بەسەر دروێنەکەرەکاندا: «ئەم کچە هی کێیە؟»
\p 
\v 6 ئەویش وەڵامی دایەوە: «کچێکی مۆئابییە لەگەڵ ناعۆمی لە وڵاتی مۆئابەوە هاتووە،
\v 7 کە پێی گوتین: ”لێمگەڕێن با گوڵەجۆ لەدوای دروێنەکەرەکان کۆبکەمەوە.“ ئیتر هات و لە بەیانییەوە هەتا ئێستا ماوەتەوە، تەنها تۆزێک نەبێت لەژێر کەپرەکە پشووی دا.»
\p 
\v 8 بۆعەز بە ڕائووسی گوت: «گوێ بگرە کچم. مەڕۆ بۆ کێڵگەیەکی دیکە بۆ گوڵەجۆ هەڵگرتنەوە، بەڵکو لێرە بە، لەلای کچە خزمەتکارەکانم.
\v 9 تەماشای کێڵگەکە بکە، پیاوەکان لەکوێ دروێنە دەکەن، تۆش لەگەڵ ژنەکاندا شوێنیان بکەوە. پیاوەکانم ئاگادار کردووەتەوە دەستت لێ نەدەن. ئەگەر تینوو بوویت بڕۆ لە کوپەکان ئاو بخۆوە کە پیاوەکان ئاوی تێدەکەن.»
\p 
\v 10 ڕائووس کڕنۆشی برد و لەسەر ڕوو کەوت، پێی گوت: «بۆچی سەرەڕای بێگانەییم ڕەزامەندی تۆم بەدەستهێنا و گرنگیت پێدام؟»
\p 
\v 11 بۆعەزیش وەڵامی دایەوە: «بە تەواوی هەموو ئەو شتانەم پێ گوتراوە کە دوای مردنی پیاوەکەت بۆ خەسووت کردووە، تەنانەت وازت لە دایک و باوک و ئەو خاکەی لێی لەدایک بوویت هێناوە و هاتیت بۆ لای گەلێک کە پێشتر نەتناسیون.
\v 12 با یەزدان چاکەی ئەم کارەت بداتەوە. با یەزدانی پەروەردگاری ئیسرائیل بە تەواوی پاداشتت بداتەوە، ئەوەی کە هاتوویت بۆ ئەوەی پەنا ببەیتە ژێر باڵەکانی.»
\p 
\v 13 ئەویش گوتی: «گەورەم با بەردەوام لەبەرچاوت ڕەزامەندی بەدەستبهێنم، چونکە دڵت دامەوە و دڵی کارەکەرەکەتت خۆش کرد، هەرچەندە وەکو یەکێکیش نیم لە کارەکەرەکانت.»
\p 
\v 14 لە کاتی نانخواردندا بۆعەز پێی گوت: «وەرە بۆ ئێرە. هەندێک نان بێنە و بیکە بەنێو سرکەکەدا و بیخۆ.»
\p ئەویش لەلای دروێنەکەرەکانەوە دانیشت و بۆعەزیش جۆی برژاوی پێدا، ئیتر خواردی و تێر بوو، لێشی مایەوە.
\v 15 کاتێک هەستا بۆ ئەوەی جۆ هەڵبگرێتەوە، بۆعەز فەرمانی بە پیاوەکانی دا: «لێیگەڕێن با لەنێو کۆڵەجۆکانیش\f + \fr 2:15 \ft بڕوانە \xt دواوتار 24‏:19‏\xt*\ft .‏\f* جۆ هەڵبگرێتەوە و ئەزیەتی مەدەن،
\v 16 لە دەسکەکانیش بۆی دەربهێنن. لێیگەڕێن با هەڵیبگرێتەوە و قسەی پێ مەڵێن.»
\p 
\v 17 ئەویش هەتا ئێوارە گوڵەجۆی هەڵگرتەوە. پاشان ئەوەی هەڵیگرتبووەوە کوتای و نزیکەی ئێفەیەک\f + \fr 2:17 \ft ‏نزیکەی سێزدە کیلۆ.‏\f* جۆ بوو.
\v 18 جا هەڵیگرت و گەڕایەوە ناو شار و خەسووی ئەوەی بینی کە هەڵیگرتبووەوە. دوای ئەوەی کە ڕائووس تێری خوارد، ئەو خواردنەی دا بە خەسووی کە مابووەوە.
\p 
\v 19 خەسووشی پێی گوت: «ئەمڕۆ لەکوێ گۆڵەجۆت هەڵگرتەوە و لەکوێ ئیشت کرد؟ با بەرەکەتدار بێت ئەو کەسەی کە چاوی لێتە.»
\p ئەویش باسی ئەو کەسەی بۆ خەسووی کرد کە لە کێڵگەکەیدا ئیشی کردووە و گوتی: «ئەو پیاوەی کە ئەمڕۆ لە کێڵگەکەیدا ئیشم کردووە ناوی بۆعەزە.»
\p 
\v 20 ناعۆمیش بە بووکەکەی گوت: «ئەو بەرەکەتدارە لەلایەن یەزدانەوە، ئەوەی زیندووان و مردووانی بێبەش نەکردووە لە خۆشەویستییە نەگۆڕەکەی.» ئینجا ناعۆمی پێی گوت: «ئەو پیاوە یەکێکە لە خزمە خوێنگرەکانمان\f + \fr 2:20 \ft بڕوانە پێشەکی.‏\f*.»
\p 
\v 21 ڕائووسی مۆئابیش گوتی: «هەروەها پێی گوتم: ”لەگەڵ خزمەتکارەکانمدا بمێنەوە هەتا هەموو دروێنەکەم تەواو دەکەن.“»
\p 
\v 22 ناعۆمیش بە ڕائووسی بووکی گوت: «کچم وا چاکە لەگەڵ کارەکەرەکانی ئەو بچیت، نەوەک لە کێڵگەیەکی دیکە ئەزیەتت بدەن.»
\p 
\v 23 بەو شێوەیە ڕائووس هەتا تەواوبوونی دروێنەی گەنم و جۆ لەگەڵ کچە خزمەتکارەکانی بۆعەز لە هەڵگرتنەوە مایەوە و لەگەڵ خەسووی دەژیا.
\c 3
\s1 ڕائووس و بۆعەز لە جۆخینەکە
\p 
\v 1 ڕۆژێکیان ناعۆمی خەسووی بە ڕائووسی گوت: «کچم، ئایا هەوڵ نەدەم ماڵێکت بۆ پەیدا بکەم کە تێیدا بحەوێیتەوە؟
\v 2 بۆعەز ئەوەی کە لەگەڵ کچە خزمەتکارەکانی بوویت خزممانە و ئەوەتا ئەمشەو لەسەر جۆخینەکە\f + \fr 3:2 \ft جۆخین یان سەرخەرمان ئەو زەوییە تەرخانکراوەیە کە لەلایەن وەرزێر و جوتیارەوە بەکارهێنراوە بۆ کوتانی دانەوێڵە لەسەری لەدوای کۆکردنەوەی لە کێڵگە.‏\f* شەنی جۆ دەکات.
\v 3 خۆت بشۆ و بۆن لە خۆت بدە و خۆت بگۆڕە. پاشان بڕۆ بۆ سەر جۆخینەکە، بەڵام خۆت بۆ پیاوەکە ئاشکرا مەکە هەتا لە خواردن و خواردنەوە دەبێتەوە.
\v 4 هەرکە پاڵکەوت، بزانە شوێنی پاڵکەوتنەکەی کوێیە. بڕۆ لای پێی هەڵبدەوە و پاڵبکەوە، ئیتر خۆی پێت دەڵێت چی بکەیت.»
\p 
\v 5 ئەویش پێی گوت: «هەرچییەکت گوت دەیکەم.»
\v 6 ئیتر چووە سەر جۆخینەکە و هەموو ئەوەی کە خەسووی فەرمانی پێدا کردی.
\p 
\v 7 بۆعەز خواردی و خواردیەوە و دڵی خۆش بوو و چووە ژوورەوە بۆ ئەوەی لە قەراغی دانەوێڵە کۆکراوەکەدا پاڵ بکەوێت. ئەویش بەدزییەوە چووە ژوورەوە و لای پێیەکانی بۆعەزی هەڵدایەوە و پاڵکەوت.
\v 8 لە نیوەشەودا بۆعەز پەشۆکا، ئاوڕی دایەوە و بینی ژنێک لەلای پێیەوە پاڵکەوتووە.
\p 
\v 9 گوتی: «تۆ کێیت؟»
\p ئەویش گوتی: «من ڕائووسی کارەکەری تۆم. دامێنی کراسەکەت بدە\f + \fr 3:9 \ft پێدادانی دامێنی کراس، دەربڕینێکە بۆ مارەبڕین بەکاردێت. لێرەدا ڕائووس مەبەستی ئەوەیە کە بۆعەز هاوسەرگیری لەگەڵ بکات.‏\f* بەسەر خزمەتکارەکەتدا، چونکە تۆ خوێنگری منیت.»
\p 
\v 10 ئەویش گوتی: «کچەکەم، با تۆ لەلایەن یەزدانەوە بەرەکەتدار بیت، چونکە ئەم چاکەیەی دواییت زیاترە لەوەی یەکەم جارت. تۆ هەوڵت نەداوە شوێن لاوان بکەویت، هەژار بن یان دەوڵەمەند.
\v 11 ئێستاش کچی خۆم، مەترسە. هەرچییەک بڵێی بۆت دەکەم، چونکە هەموو خەڵکی شارۆچکەکەم دەزانن کە تۆ ژنێکی ڕەوشت بەرزیت.
\v 12 ڕاستە من خوێنگرم، بەڵام خوێنگرێکی دیکە هەیە کە لە من پێشترە.\f + \fr 3:12 \ft لە من پێشترە: بڕوانە \xt لێڤییەکان 25‏:25‏\xt*\ft ‏.‏\f*
\v 13 ئەمشەو بخەوە، بەیانی ئەگەر ئەو خزمە بە مافی پێشینەیی خزمایەتی هەستا ئەوا باشە، با بەجێی بهێنێت. بە یەزدانی زیندوو! ئەگەر ئەو نەیویست مافی پێشینەیی خزمایەتی بەجێبهێنێت، ئەوا من بەجێی دەهێنم. تۆ هەتا بەیانی پاڵبکەوە.»
\p 
\v 14 ئەویش لەلای پێیەوە پاڵکەوت هەتا بەرەبەیان، ئینجا پێش ئەوەی کەسێک بتوانێت بیناسێتەوە، هەستا. بۆعەز گوتی: «با کەس نەزانێت کە ئافرەتێک هاتووە بۆ سەر جۆخینەکە.»
\p 
\v 15 ئینجا بۆعەز بە ڕائووسی گوت: «چارۆکەکەی بەرت بهێنە و بیگرەوە.» ئەویش گرتییەوە و بۆعەزیش شەش پێوانە جۆی کردە ناوی و دای بەسەر شانیدا. ئینجا بۆعەز چووە ناو شارۆچکەکەوە.
\p 
\v 16 ڕائووسیش کە هات بۆ لای خەسووی، خەسووی لێی پرسی: «کچم چیت کرد؟»
\p ئەویش پیاوەکە هەرچییەکی بۆ کردبوو بۆی گێڕایەوە.
\v 17 گوتی: «ئەم شەش پێوانە جۆیە ئەو پێیدام، چونکە گوتی: ”بە دەستبەتاڵی مەچووەوە لای خەسووت.“»
\p 
\v 18 ئینجا ناعۆمی گوتی: «کچم، دابنیشە هەتا دەزانیت کارەکە چی لێدێت، چونکە پیاوەکە هێور نابێتەوە هەتا ئەمڕۆ کارەکە تەواو نەکات.»
\c 4
\s1 بۆعەز ڕائووس لە خۆی مارە دەکات
\p 
\v 1 هەر لەو ماوەیەدا بۆعەز چوو بۆ لای دەروازەی شارۆچکەکە و لەوێ دانیشت. ئەوە بوو کاتێک ئەو خوێنگرەی کە بۆعەز باسی کرد لەوێوە تێدەپەڕی، بۆعەز گوتی: «خزمە، لابدە و لێرە دابنیشە.» ئەویش لایدا و دانیشت.
\p 
\v 2 ئینجا بۆعەز دە پیاوی لە پیرانی شارۆچکەکە برد و پێی گوتن: «لێرە دابنیشن.» ئەوانیش دانیشتن.
\v 3 ئینجا بە خوێنگرەکەی\f + \fr 4:3 \ft یەکێک لە ئەرکەکانی خوێنگر پاراستنی ناو و سەروەتی مردووەکەیە.‏\f* گوت: «ناعۆمی کە لە وڵاتی مۆئاب گەڕاوەتەوە، پارچە زەوییەکی هەیە کە هی ئەلیمەلەخی برامانە دەیفرۆشێت.
\v 4 منیش پێم وایە ئەرکی منە کە پێت بڵێم لەبەردەمی دانیشتووان و لەبەردەمی پیرانی گەلەکەم بیکڕە. ئیتر ئەگەر دەیکڕیتەوە بیکڕەوە و ئەگەر نایکڕیتەوە ئەوا پێم بڵێ با بزانم، چونکە تۆ لەپێشتریت بۆ کڕینەوەی، دوای تۆ من.»
\p ئەویش گوتی: «دەیکڕمەوە.»
\p 
\v 5 بۆعەزیش گوتی: «ئەو ڕۆژەی زەوییەکە لە ناعۆمی دەکڕیت، پێویستە ڕائووسی مۆئابیش بخوازیت کە ژنی مردووەکەیە، بۆ ئەوەی میراتەکە بە ناوی مردووەکە بکەیت.»
\p 
\v 6 خوێنگرەکەش گوتی: «من خۆم ناتوانم بیکڕمەوە، نەوەک میراتەکەی خۆم تێکبدەم. جا تۆ خۆت بیکڕەوە، چونکە من ناتوانم بیکڕمەوە.»
\p 
\v 7 وا باو بوو لە ئیسرائیلدا بۆ سەلماندنی ئەنجامدانی هەموو کارێکی مافی کڕینەوە و گواستنەوەی خاوەنداریێتی موڵک، کابرا پێڵاوەکەی دابکەنێت و بیداتە لایەنی بەرامبەر. ئیتر ئەمە ئەو نەریتە بوو کە لە ئیسرائیل دەگیرایەبەر.
\p 
\v 8 ئینجا خوێنگرەکە بە بۆعەزی گوت: «خۆت بیکڕە.» ئیتر پێڵاوەکەی داکەند.
\p 
\v 9 بۆعەزیش بە پیرەکان و هەموو خەڵکەکەی گوت: «ئێوە ئەمڕۆ شایەتن کە من هەرچییەک هی ئەلیمەلەخ و هەرچییەک هی کیلیۆن و مەحلۆن بوو لە دەستی ناعۆمی کڕیمەوە.
\v 10 هەروەها ڕائووسی مۆئابی ژنی مەحلۆنیشم لە خۆم مارە کرد هەتا ببێت بە ژنم، بۆ ئەوەی میراتەکە بە ناوی مردووەکە بکەم، تاکو ناوی مردووەکە لەنێو گەلەکەی کوێر نەبێتەوە و لە تۆماری شارۆچکەکەیدا نەسڕێتەوە. ئێوە ئەمڕۆ شایەتن!»
\p 
\v 11 هەموو خەڵکەکە و پیرەکان کە لەناو دەروازەکە دانیشتبوون، گوتیان: «ئێمە شایەتین. با یەزدان ئەو ژنەی کە دێتە ماڵەکەت وەکو ڕاحێل و لێئەی لێ بکات کە بنەماڵەی ئیسرائیلیان دروستکرد. ئیتر با مەزن بیت لە ئەفراتە و ناودار بیت لە بێت‌لەحم.
\v 12 هەروەها ماڵەکەت و ئەو وەچەیەی یەزدان لەم ژنە دەتداتێ وەکو بنەماڵەی پێرێز بێت ئەوەی لە تامار لەدایک بوو بۆ یەهودا.»
\s1 بنەچەی داود
\p 
\v 13 ئیتر بۆعەز ڕائووسی هێنا و گواستییەوە، یەزدانیش سکپڕبوونی پێ بەخشی و کوڕێکی بوو.
\v 14 ژنان بە ناعۆمییان گوت: «ستایش بۆ ئەو یەزدانەی ئەمڕۆ بێ خوێنگری نەکردیت. با ناوی بۆعەز لە ئیسرائیلدا دەنگ بداتەوە.
\v 15 دەبێتە نوێکەرەوەی گیانت و لە پیریتدا بەخێوت دەکات، چونکە لە بووکەکەت بووە کە تۆی خۆشدەوێت و بۆ تۆ لە حەوت کوڕ باشترە.»
\p 
\v 16 ناعۆمیش کوڕەکەی هەڵگرت و لە باوەشی کرد و بوو بە دایەنی.
\v 17 ژنە دراوسێکان گوتیان «کوڕێک لەدایک بوو بۆ ناعۆمی» و ناویان لێنا عوبێد، کە باوکی یەسای باوکی داود بوو.
\li4 
\v 18 ئەمانەش نەوەکانی پێرێزن:
\b
\li1 پێرێز باوکی حەسرۆن بوو،
\li1 
\v 19 حەسرۆنیش باوکی ڕام بوو،
\li1 ڕامیش باوکی عەمیناداب بوو،
\li1 
\v 20 عەمینادابیش باوکی نەحشۆن بوو،
\li1 نەحشۆنیش باوکی سەلمۆن بوو،
\li1 
\v 21 سەلمۆنیش باوکی بۆعەز بوو،
\li1 بۆعەزیش باوکی عوبێد بوو،
\li1 
\v 22 عوبێدیش باوکی یەسا بوو و
\li1 یەساش باوکی داود بوو.
