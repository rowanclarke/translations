\id SNG – ESR Marek Olah Unicode 
\h Nekšukareder giľi 
\toc1 E Nekšukareder giľi 
\toc2 Nekšukareder giľi 
\toc3 Giľi 
\mt1 E Nekšukareder giľi 
\c 1  
\p  
\v 1 E nekšukareder giľi le Šalamunoskri. 
\s1 Ešebno giľi 
\sp E džuvľi 
\q1  
\v 2 Ó, te man furt čumidľalas tire vuštenca! 
\q1 Tiro kamiben hino feder sar e mol. 
\q1  
\v 3 Šukares voňinel tiro parfumos; 
\q1 tiro nav hin sar o nekfeder parfumos, 
\q1 vašoda tut o terne čhaja kamen. 
\q1  
\v 4 Le man tuha, av denašas! 
\q1 Ľidža man, kraľina miro, andre tire khera! 
\q1 Radisaľuvaha a thovaha baripen andre tu, 
\q1 lašaraha tiro kamiben buter sar e mol. 
\q1 Na čudaľinav man, hoj tut o terne čhaja avke kamen. 
\q1  
\v 5 Kaľori som, ale šukar, 
\q1 čhajale le Jeruzalemoskre, 
\q1 kaľori sar o stani le Kedaroskre, 
\q1 sar o zavesi andro Šalamunoskro palacis. 
\q1  
\v 6 Ma dikhen man tele, hoj som kaleder, 
\q1 hoj man chudňa o kham. 
\q1 O čhave mira dakre pre ma choľisaľile 
\q1 a thode man te stražinel o viňici, 
\q1 ale miri viňica me zamukľom. 
\q1  
\v 7 Phen mange avri, tu, saves avke kamav: 
\q1 Kaj pašineha tiro stados? 
\q1 Kaj odpočovineha pro dilos? 
\q1 Soske te avav sar e napačivaľi džuvľi 
\q1 paš o stadi tire prijaťeľengre? 
\sp O murš 
\q1  
\v 8 Tu, so sal nekšukareder le džuvľendar, 
\q1 te na džanes, kaj hin oda than, 
\q1 dža pal o stopaja le bakrengre 
\q1 a muk tire kozicen te chal e čar 
\q1 paš o stani le pasťjerengre. 
\b  
\q1  
\v 9 Tu sal ajsi šukar, lasko miri, 
\q1 sar e terňi kobila, so cirdel le faraonoskro verdan! 
\q1  
\v 10 Tire čhama hine igen šukar le ozdobenca andro kana, 
\q1 tiri meň le perlengre lancociha. 
\q1  
\v 11 Keraha tuke o somnakune lancici 
\q1 le rupune guľičkenca. 
\sp E džuvľi 
\q1  
\v 12 Medik pašľolas miro kraľis pre peskro divanos, 
\q1 miro parfumos šukares voňinelas. 
\q1  
\v 13 Oda, kas kamav, mange hino sar e voňavo mirha, 
\q1 so mange pašľol pro koľin; 
\q1  
\v 14 hino mange sar o kvitki henna 
\q1 andre viňica paš o En-Gedi. 
\sp O murš 
\q1  
\v 15 Ó, savi šukar sal, lasko miri! Igen šukar sal! 
\q1 Tire jakha hine sar holubici. 
\sp E džuvľi 
\q1  
\v 16 Ó, savo šukar sal tu, lasko miri! Čačes sal šukar! 
\q1 E zeleno čar hiňi amaro hadžos. 
\q1  
\v 17 O hranoli pre amaro kher hine le cedrostar, 
\q1 amaro plafonos hin le sosnendar. 
\c 2  
\sp E džuvľi 
\q1  
\v 1 Me som ča e kvitka andro Šaron, 
\q1 ča e ľaľija, so barol andre dolina. 
\sp O murš 
\q1  
\v 2 Sar e ľaľija maškar o koľaka, 
\q1 ajsi hiňi miri laska maškar o terne čhaja. 
\sp E džuvľi 
\q1  
\v 3 Sar o lačho phabengro stromos 
\q1 maškar o stromi andro veš, 
\q1 ajso hin oda, ko man kamel, 
\q1 feder sar savore terne čhave. 
\q1 Igen kamavas te bešel andre leskro ciňos 
\q1 a leskro ovocje hino gulo andre miro muj. 
\q1  
\v 4 Domukľa mange te pijel peskri kamibnaskri mol\f + \fr 2,4 \ft E hebrejiko čhib: Anďa man andro kher la moľakro.\f*, 
\q1 leskro kamiben sas upral mande sar e zastava. 
\q1  
\v 5 Občerstvinen man le hrozienkenca! 
\q1 Zoraľaren man le phabenca, 
\q1 bo som nasvaľi le kamibnastar! 
\q1  
\v 6 Leskro baľogno vast hin tel miro šero 
\q1 a peskre čače vasteha man obchudel. 
\b  
\q1  
\v 7 Den man lav, 
\q1 čhajale andral o Jeruzalem, 
\q1 anglo srnki the anglo gazeli! 
\q1 Ma čhalaven amaro kamiben, 
\q1 medik o kamiben korkoro na kamela. 
\s1 Dujto giľi 
\sp E džuvľi 
\q1  
\v 8 Šunav o hangos oleskro, ko man kamel! 
\q1 Dikh, avel kade! 
\q1 Chučkerel pal o verchi a denašel pal o brehi; 
\q1  
\v 9 hino sar e gazela, sar o terno jeleňis. 
\q1 Dikh, kade ačhel pal amaro muros; 
\q1 dikhel andre prekal o oblaki, zadikhel prekal o mreži. 
\q1  
\v 10 Prevakerďa ke ma oda, ko man kamel: 
\q1 „Ušťi upre, lasko miri, 
\q1 av, miri šukarori! 
\q1  
\v 11 Dikh, o jevend imar pregeľa; 
\q1 o brišind preačhiľa, geľa het. 
\q1  
\v 12 O kvitki aven avri pre phuv! 
\q1 Avľa o časos pro giľavipen! 
\q1 O hangos la hrdličkakro 
\q1 šunďol andre amari phuv. 
\q1  
\v 13 Pro figovňikos barol o terne figi, 
\q1 o viňici kvitňisaľon a šukares voňinen. 
\q1 Ušťi upre, lasko miri, 
\q1 av, miri šukarori!“ 
\sp O murš 
\q1  
\v 14 Holubico miri, 
\q1 garuďi sal andre chev andre skala, 
\q1 andre skalakri škara. 
\q1 Sikav mange tiro muj 
\q1 a domuk mange te šunel tiro hangos; 
\q1 bo mištes šunďol tiro hangos 
\q1 a šukar hin tiro muj. 
\q1  
\v 15 Chuden amenge le lišken\f + \fr 2,15 \ft Kade šaj džal pal aver murša, so tiš kamen ola terňa džuvľa.\f*, 
\q1 le cikne lišken, so musaren o viňici, 
\q1 amare viňici, so imar kvitňisaľon. 
\sp E džuvľi 
\q1  
\v 16 Oda, ko man kamel, 
\q1 hino miro a me som leskri; 
\q1 čaľarel pes maškar o ľaľije. 
\q1  
\v 17 Medik na predžal o džives 
\q1 a o ciňos na našľol, 
\q1 visaľuv pale, tu, so man kames, 
\q1 av ajso sar e gazela, 
\q1 sar o terno jeleňis pro Beterska verchi\f + \fr 2,17 \ft Kada hin o verchi rozďelimen pro duj.\f*. 
\c 3  
\q1  
\v 1 Pre miro hadžos račenca rodavas oles, 
\q1 kas kamel miri duša. 
\q1 Rodavas les, ale na arakhľom. 
\q1  
\v 2 No ča uščav a predžav man pal o foros; 
\q1 pro uľici the pro pľacos rodava oles, 
\q1 kas kamel miro jilo; 
\q1 rodavas les, ale na arakhľom. 
\q1  
\v 3 Arakhle man o stražňika, save phiren pal o foros. 
\q1 Phučľom lendar: „Na dikhľan oles, kas kamel miro jilo?“ 
\q1  
\v 4 Soča lendar odgeľom, 
\q1 arakhľom oles, kas kamel miro jilo. 
\q1 Chudňom les a na mukľom, 
\q1 medik les na anďom andre mira dakro kher, 
\q1 andre oda kher, kaj man miri daj anďa pro svetos. 
\b  
\q1  
\v 5 Den man lav, 
\q1 čhajale andral o Jeruzalem, 
\q1 anglo srnki the anglo gazeli! 
\q1 Ma čhalaven a ma uštaven o kamiben, 
\q1 medik o kamiben korkoro na kamela. 
\s1 Trito giľi 
\sp E džuvľi 
\q1  
\v 6 So hin oda, so avel pal e pušťa sar o slupi le thuvestar, 
\q1 sar o parfumos andral e mirha the kaďidlos, 
\q1 savore koreňjendar le kupcendar? 
\q1  
\v 7 Dikh, le Šalamunoskro tronos! 
\q1 Pašal leste šovardeš zorale murša, 
\q1 nekfeder murša andral o Izrael. 
\q1  
\v 8 Savore pes džanen te marel le šabľenca; 
\q1 dojekh hino avrisikado pro mariben; 
\q1 paš sakoneste hin e šabľa, 
\q1 hoj te ochraňinel le utokendar rači. 
\q1  
\v 9 O kraľis Šalamun peske kerďa tronos\f + \fr 3,9 \ft Oda sas tronos, so pes del te preľidžal.\f* 
\q1 le kaštestar andral o Libanon. 
\q1  
\v 10 O slupici kerďa rupune, 
\q1 o operadlos kerďa somnakuno, 
\q1 o šedziskos fijalovo, 
\q1 obthodo andral le kamibnaha\f + \fr 3,10 \ft Abo: le ebenoskre kaštestar\f* 
\q1 le Jeruzalemoskre čhajendar\f + \fr 3,10 \ft Abo: Čhajale andral o Jeruzalem\f*. 
\q1  
\v 11 Aven avri, čhajale le Sionoskre, 
\q1 dikhen pro kraľis Šalamun, 
\q1 pre koruna, so leske thoďa e daj pro šero, 
\q1 andre oda džives, sar leske sas o bijav, 
\q1 oda džives, sar leske radisaľolas o jilo. 
\c 4  
\sp O murš 
\q1  
\v 1 Jaj, savi šukar sal, lasko miri, savi šukar sal, 
\q1 tire jakha hine mila sar o holubici tel o zavojis, 
\q1 tire bala hine kale sar o stados le kozengro, 
\q1 so avel tele pal o verchi andro Gilead. 
\q1  
\v 2 Tire danda hine ajse parne sar o strihimen bakrore, 
\q1 so sas akana ča žužarde andro paňi. 
\q1 Savoren hin peskri dvojička, 
\q1 aňi jekh lendar na chibaľinel. 
\q1  
\v 3 Tire vušta hine sar o šarlatovo thav 
\q1 a tiro muj hino igen šukar. 
\q1 Tire čhama pal o zavojis 
\q1 hine ajse lole sar e jepaš granatoskri phabaj. 
\q1  
\v 4 Tiri meň hiňi šukar sar e veža le Davidoskri, 
\q1 ačhaďi le barendar andro šori, 
\q1 ezeros šťiti upre figinen, 
\q1 savore šťiti le zorale muršengre. 
\q1  
\v 5 Tire duj koľina hine sar duj terne gazeli, 
\q1 sar o dvojički, so chan e čar maškar o ľaľije. 
\q1  
\v 6 Sigeder sar avela o džives 
\q1 a o kaľipen denašela, 
\q1 džava mange upre pro verchos la mirhakro 
\q1 the pro brehos le kaďidloskro. 
\q1  
\v 7 Caľi sal šukar, lasko miri; 
\q1 nane pre tu chiba! 
\b  
\q1  
\v 8 Av manca andral o Libanon, miri terňije, 
\q1 av manca andral o Libanon. 
\q1 Av tele pal o verchos Amana, 
\q1 pal o verchos Senir the Chermon, 
\q1 pal o thana le ľevengre 
\q1 the pal o brehi le leopardengre. 
\q1  
\v 9 Zachudňal mange miro jilo, 
\q1 pheňe miri, terňije miri, 
\q1 zaiľal mange les, 
\q1 soča pre ma jekhvar dikhľal, 
\q1 le jekhore šperkoha andral tiro lancocis. 
\q1  
\v 10 Savo ča šukar hin tiro kamiben, 
\q1 pheňe miri, terňije miri! 
\q1 Tiro kamiben hin feder sar e mol; 
\q1 tire parfumi voňinen feder 
\q1 sar savore koreňja. 
\q1  
\v 11 Pal tire vušta čuľal o gulo medos, miri terňije, 
\q1 tel e čhib tut hin o medos the o thud 
\q1 a tire gada voňinen avke, sar voňinel o Libanon. 
\q1  
\v 12 Tu sal e zarimen zahrada, pheňe miri, terňije miri; 
\q1 e zarimen zahrada, o prameňis, so hino zakerdo andre. 
\q1  
\v 13 Tu sal sar e zahrada le granatoskre phabengri, 
\q1 kaj barol o lačho ovocje, 
\q1 e henna the o nardos; 
\q1  
\v 14 o nardos the o šafran, 
\q1 o puškvorcos the e škorica 
\q1 the but aver voňavo kaďidlos, 
\q1 e mirha the aloe 
\q1 le savore nekfeder koreňjenca. 
\q1  
\v 15 Tu sal o prameňis andre zahrada, 
\q1 e chaňig le džide paňeha, 
\q1 so čuľal tele pal o Libanon. 
\sp E džuvľi 
\q1  
\v 16 Balvajale pal o severos the pal o juhos, ušťen upre a aven! 
\q1 Prephurden miri zahrada, 
\q1 hoj lakri voňa te voňinel všadzik, 
\q1 hoj oda, kas kamav, te avel andre peskri zahrada 
\q1 a te chal lakro lačho ovocje. 
\c 5  
\sp O murš 
\q1  
\v 1 Avľom andre miri zahrada, 
\q1 pheňe miri, terňije miri, 
\q1 obkidav miri mirha the miro koreňje; 
\q1 koštoľinav mire medostar, 
\q1 pijav miri mol the miro thud. 
\sp O džuvľa 
\q1 Chan, mire prijaťeľale, pijen, 
\q1 mačon le kamibnastar. 
\sp E džuvľi 
\q1  
\v 2 Me sovavas, ale miro jilo sas upre. 
\q1 Šun! Oda, kas kamav, durkinďa. 
\sp O murš 
\q1 Phundrav mange, 
\q1 pheňe miri, lasko miri, 
\q1 holubico miri, nane pre tu chiba! 
\q1 Pro šero man hin pherdo rosa, 
\q1 o bala mange cinďile la račakra molhatar. 
\sp E džuvľi 
\q1  
\v 3 E rokľa čhiďom tele! 
\q1 Pale la urava? 
\q1 O pindre žužarďom le paňeha. 
\q1 Pale len meľarava? 
\q1  
\v 4 Oda, kas kamav, 
\q1 nacirdňa peskro vast, hoj te phundravel o vudar, 
\q1 a miro jilo pes andre mande čhalaďa. 
\q1  
\v 5 Ušťiľom upre te phundravel oleske, kas kamav, 
\q1 a mire vastendar čuľalas e mirha, 
\q1 prekal o angušta mange prečuľalas 
\q1 pre kľamka pro vudar. 
\q1  
\v 6 Phundraďom oleske, kas kamav, 
\q1 ale ov ode imar na sas, geľa het. 
\q1 Ačhiľom smutno\f + \fr 5,6 \ft Na džanel pes, so phenel e hebrejiko čhib; oda šaj el the: „sar ov vakerelas.“\f*, 
\q1 rodavas les, ale našťi les arakhľom; 
\q1 vičinavas pre leste, 
\q1 ale na odphenelas mange. 
\q1  
\v 7 Arakhle man o stražňika, 
\q1 sar phirenas pal o foros. 
\q1 Marde man, dukhade man, 
\q1 ile pal ma tele the o plašťos 
\q1 ola, ko stražinen o muros. 
\q1  
\v 8 Den man lav, 
\q1 čhajale andral o Jeruzalem: 
\q1 Te arakhena oles, kas kamav, 
\q1 so leske phenena? 
\q1 Phenen leske, hoj som nasvaľi le kamibnastar! 
\sp O džuvľa 
\q1  
\v 9 Soha hino feder oda, kas kames, avrendar, 
\q1 tu, nekšukareder maškar o džuvľija? 
\q1 Soha hino feder oda, kas kames, avrendar, 
\q1 hoj tut mušinas te del ajso lav? 
\sp E džuvľi 
\q1  
\v 10 Oda, kas me kamav, hino šukar, lolečhamengro, 
\q1 feder sar deš ezera aver. 
\q1  
\v 11 Leskro šero hino ajso šukar sar o žužo somnakaj; 
\q1 leskre bala hine kučerava, kale sar o havranos; 
\q1  
\v 12 leskre jakha hine sar o holubici paš o paňa, 
\q1 avrithode (avrimorde) andro thud, 
\q1 zathode sar o drahokami. 
\q1  
\v 13 Leskre čhama hine sar e zahrada, 
\q1 kaj barol pherdo koreňja; 
\q1 leskre vušta hine sar o ľaľije; 
\q1 kvapkinel lendar e mirha. 
\q1  
\v 14 Leskre vasta hin o somnakune paci, 
\q1 obthode le vzacne barenca; 
\q1 leskro ťelos hin e hladko slonovina 
\q1 šukaľardi le zafirenca. 
\q1  
\v 15 Leskre pindre hin o slupi le parne mramoristar 
\q1 ačhade pro somnakune podstavci. 
\q1 Dičhol avri sar o verchi andro Libanon, 
\q1 učo sar o cedri. 
\q1  
\v 16 Leskre vušta hine igen gule; 
\q1 savoreha man pricirdel. 
\q1 Ajso hino oda, kas kamav, ajso hino miro prijaťeľis, 
\q1 čhajale andral o Jeruzalem! 
\c 6  
\sp O džuvľa 
\q1  
\v 1 Kaj geľa oda murš, saves kames, 
\q1 tu nekšukareder maškar o džuvľija? 
\q1 Pre savo drom visaľiľa oda, kas kames? 
\q1 Odphen amenge, hoj les te džas tuha te rodel. 
\sp E džuvľi 
\q1  
\v 2 Miri laska geľa tele andre peskri zahrada, 
\q1 kaj barol o koreňja, 
\q1 hoj peske te radisaľol andre zahrada 
\q1 a te kidel o ľaľije. 
\q1  
\v 3 Me som oleskri, ko man kamel, a ov hino miro, 
\q1 čaľarel pes maškar o ľaľije. 
\sp O murš 
\q1  
\v 4 Šukar sal, lasko miri, sar e Tirca, 
\q1 ajsi šukar sar o Jeruzalem, 
\q1 užasno sar o čercheňa pro ňebos\f + \fr 6,4 \ft Na džanel pes, so phenel e hebrejiko čhib. \f*. 
\q1  
\v 5 Tire jakha man igen pricirden, 
\q1 ma dikh pre ma! 
\q1 Tire bala hine kale sar o stados le kozengro, 
\q1 so avel tele pal o verchi andro Gilead. 
\q1  
\v 6 Tire danda hine sar o bakrano stados, 
\q1 so sas akana ča žužarde andro paňi. 
\q1 Savoren hin peskri dvojička, 
\q1 aňi jekh lendar na chibaľinel. 
\q1  
\v 7 Tire čhama pal o zavojis 
\q1 hine ajse lole sar e jepaš granatoskri phabaj. 
\q1  
\v 8 Šaj el le kraľis šovardeš kraľovni, 
\q1 ochtovardeš romňija-služobňički 
\q1 a pačivale čhaja buter, sar pes del te zrachinel, 
\q1  
\v 9 ale miri holubica hiňi jekhori, 
\q1 nane pre late ňisavi chiba, 
\q1 jekhori čhaj peskra dakri, 
\q1 nekšukareder olake, ko la anďa pro svetos. 
\q1 Dikhle la o terne čhaja a phende lake: „Požehňimen sal!“ 
\q1 O kraľovni the o romňija-služobňički la lašarenas. 
\b  
\q1  
\v 10 „Ko hin odi, so dikhel uprunestar sar e tosarutňi čercheň, 
\q1 šukar sar o čhonoro, švicinel sar o kham, 
\q1 užasno sar o čercheňa pro ňebos\f + \fr 6,10 \ft Na džanel pes, so phenel e hebrejiko čhib. \f*.“ 
\b  
\q1  
\v 11 Geľom tele andro zahradi, kaj baron o pendecha, 
\q1 te dikhel o neve konarica andre dolina. 
\q1 Kamľom te dikhel, či imar o viňičis mukľa o pučiki 
\q1 a či imar kvitňisaľon o granatoskre phaba. 
\q1  
\v 12 Zaiľa man o radišagos, 
\q1 izdravas avke, sar te geľomas pro kraľiko verdan\f + \fr 6,12 \ft Na džanel pes, so phenel e hebrejiko čhib.\f*. 
\b  
\c 7  
\sp O džuvľa 
\q1  
\v 1 Av pale, av pale, čhaje Šulamitko\f + \fr 7,1 \ft Dokonalo čhaj\f*; 
\q1 av pale, av pale, hoj pre tu te dikhas! 
\sp E džuvľi 
\q1 So kamen pre Šulamitka te dikhel, 
\q1 sar khelel andro taboris?\f + \fr 7,1 \ft Na džanel pes, so phenel e hebrejiko čhib. \f* 
\sp O murš 
\q1  
\v 2 Save šukar hin tire pindre andro sandalki, 
\q1 čhaje le princoskri! 
\q1 Tire klubi hine šukares avrikerde sar o šperki; 
\q1 sar e buči le majstroskre vastengri. 
\q1  
\v 3 Tiri pupa hiňi sar o poharis, 
\q1 andre savo na chibaľinel e koreňimen mol; 
\q1 tiro pasos pašal o per 
\q1 hino sar e pšeňica pre kopa 
\q1 obthoďi le ľaľijenca. 
\q1  
\v 4 Tire koľina hine sar duj terne gazeli, 
\q1 sar dvojički la gazelakre. 
\q1  
\v 5 Tiri meň hiňi sar e veža la slonovinatar; 
\q1 tire jakha hine o jazera andro Chešbon 
\q1 paš e brana Bat-Rabim. 
\q1 Tiro nakh hino ajso šukar 
\q1 sar e veža andro Libanon, 
\q1 so hiňi anglo Damašek. 
\q1  
\v 6 Tiro šero pre tute hin sar o verchos Karmel; 
\q1 tire bare bala tuke bľišťisaľon sar o fijalovo pochtan, 
\q1 o kraľis hino zachudlo andre tire husta bala. 
\q1  
\v 7 Savi šukar sal; pre dzeka mange sal! 
\q1 Miri lasko, sar tutar radisaľuvav! 
\q1  
\v 8 Tiri postava hiňi sar e palma 
\q1 a tire koľina sar lakro ovocje. 
\q1  
\v 9 Phenďom: „Džava upre pre palma 
\q1 a chudava man lendar.“ 
\q1 Mi en tire koľina sar o hroznoskre strapci, 
\q1 mi voňinel tiro dichos sar o voňava phaba 
\q1  
\v 10 a tiro čumiben sar e nekfeder mol. 
\sp E džuvľi 
\q1 Mi džal e mol šukares oleske, kas kamav; 
\q1 mi predžal leske prekal o vušta the danda. 
\q1  
\v 11 Me som oleskri, kas kamav, 
\q1 a ov pal ma džal. 
\q1  
\v 12 Av džas pre maľa, lasko miri; 
\q1 presovaha andro gava; 
\q1  
\v 13 ušťaha sig tosara a džaha andro viňici, 
\q1 dikhaha, či imar kvitňisaľol o viňičis, 
\q1 či pes imar phundraven o kvitki, 
\q1 či imar kvitňisaľon o granatoskre phaba. 
\q1 Ode tuke dava miro kamiben. 
\q1  
\v 14 O mandragori den avri peskri kamibnaskri voňa, 
\q1 paš amaro vudar hin savore vzacna plodi, 
\q1 neve the purane; 
\q1 garuďom tuke len, romoro miro. 
\c 8  
\sp E džuvľi 
\q1  
\v 1 Jaj, te uľalas miro phral, 
\q1 savo pijelas o koľin mira dakro! 
\q1 Avke te tut arakhľomas pre uľica a čumidľomas tut, 
\q1 ta ňiko na phenďahas, hoj namištes kerav. 
\q1  
\v 2 Iľomas tut a anďomas andre mira dakro kher. 
\q1 Tu man ode sikaďalas pal o kamiben 
\q1 a me tut diňomas te pijel e koreňimen mol, 
\q1 o muštos le granatoskre phabendar. 
\q1  
\v 3 Leskro baľogno vast hin tel miro šero 
\q1 a peskre čače vasteha man obchudel. 
\q1  
\v 4 Den man lav, 
\q1 čhajale andral o Jeruzalem! 
\q1 Ma čhalaven amaro kamiben, 
\q1 medik o kamiben korkoro na kamela. 
\sp O džuvľa 
\q1  
\v 5 Koda hiňi odi, ko avel pal e pušťa 
\q1 a oprinel pes pre oda, kas kamel? 
\sp E džuvľi 
\q1 Uštaďom tut, sar salas tel o phabengro stromos. 
\q1 Ode sas tiri daj andro ločhibnaskre dukha, 
\q1 ode pašľiľa andro dukha odi, 
\q1 ko tut anďa pro svetos. 
\q1  
\v 6 Thov tuke man pre tiro jilo sar e pečať, 
\q1 sar e angrusi pre tiro vast; 
\q1 bo o kamiben hin ajso zoralo sar o meriben 
\q1 a e vašeň ľikerel ajci sar o hrobos. 
\q1 Labol sar e zoraľi jag, sar o baro plameňis. 
\q1  
\v 7 Aňi but paňi našťi ačhavel o kamiben, 
\q1 aňi o bare paňa les našťi tašľaren. 
\q1 Te vareko kamľahas te del vaš o kamiben 
\q1 savoro barvaľipen andral peskro kher, 
\q1 uľahas calkom teledikhlo. 
\sp O džuvľa 
\q1  
\v 8 Hin amen cikňi pheňori 
\q1 a lakre koľina hine mek ciknore. 
\q1 So keraha amara pheňaha oda džives, 
\q1 sar la avena te mangavel? 
\q1  
\v 9 Te hiňi muros, 
\q1 ačhavaha pre late o rupune veži! 
\q1 Te hiňi vudar, 
\q1 zakeraha la andre le cedroskre deskenca! 
\sp E džuvľi 
\q1  
\v 10 Me som muros 
\q1 a mire koľina hine sar o veži! 
\q1 Akor ačhiľom andre leskre jakha 
\q1 sar odi, ko anel pherdo radišagos\f + \fr 8,10 \ft E hebrejiko čhib: šalom\f*. 
\sp O murš 
\q1  
\v 11 Le Šalamun sas e viňica andro Baal-Hamon\f + \fr 8,11 \ft Oda hin: raj upral o barvaľipen\f*, 
\q1 odi viňica diňa le manušenge, hoj pes te starinen. 
\q1 Sako počinďahas vaš lakro ovocje 
\q1 ezeros rupune. 
\q1  
\v 12 Ale miri viňica, hiňi miri, 
\q1 hiňi prekal mande. 
\q1 Muk tuke, Šalamun, o ezeros rupune prekal tu 
\q1 a o duj šel prekal ola, ko pes starinen pal o ovocje. 
\b  
\q1  
\v 13 Tu, savo bešes andro zahradi, 
\q1 mire prijaťeľa mištes šunen pre tiro hangos. 
\q1 Domuk the mange te šunel! 
\sp E džuvľi 
\q1  
\v 14 Romoro miro, av ke ma sigo, 
\q1 denaš sar e gazela, 
\q1 abo sar o terno jeleňis pro verchos, 
\q1 kaj baron o koreňja!