\id 1CO
\h 1 إِكُورِينْثِييّنْ 
\toc1 1 إِكُورِينْثِييّنْ 
\toc2 1 إِكُورِينْثِييّنْ 
\toc3 1 كُور. 
\mt1 1 إِكُورِينْثِييّنْ  
\c 1
\s1 أَسدْجمْ غَارْ ؤُمزْوَارُو  
\m
\v 1 بُولُوسْ، \add رَّاسُولْ\add* إِتّْوَاڒَاغَانْ ذ إِتّْوَاسكّنْ ن يَاسُوع لْمَاسِيحْ عْلَاحْسَابْ مِينْ إِخْسْ أَربِّي، ذ ثَاوْمَاثْ سُوسْثِينِيسْ، \f ◼ \fr 1:‏1 \ft \+bd ’رَّاسُولْ‘\+bd* - نِيغْ ’أَمَازَانْ‘.\f*  
\v 2 إِ ثْمسْمُونْثْ ن أَربِّي إِ إِدْجَانْ ذِي كُورِينْثُوسْ، إِنِّي إِتّْوَاڒَاغَانْ ذ إِنِّي ذ إِمْقدَّاسنْ، إِنِّي إِتّْوَاقدّْسنْ ذِي يَاسُوع لْمَاسِيحْ، ؤُ إِ مَارَّا إِنِّي مَانِي مَا إِتّْڒَاغَانْ خْ يِيسمْ ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ، ونِّي ذ سِيذِيثْسنْ ذ سِيذِيثْنغْ. \x ◘ \xo 1:‏2 \xt يُوح. 17‏:‏19؛ ڒخ. 15‏:‏9؛ رُوم. 1‏:‏7؛ أَفا. 1‏:‏1؛ 1 تس. 4‏:‏7؛ 2 تِيم. 2‏:‏22. \x*  
\v 3 أَذْ خَاومْ يِيڒِي أَرْضَا ذ ڒهْنَا زِي أَربِّي، بَابَاثْنغْ، ؤُ زِي سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ. \x ◘ \xo 1:‏3 \xt رُوم. 1‏:‏7؛ 2 كُور. 1‏:‏2؛ أَفا. 1‏:‏2؛ 1 بُط. 1‏:‏2. \x*   
\b  
\m
\v 4 نشّْ ڒبْذَا تّْقَاذِيغْ أَربِّي إِنُو ذِي طّْوعْ نْومْ خْ أَرْضَا ن أَربِّي إِ ذ أَومْ إِمّوْشنْ ذِي يَاسُوع لْمَاسِيحْ.  
\v 5 مِينْزِي ذِي مَارَّا ثْذوْڒمْ زَّايسْ ذ تُّوجَّارْ، ذِي مَارَّا أَوَاڒْ ؤُ ذِي مَارَّا ثُوسّْنَا، \x ◘ \xo 1:‏5 \xt كُول. 1‏:‏9. \x*  
\v 6 مَاغَارْ شّْهَاذثْ ن لْمَاسِيحْ ثتّْوَاضْمنْ ذَايْومْ،  
\v 7 مِينْزِي ؤُڒَا ذ إِجّْ ن زّْعَافْ ن ثوْهِيبِينْ نّسْ وَارْ ذَايْومْ إِقِّيمْ، \add أَمْ\add* ثتّْرَاجَامْ أَسَارْڭَابْ ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ، \x ◘ \xo 1:‏7 \xt فِيل. 3‏:‏20؛ ثِيث. 2‏:‏13. \x*  
\v 8 مِينْزِي نتَّا أَذْ كنِّيوْ إِضْمنْ عَاوذْ غَارْ ؤُنڭَّارْ، حِيمَا أَذْ ثِيڒِيمْ بْڒَا ڒْعِيبْ ذڭْ وَاسّْ ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ. \x ◘ \xo 1:‏8 \xt 1 تس. 3‏:‏13؛ 5‏:‏23. \x*  
\v 9 أَربِّي ذ أَمْثِيقِّي، ذ ونِّي زِي ثتّْوَاڒَاغَامْ كنِّيوْ غَارْ ثْمُونْثْ أَكْ-ذ مِّيسْ يَاسُوع لْمَاسِيحْ، سِيذِيثْنغْ. \x ◘ \xo 1:‏9 \xt إِرْم. 32‏:‏40‏-‏44؛ يُوح. 15‏:‏5؛ 1 كُور. 10‏:‏13؛ ڭال. 2‏:‏20؛ 1 تس. 5‏:‏24؛ 1 يُوح. 1‏:‏3. \x*   
\b  
\m  
\s1 أَڒَاغِي غَارْ ؤُمُونِي ذ إِجّنْ ذِي لْمَاسِيحْ  
\m
\v 10 مَاشَا تّْزَاوَاڭغْ كنِّيوْ، \add أَ\add* أَيْثْمَا، س يِيسمْ ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ، أَذْ ثسِّيوْڒمْ مَارَّا س إِجّْ ن وَاوَاڒْ، وَارْ ثتّمْسبْضِيمْ جَارْ أَومْ، مَاشَا إِڒِيمْ ثْمُونمْ نِيشَانْ س نّيّثْ ذ إِشْثنْ ذ ؤُخَارّصْ ذ إِجّنْ. \x ◘ \xo 1:‏10 \xt رُوم. 12‏:‏16؛ 15‏:‏5؛ فِيل. 2‏:‏2؛ 3‏:‏16؛ 1 بُط. 3‏:‏8. \x*  
\v 11 مِينْزِي سَّارْڭْبنْ أَيِي إِنِّي زِي ثَادَّارْثْ ن كْلُووِي، \add أَ\add* أَيْثْمَا إِنُو، بلِّي جَارْ أَومْ إِمنْغَانْ.  
\v 12 خْسغْ أَذْ إِنِيغْ، أَقَا شَا زَّايْومْ قَّارنْ: ’نشّْ أَقَا أَيِي زِي بُولُوسْ!‘ ؤُ شَا نّغْنِي: ’نشّْ زِي أَپُولُّوسْ!‘، ؤُ شَا نّغْنِي \add عَاوذْ\add*: ’نشّْ زِي كِيفَا!‘، ؤُ شَا نّغْنِي قَّارنْ: ’نشّْ زِي لْمَاسِيحْ!‘ \x ◘ \xo 1:‏12 \xt ڒخ. 18‏:‏24؛ 1 كُور. 3‏:‏4؛ 16‏:‏12. \x*  
\v 13 مَا أَقَا لْمَاسِيحْ إِتّْوَابْضَا \add ذ إِوثْوِيثنْ\add*؟ مَا ثُوغَا بُولُوسْ إِتّْوَاصلّبْ ذِي سِّيبّثْ نْومْ؟ نِيغْ ثُوغَا كنِّيوْ ثتّْوَاسّْغضْصمْ س يِيسمْ ن بُولُوسْ؟  
\v 14 نشّْ تّْقَاذِيغْ أَربِّي إِنُو وَارْ سّْغضْصغْ ؤُڒَا ذ إِجّْ زَّايْومْ مْغِيرْ كْرِيسْپُوسْ ذ خَايُوسْ وَاهَا، \x ◘ \xo 1:‏14 \xt ڒخ. 18‏:‏8؛ رُوم. 16‏:‏23. \x*  
\v 15 أَڒَامِي ؤُڒَا ذ إِجّنْ أَذْ يِينِي بلِّي سّْغضْصغْ ذڭْ يِيسمْ إِنُو.  
\v 16 عَاوذْ سّْغضْصغْ ثَاوَاشُونْثْ ن سْثِيفَانُوسْ، خنِّي وَارْ سِّينغْ شَا، مَا سّْغضْصغْ حذْ نّغْنِي. \x ◘ \xo 1:‏16 \xt 1 كُور. 16‏:‏15، 17. \x*  
\v 17 مَاغَارْ لْمَاسِيحْ وَارْ ذ أَيِي د-إِسّكّْ حِيمَا أَذْ سّْغضْصغْ، مَاشَا حِيمَا أَذْ بَارّْحغْ س ڒخْبَارْ أَصبْحَانْ، وَارْ إِدْجِي س ثِيغِيثْ ن وَاوَاڒنْ، حِيمَا وَارْ إِتّتّْوَاسّْبطّڒْ صَّالِيبْ ن لْمَاسِيحْ. \x ◘ \xo 1:‏17 \xt 1 كُور. 2‏:‏1، 4؛ 2 بُط. 1‏:‏16. \x*   
\b  
\m  
\s1 ثِيغِيثْ ن أَربِّي  
\m
\v 18 مِينْزِي أَوَاڒْ ن صَّالِيبْ ذ ثُوبُّوهڒْيَا ذِي ثِيطَّاوِينْ ن يِينِّي إِ غَا إِودَّارنْ، مَاشَا إِ نشِّينْ، إِنِّي إِدَّارنْ، مَانْ أَيَا ذ جّهْذْ ن أَربِّي. \x ◘ \xo 1:‏18 \xt رُوم. 1‏:‏16. \x*  
\v 19 مِينْزِي ثُورَا:  
\b  
\m \qt ”أَذْ أَردّْدْجغْ ثِيغِيثْ ن إِمِيغِيسنْ\qt*  
\m \qt ؤُشَا أَذْ كّْسغْ ڒفْهَامثْ ن إِفهَّامنْ.“\qt* \x ◘ \xo 1:‏19 \xt أَيُوبْ 5‏:‏12؛ إِشا. 29‏:‏14. \x*   
\b  
\m
\v 20 مَانِي إِدْجَا ؤُمِيغِيسْ؟ مَانِي إِدْجَا ؤُمْسڒْمَاذْ ن إِذْلِيسنْ؟ مَانِي إِدْجَا بُو-ؤُمْحَارْوضْ ن دُّونشْثْ-أَ؟ مَا وَارْ إِسّْشنْ أَربِّي بلِّي ثِيغِيثْ ن دُّونشْثْ-أَ ذ ثُوبُّوهڒْيَا؟ \x ◘ \xo 1:‏20 \xt إِشا. 33‏:‏18. \x*  
\v 21 مِينْزِي ذِي ثِيغِيثْ ن أَربِّي، دُّونشْثْ وَارْ ثسِّينْ شَا أَربِّي زِي سِّيبّثْ ن ثِيغِيثْ \add ن يِيخفْ نّسْ\add*، أَقَا ثُوغَا يَارْضَا أَربِّي أَذْ إِوْشْ ثُوذَارْثْ إِ يِينِّي يُومْننْ س ثُوبُّوهڒْيَا ن ثْبَارّحْثْ. \x ◘ \xo 1:‏21 \xt مت. 11‏:‏25؛ لك. 10‏:‏21. \x*  
\v 22 مِينْزِي ؤُذَاينْ تَّارنْ ڒعْڒَامَاثْ ؤُ إِرَامِييّنْ أَرزُّونْ ثِيغِيثْ، \x ◘ \xo 1:‏22 \xt مت. 12‏:‏38؛ 16‏:‏1؛ يُوح. 4‏:‏48. \x*  
\v 23 مَاشَا نشِّينْ نتّْبَارّحْ لْمَاسِيحْ، ذ ونِّي إِتّْوَاصلّْبنْ، أَقَا-ث ذ ثَاعنْكْرِيفْثْ إِ وُوذَاينْ، ذ ثُوبُّوهڒْيَا إِ إِرَامِييّنْ، \x ◘ \xo 1:‏23 \xt مت. 11‏:‏6. يُوح. 6‏:‏60، 66. \x*  
\v 24 مَاشَا إِ يِينِّي إِتّْوَاڒَاغَانْ، أَمْ وُوذَاينْ أَمْ إِرَامِييّنْ، أَقَا لْمَاسِيحْ ذ جّهْذْ ن أَربِّي ذ ثِيغِيثْ ن أَربِّي. \x ◘ \xo 1:‏24 \xt كُول. 2‏:‏3. \x*  
\v 25 مِينْزِي ثُوبُّوهڒْيَا ن أَربِّي ذ ثْمِيغِيسْثْ خْ إِوْذَانْ، ؤُ ثُوضْعفْثْ ن أَربِّي ثجْهذْ خْ إِوْذَانْ.   
\m
\v 26 خنِّي، \add أَ\add* أَيْثْمَا، خْزَارمْ \add مَامّشْ ثدْجَامْ\add* غَارْ \add وَاسّْ ن\add* ثْڒَاغِيثْ نْومْ، أَقَا وَارْ ثدْجِيمْ ذ أَطَّاسْ ن إِمِيغِيسنْ عْلَاحْسَابْ بْنَاذمْ، نِيغْ ذ أَطَّاسْ ن يِينِّي غَارْ ثدْجَا صُّولْطَا، نِيغْ ذ أَطَّاسْ ن ثَارْوَا ن ثَاصِيڒثْ. \x ◘ \xo 1:‏26 \xt يُوح. 7‏:‏48؛ يَاع. 2‏:‏5. \x*  
\v 27 مَاغَارْ أَربِّي أَقَا إِفَارْزْ إِپُوهَاڒِييّنْ ن دُّونشْثْ، حِيمَا أَذْ زَّايْسنْ إِسّحْشمْ إِمِيغِيسنْ، ؤُشَا إِمُوضْعِيفنْ ن دُّونشْثْ إِفَارْزْ إِ-ثنْ أَربِّي، حِيمَا أَذْ زَّايْسنْ إِسّحْشمْ أَيْثْ ن بُو-صُّولْطَا.  
\v 28 ؤُشَا يِينِّي د-إِخڒْقنْ أَمْ وَارْ غَارْسنْ شَا ذِي دُّونشْثْ، ذ يِينِّي إِتّْوَاسّحْقَارنْ، ذ يِينِّي وَارْ إِدْجِينْ ذ شَا، أَقَا إِفَارْزْ إِ-ثنْ أَربِّي، حِيمَا أَذْ إِبْضڒْ إِنِّي إِدْجَانْ ذ شَا،  
\v 29 حِيمَا ؤُڒَا ذ إِجّْ ن \add بْنَاذمْ ن\add* ويْسُومْ، وَارْ إِتّْفيّشْ شَا زَّاثسْ.  
\v 30 مَاشَا كنِّيوْ ثدْجَامْ زَّايسْ ذِي يَاسُوع لْمَاسِيحْ، ونِّي ذ أَنغْ إِذوْڒنْ ذ ثِيغِيثْ ن أَربِّي ذ ثْسڭْذَا ذ ثُوقدّْسِي ذ ؤُسنْجمْ، \x ◘ \xo 1:‏30 \xt إِرْم. 23‏:‏5؛ يُوح. 17‏:‏19. \x*  
\v 31 أَمْ مَامّشْ ثُورَا: \qt ”أجّْ ونِّي إِسّمْغَارَانْ، أَذْ إِسّمْغَارْ ذِي سِيذِي.“\qt* \x ◘ \xo 1:‏31 \xt إِشا. 65‏:‏16؛ إِرْم. 9‏:‏22‏-‏23؛ 2 كُور. 10‏:‏17. \x*   
\b  
\b  
\m  
\c 2
\s1 صِّيفثْ ن ثْسخَّارْثْ ن بُولُوسْ  
\m
\v 1 \add أَ\add* أَيْثْمَا، ڒَامِي د-ؤُسِيغْ غَارْومْ، وَارْ د-ؤُسِيغْ شَا حِيمَا أَذْ أَومْ بَارّْحغْ ڒخْبَارْ أَصبْحَانْ ن سِّيرّْ ن أَربِّي س ثْبزَّاحْثْ ن وَاوَاڒْ نِيغْ س ثِيغِيثْ، \x ◘ \xo 2:‏1 \xt 1 كُور. 1‏:‏17؛ 2‏:‏4. \x*  
\v 2 مِينْزِي أَقَا ثُوغَاعوّْڒغْ حِيمَا وَارْ تّسّْنغْ شَا جَارْ أَومْ مْغِيرْ يَاسُوع لْمَاسِيحْ، ذ ونِّي إِتّْوَاصلّْبنْ عَاوذْ.  
\v 3 ثُوغَا أَيِي أَكِيذْومْ س وَاطَّاسْ ن ثِيڭّْوُوذِي ذ ؤُقْذِيذسْ. \x ◘ \xo 2:‏3 \xt ڒخ. 18‏:‏1، 3؛ 2 كُور. 10‏:‏10. \x*  
\v 4 ثَابْرَاثْ إِنُو ذ ثْبَارّحْثْ إِنُو وَارْ د-ؤُسِينْثْ-إِ-د س وَاوَاڒنْ إِزوّْقنْ ن ثِيغِيثْ \add ن بْنَاذمْ\add*، مَاشَا س وسْشَانْ ن أَرُّوحْ ذ جّهْذْ، \x ◘ \xo 2:‏4 \xt 1 كُور. 1‏:‏17؛ 2‏:‏1؛ 2 بُط. 1‏:‏16. \x*  
\v 5 حِيمَا لْ-إِيمَانْ نْومْ وَارْ إِتّْبذِّي شَا خْ ثِيغِيثْ ن إِوْذَانْ، مَاشَا خْ جّهْذْ ن أَربِّي. \x ◘ \xo 2:‏5 \xt 2 كُور. 4‏:‏7. \x*   
\m
\v 6 مَاشَا نسَّاوَاڒْ س ثِيغِيثْ إِ يِينِّي ث إِوْضنْ، أَقَا س إِشْثْ ن ثِيغِيثْ ثنِّي وَارْ إِدْجِينْ ن دُّونشْثْ-أَ نِيغْ ن ڒْحُوكَّامْ ن دُّونشْثْ-أَ، إِنِّي إِ غَا إِتّْوَاسّْبطّْڒنْ، \x ◘ \xo 2:‏6 \xt أَيُوبْ 28‏:‏21؛ 1 كُور. 15‏:‏24. \x*  
\v 7 مَاشَا نسَّاوَاڒْ ثِيغِيثْ ن أَربِّي س إِجّْ ن سِّيرّْ إِ ثُوغَا إِنُوفَّارنْ، ونِّي ثُوغَا إِزَّارْ إِفَارْزْ إِ-ث أَربِّي إِ ؤُعُودْجِي نّغْ قْبڒْ إِ ثُوغَا ذِينْ زّْمَانَاثْ. \x ◘ \xo 2:‏7 \xt رُوم. 16‏:‏25؛ 1 كُور. 4‏:‏1. \x*  
\v 8 \add وَا ذ سِّيرّْ\add* نِّي وَارْ ث إِسِّينْ ؤُڒَا ذ إِجّْ زِي ڒْحُوكَّامْ ن دُّونشْثْ-أَ، مِينْزِي مَاڒَا ثُوغَا سّْننْ ث، إِڒِي وَارْ صلّْبنْعمَّارْصْ سِيذِي ن ؤُعُودْجِي. \x ◘ \xo 2:‏8 \xt مت. 11‏:‏25؛ يُوح. 7‏:‏48؛ 16‏:‏3؛ ڒخ. 3‏:‏17؛ 13‏:‏27؛ 2 كُور. 3‏:‏14؛ 1 تِيم. 1‏:‏13. \x*  
\v 9 مَاشَا أَمْ مَامّشْ ثُورَا:  
\b  
\m \qt ”مِينْ وَارْ ثژْرِي ثِيطّْ ذ مِينْ وَارْ إِسْڒِي ؤُمزُّوغْ\qt*  
\m \qt ذ مِينْ وَارْ يُوذِيفنْ شَا غَارْ وُوڒْ ن بْنَاذمْ،\qt*  
\m \qt أَقَا مَانْ أَيَا إِسّوْجذْ إِ-ث أَربِّي إِ يِينِّي ث إِتّخْسنْ.“\qt* \x ◘ \xo 2:‏9 \xt إِشا. 64‏:‏3. \x*   
\b  
\m
\v 10 مَاشَا أَربِّي إِمّڒْ أَنغْ ث س أَرُّوحْ نّسْ، مِينْزِي أَرُّوحْ ثَارزُّو كُوڒْشِي ؤُڒَا ذ ڒَادْجَاغْ ن أَربِّي. \x ◘ \xo 2:‏10 \xt مت. 13‏:‏11؛ 2 كُور. 3‏:‏18. \x*  
\v 11 مِينْزِي مَانْ ونْ ذ بْنَاذمْ إِ إِسّْننْ مِينْ إِدْجَانْ ذِي بْنَاذمْ مْغِيرْ أَرُّوحْ ن بْنَاذمْ ونِّي ذَايسْ إِدْجَانْ. أَمُّو عَاوذْ ؤُڒَا ذ إِجّْ وَارْ إِسِّينْ شَا مِينْ إِدْجَانْ ذِي أَربِّي مْغِيرْ أَرُّوحْ ن أَربِّي. \x ◘ \xo 2:‏11 \xt أَوڒن. 27‏:‏19؛ إِرْم. 17‏:‏9. \x*   
\m
\v 12 أَقَا نشِّينْ وَارْ نكْسِي شَا أَرُّوحْ ن دُّونشْثْ، مَاشَا أَرُّوحْ إِ د-يُوسِينْ زِي أَربِّي، حِيمَا أَذْ نسّنْ مِينْ ذ أَنغْ إِوْشَا أَربِّي. \x ◘ \xo 2:‏12 \xt رُوم. 8‏:‏15. \x*  
\v 13 س ؤُينِّي أَوَاڒنْ إِ زِي نسَّاوَاڒْ، وَارْ دْجِينْ ذ ثْغُورِي س وَاوَاڒنْ ن ثِيغِيثْ ن بْنَاذمْ، مَاشَا ذ ثْغُورِي زِي أَرُّوحْ، حِيمَا أَذْ نسّمْقُودَّا مِينْ إِدْجَانْ ن أَرُّوحْ أَكْ-ذ مِينْ إِدْجَانْ ن أَرُّوحْ. \x ◘ \xo 2:‏13 \xt 1 كُور. 1‏:‏17؛ 2‏:‏4؛ 2 بُط. 1‏:‏16\x*  
\v 14 مَاغَارْ بْنَاذمْ س يِيخفْ نّسْ وَارْ إِقبّڒْ شَا مِينْ إِدْجَانْ ن أَرُّوحْ، مِينْزِي إِحسْبْ إِ-ث ذ ثُوبُّوهڒْيَا، وَارْ إِزمَّارْ أَذْ ث إِفْهمْ، مِينْزِي مَانْ أَيَا إِزمَّارْ أَذْ إِتّْوَافَارْزْ س أَرُّوحْ وَاهَا.  
\v 15 مَاشَا بْنَاذمْ أَرُّوحَانِي أَقَا إِزمَّارْ أَذْ إِفَارْزْ كُوڒْشِي، مَاشَا نتَّا سِيمَانْثْ نّسْ وَارْ خَاسْ إِحكّمْ ؤُڒَا ذ إِجّْ. \x ◘ \xo 2:‏15 \xt أَوڒن. 28‏:‏5. \x*  
\v 16 مِينْزِي وِي إِسّْننْ أَخمّمْ ن سِيذِي أَڒَامِي \add إِزمَّارْ\add* أَذْ ث إِسّڒْمذْ؟ مَاشَا نشِّينْ غَارْنغْ أَخمّمْ ن لْمَاسِيحْ. \x ◘ \xo 2:‏16 \xt إِشا. 40‏:‏13؛ رُوم. 11‏:‏34. \x*   
\b  
\b  
\m  
\c 3
\s1 ڒبْنِي ن لْ-إِيمَانْ خْ ذْسَاسْ نِيشَانْ  
\m
\v 1 \add أَ\add* أَيْثْمَا، نشّْ وَارْ زمَّارغْ أَذْ كِيومْ سِّيوْڒغْ أَمْ إِوْذَانْ إِنِّي إِدَّارنْ عْلَاحْسَابْ أَرُّوحْ، مَاشَا أَمْ يِينِّي إِدَّارنْ عْلَاحْسَابْ أَيْسُومْ \add ن بْنَاذمْ\add* وَاهَا، أَمشْنَاوْ إِسيْمَانْ ذِي لْمَاسِيحْ.  
\v 2 أَقَا وْشِيغْ أَومْ أَذْ ثسْومْ أَغِي، وَارْ إِدْجِي ذ أَڒقِّيمْ إِمْثنْ، مِينْزِي ثُوغَا وَارْ ذ أَسْ ثْزمَّارمْ، أَڒْ إِ ڒخُّو ؤُ وَارْ ذ أَسْ ثْزمَّارمْ عَاذْ، \x ◘ \xo 3:‏2 \xt عبر. 5‏:‏12؛ 1 بُط. 2‏:‏2. \x*  
\v 3 س مِينْزِي كنِّيوْ عَاذْ ذڭْ ويْسُومْ. مَاغَارْ مَاڒَا ذِينْ \add عَاذْ\add* جَارْ أَومْ ڒحْسذْ ذ إِمنْغَانْ ذ ؤُمْسبْضِي، مَا وَارْ ثدْجِيمْ عَاذْ ن دَّاثْ نِيغْ ثڭُّورمْ \add عَاذْ\add* ذڭْ ويْسُومْ؟ \x ◘ \xo 3:‏3 \xt 1 كُور. 1‏:‏11؛ ڭال. 5‏:‏19؛ يَاع. 3‏:‏16. \x*  
\v 4 مِينْزِي مَاڒَا إِجّنْ زَّايْومْ إِقَّارْ: ’نشّْ أَقَا أَيِي زِي بُولُوسْ!‘ ؤُ ونّغْنِي إِقَّارْ: ’نشّْ أَقَا أَيِي زِي أَپُولُّوسْ!‘، مَا خنِّي كنِّيوْ وَارْ ثدْجِيمْ شَا دَّاثْ؟ \x ◘ \xo 3:‏4 \xt 1 كُور. 1‏:‏12. \x*  
\v 5 مَاغَارْ مِينْ إِعْنَا أَپُولُّوسْ ؤُ مِينْ إِعْنَا بُولُوسْ؟ أَقَا أَثنْ مْغِيرْ ذ إِمْسخَّارنْ إِ زِي ثْذوْڒمْ ثُومْنمْ، ؤُشَا كُوڒْ إِجّنْ أَمْ مَامّشْ ذ أَسْ إِوْشَا سِيذِي. \x ◘ \xo 3:‏5 \xt ڒخ. 18‏:‏24؛ 1 كُور. 1‏:‏12؛ 16‏:‏12. \x*  
\v 6 أَقَا نشّْ ژُّوغْ، أَپُولُّوسْ إِسُّو، مَاشَا أَربِّي إِسّغْمِي. \x ◘ \xo 3:‏6 \xt ڒخ. 18‏:‏26؛ 19‏:‏1. \x*  
\v 7 خنِّي ونِّي إِتّژُّونْ وَارْ إِدْجِي ذ شَا ؤُڒَا ذ ونِّي إِتّسُّونْ، مَاشَا أَربِّي ونِّي إِسّْغمَّاينْ.  
\v 8 مَاشَا ونِّي إِتّژُّونْ ذ ونِّي إِتّسُّونْ ذ إِجّنْ، وَاخَّا كُوڒْ إِجّْ ثكَّارْ أَسْ-د ڒْمُونثْ نّسْ أَمْ مَامّشْ ڒْخذْمثْ نّسْ. \x ◘ \xo 3:‏8 \xt إِزهد. 62‏:‏13؛ إِرْم. 17‏:‏10؛ 32‏:‏19؛ مت. 16‏:‏27؛ رُوم. 2‏:‏6؛ 14‏:‏12؛ 2 كُور. 5‏:‏10؛ ڭال. 6‏:‏5؛ أَسَا. 2‏:‏23؛ 22‏:‏12. \x*  
\v 9 مِينْزِي نشِّينْ ذ إِمْسخَّارنْ أَكْ-ذ أَربِّي ؤُشَا كنِّيوْ ذ ثَافدْجَاحْثْ ذ ڒبْنِي ن أَربِّي إِ ثدْجَامْ. \x ◘ \xo 3:‏9 \xt 2 كُور. 6‏:‏1؛ أَفا. 2‏:‏20؛ كُول. 2‏:‏7؛ 1 بُط. 2‏:‏5. \x*   
\m
\v 10 عْلَاحْسَابْ أَرْضَا ن أَربِّي إِ ذ أَيِي إِمّوْشنْ، نشّْ، أَمْ ڒمْعدْجمْ أَبنَّايْ أَمِيغِيسْ، ڭِّيغْ ذْسَاسْ ؤُ ونّغْنِي أَذْ خَاسْ إِبْنَا. أجّْ كُوڒْ إِجّْ أَذْ إِحْضَا مَامّشْ خَاسْ إِ غَا إِبْنَا.  
\v 11 مِينْزِي ؤُڒَا ذ إِجّنْ وَارْ إِزمَّارْ أَذْ إِڭّْ ذْسَاسْ نّغْنِي خْ ونِّي إِمَّارْسنْ، أَقَا-ث ذ يَاسُوع لْمَاسِيحْ. \x ◘ \xo 3:‏11 \xt إِشا. 28‏:‏16؛ مت. 16‏:‏18. \x*  
\v 12 ؤُشَا مَاڒَا إِبْنَا حذْ خْ ذْسَاسْ نِّي س وُورغْ، نُّوقَارْثْ، إِژْرَا إِغْڒَانْ، ثفْڒَاوْثْ. ڒُومْ نِيغْ س ؤُخشْخُوشْ،  
\v 13 ڒْخذْمثْ ن كُوڒْ إِجّنْ أَذْ ثْبَانْ، مِينْزِي أَسّْ أَذْ ت إِسّْشنْ. مِينْزِي س ثِيمسِّي أَذْ إِتّْوَاسّضْهَارْ مَامّشْ ثدْجَا ڒْخذْمثْ ن كُوڒْ  إِجّْ، ثِيمسِّي أَذْ ت ثْفَارْزْ. \x ◘ \xo 3:‏13 \xt إِشا. 8‏:‏20؛ 48‏:‏10؛ إِرْم. 23‏:‏29؛ 1 بُط. 1‏:‏7؛ 4‏:‏12. \x*  
\v 14 مَاڒَا ثقِّيمْ ڒْخذْمثْ \add ن ڒبْنِي\add* إِ \add خَاسْ\add* ثُوغَا إِبْنَا شَا ن إِجّنْ، أَقَا نتَّا أَذْ إِطّفْ ڒْمُونثْ نّسْ،  
\v 15 ؤُ مَاڒَا ثشْمضْ ڒْخذْمثْ ن شَا ن إِجّنْ، أَقَا نتَّا أَذْ يَارْبُو ثَاخسَّارْثْ نّسْ، مَاشَا نتَّا سِيمَانْثْ نّسْ أَذْ إِنْجمْ أَخْمِي إِكَّا ثِيمسِّي.   
\m
\v 16 مَا وَارْ ثسِّينمْ شَا بلِّي ثدْجَامْ ذ زَّاوشْثْ ن أَربِّي ؤُشَا بلِّي أَرُّوحْ ن أَربِّي إِزدّغْ ذَايْومْ؟ \x ◘ \xo 3:‏16 \xt 1 كُور. 6‏:‏19؛ 2 كُور. 6‏:‏16؛ عبر. 3‏:‏6؛ 1 بُط. 2‏:‏5. \x*  
\v 17 مَاڒَا يَاريّبْ حذْ زَّاوشْثْ ن أَربِّي، أَربِّي أَذْ ث يَاريّبْ، مِينْزِي زَّاوشْثْ ن أَربِّي، ثنِّي ثدْجَامْ كنِّيوْ، ثْقدّسْ إِ ثدْجَا.   
\m
\v 18 وَارْ تّجِّي حذْ أَذْ إِخدّعْ إِخفْ نّسْ! مَاڒَا ذِينْ حذْ جَارْ أَومْ إِتّْغِيڒْ أَسْ إِخفْ نّسْ ذ أَمِيغِيسْ ذِي دُّونشْثْ-أَ، أجّْ إِ-ث أَذْ إِذْوڒْ ذ أَبُوهَاڒِي مَاحنْذْ أَذْ يِيڒِي ذ أَمِيغِيسْ. \x ◘ \xo 3:‏18 \xt أَوڒن. 3‏:‏7؛ إِشا. 5‏:‏21. \x*  
\v 19 مِينْزِي ثِيغِيثْ ن دُّونشْثْ-أَ ثدْجَا ذ ثُوبُّوهڒْيَا غَارْ أَربِّي، مِينْزِي ثُورَا:  
\b  
\m \qt ”إِطّفْ إِمِيغِيسنْ س ثحْرَايْمشْثْ نْسنْ!“،\qt* \x ◘ \xo 3:‏19 \xt أَيُوبْ 5‏:‏13. \x*   
\b  
\m
\v 20 ؤُشَا عَاوذْ:  
\b  
\m \qt ”سِيذِي إِسّْننْ أَقَا إِخَارِّيصنْ ن إِمِيغِيسنْ ذ ڒْبَاطڒْ.“\qt* \x ◘ \xo 3:‏20 \xt إِزهد. 94‏:‏11. \x*   
\b  
\m
\v 21 س ؤُيَا، ؤُڒَا ذ إِجّنْ وَارْ إِسّمْغَارِي شَا زڭْ إِوْذَانْ، مِينْزِي مَارَّا نْومْ،  
\v 22 مَا ذ بُولُوسْ، نِيغْ ذ أَپُولُّوسْ، نِيغْ ذ كِيفَا، نِيغْ ذ دُّونشْثْ، نِيغْ ذ ثُوذَارْثْ، نِيغْ ذ ڒْموْثْ، نِيغْ ذ إِضَا نِيغْ ذ ثِيوشَّا، أَقَا مَارَّا نْومْ،  
\v 23 مَاشَا كنِّيوْ ن لْمَاسِيحْ ؤُشَا لْمَاسِيحْ ن أَربِّي.   
\b  
\b  
\m  
\c 4
\s1 رُّوسُولْ ن لْمَاسِيحْ  
\m
\v 1 أجّْ أَنغْ خنِّي أَذْ نتّْوَاحْسبْ زَّايْومْ أَمْ إِمْسخَّارنْ ن لْمَاسِيحْ ؤُ أَمْ إِوْكِيڒنْ ن ڒسْرَارْ ن أَربِّي. \x ◘ \xo 4:‏1 \xt مت. 24‏:‏45؛ 2 كُور. 6‏:‏4؛ كُول. 1‏:‏25؛ ثِيث. 1‏:‏7. \x*  
\v 2 خنِّي إِتّْخصَّا إِ مْكُوڒْ أَوْكِيڒْ أَذْ إِتّْوَافْ ذ أَمْثِيقِّي. \x ◘ \xo 4:‏2 \xt لك. 12‏:‏42. \x*  
\v 3 نشّْ وَارْ ذ أَيِي إِشْقِي شَا مَاڒَا تّْوَاحكْمغْ زَّايْومْ نِيغْ زڭْ إِجّْ ن بْنَاذمْ \add نّغْنِي\add*. ؤُڒَا ذ نشّْ وَارْ حكّْمغْ شَا خْ إِخفْ إِنُو.  
\v 4 مِينْزِي نشّْ وَارْ ؤُشِيغْ س شَا \add وَارْ إِحْڒِينْ\add* ذَايِي، مَاشَا س مَانْ أَيَا وَارْ تّْوَاسڭّْذغْ، مَاغَارْ أَقَا سِيذِي ذ ڒْقَاضِي إِنُو. \x ◘ \xo 4:‏4 \xt ؤُف. 34‏:‏7؛ أَيُوبْ 9‏:‏2؛ إِزهد. 143‏:‏2. \x*  
\v 5 س ؤُينِّي وَارْ حكّْممْ شَا خْ وَالُو قْبڒْ ڒْوقْثْ نِّي ذِي د غَا يَاسْ سِيذِي، ونِّي إِ غَا إِسُّوفّْغنْ غَارْ ثْفَاوْثْ مِينْ إِنُّوفَارنْ ذِي ثَادْجسْثْ، ونِّي إِ غَا إِسّضْهَارنْ إِخَارِّيصنْ ن وُوڒَاونْ. ؤُشَا ڒخْذنِّي كُوڒْ إِجّْ أَذْ غَارسْ يِيڒِي ؤُسمْغَارْ زِي أَربِّي. \x ◘ \xo 4:‏5 \xt دَان. 7‏:‏10؛ مت. 7‏:‏1؛ رُوم. 2‏:‏1؛ أَسَا. 20‏:‏12. \x*   
\m
\v 6 أَقَا مَانْ أَيَا، \add أَ\add* أَيْثْمَا، إِوْيغْ ث-إِ-د خَافِي ؤُ خْ أَپُولُّوسْ أَمْ يِيجّْ ن ؤُمذْيَا ذِي طّْوعْ نْومْ، حِيمَا أَذْ زَّايْنغْ ثْڒمْذمْ، مَاحنْذْ وَارْ ثتّْخَارِّيصمْ شَا بَارَّا إِ مِينْ إِدْجَانْ ذِي ثِيرَا، حِيمَا ؤُڒَا ذ إِجّْ أَذْ إِسّمْغَارْ إِخفْ نّسْ ضِيدّْ إِ ونِّي ذ أَسْ يُوذْسنْ ذِي سِّيبّثْ ن يِيجّنْ نّغْنِي. \x ◘ \xo 4:‏6 \xt أَوڒن. 3‏:‏7؛ رُوم. 12‏:‏3. \x*  
\v 7 مَانْ ونْ يَارزُّونْ ذَايكْ؟ نِيغْ مِينْ غَاركْ نِّي وَارْ ثطِّيفذْ؟ ؤُشَا مَاڒَا ثطّْفذْ ث، مَايمِّي ثْشنّْعذْ أَخْمِي وَارْ ث ثطِّيفذْ شَا؟ \x ◘ \xo 4:‏7 \xt يُوح. 3‏:‏27؛ يَاع. 1‏:‏17. \x*  
\v 8 ڒخُّو أَقَا ثجِّيوْنمْ ؤُ ثْذوْڒمْ ثتّجَّارمْ، ؤُشَا بْڒَا نشِّينْ أَقَا ثْحكّْممْ \add أَمْ إِجدْجِيذنْ\add*. معْلِيكْ كنِّيوْ ثْحكّْممْ \add أَمْ إِجدْجِيذنْ\add*، أَذْ يِيڒِي نشِّينْ خنِّي أَذْ نحْكمْ عَاوذْ أَكِيذْومْ!  
\v 9 مِينْزِي إِتّْغِيڒْ أَيِي بلِّي أَربِّي إِڭَّا أَنغْ غَارْ ؤُنڭَّارْ، نشِّينْ إِنِّي إِدْجَانْ ذ رُّوسُولْ، أَخْمِي \add خَانغْ حكْمنْ س\add* ڒْموْثْ، مِينْزِي أَقَا نذْوڒْ ذ أَفُورّجْ إِ دُّونشْثْ، إِ لْمَالَاكَاثْ ؤُ إِ إِوْذَانْ. \x ◘ \xo 4:‏9 \xt إِزهد. 44‏:‏23؛ رُوم. 8‏:‏36؛ 2 كُور. 4‏:‏11؛ عبر. 10‏:‏33. \x*  
\v 10 نشِّينْ ندْجْ ذ إِبُوهَاڒِييّنْ خْ سِّيبّثْ ن لْمَاسِيحْ، مَاشَا كنِّيوْ ثدْجَامْ ذ إِمِيغِيسنْ ذِي لْمَاسِيحْ. نشِّينْ نْهيّفْ، كنِّيوْ ثْجهْذمْ، كنِّيوْ ثتّْوَاشنّْعمْ، نشِّينْ نتّْوَاسّحْقَارَا. \x ◘ \xo 4:‏10 \xt 1 كُور. 2‏:‏3. \x*  
\v 11 أَڒْ ڒخُّو نشِّينْ ذَايْنيْ ڒَاژْ ذ ؤُفَاذِي ذ ثُوعَارْينْثْ، شَّاثنْ أَنغْ، وَارْ غَارْنغْ بُو ثْزذِّيغْثْ، \x ◘ \xo 4:‏11 \xt ڒخ. 23‏:‏2. \x*  
\v 12 نَاربّرْ أَمْ نْخدّمْ س إِفَاسّنْ نّغْ. نِيثْنِي سّحْقَارَانْ أَنغْ، أَقَا أَنغْ أَذْ نْبَاركْ، ذَارّْشنْ خَانغْ، مَاشَا أَقَا نْكسِّي أَرْمحْ، \x ◘ \xo 4:‏12 \xt مت. 5‏:‏44؛ لك. 6‏:‏28؛ 23‏:‏34؛ ڒخ. 7‏:‏60؛ 18‏:‏3؛ 20‏:‏34؛ رُوم. 12‏:‏14؛ 1 تس. 2‏:‏9؛ 2 تس. 3‏:‏8. \x*  
\v 13 شقّْفنْ ذَايْنغْ، أَقَا نتّْحشّمْ إِ-ثنْ \add ذِي ڒْخِيرْ\add*. أَڒْ ڒخُّو نذْوڒْ أَمْ ثْزُوبَاتْشْ ن دُّونشْثْ، أَمْ إِفُورَاضْ ن مَارَّا، أَڒْ إِ ڒخُّو.   
\m
\v 14 وَارْ تَّارِيغْ أَيَا حِيمَا أَذْ كنِّيوْ سّحْشِيمغْ، مَاشَا تّْزِييَّارغْ كنِّيوْ أَمْ ثَارْوَا إِعِيزّنْ. \x ◘ \xo 4:‏14 \xt 1 تس. 2‏:‏11. \x*  
\v 15 وَاخَّا مَاڒَا ثُوغَا ذِينْ غَارْومْعشْرَا-أَڒَافْ ن يِينِّي إِ كنِّيوْ يَاربَّانْ ذِي لْمَاسِيحْ، أَقَا وَارْ غَارْومْ أَطَّاسْ ن إِبَابَاثنْ، مِينْزِي نشّْ جِّيغْ-د كنِّيوْ ذِي يَاسُوع لْمَاسِيحْ س لْ-إِنْجِيلْ. \x ◘ \xo 4:‏15 \xt ڒخ. 18‏:‏11؛ ڭال. 4‏:‏19؛ فلمن. 10؛ يَاع. 1‏:‏18. \x*  
\v 16 س ؤُينِّي تَّارّغْ زَّايْومْ: أَروْسمْ أَيِي! \x ◘ \xo 4:‏16 \xt 1 كُور. 11‏:‏1؛ فِيل. 3‏:‏17؛ 1 تس. 1‏:‏6؛ 2 تس. 3‏:‏9. \x*  
\v 17 س ؤُينِّي سّكّغْ أَومْ-د ثِيمُوثِييُو، ونِّي إِدْجَانْ ذ مِّي إِعِيزّنْ ذ أَمْثِيقِّي ذِي سِيذِي، حِيمَا أَذْ ذ أَومْ إِسّْفكَّارْ إِبْرِيذنْ إِنُو إِ إِدْجَانْ ذِي لْمَاسِيحْ، أَمْ مَامّشْ ثنْ سّڒْمَاذغْ ذِي مَارَّا ثِيمسْمُونِينْ.   
\m
\v 18 مَاشَا شَا زَّايْومْ أَقَا تّْنفَّاخنْ، أَخْمِي نشّْ وَارْ غَارْومْ تِّيوِيضِيغْ.  
\v 19 مَاشَا مَاڒَا إِخْسْ سِيذِي أَذْ غَارْومْ د-أَسغْ ذغْيَا. خنِّي وَارْ تّخْسغْ \add زعْمَا\add* أَذْ سّْنغْ أَوَاڒنْ ن يِينِّي إِسّْڭعّْذنْ إِخفْ نْسنْ، مَاشَا جّهْذْ نْسنْ. \x ◘ \xo 4:‏19 \xt ڒخ. 18‏:‏21؛ عبر. 6‏:‏3؛ يَاع. 4‏:‏15. \x*  
\v 20 مِينْزِي ثَاڭلْذِيثْ ن أَربِّي وَارْ ثدْجِي شَا ذڭْ وَاوَاڒْ\add أنْ\add*، مَاشَا ذِي جّهْذْ. \x ◘ \xo 4:‏20 \xt 1 كُور. 2‏:‏4؛ 1 تس. 1‏:‏5؛ 2 بُط. 1‏:‏16. \x*  
\v 21 مِينْ ثخْسمْ؟ مَا أَذْ غَارْومْ د-أَسغْ س وعْمُوذْ نِيغْ س ثَايْرِي ؤُ س أَرُّوحْ ن ثمْهِينْثْ؟   
\b  
\b  
\m  
\c 5
\s1 أَسْحيّذْ ن إِجّْ ن ؤُمذْنُوبْ زِي ثْمسْمُونْثْ  
\m
\v 1 ڒْحَاسُوڒْ، إِتّْوَانَّا بلِّي أَقَا ذِينْ جَارْ أَومْ فَارْقْ-شّْغڒْ، ؤُ أَنشْثْ ن فَارْقْ-شّْغڒْ نِّي وَارْ إِدْجِينْ قَاعْ جَارْ لْكُوفَّارْ، أَقَا إِجّْ ن مِّيسْ غَارسْ ثَامْغَارْثْ ن بَابَاسْ. \x ◘ \xo 5:‏1 \xt لَاوِي 18‏:‏8؛ أَعَوذ. 27‏:‏20. \x*  
\v 2 كنِّيوْ ثسُّوفَّامْ إِخفْ نْومْ، وَاخَّا إِتّْخصَّا أَومْ ذِي ثِيذتّْ أَذْ ثْشضْنمْ، حِيمَا أَذْ ثْحيّْضمْ ونِّي إِڭِّينْ مَانْ أَيَا زِي ڒْوسْطْ نْومْ.  
\v 3 وَاخَّا نشّْ أَڭّْوجغْ عْلَاحْسَابْ أَرِّيمثْ، أَقَا أَيِي حْضَارغْ ذِي أَرُّوحْ، ؤُشَا أَقَا حكْمغْ أَخْمِي حْضَارغْ خْ ونِّي إِڭِّينْ مَانْ أَيَا.  
\v 4 إِتّْخصَّا أَذْ ثْمُونمْ مَارَّا ذڭْ يِيسمْ ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ، ؤُ نشّْ أَكِيذْومْ ذِي أَرُّوحْ، س جّهْذْ ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ،  
\v 5 ؤُشَا كنِّيوْ أَذْ ث ثْسلّْممْ إِ شِّيطَانْ إِ ثْخسَّارْثْ ن أَرِّيمثْ نّسْ، حِيمَا أَذْ إِدَّارْ ذِي أَرُّوحْ ذڭْ وَاسّْ ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ. \x ◘ \xo 5:‏5 \xt 1 تِيم. 1‏:‏20. \x*   
\m
\v 6 وَارْ د خَاومْ يُوسِي ؤُفيّشْ! مَا وَارْ ثسِّينمْ شَا بلِّي شْوَايْثْ ن ونْثُونْ إِسّْممّْ مَارَّا ثَاعبُّوزْثْ ن وَارشْثِي؟ \x ◘ \xo 5:‏6 \xt ڭال. 5‏:‏9. \x*  
\v 7 سِيزذْڭمْ إِخفْ نْومْ خنِّي زڭْ ونْثُونْ أَقْذِيمْ، حِيمَا أَذْ ثِيڒِيمْ ذ إِشْثْ ن ڒْعجْنثْ ن وَارشْثِي ن جْذِيذْ. أَقَا كنِّيوْ ذ أَغْرُومْ بْڒَا أَنْثُونْ، مِينْزِي \add ثَاغَارْصْثْ نّغْ ن\add* ؤُسعْذُو أَقَا ثتّْوَاغَارْصْ إِ نشِّينْ، أَقَا \add نتَّا\add* ذ لْمَاسِيحْ. \x ◘ \xo 5:‏7 \xt إِشا. 53‏:‏7؛ يُوح. 1‏:‏29؛ 1 كُور. 15‏:‏3. \x*  
\v 8 س ؤُينِّي أجّْ أَنغْ أَذْ نْعيّذْ، وَارْ إِدْجِي س ونْثُونْ أَقْذِيمْ نِيغْ س ونْثُونْ ن ثُوعفّْنَا ذ ڒْغَارْ، مَاشَا س ونْثُونْ ن ڒصْفَايثْ ذ ثْقدَّاسْثْ. \x ◘ \xo 5:‏8 \xt ؤُف. 12‏:‏3، 15؛ أَعَوذ. 16‏:‏3. \x*   
\m
\v 9 أَقَا ؤُرِيغْ أَومْ-د ذِي ثبْرَاثْ، إِتّْخصَّا وَارْ تّْعَاشَارمْ أَيْثْ ن فَارْقْ-شّْغڒْ \x ◘ \xo 5:‏9 \xt أَعَوذ. 7‏:‏2؛ مت. 18‏:‏17؛ 2 كُور. 6‏:‏14؛ أَفا. 5‏:‏11؛ 2 تس. 3‏:‏14. \x*  
\v 10 وَارْ سِّيوْڒغْ خْ أَيْثْ ن فَارْقْ-شّْغڒْ نِّي إِدْجَانْ ذِي دُّونشْثْ-أَ، نِيغْ خْ إِضمَّاعنْ نِيغْ خْ إِبعَّاجْ نِيغْ خْ يِينِّي إِعبّْذنْ لْ-أَصْنَامْ، مَاڒَا أَمُّو، إِڒِي أَذْ ثفّْغمْ زِي دُّونشْثْ-أَ.  
\v 11 مَاشَا ؤُرِيغْ أَومْ-د ڒخُّو، حِيمَا وَارْ ثتّْعَاشَارمْ شَا حذْ، وَاخَّا قَّارنْ أَسْ ؤُمَا، مَاشَا أَقَا-ث ذ بُو-فَارْقْ-شّْغڒْ، نِيغْ ذ أَضمَّاعْ، نِيغْ ذ ونِّي إِعبّْذنْ لْ-أَصْنَامْ، نِيغْ ذ أَمْشقَّافْ، نِيغْ ذ أَسْكَارْجِي، نِيغْ ذ أَشفَّارْ. أَكْ-ذ حذْ أَمْ وَانِيثَا وَارْ كِيسْ ثتّتّمْ \add عَاذْ\add* أَغْرُومْ! \x ◘ \xo 5:‏11 \xt ڒخْڒ. 12‏:‏14؛ مت. 18‏:‏17؛ 2 تس. 3‏:‏14؛ 2 يُوح. 10. \x*  
\v 12 مِينْزِي مَانْ ڒْحقّْ غَارِي، حِيمَا أَذْ حكْمغْ خْ يِينِّي إِدْجَانْ بَارَّا؟ حكّْممْ كنِّيوْ خْ يِينِّي إِدْجَانْ ذَاخڒْ!  
\v 13 مَاشَا إِنِّي إِدْجَانْ بَارَّا، أَربِّي أَذْ خَاسنْ إِحْكمْ. سْحيّْذمْ خَاومْ أَعفَّانْ! \x ◘ \xo 5:‏13 \xt أَعَوذ. 17‏:‏7\x*   
\b  
\b  
\m  
\c 6
\s1 إِمْشُوبَّاشْ جَارْ وَاوْمَاثنْ  
\m
\v 1 مَا إِزْعمْ حذْ زَّايْومْ، خْمِي غَارسْ شّْرعْ أَكْ-ذ ونّغْنِي، أَذْ \add زَّايسْ\add* إِحْكمْ زَّاثْ ن يِينِّي وَارْ إِسڭّْذنْ، وَارْ إِدْجِي زَّاثْ إِ إِمْقدَّاسنْ؟  
\v 2 نِيغْ وَارْ ثسِّينمْ شَا بلِّي إِمْقدَّاسنْ أَذْ حكْمنْ دُّونشْثْ؟ ؤُشَا مَاڒَا \add خنِّي\add* دُّونشْثْ أَذْ ثتّْوَاحْكمْ زَّايْومْ، مَا وَارْ ثْزمَّارمْ \add خنِّي\add* أَذْ ثْعذْڒمْ دّْعَاوِي ثِيمژْيَانِينْ \add جَارْ أَومْ\add*؟ \x ◘ \xo 6:‏2 \xt مت. 19‏:‏28؛ لك. 22‏:‏30. \x*  
\v 3 نِيغْ وَارْ ثسِّينمْ شَا بلِّي أَذْ نحْكمْ خْ لْمَالَاكَاثْ؟ مشْحَاڒْ عَاذْ كْثَارْ \add إِ غَا نحْكمْ خْ\add* يِينِّي إِدْجَانْ ن دُّونشْثْ-أَ؟  
\v 4 مَاشَا مَاڒَا ذِينْ جَارْ أَومْ إِشْثْ ن دّعْوثْ خْ ثْمسْڒَايِينْ ن ثُوذَارْثْ-أَ، مَا ثتّڭّمْ إِنِّي غَارْ إِدْجَا ذْرُوسْ ن ؤُوقَّارْ وَاهَا ذِي ثْمسْمُونْثْ حِيمَا أَذْ حكْمنْ؟  
\v 5 قَّارغْ أَومْ ث حِيمَا أَذْ ثْسضْحَامْ. مَا خنِّي وَارْ ذِينِّي حذْ جَارْ أَومْ ذ أَمِيغِيسْ ونِّي إِزمَّارنْ أَذْ إِحْكمْ جَارْ ثَاوْمَاثْ ذ ؤُمَاسْ؟  
\v 6 مَاشَا \add ڒخُّو\add*، إِجّْ ن ثَاوْمَاثْ أَذْ إِشَارّعْ أَكْ-ذ ؤُمَاسْ ؤُ مَانْ أَيَا قِيبَاتْشْ إِ يِينِّي وَارْ يُومِيننْ شَا.  
\v 7 س ؤُيَا ثْحكّْممْ خْ يِيخفْ نْومْ، مِينْزِي ثمْشَارَّاعمْ جَارْ أَومْ. مَايمِّي وَارْ ثْقبّْڒمْ أَذْ كنِّيوْ ضدْجنْ؟ مَايمِّي وَارْ ثْقبّْڒمْ شَا أَذْ كنِّيوْغشّنْ؟ \x ◘ \xo 6:‏7 \xt أَوڒن. 20‏:‏22؛ مت. 5‏:‏39؛ رُوم. 12‏:‏17؛ 1 تس. 5‏:‏15؛ 1 بُط. 3‏:‏9. \x*  
\v 8 مَاشَا \add ڒخُّو\add* ثتّڭّمْ مِينْ وَارْ إِسڭّْذنْ ؤُشَا ثتّْغشَّامْ عَاذْ إِ أَيْثْمَاثْومْ.   
\m
\v 9 مَا وَارْ ثسِّينمْ شَا بلِّي إِنِّي وَارْ إِسڭّْذنْ وَارْ وَارّْثنْ شَا ثَاڭلْذِيثْ ن أَربِّي؟ وَارْ تّْرَاحمْ شَا ذِي غَالَاطْ! أَيْثْ ن فَارْقْ-شّْغڒْ، نِيغْ إِنِّي إِعبّْذنْ لْ-أَصْنَامْ، نِيغْ إِنِّي إِتّڭّنْ زِّينَا، نِيغْ إِنِّي إِسّخْسَارَانْ، نِيغْ زّْوَامڒْ، \x ◘ \xo 6:‏9 \xt ڭال. 5‏:‏19؛ أَفا. 5‏:‏5؛ أَسَا. 22‏:‏15. \x*  
\v 10 نِيغْ إِضمَّاعنْ، نِيغْ إِشفَّارنْ، نِيغْ إِسْكَارْجِييّنْ، نِيغْ إِمْشقَّافنْ ؤُڒَا ذ إِبعَّاجنْ وَارْ وَارّْثنْ ثَاڭلْذِيثْ ن أَربِّي.  
\v 11 ثُوغَا ثِيمسْڒَايِينْ-أَ ڒسْقنْثْ غَارْ شَا زَّايْومْ، مَاشَا أَقَا كنِّيوْ ثتّْوَاسِّيرْذمْ، أَقَا ثتّْوَاقدّْسمْ، أَقَا ثتّْوَاسڭّْذمْ س يِيسمْ ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ ؤُ س أَرُّوحْ ن أَربِّي نّغْ. \x ◘ \xo 6:‏11 \xt أَفا. 2‏:‏2؛ كُول. 3‏:‏7؛ ثِيث. 3‏:‏3؛ عبر. 10‏:‏22. \x*   
\b  
\m  
\s1 أَرِّيمثْ ذ زَّاوشْثْ ن أَرُّوحْ إِقدّْسنْ  
\m
\v 12 مَارَّا ثِيمسْڒَايِينْ حدْجْڒنْثْ أَيِي، مَاشَا مَارَّا وَارْ نفّْعنْثْ. مَارَّا ثِيمسْڒَايِينْ حدْجْڒنْثْ أَيِي، مَاشَا وَارْ ذ أَيِي إِتّْضبَّارْ ؤُڒَا ذ إِجّنْ بْنَاذمْ. \x ◘ \xo 6:‏12 \xt 1 كُور. 10‏:‏23. \x*  
\v 13 مَاشَّا إِ ؤُعذِّيسْ ؤُشَا أَعذِّيسْ إِ مَاشَّا، مَاشَا أَربِّي أَذْ ثنْ إِبطّڒْ س ثْيُويَا. مَاشَا أَرِّيمثْ وَارْ ثدْجِي إِ فَارْقْ-شّْغڒْ، مَاشَا إِ سِيذِيثْنغْ، ؤُشَا سِيذِيثْنغْ إِ أَرِّيمثْ.  
\v 14 مَاشَا أَربِّي ونِّي د-إِسّْنكَّارنْ سِيذِيثْنغْ، أَذْ أَنغْ د-إِسّْنكَّارْ س جّهْذْ نّسْ. \x ◘ \xo 6:‏14 \xt رُوم. 8‏:‏11؛ 2 كُور. 4‏:‏14. \x*  
\v 15 مَا وَارْ ثسِّينمْ شَا بلِّي أَرِّيمَاثْ نْومْ دْجَانْثْ ذ إِغزْذِيسنْ ن لْمَاسِيحْ؟ مَا أَذْ كْسِيغْ خنِّي إِجّْ ن ؤُغزْذِيسْ ن لْمَاسِيحْ، مَاحنْذْ أَذْ ث ڭّغْ ذ أَغزْذِيسْ ن إِشْثْ ن ثمْغَارْثْ ن فَارْقْ-شّْغڒْ؟عمَّارْصْ!  
\v 16 نِيغْ وَارْ ثسِّينمْ شَا بلِّي وِي إِمُوننْ أَكْ-ذ ثمْغَارْثْ ن فَارْقْ-شّْغڒْ، أَقَا-ث ذ إِشْثْ ن أَرِّيمثْ \add أَكِيذسْ\add*؟ مِينْزِي إِقَّارْ: ’نِيثْنِي س ثْنَاينْ أَذْ إِڒِينْ ذ إِشْثْ ن أَرِّيمثْ.‘ \x ◘ \xo 6:‏16 \xt أَمز. 2‏:‏24؛ مت. 19‏:‏5، 6؛ مك. 10‏:‏8؛ أَفا. 5‏:‏31 \x*  
\v 17 مَاشَا ونِّي إِمُوننْ أَكْ-ذ سِيذِيثْنغْ، أَقَا-ث ذ إِجّْ ن أَرُّوحْ أَكِيذسْ.   
\m
\v 18 أَروْڒمْ زِي فَارْقْ-شّْغڒْ. كُوڒْ شَا ن دّنْبْ إِ إِتّڭّْ بْنَاذمْ، أَقَا-ث بَارَّا إِ أَرِّيمثْ نّسْ، مَاشَا ونِّي إِسّفْسَاذنْ إِخفْ نّسْ س فَارْقْ-شّْغڒْ، أَقَا نتَّا إِخطَّا ضِيدّْ إِ أَرِّيمثْ نّسْ.  
\v 19 مَا وَارْ ثسِّينمْ شَا بلِّي أَرِّيمثْ نْومْ ذ زَّاوشْثْ ن أَرُّوحْ إِقدّْسنْ ونِّي ذَايْومْ إِدْجَانْ، ونِّي إِ طّْفمْ زِي أَربِّي، ؤُ أَقَا كنِّيوْ وَارْ ثدْجِيمْ شَا إِ يِيخفْ نْومْ؟ \x ◘ \xo 6:‏19 \xt 1 كُور. 3‏:‏16؛ 2 كُور. 6‏:‏16؛ أَفا. 2‏:‏21؛ عبر. 3‏:‏6؛ 1 بُط. 2‏:‏5. \x*  
\v 20 أَقَا ثمّسْغمْ-د س تَّامَانْ. سمْغَارمْ خنِّي أَربِّي ذِي أَرِّيمثْ نْومْ ؤُ ذِي أَرُّوحْ نْومْ ثِينِّي إِدْجَانْ ن أَربِّي. \x ◘ \xo 6:‏20 \xt 1 كُور. 7‏:‏23؛ ڭال. 3‏:‏13؛ عبر. 9‏:‏12؛ 1 بُط. 1‏:‏18. \x*   
\b  
\b  
\m  
\c 7
\s1 خْ ڒمْڒَاشْ  
\m
\v 1 زِي جِّيهثْ مِينْ ذ أَيِي ثُورِيمْ، أَقَا مْلِيحْ إِ بْنَاذمْ وَارْ إِتّْحِيذِي شَا ثَامْغَارْثْ.  
\v 2 مَاشَا زِي سِّيبّثْ ن فَارْقْ-شّْغڒْ، كُوڒْ أَرْيَازْ أَذْ يَاوِي ثَامْغَارْثْ نّسْ ؤُشَا كُوڒْ إِشْثْ ن ثمْغَارْثْ أَذْ ثطّفْ أَرْيَازْ نّسْ.  
\v 3 أجّْ أَرْيَازْ أَذْ إِسّْشنْ إِ ثمْغَارْثْ نّسْ ثَايْرِي إِ ذ أَسْ د-يُوسِينْ، أَمُّو عَاوذْ ثَامْغَارْثْ إِ ورْيَازْ نّسْ. \x ◘ \xo 7:‏3 \xt 1 بُط. 3‏:‏7. \x*  
\v 4 ثَامْغَارْثْ وَارْ ثتّْضبَّارِي شَا ذِي أَرِّيمثْ نّسْ، مَاشَا أَرْيَازْ نّسْ. ؤُشَا أَمُّو عَاوذْ أَرْيَازْ وَارْ إِتّْضبَّارِي شَا ذِي أَرِّيمثْ نّسْ، مَاشَا ثَامْغَارْثْ نّسْ.  
\v 5 وَارْ \add ت\add* قطّْعمْ شَا خْ وَايَاوْيَا، مْغِيرْ مَاڒَا ثكّْسمْ ذڭْ وَاوَاڒْ شَا ن ؤُمُورْ حِيمَا أَذْ شغْڒمْ س ؤُژُومِّي ذ ثْژَادْجِيثْ. أَوَارْنِي مَانْ أَيَا مُونمْ عَاوذْ مَاحنْذْ أَذْ ثَاوْيمْ أَرِيقِّي إِ ڒمْرَاشْ، حِيمَا وَارْ كنِّيوْ إِتّْجَارِّيبْ شِّيطَانْ زِي سِّيبّثْ ن مژْرِي ن أَرِّيمثْ. \x ◘ \xo 7:‏5 \xt يُووِ. 2‏:‏16. \x*  
\v 6 قَّارغْ مَانْ أَيَا ذِي طّْوعْ ن يِينِّي إِضعْفنْ، وَارْ إِدْجِي س ڒُومُورْ.  
\v 7 خْسغْ عَاذْ مْلِيحْ مَاڒَا مَارَّا إِوْذَانْ أَذْ إِڒِينْ أَمْ نشّْ ذِي ثَازْذُوڭِي، مَاشَا كُوڒْ إِجّْ غَارسْ ثَاوْهِيبْثْ نّسْ إِ ذ أَسْ إِوْشَا أَربِّي، إِجّنْ أَمُّو، ونّغْنِي أَمُّو. \x ◘ \xo 7:‏7 \xt مت. 19‏:‏12؛ ڒخ. 26‏:‏29؛ 1 كُور. 12‏:‏11. \x*   
\m
\v 8 مَاشَا إِ يِينِّي وَارْ غَارْسنْ بُو ثمْغَارْثْ ؤُ إِ ثِيجَّاڒْ قَّارغْ، أَقَا مْلِيحْ إِ نِيثْنِي مَاڒَا قِّيممْ أَمْ نشّْ.  
\v 9 مَاشَا مَاڒَا وَارْ زمَّارنْ أَذْ قِّيمنْ طّْفنْ ذِي مَانْ أَيَا، أجّْ إِ-ثنْ أَذْ مڒْشنْ، مِينْزِي إِحْڒَا أَذْ أَوْينْ ثَامْغَارْثْ خْ وشْمَاضْ ن نّشْوثْ. \x ◘ \xo 7:‏9 \xt 1 تِيم. 5‏:‏14. \x*   
\m
\v 10 مَاشَا إِ يِينِّي يِيوْينْ إِشْثْ ن ثمْغَارْثْ، ؤُمُورغْ، وَارْ إِدْجِي ذ نشّْ، مَاشَا سِيذِي إِنُو، بلِّي ثَامْغَارْثْ وَارْ ثْبطِّي خْ ورْيَازْ. \x ◘ \xo 7:‏10 \xt مـَال. 2‏:‏14؛ مت. 5‏:‏32؛ 19‏:‏9؛ مك. 10‏:‏11؛ لك. 16‏:‏18. \x*  
\v 11 ؤُشَا مَاڒَا ثبْضَا، أَذْ ثقِّيمْ بْڒَا أَرْيَازْ، نِيغْ أَذْ ثمّسّصْڒحْ أَكْ-ذ ورْيَازْ نّسْ، ؤُشَا أَرْيَازْ وَارْ إِتّجِّي ثَامْغَارْثْ نّسْ.   
\m
\v 12 خنِّي إِ إِنّغْنِي قَّارغْ نشّْ، وَارْ إِدْجِي سِيذِي: مَاڒَا إِجّْ ن ثَاوْمَاثْ غَارسْ ثَامْغَارْثْ وَارْ إِتِّيمْننْ، ؤُشَا نتَّاثْ ثقْبڒْ أَذْ ثزْذغْ أَكِيذسْ، وَارْ ت إِنطَّارْ شَا.  
\v 13 ؤُشَا مَاڒَا إِشْثْ ن ثمْغَارْثْ ثنِّي غَارْ إِدْجَا ورْيَازْ وَارْ يُومِيننْ، ؤُ نتَّا إِخْسْ أَذْ كِيذسْ إِزْذغْ، وَارْ ثْسمّحْ شَا نتَّاثْ ذڭْ ورْيَازْ نّسْ.  
\v 14 س مِينْزِي أَرْيَازْ وَارْ يُومِيننْ إِتّْوَاقدّسْ ذِي ثمْغَارْثْ ثنِّي يُومْننْ، ؤُڒَا ذ ثَامْغَارْثْ وَارْ يُومِيننْ ثتّْوَاقدّسْ ذڭْ ورْيَازْ إِ يُومْننْ، مَاڒَا مَامّشْ نّغْنِي أَذْ إِڒِينْ إِحنْجِيرنْ نْومْ ذ إِمنْڭَاسْ، مَاشَا ڒخُّو أَقَا نِيثْنِي ذ إِمزْذَاڭنْ.   
\m
\v 15 مَاشَا مَاڒَا ونِّي وَارْ إِتِّيمْننْ أَذْ إِدْجفْ، أجّْ إِ-ث أَذْ إِدْجفْ. خنِّي ثَاوْمَاثْ نِيغْ ثَاوتْشْمَاثْ وَارْ تّْوَاقّْننْ شَا ذِي ڒْحَاڒْ نِّي. أَقَا أَربِّي إِڒَاغَا أَنغْ-د غَارْ ڒهْنَا.  
\v 16 مِينْزِي مَانِيسْ ثسّْنذْ شمْ، \add أَ\add* ثَامْغَارْثْ، أَذْ ثسّْنجْمذْ أَرْيَازْ نّمْ؟ نِيغْ مَانِيسْ ثسّْنذْ شكْ، \add أَ\add* أَرْيَازْ، أَذْ ثسّْنجْمذْ ثَامْغَارْثْ نّشْ؟ \x ◘ \xo 7:‏16 \xt 1 بُط. 3‏:‏1. \x*   
\m
\v 17 مَاشَا كُوڒْ إِجّْ أَمْ مَامّشْ ذ أَسْ إِوْشَا سِيذِي، أَمْ مَامّشْ إِ ذ إِڒَاغَا أَربِّي إِ كُوڒْ إِجّْ، أجّْ إِ-ث أَذْ إِدَّارْ أَمُّو. أَمُّو إِ ؤُمُورغْ إِ مَارَّا ثِيمسْمُونِينْ.  
\v 18 مَاڒَا إِتّْوَاڒَاغَا إِ ورْيَازْ إِتّْوَاخثْننْ \add غَارْ ؤُمُونِي أَكْ-ذ لْمَاسِيحْ\add*، وَانِيثَا وَارْ يَارزُّو أَذْ د-إِذْوڒْ غَارْ بْڒَا أَخْثَانْ نّسْ، ؤُشَا مَاڒَا إِتّْوَاڒَاغَا إِ حذْ بْڒَا أَخْثَانْ، أجّْ إِ-ث وَارْ يَارزُّو أَذْ ث خثْننْ.  
\v 19 أَخْثَانْ ذ وَالُو ؤُ بْڒَا أَخْثَانْ ذ وَالُو، مَاشَا أَحطُّو ن ثْوصَّا ن أَربِّي، وَاهْ!  
\v 20 أجّْ كُوڒْ إِجّنْ أَذْ إِقِّيمْ ذِي ثْڒَاغِيثْ إِ زِي د-إِتّْوَاڒَاغَا. \x ◘ \xo 7:‏20 \xt أَفا. 4‏:‏1؛ فِيل. 1‏:‏27؛ كُول. 1‏:‏10؛ 1 تس. 2‏:‏12. \x*  
\v 21 مَاڒَا ثُوغَا شكْ ثتّْوَاڒَاغِيذْ-د ذ إِسْمغْ وَارْ ثسّْحِيسِّيفذْ شَا إِ مَانْ أَيَا، مَاشَا مَاڒَا ثْزمَّارذْ أَذْ ثتّْوَاسَّارْحذْ، إِخْضَارْ خنِّي س يِيخفْ نّشْ، مَاحنْذْ أَذْ ثْسخَّارذْ.  
\v 22 مِينْزِي ونِّي إِتّْوَاڒَاغَانْ ذِي سِيذِيثْنغْ أَمْ ثُوغَا ذ إِسْمغْ، أَقَا-ث ذ أَحُورِّي ن أَربِّي، أَمْ مَامّشْ ونِّي إِتّْوَاڒَاغَانْ ذ أَحُورِّي، أَقَا-ث ذ إِسْمغْ ن لْمَاسِيحْ.  
\v 23 أَقَا ثمّسْغمْ-د س تَّامَانْ، \add خنِّي\add* وَارْ إِعدّڒْ أَذْ ثِيڒِيمْ عَاذْ ذ إِسمْغَانْ ن إِوْذَانْ. \x ◘ \xo 7:‏23 \xt 1 كُور. 6‏:‏20؛ عبر. 9‏:‏12؛ 1 بُط. 1‏:‏18. \x*  
\v 24 \add أَ\add* أَيْثْمَا، أجّْ كُوڒْ إِجّنْ أَذْ إِسِيغِي أَكْ-ذ أَربِّي ذڭْ وبْرِيذْ نِّي ذِي د-إِتّْوَاڒَاغَا.   
\b  
\m
\v 25 ذڭْ وَازَّايْ ن ثُوعزْرِييَا، أَقَا وَارْ غَارِي بُو ڒُومُورْ ن أَربِّي، مَاشَا أَذْ وْشغْ أَرَّايْ إِنُو، أَمْ وِي يِيوْضنْ س أَرْضَا ن أَربِّي حِيمَا أَذْ يِيڒِي ذ أَمْثِيقِّي.  
\v 26 إِتّْغِيڒْ أَيِي مْلِيحْ إِ ڒغْبنْ إِ إِدْجَانْ ذِي ڒْوقْثْ-أَ، بلِّي أَقَا إِشْنَا إِ بْنَاذمْ أَذْ إِقِّيمْ أَمْ إِدْجَا.  
\v 27 مَا ثْڒصْقذْ ذِي ثمْغَارْثْ؟ وَارْ أَرزُّو شَا أَذْ \add زَّايسْ\add* ثنّْفكّذْ. مَاڒَا شكْ وَارْ ثْڒصْقذْ ذِي ثمْغَارْثْ؟ وَارْ أَرزُّو خْ ثمْغَارْثْ. \f ◼ \fr 7:‏27 \ft \+bd ’مَا شكْ وَارْ ثْڒصْقضْ ذِي ثمْغَارْثْ؟‘\+bd* - أَوَاڒْ-أَ إِخْسْ أَذْ يِينِي: ’مَا شكْ بْڒَا ثَامْغَارْثْ؟‘\f*  
\v 28 مَاشَا مَاڒَا ثِيوْيذْ ثَامْغَارْثْ، وَارْ ثْخطِّيذْ. ؤُشَا مَاڒَا ثَاعْزَارشْثْ ثذْوڒْ غَارْ ورْيَازْ، نتَّاثْ وَارْ ثْخطِّي شَا. مَاشَا إِنِّي \add إِقّْننْ إِ وَايَاوَايَا س ڒمْڒَاشْ\add*، ثتّْرَاجَا إِ-ثنْ ڒْمحْنثْ ذِي أَرِّيمثْ، ؤُشَا خْسغْ أَذْ ت خَاومْ كّْسغْ.   
\m
\v 29 ذ مَانْ أَيَا إِ قَّارغْ، \add أَ\add* أَيْثْمَا، أَقَا ڒْحَاڒْ إِمْژِي. س ؤُينِّي إِنِّي غَارْ إِدْجَا ثمْغَارْثْ، أجّْ إِ-ثنْ أَذْ إِڒِينْ أَخْمِي وَارْ غَارْسنْ ثدْجِي،  
\v 30 إِنِّي إِتّْرُونْ أَخْمِي وَارْ تّْرُونْ، إِنِّي إِفَارّْحنْ أَخْمِي وَارْ فْرِيحنْ، إِنِّي إِسَّاغنْ أَخْمِي وَارْ ملّْكنْ،  
\v 31 ؤُ إِنِّي إِسْثنْفَاعنْ زِي دُّونشْثْ-أَ، إِتّْخصَّا وَارْ تَّاڭّْوِيجنْ خْ ؤُسْثنْفعْ إِ د-إِتّْڒِيقنْ، مِينْزِي ؤُذمْ ن دُّونشْثْ أَيَا أَذْ إِعْذُو. \x ◘ \xo 7:‏31 \xt إِشا. 40‏:‏6؛ يَاع. 1‏:‏10؛ 4‏:‏14؛ 1 بُط. 1‏:‏24؛ 1 يُوح. 2‏:‏17. \x*   
\m
\v 32 س ؤُينِّي خْسغْ أَذْ ثِيڒِيمْ بْڒَا أَمْنُوسْ، مَاغَارْ ونِّي وَارْ غَارسْ ثدْجِي ثمْغَارْثْ، أَذْ إِخَارّصْ ذِي مِينْ إِدْجَانْ ن سِيذسْ ذ مَامّشْ غَا يَارْضَا سِيذسْ. \x ◘ \xo 7:‏32 \xt 1 تِيم. 5‏:‏5. \x*  
\v 33 مَاشَا ونِّي غَارْ ثدْجَا ثمْغَارْثْ، أَذْ إِكْسِي س ومْنُوسْ إِ ثْمسْڒَايِينْ ن دُّونشْثْ-أَ ؤُ مَامّشْ غَا يَارْضَا ثَامْغَارْثْ نّسْ.   
\m
\v 34 أَقَا ذِينْ إِجّْ ن ڒْفَارْقْ جَارْ ثمْغَارْثْ ذ ثعْزَارشْثْ. ثنِّي وَارْ غَارْ إِدْجِي ورْيَازْعمَّارْصْ، أَذْ ثْخَارّصْ ذِي سِيذسْ، حِيمَا أَذْ ثِيڒِي ثْقدّسْ أَمْ ذِي أَرِّيمثْ أَمْ ذِي أَرُّوحْ، مَاشَا ثنِّي غَارْ ثدْجَا ورْيَازْ، أَذْ ثْخَارّصْ ذِي ثْمسْڒَايِينْ ن دُّونشْثْ، إِ مَامّشْ غَا ثَارْضَا أَرْيَازْ نّسْ.  
\v 35 ذڭَّا قَّارغْ أَومْ-د إِ ثِيزِي نْومْ، وَارْ إِدْجِي حِيمَا أَذْ أَومْ ڭّغْ ڒْفخْ، مَاشَا \add نِّيغْ ث\add* حِيمَا أَذْ ثقِّيمنْ ذ إِمْثِيقَّانْ إِ سِيذِيثْومْ خْ ؤُبْرِيذْ نِيشَانْ، أَمْ وَارْ ثْسڒْهِيمْ أَكْ-ذ دُّونشْثْ.   
\m
\v 36 مَاشَا مَاڒَا إِخَارّصْ حذْ بلِّي أَقَا سْثْهزَّانْ زَّايسْ زِي سِّيبّثْ ن يدْجِيسْ ثَاعْزَارشْثْ، ثنِّي خْ عْذُونْ وُوسَّانْ ن ثمْژِي نّسْ أَمْ وَارْ ت إِسّمْڒشْ عَاذْ إِ ورْيَازْ، ؤُشَا إِتّْغِيڒْ أَسْ نِيشَانْ أَذْ ت إِسّمْڒشْ، نتَّا وَارْ إِخطِّي شَا. أجّْ إِ-ت أَذْ ثْمڒْشْ.  
\v 37 مَاشَا وِي إِدْجَانْ نِيشَانْ ذڭْ وُوڒْ نّسْ، بْڒَا مَا يُوشَا س ؤُزِييَّارْ، ؤُشَا غَارسْ صُّولْطَا خْ يِيخفْ نّسْ، إِكّسْ ذڭْ وُوڒْ نّسْ أَذْ يجّْ ثَاعْزَارشْثْ نّسْ ثصْفَا، مْلِيحْ إِ يڭَّا.  
\v 38 س ؤُينِّي، ونِّي إِسّْمڒْشنْ يدْجِيسْ ثَاعْزَارشْثْ إِڭَّا مْلِيحْ، ؤُ ونِّي وَارْ إِسّْمدْجِيشنْ يدْجِيسْ ثَاعْزَارشْثْ، إِڭَّا مْلِيحْ أَطَّاسْ.   
\m
\v 39 ثَامْغَارْثْ ثقّنْ غَارْ ورْيَازْ نّسْ س شَّارِيعَا مِينْ غَا يكّْ ورْيَازْ نّسْ إِدَّارْ، مَاشَا مَاڒَا أَرْيَازْ نّسْ إِمُّوثْ، أَقَا-ت ثْسَارّحْ زَّايسْ، ثْزمَّارْ أَذْ ثمْڒشْ أَكْ-ذ وِي ثخْسْ، مَاشَا ذِي سِيذِيثْنغْ وَاهَا. \x ◘ \xo 7:‏39 \xt رُوم. 7‏:‏2. \x*  
\v 40 مَاشَا نشّْ غَارِي، أَقَا نتَّاثْ أَذْ ثتّْوَابَاركْ كْثَارْ مَاڒَا ثقِّيمْ أَمنِّي. ؤُ أَقَا نشّْ تّْوَاڒِيغْ أَرُّوحْ ن أَربِّي \add إِخدّمْ\add* عَاوذْ ذَايِي. \x ◘ \xo 7:‏40 \xt 1 تس. 4‏:‏8. \x*   
\b  
\b  
\m  
\c 8
\s1 خْ مَاشَّا ن ويْسُومْ ن ثْغَارْصِينْ إِ لْ-أَصْنَامْ  
\m
\v 1 زِي جِّيهثْ ن ثْغَارْصِينْ إِ لْ-أَصْنَامْ، أَقَا نسّنْ، بلِّي مَارَّا غَارْنغْ ثُوسّْنَا. ثُوسّْنَا \add مَاشَا\add* ثتّڭّْ ثُوفّثْ، مَاشَا ثَايْرِي ثسّْيمَّا.  
\v 2 مَاڒَا ذِينْ حذْ إِتّْغِيڒْ أَسْ بلِّي إِسّنْ شَا، عَاذْ وَارْ إِسِّينْ وَالُو أَنشْثْ مَامّشْ إِتّْخصَّا أَذْ إِسّنْ.  
\v 3 مَاشَا مَاڒَا إِتّخْسْ حذْ أَربِّي، أَقَا ذ وَا إِتّْوَاسّنْ زَّايسْ.   
\m
\v 4 خْ مَاشَّا ثنِّي إِتّْوَاغَارْصنْ إِ لْ-أَصْنَامْ، أَقَا نسّنْ بلِّي صَّانَامْ وَارْ إِدْجِي ذ وَالُو ذِي دُّونشْثْ، ؤُ بلِّي وَارْ ذِينْ إِدْجِي شَا أَربِّي نّغْنِي مْغِيرْ إِجّنْ. \x ◘ \xo 8:‏4 \xt أَعَوذ. 4‏:‏39؛ رُوم. 14‏:‏14؛ 1 كُور. 10‏:‏19؛ أَفا. 4‏:‏6. \x*  
\v 5 خنِّي، وَاخَّا أَقَا ذِينْ إِنِّي ؤُمِي قَّارنْ إِربِّيثنْ، نِيغْ ذڭْ ؤُجنَّا نِيغْ ذِي ثمُّورْثْ - أَمْ مَامّشْ دْجَانْ ذِينْ أَطَّاسْ ن إِربِّيثنْ ذ وَاطَّاسْ ن إِسِيذِيثنْ -  
\v 6 إِ نشِّينْ أَقَا غَارْنغْ إِجّْ ن أَربِّي، بَابَاثْنغْ، مَاغَارْ زَّايسْ إِ د-ؤُسِينْثْ مَارَّا ثِيمسْڒَايِينْ ؤُ ذَايسْ إِ ندْجْ، ؤُ أَقَا غَارْنغْ إِجّْ ن سِيذِي، أَقَا-ث ذ يَاسُوع لْمَاسِيحْ، مَاغَارْ مَارَّا ثِيمسْڒَايِينْ دْجَانْثْ س ؤُفُوسْ نّسْ، ؤُشَا ؤُڒَا ذ نشِّينْ أَقَا س إِفَاسّنْ نّسْ إِ ندْجْ. \x ◘ \xo 8:‏6 \xt مـَال. 2‏:‏10؛ يُوح. 13‏:‏13؛ 1 كُور. 12‏:‏3؛ أَفا. 4‏:‏6؛ فِيل. 2‏:‏11. \x*   
\m
\v 7 مَاشَا ثُوسّْنَا-يَا وَارْ ذَايْسنْ ثدْجِي مَارَّا، مِينْزِي ذِينْ شَا ن يِينِّي ذِي ثْنفْسشْثْ نْسنْ تّتّنْ مِينْ إِتّْوَاغَارْصنْ إِ لْ-أَصْنَامْ، ؤُشَا \add خنِّي\add* ثتّْوَاسّخْمجْ \add ثْنفْسشْثْ نْسنْ\add* س مَانَاينِّي، مِينْزِي ثضْعفْ ثْنفْسشْثْ نْسنْ. \x ◘ \xo 8:‏7 \xt 1 كُور. 10‏:‏28. \x*  
\v 8 مَاشَا مَاشَّا وَارْ ذ أَنغْ ثسِّيوِيضْ شَا غَارْ أَربِّي، مِينْزِي مَاڒَا نشَّا، أَقَا وَارْ ذَايْنغْ يَارنِّي شَا، نِيغْ مَاڒَا وَارْ نشِّي، أَقَا وَارْ ذَايْنغْ بُو ڒخْصصْ. \x ◘ \xo 8:‏8 \xt رُوم. 14‏:‏17. \x*  
\v 9 مَاشَا غَارْومْ، أَقَا تّسْرِيحْ نْومْ وَارْ د-ثُوسِي أَذْ ثِيڒِي ذ ثَاعنْكْرِيفْثْ إِ يِينِّي إِضعْفنْ. \x ◘ \xo 8:‏9 \xt ڭال. 5‏:‏13. \x*  
\v 10 س مِينْزِي مَاڒَا حذْ إِتّْوَاڒَا كنِّيوْ، إِنِّي غَارْ ثدْجَا ثُوسّْنَا، ثتّْغِيمَامْ ذِي زَّاوشْثْ مَانِيعبّْذنْ لْ-أَصْنَامْ، مَا ثَانفْسشْثْ نّسْ، مِينْزِي نتَّا إِضْعفْ، وَارْ ثتّْوَاجْبذْ شَا أَذْ ثكَّارْ مَاحنْذْ أَذْ يشّْ مِينْ غَارْصنْ إِ لْ-أَصْنَامْ؟  
\v 11 أَمُّو س ثُوسّْنَا نّشْ أَذْ إِودَّارْ ونِّي إِضعْفنْ، ونِّي إِ خفْ إِمُّوثْ لْمَاسِيحْ. \x ◘ \xo 8:‏11 \xt رُوم. 14‏:‏15. \x*  
\v 12 خْمِي ثْخطِّيمْ أَمُّو خْ وَاوْمَاثنْ نْومْ ؤُشَا ثسّْيزّْممْ ثُوضْعفْثْ ن ثْنفْسشْثْ نْسنْ، أَقَا ثْخطِّيمْ خْ لْمَاسِيحْ.  
\v 13 س ؤُينِّي، مَاڒَا مَاشَّا أَقَا ثَارَّا ؤُمَا أَذْ إِنّذْرفْ، وَارْ تّتّغْ أَيْسُومْعمَّارْصْ، حِيمَا وَارْ سّنْذْرِيفغْ شَا ؤُمَا. \x ◘ \xo 8:‏13 \xt رُوم. 14‏:‏21؛ 2 كُور. 11‏:‏29. \x*   
\b  
\b  
\m  
\c 9
\s1 تّسْرِيحْ ن رَّاسُولْ  
\m
\v 1 مَا وَارْ دْجِيغْ ذ أَحُورِّي؟ مَا وَارْ دْجِيغْ ذ رَّاسُولْ؟ مَا وَارْ ژْرِيغْ سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ؟ مَا وَارْ ثدْجِيمْ كنِّيوْ ذ ڒْخذْمثْ إِنُو ذِي سِيذِي إِنُو؟ \x ◘ \xo 9:‏1 \xt ڒخ. 9‏:‏3، 17؛ 22‏:‏14، 18؛ 23‏:‏11؛ 1 كُور. 4‏:‏15؛ 15‏:‏8؛ 2 كُور. 12‏:‏2. \x*  
\v 2 مَاڒَا وَارْ دْجِيغْ ذ رَّاسُولْ إِ ونّغْنِي، إِ كنِّيوْ نِيشَانْ عْنِيغْ ث، \add وَاهْ،\add* كنِّيوْ ذ أَشمِّيعْ ن ڒْخذْمثْ إِنُو ن رَّاسُولْ.   
\m
\v 3 نشّْ أَرِّيغْ-د خْ يِينِّي خَافِي إِحكّْمنْ أَمُّو:  
\v 4 مَا وَارْ غَارْنغْ بُو تّسْرِيحْ حِيمَا أَذْ نشّْ، أَذْ نْسُو؟ \x ◘ \xo 9:‏4 \xt 1 كُور. 9‏:‏14؛ 1 تس. 2‏:‏6؛ 2 تس. 3‏:‏9. \x*  
\v 5 مَا وَارْ غَارْنغْ بُو تّسْرِيحْ أَذْ نَاوِي أَكِيذْنغْ إِشْثْ ن ثْوتْشْمَاثْ ذ ثَامْغَارْثْ أَمْ عَاوذْ رُّوسُولْ إِنّغْنِي ذ وَاوْمَاثنْ ن سِيذِيثْنغْ ذ كِيفَا؟ \x ◘ \xo 9:‏5 \xt مت. 8‏:‏14. \x*  
\v 6 نِيغْ وَاهَا بَارْ-نَابَا ذ نشّْ وَارْ غَارْنغْ بُو تّسْرِيحْ حِيمَا وَارْ نْخدّمْ؟  
\v 7 مَانْ ونْ إِ غَا إِخدّْمنْ ذِي ڒْعسْكَارْ أَذْ إِخدْجصْ ڒْمُونثْ إِ يِيخفْ نّسْ؟ مَانْ ونْ إِ غَا إِژُّونْ إِشْثْ ن ثْزَايَارْثْ ذڭْ إِجّْ ن ؤُمَارْجعْ ن ؤُضِيڒْ، وَارْ إِتّتّْ شَا زِي ڒْغِيدْجثْ نّسْ؟ نِيغْ مَانْ ونْ إِ غَا يَاركّْوسنْ إِشْثْ ن ثْحِيمَارْثْ، وَارْ إِسسّْ شَا أَغِي ن ثْحِيمَارْثْ؟ \x ◘ \xo 9:‏7 \xt يُوح. 21‏:‏15؛ 1 كُور. 3‏:‏6، 7، 8؛ 2 كُور. 10‏:‏4؛ 1 بُط. 5‏:‏2. \x*  
\v 8 مَا قَّارغْ مَانْ أَيَا أَمْ بْنَاذمْ \add وَاهَا\add*؟ خْزَارْ، ؤُڒَا ذ شَّارِيعَا ثقَّارْ أَيَا!  
\v 9 مِينْزِي ثُورَا ذِي شَّارِيعَا ن مُوسَا: ”وَارْ تّڭّْ ثَاشْمَانْثْ إِ ؤُينْذُوزْ إِسَّارْوَاثنْ.“ مَا أَربِّي إِحطَّا خْ إِينْذُوزنْ س ثِيذتّْ؟ \x ◘ \xo 9:‏9 \xt أَعَوذ. 25‏:‏4؛ 1 تِيم. 5‏:‏18. \x*  
\v 10 نسّنْ أَقَا إِنَّا إِ-ث ذِي طّْوعْ نّغْ ؤُ مَانْ أَيَا ثُورَا ذِي طّْوعْ نّغْ، مِينْزِي ونِّي إِشَارّْزنْ، أَذْ إِشَارْزْ س ؤُسِيثمْ ؤُ ونِّي إِسَّارْوَاثنْ، أَذْ إِسَّارْوَاثْ س ؤُسِيثمْ أَذْ غَارسْ يِيڒِي صَّابثْ.   
\m
\v 11 مَاڒَا نشِّينْ أَقَا نْزَارّعْ ذَايْومْ مِينْ إِدْجَانْ ن أَرُّوحْ، خنِّي مَا ذ أَطَّاسْ مَاڒَا نمْجَارْ زَّايْومْ \add شَا\add* زِي مِينْ إِدْجَانْ ن ثمُّورْثْ؟ \x ◘ \xo 9:‏11 \xt رُوم. 15‏:‏27؛ ڭال. 6‏:‏6. \x*  
\v 12 مَاڒَا إِنّغْنِي غَارْسنْ تّسْرِيحْ-أَ خَاومْ، \add مَاحنْذْ أَذْ شَارْشنْ ذِي مِينْ إِدْجَانْ نْومْ\add*، مَايمِّي نشِّينْ كْثَارْ لَّا؟ مَاشَا نشِّينْ وَارْ نسّْثنْفِيعْ زِي تّسْرِيحْ-أَ، مَاشَا نكْسِي مَارَّا، حِيمَا وَارْ نتّڭّْ ؤُڒَا ذ إِشْثْ ن ثْعنْكْرِيفْثْ إِ ڒخْبَارْ أَصبْحَانْ ن لْمَاسِيحْ. \x ◘ \xo 9:‏12 \xt ڒخ. 20‏:‏33؛ 2 كُور. 11‏:‏9؛ 12‏:‏13. \x*  
\v 13 مَا وَارْ ثسِّينمْ شَا بلِّي إِنِّي إِتّْسخَّارنْ ذڭْ ؤُقدَّاسْ أَذْ تّْوَارزْقنْ زِي \add مِينْ إِدْجَانْ ذڭْ\add* ؤُقدَّاسْ؟ ؤُشَا إِنِّي إِتّْسخَّارنْ غَارْ ؤُعَالْطَارْ أَذْ طّْفنْ ثَاسْغَارْثْ نْسنْ زڭْ ؤُعَالْطَارْ؟ \x ◘ \xo 9:‏13 \xt أَعَوذ. 18‏:‏1. \x*  
\v 14 أَمُّو عَاوذْ يُومُورْ سِيذِيثْنغْ إِ يِينِّي إِتّْبَارّْحنْ ڒخْبَارْ نّسْ أَصبْحَانْ، أَقَا أَذْ دَّارنْ زِي ڒخْبَارْ أَصبْحَانْ. \x ◘ \xo 9:‏14 \xt لَاوِي 19‏:‏13؛ أَعَوذ. 24‏:‏14؛ 25‏:‏4؛ مت. 10‏:‏10؛ لك. 10‏:‏7؛ 1 تِيم. 5‏:‏18. \x*   
\m
\v 15 مَاشَا نشّْ وَارْ سّْثنْفِيعغْ زڭْ ؤُڒَا ذ إِشْثْ زِي ثْمسْڒَايِينْ-أَ. ؤُ نشّْ وَارْ ث ؤُرِيغْ شَا، حِيمَا أَذْ إِتّْوَاڭّْ مَانْ أَيَا إِ نشّْ، معْلِيكْ ؤُفِيغْ أَذْ مّْثغْ خْ ؤُسبْضڒْ ن ؤُسمْغَارْ إِنُو س شَا ن يِيجّنْ.  
\v 16 خنِّي مَاڒَا نشّْ تّْبَارّْحغْ س ڒخْبَارْ أَصبْحَانْ، نشّْ وَارْ غَارِي شَا مِينْ ذِي غَا سّمْغَارغْ، مِينْزِي إِتّْخصَّا أَيِي مَانْ أَيَا. أَيحَّاثْ خَافِي، مَاڒَا وَارْ تّْبَارّْحغْ شَا س ڒخْبَارْ أَصبْحَانْ!  
\v 17 س ؤُينِّي، مَاڒَا ڭِّيغْ ت س ڒْخَاضَارْ إِنُو، أَذْ غَارِي ثِيڒِي ڒْمُونثْ، مَاشَا مَاڒَا وَارْ ت تّڭِّيغْ س ڒْخَاضَارْ، أَقَا أَذْ إِقِّيمْ ؤُوكّڒْ ذڭْ ؤُفُوسْ إِنُو.  
\v 18 مَانْ ثنْ قَاعْ إِدْجَانْ ذ ڒْمُونثْ إِنُو؟ أَقَا-ت ذ ثَا: أَمْ تّْبَارّْحغْ س ڒخْبَارْ أَصبْحَانْ أَذْ سّحْضَارغْ ڒخْبَارْ أَصبْحَانْ ن لْمَاسِيحْ بَاطڒْ، وَارْ كسِّيغْ شَا تّسْرِيحْ إِنُو إِ ذَايِي إِوْشَا \add أَربِّي\add* ذِي لْ-إِنْجِيلْ.   
\m
\v 19 نشّْ، ؤُمِي قِّيمغْ تّْوَاحَارّغْ زِي مَارَّا، أَقَا أَرّغْ إِخفْ إِنُو ذ أَمْسخَّارْ ن مَارَّا، حِيمَا أَذْ أَربْحغْ أَطَّاسْ \add ن إِوْذَانْ\add*.  
\v 20 إِ وُوذَاينْ ذوْڒغْ أَمْ وُوذَايْ حِيمَا أَذْ أَربْحغْ ؤُذَاينْ، إِ يِينِّي إِدْجَانْ سَاذُو شَّارِيعَا ذوْڒغْ أَمْ يِينِّي سَاذُو شَّارِيعَا، حِيمَا أَذْ أَربْحغْ إِنِّي إِدْجَانْ سَاذُو شَّارِيعَا. \x ◘ \xo 9:‏20 \xt ڒخ. 16‏:‏3؛ 18‏:‏18؛ 21‏:‏23. \x*  
\v 21 إِ يِينِّي إِدْجَانْ بْڒَا شَّارِيعَا ذوْڒغْ أَمْ ونِّي بْڒَا شَّارِيعَا - وَارْ دْجِيغْ بْڒَا شَّارِيعَا قِيبَاتْشْ إِ أَربِّي، مَاشَا أَقَا-يِي دَّارغْ ذِي شَّارِيعَا ن لْمَاسِيحْ - حِيمَا أَذْ أَربْحغْ إِنِّي إِدْجَانْ بْڒَا شَّارِيعَا. \x ◘ \xo 9:‏21 \xt ڭال. 2‏:‏3. \x*  
\v 22 ثُوغَا أَيِي ضعْفغْ غَارْ يِينِّي إِضعْفنْ، حِيمَا أَذْ أَربْحغْ إِنِّي إِضعْفنْ. أَقَا ذوْڒغْ ذ مَارَّا إِ مَارَّا، حِيمَا بعْذَا أَذْ وْشغْ ثُوذَارْثْ إِ مَارَّا. \x ◘ \xo 9:‏22 \xt رُوم. 15‏:‏1؛ 1 كُور. 10‏:‏33؛ ڭال. 6‏:‏1. \x*  
\v 23 مَانْ أَيَا تّڭّغْ، حِيمَا أَذْ طّْفغْ ثَاسْغَارْثْ ذِي ڒخْبَارْ أَصبْحَانْ.   
\m
\v 24 مَا وَارْ ثسِّينمْ شَا بلِّي إِنِّي إِتّڭّنْ ثْحَامَاثْ ن ثَازْڒَا ذِي ڒْمڒْعبْ، مَارَّا نِيشَانْ أَقَا تَّازّْڒنْ، مَاشَا إِجّنْ زَّايْسنْ إِ غَا يَاربْحنْ وَاهَا؟ خنِّي أَزّْڒمْ كنِّيوْ أَمُّو أَڒْ ذ غَا ثَاربْحمْ. \x ◘ \xo 9:‏24 \xt ڭال. 2‏:‏2؛ 5‏:‏7؛ فِيل. 2‏:‏16؛ 2 تِيم. 4‏:‏7؛ عبر. 6‏:‏18. \x*  
\v 25 مَاشَا كُوڒْ أَرْيَازْ إِ إِتّڭّنْ إِشْثْ ن ثْحَامثْ، إِحكّمْ خْ يِيخفْ نّسْ ذِي مَارَّا. نِيثْنِي ؤُزّْڒنْ حِيمَا أَذْ أَربْحنْ إِجّْ ن تَّاجْ إِفنَّا، مَاشَا نشِّينْ حِيمَا أَذْ نَارْبحْ إِجّْ ن تَّاجْ وَارْ إِفنِّي. \x ◘ \xo 9:‏25 \xt 2 تِيم. 2‏:‏4؛ 4‏:‏8؛ 1 بُط. 1‏:‏4؛ 5‏:‏4. \x*  
\v 26 س ؤُينِّي نشّْ وَارْ تِّيزّْڒغْ شَا أَمنِّي وَاهَا، وَارْ تّْمنْغِيغْ أَمْ ونِّي إِشَّاثنْ ذِي ڒعْوِينْ،  
\v 27 مَاشَا تّْمَارَّاثغْ أَرِّيمثْ إِنُو، أَذْ أَسْ قثْمَارغْ، حِيمَا نشّْ وَارْ تّْوَاسُّوفُّوغغْ شَا بَارَّا أَوَارْنِي ڒَامِي بَارّْحغْ إِنّغْنِي.   
\b  
\b  
\m  
\c 10
\s1 إِجّْ ن وعْڒمْ زڭْ ؤُمزْرُويْ ن ڒْڭنْسْ ن إِسْرَائِيل  
\m
\v 1 \add أَ\add* أَيْثْمَا، خْسغْ أَذْ ثسّْنمْ، بلِّي ڒجْذُوذْ نّغْ ثُوغَا أَثنْ مَارَّا سَاذُو ؤُسيْنُو ؤُشَا مَارَّا شُوقنْ ذِي ڒبْحَارْ، \x ◘ \xo 10:‏1 \xt ؤُف. 13‏:‏21؛ 14‏:‏22؛ ڒخْڒ. 9‏:‏18؛ أَعَوذ. 1‏:‏33؛ ياش. 4‏:‏23؛ نَاح. 9‏:‏12، 19؛ إِزهد. 78‏:‏13، 14؛ 105‏:‏39. \x*  
\v 2 ؤُشَا مَارَّا تّْوَاسّْغضْصنْ ذِي مُوسَا ذڭْ ؤُسيْنُو ؤُ ذِي ڒبْحَارْ، \x ◘ \xo 10:‏2 \xt ؤُف. 13‏:‏20‏-‏22، 14‏:‏19، 20. \x*  
\v 3 ؤُشَا مَارَّا شِّينْ مَاشَّا ثَارُوحشْثْ ذ إِشْثْ، \x ◘ \xo 10:‏3 \xt ؤُف. 16‏:‏15. \x*  
\v 4 ؤُشَا مَارَّا سْوِينْ ثِيسسِّيثْ ثَارُوهشْثْ ذ إِشْثْ، مِينْزِي نِيثْنِي سْوِينْ زڭْ وژْرُو ن أَرُّوحْ ونِّي ثُوغَا أَكِيذْسنْ، ؤُ أَژْرُو نِّي ثُوغَا-ث ذ لْمَاسِيحْ. \x ◘ \xo 10:‏4 \xt ؤُف. 17‏:‏6؛ ڒخْڒ. 20‏:‏11؛ إِزهد. 78‏:‏15؛ يُوح. 7‏:‏37‏-‏39.\x*  
\v 5 مَاشَا أَربِّي ثُوغَا وَارْ يَارْضِي خْ وزْينْ أَمقّْرَانْ زَّايْسنْ، مِينْزِي أَقَا أَثنْ وْضَانْ ذِي ڒخْڒَا. \x ◘ \xo 10:‏5 \xt ڒخْڒ. 26‏:‏65. \x*   
\m
\v 6 مَانْ أَيَا إِمْسَارْ ذ لْمِيثَالْ إِ نشِّينْ، حِيمَا وَارْ ذَايْنغْ إِتِّيڒِي مّژْرِي ذِي مِينْ إِعفّْننْ، أَمْ مَامّشْ ثُوغَا نِيثْنِي ذَايْسنْ مژْرِي. \x ◘ \xo 10:‏6 \xt ڒخْڒ. 11‏:‏4، 33؛ إِزهد. 106‏:‏14. \x*  
\v 7 أجّْ أَنغْ وَارْ نْذِيكّْوِيڒْ شَا أَذْ نعْبذْ لْ-أَصْنَامْ، أَمْ \add شَا\add* زَّايْسنْ، أَمْ مَامّشْ ثُورَا:  
\b  
\m \qt ”ڒْْڭنْسْ إِقِّيمْ حِيمَا أَذْ إِشّْ أَذْ إِسُّو\qt*  
\m \qt ؤُشَا كَّارنْ حِيمَا أَذْ إِرَارنْ.“\qt* \x ◘ \xo 10:‏7 \xt ؤُف. 32‏:‏6. \x*   
\b  
\m
\v 8 وَارْ إِعدّڒْ أَذْ نسّفْسَاذْ إِخفْ نّغْ، أَمْ \add شَا\add* زَّايْسنْ. أَقَا مُّوثنْ ذِينْ ثْڒَاثَا ؤُ-عِيشْرِينْ-أَڒفْ ذڭْ إِجّْ ن وَاسّْ. \x ◘ \xo 10:‏8 \xt ڒخْڒ. 25‏:‏1، 9؛ إِزهد. 106‏:‏29. \x*  
\v 9 وَارْ إِعدّڒْ أَذْ نْجَارّبْ لْمَاسِيحْ، أَمْ مَامّشْ جَارّْبنْ \add ث\add* \add شَا\add* زَّايْسنْ ؤُشَا تّْوَاهلْكنْ س إِفِيغْرَانْ. \x ◘ \xo 10:‏9 \xt ڒخْڒ. 21‏:‏5؛ إِزهد. 106‏:‏14. \x*  
\v 10 وَارْ إِعدّڒْ عَاوذْ أَذْ نسّْفِيخخْ أَمْ مَامّشْ \add شَا\add* زَّايْسنْ سّْفِيخِيخنْ، ؤُشَا \add خنِّي\add* تّْوَاهلّْكنْ س ؤُفُوسْ ن ؤُمْهلّكْ. \x ◘ \xo 10:‏10 \xt ؤُف. 16‏:‏2؛ 17‏:‏2؛ ڒخْڒ. 14‏:‏36؛ إِزهد. 106‏:‏25. \x*  
\v 11 مَارَّا مِينْ ذ أَسنْ إِمْسَارنْ، أَقَا ث ذ لْمِيثَالْ إِ نشِّينْ، ؤُشَا ثُورَا ذ أَعْڒَامْ إِ نشِّينْ مِيخفْ د-يُوسَا ؤُنڭَّارْ ن زّْمَانَاثْ. \x ◘ \xo 10:‏11 \xt رُوم. 15‏:‏4؛ 1 كُور. 9‏:‏10؛ فِيل. 4‏:‏5؛ عبر. 10‏:‏25. \x*   
\m
\v 12 س ؤُينِّي ونِّي ؤُمِي إِتّْغِيڒْ أَقَا إِبدّْ، أجّْ إِ-ث أَذْ إِحْضَا وَارْ إِوطِّي.  
\v 13 وَارْ خَاومْ إِتّكّْ ؤُجَارّبْ مْغِيرْ ونِّي إِ غَا يَاوْضنْ غَارْ إِوْذَانْ. \add مَاشَا\add* أَربِّي ذَايسْ ڒَامَانْ. نتَّا وَارْ كنِّيوْ إِتّجِّي أَذْ ثتّْوَاجَارّْبمْ سنّجْ إِ مِينْ ثْزمَّارمْ، مَاشَا نتَّا إِتِّيشْ ؤُفُّوغْ أَكْ-ذ ؤُجَارّبْ نْومْ، حِيمَا أَذْ ثْزمَّارمْ أَذْ ثَارْبُومْ \add أَغكّْوِي\add*. \x ◘ \xo 10:‏13 \xt 1 كُور. 1‏:‏8؛ 1 تس. 5‏:‏24؛ 2 بُط. 2‏:‏9. \x*   
\b  
\m  
\s1 ثَازوْضَا ن سِيذِيثْنغْ  
\m
\v 14 س ؤُيَا، إِمْعِيزّنْ إِنُو، أَروْڒمْ زڭْ ؤُعْبَاذْ إِ لْ-أَصْنَامْ.  
\v 15 سَّاوَاڒغْ \add أَكِيذْومْ\add* أَخْمِي سَّاوَاڒغْ أَكْ-ذ إِمِيغِيسنْ. حكْممْ كنِّيوْ \add خنِّي\add* خْ مِينْ ذ أَومْ قَّارغْ.  
\v 16 ڒْكَاسْ ن ؤُقَاذِي نِّي نتّْبَارَاكْ، مَا وَارْ إِدْجِي ذ ثَامُونْثْ أَكْ-ذ إِذَامّنْ ن لْمَاسِيحْ؟ أَغْرُومْ نِّي نْثَارژَّا، مَا وَارْ إِدْجِي ذ ثَامُونْثْ أَكْ-ذ أَرِّيمثْ ن لْمَاسِيحْ؟  
\v 17 أَمْ مَامّشْ إِدْجَا أَغْرُومْ ذ إِجّنْ، أَمُّو مَارَّا نشِّينْ ذ إِشْثْ ن أَرِّيمثْ، مِينْزِي مَارَّا نشِّينْ نطّفْ زڭْ إِجّْ ن وغْرُومْ. \x ◘ \xo 10:‏17 \xt رُوم. 12‏:‏5؛ 1 كُور. 12‏:‏27. \x*   
\m
\v 18 خْزَارمْ غَارْ إِسْرَائِيل عْلَاحْسَابْ أَرِّيمثْ! مَا إِنِّي إِتّتّنْ زِي ثْغَارْصَا وَارْ غَارْسنْ أَشْرَاشْ أَكْ-ذ ؤُعَالْطَارْ؟ \f ◼ \fr 10:‏18 \ft \+bd ’أَعَالْطَارْ‘\+bd* - نِيغْ: ’ڒْْمذْبحْ‘.\f*  
\v 19 مِينْ غَا إِنِيغْ ذِي مَانْ أَيَا؟ مَا بلِّي مِينْ إِمّوْشنْ ذ ثَاغَارْصْثْ إِ لْ-أَصْنَامْ ذ شَا، نِيغْ بلِّي لْ-أَصْنَامْ ذ شَا؟ لَّ. \x ◘ \xo 10:‏19 \xt 1 كُور. 8‏:‏4. \x*  
\v 20 مِينْ وْشِينْ لْكُوفَّارْ ذ ثَاغَارْصْثْ، وهّْبنْ ت إِ شّْوَاطنْ، وَارْ إِدْجِي إِ أَربِّي. ؤُشَا نشّْ وَارْ خْسغْ أَذْ ثْشَارْشمْ أَكْ-ذ شّْوَاطنْ. \f ◼ \fr 10:‏20 \ft \+bd ’شّْوَاطنْ‘\+bd* - نِيغْ: ’شَّايَاطِينْ‘.\f*  \x ◘ \xo 10:‏20 \xt لَاوِي 17‏:‏7؛ أَعَوذ. 32‏:‏17. \x*  
\v 21 وَارْ ثْزمَّارمْ أَذْ ثسْومْ ڒْكَاسْ ن سِيذِيثْنغْ ؤُڒَا ذ ڒْكَاسْ ن شّْوَاطنْ، ؤُشَا وَارْ ثْزمَّارمْ أَذْ ثْشَارْشمْ ثَازوْضَا ن سِيذِيثْنغْ ؤُڒَا ذ ثَازوْضَا ن شّْوَاطنْ. \f ◼ \fr 10:‏21 \ft \+bd ’ثَاژوْضَا‘\+bd* - نِيغْ: ’مِيسَّا‘.\f*  
\v 22 نِيغْ أَذْ نسّكَّارْ ثُوسْمِي ن سِيذِيثْنغْ؟ مَا نجْهذْ خَاسْ نشِّينْ؟   
\b  
\m  
\s1 ثِيڒلِّي ن ڒْمُومنْ  
\m
\v 23 مَارَّا إِتّْحدْجڒْ أَيِي، مَاشَا مَارَّا وَارْ إِنفّعْ. مَارَّا إِتّْهدْجڒْ، مَاشَا مَارَّا وَارْ إِبنِّي. \x ◘ \xo 10:‏23 \xt 1 كُور. 6‏:‏12. \x*  
\v 24 ؤُڒَا ذ إِجّْ وَارْ يَارزُّو شَا ثِيزِي نّسْ \add وَاهَا\add*، مَاشَا \add أجّْ\add* كُوڒْ إِجّْ \add أَذْ يَارْزُو\add* عَاوذْ ثنِّي ن ونِّي ذ أَسْ يُوذْسنْ. \x ◘ \xo 10:‏24 \xt 1 كُور. 13‏:‏5؛ فِيل. 2‏:‏4. \x*   
\m
\v 25 مَارَّا مِينْ إِتّْمنْزَانْ ذِي سُّوقْ ن إِڭزَّارنْ، ثْزمَّارمْ أَذْ ث ثشّمْ بْڒَا أَسقْسِي ذِي طّْوعْ ن ثْنفْسشْثْ،  
\v 26 مِينْزِي إِ سِيذِي ؤُمِي غَارْ ثدْجَا ثمُّورْثْ ذ ؤُعمَّارْ نّسْ. \x ◘ \xo 10:‏26 \xt ؤُف. 19‏:‏5؛ إِزهد. 24‏:‏1؛ 50‏:‏12، 89‏:‏12. \x*  
\v 27 مَاڒَا شَا ن يِيجّنْ زڭْ لْكُوفَّارْ، إِعَارْضْ إِ كنِّيوْ ؤُ ثخْسمْ أَذْ ثْرَاحمْ، شّمْ زِي مَارَّا مِينْ ذ أَومْ إِ ذ غَا إِسَّارْسْ، وَارْ ثسّقْسِيمْ شَا خْ سِّيبّثْ ن ثْنفْسشْثْ. \f ◼ \fr 10:‏27 \ft \+bd ’ثَانفْسشْثْ‘\+bd* - نِيغْ: ’ضَّامِيرْ‘.\f*  \x ◘ \xo 10:‏27 \xt لك. 10‏:‏7؛ 1 كُور. 8‏:‏7. \x*  
\v 28 مَاشَا مَاڒَا حذْ إِنَّا أَومْ: ”ذڭَّا إِتّْوَاغَارْصْ إِ لْ-أَصْنَامْ!“، وَارْ زَّايسْ ثتّتّمْ ذِي طّْوعْ ن ونِّي ذ أَومْ إِعڒْمنْ ؤُڒَا ذِي طّْوعْ ن ثْنفْسشْثْ.  
\v 29 مَاڒَا نشّْ نِّيغْ \add ذِي طّْوعْ ن\add* ’ثْنفْسشْثْ‘، وَارْ عْنِيغْ ثَانفْسشْثْ نْومْ، مَاشَا ثنِّي ن ونّغْنِي. مِينْزِي مَايمِّي غَا ثتّْوَاحَاكمْ ثْڒلِّي إِنُو س ثْنفْسشْثْ ن ونّغْنِي؟  
\v 30 مَاڒَا نشّْ شَارْشغْ س ؤُوقَّارْ \add غَارْ ؤُمنْسِي\add*، مَايمِّي غَا تّْوَاشقّْفغْ ذِي سِّيبّثْ مِيخفْ تّْقَاذِيغْ؟ \x ◘ \xo 10:‏30 \xt رُوم. 14‏:‏6؛ 1 تِيم. 4‏:‏3. \x*   
\m
\v 31 خنِّي مَاڒَا ثتّتّمْ نِيغْ ثْسسّمْ نِيغْ ثتّڭّمْ شَا ن ڒْحَاجّثْ نّغْنِي، ڭّمْ ت مَارَّا إِ ؤُعُودْجِي ن أَربِّي. \x ◘ \xo 10:‏31 \xt كُول. 3‏:‏17. \x*  
\v 32 وَارْ تِّيڒِيمْ ذ ثَاعنْكْرِيفْثْ إِ وُوذَاينْ نِيغْ إِ إِرَامِييّنْ ؤُڒَا إِ ثْمسْمُونْثْ ن أَربِّي، \x ◘ \xo 10:‏32 \xt رُوم. 14‏:‏13. \x*  
\v 33 أَمْ مَامّشْ ؤُڒَا ذ نشّْ أَرزُّوغْ أَذْ د-أَسغْ أَكْ-ذ مَارَّا ذِي كُوڒْشِي، وَارْ أَرزُّوغْ مِينْ إِدْجَانْ إِ ثِيزِي إِنُو، مَاشَا مِينْ إِدْجَانْ إِ ثِيزِي ن وَاطَّاسْ، حِيمَا أَذْ غَارْسنْ ثِيڒِي ثُوذَارْثْ. \x ◘ \xo 10:‏33 \xt 1 كُور. 9‏:‏22. \x*   
\b  
\b  
\m  
\c 11
\s1 أَرْيَازْ ذ ثمْغَارْثْ ذِي ثْمسْمُونْثْ ن يَاسُوع لْمَاسِيحْ  
\m
\v 1 ضْفَارمْ أَيِي-د أَمْ مَامّشْ ضْفَارغْ لْمَاسِيحْ. \x ◘ \xo 11:‏1 \xt 1 كُور. 4‏:‏16؛ فِيل. 3‏:‏17؛ 1 تس. 1‏:‏6؛ 2 تس. 3‏:‏9. \x*  
\v 2 سّمْغَارغْ كنِّيوْ، \add أَ\add* أَيْثْمَا إِنُو، مِينْزِي ثتّْفكَّارمْ ذَايِي ذِي مَارَّا ؤُشَا ثتّطّْفمْ ذِي ثوْصيَّاثْ، أَمْ مَامّشْ ذ أَومْ ثنْثْ وْشِيغْ.   
\m
\v 3 مَاشَا خْسغْ أَذْ ثسّْنمْ بلِّي لْمَاسِيحْ ذ أَزدْجِيفْ ن كُوڒْ أَرْيَازْ ؤُشَا أَرْيَازْ ذ أَزدْجِيفْ ن ثمْغَارْثْ، ؤُشَا أَربِّي ذ أَزدْجِيفْ ن لْمَاسِيحْ. \x ◘ \xo 11:‏3 \xt يُوح. 14‏:‏28؛ 1 كُور. 3‏:‏23؛ 15‏:‏27؛ أَفا. 5‏:‏23. \x*  
\v 4 كُوڒْ أَرْيَازْ ونِّي إِتّْژَادْجَانْ نِيغْ إِتّْنَابّنْ أَمْ إِڒحّفْ خْ ؤُزدْجِيفْ نّسْ، إِفطّحْ أَزدْجِيفْ نّسْ.  
\v 5 مَاشَا كُوڒْ ثَامْغَارْثْ ثنِّي إِتّْژَادْجَانْ نِيغْ إِتّْنَابّنْ أَمْ ثسّْعَارَّا ؤُزدْجِيفْ نّسْ، ثْفطّحْ أَزدْجِيفْ نّسْ، مِينْزِي نتَّاثْ أَمْ ثنِّي إِحفّنْ أَزدْجِيفْ نّسْ.  
\v 6 مِينْزِي مَاڒَا ثَامْغَارْثْ وَارْ ثْڒحِّيفْ، أجّْ إِ-ت أَذْ ثْحفّْ عَاوذْ. مَاشَا مَاڒَا ذ ڒفْضِيحثْ إِ ثمْغَارْثْ مَاڒَا ثْقسّْ \add أَشُووَّافْ\add* نِيغْ ثْحفّْ، حْسنْ مَاڒَا ثْڒحّفْ. \x ◘ \xo 11:‏6 \xt ڒخْڒ. 5‏:‏18؛ أَعَوذ. 22‏:‏5. \x*  
\v 7 مِينْزِي أَرْيَازْ وَارْ إِتّحْوِيجِي شَا أَذْ إِڒحّفْ أَزدْجِيفْ نّسْ، مِينْزِي نتَّا ذ صِّيفثْ ذ أَعُودْجِي ن أَربِّي، مَاشَا ثَامْغَارْثْ ثدْجَا ذ أَعُودْجِي ن ورْيَازْ. \x ◘ \xo 11:‏7 \xt أَمز. 1‏:‏26، 27؛ 5‏:‏1؛ 9‏:‏6؛ كُول. 3‏:‏10. \x*  
\v 8 مِينْزِي أَرْيَازْ وَارْ إِدْجِي شَا زِي ثمْغَارْثْ، مَاشَا ثَامْغَارْثْ زڭْ ورْيَازْ. \x ◘ \xo 11:‏8 \xt أَمز. 2‏:‏18، 21. \x*  
\v 9 أَرْيَازْ عَاوذْ وَارْ د-إِخْڒِيقْ شَا إِ ثمْغَارْثْ، مَاشَا ثَامْغَارْثْ إِ ورْيَازْ.  
\v 10 س ؤُينِّي إِتّْخصَّا أَسْ إِ ثمْغَارْثْ أَذْ غَارسْ ثِيڒِي صُّولْطَا خْ ؤُزدْجِيفْ نّسْ خْ سِّيبّثْ ن لْمَالَاكَاثْ.  
\v 11 مَاشَا ذِي سِيذِيثْنغْ أَرْيَازْ وَارْ \add إِدْجِي\add* بْڒَا ثَامْغَارْثْ، ؤُڒَا ذ ثَامْغَارْثْ وَارْ \add ثدْجِي\add* بْڒَا أَرْيَازْ.  
\v 12 مِينْزِي أَمْ مَامّشْ ثَامْغَارْثْ ثُوسَا-د زڭْ ورْيَازْ، أَمنِّي عَاوذْ إِدْجَا ورْيَازْ س ثمْغَارْثْ، مَاشَا مَارَّا مِينْ إِدْجَانْ أَقَا-ث زِي أَربِّي.  
\v 13 حكْممْ كنِّيوْ سِيمَانْثْ نْومْ: مَا ثُوسَا-د خْ ثمْغَارْثْ أَذْ ثژَّادْجْ إِ أَربِّي أَمْ ثسّْعَارَّا إِ ؤُزدْجِيفْ نّسْ؟  
\v 14 مَا ثُوبَّارْثْ سِيمَانْثْ نّسْ وَارْ ذ أَومْ ثسّْشَانْ بلِّي أَشُووَّافْ ذ أَزِيرَارْ ذ ڒفْضِيحثْ إِ ورْيَازْ؟  
\v 15 مَاشَا إِ ثمْغَارْثْ ذ أَعُودْجِي مَاڒَا غَارسْ يِيڒِي ؤُشُوَّافْ ذ أَزِيرَارْ، مِينْزِي إِمّوْشْ أَسْ ؤُشُوَّافْ أَمْ ؤُڒحَّافْ.  
\v 16 مَاشَا مَاڒَا إِخْسْ حذْ أَذْ إِخَارْوضْ مَانْ أَيَا، نشِّينْ وَارْ غَارْنغْ بُو ثْنَامِيثْ نِّي ؤُڒَا ذ ثِيمسْمُونِينْ ن أَربِّي. \x ◘ \xo 11:‏16 \xt 1 تِيم. 6‏:‏4. \x*   
\b  
\m  
\s1 أَمنْسِي إِقدّْسنْ  
\m
\v 17 وصِّيغْ كنِّيوْ خْ ثْمسْڒَايِينْ-أَ \add ڒخُّو\add*، أَقَا وَارْ ذ أَومْ تّڭّغْ شَّانْ، مِينْزِي وَارْ ثُويُورمْ غَارْ زَّاثْ، مَاشَا ثُويُورمْ غَارْ ضفَّارْ.  
\v 18 \add غَارْ ؤُمزْوَارْ\add*، مَاڒَا ثْمُونمْ أَمْ ثْمسْمُونْثْ، سْڒِيغْ أَقَا ذِينْ جَارْ أَومْ أَمْسبْضِي، ؤُ مَانْ أَيَا زمَّارغْ أَذْ ث أَمْنغْ إِ إِجّْ ن وزْينْ،  
\v 19 س مِينْزِي إِتّْخصَّا أَذْ ذِينْ إِڒِينْ جَارْ أَومْ إِمْشُوبّْشنْ، حِيمَا أَذْ إِبَانْ مَانْ ونْ زَّايْومْ إِ إِدْجَانْ ذ أَمْقدْجبْ. \x ◘ \xo 11:‏19 \xt مت. 18‏:‏7؛ لك. 17‏:‏1؛ ڒخ. 20‏:‏30؛ 1 يُوح. 2‏:‏19. \x*   
\b  
\m
\v 20 خْمِي تّْمُونَامْ، وَارْ ثتّتّمْ ذ ثْسسّمْ أَمْ مَامّشْ إِشُووَّارْ ذڭْ وَاسّْ ن سِيذِيثْنغْ، \f ◼ \fr 11:‏20 \ft \+bd ’أَسّْ ن سِيذِيثْنغْ‘\+bd* - مَانْ أَيَا إِخْسْ أَذْ يِينِي أَسّْ ن ؤُمنْسِي ن سِيذِي.\f*  \x ◘ \xo 11:‏20 \xt لك. 22‏:‏14‏-‏20. \x*  
\v 21 مَاشَا كُوڒْ إِجّنْ إِتّتّْ أَمنْسِي نّسْ إِ يِيخفْ نّسْ، \add ؤُشَا خنِّي\add* إِجّنْ نّغْنِي ذَايسْ ڒَاژْ ؤُشَا نّغْنِي إِسْشَارَا.  
\v 22 مَا وَارْ غَارْومْ ثُوذْرِينْ مَانِي غَا ثشّمْ ؤُ مَانِي غَا ثسْومْ؟ نِيغْ ثسّحْقَارَامْ ثَامسْمُونْثْ ن أَربِّي ؤُشَا ثسّْحشَّاممْ إِنِّي وَارْ غَارْ إِدْجِي شَا؟ مِينْ ذ أَومْ إِ غَا إِنِيغْ؟ مَا أَذْ أَومْ ڭّغْ شَّانْ؟ \add لَّ،\add* وَارْ ذ أَومْ تّڭّغْ شَّانْ!   
\m
\v 23 مِينْزِي مِينْ طّْفغْ زِي سِيذِيثْنغْ، سِّيوْضغْ أَومْ ث-إِ-د، أَقَا سِيذِيثْنغْ يَاسُوع ذِي دْجِيڒثْ إِ ذِي إِتّْوَاغْذَارْ، إِكْسِي أَغْرُومْ، \x ◘ \xo 11:‏23 \xt مت. 26‏:‏26؛ مك. 14‏:‏22؛ لك. 22‏:‏19. \x*  
\v 24 إِبَاركْ، يَارْژَا إِ-ث، إِنَّا: ”كْسِيمْ، ثَا ذ أَرِّيمثْ إِنُو إِ خَاومْ إِتّْوَارْژنْ، ڭّمْ أَيَا أَمُّو إِ ڒِيذَارثْ خَافِي!“ \x ◘ \xo 11:‏24 \xt لك. 22‏:‏19\x*  
\v 25 ؤُشَا أَمُّو أَوَارْنِي أَمنْسِي إِوْشَا ڒْكَاسْ، إِنَّا:  
\b  
\m \qt ”ڒْكَاسْ-أَ ذ ڒْعَاهْذْ ن جْذِيذْ\qt*  
\m \qt ذڭْ إِذَامّنْ إِنُو.\qt*  
\m \qt ڭّمْ أَيَا،\qt*  
\m \qt مشْحَاڒْ مَا زَّايسْ ثسْوِيمْ،\qt*  
\m \qt إِ ڒِيضَارثْ خَافِي.“\qt* \x ◘ \xo 11:‏25 \xt إِرْم. 31‏:‏31؛ مت. 26‏:‏28، مك. 14‏:‏24، لك. 22‏:‏20، 1 كُور. 11‏:‏25، 2 كُور. 3‏:‏6، عبر. 8‏:‏6، 8، 13؛ 9‏:‏15؛ 12‏:‏24\x*   
\b  
\m
\v 26 س مِينْزِي مشْحَاڒْ مَا إِ غَا ثشّمْ أَغْرُومْ-أَ ؤُ أَذْ ثسْومْ زِي ڒْكَاسْ-أَ، أَقَا ثتِّيذَارمْ ڒْموْثْ ن سِيذِيثْنغْ أَڒْ د غَا يَاسْ. \x ◘ \xo 11:‏26 \xt يُوح. 14‏:‏3؛ ڒخ. 1‏:‏11. \x*   
\m
\v 27 س ؤُينِّي مَانْ ونْ إِ غَا إِشّنْ أَغْرُومْ ن سِيذِي ؤُشَا أَذْ إِسُو زِي ڒْكَاسْ نّسْ، \add أَمْ\add* وَارْ إِتِّيڒِي س ؤُسْذَاهدْجِي إِ مَانْ أَيَا، أَذْ يِيڒِي س ؤُمَارْوَاسْ إِ إِذَامّنْ ن سِيذِي ؤُ إِ أَرِّيمثْ نّسْ. \x ◘ \xo 11:‏27 \xt ڒخْڒ. 9‏:‏10، 13؛ يُوح. 6‏:‏51، 63، 64؛ 13‏:‏27؛ 1 كُور. 10‏:‏21. \x*  
\v 28 س ؤُينِّي أجّْ كُوڒْ إِجّْ أَذْ إِقدْجبْ إِخفْ نّسْ، ؤُشَا أجّْ إِ-ث أَذْ إِشّْ خنِّي زڭْ وغْرُومْ ؤُ أَذْ إِسُو زِي ڒْكَاسْ. \x ◘ \xo 11:‏28 \xt 2 كُور. 13‏:‏5. \x*  
\v 29 مِينْزِي وِي غَا إِشّنْ ذ وِي غَا إِسْونْ أَمْ وَارْ إِسْذِيهدْجْ، أَقَا نتَّا أَذْ إِسِّيوضْ ڒْحُوكْمْ غَارْ إِخفْ نّسْ أَمْ إِتّتّْ ؤُ أَمْ إِسسّْ، مِينْزِي نتَّا وَارْ إِفَارّزْ شَا أَرِّيمثْ ن سِيذِي.  
\v 30 س ؤُينِّي أَقَا ذِينْ أَطَّاسْ ن يِينِّي إِضعْفنْ ذ يِينِّي إِهڒْشنْ جَارْ أَومْ ؤُشَا أَطَّاسْ ذوْڒنْ تّطّْصنْ \add إِضصْ نْ ڒْموْثْ\add*.   
\m
\v 31 مَاشَا مَاڒَا نحْكمْ خْ إِخفْ نّغْ، خنِّي وَارْ نتّْوَاحَاكمْ. \x ◘ \xo 11:‏31 \xt إِزهد. 32‏:‏5؛ أَوڒن. 18‏:‏17. \x*  
\v 32 مَاشَا مَاڒَا نتّْوَاحْكمْ زِي سِيذِيثْنغْ، أَقَا نتّْوَاربَّا، حِيمَا وَارْ نتّْوَاحَاكمْ شَا أَكْ-ذ دُّونشْثْ.  
\v 33 زِي ڒخُّو، \add أَ\add* أَيْثْمَا، خْمِي غَا ثْمُونمْ حِيمَا أَذْ ثشّمْ، رَاجَامْ إِجّنْ ونّغْنِي.  
\v 34 مَاڒَا حذْ ذَايسْ ڒَاژْ، أجّْ إِ-ث أَذْ إِشّْ ذِي ثَادَّارْثْ نّسْ، حِيمَا وَارْ ثتّْمُونمْ إِ شّْرعْ. مِينْ إِقِّيمنْ، أَذْ ثعذْڒغْ خْمِي د غَا يَاسغْ.   
\b  
\b  
\m  
\c 12
\s1 ثِيموْشَا ن أَرُّوحْ  
\m
\v 1 خْ ثْمسْڒَايِينْ ن أَرُّوحْ، \add أَ\add* أَيْثْمَا، خْسغْ أَذْ ثسّْنمْ،  
\v 2 ثُوغَا كنِّيوْ ذ لْكُوفَّارْ ؤُ ثتّْوَانذْهمْ غَارْ لْ-أَصْنَامْ إِڭْنَاونْ بْڒَا مَا ثُوشِيمْ.  
\v 3 س ؤُينِّي سَّارڭْبغْ كنِّيوْ، أَقَا وَارْ ذِينْ ؤُڒَا ذ إِجّنْ ونِّي إِ غَا إِسِّيوْڒنْ س أَرُّوحْ ن أَربِّي، أَذْ يِينِي: ’أَقَا إِتّْوَانْعڒْ يَاسُوع!‘، ؤُ وَارْ ذِينْ ؤُڒَا ذ إِجّنْ ونِّي إِ غَا يِينِينْ: ’يَاسُوع ذ سِيذِي!‘، مْغِيرْ س أَرُّوحْ إِقدّْسنْ وَاهَا. \x ◘ \xo 12:‏3 \xt مك. 9‏:‏39؛ يُوح. 13‏:‏13؛ 1 كُور. 8‏:‏6. \x*   
\m
\v 4 أَقَا ذِينْ ثِيوْهِيبِينْ إِفَارْزنْ، مَاشَا أَرُّوحْ أَقَا-ث ذ إِجّْ. \x ◘ \xo 12:‏4 \xt رُوم. 12‏:‏6؛ 1 بُط. 4‏:‏10. \x*  
\v 5 ؤُ أَقَا ذِينْ ڒخْذَايمْ ن ثْسخَّارْثْ إِفَارْزنْ، مَاشَا سِيذِي أَقَا-ث ذ إِجّْ.  
\v 6 ؤُشَا أَقَا ذِينْ ڒعْجَايبْ إِفَارْزنْ، مَاشَا أَربِّي أَقَا-ث ذ إِجّْ، ذ ونِّي إِتّڭّنْ مَارَّا ذِي مَارَّا بْنَاذمْ.  
\v 7 مَاشَا أَسَارْڭبْ ن أَرُّوحْ أَذْ إِمّوْشْ إِ كُوڒْ إِجّْ حِيمَا أَذْ ث إِعَاونْ.   
\m
\v 8 أَقَا س أَرُّوحْ إِمّوْشْ إِ يِيجّنْ أَوَاڒْ ن ثِيغِيثْ، إِ ونّغْنِي أَوَاڒْ ن ثُوسّْنَا س أَرُّوحْ \add ذ إِجّنْ\add*، \x ◘ \xo 12:‏8 \xt ؤُف. 31‏:‏3؛ 35؛13؛ إِشا. 11‏:‏2؛ كُول. 1‏:‏9\x*  
\v 9 إِ ونّغْنِي لْ-إِيمَانْ س أَرُّوحْ، إِ ونّغْنِي ثَاوْهِيبْثْ إِ ؤُسْڭنْفِي س أَرُّوحْ \add ذ إِجّنْ\add*،  
\v 10 إِ ونّغْنِي مَاحنْذْ أَذْ إِڭّْ ڒعْجَايبْ، إِ ونّغْنِي مَاهنْذْ أَذْ إِنبّْ، إِ ونّغْنِي ڒْفَارْزْ ن أَرُّوحَاثْ، إِ ونّغْنِي \bd عْڒَامْ كُوڒْ  إِڒْسَاونْ\bd* ؤُشَا إِ ونّغْنِي أَفسَّارْ ن إِڒْسَاونْ.  
\v 11 مَاشَا مَانْ أَيَا مَارَّا إِتّڭّْ إِ-ث أَرُّوحْ ذ إِجّنْ، ونِّي إِبطَّانْ إِ كُوڒْ إِجّْ أَنشْثْ مَامّشْ إِخْسْ نتَّا. \x ◘ \xo 12:‏11 \xt رُوم. 12‏:‏3، 6؛ 1 كُور. 7‏:‏7؛ 2 كُور. 10‏:‏13؛ أَفا. 4‏:‏7. \x*   
\b  
\m  
\s1 أَرِّيمثْ ن لْمَاسِيحْ ذ إِشْثنْ  
\m
\v 12 مِينْزِي أَمْ أَرِّيمثْ أَقَا-ت ذ إِشْثْ ؤُ غَارسْ أَطَّاسْ ن إِغزْذِيسنْ، عَاذْ أَقَا أَثنْ مَارَّا ذ إِغزْذِيسنْ ن إِشْثْ ن أَرِّيمثْ. وَاخَّا نِيثْنِي ذڭْ وَاطَّاسْ، أَقَا تّڭّنْ إِشْثْ ن أَرِّيمثْ وَاهَا، \add ؤُشَا\add* أَمُّو \add إِ ثدْجَا ثْمسْڒَاشْثْ\add* ؤُڒَا أَكْ-ذ لْمَاسِيحْ. \x ◘ \xo 12:‏12 \xt رُوم. 12‏:‏4، 5؛ أَفا. 4‏:‏16. \x*  
\v 13 مِينْزِي نتّْوَاسّغْضصْ مَارَّا س يِيجّْ ن أَرُّوحْ ذڭْ إِشْثْ ن أَرِّيمثْ، نِيغْ ؤُذَاينْ نِيغْ إِرَامِييّنْ نِيغْ إِسمْغَانْ نِيغْ إِحُورِّييّنْ، ؤُشَا مَارَّا نشِّينْ نْسُو زڭْ إِجّْ ن أَرُّوحْ. \x ◘ \xo 12:‏13 \xt يُوح. 7‏:‏37‏-‏39؛ ڭال. 3‏:‏28. \x*  
\v 14 ؤُڒَا ذ أَرِّيمثْ وَارْ ثدْجِي شَا س إِجّْ ن ؤُغزْذِيسْ \add وَاهَا\add*، مَاشَا س وَاطَّاسْ ن إِغزْذِيسنْ.  
\v 15 مَاڒَا أَضَارْ أَذْ إِنِي: ”مِينْزِي وَارْ دْجِيغْ ذ أَفُوسْ، وَارْ دْجِيغْ زِي أَرِّيمثْ!“، مَا خنِّي وَارْ إِتِّيڒِي زِي أَرِّيمثْ؟“  
\v 16 ؤُشَا مَاڒَا أَمزُّوغْ إِنَّا: ”مِينْزِي وَارْ دْجِيغْ ذ ثِيطّْ، وَارْ دْجِيغْ زِي أَرِّيمثْ!“، مَا خنِّي وَارْ إِتِّيڒِي زِي أَرِّيمثْ؟  
\v 17 مَاڒَا مَارَّا أَرِّيمثْ ثُوغَا-ت ذ ثِيطّْ، مَانِيسْ ذ إِكَّا ؤُسدْجِي؟ مَاڒَا مَارَّا \add أَرِّيمثْ\add* ثُوغَا-ت ذ أَسدْجِي، مَانِيسْ ذ إِكَّا ؤُشمِّي؟   
\m
\v 18 مَاشَا ڒخُّو أَربِّي إِڭَّا إِغزْذِيسنْ ذِي أَرِّيمثْ، كُوڒْ إِجّْ زَّايْسنْ أَمْ مَامّشْ إِخْسْ نتَّا.  
\v 19 مِينْزِي مَاڒَا مَارَّا ثُوغَا ذ إِجّْ ن ؤُغزْذِيسْ، مَانِي ثدْجَا أَرِّيمثْ خنِّي؟  
\v 20 مَاشَا ڒخُّو أَقَا ذِينْ أَطَّاسْ ن إِغزْذِيسنْ، مَاشَا ذ إِشْثْ ن أَرِّيمثْ وَاهَا.  
\v 21 ثِيطّْ وَارْ ثْزمَّارْ أَذْ ثِينِي إِ ؤُفُوسْ: ”وَارْ شكْ حْوِيجغْ شَا!“، نِيغْ عَاوذْ أَزدْجِيفْ إِ إِضَارنْ: ”وَارْ كنِّيوْ حْوِيجغْ شَا!“  
\v 22 مَاشَا س ڒْعكْسْ إِغزْذِيسنْ ن أَرِّيمثْ إِنِّي نْحسّبْ ضعْفنْ، أَقَا نِيثْنِي تّْوَاحْذَاجنْ أَطَّاسْ.  
\v 23 \add إِغزْذِيسنْ\add* نِّي ن أَرِّيمثْ إِ ذ أَنغْ إِتّْغِيڒنْ ذ إِمُوقْڒِيڒنْ، نتّڭّْ أَسنْ شَّانْ كْثَارْ، ؤُشَا إِغزْذِيسنْ إِنِّي إِتَّاوْينْ أَسضْحِي، أَذْ أَسنْ نسّْحِينّبْ س وَاطَّاسْ ن ڒهْزُوطْ.  
\v 24 مِينْزِي إِغزْذِيسنْ نّغْ نِّي غَارْ إِدْجَا ڒهْزُوطْ، وَارْ حْذَاجنْ مَانْ أَيَا، مَاغَارْ أَربِّي إِڭَّا أَرِّيمثْ، ؤُشَا إِ إِغزْذِيسنْ إِ إِدْجَانْ ذ قلّْ، إِوْشَا أَسنْ شَّانْ كْثَارْ،  
\v 25 حِيمَا وَارْ إِتِّيڒِي ؤُبطُّو ذِي أَرِّيمثْ، مَاشَا إِغزْذِيسنْ أَذْ وْشنْ ثَايْنِيثْ إِجّنْ إِ ونّغْنِي ذڭْ ؤُقَارنْ ذ إِجّنْ.  
\v 26 مَاڒَا إِجّْ ن ؤُغزْذِيسْ ثتّكّْ خَاسْ ثَامَارَا، مَارَّا \add إِغزْذِيسنْ\add* أَذْ كْسِينْ ثَامَارَا أَكِيذسْ، ؤُ مَاڒَا إِجّْ ن ؤُغزْذِيسْ إِفَارْحْ، أَذْ فَارْحنْ مَارَّا \add إِغزْذِيسنْ\add* أَكِيذسْ.  
\v 27 كنِّيوْ ذ أَرِّيمثْ ن لْمَاسِيحْ ذ إِغزْذِيسنْ ذڭْ ومْشَانْ إِ ذ أَومْ \add إِتّْوَاڭّنْ\add*. \x ◘ \xo 12:‏27 \xt رُوم. 12‏:‏5؛ أَفا. 1‏:‏23؛ 4‏:‏12؛ 5‏:‏23؛ كُول. 1‏:‏24. \x*   
\m
\v 28 زعْمَا أَربِّي أَقَا إِڭَّا ذِي ثْمسْمُونْثْ ذ أَمزْوَارُو رُّوسُولْ، أَوَارْنِي أَسنْ إِنَابِييّنْ، أَوَارْنِي أَسنْ إِمسْغَارنْ، أَوَارْنِي أَسنْ إِنِّي إِتّڭّنْ ڒعْجَايبْ، أَوَارْنِي أَسنْ ثِيوْهِيبِينْ ن ؤُسْڭنْفِي، إِنِّي إِتِّيشنْ أَفُوسْ، إِنِّي إِضبَّارنْ ؤُشَا ؤُڒَا ذ عْڒَامْ كُوڒْ إِڒْسَاونْ. \x ◘ \xo 12:‏28 \xt أَفا. 4‏:‏11؛ 2‏:‏20. \x*  
\v 29 مَا زعْمَا مَارَّا نِيثْنِي ذ رُّوسُولْ؟ مَا مَارَّا ذ إِنَابِييّنْ؟ مَا مَارَّا ذ إِمسْغَارنْ؟ مَا مَارَّا نِيثْنِي تّڭّنْ ڒعْجَايبْ؟  
\v 30 مَا مَارَّا غَارْسنْ ثِيوْهِيبِينْ ن ؤُسْڭنْفِي؟ مَا سَّاوَاڒنْ مَارَّا س إِڒْسَاونْ؟ مَا تّْفسَّارنْ مَارَّا \add إِڒْسَاونْ\add*؟  
\v 31 مَاشَا مَاڒَا ثَارْزُومْ خنِّي ذِي ثوْهِيبِينْ ثِيمقّْرَانِينْ \add قَاعْ\add*، أَقَا نشّْ أَذْ أَومْ سّشْنغْ إِجّْ ن وبْرِيذْ يُوعْڒَانْ.   
\b  
\b  
\m  
\c 13
\s1 ثَايْرِي  
\m
\v 1 \qt ”مَاعْلِيكْ نشّْ سَّاوَاڒغْ\qt*  
\m \qt س إِڒْسَاونْ ن إِوْذَانْ ذ لْمَالَاكَاثْ،\qt*  
\m \qt مَاشَا وَارْ غَارِي بُو ثَايْرِي،\qt*  
\m \qt أَقَا ذوْڒغْ ذ نّْحَاسْ إِتّنْثُوننْ،\qt*  
\m \qt نِيغْ ذ أَدْجُونْ إِدّنْذُوننْ.\qt*   
\m
\v 2 \qt مَاعْلِيكْ غَارِي ثَاوْهِيبْثْ مَاحنْذْ أَذْ نبّغْ،\qt*  
\m \qt فهّْمغْ مَارَّا ڒسْرَارْ\qt*  
\m \qt ؤُ غَارِي مَارَّا ثُوسّْنَا ذ مَارَّا لْ-إِيمَانْ\qt*  
\m \qt أَڒْ ذ سّْمُوطِّييغْ إِذُورَارْ،\qt*  
\m \qt \+tl مَاشَا\+tl* وَارْ ذ أَيِي ثدْجِي ثَايْرِي،\qt*  
\m \qt \+tl خنِّي\+tl* نشّْ ذ وَالُو إِ دْجِيغْ.\qt* \x ◘ \xo 13:‏2 \xt مت. 7‏:‏22؛ 17‏:‏20؛ 21‏:‏21؛ مك. 11‏:‏23؛ لك. 17‏:‏6؛ رُوم. 12‏:‏7. \x*   
\m
\v 3 \qt معْلِيكْ بْضِيغْ مَارَّا أَڭْڒَا إِنُو\qt*  
\m \qt ذ مَاشَّا خْ إِمزْڒَاضْ،\qt*  
\m \qt مَاعْلِيكْ وْشِيغْ أَرِّيمثْ إِنُو\qt*  
\m \qt حِيمَا أَذْ ت سّْشمْضنْ،\qt*  
\m \qt \+tl مَاشَا\+tl* وَارْ ذَايِي ثدْجِي ثَايْرِي،\qt*  
\m \qt وَارْ ذ أَيِي ثْنفّعْ ذِي وَالُو.\qt*   
\m
\v 4 \qt ثَايْرِي ثدْجَا غَارسْ تَّاسِيعْ ن ڒْخَاضَارْ ذ ڒضْرَافثْ،\qt*  
\m \qt ثَايْرِي وَارْ ذَايسْ بُو ثُوسْمِي،\qt*  
\m \qt ثَايْرِي وَارْ ثتّْفيّشْ س يِيخفْ نّسْ،\qt*  
\m \qt وَارْ ذَايسْ بُو نّْفَاخثْ،\qt* \f ◼ \fr 13:‏4 \ft \+bd ’نّْفَاخثْ‘\+bd* -نِيغْ: ’تَّاكبُّورْ‘.\f*  \x ◘ \xo 13:‏4 \xt أَوڒن. 10‏:‏12؛ 1 بُط. 4‏:‏8. \x*   
\m
\v 5 \qt ثَايْرِي وَارْ ثتّڭّْ بُو ڒفْضِيحثْ،\qt*  
\m \qt وَارْ ثَارزُّو ثِيزِي نّسْ،\qt*  
\m \qt وَارْ ثتّْوَاسَّارْزَاڭْ،\qt*  
\m \qt ؤُشَا وَارْ ثتّْخمَّامْ ذِي مِينْ إِدْجَانْ ذ أَعفَّانْ.\qt* \x ◘ \xo 13:‏5 \xt 1 كُور. 10‏:‏24؛ فِيل. 2‏:‏4. \x*   
\m
\v 6 \qt أَقَا وَارْ ثْفَارّحْ شَا زِي ڒْغشّْ،\qt*  
\m \qt مَاشَا ثْفَارّحْ زِي ثِيذتّْ.\qt* \x ◘ \xo 13:‏6 \xt 2 يُوح. 4. \x*   
\m
\v 7 \qt أَقَا ثْصبّرْ ذِي مَارَّا،\qt*  
\m \qt ثتَّامنْ ذِي مَارَّا،\qt*  
\m \qt ثسَّاثمْ مَارَّا،\qt*  
\m \qt ؤُشَا ثَاربُّو مَارَّا.\qt*   
\m
\v 8 \qt ثَايْرِي وَارْ ثْفنِّيعمَّارْصْ،\qt*  
\m \qt مَاشَا أَوَاڒنْ ن نُّوبُووَاثْ\qt*  
\m \qt أَذْ غَارْسنْ يِيڒِي ؤُنڭَّارْ،\qt*  
\m \qt إِڒْسَاونْ أَذْ ڭْنُونْ،\qt*  
\m \qt ؤُ ثُوسّْنَا أَذْ ثبْضڒْ.\qt*   
\m
\v 9 \qt مِينْزِي أَقَا نسّنْ غَارْ إِجّْ ن ؤُغزْذِيسْ \+tl وَاهَا\+tl*،\qt*  
\m \qt ؤُشَا نتّْنَابّْ مْغِيرْ إِجّْ ن وزْينْ،\qt*   
\m
\v 10 \qt مَاشَا خْمِي د غَا ثَاسْ ڒكْمَارثْ\qt*  
\m \qt ڒخْذنِّي مِينْ إِدْجَانْ غَارْ إِجّْ ن وزْينْ أَذْ إِبْضڒْ.\qt*   
\m
\v 11 \qt ڒَامِي ثُوغَا أَيِي ذ أَحنْجِيرْ،\qt*  
\m \qt سِّيوْڒغْ أَمْ ؤُحنْجِيرْ،\qt*  
\m \qt فكَّارغْ أَمْ ؤُحنْجِيرْ،\qt*  
\m \qt خَارْصغْ أَمْ ؤُحنْجِيرْ،\qt*  
\m \qt مَاشَا ڒَامِي ذوْڒغْ ذ أَرْيَازْ،\qt*  
\m \qt جِّيغْ \+tl أَوَارْنِي أَيِي\+tl* مِينْ إِدْجَانْ ن ؤُحنْجِيرْ.\qt*   
\m
\v 12 \qt ڒخُّو نتّْوَاڒَا س إِشْثْ ن ثِيسِيثْ \+tl إِبَارْشْننْ\+tl* \qt*  
\m \qt غَارْ إِجّْ ن وَارْوَاسْ،\qt*  
\m \qt مَاشَا خنِّي أَذْ نْژَارْ ثِيفْرَاسْ غَارْ ثِيفْرَاسْ.\qt*  
\m \qt ڒخُّو سّْنغْ غَارْ إِجّْ ن وزْينْ \+tl وَاهَا\+tl*،\qt*  
\m \qt مَاشَا خنِّي أَذْ سّْنغْ\qt*  
\m \qt مَامّشْ ثُوغَا تّْوَاسّْنغْ نشّْ.\qt* \x ◘ \xo 13:‏12 \xt 2 كُور. 3‏:‏18. \x*   
\m
\v 13 \qt مَاغَارْ ثْڒَاثَا-يَا أَذْ قِّيمنْ:\qt*  
\m \qt لْ-إِيمَانْ، أَسِيثمْ ذ ثَايْرِي،\qt*  
\m \qt مَاشَا أَمقّْرَانْ نْسنْ أَقَا-ت ذ ثَايْرِي.“\qt*   
\b  
\b  
\m  
\c 14
\s1 نُّوپُووَا ذ ڒْهَارْذْ س إِڒْسَاونْ  
\m
\v 1 ضْفَارمْ ثَايْرِي ؤُ نْجبْذمْ غَارْ ثوْهِيبِينْ ن أَرُّوحْ، ذ أَمزْوَارُو حِيمَا أَذْ ثْنبَّامْ. \f ◼ \fr 14:‏1 \ft \+bd ’ثَايْرِي‘\+bd* - نِيغْ: ’ڒمْحِيبّثْ‘.\f*  
\v 2 مِينْزِي ونِّي إِسَّاوَاڒنْ س إِڒْسَاونْ \add نّغْنِي\add*، وَارْ إِسِّيوِيڒْ شَا إِ إِوْذَانْ، مَاشَا إِ أَربِّي، مِينْزِي ؤُڒَا ذ إِجّْ وَارْ ذ أَسْ إِفهّمْ، مَاشَا إِسَّاوَاڒْ ڒسْرَارْ س أَرُّوحْ.  
\v 3 مَاشَا ونِّي إِتّْنَابّنْ، إِسَّاوَاڒْ غَارْ يوْذَانْ، حِيمَا أَذْ ثنْ إِبْنَا، أَذْ ثنْ إِسجّعْ، أَذْ ثنْ إِسّْفوّجْ.  
\v 4 ونِّي إِسَّاوَاڒنْ س يِيجّْ ن إِڒسْ \add نّغْنِي\add*، إِبنَّا إِخفْ نّسْ، مَاشَا ونِّي إِتّْنَابّنْ إِبنَّا ثَامسْمُونْثْ.  
\v 5 إِوَا خْسغْ مَارَّا كنِّيوْ أَذْ ثسِّيوْڒمْ س إِڒْسَاونْ \add نّغْنِي\add*، مَاشَا مْلِيحْ عَاذْ أَذْ ثْنبَّامْ، مِينْزِي أَمنْزُو وِي إِتّْنبَّانْ خْ وِي إِسِّيوْڒنْ س إِڒْسَاونْ \add نّغْنِي\add*، مْغِيرْ مَاڒَا وَانِيثَا أَذْ \add ث\add* إِفسَّارْ، مِينْزِي مَاڒَا إِفسَّارْ أَذْ ثتّْوَابْنَا ثْمسْمُونْثْ.   
\m
\v 6 خنِّي ڒخُّو، \add أَ\add* أَيْثْمَا، مَاڒَا ؤُسِيغْ-د غَارْومْ ؤُشَا أَذْ كِيومْ سِّيوْڒغْ س إِڒْسَاونْ \add نّغْنِي\add*، مَانْ نّْفعْ إِ غَارْومْ إِ غَا يَاوْيغْ مَاڒَا وَارْ ذ أَومْ سِّيوْڒغْ شَا س ؤُسَارْڭبْ نِيغْ س ثُوسّْنَا نِيغْ س إِجّْ ن وَاوَاڒْ إِ غَا نبّغْ نِيغْ س ؤُسڒْمذْ؟  
\v 7 مَاغَارْ ؤُڒَا ذ ڒحْوَايشْ وَارْ إِدَّارنْ أَمْ ثَامْجَا نِيغْ لْڭَامْبْرِي، ڭِّينْ ڒْحسّْ. مَاڒَا وَارْ ڭِّينْ ڒْفَارْزْ جَارْ إِجّْ ن ڒْحسّْ ذ ؤُمَاسْ، مَامّشْ غَا سّْننْ إِنِّي إِتّسْڒَانْ مِينْ تِّيرَارنْ س ثَامْجَا نِيغْ س لهَارْپَا؟  
\v 8 إِوَا، مَاڒَا أَسُوضِي ذڭْ ؤُيِيشّْ إِتّڭّْ ڒْحسّْ وَارْ إِصْفِي، وِي غَا إِسّْوجْذنْ \add خنِّي\add* إِ ؤُمنْغِي؟  
\v 9 أَمُّو عَاوذْ كنِّيوْ، مَاڒَا ثسِّيوِيڒمْ أَوَاڒنْ س إِجّْ ن يِيڒسْ \add نّغْنِي\add*، مَاشَا وَارْ ثنْ ثْفسَّارمْ، مَامّشْ غَا فهْمنْ مِينْ ثقَّارمْ؟ أَذْ ثسِّيوْڒمْ خنِّي أَمْ ونِّي إِسَّاوَاڒنْ ذِي ڒعْوِينْ.  
\v 10 أَقَا ذِينْ وِي إِسّْننْ مشْحَاڒْ ن إِڒْسَاونْ ذِي دُّونشْثْ ؤُشَا ؤُڒَا ذ إِجّنْ زَّايْسنْ وَارْ إِدْجِي بْڒَا ڒْحسّْ \add نّسْ\add*.  
\v 11 خنِّي مَاڒَا وَارْ سِّينغْ ڒَادْجَاغْ ن ڒْحسّْ، أَذْ إِڒِيغْ نشّْ ذ إِجّْ ن ؤُبَارَّانِي إِ ونِّي إِسَّاوَاڒنْ، ذ ونِّي إِسَّاوَاڒنْ أَذْ يِيڒِي ذ أَبَارَّانِي إِ نشّْ.   
\m
\v 12 أَمُّو عَاوذْ كنِّيوْ، ؤُمِي ثنْجبْذمْ غَارْ ثوْهِيبِينْ ن أَرُّوحْ، أَرْزُومْ أَذْ ثْفيّْضمْ ذِي طّْوعْ ن ڒبْنِي ن ثْمسْمُونْثْ.   
\m
\v 13 ونِّي إِسَّاوَاڒنْ س شَا ن إِڒسْ \add نّغْنِي\add*، أَذْ إِژَّادْجْ حِيمَا إِزمَّارْ إِ ؤُفسَّارْ نّسْ.  
\v 14 مِينْزِي مَاڒَا نشّْ ژُّودْجغْ س شَا ن يِيڒسْ \add نّغْنِي\add*، أَرُّوحْ إِنُو أَقَا إِژُّودْجْ، مَاشَا ڒفْهَامثْ إِنُو أَذْ ثقِّيمْ بْڒَا ڒْغِيدْجثْ.  
\v 15 مَامّشْ إِ غَا ڭّغْ؟ أَذْ ژَّادْجغْ س أَرُّوحْ إِنُو، مَاشَا أَذْ ژَّادْجغْ عَاوذْ س ڒعْقڒْ إِنُو، أَذْغنّْجغْ س أَرُّوحْ إِنُو، مَاشَا أَذْغنّْجغْ عَاوذْ س ڒعْقڒْ إِنُو. \x ◘ \xo 14:‏15 \xt أَفا. 5‏:‏19؛ كُول. 3‏:‏16. \x*  
\v 16 مَامّشْ نّغْنِي، مَاڒَا ثْبَارْكمْ س أَرُّوحْ، إِزمَّارْ حذْ إِ ذِينْ إِقِّيمنْ أَمْ وَارْ إِفْهِيمْ، أَذْ يِينِي ’أَمِينْ!‘ إِ ثْژَادْجِيثْ ن ؤُقَاذِي نّشْ، مِينْزِي نتَّا وَارْ إِسِّينْ مِينْ ثقَّارذْ.  
\v 17 مِينْزِي وَاخَّا شكْ ثْبَارْكذْ مْلِيحْ، مَاشَا ونِّي ذ أَشْ يُوذْسنْ وَارْ إِتّْوَابنِّي شَا \add زِي مَانْ أَيَا\add*.  
\v 18 نشّْ تّْقَاذِيغْ أَربِّي أَقَا سَّاوَاڒغْ س إِڒْسَاونْ كْثَارْ زَّايْومْ مَارَّا،  
\v 19 مَاشَا ذِي ثْمسْمُونْثْ أَقَا معْلِيكْ ؤُفِيغْ أَذْ إِنِيغْ خمْسَا ن وَاوَاڒنْ س ڒعْقڒْ إِنُو، حِيمَا أَذْ سّْڒمْذغْ عَاوذْ إِنّغْنِي، خْعشْرَا-أَڒَافْ ن وَاوَاڒنْ س يِيجّْ ن يِيڒسْ \add نّغْنِي\add*.   
\m
\v 20 \add أَ\add* أَيْثْمَا إِنُو، وَارْ تِّيڒِيمْ ذ ثَارْوَا ذڭْ إِخَارِّيصنْ نْومْ، مَاشَا إِڒِيمْ ذ إِسيْمَانْ ذِي ثُوعفّْنَا، ؤُ إِڒِيمْ ثِيوْضمْ ذِي ڒفْهَامثْ. \x ◘ \xo 14:‏20 \xt مت. 18‏:‏3؛ 19‏:‏14؛ أَفا. 4‏:‏14؛ 1 بُط. 2‏:‏1، 2. \x*  
\v 21 أَقَا ثُورَا ذِي شَّارِيعَا:  
\b  
\m \qt ”أَذْ سِّيوْڒغْ إِ ڒْڭنْسْ-أَ\qt*  
\m \qt س إِجّْ ن ڒْهَارْذْ ن ڒْبَارَّانِي\qt*  
\m \qt ؤُ س إِجّْ ن يِيڒسْ نّغْنِي.\qt*  
\m \qt وَاخَّا أَمُّو وَارْ ذ أَيِي تّسْڒِينْ شَا،\qt*  
\m \qt إِقَّارْ سِيذِي.“\qt* \x ◘ \xo 14:‏21 \xt أَعَوذ. 28‏:‏49؛ إِشا. 28‏:‏11‏-‏12. \x*   
\b  
\m
\v 22 أَمُّو خنِّي إِڒْسَاونْ ذ ڒعْڒَامثْ، وَارْ إِدْجِي إِ يِينِّي يُومْننْ، مَاشَا إِ يِينِّي وَارْ يُومِيننْ شَا، مَاشَا أَوَاڒْ إِ إِتّْوَانَابّنْ زَّايسْ وَارْ إِدْجِي إِ يِينِّي وَارْ يُومِيننْ، مَاشَا إِ يِينِّي يُومْننْ.   
\m
\v 23 مَاڒَا مَارَّا ثَامسْمُونْثْ ثسّْمُونْ ؤُ مَارَّا ثُوغَا سَّاوَاڒنْ س إِڒْسَاونْ، ؤُشَا \add خنِّي\add* ؤُذْفنْ إِنِّي إِجهْڒنْ نِيغْ إِنِّي وَارْ يُومِيننْ، مَا نِيثْنِي وَارْ قَّارنْ بلِّي أَقَا \add إِوْذَانْ-أَ\add* تّْخڒْفنْ؟  
\v 24 مَاشَا مَاڒَا مَارَّا ثْنبَّامْ ؤُشَا يُوذفْ-د حذْ وَارْ يُومِينْ نِيغْ حذْ إِجْهڒْ، خنِّي وَانِيثَا أَذْ إِتّْوَاسّقْنعْ زِي مَارَّا كنِّيوْ ؤُشَا أَذْ إِتّْوَاوبّخْ زَّايْومْ مَارَّا،  
\v 25 ؤُشَا مِينْ إِنُّوفَارنْ ذڭْ وُوڒْ نّسْ أَذْ إِتّْوَاعَارَّا. نتَّا أَذْ يَاضَارْ س وُوذمْ نّسْ، أَذْ إِسْجذْ إِ أَربِّي، أَذْ يِينِي: ”أَقَا س ثِيذتّْ أَربِّي أَقَا-ث جَارْ أَومْ!“   
\b  
\m  
\s1 أَعْبَاذْ ن ثْمسْمُونْثْ س ؤُستّفْ ؤُ ذِي ڒهْنَا  
\m
\v 26 س ؤُينِّي أَذْ أَومْ إِنِيغْ، \add أَ\add* أَيْثْمَا إِنُو، مَاڒَا ثْمُونمْ، أجّْ كُوڒْ إِجّنْ زَّايْومْ ونِّي غَارْ إِدْجَا إِجّْ ن ؤُزهِّيذْ \add نِيغْ\add* إِشْثْ ن ثْغُورِي \add نِيغْ\add* إِجّْ ن ؤُسَارْڭبْ \add نِيغْ\add* إِجّْ ن يِيڒسْ \add نِيغْ\add* إِجّْ ن ؤُفسَّارْ أَذْ زَّايسْ د-إِنْطقْ. أجّْ أَذْ يِيڒِي مَارَّا إِ ڒبْنِي.  
\v 27 مَاڒَا ذِينْ حذْ إِسِّيوڒْ س يِيجّْ ن إِڒسْ \add نّغْنِي\add*، \add أجّْ إِ-ثنْ\add* أَذْ سِّيوْڒنْ س ثْنَاينْ نِيغْ س وَاطَّاسْ س ثْڒَاثَا يِيذْسنْ، ؤُشَا كُوڒْ إِجّنْ \add زَّايْسنْ\add* س نُّوبثْ نّسْ، ؤُ أجّْ إِجّْ أَذْ ث إِفسَّارْ.  
\v 28 مَاشَا مَاڒَا وَارْ ذِينْ إِدْجِي وِي إِزمَّارنْ أَذْ إِفسَّارْ، أَذْ إِسْقَارْ نتَّا ذِي ثْمسْمُونْثْ، أَذْ إِسِّيوڒْ إِ يِيخفْ نّسْ ؤُ إِ أَربِّي.   
\m
\v 29 جّمْ أَذْ سِّيوْڒنْ ثْنَاينْ نِيغْ ثْڒَاثَا ن إِنَابِييّنْ، ؤُشَا إِنّغْنِي أَذْ حكْمنْ.  
\v 30 مَاشَا مَاڒَا إِتّْوَاسَّارْڭبْ شَا إِ حذْ أَمْ إِقِّيمْ ذِينِّي، أجّْ خنِّي أَذْ إِسُّوسمْ ونِّي إِسَّاوَاڒنْ ذ أَمزْوَارُو،  
\v 31 مِينْزِي ثْزمَّارمْ أَذْ ثْنبَّامْ مَارَّا إِجّنْ أَوَارْنِي ونّغْنِي، حِيمَا مَارَّا أَذْ ڒمْذنْ ؤُشَا أَذْ ذَايْسنْ إِتّْوَاڭّْ وُوڒْ مَارَّا.  
\v 32 مَاغَارْ أَرُّوحْ ن إِنَابِييّنْ، أَقَا-ث إِمَّارْسْ سَاذُو إِنَابِييّنْ،  
\v 33 مِينْزِي أَربِّي وَارْ إِدْجِي ذ أَربِّي ن ؤُخَارْوضْ، مَاشَا ن ڒهْنَا، أَمُّو \add إِ يدْجَا\add* ذِي مَارَّا ثِيمسْمُونِينْ ن إِمْقدَّاسنْ.   
\m
\v 34 ثُوسَا-د خْ ثمْغَارِينْ نْومْ أَذْ سُّوسْمنْثْ ذِي ثْمسْمُونِينْ، مِينْزِي وَارْ ذ أَسنْثْ إِسْمِيحْ أَذْ سِّيوْڒنْثْ، مَاشَا إِشُووَّارْ أَسنْثْ أَذْ إِڒِينْثْ تّْوَاضْعنْثْ أَمْ مَامّشْ ثقَّارْ عَاوذْ شَّارِيعَا. \x ◘ \xo 14:‏34 \xt أَمز. 3‏:‏16؛ أَفا. 5‏:‏22؛ كُول. 3‏:‏18؛ 1 تِيم. 2‏:‏12؛ ثِيث. 2‏:‏5؛ 1 بُط. 3‏:‏1. \x*  
\v 35 ؤُشَا مَاڒَا خْسنْثْ أَذْ ڒمْذنْثْ شَا، أَذْ سّقْسَانْثْ إِرْيَازنْ نْسنْثْ ذِي ثَادَّارْثْ نْسنْ، مِينْزِي أَقَا-ت ذ ڒفْضِيحثْ إِ ثمْغَارِينْ أَذْ سِّيوْڒنْثْ ذِي ثْمسْمُونْثْ.  
\v 36 مَا زعْمَا إِفّغْ-د زَّايْومْ أَوَاڒْ ن أَربِّي؟ نِيغْ يِيوضْ-د غَارْومْ وَاهَا؟   
\b  
\m
\v 37 مَاڒَا حذْ إِتّْغِيڒْ أَسْ ذ أَنَابِي نِيغْ ذ بْنَاذمْ أَرُّوحَانِي، أجّْ إِ-ث أَذْ إِعْقڒْ مْلِيحْ بلِّي مِينْ ذ أَومْ تَّارِيغْ، أَقَا أَثنْثْ ذ ثِيوصَّا ن سِيذِيثْنغْ.  
\v 38 مَاشَا مَاڒَا \add إِخْسْ\add* حذْ أَذْ إِقِّيمْ إِجْهڒْ، أجّْ إِ-ث أَذْ إِجْهڒْ.  
\v 39 أَمُّو خنِّي، \add أَ\add* أَيْثْمَا إِنُو، نْجبْذمْ حِيمَا أَذْ ثْنبَّامْ، وَارْ منّْعمْ شَا أَوَاڒْ س إِڒْسَاونْ \add إِنّغْنِي\add*.  
\v 40 أَذْ إِمْسَارْ مَارَّا س لَاذَابْ ؤُ س ؤُستّفْ.   
\b  
\b  
\m  
\c 15
\s1 ثَانُوكْرَا ن يَاسُوع لْمَاسِيحْ  
\m
\v 1 \add أَ\add* أَيْثْمَا إِنُو، أَذْ أَومْ سَّارْڭْبغْ خْ لْ-إِنْجِيلْ ونِّي ذ أَومْ بَارّْحغْ، ذ ونِّي ثْقبْڒمْ ؤُ ذ ونِّي ذِي ثْبدّمْ \add نِيشَانْ\add*،  
\v 2 إِ زِي ثطّْفمْ ثُوذَارْثْ، س وَاوَاڒْ إِ ذ أَومْ بَارّْحغْ، مَاڒَا \add خَاسْ\add* ثْعقْڒمْ عَاذْ. مَامّشْ نّغْنِي، زعْمَا ثُومْنمْ أَمنِّي وَاهَا. \x ◘ \xo 15:‏2 \xt رُوم. 1‏:‏16؛ 1 كُور. 1‏:‏21. \x*  
\v 3 مِينْزِي زڭْ ؤُمزْوَارْ سّعْذُوغْ أَومْ-د مِينْ ثُوغَا طّْفغْ س يِيخفْ إِنُو، أَقَا لْمَاسِيحْ إِمُّوثْ خْ دّْنُوبْ نّغْ عْلَاحْسَابْ مِينْ يُورَانْ، \x ◘ \xo 15:‏3 \xt إِشا. 53‏:‏7؛ دَان. 9‏:‏24، 26؛ 1 كُور. 5‏:‏7؛ 1 بُط. 2‏:‏24. \x*  
\v 4 أَقَا إِتّْوَانْضڒْ ؤُشَا إِتّْوَاسّْنكَّارْ-د ذڭْ وَاسّْ وِيسّْ ثْڒَاثَا عْلَاحْسَابْ مِينْ يُورَانْ. \x ◘ \xo 15:‏4 \xt إِزهد. 16‏:‏10؛ إِشا. 53‏:‏8، 9؛ يُون. 2‏:‏1؛ مت. 12‏:‏40. \x*  
\v 5 نتَّا إِضْهَارْ-د غَارْ كِيفَا، خنِّي غَارْ ثنْعَاشْ \add ن إِمحْضَارنْ\add*. \x ◘ \xo 15:‏5 \xt لك. 24‏:‏34؛ يُوح. 20‏:‏19؛ ڒخ. 10‏:‏41. \x*  
\v 6 أَوَارْنِي أَسْ إِبَانْ-د إِ ثِيوَّا ن خمْسَا-مْيَا ن وَاوْمَاثنْ ذڭْ ؤُمُورْ ذ إِجّنْ، أَطَّاسْ زَّايْسنْ دَّارنْ \add عَاذْ\add* أَڒْ إِ ڒخُّو، مَاشَا إِنّغْنِي أَقَا طّْصنْ \add إِضصْ ن ڒْموْثْ\add*.  
\v 7 أَوَارْنِي أَسْ إِضْهَارْ-د إِ يَاعْقُوبْ، خنِّي إِ مَارَّا رُّوسُولْ.   
\m
\v 8 أَمْ غَارْ ؤُنڭَّارْ ن مَارَّا، إِضْهَارْ أَيِي-د عَاوذْ أَمْ إِ يِيجّْ ن ؤُمخْڒُوقْ د-إِزْوَارنْ إِ ڒْوقْثْ نّسْ. \x ◘ \xo 15:‏8 \xt ڒخ. 9‏:‏3، 17؛ 23‏:‏11؛ 1 كُور. 9‏:‏1؛ 2 كُور. 12‏:‏2. \x*  
\v 9 مِينْزِي نشّْ دْجِيغْ ذ أَمَاژُوژْ قَاعْ زِي رُّوسُولْ، وَارْ سْذِيهِيجغْ أَذْ أَيِي ڒَاغَانْ رَّاسُولْ، مِينْزِي نشّْ ثُوغَا ذَارّْشغْ خْ ثْمسْمُونْثْ ن أَربِّي. \x ◘ \xo 15:‏9 \xt أَفا. 3‏:‏8؛ ڒخ. 8‏:‏3؛ 9‏:‏1؛ 22‏:‏4؛ 26‏:‏9؛ ڭال. 1‏:‏13؛ 1 تِيم. 1‏:‏13. \x*  
\v 10 مَاشَا س أَرْضَا ن أَربِّي إِ دْجِيغْ مِينْ دْجِيغْ ؤُشَا أَرْضَا نّسْ إِ ذَايِي إِدْجَانْ وَارْ إِدْجِي بَاطڒْ، مِينْزِي خذْمغْ مَاهُو قَاعْ خَاسنْ مَارَّا، \add مَاشَا\add* وَارْ إِدْجِي ذ نشّْ، مَاشَا أَرْضَا ن أَربِّي نِّي إِدْجَانْ أَكِيذِي. \x ◘ \xo 15:‏10 \xt 2 كُور. 11‏:‏23؛ 12‏:‏11. \x*  
\v 11 خنِّي مَا ذ نشّْ نِيغْ ذ نِيثْنِي، أَمُّو إِ نتّْبَارّحْ، أَمُّو إِ ثُومْنمْ.   
\b  
\m  
\s1 ثَانُوكْرَا ن إِمتِّيننْ  
\m
\v 12 مَاشَا مَاڒَا إِتّْوَابَارّحْ س لْمَاسِيحْ ونِّي د-إِتّْوَاسّْنكَّارنْ زِي ثَادَّارْثْ ن إِمتِّيننْ، مَامّشْ خنِّي زمَّارنْ شَا جَارْ أَومْ أَذْ إِنِينْ بلِّي وَارْ ذِينْ بُو ثُوذَارْثْ إِ إِمتِّيننْ؟  
\v 13 مِينْزِي مَاڒَا وَارْ ذِينْ بُو ثُوذَارْثْ إِ إِمتِّيننْ، ؤُڒَا ذ لْمَاسِيحْ وَارْ د-إِتّْوَاسّْنكَّارْ شَا،  
\v 14 ؤُشَا مَاڒَا لْمَاسِيحْ وَارْ د-إِتّْوَاسّْنكَّارْ، خنِّي بَاطڒْ إِ ثدْجَا ثْبَارّحْثْ نّغْ، بَاطڒْ إِ يدْجَا \add خنِّي\add* لْ-إِيمَانْ نْومْ.  
\v 15 خنِّي نشِّينْ نْبَانْ عَاوذْ ذ ڒشْهُوذْ إِسّْخَارِّيقنْ ن أَربِّي، مِينْزِي نشْهذْ خْ أَربِّي بلِّي أَقَا إِسّْنكَّارْ-د لْمَاسِيحْ، وَاخَّا نتَّا وَارْ إِ-ث-إِ-د-إِسّْنكَّارْ شَا.  
\v 16 مِينْزِي مَاڒَا إِمتِّيننْ وَارْ د-تّثْوَاسْنكَّارنْ شَا، أَقَا لْمَاسِيحْ وَارْ د-إِتّْوَاسّْنكَّارْ عَاوذْ.  
\v 17 ؤُ مَاڒَا لْمَاسِيحْ وَارْ د-إِتّْوَاسّْنكَّارْ شَا، أَقَا لْ-إِيمَانْ نْومْ إِخْوَا، ؤُ أَقَا كنِّيوْ عَاذْ ذِي دّْنُوبْ نْومْ،  
\v 18 ؤُشَا تّْوَاهلّْكنْ ؤُڒَا ذ إِنِّي إِتّطّْصنْ ذِي لْمَاسِيحْ \add أَوَارْنِي ڒَامِي مُّوثنْ\add*.  
\v 19 مَاڒَا ثُوغَا نسِّيثِيمْ ذِي لْمَاسِيحْ ذِي ثُوذَارْثْ-أَ وَاهَا، أَقَا أَنغْ قَاعْ ذ إِمْشُومنْ ن مَارَّا إِوْذَانْ.   
\b  
\m
\v 20 مَاشَا ڒخُّو ؤُمِي د-إِتّْوَاسّْنكَّارْ لْمَاسِيحْ زِي ثَادَّارْثْ ن إِمتِّيننْ، أَقَا إِذْوڒْ نتَّا ذ أَمنْزُو ن يِينِّي إِطّْصنْ \add ذڭْ ونْضڒْ\add*. \x ◘ \xo 15:‏20 \xt كُول. 1‏:‏18؛ 1 بُط. 1‏:‏3؛ أَسَا. 1‏:‏5. \x*  
\v 21 ؤُ أَمْ مَامّشْ د-ثُوسَا ڒْموْثْ زڭْ إِجّْ ن بْنَاذمْ، أَمُّو ؤُڒَا ذ ثَانُوكْرَا ن إِمتِّيننْ ثدْجَا زڭْ إِجّْ ن بْنَاذمْ. \x ◘ \xo 15:‏21 \xt أَمز. 2‏:‏17؛ 3‏:‏6؛ رُوم. 5‏:‏12، 18؛ 6‏:‏23. \x*  
\v 22 مِينْزِي أَمْ إِوْذَانْ مَارَّا أَذْ مّْثنْ ذِي أَذَامْ، أَمُّو عَاوذْ إِ غَا دَّارنْ مَارَّا نِيثْنِي عَاوذْ ذِي لْمَاسِيحْ.  
\v 23 مَاشَا كُوڒْ إِجّْ ذِي نُّوبثْ نّسْ: لْمَاسِيحْ ثُوغَا ذ أَمنْزُو، خنِّي أَوَارْنِي أَسْ إِنِّي إِدْجَانْ ن لْمَاسِيحْ غَارْ ثْوَاسِيثْ نّسْ.  
\v 24 أَوَارْنِي مَانْ أَيَا ذ أَنڭَّارُو، خْمِي غَا إِوْشْ ثَاڭلْذِيثْ إِ أَربِّي، بَابَاثْنغْ، خْمِي غَا إِسّبْضڒْ مَارَّا ڒحْكَامثْ ذ مَارَّا صُّولْطَا ذ مَارَّا جّهْذْ.   
\m
\v 25 مَاغَارْ نتَّا أَذْ إِحْكمْ أَمْ ؤُجدْجِيذْ أَڒْ ذ غَا يڭّْ مَارَّا ڒْعذْيَانْ نّسْ سَاذُو إِضَارنْ نّسْ. \x ◘ \xo 15:‏25 \xt إِزهد. 110‏:‏1؛ ڒخ. 2‏:‏34؛ أَفا. 1‏:‏20؛ كُول. 3‏:‏1؛ عبر. 1‏:‏13؛ 10‏:‏12. \x*  
\v 26 ڒعْذُو أَنڭَّارُو ونِّي إِ غَا إِتّْوَابضْڒنْ، أَقَا-ت ذ ڒْموْثْ.  
\v 27 مِينْزِي أَقَا إِڭَّا مَارَّا سَاذُو إِضَارنْ نّسْ. مَاشَا خْمِي إِتّْوَانَّا: ”أَقَا مَارَّا ثِيمسْڒَايْنْ تّْوَاڭّنْثْ سَاذُو نتَّا!“، أَقَا إِبَانْ \add مْلِيحْ\add* بلِّي ونِّي ذ أَسْ إِڭِّينْ مَارَّا سَاذُو نتَّا، أَقَا نتَّا سِيمَانْثْ نّسْ وَارْ إِدْجِي سَاذُو نتَّا. \x ◘ \xo 15:‏27 \xt إِزهد. 8‏:‏7؛ مت. 11‏:‏27؛ 28‏:‏18؛ أَفا. 1‏:‏22؛ عبر. 2‏:‏8. \x*  
\v 28 ؤُشَا ڒَامِي ذ أَسْ إِتّْوَاڭّْ مَارَّا سَاذُو إِ نتَّا، ڒخْذنِّي مِّيسْ \add ن أَربِّي\add* عَاوذْ أَذْ إِتّْوَاڭّْ سَاذُو إِ ونِّي ؤُمِي ذ أَسْ إِڭِّينْ مَارَّا سَاذُو إِ نتَّا، حِيمَا أَذْ يِيڒِي أَربِّي ذ مَارَّا ذِي مِينْ ذِي مَّا.   
\m
\v 29 نِيغْ، مِينْ غَا ڭّنْ إِنِّي إِتّْوَاسّْغضْصنْ ذِي طّْوعْ ن إِمتِّيننْ مَاڒَا وَارْ د-ثتّْوَاسّْنكَّارنْ إِمتِّيننْعمَّارْصْ؟ مَاغَارْ مَايمِّي غَا تّْوَاسّْغضْصنْ عَاذْ ذِي طّْوعْ ن إِمتِّيننْ؟  
\v 30 ؤُ مَايمِّي نشِّينْ \add عَاذْ\add* ذِي لْخَاطَارْ ذِي كُوڒْ ثْسَاعّثْ؟  
\v 31 \add أَ\add* أَيْثْمَا، تّْجَادْجِيغْ غَارْ ؤُسمْغَارْ نْومْ إِ إِدْجَانْ غَارِي ذِي سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ، أَقَا تّْمتِّيغْ كُوڒْ أَسّْ.  
\v 32 ؤُ مَامّشْ، مَاڒَا تّْوَامنْضَارغْ زَّاثْ إِ ڒوْحُوشْ ذِي أَفَاسُوسْ خْ ڒحْسَابْ بْنَاذمْ، مَانْ ڒفْضڒْ إِ غَارِي، مَاڒَا إِمتِّيننْ وَارْ د-تّْوَاسّْنكَّارنْ شَا؟ أجّْ أَنغْ أَذْ نشّْ أَذْ نْسُو، مِينْزِي ثِيوشَّا أَذْ نمّثْ. \x ◘ \xo 15:‏32 \xt إِشا. 22‏:‏13؛ 56‏:‏12. \x*  
\v 33 وَارْ تّْغشِّيمْ يِيخفْ نْومْ: ڒْهَارْذْ وَارْ إِحْڒِينْ ثْجيَّاحْ نّيّثْ ثَاصبْحَانْثْ.  
\v 34 سْفَاقمْ ؤُڒَاونْ نْومْ \add غَارْ\add* ثْسڭْذَا، وَارْ خطِّيمْ شَا. مِينْزِي شَا \add زَّايْومْ\add* وَارْ غَارْسنْ ثدْجِي ثُوسّْنَا ن أَربِّي. إِ ڒحْيَا نْومْ قَّارغْ ت.   
\b  
\m  
\s1 أَرِّيمثْ ن ثْنُوكْرَا وَارْ إِفنِّينْ  
\m
\v 35 أَذْ إِنِينْ شَا زَّايْومْ: ”مَامّشْ إِ د غَا تّْوَاسّْنكَّارنْ إِمتِّيننْ؟ س مَانْ أَرِّيمثْ إِ د غَا يَاسنْ؟“ \x ◘ \xo 15:‏35 \xt حِز. 37‏:‏3. \x*  
\v 36 \add أَ\add* أَفْغُوڒْ، مِينْ ثْزَارّْعذْ شكْ، وَارْ إِدَّارْ مَاڒَا وَارْ إِمُّوثْ \add قْبڒْ\add*. \x ◘ \xo 15:‏36 \xt يُوح. 12‏:‏24. \x*  
\v 37 مِينْ ثْزَارّْعذْ، وَارْ ثدْجِي شَا ذ أَرِّيمثْ نِّي إِ غَا ثِيڒِي، مَاشَا ثْزَارّْعذْ ثَاعقَّاشْثْ إِغرْينْ ن يِيرْذنْ نِيغْ ن إِمنْذِي نِيغْ ن شَا ن زَّارِيعثْ نّغْنِي.  
\v 38 مَاشَا أَربِّي إِوْشَا أَسْ أَرِّيمثْ أَمْ مَامّشْ إِخْسْ نتَّا، إِ كُوڒْ دَّابْ ن زَّارِيعثْ إِوْشَا أَسْ أَرِّيمثْ عْلَاحْسَابْ طّْبِيعثْ ن كُوڒْ إِشْثنْ زَّايْسنْثْ.   
\m
\v 39 وَارْ إِدْجِي مَارَّا أَرِّيمثْ \add ذ أَرِّيمثْ\add* ذ إِجّْ، مَاشَا ثنِّي ن إِوْذَانْ إِمّْسبْضَا خْ ثنِّي ن ڒْمَاڒْ، ؤُ ثنِّي ن إِجْضَاضْ ونّغْنِي ن ثنِّي ن إِسڒْمَانْ.   
\m
\v 40 أَقَا ذِينْ أَرِّيمَاثْ ن ؤُجنَّا ذ أَرِّيمَاثْ ن ثمُّورْثْ، مَاشَا أَعُودْجِي ن يِينِّي ن ؤُجنَّا ونّغْنِي ن يِينِّي ن ثمُّورْثْ.  
\v 41 إِجّنْ ذ أَعُودْجِي ن ثْفُوشْثْ، ونّغْنِي ذ أَعُودْجِي ن ؤُيُورْ، ؤُ ونّغْنِي ذ أَعُودْجِي ن إِثْڒَانْ، ؤُشَا أَعُودْجِي ن إِجّْ ن إِثْڒِي إِعدُّونْ خْ ؤُعُودْجِي ن إِجّْ ن إِثْڒِي نّغْنِي.   
\m
\v 42 أَمُّو خنِّي إِ غَا ثِيڒِي ثُوذَارْثْ إِ يِينِّي مُّوثنْ. أَقَا تّْوَازَارّْعنْ نِيثْنِي ذِي مِينْ إِغشّنْ ؤُشَا تّْوَاسّْنكَّارنْ-د بْڒَا ڒْغشّْ. \x ◘ \xo 15:‏42 \xt دَان. 12‏:‏3؛ مت. 13‏:‏43. \x*  
\v 43 أَقَا تّْوَازَارّْعنْ نِيثْنِي ذِي مِينْ وَارْ إِشْنِيعنْ ؤُشَا أَذْ د-تّْوَاسّْنكَّارنْ ذڭْ ؤُعُودْجِي. نِيثْنِي تّْوَازَارّْعنْ ذڭْ وضْعَافْ ؤُشَا أَذْ د-تّْوَاسّْنكَّارنْ ذِي جّهْذْ.  
\v 44 أَقَا تّْوَازَارّْعنْ نِيثْنِي س إِشْثْ ن أَرِّيمثْ ن طّْبِيعثْ ؤُشَا \add خنِّي\add* أَذْ د-إِتّْوَاسّْنكَّارْ \add بْنَاذمْ\add* س إِشْثْ ن أَرِّيمثْ ثَارُّوحَانِيثْ. أَقَا ذِينْ أَرِّيمثْ ن طّْبِيعثْ، أَمُّو أَقَا ذِينْ ؤُڒَا ذ أَرِّيمثْ ن أَرُّوحْ.   
\m
\v 45 أَمُّو إِ ثُورَا عَاوذْ: ”أَرْيَازْ أَمزْوَارُو أَذَامْ، \add إِذْوڒْ\add* ذ ڒعْمَارْ إِدَّارنْ!“، أَذَامْ أَنڭَّارُو إِذْوڒْ ذ أَرُّوحْ إِ إِتِّيشنْ ثُوذَارْثْ. \x ◘ \xo 15:‏45 \xt أَمز. 2‏:‏7. \x*  
\v 46 مَاشَا مِينْ \add إِدْجَانْ\add* زِي أَرُّوحْ وَارْ د-يُوسِي شَا ذ أَمزْوَارُو، مَاشَا مِينْ إِدْجَانْ ن طّْبِيعثْ، خنِّي أَوَارْنِي مَانْ أَيَا مِينْ \add إِدْجَانْ\add* زِي أَرُّوحْ.  
\v 47 بْنَاذمْ أَمزْوَارُو إِكَّا-د زڭْ ؤُشَاڒْ ن ثمُّورْثْ، بْنَاذمْ وِيسّْ ثْنَاينْ ذ سِيذِي إِ د-إِكِّينْ زڭْ ؤُجنَّا.  
\v 48 أَمْ مَامّشْ إِدْجَا ونِّي زڭْ ؤُشَاڒْ، أَمُّو إِ دْجَانْ ؤُڒَا ذ نِيثْنِي زڭْ ؤُشَاڒْ، ؤُشَا أَمْ مَامّشْ إِدْجَا ونِّي ن ؤُجنَّا، أَمُّو إِ دْجَانْ ؤُڒَا ذ إِنِّي \add ن ؤُجنَّا\add*.  
\v 49 ؤُشَا أَمْ مَامّشْ نَارْبُو صِّيفثْ ن ونِّي إِتّْوَاڭّنْ زڭْ ؤُشَاڒْ، أَمُّو خنِّي أَذْ نَارْبُو صِّيفثْ ن ونِّي إِدْجَانْ زڭْ ؤُجنَّا. \x ◘ \xo 15:‏49 \xt 2 كُور. 4‏:‏11. \x*   
\b  
\m
\v 50 \add أَ\add* أَيْثْمَا إِنُو، دّڭَّا \add خْسغْ\add* أَذْ إِنِيغْ: أَقَا أَيْسُومْ ذ إِذَامّنْ وَارْ زمَّارنْ أَذْ وَارْثنْ ثَاڭلْذِيثْ ن إِجنْوَانْ، ؤُشَا مِينْ إِفنَّانْ وَارْ إِوَارّثْ مِينْ وَارْ إِفنِّينْ. \x ◘ \xo 15:‏50 \xt يُوح. 1‏:‏13. \x*  
\v 51 خْزَارمْ، أَذْ كنِّيوْ سَّارڭْبغْ خْ إِجّْ ن سِّيرّْ: أَقَا أَنغْ وَارْ نتّطّصْ شَا مَارَّا \add س يِيضصْ نْ ڒْموْثْ\add*، مَاشَا نشِّينْ مَارَّا أَذْ نتّْوَابدّڒْ، \x ◘ \xo 15:‏51 \xt 1 تس. 4‏:‏16. \x*  
\v 52 ذغْيَا، ذڭْ ورْمَاشْ ن وَابْڒِيونْ، غَارْ \bd ڒْْحسّْ ن ؤُسُوضِي أَنڭَّارُو ذڭْ ؤُيِيشّْ \+bdit ن إِشَارِّي\+bdit*\bd*: إِمتِّيننْ أَذْ د-تّْوَاسّْنكَّارنْ غَارْ مِينْ وَارْ إِفنِّينْ ؤُشَا نشِّينْ أَذْ نتّْوَابدّڒْ. \x ◘ \xo 15:‏52 \xt مت. 24‏:‏31؛ 1 تس. 4‏:‏16. \x*  
\v 53 مِينْزِي مِينْ إِفنَّانْ إِتّْخصَّا أَسْ أَذْ يَارْضْ مِينْ وَارْ إِفنِّينْ ؤُ مِينْ غَا إِمُّوثنْ إِتّْخصَّا أَسْ أَذْ يَارْضْ مِينْ وَارْ إِتّْمتِّينْ.   
\m
\v 54 ؤُشَا خْمِي مِينْ إِفنَّانْ أَذْ يَارْضْ مِينْ وَارْ إِفنِّينْ ؤُ مِينْ غَا إِمُّوثنْ \add أَذْ يَارْضْ\add* مِينْ وَارْ إِتّْمتِّينْ، ڒخْذنِّي أَذْ إِكمّڒْ وَاوَاڒْ إِ إِتّْوَارِينْ:  
\b  
\m \qt ”ڒْْموْثْ أَقَا ثتّْوَاصَارْضْ ذڭْ ڒغْڒبْ.“\qt* \x ◘ \xo 15:‏54 \xt إِشا. 25‏:‏8. \x*   
\b  
\m
\v 55 \qt ”\+tl أَ\+tl* ڒْموْثْ، مَانِي إِدْجَا ؤُسنَّانْ نّمْ؟\qt*  
\m \qt أَ ڒَاخَارْثْ، مَانِي إِدْجَا ڒغْڒبْ نّمْ؟“\qt* \x ◘ \xo 15:‏55 \xt حُوش. 13‏:‏14؛ عبر. 2‏:‏14. \x*   
\b  
\m
\v 56 أَقَا أَسنَّانْ ن ڒْموْثْ ذ دّنْبْ، ؤُشَا جّهْذْ ن دّنْبْ أَقَا-ت ذ شَّارِيعَا.  
\v 57 مَاشَا أَقَاذِي إِ أَربِّي، ونِّي ذ أَنغْ إِوْشِينْ ڒغْڒبْ س سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ. \x ◘ \xo 15:‏57 \xt 1 يُوح. 5‏:‏5. \x*   
\m
\v 58 س ؤُيَا، \add أَ\add* أَيْثْمَا إِعِيزّنْ، بدّمْ نِيشَانْ ؤُ بْڒَا أَنْهزِّي، أَرْنِيمْ ڒبْذَا ذِي ڒْخذْمثْ ن سِيذِي س ؤُفيّضْ، أَمْ ثسّْنمْ بلِّي ڒْخذْمثْ نْومْ وَارْ ثدْجِي بَاطڒْ ذِي سِيذِي.   
\b  
\b  
\m  
\c 16
\s1 أَسْمُونِي ن صّْذَاقِي إِ إِمْقدَّاسنْ ذِي ؤُرْشَالِيمْ  
\m
\v 1 زِي جِّيهثْ ن وسْمُونِي \add ن صّْذَاقِي\add* إِ إِمْقدَّاسنْ، ڭّمْ كنِّيوْ عَاوذْ أَمْ مَامّشْ ضبّْرغْ إِ-ت-إِ-د ذِي ثْمسْمُونِينْ ن ڭَالَاطِييَا.  
\v 2 كُوڒْ \add أَسّْ\add* أَمزْوَارْ ن سِّيمَانَا كُوڒْ إِجّنْ زَّايْومْ أَذْ إِحُوزْ شَا ن ثسْغَارْثْ ذِي ثَادَّارْثْ نّسْ ؤُشَا أَذْ ت إِخمّڒْ عْلَاحْسَابْ مَامّشْ إِوسّعْ، حِيمَا، خْمِي د غَا أَوْضغْ، وَارْ إِبذِّي عَاذْ ڒخْذنِّي وسْمُونِي \add ن صّْذَاقِي\add*. \x ◘ \xo 16:‏2 \xt ڒخ. 11‏:‏29؛ 2 كُور. 8‏:‏4؛ 9‏:‏1. \x*  
\v 3 ؤُشَا خْمِي د غَا أَوْضغْ، أَذْ سّكّغْ إِنِّي إِ غَا ثْفَارْزمْ كنِّيوْ أَكْ-ذ ثبْرَاثْ، حِيمَا أَذْ أَوْينْ ثَاشْرِيمثْ \add ن صّْذَاقِي\add* نْومْ غَارْ ؤُرْشَالِيمْ.  
\v 4 ؤُشَا مَاڒَا ثُوغَا إِشُووَّارْ أَذْ رَاحغْ نشّْ عَاوذْ \add ذِينِّي\add*، خنِّي أَذْ كَّارنْ أَذْ رَاحنْ أَكِيذِي.   
\m
\v 5 أَذْ غَارْومْ د-أَسغْ خْمِي د غَا كّغْ خْ مَاكِيذُونِييَا. مِينْزِي أَذْ د-كّغْ خْ وبْرِيذْ ن مَاكِيذُونِييَا، \x ◘ \xo 16:‏5 \xt 2 كُور. 1‏:‏15. \x*  
\v 6 ؤُشَا مَاڒَا إِزمَّارْ أَذْ قِّيمغْ أَكِيذْومْ نِيغْ أَذْ سّعْذُوغْ ڒْمشْثَا أَكِيذْومْ، حِيمَا خنِّي كنِّيوْ ثْزمَّارمْ أَذْ أَيِي ثسّْقبّْضمْ مَانِي غَا رَاحغْ.  
\v 7 مِينْزِي وَارْ خْسغْ أَذْ كنِّيوْ ژَترغْ ڒخُّو أَمْ د خَاومْ إِ غَا كّغْ أَبْرِيذْ وَاهَا، مِينْزِي سِّيثِيمغْ أَذْ قِّيمغْ أَكِيذْومْ شَا ن ڒْوقْثْ، مَاڒَا إِسْمحْ سِيذِي إِنُو.  
\v 8 مَاشَا أَذْ قِّيمغْ عَاذْ ذِي أَفَاسُوسْ أَڒْ أَسّْ ن ڒْعِيذْ ن خمْسِينْ ن وُوسَّانْ.  
\v 9 مِينْزِي أَقَا ثنُّورْزمْ أَيِي-د ثوَّارْثْ ثَامقّْرَانْثْ، \add مَاشَا\add* أَقَا ذِينْ إِجّْ ن ؤُبَارُّو ن ڒْعذْيَانْ.   
\b  
\m  
\s1 ثَانڭَّارُوثْ ذ ؤُسدْجمْ  
\m
\v 10 مَاڒَا يِيوضْ-د ثِيمُوثِييُو غَارْومْ، حْضَامْ مَاحنْذْ إِزمَّارْ أَذْ ذِينْ يِيڒِي جَارْ أَومْ بْڒَا ثِيڭّْوُوذِي، مِينْزِي نتَّا إِتّڭّْ ڒْخذْمثْ ن سِيذِي أَمْ نشّْ.  
\v 11 س ؤُيَا ؤُڒَا ذ إِجّنْ أَذْ ث إِسّحْقَارْ، مَاشَا قبّْضمْ ث ذِي ڒهْنَا، حِيمَا أَذْ غَارِي د-يَاسْ، مِينْزِي نشّْ تّْرَاجِيغْ ث أَكْ-ذ وَاوْمَاثنْ.   
\m
\v 12 زِي جِّيهثْ ن ثَاوْمَاثْ أَپُولُّوسْ، \add أَ\add* أَوْمَاثنْ إِنُو، أَقَا زَاوْڭغْ ث أَطَّاسْ، حِيمَا أَذْ غَارْومْ د-يَاسْ أَكْ-ذ وَاوْمَاثنْ، مَاشَا نتَّا ثُوغَا وَارْ إِعوّڒْ أَذْ د-يَاسْ ڒخُّو، مَاشَا أَذْ د-يَاسْ خْمِي ذ أَسْ إِ غَا إِسَارّحْ ڒْوقْثْ.   
\m
\v 13 حْضَامْ، بدّمْ نِيشَانْ ذِي لْ-إِيمَانْ، حزْممْ س ثرْيَاسْثْ، إِڒِيمْ ثْمحْضمْ.   
\m
\v 14 جّمْ مَارَّا مِينْ ثتّڭّمْ أَذْ يِيڒِي س ثَايْرِي.   
\m
\v 15 تّْزَاوْڭغْ كنِّيوْ، \add أَ\add* أَيْثْمَا، زِي جِّيهثْ ن ثْوَاشُونْثْ ن سْثِيفَانُوسْ، مَاغَارْ ثسّْنمْ أَقَا أَثنْ ذ \add صَّابثْ\add* ثَامزْوَارُوثْ ن أَخَايَا، ؤُ نِيثْنِي طوّْعنْ إِخفْ نْسنْ إِ ثْسخَّارْثْ ذِي طّْوعْ ن إِمْقدَّاسنْ،  
\v 16 أَقَا ڭّمْ إِخفْ نْومْ سَاذُو ؤُفُوسْ ن يِينِّي أَمْ نِيثْنِي ؤُشَا سَاذُو كُوڒْ إِجّنْ إِ إِخدّْمنْ أَكِيذْنغْ ؤُ إِ ذ \add أَنغْ\add* إِتّْعَاوَاننْ.   
\m
\v 17 أَقَا فَارْحغْ س ثْوَاسِيثْ ن سْثِيفَانُوسْ ذ فُورْثُونَاثُوسْ ذ أَخَايِيكُوسْ، مِينْزِي نِيثْنِي كمّْڒنْ مِينْ ذ أَيِي إِتّْخصَّانْ ذَايْومْ،  
\v 18 س مِينْزِي نِيثْنِي سَّاريّْحنْ أَرُّوحْ إِنُو ذ ونِّي نْومْ. وقَّارمْ \add إِرْيَازنْ\add* أَمْ يِينَا.   
\b  
\m
\v 19 مَارَّا ثِيمسْمُونِينْ ن أَسِييَا تّْسدْجَامنْثْ-إِ-د خَاومْ س ڒهْنَا.  
\m أَكْوِيلَا ذ بْرِيسْكِيلَّا أَكْ-ذ ثْمسْمُونْثْ إِ إِدْجَانْ ذِي ثَادَّارْثْ نْسنْ تّْسدْجَامنْ-د خَاومْ س ڒهْنَا أَطَّاسْ ذِي سِيذِيثْنغْ.   
\m
\v 20 تّْسدْجَامنْ-د خَاومْ مَارَّا أَوْمَاثنْ نّغْ س ڒهْنَا.  
\m تّْسدْجَاممْ-د خْ وَايَاوْيَا س ڒهْنَا س ؤُسُوذمْ إِقدّْسنْ. \x ◘ \xo 16:‏20 \xt رُوم. 16‏:‏16؛ 2 كُور. 13‏:‏12؛ 1 تس. 5‏:‏26؛ 1 بُط. 5‏:‏14. \x*   
\m
\v 21 إِجّْ ن سْڒَامْ إِ تَّارِيغْ س ؤُفُوسْ إِنُو، زِي بُولُوسْ.   
\b  
\m
\v 22 مَاڒَا حذْ وَارْ إِتّخْسْ سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ، أَذْ يِيڒِي ذ أَمنْعُوڒْ. سِيذِيثْنغْ أَقَا يُوسَا-د! \f ◼ \fr 16:‏22 \ft \+bd ’مَارَانْ-أَثَا‘\+bd* - أَوَاڒنْ-أَ خْسنْ أَذْ إِنِينْ: ’أَ سِيذِيثْنغْ، أَسْ-د‘ نِيغْ ’سِيذِيثْنغْ أَقَا يُوسَا-د!‘\f*  
\v 23 أَرْضَا ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ أَذْ يِيڒِي أَكِيذْومْ.  
\v 24 ثَايْرِي إِنُو أَقَا-ت أَكِيذْومْ مَارَّا ذِي لْمَاسِيحْ يَاسُوع. أَمِينْ.   