\id HEB - Shipibo NT with OT portions -Peru 2011 (DBL -2013)
\h HEBREOS
\toc1 Hebreo joniboki kirika wishaa
\toc2 Hebreos
\toc3 Hb.
\mt1 HEBREOS
\mt2 Hebreo joniboki kirika wishaa
\c 1
\s1 Jawen Bake meranoax Dios yoyo ika
\p 
\v 1 Moatianbora, ichaakin itan, meskóakinbo, *profetabo meranxon non rekenbo Diossen yoyo aka iki,
\p 
\v 2 ikaxbi rama netebaonra, jawen Bake meranxonbiribi noa yoyo ake. Já meranxonra, jatíbi nete jonia iki, jatian jara jatíbi jawékinin Ibo imaa iki.
\p 
\v 3 Ja riki ja Diossen penebires koshi noa jan oinmai, jawen ikábo Dios jisábishaman ixon, jatian janra jawen atipana join, jatíbi jawékibo koshiake. Jainoaxa jatíbi non ochabo noa soaxona pekáo, naikan kaax, Diossen mekayao yakata iki.
\s1 Diossen Bakera ángelbo xewina iki
\p 
\v 4 Jaskataxa ángelbo xewina baneta iki, jabaon jane xewina kikin janeribi bia ikax.
\p 
\v 5 Jawetianbira Diossen westíora ángelbi yoiama iki:
\q1 “Mia riki nokon Bake
\q1 ramara ea min Papa iki”, akin.
\p 
\v 6 Jatian jawen reken Bakebiribi nato neten raanaxa, Dios neskata iki:
\q1 “Jatíbi ja nokon ángelbaon rabibakanon”, iki.
\p 
\v 7 Jatian ja ángelbo yoii ikai Dios neskati:
\q1 “Nokon ángelbo riki niwe keskabores
\q1 jatian nokon yonotibo riki chii tiritai keskábores”, iki.\f + \fr 1:7 \ft Sal. 104.4\f*
\p 
\v 8 Ikaxbi jawen Bakebiribi yoii ikai neskati:
\q1 “Jatíbitian Apo riki mia Diossé,
\q1 jato ikinkinra, atibi keskáakin jato ikinnai.
\p 
\v 9 Jakon jawékibores noixonra, jakonma jawékibo min omisa iki,
\q1 jakopíra mia Diossen katota iki, min Dios ixon,
\q1 jaskáaxonra, ja miibetan ikábo bebonbires, raro mia imaa iki”, iki.\f + \fr 1:9 \ft Sal. 45.6-7\f*
\p 
\v 10 Jainoax iribai neskati: “Ibó, peokootiainxonbira, jaki mai koshitibo min aká iki.
\q1 Ja naibo riki min mekemanbishaman,
\q1 min aká teebo.
\q1 
\v 11 Jatíbi jabora keyónoxiki,
\q1 ikaxbi miabiribira, jatíbitian jaai keyóyamai,
\q1 jatíbi jabora chopa ikai keskati payónoxiki,
\q1 
\v 12 chopa atinra min katónoxiki,
\q1 wetsa chopa sawetininra min anoxiki,
\q1 ikaxbi miara miabi iti iki, min jatira jain keyota yamake”, iki.\f + \fr 1:12 \ft Sal. 102.25\f*
\p 
\v 13 Jawetianbira Diossen westíora ángelbi yoiama iki:
\q1 “Nokon mekayao yakáwe, ja min rawibo, en mia
\q1 jan penítiaxonai kaman”, akin.\f + \fr 1:13 \ft Sal. 110.1\f*
\p 
\v 14 Jatíbi ángelbo riki shinanres, ja kishpinmeetibo akinni teekanon ixon, jato Diossen raanabo.
\c 2
\s1 Jan kishpinmeeti joi yoikaata
\p 
\v 1 Jaskara kopí riki, ja non ninkata joi non kikinhakin onanna iti, noa wetsaorinaketian.
\p 
\v 2 Ja ángelbaon yoiai joibora, iká iki kikin koshi, jatianra ja senenhayamai yoitimatax ochaabo atixonbi, jato Diossen castigana iki.
\p 
\v 3 ¿Jatian jawekeskataxmein noa kenekaati iki, ja kishpintinin ratéyamaa ikax? Nato kishpinti joira non Ibonpari yoikin peoa iki, japekáora ja ninkatabaonbiribi tekikin noa yoikana iki.
\p 
\v 4 Jainxonra Diossenribi noa onanmaa iki, ja oinxon onanti, itan icha ratéti jawékiboribi axon, jainxon jan shinanna keskáakin, jawen tee ati onan shinanbo jawen jakon Shinan meranxon, noa menipakeanan.
\s1 Jesucristo, jawen wetsabo keská iká
\p 
\v 5 Diossenra ja non yoii iitai bená nete nokóketian, ángelbo koshi iti jato imaama iki.
\p 
\v 6 Jaskara ikenra, Wishá meran ikai neskati:
\q1 “¿Jawerin westíora joni min já shinanti?
\q1 ¿Jawerin ja jonin bake min jairaakin shinanti?
\q1 
\v 7 Basimashokores ángelbo namanbires itira min imaa iki,
\q1 jaskara ikenbira, kikinni ninkakaatai, itan aniakin oinkanai min imaa iki,
\q1 
\v 8 jatíbi jawékibora min jaki jenea iki”, iki.\f + \fr 2:8 \ft Sal. 8.4\f*
\m Jaskáakin jatíbi jawéki jaki jenea ikaxa, jawe jawékibi jaki jeneama yamake, jaskara ikenbira, jatíbishaman jaki jenekaata non oinyamapariai.
\p 
\v 9 Ikaxbira, non oinnai ja Jesús, jawetio basires ángelbo namanbires iti Diossen imani, kikinni ninkakaatai itan ani joni iká, onitsapikaini mawata ikax. Noa noixonra Diossen jaskáakin mawámaa iki, já jaskataton jatikaxbi noa jakonkanon ixon.
\p 
\v 10 Jatíbi jawékira Diossen aká ikax, jawenabires iki, jara keenai jatíbi jawen bakebo jawen pené netenko jabé jaai bokantinin. Jaskara kopíra, Diossen aká iki, jan jato kishpinmati Jesucristo, masábires tenemataanan jakonman senena imakin.
\p 
\v 11 Jatíbi ja Diossenabo, itan jan jato Diossena imaiyabira, noa jatikaxbi westíora papayabicho iki. Jaskaranixa ja Jesús, nokon wetsabo riki mato akin jato atin rabinyamai.
\p 
\v 12 Jaskara yoiira ikai Wishá meran neskati:
\q1 “Miikiriakinra nokon wetsabo en jato yoinoxiki,
\q1 jainoax tsinkíkana xaranmeaxbora, mia rabii ea bewanoxiki”, iki.\f + \fr 2:12 \ft Sal. 22.22\f*
\p 
\v 13 Jainoax iribai neskati:
\q1 “Jakira ea koshiai”, iki.\f + \fr 2:13 \ft Is. 8.17\f*
\m Jainoax iribai:
\q1 “Eara neno iki, ja Diossen ea menia bakebo betan”, iki.\f + \fr 2:13 \ft Is. 8.18\f*
\p 
\v 14 Ja jonibaon bakeabo riki, ja namibi itan ja jimibi, jaskáribiira joni ikax, Jesús namia itan jimiaribi iká iki, jaskaranixparira, já mawáti atipana iki, jaskáaxon ja retemisti koshia janharesnox, ja iki ja *Satanás.
\p 
\v 15 Neskáaxonra xabáa iki, jatíbi ja mawátiki rakékin, jatíbitian *Satanás iboamaax jakana ikábo.
\p 
\v 16 Jaskarainra onanti iki, ja ángelbo akinox nato neten Cristo joáma, jara joá iki, ja Abrahamman chiní rarebo jato akinti kopí.
\p 
\v 17 Jatian jaskáakin jato akinti kopíra, jawen wetsabo keskáribi itoshia iki, jaskatax jawen atibo senenhai, itan noibataanan, akinmis Diossen tee axonai *Sacerdotebaon Koshi inox, itan jato kopi mawáxon jonibaon ocha akábo shinanxonyamanox.
\p 
\v 18 Jatian jaribi jaskati tanakaatibo onitsapita ixonra, rama ja jaskati tanakaataiboribi, jan jato akinti atipanke.
\c 3
\s1 Jesús riki Moisés xewina
\p 
\v 1 Jaskara iken, nokon wetsabó, mato riki Diossen jonibo, jawenabo inon ixon mato katota ixonkaya, raana joni itan *Sacerdotebaon Koshiakin, ja Cristo Jesús shinankanwe, já ikonhaabo ixonra jaskara non jato yoiai.
\p 
\v 2 Jesussenra jan ati ikábo, Dios senenhaxona iki, jaskara tee ati ja imaa ixon, ja Diossen xobonko teekin, Moiséssen aní keskáakinribi.
\p 
\v 3 Ikaxbi Jesúskayara, ja Moisés akai bebonbires aniakin rabikanti imaa iki, ja xobo ayamakinbi, jan xoboaka jonires, kikinhakin rabionkanai keskáakin.
\p 
\v 4 Jatíbi xobo riki westíora jonin aká, ikaxbi jatíbi nato neten já jawékibo riki, Diossen akábobires.
\p 
\v 5 Moisésra iká iki, westíora yonoti ikax, ja Diossen xobonko teekin ja atibo senenhaai, jatian jawen teera iká iki, ja ramakaya Diossen yoiti jawékibo ikonkon onanna ixon, jato onanmati.
\p 
\v 6 Ikaxbi Cristo riki, Diossen Bake ikax, ja Diossen xobomea teebo akin, ja atibo akonkin senenhai, ja iki noabo yoii iká, já ikonhakin jeneyamai raro shinanyaxon, ja bii kati jawékinin manatabo ikax.
\s1 Diossen yoiabo ninkáxonti
\p 
\v 7 Jaskara kopíra ikai, Wishá meran Diossen jakon Shinan neskati:
\q1 “Rama netebi mato Diossen yoiai ninkáxon,
\q1 
\v 8 maton jointibo chorishayamakanwe,
\q1 jaskati yoitimakin akana iki, jain joni jayamainkoxon Dios tanakin.
\q1 
\v 9 Jainxonra ja chosko chonka baritia,
\q1 en tee akaibo oinxonbi, maton rekenbaon ea
\q1 tanakana iki.
\q1 
\v 10 Jaskara kopíra, jatoki sináxon en jato neskaa iki:
\q1 ‘Jaton shinan meran benota keskábo ixonra, en jato eseabo ninkákashamakanai’, akin.
\q1 
\v 11 Jaskara kopíra, ikonbiresi sinatax ea ikoni neskata iki:
\q1 Matora jawetianbi jikitima iki, ja en mato jain tantimati mainko”, iki.
\p 
\v 12 Jaskarabo, iken, koirameekanwe nokon wetsabo, jakonmabo ochati jointiabores ikaxa, ikonhakashamai ja jiria Diossibakeax, mato ochókanake.
\p 
\v 13 Jaskáyamaikaya, netetiibi wetsabo betan eseanani, shinan koshikanwe, “ja rama netebi”, iki iká joi Wishá meran japariketian, jaskatax mato tsoabi ochan paranxon imaa, shinan jakonmaati yoitimakantima kopí.
\p 
\v 14 Noabora moa Cristo betan iki, ikaxbira já ikonhakin peonontian iní keskatibi senenai kaman, noa jaki koshii jenéti yamake.
\p 
\v 15 Jaskara yoiira ikai Wishá meran neskati:
\q1 “Rama netebi mato Diossen yoiai ninkaxon, maton jointibo chorishayamakanwe ja moatian yoitimatax ikáni keskatiribi”, iki.
\p 
\v 16 ¿Jatian tsoaboki ikana iki, ja Diossen jato yoiai ninkataxbi jaki yoitimati? Jatíbi ja Egipto mainmea jato Moiséssen pikonibora ikana iki, jaskati yoitimai.
\p 
\v 17 ¿Jatian tsoabokiribiki iká iki, ja chosko chonka baritia Dios sinati? Ja ochax, jain joni jayamainkoniax mawánibokira iká iki.
\p 
\v 18 ¿Jatian tsoaboki ikonkon Diossen yoia iki, jain jato tantimati mainko jikimatima? Jatíbi ja jaki yoitimatabora aká iki.
\p 
\v 19 Jatianra ikonkon non oinnai, ja Dios ikonhayamakana kopí, ja main jikiamakani.
\c 4
\p 
\v 1 Jaskara iken, jabé tantii kati noa Diossen yoini japariketian, koiranmeenon akanwe, mato jatíribibora jabé iamanake.
\p 
\v 2 Jabaon akáni keskáakinribira, nonribi ja jakon joi yoikanai ninkata iki, ikaxbi ja ninkákanatonra, jawe jato akinyamaa iki, ja joi ikonhayamakanai kopí.
\p 
\v 3 Ikaxbi ja ikonhaax, noa jaki koshiabora, jain tantiti netenko noa jikinoxikanai. Ja yoii iki iki Dios neskati:
\q1 “Eara sinatax ikonkon neskata iki:
\q1 matora jawetianbi jikitima iki, ja en mato jain tantimatinko”, iki.
\m Ikon riki, ja nato nete jonianontianbi, jawen tee moa Diossen senenhaa iká,
\p 
\v 4 jatian wetsankora ikai, ja kanchis nete yoii Wishá meran neskati:
\q1 “Ja kanchis nete itinra, jatíbi jawen teebo senenhayontaanan, Dios tantia iki”, iki.\f + \fr 4:4 \ft Gn. 2.2\f*
\p 
\v 5 Jatianra nato Wishá meran jakiribi yoiribiai:
\q1 “Matora jawetianbi jikitima iki, ja en mato tantimati mainko”, iki.
\p 
\v 6 Ikaxbira maxkáparike, ja jain tantitiain jatíribibo weíkanti. Jatian ja jatonpari ja jakon joi ninkatabora jikiamakana iki, jatonbinix yoitimatax.
\p 
\v 7 Jaskara kopíra, jakiribi noa Diossen westíora nete meniribia iki, ja riki “rama netebi”, jara moa basi winóni pekáopari, Davidkan yoia iki, ja Wishá meran non yoiwana keskáakin:
\q1 “Rama netebi mato Diossen yoiai ninkáxon, maton jointibo chorishayamakanwe”, akin.
\p 
\v 8 Jatian ja *israelbo Josuékan jato tantimani iketianra, wetsa netebo moa Diossen, yoiamakeana iki,
\p 
\v 9 Jaskara ikenra ja Diossen jonibo, jakonax jain tantii bokantipari jareske,
\p 
\v 10 jaweratoboki ja Diossen noa tantimati ikainko jikiai, jabora jawen teeainoax moa tantiai, jawen teebo ayontaanan, Dios tantini keskatiribi.
\p 
\v 11 Ja jain noa Diossen tantimati ikainko jikinoxkaya, koshinon akanwe, jaskatax ja ikonhayamaibo ikáni keskatiribi, tsoabi ikantima kopí.
\p 
\v 12 Ja Diossen joi riki, jan jatia itan atipana koshia, ja riki, okenbekonbi kenshoya espada winoa kikinbires xatemis, jara jikiai, ja kaya meran itan shinan rebo ikain kamanbi, jainoax ja chichó joni meran iká jawékibo kamanbi. Jainxonra, ja non shinanbo itan non ati shinannaibo jishtiakai.
\p 
\v 13 Jatíbi ja Diossen joniani jawékibora, já bebon joné iti atipanyamake, jaweara jatíbi jishtibires iki. Jara anoxiki, jatíbi ja non akábo non yoipakekin.
\s1 Jesús iki *Sacerdotebaon Koshi
\p 
\v 14 Ja Diossen Bake Jesús riki, non ani *Sacerdotebaon Koshi, jara naikan kaa iki. Jaskara kopíra, ja ikonhaa ikax, jaki koshii noa jeneti yamake.
\p 
\v 15 Ja non *Sacerdotebaon Koshinra, non atipanyamaa onanxon, noa akinti atipanke, ja noa ikai keskatiribi jápari tanakaatibo winota ixon, jaskarabo winotibira ja jawetianbi ochayamaa iki.
\p 
\v 16 Jaskara iken, noa jan noia Dioskaya rakétanma benanon akanwe, jaskáaxon ja noa iorai maxkatatianshaman, jawen jakon shinanman noa jan akinti kopí.
\c 5
\p 
\v 1 Jatíbi ja *sacerdotebaon koshibo riki, jonibo xaranmea katóxon, imakanabo. Jabo riki janekana, jato kopi Dios betan yoyo iti itan ja Dios menikanaibo jato boxonti, jainoax jaton ocha kopi yoina jato retexonti.
\p 
\v 2 Jatian ja *sacerdoteboribi, shinan koshimaboribi ixonra, jabaon ja onanmashokobo itan ja benota keská ikax ochaiboribi, noibataanan, jato akinti atipanke.
\p 
\v 3 Jatian jaskara shinan koshimabo ikax ochai ixonra, jaton ocha kopibi itan ja jonibaon ochabo kopíribi jabaon Dios yoina retexonti jake.
\p 
\v 4 Tsoabira, nato ani teeain janbix jikiamai, ja Diossen kenaabores riki, ja nato ani tee biaibo, ja Aarónra aká iki, jaskáaxon janekin.
\p 
\v 5 Jaskáribira, Cristo janbixbi ja *Sacerdotebaon Koshi iti janekaayama iki, Diossenbira aká iki, ja ani tee menikin, jara iká iki neskati:
\q1 “Mia riki nokon bake,
\q1 rama riki ea min Papa”, iki.
\p 
\v 6 Jainoax Wishá meranribi ikai neskati:
\q1 “Mia riki jatíbitian *Sacerdote, ja Melquisedec iní betan senenribi”, iki.
\p 
\v 7 Cristonra nato neten inontian, koshin sai akin, itan winiananbibo, Dios yokákin orana iki, ja mawátiainoa janres já xabáati atipana koshia iketian; jaskáketianra, jawen joi senenhaxonai iketian, jan yokatabo Diossen ninkáxona iki.
\p 
\v 8 Jatian jakaya Diossen Bake ixonbira, onitsapixon Criston onanna iki, jawekeskarin ja joi senenhai iti iki ixon,
\p 
\v 9 jatian jaskáakin jatíbi senenhaxa, jatíbi jawen joi senenhaxonaibo, jato jan kishpinmai itoshia iki.
\p 
\v 10 Jatianra Diossen janea iki *Sacerdotebaon Koshi iti, ja Melquisedec iní betan senenribi.
\s1 Diossen joinko bebonti yoii iká
\p 
\v 11 Neskara jawékibo non mato yoitira ichapari jake, ikaxbira onantishamahakin non mato yoitibo atikoma iki, ninkáxonbi maton ishton onanti atipanyamai kopí.
\p 
\v 12 Moa basi Diossen joi akaibo ikax, wetsabo jato axeati onanbo ititianbi riki, ja peokin onanti Diossen joibo jakiribi yoikantinpari mato keeni. Ja bake keskáshokobo ixon, chorish jawékiayamakin, lecheshokores jawékiai keskábopari iki mato.
\p 
\v 13 Jatian ja lecheshokores jawékiaibo riki, xoma akai bake keskabores, atibi keskákin shinanti onanmabo.
\p 
\v 14 Ja chorish jawékiatibora yosibaona iki, moa pontéakin shinanti onanbaona. Jabaonra moa axeabo ixon, onannai ja jakon itan jakonma jawékibo.
\c 6
\p 
\v 1 Jaskara iken, bebon chibanresnon akanwe, ja Diossen joi non akonkin onannai kaman. Ja peokin onanti Cristo kiriti iká joibora non benaakin yoiamai. Ja reken non onannabo iki, jan noa mawátiain boti jawékibo moa akonkin jeneti, jainoax Dios ikonhaax jaki koshiti,
\p 
\v 2 jaskatax bautizameti; ja joi akaibo mamepasxon jatoki oranti; ja mawatabo jakiribi jiriti; jainoax jatíbitian jaskara itiakin noa Diossen yoiti nete.
\p 
\v 3 Nato jawékibora non jato onanmaboresti jake, Dios keenketian.
\p 
\v 4 Kikinshaman itikoma riki, ja Diossen joi ikonhaax iitibi, Dioski ochókanabaona. Jabora ja naikanmea jato Diossen menia biax, raroshaman ikanabo iki, itan ja Diossen jakon Shinan moa bia ikanaboribi iki,
\p 
\v 5 jainxon ja Diossen jakon joi moa ninkata ikanaboribi iki, itan ja bená netenko jawen atipana koshiabi Dios iki kaai, moa onanna ikáboribi iki.
\p 
\v 6 Jabora moa Dios ikonhakin jenea ikax, jakiribi shinanmeetanan, banéti atipanyamakanke. Jabora ja icha jonibo bebonxon jaki shirokin, jakiribi ja Diossen Bake korosen axon tasai iikanai.
\p 
\v 7 Jarake maibo, jaki oi kexto manaitian, kikinhakin tsitsiai, jatian ja wain teetaibo jato jakonshaman bimi imaxonketianra, Diossen jakonhai,
\p 
\v 8 ikaxbi ja xobiabi moxares xoxomai maira, jakonma iki. Jara moa Diossen jakonmataanan, chiikan menoxon keyotires iki.
\p 
\v 9 Ikaxbi neskáakinbo mato yoixonbira, non onanke, nokon wetsabó, matora moa kishpinmeetabo ikax, kikin jakonhain ikanai ixon.
\p 
\v 10 Dios iki pontébicho shinanya, jara ja maton aká jawékibaon, itan já noixon jawen jonibo maton jato akinnaton jainoax ramakamanbi jaskáakin maton akinni iitaibaon shinanbenoyamai.
\p 
\v 11 Ikaxbi non mato keenxonai riki, ja mato westíorabokaya, nete senenai kamanbi, jaskara shinanyabi mato ikanti, ja jaskaraton manatax itai maton bii kaai kaman,
\p 
\v 12 Noara keenyamai, mato chikish itin, jaskáyamaikaya ja Dios ikonhaax jaki koshiabo ixon, jatsanyamakin, ja jatíbitian jayáti jato Diossen meniti yoia bii kaai, mawakanwe.
\s1 Ja senenhabekonti joi Diossen senenhai
\p 
\v 13 Ja senenhabekonti joi Diossen Abraham yoinontianra, já xewina wetsa joni, ja bebonmeax yoyo iti yamaketian, janbix yoikaata iki, jan yoiabo akonkin senenhanox.
\p 
\v 14 Jatian neskáakin yoia iki: “Enra akonbireskin mia jakon imati iki, jainxonra min rareboboribi kikinbiresakin en mia kaimaxonoxiki”, akin.\f + \fr 6:14 \ft Gn. 22.17\f*
\p 
\v 15 Jaskáakin Diossen yoia jatsanyamakin manaaxa, ja Diossen jaskara imanoxon yoia keskáshaman, Abraham iká iki.
\p 
\v 16 Jonibaonra akai, jato yoyo ika joi ikon inon ixon, jato xewina jonipari janekin, jatian jaskáakin jato yoiakanara, moa tsonbi jawe yoiti yamai, akonkin senenhati iketian.
\p 
\v 17 Diossenra, ja jatíbitian jayáti jato meninoxon yoini bikantibo, onantiakin jato oinmakasa iki, já yoyo ika joibo wetsaayamakin. Jaskara kopira, ja jato menitibo ikon inon ixon, janbi jato yoia iki.
\p 
\v 18 Nato jawékibaonra Dios jansoti atipanyamake, jan noa meniti yoiabo, itan akonkin senenhanox já yoyo ikabora wetsaressibiati atipanyamake, jaskaratonra ja noa koirannon ixon non Dios benaabo, itan jaki koshiax noa jaon manatabo, koshi itan shinan jakonshamanres noa imai.
\p 
\v 19 Ja nato manátininra jaoraobi taxkemayamakin, akonkin non kaya koiranna iki, taxkemayamakin *anclanin wapóro tewanai keskáakin. Noa jan manatara, ja Diossen xobo meran iká chopa panaabi bebanbaini, naikan nokota iki,\fig Jan Diossen chité nachitea chopa bochikiax namani noshita.|src="LB00265b.TIF" size="span" loc="Hebreos 6.19" ref="Hebreos 6:19"\fig*
\p 
\v 20 ja Diossiba nokóti baira moa noa Jesussen kepenxona iki. Jaskataxa, ja Melquisedec iní betan senenribi, jatíbitian *Sacerdotebaon Koshi iki jikia iki.
\c 7
\s1 Jesús betan Melquisedec
\p 
\v 1 Nato Melquisedec iká iki, Salemhainoa apo, itan ja ani Diossen *sacerdote. Jatian ja wetsa apobo betan reteanankin jatoaresax, Abraham joáitianra, Melquisedec kaa iki ja bechii, jainxonra jatíbinin jakon itin keenxoni, jaki jakoni yoyo ika iki.
\p 
\v 2 Jatianra Abrahamman, ja reteanantiainxon jato bichina jawékibo, chonkankonia westíorabo Melquisedec menia iki. Ja Melquisedec iki iká riki, rekenpari “atibi keskáakin jato ikinnai apo”, iki iká. Jatian Salemhainoa apo iki iká riki “xabashaman imamis apo”, iki iká.
\p 
\v 3 Ikaxbira tsonbi onanyamake tsoaboki iká iki, jawen anibo itan jawen reken rarebobo ixon, jainoax, jatian pikota itan jatian mawataribi, tsonbi onanyamake. Jaskara Diossen Bake keskaribi ikaxa, járibi jatíbitian *sacerdote iki.
\p 
\v 4 Jaskara iken rama oinkanwe, ja Melquisedec iká iki kikin joni, jaskara kopíra, ja non reken papashoko Abrahamman ja apobo betan reteananxon jato bichinabo, chonkankonia westíorabo já menia iki.
\p 
\v 5 Jatian ja Moiséssen esekan yoiaira iká iki, ja Levikan rarebobo sacerdote ikábaonres, ja jemamea jonibo jatíbi jaton bia jawékibo, chonkankonia westíorabo jato yokati, jatoribikaya Abrahamman rarebobo ikax jaton wetsabo ikenbi.
\p 
\v 6 Ikaxbi Melquisedeckanra, Levikan rarebo ixonmabi, chonkankonia westíorabo Abrahamman menia bia iki, jatianra jakon itin keenxoni, jaki jakoni yoyo ika iki. Ja Abrahammanra aká iki ja Diossen jaskara meniti yoiabo bikin.
\p 
\v 7 Jatian nonra onanke, ja jakon itin keenxoni jatoki jakoni yoyo ikaibo, ja jaki jakoni yoyo ikai joni xewinabo.
\p 
\v 8 Ja nato netenxon, chonkankonia Westíorabo menikana biaibo riki, mawatai jonibo, jaskara ikenbira, Wishá meran yoiai, ja chonkankonia westíorabo menikana bia ikaxbi, Melquisedec japaria.
\p 
\v 9 Jatianra non yoiti atipanke, ja Levikan rarebobo ikax sacerdote ixon, ja rama chonkankonia westíorabo menikana bii iitaibaonribira, Abraham meranxon, chonkankonia westíorabo Melquisedec menikana iki ixon.
\p 
\v 10 Ja Abraham reteanantanax joaitian, ja bechii Melquisedec kanontianra, ja Abrahamman chiní bakebo joniamapari ikaxbi, moa ja meran ikana iki.
\p 
\v 11 Diossenra *Israel jonibo ja sacerdote *Levitabo meranxon, jawen esé jato onanmaa iki, jatian ja nato sacerdotebaon jonibo jakon imati atipana iketianra, moa Aarónman rareboainoax, iamai ja Melquisedec iní keskaribi, wetsa sacerdote joti maxkáyamakeana iki.
\p 
\v 12 Jatian moa wetsabo sacerdote iketianra, eséboribi moa wetsaresibi kaai.
\p 
\v 13 Jatian ja yoii Wishá meran ikai non Ibora, wetsa tsamá Israel jonibaon rarebo iká iki, jainoara tsoabi sacerdote ikáma iki.
\p 
\v 14 Jatíxonbira onankanke, ja non Ibo Judakan rareboibakeax pikota, jatian ja rareboibakeax sacerdote itibora, Moisés jawebi yoiamaa iki.
\p 
\v 15 Jatian jaskarainra onantibires iki, ja nato bená *sacerdote pikota Melquisedec iní keskaribi.
\p 
\v 16 Jara ja jawerato rareboibakeaki iti iki ixon, esekan yoiai keskati ikáma iki. Jara jatíbitian jati atipana koshin imaa iká iki.
\p 
\v 17 Jaskatira ikai Wishá meran já yoii Dios neskati:
\q1 “Mia riki jatíbitian sacerdote,
\q1 ja Melquisedec iní betan senenribi”, iki.\f + \fr 7:17 \ft Sal. 110.4\f*
\p 
\v 18 Jaskara ikaxa, ja moatian esé moa jawemabi, baneta iki, jawe koshiomabobi itan iresbiresa.
\p 
\v 19 Ja Moiséssen esekanra, jato jakon imati atipanyamaa iki. Jatian jawen toanra wetsa bebon jakonhira iki, noa jaon manata, janra noa Diossiba jakonhaxon nokómai.
\p 
\v 20 Jara Diossenbi imaa iki, akonkin jaskara iti yoitaanan. Jatian ja wetsa *sacerdotebora janekaakana iki, akonkin jaskara itibo yoixonmabi.
\p 
\v 21 Ikaxbi ja non Ibo itinkora, Diossenbi akonkin jaskara iti yoia iki. Jaskara yoiira ikai Wishá meran neskati:
\q1 “Ja non Ibonra akonkin jaskara iti yoia iki:
\q1 Mia riki jatíbitian sacerdote,
\q1 jatianra wetsaresibiakin moa min shinantima iki”, akin.
\p 
\v 22 Jaskarainra Jesús iki, ja jakonhira senenhabekonti bená joi Diossen nobetan aká, iorai jakon.
\p 
\v 23 Ja reken sacerdotebora ikana iki icha, mawákin moa jaton tee chibanti atipanyamaibo ikax.
\p 
\v 24 Ikaxbi Jesússa, jawetianbi mawáyamai ikax, jawen toan wetsa sacerdotebo jikiti atipanyamake.
\p 
\v 25 Jaskara kopíra, ja Dioski nokókasi jaki beaibo, jatíbitian jato jan kishpinmati atipanke, jara jatíbitian jake, jaskáaxon jato Dios yokáxonti kopí.
\p 
\v 26 Jaskara ikaxa Jesús iki, ja jaskarashaman Sacerdotebaon Koshi noa jan maxkata ikátiai. Jara ochaoma iki, jakopi jakonmanin yoikanti yama, itan jawen jakonmaomabi iki, jara ochayabo betanma iki, itan jara Diossen naikan boá iki.
\p 
\v 27 Jara wetsa *sacerdotebaon koshibo keskáma iki; jara maxkáyamake, jawen ochabo kopípari, ataanan, japekaopari ja wetsabaon ocha kopibo netetiibi, yoina retexon menotinin. Jaskáyamaikayara moa jatíbitian iká iti kopí, westíoraibicho janbix menikaatax, non ochabo kopí Jesús mawata iki.
\p 
\v 28 Ja Moiséssen esekan yoiai keskáakin, *sacerdotebaon koshi iti imakinra, ochaya jonibo janekatikanai. Ikaxbi ja esé jato menia pekáora, sacerdotebaon koshi iti, Diossen jawen Bake janea iki, jara jatíbitian jakon itiakin imaa iki.
\c 8
\s1 Jesús riki ja *Sacerdotebaon Koshi
\p 
\v 1 Ja non yoiibea bebonbires jakon riki, ja non *Sacerdotebaon Koshi naikan itina, Diossen ani yakati mekayao yakata.
\p 
\v 2 Jainoaxa teeti itai, *sacerdote keskatibi, ja ikonkon Diossen xobonkoniaxshaman, ja xobo riki non Ibonbi aká, jonibaon akáma.
\p 
\v 3 Jatíbi sacerdotebaon koshibo riki, Dios bexonkanai jawékibo jato menixonti, itan yoina retexon jato menoxonti janekanabo. Jaskara kopíra, Jesucristonaribi jati jake, ja jato Dios menixonti.
\p 
\v 4 Jatian nato mainbi ikaxa, jawekeskataxbi já sacerdote iamakeanke, nenora moa sacerdotebo jake, ja Moiséssen esekan yoiai keskáakin, Dios jawéki bexonkana jato menixonaibo.
\p 
\v 5 Ikaxbi nato sacerdotebaonra, jaton tee akanai, Diossen xobonkoxon, ja riki naikanmea Diossen xobo jisáakin aká. Ja naikanmea jisá non onanna riki, ja Moiséssen Dios xoboaxonaitian, Diossen neskáakin yoia iketian: “Ja mananmanxon en mia jaskáakin ati oinmani keskáakinshaman, jatíbi awé”, akin.
\p 
\v 6 Ikaxbi ja Sacerdotebaon Koshi iti tee Jesussen biatoninra, jato winoke, já meranxonra wetsa jakonhira bená ja senenhabekonti joi Diossen aká iki. Jara akonkin senenhati ixon, Diossen yoia jakonhira joiboki koshike.
\p 
\v 7 Ja reken Diossen jato betan senenhabekonti joi aká jatíbi jakonbires iketianra, wetsa bená senenhabekonti joi, Diossen jato betan ayamakeana iki.
\p 
\v 8 Ikaxbi jonibaon senenhayamakanai oinnax, Ibo iká iki neskati:
\q1 “Ibonra yoiai: Netera nokónoxiki, ja *Israel jonibo itan
\q1 Judá jonibo betan, en bená senenhabekonti joi ati.
\q1 
\v 9 Ja nato bená senenhabekonti joi en
\q1 akaira, ja Egipto mainmea jaton rekenbo en
\q1 metsontaanan pikonontian aní keska itima iki.
\q1 Ja en senenhabekonti aká joibo, jabaon
\q1 senenhayamaitianra aká iki, en jato jenekin, ikira ikai
\q1 ja Ibo.
\q1 
\v 10 Ja netebo moa winota pekáo, *Israel
\q1 jonibo betan, en bená senenhabekonti joi akaira
\q1 inóxiki, neskara ikira ikai non Ibo:
\q1 Nokon esébora jaton shinan meranbo en imanoxiki,
\q1 itan jaton jointi meranra en wishanoxiki.
\q1 Eara inóxiki jaton Dios, jatian jabora inóxiki nokon
\q1 jonibo.
\q1 
\v 11 Moara maxkáyamanoxiki tsonbi jabé joni, itan
\q1 jawen kaibobo non Ibo onankanon ixon jato yoiti,
\q1 jatíxonbira ea onannoxikanai, ja kikin itan kikinma
\q1 jonibaonbi.
\q1 
\v 12 Ja jakonmabo akanatonra, ea shinanbenoti iki,
\q1 jaton ocha akábora jawetianbi en jato shinanxontima iki”, ikira ikai non Ibo.\f + \fr 8:12 \ft Jer. 31.31\f*
\p 
\v 13 Ja bená senenhabekonti joi atikiriti Dios yoyo ikátoninra, ja moatian senenhabekonti joi aká, moa jawemabi imaa iki, jatian moatian ikaxa, basima maxkáke moa keyoti.
\c 9
\s1 Nato mainmea itan naikanmea Diossen xobo
\p 
\v 1 Ja reken senenhabekonti joi Diossen aká inontianra, nato mainxon Dios rabiti kopí jawen xobo meran jikinoxon, jaskara senenhatibopari jaa iki.
\p 
\v 2 Ja Dios betan nokoananti xobo iká iki, neskáakin akana. Reken iká iki, westíora nachite, ja iká iki “Dios rabiti chité”, akin akanai, jain iká iki *candelabro, itan Diosbiribi bexonkana pan jain akanai mesaribi.\f + \fr 9:2 \ft Candelabro riki, jain joé yasánti kanchis poyanya.\f*\fig Dios rabiti xobo meran iká jawékibo.|src="BK00278b.TIF" size="span" loc="Hebreos 9.2" ref="Hebreos 9:2"\fig*
\p 
\v 3 Jatian ja rabé, itin chopa nachitea pekáora iká iki, ja “Dios iká chité”, akin akanai.
\p 
\v 4 Jain iká iki westíora jainxon *incienso menoti orobires akana, itan ja senenhabekonti joi aká jan onanti imai bonanti oronbires jatiobi sikaaketana. Ja bonantiain iká iki oro akana westíora jarra, maná napokoya, jainribi iká iki, ja Aarónman kekoti jakiribi xoxoa, itan ja senenhabekonti joi aká jain wishakana tablaribi.\f + \fr 9:4 \ft Ja manára iká iki, trigo bero keska. Jara pan axon pikanai iká iki.\f*
\p 
\v 5 Jatian ja bonanti pekaten iká iki ángel querubinbo akana, jain Dios iká onanti inon ixon, jaton peibaon iká iki ja bonanti mapoa. Ikaxbi ramaparira nato jawékibo non mato onantiakin yoiti atipanyamake.
\p 
\v 6 Jatíbi neskara jawékibo moa ayonaxa chibanmai ja *sacerdotebo jikikatikanai ja reken xobo chiteain, jaskáxon Dios rabiti kopí.
\p 
\v 7 Ikaxbi ja wetsa chité ikainra, ja *sacerdotebaon koshibicho baritiatiibi westíoraibicho, jikikatitai. Kakinra yoina retexon, jawen jimi bokátikanai, jaskáxon jawen ocha kopibi itan jakonma akinbi onanyamaresi jonibo ochai kopíribi, Dios meninoxon.
\p 
\v 8 Neskara meranxonra, ja Diossen Shinanman noa onanmai, ja reken chité, Diossen xobo meran japariketian, ja Dios jain iká chité kepenmapari iká.
\p 
\v 9 Jatíbi neskarabo winotatonra, rama netebaon noa oinmai, ja Dios menikanai jawékibo, itan ja yoina retexon Dios menikanaitonin, ja jain Dios rabii tsinkitaibaon shinan meran iká jakonmabo, jato soaxonti atipanyamaa.
\p 
\v 10 Jaskáakin akanaibora iká iki, piti betan xeati, jainoax Dios bebon jakon inox chokítibo. Jaskarabora nekebi senenhati jawékibores ikax, jatíbi jawékibo wetsaresibi Diossen imai kamanres iki.
\s1 Criston jimi
\p 
\v 11 Ikaxbi Cristora moa joá iki, já riki rama ja *Sacerdotebaon Koshi. Jara rama jatíbi noa winotai jawékibo non yoiai. Ja sacerdote ikax jainoax teetai, Diossen xobo riki; bebon jakonhira itan kikínhora, jara nato netemea jonibaon akáma iki, jaskaranixa nato netemeama iki.
\p 
\v 12 Cristora, ja cabra itan waka bene jimi Dios meniti kopí, jain Dios ikainko kayamaa iki, jara kaa iki, jawen jimibi boxoni. Jainra já jikia iki, moa jatíbitian iká iti kopí, westíora potábichores, jaskáaxonra, ochankoniax jatíbitian xabakaatabo itiakin, noa imaa iki.
\p 
\v 13 Ikon riki, ja jainxon Dios yoina menoxontiainkoxon, ja cabra, ja waka benen jimi, itan ja waka awin menokana poton, jakonma aká jonibo, jan kachaxkanai. Jara nekebi jakon itiakin jato imati atipana koshiares iki.
\p 
\v 14 Jatian nato jawékibo jaskara ikenra, ja Criston jimikaya bebonbires atipana koshia iki. Ja Cristora, jatíbitian ja Shinanman imaa, ochaoma ikax, janbixbi Dioski menikaatax mawata iki. Jawen jiminra noa jan mawátiain boti, non shinan meran iká jakonmabo noa soaxonai, jaskáxon ja jatíbitian jaa Dios non tee axonon ixon.
\p 
\v 15 Jaskara kopíra, Jesucristo iki, ja bená senenhabekonti joi akainko jato kopi yoyo ikai, já mawatatonra, ja reken senenhabekonti joi aká inontian ochakani jonibo jato xabáai, itan ja Diossen kenaabaon, jatíbitian jayáti jato meniti yoinibo bikanon ixon, jato atikonhaxonai.
\p 
\v 16 Jaskatax westíora testamento akanai kirika wishaa koshi iti kopíra, jan wishaa jonipari moa mawata iti jake.\f + \fr 9:16 \ft Testamento riki, westíora jonin japarixon kirika wishaa. Ja wishá meranra yoiai, tsoabaonki jatíbi já jayata jawékibo mawata pekao biti iki ixon.\f*
\p 
\v 17 Ja wishaa joni mawatamapari ikenra, ja wishá jawe koshiomabi iki, jawetianki ja joni mawatai, jatianparira ja wishá koshi iki.
\p 
\v 18 Jaskara kopíra, ja reken senenhabekonti joi Diossen akainko, yoina retekana jimiribi chikota iki.
\p 
\v 19 Moiséssenra jatíbi jonibo, ja esé meran iká, jatíbi senenhati joibo jato onanmaa iki, jaskáa pekáora joshin lana betan westíora isopo poyan bia iki, jaskáaxonra ja wakabake betan cabra jimi onpaxen meskoatonin pokotaanan, ja esé kirika itan jatíbi jonibo jato kachaxa iki.
\p 
\v 20 Jato yoia iki: “Nato jimi riki ja senenhabekonti joi jan onanti imai, ja senenhanon ixon mato Diossen axona”, akin.
\p 
\v 21 Jainxonribi ja Diossen xobo, itan ja meran iká jatíbi, ja Dios rabikin akanai jawékiboribi, yoina jimin Moiséssen kachaxa iki.
\p 
\v 22 Ja esekan yoiai iká iki, jatíbi jawékitanishaman jimin soakaatai, jatian jaskati jimi chikoyamaitianra, Diossen jaton aká ochabo shinanxonkin jeneyamai.
\s1 Cristonres jonibaon ocha soai
\p 
\v 23 Jaskara kopíra atiora iká iki yoina reteti, ja naikanmea jisaakin akana xobo meran iká jawékibo, jan Dios bebon jakon imati kopí. Ikaxbi ja naikanmea jawékibora maxkáke, ja yoina retekana winoa bebonbires jakon wetsa jawéki.
\p 
\v 24 Cristora ja naikan iká jisaakin jonibaon Dios xoboaxona meranshoko jikiamaa iki, jara jikia iki, ja naikan iká, ikon Diossen xobonkobishaman, jaskatax rama Dios bebomeax noa kopi yoyo inox.
\p 
\v 25 Jara ichai jikinox jain jikiamaa iki, ja baritiatiibi sacerdotebaon koshi, jain Dios iká chiteain yoinanin jimires boi jikiai keskati.
\p 
\v 26 Jatian jaskati iwanketianra peokoonontianbi, Cristo moa ichai mawata ikeanke. Ikaxbi rama moa netebo senenkaitianra, westíoraibicho janbix menikaatax mawati Cristo joá iki, jaskáaxon non ochabo noa soaxonti kopí.
\p 
\v 27 Jatíbi jonira westíoraibicho mawatai, jaskata pekáora jaton akábo kopí jain bokantibo jato yoixonti nete nokotai.
\p 
\v 28 Jaskatiribira Cristo janbix menikaatax westíoraibicho mawata iki, jaskáxon icha jonibaon ochabo jato soaxonti kopí. Japekáora jakiribi joribanoxiki moa jaton ochabo soaxonima, jaon manatabo jato kishpinmaires.
\c 10
\p 
\v 1 Ja Moiséssen eséra iká iki, ramakaya iki kaai jakon jawékibaon otares, ikonkon jabishamanma. Jaskara kopíra ja esekan jawetianbi ja baritiatiibi yoinabicho Dios retexonaibo jato jakon imati atipanyamake.
\p 
\v 2 Ja esekan akonkin jaton ochabo soaxonti atipana iketianra; ochaitonin shinanmeeyamakin, Dios yoina retexonkin moa jenekeankana iki.
\p 
\v 3 Ikaxbi ja Dios yoina retexonkanaibo riki, ja ocha akábo jato jan baritiatiibi shinanmai,
\p 
\v 4 ja waka benebaon jimin itan ja cabrabaon jimin, ochabo soati atipanyamaa kopí.
\p 
\v 5 Jaskara kopíra Criston nato neten jokin Dios neskaa iki:
\q1 “Miara yoina retexonkantinin,
\q1 itan jawékibo menikanti
\q1 keenyamai, jaskáyamakinra
\q1 jonin yoraya min ea imaa iki.
\q1 
\v 6 Miara keenyamai ja
\q1 yoinabo
\q1 menokanti, nin ochabo
\q1 soaxonon ixon jawékibo
\q1 menokanti.\fig Ocha Kopi Dios yoina menoxoni.|src="CO00843b.TIF" size="col" loc="Hebreos 10.6" ref="Hebreos 10:6"\fig*
\q1 
\v 7 Jakopíra en yoia iki:
\q1 ‘Nenora ea itinke ja ea yoii
\q1 kirika meran wishakaata
\q1 keskati, ja min shinanna
\q1 keská ati kopí Diossé’ ”, akin.\f + \fr 10:7 \ft Sal. 40.6-8\f*
\p 
\v 8 Rekenpari yoiai riki: Dios keenyamai yoinabo retexonkantinin, nin jawékibo menikantinbi, nin jaton ocha soati kopí yoinabo kikinhakin keyo menoxonkantininbi. Jaskara jawékibo esekan ati yoiai ikenbi.
\p 
\v 9 Jainoax iribai: “Nenora ea joke min shinanna keská akí”, iki. Jaskáaxonra ja moatian yoinabo retekatikanaibo keyotaanan, jawen toan bená jawéki aká iki.
\p 
\v 10 Diossenra noa jawenabobiribi imaa iki, ja Jesucristo Diossen keena keskáres akí, janbixbi westíoraibicho menikaatax, mawata iketian.
\p 
\v 11 Jatíbi *sacerdotebaonra netetiibi ichaakin yoinabo retekanai, jaskaraton jawetianbi ochabo soati atipanyamakenbi.
\p 
\v 12 Ikaxbi Jesucristora, westíoraibicho ochabo kopí mawata iki. Jaskata pekáora Diossen mekayao yakata iki.
\p 
\v 13 Jainra itinke, jawen rawíbo Diossen jain já penítiaxonai kaman.
\p 
\v 14 Janra westíorai mawatatonbicho, ja Dioski kikinni menikaatabo, jatíbitian jakonman senenabo itiakin jato imaa iki.
\p 
\v 15 Jatian jara Diossen Shinanman noa onanmai neskáakin yoixon:
\p 
\v 16 “Ja netebo winota pekáo, ja bená senenhabekonti joi en jato betan akaira, inoxiki neskara ikira ikai ja Ibo:
\q1 Nokon esébora jaton jointi meran en imanoxiki,
\q1 itan jaton shinan meranra en wishanoxiki.\f + \fr 10:16 \ft Jer. 31.33\f*
\q1 
\v 17 Jatianra jaton jakonma akábo, itan jaton ochabo moa jawetianbi en jato shinanxonyamanoxiki”, iki.\f + \fr 10:17 \ft Jer. 31.34\f*
\p 
\v 18 Jaskáakin ja ochabo moa noa shinanxonyamai ikenra, ja ochabo kopí moa Dios jawékibo meniti maxkáyamake.
\s1 Dioski koshii jenétima
\p 
\v 19 Jaskara ikenra en mato yoiai nokon wetsabo, ja Jesucriston jimi kopíresa, rama rakétanma jain Dios iká chité meran noa jikiti atipanke,
\p 
\v 20 ja chopa nachitebi bebanbainkin, jan jati bená bai noa jan kepenxonatoninbi. Ja iki jawen yorabi yoii iká.
\p 
\v 21 Noara ja Diossen xobo koiranna, westíora kikin ani *sacerdoteya iki.
\p 
\v 22 Jaskara iken, shinan meran ikonkon ikax, itan akonkin ikonhaa ikax, jain Dios ikainbishaman nokónon akanwe. Moa shinan meran jakonma aká soakaatabo itan nekebi moa jakonshaman onpaxen chokita keskábo ikax.
\p 
\v 23 Jawenbi taxketimaakinkaya, ja noa jaon manata, ikonhakin jeneyamanon akanwe. Diossenra noa yoia jawékibo senenhati iki.
\p 
\v 24 Jaskatax wetsabo betan akinananni bebonbires noimis iti, itan jakon teebores atikaya shinanon akanwe.
\p 
\v 25 Dios rabí tsinkiti jeneyamanon akanwe, ja jatíribibo jaskati axeabo ikax boyamai keskati iamai. Jaskáyamaikaya wetsabo betan shinan menianannon akanwe; ja non Ibo joti nete moa ochómabires iketian ointaanan.
\p 
\v 26 Jatian ja ikon joi onanna pekáobi, nonbix keenax noa ochakaresaitianra, ja ocha kopi mawáti, moa wetsa jawéki yamake.
\p 
\v 27 Jatianra noa manáresti iki, ja non akábo yoixontaanan ja jakonmabires masá teneti chii tiritai meran, Diossen jawen rawibo jato potatiainribi noa potatinin.
\p 
\v 28 Jatian jaweratoki ja Moiséssen eséki yoitimatai, jara rabéxon, iamax kimishaxon, oinxon ikon yoiaitian jawebi onísayamakin reteti iká iki.
\p 
\v 29 Jaskara iká ikenra, bebonbires castigamekanti iki, ja Diossen Bake moa ikonhayamakin jamatai keskáakin akaibo, itan jawen jimi noa kopí chíkoni ikonhayamaibo, jainoax jan noa noia Diossen Shinanki jakonmaibires yoyo ikaibo. Ja jimi riki ja senenhabekonti joi aká jan onanti imai, ja meranxonribira, jabo jawenabobiribi jato imaa iki.
\p 
\v 30 Nonra onanke ja Ibo neskati yoyo ika: “Enra jonibo jato ramiakai, jabaon jato aká keskáakinribi jato kopíxonkin”, iki iká. Jainoax iribaa iki: “Ja Ibonra, jaton akábobiribi jawen jonibo jato yoixonoxiki”, iki.
\p 
\v 31 ¡Kikinbires onsá riki, ja jiria Diossen mekenman paketi!
\p 
\v 32 Ikaxbi matonbiribi shinankanwe, ja reken maton Diossen joi ikonhanontianra kikin, atikomabires onitsapiti jawékibo, koshi shinanyaxonres maton tenea iki.
\p 
\v 33 Jatíribi matobora, icha jonibo bebonxon, mato masábo tenemaanan, mato ichaabokana iki. Jatian jatíribibora jato jaskáakin akanaibo betanribi kikinni onitsapikana iki.
\p 
\v 34 Jaskáakanabira, ja cárcel meran akana joi akaiboribi maton jato noibaa iki. Jainxon mato jayata jawéki mato bichinkanabi, mato raroreskana iki. Naikan kaxonra bebonbires, itan keyóyosma jawéki non binoxiki iki ixon onannax.
\p 
\v 35 Jaskara iken, Cristo ikonhaax jaki koshii jeneyamakanwe. Jatianra jan mato meninoxon yoia jawékibo, maton binoxiki.
\p 
\v 36 Matobora ja onitsapiti jawékiain koshi shinanyabo iti maxkákanke. Jaskatax ja Diossen shinannai keskáshamanbo itaanan, jan meninoxon yoia jawékibo maton biti kopí.
\p 
\v 37 Wishá meranra ikai neskati:
\q1 “Basimara joti jake, ja joti joni.
\q1 
\v 38 Ja ea ikonhataanan, jakoni jaax eki koshiabora, janoxikanai, ikaxbi ea ikonhakin jenekanabo ikenra jato betan nokon shinan jakonshaman itima iki”, iki.\f + \fr 10:38 \ft Hab. 2.3-4\f*
\p 
\v 39 Ikaxbi noara, já ikonhakin jenetaanan, manotiain boaiboma iki. Jaskáyamaira noa já ikonhaax kishpinmeetabo iki.
\c 11
\s1 Oinxonmabi ikonhati
\p 
\v 1 Ja ikonhaa iti riki, oinnaxmabi, ja non biti jawékinin manata iti. Ikon riki ixon, non oinnama jawékibo ikonhati.
\p 
\v 2 Jaskáakin ikonhaa ikenra, ja non rekenbo jato Diossen oinna kikin jakon jonibo ikana iki.
\p 
\v 3 Ja ikonhaa ixonra non onanke, nato nete joniakin, jawen yoyo ikatoninres jatíbi jawékibo Diossen aní. Jaskara kopíra, ja non oinyosma jawékibo Diossen aká, non rama oinnai.
\p 
\v 4 Ikonhai ixonra, Abelnin ja Caínman aká bebonres, jakon yoina retexon, Dios menia iki. Jaskara kopíra, Diossen atibi keskáakin akai joni oinna iki, itan jan menia jawékiribi bixona iki. Jaskáakinra moa Abel mawata ikenbi, ja ikonhaax jaki koshia iní jawékinin noa shinanmaboresai.\f + \fr 11:4 \ft Gn. 4.3-7\f*\fig Abel betan Caín.|src="CO00615b.TIF" size="col" loc="Hebreos 11.4" ref="Hebreos 11:4"\fig*
\p 
\v 5 Jaskáakin já ikonhaax jaki koshia ikenribira, mawáyamanon ixon, jiriabi nato mainmea Diossen Enoc boá iki, jaskáakin moa Diossen boa iketianra, moa tsonbi oinyamaa iki. Wishá meranra akai yoikin, ja boamatianbira Dios keenai keskáshamanres Enoc iká iki ixon.\f + \fr 11:5 \ft Gn. 5.21-24\f*
\p 
\v 6 Ikaxbi já ikonhama ixon, Dios keenai keskábo ati jawékira atikoma iki. Ja Dios benaitoninra ikonhati jake, Diosra jake ixon, itan já benaibora, ja bikanti jawékibo jato meniai ixon.
\p 
\v 7 Ja ikonhai ixonra, Noekan jan oinyosma jawéki winoti kaaibo, Diossen yoiaibo ninkátaanan, jawen rareboyabi kishpinmeenoxon, ani wapóro aká iki. Jaskáakin ikonhaxonra, jaton akábo ja nato netenmea jonibo jato yoixona iki. Jaskara kopíra, já ikonhaax, atibi keskáakin akai joni baneta iki.\f + \fr 11:7 \ft Gn. 6.13-22\f*
\p 
\v 8 Já ikonhaa ikaxa, Abraham Diossen kenaa, yoitimayamai ja janbi meninoxon yoia main jaai kati kopí, pikota iki. Jara jawen mainmeax kaa iki, jaweranoki, ea kaai ixon onannaxmabi.\f + \fr 11:8 \ft Gn. 12.1-5\f*\fig Diossen kenaa, jainshaman kaai onanaxmabi Abraham kaa.|src="CO00642b.TIF" size="span" loc="Hebreos 11.8" ref="Hebreos 11:8"\fig*
\p 
\v 9 Jaskáakin já ikonhaa ikaxa, ja Diossenbi menia main ikaxbi wetsankoniax joá joni keskatires jaa iki. Jara jakatiai, chopa xobo meranres. Jatian Isaac betan Jacobribi jaskati jakana iki, jaboribi jaskara jawéki jato meniti yoia ikax.\f + \fr 11:9 \ft Gn. 23.4; 26.3\f*
\p 
\v 10 Ja Abrahammanra manaa iká iki, ja Diossenbi aká jemanko jaai katín. Jatian ja jemara, Diossenbi aká ikax, kikin koshi iki.
\p 
\v 11 Já ikonhaax jaki koshia kopíra, Saran bakeayosma ixonbi, itan Abraham yosishoko ixonbi. Diossen koshi meniatonres bakea iki. Ja jaskara jato imati yoiabora, Diossen akonkin senenhai ixon ikonha kopíres.\f + \fr 11:11 \ft Gn. 15.6; 17.19\f*
\p 
\v 12 Jaskáakin Abrahamman, kikin yosishoko moa koshioma ixonbi bakeara, jawen chiní rarebobo kikinbiresi kaikanike. Ja naikanmea wishtinbo, itan aniparo kexá iká mashibo non oinna keskati, tson toponmati.\f + \fr 11:12 \ft Gn. 15.5\f*
\p 
\v 13 Jatíbi ja jonibora, Diossen jato jaskara meniti yoiabo biaxmabi mawákana iki, ikaxbi ikonhabo ixonra, ochóxonbi jaskarabo oinxon onantaanan, meken sananxonreskana iki. Noabora nato netén iamai winotaibores iki ixon, jatonbi onantaanan.
\p 
\v 14 Jaskatibo yoyo ikáni iketianra, non kikinhakin onanke, ja jain ikanti maibiribi benai jabo ikana.
\p 
\v 15 Ja jainoax jokonkani mai shinanni jaskakani ikaxa, jakiribi ja main boribakeankana iki.
\p 
\v 16 Ikaxbi jabora, kikin jakon mainko jatín keenkana iki. Onantiakin yoia, ja nai neten jaai bokantinin keeni. Jaskara kopíra, jaton Dios riki ea iki itin, rabinyamaa iki, moa jain jakanti jema jato benxoaxona ikax.
\p 
\v 17 Jaskáakin já ikonhaa ixonra, Diossen Abraham tanaa, ja jawen bake Isaac retenoxon boá iki, Abrahamra jawen jabicho bake retexon, menoti jawemabi iká iki, Diossenbi neskaakin yoia ikenbi:
\p 
\v 18 “Ja Isaac meranoaxa, icha min chiní rarebobo kaikanti jake”, akin.\f + \fr 11:18 \ft Gn. 21.12\f*
\p 
\v 19 Abrahammanra onanna iká iki, Diosra ja mawákanabo jiriati atipana koshia iki ixon. Jaskáakinra Isaac mawataxbi, jakiribi jiria keskáakin shinanna iki.\f + \fr 11:19 \ft Gn. 22.5\f*
\p 
\v 20 Jaskati Dioski koshia ixon, ja Isaacnin jawen bake rabé, Esaú betan Jacob yoia iki, Diossen jato jakon imaboresnon ixon.
\p 
\v 21 Jaskáakin ikonhaa ixonra, Jacobnin moa mawátires ixonribi, ja Josekan bakebo yoia iki, Diossenbira matoki jakon shinannoxiki ixon yoia iki. Japekaora jawen kekótikibi koshitaanan, Dios rabia iki.\f + \fr 11:21 \ft Gn. 47.31\f*
\p 
\v 22 Jaskararibi ixonra, Josekan moa mawátires ixon, ja *israelita jonibora Egipto mainmeax jokonoxikanai ixon, jato yoia iki, jainxon ja mawata pekáoki, jawen yora jawekeskakanti iki ixon, jato yoia iki.\f + \fr 11:22 \ft Gn. 60.24; Ex. 13.19\f*
\p 
\v 23 Ja ikonhaa ixonribira, bake pikóketian, kikin metsáshoko oinxon, jawen anibobaon kimisha oxe Moisés jonekana iki. Ja benbo bakebo reteti jato apon yoia ikenbira, rakéyamakana iki.\f + \fr 11:23 \ft Ex. 1.22\f*
\p 
\v 24 Ja ikonhaa ixonribira, moa yosi joni ikax, ja faraónman bake ainbaon bake riki, akantinin Moisés keenyamaa iki.
\p 
\v 25 Jaskáyamaira, ja Diossen jonibo betanbi ramiakantin, jawemabi iká iki, ja ocha akai jonibo betan rarotitianbi.
\p 
\v 26 Janra shinanna iki, ja Diossen Bake nato neten joáx, ramiakana onitsapiti keskatiribi iti. Ja Egiptoain ja jawékibaon rarotitianbi; janra onanribia iki, ja Diossen meniti yoiabo seneni kaiboribi.
\p 
\v 27 Ja ikonhaxibira, Moisés Egipto mainmeax, ja apo sinataibi, rakéyamai pikota iki, jaskataxa jishtima iken Dios oinnama ikaxbi, janbi oinna keskati jaki koshia iki.\f + \fr 11:27 \ft Ex. 12.21\f*
\p 
\v 28 Jaskáakin ikonhaa ixonra, ja *Pascua fiesta jato akinna iki. Jainxonra ja yoina retexon, jawen jimin jaton xobo xepotibo sikakanti jato yoia iki, jaskáxon ja *israelitabaon reken bakebo, ja retemis ángelnin jato retenaketian.
\p 
\v 29 Ja ikonhakana kopíribira, israelita jonibaon, ja ani Joshin paro mai manxanshaman imaatonin shitákana iki. Jainxonra ja Egipto sontárobo jato ikanatonribi shitákanaitian, jenen jato keyoa iki.\f + \fr 11:29 \ft Ex. 14.21\f*
\p 
\v 30 Jaskáakin ikonhakanketianribira, kanchis nete ja Jericó jema katea chité, ja israelitabaon mayákanketian, ja chitébo ras ika iki.
\p 
\v 31 Jatian jaskáakin ikonhaa kopíribira, tsini ainbo, Rahab janeya, ja yoitimabo betanribi mawáyamaa iki. Ja joné jato oinni bekana israelitabo jakonhaxon jawen xobon jato bia kopí.\f + \fr 11:31 \ft Jos. 2.1\f*
\p 
\v 32 ¿Jaweboki en mato yoiboresti atipana? Ja Gedeón iníbo, ja Barac iníbo, ja Sansón iníbo, ja Jefté iníbo, ja David iníbo, ja Samuel iníbo, itan ja profetabo ikánibo mato yoitibo japariaxbira, ea netebo senenyamaa iki.
\p 
\v 33 Ja ikonhaabo ixonribira wetsa maiboribi jato bichinkana iki, joni koshi ixon, itibi keskáakinboribi jato ikínkana iki, Diossen jato meninoxon yoia jawékiboribi bikana iki, ja leónboribi jaton kexabo xeponankana iki.
\p 
\v 34 Ani chii tiritaiboribi nokamakana iki, espadaninbo retekaskanabi, jabákana iki, jatíribibaonra moa yosmakanabo ixonbi, jakiribi koshiinakiranxon, ja reteanantiainxon jaton rawíbo jatoareskana iki.
\p 
\v 35 Jatíribi ainbobaonra, jaton rarebo jirikanaboribi oinkana iki. Jatíribibora rishkixonbo retekanainbi jato jenemakantininbo keenyamai mawákana iki, jaskata pekáo jakonhirai janox jakiribi jiribiti onannax.
\p 
\v 36 Jatíribibora jatoki shiroananbo jato rishkikin, onitsapiakana, iki, cadenaninbo, itan cárcel meranboribi jato akana iki.
\p 
\v 37 Wetsabora makanman tsakaxonbo retekana iki, pochínikon xatexonbora, jato retekana iki, chichika kenshon chachixonboribira jato retekana iki. Jatíribibo ikana iki, jainshaman iti onantimabo ikax, boantani, jaton chopabo iká iki oveja bichi, itan cabra bichibo axon sawekanashokobo, jawebiomashokobo, onísshokobo, itan ramiakanabo.
\p 
\v 38 Nato netemea jonibora, jakon jonibo nato main jatín keenyamakanai, jaskákin jato ramiakanara, nato netemeax jain joni jayamainkobo boantani, manish meranbo, shanka kini meranbo, jainoax mai kini meranboribi, jonékana iki.
\p 
\v 39 Jaskarabo winoxonbira jabaon westíoraxonbi, ja Diossen jato meninoxon yoiai jawékibo biamakana iki. Já ikonhaabo ikax jakoni ikanabo ixonbi.
\p 
\v 40 Neskarara winókana iki, jato Diossen jaskara imanoxon yoia bebonbires noaboribi ikanon ixon. Jaskáaxon nobetanbi, jaboribi jakonbiresshaman imati kopí.
\c 12
\s1 Dioskires koshiax jati
\p 
\v 1 Jaskara ikenra, icha Dios ikonha jonibaon noa katekana iketian, jatíbi jan noa tsokas akaibo, itan jan noa ratanea keská ochabo moa non jeneti jake. Jaskáatananra já non chibanti jake, jaki koshixonres.
\p 
\v 2 Ja Jesucristo shinanyareskaya janon akanwe, ja riki non já ikonhaketian, noa jákoman senenabo imai. Ja Jesússa rabinti jawékibo shinanyamabaini, korosen akana mawata iki, jaskati onitsapita pekáo, kikin raroshaman iti onannax. Jaskataxa naikan kaax, Diossen mekayao jawen ani yakatinin yakata iki.
\p 
\v 3 Jaskara iken ja Jesús iníbo onannax, ja shinannires mato jakanti jake, jara omiskin, ja ochaya jonibaon ichabiresakin jakonmaakana iki. Jaskarabo kopíkaya jatsanyamai shinan namanyamakanwe.
\p 
\v 4 Matonra, ocha betan reteanankin, ja Cristo iní keskatiribi mawati, maton onanyamake.
\p 
\v 5 Jaskatira, ja jawen bakebo iken, Diossen esea joibaon mato moa shinanbenokanke. Ja Wishá meran ikai neskati:
\q1 “Nokon baké, ja jakonma min akaitian,
\q1 non Ibon ponténon ixon mia yoia,
\q1 ninkáxonkashamai iamawe, jainxon ja koshi
\q1 joinbo mia akábi, shinan namányamawe.
\q1 
\v 6 Non Ibonra, jan jato noiabo ponténon ixon jato yoiai;
\q1 jainxon jawen bakeakin jato shinannaiboribi, jato castiganai”, iki.\f + \fr 12:6 \ft Sal. 3.11-12\f*
\p 
\v 7 Matonra, ja masá tenetibo winókinbi teneti jake, jaskáxonra jawen bakeboakin mato Diossen shinanti iki. ¿Jakonmai ikaitian ponténon ixon, jawen papan notsinyosma bakeboki jaa?
\p 
\v 8 Jatian maton jakonmabo akaitian, Diossen jatíbi jawen bakebo akai keskáakinribi notsinhamai ikaxa, ikonkonshaman jawen bakemabo mato ikanai.
\p 
\v 9 Noa bakebo inontianra, ponténon ixon, non papabaon noa masábo tenemakana, jakonhakinbo non jato ixona iki. Jaskáribira, ja non Papa naikan ikátonin noa castigana, itibi noa jaki jenekaati jake, noa jati neteyabo ikanti kopí.
\p 
\v 10 Non papabaonra jaton shinannai keskáakinbiribi, nato mainxon noa castigankatikanai. Ikaxbi Diossenra noa castiganai, ikonkon noa akinnoxon, jaskatax já keska jakonboribi noa ikanon ixon.
\p 
\v 11 Ikon riki, ja noa castigankanai hora, jan keentishaman jawékima. Noara chexai, ikaxbi jaweratonki jaskákana jawékibo onannai, jara jakoni, itan pontetiribi jati iki.
\p 
\v 12 Jaskara iken, ja non meken paxkina keskábo ikax, itan ranboxo yosmaa keskábo iken, jakiribi koshiai keskábo ikanwe.
\p 
\v 13 Ja ponté bai benakanwe, jaskatax ja chanké iki niai keskábo iitibi, moa benxoax, jakoni niai keskábo, mato ikanon.
\s1 Dioski yoitimai jati riki onsá
\p 
\v 14 Jatíbibo betan jakonbires xabá shinanyabo ikanwe, itan jakonibo jakanwe. Jatian jaskati jakoni jayamaxonra, tsonbi ja Ibo ointima iki.
\p 
\v 15 Moa Dios noiabo ixon, jenetimaakinkaya shinankanwe, matora jiwi tapon moka keskábo ixon, jonibo jato jakonmaakaibores inake.
\p 
\v 16 Wetsabo betanbires yorantibo ayamakanwe, itan Diosbiribi axona jawékibo omisyamakanwe. Jaskarara winota iki Esaú, janra aká iki, jan reken bake ixon biti jawékibo, westíora plato piti kopi, jawen wetsa maromakin.\f + \fr 12:16 \ft Gn. 25.29-34\f*
\p 
\v 17 Matonra onanke, jaskáakin moa jawen wetsa menia pekáo, jawen papan jaskara meniti yoiabo bikaskinbi, moa biamani. Jaskáakinra kikinbiresi winixonbi, ja winota jawéki kopí, moa jawebi ati atipanyamaa iki.
\p 
\v 18 Matora ja *israelitabo mananman bokani keskati, ikanamabo iki. Jabaonra oinna iki, tii ati jawékibo, itan chii meranoax tirí pikotaibo, jainra kikinbires yamé ikax, niweababo bea iki.
\p 
\v 19 Jainoax trompeta xoon ikaibo, itan Diosbi yoyo ikaiboribi, maton ninkatama iki. Jatian ja joi ninkatabaonra, moa jaskáakin jato yoiborestima yoikana iki,
\p 
\v 20 ja senenhakanti esé neskati iká teneti atipanyamaxon: “Jawerato jonin, iamaxon yoinanin inonbiki, ja manan jawen taen jamatai, jara makanman tsakaanan, iamaxon yami kenshon chachianan reteti iki”, ikai iketian.
\p 
\v 21 Jatian ja oinkanai jawékibora iká iki, kikinbires onsá, jatianra Moisésbobi inike neskati: “Eara raketi saki ikai”, iki.
\p 
\v 22 Ikaxbi matora, ja *Sión janeya mananman moa nokokanabo iki, ja jiria Diossen jemanko, ja nai netemea Jerusalénhain, ja Dios rabii icha ángelbo tsinkíkanainkoribi.
\p 
\v 23 Jainoax mato nokókana iki, ja reken Diossen bakebo ikanainkoribi, ja naikan wishakaatabo ikain, ja jatíbi jaton akábo jato yoixonai koshi Diossiba, ja jakon jonibaon kayabo Diossen jakonman senenabo, jato imaxona ikainkoribi.
\p 
\v 24 Ja senenhabekonti bená joira Jesús meranxon aká iki, jawen jiminra ochabo noa soaxona iki, jaskara ikaxiki, jawen jimi ja Abelnin jimi iní bebonbires jakon.
\p 
\v 25 Jaskarabo iken, koirameekanwe, ja Diossen noa yoyo akabi ninkáxonkashamaira, noa inake. Jatian jaskáakin jato yoiabi, ninkáxonkashamakanaitianra, ja *israelitabo jato Diossen castigana iki. Jaskáribiakinra naikanxonbi, jan noa yoiabo non ninkáxonyamaitian, noa castiganshokoti iki.
\p 
\v 26 Moatianra ja Diossen jato yoyo akaitian, mai shakota iki, ikaxbi ramara ikai neskati: “Jakiribira moa maibicho imayamakin, en rama nairibi shakomanoxiki”, iki.\f + \fr 12:26 \ft Is. 13.13; Hag. 2.6\f*
\p 
\v 27 Ja “jakiribira en imanoxiki”, ikaitonra noa onanmai, jatíbi jan jonia jawékibo, ja taxkéti atipana jawékibo keyoi kaai, jaskatax ja taxkéyamaibobicho jati kopí.
\p 
\v 28 Ja Diossen ikinnaton noa jain jati netera, wetsanko taxketaima iki. Neskarabo kopíkaya, iráke ayananbi Dios rabinon akanwe jawen keena keskáakin, noitaanan aniakin shinanxon.
\p 
\v 29 Ja Diosra jatíbi keyoai tiritai chii keska iki.
\c 13
\s1 Diossen joi akai ikax, jaskati itibo
\p 
\v 1 Jaskara kopí joi akaibobires ikax, wetsabo betanribi noianani jenéyamakanwe.
\p 
\v 2 Ja matoiba beaibo noianan, jakonhaxon jato bikanwe, jaskáakinbo axonra, jatíribibaon onanxonmabi, ángelbo jaton xobon nokómakana iki.
\p 
\v 3 Ja presoboribi shinankanwe, matoribi jato betanbi presoakanabo shinantaanan; ja ramiakanai joniboribi shinankanwe, matoribi jaskarabo winotai keská, shinantaanan.
\p 
\v 4 Jatíxonbira ja wanoi biananana jawéki, jakonhakin oinkanti jake, moa biananabo ikaxa, mato yosmaananti yamake. Diossenra, ja atima betanbires yoranti akaibo, jainoax wanoya itan benoya ixonbi wetsa betan yoranti akaibo, jaton akábo jato yoixonoxiki.
\p 
\v 5 Koríkibichores noiamakanwe, ja mato jayata jawékiboya ikaxeskaya, jakon shinanni jakanwe. Jaskara yoiira ikai Dios neskati: “Jawetianbira en mia potatima iki itan jenetima iki”, iki.\f + \fr 13:5 \ft Dt. 31.6\f*
\p 
\v 6 Jaskara ikenra, kikinni Dioski koshiax noa neskatibo yoyo iti atipanke:
\q1 “Ja Ibo riki ea jan akinnai, jakopíra, jonibaon
\q1 akanti jawékibaon ea rakéyamai”, iki.\f + \fr 13:6 \ft Sal. 56.3-4\f*
\p 
\v 7 Ja Diossen joi yoiananbi, mato ikinnai jonibo shinankanwe, Shinankanwe, jawekeskataxboki jabo mawákana iki ixon. Jabo ja Dioski koshiabo ikax, ikáni keskatiribi ikanwe.
\p 
\v 8 Ja Jesucristora jabi iki moatianbi, ramakamanbi itan jatíbitian inóxiki.
\p 
\v 9 Ja meskó maton onanyamaa esébo mato yoikanabi jato ninkáxonyamakanwe. Ja Diossen noimisti shinanyabo ikaxkaya, beboni non shinanbo koshinon akanwe. Ja jatíribi jawékiati pitimabo yoikanai jawékibaonra, jawebi jato akinyamaa iki.
\p 
\v 10 Ja janxon Dios yoina menoxonainkoniara, ja moatian Diossen xobonko teetai ikátikanai *sacerdotebaon, piti atipanyamake.
\p 
\v 11 Ja *sacerdotebaon koshinra, ja yoina jimibo ja Diossen xobonko bokatiai, jaskáxon jaton ochabo soaxonon ixon Dios menikin, ikaxbi jaton yorabora apaokanike, jemamaan boxon menokin.
\p 
\v 12 Jaskáribiakinra jawen jiminbi jawen joi akaibo jakon jonibo imati kopí, jemamaanbires boxon onitsapiaxon Jesús retekana iki.
\p 
\v 13 Jaskáribiikaya pikotax, Jesús betanbi bonon bokanwe, jaskatax já retekani keskatiribi, onitsapianan mawáti shinanyaboribi inox.
\p 
\v 14 Nato netenra, jatíbitianshaman noa jain iti yamake, jaskáyamaikayara, jain noa jaai kati bená jema manaax noa ikanai.
\p 
\v 15 Jaskara kopíra, Cristo kopíres jatíbitian non Dios rabiti jake, neskáakin rabiira, jatíbi non ikáboyabi noa Dioski menikaatai, jaskáakinra non kexakanbi non Dios rabiti jake.
\p 
\v 16 Jaskara iken, jakon jawékibores akí jakanabo ixon, ja mato jayata jawékininbo, wetsaboribi jato akinkanwe. Neskati mato akinanannaitianra, Dios raroai.
\p 
\v 17 Ja mato ikinnai koshiboki yoitimayamakanwe, jabaon mato yoiai keskatiboreskaya ikanwe, jabaonra mato koirankin jeneyamai. Jabaonra onanke jaton aká jawékibo Dios yoii bonoxikanai; joibo jato senenhaxonkanwe, jaskáxon jabaon raroshamaanan jakonmaibo yoyo iamakin jaton tee senenhakanon. Ja jakonmaibo yoyo itinra, noa jakon jawékibaon akinyamai.
\p 
\v 18 Noki orankanwe, jatíbiain jakonires itiakin shinannaibo ikaxa, jakonma aká non shinan meran yamabo noa ikanai.
\p 
\v 19 Jainxon ishtontaniribi matoiba kanon ixon, ea Diossen akinti kopíribi orankanwe.
\s1 Senentiainbi jato saludana
\p 
\v 20 Ja jakon xabá shinanya jato imai Diossenra, ja non Ibo Jesús, mawákenbi jirimaa iki, ja ovejabo ikinnai joni keska, jawen jiminra ja senenhabekonti joi jatíbitian itiakin onanti imaa iki.
\p 
\v 21 Janbi mato jakonman senenabo, itan jatíbiain jakoni itiakinbo mato imabanon; jaskáaxon jawen shinanna keskáshamanbo, maton senenhanon, itan Jesucristo meranxon jawen keena keskáakin, noobetan ati kopí. Ja Cristo jatíbitian rabinon akanwe, jaskara ibanon.
\p 
\v 22 Nokon wetsabó jatsanyamakinpari, mato koshinon ixon, nato ichama joibo en mato wishaxonabo, ea ninkáxonkanwe.
\p 
\v 23 Jainxon maton onannon ixonribira, en mato yoiai, ja non wetsa Timoteora moa cárcel meranoax pikóke, ishtontani neno jokenra, ea jabé mato oinni kati iki.
\p 
\v 24 Jatíbi ja mato ikinnai koshibo, itan wetsa mato betan joi akaiboribira non saludo bomai, jainxon ja Italiainoa non wetsabaonribira, mato saludo bomakanai.
\p 
\v 25 Diossenbi jawen noimisti shinanman mato jatíbibo akinbanon.
