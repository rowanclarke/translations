\id 2TI
\h 2 טימותי
\toc1 2 טימותי
\toc2 2 טימותי
\toc3 2 טימותי
\mt1 אִגֶּרֶת פּוֹלוֹס הָשֵּׁנִית אֶל־טִימוֹתִיּוֹס
\c 1
\cp א
\cl פרק א
\p 
\v 1 \vp א\vp* פּוֹלוֹס שְׁלִיחַ יֵשׁוּעַ הַמָּשִׁיחַ בִּרְצוֹן אֱלֹהִים כַּאֲשֶׁר הִבְטִיחַ לָנוּ חַיִּים בִּיֵשׁוּעַ הַמָּשִׁיחַ׃
\v 2 \vp ב\vp* אֶל־טִימוֹתִיּוֹס בֵּן יַקִּיר לִי חֶסֶד רַחֲמִים וְשָׁלוֹם לְךָ מֵאֵת אֱלֹהִים אָבִינוּ וּמֵאֵת יֵשׁוּעַ הַמָּשִׁיחַ אֲדֹנֵינוּ׃
\v 3 \vp ג\vp* בָּרוּךְ הוּא הָאֱלֹהִים אֲשֶׁר עָבַדְתִּי אֹתוֹ בְּתָם־לְבָבִי מִימֵי אֲבוֹתָי כִּי־אֶזְכָּרְךָ תָמִיד בִּתְפִלָּתִי מִדֵּי אֶתְפַּלֵּל בַּלַּיְלָה וּבַיּוֹם׃
\v 4 \vp ד\vp* וְנַפְשִׁי כָלְתָה לִרְאוֹתֶךָ כִּי דִמְעוֹתֶיךָ עָלוּ לְזִכָּרוֹן לְפָנַי לִשְׂבֹּעַ שְׂמָחוֹת אֶת־פָּנֶיךָ׃
\v 5 \vp ה\vp* וְהָגִיתִי בָּאֱמוּנָה הַצְּרוּפָה אֲשֶׁר הָיְתָה מִקֶּדֶם בְּלֵב לוֹאִיס אֵם אִמְּךָ וּבְלֵב אַבְנִיקָה אִמֶּךָ וְיָדַעְתִּי מְאֹד כִּי הָאֱמוּנָה הַזֹּאת הִיא גַּם־בְּלִבֶּךָ׃
\v 6 \vp ו\vp* וּבַעֲבוּר זֹאת בָּאתִי לְהַזְכִּירְךָ כִּי־תְעוֹרֵת מַתְּנַת הָאֱלֹהִים הַנְּתוּנָה לְךָ מֵעֵת אֲשֶׁר סָמַכְתִּי יָדַי עָלֶיךָ׃
\v 7 \vp ז\vp* כִּי לֹא נָתַן לָנוּ אֱלֹהִים רוּחַ פָּחַד כִּי אִם־רוּחַ גְּבוּרָה אַהֲבָה וּמוּסָר׃
\v 8 \vp ח\vp* וְלָכֵן אַל־תֵּבוֹשׁ מֵעֵדוּת אֲדֹנֵינוּ וְלֹא מִמֶּנִּי אֲסִירוֹ רַק נְשָׂא חֶבְלֵי הַבְּשׁרָה כָּמֹנִי בִּגְבוּרַת אֱלֹהִים׃
\v 9 \vp ט\vp* אֲשֶׁר הֵבִיא לָנוּ יֶשַׁע וַיִּקְרָא לָנוּ בִּדְבַר קָדְשׁוֹ לֹא כְמַעֲשֵׂינוּ כִּי אִם־כַּעֲצָתוֹ וּבְחַסְדּוֹ אֲשֶׁר חָלַק לָנוּ בְּיֵשׁוּעַ מְשִׁיחֵנוּ לִפְנֵי יְמוֹת עוֹלָם׃
\v 10 \vp י\vp* וְזֶה עַתָּה עִגְלָה לָאוֹר כַּאֲשֶׁר נִגְלָה מוֹשִׁיעֵנוּ יֵשׁוּעַ הַמָּשִׁיחַ אֲשֶׁר בִּבְשׁרָתוֹ בִּלַּע אֶת־הַמָּוֶת וַיּוֹצֵא לָאוֹר חַיֵּי־עַד וּנְתִיב אַל־מָוֶת׃
\v 11 \vp יא\vp* הִיא הַבְּשׁרָה אֲשֶׁר נִקְרֵאתִי לִהְיוֹת־לָהּ לְמַגִּיד וּלְשָׁלִיחַ וּלְמוֹרֶה הַגּוֹיִם׃
\v 12 \vp יב\vp* וּבַעֲבוּר זֹאת נָשָׂאתִי הַתְּלָאָה הַזֹּאת וְלֹא אֵבוֹשׁ כִּי־יָדַעְתִּי בְּמִי הֶאֱמַנְתִּי וּבוֹ בָטְחָה נַפְשִׁי כִּי־רַב כֹּחַ הוּא לִשְׁמֹר אֵת אֲשֶׁר הִפְקַדְתִּי בְיָדוֹ עַד־הַיּוֹם הַהוּא׃
\v 13 \vp יג\vp* אֶת־הַדְּבָרִים הַנֶּאֱמָנִים כְּצוּרָתָם וְתָכְנִיתָם תִּצְפֹּן אִתְּךָ כַּאֲשֶׁר שָׁמַעְתָּ מִפִּי בֶאֱמוּנָה וּבְאַהֲבָה אֲשֶׁר בְּיֵשׁוּעַ הַמָּשִׁיחַ׃
\v 14 \vp יד\vp* וְאֶת־הַפִּקָּדוֹן הַטּוֹב אֲשֶׁר הָפְקַד אִתְּךָ שְׁמָר־לְךָ בְּרוּחַ הַקֹּדֶשׁ הַשֹּׁכֵן בָּנוּ׃
\v 15 \vp טו\vp* הִנֵּה יָדַעְתָּ כִּי־עֲזָבוּנִי כֻלָּם אֲשֶׁר בְּאַסְיָא וּבְתוֹכָם פּוּגְלוֹס וְהַרְמוֹגְנִיס׃
\v 16 \vp טז\vp* יִגְמֹל הָאָדוֹן חֶסֶד עִם־בֵּית אֳנִיסִיפוֹרוֹס כִּי־הֵשִׁיב נַפְשִׁי פְּעָמִים רַבּוֹת וְלֹא־בוֹשׁ מִן־הַכֶּבֶל אֲשֶׁר נֶאֱסַרְתִּי בוֹ׃
\v 17 \vp יז\vp* וּבִהְיוֹתִי בְרוֹמִי שָׁקַד לְבַקְּשֵׁנִי עַד כִּי־מָצָא אֹתִי׃
\v 18 \vp יח\vp* יִתֶּן־לוֹ הָאָדוֹן לִמְצֹא חֶסֶד מִלִּפְנֵי יְהוָֹה בַּיּוֹם הַהוּא וְכָל־אֲשֶׁר הֵיטִיב עִמָּדִי בְּאֶפְסוֹס נַפְשְׁךָ יֹדַעַת מְאֹד׃
\c 2
\cp ב
\cl פרק ב
\p 
\v 1 \vp א\vp* וְאַתָּה בְּנִי חֲזַק בְּחֶסֶד יֵשׁוּעַ הַמָּשִׁיחַ׃
\v 2 \vp ב\vp* אֶת־אֲשֶׁר שָׁמַעְתָּ מִפִּי בִּפְנֵי עֵדִים רַבִּים הַשְׁמַע בָּאָזְנֵי אֲנָשִׁים נֶאֱמָנִים אֲשֶׁר יִכֹּנוּ לְלַמֵּד אֶת־הַדְּבָרִים הָאֵלֶּה גַּם־לְזוּלָתָם׃
\v 3 \vp ג\vp* וּתְנָה שִׁכְמְךָ לִסְבֹּל עִמִּי כְאִישׁ־חַיִל בִּצְבָא יֵשׁוּעַ הַמָּשִׁיחַ׃
\v 4 \vp ד\vp* אִישׁ יֹצֵא לַצָּבָא לֹא־יִתְעָרֵב בְּעִנְיָנִים אֲחֵרִים וְיָפִיק רָצוֹן מִשַּׂר צְבָאוֹ׃
\v 5 \vp ה\vp* וְאַף אִם־יִצְבֹּא צָבָא עוֹד לֹא יַשִּׂיג אֶת־הָעֲטָרָה עַד אֲשֶׁר יִצְבֹּא כַּמִּשְׁפָּט׃
\v 6 \vp ו\vp* הָאִכָּר הָעֹבֵד אַדְמָתוֹ רִאשׁוֹן הוּא לֶאֱכֹל מִפְּרִי תְבוּאָתו׃
\v 7 \vp ז\vp* בִּין בַּאֲשֶׁר־אֲנִי דֹבֵר וְהָאָדוֹן יִתֶּן־לְךָ חָכְמָה בַּכֹּל׃
\v 8 \vp ח\vp* זְכֹר אֶת־יֵשׁוּעַ הַמָּשִׁיחַ אֲשֶׁר קָם מִן־הַמֵּתִים וַאֲשֶׁר יָצָא מִזֶּרַע דָּוִד כִּדְבַר בְּשׁרָתִי׃
\v 9 \vp ט\vp* אֲשֶׁר בַּעֲבוּרָהּ צָרוֹת עָבְרוּ עָלַי עַד אֲשֶׁר עִנּוּ בַכֶּבֶל נַפְשִׁי כְּפֹעֵל אָוֶן אַךְ דְּבַר אֱלֹהִים לֹא יֵאָסֵר בַּכָּבֶל׃
\v 10 \vp י\vp* עַל־כֵּן אֶסְבֹּל כָּל־סֵבֶל לְמַעַן יַשִּׂיגוּ הַבְּחִירִים גַּם־הֵם תְּשׁוּעָתָם בְּיֵשׁוּעַ הַמָּשִׁיחַ וְתִפְאַרְתָּם תִּפְאֶרֶת עוֹלָמִים׃
\v 11 \vp יא\vp* אֱמֶת הַדָּבָר הַזֶּה אִם־נָמוּת עִמּוֹ גַם־עִמּוֹ נִחְיֶה׃
\v 12 \vp יב\vp* אִם־נִסְבֹּל עִמּוֹ גַּם־עִמּוֹ נִמְלֹךְ אִם נְכַחֶשׁ־בּוֹ גַּם־הוּא יְכַחֶשׁ־בָּנוּ׃
\v 13 \vp יג\vp* אִם אֵין אֵמֻן בָּנוּ הוּא בֶאֱמוּנָתוֹ יַעֲמֹד כִּי לְכַחֵשׁ בְּנַפְשׁוֹ לֹא יוּכָל׃
\v 14 \vp יד\vp* אֶת־הַדְּבָרִים הָאֵלֶּה תַּזְכִּיר לִפְנֵיהֶם וְהָעֵד בָּם לִפְנֵי הָאָדוֹן לְבִלְתִּי יָבֹאוּ בְדִבְרֵי רִיבוֹת לְהוֹכַח מִלִּים אֲשֶׁר לֹא יוֹעִילוּ לִמְאוּמָה כִּי אִם־לִמְסֹךְ רוּחַ עִוְעִים בְּלֵב שֹׁמְעֵיהֶם׃
\v 15 \vp טו\vp* בַּקֵּשׁ לִהְיוֹת טָהוֹר כְּכֶסֶף צָרוּף לִפְנֵי אֱלֹהִים כְּפֹעֵל אֲשֶׁר לֹא־יֵבוֹשׁ מִפָּעֳלוֹ וְכַיּוֹדֵעַ לְחַלֵּק דְּבַר־אֱמֶת דָּבָר דָּבֻר עַל־אָפְנָיו׃
\v 16 \vp טז\vp* אַךְ הַרְחֵק נַפְשְׁךָ מִשִּׂיחוֹת חוּלִין וּרְעוּת רוּחַ אֲשֶׁר יִמְשְׁכוּ אֶת־בַּעֲלֵיהֶם לְהוֹסִיף רֶשַׁע לְמַכְבִּיר׃
\v 17 \vp יז\vp* וּדְבַר פִּיהֶם כְּרָקָב יֹאכַל אֲשֶׁר מֵהֶם הוּמְנִיּוֹס וּפִילִיטוֹס׃
\v 18 \vp יח\vp* וְהֵם סָרוּ מִדֶּרֶךְ אֱמֶת לֵאמֹר כִּי־תְחִיַּת הַמֵּתִים כְּבָר הָיְתָה מֵאָז וַיִּהְיוּ לֶאֱמוּנַת רַבִּים לְמוֹקֵשׁ׃
\v 19 \vp יט\vp* אַךְ יְסוֹד הָאֱלֹהִים יָקוּם לָנֶצַח וְזֶה הוּא חוֹתָמוֹ יוֹדֵעַ יְהוָֹה אֵת אֲשֶׁר־לוֹ וְגַם זֶה מִי אֲשֶׁר יִקְרָא בְשֵׁם הַמָּשִׁיחַ יֶחְדַּל מֵעֲשׂוֹת אָוֶן׃
\v 20 \vp כ\vp* אוּלָם בְּבַיִת גָּדוֹל לֹא לְבַד כְּלֵי זָהָב וּכְלֵי כֶסֶף כִּי אִם־גַּם יִמָּצְאוּן שָׁם כְּלֵי עֵץ וּכְלֵי חָרֶשׁ אֲשֶׁר יֵשׁ מֵהֶם לְכָבוֹד וְיֵשׁ מֵהֶם לְקָלוֹן׃
\v 21 \vp כא\vp* וְאִישׁ כִּי־יְטַהֵר נַפְשׁוֹ מֵהֶם וְהָיָה לִכְלִי כָבוֹד לִכְלִי קֹדֶשׁ וְלִכְלִי יְקָר בְּיַד בְּעָלָיו מוּכָן לְכָל־מַעֲשֶׂה טוֹב׃
\v 22 \vp כב\vp* הַרְחֵק לִבְּךָ מִתַּאֲוֹת הַנְּעוּרִים אַךְ רְדֹף צֶדֶק אֱמוּנָה אַהֲבָה וְשָׁלוֹם עִם־כָּל־הַקֹּרִאים בְּשֵׁם הָאָדוֹן מִלֵּב טָהוֹר׃
\v 23 \vp כג\vp* רַק מֵחִקְרֵי כֶסֶל וּרְעוּת רוּחַ חֲדַל לְךָ כִּי מִשָּׁרְשָׁם יִפְרֶה רִיב וּמָדוֹן׃
\v 24 \vp כד\vp* וְלֹא לְעֶבֶד הָאָדוֹן לָרִיב כִּי אִם־לִהְיוֹת נוֹחַ לַכֹּל וּמֵבִין לְלַמֵּד׃
\v 25 \vp כה\vp* וּבְעַנְוַת־חֵן יוֹרֶה אֶת־הַמַּמְרִים אוּלַי יִתֵּן אֱלֹהִים בִּלְבָבָם לָשׁוּב וּלְהַכִּיר אֶת־הָאֱמֶת׃
\v 26 \vp כו\vp* וּלְהִמָּלֵט מֵרֶשֶׁת הַשָּׂטָן אֲשֶׁר פָּרַשׂ לְרַגְלָם וַאֲשֶׁר נִשְׁבּוּ כִּרְצוֹנוֹ׃
\c 3
\cp ג
\cl פרק ג
\p 
\v 1 \vp א\vp* וְעַתָּה דַּע־לְךָ כִּי דֹרוֹת יִוָּלְדוּ בְּאַחֲרִית הַיָּמִים עַד־לְהַשְׁחִית׃
\v 2 \vp ב\vp* כִּי־יָקוּמוּ אֲנָשִׁים אֹהֲבֵי עַצְמָם רֹדְפֵי בֶצַע מַרְחִיבֵי פֶה וְעֵינַיִם רָמוֹת דֹּבְרֵי סָרָה מַמְרִים לְיֹלְדֵיהֶם חֶסֶד לֹא יַכִּירוּ וְכָל־קֹדֶשׁ יְחַלֵּלוּן׃
\v 3 \vp ג\vp* חַסְרֵי רַחֲמִים מְפִירֵי בְרִית וּמְלָשְׁנִים זוֹלְלִים אַכְזָרִים וְשׁנְאֵי כָל־טוֹב׃
\v 4 \vp ד\vp* מֹסְרִים פֹּחֲזִים וְזֵדִים רֹדְפִים לְהִתְעַנֵּג בְּתַעֲנוּגִים מֵהִתְעַנֵּג בֵּאלֹהִים׃
\v 5 \vp ה\vp* וְהֵם פָּנִים לָהֶם כִּדְמוּת יִרְאַת שָׁמַיִם אַךְ מִכֹּחָהּ אֵין בְּקִרְבָּם וְעַל־כֵּן הַרְחֵק נַפְשְׁךָ מֵהֶם׃
\v 6 \vp ו\vp* כִּי־מֵהֶם הֵם הַזֹּחֲלִים לָבוֹא אֶל־הַבָּתִּים לְנַהֵג כִּשְׁבֻיּוֹת חֶרֶב נָשִׁים סָרוֹת טַעַם מְלֵאוֹת עָוֹן וְנַפְשָׁן שׁוֹקֵקָה לְכָל־תְּשׁוּקָה׃
\v 7 \vp ז\vp* הֵן הֵנָּה הַלֹּמְדוֹת תָּמִיד וְלָדַעַת אֶת־הָאֱמֶת אֵין לְאֵל יָדָן׃
\v 8 \vp ח\vp* כִּי־כְמוֹ יַנִּיס וְיַמְבְּרִיס הִתְיַצְּבוּ בִּפְנֵי משֶׁה כֵּן גַּם־אֵלֶּה מִתְיַצְּבִים בִּפְנֵי הָאֱמֶת בָּנִים מַשְׁחִיתִים בְּדַעַת וּנְלוֹזִים בָּאֱמוּנָה׃
\v 9 \vp ט\vp* אַךְ חֶפְצָם לֹא יִצְלַח עוֹד בְּיָדָם כִּי תִגָּלֶה נַבְלֻתָם לְעֵינֵי־כֹל כַּאֲשֶׁר קָרָה גַּם־לַאֲנָשִׁים הָהֵם׃
\v 10 \vp י\vp* וְאַתָּה הָלַכְתָּ בְעִקְּבוֹתַי בְּמַעְגְּלֵי תוֹרָתִי בַּהֲלִיכוֹת חַיַּי וּבִמְגַמַּת פָּנָי בֶּאֱמוּנָתִי בְּאֹרֶךְ רוּחִי בְּאַהֲבָתִי וּבְסִבְלוּת נַפְשִׁי׃
\v 11 \vp יא\vp* וּבִרְדִיפוֹת וּבְצָרוֹת אֲשֶׁר יָדַעְתָּ כִּי אֲפָפוּנִי בְּאַנְטְיוֹכְיָא בְּאִקּוֹנְיָא וּבְלוּסְטְרָא כִּי־שָׁם נִרְדַּפְתִּי עַל־צַוָּארִי עַד אֲשֶׁר־הִצִּילַנִי הָאָדוֹן מִכָּל־רֹדְפָי׃
\v 12 \vp יב\vp* כִּי הֲלֹא כֻלָּם הַחֲפֵצִים בְּחַיֵּי יִרְאַת שָׁמַיִם בְּיֵשׁוּעַ הַמָּשִׁיחַ נִרְדָּפִים הֵמָּה׃
\v 13 \vp יג\vp* אַךְ אֲנָשִׁים רָעִים וְקֹסְמִים כֵּן יָרֵעוּ וְכֵן יַשְׁחִיתוּ מַתְעִים הֵם וְנִתְעִים׃
\v 14 \vp יד\vp* אֳבָל אַתָּה שְׁמֹר אֶת־אֲשֶׁר לָמַדְתָּ וְהִשְׂכַּלְתָּ אֶל־נָכוֹן כִּי יָדַעְתָּ מִי־הוּא אֲשֶׁר מִפִּיו לָמָדְתָּ׃
\v 15 \vp טו\vp* וְכִי־מִנְּעֻרֶיךָ יָדַעְתָּ אֶת־כִּתְבֵי הַקֹּדֶשׁ אֲשֶׁר עַל־יָדָם תַּשְׂכִּיל לְהִוָּשַׁע בֶּאֱמוּנַת יֵשׁוּעַ הַמָּשִׁיחַ׃
\v 16 \vp טז\vp* כָּל־כִּתְבֵי הַקֹּדֶשׁ עַל־פִּי רוּחַ אֱלֹהִים הֵמָּה וּנְכֹנִים לְהוֹרֹת וּלְהוֹכִיחַ לְהָשִׁיב נֶפֶשׁ וּלְיַשֵּׁר בְּמַעְגְּלֵי צֶדֶק׃
\v 17 \vp יז\vp* וְעַל־פִּיהֶם שָׁלֵם יִהְיֶה אִישׁ הָאֱלֹהִים וְנָכוֹן לְכָל־מַעֲשֶׂה טּוֹב׃
\c 4
\cp ד
\cl פרק ד
\p 
\v 1 \vp א\vp* לָכֵן אֲנִי נֶגֶד פְּנֵי אֱלֹהִים וְנֶגֶד פְּנֵי יֵשׁוּעַ הַמָּשִׁיחַ אֲדוֹנֵינוּ אֲשֶׁר יִשְׁפֹּט אֶת־הַחַיִּים וְאֶת־הַמֵּתִים כַּאֲשֶׁר יִגָּלֶה בְמַלְכוּתוֹ הִנְנִי מְצַוְּךָ הַיּוֹם לֵאמֹר׃
\v 2 \vp ב\vp* קְרָא אֶת־דְּבַר בְּשׁרָתוֹ וְלֹא תֶחְדַּל מִקְּרֹא גַּם־בְּעִתּוֹ וְגַם בְּלֹא עִתּוֹ וּבְכָל־אֹרֶךְ רוּחֲךָ הוֹכֵחַ תּוֹכִיחַ וְתִגְעַר וְתַזְהֵר לְפִי כָל־דִּבְרֵי הַתּוֹרָה׃
\v 3 \vp ג\vp* כִּי־יָמִים יָבוֹאוּ אֲשֶׁר לֹא־יָכִילוּ בְנֵי־אָדָם תּוֹרַת חַיִּים כִּי אָזְנֵיהֶם הֻכּוּ בֶחָרֶס וַהֲמוֹן מוֹרִים יִצְבְּרוּ לָהֶם בְּאַוָּתָם לְהִתְגָּרֶד־בָּם׃
\v 4 \vp ד\vp* מִן־הָאֱמֶת יָסִירוּ אָזְנָם לְהַטּוֹת אַחֲרֵי מִשְׁלִי שָׁוְא׃
\v 5 \vp ה\vp* אֲבָל אַתָּה עֲמֹד עַל־מִשְׁמַרְתֶּךָ הִתְעַנֶּה תַּחַת יְדֵי הָרָעָה עֲשֵׂה מְלֶאכֶת הַמְבַשֵּׂר וְכַלֵּה אֶת־עֲבֹדָתֶךָ׃
\v 6 \vp ו\vp* וַאֲנִי נְכוֹנָה נַפְשִׁי לְהִשְׁתַּפֵּךְ עֲלֵי־זָבַח וְעֵת חֲלִיפָתִי בָּאָה׃
\v 7 \vp ז\vp* מִלְחֶמֶת צֶדֶק נִלְחָמְתִּי אֶת־מְרוּצָתִי הִשְׁלַמְתִּי וְאֶת־הָאֱמוּנָה נָצָרְתִּי׃
\v 8 \vp ח\vp* וּלְמִן־הַיּוֹם הַזֶּה צָפוּן לִי כֶּתֶר הַצְּדָקָה אֲשֶׁר בַּיּוֹם הַהוּא יִתֶּן־לִי הָאָדוֹן שֹׁפֵט צֶדֶק וְלֹא־לִי לְבַדִּי כִּי אִם־גַּם לְכָל־הַחֲפֵצִים בְּהִתְגַּלּוֹתוֹ׃
\v 9 \vp ט\vp* חוּשָׁה וּבֹאָה אֵלַי עַד־מְהֵרָה׃
\v 10 \vp י\vp* דִּימָס עֲזָבַנִי כִּי אָהַב אֶת־הָעוֹלָם הַזֶּה וַיֵּלֶךְ־לוֹ לְתַסְלוֹנִיקִי קְרִיסְקִיס לְגָלַטְיָא וְטִיטוֹס לְדַלְמָטְיָא׃
\v 11 \vp יא\vp* וְלוּקָס לְבַדּוֹ נִשְׁאָר עִמִּי קְחָה־נָּא אֶת־מַרְקוֹס וַהֲבִיאֵהוּ עִמְּךָ לַעְזָר־לִי בַּעֲבֹדָתִי׃
\v 12 \vp יב\vp* אֶת־טוּכִיקוֹס שָׁלַחְתִּי לְאֶפְסוֹס׃
\v 13 \vp יג\vp* הָבֵא־נָא אִתְּךָ אֶת־מְעִילִי אֲשֶׁר עָזַבְתִּי בִטְרוֹאַס תַּחַת יְדֵי קַרְפּוֹס וְגַם אֶת־הַסְּפָרִים אַךְ אֶת־הַקְּלָפִים בְּרֹאשָׁם׃
\v 14 \vp יד\vp* אֲלֶכְסַנְדְּרוֹס חָרַשׁ הַנְּחשֶׁת עָשָׂה לִי רָעוֹת רַבּוֹת יְשַׁלֶּם־לוֹ יְהוָֹה כְּמַעֲשֵׂהוּ׃
\v 15 \vp טו\vp* וְגַם־אַתָּה הִשְׁתַּמֵר מִפָּנָיו כִּי הוּא הִתְיַצֵּב בְּפָנַי לַמְרוֹת וּלְהָפֵר דְּבָרֵינוּ׃
\v 16 \vp טז\vp* כַּאֲשֶׁר בָּאתִי לְהִצְטַדֵּק בַּפַּעַם הָרִאשֹׁנָה לֹא־עַמַד אִישׁ אִתִּי כִּי־כֻלָּם עֲזָבוּנִי אַל־יֵחָשֵׁב לָהֶם לְעָוֹן׃
\v 17 \vp יז\vp* אֲבָל הָאָדוֹן הָיָה בְעֶזְרִי וַיְחַזְּקֵנִי לְמַעַן תִּקָּרֵא הַבְּשׁרָה עַל־פִּי וְיִשְׁמְעוּ כָל־הַגּוֹיִם וְגַם־בְּעֶזְרָתוֹ מִפִּי אַרְיֵה נִצָּלְתִּי׃
\v 18 \vp יח\vp* כֵּן יַצִּילֵנִי הָאָדוֹן מִכָּל־רָע וְיוֹשִׁיעֵנִי לָבוֹא אֶל־מַלְכוּת שָׁמָיִם וְלוֹ אֶתֵּן כָּבוֹד לְעוֹלָם וָעֶד אָמֵן׃
\v 19 \vp יט\vp* שְׁאַל לִשְׁלוֹם פְּרִיסְקָה וַעֲקִילָס וּבֵית אֳנִיסִיפוֹרוֹס׃
\v 20 \vp כ\vp* אֲרַסְטוֹס נִשְׁאַר בְּקוֹרִנְתּוֹס וְאֶת־טְרוֹפִימוֹס הִנַּחְתִּי בְּמִילֵטוֹס כִּי חֹלֶה הוּא׃
\v 21 \vp כא\vp* מַהֵר וָבֹא אֵלַי לִפְנֵי יְמוֹת הַחֹרֶף אֶוְבוּלוֹס וּפוּדִיס וְלִינוֹס וּקְלוֹדְיָה וְכָל־אַחֵינוּ שֹׁאֲלִים לִשְׁלוֹמֶךָ׃
\v 22 \vp כב\vp* אֲדֹנֵינוּ יֵשׁוּעַ הַמָּשִׁיחַ עִם־רוּחֶךָ וְחַסְדּוֹ עִמָּכֶם אָמֵן׃ 
