\id MAT - Iatmul NT [ian] -Papua New Guinea 1975 (DBL 2014) 
\h Matyu 
\toc1 Matyu pÉØlÉØwutna 
\toc2 Matyu 
\toc3 Mat 
\mt1 MATYU  
\c 1  
\s1 JISASNA NGWAK WALANGA TAMBA JISASNA YELANGĘMBA LA NĘMBA  
\p
\v 1 Jisas Kraistna yelangÉØmba la nÉØmba kÉØndÉØ kiyandi. Jisasna yelangÉØna njambwi nyan Devit. Devitna ngwak tamba la nyan Ebraham.  
\v 2 Ebrahamna nyan Aisak. Aisakna nyan Jekop. Jekopna nyan Judo ndÉØna yakwa nÉØmbonala.  
\v 3 Judana nyan Peresogwi Saro. MbÉØla nyimena sÉØ Tema. Peresna nyan Hesron. Hesrona nyan Ram.  
\v 4 Ramna nyan Aminadap. Aminadapna nyan Nason. Nasona nyan Salmon.  
\v 5 Salmona nyan Boas. Boasna nyÉØmena sÉØ Rehap. Boasna nyan Obet. Obetna nyÉØmena sÉØ Rut. Obetna nyan Jesi.  
\v 6 Jesina nyan Devit. Devitna tamba la nyambwi kinga. Devitna nyan Solomon. Solomona nyÉØme tat nat nyan kla lat taagwat. LÉØ kat tat kla la nyan sÉØ Yuraia.  
\v 7 Solomona nyan Riaboam. Riaboamna nyan Abaisa. Abaisana nyan Esa.  
\v 8 Esana nyan Jihosafat. Jihosafatna nyan Joram. Joramna nyan Asaia.  
\v 9 Asaiana nyan Jotam. Jotamna nyan Ehas. Ehasna nyan Hesekaia.  
\v 10 Hesekaiana nyan Manasa. Manasana nyan Emos. Emosna nyan Josaia.  
\v 11 Josaiana nyan Jekonaio ndÉØna yakwa nÉØmbonala. Josaia ta njÉØmbla Juda walÉØnja nÉØmba kat kandi kwutaa Bebilonat kalindi.  
\v 12 Kandi kwutaa kalindi maa Jekonaia nyan njandÉØ. NdÉØna nyana sÉØ Sialtiel. Sialtielna nyan Serababel.  
\v 13 Serababelna nyan Abaiat. Abaiatna nyan Elaiakim. Elaiakimna nyan Eso.  
\v 14 Esona nyan Sedok. Sedokna nyan Ekim. Ekimna nyan Elaiat.  
\v 15 Elaiatna nyan Eliesa. Eliesana nyan Matan. Matana nyan Jekop.  
\v 16 Jokopna nyan Josep. Josep ndÉØ Mariana lana. Maria lÉØ Jisasna nyimeak. Jisas Juda kat kwunapmak kat Juda kawiga lÉØnja nyana. NdÉØ ndina Kraistna.   
\p
\v 17 Devitna yelangÉØmba la nÉØmba ndÉØna ngwak walanga taamba vÉØli kiyeli aynat mbaapmamba la nÉØimba ndi. Taamba vÉØli kiyeli aynat wan nyan Ebraham. Isrel kat kandi kwutaa Bebilonat kalinja njÉØmbla ta nÉØmbana yelangÉØ nÉØmba ndina ngwak walanga taamba vÉØli kiyeli aynat mbaapmamba la nÉØmba ndi. Taamba vÉØli kiyeli aynat wan nyan Devit. Kraistna yelangÉØmba la nÉØmba ndÉØna ngwak walanga taamba vÉØli kiyeli aynat mbaapmamba la nÉØmba ndi. Taamba vÉØli kiyeli anyat wan nyan kandi kwutaa kalinja njÉØmbla ta nyana.   
\s1 MARIA JISAS KRAIST KAT KWUTA VAT  
\p
\v 18 Maria Jisas Kraist kat kwukna vak kÉØngiyan. Josep ngangÉØtnya mÉØna kwutndÉØ, kwo yetÉØlÉØ. LÉØla ngway ana tologa yetÉØndÉØ. Godna waagqan lÉØla yapmba nondanyan kwutnjan ngwandÉØndÉØ maa nyan tÉØlÉØ.  
\v 19 Josep lÉØ kat klandangat kwusÉØsÉØvanja nyan apma nyan tagula nyana. Nyan tÉØla vak kat vÉØlaa nat nÉØmba kat mbupmak kat kai waa makasÉØgÉØt yetÉØndÉØ. Kat kiya waweyan Maria wutaa wup yigiyalÉØ waa yelavÉØka yetÉØndÉØ. Wupma yivak kat kai waa yelavÉØka yetÉØndÉØ.  
\v 20 Maawupmba yelavÉØka yetÉØga sÉØndu kwandÉØ, njambwi nyana ensel sÉØmapmba ndÉØ kat yaa wandÉØ. āJosep mÉØn DevÉØtna yelangÉØ nayan mÉØn. Maria kat klavak kat ke kai waga. LÉØla yapmba lÉØga nondanyan nat nduna nyan ana ndÉØ. Godna waagan kwutnjangwanda nyana tÉØga.  
\v 21 Nondanyan kwutÉØ maa ndÉØna sÉØ Jisas waigamÉØn. NdÉØna mbaapmamba lÉØga nÉØmba yilÉØnja kavle vak kat sÉØlÉØmbwigiyandÉØ. Ngi kat tÉØga ndÉØna sÉØ Jisas waigamÉØnā waa wandÉØ Ensel.   
\p
\v 22-23 God tamba la profet kat wandÉØ maa Maria Jisas kat kwuta vak lavu nyingamba pÉØlÉØwutndi.  
\li1 Mat mwunya wiya nyan ngÉØni nondayan kwukiyalw.  
\li1 Wan nyana sÉØ Emanyuel. Wan sÉØna angwa kÉØngiyan.  
\li1 God nÉØnogwinala lÉØgandÉØ,  
\p waa tamba pÉØlÉØwutndi. Kan vak Maria Jisas kat kwutaa vak tamba profet pÉØlÉØwukna vak vla tÉØndÉØ.  
\v 24 Josep sÉØmak valaa laatndÉØ. SÉØmak vÉØlaa laataa Maria kat kai walÉØnda vak kat kwagalalaa lÉØ kat klandÉØ.  
\v 25 Ana lÉØ kat nyway tologa yetÉØndÉØ. Kwo lÉØga nyan tÉØga nyan kwutÉØ. KwutÉØ maa Josep ndÉØna sÉØ Jisas waa wandÉØ.   
\c 2  
\s1 NYA WOKE LA KAYAMBA NAMBUO LA NĘMBA JISAS KAT VIVAT YANDI  
\p
\v 1 Maria Betlehem walÉØnja ngepmamba tÉØga Jisas kat kwutÉØ. Judia walÉØnja kÉØpmamba la ngepma Betlehem. NdÉØ kat kwuta njÉØmbla ndina King Herot ta njÉØmbla. Samat tÉØga nya woke la kavamba la nambuo la nÉØmba sÉØngwut wogwela lÉØndÉØ, vÉØgÉØva Jerusalemat yandi.  
\v 2 Yalaa wagalandi. Juda kat kat njuambwi nyan tÉØvat ya mat nyan andamba lÉØgandÉØ. Nya woke lÉØga kavamba la nÉØmba nÉØn. NdÉØnÉØ sÉØ kwutaa katsovak yanÉØn waa wandi.  
\v 3 King Herot wanja vak kat wutaa ngÉØpaliga ndandÉØ. Jerusalemba la nat nÉØma sakwat nÉØmba wan nyaangÉØt wutaa ngÉØpaliga ndandi.  
\v 4 Ngi kat tÉØga Herot wandÉØ maa God kat kwunata njambwi nÉØmbagwi Moses kwiya nyaangÉØt sÉØmogwi la nÉØmbo kÉØta yisolaa lÉØndi maa Herot ndi kat wagalandÉØ. Juda kat kwunapmak yaiga nyan ndina Kraist anda ngepmamba yalaa lÉØga laakiyandÉØ waa ndi kat wagalandÉØ.  
\v 5 WagalandÉØ maa ngepmamba yalaa lÉØga laakiyandÉØ waa tamba la profet waga  
\v 6-7 God wandÉØ maa tamba pÉØlÉØwutnda lavu nyinga kwutaa vÉØga mbutndi  
\li1 Juda walÉØna kÉØpmamba la Betlehem walÉØna ngepma  
\li1 mat sandÉØ ngepma ana ndÉØ. Nat kavamba lÉØga angwa  
\li1 ngepma wan ngepma kat ana kwula kiyandÉØ. Wuna  
\li1 nÉØmba Iarel ndi kat vÉØga lÉØgiyaa nyan ndina  
\li1 njambwi nyan wan ngepmamba yalaa lÉØga laataa ndi  
\li1 kat vÉØga lÉØgiyandÉØ waa wandÉØ God,  
\p waa pÉØlÉØwutndi tamba la profet vÉØlaa kavamba la nÉØmba kat Herot yagwa wandÉØ maa yand. Yandi maa ndi kat wagalandÉØ. VÉØngwa sÉØngwut anda njÉØmbla wogwelaa lÉØndÉØ, vÉØngwuk waa wagalandÉØ ndi kat.  
\v 8 Mbutndi maa wutaa ndi kat wandÉØ. Betlehemat ay ngwula. SÉØngwut kat vÉØlaa wutaa yagwa mat nyan kat yiga vÉØlaa wun kat yaa mbupmba ngwuk. Wuno ndÉØ kat yiga vÉØlaa ndÉØna sÉØ kwutaa katsovak kat wowun waa ndi kat woseka wandÉØ Herot.   
\p
\v 9 Herotna nyaangÉØt wutaa wogwelaa ngepmamba lÉØga vÉØnja sÉØngwut wogwelaa lÉØndÉØ maa vÉØgÉØva yindi. SÉØngwut yilÉØndÉØ, vÉØgÉØva sÉØngwut yila vla yilÉØndi. NdÉØ kat vÉØgÉØva yilÉØndi maa mat nyan ta ngay sÉØsomba yiga tamata lÉØndÉØ.  
\v 10 SÉØngwut mat nyan ta ngay sÉØsomba tamata lÉØnda vak vÉØlaa apma maawut yelavÉØka solat sÉØga lÉØndi.  
\v 11 Ngay wuleilaa wan mat nyan nyime Marionala tÉØndÉØ, vÉØndi. VÉØlaa kwali mamba sÉØla nambu sÉØlandalaa ndÉØna sÉØ kwutaa katsondi. Ndina yimbwimba la nda ndÉØ kat kwivat kiyanja nda walÉØnja kapa ndÉØ kat windi. Apma njangu veila mbaw ndÉØ kat kwind. Apma njangu velÉØga ngwaak ndÉØ kat kwindi.  
\v 12 Kwindi maa vÉØga kava ke yiga ndÉØ kat sÉØmapmba mbutndÉØ. Herot tÉØga kava ke yiga ndÉØ kat mbuka waa sÉØmapmba ndi kat wandÉØ God. Ngi kat tÉØga yanja yambÉØ kwagalalaa nat ava yambÉØmba yindi ngepma.   
\s1 NYAEK NYĘME NYAN KUVUK NĘMBA ISIP WALĘNJA NĘMA KĘPMAT VAAKA YINDI  
\p
\v 13 Yindi maa njambwi nyana ensel Josep kat sÉØmapmba ngan wandÉØ. Laataa nyan taagwa kwuka. Isipmat vaaka kwiyatapman ay ngwula. Yiga tÉØmÉØn mala at mÉØn kat ngÉØni waigowun. Herot mÉØna mat nyan kat vatnyavak kwatÉØgandÉØ waa wandÉØ maa  
\v 14 Josep ngan laataa nyan nyÉØme kat kwutaa vaaka kwiyatapman Isipmat yindÉØ.  
\v 15 Isipmba yiga yetÉØndÉØ, Herot kiyandÉØ. Wan Isipmat yinja vak kwo ana yindi. Tamba God wandÉØ maa profet pÉØlÉØwukna vak vla yindi.  
\li1 God wandÉØ, wuna nyan Isipmba yiga lÉØndÉØ, ndÉØ kat  
\li1 ngÉØni wowun maa lungwamataa yaigandi waa wandi God  
\p waa tamba la profet pÉØlÉØwutndÉØ.  
\v 16 Nya woke la kavamba tÉØga ya nÉØmba ngÉØni lungwamataa yiga Herot kat ana vÉØndi. Herot ndÉØ yelavÉØtndÉØ. Ndi ana yaigandi. Wun kat woseka wandi waa yelavÉØtaa nyingi maawut yelavÉØka lÉØndÉØ. Ngi kat tÉØga Herot wandÉØ maa ndÉØna soldia Betlehemat mat nondanyangu kat vatnyavat yindi. Tat nya woke la kavamba tÉØga ya nÉØmba ndÉØ kat wandÉØ. NdÉØmwe vÉØlÉØlÉØk tÉØgiya nondangangu kat aywaa kwutaa vatnyamba ngwuk wandÉØ. WandÉØ maa wutaa yiga aywaa vatnyandi.  
\v 17 Vatnyanja vak kat tamba la proget Jeremaia lava nyingamba tamba pÉØlÉØwutndÉØ.   
\p
\v 18 Rama valÉØnja ngepmamba la nÉØmba nÉØma kÉØndÉØgÉØn  
\li1 wutndi. NÉØma vak nyangu kat nglalÉØnja kwundi  
\li1 wutndi. Resel lÉØla nyangu kat nglalÉØlÉØ. YelavÉØka  
\li1 nglalÉØla maawut kat ana alÉØpsÉØga kwunakiyandi.  
\li1 LÉØla nyangu kat aywaa sÉØndi, kiyandi  
\p waa tamba la profet pÉØlÉØwutndÉØ.   
\s1 ISIPMBA LĘGA LUNGWAMATAA YANDI  
\p
\v 19 Herot wundumbu ya vak kat Godna ensel Josep kat sÉØmapmba mbutndÉØ. Josep Isipmba lÉØndÉØ, mbutndÉØ.  
\v 20 Laataa mÉØna nyan taagwa kat kwutaa lungwamataa Isrelat ay ngwula. MÉØna mat nyan vatnyavat ta nÉØmba tamba wundumbu yindi waa mbutndÉØ ensel.  
\v 21 MbutndÉØ maa wutaa laataa nyan taagwa kat kwutaa laataa yindÉØ.   
\p
\v 22 Akeleas ndÉØna nyaek Herot ta njÉØvwa klalaa tÉØndÉØ. NdÉØ Judia walÉØnja kÉØpmamba la kinga. King tÉØnda vak kat Josep wutaa Judiamba yiga yetÉØvak kat vaaka lÉØndÉØ. Vaaka yiga galili walÉØnja kÉØpmamba lÉØndi.  
\v 23 Galili yilaa Nasaret walÉØnja ngepma yiga yetÉØndi. Kwo ana yindi. Jisas Nasaretmba yetÉØnda vak kat tamba la profet pÉØlÉØwutndi  
\li1 Jisas ndÉØ Nasaret nyana waa waigandi  
\p waa tamba pÉØlÉØwutndi.   
\c 3  
\s1 NGU YAGULA JON MBUTA NYAANGĘT  
\p
\v 1 Wan njÉØmbla ngu yagula Jon Judiana nat kava ndÉØnyangu lapma kavamba yalaa nyaangÉØt mbutÉØndÉØ. Mbuka wandÉØ.  
\v 2 Kavle vat yiga yetÉØlÉØngwa vak ngwuk kwagala ngwula. God nÉØn kat vÉØga lÉØgiya njÉØmbla tamba yaa ngway tolagandÉØ.  
\v 3 Tamba la profet Aisaia pÉØlÉØwutnda nyaangÉØt Jon kat pÉØlÉØwutndÉØ.  
\li1 Ndinyangu lapman kavamba lÉØga kÉØta nyan laataa  
\li1 nÉØma kwundimba nyaangÉØt mbutÉØgandÉØ. Njambwi nyan  
\li1 yaiga yambÉØ kat ngwut kwunak ngwula. NÉØn kat  
\li1 yandeya yambÉØ agwuk ngwula waa mbutÉØgandÉØ  
\p waa pÉØlÉØwutndÉØ tamba la profet Aisaia.   
\p
\v 4 Jon kamelna yuwimba kwutnja waavwimba kwusondÉØ. NdÉØna yipmamba sÉØmbÉØmba sÉØtndÉØ. NdÉØ kwapÉØmba la nda wakalavio wanyanyevina ngumba kÉØga lwndÉØ.  
\v 5 Jerusalemba la nÉØmba Judiana ngepma ngepmamba la nÉØimb ndÉØ kat vÉØvat yalÉØndi. Jodan walÉØnja ndandangÉØ ngwaymba lÉØga negpma ndino ndÉØnai la kavat yalÉØndi.  
\v 6 Kavle savle yetÉØlÉØnja vak ndÉØ kat mbuka kavle vat yinÉØn waa wandi maa Jodan walÉØnja ngumba ndi kat ngu yagundÉØ.  
\v 7 Ferisi valÉØnja mbaapmamba la nÉØmbo Sadyusi walÉØnja mbaapmamba la nÉØmbo ndÉØnai la kavat yalwndi ngu yagundangat. Ndi Judana njambwi nÉØimba ndi. Jon ndi kat vÉØlaa wandÉØ. Ngwuk kavle vat yiga yetÉØlÉØga nÉØmba ngwuk. Ngwuk kamboyna nyangu vla lÉØgangwuk. Ngwuk manda kat wuna lak yangwuk. God ngÉØni ndinyangu kat sÉØndeya vak ngwuk ana kwagalagiyangwuk.  
\v 8 Wuna lak ke yangwa. Tak yiga apma njÉØvwa kwuka yetÉØ ngwula. Wupma yetÉØngweyan nat nÉØimb vÉØlaa vaigandi. Ndi kavle vak yetÉØlÉØnja vak tamba kwagalandi waa waigandi.  
\v 9 Ngwuk kupma walÉØgangwuk. NÉØn apma nÉØmba nÉØn. NÉØna ngwak Ebraham tamba la nyana waa walÉØgangwuk. WalÉØngwa vak ana nglaatndÉØ. Ngwuk kavle nÉØmba ngwuk. Ebrahamna yelangÉØmba la nÉØmba yetÉØlwnja vla ana yetÉØlÉØgangwuk. Kavle savle yetÉØlÉØngwa vak kat vÉØlaa God kan kÉØpmamba lÉØga vÉØlÉØngwa kambak klalaa ndu lagwa kwutaa Ebrahamna yelangÉØmba taagandeyan wovuna. Ngwuk kat kai waw kwagalalaa kambapmba mandÉØt nÉØmba kwutaa ngwulai lÉØga yelangÉØmba taagandeyan nglaatndÉØ.  
\v 10 Yaiga nyan kula kwutaa lÉØga nyan vla lÉØgandÉØ. Mi angwamba vÉØkiyandÉØ. Apma mi sÉØk kwalapma yigiya mi vÉØtaa yamba laagagiyandÉØ.   
\p
\v 11 Ngwut kavle maawut kwanalalaa apma maawut yelavÉØka lÉØngwuk maa ngwuk kat kwutaa ngu yagulÉØowun. Wuna kwupmba yaiga nyan ndÉØ ngwuk kat Godna waagan kwigiyandÉØ. Ngwula kavle vat yiga yetÉØlÉØngwa vak kat yamba laagandÉØ, vÉØkiyandÉØ. Wuna kwupmba yaiga nyan wuna njambwi nyana. NdÉØna man su wun ana alÉØpÉØiga kwutaa kalÉØgiyowun. Wun mat nyan wun. NdÉØna njÉØvwa kwupmak kat wup yiga lÉØgowun.  
\v 12 Kavle yuwi sÉØk yamba yaagilÉØnja vak vla ndÉØno kavle nÉØimba kat kwutaa ya vÉØtÉØga kavamba yaagigiyandÉØ. Wan kavamba vÉØtÉØga ya ana ngÉØlÉØgiyandÉØ. Apma yuwi sÉØk klalaa ngaymba yisoga taaga lÉØnja vak vla ndÉØno wupma apma vak tÉØga nÉØmba kat kwutaa ndÉØna ngaymba laagagiyandÉØ.   
\s1 JISAS YANDĘ, JON NDĘ KAT NGU YAGUNDĘ  
\p
\v 13 Jisas Galilimba lÉØga Jotan walÉØnja ndandangÉØ ngu la kavat yindÉØ. Jon ndÉØ kat ngu yagundangat Jisas yindÉØ.  
\v 14 YalÉØnda vak kat vÉØga wutaa Jon Jisas kat wandÉØ. Manda kat mÉØn kat ngu yaguwangat wun kat yamÉØn. Wun kat ngu yagumeya vat wovena wandÉØ Jon.  
\v 15 Jisas ndÉØ kat wandÉØ. Kiat walaa wama vapmba wutaa wun kat ngu yagugiyamÉØn. Wupma yimangat God woviyaguga lÉØgandÉØ was wandÉØ maa wutaa Jon kiyak walaa tÉØga lÉØga wandÉØ. Kwowa wameya vat tamba wulowun. MÉØn kat ngu yagugiyowun waa wandi Jon.   
\p
\v 16 NdÉØ kat ngu yagundÉØ maa ngu yagulas nÉØmbak wokendÉØ. WokendÉØ maa nyinangwuk mbÉØlÉØndÉØ, Godna waagan namiyo vla Jisas ta sÉØsomba ngaga yandÉØ.  
\v 17 Ngaga yalaa tÉØndÉØ maa nyinangwupmba lÉØga kwundi wandÉØ. Wan nyan wuna nyana. NdÉØ kat vÉØlaa woviyaguga solat sÉØlÉØgowun waa nyinangwupmba lÉØga kwundi wandÉØ.   
\c 4  
\s1 SETEN JISAS KAT KAVLE VAT AY WANDĘ  
\p
\v 1 Godna waagan wandÉØ maa Jisas ndinyangu lapman kavat yindÉØ. Seten ndÉØ kat kavle vat ay mÉØla wavat yindÉØ.  
\v 2 Ngan ndumi vÉØli nandinya ndumi vÉØli kÉØgÉØnda lapman kwo lÉØndÉØ. Ngi kat gÉØga wundÉØ kat tÉØndÉØ.  
\v 3 TÉØndÉØ, Seten ndÉØ kat vÉØlaa yalaa wandÉØ. MÉØn Godna nyanat tÉØmeyan wamÉØn maa vÉØga lÉØma kambak bretnat tÉØgiyandÉØ, waa wandÉØ.  
\v 4 WandÉØ maa wutaa Jisas wandÉØ. God waa nyaangÉØt tamba pÉØlÉØwutndi. Kupma pÉØlÉØwutndi.  
\li1 KÉØta nyan bret-nao kÉØvak mÉØna yelavÉØk lÉØndeyan ana nglaatndÉØ aywaa wupmak yelavÉØk kÉØndeyan wan apma vala. God waa nyaangÉØt kan nÉØma nda.  
\p waa tamba pÉØlÉØwutndi waa wandÉØ Jisas.   
\p
\v 5-6 Seten Jisas kat kwutaa Judana angwa ngepma Jerusalemat kalindÉØ. Kaliga yiga God kat kwunatÉØnja ngayna sambangemba taagandÉØ, lÉØndÉØ. Taagalaa Seten ndÉØ kat wandÉØ. Godna nyanat tÉØmeyan laataa kÉØpmat vasaseli. God waa nyaangÉØt tamba pÉØlÉØwutndi  
\li1 God ndÉØ ensel kat wandÉØ maa mÉØn kat vÉØga  
\li1 lÉØgiyandi. Ana kavble yigiyamÉØn. MÉØn kat  
\li1 pwegwukiyandi. Ngi kat tÉØga mÉØna mbangÉØ ana  
\li1 kavle yigiyandÉØ. Kwo lÉØgiyamÉØn  
\p waa tamba pÉØlÉØwutndi waa wandÉØi Seten.  
\v 7 Jisas ndÉØ kat wandÉØ. God wandÉØ, tamba pÉØlÉØwutnja nat nyaangÉØt ngi lÉØga.  
\p God mÉØna njambwi nyana ndÉØ kat kavle vat ay waa ke waa  
\p waa tamba pÉØlÉØwutndi waa wandÉØ Jisas.   
\p
\v 8 Seten Jisas kat kwutaa woke lÉØmbwilaa lan nambu nduwiat kalindÉØ. Kalilaa kÉØpmamba la nda kÉØpmana nÉØmba aywaa ndÉØ kat sÉØmogwindÉØ.  
\v 9 SÉØmogwilaa wandÉØ. Kwali mamba sÉØlaa nambu sÉØlandalaa wuna sÉØ kwutaa katsomeyan wan kÉØpmamba lÉØndÉØ, vÉØlÉØma nda aywaa mÉØna lak kwigiyowun wandÉØ Seten.  
\v 10 WandÉØ maa Jisas wandÉØ. MÉØn Seten wun kat kwagalalaa ay mÉØla. God waa nyaangÉØt tamba kupma pÉØlÉØwutndi.  
\li1 Njambwi nyan Godna sÉØ mÉØna kwutaa katso ngwula.  
\li1 Nat nyan kai. God kÉØta lÉØgandÉØ  
\p waa tamba pÉØlÉØwutndi waa wandÉØ Jisas.   
\p
\v 11 WandÉØ maa Seten tÉØnda kava kwagalalaa yindÉØ. YindÉØ maa Godna ensel yalaa Jisas kat kwunatndi.   
\s1 JISAS GALILI YIGA LĘGA TAT NJĘVWA KWUTNDĘ  
\p
\v 12 Ngu yagu la Jon kat kwutaa kalabusmba laaganja vak kat Jisas wutaa Galili kwagalalaa Kapaneamat yindÉØ.  
\v 13 NdÉØna angwa ngepma Nasaretmba ana lÉØndÉØ. Yinda ngepma Kapaneam Galili walÉØnja sak ngwaymba lÉØndÉØ. Wan kÉØpma Sebyulan waa Naftalai walÉØnja kwpma.  
\v 14 Kan kava kwo ana yindÉØ. Tamba la profet Aisaia pÉØlÉØwuta vak vla yindÉØ. Tamba kupma pÉØlÉØwutndÉØ.   
\li1
\v 15 Sebyulan walÉØnja kÉØpma, Naftalai walÉØnja kÉØpma,  
\li1 Galili walÉØnja sak waymba lÉØga kÉØpma. Jodan  
\li1 walÉØnja ndandangÉØ nat naangÉØmba lÉØga kÉØpma. Juda  
\li1 ana ndi Judagwi ndina wava lÉØga kayana kÉØpma.   
\li1
\v 16 Wan kÉØpmamba la nÉØmba tat tÉØngjan kulun wala la  
\li1 kavamba lindi. Mbambala nya vla sÉØndÉØ, kembandÉØ,  
\li1 vÉØndi. Kulun waa kavle kavamba lÉØgiya nÉØmba  
\li1 ndino nya vla sÉØndÉØ, kembandÉØ, vÉØgiyandi  
\p waa tamba pÉØlÉØwutndÉØ. Jisas yalaa ndi kat apma vat kwindeya vak kat tamba la nayan Aisaia pÉØlÉØwutndÉØ.   
\p
\v 17 TÉØga lÉØga laataa Jisas ndi kat nyaangÉØt mbutÉØndÉØ. Kavle maawut yelavÉØka lÉØngwa vak kwagala ngwula. God ngwuk kat vÉØga lÉØndeya njÉØmbla tamba ngway tolagandÉØ waa mbutndÉØ Jisas.   
\s1 KAMI KWUTA NDI AYNAT NĘMBA KAT JISAS WUNA KWUPMBA YAGWA WANDĘ  
\p
\v 18 Galili walÉØnja sakna tÉØvagawimba Jisas yiga lÉØga kami njulamba kwuta mbÉØk nyamwun sambu kat vwndÉØ. MbÉØtna sÉØ Saimon waa Pita walÉØnja nyano Endruo.  
\v 19 Jisas mbÉØk kat wandÉØ. Laataa wuna kwupmba yagwa mbÉØla. Kami kwutÉØmba vak kwagalalaa ndinyangu kwutÉØmbeya vak kat mbÉØk kat ngÉØni sÉØmogwigiyowun waa wandÉØ maa  
\v 20 laataa njula kwagalalaa ndÉØna kwupmba yimbÉØt.   
\p
\v 21 Yiga lÉØga nat vÉØlÉØ palÉØ nyamwun samb kat nyaekno njaambÉØpmba lÉØga njula kwunatÉØmbÉØk, vÉØndÉØ. MbÉØtna sÉØ Jemsogwi Jono. MbÉØtna nyaekna sÉØ Sebedi. Jisas mbÉØk kat laataa yagwa wuna kwupmba wandÉØ,  
\v 22 laataa nyaeknogwi njaambÉØk kat kwagalalaa ndÉØna kwupmba yimbÉØt.   
\s1 JISAS NĘMA SAKWAT NDU LAGWA KAT NJĘVWA KWUTNDĘ  
\p
\v 23 Jisas Galilina ngepma ngepmamba yiga njÉØvwa kwutÉØndÉØ. Juda nyaangÉØt ngambulÉØnja ngay wuleilaa God ndi kat kwunakiya apma nyaangÉØt mbutÉØndÉØ. MandÉØp mandÉØp yelogwen kat ta nÉØmba kat kwunatÉØndÉØ.  
\v 24 YilÉØnda vak kat vÉØlaa wan kavana nÉØmba kat mbuki mbukimba mbutÉØndi. Ngi kat tÉØga Siria walÉØnja nÉØma kÉØpmamba la nÉØmba aywaa wan nyaangÉØt wutndi. Wutaa ndina mbangÉØ mandÉØp mandÉØp yelogwen vÉØta nÉØmba kat kwutaa Jisas ta kavat kalindi. Kavle waagan tavila la nÉØmbagwi kwutaa kalindi. Ava plaga kÉØpmamba nda la nÉØmbagwi kwutaa kalindi. Man taamba kÉØvÉØ wata la nÉØmbagwi kwutaa kalindi. Jisas ndi kat vÉØlaa aywaa kwunatndÉØ.  
\v 25 Galilimba lÉØga yaa nÉØmba, ngepma tamba vÉØlimba lÉØga yaa nÉØmba, Jerusalemba lÉØga yaa nÉØmba, Judiamba lÉØga yaa nÉØmba, Jotana nat naangÉØmba lÉØga yaa nÉØmba nÉØma sakwat yalaa Jisasna kwupmba yisolaa yindi.   
\c 5  
\s1 JISAS NAMBU NDUWIMBA WOKELAA LĘGA NYAANGĘT MBUTĘNDĘ  
\p
\v 1 Jisas wan nÉØma sakwat nÉØmba kat vÉØlaa nduwiat wokendÉØ maa ndÉØ kat vÉØlaa ndÉØna kwupmba wokendi. Nduwi wokelaa kÉØpmamba ndaa lÉØndÉØ. NdÉØna mbaapmamba la nÉØimba ndaa lÉØnda kavamba yiga yisolaa lÉØndi.  
\v 2 Jisas wan nÉØma sakwat ya nÉØmba kat vÉØlaa ndi kat nyaangÉØt mbutÉØndÉØ.   
\s1 APMA MAAWUT KLALAA SOLAT SĘGA YETĘNEYA VAK KAT JISAS WANDĘ  
\p
\v 3 KÉØta nyan kupma wandeyan. Wun kavle nyan wun. Wuna maawupmba yelavÉØka apma vak yiga ana yetÉØgiyowun. Kapma lÉØga apma vat ana yiga yetÉØgiyowun. God wun kat ava kwindÉØ maa apma vak yiga yetÉØgiyowun waa wandwyan wan nyan nyinangwupmba lÉØga apma nda klaigandÉØ. Klalaa apma vat tÉØgiyandÉØ wan nyan.   
\p
\v 4 Kavle vat yiga yetÉØlÉØga nÉØmba nÉØma maawut yelavÉØka kÉØnjeyan apma vala. God ndi kat kwunatndÉØ maa solat sÉØga lÉØgiyandi.   
\p
\v 5 Nat nÉØmba ndina sÉØ kwusolapman tÉØga yigumba lÉØnjeyan apma vatna. Ndi Godnanamba nÉØma sakwat nda klaigandi.   
\p
\v 6 Nat nÉØmba Godna nyaangÉØt wupmak kat woviyaguga lÉØnjeyan apma vala. Klavak yelavÉØka lÉØnja nda God ndi kat kwigiyandÉØ.   
\p
\v 7 Nat nÉØmba kat miwa yiga lÉØgiya nÉØmba apma vatna. God ndi kat miwa yiga lÉØgiyandi.   
\p
\v 8 Apma tagula maawutno lÉØgiya nÉØmba apma vatna. NgÉØni God kat vÉØgiyandi.   
\p
\v 9 Waleavak kat ndinyangu sÉØvak kat kai waga wupma ke yingwa waa walÉØga nÉØmba ndi. God ndi kat waigandÉØ. Ngwuk wuna nyangu ngwuk waa waigandÉØ.   
\p
\v 10 Nat nyangu Godna apma njÉØvwa kwutindi, vÉØlaa nat kavle nyangu ndi kat vat yilÉØnjeyan apma vatna. Nyinangwupmba lÉØga nyan kwigiya apma nda wundi apma nÉØmba klaigandi waa wandÉØ Jisas.   
\p
\v 11-12 Jisas ndi kat nat nyaangÉØt ngambundÉØ. Ngambuga wandÉØ. Wuna kwupmba yalÉØngwa vak kat vÉØlaa ngwuk kat kavle vat yiga njÉØka waga woseka walÉØnjeyan ngwuk nÉØma vak ke yelavÉØkngwa. Ngwuk apma maawuk sÉØka solat sÉØga yetÉØ ngwula. Ngwuk kat yilÉØnja kavle vak vla tamba la profet kat wupma yilÉØndi.   
\s1 SOLOGWI NYA VLA LĘGA NYAN KAT JISAS WANDĘ  
\p
\v 13 KÉØlÉØnja sol yuvut kÉØgindamba taagandi, ana njangu veiga kavle yigiyandÉØ. Ngwulo wupma kÉØlÉØnja sol vla lÉØga kÉØpmamba lÉØga nÉØmba kat kwunatÉØgangwuk. Sol nyingi lÉØga vat ngÉØlÉØndyan ngÉØni kwunatndeya vak kai. Tamba kavle yindÉØ. Ava yambÉØmba yaagindi maa yi ya lÉØga nÉØmba mamba veiga yetÉØlÉØgandi.   
\p
\v 14 Ngwuk kÉØpmamba lÉØga kemba lÉØga nda vla lÉØgangwuk. Nambu nduwinmba ngepma kwutaa lÉØnjeyan ana alÉØpÉØiga pagwugiyandi. Wan ngepma aywaa vÉØgiyandi.  
\v 15 Kita nyan lam sagalalaa aw yapmba ana naangagiyandÉØ. NjambÉØmba wokega taagaiyandÉØ. TaagandÉØ mala kembalÉØndÉØ, ngaymba lÉØga nÉØmba aywaa vÉØga lÉØgiyandi.  
\v 16 Lam njambÉØmba taaganda vak vla kwutÉØngwa apma njÉØvwa kapmba agwuk ngwula. Ndinyangu aywaa vÉØlaa ngwutna nyinangwupmba lÉØga nyaekna sÉØ kwutaa wiyak waa katsogiyandi.   
\s1 MOSES KWIYA LO KAT JISAS MBUTNDĘ  
\p
\v 17 Jisas Moses kwiya lo kat kalÉØpmat yandÉØ waa ke yelavÉØkngwa. Wungi vak kat ana yawun. NdÉØnai kwuta la lonana angwa nyaangÉØt mbupmat yawun.  
\v 18 Maawut ke sÉØlÉØwoka yetÉØngwa. YelavÉØka yetÉØ ngwula. Moses kwiya lomba tÉØga nyaangÉØt aywaa ana kwo vatnat tÉØgiyandÉØ. Nginangwutno kÉØpmo tÉØgiyaa njÉØmbla wan nyaangÉØt tÉØgiyandÉØ. Ngingwutno kÉØpmo ngÉØlÉØndÉØ, ndÉØna lo ngÉØlÉØgiyandÉØ.  
\v 19 KÉØta nyan lo kat kai waga nat nÉØmba kat kalÉØtÉØnda vat sÉØmogwindeyan ndÉØ nyinangwat wuleilaa mat nyanat tÉØgiyandÉØ. KÉØta nyan lona nyaangÉØt wuke kwutaa yetÉØga nat nÉØmba kat yetÉØnda vak sÉØmogwindeyan ndÉØ nyinangwut wuleilaa njambwi nyanat tÉØgiyandÉØ.  
\v 20 Moses kwiya lo vÉØsÉØmogwi lÉØga nÉØmbagwi Ferisio maawut sÉØtapman nÉØma njÉØvwa kwuka lo waa nyaangÉØtmba yetÉØlÉØgandi. Wundi nÉØmba nyinangwut ana wuleigiyandi. Wundi nÉØmba yetÉØga vak kat kwulataa apma maawut yelavÉØka apma vak yetÉØngweyan nyinangwut wuleigiyangwuk. YetÉØnja vak kat kwulatapman yingweyan ana nyinangwut wuleigiyangwuk.   
\s1 KWONDU MAAWUT MĘNA YELAVĘTNJA VAK  
\p
\v 21 Tamba mbutnja nyaangÉØt tamba wutÉØngwuk. Nat nyan kat ke vatnyapga. Vatnyangweyan kotngwangat kaligiyandi waa tamba mbutndi.  
\v 22 Mbambala ngwuk kat mandÉØt kupi nyaangÉØt mbutÉØgowun. KÉØta nyan ndÉØna yakwa nyan kat nyigi maawut tÉØga walealÉØndeyan ndÉØ kat kotndangat kaligiyandi. KÉØta nyan ndÉØna yakwa nyan kat mÉØn kavle nyan mÉØn waa wandeyan ndÉØ kat kaunsilmba kotndangat kaligiyandi. KÉØta nyan ndÉØna yakwa nyan kat mÉØn tungwengan yiga yetÉØga nyan mÉØn waa wandeyan wan nyan ya vÉØtÉØga kavat yigiyandÉØ.   
\p
\v 23-24 God kat kwunapmak tÉØga wuna yakwa nyan kat tamba kavle vat yiwun waa yelavÉØpmeyan kwilÉØma nda njambÉØ ngwaymba taagalaa kwagalalaa yakwa nyan kat yiga avÉØ. NdÉØ kat kavle vat yilÉØma vak kwunataa at yiga God kat kwunapmak agwi.   
\p
\v 25 KÉØta nyan mÉØn kat kotmak kalindeyan ava yambÉØmba yiga lÉØga kavle vak kat kwunap mÉØla. Kwunatapman yimeyan jas wandÉØ, plisman mÉØn kat kalambusmba taagagiyandi.  
\v 26 MÉØn kat woseka ana wowun. Kalabus ana kwo kwagalagiyamÉØn. Jas mÉØn kat wand mbak ngÉØlÉØndÉØ maa wogwegiyamÉØn.   
\s1 YAMBĘSĘK YILĘNJA VAK KAT JISAS KAI WANDĘ  
\p
\v 27 Tamba la nÉØmba tamba mbutÉØnja nyaangÉØt tamba wutÉØngwuk. NÉØmbana taagwa kat yambÉØsÉØk yilÉØnja vak ke yiga yetÉØlÉØngweya waa mbutÉØndi.  
\v 28 Kan mbambala ngwuk kat mandÉØt kupi nyaangÉØt mbutÉØgowun. KÉØta nyan nat nÉØmbana taagwa kat mÉØnimba vÉØlaa yambÉØsÉØk yilÉØnja vak kat maawupmba yelavÉØtndeyan wan kavle vatna. YambÉØsÉØk yilÉØnja vak vla lÉØgandÉØ.  
\v 29 Yaagindan naangÉØ lÉØga mÉØni sÉØkmba kavle vak vÉØlaa kavle vak yelavÉØka kavle vak yilÉØmeyan wan mÉØni sÉØk kuvu ngwula yaagi. MÉØni sÉØk tapman tÉØmeyan nÉØma vak ana ndÉØ. Ya vÉØtÉØga kavat yimeyan wan nÉØma vatna.  
\v 30 Yaagindan taambamba kavle vat yilÉØmeyan wat taamba kalÉØtaa yaagi. KÉØta naangÉØ taambambaa yetÉØmeyan wan nÉØma vat ana ndÉØ. Ya vÉØtÉØga kavat yimeyan wan nÉØma vatna.   
\s1 NDU TAAGWA KAT KWAGALANDA VAK  
\p
\v 31 Tamba la nÉØmba tamba mbutÉØnja nyaangÉØt tamba wutÉØngwuk. KÉØta nayan ndÉØna taagwa kat kwagalavat yelavÉØtndeyan pas mÉØna pÉØlÉØwutaa lÉØ kat kwilaa kwagalagiyandÉØ. NyaangÉØt kai, waa tamba la nÉØmba mbutÉØndi.  
\v 32 Mbambala ngwuk kat mandÉØt kupi nyaangÉØt mbukiyowun. KÉØta nyana taagwa yambÉØsÉØk yiga ana yetÉØlÉØ. LÉØla lan lÉØ kat kwo waga kwo lÉØ kat kwagalandÉØ. Wupma yinda vak wan kavle vatna. Wupma kwagalandÉØ maa nat ndu kat yiga ngway tololeyan yambÉØsÉØk taagwat tÉØgiyalÉØ. NgÉØni yila nyan ndÉØ yambÉØsÉØk nduat tÉØgiyandÉØ ndÉØno.   
\s1 NĘMA SAKWAT NYAANGĘT MBUTĘNJA VAK  
\p
\v 33 Tamba la nÉØmba tamba mbutÉØnja nyaangÉØt tamba wutÉØngwuk. NÉØma njÉØvwa kwukiyanÉØn woseka ana waiganÉØn. God vÉØga lÉØgandÉØ waa nÉØma kwundimba wandweya njÉØvwa agwuk ngwula waa tamba la nÉØmba wandi. Woseka ke wangweya waa wandi. Wan nÉØma kwundimba walÉØnja vak ke walÉØngweya.  
\v 34 Kan mbambala ngwuk kat mandÉØt kupi nyaangÉØt mbukiyowun. NÉØma njÉØvwa kwukiyanÉØn. Woseka ana wanÉØn nyinangwut tÉØga nÉØmba vÉØga lÉØgandi waa ke waa. Wan nÉØma kwundimba walÉØnja vak ke walÉØngweya. Nyinangwut vÉØga lÉØngwa kava ana ndÉØ. God ndaa lÉØga tÉØgÉØtna nyinangwut.  
\v 35 NÉØma njÉØvwa kwukiyanÉØn. Woseka ana wanÉØn. KÉØpma lÉØga nÉØmba vÉØga lÉØgandi waa ke waa. KÉØpma vÉØga lÉØngwa kava ana ndÉØ. God nyinangwupmba ndaa lÉØga lÉØngwa kava ana ndÉØ. God nyinangwupmba ndaa lÉØga man veila lÉØnda kava kÉØpma. NÉØma njÉØvwa kwukiyanÉØn. Woseka ana wanÉØn. God vÉØga lÉØga nÉØma ngepma Jerusalemba lÉØga nÉØmba vÉØga lÉØgandi waa ke waa. Wupma wangweyan wan kavle vatna.  
\v 36 NÉØma njÉØvwa kwukiyanÉØn. Woseka ana wanÉØn. Wundi nÉØma njÉØvwa kwutapman yineyan nÉØna nambumba lÉØga yuwi kavle yigiyandÉØ waa ke waa. Ngwutna nambu tÉØga vak ana vÉØga lÉØgangwuk. Wangwut maa ngwula nambuna nÉØmba sawun mbangÉØ tÉØga ngÉØk mbangÉØ tÉØgiyandÉØ? kai.  
\v 37 Ngwuk kat nyaangÉØt wagalanjeyan awa o kai waa awa ndi kat. Wan nÉØma kwundimba ke wangweya. Nat nÉØma sakwat nyaangÉØt ngwuk ke waga. Nat nÉØma sakwat kavle nyaangÉØt Setenanamba ngwuk klalÉØgangwuk.   
\s1 AWAT SOWAT KAVLE VAT YILĘNJA VAK  
\p
\v 38 Tamba la nÉØmba tamba mbutÉØnja nyaangÉØt tamba wutÉØngwuk. KÉØta nyan mÉØna mÉØni kavle yindeyan awat ndÉØna mÉØni kat kavle vat ay. KÉØta nyan mÉØna nÉØmbi kavle yindeyan awat ndÉØna nÉØmbi kat kavle vat ay waa tamba la nÉØmba pÉØlÉØwutndi.  
\v 39 Kan mbambala ngwuk kat mandÉØp kupi nyaangÉØt mbutÉØgowun. KÉØta nyan ngwuk kat kavle vat yindyan ndÉØ kat awat kavle vat ke yiga. Ngwula ngangava viyandeyan ndÉØ kat nat naangÉØ lÉØga ngangavamba agwi viyandangat.  
\v 40 KÉØta nyan ngwula waavwi klavat ngwuk kat kotmak kalindeyan ndÉØ kat agwi. Kwilaa alagu kwusolÉØngwa waavwi klalaa agwi.  
\v 41 KÉØta nyan mÉØn kat yiweya yambÉØ kÉØta vat yili waa wandeyan yivak kat wanda sÉØvla kwulaka ay mÉØla. Wuna kwanda kwanda nda kwutaa mail kÉØta yiga kali mÉØla waa wandeyan ndÉØna nda kwutaa mail vÉØlÉØlÉØk kali mÉØla.  
\v 42 KÉØta nyan ngwuk kat kÉØta nda klavak kat wagalandeyan agwi ngwula. KÉØta nyan wun kat mÉØna nda agwi ngÉØni awat kwigiyowun wandeyan ndÉØ kat agwi.   
\s1 MAAMA NĘMBA KAT YINGWEYA VAT  
\p
\v 43 Tamba la nÉØmba tamba mbutÉØnja nyaangÉØt tamba wutÉØngwuk. Ngwutna alÉØ nÉØmba kat woviyaguga lÉØga ndi kat kwunak ngwula. Ngwutna maama nÉØmba kat ndi kat kai awa waa tamba mbutÉØndi.  
\v 44 Kan mbambala mandÉØp kupi nyaangÉØt ngwuk kat mbukiyowun. Ngwutna maama nÉØmba kat ndi kat woviyanguga lÉØga ndi kat kwunak ngwula. Ngwuk kat kavle vat yilÉØga nÉØmba kat ndi kat tÉØga God kat wagala ngwula.  
\v 45 Maama nÉØmba kat apma vat yingweyan ngwutna nyinangwapmba lÉØga nyaekna nyanguat tÉØgiyangwuk. God wandÉØ maa nya sÉØndÉØ, apma vat tÉØga nÉØmba kavle vat tÉØga nÉØmba aywaa ndÉØna ambukatna kÉØgÉØnda waatÉØgandÉØ. God wandÉØ maa meik ndandÉØ, apma vat tÉØga nÉØmba kavle vat tÉØga nÉØmba aywaa ndina ambukatna kÉØgÉØnda waatÉØgandÉØ.  
\v 46 Takis sanya klalÉØga kavle nÉØmba ndi kat woviyaguga lÉØga nÉØmba kat mÉØna apma vat yilÉØgandi. Ngwuk kat woviyaguga lÉØga nÉØmba kat mÉØna apma vat yiga yetÉØngweyan God ngwuk kat apma wenga ana kwigiyandÉØ. Ngwuk ndinyangu aywaa ndi kat apma vat ay ngwula.  
\v 47 God kat kai walÉØga nÉØmba ndina ava nÉØmba kat mÉØna apma nandinya walÉØgandi. Ngwula ava nÉØmba kat mÉØna apma nandinya wangweyan wan apma vat ana ndÉØ. Ngwuk ndinyangu aywaa ndi kat apma nandinya awa ngwula.  
\v 48 Nyinangwupmba lÉØga ngwula nyaek apma vat yilÉØnda vak mÉØna ngwulo wupma yiga yetÉØ.   
\c 6  
\s1 NAT NĘMBA KAT MIWA YIGA KWINGWEYA VAK KAT JISAS NDI KAT MBUTNDĘ  
\p
\v 1 Ngwuk vÉØga wuka lÉØgiyangwuk. Nat nÉØmba kat apma vat yingweya vat kapmba ke kwuka. Nat nÉØmba vÉØlandi. VÉØnjeyan ngÉØni ngwuk kat nyinangwupmba lÉØga nyaek wenga ana kwigiyandÉØ.  
\v 2 Sanya lapman kwanda kwanda lapman tÉØgiyaa nyan kat kwivat tÉØngweyan nyaangÉØt ke tak tapmba mbuka. Nat nÉØmba avla ndina sÉØ kwutaa kwusolÉØga nÉØmba ndi. Ndi Juda nyaangÉØt ngambulÉØga ngaymba wuleilaa ava yambÉØmba yilaa nyaangÉØt mbutaa mÉØna kwilÉØgandi. Nat nÉØmba kat kwilÉØnja vak vÉØlaa ndina sÉØ kwutaa katsonjangat tat tapmba nyaangÉØt mbutÉØgandi. Ndi ndina wenga nda ndinyangunanamba tamba klandi. Nyinangwupmba lÉØga nÉØna nyaeknanamba ana klaigandi.  
\v 3 Sanya lapman kwanda kwanda lapman nyan kat kwivat tÉØngweya nda pagwuga agwi ngwula. Ngwulogwinala lÉØga nÉØmba vÉØlandi.  
\v 4 Pagwuga kwingweyan nÉØna nyaek vÉØga lÉØgandÉØ. VÉØlaa apma wenga ngwuk kat kwigiyandÉØ.   
\s1 GOD KAT WAGALANGWA VAK KAT JISAS NDI KAT MBUTNDĘ  
\p
\v 5 God kat wagalangweya njÉØmbla kapmba laataa wagala lÉØnja vla ke wagalangwa. Wundi nÉØmba avla ndina sÉØ kwutaa kwuso lÉØga nÉØmba ndi. Ndi Judana nyaangÉØt ngambulÉØnja ngay wuleilaa way ava yambÉØmba lÉØga laataa God kat wagalalÉØgandi. Nat nÉØmba ndi kat vÉØnjangat kapmba laataa wagalalÉØgandi. Ngwuk kat woseka ana wowun. Ndi wenga lamba klandi ndinyangunanamba.  
\v 6 God kat wagalangweya njÉØmbla wupma ke wagalangwa. Ngay weleilaa ngay kamanga kwalalaaa pagwula lÉØga kavamba tÉØga God kat wagala ngwula. Nyinangwupmba lÉØga nÉØna nyaek papwula lÉØga wagalangweya vat vÉØga wutaa apma wenga ngwuk kat kwigiyandÉØ. NdÉØno pagwula lÉØgandÉØ. NdÉØna mbangÉØ ana vÉØlÉØganÉØn.   
\p
\v 7 God kat wagalangweya njÉØmbla nÉØma sakwat kwo nyaangÉØt ke ngambuga. Ngepma ngepma la God kat vÉØlapman nÉØmba ndina ngepma waagan kat wupma mandÉØt mandÉØt walÉØgandi. SÉØvla mbundÉØ nyaangÉØt ngambuneyan nÉØna waagan wukiyandÉØ waa yelavÉØtaa ngambulÉØgandi.  
\v 8 Wupma ngambulÉØnja vak vla ngwuk ke ngambuga. NÉØna nyaek ngÉØni wagalangweya vat ndÉØ mbambala vÉØga lÉØgandÉØ. Manda kat nÉØma sakwat nyaangÉØt ngambuga ndÉØ kat wagalagiyangwuk. NÉØma sakwat nyaangÉØt ngwuk ke wagalaga.  
\v 9 God kat ngambuga wagalangweya njÉØmbla kupma ngambungwula waa wandÉØ Jisas.  
\li1 NÉØna nyaek nyinangwupmba lÉØgamÉØn. MÉØna sÉØ waga  
\li1 kwutaa katsonjeyan apma vatna. MÉØn nÉØma nyan mÉØn.   
\li1
\v 10 Kava kava kat vÉØga lÉØmeya njÉØmbla yaandÉØ. Wungi  
\li1 vat yandeyangat woviyanguga lÉØganÉØn. Mbambala  
\li1 nyinangwupmba lÉØga nÉØmba aywaa mÉØna kwundi wuka  
\li1 lÉØgandi. NÉØno kÉØpmamba lÉØga nÉØmba aywaa mÉØna  
\li1 kwundi wutneya njÉØmbla nÉØn kat yaandÉØ. Wungi vat  
\li1 yandeya njÉØmbla kat woviyaguga lÉØganÉØn.   
\li1
\v 11 Mbambala kÉØneya kÉØgÉØnda nÉØn kat agwi mÉØla.  
\v 12 NÉØn  
\li1 nat nÉØmba nÉØn kat kavle vat yinja vak kat vÉØlaa  
\li1 kwagalaÉØganÉØn. MÉØno yina kavle vak kat vÉØlaa  
\li1 kwagala mÉØla.  
\v 13 Kavle vat nÉØn kat yaa kwutandÉØ.  
\li1 WamÉØn maa ana nÉØn kat yaa kwukiyandÉØ. Seten nÉØn  
\li1 kat kwutaa lÉØlÉØndÉØ. WamÉØn maa ndÉØ ana nÉØn kat  
\li1 kwutaa lÉØgiyandÉØ waa God kat wagala ngwula.   
\p
\v 14 Jisas wandÉØ. Ngwuk kat wowun. Nat nÉØmba ngwuk kat kavle vat yinja vak kat vÉØga kwagalangweyan nyinangwupmba lÉØga nÉØnÉØ nyaek yingweya kavle vat vÉØga kwagalagiyandÉØ.  
\v 15 VÉØga kwagalalapman yingweyan ndÉØno ana vÉØga kwagalagiyandÉØ waa wandÉØ Jisas.   
\s1 KĘGĘNDA KĘVAK KAT KAI WALĘNGWA VAK KAT JISAS MBUTNDĘ  
\p
\v 16 Nat njÉØmbla kÉØgÉØnda kÉØvak kat kai walaa God kat mÉØna wagalalÉØgangwuk. KÉØgÉØnda kÉØvak kat kai waa lÉØngweya vak nat nÉØmba mbak vÉØlandi. MÉØndama sÉØli lÉØpmwiga ke lÉØga. Nat nÉØmba avla ndina sÉØ kwusolÉØga nÉØmba ndi wupma yilÉØgandi. Wupma mÉØndama sÉØli lÉØpmwiga nat nÉØmba vÉØnjangat tÉØlÉØgandi. Ndina mÉØndama vÉØlaa ndi kÉØgÉØnda kÉØvak kat kai walaa kwo lÉØgandi. Apma nÉØmba ndi waa waigandi. Wan ana nglaatandÉØ. Awuk ngwula. Ndi wenga tamba ndinyandgunanamba klandi. NgÉØni Godnamba ana klaigandi.  
\v 17 KÉØgÉØnda kÉØvak kat kai waa kwagalalaa mbangÉØ njangulaa sanda nÉØmbi kwuka mbangÉØ kwutaa apma mÉØndama vÉØga lÉØngweyan wovuna.  
\v 18 God kat wagalavat kÉØgÉØnda kÉØvak kat kai waa kwagalalaa tÉØngweya vat nat nÉØmba vÉØlandi. NÉØna nyaek ndÉØ vÉØlaa apma wenga ngwuk kat kwigiyandÉØ. NdÉØno pogwula lÉØga nyana. NÉØna mÉØni ndÉØna mbangÉØ ana vÉØga lÉØganÉØn.   
\s1 NYINANGWUPMBA APMA NDA YISOGA TAAGANGWEYA VAK KAT JISAS NDI KAT MBUTNDĘ  
\p
\v 19 Kan kÉØpmamba ke nÉØma sakwat kwanda kwanda yisoga taagaga. NdÉØkna kwutÉØndÉØ, vÉØlÉØngÉØni kalÉØtÉØgandÉØ. Kun kÉØga lÉØgiyandi. SÉØkwutÉØga nÉØmba weleilaa tÉØvwi ngÉØlÉØka sÉØkwukiyandi.  
\v 20 Nyinangwupmba nÉØma sakwat kwanda kwanda yisoga taagangweyan wovuna. NdÉØkna ana kwukiyandÉØ. VÉØlÉØngÉØni ana kalÉØkiyandÉØ. Kun ana kÉØga lÉØgiyandÉØ. SÉØkwutÉØga nÉØmba ana tÉØvwi ngÉØlÉØka sÉØkwukiyandi.  
\v 21 Ngwutna kwand kwanda nda yisoga taagangwa kavakat mÉØna nÉØmamba maawupmba yelavÉØka lÉØgiyangwuk. Kwanda kwand kÉØpmamba yisoga taaga lÉØga nÉØmba kÉØpmana nda kat mÉØna yelavÉØka lÉØgandi. Kwanda kwanda nyinangwupmba yisoga taagalÉØga nÉØmba nyinangwutna nda kat mÉØna yelavÉØka lÉØgiyandi.   
\s1 MĘNI NGAYNA NDAAMANGE VLA LĘGANDĘ WAA JISAS MBUTNDĘ  
\p
\v 22 Ngwutna mÉØni ngay wuleinja ndaamange vla lÉØgandÉØ. MÉØnimba vÉØngwuk, nÉØma sakwat vak ngwula mbangÉØ wuleigiyandÉØ. Apma nda mÉØna vÉØga lÉØngweyan ngwula mbangÉØ ngwula maawut apma vat tÉØgiyandÉØ.  
\v 23 Kavle nda mÉØna vÉØga lÉØngweyan ngwula mbangÉØ maawut kavle yigiyandÉØ. Apma nda ngwula maawut weleigiya nat yambÉØ kai. Kavle vat mÉØna wuleindyan wan kavle nglei vatna. Apma vat ana ndÉØ.   
\s1 NĘMA NYAN VĘLĘLĘKMBA KĘTA NYAN ANA ALĘPSĘGA NJĘVWA KWUKIYANDĘ WAA JISAS MBUTNDĘ  
\p
\v 24 Ndu nyan kÉØta nÉØma nyan vÉØlÉØlÉØkmba ana njÉØvwa kwukiyandÉØ. Nat nÉØma nyan kat kai walaa nat nÉØma nyan kat mÉØna yelavÉØka lÉØgiyandÉØ. Nat nÉØma nyana kwundi wupmak kat kai walaa nat nÉØma nyana kwundi mÉØna wuka lÉØgiyandÉØ. Ngwutno wungi vat tÉØga nÉØmba ngwuk. Godna njwvwa kwukawi sanya njÉØvwa kwukawi ana kwukiyangwuk.   
\s1 NĘMA MAAWUT YELAVĘKA LĘLĘNJA VAK KAT JISAS NDI KAT MBUTNDĘ  
\p
\v 25 Ngi vak kat ngwuk kat wowun. KÉØngweya nao kÉØgÉØnda ngu kat nÉØmamba ke yelavÉØtÉØngwa. Kwusongweya waavwi kat ke nÉØmbamba yelavÉØtÉØngwa. Wan kÉØgÉØnda nÉØma vat ana ndÉØ. Waavwi nÉØma vat ana ndÉØ. God waa nyaangÉØt wuka apma vat mÉØna yiga yetÉØneyan wan nÉØma vatna.  
\v 26 Wan wiyaka yi yalÉØga waavi kat avÉØ ngwula. Ndi ambkat njÉØvwa ana kwutÉØgandi. Ndi ambukatna nda ana vaga yiga kÉØga kwutÉØgandi. Ndi ambukatna nda ana vaga yiga kÉØga kavamba yisoga taagalÉØgandi. Nyinangwupmba lÉØga nÉØna nyaek ndi kat vÉØga lÉØgandÉØ. NÉØno nÉØn kat vÉØga lÉØgandÉØ. Waavi mat nda. NÉØn ndinyangu nÉØma nda nÉØn.  
\v 27 NÉØma vak yelavÉØka yetÉØngwa vak nÉØma njÉØvwa kwutÉØga vak ana ndÉØ. KÉØta nyan wundumbu yivak kat vaaka nÉØma maawut yelavÉØka lÉØndeyan ndÉØna lÉØvÉØ nÉØmba kat ana kwulakiyandÉØ. Wundumbu yivak kat vaatapman tÉØgiya nyan kat ana kwulala kwo yetÉØgiyandÉØ. NdÉØ kiyaigandÉØ.   
\p
\v 28 Kwusoga yetÉØngweya waavwi kat manda kat nÉØmbamba yelavÉØka lÉØgangwuk. KÉØpmamba avla waataa lÉØlÉØga mwe ndi kwuso waavwi kat ana yelavÉØka lÉØlÉØgandi. Mwe ana njÉØvwa kwuka waavwi klalaa tavaga yelaga lÉØgandi.  
\v 29 Tamba la King Solomon ndÉØ apma nglei waavwi kwusoga lÉØndÉØ. NdÉØna kwuso lÉØnda waavwi mwena mbangÉØ kat ana kwulatÉØndÉØ. Mwena mbangÉØ ndÉØna waavwi kat kwulatÉØndÉØ.  
\v 30 Avla waatÉØga nda kat God ndi kat apma yelaga nda kwilÉØgandÉØ. Avla waatÉØga nda nÉØma nda ana ndÉØ. SÉØvla mbundÉØ ana lÉØlÉØgandÉØ. Ndinyangu kalÉØka kÉØta lÉØvwimba yisolaa ya sagalandÉØ, vÉØka ngÉØlÉØlÉØgandi. NÉØn ndinyangu wupma lÉØga nda ana nÉØn. NÉØn nÉØma nda nÉØn. God nÉØn kat vÉØga lÉØga kwusoneya waavwi kwigiyandÉØ. Ngwuk nÉØma maawut ke yelavÉØka lÉØngweya. Ngwuk God kat wagala ngwula.  
\v 31 KÉØweya nao kÉØgÉØnda ngu andamba lÉØndÉØ, klaigowun kwusoga yetÉØweya waavwi andamba lÉØndÉØ, klaigowun waa ke nÉØmamba yelavÉØtÉØngwa.  
\v 32 Godna sÉØ wutapman ta nÉØmba ndino wupma nÉØma maawut yelavÉØka lÉØndi. Ngwuk Godna nyangu ngwuk. NdÉØ ngwuk kat vÉØga lÉØga miwa yiga kwigiyandÉØ.  
\v 33 Wan nda kat ngwuk nÉØma maawut ke yelavÉØka lÉØngwa. Godna kwundi wupmak kat mÉØna nÉØma maawut yelavÉØka lÉØngweyan ndÉØna apma vak kwilaa kan kÉØpmana nda ngwutna lak kwigiyandÉØ.  
\v 34 NgÉØni yaiga vak kat ke ngwuk nÉØma maawut yelavÉØka lÉØngwa. Yaiga vak ngÉØni yaigandÉØ. Nandinya nandinya nÉØma vat tÉØgiyandÉØ. Ngwuk mand kat yaiga vak kat nÉØma maawut yelavÉØka lÉØgiyangwuk. Ana nglaatndÉØ.   
\c 7  
\s1 NAT NĘMBA YIGA YETĘNJA KAVLE VAK KAT VĘLAA SĘGA NAGUNGWEYA VAK  
\p
\v 1 Nat nÉØmba kat vÉØlaa ngwuk kavle nÉØmba ngwuk waa wangweyan God ngwuk kat vÉØlaa ngwuk kavle nÉØmba ngwuk waa waigandÉØ.  
\v 2 Ndi kat vÉØlaa walÉØngwa vak vla God ngwuk kat vÉØlaa waigandÉØ.  
\v 3 Nat nyan yiga yetÉØga kavle mat vat manda kat vÉØlaa sÉØga nagulÉØgangwuk. Ngwulai yiga yetÉØlÉØga kavle nÉØma vak kat ngwuk ana vÉØlÉØgangwuk?  
\v 4 Nat nyan kat vÉØlaa mÉØn samat kavle vat tamba yimÉØn. Yima vak kwunakiyanÉØn waa manda kat walÉØgangwuk. Kavle vat yiga yetÉØngwa vak nÉØma nglei vatna.  
\v 5 Ngi kat tÉØga nat nyan samat kavle vak yinda vak kat vÉØlaa walÉØngweyan ngwuk woseka walÉØga nÉØmba vla lÉØgiyangwuk. Ngwulai yiga yetÉØlÉØga nÉØma kavle vak kwagalalaaa yingweyan nat nyan yiga yetÉØgiyaa mat kavle vak kat kwunakiyangwuk. Tat ngwutnai yiga yetÉØga kavle vak kwagala ngwula.  
\v 6 God waa apma nyaangÉØt wupmak kat kai walÉØga nÉØmba kat ke mbuka. Mbukngweyan kavle waala valÉØnda vak vla ngwuk kat yigiyandi. God walÉØga apma nyaangÉØt kavle nyaangÉØtna waa walÉØga nÉØmba kat ke mbuka. Ndi wutaa kai waigandi. Mbak yetÉØga kavamba yaagingwa apma nda mbak velÉØngwundi, ndailaa lÉØga nda vla lÉØgiyandÉØ ngwutna nyaangÉØt.   
\s1 GOD KAT NĘMBAMBA WAGALA NGWULA WAA JISAS WANDĘ  
\p
\v 7 God kat wagalangweyan ndÉØ kat wagalangweya nda klaigangwuk. Kwaka lÉØngweya nda vÉØgiyangwuk. God tÉØga ngayna mbapmo taambamba viyangweyan ndÉØ lavwiygiyandÉØ.  
\v 8 God kat wagala lÉØga nÉØmba ndi aywaa wagalalÉØnja nda klaigandi. Kwaka yetÉØlÉØga nÉØmba aywaa kwatÉØnja nda klaigandi. Mbapmo taambamba viyalÉØiga nÉØmba aywaa wan ngayna mbapmo God lavwindÉØ maa wuleigiyandi.   
\p
\v 9 Ngwula ngepmana vatnonala kÉØta vatna. KÉØta mat nyan ndÉØna nyaek kat nao kat wagalandyan ndÉØna nyaek ndÉØ kat kambapmba kwigiyandÉØ? E? Kai la. Wupma ana kwigiyandÉØ.  
\v 10 KÉØta mat nyan nyaek kat kami kat wagalandeyan ndÉØ kat kamboymba kwigiyandi? E? Kai la. Wupma ana kwigiyandÉØ.  
\v 11 Ngwuk kavle nÉØmba ngwuk. Ngwutna mat nyangu kat apma nda klalaa kwilÉØgangwuk. Nyinangwupmba lÉØga nÉØna nyaek ndÉØ kavle nyan ana ndÉØ. NdÉØno wupma nÉØn kat apma nglei nda klalaa ndÉØ kat wagala lÉØga nÉØmba kat kwilÉØgandÉØ.  
\v 12 Mandana apma vat yinda vak kat vÉØlaa woviyaguga lÉØma nat nyan kat yindangat wan vak woviyaguga lÉØma vak nat nÉØmba kat ay mÉØla. Wan vak Moses kwiya lomba profet pÉØlÉØwutnja nyaangÉØtmba la angwa nyaangÉØtna.   
\s1 NĘMA AVA YAMBĘ MAT AVA YAMBĘ KAT JISAS MBUTNDĘ  
\p
\v 13 Ngwuk mat suwi yambÉØmba wulei ngwula. Kavle kava yilÉØnja ava yambÉØna suwi yambÉØ nÉØma nglei lÉØgandÉØ. Kavle kava yilÉØnja ava yambÉØ savagu lÉØgandÉØ. NÉØma sakwat nÉØmba wungi ava yambÉØmba yilÉØgandi.  
\v 14 Apma kava yilÉØnja ava yambÉØna suwi yambÉØ nÉØma ana lÉØ. Matnat. Apma kava yloÉØnja yambÉØ savagu lÉØga yambÉØ ana ndÉØ. NÉØma sakwat nÉØmba ana yilÉØgandi.   
\s1 KAVLE NYAANGĘT MBUTĘGA NYANGU KAT JISAS MBUTNDĘ  
\p
\v 15 Woseka waa kavle nyaangÉØt mbutÉØga nyangu kat yiga ngwaymba avÉØ. NÉØn God waa nyaangÉØt mbutÉØganÉØn waa woseka walÉØgandi. Ndina mbangÉØ mÉØndama apma vatna. Ndinai yelavÉØka yetÉØga maawut kavle maawutna yelavÉØka yetÉØnja. Ndi kat yiga ngwaymba avÉØ ngwula.  
\v 16 Yiga yetÉØnja vak kat vÉØlaa ndinai maawupmba yelavÉØka yetÉØnja vak kat vÉØga wukiyangwuk. Ndi kavle mi vla lÉØgandi. Kavle tangu mbundÉØ lÉØga apma mi sÉØk ana kwalÉØgandÉØ. Yilavi mbundÉØ lÉØga kavle yuwi apma vak kÉØlÉØnja yuwi sÉØk ana kwalÉØgandÉØ.  
\v 17 Apma mi mÉØna apma sÉØk wogwulaa kwalÉØgandÉØ. Kavle mi ndÉØno kavle mi sÉØk wogwulaa kwalÉØgandÉØ.  
\v 18 Apma mi kavle mi sÉØk ana kwalÉØgandÉØ. Kavle mi apma mi sÉØk ana kwalÉØgandÉØ.  
\v 19 Apma mi sÉØk kwalapman mi vÉØtaa tambÉØ lambÉØ kalÉØka yisolaa ya sagalandi, vÉØtÉØgandÉØ.  
\v 20 Ngi kat tÉØga God waa nyaangÉØt mbutÉØganÉØn waga kavle nyaangÉØt mbuka yetÉØlÉØga nÉØmba kat yiga yetÉØnja vak kat vÉØlaa sÉØga ngugiyangwuk. Yiga yetÉØnja vak mi sÉØk vla lÉØgandÉØ.   
\s1 JISAS WANDĘ. NGWUTNA MĘNDAMA ANA VĘGA LĘGOWUN  
\p
\v 21 NÉØma sakwat nÉØmba wun kat vÉØlaa njambwi nyan waa woseka walÉØgandi. Ndi aywaa nyinangwut ana alÉØpsÉØga wuleigiyandi. Nyinangwupmba lÉØga wuna nyaek walÉØga kwundi wuka yetÉØlÉØga nÉØmba mÉØna nyinangwuk wuleigiyandi.  
\v 22 NgÉØni yaiga nandinya nÉØma sakwat nÉØmba wun kat yaa vÉØlaa njambwi nyan njambwi nyan waa woseka waigandi. MÉØna sÉØmba waga God waa nyaangÉØt nat nÉØmba kat yiga mbutÉØnÉØn. MÉØna sÉØmba waga kavle waagan kat savÉØlÉØnÉØn. MÉØna sÉØmba waga nÉØma nÉØma njÉØvwa kwutÉØnÉØn waa woseka waigandi.  
\v 23 Wandi maa ndi kat waigowun. Ngwutna mÉØndama ana vÉØga lÉØgowun. Wun kat kwagalalaa ay ngwula. Ngwuk kavle nÉØmba ngwuk waa ndi kat waigowun.   
\s1 NGAY VĘLĘLĘK KAT JISAS MBUTNDĘ  
\p
\v 24 KÉØta nyan mbutuwa nyaangÉØt wutaa wan nyaangÉØpmba yiga yetÉØndeyan kambapmba ngay tolaa kwutÉØga apma nyan vla lÉØgandÉØ.  
\v 25 Wan nyan kambapmba ngay tolaa kwutndÉØ mala nÉØma meik mwutolo kiyandÉØ. NdandÉØ mala ngumbi kiyandÉØ, wan ngay kwo lÉØndÉØ. Kambapmba taundÉØ. Ana ndandÉØ.  
\v 26 KÉØta nyan mbutuwa nyaangÉØt wutaa kai wandeyan yaawiamba ngay tolaa kwutÉØga kavle nyan vla lÉØgandÉØ.  
\v 27 Wan nyan yaawiamba tolaa ngay kwutndÉØ mala nÉØma meik mwutolo kiyandÉØ. NdandÉØ mala ngumbi kiyaga sÉØngwamatndÉØ, aywaa ndandÉØ wan ngay waa wandÉØ Jisas.   
\s1 JISAS KWONDUO LĘGA MBUTNDĘ  
\p
\v 28 Jisas wandÉØ maa wan nÉØma sakwat nÉØmba ndÉØna kwundi wutaa ngÉØpaliga ndandi.  
\v 29 Ndina nat nÉØmba Moses kwiya lo sÉØmogwilÉØga nÉØmba vla lÉØga ana Jisas mbutÉØndÉØ. NdÉØ kwonduo lÉØga mbutndÉØ.   
\c 8  
\s1 KAWILA KĘGA LA NYAN KAT JISAS KWUNATNDĘ  
\p
\v 1 Jisas nduwimba lÉØga ngaga yandÉØ. Ngaga yandÉØ maa tat ndÉØnai mbukna vak wuka la nÉØmba ndÉØna kwupmba yalaa yisolaa lÉØndi ndu lagwa.  
\v 2 TÉØga lÉØga kawia kÉØga la nyan yalaa Jisasna mangÉØndamba kwali kwali sÉØlaa Jisas kat wandÉØ. Njambwi nyan wun kat kwunapmak wameyan alÉØpsÉØga kwunakiyamÉØn.  
\v 3 WandÉØ maa Jisas ndÉØna mbangÉØmba taamba taagalaa wandÉØ. MÉØn kat tamba kwunakowun. Apma vat yetÉØ mÉØla waa wandÉØ maa kawia kÉØga lÉØnda vat wan kawia kasendÉØ.  
\v 4 Jisas ndÉØ kat wandÉØ. Awup mÉØla. MÉØn kat kwunakwa vak nat nÉØmba kat mÉØn ke mbuka. God kat kwunatÉØga nyan kat mÉØna yiga mÉØna mbangÉØ sÉØmogwi mÉØla. MÉØna mbangÉØ vÉØlaa God Moses waa vapmba kwanda kwanda vatnyalaa God kat kwigiyandÉØ. Kwindeya vak vÉØlaa mÉØna mbangÉØ kwo lÉØnda vak kat vÉØgiyandi waa wandÉØ Jisas.   
\s1 SOLDIANA NJAMBWI NYANA NJĘVWA KWUTA NYAN KAT JISAS KWUNATNDĘ  
\p
\v 5 Jisas Kapaneam walÉØnja ngepma yiga wuleindÉØ maa njambwi soldia yalaa Jisas kat wandÉØ.  
\v 6 Jambwi nyan wuna njÉØvwa kwuta nyan yelogwen kat tÉØgandÉØ. NdÉØna ava kiyandÉØ, njambÉØmba kwandÉØ. NÉØma kangÉØt yilÉØndÉØ, tÉØgandÉØ waa Jisas kat wandÉØ.  
\v 7 WandÉØ maa Jisas ndÉØ kat wandÉØ. Yiga kwunakiyowun wandÉØ.   
\p
\v 8 Wan nyan Jisas kat wandÉØ. Wun apma nyan ana wun. Wuna ngay manda kat yaigamÉØn. Kai wowun. Kumba lÉØga nyaangÉØt mÉØna wamÉØn maa wuna njÉØvwa kwutÉØga nyan kwo lÉØgiyandÉØ.  
\v 9 Wuna njambwi soldia wun kat vÉØga lÉØgandÉØ. NdÉØna kwundi wuka lÉØgowun. Wuno nat nÉØmba kat vÉØga lÉØga nyaangÉØt mbutÉØga nyan wun. Wuna kwupmba lÉØga soldia kat ay waweyan yigiyandi. Yagwa waweyan yaigandi. Wuna njÉØvwa kwutÉØga nyan kat njÉØvwa agwut waweyan ndÉØ kwukiyandÉØ waa wandÉØ njambwi soldia.  
\v 10 Jisas wutaa ngÉØpaliga ndalaa wandÉØ. NdÉØna maawupmba yelavÉØka lÉØnda vak vla ana Isrelmba lÉØga nÉØmbana maawut yelavÉØka lÉØgandi. Ndi kat aywaa kwulatndÉØ. NdÉØna maawut apma vat tÉØgandÉØ. Yelogwen kat kwa nÉØmba kat kwunatuwa vak ndÉØ vÉØga lÉØgandÉØ.  
\v 11 Yigumba awuk ngwula. Nyinangwut wuleigiyaa wan kava. Wuleilaa Judana njambwi nÉØmba Ebraham, Aisak, Jekopnogwinala kÉØta vak kÉØga kÉØta yelangÉØmba yetÉØgiyandi.  
\v 12 Judana nat nÉØma sakwat nÉØmba ndi ana wuleigiyandi. Nat nÉØmba wuleigiyandi. Ndi wuleilapman nÉØmba kavle kava yilaa nglaga nÉØmbi ngliaka lÉØgiyandi waa Jisas ndi kat wandÉØ.   
\p
\v 13 Ndi kat walaa njambwi soldia kat wandÉØ. MÉØna ngay ay mÉØla. Wagalama vat tÉØgiyandÉØ waa wandÉØ maa yilaa ndÉØna njÉØvwa kwuta nyan kwo lÉØnda vat vÉØndÉØ. VÉØlaa yelavÉØtndÉØ. Jisas waa njÉØmblamba ndÉØ kwo lÉØndÉØ waa yelavÉØtndÉØ.   
\s1 PITANA NASAKWAT YELOGWEN KAT TĘLĘ, JISAS LĘ KAT VĘLAA KWUNATNDĘ  
\p
\v 14 Jisas Pitana ngay wuleilaa ndÉØna tangwana nyÉØme yelogwen kat tÉØlÉØ, vÉØndÉØ. LÉØla mbangÉØ kangan walÉØndÉØ, njambÉØmba kwalÉØ.  
\v 15 Jisas lÉØla taamba kwutndÉØ maa lÉØla mbangÉØ kangan yelogwen vÉØtÉØnda vak ngÉØlÉØndÉØ, laataa kÉØgÉØnda kwutÉØ Jisas kat.   
\s1 JISAS NĘMA SAKWAT NDU LAGWA KAT KWUNATNDĘ  
\p
\v 16 Nglaambu kavle waagan tavila la nÉØmba kat kwutaa Jisas ta kavat kiyandi, ngwuk kavle waagan ndi kat kwagalalaa ay ngwula waga ndi kat kwunatndÉØ. Yelogwen kat ta nÉØma sakwat ndu taagwa yandi, vÉØlaa ndino ndi kat kwunatndÉØ.  
\v 17 Ndi kat kwo ana kwunatndÉØ. Tamba la profet Aisaia pÉØlÉØwuthnda nyaangÉØt vla kwunatndÉØ. Tamba Jisas kat pÉØlÉØwutndÉØ.  
\li1 Yelogwen kat tÉØna vak ndÉØna lak klalaa  
\li1 kwunatndÉØ  
\p waa tamba pÉØlÉØwutndÉØ.   
\s1 JISASNA KWUPMBA YIVAT WA NĘMBA  
\p
\v 18 NÉØma sakwat nÉØmba yalaa yisolaa lÉØndi vÉØlaa Jisas tamatndÉØ. Ngi kat tÉØga Jisas njaambÉØt kulaa wandÉØ maa ngusamba kaga nat naangat valÉØgendi.  
\v 19 Kawindi mala Moses kwiya nyaangÉØt sÉØmogwi lÉØga nyan yalaa Jisas kat vÉØlaa wandÉØ. SÉØmogwi lÉØga nyan yimeya kava wuno mÉØna kwupmba yigiyowun waa wandÉØ maa  
\v 20 Jisas ndÉØ kat wandÉØ. KwapÉØmba yetÉØlÉØga waala sÉØndu kwalÉØnda waangu ngi lÉØga. Waavi sÉØndu kwalÉØnja ngay ngilÉØga. Wun Godna vak ndinyangu kat sÉØmogwi lÉØga nyan wun sÉØndu kwaweya kava kai waa wandÉØ Jisas.  
\v 21 NdÉØna kwupmba yetÉØ lÉØga nyan laataa Jisas kat wandÉØ. Njambwi nyan. Wuna nyaek tamba wundumbu yindÉØ. NdÉØ kat yiga waangu vala nguvat wowun. NgÉØni yalaa mÉØna kwupmba yetÉØgiyowun waa wandÉØ maa  
\v 22 Jisas ndÉØ kat wandÉØ. Ke yiga ndÉØna mala. Wuna kwupmba yavak kat kai walÉØga nÉØmba ndi waangu vala waangumba ngugandi. MÉØn wuna kwupmba yagwa mÉØla waa wandÉØ Jisas.   
\s1 JISAS WANDĘ, MWUK KIYAK WANDĘ  
\p
\v 23 Jisas njaambÉØt ndÉØna mbaapma nÉØmbonala kulaa yindÉØ.  
\v 24 YilÉØndi maa nÉØma mwutolo kwutndÉØ, pali laatndÉØ NÉØma pali laataa ndina njaambÉØt wuleindÉØ. Jisas sÉØndu kwandÉØ.  
\v 25 NdÉØnagwi kÉØta vat ya nÉØmba ndÉØ kat sÉØvÉØlulaa wandi. Njambwi nyan. NÉØna njaambÉØt tamba kambruka tÉØgandÉØ. NÉØn ngu kÉØgiyanÉØn waa wandi.  
\v 26 Jisas laataa ndi kat wandÉØ. Ngwuk manda kat vaatÉØgangwuk. Njambwi nyanat tuwa vat ana ngwuk nÉØmamba yelavÉØtÉØgangwuk waa walaa mwukagwi pali kat wandÉØ, kiyak wandÉØ. Mwuk kiyak wandÉØ, pali ndÉØno kiyak wandÉØ. Ngu yuvut tapman tÉØndÉØ.  
\v 27 NdÉØna nyan manda nyana. Mwuk pali ndÉØnai waa vapmba wutÉØnda waa wandi.   
\s1 KAVLE WAAGAN TAVILA LA VĘLĘLĘK PALĘ KAT JISAS KWUNATNDĘ  
\p
\v 28 NjaambÉØpmba yiga Gadara walÉØnja ngepma kawindi anguveli naangamba. Kawindi maa kiya nÉØmbana waangumba yetÉØ lÉØga mbÉØt nyan laataa Jisas la kavat yambÉØt. Kavle waagan tavila la mbÉØt nyan. Kao mbundÉØ nyan mbÉØt. Nat nÉØmba mbÉØk kat vaaka lÉØndi. TÉØlÉØmba kavamba ana yi ya yetÉØlÉØindi.  
\v 29 Jisas kat vÉØlaa mbÉØt kÉØselaa wambÉØt. MÉØn Godna nyan mÉØn. An kat angamak yigiyamÉØn. An kat kavle vat yivat yamÉØn? An kat kwulapmeya njÉØmbla na ndÉØ waa kÉØselaa wambÉØt.  
\v 30 NÉØma sakwat mbak wan kavamba kÉØga yetÉØndi.  
\v 31 MbÉØk kat tavila la waagan Jisas kat wagalambÉØt. An kat savÉØlÉØvat wameyan savÉØlÉØlÉØmÉØn maa mbapmba wuleilaa yigiyaa. Wovuna? waa wagalambÉØt.  
\v 32 WagalambÉØt maa Jisas kwowa ay mbÉØla wandÉØ. MbÉØk kat kwagalalaa yiga mbapmba wuleimbÉØk maa wan mbak vaaka pÉØlÉØga ndaiga satnat yindi. Yilaa wan mbak aywaa ngu kÉØgiyatndi.   
\p
\v 33 Wan mbak kat vÉØga la nyangu ngepmat pÉØlÉØga yiga ngepmamba la nÉØmba kat nayaangÉØt mbutndi. Kavle waagan ndu nyan kat kwagalalaa mbapmba wuleilaa pÉØlÉØnja vak kat yiga mbutndi.  
\v 34 Ngepmamba la nÉØmba wutaa Jisas la kavat yindi ndÉØ kat vÉØvat. NdÉØ kat yiga vÉØlaa wandi. NÉØna kÉØpma kwagalalaa mÉØn ay mÉØla wandi.   
\c 9  
\s1 JISAS MAN TAAMBA KĘVĘ WATNA NYAN KAT KWUNATNDĘ  
\p
\v 1 Jisas kat kai wandi maa njaambÉØt kulaa valÉØgega ndÉØna angwa ngepmamba kawindÉØ.  
\v 2 Man taamba kÉØvÉØ watna nyan njambÉØmba ndaa lÉØndÉØ maa nat nÉØmba ndÉØ kat walalaa kiyandi. Jisas ndÉØ kat kwunakiyandÉØ waa maawupmba yelavÉØtnja vak kat vÉØlaa Jisas wandÉØ. Wuna nyan mÉØn nÉØma maawut ke yelavÉØka. Kavle vat yiga yetÉØma vak tamba sÉØlÉØmbwigowun waa wandÉØ Jisas.   
\p
\v 3 Moses kwiya nyaangÉØt sÉØmogwi lÉØga nÉØmba wutaa maawupmba yelavÉØka lÉØndi. Wan nyan God kat kavle vat wandÉØ waa yelavÉØka lÉØndi.   
\p
\v 4 Maawupmba yelavÉØka tÉØnja vak kat Jisas vÉØlaa wandÉØ ndi kat. Ngwutna maawupmba manda kat kavle vak yelavÉØka lÉØgangwuk.  
\v 5 Kavle vat yiga yetÉØma vak kat sÉØlÉØmbwigiyowun waweyan njambÉØ kwagalalaa laataa yetÉØ waweyan kÉØmbÉØt vÉØlÉØlÉØk nyaangÉØt kÉØta vatna.  
\v 6 Wun Godna vak ndinyangu kat sÉØmogwi lÉØga nyan wun. Kavle vat yetÉØnja vak kat sÉØlÉØmbwiweya kwondu ngilÉØga wunamba. Wuna kwondu ngwuk kat sÉØmogwivat wowun. Ndi kat ndÉØna kwondu sÉØmogwivat man taamba kÉØvÉØ watna nyan kat vÉØlaa wandÉØ. MÉØn laataa mÉØna njambÉØ walalaa ngay ay wandÉØ.  
\v 7 WandÉØ maa laataa yindÉØ.  
\v 8 Nat nÉØmba vÉØlaa ngÉØpali walaa vaaka lÉØndi. Vaaka lÉØga wandi. God wan nyan kat nÉØma kwondu kwindÉØ waa Godna sÉØ kwutaa katsondi.   
\s1 JISAS MATYU KAT YAGWA WUNA KWUPMBA WANDĘ  
\p
\v 9 Jisas wan ngepma kwagalalaa yiga takis sanya kla lÉØga nyan kat vÉØndÉØ. NdÉØna sÉØ Matyu. Takis sanya klalÉØnda ngaymba lÉØndÉØ. Jisas ndÉØ kat vÉØlaa wuna kwupmba laataa yagwa wandÉØ. WandÉØ maa laataa yindÉØ ndÉØna kwupmba.   
\p
\v 10 Nat nandinya Jisas ngaymba lÉØga nÉØma sakwat nÉØmbonala nao kÉØga lÉØndÉØ. NdÉØnogwinala kÉØla nÉØmba nÉØmbonala nao kÉØga lÉØndÉØ. NdÉØnogwinala kÉØla nÉØmba takis sanya klala nÉØmbo kavle vat yiga yetÉØ lÉØga nÉØmbo kÉØta vat yisolaa lÉØga nao kÉØlÉØndi.  
\v 11 Ferisi yalaa nao kÉØlÉØnja vak kat vÉØlaa Jisasna kwupmba la nÉØmba kat wandi. Takis sanya klalÉØga nÉØmbo kavle vat yiga yetÉØlÉØga nÉØmbo manda kat ngwula njambwi nyan nao kÉØlÉØgandÉØ waa wandi.   
\p
\v 12 Wanja vak Jisas wutaa ndi kat wandÉØ. Apma vat kwo lÉØga nÉØmba dokta kat ana yilÉØgandi. Yelogwen kat ta nÉØmba mÉØna yilÉØgandi.  
\v 13 Ngwuk tamba God wandÉØ, pÉØlÉØwutnja nyaangÉØtna angwa vak ana vÉØga lÉØgangwuk. Kupma pÉØlÉØwutndi.  
\li1 Kwanda kwanda vatnyalaa wun kat ke kwiga. Nat  
\li1 nÉØmba kat nÉØma vak yelavÉØka ndi kat kwunak ngwula  
\li1 waa wandÉØ God  
\p waa tamba pÉØlÉØwutndi. Wun apma vat yetÉØlÉØga nÉØmba kat kwunapmak ana yawun. Kavle savle yetÉØlÉØga nÉØmba kat mÉØna kwunapmak yawun waa wandÉØ Jisas.   
\s1 KĘGĘNDA KĘVAK KAT KAI WANJA VAK  
\p
\v 14 Ngu yagula Jona kwupmba la nÉØmba yalaa Jisas kat wandi. NÉØnogwi Ferisio nÉØma sakwat njambÉØ kÉØgÉØnda kÉØvak kat kai walÉØganÉØn. MÉØna kwupmba la nÉØmba ndi wupma ana yilÉØgandi waa wandi.   
\p
\v 15 Wandi maa Jisas tamba la nyaangÉØtno ndÉØnai kiya kupi nyaangÉØt kat ndi kat mbuka wandÉØ. KÉØta nyan taagwa klandeya njÉØmbla nÉØma kÉØgÉØnda kwutndi. Ya nÉØmba wan kÉØgÉØnda kÉØvak kat kÉØlÉØp mbangÉØ yiga ana lÉØndi. Wan kapti kwukna nyan yindÉØ maa ndina mbangÉØ kÉØlÉØp mbangi yindÉØ, kÉØgÉØnda kÉØvak kat kai waigandi.   
\p
\v 16 Tamba ngÉØlÉØkna waavwimba kupi waavwi taagalaa tavanjeyan ngÉØni wan waavwi nÉØmamba ngÉØlÉØkiyandÉØ.  
\v 17 Tamba sÉØmbÉØmba tavanja awmba kupi nÉØma ngu ana salakiyandi. Salatnjeyan nÉØma nguna mbiyak nÉØma yindÉØ maa sÉØmbÉØ kÉØkÉØk waa mbÉØlÉØgiyandÉØ. MbÉØlÉØndÉØ maa nÉØma ngu kÉØpmamba salaka yigiyandÉØ. NÉØma nguagwi wan sÉØmbo kÉØta kÉØta kavle yigiyandÉØ. Kupi nÉØma ngu klalaa kupi sÉØmbÉØmba mÉØna kwutaa salatndi maa kwo lÉØgiyandÉØ waa ngambundÉØ Jisas.   
\p
\v 18 Jisas ngambulÉØndÉØ maa Judana njambwi nyan yalaa kwali mamba sÉØlaa wandÉØ.  
\v 19 WandÉØ maa Jisas laataa ndÉØna kwupmba yindÉØ. Jisasna mbaapmamba la nÉØmba ndÉØno laataa kÉØta vat yindi.   
\p
\v 20 YilÉØndi maa yaat tÉØgÉØmbimba yelogwen yilÉØndÉØ, yetÉØla taagwa yalÉØ. Naambi tamba vÉØli kiyeli vÉØlÉØlÉØk yelogwen yilÉØndÉØ, yetÉØlÉØlÉØ. Jisasna kwupmba yalaa ndÉØna njÉØmbwi waavwi sÉØnyÉØtÉØ.  
\v 21 Tat yelavÉØtÉØ. NdÉØna waavwi sÉØnyÉØkweyan wuna mbangÉØ kwo lÉØgiyowun waa yelavÉØtaa sÉØnyÉØtÉØ.  
\v 22 SÉØnyÉØtÉØ maa Jisas lÉØmbalaguga vÉØlaa wandÉØ. Taagwa nyan nÉØmamba ke yelavÉØka. Jisas wun kat kwunakiyowun waa yelavÉØtÉØnya vak vÉØlaa nyÉØna kavle vak kat tamba kwunakowun. NyÉØn kwo apma vat tÉØgiyanyÉØn waa walaa  
\v 23 Judana njambwi nyana ngay wuleindÉØ. Ngay wuleilaa waavi wala nÉØmba ngla lÉØga nÉØmba kat vÉØlaa wandÉØ.  
\v 24 Ngwuk wun kat tula ngwula. Wat taagwa nyan ana kiyalÉØ. SÉØndu kwalÉØ waa wandÉØ maa wutaa ndÉØ kat njÉØtÉØndi.  
\v 25 Yindi maa Jisas wat taagwa nyana ngway yilaa lÉØla taambamba kwutndÉØ, laatÉØ.  
\v 26 Laataa vak mbutseli mbutsela ngepma ngepma mbuka kalindi, aywaa wutndi.   
\s1 JISAS MĘNI VĘLAPMAN TA VĘLĘLĘK PALĘ KAT KWUNATNDĘ  
\p
\v 27 Jisas wan kava kwagalalaa yindÉØ maa mÉØni vÉØlapman ta mbÉØt nyan vÉØlÉØlÉØk ndÉØna kwupmba yiga wambÉØt. MÉØn Devitna yelangÉØ nyan mÉØn. An kat miwa ay mÉØla waa wambÉØt.  
\v 28 Jisas ngay wuleindÉØ maa ndÉØna kwupmba wuleimbÉØt. Wuleilaa an kat kwunap mÉØla wambÉØt. WambÉØt maa Jisas wandÉØ. MbÉØk angamak yelavÉØka lÉØgambÉØk. MbÉØk kat alÉØpsÉØga mbambala kwunakiyowun? waa wagalandÉØ maa awa njambwi nyan mÉØn alÉØpsÉØga an kat kwunakiyamÉØn waa wambÉØt maa  
\v 29 Jisas mbÉØk kat mÉØnimba taamba taagalaa wandÉØ. Maawupmba yelavÉØka lÉØmba vak kat vÉØlaa kwunakowun waa wandÉØ maa  
\v 30 mbÉØla mÉØn kembandÉØ, vÉØmbÉØk. Jisas mbÉØk kat nÉØma kwundimba wandÉØ. MbÉØk kat kwunatuwa vak mbÉØk nat nÉØmba kat ke mbuka waa wandÉØ.  
\v 31 YimbÉØk maa mbutseli mbutsela mbutÉØmbÉØk, wan kavana ngepma aywaa wutndi wan kwunatnda nyaangÉØt.   
\s1 KWUNDI NGAMBU LAPMAN NYAN KAT JISAS KWUNATNDĘ  
\p
\v 32 YilÉØmbÉØt maa kwundi ngambu lapman nyan kat kwutaa Jisas la kavat kalindi. Kavle waagan ndÉØ kat tavilaa ndÉØna tÉØgat kulumatndÉØ, ana kwundi ngambulÉØndÉØ.  
\v 33 Jisas wan ndÉØ kat kwuta la kavle waagan kat savÉØlÉØndÉØ maa wan nyan kwundi ngambundÉØ. Nat nÉØmba vÉØlaa ngÉØpaliga ndalaa wandi. Tak nÉØn Isrel tÉØna kavamba wupma ana vÉØlÉØnÉØn. Apma vatna.  
\v 34 Ferisi ndi mandÉØp vak wandi. Kavle waagana savÉØlÉØlÉØgandÉØ waa wandi ndÉØ kat.   
\s1 JISAS NDINYANGU KAT MIWA YINDĘ  
\p
\v 35 Jisas ngepma ngepma yindÉØ. Yiga Juda nyaangÉØt ngambula ngay wuyleilaa wan apma nyaangÉØt ndi kat mbutÉØndÉØ. God yalaa nÉØn kat vÉØga lÉØgiyandÉØ waa wandÉØ. MandÉØt mandÉØt yelogwen vÉØtÉØndÉØ, ta nÉØmba kat vÉØlaa kwunatndÉØ.  
\v 36 NÉØma sakwat nÉØmba kat vÉØlaa ndi kat miwa yiga lÉØndÉØ ndi. Ndu nyan vÉØga lÉØlapman sip sip ta vak vla lÉØndi. Ngi kat tÉØga ndi kat miwa yiga lÉØndÉØ.  
\v 37 Ndi kat miwa yiga lÉØga ndÉØna kwupmba la nÉØmba kat wandÉØ. NÉØma sakwat kÉØgÉØnda ambugapmba kwo lÉØga ak wulÉØgandÉØ. VÉØlaa sÉØgÉØka kiya nÉØmba kai.  
\v 38 Ambugat kat vÉØga lÉØga njambwi nyan kat wagala ngwula. NÉØma sakwat nÉØmba kat ay wamÉØn maa ambugatna kÉØgÉØnda sÉØgÉØka kiyaigandi waa wagala ngwula njambwi nyan kat waa wandÉØ Jisas.   
\c 10  
\s1 TAMBA VĘLI KIYELI VĘLĘLĘK JISASNA KWUPMBA LA APOSELNA SĘ  
\p
\v 1 Jisas wandÉØ maa ndÉØna kwupmba la tamba vÉØli kiyeli vÉØlÉØlÉØk nÉØmba yisolaa lÉØndi. Yisolaa lÉØndi maa kavle waagan savÉØlÉØnjeya kwondu ndi kat kwindÉØ. Yelogwen kat kwaiga nÉØmba kat kwunatnjeya kwondu ndi kat kwindÉØ.   
\p
\v 2 Wan tamba vÉØli kiyeli vÉØlÉØlÉØk aposelna sÉØ kÉØngiyan. Tat ta nyan Saimon waa Pita walÉØnja nyan. Nat nyan Pitana yakwa nyan Endru. Nat vÉØlÉØlÉØk palÉØ Sebedina nyan Jemsagwi Jono.  
\v 3 Nat nyan Filip. Nat nyan Batolomyu. Nat nyan Tomas. Nat nyan Matyu. NdÉØ takis sanya klala nyana. Nat nyan Alfiasna nyan nat Jems.  
\v 4 Nat nyan Tadias. Nat nyan nat Saimon. NdÉØ ngepma ngepma yiga nat nÉØmba nÉØna kÉØpma kat yalaa vÉØga lÉØnjangat kai waa ngambulÉØndÉØ. Nat nyan Judas Iskeriot Jisas kat vatnyavat kamwin kwiga ndÉØ kat sÉØmogwiya nyana.   
\s1 JISAS WANDĘ MAA APOSEL NJĘVWA KWUPMAK YINDI  
\p
\v 5 Jisas tamba vÉØli kiyeli vÉØlÉØlÉØk nÉØmba kat wandÉØ. Ngwuk ngepma ngepma yiga njÉØvwa kwuk ngwula. Juda ana ndi nat nÉØmbana ngepma ke yingwa. Sameria lÉØga nÉØmbana ngepma ke yingwa.  
\v 6 Juda lÉØga ngepma ngepmat ay ngwula. Wundi Juda nÉØma nyan kat pogwula lÉØga sip sip vla lÉØgandi.  
\v 7 Yiga ndi katambuk ngwula. Nginangwupmba lÉØga nÉØma nyan nÉØn kat vÉØga lÉØndeya njÉØmbla tamba ngway tologandÉØ waga yiga ndi kat mbuk ngwula.  
\v 8 Yelogwen kat tÉØgiyaa nÉØmba kat vÉØlaa kwunak ngwula. Kiya nÉØmba kat vÉØlaa wangwuk mala laakiyandi. Kawia kÉØga lÉØgiya nÉØmba kat yiga vÉØlaa kwunakngwuk mala kwo lÉØgiyandi. Kavle waagan tavila lÉØgiyaa nÉØmba kat vÉØlaa savÉØlÉØmba ngwuk. Wunamba la kwondu kwo klangwuk. Wun kat wenga kwilaa ana klangwuk. Ngi kat tÉØga yiga ndi kat kwo kwunak ngwula. Ndina wenga ke klangweya.   
\p
\v 9 Moni sanya kwuka wana yilÉØngweya. Yimbwi kwuka wana yilÉØngweya.  
\v 10 MandÉØp waavwi mandÉØp man su vasÉØ vasÉØ ke kwutaa yiga. Ngwuk njÉØvwa kwutÉØga nÉØmba ngwuk. NjÉØvwa kwukngwuk maa ngwuk kat wan da kwigiyandi.   
\p
\v 11 Ngepma wuleilaa wuna ngay yagwa waiga nyan kat vÉØlaa ndÉØna ngay wuleigiyangwuk. Ngay ngay ke yilÉØngweya.  
\v 12 Ngay wuleilaa apma nandinya waga apma vat tÉØgiyangwuk waa waigangwuk ndi kat.  
\v 13 Wuleingwuk maa ngwuk kat yagwa wanjeyan apma nyaangÉØt wangwa nyaangÉØt ndinamba tÉØgiyandÉØ. Wuleingwuk mala ngwuk kat kai wanjeyan wangwa apma nyaangÉØt lungwamata ngwula lak yaigandÉØ. Lungwamataa ngwula lak yandÉØ maa ndi kavle savle tÉØgiyandi.  
\v 14 Wan ngaymba lÉØgiya nyan wan nÉØma ngepmamba lÉØgiya nyan ngwuk kat kai wandeyan wan ngepma kwagalavat laataa man mbaw vÉØvlÉØlaa kwagalalaa laataa aymba ngwuk. Ngwuk vÉØga lÉØgiyangwuk. God ngwuk kat sÉØgiyandÉØ waa ndi kat waga man mbaw vÉØvlÉØmba ngwuk.  
\v 15 NgÉØni yaiga nandinya God ndinyangu kat sÉØga naguvat tÉØndeya nandinya Sodom Gomora walÉØnja kavle ngepmamba la nÉØmba ndi nÉØma vat dlaigandi. Ngwuk kat kai waiga ngepma nÉØmba ndi nÉØma nglei vat klaigandi.   
\s1 NĘMA SAKWAT NĘMA VAK YAIGANDĘ WAA JISAS MBUTNDĘ  
\p
\v 16 Awuk ngwula. Ngwuk ngepma ngepma yivat yilÉØgangwuk. Kavle waala sip sip kat valÉØnda vla wundi nÉØmba ngwuk kat kavle vat yigiyandi. Kamboy apma maawut yelavÉØka yigumba yilÉØga vak vla ngwuk wupma ay ngwula. Namiyo yilÉØga vak kap ana yalÉØgandÉØ.  
\v 17 Ngwuk yigumba vÉØga lÉØgiyangwuk. Nat nÉØmba ngwuk kat kwutaa kotngwangat kaligiyandi. Juda ngaangÉØt ngambulÉØnja ngay ngwuk kat kwutaa kalilaa viyaigandi.  
\v 18 Wuna sÉØ wangwuk maa ngwuk kat kwutaa kaligiyandi. Njambwi king mat king ngwuk kat vÉØga sÉØga nagunjangat kaligiyandi. Ngwuk kat kalindi maa wan njambwi nÉØmba kat kwutaa lÉØngwa apma nyaangÉØt ndi kat mbukiyangwuk. Juda ana ndi nat nÉØmba ndino ndi kat mbukiyangwuk.  
\v 19 Notngwangat kalindi maa kotmak tÉØngweya nyaangÉØt kat nÉØmamba ke vaaka yelavÉØkngweya. Ngwuk kat kwutaa kalindi maa kotngweya nyaangÉØt ngwutna maawupmba mbukiyowun.  
\v 20 Mbukngweya nyaangÉØt ngwutna nyaangÉØt ana ndÉØ. NÉØna nyaek kwigiya waagan ngwutna mbangÉØmba tavindÉØ maa mbukiyangwuk.   
\p
\v 21 NgÉØni yaiga kavle njÉØmbla kavle vat nÉØma sakwat yaigandÉØ. KÉØta nyan ndÉØna yakwa nda nyan kat kwutaa kotmak kalindÉØ maa ndÉØ kat kwutaa vatnyangiyandi. Nyaek ndino indina nyangu kat kwutaa kotnjangat kaligiyandi. Nyangu ndina nyaek nyÉØme kat kai walaa nyaek nyÉØme kat kwutaa kotmak kalindi maa vatnyagiyandi.  
\v 22 Wuna sÉØ ngwuk tamba kwutaa lÉØgangwuk. Ngi kat tÉØga nÉØma sakwat nÉØmba ngwuk kat kai waigandi. Wan kavle njÉØmbla ngÉØlÉØndÉØ maa kwo lÉØga wuna sÉØ kwutaa lÉØga nÉØmba ndi apma vat tÉØigiyandi.  
\v 23 KÉØta ngepmana nÉØmba ngwuk kat kavle vat yinjeyan wan ngepma kwagalalaa vaaka nat ngepmat ay ngwula. Ngwuk kat wowun. Judana ngepma ngepma yiga mbutÉØngweya njÉØvwa kwiyatapman ana ngÉØlÉØgiyandÉØ. Wun Godna vak sÉØmogwi lÉØga nyan yilaa yawun maa wan njÉØvwa ngÉØlÉØgiyandÉØ.   
\p
\v 24 Kwupmba lÉØga nyan ndÉØ kat vÉØga lÉØga sÉØmogwi lÉØga nyana njambwi nyan ana ndÉØ. SÉØmogwi lÉØga nyan ndÉØ njambwi nyana. NjÉØvwa kwutÉØga nyan wan njÉØvwa kat vÉØga lÉØgiya njambwi nyana njambwi ana ndÉØ. NjÉØvwa kat vÉØga lÉØgiya nyan ndÉØ njambwi nyana.  
\v 25 Kwupmba lÉØga nyan ndÉØ kat vÉØga lÉØga sÉØmogwi lÉØga nyan lÉØnda vla lÉØndeyan wovuna. NjÉØvwa kwutÉØga nyan wan njÉØvwa kat vÉØga lÉØgiya njambwi nyan lÉØnda vla lÉØndeyan wovuna. Wun ngwutna njambwi nyan wun. Nat nÉØmba wun kat wandi. MÉØn waagana njambwi nyan mÉØn. MÉØn Bielsebul mÉØn waa wun kat wandi. Ngwuk wuna kwupmba lÉØga mbaapma nÉØmba ngwuk. Ngwutno ngwuk kat kavle nglei sÉØ waigandi.   
\s1 NDINYANGU GOD KAT MĘNA VAAKA LĘGIYANĘN  
\p
\v 26 Ndinyangu ngwuk kat yigiya kavle vak kat nÉØmamba ke vaaka yelavÉØka lÉØngwa. Ngwuk kat pagwuga kavle vat yilÉØnja vak ngÉØni nat nÉØmba aywaa vÉØgiyandi. PagwulÉØnja kavle nyaangÉØt ngÉØni nat nÉØmba aywaa wukiyandi.  
\v 27 Mbambala ngwuk kat pagwuga mbutuwa nyaangÉØt ngepma ngepma yiga kapmba mbukiyangwuk. Kan ngwuk kat mbutuwa nat nÉØma sakwat nÉØmba ana wutÉØgandi. Ngwuk kat mÉØna mbutÉØgowun. Ngwuk wutaa yiga nÉØma sakwat nÉØmba kat kak kiya mbukiyangwuk ngepma ngepmamba.  
\v 28 Ngwuk kat vatnyagiya nÉØmba kat ngwuk ke vakngwa. Ndi ngwutna wundumbu kat ana vatnyagiyandi. God kat mÉØna vaaka alÉØ ngwula. NÉØna mbango wundumbu kat ya vÉØtÉØga kavamba yiga alÉØpsÉØga taagagiyandÉØ.  
\v 29 Mat waavi kÉØlÉØnja waavi peni kÉØta yaagilaa vÉØlÉØlÉØk klaigangwuk. Kan mat waavi kiyalÉØnja vak kat nÉØna nyaek ndÉØ vÉØga lÉØgandÉØ. Mat waavi ana kiyaigandÉØ waa wandeyan wan waavi ana kiyaigandÉØ.  
\v 30 Ngwulo ngwuk kat wupma vÉØga lÉØgandÉØ. Ngwula nambumba lÉØga yuwina sakwat vÉØga sÉØga naguga lÉØgandÉØ.  
\v 31 Ngwuk ke vatÉØngwa. Ngwuk kat vÉØga lÉØgandÉØ. Mat waavi kat ngwuk kwulatÉØgangwuk.   
\s1 JISAS NĘNA NJAMBWI NYANA WAA WALĘNJA VAK  
\p
\v 32 KÉØta nyan Jisas wuna njambwi nyana waa nat nÉØimba kat wandeyan nyinangwuk tÉØga wuna nyaek kat vÉØlaa wan nyana sÉØ waa ndÉØ wuna nyana waa waigowun.  
\v 33 KÉØta nyan Jisas wandeyan nyinangwut tÉØga wuna nyaek kat waigowun. Wan nyan wuna nyan ana ndÉØ waa waigowun.   
\s1 JISAS KAO SĘNJANGAT YANDĘ  
\p
\v 34 Kan kÉØpmana nÉØmba kao yilÉØnja vak kat kalÉØpmak ana yawun. Wungi vak kat ana yawun. Awat sowat kao sÉØnjangat yawun.  
\v 35 Yawun maa nat nÉØmba wun kat kai wandi maa nat nÉØmba wun kat yagwa wandi, wungi vak kat tÉØga laataa awat sowat waliandi. Mat nyangu laataa ndina nyaek kat waliagiyandi. Taagwa nyangu ndino laataa ndina nyÉØme kat waliagiyandi. Ndinyanguna taagwa laataa ndina lana nyÉØme kat waliagiyandi.  
\v 36 Yawun maa kÉØta ngaymba lÉØlÉØga nÉØmba laataa waliaga kapma kapma nÉØmingi vla lÉØgiyandi.   
\p
\v 37 kita nyan wun kat samat samat yelavÉØtaa ndÉØna nyaek nyÉØme kat nÉØma nÉØma vat yelavÉØtndeyan ndÉØ ana wuna mbaapma wuleigiyandÉØ.  
\v 38 God wandÉØ, ndÉØna njÉØvwa kwupmat yawun. Nat nÉØmba kai waa wun kat sÉØnjeya vak kat ana vaakiyowun. Wun kat kwinda njÉØvwa kwutapman yiga wuna kwupmba yalapman yindeyan wan nyan wuna mbaapma ana wuleigiyandÉØ.  
\v 39 KÉØta nyan avla ndÉØna mbangÉØ kat mÉØna yelavÉØka kwo yetÉØndeya vak kat mÉØna yelavÉØka lÉØndyan ndÉØ kavle yigiyandÉØ. Kita nyan wuna njÉØvwa kwuka ndÉØna mbangÉØ kat yelavÉØtapman yindeyan ndÉØ apma vat tÉØgiyandÉØ.   
\s1 GODNANAMBA APMA WENGA KLANJEYA VAK KAT JISAS NDĘNA APOSEL KAT MBUTNDĘ  
\p
\v 40 KÉØta nyan ngwuk kat apma vat yindeyan wan apma vat yinda vak wuna lak yaigandÉØ. Kita nyan wun kat ay waa nyanat yaigandÉØ.  
\v 41 KÉØta nyan Godna nyaangÉØt mbuka yetÉØlÉØga nyan kat vÉØlaa yagwa waa ndÉØna ngayat kalindeyan wan apma vatna. Godna nyaangÉØt mbuka yetÉØlÉØga nyan klaiga wenga ndÉØno ngayat kwutaa kalia nyan klaigandÉØ. Kita nyan apma nyan kat vÉØlaa yagwa waa ndÉØna ngayat kalindyan wan apma vatna. Apma nyan klaiga wenga wan dÉØ kat kwutaa ngayat kalia nyan ndÉØno klaigandÉØ.  
\v 42 Ngwuk ke maawut tÉØvÉØga lÉØngwa. KÉØta nyan wuna mbaapmamba la mat nyan kat vÉØlaa ndÉØ Jisasna mbaapma nyana walaa ndÉØ kat kÉØgÉØn ngu kuvuk kwindeyan ndÉØ apma wenga klaigandÉØ. Wan kwinda mat nda kat vÉØlaa God ndÉØ kat wenga kwigiyandÉØ. NdÉØna maawut ana tÉØvÉØgiyandÉØ waa wandÉØ Jisas.   
\c 11  
\s1 JON NDĘNA MBAAPMAMBA LA NĘMBA KAT WANDĘ, JISAS KAT VĘVAT YANDI  
\p
\v 1 Jisas ndÉØna mbaapmamba la tamba vÉØli kiyeli vÉØlÉØlÉØk nÉØmba kat yinjeya vak kat mbuka walaa ndi kat kwagalalaa nyaangÉØt mbupmat laataa ngepma ngepma yindÉØ.  
\v 2 Ngu yagula Jon ndÉØ kat kalambusmba taagandi, lÉØndÉØ. Kraist kwuta njÉØvwa kat wutaa Jon ndÉØna mbaapmamba la nÉØmba kat wandÉØ. Kraist kat yiga wagala ngwula.  
\v 3 WandÉØ maa yiga Jisas kat wagalandi. NÉØn kat ambuk. Tat Jon njÉØvÉØa kwuka lÉØga wandÉØ. KÉØta nyan wuna kwupmba yaigandÉØ wandÉØ. MÉØn kat wandÉØ? E? Kanda kat wandÉØ waa wagalandi.   
\p
\v 4 Jisas ndi kat kat wandÉØ. Kwutuwa njÉØvwa vÉØga wukngwa vak lungwamataa yiga Jon kat ambuk.  
\v 5 MÉØni kiyala lÉØga nÉØmba kwunakwun mala apma mÉØna vÉØlÉØgandi. Man kÉØvÉØ wata la nÉØmba kwunakwun mala laataa apma man veilÉØgandi. Kawia kÉØga la nÉØmba wowun mala kawia kasÉØlÉØgandÉØ, kwo lÉØlÉØgandi. Waan wutapman nÉØmba kat wowun mala laatÉØgandi. kwondu kapman kwo lÉØga nÉØmba kat wan apma nyaangÉØt mbutÉØgowun.  
\v 6 KÉØta nyan wun kat vÉØlaa ndÉØ God wandÉØ, yaa nyana waa yelavÉØka lÉØndyan ndÉØ apma maawut sÉØka lÉØga nyana waa wandÉØ Jisas.   
\p
\v 7 Jona mbaapmamba la nÉØmba Jon ta kavat lungwamataa yindi maa Jisas wan nÉØma sakwat nÉØmba kat Jon yeta vak kat ndi kat mbutndÉØ. Jon ndinyangu lapman kavamba lÉØndÉØ, vÉØvat yingwa njÉØmbla ndÉØ kat angamak yelavÉØka yingwuk. Mwuk kwutÉØndÉØ, kÉØpmamba lÉØga yuwi ava yuvut yilÉØnda vak vla lÉØga nyana waa yelavÉØka ndÉØ kat vÉØvat yingwuk? Kai. Jon wupma ana lÉØndÉØ. NdÉØ tagula nyana.  
\v 8 NdÉØ apma waavwi kwuso lÉØga nyana waa yelavÉØka ndÉØ kat vÉØvat yingwuk? Jon wupma ana lÉØndÉØ. Apma waavwi kwuso lÉØga nÉØmba ndi apma ngaymba yetÉØlÉØga nÉØmba ndi. NdÉØ apma ngay kai.  
\v 9 NdÉØ profetna waa yelavÉØka ndÉØ nat profet kat kwulatndÉØ. NdÉØ ndina njambwi nyana.  
\v 10 Tamba God waa nyaangÉØt pÉØlwuta nÉØmba ndi Jon kat pÉØlÉØwutndi.  
\li1 God wandÉØ. Kan nyan wuna nyaangÉØt mbutÉØga nyana.  
\li1 NdÉØ tatak yiga mbukiyandÉØ. NgÉØni yimeya yambÉØ  
\li1 kwukiyandÉØ waa God wandÉØ ndÉØna nyan kat waa tamba la nÉØmba pÉØlÉØwutndi.   
\p
\v 11 Ngwuk wutaa yelavÉØk ngwula. Kan kÉØpmamba la nat nÉØmba kat aywaa Jon ndÉØ kwulatÉØgandÉØ. Nyinangwut wuleila nyan God vÉØga lÉØga mat nyan ndÉØ Jon kat kwulakiyandÉØ.   
\p
\v 12 Tat jon nyaangÉØt mbuka yliÉØndan yiga yaa kan mbambala kavle nÉØmba wuna njÉØvwa kalÉØpmak kat walÉØgandi. KwutÉØma njÉØvwa nÉØna maawupmba apgwup mÉØla waa wun kat walÉØgandi. ndina kwundi wutapman nyinangwupmba lÉØga njambi nyan kÉØpmamba lÉØga nÉØmba kat vÉØga lÉØndangat kan kwutuwa njÉØvwa kwutÉØgowun.  
\v 13 Njambwi nyan kan vÉØga lÉØndeya vat tamba la profet mbutÉØndi. Moses ndÉØno wan nyaangÉØt mbutÉØndÉØ. Jon ndÉØno wan nyaangÉØt mbutÉØndÉØ.  
\v 14 Ndinai mbuta nyaangÉØt wuka lÉØngweyan apma vatna. Jon tamba la nyan Ilaija mbutnda vak vla mbutÉØndÉØ. Tamba la nÉØmba pÉØlÉØwutndi. ngÉØni Ilaija yaigandÉØ waa pÉØlÉØwutndi Mbambala Ilaija tamba yalaa lÉØgandÉØ, Jona.   
\p
\v 15 Apma maawut yelavÉØka lÉØgiya nÉØmba kan mbutuwa nyaangÉØt kat wutaa yelavÉØka lÉØgiyandi.  
\v 16 Mbambala kan kÉØpmamba lÉØga nÉØmba kwuka yetÉØnja vak ngwuk kat mbukiyowun. Ndi mat nyangu vla lÉØgandi. Ngepma nÉØndÉØmba ndaa lÉØga nat nyaangu kat walÉØgandi.  
\v 17 Mbangu kwundi waga tamba kwangu viyanÉØn. MbÉØk ana mbangu veiga lÉØgambÉØk. NÉØn nglasa kwundi nglasÉØka nglalÉØnÉØn. MbÉØk ana nglasaka nglalÉØgambÉØk. YilÉØna vak ana nÉØna kwupmba yina vla yiligambÉØk waa mat nyangu walÉØgandi.  
\v 18 Jon yalaa kÉØgÉØnda kÉØvak kat kai walaa lÉØga nÉØma ngu ana kÉØlÉØndÉØ. Mbambala lÉØga mat nyangu vla lÉØga nÉØmba ndÉØ kat vÉØlaa wandi. manda kat wupma yilÉØgandÉØ. NdÉØ tungwengwan yiga nyana waa wandi.  
\v 19 Wun Godna vak sÉØmogwi lÉØga nyan yalaa kÉØgÉØnda kÉØga nÉØma ngu kÉØlÉØwun. Mbambala lÉØga mat nyanagu vla lÉØga nÉØmba wun kat vÉØlaa wandi. NdÉØ kavle nyana. KÉØgÉØnda kÉØga nÉØma ngu nÉØma sakwat kÉØlÉØga nyana. Takis sanya klalÉØga nÉØmbo kavle vat yetÉØlÉØga nÉØmbana alÉØ nyana waa walÉØndi. Ndi God wandÉØ, yelavÉØka lÉØnja maawupmba ana lÉØgandi. Kavle maawut yelavÉØka lÉØgandi. kwutuwa apma njÉØvwa vÉØlaa Godnonala lÉØga kwutÉØgandÉØ waa waigangwuk waa wandÉØ Jisas.   
\s1 KOROSINO BETSAIDO KAPANEAM WALĘNJA NGEPMA KUVUKMBA LA NĘMBA KAT JISAS KAI WANDĘ  
\p
\v 20 Nat ngepma vÉØlÉØlÉØk yiga wuleilaa Jisas nÉØma sakwat nÉØma njÉØvwa kwutÉØndÉØ. Wan ngepma nÉØmba kwutÉØnda njÉØvwa yÉØlaa wan yetÉØnja kavle vat ana kwagalandi. TÉØga lÉØna ngÉØni wan ngepma wuleilaa wan ngepma nÉØmba kat Jisas njÉØka wandÉØ.  
\v 21 Ngwuk Korosin walÉØnja ngepmamba lÉØga nÉØmba ngwuk kat ngÉØni kavle vat yaigandÉØ. Ngwuk Betsaida walÉØnja ngepmamba lÉØga nÉØmbo ngwulo ngwuk kat kavle vat yaigandÉØ. Tamba vÉØngwa kwutuwa nÉØma njÉØvwa tamba la nÉØmba Taia Saidon walÉØnja ngepmamba la nÉØmba vÉØganjan ndina kavle vak kat kai waa kwagalagendi. Kavle vak kwagalalaa kavle waavwi ndina mbangÉØmba sÉØtaa mbaw klalaa ndina mbangÉØmba kwukendi. kwutndi maa vÉØlaa nat nÉØmba ndi kat vÉØlaa wagendi. Ndina kavle vat tamba kwagalandi waa wagendi.  
\v 22 Ngwuk kat wowun. Ngwuk awuk ngwula. NgÉØni yaiga nandinya God ndinyangu kat vÉØga sÉØga nagundeya nandinya Taia Saidon walÉØnja ngepmamba la nÉØmba ndi kat God nÉØma vat yigiyandÉØ. Ngwuk ngwuk kat nÉØma nglei vat yigiyandÉØ.  
\v 23 Ngwuk Kapaneam valÉØnja ngepmamba lÉØga nÉØmba nÉØn apma vat tÉØganÉØn nyinangwupmba lÉØga nÉØmba vla lÉØganÉØn waa yelavÉØka lÉØgangwuk. Wupma yelavÉØka lÉØngwa vat ana nglaatndÉØ. God ngÉØni ngwuk kat kwutaa ya vÉØtÉØga kavat yisenda kiyandÉØ. Ngwutna ngepmamba kwutuwa nÉØma njÉØvwa tamba la ngepma Sodomba kwukewan ndi kavle yiga yetÉØnja vak kat kwagalagendi. God ndi kat ana kwutaa vatngagendÉØ.  
\v 24 Ngwuk kat wowun. GÉØni yaiga nandinya God nandinya Sodom walÉØnja ngepmamba la nÉØmba ndi kat God nÉØma vat sÉØgiyandÉØ. Ngwuk ngwuk kat nÉØma nglei vat sÉØgiyandÉØ waa wandÉØ Jisas.   
\s1 WUNA LAK YANGWEYAN NGWUK APMA YAT NJAWIYA LĘGIYANGWUK  
\p
\v 25 Wan nandinya Jisas ndÉØna nyaek kat wandÉØ. Wuna nyaek mÉØn nyinangwut kÉØpma kat vÉØga njambwi nyan mÉØn. MÉØna angwa vak apma nambuo lÉØga nÉØmba kat ana sÉØmogwiwun. Save lapman tÉØga nÉØmba kat mÉØna sÉØmogwiwun. nambuo lÉØga nÉØmba kat kai. Ndi kat ana sÉØmogwiwun. Wan yima vak apma vakna.  
\v 26 MÉØn mÉØna yelavÉØpma maavupmba wupma yimÉØn.  
\v 27 Wuna nyaek wun kat mÉØna kwondu mÉØnai yelavÉØka lÉØga vat aywaa wuna lak kwimÉØn. Wunai yelavÉØka lÉØga vat nat nÉØmba ana vÉØlÉØgandi. MÉØn kÉØta nyan mÉØna vÉØlÉØgamÉØn. MÉØnai yelavÉØka lÉØga vat nat nÉØmba ana vÉØlÉØgandi. Wun kÉØta nyan vÉØga lÉØgowun. Yagwa walaa wunai sÉØmogwia nÉØmba wundi nÉØmba ndino vÉØga lÉØgandi waa nyaek kat wasÉØmblalaa wumba kÉØta vat tÉØnda nÉØmba kat wandÉØ.   
\p
\v 28 NÉØma vat tÉØga njÉØvwa kwuka nÉØma maawut yelavÉØka lÉØga nÉØmba ngwut aywaa yagwa ngwuyla. Yalaa yat njawiaga apma maawut yelavÉØka tÉØngweya vat klaigangwuk.  
\v 29 Kwutuwa njÉØvwa agwuk ngwula. Wun kao mbundÉØ nyan ana wun. Ngwuk kat ana njÉØka waigowun. Kwutuwa apma nÉØma njÉØvwa kÉØta vat kwukngweyan apma vak yat njawiaga apma maawut yelavÉØka lÉØngweya vat klaigangwuk.  
\v 30 Wuna njÉØvwa nÉØma vat tÉØga njÉØvwa ana ndÉØ. Ngwuk kat kwiweya njÉØvwa kwutÉØngweyan ngwutna mbangÉØ wiyo waavi laagagiyandÉØ waa wandÉØ Jisas.   
\c 12  
\s1 NJĘVWA LAPMAN NANDINYA KAT NGAMBULĘNDI  
\p
\v 1 TÉØga lÉØga ngÉØni njÉØvwa lapman nandinyamba Jisas ndÉØna mbaapmamba la nÉØmbonala yuwi sÉØk watÉØga ambugava yindÉØ. Yilaa yetÉØga lÉØga ndÉØna mbaapmamba la nÉØmba wundÉØ kat tÉØndi. TÉØga lÉØga ndi yuwi sÉØk pangwutaa kÉØlÉØndi.  
\v 2 KÉØlÉØnja vak kat Ferisi vÉØlaa Jisas kat wandi. NÉØnai yetÉØlÉØga vak kat kai valaa mÉØna mbaapmamba lÉØga nÉØmba njÉØvwa lapman nandinyamba yuwi sÉØk pangwutÉØgandi. Wupma yinja vak ana nglaatndÉØ. Kavle vatna waa wandi.  
\v 3 Jisas wanja vak wutaa ndi kat wandÉØ. Tamba Devit ndÉØna mbaapma nÉØmbonala wundÉØ kat tÉØga kÉØlÉØnja vat tamba pÉØlÉØwutndi. Ngwuk ana vÉØngwuk?  
\v 4 Ndi wundÉØ kat tÉØga Godna ngay wuleilaa God kat taaganja bret-nao klalaa kÉØlÉØndi. nÉØna ngepmana vak God kat kwunatÉØga nÉØmba mÉØna kÉØlÉØndi.  
\v 5 NjÉØvwa lapman nandinyamba God kat kwunat tÉØga nÉØmba Godna ngay wuleilaa God kat kwunapmak njÉØvwa kwutÉØgandi. Wan njÉØvwa kwutÉØnja vak Moses kwiya nyaangÉØpmba ana wukngwuk? NjÉØvwa lapman nandinyamba njÉØvwa ke kwuka waa Moses waa nyaangit kat kai walaa ndi God kat kwunatÉØga nÉØmba ndi njÉØvwa kwutÉØgandi. Ndi kat nyaangÉØty ana lÉØgandÉØ.  
\v 6 Tamba Moses kwila nyaangÉØt kat kwulakiya nat nyaangÉØt ngilÉØga.  
\v 7 Tamba God wandÉØ, Hosia pÉØlÉØwutnda nyaangÉØtna angwa vat ngwuk ana vÉØga lÉØgangwuk?  
\li1 God wandÉØ. Kwanda kwanda vatnyalaa wun kat ke  
\li1 kwiga. Nat nÉØmba kat nÉØmamba yelavÉØka kwunak  
\li1 ngwula waa wandÉØ God  
\p waa tamba Hosia pÉØlÉØwutndÉØ. Kan nyaangÉØtna angwa vak vÉØgengwan apma vat yilÉØga nÉØmba kat vÉØlaa ngwuk kavle vat yilÉØgangwuk waa ana wagengwuk.  
\v 8 Wun Godna angwa vat sÉØmogwilÉØga nyan wun. Wun njÉØvwa lapman nandinyana nÉØma nyan wun. Wan nandinya wun kat njambiya ana taagagiyandÉØ.   
\s1 TAAMBA KĘVĘ WATA LA NYAN KAT JISAS KWUNATNDĘ  
\p
\v 9 Jisas wan kava kwagalalaa Juda nyaangÉØt ngambula ngay wuleindÉØ.  
\v 10 Taamba kÉØvÉØ wata la nyan kÉØta wumba lÉØndÉØ. Jisas kavle vat yindeyan wovuna. NdÉØ kat kotndangat kaligiyanÉØn waa yelavÉØka lÉØga nÉØmba ndino wumba lÉØndi. Ndi Jisas Kat wagalandi. NjÉØvwa lapman nandinyamba kÉØta nyan kat kwunapmeyan wovuna? waa wagalandi.  
\v 11 Jisas ndi kat wandÉØ. Ngwutna kÉØta nyana sip sip nÉØma waangumba ndaindÉØ maa ndÉØ njÉØvwa lapman nandinyamba taambamba kwutaa katsogiyandÉØ. njÉØvwa lapman nandinyamba kwutaa katsondeyan nyaangÉØt kai. NÉØna ngepmana vat kÉØngiyan.  
\v 12 Ndu nyan sip sip kat kwulatÉØgandÉØ. Ngi kat tÉØga njÉØvwa lapman nandinyamba kÉØta nyan kat kwunakweyan nyaangÉØt kai. nÉØna ngepmana vat kÉØngiyan waa ndi kat walaa  
\v 13 taamba kÉØvi wata la nyan kat wandÉØ. MÉØna taamba agiya wandÉØ maa taamba kwindÉØ. kwindÉØ maa ndÉØna taamba kwo lÉØndÉØ. NdÉØna nat taamba vla lÉØndÉØ.  
\v 14 Ferisi vÉØlaa wan ngay kwagalala Jisas kat vatnyanjeya vak kat yelavÉØka lÉØndi.   
\s1 JISAS GODNA NJĘVWA KWUTĘGA NYAN  
\p
\v 15 Jisas ndÉØ kat vatnyanjeya vak kat wutaa Jisas wan kava kwagalaa nat ngepmat yindÉØ. NÉØma sakwat nÉØmba ndÉØna kwupmba yindi. ndina nat nÉØmba yelogwen kat ta nÉØmba. Yelogwen kat ta nÉØmba kat aywaa kwunatndÉØ.  
\v 16 Kwunataa wandÉØ. Wuna sÉØ nat nÉØmba kat ke yiga mbuka wandÉØ.  
\v 17 Wupma kwo ana wandÉØ. Tamba profet Aisaia pÉØlÉØwukna nyaangÉØt vla ndi kat wandÉØ.   
\li1
\v 18 God wandÉØ. Wan nyan wuna njÉØvwa kwutga nyana. Kwutndeya njÉØvwa ndÉØ kat kwiwun. NdÉØ kat vÉØga  
\li1 yelavÉØka solat sÉØlÉØgowun. Wuna waagan ndÉØ kat  
\li1 kwiwun ndÉØna mbangÉØmba tavindÉØ maa wuna angwa  
\li1 vat aywaa ndinyangu kat mbukiyandÉØ.  
\v 19 Ana nÉØma kwundimba njÉØka waigandÉØ. NÉØndÉØ ava yambÉØmba  
\li1 laataa ana nÉØma kwundimba waigandÉØ.  
\v 20 VÉØta lÉØga  
\li1 suwa ana nagÉØ vÉØli mbÉØlÉØgiyandÉØ. kwunakiyandÉØ.  
\li1 Samat samat vÉØgÉØga lam ana kwutnyagiyandÉØ.  
\li1 KwunatndÉØ maa nÉØma vak vÉØkiyandÉØ. NjÉØvwa kwuka  
\li1 yiga apma vak kwulakiyandÉØ.  
\v 21 NÉØma sakwat nÉØmba  
\li1 ndÉØ kat vÉØlaa waigandi. NdÉØ nÉØn kat kwunatÉØga  
\li1 nyana waa waigandi waa wandÉØ God  
\p waa tamba pÉØlÉØwutndÉØ Aisaia.   
\s1 JISAS BIELSEBULNOGWINALA KĘTA VAT NJĘVWA KWUTĘGANDĘ WAA JISAS KAT WANDI  
\p
\v 22 KÉØta nyan kavle waagan ndÉØ kat tavila lÉØndÉØ maa ndÉØna mÉØni kwita lÉØga ndÉØna tÉØgat kulumatndÉØ, lÉØndÉØ. Wan nyan kat kwutaa Jisas la kavat kalindi. Kalindi maa Jisas kwunatndÉØ maa wan nyan mÉØni vÉØga kwundi ngambundÉØ.  
\v 23 Wumba la nÉØma sakwat nÉØmba vÉØlaa ngÉØpaliga ndalaa wandi. NdÉØ Devitna yelangÉØmba la nyan anaga ndÉØ. NÉØn Juda nÉØn kat kwunatÉØga nyan anaga ndÉØ waa wandi.  
\v 24 WalÉØnja vak Ferisi ndino tÉØga wutaa wandi. Wupma wangwa vak ana nglaatndÉØ. Waagana njambwi nyan Bielsebul ndÉØ kat kwondu kwindÉØ maa waagan kat savÉØlÉØlÉØgandÉØ waa wandi.   
\p
\v 25 Ndina maawupmba yelavÉØka lÉØnja vak kat Jisas vÉØlaa ndi kat wandÉØ. KÉØta ngepma nÉØmba mbaapma vÉØlÉØlÉØpmba lÉØga awat sowat sÉØga viyanjeyan wan ngepmamba lÉØga nÉØmba aywaa ngÉØlÉØgiyandi. KÉØta ngaymba lÉØga nÉØmba mbaapma vÉØlÉØlÉØk tÉØga awat sowat sÉØga viyanjeyan wundi nÉØmba ngÉØlÉØgiyandi.  
\v 26 Setena mbaapmamba lÉØga nÉØmba ndion wungi vat sÉØgÉØt. Mbaapma vÉØlÉØlÉØk tÉØga awat sowat sÉØga viyanjeyan ndÉØna mbaapmamba lÉØga nÉØmba ndiono ngÉØlÉØgiyandi.  
\v 27 Beklsebul ndÉØ kat kwondu kwindÉØ maa waagan savÉØlÉØlÉØgandÉØ waa wun kat walÉØgangwuk. Ngwutna mbaapma nÉØmba ndino waagan kat savÉØlÉØlÉØgandi. Ndi kat kand kwondu kwindÉØ maa waagan kat savÉØlÉØlÉØgandi. Wun kat walÉØngwa vat ndina lak yigiyandÉØ.  
\v 28 WalÉØngwa vak ana nglaatndÉØ. Godna waagan wun kat kwondu kwindÉØ maa kavle waagan kat savÉØlÉØlÉØgowun. SavÉØlÉØluwa vak vÉØlaa God nÉØn kat kwutnatndeya njÉØmbla tamba ngway tologandÉØ waa yelavÉØk ngwula.   
\p
\v 29 Tagula ava la kavle nyan ndÉØna man taamba yaawmba sangilapman tÉØga ana alÉØpsÉØga ndÉØna ngay wuleilaa ndÉØna kwanda kwanda kwutaa kaligiyandi. NdÉØ kat man taamba sangilaa mÉØna ndÉØna nda kwutaa kaligiyandi. Seten ndÉØno ndÉØ kat man taamba sangilaa mÉØna ndÉØna kwupmba lÉØga kavle waagan kat savÉØlÉØgiyandi.   
\p
\v 30 KÉØta nyan wunogwinala njÉØvwa kwutapman yindeyan wan nyan wun kat kai walÉØga nayna. Wun ndinyangu kat kwutaa kiyaa wuna mbaapmamba taaga lÉØgowun. KÉØta nyan wunogwinala taagalapman yindeyan wuna mbbapma lÉØga nÉØmba kat savÉØlÉØlÉØga nyana.   
\p
\v 31 Ngi kat tÉØga ngwuk kat wowun. Yigumba awuk ngwula wowun ngwuk kat. KÉØta nyan kavle vat yiga yetÉØga kavle nyaangÉØt ngambundeyan ndÉØnai yiga yetÉØga kavle vak God alÉØpsÉØga sÉØlÉØmbwigiyandÉØ.  
\v 32 Wun Godna vak sÉØmogwi lÉØga nyan wun. KÉØta nyan wun kat kavle nyaangÉØt ngambundeyan God ndÉØ kat alÉØpsÉØga sÉØlÉØmbigiyandÉØ. Godna waagan kat kavle nyaangÉØt ngambundeyan wupma ana sÉØlÉØmbwigiyandÉØ. NgÉØni nÉØmbun ana sÉØlÉØmbwigiyandÉØ.   
\s1 KAVLE MI KAVLE SĘK KWAIGANDĘ WAA WANDĘ JISAS  
\p
\v 33 Apma mi mÉØna apma sÉØk wogwulaa kwaigandÉØ. Kavle mi ndÉØ kavle sÉØk mÉØna wogwulaa kwaigandÉØ. Mina sÉØk vÉØlaa wan mi kat vÉØlaa ndÉØna sÉØ yelavÉØka lÉØgiyangwuk.  
\v 34 Wan apma mi kavle mi tÉØnda vak vla ngwulo ndinyangu wupma lÉØgangwuk. Ngwuk apma nyaangÉØt ana alÉØpsÉØga ngambulÉØgangwuk. Ngwuk kavle kamboyna nyangu vla lÉØgangwuk.  
\v 35 Apma maawut yelavÉØka yetÉØgiya nyan ndÉØ apma njÉØvwa kwuka apma nyaangÉØt ngambuga yetÉØgiyandÉØ. Kavle maawut yelavÉØka yetÉØgiya nyan ndÉØ kavle njÉØvwa kwuka kavle nyaangÉØt ngambuga yetÉØgiyandÉØ.   
\p
\v 36 Ngwuk kat wowun. Awuk ngwula. NgÉØni yaiga nandinya God ndinyangu kat sÉØga nagundeya nandinya kavle nyaangÉØt ngambungwa nyaangÉØt kat aywaa God ngwuk kat wagalagiyandÉØ. Wagalalaa kavle wenga kwigiyandÉØ.  
\v 37 Ngambungwa apma nyaangÉØt kavle nyaangÉØt wuka sÉØga nagulaa ngwuk kat waigandÉØ. MÉØn kavle nyan mÉØn. MÉØn apma nyan mÉØn waa ndinyangu kÉØta kÉØta kat waigandÉØ God waa wandÉØ Jisas.   
\s1 NĘMA NJĘVWA AGWUT MĘLA WAA JISAS KAT WANDI  
\p
\v 38 Jisas wandÉØ maa Moses kwiya lo sÉØmogwi lÉØga nÉØmbagwi Ferisio ndÉØ kat wandi. SÉØmogwi lÉØga nyan. Apma nÉØma njÉØvwa kwupmÉØn maa vÉØgiyanÉØn waa wandi maa.   
\p
\v 39 Jisas ndi gat wandÉØ. Ngwuk mbambala yetÉØlÉØga nÉØmba ngwuk kavle nÉØmba ngwuk. Godna vak ana vÉØga lÉØgangwuk. Apma nÉØma njÉØvwa kwukwangat wangwuk. Wangwa vak vla ana kwukiyowun. Tamba la profet Jona kwukna vak vla kwukiyowun.  
\v 40 Jona nandiynya kuwuk nÉØma kamina yapmba tÉØndÉØ. TÉØga lÉØga wogwendÉØ. Wun Godna vak sÉØmogwi lÉØga nyan wun. Wuno waangumba nandinya kuvuk ngan kuvuk tÉØga laakiyowun.  
\v 41 NgÉØni yaiga nandinya God ndinyangu kat vÉØga sÉØga nagundeya nandinya Nineva walÉØnja ngepmamba ta nÉØmba laataa ngwuk kat vÉØlaa waigandi. Tamba la profet Jona mbukna nyaangÉØt wutaa kavle vat yiga yetÉØna vak kwagalanÉØn waa waigandi. Ngwuk Ferisio Mosesna nyaangÉØt sÉØmogwi lÉØga nÉØmbo Jonana njambwi nyan mbukna nyaangÉØt wupmak kat kai wangwuk.  
\v 42 NgÉØni yaiga nandinya kambangwapmba tÉØga Solomon kat vÉØvat yat njambwi lagwa kwin laataa ngwuk kat vÉØlaa waigalÉØ. Tamba wun Solomona kwundi ngambulÉØnda vat wupmak laataa sÉØvla mbundÉØmba lÉØga yawun. Yalaa ndÉØna ngambulÉØnda apma kwundi wutwun waa waigalÉØ wat njambwi lagwa. Ngwuk Solomona njambwi nyana kwundi wupmak kat ngwuk kai wangwuk waa wandÉØ Jisas.   
\s1 KAVLE WAAGAN YILAA LUNGWAMATAA YANDĘ WAA WANDĘ JISAS  
\p
\v 43 Kavle waagan kÉØta nyan kat kwagalalaa kwo kavamba yiga yi ya yetÉØga lÉØga tÉØndeya ngay kat kwaka yetÉØndÉØ. Wan yetÉØnda kavamba ngay lÉØlapman yindeyan yelavÉØtndÉØ.  
\v 44 Tamba luwa ngayat lungwamataa yigiyowun waa yelavÉØtaa lungwamataa yandÉØ. Yalaa vÉØndÉØ. Wan ngay tamba yaguga kwunaka yelagandi, kwo lÉØndÉØ.  
\v 45 Yalaa vÉØlaa kavle waagan sÉØla vÉØli kat yiga walaa kÉØta vat yandi. Yalaa wan ngay wuleindi. Ndi waagan sÉØla vÉØli vÉØli kÉØta la waagan kat kavle vapmba kwulatndi. Ndina ngay vla lÉØga wuleinja nyan tak kavle savle lÉØndÉØ. Wuleindi maa mbambala kavle klei yilaa lÉØgandÉØ. Kavle klei lÉØnda vak vla kan mbambala klei lÉØga nÉØmba ndino kÉØta vatna.   
\s1 JISASNA NYĘMEO YAKWA NĘMBO  
\p
\v 46 Jisas ngaymba ngambulÉØndÉØ maa ndÉØna nyÉØmeo sambo yandi. Alagumba lÉØga ndÉØ kat wandi.  
\v 47 Ngaymba la kÉØta nyan ndi kat vÉØlaa Jisas kat wandÉØ. MÉØna nyÉØme yakwa nyangu kÉØndÉØ kiyandi yalaa alagumba lÉØga mÉØn kat walÉØga waa wandÉØ.  
\v 48 WandÉØ maa Jisas ndÉØ kat wandÉØ. Wuna nyÉØme wuna sambu ngwuk vÉØsÉØmogwi kiyowun walaa  
\v 49 ndÉØna mbaapmamba la nÉØmba kat ndÉØnogwinala lÉØndi, taamba sÉØga wandÉØ. AvÉØ mÉØla. Wuna nyÉØme wuna yakwa nÉØmba kÉØndÉØ kiyandi lÉØga.  
\v 50 Nyinangwupmba lÉØga wuna nyaek wa vapmba yetÉØgiya nÉØmgba wuna nyÉØme, wuna sambu, wuna nyange ndi.   
\c 13  
\s1 KĘLĘNJA NDANA SĘK YAAGI LĘGA NYAN KAT JISAS MBUTNDĘ  
\p
\v 1 Wan nandinya Jisas ngay kwagalalaa sat ta tÉØvagawiat wogwendÉØ. Wogwelaa ndaa lÉØga ndinyangu kat nyaangÉØt mbutÉØndÉØ.  
\v 2 NÉØma sakwat ndu lagwa ndÉØna nyaangÉØt wupmat yalaa tÉØndi, ndi kat vÉØlaa tamataa njaambÉØtnat wuleilaa ndaa lÉØndÉØ. NÉØma sakwat ndu lagwa tÉØvagawimba yisolaa lÉØndi, ndi kat nyaagÉØt mbutÉØndÉØ.  
\v 3 Ndi kat pagwuga mandÉØt mandÉØt nyaangÉØpmba nÉØma sakwat nyaangÉØt ndi kat mbutÉØndÉØ.  
\v 4 Mbuka walÉØndÉØ. Tak kÉØta nyan tÉØndÉØ. NdÉØ yuwi sÉØk ambugapmba yaagivat yindÉØ. YaagilÉØndÉØ maa nat sÉØk ava yambÉØmba ndandÉØ, waavi yalaa vÉØlaa kÉØndi.  
\v 5 Nat sÉØk kambat tÉØga kava tagu kipma kuvut ta kavamba ndandÉØ. Ndalaa kwiyatapman kandi waatndÉØ.  
\v 6 Njingwut tambÉØ lÉØndÉØ maa nya sÉØngwalÉØtndÉØ, njingwut law wandÉØ, kiyandÉØ.  
\v 7 Nat sÉØk kavle yuwi sÉØk tÉØga kavamba ndandÉØ. Kavle yuwi wataa tegÉØlÉØndÉØ mala sÉØk ndÉØna sÉØk ana kwandÉØ.  
\v 8 Nat sÉØk apma kÉØpmamba ndandÉØ. NdandÉØ, sÉØk kwandÉØ. Nat avamba sÉØk ndumi tambanat kwandÉØ. Nat avamba sÉØk kÉØta ndumi kuvuk kwandÉØ. Nat avamba sÉØk kÉØta ndumi kiyeli tamba vÉØli kwandÉØ.  
\v 9 Apma maawut sÉØka lÉØgiya nyan kan mbutuwa nyaangÉØtna angwa vak kat yelavÉØka lÉØgiyandÉØ waa wandÉØ Jisas.   
\s1 PAGWUGA MANDĘP MANDĘP MBUTĘNDA NYAANGĘTNA ANGWA VAK  
\p
\v 10 Jisas mbutÉØndÉØ, wuka lÉØga yalaa ndÉØna mbaapmamba la nÉØmba ndÉØ kat wagalandi. Manda kat pagwuga mandÉØt mandÉØt nyaangÉØpmba ndi kat mbutÉØmÉØn waa wagalandi.  
\v 11 Jisas ndi kat wandÉØ. nyinangwut tÉØga nÉØma nyan nÉØn kat vÉØga lÉØndeya vatna angwa vak ngwuk kat tamba sÉØmogwiwun. Nat nÉØmba kat ana sÉØmogwiwun.  
\v 12 Apma maawut sÉØka lÉØgiya nyan nÉØma sakwat nyaangÉØt wutaa wan nyaangÉØtna angwa vat wutaa yelavÉØka lÉØgiyandÉØ. NdÉØ apma vat yelavÉØka lÉØndeyan ndÉØnamba nÉØma sakwat apma nyaangÉØt tÉØgiyandÉØ. Apma maawut sÉØtapman tÉØgiya nyan nÉØma sakwat nyaangÉØt wutaa wan nyaangÉØtna angwa vak ana yelavÉØka lÉØgiyandÉØ. Apma nyaangÉØt wuka lÉØga yigumba yelavÉØtapman yilaa waigandÉØ. A. MbutÉØnja apma vak yigumba ana yelavÉØkowun. Wun tungwengwan yiga lÉØgowun waa waigandÉØ.  
\v 13 Ngi vak kat tÉØga ndi kat pagwuga mandÉØp mandÉØp nyaangÉØtmba mbutÉØwun. Ndi mÉØni vÉØga apma maawut yelavÉØtapman tÉØgandi. Ndi waan mÉØna wuka apma maawut yelavÉØtapman tÉØgandi.  
\v 14 Wupma ana kwo yilÉØgandi. Tamba la profet Aisaia pÉØlÉØwutnda vak vla wupma yilÉØgandi. Tamba kupma pÉØlÉØwutndÉØ.  
\li1 God wandÉØ. Ngwuk waan mÉØna wuka mÉØni mÉØna vÉØga  
\li1 apma maawut yelavÉØtapman tÉØgangwuk.   
\li1
\v 15 Wundi nÉØmba yelavÉØka lÉØga maawut apma maawut ana ndÉØ  
\li1 yelavÉØka lÉØnja. Ndina waan tÉØvÉØlaa lÉØgandÉØ.  
\li1 Ndina mÉØni kwita lÉØgandÉØ. MÉØni vÉØga waan wutnjeyan  
\li1 ndi vÉØga wuka yelavÉØkiyandÉØ wan apma vak kat. VÉØga  
\li1 wuka maawupmba yelavÉØtaa wun kat vÉØvat yandi maa  
\li1 ndi kat kwunakiyowun waa wandÉØ God  
\p waa tamba pÉØlÉØwutndÉØ Aisaia.   
\p
\v 16 Ngwuk apma vat tÉØgangwuk. Ngwuk mÉØni vÉØga waan wuka apma vat yelavÉØka lÉØgangwuk.  
\v 17 Ngwuk yelavÉØk ngwula. Tamba la Godna njÉØvwa kwuta nÉØmbagwi profetno vÉØlÉØngwa vak ndino vÉØvat walÉØndi. Ana vÉØlÉØndi. Waamba wutÉØngwa vak ndino wupmak walÉØndi. Ana wutÉØndi.   
\s1 NYAANGĘTNA ANGWA VAT  
\p
\v 18 Awuk ngwula. KÉØlÉØnja ndand sÉØk yaagi lÉØga nyana pogwuga lÉØga nyaangÉØtna angwa kÉØngiyan. Ngwuk kat mbukiyowun.  
\v 19 Godna nyaangÉØt wutaa maawupmba yelavÉØka yetÉØlapman yilÉØga nÉØmba ndi ava yambÉØmba nda yuwi sÉØk vla lÉØgandi. nyaangÉØt wuka lÉØndi maa Seten yalaa wan nyaangÉØt klalaa yiga pagwulÉØgandÉØ.  
\v 20 Godna nyaangÉØt wutaa ndi kwiyatapman klala nÉØmba kambat ta tagu kÉØpma kuvut ta kavamba nda yuwi sÉØk vla lÉØgandi.  
\v 21 NÉØmamba ana wan nyaangÉØt kwutaa lÉØgandi. manda kat wan nyaangÉØt kwuta lÉØgangwuk waa waliaga lÉØga wanjeyan wan nyaangÉØt kwagalagiyandi.  
\v 22 Kavle yuwi lÉØga kavamba nda lÉØga yuwi sÉØk nat nÉØmba vla lÉØgandi. Ndi Godna nyaangÉØt wutaa yigumba ana yelavÉØka lÉØgandi. Kan kÉØpmamba lÉØga kwanda kwanda klavak mÉØna yelavÉØka lÉØgandi. Ndi God waa njÉØvwa ana kwutÉØgandi.  
\v 23 Apma kÉØpmamba nda lÉØga yuwi sÉØk nat nÉØmba vla lÉØgandi. nyaangÉØt wutaa maawupmba yelavÉØka God waa njÉØvwa kwutÉØgandi. Nat nyan sÉØk ndumi tambanat kwa vak vla nÉØma nglei sakwat apma njÉØvwa kwukiyandÉØ. Nat nyan sÉØk ndumi kuvuk kwa vak vla nÉØma sakwat apma njÉØvwa kwukiyandÉØ. Nat nyan sÉØk kÉØta ndumi kiyeli tamba vÉØli kwa vak vla apma njÉØvwa kwukiyandi waa wandÉØ Jisas.   
\s1 KAVLE YUWI WAATĘGA NYAANGĘT  
\p
\v 24 Jisas pagwuga nat nyaangÉØtmba mbutÉØndÉØ ndi kat. Nyinangwupmba lÉØga njambwi nyan nÉØn kat vÉØga lÉØndeya vak kupma lÉØgandÉØ. KÉØta nyan ndÉØna ambugapmba yuwi sÉØk yaagindÉØ, kandi waatndÉØ.  
\v 25 Ngan sÉØndu kwandi maa ndÉØna maama nyan yalaa ambugapmba kavle yuwi sÉØk yaagindÉØ. Yaagilaa yindÉØ.  
\v 26 Kavle yuwi sÉØkno apma yuwi sÉØkno kÉØta kandi waapÉØk, kavle yuwi waataa lÉØnda vak kat vÉØndi.  
\v 27 VÉØlaa njÉØvwa kwuta nÉØmba yiga njambwi nyan kat mbutndi. Njambwi nyan mÉØna ambugapmba kavle yuwina sÉØk kandana yaagia. Ngi kandi waataa lÉØndÉØ vÉØna kavle yuwi waa mbutndi maa njambwi nyan wutaa wandÉØ.   
\p
\v 28 Wuna maama nyan ngan yalaa wan kavle yuwi sÉØk yaagindÉØ. WandÉØ maa wandi. WamÉØn maa kavle yuwina kandi pÉØka yaagiygiyanÉØn waa wandi.  
\v 29 Njambwi nyan wutaa kai wandÉØ. Kavle yuwina kandi pÉØpmak yingweyan apma yuwina kandio mbak pÉØtangwuk. Ke yiga pÉØka. TÉØgandÉØ.  
\v 30 NÉØma yilaa sÉØk kwandÉØ maa kÉØlÉØnja ywuina sÉØk sÉØgÉØtÉØga nyangu kat waigowun. Kavle yuwi tat pÉØtaa saymba sangilaa yamba tulaa apma yuwi sÉØk sÉØgÉØtaa wuna ngaymba yiga taaga waa waigowun waa wandÉØ njambwi nyan waa wandÉØ Jisas.   
\s1 MASTET WALĘNJA SĘKNA NYAANGĘT  
\p
\v 31 Jisas ndi kat pagwuga nat nyaangÉØtmba mbutÉØndÉØ. Nyinangwupmba lÉØga nÉØma nyan ndinyangu kat vÉØga lÉØndeya vak mastet walÉØnja sÉØk vla lÉØgandÉØ. Wan sÉØk mak nglei nda ndÉØ.  
\v 32 KÉØta nyan wan sÉØk ambugavamba yaagindeyan waakiyandÉØ. Kaawa ava vla waakiyandÉØ. NÉØma sando lÉØgiyandÉØ. Waavi yalaa ndÉØnamba ngay kwuka lÉØgiyandi waa wandÉØ Jisas.   
\s1 YISNA NYAANGĘT  
\p
\v 33 Jisas ndi kat pagwuga nat nyaangÉØtmba mbutÉØndÉØ. Nyinangwupmba lÉØga nÉØma nyan ndinyangu kat vÉØga lÉØndeya vak yis vla lÉØgandÉØ. KÉØta lagwa yis kwutaa wit milmba taagalÉØ maa kÉØkÉØk waga nÉØma yigiyandÉØ waa wandÉØ Jisas.   
\s1 PAGWUGA NAT NYAANGĘT MĘNA JISAS MBUTĘNDĘ  
\p
\v 34 Jisas wan nÉØma sakwat ndu lagwa kat pagwuga nat nyaangÉØtmba mÉØna mbutÉØndÉØ. Kapmba ana mbutÉØndÉØ.  
\v 35 Wupma kwo ana mbutÉØndÉØ. Tamba Jisas kat kupma pÉØlÉØwutndÉØ.  
\li1 Ndi kat pagwuga mandÉØt mandÉØt nyaangÉØtmba  
\li1 mbukÉØyowun. Tamba kÉØpma kwutndÉØ mala lÉØndÉØ,  
\li1 vÉØlapman yilÉØnja vak ndi kat vÉØsÉØmogwi kiyowun  
\p waa tamba pÉØlÉØwutndÉØ tamba la profet.   
\s1 KAVLE YUWI WAAT TĘGA NYAANGĘTNA ANGWA  
\p
\v 36 Wan nÉØma sakwat nÉØmba Jisas kat kwagalalaa ndina ngay wuleindi. NdÉØna mbaapmamba la nÉØmba mÉØna ndÉØnagwinala lÉØndi. TÉØga lÉØga ndÉØ kat wandi. Kavle yuwi waat tÉØga nyaangÉØtna angwa nÉØn kat ambuk mÉØla waa wandi.   
\p
\v 37 Jisas ndi kat wandÉØ. Apma yuwi sÉØk yaagi lÉØga nyan wunayÉØ God na vak sÉØmogwi lÉØga nyan.  
\v 38 Ambugat kan tÉØna kÉØpma. Apma yuwi sÉØk God vÉØga lÉØga apma nÉØmba ndi. Kavle yuwi Setena mbaapmamba lÉØga nÉØmba ndi.  
\v 39 Kavle yuwi sÉØk yaagilÉØga wuna maama nyan Setena. Yuwi sÉØk sÉØgÉØtnjeya njÉØmbla ngÉØni yaiga njÉØmbla. Yuwi sÉØk sÉØgÉØtÉØga nÉØmba ni ensel ndi.  
\v 40 Kavle yuwi pÉØtaa saymba sangilaa yamba tunja vak vla ngÉØni yaiga njÉØmbla kavle nÉØmba kat wupma yigiyandi.  
\v 41 NgÉØni wun Godna vak sÉØmogwi lÉØga nyan wun ensel kat wowun maa ndi God vÉØga lÉØga kava kava yiga kavle nÉØmba kat kwutaa man taamba sangilaa  
\v 42 ya vÉØtÉØga kavamba yaagigiyandi. Nat nÉØmba kat kavle vat ay walÉØga nÉØmba kat ndino ndi kat wupma sangilaa yaagigiyandi. Yaagindi maa nglaga nÉØmbi ngliaka kavle savle lÉØgiyandi.  
\v 43 Wan njÉØmbla Godna nÉØmba ndi apma vat tÉØgiyandi. Nat nÉØmba ndi kat vÉØlaa ndi apma nÉØmba ndi waa waigandi. Ndina nyaek vÉØga lÉØga kava kava ndi vÉØga lÉØgandi. Mbutuwa vak wutaa ngwula maawupmba yelavÉØk ngwula waa wandÉØ Jisas.   
\s1 PAGWUNJA NDA KLA NYANA NYAANGĘT  
\p
\v 44 Nyinangwutmba lÉØga nÉØma nyan ndinyangu kat vÉØga lÉØndeya vak kupma lÉØgandÉØ. KÉØta nyan kÉØpmamba vaangunja apma kwanda kwanda yiga waangu vaga vÉØndÉØ. VÉØlaa ak wumba yambÉØ kÉØpma tegÉØlÉØlaa ndÉØna kwanda kwanda aywaa kwilaa sanya klalaa yiga wan kÉØpma sanya yaagilaa klandÉØ waa wandÉØ Jisas.   
\s1 NĘMA SAKWAT SANYA KWILAA KLALĘBJA BIS WALĘNJA YELAGA NDANA NYAANGĘT  
\p
\v 45 Nyinangwutmba lÉØga nÉØma nyan ndinyangu kat vÉØga lÉØndeya vak kupma lÉØgnadÉØ. KÉØta nyan nÉØma sanyo lÉØga apma bis kat kwatÉØndÉØ.  
\v 46 Kwaka yiga apma nglei bis vÉØndÉØ. VÉØlaa ndÉØna kwanda kwanda aywaa kwilaa sanya klalaa yiga wan bis sanya yaagilaa kalndÉØ waa wandÉØ Jisas.   
\s1 NJULANA NYAANGĘT  
\p
\v 47 Nginangwupmba lÉØga nÉØma nyan ndinyangu kat vÉØga lÉØndeya vak njula vla lÉØgandÉØ. Njula yiga ngumba yisendalaa mandÉØt mandÉØt kami wan njulamba ndandÉØ.  
\v 48 NdandÉØ, kwuta nÉØmbak kalindi. kalilaa apma kami mbaymba laagalaa kavle kami klalaa kai waa yaagilÉØndi.  
\v 49 NgÉØni yaiga nandinya wupma njulamba kwutnja kami vla lÉØgiyangwuk. NÉØma nyana ensel yi ya apma nyangu kavle nyangu kat mbaapma vÉØlÉØlÉØkmba viyaseli viyasela taagagiyandi.  
\v 50 Kavle nÉØmba kat kwutaa ya vÉØtÉØga kavamba yaagigiyandi. yaagindi maa nglaga nÉØmbi ngliaka kavle savle lzÉØgiyandi.   
\s1 TAMBA NDA KUPI NDAGWI TA NYAN  
\p
\v 51 Jisas ndi kat wagalandÉØ. Mbutuwa nyaangÉØt wutaa yelavÉØka lÉØgangwuk? Waa wagalandÉØ maa awa wuka lÉØganÉØn wandi.  
\v 52 Jisas ndi kat wandÉØ. KÉØta nyan Moses kwiya lo sÉØmogwiga lÉØga nyan nyinangwut tÉØga nÉØma nyana mbaapma wuleindyan wan nyan kÉØngi vat tÉØgiyandÉØ. KÉØta nyan ndÉØna ngayna kwanda kwanda taagalÉØnda ngay wuleilaa tamba la nda kupi nda klalaa ndÉØna ngay alagu ngemba taagandÉØ waa wandÉØ Jisas.   
\s1 NASARETMBA LĘGA NĘMBA JISAS KAT KAI WANDI  
\p
\v 53 Jisas pagwuga mandÉØt mandÉØt nyaangÉØt mbuka lÉØga kwagalalaa laataa ndÉØna angwa ngepmat yindÉØ.  
\v 54 Angwa ngepma yilaa Juda nyaangÉØt ngambulÉØnja ngay wuleilaa ndi kat nyaangÉØt mbutÉØndÉØ. Wuka la nÉØmba ngÉØipali walaa ndi awat sowat ngambulÉØndi. Maawupmba yelavÉØtÉØnda vak ndÉØ kat kandana kwiya. KwunatÉØnda nÉØma njÉØvwa mandamba kwutÉØgandÉØ.  
\v 55 NdÉØna nyaek ngay kwuta nyana. NdÉØ Mariana nyana. Jems, Josis, Saimon, Judas ndina nyamwun ndÉØ.  
\v 56 NdÉØna nyange ndu nÉØnogwinala yetÉØlÉØgandi. An yiga yetÉØlÉØnda vak andamba klandÉØ waa awat sowat ngambulÉØndi.  
\v 57 Ngambuga lÉØga ndÉØ kat kai wandi. jisas ndi kat wandÉØ. God waa nyaangÉØt mbutÉØga nyan kwo ngepmamba lÉØndeyan ndÉØ kat apma maawut yelavÉØka lÉØgiyandi. NdÉØna angwa ngepmamba lÉØndeyan ndÉØna angwa ngepmana nÉØmba ndÉØ kat kai waigandi waa wandÉØ Jisas.  
\v 58 Wungi kat tÉØga ndÉØna angwa ngepmamba apma nÉØma njÉØvwa ana kwutndÉØ. Mat njÉØvwa mÉØna kwutndÉØ. Ndina mbangÉØ ndÉØ kat vÉØndi mala vali yindangat ana kwutndÉØ.   
\c 14  
\s1 NGU YAGULA JON KIYANDA VAK  
\p
\v 1 Wan njÉØmbla Galilina njambwi nyan Herot Jisas kwuta njÉØvwa kat wutndÉØ. Wutaa wandÉØ.  
\v 2 NdÉØ nambu kalÉØkwa ngu yagu la Jon. Kiyalaa lÉØga laatndÉØ. Kiyalaa lÉØga laataa kwondu klalaa wan nÉØma njÉØvwa kwutÉØgandÉØ waa ndÉØna kwupmba la nÉØmba kat wandÉØ.   
\p
\v 3 Tat Herot wandÉØ maa Jon kat kwutaa man taamba sangilaa kalabusmba taagandi, lÉØndÉØ. Herotna yakwa nyan Filipna taagwa Herodias walÉØ maa Jon kat kalabusmba taaga waa wandÉØ Herot.  
\v 4 Tak ngu yagula Jon yalaa Herot kat walÉØndÉØ. MÉØna yakwa nyana taagwa sÉØkwuka klama vat ana nglaatndÉØ. NdÉØ ana wundumbu yindÉØ. Kwo lÉØgandÉØ waa walÉØndÉØ maa  
\v 5 Herot ndÉØ kat vatnyavak kat yelavÉØka lÉØndÉØ. NÉØma sakwat Juda ndi yelavÉØtndi. NdÉØ ngu yagu lÉØga Jon God waa nyaangÉØt mbutÉØga profetna waa yelavÉØka lÉØndi. Herot ndi kat vaaka lÉØga Jon kat ana vatnyandÉØ.   
\p
\v 6 Herot kat kwutnja nandinya nÉØma kÉØgÉØnda kwutndÉØ. Kwutaa wandÉØ, nÉØma sakwat nÉØmba yandi kwutnda kÉØgÉØnda kÉØvak. Yandi maa Herodiasna taagwa nyan laataa mbangu veilÉØlÉØ maa vÉØga lÉØndi. Herot vÉØga lÉØga mbangu veila vak kat woviyaguga lÉØga wandÉØ.  
\v 7 Klavat wanyeya nda wun kat mbukiyanyÉØn. NyÉØn kat kwigiyowun. Woseka ana wowun wawa wandÉØ Herot.  
\v 8 LÉØ yiga nyÉØme kat wagalalaa yaa Herot kat walÉØ. Ngu yagu la Jona nambu kalÉØtaa wun kat yaanjÉØmba taagalaa agwi walÉØ.   
\p
\v 9 Herot wutaa Jona nambu kalÉØpmak kat ndÉØna mbangÉØ kÉØlÉØp mbangÉØ yindÉØ. Woseka ana wowun waa wanda vat aywaa wumba la nÉØmba wutndi. Ngi kat tÉØga wandÉØ maa  
\v 10 yiga kalabusmba lÉØndÉØ, ndÉØna nambu kalÉØtndi.  
\v 11 Nambu kalÉØtaa yaanjÉØmba taagalaa Herodiasna taagwa nyan kat kwindi. Wan yaanjÉØmba taagalaa kwinja nmbu klalaa nyÉØmeat yiga kwilÉØ.  
\v 12 Jona mbaapmamba la nÉØmba nambu kalÉØtnda vak kat wutaa yalaa Jona sÉØm klalaa yiga waangumba valaa taagandi. Taagalaa Jisas kat yiga mbutndi.   
\s1 JISAS 5,000 TA NĘMBA KAT KĘGĘNDA KWINDĘ  
\p
\v 13 Mbutndi maa wutaa Jisas wan kava kwagalalaa ndinyangu lapman kavat njaambÉØt kulaa yindÉØ. Yinda vat wutaa nÉØma sakwat nÉØmba laataa ndÉØ kat vÉØvat yindi nÉØmbumba.  
\v 14 Kawiga lÉØga yanja vak kat vÉØndÉØ. Ndi kat vÉØlaa miwa yiga lÉØndi. Miwa yiga lÉØga ndina yelogwen kat ta nÉØmba kat kwunatndÉØ.   
\p
\v 15 Wan nglaambu ndÉØna mbaapmamba la nÉØmba yalaa Jisas kat wandi. Kan kava kwo kava kÉØgÉØnda klaneya kava kai. Ngan lamba ndaiveigandÉØ. WamÉØn maa ngepmat yilaa kÉØgÉØnda klaandi waa wandi.  
\v 16 Wandi maa Jisas ndi kat wandÉØ. Ndi ana yigiyandi. Ngwuk ndi kat kÉØgÉØnda agwi ngwula waa wandÉØ maa  
\v 17 wandi. NÉØma kÉØgÉØnda nÉØma sakwat ana lÉØgandÉØ. Nao tambanat kami vÉØlÉØlÉØk mÉØna lÉØgandÉØ waa wandi.   
\p
\v 18-19 Wandi maa Jisas wandÉØ. Wan nao kÉØgÉØnda agwi ngwula wuna lak waa walaa nÉØma sakwat nÉØmba kat vÉØlaa ngwuk yuwimba ndaa alÉØ ngwula waa walaa wan nao kÉØgÉØnda klalaa tanambÉØka vÉØlaa God kat sÉØvu kÉØlaa wan nao tambÉØ lambÉØ lÉØmbaga ndÉØna mbaapmamba la nÉØmba kat kwindÉØ. Ndi yiga wan nÉØma sakwat nÉØmba kat kwindi.  
\v 20 KÉØlÉØndi, yaat taatÉØ. KÉØlambÉØga kwagalanja nao kÉØgÉØnda aposel mbanimba tamba vÉØli kiyeli vÉØlÉØlÉØkmba naagandi.  
\v 21 Ka ndi nÉØmbana sakwat 5,000 nÉØmba. Taagwa nyangu kat ana sÉØga nagundi. Ndu mÉØna sÉØga nagundi.   
\s1 JISAS TAGU NGUMBA VEIGA YALĘNDI  
\p
\v 22 Jisas ndÉØna kwupmba la nÉØmba kat wandÉØ. NjaambÉØt kulaa yindi maa wan ndÉØnai la kavamba la nÉØma sakwat nÉØmba kat wandÉØ. Ngwuk ngepma ay ngwula wandÉØ, yindi.  
\v 23 Yindi maa God kat nyaangÉØt ngambuvat nduwiat wokendÉØ. Wumba kapma lÉØndÉØ, ngan ndandÉØ.  
\v 24 Ngan ndandÉØ, kulaa yinja njaambÉØt nÉØndÉØ sapmba lÉØndÉØ maa mwuk ndina ndaama njaambÉØpmba viyalÉØndÉØ, nÉØma pali laataa kiyalÉØndÉØ.  
\v 25 Ngambi ngan Jisas tagu ngumba veiga ndi kat vÉØvat yalÉØndÉØ.  
\v 26 NdÉØna kwupmba la nÉØmba ndÉØ kat vÉØlaa vaaka kÉØselaga wundumba yalÉØga waa walÉØndi.  
\v 27 Jisas ndi kat wandÉØ. Ngwula maawut ke nÉØmamba yelavÉØka vakngwa. Wun Jisas wun yaa ngwuk kat vÉØvat waa wandÉØ.   
\p
\v 28 WandÉØ maa wutaa Pita ndÉØ kat wandÉØ. Njambwi nyan mÉØnayÉØ? MÉØna lat tÉØmeyan wun kat wamÉØn maa ngu tagumba veiga mÉØnai lÉØga kavat yalu wandÉØ.  
\v 29 WandÉØ maa Jisas yagwa wandÉØ. Pita njaambÉØt kwagalalaa ngu tagumba veiga yilÉØndÉØ.  
\v 30 Yiga lÉØga mwuk pali kat vÉØlaa vaaka yelavÉØtaa lumaka ndaivat yindÉØ. Lumaka ndaivat tÉØga wandÉØ. Njambwi nyan wun kat yaa kwutaa katso wandÉØ.   
\p
\v 31 Jisas yalaa ndÉØ kat taambamba kwutaa katsolaa wandÉØ. MÉØnai yelavÉØka lÉØga vat nÉØma ana ndÉØ. manda kat vapmÉØn. Vapmangat tÉØga lumaka ndaivat yimÉØn waa wandÉØ maa  
\v 32 mbÉØt njaambÉØt yiga kumbÉØt. kumbÉØt maa kwuta mwuk pali kiyak wandÉØ.  
\v 33 Kiyak wanda vak kat vÉØlaa ndÉØna mbaapmamba la nÉØmba Jisasna sÉØ kwutaa katsoga wandi. mÉØn Godna nyan mÉØn waa wandi.   
\s1 GENESARETMBA LA YELOGWEN KAT TA NĘMBA KAT JISAS KWUNATNDĘ  
\p
\v 34 NjaambÉØpmba valÉØgelaa Genesaret walÉØnja ngempamba kawindi.  
\v 35 Kawindi maa wan ngepmamba la nÉØmba Jisasna mÉØndama vÉØlaa yanda vak yiga mbutndi. Mbutndi maa ngepma ngepmamba yelogwen kat ta nÉØmba kat aywaa kwutaa kiyandi.  
\v 36 Yelogwen kat ta nÉØmba ndÉØna waavwina njÉØmbwi waavwi sÉØnyÉØpmak kat wagalandi. njÉØmbwi waavwi sÉØnyÉØta nÉØmba yelogwen kat ta nÉØmba ndi kwo lÉØndi.   
\c 15  
\s1 JUDANA NGWAT YETA VAK  
\p
\v 1 Moses kwiya nyaangÉØt sÉØmogwi lÉØga nÉØmbo Ferisio Jerusalem kwagalalaa yalaa Jisas kat vÉØlaa wagalandi.  
\v 2 Manda kat mÉØna mbaapma nÉØmba nÉØna ngwat ndu tamba waa vapmba yetÉØlapman yilÉØgandi. Taamba njangi lapman manda kat kwo kÉØlÉØgandi waa wagalandi maa  
\v 3 Jisas ndi kat wandÉØ. Ngwuk God waa nyaangÉØt kat kwagalalaa ngwula ngwat ndu waa nyaangÉØpmba yetÉØlÉØgangwuk. Ana nglaatndÉØ.  
\v 4 Tamba God wandÉØ, āNgwula nyaek nyÉØme kat apma vat ay ngwula. KÉØta nyan ndÉØna nyaek nyÉØme kat kavle nyaangÉØt ngambundeyan ndÉØ kat vatnyagiyangwukā waa wandÉØ God.  
\v 5 Ngwuk Gerisi mandÉØp vak yilÉØgangwuk. KÉØta nyan wuna nyaek nyÉØme kat kwunapmat kwiweya nda tamba God kat kwigiyowun waa wandeyan apma vatna nyaangÉØt kai waa wangwuk.  
\v 6 Wun ngwuk kat wowun. God kat kwindeyan ndÉØna nyaek nyÉØme kat ndÉØ kavle vat yigiyandÉØ. God kat kwindeyan mbÉØk kwanda kwanda lapman tÉØga kavle savle lÉØgiyambÉØk. Wungi vak walÉØngwa vapmba Godna nyaangÉØt kwagalalaa ngwutna kavle maawupmba yelavÉØka yetÉØlÉØgangwuk.  
\v 7 Ngwuk woseka walÉØga nÉØmba ngwuk. Tamba la profet Aisaia ngwuk kat pÉØlÉØwutndÉØ. NdÉØ woseka waga ana pÉØlÉØwutndÉØ. kupma pÉØlÉØwutndÉØ. NdÉØ woseka waga ana pÉØlÉØwutndÉØ. Kupma pÉØlÉØwutndÉØ.   
\li1
\v 8 God wandÉØ. Wundi nÉØmba ndina kwundimba wuna sÉØ  
\li1 nÉØma yindangat walÉØgandi. Ndina maawupmba wun  
\li1 kat ana yelavÉØtÉØgandi.  
\v 9 Ndi nambu sÉØlandalaa wun  
\li1 kat maawupmba yelavÉØtnja vak kwo vatnat  
\li1 tÉØlÉØgandÉØ. Wunai waa nyaangÉØt kwagalalaa  
\li1 ndinyangu mbukna nyaangÉØt nat nÉØmba kat sÉØmogwiga  
\li1 mbutÉØgandi. Kan God waa nyaangÉØtna woseka waa  
\p waa pÉØlÉØwutndÉØ Aisaia waa wandÉØ Jisas.   
\s1 MAAWUT KAT KAVLE YIGIYA VAT  
\p
\v 10 Jisas nÉØma sakwat nÉØmba kat wandÉØ maa yandi. Yandi maa ndi kat wandÉØ. Ngwula waan wuka maawut yelavÉØk ngwula.  
\v 11 Ndinyangu kÉØgiya kÉØgÉØnda nda nyan kat ana kavle yigiyandÉØ. Ndina kwundimba ngambunjeya kavle nyaangÉØt wan nyaangÉØt ndu nyan kat kavle yigiyandÉØ waa wandÉØ Jisas.   
\p
\v 12 WandÉØ maa ndÉØna mbaapmamba la nÉØmba yalaa ndÉØ kat wandi. Wama nyaangÉØt kat wupmak kat Ferisi ndi kai wandi waa wandi.   
\p
\v 13 Jisas ndi kat wandÉØ. Nginangwupmba lÉØga wuna nyaek ndÉØ ambukat kwutÉØgandÉØ. NdÉØna ambukapmba nat nyan tugiya nda God ndÉØ aywaa pÉØka yaagigiyandÉØ.  
\v 14 Ferisi kat ngwuk nÉØma vak ke yelavÉØkngwa. nat mÉØni vÉØlapman nyan kat yambÉØ sÉØmogwi lÉØga mÉØni vÉØlapman nyan vla lÉØgandi. MÉØni vÉØlapman tÉØgiya mbÉØt vÉØlÉØlÉØk palÉØ yiga lÉØga ava yambÉØ kwagalalaa waangumba ndaigiyambÉØk waa wandÉØ Jisas.   
\p
\v 15 Pita ndÉØ kat wandÉØ. Ndu nyan kavle vat yigiya vak kat mbutÉØma nyaangÉØtna angwa nÉØn kat sÉØmogwi mÉØla. Ana vÉØga yelavÉØka lÉØganÉØn waa wandÉØ Pita.  
\v 16 Jisas ndi kat wandÉØ. Nat nÉØmbo ngwutno ana maawut sÉØka lÉØgangwuk.  
\v 17 Maawut sÉØtapman nÉØmba vla lÉØgangwuk. Ndinyangu kÉØgiya nda yapmba wuleilaa tÉØga kwo wogwegiyandÉØ.  
\v 18 Ndinyangu kwundimba ngambugiya nyaangÉØt maawupmba yelavÉØtaa ngambugiyandi. Wan ngambunjeya vak ndinyangu kat kavle yigiyandÉØ.  
\v 19 Maawupmba lÉØga kavle vak kÉØngiyan. Ngwuk kat mbukwa. Nat nyan kat vatnya lÉØnja vat, yambÉØsÉØk yilÉØnja vat, kavle vat yilÉØnja vak, sÉØkwut tÉØnja vak, woseka walÉØnja vak, njÉØka walÉØnja vak.  
\v 20 Wan vak aywaa ndinyangu kat kavle yigiyandÉØ. Ngwuk kat wanja vak taamba njangi lapman kÉØngwa vak ndinyangu kat ana kavle yigiyandÉØ waa wandÉØ Jisas.   
\s1 KENENA TAAGWA JISAS KAT NĘMA VAK YELAVĘKA LĘLĘ  
\p
\v 21 Jisas wan kava kwagalalaa Taiagwi Saidano walÉØnja ngepma vÉØlÉØlÉØk ta kavat yindÉØ.  
\v 22 Wan ngepmamba yetak Kenemba la taagwa yalaa Jisas kat vÉØlaa walÉØ. Njambwi nyan, Devitna yelangÉØ nyan, wun kat miwa ay mÉØla. Wuna taagwa nyan kavle waagan tavila lÉØndÉØ maa kavle savle tÉØgalÉØ waa walÉØ.  
\v 23 WalÉØ, Jisas ana awat lÉØ kat wandÉØ. NdÉØna mbaapmamba la nÉØmba vÉØlaa yaa ndÉØ kat wandi. NÉØna kwupmba yalaa nÉØma kwundimba waa yilÉØgalÉØ. LÉØ kat wamÉØn yigalÉØ waa wandi.   
\p
\v 24 Wandi maa Jisas wandÉØ. SÉØlÉØwata lÉØga sip sip vla lÉØga Juda kat mÉØna kwunapmak yawun. NyÉØn Juda ana nyÉØn. NyÉØn njambwi nyana nyan vla lÉØgat taagwa ana nyÉØn waa wandÉØ Jisas.  
\v 25 WandÉØ maa kwali mamba sÉØlaa walÉØ ndÉØ kat. njambwi nyan wun kat kwunap mÉØla waa walÉØ.  
\v 26 Jisas lÉØ kat wandÉØ. Njambwi nyan ndÉØna nyangu kat kwindeya kÉØgÉØnda ndÉØna waala kat kwindeyan ana nglaatndÉØ waa wandÉØ Jisas.  
\v 27 WandÉØ maa walÉØ. Njambwi nyan ngiyambak wama. KÉØgÉØnda kÉØlÉØnja njÉØmbla kÉØpmamba nda lÉØga kÉØlambÉØ kÉØgÉØnda waala kÉØlÉØndi waa walÉØ.  
\v 28 Jisas lÉØ kat wandÉØ. NÉØnai yelavÉØka lÉØga vat nÉØma ngleia. Kan wun kat wagalanya vat tÉØgiyandÉØ waa wandÉØ Jisas. Wanda sÉØvamba lÉØla taagwa nyan apma vat kwo lÉØlÉØ.   
\s1 JISAS YELOGWEN KAT TA NĘMA SAKWAT NĘMBA KAT KWUNATNDĘ  
\p
\v 29 Jisas wan kava kwagalalaa yiga Galili walÉØnja sak tÉØvagawi yiga nduwi wokelaa ndaa lÉØndÉØ.  
\v 30 Ndaa lÉØndÉØ maa yelogwen kat ta nÉØma sakwat nÉØmba kat kwutaa ndÉØnai la kavat kiyandi. Man kÉØvÉØ wakna nÉØmba, mÉØni vÉØlapman nÉØmba, ava tagwulia nÉØmba, kwundi walapman nÉØmba, mandÉØt mandÉØt yelogwen kat ta nÉØmba ndi kat kwutaa Jisas ta kavat kiyandi. kiyandi, vÉØlaa ndi kat kwunatndÉØ.  
\v 31 KwunatndÉØ maa kwundi walapman ta nÉØmba kwundi ngambundi. KÉØvÉØ watna man ta nÉØmba laataa veiga yilÉØndÉØ. Ava tagwulia nÉØmba ndino kwo lÉØndi. MÉØni vÉØlapman ta nÉØmba mÉØni vÉØndi. KwunatÉØnda vak kat va nÉØmba vÉØlaa ngÉØpali walaa Isrelna njambwi nyan God ndÉØ apma vat nÉØn kat kwunatndÉØ waa wandi.   
\s1 JISAS 4,000 NĘMBA KAT KĘGĘNDA KWINDĘ  
\p
\v 32 TÉØga lÉØga Jisas ndÉØna mbaapmamba la nÉØmba kat wandÉØ. Wundi nÉØmba kat miwa yiga lÉØgowun. Nandinya kuvuk wunogwinala tÉØgandi. Kiyanja kÉØgÉØnda tamba aywaa ngÉØlÉØndÉØ. Ndi kat kÉØgÉØnda kwilapman tÉØga ay ngwula waa wavak kat kai wowun. Ay waweyan ava yambÉØmba yiga lÉØga mÉØni ngangan yindÉØ maa anagandi ndaiga waa wandÉØ.  
\v 33 NdÉØna mbaapmamba la nÉØmba ndÉØ kat wagalandi. Kan kava kwo kava. Ngepma kai. Ndi kat kwineya bret-nao andamba klaiganÉØn. Ndi nÉØma sakwat nÉØmba ndi waa wandi.  
\v 34 Wandi maa Jisas wandÉØ. Ngwut taagala lÉØngwa bret-nao angamala tÉØgandÉØ waa wandÉØ maa bret-nao sÉØla vÉØli mat kami kuvut wupma taaganÉØ, tÉØgandÉØ waa wandi.   
\p
\v 35 Jisas wandÉØ maa wan nÉØma sakwat nÉØmba kÉØpmamba ndaa lÉØndi.  
\v 36 Bret-nao sÉØla vÉØli kami kuvuk klaa kwutaa God kat sÉØvu kÉØlaa wan nao lÉØmbaga ndÉØna mbaapmamba la nÉØmba kat kwindÉØ. Yalaa la nÉØma sakwat nÉØmba kat yiga kwindi.  
\v 37 Ndi aywaa kÉØlÉØndi, yaat taatÉØ. KÉØlambÉØnja kÉØgÉØnda Jisasna mbaapmamba la nÉØmba klalaa mbani sÉØla vÉØli naangandi.  
\v 38 Ka ndi nÉØmbana sakwat 4,000. Ndu mÉØna nagindi. Taagwa mat nyangu kat ana nagindi.  
\v 39 Jisas wan kava kwagalalaa njaambÉØt kulaa Magadan walÉØnja ngepmat yindÉØ.   
\c 16  
\p
\v 1 Ferisio Sadyusio yalaa Jisas kat vÉØlaa yelavÉØtndi. NdÉØ nyinangwupmba lÉØga yandÉØ? E? Nyinangwupmba lÉØga ana yandÉØ. NdÉØ kÉØpmana nyana waa yelavÉØtaa wandi ndÉØ kat. NÉØma apma njÉØvwa agwut. KwupmÉØn maa vÉØlaa nyinangwupmba ya nyana waa yelavÉØkiyanÉØn waa wandi.  
\v 2 Jisas ndi kat wandÉØ. Nglaambu nya ndaindÉØ, vÉØlaa nyinangwut yelogwen mbangÉØ lÉØndÉØ maa vÉØlaa walÉØgangwuk. nyinangwut yelogwen mbangÉØ lÉØgandÉØ. Kinya meik ana ndaigandÉØ waa walÉØgangwuk.  
\v 3 Ngambi nya wokendÉØ, vÉØlaa nyinangwut yelogwen mbangÉØ lÉØndÉØ maa vÉØlaa walÉØgangwuk. Mbambala meik ndaigandÉØ waa walÉØgangwuk. Nyinangwut vÉØlaa ngÉØni yaiga meik mwuk tat vÉØga lÉØgangwuk. Manda kat kwutawa njÉØvwa vÉØlaa yetuwa vak kat ana vÉØga lÉØgangwuk.  
\v 4 Kan mbambala lÉØga ndu lagwu Godna vak vÉØlapman kavle vat yiga yetÉØlÉØga nÉØmba ndi. NÉØma apma njÉØvwa agwup mÉØla waa wun kat wangwuk. Ana kwukiyowun. NÉØma nyÉØvwa kÉØta mÉØna kwuikiyowun. Tamba la nyan Jona kwukna vak vla mÉØna kwukwun, vÉØgiyangwuk waa wandÉØ Jisas. Wandi maa Jisas kat kwagalalaa yindi.   
\s1 FERISIO SADYUSINA YIS  
\p
\v 5 Jisas ndÉØna mbaapma nÉØmbagwi njaambÉØt kulaa sak valÉØgendi. KÉØgÉØnda klalapman maawut tÉØvÉØga kwagalalaa kwo yindi.  
\v 6 Jisas ndi kat wandÉØ. Ferisiogwi Sadyusina bretmba taagalÉØnja yis ke klaga. Kavle nda wandÉØ.  
\v 7 WandÉØ maa ndÉØna mbaapmamba la nÉØmba awat sowat yelavÉØka ngambulÉØndi. manda kat kupma wandÉØ. KÉØgÉØnda klalapman yanangat anagandÉØ waa waa yelavÉØka ngambulÉØndi.  
\v 8 Jisas ngambulÉØnja vak kat wutaa wandÉØ. KÉØgÉØnda klalapman yangwa vak kat manda kat ngambulÉØgangwuk. KÉØgÉØnda kat manda kat nÉØmamba yelavÉØka lÉØgangwuk.  
\v 9 Njambwi nyanat tuwa vat ngwuk ana nÉØmamba yelavÉØka lÉØgangwuk. Tat bret-nao tambanat klalaa 5,000 ta nÉØmba kat kwiwun maa kÉØndi. KÉØndi mala kÉØlambÉØnja kÉØgÉØnda angamala mbanimba naangangwuk.  
\v 10 Nat njambÉØ bret-nao sÉØla vÉØli klalaa 4,000 ta nÉØmba kat kwiwun maa klalaa kÉØndi. KÉØndi mala kÉØlambÉØnja kÉØgÉØnda mbani angamala naagangwuk.  
\v 11 Tat ngwuk kat wowun. Ferisogwi Sadyusina bretmba taagalÉØnja yis ke klaga wowun. KÉØlÉØnja bret-nao kat ana wowun waa wandÉØ Jisas.  
\v 12 WandÉØ maa ndÉØna mbaapmamba la nÉØmba maawupmba yelavÉØka lÉØndi. Bretmba taagalÉØnja yis kat ana wandÉØ. Ferisio Sadyusio mbutÉØga nyaangÉØt ngwuk ke wuka waa wandÉØ waa yelavÉØkaw lÉØndi.   
\s1 MĘN KRAIST MĘN WAA JISAS KAT WANDĘ PITA  
\p
\v 13 Jisas Sisaria Filipai walÉØnja ngepmana ngwayat yindÉØ. NdÉØna mbaapmamba la nÉØmbo ndÉØno kÉØta vat yindi. Jisas ndi kat wagalandÉØ. Wun Godna vak sÉØmogwi lÉØga nyan wun kat ndu lagwa anda sÉØmba walÉØgandi waa wagalandÉØ maa wandi.  
\v 14 Nat nÉØmba ndÉØ ngu yagu lÉØga Jona waa mÉØn kat walÉØgandi. Nat nÉØmba ndÉØ Jeremaia waa mÉØn kat walÉØgandi. Nat nÉØmba ndÉØ profetna waa mÉØn kat walÉØgandi waa wandi.  
\v 15 ma Jisas ndi kat wagalandÉØ. Ngwuk wun kat angamak walÉØgangwuk waa wagalandÉØ.   
\p
\v 16 Pita ndÉØ kat wandÉØ. MÉØn nÉØn kat kwunapmak ya nyan mÉØn. MÉØn Godna nyan mÉØn waa wandÉØ Pita.  
\v 17 WandÉØ, Jisas ndÉØ kat wandÉØ. Saimon, Jonana nyan mÉØn apma maawut yelavÉØka lÉØgamÉØn. Maawupmba yelavÉØtÉØma vak nat nyanananmba ana klamÉØn. Nyinangwupmba lÉØga wuna nyaek mÉØn kat mbutndÉØ, wamÉØn.  
\v 18 MÉØn kambak vla lÉØgamÉØn. Wuna mbaapmamba tÉØgiya nÉØmba kÉØngi kambapmba veiga laataa lÉØgiyandi. Wundumbu yinjeyan wuna mbaapmamba veilapman tÉØgiya nÉØmba ngÉØni kavle yigiyandi.  
\v 19 Nginangwuk wuleilÉØnja ndaamangemba lÉØga mbapmona ki mÉØna lak taagagiyowun. Kan kÉØpmamba lÉØga nÉØmba kat kemapmeyan ndi ana wuleigiyandi. Kan kÉØpmamba lÉØga wuleigiyangwuk wameya nÉØmba ndi wuleigiyandi waa wandÉØ Jisas Pita kat.  
\v 20 Pita kat walaa ndÉØna mbaapmamba la nÉØmba kat aywaa ndi kat wandÉØ. Ndinyangu kat kwunapmat ya nyan Kraistnat tuwa vat nat nÉØmba kat ke mbukngwa wandÉØ.   
\s1 KIYALAA LĘGA LAAKIYOWUN WAA WANDĘ JISAS  
\p
\v 21 Wan njÉØmbla Jisas kÉØta nyaangÉØt ndi kat ngambundÉØ. Ngambuga wandÉØ. Samat tÉØga Jerusalemat yigiyowun. Yiwun maa Judana njambwi nÉØmbo God kat kwunatÉØga njambwi nÉØmbo Moses kwiya nyaangÉØt sÉØmogwi lÉØga nÉØmbo wun kat kwutaa kavle vat yigiyandi. Kavle vat yiga wun kat kwutaa vatnyagiyandi. Kiyalaa nandinya kuvut tÉØga laakiyowun waa wandÉØ maa wutaa  
\v 22 Pita ndÉØ kat kwuknat kalilaa wandÉØ. Njambwi nyan wama vat ana nglaatndÉØ. Manda kat wupma wamÉØn. Wan kavle vat mÉØn kat wupma yilandi waa wandÉØ maa  
\v 23 Jisas Pita kat wandÉØ. Seten mÉØn wun kat kwagalalaa ay. yiweya yambÉØ kat mÉØn ke tÉØvÉØlÉØga. YelavÉØtÉØma vak Godna vak ana ndÉØ. Ndinyanguna vakna yelavÉØtÉØma waa ndÉØ kat walaa ndÉØna mbaapmamba la nÉØmba kat wandÉØ.   
\p
\v 24 KÉØta nyan wuna mbaapma wuleivat wandeyan avla ndÉØna mbangÉØ kwunapmak kat kai walaa kwutuwa njÉØvwa ndÉØno kwukiyandÉØ.  
\v 25 KÉØta nyan ndÉØna mbangÉØ kwunapmak mÉØna yelavÉØka lÉØndeyan kavle yigiyandÉØ. KÉØta nyan wuna njÉØvwa kwuka yetÉØga kiyandeyan ndÉØ apma vat tÉØgiyandÉØ.  
\v 26 KÉØta nyan kÉØpmana kwanda kwanda nda aywaa klalaa kavle vat yiga yetÉØndeyan wan apma vatna? Kai. Apma vat ana ndÉØ. Kavle vatna. NjÉØmbla njÉØmbla apma vat tÉØnjeya vat kÉØta nyan wenga kwilaa ana klaigandÉØ.  
\v 27 Wun Godna vak sÉØmogwi lÉØga nyan samat tÉØga enselonala yaigowun. Wuna nyaek wun kat ndÉØna kwondu kwindÉØ maa yaigowun. Yalaa ndinyangu aywaa kwutÉØnja njÉØvwa kat wenga kwigiyowun.  
\v 28 Ngwuk wutaa yelavÉØk ngwula. Ngwutna nat nÉØmba kwo lÉØga njambwi nyanat tÉØga yaweya vat vÉØgiyangwuk. Wun Godna vak sÉØmogwi lÉØga nyan wun yaweya vak vÉØgiyangwuk waa wandÉØ Jisas.   
\c 17  
\s1 JISASNA MBANGĘ MANDĘP MBANGĘ LĘNDĘ  
\p
\v 1 Nandinya sÉØla kÉØta yindÉØ maa Jisas Pita Jems Jon nyamwun sambu ndi kat yagwa waa kwutaa nÉØma nduwiat klo kalindÉØ.  
\v 2 Wokelaa lÉØga Jisasna mbangÉØ mandÉØt mbangÉØ ngwandÉØyandÉØ, vÉØga lÉØndi. NdÉØna mÉØndama nya vla sÉØlÉØndÉØ, vÉØndi. NdÉØna waavwi sawun glei mÉØna lÉØga kemba kava vla lÉØndÉØ maa vÉØndi.  
\v 3 VÉØlÉØndi maa Mosesogwi Ilaijo yalaa ndÉØnogwinala ngambuga lÉØmbÉØt, ndi kuvut nyangu tÉØga lÉØga vÉØndi.  
\v 4 VÉØga lÉØga Pita Jisas kat wandÉØ. Njambwi nyan kan kava apma kava. TÉØnan apma vatna. WamÉØn maa kwapÉØ mbale kuvuk kwukiyanÉØn. mÉØn kat kÉØta Moses kat kÉØta Ilaija kat kÉØta kwukiyanÉØn waa walÉØndÉØ maa  
\v 5 sawun mbangÉØ tÉØmbu ngaga yalaa tÉØnja kava kapmandÉØ. TÉØmbumba lÉØga ndu nyana kwundi ngambulÉØndÉØ maa wutÉØndi. Kwundi kupma ngambundÉØ. Wan nyan wuna nyana. NdÉØ kat vÉØga waa ngambundÉØ wan kwundi.   
\p
\v 6 Wan kwundi wutaa Jisasna mbaapmamba la ndi nyangu vaaka lÉØga mÉØndama mÉØndama kÉØpmamba ndalaa lÉØndi.  
\v 7 Ndalaa lÉØndi, Jisas yalaa taamba laagalaa ndi kat wandÉØ. Ke vaaka lÉØngwa. laak ngwula wandÉØ, laatndi.  
\v 8 Laataa ngambuga lÉØnda mbÉØt nyan kat ana vÉØndi. Jisas kapma lÉØndÉØ, vÉØndi.   
\p
\v 9 Wan nduwi kwagalalaa ngaga yalÉØndi maa Jisas ndi kat wandÉØ. Wun Godna vak sÉØmogwi lÉØga nyan wan. Wun kiyalaa laakwun maa kan vÉØngwa vak ngÉØni nat nÉØmba kat mbukiyangwuk. Kanmbambala ke yiga mbuka waa wandÉØ Jisas.   
\p
\v 10 NdÉØna mbaapmamba la nÉØmba ngambunda nyaangÉØt wutaa ndÉØ kat wagalandi. Moses kwiya nyaangÉØt sÉØmogwi lÉØga nÉØmba kupma walÉØgandi. Kraist tat ana yaigandÉØ. Ilaija tat yandÉØ maa ngÉØni Kraist yaigandÉØ waa walÉØgandi. Wupma manda kat walÉØgandi waa wagalandi Jisas kat.   
\p
\v 11 Jisas wagalanja vak wutaa ndi kat wandÉØ. ngiyambak wanja. ilaija ndÉØ tamba yandÉØ. Yalaa Kraist yaiga yambÉØ kwunatndÉØ.  
\v 12 Ilaija yandÉØ, kan kÉØpmamba la ndu lagwa Ilaija njambwi nyanat tÉØnda vak kat ana vÉØga lÉØngi. ndina maawupmba ndÉØ kat kavle vat yelavÉØka kavle yindi. NdÉØ kat kavle vat yinja vat vla wuno Godna vak sÉØmogwi lÉØga nyan wun kat kavle vat yigiyandi waa wandÉØ Jisas.  
\v 13 Jisas wanda nyaangÉØt wutaa maawupmba yelavÉØtndi. NdÉØ Ilaija walÉØndan ngu yagu la Jon kat walÉØgandÉØ waa yelavÉØka lÉØndi.   
\s1 JISAS KAVLE WAAGAN TAVILA LA NYAN KAT KWUNATNDĘ  
\p
\v 14 Nduwimba lÉØga ngaga yalaa nÉØma sakwat ta nÉØmba la kavat ndi yindi. Yindi maa kÉØta nyan yalaa Jisasna mÉØndama sambÉØmba kwlai mamba sÉØlaa ndÉØ kat wandÉØ.  
\v 15 Wuna mat nondanyan kat miwa yilaa kwunap mÉØla. Kavle waagan ndÉØ kat tavila lÉØandÉØ. Kavle waagan ndÉØ kat kwutndÉØ maa mÉØni ngangan yindÉØ, kÉØpmamba ndaa lÉØgandÉØ. Nat nÉØma sakwat njambÉØ yamba ndaa lÉØgandÉØ. Nat njambÉØ ngumba yilÉØgandÉØ.  
\v 16 MÉØna mbaapmamba la nÉØmba kat kwutaa kiyowun maa ana alÉØpsÉØga ndÉØ kat kwunatndi waa wandÉØ maa  
\v 17 Jisas ndÉØna mbaapmamba la nÉØmba kat vÉØlaa wandÉØ. Ngwuk nÉØmamba ana yelavÉØtÉØgangwuk. Ngwuk kavle vat yelavÉØtÉØgangwuk. Anda sakwat nandinya tÉØga ngwuk kat sÉØmagaga mbutÉØwun mala nÉØmamba yelavÉØkiyangwuk. NÉØmamba yelavÉØtapman yilÉØngwa vak kat wupmak kat kai wowun. Wan nyan kat yiga kwutaa wuna lak agiya ngwula waa wandÉØ Jisas.  
\v 18 Wan nyan kat kiyandi maa Jisas vÉØlaa kavle waagan savÉØlÉØndÉØ, yingÉØ. YindÉØ maa wan nyan apma vat kwo lÉØndÉØ.   
\p
\v 19 Wan nÉØma sakwat ta nÉØmba yindi maa vÉØlaa Jisasna mbaapma nÉØmba ndÉØ kat wagalandi. manda kat kavle waagan alÉØpsÉØga nÉØn savÉØlÉØlapman yinan waa wagalandi.   
\p
\v 20 Wagalandi maa Jisas ndi kat wandÉØ. God kat nÉØmamba yelavÉØka kwutaa lÉØlapman yingwan kat tÉØga wan kavle waagan kat savÉØlÉØlapman yingwuk. God kat nÉØmamba yelavÉØka lÉØngja vat samat ngwutanamba tÉØndeyan kan tÉØga nduwi kat ay wangwuk, yigiyandÉØ. God kat nÉØmamba yelavÉØka lÉØngja vak kat nÉØma sakwat vak kat ana wowun. God kat nÉØmamba yelavÉØka lÉØngja vak samat ngwutnamba lÉØndyan ngwuk nÉØma nÉØma njÉØvwa kwukiyanngwuk.  
\v 21 (KÉØgÉØnda kÉØvak kat kai walaa God kat wagala lÉØngweyan kÉØngi vat tÉØga waagan savÉØlÉØgiyangwuk waa wandÉØ Jisas.)   
\s1 KIYALAA LAAKIYOWUN WAA JISAS VĘLĘLĘK WAN NJAMBĘ WANDĘ  
\p
\v 22 Jisasna mbaapmamba la nÉØmba Galilimba yisolaa lÉØndi maa ndi kat wandÉØ. Wun Godna vak sÉØmogwi lÉØga nyan wun. Wun kat ngÉØni kwutaa vatnyagiyandi.  
\v 23 Kiyalaa nandinya kuvut tÉØga laakiyowun waa wandÉØ maa wutaa ndÉØna mbaapmamba la nÉØmba nÉØma maawut yelavÉØka lÉØndi.   
\s1 JISAS TAKIS SANYA YAAGINDĘ  
\p
\v 24 Jisas ndÉØna mbaapmamba la nÉØmbo kapaneam walÉØnja ngepmat yindi. Ngepma wuleindi maa Godna ngay kwunatÉØnja takis sanya kla lÉØga nyan yalaa Pita kat wagalandÉØ. Ngwutna njambwi nyan takis sanya yaagilÉØgandÉØ? E? Ana yaagilÉØgandÉØ? Waa wagalandÉØ.   
\p
\v 25-26 WagalandÉØ maa Pita wutaa awa wandÉØ. Walaa ngay wuleindÉØ mala Jisas ndÉØ kat wandÉØ. Saimon mÉØn angamak yelavÉØka lÉØgamÉØn. Kan kÉØpmana njambwi king anda nÉØmbananamba takis sanya klalÉØgandi. Ndina ngepma nÉØmbananamba ana klalÉØgandi. Nat ngepma nÉØmbananamba mÉØna klalÉØgandi waa wandÉØ. Jisas ngiyambak wamÉØn wandÉØ. NÉØn Godna ngepma nÉØmba nÉØn. Ngi kat tÉØga nÉØn Godna ngay kwunatÉØnja takis sanya yaagilapman yineyan wan vat kwowa.  
\v 27 Yaagilapman yineyan nÉØn kat kai waigandi. Ngi vak kat kai wowun. Ngi kat tÉØga sak yilaa sÉØngwa laagagiyamÉØn. Tat kwupma kami kwutaa ndÉØna ngaangamba sanya vÉØlaa klalaa kwutaa agiya. MÉØna wugÉØn wuna wugÉØn sanya kwigiyamÉØn waa wandÉØ Jisas.   
\c 18  
\s1 KANDANA NĘMA NYAN  
\p
\v 1 Jisasna mbaapmamba la nÉØmba Jisas kat yalaa wagalandi. Nyinangwut wuleilaa anda nyana kwulaka nÉØma nyanat tÉØgiyaa waa wagalandi.   
\p
\v 2 Wagalanja vat wutaa Jisas mat nyan kÉØta kat yagwa wandÉØ, yalaa ndina nÉØndÉØmba laataa lÉØndÉØ.  
\v 3 LÉØndÉØ maa jisas ndi kat wandÉØ. Ngwuk yelavÉØk ngwula. Mbambala maawupmba yelavÉØtÉØngwa vak kwagalalaa kan mat nyan tÉØga vla tÉØlapman yingweyan nyinangwut ana wuleigiyangwuk.  
\v 4 KÉØta nyan wun nÉØma nyan ana wun waa yelavÉØka lÉØga kan mat nyan tÉØga v a tÉØndeyan wan nyan nyinangwut wuleilaa nÉØma nyanat tÉØgiyandÉØ.   
\p
\v 5 KÉØta nyan wuna njÉØvwa kwuka kÉØngi vat mat nyan kat apma vat yilÉØndeyan wan yindeya apma vat wuna lak yaigandÉØ waa wandÉØ Jisas.   
\s1 KAVLE VAT NDINYANGUNA MAAWUT KAT KAVLE YILĘGANDĘ  
\p
\v 6 Jisas ndi kat wandÉØ. KÉØngi vat mat nyan vla lÉØga nÉØmba wun kat yelavÉØtnja vak kat nat nyan kai wandÉØ maa wun kat kwagalalaa yindeyan wan ana nglaatndÉØ. Wan kai waa nyan kat nÉØma kambak klalaa yaawmba tulaa kwapmba waataa ngumba yaagingweyan apma vatna.   
\p
\v 7 Nat nÉØmba kÉØpmana nda kat vÉØlaa wun kat yelavÉØtÉØnja vak kwagala lÉØgandi. Kan kÉØpmana nda kavle nda. Nat nÉØmba wun kat kwagalagiyandi. VÉØlÉØgowun. Wun kat yelavÉØtÉØga nÉØmba kat kai walÉØga nÉØmba ndi wan nÉØmba kavle klei nÉØmba ndi. ndi kavle klei yigiyandi.   
\p
\v 8 KÉØta nyana taambamba kwutÉØnda kavle njÉØvwa ndÉØna maawupmba lÉØga apma vak kat kwulatndeyan taamba kalÉØka tÉØgandÉØ. Taamba lapman apma kavat tÉØndeyan wovuna. Apma taamba lÉØga kavle kava njÉØmbla njÉØmbla ya vÉØtÉØga kavat yindeyan kavle vatna. KÉØta nyan kavle kavat man veiga wan kavamba kavle njÉØvwa kwutÉØnda njÉØvwa ndÉØna maawupmba lÉØga apma vak kat kwulatndeyan man kalÉØkiyandÉØ. SambÉØn tÉØga apma kavat yindeyan apma vatna. man apma vat tÉØndÉØ, kavle kava njÉØmbla njÉØmbla ya vÉØtÉØga kavat yindeyan kavle vatna.  
\v 9 KÉØta nyan mÉØnimba vÉØnda kavle vat ndÉØna maawupmba lÉØga apma vak kat kwulatandeyan mÉØni pÉØnguga yaagigiyandÉØ. MÉØni lapman kÉØta naangÉØ mÉØnimba vÉØga apma kavat yindeyan apma vatna. MÉØni vÉØli apa apma vat tÉØmbÉØk, kavle kava njÉØmbla njÉØmbla ya vÉØtÉØga kavat yindeyan ana nglaatndÉØ.   
\s1 SĘLĘWOKNA SIP SIPNA NYAANGĘT  
\p
\v 10 Ngwuk mat nyangu kat vÉØlaa ndi kwo nda ndi waa ke yelavÉØkngwa. Ndi kat vÉØga lÉØga ensel ngilÉØga. Ndina ensel nyinangwupmba lÉØga wuna nyaekagwi lÉØgandi.  
\v 11 (Wun Godna vak ÉØmogwi lÉØga nyan wun. Wun sÉØlÉØwota la nÉØmba kat aywaa kwunapmak kat yawun.)   
\p
\v 12 KÉØta nyan sip sip l00 ndÉØnamba lÉØndÉØ. VÉØga lÉØndÉØ. Kita yiga sÉØlÉØwotnda. SÉØlÉØwotndÉØ maa ndÉØ angamak yigiyandÉØ. Ngwuk angamak yelavÉØkalÉØgangwuk. Ngwuk kat waigowun. Samat tÉØga 99 kwo lÉØga sip sip kat ana vÉØga lÉØgiyandÉØ. SÉØlÉØwokna sip sip kat kwaka yigiyandÉØ nat sip sip kat kwagalalaa. Kwagalalaa yinda sip sip kwo lÉØga yuwi kÉØga lÉØgiyandi.  
\v 13 Kwaka yiga vÉØlaa solat sÉØngÉØ.  
\v 14 Sip sip kat vÉØga la nyan ta vak vla ndÉØno nyinangwupmba lÉØga ngwutna nyaek God wupma vÉØga lÉØgandÉØ. NdÉØna nyangu mbaak sÉØlwatandi walÉØgandÉØ God.   
\s1 KAVLE VAT YA NYAN KAT KWUNAKNGWEYA VAK  
\p
\v 15 MÉØnogwinala kÉØta vat wuna mbaapmamba la nyan mÉØn kat kavle vat yindeyan ndÉØ kat vÉØlaa kavle vat yinda vak kat ngambu mbÉØla. nat nÉØmba kat ke mbuka. Ngambuma nyaangÉØt wutndeyan wovuna. NdÉØ kat tamba kwunapmÉØn.  
\v 16 Wupmak kat kai wandeyan mÉØna mbaapmamba la kÉØta nyan o vÉØlÉØlÉØk palÉØ kwutaa yiga ndinogwinala kÉØta vat tÉØga ndÉØ kat nyaangÉØt ngambu ngwula. Tamba la nÉØmba God waa nyaangÉØt kupma pÉØlÉØwutndi.  
\p VÉØlÉØlk pali o kuvut nÉØmba kÉØta nyaangÉØpmba ngambungweyan wovuna. Ngambungweya  
\li1 nyaangÉØt kwo valat ana tÉØgiyandÉØ  
\p waa tamba pÉØlÉØwutndi. Tamba pÉØlÉØwutnja nyaangÉØt vla ngambu ngwula.  
\v 17 Kuvut nÉØmba ngambu nyaangÉØt wupmak kat kai wandeyan kÉØta vat mbaapmamba lÉØngwa nÉØmba kat aywaa mbukiyangwuk. Kavle vat yinda vak kat wukiyandi. Ndina nyaangÉØt wupmak kat kai wandeyan ndÉØ maama nyana waa ndÉØ kat yelavÉØk ngwula. NdÉØ takis sanya klalÉØga kavle nyan vla lÉØgandÉØ waa ndÉØ kat yelavÉØk ngwula.  
\v 18 Ngwuk kat wowun. Kan kÉØpmamba kÉØta nyan kavle vat yiga yetÉØnda vak kat kwunatapman yingweyan nyinangwupmba lÉØga nyaek God ndÉØno ana kwunakiyandÉØ. kÉØpmamba lÉØga yinjeya kavle vak kat kwunakngweyan nyinangwupmba lÉØga nyaek God ndÉØno kwunakiyandÉØ.   
\p
\v 19 Ngwuk kat nat samak nyaangÉØt mbukiyowun. Ngwutna vÉØlÉØlÉØk palÉØ kÉØta maawupmba yelavÉØka lÉØga God kat kwi nda kwindangat wagalambeyan wuna nyinangwupmba lÉØga nyaek wagalambeya nda mbÉØk kat kwigiyandÉØ.  
\v 20 VÉØlÉØlÉØk palÉØ kuvut nÉØmba kÉØta yisolaa lÉØga wuna sÉØ waga ngambulÉØngjeyan wuno ndina nÉØndÉØmba kÉØta vat tÉØgiyowun waa wandÉØ Jisas.   
\s1 NAT NYAN YILĘNDA KAVLE VAT KWAGALALAPMAN NJĘVWA KWUTA NYAN  
\p
\v 21 Pita yalaa Jisas kat wagalandÉØ. Njambwi nyan wuna mbaapmamba la nyan anda sakwat njambÉØ wun kat kavle vat yindÉØ, vÉØlaa ndÉØnai yindeya kavle vat sÉØlÉØmbwigiyowun. NjambÉØ sÉØla vÉØli ndÉØna kavle vat sÉØlÉØmbwiweyan wovuna? Waa wagalandÉØ Pita. WagalandÉØ maa Jisas wandÉØ.   
\p
\v 22 Kai la. SÉØla vÉØla njambÉØ kai. 490 njambÉØ yindeya kavle vak kat vÉØlaa sÉØlÉØmbwimeyan wovuna waa wandÉØ Jisas. Anda sakwat njambÉØ sÉØlÉØmbwigiyowun waa wanda nyaangÉØt wutaa Jisas wupuseput mbutÉØndÉØ.   
\p
\v 23 Nyinangwupmba lÉØga njambwi nyan ndinyangu kat vÉØga lÉØndya vat kÉØngi vat tÉØgandÉØ. Tamba njambwi king kÉØta lÉØndÉØ. NdÉØna njÉØvwa kwuta nÉØmbana dinau aywaa kwunataa kalÉØpmak kat wandÉØ.  
\v 24 Dinau kat kwunaka kalÉØka sÉØlÉØmbwiga yilÉØndÉØ, kÉØta nyan nÉØma nglei dinau la nyan kat kwutaa kingat kiyandi.  
\v 25 Ngi kat tÉØga njambwi king wandÉØ. NdÉØna kwanda kwanda aywaa ndÉØna nyan taagwa aywaa kwilaa wenga klalaa wan dinau kat agwi. NdÉØno ndÉØ kat kwilaa wenga klalaa wun kat agwi waa wandÉØ maa  
\v 26 njÉØvwa kwuta nyan kwali mamba sÉØlaa nambu sÉØlandalaa king kat wandÉØ. Wun kat miwa ay mÉØla. NgÉØni yuwa inau aywaa kwigiyowun waa ndÉØ kat wagalandÉØ.  
\v 27 King wutaa miwa yilaa ndÉØna dinau kat kai waa kwagalandÉØ.   
\p
\v 28 KwagalandÉØ mala laataa wogwendÉØ. Wogwelaa ndÉØnogwi kÉØta vat njÉØvwa kwuta nyan kat vÉØndÉØ. VÉØlaa kwapmba kwutaa ndÉØ kat wandÉØ. MÉØn tamba la wuna mat dinau kat agwi mÉØla wandÉØ.   
\p
\v 29 WandÉØ maa nat nyan wandÉØ. Samat kawiga alÉØ. Kwigiyowun wandÉØ.  
\v 30 Kawiga lÉØvak kat kai walaa ndÉØ kat kwutaa yiga kalabusmba taagandÉØ. Dinau kat kwimeyan mÉØna kalabus ngÉØlÉØgiyandÉØ walaa ndÉØ kat kalabusmba taagandÉØ.   
\p
\v 31 KÉØta vat njÉØvwa kwuta nat nÉØmba yinda vak vÉØlaa kavle vat yindÉØ waa yelavÉØtaa njambwi king kat yiga mbutndi.  
\v 32 King wan nyaangÉØt wutaa ndÉØna njÉØvwa kwuta nyan kat yagwa wandÉØ, yandÉØ. YandÉØ maa king ndÉØ kat wandÉØ. MÉØn kavle klei nyan mÉØn. Wun kat yima nÉØma nglei dinau wun kat yaa wagalamÉØn maa kai waa kwagalawun. MÉØnagwi kÉØta vat njÉØvwa kwuta nyan ndÉØ kat ana miwa yigamÉØn. MÉØn kat tamba miwa yiga kai waa nÉØma dinau kwagalawun. NdÉØ kat wupma ana miwa yiga mÉØn kat yinda mat dinau kwagalamÉØn.  
\v 33 MÉØn kat miwa yiga luwa vak vla manda kat nat nyan kat miwa yilapman yimÉØn. MÉØn kavle keli nyan mÉØn waa wandÉØ njambwi king.  
\v 34 Njambwi king nyingi maawut tÉØga wandÉØ maa ndÉØna njÉØvwa kwuta nyan kat kwutaa yiga kalabusmba taagandi. Dinau kat kwimeyan mÉØna kalabus ngÉØlÉØgiyandÉØ walaa ndÉØ kat kalabusmba taagandi.   
\p
\v 35 Kan ngwuk kat wawa wapuseputna angwa nyaangÉØt yelavÉØk ngwula. Ngwutna mbaapmamba lÉØga nÉØmba ngwuk kat kavle vat yinja vat kat kai waa kwagalalapman yingweyan nyinangwupmba lÉØga wuna nyaek kavle vat yingwa vat kat ana kai waa kwagalagiyandÉØ waa wandÉØ Jisas.   
\c 19  
\s1 TAAGWA KAT KWAGALANJA VAT  
\p
\v 1 Jisas wan nyaangÉØt ngambulaa Galili kwagalalaa Judiat yindÉØ. Jodan walÉØnja ndandangÉØ nat naangat yindi.  
\v 2 NÉØma sakwat nÉØmba ndÉØna kwupmba yindi. Yindi maa ndina yelogwen kat vÉØlaa Jisas kwunatndÉØ.  
\v 3 Nat Ferisi ndÉØ kat yalaa wagalangeya vak kat anagandÉØ mandÉØp vapmba ngambugiya waa yelavÉØtaa ndÉØ kat wagalandi. Moses kwiya nyaangÉØt angamak wandÉØ. KÉØta nyan ndÉØna taagwa kat kwo kwagalandeyan wovuna? waa wagalandi.   
\p
\v 4 Jisas wuta wandÉØ. Tamba God wandÉØ, pÉØlwutnja nyaangÉØt ngwuk ana vÉØngwuk? Tamba God ndu lagwa kat kwutaa kÉØpmamba laagalaa wandÉØ.   
\q1
\v 5 Ndu ndÉØna nyaek nyÉØmena ngay kwagalalaa yiga  
\q1 ndÉØna tagwonala yetÉØgiyandÉØ. Ndu taagwa kÉØta vat tÉØgiyambÉØt waa wandÉØ God  
\p waa tamba pÉØlÉØwutndi.  
\v 6 Ndu taagwa klandeyan kapma kapma mbangÉØ ana ndÉØ. MbÉØk kÉØta mbango lÉØgiyambÉØt. MbÉØla mbangÉØ kÉØta mbÉØk kÉØta nyan mbÉØk. God mbÉØk kat sangindÉØ, lÉØgambÉØt. Ndu ndÉØna taagwa kat ana kwagalagiyandÉØ waa wandÉØ Jisas.  
\v 7 Ferisi wanda nyaangÉØt wutaa ndÉØ kat wagalandi. Wama nyaangÉØt ana nglaatndÉØ. Tamba Moses wandÉØ. KÉØta nyan pepa pÉØlÉØwutaa taagwa kat kwilaa kwo kwagalagiyandÉØ waa Moses tamba pÉØlÉØwutndÉØ. Manda kat wupma pÉØlÉØwutndÉØ waa wandi. Wandi maa Jisas wandÉØ.   
\p
\v 8 Kavle savle tÉØngwa vak kat vÉØlaa ngwuk taagwa kwagalavak kat pepa taagwa kat kwilaa kwagalagiyangwuk waa wandÉØ Moses. Tamba God ndu lagwa kat kwuta njÉØmbla ndu taagwa kat kwagalanjeya vak wupma ana lÉØndÉØ.  
\v 9 Ngwuk kat wowun. KÉØta nyan ndÉØna taagwa kat vÉØvak kat kai waa kwo kwagalalaa nat taagwa kat klandeyan ndÉØ wan nyan wupma yindeya vak yambÉØsÉØk taagwa kat yinjeya vak vla lÉØgandÉØ. NdÉØna taagwa sÉØmblan wangÉØga yetÉØlÉØ, vÉØlaa kwagalandeyan nyaangÉØt kai waa wandÉØ Jisas.   
\p
\v 10 Jisas wandÉØ maa ndÉØna mbaapmamba la nÉØmba ndÉØ kat wandi. taagwa klaga lÉØgiya nyan ndÉØna taagwa kat kai waa kwagalagiyandÉØ. NÉØna ngepma vatna. Ngwut taagwa kat ke kwo kwagalaga waa wama nyaangÉØt apma vat tÉØndeyan taagwa klalapman tÉØgiya nyan mÉØna apma vat tÉØgiyandÉØ waa wandi.   
\p
\v 11 Jisas ndi kat kupma wandÉØ. Taagwa klalapman vat aywaa wupma ana yilÉØgandi. Nat nÉØmba kat mÉØna wan vak God kwilÉØgandÉØ.  
\v 12 Taagwa klalapman tÉØnja vatna angwa nÉØma sakwat tÉØgandÉØ. Nat nÉØmba ndina maawupmba yelavÉØtaa taagwa kla vak kat kai walÉØgandi. nat nÉØmba na alÉØpsÉØga klalÉØgandi. Nat nÉØmba nÉØn Godna njÉØvwa mwna kwuka yetÉØga taagwa ana klaiganÉØn waa walÉØgandi. Ndinyangu aywaa wupma ana yilÉØgandi. Taagwa kat klalapman yigiya nÉØmba mÉØna kan nyaangÉØt awuk ngwula waa wandÉØ Jisas.   
\s1 JISAS MAT NYANGU KAT APMA VAT YINDĘ  
\p
\v 13 Jisas ndina nambumba taamba laagalaa God kat wagalandangat nÉØma sakwat mat nyangu kat nyaek nyÉØme kwutaa kiyandi. Kiyanja vak kat vÉØlaa Jisasna mbaapmamba la nÉØmba kai wandi.  
\v 14 Kai wanja vak kat wutaa Jisas ndi kat wandÉØ. Ke kai wangwa. Nyinangwupmba lÉØga apma nda kÉØndigi mat nyangu tÉØga vla tÉØgiya nÉØmba klaigandi waa walaa  
\v 15 ndina nambumba taamba taagandÉØ. Taagalaa lÉØga wan kava kwagalalaa yindÉØ.   
\s1 NĘMA SAKWAT KWANDA KWANDA NDO LA KWANDĘ NYAN  
\p
\v 16 KÉØta nyan Jisas la kavat yalaa wagalandÉØ. SÉØmogwi lÉØga nyan, kan kÉØpmogwi njÉØmbla njÉØmbla nyinangwupmba apma vat tÉØweya vak klavak kat angamak njÉØvwa kwukiyowun waa wagalandÉØ.  
\v 17 WandÉØ maa Jisas ndÉØ kat wandÉØ. Apma nda klavak kat manda kat wun kat wagalamÉØn. Kan kÉØpmamba apma nyan ana lÉØgandÉØ. God ndÉØ kÉØta nyan mÉØna apma nyan tÉØgandÉØ. Tamba God wandÉØ, pÉØlÉØwutnja nyaangÉØpmba wuka yetÉØmeya njÉØmbla njÉØmbla apma vat tÉØmeya vat klaigamÉØn waa wandÉØ Jisas.   
\p
\v 18 Manda nyaangÉØt kat wamÉØn God waa nyaangÉØt waa Jisas kat wagalandÉØ. Jisas wutaa wandÉØ ndÉØ kat. Nat nyan kat ke vatnyaga, yambÉØsÉØk ke yiga yetÉØmeya, ke sÉØkwuka, nat nyan kat woseka ke waga,  
\v 19 nyaek nyÉØme mÉØn kat waiga nyaangÉØt awup mÉØla. Avla mÉØna mbangÉØ kwunatÉØma vak vla nat nÉØmba kat kwunap mÉØla waa tamba God wandÉØ, pÉØlÉØwutndi waa wandÉØ Jisas.   
\p
\v 20 Wan nyan wutaa wandÉØ. Wama nyaangÉØt aywaa wuka yetÉØlÉØgowun. Nat anda njÉØvwa kwukweya waa wandÉØ maa  
\v 21 Jisas ndÉØ kat wandÉØ. Kwupmeya nat njÉØvwa kita lÉØgandÉØ. Wan njÉØvwa kwutaa apma vat tÉØgiyamÉØn. MÉØna kwanda kwanda aywaa kwilaa wenga yiga klalaa sanya lapman tÉØga nÉØmba kat agwi mÉØla. Kwilaa nyinangwut wuleimeyan apma wenga klaigamÉØn. Ndi kat kwilaa wuna kwupmba yagwa mÉØla waa wandÉØ Jisas.  
\v 22 Wan kwandÉØ nyan wutaa ndÉØna mbangÉØ valÉØ yilÉØndÉØ maa yindÉØ. NdÉØna kwanda kwanda nÉØma sakwat nda kat kwagalavak kat kai waa yelavÉØka yindÉØ.   
\p
\v 23 YindÉØ maa Jisas ndÉØna mbaapmamba la nÉØmba kat wandÉØ. Ngwuk kat wowun. NÉØma sakwat sanya nÉØma sakwat kwanda kwanda la nyan nyinangwut wuleindeyan nÉØma njÉØvwa.  
\v 24 Bulmakau vla lÉØga kamel kumbwi mbawna yambÉØ wuleivat tÉØndeyan njÉØvwa lÉØgandÉØ. NÉØma sakwat kwanda kwanda ndo lÉØga nyan nyinangwut wuleivat tÉØndeyan nÉØma nglei njÉØvwa waa wandÉØ Jisas.   
\p
\v 25 WandÉØ maa wutaa ndÉØna mbaapmamba la nÉØmba ngÉØpaliga ndalaa ndÉØ kat wagalandi. Nyinangwut kandana wuleiya waa wagalandi.   
\p
\v 26 Jisas ndi kat vÉØlaa wandÉØ. Ndinyangu nat nÉØmba kat kwutaa nyinangwutnat ana kaligiyandi. Wan Godna njÉØvwa. NdÉØ alÉØpsÉØga kaligiyandÉØ. NdÉØ nÉØma nglei njÉØvwa kwukiyandÉØ waa wandÉØ Jisas.   
\p
\v 27 WandÉØ maa Pita Jisas kat wandÉØ. Awut. Wutaa yelavÉØk. NÉØna kwanda kwanda nda aywaa kwagalalaa mÉØna kwupmba laataa yinÉØn. NgÉØni anda wenga klangeya waa wandÉØ Pita.   
\p
\v 28 Jisas wutaa wandÉØ. Ngwuk kat wowun. NgÉØni yaiga nandinya kupi nda lÉØgiya nandinya wun Godna vak sÉØomgwi lÉØga nyan yalaa wuna njambwi tÉØkÉØtmba ndaa lÉØga ndinyangu kat vÉØga lÉØgiyowun. Njambwi nyanat tÉØgiyowun. Ngwutno tamba vÉØli kiyeli vÉØlÉØlÉØk yelangÉØ kat vÉØga lÉØgiyangwuk. Ndina njambwi nÉØmbat tÉØgiyangwuk.  
\v 29 KÉØta nyan wuna njÉØvwa kwupmak ndÉØna ngay nyamwun nyange nyaek nyÉØme nyangu ambukat kwagalandeyan ngÉØni yaiga nandinya mandÉØt nda nÉØma sakwat klaigandÉØ. Klalaa njÉØmbla njÉØmbla apma vat tÉØndeya vat klaigandÉØ.  
\v 30 Mbambala kÉØpmamba lÉØga nÉØma sakwat ndo lÉØga nÉØmba ngÉØni yaiga nandinya ndi kwanda kwanda lapman nÉØmbat tÉØgiyandi. Mbambala kÉØpmamba lÉØga kwanda kwanda lapman nÉØmba ngÉØni yaiga nandinya ndi nÉØma sakwat ndo tÉØgiyandi.   
\c 20  
\s1 AMBUGAT NJĘVWA KWUTĘGA NĘMBANA WAPUSEPUT  
\p
\v 1 Jisas wandÉØ. Nyinangwupmba lÉØga njambwi nyan ndinyangu kat vÉØga lÉØnda vat kÉØngi vat tÉØgandÉØ. KÉØta nyan nÉØma ambugavo lÉØndÉØ. Ngambi ambugatna nyan laataa njÉØvwa kwut nÉØmba kat kwaka yindÉØ.  
\v 2 Yiga vÉØlaa ndinyangu kat wandÉØ. Nandinya kÉØta njÉØvwa kwukngweyan ngwuk kat dola kÉØta kwigiyowun wandÉØ. Wutaa wovuna walaa njÉØvwa kwupmat yindi.  
\v 3 Ngambi 9 klok laataa ngepma yiga njÉØvwa kwut nÉØmba kat kwaka wavat nat njambÉØ yindÉØ.  
\v 4 Kwaka yiga kwo la nÉØmba kat vÉØlaa wandÉØ. Wuna ambugapmba yiga njÉØvwa kwukngweyan ngwuk kat wenga kwigiyowun wandÉØ. WandÉØ maa yindi.  
\v 5 NÉØma nÉØndÉØ nandinya ak laataa ngepma yindÉØ. Nglaambu 3 klok at ngepma yindÉØ.  
\v 6 Nglaambu 5 klok laataa ngepma yindÉØ. Yilaa kwo la nÉØmba kat vÉØlaa ndi kat wandÉØ. Ngwuk manda kat njÉØvwa kwutapman kwo laataa lÉØgangwuk waa wagalandÉØ maa wandi.  
\v 7 NÉØn kat nat nyan njÉØvwa ana kwindÉØ waa wandi maa wuna ambugapmba yiga njÉØvwa agwut ngwula wandÉØ. WandÉØ maa yindi.   
\p
\v 8 Nglaambu ndÉØna ambugat vÉØga la nyan kat wandÉØ. NjÉØvwa kwuta nÉØmba aywaa yandi maa ndi kat sanya agwi mÉØla. NgÉØni njÉØvwa kwupmat ya nÉØmba tat ndi kat sanya agwi. Ngambi tata njwvwa kwupmat ya nÉØmba kat ngÉØni sanya agwi waa wandÉØ.   
\p
\v 9 Nglaambu 5 klokmba yiga njÉØvwa kwukna nÉØmba kat dola kÉØta kÉØta njÉØvwa kwutaa nyangu kat kwindÉØ.  
\v 10 Ngambi tata yiga njÉØvwa kwukna nÉØmba vÉØlaa nÉØn nÉØma sakwat dola klaiganÉØn waa maawupmba yelavÉØtndi. Wupma ana klandi. Dola kÉØta mÉØna klandi.  
\v 11 Dola kÉØta klalaa wan ambugatna nyan kat njÉØka wandi.  
\v 12 KÉØndi nÉØmba nglaambu yalaa wan ana nÉØma njÉØvwa kwutndi. NÉØma njÉØvwa ana kwutndi. NÉØn ngambimba yalaa kan njÉØvwa kwutÉØnÉØn nÉØna mbangÉØ nya nÉØmamba sÉØlÉØndÉØ nÉØma waangÉØt soga kwutÉØnÉØn. NÉØnogwi ndi kat manda kat kÉØta wengamba kwimÉØn waa njÉØka wandi ndÉØ kat.   
\p
\v 13 Wanja vak wutaa ndina kÉØta nyan kat wandÉØ. Wuna ava nyan wuna kÉØta nyaangÉØt awup mÉØla. MÉØn kat ana woseka waa kavle wenga kwiwun. Ngambi mÉØn kat wowun. Mbambala njÉØvwa kwupmeyan dola kÉØta mÉØn kat kwigiyowun waa wowun maa wovuna yiga mÉØna njÉØvwa kwukiyowun wamÉØn.  
\v 14 Klama dola kwutaa ngay ay. NgÉØni njÉØvwa kwupmak ya nyan kat mÉØn kat kwiwa wenga vla ndÉØ kat kwiweyan wuna vatna. MÉØna vak ana ndÉØ.  
\v 15 Kwiweya sanya wuna sanya kwiweya. Wuna maawupmba yelavÉØtaa kwiweyan mÉØn nyaangÉØt kai. Ndi kat kwo kwiweya vak kat manda kat mÉØn kai wamÉØn. Wuna vatna waa wandÉØ ambugatna nyaek.  
\v 16 Nyinangwut wuleigiya nÉØmba ndino wupma klaigandi. Tat mat nyan tÉØga Godna njÉØvwa kwuka nÉØma sakwat naambi tÉØga kiyalaa nyinangwut wuleinjeyan ngÉØni God ndi kat wenga kwigiyandÉØ. AvÉØt ndu lÉØga Godna njÉØvwa kwuka naambi kuvut tÉØga kiyalaa nyinangwut wuleinjeyan tak God ni kat wenga kwigiyandÉØ waa wandÉØ Jisas.   
\s1 JISAS WANDĘ KIYALAA LĘGA LAAKIYOWUN  
\p
\v 17 Jisas Jerusalem yiga lÉØga nat nÉØmba kat kwagalalaa ndÉØna mbaapmamba la tamba vÉØli kiyeli vÉØlÉØlÉØk nÉØmba kat wandÉØ.  
\v 18 Ngwuk awuk ngwula. Mbambala Jerusalem yigiyanÉØn. Wun Godna vak sÉØmogwi lÉØga nyan wun kat kwutaa God kat kwunatÉØga njambwi nÉØmbo Moses kwiya nyaangÉØt sÉØmogwi lÉØga nÉØmba lÉØga kavat kaligiyandi. Ndi wun kat waigandi. NdÉØ kat kwutaa yiga vatnya waa wun kat waigandi.  
\v 19 Wandi maa Juda ana ndi nat nÉØmba wun kat kwutaa njÉØka waga viyalaa diwai krosmba kaalagiyandi. Kiyalaa nandinya kuvut tÉØga laakiyowun waa wandÉØ Jisas.   
\s1 JEMSOGWI JONO NĘMA NYAN TĘVAK KAT WAGALAMBĘT  
\p
\v 20 Sebedina nyan vÉØlÉØlÉØkna nyÉØme mbÉØk kat kwutaa Jisas ta kavat kiyalaa nambu sÉØlandalaa Jisas kat kÉØta nda kat wagalavat tÉØlÉØ.  
\v 21 Wagalavat tÉØlÉØ maa anda nda wun kat wagalanyÉØn wandÉØ. Wat taagwa walÉØ. NgÉØni kingat tÉØga nÉØma tÉØgÉØtmba ndaa lÉØmeya njÉØmbla wuna mbÉØt nyan nat nyan yaagindan naangÉØmba ndaa lÉØga njambwi nyanat tÉØndangat ndaa lÉØga njambwi nyanat tÉØndangat mÉØn kat wagalawun waa walÉØ. WalÉØ maa wutaa Jisas mbÉØk kat wandÉØ.   
\p
\v 22 Wagalamba vat mbÉØtna maawutmba yigumba yelavÉØtapman tÉØga wun kat wagalambÉØk. Wun kat yinjeya nÉØma vat vla mbÉØk kat wupma yivat tÉØnjeyan yinjeya nÉØma vat vla mbÉØk kat wupma yivat tÉØnjeyan wun kat kwagalagiyambÉØt? waa wagalandÉØ maa wambÉØt. Kai mÉØn kat ana kwagalagiya waa wambÉØt. wambÉØt maa wandÉØ.  
\v 23 Awa luwa. Wun kat kavle yinjeya vak vla mbÉØk kat wupma kavle yigiyandi. Yaagindan naangÉØ ambugendan naangÉØmba ndaa lÉØgiya nÉØmba kat wun ana waigowun. Wuna njÉØvwa ana ndÉØ. Wan njÉØvwa wuna nyaek mÉØna kwutÉØnda njÉØvwa waa wandÉØ Jisas.  
\v 24 Jisasna mbaapmamba la tamba vÉØli nÉØmba wutaa nyingi maawut yelavÉØka mbÉØk kat waleavat tÉØndi.  
\v 25 Jisas yagwa ngwula wandÉØ, yalaa yisolaa lÉØndi, ndi kat mbuka wandÉØ. Kan kÉØpmamba la njambi nÉØmba nat nÉØmba kat mandÉØp mandÉØp vapmba vÉØga lÉØga nÉØna njÉØvwa agwuk ngwula waa nÉØma kwundimba walÉØgandi.  
\v 26-27 Ngwuk wungi vat njÉØvwa wana kwutÉØngweya. Ngwutna kÉØta nyan njambwi nyanat tÉØvat wandeyan nat nÉØmbana njÉØvwa kwuka ndina nyaangÉØt wukiyangwuk.  
\v 28 Wuno Godna vak sÉØmogwi lÉØga nyan wungi vat njÉØvwa kwutÉØgowun. Wuna njÉØvwa nat nÉØmba kwutnjangat ana yawun. Ndi kat tÉØga njÉØvwa kwupmat yawun. kwo luwa vat kwagalalaa kiyalaa nat nÉØmba kat wenga kwivat yawun waa wandÉØ Jisas.   
\s1 JISAS MĘNI KIYALA LA MBĘT NYAN KAT KWUNATNDĘ  
\p
\v 29 Jeriko kwagalalaa yindi maa Jisasna kwupmba nÉØma sakwat nÉØmba yindi.  
\v 30 MÉØni kiyandÉØ ta mbÉØt nyan ava yambÉØ waymba ndaa lÉØga Jisas yanda vak kat wutaa nÉØma kwundimba walega wambÉØt. Jisas mÉØn Devitna yelangÉØ nyan mÉØn. An kat miwa ay mÉØla waa walega wambÉØt.  
\v 31 WalÉØmbÉØt mala wan nÉØma sakwat ya nÉØmba wutaa mbÉØk kat wandi. MbÉØk kiyak awa mbÉØla walÉØndi, wuka kwagalalaa nÉØma kwundimba walega walÉØmbÉØk. Jisas mÉØn Devitna yelangÉØ nyan mÉØn. An kat miwa ay mÉØla walÉØmbÉØt.   
\p
\v 32 Jisas yiga lÉØga tamataa mbÉØk kat wandÉØ. MbÉØk kat manda yiwangat walÉØgambÉØk.   
\p
\v 33 WandÉØ mala wambÉØt. Njambwi nyan. Ana mÉØni kwunapmangat mÉØn kat walega walÉØgali waa wambÉØt.   
\p
\v 34 Jisas wutaa mbÉØk kat miwa yilaa mbÉØtna mÉØnimba taamba taagalaa kunatndÉØ mbÉØk kat. Apma mÉØni bÉØlaa laataa Jisasna kwupmba yimbÉØt.   
\c 21  
\s1 JISAS KING VLA JERUSALEM WULEINDĘ  
\p
\v 1 Jerusalem yiga lÉØga Jerusalemna ngwaymba la ngepma Betfasi yandi. Wan ngepma Oliv walÉØnja nduwi waymba lÉØgandÉØ. Yalaa lÉØga Jisas ndÉØna mbaapmamba la mbÉØt vÉØlÉØlÉØk palÉØ kat wandÉØ. MbÉØk tata ay mbÉØla.  
\v 2 Ngepma wuleilaa donki nyano nyÉØmeo yaawumba tndi, kwambÉØt, yiga vÉØlaa svugiga kwutaa wuna lak agiya.  
\v 3 SÉØvugimbeya vak vÉØlaa mandana yilÉØmba waa kÉØta nyan wandeyan ndÉØ kat awamba mbÉØt. NÉØma nyan wandÉØ mala yaa kalivat yigali waa awamba mbÉØt. Wupma wambeyan kali waa waigandÉØ waa wandÉØ Jisas.   
\p
\v 4 Jisas wupma kwo ana wandÉØ. Tamba la profet pÉØlÉØwutnda vak vla wandÉØ.  
\v 5 Tamba la profet kupma pÉØlÉØwutndÉØ.  
\li1 Jerusalemba lÉØga nÉØmba kat yiga ambuk ngwula.  
\li1 Ngwula king kÉØngi tamba yalÉØga. NdÉØna sÉØ avla  
\li1 ana kwutaa katsogiyandÉØ. Nyan donkina mbunimba  
\li1 ndaa lÉØga yalÉØgandÉØ waa yiga ambuk ngwula  
\p waa tamba la profet pÉØlÉØwutndÉØ.   
\p
\v 6 Jisas mbÉØk kat tata ayt mbÉØla wandÉØ maa tata yimbÉØk. Yilaa wanda vapmba yiga kwupmbÉØk.  
\v 7 Wutaa doni nyÉØmeo nyano kiyambÉØk. kiyambÉØk maa ndina mbangÉØmba kwusoga yinja waavwi njeguga donkina mbunimba taagandi. Taagandi, Jisas nyan donkina mbunimba ndaa lÉØndÉØ.  
\v 8 NÉØma sakwat nÉØmba Jisas yigiya ava yambÉØ kat alagumba kwusola lÉØnja waavwi lapmiga klalaa ava yambÉØmba taagandi. Nat nÉØmba mi sandÉØ kalÉØtaa ava yambÉØmba taagandi.  
\v 9 NdÉØna kwupmba la nÉØmba, ndÉØna mÉØndama sambÉØmba la nÉØmba, nÉØma kwundimba kiselaa walÉØndi. Devitna yelangÉØ nyan nÉØn kat vÉØvat yandan apma vat yandÉØ. God wandÉØ maa yandÉØ. Wan apma vatna yanda. God nÉØn kat apma vat kwiga kwunatÉØgandÉØ waa kÉØselaa walÉØndi.   
\p
\v 10 Jisas Jerusalem wuleindÉØ maa ngepmamba yisolaa la ndu lagwa ngÉØpaliga walaa laataa nÉØmamba kÉØselaa wandi ndÉØ kat. Wan anda nyana yaa waa wandi.   
\p
\v 11 Jisasonala yalaa yisola la nÉØmba ndÉØ kat wandi. NdÉØ Jisas profetna. NdÉØna ngepma Nasaret. Galilina ngepma waa wandi.   
\s1 JISAS GODNA NGAY WULEINDĘ  
\p
\v 12 Jisas Godna ngay wuleilaa wenga kla la nÉØmba kat vÉØlaa savÉØlÉØndÉØ maa laataa yindi. Nat nÉØmba ngepma ngepmana sanya klalaa Judana sanya kwila nÉØmba. Ndina njamba kwutaa kungwamatndÉØ. Namio kat wenga wila nÉØmbana tÉØgÉØt kwutaa kungwamatndÉØ.  
\v 13 Kungwamataa ndi kat wandÉØ. Tamba God wandÉØ, pÉØlÉØwutndi.  
\li1 Wuna ngay ndinyangu wuleilaa wun kat nyaangÉØt  
\li1 ngambulÉØnjeya ngayat tÉØgyandÉØ waa tamba God  
\li1 wandÉØ  
\p waa tamba pÉØlwutndi. Ngwuk wupma ana yilÉØgangwuk. Ngwuk wupma wenga klalÉØngwan sÉØkwutÉØga nÉØmba pagwula lÉØga ngay vla lÉØgandÉØ waa wandÉØ Jisas.   
\p
\v 14 MÉØni kiya nÉØmbo man kÉØvÉØ watna nÉØmbo yandi maa Godna ngaymba tÉØga ndi kat kwunatndÉØ.  
\v 15 God kat kwunatÉØga njambwi nÉØmbo Moses kwiya nyaangÉØt sÉØmogwi lÉØga nÉØmbo kwunatÉØnda apma njÉØvwa vÉØlaa ndÉØ kat maawupmba kÉØmbuk yiga yelavÉØka lÉØndi. Mat nyangu nÉØma sakwat Godna ngay wuleilaa kÉØselaga Jisasna sÉØ nÉØma wandi. MÉØn Devitna yelangÉØ nyan mÉØn. Apma vat tÉØgambÉØn waa wandi. Judna njambwi nÉØmba walÉØnja vat wutaa nat njambÉØ maawupmba kÉØmbuk yiga yelavÉØka lÉØndi ndÉØ kat.  
\v 16 Ndi Jisas kat yalaa wuka lÉØga wandi. KÉØselaga walÉØnja vat mÉØn ana wutÉØgamÉØn? Apma vat ana ndÉØ walÉØnja waa wandi. Wandi maa Jisas ndi kat wandÉØ. Wuka lÉØgowun. Apma vat walÉØgandi. Ngwuk kan nyaangÉØt ana vÉØga lÉØgangwuk? Kupma pÉØlÉØwutndi.  
\li1 God wandÉØ. Mat nyangu mwunyamba lÉØga nyangu  
\li1 ndina kwundimba wuna sÉØ waga kwutaa  
\li1 katsogiyandi waa wandÉØ God  
\p waa tamba pÉØlÉØwutndi waa wandÉØ Jisas.  
\v 17 Jisas ndi kat walaa wan ngepma kwagalalaa Betani walÉØnja ngepma wuleilaa ngan wumba kwandÉØ.   
\s1 JISAS WANDĘ MAA FIK WALĘNJA MI LĘGA WUNDĘ  
\p
\v 18 Ngambi Jerusalem yiga lÉØga Jisas wundÉØ kat tÉØga  
\v 19 ava yambÉØmba la fik walÉØnja mi kat vÉØndÉØ. VÉØlaa ndÉØna sÉØk sÉØgÉØtaa kÉØvak kat yelavÉØtndÉØ. YelavÉØtaa laataa yiga wan mi angwa ngway tolalaa tanambÉØka vÉØndÉØ. VÉØndan sÉØk kwandÉØ, ana vÉØndÉØ. Nganga mÉØna lÉØndÉØ, vÉØlaa wandÉØ. NgÉØni kan mi sÉØk ana kwaigandÉØ wandÉØ. WalÉØndÉØ mala wan mi njingwut njama nganga aywaa lÉØga wundÉØ.  
\v 20 Jisasna mbaapmamba la nÉØmba vÉØlaa ngÉØpali walaa wandi. Kan mi kat wama nyaangÉØt sÉØvla ana wamÉØn. Anda vapmba lÉØga wundÉØ waa wandi maa Jisas ndi kat wandÉØ.   
\p
\v 21 Ngwuk awuk ngwula. Wuka yelavÉØk ngwula. Maawut vÉØlÉØlÉØk yelavÉØtapman tÉØga God kat nÉØmamba apma maawut yelavÉØka lÉØngweyan fik walÉØnja mi kat yuwa vak vla ngwulo wupma yigiyangwuk. Kupma yuwa vak kat kwulakiyangwuk. Kan tÉØga nduwi kat laataa nguat ay wangeyan yigiyandÉØ.  
\v 22 NÉØmamba apma maawut yelavÉØka lÉØngweyan God kat wagalangweya nda ngwuk kat kwigiyandÉØ waa wandÉØ Jisas.   
\s1 MĘN KAT KANDA WANDĘ, NJĘVWA KWUPMĘN WAA JISAS KAT WAGALANDI  
\p
\v 23 Jisas Godna ngay wuleilaa ndinyangu kat nyaangÉØt mbutÉØndÉØ. MbutÉØndÉØ maa wutaa God kat kwunatÉØga njambwi nÉØmbo Judana nat njambwi nÉØmbo yalaa ndÉØ kat wagalandi. MÉØn kat kanda wandÉØ, kan njÉØvwa kwutÉØgamÉØn.   
\p
\v 24 Jisas ndi kat wandÉØ. Ngwuk kat kÉØta nda wagalagiyowun. Wagalaweya vak ngwuk kat mbukiyowun.  
\v 25 Kanda wandÉØ maa ngu yagu la Jon yalaa nÉØma sakwat nÉØmba kat ngu yagulÉØndÉØ. God wandÉØ maa yalaa yagundÉØ? E? Ndu nyan wandÉØ mala yalaa yagundÉØ? Ngwuk ambuk ngwula wun kat waa ndi kat wagalandÉØ.  
\v 26 Wagalanda vak wutaa awat sowat ngambulÉØndi. God waqndÉØ maa ngu yagulÉØndÉØ waa waneyan nÉØn kat waigandÉØ. NdÉØnai waa nyaangÉØt manda kat wutapman yingwuk waa nÉØn kat waigandÉØ. Ndu nyan wandÉØ maa yalaa ngu yagulÉØndÉØ waneyan wan nÉØma sakwat nÉØmba wutaa nÉØn kat kai waigandi. Jon dÉØ profetna waa yelavÉØtaa lÉØgandi waa awat sowat ngambulaa  
\v 27 Jisas kat wandi. NÉØn kat wagalama vat ana vÉØga lÉØganÉØn waa wandi. Wandi maa Jisas ndi kat wandÉØ. Wuno wun kat wagalangwa nyaangÉØt ana ngwuk kat mbukiyowun waa wandÉØ Jisas.   
\s1 KĘTA NYANANA MBĘT NYANA WAPUSEPUT  
\p
\v 28 Jisas laataa ndi kat pagwuga lÉØga wapuseput mbutndÉØ. KÉØta nyan nyan vÉØlÉØlÉØkno lÉØndÉØ. Nyaek laataa yiga njambwi nyan kat wandÉØ. Njambwi nayan mÉØn laataa yiga ambugat njÉØvwa agwut waa wandÉØ maa  
\v 29 kai wowun wandÉØ. Kai walaa tÉØga mandÉØp vak yelavÉØtaa laataa yiga ambugat njÉØvwa kwutndÉØ.  
\v 30 Nyaek at mat nyan kat wandÉØ. Mat nyan mÉØn laataa yiga mabugat njivwa agwut wandÉØ maa yigiyowun wandÉØ. Yigiyowun walaa ana yindÉØ.  
\v 31 Anda nyan nyaekna kwundi wutaa yiga njÉØvwa kwukiya Ngwuk angamak yelavÉØka lÉØgangwuk waa Jisas wandÉØ maa nyamwun laataa yiga njÉØvwa kwutndÉØ wandi. Jisas ndi kat wandÉØ. God vÉØga lÉØga kava wuleivat tÉØgiyaa nÉØmba ndino wupma yuigiyandi. NÉØma sakwat takis sanya klalÉØga kavle nÉØmbo yambÉØsÉØk yilÉØga taagwo ndi tat God vÉØga lÉØga kava wuleigiyandi. Ngwuk anaga ngwuk wuleigiya.  
\v 32 Ngu yagu la Jon ngwuk kat wuleingweya yambÉØ vÉØsÉØmogwindÉØ. Ngwut ndÉØna nyaangÉØt wupmak kat kai wangwuk. NÉØma sakwat takis sanya klalÉØga nÉØmbo yambÉØsÉØk yilÉØga taagwo ndi wutndi. ana kai wandi. Wutnja vak vÉØlaa ngwuk ana mandÉØp maawut yelavÉØka wukngwuk waa wandÉØ Jisas.   
\s1 DIWAI WAIN WATĘGA AMBUGATNA WAPUSEPUT  
\p
\v 33 Jisas ndi kat wandÉØ. Pagwula lÉØga nat wapuseput ngwuk kat mbukiyowun. Tamba kÉØta nyan ndÉØna kÉØpmamba diwai wain watÉØga ambugat kwutndÉØ. Waina kandi tulaa wan ambugat tÉØvwi kÉØlÉØndÉØ. Waina ngu klavat veigÉØnyanjeya waangu vandÉØ. Ambugat kat vÉØga lÉØnjeya awlapmba la ngay kwutndÉØ. Wan ambugatna njÉØvwa aywaa kwutaa ambugat kat vÉØga lÉØgiya nÉØmba kat wan ngaymba taagalaa sÉØvla kava yindÉØ. NdÉØnai vÉØga lÉØgiya wain nat waambu klaigandi. Nat waambu kÉØpma lÉØga nyan klaigandÉØ.  
\v 34 Wain sÉØgÉØpmak tÉØnja njÉØmbla lÉØndÉØ maa ndÉØna njÉØvwa kwuta nÉØmba kat ambugat ay wandÉØ maa ndina njambwi nyan klaiga wain klavat yindÉØ.  
\v 35 NdÉØna njÉØvwa kwuta nÉØmba ambugat yandi maaambugat vÉØga la nÉØmba ndina nat nyan kat viyalaa nat nyan kat vatnyalaa nat nyan kat vatnyavak ndÉØ kat kambak yaagilÉØndi.  
\v 36-37 KÉØpma lÉØga nyan nat njambÉØ nat njÉØvwa kwuta nÉØmba kat ay wandÉØ maa yindi. Yindi maa ambugapmba la ndinyangu wandÉØ, yindÉØ. Wuna nyan kat vÉØlaa ndÉØna kwundi wukiyandi walaa ndÉØna nyan kat ay wandÉØ, ambugat yindÉØ.  
\v 38 Ambugat vÉØga la nÉØmba ndÉØna nyan yandÉØ maa vÉØlaa yelavÉØtndi. KÉØpma kwukna nyana nyana. NdÉØ kat vatnyandyan kan kÉØpma nÉØna lak klaiganÉØn waa yelavÉØtaa  
\v 39 ndÉØ kat kwutaa alaguat kalilaa ndÉØ kat vatnyandi.  
\v 40 KÉØpma lÉØga nyan yandeyan wan nÉØmba kat angamak yigiyandÉØ.   
\p
\v 41 Ndi kat wundi kavle nÉØmba kat vatnyagiyandÉØ. Vatnyalaa ndÉØna ambugat kat vÉØga lÉØgiyaa nat nÉØmba kat kwutaa yaa taagagiyandÉØ.   
\p
\v 42 Kan mbutuwa wapuseput tamba God wandÉØ, pÉØlÉØwutnja nyaangÉØt vla lÉØgandÉØ. Ngwuk vÉØlÉØngwuk? E? Ana vÉØlÉØngwuk? Kan nyaangÉØt. Kupma pÉØlÉØwutndi.  
\li1 Kambapmba ngay kwuta nÉØmba tat yaagibnja kambak  
\li1 ngÉØni kwutaa ngay tagumba taagandi, lÉØndÉØ.  
\li1 Taagandi tÉØga wan ngayna njambwi kambanknat tÉØndÉØ.  
\li1 God sÉØmogwindÉØ, wan kambak kwutaa tagumba  
\li1 taagandi. God apma vat ndi kat sÉØmogwindÉØ.  
\p waa tamba pÉØlÉØwutndi.  
\v 43 Ngwuk Judana njambwi nÉØmba ngwuk kat wowun. God ndinyangu kat kwunatndeya vat ngwuk ana klaigangwuk. Nat nÉØmba Godna njÉØvwa kwuka yetÉØgiya nÉØmba ndi klaigandi.  
\v 44 (Wan wawa kambak kÉØta nyan kambak kat kai walaa mamba veindeyan wan nyan kavle yigiyandÉØ. Kambak ana kavle yigiyandÉØ. Tagula kambakna. Wan kambak nat nyamba ndÉØ kat viyandeyan ndÉØ mbaw vla lÉØga kavle yigiyandÉØ waa wandÉØ Jisas.   
\p
\v 45 God kat kwunatÉØga njambwi nÉØmbo Ferisio Jisas mbutnda pagwula la wapuseput wutaa yelavÉØtndi. Wanda nyaangÉØt nÉØn kat nÉØma vat wavat wandÉØ waa yelavÉØtndi.  
\v 46 Ngi kat ana kwutaa kalindi. NÉØma sakwat nÉØmba ndÉØ Jisas profetna waa wandi. Wan nÉØma sakwat nÉØmba kat vaaka lÉØga ana ndÉØ kat kwutaa kalindi.   
\c 22  
\s1 TAAGWA KLAVAT TA NYANA KĘGĘNDA  
\p
\v 1 Jisas pagwula la nat wapuseput ndi kat mbutndÉØ.  
\v 2 Nyinangwupmba lÉØga njambwi nyan ndinyangu kat vÉØga lÉØgiya vat kÉØngi vat tÉØgandÉØ. Tamba nÉØma king tÉØndÉØ. NdÉØna nyan taagwa klavat tÉØndÉØ, king nÉØma kÉØgÉØnda kwutndÉØ.  
\v 3 NdÉØna njÉØvwa kwuta nÉØmba kat wandÉØ maa ngepma ngepma yiga ndinyangu kat wangwuk yaandi wandÉØ ndi kat. WandÉØ, yindi. Yiga wanja nÉØmba yavak kat kai wandi.  
\v 4 Kawiga lÉØga vÉØlevilaa ndÉØna nat njÉØvwa kwuta nÉØmba kat ay wandÉØ maa ngepma ngepma yiga ndinyangu kat wandi. KÉØgÉØnda lamba kwuka taaganÉØn tÉØandÉØ. Njambwi nyan ndÉØna kwandÉØ bulmakau vatnyalaa ndina wimbu awmba kwalalaa taagalaa kÉØgiya nÉØmba kat kawiga lÉØgandÉØ. yagwa ngwula waa wandi.   
\p
\v 5 Wanja vak yiga wanja nÉØmba ana wutndi. Ndina njÉØvwa kwagalalaa yavak kat kai walaa njÉØvwa mÉØna kwutÉØndi. KÉØta nyan ambugat kwupmat yindÉØ. Nat nyan stua vÉØga lÉØvat yindÉØ.  
\v 6 Nat nÉØmba kingna njÉØvwa kwuta nÉØmba kat kwutaa lÉØga viyalaa vatnyandi.  
\v 7 NÉØma king wutaa ndÉØna maawut nyingi yiga ndÉØna soldia kat ay wandÉØ. WandÉØ maa yiga wan nÉØmba kat aywaa vatnyalaa ndina ngay aywaa yamba tundi.  
\v 8 NdÉØna njÉØvwa kwuta nÉØmba kat wandÉØ. KÉØgÉØnda tamba kwuka lÉØganÉØn. Tak wawa nÉØmba apma nÉØmba ana ndi. Kavle nÉØmba ndi. Ndi ana wawa vat wutaa alÉØpsÉØga yalaa wawa kÉØgÉØnda kÉØgiyandi.  
\v 9 Ava yambÉØ ava yambÉØ kava kava aywaa yigiyangwuk. Yilaa vÉØngweya nÉØmba kat aywaa kwutaa kiyaigangwuk. Kiyangwuk mala ndi kÉØgÉØnda kÉØgiyandi waa wandÉØ maa yindi.  
\v 10 Ava yambÉØ ava yambÉØ kava kava aywaa yilaa vÉØnja apma nÉØmba kavle nÉØmba kat aywaa kwutaa kiyandi. Taagwa klalaa lÉØnda ngay ndinyangu mÉØna taata lÉØndÉØ.   
\p
\v 11 Kind wan ngay wuleilaa apma waavwi kwusolapman kÉØgÉØnda kÉØvat ya nyan kÉØta kat vÉØndÉØ.  
\v 12 VÉØlaa ndÉØ kat wandÉØ. MÉØn, kÉØgÉØnda kÉØvat yamÉØn. Kupi waavwi kwusolapman manda kat kwo yamÉØn waa wandÉØ maa wan nyan awat ndÉØ kat ana nyaangÉØt wandÉØ.  
\v 13 King ndÉØna njÉØvwa kwuta nÉØmba kat wandÉØ. Wan nyan kat kwutaa man taamba sangilaa ndÉØ kat alagumba yiga yaagi. Kulun walaa lÉØga kavamba tÉØgandÉØ. Wan kavamba lÉØga nglaga nÉØmbi ngliaka tÉØgiyandÉØ waa wandÉØ king.  
\v 14 Kan wapuseputna angwa kÉØngiyan. God nÉØma sakwat nÉØmba kat yagwa walÉØgandÉØ. NÉØma sakwat nÉØmba ana wutaa ndÉØna ngway yalÉØgandi. Nat nÉØmba mÉØna yalÉØgandi wandÉØ Jisas.   
\s1 TAKIS SANYA YAAGINJEYA VAK KAT WAGALANDI  
\p
\v 15 Ndi Ferisi yelavÉØtndi. Jisas kat wagalaneyan anagandÉØ nÉØn kat kavle nyaangÉØt mbukiya waa ndina maawupmba yelavÉØtndi.  
\v 16 Ngi kat tÉØga ndina nat nÉØmbo Herotna mbaapmamba la nÉØmba kat ay wandi maa Jisas ta kavat yindi. Yilaa lÉØga Jisas kat wandi. NyaangÉØt sÉØmogwi lÉØga nyan mÉØn. MÉØn ana woseka walÉØgamÉØn. MÉØn Godna angwa nyaangÉØt ndinyangu nÉØn kat pagwuga ana mbutÉØgamÉØn. Savagu mbutÉØgambÉØn nÉØn kat. MÉØn mandÉØp mandÉØp vapmba ana yilÉØgamÉØn. KÉØpmamba lÉØga ndinyangu nÉØn kat aywaa kÉØta vapmba yilÉØgamÉØn. Nat nÉØmbana yelavÉØk vapmba ana yetÉØlÉØgamÉØn.  
\v 17 NÉØn kat awamba mÉØn. Romba lÉØga njambwi king Sisa kat takis sanya kwineyan Moses kwiya nyaangÉØt kai waa kalÉØkiyanÉØn? MÉØn angamak yelavÉØka lÉØgamÉØn. NÉØn kat ambuk waa wagalandi.   
\p
\v 18 NÉØn kat kavle nyaangÉØt anagandÉØ mbukiya waa maawupmba yelavÉØtnja vak kat vÉØlaa wandÉØ. Ngwuk woseka waa pagwula lÉØga nÉØmba ngwuk. NÉØn kat kavle nyaangÉØt anagandÉØ mbukiyaa waa manda kat ngwula maawupmba yelavÉØtÉØgangwuk.  
\v 19 Takis yaagingweya sanya kÉØta agiya wun kat waa wandÉØ maa kwindi.  
\v 20 Jisas sanya kwutaa ndi kat sÉØmagaga wandÉØ. Kan kana sa kana mÉØndama kan moni sanyamba lÉØga waa wagalandÉØ ndi kat.   
\p
\v 21 WagalandÉØ, wandi. Romba lÉØga njambwi king Sisana sÉØ mÉØndama wandi. Jisas wutaa wandÉØ. Ngiyambak wangwa. Sanya ndÉØna nda. NdÉØna nda ndÉØ kat kwigiyangwuk. Godna nda Godnat kwigiyangwuk waa wandÉØ Jisas.   
\p
\v 22 Jisas waa nyaangÉØt wutaa ngÉØpali waa kwundi lapman laataa ndÉØ kat kwagalalaa yindi.   
\s1 KIYAA NĘMBA LAATNJEYA VAK KAT JISAS MBUTNDĘ  
\p
\v 23 Sadyusi walÉØnja mbaapma nÉØmba kiya lÉØga nÉØmba ngÉØni ana laakiyandi walÉØga nÉØmba ndi. Ndi yalaa Jisas kat wagalandi.  
\v 24 NyaangÉØt sÉØmogwi lÉØga nyan tak Moses kupma pÉØlÉØwutndÉØ.  
\li1 Nyamwun taagwa klalÉØga nyan njantapman nyamwun  
\li1 kiyandÉØ, sambu nyamwuna taagwa klaigandÉØ.  
\li1 Klalaa nyan njangiyandÉØ  
\p waa pÉØlÉØwutndÉØ Moses.   
\p
\v 25 Tamba kan ngepmamba kÉØta ndu kÉØta lagwana nyangu nondanyangu mÉØna sÉØla vÉØli tÉØndi. NÉØma nyan taagwa klalaa nyan njantapman tÉØga kiyandÉØ. NdÉØna sambu saasÉØ kat klalaa nyan njantapman tÉØga kiyandÉØ.  
\v 26 Ndi sÉØla vÉØli nondayangu nyan njantapman kÉØta lagwamba klalÉØga aywaa kiyandi.  
\v 27 TÉØga lÉØga ngÉØni wat taagwa kiyalÉØ.  
\v 28 NgÉØni kiya nÉØmba laatnjeya njÉØmbla wat taagwa kana taagwat tÉØgiyalÉØ waa wagalandi Jisas kat.   
\p
\v 29 Jisas wanja nyaangÉØt wutaa ndi kat wandÉØ. Ngwuk apma vat ana yelavÉØka lÉØgangwuk. God waa nyaangÉØt kat ana apma vak yelavÉØka lÉØgangwuk. Godna kwondu kat ana apma vak yelavÉØka lÉØgangwuk.  
\v 30 NgÉØni kiya nÉØmba laatnjeya njÉØmbla ndu lagwa ana klaigandÉØ. Taagwa ndu ana klaigalÉØ. Ensel lÉØga vla tÉØgiyandi.   
\p
\v 31 Kiya lÉØga nÉØmba laatnjeya vak kat ngwuk kat nat nyaangÉØt mbukiyowun. tamba God ngwuk kat yelavÉØka wandÉØ, pÉØlÉØwutnja nyaangÉØt tamba vÉØngwuk? E? Ana vÉØngwuk? Kupma pÉØlÉØwutndi.   
\p
\v 32 God Moses kat wandÉØ. Wun Ebrahamna njambwi,  
\li1 Aisakna njambwi, Jekopna njambwi nyan wun waa wandÉØ God  
\p waa tamba pÉØlÉØwutndi. God kiya nÉØmbana njambwi nyan ana ndÉØ. Kwo lÉØga nÉØmbana njambwi nyana God waa wandÉØ Jisas.  
\v 33 Wan nÉØma sakwat ta nÉØmba ndÉØna nyaangÉØt kat wutaa ngÉØpaliga ndalaa wandi. Apma nyaangÉØtna mbutÉØnda waa wandi.   
\s1 GOD KWIYA NĘMA NYAANGĘT  
\p
\v 34 Jisas Sadyusi kat wagalanda nyaangÉØt wutaa ndÉØ kat awat mbutnjeya nyaangÉØt kat yelavÉØt sÉØgÉØtaa tagula ngega lÉØndi. Tagula ngega lÉØnja vak vÉØlaa Ferisi ndino yisolaa lÉØndi.  
\v 35 Yisolaa lÉØga ndina kÉØta nyan kat wandi. Jisas kat laataa yiga wagala wandi. Wagalameya vak wutaa anagandÉØ awat mÉØn kat kavle nyaangÉØt mbukiya waa wandi, laataa yindÉØ. Laataa ya nyan Moses kwiya lo sÉØmogwi la nyana.  
\v 36 NdÉØ Jisas kat wagalandÉØ. NyaangÉØt sÉØmogwi lÉØga nyan Moses kwiya nyaangÉØt nÉØma sakwat tÉØgandÉØ. Anda nyaangÉØtna nÉØma tÉØga nat nyaangÉØt kat kwulataa lÉØga. Wun kat ambuk waa wagalandÉØ.   
\p
\v 37 Jisas wutaa wagalanda nyaangÉØt kat awat ndÉØ kat wandÉØ. NÉØma nyaangÉØt kÉØngiyan.  
\p NÉØma nyan God ndÉØ kat ngwula maawupmba yelavÉØka  
\li1 solat sÉØga yetÉØ ngwula. NdÉØ kat vÉØga ngwula  
\li1 mbangÉØ nolin ngwandÉØga waavi laagnadÉØ, yetÉØ ngwula  
\p waa wandÉØ Moses.  
\v 38 Kan nyaangÉØt nat nyaangÉØt kat aywaa kwulatndÉØ.  
\v 39 NdÉØna kwupmba lÉØga nyaangÉØtno kÉØta vatna. Kwupmba lÉØga nyaangÉØt kÉØngiyan.  
\p MÉØna mbangÉØ kat kwunapmak vla nat nyana mbangÉØ kat vÉØlaa wupma kwunak  
\p waa wandÉØ Moses.  
\v 40 Tamba Moses nÉØma sakwat nyaangÉØt mbutÉØndÉØ. Profet ndino nÉØma sakwat mbutÉØndÉØ. Mbambala ngwuk kat mbutuwa nyaangÉØt vÉØlÉØlÉØk tamba la nÉØmba mbuta nyaangÉØtna angwa nyaangÉØtna mbÉØk.   
\s1 JISAS FERISI KAT WAGALANDĘ  
\p
\v 41 Ferisi yisolaa lÉØndi maa Jisas yalaa ndi kat wagalandÉØ.  
\v 42 Juda kat kwunapmak ya nyan Kraist ndÉØ kat ngwuk angamak yelavÉØtaa lÉØgangwuk. Anda nyana nyana waa wagalandÉØ maa wutaa wandi. NdÉØ Devitna nyana waa wandi.  
\v 43 Jisas ndi kat wandÉØ. Devit kat Godna waagan wuleindÉØ maa Kraist wuna njambwi nyana wandÉØ. Tamba la nyan Devit kupma walaa pÉØlÉØwutndÉØ.   
\li1
\v 44 God wuna njambwi nyan kat wandÉØ. Wuna yagindan  
\li1 naangÉØmba ndaalÉØ. MÉØn kat kao lÉØga nÉØmba kat  
\li1 sÉØwun maa ngÉØni mÉØn kat ana kao yigiyandi waa  
\li1 wandÉØ God  
\p waa pÉØlÉØwutndÉØ Devit.  
\v 45 Devit Kraist kat ndÉØ wuna njambwi nyana wandÉØ. Kraist kat Devitna mat nyana waa manda kat walÉØgangwuk waa wagalandÉØ Jisas.   
\p
\v 46 Wagalanda vak kat wutaa ana alÉØpsÉØga ndÉØ kat mbutndi. NgÉØni Jisas kat wagalanjeya vak kat vaaka lÉØndi. NgÉØni ndÉØ kat ana wagalandi.   
\c 23  
\s1 FERISI YETĘLĘGA KAVLE VAT  
\p
\v 1 Jisas ndÉØna mbaapmamba la nÉØmbagwi nat nÉØma sakwat nÉØmba yalaa lÉØndi, nyaangÉØt ndi kat mbutÉØndÉØ.  
\v 2 Mbuka wandÉØ. Ferisio Moses kwiya nyaangÉØt sÉØmogwi lÉØga nÉØmba ndinai mbukiya nyaangÉØt awuk ngwula. Ndi Moses kwiya nyaangÉØt sÉØmogwi wuka lÉØga nÉØmba ndi.  
\v 3 Ndinai mbukiya nyaangÉØt wuka yetÉØ ngwula. Ndinai yiga yetÉØlÉØga vapmba ke yetÉØngwa. ndi apma vak ngambuga lÉØga kavle vapmba yetÉØlÉØgandi.  
\v 4 Ndi nat nÉØmba kat walÉØngandi. YetÉØlÉØna vak kat vÉØlaa nÉØnai yetÉØlÉØga vapmba yetÉØ ngwula. YetÉØlÉØnja vak vla yetÉØvak nÉØma njÉØvwa kwutÉØgandi. NÉØma njÉØvwa kwutÉØnja njÉØvwa kat vÉØlaa Ferisi ndi kat ana miwa yiga kwunatÉØgandi.  
\v 5 Ndina apma njÉØvwa nat nÉØmba vÉØmbandi walaa kapmba kwutÉØgandi. Nat nÉØmba vÉØmbandi walaa God wandÉØ, lavungamba pÉØlÉØwutnja nyaangÉØt kapmba kwutaa kalilÉØgandi. Nat nÉØmba vÉØmbandi walaa sÉØvla mbundÉØ waavwi kwusolÉØgandi.  
\v 6 NyaangÉØt ngambulÉØnja ngay wuleilaa njambwi nyana tÉØgÉØtmba ndaa lÉØvat walÉØgandi. NÉØma kÉØgÉØnda kwutnja ngaymba wungi vat sÉØgÉØt nda lÉØvak kat walÉØgandi.  
\v 7 NÉØndÉØ ngepmamba laataa lÉØga nat nÉØmba ndi kat apma vak tÉØga nÉØmba ndi waa wanja vak wupmak walÉØgandi. Nat nÉØmba ndi kat nyaangÉØt sÉØmogwi lÉØga nÉØmba ngwuk waa wambandi walaa walÉØgandi.   
\p
\v 8 Ngwuk wuna mbaapmamba lÉØga nÉØmba aywaa ngwuk wupma ke yingweya. ngwuk aywaa kÉØta mbaapmamba lÉØga nÉØmba ngwuk. Awat sowat mÉØn sÉØmogwi lÉØga nyan mÉØn waa ke waa. Ngwuk aywaa ngwuk kat nyaangÉØt sÉØmogwi lÉØga nyan kÉØta lÉØgandÉØ.  
\v 9 Kan kÉØpmamba lÉØga nat nyan kat nÉØna nyaekna waa ke wangweya. Ngwutna nyaek kÉØta. Nyinangwupmba lÉØgandÉØ.  
\v 10 Ngwuk awat sowat mÉØn njambwi nyan mÉØn waa ke wangweya. Ngwutna njambwi nyan kÉØta lÉØgandÉØ. NdÉØ Kraistna.  
\v 11-12 Ngwutna kÉØta nyan njambwi nyanat tÉØvat tÉØvat wandeyan avla ndÉØna sÉØ kwutaa viyesendagiyandÉØ. Avla ndÉØna sÉØ kwutaa viyesendandeyan God ndÉØ kat kwutaa katsondÉØ maa njambwi nyanat tÉØgiyandÉØ.   
\s1 FERISI WOSEKA WALĘNJA VAK  
\p
\v 13 Ngwuk Moses kwiya lo sÉØmogwi lÉØga nÉØmbo Ferisio ngwuk kavle glei yigiyangwuk. Apma vak ana lÉØgiyangwuk. Ngwuk woseka walÉØga nÉØmba lÉØgangwuk. nyinangwut wuleinjeya yambÉØ kat ngwuk tÉØvÉØlÉØgangwuk. Ngwuk wuleivak kat kai walÉØgangwuk. Nat nÉØmba wuleivak kat kai valÉØgangwuk.   
\p
\v 14 (Ngwuk Moses kwiya lo sÉØmogwi lÉØga nÉØmbo Ferisio ngwuk kavle glei yigiyangwuk. Ngwuk woseka walÉØga nÉØmba ngwuk. Ndu kiyandi, yetÉØgat talagwana kwanda kwanda nda sÉØkwuka klalÉØgangwuk. Wupma yilÉØngwan nÉØma vat kavle yigiyangwuk.)   
\p
\v 15 Ngwuk Moses kwiya lo sÉØmogwi lÉØga nÉØmbo Ferisio ngwuk kavle glei yigiyangwuk. Ngwuk woseka walÉØga nÉØmba ngwuk. KÉØta nyan kwutaa ngwutna mbaapmamba taagavat sÉØvla mbundÉØ yambÉØ yilÉØgangwuk. njambÉØt kulaa yiga nduwi yiga wokega sÉØvla mbundÉØ yambÉØ yilÉØgangwuk. Ndi kat kwutaa taagangwuk maa kavle vat yilÉØnjeya vak yilÉØngweya vak kat kwulatÉØgandÉØ. Ngwutnogwi ndinogwi ya vÉØtÉØga kavle kavat yigiyangwuk.   
\p
\v 16 Ngwuk nat nÉØmba kat yambÉØ sÉØmogwiga mÉØni kiyala lÉØga nÉØmba vla lÉØgangwuk. Ngwuk kavle glei yigiyangwuk. NÉØna ngepmana nat nÉØmba Godna ngayna sÉØ waga nÉØma njÉØvwa kwukiyanÉØn waa laataa nÉØma kwundimba walÉØgandi. Wanja njÉØvwa kwutapman yinjeyan ngwuk Ferisi ndi kat ana kai walÉØgangwuk. NÉØna ngepmana nat nÉØmba Godna ngaymba lÉØga golmba kwutnja awna sÉØ waga nÉØma njÉØvwa kwukiyanÉØn waa laataa nÉØma kwundimba walÉØgandi. Wanja njÉØvwa kwutapman yinjeyan ngwuk Ferisi ndi kat kai walÉØgangwuk. Ngwuk ferisi Godna ngay makna ngaymba lÉØga golmba kwutnja aw nÉØma nda waa yelavÉØtaa ndi kat wupma walÉØgangwuk. Ngwuk mandÉØp mandÉØp walÉØgangwuk.  
\v 17 Ndi kat mbutÉØngwa nyaangÉØt tungwengwan yiga lÉØga nÉØmba vla lÉØga mbutÉØgangwuk. Ngwuk mÉØni kiya la lÉØga nÉØmba vla lÉØgangwuk. Godna ngay nÉØma nda. Wan ngaymba golmba kwutnja aw mat nda. Ngwuk manda kat nat nÉØmba kat kai walaa at nat nÉØmba kat kai walapman yilÉØgangwuk.  
\v 18 Ngwuk Ferisi nat nÉØmba kat kupma mbutÉØgangwuk. Ndi nat nÉØmba God kat kwunapmak kwanda kwanda taaganjeya njambana sÉØ waga nÉØma kwundi wanjeyan nyaangÉØt kai waa mbutÉØgangwuk. Ndi nat nÉØmba God kat kwunapmak kwinja kwanda kwandana sÉØ waga nÉØma kwundi wanjeyan nyaangÉØt tÉØgandÉØ waa mbutÉØgangwuk.  
\v 19 Ngwuk apma maawut ana yelavÉØka lÉØgangwuk. Kwanda kwanda taanganja njambo njambamba taaganja kwanda kwando mbÉØk kÉØta nda mbÉØk.  
\v 20 Jambana sÉØ wandeyan njambamba laaganja kwanda kwanda nda kat ndina maawupmba yelavÉØkiyandi.  
\v 21 KÉØta nyan Godna ngayna sÉØ wandeyan God kat yelavÉØka lÉØga waigandÉØ. God kan ngaymba tÉØgandÉØ waa yelavÉØka lÉØgiyandÉØ.  
\v 22 KÉØta nyan nyingangwut wandeyan nyinangwupmba lÉØga nyan God kat yelavÉØka lÉØga waigandÉØ. God nyinangwupmba lÉØga ndÉØna nÉØma tÉØgÉØtmba ndaa lÉØgandÉØ waa yelavÉØka lÉØgiyandÉØ.   
\p
\v 23 Ngwuk Moses kwiya lo sÉØmogwi lÉØga nÉØmbo Ferisio ngwuk kavle glei yigiyangwuk. Ngwuk woseka walÉØga nÉØmba ngwuk. Ngwuk klangwa nda aywaa nÉØma nda mat nda kalÉØtaa mbaapma amba vÉØli taagalÉØgangwuk. Mat glei nda kÉØlÉØnja ndana ngaanga kalÉØtaa mbaapma tamba vÉØli taagalÉØgangwuk. Taagalaa nat kÉØta mbaapma God kat kwilÉØgangwuk. Moses kwiya lo tÉØga apma nÉØma nyaangÉØpmba ana kwutaa yetÉØlÉØgangwuk. Mat nyaangÉØt mÉØna. Moses nÉØma nyaangÉØt kupma wandÉØ. Savagu lÉØga vapmba ngwula maawupmba yelavÉØka yetÉØ ngwula wandÉØ. Ngwuk wupma ana yetÉØlÉØgangwuk. Moses nat nÉØma nyaangÉØt kupma wandÉØ. Woseka waga ke yetÉØlÉØngweya wandÉØ. Ngwuk wupma ana yetÉØlÉØgangwuk. Kan tÉØga Moses kwiya nÉØma nyaangÉØt kwagalalaa Moses kwiya mat nyaangÉØt mÉØna ngambuga yetÉØlÉØgangwuk. Moses kwiya mat nyaangÉØt nÉØma nyaangÉØt wuka ngambuga yetÉØngweyan wovuna. Apma vat tÉØgiyangwuk.  
\v 24 Nat nÉØmba kat yambÉØ sÉØmagaga mÉØna kiyala lÉØga nÉØmba vla lÉØgangwuk. Ngwuk mat kavle vak savÉØlÉØvak nÉØma njÉØvwa kwutÉØgangwuk. NÉØma kavle vak savÉØlÉØvak ngwuk ana yelavÉØka lÉØgangwuk. NÉØma kavle vak ngwula lak yalÉØgandÉØ.   
\p
\v 25 Ngwuk Moses kwiya lo sÉØmogwi lÉØga nÉØmbo Ferisio ngwuk kavle glei yigiyangwuk. Ngwuk woseka walÉØga nÉØmba ngwuk. Ngwuk ngu tulaa kÉØlÉØnja kap vla lÉØgangwuk. Kan kapmana alagu kap mÉØna njangindi, apma vat tÉØgandÉØ. Yap kap ana njangilÉØgandi. KÉØgÉØn mbundÉØ lÉØgandÉØ. Ngwuk wupma lÉØgangwuk. Ngwuk kao yiga avla ngwula mbangÉØ kwunapmak kat nÉØma sakwat nda avla ngwula mbangÉØ kwunapmak kat nÉØma sakwat nda klalÉØgangwuk.  
\v 26 Kavle vak yiga yetÉØngwa vak ngwuk ana vÉØga lÉØgangwuk. Ngwutna kavle maawut kwunakngweyan apma vat njÉØvwa kwuka lÉØgiyangwuk.   
\p
\v 27 Ngwuk Moses kwiya lo sÉØmogwi lÉØga nÉØmbo Ferisio ngwuk kavle glei yigiyangwuk. Ngwuk woseka walÉØga nÉØmba ngwuk. Ngwut kiya nyan kat taagalÉØnja ngay vla lÉØgangwuk. Kan ngay alagu nge sawun mbangÉØ kÉØpma taagalÉØgandi. Awla nge kavle njangu veilÉØga sÉØm tÉØgandÉØ.  
\v 28 Ngwutno wupma lÉØgangwuk. Nat nÉØmba ngwuk kat vÉØlaa ndi apma vat yetÉØga nÉØmba ndi walÉØgandi. Ngwula maawut wupma ana lÉØgandÉØ. Kavle vat woseka walÉØnja vak ngwula maawupmba tÉØgandÉØ.   
\s1 FERISI KAVLE WENGA KLAIGANDI  
\p
\v 29 Ngwuk Moses kwiya lo sÉØmogwi lÉØga nÉØmbo Ferisio ngwuk kavle glei yigiyangwuk. Ngwuk woseka walÉØga nÉØmba ngwuk. Tambana profetna sÉØm tÉØgiya ngay apma vat kwutÉØgangwuk. Tamba la apma vat ta nÉØmbana sÉØm ta ngay apma vat yelaga lÉØgangwuk.  
\v 30 Ngwuk kupma walÉØgangwuk. Tamba nÉØna ngwat walanga ta njÉØmblamba tÉØgenÉØn nÉØn profet kat ana vatnyagenÉØn waa walÉØgangwuk. Woseka walÉØgangwuk.  
\v 31 Tamba la ndi profet kat vatnya nÉØmba ngwula ngwat walanga ndi vatnya. NÉØna ngwat walanga ndi wangwuk. Ngwulo ngwula ngwat walanga ta vla lÉØgangwuk.  
\v 32 Tamba kwutÉØnja kavle njÉØvwa vla ngwulo wupma kwutÉØgangwuk.  
\v 33 Ngwuk kavle kamboyna nyangu vla lÉØgangwuk. God ngwuk kat kwutaa ya vÉØtÉØga kavat yisendagiyandÉØ. NdÉØ kat ana kwagalalaa nat yambÉØmba yigiyangwuk.   
\p
\v 34 Ngwuk kat wowun. Samat tÉØga apma nambuo lÉØga nÉØmba, profet, nyaangÉØt sÉØmaga lÉØga nÉØmba wowun maa ngwuk kat yigiyandi. ndina nat nÉØmba kat vatnyagiyangwuk. Ndina nat nÉØmba diwai krosmba kaalagiyangwuk. Ndina nat nÉØmba kat kwutaa nyaangÉØt ngambulÉØngwa ngay kalilaa viyalaa savÉØlÉØngwuk maa ngepma ngepmat yigiyandi.  
\v 35 Wupma yilÉØngwan apma nÉØmba kat vatnyanja vatna kavle wenga ngwutna lak klaigangwuk. Tat apma vat ta nyan Abel kat tamba vatnyandi. Vatnyalaa tÉØga Berikaiana nyan Sekaraia kat ngÉØni vatnyandi. Godna ngay wuleindÉØ maa vatnyandi. Ndi aywaa vatnyanja nÉØmbana kavle wenga ngwula lak klaigangwuk.  
\v 36 Ngwuk kat wowun. Ndi kan mbambala lÉØga nÉØmba wan kavle wenga klaigandi wowun ngwuk kat waa wandÉØ Jisas.   
\s1 JISAS JERUSALEM VĘLAA NGLANDĘ  
\p
\v 37 Jisas Jerusalem walÉØnja ngepma vÉØlaa wandÉØ. Jerusalem Jerusalemba lÉØga nÉØmba ngwuk tamba la profet kat vatnyangwuk. God waa nyaangÉØt ngwuk kat mbupmat yala nÉØmba ndi kat kambapmba vatnyavat yaagilÉØngwuk. NÉØma sakwat njambÉØ ngwuk kat kwutaa wuna mbaapmamba taagavat walÉØwun. nyaaga nyangu kat lÉØla wiyo pupumba pagwulÉØ la vla ngwuk kat pagwuvat walÉØwun. Ngwuk wun kat kai walÉØgangwuk.  
\v 38 Ngwuk kat wowun. Samat tÉØga ngwutna ngepma sulÉØndi maa ngÉØni ndu nyan tapman ngepma tÉØgiyandÉØ wowun ngwuk kat.  
\v 39 Mbambala glei wun kat ana nat njambÉØ vÉØgiyangwuk. ngÉØni glei tÉØga wun kat vÉØlaa waigangwuk. Ngwuk avÉØ ngwula. God wandÉØ, yaa nyan kÉØngiyandÉØ yaa. God ndÉØ kat apma vat yindÉØ, yaandÉØ waa waigangwuk waa wandÉØ Jisas.   
\c 24  
\s1 GODNA NGAY KAVLE YIGIYANDĘ WAA WANDĘ JISAS  
\p
\v 1 Jisas Godna ngay kwagalalaa wogwendÉØ maa ndÉØna mbaapmamba la nÉØmba yalaa wandi. NdÉØ kat ngay kat sÉØmogwi vat yalaa wandi. Kan ngay apma vat kwutnja ngeya. Godna ngaya waa wandi maa wutaa Jisas ndi kat wandÉØ.  
\v 2 Awa luwa. Apma ngeya. ngwuk kat wowun. Samat tÉØga kan ngay sulÉØndi maa nat kambak nat kambakna tagumba ana tÉØgiyandÉØ. Kambak kÉØta kÉØta mÉØna lÉØgiyandÉØ waa wandÉØ Jisas.   
\s1 KAVLE VAT YANDEYA VAK  
\p
\v 3 Jisas Oliv walÉØnja nduwimba wokela ndaa lÉØndÉØ. Ndaa lÉØndÉØ maa ndÉØna mbaapmamba lÉØga nÉØmba kapma lÉØga ndÉØ kat yalaa wagalandi. NgÉØni Godna ngay sulÉØnjeya vak kat mbupma vat anda njÉØmbla yaigandÉØ. Anda nda tak vÉØneya. Vilaa lÉØga yelavÉØtneya. Njambwi nyan yaiga ngÉØni la lÉØga nandinya waa yelavÉØka lÉØneya waa ndÉØ kat wagalandi.   
\p
\v 4 Jisas wutaa ndi kat wandÉØ. yigumba vÉØga alÉØmba ngwuk. Ngwuk kat kÉØta nyan woseka walandÉØ.  
\v 5 NgÉØni nÉØma sakwat nÉØmba wuna sÉØmba waga ngwuk kat yaigandi. Wun Kraist wun waga waigandi. Wan nÉØmbana woseka wanjeya nyaangÉØt wutaa nÉØma sakwat nÉØmbana maawut kavle yigiyandÉØ.  
\v 6 Tat nÉØma sakwat nÉØmba waliagiyandi. waliandi, vÉØgiyangwuk. Ngwutna ngwaymba lÉØga nÉØmbo ndino waliagiyandi. SÉØvla kavamba lÉØga nÉØmbo ndino waliagiyandi. walialÉØnjeya vak vÉØlaa nÉØma maawut ke yelavÉØka lÉØngweya. Kan vak tÉØgiyandÉØ ngÉØni. NgÉØni la lÉØga nandinya asÉØk glei ana yaigalÉØ.  
\v 7 Nat kÉØpmamba lÉØga nÉØmba nat kÉØpmamba lÉØga nÉØmba kat yiga sÉØga viyaga waliagiyandi. Nat kingna nÉØmba nat kingna nÉØmba kat yiga sÉØga viyaga waliagiyandi. Ngepma ngepmamba lÉØga nÉØma sakwat nÉØmba wundÉØ kat tÉØga kiyaigandi. Kava kava aywaa yinaw kwukiyandÉØ kan kÉØpma.  
\v 8 Wan nÉØma vak taagwa nyan kwupmak yipma sÉØndÉØ tÉØleya vak vla tÉØgiyandÉØ.   
\p
\v 9 TÉØga lÉØga nat nÉØmba ngwuk kat kwutaa sÉØga viyaga vatnyanjangat kaligiyandi. Wuna mbaapmamba lÉØngwa vak kat vÉØlaa ngwuk kat aywaa kai waigandi.  
\v 10 Wan yaiga njÉØmblamba mbambala wun kat ndina maawupmba yelavÉØka kwutaa lÉØnja vak kwagalagiyandi. Ndi ndina mbaapmamba la nÉØmba kat kai walaa kotnjangat kaligiyandi.  
\v 11 Wan yaiga njÉØmbla nÉØn profet nÉØn waa woseka waiga nÉØma sakwat nÉØmba yaigandi. ndina nyaangÉØt wutaa nÉØma sakwat nÉØmba apma vak yelavÉØka lÉØnja maawut kavle yigiyandÉØ.  
\v 12 Wan yaiga njÉØmbla kavle vat nÉØma sakwat yaigandÉØ. yandÉØ maa wuna nÉØmba nÉØma sakwat wun kat kwagalagiyandi.  
\v 13 Wan yaiga kavle vak vÉØlaa wun kat kwagalalapman kwo lÉØgiya nÉØmba ndi apma vat tÉØgiyandi.  
\v 14 Wan yaiga njÉØmbla mbutuwa apma nyaangÉØt ngepma kava kava yiga mbukiyandi. Kava kava ngepma ngepmamba lÉØgiya nÉØmba wutaa kan Godna nyaangÉØtna waigandi. Ndi aywaa wutaa lÉØndi, ngÉØni la lÉØga nandinya yaigandÉØ waa wandÉØ Jisas.   
\s1 GODNA NGAYMBA TAAGANJEYA KAVLE NDA KAT JISAS MBUTNDĘ  
\p
\v 15 Jisas wandÉØ. Tamba God waa nyaangÉØt walÉØga nyan Danyel kupma pÉØlÉØwutndÉØ. KÉØta nyan Godna ngaymba kavle glei nda taagaiyandÉØ. taaganda nda wan ngay nglambio lÉØgiyandÉØ waa tamba pÉØlÉØwutndÉØ. Wun Matyu kan vÉØlÉØngwa nyaangÉØt pÉØlÉØwutÉØga nyan wun. Ngwuk kat wowun. Wan tamba pÉØlÉØwutnda vatna angwa nyaangÉØt kat ngwula maawupmba yelavÉØk ngwula wowun.  
\v 16 Jisas ndi kat wandÉØ. Tamba pÉØlÉØwutnda kavle glei nda kat vÉØlaa Judiamba lÉØga nÉØmba vaaka pÉØlÉØga nduwiat ay ngwula.  
\v 17 Kita nyan sambangemba lÉØga ndÉØna kwanda kwanda nda klavat ngay wuyleideyan ndÉØ kavle yigiyandÉØ. KÉØta yi yigiyandÉØ.  
\v 18 KÉØta yi yigiyandÉØ.  
\v 19 Nyan tÉØga taagwogwi nyan kat mwunya kwilÉØgat taagwo ndi kat miwa yigiyangwuk. Kwiyatapman pÉØlÉØga yinjeya yambÉØ kai.  
\v 20 Meit mwutolo kiya lÉØga njÉØmbla wungi vat kavle vat nÉØn kat ke kwiga waa God kat wagala ngwula.  
\v 21 Wan nÉØma sakwat kavle vat tak wupma ana lÉØndÉØ. Tak God kÉØpma kwuta njÉØmbla tÉØga wungi vak kavle vak ana lÉØndÉØ. ngÉØni wungi vak kavle vak ana nat njambÉØ lÉØgiyandÉØ.  
\v 22 NÉØma nyan wan nandinyana sakwat kalÉØtapman yindeyan ndinyangu aywaa kiyaigandi. God ndÉØna mbaapmamba lÉØgiya nÉØmba kat yelavÉØtaa wan nandinyana sakwat kalÉØkiyandÉØ.   
\p
\v 23 KÉØta nyan yalaa ngwuk kat kupma avÉØ ngwula Kraist kÉØngiyan waa woseka wandeyan ngwut maawupmba ke yelavÉØkngweya.  
\v 24 Wun Kraist wun. Wun God waa nyaangÉØt mbutÉØga nyan wun waa nÉØma sakwat nÉØmba yalaa waigandi. Ndi ngwuk kat woseka waigandi. Yalaa sÉØmogwi lÉØga nÉØma njÉØvwa kwukyandi. Kwutndi, ngÉØpaliga ndaigandi. Kwutnjeya vak kat vÉØlaa wan nÉØmbana maawupmba yelavÉØtnja vak kavle yigiyandÉØ. Godna nÉØmbana maawupmba yelavÉØka lÉØnja vak kat kavle yivat yalaa waigandi. ngwutna maawut ana kavle yigiyandÉØ.  
\v 25 Ngwuk kat ngÉØni yaiga vak tamba mbukwun. ngÉØni wan vak yandÉØ maa ngwutna maawut ana kavle yigiyandÉØ.   
\p
\v 26 Nat nÉØmba ngwuk kat yalaa avÉØmba ngwuk Kraist kan ndinyangu lapman kwo kavamba lÉØgandÉØ waa wanjeyabn ke wuka. Nat nÉØmba waigandi. Kan ngaymba pagwula lÉØgandÉØ waa wanjeyan ke wuka. woseka kwo waigandi.  
\v 27 Wun Godna nyaangÉØt kÉØpmat yalaa mbutÉØga nyan wun. NgÉØni yaweya vak ngwuk ndinyangu aywaa vÉØgiyangwuk. Vlap vlap wandÉØ, vÉØngwa vak vla yawun, vÉØgiyangwuk.   
\p
\v 28 Ngwut tamba vÉØga lÉØgangwuk. Kiya nyana sÉØm kwo kavamba yiga taagangweyan ndÉØna sÉØm ngaawi ambugavi yalaa plaga kÉØgiyandi waa wandÉØ Jisas.   
\s1 KRAIST YANDEYA VAK  
\p
\v 29 Jisas ndi kat wandÉØ. Wan kavle njÉØmblana nÉØma vak yiga ngÉØlÉØndÉØ maa nya yiga kulun waigandÉØ. Mbak ana sÉØgiyandÉØ. SÉØngwuk nyinangwupmba lÉØga pÉØka ndaigandi. nyinangwapomba lÉØga nda kat yinaw kwukiyandÉØ.  
\v 30 TÉØga lÉØga yaweya njÉØmbla ngway tolandÉØ, vÉØgiyangwuk. Nyinangwupmba lÉØga yaigowun. Wun Godna vak kÉØpmana nÉØmba kat sÉØmogwi lÉØga nyan wun. Wun tÉØmbumba yaigowun. Wun nÉØma avo lÉØga yaigowun. Kava kava ngepma ngepmamba lÉØga nÉØmba yaweya vak kat vÉØlaa nÉØma nyana yaa waa vaaka nglaigandi.  
\v 31 Nyinangwupmba lÉØga nÉØma sakwat ensel yigiyandi. Woli agwiat yigiyandi. Yambunat yigiyandi. Malingwatnat yigiyandi. Kambangwatnat yigiyandi. Yiga Godna mbaapmamba lÉØgiya nÉØmba kat kwutaa kaligiyandi waa wandÉØ Jisas.   
\s1 FIK WALĘNJA MINA NYAANGĘT  
\p
\v 32 Jisas ndi kat wandÉØ. Fik walÉØnja mi tÉØga vak kat ngwuk yelavÉØk ngwula. Nguo lÉØndeya njÉØmbla apma kwin klandeya njÉØmbla ngwuk vÉØlaa yelavÉØkiyangwuk. apma nya sÉØgiya njÉØmbla tamba ngway tologandÉØ waa yelavÉØkiyangwuk.  
\v 33 Ngwuk kat mbutuwa nyaangÉØtnonala kÉØta vatna. Mbutuwa vak kat wutaa ngwula maawupmba yelavÉØtaa ngÉØni la lÉØga nandinya tamba ngway tologandÉØ waa yelavÉØkiyangwuk.  
\v 34 Ngwuk yelavÉØk ngwula. Ngwula maawut ke tÉØvÉØnda. Ngwuk kan kÉØpmamba vÉØgiyangwuk.  
\v 35 Ngwuk kat wowun. NgÉØni kÉØpma nyinangwut ngÉØlÉØgiyandi. Ngwuk kat mbutuwa nyaangÉØt ana kwo valat tÉØgiyandÉØ waa wandÉØ Jisas.   
\s1 KRAIST YAIGA NJĘMBLA KĘTA NYAN ANA VĘGA WUKA LĘGANDĘ  
\p
\v 36 Jisas ndi kat wandÉØ. Yaweya njÉØmbla kÉØta nyan ana vÉØga lÉØgandÉØ. Nyinangwupmba lÉØga ensel ndi ana vÉØga lÉØgandi. Nyinangwupmba lÉØga ensel ndi ana vÉØga lÉØgandi. Wun Godna nyan wun ana vÉØga lÉØgowun. Wuna nyaek mÉØna vÉØga lÉØgandÉØ.  
\v 37 Yaweya njÉØmbla kan kÉØpmamba lÉØgiya nÉØmba yetÉØnjeya vak tamba Noa ta njÉØmbla yetÉØnja vak vla lÉØgiyandÉØ.  
\v 38 Tamba Noa ta njÉØmbla ta nÉØmba ndi God kat maawut yelavÉØtapman kwo nao mÉØna ngu mÉØna kÉØga taagwa mÉØna klaga yetÉØndi. YetÉØndi maa Noa njaambÉØt kwutaa njaambÉØtnat weleindÉØ.  
\v 39 Sambiyangu nÉØn kat vatnyavat yaigandÉØ waa wan ngepmana nÉØmba ana yelavÉØka lÉØndi. Sambiyangu yandÉØ, ndi aywaa ngu kÉØga kiyandi. Wun Godna ngepmamba tÉØga yaweya njÉØmbla Noa ta njÉØmbla ta vak vla tÉØgiyandÉØ.  
\v 40 Wan njÉØmbla ambugapmba vÉØlÉØlÉØk palÉØ kÉØtamba njÉØvwa kwuka lÉØmbÉØt. yaweya njÉØmbla kÉØta nyan kat kaligiyowun. Nat nyan tÉØgiyandÉØ.  
\v 41 Taagwa vÉØlÉØlÉØk wit mil kwuka lÉØmbÉØt, yaigowun. Yalaa taagwa kÉØta kwutaa kaligiyowun. Nat taagwa tÉØgiyalÉØ.  
\v 42 Ngwuk yigumba vÉØga alÉØmba ngwuk. Anda sÉØva ngwula njambwi nyan yaigandÉØ. Ana viga lÉØgangwuk.  
\v 43 Ngwuk maawut yelavÉØk ngwula. Ngaymba lÉØgiya nyan sÉØkwutÉØga nyan yaiga njÉØmbla wukendan ndÉØ ana sÉØndu kwagendÉØ. VÉØga lÉØgendan sÉØkwutÉØga nyan ana wuleigiyandÉØ. NdÉØ kat kai wandÉØ, yigendÉØ.  
\v 44 Ngwutno wupma sÉØndu kwalapman vÉØga lÉØgiyangwuk. Wun God tÉØga kavamba lÉØga yaweya njÉØmbla ngwuk ana vÉØga lÉØgangwuk. NdÉØ mbambala ana yaigandÉØ waga yelavÉØka lÉØngweya njÉØmbla wun yaigowun waa wandÉØ Jisas.   
\s1 NJĘVWA KWUTA APMA NYAN NJAMBWI NYAN YAIGA VAK KAT YELAVĘKA NJĘVWA KWUTNDĘ  
\p
\v 45 Jisas ndi kat wandÉØ. njÉØvwa kwuta apma nyan ndÉØno wupma yilÉØndÉØ. NdÉØna njambwi nyan ndÉØ kat wandÉØ, wan njwvwa kwuta nÉØmba kat njambwi nyanat tÉØgas vÉØga lÉØndÉØ. Ndi kat kÉØgÉØnda sanya kwiga ndi kat bÉØga lÉØndÉØ.  
\v 46 Njambwi nyan yilaa yalaa vÉØga lÉØga apma njÉØvwa kwutÉØgamÉØn waa wandeyan wan njÉØvwa kwutÉØga nyan nÉØma vat solat sÉØga lÉØgiyandÉØ.  
\v 47 Njambwi nyan ndÉØna apma njÉØvwa vÉØlaa ndÉØ kat waigandÉØ. MÉØn yaweya vak kat apma maawut yelavÉØka apma njÉØvwa kwutÉØmÉØn. Wuna kwanda kwanda nda aywaa mÉØnai vÉØga lÉØgiyaa waigandÉØ.  
\v 48 NjÉØvwa kwuta kavle nyan ndÉØ kupma yilÉØndÉØ. Wuna njambwi nyan yindan asÉØk glei ana yaigandÉØ waa yelavÉØtndÉØ.  
\v 49 YelavÉØka lÉØga ndÉØnogwinala kÉØta vat njÉØvwa kwutÉØnda nÉØmba kat viyaigandÉØ. NjÉØvwa kwagalalaa nÉØma ngu kÉØga yetÉØlÉØga nÉØmbanala yiga nÉØma ngu kÉØgÉØnda kÉØgiyandÉØ.  
\v 50 Mbambala wuna njambwi nyan ana yaigandÉØ waa yelavÉØtÉØndÉØ maa ndÉØna njambwi nyan wan nandinya yaigandÉØ.  
\v 51 NdÉØna njambwi nyan yalaa ndÉØ kat viyalaa kavle nÉØmba tÉØga kavamba taagagiyandÉØ. Wan kavle kavamba lÉØga nglaga nÉØmbi ngliaka lÉØgiyandÉØ waa wandÉØ Jisas.   
\c 25  
\s1 MWUNYOWIA NYANGUNA WAPUSEPUT  
\p
\v 1 Jisas wandÉØ. ngÉØni nyinangwupmba lÉØga yaiga nyan yaiga nandinya kÉØngi vat tÉØgandÉØ. Mwunyowia nyangu tamba vÉØli taagwa klavak ya nyan kat vÉØvat lam kwutaa yindi.  
\v 2 Nat tambanat mwunyowia nyangu apma vak yelavÉØtapman kwo yindi. Nat tambanat mwunyowia nyangu apma vak yelavÉØka yindi.  
\v 3 Apma vak yelavÉØtapman nyangu lam kalÉØtnjeya wel klalapman lammÉØna kwuka kwo yindi.  
\v 4 Apma vak yelavÉØka la ndi nyangu lam kalÉØtnjeya wel klalaa lam kwuka yindi.  
\v 5 Taagwa klavat ta nyan kÉØgÉØnda kwupmak kat yalapman tÉØndÉØ, kawiga lÉØga sÉØndu yindÉØ, kwandi.   
\p
\v 6 NÉØma nÉØndÉØ ngan kÉØta nyan walega wandÉØ. Wan taagwa klavat tÉØga nyan ngi lamba yaa waa walega wandÉØ.  
\v 7 WandÉØ maa laataa lam sagÉØlalaa ndÉØ kat vÉØvat yindi.  
\v 8 Apma vat yelavÉØtapman nyangu apma vat yelavÉØtÉØga nyangu kat wandi. NÉØna lam wel ngÉØlÉØndÉØ. NÉØn kat wel kwigiyangwuk wandi.  
\v 9 Wandi maa kai wandi. Ngwula lamo nÉØna lamo kalÉØtneya wel sakwat ana ndÉØ. NÉØn nÉØna lam mÉØna kalÉØkiyanÉØn. ngwuk yiga kla ngwula wandi, klavat yindi.  
\v 10 Wel klavat yindi maa taagwa klavat ta nyan yandÉØ. Yalaa ngay wuleindÉØ, ndino tambanat nyangu nÉØma kÉØgÉØnda kÉØvat wuleindi. Wuleindi maa ndaamangena mbapmo kwaalandi.   
\p
\v 11 Mbapmo kwalalaa tÉØndi maa wel klavat ya nyangu yandi. Yalaa wandi. NÉØma nyan, nÉØma nyan nÉØn kat mbapmo lavwi wandi maa wandÉØ.  
\v 12 Ngwuk kanda ngwuk. Ngwuk kat ana vÉØga lÉØgowun. Woseka ana wowun ngwuk kat ana vÉØga lÉØgowun waa wandÉØ taagwa klavat ya njambi nyan.  
\v 13 Jisas ndÉØna mbaapmamba la nÉØmba kat vÉØlaa wandÉØ. Ngwuk yigumba vÉØga lÉØgiyangwuk. Njambwi nyan yaiga nandinya ana vÉØga lÉØgangwuk waa wandÉØ Jisas.   
\s1 NJĘVWA KWUTA KUVUK NYANGUNA WAPUSEPUT  
\p
\v 14 Jisas ndi kat wandÉØ. NgÉØni nyinangwupmba lÉØga nyan yaiga nandinya kÉØngi vat tÉØgandÉØ. KÉØta njambwi nyan ngay kwagalalaa nat kavat yivat tÉØndÉØ. Yivat tÉØga ndÉØna njÉØvwa kwuta nÉØmba kat yagwa walaa ndi kat njivwa kwindÉØ.  
\v 15 Ndina maawupmba lÉØga vak kat vÉØlaa sÉØga nagulaa ndi kat wan njÉØvwa kwindÉØ. Nat nyan kat dola 5,000 kwilaa wandÉØ. Kan moni vÉØga lÉØgiyamÉØn wandÉØ. Nat nyan kat dola 2,000 kwilaa wupma ndÉØ kat kwilaa wandÉØ. Nat nyan kat dola 1,000 yindÉØ.  
\v 16 5,000 dola kla nyan wungi monimba bisnis kwuka nat 5,000 kdola kla nyan wungi monimba bisnis kwuka nat 5,000 dola klandÉØ. klandÉØ, ndÉØnamba 10,000 dola tÉØndÉØ.  
\v 17 NdÉØno 2,000 dola kla nyan wungi monimba bisnis kwuka nat 2,000 dola klandÉØ. KlandÉØ, ndÉØnamba 4,000 dola tÉØndÉØ.  
\v 18 NdÉØno 1,000 dola kla nyan ndÉØ bisnis ana kwutndi. Waangu valaa wan moni waangumba laagandÉØ, tÉØndÉØ.  
\v 19 NÉØma njÉØmbla lÉØga njambwi nyan yalaa njÉØvwa kwilaa yinda ndi kuvut nyanguna njÉØvwa vÉØvat yandÉØ.  
\v 20 5,000 dola kla nyan yalaa nÉØma nyan kat vÉØlaa wandÉØ. tat wun kat 5,000 dola kwimÉØn. Wungi monimba bisnis kwuka nat 5,000 dola klawun. mÉØna 10,000 dola agla waa wandÉØ.  
\v 21 WandÉØ maa njambwi nyan wandÉØ. MÉØn apma njÉØvwa kwutÉØma. mÉØn kat njÉØvwa kwiwa moni apma vat vÉØga lÉØmÉØn. NgÉØni mÉØn kat nÉØma moni kwiwun, vÉØga lÉØgiyamÉØn. Wuna ngay wuleilaa wunogwinala apma vat yetÉØgiyamÉØn waa wandÉØ.  
\v 22 2,000 dola kla nyan yalaa nÉØma nyan kat vÉØlaa wandÉØ. Tak wun kat 2,000 dola kwimÉØn, wungi monimba bisnis kwuka nat 2,000 dola klawun. MÉØna 4,000 dola kÉØngiyan. Agla waa wandÉØ maa njambwi nyan ndÉØ kat wandÉØ.  
\v 23 MÉØn apma njÉØvwa kwutÉØma. Tak mÉØn kat kwiwa mat moni kat apma vak vÉØga lÉØgiyamÉØn. Wuna ngay wuleilaa wunogwinala apma vat yetÉØgiyamÉØn waa wandÉØ njambwi nyan.   
\p
\v 24 1,000 dola kla nyan wuleilaa wandÉØ. Njambwi nyan. MÉØn kao mbundÉØ nyan mÉØn. Ngi kat tÉØga mÉØn kat vaaka lÉØgowun. Nat nyan tuga kandi ndamba klaga kÉØga yetÉØlÉØgamÉØn. Nat nyan yaagiya mina sÉØpmba sÉØgÉØka kÉØga yetÉØlÉØgamÉØn.  
\v 25 MÉØn kat vaaka lÉØga wun kat kwima moni waangu valaa waangumba taagawun. MÉØna moni kÉØngiyan. Agla wandÉØ.   
\p
\v 26 WandÉØ maa njambwi nyan wandÉØ. MÉØn kavle njwvwa kwutÉØga nyan mÉØn. MÉØn mbangÉØ kÉØlÉØpangÉØ namwiya nyan mÉØn. Wuna vak tamba vÉØga lÉØgamÉØn. Nat nyan tuga kandi ndamba klalaa kÉØga yetÉØlÉØgowun. Nat nyan yaagiya mi sÉØpmba sÉØgÉØka kÉØga yetÉØlÉØgowun.  
\v 27-28 Manda kat mÉØn kat kwiwa wuna moni bengmba taagalapman yimÉØn. Bengmba taagagemÉØn wan moni samat nÉØman yigendÉØ. Yilaa yawan bengmba taagagemÉØn 1,000 dola nÉØmba kat wandÉØ. Kan kwutaa lÉØnda moni klalaa 10,000 dola kwuta lÉØga nyan kat agwi ngwula.  
\v 29 Moni kwuta lÉØga nÉØmba ndi nat moni klaigandi. Klalaa ndi nÉØma sakwat monio lÉØgiyandi. Moni kwutapman tÉØga nÉØmba wan kwutaa lÉØnja nda klalaa yaagigiyandi.  
\v 30 Wan kavle njÉØvwa kwutÉØga nyan kat kwutaa alaguat yaagi ngwula. Yaagingwut, yiga kulun walÉØga kavamba lÉØga nglaga nÉØmbi ngliaka lÉØgiyandÉØ waa wandÉØ njambwi nyan waa wandÉØ Jisas.   
\s1 NGĘNI LA LĘGA NANDINYANA VAT  
\p
\v 31 Jisas ndi kat wandÉØ. Wun ndinyangu kat Godna nyaangÉØt mbutÉØganyan wun. NgÉØni njambwi kingat tÉØwun, Godna ensel wuna sÉØ kwutaa katsolÉØndi, yaigowun. Enselonala yalaa kingna tÉØgÉØtmba ndaa lÉØgiyowun.  
\v 32 Ndaa lÉØwun maa kan kÉØpmamba lÉØga nÉØmba aywaa yaa yisolaa lÉØgiyandi. Ndi kat vÉØlaa sÉØga naguga mbaapma vÉØlÉØlÉØkmba taagaiyowun. Sip sip vÉØga la nyan nat mbaapmamba sip sip taagalaa nat mbaapmamba meme taaganda vla taagaiyowun.  
\v 33 Sip sip kat yaagindan naangamba taagagiyowun. Meme kat ambugendan naangamba taagagiywoun.  
\v 34 Taagalaa yaagindan naangamba lÉØga nÉØmba kat wun njambwi king wun waigowun. Ngwuk apma nÉØmba ngwuk. Wuna nyaek ngwuk kat apma vat yindÉØ. Yagwa ngwula. God ngwuk kat kwindeya nda yaa kla ngwula. Tamba kÉØpma kwuta njÉØmblamba ngwuk kat kwindeya nda kwundaka taagandÉØ.  
\v 35 Ngwuk wun kat apma vat yilÉØngwuk. WundÉØ kat tÉØwun, wun kat kÉØgÉØnda kwingwuk. Ngu kÉØvat tÉØwun, wun kat ngu kwingwuk. Nat ngepmamba lÉØga ya nyan vla lÉØwun, wun kat kwutaa ngwula ngayat kalingwuk.  
\v 36 Waavwi lapman tÉØwun, wun kat waavwi kwingwuk. Yelogwen kat tÉØwun, wun kat yaa kwunakngwuk. Kalambusmba tÉØwun, wun kat yaa vÉØngwuk waa ndi kat waigowun.   
\p
\v 37 Ndi kat wupma wowun, wan apma nÉØmba awat wun kat waigandi. njambwi nyan anda njÉØmbla wundÉØ kat tÉØmÉØn, mÉØn kat kÉØgÉØnda kwinÉØn. Anda njÉØmbla ngu kÉØvat tÉØmÉØn, mÉØn kat kwinÉØn.  
\v 38 Anda njÉØmbla kapma ngepma nyan vla lÉØmÉØn, vÉØlaa mÉØn kat kwutaa nÉØna ngayat kalinan. Anda njÉØmbla waavwi lapma tÉØmÉØn, mÉØn kat waavwi kwinan.  
\v 39 Anda njÉØmbla yelogwen kat kwamÉØn, mÉØn kat kwunatnÉØn. Anda njÉØmbla kalabusmba tÉØmÉØn, mÉØn kat yaa vÉØnÉØn waa wagalagiyandi.  
\v 40 Wun njambwi king ndi kat waigowun Ngwuk kat wowun. Mbutuwa apma njÉØvwa ngwuk tamba yilÉØngwuk wuna mbaapmamba la nÉØma nÉØmba mat nyaangu kat. Ndi kat yilÉØngwa vak wuna lak yandÉØ. Ngi kat tÉØga wun kat yilÉØngwuk wowun waa ndi kat walaa  
\v 41 ambugendan naangamba lÉØga nÉØmba kat waigowun. Ngwuk wun kat kwagalalaa ay ngwula. God ngwuk kat kai walÉØgandÉØ. NjÉØmbla njÉØmbla vÉØtÉØga ya lÉØga kavat ay ngwula. ngwula ngepma. Tamba wan kava God kwutndÉØ. Setan dÉØna enselonala ndi kat kwutaa taagandeya ngepma kat kwutndÉØ.  
\v 42 Tak wun wundÉØ kat tÉØwun, wun kat kÉØgÉØnda kwivak kat kai wangwuk. Ngu kÉØvat tÉØwun, ngu kwivak kat kai wangwuk.  
\v 43 Wun nat ngepmamba lÉØga yalaa la nyan vla lÉØwun, ngwula ngayat kalivak kat kai wangwuk. Wun waavwi lapman tÉØwun, wun kat waavwi kwivak kat kai wangwuk. Wun yelogwen kat kwowun, wun kat kwunapmak kat kai wangwuk. Wun kalambusmba lÉØwun, wun kat vÉØvak kat kai wangwuk waa wowun maa wun kat waigandi.   
\p
\v 44 Njambwi nyan anda njÉØmbla wundÉØ kat tÉØmÉØn, vÉØlaa kÉØgÉØnda ngu kwilapman yinÉØn. anda njÉØmbla kapma nyan vla lÉØmÉØn, mÉØn kat kwutaa nÉØna ngayat kalilapman yinÉØn. anda njÉØmbla waavwi lapman tÉØmÉØn, kwilapman yinÉØn. anda njÉØmbla yelogwen kat tÉØmÉØn, kwunatapman yinÉØn. anda njÉØmbla kalabusmba tÉØmÉØn, mÉØn kat vÉØlapman yinan waa wandi maa  
\v 45-46 wun njambwi king ndi kat waigowun. Wuna mbaapmamba lÉØga mat nyangu ndi kat kwunapmak kat kai wangwuk. Ndi kat tÉØga kavat kalilaa ndi kat taagagiyandi. Yaagindan naangamba lÉØga apma nÉØmba njÉØmbla njÉØmbla apma vat tÉØnjeya kava wuleigiyandi waa wandÉØ Jisas.   
\c 26  
\s1 JISAS KAT VATNYAVAK KAT NYAANGĘT NGAMBUNDI  
\p
\v 1 Jisas yisola la nÉØma sakwat nÉØmba kat nyaangÉØt kwilaa ndÉØna mbaapmamba la nÉØmba kat wandÉØ.  
\v 2 Nandinya vÉØlÉØlÉØk yindÉØ maa Pasova walÉØna pesto tÉØgiyandÉØ. Wan nandinya wun Godna vak sÉØmogwi lÉØga nyan wun kat kwutaa diwai krosmba kaalagiyandi waa wandÉØ Jisas.   
\p
\v 3 TÉØga lÉØga God kat kwunatÉØga njambwi nÉØmbo Judana njambwi nÉØmbo yisola lÉØga nyaangÉØt ngambulÉØndi. God kat kwunatÉØga njambwi nyan Kaiafasna ngaymba yisolaa lÉØga nyaangÉØt ngambulÉØndi.  
\v 4 Jisas kat pagwuga kwutaa vatnyagiyanÉØn waa ngambulÉØndi.  
\v 5 NÉØma sakwat nÉØmba Pesto tÉØga njÉØmbla yalÉØgandi. NdÉØ kat kwutneya vak vÉØlaa nÉØn kat kai walaa walegiyandi. Ana nglaatndÉØ. NdÉØna mala waa ngambulÉØndi.   
\s1 TAAGWA JISASNA NAMBUMBA SANDA SALĘTĘ  
\p
\v 6 Jisas Betanimba lÉØga tak kawia kÉØla nyan Saimona ngaymba lÉØndÉØ.  
\v 7 Jisas ngaymba lÉØndÉØ, kÉØta lagwa kambapmba kwutnja aw kwutaa yalÉØ. Wan awmba apma njangu veilÉØga sanda lÉØndÉØ. Wan sanda nÉØma sanya kwiga klalÉØnja sanda. Jisas njambamba lÉØga nao kÉØlÉØndi maa wan sanda Jisasna nambumb salatÉØ.  
\v 8 NdÉØna mbaapmamba la nÉØmba vÉØlaa walega wandi. Wan sanda manda kat kwo salatÉØ.  
\v 9 NÉØma sanyo lÉØga sanda. Wan sanda kwilaa sanya klalaa sanya lapman tÉØga nÉØmba kat kwigelÉØ waa walega wandi.   
\p
\v 10 Jisas wanja vak wutaa ndi kat kat wandÉØ. Manda kat ngwuk lÉØ kat walega njÉØka wangwuk. Wun kat apma vak kwunakalÉØ.  
\v 11 Sanya lapman nÉØmba ngÉØni ngwulogwinala njÉØmbla njÉØmbla tÉØgiyandi. NjÉØmbla njÉØmbla ndi kat apma vat yilÉØgiyangwuk. Wun ngwutnogwina njÉØmbla njÉØmbla ana lÉØgiyowun.  
\v 12 Kiyawun maa wun kat waangumba taaganjeya vak kat yelavÉØta wan sanda salÉØtÉØ.  
\v 13 Ngwuk kat wowun. YelavÉØk ngwula. Kan apma nyaangÉØt mbutnjeya kava kavamba lÉØlai sanda wun kat salÉØkna vak kat yelavÉØtaa mbukiyandi waa wandÉØ Jisas.   
\s1 JISAS KAT NGWUK KAT SĘMOGWIGIYOWUN WANDĘ JUDAS  
\p
\v 14 Wan tamba vÉØli kiyeli vÉØlÉØlÉØk Jisasna ngwaymba la nÉØmbana kÉØta nyan ndÉØna sÉØ Judas Iskeriot. NdÉØ God kat kwunatÉØga njambwi nÉØmba kat yiga vÉØlaa ndi kat nyaangÉØt ngambundÉØ.  
\v 15 NyaangÉØt ngambulaa wandÉØ. Jisas kat kwukngweya vat ngwuk kat sÉØmogwiweyan wun kat angamala sanya kwigiyangwuk waa wandÉØ maa ndÉØ kat sanya kÉØta ndumi kiyeli tamba vÉØli kwindi.  
\v 16 Sanya klalaa ndi kat kwagalalaa yiga Jisas kat kwutnjeya vak kat ndÉØna maawupmba yelavÉØka lÉØndÉØ.   
\s1 JISAS PASOVANA KĘGĘNDA NDĘNA MBAAPMAMBA LA NĘMBO KĘNDĘ  
\p
\v 17 Yis taagalapman nao kÉØlÉØnja pestona kÉØta nandinya Jisasna mbaapmamba la nÉØmba yalaa ndÉØ kat wagalandi. Pestona kÉØneya kÉØgÉØnda anda kavamba kwukiyanÉØn waa wagalandi Jisas kat.  
\v 18 Jisas ndi kat wandÉØ. nÉØma ngepma wuleilaa tamba wawa nyana ngay kat yiga vÉØ ngwula. NdÉØ kat vÉØlaa awa ngwula ndÉØ kat. NyaangÉØt sÉØmogwi lÉØga nyan wandÉØ. NÉØma njÉØvwa kwukweya njÉØmbla tamba ngway tologandÉØ. MÉØna ngaymba wunogwinala wuna mbaapma lÉØga nÉØmbo pestona kÉØgÉØnda kÉØgiyanÉØn waa sÉØmogwi lÉØga nyan wandÉØ waa ndÉØ kat yiga awa ngwula waa wandÉØ Jisas.  
\v 19 WandÉØ maa yindi. yilaa ngay wuleilaa pestona kÉØgÉØnda kwutndi.   
\p
\v 20 Nglaambu Jisas yandÉØ maa ndÉØna mbaapmamba lÉØga nÉØmbo njambamba ndaa lÉØga nglaambu kÉØgÉØnda kÉØga lÉØndi.  
\v 21 KÉØga lÉØga Jisas ndi kat wandÉØ. Ngwuk kat wowun. Wuna mbaapmamba lÉØga ngwutna kÉØta nyan wun kat kwutajangat sÉØmogwigiyandÉØ waa wandÉØ maa  
\v 22 ndÉØna mbaapmamba la nÉØmba nÉØma vak yelavÉØka lÉØga wunayÉØ? Njambwi nyan wunayÉØ? waa wagalandi.  
\v 23 Wagalandi, wandÉØ. Wunogwina kÉØta nombe awmba kÉØgÉØnda klavat taamba kwusendagiya nyan wungian ndÉØnayÉØ wun kat sÉØmogwigiya.  
\v 24 Wun Godna vat sÉØmogwi lÉØga nyan wun. Wun kat vatnyanjeyangat sÉØmogwigiya nyan kat ndÉØ kat miwa ay ngwula. NdÉØ kat nyÉØme kwutapman yigelan ndÉØ apma vat tÉØgendÉØ waa wandÉØ Jisas.  
\v 25 Judas Jisas kat vatnyanjeya vak kat sÉØmogwigiya nyan wutaa Jisas kat wandÉØ. NyaangÉØt sÉØmogwi lÉØga nyan. WunayÉØ? wandÉØ. WandÉØ maa Jisas ndÉØ kat wandÉØ. MÉØn ngiyambak wama. mÉØnayÉØ waa wandÉØ Jisas.   
\s1 JISAS NDĘNA WIMBU NDĘNA YELOGWEN NDI KAT KWINDĘ  
\p
\v 26 KÉØga lÉØga Jisas bret-nao klalaa God kat sÉØvu kÉØlaa lÉØmba ngÉØlÉØga ndÉØna mbaapmamba la nÉØmba kat kwilaa wandÉØ. Klalaa agÉØ ngwula. Kan wuna wimba ngwuk kat kwiwa waa walaa.  
\v 27 wain ta kap klalaa God kat sÉØvu kÉØlaa ndÉØna mbaapmamba la nÉØmba kat kwilaa wandÉØ. Ngwuk aywaa kan ngu agÉØ ngwula.  
\v 28 Kan ngu wuna yelogwena ngwuk kat kwiwa. kan wuna yelogwen Godna nyingi maawut kat kwunatndÉØ maa ngwuk kat ana sÉØgiyandÉØ. NÉØma sakwat nÉØmba yiga yetÉØlÉØnja kavle vak kwunapmak kan wuna mbangÉØna yelogwen salakiyandÉØ.  
\v 29 Ngwuk kat wowun. Wain walÉØna ngu kÉØpmamba lÉØga ana nat njambÉØ kÉØgiyowun. God vÉØga lÉØga kavat wuleilaa ngÉØni ngwulogwinala kupi apma ngu kÉØgiywoun waa wandÉØ Jisas.   
\p
\v 30 Jisas wandÉØ maa God kat yelavÉØka mbangu kwundi walaa wan ngay kwagalalaa Oliv walÉØnja nduwiat yindi.   
\s1 PITA JISAS KAT KAI WANDEYA VAK  
\p
\v 31 Jisas ndi kat wandÉØ. Mbambala ngan ngwuk aywaa wun kat kwagalalaa vaaka yigiyangwuk. Tamba la nÉØmba God waa nyaangÉØt kupma pÉØlÉØwutndi.  
\p Sip sip kat bÉØga la nyan kat God vatnyandÉØ maa  
\li1 ndi sip sip kava kavat yigiyandi  
\p waa tamba pÉØlÉØwutndi.  
\v 32 Kiyalaa lÉØga laataa tak Galiliat yigiyowun. Ngwuk ngÉØni wuna kwupmba yaigangwuk waa wandÉØ Jisas.  
\v 33 WandÉØ maa wutaa Pita Jisas kat wandÉØ. Njambwi nyan mÉØn kat kwagalalaa ana vaaka yigiyowun. mÉØna mbaapmamba lÉØga nÉØmba nat nÉØmba ndi anagandi mÉØn kat kwagalagiya. Wun ana mÉØn kat kwagalgiywowun waa wandÉØ maa Jisas ndÉØ kat wandÉØ.  
\v 34 Pita wawa nyaangÉØt wutaa mÉØna maawut ke sÉØlwoka kwagalaga. Mbambala ngan njambÉØ kuvuk waigamÉØn. Jisas kat ana vÉØga lÉØgowun waigamÉØn. WamÉØn maa ava nyaaga viyaigandÉØ waa wandÉØ Jisas.  
\v 35 Pita wutaa wandÉØ. Jisas kat ana vÉØga lÉØgowun waa ana wupma waigowun. mÉØnogwinala kiyaweyan apma vatna. Ana vaakiyowun waa wandÉØ maa Jisasna mbaapmamba la nÉØmba aywaa wupma wandi.   
\s1 GETSEMANI WALĘNJA KAVA YILAA GOD KAT WAGALANDĘ  
\p
\v 36 Jisas ndÉØna mbaapmamba la nÉØmbonala Getsemani walÉØnja kavat yindi. yindi maa Jisas ndi kat wandÉØ. Ngwuk kumba ndaa lÉØ ngwula. Wun samat yiga yilaa tÉØga lÉØga God kat wagalagiyowun, waa walaa  
\v 37 ndÉØna mbaapmamba la nÉØmbana nat nÉØmba kat kwagalaa Pita, Jems, Jon kuvut nÉØmba ndi kat mÉØna kwutaa yindÉØ. TÉØga lÉØga nÉØma maawut yelavÉØka lÉØga ndi kat wandÉØ.  
\v 38 Wun nÉØma maawut yelavÉØka lÉØgowun. Kiyavat tÉØga nyan vla lÉØgowun. Ngwuk kumba lÉØga sÉØndu ke kwa. Wun kat kawiga alÉØ ngwula waa walaa  
\v 39 ndi kat kwagalalaa samat kapma yindÉØ. yilaa mÉØndama mÉØndama kÉØpmamba ndalaa tÉØga God kat wagalandÉØ. Wuna nyaek mÉØn kat wagalavat yigowun. Kan yaiga kavle vat wun kat yalandÉØ. Wuna maawupmba yelavÉØkwa vapmba wun kat ke yiga. MÉØnaj yelavÉØkiya vapmba wun kat ay mÉØla waa walaa  
\v 40 lataa kuvut nyaangu ta kavat ndi kat vÉØvat yindÉØ. SÉØndu kwanja vak vÉØlaa Pita kat wandÉØ. Ngwuk manda kat sÉØndu kwangwuk. Samat wun kat ana kawiga lÉØlÉØgangwuk?  
\v 41 MÉØni vÉØga lÉØga God kat wagala ngwula. God kat wagalangweyan ngwuk kat yaiga kavle vat ana ngwuk kat kwulakiyandÉØ. Kwo lÉØgiyangwuk. Ngwuk kat bÉØga lÉØgowun. SÉØndu kwavat ana yelavÉØka waa walaa lungwamataa yindÉØ.   
\p
\v 42 Yilaa God kat wagalandÉØ. Kan yaiga kavle vat wun kat yalandÉØ. mÉØnai yelavÉØka lÉØga vapmba kan yaiga kavle vat wun kat yandyan wovuna waa walaa laataa  
\v 43 kuvut nyangu ta kavat yindÉØ. ndina mÉØni valÉØ kwutndÉØ, sÉØndu kwandi, yiga vÉØndÉØ. VÉØlaa ana wandÉØ. Lungwamataa yindÉØ.  
\v 44 Ndi kat kwagalalaa yiga kuvut wan njambÉØ God kat wagalandÉØ. Tak wagalanda wumba nyaangÉØpmba wagalandÉØ.   
\p
\v 45 Wagalalaa ndÉØna mbaapmamba la kuvut nyaangu kat laataa vÉØvat yindÉØ kuvut wan njambÉØ. Yilaa ndi kat wandÉØ. Ngwuk sÉØndu kwangwuk? Wun Godna vak sÉØmogwi lÉØga nyan wun. Wun kat kwutaa kaligiya kavle nÉØmba tamba yaa ngway tologandÉØ. laataa avÉØ ngwula.  
\v 46 Laak ngwula. yigat. Wun kat sÉØmogwivat tÉØga nyan tamba yaa ngway tologandÉØ waa wandÉØ Jisas.   
\s1 JISAS KAT KWUTAA KALINDI  
\p
\v 47 Jisas walÉØndi maa ndÉØna mbaapmamba la tamba vÉØli kiyeli vÉØlÉØlÉØk nyanguna kÉØta nyan Judas yandÉØ. Jisas kat kwutaa kalivat ta nÉØma sakwat nÉØmbana yandÉØ. ndi yak kwuka njay kwuka nÉØmbi nda kwuka yandi. God kat kwunatÉØga njambwi nÉØmbo Judana njambwi nÉØmbo ay wandi maa yandi.  
\v 48 Tak Judas ndi kat mbuka wandÉØ. Yiga vÉØlaa kÉØpmwimba wusÉØtweya nyan ndÉØ Jisas wungiyan ndÉØ. ndÉØ kat wumba agwukmba ngwuk waa tak Judas ndi kat mbuka wandÉØ.  
\v 49 Judas yalaa Jisas kat vÉØlaa nyaangÉØt sÉØmogwi lÉØga nyan apma ngan walaa ndÉØ kat yiga kwutaa ndÉØna kÉØipmwimba wusÉØtndÉØ.  
\v 50 WusÉØtndÉØ maa Jisas ndÉØ kat wandÉØ. KÉØta mbaapma nyan wun kat kwupmeya njÉØvwa kwiyatapman agwup mÉØla waa wandÉØ maa Judasnogwinala ya nÉØmba Jisas kat taambamba kwutndi.   
\p
\v 51 Jisasna mbaapmamba la nyan kÉØta ndÉØna ngway avamba kwa yak laguga klalaa God kat kwunat njambwi nayana njÉØvwa kwuta nyana waan kalÉØtndÉØ. KalÉØtndÉØ, kÉØpmamba ndandÉØ.  
\v 52 VÉØlaa Jisas wandÉØ. MÉØna yak tÉØnda vla sisenda. KÉØta nyan wan yapmba viyama vak vatnyagiyandi.  
\v 53 Wuna nyaek kat wagalaweyan wuna nyaek wandÉØ maa nyingangwutna nÉØma sakwat ensel yaigandi wun kat kwunapmak. Mbaapma tamba vÉØli kiyeli vÉØlÉØlÉØk ensel wun kat walaa ndi kat sÉØvat yaigandi. Wun ana wagalgiyowun.  
\v 54 Wun kat kwutaa kalilaa vatnyanjeya vak kat tamb la nÉØmba lavu nyinangmba pÉØlÉØwutndi. Nyaek kat ndÉØnogwi lÉØga ensel kat wagalaweyan tamba pÉØlÉØwutnja vak ana kak kiyaigandÉØ. Wungi kat tÉØga kai wowun. Ana wagalgiyowun waa walaa  
\v 55 ndÉØ kat kwupmat ya nÉØmba kat wandÉØ. ngwuk manda kat nÉØmbi nda njay yak kwutaa wun kat yangwuk. SÉØkwutÉØga nyan kat kwupmat tÉØnja vak vla manda kat wun kat yangwuk. nandinya nandiya Godna ngay wuleilaa ngwutnogwinala ndaa lÉØga nyaangÉØt ngwuk kat mbutÉØwun. Wun kat wungi nandinyamba kwukengwuk tuwa.  
\v 56 Wun kat yilÉØngwa vak kwo ana yilÉØgangwuk. Tamba la profet pÉØlÉØwutnja vak vla wun kat wupma yilÉØgangwuk waa wandÉØ maa ndÉØna mbaapmamba la nÉØmba aywaa ndÉØ kat kwagalalaa vaaka pÉØlÉØga yindi.   
\s1 JISAS KAT KWUTAA NJAMBWI NĘMBA YISOLAA LA NGAYAT KALINDI  
\p
\v 57 Jisas kat kwuka nÉØmba God kat kwunatÉØga njambwi nyan Kaiafasna ngayat kalindi. Moses kwiya lo sÉØmogwi la nÉØmbo Judana njambwi nÉØmbo wan ngaymba yilaa yisolaa lÉØndi.  
\v 58 Pita sÉØvlamba lÉØga Jisasna kwupmba yandÉØ. yalaa ngayna ngwutnyala way nge alagumba tÉØndÉØ. Plismanonala kÉØta kavamba lÉØndÉØ. jisas kat yinjeya vakvÉØmbowun walaa yalaa vÉØga lÉØndÉØ.   
\p
\v 59 God kat kwunatÉØga njambwi nÉØmbo yisola la nat nÉØmbo Jisas kat woseka wanja vak kat wupmak yalaa lÉØndi. Wutaa ndÉØ kat vatnyagiyanÉØn waa yelavÉØka lÉØndi.  
\v 60 NÉØma sakwat nÉØmba yalaa Jisas kat woseka walÉØndi. Woseka walÉØnja vak kÉØta nyaangÉØt ana walÉØndi ndÉØ kat. MandÉØp mandÉØp nyaangÉØt walÉØndi. NgÉØni vÉØlÉØlÉØk palÉØ laataa nÉØmba sakwat nÉØmba kat woseka waga mbupmbÉØk.  
\v 61 Kupma wambÉØk. Tak Jisas kupma wandÉØ. Godna ngay sulÉØlaa nandinya kuvutmba kwukiyowun waa Jisas wandÉØ waa woseka mbupmbÉØk.   
\b  
\p
\v 62 MbupmbÉØk maa God kat kwunatÉØga njambwi nyan laataa Jisas kat wandÉØ. MÉØn kat mbupmba nyaangÉØt mÉØn an ngambumba nyaangÉØt kat wutaa awat nyaangÉØt mbukiyamÉØn? waa wagalandÉØ maa  
\v 63 Jisas kwundi ana wandÉØ. God kat kwunatÉØga njambwi nyan at nat njambÉØ Jisas kat nÉØma kwundimba wagalandÉØ. MÉØn nÉØn kat ambup mÉØla. Woseka wana walÉØmeya. nyinangwupmba lÉØga God woseka wameya vak vÉØgiyandÉØ. MÉØn Juda kat kwunapmak ya nyan mÉØn? MÉØn Godna nyan mÉØn? waa ndÉØ kat wagalandÉØ.  
\v 64 Jisas ndÉØ kat wandÉØ. MÉØn ngiyambak wupma wama wun kat. Wun Godna vat sÉØmogwi lÉØga nyan wun. NgÉØni kan kÉØpmamba lÉØga yiwun maa wun kat ana vÉØgiyangwuk. Nyinangwut wokelaa Godna yaagindan naangÉØmba ndaa lÉØga njambwi nyanat tÉØwun maa vÉØgiyangwuk. NgÉØni nyinangwupmba lÉØga ngaga yaweya vak vÉØgiyangwuk waa wandÉØ Jisas.   
\p
\v 65 Jisas waa nyaangÉØt wutaa God kat kwunata njambwi nyan nyingi maawut tÉØga avla ndÉØna waavwi taambamba ngÉØlÉØtaa wandÉØ. Wan nyan God kat kavle nyaangÉØtna wanda. NgÉØni ndÉØna kavle vat mbukiya nÉØmba ana yalaa mbukiyandi. Kavle vat yinda vak ngiyambak wutna. Kavle vat mbuta nyaangÉØt kan yesolaa lÉØga nÉØmba nÉØn aywaa tamba wutnÉØn.  
\v 66 Ngwuk angamak ndÉØ kat yigiyangwuk. Angamak ngwuk yelavÉØka lÉØgangwuk waa ndi kat wandÉØ maa wandi. NdÉØ kavle nyan. NdÉØ kat sÉØgiyanÉØn. KiyaigandÉØ waa wandi.   
\p
\v 67 Wupma walaa ndÉØ kat mÉØndamamba sÉØpmiya saga ndÉØ kat taamamba viyalÉØndi.  
\v 68 Nat nÉØmba pagwuga yalaa ndÉØ kat viyalaa wandi. MÉØn Kraist profet vla timeyan mÉØn kat viyalÉØga nÉØmbana sÉØ ambuk waa kasega wandi.   
\s1 PITA JISAS KAT KAI WAA PAGWUNDI  
\p
\v 69 Pita alagu ndaamangemba ndaa lÉØndÉØ, God kat kwunata njambwi nyana njÉØvwa kwutat taagwa yalaa Pita kat vÉØlaa walÉØ. MÉØn Galilimba lan Jisasonala tÉØmÉØn, vÉØwun walÉØ.  
\v 70 Pita wutaa wandÉØ. Wanya vak wun ana vÉØga lÉØgowun waa walaa  
\v 71 laataa ngegavamba la tÉØvwina suwi yambat yindÉØ. YindÉØ maa nat taagwa vÉØlaa wumba yisolaa la nÉØmba kat walÉØ. Kan nyan kat avÉØ ngwula. Kan nyan Nasaretmba la Jisasonala kÉØta vat tÉØndÉØ.  
\v 72 Pita wala vak kat wutaa wandÉØ. NÉØma kwundimba wandÉØ. Wanya nyan wun ana vÉØga lÉØgowun wandÉØ.  
\v 73 TÉØga lÉØga wumba yisola la nÉØmba Pita kat vÉØlaa wandi. MÉØn mÉØn kat vÉØnÉØn. Jisasna mbaapmamba la nyan mÉØn. Galilimba lÉØga nÉØmbana kwundimba ngambulÉØgamÉØn waa wandi.  
\v 74 Pita wutaa ndi kat nÉØma kwundimba wandÉØ. Ngwuk kat woseka ana waigowun. Woseka waweya vak God vÉØga wutaa wun kat sÉØgiyandÉØ. Wan wun kat wangwa nyan Jisas kat ana vÉØga lÉØgowun waa walÉØndÉØ maa ava nyaaga viyandÉØ.  
\v 75 ViyandÉØ maa wutaa Pita yelavÉØtndÉØ. Tak Jisaswun kat wandÉØ. Wun kat njambÉØ kuvut pagwuga kai walÉØmÉØn, ava nyaaga viyaigandÉØ wanda vak kat ndÉØna maawupmba yelavÉØtaa Pita laataa yiga nÉØmamba nglalÉØndÉØ.   
\c 27  
\s1 JISAS KAT KWUTAA PAILAT TA NGAYAT KALINDI  
\p
\v 1 Ngambi gleimba God kat kwunata njambwi nÉØmbo Judana nÉØma nÉØmbo Jisas kat vatnyanjeya vak kat yisola lÉØga ngambulÉØndi.  
\v 2 Jisas kat kwutaa man taamba sangilaa njambwi nyan pailat ta ngayat kalindi.   
\s1 JUDAS KIYANDĘ  
\p
\v 3 Jisas kat sÉØmogwia nyan Judas Jisas kat kwutaa kotndangat kalindi, wutaa mandÉØp maawut sÉØlÉØmaka yelavÉØtndÉØ. YelavÉØtaa wan ndÉØ kat kwinja sanya kÉØta ndumi kiyeli tamba vÉØli kwutaa yiga God kat kwunatÉØga njambwi nÉØmbo Judana njambwi nÉØmba kat wandÉØ.  
\v 4 Wan nyan Jisas kavle vat yiga yetÉØla nyan SÉØmogwiwun mala apma njÉØvwa kwuka yeta nyan kat kwo vatnyagiyangwuk waa wandÉØ. WandÉØ maa wutaa wandi. NÉØna njÉØvwa ana ndÉØ. MÉØn mÉØna njÉØvwa waa wandi maa  
\v 5 Judas wutaa sanya Godna ngaymba yaagiga kwagalalaa wup yiga yelavÉØka yilaa kwapmba yaaw tulaa mimba tulaa vasak selindÉØ. Vasak selilaa kwapmba tunda yaawmba kiyandÉØ.  
\v 6 God kat kwunatÉØga njambwi nÉØmba ngay yapmba la sanya klalaa wandi. Ndu nyan kat sÉØvak kat kwina sanya. Godna ngaymba bengmba lÉØga sanyogwi ana kÉØta kavamba taagagiyanÉØn. Wupma ana yigiyanÉØn. moses kwiya lo nÉØn kat kai wandÉØ maa ngambundi.  
\v 7 Ngambuga lÉØga kÉØta maawupmba yelavÉØka ngambulaa wan sanya kwutaa aw nyalÉØga nÉØmbana kÉØpma kat wenga kwindi. Kwilaa klandi wan kÉØpmÉØ. Kapma ngepmamba lÉØga yaiga nÉØmba kiyangjeyan waangu valaa ndi kat kumba laagagiyanÉØn waa wandi.  
\v 8 Wan kÉØpma kan mbambala tÉØna njÉØmbla kwo lÉØgandÉØ. Yelogwen ndaa la lÉØga kÉØpma walÉØnja kÉØpma.  
\v 9-10 Tamba la profet Jeremaia tamba pÉØlÉØwutnda vak kak kiyandÉØ, mbambala vÉØganÉØn. Ndi kÉØpma kwo ana klandi. Jeremaia pÉØlÉØwutnda nyaangÉØtmba klandi. Tamba kupma pÉØlÉØwutndÉØ.  
\li1 Isrelmba la nÉØmba ndÉØ kat sÉØvak kat wenga kwinja  
\li1 sanya kÉØta ndumi kiyeli tamba vÉØli kwilaa aw  
\li1 nyalÉØga kÉØpma lÉØga nÉØmba kat kwilaa wan kÉØpma  
\li1 ndina lak klandi. God wun kat wandÉØ maa wupma  
\p waa tamba pÉØlÉØwutndÉØ Jeremaia.   
\s1 PAILAT JISAS KAT WAGALANDĘ  
\p
\v 11 Jisas njambwi nyan Pailat ta kavamba laataa tÉØndi maa ndÉØ kat wagalandÉØ. MÉØn Judana king mÉØn? waa wagalandÉØ. WagalandÉØ maa Jisas wandÉØ. MÉØn ngiyambak wun kat wama.  
\v 12 God kat kwunatÉØga njambwi nÉØmbo Judana nÉØma nÉØmbo yalaa yisolaa lÉØga Jisas kat nÉØma sakwat kavle vak kat ngambuga lÉØndi. NgambulÉØnja vak kat wutaa Jisas awat ndi kat ana kulumataa wandÉØ.  
\v 13 Jisas kwundi walapman tÉØnda vak kat vÉØlaa Pailat ndÉØ kat wandÉØ. MÉØn kat kotÉØnia nyaangÉØt mÉØn ana wutÉØgamÉØn?  
\v 14 Jisas wutaa ana Pailat kat wandÉØ. Wuka kwagalalaa lÉØndÉØ. Wuka kwagala lÉØnda vak kat vÉØlaa Pailat ngÉØpaliga ndalaa lÉØndÉØ.   
\s1 JISAS KAT KWUTAA KALILAA VATNYA NGWULA WAA PAILAT WANDĘ  
\p
\v 15 Pailat wan pesto la nandinyamba kalabusmba la kÉØta nyan kat kwo ay walÉØndÉØ. Juda wan nyan kat sÉØmogwindi maa kwo wogwelaa ay walÉØndÉØ Pailat.  
\v 16 Wan njÉØmbla kavle glei nyan kalabusmba lÉØndÉØ. NdÉØna sÉØ Barabas.  
\v 17 Wan nÉØma sakwat ndu lagwa yisola lÉØndi maa Pailat laataa ndi kat wagalandÉØ. Anda nyan kat kwo ay waigowun. Ngwuk kanda kat yelavÉØka lÉØgangwuk. Wangwuk maa waigowun. Barabas kat kwo ay walu? Jisas waa Kraist walÉØnja nyan kat kwo ay walu? waa ndi kat wagalandÉØ.  
\v 18 Pailat Jisas kat kwagalavak kat yelavÉØka lÉØga ndi kat wangalandÉØ. Jisas ndÉØ kavle vat ana yindÉØ. Ndina kumbut maawupmba ndÉØ kat kai walaa kwutaa kiyandi. Ndi mandÉØp maawut anagandi yelavÉØkiya walaa ndi kat wagalandÉØ.   
\p
\v 19 Pailat jas tÉØla tÉØgÉØtmba ndaa lÉØndÉØ maa ndÉØna taagwa walÉØ maa kÉØta nyan yalaa Pailat kat mbutndÉØ. Wan yalaa lÉØndÉØ kat wutÉØna nyan ndÉØ kavle vat ana yindÉØ. Nak ngan wun smapmba vÉØwun. NdÉØ vak kai. NdÉØ kat kwagala mÉØla. Wan sÉØmak vÉØlaa wun kat kavle vat nÉØma vat yandangat nÉØma maawut yelavÉØka lÉØgowun waa walÉØ mÉØna taagwa waa Pailat kat mbutndÉØ.   
\p
\v 20 God kat kwunatÉØga njambwi nÉØmbo Judana nÉØma nÉØmbo nÉØma sakwat yisola la ndu lagwa kat wutnjangat wandi. Pailat kat awa ngwula. Barabas kat kwagalamÉØn nÉØna lak yaandÉØ. Jisas kat kwutaa vatnya mÉØla waa Pailat kat awa ngwula wandi.  
\v 21 Wandi maa Pailat laataa ndi kat wagalandÉØ. Anda nyan kat kwo ay waigowun waa andÉØ maa Barabas kat waigamÉØn wandi.  
\v 22 Wandi maa Pailat ndi kat wagalandÉØ. Jisas waa Kraist walÉØnja nyan kat angamak yigiyowun waa wagalandÉØ maa wandi. NdÉØ kat diwai krosmba kaalaa mÉØla wandi.  
\v 23 Pailat ndi kat wandÉØ. Kavle vat yinda vat wun ana vÉØga lÉØgowun. Anda kavle vatna yinda waa wandÉØ maa ndi nÉØma kwundimba kÉØselaa wandi. NdÉØ kat dewai krosmba kaala mÉØla waa kÉØselaa wandi.   
\p
\v 24 Pailat yelavÉØtndÉØ. Ndi kat waluwa vak ana wutÉØgandi. yelavÉØka walÉØnja vapmba yilapman yiweyan wun kat waleagiyandi waa yelavÉØtaa ngu awmba kalÉØtaa yisolaa vÉØga lÉØndi maa taamba ngu njangindÉØ. Njangilaa wandÉØ. Wan nyan kat tamba kwagalawun. NdÉØ kat kwutaa vatnyangweyan wuna vak ana ndÉØ. Ngwuk ngwutna vatna waa wandÉØ Pailat.  
\v 25 WandÉØ maa ndi aywaa ta nÉØmba wutaa wandi. Wama vak tamba wukanÉØn. Wovuna. NÉØna vatna. NdÉØ kat vatnyaneya nglambi nÉØna lak nÉØna nyangu lagwa nÉØna lak yaigandÉØ wandi.  
\v 26 Wandi mala Pailat wutaa barabas kat kwo ay walaa wandÉØ maa Jisas kat kwutaa viyalaa diwai krosmba kaalavat kwutaa kalindi.   
\s1 KAO YA NĘMBA KWUSĘLĘGA JISAS KATWANDI  
\p
\v 27 Pailatna mbaapmamba lÉØga soldia Jisas kat kwutaa Pailat wuleilaa njÉØvwa kwuta ofisat kalindi. WuleindÉØ maa soldia yaa yisolaa ngÉØlÉØtaa ndÉØ kat vÉØndi.  
\v 28 NdÉØna waavwi lapmiga klalaa yelogwen mbangÉØ waavwi kwindi, kwusondÉØ.  
\v 29 MangÉØ nÉØmbÉØ yamboy klalaa ndÉØna nambumba wegwuga taagalaa kaalandi. Suwa kalÉØtaa ndÉØna yaagindan taambamba taagandi, kwutaa lÉØndÉØ, kwali mamba sÉØlaa ndÉØ kat kwusÉØlÉØga wandi. MÉØn Judana king mÉØn. Apma vat tÉØgamÉØn waa ndÉØ kat kwusÉØlÉØga wandi.  
\v 30 Walaa ndÉØna mbangÉØmba ndÉØ kat sÉØpmiya sandi. Taambamba kwutaa lÉØnda suwa klalaa ndÉØna nambumba viyandi.  
\v 31 NdÉØ kat kwusÉØlÉØga kwagalalaa ndÉØ kat kwusonja yelogwen mbangÉØ waavwi lapmiga klalaa ndÉØna waavwi kwindi, kwusondÉØ. KwusondÉØ maa ndÉØ kat kwutaa diwai krosmba kaalavat kalindi.   
\s1 JISAS KAT DIWAI KROSMBA KAALANDI  
\p
\v 32 Jisas kat kaliga lÉØga ava yambÉØ yiga lÉØga kÉØta nyan Saimon ndÉØ kat ava yambÉØmba soldia vÉØndi. Sairini walÉØnja ngepmamba ya nyana. yalÉØndÉØ, ndÉØ kat vÉØlaa wandi. Kan kiwai kros klalaa mÉØna lak walalaa kali mÉØla wandi malaa klalaa walalaa kalindÉØ.  
\v 33 Yiga lÉØga Golgota walÉØnja nduwiat wokendi. Golgota walÉØnja nduwina angwa sÉØ Andagava Nambu.  
\v 34 NÉØma nguo mi mbio kÉØta awmba salÉØtaa Jisas kat kwindi. Njangu wutaa kÉØvak kat kai wandÉØ. Ana kÉØndÉØ.  
\v 35 Soldia ndÉØ kat kwutaa kiwai krosmba taagalaa man taamba kaalandi. Kaalalaa ndÉØna waavwi klavak kat satumba kaselÉØndi.  
\v 36 Satumba kasega ngÉØlÉØlaa kwo ndaa lÉØga ndÉØ kat vÉØga lÉØndi.  
\v 37 Jisas kat kotnja nyaangÉØt lavungamba pÉØlÉØwutaa ndÉØna nambu sÉØso diwai krosmba kaalandi. Kupma pÉØlÉØwutndi. NdÉØ Jisas. Judana kinga waa pÉØlÉØwutndi.   
\p
\v 38 SÉØkwuta mbÉØt nyanogwi Jisaso kaalandi. Nat nyan kat yaagindan naangÉØmba kaalandi. Nat nyan kat ambugendan naangÉØmba kaalandi.  
\v 39 Diwai krosmba Jisas tÉØndÉØ maa yi ya la nÉØmba ndÉØ kat bÉØga nambu njingwenga kwusÉØlÉØga ndÉØ kat waga yilÉØndi.  
\v 40 Kupma kwusÉØlÉØga wandi. Godna ngay sulÉØlaa nandinya kuvupmba kwukiyowun wamÉØn. MÉØn Godna nyanat tÉØmeyan mÉØna mbangÉØ kwunap mÉØla. Godna nyanat tÉØmeyan diwai kros kwagalalaa ngaga yaa mÉØla waa kwusÉØlÉØga waga yilÉØndi.  
\v 41 God kat kwunatÉØga njambwi nÉØmbo Moses kwiya lo sÉØmogwi la nÉØmbo Judana nÉØma nÉØmbo ndino wupma kwusÉØlÉØga walÉØndi.  
\v 42 Kupma walÉØndi. Nat nÉØmba kat tak kwunatndÉØ. NdÉØ avla ndÉØ kat ana alÉØpsÉØga kwunakiyandÉØ ndÉØna mbangÉØ kat. NdÉØ Isrelna kingat tÉØndeyan ndÉØ diwai kros kwagalalaa ngaga yaigandÉØ. Diwai kros kwagalaa ngaga yandeyan ndÉØ kat vÉØlaa waiganÉØn. NdÉØ njambwi nyana waa waiganÉØn.  
\v 43 Wun Godna nyan wun. God wun kat kwunakiyandÉØ waa walÉØndÉØ. God ndÉØ kat anagandÉØ alÉØpsÉØga kwunakiya. VÉØgiyanÉØn waa kwusÉØlÉØga ndÉØ kat walÉØndi.  
\v 44 SÉØkwuta mbÉØt nyan Jisasonala mbÉØk kat diwai krosmba kaalandi. Jisas kat kwusÉØlÉØlÉØnja vla mbÉØlo kwusÉØlÉØga walÉØmbÉØt.   
\p
\v 45 NÉØma nÉØndÉØ nandinya nya kulun wandÉØ. 12 klok kulun walaa tÉØga yiga 3 lok nglaambu kembandÉØ.  
\v 46 3 klok nglaambu Jisas nÉØma kwundimba kiselaa wandÉØ. Ndina kwundimba wandÉØ. Eli, Eli, lema sabaktani. God wuna nyaek wun kat manda kat kwagalmÉØn waa wandÉØ.  
\v 47 Wumba la nÉØmba yigumba ana wutndi. Wutaa wandi. Awuk ngwula. NdÉØ Ilaija kat walÉØgandÉØ waa wandi.  
\v 48 Ndina kÉØta nyan pÉØlÉØga namÉØnÉØnga klalaa nÉØma ngumba sÉØvugundÉØ. SÉØvugulaa njÉØmbwi mbaomba ngilaa kwusoga Jisasna tÉØpmwimba taagalaa agÉØ wandÉØ. Jisas kÉØvak kat kai wandÉØ.  
\v 49 Wumba la ndina nat nÉØmba wandi. Kumba kawiga vÉØga lÉØgiyanÉØn. TÉØga lÉØga Ilaija ndÉØ kat kwunapmak yandeya vak vÉØgiyanÉØn. AnagandÉØ yaiga waa njÉØka wandi.  
\v 50 Jisas nÉØma kwundimba kÉØselaga waga kiyandÉØ.   
\p
\v 51 KiyandÉØ maa Godna ngay nÉØndÉØmba la nÉØma waavwi ngÉØlÉØtndÉØ. Angwapmba lÉØga ngÉØlÉØka ngaga yandÉØ. NÉØma yÉØnaw kwutndÉØ, nduwimba la kambak mbÉØlÉØga yindÉØ.  
\v 52 Godna mbaapmamba la tÉØga kiya nÉØmba nÉØma sakwat mat matna kÉØpma mbÉØlÉØndÉØ vasagla laatndi. Laataa lÉØndi.  
\v 53 NgÉØni Jisas laatndÉØ maa ndi Jerusalemat wuleini, nÉØma sakwat nÉØmba vÉØndi ndi kat.  
\v 54 Jisas kat bÉØga la njambwi soldagwi ndÉØna kwupmba la soldio yÉØnaw kwutÉØndÉØ mala kiya nÉØmba laatnja vak vÉØlaa vaaka lÉØndi. Vaaka lÉØga wandi. NdÉØ Godna nyana luwa waa wandi.   
\p
\v 55 SÉØvla kavamba la ndi taagwa nÉØma sakwat yitega vÉØga lÉØndi. Tamba Jisas Galilimba lÉØga yandÉØ, ndÉØna kwupmba yandi. Yalaa ndÉØna kÉØgÉØnda kwutndi.  
\v 56 Ndina nat kÉØta lagwa Maria. Magdala walÉØnja ngepmana taagwat. Nat Maria tÉØlÉØ. LÉØ Jems Josepna nyÉØmeat. Sebedina mbÉØt nyana nyÉØme lÉØlo tÉØlÉØ.   
\s1 JISAS KIYANDĘ, WAANGUMBA TAAGANDI  
\p
\v 57 Jisas kiya nandinyana nglaambu arimatia walÉØnja ngepmamba la sanyo la nyan yandÉØ. NdÉØna sÉØ Josep. NdÉØ Jisasna mbaapmamba ta nyana.  
\v 58 NdÉØ Pailat kat yiga Jisasna sÉØm kwutaa kalivat wagalandÉØ. Kwutaa kali mÉØla waa Pailat wandÉØ maa Josep Jisasna sÉØm kwutaa kalindÉØ.  
\v 59 Josep sÉØm klalaa sawun mbangÉØ waavwi lalaa Jisasna sÉØm mbaatndÉØ.  
\v 60 Mbaataa kwutaa kaliga yiga kambapmba vanja kupi waangumb taagandÉØ. Wan waangu Josepna waangua. SÉØm taagalaa nÉØma kambak mbandÉØga dkliga waangu tegÉØlÉØndÉØ. TegÉØlÉØlaa kwagalalaa ngepma yindi.  
\v 61 Magdalamba la Mariagwi nat Mario waangu la kavamba ndaa lÉØga vÉØga lÉØmbÉØt.   
\s1 SOLDIA JISAS TA WAANGU KAT VĘGA LĘNDI  
\p
\v 62 Jisas kiyandÉØ, vaangulaa tÉØga nat nandinya God kat kwunatÉØga njambwi nÉØmbagwi Ferisio laataa yiga Pailat kat wandi.  
\v 63 Kupma wandÉØ, njambwi nyan. Wan woseka walÉØga nyan tamba wandÉØ. Kiyalaa nandinya kuvut tÉØga laakiyowun waa wandÉØ.  
\v 64 WamÉØn maa ndÉØna waangu lÉØga kava soldia yiga vÉØga lÉØgiyandi. Soldia yiga vÉØlapman yinjeyan ndÉØna mbaapmamba lÉØga nÉØmba ndÉØna sÉØm sÉØkwuta kalilaa Jisas tamba kiyalaa laatndÉØ waa woseka waigandi. Tak Jisaana mbaapma nÉØmba nÉØma sakwat kavle nyaangÉØt woseka wandi. Samat kavle vatna. NgÉØni Jisas kiyalaa laatndÉØ waa wanjeyan nÉØma kavle vatna waa Pailat kat wandi.  
\v 65 Wandi maa Pailat wandÉØ. Ngwuk soldia kat kwutaa kaliga yiga waangu lÉØga kavamba taagangwuk, vÉØga lÉØgiyandi wandÉØ. WandÉØ maa soldia kat kwutaa kalindi.  
\v 66 Kaliga yiga waangu taa kavamba taagandi, vÉØgalÉØndi. Waangu sÉØlÉØtÉØnja kambapmba njambiya taagandi, tÉØndÉØ. Kan kava ke yangweya waa taagandi. Wungi njambiya kat soldia yiga vÉØga lÉØndi.   
\c 28  
\s1 JISAS KIYALAA LĘGA LAATNDĘ  
\p
\v 1 NjÉØvwa lapman nandinya ngÉØlÉØndÉØ maa Sande ngambi Magdalana taagwa Mariagwi nat Mario Jisas taagndi ta waangu vÉØvat ngambi gleimba laataa yimbÉØt.  
\v 2 YilÉØmbÉØt maa yÉØnaw kiyandÉØ, nyÉØnangwupmba lÉØga ensel ngaga yandÉØ. Yalaa waangu tegÉØlÉØnja kambak mbandÉØga kalilaa wungi kambak tagumba ndaa lÉØndÉØ.  
\v 3 Enselna mÉØndama vlap vlap wandÉØ, kembandÉØ vÉØna vla ndÉØna mÉØndama wupma lÉØndÉØ. ndÉØna waavwi sawun mÉØna lÉØndÉØ.  
\v 4 Waangu vÉØga la Soldia ensel kat vÉØlaa ava mban plaga vaaka lÉØga yiga kÉØpmamba ndandi. ndalaa kiyalaa la nÉØmba vla lÉØndi.   
\p
\v 5 Taagwa vÉØlÉØlÉØk yambÉØt maa ensel mbÉØk kat vÉØlaa wandÉØ. Diwai krosmba kaalanja Jisas kat kwaaka vÉØvat yambÉØt. VÉØga lÉØgowun mbÉØk kat.  
\v 6 NdÉØ kumba waangumba ana lÉØgandÉØ. Tamba laataa yindÉØ. Tamba Jisas wandÉØ. Kiyalaa lÉØga ngÉØni laakiyowun wandÉØ. Wanda vapmba laatndÉØ. TÉØnda waangu yaa vÉØ mbÉØla.  
\v 7 MbÉØk kwiyatapman yiga vÉØmba vat ndÉØna mbaapmamba la nÉØmba kat yiga mbuikiyambÉØt. Kiyalaa lÉØga laataa Galiliat yindÉØ. Ngwuk ndÉØna kwupmba aymba ngwuk. yiga mbupmba ngwuk. MbÉØk kat wawa nyaangÉØt mbÉØtna maawut ke tÉØvÉØga waa wandÉØ ensel.   
\p
\v 8 WandÉØ maa waangu kwagalalaa pÉØlÉØga yimbÉØt. Vaaka yelavÉØka solat sÉØga yimbÉØt. Yiga Jisasna mbaapmamba la nÉØmba kat mbupmat yimbÉØt.  
\v 9 YilÉØmbÉØt maa Jisas ava yambÉØmba mbÉØk kat vÉØlaa wandÉØ. apma vat alÉØmba mbÉØt waa wandÉØ, wutna kwali kwali ndaa sÉØlaa ndÉØna mamba kwutaa ndÉØna sÉØ kwutaa katsoga wambÉØt.  
\v 10 Jisas mbÉØk kat wandÉØ. MbÉØk ke vapmba. Tak Galiliat yiga tÉØgowun. Wuna mbaapmamba la nÉØimba kat ambukmba mbÉØk. MpupmbÉØk, wutaa wuna kwupmba yalaa wun kat vÉØgandi waa wandÉØ Jisas.   
\s1 SOLDIA WAA NYAANGĘT  
\p
\v 11 WumbÉØt taagwa yilÉØmbÉØt maa waangu kat vÉØga la nat soldia laataa ngepmat yindi. Yiga God kat kwunatÉØga njambwi nÉØmba kat Jisas laatnda vak mbutndi.  
\v 12 Mbutndi maa God kat kwunatÉØga njambwi nÉØmbo Judana nÉØma nÉØmbo yisolaa nyaangÉØt ngambundi. NyaangÉØt ngambulaga soldia kat nÉØma sakwat sanya kwilaa wandi.  
\v 13 Ngwuk kupma ambukmba ngwuk. Ngan sÉØndu kwanÉØn maa Jisasna mbaapmamba la nÉØmba yalaa ndÉØna sÉØm sÉØkwuta kalindi waa ambukmba ngwuk nat nÉØmba kat.  
\v 14 Ngwuk kat vÉØga la njambwi nayan mbukngweya nyaangÉØt wutaa ngwuk kat kai wandeyan ndÉØ kat yiga waiganÉØn. WamÉØn maa ngwuk kat ana sÉØga viyaigandÉØ waa wandi Judana njambwi nÉØmba.  
\v 15 Soldia wutaa kwinja sanya klalaa wanja nyaangÉØtmba waa ndinyangu kat yiga mbutndi. Soldia waa nyaangÉØt wuka lÉØga apma vala wangwa waa Juda walÉØndi. Mbambala nÉØmbun wupma walÉØgandi.   
\s1 JISAS NDĘNA MBAAPMA NĘMBA KAT NJĘVWA KWINDĘ  
\p
\v 16 Tak Jisas wanda Galilimba lÉØga nduwi Jisasna mbaapmamba la tamba vÉØli kiyeli kÉØta nÉØmba wokendi.  
\v 17 Wokelaa Jisas kat vÉØlagala solat sÉØga ngu navÉØn vÉØyaa ndÉØ kat tÉØndi. NdÉØ kat nat nÉØmba vÉØlaa lÉØga Jisas ana ndÉØ waa maawupmba yelavÉØka lÉØndi.  
\v 18 Jisas ndi kat yalaa ngwaymba lÉØga wandÉØ. Nyinangwutna kwondu kÉØpmana kwondu aywaa tamba klalaa lÉØgowun.  
\v 19 Kan kwondu ngwuk kat kwiwun mala klalaa ngepma ngepma aywaa yigiyangwuk. Wuna nyaekna sÉØ waga wuna sÉØ waga wuna nyaekna waagana sÉØ waga ndi kat ngu yagugiyangwuk.  
\v 20 Ngwuk kat mbutuwun, wutaa yetÉØngwa nyaangÉØt ndi kat mbukngwuk maa kwutaa yetÉØgiyandi. Ngwuk kÉØta nda kat wana yelavÉØtapman yilÉØngweya. Ngwuk kat ana kwagalagiyowun. Ngwutnogwinala njÉØmbla njÉØmbla tÉØgiyowun. Ngwulogwi tÉØlÉØwun, kÉØpma nyinangwut ngÉØlÉØgiyandi ngÉØni la lÉØga nandinya waa wandÉØ Jisas.   