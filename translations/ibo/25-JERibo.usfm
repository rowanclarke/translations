\id JER - Biblica® Open Igbo Contemporary Bible 2020 
\h Jeremaya 
\toc1 Jeremaya 
\toc2 Jeremaya 
\toc3 Jer 
\mt1 Jeremaya 
\c 1  
\p  
\v 1 Ndị a bụ okwu Jeremaya nwa Hilkaya, bụ otu onye nʼime ndị nchụaja, nọ nʼAnatot nke dị nʼala Benjamin.  
\v 2 Onye okwu nke \nd Onyenwe anyị\nd* bịakwutere nʼafọ nke iri na atọ nʼoge ọchịchị Amọn, eze Juda bụ nwa Josaya.  
\v 3 Ozi ndị ọzọ rukwara ya ntị nʼoge Jehoiakim nwa Josaya, bụ eze Juda, ruokwa nʼọnwa nke ise nʼafọ nke iri na otu nke Zedekaya nwa Josaya, bụ eze Juda kwụsịrị, mgbe a dọkpụụrụ ndị Jerusalem nʼagha buru ha ka ha gaa biri na mba ọzọ. 
\b  
\s1 Ọkpụkpọ Jeremaya 
\p  
\v 4 Okwu \nd Onyenwe anyị\nd* bịakwutere m, na-asị, 
\q1  
\v 5 “Amaara m gị tupu a tụrụ ime gị, 
\q2 tupu a mụọ gị, edoro m gị nsọ, 
\q2 ahọpụtakwara m gị dịka onye amụma nye mba niile.” 
\p  
\v 6 Asịrị m, “Ewoo, Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd*. Lee, amaghị m ekwu okwu. Abụ m naanị nwantakịrị.” 
\p  
\v 7 Ma \nd Onyenwe anyị\nd* sịrị m, “Asịkwala ‘Abụ m naanị nwantakịrị,’ nʼihi na ị ga-agakwuru onye ọbụla m zigara gị, ị ga-ekwukwa ihe niile m nyere gị nʼiwu.  
\v 8 Atụkwala egwu nʼihi ha, nʼihi na mụ onwe nọnyere gị ịnapụta gị,” ọ bụ ihe \nd Onyenwe anyị\nd* kwupụtara. 
\p  
\v 9 Mgbe ahụ, \nd Onyenwe anyị\nd* setịpụrụ aka ya metụ m nʼọnụ, sị m, “Lee, ewerela m okwu m tinye gị nʼọnụ.  
\v 10 Lee, taa, ana m eme gị onye nlekọta mba dị iche iche na alaeze niile, ihopu na ikwada, ịla nʼiyi na ịtịkpọkwa ha, i wulite ma kụọkwa.” 
\p  
\v 11 Mgbe ahụ, okwu nke \nd Onyenwe anyị\nd* bịakwutere m, na-asị, “Jeremaya, gịnị ka ị na-ahụ?” 
\p Azara m sị, “Ana m ahụ otu alaka osisi alụmọnd.” 
\p  
\v 12 Mgbe ahụ, \nd Onyenwe anyị\nd* sịrị m, “Ị hụrụ nke ọma, nʼihi na m na-eche okwu ọnụ ịhụ m na m mezuru ha.” 
\p  
\v 13 Okwu \nd Onyenwe anyị\nd* bịakwutere m nke ugboro abụọ na-asị, “Gịnị ka ị na-ahụ?” 
\p A sịrị m, “Ana m ahụ ite mmiri ọkụ, nke na-agbọ agbọ, nke e mere ka o hulata chee ọnụ ya na ndịda.” 
\p  
\v 14 \nd Onyenwe anyị\nd* sịrị m, “Ihe egwu ga-esite nʼugwu bịakwasị ndị niile bi nʼala a.  
\v 15 Ma ugbu a, ana m akpọku ndị niile bi nʼalaeze dị nʼugwu,” otu a ka \nd Onyenwe anyị\nd* kwubiri ya. 
\q1 “Ndị eze ha ga-abịa doo ocheeze ha 
\q2 nʼọnụ ụzọ ama e si abata Jerusalem, 
\q1 imegide ogologo mgbidi nke obodo ahụ gburugburu, 
\q2 na imegidekwa obodo niile nke Juda. 
\q1  
\v 16 Aga m ekwupụta ikpe niile m megide ha, 
\q2 nʼihi ajọ omume ha niile nʼịgbakụta m azụ, 
\q1 na isure ihe nsure ọkụ na-esi isi ụtọ nye chi ndị ọzọ, 
\q2 nakwa ịkpọ isiala nye ihe ndị ahụ niile ha ji aka ha kpụọ. 
\p  
\v 17 “Bilie ọtọ, jikere onwe gị, ka ị pụọ gaa gwa ha ihe ọbụla m nyere gị nʼiwu. Atụkwala ụjọ ha, ma ọ bụghị ya, aga m emenye gị egwu nʼihu ha.  
\v 18 Nʼihi na lee, site taa gaa nʼihu emeela m gị ka ị dịrị ka obodo e wusiri ike. Ị dịkwa ka mgbidi e ji igwe kpụọ, na dịka ibo e ji ọla dị arọ kpụọ, iguzogide ala ahụ niile. Iguzogide ndị eze Juda niile, ndịisi ala Juda niile, na ndị nchụaja niile, na ndị mmadụ ọzọ.  
\v 19 Ha ga-agbalị ka ha megide gị, ma ha agaghị emeri gị. Nʼihi na mụ onwe m nọnyeere gị, aga m anapụtakwa gị.” Otu ka \nd Onyenwe anyị\nd* kwubiri ya. 
\c 2  
\s1 Izrel agbakụta Chineke azụ 
\p  
\v 1 Okwu nke \nd Onyenwe anyị\nd* bịakwutere m na-asị,  
\v 2 “Gaa, kwupụta na ntị Jerusalem, 
\b  
\p “Otu a ka \nd Onyenwe anyị\nd* kwuru, 
\q1 “ ‘Echetara m ịnụ ọkụ nʼobi nke okorobịa gị nʼoge gara aga ime ihe ga-atọ m ụtọ, 
\q2 ịhụnanya gị dịka onye a lụrụ ọhụrụ, 
\q1 echetakwara m otu unu si soro m nʼime ọzara, 
\q2 ga nʼala tọgbọrọ nʼefu nke a na-akụghị mkpụrụ. 
\q1  
\v 3 Izrel bụ ihe dị nsọ nye \nd Onyenwe anyị\nd*, 
\q2 mkpụrụ mbụ nke owuwe ihe ubi ya. 
\q1 Ndị niile ripịara ya ka a gụrụ dị ka ndị ikpe mara. 
\q2 Ihe ọjọọ dakwasịkwara ha.’ ” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwupụtara. 
\b  
\q1  
\v 4 Nụrụ okwu nke \nd Onyenwe anyị\nd* unu ụlọ Jekọb, 
\q2 na unu ndị bụ agbụrụ niile sitere nʼIzrel. 
\p  
\v 5 Ihe a ka \nd Onyenwe anyị\nd* kwuru, 
\q1 “Gịnị bụ ihe ọjọọ nna unu ha chọpụtara nʼime m, 
\q2 mere ha ji si nʼebe m nọ kpafuo, nọrọ m ebe dị anya? 
\q1 Nke mere na ha ghọrọ ndị nzuzu 
\q2 site nʼịgbaso arụsị? 
\q1  
\v 6 Ha ajụghị ‘Olee ebe \nd Onyenwe anyị\nd* ahụ nọ, 
\q2 bụ onye sitere nʼala Ijipt kpọpụta anyị, 
\q1 duuru anyị gafee ọzara tọgbọrọ nʼefu, 
\q2 nʼala ọzara na ala olulu jupụtara, 
\q1 ala nke akpịrị ịkpọ nkụ na nke oke ọchịchịrị, 
\q2 ala ebe ọ dịghị onye na-esi na ya agafee na nke mmadụ na-ebighị na ya?’ 
\q1  
\v 7 Ọ bụ m kpọbatara unu nʼala na-amị ọtụtụ mkpụrụ, 
\q2 ka unu rie ihe dị ukwuu na ihe dị mma si nʼime ya. 
\q1 Ma unu bara merụọ ala m 
\q2 unu mere ihe nketa m ka ọ ghọọ ihe arụ. 
\q1  
\v 8 Ndị nchụaja ajụghị sị, 
\q2 ‘Olee ebe \nd Onyenwe anyị\nd* nọ?’ 
\q1 Ndị ikpe ha amaghị m, 
\q2 ndị na-achị ha mehiere megide m, 
\q1 ndị amụma ha bụkwa aha Baal ka ha ji ebu amụma, 
\q2 ha gbasooro ihe na-enweghị isi. 
\b  
\q1  
\v 9 “Nʼihi ya, aga m ebulite ebubo megide unu,”\f + \fr 2:9 \ft Aga m akpọ unu ikpe.\f* 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwubiri ya. 
\q2 “M ga-ebulikwa ebubo megide ụmụ ụmụ unu. 
\q1  
\v 10 Gafee nʼọnụ mmiri Saiprọs lee anya, 
\q2 zie ozi gaa Keda ma leruo anya nke ọma, 
\q2 ma ị ga-ahụ ihe ọbụla yiri nke a. 
\q1  
\v 11 O nwerela mba gbanwere chi ndị ha na-efe? 
\q2 (Ọ bụ ezie na ha abụghị chi.) 
\q1 Ma ndị m ewerela arụsị na-enweghị isi 
\q2 gbanwere ebube ha.\f + \fr 2:11 \ft Gbanwere Chineke ha dị ebube\f* 
\q1  
\v 12 Ka ibubo nwụọ gị, gị eluigwe nʼihi nke a, 
\q2 maa jijiji, tụọkwa oke ụjọ.” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwupụtara. 
\q1  
\v 13 “Nʼihi na ndị m emeela ihe ọjọọ abụọ. 
\q1 Ha agbakụtala m azụ, 
\q2 bụ Isi iyi mmiri ndụ, 
\q1 gwuoro onwe ha ebe ichebe mmiri 
\q2 nke tipuru etipu na-enweghị ike ịnagide mmiri ọbụla. 
\q1  
\v 14 Izrel ọ bụ ohu, ka ọ bụ ohu a mụrụ nʼụlọ? 
\q2 Gịnị mere o ji ghọọ ihe nlụta nʼagha? 
\q1  
\v 15 Ọdụm agbọọla ụja, 
\q2 ha ebigbọọla meekwa ka ọ nụ olu ha. 
\q1 Ha ebibiela obodo ya laa ya nʼiyi, 
\q2 suo ya ọkụ, nke mere na o nweghị onye bi na ha. 
\q1  
\v 16 Ọzọkwa, ndị ikom Memfis na Tapanhis 
\q2 a kupuola gị isi. 
\q1  
\v 17 Ọ bụghị unu onwe unu wetaara onwe unu ihe ọjọọ dị otu a 
\q2 site na ịhapụ \nd Onyenwe anyị\nd* bụ Chineke unu, 
\q2 mgbe ọ na-edu unu na-aga nʼụzọ? 
\q1  
\v 18 Ugbu a, gịnị bụ uru unu nwetara site nʼịga Ijipt 
\q2 sitekwa nʼịṅụ mmiri nke osimiri Naịl? 
\q1 Gịnị bụ uru unu nwetara site nʼịga Asịrịa, 
\q2 sitekwa nʼịṅụ mmiri si na Yufretis? 
\q1  
\v 19 Ọ bụ ajọ omume unu ga-ewetara unu ahụhụ; 
\q2 ahụhụ soo ndaghachi azụ unu bụ ihe ga-adọ unu aka na ntị. 
\q1 Tulee ma matanụ nʼonwe unu 
\q2 otu o si bụrụ ihe ọjọọ na ihe ilu nye unu 
\q1 bụ inupu isi na ịgbakụta \nd Onyenwe anyị\nd* bụ Chineke unu azụ 
\q2 na-enweghị egwu ọbụla nʼime unu banyere m,” 
\q2 nke a bụ ihe Chineke, Onye pụrụ ime ihe niile, kwupụtara. 
\b  
\q1  
\v 20 “Nʼoge gara aga, unu gbajiri yoku unu 
\q2 dọkapụ agbụ jikọtara mụ na unu, 
\q2 unu sịrị, ‘Agaghị m ejere gị ozi.’ 
\q1 Nʼezie, ọ bụ nʼelu ugwu ọbụla 
\q2 nakwa nʼokpuru osisi na-agbasa agbasa, 
\q2 ka ị na-edina dịka onye akwụna. 
\q1  
\v 21 Ma mụ onwe m kụrụ gị dịka osisi vaịnị kachasị mma 
\q2 nke mkpụrụ ya dị ndụ dịkwa mma. 
\q1 Olee otu i siri tụgharịa megide m, 
\q2 ghọọ ihe rụrụ arụ, osisi vaịnị ọhịa? 
\q1  
\v 22 Nʼagbanyeghị na iji ncha\f + \fr 2:22 \ft Ya bụ, akanwụ\f* sachaa onwe gị, 
\q2 maọbụ jirikwa ọtụtụ ntụ ncha, 
\q2 ntụpọ nke mmehie gị ka dị nʼihu m,” 
\q2 Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwupụtara. 
\q1  
\v 23 “Ị ga-esi aṅaa na-asị, ‘A bụghị m onye e merụrụ emerụ; 
\q2 o nwebeghị oge ọbụla m ji gbaso Baal?’ 
\q1 Leruo ụzọ gị anya na ndagwurugwu, 
\q2 tulee ihe ndị i mere. 
\q1 Ị bụ nne ịnyịnya ibu dị nkọ, 
\q2 na-agbagharị ebe a nʼebe nke ọzọ. 
\q1  
\v 24 Nne ịnyịnya ibu ọhịa nke mara ụzọ ya nke ọma nʼọzara, 
\q2 na-esi imi ma ọ ga-esichapụta oke ịnyịnya ibu, 
\q2 onye pụrụ igbochi ya nʼoge mmekọ ya na oke ịnyịnya zuru? 
\q1 Oke ịnyịnya ọbụla chọọrọ ya agaghị atụfu oge nʼịchụgharị ya, 
\q2 nʼihi nʼoge ha chọrọ mmekọ, ha ga-achọta ya. 
\q1  
\v 25 Agbala ọsọ ruo mgbe ị ga-agbara ụkwụ efu, 
\q2 mgbe akpịrị ga-akpọ gị nku. 
\q1 Ma ị na-asị, ‘O nweghị uru ọ bara. 
\q2 Nʼihi na ahụrụ m chi ndị mba ọzọ nʼanya, 
\q2 aghaghị m ịgbaso ha.’ 
\b  
\q1  
\v 26 “Dịka a na-eme onye ohi ihe ihere mgbe e jidere ya, 
\q2 otu a ka a ga-eme ụlọ Izrel ihere, 
\q1 ha onwe ha, ma ndị eze ha, ma ndịisi ha, 
\q2 ndị nchụaja ha na ndị amụma ha. 
\q1  
\v 27 Ha na-asị osisi, ‘Nna m ka ị bụ,’ 
\q2 na-asịkwa nkume, ‘Ọ bụ gị mụrụ m.’ 
\q1 Ha agbakụtala m azụ, 
\q2 jụ iche m ihu. 
\q1 Ma mgbe ọbụla nsogbu bịakwasịrị ha, ha na-asị, 
\q2 ‘Bịa, zọpụta anyị.’ 
\q1  
\v 28 Olee ebe chi ndị ahụ i meere nye onwe gị nọ? 
\q2 Ka ha bịa, ma ọ bụrụ na ha nwere ike ịzọpụta gị, 
\q2 mgbe nsogbu bịakwasịrị unu. 
\q1 Nʼihi na gị, bụ Juda, nwere ọtụtụ chi 
\q2 dịka i si nwee ọtụtụ obodo. 
\b  
\q1  
\v 29 “Gịnị mere unu ji ekwu okwu ebubo megide m? 
\q2 Unu niile enupula isi megide m,” 
\q2 ka \nd Onyenwe anyị\nd* kwupụtara. 
\q1  
\v 30 “Nʼefu ka m tiri ụmụ unu ihe; 
\q2 ma nke a emeghị ka ha nabata ịdọ aka na ntị. 
\q1 Dịka ọdụm na-adọgbu anụ, 
\q2 mma agha unu eripịala ndị amụma unu. 
\p  
\v 31 “Unu ndị ọgbọ a, tuleenụ okwu nke \nd Onyenwe anyị\nd*: 
\q1 “O nweela mgbe m bụ ọzara nye ndị Izrel 
\q2 ma ọ bụkwanụ ala gbara oke ọchịchịrị? 
\q1 Gịnị mekwaranụ ndị m ji na-asị, ‘Anyị enwerela onwe anyị ịwagharị, 
\q2 anyị agaghị abịakwutekwa gị ọzọ’? 
\q1  
\v 32 Nwaagbọghọ ọ na-echefu ọla ịchọ mma ya, 
\q2 nwanyị a na-alụ ọhụrụ ọ na-echefu ngwa ịchọ mma ya? 
\q1 Ma nʼime ọtụtụ ụbọchị nke a na-apụghị ịgụta ọnụ, 
\q2 ndị m echefuola m. 
\q1  
\v 33 Lee ka unu si bụrụ ndị ọka nʼịgbaso ịhụnanya. 
\q2 Ọ bụladị ụmụ nwanyị dị njọ karịsịa nwere ike ịmụta ihe site nʼụzọ unu. 
\q1  
\v 34 Nʼuwe unu ka achọtara ọbara 
\q2 ndị ogbenye na-enweghị ihe ọjọọ ha mere, 
\q2 nʼagbanyeghị na unu ejideghị ha ka ha nʼagbaka ụzọ. 
\q1 Ma unu gara nʼihu 
\q2  
\v 35 na-asịkwa, ‘Emeghị m ihe ọjọọ, 
\q2 ọ dịghị eweso m iwe.’ 
\q1 Ma aga m ekpe unu ikpe, 
\q2 nʼihi na unu na-asị, ‘Emeghị m mmehie.’ 
\q1  
\v 36 Gịnị mere unu ji na-akpagharị 
\q2 na-agbanwe ụzọ unu ọtụtụ mgbe? 
\q1 Ijipt ga-etinye unu nʼọnọdụ ihere 
\q2 dịka ndị Asịrịa mere unu. 
\q1  
\v 37 Unu ga-ebu aka unu nʼisi 
\q2 mgbe unu si ebe ahụ na-apụ, 
\q1 nʼihi na \nd Onyenwe anyị\nd* ajụla ndị ahụ unu tụkwasịrị obi. 
\q2 Ha agaghị enyere unu aka. 
\b  
\b  
\c 3  
\q1  
\v 1 “Ọ bụrụ na nwoke agbaara nwunye ya alụkwaghị m, 
\q2 nwanyị ahụ ahapụ ya pụọ ga lụrụ nwoke ọzọ, 
\q1 di mbụ ya ahụ, o kwesiri ịlaghachi ka ọ lụọkwa ya ọzọ? 
\q2 Ọ bụ na agaghị emerụ ala ahụ nke ukwuu? 
\q1 Ma unu ebiela ndụ dịka ndị akwụna nwere ọtụtụ ndị iko, 
\q2 ọ bụ ugbu a ka unu ga-alaghachikwute m?” 
\q2 otu ka \nd Onyenwe anyị\nd* kwupụtara. 
\q1  
\v 2 “Welie anya gị abụọ ma lee ebe niile nke dị elu nke ọhịa na-adịghị nʼala a, 
\q2 olee ebe gị na ndị ikom na-edinakọbeghị nʼịkwa iko? 
\q1 Ị na-anọ nʼakụkụ ụzọ niile na-eche ndị iko,\f + \fr 3:2 \ft Ya bụ, dịka nwanyị akwụna\f* 
\q2 na-anọkwa dịka onye Arebịa\f + \fr 3:2 \ft Onye na-achịgharị anụ ụlọ\f* nʼọzara. 
\q1 Ị werela ịkwa iko gị niile 
\q2 na ihe ọjọọ gị merụọ ala a. 
\q1  
\v 3 Ọ bụ nke a mere mmiri ji kwụsị izokwara unu, 
\q2 ọbụla dị mmiri nke na-ezo nʼoge ọkọchị. 
\q1 Nʼihi na unu bụ ndị akwụna, 
\q2 ndị ihere na-adịghị eme. 
\q1  
\v 4 Ọ dịbeghị anya mgbe unu kpọrọ m, sị m, 
\q2 ‘Nna m, ị bụ enyi m kemgbe m dị na nwantakịrị. 
\q1  
\v 5 Iwe gị ọ ga-adịgide mgbe niile? 
\q2 Iwe gị dị ọkụ ọ ga-adịgide ebighị ebi?’ 
\q1 Otu a ka unu si ekwu okwu, 
\q2 ma unu nọgidesịrị ike na-eme ihe ọjọọ niile unu nwere ike ime.” 
\s1 Ekwesighị ntụkwasị obi Izrel 
\p  
\v 6 Ozi a, nke si nʼọnụ \nd Onyenwe anyị\nd* pụta, rutere m aka nʼoge eze Josaya na-achị. Lee ihe ọ gwara m. “Ị hụla ihe Izrel na-ekwesighị ntụkwasị obi na-eme? Ọ gaala nʼelu ugwu ọbụla dị elu nakwa nʼokpuru osisi ndụ ọbụla, na-akwa iko nʼebe ahụ.  
\v 7 Echere m na mgbe o mesịrị ihe ndị a niile na ọ ga-alọghachikwute m, ma ọ lọtaghị. Nwanne ya nwanyị bụ Juda, onye na-ekwesighị ntụkwasị obi hụkwara ya.  
\v 8 Enyere m Izrel na-ekwesighị ntụkwasị obi akwụkwọ alụkwaghị m, chụpụ ya nʼihi ndụ ịkwa iko ya, ma lee na nwanne ya nwanyị onye na-ekwesịkwaghị ntụkwasị obi bụ Juda atụghị egwu. Ọ gakwara nʼihu ịkwa iko.  
\v 9 Ma nke a emeghị ka ihere mee ya. O merụọla ala, ọ na-akwakwa iko site nʼife nkume na osisi.  
\v 10 Nʼagbanyeghị nke a, nwanne ya nwanyị nke na-ekwesighị ntụkwasị obi, bụ Juda ejighị obi ya lọghachikwute m, maọbụ naanị nlọghachi aghụghọ,” otu a ka \nd Onyenwe anyị\nd* kwupụtara. 
\p  
\v 11 Mgbe ahụ, \nd Onyenwe anyị\nd* sịrị m, “Izrel na-adaghachi azụ na-egosi onwe ya nʼonye ezi omume karịa Juda onye na-aghọ aghụghọ.  
\v 12 Gaa, kwusaa ozi a nʼụzọ ugwu, na-asị, 
\q1 “ ‘Lọta, gị Izrel nke na-ekwesighị ntụkwasị obi,’ otu a ka \nd Onyenwe anyị\nd* kwupụtara, 
\q2 ‘Agaghị m ewesokwa gị iwe ọzọ, 
\q1 nʼihi na abụ m onye obi ebere,’ otu a ka \nd Onyenwe anyị\nd* kwupụtara, 
\q2 ‘Agaghị m ewe iwe ruo mgbe ebighị ebi. 
\q1  
\v 13 Naanị nabata na ị bụ onye ikpe mara, 
\q2 na i nupula isi megide \nd Onyenwe anyị\nd*, bụ Chineke gị. 
\q1 Kwupụta na i werela onwe gị kesara ndị mba ọzọ dị iche iche 
\q2 nʼokpuru osisi ndụ niile, 
\q2 na ị jụkwara irubere m isi.’ ” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwupụtara. 
\p  
\v 14 “Lọghachinụ unu ndị na-ekwesighị ntụkwasị obi,” ka \nd Onyenwe anyị\nd* kwupụtara, sị, “nʼihi abụ m di unu. M ga-ahọrọ unu, otu onye site nʼotu obodo na mmadụ abụọ site nʼotu agbụrụ. M ga-akpọghachi unu Zayọn.  
\v 15 Mgbe ahụ, aga m enye unu ndị ọzụzụ atụrụ masịrị m, ndị ga-eji amamihe na nghọta duo unu.  
\v 16 Nʼụbọchị ahụ, mgbe ọnụọgụgụ unu mụbara dị ukwuu nʼala ahụ,” otu ka \nd Onyenwe anyị\nd* kwubiri ya, “ndị mmadụ agaghị asịkwa ọzọ, ‘igbe ọgbụgba ndụ nke \nd Onyenwe anyị\nd*.’ Ọ gaghị abakwa ha nʼobi maọbụ ha echeta ya; ọ gaghị adịkwa ha mkpa maọbụ emepụtakwa ọzọ.  
\v 17 Mgbe oge ahụ ruru, aha a ga-akpọ Jerusalem bụ Ocheeze \nd Onyenwe anyị\nd*. Mba niile kwa ga-ezukọta nʼebe ahụ ife m ofufe. Ha agakwaghị agbaso echiche obi ọjọọ ha.  
\v 18 Nʼụbọchị ahụ ndị Juda ga-adịnyere ndị Izrel, ha abụọ ga-ejikọta aka site nʼala ahụ dị nʼugwu bịa nʼala nke m nyere nna nna unu dịka ihe nketa.” 
\p  
\v 19 “Mụ onwe m kwuru sị, 
\q1 “ ‘Lee ka ọ ga-esi masị m imeso unu mmeso dịka unu bụ ụmụ m ndị ikom, 
\q2 nye unu ala dị mma nke ga-ewetara unu ọṅụ, 
\q2 nke bụ ihe nketa kachasị mma na mba niile.’ 
\q1 Ana m eche na unu ga-akpọ m ‘Nna’ 
\q2 ma hapụ iwezuga onwe unu site nʼịgbaso m. 
\q1  
\v 20 Ma dịka nwunye na-ekwesighị ntụkwasị obi, 
\q2 i gosila onwe gị, O Izrel na ị bụ onye a na-ekwesighị ịtụkwasị obi” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwupụtara. 
\b  
\q1  
\v 21 A na-anụ ụzụ mkpu akwa nʼelu ugwu. 
\q2 Ọ bụ ụzụ akwa ụmụ Izrel ndị na-arịọ arịrịọ 
\q1 nʼihi na ha ebiela ndụ mmehie; 
\q2 ha echefuokwala \nd Onyenwe anyị\nd* bụ Chineke ha. 
\b  
\q1  
\v 22 “Lọghachinụ, unu bụ ndị na-adaghachi azụ. 
\q2 Mụ onwe m ga-agwọ unu ndaghachi azụ unu.”\f + \fr 3:22 \ft Ga-eme unu ndị kwesiri ntụkwasị obi.\f* 
\b  
\q1 Ma unu na-aza sị, “E, anyị na-alọghachikwute gị 
\q2 nʼihi na gị onwe gị bụ \nd Onyenwe anyị\nd* Chineke anyị. 
\q1  
\v 23 Nʼezie, aghụghọ, ka mkpọtụ ofufe nke arụsị niile, 
\q2 nʼelu ugwu nta dị iche iche na nʼelu ugwu niile bụ, 
\q1 nʼezie, nʼime \nd Onyenwe anyị\nd*, bụ Chineke anyị 
\q2 ka nzọpụta Izrel dị. 
\q1  
\v 24 Ma site mgbe anyị dị na nwantakịrị, ihe ihere ahụ eripịala 
\q2 mkpụrụ sitere na ndọgbu nʼọrụ nke nna nna anyị ha 
\q1 igwe anụ ụlọ na ehi ha, 
\q2 ụmụ ha ndị ikom na ụmụ ha ndị inyom. 
\q1  
\v 25 Ka anyị dinara ala nʼihere anyị, 
\q2 ka ọnọdụ oke ihere dịrị anyị kpuchikwa anyị. 
\q1 Anyị na nna nna anyị ha 
\q2 emehiela megide \nd Onyenwe anyị\nd* Chineke anyị; 
\q1 site mgbe anyị dị na nwantakịrị ruo taa 
\q2 o nwebeghị mgbe anyị ji rube isi ime ihe \nd Onyenwe anyị\nd* Chineke anyị nyere nʼiwu.” 
\b  
\c 4  
\q1  
\v 1 “Ọ bụrụ na unu bụ Izrel, ga-alọta, ka \nd Onyenwe anyị\nd* kwubiri, 
\q2 mụ ka ị ga-alọghachikwute,” 
\q1 “Ọ bụrụ na unu ewezuga arụsị ndị ahụ rụrụ arụ site nʼihu m, 
\q2 hapụ isi ebe m nọ kpafuo, 
\q1  
\v 2 ọ bụrụkwa na unu ga-eji eziokwu, ikpe ziri ezi na ụzọ ezi omume 
\q2 ṅụọ iyi sị, ‘Dịka \nd Onyenwe anyị\nd* na-adị ndụ,’ 
\q1 mgbe ahụ mba niile ga-agọzi onwe ha site na ya 
\q2 nyakwaa isi nʼime ya.” 
\p  
\v 3 Ihe ndị a ka \nd Onyenwe anyị\nd* na-agwa ndị Juda na Jerusalem sị, 
\q1 “Kọzeenụ ala ubi unu nke unu na-akọbeghị; 
\q2 unu akụnyela mkpụrụ ubi unu nʼetiti ogwu. 
\q1  
\v 4 Bienụ onwe unu ugwu nye \nd Onyenwe anyị\nd*, 
\q2 biekwanụ mkpụrụobi unu ugwu, 
\q2 unu ndị Juda na ndị bi na Jerusalem 
\q1 ma ọ bụghị otu a, iwe m ga-abịakwasị unu dịka ọkụ, 
\q2 nʼihi ihe ọjọọ niile unu mere, 
\q2 ọ ga-ere ma ọ dịkwaghị onye ga-emenyụ ya. 
\s1 Mbibi si nʼugwu na-abịa 
\q1  
\v 5 “Kwupụta ya na Juda, kwusaa ya na Jerusalem sị, 
\q2 ‘Fụọnụ opi nʼala ahụ niile.’ 
\q1 Tienụ mkpu nʼụzọ mmadụ ga-aghọta ya. 
\q2 Gwanụ ndị Juda na Jerusalem ka ha zukọtaa 
\q2 gbaga nʼobodo ndị ahụ niile e wusiri ike. 
\q1  
\v 6 Bulie ihe i gosi ụzọ ị ga Zayọn! 
\q2 Gbaganụ zoo onwe unu. Unu atụfula oge! 
\q1 Lee na mụ onwe m na-ewebata mbibi 
\q2 na ịla nʼiyi site nʼakụkụ ugwu.” 
\b  
\q1  
\v 7 Dịka ọdụm si nʼebe o zoro onwe ya amapụta, 
\q2 ka onye a na-ebibi mba niile si abịa. 
\q1 Ọ hapụla ebe obibi ya, 
\q2 na-abịa ịla Juda nʼiyi. 
\q1 Ọ ga-etidasị obodo niile nke Juda, 
\q2 ọ dịkwaghị onye ga-ebi nʼime ha. 
\q1  
\v 8 Ya mere, yikwasịnụ onwe unu uwe mkpe; 
\q2 kwaanụ akwa, tiekwanụ mkpu akwa, 
\q1 nʼihi na ọnụma \nd Onyenwe anyị\nd* esitebeghị 
\q2 nʼebe Juda nọ wezuga onwe ya. 
\b  
\q1  
\v 9 “Nʼụbọchị ahụ,” ka \nd Onyenwe anyị\nd* kwupụtara, 
\q2 “Obi ndị eze na ndịisi ọchịchị ga-ada mba; 
\q1 ahụ ga-akpọnwụ ndị nchụaja, 
\q2 otu a kwa, ihe ga-eme ga-eju ndị amụma anya.” 
\p  
\v 10 Mgbe ahụ ekwuru m sị; “Ewoo, Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* lee na ị ghọgbuola ndị a na Jerusalem site na ị sị, ‘Unu ga-enwe udo,’ mgbe mma agha dị anyị nʼolu.” 
\p  
\v 11 Nʼoge ahụ, a ga-agwa ndị a na Jerusalem, “Ifufe dị ọkụ, nke sitere nʼebe dị elu ihe na-adịghị si nʼọzara na-efebata irute ndị m. Ma ọ bụghị ifufe maka ịfụcha, maọbụ ime ka adị ọcha,  
\v 12 ọ bụ ifufe nke dị oke ike karịa nke na-esite na mụ. Ugbu a, ana m ekwupụta okwu ikpe m megide ha.” 
\q1  
\v 13 Lee anya, ha na-abịa dịka igwe ojii. 
\q2 Ụgbọala agha ya na-abịa dịka oke ifufe, 
\q1 ịnyịnya ha niile na-agbasikwa ọsọ ike karịa ugo. 
\q2 Ahụhụ dịrị anyị, anyị abụrụla ndị e bibiri ebibi! Anyị abụrụla ndị na-aga ịla nʼiyi! 
\q1  
\v 14 Jerusalem, sachapụ mmehie dị gị nʼobi, ka a zọpụta gị. 
\q2 Ruo ole mgbe ka echiche mmehie ga-ejupụta gị obi? 
\q1  
\v 15 Otu olu na-akpọsa site na Dan, 
\q2 ọ na-akpọsa ịla nʼiyi site nʼugwu niile nke Ifrem. 
\q1  
\v 16 “Gwa mba niile otu a, ha abịala, 
\q2 kpọsaa banyere Jerusalem: 
\q1 ‘Ndị agha ga-agba gị gburugburu na-abịa site nʼala dị anya, 
\q2 na-eti mkpu agha megide obodo niile nke Juda. 
\q1  
\v 17 Ha ga-agbakwa Jerusalem gburugburu dịka ndị agha na-eche ubi a gbara ogige nche, 
\q2 nʼihi na ndị bi nʼime ya enupula isi megide m,’ ” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwubiri ya. 
\q1  
\v 18 “Ụzọ gị na omume gị niile 
\q2 buteere gị ihe ndị a. 
\q1 Nke a bụ ntaramahụhụ gị. 
\q2 Lee ka o si dị ilu! 
\q2 Lee ka o si emibanye nʼime obi.” 
\b  
\q1  
\v 19 Ihe mgbu a dị ukwuu. 
\q2 Lee na apụghị m ịnagide ya. 
\q1 Obi m o, obi m o! 
\q2 Lee ka obi m si ada m gbim gbim gbim. 
\q2 Apụghịkwa m ịnọ jụụ. 
\q1 Ana m anụ ụda opi ike, 
\q2 na-anụkwa ụzụ agha. 
\q1  
\v 20 Mbibi na-arị mbibi ibe ya elu, 
\q2 lee na a laala ala a niile nʼiyi. 
\q1 Na mberede, e bibiela ụlọ ikwu anyị niile; 
\q2 a dọkasịkwala akwa mgbochi ha niile. 
\q1  
\v 21 Ruo ole mgbe ka m ga-anọgide na-ahụ ọkọlọtọ agha ndị a a na-alụ? 
\q2 Ruo ole mgbe kwa ka m ga-anọgide na-anụ ụda opi ike? 
\b  
\q1  
\v 22 “Ndị m bụ ndị nzuzu, 
\q2 ha amaghị m. 
\q1 Ha bụ ụmụntakịrị ndị na-enweghị uche, 
\q2 ha enweghị nghọta ọbụla. 
\q1 Ha bụ ọkachamara nʼihe gbasara ajọ omume, 
\q2 ma ha amaghị otu esi eme ezi ihe ọbụla.” 
\b  
\q1  
\v 23 Elere m anya nʼụwa 
\q2 hụ na ọ bụ ihe tọgbọrọ nʼefu, 
\q1 leekwa anya na mbara eluigwe, 
\q2 ma o nweghị ìhè dị ya. 
\q1  
\v 24 Elere m anya nʼugwu ukwu, 
\q2 hụ na ha na-ama jijiji, 
\q2 leekwa anya nʼugwu nta, hụ na ha na-aṅagharị aṅagharị. 
\q1  
\v 25 Elere m anya ma ahụghị mmadụ ọbụla, 
\q2 ụmụ nnụnụ niile dị na mbara eluigwe efefusịala. 
\q1  
\v 26 Ala ọma ahụ aghọọla ọzara, 
\q2 obodo niile aghọọla mkputamkpu ebe 
\q2 nʼihu \nd Onyenwe anyị\nd*, nʼihu oke iwe ya. 
\p  
\v 27 Ihe a ka \nd Onyenwe anyị\nd* kwuru, 
\q1 “A ga-ebibi ala ahụ niile, 
\q2 ma agaghị m ebibicha ya kpamkpam. 
\q1  
\v 28 Ụwa ga-eru ụjụ, 
\q2 mbara eluigwe ga-agbakwa ọchịchịrị. 
\q1 Nʼihi na ekwuola ya, agaghị m agbanwe obi m. 
\q2 Ekpebiela m ya, agaghị m alakwa azụ nʼihe m zubere ime.” 
\b  
\q1  
\v 29 Ndị mmadụ niile ga-agbapụ ọsọ site nʼobodo ha 
\q2 mgbe ha nụrụ ụzụ ndị agha na-agba ụta nọ nʼelu ịnyịnya na-abịa nso nso. 
\q1 Ha ga-ezo onwe ha nʼọhịa; 
\q2 ndị ọzọkwa ga-agbalaga zoo onwe ha nʼugwu ukwu. 
\q1 Obodo ha niile ga-atọgbọrọkwa nʼefu, 
\q2 mgbe ndị mmadụ si nʼime ya gbapụ ọsọ nʼihi oke ihe egwu. 
\b  
\q1  
\v 30 Gịnị bụ nke a, gị onye na-enweghị olileanya? 
\q2 Gịnị mere unu ji yiri uwe uhie, 
\q2 were ọlaolu ọlaedo dị oke ọnụ yiri nʼolu? 
\q1 Gịnị mere unu ji were ihe ịchọ mma tee nʼanya unu? 
\q2 Nʼefu ka unu na-eme onwe unu ka unu dị mma. 
\q1 Ndị iko unu na-elelị unu; 
\q2 ndụ unu ka ha na-achọkwa. 
\b  
\q1  
\v 31 Ana m anụ olu iti mkpu akwa nke yiri olu akwa nwanyị ime na-eme, 
\q2 ọ dị ka ude nwanyị na-agbalị ịmụpụta nwa mbụ ya. 
\q1 Ma olu akwa m nụrụ bụ nke ada Zayọn, ebe ọ nọ na-eku ume ike ike. 
\q2 Ọ dara nʼala gbasapụ aka ya, ma na-akwa akwa na-asị, 
\q1 “Onye nwụrụ anwụ ka m bụ! 
\q2 Lee, ndụ m ka e nyere ndị ogbu mmadụ.” 
\c 5  
\s1 O nweghị onye na-eme ezi ihe 
\q1  
\v 1 “Jegharịa nʼokporoụzọ niile dị na Jerusalem, 
\q2 legharịa anya, ma mara, 
\q2 chọkwanụ gburugburu nʼama ya niile. 
\q1 Ma unu ọ ga-achọpụta otu onye, 
\q2 bụ onye na-eme ihe ziri ezi, na onye na-achọ eziokwu. 
\q2 M ga-agbagharakwa obodo a 
\q1  
\v 2 Ọ bụ ezie, na ha na-asị, ‘Dịka \nd Onyenwe anyị\nd* na-adị ndụ,’ 
\q2 ma ha ka na-aṅụ iyi nʼokwu ụgha.” 
\b  
\q1  
\v 3 \nd Onyenwe anyị\nd*, anya gị abụọ ọ bụghị eziokwu ka ọ na-achọ? 
\q2 Ị tiela ha ihe, ma o metụghị ha nʼahụ. 
\q2 I gwepịara ha, ma ha ekweghị a nabata ịdọ aka na ntị. 
\q1 Ha emeela ka ihu ha sie ike karịa nkume, 
\q2 ha ajụla ịchịgharị. 
\q1  
\v 4 Mgbe ahụ, a sịrị, “Ndị a bụ naanị ndị ogbenye 
\q2 na ndị na-enweghị uche, 
\q1 ha amaghị ihe ọbụla gbasara ụzọ \nd Onyenwe anyị\nd*, 
\q2 na iwu nke Chineke ha. 
\q1  
\v 5 Aga m ejekwuru ndị ndu, 
\q2 gwa ha okwu sị, 
\q1 nʼezie ha maara ihe gbasara ụzọ \nd Onyenwe anyị\nd*, 
\q2 marakwa iwu niile nke Chineke ha.” 
\q1 Ma ha onwe ha nʼotu obi agbajiela ịyagba ahụ, 
\q2 tijiekwa agbụ niile. 
\q1  
\v 6 Ya mere, aga m eme ka ọdụm si nʼoke ọhịa bịa lụso ha ọgụ; 
\q2 nkịta ọhịa bi nʼọzara ga-ebibi ha. 
\q1 Otu a kwa, agụ ga-abịa makpuru nso nso obodo ha 
\q2 ịdọkasị onye ọbụla si nʼime obodo ahụ na-apụta. 
\q1 Ihe ndị a ga-emezu nʼihi na nnupu isi ha adịla ukwuu, 
\q2 na nʼihi na ndaghachi azụ ha site na iso ụzọ m adịla ukwuu. 
\b  
\q1  
\v 7 “Nʼihi gịnị ka m ga-eji gbaghara unu? 
\q2 Lee na ụmụ unu ahapụla m, 
\q2 na-agbaso, ma na-eji chi ndị na-abụghị chi na-aṅụ iyi. 
\q1 Ọ bụ m gbooro ha mkpa ha, 
\q2 ma ha nọgidere na-akwa iko. 
\q2 Ha jikwa ụlọ ndị akwụna mere ebe ha na-ezukọ. 
\q1  
\v 8 Ha rijuru afọ, gbaa abụba dị ka oke ịnyịnya. 
\q2 Onye ọbụla nʼime ha kwa na-esigharị imi na-akpọku nwunye na-abụghị nke ya. 
\q1  
\v 9 Ma \nd Onyenwe anyị\nd* na-ajụ ajụjụ sị, 
\q2 m ga-ahapụ ịta ha ahụhụ nʼihi ihe ndị a niile? 
\q1 M ga-ahapụ ịbọtara mkpụrụobi m ọbọ 
\q2 megide mba dị otu a?” 
\b  
\q1  
\v 10 “Baanụ nʼime ubi vaịnị ha a gbara ogige kposaa ihe dị nʼime ya, 
\q2 ma unu emebila ya kpamkpam. 
\q1 Gbajisienụ alaka ya 
\q2 nʼihi na o nweghị oge ndị a ji bụrụ ndị nke \nd Onyenwe anyị\nd*. 
\q1  
\v 11 \nd Onyenwe anyị\nd* ekwuola ya sị, Lee, ụlọ Izrel na ụlọ Juda 
\q2 egosila na ha abụghị ndị e kwesiri ịtụkwasị obi.” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwupụtara. 
\b  
\q1  
\v 12 Ha ekwuola okwu ụgha megide \nd Onyenwe anyị\nd*. 
\q2 E, ha ekwuola sị, “O nweghị ihe Ọ ga-eme! 
\q1 Ihe ọjọọ ọbụla agaghị adakwasị anyị; 
\q2 mbibi nke ụnwụ na mma agha na-eweta agaghị erute anyị nso. 
\q1  
\v 13 Ndị amụma ndị a niile dịka ikuku, 
\q2 nke okwu nwere isi na-adịghị nʼime ha. 
\q2 Ya mere, ka ihe ahụ niile ha buru nʼamụma bịakwasị ha.” 
\p  
\v 14 Nʼihi ihe ndị a niile, ihe ndị a ka \nd Onyenwe anyị\nd* Chineke Onye pụrụ ime ihe niile kwuru, 
\q1 “Nʼihi na okwu ndị a esitela nʼọnụ ndị a pụta, 
\q2 aga m eme ka okwu m, nke si gị nʼọnụ na-apụta, ghọọ ọkụ. 
\q2 Aga m emekwa ka ndị a ghọọ nkụ ọkụ ahụ ga-erepịa. 
\q1  
\v 15 Unu bụ ndị Izrel,” otu a ka \nd Onyenwe anyị\nd* kwubiri, 
\q2 “Aga m eme ka otu mba si nʼebe dị anya bịa megide unu. 
\q1 Ọ bụ mba na-adị site na mgbe ochie, mba dị ike, 
\q2 nke unu na-adịghị anụ asụsụ ha, 
\q2 ndị unu na-adịghị aghọta okwu ha. 
\q1  
\v 16 Akpa àkụ ha dịka ili ghere oghe; 
\q2 ha niile bụkwa ndị dike nʼagha. 
\q1  
\v 17 Ha ga-eripịa ihe niile unu wetara nʼubi, ya na nri niile unu nwere. 
\q2 Ha ga-ebibi ụmụ unu ndị nwoke na ndị nwanyị. 
\q1 Ha ga-ebibi igwe ewu na atụrụ unu, na igwe ehi unu. 
\q2 Ha ga-ebibikwa osisi vaịnị na osisi fiig unu. 
\q1 Ọ bụ mma agha ha ka ha ga-eji bibie obodo unu niile e wusiri ike, 
\q2 bụ obodo ndị ahụ niile unu na-atụkwasị uche. 
\p  
\v 18 “Ma ọ bụladị na nʼụbọchị ndị ahụ,” otu a ka \nd Onyenwe anyị\nd* kwupụtara, “Agaghị m ebibicha unu kpamkpam.  
\v 19 Ọ ga-erukwa, mgbe ndị mmadụ ga-ajụ ajụjụ sị, ‘Gịnị mere \nd Onyenwe anyị\nd* Chineke anyị ji mee anyị ihe dị otu a?’ Unu ga-agwa ha sị, ‘Dịka unu si gbakụta ya azụ malite ife chi ndị mba ọzọ nʼala nke aka unu, otu a ka unu ga-esi kpọọ isiala nye ndị mba ọzọ nʼala na-abụghị nke unu.’ 
\q1  
\v 20 “Kwupụta ihe a ka ụlọ Jekọb nụrụ ya, 
\q2 kwusaa ya na Juda. 
\q1  
\v 21 Nụrụnụ ihe ndị a, unu ndị nzuzu na ndị na-enweghị uche, 
\q2 unu ndị nwere anya nke na-adịghị ahụ ụzọ, 
\q2 na unu ndị nwere ntị nke na-adịghị anụ ihe. 
\q1  
\v 22 Otu a ka \nd Onyenwe anyị\nd* kwupụtara, na-ajụ sị, 
\q2 o kwesighị ka unu tụọ m egwu?” 
\q2 “O kwesighị ka unu maa jijiji nʼihu m? 
\q1 Emeela m ka uzuzu bụrụ oke osimiri nwere. 
\q2 Ọ bụkwa ụkpụrụ ebighị ebi nke ọ na-enweghị ike ịgafe. 
\q1 Ebili mmiri nwere ike magharịa, ma nke a apụghị ime ka osimiri si nʼọnọdụ ya wezuga onwe ya. 
\q2 Osimiri nwere ike bigbọọ, ma ọ pụghị ịgafe oke ahụ. 
\q1  
\v 23 Ma ndị a nwere obi nke na-enupu isi, na obi nke na-adịghị ekwe ekwe. 
\q2 Ha atụgharịala wezuga onwe ha. 
\q1  
\v 24 Ha adịghị asị onwe ha, 
\q2 ‘Ka anyị tụọ egwu \nd Onyenwe anyị\nd* Chineke anyị, 
\q1 onye na-enye anyị mmiri ozuzo nʼoge ya, 
\q2 ọ bụkwa ya na-eme ka anyị na-ewebata ihe ubi anyị nʼoge ya.’ 
\q1  
\v 25 Ajọ omume unu emeela ka ihe ndị a hapụ irute unu aka. 
\q2 Mmehie unu anapụla unu ihe ọma gaara abụ nke unu. 
\b  
\q1  
\v 26 “E nwere ndị ajọ mmadụ nʼetiti ndị m, 
\q2 ndị na-edo onwe ha dịka ndị mmadụ na-esiri nnụnụ ọnya, 
\q2 dịka ndị na-esi ọnya ka ha nwude mmadụ. 
\q1  
\v 27 Dịka nkata a kpara nke nnụnụ jupụtara nʼime ya, 
\q2 ụlọ ndị dị otu a jupụtara nʼaghụghọ. 
\q1 Nʼihi nke a, ha ghọrọ ndị ọgaranya na ndị dị ike, 
\q2  
\v 28 ha amaala abụba, anụ ahụ ha na-akwọkwa mụrụmụrụ. 
\q1 Ajọ ọrụ ha enweghị nsọtụ; 
\q2 ha adịghị achọkwa ikpe ziri ezi. 
\q1 Ha adịghị ekwuchite ọnụ onye na-enweghị nna; 
\q2 ha adịghị ekwuchitekwa ọnụ ndị ogbenye ime ka ha nweta ihe ruuru ha. 
\q1  
\v 29 M ga-ahapụ ịta ha ahụhụ nʼihi ihe ndị a niile?” 
\q2 ka \nd Onyenwe anyị\nd* kwupụtara, na-ajụ. 
\q1 “M ga-ahapụ ịbọrọ onwe m ọbọ 
\q2 megide mba dị otu a? 
\b  
\q1  
\v 30 “Ihe ọjọọ nke jọbigara njọ oke 
\q2 emeela nʼala a. 
\q1  
\v 31 Lee, ndị amụma na-ebu naanị amụma ụgha, 
\q2 ndị nchụaja na-achịkwa ndị m site nʼọchịchị nke nʼaka ike, 
\q1 ma lee, ndị m hụrụ ndụ dị otu a nʼanya. 
\q2 Gịnịkwa ka unu ga-eme nʼoge ikpeazụ.” 
\c 6  
\s1 Ndị iro agbaa Jerusalem gburugburu 
\q1  
\v 1 “Gbalaganụ unu ụmụ Benjamin! 
\q2 Sitenụ na Jerusalem gbapụ! 
\q1 Gbuonụ opi ike na Tekoa! 
\q2 Bulienụ ihe ngosi elu na Bet-Hakerem! 
\q1 Nʼihi na lee, ihe ọjọọ si nʼakụkụ ugwu na-abịa, 
\q2 e, mbibi dị ukwuu na-abịa. 
\q1  
\v 2 Aga m ebibi ada Zayọn, 
\q2 onye mara ezi mma, na onye dịkwa pekepeke. 
\q1  
\v 3 Ndị na-azụ atụrụ ga-eduru igwe atụrụ bịa megide ya. 
\q2 Ha ga-ama ụlọ ikwu ha gburugburu ya. 
\q2 Onye ọbụla nʼime ha ga-elekọtazi akụkụ ala nke o ketara anya nke ọma. 
\b  
\q1  
\v 4 “Jikerenụ ibu agha megide ya! 
\q2 Bilienụ, ka anyị buso ha agha nʼehihie. 
\q1 Ma lee, anyanwụ ebidola ịda, 
\q2 onyinyo anyasị na-esetipụkwa onwe ya. 
\q1  
\v 5 Ya mere, bilienụ ka anyị buso ha agha, ọ bụladị nʼabalị! 
\q2 Ka anyị bibie ebe ha niile e wusiri ike!” 
\p  
\v 6 Ihe ndị a bụ ihe \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, kwuru, 
\q1 “Gbutusienụ osisi niile, 
\q2 wuonụ nkwasa ọgụ gburugburu Jerusalem. 
\q1 A ghaghị ịta obodo a ahụhụ, 
\q2 nʼihi na mmegbu jupụtara nʼime ya. 
\q1  
\v 7 Dịka mmiri si esite nʼolulu mmiri na-asọpụta 
\q2 otu a ka ajọ omume na-esite nʼime ya na-asọpụta. 
\q1 Ihe ike na mbibi ka a na-anụ nʼime ya; 
\q2 ọrịa ya niile na ọnya ya niile ka a na-eche nʼihu m oge niile. 
\q1  
\v 8 Nabata ịdọ aka na ntị m, gị Jerusalem, 
\q2 ka m ghara ịgbakụta gị azụ, 
\q1 mee ka ala gị tọgbọrọ nʼefu, 
\q2 ka mmadụ ọbụla hapụkwa inwe ike ibi nʼime ya.” 
\p  
\v 9 Nke a bụ ihe \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwuru, 
\q1 “Ka ha tụtụkọtasịa ndị niile fọdụrụ nʼala Izrel nke ọma, 
\q2 dịka e si atụtụkọta mkpụrụ niile dị nʼosisi vaịnị; 
\q1 werenụ aka chọgharịa nʼalaka niile, 
\q2 dịka onye ọghọ mkpụrụ vaịnị si eme.” 
\b  
\q1  
\v 10 Ma onye kwanụ ka m nwere ike ịgwa okwu ma dọọ aka na ntị? 
\q2 Onye ga-ege ntị ịnụrụ ihe m na-ekwu? 
\q1 Ntị ha emechiela 
\q2 ruo na ha enweghị ike ịnụ ihe ọbụla. 
\q1 Okwu \nd Onyenwe anyị\nd* aghọọla ihe ha na-achọghị ịnụ ọzọ; 
\q2 nke na-adịghị ewetara ha obi ụtọ. 
\q1  
\v 11 Ma ọnụma \nd Onyenwe anyị\nd* juru m obi, 
\q2 apụghị m ịnagide ya nʼime m. 
\b  
\q1 “Wụkwasị ya nʼahụ ụmụntakịrị ndị nọ nʼokporoụzọ; 
\q2 wụkwasịkwa ya ụmụ okorobịa ebe ha zukọrọ. 
\q1 Ọ bụladị di na nwunye ga-anụrụ ụfụ ọnụma ahụ, 
\q2 ndị agadi na ndị ahụ merela nnọọ ezigbo agadi. 
\q1  
\v 12 A ga-ewere ụlọ ha nyefee nʼaka ndị ọzọ. 
\q2 A ga-ewerekwa ala ubi ha na ndị nwunye ha nye ndị ọzọ, 
\q1 \f + \fr 6:12 \ft Ee, ihe ndị a ga-emezu\f*mgbe m setịpụrụ aka m 
\q2 megide ndị ahụ bi nʼala ahụ.” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwubiri. 
\q1  
\v 13 “Nʼihi na site nʼonye ukwu ruo nʼonye dịkarịsịrị nta, 
\q2 ọ bụ naanị akpịrị uru na-ezighị ezi ka e ji mara ha. 
\q1 Ọ bụladị ndị amụma na ndị nchụaja 
\q2 na-etinyekwa aka nʼọrụ aghụghọ. 
\q1  
\v 14 Ha na-ekechi ọnya ndị m, 
\q2 dịka a ga-asị na ọ dịghị ihe ọ bụ. 
\q1 Ha na-asị, ‘Udo dị, udo dị,’ 
\q2 mgbe udo na-adịghị. 
\q1  
\v 15 O nwere ụzọ omume ha ndị a rụrụ arụ si eme ha ihere? 
\q2 Mba! Ihere adịghị eme ha ma ọlị. 
\q2 Nʼezie, ha amakwaghị ihe a na-akpọ inwe ihere! 
\q1 Nʼihi ya, ha ga-ada nʼetiti ndị dara ada. 
\q2 Ha ga-asọ ngọngọ mgbe m tara ha ahụhụ.” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwuru. 
\p  
\v 16 Ihe ndị a kwa bụ ihe \nd Onyenwe anyị\nd* kwuru, 
\q1 “Guzonụ nʼebe niile ụzọ gbara abụọ. Lee anya. 
\q2 Jụọnụ ajụjụ banyere okporoụzọ ochie ahụ. 
\q1 Jụpụtanụ ebe ụzọ ọma ahụ dị, jeenụ ije nʼime ya. 
\q2 Unu gbaso ya, unu ga-achọtara mkpụrụobi unu ebe izuike. 
\q2 Ma gịnị ka unu kwuru? Unu sịrị. ‘Anyị agaghị agbaso ụzọ ọma ahụ.’ 
\q1  
\v 17 Ahọpụtara m ndị nche doo ha ichebe unu. Agwakwara m unu okwu sị, 
\q2 ‘Ṅaanụ ntị nʼụda opi ike ha.’ 
\q2 Ma unu kwuru sị, ‘Anyị agaghị ege ntị!’ 
\q1  
\v 18 Ya mere, nụrụnụ, unu mba niile; 
\q2 lezienụ anya, unu ndị akaebe niile, 
\q2 ka unu hụrụ ihe na-aga ịbịakwasị ha. 
\q1  
\v 19 Nụrụ, gị ụwa, lee, 
\q2 ana m aga iwetara ndị a ịla nʼiyi, 
\q2 nke bụ mkpụrụ atụmatụ ọjọọ ha niile, 
\q1 nʼihi na ha jụrụ ige ntị nʼokwu m. 
\q2 Ha jụkwara ịnabatara onwe ha iwu m. 
\q1  
\v 20 Gịnị ka m ji ihe nsure ọkụ na-esi isi ụtọ nke unu si nʼobodo Sheba bubata, eme? 
\q2 Gịnị ka m ji ụda kalamus ọma unu si mba dị anya bubata eme? 
\q1 Ajụla m ịnabata aja nsure ọkụ unu niile. 
\q2 Aja niile unu na-achụ adịghị atọ m ụtọ.” 
\p  
\v 21 Ya mere, ihe ndị a bụ ihe \nd Onyenwe anyị\nd* kwuru, 
\q1 “Aga m etinye ihe ịsọ ngọngọ nʼụzọ ndị a si agafe. 
\q2 Nna na nwa ya ga-asọ ngọngọ nʼelu ya; 
\q2 otu a kwa, ndị agbataobi na enyi ha ga-ala nʼiyi.” 
\p  
\v 22 Otu a ka \nd Onyenwe anyị\nd* kwuru, 
\q1 “Lee, ndị agha si nʼala 
\q2 dị nʼebe ugwu na-abịa; 
\q1 mba dị ukwuu ka a na-akpọlitekwa 
\q2 site na nsọtụ niile nke ụwa. 
\q1  
\v 23 Ha ji ụta na ùbe, 
\q2 ha bụ ndị afọ tara mmiri, ndị na-adịghị eme obi ebere. 
\q1 Ha na-ebigbọ dịka mbigbọ nke osimiri, 
\q2 dịka ha na-anọkwasị nʼelu ịnyịnya ha. 
\q1 Ha na-abịa dịka ndị ikom e doro nʼusoro ibu agha, 
\q2 ibuso gị agha, Ada Zayọn.” 
\b  
\q1  
\v 24 Anyị anụla akụkọ banyere ude ha, 
\q2 ike agwụla aka anyị\f + \fr 6:24 \ft Ya bụ, akụdawo\f* abụọ kpamkpam. 
\q1 Oke ihe mgbu na-ejide anyị 
\q2 dị ka nke nwanyị ime na-eme. 
\q1  
\v 25 Ka onye ọbụla gharakwa ịga nʼubi, 
\q2 maọbụ ijegharị nʼokporoụzọ, 
\q1 nʼihi na ndị iro ji mma agha na-agagharị, 
\q2 egwu dịkwa nʼebe niile. 
\q1  
\v 26 Unu ndị m, yikwasịnụ onwe unu uwe mkpe. 
\q2 Tụrụọnụ onwe unu na ntụ, 
\q1 ruonụ uju, ma kwaanụ akwa, 
\q2 dịka nwanyị na-eru ụjụ nʼihi ọnwụ otu nwa nwoke ọ mụtara. 
\q1 Nʼihi na onye mbibi ahụ 
\q2 ga-abịakwasị anyị na mberede. 
\b  
\q1  
\v 27 “Emeela m gị ka ị bụrụ onye na-anwapụta ọla, 
\q2 ma ọla ahụ bụkwa ndị m. 
\q1 Achọrọ m ka i nyochaa 
\q2 ma nwapụtakwa ụzọ ha niile. 
\q1  
\v 28 Ha bụ ndị nnupu isi, ndị nwere obi nʼazụ, 
\q2 ndị na-ejegharị na-ekwutọ ibe ha. 
\q1 Ha bụ bronz na igwe; 
\q2 ọ bụkwa ndụ rụrụ arụ ka ha na-ebi. 
\q1  
\v 29 Ngwa ọrụ ọkpụ uzu na-afụnwu ọkụ ike ike, 
\q2 ime ka ọkụ rechapụ akụkụ igwe ahụ na-enweghị isi, 
\q1 ma nnụcha ahụ na-aga nʼihu abaghị uru, 
\q2 nʼihi na anụchapụghị ndị ajọ omume. 
\q1  
\v 30 Ọlaọcha a jụrụ ajụ ka akpọrọ ha, 
\q2 nʼihi na \nd Onyenwe anyị\nd* ajụla ha.” 
\c 7  
\s1 Enweghị isi nke okpukpe aghụghọ 
\p  
\v 1 Ndị a bụ okwu nke sị nʼebe \nd Onyenwe anyị\nd* nọ bịakwute Jeremaya.  
\v 2 “Guzo nʼọnụ ụzọ ama nke ụlọ \nd Onyenwe anyị\nd* kwusaa ozi a nʼebe ahụ, 
\p “ ‘Nụrụnụ okwu \nd Onyenwe anyị\nd*, unu ndị Juda niile, ndị na-esi nʼọnụ ụzọ a niile na-abata ife \nd Onyenwe anyị\nd* ofufe.  
\v 3 Ihe ndị a bụ ihe \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, bụ Chineke Izrel na-ekwu. Mezienụ ụzọ unu na omume unu niile, m ga-ekwe ka unu biri nʼebe a.  
\v 4 Unu atụkwasịla uche unu nʼokwu aghụghọ niile a na-agwa unu na-asị, “Nke a bụ ụlọnsọ ukwu \nd Onyenwe anyị\nd*, ụlọnsọ ukwu \nd Onyenwe anyị\nd*, ụlọnsọ ukwu \nd Onyenwe anyị\nd*!”  
\v 5 Ọ bụrụ na unu emee ka ụzọ unu na omume unu guzozie, ọ bụrụ na unu emesoo ibe unu mmeso nʼụzọ ikpe ziri ezi,  
\v 6 ọ bụrụ na unu ahapụ imegbu ndị ọbịa, na ndị na-enweghị nna, maọbụ nwanyị di ya nwụrụ; ọ bụrụ na unu ajụ iwufu ọbara onye aka ya dị ọcha nʼebe a, ọ bụrụkwa na unu ajụ ịgbaso chi ndị ọzọ nke na-ewetara unu nsogbu,  
\v 7 mgbe ahụ, aga m ekwere ka unu biri nʼebe a, nʼala a m nyere nna nna unu ha, ruo mgbe ebighị ebi.  
\v 8 Ma lee, ihe unu na-eme ugbu a bụ ịtụkwasị uche unu nʼokwu aghụghọ nke na-enweghị isi. 
\p  
\v 9 “ ‘Unu ga-aga nʼihu na-ezu ohi, na-egbu mmadụ ibe unu, na-akwa iko, ma na-eji chi ndị ọzọ na-aṅụ iyi? Unu ga-anọgide na-achụ aja ihe nsure ọkụ na-esi isi ụtọ nye Baal, ma na-agbaso chi ndị ọzọ unu na-amaghị?  
\v 10 Unu ga-emecha bịa guzo nʼihu m nʼụlọnsọ a, nke a kpọkwasịrị aha m, na-asị, “Anyị nọ na nchekwa,” ọ bụ ịnọ na nchekwa maka ime ihe arụ niile ndị a?  
\v 11 Ọ pụtara na ụlọ a, nke a kpọkwasịrị aha m aghọọla ogige nye ndị ohi? Ma anọkwa m ya na-ele unu anya, ka \nd Onyenwe anyị\nd* kwupụtara. 
\p  
\v 12 “ ‘Otu ọ dị, biko, Jeruonụ ebe ahụ dị na Shaịlo, ebe ahụ m buru ụzọ mee ka ọ bụrụ ebe a kpọkwasịrị aha m, ka unu chọpụta ihe m mere ya nʼihi ajọ omume ndị m, ụmụ Izrel.  
\v 13 Mgbe unu nọ na-eme ihe ndị a niile, ka \nd Onyenwe anyị\nd* kwupụtara, agwara m unu okwu mgbe mgbe, ma unu jụrụ ige ntị. Akpọrọ m unu oku, ma unu jụrụ ịza.  
\v 14 Nʼihi ya, ihe ahụ m mere na Shaịlo ka m ga-emekwa ọzọ megide ụlọ ahụ a kpọkwasịrị aha m. E, aga m eme ya megide ụlọnsọ ukwu ahụ unu na-atụkwasị obi unu nʼime ya, ụlọnsọ ukwu ahụ m nyere unu na nna nna unu ha.  
\v 15 A ga-esite nʼihu m wezuga unu, tufuo unu, dịka m wezugara ma tufukwaa ụmụnna unu, bụ ndị Ifrem.’ 
\p  
\v 16 “Ya mere, unu ekperela m ekpere nʼihi ndị a; unu atụfula oge unu ịrịọ m arịrịọ nʼihi ha. Agaghị m ege ntị nʼekpere na arịrịọ unu.  
\v 17 Ọ bụ na unu adịghị ahụ ihe na-eme nʼobodo niile nke Juda, na ihe ha na-eme nʼokporoụzọ niile nke Jerusalem?  
\v 18 Ụmụ na-achịkọta nkụ nke nna ha ji emenye ọkụ, ebe nne ha na-eghe achịcha ha na-eche nʼihu Eze nwanyị mbara Eluigwe. Ha na-awụpụrụ chi ndị ọzọ mmanya nʼihi ịkpasu m iwe.  
\v 19 Ọ bụ m ka ha na-akpasu iwe? Otu a ka \nd Onyenwe anyị\nd* kwupụtara. Ọ bụghị onwe ha ka ha na-emesi ike, ka ihe ihere mee ha? 
\p  
\v 20 “ ‘Ya mere, otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* sịrị: Iwe m na ọnụma m ka a ga-awụkwasị nʼebe a, nʼelu ndị mmadụ, na anụmanụ, na osisi dị nʼọhịa, na mkpụrụ nke ala ubi. Ọ ga-ere ọkụ ma agaghị emenyụ ya. 
\p  
\v 21 “ ‘Ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, bụ Chineke Izrel kwuru, Gaanụ nʼihu, tụkwasịnụ aja nsure ọkụ unu nʼelu aja unu ndị ọzọ niile. Riekwanụ anụ ndị a nʼonwe unu.  
\v 22 Nʼihi na mgbe m si nʼala Ijipt kpọpụta nna nna unu ha, gwa ha okwu, e nyeghị ha naanị iwu maọbụ gwa ha okwu banyere ịchụ aja nsure ọkụ na aja ndị ọzọ.  
\v 23 Ma iwu m nyere ha bụ nke a, ruberenụ m isi, aga m abụ Chineke unu, unu ga-abụkwa ndị nke m. Bienụ ndụ nʼiwu niile m nyere unu, ka ihe gaara unu nke ọma.  
\v 24 Ma ha jụrụ ige ntị, jụkwa ilezi anya ime ihe ndị ahụ m nyere nʼiwu. Kama ha gbasoro ọchịchọ ọjọọ nke obi rụrụ arụ ha. Kama ịga nʼihu, ha daghachiri azụ.  
\v 25 Site na mgbe nna nna unu ha hapụrụ ala Ijipt, esepụbeghị m aka izitere unu ndị amụma bụ ndị ohu m.  
\v 26 Ma ha jụrụ ige ntị, jụkwa ilezi anya ime ihe m nyere nʼiwu. Ha bụ ndị ntị ike, ndị nọgidere na-eme ihe ọjọọ karịrị nke nna nna ha mere.’ 
\p  
\v 27 “Mgbe ị gwara ha ihe ndị a niile, ha agaghị ege ntị. Ọ bụrụkwa na ị kpọọ ha oku ha agaghị aza.  
\v 28 Ya mere, ihe ndị a ka ị ga-agwa ha, ‘Nke a bụ mba na-enwebeghị oge ha ji rubere \nd Onyenwe anyị\nd* Chineke ha isi. O nwebekwaghị oge ọbụla ha ji nabata ịdọ aka na ntị ya. Eziokwu ọbụla adịghịkwa; okwu ọnụ ha bụ naanị ụgha ụgha. 
\p  
\v 29 “ ‘Kpụchaanụ agịrị isi unu, tufuo ya, nọọnụ nʼebe dị elu nke tọgbọrọ nʼefu bulie abụ akwa, nʼihi na \nd Onyenwe anyị\nd* esitela nʼoke ọnụma ya jụ ọgbọ a. Ọ gbakụtala ha azụ bụ ọgbọ nke a iwe ya na-adakwasị. 
\s1 Ndagwurugwu ogbugbu mmadụ 
\p  
\v 30 “ ‘\nd Onyenwe anyị\nd* kwupụtara sị, ndị Juda emeela ihe ọjọọ dị iche iche nʼihu m. Ha akpụọla arụsị rụrụ arụ nke ha tinyere nʼime ụlọnsọ ukwu ahụ a kpọkwasịrị aha m. Ha emerụọla ya.  
\v 31 Ha ewuolara onwe ha ebe ịchụ aja dị elu na Tofet, nke dị na Ndagwurugwu nke Ben Hinom. Ebe ahụ ka ha na-anọ na-esure ụmụ ha ndị ikom na ndị inyom ọkụ. Ihe dị otu a abụkwaghị ụdị ihe m nyere ha nʼiwu ka ha mee. O nwekwaghị oge ihe dị otu a batara m nʼobi.  
\v 32 Ya mere, kpacharanụ anya, nʼihi na otu a ka \nd Onyenwe anyị\nd* kwubiri, ụbọchị ndị ahụ na-abịa, mgbe ndị mmadụ na-agaghị akpọkwa ebe ahụ Tofet maọbụ Ndagwurugwu nke Ben Hinom. Kama ha ga-akpọ ya ndagwurugwu ogbugbu mmadụ, nʼihi na ha ga-eli ọtụtụ ndị ha na Tofet ruo mgbe ha na-agaghị ahụkwa ebe ha ga-eli ndị fọdụrụ.  
\v 33 Mgbe ahụ, ozu ndị mmadụ ndị a ga-aghọrọ ụmụ anụ ufe na anụ ọhịa ihe oriri. O nwekwaghị onye ga-anọ menye ha egwu chụpụ ha.  
\v 34 Mgbe ahụ, aga m eme ka ụzụ ọṅụ na obi ụtọ, na olu ndị ikom na ndị inyom na-alụ di na nwunye nʼobodo niile nke Juda, na nʼokporoụzọ Jerusalem kwụsị. Ala ahụ ga-aghọkwa ebe tọgbọrọ nʼefu. 
\c 8  
\p  
\v 1 “ ‘Otu a ka \nd Onyenwe anyị\nd* kwupụtara, nʼoge ahụ a ga-esi nʼili ha wezuga ọkpụkpụ ndị eze, na ọkpụkpụ ndịisi ọchịchị Juda, na ọkpụkpụ ndị nchụaja na ndị amụma, na ọkpụkpụ ndị niile bi na Jerusalem.  
\v 2 A ga-agbasapụ ha nye anyanwụ, na ọnwa, na kpakpando niile nke mbara eluigwe, bụ ihe ndị ahụ niile ha hụrụ nʼanya na ihe ha na-akpọ isiala nye. Bụkwa ihe ndị ahụ ha na-agbaso, nke ha na-ajụta ase site nʼaka ha, na-efekwa. A gaghị ekpokọta ọkpụkpụ ndị a niile, maọbụ lie ha nʼala. Kama ha ga-aghasara nʼala dịka unyi.  
\v 3 Nʼebe niile nke m chụsara ha, bụ ndị fọdụrụ ndụ site na mba ọjọọ a, ha ga-ahọrọ ọnwụ karịa ịdị ndụ. Otu a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwubiri.’ 
\s1 Mmehie na ahụhụ 
\p  
\v 4 “Ị ga-asịkwa ha, ‘Otu a ka \nd Onyenwe anyị\nd* kwuru: 
\q1 “ ‘Mgbe mmadụ dara ada, ọ dịghị ebili ọtọ? 
\q2 Mgbe mmadụ daghachiri azụ, ha ọ dịghị alaghachi azụ? 
\q1  
\v 5 Gịnịkwa mere ndị a ji tụgharịa site nʼịgbaso ụzọ ọjọọ ha? 
\q2 Gịnị mere Jerusalem ji nọgide na-agbaso ụzọ ọjọọ? 
\q1 Lee, ha na-ejidesi aghụghọ aka ike; 
\q2 ha jụrụ ịtụgharị. 
\q1  
\v 6 Aṅaala m ntị, 
\q2 ma anụbeghị m ka ihe ọma ọbụla si ha nʼọnụ na-apụta. 
\q1 O nweghị onye nʼime ha chegharịrị tie aka nʼobi sị, 
\q2 “Gịnị bụ ihe a m mere?” 
\q1 Kama onye ọbụla na-agbaso ụzọ nke aka ya, 
\q2 dịka ịnyịnya nke na-agbaba nʼọgbọ agha. 
\q1  
\v 7 Ọ bụladị ụgbala na-efegharị na mbara eluigwe 
\q2 maara oge ya a kara aka. 
\q1 Nduru, na eleke, na okwolo 
\q2 makwaara mgbe ha kwesiri isite nʼotu ebe obibi ha gafee nʼebe obibi ọzọ. 
\q1 Ma ndị m amaghị 
\q2 ihe \nd Onyenwe anyị\nd* chọrọ site nʼaka ha. 
\b  
\q1  
\v 8 “ ‘Unu si aṅaa kwuo, “Ndị maara ihe ka anyị bụ, 
\q2 nʼihi na iwu \nd Onyenwe anyị\nd* dị nʼaka anyị,” 
\q1 ebe ọ bụ na mkpisi akwụkwọ aghụghọ ndị ode akwụkwọ unu 
\q2 adịghị akọwa iwu ya otu o kwesiri? 
\q1  
\v 9 A ga-eme ka ihere mee ndị maara ihe; 
\q2 a ga-eme ka ụjọ jupụta ha obi, meekwa ka ha maa nʼọnya. 
\q1 Ebe ọ bụ na ha ajụla okwu \nd Onyenwe anyị\nd*, 
\q2 ọ bụ ụdị amamihe dị aṅaa ka ha nwere? 
\q1  
\v 10 Ya mere, aga m akpọnye ndị ikom ọzọ nwunye ha, 
\q2 werekwa ubi ha nyefee nʼaka ndị ọrụ ubi ọzọ. 
\q1 Nʼihi na site nʼonye ukwu ruo nʼonye dịkarịsịrị nta, 
\q2 ọ bụ naanị akpịrị uru na-ezighị ezi ka e ji mara ha. 
\q1 Ọ bụladị ndị amụma na ndị nchụaja 
\q2 na-etinyekwa aka nʼọrụ aghụghọ. 
\q1  
\v 11 Ha na-ekechi ọnya ndị m 
\q2 dịka a ga-asị na ọ dịghị ihe ọ bụ. 
\q1 Ha na-asị, “Udo dị, udo dị,” 
\q2 mgbe udo na-adịghị. 
\q1  
\v 12 Ihere o mere ha nʼihi omume arụ ha niile? 
\q2 Mba! Ihere adịghị eme ha ma ọlị; 
\q2 nʼezie, ha amakwaghị ihe a na-akpọ inwe ihere. 
\q1 Nʼihi ya, ha ga-ada nʼetiti ndị dara ada; 
\q2 ha ga-asọ ngọngọ mgbe e nyere ha ntaramahụhụ. 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwuru. 
\b  
\q1  
\v 13 “ ‘Aga m anapụ ha ihe owuwe ubi niile ha nwetara, 
\q2 otu a ka \nd Onyenwe anyị\nd* kwupụtara. 
\q2 Ha agaghị enwekwa mkpụrụ vaịnị, 
\q1 maọbụ mkpụrụ osisi fiig nʼelu osisi fiig ha. 
\q2 Akwụkwọ osisi ndị a niile ga-akpọnwụ. 
\q1 A ga-anapụkwa ha 
\q2 ihe niile m nyere ha.’ ” 
\b  
\q1  
\v 14 Gịnị ka unu na-eme nʼebe a unu nọdụrụ ala? 
\q2 Kwakọtaanụ ihe unu niile. 
\q1 Ngwa, ka anyị gbapụnụ ọsọ gaa nʼobodo ndị ahụ niile e wusiri ike 
\q2 nọdụ nʼebe ahụ nwụọ! 
\q1 Nʼihi na \nd Onyenwe anyị\nd* Chineke anyị amaala anyị ikpe ọnwụ. 
\q2 O nyela anyị mmiri e tinyere nsi ka anyị ṅụọ, 
\q2 nʼihi na anyị emehiela megide ya. 
\q1  
\v 15 Anyị lere anya udo, 
\q2 ma o nweghị ihe ọma ọbụla anyị hụrụ. 
\q1 Anyị lere anya ọgwụgwọ ọrịa anyị, 
\q2 maọbụ naanị ihe egwu ka anyị hụrụ. 
\q1  
\v 16 E sitere na Dan 
\q2 nụ ụda ịma imi ịnyịnya ndị iro. 
\q1 Ala a niile mara jijiji 
\q2 mgbe ha nụrụ akwa nke ịnyịnya ndị ahụ dị ike. 
\q1 Ha na-abịa ịla ala a na ihe niile dị nʼime ya nʼiyi. 
\q2 Ọ bụkwa otu ihe ahụ ka ha 
\q2 na-abịa ime obodo a na ndị bi nʼime ya. 
\b  
\q1  
\v 17 “Lee, ana m ezibata agwọ ọjọọ, ndị na-atagbu atagbu, nʼetiti unu. 
\q2 Ajụala nke ọ dịkwaghị ụra ga-arata ha.\f + \fr 8:17 \ft Ihe pụrụ ime na ha agaghị ata unu\f* 
\q2 Ana m ezibata ha ka ha taa unu.” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwubiri. 
\b  
\q1  
\v 18 Ọ ga-adị mma ma ọ bụrụ na m hụrụ onye ga-akasị m obi nʼime ọnọdụ iru ụjụ m, 
\q2 nʼihi na obi m na-ada mba nʼime m.\f + \fr 8:18 \ft Maọbụ, \fqa Unu ndị na-akasị m obi nʼime ọnọdụ iru ụjụ m, obi m na-ada mba nʼime m.\f* 
\q1  
\v 19 Gee ntị nụrụ akwa ndị m 
\q2 ka ọ na-ada site nʼebe dị anya. 
\q1 \nd “Onyenwe anyị\nd*, ọ sitela na Zayọn pụọ? 
\q2 Ọ pụtara na Eze ha anọkwaghị nʼebe ahụ?” 
\b  
\q1 “Gịnị mere ha ji site nʼoyiyi a tụrụ atụ, 
\q2 na arụsị ndị mba ọzọ ha na-efe kpasuo m iwe?” 
\b  
\q1  
\v 20 “Oge owuwe ihe ubi agafeela, 
\q2 leekwa na ọkọchị agabigakwala, 
\q2 ma a zọpụtabeghị anyị.” 
\b  
\q1  
\v 21 Ebe ọ bụ na a zọpịara ndị m, ọ bụkwa m ka azọpịara. 
\q2 Anam eru ụjụ, oke egwu jisikwara m aka ike. 
\q1  
\v 22 Ọ pụtara na o nweghị mmanụ otite na-eme ka ọnya laa dị na Gilead? 
\q2 Ọ bụ na e nwekwaghị dibịa nọ nʼebe ahụ? 
\q1 Gịnị mere o nweghị ọgwụgwọ dịrị ndị m 
\q2 nʼihi mmerụ ahụ ha niile? 
\c 9  
\q1  
\v 1 Ọ gaara adị m mma ma a sị na isi m bụ isi iyi, ebe mmiri si asọpụta; 
\q2 ọ gaara adị m mma ma a sịkwa na anya mmiri akwa jupụtara m nʼanya. 
\q1 Agaara m akwagide akwa ehihie na abalị 
\q2 nʼihi ndị m niile e gburu egbu. 
\q1  
\v 2 Ọ gaara adị m mma 
\q2 ma a sị na m nwere ụlọ ndị ije e wuru nʼime ọzara. 
\q1 Ka m nwee ike hapụ ndị m 
\q2 site nʼebe ha nọ pụọ. 
\q1 Nʼihi na ha niile bụ ndị na-akwa iko, 
\q2 igwe ndị na-ekwesighị ntụkwasị obi. 
\b  
\q1  
\v 3 “Ha na-ekwe ire ha dịka ụta, 
\q2 ịgbapụ okwu ụgha dịka àkụ; 
\q1 Ọ bụghị site nʼeziokwu 
\q2 ka ihe ji agara ha nke ọma nʼala ahụ. 
\q1 Ha na-esite nʼotu mmehie gaa nʼọzọ; 
\q2 ọ dịkwaghị mgbe ha ji mara m,” 
\q2 otu a ka \nd Onyenwe anyị\nd* kwupụtara. 
\q1  
\v 4 “Lezie anya, gbaara enyi gị ọsọ. 
\q2 Atụkwasịkwala nwanne gị obi. 
\q1 Nʼihi na nwanne ọbụla na-aghọ aghụghọ. 
\q2 Ndị enyi niile bụkwa ndị nkwutọ. 
\q1  
\v 5 Enyi na-aghọgbu enyi ya, 
\q2 ọ dịkwaghị onye na-agwa ibe ya eziokwu. 
\q1 Ha azụọla ire ha ikwu naanị okwu ụgha; 
\q2 ha emeekwala ka ike gwụ anụ ahụ ha ime mmehie. 
\q1  
\v 6 I bi nʼetiti aghụghọ.\f + \fr 9:6 \ft Ebe obibi gị bụ nʼetiti aghụghọ\f* 
\q2 Ha jụkwara ịmara m nʼime aghụghọ ha.” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwupụtara. 
\p  
\v 7 Ya mere, ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwuru, 
\q1 “Lee, aga m anụcha ha, nwaa ha ọnwụnwa. 
\q2 Gịnị ọzọ ka m kwesiri ime 
\q2 nʼihi mmehie ndị m? 
\q1  
\v 8 Ire ha na-egbu dịka àkụ. 
\q2 Ọ bụ naanị okwu aghụghọ si na ya apụta. 
\q1 Ha ji ọnụ ha na-agwarịta ibe ha okwu udo, 
\q2 ma nʼime obi ha, ha na-esirịtara onwe ha ọnya igbudu.” 
\q1  
\v 9 Otu a ka \nd Onyenwe anyị\nd* kwupụtara sị, 
\q2 “M ga-aghara ịta ha ahụhụ nʼihi ihe ndị a niile? 
\q1 M ga-ahapụ ịbọrọ onwe m ọbọ 
\q2 megide mba dị otu a?” 
\b  
\q1  
\v 10 Aga m anọ nʼelu ugwu ukwu kwa akwa. 
\q2 Nʼebe ahụ ka m ga-anọ kwaa ụwa m nʼihi ebe ịta nri nke anụmanụ ndị ahụ dị nʼọzara. 
\q1 Ha tọgbọrọ nʼefu. Ọ dịghị onye na-ejegharị nʼime ya. 
\q2 A naghị anụkwa olu anụ ụlọ nʼebe ahụ. 
\q1 Ụmụ nnụnụ efefusịala. 
\q2 Otu a kwa, ụmụ anụmanụ alaala. 
\b  
\q1  
\v 11 “Aga m eme ka Jerusalem ghọọ ebe a na-awụfu unyi. 
\q2 Ọ ga-aghọ ebe nkịta ọhịa na-awagharị na-achọ nri. 
\q1 Aga m ekposa obodo niile nke Juda. 
\q2 Ọ dịkwaghị onye ga-ebi na ya.” 
\p  
\v 12 Olee onye ahụ maara ihe, nke nwere ike ịghọta ihe ndị a niile? Onye ka \nd Onyenwe anyị\nd* ziri ihe ndị a, nke ga-akọwa ya? Gịnị mere e ji bibie ala a, kposaa ya, mee ka ọ tọgbọrọ nʼefu dịka ọzara mmadụ na-enweghị ike ịgafe? 
\p  
\v 13 \nd Onyenwe anyị\nd* kwuru sị, “Ọ bụ nʼihi na ha agbakụtala iwu ahụ m nyere ha idebe azụ. Ha jụrụ irubere m isi, jụkwa ịgbaso iwu m.  
\v 14 Kama, ha na-agbaso isiike nke obi ha, ha gbasoro chi Baal dịka nna nna ha si kuziere ha.”  
\v 15 Nʼihi ya, nke a bụ ihe \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, Chineke nke Izrel kwuru, “Lee, aga m eme ka ndị a rie nri na-akụ ilu. Ha ga-aṅụkwa mmiri e tinyere nsi.  
\v 16 Aga m ekposa ha na mba niile nke ụwa. Ha ga-ebi na mba nke ha na nna ha na-amaghị. Aga m eji mma agha chụọ ha ọsọ tutu ruo mgbe m bibiri ha niile.” 
\p  
\v 17 Otu a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwuru, 
\q1 “Tụgharịanụ uche unu ugbu a. Kpọọnụ ụmụ nwanyị ndị ọrụ ha bụ ịbụ abụ akwa. 
\q2 E, zienụ ozi ka ndị ọkachamara nʼetiti ha bịa. 
\q1  
\v 18 Ha bịa ngwangwa 
\q2 kwaa akwa nʼihi anyị, 
\q1 tutu anya mmiri akwa ejupụta ha nʼanya, 
\q2 tutu anya mmiri akwa esite anyị nʼanya na-asọda ruo na ntị anyị. 
\q1  
\v 19 Olu ụzụ ịkwa akwa ka a nụrụ site na Zayọn 
\q2 ‘Lee ka anyị si laa nʼiyi! 
\q2 Lee ka ihe ihere anyị si dị ukwuu! 
\q1 Nʼihi na anyị hapụrụ ala anyị, 
\q2 nʼihi na ha etikpọsịala ebe obibi anyị niile.’ ” 
\b  
\q1  
\v 20 Ugbu a, nụrụnụ okwu \nd Onyenwe anyị\nd*, unu ụmụ nwanyị, 
\q2 megheenụ ntị unu nụrụ okwu si ya nʼọnụ. 
\q1 Kuzierenụ ụmụ unu ndị inyom otu e si eti mkpu akwa, 
\q2 kuziekwaranụ ibe unu abụ akwa. 
\q1  
\v 21 Nʼihi na ọnwụ abatala nʼetiti anyị, o si na oghereikuku niile nke ụlọ anyị 
\q2 bata nʼebe niile e wusiri ike nke ala anyị. 
\q1 O gbuola ụmụntakịrị ndị na-ejegharị nʼokporoụzọ, 
\q2 gbukwaa ụmụ okorobịa ndị na-anọ nʼama. 
\p  
\v 22 Gwa ha, sị, “Otu a ka \nd Onyenwe anyị\nd* kwubiri, 
\q1 “ ‘Ozu ndị nwụrụ anwụ ga-atọgbọrọ 
\q2 dịka unyi e kpofuru nʼọhịa, 
\q1 dịka ukwu ọka nke e gbuturu nʼazụ onye na-aghọ mkpụrụ ubi, 
\q2 nke ọ dịghị onye ga-achịkọta ha.’ ” 
\p  
\v 23 Otu a ka \nd Onyenwe anyị\nd* kwuru, 
\q1 “Ka onye maara ihe hapụ ịnya isi nʼihi amamihe ya, 
\q2 ka onye dị ike ghara ịnya isi nʼihi ịdị ike ya, 
\q2 ka ọgaranya hapụkwa ịnya isi nʼihi ịba ụba nke akụ ya, 
\q1  
\v 24 kama, onye ọbụla na-anya isi, ya nyaa isi nʼihi nke a: 
\q2 na o nwere uche ịghọta na mụ onwe m bụ, 
\q1 \nd Onyenwe anyị\nd* nke na-eme obi ebere, 
\q2 na-ekpe ikpe ziri ezi na ezi omume nʼụwa. 
\q2 Nʼihi nʼihe ndị a ka m na-enwe obi ụtọ,” 
\q2 ka \nd Onyenwe anyị\nd* kwubiri. 
\p  
\v 25 “Lee, ụbọchị ahụ na-abịa,” ka \nd Onyenwe anyị\nd* kwupụtara, “mgbe m ga-ata ndị ahụ niile nke e biri ugwu naanị nʼanụ ahụ ha ahụhụ.  
\v 26 Ya bụ ndị Ijipt, Juda, Edọm, Amọn, na Moab, na ndị ahụ niile bi nʼọzara nʼebe dị anya. Nʼihi na, nʼezie, mba ndị a niile bụ ndị a na-ebighị ugwu. Ọ bụladị ụlọ Izrel niile bụ ndị a na-ebighị ugwu nʼime obi ha.” 
\c 10  
\s1 Chineke na arụsị 
\p  
\v 1 Nụrụnụ ihe \nd Onyenwe anyị\nd* na-agwa unu, ụmụ Izrel.  
\v 2 Nʼihi na otu a ka \nd Onyenwe anyị\nd* kwuru, 
\q1 “Unu amụtala ụzọ ndị mba ọzọ, 
\q2 unu atụkwala ụjọ ihe ịrịbama niile nke na-apụta ihe na mbara eluigwe, 
\q2 ọ bụ ezie na ndị mba dị iche iche na-atụ ha ụjọ. 
\q1  
\v 3 Nʼihi na omenaala ndị mmadụ ahụ abaghị uru. 
\q2 Ha na-aba nʼọhịa gbute osisi, 
\q2 nke onye ǹka osisi na-eji anyụike pịara ha ihe. 
\q1  
\v 4 Ha na-eji ọlaọcha na ọlaedo chọọ ihe ahụ a pịrị apị mma, 
\q2 jiri mkpirisi igwe na ǹtu kụọ ya ka o sie ike, 
\q2 ka ọ ghara ịda. 
\q1  
\v 5 Arụsị ha yiri osisi eguzobere nʼubi kukumba maka iji chụọ anụ ufe ọsọ, 
\q2 ha adịghị ekwu okwu. 
\q1 A na-ebugharị ha nʼaka 
\q2 nʼihi na ha adịghị eje ije. 
\q1 Unu atụla ha egwu, 
\q2 nʼihi na ha apụghị imerụ unu ahụ, 
\q2 ha enwekwaghị ike imere unu ihe ọma ọbụla.” 
\b  
\q1  
\v 6 O nweghị onye dịka gị, \nd Onyenwe anyị\nd*. 
\q2 Ị dị ukwuu. 
\q2 Aha gị dị ukwuu, na-arụpụtakwa ihe dị ike. 
\q1  
\v 7 Onye ka ọ bụ nke na-ekwesighị ịtụ gị egwu? 
\q2 Ọ bụ gị bụ eze mba niile. 
\q2 Ọ bụkwa gị ka e kwesiri ịtụ egwu. 
\q1 Nʼetiti ndị niile maara ihe na mba niile, 
\q2 na nʼalaeze niile, 
\q2 ọ dịghị onye dịka gị. 
\b  
\q1  
\v 8 Ha niile bụ ndị na-enweghị uche na ndị nzuzu. 
\q2 Ọ bụkwa arụsị osisi na-abaghị uru na-ezi ha ihe. 
\q1  
\v 9 A na-esite na Tashish bubata ọlaọcha e tipịaziri nke ọma, 
\q2 site na Ụfaz bubata ọlaedo. 
\q1 Ihe ahụ nke ọka osisi pịrị, nke ndị ọkpụ ụzụ ọlaedo chọrọ mma 
\q2 ka a na-eyikwasị uwe na-acha anụnụ anụnụ, na uwe na-acha odo odo. 
\q2 Ọ bụkwa ndị ǹka dị iche iche na-eme ha niile. 
\q1  
\v 10 Ma naanị \nd Onyenwe anyị\nd* bụ Chineke nʼezie. 
\q2 Ọ bụ Chineke dị ndụ, na Eze nke ebighị ebi. 
\q1 Mgbe iwe were ya, ụwa na-ama jijiji. 
\q2 Mba niile apụghịkwa ịnagide iwe ya dị ọkụ. 
\p  
\v 11 “Ihe ndị a ka unu ga-agwa ha, ‘Chi ndị ahụ niile a na-esiteghị nʼaka ha mee eluigwe na ụwa niile ga-ala nʼiyi. A ga-ewezuga ha site nʼụwa na nʼokpuru eluigwe niile.’ ” 
\q1  
\v 12 Ma Chineke sitere nʼike ya mee ụwa. 
\q2 Ọ tọrọ ntọala ụwa mee ka o guzosie ike site nʼamamihe ya, 
\q2 ọ jikwa nghọta ya setịpụ eluigwe niile. 
\q1  
\v 13 Mgbe o bigbọrọ, mmiri niile nke dị nʼeluigwe na-ebigbọkwa. 
\q2 Ọ na-eme ka igwe ojii site na nsọtụ niile nke ụwa kwụlie. 
\q1 Ọ na-ezipụ amụma mgbe mmiri na-ezo, 
\q2 na-esitekwa nʼụlọ nkwakọba ihe ya niile na-ewepụta ifufe. 
\b  
\q1  
\v 14 Onye ọbụla bụ onye na-enweghị uche nke ihe ọmụma kọrọ. 
\q2 Emeela ka ihere mee onye ọkpụ ụzụ ọlaedo ọbụla site nʼarụsị ọ kpụrụ. 
\q1 Nʼihi na oyiyi niile ọ na-akpụ bụ aghụghọ; 
\q2 ha enweghị nkuume ọbụla nʼime ha. 
\q1  
\v 15 Ha bụ ihe efu, na ihe ịkwa emo, 
\q2 mgbe ikpe ọmụma ha bịakwasịrị ha, ha ga-ala nʼiyi. 
\q1  
\v 16 Ma Onye ahụ bụ Oke Jekọb adịghị ka ihe ndị a, 
\q2 nʼihi na Ọ bụ ya na-eke ihe niile, 
\q1 tinyere Izrel bụ ebo nke ihe nketa ya. 
\q2 \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile bụ aha ya. 
\s1 Mbibi nke na-abịa 
\q1  
\v 17 Chịkọtaanụ ngwongwo unu niile; nọọnụ na njikere ịhapụ ala a, 
\q2 nʼihi na lee, ndị iro gbara unu gburugburu. 
\q1  
\v 18 Nʼihi na ihe ndị a ka \nd Onyenwe anyị\nd* kwuru, 
\q2 “Nʼoge a, aga m amafu 
\q2 ndị niile bi nʼala a. 
\q1 M ga-eme ka oke mkpagbu bịakwasị ha, 
\q2 meekwa ka ndị iro ha jide ha.” 
\b  
\q1  
\v 19 Ahụhụ dịịrị m nʼihi mmerụ ahụ m merụrụ. 
\q2 Ọnya dị m nʼahụ enweghị ọgwụgwọ. 
\q1 Ma ana m akasị onwe m obi na-asị, 
\q2 “Nʼezie, ọrịa a dakwasịrị m bụ ọrịa m, aga m edikwa ya.” 
\q1  
\v 20 Ebibiela ụlọ ikwu m, 
\q2 e tibisiala ụdọ ya niile. 
\q1 Ụmụ m ndị ikom esitela nʼebe m nọ pụọ, ha anọkwaghị ya. 
\q2 Ọ dịkwaghị onye fọdụrụ nke ga-enyere m aka isetipụ ụlọ ikwu m, 
\q2 maọbụ onye ga-edoziri m ebe m ga-anọ zuo ike. 
\q1  
\v 21 Nʼihi na ndị ọzụzụ atụrụ a enweghị uche. 
\q2 Ha adịghị ajụta ase site nʼaka \nd Onyenwe anyị\nd*, 
\q1 ya mere, na ihe adịghị agara ha nke ọma, 
\q2 igwe atụrụ ha niile agbasasịakwala. 
\q1  
\v 22 Gee ntị, nụrụ! Lee ozi na-abịa, 
\q2 oke ụzụ nke ọgbaaghara site nʼala dị nʼugwu, 
\q1 ime ka obodo niile nke Juda tọgbọrọ nʼefu, 
\q2 ghọọkwa ebe obibi nye nkịta ọhịa. 
\s1 Ekpere Jeremaya 
\q1  
\v 23 O \nd Onyenwe anyị\nd*, amaara m na ụzọ mmadụ adịghị nʼaka ya, 
\q2 na ọ bụghị mmadụ ka ọ dịịrị ịtụziri onwe ya ụzọ nke ọ ga-agbaso. 
\q1  
\v 24 Ya mere, \nd Onyenwe anyị\nd*, site nʼụzọ nke ikpe ziri ezi dọọ m aka na ntị, 
\q2 ma ọ bụghị site nʼiwe gị, 
\q2 ma ọ bụghị ya, ị ga-eme ka m ghọọ ihe efu. 
\q1  
\v 25 Wụkwasị ọnụma gị nʼelu mba niile dị iche iche 
\q2 bụ ndị na-amaghị gị, 
\q2 wụkwasịkwa ya ndị ahụ niile na-adịghị akpọku aha gị. 
\q1 Nʼihi na ha eripịala Jekọb, 
\q2 ha eripịala ya kpamkpam, 
\q2 bibiekwa ebe obibi ya. 
\c 11  
\s1 Edebezughị ọgbụgba ndụ 
\p  
\v 1 Nke a bụ okwu nke sị nʼebe \nd Onyenwe anyị\nd* nọ bịakwute Jeremaya,  
\v 2 “Gee ntị nʼihe niile metụtara ọgbụgba ndụ a, gwakwa ndị Juda, na ndị bi na Jerusalem.  
\v 3 Gwa ha na nke a bụ ihe \nd Onyenwe anyị\nd*, Chineke Izrel kwuru, ‘Onye a bụrụ ọnụ ka mmadụ ahụ bụ nke na-adịghị edebe ihe niile banyere ọgbụgba ndụ a,  
\v 4 bụ nke m nyere nna nna unu ha, mgbe m si nʼIjipt, site nʼoke ọkụ e ji agbaze igwe, kpọpụta ha.’ Asịrị m, Ruberenụ m isi, meekwa ihe niile m nyere unu nʼiwu, unu ga-abụ ndị m, mụ onwe m kwa ga-abụkwa Chineke unu.  
\v 5 ‘Mgbe ahụ, aga m emezu iyi ahụ m ṅụụrụ nna nna unu ha, inye ha ala mmiri ara ehi na mmanụ aṅụ na-eru na ya,’ ya bụ, ala ahụ unu bi nʼime ya taa.” 
\p Azara m sị, “Amen, \nd Onyenwe anyị\nd*.” 
\p  
\v 6 \nd Onyenwe anyị\nd* sịrị m, “Kpọsaa okwu ndị a nʼobodo Juda niile, na nʼokporoụzọ Jerusalem niile, ‘Geenụ ntị nʼiwu nke ọgbụgba ndụ ahụ, ma mezuo ihe o kwuru.  
\v 7 Site nʼoge ahụ m si nʼala Ijipt kpọpụta nna nna unu ha ruo taa, adọọla m unu aka na ntị mgbe mgbe sị, “Ruberenụ m isi.”  
\v 8 Ma ha jụrụ ige ntị. Ha akpọkwaghị okwu m mkpa dịrị ha. Kama ha jegharịrị nʼisiike nke obi ọjọọ ha. Ọ bụ nke a mere m ji mee ka ọbụbụ ọnụ niile nke ya na ọgbụgba ndụ ahụ so bịakwasị ha, dịka m buru ụzọ nye nʼiwu, ma ihe ndị a emeghị ka ha jezie ije.’ ” 
\p  
\v 9 Mgbe ahụ, \nd Onyenwe anyị\nd* gwara m sị, “Achọpụtala na-enwere njikọta na ịgba izu mmegide nʼetiti ndị Juda na ndị bi na Jerusalem.  
\v 10 Ha alaghachila azụ nʼụdị mmehie ahụ nna nna ha mehiere, bụ ndị ahụ jụrụ ige ntị nʼokwu m. Ha agbasoola chi ndị ọzọ na-efe ha. Ụlọ Izrel na ụlọ Juda adịghị edebekwa ọgbụgba ndụ ahụ mụ na nna nna ha gbara.  
\v 11 Nʼihi ya, nke a bụ ihe \nd Onyenwe anyị\nd* kwuru, ‘Aga m eme ka mbibi, nke ha na-enweghị ike ịgbanarị, bịakwasị ha. Ọ bụrụkwa na ha akpọkuo m agaghị m aṅa ntị.  
\v 12 Ndị obodo Juda na ndị bi na Jerusalem ga-apụ kpọkuo chi ndị ahụ niile ha na-achụrụ aja ihe nsure ọkụ na-esi isi ụtọ, ma chi ndị a agaghị enyere ha aka mgbe mbibi a bịakwasịrị ha.  
\v 13 Gị, bụ Juda, nwere ọtụtụ chi dị iche iche dịka obodo dị nʼime gị si dị ọtụtụ. Ebe ịchụ aja i wukwara nʼihi ịchụrụ chi ahụ na-eweta ihere bụ Baal aja ihe nsure ọkụ na-esi isi ụtọ, dịkwa ọtụtụ dịka okporoụzọ dị na Jerusalem.’ 
\p  
\v 14 “Ekperela ndị a ekpere, arịọkwala arịrịọ ọbụla nʼihi ha. Nʼihi na agaghị m ege ntị mgbe ha ga-akpọku m nʼoge ihe mgbu ha. 
\q1  
\v 15 “Gịnị ka onye m hụrụ nʼanya na-eme nʼime ụlọnsọ ukwuu m, 
\q2 mgbe ya na ọtụtụ ndị ọzọ na-ejikọta onwe ha nʼotu ịtụ atụmatụ ihe ọjọọ? 
\q2 Anụ e doro nsọ apụghị ime ka ahụhụ unu kwesiri ịnata hapụ ịbịakwasị unu. 
\q1 A sị na o si otu a dịrị, mgbe ahụ, unu pụrụ ịṅụrị ọṅụ 
\q2 mgbe unu na-eme ihe ọjọọ unu.” 
\b  
\q1  
\v 16 Aha \nd Onyenwe anyị\nd* nyere gị bụ Osisi oliv dị ndụ, 
\q2 nke na-amị mkpụrụ mara mma. 
\q1 Ma ọ bụ olu mkpọtụ nke oke mmiri ozuzo 
\q2 ka ọ ga-eji mụkwasị gị ọkụ; 
\q2 alaka gị ga-agbajisikwa. 
\m  
\v 17 \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile bụ onye ahụ kụnyere gị nʼala, e nyela iwu na mbibi ga-abịakwasị gị, nʼihi na ndị Izrel na Juda emeela ihe ọjọọ, kpasuo m iwe site nʼịchụ aja ihe nsure ọkụ na-esi isi ụtọ nye Baal. 
\s1 Nzube ọjọọ megide Jeremaya 
\p  
\v 18 Ọ bụ \nd Onyenwe anyị\nd* kpughere izuzu ọjọọ ha nye m; amatakwara m ihe ha na-ezube, nʼihi na o gosiri m ya nʼoge ahụ.  
\v 19 Mụ onwe m dị ka nwa atụrụ dị nwayọọ nke e du na-aga ebe a ga-egbu ya. Ma aghọtaghị m na ọ bụ m ka ha zubererị nzube ọjọọ megide. Ha kwuru sị, 
\q1 “Bịanụ ka anyị bibie osisi a na mkpụrụ ya. 
\q2 Ka anyị site nʼala ndị dị ndụ wezuga ya, 
\q2 ka a hapụ ichetakwa aha ya ọzọ” 
\q1  
\v 20 Ma gị, \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, ị bụ onye na-ekpe ikpe ziri ezi, 
\q2 na-anwapụtakwa obi mmadụ na mmụọ ya. 
\q1 Mee ka m hụ mgbe ị ga-abọ ọbọ megide ha, 
\q2 nʼihi na ọ bụ nʼaka gị ka m na-etinye okwu a metụtara m. 
\p  
\v 21 Ya mere, nke a ka \nd Onyenwe anyị\nd* na-ekwu banyere ndị Anatot ahụ na-achọ ịnapụ gị ndụ gị, ndị ahụ na-asị gị, “Ebukwala amụma site nʼaha \nd Onyenwe anyị\nd* ka ị ghara ịnwụ nʼaka anyị.”  
\v 22 Nʼihi nke a \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwuru, sị, “Aga m ata ha ahụhụ. Ụmụ okorobịa ha ga-anwụ site na mma agha, ụnwụ ga-egbukwa ụmụ ha ndị ikom na ndị inyom.  
\v 23 O nweghị ndị ga-afọdụ ndụ nʼime ha nʼihi na a ga-eme ka oke mbibi bịakwasị ndị Anatot nʼafọ ahụ m ga-ata ha ahụhụ.” 
\c 12  
\s1 Mkpesa Jeremaya 
\q1  
\v 1 Onye ezi omume ka ị bụ mgbe niile, gị \nd Onyenwe anyị\nd*, 
\q2 mgbe ọbụla m butere ikpe bịa nʼihu gị. 
\q1 Ma achọrọ m ịgwa gị okwu banyere ikpe ziri ezi gị: 
\q2 Gịnị mere ihe ji agara ndị ajọ omume nke ọma? 
\q2 Gịnị mere ndị na-aghọ aghụghọ ji ebi ndụ enweghị nsogbu ọbụla? 
\q1  
\v 2 Ị kụọla ha ka osisi, ha agbaala mgbọrọgwụ; 
\q2 ha na-etokwa na-amị mkpụrụ. 
\q1 Ị nọ nso mgbe niile nʼọnụ ha, 
\q2 ma ị nọ nʼebe dị anya nʼobi ha. 
\q1  
\v 3 Ma gị onwe gị maara m \nd Onyenwe anyị\nd*; 
\q2 ị na-ahụ m, na-anwapụtakwa echiche niile m na-eche banyere gị. 
\q1 Dọkpụrụ ha dịka atụrụ a ga-egbu egbu. 
\q2 Doo ha iche nye ụbọchị ahụ a ga-egbu ha. 
\q1  
\v 4 Ruo ole mgbe ka ala ga-eru ụjụ? 
\q2 Ruo ole mgbe ka ahịhịa dị nʼubi ga-anọgide na-akpọnwụ? 
\q1 Ụmụ anụmanụ na nnụnụ na-anwụchasị 
\q2 nʼihi na ndị bi nʼala ahụ bụ ndị na-emebi iwu. 
\q1 Ma ndị mmadụ ahụ na-ekwu sị, 
\q2 “Ọ gaghị ahụ ihe ga-adakwasị anyị.” 
\s1 Ọsịsa Chineke nyere 
\q1  
\v 5 “Ọ bụrụ na ndị ji ụkwụ ha agba ọsọ 
\q2 emerie gị nʼọsọ nke gị na ha gbara, 
\q2 i si aṅaa chee na gị na ndị ji ịnyịnya agba ọsọ nwere ike ịgbakọta ọsọ ịsọ mpi? 
\q1 Ọ bụrụ na ị sọọ ngọngọ nʼala ebe udo dị, 
\q2 ị ga-esi aṅaa ghara ịsọ ngọngọ nʼọhịa dị nʼakụkụ osimiri Jọdan? 
\q1  
\v 6 Lee, ọ bụladị ụmụnne gị, ndị ezinaụlọ nke aka gị, 
\q2 ararala gị nye. 
\q2 Lee, ha eweliela oke olu iti mkpu megide gị. 
\q1 Atụkwasịla ha obi, 
\q2 ọ bụladị mgbe ha na-ekwu okwu ọma banyere gị. 
\b  
\q1  
\v 7 “Aga m agbakụta ụlọ m 
\q2 na ihe nketa m họpụtara nye onwe m azụ. 
\q1 Aga m ewere onye ahụ m hụrụ nʼanya 
\q2 nyefee ya nʼaka onye iro ya. 
\q1  
\v 8 Ihe nketa m aghọrọọla m, 
\q2 ihe dịka ọdụm nọ nʼọhịa, 
\q1 Ọ na-agbọ ụja megide m; 
\q2 ya mere, m ji kpọọ ya asị. 
\q1  
\v 9 Ọ bụ na ihe nketa m aghọbeghị 
\q2 nnụnụ ugo tụrụ agwa nye m 
\q2 nke ọtụtụ ugo gbara gburugburu na-emegide ya? 
\q1 Gaanụ, kpọkọta ụmụ anụ ọhịa niile, 
\q2 mee ka ha zukọọ bịa dọrie nri. 
\q1  
\v 10 Ọtụtụ ndị ọzụzụ atụrụ ebibiela ubi vaịnị m. 
\q2 Ha azọtọọla ubi m nʼokpuru ụkwụ, 
\q1 ha emeela ka ubi m mara mma 
\q2 ghọọ ọzara tọgbọrọ nʼefu. 
\q1  
\v 11 Ha emeela ya ka ọ ghọọ ebe tọgbọrọ nʼefu; 
\q2 e, ọ ghọọla ebe kpọrọ nkụ nʼebe tọgbọrọ nʼefu nʼihu m. 
\q1 Ala ahụ niile ga-atọgbọrọkwa nʼefu, 
\q2 nʼihi na o nweghị onye ọbụla ihe banyere ya na-emetụ nʼobi. 
\q1  
\v 12 Ndị mbibi ga-ejupụta 
\q2 nʼelu ebe niile dị elu nke ọzara, 
\q1 nʼihi na mma agha \nd Onyenwe anyị\nd* 
\q2 ga-esite nʼotu nsọtụ ala ahụ ruo na nsọtụ nke ọzọ, ripịa ndị niile dị na ya. 
\q2 O nweghị onye ọbụla udo ga-adịrị nʼala ahụ. 
\q1  
\v 13 Ha ga-agha mkpụrụ ọka wiiti, maọbụ ogwu ga-epuru ha. 
\q2 Ha ga-adọgbu onwe ha nʼọrụ ma ha agaghị enweta ihe ọbụla. 
\q1 Ya mere, ka ihe ihere unu ghọtara dịka ihe ubi dịrị unu, 
\q2 nʼihi na ahụhụ ndị a sitere nʼiwe dị ọkụ nke \nd Onyenwe anyị\nd*.” 
\p  
\v 14 Ihe ndị a ka \nd Onyenwe anyị\nd* kwuru, “Ma banyere ndị agbataobi ọjọọ m ahụ niile, bụ ndị na-apụnara ndị m Izrel ihe nketa ahụ m nyere ha. Aga m esite nʼala ha hopu ha. Aga m esitekwa nʼetiti ha hopu ụlọ Juda.  
\v 15 Ma mgbe m hopuchara ha, aga m emesịa meere ha ebere, meekwa ka onye ọbụla nʼime ha laghachikwa nʼobodo nke aka ya. Ha ga-enwetakwa ihe nketa ha niile.  
\v 16 Ọ bụrụkwa na ha amụta ụzọ niile nke ndị m nke ọma, na iji aha m ṅụọ iyi, na-asị, ‘Dịka \nd Onyenwe anyị\nd* na-adị ndụ,’ dịka ha si kuziere ndị m iji aha Baal na-aṅụ iyi, aga m eme ka ha guzosie ike nʼetiti ndị m.  
\v 17 Ma ọ bụrụ na mba ọbụla ajụ ige ntị, aga m ehopu ha kpamkpam, laa ha nʼiyi.” Otu a ka \nd Onyenwe anyị\nd* kwubiri. 
\c 13  
\s1 Ihe ike nʼukwu\f + \fr 13:1 \ft Maọbụ, \fqa ihe mgbado ukwu\f* 
\p  
\v 1 Ihe ndị a ka \nd Onyenwe anyị\nd* gwara m, “Gaa, zụta mgbado ukwu akwa ọcha nke a na-eke nʼukwu. Ị zụtachaa ya, kekwasị ya nʼukwu gị. Ma ekwekwala ka o metụ na mmiri.”  
\v 2 Ejere m zụta ajị\f + \fr 13:2 \ft Ọtụtụ ndị ọgbara ọhụrụ amaghị ihe bụ ajị, kama ọ bụ nke a na-akpọ \fqa belịt, \ft maọbụ, \fqa ihe mgbado ukwu \ft ma ọ bụkwanụ, \fqa ihe okike ka ha maara\f* ahụ dịka \nd Onyenwe anyị\nd* kwuru, kee ya nʼukwu m. 
\p  
\v 3 Mgbe ahụ, okwu \nd Onyenwe anyị\nd* bịakwutere m nke ugboro abụọ, sị m,  
\v 4 “Were ajị ahụ ị zụtara, nke i kekwasịrị nʼukwu gị, bilie, jee nʼosimiri Yufretis. I ruo, zoo ihe okike ukwu ahụ na mgbawa nkume dị nʼebe ahụ.”  
\v 5 Ya mere, apụrụ m, jee, zoo ya na Yufretis dịka \nd Onyenwe anyị\nd* gwara m. 
\p  
\v 6 Mgbe ọtụtụ ụbọchị gasịrị, \nd Onyenwe anyị\nd* gwara m okwu sị m, “Bilie, jeghachi Yufretis. I jeruo, wepụta ajị ahụ m sị gị zoo nʼebe ahụ.”  
\v 7 Ya mere, agara m Yufretis, gwupụta ajị ahụ site nʼebe m zoro ya, ma mgbe m wepụtara ya, ahụrụ m na o mebiela, na ọ bakwaghị uru ọbụla. 
\p  
\v 8 Mgbe ahụ, okwu \nd Onyenwe anyị\nd* ruru m ntị, sị,  
\v 9 “Otu a ka \nd Onyenwe anyị\nd* kwuru, ‘Nʼotu aka ahụ, mụ onwe m ga-ebibi mpako Juda na oke mpako Jerusalem.  
\v 10 Ndị ajọ omume ahụ, bụ ndị jụrụ ige ntị nʼokwu m, ndị ahụ na-ejegharị nʼisiike nke obi ha na-agbaso chi ndị ọzọ na-efe ma na-akpọkwa isiala nye ha. Ha ga-adịka belịt a, nke na-abakwaghị uru ọbụla.  
\v 11 Nʼihi na dịka belịt mmadụ kere nʼukwu ya si arapara ya nʼukwu, otu a ka m si mee ka ụlọ Izrel niile, na ụlọ Juda niile rapara m nʼahụ,’ ime ka ha ghọọ ndị m, ndị a ga-esite na ha bulie aha m elu, nye m otuto na nsọpụrụ. Ma ha ajụla ige ntị.” Otu a ka \nd Onyenwe anyị\nd* kwupụtara. 
\s1 Karama mmanya akpụkpọ 
\p  
\v 12 Sị ha, “Otu a ka \nd Onyenwe anyị\nd*, Chineke Izrel kwuru: A ga-agbaju karama akpụkpọ ọbụla mmanya. Ọ bụrụ na ha sị gị, ‘Ọ bụ na anyị amaghị na a na-agbaju karama akpụkpọ ọbụla mmanya?’  
\v 13 Mgbe ahụ gwa ha, ‘Ihe ndị a ka \nd Onyenwe anyị\nd* na-ekwu, Aga m eme ka ndị bi nʼala a ṅụbiga mmanya oke, ma onye eze na-anọkwasị nʼocheeze Devid, ma ndị nchụaja, na ndị amụma niile bi na Jerusalem.  
\v 14 Aga m atụpịakwa ha, otu onye nʼelu ibe ya, nna na ụmụ ya nʼelu ibe ha kwa. Agaghị m ekwe ka obi ọmịiko, maọbụ obi ebere gbochie m ibibi ha.’ ” Otu a ka \nd Onyenwe anyị\nd* kwubiri. 
\s1 Ịdọ aka na ntị banyere ịdọta nʼagha 
\q1  
\v 15 Nụrụnụ, geekwanụ ntị, 
\q2 unu ebulila onwe unu elu, 
\q2 nʼihi na \nd Onyenwe anyị\nd* ekwuola ya. 
\q1  
\v 16 Nyenụ \nd Onyenwe anyị\nd* Chineke unu nsọpụrụ. 
\q2 Tupu o mee ka ọchịchịrị dakwasị unu; 
\q1 tupu unu akpọbie ụkwụ unu 
\q2 nʼelu ugwu gbara ọchịchịrị. 
\q1 Unu na-ele anya ìhè 
\q2 ma ọ ga-eme ka ihe ahụ ghọọrọ unu oke ọchịchịrị. 
\q2 Ọ ga-agbanwe ihe ahụ, mee ka ọ ghọọ onyinyo ọnwụ. 
\q1  
\v 17 Ma ọ bụrụ na unu ajụ ige ntị. 
\q2 Ọ bụ na nzuzo ka m ga-anọ kwaa akwa 
\q2 nʼihi mpako unu. 
\q1 Anya mmiri ga-esi m nʼanya pụta; 
\q2 anya mmiri ga-esi na ya na-eruda nke ukwuu 
\q2 nʼihi na igwe atụrụ \nd Onyenwe anyị\nd* ka a ga-adọta nʼagha. 
\b  
\q1  
\v 18 Gwanụ eze na nne eze okwu sị ha, 
\q2 “Sitenụ nʼocheeze unu rịdata, 
\q1 nʼihi na okpueze ọma unu 
\q2 ga-esi nʼisi unu dapụ.” 
\q1  
\v 19 A ga-emechi obodo niile nke Negeb. 
\q2 Ọ dịkwaghị onye ga-emeghe ha. 
\q1 A ga-adọtakwa Juda niile nʼagha 
\q2 buru ha kpamkpam buga ha nʼala ọzọ. 
\b  
\q1  
\v 20 Welienụ anya unu 
\q2 ka unu hụrụ ndị ahụ si nʼugwu na-abịa. 
\q1 Ebee ka igwe ewu na atụrụ ndị ahụ e tinyere unu nʼaka nọ, 
\q2 igwe ewu na atụrụ ahụ unu ji na-anya isi? 
\q1  
\v 21 Gịnị ka ị ga-asị mgbe \nd Onyenwe anyị\nd* mere ka ndị ahụ ị gụrụ 
\q2 dịka ndị enyi gị bịa buso gị agha? 
\q1 Ihe mgbu nke ga-abịakwasị gị 
\q2 ọ gaghị adị ka ihe mgbu na-abịakwasị nwanyị ime na-eme? 
\q1  
\v 22 Mgbe ahụ, ị ga-ajụkwa obi gị ajụjụ sị, 
\q2 “Gịnị mere ihe ndị a ji dakwasị m?” 
\q1 Ọ bụ nʼihi ịba ụba nke mmehie gị 
\q2 ka e ji dọwaa uwe mwụda gị, 
\q2 merụọ gị ahụ nʼakụkụ ahụ gị niile. 
\q1  
\v 23 Onye Kush ọ pụrụ ịgbanwe akpụkpọ ahụ ya? 
\q2 Agụ ọ pụrụ ịgbanwe akpụkpọ ahụ ya tụrụ agwa agwa? 
\q1 Nʼụzọ dị otu a kwa, 
\q2 unu ndị ihe ọjọọ riri ahụ apụghị ime ezi ihe. 
\b  
\q1  
\v 24 “Aga m efesasị unu dịka ahịhịa ọka kpọrọ nkụ, 
\q2 nke oke ifufe si nʼọzara na-ebugharị. 
\q1  
\v 25 Nke a bụ ihe unu fetara na nza, 
\q2 oke nke m kwadoro si nʼaka m inye unu.” Otu a ka \nd Onyenwe anyị\nd* kwubiri. 
\q1 “Nʼihi na unu echefuola m, 
\q2 tụkwasị obi unu na chi okwu ụgha dị iche iche. 
\q1  
\v 26 Ya mere, aga m ekpughepụ uwe i yi nʼahụ, jiri ya kpuchie gị ihu, 
\q2 si otu a gbaa gị ọtọ. Ihere ga-emekwa gị. 
\q1  
\v 27 Mgbe ahụ, ịkwa iko gị niile ga-apụta ihe ya na agụụ ihe ọjọọ niile na-agụ gị, 
\q2 na ọnọdụ enweghị ihere nke ịgba akwụna gị niile! 
\q1 Nʼihi na ahụla m omume rụrụ arụ gị niile, 
\q2 nke ị na-eme nʼelu ugwu, na nʼime ọhịa. 
\q1 Ahụhụ dịrị gị, Jerusalem! 
\q2 Ruo ole mgbe ka ị ga-anọgide nʼime adịghị ọcha gị?” 
\c 14  
\s1 Ụkọ mmiri, ụnwụ na mma agha 
\p  
\v 1 Nke a bụ okwu \nd Onyenwe anyị\nd*, nke rutere Jeremaya banyere ụkọ mmiri. 
\q1  
\v 2 “Juda na-eru ụjụ, 
\q2 ndị bi nʼobodo ya niile na-ahụjukwa anya. 
\q1 Ha na-akwa akwa nʼihi ala ahụ, 
\q2 ụda ịkwa akwa ha eruokwala Jerusalem. 
\q1  
\v 3 Ndị a na-asọpụrụ na-ezipụ ndị ohu ha ịga chọta mmiri. 
\q2 Ha na-aga nʼolulu mmiri 
\q2 ma o nweghị mmiri ha na-achọta. 
\q1 Ha bu ite nke mmiri ọbụla na-adịghị nʼime ya na-alọta. 
\q2 Ha ji aka ha kpuchie isi ha 
\q2 nʼihi ịda mba nke obi na nʼihi ọnọdụ obi ọjọọ nke ha nọ nʼime ya. 
\q1  
\v 4 Ala na-agbawa 
\q2 nʼihi enweghị mmiri ozuzo. 
\q1 Ndị ọrụ ubi na-ekpuchikwa isi ha 
\q2 nʼihi obi ọjọọ ha. 
\q1  
\v 5 Ọ bụladị nne ele, nke nọ nʼọhịa, 
\q2 na-ahapụ nwa ọhụrụ ya, 
\q2 nʼihi na ahịhịa ndụ adịghị. 
\q1  
\v 6 Ịnyịnya ibu ọhịa na-eguzokwa nʼelu ebe dị elu nke ahịhịa na-adịghị. 
\q2 Ha na-eku ume na-ekupụ ngwangwa, ngwangwa, dịka nkịta ọhịa; 
\q1 anya ha adabamiela ha nʼisi 
\q2 nʼihi ahụghị ahịhịa ndụ ha ga-ata.” 
\b  
\q1  
\v 7 Ọ bụ ezie na mmehie anyị na-agbagide anyị ama, 
\q2 \nd Onyenwe anyị\nd*, biko rụọ ọrụ gị nʼihi aha gị. 
\q1 Anyị emehiela megide gị. 
\q2 Ndaghachi azụ anyị site nʼebe ị nọ dịkwa ukwuu. 
\q1  
\v 8 Gị, onye bụ olileanya Izrel. 
\q2 Onye Nzọpụta ya nʼoge ahụhụ, 
\q1 gịnị mere i ji nọdụ dịka onye ọbịa nʼala a, 
\q2 dịka onye ije nke na-anọ naanị ọnọdụ otu abalị? 
\q1  
\v 9 Gịnị mere i ji nọdụ dịka onye ihe mere na mberede, 
\q2 dịka dike nke na-enweghị ike ịzọpụta? 
\q1 \nd Onyenwe anyị\nd*, ị nọ nʼetiti anyị; 
\q2 ọ bụkwa aha gị ka a kpọkwasịrị anyị. 
\q2 Ahapụkwala anyị! 
\p  
\v 10 Ihe ndị a bụ okwu \nd Onyenwe anyị\nd* kwuru banyere ndị a, 
\q1 “Ha hụrụ mwagharị nʼanya nke ukwuu. 
\q2 Ụkwụ ha adịghị anọkwa nʼotu ebe. 
\q1 Nʼihi nke a, ihe banyere ha adịghị atọkwa \nd Onyenwe anyị\nd* ụtọ. 
\q2 Ugbu a kwa ka ọ na-echeta ajọ omume ha, 
\q2 ọ ga-atakwa ha ahụhụ nʼihi mmehie ha.” 
\p  
\v 11 Mgbe ahụ, \nd Onyenwe anyị\nd* sịrị m, “Ekpela ekpere nʼihi ọdịmma ndị a.  
\v 12 Ọ bụ ezie na ha na-ebu ọnụ, agaghị m ege ntị nʼakwa ha; ọ bụrụkwa na ha achụọrọ m aja nsure ọkụ, maọbụ aja mkpụrụ onyinye, agaghị m anabata ha. Kama, aga m eji mma agha na ụnwụ, na ọrịa dị iche iche bibie ha.” 
\p  
\v 13 Ma asịrị m, “Ewoo, Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd*! Lee na ndị amụma na-asị ha, ‘Unu agaghị ahụ mma agha anya, maọbụ hụ ahụhụ nke ụnwụ na-eweta, nʼeziokwu, aga m enye unu udo nke na-adịgide adịgide nʼebe a.’ ” 
\p  
\v 14 Mgbe ahụ, \nd Onyenwe anyị\nd* gwara m okwu sị, “Ndị amụma ahụ na-ebu amụma ụgha nʼaha m. Ọ bụghị m họpụtara ha, ọ bụghị m gwara ha okwu, ọ bụkwaghị m ziri ha. Ọ bụ amụma ụgha ka ha na-eburu unu, amụma ụgha nke ọhụ ụgha, na nke ịgba afa, na nke na-enweghị isi, na nke si nʼobi ha nke aghụghọ jupụtara.  
\v 15 Ya mere, ihe ndị a ka \nd Onyenwe anyị\nd* kwuru banyere ndị amụma ahụ na-ebu amụma nʼaha m. Ọ bụghị m ziteere ha, ma ha nọgidere na-asị, ‘Mma agha na ụnwụ enweghị ike ịbịaru ala a nso.’ Ndị amụma a niile ka a ga-ebibi site na mma agha na ụnwụ.  
\v 16 A ga-esitekwa nʼụlọ tụpụ ndị ahụ niile ha na-eburu amụma nʼokporoụzọ Jerusalem nʼihi ụnwụ na mma agha. O nweghị onye ga-eli ha, maọbụ ndị nwunye ha, maọbụ ụmụ ha ndị ikom na ndị inyom. Nʼihi na aga m awụkwasị ha ihe ọjọọ ahụ niile ruuru ha. 
\p  
\v 17 “Gwa ha okwu ndị a, 
\q1 “ ‘Ka anya mmiri si nʼanya m na-eruda 
\q2 ehihie na abalị, na-akwụsịghị akwụsị, 
\q1 nʼihi ndị m, nʼihi ada ndị m, nke na-amaghị nwoke, 
\q2 ndị hụrụla ahụhụ dị ukwuu, 
\q2 ndị e tipụtara ọnya jọrọ njọ. 
\q1  
\v 18 Ọ bụrụ na m apụọ jee nʼime ime obodo 
\q2 ana m ahụ ndị e ji mma agha gbuo; 
\q1 Ọ bụrụ na m abata nʼobodo ukwu, 
\q2 ana m ahụ mbibi nke ụnwụ wetara. 
\q1 Ma onye amụma ma onye nchụaja 
\q2 agaala nʼala nke ha amaghị.’ ” 
\b  
\q1  
\v 19 Ị jụla Juda kpamkpam? 
\q2 Ọ pụtara na ihe banyere Zayọn adịghị atọkwa gị ụtọ? 
\q1 Gịnị mere i ji tigbuo anyị 
\q2 ruo na ọgwụgwọ adịghịkwa nye anyị? 
\q1 Anyị lere anya udo, 
\q2 ma ọ dịghị ezi ihe bịara; 
\q1 anyị lere anya ọgwụgwọ, 
\q2 ma lee, ihe anyị hụrụ bụ oke egwu. 
\q1  
\v 20 \nd Onyenwe anyị\nd*, anyị nabatara ajọ omume anyị, 
\q2 na ikpe mara nna nna anyị ha; 
\q2 nʼezie, anyị onwe anyị emehiekwala megide gị. 
\q1  
\v 21 Elelịla anyị anya, nʼihi aha gị. 
\q2 Ekwela ka ocheeze gị dị ebube bụrụ ihe a na-adịghị asọpụrụ. 
\q1 Cheta ọgbụgba ndụ nke anyị na gị gbara; 
\q2 emebikwala ya. 
\q1  
\v 22 Ọ dị chi ihe efu nke ndị mba ọzọ nwere ike ime ka mmiri zoo? 
\q2 Mbara eluigwe ọ pụrụ ime ka mmiri zoo site nʼike aka ya naanị? 
\q1 Mba! Ọ bụ gị, \nd Onyenwe anyị\nd* Chineke anyị pụrụ ime ihe ndị a. 
\q2 Nʼihi nke a, olileanya anyị dị nʼime gị, 
\q2 nʼihi na ọ bụ gị na-eme ihe ndị a niile. 
\c 15  
\p  
\v 1 Mgbe ahụ \nd Onyenwe anyị\nd* gwara m okwu sị m, “Ọ bụrụ na Mosis na Samuel apụta bịa guzo nʼihu m, ụdịdị obi m agaghị agbanwe nʼebe ndị a nọ. Chụpụ ha nʼihu m. Mee ka ha si nʼebe a pụọ.  
\v 2 Ọ bụrụ na ha ajụọ gị si, ‘Ebee ka anyị ga-aga?’ Gwa ha na ihe ndị a ka \nd Onyenwe anyị\nd* kwuru, 
\q1 “ ‘Ndị e debere nʼihi ọnwụ ga-anwụ, 
\q1 ndị e debere nʼihi mma agha ka mma agha ga-egbu; 
\q1 ndị e debere nʼihi ụnwụ ka ụnwụ ga-egbu, 
\q1 otu a kwa, ndị e debere nʼihi ịdọta nʼagha, ka a ga-adọta nʼagha buru ha gaa mba ọzọ.’ 
\p  
\v 3 “Aga m ezite ụdị mbibi anọ megide ha: mma agha nke ga-egbu ha, nkịta ga-adọkpụrụ ozu ha pụọ, ụmụ anụ ufe na ụmụ anụ ọhịa dị iche iche ga-eripịa ha, ma bibiekwa ha.” Otu a ka \nd Onyenwe anyị\nd* kwubiri.  
\v 4 Aga m eme ka ha ghọọ ihe a na-asọ oyi nʼalaeze niile nke ụwa, nʼihi ihe Manase nwa eze Hezekaya nke Juda mere na Jerusalem. 
\q1  
\v 5 “Onye ga-enwe ebere nʼahụ gị, gị Jerusalem? 
\q2 Onye ga-eru ụjụ nʼihi ihe ga-adakwasị gị? 
\q2 Onye ga-apụta guzo ịjụ ajụjụ banyere otu ihe si agara gị? 
\q1  
\v 6 Gị onwe gị ajụla m,” 
\q2 ka \nd Onyenwe anyị\nd* kwupụtara. 
\q2 “Ị nọgidela na-adaghachi azụ. 
\q1 Ya mere, aga m ebikwasị gị aka, bibie gị. 
\q2 Ike m ji akwụsị gị ka ị ghara ịdaghachi azụ agwụla m.\f + \fr 15:6 \ft Agaghị m enwekwa ọmịiko nʼebe ị nọ ọzọ\f* 
\q1  
\v 7 Aga m eji ihe e ji afụcha ọka fụchaa ha 
\q2 nʼọnụ ụzọ ama nke ala ahụ. 
\q1 Aga m eme ka mbibi bịakwasị ndị m, nke ga-eme ka ha gbara aka ụmụ, 
\q2 nʼihi na ha esitebeghị nʼụzọ ọjọọ ha chigharịa. 
\q1  
\v 8 Aga m eme ka ọnụọgụgụ ụmụ nwanyị di ha nwụrụ baa ụba. 
\q2 Ha ga-ehi nne karịa aja dị nʼọnụ oke osimiri. 
\q1 Nʼetiti ehihie ka m ga-eme ka onye mbibi 
\q2 bịakwasị ndị bụ nne ụmụ okorobịa ha; 
\q1 na mberede ka m ga-eme ka nhụju anya 
\q2 na ihe oke egwu bịakwasị ha. 
\q1  
\v 9 Nwanyị mụrụ ụmụ asaa ga-ada mba, 
\q2 kubie ume. 
\q1 Ọ ga-anwụ mgbe oge ya na-erubeghị, 
\q2 ihere ga-eme ya; ọ ga-abụkwa onye e wedara nʼala. 
\q1 Ma ndị fọdụrụ ndụ ka m ga-eme ka ha nwụọ 
\q2 site na mma agha ndị iro ha.” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwubiri. 
\b  
\q1  
\v 10 Ahụhụ dịịrị m, nne m, na ị mụrụ m, 
\q2 onye ya na ndị niile bi nʼala a na-alụ ọgụ, ma na-ese okwu. 
\q1 O nwebeghị onye m binyere ego, ọ dịkwaghị onye binyere m ego, 
\q2 ma mmadụ niile na-akọcha m. 
\p  
\v 11 \nd Onyenwe anyị\nd* kwuru sị, 
\q1 “Nʼezie, aga m anapụta gị nʼihi ezi ihe, 
\q2 aga m eme ka onye iro gị rịọ gị arịrịọ 
\q2 nʼoge ihe ọjọọ na nʼoge mkpagbu. 
\b  
\q1  
\v 12 “Mmadụ o nwere ike ịgbaji igwe, 
\q2 ya bụ igwe e si nʼakụkụ ugwu bubata, maọbụ bronz? 
\b  
\q1  
\v 13 “Aga m ewere ihe niile i nwere, ya na akụnụba gị, 
\q2 nye ya onye ga-akwata ha nʼagha. Ọ gaghị akwụ gị ihe ọbụla. 
\q1 Nʼihi na mmehie gị niile 
\q2 ejupụtala nʼala a niile. 
\q1  
\v 14 Aga m ewere gị nye ka ị bụrụ ohu ndị iro gị. 
\q2 Ị ga-ebi nʼala ị na-amaghị. 
\q1 Nʼihi na a ga-esite nʼiwe m mụnye ọkụ 
\q2 nke ga-eregbu gị.” 
\b  
\q1  
\v 15 Ị maara O \nd Onyenwe anyị\nd*, 
\q2 ya mere cheta m, lekọtaakwa m. 
\q2 Bọọrọ m ọbọ megide ndị na-akpagbu m. 
\q1 Ewezugala m, biko, nʼihi na ị bụ onye ogologo ntachiobi. 
\q2 Lee ka m si na-anata nkọcha nʼihi na m na-asọpụrụ gị. 
\q1  
\v 16 Mgbe m chọpụtara okwu gị, eweere m ya rie dịka nri. 
\q2 Ha tọrọ obi m ụtọ, bụrụkwa ihe na-enye m ọṅụ, 
\q1 nʼihi na-akpọkwasịrị m aha gị, 
\q2 \nd Onyenwe anyị\nd* Chineke Onye pụrụ ime ihe niile. 
\q1  
\v 17 O nwebeghị oge mụ na ndị na-achị ọchị nke ukwuu ji nọkọọ. 
\q2 Esokwaghị m ha ṅụrịkọọ ọṅụ. 
\q1 A nọdụụrụ m onwe m nʼihi na aka gị dịkwasịrị m. 
\q2 I mekwara ka iwe jupụta m nʼobi nʼihi ajọ omume ha. 
\q1  
\v 18 Gịnị mere ihe mgbu m adịghị akwụsị akwụsị? 
\q2 Gịnị mekwara ọnya m ji dị njọ na-apụghị ịgwọta ya? 
\q1 Ị dịrị m dịka mmiri iyi na-arafu mmadụ, 
\q2 dịka isi iyi nke na-ekwesighị ntụkwasị obi. 
\p  
\v 19 Ya mere, ihe ndị a ka \nd Onyenwe anyị\nd* kwuru, 
\q1 “Ọ bụrụ na i chegharịa, aga m etinyeghachi gị nʼọnọdụ gị, 
\q2 ime ka i guzokwa nʼihu m. 
\q1 Ọ bụrụ na okwu si gị nʼọnụ abụrụ okwu kwesiri ntụkwasị obi, okwu na-abụghị okwu nzuzu 
\q2 ị ga-abụ onye na-ekwuchitere m ọnụ m. 
\q1 Ndị a ga-alaghachikwute gị 
\q2 ma i gaghị alaghachikwuru ha. 
\q1  
\v 20 Aga m eme ka ị dịrị ka mgbidi nʼebe ha nọ. 
\q2 Ị ga-abụ mgbidi e wusiri ike, nke e ji bronz wuo. 
\q1 Ha ga-ebuso gị agha, 
\q2 ma ha agaghị emeri gị 
\q1 nʼihi na m nọnyeere gị ịnapụta gị, 
\q2 nakwa ịzọpụta gị,” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwubiri. 
\q1  
\v 21 “Aga m anapụta gị site nʼaka ndị ọjọọ. 
\q2 Gbapụtakwa gị site nʼaka ndị na-enweghị obi ebere.” 
\c 16  
\s1 Ụbọchị Mbibi 
\p  
\v 1 Mgbe ahụ, okwu \nd Onyenwe anyị\nd* ruru m ntị, sị,  
\v 2 “Ị gaghị alụtara onwe gị nwunye, ị gaghị amụtakwa ụmụ ndị ikom na ndị inyom nʼebe a.”  
\v 3 Nʼihi na otu a ka \nd Onyenwe anyị\nd* kwuru banyere ụmụ ndị ikom niile na ụmụ ndị inyom niile a mụrụ nʼala a. Otu a ka ọ kwukwara banyere nne na nna ụmụntakịrị ndị a.  
\v 4 “Ha ga-anwụ site nʼajọ ọrịa nke ga-egbu ha niile. O nweghị onye ga-eru ụjụ nʼihi ha, a gaghị elikwa ha. Kama ha ga-adị ka unyi e kposara nʼala. Mma agha na ụnwụ ga-ala ha nʼiyi, ozu ha ga-abụkwa ihe oriri nye ụmụ anụ ufe na ụmụ anụ ọhịa nke ụwa.” 
\p  
\v 5 Nʼihi na ihe ndị a ka \nd Onyenwe anyị\nd* kwuru, “Abanyela nʼụlọ ọbụla a na-akwa ozu; abanyela maka iso ha ruo ụjụ,\f + \fr 16:5 \ft Iti ha aka nʼobi\f* maọbụ maka igosi ha ebere, nʼihi na ewepụla m ngọzị m nʼịhụnanya m, na ọmịiko m site nʼebe ha nọ,” otu a ka \nd Onyenwe anyị\nd* kwupụtara.  
\v 6 “Ma ndị ukwu na ndị nta nʼime ha ga-anwụ nʼala a. O nweghị onye ga-eli ha, maọbụ ruo ụjụ nʼihi ha. O nweghị onye ga-akpụcha isi ya, maọbụ gbuo onwe ya mma nʼihi ha.  
\v 7 O nweghị onye ga-eweta ihe oriri nye ndị zukọrọ maka ịkasị ndị na-eru ụjụ obi. Nri agaghị adị ọ bụladị nye ndị na-eru ụjụ, nʼihi ọnwụ nna ha maọbụ ọnwụ nne ha. Ọ dịkwaghị onye ga-enye ha ihe ọṅụṅụ nʼihi ịkasị ha obi. 
\p  
\v 8 “Abanyekwala nʼụlọ ebe e nwere oriri soro ndị nọ nʼebe ahụ nọdụ ala iri ihe na ịṅụ ihe ọṅụṅụ  
\v 9 Nʼihi na otu a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, onye bụkwa Chineke Izrel kwuru, ‘Nʼihu gị, na nʼoge ndị a niile ị dị ndụ, ka m ga-eme ka ụzụ ọṅụ na obi ụtọ, na olu ndị ikom na nke ndị inyom na-alụ di na nwunye kwụsị.’ 
\p  
\v 10 “Mgbe ị gwara ndị a ihe ndị a, ha ga-ajụ gị ajụjụ sị, ‘Gịnị mere \nd Onyenwe anyị\nd* ji kpebie izitere anyị ụdị oke ịla nʼiyi dị otu a? Gịnị bụ ihe ọjọọ anyị mere? Gịnị bụ mmehie anyị mere megide \nd Onyenwe anyị\nd* Chineke anyị?’  
\v 11 Mgbe ahụ, ị ga-asa ha sị ha, ‘Ihe ndị a na-adakwasị unu nʼihi na nna nna unu ha gbakụtara m azụ,’ otu a ka \nd Onyenwe anyị\nd* kwupụtara, ‘gbasoro, fee ma kpọọkwa isiala nye chi ndị ọzọ. Ha jụrụ iso m, jụkwa idebe ihe m nyere ha nʼiwu.  
\v 12 Ma unu emesoola m mmeso ọjọọ karịa ụdị mmeso nna unu ha mesoro m. Lee ka unu niile nʼotu nʼotu si agbaso ụzọ isiike nke obi ọjọọ unu chepụtara, kama irubere m isi.  
\v 13 Ya mere, aga m esite nʼala a tufuo unu. Aga m atụbanye unu nʼala ahụ unu na nna unu ha na-amaghị. Ebe ahụ ka unu ga-anọkwa fee chi ndị ọzọ ehihie na abalị. Nʼihi na agaghị m emere unu amara.’ 
\p  
\v 14 “Otu ọ dị, ụbọchị ndị ahụ na-abịa,” ka \nd Onyenwe anyị\nd* kwupụtara, “mgbe ndị mmadụ na-agaghị asịkwa ọzọ,\f + \fr 16:14 \ft Ejikwa ụdị okwu ndị a malite ịṅụ iyi ha\f* ‘Dịka \nd Onyenwe anyị\nd* na adị ndụ, bụ onye ahụ sitere nʼala Ijipt kpọpụta ụmụ Izrel.’  
\v 15 Ma a ga-asị, ‘Dịka \nd Onyenwe anyị\nd* na-adị ndụ, bụ onye ahụ kpọpụtara Izrel site nʼala dị nʼugwu, na mba ahụ niile ọ chụsara ha.’ Nʼihi na aga m akpọlata ha nʼala ahụ m nyere nna nna ha. 
\p  
\v 16 “Ma ugbu a, aga m ezipu ọtụtụ ndị ọkụ azụ ka ha gaa jide ha.” Otu a ka \nd Onyenwe anyị\nd* kwubiri. “Mgbe nke ahụ gasịrị, aga m ezipụkwa ọtụtụ ndị na-achụ nta, ndị ga-esite nʼelu ugwu ukwu niile na nʼelu ugwu nta niile, na nʼọnụ mgbawara dị na nkume niile, chụọ nta ha.  
\v 17 Ana m ahụzu ụzọ ha niile. O nweghị ihe zoro ezo nʼebe m nọ. Anya m na-ahụzukwa mmehie ha niile.  
\v 18 Aga m akwụghachi ha okpukpu abụọ nʼihi ajọ omume ha, na mmehie ha, nʼihi na ha ejirila oyiyi ihe arụ a pịrị apị ha, nke na-enweghị ndụ nʼime ya, merụọ ala m. Ha emeekwala ka arụsị bụ ihe arụ jupụta nʼihe nketa m.” 
\q1  
\v 19 \nd Onyenwe anyị\nd*, ị bụ ike m na ebe m e wusiri ike, 
\q2 ebe mgbaba m nʼoge nsogbu. 
\q1 Mba niile nke ụwa ga-esite na nsọtụ ụwa niile bịakwute gị. 
\q2 Ha ga-abịakwute gị sị gị, 
\q1 “Nna anyị ha enweghị ihe ọbụla karịakwa chi ndị na-abụghị chi nʼezie. 
\q2 Ha bụkwa chi na-abaghị uru, nke na-adịghị ewetara ha ihe ọma ọbụla.” 
\q1  
\v 20 Mmadụ ọ pụrụ imere onwe ya chi? 
\q2 E, ma chi ndị ahụ abụghị chi. 
\b  
\q1  
\v 21 “Ya mere, aga m eme ka ha mata. 
\q2 Nʼoge a ka m ga-eme ka ha mata ike m, 
\q2 na ịdị ike m. 
\q1 Mgbe ahụ, ha ga-amata 
\q2 na aha m bụ \nd Onyenwe anyị\nd*. 
\b  
\c 17  
\q1  
\v 1 “E ji mkpisi igwe gbunye mmehie Juda, 
\q2 jikwa ọnụ nkume siri ike a pịrị ọnụ\f + \fr 17:1 \ft Nkume a na-egbuke ka ọla dịamọndu\f* ya apị, 
\q1 depụta nʼelu mbadamba nkume, bụ obi ha, 
\q2 nakwa nʼelu mpi niile nke ebe ịchụ aja ha. 
\q1  
\v 2 Ọ bụladị ụmụ ha na-echeta ebe ịchụ aja ha, 
\q2 na ogidi a manyere nʼala nʼihi arụsị Ashera, 
\q1 nke dị nʼebe ọtụtụ osisi ndụ na-etokọ ọnụ, 
\q2 ma nʼelu ugwu nta niile. 
\q1  
\v 3 Ugwu m, nke dị nʼala ahụ, 
\q2 na ihe niile ha nwere, na akụnụba ha 
\q1 ka m ga-eweta nye ndị ga-adọta ha nʼagha. 
\q2 Aga m enyekwa ha ihe niile ahụ dị nʼelu ugwu, 
\q2 nʼihi mmehie gị, nke jupụtara nʼala gị niile. 
\q1  
\v 4 Ihe nketa ahụ m nyere gị ga-efunarị gị, 
\q2 nʼihi ihe i ji aka gị wetara onwe gị. 
\q1 Aga m emekwa ka ị bụrụ ohu ndị iro gị 
\q2 nʼala nke ị na-amaghị, 
\q1 nʼihi na ị kpasuola iwe m, 
\q2 ọ ga-adịgidekwa ruo mgbe niile ebighị ebi.” 
\p  
\v 5 Ihe ndị a ka \nd Onyenwe anyị\nd* kwuru, 
\q1 “Onye a bụrụ ọnụ ka mmadụ ahụ bụ nke na-atụkwasị mmadụ ibe ya obi, 
\q2 onye olileanya ya dị nʼinyeaka ga-esi nʼaka mmadụ rute ya aka, 
\q2 onye wezugara obi ya site nʼebe \nd Onyenwe anyị\nd* nọ. 
\q1  
\v 6 Onye ahụ ga-adị ka osisi na-eto nʼala tọgbọrọ nʼefu. 
\q2 Ọ gaghị ahụkwa mgbe ọ dịmma na-abịara ya. 
\q1 Ọ ga-ebi nʼebe niile kpọrọ nkụ nke ọzara, 
\q2 nʼala nnu nnu, ebe ndị mmadụ na-ebighị. 
\b  
\q1  
\v 7 “Ma ngọzị na-adịrị onye ahụ na-atụkwasị \nd Onyenwe anyị\nd* obi ya. 
\q2 Onye ịnya isi ya bụ nʼime \nd Onyenwe anyị\nd*. 
\q1  
\v 8 Onye dị otu a ga-adị ka osisi a kụrụ nʼakụkụ iyi, 
\q2 nke mgbọrọgwụ ya na-awasa banye nʼiyi ahụ. 
\q1 Ụjọ adịghị atụ ya nʼoge okpomọkụ, 
\q2 akwụkwọ ndụ na-adịgidekwa nʼelu ya. 
\q1 Ọ dịghị echegbu onwe ya nʼafọ ụnwụ dị. 
\q2 Ọ dịkwaghị mgbe ọ na-akwụsị ịmị mkpụrụ.” 
\b  
\q1  
\v 9 Obi mmadụ dị aghụghọ karịa ihe niile, 
\q2 o nwekwaghị ngwọta. 
\q2 Onye pụrụ ịghọta ya? 
\b  
\q1  
\v 10 “Mụ onwe m bụ \nd Onyenwe anyị\nd* na-enyocha obi, 
\q2 na-anwụpụta ihe dị nʼime mmụọ, 
\q1 nʼihi ịkwụ mmadụ ụgwọ dịka ọrụ ya si dị, 
\q2 na dịka ihe ruuru ya si dị nʼihi ọrụ ya.” 
\b  
\q1  
\v 11 Dịka ọkwa si ekpokọba akwa ọ na-eyighị, 
\q2 otu a ka ndị na-akpakọba akụ nʼụzọ na-ezighị ezi dị. 
\q1 Nʼetiti ụbọchị ndụ ha, akụ ndị a ga-efunarị ha. 
\q2 Nʼikpeazụ ha ga-aghọ ndị nzuzu. 
\b  
\q1  
\v 12 Ocheeze dị ebube, nke e mere ka ọ dị elu site na mmalite, 
\q2 ka ebe nsọ anyị bụ. 
\q1  
\v 13 \nd Onyenwe anyị\nd*, olileanya Izrel ka ị bụ. 
\q2 A ga-emekwa ka ihere mee ndị na-agbakụta gị azụ. 
\q1 A ga-edekwa aha ndị ahụ niile si nʼebe ị nọ wezuga onwe ha nʼala, 
\q2 nʼihi na ha ewezugala onwe ha site nʼebe \nd Onyenwe anyị\nd*, 
\q2 isi iyi nke mmiri na-enye ndụ, nọ. 
\b  
\q1  
\v 14 \nd Onyenwe anyị\nd*, ọ bụrụ na i mee ka ahụ sie m ike aga m adị ndụ. 
\q2 Ọ bụrụ na ị zọpụta m aga m abụ onye azọpụtara, 
\q2 nʼihi na ọ bu naanị gị ka m na-eto. 
\q1  
\v 15 Ha nọ na-ajụ m ọnụ, na-asị m, 
\q2 “Olee ebe okwu \nd Onyenwe anyị\nd* dị? 
\q2 Ya mezuonụ ugbu a!” 
\q1  
\v 16 Ma esitebeghị m na ị bụ onye ọzụzụ atụrụ gị wezuga onwe m. 
\q2 Ị maara na ọ bụghị ọchịchọ obi m ịhụ ụbọchị ahụ na-eweta ịda mba. 
\q2 Ị maara ụdị okwu niile na-esite nʼọnụ m na-apụ. 
\q1  
\v 17 A ghọrọla m ihe na-eyi egwu, 
\q2 nʼihi na ị bụ ebe mgbaba m nʼụbọchị mbibi. 
\q1  
\v 18 Mee ka ihere mee ndị na-akpagbu m. 
\q2 Ekwekwala ka ihere mee m. 
\q1 Mee ka ha tụọ ụjọ, 
\q2 ma chebe m site nʼihe egwu. 
\q1 Mee ka ụbọchị mbibi bịakwasị ha, 
\q2 werekwa okpukpu ihe mbibi abụọ tipịa ha. 
\s1 Idebe Ụbọchị Izuike nsọ 
\p  
\v 19 Ihe a ka \nd Onyenwe anyị\nd* gwara m, “Gaa, guzo nʼọnụ ụzọ ama obodo, ebe ndị eze Juda na-esi apụ, ma na-abatakwa. Guzokwa nʼọnụ ụzọ ama ndị ọzọ niile dị na Jerusalem.  
\v 20 Gwa ha sị, ‘Nụrụnụ okwu \nd Onyenwe anyị\nd*, unu ndị eze Juda na ndị Juda niile, na ndị niile bi na Jerusalem, ndị na-esi nʼọnụ ụzọ a apụ, na-abatakwa.’  
\v 21 Ihe ndị a ka \nd Onyenwe anyị\nd* kwuru, ‘Lezienụ onwe unu anya ịhụ na unu ebughị ibu ọbụla nʼụbọchị izuike; lezienụ onwe unu anya ịhụ na unu esiteghị nʼọnụ ụzọ ama Jerusalem bufee ya.  
\v 22 Unu esitela nʼụlọ unu buputa ihe ọbụla, unu arụkwala ọrụ ọbụla nʼụbọchị izuike. Doonụ ụbọchị izuike nsọ dịka m nyere nna unu ha nʼiwu.  
\v 23 Ma ha egeghị ntị, maọbụ kpọọ ya mkpa ha. Ha bụ ndị ntị ike, ndị na-adịghị aṅa ntị nʼịdọ aka na ntị, maọbụ nabata ya.  
\v 24 Ma otu a ka \nd Onyenwe anyị\nd* kwubiri, ọ bụrụ na unu ga-elezi anya rubere m isi, hapụ isi nʼọnụ ụzọ ama obodo a bufee maọbụ bubata ibu nʼụbọchị izuike, kama debe ụbọchị izuike nsọ, site na-arụghị ọrụ ọbụla nʼime ya,  
\v 25 mgbe ahụ, ndị eze ndị ga-anọkwasị nʼocheeze Devid ga-edu ndị na-ejere ya ozi na-agafe na-abatakwa site nʼọnụ ụzọ ama a. Ha na ndị na-ejere ha ozi ga-anọkwasị nʼịnyịnya ha, na nʼụgbọ agha ha, mgbe ha sị nʼọnụ ụzọ ama a na-abata, ma na-apụ. Ndị Juda, na ndị bi na Jerusalem ga-esokwa ha nʼazụ. Aga m emekwa ka ndị mmadụ biri nʼobodo a ruo mgbe ebighị ebi.  
\v 26 Ndị mmadụ ga-esite nʼobodo niile nke Juda, na nʼobodo nta gbara Jerusalem gburugburu; ha ga-esitekwa nʼala ndị Benjamin, na nʼala ndagwurugwu nke ugwu ndị ahụ dị nʼọdịda anyanwụ, sitekwa nʼala Negev, na-ewebata onyinye aja nsure ọkụ, na aja dị iche iche, na onyinye ọka, na onyinye ihe nsure ọkụ na-esi isi ụtọ, na onyinye ekele, nʼime ụlọ \nd Onyenwe anyị\nd*.  
\v 27 Ma ọ bụrụ na unu enupu isi jụ idebe ụbọchị izuike nsọ, ọ bụrụ na unu anọgide na-ebubata ihe site nʼọnụ ụzọ ama Jerusalem nʼụbọchị izuike, aga m amụnye ọnụ ụzọ ama niile dị na Jerusalem ọkụ, nke a na-apụghị imenyụ emenyụ. Ọ ga-erepịakwa ebe niile e wusiri ike na Jerusalem.’ ” 
\c 18  
\s1 NʼỤlọ ọkpụ ite 
\p  
\v 1 Nke a bụ okwu nke sị nʼebe \nd Onyenwe anyị\nd* nọ bịakwute Jeremaya.  
\v 2 “Bilie, jee nʼụlọ ọkpụ ite, ebe ahụ ka m ga-anọ zie gị ozi.”  
\v 3 Ya mere, ebiliri m jee nʼụlọ ọkpụ ite, bịakwute ya mgbe ọ nọ na-arụ ọrụ na nkume ịkpụ ihe.  
\v 4 Ma ite ahụ ọ chọrọ ịkpụ apụtaghị dịka ọkpụ ite si chọọ ya, nʼihi ya, ọ kpụkọtara ụrọ ahụ ọzọ, malitekwa ịkpụgharị ya. 
\p  
\v 5 Mgbe ahụ okwu \nd Onyenwe anyị\nd* ruru m ntị,  
\v 6 Ọ sịrị, “Ọ bụ na m apụghị ime unu dịka ọkpụ ite a mere, unu ụmụ Izrel?” Otu a ka \nd Onyenwe anyị\nd* kwubiri, “Dịka ụrọ si dị nʼaka ọkpụ ite ahụ, otu a ka unu onwe unu si dịrị nʼaka m, gị Izrel.  
\v 7 Mgbe ọbụla m kpọsara na a ga-akwada maọbụ bibie, maọbụ si nʼọnọdụ ya hopu mba maọbụ alaeze ọbụla,  
\v 8 ọ bụrụ na mba ahụ m dọrọ aka na ntị esite na mmehie ha chegharịa, a gaghị ebibi ya dịka m si zube.  
\v 9 Ọzọ, ọ bụrụ na m akpọsaa na a ga-ewuli mba ọbụla maọbụ alaeze ọbụla elu, kụọkwa ya,  
\v 10 ọ bụrụ na o mee ihe jọrọ njọ nʼanya m, jụ irubere m isi, agaghị m emere ya ihe ọma ahụ m zubere imere ya. 
\p  
\v 11 “Ugbu a, gwa ndị Juda na ndị ahụ bi na Jerusalem, sị, ‘Otu a ka \nd Onyenwe anyị\nd* sịrị: Lee, ana m akwado mbibi nke ga-abịakwasị unu; ana m echekwa echiche ọjọọ megide unu. Ya mere, ka onye ọbụla nʼime unu site nʼụzọ ọjọọ ya chegharịa, ya meekwa ka ụzọ ya na omume ya zie ezi.’  
\v 12 Ma ha ga-aza sị, ‘O nweghị isi! Anyị ga-anọgide na-eme ihe ọbụla anyị chepụtara nʼechiche anyị, na-emekwa atụmatụ isiike nke obi ọjọọ anyị tụpụtara.’ ” 
\p  
\v 13 Nʼihi ya ka \nd Onyenwe anyị\nd* ji kwuo sị, 
\q1 “Jụtanụ ajụjụ nʼetiti mba niile, 
\q2 onye nụrụla ihe dị otu a? 
\q1 Ndị m, Izrel, bụ nwaagbọghọ na-amaghị nwoke 
\q2 emeela ihe jọgburu onwe ya. 
\q1  
\v 14 O nweela mgbe mmiri oyi m mere ka ọ kpụkọtaa 
\q2 kọrọ nʼelu ugwu Lebanọn? 
\q1 O nweela mgbe mmiri ya jụrụ oyi, 
\q2 nke si nʼebe dị anya na-asọdata ji akwụsị ịsọ asọ? 
\q1  
\v 15 Ma ndị m echezọọla m. 
\q2 Ha na-achụ aja nsure ọkụ na-esi isi ụtọ nye arụsị na-enweghị isi, 
\q1 bụ arụsị ndị ahụ mere ka ha sọọ ngọngọ nʼụzọ ha niile. 
\q2 Ha sụrụ ngọngọ hapụ ịgbasokwa ụzọ ọma ahụ dị site na mgbe ochie. 
\q1 Kama ha na-eje ije nʼụzọ ọhịa, nke na-enweghị ụkpụrụ, 
\q2 nke a na-ewuzighị ewuzi. 
\q1  
\v 16 Ala ha ga-atọgbọrọ nʼefu. 
\q2 Ọ ga-aghọ ihe iju anya ruo ebighị ebi. 
\q1 Ndị si nʼakụkụ ya na-agafe ga-efufe isi ha, 
\q2 nʼihi na ihe ha ga-ahụ ga-eju ha anya. 
\q1  
\v 17 Aga m achụsa ha nʼihu ndị iro ha 
\q2 dịka ifufe na-efe site nʼọwụwa anyanwụ. 
\q1 Aga m agbakụta ha azụ. 
\q2 Ha agaghị ahụkwa ihu m anya nʼụbọchị ahụ mbibi ga-abịakwasị ha.” 
\p  
\v 18 Ha sịrị, “Bịanụ ka anyị gbaa izu megide Jeremaya, nʼihi na izi iwu agaghị esite nʼebe ndị nchụaja nọ kwụsị, maọbụ ndụmọdụ nʼebe ndị maara ihe, ma ọ bụkwanụ okwu site nʼebe ndị amụma nọ. Ya mere, bịanụ ka anyị were ire anyị buso ya agha,\f + \fr 18:18 \ft Maọbụ, \fqa gwajuo ya okwu afọ\f* gharakwa ịṅa ntị nʼokwu ọbụla nke ọ na-ekwu.” 
\q1  
\v 19 Gee m ntị, \nd Onyenwe anyị\nd*. 
\q2 Nụrụ ihe ndị na-ebo m ebubo na-ekwu megide m. 
\q1  
\v 20 O kwesiri iji ajọ omume kwụghachi ihe ọma? 
\q2 Ma lee na ha egwuolara m olulu. 
\q1 Chetakwa na m guzooro nʼihu gị 
\q2 ma rịọ gị arịrịọ nʼihi ha. 
\q2 Arịrịọ m bụ ka ị hapụ iweso ha oke iwe. 
\q1  
\v 21 Ya mere, were ụmụ ha nyefee nʼaka ụnwụ. 
\q2 Werekwa ha onwe ha nyefee nʼaka mma agha. 
\q1 Mee ka ndị nwunye ha ghọọ ndị gba aka ụmụ na di. 
\q2 Meekwa ka e gbuo ndị ikom ha, 
\q2 ka mma agha gbukwaa ụmụ okorobịa nʼọgbọ agha. 
\q1  
\v 22 Mee ka e site nʼụlọ ha nụ mkpu akwa, 
\q2 mgbe i mere ka ndị iro ha buso ha agha na mberede. 
\q1 Nʼihi na ha egwuola olulu ijide m, 
\q2 ha esiekwarala m ọnya nzuzo ijide m nʼụkwụ. 
\q1  
\v 23 Ma gị onwe gị, \nd Onyenwe anyị\nd*, 
\q2 maara nzube ọjọọ ha niile igbu m. 
\q1 Agbagharala ha ajọ omume ha; 
\q2 maọbụ hichapụ mmehie ha site nʼihu gị. 
\q1 Mee ka ụkwụ ha gbuchapụ ka ha daa nʼihu gị; 
\q2 mesie ha ike mgbe ị na-ewe iwe. 
\c 19  
\p  
\v 1 Ihe ndị a ka \nd Onyenwe anyị\nd* kwuru, “Jee, zụta otu ite aja site nʼaka ọkpụ ite. Duru ụfọdụ nʼime ndị okenye na ndị nchụaja,  
\v 2 jee na Ndagwurugwu nke Ben Hinom, nke dị nso nʼọnụ ụzọ ama Ejuju dị nʼọwụwa anyanwụ. Nọdụ nʼebe ahụ kwupụtara ha okwu ndị m gwara gị.  
\v 3 Sị ha, ‘Nụrụnụ okwu \nd Onyenwe anyị\nd*, unu ndị eze Juda, na ndị Jerusalem. Ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, onye bụ Chineke Izrel kwuru. Geenụ ntị! Aga m eme ka ihe ọjọọ bịakwasị ala a, ụdị ihe ọjọọ ga-eme ka ntị ọbụla nụrụ ya zụọ wuruwuru.  
\v 4 Nʼihi na ha ahapụla m, mee ka ebe a ghọọ nke chi ndị mba ọzọ. Ha achụọla aja nsure ọkụ nʼime ya nye chi ndị ahụ ha na nna nna ha, maọbụ ndị eze Juda, na-amaghị. Ha ejirila ọbara ndị aka ha dị ọcha mejupụta ebe a.  
\v 5 Ha ewuola ebe ịchụ aja dị elu nye chi Baal. Nʼelu ya kwa ka ha na-esure ụmụ ha dịka aja nye Baal, bụ nke m na-enyeghị nʼiwu, ekwughịkwa m ya, o nwekwaghị mgbe o ji bata m nʼobi.  
\v 6 Ya mere, kpacharanụ anya, nʼihi na ụbọchị ahụ na-abịa, ka \nd Onyenwe anyị\nd* kwubiri, mgbe ndị mmadụ agaghị akpọkwa ebe a Tofet ma ọ bụkwanụ Ndagwurugwu nke Ben Hinom, kama a ga-akpọ ya Ndagwurugwu Ogbugbu. 
\p  
\v 7 “ ‘Nʼebe a ka m ga-anọ laa nzube niile nke Juda na Jerusalem nʼiyi. Aga m eme ka ha daa site na mma agha nʼihu ndị iro ha, nʼaka ndị ahụ na-achọsi ndụ ha ike. Aga m enye ụmụ anụ ufe na anụ ọhịa ozu ha dịka nri.  
\v 8 Aga m ebibi obodo a mee ka ọ ghọọ ihe iju anya na ihe ịma ọsụ. Ndị niile na-esi nʼakụkụ ya agafe ga-anọ nʼọnọdụ iju anya, ha ga-eledakwa ya anya nʼihi ọnya ya niile.  
\v 9 Aga m emekwa ka ha rie anụ ahụ nke ụmụ ha ndị ikom na ndị inyom. Ha ga-erikwa anụ ahụ ibe ha, nʼihi na ndị iro ha ga-agba ha gburugburu nọchibido ha nʼime oke mkpagbu\f + \fr 19:9 \ft Gbochie nri ọbụla isite nʼezi rute ha aka\f* ka ha bibie ndụ ha.’ 
\p  
\v 10 “Kụwaa ite ahụ mgbe ndị gị na ha so nọ na-ele gị anya.  
\v 11 Gwa ha sị, ‘Otu a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile sịrị: Aga m etipịa mba a na obodo a, dịka ite aja nke ọkpụ ite a si daa tipịasịa nʼụzọ a na-apụghị imezikwa ya ọzọ. Ha ga-eli ndị nwụrụ anwụ na Tofet tutu ruo mgbe ohere na-agaghị adịkwa ili ozu ọzọ.  
\v 12 Ihe dị otu a ka m ga-eme nʼebe a, meekwa ndị bi na ya. Otu a ka \nd Onyenwe anyị\nd* kwubiri. Aga m eme obodo a ka ọ dịrị ka Tofet.  
\v 13 Ụlọ niile dị na Jerusalem na ụlọ niile nke ndị eze Juda ka a ga-emerụ dịka ebe a, bụ Tofet, otu a ka a ga-esi merụọkwa ụlọ niile a suree ihe nsure ọkụ na-esi isi ụtọ nʼelu ha nye usuu niile nke eluigwe, wụsakwara chi ndị ọzọ ihe ọṅụṅụ dịka onyinye.’ ” 
\p  
\v 14 Mgbe Jeremaya si na Tofet, ebe ahụ \nd Onyenwe anyị\nd* zigara ya ibu amụma lọta, o guzoro nʼogige ụlọnsọ ukwu Chineke ahụ, gwa ndị mmadụ niile okwu sị ha,  
\v 15 “Otu a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, onye bụ Chineke nke Izrel sịrị, ‘Geenụ ntị! Ana m aga ime ka ihe ọjọọ ahụ m kwuru okwu ya bịakwasị obodo a, na obodo nta niile gbara ya gburugburu, nʼihi na ha bụ ndị isiike, ndị jụrụ ige ntị nʼokwu m.’ ” 
\c 20  
\s1 Jeremaya na Pashua 
\p  
\v 1 Mgbe Pashua nwa Imea, bụ onye nchụaja, ma burukwa onyeisi na-elekọta ụlọnsọ ukwu \nd Onyenwe anyị\nd*, nụrụ amụma ndị a Jeremaya na-ebu,  
\v 2 o nyere iwu ka e tie Jeremaya, bụ onye amụma ihe, kee ya agbụ, tinye ya nʼọnụ ụzọ ama Dị Elu nke Benjamin, nke dị ụlọnsọ ukwu \nd Onyenwe anyị\nd*.  
\v 3 Nʼechi ya, mgbe Pashua tọpụrụ ya site nʼagbụ ahụ, Jeremaya sịrị ya, “\nd Onyenwe anyị\nd* akpọghị gị Pashua, kama aha gị bụ Mago-Misabib, nke pụtara, Nwoke ihe egwu gbara gburugburu.  
\v 4 Nʼihi na nke a ka \nd Onyenwe anyị\nd* na-ekwu, ‘Aga m eme ka ị ghọọrọ onwe gị, ghọọkwara ndị enyi gị niile ihe egwu. Anya gị abụọ ka ị ga-eji hụ ha mgbe mma agha ndị iro ha ga-egbuda ha. Aga m ararakwa ala Juda niile nyefee ha nʼaka eze Babilọn, onye ga-egbuda ha. Aga m ararakwa ala Juda niile nyefee ha nʼaka eze Babilọn, onye ga-eburu ndị niile bi nʼime ya gaa Babilọn. Ọ ga-egbu ndị fọdụrụ.  
\v 5 Aga m enyefe ndị iro ha akụ niile dị nʼobodo, na ihe niile ha rụpụtara, na ihe niile dị oke ọnụahịa, na ngwongwo na akụ niile nke ndị eze Juda. Ha ga-eburu ya dịka ihe a kwatara nʼagha laa Babilọn.  
\v 6 Ma gị onwe gị bụ Pashua, na ndị niile bi nʼụlọ gị, ka a ga-adọta nʼagha buru gaa Babilọn. Nʼebe ahụ ka ị ga-anwụ. Ebe ahụ kwa ka a ga-eli gị, gị na ndị enyi gị ndị a niile ị na-eburu amụma ụgha.’ ” 
\s1 Mkpesa Jeremaya 
\q1  
\v 7 \nd Onyenwe anyị\nd*, ị ghọọla m aghụghọ, meekwa m ka m ghọọ onye a ghọgburu nʼaghụghọ. 
\q2 I jidesiela m aka ike, mee ka uche gị mezuo m nʼahụ. 
\q1 Lee na mmadụ niile na-akparị m ụbọchị niile. 
\q2 Onye ọbụla jikwa m na-eme ihe ọchị. 
\q1  
\v 8 Nʼihi na mgbe ọbụla m meghere ọnụ kwuo okwu, aghaghị m iti mkpu. 
\q2 Aga m akpọ mkpu banyere ihe ike na ịla nʼiyi. 
\q1 Nʼihi na okwu \nd Onyenwe anyị\nd* ewetarala 
\q2 m mkparị na ịkwa emo ụbọchị niile. 
\q1  
\v 9 Ọ bụrụkwa na m ekwuo nʼobi m sị, “Agaghị m ekwute ihe ọbụla metụtara okwu ya maọbụ aha ya ọzọ.” 
\q2 Ọ dịghị ekwe m. 
\q1 Nʼihi na okwu ya na-enwu m ọkụ nʼobi. 
\q2 Ọ dịkwa ka ọkụ na-enwu enwu emechibidoro ụzọ nʼime ọkpụkpụ m. 
\q1 Ike agwụla m ịnagide okpomọkụ nke okwu ya. 
\q2 Nʼezie, apụghịkwa m ịnagide ya. 
\q1  
\v 10 Ana m anụ ọtụtụ akụkọ nzuzo, 
\q2 “Oke egwu nʼakụkụ niile! 
\q2 Jụụnụ ya! Ka anyị jụụnụ ya!” 
\q1 Ndị enyi m niile 
\q2 nọ na-eche mgbe m ga-azọhie ụkwụ daa, na-asị, 
\q1 “Ma eleghị anya ọ ga-abụ onye eduhiere, 
\q2 mgbe ahụ, anyị ga-emegide ya, 
\q2 bọọrọ onwe anyị ọbọ nʼahụ ya.” 
\b  
\q1  
\v 11 Ma \nd Onyenwe anyị\nd* nọnyeere m dịka dike nʼagha; 
\q2 nʼihi ya, ndị na-esogbu m ga-asọ ngọngọ, ha agaghị emerikwa m. 
\q1 Ihe ha zubere agaghị emezuru ha, nʼihi ya, ihere ga-eme ha nke ukwuu; 
\q2 a gaghị echezọkwa ọnọdụ ihere ha ruo ebighị ebi. 
\q1  
\v 12 Ma gị, \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, gị, onye na-enyocha onye ezi omume, 
\q2 onye anya ya na-eru nʼihe dị mmadụ nʼobi na nʼime echiche uche ya, 
\q1 biko, kwere ka m dị ndụ hụ mgbe ị ga-abọrọ onwe gị ọbọ megide ha, 
\q2 nʼihi na ọ bụ nʼaka gị ka m tinyere ihe niile gbasara m. 
\b  
\q1  
\v 13 Bụkuonụ \nd Onyenwe anyị\nd* abụ! 
\q2 Nyenụ \nd Onyenwe anyị\nd* otuto! 
\q1 Nʼihi na ọ na-anapụta ndụ ndị mkpa na-akpa, 
\q2 site nʼaka ndị ajọ omume. 
\b  
\q1  
\v 14 Ihe a bụrụ ọnụ ka ụbọchị ahụ a mụrụ m bụ. 
\q2 Ka ụbọchị nne m mụrụ m ghara inwe ngọzị. 
\q1  
\v 15 Onye a na-abụ ọnụ ka nwoke ahụ bụ nke wetara nna m akụkọ ọmụmụ m, 
\q2 nke mere ka ọ ṅụrịa ọṅụ, na-asị ya, 
\q2 “A mụọlara gị nwa, ọ bụ nwa nwoke!” 
\q1  
\v 16 Ka e meekwa nwoke ahụ ihe \nd Onyenwe anyị\nd* mere obodo ndị ahụ 
\q2 o bibiri na-enweghị ọmịiko. 
\q1 Ka nwoke ahụ nọgidekwa na-anụ iti mkpu akwa nʼụtụtụ, 
\q2 na akwa ibu agha nʼehihie. 
\q1  
\v 17 Nʼihi na ọ hapụrụ igbu m mgbe m nọ nʼafọ nne m, 
\q2 hapụ ime ka afọ nne m bụrụ ili m, 
\q2 ka afọ ya bụrụkwa ihe buru ibu ruo mgbe ebighị ebi. 
\q1  
\v 18 Nʼihi gịnị ka m ji site nʼafọ nne m pụta 
\q2 ịhụ ọnọdụ ọjọọ ndị a, na ịnọgide nʼobi mwute, 
\q2 na ịnọ ọnọdụ ihere ogologo ụbọchị niile nke ndụ m? 
\c 21  
\s1 Chineke ajụ arịrịọ Zedekaya 
\p  
\v 1 Ndị a bụ okwu \nd Onyenwe anyị\nd*, nke ruru Jeremaya ntị mgbe eze Zedekaya zigara Pashua nwa Malkija, na onye nchụaja bụ Zefanaya nwa Maaseia,  
\v 2 sị, “Jụtara anyị ase site nʼaka \nd Onyenwe anyị\nd*, nʼihi na Nebukadneza eze Babilọn na-ebuso anyị agha. Eleghị anya Onyenwe anyị ga-emere anyị ihe ịtụnanya dịka oge gara aga, nke ga-eme ka o si nʼebe anyị nọ wezuga onwe ya.” 
\p  
\v 3 Ma Jeremaya zara sị ha, “Gwanụ Zedekaya sị ya,  
\v 4 ‘Ihe ndị a ka \nd Onyenwe anyị\nd*, Chineke Izrel kwuru: Lee ejikerela m ugbu a ichigharị ihe agha niile dị unu nʼaka, nke unu ji na-ebuso eze Babilọn na ndị Kaldịa gbara obodo unu gburugburu agha, e, ejikerela m ichigharị ha megide unu. Aga m akpọbata ha nʼime obodo a.  
\v 5 Mụ onwe m ga-eji aka e setịpụrụ nke ọma, na aka dị ike, nke iwe na ọnụma dị ukwuu, buo agha megide unu.  
\v 6 Aga m etida ndị niile bi nʼobodo a, ma mmadụ ma anụ ọhịa. Ha ga-anwụkwa site nʼoke ihe otiti, nke m ga-eme ka ọ bịakwasị ha.  
\v 7 Mgbe nke a mesịrị, Otu a ka \nd Onyenwe anyị\nd* kwupụtara, aga m ewere Zedekaya eze Juda, na ndịisi ọchịchị ya, na ndị niile bi nʼobodo a, ndị mma agha na ụnwụ na ihe otiti ndị a na-egbughị, nyefee ha nʼaka Nebukadneza eze Babilọn, na nʼaka ndị iro ha, ndị na-achọsi ndụ ha ike. Ọ ga-eji mma agha gbuo ha. Ọ gaghị emere ha ebere, ọ gaghị egosikwa ha ọmịiko.’ 
\p  
\v 8 “Tinyere nke a, gwanụ ndị mmadụ niile, ‘na ihe ndị a ka \nd Onyenwe anyị\nd* kwuru: Lee, ana m eche nʼihu unu ụzọ abụọ, ụzọ na-eduba na ndụ, na ụzọ na-eduba nʼọnwụ.  
\v 9 Onye ọbụla nʼime unu nọgidere nʼobodo a ka mma agha, maọbụ ụnwụ, maọbụ ihe otiti ga-egbu. Ma onye ọbụla nʼime unu pụkwuru ndị Kaldịa gbara obodo unu gburugburu, were onwe ya nyefee ha nʼaka, ga-adị ndụ; ọ ga-echebekwa ndụ ya.  
\v 10 Ekpebiela m imesi obodo a ike; o nweghị ihe ọma ọbụla ga-esi nʼaka m rute ha, otu a ka \nd Onyenwe anyị\nd* kwubiri. A ga-enyefe obodo a nʼaka eze Babilọn, onye ga-eji ọkụ laa ya nʼiyi.’ 
\p  
\v 11 “Karịchasịa, gwa ndị ezinaụlọ eze Juda sị, ‘Nụrụnụ okwu \nd Onyenwe anyị\nd*.  
\v 12 Unu ụlọ Devid, otu a ka \nd Onyenwe anyị\nd* sịrị, 
\q1 “ ‘Kpeenụ ikpe ziri ezi\f + \fr 21:12 \ft Meenụ ka ikpe ziri ezi na-adịrị mmadụ niile kwa ụbọchị\f* kwa ụtụtụ niile; 
\q2 napụtanụ ndị a na-emegbu emegbu site nʼaka ndị na-emegbu ha. 
\q2 Napụtakwanụ ndị a na-apụnara ihe ha nwere site nʼaka ndị na-apụnara ha ihe ndị a. 
\q1 Ọ bụrụ na unu emeghị otu a, iwe m ga-abịakwasị unu, 
\q2 dịka ọkụ nʼihi ajọ omume unu, 
\q2 ọ dịkwaghị onye pụrụ ime ka ọ kwụsị. 
\q1  
\v 13 Edoola m onwe m megide gị, Jerusalem, 
\q2 gị onye bi nʼebe dị elu karịa ndagwurugwu a, 
\q2 onye bi nʼebe dị elu nke dị larịị, Otu a ka \nd Onyenwe anyị\nd* kwubiri. 
\q1 Gị onye na-asị “Onye pụrụ ibuso anyị agha? 
\q2 Onye kwa pụrụ ịbata nʼebe anyị e wusiri ike?” 
\q1  
\v 14 Aga m enye gị ahụhụ nke ruuru gị nʼihi ajọ omume gị, 
\q2 otu a ka \nd Onyenwe anyị\nd* kwubiri. 
\q1 Aga m amụnye ọkụ nʼoke ọhịa gị niile, 
\q2 nke ga-erechapụ ihe niile dị gị gburugburu.’ ” 
\c 22  
\s1 Ikpe ọmụma dịrị ndị eze ọjọọ 
\p  
\v 1 Ihe ndị a ka \nd Onyenwe anyị\nd* kwuru, “Jee nʼụlọeze Juda nọdụ nʼebe ahụ kwusaa ozi ndị a.  
\v 2 ‘Nụrụ okwu \nd Onyenwe anyị\nd*, nye gị, gị eze Juda, gị onye na-anọkwasị nʼocheeze Devid. Nụrụ ya, gị na ndịisi ọchịchị gị, na unu ndị niile na-esite nʼọnụ ụzọ ama ndị a na-apụ na-abatakwa.  
\v 3 Ihe ndị a ka \nd Onyenwe anyị\nd* kwuru, Meenụ ihe dị mma na ihe ziri ezi. Napụtanụ onye eji aka ike napụ ihe o nwere site nʼaka onye ahụ na-emegbu ya. Unu emejọkwala onye ọbịa, maọbụ mee ya ihe ike. Unu emekwala ndị na-enweghị nna, maọbụ ndị inyom di ha nwụrụ ihe ọjọọ. Unu awụsịkwala ọbara ndị aka ha dị ọcha nʼebe a.  
\v 4 Nʼihi na ọ bụrụ na unu elezie anya mee iwu ndị a niile, mgbe ahụ, ndị eze na-anọkwasị nʼelu ocheeze Devid ga-anọgide na-esite nʼọnụ ụzọ ama ndị a na-apụta, na-abata nʼelu ụgbọ agha ha, ma nʼelu ịnyịnya ha, ha na ndịisi ọchịchị ha, na ndị ha na-achị.  
\v 5 Ma ọ bụrụ na unu ajụ irube isi nye iwu ndị a, otu a ka \nd Onyenwe anyị\nd* kwubiri, eji m onwe m na-aṅụ iyi na ụlọeze a ga-aghọ mkpọmkpọ ebe.’ ” 
\p  
\v 6 Nʼihi na ihe ndị a ka \nd Onyenwe anyị\nd* kwuru banyere ụlọeze Juda, 
\q1 “Ọ bụ ezie na ịdị dịka Gilead nye m, 
\q2 dịka elu ugwu ukwu Lebanọn, 
\q1 aghaghị m ime gị ka ị dịrị ka ebe ikpofu ahịhịa, 
\q2 dịka obodo ndị mmadụ na-ebighị nʼime ya. 
\q1  
\v 7 Aga m ezite ndị mbibi ndị ga-abịa megide gị. 
\q2 Onye ọbụla nʼime ha ga-eji ngwa agha ya. 
\q1 Ha ga-egbutusịkwa osisi sida ọma gị niile, 
\q2 tụnye ha niile nʼime ọkụ. 
\p  
\v 8 “Ọtụtụ ndị si mba ọzọ bịa ga-agafe obodo a. Ha ga-ajụrịta ibe ha ajụjụ sị, ‘Gịnị mere \nd Onyenwe anyị\nd* ji mee obodo ukwuu a ihe ọjọọ dị otu a?’  
\v 9 Ọsịsa ha ga-enweta ga-abụ, ‘Ọ bụ nʼihi na ha gbakụtara ọgbụgba ndụ \nd Onyenwe anyị\nd* Chineke ha azụ, malite ịkpọ isiala na ife chi ndị ọzọ.’ ” 
\q1  
\v 10 Unu akwala akwa nʼihi eze ahụ nwụrụ anwụ, maọbụ ruo ụjụ nʼihi na ọ gaghị abụkwa eze unu, 
\q2 kama kwaanụ akwa nʼihi onye ahụ a dọtara nʼagha buru gaa mba ọzọ. 
\q1 Nʼihi na ọ gaghị alọghachi ọzọ; 
\q2 ọ gaghị ahụkwa ala ebe a mụrụ ya anya ọzọ. 
\m  
\v 11 Nʼihi na ihe ndị a ka \nd Onyenwe anyị\nd* kwuru banyere Shalum nwa Josaya, onye nọchiri anya nna ya dịka eze Juda, bụ onye ahụ e si nʼebe a buru gaa mba ọzọ, “Ọ gaghị alọtakwa ọzọ.  
\v 12 Ebe ahụ e buuru ya gaa ka ọ ga-anọ nwụọ. Ọ gaghị ahụkwa ala nke aka ya anya ọzọ.” 
\q1  
\v 13 “Ahụhụ na-adịrị onye ahụ na-ewu ụlọeze ya site nʼụzọ ajọ omume, 
\q2 nke jikwa ikpe na-ezighị ezi na-ewu ime ụlọ elu ya niile, 
\q1 onye ahụ nke na-eme ndị mmadụ rụọ ọrụ nʼefu, 
\q2 nke na-adịghị akwụ ha ụgwọ ọbụla nʼihi ọrụ ha. 
\q1  
\v 14 Onye na-asị, ‘Aga m ewuru onwe m ụlọeze buru ibu, 
\q2 nke ọnụụlọ dị nʼụlọ elu ya sara ezi mbara.’ 
\q1 Ya mere, ọ tinyere oghereikuku sara mbara nʼụlọ ahụ, 
\q2 jirikwa osisi sida machie elu ya, 
\q2 werekwa penti\f + \fr 22:14 \ft Ya bụ, mgba\f* na-acha uhie uhie chọọ ya mma. 
\b  
\q1  
\v 15 “Ị ga-abụ eze 
\q2 nʼihi na i nwere ọtụtụ osisi sida karịa ndị ọzọ? 
\q1 Nna gị o nweghị ihe oriri na ihe ọṅụṅụ? 
\q2 O mere ihe dị mma na ihe ziri ezi 
\q2 nʼihi ya ihe niile gaara ya nke ọma. 
\q1  
\v 16 O kwuchitere ọnụ ndị ogbenye na ndị nọ na mkpa, 
\q2 nke a mere na ihe niile gara nke ọma. 
\q1 Ọ bụghị nke a bụ ihe ọ pụtara bụ ịmara m? 
\q2 Ka \nd Onyenwe anyị\nd* kwupụtara 
\q1  
\v 17 Ma anya unu na obi unu 
\q2 adịghị nʼihe ọzọ ma ọ bụghị naanị nʼuru nʼezighị ezi 
\q1 nʼiwufu ọbara ndị aka ha dị ọcha, 
\q2 na imegbu ndị mmadụ, na iji aka ike pụnara ha ihe ha nwere.” 
\m  
\v 18 Ya mere, ihe ndị a ka \nd Onyenwe anyị\nd* kwuru banyere Jehoiakim nwa Josaya eze Juda: 
\q1 “Ha agaghị eruru ya uju sị, 
\q2 ‘Ewoo nwanne m nwoke! Ewoo nwanne m nwanyị!’ 
\q1 Ha agaghị eruru ya uju sị, 
\q2 ‘Ewoo nna anyị ukwu! Ewoo ịma mma ya!’ 
\q1  
\v 19 A ga-eli ya dịka e si eli ịnyịnya ibu. 
\q2 A ga-adọkpụrụ ozu ya nʼala tufuo ya 
\q2 nʼazụ ọnụ ụzọ ama Jerusalem.” 
\b  
\q1  
\v 20 “Gbagoruo na Lebanọn tie mkpu akwa, 
\q2 meenụ ka a nụ olu unu na Bashan, 
\q1 sitekwanụ na Abarim tie mkpu akwa 
\q2 nʼihi na e gweriela ndị niile unu na ha dị na mma. 
\q1  
\v 21 Adọrọ m gị aka na ntị nʼoge ahụ ị nọ na-eche na i guzo chịm, 
\q2 ma ị jụrụ ige ntị. 
\q1 Nke a bụkwa omume gị site na mgbe ị bụ nwantakịrị. 
\q2 Ị jụkwara irubere m isi. 
\q1  
\v 22 Oke ifufe ga-ebufu ndị ọzụzụ atụrụ gị niile, 
\q2 a ga-emekwa ka ndị gị na ha dị na mma gaa biri na mba ọzọ. 
\q1 Mgbe ahụ, ihere ga-eme gị, ị ga-aghọkwa onye e wedara nʼala 
\q2 nʼihi ajọ omume gị niile. 
\q1  
\v 23 Gị onye na-ebi na Lebanọn,\f + \fr 22:23 \ft Nke a bụ ụlọeze ahụ dị na Jerusalem, hụ nke a na \xt 1Ez 7:2\f* 
\q2 onye ebe obibi ya dị nʼụlọ e ji osisi sida wuo, 
\q1 lee ka i si\f + \fr 22:23 \ft Akwụkwọ ndị ọzọ ga-ede; lee ka ị si bụrụ onye a ga-emere ebere mgbe ihe mgbu\f* na-asụ ude mgbe ihe mgbu bịakwasịrị gị, 
\q2 ihe mgbu yiri nke nwanyị ime na-eme. 
\p  
\v 24 “Ma dịka m na-adị ndụ,” otu a ka \nd Onyenwe anyị\nd* kwubiri ya, “a sịkwarị na gị, bụ Jehoiakin, nwa Jehoiakim eze Juda, bụ mgbaaka akara m gbanyere na mkpịsịaka dị nʼaka nri m, aga m agbapụkwa gị,  
\v 25 were gị nyefee nʼaka ndị ahụ na-achọsi ndụ gị ike, bụ ndị ahụ ị na-atụ ụjọ ha. Aga m enyefe gị nʼaka Nebukadneza eze Babilọn na ndị Kaldịa.  
\v 26 Aga m atụfu gị na nne mụrụ gị, tụga unu na mba ọzọ dị iche site nʼobodo a nọ mụọ unu. Ebe ahụ ka unu ga-anọ nwụọ.  
\v 27 Unu agaghị alọghachikwa nʼala ahụ na-agụ unu agụụ ịlọghachi nʼime ya.” 
\q1  
\v 28 Nwoke a bụ Jehoiakin, ọ bụ ite tiwara etiwa, nke e lelịrị elelị, 
\q2 ihe onye ọbụla na-achọghị? 
\q1 Nʼihi gịnị ka a ga-eji tufuo ya na ụmụ ya, 
\q2 tụga ha na mba ha na-amaghị? 
\q1  
\v 29 Ala, ala, ala, 
\q2 nụrụ okwu \nd Onyenwe anyị\nd*. 
\q1  
\v 30 Ihe ndị a ka \nd Onyenwe anyị\nd* kwuru: 
\q1 “Detuo ya nʼakwụkwọ na nwoke a bụ onye gba aka nwa, 
\q2 nwoke nke ihe na-agaghị agara nke ọma nʼoge ndụ ya niile, 
\q1 nʼihi na o nweghị onye nʼime ụmụ ọ mụrụ nke ihe ga-agara nke ọma, 
\q2 o nwekwaghị onye nʼime ha ga-anọkwasị nʼocheeze Devid, 
\q2 maọbụ chịakwa ọzọ na Juda.” 
\c 23  
\s1 Onyenwe anyị Ezi omume Anyị 
\p  
\v 1 “Ahụhụ dịrị ndị ọzụzụ atụrụ ahụ na-achụsasị, ma na-ebibi igwe atụrụ m ha kwesiri ilekọtazi anya.” Otu a ka \nd Onyenwe anyị\nd* kwupụtara.  
\v 2 Ya mere, ihe ndị a ka \nd Onyenwe anyị\nd*, Chineke Izrel na-agwa ndị ọzụzụ atụrụ ahụ na-elekọta ndị m, “Ebe ọ bụ na unu akpasasịala igwe ewu na atụrụ m, chụsaa ha, kama ilekọtazi ha anya nke ọma, aga m ata unu ahụhụ nʼihi ihe ọjọọ ndị a unu mere.” Otu a ka \nd Onyenwe anyị\nd* kwubiri.  
\v 3 “Mụ onwe m ga-eji aka m chịkọta ndị m fọdụrụ nʼigwe ewu na atụrụ m site na mba ahụ niile m chụgara ha, kpọghachikwa ha nʼebe ịta nri ha, ebe ha ga-anọ mụbaa, dị ukwuu nʼọnụọgụgụ.  
\v 4 Aga m ahọpụtakwa ndị ọzụzụ atụrụ, ndị ga-elekọtazi ha anya. Egwu agaghị atụ ha, ọ dịkwaghị onye ga-emenye ha ụjọ. O nwekwaghị onye ga-akpafu akpafu nʼime ha.” Otu a ka \nd Onyenwe anyị\nd* kwubiri. 
\q1  
\v 5 “Ụbọchị ndị ahụ na-abịa,” ka \nd Onyenwe anyị\nd* kwupụtara, 
\q2 “mgbe m ga-eme ka Ngalaba na-eme ezi omume bilie nʼezinaụlọ Devid. 
\q1 Ọ ga-abụ Eze ga-eji amamihe chịa ndị ya. 
\q2 Ọ ga-eme ezi ihe, kpeekwa ikpe ziri ezi nʼala ahụ. 
\q1  
\v 6 Nʼụbọchị, ya ka a ga-azọpụta Juda, 
\q2 Izrel ga-ebikwa nʼudo. 
\q1 Nke a bụ aha a ga-akpọ ya: 
\q2 \nd Onyenwe anyị\nd* Onye Nzọpụta, bụ Ezi omume Anyị.\f + \fr 23:6 \ft Onyenwe anyị, bụ ezi omume anyị.\f* 
\b  
\m  
\v 7 “Nʼihi nke a, ụbọchị ahụ na-abịa,” ka \nd Onyenwe anyị\nd* kwupụtara, “mgbe ndị mmadụ na-agaghị asịkwa ọzọ, ‘Dịka \nd Onyenwe anyị\nd* na-adị ndụ, bụ onye sitere nʼala Ijipt dupụta ndị Izrel,’  
\v 8 ma ha ga-asị, ‘Dịka \nd Onyenwe anyị\nd* na-adị ndụ, bụ onye ahụ kpọlatara agbụrụ Izrel site nʼala dị nʼugwu, na mba dị iche iche ebe ọ chụgara ha.’ Mgbe ahụ, ha ga-ebi nʼala nke aka ha.” 
\s1 Ndị amụma ụgha. 
\p  
\v 9 Ma banyere ndị amụma, 
\q1 obi m na-agbawa nʼime m, 
\q2 ọkpụkpụ m na-amakwa jijiji nʼihi ha. 
\q1 Adị m dịka nwoke mmanya na-egbu, 
\q2 dịka onye ṅụbigara mmanya oke, 
\q1 nʼihi ihe na-eche ha site nʼaka \nd Onyenwe anyị\nd*, 
\q2 na site nʼokwu nsọ ya. 
\q1  
\v 10 Ndị jupụtara nʼala a bụ ndị na-akwa iko. 
\q2 Nʼihi ịbụ ọnụ ndị a niile ala a tọgbọrọ nʼefu, 
\q2 ahịhịa niile dị nʼọzara akpọnwụọla. 
\q1 Ndị amụma na-agbasokwa ihe ọjọọ. 
\q2 Ha na-egosikwa ike ha nʼụzọ na-ezighị ezi. 
\b  
\q1  
\v 11 “Nʼihi na ndị amụma na ndị nchụaja aghọọla ndị na-amaghị Chineke. 
\q2 Ọ bụladị nʼime ụlọnsọ ukwu m ka m na-ahụ ajọ omume ha.” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwupụtara. 
\q1  
\v 12 “Nʼihi ya, ụzọ ha na-agbaso ga-adị ka ebe na-amị amị; 
\q2 a ga-achụbanye ha nʼọchịchịrị 
\q2 ebe ahụ ka ha ga-anọkwa daa. 
\q1 Aga m eme ka ihe mbibi bịakwasị ha 
\q2 nʼafọ ahụ, a ga-ata ha ahụhụ.” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwubiri ya. 
\b  
\q1  
\v 13 “Ahụrụ m ihe arụ 
\q2 nʼetiti ndị amụma Sameria: 
\q1 Ha buru amụma site nʼike chi Baal, 
\q2 si otu a duba ndị m, bụ Izrel na mmehie. 
\q1  
\v 14 Ahụkwara m ihe jọgburu onwe ya 
\q2 nʼetiti ndị amụma nọ na Jerusalem. 
\q2 Ha na-ebi ndụ ịkwa iko, na ikwu okwu ụgha. 
\q1 Ha na-agba ndị ajọ omume ume, 
\q2 si otu a na-egbochi ha isi nʼihe ọjọọ ha tụgharịa. 
\q1 Ha niile dịka ndị Sọdọm nʼebe m nọ; 
\q2 ndị Jerusalem dịkwa ka ndị Gọmọra nʼihu m.” 
\p  
\v 15 Nʼihi nke a, ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwuru banyere ndị amụma a, 
\q1 “Aga m eme ka ha rie nri na-akụ ilu, 
\q2 meekwa ka ha ṅụọ mmiri e tinyere nsi, 
\q1 nʼihi na mmụọ nke amaghị Chineke esitela nʼaka ndị amụma nọ na Jerusalem 
\q2 gbasaa ruo ndị niile bi nʼala ahụ.” 
\p  
\v 16 Ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwuru, 
\q1 “Unu aṅala ntị nʼihe ndị amụma ahụ na-eburu unu nʼamụma, 
\q2 nʼihi na olileanya ha na-ewetara unu abụghị ezi olileanya. 
\q1 Ọhụ ha na-agwa unu na ha hụrụ bụ ihe ha chepụtara nʼobi ha, 
\q2 o sighị nʼọnụ \nd Onyenwe anyị\nd* rute ha 
\q1  
\v 17 Ha na-anọgide na-agwa ndị ahụ na-elelị m anya na-asị ha, 
\q2 ‘\nd Onyenwe anyị\nd* kwuru sị, unu ga-enwe udo.’ 
\q1 Ndị ahụ niile na-agbasokwa ụzọ isiike nke obi ha tụpụtara, 
\q2 ka ha na-agwakwa okwu sị, ‘O nweghị ihe ọjọọ ga-abịakwasị gị.’ 
\q1  
\v 18 Ma olee onye ọ bụ nʼetiti ndị amụma a nke na-abịaru \nd Onyenwe anyị\nd* nso, 
\q2 hụ ya anya maọbụ ịnụ ihe ọ na-ekwu? 
\q2 Onye kwa nʼetiti ha nwerela ike ṅaa ntị nụrụ okwu ya? 
\q1  
\v 19 Lee, \nd Onyenwe anyị\nd* na-ezite oke ifufe na-efesi ike, 
\q2 ọ bụ oke ifufe nke iwe ya, 
\q1 nke ga-abịa 
\q2 bufuo ndị ajọ omume a. 
\q1  
\v 20 \nd Onyenwe anyị\nd* agaghị akwụsị iwe iwe ya 
\q2 tutu ruo mgbe o mezuru 
\q2 ihe niile dị ya nʼobi. 
\q1 Nʼụbọchị ndị ahụ na-abịa nʼihu, 
\q2 unu ga-aghọta ihe ndị a niile nke ọma. 
\q1  
\v 21 Ọ bụghị m zitere ndị amụma a, 
\q2 ma ha na-ekwu na ọ bụ okwu si m nʼọnụ ka ha na-ekwu. 
\q1 O nwebeghị oge m ji gwa ha okwu, 
\q2 ma ha nọkwa na-ebu amụma. 
\q1  
\v 22 A sị na ha abịala nso guzo nʼebe ịgba izu nzuzo m, 
\q2 ha gaara ekwusara ndị m okwu m, 
\q1 nke gaara eme ka ha site nʼajọ omume ha tụgharịa, 
\q2 sitekwa nʼụzọ ọjọọ ha chigharịa. 
\b  
\q1  
\v 23 “Abụ m naanị Chineke na-anọ ha nso, 
\q2 ma adịghị m anọ nʼebe dị anya?” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwupụtara. 
\q1  
\v 24 “O nwere onye pụrụ izo onwe ya nʼebe nzuzo 
\q2 nke m na-enweghị ike ịhụ anya?” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwupụtara. 
\q1 “Ọ bụ na m anọghị nʼebe niile nʼeluigwe nakwa nʼụwa?” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwupụtara. 
\p  
\v 25 “Anụla m ka ndị amụma a, bụ ndị na-ebu amụma ụgha nʼaha m na-ekwu na-asị, ‘Arọrọ m nrọ! Arọrọ m nrọ!’  
\v 26 Ruo ole mgbe ka ihe dị otu a ga-adịgide nʼobi ndị amụma ndị a, ndị na-ebu amụma aghụghọ dị ha nʼobi?  
\v 27 Ha na-eche na nrọ ha na-akọrịtara ibe ha ga-eme ka ndị mmadụ chezọọ aha m, dịka ndị nna nna ha si chezọọ aha m site nʼịkpọ isiala nye Baal.  
\v 28 Ka onye amụma ahụ rọrọ nrọ kọgharịa nro ọ rọrọ. Otu a kwa, ka onye ahụ okwu m dị nʼọnụ ya nọgidekwa na-ekwusa ya nʼeziokwu. Nʼihi na gịnị ka okporo ọka na mkpụrụ ọka nwekọrọ?” Otu a ka \nd Onyenwe anyị\nd* kwupụtara.  
\v 29 “Okwu m ọ dịghị ka ọkụ? Otu a ka \nd Onyenwe anyị\nd* kwupụtara,\f + \fr 23:29 \ft Maọbụ, \fqa na-ajụ ajụjụ sị\f* Okwu m ọ dịkwaghị ka okporo igwe\f + \fr 23:29 \ft Lit. \fqa Hama\f* nke na-etiwasị nkume?” 
\p  
\v 30 Nʼihi ya, \nd Onyenwe anyị\nd* kwubiri sị, “Ana m edo onwe m megide ndị amụma na-esite nʼọnụ ibe ha na-ezute okwu ha na-ekwu, ma na-asị na ọ bụ nʼọnụ m ka ha si nata ya.  
\v 31 E, otu a ka \nd Onyenwe anyị\nd* kwubiri, Ana m edo onwe m megide ndị amụma ahụ ire ha na-ekwu ọtụtụ okwu, ndị ahụ na-asịkwa, ‘Ọ bụ ihe si nʼọnụ \nd Onyenwe anyị\nd* pụta.’  
\v 32 Nʼezie, ana m edo onwe m megide ndị ahụ niile na-ebu amụma nro ụgha.” Otu a ka \nd Onyenwe anyị\nd* kwupụtara. “Ha ji okwu ụgha ha na-agwa ndị m okwu, na-eduhie ha, ma ọ bụghị m họpụtara ha. Ọ bụkwaghị m zitere ha. Okwu ha adịghịkwa abara ndị m uru ọbụla.” Otu a ka \nd Onyenwe anyị\nd* kwupụtara. 
\s1 Ndị amụma ụgha na ịjụ ase ụgha. 
\p  
\v 33 “Mgbe ndị a, maọbụ ndị amụma ha, maọbụ ndị nchụaja ha, jụrụ gị ajụjụ sị gị, ‘Gịnị bụ ozi i si nʼọnụ \nd Onyenwe anyị\nd* nata?’ Ị ga-asa ha sị, ‘Ozi nke ole?\f + \fr 23:33 \ft Akwụkwọ ụfọdụ na-asị, unu onwe unu bụ isi okwu ya\f* Aga m agbakụta unu azụ, ya bụ ihe \nd Onyenwe anyị\nd* kwubiri.’  
\v 34 Ọ bụrụ na onye amụma maọbụ onye nchụaja maọbụ onye ọbụla ọzọ ekwuo sị, ‘Ihe dị otu a bụ ozi\f + \fr 23:34 \ft Maọbụ, \fqa okwu\f* si nʼọnụ \nd Onyenwe anyị\nd*,’ aga m ata onye ahụ kwuru okwu ahụ na ndị ezinaụlọ ya ahụhụ.  
\v 35 Ihe ndị a bụ ihe unu na-agwarịta onwe unu nʼotu nʼotu. Ọ bụ ihe enyi na-agwa enyi ya, na ihe nwanna na-agwa nwanna Izrel ibe ya. Unu na-asị, ‘Gịnị bụ ọsịsa \nd Onyenwe anyị\nd* nyere?’ maọbụ, ‘Gịnị bụ okwu e si nʼọnụ \nd Onyenwe anyị\nd* nata?’  
\v 36 Kwụsịnụ ịjụgharị ajụjụ banyere ihe \nd Onyenwe anyị\nd* kwuru, nʼihi na okwu onye ọbụla nʼime unu kwuru na-aghọrọ onye ahụ ihe si nʼọnụ \nd Onyenwe anyị\nd* pụta. Site nʼụzọ dị otu a unu na-agbanwe ma na-asụgharịkwa okwu Chineke dị ndụ isi, bụ okwu \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, onye bụ Chineke anyị.  
\v 37 Ihe ndị a niile bụ ihe unu na-ajụkarị onye amụma, ‘Gịnị bụ ọsịsa \nd Onyenwe anyị\nd* nyere gị? Maọbụ, gịnị ka \nd Onyenwe anyị\nd* kwuru?’  
\v 38 Ọ bụ ezie na unu na-ekwu sị, ‘Ihe ndị a bụ ozi si nʼaka \nd Onyenwe anyị\nd*,’ ma lee ihe \nd Onyenwe anyị\nd* na-ekwu: Unu na-ekwu okwu ndị a, ‘Ihe a bụ ozi si nʼaka \nd Onyenwe anyị\nd*,’ ọ bụladị mgbe m gwarala unu si unu asịkwala ‘Ihe ndị a bụ ozi nʼaka \nd Onyenwe anyị\nd*.’  
\v 39 Ya mere, mụ onwe m ga-echezo unu kpamkpam ma sitekwa nʼihu m chụpụ unu na obodo a nke m nyere unu na nna nna unu ha.  
\v 40 Aga m eme ka ịta ụta ebighị ebi bịakwasị unu. Aga m etinyekwa unu nʼọnọdụ ihere nke ga-adịgide ruo ebighị ebi, e, ọnọdụ ihere nke a na-agaghị echefu echefu.” 
\c 24  
\s1 Nkata fiig abụọ 
\p  
\v 1 Emesịa, \nd Onyenwe anyị\nd* gosiri m nkata fiig abụọ, nke a dọbara nʼihu ụlọnsọ \nd Onyenwe anyị\nd*. Nʼoge a, Nebukadneza eze Babilọn esitelarị na Jerusalem dọkpụrụ Jehoiakin nwa Jehoiakim, eze Juda, na ndịisi Juda, na ndị ọka, na ndị ụzụ, mee ka ha gaa biri na Babilọn, nke dị na mba ọzọ.  
\v 2 Otu nkata nwere mkpụrụ fiig mara mma, dịka ndị ahụ na-ebu ụzọ acha, nkata nke ọzọ nwere mkpụrụ fiig nke jọrọ njọ, ha jọrọ njọ na mmadụ enweghị ike ịracha ha. 
\p  
\v 3 Mgbe ahụ, \nd Onyenwe anyị\nd* jụrụ m ajụjụ sị m, “Jeremaya, gịnị ka ị hụrụ?” 
\p Azara m sị ya, “Ahụrụ m mkpụrụ fiig. Ụfọdụ dị nnọọ ezi mma, ma ndị ọzọ jọrọ njọ. Ha adịghịkwa mma nracha.” 
\p  
\v 4 Mgbe ahụ, okwu \nd Onyenwe anyị\nd* ruru m ntị, sị,  
\v 5 “Ihe ndị a ka \nd Onyenwe anyị\nd*, bụ Chineke Izrel kwuru: Ndị ahụ m mere ka e si na Juda dọta nʼagha, ndị e buuru gaa nʼala Kaldịa dị m dịka mkpụrụ osisi fiig ndị a mara mma.  
\v 6 Anya m ga-adịkwasị ha nʼahụ ịhụ na ihe gaara ha nke ọma. Aga m akpọghachitekwa ha nʼala a. Aga m ewulikwa ha elu ghara ikwada ha; Aga m akụ ha dịka osisi ghara ihopu ha.  
\v 7 Aga m enye ha ụdị obi ha ga-eji mata m, na m bụ \nd Onyenwe anyị\nd*. Ha ga-abụ ndị m, mụ onwe m ga-abụkwa Chineke ha. Nʼihi na obi ha niile ka ha ga-eji lọghachikwute m. 
\p  
\v 8 “ ‘Ma dịka fiig ọjọọ ndị a, bụ ndị dị njọ nke ukwuu na-enweghị ike iri ha eri,’ \nd Onyenwe anyị\nd* sịrị, ‘otu a ka m gaa emeso Zedekaya, eze Juda, na ndịisi ọchịchị ya, na ndị ahụ niile fọdụrụ ndụ na Jerusalem, ma ha bi nʼime ya, maọbụ biri nʼIjipt.  
\v 9 Aga m eme ka ha ghọọrọ alaeze niile nke ụwa ihe ịsọ oyi, na ihe na-eweta obi ọjọọ. Ha ga-aghọ ihe ịta ụta, na ihe e ji akọ akụkọ, na ihe nkọcha na ihe ịbụ ọnụ nʼebe ọbụla m mere ka ha gaa biri.  
\v 10 Aga m ezigakwa mma agha na ụnwụ na ọrịa na-efe efe nʼetiti ha, tutu ruo mgbe e mere ka ha gwụsịa nʼelu ala ahụ nke m nyere ha, nyekwa ndị bụ nna nna ha.’ ” 
\c 25  
\s1 Iri afọ asaa nke ịdọta nʼagha 
\p  
\v 1 Okwu ruru Jeremaya ntị banyere ndị Juda niile, nʼafọ nke anọ nke ọchịchị eze Jehoiakim, nwa Josaya na Juda. Ọ bụkwa nʼafọ nke mbụ nke ọchịchị eze Nebukadneza na Babilọn.  
\v 2 Ya mere, ihe ndị a ka Jeremaya, bụ onye amụma gwara ndị Juda na ndị niile bi na Jerusalem:  
\v 3 Kemgbe afọ iri abụọ na atọ, sitekwa nʼafọ iri na atọ nke ọchịchị eze Josaya nwa Amọn, bụ eze Juda ruo taa, ka okwu \nd Onyenwe anyị\nd* ruru m ntị, a gwara m unu okwu, mgbe na mgbe, ma unu jụrụ ige ntị nʼihe m gwara unu. 
\p  
\v 4 Ọ bụkwa ezie na \nd Onyenwe anyị\nd* eziterela unu ndị ohu ya bụ ndị amụma site nʼoge ruo nʼoge ma unu ajụla ige ntị. Unu jụkwara ịṅa ntị nʼihe ha na-ekwu.  
\v 5 Ozi ha ziri unu bụ nke a, “Unu niile nʼotu nʼotu sitenụ nʼụzọ ọjọọ unu na ndụ ọjọọ unu tụgharịa, ka unu nwee ike ibigide nʼala a \nd Onyenwe anyị\nd* nyere unu na nna nna unu ha ruo mgbe ebighị ebi.  
\v 6 Unu agbasola maọbụ fee, maọbụ kpọọ isiala nye chi ndị ọzọ; unu ejila arụsị unu ji aka unu mee kpasuo m iwe, ka m ghara imerụ unu ahụ. 
\p  
\v 7 “Ma unu jụrụ ige m ntị,” otu a ka \nd Onyenwe anyị\nd* kwupụtara. “Unu ejirila arụsị unu ji aka unu mee kpasuo m iwe, si otu a wetara onwe unu mmerụ ahụ.” 
\p  
\v 8 Ya mere, \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile na-asị, “Ebe ọ bụ na unu ajụla ige ntị nʼokwu m.  
\v 9 Aga m akpọku ndị ahụ si nʼugwu, ha na ohu m bụ Nebukadneza, eze Babilọn.” Otu a ka \nd Onyenwe anyị\nd* kwubiri, “Aga m eme ka ha bịa megide ala a, na ndị bi nʼime ya. Ha ga-emegidekwa mba niile gbara ala a gburugburu. Aga m ebibi ha niile kpamkpam, mee ha ka ha ghọọ ihe iju anya, na ihe a na-elelị. Ha ga-aghọkwa mkpọmkpọ ebe ruo mgbe ebighị ebi.  
\v 10 Aga m emekwa ka olu obi ụtọ na ọṅụ, na olu ndị ikom na ndị inyom na-alụ di na nwunye, na olu ndị na-akwọ ọka, na ìhè nke oriọna na-enye, hapụkwa ịdị nʼime ya.  
\v 11 Ala a niile ga-aghọ mkpọmkpọ ebe tọgbọrọ nʼefu, mba ndị a niile ga-ejere eze Babilọn ozi iri afọ asaa. 
\p  
\v 12 “Ma mgbe iri afọ asaa zuru, aga m ata eze Babilọn na mba ya, bụ ala ndị Babilọn, ahụhụ nʼihi ajọ omume ha,” otu a ka \nd Onyenwe anyị\nd* kwubiri, “Aga m emekwa ka ala ahụ ghọọ mkpọmkpọ ebe ruo mgbe ebighị ebi.  
\v 13 Aga m emekwa ka ihe niile m buru ụzọ kwuo megide ala ahụ bịakwasị ya, bụ ihe niile e dere nʼakwụkwọ a, na ihe niile Jeremaya buru nʼamụma megide mba niile dị iche iche.  
\v 14 A ga-eme ka ha ghọọ ndị ohu nye mba dị iche iche na nke ndị eze dị ukwuu. Aga m akwụghachikwa ha dịka omume ha si dị, na dịka akaọrụ ha si dịkwa.” 
\s1 Iko ọnụma Chineke 
\p  
\v 15 Ihe ndị a ka \nd Onyenwe anyị\nd*, Chineke Izrel gwara m, “Nara m iko a dị m nʼaka, nke a gbajuru mmanya ọnụma m, gaa mee ka mba niile m zigara gị ijekwuru ṅụrụ site na mmanya ọnụma m dị nʼime ya.  
\v 16 Mgbe ha ṅụrụ ya, ha ga-adagharị, malitekwa ịyị ara nʼihi mma agha, nke m ga-ezite nʼetiti ha.”  
\v 17 Ya mere, esi m nʼaka \nd Onyenwe anyị\nd* nara iko ahụ, meekwa ka mba ndị ahụ niile o ziri m ka m jekwuru ṅụrụ ihe dị nʼime ya. 
\b  
\li1  
\v 18 Jerusalem na obodo Juda niile, na ndị eze ha, na ndịisi ọchịchị ha, si nʼiko ahụ ṅụrụ ihe dị nʼime ya, nʼihi ime ka e bibie ha, ka ha ghọọ ihe iju anya, na ihe nkọcha, na ihe a bụrụ ọnụ, dịka ha dị taa. 
\li1  
\v 19 Fero, eze Ijipt, na ndị na-ejere ya ozi, na ndịisi ọchịchị ya, na ndị ya niile,  
\v 20 na ndị mba ọzọ niile bi nʼebe ahụ; 
\li1 na ndị eze Uz; 
\li1 na ndị eze ndị Filistia niile, bụ nke ndị Ashkelọn, na Gaza, na Ekrọn, na ndị fọdụrụ nʼime Ashdọd. 
\li1  
\v 21 Ndị eze Edọm, na Moab, na ndị Amọn; 
\li1  
\v 22 na ndị eze Taịa na Saịdọn, 
\li1 na ndị eze obodo ha dị nʼakụkụ osimiri, nke dị nʼofe nke ọzọ; 
\li1  
\v 23 na ala Dedan, na Tema, na Buz, na ndị niile bi nʼebe dị anya. 
\li1  
\v 24 Na ndị eze Arebịa, na ndị eze mba niile ndị ahụ bi nʼọzara; 
\li1  
\v 25 na ndị eze Zimri, na Elam, na Midia; 
\li1  
\v 26 na ndị eze ala dị nʼugwu, na mba dị nso, na mba dị anya, ha niile nʼotu nʼotu, na alaeze niile dị nʼụwa. 
\li1 Mgbe eze ndị a niile ṅụtụrụ site nʼihe dị nʼiko ahụ, eze Sheshak ga-esitekwa na ya ṅụrụ. 
\b  
\p  
\v 27 “Mgbe ahụ, gwakwa ha sị, ‘Ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, bụ Chineke Izrel kwuru: Ṅụọnụ, ṅụbiganụ oke; gbọọkwanụ agbọọ, daanụ nʼala ebe unu na-agaghị esi bilitekwa ọzọ, nʼihi mma agha m ga-ezite nʼetiti unu.’  
\v 28 Ọ bụrụ na ha ajụ ịnara gị iko a site na ya ṅụtụ ihe dị ya nʼime, gwa ha sị, ‘Unu ga-aṅụrịrị ya, nʼihi na otu a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwuru.  
\v 29 Lee, ana m amalite ime ka mbibi bịakwasị obodo ahụ a kpọkwasịrị aha m. Ma unu ga-esi aṅaa gbanarị ahụhụ? Unu agaghị agbanarị ahụhụ, nʼihi na ana m enye iwu ka e webata mma agha nʼetiti ndị niile bi nʼụwa. Otu a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwubiri.’ 
\p  
\v 30 “Ugbu a buo amụma ndị a niile megide ha, sị ha, 
\q1 “ ‘\nd Onyenwe anyị\nd* ga-esi nʼelu bigbọọ; 
\q2 ọ ga-esitekwa nʼebe obibi ya dị nsọ mee ka olu ya daa ụda. 
\q2 Ọ ga-ebigbọsị ike megide ala ya 
\q1 Ọ ga-eti mkpu dịka ndị ahụ na-azọcha mkpụrụ vaịnị; 
\q2 ọ ga-eti mkpu megide ndị niile bi nʼụwa. 
\q1  
\v 31 Ụda mkpọtụ ahụ ga-eru na nsọtụ niile nke ụwa, 
\q2 nʼihi na \nd Onyenwe anyị\nd* ga-ebo mba niile nke ụwa ebubo. 
\q1 Ọ ga-eme ka ikpe ọmụma rute mmadụ niile, 
\q2 meekwa ka e jiri mma agha bibie ndị ajọ omume.’ ” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwubiri. 
\p  
\v 32 Ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwuru, 
\q1 “Lee, mbibi na-agbasa 
\q2 site nʼotu mba na-eru na mba ọzọ; 
\q1 oke ifufe na-abịakwa 
\q2 site na nsọtụ niile nke ụwa.” 
\m  
\v 33 Nʼoge ahụ, ndị ahụ \nd Onyenwe anyị\nd* ga-egbu ga-atọgbọrọ nʼebe niile, site nʼotu nsọtụ nke ụwa ruo na nke ọzọ. A gaghị eli ha, o nwekwaghị onye ga-akwa ha. Kama ha ga-atọgbọrọ nʼala dịka unyi. 
\q1  
\v 34 Kwasienụ akwa ike, unu ndị ọzụzụ atụrụ, tiekwanụ mkpu akwa; 
\q2 tụrụọnụ onwe unu nʼala, unu ndị ndu nke igwe ewu na atụrụ. 
\q1 Nʼihi na oge a ga-egbu unu eruola, 
\q2 unu ga-adakwa tiwasịa dịka ite aja. 
\q1  
\v 35 Ndị ọzụzụ atụrụ agaghị enwe ebe ha ga-agbaga ọsọ; 
\q2 ndị ndu igwe ewu na atụrụ agaghị enwekwa ebe ha ga-ezo onwe ha. 
\q1  
\v 36 Geenụ ntị ka unu nụrụ ịkwa akwa ndị ọzụzụ atụrụ, 
\q2 geenụ ntị nụrụ mkpu akwa ndị ndu igwe ewu na atụrụ, 
\q2 nʼihi na \nd Onyenwe anyị\nd* na-ebibi ebe ịta nri ha. 
\q1  
\v 37 Ebe mmakpu ọma niile nke anụ ụlọ ga-aghọkwa mkpọmkpọ ebe, 
\q2 nʼihi oke iwe nke \nd Onyenwe anyị\nd*. 
\q1  
\v 38 Ọ ga-apụkwute ha, dịka ọdụm si esi nʼebe ndina ya na-apụta ịchụ anụ ọhịa. 
\q2 Ọ ga-eme ka ala ha ghọọ mkpọmkpọ ebe, 
\q1 nʼihi mma agha nke onye mmegbu, 
\q2 na nʼihi oke iwe \nd Onyenwe anyị\nd*. 
\c 26  
\s1 Mba ọnwụ a baara Jeremaya 
\p  
\v 1 Na mmalite oge ahụ, Jehoiakim nwa Josaya eze Juda bidoro ịchị ndị Juda, \nd Onyenwe anyị\nd* mere ka okwu ya rute Jeremaya ntị.  
\v 2 Ihe ndị a ka \nd Onyenwe anyị\nd* kwuru, “Guzo nʼogige ụlọnsọ \nd Onyenwe anyị\nd*. Nọdụ nʼebe ahụ gwa ndị niile si nʼobodo Juda bịa ịkpọ isiala nʼụlọnsọ \nd Onyenwe anyị\nd* okwu. Gwa ha ihe ahụ niile m nyere gị nʼiwu. Mee ka ihe ndị ahụ niile m nyere gị nʼiwu rute ha ntị, na-afọdụghị otu.  
\v 3 Ma eleghị anya ha ga-anụ, si na mmehie ha chegharịa. Mgbe ahụ, mụ onwe m ga-eme ka ihe ọjọọ ahụ m na-ezube na ọ ga-abịakwasị ha ghara ịbịakwasị ha.  
\v 4 Gwa ha sị, ‘Otu a ka \nd Onyenwe anyị\nd* kwuru: Ọ bụrụ na unu ajụ ige m ntị, jụkwa ịgbaso iwu m, nke m nyere unu.  
\v 5 Ọ bụrụkwa na unu ajụ ige ntị nʼokwu ndị ohu m bụ ndị amụma ahụ m ziteere unu site nʼoge ruo nʼoge (ndị unu nọgidekwara jụ ige ntị),  
\v 6 mgbe ahụ, aga m eme ka ụlọnsọ a dịrị ka Shaịlo. Aga m emekwa ka obodo a bụrụ obodo a bụrụ ọnụ nʼetiti mba niile dị nʼụwa.’ ” 
\p  
\v 7 Ndị nchụaja, na ndị amụma, na ndị mmadụ ndị ọzọ nọ nʼụlọnsọ \nd Onyenwe anyị\nd* nụrụ mgbe Jeremaya kwuru okwu ndị a niile.  
\v 8 Mgbe Jeremaya kwusiri okwu ndị ahụ \nd Onyenwe anyị\nd* sị ya kwuo, ndị nchụaja ahụ, na ndị mmadụ ndị ọzọ, na ndị amụma ahụ niile, jidere ya sị ya, “Ị ghaghị ịnwụ!  
\v 9 Gịnị mere i ji buo amụma na ụlọnsọ a ga-adị ka Shaịlo? Gịnịkwa mere i ji akwado na obodo a ga-aghọ mkpọmkpọ ebe, nke onye ọbụla na-agaghị ebikwa nʼime ya?” Nʼoge ahụ, ndị mmadụ ahụ niile gbara Jeremaya gburugburu nʼụlọnsọ \nd Onyenwe anyị\nd*. 
\p  
\v 10 Mgbe ndịisi ọchịchị Juda nụrụ ihe ndị a na-eme, ha sitere nʼụlọeze bilie pụọ, jee nʼụlọnsọ \nd Onyenwe anyị\nd*. Mgbe ha ruru nʼebe ahụ, ha weere ọnọdụ nʼọnụ ụzọ ama ọhụrụ nke dị nʼụlọnsọ \nd Onyenwe anyị\nd*.  
\v 11 Mgbe ahụ, ndị nchụaja na ndị amụma gwara ndịisi ọchịchị ahụ okwu sị ha: “O kwesiri ka a maa nwoke a ikpe ọnwụ, nʼihi na o buru amụma megide obodo a. Unu onwe unu ji ntị unu nụrụ ihe o kwuru.” 
\p  
\v 12 Mgbe ahụ, Jeremaya gwara ndịisi ọchịchị ahụ na mmadụ niile nọ nʼebe ahụ okwu sị ha, “Ọ bụ \nd Onyenwe anyị\nd* zitere m ibu amụma megide ụlọnsọ a na obodo a. Okwu niile m kwuru, nke unu nụrụ, bụ ihe \nd Onyenwe anyị\nd* ziri m ikwu.  
\v 13 Ma ọ bụrụ na unu emee ka ụzọ unu na omume unu zie ezi, ọ bụrụ na unu erube isi nye \nd Onyenwe anyị\nd* Chineke unu, mgbe ahụ, \nd Onyenwe anyị\nd* ga-eme ka ihe ọjọọ ahụ o zubere na ọ ga-abịakwasị unu ghara ịbịakwasị unu.  
\v 14 Ma nʼebe mụ onwe m nọ, lee adị m unu nʼaka, jirinụ m mee ihe ọbụla ziri unu ezi nʼanya nke dịkwa mma nʼanya unu.  
\v 15 Ma ghọtakwanụ nke ọma, na ọ bụrụ na unu emee ka m nwụọ, unu ga-eweta ikpe ọmụma nke igbu onye aka ya dị ọcha nʼisi unu. Ikpe ọmụma ga-adịkwara obodo a na ndị bi nʼime ya, nʼihi na eziokwu, \nd Onyenwe anyị\nd* zitere m ikwupụta na ntị unu okwu ndị a niile.” 
\p  
\v 16 Mgbe ahụ, ndịisi ọchịchị na ndị mmadụ ahụ niile gwara ndị nchụaja na ndị amụma okwu sị ha, “O kwesighị ka a maa nwoke a ikpe ọnwụ nʼihi na ọ gwara anyị okwu site nʼaha \nd Onyenwe anyị\nd* Chineke anyị.” 
\p  
\v 17 Ụfọdụ nʼime ndị okenye nọ nʼebe ahụ pụtara nʼihu ọha mmadụ ahụ gwa ha okwu sị,  
\v 18 “Maịka onye Moreshet buru amụma nʼoge Hezekaya, bụ eze Juda. Ọ gwara ndị Juda niile, sị ha, ‘Otu a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwuru: 
\q1 “ ‘A ga-akọgharị Zayọn dịka ala ubi. 
\q2 Jerusalem ga-aghọ ebe e kpokọtara nkume na ngwongwo ụlọ dakpọrọ adakpọ, 
\q2 ugwu nke ụlọnsọ ukwu ahụ ga-aghọ ebe dị elu nke oke ọhịa tochiri.’ 
\m  
\v 19 “Hezekaya bụ eze Juda, na ndị Juda niile, ha mere ya ka ọ nwụọ? Hezekaya ọ tụghị egwu \nd Onyenwe anyị\nd*, rịọọ amara na ihuọma ya? Ọ bụ na \nd Onyenwe anyị\nd* atụgharịghị uche, mee ka ihe ọjọọ o kwuru megide ya gharakwa imezu? Ma anyị na-achọ iwetara onwe anyị ihe ọjọọ nke oke mbibi.” 
\p  
\v 20 (Ụraya nwa Shemaya, onye si Kiriat Jearim pụta, bụkwa onye ọzọ buru amụma site nʼaha \nd Onyenwe anyị\nd*. Amụma o buru megide obodo a na ala a bụkwa ụdị amụma nke Jeremaya na-ebu.  
\v 21 Mgbe Jehoiakim bụ eze na ndịisi ọchịchị nụrụ amụma Ụraya na-ebu, ha gbalịrị ijide ya gbuo ya, ma Ụraya nụrụ ihe ha zubere ime. Ya mere, Ụraya nụrụ ya gbapụ ọsọ gbalaa Ijipt nʼihi egwu.  
\v 22 Ma eze bụ Jehoiakim, zipụrụ Elnatan nwa Akboa na ụfọdụ ndị ikom ọzọ ka ha gaa Ijipt jide Ụraya.  
\v 23 Ha si nʼIjipt kpọlata Ụraya, duru ya gaa nʼihu Jehoiakim bụ eze, onye nyere iwu ka e jiri mma agha gbuo ya. A tụnyere ozu ya nʼebe a na-eli ndị mmadụ efu nʼala ahụ.) 
\p  
\v 24 Ma otu ọ dị, Ahikam nwa Shefan, dịnyeere Jeremaya, nʼihi ya a raraghị Jeremaya nye nʼaka ndị mmadụ ka ha gbuo ya. 
\c 27  
\s1 Juda ga-aghọ onye na-ejere Nebukadneza ozi 
\p  
\v 1 Na mmalite ọchịchị Zedekaya, nwa Josaya eze Juda, okwu ndị a si nʼọnụ \nd Onyenwe anyị\nd* rute Jeremaya ntị.  
\v 2 Ihe ndị a ka \nd Onyenwe anyị\nd* gwara m, “Jiri akpụkpọ anụ dị warawara na ụfọdụ okporo igwe, meere onwe gị ụdị agbụ ahụ a na-amanye ụmụ ehi nʼolu,\f + \fr 27:2 \ft Lit. \fqa Yoku\f* nyakwasị ya nʼolu gị.  
\v 3 Mgbe ahụ, zigara ndị eze Edọm, na Moab, na Amọn, na Taịa, na Saịdọn ozi site nʼọnụ ndị ozi ha bịara Jerusalem iwetara Zedekaya eze Juda ozi.  
\v 4 Zie ha ozi ha ga-ezi ndị nwe ha, sị, ‘Ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, bụ Chineke Izrel kwuru, sị, “Zienụ ndị nna unu ukwu ozi a, sị,  
\v 5 Ọ bụ site nʼike aka m, na site nʼogwe aka m, nke e setịrị eseti, ka m ji mee ụwa, na mmadụ, na anụmanụ dị nʼime ya. Mụ onwe m ka ọ dịkwara ikpebi itinye ha niile nʼaka onye ọbụla m họpụtara dịka o si dị m mma.  
\v 6 Ugbu a, ana m ewere alaeze unu niile nyefee ya nʼaka onye na-ejere m ozi bụ Nebukadneza eze Babilọn; aga m emekwa ka ọ bụladị ụmụ ajọ anụ ọhịa mee ihe o nyere nʼiwu.  
\v 7 Mba niile ga-akpọ isiala nye ya; ha ga-akpọkwa isiala nye nwa ya na nwa nwa ya, tutu ruo mgbe m kpebiri na oge ha ezuola. Mgbe ahụ, aga m eme ka ọtụtụ mba na ọtụtụ ndị eze merie ya. 
\p  
\v 8 “ ‘ “Ma ọ bụrụkwa na mba maọbụ alaeze ọbụla ajụ ife Nebukadneza, bụ eze Babilọn, maọbụ jụ ijere ya ozi dịka ohu,\f + \fr 27:8 \ft Ka o si chọọ\f* aga m eji mma agha na ụnwụ na ọrịa na-efe efe, taa mba ahụ ahụhụ, tutu ruo mgbe m bibiri ya site nʼaka ya. Otu a ka \nd Onyenwe anyị\nd* kwubiri.  
\v 9 Ya mere, unu aṅala ndị amụma unu, na ndị na-ajụ mmụọ ase, na ndị na-akọwara unu nrọ, na ndị mmụọ ọjọọ si nʼọnụ ha ekwu okwu, na ndị mgbaasị ntị. Unu aṅala ha ntị mgbe ha na-asị unu, ‘Unu agaghị abụ ndị ohu eze Babilọn.’  
\v 10 Nʼihi na ọ bụ naanị amụma ụgha ka ha na-eburu unu, okwu ụgha nke ga-eme ka e site nʼala unu wezuga unu, bulaa unu ala dị anya. Aga m esi nʼala unu chụsaa unu. Unu ga-alakwa nʼiyi.  
\v 11 Ma ọ bụrụ na mba ọbụla ekwere ịbụ ohu eze Babilọn, kwenyekwa ife ya ofufe, mba ahụ ka m ga-eme ka ọ nọgide nʼala nke aka ya. Ọ ga-akọ ala ahụ, birikwa nʼime ya. Otu a ka \nd Onyenwe anyị\nd* kwubiri.” ’ ” 
\p  
\v 12 Otu ozi ahụ ka m ziri Zedekaya, bụ eze Juda. Asịrị m, “Were olu\f + \fr 27:12 \ft Ya bụ, onwe\f* gị nyefee eze Babilọn nʼaka dịka ohu, feekwa ya na ndị ya, ị ga-adịkwa ndụ.  
\v 13 Nʼihi gịnị ka gị na ndị gị ga-eji nwụọ site na mma agha, na site nʼụnwụ na ọrịa na-efe efe, dịka nke \nd Onyenwe anyị\nd* kwurula banyere mba ọbụla nke na-agaghị efe eze Babilọn?  
\v 14 Egela ntị nʼokwu ndị amụma na-agwa gị sị, ‘Unu agaghị efe eze Babilọn,’ nʼihi na ọ bụ okwu ụgha ka ha na-agwa unu.  
\v 15 ‘Ọ bụghị m zitere ha,’ otu a ka \nd Onyenwe anyị\nd* kwupụtara. ‘Ha ji aha m na-ebu amụma ụgha. Nʼihi ya, aga m achụpụ unu, unu ga-alakwa nʼiyi, unu na ndị amụma ahụ na-eburu unu amụma.’ ” 
\p  
\v 16 Mgbe ahụ, agwara m ndị nchụaja na ndị mmadụ niile okwu sị ha, “Ihe ndị a ka \nd Onyenwe anyị\nd* kwuru: Unu egela ndị amụma ahụ ntị, bụ ndị na-asị unu, ‘Na mgbe na-adịghị anya a ga-ebughachi ngwongwo ahụ e si nʼụlọnsọ \nd Onyenwe anyị\nd* bulaa Babilọn.’ Ọ bụ amụma ụgha ka ha na-eburu unu.  
\v 17 Unu egela ha ntị. Feenụ eze Babilọn, nʼihi na ọ bụ naanị site nʼụzọ ahụ ka unu ga-esi dịrị ndụ. Nʼihi gịnị ka unu ga-eji kwenye ka obodo a ghọọ mkpọmkpọ ebe?  
\v 18 Ọ bụrụ nʼezie na ọ bụ okwu \nd Onyenwe anyị\nd* si nʼọnụ ndị amụma a na-apụta, ha rịọọnụ \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile arịrịọ ka ọ hapụ ikwe ka e bukọrọ ngwongwo fọdụrụ nʼime ụlọnsọ nakwa ndị fọdụrụ nʼụlọeze Juda, na nʼime Jerusalem bulaa Babilọn.  
\v 19 Nʼihi na ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwuru banyere ogidi niile ndị ahụ, na Oke osimiri bronz ahụ, na ihe ndọkwasị niile, na ihe niile fọdụrụ nʼobodo a,  
\v 20 nke Nebukadneza, bụ eze Babilọn na-eburughị mgbe o sitere na Juda na Jerusalem, dọkpụrụ Jehoiakin nwa Jehoiakim, bụ eze Juda, na ndị niile a na-asọpụrụ bulaa Babilọn.  
\v 21 E, ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile bụ Chineke Izrel kwuru banyere ihe niile fọdụrụ nʼụlọnsọ \nd Onyenwe anyị\nd*, na ndị fọdụrụ nʼụlọeze Juda na nʼime Jerusalem.  
\v 22 ‘A ga-eburu ha niile bulaa ha Babilọn. Ebe ahụ ka ha ga-anọkwa tutu ruo mgbe m ga-abịa leta ha,’ ka \nd Onyenwe anyị\nd* kwubiri. ‘Mgbe ahụ, aga m ebulatakwa ha, kpọghachitekwa ha nʼebe a.’ ” 
\c 28  
\s1 Hananaya onye amụma ụgha 
\p  
\v 1 O ruo, nʼọnwa nke ise nke otu afọ ahụ, nke bụ afọ nke anọ, na mmalite ọchịchị Zedekaya eze Juda, Hananaya, nwa Azoa, onye amụma si Gibiọn, gwara m okwu nʼụlọnsọ \nd Onyenwe anyị\nd* nʼihu ndị nchụaja na ndị mmadụ si m.  
\v 2 “Ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, bụ Chineke Izrel kwuru, ‘Aga m agbaji agbụ nke eze Babilọn.  
\v 3 Tupu afọ abụọ agabiga, aga m esi Babilọn bulata ihe ndị ahụ niile Nebukadneza eze Babilọn si nʼụlọnsọ \nd Onyenwe anyị\nd* bupụ bulaa Babilọn.  
\v 4 Aga m akpọlatakwa Jehoiakin nwa Jehoiakim, na ndị niile ọzọ e si na Juda dọta nʼagha bulaa Babilọn, nʼihi na aga m agbaji agbụ ahụ eze Babilọn nyanyere ha nʼolu.’ ” Otu a ka \nd Onyenwe anyị\nd* kwubiri. 
\p  
\v 5 Mgbe ahụ, Jeremaya onye amụma zara Hananaya onye amụma nʼihu ndị nchụaja na ndị mmadụ niile guzo nʼụlọnsọ \nd Onyenwe anyị\nd* 
\v 6 Jeremaya onye amụma sịrị, “Amen!\f + \fr 28:6 \ft Maọbụ, \fqa Ya sikwa otu a dịrị\f* Ka \nd Onyenwe anyị\nd* mezuo okwu amụma a i buru site na ibughachite ngwongwo ụlọ \nd Onyenwe anyị\nd* na ịkpọghachite ndị niile e mere ka ha si nʼebe a gaa biri na Babilọn.  
\v 7 Ma gee ntị nụrụ ihe m ga-ekwu nʼihu gị na nʼihu ndị a niile guzo nʼebe a.  
\v 8 Site na mgbe ochie, ndị amụma ahụ bu mụ na gị ụzọ ebuola amụma banyere agha na mbibi na ọrịa na-efe efe megide ọtụtụ obodo dị iche iche, na ọtụtụ alaeze dị iche iche.  
\v 9 Ma ihe e ji amata na ọ bụ \nd Onyenwe anyị\nd* nʼezie, zitere onye amụma buru amụma kwuo na udo ga-adị, bụ naanị ma ọ bụrụ na amụma ya emezuo.” 
\p  
\v 10 Mgbe ahụ, Hananaya bụ onye amụma yipụrụ Jeremaya agbụ ahụ o yikwasịrị onwe ya nʼolu gbajie ya.  
\v 11 Ọ sịrị nʼihu ọha mmadụ ahụ niile, “Nke a ka \nd Onyenwe anyị\nd* kwuru: ‘Ọ bụ nʼotu aka ahụ ka m ga-agbajipụkwa agbụ ịyagba Nebukadneza, eze Babilọn nyanyere nʼolu mba niile tupu afọ abụọ agabiga.’ ” Mgbe o kwuru otu a, Jeremaya onye amụma hapụrụ ebe ahụ laa. 
\p  
\v 12 Mgbe Hananaya bụ onye amụma gbajisiri ịyagba\f + \fr 28:12 \ft Lit. \fqa Yoku\f* ahụ Jeremaya, onye amụma nyanyere onwe ya nʼolu, okwu \nd Onyenwe anyị\nd* ruru Jeremaya ntị sị ya,  
\v 13 “Gaa gwa Hananaya okwu sị ya, ‘Ihe ndị a ka \nd Onyenwe anyị\nd* kwuru: Ị gbajiela agbụ e ji osisi mee, ma nʼọnọdụ ya ihe ị ga-enweta bụ agbụ igwe.  
\v 14 Ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, bụ Chineke Izrel, kwuru. Aga m anyanye mba ndị a niile agbụ igwe, i mee ka ha fee Nebukadneza eze Babilọn. Ha ga-efekwa ya. Aga m enyekwa ya ike ọ bụladị nʼebe ụmụ anụ ọhịa dị.’ ” 
\p  
\v 15 Mgbe ahụ, Jeremaya onye amụma sịrị Hananaya onye amụma, “Gee ntị, Hananaya! Ọ bụghị \nd Onyenwe anyị\nd* zitere gị, ma ị ghọgbuola mba a mee ka ha tụkwasị uche nʼokwu ụgha.  
\v 16 Nʼihi nke a, otu a ka \nd Onyenwe anyị\nd* kwuru, ‘Ekpebiela m isite nʼụwa wepụ gị. Ị ga-anwụ nʼafọ a, nʼihi na i kwusaala nnupu isi megide \nd Onyenwe anyị\nd*.’ ” 
\p  
\v 17 Nʼọnwa asaa nke afọ ahụ Hananaya onye amụma nwụrụ. 
\c 29  
\s1 Akwụkwọ ozi nye ndị a dọtara nʼagha 
\p  
\v 1 Ihe ndị a bụ ihe dị nʼakwụkwọ ozi Jeremaya onye amụma si Jerusalem degaara ndị fọdụrụ ndụ nʼetiti ndị okenye, na ndị nchụaja, na ndị amụma, na ndị Izrel Nebukadneza dọtara nʼagha si na Jerusalem bulaa ha Babilọn.  
\v 2 Nke a bụ mgbe eze Jehoiakin, nne eze, ndị ozi nʼụlọeze, ndị ndu Juda na Jerusalem, ndị ọka, na ndị ụzụ sitere na Jerusalem dọta ha nʼagha buru ha gaa mba ọzọ.  
\v 3 Onye Jeremaya nyere akwụkwọ ozi a ka o nyeruo ndị e deere ya bụ Eleasa nwa Shefan, na Gemaraya nwa Hilkaya, ndị Zedekaya eze Juda zigara Babilọn izi Nebukadneza bụ eze ozi. 
\pm  
\v 4 Ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, bụ Chineke Izrel na-agwa ndị niile m mere ka e si na Jerusalem dọta nʼagha buru laa Babilọn,  
\v 5 “Wuoronụ onwe unu ụlọ, birikwanụ nʼime ya; kụọnụ ihe nʼubi a gbara ogige, riekwa mkpụrụ si na ya;  
\v 6 lụọnụ nwunye, mụọkwanụ ụmụ ndị ikom na ụmụ ndị inyom; lụọkwaranụ ụmụ unu ndị ikom nwunye, kwenyekwanụ ka ụmụ unu ndị inyom lụọ di, ka ha mụọkwa ụmụ ndị ikom na ụmụ ndị inyom. Mụbaanụ nʼebe ahụ, unu ebilatakwala.  
\v 7 Chọọnụ udo nke obodo ahụ m mere ka unu gaa biri nʼime ya. Kpeekwanụ ekpere nye \nd Onyenwe anyị\nd* banyere ya. Nʼihi na ọ bụrụ na ihe agaara obodo ahụ nke ọma, ọ ga-agakwara unu nke ọma.”  
\v 8 Nʼihi na ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile bụ Chineke Izrel kwuru, “Unu ekwela ka ndị amụma ahụ nọ nʼetiti unu, na ndị na-ajụ arụsị ase rafuo unu; unu egela ntị nʼakụkọ ha na-akọ banyere nrọ ndị ahụ unu na-akwagide ha ka ha rọọ.  
\v 9 Nʼihi na amụma ha na-ebu nʼaha m bụ amụma ụgha. Ọ bụkwaghị m zitere ha.” Otu a ka \nd Onyenwe anyị\nd* kwupụtara. 
\pm  
\v 10 Ihe ndị a ka \nd Onyenwe anyị\nd* kwuru, “Mgbe iri afọ asaa m kwadoro maka Babilọn zuru, aga m abịa mezuo nkwa ahụ m kwere. Aga m eme ka unu lọtakwa nʼebe a.  
\v 11 Nʼihi na mụ onwe m maara echiche niile m na-eche banyere unu,” ka \nd Onyenwe anyị\nd* kwubiri, “echiche ime ka ihe gaara unu nke ọma, ọ bụkwaghị echiche ime unu ihe ọjọọ, echiche ime ka unu nwee ezi ọdịnihu, na olileanya kwesiri ntụkwasị obi.  
\v 12 Mgbe ahụ, unu ga-abịakwute m, unu ga-abịa kpọkuokwa m nʼekpere, aga m egekwa unu ntị.  
\v 13 Unu ga-achọsikwa m ike, chọta m ma ọ bụrụ na unu ejiri obi unu niile chọọ m.  
\v 14 Aga m emekwa ka unu chọta m,” otu a ka \nd Onyenwe anyị\nd* kwubiri, “meekwa ka unu bụ ndị a dọtara nʼagha lọta. Aga m esitekwa na mba ahụ niile m chụgara unu chịkọtaa unu, kpọghachitekwa unu nʼebe ahụ m si chụpụ unu.” Otu a ka \nd Onyenwe anyị\nd* kwubiri ya. 
\pm  
\v 15 Unu pụrụ ị sị, “\nd Onyenwe anyị\nd* akpọlite ndị amụma nye anyị na Babilọn.”  
\v 16 Ma ihe ndị a ka Onyenwe anyị na-ekwu banyere eze ahụ na-anọkwasị nʼocheeze Devid, na banyere ndị mmadụ niile fọdụrụ nʼobodo a, bụ ụmụnne unu ndị ahụ na-esoghị unu gaa ebe e mere ka ha ga biri na mba ọzọ.  
\v 17 E, ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwuru, “Aga m eziga mma agha nʼetiti ha, zigakwa ụnwụ na ọrịa na-efe efe. Aga m eme ha ka ha dị ka mkpụrụ fiig jọgburu onwe ya, nke mmadụ na-agaghị ata ata.  
\v 18 Aga m eji mma agha, na ụnwụ, na ọrịa na-efe efe, chụọ ha ọsọ. Aga m eme ha ka ha bụrụ ihe alaeze niile nke ụwa ga na-asọ oyi. Ha ga-abụ ihe ịbụ ọnụ, na ihe iju anya, na ihe nkọcha, na ihe ịta ụta nʼetiti mba niile ebe m ga-achụla ha ọsọ.  
\v 19 Nʼihi na ha egeghị ntị nʼokwu m, bụ okwu si nʼọnụ ndị ohu m bụ ndị amụma, ndị m zigaara ha mgbe mgbe. Ma unu onwe unu, ndị bi na mba ọzọ egekwaghị ntị nʼokwu m.” Otu a ka \nd Onyenwe anyị\nd* kwubiri. 
\pm  
\v 20 Ya mere, nụrụnụ okwu \nd Onyenwe anyị\nd*, unu niile bụ ndị m mere ka e si na Jerusalem dọta nʼagha gaa Babilọn.  
\v 21 Ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, bụ Chineke Izrel na-ekwu banyere Ehab nwa Kolaya, na Zedekaya nwa Maaseia, ndị na-ebu amụma ụgha nʼaha m, “Aga m ewere ha nyefee nʼaka Nebukadneza bụ eze Babilọn. Ọ ga-etigbukwa ha nʼihu unu.  
\v 22 Nʼihi ha, ndị niile e si Juda dọta nʼagha buru gaa Babilọn ga na-ekwu okwu nkọcha sị, ‘Ka \nd Onyenwe anyị\nd* mesokwa gị ụdị mmeso o mesoro Zedekaya na Ehab, ndị eze Babilọn tụnyere nʼọkụ nke regburu ha.’  
\v 23 Nʼihi na ha emeela ihe ndị jọgburu onwe ya na njọ nʼIzrel; ha na nwunye ndị agbataobi ha akwaala iko; ha esitekwala nʼaha m buo amụma ụgha, amụma nke m na-enyeghị ha iwu ibu. Amaara m na ihe ndị a bụ eziokwu, nʼihi na ahụrụ m ya.” Otu a ka \nd Onyenwe anyị\nd* kwubiri. 
\s1 Ozi e ziri Shemaya 
\p  
\v 24 Gwa Shemaya onye Nehelam okwu sị ya,  
\v 25 Otu a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, bụ Chineke Izrel kwuru, “I dere akwụkwọ zigara ndị niile bi na Jerusalem, ha na Zefanaya nwa Maaseia onye nchụaja, na ndị nchụaja ndị ọzọ. Ị gwara Zefanaya okwu nʼakwụkwọ ahụ sị ya,  
\v 26 ‘\nd Onyenwe anyị\nd* ahọpụtala gị mee gị onye nchụaja ga-anọchi anya Jehoiada. Nʼihi ya, ị bụrụla onyeisi ụlọnsọ ukwu \nd Onyenwe anyị\nd*. Ya mere, o kwesiri ka i jide onye ara ọbụla na-akpọ onwe ya onye amụma, manye ya agbụ igwe nʼụkwụ, na nʼolu ya.  
\v 27 Gịnị mere i ji hapụ ịbasiri Jeremaya, onye Anatot mba ike, onye na-eme onwe ya onye amụma nʼetiti unu?  
\v 28 O ziterela anyị ozi dị otu a na Babilọn sị anyị, Unu ga-anọ nʼebe ahụ tee anya. Ya mere, wuoronụ onwe unu ụlọ, birikwanụ nʼime ya. Kụọnụ ihe nʼubi, riekwanụ ihe si nʼubi unu.’ ” 
\p  
\v 29 Zefanaya bụ onye nchụaja, gụrụ akwụkwọ ozi ahụ nʼihu Jeremaya, bụ onye amụma.  
\v 30 Mgbe ahụ, okwu \nd Onyenwe anyị\nd* bịakwutere Jeremaya, sị,  
\v 31 “Zigara ndị ahụ niile e mere ka ha gaa biri na mba ọzọ ozi sị ha, ‘Ihe ndị a ka \nd Onyenwe anyị\nd* kwuru banyere Shemaya onye Nehelam, Ebe ọ bụ na Shemaya ebuorola unu amụma mee ka unu tụkwasị obi unu nʼokwu ụgha ya, ma ọ bụghị m ziri ya,  
\v 32 ihe ndị a ka \nd Onyenwe anyị\nd* kwuru, Mụ onwe m aghaghị ịta Shemaya onye Nehelam na mkpụrụ ya ahụhụ nʼihi mmehie ya. Ọ gaghị enwe nwoke ọbụla ga-afọdụ ndụ nʼetiti ndị ya niile. Ọ gaghị esokwa unu lekwasị anya nʼihe ọma ahụ niile m na-akwado imere ndị m, nʼihi na o kwusara nnupu isi megide \nd Onyenwe anyị\nd*. Otu a ka \nd Onyenwe anyị\nd* kwubiri.’ ” 
\c 30  
\s1 Nlọta ụmụ Izrel 
\p  
\v 1 Ndị a bụ okwu nke sị nʼebe \nd Onyenwe anyị\nd* nọ bịakwute Jeremaya.  
\v 2 “Otu a ka \nd Onyenwe anyị\nd*, Chineke Izrel kwuru, ‘Dee ihe niile m gwara gị nʼime akwụkwọ.  
\v 3 Nʼihi na ụbọchị ndị ahụ na-abịa,’ ka \nd Onyenwe anyị\nd* kwupụtara, ‘mgbe m ga-akpọghachite ndị m bụ Izrel na Juda si nʼebe e mere ka ha jee biri na mba ọzọ lọta. Aga m eme ka ha laghachi nʼala ahụ m nyere nna nna ha, ka ha nwetakwa ya.’ Otu a ka \nd Onyenwe anyị\nd* kwuru.” 
\p  
\v 4 Ma ndị a bụ okwu \nd Onyenwe anyị\nd* kwuru banyere Izrel na Juda.  
\v 5 “Nʼihi na otu a ka \nd Onyenwe anyị\nd* kwuru, 
\q1 “ ‘A na-anụ mkpu akwa sitere nʼegwu, 
\q2 nke oke egwu, ọ bụghị udo. 
\q1  
\v 6 Jụọnụ ajụjụ, ma hụ, 
\q2 nwoke ọ pụrụ ịmụ ụmụ? 
\q1 Gịnịkwa mere m ji na-ahụ ndị ikom dị ike 
\q2 ka ha tụkwasịrị aka ha nʼukwu ha dịka nwanyị ime na-eme, 
\q2 ihu onye ọbụla gbanwekwara dịka nke onye na-anwụ anwụ? 
\q1  
\v 7 Ụbọchị dị oke egwu ka ụbọchị ahụ ga-abụ. 
\q2 O nwekwaghị ụbọchị ga-adị ka ya. 
\q1 Ọ ga-abụ oge oke nsogbu nye Jekọb, 
\q2 ma a ga-anapụta ya site na ya. 
\b  
\q1  
\v 8 “ ‘Nʼụbọchị ahụ,’ 
\q2 ‘aga m agbaji ihe ịnya nʼolu a nyakwasịrị ha nʼolu, 
\q1 tibisikwaa agbụ niile e kere ha. 
\q2 Ha agaghị abụkwa ndị ohu nye ndị mba ọzọ, ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwubiri. 
\q1  
\v 9 Kama ha ga-efe \nd Onyenwe anyị\nd* bụ Chineke ha, 
\q2 na Devid eze ha, 
\q2 onye m ga-esi nʼetiti ha mee ka o biliere ha. 
\b  
\q1  
\v 10 “ ‘Ya mere, atụla egwu, gị Jekọb, ohu m. 
\q2 Atụkwala ụjọ\f + \fr 30:10 \ft Ya bụ, adakwala mba\f* gị Izrel,’ 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwupụtara. 
\q1 ‘Aghaghị m ịzọpụta gị site na mba ahụ dị anya, 
\q2 zọpụtakwa ụmụ ụmụ gị site na mba ahụ e mere ka ha gaa biri nʼime ya. 
\q1 Jekọb ga-emesịakwa biri nʼudo na nchebe. 
\q2 Ọ dịkwaghị onye ga-eme ka ụjọ tụọ ya ọzọ. 
\q1  
\v 11 Nʼihi na mụ onwe m nọnyeere gị, aga m azọpụtakwa gị,’ 
\q2 otu a ka \nd Onyenwe anyị\nd* kwubiri. 
\q1 ‘A sịkwarị na m alaa mba ndị ahụ niile nʼiyi, 
\q2 bụ mba ndị ahụ m chụbanyere gị nʼime ha, 
\q2 agaghị m ebibi gị onwe gị kpamkpam. 
\q1 Aga m adọ gị aka na ntị maọbụ dịka o kwesiri,\f + \fr 30:11 \ft Dịka o ziri ezi nʼikpe\f* 
\q2 ị gaghị agbanarị ịta ahụhụ.’ 
\p  
\v 12 “Ihe ndị a ka \nd Onyenwe anyị\nd* kwukwara, 
\q1 “ ‘Ọnya dị gị nʼahụ enweghị ngwọta, 
\q2 mmerụ ahụ i merụrụ dị ukwuu, ọ pụghị ịla ala. 
\q1  
\v 13 O nweghị onye na-ekpechitere gị ọnụ gị, 
\q2 o nweghị ọgwụ dị nke e ji eme ka ọnya gị laa. 
\q2 Olileanya adịghị na a ga-agwọ gị. 
\q1  
\v 14 Ndị niile gị na ha dị na mma e chezọọla gị; 
\q2 ha adịghị echetakwa gị nʼechiche uche ha. 
\q1 E tieela m gị ihe dịka onye iro gị ga-esi tie gị ihe; 
\q2 ataala m gị ahụhụ dịka onye na-enweghị obi ebere ga-esi taa gị ahụhụ, 
\q1 nʼihi na ajọ omume gị bara ụba nke ukwuu, 
\q2 mmehie gị dịkwa ọtụtụ. 
\q1  
\v 15 Gịnị mere i ji na-akwa akwa nʼihi ọnya dị gị nʼahụ? 
\q2 Gịnị mere i ji na-akwa akwa nʼihi ihe mgbu nke na-enweghị ọgwụgwọ? 
\q1 Emere m ka ihe ndị a bịakwasị gị nʼihi ịba ụba nke ajọ omume gị, 
\q2 na nʼihi ọtụtụ mmehie gị. 
\b  
\q1  
\v 16 “ ‘Ma a ga-erepịa ndị niile na-eripịa gị; 
\q2 ndị iro gị niile, ha niile nʼotu nʼotu, ka a ga-adọta nʼagha buru gaa mba ọzọ. 
\q1 Ndị na-apụnara gị ihe i nwere nʼike ka a ga-apụnarakwa ha ihe ha nwere nʼike. 
\q2 Ndị niile na-alụtakwa ihe inwere nʼagha ka a ga-enye ka ha ghọọ ihe nlụta nʼagha. 
\q1  
\v 17 Ma aga m eme ka ahụ sie gị ike; 
\q2 aga m agwọkwa ọnya gị niile,’ otu a ka \nd Onyenwe anyị\nd* kwubiri ya. 
\q1 ‘Nʼihi na a na-akpọ gị onye a jụrụ ajụ. 
\q2 Gị Zayọn, nke o nweghị onye na-elekọta ya.’ 
\p  
\v 18 “Otu a ka \nd Onyenwe anyị\nd* kwuru, 
\q1 “ ‘Lee, ana m aga ime ka Jekọb nwetaghachi ụlọ ikwu\f + \fr 30:18 \ft Ya bụ, ebe obibi\f* ya; 
\q2 aga m enwekwa obi ebere nʼebe obibi ya. 
\q1 A ga-ewugharị obodo ahụ nʼelu mkpọmkpọ ebe ya;\f + \fr 30:18 \ft Ụfọdụ akwụkwọ na-asị nʼelu ugwu ya\f* 
\q2 ụlọeze ga-eguzokwa nʼọnọdụ kwesiri ya. 
\q1  
\v 19 Nʼebe ahụ ka a ga-esi na-anụ olu abụ ekele, 
\q2 na olu ndị na-aṅụrị ọṅụ. 
\q1 Aga m eme ka ha baa ụba nʼọnụọgụgụ, 
\q2 ha agaghị adịkwa ole na ole. 
\q1 Aga m eme ka ha bụrụ ndị a na-asọpụrụ, 
\q2 ndị a na-agaghị eledakwa anya. 
\q1  
\v 20 Ụmụ ha ga-adịkwa ka ụmụntakịrị ndị mgbe ochie ahụ, 
\q2 nzukọ ha ga-eguzosikwa ike nʼihu m. 
\q2 Aga m atakwa ndị ahụ na-emegbu ha ahụhụ. 
\q1  
\v 21 Onyendu ha ga-abụ otu onye nʼime ndị ha; 
\q2 onye ga-achị ha ga-esi nʼetiti ha pụta. 
\q1 Aga m akpọbata ya nso ebe m nọ, ọ ga-abịaru m nso, 
\q2 nʼihi na olee mmadụ ahụ nke pụrụ inyefe onwe ya kpamkpam, 
\q2 maka ịbịaru m nso?’ 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwubiri. 
\q1  
\v 22 ‘Nʼụzọ dị otu a unu ga-abụ ndị m, 
\q2 mụ onwe m kwa ga-abụ Chineke unu.’ ” 
\b  
\q1  
\v 23 Lee, \nd Onyenwe anyị\nd* ga-esite nʼọnụma ya 
\q2 mee ka oke ifufe ya fee. 
\q1 Ọ ga-efekwasị ndị na-emebi iwu 
\q2 dịka ifufe na-efesi ike. 
\q1  
\v 24 Iwe ọkụ \nd Onyenwe anyị\nd* agaghị akwụsị 
\q2 tutu ruo mgbe o mezuru 
\q2 ihe ndị o bu nʼobi. 
\q1 Nʼụbọchị ndị ahụ na-abịa 
\q2 unu ga-aghọta ihe ndị a. 
\c 31  
\p  
\v 1 “Nʼoge ahụ,” otu a ka \nd Onyenwe anyị\nd* kwupụtara ya, sị, “Aga m abụ Chineke nke agbụrụ Izrel niile. Ha ga-abụkwa ndị m.” 
\p  
\v 2 Otu a ka \nd Onyenwe anyị\nd* kwuru, 
\q1 “Ndị ahụ gbanarịrị mma agha 
\q2 ga-ahụta ihuọma nʼọzara. 
\q2 Aga m abịa iwetara Izrel izuike.” 
\p  
\v 3 \nd Onyenwe anyị\nd* mere ka anyị hụ ya anya site nʼebe dị anya, na-asị, 
\q1 “Ọ bụ ịhụnanya nke na-adịgide ruo mgbe ebighị ebi ka m ji hụ gị nʼanya; 
\q2 Ọ bụ ebere nke na-adịghị agbanwe ka m ji dọta unu nso. 
\q1  
\v 4 Aga m ewulikwa gị elu ọzọ, 
\q2 e, aga m eme ka ị bụrụ ihe e wugharịrị ọzọ, gị Izrel bụ nwaagbọghọ na-amaghị nwoke. 
\q1 Mgbe ahụ, ị ga-eji ihe iti egwu gị pụọ 
\q2 soro ndị ọṅụ juru obi tee egwu. 
\q1  
\v 5 Mgbe ahụ, ị ga-akụkwa ubi vaịnị a gbara ogige 
\q2 nʼelu ugwu Sameria. 
\q1 Ndị ọrụ ubi kụrụ ya 
\q2 ga-erikwa mkpụrụ si na ya. 
\q1  
\v 6 Ụbọchị ahụ ga-adị mgbe ndị nche ga-anọ 
\q2 nʼelu ugwu nta niile nke Ifrem tikuo ndị niile sị ha, 
\q1 ‘Bịanụ ka anyị jeruo Zayọn, 
\q2 ka anyị jee nʼihu \nd Onyenwe anyị\nd* Chineke anyị.’ ” 
\p  
\v 7 Ihe ndị a ka \nd Onyenwe anyị\nd* kwuru, 
\q1 “Tienụ mkpu ọṅụ nʼihi Jekọb, 
\q2 tienụ mkpu ọṅụ nʼihi onye ahụ kachasị mba niile nʼịdị ukwuu. 
\q1 Meenụ ka a nụrụ ya, toonu ma na-asịkwanụ, 
\q2 ‘\nd Onyenwe anyị\nd*, biko, zọpụta ndị gị, 
\q2 bụ ndị Izrel fọdụrụ.’ 
\q1  
\v 8 Lee, aga m esite nʼala ahụ dị nʼugwu kpọta ha; 
\q2 aga m eme ka e si na nsọtụ niile nke ụwa chịkọtaa ha. 
\q1 Nʼetiti ha ka a ga-ahụ ndị kpuru ìsì na ndị ngwụrọ, 
\q2 na ndị inyom dị ime, na ndị inyom ime na-eme. 
\q2 Ndị ga-alọta ga-adị nnọọ ukwuu! 
\q1  
\v 9 Ha ga na-akwa akwa mgbe ha na-alọta, 
\q2 ha ga-anọkwa nʼekpere mgbe m ga-edulata ha. 
\q1 Aga m edu ha site nʼakụkụ iyi, 
\q2 nʼala dị larịị, ebe ha na-agaghị akpọbi ụkwụ ha, 
\q1 nʼihi na aghọọlara m Izrel nna, 
\q2 Ifrem bụkwa ọkpara m. 
\b  
\q1  
\v 10 “Nụrụnụ okwu \nd Onyenwe anyị\nd*, unu mba niile; 
\q2 kwusaanụ ya nʼebe dị anya nke ala ahụ dị nʼakụkụ osimiri niile. 
\q1 Onye ahụ chụsara Izrel ga-achịkọtakwa ha. 
\q2 Ọ ga-elekọtakwa igwe ewu na atụrụ ya dịka onye ọzụzụ atụrụ. 
\q1  
\v 11 Nʼihi na \nd Onyenwe anyị\nd* ga-agbapụta Jekọb, 
\q2 ọ ga-anapụtakwa ha site nʼaka ndị ka ha ike. 
\q1  
\v 12 Ha ga-abịa nọọ nʼugwu Zayọn tie mkpu ọṅụ, 
\q2 ha ga-aṅụrị ọṅụ nʼihi ịdị ukwu nke ezi ihe \nd Onyenwe anyị\nd* nyere ha, 
\q1 dịka ọka, na mmanya ọhụrụ, na mmanụ, 
\q2 na ụmụ igwe ewu na atụrụ, na ọtụtụ ehi. 
\q1 Ha ga-adị ka ubi a na-agba mmiri mgbe niile; 
\q2 ha agaghị erukwa ụjụ ọzọ. 
\q1  
\v 13 Mgbe ahụ, obi ga-atọ ụmụ agbọghọ ụtọ, ha ga-etekwa egwu ọṅụ, 
\q2 ụmụ okorobịa na ndị agadi ga-aṅụrịkwa ọṅụ. 
\q1 Aga m eme ka iru ụjụ ha ghọọrọ ha obi ụtọ, 
\q2 aga m enyekwa ha nkasiobi na ọṅụ nʼọnọdụ mwute. 
\q1  
\v 14 Aga m emekwa ka afọ jubiga ndị nchụaja oke nʼihi ịdị ukwuu nke onyinye ha ga-enweta, 
\q2 afọ ezi ihe m ga-ejukwa ndị m,”\f + \fr 31:14 \ft Ndị m ga-enwejubigakwa ihe niile oke\f* 
\q2 otu a ka \nd Onyenwe anyị\nd* kwubiri. 
\p  
\v 15 Ihe ndị a bụ ihe \nd Onyenwe anyị\nd* kwuru, 
\q1 “A nụrụ otu olu na Rema, 
\q2 iru ụjụ na oke ịkwa akwa. 
\q1 Rechel na-akwa akwa nʼihi ụmụ ya, 
\q2 o kwekwaghị ịnabata nkasiobi a na-akasị ya, 
\q2 nʼihi na ụmụ ya adịghịkwa.” 
\p  
\v 16 Ma otu a ka \nd Onyenwe anyị\nd* kwuru, 
\q1 “Jide olu gị aka, ka ọ ghara ịkwa akwa, 
\q2 jidekwa anya gị abụọ, ka ha ghara ịgba anya mmiri, 
\q1 nʼihi na a ga-akwụ gị ụgwọ ọrụ nʼihi ọrụ gị.” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwupụtara. 
\q2 “Ha ga-esite nʼala ndị iro ha lọtakwa. 
\q1  
\v 17 Nʼihi ya, olileanya dịkwara ọdịnʼihu gị.” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwubiri. 
\q2 “Ụmụ gị ga-alọtakwa nʼala nke aka ha. 
\b  
\q1  
\v 18 “Anụla m nnọọ ịsụ ude Ifrem, na okwu o kwuru sị, 
\q2 ‘Ị dọọla m aka na ntị dịka nwa ehi nke na-eme isiike. 
\q2 Lee, amụtala m ihe ị chọrọ ka m mụta site nʼịdọ aka na ntị gị. 
\q1 Ya mere, kpọlata m, ka m nwee ike lọtakwa, 
\q2 nʼihi na ị bụ \nd Onyenwe anyị\nd* na Chineke m. 
\q1  
\v 19 Mgbe m kpafuru, 
\q2 echegharịrị m. 
\q1 Mgbe m ghọtakwara, 
\q2 e tiri m aka nʼobi m, 
\q1 ihere mere m, ọ wutekwara m 
\q2 nʼihi nʼọnọdụ ihe ihere nʼihi ụdị ndụ m biri nʼokorobịa m.’ 
\q1  
\v 20 Ifrem, ọ bụghị nwa m nwoke, 
\q2 onye ihe ya na-atọ m ụtọ? 
\q1 Ọ bụ ezie na m na-ekwu okwu megide ya, 
\q2 ma anọkwa m na-echeta ya. 
\q1 Nʼihi ya, ihe banyere ya na-agụsị obi m agụụ ike. 
\q2 Ana m enwekwa obi ebere nʼebe ọ nọ.” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwupụtara. 
\b  
\q1  
\v 21 “Manyenụ ogidi ịhụba ụzọ ama, 
\q2 manyekwanụ osisi ịhụba ụzọ ama. 
\q1 Lezienụ anya mụta aha okporoụzọ niile, 
\q2 bụ okporoụzọ unu ga-eso. 
\q1 Lọta, gị Izrel, bụ nwaagbọghọ na-amaghị nwoke, 
\q2 laghachi nʼobodo gị ndị a. 
\q1  
\v 22 Ruo ole mgbe ka ị ga-anọ na-awagharị, 
\q2 gị nwaagbọghọ na-ekwesighị ntụkwasị obi Izrel? 
\q1 Nʼihi na \nd Onyenwe anyị\nd* na-aga ime ihe ọhụrụ nʼụwa; 
\q2 nwanyị ga-anọ nwoke gburugburu.” 
\p  
\v 23 Ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, bụ Chineke Izrel, kwuru, “Mgbe m si na mba ọzọ kpọghachi ha, ndị ga-ebi nʼala Juda na nʼime obodo ya niile ga-ekwu okwu ndị a ọzọ sị: ‘\nd Onyenwe anyị\nd* gọzie gị, gị ebe obibi dị nsọ, gị ugwu dị nsọ.’  
\v 24 Ndị mmadụ ga-ebikọta ọnụ na Juda na nʼobodo niile dị nʼime ya, ma ndị na-arụ ọrụ ubi, ma ndị na-elekọta igwe ewu na atụrụ ha.  
\v 25 Aga m enwoghakwa ike ndị na-ada mba, meekwa ka afọ ju ndị ike gwụrụ.” 
\p  
\v 26 Nʼoge a, esi m nʼụra teta, lee anya gburugburu m. Ụra m rahụrụ tọrọ m ụtọ nke ukwuu. 
\p  
\v 27 Otu a ka \nd Onyenwe anyị\nd* kwupụtara, “Lee, ụbọchị ndị ahụ na-abịa, mgbe m ga-akụ ụmụ mmadụ na ụmụ anụmanụ nʼụlọ Izrel na nʼụlọ Juda.  
\v 28 Ọ ga-erukwa na dịka m legidere ha anya maka ihopu ha, ikwada ha, itikpọ ha, laa ha nʼiyi, ma mee ka ihe ọjọọ bịakwasịrị ha, otu a ka m ga-esikwa lezie ha anya iwuzi ha na ịkụ ha dị ka mkpụrụ.” Ọ bụ otu a ka \nd Onyenwe anyị\nd* kwubiri.  
\v 29 “Nʼụbọchị ndị ahụ, ndị mmadụ agaghị asịkwa, 
\q1 “ ‘Nna anyị ha arachaala mkpụrụ osisi na-achaghị acha, 
\q2 ma lee, eze ụmụ ha na-ejiji ejiji.’ 
\m  
\v 30 Kama onye ọbụla ga-anwụ nʼihi mmehie nke aka ya; onye rachara mkpụrụ osisi na-achaghị acha ka eze ya ga-ejiji. 
\q1  
\v 31 “Lee, oge na-abịa,” ka \nd Onyenwe anyị\nd* kwupụtara, 
\q2 “mgbe m ga-eme ka ọgbụgba ndụ ọhụrụ dịrị 
\q1 nʼetiti mụ na ụlọ Izrel, 
\q2 nakwa ụlọ Juda. 
\q1  
\v 32 Ọ bụghị ụdị ọgbụgba ndụ ahụ 
\q2 mụ na nna nna ha gbara, 
\q1 mgbe ahụ m jidere ha nʼaka 
\q2 site nʼala Ijipt dupụta ha, 
\q1 nʼihi na ha mebie ọgbụgba ndụ m, 
\q2 ọ bụ ezie na mụ onwe m bụ di nye ha,” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwupụtara. 
\q1  
\v 33 “Ma nke a bụ ọgbụgba ndụ mụ na ụlọ Izrel ga-agba 
\q2 mgbe oge ndị ahụ gasịrị,” ka \nd Onyenwe anyị\nd* kwupụtara. 
\q1 “Aga m etinye iwu m nʼime obi ha, 
\q2 aga m edekwasịkwa ha nʼuche ha. 
\q1 Aga m abụ Chineke ha, 
\q2 ha onwe ha ga-abụkwa ndị m. 
\q1  
\v 34 Ọ dịghị onye ọbụla nʼetiti ha ga-akụziri onye agbataobi ya ihe, 
\q2 maọbụ otu onye asị ibe ya, ‘Mara \nd Onyenwe anyị\nd*,’ 
\q1 nʼihi na ha niile ga-ama onye m bụ, 
\q2 site nʼonye dịkarịsịrị nta ruo nʼonye dịkarịsịrị ukwuu nʼetiti ha.” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwubiri ya. 
\q1 “Nʼihi na aga m agbaghara ajọ omume ha, 
\q2 agaghị m echetakwa mmehie ha niile ọzọ.” 
\p  
\v 35 Ihe ndị a ka \nd Onyenwe anyị\nd* kwuru, 
\q1 bụ onye ahụ họpụtara anyanwụ 
\q2 mee ka ọ na-enye ihe nʼehihie, 
\q1 onye ahụ nyere ọnwa na kpakpando iwu 
\q2 ka ha na-enye ihe nʼanyasị, 
\q1 onye na-akpali oke osimiri, 
\q2 na-eme ka ebiliri mmiri na-ebigbọ. 
\q2 Aha ya bụ \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile. 
\q1  
\v 36 Otu a ka \nd Onyenwe anyị\nd* kwupụtara, 
\q2 “Ọ bụ naanị ma ụkpụrụ ndị a ọ pụrụ nʼihu m, ghara ịdịkwa, 
\q1 ka a ga-eme ka ụmụ ụmụ Izrel ghara ịdị, 
\q2 ka ha ghara ịbụkwa mba nʼihu m ọzọ.” 
\p  
\v 37 Ihe ndị a ka \nd Onyenwe anyị\nd* kwuru, 
\q1 “Ọ bụ naanị mgbe e nwere ike ịtụ ma chọpụta ịsa mbara nke mbara eluigwe, 
\q2 na ịdị omimi nke ntọala ụwa, 
\q1 ka m ga-ajụ ụmụ ụmụ niile nke Izrel, 
\q2 nʼihi ihe\f + \fr 31:37 \ft Ya bụ, ihe ọjọọ\f* niile ha mere.” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwubiri. 
\p  
\v 38 “Ụbọchị ndị ahụ na-abịa, Otu a ka \nd Onyenwe anyị\nd* kwubiri, mgbe a ga-ewugharị obodo a nye m, site nʼụlọ elu Hananel ruo nʼọnụ ụzọ ama Akụkụ.  
\v 39 Ịdị ogologo nke eriri ọtụtụ a ga-eji tụọ ya ga-adị ka site nʼihu ọnụ ụzọ ama ahụ ruo nʼugwu Gareb, gaakwa ruo Goa.  
\v 40 Ndagwurugwu ahụ niile ebe a tụnyere ozu ndị mmadụ, na ebe e kpofuru ntụ, na mgbada ugwu ahụ niile ebe e doziri edozi maka ịkụ ihe, ruo na ndagwurugwu iyi Kidrọn nke dị nʼakụkụ ọnụ ụzọ ama ịnyịnya, ga-aghọkwa ebe dị nsọ nye \nd Onyenwe anyị\nd*. A gaghị ehopukwa obodo ahụ ọzọ, maọbụ tikpọọ ya.” 
\c 32  
\s1 Jeremaya azụọ ala ubi 
\p  
\v 1 Ihe ndị a bụ okwu \nd Onyenwe anyị\nd* nke rutere Jeremaya nʼafọ nke iri nke ọchịchị Zedekaya eze Juda, nke bụkwa afọ nke iri na asatọ nke ọchịchị Nebukadneza.  
\v 2 Nʼoge a, ndị agha Babilọn gbara Jerusalem gburugburu. E tinyekwara Jeremaya, bụ onye amụma nʼogige ụlọ ndị nche nke dị nʼụlọeze Juda. 
\p  
\v 3 Zedekaya eze Juda tụrụ ya mkpọrọ nʼebe ahụ, sị ya, “Gịnị mere i ji na-ebu amụma dị otu a. Nʼihi na ị na-asị, ‘Ihe ndị a ka \nd Onyenwe anyị\nd* kwuru, ejikerela m inyefe gị na obodo a nʼaka eze Babilọn. Ọ ga-alụtakwa ya nʼagha.  
\v 4 Zedekaya eze Juda agaghị agbapụ site nʼaka ndị Babilọn, nʼihi na a ga-enyefe ya nʼaka eze Babilọn, onye ya na ya ga-ekwurịtakwa okwu ihu na ihu. Zedekaya ga-ejikwa anya ya abụọ hụ eze Babilọn,  
\v 5 onye ga-eduru ya, bụ Zedekaya, gaa Babilọn, ebe ọ ga-anọ tutu ruo mgbe mụ, bụ \nd Onyenwe anyị\nd*, mesiri ya ike. Ọ bụrụ na ibuso ndị Babilọn agha, ị gaghị emeri.’ ” 
\p  
\v 6 Jeremaya sịrị, “Okwu \nd Onyenwe anyị\nd* rutere m ntị, sị,  
\v 7 Lee, Hanamel nwa Shalum, nwanne nna gị, ga-abịakwute gị, sị gị, ‘Zụrụ ala m dị nʼAnatot, nʼihi na ebe ị bụ onye ikwu m ọ bụ gị ka o ruuru ịzụ ya.’ 
\p  
\v 8 “Mgbe ahụ, dịka \nd Onyenwe anyị\nd* si kwuo ya, Hanamel nwa nwanne nna m bịakwutere m nʼogige ndị nche sị m, ‘Zụrụ ala m dị nʼAnatot, nʼime ala ndị Benjamin. Ebe ọ bụ ihe ruuru gị ịgbapụta ya ime ka ọ bụrụ nke gị, ọ bụ gị kwesiri ịzụ ya.’ 
\p “Amaara m na nke a bụ okwu \nd Onyenwe anyị\nd*.  
\v 9 Ya mere, azụrụ m ala ahụ dị nʼAnatot site nʼaka nwanna m Hanamel. Atụpụtara m ọlaọcha shekel iri na asaa ọnụahịa ala ahụ, jiri ya kwụọ ya ụgwọ.  
\v 10 Emesịa, etinyere m aka m nʼakwụkwọ ire ala ahụ, kaa ya akara, nyachie ya, nʼihu ndị akaebe. Atụkwara m ọlaọcha ahụ nʼihe ọtụtụ.  
\v 11 Eweere m akwụkwọ ịzụta ala ahụ a kara akara, nke a nyachikwara anyachi, ebe e dere ihe banyere ọzụzụ na orire nke ala ahụ, werekwa ụdị akwụkwọ ahụ nke a na-anyachighị anyachi,  
\v 12 nyefee ha nʼaka Baruk nwa Neraya, nwa Mahseia, nʼihu Hanamel nwanna m, na nʼihu ndị akaebe ndị ọzọ, ndị aka ha dị nʼakwụkwọ ahụ, na nʼihu ndị Juu ndị ọzọ, ndị nọ nʼogige ụlọ ndị agha ahụ. 
\p  
\v 13 “Nʼihu ha, enyere m Baruk iwu ndị a sị ya,  
\v 14 ‘Ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, bụ Chineke Izrel kwuru, Were akwụkwọ ndị a, ma nke a nyachiri anyachi, ma nke a na-anyachighị anyachi, tinye ha nʼime ite e ji ụrọ kpụọ, ebe ha ga-adị ogologo oge.  
\v 15 Nʼihi na ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, bụ Chineke Izrel kwuru, a ga-emesịakwa zụọ ụlọ, ala ubi nakwa ubi vaịnị nʼala a.’ 
\p  
\v 16 “Mgbe m nyechasịrị Baruk nwa Neraya akwụkwọ ndị ahụ, ekpere m ekpere nye \nd Onyenwe anyị\nd* sị, 
\pm  
\v 17 “Gị, Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* ọ bụ gị sitere nʼike gị dị ukwuu, na aka gị e setịrị eseti mee eluigwe na ụwa. O nweghị ihe ọbụla ị na-enweghị ike ime.  
\v 18 Ị na-egosi ịhụnanya nye ọtụtụ puku ndị mmadụ ma na-eweta ịta ahụhụ nye ụmụ site nʼihi mmehie nna ha. O Chineke dị ukwuu dịkwa ike, \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile bụ aha gị.  
\v 19 Nzube gị dị ukwuu, otu a kwa akaọrụ gị dịkwa ukwuu. Anya gị ghere oghe nye ụzọ mmadụ niile. Ị na-akwụghachikwa onye ọbụla dịka ndụ ya na akaọrụ ya si dị.  
\v 20 Ọ bụ gị mere ihe ịrịbama na ihe ebube dị iche iche nʼIjipt. Ị nọgidekwara na-arụ ha ruo taa, ma nʼala Izrel ma nʼetiti ndị niile nọ nʼụwa. Nʼihi ya, i meere onwe gị aha nke ka bụkwa nke gị nʼebe niile.  
\v 21 Ọ bụ ihe ịrịbama na ọrụ ebube dị iche iche, nʼaka dị ike, na ogwe aka e setịpụrụ esetipụ, nʼihe oke egwu, ka i ji kpọpụta ndị gị Izrel site nʼIjipt.  
\v 22 Ị nyere ha ala a, nke ị ṅụrụ nʼiyi inye nna nna ha, ala mmiri ara ehi na mmanụ aṅụ na-eru na ya.  
\v 23 Ha batara nʼala a, nweta ya, ma ha jụrụ irubere gị isi, maọbụ jegharịa nʼiwu gị; ha emeghị ihe ndị i nyere ha nʼiwu mee. Nʼihi ya, i mere ka ihe ọjọọ ndị a bịakwasị ha. 
\pm  
\v 24 “Lee ka ndị iro si wuo ihe agha ha gburugburu mgbidi obodo a, ihe agha nke ha ga-eji lụta ya nʼagha. I werela obodo a nyefee ndị Babilọn na-ebuso ya agha nʼaka, nʼihi mma agha na ụnwụ, na oke ọrịa dị nʼime ya. Ihe i kwuru na ọ ga-eme emezuola, dịka i si ahụ ya ugbu a.  
\v 25 Ma ọ bụ ezie na a ga-enyefe obodo a nʼaka ndị Babilọn, ma gị, Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* gwara m sị, ‘Were ọlaọcha zụta ala ahụ. Zụkwaa ya nʼihu ndị akaebe.’ ” 
\p  
\v 26 Mgbe ahụ, okwu \nd Onyenwe anyị\nd* ruru Jeremaya ntị sị ya,  
\v 27 “Abụ m \nd Onyenwe anyị\nd*, Chineke nke anụ ahụ niile bụ mmadụ. Ọ dị ihe ọbụla karịrị m ime?  
\v 28 Ya mere, ihe ndị a ka \nd Onyenwe anyị\nd* kwuru: Ejikerela m ugbu a inyefe obodo a nʼaka ndị Babilọn, na nʼaka Nebukadneza eze Babilọn, onye ga-alụta ya nʼagha.  
\v 29 Ndị Babilọn ahụ na-ebuso obodo a agha, ga-abata nʼime ya, kpọọ ya ọkụ. Ha ga-akpọ ya ọkụ, ya na ụlọ niile dị nʼime ya, bụ ụlọ niile ahụ ndị bi nʼime ya nọ kpasuo m iwe, site nʼisure ihe nsure ọkụ na-esi isi ụtọ nye chi Baal nʼelu ụlọ ha niile, na site nʼịwụsara chi ndị ọzọ onyinye ihe ọṅụṅụ. 
\p  
\v 30 “Ọ bụ naanị ihe ọjọọ ka ndị Izrel na ndị Juda mere nʼihu m site na mgbe ha bụ nwantakịrị. Nʼezie, ha esitela nʼihe ha ji aka mee kpasuo m iwe, ka \nd Onyenwe anyị\nd* kwuru.  
\v 31 Site nʼoge e wuru ya ruo ugbu a, ndị bi nʼobodo a akpaliela iwe m na ọnụma m. Ya mere, aga m esite nʼihu m wezuga ha.  
\v 32 Ndị Izrel na Juda, na ndị eze ha, na ndịisi ọchịchị ha, na ndị nchụaja ha, na ndị amụma ha, na ndị ikom Juda, ma ndị bi na Jerusalem, akpasuola m iwe site nʼihe ọjọọ niile ha mere.  
\v 33 Ha gbakụtara m azụ, jụ ilenye anya nʼebe m nọ. Ọ bụ ezie na m ziri ha ihe mgbe mgbe, ma ha jụrụ ige ntị, jụkwa ịnabata ịdọ aka na ntị m.  
\v 34 Ha doro oyiyi ihe arụ nʼụlọnsọ ahụ a kpọkwasịrị aha m, si otu a merụọ ya.  
\v 35 Ha wuru ebe dị elu dị iche iche na Ndagwurugwu nke Ben Hinom nye Baal, ebe ha nọ jiri ụmụ ha ndị ikom na ndị inyom chụọ aja nye Molek. O nweghị mgbe m nyere ha iwu ime ihe dị otu a, o nweghị mgbe ajọ ihe dị otu a batara m nʼobi, nke i nye ha iwu ime ihe arụ dị otu a, nke ime ka Juda mehie. 
\p  
\v 36 “Ihe i kwuru banyere obodo a bụ, ‘A ga-esite na mma agha, na nʼụnwụ, na nʼoke ọrịa, nyefee ha nʼaka eze Babilọn,’ ma ihe ndị a ka \nd Onyenwe anyị\nd*, Chineke Izrel kwuru,  
\v 37 Lee, aghaghị m ịchịkọta ha site na mba ndị ahụ niile m sitere nʼiwe m, na nʼoke ọnụma m chụga ha. Aga m akpọghachite ha nʼebe a, mee ka ha biri nʼudo.  
\v 38 Ha ga-abụ ndị m, mụ onwe m ga-abụkwa Chineke ha.  
\v 39 Aga m enye ha otu obi na otu ụzọ, ime ka ha na-atụ egwu m, nʼihi ọdịmma nke ha, na ọdịmma nke ụmụ ha ndị ga-eso ha.  
\v 40 Aga m eme ka ọgbụgba ndụ ebighị ebi dịrị nʼetiti mụ na ha. Agaghị m akwụsị imere ha ihe ọma, aga m akwalikwa obi ha ịtụ egwu m. Nʼụzọ dị otu a, ha agaghị esitekwa nʼiso m wezuga onwe ha.  
\v 41 Obi ga-atọkwa m ụtọ ime ha mma; m ga-ejikwa obi m niile, na mkpụrụobi m niile kụọ ha nʼala a. 
\p  
\v 42 “Ihe ndị a ka \nd Onyenwe anyị\nd* kwuru, Dịka m mere ka ihe ọjọọ ukwuu a niile bịakwasị ndị a, otu a ka m ga-esikwa mee ka ezi ihe ahụ niile m kwere ha na nkwa bịakwasị ha.  
\v 43 A ga-azụkwa ọhịa\f + \fr 32:43 \ft Ya bụ, ala ubi\f* nʼala a unu na-asị na ọ bụ ala tọgbọrọ nʼefu, nke mmadụ na anụmanụ na-adịghị nʼime ya, ala nke e nyefere nʼaka ndị Babilọn.  
\v 44 A ga-ejikwa ọlaọcha zụọ ala ubi, deekwa ihe banyere orire na ọzụzụ ya nʼakwụkwọ. A ga-aka akwụkwọ ndị ahụ akara nʼihu ndị akaebe, nʼala Benjamin, na nʼobodo nta niile dị gburugburu Jerusalem, ma nʼala Juda, na nʼobodo dị nʼala ugwu ugwu, na nke dị na mgbada ugwu niile dị nʼọdịda anyanwụ, na nke dị na Negev, nʼihi na aga m esite nʼobodo ndị ahụ dọtara ha nʼagha buuru ha gaa kpọlata ha.\f + \fr 32:44 \ft Maọbụ, \fqa m ga-eweghachitere ha ihe onwunwe ha\f* Otu a ka \nd Onyenwe anyị\nd* kwubiri.” 
\c 33  
\s1 Nkwa banyere nlọghachi 
\p  
\v 1 Mgbe Jeremaya ka nọ dịka onye mkpọrọ nʼogige ụlọ ndị nche, okwu \nd Onyenwe anyị\nd* ruru ya ntị nke ugboro abụọ, sị ya,  
\v 2 “Ihe ndị a ka \nd Onyenwe anyị\nd*, onye ahụ kere ụwa kwuru, \nd Onyenwe anyị\nd*, onye kpụrụ ya mee ya ka o guzosie ike, Onye aha ya bụ \nd Onyenwe anyị\nd*:  
\v 3 ‘Kpọkuo m, aga m aza gị, gosi gị ihe dị ukwuu dị iche iche, na ihe siri ike na nghọta nke ị na-amaghị.’  
\v 4 Nʼihi na nke a bụ ihe \nd Onyenwe anyị\nd*, bụ Chineke Izrel, kwuru banyere ụlọ ndị ahụ niile dị nʼobodo, na ụlọeze niile nke ndị eze Juda, bụ nke akwadara maka iji megide nnọchibido niile na mma agha  
\v 5 nʼagha a na-alụso ndị Babilọn. ‘Aga eji ozu ndị mmadụ ahụ niile m ga-etigbu site nʼiwe m na nʼọnụma m kpojuo ha. Aga m ezo ihu m site nʼebe obodo a nọ, nʼihi ajọ omume ya niile. 
\p  
\v 6 “ ‘Ma otu ọ dị, aga m agwọ ya, mee ka ahụ sie ya ike. Aga m agwọ ndị m, meekwa ka ha nwe udo nʼebe ọ bara ụba. Ha ga-ebikwa nʼudo na-enweghị egwu ọbụla.  
\v 7 Aga m emekwa ka ndị Izrel na ndị Juda a dọtara nʼagha lọta. Aga m ewugharịkwa ha dịka ụlọ, mee ka ha dịrị ka ha dị na mbụ.  
\v 8 Aga m eme ka ha dị ọcha site na mmehie ha niile, nke ha mere megide m. Aga m agbaghara ha mmehie ha na nnupu isi ha niile megide m.  
\v 9 Mgbe ahụ, obodo a ga-aghọkwa ihe ga-eme ka mba niile nke ụwa mara m, ka ha ṅụrịa ọṅụ nʼime m, tookwa m, ma wetara m nsọpụrụ, mgbe ha ga-anụ ihe ọma niile m meere obodo a. Ha ga-atụkwa oke egwu, maakwa jijiji, nʼihi ezi ihe ahụ niile na nʼihi udo ahụ niile nke mụ onwe m mere ka o rute ha aka.’ 
\p  
\v 10 “Ihe ndị a ka \nd Onyenwe anyị\nd* kwuru, ‘Unu na-asị banyere ebe a, “Ọ bụ mkpọmkpọ ebe, ebe ụmụ mmadụ na ụmụ anụmanụ na-ebighị nʼime ya.” Ma nʼobodo Juda, ya na okporoụzọ niile dị na Jerusalem, nke tọgbọrọ nʼefu ugbu a, nke mmadụ maọbụ anụmanụ na-ebighị nʼime ya, a ga-emesịa nụkwa  
\v 11 olu ọṅụ na obi ụtọ, na olu ndị ikom na ndị inyom na-alụ di na nwunye, na olu ndị ahụ niile na-eweta onyinye ekele nʼụlọ \nd Onyenwe anyị\nd*, ndị ahụ ga-asị, 
\q1 “ ‘ “Nyenụ \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile ekele 
\q2 nʼihi na \nd Onyenwe anyị\nd* dị mma. 
\q2 Ịhụnanya ya na-adịgidekwa ruo mgbe ebighị ebi.” 
\m Nʼihi na aga m eme ka ndị ala a, nke a dọtara nʼagha lọta, dịkwa ka ha dị na mbụ,’ otu a ka \nd Onyenwe anyị\nd* kwuru. 
\p  
\v 12 “Ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwuru, ‘Nʼebe a, nke bụ mkpọmkpọ ebe ugbu a, nke mmadụ maọbụ anụmanụ na-ebighị nʼime ya, ka a ga-emesịa nweekwa ebe ịta nri nke igwe ewu na atụrụ, nʼime obodo niile, ebe ndị ọzụzụ atụrụ ga-eduru igwe ewu na atụrụ ha gaa izuike.  
\v 13 Nʼime obodo niile nke dị nʼala ugwu ugwu, na nʼobodo niile nke dị na mgbada ugwu niile nke Negev, nʼoke ala Benjamin, nʼime obodo nta niile nke gbara Jerusalem gburugburu, na nʼime obodo niile nke Juda. Igwe ewu na atụrụ ga-agabigakwa ọzọ nʼokpuru aka abụọ nke onye na-agụ ha ọnụ.’ Otu a ka \nd Onyenwe anyị\nd* na-ekwu. 
\p  
\v 14 “ ‘Ụbọchị ndị ahụ na-abịa,’ ka \nd Onyenwe anyị\nd* kwupụtara, ‘mgbe m ga-emezu ezi nkwa ahụ m kwere ụlọ Izrel na ụlọ Juda. 
\q1  
\v 15 “ ‘Nʼụbọchị ndị ahụ, na nʼoge ahụ, 
\q2 aga m eme ka Alaka ezi omume pupụta site nʼezinaụlọ Devid. 
\q2 Ọ ga-eme ihe ziri ezi, kpeekwa ikpe ziri ezi nʼala ahụ. 
\q1  
\v 16 Nʼụbọchị ndị ahụ, ka a ga-azọpụta Juda, 
\q2 Jerusalem ga-ebikwa nʼudo.\f + \fr 33:16 \ft Na-atụghị ụjọ ọbụla\f* 
\q1 Nke a bụ aha a ga-akpọ ya, 
\q2 \nd Onyenwe anyị\nd* Onye Nzọpụta, bụ ezi omume anyị.’\f + \fr 33:16 \ft Onyenwe anyị, bụ ezi omume anyị\f* 
\m  
\v 17 Nʼihi na ihe ndị a ka \nd Onyenwe anyị\nd* kwuru, ‘O nweghị oge a ga-ahapụ inweta otu onye site nʼezinaụlọ Devid onye ga-anọ nʼocheeze ụlọ Izrel.  
\v 18 Ọ dịkwaghị mgbe a ga-ahapụ inweta onye ga-esite nʼetiti ndị nchụaja na ndị Livayị, nke ga-eguzo nʼihu m ụbọchị niile ịchụ aja nsure ọkụ, na i wetara m onyinye ịnata ihuọma, na ịchụrụ m aja dị iche iche.’ ” 
\p  
\v 19 Emesịa, okwu \nd Onyenwe anyị\nd* ruru Jeremaya ntị sị ya,  
\v 20 “Ihe ndị a ka \nd Onyenwe anyị\nd* kwuru, ‘Ọ bụrụ na unu nwere ike ime ka ọgbụgba ndụ m na ehihie, na ọgbụgba ndụ mụ na abalị ghara ịdịkwa, ime ka ehihie na abalị gharakwa ịpụta nʼoge ha,  
\v 21 mgbe ahụ ọgbụgba ndụ nke mụ na Devid ohu m gbara, na ọgbụgba ndụ nke m mere ka ọ dịrị nʼetiti mụ na ndị Livayị, bụ ndị nchụaja na-eje ozi ha nʼihu m, agaghị adịkwa. A gaghị enwekwa onye ga-esi nʼezinaụlọ Devid nke ga-anọkwasị nʼocheeze ya.  
\v 22 Aga m eme ka ụmụ ụmụ Devid ohu m, na ndị Livayị, bụ ndị na-eje ozi ha nʼihu m, dị ukwuu nʼọnụọgụgụ dịka kpakpando dị na mbara eluigwe; ha ga-adịkwa ukwuu dịka uzuzu dị nʼọnụ mmiri osimiri nke a na-apụghị ịgụta ọnụ.’ ” 
\p  
\v 23 Okwu \nd Onyenwe anyị\nd* ruru Jeremaya ntị sị ya,  
\v 24 “Ị hụla ajụjụ ndị a na-ajụ? Ha na-ajụ na-asị, ‘\nd Onyenwe anyị\nd* ọ jụla agbụrụ abụọ ndị a ọ họpụtara?’ Nʼihi ya, ha na-elelị ndị m, ha adịghị agụkwa ha dịka mba.  
\v 25 Ihe ndị a ka \nd Onyenwe anyị\nd* kwuru, ‘Ọ bụrụ na m emeghị ka ọgbụgba ndụ dịrị nʼetiti mụ na ehihie na abalị, meekwa ka iwu na-achị eluigwe na ụwa guzosie ike,  
\v 26 mgbe ahụ, agaara m ajụ ụmụ ụmụ Jekọb, na ụmụ ụmụ Devid ohu m. Agaraghị m ahọpụta otu nʼime ụmụ ya ka ọ chịa ụmụ ụmụ Ebraham na Aịzik na Jekọb. Ma aga m eme ka ndị ha a dọtara nʼagha lọta; aga m enwekwa obi ebere nʼahụ ha.’ ” 
\c 34  
\s1 Ịdọ aka na ntị a dọrọ Zedekaya 
\p  
\v 1 Mgbe Nebukadneza eze Babilọn na ndị agha ya niile, na mba niile dị nʼalaeze nke ọ na-achị na-ebuso Jerusalem na obodo niile gbara ya gburugburu agha, okwu \nd Onyenwe anyị\nd* ruru Jeremaya ntị sị,  
\v 2 “Ihe ndị a ka \nd Onyenwe anyị\nd*, Chineke Izrel kwuru, Jekwuru Zedekaya bụ eze Juda, gwa ya sị, ‘Ihe ndị a ka \nd Onyenwe anyị\nd* kwuru, ejikerela m ugbu a inyefe eze Babilọn obodo a nʼaka. Ọ ga-esurekwa ya ọkụ.  
\v 3 Ị gaghị agbanarị ya, nʼihi na ọ ga-ejide gị. A ga-arara gị nyefekwa ya nʼaka. Anya gị abụọ ka ị ga-eji hụ eze Babilọn. Gị na ya ga-ekwurịtakwa okwu. Ị ga-agakwa Babilọn. 
\p  
\v 4 “ ‘Ma nụrụkwa nkwa \nd Onyenwe anyị\nd* na-ekwe gị, gị Zedekaya eze Juda. Ihe ndị a ka \nd Onyenwe anyị\nd* kwuru banyere gị, Ị gaghị anwụ site na mma agha;  
\v 5 ị ga-anwụ nʼudo. Dịka ndị mmadụ si mụnye ọkụ kwaa ozu nna gị ha, bụ ndị buru gị ụzọ chịa ka eze, otu a ka ha ga-esi mụnye ọkụ kwaa gị. Ha ga-eti aka nʼobi kwa akwa sị, “Ewoo, onyenwe anyị!” Ọ bụ mụ onwe m na-ekwe nkwa a, otu a ka \nd Onyenwe anyị\nd* kwubiri ya.’ ” 
\p  
\v 6 Mgbe ahụ, Jeremaya onye amụma gara gwa Zedekaya eze Juda ihe ndị a niile na Jerusalem.  
\v 7 Nʼoge a, ndị agha eze Babilọn na-ebuso Jerusalem agha. Ha na-ebusokwa obodo ndị ọzọ nke nọgidere na-ebuso ha agha, nke bụ obodo Lakish na Azeka. Obodo ndị a bụ naanị obodo fọdụrụ nʼala Juda nke ndị agha Babilọn na-emeribeghị. 
\s1 Inwe onwe nke ndị ohu 
\p  
\v 8 Okwu \nd Onyenwe anyị\nd* ruru Jeremaya ntị mgbe Zedekaya bụ eze, na ndị Izrel niile gbachara ndụ na Jerusalem ịkpọsara ndị ohu niile nwere onwe ha.  
\v 9 Onye ọbụla ga-ahapụ ohu ya bụ onye Hibru ka o nwere onwe ya, ma ohu ahụ ọ bụ nwoke maọbụ nwanyị. A gaghị agụkwa onye Juu ọbụla dịka ohu ọzọ.  
\v 10 Ya mere, ndịisi ọchịchị niile, na ndị niile bụ ndị kwekọrịtara gbaa ndụ a, na ha ga-ahapụ ohu ha ndị nwoke na ndị nwanyị ka ha nwere onwe ha. Ha mekwara dịka ha si kwuo.  
\v 11 Ma mgbe oge nta gasịrị, ndị a niile gbanwere obi ha. Ha gara jide ohu ndị ahụ ha hapụrụ, mee ka ha ghọọkwa ndị ohu ha ọzọ. 
\p  
\v 12 Mgbe ahụ, okwu \nd Onyenwe anyị\nd* ruru Jeremaya ntị sị ya,  
\v 13 “Ihe ndị a ka \nd Onyenwe anyị\nd*, Chineke Izrel, kwuru, Mụ na nna nna unu ha gbara ndụ mgbe m si nʼala Ijipt, bụ ala ebe ha bụ ohu kpọpụta ha. Mgbe ahụ agwara m ha sị,  
\v 14 ‘Nʼọgwụgwụ afọ asaa ọbụla, onye ọbụla nʼime unu aghaghị ịhapụ onye Hibru ibe unu resiri unu onwe ya dịka ohu, ka o nwerekwa onwe ya. Mgbe onye ahụ jeere unu ozi afọ isii, unu kwesiri ịhapụ ya ka o nwere onwe ya.’ Ma nna nna unu ha egeghị m ntị, ha etinyeghịkwa uche ha nʼiwu m nyere ha.  
\v 15 Na nwa oge nta gara aga unu chegharịrị mee ihe ziri ezi nʼanya m. Onye ọbụla nʼime unu kpọsara inwere onwe nye ndị unu. Unu gara nʼihu gbaa ndụ nʼihu m nʼime ụlọnsọ ahụ a kpọkwasịrị aha m.  
\v 16 Ma ugbu a, unu echigharịala, merụọ aha m; onye ọbụla nʼime unu akpọghachikwala nye onwe ya ndị ohu ndị ikom na ndị inyom ahụ unu hapụrụ ka ha nwere onwe ha, gaa dịka o si masị mkpụrụobi ha. Unu akwagidekwala ha ka ha bụrụkwa ndị ohu unu ọzọ. 
\p  
\v 17 “Nʼihi nke a, ihe ndị a ka \nd Onyenwe anyị\nd* kwuru, Unu erubeghị isi nye m, unu ekwusaghị nwere onwe nye ndị unu. Ya mere, ugbu a mụ onwe m na-akpọsa ‘Inwere onwe’ nye unu, ka \nd Onyenwe anyị\nd* kwubiri, ‘inwere onwe’ nke ịda nʼihi mma agha, na ajọ ọrịa na-efe efe, na oke ụnwụ. Aga m emekwa unu ka unu ghọọ ihe ịsọ oyi nye alaeze niile nke ụwa.  
\v 18 Ma ndị ikom ahụ niile merụrụ ọgbụgba ndụ m, ndị ahụ na-edebezughị ọgbụgba ndụ ha gbara nʼihu m, ka m ga-eme ka ha dịrị ka nwa ehi ọgbụgba ndụ ahụ ha kpọwara abụọ, nke ha si nʼetiti ọkara abụọ ya gafee, maka imesi ọgbụgba ndụ ha ike.  
\v 19 Ndị ndu Juda na Jerusalem na ndị ozi eze na ndị nchụaja na ndị niile bi nʼala a ndị si nʼetiti ọkara nwa ehi ahụ gabiga  
\v 20 ka m ga-enyefe nʼaka ndị iro ha ndị na-achọ iwepụ ndụ ha. Ozu ha ga-abụ ihe oriri nye anụ ufe nke eluigwe na anụ ọhịa nke ụwa. 
\p  
\v 21 “Aga m enyefe Zedekaya eze Juda na ndịisi ọchịchị ya nʼaka ndị iro ha, ndị na-achọ ndụ ha. Aga m enyefe ha nʼaka ndị agha eze Babilọn, ndị siterela nʼibuso unu agha wezuga onwe ha.  
\v 22 Aga m enye iwu, ka \nd Onyenwe anyị\nd* kwubiri, mee ka a kpọghachi ha azụ nʼobodo a. Ha ga-ebuso ya agha, merie ya, surekwaa ya ọkụ. Aga m emekwa ka obodo Juda niile tọgbọrọ nʼefu. Ọ dịkwaghị onye ga-ebi nʼime ya.” 
\c 35  
\s1 Ụmụ Rekab 
\p  
\v 1 Ndị a bụ okwu \nd Onyenwe anyị\nd* nke ruru Jeremaya ntị nʼoge ọchịchị Jehoiakim nwa Josaya eze Juda sị ya,  
\v 2 “Jee nʼụlọ ụmụ Rekab kpọọ ha oku ka ha bịa nʼụlọnsọ \nd Onyenwe anyị\nd*, nʼotu nʼime ọnụụlọ ya, nọdụ nʼebe ahụ nye ha mmanya ka ha ṅụọ.” 
\p  
\v 3 Ya mere, ejekwuuru m Jaazanaya nwa Jeremaya, nwa Habazinaya na ụmụnne ya, na ụmụ ya ndị ikom, ya bụ, ndị ezinaụlọ Rekab niile.  
\v 4 Akpọbatara m ha nʼụlọnsọ \nd Onyenwe anyị\nd*, nʼime ọnụụlọ ụmụ Hanan nwa Igdalaya, onye nke Chineke. Ọnụụlọ a dị nso nʼọnụụlọ ndịisi ụlọnsọ, nke dị nʼelu ọnụụlọ Maaseia nwa Shalum, onye nche ọnụ ụzọ ụlọnsọ.  
\v 5 Mgbe ahụ, e doziri m ọkwa ụfọdụ jupụtara na mmanya na iko ụfọdụ nʼihu ụmụ Rekab, sị ha, “Ngwanụ, ṅụanụ mmanya.” 
\p  
\v 6 Ma ha zara sị, “Anyị adịghị aṅụ mmanya, nʼihi na nna nna anyị Jehonadab nwa Rekab nyere anyị iwu sị anyị, ‘Unu aṅụkwala mmanya, unu na ụmụ ụmụ unu.  
\v 7 Ọzọkwa, unu ewurula onwe unu ụlọ, unu akụla mkpụrụ ubi, maọbụ kụọ ubi vaịnị. Unu adọtarala onwe unu ihe ndị a niile, kama na-ebinụ nʼụlọ ikwuu. Ọ bụ nʼụzọ dị otu a ka unu ga-esi bie ogologo ndụ nʼala ahụ unu bụ ndị ọbịa nʼime ya.’  
\v 8 Anyị erubela isi nʼihe niile nna nna anyị Jehonadab nwa Rekab gwara anyị. Anyị na ndị nwunye anyị na ụmụ anyị ndị ikom na ndị inyom adịghị aṅụ mmanya,  
\v 9 maọbụ wuo ụlọ, maọbụ nwee ubi vaịnị, ala ubi maọbụ mkpụrụ ọkụkụ.  
\v 10 Ọ bụkwa nʼụlọ ikwuu ka anyị na-ebi dị ka nna nna anyị Jehonadab nyere anyị nʼiwu.  
\v 11 Ma mgbe Nebukadneza eze Babilọn busoro ala anyị agha, anyị kpebiri sị, ‘Bịanụ ka anyị gbaba Jerusalem si otu a gbanarị ndị agha Babilọn, na ndị agha ndị Aram.’ Ọ bụ nke a mere anyị ji biri na Jerusalem.” 
\p  
\v 12 Mgbe ahụ, okwu \nd Onyenwe anyị\nd* ruru Jeremaya ntị sị ya  
\v 13 Ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, bụ Chineke Izrel kwuru, “Gaa gwa ndị Juda na ndị bi na Jerusalem, ‘Ọ bụ na unu agaghị esite nʼịdọ aka na ntị mụta irubere okwu m isi?’ ka \nd Onyenwe anyị\nd* kwupụtara.  
\v 14 ‘Jehonadab nwa Rekab nyere ụmụ ụmụ ya iwu sị ha aṅụla mmanya, ha na-edebe iwu ahụ. Ruo taa, ha adịghị aṅụ mmanya, nʼihi na ha na-edebe iwu nna nna ha nyere ha. Ma mụ onwe m agwala unu okwu mgbe na mgbe, ma unu jụrụ irubere m isi.  
\v 15 Mgbe mgbe ka m ziteere unu ụmụ ohu m bụ ndị amụma, ndị bịara gwa unu okwu sị, “Dozienụ ụzọ unu, sitekwanụ nʼajọ omume unu tụgharịa. Unu niile nʼotu nʼotu, unu agbasola chi ndị ọzọ ife ha. Ọ bụrụ na unu emee otu a, unu ga-ebi nʼala a m nyere unu na nna nna unu ha.” Ma unu jụrụ ịṅa ntị, jụkwa ige m ntị.  
\v 16 Ụmụ ụmụ Jehonadab, nwa Rekab, emeela ihe nna nna ha nyere ha nʼiwu, ma ndị a jụrụ irubere m isi.’ 
\p  
\v 17 “Nʼihi ya, ihe ndị a ka \nd Onyenwe anyị\nd* Chineke Onye pụrụ ime ihe niile, Chineke Izrel kwuru: ‘Geenụ ntị! Lee, ana m aga ime ka ihe ọjọọ bịakwasị Juda na ndị niile bi na Jerusalem, dịka m kwuru na ọ ga-adị. Nʼihi na agwala m ha okwu, ma ha jụrụ ige m ntị. Akpọrọ m ha oku, ma ha jụrụ ịza.’ ” 
\p  
\v 18 Mgbe ahụ, Jeremaya gwara ndị ezinaụlọ Rekab, “Ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, bụ Chineke Izrel kwuru, ‘Unu erubeela isi mee ihe niile nna nna unu bụ Jehonadab nyere unu nʼiwu.’  
\v 19 Nʼihi ya, \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, bụ Chineke Izrel, kwuru sị, ‘O nweghị mgbe ọbụla nwoke ga-ejere m ozi ga-akọ nʼezinaụlọ Jehonadab nwa Rekab.’ ” 
\c 36  
\s1 Jehoiakim akpọọ akwụkwọ Jeremaya ọkụ 
\p  
\v 1 Nʼafọ anọ nke ọchịchị Jehoiakim nwa Josaya bụ eze Juda, okwu \nd Onyenwe anyị\nd* ndị a ruru Jeremaya ntị,  
\v 2 “Were akwụkwọ detuo okwu ahụ niile m gwarala gị banyere Izrel, na Juda, na banyere ndị mba ọzọ dị iche iche, bụ okwu ndị ahụ m bidoro ịgwa gị site nʼoge ọchịchị Josaya ruo ugbu a.  
\v 3 Ma eleghị anya mgbe ndị Juda nụrụ ka e kwupụtara ihe banyere ihe ọjọọ ndị ahụ m zubere, nke na-aga ịbịakwasị ha, onye ọbụla nʼime ha nʼotu nʼotu ga-esite nʼụzọ ọjọọ ya tụgharịa. Mgbe ahụ, aga m agbaghara ha ajọ omume ha na mmehie ha.” 
\p  
\v 4 Ya mere, Jeremaya kpọrọ Baruk nwa Neraya ka ọ bịakwute ya. Mgbe Jeremaya nọ na-akpọpụta okwu ahụ niile \nd Onyenwe anyị\nd* gwara ya, Baruk nọkwa na-edepụta ha nʼakwụkwọ.  
\v 5 Emesịa, Jeremaya gwara Baruk okwu sị ya, “Ọnọdụ nke m nọ nʼime ya ugbu a agaghị ekwe ka m site nʼebe a pụọ jeruo nʼụlọnsọ \nd Onyenwe anyị\nd*.  
\v 6 Nʼihi ya, gaa nʼụlọnsọ \nd Onyenwe anyị\nd* nʼụbọchị ibu ọnụ, nọdụ nʼebe ahụ gụpụtara ndị mmadụ okwu \nd Onyenwe anyị\nd* ndị a ị dere nʼakwụkwọ dịka m kpọpụtara ha. Gụpụtara ya ndị Juda si obodo niile bịa nʼụlọnsọ ahụ.  
\v 7 Ma eleghị anya, ha ga-arịọ \nd Onyenwe anyị\nd* arịrịọ. Ma eleghị anya onye ọbụla nʼime ha ga-esite nʼụzọ ọjọọ ya tụgharịa, ka iwe na ọnụma dị ukwuu nke \nd Onyenwe anyị\nd* ga-ekpughe megide ndị a ghara ịbịakwasị ha.” 
\p  
\v 8 Baruk nwa Neraya mere dịka Jeremaya onye amụma si gwa ya. Ọ gụpụtara okwu \nd Onyenwe anyị\nd*, nke dị nʼakwụkwọ ahụ, nʼụlọnsọ \nd Onyenwe anyị\nd*.  
\v 9 Nʼọnwa itoolu nke afọ ise nke ọchịchị Jehoiakim nwa Josaya eze Juda, e doro oge dị iche nye maka ibu ọnụ nʼihu \nd Onyenwe anyị\nd*. E kwusara ibu ọnụ a nye ndị niile nọ na Jerusalem, na ndị si nʼobodo Juda niile bịa na Jerusalem.  
\v 10 Baruk nọ nʼọnụụlọ Gemaraya nwa Shefan, bụ ode akwụkwọ, gụpụtara ndị niile nọ nʼụlọnsọ Onyenwe anyị okwu Jeremaya, nke dị nʼakwụkwọ a dị nsọ nʼọnụ ụzọ ama ọhụrụ nke ụlọnsọ ahụ. 
\p  
\v 11 Mgbe Mikaya nwa Gemaraya nwa Shefan nụrụ okwu \nd Onyenwe anyị\nd* nke e si nʼakwụkwọ ahụ gụpụta,  
\v 12 o si nʼebe ahụ pụọ, gaa nʼụlọ ode akwụkwọ dị nʼụlọeze, ebe ndịisi niile zukọrọ. Ndị a bụ ndị zukọrọ nʼebe ahụ; Elishama, ode akwụkwọ, na Delaya nwa Shemaya, na Elnatan nwa Akboa, na Gemaraya nwa Shefan, na Zedekaya nwa Hananaya, na ndịisi ọchịchị ndị ọzọ.  
\v 13 Mgbe Mikaya gwara ha ihe ọ nụrụ Baruk si nʼakwụkwọ ahụ gụpụtara ndị mmadụ,  
\v 14 ndịisi ahụ niile zipụrụ Jehudi nwa Netanaya, nwa Shelemaya, nwa Kushi, ka o jekwuru Baruk sị ya “Were akwụkwọ ahụ ị si na ya gụpụtara ndị mmadụ ihe, bịa.” Ya mere, Baruk, nwa Neraya, ji akwụkwọ a nʼaka ya jekwuru ha.  
\v 15 Mgbe o ruru nʼebe ahụ, ha gwara ya sị ya, “Biko, nọdụ ala gụọra anyị ihe dị nʼakwụkwọ a.” 
\p Ya mere, Baruk gụpụtara ha ihe dị nʼakwụkwọ ahụ.  
\v 16 Mgbe ha nụchasịrị okwu dị nʼakwụkwọ ahụ, ha lerịtara onwe ha anya nʼegwu, gwa Baruk okwu sị ya, “Anyị aghaghị ime ka okwu ndị a ruo eze ntị.”  
\v 17 Ha jụrụ Baruk sị ya, “Gwa anyị i si aṅaa detuo ihe ndị a niile? Ọ bụ Jeremaya kpọpụtaara gị ihe i dere?” 
\p  
\v 18 Baruk zara sị ha, “E, ọ bụ ya kpọpụtara m okwu ndị a niile m deturu. E ji m inki dee ha nʼakwụkwọ.” 
\p  
\v 19 Mgbe ahụ, ndịisi ahụ gwara Baruk okwu sị ya, “Ọsọ, gaa ka gị na Jeremaya zoo onwe unu. Unu ekwekwala ka onye ọbụla mata ebe unu zoro onwe unu.” 
\p  
\v 20 Mgbe ha zochasịrị akwụkwọ ahụ nʼọnụụlọ Elishama onye ode akwụkwọ, ha jekwuuru eze nʼogige ụlọ ya kọọrọ ya ihe niile.  
\v 21 Eze ziri Jehudi ka ọ gaa weta akwụkwọ ahụ. Mgbe Jehudi wetara ya site nʼọnụụlọ Elishama, ode akwụkwọ, ọ gụrụ ya nʼihu eze, na nʼihu ndịisi ọchịchị ahụ niile guzo nʼakụkụ eze.  
\v 22 Nʼọnwa nke itoolu ahụ, mgbe eze nọ nʼụlọ oyi ya, ọkụ na-enwukwa nʼime ite ọkụ dị nʼihu ya.  
\v 23 Mgbe ọbụla Jehudi gụsịrị ibe akwụkwọ atọ maọbụ anọ, eze na-anara ya akwụkwọ ndị ahụ were agụba ode akwụkwọ chakasịa ha, wụnye ha nʼọkụ. O megidere otu a tutu ruo mgbe ọ wụnyechara akwụkwọ ndị ahụ niile nʼọkụ.  
\v 24 Eze na ndị so ya nọdụ nʼoge a na-agụpụta akwụkwọ a atụghị egwu ọbụla; ha adọwakwaghị uwe ha igosi obi ọjọọ.  
\v 25 Ọ bụ ezie na Elnatan na Delaya na Gemaraya rịọrọ eze sị ya adọkasịla akwụkwọ ndị ahụ, ma o geghị ha ntị.  
\v 26 Kama eze nyere Jerameel otu nʼime ụmụ eze, na Seraya nwa Azriel, na Shelemaya nwa Abdeel iwu ijide Baruk ode akwụkwọ, na Jeremaya onye amụma, ma \nd Onyenwe anyị\nd* zoro ha. 
\p  
\v 27 Mgbe eze suresịrị akwụkwọ ahụ na okwu niile nke Baruk dere nʼime ya ọkụ, bụ okwu nke Jeremaya kpọpụtara site nʼọnụ ya, okwu \nd Onyenwe anyị\nd* ruru Jeremaya ntị sị ya:  
\v 28 “Werekwa akwụkwọ ọzọ dee okwu ndị ahụ niile e dere nʼakwụkwọ nke mbụ ahụ, nke Jehoiakim eze Juda kpọrọ ọkụ.  
\v 29 Ọzọkwa, gwa Jehoiakim eze Juda sị ya, ‘otu a ka \nd Onyenwe anyị\nd* kwuru, Ị kpọrọ akwụkwọ ndị ahụ ọkụ, kwuo sị, “Gịnị mere i ji dee nʼime ya na eze Babilọn aghaghị ịbịa bibie ala a, gbuchapụ ndị niile nọ nʼime ya, ma mmadụ ma anụmanụ?”  
\v 30 Nʼihi ya, ihe ndị a ka \nd Onyenwe anyị\nd* kwuru banyere Jehoiakim eze Juda; Ọ gaghị amụta onye ga-anọ nʼocheeze Devid. Ọzọ, a ga-atụfu ozu ya nʼebe igirigi nke abalị ga-adakwasị ya, ebe okpomọkụ nke ehihie ga-erute ya.  
\v 31 Aga m ata ya na ụmụ ya, na ndị ozi ya ahụhụ nʼihi ajọ omume ha. Aga m eme ka ihe ọjọọ ahụ m kwuru ihe banyere ya bịakwasị ha na ndị niile bi na Jerusalem, na ndị Juda niile, nʼihi na ha jụrụ ige m ntị.’ ” 
\p  
\v 32 Ya mere, Jeremaya weere akwụkwọ ọzọ nye Baruk ode akwụkwọ, bụ nwa Neraya, dịka Jeremaya na-akpọpụta okwu, Baruk depụtakwara nʼakwụkwọ okwu ndị ahụ niile, nke Jehoiakim eze Juda surere nʼọkụ. A tụkwasịkwara nʼelu ha ọtụtụ okwu ndị ọzọ nke dịka ha. 
\c 37  
\s1 Jeremaya nʼụlọ mkpọrọ 
\p  
\v 1 Emesịa, Nebukadneza eze Babilọn mere Zedekaya nwa Josaya eze Juda, nʼọnọdụ Konaya\f + \fr 37:1 \ft Bụkwa Jehoiakin\f* nwa Jehoiakim.  
\v 2 Ma Zedekaya na ndị ozi ya, na ndị Juda niile egeghị ntị nʼokwu \nd Onyenwe anyị\nd* nke o si nʼọnụ Jeremaya onye amụma gwa ha. 
\p  
\v 3 Zedekaya bụ eze, ziri Jehukal nwa Shelemaya, na Zefanaya onye nchụaja, bụ nwa Maaseia ozi sị ha, jekwuru Jeremaya onye amụma gwa ya okwu sị, “Biko, kpeere anyị ekpere, rịọrọ anyị \nd Onyenwe anyị\nd* Chineke anyị arịrịọ.” 
\p  
\v 4 Nʼoge a, Jeremaya nweere onwe ya ijegharị nʼetiti ndị Izrel, nʼihi na ha etinyebeghị ya nʼụlọ mkpọrọ.  
\v 5 Nʼihi na mgbe ndị agha Babilọn gbara Jerusalem gburugburu na-ebuso ya agha, ndị agha Fero sitere Ijipt na-apụkwute ha ibuso ha agha. Mgbe ndị agha Babilọn nụrụ na ndị agha Ijipt na-abịa, ha mere ngwangwa si nʼibuso Jerusalem agha wezuga onwe ha. 
\p  
\v 6 Mgbe ahụ, okwu \nd Onyenwe anyị\nd* ruru Jeremaya onye amụma ntị sị ya,  
\v 7 “Ihe ndị a ka \nd Onyenwe anyị\nd* bụ Chineke Izrel kwuru, Ihe ndị a ka ị ga-agwa eze Juda onye zitere ozi sị gị rịọọ m arịrịọ, ‘Ndị agha Fero ahụ si nʼIjipt pụta bịa inyere unu aka ga-emesịa laghachi nʼala ha bụ Ijipt.  
\v 8 Mgbe ahụ, ndị agha Babilọn ga-alọghachikwa ibuso obodo a agha. Ha ga-emeri ya, dọta ya nʼagha, kpọọkwa ya ọkụ.’ 
\p  
\v 9 “Ihe ndị a ka \nd Onyenwe anyị\nd* kwuru, Unu arafula onwe unu site nʼiche echiche sị, ‘Ndị Babilọn agaghị abịakwa ibuso anyị agha.’ E, ha agaghị abịakwa ọzọ.  
\v 10 A sịkwa na ndị agha unu enwee ike merie ndị agha Babilọn ahụ ga-abịa ibuso unu agha, a sịkwa na ọ bụ naanị ndị e merụrụ ahụ bụ ndị fọdụrụ nʼetiti ha, ndị a ga-esi nʼogige ndị agha Babilọn pụta bịa kpọọ obodo a ọkụ.” 
\p  
\v 11 Mgbe ndị agha Babilọn si na gburugburu Jerusalem wezuga onwe ha nʼihi ọbịbịa ndị agha Fero na-abịa,  
\v 12 Jeremaya sitekwara na Jerusalem pụọ malite ịgawa nʼala ndị Benjamin, nʼihi iketa oke ruuru ya site nʼaka ndị bi nʼebe ahụ.  
\v 13 Ma mgbe o ruru nʼọnụ ụzọ ama Benjamin, onyeisi ndị agha aha ya bụ Irija nwa Shelemaya, nwa Hananaya jidere ya, boo ya ebubo sị ya, “Ọ bụ ọsọ ka ị na-agba! Ị na-achọ ịgbakwuru ndị Babilọn!” 
\p  
\v 14 Ma Jeremaya zara sị ya, “Ọ bụ okwu ụgha ka ị na-ekwu. Anaghị m agba ọsọ ịgbakwuru ndị Babilọn.” Ma Irija egeghị ya ntị, kama o jidere Jeremaya kpụta ya nʼihu ndịisi ọchịchị.  
\v 15 Ha were iwe megide Jeremaya, nye iwu ka e tie ya ihe, kpọchiekwa ya nʼụlọ Jonatan, ode akwụkwọ. Nʼihi na ha ji ụlọ ahụ mere ụlọ mkpọrọ nʼoge a. 
\p  
\v 16 E tinyere Jeremaya nʼime ụlọ mkpọrọ olulu, ebe ọ nọrọ ogologo oge.  
\v 17 Emesịa, Zedekaya bụ eze nyere iwu ka a kpọta ya nʼụlọeze. Mgbe a kpọtara ya, Zedekaya jụrụ ya ajụjụ na nzuzo sị ya, “I nwere okwu site nʼaka \nd Onyenwe anyị\nd*?” 
\p Jeremaya zara sị ya, “E, lee, a ga-arara gị nyefee gị nʼaka eze Babilọn.” 
\p  
\v 18 Mgbe ahụ, Jeremaya gwara Zedekaya, bụ eze okwu ọzọ sị ya, “Ihe ọjọọ dị aṅaa ka m mere megide gị, maọbụ megide ndị ọrụ gị, maọbụ megide ndị a, unu ji tinye m nʼụlọ mkpọrọ?  
\v 19 Ebee ka ndị amụma unu nọ, bụ ndị ahụ na-eburu unu amụma na-asị unu, ‘Eze Babilọn agaghị ebuso unu agha, ọ gaghị ebusokwa ala a agha?’  
\v 20 Ugbu a, biko, onyenwe m eze, biko gee m ntị. Biko, nụrụ arịrịọ m: Ezighachila m nʼụlọ Jonatan, ode akwụkwọ, nʼihi na ọ bụrụ na i mee otu a, aga m anwụ nʼebe ahụ.” 
\p  
\v 21 Zedekaya bụ eze, nyere iwu ka e debe Jeremaya nʼogige ndị nche. O nyekwara iwu ka a na-enye ya achịcha e si nʼụlọ ndị na-eme achịcha na-ewebata ụbọchị niile, tutu ruo mgbe achịcha e nwere nʼobodo ahụ gwụsịrị. Ya mere, o mere ka Jeremaya nọgide nʼogige ndị nche. 
\c 38  
\s1 Jeremaya nʼime olulu mmiri 
\p  
\v 1 Shefataya nwa Matan, na Gedaliya nwa Pashua, na Jehukal\f + \fr 38:1 \ft Maọbụ, \fqa Jukal\f* nwa Shelemaya, na Pashua, nwa Malkija, nụrụ mgbe Jeremaya nọ na-agwa ndị mmadụ okwu ndị a sị ha,  
\v 2 “Ihe ndị a ka \nd Onyenwe anyị\nd* kwuru, ‘Onye ọbụla nọgidere nʼime obodo a ga-anwụ site na mma agha, maọbụ site nʼụnwụ, maọbụ site nʼọrịa na-efe efe. Ma onye ọbụla pụkwuru ndị Babilọn ga-adị ndụ. Ọ ga-adị ndụ, nʼihi na ọ ga-echebe ndụ ya.’  
\v 3 Ihe ndị a kwa ka \nd Onyenwe anyị\nd* kwuru, ‘A ga-arara obodo a nyefee ya nʼaka ndị agha eze Babilọn, onye ga-adọta ya nʼagha.’ ” 
\p  
\v 4 Mgbe ahụ, ndịisi ọchịchị sịrị eze, “O kwesiri ka e gbuo nwoke a, nʼihi na ọ na-eme ka obi ndị agha na obi ndị mmadụ fọdụrụ nʼime obodo a na-ada mba site nʼụdị okwu ọ na-agwa ha. Ọ bụghị ọdịmma ndị a ka ọ na-eche echiche ya, kama ọ bụ otu ha ga-esi laa nʼiyi.” 
\p  
\v 5 Zedekaya bụ eze zara sị ha, “Ọ dị unu nʼaka. Unu maara na o nweghị ihe ọbụla eze nwere ike ime igbochi unu ime ihe unu chọrọ.” 
\p  
\v 6 Ya mere, ha jidere Jeremaya, tinye ya nʼime olulu mmiri Malkija, nwa eze. Olulu mmiri a dị nʼogige ụlọ ndị nche. Ọ bụ ụdọ ka ha ji wetuo Jeremaya nʼime olulu mmiri ahụ. Ma mmiri adịghị nʼime ya, naanị apịtị. Ya mere, Jeremaya danyere nʼime apịtị ahụ, mibanye nʼime ya. 
\p  
\v 7 Ma Ebed-Melek, onye Kush, otu nʼime ndịisi ozi nʼụlọeze nụrụ na etinyela Jeremaya nʼime olulu mmiri. Mgbe eze nọdụrụ nʼọnụ ụzọ ama Benjamin,  
\v 8 Ebed-Melek si nʼụlọeze pụọ jekwuuru ya nʼebe ahụ sị ya,  
\v 9 “Onyenwe m eze, lee na mmeso ndị a mesoro Jeremaya onye amụma jọgburu onwe ya. Ha atụbala ya nʼime olulu mmiri hapụ ya ka ọ nọdụ nʼebe ahụ nwụọ nʼihi agụụ mgbe achịcha kọrọ nʼobodo.” 
\p  
\v 10 Mgbe ahụ, eze nyere Ebed-Melek onye Kush iwu sị ya, “Sị nʼebe a kpọrọ iri mmadụ atọ ka gị na ha soro gaa dọpụta Jeremaya onye amụma site nʼolulu ahụ tupu ọ nwụọ.” 
\p  
\v 11 Ya mere, Ebed-Melek duuru ndị ahụ pụọ. O buru ụzọ jee nʼọnụụlọ dị nʼokpuru ụlọakụ nke ụlọeze. Nʼebe ahụ, ọ chịpụtara ụfọdụ nkịrịnka akwa, na ụfọdụ uwe kara nka. O kenyere ha nʼụdọ, wetuore ya Jeremaya nʼime olulu mmiri ahụ.  
\v 12 Ebed-Melek onye Kush ahụ gwara Jeremaya okwu sị ya, “Were nkịrịnka akwa ndị a, na uwe ndị a kara aka fanye ha na mkpa abụ gị, ime ka ụdọ a ghara imerụ gị ahụ.” Jeremaya mere dị ka a gwara ya.  
\v 13 Emesịa, ha dọlịtere ya elu, dọpụta ya site nʼolulu mmiri ahụ. Site nʼoge ahụ, Jeremaya nọgidere nʼogige ụlọ ndị nche. 
\s1 Zedekaya ajụọ Jeremaya ajụjụ ọzọ 
\p  
\v 14 Mgbe ahụ, Zedekaya bụ eze, ziri ozi ka a kpọta Jeremaya onye amụma, ka ọ bịakwute ya nʼọnụ ụzọ nke atọ, nke ụlọnsọ \nd Onyenwe anyị\nd*. Mgbe ọ bịara, eze gwara ya okwu sị ya, “Achọrọ m ịjụ gị ajụjụ. Ezonarịla m ihe ọbụla.” 
\p  
\v 15 Ma Jeremaya zara Zedekaya sị ya, “Ọ bụrụ na m enye gị ọsịsa, ị gaghị egbu m? A sịkwa na m adụọ gị ọdụ, ị gaghị ege m ntị.” 
\p  
\v 16 Ma Zedekaya bụ eze ṅụrụ iyi na nzuzo nye Jeremaya sị ya, “Dịka \nd Onyenwe anyị\nd* onye nyere anyị ume anyị na-eku si adị ndụ, agaghị m egbu gị, maọbụ nyefee gị nʼaka ndị na-achọsi ndụ gị ike.” 
\p  
\v 17 Mgbe ahụ, Jeremaya zara Zedekaya sị ya, “Ihe ndị a ka \nd Onyenwe anyị\nd* Chineke Onye pụrụ ime ihe niile, bụ Chineke Izrel kwuru, ‘Ọ bụrụ na ị pụkwuru ndịisi eze Babilọn nyefee onwe gị nʼaka ha, ha ga-echebe gị ndụ, ha agakwaghị akpọ obodo a ọkụ. Gị na ezinaụlọ gị ga-adịkwa ndụ.  
\v 18 Ma ọ bụrụ na ị jụ iwere onwe gị nyefee nʼaka ndịisi eze Babilọn, a ga-enyefe obodo a nʼaka ndị Babilọn. Ha ga-akpọkwa ya ọkụ, ma gị onwe gị agakwaghị agbapụ site nʼaka ha.’ ” 
\p  
\v 19 Eze Zedekaya sịrị Jeremaya, “Mụ onwe m na-atụ egwu ndị Juu ahụ bụ ndị gbakwuru ndị Babilọn, nʼihi na ndị Babilọn nwere ike nyefee m nʼaka ha, ha ga-emesikwa m ike.” 
\p  
\v 20 “Ha agaghị enyefe gị nʼaka ha,” ka Jeremaya zara ya. “Rubere \nd Onyenwe anyị\nd* isi, site nʼime ihe m gwara gị. Mgbe ahụ, ihe niile ga-agara gị nke ọma. A ga-echebekwa ndụ gị.  
\v 21 Ma ọ bụrụ na ị jụ iwere onwe gị nye, lee ihe \nd Onyenwe anyị\nd* mere ka m hụ:  
\v 22 A ga-akpụta ndị inyom niile fọdụrụ nʼụlọeze Juda mee ka ha pukwuru ndịisi eze Babilọn. Ndị inyom ndị a ga-asị gị, 
\q1 “ ‘Ndị enyi gị ahụ niile ị na-atụkwasị obi arafuola gị, 
\q2 mee ka ị bụrụ onye e meriri emeri. 
\q1 Ụkwụ gị abụọ emikpuola nʼime apịtị, 
\q2 ugbu a, ndị enyi gị niile ahụ agbanarịla gị.’ 
\p  
\v 23 “A ga-akpụpụtara ndị Babilọn ndị nwunye gị niile na ụmụ gị niile. Gị onwe gị agaghị agbanarị ha, ma eze Babilọn ga-ejidekwa gị, a ga-esurekwa obodo a ọkụ.” 
\p  
\v 24 Mgbe ahụ, Zedekaya gwara Jeremaya, “Ekwela ka ntị ọzọ nụ ihe ndị a niile mụ na gị kwuru, ma ọ bụghị ya, ị ga-anwụ.  
\v 25 Ọ bụrụ na ndịisi ọchịchị anụ na mụ na gị kparịtara ụka, ha bịakwute gị, sị gị, ‘Gwa anyị ihe ị gwara eze na ihe eze gwara gị, ezola ihe ọbụla nʼebe anyị nọ, ma ọ bụghị ya anyị ga-egbu gị,’  
\v 26 mgbe ahụ ị ga-agwa ha, ‘Anọ m na-arịọ eze arịrịọ ka ọ hapụ izighachi m nʼụlọ Jonatan, ka m nwụọ nʼebe ahụ.’ ” 
\p  
\v 27 Ndịisi ọchịchị ahụ niile bịakwutere Jeremaya jụọ ya ajụjụ. Ọ gwakwara ha ihe ahụ niile eze nyere ya nʼiwu. Ha hapụrụ ịjụ ya ihe ọzọ, nʼihi o nwekwaghị onye ọzọ nụrụ okwu niile ya na eze kwuru. 
\p  
\v 28 Jeremaya nọgidekwara nʼogige ndị nche tutu ruo ụbọchị ahụ a dọtara Jerusalem nʼagha. 
\s1 Ọdịda Jerusalem 
\p Otu a ka esi were Jerusalem. 
\c 39  
\nb  
\v 1 Otu a ka e si dọta Jerusalem nʼagha. Nʼafọ nke itoolu, nke ọchịchị Zedekaya eze Juda, nʼọnwa nke iri ya, Nebukadneza eze Babilọn duuru ndị agha ya niile bịa ibuso Jerusalem agha, Ha gbara ya gburugburu, nọchibido ya.  
\v 2 Nʼụbọchị nke itoolu, nʼọnwa nke anọ, nʼafọ nke iri na otu nke ọchịchị Zedekaya, ha gwupuru mgbidi obodo ahụ.  
\v 3 Mgbe ahụ, ndịisi niile nke eze Babilọn batara were ọnọdụ ha nʼọnụ ụzọ ama nke Etiti. Ndị a bụ ndị batara: Negal-Shareza onye Samga, na Nebo-Sasekim, onyeisi nʼetiti ndịisi, na Negal-Shareza onyeisi nke ọkwa ya dị elu, na ndịisi niile ọzọ nke eze Babilọn ndị fọdụrụ.  
\v 4 Mgbe Zedekaya eze Juda na ndị agha ya niile hụrụ ha, ha gbapụrụ ọsọ. Ha ji abalị gbapụ nʼobodo ahụ site nʼọnụ ụzọ ama nke dị nʼetiti mgbidi abụọ nʼakụkụ ubi eze a gbara ogige, chee ihu nʼụzọ Araba.\f + \fr 39:4 \ft Ya bụ ndagwurugwu Jọdan\f* 
\p  
\v 5 Ma ndị agha ndị Babilọn chụsoro ha nʼazụ, chụkwute Zedekaya na mbara ala Jeriko. Ha jidere ya, kpụgara ya Nebukadneza eze Babilọn, nʼobodo Ribla, nke dị nʼala Hamat, ebe ọ nọ maa ya ikpe.  
\v 6 Ọ bụ na Ribla, ka eze Babilọn nọ gbuo ụmụ ndị ikom Zedekaya niile nʼihu ya. Ebe ahụ ka a nọkwa gbuo ndị Juda niile a na-asọpụrụ.  
\v 7 Emesịa, ọ ghụpụrụ Zedekaya anya ya abụọ, jiri ụdọ bronz kee ya agbụ kpọrọ ya gaa Babilọn. 
\p  
\v 8 Ndị Babilọn sunyere ụlọeze na ụlọ ndị mmadụ niile ọkụ, kwatukwa mgbidi niile nke Jerusalem.  
\v 9 Nebuzaradan bụ ọchịagha ndị nche eze, buuru ndị niile fọdụrụ nʼobodo, ha na ndị ahụ buuru ụzọ jekwuru ya, na ndị ọzọ fọdụrụ, bulaa ha Babilọn, dịka ndị a dọtara nʼagha.  
\v 10 Ma Nebuzaradan bụ ọchịagha ndị nche eze, hapụrụ ụfọdụ ndị ogbenye, ndị na-enweghị ihe ọbụla nʼala Juda. Nʼoge ahụ, o nyere ha ubi vaịnị a gbara ogige na ala ubi niile. 
\p  
\v 11 Ugbu a, Nebukadneza eze Babilọn enyelarị Nebuzaradan ọchịagha ndị nche eze iwu banyere Jeremaya, sị,  
\v 12 “Kpọrọ ya, lekọtazie ya anya nke ọma; emekwala ya ihe ọjọọ ọbụla, kama meere ya ihe ọbụla ọ rịọrọ gị.”  
\v 13 Ya mere, Nebuzaradan, ọchịagha ndị nche eze, na Nebushazban, onyeisi nʼetiti ndịisi, na Negal-Shareza, bụ onyeisi ọkwa ya dị elu, na ndịisi ndị ọzọ niile nke eze Babilọn,  
\v 14 ziri ndị jere kpọpụta Jeremaya site nʼogige ndị nche. Ha nyefere ya nʼaka Gedaliya nwa Ahikam, nwa Shefan, ka o dulaa ya nʼụlọ ya. Ya mere, Jeremaya nọgidere nʼetiti ndị nke ya. 
\p  
\v 15 Ma nʼoge ahụ, Jeremaya nọ dị ka onye mkpọrọ nʼogige ụlọ ndị nche, okwu \nd Onyenwe anyị\nd* ruru ya ntị sị ya,  
\v 16 “Jekwuru Ebed-Melek onye Kush, gwa ya sị ya, ‘Ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, bụ Chineke Izrel kwuru, Lee, ana m aga ime ka okwu ahụ m kwuru megide obodo a mezuo. Ihe ga-abịakwasị obodo a bụ ịla nʼiyi, ọ bụghị ọganihu. Nʼoge ahụ, ihe ndị a ga-emezukwa nʼihu gị.  
\v 17 Ma aga m anapụta gị nʼụbọchị ahụ, otu a ka \nd Onyenwe anyị\nd* kwubiri. A gaghị enyefe gị nʼaka ndị ahụ ị na-atụ egwu ha.  
\v 18 Aga m azọpụta gị. Ị gakwaghị ada site na mma agha kama ị ga-agbapụkwa na ndụ, nʼihi na ị tụkwasịrị m obi.’ ” Otu a ka \nd Onyenwe anyị\nd* kwubiri ya. 
\c 40  
\s1 Jeremaya enwere onwe ya 
\p  
\v 1 Mgbe oge nta gasịrị site nʼoge Nebuzaradan ọchịagha ndị nche nọ na Rema mere ka Jeremaya nwere onwe ya, okwu \nd Onyenwe anyị\nd* ruru ya ntị. Nebuzaradan hụrụ Jeremaya mgbe e kekọtara ya na ndị e si na Jerusalem na Juda dọta nʼagha agbụ, bụ ndị ahụ a na-ebula Babilọn.  
\v 2 Mgbe ọchịagha ndị nche eze a hụrụ Jeremaya, ọ sịrị ya, “Ọ bụ \nd Onyenwe anyị\nd* Chineke gị nyere iwu na ihe ọjọọ ndị a ga-abịakwasị ala a.  
\v 3 Ugbu a kwa \nd Onyenwe anyị\nd* emeela ka ihe o kwuru mezuo. O wetarala ala a mbibi ahụ. Ma ihe ndị a niile mezuru nʼihi na ndị gị mehiere megide \nd Onyenwe anyị\nd*, jụ irubere ya isi.  
\v 4 Ma taata, ana m eme ka i nwere onwe gị site nʼagbụ nke e kere gị na nkwoji aka. Ọ bụrụ na ị chọọ, soro m gaa Babilọn. Nʼebe ahụ, aga m elezi gị anya nke ọma. Ọ bụrụkwa na i kpebie na ị gaghị eso m gaa Babilọn, abịala. Ma, lee, ala a niile dị gị nʼihu. Jee ka i biri nʼakụkụ ya ọbụla dị gị mma; jegharịakwa nʼebe ọbụla ị chọrọ.”  
\v 5 Ma tupu Jeremaya atụgharịa ịhapụ ya pụọ, Nebuzaradan gwakwara ya ọzọ sị, “Laghachikwuru Gedaliya nwa Ahikam, nwa Shefan, onye eze Babilọn họpụtara ka ọ na-elekọta obodo Juda niile. Gaa soro ya biri nʼetiti ndị gị, maọbụ i nwere ike gaa ebe ọbụla ọzọ dị gị mma.” 
\p Mgbe ahụ, ọchịagha ahụ nyere ya ihe oriri hiri nne. O nyekwara ya onyinye, hapụ ya ka ọ laa.  
\v 6 Ya mere, Jeremaya jekwuuru Gedaliya nwa Ahikam na Mizpa, soro ya na ndị fọdụrụ nʼala ahụ biri. 
\s1 Ogbugbu e gburu Gedaliya nʼike 
\p  
\v 7 Mgbe ndịisi agha ahụ niile na ndị ikom ha, bụ ndị gbalagara nʼọhịa, nụrụ na eze Babilọn emeela Gedaliya nwa Ahikam, onye na-achị ala ahụ, na onye nlekọta ndị ikom na ndị inyom, na ụmụntakịrị, bụ ndị ogbenye ọnụ ntụ, ndị a na-eburughị gaa Babilọn, ka ha gaa biri nʼala ọzọ,  
\v 8 ha bịakwutere Gedaliya na Mizpa. Ndị bịakwutere ya bụ ndị a; Ishmel nwa Netanaya, Johanan na Jonatan ụmụ Kariya, na Seraya nwa Tanhumet, na ụmụ Efai onye Netofa, na Jaazanaya nwa Maaka, na ndị ikom ha.  
\v 9 Gedaliya nwa Ahikam, nwa Shefan, ṅụọrọ ha iyi, ṅụkwaara ndị ikom ha iyi, sị, “Unu atụla egwu ife ndị Babilọn:\f + \fr 40:9 \ft Ya bụ, Kaldịa\f* birinụ nʼala a, feekwa eze Babilọn, ihe ga-agara unu nke ọma.  
\v 10 Mụ onwe m ga-ebi na Mizpa ịnọchite anya unu nʼihu ndị Babilọn ga-abịakwute anyị, ma gaanụ chịkọtaa mkpụrụ vaịnị niile, na mkpụrụ niile e kwesiri ịghọkọta nʼoge okpomọkụ, na mmanụ niile. Chikọtanụ ha tinye ha nʼime ite ichebe nri unu. Birikwanụ nʼobodo ahụ niile unu nwetara.” 
\p  
\v 11 Mgbe ndị Juu niile nọ na Moab, na Amọn, na Edọm, na nʼobodo ndị ọzọ niile nụrụ na eze Babilọn hapụrụ ụfọdụ ka ha biri na Juda, na ọ họpụtara Gedaliya nwa Ahikam, nwa Shefan, mee ya onye na-achị ndị ahụ niile,  
\v 12 ha niile si nʼebe ahụ ha nọ lọghachikwa nʼala Juda. Ha lọkwutere Gedaliya na Mizpa, site na mba ndị ahụ niile a chụgara ha. Ha chịkọtakwara mmanya vaịnị, na mkpụrụ dị ukwuu, bụ mkpụrụ nke na-acha nʼoge okpomọkụ. 
\p  
\v 13 Johanan nwa Kariya, na ndịisi agha niile nọ nʼọhịa bịakwutere Gedaliya na Mizpa  
\v 14 sị ya, “Ọ bụ na i maghị na Baalis eze ndị Amọn ezitela Ishmel nwa Netanaya ka ọ bịa gbuo gị?” Ma Gedaliya nwa Ahikam ekwetaghị na ọ bụ eziokwu ka ha na-ekwu. 
\p  
\v 15 Mgbe ahụ, Johanan nwa Kariya pụrụ na nzuzo jekwuru Gedaliya na Mizpa sị ya, “Biko, kwere ka m gaa gbuo Ishmel nwa Netanaya. O nweghị onye ga-amata otu o si nwụọ. Nʼihi gịnị ka ọ ga-eji gbuo gị, ime ka ndị Juu niile na-alọghachikwute gị gbasasịakwa ọzọ, na imekwa ka ndị Juda fọdụrụ laa nʼiyi?” 
\p  
\v 16 Ma Gedaliya nwa Ahikam zara Johanan nwa Kariya sị ya, “Biko, emela ihe dị otu ahụ! Nʼihi na ihe ị na-ekwu banyere Ishmel abụghị eziokwu.” 
\c 41  
\p  
\v 1 Nʼọnwa nke asaa, Ishmel nwa Netanaya, nwa Elishama, onye si nʼagbụrụ eze, na onye naara abụ otu nʼime ndịisi ozi eze, duuru ndị ikom iri bịa nʼụlọ Gedaliya nwa Ahikam na Mizpa. Mgbe Gedaliya soo ha niile na-eri nri,  
\v 2 Ishmel nwa Netanaya na mmadụ iri ndị ahụ ya na ha so, biliri jiri mma agha tigbuo Gedaliya nwa Ahikam, nwa Shefan, bụ onye eze Babilọn họpụtara dịka onye na-achị ala ahụ niile.  
\v 3 Ishmel gbukwara ndị ikom Juda niile ha na Gedaliya nọ na Mizpa, gbukwaa ndị agha Babilọn nọkwa nʼebe ahụ. 
\p  
\v 4 Nʼụbọchị na-eso ụbọchị ahụ ha gbusịrị Gedaliya, tupu mmadụ ọbụla anụ ihe banyere ya,  
\v 5 o nwere iri mmadụ asatọ, bụ ndị kpụchara afụọnụ ha, dọwasịa uwe ha, gbukasịakwa onwe ha ahụ, sitere nʼobodo Shekem, na Shaịlo na Sameria buuru onyinye ịnata ihuọma, na ihe nsure ọkụ na-esi isi ụtọ na-abịa nʼụlọnsọ \nd Onyenwe anyị\nd*.  
\v 6 Ishmel nwa Netanaya sitere na Mizpa pụọ izute ha, na-akwa akwa mgbe ọ na-aga. Mgbe o zutere ha, ọ sịrị ha, “Bịakwutenụ Gedaliya nwa Ahikam.”  
\v 7 Mgbe ha batara nʼobodo, Ishmel nwa Netanaya na ndị ikom ahụ bụ ndị so ya, gburu ndị ahụ tụnye ozu ha nʼime olulu.  
\v 8 Ma mmadụ iri nʼime ndị ahụ gwara Ishmel okwu sị ya, “Biko, egbula anyị, nʼihi na anyị nwere ọka wiiti na ọka balị, na mmanụ aṅụ anyị zoro nʼime ọhịa.” Nʼihi ya, o gbughị ha, kama ọ hapụrụ ha ndụ.  
\v 9 Olulu ahụ Ishmel tụnyere ozu Gedaliya na ozu ndị ọzọ ahụ niile bụ olulu nke Asa bụ eze gwuru maka ichebe Jerusalem mgbe Baasha eze Izrel na-ebuso ya agha. Ọ bụkwa ozu ndị mmadụ ka Ishmel, nwa Netanaya kpojuru nʼime olulu ahụ. 
\p  
\v 10 Ishmel dọtakwara ndị niile fọdụrụ nʼime Mizpa nʼagha. Ọ dọtara ụmụ ndị inyom eze nʼagha, dọtakwa ndị ahụ niile a hapụrụ nʼebe ahụ, bụ ndị ahụ Nebuzaradan, ọchịagha ndị nche eze mere ka Gedaliya nwa Ahikam bụrụ onye na-achị ha. Ishmel nwa Netanaya dọtara ha niile nʼagha duru ha na-achọ ịgbapụ gaa nʼala ndị Amọn. 
\p  
\v 11 Mgbe Johanan nwa Kariya, na ndịisi agha ahụ niile ya na ha nọ nụrụ ihe ọjọọ Ishmel nwa Netanaya mere,  
\v 12 ha duuru ndị agha ha niile pụọ ibuso Ishmel nwa Netanaya agha. Ha chụkwutere ya nʼebe dị nso nʼiyi ukwu Gibiọn.  
\v 13 Mgbe ndị ahụ niile Ishmel dọtara nʼagha hụrụ Johanan nwa Kariya na ndịisi agha so ya, ha ṅụrịrị ọṅụ.  
\v 14 Ndị ahụ niile Ishmel dọtara nʼagha na Mizpa, chigharịrị gafee nʼebe Johanan nwa Kariya nọ.  
\v 15 Ma Ishmel nwa Netanaya, na mmadụ asatọ nʼime ndị agha ya, gbapụrụ ọsọ gbanarị Johanan. Ha gbalagara nʼala ndị Amọn. 
\s1 Mgbapụ ọsọ gaa Ijipt 
\p  
\v 16 Mgbe ahụ, Johanan nwa Kariya na ndịisi agha niile ya na ha so duuru ndị ahụ niile ha napụtara site nʼaka Ishmel pụọ, bụ ndị ahụ Ishmel nwa Netanaya dọtara nʼagha na Mizpa, mgbe o buuru ụzọ gbuo Gedaliya nwa Ahikam. Ndị ọzọ Johanan si na Gibiọn durukwa bụ ndị a, ndị agha, na ndị inyom, na ụmụntakịrị, na ndịisi ụlọ ikpe.  
\v 17 Ha duuru ha na-aga, ma kwụsị nʼobodo Gerut Kimham, nke dị nso na Betlehem, ebe ha bu nʼobi ịga Ijipt,  
\v 18 nʼihi ịgbanarị ndị Babilọn. Ha tụrụ egwu ihe ndị Babilọn ga-eme ha nʼihi ogbugbu Ishmel nwa Netanaya gburu Gedaliya nwa Ahikam, onye eze Babilọn họpụtara ka ọ bụrụ onye na-achị ala ahụ. 
\c 42  
\p  
\v 1 Mgbe ahụ, Johanan nwa Kariya, na ndịisi agha ahụ niile, na Jezenaya nwa Hoshaya, na ndị Izrel niile, site nʼonye dịkarịsịrị nta ruo nʼonye dịkarịsịrị ukwuu, bịakwutere  
\v 2 Jeremaya onye amụma sị ya, “Biko, anyị bịara ịrịọ gị arịrịọ. Kpọkuo \nd Onyenwe anyị\nd* Chineke gị nʼekpere nʼihi anyị bụ ndị fọdụrụ nʼala a. Ị maara na o nwere oge anyị dị ọtụtụ nʼala a, ma ugbu a anyị dị naanị ole na ole.  
\v 3 Kpee ekpere ka \nd Onyenwe anyị\nd* Chineke gị gosi anyị ihe anyị ga-eme, maọbụ ebe anyị ga-eje.” 
\p  
\v 4 Jeremaya onye amụma zara sị ha, “Anụla m ihe unu kwuru. Aga m ekpere \nd Onyenwe anyị\nd* Chineke unu ekpere dịka unu rịọrọ. Mgbe m natara ọsịsa ya, aga m agwakwa unu ihe niile \nd Onyenwe anyị\nd* kwuru. O nwekwaghị ihe m ga-ezonarị unu.” 
\p  
\v 5 Ha sịrị Jeremaya, “Ka \nd Onyenwe anyị\nd* bụrụ onyeama eziokwu na nke kwesiri ntụkwasị obi megide anyị, ma ọ bụrụ na anyị emeghị dịka ihe niile \nd Onyenwe anyị\nd* bụ Chineke gị gwara gị ka ị gwa anyị.  
\v 6 Ọ bụ ihe Chineke, onye anyị na-eziga gị ka ị jụta ase, kwuru ka anyị ga-eme. Ma ọ dị mma, ma ọ dị njọ. Anyị ga-erubere \nd Onyenwe anyị\nd* Chineke gị isi, ka ihe gaara anyị nke ọma.” 
\p  
\v 7 Mgbe ụbọchị iri gasịrị okwu \nd Onyenwe anyị\nd* ruru Jeremaya ntị.  
\v 8 Nʼihi ya ọ kpọrọ Johanan nwa Kariya, ndịisi agha ya na ha so na ndị Izrel niile, site nʼonye dịkarịsịrị nta ruo nʼonye dịkarịsịrị ukwuu.  
\v 9 Mgbe ha bịara, ọ gwara ha okwu sị ha, “Ihe ndị a ka \nd Onyenwe anyị\nd*, Chineke Izrel, onye unu zigara m ka m wegara arịrịọ unu, sịrị:  
\v 10 ‘Ọ bụrụ na unu anọgide nʼala a, aga m ewuli unu elu; agaghị m akwada unu. Aga m akụkwa unu dịka osisi, gharakwa ihopu unu. Nʼihi na ihe ọjọọ ahụ m mere ka ọ bịakwasị unu na-ewute m nke ukwuu.  
\v 11 Unu atụla eze Babilọn egwu, bụ onye unu na-atụ egwu ya ugbu a. Unu atụla ya egwu, otu a ka \nd Onyenwe anyị\nd* kwubiri, nʼihi na anọnyeere m unu, aga m azọpụta unu, napụtakwa unu site nʼaka ya.  
\v 12 Aga m enwe obi ebere nʼebe unu nọ, si otu a mee ka ya onwe ya nweekwa obi ebere nʼebe unu nọ. Ọ ga-emekwa ka unu nwetaghachikwa ala unu.’ 
\p  
\v 13 “Ma ọ bụrụ na unu onwe unu asị, ‘Anyị agaghị anọgide nʼala a,’ si otu a nupu isi nʼebe \nd Onyenwe anyị\nd* Chineke unu nọ;  
\v 14 ọ bụrụkwa na unu asị, ‘Mba, anyị ga-aga biri nʼala Ijipt ebe anyị na-agaghị ahụ agha, maọbụ nụ ụda opi ike, maọbụ nọọ agụụ nʼihi enweghị ihe oriri,’  
\v 15 mgbe ahụ, nụrụnụ okwu \nd Onyenwe anyị\nd*, unu ndị fọdụrụ na Juda. Ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, bụ Chineke Izrel kwuru, ‘Ọ bụrụ na unu anọgidesie ike na mkpebi unu ịga Ijipt ibiri nʼebe ahụ, ọ bụrụkwa na unu agaa biri nʼIjipt nʼeziokwu,  
\v 16 mgbe ahụ, mma agha ahụ unu na-atụ egwu ga-eru unu nʼahụ, ụnwụ ahụ unu na-atụ oke egwu ya ga-esoro unu baa nʼIjipt. Unu ga-anwụkwa nʼebe ahụ.  
\v 17 Nʼezie, ndị ahụ niile kpebiri ịga biri nʼIjipt ga-anwụ site na mma agha, na site nʼụnwụ, na site nʼọrịa na-efe efe. O nweghị onye ọbụla nʼime ha ga-afọdụ ndụ, o nweghị onye ọbụla nʼime ha ga-agbanarị ihe ọjọọ ahụ m ga-eme ka ọ bịakwasị ha.’  
\v 18 Ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, bụ Chineke Izrel kwuru, ‘Dịka iwe m na ọnụma m bụ ihe awụkwasịrị nʼelu ndị bi na Jerusalem, otu a ka m ga-esi wụkwasịkwa unu ọnụma m, mgbe unu ga-aga Ijipt. Unu ga-aghọ ihe ọbụbụ ọnụ na ihe iju anya, ihe nkọcha na ihe ịta ụta. Unu agakwaghị ahụ ebe a anya ọzọ.’ 
\p  
\v 19 “Unu bụ ndị fọdụrụ na Juda, lee na \nd Onyenwe anyị\nd* agwala unu sị, ‘Unu agala Ijipt.’ Matanụ nke ọma na m adọọla unu aka na ntị,  
\v 20 na unu mehiere nʼobi unu mgbe unu ziri m sị m jụta \nd Onyenwe anyị\nd* Chineke unu ase. Mgbe ahụ, unu rịọrọ m sị m, ‘Rịọrọ anyị \nd Onyenwe anyị\nd* Chineke anyị arịrịọ, gwa anyị ihe niile o kwuru, anyị ga-emekwa ya.’  
\v 21 Agwala m unu taa ihe o kwuru, ma unu ajụla ime ihe ahụ niile \nd Onyenwe anyị\nd* Chineke unu, bụ onye unu zigara m ka m jekwuru, kwuru.  
\v 22 Ya mere, matanụ ya nke ọma taa na unu ga-anwụ site na mma agha, na site nʼụnwụ, na site nʼọrịa na-efe efe, nʼebe ahụ unu chọrọ ịga biri.” 
\c 43  
\p  
\v 1 Mgbe Jeremaya gwasịrị ndị ahụ niile okwu ahụ \nd Onyenwe anyị\nd* Chineke ha ziri ya ka o zie ha,  
\v 2 Azaraya nwa Hoshaya, Johanan nwa Kariya na ndị nganga niile nọ nʼebe ahụ, gwara Jeremaya okwu sị ya, “Ọ bụ okwu ụgha ka i kwuru! \nd Onyenwe anyị\nd* Chineke anyị ezighị gị ka i kwuo na anyị ekwesighị ịga biri nʼIjipt,  
\v 3 Kama ọ bụ Baruk nwa Neraya na-akwalị gị megide anyị, nʼihi na ọ chọrọ inyefe anyị nʼaka ndị Babilọn ka ha gbuo anyị, maọbụ buru anyị gaa Babilọn dịka ndị a dọtara nʼagha.” 
\p  
\v 4 Ya mere, Johanan nwa Kariya na ndịisi agha ahụ niile, nakwa ndị mmadụ ahụ niile nupuru isi nʼiwu \nd Onyenwe anyị\nd*, jụụ ịnọgide nʼala Juda.  
\v 5 Kama Johanan nwa Kariya, na ndịisi agha ahụ, duuru ndị ahụ fọdụrụ na Juda pụọ, ha na ndị ahụ si na mba ndị ọzọ dị iche iche, ebe ha gbagara lọta.  
\v 6 Ha duuru ndị ikom niile na ndị inyom niile na ụmụntakịrị niile, na ụmụ ndị inyom eze niile, bụ ndị ahụ Nebuzaradan ọchịagha ndị nche eze Babilọn tinyere na nlekọta Gedaliya nwa Ahikam, nwa Shefan na Jeremaya onye amụma na Baruk nwa Neraya.  
\v 7 Ya mere, ha nupuru isi nʼebe \nd Onyenwe anyị\nd* nọ site nʼịbanye ala Ijipt. Ha jegidere ije ruo nʼobodo Tapanhis. 
\p  
\v 8 Mgbe ha nọ na Tapanhis, okwu \nd Onyenwe anyị\nd* ruru Jeremaya ntị sị ya,  
\v 9 “Mgbe ndị Juu nọ na-ele gị anya, chịrị ụfọdụ nkume buru ibu nʼaka gị, gaa zoo ha nʼime ụrọ dị na mpụta ihu ụlọ e ji aja ụrọ\f + \fr 43:9 \ft Lit. \fqa Brik\f* wuo, nke dị nʼọnụ ụzọ e si abata nʼụlọ Fero dị na Tapanhis.  
\v 10 Mgbe ahụ sị ha, ‘Ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, bụ Chineke Izrel sịrị, Aga m ezi ozi kpọta ohu m bụ Nebukadneza, eze Babilọn. Aga m edokwasịkwa ocheeze ya nʼelu nkume ndị a m zoro nʼebe a, ọ ga-agbasa ụlọ ndo nke ịbụ eze ya nʼelu ha.  
\v 11 Ọ ga-abịa buso Ijipt agha, si otu a mee ka ha nwụọ, bụ ndị ahụ a kwadobere maka ọnwụ, mee ka a dọta ha nʼagha, bụ ndị ahụ a kwadobere na-aga adọta nʼagha; mekwaa ka ha nwụọ site na mma agha bụ ndị ahụ a kwadobere na ha ga-anwụ site na mma agha.  
\v 12 Ọ ga-esunyekwa ọkụ nʼụlọ ebe a nọ na-efe chi niile nke ndị Ijipt. Ọ ga-esure ụlọ ndị a ọkụ, dọtakwa chi ha niile nʼagha. Dịka onye ọzụzụ atụrụ si ewepụcha igwu site na uwe ya, ọ ga-esikwa otu a wezuga onwe ya nʼudo site nʼIjipt pụọ.  
\v 13 Nʼime ụlọnsọ anyanwụ dị nʼIjipt, ka ọ ga-akwatu ogidi nsọ niile, surekwaa ụlọnsọ niile nke chi dị iche iche nʼIjipt ọkụ.’ ” 
\c 44  
\s1 Mbibi na-abịa nʼihi ikpere arụsị 
\p  
\v 1 Ndị a bụ okwu ruru Jeremaya ntị banyere ndị Juu ahụ niile bi nʼala Ijipt, bụ ndị bi na Migdol, na nʼime Tapanhis, na nʼime Memfis, na nʼime Patros,  
\v 2 “Ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, bụ Chineke Izrel kwuru, Unu ji anya unu hụ ihe ọjọọ ahụ niile m mere ka ha bịakwasị Jerusalem, na obodo niile nke Juda. Lee, obodo ndị ahụ aghọọla mkpọmkpọ ebe taa, o nwekwaghị onye bi nʼime ha.  
\v 3 Ihe ndị a bịakwasịrị ha nʼihi ihe ọjọọ ha mere. Ha kpasuru m iwe site nʼịchụ aja ihe nsure ọkụ na-esi isi ụtọ, na site nʼife chi ndị ọzọ, ndị ha onwe ha maọbụ nna nna ha na-amaghị.  
\v 4 Site nʼoge ruo nʼoge, mgbe mgbe, eziteere m ha ndị ohu m, bụ ndị amụma, ndị gwara ha okwu sị ha, ‘Unu emela ihe arụ dị otu a nke m kpọrọ asị!’  
\v 5 Ma ha egeghị ntị, ha atọkwaghị ntị ha nʼala. Ha esiteghị nʼihe ọjọọ ha na-eme chegharịa, maọbụ kwụsị ịchụ aja ihe nsure ọkụ na-esi isi ụtọ nye chi ndị ọzọ.  
\v 6 Nʼihi ya, awụkwasịrị m ha ọnụma m na iwe m, nke rere dịka ọkụ megide obodo niile nke Juda, na okporoụzọ nke Jerusalem. Ya mere, ha ghọrọ mkpọmkpọ ebe na ebe tọgbọrọ nʼefu taa. 
\p  
\v 7 “Ma ugbu a, ihe ndị a ka \nd Onyenwe anyị\nd* Chineke Onye pụrụ ime ihe niile, bụ Chineke Izrel kwuru, Nʼihi gịnị ka unu ji chọọ iji aka unu wetara onwe unu ihe ọjọọ ndị a? Lee ka unu si duru ndị ikom na ndị inyom niile, na ụmụntakịrị niile, na ụmụ a mụrụ ọhụrụ niile na-agbala nʼala Ijipt, si otu a mee ka, ọ bụladị, otu mkpụrụ mmadụ hapụ ịfọdụkwa nʼala Juda.  
\v 8 Gịnị mere unu na-eji ọrụ aka unu na-akpasu m iwe, na-esurere chi ndị ọzọ ihe nsure ọkụ na-esi isi ụtọ nʼala Ijipt, ebe unu bịara ibi? Unu onwe unu ga-ala onwe unu nʼiyi, mekwaa onwe unu ihe ịbụ ọnụ nakwa ihe nkọcha nʼetiti mba niile dị nʼụwa.  
\v 9 Unu echefuola ihe ọjọọ nna unu ha mere na ihe ọjọọ niile ndị eze Juda na ndị eze nwanyị Juda mere na ihe ọjọọ niile nke unu onwe unu na ndị nwunye unu mekwara nʼala Juda, na nʼokporoụzọ Jerusalem?  
\v 10 Ruo ụbọchị taa, o nwebeghị onye ọbụla nʼime ha wedarala onwe ya ala, maọbụ tụọ egwu m; ha adịghị ejegharị nʼiwu m, maọbụ jidesie ụkpụrụ ndị ahụ niile m debere nʼihu ha na nʼihu nna nna ha aka ike, ịgbaso ya. 
\p  
\v 11 “Nʼihi ihe ndị a niile, otu a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, bụ Chineke Izrel kwuru: Ekpebiela m ime ka ihe ọjọọ bịakwasị unu; ekpebiela m ibibi Juda.  
\v 12 Aga m eme ka ndị ahụ niile fọdụrụ nʼala Juda, bụ ndị ahụ kpebiri nʼobi ha ịga biri nʼala Ijipt ghara ịdịkwa. A ga-ala ha nʼiyi nʼala Ijipt; ha ga-ada site na mma agha, maọbụ site nʼụnwụ. Ndị niile dịkarịsịrị ukwuu nʼetiti ha na ndị niile dịkarịsịrị nta ga-anwụ. Ha ga-aghọkwa ihe ịbụ ọnụ na ihe iju anya, ihe ọmụma ikpe na ihe nkọcha.  
\v 13 Dịka m si taa Jerusalem ahụhụ, otu a ka m ga-esi jiri mma agha, na ụnwụ, na ọrịa na-efe efe, taa ndị ahụ bi nʼIjipt ahụhụ.  
\v 14 O nweghị onye ọbụla nʼime ndị Juda ahụ fọdụrụ, ndị gara biri nʼIjipt nke ga-agbanarị ọnwụ. Ọ bụ ezie na ọ na-agụsị ha agụụ ike ịlọghachi nʼala Juda, ma o nweghị onye ọbụla nʼime ha ga-alọghachi, karịakwa mmadụ ole na ole ndị ga-agbapụ agbapụ.” 
\p  
\v 15 Ndị nọ nʼebe ahụ mgbe ahụ Jeremaya kwuru okwu ndị a bụ ndị ikom ahụ niile maara na ndị nwunye ha na-achụ aja ihe nsure ọkụ na-esi isi ụtọ nye chi ndị ọzọ, na ndị niile bi nʼIjipt nʼakụkụ Patros. Ndị a zara Jeremaya sị ya,  
\v 16 “Anyị agaghị anabata okwu ahụ i si nʼaha \nd Onyenwe anyị\nd* gwa anyị  
\v 17 Nʼihi na anyị aghaghị ime ihe ndị ahụ anyị kpebiri ime. Anyị ga-achụrụ Eze nwanyị mbara Eluigwe aja ihe nsure ọkụ na-esi isi ụtọ. Anyị ga-awụsakwara ya aja ihe ọṅụṅụ dịka anyị na nna anyị ha, ndị eze anyị na ndịisi ọchịchị anyị mere nʼobodo Juda niile na nʼokporoụzọ Jerusalem. Nʼoge ahụ, anyị na-eriju afọ, ihe na-agakwara anyị nke ọma, o nweghị ihe ọjọọ bịakwasịrị anyị.  
\v 18 Ma site nʼoge anyị kwụsịrị ịchụrụ Eze nwanyị mbara Eluigwe aja, ihe nsure ọkụ na-esi isi ụtọ na ịwụsara ya aja ihe ọṅụṅụ, ihe niile akọla anyị, ọ bụkwa site na mma agha na oke ụnwụ ka anyị na-ala nʼiyi.” 
\p  
\v 19 Ndị inyom ahụ niile kwukwara sị, “Mgbe ahụ anyị na-eji ihe nsure ọkụ na-esi isi ụtọ na-achụrụ Eze nwanyị mbara Eluigwe aja na mgbe ahụ anyị na-awụsakwara ya aja ihe ọṅụṅụ, ọ bụ na ndị di na-alụ anyị amaghị na anyị na-eme achịcha nʼoyiyi ya, na-awụsakwara ya aja ihe ọṅụṅụ?” 
\p  
\v 20 Mgbe ahụ, Jeremaya gwara mmadụ ahụ niile okwu, ma ndị ikom ma ndị inyom ahụ niile zara ya okwu sị ha,  
\v 21 “\nd Onyenwe anyị\nd* chetara ihe nsure ọkụ na-esi isi ụtọ niile unu na nna unu ha, na ndị eze unu, na ndịisi ọchịchị unu, na ndị Izrel niile ji chụọ aja nʼobodo Juda niile na nʼokporoụzọ Jerusalem niile.  
\v 22 Nʼihi ya, mgbe \nd Onyenwe anyị\nd* na-enweghịkwa ike ịnagide ihe ọjọọ niile ndị a unu mere, na ihe arụ niile unu mere, o mere ka ala unu ghọọ mkpọmkpọ ebe, na ihe iju anya, na ihe nkọcha, nke mmadụ na-ebighị nʼime ya, dịka ọ dị taa.  
\v 23 Nʼihi na unu surere ihe nsure ọkụ na-esi isi ụtọ na nʼihi na unu mehiere megide \nd Onyenwe anyị\nd*, ghara irubere ya isi, maọbụ ịgbaso iwu ya, maọbụ idebe ụkpụrụ ya, maọbụ imezu ihe niile ọ sịrị ka unu mee, nʼihi ya ka ihe ọjọọ ndị a ji dakwasị unu dịka unu na-ahụ ugbu a.” 
\p  
\v 24 Mgbe ahụ, Jeremaya gwara ndị inyom ahụ, na ndị Izrel niile okwu sị ha, “Nụrụnụ okwu \nd Onyenwe anyị\nd* unu ndị Juda niile nọ nʼIjipt.  
\v 25 Ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, bụ Chineke Izrel kwuru, Unu na ndị nwunye unu esitela nʼomume unu gosi na unu na-emezu ihe ndị ahụ unu ji ọnụ kwuo sị, ‘Anyị aghaghị imezu nkwa niile anyị kwere banyere ịchụ aja ihe nsure ọkụ na-esi isi ụtọ na nke ihe ọṅụṅụ nye Eze nwanyị mbara Eluigwe.’ 
\p “Gaanụ nʼihu mezuo nkwa unu kwere! Mezuokwanụ iyi unu ṅụrụ.  
\v 26 Ma nụrụkwanụ okwu \nd Onyenwe anyị\nd*, unu ndị Juu niile bi nʼIjipt, ‘Eji m aha m dị ukwuu na-aṅụ iyi,’ ka \nd Onyenwe anyị\nd* na-ekwu, ‘na o nweghị onye Juda ọbụla bi nʼakụkụ ọbụla nke Ijipt, nke ga-akpọkukwa aha m ọzọ, maọbụ jiri ya ṅụọ iyi sị, “Dịka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* na-adị ndụ.”  
\v 27 Nʼihi na anya m na-ele ha abụghị maka ime ha mma, kama ọ bụ maka ime ha ihe ọjọọ. Ndị Juu niile bi nʼIjipt ga-anwụ site na mma agha, maọbụ site nʼoke ụnwụ, tutu ruo mgbe e bibichara ha dum.  
\v 28 Naanị mmadụ ole na ole ga-esi Ijipt gbalata Juda ịgbanarị mma agha. Mgbe ahụ ndị Juda niile fọdụrụ, bụ ndị bịara biri nʼIjipt, ga-amata onye okwu ya na-eguzosi ike, maọbụ nke m, maọbụ nke ha. 
\p  
\v 29 “ ‘Nke a ga-abụrụ unu ihe ama nke ga-egosi unu na m ga-ata unu ahụhụ nʼebe a,’ otu a ka \nd Onyenwe anyị\nd* kwupụtara. ‘Ka unu si otu a mara na mba m na-aba na m ga-emesi unu ike aghaghị iguzosi ike.’  
\v 30 Ihe a ka \nd Onyenwe anyị\nd* kwuru, ‘Aga m arara Fero Hofra, eze Ijipt nyefee nʼaka ndị iro ya, bụ ndị na-achọ ndụ ya, dịka m si rara Zedekaya eze Juda, nyefee nʼaka Nebukadneza eze Babilọn, bụ onye iro ahụ chọrọ ndụ ya.’ ” 
\c 45  
\s1 Ozi e ziri Baruk 
\p  
\v 1 Okwu ndị Jeremaya onye amụma gwara Baruk nwa Neraya, mgbe o dere okwu ndị a nʼakwụkwọ dịka Jeremaya na-akpọpụta ha, nʼafọ nke anọ nke ọchịchị Jehoiakim nwa Josaya eze Juda. Jeremaya gwara Baruk sị,  
\v 2 “Ihe ndị a ka \nd Onyenwe anyị\nd* bụ Chineke Izrel na-agwa gị, gị Baruk,  
\v 3 Ị sịrị, ‘Ahụhụ dịịrị m! Lee na \nd Onyenwe anyị\nd* atụkwasịrịla m mwute nʼelu ihe mgbu nke m nwere. Ike ịsụ ude agwụla m, ma ruo ugbu a, achọtabeghị m izuike.’  
\v 4 Ma ihe ndị a ka ị ga-agwa ya, ‘Otu a ka \nd Onyenwe anyị\nd* kwuru, Aga m akwada ihe ndị ahụ niile m wuru, hopukwa ihe ndị ahụ niile m kụrụ nʼala\f + \fr 45:4 \ft Maọbụ, \fqa nʼụwa\f* a niile.  
\v 5 Ma gị onwe gị, ị na-achọrọ onwe gị ihe ukwu? Achọkwala ha. Nʼihi na, lee, aga m eme ka ihe ọjọọ bịakwasị mmadụ niile, otu a ka \nd Onyenwe anyị\nd* kwubiri, ma aga m eme ka ị jiri ndụ gị gbapụ jee ebe ọbụla ị ga-eje.\f + \fr 45:5 \ft Ị ga-agbapụ na ndụ ga nʼebe ọbụla ị ga-agbaga\f*’ ” 
\c 46  
\s1 Ozi e ziri banyere Ijipt 
\p  
\v 1 Ndị a bụ okwu \nd Onyenwe anyị\nd*, nke ruru Jeremaya onye amụma ntị, banyere mba dị iche iche. 
\b  
\p  
\v 2 Nke dịrị Ijipt: 
\b  
\p Ndị a bụ okwu dị megide usuu ndị agha Fero Neko, bụ eze Ijipt, ndị Nebukadneza eze Babilọn meriri nʼagha na Kakemish, nʼakụkụ osimiri Yufretis, nʼafọ nke anọ nke ọchịchị Jehoiakim nwa Josaya, bụ eze Juda. 
\q1  
\v 3 “Kwadoonụ ọta agha unu, ndị ukwu na ndị nta, 
\q2 zọpụnụ ije maka ibu agha. 
\q1  
\v 4 Kegidezienụ ịnyịnya unu, 
\q2 rịkwasịkwanụ nʼelu ha. 
\q1 Guzokwanụ nʼọnọdụ ibu agha unu, 
\q2 ma kpukwasịkwanụ onwe unu okpu agha unu. 
\q1 Mụọnụ ùbe unu ka ọ dị nkọ, 
\q2 yikwasịkwanụ uwe agha unu. 
\q1  
\v 5 Gịnị ka anya m abụọ hụrụ? 
\q2 Ụjọ na-atụ ha, 
\q1 ha na-agbaghachikwa azụ; 
\q2 lee, a na-etipịa ndị ha bụ dike nʼagha. 
\q1 Ha na-agbasi ọsọ ike, 
\q2 na-eleghị anya nʼazụ. 
\q2 Egwu dịkwa nʼakụkụ niile,” otu a ka \nd Onyenwe anyị\nd* kwupụtara. 
\q1  
\v 6 “Ndị nwere ụkwụ ọsọ enweghị ike ịgbalaga, 
\q2 ndị dị ike enweghị ike isi nʼebe ahụ wezuga onwe ha. 
\q1 Ha na-asọ ngọngọ daa, 
\q2 nʼakụkụ ugwu dị nso nʼosimiri Yufretis. 
\b  
\q1  
\v 7 “Onye bụ onye a, nke na-ebili\f + \fr 46:7 \ft Maọbụ, \fqa na-eruju\f* ọtọ dịka osimiri Naịl, 
\q2 na dịka osimiri nke mmiri ya na-amagharị? 
\q1  
\v 8 Ijipt na-ebili elu dịka osimiri Naịl, 
\q2 dịka osimiri nke mmiri ya na-amagharị. 
\q1 Ọ na-asị, ‘Aga m ebili kpuchie ụwa niile. 
\q2 Aga m ebibi obodo ukwu dị iche iche, na ndị mmadụ bi nʼime ha.’ 
\q1  
\v 9 Gbabanyenụ nʼọgbọ agha, unu ịnyịnya niile. 
\q2 Gbanụ ọkụ ọkụ, unu ndị na-agba ụgbọ agha. 
\q1 Zọọnụ ike ike, unu ndị bụ dike nʼagha, unu ndị ikom Kush na Put, ndị na-ebu ọta, 
\q2 na unu ndị ikom Lidiya ndị na-agba ụta. 
\q1  
\v 10 Ma ụbọchị ahụ dịrị Onyenwe anyị, bụ \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile. 
\q2 Ọ bụ ụbọchị ịbọ ọbọ ya, ụbọchị ọ ga-abọrọ ọbọ nʼahụ ndị iro ya. 
\q1 Mma agha ga-eripịa ha tutu afọ eju ya, 
\q2 e, tutu ruo mgbe ọ ṅụjuru ọbara afọ. 
\q1 Nʼihi na Onyenwe anyị bụ \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile ga-achụ aja nʼala ahụ dị nʼugwu, 
\q2 nke dị nso osimiri Yufretis. 
\b  
\q1  
\v 11 “Rigoro Gilead ka i weta mmanụ a na-ete nʼọnya, 
\q2 gị Ada Ijipt na-amaghị nwoke. 
\q1 Ma ọ bụ nʼefu ka ị na-ewebata ọgwụ ndị a niile, 
\q2 nʼihi na ọgwụgwọ ọbụla agaghị adịrị gị. 
\q1  
\v 12 Mba niile ga-anụ akụkọ ihe ihere bịakwasịrị gị. 
\q2 Nʼakụkụ niile nke ụwa ka a ga-anụkwa ịkwa akwa gị. 
\q1 Otu dike nʼagha na-asọ ngọngọ na-adakwasị dike ibe ya; 
\q2 ha abụọ na-adakwa nʼala.” 
\p  
\v 13 Okwu ndị a ka \nd Onyenwe anyị\nd* gwara Jeremaya onye amụma, banyere ọbịbịa nke Nebukadneza, bụ eze Babilọn, onye na-abịa ibuso Ijipt agha. 
\q1  
\v 14 “Kwupụtanụ ihe ndị a nʼIjipt. Kwusaa ya na Migdol. 
\q2 Kwusaakwa ya na Memfis, na nʼobodo Tapanhis. 
\q1 Guzozienụ onwe unu nʼusoro, nọọkwanụ na njikere, 
\q2 nʼihi na mma agha na-eripịa ndị gbara unu gburugburu. 
\q1  
\v 15 Gịnị mere a ga-eji gbudasịa ndị gị niile bụ dike nʼagha? 
\q2 Ha agaghị enwe ike guzokwa, nʼihi na \nd Onyenwe anyị\nd* ga-akwada ha. 
\q1  
\v 16 Ha ga-asọ ngọngọ mgbe mgbe, 
\q2 ha ga-adakwasịkwa nʼelu ibe ha. 
\q1 Ha ga-asịkwa, ‘Bilienụ ọtọ, bịanụ ka anyị laghachikwuru ndị anyị, 
\q2 ka anyị laghachikwa nʼala ebe a mụrụ anyị, 
\q2 ka anyị wezugakwa onwe anyị site na mma agha nke ndị mmegbu.’ 
\q1  
\v 17 Nʼebe ahụ ka ha ga-anọ tie mkpu sị, 
\q2 ‘Fero eze Ijipt bụ naanị onye oke okwu. 
\q2 Lee, oge a kara aka nye ya efunarịla ya.’ 
\b  
\q1  
\v 18 “Dịka mụ onwe m na-adị ndụ,” ka Eze ahụ kwupụtara, 
\q2 onye aha ya bụ \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, 
\q1 “otu onye ga-abịa, onye dị ukwuu dịka ugwu Taboa si dị ukwuu nʼebe ugwu ndị ọzọ dị, 
\q2 na dịka Kamel si dịrị nʼakụkụ osimiri. 
\q1  
\v 19 Kwakọtaanụ ngwongwo unu, jikerenụ maka ije biri nʼala ọzọ, 
\q2 unu ndị bi nʼIjipt, 
\q1 nʼihi na a ga-eme ka Memfis ghọọ ebe tọgbọrọ nʼefu. 
\q2 Ọ ga-aghọkwa mkpọmkpọ ebe, nke mmadụ na-agaghị ebi nʼime ya. 
\b  
\q1  
\v 20 “Ijipt mara mma dịka nne ehi, 
\q2 ma ijiji\f + \fr 46:20 \ft Odudo na ijiji bụ ihe na-ata anụmanụ\f* nke si nʼakụkụ ugwu, 
\q2 na-abịa imegide ya. 
\q1  
\v 21 Ndị agha e goro ego nọ nʼetiti ha 
\q2 dịka ụmụ ehi gbara abụba. 
\q1 Ha onwe ha kwa ga-atụgharịa gbaa ọsọ, 
\q2 ha agaghị eguzo, 
\q1 nʼihi na ụbọchị nhụju anya na-abịakwasị ha, 
\q2 bụ ụbọchị a ga-ata ha ahụhụ. 
\q1  
\v 22 Ijipt ga-eme mkpọtụ, dịka mkpọtụ nke agwọ na-agba ọsọ na-eme, 
\q2 mgbe ndị iro ya ji ike na-abịakwasị ya. 
\q1 Ha ga-eji anyụike bịakwasị ya, 
\q2 dịka ndị na-egbutu osisi. 
\q1  
\v 23 Ha ga-egbutu oke ọhịa ya,” otu a ka \nd Onyenwe anyị\nd* kwubiri, 
\q2 “nʼagbanyeghị na ọ bụ oke ọhịa rubigara oke. 
\q1 Ha dị ọtụtụ karịa igurube, 
\q2 a pụghịkwa ịgụta ole ha dị. 
\q1  
\v 24 A ga-eme ka ihere mee Ada Ijipt, 
\q2 mgbe e nyefere ya nʼaka ndị si nʼakụkụ ugwu bịa.” 
\p  
\v 25 \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, bụ Chineke Izrel, sịrị, “Ana m aga ime ka ahụhụ bịakwasị Amọn, bụ chi ndị Tibs, na Fero, na ala Ijipt na chi niile dị nʼime ya, ndị eze ya niile nakwa ndị ahụ na-atụkwasị Fero obi.  
\v 26 Aga m enyefe ha nʼaka ndị ahụ na-achọsi ndụ ha ike, bụ Nebukadneza eze Babilọn, na ndịisi ọchịchị ya. Ma nʼikpeazụ, aga m emekwa ka ndị mmadụ birikwa nʼime ya ọzọ, dịka e si biri nʼime ya na mgbe ochie.” Otu a ka \nd Onyenwe anyị\nd* kwubiri ya. 
\q1  
\v 27 “Atụla egwu, gị Jekọb, ohu m. 
\q2 Adakwala mba, gị Izrel. 
\q1 Nʼihi na lee, aghaghị m ịzọpụta gị site nʼebe dị anya nke e mere ka ị gaa biri. 
\q2 Aga m azọpụtakwa ụmụ ụmụ gị site nʼala ebe e mere ka ha gbapụ ọsọ gaa biri. 
\q1 Jekọb ga-emesịakwa biri nʼudo, na-atụghị egwu ọbụla. 
\q2 Ọ dịkwaghị onye ga-eme ka ọ tụọ ụjọ. 
\q1  
\v 28 Atụla egwu, gị Jekọb, ohu m, 
\q2 nʼihi na anọnyeere m gị,” 
\q2 otu a ka \nd Onyenwe anyị\nd* kwubiri ya. 
\q1 “A sịkwarị na m ebibie mba ndị ahụ niile 
\q2 nke m mere ka ị gaa biri nʼetiti ha kpamkpam, 
\q2 agaghị m ebibi gị kpamkpam. 
\q1 Aga m adọ gị aka na ntị, ma ọ ga-abụ site nʼụzọ ikpe ikpe ziri ezi. 
\q2 Agakwaghị m ahapụ inye gị ahụhụ i kwesiri ịnata.” 
\c 47  
\s1 Ozi e ziri banyere ndị Filistia 
\p  
\v 1 Okwu \nd Onyenwe anyị\nd* nke ruru Jeremaya onye amụma ntị banyere ndị Filistia. Okwu ndị a bịara tupu Fero ebuso obodo Gaza agha. 
\b  
\p  
\v 2 Ihe ndị a ka \nd Onyenwe anyị\nd* kwuru, 
\q1 “Lee ka mmiri si ala elu nʼakụkụ ugwu; 
\q2 ha ga-aghọkwa mmiri nke na-erubiga oke. 
\q1 Ha ga-erukwasị ala ahụ, kpuchiekwa ihe niile dị nʼime ya, 
\q2 ọ ga-ekpuchikwa obodo niile dị nʼala ahụ, na ndị bi nʼime ya. 
\q1 Ndị niile bi nʼala ahụ ga-eti mkpu akwa, 
\q2 mmadụ niile ga-akwasikwa akwa ike. 
\q1  
\v 3 Mgbe ha ga-anụ ụzụ ikiri ụkwụ nke ọtụtụ ịnyịnya, nke na-agbata ọsọ na-abịa nʼebe ha nọ, 
\q2 mgbe ha ga-anụkwa ụzụ ụgbọ agha ndị iro, 
\q2 na ụzụ nzọ ụkwụ igwe ha. 
\q1 Nʼoge ahụ, ndị bụ nna agaghị enwe ike nyere ụmụ ha aka, 
\q2 nʼihi na aka ha ga-akụda nʼakụkụ ha. 
\q1  
\v 4 Nʼihi na ụbọchị ahụ abịala 
\q2 mgbe a ga-ebibi ndị Filistia niile, 
\q1 mgbe a ga-ebipụ ndị niile fọdụrụ, 
\q2 ndị nwere ike inyere obodo Taịa na Saịdọn aka. 
\q1 Nʼihi na \nd Onyenwe anyị\nd* akwadoola ibibi ndị Filistia, 
\q2 o kwadoola ibibi ndị ahụ fọdụrụ nʼọnụ mmiri Kafto. 
\q1  
\v 5 Gaza ga-akpụcha isi ya nʼọnọdụ iru ụjụ. 
\q2 A ga-eme ka Ashkelọn dere duu. 
\q1 Ruo ole mgbe ka unu ga-anọgide na-egbukasị onwe unu ahụ, 
\q2 unu bụ ndị fọdụrụ afọdụ bi nʼala dị larịị? 
\b  
\q1  
\v 6 “ ‘Ewoo, gị mma agha \nd Onyenwe anyị\nd*, 
\q2 ole mgbe ị ga-ezu ike? 
\q1 Mịnye onwe gị nʼọbọ gị, 
\q2 kwụsị ịkpa ike gị ma dere duu.’ 
\q1  
\v 7 Ma ọ ga-esikwanụ aṅaa zuru ike, 
\q2 ebe ọ bụ \nd Onyenwe anyị\nd* nyere ya iwu 
\q1 ibu agha megide Ashkelọn, 
\q2 na ndị bi nʼọnụ mmiri oke osimiri?” 
\c 48  
\s1 Ozi e ziri banyere Moab 
\p  
\v 1 Nke a dịrị Moab: 
\b  
\p Ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, bụ Chineke Izrel kwuru, 
\q1 “Ahụhụ dịrị Nebo! Nʼihi na a ga-emebi ya. 
\q2 A ga-emekwa ka ihere mee Kiriatem, e, a ga-adọta ya nʼagha. 
\q2 A ga-etipịa Misgab, mee ka ihere mee ya. 
\q1  
\v 2 Ọ dịkwaghị ndị ga-eto Moab ọzọ, 
\q2 kama a ga-anọ na Heshbọn pịa ọpịpịa ọdịda ya. 
\q2 Ha ga-asị, ‘Bịanụ ka anyị bibie mba a, ka ọ ghara ịdịkwa.’ 
\q1 Ọ bụladị gị bụ Madmen, ka a ga-eme ka i dere duu. 
\q2 A ga-ejikwa mma agha chụọ gị ọsọ. 
\q1  
\v 3 Gee ntị nụrụ akwa na-ada na Horonaim, 
\q2 ọ bụ mkpu akwa oke mbibi na ịla nʼiyi. 
\q1  
\v 4 A ga-etikpọ Moab, 
\q2 ụmụntakịrị ya ga-etikwa mkpu akwa. 
\q1  
\v 5 Ha ga-eji oke ịkwa akwa 
\q2 na-agbago ụzọ Luhit; 
\q1 a ga-anụkwa mkpu akwa nke ndị e bibiri ihe ha nʼụzọ na-agbada Horonaim. 
\q2 A ga-anụ akwa mwute nʼihi mbibi nke bịakwasịrị ha. 
\q1  
\v 6 Gbalaganụ! Gbapụnụ ọsọ ndụ! 
\q2 Dịkwanụ ka osisi nta nke dị nʼọzara. 
\q1  
\v 7 Ebe ọ bụ na unu na-atụkwasị obi nʼaka ọrụ unu, na nʼakụnụba unu, 
\q2 a ga-adọtakwa unu nʼagha. 
\q1 Ndị Kemosh ka a ga-eburu gaa mba ọzọ, 
\q2 ha na ndị nchụaja na ndịisi ọchịchị ya. 
\q1  
\v 8 Onye mbibi ahụ ga-abịa megide obodo niile. 
\q2 O nwekwaghị obodo nke pụrụ ịgbanarị mbibi ya. 
\q1 A ga-ala ndagwurugwu niile nʼiyi, 
\q2 bibiekwa ebe dị elu nke dị larịị, 
\q2 nʼihi na ọ bụ okwu si nʼọnụ \nd Onyenwe anyị\nd* pụta. 
\q1  
\v 9 Wụkwasị ala Moab nnu, 
\q2 nʼihi na a ga-eme ka ọ ghọọ ebe tọgbọrọ nʼefu. 
\q1 Obodo niile dị nʼime ya ga-aghọ mkpọmkpọ ebe, 
\q2 nke mmadụ ọbụla na-agaghị ebikwa nʼime ya. 
\b  
\q1  
\v 10 “Ọbụbụ ọnụ dịrị onye ahụ ji aghụghọ na-arụ ọrụ \nd Onyenwe anyị\nd*. 
\q2 Ahụhụ dịrị onye na-ewezuga mma agha nʼebe iwusi ọbara dị. 
\b  
\q1  
\v 11 “Onye na-anọ juu ka Moab bụ site na mgbe ọ bụ nwantakịrị, 
\q2 ọ dịka mmanya doro edo, 
\q1 nke a na-adịghị esi nʼotu udu wụgharịa ya nʼime udu ọzọ, 
\q2 o nwebeghị oge ọbụla e ji mee ka ọ ga biri nʼala ọzọ. 
\q1 Ọ bụ ya mere ụtọ ya adịghị agbanwe agbanwe, 
\q2 isisi ya agbanwekwaghị. 
\q1  
\v 12 Ma ụbọchị ndị ahụ na-abịa,” otu a ka \nd Onyenwe anyị\nd* kwupụtara, 
\q1 “mgbe m ga-eziga ndị ikom ọrụ ha bụ ịwụpụ ihe site nʼite,\f + \fr 48:12 \ft Ịwụgharị ihe site nʼotu ite wụbanye ya nʼọzọ\f* 
\q2 ha ga-awụpụkwa ya. 
\q1 Ha ga-agbapụ ihe niile dị nʼite ya niile, 
\q2 tụwakwaa ite ya niile. 
\q1  
\v 13 Mgbe ahụ, ihere Kemosh ga-eme Moab, 
\q2 dịka ihere si mee Izrel 
\q2 mgbe ha tụkwasịrị Betel obi ha. 
\b  
\q1  
\v 14 “Unu si aṅaa ekwu sị, ‘Ndị dị ike nʼagha ka anyị bụ; 
\q2 anyị bụkwa dimkpa nʼagha’? 
\q1  
\v 15 A ga-ebibi ala Moab, busokwa obodo ya niile agha. 
\q2 Ụmụ okorobịa ya niile ndị ahọrọ ahọ ga-ada nʼogbugbu\f + \fr 48:15 \ft Ya bụ, nʼagha ahụ\f* ahụ.” 
\q2 Otu a ka Eze ahụ kwubiri, onye aha ya bụ \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile. 
\q1  
\v 16 “Ọdịda Moab dị nso; 
\q2 oke nhụju anya ya ga-abịakwa ọsịịsọ. 
\q1  
\v 17 Kasịenụ\f + \fr 48:17 \ft Maọbụ, \fqa ruo ụjụ maka ya\f* ya obi, unu ndị niile gbara ya gburugburu, 
\q2 unu ndị niile maara na ọ bụ mba dị ukwuu. 
\q1 Kwupụtanụ sị, ‘Esi aṅa gbajie mkpanaka eze a, nke dị ike, 
\q2 lee ka e si gbajiekwa mkpanaka a nke dị ebube!’ 
\b  
\q1  
\v 18 “Sitenụ nʼebe nsọpụrụ unu dị elu rịdata, 
\q2 bịa nọdụnụ nʼala kpọrọ nkụ, 
\q2 unu ndị bi nʼobodo bụ Ada Dibọn. 
\q1 Nʼihi na onye ahụ bibiri Moab 
\q2 ga-abịa ibu agha megide unu, 
\q2 ọ ga-alakwa obodo unu niile e wusiri ike nʼiyi. 
\q1  
\v 19 Guzonụ nʼakụkụ ụzọ, hụrụ\f + \fr 48:19 \ft Ya bụ, Lee\f* ihe na-eme, 
\q2 unu ndị bi nʼime Aroea. 
\q1 Jụọnụ nwoke unu hụrụ na-agba ọsọ, na nwanyị nke na-ewezuga onwe ya ajụjụ 
\q2 sị ha, ‘Gịnị mere?’ 
\q1  
\v 20 E meela ka ihere mee Moab, nʼihi na a tụpịala ya. 
\q2 Kwasienụ akwa ike, tiekwanụ mkpu akwa. 
\q1 Kwupụta ya nʼAnọn 
\q2 na e bibiela Moab. 
\q1  
\v 21 Oge a ga-ekpe ndị bi nʼala dị larịị ikpe abịala, 
\q2 bụ ndị bi na Họlọn, Jahaz na Mefaat, 
\q2  
\v 22 Dibọn, Nebo na Bet-Diblataim, 
\q2  
\v 23 Kiriatem, Bet-Gamul na Bet-Meon, 
\q2  
\v 24 Keriọt na Bozra, 
\q2 na obodo niile dị nʼala Moab, ndị dị nso, na ndị nke dị anya. 
\q1  
\v 25 E bipụla mpi\f + \fr 48:25 \ft Ya bụ, ike\f* Moab, 
\q2 a gbajiekwala ogwe aka ya,” 
\q2 otu a ka \nd Onyenwe anyị\nd* kwupụtara. 
\b  
\q1  
\v 26 “Meenụ ya ka ọ ṅụbiga mmanya oke, 
\q2 nʼihi na o nupuru isi megide \nd Onyenwe anyị\nd*. 
\q1 Moab ga-atụrụ onwe ya nʼihe ọ gbọrọ. 
\q2 Ọ ga-aghọkwa ihe ọchị. 
\q1  
\v 27 Izrel ọ bụghị ihe ọchị nye gị? 
\q2 Ọ bụ nʼetiti ndị na-ezu ohi ka e jidere ya, 
\q1 mere i ji na-efufere ya isi 
\q2 mgbe ọbụla ị na-ekwu okwu banyere ya? 
\q1  
\v 28 Sitenụ nʼobodo unu niile gbapụ ọsọ; jeenụ biri nʼetiti nkume, 
\q2 unu ndị bi nʼala Moab. 
\q1 Dịrịnụ ka nduru nke na-ewu akwụ ya 
\q2 nʼakụkụ ọnụ ọgba nkume. 
\b  
\q1  
\v 29 “Anyị anụla ihe banyere mpako Moab. 
\q2 Anyị anụla na mpako ahụ dị ukwuu, 
\q1 nụkwa ihe banyere oke mbuli elu nke ọ na-ebuli onwe ya, 
\q2 na oke nganga nke obi ya. 
\q1  
\v 30 Amaara m ihe banyere mmụọ nke akpọghị onye ọzọ ihe ọbụla, nke dị nʼime ya, ma ọ gaghị abara ya uru ọbụla. 
\q2 Ịnya isi ya agaghị arụpụtakwa ihe ọbụla, otu a ka \nd Onyenwe anyị\nd* kwubiri ya. 
\q1  
\v 31 Nʼihi ya, aga m akwasị akwa ike nʼihi Moab, 
\q2 aga m eti mkpu akwa nʼihi ala Moab niile. 
\q2 Aga m asụ ude akwa nʼihi ndị Kia Hareset. 
\q1  
\v 32 Akwa nke karịrị akwa Jeza ka m ga-akwa nʼihi gị, 
\q2 gị osisi vaịnị dị na Sibma. 
\q1 Alaka gị gbasara ruo nʼakụkụ osimiri, 
\q2 e, ha gbasara ruo nʼosimiri Jeza. 
\q1 Ma onye mbibi abịakwasịla mkpụrụ gị niile chara acha, 
\q2 e, ọ bịakwasịla mkpụrụ vaịnị gị niile. 
\q1  
\v 33 Ọṅụ na obi ụtọ ka e wepụrụ 
\q2 site nʼubi vaịnị niile, na nʼala ubi niile nke Moab. 
\q1 E meela ka mmanya vaịnị kwụsị ịgbapụtakwa site nʼebe ịzọcha mmanya. 
\q2 Ọ dịkwaghị onye na-eji mkpu ọṅụ na-azọcha ha, 
\q1 Ọ bụ ezie na a na-anụ olu iti mkpu, 
\q2 ma ọ bụghị olu iti mkpu ọṅụ. 
\b  
\q1  
\v 34 “A na-anụ ụda iti mkpu akwa ha 
\q2 site nʼobodo Heshbọn ruo Eleale, na Jehaz. 
\q1 A na-anụkwa ya site na Zoa ruo, ọ bụladị obodo ndị dị anya, dịka Horonaim, na Eglat Shelishiya. 
\q2 Nʼihi na mmiri niile nke Nimrim ataala. 
\q1  
\v 35 Aga m eme ka ndị ahụ niile na-achụ aja nʼebe niile dị elu, 
\q2 na ndị ahụ niile na-achụrụ chi ha dị iche iche aja ihe nsure ọkụ na-esi isi ụtọ, 
\q2 hapụ ịdịkwa nʼala Moab,” otu a ka \nd Onyenwe anyị\nd* kwubiri. 
\q1  
\v 36 “Ụda akwa nke na-ada nʼime obi m nʼihi Moab dịka ụda ọja. 
\q2 Ụda akwa nke dịkwa ka ụda ọja na-adakwa nʼime obi m nʼihi ndị Kia Hareset. 
\q2 Akụ niile ha kpakọtara alaala nʼiyi. 
\q1  
\v 37 A kpụchapụla agịrị isi niile, 
\q2 kpachakwa afụọnụ ha niile. 
\q1 E bipụkwala aka ha niile. 
\q2 Ọ bụkwa akwa mkpe ka e ji kpuchie ukwu niile. 
\q1  
\v 38 Nʼelu ụlọ niile nke dị na Moab, 
\q2 nakwa nʼama egwuregwu niile, 
\q1 ọ dịghị ihe ọzọ karịa naanị iru ụjụ ka a na-ahụ. 
\q2 Nʼihi na e tiwaala m Moab 
\q2 dịka e si etiwa ite aja nke ọ dịghị onye bụla chọrọ ya,” otu a ka \nd Onyenwe anyị\nd* kwupụtara. 
\q1  
\v 39 “Lee ka e si tipịa ya! Lee ka ha si akwasị akwa ike! 
\q2 Leekwa ka Moab si gbakụta azụ ya nʼihi ọnọdụ ihere ya! 
\q1 Moab aghọọla ihe ọchị, 
\q2 ọ ghọọla ihe iju anya nye ndị niile gbara ya gburugburu.” 
\p  
\v 40 Ihe ndị a ka \nd Onyenwe anyị\nd* kwuru, 
\q1 “Lee, ọ dị otu ugo na-efedata, 
\q2 nke gbasapụrụ nku ya kpuchie ala Moab niile. 
\q1  
\v 41 A ga-adọta Keriọt nʼagha, 
\q2 meriekwa ebe ya niile e wusiri ike. 
\q1 Nʼụbọchị ahụ, obi ndị bụ dike nʼagha nʼala Moab 
\q2 ga-adị ka obi nwanyị ime na-eme. 
\q1  
\v 42 A ga-ebibi obodo Moab, mee ya ka ọ ghara ịdịkwa, 
\q2 nʼihi na ọ kagidere \nd Onyenwe anyị\nd* anya. 
\q1  
\v 43 Oke egwu na olulu, na igbudu nke onye na-esi ọnya nọ na-eche unu, 
\q2 unu ndị Moab,” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwubiri. 
\q1  
\v 44 “Nʼoge ahụ, onye ọbụla gbapụrụ ọsọ site nʼihe oke egwu 
\q2 ga-adaba nʼolulu. 
\q1 Onye ọbụla ga-esikwa nʼolulu rịpụta 
\q2 ka igbudu ga-ejide. 
\q1 Nʼihi na aga m eme ka afọ ahụ a kara aka 
\q2 maka ịta Moab ahụhụ bịakwasị ya,” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwubiri ya. 
\b  
\q1  
\v 45 “Nʼokpuru ndo Heshbọn 
\q2 ka ndị ahụ gbapụrụ ọsọ ndụ guzoro, na-enweghị onye inyeaka. 
\q1 Nʼihi na ọkụ esitela na Heshbọn rere na-aga; 
\q2 ire ọkụ dị ukwuu esitela nʼetiti Saịhọn na-apụ, 
\q1 na-erepịa egedege ihu ndị Moab, 
\q2 na okpokoro\f + \fr 48:45 \ft Maọbụ, \fqa opu isi\f* isi ndị ahụ ji oke ụzụ\f + \fr 48:45 \ft Maọbụ, \fqa mkpọtụ\f* na-anya isi. 
\q1  
\v 46 Ahụhụ dịrị gị, gị Moab! 
\q2 Ebibiela ndị Kemosh niile. 
\q1 A dọtakwala ụmụ gị ndị ikom 
\q2 na ụmụ gị ndị inyom nʼagha, buru ha gaa mba ọzọ. 
\b  
\q1  
\v 47 “Ma emesịa, nʼụbọchị ndị ahụ na-abịa, 
\q2 aga m eme ka ndị Moab a dọtara nʼagha lọghachi.” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwubiri ya. 
\p Nke a bụ ọgwụgwụ ikpe ọmụma dịrị Moab. 
\b  
\c 49  
\s1 Ozi e ziri banyere Amọn 
\p  
\v 1 Nke a dịrị ndị Amọn: 
\b  
\p Ihe ndị a ka \nd Onyenwe anyị\nd* kwuru, 
\q1 “Ọ bụ na Izrel enweghị ụmụ ndị ikom? 
\q2 Izrel o nweghị onye nnweta ihe o nwere? 
\q1 Gịnị mere Molek ji nweta obodo Gad? 
\q2 Gịnị mere ndị ya ji bichie obodo ya niile? 
\q1  
\v 2 Ma ụbọchị ahụ na-abịa,” ka \nd Onyenwe anyị\nd* kwupụtara, 
\q1 “mgbe m ga-eme ka a nụ ụda iti mkpu agha, 
\q2 nke a ga-eti megide Raba, obodo ndị Amọn. 
\q1 A ga-eme ya ka ọ ghọọ mkputamkpu ebe. 
\q2 A ga-esurekwa ya ọkụ, ya na obodo nta niile gbara ya gburugburu. 
\q1 Mgbe ahụ Izrel ga-achụpụkwa 
\q2 ndị ahụ niile chụpụrụ ya.” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwuru. 
\q1  
\v 3 “Kpọọ mkpu akwa, gị Heshbọn, nʼihi na ebibiela Ai! 
\q2 Tisienụ mkpu akwa ike unu ndị bi na Raba! 
\q1 Yirinụ uwe mkpe unu, tiekwanụ aka nʼobi nʼihi iru ụjụ; 
\q2 gbagharịanụ nʼogige mgbidi obodo unu, 
\q1 nʼihi na a ga-adọta Molek nʼagha, 
\q2 buru ya na ndị nchụaja ya na ndịisi ọchịchị ya gaa mba ọzọ. 
\q1  
\v 4 Gịnị mere unu ji anya isi nʼihi ndagwurugwu 
\q2 nke na-amị mkpụrụ hiri nne, 
\q1 gị ada nwanyị na-ekwesighị ntụkwasị obi, 
\q2 onye ntụkwasị obi ya dị nʼakụnụba ya, 
\q2 gị onye na-asị, ‘Onye ga-ebuso m agha?’ 
\q1  
\v 5 Aga m esite nʼaka ndị niile gbara gị gburugburu 
\q2 mee ka oke egwu bịakwasị gị,” 
\q2 otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwupụtara ya, 
\q1 “A ga-achụpụ onye ọbụla nʼime unu. 
\q2 Ọ dịkwaghị onye ga-achịkọta ndị ahụ niile gbapụrụ agbapụ. 
\b  
\q1  
\v 6 “Ma mgbe e mesịrị, aga m emekwa ka ndị Amọn laghachikwa nʼala ha.” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwubiri. 
\s1 Ozi e ziri banyere Edọm 
\p  
\v 7 Nke dịrị Edọm: 
\b  
\p Ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwuru, 
\q1 “Ọ pụtara na onye amamihe adịghịkwa na Teman? 
\q2 Okwu ndụmọdụ ọ gwụla nʼọnụ ndị nwere nghọta? 
\q2 Amamihe ha o reela ure? 
\q1  
\v 8 Chigharịanụ gbalaga, unu ndị bi na Dedan. 
\q2 Gaa zoonụ onwe unu nʼọgba nkume miri emi, 
\q1 nʼihi na aga m eme ka ihe ọjọọ bịakwasị Ịsọ, 
\q2 nʼoge ahụ m ga-ata ya ahụhụ. 
\q1  
\v 9 Ọ bụrụ na ndị na-aghọrọ mkpụrụ vaịnị abịakwute gị, 
\q2 ọ bụ na ha agaghị ahapụrụ gị mkpụrụ ole na ole? 
\q1 Ọ bụrụkwa na ndị ohi abịa nʼabalị, 
\q2 ọ bụghị naanị ihe ha chọrọ ka ha ga-akwakọrọ? 
\q1  
\v 10 Ma aga m agba Ịsọ ọtọ.\f + \fr 49:10 \ft Agaghị ahapụrụ ya ihe ọbụla\f* 
\q2 Aga m ekpughe ebe nzuzo ya niile 
\q2 ka ọ ghara izobe onwe ya. 
\q1 Ụmụ ya na ndị ikwu ya,\f + \fr 49:10 \ft Maọbụ, \fqa ndị ikom ya ji ngwa agha\f* 
\q2 tinyere ndị ya na ha dị na mma na ndị agbataobi ya, ga-ala nʼiyi. 
\q2 Ya mere, ọ dịghịkwa onye ga-asị, 
\q1  
\v 11 ‘Hapụnụ ụmụ mgbei unu niile, nʼihi na mụ onwe m ga-edebe ha ndụ. 
\q2 Ndị inyom unu niile ndị di ha nwụrụ nwere ike ịtụkwasị m obi.’ ” 
\p  
\v 12 Ihe ndị a ka \nd Onyenwe anyị\nd* kwuru, “Ọ bụrụ na e mere ka ndị ahụ na-ekwesighị ịṅụ ihe dị nʼiko ahụ ṅụọ ya, a ga-esi aṅaa ghara ịta gị ahụhụ? A ghaghị ịta gị ahụhụ; ị ghakwaghị ịṅụ site nʼiko ahụ.”  
\v 13 “Eji m onwe m ṅụọ iyi, otu a ka \nd Onyenwe anyị\nd* kwupụtara, sị, na Bozra ga-aghọ mkpọmkpọ ebe, na ihe iju anya, na ihe ịta ụta, na ihe ịbụ ọnụ. Obodo ya niile ga-aghọkwa mkpọmkpọ ebe ruo mgbe ebighị ebi.” 
\q1  
\v 14 Anụla m ozi si nʼọnụ \nd Onyenwe anyị\nd*. 
\q2 E zipụla onyeozi ka ọ ga mba niile dị iche iche zie ha ozi, sị, 
\q1 “Chịkọtaanụ onwe, megide ya. 
\q2 Bilikwanụ maka ibu agha!” 
\b  
\q1  
\v 15 Ugbu a, aga m eme ka ị dị nta nʼetiti mba dị iche iche, 
\q2 ihe nlelị na-ebe mmadụ nọ. 
\q1  
\v 16 Ịdị egwu gị nke na-eyinye ndị mmadụ egwu, 
\q2 na nganga nke obi gị eduhiela gị, 
\q1 gị onye na-ebi na mgbawa niile nke nkume dị elu, 
\q2 gị onye ji ebe niile dị elu nke ugwu nʼaka ya. 
\q1 A sịkwarị na i wuo akwụ gị nʼebe dị elu, dịka ebe ugo ga-ewu akwụ ya, 
\q2 aga m esite nʼebe ahụ kpụdata gị nʼala, 
\q2 otu a ka \nd Onyenwe anyị\nd* kwubiri ya. 
\q1  
\v 17 “Edọm ga-aghọ ihe iju anya. 
\q2 Ndị niile na-esi nʼakụkụ ya agafe ga-anọ nʼọnọdụ iju anya, 
\q2 ha ga-eledakwa ya anya nʼihi ọnya ya niile. 
\q1  
\v 18 Dịka a kwaturu Sọdọm na Gọmọra, 
\q2 ya na obodo niile gbara ya gburugburu. 
\q1 Otu a kwa, ọ dịghị onye ọbụla ga-ebi nʼebe ahụ; 
\q2 nwa mmadụ ọbụla agakwaghị ebi nʼime ya,” otu a ka \nd Onyenwe anyị\nd* kwuru. 
\b  
\q1  
\v 19 “Aga m esi nʼala ya chụpụ Edọm nʼotu ntabi anya, 
\q2 dịka mgbe ọdụm na-esi nʼoke ọhịa Jọdan 
\q1 na-arịgopụta nʼebe ịta nri nke ụmụ anụmanụ jupụtara nʼahịhịa ndụ. 
\q2 Ma onye bụ onye ahụ a họpụtara, onye m ga-enyefe ọrụ a nʼaka ya? 
\q1 Onye dịka m? Onye kwa pụrụ ịpụta tụọ m aka nʼihu? 
\q2 Onye bụkwa onye ọzụzụ atụrụ ahụ nke pụrụ ido onwe ya megide m?” 
\b  
\q1  
\v 20 Nʼihi nke a, nụrụ ihe \nd Onyenwe anyị\nd* kwadobere megide Edọm, 
\q2 nụrụkwa ihe o zubere megide ndị bi na Teman. 
\q1 A ga-adọkpụrụ ndị dị nta nʼetiti igwe ewu na atụrụ ahụ, 
\q2 ebe ịta nri ha ga-anọ nʼọnọdụ mgbagwoju anya nʼihi nke a. 
\q1  
\v 21 Ụwa ga-ama jijiji mgbe ha nụrụ mkpọtụ ọdịda ha; 
\q2 iti mkpu akwa ha ga-adakwa ụda ruo nʼOsimiri Uhie. 
\q1  
\v 22 Lee, otu ugo ga-efeli elu, fedatakwa. 
\q2 Ọ ga-agbasapụ nku ya kpuchie ala Bozra niile. 
\q1 Nʼụbọchị ahụ, obi ndị bu dike nʼagha nʼEdọm 
\q2 ga-adị ka obi nwanyị ime na-eme. 
\s1 Ozi e ziri banyere Damaskọs 
\p  
\v 23 Nke dịrị Damaskọs: 
\q1 “Ụjọ ejula Hamat na Apad obi, 
\q2 nʼihi na ha anụla akụkọ ọjọọ. 
\q1 Ha adaala mba, 
\q2 nọọkwa nʼoke echiche dịka osimiri nke ebili na-amagharị nʼelu ya. 
\q1  
\v 24 Damaskọs aghọọla onye ike gwụrụ. 
\q2 Ọ tụgharịala ịgbapụ ọsọ, 
\q2 ma ọma jijiji ejidela ya. 
\q1 Oke obi ụfụ na ihe mgbu ejidesiela ya aka ike, 
\q2 dịka obi ụfụ na ihe mgbu nke na-ejide nwanyị ime na-eme. 
\q1  
\v 25 Gịnị mere na-agbahapụbeghị obodo ahụ a maara aha ya, 
\q2 bụ obodo ahụ nke ihe ya na-atọ obi m ụtọ? 
\q1  
\v 26 Nʼezie, ụmụ okorobịa nọ nʼime ya ga-ada nʼokporoụzọ niile, 
\q2 a ga-emekwa ka ndị agha ya niile dere duu nʼụbọchị ahụ.” 
\q2 Otu a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwubiri. 
\q1  
\v 27 “Aga m esunye mgbidi Damaskọs ọkụ. 
\q2 Ọkụ ahụ ga-eripịakwa ebe e wusiri ike nke Ben-Hadad.” 
\s1 Ozi e ziri banyere Keda na Hazọ 
\p  
\v 28 Banyere Keda na alaeze Hazọ, nke Nebukadneza eze Babilọn busoro agha: 
\b  
\p Ihe ndị a ka \nd Onyenwe anyị\nd* kwuru, 
\q1 “Bilienụ gaa buso Keda agha. 
\q2 Bibiekwanụ ndị ahụ niile bi nʼakụkụ ọwụwa anyanwụ. 
\q1  
\v 29 A ga-adọta ụlọ ikwu ha, na igwe ewu na atụrụ ha nʼagha. 
\q2 A ga-ebukọrọkwa ụlọ mgbochi ha niile, 
\q2 ya na ngwongwo na ịnyịnya kamel ha niile. 
\q1 Ndị mmadụ ga-etikwa mkpu sị ha, 
\q2 ‘Oke egwu dị nʼakụkụ niile!’ 
\b  
\q1  
\v 30 “Gbalaganụ ọsịịsọ. 
\q2 Jeenụ nọdụ nʼime ọgba nkume niile miri emi, unu ndị niile bi na Hazọ,” 
\q2 otu a ka \nd Onyenwe anyị\nd* kwupụtara. 
\q1 Nebukadneza eze Babilọn atụọla atụmatụ megide unu, 
\q2 o chepụtakwala ụzọ ọ ga-esi megide unu. 
\b  
\q1  
\v 31 “Bilienụ, gaa buso mba ahụ agha, 
\q2 bụ mba ahụ na-ebi na ntụkwasị obi,” 
\q2 otu a ka \nd Onyenwe anyị\nd* kwupụtara, 
\q1 “mba nke na-enweghị ibo ọnụ ụzọ, maọbụ mkpọrọ e ji akpọchi ya, 
\q2 mba ahụ nke ndị ya na-ebiri naanị onwe ha. 
\q1  
\v 32 Ịnyịnya kamel ha ga-abụ ihe a ga-akwata nʼagha, 
\q2 ọtụtụ igwe ehi ha ga-abụkwa ihe a ga-alụta nʼagha. 
\q1 Aga m efesa ha nye ifufe, bụ ndị niile nọ ebe dị anya, bụ ndị ahụ niile na-akpụchapụ agịrị isi egedege ihu ha. 
\q2 Aga m emekwa ka ihe ọjọọ si nʼakụkụ niile bịakwasị ha,” 
\q2 otu a ka \nd Onyenwe anyị\nd* kwubiri. 
\q1  
\v 33 “Mgbe ahụ, Hazọ ga-aghọ ebe obibi nke nkịta ọhịa. 
\q2 Ọ ga-aghọ ebe tọgbọrọ nʼefu ruo mgbe ebighị ebi. 
\q1 O nweghị onye ọbụla ga-ebi nʼebe ahụ, 
\q2 nwa mmadụ ọbụla agakwaghị ebi nʼime ya.” 
\s1 Ozi banyere Ilam 
\p  
\v 34 Nke a bụ okwu \nd Onyenwe anyị\nd* ndị ruru Jeremaya onye amụma ntị banyere Elam, mgbe Zedekaya eze Juda bidoro ọchịchị ya. 
\b  
\p  
\v 35 Ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwuru, 
\q1 “Lee, aga m agbaji ụta nke Elam, 
\q2 bụ ụta ahụ ha ji anya isi na ọ bụ ebe ike ha dị. 
\q1  
\v 36 Aga m esite nʼakụkụ anọ nke mbara eluigwe zite oke ifufe anọ, 
\q2 nke ga-abịa megide Elam. 
\q1 Aga m efesa ha nye oke ifufe anọ ndị a, 
\q2 ndị ga-ebufu ha buga ha na mba niile dị iche iche, 
\q2 ọ dịghị obodo a na-agaghị ahụ ndị Ilam a dọtara nʼagha. 
\q1  
\v 37 Aga m etipịa Elam nʼihu ndị iro ha, 
\q2 e, nʼihu ndị ahụ na-achọsi ndụ ya ike. 
\q1 Aga m eme ka ihe ọjọọ bịakwasị ha, 
\q2 meekwa ka oke iwe m dị ọkụ bịakwasị ha,” 
\q2 otu a ka \nd Onyenwe anyị\nd* kwubiri. 
\q1 “Aga m eji mma agha chụọ ha ọsọ 
\q2 tutu ruo mgbe m mere ka ha niile gwụsịa. 
\q1  
\v 38 Aga m edo ocheeze m nʼElam, 
\q2 bibiekwa eze ya na ndịisi ọchịchị ya,” 
\q2 otu a ka \nd Onyenwe anyị\nd* kwubiri. 
\b  
\q1  
\v 39 “Ma nʼikpeazụ, nʼụbọchị ndị ahụ na-abịa, 
\q2 aga m eweghachite akụnụba niile nke Elam.” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwubiri ya. 
\c 50  
\s1 Ozi e ziri banyere Babilọn 
\p  
\v 1 Okwu \nd Onyenwe anyị\nd* nke ruru Jeremaya onye amụma ntị banyere Babilọn na banyere ala ndị Babilọn. 
\q1  
\v 2 “Kwusaa ya na mba niile, mee ka a nụrụ ya; 
\q2 bulie ọkọlọtọ mgbe a na-ekwusa ya. 
\q2 Kwupụta ihe niile, ezokwala ihe ọbụla, kama kwusaa ya sị, 
\q1 ‘A ga-adọta Babilọn nʼagha. 
\q2 Ihere ga-emesịa mee Bel; 
\q2 otu a kwa, egwu ga-ejupụta Maduk obi. 
\q1 A ga-eme ka ihere mee oyiyi ya niile a kpụrụ akpụ; 
\q2 oke egwu ga-ejidekwa arụsị ya niile.’ 
\q1  
\v 3 Otu mba, nke si nʼakụkụ ugwu, ga-ebuso ya agha, 
\q2 mee ala ya ka ọ tọgbọrọ nʼefu. 
\q1 Ọ dịkwaghị onye ga-ebi nʼime ya, 
\q2 nʼihi na mmadụ na anụmanụ ga-esi nʼime ya gbalaga. 
\b  
\q1  
\v 4 “Nʼụbọchị ndị ahụ, ma na mgbe ahụ,” otu a ka \nd Onyenwe anyị\nd* kwupụtara, 
\q1 ndị Izrel na ndị Juda ga-ejikọta onwe ha nʼotu. 
\q2 Ha niile ga-eji anya mmiri pụọ ịchọ \nd Onyenwe anyị\nd* Chineke ha. 
\q1  
\v 5 Ha ga-ajụ ajụjụ, banyere ụzọ e si eje Zayọn. 
\q2 Mgbe ahụ, ha ga-eche ihu ha ijeru nʼebe ahụ. 
\q1 Ha niile ga-abịakwa were onwe ha nyefee\f + \fr 50:5 \ft Rapara nʼahụ Onyenwe anyị\f* nʼaka \nd Onyenwe anyị\nd*, 
\q2 nʼime ọgbụgba ndụ ebighị ebi, 
\q2 nke a na-agaghị echefu echefu. 
\b  
\q1  
\v 6 “Ndị m akpafuola dịka atụrụ furu efu. 
\q2 Ndị ọzụzụ atụrụ ha eduhiela ha, 
\q2 mee ka ha na-awagharị nʼugwu ukwu niile. 
\q1 Ha na-akpagharị nʼelu ugwu ukwu, ma nʼelu ugwu nta. 
\q2 Ha echefuokwala ebe izuike nke ha. 
\q1  
\v 7 Nʼihi ya, ndị niile chọtara ha na-eripịa ha. 
\q2 Ndị iro ha na-ekwukwa sị, ‘Ikpe amaghị anyị 
\q1 nʼihi na ha emehiela megide \nd Onyenwe anyị\nd*, onye bụ ezi ebe ịta nri ha, 
\q2 na onye bụkwa olileanya nke nna nna ha.’ 
\b  
\q1  
\v 8 “Sinụ na Babilọn gbalaga; 
\q2 sitekwanụ nʼala Babilọn pụọ, 
\q2 dịrịnụ ka mkpi na-edu igwe ewu na atụrụ. 
\q1  
\v 9 Nʼihi na aga m akpali ọtụtụ mba dị ike site nʼala dị nʼugwu, 
\q2 ndị ga-ejikọta onwe ha ibuso Babilọn agha. 
\q1 Ha ga-edo onwe ha nʼusoro imegide ya; 
\q2 ọ bụkwa nʼakụkụ ugwu ka ha ga-esi dọta ya nʼagha. 
\q1 Àkụ ha ga-agba ga-adị ka àkụ nke onye bụ dike nʼagha na onye ọka ịgba ụta na-agba. 
\q2 Ha agaghị agba aka lọta. 
\q1  
\v 10 Nʼihi nke a, Babilọn ga-aghọ ihe nkwata nʼagha. 
\q2 Afọ ga-ejukwa ndị niile bụ ndị ga-akwata ya.” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwubiri. 
\b  
\q1  
\v 11 “Nʼihi na ị ṅụrịrị ọṅụ nwee obi ụtọ, 
\q2 gị onye bibiri ihe nketa m, 
\q1 ị wugharịrị dịka nwa ehi nke na-azọcha ọka, 
\q2 bee akwa dịka oke ịnyịnya. 
\q1  
\v 12 Ihere ga-eme nne unu, 
\q2 e, a ga-eme ka oke ihere mee nne mụrụ unu. 
\q1 Ọ ga-abụkwa mba dịkarịsịrị ala nʼetiti mba niile, 
\q2 bụrụkwa ọzara, ala kpọrọ nkụ na ala uzuzu. 
\q1  
\v 13 Nʼihi iwe dị ukwuu nke \nd Onyenwe anyị\nd*, ọ dịghị onye ga-ebikwa nʼala Babilọn ọzọ, 
\q2 nʼihi na a ga-ebibi ya kpamkpam. 
\q1 Ndị niile si nʼakụkụ ya na-agafe ka ọ ga-eju anya. 
\q2 Ha ga-akparị ya nʼihi ọnya niile dị ya nʼahụ. 
\b  
\q1  
\v 14 “Doonụ onwe unu nʼusoro gburugburu obodo Babilọn, 
\q2 unu ndị niile na-agba ụta. 
\q1 Gbaanụ ya ụta. Unu echela banyere àkụ ole unu ga-agbapụ 
\q2 nʼihi na o mehiela megide \nd Onyenwe anyị\nd*. 
\q1  
\v 15 Kpọọnụ mkpu agha megide ya, site nʼakụkụ niile! 
\q2 Ọ chiliela aka ya elu. Lee, ụlọ elu ya e wusiri ike adaala, 
\q2 a kwatuokwala mgbidi ya niile. 
\q1 Ebe ọ bụ na \nd Onyenwe anyị\nd* na-abọrọ onwe ya ọbọ nʼahụ Babilọn, 
\q2 bọọnụ ya ọbọ. 
\q2 Meenụ ya dịka o si mee ndị ọzọ. 
\q1  
\v 16 Site na Babilọn wezuga onye na-agha mkpụrụ 
\q2 na onye ji mma owuwe ihe ubi na-ewe ihe ubi. 
\q1 Ka onye ọbụla laghachikwuru ndị nke ya, 
\q2 ka onye ọbụla gbalaakwa nʼala nke aka ya, 
\q2 nʼihi mma agha nke onye na-emegbu emegbu. 
\b  
\q1  
\v 17 “Izrel dị ka ewu na atụrụ a chụsasịrị achụsasị, 
\q2 nke ọdụm chụsasịrị. 
\q1 Onye bu ụzọ ripịa ya 
\q2 bụ eze Asịrịa. 
\q1 Onye ikpeazụ gwepịara ọkpụkpụ ya 
\q2 bụ Nebukadneza, eze Babilọn.” 
\p  
\v 18 Nʼihi ya, ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, bụ Chineke Izrel kwuru, 
\q1 “Aga m ata eze Babilọn, na ndị ala ya ahụhụ, 
\q2 dịka m si taa eze Asịrịa ahụhụ. 
\q1  
\v 19 Ma aga m akpọghachitekwa Izrel nʼebe ịta nri nke ha. 
\q2 Ha ga-atakwa nri na Kamel na Bashan. 
\q1 Ọ bụkwa nʼugwu Ifrem na Gilead 
\q2 ka afọ ga-ejukwa ha. 
\q1  
\v 20 Nʼụbọchị ndị ahụ, ma na mgbe ahụ,” otu a ka \nd Onyenwe anyị\nd* kwubiri, 
\q1 “a ga-achọ ajọọ omume nke Izrel, 
\q2 ma ọ dịghị nke a ga-achọta. 
\q1 A ga-achọkwa mmehie niile nke Juda, 
\q2 ma o nweghị nke a ga-achọta, 
\q2 nʼihi na aga m agbaghara ndị ahụ m mere ka ha fọdụ mmehie ha. 
\b  
\q1  
\v 21 “Busonụ ala Merataim agha, 
\q2 busokwanụ ndị bi na Pekod agha. 
\q1 Chụọ ha ọsọ, gbuchapụ ma bibiekwa ha niile kpamkpam.” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwubiri. 
\q2 “Mezuonụ ihe niile m nyere unu nʼiwu. 
\q1  
\v 22 A na-anụ ụzụ agha nʼala ahụ, 
\q2 a na-anụ ụzụ oke mbibi. 
\q1  
\v 23 Lee ka e si gbajie, 
\q2 ma tipịa mkpirisi igwe ahụ na-esupịa ụwa niile. 
\q1 Lee ka Babilọn si tọgbọrọ nʼefu 
\q2 nʼetiti mba niile nke ụwa. 
\q1  
\v 24 Esiiri m gị ọnya, gị Babilọn; 
\q2 ị makwara nʼọnya ahụ tupu ị mata na ọnya ahụ dị. 
\q1 A chọtala gị, jidekwa gị, 
\q2 nʼihi na i doola onwe gị ibuso \nd Onyenwe anyị\nd* agha. 
\q1  
\v 25 \nd Onyenwe anyị\nd* emegheela ụlọakụ ngwa agha ya, 
\q2 site nʼime ya wepụta ngwa agha nke ọnụma ya. 
\q1 Nʼihi na Onyenwe anyị bụ \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile 
\q2 nwere ọrụ ọ ga-arụ nʼala Babilọn. 
\q1  
\v 26 Sitenụ nʼebe dị anya bịa buso ya agha. 
\q2 Kụkapunụ ọba ya niile, 
\q2 tụkọtanụ ha ọnụ dịka akpa ọka dị ukwuu, nke atụkọtara nʼelu ibe ha. 
\q1 Bibienụ ya kpamkpam, 
\q2 ka ihe ọbụla ghakwara ịfọdụrụ ya. 
\q1  
\v 27 Gbuonụ ụmụ oke ehi ya niile, 
\q2 ka ha niile gaa nʼebe ụlọ igbu anụ 
\q1 Ahụhụ na-adịrị ha, nʼihi na ụbọchị ahụ a kara aka banyere ha abịala, 
\q2 bụ oge a ga-eji taa ha ahụhụ. 
\q1  
\v 28 Geenụ ntị nʼihe ndị na-agbalaga na-ekwu, bụ ndị si na Babilọn na-agbapụ ọsọ. 
\q2 Ha na-ekwusa na Zayọn 
\q1 otu \nd Onyenwe anyị\nd* Chineke anyị si bọọ ọbọ, 
\q2 otu o si abọ ọbọ nʼihi ụlọnsọ ukwu ya. 
\b  
\q1  
\v 29 “Kpọkọtanụ ndị na-agba ụta maka imegide Babilọn, 
\q2 bụ ndị niile na-agba ụta. 
\q1 Maanụ ụlọ ikwu, gbaa ya gburugburu; 
\q2 unu ekwela ka onye ọbụla si nʼime ya gbapụ. 
\q1 Kwụghachi ya ụgwọ dịka ọrụ ya si dị, 
\q2 dịka ihe niile ahụ o mere si dị meenụ ya otu ahụ. 
\q1 Nʼihi na o buliela onwe ya elu megide \nd Onyenwe anyị\nd*, 
\q2 bụ Onye nsọ nke Izrel. 
\q1  
\v 30 Nʼihi ya, ụmụ okorobịa ya ga-ada nʼokporoụzọ ama niile. 
\q2 A ga-emekwa ka ndị agha ya niile dere duu nʼụbọchị ahụ.” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwubiri. 
\q1  
\v 31 “Lee, edoola m onwe m imegide gị, gị onye nganga.” 
\q2 Otu a ka Onyenwe anyị, bụ \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwubiri ya. 
\q1 “Nʼihi na ụbọchị gị abịala, 
\q2 bụ oge ahụ a ga-ata gị ahụhụ. 
\q1  
\v 32 Onye nganga ahụ ga-asọ ngọngọ daa, 
\q2 ma o nweghị onye ga-enyere ya aka ka o bilitekwa. 
\q1 Aga m esunye obodo ya niile ọkụ, 
\q2 nke ga-erechapụ ndị niile gbara ya gburugburu.” 
\p  
\v 33 Ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwuru: 
\q1 “A na-emegbu nnọọ ndị Izrel, 
\q2 nʼotu aka ahụkwa, ndị Juda. 
\q1 Ndị dọtara ha nʼagha jidesiri ha aka ike. 
\q2 Ha adịghị ahapụ ha ka ha laa. 
\q1  
\v 34 Ma Onye mgbapụta ha dị ike. 
\q2 \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile bụkwa aha ya. 
\q1 Ọ ga-eji ike ya niile kpepụta ọnụ ha, 
\q2 ime ka ala ha nweekwa izuike, 
\q2 ma meekwa ka ndị bi na Babilọn ghara inwe izuike. 
\b  
\q1  
\v 35 “Mma agha ga-ebili megide ndị Babilọn niile,” 
\q2 otu a ka \nd Onyenwe anyị\nd* kwupụtara, 
\q1 “na ndị ahụ niile bi na Babilọn 
\q2 ma megidekwa ndịisi ọchịchị niile na ndị ahụ niile maara ihe. 
\q1  
\v 36 Mma agha ga-ebili megide ndị amụma ụgha ha niile. 
\q2 Ha ga-aghọ ndị nzuzu. 
\q1 Mma agha ga-ebili megide ndị bụ dike nʼagha. 
\q2 Obi ha ga-ejupụtakwa nʼoke egwu. 
\q1  
\v 37 Mma agha ga-ebili megide ịnyịnya ha, na ụgbọ agha ha, 
\q2 na ndị mba ọzọ niile nọ nʼetiti ha. 
\q2 Ha ga-aghọkwa ndị inyom. 
\q1 Mma agha ga-ebilikwa megide akụ ha niile. 
\q2 A ga-alụta ha niile nʼagha. 
\q1  
\v 38 Okpomọkụ ga-abịakwasị mmiri ha niile 
\q2 mee ka ha taa. 
\q1 Nʼihi na ala ha bụ ala arụsị: 
\q2 arụsị ha niile ga-ayịkwa ara nʼihi oke egwu nke ga-abịakwasị ha. 
\b  
\q1  
\v 39 “Nʼihi ya, ọ bụ ụmụ anụmanụ nke ọzara, na nkịta ọhịa ga-ebi nʼebe ahụ. 
\q2 Ikwighịkwighị ga-ebikwa nʼebe ahụ. 
\q1 Mmadụ ọbụla agaghị ebikwa nʼime ya ọzọ. 
\q2 O nweghị onye ga-ebikwa nʼime ya site nʼọgbọ ruo nʼọgbọ. 
\q1  
\v 40 Dịka m si kwatuo Sọdọm na Gọmọra, 
\q2 ya na obodo niile gbara ya gburugburu,” 
\q2 otu a ka \nd Onyenwe anyị\nd* kwubiri ya. 
\q1 “Otu a kwa, ọ dịghị onye ọbụla ga-ebi nʼebe ahụ; 
\q2 nwa mmadụ ọbụla agakwaghị ebi nʼime ya.” 
\b  
\q1  
\v 41 “Lee, ndị agha si nʼala dị nʼebe ugwu na-abịa; 
\q2 mba dị ukwuu na ọtụtụ ndị eze 
\q2 ka a na-akpọlitekwa site na nsọtụ niile nke ụwa. 
\q1  
\v 42 Ha ji ọtụtụ ụta na ùbe; 
\q2 ha bụ ndị afọ tara mmiri, ndị na-enweghị obi ebere. 
\q1 Ha na-ebigbọ dịka mbigbọ nke osimiri, 
\q2 dịka ha na-anọkwasị nʼelu ịnyịnya ha. 
\q1 Ha na-abịa dịka ndị ikom e doro nʼusoro ibu agha, 
\q2 ibuso gị agha, Ada Babilọn. 
\q1  
\v 43 Eze Babilọn nụrụ akụkọ banyere ude ha, 
\q2 akụkọ mere ka ike gwụrụ aka ya abụọ kpamkpam. 
\q1 Oke ihe mgbu ejidela ya, 
\q2 ihe mgbu dịka nke nwanyị ime na-eme. 
\q1  
\v 44 Lee, dịka mgbe ọdụm na-esi nʼoke ọhịa Jọdan 
\q2 na-arịgopụta nʼebe ịta nri nke ụmụ anụmanụ jupụtara nʼahịhịa ndụ, 
\q1 nʼotu ntabi anya ka m ga-esi nʼala ya chụpụ Babilọn. 
\q2 Ma onye bụ onye ahụ a họpụtara, onye m ga-enyefe ọrụ a nʼaka? 
\q1 Onye dịka m? Onye kwa pụrụ ịpụta tụọ m aka nʼihu? 
\q2 Onye bụkwa onye ọzụzụ atụrụ ahụ nke pụrụ ido onwe ya megide m?” 
\b  
\q1  
\v 45 Nʼihi ya, nụrụ ihe \nd Onyenwe anyị\nd* kwadobere megide Babilọn, 
\q2 nụrụkwa ihe o zubere megide ala ndị Babilọn. 
\q1 A ga-adọkpụrụ ndị dị nta nʼetiti igwe ewu na atụrụ ahụ. 
\q2 Ebe ịta nri ha ga-anọ nʼọnọdụ mgbagwoju anya nʼihi nke a. 
\q1  
\v 46 Ụwa ga-ama jijiji mgbe ha nụrụ mkpọtụ ọdịda Babilọn, 
\q2 iti mkpu akwa ya ga-adakwa ụda nʼetiti mba niile dị iche iche. 
\c 51  
\p  
\v 1 Ihe ndị a ka \nd Onyenwe anyị\nd* kwuru, 
\q1 “Lee, aga m akpali mmụọ onye mbibi, 
\q2 ka ọ bịa megide Babilọn na ndị bi na Kaldịa. 
\q1  
\v 2 Aga m eziga ndị mba ọzọ nʼobodo Babilọn, 
\q2 ka ha gaa fụchaa ya, bibiekwa ala ya. 
\q1 Ha ga-emegide ya nʼakụkụ niile, 
\q2 nʼụbọchị ahụ ihe ọjọọ ga-abịakwasị ya. 
\q1  
\v 3 Ekwela ka onye na-agba ụta kwee ụta ya, 
\q2 ekwekwala ka o yikwasị uwe agha ya. 
\q1 Enwekwala ọmịiko nʼebe ụmụ okorobịa ya nọ, 
\q2 kama bibie usuu ndị agha ya kpamkpam. 
\q1  
\v 4 Ha ga-ada, bụrụ ndị e gburu egbu nʼime Babilọn, 
\q2 ha ga-abụ ndị e merụrụ oke ahụ nʼokporoụzọ niile. 
\q1  
\v 5 Ọ bụ ezie nʼala ha jupụtara nʼikpe ọmụma, 
\q2 nʼihu Onye nsọ nke Izrel, 
\q1 ma Chineke bụ \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile 
\q2 agbakụtabeghị ndị Izrel na Juda azụ. 
\b  
\q1  
\v 6 “Sinụ na Babilọn gbapụ ọsọ. 
\q2 Gbasienụ ọsọ ike nʼihi ndụ unu. 
\q2 Unu ekwela ka e bibie unu nʼihi mmehie ya. 
\q1 Oge ịbọ ọbọ \nd Onyenwe anyị\nd* eruola, 
\q2 ọ ga-akwụghachi ya ihe ruuru ya. 
\q1  
\v 7 Babilọn dị ka iko ọlaedo nʼaka \nd Onyenwe anyị\nd*. 
\q2 O mere ka ụwa niile si nʼiko ahụ ṅụbiga ihe ọṅụṅụ oke. 
\q1 Mba niile nke ụwa ṅụrụ mmanya ya. 
\q2 Ugbu a ha niile na-ayị ara. 
\q1  
\v 8 Na mberede, Babilọn ga-ada, a ga-etipịakwa ya. 
\q2 Kwasierenụ ya akwa ike. 
\q1 Wetanụ ọgwụ tee ya, 
\q2 ma eleghị anya ọnya ahụ ga-adị ya mma. 
\b  
\q1  
\v 9 “ ‘Anyị gaara agwọ Babilọn, 
\q2 ma ọrịa ji ya enweghị ngwọta. 
\q1 Ka anyị hapụnụ ya; ka anyị niile nʼotu nʼotu laghachi nʼobodo nke aka anyị, 
\q2 nʼihi na ikpe ọmụma dịrị ya eruola mbara eluigwe. 
\q2 Ọ na-arịgokwa ruo nʼigwe ojii.’ 
\b  
\q1  
\v 10 “ ‘\nd Onyenwe anyị\nd* emeela ka ezi omume anyị pụta ìhè. 
\q2 Ka anyị kwupụta 
\q2 ihe \nd Onyenwe anyị\nd* Chineke anyị mere na Zayọn.’ 
\b  
\q1  
\v 11 “Mụọnụ ọnụ àkụ unu; 
\q2 bulienụ ọta unu! 
\q1 \nd Onyenwe anyị\nd* akwaliela ndị eze ndị Midia, 
\q2 nʼihi na nzube ya bụ ịla Babilọn nʼiyi. 
\q1 \nd Onyenwe anyị\nd* ga-abọrọ onwe ya ọbọ, 
\q2 ọ ga-abọtara ụlọnsọ ukwu ya ọbọ. 
\q1  
\v 12 Bulienụ ọkọlọtọ nʼihi imegide mgbidi Babilọn. 
\q2 Tinyekwanụ ndị agha ọzọ nʼetiti ndị nche, ka ọnụọgụgụ ha hie nne 
\q1 Kwadoonụ ndị ga na-elepụ anya. 
\q2 Kwadoonụ ndị agha ga-ezo onwe ha, 
\q1 nʼihi na \nd Onyenwe anyị\nd* ga-eme ka ihe o zubere mezuo, 
\q2 bụ ihe ahụ o kpebiri megide ndị Babilọn. 
\q1  
\v 13 Unu bụ ndị bi nʼakụkụ ọtụtụ mmiri, 
\q2 ndị nwere akụnụba dị ukwuu, 
\q1 ọgwụgwụ unu abịaruola. 
\q2 Oge ahụ eruola mgbe e ji wezuga unu. 
\q1  
\v 14 \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile ji onwe ya ṅụọ iyi, sị, 
\q2 Nʼezie, aga m eme ka ndị mmadụ ọnụọgụgụ ha ga-aha ka igurube jupụta nʼime gị. 
\q2 Ha ga-etikwa mkpu ọṅụ megide gị. 
\b  
\q1  
\v 15 “O sitere nʼike ya mee ụwa; 
\q2 ọ tọrọ ntọala ụwa mee ka o guzosie ike site nʼamamihe ya, 
\q2 ọ jikwa nghọta ya setịpụ eluigwe niile. 
\q1  
\v 16 Mgbe o bigbọrọ, mmiri niile nke dị nʼeluigwe na-ebigbọkwa. 
\q2 Ọ na-eme ka igwe ojii site na nsọtụ niile nke ụwa kwụlie. 
\q1 Ọ na-ezipụ amụma mgbe mmiri na-ezo, 
\q2 na-esitekwa nʼụlọ nkwakọba ihe ya na-ewepụta ifufe. 
\b  
\q1  
\v 17 “Onye ọbụla bụ onye na-enweghị uche nke ihe ọmụma kọrọ. 
\q2 Emeela ka ihere mee onye ọkpụ ụzụ ọlaedo ọbụla site nʼarụsị ọ kpụrụ. 
\q1 Nʼihi na oyiyi niile ọ na-akpụ bụ aghụghọ; 
\q2 ha enweghị nkuume ọbụla nʼime ha. 
\q1  
\v 18 Ha bụ ihe efu, na ihe ịkwa emo, 
\q2 mgbe ikpe ọmụma ha bịakwasịrị ha, ha ga-ala nʼiyi. 
\q1  
\v 19 Ma onye ahụ bụ Oke Jekọb adịghị ka ihe ndị a, 
\q2 nʼihi na Ọ bụ ya na-eke ihe niile, 
\q1 tinyere Izrel bụ ebo nke ihe nketa ya. 
\q2 \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile bụ aha ya. 
\b  
\q1  
\v 20 “Ị bụ mkpọrọ osisi m ji ebu agha, 
\q2 na ngwa agha m ga-eji gaa nʼihu agha. 
\q1 Gị ka m ga-eji tipịa mba niile dị iche iche, 
\q2 gị ka m ga-eji laa alaeze niile nʼiyi; 
\q1  
\v 21 gị ka m ga-eji tipịa ịnyịnya na onye na-agba ya, 
\q2 gị ka m ga-eji tipịa ụgbọ agha na onye na-anya ya; 
\q1  
\v 22 gị ka m ga-eji tipịa nwoke na nwanyị, 
\q2 gị ka m ga-eji tipịa agadi nwoke na okorobịa, 
\q2 gị ka m ga-eji tipịa okorobịa na nwaagbọghọ, 
\q1  
\v 23 gị ka m ga-eji tipịa onye ọzụzụ atụrụ na igwe ewu na atụrụ ya, 
\q2 gị ka m ga-eji tipịa onye ọrụ ubi na ehi ya; 
\q2 gị ka m ga-ejikwa tipịa ndị na-achị achị na ndịisi ọchịchị eze. 
\p  
\v 24 “Nʼihu gị ka m ga-anọ kwụghachi Babilọn na ndị niile bi na Babilọn ihe ọjọọ niile ha mere na Zayọn,” ọ bụ ihe \nd Onyenwe anyị\nd* kwubiri. 
\q1  
\v 25 “Edoola m onwe m imegide gị, gị ugwu ukwu na-emebisi ihe, 
\q2 gị onye na-ala ụwa niile nʼiyi.” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwupụtara. 
\q1 “Aga m esetipụ aka m megide gị, 
\q2 kwapụ gị site na nkume dị elu. 
\q2 Aga m emekwa gị ka ị bụrụ ugwu ukwu e suru ọkụ. 
\q1  
\v 26 A gaghị esite nʼime gị weta nkume e ji ewu isi nkuku ụlọ, 
\q2 maọbụ nke e ji ewu ntọala ụlọ ọbụla, 
\q2 nʼihi na ị ga-abụ ebe tọgbọrọ nʼefu ruo mgbe ebighị ebi,” otu a ka \nd Onyenwe anyị\nd* kwubiri ya. 
\b  
\q1  
\v 27 “Bulienụ ọkọlọtọ elu nʼala ahụ. 
\q2 Fụọnụ opi ike nʼetiti mba niile. 
\q1 Kwadoonụ mba niile maka ibu agha megide ya; 
\q2 kpọkuonụ alaeze ndị a niile imegide ya: 
\q2 Ararat, na Mini, na Ashkenaz. 
\q1 Họpụtanụ ọchịagha ga-edu usuu ndị agha megide ya; 
\q2 ziganụ ịnyịnya ga-adị ukwuu nʼọnụọgụgụ, dịka igurube. 
\q1  
\v 28 Kwadoonụ mba niile maka ibu agha megide ha, 
\q2 kwadoonụ ndị eze Midia, 
\q1 na ndị ha na-achị achị, na ndịisi ọchịchị, 
\q2 na mba niile nke ha na-achị. 
\q1  
\v 29 Ala ahụ na-ama jijiji, na-atakwa ikikere eze nke ihe mgbu, 
\q2 nʼihi na nzube \nd Onyenwe anyị\nd* zubere megide Babilọn ga-emezu. 
\q1 Ọ ga-eme ka ala Babilọn ghọọ ebe tọgbọrọ nʼefu, 
\q2 ka mmadụ ọbụla gharakwa ibi nʼime ya. 
\q1  
\v 30 Ndị bụ dike nʼagha na Babilọn akwụsịla ịlụ ọgụ; 
\q2 ha anọgidela nʼebe ha e wusiri ike. 
\q1 Ike agwụla ha; 
\q2 ha adịla ka ndị inyom. 
\q1 E sunyela ebe obibi ya niile ọkụ, 
\q2 tijiekwa mkpọrọ e ji akpọchi ọnụ ụzọ ama ya niile. 
\q1  
\v 31 Otu onye na-agba ọsọ na-agbaso ọgba ọsọ ibe ya, 
\q2 otu onyeozi na-esochikwa onyeozi ọzọ nʼazụ; 
\q1 ha niile na-abịa izi eze Babilọn ozi sị ya 
\q2 na a dọtala obodo ya nʼagha, 
\q1  
\v 32 na ndị iro anọchiela ụzọ e si agafe iyi, 
\q2 na e sunyela ala mmiri mmiri niile ọkụ, 
\q2 na ndị agha niile na-amakwa jijiji.” 
\p  
\v 33 Ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, bụ Chineke Izrel kwuru, 
\q1 “Ada Babilọn dịka ebe ịzọcha ọka, 
\q2 nʼoge a na-azọcha ya. 
\q2 Mgbe a ga-ewe ya dịka e si ewe ihe ubi na-abịa nso.” 
\b  
\q1  
\v 34 “Nebukadneza eze Babilọn eripịala anyị, 
\q2 o tinyela anyị nʼọnọdụ mgbagwoju anya. 
\q2 O meela ka anyị dịrị ka ite ihe na-adịghị nʼime ya. 
\q1 O lodara anyị dịka ọ bụ agwọ ọjọọ, 
\q2 jiri ihe ụtọ anyị niile mejuo afọ ya. 
\q2 Emesịa, ọ gbọpụtara anyị. 
\q1  
\v 35 Ka ihe ike ahụ niile o mere anyị na ụmụ anyị dịkwasịkwa Babilọn nʼisi.” 
\q2 Ọ bụ ihe ndị bi na Zayọn kwuru. 
\q1 Jerusalem na-ekwukwa sị, 
\q2 “Ka ọbara anyị dịkwa nʼisi ndị bi na Babilọn.” 
\p  
\v 36 Nʼihi ya, ihe ndị a ka \nd Onyenwe anyị\nd* na-ekwu, 
\q1 “Lee, aga m ekwuchitere gị ọnụ gị, 
\q2 bọtakwara gị ọbọ. 
\q1 Aga m emekwa ka osimiri taa, 
\q2 meekwa ka isi iyi mmiri niile taakwa. 
\q1  
\v 37 Babilọn ga-aghọ mkpọmkpọ ebe, 
\q2 ọ ga-aghọ ebe obibi nke nkịta ọhịa, 
\q1 bụrụkwa ihe iju anya, na ihe nkọcha, 
\q2 na ebe mmadụ ọbụla na-agaghị ebikwa. 
\q1  
\v 38 Ndị ya niile na-agbọ ụja dịka ụmụ ọdụm, 
\q2 ha na-emekwa ụzụ dịka ụmụ ọdụm na-aṅụ ara. 
\q1  
\v 39 Ma nʼoge ahụ a kpaliri ha, 
\q2 aga m edo oriri nʼihu ha. 
\q2 Aga m eme ka ha ṅụbiga mmanya oke, 
\q1 si otu a mee ka ha jiri oke ịchị ọchị tie mkpu ọṅụ. 
\q2 Nʼikpeazụ, ha ga-arahụ ụra ebighị ebi, nke ha na-agaghị esite na ya bilie.” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwubiri. 
\q1  
\v 40 “Aga m akpụdata ha, 
\q2 dịka ụmụ atụrụ a na-aga igbu egbu, 
\q2 dịka ebule na mkpi. 
\b  
\q1  
\v 41 “Lee ka a ga-esi dọta Sheshak nʼagha, 
\q2 jichie ihe ụwa niile ji anya isi nʼagha. 
\q1 Lee ka Babilọn ga-esi ghọọ ihe tọgbọrọ nʼefu 
\q2 nʼetiti mba niile! 
\q1  
\v 42 Osimiri ga-eri Babilọn, 
\q2 mmali elu nke mmiri ya ga-ekpuchi ya. 
\q1  
\v 43 Obodo ya niile ga-atọgbọrọ nʼefu, 
\q2 ọ ga-abụ ebe kpọrọ nkụ, na ala ọzara, 
\q1 ọ ga-aghọ ala onye ọbụla na-agaghị ebi nʼime ya, 
\q2 nke mmadụ ọbụla na-agaghị esi nʼetiti ya gafee. 
\q1  
\v 44 Aga m ata Bel dị na Babilọn ahụhụ, 
\q2 mee ya ka ọ gbọpụta ihe ndị ahụ o loro. 
\q1 Mba dị iche iche agakwaghị agakwurukwa ya ọzọ. 
\q2 Mgbidi Babilọn ga-adakwa. 
\b  
\q1  
\v 45 “Sinụ nʼime ya pụta, unu ndị m! 
\q2 Gbapụnụ ọsọ nʼihi ndụ unu. 
\q2 Gbapụnụ ọsọ site nʼiwe dị ọkụ nke \nd Onyenwe anyị\nd*. 
\q1  
\v 46 Unu adala mba, unu atụkwala ụjọ, 
\q2 mgbe unu nụrụ akụkọ dị iche iche nʼala ahụ. 
\q1 Nʼihi na otu ụdị akụkọ ka a ga-anụ nʼafọ a, akụkọ ọzọ dị iche ka a ga-anụkwa nʼafọ nke ọzọ. 
\q2 A ga-anụ akụkọ iwusi ọbara nʼala ahụ, 
\q2 nụkwa akụkọ onye ọchịchị nke na-ebuso onye ọchịchị ọzọ agha. 
\q1  
\v 47 Nʼihi na oge ahụ aghaghị ịbịa 
\q2 mgbe m ga-ata arụsị niile dị na Babilọn ahụhụ. 
\q1 A ga-eme ka ihere mee ala ahụ niile. 
\q2 Ndị ya niile e gburu egbu ga-ada, tọgbọrọkwa nʼime ya, 
\q1  
\v 48 mgbe ahụ, eluigwe na ụwa, na ihe niile dị nʼime ha 
\q2 ga-eti mkpu ọṅụ nʼihi ihe dakwasịrị Babilọn. 
\q1 Ndị ga-ebuso ya agha 
\q2 ga-esitekwa nʼugwu bịa.” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwubiri. 
\b  
\q1  
\v 49 “Babilọn ga-ada nʼihi ndị Izrel e gburu, 
\q2 dịka ndị niile e gburu nʼụwa 
\q2 si daa site nʼaka ndị Babilọn. 
\q1  
\v 50 Unu ndị siterela nʼihu mma agha gbapụ ọsọ, 
\q2 wezuganụ onwe unu, unu eguzokwala. 
\q1 Chetanụ \nd Onyenwe anyị\nd* nʼala ahụ dị anya, 
\q2 na-echetakwa Jerusalem.” 
\b  
\q1  
\v 51 “Ihere emeela anyị, 
\q2 nʼihi na a kparịala anyị. 
\q2 Ihere ekpuchiekwala ihu anyị, 
\q1 nʼihi na ndị mba ọzọ abatala 
\q2 nʼebe nsọ nke ụlọnsọ \nd Onyenwe anyị\nd*.” 
\b  
\q1  
\v 52 “Ma ụbọchị ndị ahụ na-abịa,” ka \nd Onyenwe anyị\nd* kwupụtara, 
\q2 “mgbe m ga-ata arụsị ya niile ahụhụ. 
\q1 Ndị e merụrụ ahụ 
\q2 ga-asụkwa ude nʼala ahụ niile. 
\q1  
\v 53 A sịkwarị\f + \fr 51:53 \ft Maọbụ, \fqa asịgodu\f* na Babilọn a arịgoruo nʼeluigwe, 
\q2 ma a sịkwa na o wusie ebe dị elu nke ike ya mee ka o siwanyekwuo ike karịa, 
\q2 aga m ezite ndị mbibi ga-abịa megide ya.” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwubiri ya. 
\b  
\q1  
\v 54 “Ụzụ ịkwa akwa si na Babilọn na-apụta, 
\q2 ụzụ oke ịla nʼiyi 
\q2 sikwa nʼala ndị Babilọn na-apụta. 
\q1  
\v 55 \nd Onyenwe anyị\nd* ga-ala Babilọn nʼiyi. 
\q2 Ọ ga-emekwa ka oke ụzụ ha kwụsị. 
\q1 Mbigbọ nke ndị iro ga-adịkwa ka mbigbọ nke ọtụtụ mmiri, 
\q2 mkpọtụ nke olu ha ga-ada ụda dị ukwuu. 
\q1  
\v 56 Onye mbibi ga-ebuso Babilọn agha. 
\q2 A ga-adọta ndị bụ dike ya nʼagha, 
\q2 gbajisiekwa ụta ha niile. 
\q1 Nʼihi na \nd Onyenwe anyị\nd* bụ Chineke onye na-akwụghachi; 
\q2 ọ ga-akwụghachikwa nʼuju ya. 
\q1  
\v 57 Aga m eme ka ndịisi ọchịchị ya niile, na ndị maara ihe ha ṅụbiga mmanya oke; 
\q2 aga m emekwa ndị ha na-achị achị, na ndịisi ha, na ndị ha bụ dike nʼagha otu ihe ahụ. 
\q1 Ha ga-arahụ ụra ruo mgbe ebighị ebi. Ha agaghị esitekwa nʼụra ahụ bilie ọzọ.” 
\q2 Ọ bụ ihe Eze ahụ kwubiri, bụ onye ahụ aha ya bụ \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile. 
\p  
\v 58 Ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwuru, 
\q1 “A ga-akwada mgbidi Babilọn nke sara mbara, mee ka ọ daruo ala, 
\q2 a ga-eji ọkụ sunye nʼọnụ ụzọ ama ya niile dị elu. 
\q1 Ndị dị iche iche na-adọgbu onwe ha nʼọrụ nʼefu. 
\q2 Ndọgbu nʼọrụ nke mba niile dị iche iche ga-abụ nkụ a na-akwanye nʼọkụ.” 
\p  
\v 59 Ndị a bụ ozi Jeremaya, bụ onye amụma ziri onyeisi ozi aha ya bụ Seraya nwa Neraya, nwa Mahseia, mgbe o so Zedekaya eze Juda gaa Babilọn. E ziri ya ozi a nʼafọ nke anọ nke ọchịchị Zedekaya.  
\v 60 Jeremaya depụtara nʼakwụkwọ ihe banyere ihe ọjọọ ndị ahụ niile ga-abịakwasị Babilọn, ya bụ ihe niile e dere banyere Babilọn.  
\v 61 Ọ sịrị Seraya, “Mgbe i ruru Babilọn, lezie anya hụ na ị gụpụtara okwu ndị a niile ebe ndị mmadụ ga-anụ ya.  
\v 62 Emesịa, ị ga-ekwukwa sị, ‘\nd Onyenwe anyị\nd*, gị onwe gị ekwuola na i ga-ebibi ebe a, ma mmadụ maọbụ anụmanụ agaghị ebikwa nʼime ya. I kwuokwala na ọ ga-aghọ mkpọmkpọ ebe ruo mgbe ebighị ebi.’  
\v 63 Mgbe ị gụsịrị ihe dị nʼakwụkwọ a, kegide ya nkume, tụnye ya nʼetiti iyi ukwu Yufretis.  
\v 64 Ị ga-asịkwa, ‘Otu a ka Babilọn ga-esi mikpuo. Ọ gaghị ebilikwa ọzọ, nʼihi ihe ọjọọ ahụ m ga-eme ka ọ bịakwasị ya. Ndị ya ga-adakwa.’ ” 
\p Ebe a ka okwu Jeremaya niile gwụrụ. 
\b  
\c 52  
\s1 Ndọta nʼagha a dọtara Jerusalem 
\p  
\v 1 Zedekaya gbara iri afọ abụọ na otu mgbe ọ malitere ịbụ eze. Ọ chịrị dị ka eze na Jerusalem afọ iri na otu. Aha nne ya bụ Hamutal nwa Jeremaya, onye Libna.  
\v 2 O mere ihe jọrọ njọ nʼanya \nd Onyenwe anyị\nd* dịka Jehoiakim mere.  
\v 3 Ọ bụ nʼihi iwe \nd Onyenwe anyị\nd* ka ihe ndị a niile ji bịakwasị Jerusalem na Juda. Nʼikpeazụ, o sitere nʼihu ya chụpụ ha. 
\p Nʼoge a, Zedekaya nupuru isi nʼokpuru eze Babilọn. 
\p  
\v 4 Nʼihi ya, nʼafọ nke itoolu, nke ọchịchị Zedekaya, nʼụbọchị nke iri nʼọnwa nke iri, nke afọ ahụ, Nebukadneza, eze Babilọn, duuru usuu ndị agha ya niile bịa ibuso Jerusalem agha. Ha mara ụlọ ikwu ndị agha nʼazụ obodo ahụ, wuokwa mgbidi nnọchibido gburugburu obodo ahụ.  
\v 5 Anọchibidoro obodo a nʼagha ruo nʼafọ nke iri na otu nke ọchịchị eze Zedekaya. 
\p  
\v 6 Nʼabalị nke itoolu, nke ọnwa anọ nʼafọ ahụ, oke ụnwụ siri ike dị nʼobodo ahụ ruo na ọ dịkwaghị nri dị nke ndị mmadụ ga-eri.  
\v 7 Mgbe ahụ, e tipuru oghere nʼaja mgbidi obodo ahụ, ndị agha niile ji abalị gbapụ site nʼọnụ ụzọ ama nke dị nʼetiti mgbidi abụọ nʼakụkụ ubi eze a gbara ogige, nʼagbanyeghị na ndị Babilọn\f + \fr 52:7 \ft Maọbụ, \fqa Kaldịa\f* nọ obodo ahụ gburugburu. Ha gbapụrụ chee ihu nʼụzọ Araba.\f + \fr 52:7 \ft Ya bụ ndagwurugwu Jọdan\f* 
\v 8 Ma usuu ndị agha Babilọn\f + \fr 52:8 \ft Kaldịa dịkwa nʼamaokwu nke 14 na 17\f* chụsoro Zedekaya bụ eze nʼazụ, chụkwute ya na mbara ala Jeriko. Ndị agha ya niile sitere nʼebe ọ nọ gbasasịa, hapụ ya,  
\v 9 e jide ya. 
\p Ha kpụgara ya eze Babilọn, nʼobodo Ribla, nke dị nʼala Hamat, ebe a nọ maa ya ikpe.  
\v 10 Na Ribla ka eze Babilọn nọ gbuo ụmụ ndị ikom Zedekaya niile, nʼihu ya, o gbukwara ndịisi ọchịchị Juda niile.  
\v 11 Ọ ghụpụrụ anya Zedekaya abụọ, jiri ụdọ bronz kee ya agbụ, kpụrụ ya gaa Babilọn, ebe o tinyere ya nʼụlọ mkpọrọ tutu ruo ụbọchị ọnwụ ya. 
\p  
\v 12 Nʼụbọchị nke iri, nʼọnwa nke ise, nke afọ iri na itoolu, nke ọchịchị Nebukadneza eze Babilọn, Nebuzaradan ọchịagha ndị nche eze, onye na-ejere eze Babilọn ozi, bịarutere Jerusalem.  
\v 13 O sunyere ụlọnsọ \nd Onyenwe anyị\nd* ọkụ, ụlọeze na ụlọ niile dị na Jerusalem, ụlọ ọbụla bụ nke dị mkpa ka o surere ọkụ.  
\v 14 Usuu ndị agha Kaldịa niile bụ ndị nọ nʼokpuru onyeisi ndị nche eze ahụ, kwaturu mgbidi ahụ niile gbara Jerusalem gburugburu.  
\v 15 Nebuzaradan, ọchịagha ndị nche eze, buru ụfọdụ nʼime ndị dakarịsịrị nʼogbenye na ndị fọdụrụ nʼime obodo ahụ, ha na ndị ǹka niile fọdụrụ, na ndị ahụ ji aka ha gbakwuru eze Babilọn, bulaa ha Babilọn, ka ha ga biri nʼala ọzọ.  
\v 16 Ma Nebuzaradan, hapụrụ ndị ahụ bụ nnọọ ndị ogbenye ọnụ ntụ,\f + \fr 52:16 \ft Ya bụ ndị dakarịsịrị nʼogbenye\f* ka ha na-elekọta ubi vaịnị niile a gbara ogige na ala ubi niile. 
\p  
\v 17 Ma ndị Babilọn tipịara ogidi bronz niile, ha na ihe ndọkwasị niile na Oke osimiri bronz ndị ahụ dị nʼụlọnsọ \nd Onyenwe anyị\nd*, buru bronz ahụ niile bulaa Babilọn.  
\v 18 Ha chịkọọrọ ite niile, na shọvel niile na ihe ịkpakepụ ọkụ niile, na efere ịkwọsa mmiri niile, na ngaji ukwu niile, na ihe bronz niile, bụ nke e ji eje ozi nʼime ụlọnsọ ahụ.  
\v 19 Ọchịagha ndị nche eze ahụ sikwa nʼụlọnsọ ahụ chịrị ihe ndị a: efere ukwu niile, ihe ịgụnye ọkụ niile, efere ịkwọsa mmiri niile, ite niile, ihe ịdọkwasị oriọna niile, ngaji ukwu niile na iko e ji enye onyinye ihe ọṅụṅụ, ya bụ ihe ndị ahụ niile e ji ọlaedo a nụchara anụcha maọbụ ọlaọcha kpụọ. 
\p  
\v 20 O burukwara bronz sitere nʼogidi abụọ ahụ, oke Osimiri ahụ na ehi iri na abụọ e ji bronz kpụọ, bụ nke dị nʼokpuru ya, na ihe ndọkwasị ya niile, nke eze bụ Solomọn mere nʼihi ụlọnsọ \nd Onyenwe anyị\nd*. Ha karịrị ihe a ga-eji ihe ọtụtụ tụọ.  
\v 21 Ị dị elu nke otu nʼime ogidi abụọ ndị a bụ mita asatọ na ụma\f + \fr 52:21 \ft Iri nzọ ụkwụ abụọ na asaa\f* nʼọtụtụ. Ị dị gburugburu ya bụkwa mita ise na ụma anọ,\f + \fr 52:21 \ft Nzọ ụkwụ iri na asatọ\f* nke ọbụla nʼime ha bụ mkpịsịaka anọ. Oghere dịkwa nʼime ha.  
\v 22 Isi bronz nke e kpụkwasịrị nʼotu ogidi dị mita abụọ na ụma atọ\f + \fr 52:22 \ft Ya bụ nzọ ụkwụ asaa na ọkara\f* nʼịdị elu. Ọ bụkwa ihe yiri mkpụrụ pomegranet e ji bronz kpaa, ka e ji chọọ ya mma gburugburu ya niile. Ogidi nke abụọ nwekwara pomegranet, yiri ibe ya.  
\v 23 Pomegranet ndị ahụ dị iri itoolu na isii, ọ bụkwa nʼakụkụ ọbụla ka ọ dị. Ọnụọgụgụ pomegranet niile dị nʼelu ihe ahụ a kpụrụ akpụ dị otu narị. 
\p  
\v 24 Ọchịagha ndị nche eze ahụ, kpụụrụ Seraya, onyeisi nchụaja, na Zefanaya, bụ onye nchụaja na-esote ya nʼọkwa, na ndị nche atọ na-eche ọnụ ụzọ mbata dịka ndị mkpọrọ.  
\v 25 O sitere nʼetiti ndị ahụ fọdụrụ nʼobodo kpụụrụ otu onyeisi na-ahụ maka ndị agha, na ndị ikom asaa na-enye eze ndụmọdụ. O kpukwaara ode akwụkwọ, onye isi ọrụ na-ahụ maka ịmanye ndị ga-aga agha, jidekwa iri ndị ikom isii bụ ndị a hụrụ nʼime obodo ahụ.  
\v 26 Nebuzaradan, bụ ọchịagha kpụụrụ ha niile, dute ha nʼihu eze Babilọn na Ribla.  
\v 27 Nʼebe ahụ na Ribla, dị nʼobodo Hamat, ka eze nọ nye iwu ka e gbuo ha niile. 
\p Ya mere, a dọọrọ Juda nʼagha, mee ka ọ ga biri nʼala ọzọ. 
\b  
\li4  
\v 28 Nke a bụ ọnụọgụgụ ndị ahụ Nebukadneza mere ka ha gaa biri nʼala ọzọ. 
\b  
\li1 Nʼafọ nke asaa nke ọchịchị ya, 
\li2 puku atọ ndị Juu na iri abụọ na atọ, 3,023. 
\li1  
\v 29 Nʼafọ nke iri na asatọ nke ọchịchị Nebukadneza, 
\li2 ka o mere ka narị mmadụ asatọ na iri atọ na abụọ, 832 si na Jerusalem gaa biri nʼala ọzọ. 
\li1  
\v 30 Nʼafọ nke iri abụọ na atọ, 
\li2 Nebuzaradan, onyeisi ndị nche alaeze Babilọn bulara ndị dị narị ndị Juu asaa na iri anọ na ise, 745 ka ha ga biri nʼala ọzọ. 
\b  
\li4 Ọnụọgụgụ ha niile dị puku anọ na narị isii, 4,600. 
\s1 Jehoiakin enwere onwe ya 
\p  
\v 31 Nʼafọ nke iri atọ na asaa, site na mgbe e mere ka Jehoiakin eze Juda gaa biri nʼala ọzọ, nʼafọ Awel-Maduk ghọrọ eze Babilọn. Mgbe ahụ, o mere ka Jehoiakin eze Juda, si nʼụlọ mkpọrọ pụta, nwere onwe ya. O mere nke a nʼụbọchị iri abụọ na ise nke ọnwa iri na abụọ.  
\v 32 Ọ gwara ya okwu ọma, nyekwa ya ọnọdụ ugwu dị elu karịa ọnọdụ ndị eze ndị ọzọ niile ha na ya nọ na Babilọn.  
\v 33 Nʼihi nke a, Jehoiakin gbanwere uwe mkpọrọ ya, wezuga ya. Sitekwa nʼoge ahụ tutu ruo mgbe ọ nwụrụ, ya na eze na-erikọ nri.  
\v 34 Site nʼụbọchị ruo nʼụbọchị, eze Babilọn na-enye Jehoiakin oke ihe ruru ya kwa ụbọchị niile nke ọ dị ndụ, ruokwa nʼụbọchị ọnwụ ya.