\id GAL - Biblica® Open Kurdi Sorani Standard Version
\h گەلاتیا
\toc1 نامەی پۆڵس بۆ کڵێساکانی گەلاتیا
\toc2 گەلاتیا
\toc3 گەلاتیا
\mt1 نامەی پۆڵس بۆ کڵێساکانی گەلاتیا
\c 1
\p 
\v 1 لە پۆڵسەوە، ئەوەی نە لەلایەن خەڵک و نە بەهۆی مرۆڤێکەوە نێردراوە، بەڵکو لەلایەن عیسای مەسیح و خودای باوکەوە، کە لەنێو مردووان هەڵیستاندەوە،
\v 2 هەروەها هەموو ئەو برایانەی لەگەڵمدان،
\b
\p بۆ ئەو کڵێسایانەی لە گەلاتیان:
\b
\p 
\v 3 با نیعمەت\f + \fr 1:3 \ft نیعمەت بەخشینێکی خودایە بە مرۆڤ بەبێ شایستەبوونی پێی دەبەخشێت.\f* و ئاشتی لە خودای باوکمان و عیسای مەسیحی خاوەن شکۆوە لەگەڵتان بێت،
\v 4 ئەوەی لە پێناوی گوناهەکانمان خۆی بەخشی، تاکو بەگوێرەی خواستی خودای باوکمان، لەم دنیایە خراپەی ئێستا ڕزگارمان بکات.
\v 5 هەتاهەتایە شکۆمەندی بۆ ئەوە. ئامین.
\b
\s1 مژدەیەکی دیکە نییە
\p 
\v 6 پێم سەیرە چۆن وا بە خێرایی، لەوەی بە نیعمەتی مەسیح بانگی کردوون، بۆ مزگێنییەکی دیکە\f + \fr 1:6 \ft مەبەست لە مژدەیەکی جیاوازە.‏\f* وەردەگەڕێن!
\v 7 مزگێنییەکی دیکە بوونی نییە، بەڵکو هەندێک کەس دەیانەوێت سەرتان لێ بشێوێنن و پەیامی مزگێنیی مەسیح بگۆڕن.
\v 8 بەڵام تەنانەت ئەگەر ئێمە یان فریشتەی ئاسمان مزگێنییەکمان پێدان، جگە لەو مزگێنییەی ئێمە پێمان دان، با نەفرەتی لێ بێت.
\v 9 وەک پێشتر پێمان گوتوون ئێستاش پێتان دەڵێمەوە: ئەگەر کەسێک مزگێنییەکی پێدان جگە لەوەی پەسەندتان کردووە، با نەفرەتی لێ بێت.
\p 
\v 10 ئایا ئێستا بۆ بەدەستهێنانی ڕەزامەندی خەڵک هەوڵ دەدەم، یاخود ڕەزامەندی خودا؟ یان ئایا داوای ئەوە دەکەم خەڵک ڕازی بکەم؟ ئەگەر هەتا ئێستا خەریکی ڕازیکردنی خەڵک بوومایە، ئەوا نەدەبوومە بەندەی مەسیح.
\s1 چۆن پۆڵس بوو بە نێردراو؟
\p 
\v 11 پێتان دەڵێم، خوشکان، برایان، ئەو پەیامەی ئینجیل\f + \fr 1:11 \fq پەیامەی ئینجیل \ft دەربڕینی پەیامی ئینجیل کە لێرەدا بەکارهاتووە هەمان وشەی مزگێنییە کە لە ئایەتەکانی 7، 8، 9 بەکارهاتووە.\f* کە جاڕم بۆی داوە، لە مرۆڤەوە نییە.
\v 12 لە کەسیشم وەرنەگرتووە و فێریش نەکراوم، بەڵکو بە ئاشکراکردنی عیسای مەسیح وەرمگرتووە.
\p 
\v 13 بێگومان سەربوردەی منتان بیستووە لە جولەکایەتی، کە چۆن دڕندانە کڵێسای خودام چەوساندەوە و هەوڵم دا لەناوی ببەم.
\v 14 لە جولەکایەتی پێش زۆربەی خەڵک کەوتم لە نەوەی خۆم، زۆر دڵگەرمتر بووم لەوان بۆ دابونەریتی باوکان.
\v 15 بەڵام کاتێک خودا کە لە سکی دایکمەوە تەرخانی کردم، بە نیعمەتی خۆی بانگی کردم، خۆشحاڵ بوو
\v 16 کوڕەکەی لە مندا دەربکەوێت، تاکو لەناو نەتەوە ناجولەکەکاندا مژدە بدەم. لەو کاتەدا دەستبەجێ ڕاوێژم بە کەس نەکرد،
\v 17 سەرنەکەوتمە ئۆرشەلیم بۆ لای ئەوانەی پێش من نێردراو بوون، بەڵکو ڕۆیشتم بۆ عەرەبستان و دیسان گەڕامەوە دیمەشق.
\p 
\v 18 ئینجا دوای سێ ساڵ سەرکەوتمە ئۆرشەلیم، بۆ ئەوەی پەترۆس\f + \fr 1:18 \ft یۆنانی: \tl کێفاس‏\tl*.‏\f* بناسم، پازدە ڕۆژ لای ئەو مامەوە.
\v 19 بەڵام جگە لە یاقوبی برای عیسای خاوەن شکۆ هیچ نێردراوێکی دیکەم نەبینی.
\v 20 خودا دەزانێت ئەوەی بۆتان دەنووسم درۆ نییە.
\p 
\v 21 دوایی چوومە هەرێمەکانی سوریا و کیلیکیا،
\v 22 بەڵام هێشتا لەلای کڵێساکانی یەهودیا کە سەر بە مەسیحن\f + \fr 1:22 \fq سەر بە مەسیحن \ft لە زمانی یۆنانیدا (لە مەسیحدا) بەکارهاتووە.‏\f* بە ڕوخسار نەناسراو بووم،
\v 23 تەنها بیستبوویان: «ئەوەی جاران ئێمەی دەچەوساندەوە، ئێستا مژدەی ئەو باوەڕە دەدات، کە جاران لەناوی دەبرد.»
\v 24 ئیتر بەهۆی منەوە ستایشی خودایان دەکرد.
\c 2
\s1 ڕازیبوون بە خزمەتی پۆڵس
\p 
\v 1 دوای چواردە ساڵ لەگەڵ بەرناباس گەڕامەوە ئۆرشەلیم و تیتۆسیشم لەگەڵ خۆم برد.
\v 2 گەڕانەوەکەم بەگوێرەی ئاشکراکردنێک بوو و ئەو پەیامەی ئینجیل کە لەنێو نەتەوەکان جاڕی دەدەم، تەنها خستمە بەردەم گەورە پیاوانی کڵێسا، تاکو ئەوەی بۆی ڕادەکەم و ڕامکردووە بەفیڕۆ نەڕوات.
\v 3 بەڵام هەرچەندە تیتۆس کە لەگەڵم بوو یۆنانی بوو، زۆریان لێ نەکرد خەتەنە بکرێت.
\v 4 ئەم بابەتە لەوەوە سەری هەڵدا کە هەندێک لە برایانی درۆزن بە نهێنی هاتبوونە ناومان بۆ سیخوڕیکردن لەسەر ئەو ئازادییەی لە عیسای مەسیحدا هەمانە، تاکو بمانکەنە کۆیلە.
\v 5 بۆ کاتژمێرێکیش ملکەچیان نەبووین، تاکو ڕاستی ئینجیل لەگەڵتان بمێنێتەوە.
\p 
\v 6 بەڵام ئەوانەی بە گەورە پیاو دادەنران، هەرچییەک بن، بەلای منەوە گرنگ نییە، چونکە خودا تەماشای ڕواڵەتی مرۆڤ ناکات، ئەوان هیچیان بۆ پەیامەکەم زیاد نەکرد.
\v 7 بەڵکو بە پێچەوانەوە، بینییان کە پەیامی ئینجیل بۆ ناجولەکەکان\f + \fr 2:7 \ft یۆنانی: خەتەنەنەکراوان.‏\f* بە من سپێردراوە، هەروەک پەیامی ئینجیل بۆ جولەکەکان بە پەترۆس سپێردراوە،
\v 8 چونکە خودا بەهۆی پەترۆسەوە وەک نێردراو بۆ جولەکەکان کاری دەکرد، لە منیشدا بۆ ناجولەکەکان کاری دەکرد.
\v 9 کاتێک یاقوب و پەترۆس و یۆحەنا کە بە کۆڵەکە دانرابوون، بەم نیعمەتەیان زانی کە بە من دراوە، ئەوسا ئەوان دەستی ڕاستی هاوبەشییان بۆ من و بەرناباس درێژکرد، تاکو ئێمە بۆ لای نەتەوەکان بچین و ئەوانیش بۆ لای جولەکەکان بچن.
\v 10 تەنها داوایان کرد هەژاران لەیاد نەکەین، ئەمەش شتێکە هەمیشە کۆششم بۆی کردووە.
\s1 سەرزەنشتکردنی پەترۆس
\p 
\v 11 بەڵام کاتێک پەترۆس هاتە ئەنتاکیا، ڕووبەڕوو بەربەرەکانێم کرد، لەبەر ئەوەی گلەیی لەسەر بوو،
\v 12 چونکە پێش ئەوەی کەسانێک لەلای یاقوبەوە بێن، ئەو لەگەڵ ناجولەکەکان نانی دەخوارد، بەڵام کاتێک ئەوان هاتن، لە ترسی ئەو تاقمەی کە دەڵێن دەبێ باوەڕدار خەتەنە بکرێت\f + \fr 2:12 \ft ڕێبازەکە دەڵێت کە بێ خەتەنەکردن مرۆڤ ڕزگاری نابێت.‏\f*، خۆی کێشایەوە.
\v 13 جولەکەکانی دیکەش لەگەڵیدا دەستیان بە دووڕوویی کرد، تەنانەت بەرناباسیش بە دووڕووییان چەواشە بوو.
\p 
\v 14 کاتێک بینیم بەگوێرەی ڕێگای ڕاستی پەیامی ئینجیل ناڕۆن، لەبەرچاوی هەمووان بە پەترۆسم گوت: «ئەگەر تۆ جولەکەی، وەک ناجولەکە دەژیت نەک وەکو جولەکە، ئیتر چۆن ناجولەکەکان ناچار دەکەیت نەریتی جولەکەکان پەیڕەو بکەن؟
\p 
\v 15 «ئێمە بە جولەکەیی لەدایک بووین و لە نەتەوە گوناهبارەکان نین،
\v 16 دەزانین مرۆڤ بە کارکردن بە شەریعەت بێتاوان ناکرێ، بەڵکو بە باوەڕ بە عیسای مەسیح. جا ئێمە باوەڕمان بە عیسای مەسیح هێنا تاکو بە باوەڕ بە مەسیح بێتاوان بکرێین، ئەمەش نەک بە کارکردن بە شەریعەت، چونکە لە ڕێی کارکردن بە شەریعەت کەس بێتاوان ناکرێت.
\p 
\v 17 «بەڵام ئەگەر ئێمە لە هەوڵدانمان بۆ بێتاوانبوون بە مەسیح، خۆمان دۆزییەوە کە گوناهبارین، ئیتر ئایا مەسیح خزمەتکاری گوناهە؟ بێگومان نەخێر!
\v 18 ئەگەر من شتێک بنیاد بنێمەوە کە لەپێشدا تێکمدابێت، ئەوا دەیسەلمێنم سەرپێچیکارم.
\p 
\v 19 «چونکە لە ڕێگەی شەریعەت بۆ شەریعەت مردم، تاکو بۆ خودا بژیم.
\v 20 من لەگەڵ مەسیح لە خاچ درام، ئیتر من نیم ئەوەی دەژیێت، بەڵکو مەسیحە لە مندا دەژیێت. ئێستاش کەوا بە جەستە دەژیم، ئەوا بە باوەڕ بە کوڕی خودا دەژیم، ئەوەی منی خۆشویست و خۆی کردە قوربانی بۆ من.
\v 21 من نیعمەتی خودا پووچەڵ ناکەمەوە، چونکە ئەگەر بێتاوانبوون بە شەریعەت بووایە، ئەوا مردنی مەسیح بێ سوود دەبوو.»
\c 3
\s1 باوەڕ یان بەجێگەیاندنی شەریعەت؟
\p 
\v 1 ئەی گەلاتیاییە گێلەکان! کێ جادووی لێکردوون؟ لەپێش چاوتان وێنەی عیسای مەسیح بە لە خاچ دراوی کێشرا!
\v 2 تەنها دەمەوێ ئەوەتان لێ فێربم: ئایا بەهۆی کارکردن بە شەریعەت ڕۆحی پیرۆزتان وەرگرت، یاخود بەهۆی باوەڕ بەوەی بیستتان؟
\v 3 ئایا هەتا ئەم ڕادەیە گێلن؟ ئێوە کە بەهۆی ڕۆحی پیرۆزەوە دەستتان پێکرد، ئایا ئێستا دەتانەوێت بەهۆی جەستەوە کۆتایی پێ بهێنن؟
\v 4 ئایا لەخۆڕایی ئەوەندە ئازارتان چێژت؟ ئایا بەڕاستی لەخۆڕایی بوو؟
\v 5 ئەوەی ڕۆحتان پێ دەبەخشێت و لەنێوانتاندا پەرجوو دەکات، ئایا بەهۆی کارکردنە بە شەریعەت، یاخود بەهۆی باوەڕە بەوەی بیسترا؟
\v 6 وەک چۆن ئیبراهیم ﴿باوەڕی بە خودا هێنا و ئەمەشی بە ڕاستودروستی بۆ دانرا.﴾\f + \fr 3:6 \ft \xt پەیدابوون 15‏:6.‏\xt*\ft ‏\f*
\p 
\v 7 جا بزانن ئەوانەی لە باوەڕدان، نەوەی ئیبراهیمن.
\v 8 نووسراوە پیرۆزەکە پێشتر بینیویەتی کە خودا نەتەوەکان بەهۆی باوەڕ بێتاوان دەکات، پێشتر مژدەی بە ئیبراهیم دا، پێی فەرموو: ﴿هەموو نەتەوەکان لە ڕێگەی تۆوە بەرەکەتدار دەبن.﴾\f + \fr 3:8 \ft \xt پەیدابوون 12‏:3‏؛ 18‏:18 و 22‏:18.‏\xt*\ft ‏\f*
\v 9 کەواتە ئەوانەی باوەڕدارن، لەگەڵ ئیبراهیمی باوەڕدار بەرەکەتدار دەبن.
\p 
\v 10 هەموو ئەوانەی پشت بە کرداری شەریعەت دەبەستن، لەژێر نەفرەتن، چونکە نووسراوە: ﴿هەرکەسێک لە هەموو نووسراوی پەڕتووکەکانی تەورات نەچەسپێت بۆ پەیڕەوکردن، نەفرەت لێکراوە.﴾\f + \fr 3:10 \ft \xt دواوتار 27‏:26‏\xt*\ft .‏\f*
\v 11 ئاشکرایە لە بەرامبەر خودا کەس بە شەریعەت بێتاوان ناکرێت، چونکە: ﴿ئەوەی ڕاستودروستە بە باوەڕ دەژیێت.\f + \fr 3:11 \ft بە واتای: ئەو کەسەی کە بە باوەڕ بێتاوان دەکرێت و ڕاستودروست دەبێت، بەهۆی باوەڕەکەی دەژیێت.‏\f*‏﴾\f + \fr 3:11 \ft \xt حەبەقوق 2‏:4‏\xt*\ft .‏\f*
\v 12 بەڵام شەریعەت پشت بە باوەڕ نابەستێت، بەڵکو: ﴿ئەو کەسەی پەیڕەویان بکات، بەهۆیانەوە دەژیێت.﴾\f + \fr 3:12 \ft \xt لێڤییەکان 18‏:5.‏\xt*\ft ‏\f*
\v 13 مەسیح ئێمەی لە نەفرەتی شەریعەت کڕییەوە، بەوەی لە پێناوماندا بووە نەفرەت، چونکە نووسراوە: ﴿هەرکەسێک لەسەر دار هەڵبواسرێت نەفرەت لێکراوە.﴾\f + \fr 3:13 \ft \xt دواوتار 21‏:23‏\xt*\ft .‏\f*
\v 14 ئەو ئێمەی کڕییەوە بۆ ئەوەی لە ڕێگەی عیسای مەسیحەوە بەرەکەتی ئیبراهیم بۆ نەتەوەکان بێت، تاکو بەهۆی باوەڕەوە بەڵێنی ڕۆحی پیرۆز بەدەستبهێنین.
\s1 پەیمانی خودا و شەریعەت
\p 
\v 15 خوشکان، برایان، با نموونەیەکی مرۆڤانەتان بۆ بهێنمەوە: ئەگەر یەکێک پەیمانێکی مۆرکراوی پێ بێت، کەس ناتوانێت بەتاڵی بکاتەوە یاخود شتێکی بخاتە سەر.
\v 16 هەروەک بەڵێنەکان بۆ ئیبراهیم و نەوەکەی گوتراوە. نووسراوە پیرۆزەکە نافەرموێت: «بە نەوەکان» وەک ئەوەی زۆر بن، بەڵام ﴿بە نەوەی تۆ،﴾\f + \fr 3:16 \ft \xt پەیدابوون 12‏:7‏\xt*\ft ‏ (ئەم زەوییە دەدەمە نەوەی تۆ.)، کاتێک خودا بەڵێن بە ئیبراهیم دەدات.‏\f* واتا یەک، ئەوەی مەسیحە.
\v 17 مەبەستم ئەمەیە: ئەو شەریعەتەی پاش چوار سەد و سی ساڵ هات، پەیمانی چەسپاوی پێشووی خودا هەڵناوەشێنێتەوە، تاکو بەڵێنەکە بشکێنێت،
\v 18 چونکە ئەگەر میرات بەهۆی شەریعەتەوە هەبێت، ئیتر بەهۆی بەڵێنەوە نییە. بەڵام خودا بە نیعمەتی خۆی بەڵێنی بە ئیبراهیم دا.
\s1 مەبەستی شەریعەت
\p 
\v 19 کەواتە شەریعەت بۆ چییە؟ بەهۆی پێشێلکردنەکانەوە زیادکراوە، هەتا ئەو کاتەی نەوەی بەڵێندراو\f + \fr 3:19 \ft مەبەست لە مەسیحە.‏\f* دێت، لە ڕێگەی فریشتەکانەوە بە دەستی پەیوەندی ڕێکخەرێک\f + \fr 3:19 \ft مەبەست لە موسایە.‏\f* ڕێکخرا.
\v 20 پەیوەندی ڕێکخەر تەنها نوێنەری یەک لایەن نییە، بەڵام خودا یەکە.
\p 
\v 21 ئایا تەورات لە دژی بەڵێنەکانی خودایە؟ حاشا! چونکە ئەگەر شەریعەتێک هەبووایە بتوانێت ژیان ببەخشێت، ئەوا ڕاستودروستی بە شەریعەتی تەورات دەبوو.
\v 22 بەڵام نووسراوە پیرۆزەکە هەمووی کردووەتە بەندی گوناه،\f + \fr 3:22 \ft بۆ نموونە \xt زەبوورەکان 14‏:3.‏\xt*\ft ‏\f* تاکو ئەو بەڵێنەی لە ڕێگەی عیسای مەسیحەوە و بەهۆی باوەڕەوە دراوە، بۆ ئەوانە بێتە دی کە باوەڕ دەهێنن.
\p 
\v 23 پێش ئەوەی باوەڕ بێت، لەلایەن تەوراتەوە بەند کرابووین، لە ژوورەوە کرابووین هەتا ئاشکراکردنی باوەڕەکەی داهاتوو.
\v 24 تەورات پەروەردەی دەکردین تاکو بمانهێنێت بۆ لای مەسیح، بۆ ئەوەی بە باوەڕ بێتاوان بکرێین.
\v 25 بەڵام دوای هاتنی باوەڕ، ئێمە ئیتر لەژێر سایەی تەمبێکار نین.
\s1 ڕۆڵەکانی خودا
\p 
\v 26 هەمووتان لە ڕێگەی باوەڕەوە ڕۆڵەی خودان، بەو یەکبوونەی کە لەگەڵ عیسای مەسیحدا هەتانە،
\v 27 چونکە کاتێک لە ئاو هەڵکێشران، هەمووتان لەگەڵ مەسیح یەکتانگرت\f + \fr 3:27 \fq لەگەڵ مەسیح یەکتانگرت \ft لە زمانی یۆنانیدا (لە مەسیحدا) بەکارهاتووە.‏\f* و مەسیحتان وەک جلوبەرگێک لەبەرکرد.
\v 28 جولەکە و ناجولەکە نییە، کۆیلە و ئازاد نییە، ژن و پیاو نییە، چونکە هەمووتان بەهۆی یەکبوونتان لەگەڵ عیسای مەسیح، یەکن.
\v 29 جا ئەگەر ئێوە هی مەسیح بن، ئەوا لە نەوەی ئیبراهیمن و بەگوێرەی بەڵێنەکە میراتگرن.
\c 4
\p 
\v 1 دەمەوێت ئەمەتان پێ بڵێم: ئەگەر میراتگر ناکام بێت جیاوازیی نابێت لەگەڵ کۆیلە، هەرچەندە میراتگرەکە خاوەنی هەموو میراتەکەیە،
\v 2 بەڵام لەژێر دەسەڵاتی سەرپەرشتیکار و سەرکاردا دەمێنێتەوە هەتا ئەو ماوەیەی کە باوکی دیاریی کردووە.
\v 3 ئێمەش بە هەمان شێوە، کاتێک ناکام بووین کۆیلەی دەستی بنەما سەرەکییەکانی جیهان بووین.
\v 4 بەڵام کە کاتی تەواوی خۆی هات، خودا کوڕی خۆی نارد، لە ژنێک لەدایک بوو، لە سایەی شەریعەتی تەورات لەدایک بوو،
\v 5 بۆ ئەوەی ئەوانە بکڕێتەوە کە لە سایەی شەریعەتدان، تاکو وەک ڕۆڵە لەخۆگرتنەوە\f + \fr 4:5 \ft منداڵی کەسێکی دیکە وەک منداڵی خۆی پەروەردە دەکات و هەموو مافەکانی پێدەدات.‏\f* بەدەستبهێنین.
\v 6 لەبەر ئەوەی ئێوە ڕۆڵەی خودان، خودا ڕۆحی کوڕەکەی خۆی ناردە دڵتانەوە، بە هاوارەوە دەیفەرموو: «بابە! باوکە!»
\v 7 کەواتە ئیتر کۆیلە نیت، بەڵکو ڕۆڵەی ئەویت، ئەگەر ڕۆڵەش بیت، ئەوا خودا تۆی کردووەتە میراتگر.
\s1 سەرسوڕمانی پۆڵس
\p 
\v 8 بەڵام ئەو کاتەی کە خوداتان نەدەناسی، کۆیلەی ئەوانە بوون کە بە سروشت خودا نین.
\v 9 بەڵام ئێستا خودا دەناسن، ڕاستتریش لەلای خوداوە ناسران، ئایا چۆن دیسان دەگەڕێنەوە لای بنەما سەرەکییە لاواز و هەژارەکان؟ ئایا دەتانەوێ سەرلەنوێ ببنەوە کۆیلەی ئەوانە؟
\v 10 ئایا بایەخ بە ڕۆژ و مانگ و وەرز و ساڵی تایبەت دەدەن؟
\v 11 دەترسم بەخۆڕایی لە پێناوتان ماندووبووبم.
\p 
\v 12 خوشکان، برایان، لێتان دەپاڕێمەوە، وەکو من بن، چونکە من خۆم وەکو ئێوەم لێهات. هەڵەتان لەگەڵم نەکردووە.
\v 13 هەروەک دەزانن بەهۆی نەخۆشییەکەمەوە بوو کە یەکەم جار مژدەم پێدان،
\v 14 نەخۆشییەکەم تاقیکردنەوەیەکی ئاسان نەبوو بۆتان، بەڵام بە چاوێکی سووک سەیرتان نەکردم و ڕقتان لێم نەبووەوە، بەڵکو وەک فریشتەی خودا، وەک عیسای مەسیح پێشوازیتان لێکردم.
\v 15 ئەو خۆشییەتان چی بەسەرهات؟ چونکە شایەتیتان بۆ دەدەم ئەگەر بتانتوانیایە چاوی خۆتان دەردەهێنا و دەتاندامێ.
\v 16 ئایا ئێستا بوومەتە دوژمنی ئێوە، چونکە ڕاستیتان پێ دەڵێم؟
\p 
\v 17 ئەوانەی کە دڵگەرمن بۆ ئێوە، نیازیان باش نییە، چونکە دەیانەوێت لە ئێمەتان بترازێنن تاکو بۆ ئەوان دڵگەرم بن.
\v 18 دڵگەرمی شتێکی باشە، ئەگەر هەموو کاتێک بە مەبەستێکی پاک بێت، نەک تەنها ئەو کاتەی من لەگەڵتانم.
\v 19 ڕۆڵە خۆشەویستەکانم، جارێکی دیکە لە پێناوتاندا ژانی منداڵبوون دەچێژم، هەتا وێنەی مەسیح لە ژیانتاندا بەرجەستە دەبێت،
\v 20 بەڵام دەمویست ئێستا لەگەڵتان بم، بۆ ئەوەی بە شێوەیەکی دیکە لەگەڵتان بدوێم، چونکە سەرم لە ئێوە سوڕماوە.
\s1 نموونەی هاجەر و سارا
\p 
\v 21 ئەی ئەوانەی حەز دەکەن لەژێر سایەی شەریعەتدا بن، پێم بڵێن، ئایا تەورات نابیستن؟
\v 22 چونکە نووسراوە کە ئیبراهیم دوو کوڕی هەبووە، یەکێکیان لە کۆیلەکە، ئەوی دیکەیان لە ئازادەکە\f + \fr 4:22 \ft بڕوانە پەیدابوون بەشەکانی 16 و 21.‏\f*.
\v 23 ئەوەی لە کۆیلەکە بوو بەگوێرەی جەستە لەدایک بوو، بەڵام ئەوەی لە ئازادەکە، بە بەڵێن بووە.
\p 
\v 24 هەموو ئەمانەش هێمان، چونکە ئەو دوو ژنە دوو پەیمانەکەن، یەکێکیان لە شاخی سیناوەیە، بۆ کۆیلایەتی منداڵی دەبێت، ئەوەش هاجەرە.
\v 25 هاجەر هێمایە بۆ شاخی سینا لە عەرەبستان، ئەو ئۆرشەلیمەی ئێستا دەنوێنێت، ئەویش لەگەڵ منداڵەکانی کۆیلەن.
\v 26 بەڵام ئۆرشەلیمی سەرەوە ئازادە، دایکی ئێمەیە،
\v 27 چونکە نووسراوە:
\q1 ﴿ئەی نەزۆک، دڵشادبە،
\q2 ئەی ئەوەی منداڵت نەبووە،
\q1 ئەی ئەوەی ژانت نەگرتووە،
\q2 لە خۆشیدا بە دەنگی بەرز هاوار بکە،
\q1 چونکە منداڵی ژنی بەجێهێڵراو\f + \fr 4:27 \ft ژنی بەجێهێڵراو: دەربڕینێکی مەجازییە مەبەستی لە ئۆرشەلیمی ئاسمانییە، بڕوانە \xt عیبرانییەکان 12‏:22.‏\xt*\ft ‏\f* زیاترن
\q2 لەوەی مێردی لەگەڵیەتی.﴾\f + \fr 4:27 \ft \xt ئیشایا 54‏:1.‏\xt*\ft ‏\f*
\p 
\v 28 بەڵام ئێوە، خوشکان و برایان، وەک ئیسحاق منداڵی بەڵێنن.
\v 29 جا چۆن لە کاتێکدا ئەوەی بەگوێرەی جەستە لەدایک بوو، ئەوەی چەوساندەوە کە بەگوێرەی ڕۆحی پیرۆز لەدایک ببوو، ئێستاش ئاوایە.
\v 30 بەڵام نووسراوە پیرۆزەکە چی دەفەرموێ؟ ﴿کەنیزەکە و کوڕەکەی دەربکە، چونکە کوڕی کەنیزەکە لەگەڵ کوڕی ئازادەکە نابێتە میراتگر.﴾\f + \fr 4:30 \ft \xt پەیدابوون 21‏:10.‏\xt*\ft ‏\f*
\v 31 کەواتە ئەی خوشک و برایان، ئێمە منداڵی کۆیلەکە نین، بەڵکو هی ئازادەکەین.
\c 5
\s1 ئازادی بە مەسیح
\p 
\v 1 مەسیح ئازادی کردین تاکو بە ئازادی بژین. بۆیە چەسپاو بن و جارێکی دیکە ملکەچی نیری کۆیلایەتی مەبن.
\p 
\v 2 ئاگاداربن، من پۆڵسم پێتان دەڵێم: ئەگەر ڕێبدەن خەتەنە بکرێن ئەوا مەسیح هیچ سوودێکی بۆتان نابێت!
\v 3 دیسان شایەتی دەدەم، هەر مرۆڤێک ڕێ بدات خەتەنە بکرێت، دەبێت کار بە هەموو شەریعەت بکات.
\v 4 ئەی ئەوانەی دەتانەوێت بە شەریعەت بێتاوان بکرێن، ئەوا لە مەسیح جیا بوونەوە و لە نیعمەتی خودا کەوتن.
\v 5 بەڵام ئێمە لە ڕێگەی ڕۆحی پیرۆزەوە، بە باوەڕ، چاوەڕێی هیوای ڕاستودروستین.
\v 6 بە یەکبوون لەگەڵ عیسای مەسیحدا خەتەنەکردن یان نەکردن هیچ سوودێکی نییە، بەڵکو ئەو باوەڕە گرنگە کە بە خۆشەویستی کار دەکات.
\p 
\v 7 باش ڕاتاندەکرد. کێ ڕێی لێ گرتن تاکو گوێڕایەڵی ڕاستی نەبن؟
\v 8 ئەم بیروباوەڕە لەلایەن ئەوەوە نییە کە بانگتان دەکات.
\v 9 «هەویرترشێکی بچووک، هەموو هەویرەکە هەڵدێنێت.»
\v 10 لەبەر ئەوەی ئێمە لەگەڵ مەسیح یەکین، دڵنیام کە بە شێوەیەکی دیکە بیرناکەنەوە. ئەوەی بتانشێوێنێ سزای خۆی وەردەگرێت، جا هەرکەسێک بێت.
\v 11 بەڵام خوشکان، برایان، ئەگەر هەتا ئێستا من خەتەنەکردن ڕادەگەیەنم، ئیتر بۆچی هەتا ئێستا دەچەوسێمەوە؟ ئەگەر وا بێت، کۆسپی خاچ لادراوە.
\v 12 خۆزگە ئەو کەسانە دەخەسێنران کە دەتانشێوێنن.
\p 
\v 13 ئەی خوشک و برایانم، ئێوە بۆ ئازادی بانگکراون، بەڵام ئازادی مەقۆزنەوە بۆ ڕازیکردنی سروشتی دنیایی، بەڵکو بە خۆشەویستی خزمەتی یەکتری بکەن،
\v 14 چونکە تەورات هەمووی لە یەک ڕاسپاردەدا دێتە دی: ﴿نزیکەکەت وەک خۆت خۆشبوێت.﴾\f + \fr 5:14 \ft \xt لێڤییەکان 19‏:18.‏\xt*\ft ‏\f*
\v 15 ئەگەر پەلاماری یەکتری بدەن و یەکتری بخۆن، ئاگاداربن یەکتری لەناونەبەن.
\s1 ڕۆح و جەستە
\p 
\v 16 پێتان دەڵێم: بە ڕۆحی پیرۆز بژین، ئینجا ئارەزووی سروشتی دنیایی تێر ناکەن،
\v 17 چونکە ئارەزووی سروشتی دنیایی لە دژی ڕۆحەکەیە، ڕۆحەکەش لە دژی سروشتی دنیاییە. هەریەکەیان بەربەرەکانێی ئەوی دیکە دەکات، تاکو ئەوە نەکەن کە دەتانەوێت.
\v 18 بەڵام ئەگەر ئێوە بە ڕۆحەکە بەڕێوە بچن، ئەوا لەژێر سایەی شەریعەتدا نین.
\p 
\v 19 ئێستا کردەوەکانی سروشتی دنیایی مرۆڤ ڕوونن، ئەوانیش: داوێنپیسی، گڵاوی، بەڕەڵایی،
\v 20 بتپەرستی، جادووگەری، دوژمنایەتی، یاخیبوون، دڵپیسی، تووڕەبوون، خۆپەرستی، دووبەرەکی، ناکۆکی،
\v 21 چاوپیسی، سەرخۆشی، ڕابواردن، شتی دیکەی وەک ئەمانە، ئاگادارتان دەکەمەوە، وەک پێشتر ئاگادارم کردوونەتەوە: ئەوانەی ئەو کارانە دەکەن نابنە میراتگری شانشینی خودا.
\p 
\v 22 بەڵام بەروبوومی ڕۆحی پیرۆز ئەمەیە: خۆشەویستی، خۆشی، ئاشتی، ئارامگرتن، نیانی، چاکە، دڵسۆزی،
\v 23 دڵنەرمی و بەسەرخۆدا زاڵبوون. شەریعەت نییە لە دژی ئەمانە بێت.
\v 24 بەڵام ئەوانەی هی عیسای مەسیحن سروشتی دنیاییان لەگەڵ حەز و ئارەزووەکانیان لە خاچ داوە.
\v 25 ئەگەر بە ڕۆحی پیرۆز بژین، با هەنگاوەکانی ڕۆحەکەش بپارێزین.
\v 26 با لەخۆبایی نەبین، یەکتری تووڕە نەکەین، ئیرەیی بە یەکتر نەبەین.
\c 6
\s1 باری یەکتری هەڵبگرن
\p 
\v 1 خوشکان، برایان، ئەگەر کەسێک تووشی گوناهێک بوو، با ئێوەی ڕۆحانی کەسی ئاوا بە ڕۆح نەرمی ڕاست بکەنەوە. سەیری خۆشت بکە، نەوەک تۆش تاقی بکرێیتەوە.
\v 2 باری یەکتری هەڵبگرن و بەم شێوەیە شەریعەتی مەسیح بهێننە دی.
\v 3 ئەگەر یەکێک خۆی بە شتێک زانی، بەڵام لەڕاستیدا هیچ نەبوو، ئەوا خۆی هەڵدەخەڵەتێنێت.
\v 4 بەڵام با هەریەکە کرداری خۆی تاقی بکاتەوە، ئەوسا با تەنها شانازی بە خۆیەوە بکات، نەک بە کەسێکی دیکەوە،
\v 5 چونکە هەرکەسێک باری خۆی هەڵدەگرێت.
\v 6 ئەو کەسەی فێری وشەی خودا\f + \fr 6:6 \ft مەبەست لە کتێبی پیرۆزە.‏\f* دەکرێت، دەبێت فێرکارەکەی لە هەموو شتێکی باشدا بەشدار بکات.
\p 
\v 7 خۆتان هەڵمەخەڵەتێنن، خودا گاڵتەی پێ ناکرێت. مرۆڤ چی بچێنێت، ئەوە دەدروێتەوە.
\v 8 ئەوەی بۆ سروشتی دنیایی خۆی بچێنێت، گەندەڵی لە سروشتی دنیایی دەدروێتەوە، بەڵام ئەوەی بۆ ڕۆحی پیرۆز بچێنێت لە ڕۆحەکەوە ژیانی هەتاهەتایی دەدروێتەوە.
\v 9 کەواتە با لە چاکەکاری نەکەوین، چونکە ئەگەر ورە بەرنەدەین لە کاتی خۆیدا دروێنەی دەکەین.
\v 10 ئینجا هەتا دەرفەتمان هەیە، با چاکە لەگەڵ هەمووان بکەین، بە تایبەتی لەگەڵ خێزانی باوەڕداران.
\b
\s1 بەدیهێنراوی نوێ
\p 
\v 11 سەیر بکەن، ئەو پیتانە کە بە دەستی خۆم نووسیومە چەندە گەورەن.\f + \fr 6:11 \ft نامەکە دەستنووسی یارمەتیدەرە و بەشی کۆتایی دەستنووسی پۆڵس خۆیەتی، بۆ سەلماندنی سەرچاوەی نامەکە.‏\f*
\b
\p 
\v 12 ئەوانەی دەیانەوێت لە جەستەدا ڕواڵەتێکی چاک دروستبکەن، ئەوانە ناچارتان دەکەن خەتەنە بکرێن، تەنها تاکو لەبەر خاچی مەسیح نەچەوسێنرێنەوە.
\v 13 ئەوانەی خەتەنەکراون، شەریعەتی تەورات پەیڕەو ناکەن، تەنها دەیانەوێت ئێوە خەتەنە بکرێن، تاکو شانازی بە جەستەی ئێوەوە بکەن.
\v 14 لە من بەدوور بێت شانازی بە هیچ شتێکەوە بکەم، جگە لە خاچی عیسای مەسیحی خاوەن شکۆمان، کە بەهۆیەوە جیهان بۆ من لە خاچ دراوە، منیش بۆ جیهان،
\v 15 چونکە نە خەتەنەکردن سوودی هەیە و نە خەتەنەنەکردنیش، بەڵکو بەدیهێنراوی نوێ.
\v 16 با ئاشتی و بەزەیی بۆ هەموو ئەوانە بێت کە ئەم یاسایە پەیڕەو دەکەن، بۆ گەلی ئیسرائیلی خوداش.
\b
\p 
\v 17 ئیتر با کەس گرفتم بۆ دروستنەکات، چونکە نیشانەکانی عیسام لە لەشدا هەڵگرتووە.
\b
\p 
\v 18 خوشکان و برایان، با نیعمەتی عیسای مەسیحی خاوەن شکۆمان لەگەڵ ڕۆحتان بێت. ئامین.
