\q1
\v 14 “\w whose|strong="G3739"\w* \w mouth|strong="G4750"\w* \w is|strong="G3588"\w* \w full|strong="G1073"\w* \w of|strong="G2532"\w* cursing \w and|strong="G2532"\w* \w bitterness|strong="G4088"\w*.”\f + \fr 3:14 \ft See Psalm 10:7.\f*   
\q1
