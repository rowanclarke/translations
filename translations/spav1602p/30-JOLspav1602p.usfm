\v 18 \w Y|strong="H3068"\w* \w el|strong="H5921"\w* \w SEÑOR|strong="H3068"\w* \w celará|strong="H7065"\w* su tierra, \w y|strong="H5921"\w* \w perdonará|strong="H2550"\w* su \w pueblo|strong="H5971"\w*.
\m 
\v 19 \w Y|strong="H3068"\w* \w responderá|strong="H6030"\w* el \w SEÑOR|strong="H3068"\w*, y dirá \w a|strong="H3068"\w* su \w pueblo|strong="H5971"\w*: He \w aquí|strong="H2005"\w* yo os \w envío|strong="H7971"\w* \w pan|strong="H1715"\w*, y \w mosto|strong="H8492"\w*, y \w aceite|strong="H3323"\w*, y seréis saciados \w de|strong="H5750"\w* ellos: y \w nunca|strong="H3808"\w* \w más|strong="H5750"\w* os \w pondré|strong="H5414"\w* \w en|strong="H5750"\w* \w oprobio|strong="H2781"\w* \w entre|strong="H3808"\w* las \w gentes|strong="H1471"\w*.
\m 
\v 20 \w Y|strong="H3068"\w* \w haré|strong="H6213"\w* alejar \w de|strong="H5921"\w* vosotros \w al|strong="H5921"\w* \add ejército\add* \w del|strong="H5921"\w* norte, \w y|strong="H3588"\w* echarélo \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w seca|strong="H6723"\w* \w y|strong="H3588"\w* \w desierta|strong="H8077"\w*: \w su|strong="H3588"\w* \w faz|strong="H6440"\w* \w será|strong="H6213"\w* \w hacia|strong="H6213"\w* \w el|strong="H5921"\w* \w mar|strong="H3220"\w* oriental, \w y|strong="H3588"\w* \w su|strong="H3588"\w* fin \w al|strong="H5921"\w* \w mar|strong="H3220"\w* \w occidental|strong="H3220"\w*, \w y|strong="H3588"\w* exhalará \w su|strong="H3588"\w* hedor; \w y|strong="H3588"\w* \w subirá|strong="H5927"\w* \w su|strong="H3588"\w* pudrición, \w por|strong="H5921"\w*­\w que|strong="H3588"\w* \w hizo|strong="H6213"\w* \w grandes|strong="H1431"\w* cosas.
\m 
\v 21 Tierra, \w no|strong="H6213"\w* \w temas|strong="H3372"\w*; \w alégrate|strong="H8055"\w* \w y|strong="H3588"\w* \w gózate|strong="H8055"\w*: \w porque|strong="H3588"\w* \w el|strong="H3588"\w* \w SEÑOR|strong="H3068"\w* ha \w de|strong="H3588"\w* \w hacer|strong="H6213"\w* \w grandes|strong="H1431"\w* cosas.
\m 
\v 22 Animales del \w campo|strong="H7704"\w*, \w no|strong="H3588"\w* \w temáis|strong="H3372"\w*; \w porque|strong="H3588"\w* \w los|strong="H3588"\w* pastos del \w desierto|strong="H4057"\w* \w reverdecerán|strong="H1876"\w*, \w porque|strong="H3588"\w* \w los|strong="H3588"\w* \w árboles|strong="H6086"\w* \w llevarán|strong="H5375"\w* \w su|strong="H3588"\w* \w fruto|strong="H6529"\w*, \w la|strong="H3588"\w* higuera \w y|strong="H3588"\w* \w la|strong="H3588"\w* \w vid|strong="H1612"\w* \w darán|strong="H5414"\w* sus \w frutos|strong="H6529"\w*.
\m 
\v 23 Vosotros también, \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Sión|strong="H6726"\w*, \w alegraos|strong="H8055"\w* \w y|strong="H3588"\w* gozaos \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w SEÑOR|strong="H3068"\w* vuestro \w Dios|strong="H3068"\w*; \w porque|strong="H3588"\w* os ha \w dado|strong="H5414"\w* \w la|strong="H3588"\w* \w primera|strong="H7223"\w* \w lluvia|strong="H1653"\w* arregla­damente, \w y|strong="H3588"\w* \w hará|strong="H5414"\w* descender sobre vosotros \w lluvia|strong="H1653"\w* \w temprana|strong="H4175"\w* \w y|strong="H3588"\w* \w tardía|strong="H4456"\w* \add como\add* al \w principio|strong="H5414"\w*.
\m 
\v 24 \w Y|strong="H3068"\w* las eras se \w henchirán|strong="H4390"\w* de \w trigo|strong="H1250"\w*, y los lagares rebosarán de \w vino|strong="H8492"\w* y \w aceite|strong="H3323"\w*.
\m 
\v 25 \w Y|strong="H3068"\w* os restituiré los \w años|strong="H8141"\w* que comió la oruga, la langosta, el pulgón, y el revoltón; mi \w grande|strong="H1419"\w* \w ejército|strong="H2428"\w* que \w envié|strong="H7971"\w* contra voso­tros.
\m 
\v 26 \w Y|strong="H3068"\w* comeréis hasta saciaros, y alabaréis \w el|strong="H5973"\w* \w nombre|strong="H8034"\w* \w del|strong="H5973"\w* \w SEÑOR|strong="H3068"\w* vuestro \w Dios|strong="H3068"\w*, \w el|strong="H5973"\w* \w cual|strong="H5973"\w* \w hizo|strong="H6213"\w* mara­villas \w con|strong="H5973"\w* \w vosotros|strong="H5973"\w*: y \w nunca|strong="H3808"\w* \w jamás|strong="H5769"\w* \w será|strong="H3808"\w* mi \w pueblo|strong="H5971"\w* avergonza­do.
\m 
\v 27 \w Y|strong="H3068"\w* \w conoceréis|strong="H3045"\w* \w que|strong="H3588"\w* \w en|strong="H3588"\w* \w medio|strong="H7130"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* estoy \w yo|strong="H3588"\w*, \w y|strong="H3588"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* soy \w el|strong="H3588"\w* \w SEÑOR|strong="H3068"\w* vuestro \w Dios|strong="H3068"\w*, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w hay|strong="H5750"\w* \w otro|strong="H5750"\w*: \w y|strong="H3588"\w* mi \w pueblo|strong="H5971"\w* \w nunca|strong="H3808"\w* \w jamás|strong="H5769"\w* \w será|strong="H3808"\w* avergonzado.
\m 
\v 28 \w Y|strong="H3068"\w* será que después de esto, derramaré mi espíritu sobre toda carne, y profetizarán vuestros hijos y vuestras hijas; vuestros viejos soñarán sueños, y vuestros mancebos verán visiones.
\m 
\v 29 \w Y|strong="H3068"\w* aun también sobre los sier­vos y sobre las siervas derramaré mi espíritu en aquellos días.
\m 
\v 30 \w Y|strong="H3068"\w* mostraré prodigios en los cielos y en la tierra, sangre, y fuego, y columnas de humo.
\m 
\v 31 El sol se tornará en tinieblas, y la luna en sangre, antes que venga el día grande y espantoso del SEÑOR.
\m 
\v 32 \w Y|strong="H3068"\w* será que cualquiera que invocare el nombre del SEÑOR, será salvo: porque en el monte de Sión y en Jerusalem habrá salva­ción, como el SEÑOR ha dicho, y en el remanente, al cual el SEÑOR habrá llamado.
\c 3
\m 
\v 1 \w PORQUE|strong="H5921"\w* he aquí, \w que|strong="H5921"\w* \w en|strong="H5921"\w* \w aquellos|strong="H3605"\w* días, \w y|strong="H5921"\w* \w en|strong="H5921"\w* \w aquel|strong="H3605"\w* tiempo \w en|strong="H5921"\w* \w que|strong="H5921"\w* haré tornar \w la|strong="H5921"\w* cautividad \w de|strong="H5921"\w* Judá \w y|strong="H5921"\w* \w de|strong="H5921"\w* Jerusalem,
\m 
\v 2 Juntaré todas \w las|strong="H1992"\w* naciones, \w y|strong="H1571"\w* haré­\w las|strong="H1992"\w* descender \w al|strong="H5921"\w* valle \w de|strong="H5921"\w* Josafat, \w y|strong="H1571"\w* allí entraré \w en|strong="H5921"\w* juicio \w con|strong="H5921"\w* \w ellos|strong="H1992"\w* \w a|strong="H3068"\w* causa \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w pueblo|strong="H1992"\w*, \w y|strong="H1571"\w* \w de|strong="H5921"\w* Israel \w mi|strong="H5921"\w* heredad, \w a|strong="H3068"\w* \w los|strong="H1992"\w* cuales espar­cieron \w entre|strong="H5921"\w* \w las|strong="H1992"\w* naciones, \w y|strong="H1571"\w* par­tieron \w mi|strong="H5921"\w* tierra:
\m 
\v 3 \w Y|strong="H3068"\w* echaron suertes sobre mi pueblo, y \w a|strong="H3068"\w* los niños \w dieron|strong="H5414"\w* \w por|strong="H5414"\w* una ramera, y vendieron las niñas \w por|strong="H5414"\w* vino \w para|strong="H5414"\w* beber.
\m 
\v 4 \w Y|strong="H3068"\w* también, ¿\w qué|strong="H3117"\w* tengo yo con vosotras, Tiro y Sidón, y todos los términos \w de|strong="H6440"\w* Filistea? ¿Queréis vengaros \w de|strong="H6440"\w* mí? \w Y|strong="H3068"\w* \w si|strong="H6440"\w* \w de|strong="H6440"\w* mí os vengáis, bien pronto haré yo recaer la paga sobre vuestra cabeza.
\m 
\v 5 \w Porque|strong="H3588"\w* habéis llevado \w mi|strong="H3389"\w* plata \w y|strong="H3588"\w* \w mi|strong="H3389"\w* oro, \w y|strong="H3588"\w* mis cosas preciosas \w y|strong="H3588"\w* hermosas metisteis \w en|strong="H3588"\w* vuestros templos:
\m 
\v 6 \w Y|strong="H3068"\w* vendisteis los hijos de Judá y los hijos de Jerusalem \w a|strong="H3068"\w* los hijos de los griegos, por alejarlos de sus términos.
\m 
\v 7 He aquí los levantaré yo del lugar donde los vendisteis, y vol­veré vuestra paga sobre vuestra cabeza:
\m 
\v 8 \w Y|strong="H3068"\w* venderé vuestros hijos y vuestras hijas en la mano de los hijos de Judá, y ellos los vende­rán \w a|strong="H3068"\w* los sabeos, nación aparta­da; porque el SEÑOR ha habla­do.
\m 
\v 9 Pregonad esto entre los gentiles, proclamad guerra, despertad \w a|strong="H3068"\w* los valientes, lléguense, vengan todos los hombres de guerra.
\m 
\v 10 Haced espadas de vuestros azadones, lanzas de vuestras hoces; diga el flaco: Fuerte soy.
\m 
\v 11 Juntaos y venid, gentes todas de alrededor, y congregaos: haz venir allí, oh SEÑOR, tus fuer­tes.
\m 
\v 12 Las gentes se despierten, y suban al valle de Josafat: por­que allí me sentaré para juzgar todas las gentes de alrededor.
\m 
\v 13 Echad la hoz, porque la mies está ya madura. Venid, descen­ded; porque el lagar está lleno, rebosan las lagaretas: porque mucha es la maldad de ellos.
\m 
\v 14 Muchos pueblos en el valle de la decisión: porque cercano está el día del SEÑOR en el valle de la decisión.
\m 
\v 15 El sol y la luna se oscurece­rán, y las estrellas retraerán su resplandor.
\m 
\v 16 \w Y|strong="H3068"\w* el SEÑOR rugirá desde Sión, y dará su voz desde Jerusalem, y temblarán los cielos y la tierra: mas el SEÑOR será la esperanza de su pueblo, y la for­taleza de los hijos de Israel.
\m 
\v 17 \w Y|strong="H3068"\w* conoceréis que yo soy el SEÑOR vuestro Dios, que habi­to en Sión, monte de mi santidad: y será Jerusalem santa, y extra­ños no pasarán más por ella.
\m 
\v 18 \w Y|strong="H3068"\w* será en aquel tiempo, que los montes destilarán mosto, y los collados fluirán leche, y por todos los arroyos de Judá corre­rán aguas: y saldrá una fuente de la casa del SEÑOR, y regará el valle de Sitim.
\m 
\v 19 Egipto será destruído, y Edom será vuelto en asolado desierto, por la injuria hecha \w a|strong="H3068"\w* los hijos de Judá: porque derra­maron en su tierra la sangre ino­cente.
\m 
\v 20 Mas Judá para siempre será habitada, y Jerusalem en genera­ción y generación.
\m 
\v 21 \w Y|strong="H3068"\w* limpiaré la sangre de los que no limpié; y el SEÑOR morará en Sión. 
