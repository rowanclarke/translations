\id HAB  
\h عَننَبِ هَبَكُكُ 
\toc1 عَلَ شَ مَسٍنيِ عَننَبِ هَبَكُكُ بّ 
\toc2 عَننَبِ هَبَكُكُ 
\toc3 هَب 
\mt1 عَلَ شَ مَسٍنيِ عَننَبِ هَبَكُكُ بّ 
\imt1 مَسٍنيِ ندٍ يِ كِتَابُي شَ قٍ رَ 
\ip عَننَبِ هَبَكُكُ شَ كِتَابُي قْلْمَ مَشْرِنيِ نَن مَ عَ نَشَن تِ عَلَتَلَ مَ؛ «مُنقٍرَ عِ شَ حَمَ نَ تْورّ كُي؟» عَلَتَلَ نَشَ عَ يَابِ عَ شْرْشْي رَ، عَ قَلَقٍ رَ عٍ شَ تْورّ قَمَ نّ عَ شُن مَسَدٍ. عَلَ نُ بَرَ نَتّ تٌنفٌ عَ شَ كَاقِرِ رَوَلِ نَ حَشَنكَتّ دْشْقٍ رَ عَ شَ حَمَ مَ. 
\ip كْنْ نَ كٍلِشِ مُنسٍ مَ؟ عَننَبِ هَبَكُكُ شَ كِتَابُي نَ تَفِ رَبَمَ عَ قَنيِ رَ. عَلَ نَشَ عَ مَسٍن نَمِحْنمّ سَابُي رَ، نَ تْورّ بِرِن قَتَنشِ عِسِرَيِلَكَيٍ شَ وَلِ حَاشِ نَن نَ، عَلْ مُحّ تِقٍ، يّنّ رَبَقٍ، سِيسِقٍ، نُن كُيٍ بَتُقٍ. عٍ تٌ نُ نَ مْولِ رَبَمَ، نَ بَرَ عَ نِيَ عَلَتَلَ شَ نَتّ شْرْشْي تٌنفٌ عٍ شِلِ مَ. 
\ip عَلَتَلَ شَ يَرَفَاشُي نَشَ لُ عَننَبِ هَبَكُكُ بْحّ مَ. عَ نَشَ عَ مَشَندِ عَ شَ دِحّ عَ شَ حَمَ شَ يُنُبِيٍ مَ. عَلَتَلَ سّنبّ فبٌ، عَ مَفَاشُ، كْنْ عَ شَ شَنُنتٍيَ فبٌ نَ بِرِن بّ. نَ نَن عَ رَ، عَننَبِ هَبَكُكُ نَشَ عَ شَشِلِ تِ عَلَ رَ. عَ نَشَ نَتّ تٌنفٌ عَ شَ لُ عَلَ سَفٌي هَلِ نَ قِندِ حَشَنكَتّ شْرْشْي رَ عَ بّ. 
\ip عَلَ شَ وٌن مَلِ عَلَكٌ نَ شَشِلِ شَ لُ وٌن بِرِن يِ رَ. عَمِنَ. 
\mt1 عَلَ شَ مَسٍنيِ عَننَبِ هَبَكُكُ بّ 
\c 1  
\s1 عَننَبِ هَبَكُكُ شَ يَشَسٍرِ مَسَ سِنفٍ 
\p  
\v 1 عَننَبِ هَبَكُكُ شَ مَسٍنيِ نَن يَ، عَلَتَلَ نَشَن مَسٍن عَ بّ؛ 
\q1  
\v 2 «عَلَتَلَ، ﭑ شَ عِ مَشَندِ هَن تّمُي مُندُن؟ 
\q1 مُنقٍ رَ عِ مُ ﭑ مَ دُبّ سُشُشِ؟ 
\q1 ﭑ بَرَ ﭑ مَوَ عِ بّ فٍرٍ شَ قٍ رَ، 
\q1 كْنْ هَن يَ عِ مُ نُ مُشُ رَتَنفَ. 
\q1  
\v 3 مُنقٍ رَ عِ تِنشِ ﭑ يَ شَ كٌبِحَ تٌ؟ 
\q1 عِ تِنشِ يِ تْورّ مْولِ رَ مُنقٍ رَ؟ 
\q1 فبَلٌي نُن فٍرٍ نَ ﭑ يَ رَ تّمُي بِرِن. 
\q1 لَنتَرٍيَ نُن كَلَمُي بَرَ فبٌ يّ. 
\q1  
\v 4 مِشِيٍ بَرَ فبِلٍن عِ شَ سّرِيّ قْشْ رَ. 
\q1 عٍ بَرَ عِ شَ يَامَرِ لُ نَ. 
\q1 تِنشِنتَرٍ قُمَ تِنشِنتْي مَ. 
\q1 سّرِيّ مُ نَ سْنْن.» 
\b  
\s1 عَلَتَلَ شَ يَابِ سِنفٍ 
\q1  
\v 5 «وٌ وٌ يَ تِ حَمَنّيٍ رَ، وٌ عٍ مَتٌ. 
\q1 وٌ كَابَمَ نّ، وٌ دّ عِشَرَ، 
\q1 بَرِ مَ قٍ ندٍ نَ رَبَقٍ وٌ شَ وَشَتِ كُي 
\q1 وٌ مُ لَمَ نَشَن نَ، 
\q1 هَلِ نَ سَ قَلَ وٌ بّ. 
\q1  
\v 6 ﭑ نَ كَلِدِكَيٍ شُن نَكٍلِقٍ. 
\q1 سِ كِنِكِنِتَرٍ نَن عٍ رَ. 
\q1 عٍ حَمَنّ فبّتّيٍ عِسَمَ 
\q1 عَلَكٌ عٍ شَ بْشِيٍ رَ سُشُ، عٍ فبٍ مُ نَشَن نَ. 
\q1  
\v 7 عٍ مَفَاشُ، عٍ مُ قَن. 
\q1 عٍ يَامَرِ تِمَ يّتّ عِفبٌحَ نَن نَ. 
\q1  
\v 8 عٍ شَ سٌييٍ شُلُن بَرَتّيٍ بّ. 
\q1 عٍ شَاحّ وُلَءِ بَرٍيٍ بّ نَشٍيٍ مِنِمَ كْي رَ. 
\q1 عٍ شَ سٌييٍ قَمَ سّنبّ رَ كٍلِقٍ يِرٍ مَكُيٍ. 
\q1 عٍ مَقُرَ عَلْ سّفّ، نَشَن فٌرٌ مَ تْشْي يْرّ قْشْ رَ. 
\q1  
\v 9 يِ حَمَ قَمَ كَنَرِ نَن شِلِ مَ، 
\q1 عٍ يَيٍ بَنبَنشِ عٍ سِفَدٍ رَ. 
\q1 عٍ مِشِ سُشُشِيٍ مَلَنمَ عَلْ مّيّنيِ. 
\q1  
\v 10 عٍ يٌمَ مَنفّيٍ مَ، عٍ كُنتِفِيٍ مَيٍلٍمَ. 
\q1 عٍ مُ فَاشُمَ يِرٍ مَكَنتَشِ يَ رَ. 
\q1 عٍ بّندّ مَتٍمَ تّتّ رَ، عَلَكٌ عٍ شَ سٌ نَا كُي. 
\q1  
\v 11 عٍ دَنفِمَ عَلْ قٌيٍ بٍلٍبٍلٍ. 
\q1 عٍ فبَتَشِ قٍ حَاشِ رَبَدٍ. 
\q1 عٍ بَرَ عٍ سّنبّ قِندِ عٍ شَ عَلَ رَ.» 
\s1 عَننَبِ هَبَكُكُ شَ يَشَسٍرِ مَسَ قِرِن ندٍ 
\q1  
\v 12 ﭑ مَرِفِ سّنِيّنتْي، ﭑ مَرِفِ عَلَتَلَ، 
\q1 عِ نَ نَ كَبِ قٍ قْلْ قْلّ. 
\q1 عٍ مُ قَمَ مُشُ قَشَدٍ. 
\q1 عَلَتَلَ، عِ قَمَ عٍ تَن نَن مَكِيتِدٍ. 
\q1 ﭑ كَنتَ فّمّ نَ عِ تَن نَن نَ، 
\q1 عِ عٍ حَشَنكَتَمَ نّ. 
\q1  
\v 13 عِ يَيٍ سّنِيّن، عِ مُ وَ مَ كٌبِحَ تٌقٍ، 
\q1 عِ قٍ حَاشِ شْنشِ. 
\q1 عَوَ، مُنقٍ رَ عِ مُ يَنقَنتٍيٍ هَلَكِمَ؟ 
\q1 مُنقٍ رَ عِ مُ سٍسٍ نِيَمَ تِنشِنتَرٍيٍ رَ 
\q1 عٍ تِنشِنتْييٍ تْورْ مَ تّمُي نَشّ؟ 
\q1  
\v 14 عِ بَرَ عَدَ مَدِيٍ لُ عَلْ يّشّ نَشٍيٍ نَ بَا مَ، 
\q1 عَلْ سُبٍيٍ مَنفّ مُ نَ نَشٍيٍ بّ. 
\q1  
\v 15 مُشُ يَشُييٍ مُشُ سُشُمَ كْنيِ رَ، 
\q1 عٍ مُشُ سُشُمَ يّلّ رَ. 
\q1 عٍ نَ فّ مُشُ مَلَندٍ بّكِ كُي، عٍ حّلّشِن. 
\q1  
\v 16 نَ تّمُي عٍ سّرّشّ مْولِ بِرِن بَمَ عَ شَ يّلّ بّ، 
\q1 بَرِ مَ نَ نَن بَرَ عَ نِيَ عٍ شَ قّيرّ فبٍفبٍ سْتْ. 
\q1 عٍ دٌنسٍ قَنيِ دٌنمَ عَ تَن نَن سَابُي رَ. 
\q1  
\v 17 عَ لَنمَ عٍ شَ يّلّ شَ نُ سِفَ يّشّيٍ سُشُ رَ، 
\q1 عٍ شَ نُ بْنسْييٍ رَهَلَكِ كِنِكِنِتَرٍحَ كُي؟ 
\c 2  
\s1 عَلَتَلَ شَ يَابِ قِرِن ندٍ 
\q1  
\v 1 «ﭑ قَ تِمَ تّتّ نَن قَرِ. ﭑ شَ مَمّ تِ. 
\q1 ﭑ شَ عَ كٌلٌن عَ نَشَن مَسٍنمَ ﭑ بّ، 
\q1 عَ ﭑ مَ يَشَسٍرِ مَسَ يَابِمَ كِ نَشّ.» 
\b  
\p  
\v 2 عَلَتَلَ نَشَ ﭑ يَابِ يِ مَسٍنيِ رَ؛ 
\q1 «عِ شَ ﭑ مَ مَسٍنيِ سّبّ، 
\q1 عِ شَ عَ سّبّ عَ قَنيِ رَ وَلَشّيٍ مَ، 
\q1 عَلَكٌ نَشٍيٍ عَ شَرَنمَ، 
\q1 عٍ شَ نْ بِرَدٍ عَ قْشْ رَ سّنبّ رَ. 
\q1  
\v 3 يِ مَسٍنيِ كَمَلِ وَشَتِ قَقٍ، 
\q1 عَ مُ كَنَمَ، وُلٍ مُ عَ رَ. 
\q1 شَ عِ عَ تٌ عَ تَاشِرِ مَ كَمَلِدٍ، 
\q1 عِ شَ مَمّ تِ. عَ كَمَلِقٍ مُ بُمَ.» 
\b  
\q1  
\v 4 «يّتّ عِفبٌي مَتٌ. عَ وَشْنقٍ مُ تِنشِن، 
\q1 كْنْ تِنشِنتْي تَن كِسِمَ عَ شَ دَنشَنِيَ نَن سَابُي رَ. 
\q1  
\v 5 بٍيرٍ مِشِ مَيَنقَمَ. 
\q1 يّتّ عِفبٌي مُ رَشَرَشِ. 
\q1 عَ مُ وَ سَمَ، عَلْ عَلِفِيَمَ مُ وَ سَمَ كِ نَشّ. 
\q1 عَ حَمَنّ بِرِن قِندِ مَ عَ فبٍ نَن نَ، 
\q1 عَ سِ بِرِن سَ عَ شَ نْي بُن مَ. 
\q1  
\v 6 نَ سِيٍ مُ يٌمَ عَ مَ شّ؟ 
\q1 عٍ مُ عَ مَيٍلٍمَ شّ، عٍ عَ قِندِ دّءِ سِفِ رَ؟» 
\s1 دَنكَرِ سِنفٍ 
\q1 «عٍ قَمَ نّ عَ قَلَدٍ، 
\q1 ‹حَشَنكَتّ نَ مِشِ بّ 
\q1 نَشَن سٍ مَلَنمَ عَ فبٍ مُ نَشَن نَ. 
\q1 عَ شَ دٌنِ شُن نَن تُن لُمَ مَسَ رَ. 
\q1 يِ قٍ مْولِ بُمَ هَن مُن تّمُي؟ 
\q1  
\v 7 نَشٍيٍ شَ دٌنِ نَ عِ مَ، نٍيٍ مُ كٍلِمَ شّ، 
\q1 عٍ عِ رَشُنُ، عٍ عِ سُشُ، عٍ عٍ فبٍ حْشْ عِ مَ؟ 
\q1  
\v 8 عِ تٌ بَرَ سِ فبٍفبٍ شُن نَكَنَ، 
\q1 نَشٍيٍ لُشِ قَ، نٍيٍ نَن قَمَ عِ قَن شُن نَكَنَدٍ. 
\q1 عٍ نَ رَبَمَ نّ عِ تٌ بَرَ مِشِ وُلِ عِقِلِ، 
\q1 عِ تٌ بَرَ بْشِيٍ نُن تَايٍ كَنَ، عِ نَاكَيٍ قَن قَشَ.›» 
\s1 دَنكَرِ قِرِن ندٍ 
\q1  
\v 9 «حَشَنكَتّ نَ مِشِ بّ 
\q1 نَشَن فٍينِمَ تِنشِنتَرٍيَ كُي 
\q1 عَلَكٌ عَ شَ بَنشِ قَنيِ تِ عَ يّتّ بّ 
\q1 تْورّ يٌ مُ نَ دّننَشّ. 
\q1  
\v 10 عِ نَشَن نَبَشِ عَ قِندِ مَ يَافِ نَن نَ عِ شَ مِشِيٍ بّ. 
\q1 عِ حَشَنكَتّ نَشَن سَشِ حَمَيٍ مَ، 
\q1 عَ قَمَ فبِلٍندٍ نّ عِ مَ. 
\q1  
\v 11 عِ شَ بَنشِ تِشِ فّمّ نَشَن نَ، 
\q1 وُرِ نَشَن بَنبَنشِ عَ قَرِ، 
\q1 عٍ قَمَ نّ سٍيدٍحْشْيَ بَدٍ عِ شِلِ مَ.» 
\s1 دَنكَرِ سَشَن ندٍ 
\q1  
\v 12 «حَشَنكَتّ نَ مِشِ بّ 
\q1 نَشَن تَا تِمَ قَشّ تِ سَابُي رَ، 
\q1 نَشَن عَ شَ تَا رَفبٌمَ قٍ كٌبِ سَابُي رَ. 
\q1  
\v 13 مَنفّ عَلَتَلَ بَرَ عَ نِيَ، 
\q1 حَمَيٍ شَ وَلِ بِرِن شَ فَن، 
\q1 عٍ شَ وَكِلِ قِندِ مَ قٍ قُقَقُي نَن نَ. 
\q1  
\v 14 دُنِحَ بِرِن قَمَ نّ عَلَتَلَ شَ نْرّ كٌلٌندٍ، 
\q1 عَلْ بَنبَرَنيِ فبٌمَ كِ نَشّ بَا مَ.» 
\s1 دَنكَرِ نَانِ ندٍ 
\q1  
\v 15 «حَشَنكَتّ نَ مِشِ بّ 
\q1 نَشَن عَ بٌورٍ رَ سِيسِمَ 
\q1 عَلَكٌ سَدٍ قٍ شَ لُ عٍ تَفِ. 
\q1  
\v 16 عِ شَ شُننَكٍلِ قِندِ مَ نّ يَافِ رَ. 
\q1 عِ قَن شَ بٍيرٍ مِن، عِ شَ سَدٍ قٍ كٌلٌن. 
\q1 عَلَتَلَ شَ شْنّ قَقٍ عِ مَ، 
\q1 عَ عِ شَ شُننَكٍلِ مَقِندِ مَ يَافِ نَن نَ. 
\q1  
\v 17 عِ قٍ كٌبِ نَشَن نَبَشِ لِبَن، 
\q1 نَ سَرٍ قَمَ نّ فبِلٍندٍ عِ مَ. 
\q1 عِ بَرَ شُرُ سٍيٍ كَسَرَ، 
\q1 عِ بَرَ مِشِيٍ قَشَ، 
\q1 عِ بَرَ بْشِ نُن تَايٍ كَنَ، عَ نُن عٍ شَ مِشِيٍ. 
\q1 نَ حَشَنكَتّ بِرِن قَمَ نّ فبِلٍندٍ عِ مَ.» 
\s1 دَنكَرِ سُولِ ندٍ 
\q1  
\v 18 «كُيٍ مُنسٍ قَنشِ مِشِ مَ؟ 
\q1 مِشِ شَ مُ عَ يَءِلَنمَ؟ 
\q1 عَ وُلٍ نَن تُن مَسٍنمَ. 
\q1 عَ يَءِلَنمَ مَن قَ عَ يّتّ تَشُ عَ رَ. 
\q1 عَ بَرَ عَلَ بٌبٌي يَءِلَن. 
\q1  
\v 19 حَشَنكَتّ نَ مِشِ بّ 
\q1 نَشَن عَ قَلَمَ وُرِ مَسٌلِشِ بّ، ‹كٍلِ،› 
\q1 نَشَن وْيّنمَ فّمّ بٌبٌشِ بّ، ‹شُنُ.› 
\q1 كُيٍ مُنسٍ مَسٍنمَ عِ بّ؟ 
\q1 هَلِ شّيمَ نُن فبٍتِ لُ عَ مَ، 
\q1 شَشِلِ تَن يٌ مُ نَ عَ بّ. 
\q1  
\v 20 كْنْ عَلَتَلَ نَ عَ شَ هْرْ مْبَنشِ كُي. 
\q1 دُنِحَ بِرِن شَ عَ سَبَرِ عَ يَ عِ.» 
\c 3  
\s1 عَننَبِ هَبَكُكُ شَ عَلَ مَشَندِ 
\p  
\v 1 عَننَبِ هَبَكُكُ شَ عَلَ مَشَندِ نَن يَ، نَشَن بَمَ بّيتِ كِ مَ. 
\q1  
\v 2 عَلَتَلَ، ﭑ بَرَ عِ شَ مَسٍنيِ مّ، 
\q1 ﭑ بَرَ كَابَ عِ شَ وَلِ مَ. 
\q1 عِ شَ عَ رَفِرِ يِ وَشَتِ مَ، 
\q1 عِ شَ عَ رَكَمَلِ مِشِيٍ يَ شْرِ. 
\q1 كْنْ عِ نَشَ نّيمُ عِ شَ كِنِكِنِ مَ عِ شَ شْنّ كُي. 
\b  
\q1  
\v 3 ﭑ بَرَ عَلَ سّنِيّنشِ تٌ قَ رَ كٍلِقٍ تٍمَن مَبِرِ، 
\q1 كٍلِقٍ ثَرَن فٍيَ مَ. 
\q1 كٌورٍ نَشَ رَقٍ عَ شَ نْرّ رَ، 
\q1 دُنِحَ نَشَ رَقٍ عَ شَ مَتْشْي رَ. 
\q1  
\v 4 عَلَ شَ يَنبّ سّنبّ فبٌ. 
\q1 نَءِيَلَنيِ نُ كٍلِمَ عَ بّلّشّ كُي، 
\q1 عَ سّنبّ نْشُنشِ دّننَشّ. 
\q1  
\v 5 وُفَن قُرٍ نُ عَ حّرّ مَ عَ يَ رَ، 
\q1 حَشَنكَتّ قَن نَ عَ قْشْ رَ. 
\q1  
\v 6 عَ نَشَ تِ، عَ دُنِحَ رَ سّرّن. 
\q1 عَ نّقّ عَ مَتٌ، بْنسْييٍ بَرَ هَلَكِ. 
\q1 فٍيَ نَشٍيٍ تِ دُنِحَ قْلّ رَ، 
\q1 نٍيٍ نَشَ سّرّن، عٍ عٍ عِفٌرٌ عَلَتَلَ يَ رَ. 
\q1 قْلّ مُ نَ عَلَتَلَ بّ. 
\q1  
\v 7 ﭑ نَشَ كُسَنكَيٍ تٌ حَشَنكَتَ رَ، 
\q1 ﭑ نَشَ مَدِيَنكَيٍ تٌ سّرّن نَ. 
\b  
\q1  
\v 8 عَلَتَلَ، عِ نُ شْنْشِ نّ شُرٍيٍ مَ؟ 
\q1 عِ تٌ تِ عِ شَ فٍرٍ سٌي يَ رَ، 
\q1 عٍ نُن عٍ شَ سٌييٍ نُن عٍ شَ فِسٍيٍ، 
\q1 عِ نُ شْنْشِ نّ بَا مَ؟ 
\q1  
\v 9 عِ نَشَ عِ شَ شَلِ رَ مِنِ، 
\q1 عِ نَشَ تَنبّ وُيَشِ سُشُ. 
\q1 عِ نَشَ شُرٍيٍ رَبْو بْشِ مَ. 
\q1  
\v 10 فٍيَيٍ تٌ عِ تٌ، 
\q1 عٍ نَشَ سّرّن. 
\q1 تُنّ شُنفبٍ نَشَ قَ. 
\q1 بَا نَشَ عَ شُي رَ مِنِ، 
\q1 مْرْنيِيٍ نَشَ تٍ. 
\q1  
\v 11 سٌفٍ نُن كِكٍ نَشَ عٍ شَ وَلِ عِتِ 
\q1 عٍ تٌ عِ شَ تَنبّيٍ تٌ يَنبَ رَ كٌورٍ عَلْ سٍيَمَكْنيِ. 
\q1  
\v 12 عِ نَشَ تِ بْشِ قَرِ، 
\q1 عِ قَ حَمَنّيٍ رَبٌرٌن حّ عِ شَ شْنّ كُي. 
\q1  
\v 13 عِ نَشَ عِ شَ حَمَ رَكِسِ، 
\q1 عِ مَن قَ عِ شَ مِشِ سُفَندِشِ رَتَنفَ. 
\q1 عِ نَشَ بْنسْي كٌبِيٍ شَ مَنفّ بُتُشُن، 
\q1 عِ عَ شَ سٍيٍ بِرِن قِندِ شُبٍ رَ. 
\q1  
\v 14 عَ شَ سْورِيٍ نَشَ مِنِ مُشُ شِلِ مَ، 
\q1 عٍ شَ تْورْ مِشِيٍ هَلَكِ حّلّشِنيِ كُي فُندٌ رَ، 
\q1 كْنْ عِ تَن نَشَ عٍ شَ مَنفّ سْشْ عَ يّتّ شَ تَنبّ رَ. 
\q1  
\v 15 عِ نَشَ كِرَ رَبْو عِ شَ سٌييٍ بّ، 
\q1 عٍ شَ دَنفِ بَا تَفِ. 
\b  
\q1  
\v 16 ﭑ تٌ عِ شَ مَسٍنيِ مّ، 
\q1 ﭑ بْحّ نَشَ مِنِ عَ عِ، ﭑ دّ نَشَ عِشَرَ، 
\q1 ﭑ شْرِيٍ نَشَ تَفَن، ﭑ سَنيِيٍ نَشَ سّرّن. 
\q1 ﭑ نَ لْشْي مَمّقٍ 
\q1 عِ مُشُ يَشُييٍ حَشَنكَتَمَ لْشْي نَشّ. 
\q1  
\v 17 هَلِ قُفٍ مُ نَ شْرّ بِلِ مَ، 
\q1 هَلِ وّنِ بٌفِ مُ نَ عَ قِرِ مَ، 
\q1 هَلِ بٌفِ يٌ مُ بَمَ وُرِ بِلِيٍ كْن نَ، 
\q1 هَلِ سَنسِيٍ مُ قَنمَ شّ مَ، 
\q1 هَلِ شُرُ سٍيٍ مُ نَ كُلّ كُي، 
\q1 هَلِ نِنفٍ كٍرٍن مُ لُ فْورّ، 
\q1  
\v 18 نَ بِرِن كُي، ﭑ عَلَتَلَ مَتْشْمَ نّ، 
\q1 ﭑ سّيوَ عَلَ رَ، ﭑ مَ مَرَكِسِمَ. 
\q1  
\v 19 ﭑ سّنبّ نَ ﭑ مَرِفِ عَلَتَلَ نَن نَ. 
\q1 عَ ﭑ مَ حّرّ سْونّيَمَ نّ قٍ شْرْشْي كُي، 
\q1 عَلْ شٍلِ شَ حّرّ سْونّيَمَ فٍيَيٍ قَرِ كِ نَشّ. 
\b  
\p يِ سّبّشِ بّيتِبَ مَنفّ نَن بّ. عَ شَ عَ بَ كْرَ شُي رَ.