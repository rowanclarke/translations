\c 16  
\s1 Hnokhoem Thae  
\p
\v 1 A \w hnukbang|strong="G3101"\w* \w rhoek|strong="G3588"\w* \w te|strong="G4314"\w* \w khaw|strong="G2532"\w*, \wj “ \+w Hlang|strong="G0444"\+w* \+w pakhat|strong="G5100"\+w* tah \+w kuirhang|strong="G4145"\+w* la \+w om|strong="G2258"\+w* tih \+w hnokhoem|strong="G3623"\+w* \+w a|strong="G3739"\+w* \+w khueh|strong="G2192"\+w*. \+w Te|strong="G3778"\+w* long te \+w a|strong="G0846"\+w* \+w khuehtawn|strong="G5224"\+w* a \+w haeh|strong="G1287"\+w* pah \+w dongah|strong="G5613"\+w* \+w amah|strong="G0846"\+w* a \+w khotoh|strong="G1225"\+w* nah\wj*.  
