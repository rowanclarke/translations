\p
\v 2 “\w When|strong="H3588"\w* \w you|strong="H3588"\w* \w are|strong="H5869"\w* living \w in|strong="H3068"\w* \w any|strong="H6213"\w* \w of|strong="H3068"\w* \w the|strong="H3588"\w* \w towns|strong="H8179"\w* \add in the land\add* \w that|strong="H3588"\w* \w Yahweh|strong="H3068"\w* \w our|strong="H3068"\w* \w God|strong="H3068"\w* \w is|strong="H3068"\w* \w giving|strong="H5414"\w* \w to|strong="H3068"\w* \w you|strong="H3588"\w*, \w suppose|strong="H3588"\w* \w you|strong="H3588"\w* hear \w that|strong="H3588"\w* \w there|strong="H4672"\w* \w is|strong="H3068"\w* some \w man|strong="H7451"\w* \w or|strong="H3068"\w* woman \w who|strong="H3068"\w* sins \w by|strong="H5674"\w* disobeying \w the|strong="H3588"\w* \w agreement|strong="H1285"\w* \w that|strong="H3588"\w* \w Yahweh|strong="H3068"\w* \w has|strong="H3068"\w* \w made|strong="H6213"\w* \w with|strong="H3068"\w* \w you|strong="H3588"\w*.  
