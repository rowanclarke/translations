\id LEV - Biblica® Open Igbo Contemporary Bible 2020
\h Levitikọs
\toc1 Levitikọs
\toc2 Levitikọs
\toc3 Lev
\mt1 Levitikọs
\c 1
\s1 Aja nsure ọkụ
\p 
\v 1 \nd Onyenwe anyị\nd* sitere nʼụlọ nzute ahụ kpọ Mosis oku, gwa ya sị,
\v 2 “Gwa ụmụ Izrel sị, ‘Mgbe onye ọbụla nʼime unu wetaara \nd Onyenwe anyị\nd* onyinye, ka onyinye ọ ga-eweta bụrụ anụ ụlọ si nʼetiti igwe ehi maọbụ igwe ewu na atụrụ.
\p 
\v 3 “ ‘Ọ bụrụ na ọ bụ onyinye aja nsure ọkụ\f + \fr 1:3 \fk Aja nsure ọkụ \ft Ọ bụ ụzọ anụ atọ ka a na-eji achụ aja nsure ọkụ, nke a na-adaba dịka aka si ruo onye ahụ na-achụ aja. Nke mbụ bụ ehi, nke dịrị ndị ọgaranya. Ọzọkwa, bụ ewu na atụrụ, ma banyere ndị ogbenye, ihe ha ga-eweta bụ nnụnụ nduru ma ọ bụ kpalakwukwu. \xt Lev 1:3,10,14; 5:7; 12:8; Luk 1:24\xt*\f* e wetara site nʼigwe ehi, ọ bụ oke ehi nke na-enweghị ntụpọ ka ọ ga-eweta. Nʼọnụ ụzọ ụlọ nzute ka ọ ga-eweta ya, ka ọ bụrụ ihe \nd Onyenwe anyị\nd* ga-anabata.
\v 4 Onye ahụ wetara ya ga-ebikwasị aka ya nʼisi anụ aja nsure ọkụ ahụ, a ga-anabata ya maka iji kpuchie mmehie ya.
\v 5 Nwoke ahụ ga-egbu nwa oke ehi ahụ nʼihu \nd Onyenwe anyị\nd*. Ụmụ ndị ikom Erọn, bụ ndị nchụaja ga-ewere ọbara ya fesa ya nʼakụkụ niile nke ebe ịchụ aja, nʼọnụ ụzọ e si abata ụlọ nzute ahụ.
\v 6 Ị ga-agba ehi aja nsure ọkụ ahụ akpụkpọ, bọkasịa ya ntakịrị ntakịrị.
\v 7 Ụmụ Erọn, ndị nchụaja ga-etinye ọkụ nʼebe ịchụ aja ahụ, doo nkụ nʼusoro nʼelu ya.
\v 8 Mgbe ahụ, ụmụ Erọn ndị nchụaja ga-atụkwasị akụkụ ehi ahụ niile, na isi ya, na abụba ya, nʼelu nkụ ahụ na-enwu ọkụ nʼebe ịchụ aja ahụ.
\v 9 Ma a ga-asacha ihe ndị dị nʼime afọ ya, na ụkwụ ya mmiri. Onye nchụaja ga-akpọ ha niile ọkụ nʼebe ịchụ aja ahụ. Ọ bụ onyinye aja nsure ọkụ, onyinye e nyere site nʼọkụ nke dị ezi ụtọ nye \nd Onyenwe anyị\nd*.
\p 
\v 10 “ ‘Ọ bụrụ na onyinye aja nsure ọkụ ahụ si nʼigwe ewu na atụrụ, ọ ga-abụrịrị mkpi maọbụ ebule na-enweghị nkwarụ.
\v 11 Onye wetara ya ga-egbu ya nʼihu \nd Onyenwe anyị\nd* nʼakụkụ ebe ịchụ aja chere ihu nʼugwu. Ụmụ ndị ikom Erọn, bụ ndị nchụaja, ga-efesa ọbara ya nʼakụkụ niile nke ebe ịchụ aja ahụ.
\v 12 Mgbe nke a gasịrị, onye ahụ wetara ya, ga-abọ ya. Onye nchụaja ga-ewere akụkụ ya niile, na isi ya, na abụba ya tụkwasị ha nʼelu nkụ ahụ na-enwu ọkụ dị nʼebe ịchụ aja.
\v 13 Ma ihe ndị dị nʼime afọ ya, na ụkwụ ya, ka onye ahụ ga-asa mmiri, tupu onye nchụaja eweta ha niile kpọọ ha ọkụ nʼebe ịchụ aja. Ọ bụ onyinye aja nsure ọkụ, onyinye e nyere site nʼọkụ, nke isisi ya dị ezi ụtọ nye \nd Onyenwe anyị\nd*.
\p 
\v 14 “ ‘Ọ bụrụ na onyinye ọ na-enye \nd Onyenwe anyị\nd* dịka aja nsure ọkụ bụ site nʼụmụ anụ ufe, ọ ghaghị ịbụ nduru, maọbụ nwa kpalakwukwu.
\v 15 Onye nchụaja ga-ewebata anụ ufe ahụ nʼebe ịchụ aja, tụbipụ isi ya, wụsa ọbara ya nʼakụkụ ebe ịchụ aja.
\v 16 Ọ ga-ewepụ akpa nri ya, na ihe dị ya nʼime, tụnye ha nʼakụkụ ọwụwa anyanwụ nke ebe ịchụ aja ahụ; ebe a na-ekposa ntụ.
\v 17 Ọ ga-ejide nku ya abụọ nyawaa ha, ma ọ gaghị anyakapụcha ha. Mgbe ahụ, onye nchụaja ahụ ga-akpọ ya ọkụ nʼelu ebe ịchụ aja. Ọ bụ aja nsure ọkụ, onyinye e nyere site nʼọkụ, nke isisi ya dị \nd Onyenwe anyị\nd* ezi ụtọ.
\c 2
\s1 Aja mkpụrụ ọka
\p 
\v 1 “ ‘Mgbe onye ọbụla wetaara \nd Onyenwe anyị\nd* onyinye mkpụrụ ọka, onyinye ya ga-abụ nke ezi ụtụ ọka a kwọrọ nke ọma. Ha ga-awụkwasị ya mmanụ oliv, tinyekwa ihe nsure ọkụ na-esi isi ụtọ nʼelu ya,
\v 2 ọ ga-ebutere ya ụmụ Erọn ndị nchụaja. Onye nchụaja ga-ekpoju ụtụ ọka na mmanụ ahụ nʼaka, tinyekwara ihe nsure ọkụ na-esi isi ụtọ niile ahụ, kpọọ ihe ndị a ọkụ dịka oke ncheta\f + \fr 2:2 \ft Nke nọchiri anya ụtụ ọka ahụ niile\f* nʼelu ebe ịchụ aja. Ọ ga-abụkwa onyinye nsure ọkụ, nke na-esi isi ụtọ nye \nd Onyenwe anyị\nd*.
\v 3 Ma nke fọdụrụ nʼonyinye ọka ahụ bụ nke Erọn na ụmụ ya. Ọ bụ oke dịkarịsịrị nsọ nke onyinye nsure ọkụ niile echere nʼihu \nd Onyenwe anyị\nd*.
\p 
\v 4 “ ‘Ọ bụrụ na onyinye mmadụ wetara bụ achịcha eghere nʼite e ji eghe ihe, ọ ga-abụ nke e ji ezi ụtụ ọka a kwọrọ nke ọma mee. Ọ ga-abụ ogbe achịcha agwara mmanụ oliv nke a na-ejighị ihe na-eko achịcha\f + \fr 2:4 \fq Ihe na-eko achịcha \ft Ọ bụ naanị nʼoge aja udo na mmemme izu asaa, ka a na-etinye ihe na-eko achịcha nʼụtụ ọka a na-eweta. \xt Lev 7:13; 23:17\xt*\f* mee, maọbụ achịcha mbadamba e tere mmanụ nke a na-ejighị ihe na-eko achịcha mee.
\v 5 Ọ bụrụ na onyinye mmadụ wetara bụ achịcha e ghere eghe, achịcha ahụ aghaghị ịbụ nke e mere site nʼezi ụtụ ọka a kwọrọ nke ọma, nke a gwakọtara mmanụ, nke na-enweghị ihe na-eko achịcha nʼime ya.
\v 6 Nyawasịa ya, wụkwasị ya mmanụ nʼelu, ọ bụkwa onyinye mkpụrụ ọka.
\v 7 Ọ bụrụ na onyinye mkpụrụ ọka gị bụ ihe e siri nʼite, ọ ghaghị ịbụ ezi ụtụ ọka a kwọrọ nke ọma, e tinyetụrụ mmanụ oliv.
\v 8 Ị ga-ebute onyinye mkpụrụ ọka ahụ bunye ya onye nchụaja. Ọ ga-eche ya nʼihu \nd Onyenwe anyị\nd* nʼebe ịchụ aja.
\v 9 Onye nchụaja ga-ekporo ụfọdụ nʼaka dịka oke ncheta nʼime onyinye ọka ahụ, kpọọ ya ọkụ nʼelu ebe ịchụ aja dịka aja e surere nʼọkụ, nke isisi ya na-atọ \nd Onyenwe anyị\nd* ezi ụtọ.
\v 10 Ma nke fọdụrụ nʼonyinye ọka ahụ bụ nke Erọn na ụmụ ya. Ọ bụ oke dịkarịsịrị nsọ nke onyinye nsure ọkụ niile echere nʼihu \nd Onyenwe anyị\nd*.
\p 
\v 11 “ ‘Unu etinyela ihe na-eko ọka ọbụla nʼonyinye mkpụrụ ọka unu na-enye \nd Onyenwe anyị\nd*, nʼihi na unu ekwesighị ịkpọ ihe na-eko achịcha maọbụ mmanụ aṅụ ọkụ nʼonyinye nsure ọkụ unu na-enye \nd Onyenwe anyị\nd*.
\v 12 Unu nwere ike nye \nd Onyenwe anyị\nd* achịcha e ji ihe na-eko achịcha na mmanụ aṅụ mee nʼoge onyinye owuwe ihe ubi, ma a gaghị eme otu a nʼoge onyinye ọchụchụ aja nsure ọkụ, nke na-esi isi ụtọ.
\v 13 Unu aghaghị itinye nnu\f + \fr 2:13 \fq Nnu \ft Nnu na-echekwa ihe ka ọ ghara imebi.\f* nʼime onyinye mkpụrụ ọka ọbụla unu na-enye. Unu ahapụla ọgbụgba ndụ Chineke unu nʼonyinye mkpụrụ ọka unu. Tinyenụ nnu nʼonyinye unu niile.
\p 
\v 14 “ ‘Ọ bụrụ na onyinye mkpụrụ ọka ị na-ewetara \nd Onyenwe anyị\nd* bụ mkpụrụ mbụ nke ubi gị, site nʼọka ọhụrụ gị weta ọka a sụrụ asụ, maọbụ nke a hụrụ nʼọkụ.
\v 15 Tinye ya mmanụ na ụda na-esi isi ụtọ. Ọ ga-abụ onyinye ọka.
\v 16 Onye nchụaja ga-ewere oke ncheta nʼime ọka ahụ a sụrụ asụ, nke a gwara mmanụ na ụda na-esi isi ụtọ, dịka onyinye nsure ọkụ nye \nd Onyenwe anyị\nd*.
\c 3
\s1 Aja Udo
\p 
\v 1 “ ‘Ọ bụrụ na onye ọbụla achọọ inye onyinye aja udo, o nwere ike jiri anụ ụlọ si nʼigwe ehi, oke ehi maọbụ nwunye ehi. Ma anụ ahụ ọ ga-ewebata nʼihu \nd Onyenwe anyị\nd* aghaghị ịbụ ehi na-enweghị nkwarụ.
\v 2 Onye ahụ wetara ya, ga-ebikwasị aka ya nʼisi anụ ahụ, gbuo ya nʼọnụ ụzọ ụlọ nzute. Mgbe ahụ ụmụ Erọn ndị ikom, bụ ndị nchụaja,\f + \fr 3:2 \ft \xt Lev 1:5\xt*\f* ga-efesa ọbara ya nʼakụkụ niile nke ebe ịchụ aja.
\v 3 Site nʼonyinye aja udo, ị ga-eweta onyinye nsure ọkụ nye \nd Onyenwe anyị\nd*: abụba niile kpuchiri ihe dị nʼime afọ ya, na abụba niile nke metụtara ha,
\v 4 akụrụ ya abụọ na abụba nke dị nʼelu ha ruo nʼakụkụ ukwu ya, na umeju ya na abụba kpuchiri umeju ya, nke ọ ga-ewepụ ya na akụrụ ya.
\v 5 Mgbe ahụ, ụmụ Erọn ga-esunye ha ọkụ nʼelu aja nsure ọkụ a tụkwasịrị nʼosisi e sunyere ọkụ, ọ bụ onyinye nsure ọkụ, nke na-esi isi ụtọ nye \nd Onyenwe anyị\nd*.
\p 
\v 6 “ ‘Ọ bụrụ na onyinye aja udo a na-achụrụ \nd Onyenwe anyị\nd* bụ site nʼigwe ewu maọbụ atụrụ, ọ ghaghị ịbụ mkpi maọbụ nne ewu na-enweghị ntụpọ.
\v 7 Ọ bụrụ onyinye atụrụ, onye ahụ ga-ewebata ya nʼihu \nd Onyenwe anyị\nd*.
\v 8 Ọ ga-ebikwasị aka ya nʼisi atụrụ ahụ, gbuo ya nʼọnụ ụzọ ụlọ nzute. Ndị nchụaja, ụmụ Erọn, ga-efesa ọbara ya nʼakụkụ niile nke ebe ịchụ aja ahụ.
\v 9 Ị ga-esite nʼonyinye aja udo a, weta onyinye nsure ọkụ nye \nd Onyenwe anyị\nd*: abụba ya, na abụba niile dị nʼọdụdụ ya nke a ga-esite nʼakụkụ ọkpụkpụ azụ ya bepụta, na abụba kpuchiri ihe dị nʼime afọ ya; na abụba niile nke metụtara ha,
\v 10 na akụrụ ya abụọ, na abụba kpuchiri ha ruo nʼakụkụ ukwu ya, na umeju ya, na abụba kpuchiri ya; nke ọ ga-ewepụ ya na akụrụ ya.
\v 11 Onye nchụaja ga-akpọ ha ọkụ nʼebe ịchụ aja dịka ihe oriri, onyinye nsure ọkụ nye \nd Onyenwe anyị\nd*.
\p 
\v 12 “ ‘Ọ bụrụ na onye ọbụla eweta ewu dịka onyinye ọ na-eche nʼihu \nd Onyenwe anyị\nd*,
\v 13 ọ ga-ebikwasị aka ya nʼisi ewu ahụ, gbuo ya nʼọnụ ụzọ ụlọ nzute. Ụmụ Erọn ndị ikom ga-efesa ọbara ya nʼakụkụ niile nke ebe ịchụ aja.
\v 14 Ọ bụ site nʼonyinye nke i wetara ka ị ga-esi chee onyinye nsure ọkụ nye \nd Onyenwe anyị\nd*: abụba niile kpuchiri ihe dị nʼime afọ ya na abụba niile metụtara ha,
\v 15 na akụrụ ya abụọ, na abụba kpuchiri ha ruo nʼakụkụ ukwu ya, na ihe kpuchiri umeju ya; nke ọ ga-ewepụ ya na akụrụ ya.
\v 16 Onye nchụaja ga-akpọ ha ọkụ nʼelu ebe ịchụ aja dịka ihe oriri, onyinye nsure ọkụ, nke na-esi isi ụtọ. Abụba niile bụ nke \nd Onyenwe anyị\nd*.
\p 
\v 17 “ ‘Iwu ndị a ga-adịgide site nʼọgbọ ruo nʼọgbọ. Unu ga-edebezu ya nʼebe ọbụla unu bi. Unu agaghị eri abụba maọbụ ọbara ọbụla.’ ”\f + \fr 3:17 \ft \xt Lev 7:25-26; 17:10-14.\xt*\f*
\c 4
\s1 Aja mmehie, na usoro aja ndị ọzọ
\p 
\v 1 \nd Onyenwe anyị\nd* gwara Mosis sị,
\v 2 “Gwa ụmụ Izrel okwu, sị ha, ‘Mgbe onye ọbụla mehiere na-amaghị ama, megide ihe ọbụla \nd Onyenwe anyị\nd* nyere nʼiwu:
\p 
\v 3 “ ‘Ọ bụrụ na onye nchụaja e tere mmanụ emehie na-amaghị ama, si otu a weta ikpe ọmụma nʼisi ọha mmadụ. Ọ ga-ewetara \nd Onyenwe anyị\nd* otu oke ehi na-enweghị ntụpọ dịka aja mmehie, nʼihi mmehie ahụ o mere.
\v 4 Ọ ga-ewere oke ehi ahụ bịa nʼọnụ ụzọ ụlọ nzute, nʼihu \nd Onyenwe anyị\nd*. Ọ ga-ebikwasị aka ya nʼisi ya, gbuo ya nʼebe ahụ nʼihu \nd Onyenwe anyị\nd*.
\v 5 Mgbe ahụ, onye nchụaja e tere mmanụ ga-eburu ụfọdụ ọbara oke ehi ahụ baa nʼime ụlọ nzute.
\v 6 Ọ ga-edenye mkpịsịaka ya nʼime ọbara ahụ, fesa ya ugboro asaa nʼihu \nd Onyenwe anyị\nd*, nʼihu akwa mgbochi nke ebe nsọ ahụ.
\v 7 Onye nchụaja ga-etekwasị ụfọdụ ọbara ahụ na mpi dị nʼebe ịchụ aja nke aja nsure ọkụ ihe na-esi isi ụtọ, nʼihu \nd Onyenwe anyị\nd* nʼime ụlọ nzute. Ọbara fọdụrụ nʼoke ehi ahụ ka ọ ga-awụsa nʼụkwụ ebe ịchụ aja nke aja nsure ọkụ ahụ, nʼọnụ ụzọ ịba ụlọ nzute.
\v 8 Ọ ga-ewepụ abụba niile site nʼoke ehi aja mmehie, abụba niile kpuchiri ihe dị nʼime afọ ya na nke jikọtara ha,
\v 9 na akụrụ ya abụọ na abụba kpuchiri ha ruo nʼakụkụ ukwu ya, na ihe kpuchiri umeju ya, nke ọ ga-ewepụ ya na akụrụ ya,
\v 10 dịka e si ewepụ abụba oke ehi e ji chụọ aja udo. Mgbe ahụ, onye nchụaja ga-akpọ ha ọkụ nʼelu ebe ịchụ aja nke aja nsure ọkụ.
\v 11 Ma akpụkpọ anụ oke ehi ahụ na ahụ ya niile, ma isi ya, na ụkwụ ya, na ihe dị nʼime afọ ya, na mgbịrị afọ ya,
\v 12 ihe niile fọdụrụ nʼoke ehi ahụ, ka a ga-ebupu nʼazụ ebe obibi ụmụ Izrel, ebe dị ọcha, ebe a na-ekpofu ntụ. Ebe ahụ ka a ga-anọ kpọọ ya ọkụ, nʼọkụ a kwanyere nʼebe a na-ekpofu ntụ.
\p 
\v 13 “ ‘Ọ bụrụ na nzukọ Izrel niile emehie na-amaghị ama, mee ihe ọbụla megidere ihe \nd Onyenwe anyị\nd* nyere nʼiwu nke a na-adịghị eme eme, ọ bụ ezie na ndị obodo amaghị okwu a, mgbe ha ghọtara ikpe ọmụma ha
\v 14 matakwa mmehie ha mehiere, nzukọ ahụ aghaghị iweta nwa oke ehi dịka aja mmehie, duru ya chee ya nʼihu ụlọ nzute.
\v 15 Ndị okenye nzukọ Izrel ga-ebikwasị aka\f + \fr 4:15 \ft \xt Lev 8:14,22; Ọnụ 8:8-10\xt*\f* ha nʼisi oke ehi ahụ nʼihu \nd Onyenwe anyị\nd*. A ga-egbu ehi ahụ nʼihu Onyenwe anyị.
\v 16 Mgbe ahụ, onye nchụaja e tere mmanụ ga-ewere ụfọdụ nʼime ọbara ya baa nʼụlọ nzute.
\v 17 Ọ ga-edenye mkpịsịaka ya nʼime ọbara ahụ fesa ya ugboro asaa nʼihu \nd Onyenwe anyị\nd*, nʼihu akwa mgbochi ahụ.
\v 18 Ọ ga-ete ọbara ụfọdụ nʼelu mpi nke dị nʼebe ịchụ aja nke dị nʼihu \nd Onyenwe anyị\nd*, nʼụlọ nzute. Ọ ga-awụ ọbara nke fọdụrụ nʼụkwụ ala ala, nʼebe ịchụ aja nke aja nsure ọkụ, nʼọnụ ụzọ ụlọ nzute.
\v 19 Ọ ga-ewepụta abụba niile dị ya nʼahụ kpọọ ha ọkụ nʼelu ebe ịchụ aja.
\v 20 Ọ ga-eme oke ehi ahụ ihe o mere oke ehi aja mmehie. Nʼụzọ dị otu a, onye nchụaja ga-ekpuchi mmehie ndị Izrel. A ga-agbagharakwa ha.
\v 21 Emesịa, onye nchụaja ga-eburu ozu oke ehi ahụ gaa nʼazụ obodo kpọọ ya ọkụ nʼebe ahụ, dịka o mere oke ehi nke mbụ. Nke a bụ aja mmehie nʼihi nzukọ Izrel.
\p 
\v 22 “ ‘Mgbe otu nʼime ndịisi obodo mehiere na-amaghị ama, si otu a megide ihe \nd Onyenwe anyị\nd* Chineke nyere nʼiwu banyere ihe a na-agaghị eme, mgbe ọ ghọtara ikpe ọmụma ya.
\v 23 Ọ bụrụkwa na-eme ka ọ mata mmehie ya, ọ ghaghị iweta mkpi na-enweghị nkwarụ dịka onyinye nʼihi mmehie ya.
\v 24 Ọ ga-ebikwasị aka ya nʼisi mkpi ahụ. Gbuo ya nʼebe a na-egbu anụ aja nsure ọkụ, nʼihu \nd Onyenwe anyị\nd*. Ọ bụ aja mmehie.
\v 25 Mgbe ahụ, onye nchụaja ga-arụrụ ụfọdụ nʼime ọbara aja mmehie ahụ na mkpịsịaka ya tee ya nʼelu mpi ebe ịchụ aja nke aja nsure ọkụ.\f + \fr 4:25 \ft \xt Lev 9:9\xt*\f* Nke fọdụrụ ka ọ ga-awụpụ nʼụkwụ ala ala ebe ịchụ aja.
\v 26 Ọ ga-akpọ abụba ya niile ọkụ nʼebe ịchụ aja dịka o si kpọọ abụba anụ e ji chụọ aja udo ọkụ. Nʼụzọ dị otu a, onye nchụaja ga-ekpuchiri onyeisi ahụ mmehie ya. A ga-agbaghara ya.
\p 
\v 27 “ ‘Ọ bụrụ na otu onye nʼetiti ndị obodo ahụ emehie na-amaghị ama, mee ihe megidere ihe ọbụla \nd Onyenwe anyị\nd* nyere nʼiwu nke a na-adịghị eme eme, mgbe ha ghọtara ikpe ọmụma ha,
\v 28 ọ bụrụkwa na-amata mmehie ha mere, ha ga-eweta nne ewu na-enweghị ntụpọ dịka onyinye nʼihi mmehie ya.
\v 29 Ọ ga-ebikwasị aka ya nʼelu isi aja mmehie ahụ, e gbuo ya nʼebe a na-achụ aja nsure ọkụ.
\v 30 Onye nchụaja ga-ewere ụfọdụ ọbara ahụ na mkpịsịaka ya tee ya na mpi nke ebe ịchụ aja nke aja nsure ọkụ, ọ ga-awụ ọbara fọdụrụ nʼụkwụ ala ala ebe ịchụ aja.
\v 31 Ọ ga-ewepụ abụba ya niile dịka a na-eme nʼaja udo. Onye nchụaja ga-akpọ ha ọkụ nʼebe ịchụ aja, dịka ihe na-esi isi ụtọ nye \nd Onyenwe anyị\nd*. Nʼụzọ dị otu a, onye nchụaja a ga-ekpuchikwara ha mmehie. A ga-agbagharakwa ha.
\p 
\v 32 “ ‘Ma ọ bụrụ na mmadụ eweta otu atụrụ dịka onyinye nʼihi aja mmehie ya, ọ ghaghị ịbụ nne atụrụ na-enweghị ntụpọ.
\v 33 Ọ ga-eweta ya nʼebe a na-egbu anụ aja nsure ọkụ. Ọ ga-ebikwasị ya aka nʼisi, gbuo ya nʼebe ahụ, ka ọ bụrụ aja mmehie ya.
\v 34 Onye nchụaja ga-ewere ụfọdụ ọbara anụ aja mmehie ahụ na mkpịsịaka ya, tee ya na mpi dị nʼebe ịchụ aja nke aja nsure ọkụ. Ọ ga-awụ ọbara fọdụrụ nʼụkwụ ala ala nke ebe ịchụ aja.
\v 35 Ha ga-ewepụ abụba ya niile, dịka a na-eme nʼatụrụ aja udo. Onye nchụaja ga-akpọ abụba ahụ ọkụ nʼelu ebe ịchụ aja dịka onyinye nsure ọkụ a chụrụ nye \nd Onyenwe anyị\nd*. Nʼụzọ dị otu a, onye nchụaja ga-ekpuchikwara ha mmehie nʼihi iwu ha dara. A ga-agbaghara ha mmehie ha.
\c 5
\p 
\v 1 “ ‘Ọ bụrụ na mmadụ ọbụla emehie nʼihi na ọ jụrụ ikwupụta mgbe ọ nụrụ ọkwa amaara nʼọha maka ịgba ama banyere ihe ọ hụrụ maọbụ ihe ọ maara, ọ bụ onye ikpe mara.
\p 
\v 2 “ ‘Onye na-amaghị ama metụ ihe rụrụ arụ aka, dịka ozu anụ ọbụla iwu megidere, maọbụ anụ ụlọ, maọbụ anụ ọhịa, maọbụ anụ ọbụla na-akpụ akpụ nʼala. Ọ ghọọla onye rụrụ arụ, na onye ikpe mara.
\v 3 Ma ọ bụrụ na ha emetụ ihe ọbụla rụrụ arụ si nʼahụ mmadụ pụta aka, ihe ọbụla ga-eme ya ka ọ hapụ ịdị ọcha, ọ bụ ezie na ha amaghị na ọ bụ ihe rụrụ arụ, mgbe ọ matara ya, ọ ga-abụ onye ikpe mara.
\v 4 Ọ bụrụ na mmadụ a ṅụọ iyi nzuzu, nke ga-akwagide ya ime ihe ọbụla maọbụ ihe dị mma, maọbụ ihe dị njọ, mgbe onye ahụ ghọtara na ọ bụ iyi nzuzu ka ọ ṅụrụ, ọ bụrụla onye ikpe mara.
\v 5 Onye ọbụla sitere nʼụzọ dị otu a bụrụ onye ikpe mara, ga-ekwupụta mmehie ya,\f + \fr 5:5 \ft \xt Ọnụ 5:7\xt*\f* dịka o si dị.
\v 6 Ọ ga-ewetara \nd Onyenwe anyị\nd* nne atụrụ, maọbụ nne ewu site nʼigwe ewu na atụrụ, dịka aja ikpe ọmụma maka mmehie ha mere. Onye nchụaja ga-achụrụ ha aja mkpuchi mmehie maka mmehie ha.
\p 
\v 7 “ ‘Ọ bụrụ na o nweghị ike iweta atụrụ, ọ ga-ewetara \nd Onyenwe anyị\nd* nduru abụọ, maọbụ kpalakwukwu abụọ, dịka ihe ikpe ọmụma mmehie ha. Otu nʼime nnụnụ ndị a ga-abụ maka aja mmehie, nke ọzọ ga-abụ maka aja nsure ọkụ.
\v 8 Ọ ga-eweta ha nye onye nchụaja. Onye ga-ewere nnụnụ nke mbụ chụọ aja mmehie. Ọ ga-atụbipụ olu ya, kama ọ gaghị ekewapụcha isi nnụnụ ahụ site nʼahụ ya.
\v 9 Ọ ga-efesa ụfọdụ ọbara aja mmehie ahụ nʼakụkụ ebe ịchụ aja, ma ọbara fọdụrụ ka ọ ga-awụsa nʼụkwụ ala ala ebe ịchụ aja. Nke a ga-abụ aja mmehie.
\v 10 Onye nchụaja ga-eji nnụnụ nke ọzọ chụọ aja nsure ọkụ. Ọ ga-agbaso usoro e debere maka ịchụ aja nsure ọkụ.\f + \fr 5:10 \ft \xt Lev 1:14-17\xt*\f* Ọ ga-ekpuchikwara ha mmehie ha mere. A ga-agbagharakwa ha.
\p 
\v 11 “ ‘Ọ bụrụ na onye ahụ enweghị ike iweta nduru abụọ, maọbụ kpalakwukwu abụọ, ọ ga-eweta iko ọka asaa a kwọrọ nke ọma ka ọ bụrụ onyinye aja mmehie. Ọ gaghị etinye ya mmanụ oliv na ụda na-esi isi ụtọ, nʼihi na ọ bụ aja mmehie.
\v 12 Ha ga-ewere ya bịakwute onye nchụaja, onye ga-ekporo nke ga-eju ya aka ya dịka oke ncheta. Kpọọ ya ọkụ nʼebe ịchụ aja nke onyinye nsure ọkụ e chere nʼihu \nd Onyenwe anyị\nd*. Nke a ga-abụkwa aja mmehie ya.
\v 13 Nʼụzọ dị otu a, onye nchụaja ga-achụrụ ya aja ikpuchi mmehie ya niile. A ga-agbagharakwa ya. Ụtụ ọka fọdụrụ ga-abụ nke onye nchụaja, dịka e si mee ya nʼaja onyinye mkpụrụ ọka.’ ”
\s1 Aja ikpe ọmụma
\p 
\v 14 \nd Onyenwe anyị\nd* gwara Mosis sị,
\v 15 “Mgbe onye ọbụla sitere na-amaghị ama mehie, merụọ ihe nsọ niile nke \nd Onyenwe anyị\nd*, bụrụ onye nke nʼekwesighị ntụkwasị obi nye \nd Onyenwe anyị\nd*. Ọ ga-ewetara \nd Onyenwe anyị\nd* otu ebule na-enweghị ntụpọ site nʼigwe anụ, dịka ọnụahịa ya si dị nʼọlaọcha, nʼusoro shekel nke ebe nsọ.\f + \fr 5:15 \ft Ya bụ ọnụ ego, dịka ndị ikpe kpebiri ya.\f* Ọ bụ aja ikpe ọmụma.
\v 16 Ọ ga-akwụghachikwa ụgwọ ihe nsọ ndị ahụ niile nke ọ na-emezughị. Ọ ga-atụkwasị otu ụzọ nʼime ụzọ ise nke ọnụahịa ya nʼelu ya, were ha niile nye onye nchụaja. Onye nchụaja ahụ ga-ewere ebule ahụ na ihe ndị a chụọrọ ya aja mkpuchi mmehie, nʼihi ikpe ọmụma ya. A ga-agbagharakwa ya.
\p 
\v 17 “Ma ọ bụrụ na mmadụ ọbụla emehie, mee ihe ọbụla megidere iwu ọbụla \nd Onyenwe anyị\nd* nyere, ọ bụ ezie na e mere mmehie a na-amaghị ama, ma ikpe mara ha, ọ ga-atakwa ahụhụ soo ya.
\v 18 Ọ ga-ewetara onye nchụaja ihe aja ikpe ọmụma nke bụ otu ebule na-enweghị ntụpọ site nʼigwe anụ, nke ọnụahịa ga-abụ ihe o ruru. Nʼụzọ dị otu a, onye nchụaja ga-achụrụ ya aja mkpuchi mmehie nʼihi ihe ọjọọ o mere na-amaghị ama. A ga-agbaghara ya mmehie ya.
\v 19 Ọ bụ aja ikpe ọmụma, nʼihi na onye mehiere megide \nd Onyenwe anyị\nd* ka ọ bụ.”
\c 6
\p 
\v 1 \nd Onyenwe anyị\nd* gwara Mosis sị,
\v 2 “Ọ bụrụ na onye ọbụla emehie bụrụ onye na-ekwesighị ntụkwasị obi nye \nd Onyenwe anyị\nd*, site nʼiduhie onye agbataobi ya banyere ihe e tinyere ya nʼaka idebe, maọbụ izunarị mmadụ ihe, maọbụ iji aghụghọ nara mmadụ ibe ya ihe;
\v 3 maọbụ site nʼijide ihe furu efu nke ọ chọtara ghaa ụgha banyere ya. Ma ọ bụrụ na ha a ṅụọ iyi na ha ejighị ya, maọbụ gbasara ụdị mmehie mmadụ pụrụ ime.
\v 4 Mgbe ha mehiere nʼụzọ ọbụla nʼime ụzọ ndị a niile, ghọta na ikpe mara ha. Ha aghaghị inyeghachi onye nwe ihe ahụ ha zuru nʼohi, maọbụ ihe ha pụnara nʼike, maọbụ ihe e nyere ya idebe, ma ọ bụkwanụ ihe ahụ furu efu ọ chọtara,
\v 5 maọbụ ihe ọbụla ọ ṅụrụ nʼiyi ụgha. Ọ ga-akwụghachi ihe ndị a niile nʼuju, tụkwasịkwa otu ụzọ nʼime ụzọ ise\f + \fr 6:5 \ft \xt Ọnụ 5:7\xt*\f* nke ọnụahịa ihe ahụ, nyeghachi ya onye nwe ya, nʼụbọchị ahụ ọ ga-eweta aja ikpe ọmụma ya.
\v 6 Ọ ga-ewetara onye nchụaja nʼihu \nd Onyenwe anyị\nd*, aja ikpe ọmụma ya nke bụ ebule na-enweghị ntụpọ site nʼigwe anụ, nke ọnụahịa ya ga-abụ ihe ahụ e gbubiri iji ịkwụ ụgwọ mmehie.
\v 7 Nʼụzọ dị otu a, onye nchụaja ga-ekpuchikwara ya mmehie ya nʼihu \nd Onyenwe anyị\nd*, a ga-agbaghakwara ha nʼihi ihe ọbụla ha mere nke ikpe ji maa ha.”
\s1 Aja nsure ọkụ
\p 
\v 8 \nd Onyenwe anyị\nd* gwara Mosis okwu sị ya,
\v 9 “Nye Erọn na ụmụ ya ndị ikom iwu sị: ‘Ndị a bụ usoro iwu metụtara aja nsure ọkụ. Aja nsure ọkụ ga-adịgide nʼekwu ahụ dị nʼebe ịchụ aja site nʼabalị ruo nʼụtụtụ. A ga-akwanyekwa ọkụ na-adị nʼebe ịchụ aja hapụ ya ka o nwuo abalị niile.
\v 10 Mgbe chi bọrọ, onye nchụaja ga-eyiri uwe ime ahụ ya nke akwa ọcha, nakwa uwe elu ahụ ya, gaa kpopu ntụ dị nʼekwu nke ebe ịchụ aja nsure ọkụ ahụ, wụsa ha nʼakụkụ ebe ịchụ aja ahụ.
\v 11 Mgbe o mesịrị nke a, ọ ga-agbanwe uwe ya, kporo ntụ ahụ, buru ya pụọ nʼazụ ogige ahụ gaa wufuo ya nʼebe ahụ e mere ka ọ dị ọcha.
\v 12 Ọkụ dị nʼebe ịchụ aja ga na-enwu mgbe niile, a gaghị ekwe ka ọ nyụọ. Nʼụtụtụ niile onye nchụaja ga-akwanye ya nkụ ọhụrụ, tụkwasịkwa aja nsure ọkụ nʼelu ya surekwaa abụba aja udo nʼelu ya.
\v 13 Ọkụ ga-enwugide nʼebe ịchụ aja mgbe niile. A gaghị ekwe ka ọ nyụọ mgbe ọbụla.’
\s1 Aja mkpụrụ ọka
\p 
\v 14 “ ‘Ndị a bụ usoro iwu gbasara onyinye mkpụrụ ọka. Ụmụ Erọn ndị ikom ga-eguzo nʼihu ebe ịchụ aja iche ya nʼihu \nd Onyenwe anyị\nd*.
\v 15 Mgbe ahụ, onye nchụaja ga-ekpoju ọka ahụ a kwọrọ nke ọma, na ụfọdụ mmanụ oliv, tinyere ụda na-esi isi ụtọ nʼaka ya dịka oke ncheta. Kpọọ ya ọkụ nʼelu ebe ịchụ aja ka ọ nọchie anya onyinye ahụ niile, nke isisi ya dị \nd Onyenwe anyị\nd* ezi mma.
\v 16 \f + \fr 6:16 \ft \xt Lev 2:3\xt*\f*Erọn na ụmụ ya ndị ikom ga-eri nke fọdụrụnụ. Ma a ga-eri ya na-ejighị ihe na-eko achịcha, nʼime ebe nsọ, nʼogige ụlọ nzute ka a ga-anọ eri ya.
\v 17 Agaghị etinye ya ihe na-eko achịcha ma a na-eghe ya. Enyela ya ka ọ bụrụ oke ruuru ha site nʼonyinye nsure ọkụ e chere nʼihu m. Ha bụkwa ihe dịkarịsịrị nsọ, dịka aja ikpe ọmụma na aja mmehie.
\v 18 Nwoke ọbụla sitere nʼagbụrụ Erọn, onye nchụaja, nwere ike iri ya. Ọ bụ oke ọ ga na-eketa site nʼonyinye nsure ọkụ niile echere nʼihu \nd Onyenwe anyị\nd* ruo nʼọgbọ niile na-abịa. Ihe ọbụla metụrụ ha ahụ ga-aghọ ihe dị nsọ.’ ”
\p 
\v 19 \nd Onyenwe anyị\nd* gwakwara Mosis sị,
\v 20 “Nke a bụ aja Erọn na ụmụ ya ndị ikom ga-achụrụ \nd Onyenwe anyị\nd* nʼụbọchị a ga-ete ya mmanụ. Ọ ga-abụ ọtụtụ ruru lita abụọ nke ọka dị ezi mma dịka aja onyinye a na-achụ mgbe niile. Ha ga-enye otu ọkara ya nʼụtụtụ, nye nke ọzọ nʼuhuruchi.
\v 21 Ha ga-etinye ya mmanụ, ghee ya nʼite. Ị ga-ebubata ya mgbe a gwọkọrọ ya nke ọma, chee ya dịka aja ọka a nyawasịrị anyawasị nke isisi ya dị \nd Onyenwe anyị\nd* ezi mma.
\v 22 Nwa nwoke ahụ nke ga-anọchi ya dịka onye nchụaja e tere mmanụ bụ onye ga-akwado ya. Ọ bụ oke ruuru \nd Onyenwe anyị\nd* ebighị ebi, bụrụkwa nke a ga-esure ọkụ kpamkpam.
\v 23 Onyinye mkpụrụ ọka ọbụla nke onye nchụaja nyere ka a ga-akpọ ọkụ kpamkpam. A gaghị eri ya eri.”
\s1 Aja mmehie
\p 
\v 24 \nd Onyenwe anyị\nd* sịrị Mosis,
\v 25 “Gwa Erọn na ụmụ ya ndị ikom, sị, ‘Ndị a bụ usoro iwu unu ga-edebe banyere aja mmehie. A ga-egbu anụ aja mmehie nʼihu \nd Onyenwe anyị\nd*, nʼebe ahụ a na-egbu anụ aja nsure ọkụ. Ọ bụ ihe dịkarịsịrị nsọ.
\v 26 Onye nchụaja chụrụ ya ga-eri anụ ya, ọ bụ nʼakụkụ ebe nsọ ahụ, ya bụ nʼogige ụlọ nzute ahụ ka a ga-anọ rie ya.
\v 27 Ihe ọbụla metụrụ anụ nke ọbụla aka, ga-aghọ ihe dị nsọ. Ọ bụrụkwa na ọbara ya efesa nʼuwe ọbụla, ị ga-asụ uwe ahụ nʼakụkụ ebe nsọ ahụ.
\v 28 A ghaghị itiwa ite aja e ji sie anụ ahụ. Ọ bụrụkwanụ nʼite bronz ka e siri ya, a ga-asa ite ahụ mmiri nke ọma, saa ya ka ọ dị ezi ọcha.
\v 29 Nwoke ọbụla a mụrụ nʼezinaụlọ ndị nchụaja nwere ike iri anụ ahụ, ọ bụ ihe dịkarịsịrị nsọ.
\v 30 Ma a gaghị eri anụ aja mmehie ọbụla, bụ nke e webatara ọbara ya nʼime ụlọ nzute maka ikpuchi mmehie nʼEbe nsọ ahụ. Aghaghị ịkpọ ya ọkụ.
\c 7
\s1 Aja ikpe ọmụma
\p 
\v 1 “ ‘Ndị a bụ usoro iwu banyere aja ikpe ọmụma, bụ nke dịkarịsịrị nsọ.
\v 2 A ga-egbu anụ aja ikpe ọmụma ahụ nʼebe a na-egbu anụ aja nsure ọkụ, were ọbara ya fesaa nʼakụkụ niile nke ebe ịchụ aja.
\v 3 Abụba ya niile ka a ga-enye dịka onyinye: abụba dị nʼọdụdụ ya, na abụba niile kpuchiri ihe dị nʼime afọ ya,
\v 4 na akụrụ abụọ ya, na abụba nke dị nʼelu ha, ruo nʼakụkụ ukwu ya, na umeju ya, na abụba kpuchiri ya.
\v 5 Onye nchụaja ga-akpọ ha ọkụ nʼelu ebe ịchụ aja dịka onyinye nsure ọkụ nye \nd Onyenwe anyị\nd*. Ọ bụ aja ikpe ọmụma.
\v 6 Nwoke ọbụla a mụrụ nʼezinaụlọ ndị nchụaja nwere ike iri anụ fọdụrụ na ya, maọbụ nʼebe nsọ ka aghaghị ịnọ rie ya. Ọ bụ ihe dịkarịsịrị nsọ.
\p 
\v 7 “ ‘Otu iwu a metụtakwara aja ikpe ọmụma na aja mmehie. Anụ ọbụla fọdụrụ ga-abụ nke onye nchụaja ahụ nke ji ha chụọ aja mkpuchi mmehie. Oke ya ka ọ bụ.
\v 8 Onye nchụaja nke chụrụ aja nsure ọkụ nʼisi onye ọbụla, ka ọ dịrị iwere akpụkpọ niile si nʼanụ ahụ o ji chụọ aja nye onwe ya.
\v 9 A ga-ebunye onye nchụaja chụrụ aja mkpụrụ ọka nke e ji ụtụ ọka chụọ, ụtụ ọka fọdụrụ. Otu a ka ọ ga-adịkwa nʼaja achịcha ọbụla a nụrụ anụ, maọbụ nke e siri esi, maọbụ nke e ghere eghe. Ihe ọbụla fọdụrụ ga-abụ nke onye nchụaja ahụ.
\v 10 Aja mkpụrụ ọka ọbụla, ma nke e tinyere mmanụ, ma nke a na-etinyeghị mmanụ, nke fọdụrụ ga-abụ nke ụmụ ndị ikom Erọn.
\s1 Aja udo
\p 
\v 11 “ ‘Ndị a bụ usoro iwu gbasara aja udo nke mmadụ ọbụla nwere ike chụọrọ \nd Onyenwe anyị\nd* nʼaja:
\p 
\v 12 “ ‘Ọ bụrụ na ha enye ya dịka aja ekele, tinyere aja ekele a ha ga-eweta ogbe achịcha a na-ejighị ihe na-eko achịcha mee, nke a gwakọtara ya na mmanụ oliv, na mbadamba achịcha a na-ejighị ihe na-eko achịcha mee, nke e tere mmanụ nʼelu ya, nakwa achịcha e ji ọka a kwọrọ nke ọma a gwakọtara ya na mmanụ nʼime ya.
\v 13 Ọ ga-ewetakwa onyinye achịcha ọzọ nke e ji ihe na-eko achịcha, ya bụ, yiist mee, tinyere aja udo nke ekele ha.
\v 14 Ha ga-esikwa na ya weta otu nʼime onyinye ọbụla, chee nʼihu \nd Onyenwe anyị\nd*, dịka onyinye. Ọ bụ nke ndị nchụaja ahụ na-efesa ọbara anụ e ji chụọ aja udo nʼelu ebe ịchụ aja.
\v 15 Ma anụ ahụ eji chụọ aja onyinye udo nke ekele, ka a ga-eri nʼotu ụbọchị ahụ e ji ha chụọ aja. O nweghị nke a ga-ahapụ ka ọ bọọ chi.
\p 
\v 16 “ ‘Ma ọ bụrụ na onyinye mmadụ wetara bụ onyinye afọ ofufu, maọbụ onyinye o wetara nʼihi nkwa o kwere, a ga-eri anụ aja ahụ nʼụbọchị ahụ a chụrụ ya, nweekwa ike rie nke fọdụrụ ma chi bọọ.
\v 17 Ma anụ ọbụla fọdụrụ nʼime anụ aja ahụ, nke a na-erichapụghị nʼụbọchị nke abụọ ahụ ka a ga-akpọ ọkụ.
\v 18 Ọ bụrụ na e rie anụ aja udo ahụ nʼụbọchị nke atọ, a gaghị anabata ya. A gaghị agụnyere ya onye ahụ wetara ya nʼihi na ihe rụrụ arụ ka ọ bụ. Onye ọbụla riri ya ga-abụ onye ikpe mara.
\p 
\v 19 “ ‘Anụ ọbụla nke metụrụ ihe rụrụ arụ aghọọla ihe na-adịghị ọcha. A gaghị eri ya. A ga-akpọ ya ọkụ. Ma nʼebe anụ ndị ọzọ dị, onye ọbụla e mere ka ọ dị ọcha nwere ike iri ya.
\v 20 A ga-esite nʼetiti ndị m kewapụ onye ọbụla riri anụ e ji chụọ aja udo nye \nd Onyenwe anyị\nd* mgbe onye ahụ nọ nʼọnọdụ adịghị ọcha.
\v 21 Onye ọbụla metụrụ ihe ọbụla rụrụ arụ aka, ma ịrụ arụ ahụ o si na mmadụ, ma o si nʼanụ ọhịa, ma o si nʼihe ọbụla ọzọ, a ga-esite nʼetiti ndị ya kewapụ ya ma ọ bụrụ na onye ahụ anọrọ nʼọnọdụ ahụ rie anụ e ji chụọ aja udo nye \nd Onyenwe anyị\nd*.’ ”
\s1 Iwu megidere iri abụba na ọbara
\p 
\v 22 Mgbe ahụ, \nd Onyenwe anyị\nd* gwara Mosis sị,
\v 23 “Gwa ụmụ Izrel okwu sị ha, ‘Unu erila abụba ehi, maọbụ nke ewu, maọbụ nke atụrụ.
\v 24 Abụba anụ ọbụla nwụrụ anwụ maọbụ nke anụ ọhịa gburu adịghị mma oriri. E nwere ike jiri ha mee ihe ọzọ.
\v 25 A ga-ekewapụ mmadụ ọbụla site nʼetiti ndị ya, bụ onye na-eri abụba anụmanụ nke a ga-esite na ya chee onyinye nsure ọkụ nye \nd Onyenwe anyị\nd*.
\v 26 Ọzọkwa, unu erila ọbara nnụnụ maọbụ nke anụmanụ nʼebe ọbụla unu bi.\f + \fr 7:26 \ft \xt Jen 9:4\xt*\f*
\v 27 Onye ọbụla riri ọbara ka a ga-ekewapụ site nʼetiti ndị ya.’ ”
\s1 Oke ndị nchụaja
\p 
\v 28 \nd Onyenwe anyị\nd* gwakwara Mosis sị,
\v 29 “Gwa ụmụ Izrel okwu sị ha, ‘Onye ọbụla wetaara \nd Onyenwe anyị\nd* onyinye aja udo aghaghị iweta ụfọdụ nʼime onyinye ahụ dịka onyinye pụrụ iche nye Onyenwe anyị.
\v 30 Ha ga-eji aka ha chee onyinye nsure ọkụ ahụ nʼihu \nd Onyenwe anyị\nd*. Ha ga-eweta abụba ahụ, ya na obi anụ, fufee obi anụ ahụ nʼihu \nd Onyenwe anyị\nd* dịka aja mfufe.
\v 31 Onye nchụaja ga-akpọ abụba ahụ ọkụ nʼebe ịchụ aja, ma obi anụ ahụ ga-abụ nke Erọn na ụmụ ya ndị ikom.
\v 32 Unu ga-enye onye nchụaja apata aka nri nke anụ aja udo ahụ, dịka onyinye.
\v 33 Nwa Erọn, onye ji ọbara na abụba chụọ aja udo ahụ ga-ewere apata aka nri ya dịka oke ruuru ya.
\v 34 Site nʼonyinye ụmụ Izrel na-enye nʼoge aja udo, ewerela m obi anụ ahụ a na-efufe efufe, na apata anụ a na-eche nʼihu m nye Erọn, onye nchụaja na ụmụ ya ndị ikom ka ha bụrụ oke ruuru ha mgbe ọbụla ụmụ Izrel na-achụ aja udo.’ ”\f + \fr 7:34 \ft \xt Ọpụ 29:27\xt*\f*
\p 
\v 35 Nke a bụ akụkụ anụ ahụ e ji chụọ aja nsure ọkụ nye \nd Onyenwe anyị\nd*, nke e nyekwara Erọn na ụmụ ya ndị ikom nʼụbọchị ahụ e chere ha nʼihu \nd Onyenwe anyị\nd* ijere ya ozi dịka ndị nchụaja.
\v 36 Nʼihi na nʼụbọchị ahụ e tere ha mmanụ ka \nd Onyenwe anyị\nd* nyere ụmụ Izrel iwu sị ha nye Erọn na ụmụ ya ndị ikom oke ndị a oge niile, site nʼọgbọ ruo nʼọgbọ.
\p 
\v 37 Ndị a bụ usoro iwu metụtara aja nsure ọkụ, na aja mkpụrụ ọka, na aja mmehie, na aja ikpe ọmụma, na onyinye ido nsọ, na aja udo.
\v 38 \nd Onyenwe anyị\nd* nyere Mosis iwu ndị a nʼugwu Saịnaị nʼụbọchị ahụ o nyere ụmụ Izrel iwu sị ha, wetara \nd Onyenwe anyị\nd* onyinye nʼọzara Saịnaị.
\c 8
\s1 Ido Erọn na ụmụ ya nsọ
\p 
\v 1 \nd Onyenwe anyị\nd* gwara Mosis sị,
\v 2 “Kpọta Erọn na ụmụ ya ndị ikom, chịtakwa uwe ha, weta mmanụ nsọ, oke ehi nke aja mmehie na ebule abụọ ahụ, na nkata achịcha a na-ejighị ihe na-eko achịcha mee.
\v 3 Kpọkọtaa ọgbakọ ụmụ Izrel niile ka ha bịa nʼọnụ ụzọ ụlọ nzute.”
\v 4 Mosis mere ihe \nd Onyenwe anyị\nd* gwara ya ka o mee. Ọgbakọ ụmụ Izrel zukọtara nʼọnụ ụzọ ụlọ nzute ahụ.
\p 
\v 5 Mosis gwara ọgbakọ ahụ sị, “Nke a bụ ihe \nd Onyenwe anyị\nd* nyere nʼiwu ka e mee.”
\v 6 Mgbe ahụ, Mosis kpọpụtara Erọn na ụmụ ya ndị ikom nʼihu, jiri mmiri saa ha ahụ.
\v 7 O yikwasịrị Erọn uwe ime ahụ, kee ya ihe okike a na-eke nʼukwu, yikwasịkwa ya uwe mwụda na efọọd ahụ, jiri ihe okike ahụ a chọrọ mma kegidesie efọọd ahụ ike nʼahụ ya.
\v 8 O tụkwasịrị ya ihe igbochi obi ahụ nʼahụ, tinye Urim na Tumim nʼime ihe igbochi obi ahụ.
\v 9 Ọ tụhịkwara akwa ike nʼisi ahụ nʼisi Erọn, tinye nʼihu akwa ike nʼisi ahụ, okpu nsọ e ji ọlaedo kpụọ, nke bụ akara ido nsọ, dịka \nd Onyenwe anyị\nd* si nye Mosis nʼiwu.
\p 
\v 10 Mgbe ahụ, Mosis weere mmanụ nsọ ahụ tee nʼụlọ nzute ahụ, na nʼihe niile dị nʼime ya, ido ha nsọ.
\v 11 Ọ fesakwara ụfọdụ nʼime mmanụ ahụ ugboro asaa nʼebe ịchụ aja, fesakwa ya ugboro asaa nʼelu ngwongwo niile dị nʼebe ịchụ aja, na nʼefere e ji asa ihe, na ụkwụ ya, ido ha nsọ.
\v 12 Ọ wụsara Erọn ụfọdụ mmanụ nsọ ahụ nʼisi, tee ya mmanụ, nʼihi ido ya nsọ.
\v 13 Ọ kpọtara ụmụ ndị ikom Erọn nso, o yikwasịrị ha uwe ime ahụ, kee ha ihe okike nke ukwu, kekwasị ha ihe okike nʼisi, dịka iwu \nd Onyenwe anyị\nd* nyere Mosis si dị.
\p 
\v 14 Ọ kpụtara oke ehi e ji achụ aja mmehie, mee ka Erọn na ụmụ ya ndị ikom bikwasị aka ha nʼelu isi ya.
\v 15 Mosis gburu oke ehi ahụ, were ụfọdụ nʼime ọbara ahụ, jiri mkpịsịaka ya rụta ọbara tee na mpi niile dị nʼebe ịchụ aja, ido ebe ịchụ aja ahụ nsọ. Ọ wụpụrụ ọbara nke fọdụrụ nʼụkwụ ala ala nke ebe ịchụ aja ahụ. Otu a ka o si doo ya nsọ, ikpuchiri ya mmehie.
\v 16 Mosis wekwara abụba niile dị gburugburu ihe dị nʼime afọ ehi ahụ, mba-umeju nke umeju ya, akụrụ abụọ ya na abụba dị nʼelu ha, kpọọ ya ọkụ nʼebe ịchụ aja.
\v 17 Ma oke ehi ahụ, akpụkpọ ya, anụ ya na mgbịrị afọ ya, ka ọ kpọrọ ọkụ nʼazụ ọmụma ụlọ ikwu ahụ dịka \nd Onyenwe anyị\nd* nyere Mosis nʼiwu.
\p 
\v 18 O weere ebule ahụ, chee nʼihu \nd Onyenwe anyị\nd*, dịka aja nsure ọkụ. Erọn na ụmụ ya ndị ikom bikwasịrị aka ha nʼelu isi ya.
\v 19 Mgbe ahụ, Mosis gburu ebule ahụ, fesa ọbara ya nʼakụkụ niile nke ebe ịchụ aja.
\v 20 Ọ bọwasịrị ebule ahụ ntakịrị ntakịrị, kpọọ isi ya, iberibe anụ ya na abụba ya ọkụ.
\v 21 Ọ sachara ihe dị nʼime afọ ya na ụkwụ ya niile mmiri, kpọọ ebule ahụ niile ọkụ nʼebe ịchụ aja. Nʼihi na ọ bụ aja nsure ọkụ nke isisi ya dị \nd Onyenwe anyị\nd* ezi mma, nʼihi na ọ bụ dịka \nd Onyenwe anyị\nd* nyere Mosis nʼiwu.
\p 
\v 22 O kpụpụtara ebule nke ọzọ, bụ ebule nke ido nsọ, Erọn na ụmụ ya ndị ikom bikwasịrị aka ha nʼelu isi ya.
\v 23 Mgbe ahụ, Mosis gburu ya, were ụfọdụ nʼime ọbara ya tee Erọn nʼọnụ ntị aka nri, na nʼisi mkpụrụ aka nke aka nri ya, na nʼisi mkpụrụ ụkwụ nke aka nri ya.
\v 24 Mosis kpọtara ụmụ ndị ikom Erọn nso, weere ụfọdụ ọbara ahụ tee nʼọnụ ntị aka nri ha, na nʼisi mkpụrụ aka nke aka nri ha, na nʼisi mkpụrụ ụkwụ nke aka nri ha. O fesakwara ọbara nʼakụkụ niile nke ebe ịchụ aja ahụ.
\v 25 O weere abụba ya, akụkụ ọdụdụ ya nwere abụba, na abụba niile nke kpuchiri ihe dị nʼime afọ ya, na mba-umeju nke dị nʼumeju ya, akụrụ ya abụọ na abụba ha, na apata aka nri ya
\v 26 O sitere na nkata achịcha ahụ a na-ejighị ihe na-eko achịcha mee, nke dị nʼihu \nd Onyenwe anyị\nd*, wepụta otu ogbe achịcha, na otu ogbe achịcha a gwakọtara mmanụ oliv, na otu mbadamba ogbe achịcha, tụkwasị ha nʼelu abụba ndị ahụ, na nʼelu apata aka nri ahụ.
\v 27 O tinyere ihe ndị a niile nʼaka Erọn na ụmụ ya ndị ikom, ha fufere ha nʼihu \nd Onyenwe anyị\nd* dịka aja mfufe.
\v 28 Mosis naara ya site nʼaka ha, kpọọ ha ọkụ nʼelu ebe ịchụ aja, ya na aja nsure ọkụ, ka ọ bụrụ aja ido nsọ nke isisi ya dị ezi mma, onyinye nsure ọkụ nye \nd Onyenwe anyị\nd*.
\v 29 Mosis werekwara obi ebule ido nsọ ahụ, fufee ya nʼihu \nd Onyenwe anyị\nd*, dịka aja mfufe, dịka \nd Onyenwe anyị\nd* nyere nʼiwu. Nke a bụ oke Mosis.
\p 
\v 30 Mgbe ahụ, Mosis weere ụfọdụ nʼime mmanụ nsọ ahụ, na ụfọdụ nʼime ọbara ahụ dị nʼebe ịchụ aja fesa ya Erọn na uwe ya, fesakwa ya ụmụ ndị ikom Erọn nʼuwe ha. Otu a ka o si doo Erọn na uwe ya, na ụmụ ya ndị ikom na uwe ha nsọ.
\p 
\v 31 Mgbe ahụ, Mosis gwara Erọn na ụmụ ya ndị ikom sị, “Sienụ anụ ahụ nʼọnụ ụzọ ụlọ nzute. Nọrọkwanụ nʼebe ahụ rie ya na achịcha ahụ dị nʼime nkata onyinye ido nsọ, dịka a gwara m, sị, ‘Erọn na ụmụ ya ndị ikom ga-eri ya.’
\v 32 Ihe ọbụla fọdụrụ na anụ ahụ na achịcha ahụ, ka unu ga-akpọ ọkụ.”
\v 33 Ọ sịrị ha: “Unu esikwala nʼọnụ ụzọ ụlọ nzute a pụọ ruo ụbọchị asaa, tutu ruo mgbe ụbọchị ido nsọ unu zuruoke, nʼihi na ido nsọ unu ga-anọ ụbọchị asaa.
\v 34 Ihe niile e mere nʼụbọchị taa bụ ihe \nd Onyenwe anyị\nd* nyere nʼiwu, banyere ịchụ aja maka mkpuchi mmehie unu.”
\v 35 Unu aghaghị ịnọgide nʼọnụ ụzọ ụlọ nzute ehihie na abalị ụbọchị asaa, mezuokwa ihe \nd Onyenwe anyị\nd* nyere nʼiwu, ka unu ghara ịnwụ. Nʼihi na nke a bụ iwu e nyere m.
\p 
\v 36 Ya mere, Erọn na ụmụ ya ndị ikom mezuru ihe niile dịka \nd Onyenwe anyị\nd* si nye nʼiwu site nʼọnụ Mosis.
\c 9
\s1 Mbido ọrụ ndị nchụaja
\p 
\v 1 Nʼụbọchị nke asatọ, Mosis kpọrọ Erọn na ụmụ ya ndị ikom, na ndị okenye Izrel.
\v 2 Ọ gwara Erọn sị, “Site nʼime igwe ehi were nwa oke ehi ị ga-eji chụọ aja mmehie. Werekwa ebule na-enweghị ntụpọ ị ga-eji chụọ aja nsure ọkụ, nke m ga-eche nʼihu \nd Onyenwe anyị\nd*.
\v 3 Ọ gwakwara ụmụ Izrel sị ha, ‘Họrọnụ mkpi a ga-eji chụọ aja mmehie, na nwa ehi, na nwa atụrụ na-enweghị ntụpọ, ndị gbara naanị otu afọ, a ga-eji chụọ aja nsure ọkụ,
\v 4 na ehi, na ebule a ga-eji chụọ aja udo nʼihu \nd Onyenwe anyị\nd*, tinyere mkpụrụ ọka a gwara mmanụ. Nʼihi na taa ka \nd Onyenwe anyị\nd* ga-eme ka unu hụ ya anya.’ ”
\p 
\v 5 Ha wetara ihe ndị a niile bịa nʼọnụ ụzọ ụlọ nzute dịka Mosis nyere nʼiwu. Ọgbakọ ụmụ Izrel niile bịara nso guzo nʼihu \nd Onyenwe anyị\nd*.
\v 6 Mgbe ahụ, Mosis sịrị ha, “Ihe ndị a bụ ihe \nd Onyenwe anyị\nd* nyere unu nʼiwu idebe, ka ebube ya si otu a pụta ìhè nʼihu unu.”
\p 
\v 7 Mosis sịrị Erọn, “Bịa nso nʼebe ịchụ aja. Chụọ aja mmehie, na aja nsure ọkụ nke a ga-eji kpuchie mmehie gị na mmehie ndị ahụ niile. Chụọ aja onyinye dịrị ndị ahụ, maka ikpuchiri ha mmehie ha, dịka \nd Onyenwe anyị\nd* nyere nʼiwu.”
\p 
\v 8 Erọn bịara nso nʼebe ịchụ aja, gbuo nwa ehi ahụ ka ọ bụrụ aja mmehie nke ya.
\v 9 Ụmụ Erọn buteere ya ọbara ehi ahụ. O tinyere mkpịsịaka ya nʼime ọbara ahụ tee ya na mpi dị nʼebe ịchụ aja. Ọ wụrụ ọbara fọdụrụ nʼụkwụ ala ala ebe ịchụ aja ahụ.
\v 10 Ọ kpọrọ abụba ya, na akụrụ ya abụọ, na ihe kpuchiri umeju si nʼaja mmehie ahụ ọkụ nʼebe ịchụ aja dịka \nd Onyenwe anyị\nd* nyere Mosis iwu.
\v 11 Ma anụ ahụ ya, na akpụkpọ ya, ka ọ kpọrọ ọkụ nʼazụ ebe obibi.
\p 
\v 12 Emesịa, o gburu anụ e wetara maka aja nsure ọkụ ahụ. Ụmụ ya ndị ikom nyere ya ọbara anụ ahụ, nke o fesara gburugburu ebe ịchụ aja.
\v 13 Ha nyefere ya aja nsure ọkụ ahụ nʼaka nʼotu ha sị bọọ ya, tinyere isi ya. Ọ kpọrọ ihe niile ọkụ nʼebe ịchụ aja.
\v 14 Ọ sachara ihe dị nʼime afọ ya, na ụkwụ ya, kpọọ ha ọkụ, dịka aja nsure ọkụ.
\p 
\v 15 Emesịa, Erọn wetara onyinye nke dị maka ndị mmadụ, o were ewu ahụ bụ maka mmehie ndị mmadụ, gbuo ya, were chụọ aja mmehie, dịka o mere nke mbụ.
\p 
\v 16 Ọ chụkwara aja nsure ọkụ nʼusoro dịka iwu e nyere si dị.
\v 17 O webatakwara aja mkpụrụ ọka ahụ, kporo nke juru ya aka, kpọọ ya ọkụ nʼelu ebe ịchụ aja, tinyekwara aja nsure ọkụ nke ụtụtụ ahụ.
\p 
\v 18 Nʼikpeazụ, o gburu ehi na ebule ahụ, nke bụ aja udo ndị Izrel. Ụmụ Erọn buteere ya ọbara nke o fesara gburugburu ebe ịchụ aja.
\v 19 Ọ chịkọtara abụba niile dị ehi na ebule ndị ahụ nʼahụ, na ọdụdụ ha, na abụba kpuchiri ihe ime ha, ya na akụrụ ha, na abụba kpuchiri umeju ha,
\v 20 tụkwasị ha nʼobi anụ ndị ahụ, kpọọ ha ọkụ nʼebe ịchụ aja.
\v 21 Mgbe ahụ, Erọn fufere, dịka onyinye mfufe, obi anụ ahụ, na apata aka nri ha nʼihu \nd Onyenwe anyị\nd* dịka Mosis nyere nʼiwu.
\p 
\v 22 Erọn weliri aka ya elu nʼebe ụmụ Izrel nọ, gọzie ha. Emesịa, mgbe ọ chụchara aja mmehie, na aja nsure ọkụ na aja udo, o sitere nʼebe ịchụ aja ahụ rịdata.
\p 
\v 23 Mosis na Erọn bara nʼime ụlọ nzute. Mgbe ha pụtara, ha gọziri ọha mmadụ ahụ. Mgbe ahụ kwa, ebube \nd Onyenwe anyị\nd* pụtara ìhè nye mmadụ niile nʼọgbakọ ahụ.
\v 24 Ọkụ sitekwara nʼebe \nd Onyenwe anyị\nd* nọ daa, rechapụ aja nsure ọkụ ahụ, na abụba ahụ dị nʼebe ịchụ aja. Mgbe ndị Izrel hụrụ ya, ha tiri mkpu ọṅụ. Daa, kpuo ihu nʼala.
\c 10
\s1 Ọnwụ Nadab na Abihu
\p 
\v 1 Ma ụmụ Erọn, Nadab na Abihu, were ọkụ tinye nʼihe ịgụ ọkụ ha, tinyekwa ụda na-esi isi nʼọkụ ahụ, si otu a chee ọkụ na-adịghị nsọ nʼihu \nd Onyenwe anyị\nd*, nʼụzọ megidere ihe e nyere nʼiwu.
\v 2 Nʼihi ya, ọkụ sitere nʼihu \nd Onyenwe anyị\nd* daa rechapụ ha, ha nwụrụ nʼihu \nd Onyenwe anyị\nd*.
\v 3 Mgbe ahụ, Mosis gwara Erọn sị, “Nke a bụ ihe \nd Onyenwe anyị\nd* bu nʼobi mgbe o kwuru sị,
\q1 “ ‘Nʼetiti ndị niile na-abịaru m nso
\q2 ka a ga-edo m nsọ
\q1 ọ bụkwa nʼihu ọha mmadụ,
\q2 ka a ga-asọpụrụ m.\f + \fr 10:3 \ft A ga-ebulikwa m elu.\f*’ ”
\m Ma Erọn gbara nkịtị.
\p 
\v 4 Mgbe ahụ, Mosis kpọrọ Mishael na Elzafan, ụmụ Uziel, nwanne nna Erọn sị ha, “Bịanụ nso. Gaanụ buputa ozu ụmụnne unu site nʼihu ebe nsọ, buru ha gaa nʼazụ ebe obibi.”
\v 5 Ha bịara ghanye aka nʼuwe ime ahụ ha buru ha bupụ nʼazụ ọmụma ụlọ ikwu, dịka Mosis nyere nʼiwu.
\p 
\v 6 Mosis tụgharịrị sị Erọn na ụmụ ya, Elieza na Itama, “Unu ekwekwala ka ntutu isi unu kpasaa akpasa izipụta na unu na-eru ụjụ. Unu adọwakwala uwe unu. Nʼihi na ọ bụrụ na unu emee otu a, unu ga-anwụ. Iwe \nd Onyenwe anyị\nd* ga-abịakwasịkwa ọgbakọ Izrel niile. Ma ndị ikwu gị, ụmụ Izrel ndị ọzọ, nwere ike ruo ụjụ nʼihi Nadab na Abihu.
\v 7 Ọzọ, unu ahapụla ọnụ ụzọ ụlọ nzute, ka unu ghara ịnwụ, nʼihi na mmanụ nsọ nke \nd Onyenwe anyị\nd* dị nʼahụ unu.” Ha mere dịka Mosis gwara ha.
\p 
\v 8 Mgbe ahụ, \nd Onyenwe anyị\nd* gwara Erọn sị,
\v 9 “Gị na ụmụ gị ndị ikom agaghị aṅụ mmanya, maọbụ ihe ọṅụṅụ ọbụla na-aba nʼanya mgbe unu na-aba nʼụlọ nzute ka unu ghara ịnwụ. Agbụrụ unu niile ga-esogide iwu a ruo ọgbọ niile na-abịa.
\v 10 Ọrụ unu ka ọ bụ ịkpa oke nʼetiti ihe dị nsọ na ihe na-adịghị nsọ, na nʼetiti ihe dị ọcha na ihe na-adịghị ọcha.
\v 11 Ọrụ unu bụkwa izi ụmụ Izrel ụkpụrụ niile \nd Onyenwe anyị\nd* nyere ha site nʼaka Mosis.”
\p 
\v 12 Mosis sịrị Erọn na ụmụ ya ndị ikom fọdụrụ, bụ Elieza na Itama, “Werenụ onyinye mkpụrụ ọka nke fọdụrụ site na onyinye nsure ọkụ, nke a kwadoro na-etinyeghị ihe iko achịcha ọbụla, bụ nke e nyere \nd Onyenwe anyị\nd*. Rienụ ya nʼakụkụ ebe ịchụ aja, nʼihi na ọ bụ ihe dịkarịsịrị nsọ.
\v 13 Rienụ ya nʼime ebe nsọ ahụ, nʼihi na ọ bụ oke ruru unu na ụmụ unu ndị ikom site nʼonyinye nsure ọkụ e nyere \nd Onyenwe anyị\nd*; nʼihi na nke a bụ ihe e nyere m nʼiwu.
\v 14 Ma unu na ụmụ unu ndị ikom na ndị inyom ka ọ dịkwara iri obi anụ na apata ya, nke e fufere nʼihu \nd Onyenwe anyị\nd*. Kama, ọ bụ nʼebe dị ọcha ka unu ga-anọ rie ya. Nke a bụ oke enyere unu na ụmụ unu site nʼaja udo nke ụmụ Izrel.
\v 15 Apata ụkwụ anụ nke aja mbuli na obi anụ ahụ nke e fufere, ka a ga-eweta ya na abụba ya nye dịka onyinye sitere nʼọkụ. A ga-efufe ha nʼihu \nd Onyenwe anyị\nd* dịka aja mfufe. Nke a ga-abụ oke ruuru unu na ụmụ unu mgbe niile, dịka \nd Onyenwe anyị\nd* nyere nʼiwu.”
\p 
\v 16 Mgbe Mosis jụrụ ajụjụ banyere mkpi ahụ e ji chụọ aja mmehie, ọ chọpụtara na a kpọọla ya ọkụ. O wesoro Elieza na Itama ụmụ ndị ikom Erọn iwe sị ha,
\v 17 “Gịnị mere unu erighị anụ ahụ e ji chụọ aja mmehie nʼakụkụ ebe nsọ ahụ? Ọ bụ nke dịkarịsịrị nsọ; e nyere unu ya maka iwepụ ọmụma ikpe dịrị ọgbakọ Izrel, na ikpuchi mmehie ha nʼihu \nd Onyenwe anyị\nd*.
\v 18 Ebe ọ bụ na e webataghị ọbara ya nʼime Ebe Nsọ ahụ, unu gaara anọ nʼakụkụ ebe nsọ ahụ rie anụ ewu ahụ, dịka m nyere unu nʼiwu.”
\p 
\v 19 Ma Erọn zara Mosis sị ya, “Lee, taa ka ha chụrụ aja mmehie na aja nsure ọkụ ha nʼihu \nd Onyenwe anyị\nd*. Ma lee ụdị ihe dakwasịrị m. Ọ gaara atọ \nd Onyenwe anyị\nd* ụtọ ma a sị na m riri anụ aja mmehie ndị a nʼụbọchị dị otu a?”
\v 20 Mgbe Mosis nụrụ nke a, o nwere afọ ojuju nʼihi ọsịsa Erọn nyere.
\c 11
\s1 Nri dị ọcha na ndị na-adịghị ọcha
\p 
\v 1 \nd Onyenwe anyị\nd* gwara Mosis na Erọn, sị,
\v 2 “Gwanụ ụmụ Izrel, sị, ‘Nʼime anụmanụ niile dị nʼụwa, ndị a bụ anụmanụ unu ga-eri.
\v 3 Unu nwere ike iri anụmanụ ọbụla ụkwụ ya wara njakpa.\f + \fr 11:3 \ft Ya bụ wara abụọ\f* nke na-atagharị ọnụ.\f + \fr 11:3 \ft Nke na-ata nri ya ugboro abụọ\f*
\p 
\v 4 “ ‘Ma ọ dị ụfọdụ ndị na-atagharị nri maọbụ ndị nwere naanị ụkwụ wara njakpa, unu agaghị eri anụ ha. Ha bụ ịnyịnya kamel, ọ bụ ezie na ọ na-atagharị nri, ma ụkwụ ya awaghị njakpa. Unu agaghị eri ha nʼihi na ọ bụ anụ na-adịghị ọcha.
\v 5 Ewi: Ọ na-atagharị nri ya, ma o nweghị ụkwụ wara njakpa. Ọ bụ anụ na-adịghị ọcha nye unu.
\v 6 Ewi nkume: Ọ na-atagharị nri ya, ma o nweghị ụkwụ wara njakpa. Ọ bụ anụ na-adịghị ọcha nye unu.
\v 7 Ezi: Ọ bụ nʼezie na ụkwụ ya wara njakpa ma ọ dịghị atagharị nri ya. Ọ bụ anụ na-adịghị ọcha nye unu.
\v 8 Unu emetụkwala ozu ha aka maọbụ rie anụ ha, nʼihi na ha bụ ihe na-adịghị ọcha nye unu.
\p 
\v 9 “ ‘Nʼime ihe niile e kere eke dị ndụ biri na mmiri, maọbụ nʼiyi nta na nʼoke osimiri, unu nwere ike iri ụdị ọbụla nwere ntu na akpịrịkpa nʼahụ ha.
\v 10 Ma unu ekwesighị iri ihe ọbụla nke na-enweghị ntu maọbụ akpịrịkpa, ma ha bụ anụ na-enupụta enupụta, maọbụ na ha so nʼanụ ndị ọzọ dị ndụ bi na mmiri, unu kwesiri ịsọ ha asọ.
\v 11 Ebe ha bụ ihe na-asọ oyi nye unu, unu ekwesighị iri ha, unu ga-agụkwa ozu ha ka ihe na-adịghị ọcha.
\v 12 Ihe ọbụla bi nʼime mmiri nke na-enweghị ntu na akpịrịkpa nʼahụ ha, bụ nke unu ga-asọ asọ.
\p 
\v 13 “ ‘Ndị a bụ nnụnụ ndị unu ga-asọ asọ, nke unu na-ekwesighị iri nʼihi na ha bụ ihe arụ a na-asọ oyi: ugo, udele na udele ojii,
\v 14 ndagbụ na ọgankwọ dị iche iche,
\v 15 ugolọma ọbụla dị iche iche,
\v 16 enyi nnụnụ, egbe abalị, nnụnụ oke osimiri na egbe dị iche iche,
\v 17 okwukwu nta, komorant na okwukwu ukwu,
\v 18 okwukwu nwere mpi, okwolo na udele,
\v 19 ụgbala, utù dị iche iche, nnụnụ ọdụ nta\f + \fr 11:19 \ft Maọbụ, \fqa hoopoe\f* na ụsụ.
\p 
\v 20 “ ‘Ụmụ ahụhụ niile na-efe efe nke na-aga ije nʼụkwụ anọ bụ ihe rụrụ arụ nye unu, unu agaghị eri ya.
\v 21 Ma e nwere ụfọdụ ụmụ ahụhụ na-efe efe nke na-aga ije nʼụkwụ anọ ndị unu nwere ike iri: ndị a bụ ndị nwere ogwe ụkwụ nke ha ji na-awụ awụ nʼala,
\v 22 ndị a ka unu ga-eri nʼetiti ha, igurube dị iche iche, na akpankwụ dị iche iche, na abụzụ dị iche iche, na ụkpana dị iche iche.
\v 23 Ahụhụ ndị ọzọ niile na-efe efe, ndị nwere ụkwụ anọ, bụ ihe rụrụ arụ. Unu ekwesighị iri ha.
\p 
\v 24 “ ‘Iri ha ga-eme ka unu rụọ arụọ. Onye ọbụla metụrụ ozu ha aka ga-abụ onye rụrụ arụ site nʼoge o bitụrụ ha aka tutu ruo nʼabalị nke ụbọchị ahụ.
\v 25 Onye ọbụla metụrụ otu nʼime ozu ha aka ga-asakwa uwe ya, gụọkwa onwe ya dịka onye na-adịghị ọcha ruo uhuruchi.
\p 
\v 26 “ ‘Anụmanụ ọbụla ụkwụ ya na-awasaghị abụọ, maọbụ nke na-adịghị atagharị nri ya ugboro abụọ, rụrụ arụ. Onye ọbụla metụrụ ozu ya aka ga-abụ onye rụrụ arụ.
\v 27 Nʼime anụmanụ niile na-aga ije nʼụkwụ anọ, anụmanụ ọbụla na-aga ije nʼọbụaka ya rụrụ arụ, unu agaghị eri ya. Onye ọbụla metụrụ ozu ya aka ga-abụ onye rụrụ arụ ruo uhuruchi.
\v 28 Onye ọbụla ga-ebu ozu ya ga-asa uwe ya, bụrụkwa onye rụrụ arụ ruo uhuruchi, nʼihi na ọ bụ ihe rụrụ arụ nʼebe unu nọ.
\p 
\v 29 “ ‘Nʼime anụmanụ niile na-enupụta enupụta nʼala, anụmanụ ndị a bụ ndị rụrụ arụ: nkapi, na oke, na agụ iyi dịka ụdị ha si dị,
\v 30 na ọba mmiri,\f + \fr 11:30 \ft Maọbụ, \fqa agụ ụlọ\f* na ngwere aghụ, na ngwere, na ngwere uzuzu, na ogumagala.
\v 31 Nʼime ihe niile na-enupụta enupụta nʼala ndị a rụrụ arụ nʼebe unu nọ. Onye metụrụ ozu ha aka ga-abụ onye rụrụ arụ tutu ruo uhuruchi ụbọchị ahụ.
\v 32 Ihe ọbụla nke ozu ha dakwasịrị ga-abụ ihe rụrụ arụ, maọbụ osisi, maọbụ akwa, maọbụ akpụkpọ a na-akwa nʼala, maọbụ akpa, ihe ọbụla nke eji ya eme. A ga-etinye ya na mmiri, ọ ga-adịgide nʼime mmiri tutu ruo uhuruchi, mgbe ahụ ka ọ ga-adị ọcha.
\v 33 Ọ bụrụ na otu nʼime ihe ndị a adanye nʼite aja, a ga-etiwa ite ahụ. Ihe niile dị nʼite ahụ abụrụla ihe rụrụ arụ.
\v 34 Ihe oriri ọbụla nke mmiri si nʼite a metụrụ abụrụla ihe rụrụ arụ. Mmiri ọṅụṅụ ọbụla dị nʼime ite ahụ rụkwara arụ.
\v 35 Ihe ọbụla ozu anụmanụ dị otu a dakwasịrị, maọbụ ite ọkụ eji eghe ihe, maọbụ ekwu a ga-etiwa ha. Nʼihi na ha bụ ihe rụrụ arụ, unu ga-agụ ha dịka ihe rụrụ arụ.
\v 36 Ọ bụrụkwa na ozu anụmanụ ahụ adaba nʼisi iyi, maọbụ nʼolulu mmiri, mmiri ahụ ga-adị ọcha, kama onye ga-emetụ anụ ahụ aka ga-abụ onye rụrụ arụ.
\v 37 Ọ bụrụ na ozu anụ ahụ adakwasị mkpụrụ ubi a na-aga ịkụ nʼubi, ọ gaghị emerụ ha.
\v 38 Ma ọ bụrụ na e tinyere mmiri nʼelu mkpụrụ ọghịgha ndị ahụ, ozu adakwasị nʼelu ya, ha ga-abụ ihe rụrụ arụ.
\p 
\v 39 “ ‘Ọ bụrụ na anụmanụ unu kwesiri iri eri anwụọ, onye ahụ metụrụ ya aka ga-abụ onye rụrụ arụ ruo uhuruchi.
\v 40 Onye ọbụla riri ozu anụ ahụ, maọbụ bufuo ozu ya, ga-abụ onye rụrụ arụ ruo uhuruchi. Ọ ga-asa uwe ya mmiri.
\p 
\v 41 “ ‘Anụmanụ ọbụla na-akpụgharị nʼala bụ ihe rụrụ arụ nye unu. Unu erikwala ha.
\v 42 Unu agaghị eri anụmanụ ọbụla na-akpụgharị nʼala, ma ha na-akpụgharị nʼafọ ha, ma ha na-agagharị nʼụkwụ anọ, ma ha nwere ụkwụ dị ọtụtụ. Ha bụ ihe rụrụ arụ.
\v 43 Unu emerụla onwe unu site nʼiri anụmanụ ndị a na-akpụgharị nʼala. Unu abụla ndị na-emerụ onwe unu site nʼanụmanụ ndị a, maọbụ mee ka unu bụrụ ndị e merụrụ site na ha.
\v 44 Abụ m \nd Onyenwe anyị\nd* Chineke unu. Doonụ onwe unu nsọ, nʼihi na adị m nsọ. Unu emerụla onwe unu site nʼimetụ anụmanụ ndị a na-akpụgharị nʼala aka.
\v 45 Abụ m \nd Onyenwe anyị\nd*, onye si nʼala Ijipt kpọpụta unu, ka m bụrụ Chineke unu. Unu aghaghị ịdị nsọ, nʼihi na adị m nsọ.
\p 
\v 46 “ ‘Ndị a bụ usoro iwu metụtara ụmụ anụmanụ, na anụ ufe, na anụ bi na mmiri, na anụ ndị na-arịgharị arịgharị nʼala.
\v 47 Ka unu si otu a kpaa oke nʼetiti ndị rụrụ arụ na ndị dị ọcha, nʼetiti ihe e kere eke dị ndụ ndị unu nwere ike iri nʼihi na ha dị ọcha, na ndị unu na-ekwesighị iri nʼihi na ha rụrụ arụ.’ ”
\c 12
\s1 Ịdị ọcha nke nwanyị mụrụ nwa ọhụrụ
\p 
\v 1 \nd Onyenwe anyị\nd* gwara Mosis sị ya,
\v 2 “Nye ụmụ Izrel iwu ndị a sị ha, ‘Mgbe nwanyị tụụrụ ime mesịa mụọ nwa nwoke, ọ ga-abụ onye na-adịghị ọcha ụbọchị asaa, dịka o si adị mgbe ọ nọ nʼadịghị ọcha nke nsọ ya nʼoge a kara aka.
\v 3 Nʼụbọchị nke asatọ site nʼoge a mụrụ ya, a ga-ebi nwa nwoke ahụ ugwu.
\v 4 Nʼime iri abalị atọ na atọ site nʼụbọchị nwanyị ahụ mụsịrị nwa ahụ, ọ ga-anọkwa na-adịghị ọcha nke ọbara gbara ya. Ọ gaghị emetụ ihe dị nsọ aka, maọbụ banye nʼime ebe nsọ, ruo mgbe ụbọchị ime ya ka ọ dị ọcha gasịrị.
\v 5 Mgbe nwanyị dị ime mụrụ nwa nwanyị, ọ ga-abụ onye nʼadịghị ọcha iri ụbọchị na anọ, dịka o si adị mgbe ọ nọ na nsọ ya. Ọ ga-echere tutu iri ụbọchị isii agwụsịa, ime ya ka ọ dị ọcha.
\p 
\v 6 “ ‘Mgbe ụbọchị ịdị ọcha ya zuru, ma ọ mụrụ nwa nwoke maọbụ nwa nwanyị, ọ ga-ewetara onye nchụaja nʼọnụ ụzọ ụlọ nzute otu nwa atụrụ gbara otu afọ maka onyinye aja nsure ọkụ, na otu nwa kpalakwukwu maọbụ otu nduru maka onyinye aja mmehie.
\v 7 Onye nchụaja ga-anarakwa ha chee ha nʼihu \nd Onyenwe anyị\nd*, chụọrọ ya aja ikpuchi mmehie. Mgbe ahụ ka ọ ga-adị ọcha site nʼịsọ ọbara ya.
\p “ ‘Nke a bụ usoro iwu dịịrị nwanyị ọbụla mụrụ nwa nwoke, maọbụ nwa nwanyị.
\v 8 Ọ bụrụ na aka erughị ya iweta nwa atụrụ, ọ ga-eweta ụmụ kpalakwukwu abụọ, maọbụ ụmụ nduru abụọ. Otu ga-abụ maka aja nsure ọkụ, nke ọzọ ga-abụ maka aja mmehie. Onye nchụaja ga-ewere ha chụọrọ ya aja ikpuchi mmehie, ka ọ dịkwa ọcha ọzọ.’ ”
\c 13
\s1 Usoro iwu gbasara ọrịa elu ahụ
\p 
\v 1 \nd Onyenwe anyị\nd* gwara Mosis na Erọn okwu sị ha,
\v 2 “Mgbe mmadụ hụrụ etuto, maọbụ ọnya, maọbụ ntụpọ na-eko eko nʼakpụkpọ anụ ahụ ya nke dị ka ihe ọrịa ekpenta na-eweta, a ga-eduru onye ahụ bịa nʼihu Erọn onye nchụaja maọbụ ụmụ ya ndị ikom, bụ ndị nchụaja.
\v 3 Onye nchụaja ga-eleru ọrịa ahụ dị ya nʼahụ anya. Ọ bụrụ na ajị dị gburugburu ebe ahụ ebidola ịcha ọcha, ọ bụrụkwa na ebe ahụ mibara ime, ọ bụ ọrịa ekpenta. Mgbe onye nchụaja leruchara ya anya, ọ ga-ekwupụta na onye ahụ bụ onye rụrụ arụ.
\v 4 Ọ bụrụkwanụ na ajị dị gburugburu ebe ahụ dị ọcha, ma na ebe ahụ emighị emi karịa akụkụ ahụ ya ndị ọzọ, onye nchụaja ga-edebe onye ahụ ebe ọ ga-anọ naanị ya abalị asaa.
\v 5 Mgbe ụbọchị asaa gasịrị, onye nchụaja ga-ele ya ahụ ọzọ. Ọ bụrụ na ọnya ahụ alabeghị, na ọ nwekwaghị mgbanwe ọbụla, a ga-edebekwa ya abalị asaa ọzọ.
\v 6 Mgbe abalị asaa nke a gafekwara, onye nchụaja ga-elekwa ya ahụ ọzọ. Ọ bụrụ na ọ dịtụla ya mma, na ọnya ahụ agbasaghị nʼanụ ahụ ya, onye nchụaja ga-asị na ọ dị ọcha, nʼihi na ọ bụ naanị ọnya efu. Onye ahụ ga-asakwa uwe ya mmiri, mgbe ahụ dị ọcha.
\v 7 Ma ọ bụrụ na ọnya ahụ agbasaa nʼahụ ya mgbe o gosicharala onye nchụaja onwe ya maka nsacha ịdị ọcha, ọ ga-alaghachikwa azụ ga hụ onye nchụaja ahụ ọzọ.
\v 8 Onye nchụaja ga-eleru ya anya, ọ bụrụ na onye nchụaja achọpụta na ọnya ahụ na-agbasa, ọ ga-agụ onye ahụ dịka onye rụrụ arụ, ọ bụ ọrịa na-efe efe.
\p 
\v 9 “Mgbe ọbụla mmadụ nwere ihe dị ka ọrịa na-efe efe nʼahụ ya, a ghaghị ịkpọtara ya onye nchụaja.
\v 10 Onye nchụaja ga-ele anya nʼakụkụ anụ ahụ ya zara aza ịchọpụta ma ọ dị ọcha, ma ajị dị gburugburu ebe ahụ ọ na-acha ọcha, na ịhụkwa ma ọ nwere ọnya dị gburugburu ebe ahụ.
\v 11 Ọ bụrụ na onye nchụaja ahụ ihe ndị a, ọ bụ ọrịa ekpenta nʼezie. Ọ ga-agụkwa onye ahụ dịka onye rụrụ arụ. A gaghị edebekwa ya ile ya ahụ, nʼihi na ọ bụrụlarị onye rụrụ arụ.
\p 
\v 12 “Ọ bụrụ na onye nchụaja elee onye ahụ anya hụ na ọrịa ọcha ahụ enupụtala nʼakụkụ ahụ ya niile, site nʼụkwụ ya ruo nʼisi ya,
\v 13 onye nchụaja a ga-eleru ya anya, ọ bụrụ na ọrịa ahụ enupụtala nʼahụ ya niile, ọ ga-ekwupụta na onye ahụ dị ọcha, ebe ọ bụ na ọrịa ahụ enupụtala mee ka anụ ahụ ya chawa ọcha.
\v 14 Ma ọ bụrụ na e nwere akụkụ ahụ ya ọnya ọ hụrụ pụtara, ọ ga-agụ ya dịka onye na-adịghị ọcha.
\v 15 Onye nchụaja ga-enyocha ọnya ahụ. Kwupụta na onye ahụ rụrụ arụ. Ọnya ahụ rụrụ arụ nʼihi na ọrịa ekpenta ka ọ bụ.
\v 16 Ọ bụrụ nʼọnya ahụ agbanwe na-acha ọcha, ha ga-agakwuru onye nchụaja.
\v 17 Onye nchụaja ga-ele ya ahụ. Ọ bụrụ na ọnya niile ahụ na-acha ezi ọcha, onye nchụaja ga-agụ ya dịka onye na-enweghị ntụpọ. Ndị dị ọcha ka ha ga-abụ.
\p 
\v 18 “Ọ bụrụ na etuto toro mmadụ nʼahụ alaa,
\v 19 ma akpụkpọ anụ ahụ ya anọgide na-acha ọcha, maọbụ na-acha ọbara ọbara, a ga-ejekwuru onye nchụaja ka o lee ya anya nʼahụ.
\v 20 Ọ bụrụ na onye nchụaja achọpụta na e nwere ọrịa dị nʼokpuru akpụkpọ ahụ ya, chọpụtakwa na ajị ya na-acha ọcha, onye nchụaja ga-agụ mmadụ ahụ dịka onye rụrụ arụ, nʼihi na ekpenta esitela nʼetuto ahụ pụta.
\v 21 Ọ bụrụ na onye nchụaja achọpụta na ajị ọcha adịghị nʼakpụkpọ ahụ ya, chọpụtakwa na ọnya ahụ abanyeghị nʼime, onye nchụaja ga-edebe onye ahụ ụbọchị asaa.
\v 22 Nʼime ụbọchị asaa ahụ, ọ bụrụ na ọnya ahụ abaa ụba karịa ka ọ dị na mbụ, onye nchụaja ga-agụ mmadụ ahụ dịka onye na-adịghị ọcha. Ọ bụ ọrịa na-emerụ emerụ ka ọ bụ.
\v 23 Ma ọ bụrụ na ọ baghị ụba karịa, onye nchụaja ga-agụ mmadụ ahụ dịka onye dị ọcha, nʼihi na ihe a bụ etuto lara ala.
\p 
\v 24 “Ọ bụrụ na ọkụ agbaa mmadụ, mee ka ọnya pụta ya nʼahụ: ọ bụrụ na ọnya ahụ ebido na-acha ọbara ọbara, maọbụ na-acha ezigbo ọcha,
\v 25 onye nchụaja ga-elezi onye dị otu a anya. Ọ bụrụ na ajị dị gburugburu ebe ọnya ahụ dị na-acha ọcha, maọbụ na ọnya ahụ mibara ime karịa, ọ ghọọla ekpenta nke si nʼọnya ahụ nupụta. Onye nchụaja ga-agụ mmadụ ahụ dịka onye na-adịghị ọcha. Ọ bụ ọrịa ekpenta.
\v 26 Ma ọ bụrụ na onye nchụaja elee ya hụ na ajị dị gburugburu ebe ahụ adịghị ọcha, ọ bụrụkwa na ọ dịghị ala karịa akpụkpọ ahụ, na ọ na-aṅacha, mgbe ahụ onye nchụaja ga-edebe onye ahụ iche ụbọchị asaa.
\v 27 Nʼụbọchị nke asaa, onye nchụaja ga-elezi onye ahụ anya nke ọma. Ọ bụrụ na ọ chọpụtara na ọnya ahụ na-abasaa nʼakpụkpọ ahụ ya, onye nchụaja ga-agụ onye ahụ dịka onye na-adịghị ọcha. Ọrịa na-emerụ emerụ ka ọ bụ.
\v 28 Ma ọ bụrụ na ọ gbanweghị, bụrụkwa na ọ basaghị nʼakpụkpọ ahụ ma ọ na-aṅacha, ọ bụ ihe ọzịza sitere nʼọkụ rere onye ahụ, onye nchụaja ga-agụ ya dịka onye dị ọcha, nʼihi na ọ bụ apa ọnya lara ala.
\p 
\v 29 “Ọ bụrụ na nwoke maọbụ nwanyị ọbụla enwee ọnya nʼisi, maọbụ na nti ya,
\v 30 onye nchụaja ga-elezi ọnya ahụ anya. Ọ bụrụ na ọ dị ala karịa akpụkpọ ahụ ya, ọ bụrụkwa na ajị dị na ya na-acha odo odo dị irighiri, onye nchụaja ga-agụ ha dịka ndị na-adịghị ọcha. Ọ bụ ọrịa na-emerụ emerụ nke dị nʼisi maọbụ nʼagba.
\v 31 Ma ọ bụrụ na onye nchụaja achọpụta na ọnya ahụ adịghị abasa abasa, maọbụ na ajị dị nʼebe ahụ adịghị eji ojii, onye nchụaja ga-edebe onye ahụ ụbọchị asaa.
\v 32 Nʼụbọchị nke asaa onye nchụaja ga-elezi ọnya ahụ anya. Ọ bụrụ na ọnya ahụ abasaghị karịa, ọ bụrụ na o nweghị ajị na-acha edo edo, ọ bụrụkwa na o mibaghị emiba,
\v 33 ọ ga-akpụchapụ ajị niile dị nʼakụkụ ebe ahụ ọnya mere ya, ma ọ gaghị akpụchapụ ajị dị nʼọnya ahụ nʼonwe ya. Onye nchụaja ga-edebe onye ahụ ụbọchị asaa.
\v 34 Nʼụbọchị nke asaa, onye nchụaja ga-elezi ọnya ahụ anya. Ọ bụrụ na ọ basaghị karịa, maọbụ mibanye nʼime karịa anụ ahụ, a ga-agụ mmadụ ahụ dịka onye dị ọcha. Ọ ga-apụ sachaa uwe ya, bụrụ onye dị ọcha.
\v 35 Ma ọ bụrụ na mgbe a gụchara ya nʼonye dị ọcha ọnya ahụ emesịa basaa nʼahụ ya.
\v 36 Onye nchụaja ga-ele ya anya. Ọ bụrụ na ọnya ahụ agbasaala nʼakpụkpọ ahụ ya, onye nchụaja a gaghị achọwa ajị na-acha edo edo. Onye ahụ rụrụ arụ.
\v 37 Ma ọ bụrụ nʼuche onye nchụaja na ọnya ahụ adịghị abasa abasa, ọ bụrụkwa na ajị ojii epupụtala nʼebe ahụ, ọnya ahụ alaala. Onye dị ọcha ka mmadụ ahụ bụ. Onye nchụaja ga-ekwupụta na ọ dị ọcha.
\p 
\v 38 “Mgbe nwoke maọbụ nwanyị ọbụla nwere ntụpọ ọcha nʼanụ ahụ ya,
\v 39 onye nchụaja ga-ele ya ahụ. Ọ bụrụ na ntụpọ ahụ adịghị achazi ezi ọcha, ọ bụ ọkọ nupụtara onye ahụ nʼahụ. Onye ahụ dị ọcha.
\p 
\v 40 “Mgbe ajị na-adịghịkwa nwoke nʼisi, ọ bụ isi nkwọcha, onye ahụ dị ọcha.
\v 41 Otu aka ahụ, ọ bụrụ na isi ya esite nʼegedege ihu ya kwọchasịa, ọ bụghị ekpenta, onye dị ọcha ka ọ bụ.
\v 42 Kama ọ bụrụ na onye ahụ enwee etuto nʼisi ya maọbụ nʼegedege ihu ya nke na-acha ọbara ọbara, na ọcha ọcha, o nwere ike bụrụ ọrịa ekpenta na-enupụta ya nʼisi maọbụ nʼegedege ihu.
\v 43 Nʼihi ya, onye nchụaja ga-elezi ya anya. Ọ bụrụ na etuto ahụ toro ya nʼisi maọbụ nʼegedege ihu na-acha ọbara ọbara, na ọcha ọcha, ọ ga-abụ na ọ ghọọla ọrịa ekpenta.
\v 44 Onye nchụaja ga-agụ ya dịka onye ekpenta. Ọ bụkwa onye rụrụ arụ, nʼihi ọnya ahụ dị ya nʼisi.
\p 
\v 45 “Onye ọbụla a chọpụtara na ọ bụ onye ekpenta ga-eyi uwe dọkara adọka, hapụ agịrị isi ya ka ọ dịka nke onye ara. Ọ ga-ekpuchi elu egbugbere ọnụ ya, na-eti mkpu na-asị, ‘Onye rụrụ arụ ka m bụ. Onye rụrụ arụ ka m bụ!’
\v 46 Ụbọchị niile nke ọ nọ nʼọrịa ahụ, ọ gaghị ebi nʼime obodo nʼetiti ụmụ mmadụ nʼihi na onye rụrụ arụ ka ọ bụ.
\s1 Usoro iwu banyere Ọrịa na-efe efe
\p 
\v 47 “Ọ bụrụ na a hụrụ ntụpọ yiri ntụpọ ọrịa na-efe efe nʼuwe ajị anụ maọbụ nʼuwe ogho ọcha,
\v 48 maọbụ nʼakpụkpọ anụ ọbụla, maọbụ nʼihe ọbụla e ji akpụkpọ ajị anụ maọbụ uwe ogho ọcha, uwe a kpara akpa, maọbụ nke a tụrụ atụ mee.
\v 49 Ọ bụrụkwa na ntụpọ dị nʼuwe ahụ, maọbụ nʼakpụkpọ anụ ahụ, maọbụ nke a kpara akpa, maọbụ nke atụrụ atụ, maọbụ nʼihe akpụkpọ anụ ọbụla na-acha ahịhịa ndụ maọbụ uhie uhie, o nwere ike ịbụ ọrịa na-efe efe. A ga-ewegara onye nchụaja uwe ahụ ka o lezie ya anya.
\v 50 Onye nchụaja ga-ele ya anya, were ya debe ya iche ụbọchị asaa.
\v 51 Nʼụbọchị nke asaa, onye nchụaja ga-ele ya anya ọzọ. Ọ bụrụ na ntụpọ ahụ agbasaa nʼuwe ahụ maọbụ nʼihe ahụ a kpara akpa, maọbụ nʼihe ahụ a tụrụ atụ, maọbụ nʼihe akpụkpọ anụ ahụ, nʼime ụbọchị asaa ndị a, nʼagbanyeghị ihe e ji ha eme, ọ bụ ọrịa ọjọọ na-efe efe. Ihe ahụ bụ ihe rụrụ arụ.
\v 52 A ga-akpọ uwe ahụ, maọbụ akwa ajị anụ ahụ, maọbụ akwa ajị anụ a kpara akpa, maọbụ akwa ogho ọcha ahụ, maọbụ ihe akpụkpọ anụ ọbụla ọkụ, nʼihi na ọrịa na-efe efe dị nʼime ya, nʼihi na ọrịa na-eweta mbibi ka ọ bụ. A ghakwaghị iji ọkụ rechapụ ya.
\p 
\v 53 “Ma ọ bụrụ na onye nchụaja ahụ ele hụ na ntụpọ ahụ agbasaghị nʼuwe ahụ, maọbụ nʼakwa ahụ a kpara akpa, maọbụ akwa a tụrụ atụ, maọbụ nʼihe akpụkpọ anụ ahụ ọbụla.
\v 54 Ọ ga-enye iwu ka a saa ihe ndị ahụ niile mmiri, wezugakwa ya iche ruo ụbọchị asaa ọzọ.
\v 55 Mgbe a sachara ihe ahụ mmiri, onye nchụaja ga-ele ya anya ọzọ. Ọ bụrụ na ntụpọ ahụ agbanwebeghị, ọ bụrụ na ọ na-achakwa dịka o si acha na mbụ, mgbe ụbọchị ndị a gasịrị, ọ bụ ezie na ọ gbasaghị, ọ bụ ihe rụrụ arụ. A ga-akpọ ya ọkụ, ma ntụpọ ahụ ọ dị nʼihu uwe ahụ maọbụ nʼazụ ya.
\v 56 Ma ọ bụrụ na onye nchụaja elee ya anya hụ na ụcha ntụpọ dị nʼihe ahụ adịghị ukwuu nʼihi nsacha a sachara ya na mmiri, ọ ga-achakapụ akụkụ uwe ahụ, maọbụ akwa ahụ a kpara akpa maọbụ nke a tụrụ atụ.
\v 57 Ọ bụrụ na ntụpọ ahụ emesịa pụta ọzọ nʼuwe ahụ, maọbụ nʼakwa ahụ a kpara akpa, maọbụ nke a tụrụ atụ, maọbụ nʼakpụkpọ anụ ahụ, o gosiri na ọ na-agbasa agbasa. Ihe ọbụla nwere ntụpọ ahụ ka a ga-akpọ ọkụ.
\v 58 Uwe maọbụ ihe a kpara akpa, maọbụ ihe a tụrụ atụ, maọbụ ihe akpụkpọ anụ ọbụla a sara mmiri nke ntụpọ dị na ya pụrụ, a ga-asa ya mmiri ọzọ. Ọ ga-abụkwa ihe dị ọcha.”
\p 
\v 59 Ndị a bụ usoro iwu metụtara ntụpọ dịka ntụpọ ọrịa na-efe efe nke dị nʼuwe ajị anụ maọbụ uwe ogho ọcha, maọbụ nʼihe a kpara akpa maọbụ nʼihe a tụrụ atụ, maọbụ nʼihe akpụkpọ anụ. Iwu ndị a ga-enye aka ịchọpụta ma ha rụrụ arụ, maọbụ na ha dị ọcha.
\c 14
\s1 Usoro ido ụlọ na ndị ekpenta ọcha
\p 
\v 1 \nd Onyenwe anyị\nd* gwara Mosis, sị,
\v 2 “Ndị a bụ usoro iwu gbasara onye ọrịa ekpenta nʼoge a na-eme mmemme ịdị ọcha ya, mgbe e dutere ya bịakwute onye nchụaja.
\v 3 Onye nchụaja ga-apụ gaa nʼazụ ebe obibi nọdụ nʼebe ahụ lee ya ahụ, ịchọpụta ma ọrịa ekpenta ya ọ laala nʼezie. Ọ bụrụ na ọrịa ya alaala,
\v 4 onye nchụaja ga-enye iwu ka e weta nnụnụ abụọ dị ndụ, na ụfọdụ osisi sida, na eriri ogho uhie, na hisọp, maka onye ahụ a ga-emere mmemme ịdị ọcha.
\v 5 Onye nchụaja ga-enye iwu ka e gbuo otu nʼime nnụnụ abụọ ahụ nʼelu mmiri e si nʼọdọ mmiri na-asọ asọ kute nke dị nʼime ite aja.
\v 6 Ọ ga-ewere nnụnụ nke ọzọ dị ndụ, ya na osisi sida ahụ, na ogho uhie ahụ, na hisọp ahụ, denye ha nʼime ọbara nnụnụ ahụ e gburu nʼelu mmiri ahụ.
\v 7 Mgbe ahụ, onye nchụaja ga-efe ọbara ahụ ugboro asaa nʼahụ onye ahụ a na-eme ka ọ dị ọcha site nʼọrịa ekpenta. Ọ ga-ekwupụtakwa na a gwọọla onye ahụ. Emesịa, ọ ga-ahapụ nnụnụ ahụ ka o felaa nʼọhịa.
\p 
\v 8 “Onye ahụ e mere ka ọ dị ọcha ga-asacha uwe ya, kpụchaa ntutu isi ya, saakwa ahụ ya. Mgbe ahụ, ọ ga-adị ọcha. Emesịa, ọ ga-esoro ndị mmadụ biri nʼobodo. Ma ọ gaghị abanye nʼụlọ nke aka ya tutu ụbọchị asaa agafee.
\v 9 Nʼụbọchị nke asaa, ọ ga-akpụchapụ ntutu isi ya, na afụọnụ ya, na ikuanya ya, na ajị ndị ọzọ dị ya nʼahụ. Ọ ga-asa uwe ya na ahụ ya niile. Mgbe ahụ, a ga-agụ ya nʼonye dị ọcha.
\p 
\v 10 “Nʼụbọchị nke asatọ, ọ ga-ewere ebule abụọ na-enweghị ntụpọ, na otu nne atụrụ nke na-enweghị ntụpọ gbara otu afọ, ya na iri iko ọka a kwọrọ nke ọma a gwakọtara mmanụ oliv maka aja mkpụrụ ọka, na otu iko mmanụ.
\v 11 Onye nchụaja ahụ lere ya ahụ sị na ha dị ọcha, ga-ewere aja ndị a, ha na onye ahụ a na-aga ime ka ọ dị ọcha chee nʼihu \nd Onyenwe anyị\nd* nʼọnụ ụzọ ụlọ nzute.
\p 
\v 12 “Mgbe ahụ, onye nchụaja ahụ ga-ewere otu nʼime ụmụ ebule ahụ, na otu iko mmanụ chụọ ya dịka onyinye aja ikpe ọmụma. Ọ ga-efufe ha nʼihu \nd Onyenwe anyị\nd* dịka aja mfufe.
\v 13 Ọ ga-egbu nwa ebule ahụ nʼakụkụ ebe nsọ ahụ, nʼebe a na-anọ egbu anụ aja mmehie na aja nsure ọkụ. Ọ bụ onye nchụaja ga-ewere anụ aja ikpe ọmụma a, dịka o were nke aja mmehie. Ọ bụ ihe dịkarịsịrị nsọ.
\v 14 Onye nchụaja ahụ ga-ewere ụfọdụ nʼime ọbara aja ikpe ọmụma ahụ, tee nʼọnụ ntị aka nri nke onye ahụ a na-eme ka ọ dị ọcha. Ọ ga-etekwa ya nʼisi mkpụrụ aka nke aka nri ya, na nʼelu isi mkpụrụ ụkwụ nke ụkwụ aka nri ya.
\v 15 Emesịa onye nchụaja ga-awụnyetụ mmanụ oliv ahụ nʼọbụaka nke aka ekpe ya,
\v 16 ọ ga-arụnye otu mkpịsịaka nri ya nʼime mmanụ dị nʼọbụaka ya, ọ ga-ewere mkpịsịaka ya fesa ụfọdụ nʼime ya ugboro asaa nʼihu Onyenwe anyị.
\v 17 Onye nchụaja ga-ewere mmanụ ahụ fọdụrụ nʼọbụaka ya tee ya onye ahụ nʼọnụ ntị aka nri nke onye ahụ a na-aga ime ka ọ dị ọcha, na nʼisi mkpụrụ aka nke aka nri ya, na nʼisi mkpụrụ ụkwụ nke aka nri ya, nʼelu ọbara aja ikpe ọmụma ahụ mee.
\v 18 Ọ ga-ete mmanụ ahụ fọdụrụ nʼaka ya, nʼisi onye ahụ a na-eme ka ọ dị ọcha. Onye nchụaja ga-ekpuchikwara ha mmehie ya nʼihu Onyenwe anyị.
\p 
\v 19 “Mgbe ahụ, onye nchụaja ga-achụ aja mmehie, kpuchiere onye ahụ a ga-eme ka ọ dị ọcha site na-adịghị ọcha ha mmehie ya. Emesịa, onye nchụaja ga-egbu aja nsure ọkụ ahụ,
\v 20 were ya na onyinye mkpụrụ ọka chụọrọ onye ahụ aja, maka ikpuchiri ya mmehie ya. Mgbe ahụ, a ga-agụ onye ahụ nʼonye dị ọcha.
\p 
\v 21 “Ọ bụrụ na ọ bụ ogbenye onye na-enweghị ike iweta ihe ndị a, ha aghaghị iwere otu nwa ebule dịka aja ikpe ọmụma nke a ga-efufe nʼihi aja ikpuchi mmehie ha, Ọ ga-ewetakwa iko ọka a kwọrọ nke ọma asaa maọbụ ihe ọtụtụ efaa a gwara mmanụ oliv dịka aja mkpụrụ ọka, ya na otu iko mmanụ.
\v 22 Ọ ga-ewetakwa nduru abụọ maọbụ kpalakwukwu abụọ, nke ọbụla o nwere ike iweta. Otu ga-abụ maka aja mmehie, nke ọzọ ga-abụ maka aja nsure ọkụ.
\p 
\v 23 “Ọ ga-ewere ha nye onye nchụaja nʼọnụ ụzọ ụlọ nzute nʼihu \nd Onyenwe anyị\nd*, nʼụbọchị nke asatọ ya, maka ime ka ha dị ọcha.
\v 24 Onye nchụaja ga-ewerekwa nwa atụrụ aja ikpe ọmụma ahụ, ya na otu iko mmanụ oliv ahụ, fufee ha nʼihu ebe ịchụ aja nye \nd Onyenwe anyị\nd*.
\v 25 Ọ ga-egbu nwa atụrụ aja ikpe ọmụma ahụ, were ụfọdụ ọbara ya tee nʼọnụ ntị aka nri onye ahụ a na-aga ime ka ọ dị ọcha, na nʼisi mkpụrụ aka nke aka nri ya, na nʼisi mkpụrụ ụkwụ nke aka nri ya.
\v 26 Onye nchụaja ahụ ga-awụnye ụfọdụ mmanụ oliv ahụ nʼọbụaka nke aka ekpe ya,
\v 27 ọ ga-ewere mkpịsịaka nri ya fesa ụfọdụ mmanụ ahụ nke dị nʼọbụaka ya ugboro asaa nʼihu \nd Onyenwe anyị\nd*.
\v 28 Ọ ga-etekwa ụfọdụ mmanụ ahụ dị nʼaka ya nʼebe ndị ahụ o tere ọbara ikpe ọmụma ahụ, nke bụ nʼọnụ ntị onye ahụ nke a na-eme ka ọ dị ọcha, na nʼisi mkpụrụ aka nke aka nri ya, na nʼisi mkpụrụ ụkwụ nke aka nri ya.
\v 29 Mmanụ nke fọdụrụ nʼaka ya ka onye nchụaja ga-ete nʼisi onye ahụ a na-eme ka ọ dị ọcha, ikpuchi mmehie ha nʼihu \nd Onyenwe anyị\nd*.
\v 30 Emesịa, ọ ga-eji nduru abụọ ahụ maọbụ kpalakwukwu abụọ ahụ, nke ọbụla o nwere ike iweta, chụọ aja.
\v 31 Otu ga-abụ maka aja mmehie, nke ọzọ ga-abụ maka aja nsure ọkụ, ha na aja mkpụrụ ọka. Nʼụzọ dị otu a, onye nchụaja ga-ekpuchiri ya mmehie ya nʼihu \nd Onyenwe anyị\nd*, bụ onye ahụ a na-eme ka ọ dị ọcha.”
\p 
\v 32 Ndị a bụ usoro iwu dịrị onye ọbụla e sitere nʼọrịa ekpenta mee ka ọ dị ọcha, onye aka ya na-erughị iweta ihe o kwesiri iweta, bụ nke e ji eme ka ọ dị ọcha.
\s1 Ọrịa na-efe efe dị nʼụlọ
\p 
\v 33 \nd Onyenwe anyị\nd* gwara Mosis na Erọn okwu sị,
\v 34 “Mgbe unu banyere ala Kenan, bụ ala ahụ m na-enye unu, ọ bụrụ na o nwee ụlọ ọbụla m webatara ọrịa na-efe efe,
\v 35 onyenwe ụlọ ahụ ga-ejekwuru onye nchụaja sị ya, ‘Ahụla m ihe yiri ọrịa na-efe efe nʼụlọ m.’
\v 36 Onye nchụaja ahụ ga-enye iwu ka a kwapụsịa ihe niile dị nʼụlọ ahụ tupu ọ gaa lezie ụlọ ahụ anya, ka ihe niile dị nʼụlọ ahụ ghara ịbụ ihe rụrụ arụ, ma ọ bụrụ na achọpụta ọrịa na-efe efe nʼụlọ ahụ. Mgbe a kwapụtasịrị ihe dị nʼụlọ ahụ, onye nchụaja ga-aga lee ụlọ ahụ.
\v 37 Ọ ga-ele ntụpọ dị nʼahụ ụlọ ahụ. Ọ bụrụ na ntụpọ ahụ na-acha ahịhịa ndụ ahịhịa ndụ, maọbụ ọbara ọbara,\f + \fr 14:37 \ft Nke na-acha mmanụ nri mmanụ nri\f* ọ bụrụkwa na ha miri emi karịa aja ụlọ ahụ nʼile anya,
\v 38 onye nchụaja ga-esi nʼọnụ ụzọ ụlọ ahụ pụọ, kpọchie ụlọ ahụ ụbọchị asaa.
\v 39 Nʼụbọchị nke asaa, onye nchụaja ga-alọghachi bịa lee ụlọ ahụ ọzọ. Ọ bụrụ na ntụpọ ahụ agbasaala nʼaja ụlọ ahụ,
\v 40 onye nchụaja ga-enye iwu ka e tida akụkụ aja ụlọ ahụ bufuo ya nʼebe a na-ekpofu ihe rụrụ arụ nʼazụ obodo.
\v 41 Ọ ga-enyekwa iwu ka a kpụchaa aja ụlọ niile dị nʼime ụlọ ahụ, bufukwaa aja niile a kpụchapụtara nʼebe a na-ekpofu ihe rụrụ arụ nʼazụ obodo.
\v 42 A ga-ebute nkume ọzọ jiri ha dochie ndị ahụ e bupụsịrị. A ga-ejikwa ụrọ ọhụrụ tee ụlọ ahụ ọzọ.
\p 
\v 43 “Ma ọ bụrụ na ntụpọ ahụ apụta ọzọ, mgbe e bupụsịrị nkume ndị ahụ, ma mgbe a kpuchasịrị aja ụlọ ma techikwaa ya,
\v 44 onye nchụaja ga-abịa lee ya. Ọ bụrụ na ọ hụ na ntụpọ ahụ agbasaala ọzọ, ọ ga-agụ ụlọ ahụ dịka ihe rụrụ arụ, nʼihi na ntụpọ ahụ bụ ọrịa na-efe efe.
\v 45 Ọ ga-enye iwu ka a kwatuo ụlọ ahụ bufukwaa ihe niile e jiri rụọ ya, nkume niile, osisi niile na ụrọ niile, nʼebe a na-ekpofu ihe rụrụ arụ nʼazụ obodo.
\p 
\v 46 “Onye ọbụla banyere nʼụlọ ahụ nʼoge e mechiri ya, ga-abụ onye rụrụ arụ ruo nʼoge uhuruchi.
\v 47 Onye ọbụla dinara ala maọbụ rie nri nʼime ya, ga-asacha uwe ya.
\p 
\v 48 “Ma ọ bụrụ na onye nchụaja abịa hụ na ntụpọ ahụ apụtaghị ọzọ, mgbe e techara ụlọ ahụ ụrọ nke ugboro abụọ, ọ ga-agụ ya nʼụlọ dị ọcha, nʼihi na ọrịa ahụ na-efe efe alaala.
\v 49 Ọ ga-ejikwa nnụnụ abụọ, na osisi sida, na ogho uhie, na osisi hisọp mee mmemme ido ihe ọcha.
\v 50 Ọ ga-egbu otu nʼime nnụnụ ndị ahụ nʼelu mmiri e si nʼiyi na-asọ asọ kute, nke dị nʼime ite aja.
\v 51 Ọ ga-edenye osisi sida ahụ, na ogho uhie ahụ, na osisi hisọp ahụ, nʼime ọbara nnụnụ ahụ na mmiri ahụ. Ọ ga-efesa ọbara ahụ nʼụlọ ahụ ugboro asaa.
\v 52 Ọ bụ ọbara nnụnụ ahụ, na mmiri ahụ, na nnụnụ nke ọzọ ahụ dị ndụ, na osisi sida ahụ na hisọp ahụ, na ogho uhie ahụ ka ọ ga-eji mee ka ụlọ ahụ dị ọcha.
\v 53 Ọ ga-ahapụ nnụnụ ahụ dị ndụ ka o fepụ felaa nʼọhịa dị nʼazụ obodo. Nke a ga-abụ otu e si kpuchiere ụlọ ahụ mmehie ya. Ọ ga-adịkwa ọcha.”
\p 
\v 54 Ndị a bụ usoro iwu metụtara ọrịa ekpenta, na ọkọ,
\v 55 na ọrịa na-efe efe dị nʼuwe maọbụ nʼụlọ,
\v 56 maọbụ etuto, maọbụ ntụpọ, maọbụ ọnya.
\v 57 Iwu ndị a ga-enye aka ịmata ihe rụrụ arụ maọbụ ihe na-adịghị ọcha.
\p Ndị a bụ usoro iwu metụtara ọrịa ekpenta na ọrịa na-efe efe.
\c 15
\s1 Ihe nsọpụta ndị na-ebute adịghị ọcha
\p 
\v 1 \nd Onyenwe anyị\nd* gwara Mosis na Erọn okwu sị ha,
\v 2 “Gwa ụmụ Izrel okwu sị ha, ‘Nwoke ọbụla ihe nsọpụta si nʼahụ ya na-asọpụta, bụ onye rụrụ arụ.
\v 3 Onye ahụ rụrụ arụ mgbe ihe ahụ si ya nʼahụ na-asọpụta, rụọkwa arụ mgbe ihe ahụ kwụsịrị ịsọ. Otu a ka ihe ọsụsọ ahụ si eme ka onye ahụ rụọ arụ.
\p 
\v 4 “ ‘Ihe ọbụla onye ahụ ji anọdụ ala, maọbụ nke o ji dinaa bụ ihe rụrụ arụ.
\v 5 Onye ọbụla metụrụ ihe ndina ya aka ga-abụ onye rụrụ arụ ruo uhuruchi. Ọ ga-asa uwe ya, na ahụ ya mmiri.
\v 6 Onye ọbụla nọdụrụ ala nʼihe onye ahụ nọdụrụ ala nʼoge ahụ ọ bụ onye rụrụ arụ, ga-abụ onye rụrụ arụ ruo uhuruchi. Ọ ga-asa uwe ya, na ahụ ya mmiri.
\p 
\v 7 “ ‘Onye ọbụla metụrụ nwoke ahụ ihe si nʼahụ ya na-asọpụta aka ga-asa uwe ya na ahụ ya mmiri, bụrụ onye rụrụ arụ ruo uhuruchi.
\p 
\v 8 “ ‘Onye ọbụla dị ọcha nke onye ahụ bụsara ọnụ mmiri ga-abụ onye rụrụ arụ ruo uhuruchi. Ọ ga-asa uwe ya na ahụ ya mmiri.
\p 
\v 9 “ ‘Ihe ọbụla onye ahụ ji anọkwasị nʼelu anụmanụ ọ na-agba ga-abụ ihe rụrụ arụ.
\v 10 Onye ọbụla ga-eburu, maọbụ metụ ihe ọbụla o ji nọdụ ala aka ga-abụ onye rụrụ arụ ruo uhuruchi. Ọ ga-asa uwe ya na ahụ ya mmiri.
\p 
\v 11 “ ‘Ọ bụrụ na nwoke ahụ rụrụ arụ ebughị ụzọ saa aka ya tupu o metụ mmadụ aka, onye ahụ o metụrụ aka ga-abụ onye rụrụ arụ ruo uhuruchi. Ọ ga-asa uwe ya na ahụ ya mmiri.
\p 
\v 12 “ ‘A ga-etiwa ite aja ọbụla onye ahụ metụrụ aka, jiri mmiri ṅachaa ihe osisi ọbụla o metụrụ aka.
\p 
\v 13 “ ‘Mgbe e mere ka onye ahụ bụrụ onye dị ọcha site nʼihe nsọpụta a, ọ ga-anọ ụbọchị asaa maka ịdị ọcha ya. Ọ ga-asa uwe ya na ahụ ya nʼime mmiri na-asọ asọ tupu ọ bụrụ onye dị ọcha.
\v 14 Nʼụbọchị nke asatọ, ọ ga-ewere nduru abụọ maọbụ ụmụ kpalakwukwu abụọ bịa nʼihu \nd Onyenwe anyị\nd* nʼọnụ ụzọ ụlọ nzute, were ha nye onye nchụaja.
\v 15 Onye nchụaja ga-eji ha chụọrọ ya aja nʼebe ahụ. Otu nʼime nnụnụ abụọ ahụ ga-abụ maka aja mmehie, nke ọzọ maka aja nsure ọkụ. Nʼụzọ dị otu a, ọ ga-ekpuchiri nwoke ahụ mmehie ya nʼihu \nd Onyenwe anyị\nd* nʼihi ihe ọsụsọ ahụ.
\p 
\v 16 “ ‘Nwoke ọbụla mkpụrụ nwa ya si ya nʼamụ pụọ, ga-asa ahụ ya nke ọma, bụrụ onye rụrụ arụ ruo uhuruchi.
\v 17 A ga-asacha ihe ọbụla mkpụrụ nwa ahụ metụrụ, maọbụ akwa maọbụ akpụkpọ anụ. Ha ga-abụ ihe rụrụ arụ ruo uhuruchi.
\v 18 Mgbe nwoke na nwanyị dinakọrọ, ma nwoke ahụ anyụpụta mkpụrụ nwa, ha abụọ ga-asa ahụ ha nke ọma, bụrụ ndị rụrụ arụ ruo uhuruchi.
\p 
\v 19 “ ‘Mgbe ọbara si nwanyị nʼahụ pụọ dịka o kwesiri nʼoge a kara aka nʼọnwa ọbụla, nwanyị ahụ ga-abụ onye rụrụ arụ ụbọchị asaa. Onye ọbụla metụrụ ya aka nʼoge a ga-abụ onye rụrụ arụ ruo uhuruchi.
\p 
\v 20 “ ‘Ihe ọbụla o dinara nʼelu ya nʼoge a, maọbụ ihe ọ nọkwasịrị nʼelu ya ga-arụ arụ.
\v 21 Onye ọbụla metụrụ ihe ndina ya aka, ga-asa uwe ya na ahụ ya. Ọ ga-abụ onye rụrụ arụ ruo uhuruchi.
\v 22 Onye metụrụ ihe o ji nọdụ ala aka ga-asa uwe ya na ahụ ya. Ọ ga-abụ onye rụrụ arụ ruo uhuruchi.
\v 23 Ọ bụrụkwa na ọ bụ ihe ndina ya, maọbụ ihe ọzọ nke o ji nọdụ ala, onye ọbụla metụrụ ya aka ga-abụ onye rụrụ arụ ruo uhuruchi.
\p 
\v 24 “ ‘Nwoke dinakwuru nwanyị ọbara si nʼahụ ya na-apụta, ọ bụrụ na ọbara ahụ emetụ ya, ọ ga-abụ onye rụrụ arụ abalị asaa. Ihe ndina ọbụla o dinara nʼelu ya ga-abụ ihe rụrụ arụ.
\p 
\v 25 “ ‘Ọ bụrụ na ọbara si nwanyị nʼahụ na-apụta agafee oge o kwesiri ịkwụsị maọbụ na ọ pụtara nʼoge ọ na-ekwesighị ịpụta, nwanyị ahụ ga-anọgide bụrụ onye rụrụ arụ ogologo ụbọchị ndị ahụ niile ọbara ahụ si ya nʼahụ na-apụta.
\v 26 Ihe ọbụla o dinara nʼelu ya mgbe ọbara si ya nʼahụ na-apụta, maọbụ ihe ọbụla ọ nọdụrụ ala nʼelu ya, ga-abụ ihe rụrụ arụ, dịka mgbe ọbara nke oge a kara aka.
\v 27 Onye ọbụla metụrụ ihe ndina ya maọbụ ihe ọ nọdụrụ ala nʼelu ya aka, ga-arụ arụ ruo uhuruchi. Ọ ga-asakwa uwe ya na ahụ ya mmiri.
\p 
\v 28 “ ‘Mgbe ọbara ahụ kwụsịrị, ọ ga-agụ ụbọchị asaa site nʼoge ọ kwụsịrị. Mgbe abalị asaa ahụ zuru, ọ ga-abụ onye dị ọcha.
\v 29 Nʼụbọchị nke asatọ, ọ ga-ewere nduru abụọ maọbụ ụmụ kpalakwukwu abụọ, nye onye nchụaja nʼọnụ ụzọ ụlọ nzute.
\v 30 Onye nchụaja ahụ ga-eji otu chụọrọ ya aja mmehie, werekwa nke ọzọ chụọrọ ya aja nsure ọkụ. Nʼụzọ dị otu a, ọ ga-ekpuchiri ya mmehie ya nʼihu \nd Onyenwe anyị\nd*, nʼihi adịghị ọcha nke ihe ọsụsọ ya.
\p 
\v 31 “ ‘Unu ga-ekewapụ ụmụ Izrel site nʼihe ndị ahụ na-emerụ ha, ka ha ghara ịnwụ nʼọnọdụ adịghị ọcha ha nʼihi imerụ ụlọ nzute m, nke dị nʼetiti ha.’ ”
\p 
\v 32 Ndị a bụ usoro iwu gbasara ndị ikom ihe si nʼahụ ha na-asọpụta, na ndị ikom rụrụ arụ nʼihi mkpụrụ nwa si ha nʼahụ pụọ.
\v 33 Ọ bụkwa iwu dịrị nwanyị ọbara si nʼahụ ya pụọ nʼoge a kara aka, na nwoke maọbụ nwanyị ọbụla ihe si nʼahụ ya na-asọpụta, na nke dịrị nwoke ọbụla ya na nwanyị ga-edinakọ nʼoge nwanyị ahụ bụ onye rụrụ arụ.
\c 16
\s1 Ụbọchị mkpuchi mmehie
\p 
\v 1 \nd Onyenwe anyị\nd* gwara Mosis okwu mgbe ụmụ ndị ikom Erọn abụọ ndị ahụ bịara nʼihu \nd Onyenwe anyị\nd* nwụsịrị.
\v 2 \nd Onyenwe anyị\nd* sịrị Mosis, “Gwa nwanne gị nwoke Erọn si ya ka ọ ghara ịbata mgbe ọbụla ọ chọrọ, nʼime Ebe ahụ Kachasị Nsọ nke dị nʼazụ akwa mgbochi, nke dị nʼihu ebe mkpuchi mmehie dị nʼelu igbe ọgbụgba ndụ ahụ, ma ọ bụghị ya ọ ga-anwụ. Nʼihi na aga m apụta ìhè nʼime igwe ojii dị nʼelu ebe mkpuchi ahụ.
\p 
\v 3 “Otu a ka Erọn ga-esi na-abata nʼEbe ahụ Kachasị Nsọ. Ọ ga-eweta nwa oke ehi nʼihi aja mmehie, na ebule ọ ga-eji chụọ aja nsure ọkụ,
\v 4 Ọ ga-eyikwasị onwe ya uwe mwụda ọcha,\f + \fr 16:4 \ft Ndị nchụaja na-eyipụ uwe ije ozi ha, hapụ ya nʼime ụlọnsọ ukwu Onyenwe anyị, mgbe ha jesiri ozi. \xt Izk 44:17-19\xt*\f* ya na uwe ime ahụ dị ọcha. Ọ ga-eke gburugburu ukwu ya ihe ike nʼukwu akwa ọcha, keekwa akwa ọcha nʼisi ya. Ndị a bụ uwe dị nsọ, nʼihi ya, ọ ga-ebu ụzọ saa ahụ tupu ọ na-eyi ha.
\v 5 Ọ ga-esi nʼaka ọgbakọ ụmụ Izrel nata mkpi abụọ nʼihi aja mmehie, na otu ebule nʼihi aja nsure ọkụ.
\p 
\v 6 “Erọn ga-eweta oke ehi nke ya, maka aja mmehie iji kpuchie mmehie nke ya na nke ezinaụlọ ya.
\v 7 Emesịa, ọ ga-ewere mkpi abụọ ndị ahụ chee ha nʼihu \nd Onyenwe anyị\nd* nʼọnụ ụzọ ụlọ nzute ahụ.
\v 8 Ọ ga-efe nza nʼisi mkpi abụọ ahụ, ịchọpụta nke dịrị \nd Onyenwe anyị\nd* nke ọzọ abụrụ nke ọ ga-ahapụ.
\v 9 Mkpi ahụ nza mara ga-abụ nke \nd Onyenwe anyị\nd*, ya ka Erọn ga-egbu dịka aja mmehie.
\v 10 Ma mkpi ahụ nke nza mara dịka ewu na-ewere ọnọdụ iburu mmehie ka a ga-eche na ndụ nʼihu \nd Onyenwe anyị\nd*, nʼihi iji ya mee mmemme mkpuchi mmehie, a ga-ahapụ ya ka o buru mmehie niile kpafuo nʼọzara.
\p 
\v 11 “Erọn ga-eweta oke ehi maka aja mmehie nke ya onwe ya, iji kpuchie mmehie ya na nke ezinaụlọ ya. Ọ ga-egbu oke ehi ahụ maka aja mmehie nke ya onwe ya.
\v 12 Ọ ga-esite nʼebe ịchụ aja dị nʼihu \nd Onyenwe anyị\nd* were ihe ịgụ ọkụ jupụtara nʼicheku ọkụ. Ọ ga-ewerekwa ụda na-esi isi ụtọ ruru mkpoju aka abụọ, were ha bata nʼime akụkụ nke ọzọ nke akwa mgbochi ahụ.
\v 13 Nʼebe ahụ ọ ga-awụnye ụda ndị ahụ na-esi isi ụtọ nʼelu icheku ọkụ ahụ nʼihu \nd Onyenwe anyị\nd*, ka anwụrụ ọkụ nke ụda ndị a kpuchie ebe mkpuchi mmehie ahụ dị nʼelu Ihe Ama ahụ ka ọ ghara ịnwụ.
\v 14 Ọ ga-ewebatakwa ụfọdụ ọbara oke ehi ahụ, jiri mkpịsịaka ya fesa ya nʼihu ebe mkpuchi mmehie ahụ, nʼakụkụ ọwụwa anyanwụ, fesakwa ya ugboro asaa nʼihu ebe mkpuchi mmehie ahụ.
\p 
\v 15 “Emesịa, ọ ga-esi nʼebe ahụ pụọ gaa gbuo mkpi aja mmehie ụmụ Izrel, werekwa ọbara ya bata nʼazụ akwa mgbochi fesa ya nʼelu ebe mkpuchi mmehie ahụ, na nʼihu ya, dịka o jiri ọbara nwa oke ehi ahụ mee.
\v 16 Nʼụzọ dị otu a, ọ ga-ekpuchiri Ebe ahụ Kachasị Nsọ mmehie ya, nʼihi mmehie na nnupu isi ụmụ Izrel, ihe ọbụla mmehie ndị ahụ bụ. Ọ ga-achụkwa ụdị aja a nʼihi ụlọ nzute ahụ, nʼihi na ọ dị nʼetiti ebe obibi rụrụ arụ nke ụmụ Izrel.
\v 17 O nweghị onye ọbụla ọzọ ga-anọ nʼime ụlọ nzute ahụ, site nʼoge Erọn banyere nʼEbe ahụ Kachasị Nsọ ịchụ aja mkpuchi mmehie tutu ruo mgbe ọ pụtara, mgbe ọ chụchara aja mkpuchi mmehie maka onwe ya na ezinaụlọ ya, na maka ụmụ Izrel niile.
\p 
\v 18 “Mgbe o si nʼebe ahụ pụta, gaa nʼebe ịchụ aja dị nʼihu \nd Onyenwe anyị\nd* kpuchiere ya mmehie ya. Ọ ga-ewere ụfọdụ ọbara nwa oke ehi ahụ na nke mkpi ahụ tee ya na mpi niile dị nʼebe ịchụ aja ahụ.
\v 19 Ọ ga-eji mkpịsịaka ya fesa ụfọdụ ọbara ahụ nʼelu ebe ịchụ aja ahụ ugboro asaa iji hichapụ adịghị ọcha ya nʼihi ịrụ arụ ụmụ Izrel, na ido ya nsọ.
\p 
\v 20 “Mgbe Erọn chụchara aja mkpuchi mmehie maka Ebe ahụ Kachasị Nsọ, ụlọ nzute, nakwa ebe ịchụ aja, ọ ga-akpụbata mkpi ahụ e debere ndụ.
\v 21 Ọ ga-ebikwasị aka ya abụọ nʼisi ya, kwupụta ajọ omume na nnupu isi ụmụ Izrel niile, mmehie ha niile, bokwasị ha mkpi ahụ nʼisi. Ọ ga-ezipụ mkpi ahụ pụọ nʼime ọzara site nʼaka onye ahụ a họpụtara ime nke a.
\v 22 Nʼụzọ dị otu a, mkpi ahụ ga-eburu mmehie ndị ahụ niile baa nʼebe mmadụ ọbụla na-ebighị. Nwoke ahụ ga-ahapụkwa ya nʼọzara.
\p 
\v 23 “Mgbe ahụ, Erọn ga-aba nʼime ụlọ nzute ahụ,\f + \fr 16:23 \ft \xt Izk 42:14\xt*\f* yipụ uwe akwa ọcha ndị nchụaja ahụ niile o yi nʼahụ ya tupu ọ banye nʼEbe ahụ Kachasị Nsọ. Ọ ga-awụsa ha nʼebe ahụ.
\v 24 Ọ ga-eji mmiri saa ahụ ya nʼakụkụ ebe nsọ ahụ, yirikwa uwe efu ya. Mgbe ahụ, ọ ga-apụta bịa chụọ aja nsure ọkụ nke onwe ya, na aja nsure ọkụ nke ndị ahụ, maka ikpuchiri onwe ya, na ikpuchikwara ndị ahụ mmehie ha.
\v 25 Ọ ga-akpọkwa abụba anụ e ji chụọ aja mmehie ahụ ọkụ nʼelu ebe ịchụ aja.
\p 
\v 26 “Mgbe nwoke ahụ kpụgara mkpi ahụ nʼọzara hapụ ya, lọtara, ọ ga-asa ahụ ya na uwe ya tupu ọ laghachi nʼime obodo.
\v 27 Oke ehi nakwa mkpi maka ịchụ aja mmehie ahụ, bụ nke ewebatara ọbara ha nʼime Ebe ahụ Kachasị Nsọ, maka ikpuchi mmehie, ka aghaghị ibupụ nʼazụ ọmụma ụlọ ikwu; a ga-akpọ akpụkpọ ha, anụ ahụ ha na mgbịrị afọ ha niile ọkụ.
\v 28 Onye ga-akpọ ha ọkụ ga-asa uwe ya, saakwa ahụ ya tupu ọ laghachi nʼime obodo.
\p 
\v 29 “Nke a ga-abụrụ unu ụkpụrụ ebighị ebi. Nʼafọ ọbụla, unu ga-ebu ọnụ, hapụ ịrụ ọrụ ọbụla, nʼụbọchị iri nke ọnwa asaa. Iwu a dịrị nwa afọ ala maọbụ onye ọbịa bi nʼetiti unu.\f + \fr 16:29 \ft \xt Lev 23:27,32; Ọnụ 29:7\xt*\f*
\v 30 Nʼihi na nʼụbọchị a ka a na-ekpuchiri unu mmehie unu, ime ka unu dịrị ọcha. Mgbe ahụ, unu ga-abụ ndị dị ọcha site na mmehie unu niile nʼihu \nd Onyenwe anyị\nd*.
\v 31 Ọ bụ ụbọchị izuike nye unu, bụrụkwa ụbọchị unu ga-ebu ọnụ. Iwu a enweghị mgbanwe!
\v 32 Onye nchụaja e tere mmanụ, nke e doro nsọ dịka onye nchụaja ịnọchi nna ya, ga-achụ aja mkpuchi mmehie ndị a, yirikwa akwa ọcha ahụ, bụ uwe nsọ ahụ.
\v 33 Ọ ga-ekpuchiri Ebe ahụ Kachasị Nsọ na ụlọ nzute, ebe ịchụ aja na ndị nchụaja, na mkpokọta ndị obodo niile mmehie ha.
\p 
\v 34 “Nke a ga-abụ iwu ebighị ebi nye unu. Otu ugboro nʼotu afọ ka a ga-ekpuchi mmehie maka mmehie ndị Izrel niile.”
\p E mezuru ihe ndị a niile dịka \nd Onyenwe anyị\nd* si nye ya Mosis nʼiwu.
\c 17
\s1 Iwu banyere iri ọbara
\p 
\v 1 \nd Onyenwe anyị\nd* gwara Mosis sị,
\v 2 “Gwa Erọn, na ụmụ ya ndị ikom, na ụmụ Izrel niile okwu sị ha, ‘Ihe ndị a ka \nd Onyenwe anyị\nd* nyere nʼiwu.
\v 3 Onye ọbụla bụ onye ụlọ Izrel gbuo ehi, maọbụ nwa atụrụ, maọbụ ewu nʼogige ebe obibi,\f + \fr 17:3 \ft Ya bụ ọmụma ụlọ ikwu\f* maọbụ nʼazụ ebe obibi,
\v 4 ma o wetaghị ya nʼọnụ ụzọ ụlọ nzute iche ya dịka onyinye nʼihu \nd Onyenwe anyị\nd*, nʼihu ụlọnsọ \nd Onyenwe anyị\nd*, a ga-agụ onye ahụ dịka onye ikpe iwufu ọbara mara. Ọ wụfuola ọbara, nʼihi ya, a ga-esite nʼetiti ndị ya kewapụ ya.
\v 5 Ihe e ji nye iwu a bụ ka ụmụ Izrel wetara \nd Onyenwe anyị\nd* aja niile ha na-achụ ugbu a na mbara ezi ọbụla. Ha kwesiri iwetara ya \nd Onyenwe anyị\nd* site nʼaka onye nchụaja nʼọnụ ụzọ ụlọ nzute, ka o jiri ya chụọrọ ha aja udo.
\v 6 Nʼụzọ dị otu a, onye nchụaja ga-efesa ọbara ahụ nʼebe ịchụ aja dị nʼọnụ ụzọ ụlọ nzute, kpọọkwa abụba ya ọkụ, ka ọ bụrụ aja nsure ọkụ nke isisi ya dị \nd Onyenwe anyị\nd* ezi ụtọ.
\v 7 O kwesikwaghị ka ndị Izrel chụọ aja ha ọzọ na mbara ezi nye arụsị ewu ndị ha na-akpọ isiala nye. Iwu a ga-adịgide nye ha na ụmụ ha niile, site nʼọgbọ ruo nʼọgbọ.’
\p 
\v 8 “Gwa ha, ‘Onye Izrel ọbụla, maọbụ onye ọbịa bi nʼetiti unu, nke ga-achụ aja nsure ọkụ maọbụ aja ọzọ,
\v 9 ma o webataghị ya nʼọnụ ụzọ ụlọ nzute, ebe a ga-achụrụ ya \nd Onyenwe anyị\nd*, ka a ga-ewezuga site nʼetiti ndị ya.
\p 
\v 10 “ ‘Onye Izrel ọbụla maọbụ onye ọbịa bi nʼetiti ha, nke riri ọbara ọbụla ka m ga-eche ihu m megide. A ga-ewezuga ya site nʼetiti ndị m.
\v 11 Nʼihi na ndụ ihe nwere ndụ dị nʼọbara ya, ọ bụ nʼihi nke a ka m ji nye iwu na a ga-awụsa ọbara niile nʼelu ebe ịchụ aja, maka iji ya kpuchie mmehie unu. Ọ bụ ọbara na-ekpuchi mmehie maka ndụ mmadụ.\f + \fr 17:11 \ft \xt Hib 9:22\xt*\f*
\v 12 Nʼihi nke a, a sịrị ndị Izrel, “Ọ dịghị onye ọbụla nʼetiti unu, maọbụ onye ọbịa ọbụla nke bi nʼetiti unu ga-eri ọbara.”
\p 
\v 13 “ ‘Onye Izrel ọbụla, na onye ọbịa ọbụla binyere unu nke gara ịchụ nta, gbuo anụ maọbụ nnụnụ ọbụla a na-eri eri, ga-awụfu ọbara ya were aja kpuchie ya.
\v 14 Nʼihi na ndụ ihe niile nwere ndụ dị nʼọbara. Ọ bụ ya mere m ji nye ụmụ Izrel iwu si unu erila ọbara anụmanụ ọbụla, nʼihi na ndụ ihe niile nwere ndụ dị nʼọbara ya. Nʼihi ya onye ọbụla riri ọbara, a ga-ekewapụ ya site nʼetiti ndị m.
\p 
\v 15 “ ‘Mmadụ ọbụla, maọbụ nwa afọ ma ọ bụkwanụ onye ọbịa, nke riri anụ nwụrụ nʼonwe ya, maọbụ nke anụ ọhịa dọgburu,\f + \fr 17:15 \ft \xt Ọpụ 22:31\xt*\f* ga-eji mmiri saa uwe ya na ahụ ya, ọ ga-abụkwa onye rụrụ arụ ruo uhuruchi tupu ọ dị ọcha ọzọ.
\v 16 Ma ọ bụrụ na ọ saghị uwe ya na ahụ ya, ikpe ọmụma dị ya nʼisi.’ ”
\c 18
\s1 Iwu banyere mmekọ dị iche iche
\p 
\v 1 \nd Onyenwe anyị\nd* gwara Mosis okwu sị ya,
\v 2 “Gwa ụmụ Izrel okwu ndị a sị ha, ‘Mụ onwe m bụ \nd Onyenwe anyị\nd* Chineke unu.
\v 3 Ya mere, ọ bụ ezie na unu ebiela nʼetiti ndị Ijipt, ma unu ekwesighị ibi ndụ unu dịka ha si ebi. Unu ekwesịkwaghị ibi ndụ dịka ndị Kenan ebe m na-akpọbata unu. Unu agbasola omenaala ha.
\v 4 Unu ga-edebe iwu m niile, gbasookwa ụkpụrụ m niile nʼihi na abụ m \nd Onyenwe anyị\nd* Chineke unu.
\v 5 Debenụ iwu m na ụkpụrụ m, nʼihi na onye na-edebe ha ga-adị ndụ\f + \fr 18:5 \ft \xt Izk 20:11; Rom 10:5\xt*\f* site na ha. Abụ m \nd Onyenwe anyị\nd*.
\p 
\v 6 “ ‘Onye ọbụla ya na mmadụ bụ nwanne e jekwurukwala ya ka ha nwe mmekọ edina, i ji kpughee ọtọ ya. Mụ onwe m bụ \nd Onyenwe anyị\nd*.
\p 
\v 7 “ ‘Ị gaghị eleda nna gị anya site na i jekwuru nne gị ka gị na ya nwe mmekọ edina. Nne gị ka ọ bụ; gị na ya agaghị enwe ụdị mmekọ dị otu a.
\p 
\v 8 “ ‘Ị gaghị e jekwuru nwunye nna gị ka gị na ya nwe mmekọ edina. Nke a bụ ileda nna gị anya.
\p 
\v 9 “ ‘Ị gaghị e jekwuru nwanne gị nwanyị ka gị na ya nwe mmekọ edina, maọbụ nwa nwanyị nke a mụụrụ nna gị, maọbụ nwa nwanyị nke nne gị mụrụ, ma a mụrụ ya nʼụlọ ma a mụrụ nʼama.
\p 
\v 10 “ ‘Ị gaghị e jekwuru nwa nwanyị nke nwa gị nwoke mụrụ, maọbụ nwa nwanyị nke nwa gị nwanyị mụrụ i nwe mmekọ edina; nʼihi na nke a ga-eweta nleda anya nye gị.
\p 
\v 11 “ ‘Ị gaghị e jekwuru nwa nwanyị nwunye nna gị mụrụ, ka gị na ya nwe mmekọ edina, nʼihi na ọ bụ nwa nna gị mụrụ; nwanne gị nwanyị ka ọ bụ.
\p 
\v 12 “ ‘Ị gaghị e jekwuru nwanne nwanyị nna gị ka gị na ya nwe mmekọ edina, nʼihi na ọbara jịkọrọ ya na nna gị, ha bụ otu ahụ.
\p 
\v 13 “ ‘Ị gaghị e jekwuru nwanne nne gị nke nwanyị, ka gị na ya nwe mmekọ edina, nʼihi na ọbara jịkọrọ ya na nne gị, ha bụ otu ahụ.
\p 
\v 14 “ ‘Ị gaghị eleda nwanne nna gị nke nwoke anya, site nʼijekwuru nwunye ya, ka gị na ya nwe mmekọ edina. Nʼihi na nwunye nwanna gị ka ọ bụ.
\p 
\v 15 “ ‘Ị gaghị e jekwuru nwunye nwa gị nwoke ka gị na ya nwe mmekọ edina; nwunye nwa gị nwoke ka ọ bụ; gị na ya agaghị enwe mmekọrịta ọbụla gosiri mkpughe ọtọ ya.
\p 
\v 16 “ ‘Ị gaghị e jekwuru nwunye nwanne gị nwoke ka gị na ya nwe mmekọ edina, nʼihi na nke a bụ omume nleda anya nye nwanne gị nwoke.
\p 
\v 17 “ ‘Ị gaghị e jekwuru nwanyị na nwa ya nwanyị ka gị na ha nwe mmekọ edina. Ị gaghị akpọrọ nwa nwanyị nwa ya nwoke, maọbụ nwa nwanyị nke nwa ya nwanyị mụrụ dinaa ya; nʼihi na otu ọbara ka ha bụ. Ihe dị otu a bụ arụ.
\p 
\v 18 “ ‘Ị gaghị alụ nwanne nwanyị nwunye gị, dịka nwunye ọzọ gị, nʼihi ịkpagbu ya, gị na ya a na-enwe mmekọrịta edina, ị na-ekpughe ọtọ nwunye gị mgbe ọ ka dị ndụ.
\p 
\v 19 “ ‘E jekwurukwala nwanyị ka gị na ya nwe mmekọ edina, mgbe ọ nọ nʼọnọdụ adịghị ọcha nke (ịsọ ụba) nsọ nwanyị ya nʼoge a kara aka.
\p 
\v 20 “ ‘A kpọrọkwala nwunye onye agbataobi gị idina ya, si otu a merụọ onwe gị nʼihi mmekọ dị otu a.\f + \fr 18:20 \ft \xt Ọpụ 20:14; Mat 5:27-28; 1Kọ 6:9; Hib 13:4\xt*\f*
\p 
\v 21 “ ‘Ị gaghị enye nwa gị ka e jiri ya chụọrọ Molek aja.\f + \fr 18:21 \ft \xt Lev 20:2-5\xt*\f* Nʼihi na i kwesighị imerụ aha Chineke gị. Mụ onwe m bụ \nd Onyenwe anyị\nd*.
\p 
\v 22 “ ‘Gị na nwoke edinala, dịka nwanyị na nwoke si edina. Ihe akpọrọ asị ka ọ bụ.
\p 
\v 23 “ ‘Gị na anụmanụ ọbụla edinakwala, site otu a merụọ onwe gị. Nwanyị agakwaghị ewere onwe ya nye ka ya na oke anụmanụ nwee mmekọrịta, arụ a na-adịghị eme eme ka ọ bụ.
\p 
\v 24 “ ‘Unu emerụkwala onwe unu site na-ime ihe ndị a, nʼihi na ihe ndị a bụ ihe mba ndị ahụ na-eme. Ọ bụkwa nʼihi ya ka m ga-eji chụpụ ha site nʼala ahụ m ga-enye unu.
\v 25 Ọ bụladị ala ahụ niile ghọrọ ihe rụrụ arụ site nʼomume ndị a. Ọ bụ nke a mere m ji ata ndị bi nʼime ya ahụhụ nʼihi mmehie ha. Ala ahụ meghere ọnụ ya gbọpụta ndị bi nʼime ya.
\v 26 Unu ga-edebe iwu m na ụkpụrụ m ndị a niile. Unu emekwala ihe arụ ndị a, ma ndị amụrụ nʼala ma ndị ọbịa niile bi nʼetiti unu.
\v 27 Ala m na-aga inye unu rụrụ arụ nʼihi na ndị bi nʼime ya na-eme omume ndị a rụrụ arụ.
\v 28 Unu emekwala ihe arụ ndị a, nʼihi na ọ bụrụ na unu emee ha, ọ ga-emeghe ọnụ ya gbọpụta unu, dịka o si mee mba niile bụ ndị buru unu ụzọ biri nʼime ya.
\p 
\v 29 “ ‘Onye ọbụla nʼetiti unu mere ihe arụ ndị a, ka a ga-ekewapụ site nʼetiti ndị ya.
\v 30 Nʼihi ya, lezienụ anya ka unu debe iwu m, ka unu ghara ime ihe arụ ndị a, nke ndị buru unu ụzọ biri nʼala ahụ mere. Ka unu gharakwa imerụ onwe unu site nʼomume arụ ndị a. Abụ m \nd Onyenwe anyị\nd* Chineke unu.’ ”
\c 19
\s1 Iwu ndị ọzọ
\p 
\v 1 \nd Onyenwe anyị\nd* gwara Mosis okwu sị ya,
\v 2 “Gwa ọgbakọ ụmụ Izrel niile okwu sị ha: ‘Dịnụ nsọ, nʼihi na mụ onwe m bụ \nd Onyenwe anyị\nd* bụ Chineke unu, dị nsọ.
\p 
\v 3 “ ‘Onye ọbụla nʼime unu aghaghị ịsọpụrụ nne na nna ya, debekwa iwu m nyere maka ụbọchị izuike, nʼihi na mụ onwe m bụ \nd Onyenwe anyị\nd* Chineke unu.
\p 
\v 4 “ ‘Unu akpọla isiala nye arụsị, unu emekwarala onwe unu chi ndị e ji ọla kpụọ. Mụ onwe m bụ \nd Onyenwe anyị\nd* Chineke unu.
\p 
\v 5 “ ‘Mgbe unu ga-achụrụ \nd Onyenwe anyị\nd* aja udo, soronụ ụkpụrụ m nyere unu chụọ ya, ka m nabata ya.
\v 6 Unu ga-eri ya nʼụbọchị ahụ unu chụrụ ya, maọbụ nʼụbọchị nke na-eso ụbọchị ahụ. Nke ọbụla fọdụrụ ruo ụbọchị nke atọ ka unu ga-esure ọkụ.
\v 7 Ọ bụrụ na unu erie ya nʼụbọchị nke atọ ihe arụ ka ọ bụ. A gaghị anabata aja ọbụla unu ga-eri nʼụbọchị nke atọ.
\v 8 Ikpe ga-ama onye ga-eri ya nʼụbọchị nke atọ nʼihi na o meela ka ihe nsọ \nd Onyenwe anyị\nd* bụrụ ihe arụ. A ga-ekewapụ onye ahụ site nʼetiti ndị ya.
\p 
\v 9 “ ‘Mgbe unu na-ewe ihe ubi, unu ewechala ihe niile dị nʼakụkụ ubi niile, maọbụ chịkọtachaa irighiri ihe ubi niile fọdụrụ nʼala.
\v 10 A ghọrọchakwala mkpụrụ vaịnị niile mịrị nʼelu vaịnị gị, maọbụ chịkọrọ mkpụrụ ndị dara nʼala. Hapụrụ ha ụmụ ogbenye na ndị ọbịa, nʼihi na mụ onwe m bụ \nd Onyenwe anyị\nd* Chineke unu.
\p 
\v 11 “ ‘Unu ezula ohi.
\p “ ‘Unu aghala ụgha.
\p “ ‘Unu aghọgbula ibe unu.
\p 
\v 12 “ ‘Unu aṅụla iyi ụgha, si otu a weta nkọcha nye aha \nd Onyenwe anyị\nd* Chineke unu. Abụ m \nd Onyenwe anyị\nd*.
\p 
\v 13 “ ‘Unu ejila ike pụnara onye agbataobi unu ihe ya, maọbụ zuru ihe o nwere nʼohi.
\p “ ‘Kwụọnụ onye ọbụla unu goro ọrụ ụgwọ ọrụ ya ọsịịsọ. Unu echela ka chi bọọ tupu unu akwụọ ya ụgwọ ya.
\p 
\v 14 “ ‘Akọchala onye ntị chiri, edochikwarala onye ìsì ihe nʼụzọ. Tụọ egwu Chineke. Abụ m \nd Onyenwe anyị\nd*.
\p 
\v 15 “ ‘Unu ekpela ikpe na-ezighị ezi, unu elela mmadụ anya nʼihu mgbe unu na-ekpe ikpe, ma onye unu na-ekpe ikpe ọ bụ ọgaranya maọbụ ogbenye. Kama kpeenụ ikpe kwụ ọtọ.
\p 
\v 16 “ ‘Unu ejegharịla na-agbasa okwu nkwujọ nʼetiti ndị mmadụ.
\p “ ‘Emela ihe ọbụla ga-ebutere onye agbataobi gị ọnwụ. Abụ m \nd Onyenwe anyị\nd*.
\p 
\v 17 “ ‘Akpọla nwanne gị asị nʼime obi gị. Tụọ onye agbataobi gị mmehie ya nʼihu ya, ka ị ghara iketa oke nʼikpe ọmụma dịrị ya.
\p 
\v 18 “ ‘Abọla ọbọ, ebukwala iro nʼobi megide onye ọbụla nʼetiti ndị gị. Kama hụ onye agbataobi gị nʼanya dịka i si hụ onwe gị nʼanya. Mụ onwe m bụ \nd Onyenwe anyị\nd* unu.
\p 
\v 19 “ ‘Unu ga-edebe iwu m niile.
\p “ ‘Unu ejila otu ụdị anụ ụlọ unu na-agba ụdị anụ ụlọ ọzọ dị iche.
\p “ ‘Akụla ụdị mkpụrụ abụọ nʼubi.
\p “ ‘Eyila uwe e ji ụzọ ihe abụọ, dịka ajị anụ na ogho dụọ.
\p 
\v 20 “ ‘Ọ bụrụ na nwoke ọbụla akpọrọ nwaagbọghọ bụ ohu nwanyị nke a na-agbapụtabeghị, maọbụ nke na-enwerebeghị onwe ya, nke nwoke ọzọ chọrọ ịlụ, mee ka ha abụọ dinakọọ, a ga-ekpe ha abụọ ikpe nʼụlọikpe, ma a gaghị egbu ha, nʼihi na nwanyị ahụ abụghị onye nwe onwe ya.
\v 21 Ma nwoke ahụ ga-eweta aja ikpe ọmụma nye \nd Onyenwe anyị\nd* nʼọnụ ụzọ ụlọ nzute. Ọ ga-abụkwa ebule ka ọ ga-eji chụọ aja ahụ.
\v 22 Onye nchụaja ga-eji ebule aja ikpe ọmụma ahụ chụọrọ nwoke ahụ aja mkpuchi mmehie ya nʼihu \nd Onyenwe anyị\nd*, nʼihi mmehie o mere. A ga-agbaghakwara ya mmehie ya.
\p 
\v 23 “ ‘Mgbe unu batara nʼala ahụ kụọ mkpụrụ osisi dị iche iche, unu erila mkpụrụ osisi ahụ mịrị nʼafọ nke mbụ, ọ bụ ihe rụrụ arụ. Ruo nʼafọ nke atọ, ha bụ ihe rụrụ arụ. Unu agaghị eri ha.
\v 24 Nʼafọ nke anọ, mkpụrụ nke osisi ndị ahụ niile ga-amị dị nsọ. Unu ga-eji ya nye \nd Onyenwe anyị\nd* onyinye otuto.
\v 25 Site nʼafọ nke ise, mkpụrụ ọbụla ga-abụ nke unu. Nʼụzọ dị otu a ihe ha ga-amịpụta ga-adị ukwuu. Mụ onwe m bụ \nd Onyenwe anyị\nd* Chineke unu.
\p 
\v 26 “ ‘Unu erila anụ ọbụla ọbara dị nʼime ya.
\p “ ‘Unu agbala afa maọbụ jụta mmụọ ase.
\p 
\v 27 “ ‘Unu akpụchala agịrị isi dị gburugburu akụkụ isi unu, maọbụ chabie ọnụ ọnụ afụọnụ unu.
\p 
\v 28 “ ‘Unu akala ihe ọbụla nʼahụ unu, nʼihi onye nwụrụ anwụ maọbụ jiri mma ọkụ dee ihe nʼahụ unu. Abụ m \nd Onyenwe anyị\nd*.
\p 
\v 29 “ ‘Emerụla nwa gị nwanyị site nʼịkwagide ya ka ọ bụrụ akwụna, ka ala unu ghara ijupụta nʼịgba akwụna na ihe ọjọọ dị iche iche.
\p 
\v 30 “ ‘Debenụ iwu niile m nyere maka ụbọchị izuike m. Sọpụkwaranụ ebe nsọ m. Abụ m \nd Onyenwe anyị\nd*.
\p 
\v 31 “ ‘Unu ejekwurula ndị na-ajụ mmụọ ọjọọ ase maọbụ chọgaa ndị dibịa afa, nʼihi na unu ga-emerụ onwe site na ha. Mụ onwe m bụ \nd Onyenwe anyị\nd* Chineke unu.
\p 
\v 32 “ ‘Bilienụ ọtọ nʼihu okenye, sọpụrụnụ ndị okenye, ma tụọnụ egwu Chineke unu. Abụ m \nd Onyenwe anyị\nd*.
\p 
\v 33 “ ‘Mgbe onye ọbịa soro unu biri nʼala unu, unu emejọla ya.
\v 34 Mesonụ onye ọbịa bi nʼetiti unu mmeso dịka ọ bụ otu nʼime ndị amụrụ nʼala. Hụnụ ha nʼanya dịka unu si hụ onwe unu, nʼihi na o nwere oge unu bụ ọbịa nʼala Ijipt. Abụ m \nd Onyenwe anyị\nd* Chineke unu.
\p 
\v 35 “ ‘Unu ejila ihe ọtụtụ aghụghọ mgbe unu na-atụ ihe dị ogologo, maọbụ ihe dị arọ, maọbụ ihe dị ukwuu,
\v 36 Jirinụ ezi ihe ọtụtụ tụọ ogologo, maọbụ ihe dị arọ, maọbụ ihe dị ukwuu. Abụ m \nd Onyenwe anyị\nd* Chineke unu, onye si nʼala Ijipt kpọpụta unu.
\p 
\v 37 “ ‘Debenụ ụkpụrụ m niile, na iwu m niile, gbasoonụ ha. Abụ m \nd Onyenwe anyị\nd*.’ ”
\c 20
\s1 Ahụhụ nʼihi mmehie
\p 
\v 1 \nd Onyenwe anyị\nd* sịrị Mosis,
\v 2 “Gwa ụmụ Izrel, ‘Onye Izrel ọbụla maọbụ onye ọbịa ọbụla bi nʼetiti unu, nke weere nwa ya nye maka ịchụrụ Molek aja, aghaghị ime ka ọ nwụọ. Ndị mmadụ ga-ewere nkume tugbuo ya.
\v 3 Mụ onwe m ga-emegide onye ahụ, bipụ ya site nʼetiti ndị ya, nʼihi na o merụọla ebe nsọ m, mee ka aha m gharakwa ịdị nsọ, site nʼiji ụmụ ya chụọrọ Molek aja.
\v 4 Ọ bụrụ na ndị obodo elezie anya mee omume dịka a ga-asị na ha amaghị ihe onye ahụ mere, hapụkwa igbu ya, mgbe o were otu nʼime ụmụ ya nye Molek,
\v 5 mụ onwe m ga-emegide onye ahụ na ezinaụlọ ya bipụ ha site nʼetiti ndị ya. Otu a kwa ka m ga-eme ya na ndị niile so ya merụọ onwe ha site nʼife arụsị Molek.
\p 
\v 6 “ ‘Aga m edo ihu m megide onye ọbụla gara jụọ ase site nʼaka mmụọ ọjọọ, maọbụ onye gara na dibịa afa gbaa afa, site nʼiso ha kwaa iko. Aga m ekewapụ onye ahụ site nʼetiti ndị ya.
\p 
\v 7 “ ‘Doonụ onwe unu nsọ, ma dịkwanụ nsọ nʼihi na abụ m \nd Onyenwe anyị\nd* Chineke unu.
\v 8 Debenụ ụkpụrụ m niile, ma gbasoonụ ha nʼihi na abụ m \nd Onyenwe anyị\nd* onye na-edo unu nsọ.
\p 
\v 9 “ ‘Onye ọbụla kọchara nne ya maọbụ nna ya ka a ga-egbu nʼihi na ọ kọchara nne na nna ya. Ọbara onye dị otu a ga-adịkwa ya nʼisi.
\p 
\v 10 “ ‘Ọ bụrụ na nwoke ọbụla edinakwuru nwunye nwoke ọzọ, ya bụ nwunye onye agbataobi ya, nwoke ahụ na nwanyị kwara iko ka a ga-egbu.
\p 
\v 11 “ ‘Nwoke ọbụla ya na nwunye nna ya dinakọrọ nwe mmekọ, emerụọla nna ya. A ga-egbu nwoke ahụ na nwanyị ahụ. Ọbara ha ga-adị ha nʼisi.
\p 
\v 12 “ ‘Ọ bụrụ na nwoke ọbụla edinakwuru nwunye nwa ya, wetara onwe ha ikpe ọmụma, a ga-egbu ha abụọ nʼihi na ọ bụ arụ ka ha mere.
\p 
\v 13 “ ‘Ọ bụrụ nwoke na nwoke ibe ya edinakọọ nwee ụdị mmekọ edina nwoke na nwanyị, a ga-egbu ha abụọ nʼihi na ihe ha mere bụ ihe rụrụ arụ. Ọbara ha ga-adị ha nʼisi.
\p 
\v 14 “ ‘Ọ bụrụ na nwoke alụọ nwanyị na nne mụrụ ya, ajọ ihe ka ọ bụ. Nwoke ahụ na ndị inyom ndị ahụ ka a ga-akpọ ọkụ, ka ihe ọjọọ dị otu a hapụ ịdị nʼetiti unu.
\p 
\v 15 “ ‘Ọ bụrụ na nwoke na anụmanụ enwee mmekọrịta, a ga-egbu nwoke ahụ gbukwaa anụmanụ ahụ.
\p 
\v 16 “ ‘Ọ bụrụ na nwanyị ọbụla abịaruo anụmanụ ọbụla nso dinakwuru ya inwe mmekọ, a ga-egbu nwanyị ahụ na anụmanụ ahụ, nʼihi na ha kwesiri ọnwụ. Ọbara ha ga-adị ha nʼisi.
\p 
\v 17 “ ‘Nwoke ọbụla ya na nwanne ya nwanyị nwere mmekọ edina, maọbụ nwa afọ nne ya maọbụ nwa nwunye nna ya, a ga-ekpochapụ ha site nʼihu ọha mmadụ nʼihi na ọ bụ ihe ihere dị ukwuu ka ha mere. Ọ merụọla nwanne ya, nʼihi ya ikpe ọmụma dị ya nʼisi.
\p 
\v 18 “ ‘Nwoke ọbụla nke ya na nwanyị nọ na nsọ nwanyị ya dinakọrọ nwee mmekọ ekpugheela adịghị ọcha nwanyị ahụ. Nwanyị ahụ nʼonwe ya ekpugheekwala adịghị ọcha nke ya. A ga-ebipụ ha abụọ site nʼetiti ndị ha.
\p 
\v 19 “ ‘Ị gaghị enwe mmekọ edina nʼetiti gị na nwanne nwanyị nne gị maọbụ nwanne nwanyị nna gị, nʼihi na nke a bụ ihe nleda anya nye onye ọbara jịkọrọ gị na ya. Ikpe ọmụma ga-adịrị unu abụọ.
\p 
\v 20 “ ‘Ọ bụrụ na nwoke ọbụla na nwunye nwanne nna ya edinaa, ọ bụ omume ileda anya nye nwanne nna ya. Ha ga-ebu mmehie ha. Ha ga-anwụ na-amụtaghị nwa.
\p 
\v 21 “ ‘Ọ bụrụ na nwoke alụọ nwunye nwanne ya, ọ bụ omume rụrụ arụ, nʼihi na ọ bụ ihe nleda anya nye nwanne ya. Ha ga-agba aka nwa.
\p 
\v 22 “ ‘Debenụ iwu ndị a na ụkpụrụ ndị a, ma gbasoonụ ha ka ala ahụ m na-eduba unu nʼime ya hapụ imeghe ọnụ ya gbụpụ unu.
\v 23 Unu agbasola omenaala ndị mba niile a m na-achụpụ site nʼala m na-enye unu, nʼihi na ha na-eme ihe ndị a niile m nyere unu nʼiwu emela. Ọ bụ nke a mere ihe banyere ha ji sọọ m oyi.
\v 24 Ma agwala m unu sị, “Unu ga-eketa ala ha. Aga m enye ya unu ka ọ bụrụ ihe nketa unu. Ala mmiri ara ehi na mmanụ aṅụ na-eru na ya.” Abụ m \nd Onyenwe anyị\nd* Chineke unu onye kewapụtara unu doo unu iche site na mba ndị ọzọ niile.
\p 
\v 25 “ ‘Unu aghaghị ịkpa oke nʼetiti anụmanụ ndị dị ọcha iri eri, na anụmanụ ndị na-adịghị ọcha, na nʼetiti anụ ufe dị ọcha iri eri na ndị rụrụ arụ.\f + \fr 20:25 \ft \xt Dit 14:3-21\xt*\f* Unu emerụla onwe unu site nʼiri anụmanụ maọbụ anụ ufe, maọbụ ihe ọzọ na-akpụgharị nʼala, ndị ahụ m kewapụrụ iche dịka ihe rụrụ arụ.
\v 26 Unu ga-adị nsọ nye m, nʼihi na mụ, bụ \nd Onyenwe anyị\nd*, dị nsọ. Ekewapụtala m unu, doo unu iche, site nʼetiti ndị mba ọzọ niile, ka unu bụrụ nke m.
\p 
\v 27 “ ‘A ga-eji nkume tugbuo nwoke maọbụ nwanyị ọbụla nke na-ajụ mmụọ ọjọọ ase, maọbụ dibịa afa nọ nʼetiti unu ka ọ nwụọ. Ọbara ha ga-adịkwa ha nʼisi.’ ”
\c 21
\s1 Iwu nke ndị nchụaja
\p 
\v 1 \nd Onyenwe anyị\nd* gwara Mosis sị, “Gwa ndị nchụaja, ụmụ ndị ikom Erọn okwu sị ha, ‘Onye nchụaja ekwesighị imerụ onwe ya mgbe mmadụ nwụrụ nʼetiti ụmụnna ya.
\v 2 Karịakwa ma onye ahụ bụ onye dị ya nnọọ nso, dịka nne ya, maọbụ nna ya, maọbụ nwa ya nwoke, maọbụ nwa ya nwanyị, maọbụ nwanne ya nwoke,
\v 3 maọbụ nwanne ya nwanyị na-alụbeghị di, onye ọ na-elekọta nʼihi na o nweghị di. Nʼihi ya, o nwere ike merụọ onwe ya.
\v 4 Ma ọ gakwaghị eme onwe ya ka ọ ghara ịdị ọcha nʼetiti ndị ọgọ ya, ma site otu a merụọ onwe ya.
\p 
\v 5 “ ‘Ndị nchụaja ekwesighị ịkpụcha isi ha, maọbụ kpụchapụ akụkụ afụọnụ ha, maọbụ kaa ihe ọbụla nʼakpụkpọ ahụ ha.\f + \fr 21:5 \ft \xt Lev 19:28; Izk 44:20\xt*\f*
\v 6 Ha ga-abụ ndị dị nsọ nye Chineke ha, ndị na-agaghị emekwa ka aha Chineke ha ghara ịdị nsọ. Nʼihi na ọ bụ ha na-eche nʼihu \nd Onyenwe anyị\nd* onyinye aja nsure ọkụ, bụ nri Chineke ha. Nʼihi ya, ha aghaghị ịdị nsọ.
\p 
\v 7 “ ‘Onye nchụaja agaghị alụ nwanyị e merụrụ site nʼịgba akwụna, maọbụ nwanyị lụtụrụla di nke kewapụrụ onwe ya site nʼahụ di ya, nʼihi na ndị nchụaja bụ ndị dị nsọ nye Chineke ha.
\v 8 Gụọ ha dịka ndị dị nsọ nʼihi na ọ bụ ha na-eche nri Chineke nʼihu ya. Gụọ ha dịka ndị dị nsọ nʼihi na mụ onwe m bụ \nd Onyenwe anyị\nd* dị nsọ, mụ onwe m na-eme ka unu dị nsọ.
\p 
\v 9 “ ‘Ọ bụrụ na nwa nwanyị onye nchụaja emerụọ onwe ya site nʼịghọ onye akwụna, o sitela na ndụ ọjọọ dị otu a wetara nna ya ihe ihere. A ga-akpọ ya ọkụ.
\p 
\v 10 “ ‘Onyeisi nchụaja, onye ahụ sitere nʼetiti ụmụnna ya, onye awụsara mmanụ nsọ nʼisi ya, onye ahọrọ doo nsọ iyiri uwe onye nchụaja ahụ, agaghị ahapụ agịrị isi ya ka ọ kpasasịa, maọbụ dọwaa uwe ya.
\v 11 Ọ gaghị abanye ebe ozu dị. Ọ gaghị emerụ onwe ya, ọ bụladị ma ozu ahụ ọ bụ nke nne ya maọbụ nke nna ya.
\v 12 Ọ gaghị esi nʼebe nsọ Chineke ya pụọ, maọbụ mee ya ka ọ ghara ịdị nsọ, nʼihi na e doola ya nsọ site na ite ya mmanụ nsọ nke Chineke ya. Abụ m \nd Onyenwe anyị\nd*.
\p 
\v 13 “ ‘Nwanyị onyeisi nchụaja ga-alụ ga-abụ nwanyị na-amaghị nwoke.
\v 14 Ọ gaghị alụ nwanyị di ya nwụrụ, maọbụ nwanyị ya na di ya na-ebikwaghị, maọbụ nwanyị akwụna. Nwanyị ọ ga-alụ ga-abụ naanị nwanyị na-amaghị nwoke nke si nʼetiti ụmụnna ya,
\v 15 ka ọ ghara ime ka ụmụ ya ghara ịdị nsọ nʼetiti ụmụnna ya. Abụ m \nd Onyenwe anyị\nd* onye na-edo ya nsọ.’ ”
\p 
\v 16 \nd Onyenwe anyị\nd* gwara Mosis sị,
\v 17 “Gwa Erọn, ‘Nʼọgbọ niile nke na-abịa, o nweghị onye ọbụla nʼime ụmụ ụmụ gị nke akụkụ ahụ ya na-ezughị oke ga-abịa nso iwetara Chineke ya ihe oriri.
\v 18 O nweghị nwoke ọbụla nwere ọrụsị ọbụla ga-abịa nso, o nweghị nwoke kpuru ìsì, maọbụ onye ngwụrọ, maọbụ onye imi mpịa, maọbụ onye ụkwụ maọbụ aka ya na-ezughị oke,\f + \fr 21:18 \ft Ihe ndị a gụnyere ma mmadụ ma anụmanụ, dịka e depụtara ha site nʼamaokwu iri na isii gbadaa.\f*
\v 19 maọbụ onye ọkpụkpụ ụkwụ ya maọbụ ọkpụkpụ aka ya gbajiri,
\v 20 maọbụ onye mkpumkpu azụ dị, maọbụ nwa akakpọ, maọbụ onye na-adịghị ahụzi ụzọ, maọbụ onye agba na-ata, maọbụ onye akpụkpa dị nʼahụ, maọbụ onye mkpụrụ amụ ya chipịara echipịa.
\v 21 O nweghị nwa nwa Erọn onye nchụaja ọbụla nwere ọrụsị ga-abịa iwetara \nd Onyenwe anyị\nd* aja onyinye site nʼọkụ. Ebe ọ bụ na o nwere ọrụsị, ọ gaghị abịa nso iwetara Chineke ya nri.
\v 22 Ma o nwere ike iri nri ahụ dịkarịsịrị nsọ nke sitere na nri Chineke ya, tinyekwara nri ahụ dị nsọ.
\v 23 Kama ọ gaghị abịa nso akwa mgbochi ahụ maọbụ bịaruo ebe ịchụ aja nso, nʼihi ezughị oke ya. Ka ọ ghara imerụ ebe nsọ m, nʼihi na abụ m \nd Onyenwe anyị\nd* onye na-edo ha nsọ.’ ”
\p 
\v 24 Ya mere Mosis nyere Erọn na ụmụ ya ndị ikom na ụmụ Izrel niile iwu ndị a.
\c 22
\s1 Ịdị nsọ nke onyinye ọchụchụ aja
\p 
\v 1 \nd Onyenwe anyị\nd* gwara Mosis sị,
\v 2 “Gwa Erọn na ụmụ ya ndị ikom ka ha jiri nsọpụrụ nabata onyinye dị nsọ nke ụmụ Izrel na-edo nsọ nye m, ka ha ghara imerụ aha nsọ m. Abụ m \nd Onyenwe anyị\nd*.
\p 
\v 3 “Gwa ha sị, ‘Nʼọgbọ unu niile na-abịa, ọ bụrụ na enwee onye ọbụla nʼagbụrụ unu nke bịara nso nʼihe ndị ahụ dị nsọ ụmụ Izrel na-edo nsọ nye \nd Onyenwe anyị\nd*, mgbe onye ahụ nọ ọnọdụ dịka onye rụrụ arụ, a ga-esi nʼihu m wezuga onye ahụ. Abụ m \nd Onyenwe anyị\nd*.
\p 
\v 4 “ ‘Onye ọbụla bụ nwa nwa Erọn nke ọrịa ekpenta na-arịa, maọbụ nke ihe si nʼahụ ya na-asọpụta agaghị eri aja dị nsọ tutu ruo mgbe e mere ka ọ dịrị ọcha. Ọ ga-abụkwa onye rụrụ arụ ma ọ bụrụ na o metụ ozu aka, maọbụ onye mkpụrụ nwa na-esite nʼahụ awụsị,
\v 5 maọbụ na o metụrụ anụ na-akpụgharị akpụgharị nʼala aka, nke na-emerụ ya, maọbụ na ọ metụrụ mmadụ aka nke mere ka ọ bụrụ onye rụrụ arụ nʼagbanyeghị ihe ọ bụ na-emerụ ya.
\v 6 Onye ahụ metụrụ ihe ndị a aka ga-abụ onye rụrụ arụ ruo uhuruchi. Ọ gaghị eri ihe nsọ ọbụla tutu ruo mgbe ọ sachara ahụ.
\v 7 Mgbe anyanwụ dara ka ọ ga-adị ọcha, nweekwa ike iri ihe dị nsọ, nʼihi na ọ bụ nri ya.
\v 8 Ọ gaghị eri anụ nwụrụ anwụ, maọbụ nke anụ ọzọ dọgburu,\f + \fr 22:8 \ft \xt Ọpụ 22:31\xt*\f* nʼihi na ihe ndị a ga-emerụ ya. Abụ m \nd Onyenwe anyị\nd*.
\p 
\v 9 “ ‘Ndị nchụaja kwesiri idebe ụkpụrụ m, ka ha ghara ịbụ ndị ikpe mara si otu a nwụọ nʼihi na ha lelịrị ha anya. Abụ m \nd Onyenwe anyị\nd* onye na-edo ha nsọ.
\p 
\v 10 “ ‘O nweghị onye ọbụla na-esiteghị nʼezinaụlọ ndị nchụaja ga-eri aja nsọ ahụ. Onye bụ ọbịa na onye e goro ọrụ nọ nʼụlọ onye nchụaja agaghị eri ya.
\v 11 Otu ọ dị, ọ bụrụ na onye nchụaja weere ego nke aka ya gbata ohu, maọbụ na a mụrụ ohu ahụ nʼụlọ ya, ohu ahụ nwere ike iri aja nsọ ahụ.
\v 12 Ọ bụrụ na nwa nwanyị onye nchụaja alụọ onye na-abụghị onye nchụaja, ọ gaghị eri ihe ọbụla site nʼime aja nsọ a.
\v 13 Ma nwa nwanyị onye nchụaja nke di ya nwụrụ, maọbụ na ya na di ya ebikwaghị, ọ bụrụkwa na ọ mụtaghị nwa ọbụla, ọ lọghachi bịa biri nʼụlọ nna ya dịka o mere mgbe ọ bụ agbọghọ, o nwere ike iri nri dị nʼụlọ nna ya. Ọ dịkwaghị onye na-ekwesighị iri ya,\f + \fr 22:13 \ft Nke a bụ onye ọbịa maọbụ onye ala ọzọ\f* nke ga-eri ya.
\p 
\v 14 “ ‘Ọ bụrụ na onye ọbụla erie onyinye nsọ ahụ na-amaghị ama, ọ ga-eweghachiri onye nchụaja ihe niile o riri tụkwasịkwa ya otu ụzọ nʼụzọ ise ọzọ.
\v 15 Ndị nchụaja ekwesighị imerụ onyinye nsọ ụmụ Izrel na-eche nʼihu \nd Onyenwe anyị\nd*,
\v 16 site nʼikwenye ka ndị mmadụ efu rie onyinye nsọ ahụ, si otu a wetara ndị riri ya ikpe ọmụma nke ya na nkwụghachi so. Abụ m \nd Onyenwe anyị\nd* onye na-edo ha nsọ.’ ”
\s1 Aja na-ezughị oke
\p 
\v 17 \nd Onyenwe anyị\nd* gwara Mosis sị,
\v 18 “Gwa Erọn na ụmụ ya ndị ikom na ụmụ Izrel niile okwu sị ha, ‘Ọ bụrụ na onye ọbụla, onye Izrel maọbụ onye ọbịa nʼIzrel, eweta aja nsure ọkụ nye \nd Onyenwe anyị\nd* imezu nkwa o kwere, maọbụ dịka onyinye afọ ofufu,
\v 19 ọ ga-eweta otu oke nke na-enweghị nkwarụ nke si nʼigwe ehi, maọbụ atụrụ, maọbụ ewu, ka a nabata ya nʼaha.
\v 20 Ewebatala ihe ọbụla nke nwere nkwarụ, nʼihi na agaghị m anabata ya nʼaha gị.
\v 21 Mgbe onye ọbụla wetara ehi maọbụ atụrụ maọbụ ewu site nʼigwe anụ, dịka onyinye aja udo ọ na-enye \nd Onyenwe anyị\nd* maka imezu nkwa, maọbụ onyinye afọ ofufu, ọ ga-abụ nke na-enweghị ọrụsị maọbụ ntụpọ ọbụla tupu a nabata ya.
\v 22 Anụmanụ ọbụla kpuru ìsì, maọbụ nke merụrụ ahụ, maọbụ nke ụkwụ maọbụ aka gbajiri, maọbụ nke akpụkpa dị nʼahụ ya, maọbụ ihe nwere ure, maọbụ nke ọnya dị nʼahụ, agaghị abụ ihe onyinye nye \nd Onyenwe anyị\nd*. Unu atụkwasịkwala ha nʼebe ịchụ aja dịka onyinye nye \nd Onyenwe anyị\nd*.
\v 23 Unu nwere ike jiri ehi maọbụ atụrụ\f + \fr 22:23 \ft \xt Lev 3:6\xt*\f* nke akụkụ ahụ ya tara ata, maọbụ nke otu akụkụ ya buru ibu karịa ibe ya chụọ aja onyinye si nʼobi, ma a gaghị e ji ya chụọ aja imezu nkwa.
\v 24 Unu agaghị enye anụmanụ ọbụla nke mkpụrụ amụ ya chipịara echipịa, maọbụ nke pịara apịa, maọbụ nke a dọwapụrụ adọwapụ maọbụ nke a chakapụrụ achakapụ, dịka onyinye nʼihu \nd Onyenwe anyị\nd*. Unu enyekwala ụdị onyinye a nʼala unu.
\v 25 Unu esitekwala nʼaka onye ọbịa nata ụdị onyinye a, ma webata ya dịka nri a na-enye Chineke unu. A gaghị anabata ha nʼọnọdụ unu, nʼihi na ha nwere nkwarụ, nwekwa ntụpọ.’ ”
\p 
\v 26 \nd Onyenwe anyị\nd* sịrị Mosis,
\v 27 “Mgbe a mụrụ nwa ehi, maọbụ nwa atụrụ, maọbụ ewu ọhụrụ, a ga-ahapụ ya na nne ya ụbọchị asaa. Site nʼụbọchị nke asatọ gaa nʼihu a ga-anabata ya dịka onyinye ihe oriri i ji chụọ aja nsure ọkụ nye \nd Onyenwe anyị\nd*.
\v 28 Egbula nne anụ na nwa ya nʼotu ụbọchị, maọbụ ehi maọbụ atụrụ.\f + \fr 22:28 \ft \xt Dit 22:6-7\xt*\f*
\p 
\v 29 “Mgbe unu na-achụrụ \nd Onyenwe anyị\nd* aja ekele, chụọnụ ya nʼụzọ ahụ a ga-anabata ya.
\v 30 Riekwanụ anụ aja ahụ nʼotu ụbọchị ahụ, ka ọ hapụ ịfọdụ ruo echi ya. Abụ m \nd Onyenwe anyị\nd*.
\p 
\v 31 “Unu ga-edebe iwu m ndị a niile, mee ha nʼihi na abụ m \nd Onyenwe anyị\nd*.
\v 32 Unu emekwala ka aha m ghara ịdị nsọ. A ga-edo aha m nsọ nʼetiti ụmụ Izrel, nʼihi na abụ m \nd Onyenwe anyị\nd* onye na-edo unu nsọ.
\v 33 Ọ bụ m kpọpụtara unu site nʼala Ijipt ka m bụrụ Chineke unu. Abụ m \nd Onyenwe anyị\nd*.”
\c 23
\s1 Mmemme dị iche iche
\p 
\v 1 \nd Onyenwe anyị\nd* gwara Mosis okwu sị ya,
\v 2 “Gwa ụmụ Izrel okwu sị ha, ‘Ndị a bụ mmemme a kara aka nye \nd Onyenwe anyị\nd*, nke unu ga-ekwusa dịka mkpọkọta dị nsọ.
\s2 Ụbọchị izuike
\p 
\v 3 “ ‘Ụbọchị isii ka unu ga-eji rụọ ọrụ. Ma ụbọchị nke asaa, bụ ụbọchị izuike, ụbọchị mkpọkọta dị nsọ. Unu agaghị arụ ọrụ ọbụla nʼụbọchị ahụ, nʼebe ọbụla unu bi. Ọ bụ ụbọchị izuike nye \nd Onyenwe anyị\nd*.
\s2 Mmemme Ngabiga na Mmemme Achịcha na-ekoghị eko
\p 
\v 4 “ ‘Ndị a bụ mmemme \nd Onyenwe anyị\nd* a kara aka, mkpọkọta dị nsọ nke unu ga-ekwusa nʼoge a kara aka.
\v 5 Nʼọnwa mbụ, nʼụbọchị nke iri na anọ nke ọnwa ahụ, nʼoge uhuruchi, mgbe anwụ dara, ka Mmemme Ngabiga \nd Onyenwe anyị\nd* ga-adị.
\v 6 Mmemme achịcha na-ekoghị eko \nd Onyenwe anyị\nd* ka unu ga-ebido nʼụbọchị iri na ise nke ọnwa ahụ. Abalị asaa ka unu ga-eri achịcha a na-ejighị ihe na-eko achịcha mee.
\v 7 Nʼụbọchị mbụ nke mmemme a, unu ga-enwe mkpọkọta dị nsọ, ọ dịkwaghị onye ọbụla ga-arụ ọrụ ọbụla.
\v 8 Unu ga-eweta aja e sitere nʼọkụ chụọ nye \nd Onyenwe anyị\nd*. Nʼụbọchị nke asaa nweenụ mkpọkọta dị nsọ, unu arụkwala ọrụ nke ụbọchị ahụ.’ ”
\s2 Mmemme Mkpụrụ Mbụ
\p 
\v 9 \nd Onyenwe anyị\nd* gwara Mosis sị ya,
\v 10 “Gwa ụmụ Izrel sị ha, ‘Mgbe unu banyere nʼala ahụ m na-aga inye unu, ghọta mkpụrụ ihe ubi nke mbụ unu, unu ga-ewetara onye nchụaja otu ukwu ọka site nʼọka unu ghọtara nʼubi unu.
\v 11 Ọ ga-anara unu ukwu ọka ahụ fufee ya nʼihu \nd Onyenwe anyị\nd*, ka a nabata ya. Ọ bụ nʼụbọchị ahụ ga-esote ụbọchị izuike ka onye nchụaja ga-efufe ya.
\v 12 Nʼotu ụbọchị ahụ e fufere ukwu ọka ahụ, unu ga-ewere nwa ebule na-enweghị ntụpọ, nke gbara naanị otu afọ, chụọrọ \nd Onyenwe anyị\nd* aja nsure ọkụ.
\v 13 Aja mkpụrụ ọka ga-eso aja nsure ọkụ a. Ọ ga-eji iko ọka a kwọrọ nke ọma iri na abụọ a gwara mmanụ oliv, ka ọ bụrụ ihe e surere nʼọkụ na-esi ezi isi ọma nye \nd Onyenwe anyị\nd*. A ga-enyekwa iko mmanya atọ dịka onyinye ihe ọṅụṅụ
\v 14 Unu agaghị eri achịcha, maọbụ ọka e ghere eghe, maọbụ ọka ọhụrụ tutu ruo mgbe unu buru ụzọ weta onyinye nye Chineke unu. Nʼebe ọbụla unu bi, ụkpụrụ a ga-adịgide ruo ọgbọ niile.
\s2 Mmemme Izu Asaa
\p 
\v 15 “ ‘Site nʼụbọchị ahụ sotere ụbọchị izuike, bụ ụbọchị ahụ unu wetara ukwu ọka nke onyinye mfufe, gụpụta izu asaa zuru ezu.
\v 16 Gụpụtakwa iri ụbọchị ise site nʼụbọchị izuike ahụ mezuru izu asaa ahụ ma wetara \nd Onyenwe anyị\nd* onyinye ọka ọhụrụ.
\v 17 Site nʼebe ọbụla unu bi, unu ga-ewetara \nd Onyenwe anyị\nd* ogbe achịcha abụọ nke unu ji iko ọka a kwọrọ nke ọma iri na abụọ, nke e ji ihe na-eko achịcha mee, ya bụ yiist, dịka aja mfufe nke mkpụrụ mbụ nye \nd Onyenwe anyị\nd*.
\v 18 Tinyere achịcha a, unu ga-eweta ụmụ atụrụ asaa gbara otu afọ, ndị na-enweghị ntụpọ, na otu nwa oke ehi, na ebule abụọ. Ha ga-abụ aja nsure ọkụ nye \nd Onyenwe anyị\nd*, ya na aja mkpụrụ ọka na aja ihe ọṅụṅụ, aja e sitere nʼọkụ chụọ, nke isisi ya dị ezi mma nye \nd Onyenwe anyị\nd*.
\v 19 Unu ga-ejikwa otu mkpi chụọ aja mmehie. Werekwa ụmụ atụrụ abụọ gbara otu afọ, otu afọ, chụọ aja udo.
\v 20 Onye nchụaja ga-efufe ụmụ atụrụ abụọ ndị a, na achịcha ndị si na mkpụrụ mbụ ahụ nʼihu \nd Onyenwe anyị\nd* dịka aja mfufe. Ha bụ aja dị nsọ nye \nd Onyenwe anyị\nd*. Ọ bụkwa ndị nchụaja ga-ewere ha dịka nri ha.
\v 21 Nʼotu ụbọchị ahụ unu ga-akpọsakwa mkpọkọta dị nsọ, unu arụkwala ọrụ nke ụbọchị ahụ. Nke a ga-abụ ụkpụrụ ga-adịgide ebighị ebi site nʼọgbọ ruo nʼọgbọ niile, nʼebe ọbụla unu bi.
\p 
\v 22 “ ‘Mgbe unu na-ewe ihe ubi, unu ewechala ihe niile dị nʼakụkụ niile nke ubi unu. Hapụrụnụ ha ụmụ ogbenye, na ndị ọbịa. Hapụkwara ha mkpụrụ ubi niile dara nʼala. Abụ m \nd Onyenwe anyị\nd* Chineke unu.’ ”
\s2 Mmemme Opi
\p 
\v 23 \nd Onyenwe anyị\nd* gwara Mosis sị,
\v 24 “Gwa ụmụ Izrel sị, ‘Ụbọchị mbụ nke ọnwa nke asaa ga-abụ ụbọchị izuike, ụbọchị mkpọkọta dị nsọ nke a ga-eji opi na-ada oke ụda cheta.
\v 25 Unu arụla ọrụ ọbụla nʼụbọchị ahụ, kama unu ga-achụ aja nsure ọkụ nye \nd Onyenwe anyị\nd*.’ ”
\s2 Ụbọchị Mkpuchi Mmehie
\p 
\v 26 \nd Onyenwe anyị\nd* gwara Mosis sị,
\v 27 “Ụbọchị nke iri nke ọnwa asaa a bụ ụbọchị Mkpuchi Mmehie. Ọ bụ ụbọchị mkpọkọta dị nsọ nye unu. Unu ga-ata onwe unu ahụhụ bịa wetara \nd Onyenwe anyị\nd* onyinye site nʼọkụ.
\v 28 Unu arụla ọrụ ọbụla nʼụbọchị ahụ nʼihi na ụbọchị ahụ bụ ụbọchị ịchụ aja mkpuchi mmehie unu nʼihu \nd Onyenwe anyị\nd* Chineke unu.
\v 29 Onye ọbụla na-ejighị ụbọchị ahụ weda onwe ya nʼala ka a ga-ekewapụ site nʼetiti ndị ya.
\v 30 Aga m ebibikwa onye ọbụla rụrụ ọrụ nʼụbọchị ahụ.
\v 31 Unu agaghị arụ ọrụ ọbụla. Nʼebe ọbụla unu bi, ụkpụrụ a ga-adịgide nye unu niile site nʼọgbọ ruo nʼọgbọ.
\v 32 Ọ ga-abụ ụbọchị izuike zuruoke nye unu, unu ga-ewedakwa onwe unu nʼala. Nʼụbọchị nke itoolu nke ọnwa ahụ, site nʼuhuruchi ruo nʼuhuruchi nke na-esote ya, unu ga-edebe izuike unu.”
\s2 Mmemme Ụlọ Ikwu
\p 
\v 33 \nd Onyenwe anyị\nd* gwara Mosis sị,
\v 34 “Gwa ụmụ Izrel, ‘Nʼụbọchị nke iri na ise, nʼọnwa nke asaa, ka unu ga-amalite mmemme Ụlọ Ikwu \nd Onyenwe anyị\nd*. A ga-eme ya ụbọchị asaa.
\v 35 Nʼụbọchị nke mbụ bụ ụbọchị mkpọkọta dị nsọ. Onye ọbụla agaghị arụ ọrụ nʼụbọchị ahụ.
\v 36 Nʼụbọchị ọbụla nʼime ụbọchị asaa ndị a niile ka a ga-ewetara \nd Onyenwe anyị\nd* onyinye site nʼọkụ. Nʼụbọchị nke asatọ ka mkpọkọta dị nsọ ga-adị. A ga-achụ aja nsure ọkụ nye \nd Onyenwe anyị\nd*, nʼụbọchị a. Ọ bụ mkpokọta mmechi, nʼihi ya, a gaghị arụ ọrụ ọbụla nʼụbọchị ahụ.
\p 
\v 37 (“ ‘Ndị a bụ mmemme a kara aka, mgbe a ga-ekwusa mkpọkọta dị nsọ maka iwetara \nd Onyenwe anyị\nd* onyinye nri, ya bụ, onyinye aja nsure ọkụ, na onyinye mkpụrụ ọka, na aja dị iche iche, na onyinye ihe ọṅụṅụ dịka e sị hazie na ọ ga na-adị kwa ụbọchị.
\v 38 Unu ga-enye onyinye ndị a, tinyere onyinye a na-enye \nd Onyenwe anyị\nd* nʼụbọchị izuike, na tinyere onyinye ndị ọzọ unu na-enye na ihe ndị ọzọ unu kwere na nkwa, na onyinye afọ ofufu niile unu na-enye \nd Onyenwe anyị\nd*.)
\p 
\v 39 “ ‘Ya mere, malite nʼụbọchị nke iri na ise nke ọnwa asaa, mgbe unu webatasịrị ihe ubi unu, meerenụ \nd Onyenwe anyị\nd* mmemme ụbọchị asaa, ụbọchị nke mbụ, na ụbọchị nke asatọ ga-abụ ụbọchị izuike.
\v 40 Nʼụbọchị nke mbụ, unu ga-ewere ụfọdụ mkpụrụ osisi dị mma nke si nʼosisi unu na-amị mkpụrụ, gbutekwa igu nkwụ, na alaka osisi nwere ahịhịa ndụ, na osisi pọpla, jiri ha mee mmemme obi ụtọ nʼihu \nd Onyenwe anyị\nd* Chineke unu ụbọchị asaa.
\v 41 Mmemme ụbọchị asaa a ga-adị nye \nd Onyenwe anyị\nd* nʼafọ niile, site nʼọgbọ ruo nʼọgbọ unu niile. Ọ bụkwa nʼọnwa nke asaa ka unu ga-eme mmemme a.
\v 42 Nʼoge mmemme a, ụmụ Izrel niile ga-ebi nʼụlọ e ji alaka osisi na ahịhịa wuo ụbọchị asaa. Ụmụ afọ Izrel niile ga-ebi nʼụlọ dị otu a.
\v 43 Nke a ga-echetara ọgbọ ụmụ Izrel niile na mgbe m kpọpụtara unu site nʼala Ijipt, unu biri nʼụlọ e ji osisi na ahịhịa wuo nʼọzara. Abụ m \nd Onyenwe anyị\nd* Chineke unu.’ ”
\p 
\v 44 Mosis gwara ụmụ Izrel ihe gbasara mmemme niile a kara aka nye \nd Onyenwe anyị\nd*.
\c 24
\s1 Iheọkụ na mmanụ ya
\p 
\v 1 \nd Onyenwe anyị\nd* gwara Mosis sị,
\v 2 “Nye ndị Izrel niile iwu ka ha wetara gị mmanụ oliv asụrụ asụ, nke a na-agwaghị ihe, maka itinye nʼiheọkụ ime ka ọkụ oriọna na-enwu mgbe niile.
\v 3 Na mpụta nke akwa mgbochi nke kpuchiri igbe Ihe Ama ahụ, nʼime ụlọ nzute, Erọn ga-amụnye oriọna ndị ahụ nʼihu \nd Onyenwe anyị\nd* mgbe niile, site nʼuhuruchi ruo nʼụtụtụ. Nke a bụ ụkpụrụ ga-adịgide nye ọgbọ niile dị nʼihu.
\v 4 Ihe ọkụ ọlaedo a nụchara anụcha ndị ahụ dọọ nʼelu ihe ịdọkwasị oriọna, nʼihu \nd Onyenwe anyị\nd* ga na-enwu ọkụ mgbe niile.
\s1 Achịcha na-adị nʼihu \nd Onyenwe anyị\nd*
\p 
\v 5 “Were ọka a kwọrọ nke ọma mee ogbe achịcha iri na abụọ. Jiri ihe ruru iko ọka asatọ mee otu ogbe achịcha ọbụla.
\v 6 Doo achịcha ndị a nʼahịrị abụọ nʼelu tebul ahụ e ji ọlaedo a nụchara anụcha kpụọ, nke dị nʼihu \nd Onyenwe anyị\nd*. Ogbe achịcha isii ga-adị nʼotu ahịrị.
\v 7 Nʼogologo ahịrị ọbụla tinye insensi a na-agwaghị ihe, ka ọ bụrụ ihe nọchiri achịcha ndị a dịka onyinye nsure ọkụ nye \nd Onyenwe anyị\nd*.
\v 8 A ga-edo achịcha ndị a nʼihu \nd Onyenwe anyị\nd* oge niile, ụbọchị izuike niile, nʼọnọdụ ụmụ Izrel, dịka ọgbụgba ndụ ebighị ebi.
\v 9 Ọ dịrị Erọn na ụmụ ya ndị ikom, bụ ndị ga-eri ya nʼime nʼebe nsọ ahụ, nʼihi na ọ bụ oke dịkarịsịrị nsọ, site nʼoke ha mgbe niile, nke sitere nʼonyinye nsure ọkụ e chere nye \nd Onyenwe anyị\nd*.”
\s1 Ọnwụ onye kọchara \nd Onyenwe anyị\nd*
\p 
\v 10 Otu nwokorobịa, nke nna ya bụ onye Ijipt ma nne ya bụ onye Izrel, sitere nʼetiti ụmụ Izrel pụta. O ruo na nwoke a nne ya bụ onye Izrel na otu nʼime ndị ikom Izrel malitere ịlụ ọgụ.
\v 11 Mgbe ha na-alụ ọgụ ahụ nwoke ahụ nne ya bụ onye Izrel kwuluru Aha ahụ kọchaa ya. Nʼihi ya, a kpọrọ ya ikpe nʼihu Mosis. (Aha nne ya bụ Shelomit, nwa Dibri, onye ebo Dan.)
\v 12 Ha tinyere nwoke ahụ nʼụlọ mkpọrọ na-eche ka ha nụ okwu \nd Onyenwe anyị\nd*, ịmata ihe ha ga-eme ya.
\p 
\v 13 Mgbe ahụ, \nd Onyenwe anyị\nd* gwara Mosis sị,
\v 14 “Kpụrụ onye nkwulu ahụ gaa nʼazụ obodo. Ndị niile nụrụ okwu ahụ o kwuru ga-ebikwasị ya aka ha nʼisi. Mgbe ahụ, ọgbakọ Izrel niile ga-eji nkume tugbuo ya.
\v 15 Gwa ụmụ Izrel okwu sị ha, ‘Onye ọbụla kọchara Chineke ya ga-ebu mmehie ya nʼisi ya.
\v 16 Onye ọbụla kwuluru aha \nd Onyenwe anyị\nd* ka a ga-egbu. Mmadụ niile ga-agbakọ jiri nkume tugbuo onye ahụ. Onye ọbụla kwuluru Aha ahụ, maọbụ ọbịa, maọbụ nwa afọ ala, ka a ga-egbu.
\p 
\v 17 “ ‘Onye ọbụla gburu mmadụ ka a ga-egbu.
\v 18 Onye gburu anụ ụlọ na-abụghị nke ya, ga-akwụghachi ụgwọ ya. Ndụ ga-alara ndụ.
\v 19 Onye ọbụla merụrụ mmadụ ibe ya ahụ, a ga-emerụkwa onye ahụ ahụ nʼebe o merụrụ ibe ya ahụ.
\v 20 Onye tijiri mmadụ ọkpụkpụ, a ga-etiji ọkpụkpụ nke ya. Anya ga-alara anya, eze ga-alakwara eze. Otu e si merụọ mmadụ ahụ, ka a ga-esi merụọkwa onye merụrụ ya ahụ.
\v 21 Onye ọbụla gburu anụ ụlọ onye ọzọ, ga-akwụ ụgwọ ya. Ma a ga-egbu onye ọbụla gburu mmadụ.
\v 22 Unu ga-enwe otu iwu nke ga-adị nye ndị amụrụ nʼala, dịkwara ndị ọbịa niile. Abụ m \nd Onyenwe anyị\nd* Chineke unu.’ ”
\p 
\v 23 Mgbe ahụ, Mosis gwara ndị Izrel okwu, nʼihi ya ha dọkpụụrụ onye nkwulu ahụ pụọ nʼazụ obodo, jiri nkume tugbuo ya nʼebe ahụ, dịka \nd Onyenwe anyị\nd* nyere Mosis nʼiwu.
\c 25
\s1 Afọ izuike
\p 
\v 1 \nd Onyenwe anyị\nd* gwara Mosis okwu nʼugwu Saịnaị sị ya,
\v 2 “Gwa ụmụ Izrel sị ha, ‘Mgbe unu batara nʼala ahụ m ga-enye unu, unu ga-eme ka ala ahụ nwee afọ izuike nke ya nye \nd Onyenwe anyị\nd*.
\v 3 Afọ isii ka unu ga-akụ ihe nʼubi, afọ isii ka unu ga-ewe ihe ubi, kwachaakwa alaka osisi vaịnị unu.
\v 4 Ma mgbe o ruru afọ nke asaa, unu ga-ahapụ ala ubi unu ka o zuo ike, afọ izuike nye \nd Onyenwe anyị\nd*. Unu akụla ihe ọbụla nʼubi unu maọbụ kwachaa osisi vaịnị unu.
\v 5 Unu agaghị ewe ihe ubi ọbụla ga-epupụtara onwe ha nʼoge a, maọbụ tụtụọ mkpụrụ osisi vaịnị ndị ga-ada ada. Nʼihi na afọ ahụ bụ afọ ozuzu ike dịrị ala ubi niile.
\v 6 Ihe ubi puputara nʼala ahụ niile nʼafọ izuike ahụ bụ nri dịrị unu onwe unu, na ndị odibo nwoke na nwanyị unu niile, na onye i goro ọrụ, na onye ọbịa bi nʼetiti unu.
\v 7 Ihe ubi ahụ dịkwara anụ ụlọ gị, na anụ ọhịa bi nʼala gị. Ihe ọbụla puputara nʼala bụ ihe unu ga-eri.
\s1 Afọ iri ise nke inwere onwe
\p 
\v 8 “ ‘Gụpụta afọ izuike asaa, afọ asaa, ụzọ asaa. Ngụkọ afọ izuike ndị a niile ga-enye iri afọ anọ na itoolu.
\v 9 Nʼụbọchị nke iri nke ọnwa asaa, zipụ onye ga-egbu opi ike, ya bụ, nʼụbọchị mkpuchi mmehie, a ga-egbu opi ike nʼala Izrel niile.
\v 10 Doonụ afọ nke iri ise ahụ nsọ, kwusaakwa inwere onwe nye mmadụ niile nʼala ahụ niile. Afọ ahụ ga-abụ afọ inwere onwe\f + \fr 25:10 \fq Inwere onwe \ft pụtara \fqa mmeri maọbụ Jubili.\f* nye unu. Onye ọbụla nʼime unu ga-alaghachi nʼihe onwunwe nke ezinaụlọ ya, onye ọbụla kwa ga-alaghachi nʼagbụrụ ya.
\v 11 Afọ nke iri ise bụ afọ inwere onwe nye unu. A gaghị akụ ihe ọbụla nʼubi, a gakwaghị ewe ihe ubi ọbụla puputara nʼonwe ya, maọbụ mkpụrụ osisi vaịnị mịrị nʼonwe ya.
\v 12 Ọ bụ afọ inwere onwe, bụrụkwa afọ dị nsọ nye unu, nke onye ọbụla ga-eri naanị ihe e wetara nʼubi.
\p 
\v 13 “ ‘Onye ọbụla ga-alaghachi nʼihe onwunwe nke ya, nʼafọ inwere onwe a.
\p 
\v 14 “ ‘Ọ bụrụ na i resiri onye agbataobi gị ala, maọbụ na o nwere nke ọ zụrụ site nʼaka gị, unu aghọgbula ibe unu.
\v 15 Ị ga-azụrụ ala site nʼaka onye agbataobi dịka ọnụọgụgụ afọ si dị site nʼafọ inwere onwe. Ha ga-eresi gị ya dịka ọnụọgụgụ afọ ole fọdụrụ maka ịkọ ihe nʼala ahụ.
\v 16 Ọ bụrụ na a zụrụ ala ahụ nso nso mmemme iri afọ ise a, ọnụahịa ala ahụ ga-adị ala, ọ bụrụkwanụ na ọ dị anya site na mmemme ahụ, ọnụahịa ya ga-adị elu, nʼihi na ụgwọ onye ahụ na-akwụ bụ ụgwọ ugboro ole ọ ga-akụ ihe nʼala ahụ.
\v 17 Unu emegbula ibe unu kama tụọnụ egwu Chineke unu. Abụ m \nd Onyenwe anyị\nd* Chineke unu.
\p 
\v 18 “ ‘Gbasoonụ ụkpụrụ m, ma lezie anya imezu ihe m nyere nʼiwu, ka unu nwee ike ibi obi udo nʼala ahụ.
\v 19 Mgbe ahụ, ala ga-amị mkpụrụ ya, unu ga-eriju afọ, birikwa nʼala ahụ nʼudo.
\v 20 Unu nwere ike jụọ ajụjụ sị, “Gịnị ka anyị ga-eri nʼafọ nke asaa ahụ ebe ọ bụ na anyị agaghị akụ ihe ọbụla, maọbụ wee ihe ubi ọbụla nʼafọ ahụ?”
\v 21 Aga m ezitere unu ngọzị dị ukwuu nʼafọ nke isii, nke ga-eme ka ala mee ihe omume nke ga-ezuru unu afọ atọ.
\v 22 Mgbe unu ga-akụ ihe ubi nʼafọ nke asatọ unu ga na-eri site nʼowuwe ihe ubi ochie unu tutu ruo nʼafọ nke itoolu mgbe unu ga-ewebata ihe ubi ọhụrụ.
\p 
\v 23 “ ‘Chetanụ na ala bụ nke m, nʼihi nke a, o kwesighị ka unu ree ala ọbụla kpamkpam. Unu bụ naanị ndị ọbịa na ndị nlekọta nye m.
\v 24 Nʼala obibi unu niile, unu ga-enye ohere maka mgbapụta ala erere ere.
\p 
\v 25 “ ‘Ọ bụrụ na otu onye nʼime unu aghọọ onye ogbenye si otu a ree ala ya, nwanna ya dị ya nso ga-abịa gbapụta ala ahụ.
\v 26 Ọ bụrụ na-enweghị onye ga-agbapụta ala ahụ nye ha, ma ha mesịa ghọọ ndị bara ụba nwekwa ihe ga-ezu ịgbapụta ala ahụ nʼonwe ha.
\v 27 A ga-agụ afọ ole gara site na mgbe o rere ala ahụ, nyeghachi ya ego ole o kwesiri inweta. Onye rere ala ga-alaghachikwa nʼala ya.
\v 28 Ọ bụrụ na onyenwe ya enweghị ike ịchọta ego ọ ga-eji gbara ya, ala ahụ ga-adị nʼaka onye ahụ zụrụ ya tutu ruo nʼafọ inwere onwe. Mgbe ahụ ọ ga-ewerekwa ala ahụ nyeghachi ya onye resiri ya.
\p 
\v 29 “ ‘Onye ọbụla rere ụlọ obibi dị nʼobodo e ji mgbidi gbaa gburugburu nwere ikike mgbapụta ya naanị mgbe otu afọ zuru site na mgbe e rere ya. Nʼoge ahụ ka onye rere ya nwere ike ịgbaghachi ya.
\v 30 Ọ bụrụ na a gbapụtaghị ya tupu otu afọ agafee, ụlọ ahụ dị nʼime obodo nwere mgbidi ga-abụ nke onye ahụ zụrụ ya mgbe niile, bụrụkwa nke ụmụ ụmụ ya. A gaghị enyeghachikwa ya mgbe afọ inwere onwe ruru.
\v 31 Ma ụlọ ndị dị nʼobodo nta na-enweghị mgbidi a ga-agụ ha dịka ihe dị nʼọhịa. E nwere ike ịgbapụta ha, ha bụkwa nke a ga-eweghachite mgbe afọ inwere onwe ruru.
\p 
\v 32 “ ‘Ma banyere obodo niile nke ndị Livayị dị iche iche. Ha nwere ikike ịgbapụta ụlọ ha dị nʼime nketa ha mgbe ọbụla.
\v 33 Ihe onwunwe ndị Livayị bụ nke e nwere ike ịgbapụta, bụ ndị a, ụlọ niile e rere nke dị nʼobodo ha nwere. Ọ ga-abụ nʼafọ inwere onwe ka aga enwetaghachi ha, nʼihi na ụlọ ndị ahụ dị nʼobodo ndị Livayị bụ naanị oke ha nwere nʼetiti ụmụ Izrel.
\v 34 Ma a gaghị ere ala ebe ịta nri nke anụ ụlọ gbara obodo ha gburugburu ere, nʼihi ọ bụ ihe ha nwee nʼọha ruo ebighị ebi.
\p 
\v 35 “ ‘Ọ bụrụ na nwanne gị adaa ogbenye ruo na o nweghị ike inyere onwe ya aka, ọ dị gị nʼaka inyere ya aka, kpọbata ya ka ọ bịa biri nʼụlọ gị dịka ị ga-esi kpọbata onye ọbịa. Nʼụzọ dị otu a, ọ ga-anọgide biri nʼetiti unu.
\v 36 Tụọ egwu Chineke, kwerekwa ka nwanna gị soro gị biri nʼala ahụ. A nakwala ụma maọbụ ọmụrụnwa ọbụla.\f + \fr 25:36 \ft \xt Ọpụ 22:25\xt*\f*
\v 37 Ị gaghị ana ọmụrụnwa nʼego i gbazinyere ha, maọbụ rie uru site na nri i resiri ha.
\v 38 Mụ onwe m bụ \nd Onyenwe anyị\nd* Chineke unu, onye kpọpụtara unu site nʼala Ijipt, inye unu ala Kenan, na ị bụ Chineke unu.
\p 
\v 39 “ ‘Ọ bụrụ na onye Izrel ọbụla adaa ogbenye, resi gị onwe ya, emela ka o jere gị ozi dịka onye ohu.
\v 40 Kama ị ga-emeso ya mmeso dịka ị ga-esi meso onye ọrụ e goro ego, maọbụ dịka onye ọbịa nọ nʼetiti unu. Ọ ga-ejere gị ozi tutu ruo afọ inwere onwe.
\v 41 Nʼafọ ahụ, ị ga-ahapụ ha na ụmụ ha ka ha laghachikwuru ndị ikwu ha, si otu a nwetaghachi ala ubi dị nʼezinaụlọ ha.
\v 42 Nʼihi na a kpọpụtara m ndị Izrel site nʼala Ijipt ka ha bụrụ ndị na-ejere m ozi. Ya mere, a gaghị ere ha mgbe ọbụla dịka ohu.
\v 43 A gakwaghị emegbu ha nʼụzọ dị njọ.\f + \fr 25:43 \ft \xt Ọpụ 1:13\xt*\f* Tụọnụ egwu Chineke unu.
\p 
\v 44 “ ‘Ma unu nwere ike gbara ndị ohu nwoke maọbụ nwanyị site nʼetiti ndị mba ọzọ niile bi nʼakụkụ unu. Unu nwere ike site nʼebe ahụ zụta ndị ohu.
\v 45 Unu nwere ike ịzụ ndị ohu site nʼetiti ndị mbịarambịa bi nʼetiti unu, maọbụ site nʼetiti ndị agbụrụ ha a mụrụ nʼala Izrel. Ndị dị otu a ga-abụkwa ihe onwunwe unu.
\v 46 Unu nwere ike kenye ha ụmụ unu dịka ihe nketa, ma mee ha ndị ohu unu ụbọchị ndụ ha niile. Ma unu agaghị eji aka ike chịa onye Izrel ibe unu.
\p 
\v 47 “ ‘Ọ bụrụ na onye ọbịa bi nʼetiti unu aghọọ ọgaranya, ma otu nʼime ụmụnna unu adaa ogbenye were onwe ya resi onye ọbịa ahụ bi nʼetiti unu, maọbụ were onwe ya resi nwanna ndị ikwu onye ọbịa ahụ,
\v 48 ha nwere ikike ịgbapụta ya mgbe ha resiri onwe ha. Otu nʼime ụmụnna ya nwere ike gbapụta ha.
\v 49 Nwanne nne ya, maọbụ nwanne nna ya, maọbụ nwanna nʼikwu ha\f + \fr 25:49 \fq Nwanna \ft Onye ahụ ga-abụ nwa nwoke nwanne nna ya.\f* ọbụla nwere ike ịgbapụta ya. Ọ nwekwara ike ịgbapụta onwe ya ma ọ bụrụ na ọ kpata ego.
\v 50 Ya na onye ahụ o resiri onwe ya ga-agụ afọ ole ọ bụ site na mgbe o rere onwe ya ruo nʼafọ inwere onwe. Ego a ga-akwụ nʼihi ịgbapụta ya ga-abụ ego ọ ga-efu ịkwụ ohu ọzọ ụgwọ ịrụ ọrụ ọnụọgụgụ afọ ndị ahụ niile.
\v 51 Ọ bụrụ nʼọtụtụ afọ fọdụrụ, ọ ga-esite nʼọnụ ego e rere ha kwụọ nke dị ukwu dịka ego mgbapụta ha. Naanị ihe ntakịrị ga-apụ nʼime ego ahụ.
\v 52 Ọ bụrụ naanị afọ ole na ole fọdụrụ tupu afọ inwere onwe eruo, ọ ga-agụkọ ihe ego ahụ pụtara, kwụọ ya maka ịgbara onwe ya dịka o kwesiri.
\v 53 A ga-emeso ha dịka ndị ọrụ e goro ego kwa afọ, ma ị ga-ahụ na onye ha nọ nʼokpuru ya agaghị eji aka ike chịa ha.
\p 
\v 54 “ ‘Ma ọ bụrụ na e nweghị ike gbapụta ya site nʼụzọ ndị a niile, ya na ụmụ ya ga-enwere onwe ha mgbe afọ inwere onwe ahụ zuru.
\v 55 Nʼihi na mụ ka ụmụ Izrel bụ ndị ohu nye. Ha bụ ndị ohu m, ndị m kpọpụtara site nʼala Ijipt. Mụ onwe m bụ \nd Onyenwe anyị\nd* Chineke unu.
\c 26
\s1 Ụgwọ ọrụ nrube isi
\p 
\v 1 “ ‘Unu emerela onwe unu arụsị\f + \fr 26:1 \ft \xt Ọpụ 20:4\xt*\f* ọbụla, maọbụ guzobe oyiyi apịrị apị, maọbụ ogidi nkume ọbụla ọtọ, nye onwe unu. Unu edokwala nkume a pịrị apị ọbụla nʼala unu maka ịkpọ isiala nye ya. Abụ m \nd Onyenwe anyị\nd* Chineke unu.
\p 
\v 2 “ ‘Debenụ iwu niile m nyere maka ụbọchị Izuike m,\f + \fr 26:2 \ft \xt Lev 19:30\xt*\f* sọpụkwaranụ ebe nsọ m. Abụ m \nd Onyenwe anyị\nd*.
\p 
\v 3 “ ‘Ọ bụrụ na unu ejegharịa nʼụkpụrụ m, lezie anya debe iwu m niile,
\v 4 aga m enye unu mmiri ozuzo nʼoge ya, nke ga-eme ka ala unu mịa ọtụtụ ihe ubi. Osisi unu niile ga-ejupụtakwa na mkpụrụ mgbe niile.
\v 5 Unu ga-anọgide na-azọcha ọka tutu ruo mgbe unu ga-aghọ mkpụrụ vaịnị unu, owuwe ihe ubi mkpụrụ vaịnị unu ga-adịgidekwa ruo oge ịkụ mkpụrụ nʼubi. Nʼụzọ dị otu a, unu ga-enwe nri ga-ezuru unu, unu ga-ebikwa nʼudo nʼala unu.
\p 
\v 6 “ ‘Aga m eme ka udo dịrị nʼala ahụ, unu ga-edina ala, ọ dịghịkwa onye ga-eme ka unu tụọ egwu ọbụla. Aga m ewezuga site nʼetiti unu ajọ anụ ọhịa, mma agha agaghị esitekwa nʼala unu bi nʼime ya gafee.
\v 7 Unu ga-achụ ndị iro unu ọsọ. Ha ga-ada nʼihu unu site na mma agha.
\v 8 Mmadụ ise nʼime unu ga-achụ narị mmadụ ọsọ. Narị mmadụ nʼetiti unu ga-achụkwa iri puku mmadụ ọsọ. Ndị iro unu ga-ada nʼihu unu site na mma agha.
\p 
\v 9 “ ‘Aga m eji ihuọma leta unu, mee ka unu mụbaa ma jupụta nʼọnụọgụgụ. Aga m eme ka ọgbụgba ndụ m nʼebe unu nọ dịgide.
\v 10 Unu ga-enwebiga mkpụrụ ubi oke ruo na mgbe unu ka nọ na-eri ndị ochie unu ga-ewezuga ha nʼakụkụ maka inye ohere iwebata ihe ubi ọhụrụ.
\v 11 Aga m eme ka ebe obibi m dịrị nʼetiti unu. Agaghị m asọ unu oyi.
\v 12 Aga m ejegharị nʼetiti unu, bụrụ Chineke unu, unu ga-abụkwa ndị m.
\v 13 Nʼihi na abụ m \nd Onyenwe anyị\nd* Chineke unu onye kpọpụtara unu site nʼala Ijipt, ka unu ghara ịbụ ndị ohu ọzọ. Etijiela m mkpọrọ igwe\f + \fr 26:13 \ft Ya bụ, yoku\f* nke ịbụ ohu unu, mee ka unu bụrụ ndị ji nganga ejegharị.
\s1 Ahụhụ nʼihi Nnupu isi
\p 
\v 14 “ ‘Ma ọ bụrụ na unu ajụ ige m ntị, jụkwa imezu ihe ndị a m nyere unu iwu ya,
\v 15 ọ bụrụ na unu ajụ ịgbaso ụkpụrụ m, sọọ iwu m ndị a oyi, si otu a mebie ọgbụgba ndụ m,
\v 16 mgbe ahụ, aga m eme ka oke ụjọ, na ọrịa na-ebibi ebibi, na ahụ ọkụ, bịakwasị unu. Ọrịa ndị a ga-eme ka anya unu daa mba, ọ ga-eripịakwa anụ ahụ unu. Unu ga-akụ mkpụrụ ubi nʼubi unu ma ndị iro unu ga-eri ha.
\v 17 Aga m eguzo megide unu nʼoge ibu agha, mee ka ndị iro unu merie unu nʼagha. Unu ga-agba ọsọ mgbe onye ọbụla na-adịghị achụ unu ọsọ. Ndị kpọrọ unu asị ga-achịkwa unu.
\p 
\v 18 “ ‘Ọ bụrụ na unu anọgidesie ike ju ige m ntị nʼagbanyeghị ihe ndị a, aga m enye unu ntaramahụhụ dị okpukpu asaa nʼihi mmehie unu.
\v 19 Aga m etiji ịnya isi nganga unu, mee ka mbara eluigwe dịịrị unu dịka igwe, elu ala unu na-azọkwasị ụkwụ ga-adịkwa dịka bronz.
\v 20 Unu ga-adọgbu onwe unu nʼọrụ nʼefu, nʼihi na ala unu agaghị emepụtara unu ihe omume ya, osisi nke ala unu agaghị amịkwa mkpụrụ ya.
\p 
\v 21 “ ‘Ọ bụrụkwa na mgbe nke a mesịrị, unu anọgidekwa jụ ime ihe m nyere nʼiwu, aga m eme ka ntaramahụhụ unu dịrị ukwuu, ugboro asaa ọzọ, nʼihi mmehie unu.
\v 22 Aga m ezite anụ ọhịa megide unu. Ha ga-adọgbu ụmụ unu, bibie anụ ụlọ unu, meekwa ka unu dị nta nʼọnụọgụgụ, ruo na ndị a ga-ahụ nʼokporoụzọ unu ga-adị ole na ole.
\p 
\v 23 “ ‘Ọ bụrụkwa na unu anọgide jụ ịdọ aka na ntị m, chie ntị nọgide na-ebu agha nnupu isi unu megide m,
\v 24 mụ onwe m ga-ebu agha megide unu. Aga m eti unu ugbo ihe otiti asaa, nʼihi mmehie unu.
\v 25 Aga m ewebata mma agha nʼebe unu nọ, ịbọ ọbọ nʼihi ọgbụgba ndụ m unu mebiri. Mgbe unu ga-agba ọsọ gbaba nʼobodo unu, aga m ezite ihe mbibi ga-ebibi unu nʼebe ahụ. Aga m enyefekwa unu nʼaka ndị iro unu.
\v 26 Aga m eme ka unu hapụ inwe ihe oriri ga-ezuru unu. Otu ite nri naanị ka ndị inyom iri ga-eji sie nri ha nwere. Ha ga-eji ihe ọtụtụ tụọ ya mgbe ha na-eke ya. Unu ga-eri ya, ma afọ agaghị eju unu.
\p 
\v 27 “ ‘Ọ bụrụkwa na unu agaa nʼihu jụ ige m ntị nʼagbanyeghị ihe ndị a, nọgide na-emegide m,
\v 28 mgbe ahụ, aga m egosi unu oke iwe m, nye unu ntaramahụhụ dị okpukpu asaa nʼihi mmehie unu.
\v 29 Unu ga-eri anụ ụmụ unu ndị ikom, na anụ ụmụ unu ndị inyom.
\v 30 Aga m ebibikwa ụlọ arụsị unu niile dị nʼelu ugwu, gbutuo ebe ịchụ aja niile unu na-esure ihe nsure ọkụ na-esi isi. Aga m atụkọta ozu unu nʼelu arụsị unu na-enweghị ume ndụ, ka unu bụrụ ihe m na-asọ oyi.
\v 31 Aga m eme ka obodo unu niile tọgbọrọ nʼefu, kụdasịakwa ebe nsọ unu niile. Agaghị m anabatakwa isisi ụtọ nke aja unu.
\v 32 Aga m eme ka ala unu tọgbọrọ nʼefu, mee ka ọnọdụ ịdị ala unu bụrụ ihe ga-eju ndị iro unu ga-ebi nʼime ya anya.
\v 33 Aga m achụsa unu na mba niile, mịpụta mma agha m jiri ya chụso unu ọsọ. Ala unu ga-atọgbọrọ nʼefu, a ga-etikpọkwa obodo unu niile.
\v 34 Mgbe ahụ, ala ahụ ga-ezu ike, ogologo oge ndị ahụ niile ọ ga-atọgbọrọ nʼefu. Mgbe unu ga-anọ dịka ndị ohu nʼala ndị iro unu. Ala ahụ ga-ezu ike, imejupụta afọ izuike ya niile.
\v 35 Ogologo oge niile ala ahụ tọgbọrọ nʼefu, ala ahụ ga-ezu ike, ụdị izuike ọ na-enweghị nʼafọ izuike ndị ahụ unu bi nʼime ya.
\p 
\v 36 “ ‘Ma ndị ahụ fọdụrụ ndụ nʼime unu, aga m etinye ịda mba nʼobi ha nʼala ndị iro ha. Mkpọtụ ahịhịa nke ifufe na-ebugharị ga-eme ka ha gbapụ ọsọ. Ha ga-agba ọsọ dịka ndị si nʼihu mma agha na-agba ọsọ. Ha ga-ada mgbe onye ọbụla na-adịghị achụ ha ọsọ.
\v 37 Nʼezie, ha ga-agba ọsọ mgbe onye ọbụla na-adịghị achụ ha ọsọ. Ha ga-adagide ibe ha mgbe ha na-agba ọsọ a, dịka ndị si nʼebe a na-alụ agha na-agbapụ ọsọ. Unu agaghị enwe ike iguzo nʼihu ndị iro unu.
\v 38 Unu ga-ala nʼiyi nʼetiti ndị mba ọzọ, ala ndị iro unu ga-eri unu.
\v 39 Ndị ahụ a hapụrụ na ndụ nʼetiti unu ga-ata ahụhụ nʼala ndị iro ha nʼihi mmehie ha. Ha ga-atakwa ahụhụ nʼihi mmehie nke nna nna ha.
\p 
\v 40 “ ‘Ma ọ bụrụ na ha ekwupụta mmehie\f + \fr 26:40 \ft \xt 1Jọn 1:9\xt*\f* ha niile, na mmehie niile nke ndị nna nna na ha na ha mehiere megide m, mmehie ekwesighị ntụkwasị obi ha, na mmehie nnupu isi ha, nke ha mehiere megide m,
\v 41 nke mere ka m doo onwe m imegide ha, na izipụ ha gaa nʼala ndị iro ha, ọ bụrụ na ha eweda onwe ha ala nabata ntaramahụhụ m nyere ha nʼihi mmehie ha
\v 42 aga m echeta ọgbụgba ndụ mụ na Jekọb gbara, ọgbụgba ndụ mụ na Aịzik gbara, na ọgbụgba ndụ mụ na Ebraham gbara. Aga m echeta ala ahụ.
\v 43 Ma ala ahụ aghaghị ịtọgbọrọ nʼefu. Ọ ghakwaghị inwezu izuike ruuru ya, oge ndị ahụ ọ tọgbọrọ nʼefu, mgbe ha na-ebighị nʼime ya. Ha ga-anata ntaramahụhụ ruuru ha nʼihi na ha jụrụ iwu m, sọọkwa ụkpụrụ m oyi.
\v 44 Ma ewezugakwa ihe ndị a niile, agaghị m ajụ ha,\f + \fr 26:44 \ft \xt Rom 11:2\xt*\f* maọbụ sọọ ha oyi, ruo na ibibi ha kpamkpam mgbe ahụ ha nọ nʼala ndị iro ha. Agakwaghị m emebi ọgbụgba ndụ\f + \fr 26:44 \ft \xt Dit 4:31\xt*\f* mụ na ha gbara nʼihi na abụ m Onyenwe anyị Chineke ha.
\v 45 Kama nʼihi ha, aga m echeta ọgbụgba ndụ ahụ mụ na nna nna ha gbara, ịbụ Chineke ha, ndị ahụ m kpọpụtara site nʼala Ijipt nʼihu mba niile. Abụ m \nd Onyenwe anyị\nd*.’ ”
\p 
\v 46 Ndị a bụ iwu, na ụkpụrụ na ndụmọdụ \nd Onyenwe anyị\nd* guzobere nʼugwu Saịnaị, nʼetiti ya onwe ya, na ụmụ Izrel, site nʼaka Mosis.\f + \fr 26:46 \ft \xt Lev 7:38; 27:34\xt*\f*
\c 27
\s1 Iwu banyere nkwa dị iche iche
\p 
\v 1 \nd Onyenwe anyị\nd* gwara Mosis okwu sị ya,
\v 2 “Gwa ụmụ Izrel sị ha, ‘Ọ bụrụ na mmadụ e kwee nkwa pụrụ iche iji mmadụ nye \nd Onyenwe anyị\nd* onyinye, ihe ndị a ka ọ ga-eji gbara onye ahụ:
\v 3 nʼisi nwoke ọbụla gbara iri afọ abụọ ruo iri afọ isii, ọ ga-akwụ iri ọlaọcha shekel ise, dịka ihe ọtụtụ ebe nsọ si dị.
\v 4 Nʼisi nwanyị ọbụla gbara iri afọ abụọ ruo iri afọ isii ọ ga-enye iri ọlaọcha shekel atọ.
\v 5 Nʼisi nwoke gbara afọ ise ruo iri afọ abụọ, ọ ga-enye iri ọlaọcha shekel abụọ. Nʼisi nwanyị gbara afọ ise ruo iri afọ abụọ, ọ ga-enye ọlaọcha shekel iri.
\v 6 A ga-akwụrụ nwantakịrị nwoke gbara site otu ọnwa ruo afọ ise, ọlaọcha shekel ise, kwụọra nwantakịrị nwanyị gbara otu ọnwa ruo afọ ise ọlaọcha shekel atọ.
\v 7 Nʼisi nwoke gafere iri afọ isi, a ga-enye ọlaọcha shekel iri na ise. Nʼisi nwanyị gafere iri afọ isi a ga-enye ọlaọcha shekel iri.
\v 8 Ọ bụrụ na e nwee onye ogbenye na-enweghị ego ọ ga-eji kwụọ ụgwọ ndị a, a ga-akpọtara ya onye nchụaja, onye ga-ekwubi ihe onye ahụ kwere nkwa ga-akwụ dịka ego o nwere ruru.
\p 
\v 9 “ ‘Ọ bụrụ anụ ụlọ dị mma inye \nd Onyenwe anyị\nd* dịka onyinye ka e kwere nkwa inye, anụ ụlọ e nyere \nd Onyenwe anyị\nd* ga-aghọ ihe dị nsọ.
\v 10 Onye kwere nkwa inye ya enweghị ike iji anụ ụlọ nke ahụ ya na-ezughị oke gbanwere anụ ụlọ ahụ na-enweghị ntụpọ. O nwekwaghị ike iji anụ ụlọ ahụ na-enweghị ntụpọ gbanwere nke anụ ahụ ya na-ezughị oke. Ọ bụrụ na o mee otu a, anụ ụlọ nke mbụ, na nke abụọ, ga-abụ ihe dị nsọ.
\v 11 Ọ bụrụ na anụ ụlọ o ji kwee nkwa bụ anụ ụlọ rụrụ arụ,\f + \fr 27:11 \fk Anụ ụlọ rụrụ arụ \ft Ndị a bụ anụ ndị ahụ a jụrụ ịnabata maka i ji chụọ aja, ha bụ ịnyịnya, ịnyịnya kamel na ịnyịnya ibu.\f* ụdị anụ ụlọ ahụ a jụrụ ịnabata dịka onyinye maka iji ya chụọ aja nye \nd Onyenwe anyị\nd*, a ga-akpụtara onye nchụaja anụ ụlọ ahụ.
\v 12 Ọ bụ ya ka ọ dịrị ikpebi ma anụ ụlọ ahụ ọ dị mma, ma ọ jọrọ njọ. Ọnụ ego ọbụla onye nchụaja kpebiri, ka onye wetara anụ ụlọ ahụ ga-akwụ.
\v 13 Ọ bụrụ na onye nwe anụ ụlọ ahụ achọọ ịgbara ya, ọ ga-akwụ ụgwọ anụ ụlọ ahụ, tụkwasịkwa nʼelu ya otu ụzọ nʼime ụzọ ise nke ọnụahịa anụ ụlọ ahụ.
\p 
\v 14 “ ‘Ọ bụrụ na mmadụ enye ụlọ ya, dịka ihe ga-adị nsọ nye \nd Onyenwe anyị\nd*, onye nchụaja ga-ekpebi maọbụ ụlọ dị mma, ma ọ bụkwanụ ụlọ jọrọ njọ. Ọ ga-ekwukwa ihe bụ ọnụahịa ụlọ ahụ.
\v 15 Ọ bụrụ na onye ahụ nke na-edo ụlọ ya nsọ achọọ ịgbara ya, ọ ga-akwụ ọnụahịa ụlọ ahụ, tụkwasịkwa nʼelu ya otu ụzọ nʼime ụzọ ise nke ọnụahịa ụlọ ahụ. Emesịa, ụlọ ahụ ga-abụkwa nke ya.
\p 
\v 16 “ ‘Ọ bụrụ na mmadụ ewere mpaghara ala ubi ezinaụlọ ya nye \nd Onyenwe anyị\nd* ka ihe ido nsọ, ihe a ga-eji mata ọnụahịa ala ahụ ga-abụ ụdị ihe ubi e nwere ike ịkụ nʼime ya. Ọnụahịa ala ubi e nwere ike ịkụnye ọka balị ruru otu ihe ọtụtụ homa, ga-abụ iri mkpụrụ ego ọlaọcha shekel ise.
\v 17 Ọ bụrụ nʼime afọ inwere onwe ka o doro ala ahụ nsọ, agaghị agbanwe ọnụahịa ya.
\v 18 Ma ọ bụrụ na o doro ala ahụ nsọ mgbe afọ inwe onwe ahụ gafere, onye nchụaja ga-agụkọrọ ya ọnụahịa ya dịka afọ ole ọ fọdụrụ mgbe mmemme afọ inwere onwe ọzọ ga-adị. A ga-ewebilatakwa ihe ọnụahịa ya ruru.
\v 19 Ọ bụrụ na onye doro ala ahụ nsọ achọọ ịgbara ala ya, ọ ga-akwụ ọnụahịa ahụ onye nchụaja kpebiri, tụkwasị ya ego ruru otu ụzọ nʼime ụzọ ise nke ọnụahịa ala ahụ. Mgbe ahụ ala ahụ ga-abụkwa nke ya.
\v 20 Ọ bụrụ na ọ gbapụtaghị ala ahụ, maọbụ na o resila ya onye ọzọ, a gaghị agbapụtakwa ala ahụ ọzọ.
\v 21 Mgbe mmemme afọ inwere onwe ruru, ala ahụ ga-aghọ ala dị nsọ, ala e doro nsọ nye \nd Onyenwe anyị\nd*. Ndị nchụaja ga-ewere ya ka ọ bụrụ nke ha.
\p 
\v 22 “ ‘Ọ bụrụ na mmadụ e doro \nd Onyenwe anyị\nd* ala ubi ọ zụrụ azụ nsọ, nke na-abụghị ala ezinaụlọ ha,
\v 23 onye nchụaja ga-agụ afọ ole ọ fọdụrụ ruo mmemme afọ inwere onwe. Ọ ga-agwa onye ahụ ego ole ọ ga-akwụ nʼihi ya. Ego ọbụla ọ kwụrụ nʼụbọchị ahụ ga-abụ ihe dị nsọ nye \nd Onyenwe anyị\nd*.
\v 24 Mgbe afọ inwere onwe ahụ zuru, onye nwe ala ahụ, ya bụ onye ahụ e si nʼaka ya zụọ ya, ga-ewerekwa ala ya.
\v 25 Ọnụahịa ọbụla a ga-ekpebi ga-abụ nʼusoro dịka shekel ebe nsọ si dị. Iri gera abụọ\f + \fr 27:25 \ft \xt Ọpụ 30:13\xt*\f* ga-abụ otu shekel.
\p 
\v 26 “ ‘A gaghị edo nwa mbụ anụmanụ mụtara nsọ maọbụ ehi maọbụ atụrụ nʼihi na ha bụ nke \nd Onyenwe anyị\nd*.
\v 27 Ọ bụrụ otu nʼime anụ ndị ahụ rụrụ arụ, a ga-agbara ya nʼọnụ ego nke akara bụ ọṅụ ahịa ya, tụkwasịkwa nʼelu ya otu ụzọ nʼime ụzọ ise nke ọnụahịa ya. Ọ bụrụkwanụ na onye nwe anụ ụlọ ahụ achọghị ịgbarakwa ya, a ga-ere ya nʼọnụ ahịa dịka o ruru.
\p 
\v 28 “ ‘A gaghị ere, maọbụ gbara ihe ọbụla mmadụ nwere, nke o doro nsọ\f + \fr 27:28 \ft \xt Jos 6:15-17\xt*\f* nye \nd Onyenwe anyị\nd*, maọbụ mmadụ, maọbụ ala ezinaụlọ, maọbụ anụ ụlọ, nʼihi na ihe ọbụla nke e wezugara iche bụ ihe dịkarịsịrị nsọ nye \nd Onyenwe anyị\nd*.
\p 
\v 29 “ ‘Mgbapụta ọbụla adịghị nye onye ọbụla e doro nsọ nye mbibi. A ghaghị ime ka ọ nwụọ.
\p 
\v 30 “ ‘Otu ụzọ nʼime ụzọ iri nke ihe niile si nʼala, maọbụ mkpụrụ ọghịgha nke ubi, maọbụ mkpụrụ nke osisi mịrị, bụ nke \nd Onyenwe anyị\nd*. Ha bụ ihe nsọ dịrị \nd Onyenwe anyị\nd*.
\v 31 Onye ọbụla chọrọ ịgbara otu ụzọ nʼime ụzọ iri nke ihe ubi ya aghaghị ịkwụ ọnụahịa ya, tụkwasị ya otu ụzọ nʼime ụzọ ise nke ọnụahịa e kwesiri ire ya.
\v 32 Otu ụzọ nʼụzọ iri nke igwe ehi na atụrụ niile, anụ nke iri ọbụla nke na-agabiga nʼokpuru mkpanaka onye ọzụzụ atụrụ mgbe a na-agụ ha ọnụ, ga-abụ ihe dị nsọ nye \nd Onyenwe anyị\nd*.
\v 33 A gaghị ahọ anụ ụlọ a na-enye \nd Onyenwe anyị\nd* ahọ, ile ma ha dị mma, maọbụ na ha dị njọ. A gaghị agbanwekwa ha. Ọ bụrụ na a gbanwee ha, ndị e ji gbanwee ha na ndị a na-achọ ịgbanwe ga-aghọ ihe dị nsọ, a gaghị agbarakwa ha.’ ”
\p 
\v 34 Ndị a bụ iwu \nd Onyenwe anyị\nd* nyere Mosis nʼugwu Saịnaị ka ọ nye ụmụ Izrel.
