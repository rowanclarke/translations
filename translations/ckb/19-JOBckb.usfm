\id JOB - Biblica® Open Kurdi Sorani Standard Version 
\h ئەیوب 
\toc1 ئەیوب 
\toc2 ئەیوب 
\toc3 ئەیوب 
\mt1 ئەیوب 
\c 1  
\s1 سەرەتا: ژیانی ئەیوب پێش تاقیکردنەوە 
\p  
\v 1 پیاوێک هەبوو لە خاکی عوچ ناوی ئەیوب بوو، کەسێکی ڕاست و بێ کەموکوڕی بوو، لەخواترس بوو، خۆی لە خراپە لا دەدا.  
\v 2 حەوت کوڕ و سێ کچی هەبوو.  
\v 3 مەڕوماڵاتەکەشی، حەوت هەزار مەڕ و سێ هەزار وشتر و پێنج سەد جووت مانگا و پێنج سەد ماکەر بوو، خزمەتکارەکانیشی زۆر زۆر بوون، ئەیوب لەنێو هەموو خەڵکی ڕۆژهەڵاتدا مەزنترین کەس بوو. 
\p  
\v 4 کوڕەکانیشی بە نۆرە هەر جارەی لە ماڵی یەکێکیان خوانیان ساز دەکرد، سێ خوشکەکەیان بانگهێشت دەکرد بۆ ئەوەی لەگەڵیان بخۆن و بخۆنەوە.  
\v 5 کاتێک کە ڕۆژانی خوان سازکردنەکە دەسووڕایەوە، ئەیوب بەدوایاندا دەینارد و پیرۆزی دەکردن، بۆ ڕۆژی پاشتر بەیانی زوو هەڵدەستا و بەپێی ژمارەیان قوربانی سووتاندنی پێشکەش دەکرد، چونکە ئەیوب دەیگوت: «ڕەنگە منداڵەکانم گوناهیان کردبێت و لە دڵیاندا نەفرەتیان لە خودا کردبێت.» ئەیوب بە بەردەوامی ئەم کارەی دەکرد. 
\s1 یەکەم تاقیکردنەوەی ئەیوب 
\p  
\v 6 ئەوە بوو ڕۆژێکیان فریشتەکان\f + \fr 1:6 \ft عیبری: کوڕانی خودا، لێرە و لە 2‏:1. بڕوانە \xt پەیدابوون 6‏:2‏\ft ‏.‏\f* هاتن بۆ ئەوەی لەبەردەم یەزدان بوەستن، شەیتانیش لەگەڵیان هات.  
\v 7 جا یەزدان بە شەیتانی فەرموو: «لەکوێوە هاتیت؟» 
\p شەیتانیش وەڵامی یەزدانی دایەوە: «لە گەڕان لەسەر زەوی و هاتوچۆکردن تێیدا.» 
\p  
\v 8 یەزدانیش بە شەیتانی فەرموو: «خۆ چاوت نەبڕیوەتە سەر ئەیوبی بەندەم؟ لە زەویدا کەس نییە وەک ئەو، کەسێکی وا ڕاست و بێ کەموکوڕی، لەخواترسە و لە خراپە لادەدات.» 
\p  
\v 9 شەیتانیش وەڵامی یەزدانی دایەوە: «ئایا ئەیوب بەخۆڕایی لەخواترسە؟  
\v 10 ئایا لەبەر ئەوە نییە کە تۆ لە دەوری خۆی و ماڵەکەی و هەرچی هەیەتی لە هەموو لایەکەوە پەرژینت لێ داوە؟ کارەکانی دەستی ئەوت بەرەکەتدار کردووە، جا مەڕوماڵاتی بەناو زەویدا بڵاو بووەتەوە،  
\v 11 بەڵام ئێستا دەست درێژبکە و لە هەموو ئەوە بدە کە هەیەتی، بزانە چۆن بەرەو ڕوو نەفرەتت لێ دەکات.» 
\p  
\v 12 جا یەزدان بە شەیتانی فەرموو: «ئەوەتا هەرچی هەیەتی لە دەستی تۆدایە، بەڵام دەست بۆ خۆی مەبە.» 
\p ئینجا شەیتان لەبەردەم یەزدان چووە دەرەوە. 
\p  
\v 13 ئەوە بوو ڕۆژێکیان کوڕ و کچەکانی لە ماڵی برا گەورەکەیان دەیانخوارد و شەرابیان دەخواردەوە.  
\v 14 نێردراوێک بۆ لای ئەیوب هات و گوتی: «مانگاکان جووتیان دەکرد و ماکەرەکانیش لەلایانەوە دەلەوەڕان،  
\v 15 سەبئییەکان بەسەریاندا دان و بردیانن، خزمەتکارەکانیان دایە بەر شمشێر، تەنها من دەرباز بووم هەتا هەواڵت بدەمێ!» 
\p  
\v 16 هێشتا ئەم قسەی دەکرد، یەکێکی دیکە هات و گوتی: «ئاگری خودا لە ئاسمانەوە هاتە خوارەوە و مەڕەکان و خزمەتکارەکانی سووتاند، تەنها من دەرباز بووم هەتا هەواڵت بدەمێ!» 
\p  
\v 17 هێشتا ئەم قسەی دەکرد، یەکێکی دیکە هات و گوتی: «کلدانییەکان بە سێ کۆمەڵەوە پەلاماری وشترەکانیان دا و بردیانن، خزمەتکارەکانیان دایە بەر شمشێر، تەنها من دەرباز بووم هەتا هەواڵت بدەمێ!» 
\p  
\v 18 هێشتا ئەم قسەی دەکرد، یەکێکی دیکە هات و گوتی: «کوڕ و کچەکانت لە ماڵی برا گەورەکەیان دەیانخوارد و شەرابیان دەخواردەوە،  
\v 19 لەناکاو بایەکی بەهێز لە چۆڵەوانییەوە هات و لە هەر چوار گۆشەی ماڵەکەی دا و ماڵەکە بەسەر خزمەتکارەکاندا داڕما و مردن، تەنها من دەرباز بووم هەتا هەواڵت بدەمێ!» 
\p  
\v 20 جا ئەیوب هەستا و کەواکەی دادڕی و سەری خۆی ڕنییەوە و کەوتە سەر زەوی و کڕنۆشی برد،  
\v 21 گوتی: 
\q1 «بە ڕووتی لە سکی دایکمەوە هاتووم و 
\q2 بە ڕووتیش دەگەڕێمەوە ئەوێ. 
\q1 یەزدان دای و یەزدانیش بردییەوە، 
\q2 ستایش بۆ ناوی یەزدان.» 
\p  
\v 22 لەگەڵ هەموو ئەمانەشدا ئەیوب گوناهی نەکرد و خودای خەتابار نەکرد. 
\b  
\c 2  
\s1 دووەم تاقیکردنەوەی ئەیوب 
\p  
\v 1 ئەوە بوو ڕۆژێکیان فریشتەکان هاتن بۆ ئەوەی لەبەردەم یەزدان بوەستن، شەیتانیش لەگەڵیان هات.  
\v 2 یەزدان بە شەیتانی فەرموو: «لەکوێوە هاتیت؟» 
\p شەیتانیش وەڵامی یەزدانی دایەوە: «لە گەڕان لەسەر زەوی و هاتوچۆکردن تێیدا.» 
\p  
\v 3 جا یەزدان بە شەیتانی فەرموو: «خۆ چاوت نەبڕیوەتە سەر ئەیوبی بەندەم؟ لە زەویدا کەس نییە وەک ئەو، کەسێکی وا ڕاست و بێ کەموکوڕی، لەخواترسە و لە خراپە لادەدات. هەتا ئێستاش پابەندە بەوەی کەسێکی دروست بێت، هەرچەندە هانت دام بۆ ئەوەی بەبێ هۆ لووشی بدەم.» 
\p  
\v 4 شەیتانیش وەڵامی یەزدانی دایەوە: «پێست بە پێست! مرۆڤ هەرچی هەبێت بۆ ڕزگارکردنی ژیانی خۆی دەیدات.  
\v 5 بەڵام ئێستا دەست درێژبکە و لە ئێسک و گۆشتی خۆی بدە، بزانە چۆن بەرەو ڕوو نەفرەتت لێ دەکات.» 
\p  
\v 6 یەزدانیش بە شەیتانی فەرموو: «ئەوەتا لەبەردەستی خۆتدایە، بەڵام ژیانی بپارێزە.» 
\p  
\v 7 ئیتر شەیتان لەبەردەم یەزدان چووە دەرەوە و ئەیوبی تووشی برینی پیس کرد، لە بنی پێیەوە هەتا تەپڵی سەری.  
\v 8 ئەویش پارچە گۆزەیەکی بۆ خۆخوراندن لەدەست گرت و لەناو خۆڵەمێش دانیشتبوو. 
\p  
\v 9 ژنەکەی پێی گوت: «ئایا هەتا ئێستاش هەر پابەندیت بە دروستییەکەتەوە؟ نەفرەت لە خودا بکە و بمرە!» 
\p  
\v 10 ئەویش پێی گوت: «وەک نەزانێک قسە دەکەیت، ئایا چاکەی خودا قبوڵ بکەین، بەڵام نەهامەتی قبوڵ نەکەین؟» 
\p لە هەموو ئەمەدا ئەیوب گوناهی بەسەر لێودا نەهات. 
\b  
\s1 سێ هاوڕێکەی ئەیوب 
\p  
\v 11 سێ هاوڕێکەی ئەیوب هەموو ئەو نەهامەتییانەیان بیست کە بەسەر ئەیوب هاتووە، جا هەریەکە لە جێی خۆیەوە هات، ئەلیفازی تێمانی و بیلدەدی شوحی و چۆفەری نەعماتی، ڕێککەوتن لەسەر ئەوەی بێن و دڵنەوایی بکەن و دڵی بدەنەوە.  
\v 12 کاتێک لە دوورەوە چاویان هەڵبڕی، نەدەناسرایەوە. دەنگیان بەرزکردەوە و گریان، هەریەکە کەواکەی خۆی دادڕی و بەرەو ئاسمان خۆڵیان بەسەر خۆیاندا کرد.  
\v 13 لەسەر زەوی لەگەڵی دانیشتن، حەوت ڕۆژ و حەوت شەو، کەسیش بە وشەیەک نەیدوواند، چونکە بینییان خەمۆکیەکەی لە ڕادەبەدەرە. 
\c 3  
\s1 ئەیوب قسە دەکات 
\p  
\v 1 دوای ئەمە ئەیوب دەمی کردەوە و نەفرەتی لەو ڕۆژە کرد کە تێیدا لەدایک بووە.  
\v 2 ئەیوب دەستی بە قسە کرد و گوتی: 
\q1  
\v 3 «با لەناوبچێت ئەو ڕۆژەی تێیدا لەدایک بووم، 
\q2 ئەو شەوەش کە گوترا: ”کوڕێک لەدایک بوو!“ 
\q1  
\v 4 با ئەو ڕۆژە تاریک بێت، 
\q2 نە خودا لە سەرەوە بایەخی پێ بدات و 
\q2 نە ڕۆژی بەسەردا هەڵبێت. 
\q1  
\v 5 با تاریکی و سێبەری مەرگ لەسەری بێت، 
\q2 با هەور دایبگرێت، 
\q2 با ڕۆژ تاریک دابێت و بیتۆقێنێت. 
\q1  
\v 6 ئەو شەوە، با شەوەزەنگ بیگرێت، 
\q2 لەناو ڕۆژانی ساڵ دڵخۆش نەبێت 
\q2 نەیەتە ناو ژمارەی مانگەکان. 
\q1  
\v 7 با ئەو شەوە نەزۆک بێت، 
\q2 هاواری خۆشی تێدا نەبێت. 
\q1  
\v 8 بەر نەفرەتی ئەوانە بکەوێت کە نەفرەت لە ڕۆژگار دەکەن، 
\q2 ئەوانەی ئامادەن لیڤیاتان بەئاگا بهێنن. 
\q1  
\v 9 با ئەستێرەکانی بەرەبەیان تاریک دابێن، 
\q2 چاوەڕوانی ڕووناکی بێت و نەیەت، 
\q2 با گزنگی بەیان نەبینێت، 
\q1  
\v 10 چونکە دەرگاکانی سکی لەسەر من دانەخست و 
\q2 چەرمەسەری لە چاوەکانم نەشاردەوە. 
\b  
\q1  
\v 11 «بۆ لە بار دایکم نەچووم، 
\q2 کە لەدایک بووم، بۆ ڕۆحم بەدەستەوە نەدا؟ 
\q1  
\v 12 بۆچی ئەژنۆکان هەڵیانگرتم، 
\q2 بۆ مەمک هەبوو تاکو شیر بدرێم؟ 
\q1  
\v 13 چونکە ئێستا ڕاکشابووم و بێدەنگ ببووم، 
\q2 ئەو کاتە بە ئاسوودەیی دەخەوتم، 
\q1  
\v 14 لەگەڵ پاشایان و ڕاوێژکارانی زەوی، 
\q2 ئەوانەی ئەو کۆشکانەیان بۆ خۆیان بنیاد نا کە ئێستا بوونەتە کەلاوە، 
\q1  
\v 15 یان لەگەڵ میران کە زێڕیان هەیە، 
\q2 ئەوانەی ماڵەکانیان لە زیو پڕکردووە، 
\q1  
\v 16 یان وەک لەبارچووێکی لەخاکنراو، ئینجا نەدەبووم، 
\q2 وەک کۆرپەیەک ڕووناکی نەبینیوە. 
\q1  
\v 17 لەوێ خراپەکاران لە ئاژاوەنانەوە دەوەستن 
\q2 لەوێ ماندووان پشوو دەدەن، 
\q1  
\v 18 دیلەکان تێکڕا ئاسوودە دەبن، 
\q2 گوێیان لە دەنگی سەرکار نابێت، 
\q1  
\v 19 لەوێ بچووک وەک گەورە وایە، 
\q2 کۆیلەش ئازادە لە دەستی گەورەکەی. 
\b  
\q1  
\v 20 «بۆ ڕووناکی دەدرێتە ڕەنجدەران و 
\q2 ژیانیش بۆ ئەوەی تاڵاوی تێدایە، 
\q1  
\v 21 ئەوانەی چاوەڕوانی مردن دەکەن و نییە، 
\q2 لە گەنجینە زیاتر بەدوایدا دەگەڕێن، 
\q1  
\v 22 هەتا ئەوپەڕی شادمانی دڵخۆشن، 
\q2 دڵشادن کە گۆڕێک دەبیننەوە؟ 
\q1  
\v 23 بۆ ژیان دەدرێتە پیاوێک 
\q2 کە ڕێگای شاردراوەتەوە، 
\q2 خوداش بە چواردەوریدا پەرژینی لێ داوە؟ 
\q1  
\v 24 لەبەر ئەوەی ئاخ هەڵکێشانم بووەتە نانی ڕۆژانەم، 
\q2 هەنسکیشم وەک ئاو دەڕژێت. 
\q1  
\v 25 ئەوەی دەمتۆقێنێت هاتە سەر ڕێگام، 
\q2 ئەوەی لێی دەترسام بەسەرم هات. 
\q1  
\v 26 ئاسوودە نەبووم و بێدەنگ نەبووم، 
\q2 پشووم نەدا و ئاژاوە هات.» 
\c 4  
\s1 وەڵامی یەکەمی ئەلیفاز 
\p  
\v 1 ئینجا ئەلیفازی تێمانی وەڵامی دایەوە: 
\q1  
\v 2 «ئەگەر یەکێک قسەیەک بکات دڵگران دەبیت؟ 
\q2 بەڵام کێ دەتوانێت لە قسەکردن ڕابوەستێت؟ 
\q1  
\v 3 لە یادت بێ تۆ ڕێنمایی زۆر کەست کردووە و 
\q2 دەستە شلبووەکانت توند کردووە. 
\q1  
\v 4 قسەکانت ئەوانەی هەستاندەوە کە کەوتوون و 
\q2 ئەژنۆ لەرزۆکەکانت چەسپاند. 
\q1  
\v 5 بەڵام ئێستا کە خۆت تووشی تەنگانە بوویت، ورەت بەرداوە، 
\q2 لەوەی کە بەسەر خۆت هاتووە، پەرێشان بوویت. 
\q1  
\v 6 ئایا پشت بە لەخواترسییەکەت نابەستیت؟ 
\q2 ئایا بێ کەموکوڕییەکەت هیوابەخش نییە؟ 
\b  
\q1  
\v 7 «بەبیر خۆتی بهێنەرەوە، بێتاوانێکت بینیوە فەوتابێت، 
\q2 یاخود کەسە سەرڕاستەکان لەناوچووبن؟ 
\q1  
\v 8 وەک بینیوتە، ئەوانەی خراپە دەکێڵن و 
\q2 چەرمەسەری دەچێنن، خۆیان دروێنەی دەکەن. 
\q1  
\v 9 بە هەناسەی خودا لەناودەچن و 
\q2 بە بای تووڕەییەکەی نامێنن. 
\q1  
\v 10 مڕەمڕی شێر و دەنگی نەڕەی و 
\q2 کەڵبەی شێرەکان شکێنران. 
\q1  
\v 11 شێر دەفەوتێت لەبەر نەبوونی نێچیر و 
\q2 بەچکەی شێرەکە پەرتەوازە دەبن. 
\b  
\q1  
\v 12 «وشەیەک بۆ لای من دزەی کرد، 
\q2 گوێم چرپەیەکی بیست. 
\q1  
\v 13 لە مۆتەکەی\f + \fr 4:13 \ft خەونێکی ناخۆش.‏\f* شەومدا 
\q2 کاتێک مرۆڤ خەوێکی قووڵ دەیباتەوە، 
\q1  
\v 14 ترس و تۆقینێک منی داگرت و 
\q2 هەموو ئێسکەکانم لەرزین. 
\q1  
\v 15 ڕۆحێک بە بەردەممدا تێپەڕی و 
\q2 مووەکانی لەشم مووچڕکەیان پێدا هات. 
\q1  
\v 16 ڕاوەستا، 
\q2 بەڵام نەمزانی چی بوو، 
\q1 شێوەیەک لەبەرچاوم بوو، 
\q2 چرپەیەک و دەنگێکم بیست: 
\q1  
\v 17 ”ئایا مرۆڤ لە خودا ڕاستودروستترە، 
\q2 یان پیاو لە بەدیهێنەرەکەی بێگەردتر دەبێت؟ 
\q1  
\v 18 ئەگەر خودا متمانە بە خزمەتکارەکانی نەکات و 
\q2 گومڕایی بخاتە پاڵ فریشتەکانی، 
\q1  
\v 19 ئەی چەند زیاتر متمانە بە دانیشتووانی ناو خانووی قوڕ ناکات، 
\q2 ئەوانەی بنەچەیان لە خۆڵەوەیە و 
\q2 وەک مۆرانە پان دەکرێنەوە. 
\q1  
\v 20 لەنێوان بەیانی و ئێوارەدا تێکدەشکێنرێن، 
\q2 بێ ئەوەی کەس ئاگای لێیان بێت بۆ هەتاهەتایە لەناودەچن. 
\q1  
\v 21 ئایا گوریسی ڕەشماڵەکانیان هەڵنەکێشراوە، 
\q2 تاکو بەبێ دانایی بمرن؟“ 
\b  
\c 5  
\q1  
\v 1 «ئێستا بانگ بکە، بزانە کێ وەڵامت دەداتەوە؟ 
\q2 ڕوو لە کام لە پیرۆزان دەکەیت؟ 
\q1  
\v 2 قین گێل دەکوژێت و 
\q2 بەغیلیش ساویلکە دەمرێنێت. 
\q1  
\v 3 من گێلێکم بینی ڕەگی داکوتا، 
\q2 بەڵام لەناکاو ماڵەکەی بە نەفرەت کرا: 
\q1  
\v 4 با کوڕەکانی لە ئاسوودەیی بەدوور بن، 
\q2 لە دادگا تێکبشکێنرێن و کەس فریایان نەکەوێت. 
\q1  
\v 5 دروێنەکەیان کەسانی برسی دەیخۆن، 
\q2 ئەگەر لەناو دڕکیش بێت هەر دەیبەن، 
\q2 تینووش سامانەکەی هەڵدەقورتێنێت، 
\q1  
\v 6 چونکە بەڵا لەناو خۆڵەوە دەرناچێت و 
\q2 چەرمەسەریش لە زەوییەوە ناڕووێت. 
\q1  
\v 7 بەڵام مرۆڤ بۆ چەرمەسەری لەدایک دەبێت، 
\q2 وەک چۆن پریشکی ئاگر هەڵدەستێت. 
\b  
\q1  
\v 8 «بەڵام ئەگەر من لە جێی تۆ بوومایە داوام لە خودا دەکرد و 
\q2 کێشەی خۆمم دەدایە دەست ئەو. 
\q1  
\v 9 ئەوەی کارە مەزنەکانی کردووە کە ناپشکێنرێن و 
\q2 کارە سەرسوڕهێنەرەکان کە لە ژماردن نایەن. 
\q1  
\v 10 ئەوەی باران بەسەر ڕووی زەویدا دەبارێنێت و 
\q2 ئاو بۆ سەر ڕووی دەشتودەر دەنێرێت. 
\q1  
\v 11 ئەوەی بێفیزەکان بەرزدەکاتەوە، 
\q2 هەروەها خەمبارەکان بەرەو دڵنیایی دەبات. 
\q1  
\v 12 ئەو تەگبیری تەڵەکەبازان پووچ دەکاتەوە 
\q2 بۆ ئەوەی هیچ کارێک لەسەر دەستی ئەوان سەرکەوتوو نەبێت. 
\q1  
\v 13 ئەوەی داناکان بە فێڵبازی خۆیانەوە دەگرێت، 
\q2 ڕاوێژی تەڵەکەبازان ڕادەماڵێت. 
\q1  
\v 14 لە ڕۆژدا تاریکی بەسەریاندا دێت، 
\q2 لە نیوەڕۆشدا بە پەلکوتان دەڕۆن وەک بە شەو. 
\q1  
\v 15 ئەو نەدار لە دەمی خراپەکار و 
\q2 لە دەستی ستەمکار ڕزگار دەکات. 
\q1  
\v 16 جا زەلیل بە هیوا دەبێت و 
\q2 ناڕەوا دەمی دادەخات. 
\b  
\q1  
\v 17 «سەرزەنشتکردن لەلایەن خوداوە بەرەکەتە، 
\q2 لەبەر ئەوە تەمبێکردنی خودای هەرە بەتوانا ڕەت مەکەرەوە. 
\q1  
\v 18 لەبەر ئەوەی ئەو بریندار دەکات و برینیش ساڕێژ دەکات، 
\q2 وردوخاش دەکات و بە دەستەکانی خۆی دەیگرێتەوە. 
\q1  
\v 19 لە شەش بەڵا ڕزگارت دەکات و 
\q2 لە حەوتەمیش خراپەت لێ ناکەوێت. 
\q1  
\v 20 لە قاتوقڕیدا لە مردن دەتکڕێتەوە و 
\q2 لە جەنگیشدا لە دەمی شمشێر. 
\q1  
\v 21 لە خەنجەری زمان پارێزراو دەبیت، 
\q2 کە وێرانە ڕووت تێ دەکات ناترسیت. 
\q1  
\v 22 بە وێرانی و قاتوقڕی پێدەکەنیت و 
\q2 لە ئاژەڵە دڕندەکان ناترسیت، 
\q1  
\v 23 چونکە لەگەڵ بەردەکانی دەشتودەر پەیمانت دەبێت و 
\q2 ئاژەڵە کێوییەکان ئاشتیت لەگەڵ دەبەستن. 
\q1  
\v 24 جا دەزانیت کە ڕەشماڵەکەت سەلامەتە و 
\q2 سەرژمێری ماڵەکەت دەکەیت و هیچت ون نەبووە. 
\q1  
\v 25 ئەو کاتە دەزانیت کە منداڵت چەند زۆر دەبن و 
\q2 نەوەکانت وەک گیای زەوی دەبن. 
\q1  
\v 26 لەوپەڕی تەندروستیدا دەچیتە ناو گۆڕەوە 
\q2 وەک هەڵگرتنی کۆڵێک لە کاتی خۆیدا. 
\b  
\q1  
\v 27 «ئێمە لەمە وردبووینەوە و بینیمان کە ڕاستە، 
\q2 جا تۆش گوێ بگرە و لە ژیانی خۆتدا پەیڕەوی بکە.» 
\c 6  
\s1 قسەی دووەمی ئەیوب 
\p  
\v 1 ئەیوبیش وەڵامی دایەوە: 
\q1  
\v 2 «خۆزگە دەتوانرا خەم و پەژارەکەم بکێشن و 
\q2 هەموو دەرد و بەڵاکەم بخەنە تای تەرازووەوە! 
\q1  
\v 3 بێگومان لە لمی دەریا قورستر دەبوو، 
\q2 لەبەر ئەوە بە هەڵەشەیی قسەم کرد. 
\q1  
\v 4 تیرەکانی خودای هەرە بەتوانا لە مندان و 
\q2 ڕۆحم لە ژەهراوەکەیان دەخواتەوە؛ 
\q2 بەڵا تۆقێنەرەکانی خودا لە دژی من ڕیزیان بەستووە. 
\q1  
\v 5 ئایا کەرەکێوی کە گیای هەبێت دەزەڕێنێت، 
\q2 یان گا لەسەر ئالیکەکەی دەقۆڕێنێت؟ 
\q1  
\v 6 ئایا خواردنێکی بێ تام بەبێ خوێ دەخورێت، 
\q2 یان لینجاوی پاڵپینە تامی هەیە؟ 
\q1  
\v 7 من قێز لەو خواردنانە دەکەمەوە، 
\q2 نەفسم ڕەتیان دەکاتەوە دەستیان لێ بدەم. 
\b  
\q1  
\v 8 «خۆزگە داواکارییەکەم دەهاتە دی و 
\q2 ئەوەی چاوەڕێم دەکرد خودا پێی دەدام، 
\q1  
\v 9 کە خودا ڕازی بێت وردوخاشم بکات و 
\q2 دەستی لێم بکاتەوە تاوەکو ژیانم ببڕێتەوە! 
\q1  
\v 10 هەرچەندە ئازارەکانم دەستم لێ ناپارێزن، 
\q2 بەڵام هەتا ئێستاش دڵنەواییەکەم ئەمەیە، 
\q2 کە نکۆڵیم لە وشەکانی خودا پیرۆزەکە نەکردووە. 
\b  
\q1  
\v 11 «هێزی من چییە هەتا چاوەڕوان بم و 
\q2 کۆتاییم چییە هەتا دانبەخۆمدا بگرم؟ 
\q1  
\v 12 ئایا هێزم هێزی بەردە؟ 
\q2 یان گۆشتم بڕۆنزە؟ 
\q1  
\v 13 سەرکەوتن لە من دوور کەوتووەتەوە، 
\q2 ئایا هیچ لە دەسەڵاتی مندا هەیە؟ 
\b  
\q1  
\v 14 «ئەگەر کەسێک خۆشەویستی بۆ هاوڕێکەی دەرنەبڕێت، 
\q2 ئەوا ڕێزی خودای هەرە بەتواناشی نەگرتووە. 
\q1  
\v 15 بەڵام براکانم وەک جۆگەی ئاو پشتیان لێکردم، 
\q2 وەک جۆگەی ناو دۆڵەکان پڕن و بەسەر کەنارەکانیاندا دەڕژێن. 
\q1  
\v 16 کاتێک لێڵن لەبەر شەختە 
\q2 بەفر تێیاندا دەتوێتەوە، 
\q1  
\v 17 بەڵام کە دەڕۆن کۆتاییان پێ دێت، 
\q2 کە گەرما داهات لە شوێنی خۆیان وشک دەبن. 
\q1  
\v 18 کاروانەکان لە ڕێگای خۆیان لا دەدەن، 
\q2 دەچنە ناو چۆڵەوانی و لەناودەچن. 
\q1  
\v 19 کاروانەکانی تێما بۆی دەگەڕێن، 
\q2 بازرگانەکانی شەبا هیوادارن کە بیدۆزنەوە، 
\q1  
\v 20 کە هاتنە لای بێ ئومێد بوون، 
\q2 بێزار بوون، چونکە متمانەیان پێی کردبوو. 
\q1  
\v 21 ئێستا ئێوەش وەک ئەوتان لێهاتووە، سوودتان نییە، 
\q2 بینیتان کە چیم بەسەرهاتووە ئێوە تۆقین. 
\q1  
\v 22 ئایا هیچ کاتێک پێم گوتن: ”لە پێناوی من شتێک بدەن، 
\q2 بە سامانی خۆتان بمکڕنەوە، 
\q1  
\v 23 لە دەستی دوژمن دەربازم بکەن، 
\q2 لە دەستی ستەمکار بمکڕنەوە؟“ 
\b  
\q1  
\v 24 «فێرم بکەن، من بێدەنگ دەبم، 
\q2 تێمبگەیەنن لە چ شتێک گومڕا بووم! 
\q1  
\v 25 ئای، قسەی ڕاست چەند بریندارکەرە! 
\q2 بەڵام ئەو بەڵگانەی کە دەیانهێننەوە چی دەسەلمێنن؟ 
\q1  
\v 26 ئایا لەسەر قسەکانم سەرزەنشتم دەکەن، 
\q2 ئەوەی دەیڵێم بە با دەڕوات؟ 
\q1  
\v 27 بەڵکو ئێوە هەتیو دەفرۆشن و 
\q2 چاڵ بۆ هاوڕێی خۆتان هەڵدەکەنن. 
\b  
\q1  
\v 28 «ئێستا باش تێم بڕوانن، 
\q2 چونکە من لە ڕووی ئێوەدا درۆ ناکەم. 
\q1  
\v 29 تکایە پاشگەز بنەوە! ستەمم لێ مەکەن، 
\q2 ئەگینا ڕاستودروستییەکەم دەخەنە گومانەوە. 
\q1  
\v 30 ئایا بەدکاری لەسەر زاری منە، 
\q2 یان زمانم تامی خراپەکاری جیا ناکاتەوە؟ 
\b  
\c 7  
\q1  
\v 1 «ئایا ژیانی مرۆڤ لەسەر زەوی خزمەتکردن و ڕەنجکێشان نییە، 
\q2 ڕۆژانیشی وەک ڕۆژانی ڕەنجدەرێک نییە؟ 
\q1  
\v 2 وەک چۆن کۆیلە تامەزرۆی سێبەرە و 
\q2 کرێکاریش چاوەڕێی کرێیەکەیەتی، 
\q1  
\v 3 ئاواش مانگەکانی بێ ئومێدی بۆم بوون بە میرات و 
\q2 شەوانی چەرمەسەری بوون بە بەشم. 
\q1  
\v 4 کە دەچمە سەر جێگاکەم دەڵێم: ”کەی بێت هەستم،“ 
\q2 شەو درێژە دەکێشێت و هەتا بەرەبەیان ئەم دیو و ئەو دیو دەکەم. 
\q1  
\v 5 گۆشتم کرم و قەتماغە پۆشیویەتی، 
\q2 پێستم شەقار بووە و کێمی کردووە. 
\b  
\q1  
\v 6 «ڕۆژگارم لە تەون خێراترە و 
\q2 بێ هیوا کۆتایی دێت. 
\q1  
\v 7 ئەی خودا، لە یادت نەچێت کە ژیانم هەناسەیەکە و 
\q2 ئیتر چاوەکانم خۆشی نابینن. 
\q1  
\v 8 ئەو چاوەی کە ئێستا دەمبینێت لەمەودوا نامبینێت، 
\q2 چاوت بڕیوەتە من، بەڵام من بوونم نابێت. 
\q1  
\v 9 هەور پەرت دەبێت و نامێنێت، 
\q2 بە هەمان شێوە ئەوەی دادەبەزێتە ناو جیهانی مردووان سەرناکەوێتەوە. 
\q1  
\v 10 ئیتر ناگەڕێتەوە ماڵەکەی خۆی و 
\q2 دەوروپشتی لە یادی دەکەن. 
\b  
\q1  
\v 11 «لەبەر ئەوە منیش دەمم ناگرم، 
\q2 لە تەنگی ڕۆحمەوە قسە دەکەم، 
\q2 لە دڵشکاویمەوە سکاڵا دەکەم. 
\q1  
\v 12 بۆچی پاسەوانت لەسەر داناوم؟ 
\q2 ئایا من دەریام یان ئەژدیهام؟ 
\q1  
\v 13 ئەگەر بڵێم نوێنەکەم دڵنەواییم دەداتەوە، 
\q2 جێگاکەم دڵتەنگییەکەم دەڕەوێنێتەوە، 
\q1  
\v 14 بە خەون دەمترسێنیت و 
\q2 بە مۆتەکە دەمتۆقێنیت. 
\q1  
\v 15 لەبەر ئەوە گیانم خنکان هەڵدەبژێرێت، 
\q2 مردنم پێ باشترە لەم پەیکەرە ئێسکە. 
\q1  
\v 16 توامەوە، بۆ هەتاهەتایە ناژیم، 
\q2 وازم لێ بهێنە، چونکە ڕۆژگارم هیچ واتایەکی نییە. 
\b  
\q1  
\v 17 «مرۆڤ چییە هەتا بایەخی پێبدەیت و 
\q2 هەتا بیری خۆتی پێوە خەریک بکەی، 
\q1  
\v 18 هەموو بەیانییەک بەسەری بکەیتەوە و 
\q2 هەموو ساتێک تاقی بکەیتەوە؟ 
\q1  
\v 19 هەتا کەی ڕووت لێم وەرناگێڕیت و 
\q2 مۆڵەتم نادەیتێ هەتا تفەکەم قووت بدەم؟ 
\q1  
\v 20 ئەگەر گوناهیشم کردبێت، 
\q2 کە تۆ چاودێری مرۆڤیت، 
\q2 ئایا هیچ کاردانەوەیەکی لەسەر تۆ هەبووە؟ 
\q1 بۆچی منت کردووە بە نیشانەی تیری خۆت؟ 
\q2 ئایا بووم بە بار بەسەر تۆوە؟ 
\q1  
\v 21 ئەی بۆ لە یاخیبوونم خۆش نابیت و 
\q2 تاوانم ناسڕیتەوە؟ 
\q1 چونکە بەم نزیکانە لەناو خاکدا ڕادەکشێم و 
\q2 بەدوامدا دەگەڕێیت، بەڵام من بوونم نابێت.» 
\c 8  
\s1 وەڵامی یەکەمی بیلدەد 
\p  
\v 1 ئینجا بیلدەدی شوحی وەڵامی دایەوە: 
\q1  
\v 2 «هەتا کەی بەم شێوەیە قسە دەکەیت؟ 
\q2 ئەوەی لە دەمت دێتە دەرەوە ڕەشەبایە. 
\q1  
\v 3 ئایا خودا دادپەروەری بە لاڕێدا دەبات؟ 
\q2 ئایا توانادارەکە ڕاستودروستی بەدرۆدەخاتەوە؟ 
\q1  
\v 4 ئەو کاتەی ڕۆڵەکانت گوناهیان دەرهەق بە خودا کرد، 
\q2 ئەوا خودا سزای گوناهەکانی خۆیانی بەسەر هێنانەوە. 
\q1  
\v 5 بەڵام ئەگەر تۆ بەیانییان زوو ڕوو لە خودا بکەیت، 
\q2 لە خودای هەرە بەتوانا بپاڕێیتەوە، 
\q1  
\v 6 ئەگەر تۆ بێگەرد و ڕاست بیت، 
\q2 ئەوا هەر ئێستا ئاوڕت لێ دەداتەوە و 
\q2 ماڵەکەی خۆتت وەک پاداشت بۆ دەگەڕێنێتەوە. 
\q1  
\v 7 پاشەڕۆژەکەت هێندە تێروتەسەل دەبێت، 
\q2 کە سەرەتاکەت زۆر هەژار بووە. 
\b  
\q1  
\v 8 «پرسیار لە نەوەی ڕابردوو بکە و 
\q2 بزانە لە باوباپیرانیانەوە چی فێربوون، 
\q1  
\v 9 چونکە ئێمە منداڵی دوێنێین و هیچ نازانین، 
\q2 ڕۆژگاریشمان لەسەر زەوی وەک سێبەر تێدەپەڕێت. 
\q1  
\v 10 ئایا ئەو نەوەیە فێرت ناکەن و پێت ناڵێن؟ 
\q2 یان بە بیری خۆیان قسەت لێ دەرناهێنن؟ 
\q1  
\v 11 ئایا زەل بەبێ زۆنگاو گەشە دەکات، 
\q2 یان قامیش بەبێ ئاو شین دەبێت؟ 
\q1  
\v 12 بەڵکو ئەوان کە هێشتا گەشە دەکەن و نەبڕدراون، 
\q2 کەچی پێش هەموو گیایەک وشک دەبن، 
\q1  
\v 13 بەو جۆرەیە سەرگوزەشتەی ژیانی هەموو ئەوانەی خودایان لەبیر کردووە و 
\q2 هیوای خوانەناسان لەناودەچێت. 
\q1  
\v 14 ئەوەی پاڵپشتەکەیەتی دەبڕدرێتەوە، 
\q2 پشتی بە تەونی جاڵجاڵۆکە بەستووە. 
\q1  
\v 15 خۆی بە تەونەکەوە ڕادەگرێت بەڵام دەپچڕێت، 
\q2 دەستی پێوە دەگرێت و خۆی ڕاناگرێت. 
\q1  
\v 16 ئەوانە وەک ڕووەکێکی تەڕ لەژێر تیشکی خۆردان، 
\q2 کە لەناو باخچەکەیدا چڵی تازە دەردەکات. 
\q1  
\v 17 بەسەر کۆمەڵە بەرددا ڕەگ دادەکوتێت و 
\q2 بە تاشەبەردەکانەوە خۆیان توند دەگرن. 
\q1  
\v 18 بەڵام کە لە شوێنی خۆی هەڵکەنرا، 
\q2 شوێنەکەی نکۆڵی لێ دەکات و دەڵێ: ”من جێگای تۆ نیم.“ 
\q1  
\v 19 ببینە، خۆشی ژیانەکەی تەنها ئەوەیە، 
\q2 کە لە جێگاکەیەوە یەکێکی دیکە چەکەرە دەکات. 
\b  
\q1  
\v 20 «بێگومان خودا ئەو کەسە ڕەت ناکاتەوە کە بێ کەموکوڕی بێت، 
\q2 کە هانی خراپەکاران نادات. 
\q1  
\v 21 کاتێک دەمت پڕ لە پێکەنین دەکات و 
\q2 لێوەکانت پڕ لە هوتاف، 
\q1  
\v 22 ناحەزانت شەرمەزاری لەبەر دەکەن و ڕەشماڵی 
\q2 خراپەکارانیش تەفروتوونا دەبن.» 
\c 9  
\s1 قسەی سێیەمی ئەیوب 
\p  
\v 1 ئەیوبیش وەڵامی دایەوە: 
\q1  
\v 2 «ڕاستە، دەزانم کە وایە. 
\q2 جا چۆن مرۆڤ لەبەرچاوی خودا ڕاستودروست دەبێت؟ 
\q1  
\v 3 ئەگەر بیەوێت مشتومڕی لەگەڵ بکات، 
\q2 ناتوانێت وەڵامی یەک لە هەزار بداتەوە. 
\q1  
\v 4 خودا داناییەکی فراوان و توانایەکی زۆری هەیە. 
\q2 کێ هەیە دژایەتی کردبێت و بە سەلامەتی دەرچووبێت؟ 
\q1  
\v 5 هەژێنەری چیاکانە بێ ئەوەی بەخۆیان بزانن، 
\q2 ئەوەی لە کاتی تووڕەییدا سەرەوژێریان دەکات. 
\q1  
\v 6 زەوی لە جێی خۆی لەق دەکات، 
\q2 جا کۆڵەکەکانی دەخاتە بوومەلەرزە. 
\q1  
\v 7 فەرمان بە خۆر دەدات، کە هەڵنەیەت، 
\q2 بە ئەستێرەکانیش کە نەدرەوشێنەوە. 
\q1  
\v 8 خۆی بە تەنها ئاسمانی لێک کردووەتەوە، 
\q2 بەسەر شەپۆلەکانی دەریادا ڕۆیشتووە. 
\q1  
\v 9 دروستکەری کەلووەکانی\f + \fr 9:9 \ft مەبەستی بورجەکانە، هەریەک لەمانە لە چەند ئەستێرەیەک پێکدێن.‏\f* ورچ و ڕاوچی و 
\q2 حەوتەوانە\f + \fr 9:9 \ft یەکێک لە کەلووەکانە.‏\f* و ئەو کەلووانەیە کە لە باشووری زەوی دەبینرێن. 
\q1  
\v 10 کاری مەزنی بەم جۆرەی کردووە کە لە سەرووی بیرکردنەوەن، 
\q2 هێندە پەرجوو\f + \fr 9:10 \ft پەرجوو: موعجیزە.‏\f* کە لە ژماردن نایەن. 
\q1  
\v 11 کاتێک بەسەرمدا دەڕوات نایبینم، 
\q2 کاتێک تێدەپەڕێت هەستی پێ ناکەم! 
\q1  
\v 12 ئەگەر شتێکمان لێ بستێنێت کێ دەتوانێت بەرەنگاری بێتەوە؟ 
\q2 کێ پێی دەڵێت: ”ئەوە چی دەکەیت؟“ 
\q1  
\v 13 خودا تووڕەیی خۆی ناگێڕێتەوە، 
\q2 یارمەتیدەرانی ڕەهەڤ\f + \fr 9:13 \ft هێمایە بۆ میسر‏\f* لە ژێریدا دەچەمێنەوە. 
\b  
\q1  
\v 14 «ئیتر من چۆن وەڵامی بدەمەوە و 
\q2 چۆن وشە هەڵبژێرم بۆ وەڵامدانەوەی؟ 
\q1  
\v 15 ئەگەر ڕاستودروستیش بم، ناتوانم وەڵامی بدەمەوە، 
\q2 بەڵکو داوای بەزەیی لە دادوەرم دەکەم. 
\q1  
\v 16 ئەگەر بانگی بکەم، ئەویش وەڵامم بداتەوە، 
\q2 باوەڕ ناکەم کە گوێی بۆ دەنگم شل بکات، 
\q1  
\v 17 بەڵکو ئەو بە زریان تێکمدەشکێنێت و 
\q2 بەبێ هۆ برینەکانم زۆر دەکات. 
\q1  
\v 18 ناهێڵێت هەناسە بدەم، 
\q2 بەڵام لە تاڵی تێرم دەکات. 
\q1  
\v 19 ئەگەر تاقیکردنەوەی هێز بێت، ئەو بەهێزترینە! 
\q2 ئەگەر کێشەی دادگا بێت، کێ دەتوانێت بانگی بکات؟ 
\q1  
\v 20 ئەگەر بێتاوان بم دەمم تاوانبارم دەکات، 
\q2 ئەگەر بێ کەموکوڕیش بم، دەیسەلمێنێت تاوانبارم. 
\b  
\q1  
\v 21 «هەرچەندە من بێ کەموکوڕیم، 
\q2 بەڵام بایەخ بە ژیانی خۆم نادەم؛ 
\q2 ڕقم لە ژیانم دەبێتەوە. 
\q1  
\v 22 ”خودا کۆتایی بە چاک و بە خراپ دەهێنێت.“ 
\q2 لەبەر ئەوە گوتم: بەلامەوە هەردووکیان وەک یەکن، 
\q1  
\v 23 ئەگەر کارەساتی لەناکاو مردن بهێنێت، 
\q2 بە نائومێدیی بێتاوان پێدەکەنێت. 
\q1  
\v 24 کە خاکێک درابێت بە دەست بەدکارەوە، 
\q2 ئەوا پەردە بەسەر ڕووی دادوەرەکانی دەدات، 
\q2 ئەگەر ئەو نەبێت، ئەی کێیە؟ 
\b  
\q1  
\v 25 «ڕۆژگارم خێراترە لە کەسێک کە ڕادەکات، 
\q2 گوزەر دەکات و چێژی لێ نابینم. 
\q1  
\v 26 وەک چۆن کەشتی زەل ڕووبار دەبڕێت 
\q2 هەروەک هەڵۆیەک کە دەنیشێتە سەر نێچیرەکەی. 
\q1  
\v 27 ئەگەر بڵێم: ”سکاڵاکەی خۆم فەرامۆش دەکەم و 
\q2 واز لە ڕووگرژی دەهێنم و زەردەخەنە دەخەمە سەر لێوەکانم،“ 
\q1  
\v 28 لەگەڵ ئەوەشدا لە هەموو ئازارەکانم دەترسم، 
\q2 چونکە دەزانم بێتاوانم ناکەیت. 
\q1  
\v 29 من تاوانبار دەکرێم، 
\q2 ئیتر بۆچی بەخۆڕایی خۆم ماندوو بکەم؟ 
\q1  
\v 30 ئەگەر بە بەفراو خۆم بشۆم و 
\q2 دەستەکانم بە ئەسپۆن پاک بکەمەوە، 
\q1  
\v 31 لەناو چاڵێک ڕیخ نوقومم دەکەیت، 
\q2 تەنانەت جلوبەرگەکەم قێزم لێ دەکەنەوە. 
\b  
\q1  
\v 32 «ئەو وەک من مرۆڤ نییە هەتا وەڵامی بدەمەوە و 
\q2 لە دادگا ڕووبەڕووی یەک ببینەوە. 
\q1  
\v 33 خۆزگە ناوبژیوانێک لەنێوانمان دەبوو، 
\q2 دەستی لەسەر هەردووکمان دادەنا، 
\q1  
\v 34 تاوەکو کوتەکەکەی خودام لەسەر هەڵبگرێت و 
\q2 ترسەکەی نەمتۆقێنێت. 
\q1  
\v 35 ئەو کاتە قسەم دەکرد و لێی نەدەترسام، 
\q2 چونکە من بەو شێوەیە نیم کە ئەو لێم تێگەیشتووە.» 
\b  
\c 10  
\q1  
\v 1 «لە ناخەوە قێزم لە ژیان دەبێتەوە، 
\q2 بە ئازادی سکاڵای خۆم دەردەبڕم، 
\q2 بە دڵێکی بریندارەوە قسە دەکەم. 
\q1  
\v 2 بە خودا دەڵێم: بڕیاری تاوانباریم بەسەردا مەسەپێنە! 
\q2 تێمبگەیەنە بۆچی دادگاییم دەکەیت. 
\q1  
\v 3 ئایا بەلاتەوە باشە ستەم بکەیت، 
\q2 ئەوەی بە دەستی خۆت دروستت کرد، زەلیلی بکەیت؟ 
\q2 بە پیلانی بەدکاران پێبکەنیت؟ 
\q1  
\v 4 ئایا چاوی گۆشتیت هەیە؟ 
\q2 ئایا وەک چاوی مرۆڤ دەبینیت؟ 
\q1  
\v 5 ئایا ڕۆژگارت وەک ڕۆژگاری مرۆڤە، 
\q2 یان تەمەنت وەک تەمەنی ئێمە دیاریکراوە؟ 
\q1  
\v 6 بۆچی بەدوای تاوانمدا دەگەڕێیت و 
\q2 چاو بۆ گوناهم دەگێڕیت؟ 
\q1  
\v 7 هەرچەندە تۆ دەزانیت کە من تاوانبار نیم و 
\q2 کەسیش نییە لە دەستی تۆ فریام بکەوێت. 
\b  
\q1  
\v 8 «دەستەکانی تۆ منیان پێکهێنا و دروستیان کردم، 
\q2 ئایا دەستت دەگێڕیتەوە سەرم و لەناوم دەبەیت؟ 
\q1  
\v 9 لەبیرت نەچێت کە تۆ وەک قوڕ شێوەی منت کێشا، 
\q2 ئایا ئێستا دەمگەڕێنیتەوە بۆ خۆڵ؟ 
\q1  
\v 10 ئایا وەک شیر منت نەچۆڕاند و 
\q2 وەک پەنیر منت نەمەیاند؟ 
\q1  
\v 11 بە پێست و گۆشت منت پۆشی و 
\q2 بە ئێسک و ماسوولکە منت چنی. 
\q1  
\v 12 ژیان و خۆشەویستی نەگۆڕت پێ بەخشیم، 
\q2 چاودێریی تۆ ڕۆحی منی پاراست. 
\b  
\q1  
\v 13 «بەڵام ئەمەت لە دڵی خۆتدا شاردەوە، 
\q2 من زانیم کە چیت لە دڵدایە. 
\q1  
\v 14 ئەگەر گوناه بکەم، چاودێریم دەکەیت و 
\q2 لە تاوانەکەم بێبەریم ناکەیت. 
\q1  
\v 15 ئەگەر تاوانبار بم، قوڕبەسەرم! 
\q2 ئەگەر بێتاوانیش بم، ناتوانم شانازی پێوە بکەم، 
\q1 چونکە من تێرم لە شەرمەزاری و 
\q2 زەلیلی خۆم بینی. 
\q1  
\v 16 ئەگەر سەرم بەرز بکەمەوە وەک شێر ڕاوم دەکەیت، 
\q2 دەگەڕێیتەوە و سامی خۆتم نیشان دەدەیت. 
\q1  
\v 17 شایەتەکانت لە دژم نوێ دەکەیتەوە و 
\q2 تووڕەیی خۆتم لەسەر زیاد دەکەیت و 
\q2 یەک لەدوای یەک هێزەکانت دەنێریتە سەرم. 
\b  
\q1  
\v 18 «ئیتر بۆچی لە سکی دایکمەوە دەرتهێنام؟ 
\q2 خۆزگە بفەوتامایە و ئەو کاتە هیچ چاوێکیش نەیدەبینیم. 
\q1  
\v 19 وەک ئەوەی نەبووبم، وا دەبوو، 
\q2 لە سکی دایکمەوە بۆ گۆڕ دەبردرام. 
\q1  
\v 20 ئایا ڕۆژگارم کەم نییە؟ 
\q2 بەرمدە! وازم لێ بهێنە! با تاوێک زەردەخەنە بێتە سەر لێوم، 
\q1  
\v 21 پێش ئەوەی بڕۆم و ئیتر نەگەڕێمەوە، 
\q2 بۆ خاکی تەمومژ و سێبەری مەرگ، 
\q1  
\v 22 خاکی تاریکی، وەک شەوەزەنگ، 
\q2 سێبەری مەرگ و ناڕێکی، 
\q2 خۆرهەڵاتنیشی وەک شەوەزەنگە.» 
\c 11  
\s1 وەڵامی یەکەمی چۆفەر 
\p  
\v 1 چۆفەری نەعماتیش وەڵامی دایەوە: 
\q1  
\v 2 «ئایا ئەم هەموو قسانە شایانی وەڵام نین، 
\q2 یاخود پیاوی زۆربڵێ ئەستۆپاک دەبێت؟ 
\q1  
\v 3 ئایا قسە پووچەکانت خەڵکی بێدەنگ دەکات، 
\q2 یان گاڵتە دەکەیت و کەس نییە شەرمەزارت بکات؟ 
\q1  
\v 4 بە خودا دەڵێیت ”باوەڕم بێگەردە و 
\q2 من لەبەرچاوی تۆدا پاکم،“ 
\q1  
\v 5 بەڵام خۆزگە خودا دەدوا و 
\q2 لێوەکانی بەرامبەر بە تۆ دەکردەوە و 
\q1  
\v 6 نهێنییەکانی دانایی بۆت ئاشکرا دەکرد، 
\q2 چونکە دانایی لایەکی ئاشکرا و لایەکی شاردراوەشی هەیە، 
\q2 جا دەتزانی کە خودا لە تاوانەکەی خۆت کەمتر سزای داویت. 
\b  
\q1  
\v 7 «ئایا دەتوانیت لە نهێنییەکانی خودا بگەیت؟ 
\q2 ئایا دەتوانیت بگەیتە سنووری خودای هەرە بەتوانا؟ 
\q1  
\v 8 ئەو لە ئاسمان بەرزترە، ئیتر تۆ چی دەکەیت، 
\q2 لە جیهانی مردووان قووڵترە، ئیتر تۆ چی دەزانیت؟ 
\q1  
\v 9 پێوانەکەی لە زەوی درێژترە و 
\q2 لە دەریاش پانترە. 
\b  
\q1  
\v 10 «ئەگەر هات و تۆی خستە بەندیخانەوە و 
\q2 تۆی بردە دادگا، کێ ڕێی لێ دەگرێت؟ 
\q1  
\v 11 بێگومان ئەو دەزانێت خراپەکاران کێن و 
\q2 خراپەکاری دەبینێت، وا دەزانیت ئاگای لێ نییە؟ 
\q1  
\v 12 بەڵام پیاوێکی بێ ئەقڵ نابێتە تێگەیشتوو 
\q2 هەتا جاشکی کەرەکێوی وەک مرۆڤ لەدایک نەبێت. 
\b  
\q1  
\v 13 «ئەگەر تۆ دڵی خۆت ئامادە بکەیت و 
\q2 دەستی خۆتی بۆ پان بکەیتەوە، 
\q1  
\v 14 ئەگەر ئەو خراپەیەی لەناو دەستتە دووری بخەیتەوە و 
\q2 نەهێڵیت ستەم لەناو چادرەکەت نیشتەجێ بێت، 
\q1  
\v 15 ئەو کاتە بەبێ کەموکوڕی شەرم ناکەیت و 
\q2 چەسپاو دەبیت و ناترسیت. 
\q1  
\v 16 چەرمەسەری لەبیر دەکەیت و 
\q2 وەک ئاوێکی تێپەڕیو یادی دەکەیتەوە. 
\q1  
\v 17 ژیانت لە نیوەڕۆ ڕۆشنتر دەبێت و 
\q2 تاریکی وەک ڕووناکی بەیانی لێدێت. 
\q1  
\v 18 دڵنیا دەبیت، چونکە ئومێدت هەیە، 
\q2 دەوروبەرەکەت دەپشکنیت و بە ئاسوودەییەوە پشوو دەدەیت. 
\q1  
\v 19 خۆت مات دەکەیت و کەس نییە هەراسانت بکات و 
\q2 زۆر کەس لە ڕووی تۆ دەپاڕێنەوە. 
\q1  
\v 20 بەڵام چاوی بەدکاران کوێر دەبن و 
\q2 پەناگا نامێنێت بۆ دەربازبوون؛ 
\q2 ئاواتیان ڕۆح سپاردنە.» 
\c 12  
\s1 قسەی چوارەمی ئەیوب 
\p  
\v 1 ئەیوبیش وەڵامی دایەوە: 
\q1  
\v 2 «ڕاستە ئێوە گەلێکن، 
\q2 بە مردنتان داناییش دەمرێت، 
\q1  
\v 3 بەڵام منیش وەک ئێوە تێگەیشتنم هەیە، 
\q2 من لە ئێوە کەمتر نیم. 
\q2 ئایا ئەوەی تۆ دەیڵێیت لای هەموو کەسێک نەزانراوە؟ 
\b  
\q1  
\v 4 «لە خودا پاڕامەوە و ئەویش وەڵامی دایەوە، 
\q2 بەڵام بووم بە گاڵتەجاڕی هاوڕێیەکانم، 
\q2 هەرچەندە پیاوێکی ڕاستودروست و بێ کەموکوڕیم، بوومە مایەی گاڵتەجاڕی! 
\q1  
\v 5 کەسێکی دڵنیا 
\q2 گاڵتە بە شکستی پێ هەڵخلیسکاو دەکات. 
\q1  
\v 6 چادری تێکدەران ئارامە و 
\q2 ئاسوودەییش بۆ ئەوانەی خودا تووڕە دەکەن، 
\q2 بۆ ئەوانەی بە دەستی خۆیان بتەکانیان دەهێنن. 
\b  
\q1  
\v 7 «بەڵام پرسیار لە ئاژەڵان بکە، ئەوان فێرت دەکەن، 
\q2 هەروەها پرسیار لە باڵندەی ئاسمانیش بکە، ئەوان پێت ڕادەگەیەنن؛ 
\q1  
\v 8 یان لەگەڵ زەوی بدوێ، فێرت دەکات، 
\q2 ماسی دەریاش بۆت باس دەکەن. 
\q1  
\v 9 کام لەمانە نازانێت کە 
\q2 دەستی خودا ئەمەی ئەنجام داوە؟ 
\q1  
\v 10 ئەوەی ژیانی هەموو زیندووێک و 
\q2 ڕۆحی هەموو مرۆڤێکی لەناو دەستدایە؟ 
\q1  
\v 11 ئایا گوێ قسەکان تاقی ناکاتەوە و 
\q2 مەڵاشوو تامی خواردن ناکات؟ 
\q1  
\v 12 لە ڕیش سپیێتی دانایی و 
\q2 لە تەمەن درێژیش تێگەیشتن. 
\b  
\q1  
\v 13 «دانایی و تواناداری لەلای خوداوەیە، 
\q2 ڕاوێژ و تێگەیشتن هی ئەون. 
\q1  
\v 14 ئەوەی دەڕووخێنێت بنیاد نانرێتەوە، 
\q2 ئەگەر دەرگای لەسەر کەسێک داخست لێی ناکرێتەوە. 
\q1  
\v 15 ڕێ لە ئاو دەگرێت، وشکەساڵی دێت، 
\q2 بەڕەڵای دەکات زەوی سەرەوژێر دەکات. 
\q1  
\v 16 هێز و دانایی لەلای ئەوە، 
\q2 چەواشەکار و چەواشەکراو هی ئەون. 
\q1  
\v 17 ڕاوێژکاران بە پێ خاوسی دەبات، 
\q2 دادوەران تووشی شێتی دەکات. 
\q1  
\v 18 کۆتی پاشاکان دەکاتەوە و 
\q2 ناوقەدیان بە پشتێن دەبەستێتەوە. 
\q1  
\v 19 کاهینەکان بە پێ خاوسی دەبات و 
\q2 پتەوەکان سەرەوژێر دەکات. 
\q1  
\v 20 ڕێگری گفتوگۆ لە شارەزایان دەکات، 
\q2 ژیری لە پیران دەستێنێتەوە. 
\q1  
\v 21 سووکایەتی بەسەر پایەداراندا دەبارێنێت و 
\q2 پشتێنی بەهێزان شل دەکاتەوە. 
\q1  
\v 22 قووڵاییەکان لە تاریکی ئاشکرا دەکات و 
\q2 سێبەری مەرگ بۆ ڕووناکی دەردەخات. 
\q1  
\v 23 نەتەوەکان مەزن دەکات و لەناویان دەبات، 
\q2 نەتەوەکان بەرفراوان دەکات و پەرتەوازەیان دەکات. 
\q1  
\v 24 مێشک لە سەرکردەکانی گەلی زەوی دەستێنێتەوە و 
\q2 لە چۆڵەوانییەکی بێ ڕێگا وێڵیان دەکات. 
\q1  
\v 25 لە تاریکیدا بە پەلەکوتێ دەڕۆن و ڕووناکی نییە، 
\q2 وەک سەرخۆش بە ئەملا و ئەولادا دەکەون. 
\b  
\c 13  
\q1  
\v 1 «چاوەکانم هەموو ئەمانەی بینیوە، 
\q2 گوێیەکانم بیستوویانە و تێیان گەیشتووم. 
\q1  
\v 2 وەک زانینی ئێوە منیش زانیومە؛ 
\q2 من لە ئێوە کەمتر نیم. 
\q1  
\v 3 بەڵام من لەگەڵ توانادارەکە قسە دەکەم، 
\q2 دەمەوێت لەلای خودا دادگایی بکرێم. 
\q1  
\v 4 بەڵام ئێوە درۆم بۆ هەڵدەبەستن، 
\q2 هەمووتان پزیشکی بێ کەڵکن. 
\q1  
\v 5 خۆزگە بە تەواوی بێدەنگ دەبوون! 
\q2 ئەوە بۆتان دەبوو بە دانایی. 
\q1  
\v 6 ئێستا گوێ لە بەهانەم بگرن و 
\q2 بۆ سکاڵای لێوەکانم گوێ شل بکەن. 
\q1  
\v 7 ئایا بە درۆ بەرگری لە خودا دەکەن؟ 
\q2 ئایا بە دەم خوداوە درۆ دەکەن؟ 
\q1  
\v 8 ئایا لایەنگری دەکەن، 
\q2 یان بۆ خودا مشتومڕ دەکەن؟ 
\q1  
\v 9 ئەگەر تاقیتان بکاتەوە، ئایا دەردەچن 
\q2 یان دەتانەوێت وەک مرۆڤ هەڵیبخەڵەتێنن؟ 
\q1  
\v 10 بێگومان سەرزەنشتتان دەکات 
\q2 ئەگەر بە نهێنی لایەنگری بکەن. 
\q1  
\v 11 ئایا شکۆمەندییەکەی ناتانترسێنێت و 
\q2 ترسی ئەو دەستتان بەسەردا ناکێشێت؟ 
\q1  
\v 12 یادەوەری و پەندەکانتان تەنها خۆڵەمێشە و 
\q2 بەرگرییەکانتان بەرگرییە لە قوڕ. 
\b  
\q1  
\v 13 «لێم بێدەنگ بن، من قسە دەکەم و 
\q2 ئەوەی بەسەرم دێت با بێت! 
\q1  
\v 14 بۆچی من کێشە بۆ خۆم دروستبکەم، 
\q2 ژیانی خۆم بخەمە مەترسییەوە؟ 
\q1  
\v 15 ئەگەر بشمکوژێت هەر پشتی پێ دەبەستم، 
\q2 لەبەردەمیدا تەنها مشتومڕ لەسەر هەڵسوکەوتم دەکەم. 
\q1  
\v 16 هەروەها ئەمە بۆ ڕزگاریمە، 
\q2 کە خوانەناس نایەتە بەردەمی. 
\q1  
\v 17 بە تەواوی گوێ لە قسەکانم بگرن و 
\q2 ئەوەی ڕایدەگەیەنم با گوێتان لێی بێت. 
\q1  
\v 18 ئەوەتا من بە باشی سکاڵای خۆمم خستووەتە ڕوو، 
\q2 دەزانم ئەستۆپاک دەردەچم. 
\q1  
\v 19 کێیە ئەوەی مشتومڕم لەگەڵ دەکات، 
\q2 تاکو هەر ئێستا بێدەنگ بم و ڕۆح بەدەستەوە بدەم؟ 
\b  
\q1  
\v 20 «ئەی خودا، تەنها بەم دوو کارە پشتگیریم بکە، 
\q2 ئیتر لەبەردەمت ون نابم. 
\q1  
\v 21 دەستت لێم دووربخەوە و 
\q2 با سامی تۆ نەمترسێنێت. 
\q1  
\v 22 ئینجا بانگم بکە و من وەڵام دەدەمەوە، 
\q2 یان من قسە دەکەم و تۆ وەڵامم بدەوە. 
\q1  
\v 23 چەند تاوان و گوناهم هەیە؟ 
\q2 یاخیبوون و گوناهەکەی خۆمم پێ بناسێنە. 
\q1  
\v 24 بۆچی ڕووی خۆت دەشاریتەوە و 
\q2 بە دوژمنی خۆت دامدەنێیت؟ 
\q1  
\v 25 ئایا گەڵایەکی هەڵوەریو پان دەکەیتەوە؟ 
\q2 ئایا بەدوای پووشی وشکدا ڕادەکەیت؟ 
\q1  
\v 26 تۆ بە تاڵی لە دژم دەنووسیت و 
\q2 لەسەر تاوانەکانی لاویێتیم سزام دەدەیت. 
\q1  
\v 27 جا پێیەکانی منت خستووەتە ناو کۆتەوە و 
\q2 چاوت بڕیوەتە هەموو ڕێڕەوەکانم و 
\q2 شوێن پێیەکانم دەپشکنیت. 
\b  
\q1  
\v 28 «وەک دارێکی کلۆر لەناو دەچم، 
\q2 وەک جلێک کە مۆرانە لێی دابێت. 
\b  
\c 14  
\q1  
\v 1 «مرۆڤی لەدایکبوو لە ژن 
\q2 ڕۆژگاری کەمە و چەرمەسەری زۆرە. 
\q1  
\v 2 وەک گوڵ دەپشکوێت و پاشان سیس دەبێت، 
\q2 وەک سێبەر دەڕوات و ناوەستێت. 
\q1  
\v 3 ئایا چاوت لەسەر کەسێکی وەکو ئەم دەبێت؟ 
\q2 ئێستاش ئەوت هێناوەتە بەردەم خۆت بۆ دادگایی؟ 
\q1  
\v 4 کێ دەتوانێت پاکێک لە گڵاوێک دەربهێنێت؟ 
\q2 بێگومان کەس! 
\q1  
\v 5 جا ئەگەر ڕۆژانی هەرکەسێک دیاریکراو بێت و 
\q2 ژمارەی مانگەکانی لای تۆ بێت و 
\q2 کاتێکت بۆ دیاریکردبێت کە لێی تێنەپەڕێت، 
\q1  
\v 6 ئیتر لێیگەڕێ با پشوو بدات، 
\q2 هەتا وەک ڕەنجدەرێک دڵخۆش بێت بە تەواوبوونی ڕۆژەکەی. 
\b  
\q1  
\v 7 «لانی کەم دار ئومێدی ئەوەی هەیە کە 
\q2 ئەگەر بڕایەوە چەکەرە بکاتەوە و دووبارە شین بێتەوە و 
\q2 لقوپۆپی تازە دەربکات. 
\q1  
\v 8 ئەگەر ڕەگەکەی لەناو زەویدا کۆنیش بێت و 
\q2 بنەدارەکەی لەناو خۆڵدا بمرێت، 
\q1  
\v 9 هەر کاتێک بۆنی ئاو بکات چەکەرە دەکات و 
\q2 وەک ڕووەکێکی نوێ لق دەردەکات. 
\q1  
\v 10 بەڵام پیاو دەمرێت و لەناودەچێت؛ 
\q2 مرۆڤ ڕۆح بەدەستەوە دەدات و بوونی نابێت. 
\q1  
\v 11 هەروەک ئاوەکان لەناو دەریاچە نامێنن و 
\q2 ڕووبار ئاوی تێدا نامێنێت و وشک دەبێت، 
\q1  
\v 12 هەروەها مرۆڤیش ڕادەکشێت و هەڵناستێتەوە، 
\q2 لە خەوەکەی خەبەری نابێتەوە و بەئاگا نایەت 
\q2 هەتا ئاسمان نامێنێت. 
\b  
\q1  
\v 13 «خۆزگە لەناو جیهانی مردووان لەچاو ونت دەکردم و 
\q2 دەتشاردمەوە هەتا تووڕەییەکەت دادەمرکایەوە! 
\q1 خۆزگە کاتێکت بۆ دیاری دەکردم و 
\q2 بەبیرت دەهاتمەوە! 
\q1  
\v 14 ئەگەر پیاوێک بمرێت، ئایا زیندوو دەبێتەوە؟ 
\q2 هەموو ڕۆژانم تێکۆشانە، 
\q2 ئارام دەگرم هەتا دەرووم لێ دەکرێتەوە. 
\q1  
\v 15 بانگم دەکەیت من وەڵامت دەدەمەوە، 
\q2 تامەزرۆ دەبیت بۆ ئەو بوونەوەرەی کە دروستت کرد. 
\q1  
\v 16 بێگومان ئەو کاتە چاودێری هەنگاوەکانم دەکەیت، 
\q2 بەڵام تێبینی گوناهەکەم ناکەیت. 
\q1  
\v 17 یاخیبوونەکەم گرێی لێدراوە لەناو بوخچەیەک، 
\q2 تاوانەکەم دەشاریتەوە. 
\b  
\q1  
\v 18 «هەروەک چۆن کە چیا بکەوێت پارچەپارچە دەبێت و 
\q2 تاشەبەرد لە جێی خۆی دەلەقێت، 
\q1  
\v 19 ئاو بەرد دەسووێنێت و 
\q2 لافاو خۆڵی زەوی ڕادەماڵێت، 
\q2 بەو جۆرە تۆش هیوای مرۆڤ لەناودەبەیت. 
\q1  
\v 20 بۆ هەتاهەتایە بەسەریدا زاڵ دەبیت و کۆتایی پێ دێت، 
\q2 ڕووی دەگۆڕیت و دەریدەکەیت. 
\q1  
\v 21 ئەگەر کوڕەکانی ڕێزیان لێ بگیرێت، پێی نازانێت، 
\q2 ئەگەر لە پلەوپایەشیان نزم بکرێتەوە، ئاگای لێ نییە. 
\q1  
\v 22 تەنها هەست بە ئازاری خۆی دەکات و 
\q2 داخ بۆ حاڵی خۆی دەخوات.» 
\c 15  
\s1 وەڵامی دووەمی ئەلیفاز 
\p  
\v 1 ئەلیفازی تێمانیش وەڵامی دایەوە: 
\q1  
\v 2 «ئایا کەسی دانا بە نەزانی وەڵام دەداتەوە و 
\q2 مێشکی بە شتی هیچوپووچ پڕ دەکات؟ 
\q1  
\v 3 ئایا بە قسەی بێ سوود بەڵگە دێنێتەوە و 
\q2 بەو لێدوانانەی قازانجی لێ ناکات؟ 
\q1  
\v 4 بەڵام تۆ لەخواترسی پێشێل دەکەیت و 
\q2 خەڵک لە خواپەرستی دوور دەخەیتەوە. 
\q1  
\v 5 بێگومان گوناهەکانت دەمت فێر دەکەن و 
\q2 زمانی تەڵەکەبازی هەڵدەبژێریت. 
\q1  
\v 6 زمانی خۆت تاوانبارت دەکات، نەک من، 
\q2 لێوەکانت لە دژت شایەتی دەدەن. 
\b  
\q1  
\v 7 «ئایا تۆ یەکەم مرۆڤ بوویت لەدایک بوویت؟ 
\q2 یان لەپێش گردەکانەوە دروستبوویت؟ 
\q1  
\v 8 ئایا لە ئەنجومەنی خودا\f + \fr 15:8 \ft هەندێک لە فریشتەکان لەبەردەم خودا ئامادە دەبن، خودا لە فەرمایشت و فەرمانەکانی دەکرێ ڕاوێژیان پێ بکات و گفتوگۆیان لەگەڵ بکات.‏\f* گوێت گرتبوو؟ 
\q2 ئایا داناییت بە باڵای خۆتدا بڕیوە؟ 
\q1  
\v 9 چی دەزانیت کە ئێمە نایزانین، 
\q2 چی تێدەگەیت کە لەلای ئێمە نەبێت؟ 
\q1  
\v 10 پیر و ڕیش سپی وامان لەناودایە، 
\q2 تەمەنی لە باوکت زیاترە. 
\q1  
\v 11 ئایا دڵنەواییەکانی خودا و 
\q2 بە نەرمی قسەکردن لەگەڵت کەمە؟ 
\q1  
\v 12 بۆچی دڵت دەتبات و 
\q2 بۆچی چاوەکانت دەبریسکێنەوە، 
\q1  
\v 13 بۆ ئەوەی ڕۆحت لە دژی خودا وەربگێڕیت و 
\q2 قسەی وا لە دەمت بهێنیتە دەرەوە؟ 
\b  
\q1  
\v 14 «مرۆڤ کێیە هەتا بێگەرد بێت و 
\q2 لەدایکبوو لە ژن کێیە هەتا ڕاستودروست بێت؟ 
\q1  
\v 15 ئەگەر خودا متمانە بە پیرۆزەکانی خۆی ناکات، 
\q2 کەواتە ئاسمان لەبەرچاوی بێگەرد نییە، 
\q1  
\v 16 ئیتر مرۆڤ کە ناڕەوایی وەک ئاو دەخواتەوە 
\q2 دەبێت چەند قێزەون و گەندەڵ بێت؟ 
\b  
\q1  
\v 17 «من پێت دەڵێم گوێم لێ بگرە، 
\q2 باسی ئەوە دەکەم کە بینیم، 
\q1  
\v 18 ئەوەی دانایان لە باوباپیرانیانەوە پێیان ڕاگەیەنراوە و 
\q2 ئەوانیش نەیانشاردووەتەوە، 
\q1  
\v 19 ئەوانەی خاکەکە تەنها بەوان دراوە و 
\q2 هیچ نامۆیەک بەناویاندا تێنەپەڕیوە. 
\q1  
\v 20 بەدکار ڕۆژانە دەتلێتەوە، 
\q2 ژمارەی ساڵانی ستەمکاریش دیاریکراوە. 
\q1  
\v 21 دەنگێکی ترسناک لە گوێیەکانیەتی و 
\q2 لە ساتی ئاشتیدا تێکدەر بۆی دێت. 
\q1  
\v 22 لەو باوەڕەدا نییە لە تاریکی دەگەڕێتەوە؛ 
\q2 چاوەڕوانی شمشێرە. 
\q1  
\v 23 ئەو وێڵە و دەبێتە نێچیری سیسارکە کەچەڵ، 
\q2 دەزانێت کە ڕۆژی تاریکی نزیکە. 
\q1  
\v 24 تەنگانە و ئازار دەیتۆقێنن و 
\q2 بەسەریدا زاڵن وەک پاشایەکی ئامادە بۆ پەلاماردان، 
\q1  
\v 25 چونکە بە تووڕەییەوە دەستی لە خودا ڕادەوەشێنێت، 
\q2 لە دژی خودای هەرە بەتوانا پاڵەوانیێتی نواند، 
\q1  
\v 26 بە کەللەڕەقییەوە بەرەو ئەو ڕایکرد 
\q2 بە قەڵغانە ئەستوور و بەهێزەکەیەوە. 
\b  
\q1  
\v 27 «هەرچەندە دەموچاوی بە چەوری داپۆشی و 
\q2 ناوقەدی خۆی بە پیو\f + \fr 15:27 \ft پیو: واتا بەز.‏\f* ئەستوور کرد، 
\q1  
\v 28 بەڵام لە شارۆچکەی کاولبوو نیشتەجێ دەبێت، 
\q2 لەو ماڵانەی کەسی تێدا ناژیێت و 
\q2 خەریکن دەبنە کەلاوە. 
\q1  
\v 29 لەمەودوا دەوڵەمەند نابێت و سامانەکەی جێگیر نابێت، 
\q2 دەستکەوتی لەناو زەویدا بەرفراوان نابێت. 
\q1  
\v 30 لە تاریکی دەرباز نابێت، 
\q2 کڵپەی گڕێک پۆپکەکانی وشک دەکات و 
\q2 بە فووێکی دەمی نامێنێت. 
\q1  
\v 31 جێی باوەڕ نابێت 
\q2 بە شتی پووچ وێڵ دەبێت، 
\q2 چونکە شتی پووچ دەبێت بە کرێیەکەی. 
\q1  
\v 32 پێش ئەوەی ڕۆژی خۆی تەواو بێت، 
\q2 دەفەوتێت و گەڵاکەی سەوز نابێت. 
\q1  
\v 33 وەک ترێ پەسیرەکانی\f + \fr 15:33 \ft بەرسیلەکانی.‏\f* دەکەوێت و 
\q2 وەک زەیتوون گوڵەکەی هەڵدەوەرێت. 
\q1  
\v 34 کۆمەڵی خوانەناسان چۆڵوهۆڵ دەبێت، 
\q2 ئاگریش ڕەشماڵی بەرتیلخۆران دەسووتێنێت. 
\q1  
\v 35 بە ئاژاوە دووگیان بوون و خراپەیان بۆ لەدایک دەبێت، 
\q2 سکیان پیلانی فێڵ و درۆ پێکدەهێنێت.» 
\c 16  
\s1 قسەی پێنجەمی ئەیوب 
\p  
\v 1 ئەیوبیش وەڵامی دایەوە: 
\q1  
\v 2 «زۆرم لەمانە گوێ لێ بووە، 
\q2 هەموو دڵنەواییەکەتان بریندارکەرن! 
\q1  
\v 3 ئایا قسەی پووچ کۆتایی هەیە؟ 
\q2 یان چی دەتوروژێنێت هەتا وەڵام بدەیتەوە؟ 
\q1  
\v 4 منیش وەک ئێوە قسەم دەکرد، 
\q2 ئەگەر ئێوە لە جێی من بوونایە؛ 
\q1 قسەم بۆ دەگێڕانەوە و 
\q2 سەرم لە ئاستتان دەلەقاند. 
\q1  
\v 5 بەڵام بە دەم هانم دەدان و 
\q2 جوڵەی لێوەکانم ڕایدەگرتن. 
\b  
\q1  
\v 6 «ئەگەر قسە بکەم لە خەمۆکیەکەم کەم نابێتەوە، 
\q2 ئەگەر بێدەنگیش بم لێم دوور ناکەوێتەوە. 
\q1  
\v 7 ئەی خودایە، بێگومان تۆ بێزارت کردووم، 
\q2 هەموو کەسوکارەکەی منت لەناوبردووە. 
\q1  
\v 8 سستت کردم، سستییەکەم بووە شایەت، 
\q2 لاوازییەکەم لێم هەستاوە، بەرەوڕوو شایەتیم لەسەر دەدات. 
\q1  
\v 9 تووڕەییەکەی پەلاماری دام و منی چەوساندەوە، 
\q2 ددانەکانی لێم جیڕکردەوە، 
\q2 دوژمنەکەم چاوی تێبڕیوم. 
\q1  
\v 10 خەڵک دەمیان لێ داچەقاندووم، 
\q2 بە گاڵتەپێکردنەوە زللەیان لێدەدام، 
\q2 پێکەوە گەلەکۆمەیان لێکردم. 
\q1  
\v 11 خودا منی دایە دەست زۆردار و 
\q2 فڕێیدامە نێو دەستی خراپەکارەوە. 
\q1  
\v 12 من ئاسوودە بووم و ئەو جێی لەق کردم، 
\q2 پشتەملی گرتم و وردوخاشی کردم. 
\q1 منی کرد بە نیشانی خۆی؛ 
\q2  
\v 13 تیرهاوێژەکانی دەوریان دام. 
\q1 جەرگی بڕیم و دڵی نەسووتا، 
\q2 زراوی منی بەسەر زەویدا ڕشت. 
\q1  
\v 14 جار لەدوای جار شەقم دەکات، 
\q2 وەک جەنگاوەرێک هێرش دەکاتە سەرم. 
\b  
\q1  
\v 15 «جلوبەرگی گوشم\f + \fr 16:15 \ft لە کاتی ماتەمگێڕان و تۆبەکردندا جلوبەرگی لە گوش دروستکراویان لەبەرکردووە کە ئەزیەتی پێستیانی داوە.‏\f* بە پێستمەوە دووری و 
\q2 خۆڵەمێشم بە سەری خۆمدا کرد. 
\q1  
\v 16 دەموچاوم لەبەر گریان سوور هەڵگەڕا و 
\q2 ڕەشی بەسەر پێڵوی چاومدا هات. 
\q1  
\v 17 لەگەڵ ئەوەی زۆرداری لە دەستی مندا نییە و 
\q2 نوێژەکەم بێگەردە. 
\b  
\q1  
\v 18 «ئەی زەوی، خوێنەکەم دامەپۆشە، 
\q2 با جێیەک نەبێت بۆ هاوارم! 
\q1  
\v 19 ئەوەتا لە ئێستاوە شایەتەکەم لە ئاسمانە، 
\q2 پارێزگارەکەم لە بەرزاییەکانە، 
\q1  
\v 20 ئەو هاوڕێمە و داکۆکیم لێ دەکات. 
\q2 کاتێک لەبەردەم خودا چاوەکانم فرمێسک دەڕێژن،\f + \fr 16:20 \ft لە هەندێک وەرگێڕانەکان دەگوترێت: هاوڕێیەکانم گاڵتە پێم دەکەن.‏\f* 
\q1  
\v 21 ئەو لە پێناوی پیاوێک لە خودا دەپاڕێتەوە، 
\q2 وەک پاڕانەوەی کەسێک بۆ هاوڕێکەی. 
\b  
\q1  
\v 22 «تەمەنم کورتە و بەسەردەچێت، 
\q2 لە ڕێگایەکدا دیلم کە لێی ناگەڕێمەوە. 
\c 17  
\q1  
\v 1 ڕۆحم شکا، 
\q2 ڕۆژگارم کوژایەوە، 
\q2 گۆڕ چاوەڕێی منە. 
\q1  
\v 2 بێگومان گاڵتەجاڕان لە دەورمدان و 
\q2 ناچار تەماشای کێشمەکێشیان بکەم. 
\b  
\q1  
\v 3 «تکایە لەلای خۆت ببە پشتگیرم، 
\q2 بێجگە لە تۆ کێ هەیە ببێتە کەفیلم؟ 
\q1  
\v 4 تێگەیشتنت لە مێشکیان شاردووەتەوە، 
\q2 لەبەر ئەوە بەرزیان ناکەیتەوە. 
\q1  
\v 5 ئەوەی لە پێناوی پارە پەنجەی تاوان بۆ هاوڕێیەکانی ڕادەکێشێت، 
\q2 نەبوونی چاوی منداڵەکانی دەپوکێنێتەوە. 
\b  
\q1  
\v 6 «منی کردە پەندی گەلان و 
\q2 بووم بەوەی تف لە ڕووم بکرێت. 
\q1  
\v 7 چاوەکانم لەبەر خەم کز بوون، 
\q2 هەموو ئەندامەکانم زۆر لاواز بوون. 
\q1  
\v 8 ئەوانەی ڕاستن بەمە سەرسام دەبن و 
\q2 بێتاوان بەسەر خوانەناسدا ڕادەپەڕێت. 
\q1  
\v 9 کەسی ڕاستودروست ڕێگای خۆی دەگرێت و 
\q2 ئەوەی دەست پاکە هێزی بۆ زیاد دەکرێت. 
\b  
\q1  
\v 10 «ئێستا وەرنەوە، دووبارە هەوڵ بدەن، 
\q2 بەڵام من هیچ دانایەکتان تێدا نادۆزمەوە. 
\q1  
\v 11 ڕۆژگارم بەسەرچوو، مەبەستەکانم هەڵکەنران. 
\q2 لەگەڵ ئەوەشدا ئارەزووەکانی دڵم 
\q1  
\v 12 شەو دەکەن بە ڕۆژ، 
\q2 لە تاریکیدا ڕووناکی بە نزیک دەبینن. 
\q1  
\v 13 ئەگەر هیوا بخوازم جیهانی مردووان ببێت بە ماڵم و 
\q2 لە تاریکیدا نوێنەکەم ڕابخەم، 
\q1  
\v 14 ئەگەر بە گۆڕم گوت: ”تۆ باوکی منیت،“ 
\q2 بە کرمیش: ”تۆ دایکی منیت“ یان ”خوشکی منیت،“ 
\q1  
\v 15 ئیتر ئومێدم کوا؟ 
\q2 کێ تەماشای ئومێدم دەکات؟ 
\q1  
\v 16 ئایا بەرەو قووڵایی جیهانی مردووان دەچێتە خوارەوە؟ 
\q2 ئایا پێکەوە لەناو خۆڵ شۆڕدەبینەوە؟» 
\c 18  
\s1 وەڵامی دووەمی بیلدەد 
\p  
\v 1 بیلدەدی شوحیش وەڵامی دایەوە: 
\q1  
\v 2 «هەتا کەی تەڵە بۆ قسە دەنێنەوە؟ 
\q2 تێبگەن ئینجا ئێمە دەتوانین قسە بکەین. 
\q1  
\v 3 بۆچی بە ئاژەڵ دانراین و 
\q2 لەبەرچاوتان گێل بووین؟ 
\q1  
\v 4 ئەی ئەوەی لە ڕقی خۆی، خۆی دەخواتەوە، 
\q2 ئایا لەبەر تۆ زەوی چۆڵ بکرێت و 
\q2 تاشەبەرد لە جێی خۆی بجوڵێت؟ 
\b  
\q1  
\v 5 «بەڵێ چرای بەدکاران دەکوژێتەوە و 
\q2 گڕی ئاگرەکەی ڕووناکی نابەخشێت. 
\q1  
\v 6 لەناو چادرەکەی ڕووناکی تاریک دەبێت و 
\q2 چراکەی تەنیشتی دەکوژێتەوە. 
\q1  
\v 7 هێزی هەنگاوەکانی کورت دەبن و 
\q2 ڕاوێژەکەی خۆی دەیخات. 
\q1  
\v 8 بە پێیەکانی خۆی بۆ ناو داو هەنگاو دەنێت، 
\q2 جا لەناو تۆڕدا گیر دەخوات. 
\q1  
\v 9 تەڵە پاژنەی پێی دەگرێت و 
\q2 فاقە توند دەیگرێت. 
\q1  
\v 10 داوەکانی لە زەوی شاردراونەتەوە و 
\q2 تەڵەکەی لەسەر ڕێگایە. 
\q1  
\v 11 بەڵاکان لە هەموو لایەکەوە دەیتۆقێنن و 
\q2 هەنگاوبەهەنگاو دوای کەوتوون. 
\q1  
\v 12 برسیێتی بڕستی لێ بڕی و 
\q2 کارەسات چاوەڕێی کەوتنی دەکات. 
\q1  
\v 13 نەخۆشی پارچەکانی پێستەکەی دەخوات، 
\q2 یەکەم بەری مەرگ ئەندامەکانی لەشی دەخوات. 
\q1  
\v 14 لە ئارامی ناو چادرەکەی خۆی دەڕفێنرێت، 
\q2 بەرەو لای پاشای بەڵاکان پەلکێش دەکرێت. 
\q1  
\v 15 ئەوەی هی ئەو نییە لەناو چادرەکەی نیشتەجێ دەبێت، 
\q2 گۆگرد بەسەر جێی مانەوەی پەخش دەکرێت. 
\q1  
\v 16 لە ژێرەوە ڕەگوڕیشەی وشک دەبێت و 
\q2 لە سەرەوەش لقەکانی سیس دەبن. 
\q1  
\v 17 یادەوەری لە زەوی نامێنێت و 
\q2 لەسەر ڕووی وشکانیش هیچ ناوێکی نییە. 
\q1  
\v 18 لە ڕووناکییەوە پاڵ دەدرێت بۆ تاریکی و 
\q2 لە جیهان دەردەکرێت. 
\q1  
\v 19 نە نەوە و نە وەچەی لەنێو گەلەکەی دەبێت، 
\q2 نە دەربازبوو لەنێو چادرەکانی. 
\q1  
\v 20 خەڵکی ڕۆژئاوا لە ڕۆژی حوکمدان لەسەر ئەودا دەحەپەسێن، 
\q2 گەلانی ڕۆژهەڵات مووچڕکەیان پێدا دێت. 
\q1  
\v 21 ئەوە نشینگەی بەدکارانە و 
\q2 ئەمە شوێنی ئەوانەیە کە خودا ناناسن.» 
\c 19  
\s1 قسەی شەشەمی ئەیوب 
\p  
\v 1 ئەیوبیش وەڵامی دایەوە: 
\q1  
\v 2 «هەتا کەی گیانم ئازار دەدەن و 
\q2 بە قسە وردم دەکەن؟ 
\q1  
\v 3 ئەمە دەیەم جارە ڕیسوام دەکەن، 
\q2 بەبێ شەرمی هێرشتان کردە سەرم. 
\q1  
\v 4 گریمان بە ڕاستی گومڕا بووم، 
\q2 گومڕاییەکەم بەسەر خۆم دەشکێتەوە. 
\q1  
\v 5 ئەگەر بەڕاستی ئێوە خۆتان لە من بە گەورەتر دادەنێن و 
\q2 شەرمەزارییەکەی من لە دژی خۆم بەکاردەهێنن، 
\q1  
\v 6 ئەوا با لەلاتان زانراو بێت، خودا خۆی منی خوار کردووەتەوە و 
\q2 تۆڕەکەی بەدەورمدا ڕاکێشا. 
\b  
\q1  
\v 7 «هەرچەندە لەبەر ستەم هاوار دەکەم، بەڵام وەڵامم نادرێتەوە، 
\q2 هاوار دەهێنم، بەڵام دادپەروەری نییە. 
\q1  
\v 8 ڕێی لێ گرتم و ناپەڕمەوە، 
\q2 تاریکی خستووەتە سەر ڕێڕەوم. 
\q1  
\v 9 شکۆمەندییەکەمی لێم داماڵی و 
\q2 تاجەکەی سەرمی لێکردەوە. 
\q1  
\v 10 لە هەموو لایەکەوە منی ڕووخاند تاوەکو نەمێنم و 
\q2 هیوای منی وەک دار هەڵکەند. 
\q1  
\v 11 تووڕەیی خۆی بەسەرمدا داگیرساند و 
\q2 بە دوژمنی خۆی دانام. 
\q1  
\v 12 پەلاماردەرەکانی پێکەوە هاتن و 
\q2 سەنگەریان لە دژی من لێدا و 
\q2 لە دەوری چادرەکەم خۆیان دامەزراند. 
\b  
\q1  
\v 13 «کەسوکاری منی لێم دوورخستەوە و 
\q2 ناسیاوەکانم لێم بوون بە بێگانە. 
\q1  
\v 14 خزمەکانم وازیان لێ هێنام و 
\q2 ئەوانەی منیان ناسی لەبیریان کردم. 
\q1  
\v 15 میوان و کارەکەرەکانم وەک بیانی دایاننام، 
\q2 وەک نامۆیەک مامەڵەم لەگەڵ دەکەن. 
\q1  
\v 16 بانگی خزمەتکارەکەی خۆمم کرد بەڵام وەڵامی نەدایەوە، 
\q2 هەرچەندە بە دەمی خۆم لێی پاڕامەوە. 
\q1  
\v 17 بۆنم ناخۆش بووە لەلای ژنەکەم و 
\q2 قێزەونم لەلای جگەرگۆشەکانم. 
\q1  
\v 18 تەنانەت منداڵانیش سووکایەتییان پێکردم، 
\q2 کە هەستم، باسی من دەکەن. 
\q1  
\v 19 هەموو دۆستەکانم ڕقیان لێم بووەوە و 
\q2 ئەوانەی خۆشم دەویستن لە دژم هەڵگەڕانەوە. 
\q1  
\v 20 ئێسکم بە پێست و گۆشتمەوە نووساوە و 
\q2 بە خۆم و پووکمەوە دەرباز بووم. 
\b  
\q1  
\v 21 «بەزەییتان پێم بێتەوە، بەزەییتان پێم بێتەوە ئەی هاوڕێیان، 
\q2 چونکە دەستی خودا لێی داوم. 
\q1  
\v 22 بۆچی ئێوەش وەک خودا ڕاوم دەنێن؟ 
\q2 لە گۆشتم تێر نابن؟ 
\b  
\q1  
\v 23 «خۆزگە وشەکانم دەنووسرانەوە، 
\q2 خۆزگە لەناو تۆمارێکدا وێنەیان دەکێشرا، 
\q1  
\v 24 خۆزگە بە پێنووسی ئاسن لەسەر قورقوشم دەنووسران یان 
\q2 بۆ هەتاهەتایە لەسەر بەرد هەڵدەکۆڵران. 
\q1  
\v 25 بەڵام من زانیم ئەوەی کە دەمکڕێتەوە\f + \fr 19:25 \ft وەک کڕینەوەی کۆیلەیەک بۆ ئازادبوون.‏\f* زیندووە و 
\q2 لە کۆتاییدا لەسەر زەوی ڕاست دەبێتەوە. 
\q1  
\v 26 پاش ئەوەی ئەم پێستەم لەناودەچێت، 
\q2 هەر لە جەستەی خۆم خودا دەبینم.\f + \fr 19:26 \ft لە عیبری دەگوترێت (لە جەستەکەمەوە)، هەروەها هەندێک لە وەرگێڕانەکان بە (جەستەم هەیە کە خودا دەبینم) وەریانگێڕاوە.‏\f* 
\q1  
\v 27 ئەوەی من بۆ خۆم دەیبینم و 
\q2 چاوەکانم تەماشا دەکەن، نەک یەکێکی دیکە، 
\q2 لە ناخمەوە تامەزرۆی ئەوەم! 
\b  
\q1  
\v 28 «ئەگەر ئێوە دەڵێن: ”چەند ڕاوی دەنێین، 
\q2 چونکە ڕەگی کێشەکە لەلای ئەوە،“ 
\q1  
\v 29 لە خۆتان بترسن لە ڕووی شمشێر، 
\q2 چونکە تووڕەیی سزای شمشێر دەهێنێت، 
\q2 ئیتر دەزانن کە دادوەری هەیە.» 
\c 20  
\s1 وەڵامی دووەمی چۆفەر 
\p  
\v 1 چۆفەری نەعماتیش وەڵامی دایەوە: 
\q1  
\v 2 «لەبەر جۆشانی ناخم، 
\q2 بیرکردنەوەکانم هانم دەدەن وەڵام بدەمەوە. 
\q1  
\v 3 گوێم لە سەرزەنشتەکانی تۆ دەبێت کە سووکایەتیم پێ دەکەیت، 
\q2 ڕۆحی تێگەیشتنم وام لێ دەکات وەڵام بدەمەوە. 
\b  
\q1  
\v 4 «ئایا لە کۆنەوە ئەمەت نەزانیوە، 
\q2 لەو کاتەوەی مرۆڤ لەسەر زەوی دانراوە؟ 
\q1  
\v 5 هاواری خۆشی خراپەکاران کورتە و 
\q2 خۆشی خوانەناس بۆ ساتێکە. 
\q1  
\v 6 هەرچەندە لووتبەرزی خوانەناس بگاتە ئاسمان و 
\q2 سەریشی لە هەور بدات، 
\q1  
\v 7 بەڵام وەک تەپاڵە خۆی بۆ هەتاهەتایە لەناودەچێت و 
\q2 ئەوانەی بینیویانە دەڵێن: ”کوا؟“ 
\q1  
\v 8 وەک خەون دەفڕێت و ئیتر نامێنێت، 
\q2 وەک مۆتەکەیەک دەردەکرێت. 
\q1  
\v 9 چاوێک کە بینیویەتی دیسان نایبینێتەوە، 
\q2 جارێکی دیکە شوێنەکەشی نابینرێت. 
\q1  
\v 10 کوڕەکانی هەوڵ دەدەن هەژاران ڕازی بکەن؛ 
\q2 دەستەکانی سامانەکەی دەدەنەوە. 
\q1  
\v 11 ئێسکەکانی پڕ لە گەنجیێتین، 
\q2 بەڵام ئەو گەنجیێتییە لەگەڵیدا لەناو خاک ڕادەکشێت. 
\b  
\q1  
\v 12 «کە خراپە لەناو دەمی شیرین بێت و 
\q2 لەژێر زمانی بیشارێتەوە، 
\q1  
\v 13 دڵی پێی سووتاو و بەجێی نەهێشت، 
\q2 بەڵکو لەناو گەرویدا بەندی کرد، 
\q1  
\v 14 بەڵام نانەکەی لەناو ڕیخۆڵەکانی دەگۆڕێت، 
\q2 دەبێتە تاڵی ژەهری مار لەناو سکی. 
\q1  
\v 15 سامانێکی قووت دا و دەیڕشێنێتەوە؛ 
\q2 خودا لەناو سکی وەدەری دەنێت. 
\q1  
\v 16 ژەهری مار دەمژێت؛ 
\q2 زمانی مار دەیکوژێت. 
\q1  
\v 17 جۆگەکان نابینێت، 
\q2 ڕووبارە ڕۆیشتووەکانی هەنگوین و قەیماغ. 
\q1  
\v 18 بەری ماندووبوونەکەی دێنێتەوە و قووتی نادات، 
\q2 لە قازانجی بازرگانییەکەی خۆشی نابینێت. 
\q1  
\v 19 لەبەر ئەوەی هەژارانی وردوخاش کرد و بەجێی هێشتن؛ 
\q2 دەستی بەسەر ماڵێکدا گرت کە بنیادی نەنابوو. 
\b  
\q1  
\v 20 «بێگومان لە ناخیدا نەیزانی بەس چییە؛ 
\q2 ئەوەی ئارەزووی دەکات دەربازی ناکات. 
\q1  
\v 21 خواردنەکەی پاشماوەی نییە؛ 
\q2 ئیتر خێروخۆشییەکەی بەردەوام نابێت. 
\q1  
\v 22 لەوپەڕی سەڵتەنەتیدا تووشی تەنگانە دەبێت، 
\q2 دەستی هەموو ڕەنجدەرێکی دێتە سەر. 
\q1  
\v 23 لە کاتێکدا سکی خۆی پڕ دەکات، 
\q2 خودا گڕی تووڕەیی خۆی بۆ دەنێرێت و 
\q2 وەکو باران بەسەریدا دەیبارێنێت. 
\q1  
\v 24 لە چەکی ئاسنەوە ڕادەکات و 
\q2 تیری بڕۆنز دەیبڕێت. 
\q1  
\v 25 تیرەکەی ڕاکێشا و لە پشتییەوە هاتە دەرەوە، 
\q2 نووکی بریسکەدار زراوی بڕی. 
\q1 ترسی بەسەرەوەیە؛ 
\q2  
\v 26 هەموو تاریکییەک بۆ گەنجینەکانی شاردراوەتەوە. 
\q1 ئاگرێک دەیخوات فووی لێ نەکراوە، 
\q2 ئەوەی لە چادرەکەی مابێتەوە لووشی دەدات. 
\q1  
\v 27 ئاسمان تاوانەکەی ئاشکرا دەکات، 
\q2 زەوی لێی ڕادەپەڕێت. 
\q1  
\v 28 لەو ڕۆژەی کە خودا تووڕەییەکەی دەبارێنێت، 
\q2 لافاوێک ماڵەکەی دەبات. 
\q1  
\v 29 ئەمە بەشی کەسی خراپە لە خوداوە، 
\q2 میراتی دیاریکراوە لە خوداوە.» 
\c 21  
\s1 قسەی حەوتەمی ئەیوب 
\p  
\v 1 ئەیوبیش وەڵامی دایەوە: 
\q1  
\v 2 «بە گوێگرتن گوێ لە قسەکانم بگرن؛ 
\q2 با ئەمە ببێتە دڵنەواییتان. 
\q1  
\v 3 بەرگەم بگرن کە قسە دەکەم و 
\q2 پاش قسەکانم گاڵتە بکەن. 
\b  
\q1  
\v 4 «ئایا من سکاڵاکەم لە مرۆڤە؟ 
\q2 بۆچی ئارامیم لێ نەبڕێت؟ 
\q1  
\v 5 ڕووم لێ بکەن، واقتان وڕبمێنێت و 
\q2 دەست بخەنە سەر دەمتان. 
\q1  
\v 6 کاتێک بەبیرم دێتەوە دەتۆقم؛ 
\q2 موچڕکە بە لەشمدا دێت. 
\q1  
\v 7 بۆچی بەدکاران دەژین و پیر دەبن، 
\q2 هەروەها بە هێزەوە زاڵ دەبن؟ 
\q1  
\v 8 نەوەیان لەبەردەمیان لەگەڵیان ڕاوەستاوە، 
\q2 وەچەیان لەبەرچاویانە. 
\q1  
\v 9 ماڵەکانیان لە ترس دڵنیایە؛ 
\q2 کوتەکی خودا بەسەریانەوە نییە. 
\q1  
\v 10 گایەکەیان دەپەڕێت و هەڵە ناکات؛ 
\q2 مانگاکەیان ئاوس دەبێت و لە باری ناچێت. 
\q1  
\v 11 منداڵەکانیان وەک مەڕ بەڕەڵا دەکرێن؛ 
\q2 شیرەخۆرەکانیان سەما دەکەن. 
\q1  
\v 12 دەف و قیسارە بەدەستەوە دەگرن؛ 
\q2 بە دەنگی دووزەلە دڵخۆش دەبن. 
\q1  
\v 13 ڕۆژگاریان بە خێروخۆشی بەسەردەبەن و 
\q2 بە ئارامییەوە بۆ ناو جیهانی مردووان شۆڕ دەبنەوە. 
\q1  
\v 14 لەگەڵ ئەوەشدا بە خودا دەڵێن: ”لێمان دوور بکەوە! 
\q2 دڵخۆش نابین بە ناسینی ڕێگاکانت. 
\q1  
\v 15 توانادارەکە کێیە هەتا خزمەتی بکەین؟ 
\q2 سوودی چی دەبینین کە لێی بپاڕێینەوە؟“ 
\q1  
\v 16 بەڵام خێروخۆشییان لە دەستی خۆیان نییە، 
\q2 با ڕاوێژی بەدکاران لێم دوور بێت. 
\b  
\q1  
\v 17 «چەند کەم چرای بەدکاران دەکوژێتەوە و 
\q2 کارەساتیان بەسەردێت، 
\q2 یان خودا لە تووڕەیی خۆیدا ئازاری کردووە بە بەشیان؟ 
\q1  
\v 18 یان وەک کا بن لەبەردەم با و 
\q2 وەک ئەو سەرکۆزەرەی ڕەشەبا بردوویەتی؟ 
\q1  
\v 19 دەگوترێت: ”خودا تاوانی بەدکاران بۆ کوڕەکانیان هەڵدەگرێت.“ 
\q2 با سزای گیانی خۆیان بدات تاوەکو بزانن! 
\q1  
\v 20 با چاوەکانیان لەناوچوونەکەیان ببینن، 
\q2 لە جامی تووڕەیی خودای هەرە بەتوانا بخۆنەوە، 
\q1  
\v 21 چونکە لەدوای ئەوان، کە ژمارەی مانگەکانیان تەواو دەبێت، 
\q2 ئایا گوێ بە کەسوکاریان دەدەن؟ 
\b  
\q1  
\v 22 «ئایا خودا فێری زانین دەکرێت، 
\q2 ئەو کە دادوەری پایەدارەکان دەکات؟ 
\q1  
\v 23 کەسانێک هەن لەوپەڕی تەندروستیدا دەمرن، 
\q2 کاتێک بە تەواوی دڵنیا و ئارامن، 
\q1  
\v 24 لەشیان ساغن و 
\q2 مۆخی ناو ئێسکەکانیان هێشتا تەڕە. 
\q1  
\v 25 کەسانێکی دیکەش بە پەژارەوە دەمرن و 
\q2 تامی خێروخۆشییان نەکردووە. 
\q1  
\v 26 هەردووکیان پێکەوە لەناو گڵ ڕادەکشێن و 
\q2 کرم دایاندەپۆشێت. 
\b  
\q1  
\v 27 «بیرکردنەوەی ئێوە باش دەزانم و 
\q2 ئەو پیلانانەی بۆ ستەملێکردنم داتانناوە، 
\q1  
\v 28 چونکە دەڵێن: ”کوا ماڵی گەورە پیاوەکە؟ 
\q2 کوا چادری نشینگەی خراپەکاران؟“ 
\q1  
\v 29 ئایا پرسیارتان لە ڕێبواران نەکردووە و 
\q2 سەرنجتان نەداوەتە هەواڵەکانیان؟ 
\q1  
\v 30 بەدکار لە ڕۆژی کارەسات هەڵدێت، 
\q2 ئایا لە ڕۆژی تووڕەیی دەرباز دەبێت؟ 
\q1  
\v 31 کێ بەرەو ڕوو لەسەر ڕەفتارەکەی سەرزەنشتی دەکات؟ 
\q2 کێ سزای دەدات لەسەر ئەوەی کردوویەتی؟ 
\q1  
\v 32 ئەو بەرەو گۆڕەکان دەبردرێت و 
\q2 لەسەر گۆڕستان شەوارە دەگرێت. 
\q1  
\v 33 قوڕی دۆڵەکە شیرینە بۆ ئەو؛ 
\q2 هەموو مرۆڤ بەدوایەوە دەڕۆن و 
\q2 لەپێشیشیەوە بەبێ ژمارە. 
\b  
\q1  
\v 34 «ئیتر چۆن بە قسەی پڕوپووچ دڵنەواییم دەدەنەوە؟ 
\q2 لە وەڵامەکانتان تەنها بێوەفایی دەبینم!» 
\c 22  
\s1 وەڵامی سێیەمی ئەلیفاز 
\p  
\v 1 ئەلیفازی تێمانیش وەڵامی دایەوە: 
\q1  
\v 2 «ئایا مرۆڤ سوودی بۆ خودا هەیە؟ 
\q2 تەنانەت کەسێکی دانا، ئایا سوودی بۆ خودا هەیە؟ 
\q1  
\v 3 ئایا خۆشی تێدایە بۆ توانادارەکە کە تۆ ڕاستودروست بیت؟ 
\q2 ئەگەر ڕەفتارەکەشت بێ کەموکوڕی بێت، ئایا قازانجی بۆ خودا تێدایە؟ 
\b  
\q1  
\v 4 «ئایا لەسەر لەخواترسییەکەت سەرزەنشتت دەکات و 
\q2 تۆ دەداتە دادگا؟ 
\q1  
\v 5 ئایا خراپەکانت زۆر نین و 
\q1 تاوانەکانیشت بێ کۆتایی نین؟ 
\q1  
\v 6 بەبێ هۆ بارمتەت لە برای خۆت وەرگرت و 
\q2 جلت لەبەر داکەند ڕووتت کردەوە. 
\q1  
\v 7 ئاوت نەدا بە تینوو و 
\q2 ئامادە نەبووی نان بدەیتە برسی، 
\q1  
\v 8 هەرچەندە تۆ خاوەن زەوی و پیاوێکی بە توانا بووی، 
\q2 کە وەک کەسێکی ناودار تێدا نیشتەجێ بوو. 
\q1  
\v 9 بێوەژنانت بە دەستبەتاڵی بەڕێکرد و 
\q2 دەستی هەتیوانت شکاند. 
\q1  
\v 10 لەبەر ئەوە چواردەورت تەڵەیە و 
\q2 ترسی لەناکاو دەتتۆقێنێت، 
\q1  
\v 11 لەبەر ئەوەش ئەوەندە تاریک بووە کە نابینیت و 
\q2 لافاوێک داتدەپۆشێت. 
\b  
\q1  
\v 12 «ئایا خودا لە بەرزی ئاسمان نییە؟ 
\q2 سەیری لووتکەی ئەستێرەکان بکە چەند خۆیان بڵند گرتووە! 
\q1  
\v 13 بەڵام تۆ دەڵێیت: ”خودا چی دەزانێت؟ 
\q2 ئایا لە پشت هەوری ڕەشەوە دادوەری دەکات؟ 
\q1  
\v 14 هەورەکان پەردەن بۆ ئەو ئیتر نامانبینێت 
\q2 کە بەسەر بازنەی ئاسمان هاتوچۆ دەکات.“ 
\q1  
\v 15 ئایا تۆش بەو ڕێگا کۆنەدا دەڕۆیت 
\q2 کە خراپەکاران پێیدا ڕۆیشتوون؟ 
\q1  
\v 16 ئەوانەی پێشوەخت دەستیان بەسەردا گیرا، 
\q2 ڕووبار بەسەر بناغەکەیاندا ڕژا. 
\q1  
\v 17 ئەوانەی بە خودایان گوت: ”لێمان دوور بکەوە! 
\q2 خودای هەرە بەتوانا چیمان لەگەڵ دەکات؟“ 
\q1  
\v 18 بەڵام ئەو بوو کە ماڵەکانی ئەوانی پڕکردووە لە خێروخۆشی، 
\q2 با ڕاوێژی خراپەکاران لێم دوور بێت. 
\q1  
\v 19 ڕاستودروستان کە وێرانییان دەبینن، دڵخۆش دەبن، 
\q2 بێگەردیش گاڵتەیان پێ دەکات: 
\q1  
\v 20 ”بێگومان بەرهەڵستکارانمان لەناودەچن و 
\q2 سامانەکەشیان ئاگر دەیخوات.“ 
\b  
\q1  
\v 21 «تکایە لەگەڵ خودا ڕێک بکەوە و لە ئاشتی بە، 
\q2 بەمە خێرۆخۆشیت بۆ دێت. 
\q1  
\v 22 تکایە فێرکردنەکان لە دەمیەوە وەربگرە و 
\q2 قسەکانی بخە دڵتەوە. 
\q1  
\v 23 ئەگەر بگەڕێیتەوە بۆ لای خودای هەرە بەتوانا بنیاد دەنرێیتەوە، 
\q2 ئەگەر ستەم لە چادرەکەت دووربخەیتەوە، 
\q1  
\v 24 ئەگەر زێڕ فڕێبدەیتە سەر خۆڵ و 
\q2 زێڕی ئۆفیر بۆ ناو بەردی شیوەکان، 
\q1  
\v 25 ئەو کاتە توانادارەکە دەبێت بە زێڕەکەت و 
\q2 بە زیوی گرانبەها بۆ تۆ. 
\q1  
\v 26 بێگومان ئیتر خۆشی لە توانادارەکە دەبینیت، 
\q2 ڕووت لە خودا دەکەیت. 
\q1  
\v 27 نوێژی بۆ دەکەیت و گوێت لێ دەگرێت، 
\q2 نەزرەکانت\f + \fr 22:27 \ft نەزر: داوا لە خودا دەکرێت بۆ ئەنجامدانی کارێک و پابەند دەکرێت بە مەرجێکەوە. ئەگەر خودا ئەو کارە بکات، ئەوا دەرئەنجام ئەمیش ئەو کارە ئەنجام دەدات کە پێیەوە پابەندی کردووە. بڕوانە \xt سەرژمێری 21‏:2‏\ft ‏.‏\f* بەجێدەهێنیت. 
\q1  
\v 28 بڕیار دەدەیت و بۆت جێبەجێ دەبێت، 
\q2 بەسەر ڕێگاکانت ڕووناکی دەدرەوشێتەوە. 
\q1  
\v 29 کاتێک خەڵک دەکەون تۆ دەڵێیت: ”هەڵیانبستێنەوە!“ 
\q2 ئەوا خودا ماتومەلوولەکان ڕزگار دەکات. 
\q1  
\v 30 تەنانەت ئەو کەسەی کە بێگەرد نییە دەربازی دەکات، 
\q2 بەهۆی دەستپاکییەکەت دەرباز دەبێت.» 
\c 23  
\s1 قسەی هەشتەمی ئەیوب 
\p  
\v 1 ئەیوبیش وەڵامی دایەوە: 
\q1  
\v 2 «هەروەها ئەمڕۆش سکاڵاکەم جەرگبڕە؛ 
\q2 لەگەڵ ناڵینم دەستی خودا لەسەرم هەر قورسە. 
\q1  
\v 3 خۆزگە دەمزانی چۆن پێی بگەم؛ 
\q2 دەهاتمە لای نشینگەکەی! 
\q1  
\v 4 بە ڕێکوپێکی کێشە دەخەمە بەردەمی، 
\q2 دەمم پڕ دەکەم لە بەهانە، 
\q1  
\v 5 هەتا بزانم چۆن وەڵامم دەداتەوە و 
\q2 لەوە تێبگەم کە پێم دەڵێت. 
\q1  
\v 6 ئایا بە زۆری هێز مشتومڕم لەگەڵ دەکات؟ 
\q2 نەخێر، بەڵکو پەلکێشی دادگام ناکات. 
\q1  
\v 7 لەوێ کەسی ڕاست بەهانەی بۆ دەهێنایەوە و 
\q2 بۆ هەتاهەتایە لە دەست دادەورەکەم دەرباز دەبووم. 
\b  
\q1  
\v 8 «بەڵام ئەگەر بەرەو ڕۆژهەڵات بچم لەوێ نییە، 
\q2 بەرەو ڕۆژئاواش هەستی پێ ناکەم. 
\q1  
\v 9 کاتێک لە باکوور کار دەکات، بەرچاوم ناکەوێت؛ 
\q2 کاتێک بەرەو باشوور دەسووڕێتەوە، نایبینم. 
\q1  
\v 10 بەڵام ڕێگام دەزانێت، 
\q2 دوای ئەوەی تاقیم دەکاتەوە وەک زێڕ دەردەچم. 
\q1  
\v 11 پێیەکانم بە هەمان هەنگاوی ئەو ڕۆیشتوون، 
\q2 ڕێگای ئەوم گرتەبەر و لام نەدا. 
\q1  
\v 12 لە فەرمانەکانی زمانی ئەو لام نەداوە؛ 
\q2 لە نانی پێویستی خۆم زیاتر قسەکانی دەمی ئەوم لە گەنجینەی دڵم هەڵگرتووە. 
\b  
\q1  
\v 13 «بەڵام ئەو تاک و تەنهایە و کێ ڕێی لێ دەگرێت؟ 
\q2 ئەوەی ئارەزووی لێ بێت، دەیکات. 
\q1  
\v 14 فەرزی خۆی لە دژی من جێبەجێ دەکات، 
\q2 پلانی وەک ئەمانەش زۆرە لەلای. 
\q1  
\v 15 لەبەر ئەوە لەبەردەمی دەتۆقم؛ 
\q2 سەرنج دەدەم و لێی دەترسم. 
\q1  
\v 16 خودا دڵی بێهێز کردم؛ 
\q2 توانادارەکە منی تۆقاند. 
\q1  
\v 17 لەگەڵ ئەوەشدا تاریکی و تەمە چڕەکەش 
\q2 کە ڕوخساری داپۆشیم بێدەنگم ناکات. 
\b  
\c 24  
\q1  
\v 1 «بۆچی خودای هەرە بەتوانا کاتەکانی دادگاییکردنی خراپەکاران دیاری ناکات؟ 
\q2 بۆچی خواناسەکان ئەو ڕۆژانە نابینن؟ 
\q1  
\v 2 خراپەکاران سنوور دەگوازنەوە، 
\q2 دەست بەسەر مێگەلێکدا دەگرن و دەیلەوەڕێنن. 
\q1  
\v 3 گوێدرێژی هەتیوان دەدەنە پێش خۆیان و 
\q2 گای بێوەژن وەک بارمتە دەبەن. 
\q1  
\v 4 نەداران لەسەر ڕێگا دەردەکەن، 
\q2 هەژارانی خاکەکە ناچار دەکەن خۆیان بشارنەوە. 
\q1  
\v 5 هەژاران وەک کەرەکێوی لە چۆڵەوانی، 
\q2 بۆ گەڕان بەدوای خواردندا دەچن، 
\q2 دەشتودەریش نان بۆ منداڵەکانیان دابین دەکات. 
\q1  
\v 6 لە کێڵگە ئالیکی خۆیان دروێنە دەکەن، 
\q2 لە ڕەزی خراپەکار هەڵدەگرنەوە. 
\q1  
\v 7 بە ڕووتی بەبێ جل سەر دەنێنەوە، 
\q2 هیچ بەرگێکیان نییە لە سەرمادا. 
\q1  
\v 8 لەبەر نەبوونی پەناگا بە بارانی چیاکان تەڕ دەبن و 
\q2 خۆیان بە تاشەبەردەوە دەگرن. 
\q1  
\v 9 بەدکار هەتیو لە مەمکان دەڕفێنن، 
\q2 منداڵی ساوای هەژار وەک بارمتە دەگرن. 
\q1  
\v 10 نەدار بە ڕووتی دەڕۆن، بەبێ جل، 
\q2 بە برسیێتی کۆڵەکان هەڵدەگرن. 
\q1  
\v 11 لەنێو کەڵەکی زەوییەکان زەیت دەگوشن، 
\q2 بە پێیان گوشەرەکان دەپەستن و تینوو دەبن. 
\q1  
\v 12 ئەوانەی لەناو شار لەناودەچن دەناڵێنن، 
\q2 گیانی برینداران بۆ فریاکەوتن هاوار دەکەن، 
\q2 بەڵام خودا هیچ کەس بە خراپەکاری تاوانبار ناکات. 
\b  
\q1  
\v 13 «ئەوانە کە لە ڕووناکی یاخین، 
\q2 نە ڕێگاکانی دەزانن و 
\q2 نە لە ڕێڕەوەکانی دەمێننەوە. 
\q1  
\v 14 بکوژ لەگەڵ ڕووناکی هەڵدەستێت و 
\q2 هەژار و نەدار دەکوژێت؛ 
\q2 بە شەویش بۆ دزی دەچێت. 
\q1  
\v 15 چاوی داوێنپیسیش تێبینی تاریکوڕوونی دەکات؛ 
\q2 دەڵێت: ”هیچ چاوێک چاودێریم ناکات،“ 
\q2 ڕووپۆشێک لەسەر ڕووی دادەنێت. 
\q1  
\v 16 لە تاریکیدا ماڵ دەبڕن، 
\q2 لە ڕۆژیشدا دەرگا لەسەر خۆیان دادەخەن؛ 
\q2 ڕووناکی ناناسن. 
\q1  
\v 17 تاریکی شەو بەیانییە لەلای ئەوان، 
\q2 هاوڕێی تۆقێنەرەکانی تاریکین. 
\b  
\q1  
\v 18 «لەگەڵ ئەوەشدا ئەوانە کەفن لەسەر ڕووی ئاوەکان؛ 
\q2 بەشیان لە زەوی نەفرەت لێکراوە، 
\q2 لەبەر ئەوە کەس ناچێتە ڕەزەکان. 
\q1  
\v 19 وەک چۆن وشکەساڵی و گەرما ئاوی بەفر دەبات، 
\q2 جیهانی مردووانیش گوناهباران دەڕفێنێت. 
\q1  
\v 20 سکی دایک لەبیریان دەکات و 
\q2 کرم تامی دەمی پێیان خۆش دەکات؛ 
\q1 ئیتر یادی خراپەکار ناکرێتەوە و 
\q2 وەک دار دەشکێت. 
\q1  
\v 21 لەگەڵ نەزۆک کە منداڵی نەبووە بە خراپی هەڵسوکەوت دەکەن، 
\q2 هیچ چاکەیەک لەگەڵ بێوەژن ناکەن. 
\q1  
\v 22 بەڵام خودا بە هێزی خۆی پاڵەوانان دەگرێت؛ 
\q2 هەرچەندە هەڵدەستن بەڵام کەسیان لە ژیانی خۆی دڵنیا نابێت. 
\q1  
\v 23 دەشێت بیانهێڵێت بە ئاسوودەیی بژین، 
\q2 بەڵام چاوی لەسەر ڕێگاکانیانە. 
\q1  
\v 24 کەمێک پایەدار دەبن و ئیتر نامێنن؛ 
\q2 نزم دەبن و وەک هەمووان کۆدەکرێنەوە، 
\q2 وەک سەری گوڵەگەنم دەبڕێنەوە. 
\b  
\q1  
\v 25 «ئەگەر وا نییە، کێ بە درۆم دەخاتەوە و 
\q2 قسەکانم وەک هیچ لێ دەکات؟» 
\c 25  
\s1 وەڵامی سێیەمی بیلدەد 
\p  
\v 1 بیلدەدی شوحیش وەڵامی دایەوە: 
\q1  
\v 2 «دەسەڵات و شکۆ لەلای خودایە؛ 
\q2 ئەو بەرزاییەکانی ئاسمان بەرقەرار دەکات. 
\q1  
\v 3 ئایا هێزەکانی دەتوانرێت بژمێردرێن؟ 
\q2 ڕووناکییەکەی بەسەر کێدا هەڵنایەت؟ 
\q1  
\v 4 ئیتر چۆن مرۆڤ لەبەرچاوی خودا ڕاستودروست دەبێت؟ 
\q2 لەدایکبوو لە ژن چۆن بێتاوان دەبێت؟ 
\q1  
\v 5 ئەگەر لەبەرچاوی خودا تەنانەت مانگ ڕۆشن نییە و 
\q2 ئەستێرەکانیش بێگەرد نین، 
\q1  
\v 6 ئیتر چۆن مرۆڤ بێگەرد دەبێت کە مۆرانەیەکە، 
\q2 ئادەمیزاد کە کرمێکە!» 
\c 26  
\s1 قسەی نۆیەمی ئەیوب 
\p  
\v 1 ئەیوبیش وەڵامی دایەوە: 
\q1  
\v 2 «چۆن یارمەتی ئەوەت دا کە هێزی نییە! 
\q2 چۆن بازووی بێ توانات گرت و ڕزگار کرد! 
\q1  
\v 3 چۆن ڕاوێژت کرد بۆ ئەوەی دانایی نییە! 
\q2 چۆن زانینی زۆرت دەرخست! 
\q1  
\v 4 بە یارمەتی کێ وتەکانت ڕاگەیاند و 
\q2 ڕۆحی کێ لە زارتەوە قسەی کرد؟ 
\b  
\q1  
\v 5 «تارماییەکان لە جیهانی مردوواندا 
\q2 لە سامناکی خودا دەلەرزن. 
\q1  
\v 6 جیهانی مردووان لەبەردەم خودا ئاشکرایە، 
\q2 شوێنی لەناوچوون\f + \fr 26:6 \ft لەناوچوون: عیبری: \+tl ئەبەدۆن‏\+tl*. لە پەیمانی نوێ، ئەم وشەیە بە واتای (لەناوبەر) هاتووە، بڕوانە \xt ئاشکراکردن 11‏:9‏\ft ‏.‏\f* شاردراوە نییە. 
\q1  
\v 7 ئاسمانی باکوور بەسەر بۆشاییدا لێک دەکێشێت و 
\q2 زەوی لەسەر هیچ هەڵدەواسێت. 
\q1  
\v 8 ئاو لەناو هەورەکانی دەپێچێتەوە و 
\q2 هەور لەژێری نادڕێت. 
\q1  
\v 9 ڕووی مانگی چواردە شەوە دەشارێتەوە، 
\q2 هەوری خۆی بەسەردا بڵاو دەکاتەوە. 
\q1  
\v 10 ئاسۆی لەسەر ڕووی ئاوەکان کێشاوە 
\q2 وەک سنوور لەنێوان ڕووناکی و تاریکی. 
\q1  
\v 11 کۆڵەکەکانی ئاسمان دەلەرزن و 
\q2 لە سەرزەنشتکردنەکەی دەتۆقن. 
\q1  
\v 12 بە هێزی خۆی دەریا دەهەژێنێت و 
\q2 بە تێگەیشتنی خۆی زەبر لە ڕەهەڤ\f + \fr 26:12 \ft هێمایە بۆ میسر.‏\f* دەوەشێنێت. 
\q1  
\v 13 بە هەناسەی ئەو ئاسمان ساماڵە و 
\q2 دەستی ئەو مارە هەڵاتووەکەی پێکا. 
\q1  
\v 14 بێگومان ئەمانە شتە دەرەکییەکانی کارەکانی ئەون. 
\q2 هەواڵەکانی بە چرپە دێنە بەر گوێمان! 
\q2 ئیتر کێ لە هەورەتریشقەی هێزی تێدەگات؟» 
\c 27  
\p  
\v 1 ئەیوب دیسان بە هەمان شێوە قسەی کردەوە و گوتی: 
\q1  
\v 2 «بە گیانی خودا کە مافی خۆمی لێم داماڵیوە، 
\q2 سوێند بە توانادارەکە کە ناخی منی تاڵکردووە، 
\q1  
\v 3 هەتا ئەو کاتەی کە ژیانم لەبەر بێت، 
\q2 هەناسەی خودا لە لووتمدا بێت، 
\q1  
\v 4 لێوەکانم بە خراپە نادوێن و 
\q2 زمانم بە فێڵ ناگەڕێت. 
\q1  
\v 5 لە من بەدوور بێت بڵێم کە ڕاستییەکەی لای ئێوەیە، 
\q2 هەتا ئەو کاتەی ژیان بەدەستەوە دەدەم دروستی لە خۆم دانابڕم. 
\q1  
\v 6 دەستم بە ڕاستودروستی خۆمەوە گرتووە و شلی ناکەم، 
\q2 بە درێژایی ژیانم ویژدانم سەرزەنشتم ناکات. 
\b  
\q1  
\v 7 «با دوژمنم وەک بەدکار بێت و 
\q2 بەرهەڵستکارم وەک زۆردار بێت. 
\q1  
\v 8 خوانەناس کە دەبڕدرێتەوە چ هیوایەکی هەیە، 
\q2 کاتێک خودا ژیانی دەڕفێنێت؟ 
\q1  
\v 9 ئایا خودا گوێی لە هاواری دەبێت 
\q2 کە تەنگانەی بەسەردا دێت؟ 
\q1  
\v 10 یان ئایا بە توانادارەکە دڵخۆش دەبێت؟ 
\q2 ئایا هەموو کاتێک داوا لە خودا دەکات؟ 
\b  
\q1  
\v 11 «من توانای خوداتان پێ دەناسێنم؛ 
\q2 کارەکانی توانادارەکە لە ئێوە ناشارمەوە. 
\q1  
\v 12 ئەوەتا ئێوە هەمووتان بینیتان، 
\q2 ئیتر بۆچی بە پووچی دەدوێن؟ 
\b  
\q1  
\v 13 «ئەمە بەشی کەسی بەدکارە لەلایەن خوداوە، 
\q2 میراتی ستەمکارە کە لە توانادارەکەوە وەریدەگرن. 
\q1  
\v 14 ئەگەر کوڕانی زۆر بوون ئەوا بۆ شمشێرن و 
\q2 نەوەکەشی تێر نان نابن. 
\q1  
\v 15 دەرد پاشماوەکەی دەخاتە ناو گۆڕ و 
\q2 بێوەژنەکانیان ناگرین. 
\q1  
\v 16 ئەگەر زیو وەک خۆڵ و 
\q2 جلوبەرگ وەک قوڕ کەڵەکە بکات، 
\q1  
\v 17 ئەوەی ئامادەی دەکات ڕاستودروست لەبەری دەکات، 
\q2 بێتاوان زیوەکەی دابەش دەکات. 
\q1  
\v 18 وەک قۆزاخەی مۆرانە ماڵەکەی خۆی بنیاد دەنێت و 
\q2 وەک کەپرێک چاودێر دروستی بکات. 
\q1  
\v 19 بە دەوڵەمەندی ڕادەکشێت، بەڵام جارێکی دیکە نایکات؛ 
\q2 کە چاوی دەکاتەوە هیچی نەماوە. 
\q1  
\v 20 کارەساتەکان وەک لافاو پێی دەگەن، 
\q2 ڕەشەبایەک بە شەو دەیڕفێنێت. 
\q1  
\v 21 بای ڕۆژهەڵات هەڵیدەگرێت و دەڕوات، 
\q2 لە شوێنی خۆی ڕایدەماڵێت. 
\q1  
\v 22 لەبەردەم با بەهێزەکە هەڵدێت، 
\q2 بایەکەش بەبێ بەزەیی لێی دەدات. 
\q1  
\v 23 بە گاڵتەپێکردنەوە چەپڵەی بۆ لێدەدات، 
\q2 بە فیکەلێدان لە جێی خۆیەوە دەریدەکات.» 
\c 28  
\s1 دانایی لەکوێ دەدۆزرێتەوە؟ 
\q1  
\v 1 زیو کانی هەیە و 
\q2 بۆ زێڕیش شوێنێک هەیە بۆ پاڵاوتنی. 
\q1  
\v 2 ئاسن لە خۆڵ دەردەهێنرێت، 
\q2 مسیش لە توانەوەی بەرد. 
\q1  
\v 3 مرۆڤ کۆتایی بە تاریکی دەهێنێت؛ 
\q2 لەناو تاریکی سێبەری مەرگ 
\q2 بۆ بەردی کانزایی دوورترین کون و کەلەبەرەکان دەپشکنن. 
\q1  
\v 4 کانێکی لێدا دوور لە خەڵکی، 
\q2 لە شوێنێکی لەبیرکراو لەلایەن ڕێبوارانەوە؛ 
\q2 شۆڕ کرانەوە و دوور لە خەڵکی جۆلانەیان پێکرا. 
\q1  
\v 5 زەوی ئەوەی کە نانی لێوە دەردەهێنرێت، 
\q2 لە ژێرەوە دەگۆڕدرێت بە چەشنی ئاگر؛ 
\q1  
\v 6 بەردەکانی یاقووتی شینی\f + \fr 28:6 \ft یاقووتی شین: دەشێت لاجیوەرد بێت.‏\f* تێدایە و 
\q2 لە خۆڵەکەیدا زێڕ هەیە. 
\q1  
\v 7 ڕێگایەک کە مەلە گۆشتخۆرەکان پێی نازانن و 
\q2 چاوی هەڵۆ نایبینێت. 
\q1  
\v 8 ئاژەڵە دڕندەکان پێیدا نەڕۆیشتوون، 
\q2 شێر پێیدا تێنەپەڕیوە. 
\q1  
\v 9 مرۆڤ دەستدرێژی دەکاتە سەر بەرد، 
\q2 بنکەی چیاکان دەردەخات. 
\q1  
\v 10 لە تاشەبەردەکان تونێل دەکات؛ 
\q2 چاوەکانی هەموو شتێکی گرانبەها دەبینێت. 
\q1  
\v 11 ئاودزی ڕووبارەکان دەپشکنێت و 
\q2 ئەوەی شاراوەیە دەیخاتە بەر ڕووناکی. 
\b  
\q1  
\v 12 بەڵام دانایی لەکوێ دەدۆزرێتەوە و 
\q2 تێگەیشتن لەکوێ نیشتەجێیە؟ 
\q1  
\v 13 مرۆڤ نرخەکەی نازانێت و 
\q2 لە خاکی زیندوواندا نادۆزرێتەوە. 
\q1  
\v 14 قووڵایی ژێر زەوی\f + \fr 28:14 \ft بەپێی بیروباوەڕی خەڵکی ڕۆژهەڵاتی کۆن (قووڵایی ژێر زەوی) هەبوو کە سەرچاوەی کانیاو و ڕووبارەکان بوو. بڕوانە \xt پەیدابوون 7‏:11‏\ft ‏.‏\f* دەڵێت: «لەناو مندا نییە،» 
\q2 دەریا دەڵێت: «لەلای من نییە.» 
\q1  
\v 15 دانایی نە زێڕی بێگەرد لە جیاتی دەدرێت و 
\q2 نە بە زیویش نرخەکەی دەکێشرێت. 
\q1  
\v 16 نە بە زێڕی ئۆفیر و نە بە بەردی عاشقبەندی گرانبەها و 
\q2 نە بە یاقووتی شین دەکێشرێت. 
\q1  
\v 17 نە زێڕ و نە بلور هاوتایەتی، 
\q2 نە بە دەفرێکی زێڕی بێگەرد دەگۆڕدرێتەوە. 
\q1  
\v 18 لە پاڵ ئەودا نە مەرجان و نە یەشب باسیان ناکرێت و 
\q2 نرخی دانایی لە یاقووت بەهادارترە. 
\q1  
\v 19 یاقووتی زەردی کوش هاوتای نابێت و 
\q2 بە زێڕی بێگەرد ناکێشرێت. 
\b  
\q1  
\v 20 ئیتر دانایی لەکوێ دەدۆزرێتەوە و 
\q2 تێگەیشتن لەکوێ نیشتەجێیە؟ 
\q1  
\v 21 لەبەرچاوی هەموو زیندووێک شاراوەیە و 
\q2 لەبەرچاوی باڵندەکانی ئاسمان داپۆشراوە. 
\q1  
\v 22 لەناوچوون و مردن دەڵێن: 
\q2 «بە گوێی خۆمان هەواڵی ئەومان بیست.» 
\q1  
\v 23 خودا ڕێگاکەی تێدەگات و 
\q2 ئەو شوێنەکەی پێ دەزانێت. 
\q1  
\v 24 لەبەر ئەوەی ئەو تەماشای ئەوپەڕی زەوی دەکات و 
\q2 هەموو ژێر ئاسمان دەبینێت. 
\q1  
\v 25 کاتێک کێشی بۆ با دروستکرد و 
\q2 ئاوەکانی بە پێوانە پێوا، 
\q1  
\v 26 کاتێک بۆ باران یاسای دانا و 
\q2 بۆ دەنگی هەورەتریشقەش ڕێگا، 
\q1  
\v 27 ئەو کاتە دانایی بینی و باسی کرد، 
\q2 ئامادەی کرد و هەروەها تاقی کردەوە. 
\q1  
\v 28 بە مرۆڤی فەرموو: 
\q2 «بێگومان دانایی لە لەخواترسییەوەیە و 
\q2 لە خراپە لادانیش لە تێگەیشتنەوەیە.» 
\c 29  
\s1 بەرگری کۆتایی ئەیوب 
\p  
\v 1 ئەیوب سەرلەنوێ دەستی بە قسە کردەوە و گوتی: 
\q1  
\v 2 «خۆزگەم بە مانگەکانی ڕابردوو، 
\q2 بەو ڕۆژانەی کە خودا منی پاراست، 
\q1  
\v 3 کاتێک چراکەی خۆی لە سەرم هەڵکرد و 
\q2 بە ڕووناکی ئەو بەناو تاریکیدا دەڕۆیشتم! 
\q1  
\v 4 خۆزگە بەو ڕۆژانەی کە لە هەڕەتی هێز و توانادا بووم، 
\q2 هاوڕێیەتییە گیانی بەگیانییەکەم لەگەڵ خودا چادرەکەی منی بەرەکەتدار کردبوو، 
\q1  
\v 5 خودای هەرە بەتوانا هێشتا لەگەڵم بوو و 
\q2 منداڵەکانیشم لە چواردەورم بوون، 
\q1  
\v 6 کاتێک پێیەکانم بە شیر دەشوشت، 
\q2 تاشەبەردیش جۆگەکانی زەیتی بۆ هەڵدەقوڵاندم. 
\b  
\q1  
\v 7 «کاتێک بۆ لای دەروازەی شارەکە دەچووم و 
\q2 لە گۆڕەپانەکەدا دیوەخانی خۆم ئامادە دەکرد، 
\q1  
\v 8 گەنجەکان کە منیان دەبینی خۆیان دەشاردەوە، 
\q2 پیرانیش لەبەرم هەڵدەستان و ڕادەوەستان؛ 
\q1  
\v 9 پیاوە گەورەکان نەیاندەویست قسە بکەن، 
\q2 دەستیان دەخستە سەر دەمی خۆیان؛ 
\q1  
\v 10 پیاوماقوڵان دەنگیان لێ دەبڕا و 
\q2 زمانیان بە مەڵاشوویانەوە دەنووسا. 
\q1  
\v 11 ئەوەی گوێی لێم دەبوو ستایشی دەکردم، 
\q2 ئەو چاوەی کە دەیبینی شایەتی بۆ دەدام، 
\q1  
\v 12 چونکە ئەو هەژارانەی کە هاواریان بۆ دەهێنام و 
\q2 ئەو هەتیوانەی کە بێکەس بوون ڕزگارم دەکردن. 
\q1  
\v 13 ئەوانەی لە سەرەمەرگدا بوون بەرەکەتیان دەدامێ و 
\q2 دڵی بێوەژنم دەهێنایە قریوە. 
\q1  
\v 14 ڕاستودروستیم لەبەر دەکرد و دەمپۆشی؛ 
\q2 دادپەروەری کەوا و مێزەرەکەم بوو. 
\q1  
\v 15 دەبووم بە چاو بۆ نابینایان و 
\q2 بە قاچ بۆ شەلان. 
\q1  
\v 16 من بۆ نەداران باوکێک دەبووم و 
\q2 بەرگریم لە کەسێک دەکرد کە پێی ئاشنا نەبووم. 
\q1  
\v 17 کەڵبەی ستەمکارم وردوخاش دەکرد و 
\q2 لەنێو ددانەکانی نێچیرم دەڕفاند. 
\b  
\q1  
\v 18 «جا گوتم: ”لەناو لانەکەی خۆم ڕۆح بەدەستەوە دەدەم و 
\q2 وەک لم ڕۆژگارم زۆر دەبێت. 
\q1  
\v 19 ڕەگم بەرەو ئاوەکان درێژ دەبێتەوە، 
\q2 بە درێژایی شەو شەونم بەسەر چڵەکانمەوە دەبێت. 
\q1  
\v 20 شکۆمەندیم بە هەمیشەیی لەگەڵم دەبێت، 
\q2 کەوانەکەم لە دەستم نوێ دەبێتەوە.“ 
\b  
\q1  
\v 21 «گوێیان لە من دەگرت و چاوەڕێیان دەکرد 
\q2 لە کاتی ڕاوێژکردنم گوێیان بۆم شل دەکرد. 
\q1  
\v 22 لەدوای قسەکانم هیچیان لە دەم نەدەهاتە دەرەوە؛ 
\q2 قسەکانم دڵۆپەی بەسەریاندا کرد. 
\q1  
\v 23 چاوەڕێیان دەکردم وەک چاوەڕێی نمە باران بکەن و 
\q2 دەمیان دەکردەوە وەک بۆ بارانی بەهار. 
\q1  
\v 24 کاتێک لەگەڵیان ڕووخۆش دەبووم، باوەڕیان نەدەکرد؛ 
\q2 کاتێک ڕەزامەندیم پیشان دەدا، چاوەڕێی ئەوەیان نەدەکرد. 
\q1  
\v 25 ڕێگام بۆیان هەڵدەبژارد و وەک سەرۆک دادەنیشتم؛ 
\q2 وەک پاشایەک لەناو سوپا نیشتەجێ دەبووم، 
\q2 وەک ئەوەی دڵنەوایی شیوەنگێڕان دەداتەوە. 
\b  
\c 30  
\q1  
\v 1 «بەڵام ئێستا ئەوانەی لە من منداڵترن 
\q2 گاڵتەم پێ دەکەن، 
\q1 ئەوانەی بێزم نەدەهات باوکیان 
\q2 لەگەڵ سەگەکانی ناو ڕانەکەم دابنێم. 
\q1  
\v 2 دەبێت هێزی دەستیان چ سوودێکی بۆ من هەبێت؟ 
\q2 لەبەر ئەوەی سست بوون و لە کەڵک کەوتوون. 
\q1  
\v 3 لە دەستکورتی و لە برسیێتیدا لەڕ بوون؛ 
\q2 بە شەو بەناو زەوی وشکدا دەگەڕان، 
\q2 کە وێران و کاول بوون. 
\q1  
\v 4 ئەوانەی وشترالووک و گەڵایان لە دەوەنەکانەوە دەهێنا، 
\q2 ڕەگی دار گەز\f + \fr 30:4 \ft دارێکی گەڵا وردی لق باریکە، لقەکانی بۆ گسک بەکاردێت.‏\f* خۆراکیان بوو. 
\q1  
\v 5 لەنێو کۆمەڵەی خەڵک دەردەکران، 
\q2 هاواریان بەسەردا دەکردن وەک بەسەر دزدا هاوار بکەن. 
\q1  
\v 6 لەناو دۆڵە وشکەکان نیشتەجێ بوون، 
\q2 لە ئەشکەوت و لەناو تاشەبەردەکان. 
\q1  
\v 7 لەنێو دەوەنەکان زەڕین و 
\q2 لەژێر گەزگەزەکان خۆیان مات کرد. 
\q1  
\v 8 نەوەی گێلی، هەروەها نەوەی ئەوانەی بێ ناو بوون، 
\q2 لە خاکەکە تێهەڵدراون. 
\b  
\q1  
\v 9 «بەڵام ئێستا ئەو گەنجانە بە گۆرانی گاڵتەم پێ دەکەن؛ 
\q2 پەندم بەسەردا دەڵێن. 
\q1  
\v 10 قێزم لێ دەکەنەوە، دوورەپەرێزیم لێ دەگرن؛ 
\q2 لە تفەکانیان ڕووی من ناپارێزن. 
\q1  
\v 11 خودا پەتی کەوانەکەی منی بەرداوە و منی چەماندووەتەوە، 
\q2 جڵەوی لغاوەکەم بەدەستیانەوەیە، 
\q1  
\v 12 لەلای ڕاستم گەنجە لاسارەکان هێرش دەکەنە سەرم، 
\q2 پاشقولم لێ دەگرن و سەنگەر لە دژی من لێ دەدەن. 
\q1  
\v 13 ڕێگاکانم لێ تێکدەدەن، 
\q2 بۆ ژێرکەوتنم هاوکاری یەکتر دەکەن، 
\q2 کەس نییە پشتگیری من بکات. 
\q1  
\v 14 ئەوان دێن هەروەک لە کەلێنێکی فراوانەوە بێن، 
\q2 لەژێر وێرانیەوە خلۆر دەبنەوە. 
\q1  
\v 15 نەهامەتی بەسەرمدا وەرگەڕا، 
\q2 هەروەکو با ڕێزی منی برد، 
\q2 ئاسوودەییم وەک هەور تێپەڕی. 
\b  
\q1  
\v 16 «بە هێواشی ژیانم بەرە و کۆتایی دەچێت، 
\q2 کەوتمە ڕۆژانی زەلیلییەوە. 
\q1  
\v 17 شەوگار ئێسکەکانم لەناومدا کلۆر دەکات، 
\q2 ئازارەکانم پشوو نادەن. 
\q1  
\v 18 خودا بە زۆری هێزەکەی منی بە جلەکانم گرت و شێوەی گۆڕیم، 
\q2 وەک یەخەی کراسەکەم، منی پێچایەوە. 
\q1  
\v 19 فڕێیدامە ناو قوڕەوە، 
\q2 ڕەنگی خۆڵ و خۆڵەمێشم لێ نیشت. 
\b  
\q1  
\v 20 «ئەی خودا هاوارت بۆ دەهێنم و وەڵامم نادەیتەوە؛ 
\q2 ڕادەوەستم و ئاوڕم لێ نادەیتەوە. 
\q1  
\v 21 لەگەڵ مندا توند دەجوڵێیتەوە، 
\q2 بە توانای دەستەکانت دژایەتیم دەکەیت. 
\q1  
\v 22 دەمڕفێنیت و دەمدەیتە دەست ڕەشەبا؛ 
\q2 فڕێمدەدەیتە ناو زریانەوە. 
\q1  
\v 23 دەزانم بۆ مردن دەمگەڕێنیتەوە، 
\q2 بۆ ماڵی چاوەڕوانکراوی هەموو زیندووێک. 
\b  
\q1  
\v 24 «بێگومان کەس دەستدرێژی ناکاتە سەر مرۆڤێکی تێکشکاو، 
\q2 کاتێک لە تەنگانەیدا هاوار دەکات. 
\q1  
\v 25 ئایا بۆ لێقەوماوان نەگریام؟ 
\q2 ئایا بۆ نەدار گیانم خەمبار نەبوو؟ 
\q1  
\v 26 لەگەڵ ئەوەشدا، کە ئاواتەخوازی چاکە بووم، خراپە هات؛ 
\q2 چاوەڕوانی ڕووناکی بووم، تاریکی هات. 
\q1  
\v 27 هەناوم گڕی گرتووە و ناوەستێت، 
\q2 ڕۆژانی زەلیلی بەرەوپیرم دێن. 
\q1  
\v 28 ڕەش هەڵگەڕام بەڵام بەبێ خۆر؛ 
\q2 لەناو کۆمەڵ هەستام هاوارم کرد. 
\q1  
\v 29 بووم بە برای چەقەڵەکان و 
\q2 هاوڕێی کوندەپەپووەکان. 
\q1  
\v 30 پێستم ڕەش و هەڵوەری لەبەرم، 
\q2 لەشم لەبەر تایەکی توند دەسووتێت. 
\q1  
\v 31 قیسارەکەم بۆ لاوانەوەیە و 
\q2 شمشاڵەکەم بۆ دەنگی گریاوەکانە. 
\b  
\c 31  
\q1  
\v 1 «پەیمانم لەگەڵ چاوەکانم بەست، 
\q2 ئیتر چۆن تەماشای پاکیزەیەک بکەم؟ 
\q1  
\v 2 بەشی ئێمە لە خودا لە سەرەوە چییە، 
\q2 چ میراتێکمان هەیە لە توانادارەکەی ئاسمان؟ 
\q1  
\v 3 ئایا کارەسات بۆ بەدکار و 
\q2 بەڵا بۆ خراپەکار نییە؟ 
\q1  
\v 4 ئایا ئەو تەماشای ڕێگای من ناکات و 
\q2 هەموو هەنگاوەکانم ناژمێرێت؟ 
\b  
\q1  
\v 5 «ئەگەر لەگەڵ درۆ ملی ڕێم گرتبێتەبەر 
\q2 یان پێیەکانم پەلەیان کردبێت بەرەو فێڵ، 
\q1  
\v 6 با خودا لە تەرازووی ڕاستودروستیدا بمکێشێت و 
\q2 بزانێت کە کەموکوڕیم نییە. 
\q1  
\v 7 ئەگەر هەنگاوەکانم لە ڕێچکە لایانداوە، 
\q2 ئەگەر دڵم بەدوای چاوم کەوتووە، 
\q2 یان ئەگەر کردەوەکانم دەستەکانی منیان گڵاو کردووە، 
\q1  
\v 8 ئەوا ئەوەی من چاندم با کەسانی دیکە بیخۆن، 
\q2 با لقەکانم ڕیشەکێش بکرێن. 
\b  
\q1  
\v 9 «ئەگەر دڵم بەلای ژنێکدا فریوی خواردووە، 
\q2 یان لە بەردەرگای دراوسێکەم بۆسەم داناوە، 
\q1  
\v 10 با ژنەکەم دانەوێڵەی پیاوێکی دیکە بهاڕێت و 
\q2 با خەڵکانی دیکە بەسەریدا بچەمێنەوە. 
\q1  
\v 11 لەبەر ئەوەی ئەمە بێ ناموسییە، 
\q2 تاوانە و پێویستە دادگایی بکرێت. 
\q1  
\v 12 ئاگرێکە هەتا لەناوچوون\f + \fr 31:12 \ft بڕوانە \xt 26‏:6‏\ft .‏\f* دەخوات و 
\q2 هەموو دروێنەکەم ڕیشەکێش دەکات. 
\b  
\q1  
\v 13 «ئەگەر مافی خزمەتکار و کارەکەرەکەم ڕەت کردووەتەوە 
\q2 کاتێک لە دژی من سکاڵایان کردووە، 
\q1  
\v 14 ئەو کاتە چی بکەم لە کاتی ڕووبەڕووبوونەوەم لەگەڵ خودا؟ 
\q2 ئەگەر لێکۆڵینەوەم لەگەڵ بکرێت بە چی وەڵامی بدەمەوە؟ 
\q1  
\v 15 ئایا دروستکەری من لە سکدا دروستکەری ئەوانیش نییە؟ 
\q2 ئایا شێوەکێشمان لە سکی دایک یەک نییە؟ 
\b  
\q1  
\v 16 «ئەگەر هەژارانم لە مرازی خۆیان قەدەغە کردبێت 
\q2 یان چاوی بێوەژنم فەوتاندبێت، 
\q1  
\v 17 یان پارووەکەی خۆم بە تەنها خواردبێت، 
\q2 کە هەتیو لێی نەخواردبێت، 
\q1  
\v 18 بەڵام لە گەنجیمەوە وەک باوک بە هەتیوی بەخێوم کردووە و 
\q2 لە سکی دایکمەوە ڕێنمایی بێوەژنم کردووە. 
\q1  
\v 19 ئەگەر فەوتاوێکم بینیبێت لەبەر نەبوونی جل 
\q2 یان نەدارێکی بێ بەرگ، 
\q1  
\v 20 کە بە کەوڵی مەڕەکەم خۆیان گەرم نەکردووەتەوە 
\q2 ئیتر لە دڵیانەوە داوای بەرەکەتیان بۆ نەکردووم، 
\q1  
\v 21 ئەگەر پەیوەندیم لەگەڵ کاربەدەستانم بەکارهێناوە 
\q2 بۆ ئەوەی دەستدرێژی بکەمە سەر هەتیو، 
\q1  
\v 22 با شانم لە ئەستۆم بەربێتەوە و 
\q2 با قۆڵم لە جومگەکەیەوە بشکێت. 
\q1  
\v 23 لەبەر ئەوەی کارەسات لە خوداوە بەلامەوە تۆقێنەرە و 
\q2 لە ترسی شکۆیەکەی نەمتوانی شتی وا بکەم. 
\b  
\q1  
\v 24 «ئەگەر پشتم بە زێڕی خۆم بەستووە و 
\q2 ئەگەر بە زێڕی بێگەردم گوت: ”تۆ پاڵپشتی منی،“ 
\q1  
\v 25 ئەگەر دڵخۆش بووم کە سامانەکەم زۆر بوو و 
\q2 لەبەر ئەوەی زۆریان بەدەستهێناوە، 
\q1  
\v 26 ئەگەر تەماشای ڕووناکی خۆرم کردووە کاتێک درەوشاوەتەوە، 
\q2 یان مانگ کاتێک بە جوانییەوە دەڕوات 
\q1  
\v 27 تاوەکو دڵم بە نهێنی فریودراو و 
\q2 دەستم دەمی داپۆشی،\f + \fr 31:27 \ft مەبەست لە پەرستنی خۆر و مانگ.‏\f* 
\q1  
\v 28 ئەوا ئەمانەش تاوان دەبن و دەدرێن بە دادگا، 
\q2 چونکە ئەگەر شتی وام بکردایە ناپاک دەبووم بەرامبەر بە خودا لە سەرەوە. 
\b  
\q1  
\v 29 «ئەگەر بە بەڵای ناحەزەکەم دڵخۆش بووم 
\q2 یان بزەم گرت کە تووشی خراپە بوو، 
\q1  
\v 30 بەڵکو نەمهێشت مەڵاشووم گوناه بکات 
\q2 بەوەی کە بە نەفرەتەوە داوای ژیانی ئەو بکات؛ 
\q1  
\v 31 ئەگەر کەسانی ناو چادرەکەم هەرگیز نەیانگوتایە، 
\q2 ”کێ یەکێک دەهێنێت لە خواردنەکەی ئەیوب تێری نەخواردبێت؟“ 
\q1  
\v 32 ئاوارەیەک لە دەرەوە شەوی بەسەرنەبرد، 
\q2 دەرگای ماڵەکەم بۆ ڕێبوار کردەوە. 
\q1  
\v 33 ئەگەر وەک خەڵکی دیکە یاخیبوونی خۆم داپۆشیوە، 
\q2 بە شاردنەوەی تاوانەکانم لە باوەشی خۆم، 
\q1  
\v 34 بەهۆی ئەوەی لە قسەی خەڵک ترساوم، 
\q2 لە سووکایەتی پێکردنی خێڵەکان تۆقیوم، 
\q2 لەبەر ئەوەیە کە بێدەنگم و لە ماڵەوە دانیشتووم. 
\b  
\q1  
\v 35 «خۆزگە یەکێک دەبوو گوێی لێم دەگرت! 
\q2 ئەوەتا مۆری من، با خودای هەرە بەتوانا وەڵامم پێ بداتەوە؛ 
\q2 ئەوەی سکاڵا لە من دەکات با سکاڵانامەکەی پێشکەش بکات. 
\q1  
\v 36 بێگومان لەسەر شانم هەڵمدەگرت، 
\q2 دەمبەست وەک تاج بەسەرمەوە. 
\q1  
\v 37 ژمارەی هەنگاوەکانی خۆم پێی دەگوت، 
\q2 پێشکەشیشم دەکرد وەک بۆ فەرمانڕەوایەک. 
\b  
\q1  
\v 38 «ئەگەر زەوییەکەم هاواری کردووە لە دژی من و 
\q2 هەموو هێڵی جووتەکانی بە فرمێسک تەڕ دەبێت، 
\q1  
\v 39 ئەگەر بەروبوومەکەی ئەوم بەبێ پارە خواردووە 
\q2 یان گیانی کرێچییەکانیم کوژاندووەتەوە، 
\q1  
\v 40 با لە جێی گەنم دڕک بڕووێت و 
\q2 لە جێی جۆ زیوان.» 
\p وشەکانی ئەیوب تەواو بوون. 
\c 32  
\s1 ئەلیهو 
\p  
\v 1 ئیتر ئەو سێ پیاوە وازیان لە وەڵامدانەوەی ئەیوب هێنا، چونکە ئەو خۆی بە ڕاست دەزانی.  
\v 2 بەڵام ئەلیهوی کوڕی بەرەخێلی بووزی لە هۆزی ڕام لە ئەیوب تووڕە بوو. تووڕەیی جۆشا، چونکە ئەیوب خۆی بە بێتاوان دادەنا و گلەیی لە خودا دەکرد.  
\v 3 لە سێ هاوڕێکەشی تووڕە بوو، چونکە لەگەڵ ئەوەی نەیاندەتوانی بە هیچ شێوەیەک بەرپەرچی ئەیوب بدەنەوە، ئەیوبیان تاوانبار کرد.  
\v 4 ئەلیهوش لەسەر ئەیوب ئارامی گرت، چونکە ئەوان لەو بە تەمەنتر بوون.  
\v 5 کاتێک ئەلیهو بینی هیچ وەڵامێک لە دەمی ئەو سێ پیاوەدا نییە، تووڕە بوو. 
\p  
\v 6 ئیتر ئەلیهوی کوڕی بەرەخێلی بووزی وەڵامی دایەوە: 
\q1 «من تەمەنم کەمە و 
\q2 ئێوەش پیرن؛ 
\q1 لەبەر ئەوە نەوێرام و ترسام 
\q2 بیروڕای خۆمتان پێ بڵێم. 
\q1  
\v 7 گوتم: ”با تەمەن قسە بکات و 
\q2 با زۆری ساڵان دانایی ڕابگەیەنن.“ 
\q1  
\v 8 بەڵام ڕۆحی مرۆڤ هەناسەی خودای هەرە بەتوانایە، 
\q2 ئەوە کە تێگەیشتن بە مرۆڤ دەبەخشێت. 
\q1  
\v 9 تەنها ئەوانەی تەمەن درێژن دانا نین و 
\q2 تەنها پیران نین کە لە دادوەری تێدەگەن. 
\b  
\q1  
\v 10 «لەبەر ئەوە دەڵێم: گوێم لێ بگرن؛ 
\q2 منیش بیروڕای خۆم ڕادەگەیەنم. 
\q1  
\v 11 ئەوەتا من ئارامم گرت لەسەر قسەکانتان، 
\q2 گوێم شل کرد بۆ بەهانەکانتان؛ 
\q1 هەتا قسەکانتان تاقی کردەوە 
\q2  
\v 12 لێتان وردبوومەوە. 
\q1 بەڵام کەستان بەڵگەتان لە دژی بەهانەی ئەیوب نەهێنایەوە و 
\q2 وەڵامی بەهانەکانی ئەوتان نەدایەوە. 
\q1  
\v 13 لەبەر ئەوە مەڵێن: ”داناییمان دۆزییەوە؛ 
\q2 با خودا بەرپەرچی ئەیوب بداتەوە، نەک مرۆڤ.“ 
\q1  
\v 14 ئەیوب قسەکانی ئاراستەی من نەکردووە و 
\q2 منیش بە قسەکانی ئێوە وەڵامی نادەمەوە. 
\b  
\q1  
\v 15 «واقیان وڕماوە و هیچ وەڵامیش نادەنەوە؛ 
\q2 قسەیان لێ داماڵرا. 
\q1  
\v 16 ئێستا کە بێدەنگن، ئایا دەبێت چاوەڕێ بکەم، 
\q2 کە لەوێ ڕادەوەستن بەبێ وەڵام؟ 
\q1  
\v 17 ئێستا منیش بەشی خۆم وەڵام دەدەمەوە؛ 
\q2 منیش بیروڕای خۆم ڕادەگەیەنم، 
\q1  
\v 18 چونکە پڕم لە قسەکردن و 
\q2 ڕۆحی ناخم تەنگاوم دەکات؛ 
\q1  
\v 19 ئەوەتا ناخم وەک شەرابێکە سەرەکەی نەکرابێتەوە، 
\q2 وەک مەشکەیەکی نوێیە خەریکە بدڕێت. 
\q1  
\v 20 قسە دەکەم با ئاهێکم بەبەردا بێتەوە؛ 
\q2 لێوەکانم دەکەمەوە و وەڵام دەدەمەوە. 
\q1  
\v 21 لایەنگری کەس ناکەم و 
\q2 مەرایی هیچ کەسێکیش ناکەم؛ 
\q1  
\v 22 چونکە زمانلووسی نازانم 
\q2 جارێ دروستکەرەکەم نامبات. 
\b  
\c 33  
\q1  
\v 1 «بەڵام ئەی ئەیوب، ئێستا گوێ لە قسەکانم بگرە! 
\q2 گوێ شل بکە بۆ هەموو وشەکانم. 
\q1  
\v 2 ئەوەتا من دەمم کردەوە؛ 
\q2 قسەکانم لەسەر زمانی منن. 
\q1  
\v 3 قسەکانم لە دڵی پاکمەوەن؛ 
\q2 زمانیشم بە دڵسۆزییەوە ئەوە دەردەبڕێت کە دەیزانم. 
\q1  
\v 4 ڕۆحی خودا دروستی کردم، 
\q2 هەناسەی توانادارەکە ژیانی پێ بەخشیم. 
\q1  
\v 5 ئەگەر دەتوانیت، وەڵامم بدەوە و 
\q2 هەستە سەرپێ و کێشەکەت بخەرە بەردەمم. 
\q1  
\v 6 لەبەرچاوی خودا منیش هەروەکو تۆم، 
\q2 لە قوڕ دروستکراوم. 
\q1  
\v 7 ناشێت شەوکەتم بتترسێنێت و 
\q2 زۆرکردنم لێت بارت گران بکات. 
\b  
\q1  
\v 8 «تۆ لەبەردەمم گوتت، 
\q2 من بە وردی گوێم لێت بوو، 
\q1  
\v 9 گوتت: ”من بێتاوانم بەبێ یاخیبوون، 
\q2 بێگەردم و تاوانم نییە. 
\q1  
\v 10 لەگەڵ ئەوەشدا خودا دەگەڕێت هەڵەم لێ بدۆزێتەوە و 
\q2 بە دوژمنی خۆی دامدەنێت. 
\q1  
\v 11 پێیەکانمی لەناو کۆت داناوە؛ 
\q2 چاودێری هەموو ڕێگاکانم دەکات.“ 
\b  
\q1  
\v 12 «بەڵام پێتان دەڵێم، لەمەدا ڕاست ناکەیت، 
\q2 چونکە خودا لە مرۆڤ مەزنترە. 
\q1  
\v 13 بۆچی سکاڵای لێ دەکەیت: 
\q2 ”وەڵامی هیچ کام لە وشەکانی مرۆڤ ناداتەوە؟“ 
\q1  
\v 14 بە ڕاستی خودا هەرجارەو بە ڕێگایەک دەدوێت، 
\q2 کەس ڕامانی ئەوە ناکات. 
\q1  
\v 15 لە خەون، لە بینینی شەودا، 
\q2 کاتێک هەموو خەڵک خەوی قورسیان لێدەکەوێت 
\q2 لە کاتی خەواڵووبوون لەناو جێگا، 
\q1  
\v 16 ئەو کاتە گوێی خەڵک دەکاتەوە و 
\q2 بە ئاگادارکردنەوەکانی دەیانتۆقێنێت، 
\q1  
\v 17 تاکو لە خراپەکردن بیانگەڕێنێتەوە و 
\q2 لە لووتبەرزیش بیانپارێزێت، 
\q1  
\v 18 هەتا لە کەوتنە ناو گۆڕ ڕزگاریان بکات، 
\q2 ژیانیشیان لە لەناوچوون بە شمشێر. 
\b  
\q1  
\v 19 «یان ئەگەر کەسێکی هەبێت لەناو جێگاکەی بە ئازار تەمبێ بکرێت و 
\q2 ململانێی ئێسکەکانیشی بەردەوامە، 
\q1  
\v 20 ئەو کاتە گیانی ڕقی لە نان دەبێتەوە و 
\q2 نەوسیشی لە خواردنی خۆش. 
\q1  
\v 21 گۆشتیان وا دەفەوتێت کە ئیتر نەبینرێت، 
\q2 ئێسکەکانیشیان کە شاردرابوونەوە ئێستا دیارن. 
\q1  
\v 22 گیانیان لە گۆڕ نزیک دەبنەوە، 
\q2 ژیانیشیان لە فریشتەی مەرگ. 
\q1  
\v 23 لەگەڵ ئەوەشدا ئەگەر لەلایان نێردراوێک هەبێت، 
\q2 پەیوەندی ڕێکخەرێک، یەک لە هەزار 
\q2 تاکو ڕاستودروستی بە مرۆڤ بناسێنێت، 
\q1  
\v 24 لەگەڵ ئەو کەسە میهرەبان دەبێت و بە خودا دەڵێت: 
\q2 ”بیانگەڕێنەوە با نەکەونە گۆڕ؛ 
\q2 کڕینەوەی ژیانی ئەوانم بۆ دۆزینەوە. 
\q1  
\v 25 با گۆشتیان لە گۆشتی منداڵ ناسکتر بێت؛ 
\q2 با ڕۆژانی گەنجیێتییان بگەڕێتەوە.“ 
\q1  
\v 26 ئەو کاتە ئەوانە داوا لە خودا دەکەن و لێیان ڕازی دەبێت، 
\q2 بە هاواری خۆشییەوە ڕووی خودا دەبینن، 
\q2 ئەویش پاداشتی ڕاستودروستی مرۆڤ دەداتەوە. 
\q1  
\v 27 دەچن بۆ لای کەسانی دیکە و دەڵێن: 
\q2 ”گوناهم کرد و ڕاستیم خواروخێچ کرد، 
\q2 بەڵام سزا نەدرام لەسەری. 
\q1  
\v 28 خودا منی کڕییەوە لە جیهانی مردووان، 
\q2 ئیتر ژیانم ڕووناکی دەبینێت.“ 
\b  
\q1  
\v 29 «خودا هەموو ئەمانە دەکات، 
\q2 دوو جار و سێ جار لەگەڵ مرۆڤ، 
\q1  
\v 30 بۆ ئەوەی بیانگەڕێنێتەوە لە کەوتنی ناو گۆڕ و 
\q2 تاوەکو بە ڕووناکی زیندووان ڕووناک بێتەوە. 
\b  
\q1  
\v 31 «جا گوێ شل بکە و گوێم لێ بگرە ئەیوب! 
\q2 بێدەنگ بە من قسە دەکەم. 
\q1  
\v 32 ئەگەر قسەت لەلایە وەڵامم بدەوە، 
\q2 قسە بکە! چونکە دەمەوێت ئەستۆپاکت بکەم. 
\q1  
\v 33 ئەگەر نا، تۆ گوێم لێ بگرە؛ 
\q2 بێدەنگ بە فێری داناییت دەکەم.» 
\c 34  
\p  
\v 1 ئیتر ئەلیهو گوتی: 
\q1  
\v 2 «گوێ لە قسەکانم بگرن دانایان، 
\q2 گوێم بۆ شل بکەن، ئەی ئەوانەی دەزانن، 
\q1  
\v 3 چونکە گوێ قسە تاقی دەکاتەوە 
\q2 وەک چۆن مەڵاشوو خواردن تام دەکات. 
\q1  
\v 4 با بۆ خۆمان دادگەری تاقی بکەینەوە و 
\q2 لەنێو خۆمان بزانین چی باشە. 
\b  
\q1  
\v 5 «ئەیوب گوتی: ”من ڕاستودروست بووم، 
\q2 بەڵام خودا مافی منی داماڵی. 
\q1  
\v 6 لە کاتی دادگاییم 
\q2 بە درۆ دەخرێمەوە و 
\q1 برینەکەم ساڕێژ نابێت 
\q2 لەگەڵ ئەوەی بێ یاخیبوونم.“ 
\q1  
\v 7 چ پیاوێک وەک ئەیوبە؟ 
\q2 سووکایەتیکردن وەک ئاو دەخواتەوە و 
\q1  
\v 8 پێکەوە لەگەڵ بەدکاران ملی ڕێ دەگرێت و 
\q2 لەگەڵ خراپەکاران دەڕوات؟ 
\q1  
\v 9 لەبەر ئەوەی گوتی: ”سوودی نییە بۆ مرۆڤ 
\q2 جێی ڕەزامەندی بێت لەلای خودا.“ 
\b  
\q1  
\v 10 «لەبەر ئەوە گوێم لێ بگرن، ئەی تێگەیشتووان. 
\q2 خراپە لە یەزدان بە دوورە و 
\q2 ستەمیش لە خودای هەرە بەتوانا، 
\q1  
\v 11 چونکە مرۆڤ بەگوێرەی کردەوەکانی پاداشت دەداتەوە و 
\q2 پیاویش بەپێی ڕێگاکەی تووش دەکات. 
\q1  
\v 12 جا بە ڕاستی خودا خراپە ناکات، 
\q2 توانادارەکەش دادپەروەری خوار ناکاتەوە. 
\q1  
\v 13 کێ کردی بە لێپرسراو لەسەر زەوی و 
\q2 کێ لەسەر هەموو جیهان داینا؟ 
\q1  
\v 14 ئەگەر بیخاتە دڵی خۆیەوە 
\q2 ڕۆح و هەناسەی بۆ خۆی کۆبکاتەوە، 
\q1  
\v 15 هەموو مرۆڤ پێکەوە ڕۆح بەدەستەوە دەدەن و 
\q2 مرۆڤ بۆ خۆڵ دەگەڕێتەوە. 
\b  
\q1  
\v 16 «ئەگەر تێگەیشتنت هەیە، 
\q2 ئەمە ببیستە و بۆ دەنگی وشەکانم گوێ شل بکە. 
\q1  
\v 17 ئایا ئەوەی ڕقی لە دادپەروەرییە دەتوانێت فەرمانڕەوایەتی بکات؟ 
\q2 یان ئەوەی ڕاستودروست و مەزنە تاوانباری دەکەیت؟ 
\q1  
\v 18 ئایا خودا نییە کە بە پاشا دەفەرموێت: ”ئەی هیچوپووچ!“ 
\q2 یان بە پیاوماقوڵان: ”ئەی خراپەکاران!“ 
\q1  
\v 19 ئایا خودا نییە ئەوەی لایەنگری میران ناکات و 
\q2 دەوڵەمەند لە هەژار بە زیاتر دانانێت، 
\q2 چونکە هەمووان کاری دەستی ئەون؟ 
\q1  
\v 20 لەناکاو دەمرن، لە نیوەشەودا؛ 
\q2 گەل دەهەژێن و بەسەردەچن؛ 
\q2 بەهێزەکان دادەماڵرێن، بەڵام نەک بە دەستی مرۆڤ. 
\b  
\q1  
\v 21 «چاوەکانی لەسەر ڕێگاکانی مرۆڤە؛ 
\q2 ئەو هەموو هەنگاوەکانی دەبینێت. 
\q1  
\v 22 نە تاریکی هەیە و نە سێبەری مەرگ، 
\q2 کە بەدکاران بتوانن خۆیانی تێدا بشارنەوە. 
\q1  
\v 23 پێویست ناکات خودا زیاتر لێکۆڵینەوە لەگەڵ مرۆڤ بکات، 
\q2 هەتا بێتە بەردەمی بۆ دادگاییکردن. 
\q1  
\v 24 دلێران بەبێ پشکنین تێکدەشکێنێت و 
\q2 خەڵکی دیکە لە جێیان دادەنێت. 
\q1  
\v 25 لەبەر ئەوەی تێبینی کردەوەکانیان دەکات، 
\q2 بە شەو سەرەوژێریان دەکات و وردوخاش دەبن. 
\q1  
\v 26 لەبەر ئەوەی خراپەکارن 
\q2 لەبەرچاوی بینەران سزایان دەدات، 
\q1  
\v 27 چونکە لەدوای ئەو لایاندا و 
\q2 لە هیچ یەکێک لە ڕێگاکانی ئەو وردنەبوونەوە، 
\q1  
\v 28 بەم جۆرەیان کرد هاواری هەژار پێی بگات، 
\q2 بەم شێوەیە گوێی لە قیژەی زەلیلان بوو. 
\q1  
\v 29 بەڵام ئەگەر بێدەنگ بێت، 
\q2 کێ هەیە تاوانباری بکات؟ 
\q2 ئەگەر ڕووی خۆی بشارێتەوە، کێ دەیبینێت؟ 
\q1 لەگەڵ ئەوەشدا فەرمانڕەوایەتی نەتەوە و تاکە کەسیش دەکات 
\q2  
\v 30 بۆ ئەوەی خوانەناس پاشایەتی نەکات و 
\q2 نەبێت بە تەڵە بۆ گەل. 
\b  
\q1  
\v 31 «ئەگەر بە خودا بگوترێت: 
\q2 ”من تاوانبارم بەڵام ئیتر گەندەڵی ناکەم، 
\q1  
\v 32 ئەوەی نەمبینیوە تۆ پیشانی منی بدە، 
\q2 ئەگەر خراپەم کردووە، چیتر نایکەمەوە؟“ 
\q1  
\v 33 ئایا دەبێت خودا بەگوێرەی ئەوەی تۆ پێت باشە پاداشتت\f + \fr 34:33 \ft ئەم وشەیە لە زمانی عیبری بە هەردوو واتای پاداشت و سزا دێت.‏\f* بداتەوە، 
\q2 لە کاتێکدا کە تۆ ئامادە نیت تۆبە بکەیت؟ 
\q1 تۆ هەڵدەبژێریت نەک من، 
\q2 ئەوەی دەیزانیت دەیڵێیت. 
\b  
\q1  
\v 34 «تێگەیشتووان پێم دەڵێن، 
\q2 ئەو پیاوە دانایانەی گوێیان لێمە دەڵێن: 
\q1  
\v 35 ”ئەیوب بەبێ زانین قسە دەکات و 
\q2 قسەکانی بەبێ وریاین.“ 
\q1  
\v 36 خۆزگە ئەیوب هەتاسەر تاقی دەکرایەوە 
\q2 لەبەر وەڵامەکانی وەک بەدکاران! 
\q1  
\v 37 یاخیبوونی بۆ سەر گوناهەکەی زیاد کرد؛ 
\q2 بە گاڵتەپێکردنەوە چەپڵە لێدەدات و 
\q2 زیادەڕۆیی لەسەر خودا دەکات.» 
\c 35  
\p  
\v 1 ئەلیهوش بەردەوام بوو و گوتی: 
\q1  
\v 2 «ئایا ئەمە بە ڕاست دادەنێیت؟ 
\q2 گوتت: ”ڕاستییەکەی لای منە، نەک لای خودا.“ 
\q1  
\v 3 لەگەڵ ئەوەشدا لێی دەپرسیت: ”چ سوودێکی بۆم هەیە، 
\q2 قازانجی چیم کرد لە نەکردنی گوناه؟“ 
\b  
\q1  
\v 4 «من حەز دەکەم وەڵامی تۆ بدەمەوە، 
\q2 وەڵامی تۆ و هاوڕێیەکانیشت دەدەمەوە. 
\q1  
\v 5 تەماشای ئاسمان بکە و ببینە، 
\q2 تێبینی هەورەکان بکە لە تۆ بەرزترن. 
\q1  
\v 6 ئەگەر گوناهە بکەیت چیت لێکردووە و 
\q2 ئەگەر یاخیبوونەکانت زۆر بکەیت چیت پێکردووە؟ 
\q1  
\v 7 ئەگەر ڕاستودروست بیت چیت پێیداوە، 
\q2 یان چی لە دەستت وەردەگرێت؟ 
\q1  
\v 8 خراپەکەت بۆ مرۆڤێک دەبێت کە وەک خۆتە و 
\q2 ڕاستودروستیشت بۆ ئادەمیزادە. 
\b  
\q1  
\v 9 «خەڵک لەتاوی زۆرداری هاوار دەکەن، 
\q2 لەبەر ستەمکاران هاواری فریاکەوتن دەکەن. 
\q1  
\v 10 ناڵێن: ”کوا خودای بەدیهێنەرم، 
\q2 ئەوەی لە شەودا زەبوور دەدات، 
\q1  
\v 11 ئەوەی فێرمان دەکات زیاتر لە ئاژەڵەکانی زەوی و 
\q2 لە باڵندەکانی ئاسمان داناترمان دەکات؟“ 
\q1  
\v 12 کاتێک خەڵک لە دەست لووتبەرزی خراپەکاران هاوار دەکەن، 
\q2 وەڵام ناداتەوە. 
\q1  
\v 13 خودا گوێ لە داواکاری پووچیان ناگرێت، 
\q2 توانادارەکە تەماشای ناکات. 
\q1  
\v 14 ئیتر چۆن گوێ لە تۆ بگرێت 
\q2 ئەگەر بڵێیت کە نایبینیت، 
\q1 داواکارییەکەت لەبەردەمیەتی و 
\q2 دەبێت چاوەڕێی ئەو بکەیت، 
\q1  
\v 15 هەروەها تووڕەییەکەی هەرگیز سزا نادات و 
\q2 گوێ نادات بە زۆری خراپەکاری. 
\q1  
\v 16 بەم جۆرە ئەیوب لە هیچ دەمی کردووەتەوە و 
\q2 بەبێ زانین قسەی زل دەکات.» 
\c 36  
\p  
\v 1 دیسان ئەلیهو گوتی: 
\q1  
\v 2 «تۆزێک ئارامم لەگەڵ بگرە جا پێتی نیشان دەدەم 
\q2 کە هێشتا قسە هەیە لەبەر خودا بگوترێت. 
\q1  
\v 3 زانینم لە دوورەوە هەڵدەگرم و 
\q2 ڕاستودروستی دەدەمە پاڵ دروستکەرەکەم. 
\q1  
\v 4 بەڕاستی قسەکانم درۆ نین، 
\q2 ئەو کەسەی زانیاری تەواوە لەلای تۆیە. 
\b  
\q1  
\v 5 «خودا مەزنە و بە چاوی سووک تەماشای کەس ناکات، 
\q2 گەورەیە و ئامانجەکەی چەسپاوە. 
\q1  
\v 6 خراپەکار ناژیێنێت و 
\q2 مافی زەلیلان دەدات. 
\q1  
\v 7 چاوەکانی لەسەر کەسی ڕاستودروست لا نادات، 
\q2 بەڵکو لەگەڵ پاشایان لەسەر تەخت دایاندەنیشێنێت و 
\q2 هەتاسەر پایەداریان دەکات. 
\q1  
\v 8 ئەگەر بە زنجیر ببەسترێنەوە، 
\q2 ئەگەر بە پەتی زەلیلی ببردرێن، 
\q1  
\v 9 کردەوە و یاخیبوونەکانی خۆیانیان بۆ دەردەخات، 
\q2 چونکە لووتبەرز بوون. 
\q1  
\v 10 گوێیەکانیان بۆ ئاگادارکردنەوە دەکاتەوە و 
\q2 فەرمانیان پێ دەکات لە خراپەکانیان تۆبە بکەن. 
\q1  
\v 11 ئەگەر گوێ بگرن و بیپەرستن، 
\q2 ڕۆژگاریان بە باشە و 
\q2 ساڵانیان بە خۆشی بەسەردەبەن. 
\q1  
\v 12 ئەگەر گوێش نەگرن، 
\q2 بە شمشێر لەناودەچن و 
\q2 بە نەزانی دەمرن. 
\b  
\q1  
\v 13 «خوانەناسان تووڕەیی کۆدەکەنەوە، 
\q2 تەنانەت کاتێک دەیانبەستێتەوە هاواری فریاکەوتن ناکەن. 
\q1  
\v 14 لەنێو پیاوە لەشفرۆشەکانی نزرگەکان 
\q2 لە گەنجیێتیدا دەمرن. 
\q1  
\v 15 بەڵام فریای کڵۆڵ دەکەوێت لە زەلیلییەکەی و 
\q2 لە کاتی تەنگانە گوێیان دەکاتەوە. 
\b  
\q1  
\v 16 «هەروەها لە ڕووی تەنگانە پاڵت پێوە دەنێت 
\q2 بەرەو شوێنێکی پانوبەرین و بێ بەربەست و 
\q2 سەر خوانەکەت پڕ دەبێت لە خواردنی بەتام. 
\q1  
\v 17 بەڵام ئێستا ئەو حوکمدانەی کە بۆ خراپەکارە بەسەر تۆدا درا، 
\q2 حوکمدان و دادپەروەری دەتگرن. 
\q1  
\v 18 ئاگاداربە دەوڵەمەندی پەلکێشت نەکات، 
\q2 زۆری بەرتیل بەڕەڵات ناکات. 
\q1  
\v 19 ئایا دەوڵەمەندیت بۆ فریاکەوتن 
\q2 لە تەنگانە دەتپارێزێت 
\q2 یان هەموو ئەو کۆششکردنە لە تواناتدایە؟ 
\q1  
\v 20 تامەزرۆی شەو مەبە، 
\q2 هەتا خەڵک لە ماڵەکانیان ڕابکێشیت. 
\q1  
\v 21 ئاگاداربە! ئاوڕ لە خراپە مەدەوە، 
\q2 چونکە ئەمەت هەڵبژارد نەک زەلیلی. 
\b  
\q1  
\v 22 «خودا بە توانای خۆی پایەبەرزە. 
\q2 کێ وەک ئەو مامۆستایە؟ 
\q1  
\v 23 کێ ڕێگای ئەوی بەسەردا سەپاندووە؟ 
\q2 یان کێ پێی دەڵێت: ”خراپەت کردووە؟“ 
\q1  
\v 24 لەبیرت بێت کە کارەکەی بە مەزن بزانیت، 
\q2 کە خەڵکی گۆرانی بەسەردا دەڵێن. 
\q1  
\v 25 هەموو مرۆڤ دەیبینێت؛ 
\q2 خەڵکی لە دوورەوە تەماشای دەکەن. 
\q1  
\v 26 خودا چەند مەزنە و ئێمەش نایناسین و 
\q2 ژمارەی ساڵەکانی ناپشکێنرێن. 
\b  
\q1  
\v 27 «دڵۆپەکانی ئاو ڕادەکێشێت، 
\q2 دەیانکات بە هەور پاشان دەیانبارێنێت؛ 
\q1  
\v 28 لە هەورەکانەوە بارانێکی زۆر 
\q2 بەسەر ئادەمیزاد دەڕژێنێت. 
\q1  
\v 29 ئایا کەس تێدەگات چۆن هەورەکان پەرت دەکات 
\q2 یان چۆن لە کەپرەکەیەوە هەورەتریشقە دەنێرێت؟ 
\q1  
\v 30 ببینە بروسکەی خۆی بەسەر خۆیدا پەرتوبڵاو دەکات و 
\q2 قووڵایی دەریا دادەپۆشێت، 
\q1  
\v 31 چونکە بەمە حوکمڕانی گەلان دەکات و 
\q2 بە پڕی خواردن دەدات. 
\q1  
\v 32 بە دەستەکانی بروسکە دەگرێت و 
\q2 فەرمانی پێدەدات لە دوژمن بدات. 
\q1  
\v 33 گرمەکەی ڕایدەگەیەنێت، 
\q2 مەڕوماڵاتیش بە هاتنی دەزانن. 
\b  
\c 37  
\q1  
\v 1 «لەبەر ئەمە دڵم خورپە دەکات و 
\q2 لە جێی خۆی دەست دەکات بە کوتان. 
\q1  
\v 2 بۆ نەڕەی دەنگەکەی و گرمەگرمی دەمی 
\q2 گوێ شل بکە! 
\q1  
\v 3 لەژێر هەموو ئاسمان هەتا ئەوپەڕی زەوی، 
\q2 بە بروسکەکەی دەردەبڕێت. 
\q1  
\v 4 لەدوای ئەوەش هەر دەنگی نەڕەکەی دێت، 
\q2 بە دەنگی پڕ شانازییەکەی دەگرمێنێت. 
\q1 کاتێک دەنگ دەداتەوە 
\q2 بروسکەکەی ڕاناگرێت. 
\q1  
\v 5 خودا بە دەنگێکی سەرسوڕهێنەر دەگرمێنێت؛ 
\q2 کاری مەزنی وا دەکات کە ئێمە تێیناگەین. 
\q1  
\v 6 بە بەفر دەفەرموێت: ”بکەوە سەر زەوی،“ 
\q2 هەروەها بە تاوە باران دەفەرموێت: ”بە لێزمە ببارێ.“ 
\q1  
\v 7 مۆر لە دەستی هەموو مرۆڤێک دەدات، 
\q2 بۆ ئەوەی هەموو خەڵکی دروستکەری خۆیان بناسن. 
\q1  
\v 8 گیانلەبەران دەچنە ناو لانەکانی خۆیانەوە و 
\q2 لەناو کونەکانی خۆیان دەمێننەوە. 
\q1  
\v 9 لە باشوورەوە ڕەشەبا دێت و 
\q2 لە باکووریشەوە سەرما. 
\q1  
\v 10 لە هەناسەی خوداوە بەستەڵەک پەیدا دەبێت و 
\q2 سەر ڕووی ئاوەکان دەبنە سەهۆڵ. 
\q1  
\v 11 هەروەها هەورەکان بە شێ بار دەکات؛ 
\q2 بروسکەکەی بەناو هەورەکاندا پەرت دەکات. 
\q1  
\v 12 بەگوێرەی خواستی ئەو 
\q2 لەسەر ڕووی زەوی ئاوەدان دەگەڕێن 
\q2 هەتا هەموو ئەوە بکات کە فەرمانی پێ دەکرێت. 
\q1  
\v 13 هەورەکان دەهێنێت بۆ تەمبێکردنی خەڵک، 
\q2 یان بۆ ئەوەی ئاو بداتە زەوییەکەی و 
\q2 خۆشەویستییە نەگۆڕەکەی پیشان بدات. 
\b  
\q1  
\v 14 «ئەیوب گوێ بۆ ئەمە شل بکە! 
\q2 هەستە و لە پەرجووەکانی خودا وردبەرەوە. 
\q1  
\v 15 ئایا دەزانیت خودا چۆن فەرمان بە هەورەکان دەکات، 
\q2 یان درەوشانەوەی هەورە بروسکەکەی چۆنە؟ 
\q1  
\v 16 ئایا دەزانیت چۆن هەورەکان بە ئاسمانەوە وەستاون، 
\q2 ئایا کارە سەرسوڕهێنەرەکانی خودا دەزانیت ئەوەی کە زانیاری تەواوە؟ 
\q1  
\v 17 ئەی ئەوەی لەناو جلوبەرگەکەت گەرما دەتخوات 
\q2 بە کپبوونی زەوی بە بای باشوور، 
\q1  
\v 18 ئایا دەتوانیت هاوکاری ئەو بکەیت ئاسمان بڵاو بکەیتەوە، 
\q2 کە وەک ئاوێنەیەکی لە بڕۆنز داڕێژراو ڕەقە؟ 
\b  
\q1  
\v 19 «پێمان بڵێ کە چی پێ بڵێین؛ 
\q2 لەبەر ئەوەی ئێمە لە تاریکیداین ناتوانین داواکارییەکەمان ئامادە بکەین. 
\q1  
\v 20 ئایا دەبێت پێی بگوترێت کە من دەمەوێ قسە بکەم؟ 
\q2 ئایا مرۆڤ قسە دەکات بۆ ئەوەی خۆی بە قووتدان بدات؟ 
\q1  
\v 21 ئێستاش کەس ناتوانێت تەماشای خۆر بکات 
\q2 کە لە ئاسماندا دەدرەوشێتەوە 
\q2 دوای ئەوەی با هەڵیکرد و ئاسمانی بێگەرد کرد. 
\q1  
\v 22 لە باکوورەوە بە شکۆمەندییەکی زێڕین دێت، 
\q2 خودای شکۆدار و سامناک دێت. 
\q1  
\v 23 ئێمە پەی بە خودای هەرە بەتوانای باڵادەست نابەین، 
\q2 کە لەبەر دادپەروەرییە مەزنەکەی و ڕاستودروستییە زۆرەکەی ستەم ناکات. 
\q1  
\v 24 لەبەر ئەمە خەڵکی لێی دەترسن، 
\q2 چونکە ئاوڕ دەداتەوە لەوانەی کە بە دڵیان دانان.» 
\c 38  
\s1 یەزدان قسە دەکات 
\p  
\v 1 یەزدانیش لە گەردەلوولەکەوە وەڵامی ئەیوبی دایەوە و فەرمووی: 
\q1  
\v 2 «ئەمە کێیە، بێ زانیاری قسە دەکات و 
\q2 ڕاوێژی من تێک دەدات؟ 
\q1  
\v 3 ئێستا وەک پیاو پشتێنەکەی خۆت توند بکە، 
\q2 پرسیارت لێ دەکەم و 
\q2 وەڵامم بدەوە. 
\b  
\q1  
\v 4 «کاتێک زەویم دامەزراند لەکوێ بوویت؟ 
\q2 ئەگەر تێگەیشتنت هەیە پێم بڵێ. 
\q1  
\v 5 کێ پێوانەکانی دانا؟ بێگومان تۆ دەزانیت! 
\q2 یان کێ گوریسی پێوانەی بەسەردا هێنا؟ 
\q1  
\v 6 بناغەکانی لەسەر چی چەسپاند، 
\q2 یان کێ بەردی بناغەکەی دانا، 
\q1  
\v 7 کاتێک ئەستێرەکانی بەرەبەیان پێکەوە هاواری خۆشییان دەکرد و 
\q2 هەموو فریشتەکان\f + \fr 38:7 \ft عیبری: کوڕانی خودا. بڕوانە \xt پەیدابوون 6‏:2‏\ft ‏.‏\f* هوتافیان دەکێشا؟ 
\b  
\q1  
\v 8 «کێ بە دەروازەکان دەریای بەندکرد، 
\q2 کاتێک بە پاڵەپەستۆ لە منداڵدان هاتە دەرەوە، 
\q1  
\v 9 کە هەورم کردە بەرگی و 
\q2 هەوری تاریکم کرد بە قۆنداغی، 
\q1  
\v 10 کە فەرزی خۆم بەسەریدا سەپاند و 
\q2 دەروازە و شمشیرەم\f + \fr 38:10 \ft شمشیر، پارچە دارێک بووە لە جیاتی قوفڵ لە دواوەی دەرگا بە شێوەی ئاسۆیی دانراوە بۆ داخستنی دەرگا.‏\f* بۆ دانا، 
\q1  
\v 11 فەرمووم: ”هەتا ئێرە دێیت و تێناپەڕیت؛ 
\q2 لێرە شەپۆلەکانی لووتبەرزیت دەشکێن“؟ 
\b  
\q1  
\v 12 «ئایا لە هیچ ڕۆژێک لە ڕۆژانی ژیانتدا فەرمانت بە بەرەبەیان کردووە، 
\q2 هەتا زەردەی خۆر هەڵنەیێت، 
\q1  
\v 13 هەتا ڕۆخەکانی زەوی بگرێت و 
\q2 بەدکارانی لێ بتەکێنێت؟ 
\q1  
\v 14 وەکو مۆرێک کە لە قوڕی دەدەیت، 
\q2 دەوەستێت هەروەکو بەرگی پۆشیبێت. 
\q1  
\v 15 ڕووناکی لە بەدکاران قەدەغە دەکرێت و 
\q2 دەستی بەرزکراوەیان دەشکێنرێت. 
\b  
\q1  
\v 16 «ئایا گەیشتیتە سەرچاوەکانی دەریا و 
\q2 بەناو کون و کەلەبەرەکانی قووڵاییدا هاتوچۆت کرد؟ 
\q1  
\v 17 ئایا دەروازەکانی مردنت بۆ ئاشکرا بوون 
\q2 یان دەروازەکانی سێبەری مەرگت بینی؟ 
\q1  
\v 18 ئایا پانوبەرینی زەوی دەزانیت؟ 
\q2 ئەگەر هەموو ئەم شتانە دەزانیت، پێم بڵێ. 
\b  
\q1  
\v 19 «کام ڕێگایە دەچێتە نشینگەی ڕووناکی؟ 
\q2 ئەی شوێنی نیشتەجێبوونی تاریکی لەکوێیە؟ 
\q1  
\v 20 ئایا دەتوانیت هەریەکەیان بۆ سنووری خۆی ببەیت و 
\q2 ڕێگای ماڵەکانیان شارەزابیت؟ 
\q1  
\v 21 لەبەر ئەوەی تۆ لەپێش ئەمانەوە لەدایک ببوویت! 
\q2 بە دڵنیاییەوە تۆ زۆر تەمەن درێژیت! 
\b  
\q1  
\v 22 «ئایا چووی بۆ ناو ئەمبارەکانی بەفر 
\q2 یان کۆگاکانی تەرزەت بینیوە، 
\q1  
\v 23 ئەوەی هەڵمگرتووە بۆ کاتی تەنگانە، 
\q2 بۆ ڕۆژانی نەهامەتی و جەنگ؟ 
\q1  
\v 24 لە چ ڕێگایەکەوە بروسکە دابەش دەبێت و 
\q2 بای ڕۆژهەڵات لەسەر زەوی بڵاو دەبێتەوە؟ 
\q1  
\v 25 کێ لێکی جیا کردەوە جۆگەکان بۆ بارانی بە لێشاو و 
\q2 ڕێچکە بۆ باوبۆران؟ 
\q1  
\v 26 بۆ ئاودانی خاکێک کە مرۆڤی تێدا نییە، 
\q2 بەسەر چۆڵەوانییەک کە ئادەمیزادی تێدا نییە، 
\q1  
\v 27 بۆ ئەوەی خاکی کاول و وێران تێر بکات، 
\q2 وا بکات گیای لێ بڕووێت. 
\q1  
\v 28 ئایا باران باوکی هەیە؟ 
\q2 ئەی کێ دڵۆپەکانی شەونم دەخاتەوە؟ 
\q1  
\v 29 بەستەڵەک لە سکی کێ دێتە دەرەوە؟ 
\q2 شەختەی ئاسمان بۆ کێ لەدایک دەبێت، 
\q1  
\v 30 کاتێک ئاوەکان وەک بەردیان لێ دێت و 
\q2 ڕووی قووڵاییەکان دەیبەستێت؟ 
\b  
\q1  
\v 31 «ئایا تۆ دەتوانیت گرێیەکانی حەوتەوانە\f + \fr 38:31 \ft یەکێک لە کەلووەکانە.‏\f* ببەستیت 
\q2 یان گرێ بەستراوەکانی ڕاوچی بکەیتەوە؟ 
\q1  
\v 32 ئایا تۆ دەتوانیت کەلووەکان\f + \fr 38:32 \ft مەبەستی بورجەکانە، هەریەک لە حەوتەوانە و ڕاوچی و ورچ لە چەند ئەستێرەیەک پێکدێن.‏\f* لە کاتی خۆی دەربخەیت، 
\q2 یان ڕێنمایی کەلووی ورچ بکەیت لەگەڵ بەچکەکانی؟ 
\q1  
\v 33 ئایا یاساکانی ئاسمان دەزانیت، 
\q2 یاخود تۆ بڕیاری دەسەڵاتی ئەو بەسەر زەویدا دەچەسپێنیت؟ 
\b  
\q1  
\v 34 «ئایا دەتوانیت دەنگت بۆ هەورەکان بەرز بکەیتەوە 
\q2 هەتا بە لێشاوی ئاو داتبپۆشێت؟ 
\q1  
\v 35 ئایا توانای ئەوەت هەیە بروسکەکان بنێریت، 
\q2 جا بڕۆن و بڵێن: ”ئەوەتاین ئێمە“؟ 
\q1  
\v 36 کێ دانایی دەبەخشێت 
\q2 یان تێگەیشتن بە مێشک دەدات؟ 
\q1  
\v 37 کێ بە داناییەوە هەورەکان دەژمێرێت 
\q2 یان مەشکەکانی ئاسمان دەڕژێنێت، 
\q1  
\v 38 کاتێک تێکەڵ بە خۆڵ دەبێت 
\q2 یەکدەگرن و دەبنە قوڕ؟ 
\b  
\q1  
\v 39 «ئایا تۆ نێچیر بۆ شێرە مێ ڕاو دەکەیت 
\q2 یان هەڵپەی بەچکە شێرەکان ئارام دەکەیتەوە، 
\q1  
\v 40 کاتێک لەناو بێشەکەیان خۆیان دەکێشنەوە و 
\q2 خۆیان مەڵاس دەدەن بۆ بۆسە؟ 
\q1  
\v 41 کێ ڕاو بۆ قەلەڕەش ئامادە دەکات 
\q2 کە بەچکەکانی دەقیڕێنن بۆ خودا و 
\q2 لەبەر نەبوونی خواردن پەرتەوازە بوون؟ 
\b  
\c 39  
\q1  
\v 1 «ئایا دەزانیت کەی بزنە کێوییەکان دەزێن؟ 
\q2 یان تێبینیت کردووە ئەو کاتەی کە ئاسک ژان دەیگرێت؟ 
\q1  
\v 2 ئایا مانگەکانی ئاوسبوونی دەژمێریت 
\q2 یان کاتی زاوزێکردنیان دەزانیت؟ 
\q1  
\v 3 چۆک دادەدەن و پاڵ بە ئازارەکانیانەوە دەنێن و 
\q2 بەچکەکانیان دەبێت. 
\q1  
\v 4 بەچکەکانیان لە چۆڵەوانی بەهێز و گەورە دەبن؛ 
\q2 دەڕۆن و ئیتر ناگەڕێنەوە لایان. 
\b  
\q1  
\v 5 «کێ کەرەکێوی بەڕەڵا کرد و 
\q2 مێخ زنجیری ئەو کێوییەی کردەوە؟ 
\q1  
\v 6 ئەوەی چۆڵەوانیم کرد بە ماڵی و 
\q2 خوێڵێنم\f + \fr 39:6 \ft خاکێک کە خوێی زۆر بێت، سەرچاوەی بەدەستهێنانی خوێ بێت.‏\f* کردە ژینگەی. 
\q1  
\v 7 بە دەنگەدەنگی شار پێدەکەنێت، 
\q2 گوێی لە هاواری لێخوڕ نابێت. 
\q1  
\v 8 لە چیاکاندا بەدوای لەوەڕگادا دەگەڕێت، 
\q2 بۆ دۆزینەوەی هەموو سەوزاییەک. 
\b  
\q1  
\v 9 «ئایا گای کێوی ڕازی دەبێت خزمەتت بکات 
\q2 یان بە شەو لەلای ئاخوڕەکەت بمێنێتەوە؟ 
\q1  
\v 10 ئایا دەتوانیت گای کێوی بە گاسنەوە ببەستیتەوە و جووتی پێ بکەیت؟ 
\q2 ئایا بەدواتدا دێت دۆڵەکان خەرتە بکات؟ 
\q1  
\v 11 ئایا پشتی پێ دەبەستیت، چونکە هێزەکەی مەزنە 
\q2 یان کارەکەی خۆتی بۆ بەجێدەهێڵیت؟ 
\q1  
\v 12 ئایا متمانەی پێ دەکەیت کە دەغڵودانەکەت بهێنێت و 
\q2 بۆ سەر جۆخینەکەت\f + \fr 39:12 \ft جۆخین یان سەرخەرمان ئەو زەوییە تەرخانکراوەیە کە لەلایەن وەرزێر و جوتیارەوە بەکارهێنراوە بۆ کوتانی دانەوێڵە لەسەری لەدوای کۆکردنەوەی لە کێڵگە.‏\f* کۆی بکاتەوە؟ 
\b  
\q1  
\v 13 «بە خۆشییەوە وشترمرغ باڵەفڕکێ دەکات، 
\q2 ئایا پەڕوباڵەکەی وەک لەقلەق پیرۆزە؟ 
\q1  
\v 14 وشترمرغ هێلکەکەی لەسەر زەوی بەجێدەهێڵێت و 
\q2 خۆڵ گەرمیان دادەهێنێت، 
\q1  
\v 15 لەبیری دەچێت کە پێ وردوخاشی دەکات و 
\q2 ئاژەڵی کێوی پێی پێدا دەنێن. 
\q1  
\v 16 لەگەڵ بەچکەکانی دڵڕەقە وەک ئەوەی بەچکەی ئەو نەبن؛ 
\q2 گوێی ناداتێ کە ماندووبوونەکەی بێهوودە دەڕوات، 
\q1  
\v 17 چونکە خودا دانایی لەبیر بردووەتەوە، 
\q2 لە تێگەیشتن بەشی نەداوە. 
\q1  
\v 18 کاتێک پەڕەکانی فش دەکاتەوە بۆ ڕاکردن، 
\q2 بە ئەسپ و بە سوارەکەی پێدەکەنێت. 
\b  
\q1  
\v 19 «ئایا تۆ هێز بە ئەسپ دەدەیت 
\q2 یان ملی بە یاڵ\f + \fr 39:19 \ft مووی درێژ لەسەر ملی ئەسپ.‏\f* دادەپۆشیت؟ 
\q1  
\v 20 ئایا وای لێ دەکەیت کە وەک کوللە قەڵەمباز بدات و 
\q2 دەنگی حیلەکەی تۆقێنەر بێت؟ 
\q1  
\v 21 بە توندی سم بە زەویدا بکوتێت، بە هێزەوە دەربپەڕێت، 
\q2 بەرەو مەیدانی جەنگ مل بنێت. 
\q1  
\v 22 بە ترس پێبکەنێت و نەتۆقێت؛ 
\q2 لە ڕووی شمشێر نەگەڕێتەوە. 
\q1  
\v 23 تیردان شەقەشەقی بێت و 
\q2 خەنجەر و نووکی ڕم ببریسکێنەوە. 
\q1  
\v 24 بەوپەڕی جۆشوخرۆشەوە غار دەدات، 
\q2 هەتا کاتی لێدانی کەڕەنا خۆی پێ ڕاناگیرێت. 
\q1  
\v 25 لە کاتی فووکردن بە کەڕەنادا دەڵێت: ”ئەها!“ 
\q2 لە دوورەوە بۆنی شەڕ دەکات، 
\q2 هاواری سەرکردەکان و نەعرەتەی جەنگ. 
\b  
\q1  
\v 26 «ئایا لە تێگەیشتنی تۆدایە هەڵۆ بفڕێت و 
\q2 ڕووەو باشوور باڵەکانی بکاتەوە؟ 
\q1  
\v 27 یان بە فەرمانی تۆیە هەڵۆ بەرز بفڕێت و 
\q2 هێلانەکەی لە بەرزی دابنێت؟ 
\q1  
\v 28 لەسەر لووتکەی چیا نیشتەجێ دەبێت و بە شەو دەمێنێتەوە، 
\q2 هەڵدێری بەردەڵان قەڵاکەیەتی. 
\q1  
\v 29 لەوێوە نێچیری خۆی دەدۆزێتەوە و 
\q2 چاوەکانی لە دوورەوە دەبینن. 
\q1  
\v 30 بەچکەکانی خوێن هەڵدەمژن، 
\q2 لە هەرکوێ کوژراوی لێ بێت، ئەو لەوێیە.» 
\c 40  
\p  
\v 1 یەزدان بە ئەیوبی فەرموو: 
\q1  
\v 2 «ئایا ئەوەی ڕکابەری لەگەڵ توانادارەکە دەکات مافی ئەوەی هەیە سەرزەنشتی بکات؟ 
\q2 ئەوەی خودا تاوانبار دەکات با وەڵام بداتەوە!» 
\p  
\v 3 ئەیوبیش وەڵامی یەزدانی دایەوە: 
\q1  
\v 4 «من وا سووکوچروکم، چۆن وەڵامت بدەمەوە؟ 
\q2 من دەست دەخەمە سەر دەمی خۆم. 
\q1  
\v 5 جارێک قسەم کرد و بێ وەڵام بووم، 
\q2 دوو جار و ئیتر دووبارەی ناکەمەوە.» 
\p  
\v 6 یەزدانیش لە گەردەلوولەکەوە وەڵامی ئەیوبی دایەوە و فەرمووی: 
\q1  
\v 7 «ئێستا وەک پیاو پشتێنەکەی خۆت توند بکە؛ 
\q2 من پرسیارت لێ دەکەم و 
\q2 تۆش وەڵامم بدەوە. 
\b  
\q1  
\v 8 «ئایا دادپەروەریم دەخەیتە گومانەوە، 
\q2 تاوانبارم دەکەیت بۆ ئەوەی خۆت بە ڕاستودروست دەربخەیت؟ 
\q1  
\v 9 یان بازووێکت وەک خودا هەیە و 
\q2 بە دەنگێکی وەک دەنگی ئەو دەگرمێنیت؟ 
\q1  
\v 10 ئێستا بە پایەبەرزی و سەرفرازی خۆت بڕازێنەوە، 
\q2 ڕێز و شکۆمەندی بپۆشە. 
\q1  
\v 11 لافاوی تووڕەییەکەت بڕێژە و 
\q2 تەماشای هەموو لووتبەرزێک بکە و نزمی بکەرەوە، 
\q1  
\v 12 سەیری هەموو خۆبەزلزانێک بکە و زەلیلی بکە، 
\q2 لە جێی خۆیان پێ بە خراپەکاراندا بنێ. 
\q1  
\v 13 تێکڕا لەناو خۆڵ نوقومیان بکە، 
\q2 لە تاریکیدا ڕوویان بەند بکە. 
\q1  
\v 14 منیش دان بەوەدا دەنێم، 
\q2 کە دەستی ڕاستی خۆت دەتوانێت ڕزگارت بکات. 
\b  
\q1  
\v 15 «سەیری بەهێمۆت\f + \fr 40:15 \ft گیانلەبەرێکی زۆر گەورە بووە.‏\f* بکە، 
\q2 کە لەگەڵ تۆ دروستم کرد 
\q2 وەک مانگا گیا دەخوات. 
\q1  
\v 16 ئەوەتا هێزەکەی لە کەمەریەتی و 
\q2 تواناکەی لە ماسوولکەکانی سکیەتی. 
\q1  
\v 17 کلکی وەک داری ئورز شۆڕ دەکاتەوە؛ 
\q2 ماسوولکەکانی ڕانی یەکیان تەنیوە. 
\q1  
\v 18 ئێسکەکانی لوولەی بڕۆنزن، 
\q2 چوارپەلی وەکو لوولەی ئاسنن. 
\q1  
\v 19 ئەو سەرەتای کارەکانی خودایە، 
\q2 بەڵام دروستکەرەکەی دەتوانێت بە شمشێر لێی نزیک بێتەوە. 
\q1  
\v 20 چیاکان سەوزایی بۆ دەردەخەن و 
\q2 هەموو ئاژەڵی کێوی لەتەنیشتی یاری دەکەن. 
\q1  
\v 21 لەژێر درەختەکانی لۆتس\f + \fr 40:21 \ft درەختێکی دڕکاوییە لە ڕۆژهەڵاتی دەریا ناوەڕاست و باکووری ئەفریقیا هەیە، لە ناوچەی گەرم شێدار دەڕوێت و بە پڕی لە دەوروبەری دەریاچەی جەلیل هەیە.‏\f* ڕادەکشێت، 
\q2 خۆی دەشارێتەوە لەنێو قامیشی زۆنگەکاندا. 
\q1  
\v 22 درەختەکانی لۆتس بە سێبەرەکانیان دایدەپۆشن؛ 
\q2 شۆڕەبی کەنار جۆگەکان دەوری دەدەن. 
\q1  
\v 23 ئەگەر ئاوی ڕووبار هەستێت یان ڕووباری ئوردونیش تەووژم بۆ دەمی بهێنێت، 
\q2 ئەو دڵنیایە و ترسی لێ نانیشێت. 
\q1  
\v 24 ئایا کەس دەتوانێت ڕوو بە ڕوو ڕاوی بکات، 
\q2 یان بە تەڵە بیگرێت و لووتی کون بکات؟ 
\b  
\c 41  
\q1  
\v 1 «ئایا دەتوانیت لیڤیاتان\f + \fr 41:1 \ft گیانلەبەرێکی گەورەیە لەناو دەریا دەژیێت.‏\f* بە قولاپ ڕاو بکەیت، 
\q2 یان زمانی بە گوریس ببەستیتەوە؟ 
\q1  
\v 2 ئایا دەتوانیت ئەڵقە بخەیتە لووتی 
\q2 یان شەویلاکی بە لووتەوانە بسمیت؟ 
\q1  
\v 3 ئایا زۆر لێت دەپاڕێتەوە 
\q2 یان بە نەرمی قسەت لەگەڵ دەکات؟ 
\q1  
\v 4 ئایا پەیمانت لەگەڵ دەبەستێت 
\q2 کە بە درێژایی ژیانی بیکەیت بە کۆیلەی خۆت؟ 
\q1  
\v 5 ئایا وەک چۆلەکە یاری لەگەڵ دەکەیت 
\q2 یان بۆ کچە منداڵەکانت دەیبەستیتەوە؟ 
\q1  
\v 6 ئایا ڕاوچییەکان کڕین و فرۆشتنی لەسەر دەکەن 
\q2 یان لەنێو بازرگانەکان دابەشی دەکەن؟ 
\q1  
\v 7 ئایا پێستی پڕ دەکەیت لە ڕم و 
\q2 سەریشی پڕ لە تیر؟ 
\q1  
\v 8 دەستت لەسەری دابنێ و بیر لە جەنگ بکەرەوە، 
\q2 جارێکی دیکە دووبارەی ناکەیتەوە! 
\q1  
\v 9 هیواخواستن بۆ گرتنی پووچە، 
\q2 هەر بە بینینی دەتۆقێت. 
\q1  
\v 10 کەسێک نییە ئەوەندە ئازا بێت بەخەبەری بهێنێت، 
\q2 ئیتر کێ هەیە لە ڕووی مندا بوەستێت؟ 
\q1  
\v 11 کێ شتێکی پێم بەخشیوە تاکو من بیدەمەوە؟ 
\q2 ئەوەی لەژێر هەموو ئاسمانە هی منە. 
\b  
\q1  
\v 12 «بێدەنگ نابم لە باسکردنی ئەندامەکانی جەستەی لیڤیاتان و 
\q2 لە ڕاگەیاندنی هێزی و لە جوانی ئاکاری جەستەی. 
\q1  
\v 13 کێ دەتوانێت پێستەکەی دابماڵێت؟ 
\q2 کێ دەتوانێت هەردوو لای زرێیەکەی ببڕێت؟ 
\q1  
\v 14 کێ دوو شەویلاکی دەمی دەکاتەوە؟ 
\q2 ڕیزی ددانەکانی ترسێنەرە. 
\q1  
\v 15 پشتی بە ڕیزێک قەڵغان داپۆشراوە، 
\q2 بە پتەوی بەیەکەوە بەستراوە؛ 
\q1  
\v 16 بە شێوەیەک پێکەوە نووساون کە 
\q2 تەنانەت با بە نێوانیاندا ناڕوات. 
\q1  
\v 17 هەریەکەیان بەوی تەنیشتیەوە نووساوە؛ 
\q2 پێکەوە بەستراون لێک نابنەوە. 
\q1  
\v 18 کە دەحیلێنێت بروسکەی ڕووناکی دەدات؛ 
\q2 چاوەکانی وەک گزنگی بەیانن. 
\q1  
\v 19 لە دەمیەوە بڵێسەی ئاگر دێتە دەرەوە، 
\q2 پریشکی ئاگری لێ دەبێتەوە. 
\q1  
\v 20 لە کونە لووتییەوە دووکەڵ هەڵدەستێت، 
\q2 هەروەک سووتانی قامیش لەبن مەنجەڵێکی لە کوڵ. 
\q1  
\v 21 هەناسەی خەڵووز دادەگیرسێنێت، 
\q2 گڕیش لە دەمیەوە دەڕژێت. 
\q1  
\v 22 هێزەکەی لە ملیدایە، 
\q2 لەبەردەمی هەڵوەستەی لێ دەکەن. 
\q1  
\v 23 گۆشتەکەی قەدقەد پێکەوە نووساوە، 
\q2 بەسەر لەشیدا داڕێژراوە و ناجوڵێتەوە. 
\q1  
\v 24 سەرسەختە، 
\q2 بە جەرگ و چاونەوترسە. 
\q1  
\v 25 کە هەڵدەستێت بەهێزان دەتۆقن، 
\q2 لە ترسی خۆڕاتەکاندنەکەی پەنا دەگرن. 
\q1  
\v 26 شمشێری بەر دەکەوێت بەڵام نایپێکێت، 
\q2 نە ڕم و نە تیر. 
\q1  
\v 27 ئاسن لەلای وەک کا وایە، 
\q2 بڕۆنزیش وەک داری کلۆر. 
\q1  
\v 28 تیری کەوانەکان نایبەزێنن؛ 
\q2 بەردی بەردەقانییەکان بەلایەوە وەک پووشن. 
\q1  
\v 29 گورز لەلای وەک کایە؛ 
\q2 بە ڕاوەشاندنی ڕم پێدەکەنێت. 
\q1  
\v 30 ژێری پارچە گۆزەی تیژە، 
\q2 جەنجەڕ بەسەر قوڕدا ڕادەکێشێت. 
\q1  
\v 31 وا دەکات قووڵایی وەک مەنجەڵ بکوڵێت، 
\q2 دەریا وەک هیزەی زەیت لێ دەکات. 
\q1  
\v 32 لەدوای خۆی هێڵێکی سپی درەوشاوە بەجێدەهێڵێت، 
\q2 شەپۆلەکان وەک پرچی سپی لێ دەکات. 
\q1  
\v 33 لەسەر زەوی هاوشێوەی نییە، 
\q2 بۆ نەترسان دروستکراوە. 
\q1  
\v 34 بە سووکییەوە تەماشای لووتبەرزەکان دەکات؛ 
\q2 پاشای هەموو لەخۆباییەکانە.» 
\c 42  
\s1 وەڵامی ئەیوب 
\p  
\v 1 ئەیوبیش وەڵامی یەزدانی دایەوە: 
\q1  
\v 2 «زانیم کە دەتوانیت هەموو شتێک بکەیت؛ 
\q2 ئەوەی تۆ پلانت بۆ داناوە مەحاڵ نابێت. 
\q1  
\v 3 پرسیارت کرد: ”ئەمە کێیە، بێ زانیاری ڕاوێژی من دەشارێتەوە؟“\f + \fr 42:3 \ft بڕوانە فەرموودەی یەزدان لە \xt 38‏:2‏\ft .‏\f* 
\q2 بێگومان من ئەوەی تێی نەگەیشتم بە دەممدا هات، 
\q2 بە کارە سەرسوڕهێنەرەکان لەسەرمەوە کە نەمدەزانین. 
\b  
\q1  
\v 4 «فەرمووت: ”ئێستا گوێ بگرە من قسە دەکەم؛ 
\q2 لێت دەپرسم و پێم دەڵێیت.“ 
\q1  
\v 5 بە گوێی خۆم هەواڵەکانی تۆم بیست، 
\q2 ئێستاش چاوەکانم تۆیان بینی. 
\q1  
\v 6 لەبەر ئەوە خۆم ڕەت دەکەمەوە و 
\q2 لەناو خۆڵ و خۆڵەمێشدا تۆبە دەکەم.» 
\s1 بەشی کۆتایی 
\p  
\v 7 دوای ئەوەی یەزدان بەم وشانە قسەی لەگەڵ ئەیوبدا کرد، یەزدان بە ئەلیفازی تێمانی فەرموو: «تووڕەییم لە تۆ و لە هاوڕێیەکانت جۆشا، چونکە ئێوە وەک ئەیوبی بەندەم بە ڕاستی سەبارەت بە من قسەی ڕاستتان نەکرد.  
\v 8 ئێستاش ئێوە حەوت گا و حەوت بەران ببەن و بڕۆن بۆ لای ئەیوبی بەندەم، لە پێناوی خۆتان قوربانی سووتاندن پێشکەش بکەن. ئەو کاتە ئەیوبی بەندەم لە پێناوی ئێوە نوێژ دەکات، منیش قبوڵی دەکەم. من بەپێی گێلایەتییەکەی خۆتان هەڵسوکەوتتان لەگەڵ ناکەم، لەبەر ئەوەی ئێوە وەک ئەیوبی بەندەم بە ڕاستی سەبارەت بە من قسەی ڕاستتان نەکرد.»  
\v 9 ئیتر ئەلیفازی تێمانی و بیلدەدی شوحی و چۆفەری نەعماتی ڕۆیشتن و ئەوەیان کرد کە یەزدان پێی فەرموون، یەزدانیش نوێژەکەی ئەیوبی قبوڵ کرد. 
\p  
\v 10 دوای ئەوەی ئەیوب لە پێناوی هاوڕێیەکانی پاڕایەوە، یەزدان ئەوەی هی ئەیوب بوو بۆی گەڕاندەوە، بە دووقاتیش ئەوەی هەیبوو بۆی زیاد کرد.  
\v 11 ئەو کاتە هەموو خوشک و برا و ناسیاوەکانی پێشووی بۆ لای هاتن و لە ماڵەکەی نانیان لەگەڵی خوارد. سەرەخۆشییان لێکرد و دڵیان دایەوە لەسەر هەموو ئەو خراپەیەی یەزدان بەسەریدا هێنا، هەریەکەش پارچە زیوێک و ئەنگوستیلەیەکی زێڕیان پێ بەخشی. 
\p  
\v 12 یەزدان بەشی کۆتایی ژیانی ئەیوبی لە ژیانی ڕابردووی زیاتر بەرەکەتدار کرد، ئەیوبیش چواردە هەزار سەر مەڕ و شەش هەزار وشتر و هەزار جووت مانگا و هەزار ماکەری هەبوو.  
\v 13 هەروەها حەوت کوڕ و سێ کچیشی هەبوو.  
\v 14 کچی یەکەمی ناو نا یەمیما و دووەم قەچیعا و سێیەم قەرەن هەپوک.  
\v 15 لە هەموو خاکەکەشدا هیچ ئافرەتێک وەک کچەکانی ئەیوب جوان نەبوون، باوکیشیان لەنێو براکانیان میراتی پێدان. 
\p  
\v 16 ئەیوبیش پاش ئەوەی کە چاک بووە، سەد و چل ساڵ ژیا و چوار نەوەی خۆی بینی.  
\v 17 ئیتر ئەیوب تێری لە تەمەن خوارد و پیر بوو، پاشان مرد.