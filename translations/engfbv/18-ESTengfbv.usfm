\b
\c 8
\p 
\v 1 \w That|strong="H3588"\w* very \w day|strong="H3117"\w* \w King|strong="H4428"\w* Xerxes \w gave|strong="H5414"\w* \w Queen|strong="H4436"\w* Esther \w the|strong="H6440"\w* property \w that|strong="H3588"\w* \w had|strong="H4428"\w* belonged \w to|strong="H5414"\w* \w Haman|strong="H2001"\w*, \w the|strong="H6440"\w* \w enemy|strong="H6887"\w* \w of|strong="H4428"\w* \w the|strong="H6440"\w* \w Jews|strong="H3064"\w*. \w Also|strong="H4428"\w*, \w Mordecai|strong="H4782"\w* \w came|strong="H4428"\w* \w before|strong="H6440"\w* \w the|strong="H6440"\w* \w king|strong="H4428"\w*, \w because|strong="H3588"\w* Esther \w had|strong="H4428"\w* explained \w who|strong="H1931"\w* \w he|strong="H1931"\w* \w was|strong="H1931"\w* \w to|strong="H5414"\w* \w her|strong="H5414"\w*.
