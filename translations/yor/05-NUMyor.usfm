\id NUM - Biblica® Open Yoruba Contemporary Bible 2017 
\h Numeri 
\toc1 Ìwé Numeri 
\toc2 Numeri 
\toc3 Nu 
\mt1 Ìwé Numeri 
\c 1  
\s1 Ìkànìyàn 
\p  
\v 1 \nd Olúwa\nd* bá Mose sọ̀rọ̀ ní aginjù Sinai nínú àgọ́ àjọ ní ọjọ́ kìn-ín-ní oṣù kejì ní ọdún kejì tí àwọn ọmọ Israẹli jáde kúrò ní ilẹ̀ Ejibiti, ó wí pé,  
\v 2 “Ka gbogbo àgbájọ ènìyàn Israẹli nípa ẹbí wọn, àti nípa ìdílé baba wọn, to orúkọ wọn olúkúlùkù ọkùnrin ní ọ̀kọ̀ọ̀kan.  
\v 3 Ìwọ àti Aaroni ni kí ẹ kà gbogbo ọmọkùnrin Israẹli gẹ́gẹ́ bí ìpín wọn láti ọmọ ogún ọdún sókè, àwọn tí ó tó lọ sójú ogun.  
\v 4 Kí ẹ mú ọkùnrin kọ̀ọ̀kan láti inú olúkúlùkù ẹ̀yà kí ó sì wá pẹ̀lú yín, kí olúkúlùkù jẹ́ olórí ilé àwọn baba rẹ̀. 
\b  
\li4  
\v 5 “Orúkọ àwọn ọkùnrin tí yóò ràn ọ́ lọ́wọ́ nìyí: 
\b  
\li1 “Láti ọ̀dọ̀ Reubeni, Elisuri ọmọ Ṣedeuri. 
\li1  
\v 6 Láti ọ̀dọ̀ Simeoni, Ṣelumieli ọmọ Suriṣaddai. 
\li1  
\v 7 Láti ọ̀dọ̀ Juda, Nahiṣoni ọmọ Amminadabu. 
\li1  
\v 8 Láti ọ̀dọ̀ Isakari, Netaneli ọmọ Suari. 
\li1  
\v 9 Láti ọ̀dọ̀ Sebuluni, Eliabu ọmọ Heloni. 
\li1  
\v 10 Láti ọ̀dọ̀ àwọn ọmọ Josẹfu: 
\li2 láti ọ̀dọ̀ Efraimu, Eliṣama ọmọ Ammihudu. 
\li2 Láti ọ̀dọ̀ Manase, Gamalieli ọmọ Pedasuri. 
\li1  
\v 11 Láti ọ̀dọ̀ Benjamini, Abidani ọmọ Gideoni. 
\li1  
\v 12 Láti ọ̀dọ̀ Dani, Ahieseri ọmọ Ammiṣaddai. 
\li1  
\v 13 Láti ọ̀dọ̀ Aṣeri, Pagieli ọmọ Okanri. 
\li1  
\v 14 Láti ọ̀dọ̀ Gadi, Eliasafu ọmọ Deueli. 
\li1  
\v 15 Láti ọ̀dọ̀ Naftali, Ahira ọmọ Enani.” 
\b  
\li4  
\v 16 Àwọn wọ̀nyí ni wọ́n yàn nínú àwùjọ ènìyàn, olórí àwọn ẹ̀yà baba wọn. Àwọn ni olórí àwọn ẹbí Israẹli. 
\b  
\p  
\v 17 Mose àti Aaroni mú àwọn ènìyàn tí a dárúkọ wọ̀nyí  
\v 18 wọ́n sì pe gbogbo àwùjọ ènìyàn Israẹli jọ ní ọjọ́ kìn-ín-ní oṣù kejì. Àwọn ènìyàn sì dárúkọ baba ńlá wọn nípa ẹbí àti ìdílé wọn. Wọ́n sì ṣe àkọsílẹ̀ orúkọ àwọn ọmọkùnrin ní ọ̀kọ̀ọ̀kan láti ọmọ ogún ọdún sókè,  
\v 19 gẹ́gẹ́ bí \nd Olúwa\nd* ti pàṣẹ fún Mose. Bẹ́ẹ̀ náà ló ṣe kà wọ́n nínú aginjù Sinai. 
\b  
\li1  
\v 20 Láti ìran Reubeni tí í ṣe àkọ́bí Israẹli, gbogbo ọmọkùnrin tí ọjọ́ orí wọn jẹ́ ogún ọdún sókè tí wọ́n lè lọ sójú ogun ni wọ́n to orúkọ wọn, lẹ́yọ kọ̀ọ̀kan gẹ́gẹ́ bí àkọsílẹ̀ ẹbí àti ìdílé wọn.  
\v 21 Àwọn tí a kà ní ẹ̀yà Reubeni jẹ́ ẹgbàá mẹ́tàlélógún ó lé ẹ̀ẹ́dẹ́gbẹ̀ta (46,500). 
\b  
\li1  
\v 22 Láti ìran Simeoni, gbogbo ọmọkùnrin tí ọjọ́ orí wọn jẹ́ ogún ọdún sókè, tí wọ́n lè lọ sójú ogun ni wọ́n kà, wọ́n sì to orúkọ wọn lẹ́yọ kọ̀ọ̀kan gẹ́gẹ́ bí àkọsílẹ̀ ẹbí àti ìdílé wọn.  
\v 23 Iye àwọn tí á kà nínú ẹ̀yà Simeoni jẹ́ ẹgbàá mọ́kàndínlọ́gbọ̀n ó lé ọ̀ọ́dúnrún (59,300). 
\b  
\li1  
\v 24 Láti ìran Gadi, gbogbo ọmọkùnrin tí ọjọ́ orí wọn jẹ́ ogún ọdún sókè tí wọ́n lè lọ sójú ogun ni wọ́n to orúkọ wọn lẹ́yọ kọ̀ọ̀kan, gẹ́gẹ́ bí ẹbí àti ìdílé wọn.  
\v 25 Iye àwọn tí a kà nínú ẹ̀yà Gadi jẹ́ ẹgbàá méjìlélógún ó lé àádọ́talélẹ́gbẹ̀jọ (45,650). 
\b  
\li1  
\v 26 Láti ìran Juda, gbogbo ọmọkùnrin tí ọjọ́ orí wọn jẹ́ ogún ọdún sókè, tí wọ́n le lọ sójú ogun ni wọ́n to orúkọ wọn lẹ́yọ kọ̀ọ̀kan gẹ́gẹ́ bí àkọsílẹ̀ ẹbí àti ìdílé wọn.  
\v 27 Iye tí a kà nínú ẹ̀yà Juda jẹ́ ẹgbàá mẹ́tàdínlógójì ó lé ẹgbẹ̀ta (74,600). 
\b  
\li1  
\v 28 Láti ìran Isakari, gbogbo ọmọkùnrin tí ọjọ́ orí wọn jẹ́ ogún ọdún sókè tí wọ́n le lọ sójú ogun ni wọ́n to orúkọ wọn lẹ́yọ kọ̀ọ̀kan bí àkọsílẹ̀ ẹbí àti ìdílé wọn.  
\v 29 Iye tí a kà nínú ẹ̀yà Isakari jẹ́ ẹgbàá mẹ́tàdínlọ́gbọ̀n ó lé irinwó (54,400). 
\b  
\li1  
\v 30 Láti ìran Sebuluni, gbogbo ọmọkùnrin tí ọjọ́ orí wọn jẹ́ ogún ọdún sókè tí wọ́n lè lọ sójú ogun ni wọ́n to orúkọ wọn lẹ́yọ kọ̀ọ̀kan gẹ́gẹ́ bí àkọsílẹ̀ ẹbí àti ìdílé wọn.  
\v 31 Iye tí a kà nínú ẹ̀yà Sebuluni jẹ́ ẹgbàá méjìdínlọ́gbọ̀n ó lé egbèje (57,400). 
\b  
\li4  
\v 32 Láti inú àwọn ọmọ Josẹfu. 
\li1 Láti ìran Efraimu, gbogbo ọmọkùnrin tí ọjọ́ orí wọ́n jẹ́ ogún ọdún sókè tí wọ́n lè lọ sójú ogun ni wọ́n to orúkọ wọn lẹ́yọ kọ̀ọ̀kan gẹ́gẹ́ bí àkọsílẹ̀ ẹbí àti ìdílé wọn.  
\v 33 Iye tí a kà nínú ẹ̀yà Efraimu jẹ́ ọ̀kẹ́ méjì ó lé ẹ̀ẹ́dẹ́gbẹ̀ta (40,500). 
\li1  
\v 34 Láti ìran Manase, gbogbo ọmọkùnrin tí ọjọ́ orí wọn jẹ́ ogún ọdún sókè, tí wọ́n lè lọ sójú ogun ni wọ́n to orúkọ wọn lẹ́yọ kọ̀ọ̀kan gẹ́gẹ́ bí àkọsílẹ̀ ẹbí àti ìdílé wọn.  
\v 35 Iye tí a kà nínú ẹ̀yà Manase jẹ́ ẹgbàá ẹẹ́rìndínlógún ó lé igba (32,200). 
\b  
\li1  
\v 36 Láti ìran Benjamini, gbogbo ọmọkùnrin tí ọjọ́ orí wọn jẹ́ ogún ọdún sókè ni wọ́n to orúkọ wọn lẹ́yọ kọ̀ọ̀kan gẹ́gẹ́ bí àkọsílẹ̀ ẹbí àti ìdílé wọn.  
\v 37 Iye tí a kà nínú ẹ̀yà Benjamini jẹ́ ẹgbàá mẹ́tàdínlógún ó lé egbèje (35,400). 
\b  
\li1  
\v 38 Láti ìran Dani, gbogbo ọmọkùnrin tí ọjọ́ orí wọn jẹ́ ọmọ ogún ọdún sókè, tí wọ́n lè lọ sójú ogun ni wọ́n to orúkọ wọn lẹ́yọ kọ̀ọ̀kan gẹ́gẹ́ bí àkọsílẹ̀ ẹbí àti ìdílé wọn.  
\v 39 Iye tí a kà nínú ẹ̀yà Dani jẹ́ ẹgbàá mọ́kànlélọ́gbọ̀n ó lé ẹ̀ẹ́dẹ́gbẹ̀rin (62,700). 
\b  
\li1  
\v 40 Láti ìran Aṣeri, gbogbo ọmọkùnrin tí ọjọ́ orí wọn jẹ́ ogún ọdún sókè, tí wọ́n le lọ sójú ogun ni wọ́n to orúkọ wọn lẹ́yọ kọ̀ọ̀kan gẹ́gẹ́ bí àkọsílẹ̀ ẹbí àti ìdílé wọn.  
\v 41 Iye tí a kà nínú ẹ̀yà Aṣeri jẹ́ ọ̀kẹ́ méjì ó lé ẹ̀ẹ́dẹ́gbẹ̀jọ (41,500). 
\b  
\li1  
\v 42 Láti ìran Naftali, gbogbo ọmọkùnrin tí ọjọ́ orí wọn jẹ́ ogún ọdún ó lé, tí wọ́n lè lọ sójú ogun ni wọ́n to orúkọ wọn lẹ́yọ kọ̀ọ̀kan gẹ́gẹ́ bí àkọsílẹ̀ ẹbí àti ìdílé wọn.  
\v 43 Iye àwọn tí a kà nínú ẹ̀yà Naftali jẹ́ ẹgbàá mẹ́rìndínlọ́gbọ̀n ó lé egbèje (53,400). 
\b  
\li4  
\v 44 Wọ̀nyí ni àwọn ènìyàn tí Mose àti Aaroni kà, pẹ̀lú ìrànlọ́wọ́ àwọn olórí méjìlá fún Israẹli, tí ẹnìkọ̀ọ̀kan ṣojú fún ìdílé rẹ̀.  
\v 45 Gbogbo ọmọkùnrin Israẹli tó jẹ́ ọmọ ogún ọdún sókè, tó sì lè lọ sójú ogun ni wọ́n kà gẹ́gẹ́ bí ìdílé wọn.  
\v 46 Àpapọ̀ iye wọn jẹ́ ọgbọ̀n ọ̀kẹ́ ó lé egbèjìdínlógún dín làádọ́ta (603,550). 
\b  
\p  
\v 47       A kò ka àwọn ìdílé ẹ̀yà Lefi mọ́ àwọn ìyókù.  
\v 48 Nítorí \nd Olúwa\nd* ti sọ fún Mose pé,  
\v 49 “Ìwọ kò gbọdọ̀ ka ẹ̀yà Lefi, tàbí kí o kà wọ́n mọ́ àwọn ọmọ Israẹli.  
\v 50  Dípò èyí yan àwọn ọmọ Lefi láti jẹ́ alábojútó àgọ́ ẹ̀rí, lórí gbogbo ohun èlò àti ohun gbogbo tó jẹ́ ti àgọ́ ẹ̀rí. Àwọn ni yóò máa gbé àgọ́ àti gbogbo ohun èlò rẹ̀, wọn ó máa mójútó o, kí wọn ó sì máa pàgọ́ yí i ká.  
\v 51 Ìgbàkígbà tí àgọ́ yóò bá tẹ̀síwájú, àwọn ọmọ Lefi ni yóò tú palẹ̀, nígbàkígbà tí a bá sì tún pa àgọ́, àwọn ọmọ Lefi náà ni yóò ṣe é. Àlejò tó bá súnmọ́ tòsí ibẹ̀, pípa ni kí ẹ pa á  
\v 52 kí àwọn ọmọ Israẹli pa àgọ́ wọn gẹ́gẹ́ bí ìpín wọn olúkúlùkù ní ibùdó tirẹ̀ lábẹ́ ọ̀págun tirẹ̀.  
\v 53 Àwọn ọmọ Lefi yóò jẹ́ alábojútó àti olùtọ́jú àgọ́ ẹ̀rí náà, kí ìbínú má ba à sí lára ìjọ àwọn ọmọ Israẹli; kí àwọn ọmọ Lefi sì máa ṣe ìtọ́jú àgọ́ ẹ̀rí náà.” 
\p  
\v 54 Àwọn ọmọ Israẹli sì ṣe ohun gbogbo gẹ́gẹ́ bí \nd Olúwa\nd* ti pàṣẹ fún Mose. 
\c 2  
\s1 Ètò ibùdó ẹ̀yà kọ̀ọ̀kan 
\p  
\v 1 \nd Olúwa\nd* sọ fún Mose àti Aaroni pé,  
\v 2 “Kí àwọn ọmọ Israẹli pa àgọ́ wọn yí àgọ́ ìpàdé ká, kí wọ́n jẹ́ kí àgọ́ wọn jìnnà sí i díẹ̀, oníkálùkù lábẹ́ ọ̀págun pẹ̀lú àsíá ìdílé wọn.” 
\b  
\li4  
\v 3 Ní ìlà-oòrùn, ní ìdojúkọ àtiyọ oòrùn: 
\li1 ni kí ìpín ti Juda pa ibùdó wọn sí lábẹ́ ọ̀págun wọn. Olórí Juda ni Nahiṣoni ọmọ Amminadabu.  
\v 4 Iye ìpín rẹ̀ jẹ́ ẹgbàá mẹ́tàdínlógójì ó lé ẹgbẹ̀ta (74,600). 
\li1  
\v 5 Ẹ̀yà Isakari ni yóò pa ibùdó tẹ̀lé wọn. Olórí Isakari ni Netaneli ọmọ Suari.  
\v 6 Iye ìpín rẹ̀ jẹ́ ẹgbàá mẹ́tàdínlọ́gbọ̀n ó lé irinwó (54,400). 
\li1  
\v 7 Ẹ̀yà Sebuluni ni yóò tẹ̀lé e. Olórí Sebuluni ni Eliabu ọmọ Heloni.  
\v 8 Iye ìpín rẹ̀ jẹ́ ẹgbàá méjìdínlọ́gbọ̀n ó lé egbèje (57,400). 
\li4  
\v 9 Gbogbo àwọn tí a yàn sí ibùdó Juda, gẹ́gẹ́ bí ìpín wọn àpapọ̀ iye wọn jẹ́ ẹgbàá mẹ́tàléláàdọ́rùn-ún ó lé irinwó (186,400). Àwọn ni yóò kọ́kọ́ ṣáájú. 
\b  
\li4  
\v 10 Ní ìhà gúúsù: 
\li1 ni ìpín ti Reubeni pa ibùdó sí lábẹ́ ọ̀págun wọn. Olórí Reubeni ni Elisuri ọmọ Ṣedeuri.  
\v 11 Iye ìpín rẹ̀ jẹ́ ẹgbàá mẹ́tàlélógún ó lé ẹ̀ẹ́dẹ́gbẹ̀ta (46,500). 
\li1  
\v 12 Ẹ̀yà Simeoni ni yóò pa ibùdó tẹ̀lé wọn. Olórí Simoni ni Ṣelumieli ọmọ Suriṣaddai.  
\v 13 Iye ìpín rẹ̀ jẹ́ ẹgbàá mọ́kàndínlọ́gbọ̀n ó lé ẹ̀ẹ́dẹ́gbéje (59,300). 
\li1  
\v 14 Ẹ̀yà Gadi ló tẹ̀lé wọn. Olórí Gadi ni Eliasafu ọmọ Deueli.  
\v 15 Iye ìpín rẹ̀ jẹ́ ẹgbàá méjìlélógún ó lé àádọ́talélẹ́gbẹ̀jọ (45,650). 
\li4  
\v 16 Gbogbo ènìyàn tí a yàn sí ibùdó Reubeni, gẹ́gẹ́ bí ìpín wọn àpapọ̀ iye wọn jẹ́ ẹgbàá márùndínlọ́gọ́rin ó lé àádọ́talélégbèje (151,450). Àwọn ni yóò jáde sìkéjì. 
\b  
\li1  
\v 17 Nígbà náà ni àwọn ọmọ Lefi àti àgọ́ ìpàdé yóò tẹ̀síwájú láàrín ibùdó àwọn ènìyàn, wọn yóò tẹ̀síwájú ní ṣísẹ̀-n-tẹ̀lé gẹ́gẹ́ bí wọn ṣe pa ibùdó, olúkúlùkù láààyè rẹ̀, àti lábẹ́ ọ̀págun rẹ̀. 
\b  
\li4  
\v 18 Ní ìhà ìlà-oòrùn: 
\li1 ni ìpín Efraimu yóò pa ibùdó rẹ̀ sí lábẹ́ ọ̀págun rẹ̀. Olórí Efraimu ni Eliṣama ọmọ Ammihudu.  
\v 19 Iye ìpín rẹ̀ jẹ́ ọ̀kẹ́ méjì lé ó lẹ̀ẹ́dẹ́gbẹ̀ta (40,500). 
\li1  
\v 20 Ẹ̀yà Manase ni yóò tẹ̀lé wọn. Olórí Manase ni Gamalieli ọmọ Pedasuri.  
\v 21 Iye ìpín rẹ̀ ni ẹgbàá mẹ́rìndínlógún ó lé igba (32,200). 
\li1  
\v 22 Ẹ̀yà Benjamini ni yóò tẹ̀lé e. Olórí Benjamini ni Abidani ọmọ Gideoni.  
\v 23 Iye ìpín rẹ̀ ni ẹgbàá mẹ́tàdínlógún ó lé egbèje (35,400). 
\li4  
\v 24 Gbogbo ènìyàn tí a yàn sí ibùdó Efraimu, gẹ́gẹ́ bí ìpín wọn, àpapọ̀ iye wọn jẹ́ ẹgbàá mẹ́rìnléláàádọ́ta ó lé ọgọ́rùn-ún (108,100). Àwọn ni yóò jáde sìkẹ́ta. 
\b  
\li4  
\v 25 Ní ìhà àríwá: 
\li1 ni ìpín Dani yóò pa ibùdó sí lábẹ́ ọ̀págun wọn. Olórí Dani ni Ahieseri ọmọ Ammiṣaddai.  
\v 26 Iye ìpín rẹ̀ jẹ́ ẹgbàá mọ́kànlélọ́gbọ̀n ó lé ẹ̀ẹ́dẹ́gbẹ̀rin (62,700). 
\li1  
\v 27 Ẹ̀yà Aṣeri ni yóò pa ibùdó tẹ̀lé wọn. Olórí Aṣeri ni Pagieli ọmọ Okanri.  
\v 28 Iye ìpín rẹ̀ jẹ́ ọ̀kẹ́ méjì ó lé ẹ̀ẹ́dẹ́gbẹ̀jọ (41,500). 
\li1  
\v 29 Ẹ̀yà Naftali ni yóò kàn lẹ́yìn wọn. Olórí Naftali ni Ahira ọmọ Enani.  
\v 30 Iye ìpín rẹ̀ jẹ́ ẹgbàá mẹ́rìndínlógún ó lé egbèje (53,400). 
\li4  
\v 31 Gbogbo ènìyàn tí a yàn sí ibùdó Dani jẹ́ ẹgbàá méjìdínlọ́gọ̀rin ó lé ẹgbẹ̀jọ (157,600). Àwọn ni yóò jáde kẹ́yìn lábẹ́ ọ̀págun wọn. 
\b  
\li4  
\v 32 Wọ̀nyí ni àwọn ọmọ Israẹli tí wọ́n kà nípa ìdílé wọn. Gbogbo àwọn tó wà ní ibùdó, gẹ́gẹ́ bí ìpín wọn, wọ́n jẹ́ ọgbọ̀n ọ̀kẹ́ ó lé egbèjìdínlógún dín làádọ́ta (603,550).  
\v 33 Ṣùgbọ́n a kò ka àwọn ọmọ Lefi papọ̀ mọ́ àwọn Israẹli gẹ́gẹ́ bí \nd Olúwa\nd* ti pa á láṣẹ fún Mose. 
\b  
\p  
\v 34 Àwọn ọmọ Israẹli ṣe gbogbo ohun tí \nd Olúwa\nd* pàṣẹ fún Mose, báyìí ni wọ́n ṣe pa ibùdó lábẹ́ ọ̀págun wọn, bẹ́ẹ̀ náà sì ni wọ́n ṣe jáde, oníkálùkù pẹ̀lú ẹbí àti ìdílé rẹ̀. 
\c 3  
\s1 Àwọn ẹ̀yà Lefi 
\p  
\v 1 Ìwọ̀nyí ni ìdílé Aaroni àti Mose ní ìgbà tí \nd Olúwa\nd* bá Mose sọ̀rọ̀ ní òkè Sinai. 
\b  
\p  
\v 2       Orúkọ àwọn ọmọ Aaroni nìwọ̀nyí, Nadabu ni àkọ́bí, Abihu, Eleasari àti Itamari.  
\v 3 Orúkọ àwọn ọmọ Aaroni ni ìwọ̀nyí, àwọn àlùfáà tí a fi òróró yàn, àwọn tí a fi joyè àlùfáà láti ṣiṣẹ́ gẹ́gẹ́ bí àlùfáà.  
\v 4 Ṣùgbọ́n Nadabu àti Abihu ti kú níwájú \nd Olúwa\nd* nígbà tí wọ́n rú iná àjèjì níwájú \nd Olúwa\nd* nínú ijù Sinai, àwọn méjèèjì kò sì ní ọmọ. Báyìí Eleasari àti Itamari ló ṣiṣẹ́ àlùfáà nígbà ayé Aaroni baba wọn. 
\p  
\v 5 \nd Olúwa\nd* sọ fún Mose pé,  
\v 6 “Kó ẹ̀yà Lefi wá, kí o sì fà wọ́n fún Aaroni àlùfáà láti máa ràn án lọ́wọ́.  
\v 7 Wọn yóò máa ṣiṣẹ́ fún un àti fún gbogbo ìjọ ènìyàn ní àgọ́ ìpàdé bí wọ́n ti ń ṣiṣẹ́ ìsìn nínú àgọ́.  
\v 8 Wọn yóò máa tọ́jú gbogbo ohun èlò inú àgọ́ ìpàdé, wọn yóò sì máa ṣe ojúṣe àwọn ọmọ Israẹli nípa ṣíṣe iṣẹ́ nínú àgọ́.  
\v 9 Fi ẹ̀yà Lefi jì Aaroni àti àwọn ọmọ rẹ̀, àwọn nìkan ni a fi fún Aaroni nínú gbogbo àwọn ọmọ Israẹli.  
\v 10 Kí o sì yan Aaroni àti àwọn ọmọ rẹ̀ láti máa ṣiṣẹ́ àlùfáà; àlejò tó bá súnmọ́ ibi mímọ́ pípa ni kí ẹ pa á.” 
\p  
\v 11 \nd Olúwa\nd* tún sọ fún Mose pé,  
\v 12 “Báyìí èmi fúnra mi ti mú ẹ̀yà Lefi láàrín àwọn ọmọ Israẹli dípò gbogbo àkọ́bí ọkùnrin àwọn ọmọbìnrin Israẹli. Ti èmi ni àwọn ọmọ Lefi,  
\v 13 nítorí pé ti èmi ni gbogbo àkọ́bí. Ní ọjọ́ tí mo pa gbogbo àkọ́bí ní ilẹ̀ Ejibiti ni mo ti ya gbogbo àkọ́bí sọ́tọ̀ ní Israẹli yálà ti ènìyàn tàbí ti ẹranko. Gbogbo wọn gbọdọ̀ jẹ́ ti èmi. Èmi ni \nd Olúwa\nd*.” 
\s1 Kíka àwọn ọmọ Lefi 
\p  
\v 14 Nígbà náà ni \nd Olúwa\nd* sọ fún Mose ní aginjù Sinai pé,  
\v 15  “Ka àwọn ọmọ Lefi nípa ilé baba wọn àti ìdílé wọn kí o ka gbogbo ọmọkùnrin láti ọmọ oṣù kan sókè.”  
\v 16 Mose sì kà wọ́n gẹ́gẹ́ bí ọ̀rọ̀ \nd Olúwa\nd* ti pa á láṣẹ fún un. 
\b  
\li1  
\v 17       Wọ̀nyí ni orúkọ àwọn ọmọ Lefi: 
\li2 Gerṣoni, Kohati àti Merari. 
\li1  
\v 18 Wọ̀nyí ni orúkọ àwọn ọmọ Gerṣoni: 
\li2 Libni àti Ṣimei. 
\li1  
\v 19 Àwọn ìdílé Kohati ni: 
\li2 Amramu, Isari, Hebroni àti Usieli. 
\li1  
\v 20 Àwọn ìdílé Merari ni: 
\li2 Mahili àti Muṣi. 
\b  
\li4 Wọ̀nyí ni ìdílé Lefi gẹ́gẹ́ bí ilé baba wọn. 
\b  
\li4  
\v 21 Ti Gerṣoni ni ìdílé Libni àti Ṣimei; àwọn ni ìdílé Gerṣoni. 
\li1  
\v 22 Iye àwọn ọmọkùnrin tí ọjọ́ orí wọ́n jẹ́ oṣù kan ó lé, jẹ́ ẹgbàata ó lé ẹ̀ẹ́dẹ́gbẹ̀jọ (7,500). 
\li1  
\v 23 Àwọn ìdílé Gerṣoni yóò pa ibùdó sí ìhà ìwọ̀-oòrùn lẹ́yìn àgọ́. 
\li1  
\v 24 Olórí àwọn ìdílé Gerṣoni ni Eliasafu ọmọ Láélì. 
\li1  
\v 25 Iṣẹ́ àwọn ìdílé Gerṣoni nínú àgọ́ ìpàdé ni pé àwọn yóò máa tọ́jú àgọ́, ìbòrí àgọ́, aṣọ títa ẹnu-ọ̀nà àgọ́ ìpàdé,  
\v 26 aṣọ títa ti àgbàlá, aṣọ títa ti ẹnu-ọ̀nà àgbàlá tó yí àgọ́ àti pẹpẹ ká, àwọn okùn rẹ̀ àti gbogbo ohun tó jẹ mọ́ lílò wọn. 
\b  
\li4  
\v 27 Ti Kohati ní ìdílé Amramu, Isari, Hebroni àti Usieli, wọ̀nyí ni ìran Kohati. 
\li1  
\v 28 Iye gbogbo ọmọkùnrin tí ọjọ́ orí wọn jẹ́ ọmọ oṣù kan ó lé jẹ́ ẹgbàá mẹ́rin ó lé ẹgbẹ̀ta (8,600), 
\li1 tí yóò máa ṣiṣẹ́ ní ibi mímọ́. 
\li1  
\v 29 Àwọn ìdílé Kohati yóò pa ibùdó wọn sí ìhà gúúsù ní ẹ̀gbẹ́ àgọ́. 
\li1  
\v 30 Olórí àwọn ìdílé Kohati ni Elisafani ọmọ Usieli. 
\li1  
\v 31 Àwọn ni yóò máa tọ́jú àpótí ẹ̀rí, tábìlì, ọ̀pá fìtílà, àwọn pẹpẹ, gbogbo ohun èlò ibi mímọ́ tí à ń lò fún iṣẹ́ ìsìn, aṣọ títa àti gbogbo ohun tó jẹ mọ́ lílò wọn. 
\li1  
\v 32 Eleasari ọmọ Aaroni àlùfáà ni alákòóso gbogbo àwọn olórí ìdílé Lefi. Òun ni wọ́n yàn lórí gbogbo àwọn tí yóò máa tọ́jú ibi mímọ́. 
\b  
\li4  
\v 33 Ti Merari ni ìran Mahili àti Muṣi, àwọn ni ìran Merari. 
\li1  
\v 34 Iye gbogbo ọmọkùnrin tí ọjọ́ orí wọ́n jẹ́ oṣù kan ó lé, èyí tí wọ́n kà jẹ́ igba mọ́kànlélọ́gbọ̀n (6,200). 
\li1  
\v 35 Olórí àwọn ìdílé ìran Merari ni Ṣurieli ọmọ Abihaili. 
\li1 Wọn yóò pa ibùdó wọn sí ìhà àríwá àgọ́. 
\li1  
\v 36 Àwọn ìran Merari ni a yàn fún títọ́jú àwọn férémù àgọ́, ọ̀pá ìdábùú rẹ̀, òpó rẹ̀, ihò òpó rẹ̀ àti gbogbo ohun èlò tó jẹ mọ́ lílò wọn.  
\v 37 Iṣẹ́ wọn tún ni títọ́jú àwọn òpó tó yí àgbàlá ká, ihò òpó rẹ̀, èèkàn àti okùn wọn. 
\b  
\li1  
\v 38 Mose àti Aaroni pẹ̀lú àwọn ọmọ yóò pa àgọ́ ní ìdojúkọ ìwọ̀-oòrùn níwájú àgọ́ ìpàdé. 
\li1 Iṣẹ́ wọn ni láti máa mójútó iṣẹ́ ìsìn ibi mímọ́ àti láti máa ṣiṣẹ́ ìsìn fún àwọn ọmọ Israẹli. 
\li1 Àlejò tó bá súnmọ́ ibi mímọ́ yàtọ̀ sí àwọn tí a yàn, pípa ni kí ẹ pa á. 
\b  
\li4  
\v 39 Àpapọ̀ iye àwọn ọmọ Lefi tí a kà gẹ́gẹ́ bí \nd Olúwa\nd* ti pa á láṣẹ fún Mose àti Aaroni gẹ́gẹ́ bí ìran wọn, pẹ̀lú gbogbo ọmọkùnrin tí ọjọ́ orí wọn jẹ́ ọmọ oṣù kan ó lé jẹ́ ẹgbẹ̀rún méjìlélógún (22,000). 
\b  
\p  
\v 40 \nd Olúwa\nd* sọ fún Mose pé, “Ka gbogbo àkọ́bí ọmọkùnrin Israẹli láti ọmọ oṣù kan ó lé kí o sì ṣe àkọsílẹ̀ orúkọ wọn.  
\v 41 Kí o sì gba àwọn ọmọ Lefi dípò gbogbo àkọ́bí àwọn ọmọ Israẹli, kí o sì gba gbogbo ẹran ọ̀sìn àwọn ọmọ Lefi fún mi dípò gbogbo àkọ́bí àwọn ẹran ọ̀sìn àwọn ọmọ Israẹli. Èmi ni \nd Olúwa\nd*.” 
\p  
\v 42 Mose sì ka gbogbo àkọ́bí àwọn ọmọ Israẹli gẹ́gẹ́ bí \nd Olúwa\nd* ti pàṣẹ fún un.  
\v 43 Àpapọ̀ iye àwọn àkọ́bí ọkùnrin láti ọmọ oṣù kan ó lé, ní àkọsílẹ̀ orúkọ wọn jẹ́ ẹgbẹ̀rún méjìlélógún ó lé ọ̀rìnlúgba ó dín méje (22,273). 
\p  
\v 44 \nd Olúwa\nd* tún sọ fún Mose pé,  
\v 45  “Gba àwọn ọmọ Lefi dípò gbogbo àkọ́bí àwọn ọmọ Israẹli àti ohun ọ̀sìn àwọn ọmọ Lefi dípò ohun ọ̀sìn àwọn ọmọ Israẹli. Tèmi ni àwọn ọmọ Lefi. Èmi ni \nd Olúwa\nd*.  
\v 46 Nísinsin yìí, láti lè ra ọ̀rìnlúgba dín méje (273) àkọ́bí àwọn Israẹli tó ju iye àwọn ọmọ Lefi lọ,  
\v 47 ìwọ yóò gba ṣékélì márùn-ún lórí ẹni kọ̀ọ̀kan gẹ́gẹ́ bí iye owó ibi mímọ́, èyí tí í ṣe ogún gera.  
\v 48 Owó tí a fi ra àwọn àkọ́bí ọmọ Israẹli tó lé yìí, ni kí o kó fún Aaroni àti àwọn ọmọ rẹ̀.” 
\p  
\v 49 Nígbà náà ni Mose gba owó ìràpadà àwọn ènìyàn tó ṣẹ́kù lẹ́yìn tí àwọn ọmọ Lefi ti ra àwọn yòókù padà.  
\v 50 Mose sì gba egbèje ṣékélì ó dín márùndínlógójì (1,365) gẹ́gẹ́ bí iye ṣékélì ibi mímọ́ lọ́wọ́ àkọ́bí àwọn ọmọ Israẹli.  
\v 51 Mose sì kó owó ìràpadà yìí fún Aaroni àti àwọn ọmọ rẹ̀, bí \nd Olúwa\nd* ti pa á láṣẹ fún un. 
\c 4  
\s1 Àwọn ọmọ Kohati 
\p  
\v 1 \nd Olúwa\nd* sọ fún Mose àti Aaroni pé,  
\v 2 “Ka iye àwọn ọmọ Kohati láàrín àwọn ọmọ Lefi nípa ilé baba wọn àti ìdílé wọn.  
\v 3 Ka gbogbo ọkùnrin láti ọmọ ọgbọ̀n ọdún títí dé àádọ́ta ọdún gbogbo àwọn tó ń ṣiṣẹ́ nínú àgọ́ ìpàdé. 
\p  
\v 4 “Wọ̀nyí ni iṣẹ́ ìsìn àwọn ọmọ Kohati nínú àgọ́ àjọ, láti tọ́jú àwọn ohun èlò mímọ́ jùlọ.  
\v 5 Nígbà tí àgọ́ yóò bá tẹ̀síwájú, Aaroni àti àwọn ọmọ rẹ̀ yóò wọ inú rẹ̀, wọn yóò sí aṣọ ìbòrí rẹ̀, wọn yóò sì fi bo àpótí ẹ̀rí.  
\v 6 Wọn yóò sì fi awọ ewúrẹ́ bò ó, lórí awọ ewúrẹ́ yìí ni wọn ó tẹ̀ bọ ààyè rẹ̀. 
\p  
\v 7 “Lórí tábìlì àkàrà ìfihàn ni kí wọn ó na aṣọ aláró kan sí, kí wọn kí ó sì fi àwopọ̀kọ́ sórí rẹ̀, àti ṣíbí àti àwokòtò àti ìgò fún ọrẹ ohun mímu; àti àkàrà ìgbà gbogbo ní kí ó wà lórí rẹ̀.  
\v 8 Lórí gbogbo nǹkan wọ̀nyí ni wọn yóò da, wọn ó tún fi awọ ewúrẹ́ bò ó, wọn ó sì fi òpó rẹ̀ bọ ààyè rẹ̀. 
\p  
\v 9 “Kí wọn kí ó sì mú aṣọ aláwọ̀ aláró kan, kí wọn kí ó sì fi bo ọ̀pá fìtílà àti fìtílà rẹ̀, àti alumagaji rẹ̀, àti àwo alumagaji rẹ̀, àti gbogbo ohun èlò òróró rẹ̀, èyí tí wọ́n fi ń ṣe iṣẹ́ rẹ̀.  
\v 10 Kí wọn ó fi awọ ẹran yí fìtílà àti gbogbo ohun èlò rẹ, kí wọn kí ó sì gbé e lé orí férémù tí wọn yóò fi gbé e. 
\p  
\v 11 “Ní orí pẹpẹ wúrà ni kí wọn ó tẹ́ aṣọ aláró kan sí, wọn yóò sì fi awọ seali bò ó, kí wọ́n sì fi òpó rẹ̀ bọ ààyè rẹ̀. 
\p  
\v 12 “Kí wọn kó gbogbo ohun èlò tí wọ́n ń lò fún iṣẹ́ ìsìn ní ibi mímọ́, kí wọn ó fi aṣọ aláwọ̀ búlúù yìí, kí wọn ó sì fi awọ seali bò ó, kí wọn ó sì fi gbé wọn ka orí férémù. 
\p  
\v 13 “Kí wọn ó kó eérú kúrò lórí pẹpẹ idẹ, kí wọn ó sì tẹ́ aṣọ aláwọ̀ àlùkò lé e lórí.  
\v 14 Nígbà náà ni kí wọn ó kó gbogbo ohun èlò fún iṣẹ́ ìsìn níbi pẹpẹ, títí dórí àwo iná, fọ́ọ̀kì ẹran, ọkọ́ eérú àti àwokòtò. Kí wọn ó fi awọ ewúrẹ́ bo gbogbo rẹ̀, kí wọn ó sì fi òpó rẹ̀ bọ ààyè rẹ̀. 
\p  
\v 15 “Lẹ́yìn tí Aaroni àti àwọn ọmọ rẹ̀ ti parí bíbo ibi mímọ́ àti gbogbo ohun èlò ibi mímọ́, nígbà tí àgọ́ bá sì ṣetán láti tẹ̀síwájú, kí àwọn ọmọ Kohati bọ́ síwájú láti gbé e, ṣùgbọ́n wọn kò gbọdọ̀ fọwọ́ kan ohun mímọ́ kankan, bí wọ́n bá ṣe bẹ́ẹ̀ wọn ó kú. Àwọn ọmọ Kohati ni yóò gbé gbogbo ohun tó wà nínú àgọ́ ìpàdé. 
\p  
\v 16 “Iṣẹ́ Eleasari ọmọ Aaroni tí í ṣe àlùfáà ni ṣíṣe àbojútó òróró fìtílà, tùràrí dídùn, ẹbọ ohun jíjẹ ìgbà gbogbo àti òróró ìtasórí. Kí ó jẹ́ alábojútó gbogbo ohun tó jẹ mọ́ àgọ́ àti gbogbo ohun tó wà nínú rẹ̀, pẹ̀lú gbogbo ohun èlò ibi mímọ́.” 
\p  
\v 17 \nd Olúwa\nd* sọ fún Mose àti Aaroni pé,  
\v 18 “Rí i pé a kò gé ẹ̀yà Kohati kúrò lára àwọn ọmọ Lefi.  
\v 19 Nítorí kí wọ́n lè yè, kí wọ́n má ba à kú nígbà tí wọ́n bá súnmọ́ tòsí àwọn ohun mímọ́ jùlọ: Aaroni àti àwọn ọmọ rẹ̀ ni kí ó wọ ibi mímọ́ láti pín iṣẹ́ oníkálùkù àti àwọn ohun tí wọn yóò gbé.  
\v 20 Ṣùgbọ́n àwọn ọmọ Kohati kò gbọdọ̀ wọlé láti wo àwọn ohun mímọ́, bó tilẹ̀ jẹ́ ìṣẹ́jú kan, bí wọ́n bá ṣe bẹ́ẹ̀, wọn yóò kú.” 
\s1 Àwọn ọmọ Gerṣoni 
\p  
\v 21 \nd Olúwa\nd* sọ fún Mose pé,  
\v 22 “Tún ka iye àwọn ọmọ Gerṣoni nípa ilé baba wọn àti ìdílé wọn.  
\v 23 Ka gbogbo ọkùnrin láti ọmọ ọgbọ̀n ọdún títí dé àádọ́ta ọdún, gbogbo àwọn tó ń wá ṣiṣẹ́ ní àgọ́ ìpàdé. 
\p  
\v 24 “Èyí ni iṣẹ́ ìsìn ìdílé àwọn ọmọ Gerṣoni, bí wọ́n ti ń ṣiṣẹ́ àti ní ẹrù rírù.  
\v 25 Àwọn ni yóò máa ru àwọn aṣọ títa ti àgọ́, ti àgọ́ ìpàdé àti ìbòrí rẹ̀, àti awọ ewúrẹ́ tí a fi bò ó, aṣọ títa ẹnu-ọ̀nà àgọ́ ìpàdé,  
\v 26 aṣọ títa ti àgbàlá tó yí àgọ́ àti pẹpẹ ká, aṣọ títa ti ẹnu-ọ̀nà àbáwọlé sí àgbàlá, okùn àti àwọn ohun èlò iṣẹ́ ìsìn, àti ohun gbogbo tí à ń lò fún wọn, bẹ́ẹ̀ ni wọn ó máa sìn. Àwọn ọmọ Gerṣoni ni yóò ṣe gbogbo ohun tó bá yẹ pẹ̀lú àwọn nǹkan wọ̀nyí.  
\v 27 Gbogbo iṣẹ́ ìsìn àwọn ọmọ Gerṣoni yálà ni iṣẹ́ ṣíṣe tàbí ní ẹrù rírù ni, Aaroni àti àwọn ọmọ rẹ̀ ni yóò máa darí wọn; ìwọ ni kí o sì yàn ẹrù tí oníkálùkù yóò rù fún un.  
\v 28 Èyí ni iṣẹ́ ìdílé àwọn Gerṣoni ni àgọ́ ìpàdé Itamari, ọmọ Aaroni tí í ṣe àlùfáà ni yóò sì jẹ alábojútó iṣẹ́ wọn. 
\s1 Àwọn ọmọ Merari 
\p  
\v 29 “Ka iye àwọn ọmọ Merari nípa ilé baba wọn àti ìdílé wọn.  
\v 30 Ka gbogbo ọkùnrin láti ọmọ ọgbọ̀n ọdún títí dé àádọ́ta ọdún, gbogbo àwọn tó ń wá ṣiṣẹ́ ní àgọ́ ìpàdé.  
\v 31 Iṣẹ́ tí wọn yóò sì máa ṣe nínú àgọ́ ìpàdé nìyìí: gbígbẹ́ àwọn férémù àgọ́, pákó ìdábùú rẹ̀, òpó àti ihò òpó rẹ̀,  
\v 32 pẹ̀lú gbogbo òpó tó yí àgbàlá ká àti ohun èlò tó jẹ mọ́ lílò wọn, kí o sì yan ohun tí oníkálùkù yóò rù fún un.  
\v 33 Èyí ni iṣẹ́ ìsìn ìdílé àwọn ọmọ Merari, bí wọn yóò ti máa ṣiṣẹ́ ní àgọ́ ìpàdé lábẹ́ àkóso Itamari ọmọ Aaroni tí í ṣe àlùfáà.” 
\s1 Àbájáde kíka àwọn ọmọ Lefi 
\li1  
\v 34 Mose àti Aaroni pẹ̀lú àwọn olórí ìjọ ènìyàn ka àwọn ọmọ Kohati nípa ìdílé àti ilé baba wọn. 
\li2  
\v 35 Gbogbo ọmọkùnrin láti ọmọ ọgbọ̀n ọdún títí dé àádọ́ta ọdún gbogbo àwọn tó ń wá ṣiṣẹ́ ní Àgọ́ ìpàdé.  
\v 36 Iye wọn nípa ìdílé jẹ́ ẹgbẹ̀rìnlá ó dín làádọ́ta (2,750).  
\v 37 Èyí ni àpapọ̀ iye àwọn ọmọ Kohati tó ń ṣiṣẹ́ ní àgọ́ ìpàdé; tí Mose àti Aaroni kà gẹ́gẹ́ bí \nd Olúwa\nd* ti pa á láṣẹ fún Mose. 
\b  
\li1  
\v 38 Wọ́n ka àwọn ọmọ Gerṣoni nípa ìdílé àti ilé baba wọn. 
\li2  
\v 39 Gbogbo ọmọkùnrin láti ọmọ ọgbọ̀n ọdún títí dé àádọ́ta, gbogbo àwọn tó lè ṣiṣẹ́ ní àgọ́ ìpàdé.  
\v 40 Iye wọn nípa ìdílé àti ilé baba wọn jẹ́ ẹgbẹ̀tàlá ó lé ọgbọ̀n (2,630).  
\v 41 Èyí jẹ́ àpapọ̀ iye àwọn ọmọ Gerṣoni, àwọn tó ṣiṣẹ́ ní àgọ́ ìpàdé. Mose àti Aaroni ṣe bí àṣẹ \nd Olúwa\nd*. 
\b  
\li1  
\v 42 Wọ́n ka àwọn ọmọ Merari nípa ìdílé àti ilé baba wọn. 
\li2  
\v 43 Gbogbo ọkùnrin láti ọmọ ọgbọ̀n ọdún títí dé àádọ́ta ọdún, àwọn tó ṣiṣẹ́ ní àgọ́ ìpàdé.  
\v 44 Iye wọn nípa ìdílé àti ilé baba wọn jẹ́ ẹgbẹ̀rìndínlógún (3,200).  
\v 45 Èyí ni àpapọ̀ iye àwọn ọmọ Merari. Mose àti Aaroni kà wọ́n gẹ́gẹ́ bí àṣẹ \nd Olúwa\nd* láti ẹnu Mose. 
\b  
\li4  
\v 46 Gbogbo àwọn tí a kà nínú àwọn ọmọ Lefi, ti Mose àti Aaroni àti àwọn olórí Israẹli kà, nípa ìdílé wọn àti gẹ́gẹ́ bí ilé baba wọn.  
\v 47 Gbogbo ọkùnrin láti ọmọ ọgbọ̀n ọdún títí dé àádọ́ta, àwọn tó ń ṣiṣẹ́ ìsìn tó sì ń ru àwọn ẹrù inú Àgọ́ ìpàdé.  
\v 48 Àpapọ̀ iye wọn jẹ́ ẹgbẹ̀tàlá lé lẹ́gbàarin ó dín ogún (8,580).  
\v 49 Wọ́n yan iṣẹ́ àti àwọn ohun tí ẹni kọ̀ọ̀kan yóò máa gbé fún un gẹ́gẹ́ bí \nd Olúwa\nd* ti pàṣẹ láti ẹnu Mose. 
\b  
\p Bẹ́ẹ̀ ni wọ́n ṣe kà wọ́n gẹ́gẹ́ bí \nd Olúwa\nd* ti pàṣẹ fún Mose. 
\c 5  
\s1 Wíwà ní mímọ́ ibùdó 
\p  
\v 1 \nd Olúwa\nd* sọ fún Mose pé,  
\v 2  “Pàṣẹ fún àwọn ọmọ Israẹli pé kí wọn ó lé ẹnikẹ́ni tó bá ní ẹ̀tẹ̀, ìtújáde ara ní oríṣìíríṣìí tàbí ẹni tó jẹ́ aláìmọ́ nípa fífọwọ́ kan òkú.  
\v 3 Irú ẹni bẹ́ẹ̀ yálà ọkùnrin tàbí obìnrin, ẹ lé wọn jáde kúrò nínú ibùdó kí wọn má ba à ba ibùdó wọn jẹ́ níbi tí èmi ń gbé láàrín wọn.”  
\v 4 Àwọn ọmọ Israẹli sì ṣe bẹ́ẹ̀; wọ́n lé wọn jáde kúrò nínú ibùdó. Wọn ṣe gẹ́gẹ́ bí \nd Olúwa\nd* ti sọ fún Mose. 
\s1 Ìjẹ́wọ́ àti àtúnṣe 
\p  
\v 5 \nd Olúwa\nd* sọ fún Mose pé,  
\v 6 “Sọ fún àwọn ọmọ Israẹli: ‘Nígbà tí ọkùnrin kan tàbí obìnrin kan bá ṣẹ̀ ara wọn lọ́nà kan tàbí òmíràn, tí wọ́n sì ṣe àìṣòótọ́ sí \nd Olúwa\nd*, ẹni náà jẹ̀bi.  
\v 7 Ó gbọdọ̀ jẹ́wọ́ ẹ̀ṣẹ̀ tí ó sẹ̀. Ó gbọdọ̀ san ẹ̀san rẹ̀ ní ojú owó, kí ó sì fi ìdámárùn-ún rẹ̀ lé e, kí ó sì fi fún ẹni tí òun jẹ̀bi rẹ̀.  
\v 8 Ṣùgbọ́n bí irú ẹni bẹ́ẹ̀ kò bá ní ìbátan tí ó súnmọ́ ọn tí ó lè ṣe àtúnṣe àṣìṣe rẹ̀ náà fún, àtúnṣe náà jẹ́ ti \nd Olúwa\nd*, ẹ sì gbọdọ̀ ko fún àlùfáà pẹ̀lú àgbò tí a fi ṣe ètùtù fún ẹni náà.  
\v 9 Gbogbo ọrẹ ohun mímọ́ tí àwọn ọmọ Israẹli bá mú wá fún àlùfáà jẹ́ tirẹ̀.  
\v 10 Ọrẹ ohun mímọ́ ẹnìkọ̀ọ̀kan jẹ́ ti òun nìkan, ṣùgbọ́n ohunkóhun tó bá fún àlùfáà yóò jẹ́ ti àlùfáà.’ ” 
\s1 Àyẹ̀wò fún aláìṣòótọ́ ìyàwó 
\p  
\v 11 \nd Olúwa\nd* sọ fún Mose wí pé,  
\v 12 “Bá àwọn ọmọ Israẹli sọ̀rọ̀ kí o sọ fún wọn pé, ‘Bí ìyàwó ọkùnrin kan bá yapa tó sì ṣe àìṣòótọ́ sí i,  
\v 13 nípa mímú kí ọkùnrin mìíràn bá a lòpọ̀ tí ó sì fi èyí pamọ́ fún ọkọ rẹ̀, tí a kò si gbá a mú nínú ìwà àìmọ́ rẹ̀ (nítorí pé kò sí ẹlẹ́rìí àti pé wọn kò ká a mọ́ nígbà tí ó ń dẹ́ṣẹ̀ náà).  
\v 14 Ṣùgbọ́n tí ẹ̀mí owú jíjẹ bá bà lé ọkọ rẹ̀ dé bi pé ó ń funra sí ìyàwó rẹ̀ yìí tí ìyàwó rẹ̀ sì wà ní àìmọ́ nítòótọ́, tàbí tí ẹ̀mí owú bá bà lé ọkùnrin kan tó sì ń jowú ìyàwó rẹ̀ bí ó tilẹ̀ jẹ́ pé ó wà ní mímọ́,  
\v 15 nígbà náà ni ọkùnrin yìí yóò mú ìyàwó rẹ̀ lọ sọ́dọ̀ àlùfáà. Ọkùnrin náà yóò sì mú ọrẹ tí a yàn fún obìnrin náà, ìdámẹ́wàá òsùwọ̀n efa ìyẹ̀fun barle. Kò gbọdọ̀ da òróró sí i, bẹ́ẹ̀ ni kò gbọdọ̀ fi tùràrí dídùn sí i nítorí pé ẹbọ ohun jíjẹ fún owú ni, èyí ti n mú ẹ̀ṣẹ̀ wá sí ìrántí. 
\p  
\v 16 “ ‘Àlùfáà yóò sì mú un wá síwájú \nd Olúwa\nd*.  
\v 17 Àlùfáà yóò sì bu erùpẹ̀ ilẹ̀ àgọ́ sínú omi mímọ́ tó bù láti ìkòkò amọ̀.  
\v 18 Lẹ́yìn èyí, àlùfáà yóò mú obìnrin náà dúró níwájú \nd Olúwa\nd* yóò sì tú irun orí obìnrin náà lé e lọ́wọ́, èyí ni ẹbọ ohun jíjẹ ti owú, àlùfáà fúnra rẹ̀ yóò sì gbé omi kíkorò tí ń mú ègún lọ́wọ́.  
\v 19 Àlùfáà yóò sì mú obìnrin náà búra, yóò wí pé, “Bí ọkùnrin mìíràn kò bá bá ọ lòpọ̀, tí ó kò sì yapa, tí o kò sì di aláìmọ́ níwọ̀n ìgbà tí ó wà lábẹ́ àṣẹ ọkọ rẹ̀, a jẹ́ pé omi kíkorò tí ń mú ègún wá yìí kò ní ṣe ọ́ níbi.  
\v 20 Ṣùgbọ́n tí ìwọ bá ti yapa kúrò lọ́dọ̀ ọkọ rẹ, tí o bá ti ba ara rẹ jẹ́ nípa jíjẹ́ kí ọkùnrin tí kì í ṣe ọkọ rẹ bá ọ lòpọ̀,”  
\v 21 nígbà náà ni àlùfáà yóò mú obìnrin náà búra, yóò sọ fún obìnrin náà pé, “Kí \nd Olúwa\nd* sọ ọ́ di ẹni ègún àti ẹni ìbáwí láàrín àwọn ènìyàn rẹ nípa mímú kí itan rẹ jẹrà, kí ikùn rẹ̀ sì wú.  
\v 22 Ǹjẹ́ kí omi yìí tí ń mú ègún wá wọ inú ara rẹ, kí ó mú ikùn rẹ̀ wú, kí ó sì mú itan rẹ̀ jẹrà dànù.” 
\p “ ‘Obìnrin náà yóò sì wí pé, “Àmín. Bẹ́ẹ̀ ni kó rí.” 
\p  
\v 23 “ ‘Nígbà náà ni àlùfáà yóò kọ ègún yìí sínú ìwé kíká, yóò sì sìn ín sínú omi kíkorò náà.  
\v 24 Àlùfáà yóò sì mú kí obìnrin náà mu omi kíkorò tí ń mú ègún wá yìí, omi náà yóò wọ inú rẹ̀ yóò sì fa ìrora kíkorò fún obìnrin náà bí ó bá jẹ̀bi.  
\v 25 Àlùfáà yóò gba ọrẹ ohun jíjẹ owú náà lọ́wọ́ rẹ̀, yóò fì í síwájú \nd Olúwa\nd*, yóò sì mú iná sórí pẹpẹ.  
\v 26 Àlùfáà yóò bu ẹ̀kúnwọ́ kan nínú ọrẹ ohun jíjẹ náà, yóò sun ún lórí pẹpẹ gẹ́gẹ́ bí ẹbọ ìrántí lẹ́yìn tí ó ti mú kí obìnrin náà mu omi.  
\v 27 Bí ó bá ti mú obìnrin yìí mu omi náà, bí ó bá sì jẹ́ pé obìnrin náà ti ba ara rẹ̀ jẹ́, tí ó sì ṣe àìṣòótọ́ sí ọkọ rẹ̀, omi tí ń mú ègún wá, yóò wọ ara rẹ̀, yóò fa ìrora kíkorò fún un, ikùn rẹ̀ yóò wú, itan rẹ̀ yóò sì jẹrà dànù, yóò sì di ẹni ègún láàrín àwọn ènìyàn rẹ̀.  
\v 28 Ṣùgbọ́n tó bá jẹ́ pé obìnrin náà kò ba ara rẹ̀ jẹ́, tó sì jẹ́ mímọ́, yóò bọ́ nínú ẹ̀bi, yóò sì le bímọ. 
\p  
\v 29 “ ‘Èyí ni òfin owú jíjẹ nígbà tí obìnrin tó wà lábẹ́ ọkọ bá ṣe a ṣe má ṣe, tí ó bá ba ara rẹ̀ jẹ́,  
\v 30 tàbí nígbà tí ẹ̀mí owú jíjẹ bá bà lé ọkùnrin kan nítorí pé ó funra sí ìyàwó rẹ̀. Àlùfáà yóò mú obìnrin náà dúró níwájú \nd Olúwa\nd* yóò sì ṣe gẹ́gẹ́ bí òfin ti wí fún un.  
\v 31 Ara ọkọ rẹ̀ mọ́ nínú ẹ̀ṣẹ̀ yìí ṣùgbọ́n obìnrin náà yóò ru ẹ̀bi ẹ̀ṣẹ̀ rẹ̀.’ ” 
\c 6  
\s1 Òfin fún àwọn Nasiri 
\p  
\v 1 \nd Olúwa\nd* sọ fún Mose pé,  
\v 2 “Sọ fún àwọn ọmọ Israẹli pé, ‘Bí ọkùnrin tàbí obìnrin kan bá jẹ́ ẹ̀jẹ́ pàtàkì, ẹ̀jẹ́ ìyara-ẹni-sọ́tọ̀ sí \nd Olúwa\nd* nípa àìgé irun orí (Nasiri),  
\v 3  irú ẹni bẹ́ẹ̀ gbọdọ̀ yàgò fún wáìnì tàbí ọtí líle, ọtí wáìnì kíkan àti àwọn ohun mímu mìíràn tó bá kan. Kò gbọdọ̀ mu èso àjàrà tàbí kí ó jẹ èso àjàrà tútù tàbí gbígbẹ.  
\v 4 Níwọ́n ìgbà tí ó sì jẹ́ Nasiri, ní kò gbọdọ̀ jẹ ohunkóhun tí a fi èso àjàrà ṣe, ìbá à ṣe kóró tàbí èèpo rẹ̀. 
\p  
\v 5 “ ‘Ní gbogbo ìgbà ẹ̀jẹ́ ìyàsọ́tọ̀ rẹ̀ yìí, kí abẹ kankan má ṣe kàn án ní orí. Ó gbọdọ̀ jẹ́ mímọ́ títí tí àkókò ìyàsọ́tọ̀ rẹ̀ sí \nd Olúwa\nd* yóò fi pé; ó gbọdọ̀ jẹ́ kí irun orí rẹ̀ gùn. 
\p  
\v 6 “ ‘Ní gbogbo àkókò ìyàsọ́tọ̀ rẹ̀ sí \nd Olúwa\nd* kò gbọdọ̀ súnmọ́ òkú ènìyàn.  
\v 7 Ìbá à ṣe òkú baba, àti ìyá rẹ̀, ẹ̀gbọ́n rẹ̀ ọkùnrin tàbí obìnrin tàbí àbúrò rẹ̀, kò gbọdọ̀ sọ ara rẹ̀ di aláìmọ́ nítorí wọn, nítorí pé àmì ìyàsọ́tọ̀ rẹ̀ sí Ọlọ́run wà ní orí rẹ̀.  
\v 8 Ní gbogbo àsìkò ìyàsọ́tọ̀ rẹ̀ yìí, ó jẹ́ mímọ́ sí \nd Olúwa\nd*. 
\p  
\v 9 “ ‘Bí ẹnìkan bá kú ní ọ̀dọ̀ rẹ̀ ní òjijì, tí ó sì ba irun rẹ̀ tó yà sọ́tọ̀ jẹ́; ó gbọdọ̀ gé irun rẹ̀ ní ọjọ́ ìwẹ̀nùmọ́ rẹ̀ èyí tí í ṣe ọjọ́ keje.  
\v 10 Ní ọjọ́ kẹjọ, yóò mú àdàbà méjì àti ọmọ ẹyẹlé méjì wá sọ́dọ̀ àlùfáà ní ẹnu-ọ̀nà àgọ́ ìpàdé.  
\v 11 Àlùfáà yóò fi ọ̀kan rú ẹbọ ẹ̀ṣẹ̀ àti èkejì fún ẹbọ sísun láti fi ṣe ètùtù fún un nítorí pé ó ti ṣẹ̀ nípa wíwà níbi tí òkú ènìyàn wà. Yóò sì ya orí rẹ̀ sí mímọ́ ní ọjọ́ náà gan an.  
\v 12 Ó gbọdọ̀ ya ara rẹ̀ sọ́tọ̀ sí \nd Olúwa\nd* fún àkókò ìyàsọ́tọ̀ rẹ̀, ó sì gbọdọ̀ mú akọ ọ̀dọ́-àgùntàn ọlọ́dún kan wá gẹ́gẹ́ bí ọrẹ ẹ̀bi. Kò sì ní í ka àwọn ọjọ́ ìyàsọ́tọ̀ rẹ̀ ti tẹ́lẹ̀ nítorí pé ó tí ba ara rẹ̀ jẹ́ ní àkókò ìyàsọ́tọ̀ rẹ̀. 
\p  
\v 13       “ ‘Èyí ni òfin fún Nasiri nígbà tí àkókò ìyàsọ́tọ̀ rẹ̀ bá pé. Wọn ó mu wá sí ẹnu-ọ̀nà àgọ́ ìpàdé.  
\v 14 Níbẹ̀ ni yóò ti mú ọrẹ wá fún \nd Olúwa\nd*, akọ ọ̀dọ́-àgùntàn ọlọ́dún kan tí kò ní àbùkù fún ẹbọ sísun àti ẹgbọrọ-àgùntàn ọlọ́dún kan, tí kò ní àbùkù fún ẹbọ ẹ̀ṣẹ̀, àgbò kan tí kò ní àbùkù fún ọrẹ àlàáfíà,  
\v 15 pẹ̀lú ọrẹ ohun jíjẹ àti ọrẹ ohun mímu, apẹ̀rẹ̀ àkàrà tí a kò fi ìwúkàrà ṣe, àkàrà tí a fi ìyẹ̀fun dáradára pò mọ́ òróró àti àkàrà fẹ́lẹ́fẹ́lẹ́ tí a fi òróró sọjọ̀ lé lórí. 
\p  
\v 16 “ ‘Àlùfáà yóò gbé gbogbo rẹ̀ wá síwájú \nd Olúwa\nd*, yóò sì rú ẹbọ ẹ̀ṣẹ̀ àti ẹbọ sísun.  
\v 17 Àlùfáà yóò fi àgbò náà rú ẹbọ àlàáfíà sí \nd Olúwa\nd*, pẹ̀lú apẹ̀rẹ̀ àkàrà tí kò ní ìwúkàrà; yóò rú ẹbọ ohun jíjẹ àti ọrẹ ohun mímu. 
\p  
\v 18 “ ‘Nígbà náà ni Nasiri náà yóò fá irun ìyàsọ́tọ̀ rẹ̀ ní ẹnu-ọ̀nà àgọ́ ìpàdé. Yóò fi irun náà sínú iná tó wà lábẹ́ ẹbọ àlàáfíà. 
\p  
\v 19 “ ‘Lẹ́yìn tí Nasiri bá ti fá irun ìyàsọ́tọ̀ rẹ̀ tan, àlùfáà yóò mú apá àgbò bíbọ̀, àkàrà aláìwú kan àti àkàrà fẹ́lẹ́fẹ́lẹ́ tí kò ní ìwúkàrà láti inú apẹ̀rẹ̀ yóò sì kó gbogbo rẹ̀ lé e lọ́wọ́.  
\v 20 Àlùfáà yóò fi gbogbo rẹ̀ níwájú \nd Olúwa\nd* gẹ́gẹ́ bí ẹbọ fífì, wọ́n jẹ́ mímọ́, wọ́n sì jẹ́ ti àlùfáà pẹ̀lú igẹ̀ tí a fì àti itan tí wọ́n mú wá. Lẹ́yìn èyí, Nasiri náà lè mu wáìnì. 
\p  
\v 21 “ ‘Èyí ni òfin Nasiri tó jẹ́ ẹ̀jẹ́, ọrẹ rẹ̀ sí \nd Olúwa\nd*, yóò wà ní ìbámu pẹ̀lú ìyàsọ́tọ̀ rẹ̀ gẹ́gẹ́ bí Nasiri, ní àfikún sí àwọn ohun mìíràn tó lágbára láti mú wá. Ó gbọdọ̀ mú ẹ̀jẹ́ tó jẹ́ ṣe gẹ́gẹ́ bí òfin Nasiri.’ ” 
\s1 Ìbùkún àlùfáà 
\p  
\v 22 \nd Olúwa\nd* sọ fún Mose pé,  
\v 23 “Sọ fún Aaroni àti àwọn ọmọ rẹ̀ pé, ‘Báyìí ni kí ẹ ṣe máa súre fún àwọn ọmọ Israẹli. Ẹ sọ fún wọn pé, 
\q1  
\v 24 “ ‘ “Kí \nd Olúwa\nd* bùkún un yín, 
\q2 kí ó sì pa yín mọ́. 
\q1  
\v 25 Kí \nd Olúwa\nd* kí o mú ojú rẹ̀ kí ó mọ́lẹ̀ sí i yín lára. 
\q2 Kí ó sì ṣàánú fún un yín. 
\q1  
\v 26 Kí \nd Olúwa\nd* bojú wò yín, 
\q2 kí ó sì fún un yín ní àlàáfíà.” ’ 
\p  
\v 27 “Báyìí ni wọn ó ṣe fi orúkọ mi sára àwọn ọmọ Israẹli, Èmi ó sì bùkún wọn.” 
\c 7  
\s1 Ọrẹ níbi ìyàsímímọ́ àgọ́ 
\p  
\v 1 Nígbà tí Mose ti parí gbígbé àgọ́ dúró, ó ta òróró sí i, ó sì yà á sí mímọ́ pẹ̀lú gbogbo àwọn ohun èlò rẹ̀, Ó tún ta òróró sí pẹpẹ, ó sì yà á sí mímọ́ pẹ̀lú gbogbo ohun èlò rẹ̀.  
\v 2 Nígbà náà ni àwọn olórí Israẹli, àwọn ẹ̀yà kọ̀ọ̀kan, àwọn alábojútó àwọn tí a kà náà mú ọrẹ wá.  
\v 3 Wọ́n mú ọrẹ wọn wá síwájú \nd Olúwa\nd*: kẹ̀kẹ́ ẹrù mẹ́fà ti abo, àti akọ màlúù kan láti ọ̀dọ̀ olórí kọ̀ọ̀kan àti kẹ̀kẹ́ ẹrù kan láti ọ̀dọ̀ olórí méjì. Wọ́n sì kó wọn wá sí iwájú àgọ́. 
\p  
\v 4 \nd Olúwa\nd* sọ fún Mose pé,  
\v 5 “Gba gbogbo nǹkan wọ̀nyí lọ́wọ́ wọn, kí wọ́n ba à lè wúlò fún iṣẹ́ inú àgọ́ ìpàdé. Kó wọn fún àwọn ọmọ Lefi gẹ́gẹ́ bí iṣẹ́ ẹnìkọ̀ọ̀kan bá ṣe nílò rẹ̀.” 
\p  
\v 6 Mose sì kó àwọn kẹ̀kẹ́ ẹrù àti akọ màlúù náà fún àwọn ọmọ Lefi.  
\v 7 Ó fún àwọn ọmọ Gerṣoni ní kẹ̀kẹ́ méjì àti akọ màlúù mẹ́rin, gẹ́gẹ́ bí iṣẹ́ wọn ṣe jẹ mọ́.  
\v 8 Ó fún àwọn ọmọ Merari ní kẹ̀kẹ́ mẹ́rin àti akọ màlúù mẹ́jọ gẹ́gẹ́ bí iṣẹ́ wọn ṣe jẹ mọ́. Gbogbo wọn wà lábẹ́ àkóso Itamari ọmọ Aaroni tí í ṣe àlùfáà.  
\v 9 Ṣùgbọ́n Mose kò fún àwọn ọmọ Kohati ní nǹkan kan nítorí pé èjìká wọn ni wọn yóò fi ru àwọn ohun mímọ́ èyí tí ó jẹ́ ojúṣe tiwọn. 
\p  
\v 10 Nígbà tí a ta òróró sórí pẹpẹ. Àwọn olórí mú àwọn ọrẹ wọn wá fún ìyàsímímọ́ rẹ̀, wọ́n sì kó wọn wá síwájú pẹpẹ.  
\v 11 Nítorí tí \nd Olúwa\nd* ti sọ fún Mose pé, “Olórí kọ̀ọ̀kan ní ọjọ́ kọ̀ọ̀kan ni yóò máa mú ọrẹ tirẹ̀ wá fún ìyàsímímọ́ pẹpẹ.” 
\b  
\li4  
\v 12 Ẹni tí ó mú ọrẹ tirẹ̀ wá ní ọjọ́ kìn-ín-ní Nahiṣoni ọmọ Amminadabu láti inú ẹ̀yà Juda. 
\li1  
\v 13 Ọrẹ rẹ̀ jẹ́: 
\li2 àwo fàdákà kan tí ìwọ̀n rẹ̀ jẹ́ àádóje ṣékélì àti àwokòtò ti fàdákà tí ìwọ̀n rẹ̀ jẹ́ àádọ́rin ṣékélì, méjèèjì gẹ́gẹ́ bí iye owó ibi mímọ́ àwo kọ̀ọ̀kan kún fún ìyẹ̀fun kíkúnná dáradára tí a fi òróró pò gẹ́gẹ́ bí ẹbọ ohun jíjẹ; 
\li2  
\v 14 àwo wúrà kan tí ìwọ̀n rẹ̀ jẹ́ ṣékélì mẹ́wàá tí ó kún fún tùràrí; 
\li2  
\v 15 ọ̀dọ́ akọ màlúù kan, àgbò kan, akọ ọ̀dọ́-àgùntàn ọlọ́dún kan fún ẹbọ sísun, 
\li2  
\v 16 akọ ewúrẹ́ kan fún ẹbọ ẹ̀ṣẹ̀, 
\li2  
\v 17 akọ màlúù méjì, àgbò márùn-ún, òbúkọ ọlọ́dún kan márùn-ún tí wọn ó fi rú ẹbọ àlàáfíà. 
\li4 Wọ̀nyí ni ọrẹ Nahiṣoni ọmọ Amminadabu. 
\b  
\li4  
\v 18 Ní ọjọ́ kejì ni Netaneli ọmọ Suari olórí àwọn ọmọ Isakari mú ọrẹ tirẹ̀ wá. 
\li1  
\v 19 Ọrẹ tí ó kó wá ní: 
\li2 àwo fàdákà kan tí ìwọ̀n rẹ̀ jẹ́ àádóje ṣékélì àti àwokòtò tí ìwọ̀n rẹ̀ jẹ́ àádọ́rin ṣékélì, méjèèjì gẹ́gẹ́ bí iye owó ibi mímọ́, àwo kọ̀ọ̀kan sì kún fún ìyẹ̀fun kíkúnná dáradára tí á fi òróró pò gẹ́gẹ́ bí ẹbọ ohun jíjẹ; 
\li2  
\v 20 àwo wúrà kan tí ìwọ̀n rẹ̀ jẹ́ ṣékélì mẹ́wàá tí ó kún fún tùràrí, 
\li2  
\v 21 ọ̀dọ́ akọ màlúù kan, àgbò kan, àti akọ ọ̀dọ́-àgùntàn ọlọ́dún kan, fún ẹbọ sísun; 
\li2  
\v 22 akọ ewúrẹ́ kan fún ẹbọ ẹ̀ṣẹ̀; 
\li2  
\v 23 Màlúù méjì, àgbò márùn-ún, akọ ewúrẹ́ márùn-ún àti akọ ọ̀dọ́-àgùntàn ọlọ́dún kan márùn-ún tí wọn ó fi rú ẹbọ àlàáfíà. 
\li4 Èyí ni ọrẹ Netaneli ọmọ Suari. 
\b  
\li4  
\v 24 Eliabu ọmọ Heloni, olórí àwọn ọmọ Sebuluni ni ó mú ọrẹ rẹ̀ wá ní ọjọ́ kẹta. 
\li1  
\v 25 Àwọn ọrẹ rẹ̀ ni: 
