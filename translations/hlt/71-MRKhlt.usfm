\p
\v 19 Te \w dongah|strong="G1161"\w* \w Herodias|strong="G2266"\w* \w loh|strong="G3588"\w* \w Johan|strong="G2491"\w* te a \w hmuhuet|strong="G1758"\w* \w tih|strong="G2532"\w* \w ngawn|strong="G0615"\w* ham a \w ngaih|strong="G2309"\w* \w dae|strong="G2532"\w* ngawn \w thai|strong="G1410"\w* \w pawh|strong="G3756"\w*.  
