\id PSA - Biblica® Open New Luo Translation 2020 
\h Zaburi 
\toc1 Zaburi 
\toc2 Zaburi 
\toc3 Zab 
\mt1 Zaburi 
\c 1  
\ms1 Kitabu Mokwongo 
\mr Zaburi 1–41 
\cl Zaburi 1 
\q1  
\v 1 Nyasaye gwedho ngʼat 
\q2 ma ok lu pach joma richo, 
\q1 kata luwo yor joricho 
\q2 kata bedo e kom jojaro. 
\q1  
\v 2 To chik Jehova Nyasaye ema more, 
\q2 kendo osiko oparo kuom chikene odiechiengʼ gotieno. 
\q1  
\v 3 Ochalo gi yien mopidhi e bath aora, 
\q2 manyago olembe e kinde molemo chieke, 
\q1 kendo ma bedene ok ner. 
\b  
\q2 Gimoro amora motimo dhi maber. 
\q1  
\v 4 Joma timbegi richo to ok chal kamano kata matin! 
\q2 Gin gichalo gi mihudhi, 
\q2 ma yamo tero. 
\q1  
\v 5 Kuom mano joma timbegi richo ok nolo bura, 
\q2 adier, joricho ok nobedi e kanyakla mar joma kare, 
\b  
\q1  
\v 6 nikech Jehova Nyasaye rango yor joma kare, 
\q2 to yor joma richo to biro kethore. 
\c 2  
\cl Zaburi 2 
\q1  
\v 1 Angʼo momiyo ogendini chano timo marach 
\q2 kendo ji chano jiemo kayiem nono? 
\q1  
\v 2 Ruodhi mag piny osebiro kanyakla 
\q2 kendo jotelo pimo wach kaachiel, 
\q1 mondo giked gi Jehova Nyasaye 
\q2 kendo giked gi ngʼate mowir. 
\q1  
\v 3 “Giwacho ni, wachoduru nyorochegi; 
\q2 kendo wawit ratekegi kucha.” 
\b  
\q1  
\v 4 To Jal mobet e kom loch e polo to nyierogi anyiera, 
\q2 Ruoth goyonegi siboi. 
\q1  
\v 5 Eka okwerogi kokecho 
\q2 kendo obwogogi kopongʼ gi mirima mager, kowacho niya, 
\q1  
\v 6 “Aseketo Ruoth ma adwaro 
\q2 e Sayun, goda maler.” 
\p  
\v 7 Abiro hulo chenro mag Jehova Nyasaye ma ok lokre: 
\q1 Nowachona niya, “In wuoda; 
\q2 kawuono asedoko wuonu. 
\q1  
\v 8 Omiyo kwaya gima idwaro 
\q2 mondo aket ogendini duto obed girkeni mari, 
\q2 mondo piny ngima obed mwanduni. 
\q1  
\v 9 Initelnigi kod ludhi mar nyinyo; 
\q2 kendo initogi matindo tindo ka agulu.” 
\b  
\q1  
\v 10 Kuom mano, un ruodhi, beduru mariek; 
\q2 tangʼuru un joloch mag piny. 
\q1  
\v 11 Tiuru ne Jehova Nyasaye gi luoro 
\q2 kendo moruru e nyime gi luoro. 
\q1  
\v 12 Bolreuru e nyim Wuowi, 
\q2 nono to dipo kokecho kodu mi dongʼad ndalou, motieku, 
\q1 nimar iye nyalo wangʼ kodu kadiemo wangʼ. 
\q2 Ji duto mogeno kuome gin joma ogwedhi. 
\c 3  
\cl Zaburi 3 
\d Zaburi mar Daudi, kane oringo oa ir wuode Abisalom. 
\q1  
\v 1 Yaye Jehova Nyasaye, mano kaka wasika thoth! 
\q2 Mano kaka joma lawa ngʼeny! 
\q1  
\v 2 Ji mangʼeny wuoyo kuoma, kagiwacho ni, 
\q2 “Nyasaye ok bi rese.” \qs Sela\qs*\f + \fr 3:2 \fq Sela \ft tiend wachni ok ongʼere.\f* 
\b  
\q1  
\v 3 To In e okumbana mogengʼa, yaye Jehova Nyasaye; 
\q2 In ema imiyo alocho, kendo isetingʼo wiya malo. 
\q1  
\v 4 Aywak matek ka alemo ni Jehova Nyasaye, 
\q2 kendo odwoka gie gode maler. \qs Sela\qs* 
\b  
\q1  
\v 5 Ariera piny mondo anindi; 
\q2 kendo achako aa malo, nikech Jehova Nyasaye orita. 
\q1  
\v 6 Ok abi luoro ji gana gi gana 
\q2 molwora mondo otimna marach. 
\b  
\q1  
\v 7 Aa malo, yaye Jehova Nyasaye! 
\q2 Resa, yaye Nyasacha! 
\q1 Tur chok lemb wasika duto; 
\q2 Muk leke joma timbegi richo. 
\b  
\q1  
\v 8 Resruok aa mana kuom Jehova Nyasaye. 
\q2 Mad igweth jogi. \qs Sela\qs* 
\c 4  
\cl Zaburi 4 
\d Kuom jatend wer. Miwero gi gig wer man-gi tondegi. Zaburi mar Daudi. 
\q1  
\v 1 Ka aluongi to yie idwoka, 
\q2 yaye Nyasacha makare. 
\q1 Konya e lit momako chunya; 
\q2 yie ikecha kendo iwinj lamona. 
\b  
\q1  
\v 2 Yaye, ubiro chayo duongʼ ka ukuodo wiya nyaka karangʼo? 
\q2 Ubiro hero gik manono kendo luwo nyiseche manono nyaka karangʼo? \qs Sela\qs* 
\q1  
\v 3 Ngʼeuru ni Jehova Nyasaye oseyiera mondo abed mare owuon; 
\q2 kendo Jehova Nyasaye winja, ka aluonge. 
\b  
\q1  
\v 4 Ka iu owangʼ to kik utim richo; 
\q2 seche ma uyweyo mos e kitandau, 
\q1 to nonuru chunyu ka ulingʼ mos, 
\q2 keturu chunyu mos ka unindo e kitandau. \qs Sela\qs* 
\q1  
\v 5 Chiwuru misengini mowinjore 
\q2 kendo genuru kuom Jehova Nyasaye. 
\b  
\q1  
\v 6 Ji mangʼeny penjo niya, “En ngʼa manyalo timonwa gimoro maber?” 
\q2 Mad ler moa e lela wangʼi rieny kuomwa, yaye Jehova Nyasaye. 
\q1  
\v 7 Isepongʼo chunya gi mor maduongʼ moloyo mor ma gin-go 
\q2 e kinde ma gin-gi cham kod divai mangʼeny. 
\b  
\q1  
\v 8 Abiro riera piny mi anind gi kwe, 
\q2 nikech in kendi, yaye Jehova Nyasaye, 
\q2 in ema imiyo adak gi kwe. 
\c 5  
\cl Zaburi 5 
\d Kuom jatend wende miwero gi asili. Zaburi Mar Daudi. 
\q1  
\v 1 Chik iti mondo iwinj wechena, yaye Jehova Nyasaye, 
\q2 para kuom pek manie chunya. 
\q1  
\v 2 Winj ywakna mar dwaro kony, 
\q2 Yaye Ruodha kendo Nyasacha, 
\q2 nikech in ema alami. 
\b  
\q1  
\v 3 Yie iwinj dwonda gokinyi, yaye Jehova Nyasaye; 
\q2 aketo kwayona e nyimi gokinyi, 
\q2 kendo arito dwoko ka an gi geno. 
\q1  
\v 4 Ok in Nyasaye mamor gi timbe maricho. 
\q2 Joma richo ok nyal dak kodi kanyachiel. 
\q1  
\v 5 Josunga ok nyal chungʼ e nyimi; 
\q2 imon gi ji duto matimo gik maricho. 
\q1  
\v 6 Itieko joma wacho miriambo; 
\q2 Jehova Nyasaye ok mor gi joma dwaro chwero remo, 
\q2 kod jo-miriambo. 
\q1  
\v 7 An to, nikech kechni maduongʼ, 
\q2 abiro donjo e odi; 
\q1 abiro kulora gi luor 
\q2 ka achomo hekalu mari maler. 
\b  
\q1  
\v 8 Telna, yaye Jehova Nyasaye, kuom adiera mari, 
\q2 nikech wasigu molwora, 
\q2 yie iriena yori tir e nyima. 
\q1  
\v 9 Kata wach achiel mowuok e dho jogi ok nyal gen; 
\q2 chunygi opongʼ gi kethruok. 
\q1 Dwondgi chalo gi liel mapok oum; 
\q2 lewgi olony e wacho miriambo. 
\q1  
\v 10 Kwan-gi kaka joketho, yaye Nyasaye! 
\q2 Ket obadho ma giketo ne ji ogajgi gin giwegi. 
\q1 Riembgi nikech richogi mathoth, 
\q2 nimar gisengʼanyoni. 
\q1  
\v 11 We ji duto moketi kar pondo margi obed mamor; 
\q2 we gisiki ka giwer gimor. 
\q1 Umgi gi rit mari, 
\q2 mondo joma ohero nyingi omor kodi. 
\b  
\q1  
\v 12 Nikech igwedho joma kare adier, yaye Jehova Nyasaye; 
\q2 igengʼogi gi hapi mana ka okumba. 
\c 6  
\cl Zaburi 6 
\d Kuom jatend wer. Miwero gi gig wer man-gi tondegi. Kaluwore gi \tl sheminith\tl*\f + \fr 6:0 \fl Sheminith: \ft Ochalo ni en kit wer moro\f*. Zaburi Mar Daudi. 
\q1  
\v 1 Kik ikwera, yaye Jehova Nyasaye, ka iyi owangʼ 
\q2 kata kum kik ikuma ka mirima omaki. 
\q1  
\v 2 Kecha, yaye Jehova Nyasaye, nikech aol; 
\q2 changa, yaye Jehova Nyasaye, 
\q2 nikech chokena rama malit. 
\q1  
\v 3 Chunya winjo malit. 
\q2 Nyaka karangʼo, yaye Jehova Nyasaye, nyaka karangʼo? 
\b  
\q1  
\v 4 Lokri, yaye Jehova Nyasaye, mondo iresa; 
\q2 resa nikech herani ma ok rum. 
\q1  
\v 5 Onge ngʼama nyalo pari ka osetho. 
\q2 En ngʼa madi paki gi ei liel? 
\b  
\q1  
\v 6 Chur ma achurgo ojonya 
\q2 otieno duto abudo kitandana gi ywak, 
\q2 kendo pi wangʼa olwoko piendena. 
\q1  
\v 7 Wengena ool nikech lit ma an-go; 
\q2 ok ginen maber nikech wasika duto. 
\b  
\q1  
\v 8 Ayiuru buta, un duto ji matimo richo, 
\q2 nikech Jehova Nyasaye osewinjo ywakna. 
\q1  
\v 9 Jehova Nyasaye osewinjo ywak mar kwayo kech; 
\q2 Jehova Nyasaye orwako lamo mara. 
\q1  
\v 10 Wasika duto wigi biro kuot kendo gibiro hum nono; 
\q2 gibiro dok chien apoya nono gi wichkuot. 
\c 7  
\cl Zaburi 7 
\d Wend \tl shigaion\tl*\f + \fr 7:0 \fl Shigaion: \ft Ochalo ni en kit wer moro\f* mane Daudi owero ne Jehova Nyasaye kuom Kush ja-Benjamin. 
\q1  
\v 1 Yaye Jehova Nyasaye ma Nyasacha, in e kar pondona; 
\q2 Resa kendo igola e lwet joma lawa duto, 
\q1  
\v 2 nono to gibiro kidha kaka sibuor kidho gik moko. 
\q2 Kendo gibiro yiecha matindo tindo maonge ngʼama diresa e lwetgi. 
\b  
\q1  
\v 3 Yaye Jehova Nyasaye Nyasacha, kapo ni asetimo gima kamano adieri 
\q2 kendo lweta osetimo gima rach, 
\q1  
\v 4 kaponi asetimo marach ni ngʼama onge koda gi wach 
\q2 kata kapo ni asemayo wasika kaonge gima omiyo, 
\q1  
\v 5 to yie ni wasikano mondo olawa mi juka; 
\q2 we ginyon ngimana piny e lowo, 
\q2 mi gimi anind e buru mar lowo. \qs Sela\qs* 
\b  
\q1  
\v 6 Aa malo, yaye Jehova Nyasaye, ka in gi mirima 
\q2 aa malo irad gi gero mar wasika. 
\q2 Chiew, Nyasacha; chiew inyis adierana. 
\q1  
\v 7 We chokruoge mag ogendini olwori koni gi koni. 
\q2 Ngʼad negi bura gie kom loch mari man malo; 
\q2  
\v 8 Jehova Nyasaye mondo ongʼad bura ne ogendini. 
\q1 Ngʼadna bura, yaye Jehova Nyasaye, 
\q2 kaluwore gi ngimana makare, 
\q1 ngʼadna bura, yaye Nyasaye Man Malo Moloyo, 
\q2 kaluwore gi ngimana moriere tir. 
\q1  
\v 9 Yaye Nyasaye makare, 
\q2 In ema inono pach ji gi chunje ji, 
\q1 tiek timbe mamono mag joma richo 
\q2 mondo imi joma kare odag gi kwe. 
\b  
\q1  
\v 10 Okumbana en Nyasaye Man Malo Moloyo, 
\q2 ma reso joma chunygi oriere tir. 
\q1  
\v 11 Nyasaye en jangʼad bura makare; 
\q2 en e Nyasaye matoyo mirimbe pile ka pile. 
\q1  
\v 12 Ka ok oloko pache 
\q2 to obiro piago liganglane; 
\q2 obiro dolo okumbane mi otwe tondene. 
\q1  
\v 13 Oseiko gige mag lweny mager; 
\q2 oiko asernige makakni ka mach. 
\b  
\q1  
\v 14 Ngʼama iye okuot gi gik maricho 
\q2 kendo ma yach gi chandruok nywolo yamo nono. 
\q1  
\v 15 Ngʼama loso bur kendo kunye maber 
\q2 podho e bure mokunyono. 
\q1  
\v 16 Chandruok mokelo gaje en owuon; 
\q2 timbene mag mahundu dwogone e wiye owuon. 
\b  
\q1  
\v 17 Abiro goyo erokamano ne Jehova Nyasaye nikech en ngʼama kare 
\q2 kendo abiro wero wend pak ne nying Jehova Nyasaye Man Malo Moloyo. 
\c 8  
\cl Zaburi 8 
\d Kuom Jatend Wer. Kaluwore Gi \tl Gitith\tl*\f + \fr 8:0 \fl Gitith: \ft Ochalo ni en kit wer moro\f*. Zaburi Mar Daudi. 
\q1  
\v 1 Yaye Jehova Nyasaye, ma Ruodhwa, 
\q2 mano kaka nyingi nigi duongʼ e piny duto! 
\b  
\q1 Iseketo duongʼni maler milamo, 
\q2 moyombo polo. 
\q1  
\v 2 Ne isechano mondo 
\q2 nyithindo kod nyithindo mayom omiyi pak, 
\q1 nikech wasiki, 
\q2 mondo jawasigu kod jachul kuor olingʼ kawuoro timni. 
\b  
\q1  
\v 3 Kaparo polo mari 
\q2 ma gin tich lweti, 
\q1 kaparo dwe gi sulwe 
\q2 miseketo kargi, 
\q1  
\v 4 to dhano adhana to en angʼo momiyo ipare, 
\q2 wuod dhano to en angʼo momiyo iketo pachi kuome? 
\q1  
\v 5 Ne ichweye mapiny ne malaike 
\q2 kendo isesidhone osimbo mar duongʼ kod luor. 
\b  
\q1  
\v 6 Isekete jatelo ewi tich lweti duto; 
\q2 iseketo gik moko duto e bwo tiende: 
\q1  
\v 7 Jamni gi kweth duto 
\q2 kod le mager mag bungu, 
\q1  
\v 8 Winy duto mafuyo e kor polo, 
\q2 kod rech manie nam, 
\q2 gi le duto mamol kaluwo yore manie nembe iketo e bwo lochne. 
\b  
\q1  
\v 9 Yaye Jehova Nyasaye, ma Ruodhwa, 
\q2 mano kaka nyingi nigi duongʼ e piny duto! 
\c 9  
\cl Zaburi 9 
\d Kuom jatend wer. E dwol mar “Tho mar wuowi.” Zaburi mar Daudi. 
\q1  
\v 1 Abiro paki gi chunya duto, yaye Jehova Nyasaye; 
\q2 abiro nyiso timbegi madongo duto. 
\q1  
\v 2 Abiro bedo mamor kendo abiro bedo moil kodi; 
\q2 abiro pako nyingi gi wer, yaye Nyasaye Man Malo Moloyo. 
\b  
\q1  
\v 3 Wasika dok chien; 
\q2 gichwanyore kendo gilal e nyimi. 
\q1  
\v 4 Nikech isechungʼna matek ka ichwaka 
\q2 isebet e kom duongʼ mari, kiyalo bura kare. 
\q1  
\v 5 Isekwero ogendini kendo isetieko joma richo; 
\q2 iserucho nying-gi oko manyaka chiengʼ. 
\q1  
\v 6 Kethruok mosiko osejuko jasigu, 
\q2 isemuko miechgi madongo; 
\q2 kendo wi ji osewil kodgi. 
\b  
\q1  
\v 7 Jehova Nyasaye olocho nyaka chiengʼ, 
\q2 oseguro kom loch mare mar ngʼado bura. 
\q1  
\v 8 Obiro ngʼado bura ne piny gi tim makare; 
\q2 obiro rito ogendini gi adiera. 
\q1  
\v 9 Jehova Nyasaye en kar pondo ne joma idiyo, 
\q2 en e kar pondo e kinde mag chandruok. 
\q1  
\v 10 Joma ongʼeyo nyingi biro geno kuomi, 
\q2 nikech in, yaye Jehova Nyasaye, 
\q2 ne pok ijwangʼo joma manyi. 
\b  
\q1  
\v 11 Wer wende pak ne Jehova Nyasaye, 
\q2 mobet e kom lochne e Sayun; 
\q2 hul ni ogendini gik mosetimo. 
\q1  
\v 12 Nikech ngʼat machulo kuor kuom remo mochwer siko kaparo; 
\q2 ok owe mak odewo ywak joma hinyore. 
\b  
\q1  
\v 13 Neye kaka wasika sanda, yaye Jehova Nyasaye! 
\q2 Kecha kendo tingʼa igola e dhorangeye mag tho, 
\q1  
\v 14 mondo anyis pakni 
\q2 e dhorangeye mag Nyi Sayun, 
\q2 kendo abed mamor kuno nikech warruokni. 
\q1  
\v 15 Ogendini oselutore e buche ma gikunyo; 
\q2 tiendegi ogajore e tondegi ma gichokogo ji. 
\q1  
\v 16 Jehova Nyasaye ongʼere nikech adier mare; 
\q2 joma timbegi richo omoko e gik ma giloso gi lwetgi giwegi. \qs Higaion. Sela\qs* 
\q1  
\v 17 Joma timbegi richo dok e bur matut, 
\q2 nyaka ogendini duto ma wigi wil gi Nyasaye. 
\q1  
\v 18 To jochan wiyi ok nowilgo ngangʼ 
\q2 kendo geno mar joma hinyore ok rum. 
\b  
\q1  
\v 19 Aa malo, yaye Jehova Nyasaye, kik iyie mondo dhano olochi; 
\q2 ne ni ogendini ongʼadnegi bura e nyimi. 
\q1  
\v 20 Gogi gi luoro, yaye Jehova Nyasaye; 
\q2 mi ogendini ongʼe ni gin mana dhano. \qs Sela\qs* 
\c 10  
\cl Zaburi 10 
\q1  
\v 1 Angʼo momiyo ichungʼ gichien, yaye Jehova Nyasaye? 
\q2 Angʼo momiyo ipondo ne ji e ndalo mag chandruok? 
\b  
\q1  
\v 2 Ngʼat ma timbene richo goyo apedha ni joma onge nyalo 
\q2 kendo omakogi e otegu mage mosechiko. 
\q1  
\v 3 Dwache maricho mopando e chunye omiyo osungore; 
\q2 jowuoche ema ogwedho to Jehova Nyasaye to ochayo. 
\q1  
\v 4 Sunga omake ma ok onyal manye; 
\q2 onge thuolo kata matin mochiwo ne Nyasaye e chunye. 
\q1  
\v 5 Yorene dhi maber kinde duto, 
\q2 okawore omiyo chikeni ni mabor moyombe; 
\q2 ojaro wasike duto. 
\q1  
\v 6 Owacho ne en owuon niya, “Onge gima nyalo yienga; 
\q2 abiro dak gi kwe kinde duto kaonge gima thaga.” 
\q1  
\v 7 Dhoge opongʼ gi miriambo kod weche mag kwongʼ; 
\q2 chandruok gi weche maricho ni e bwo lewe. 
\q1  
\v 8 Okiyo ji e bath yore mag gwengʼ, 
\q2 onego ji apoya koa kuonde moponde, 
\q2 osiko ongʼicho mondo wangʼe omaki joma onge ketho mondo ohiny. 
\q1  
\v 9 Okiyo ji kokichore ka sibuor mopondo; 
\q2 okichore mar mako joma ok nyal mondo ohinygi, 
\q2 omako joma ok nyal kendo oywayogi oko gi tonde mar meko. 
\q1  
\v 10 Joma hapgi rach momako otieko kendo podho chuth, 
\q2 gipodho e bwo tekone. 
\q1  
\v 11 Owachone en owuon niya, “Nyasaye wiye osewil; 
\q2 opando wangʼe kendo onge gima oneno.” 
\b  
\q1  
\v 12 Aa malo yaye Jehova Nyasaye! 
\q2 Tingʼ badi malo, yaye Nyasaye. 
\q2 Kik wiyi wil gi joma ok nyal. 
\q1  
\v 13 Angʼo momiyo ngʼama timbene richo jaro Nyasaye? 
\q2 Angʼo momiyo owacho e chunye ni, 
\q2 “Ok obi keta piny mopenja gima asetimo?” 
\q1  
\v 14 To in, yaye Nyasaye, ineno chandruok gi kuyo, 
\q2 ikawogi kaka mari kendo itingʼogi e lweti. 
\q1 Ngʼat ma ok nyal; chiwore ne in; 
\q2 in e jakony mar joma onge wuonegi. 
\q1  
\v 15 Tur bad ngʼama rach ma timbene richo; 
\q2 luonge mondo onyis ji gik maricho mosetimo lingʼ-lingʼ, 
\q2 ma ji ok nyal fwenyo mi ngʼe. 
\b  
\q1  
\v 16 Jehova Nyasaye en Ruoth mochwere manyaka chiengʼ; 
\q2 ogendini biro lal nono e pinye. 
\q1  
\v 17 Yaye Jehova Nyasaye, in iwinjo kwayo mar joma chandore; 
\q2 ijiwogi, kendo ichiko iti ni ywakgi, 
\q1  
\v 18 Ichwako nyithi kiye kod joma isando, 
\q2 mondo dhano ma ochwe gi lowo, 
\q2 kik dhi nyime gi bwogo ji. 
\c 11  
\cl Zaburi 11 
\d Kuom jatend wer. Zaburi mar Daudi. 
\q1  
\v 1 Jehova Nyasaye ema ageno kuome. 
\q2 Koro ere kaka duwachna ni: 
\q2 “Ringi ka winyo nyaka ewi got mari. 
\q1  
\v 2 Nikech joma timbegi richo osechako ywayo atungegi; 
\q2 gisechano asernigi e tonde mag atungʼ, 
\q1 mondo gichielgo 
\q2 joma jo-adiera e chunygi. 
\q1  
\v 3 Ka mise iketho, 
\q2 to en angʼo ma joma kare ditim?” 
\b  
\q1  
\v 4 Jehova Nyasaye ni e hekalu mare maler; 
\q2 Jehova Nyasaye ni e kom duongʼ mare manie polo. 
\q1 Orango timbe yawuot ji; 
\q2 wengene nonogi matut. 
\q1  
\v 5 Jehova Nyasaye nono joma kare, 
\q2 to joma timbegi richo kod joma ohero mahundu, 
\q2 to chunye ochayo. 
\q1  
\v 6 Obiro chwero 
\q2 mach maliel mager kod salfa kuom joma timbegi richo; 
\q2 yamo maliet ha matwoyo gik moko, biro kudhogi. 
\b  
\q1  
\v 7 Nikech Jehova Nyasaye en Ngʼama Kare, 
\q2 kendo ohero adiera; 
\q2 joma timbegi oriere biro neno wangʼe. 
\c 12  
\cl Zaburi 12 
\d Kuom jatend wer. Kaluwore gi \tl sheminith\tl*\f + \fr 12:0 \fl Sheminith: \ft Ochalo ni en kit wer moro\f*. Zaburi mar Daudi. 
\q1  
\v 1 Kony ji yaye Jehova Nyasaye, 
\q2 nikech joma oluoro Nyasaye koro onge; 
\q2 joma jo-adiera oserumo e dier ji. 
\q1  
\v 2 Ngʼato ka ngʼato riambo ne nyawadgi; 
\q2 dhogi mohero jaro ji wuoyo gi wuond. 
\b  
\q1  
\v 3 Mad Jehova Nyasaye ongʼad oko lep duto 
\q2 ma jaro ji kod lep duto masungore; 
\q1  
\v 4 mawacho niya, “Wabiro wuoyo kaka wahero; 
\q2 kendo onge ngʼama biro tamowa. 
\q2 Koso en ngʼa ma ruodhwa manyalo tamowa timo kamano?” 
\b  
\q1  
\v 5 “Nikech dich modigo joma ok nyal 
\q2 kod chur ma joma ochando churgo, 
\q1 koro abiro aa malo,” Jehova Nyasaye owacho. 
\q2 “Abiro ritogi e lwet joma sandogi.” 
\q1  
\v 6 Weche Jehova Nyasaye liw, 
\q2 giliw ka fedha moleny e lowo mowangʼ maliet ha, 
\q2 mopwodhi ndalo abiriyo. 
\b  
\q1  
\v 7 Yaye Jehova Nyasaye, yie iritwa maber kik gimoro ohinywa 
\q2 kendo reswa e lwet joma kamago nyaka chiengʼ. 
\q1  
\v 8 Joma timbegi richo wuotho koni gi koni 
\q2 kendo gima rach ema ji puoyo. 
\c 13  
\cl Zaburi 13 
\d Kuom jatend wer. Zaburi mar Daudi. 
\q1  
\v 1 Nyaka karangʼo, yaye Jehova Nyasaye? Wiyi biro wil koda nyaka chiengʼ koso? 
\q2 Ibiro pandona wangʼi nyaka karangʼo? 
\q1  
\v 2 Abiro dhi nyime ka an gi pek manie pacha 
\q2 kod kuyo manie chunya odiechiengʼ kodiechiengʼ nyaka karangʼo? 
\q2 Wasika biro locho kuoma nyaka karangʼo? 
\b  
\q1  
\v 3 Para kendo idwoka, yaye Jehova Nyasaye Nyasacha. 
\q2 Chiw ler ne wengena, nono to dipo ka nindo otera mi atho; 
\q1  
\v 4 nikech mano nyalo miyo jasika wach niya, “Aseloye,” 
\q2 kendo wasika biro bedo mamor ka apodho. 
\b  
\q1  
\v 5 Anto ageno kuom herani mosiko; 
\q2 chunya oil kuom warruok mari. 
\q1  
\v 6 Abiro wer ne Jehova Nyasaye, 
\q2 nikech osebedo ka otimona maber. 
\c 14  
\cl Zaburi 14 
\d Kuom jatend wer. Zaburi mar Daudi. 
\q1  
\v 1 Ngʼat mofuwo wacho e chunye niya, 
\q2 “Nyasaye onge.” 
\q1 Gin joma okethore, timbegi richo mokalo tongʼ, 
\q2 onge kata ngʼato achiel matimo maber. 
\b  
\q1  
\v 2 Jehova Nyasaye ngʼiyo ji duto gie polo, 
\q2 mondo oneye ka bende nitie moro kuomgi ma nigi winjo, 
\q2 kata ka bende nitie moro kuomgi mamanyo Nyasaye. 
\q1  
\v 3 Ji duto osebaro, 
\q2 giduto kaachiel gisedoko joma okethore; 
\q1 onge ngʼama timo maber, 
\q2 onge kata achiel. 
\b  
\q1  
\v 4 Bende joma timo timbe maricho dipuonjre adier? 
\b  
\q1 Gin joma kidho joga kaka ji chamo kuon; 
\q2 kendo gin joma ok luong Jehova Nyasaye mondo okonygi. 
\q1  
\v 5 Negie kaka luoro dwaro negogi, 
\q2 nikech Nyasaye nitie e chokruok mar joma kare. 
\q1  
\v 6 Un joma timo gik maricho, uketho chenro joma odhier, 
\q2 to Jehova Nyasaye e kar pondo margi. 
\b  
\q1  
\v 7 Yaye, mad warruok mar Israel obi koa Sayun! 
\q2 Kinde ma Jehova Nyasaye duogo ne joge mwandugi, 
\q2 onego joka Jakobo obed moil kendo Israel obed mamor! 
\c 15  
\cl Zaburi 15 
\d Zaburi Mar Daudi. 
\q1  
\v 1 Jehova Nyasaye, en ngʼa manyalo siko kari maler milamie? 
\q2 En ngʼa manyalo dak e godi maler? 
\b  
\q1  
\v 2 En ngʼat ma wuodhe obidhore 
\q2 kendo matimo gima kare, 
\q1 ngʼat mawacho adiera gi e chunye 
\q2  
\v 3 kendo maonge gi miriambo e dhoge, 
\q1 kendo ma ok tim ne wadgi gimoro amora marach 
\q2 kendo ok dir weche makwodo wi dhano wadgi, 
\q1  
\v 4 Ngʼat machayo ngʼama timbene richo mokalo tongʼ, 
\q2 to miyo joma oluoro Jehova Nyasaye duongʼ, 
\q1 Ngʼat marito singruok motimo 
\q2 kata bed ni timo kamano hinye, 
\q1  
\v 5 Ngʼat ma holo ji pesane ma ok odwaro ni odwokne gi gimoro e wiye 
\q2 kendo ma ok yie kaw asoya kuom joma onge ketho. 
\b  
\q1 Ngʼat matimo gik makamagi 
\q2 gimoro amora ok nyal yiengo. 
\c 16  
\cl Zaburi 16 
\d \tl Miktam\tl*\f + \fr 16:0 \fl Miktam: \ft en kit wer mane Daudi wero.\f* mar Daudi. 
\q1  
\v 1 Rita maber, yaye Nyasaye 
\q2 nikech in e kar pondona. 
\b  
\q1  
\v 2 Ne awacho ne Jehova Nyasaye niya, “In e Ruodha; 
\q2 onge gima ber machielo ma an-go makmana in.” 
\q1  
\v 3 To jomaler manie piny, 
\q2 to gin kaka joma nigi duongʼ ma ahero gi chunya duto. 
\q1  
\v 4 Joma lawo nyiseche mamoko 
\q2 kuyo margi biro medore. 
\q1 Misengini magi mag remo ok abi olo oko 
\q2 kendo kata nying-gi ok abi hulo gi dhoga. 
\b  
\q1  
\v 5 Jehova Nyasaye, isemiya pok makora kod okombena; 
\q2 iserita maber gi giga duto. 
\q1  
\v 6 Kiepena duto ochopo kuonde mabeyo; 
\q2 adier, girkeni maga duto moro wangʼ adier. 
\b  
\q1  
\v 7 Abiro pako Jehova Nyasaye mangʼadona rieko; 
\q2 kata gotieno chunya puonja. 
\q1  
\v 8 Asiko aketo Jehova Nyasaye e nyima ndalo duto. 
\q2 Nikech ka entie e lweta korachwich, 
\q2 to onge gima nyalo yienga. 
\b  
\q1  
\v 9 Emomiyo chunya mor kendo lewa yot; 
\q2 ringra bende biro yweyo gi kwe, 
\q1  
\v 10 nikech ok inijwangʼa ei liel, 
\q2 to bende ok niyie Ngʼati Maler tow. 
\q1  
\v 11 Isenyisa yor ngima; 
\q2 inipongʼa gi mor mogundho ka an e nyimi, 
\q2 kendo gi mor mosiko e badi korachwich. 
\c 17  
\cl Zaburi 17 
\d Lamo mar Daudi. 
\q1  
\v 1 Yaye Jehova Nyasaye, yie iwinj kwayona makare; 
\q2 chik iti ne ywakna, 
\q1 chik iti ne lemona, 
\q2 lamona ok aa e dhok mawuondo ji. 
\q1  
\v 2 Mad chwak michwakago oa kuomi; 
\q2 mad wengeni nee gima kare. 
\b  
\q1  
\v 3 Kata obedo ni inono chunya kendo itema gotieno, 
\q2 kata ka itema to ok ibi yudo gimoro kuoma; 
\q2 asengʼado e chunya ni dhoga ok bi timo richo. 
\q1  
\v 4 To kuom gik ma joma moko timo, 
\q2 kaluwore gi wach mowuok e dhogi, 
\q1 an awuon asepogora 
\q2 gi yore jo-mahundu. 
\q1  
\v 5 Tienda osesiko e yoreni; 
\q2 tiendena pok okier. 
\b  
\q1  
\v 6 Aluongi, yaye Nyasaye, nikech ibiro dwoka; 
\q2 chik iti kendo winj lamona. 
\q1  
\v 7 Nyisie teko mar herani maduongʼ, 
\q2 in ma ireso ji gi lweti ma korachwich, 
\q2 joma pondo ne wasikgi kuomi. 
\q1  
\v 8 Rita adimba kaka tong wangʼi, 
\q2 panda e bwo tipo mar bwombi, 
\q1  
\v 9 mondo atony e lwet joma richo ma lawa, 
\q2 mondo atony e lwet wasika ma dhano molwora. 
\b  
\q1  
\v 10 Chunjegi odinore matek, 
\q2 kendo dhogi wuoyo gi wich teko. 
\q2  
\v 11 Giselawa kuonde duto, mi koro gilwora, 
\q2 ka wengegi ochiek, mondo gidira piny. 
\q1  
\v 12 Gichalo sibuor ma nigi kech mar mako le, 
\q2 mana ka sibuor maduongʼ mopondo kokichore. 
\b  
\q1  
\v 13 Aa malo, yaye Jehova Nyasaye, chomgi tir, mi igogi piny; 
\q2 resa e lwet joma richo gi liganglani. 
\q1  
\v 14 Yaye Jehova Nyasaye, resa e lwet joma kamago gi lweti, 
\q2 resa e lwet jopinyni ma pokgi ni e pinyni. 
\b  
\q1 Itieko kech ma joma ihero nigo; 
\q2 yawuotgi nigi chiemo mangʼeny, 
\q2 kendo gikano mwandu ne nyithindgi. 
\q1  
\v 15 To anane wangʼi ka ngimana nikare; 
\q2 ka achiewo, abiro romo ka aneno kiti kaka ichal. 
\c 18  
\cl Zaburi 18 
\d Kuom jatend wer. Zaburi mar Daudi jatich Jehova Nyasaye. Nowerone Jehova Nyasaye weche mag wendni kinde mane Jehova Nyasaye orese e lwet wasike duto kendo e lwet Saulo. Nowacho niya: 
\q1  
\v 1 Aheri, yaye Jehova Nyasaye, in e tekra. 
\q1  
\v 2 Jehova Nyasaye en lwandana, 
\q2 en kar pondo mara kendo en jawarna; 
\q1 Nyasacha en lwandana ma apondo kuome. 
\q2 En okumbana, en tungʼ mar warruokna, kendo en ohingana. 
\q1  
\v 3 Aluongo Jehova Nyasaye, en mowinjore gi pak, 
\q2 kendo oresa e lwet wasika. 
\q1  
\v 4 Tonde mag tho ne orida matek; 
\q2 kendo ohula mangʼongo mar tho nouma. 
\q1  
\v 5 Tonde mag liel ne orida kendo odhoga matek; 
\q2 obadho mag tho ne ochoma tir. 
\q1  
\v 6 E chandruok ne aluongo Jehova Nyasaye; 
\q2 ne aywak ne Nyasaye mondo okonya. 
\q1 Ne owinjo dwonda gie hekalu mare; 
\q2 ywakna nochopo e nyime, modonjo e ite. 
\b  
\q1  
\v 7 Piny notetni kendo oyiengni; 
\q2 kendo mise mag gode notetni; 
\q2 ne gikirni nikech ne okecho. 
\q1  
\v 8 Iro nodum koa e otuchi mag ume; 
\q2 mach mangʼangʼni nodhuolore kawuok e dhoge, 
\q2 kendo makaa maliel mager nobebni kawuok kuome. 
\q1  
\v 9 Nobaro polo mobiro e piny; 
\q2 rumbi molil ti nonyono gi tiende. 
\q1  
\v 10 Noidho kerubi eka ofuyo; 
\q2 ne ofuyo matek komoko e bwomb yamo. 
\q1  
\v 11 Noloko mudho kaka raum mare, mudhono nobedo hema molwore, 
\q2 kendo nokawo rumbi mar koth moloko raumne. 
\q1  
\v 12 Boche nowuok e ler marieny mane aa kuome, 
\q2 kaachiel gi pe madongo dongo kod mil polo ma tiarore. 
\q1  
\v 13 Jehova Nyasaye nomor gie polo; 
\q2 dwond Nyasaye Man Malo Moloyo nowinjore. 
\q1  
\v 14 Nodiro asernige mokeyo wasigu, 
\q2 mor polo gi mil polo noriembogi. 
\q1  
\v 15 Holni manie bwo nembe noelore 
\q2 kendo mise mag piny nowe nono, 
\q1 kane ikwerogi, yaye Jehova Nyasaye, 
\q2 kane teko mar muya mowuok e otuchi mag umi ogoyogi. 
\b  
\q1  
\v 16 Nochopo ira piny koa malo mi okawa; 
\q2 ne ogola oko e kude mag pi matut. 
\q1  
\v 17 Noresa e lwet jasika maratego, 
\q2 kuom jowasika, mane tek moloya. 
\q1  
\v 18 Negimonja e kinde mane an gi masira, 
\q2 to Jehova Nyasaye ema nokonya. 
\q1  
\v 19 Ne okela moketa kama lach; 
\q2 ne oresa nikech chunye ne mor koda. 
\q1  
\v 20 Jehova Nyasaye osetimona maber ka oluwore gi timna makare; 
\q2 osechiwona ka oluwore gi ler mar lwetena. 
\q1  
\v 21 Nikech aserito yore Jehova Nyasaye; 
\q2 pok atimo marach kuom lokora weyo Nyasacha. 
\q1  
\v 22 Chikene duto ni e nyima; 
\q2 pok alokora aweyo buchene. 
\q1  
\v 23 Asebedo ka aonge ketho e nyime 
\q2 kendo aseritora mondo kik atim richo. 
\q1  
\v 24 Jehova Nyasaye osechiwona kaluwore gi timna makare, 
\q2 osechiwona kaluwore gi ler mar lwetena e nyime. 
\b  
\q1  
\v 25 Ne joma jo-adiera, inyisori kaka ja-adiera, 
\q2 kendo ne joma longʼo, inyisori kaka ngʼama longʼo, 
\q1  
\v 26 ne jomaler, inyisori kaka ngʼama ler, 
\q2 to ne joma yoregi obam, inyisori kaka ngʼama rach. 
\q1  
\v 27 Ireso joma muol 
\q2 to joma wengegi tek idwoko piny. 
\q1  
\v 28 In ema imiyo tacha siko kaliel, yaye Jehova Nyasaye; 
\q2 Nyasacha loko mudho mouma doko ler. 
\q1  
\v 29 Ka ikonya to anyalo loyo jolweny momonja; 
\q2 ka an gi Nyasacha to anyalo lwenyo ohinga. 
\b  
\q1  
\v 30 Nyasaye to yore longʼo chuth; 
\q2 wach Jehova Nyasaye onge rem moro amora. 
\q1 En okumba 
\q2 ne ji duto ma pondo kuome. 
\q1  
\v 31 Nikech en Nyasaye mane minyalo pimo gi Jehova Nyasaye? 
\q2 Koso en ngʼa ma en Lwanda, ka ok Nyasachwa? 
\q1  
\v 32 Nyasaye ema miya teko 
\q2 kendo omiyo yora bedo mokwe. 
\q1  
\v 33 Omiyo tiendena bedo mayot ka tiende mwanda; 
\q2 kendo en ema omiyo achungʼ kuonde man malo maboyo. 
\q1  
\v 34 Otiego lwetena ne lweny; 
\q2 momiyo bedena nyalo dolo atung nyinyo. 
\q1  
\v 35 Isemiya okumba mar warruokni, 
\q2 kendo lweti korachwich osesira; 
\q2 kony mari osemiyo abedo gi duongʼ. 
\q1  
\v 36 Imiyo yo mawuothoe bedo malach, 
\q2 mondo tiendena kik ba yo. 
\b  
\q1  
\v 37 Ne alawo wasika mi ajukogi; 
\q2 kendo ne ok alokora aweyogi nyaka ne atiekogi pep. 
\q1  
\v 38 Ne atiekogi, mane ok ginyal chungʼ; 
\q2 negipodho e tienda. 
\q1  
\v 39 Ne imiya teko mar kedo lweny; 
\q2 ne imiyo jomamon koda kulore e nyima. 
\q1  
\v 40 Ne imiyo wasika oringo kadhi, 
\q2 mine atieko joma ok dwara. 
\q1  
\v 41 Ne giywak mondo okonygi to onge ngʼama ne nyalo resogi; 
\q2 ne giywakne Jehova Nyasaye to ne ok odwokogi. 
\q1  
\v 42 Ne agoyogi adunya ka buru ma yamo tero, 
\q2 ne achodhogi oko ka chwodho mag yore mag dala. 
\b  
\q1  
\v 43 Ne iresa e ywaruok gi ji. 
\q2 Ne iketa jatend ogendini; 
\q2 joma ne ok angʼeyo chon notiyona. 
\q1  
\v 44 Kane giwinjo humba, ne giwinja; 
\q2 jopinje mamoko nobiro motwere kuoma. 
\q1  
\v 45 Negibiro ka gitetni; kendo ka chunygi ool, 
\q2 ka gia kuondegi mag pondo. 
\b  
\q1  
\v 46 Jehova Nyasaye ngima! Lwandana mondo ogwedhi. 
\q2 Kendo Nyasaye mar Warruokna mondo otingʼ malo! 
\q1  
\v 47 Nyasaye mane ochulo kuor kara 
\q2 kendo oloyo ogendini e bwoya; 
\q2  
\v 48 mane oresa e lwet wasika; 
\q1 ne itingʼa malo e kind wasika 
\q2 ne iresa e lwet jo-mahundu. 
\q1  
\v 49 Emomiyo anapaki e kind ogendini, yaye Jehova Nyasaye, 
\q2 kendo anawer wende mapako nyingi. 
\q1  
\v 50 Jehova Nyasaye kelo resruok maduongʼ ne ruoth moketo, 
\q2 onyiso hera mogundho ma ok rum ne ngʼate mowir, 
\q2 ni Daudi gi nyikwaye nyaka chiengʼ. 
\c 19  
\cl Zaburi 19 
\d Kuom jatend wer. Zaburi mar Daudi. 
\q1  
\v 1 Polo hulo duongʼ mar Nyasaye; 
\q2 kor polo nyiso tich mar lwete. 
\q1  
\v 2 Odiechiengʼ kodiechiengʼ gilando wach; 
\q2 otieno kotieno ginyiso rieko. 
\q1  
\v 3 Gionge dhok kata weche 
\q2 kata dwondgi ok winji. 
\q1  
\v 4 Kata kamano dwondgi chopo kuonde duto e piny, 
\q2 wechegi osechopo nyaka e tunge piny. 
\q1 Osechungo hema e kor polo ne wangʼ chiengʼ, 
\q2  
\v 5 machalo gi wuon kisera mothinyore oko kawuok e ode mar mor, 
\q2 kendo mana ka jangʼwech mongirore moil moikore ni chako ngʼwech. 
\q1  
\v 6 Owuok gie tungʼ polo konchiel, 
\q2 kendo olworore nyaka komachielo; 
\q2 onge gima opondo ne liet mare. 
\b  
\q1  
\v 7 Chik Jehova Nyasaye longʼo chuth, 
\q2 odwogo chuny. 
\q1 Buche mag Jehova Nyasaye gin adiera, 
\q1 gimiyo joma riekogi tin bedo mariek. 
\q1  
\v 8 Chike mag Jehova Nyasaye nikare, 
\q2 gichiwo mor ne chuny. 
\q1 Chike mag Jehova Nyasaye rieny, 
\q2 gichiwo ler ne wangʼ. 
\q1  
\v 9 Luoro Jehova Nyasaye en gima ber, 
\q2 mosiko nyaka chiengʼ. 
\q1 Buche mag Jehova Nyasaye gin adier 
\q2 kendo gin kare kargi giduto. 
\b  
\q1  
\v 10 Gibeyo moloyo dhahabu, 
\q2 moloyo dhahabu malerie moloyo; 
\q1 gimit moloyo mor kich 
\q2 moa e pedni. 
\q1  
\v 11 Gin ema gimiyo jatichni bedo motangʼ; kendo bedogi kanyo 
\q2 kelo pok maduongʼ. 
\q1  
\v 12 En ngʼa manyalo ngʼeyo kethone mopondo? 
\q2 Wena kethoga mopondo. 
\q1  
\v 13 Bende gengʼ jatichni kuom richo mag wich teko; 
\q2 mad kik gibed gi loch kuoma. 
\q1 Eka anabed maonge ketho, 
\q2 anabed ka aonge gi ketho chik moro maduongʼ. 
\b  
\q1  
\v 14 Mad weche mawuok e dhoga, kod paro manie chunya, 
\q2 obed malongʼo e nyimi, 
\q2 yaye Jehova Nyasaye, Lwandana kendo Jawarna. 
\c 20  
\cl Zaburi 20 
\d Kuom jatend wer. Zaburi mar Daudi. 
\q1  
\v 1 Mad Jehova Nyasaye dwoki ka in e chandruok; 
\q2 mad nying Nyasach Jakobo riti. 
\q1  
\v 2 Mad oorni kony moa kare maler mar lemo 
\q2 kendo omiyi kony moa Sayun. 
\q1  
\v 3 Mad opar misengni magi duto 
\q2 kendo oyie gi misengini miwangʼo pep magi. \qs Sela\qs*\f + \fr 20:3 \fq Sela \ft tiend wachni ok ongʼere.\f* 
\q1  
\v 4 Mad omiyi gima chunyi gombo 
\q2 kendo omi chenro magi duto odhi maber. 
\q1  
\v 5 Wabiro kok gimor ka ilocho 
\q2 kendo wabiro tingʼo bendechwa malo e nying Nyasachwa. 
\q1 Mad Jehova Nyasaye chiw 
\q2 gik moko duto mikwaye. 
\b  
\q1  
\v 6 Koro angʼeyo ni Jehova Nyasaye reso ngʼate mowir; 
\q2 odwoke gie kare maler mar lemo manie polo, 
\q2 gi teko ma waro ji mar lwete ma korachwich. 
\q1  
\v 7 Jomoko ogeno kuom gechegi to jomoko kuom faresegi, 
\q2 to wan to wageno kuom nying Jehova Nyasaye, ma Nyasachwa. 
\q1  
\v 8 Gibiro lwar e chonggi mi gipodhi, 
\q2 to wan wabiro aa malo mi wachungʼ motegno. 
\b  
\q1  
\v 9 Yaye Jehova Nyasaye, reswa ruoth! 
\q2 Dwokwa ka waluongi! 
\c 21  
\cl Zaburi 21 
\d Kuom jatend wer. Zaburi mar Daudi. 
\q1  
\v 1 Yaye Jehova Nyasaye, ruoth oil nikech teko ma imiye. 
\q2 Mano kaka en gi mor maduongʼ nikech isemiyo olocho! 
\b  
\q1  
\v 2 Isemiye gima chunye gombo 
\q2 kendo pok idagi timone kwayone. \qs Sela\qs* 
\q1  
\v 3 Ne irwake gi gweth momew 
\q2 kendo nisidho osimbo mar dhahabu maler e wiye. 
\q1  
\v 4 Ne okwayi ngima kendo ne imiye; 
\q2 ne imede ndalo mochwere manyaka chiengʼ. 
\q1  
\v 5 Kuom loch mane ichiwo, duongʼ mare duongʼ; 
\q2 isemiye huma gi luor. 
\q1  
\v 6 Adier, isemiye gweth mochwere 
\q2 kendo isemiyo obedo mamor gi mor moa kuomi. 
\q1  
\v 7 Nikech ruoth ogeno kuom Jehova Nyasaye; 
\q2 kuom hera ma ok rum mar Nyasaye Man Malo Moloyo, 
\q2 ok obi yiengni. 
\b  
\q1  
\v 8 Lweti biro mako wasiki duto; 
\q2 lweti ma korachwich biro ndhiyo joma kedo kodi. 
\q1  
\v 9 E sa ma ibiro chopoe, 
\q2 to ibiro miyo gichal gi kendo mar mach mager. 
\q1 Jehova Nyasaye biro mwonyogi kuom mirimbe mager, 
\q2 kendo mach mare biro tiekogi. 
\q1  
\v 10 Ibiro tieko kothgi mi rum e piny, 
\q2 kendo nyithindgi biro rumo e dier ji. 
\q1  
\v 11 Kata obedo ni gichano timoni marach 
\q2 kendo giloso chenro maricho, to ok ginyal loyo; 
\q1  
\v 12 nikech ibiro miyo gilok dier ngʼegi 
\q2 ka ibiro dimbogi gi atungʼ moywa. 
\b  
\q1  
\v 13 Yud duongʼ, yaye Jehova Nyasaye, kuom tekoni maduongʼ; 
\q2 wabiro wer kendo pako nyalo mari. 
\c 22  
\cl Zaburi 22 
\d Kuom jatend wer. E dwol mar “Mwanda mar Okinyi.” Zaburi mar Daudi. 
\q1  
\v 1 Nyasacha, Nyasacha, iweya nangʼo? 
\q2 Angʼo momiyo in mabor koda ma ok inyal resa? 
\q2 In mabor ma ok inyal winjo weche mag churna mondo iresa? 
\q1  
\v 2 Yaye Nyasacha, aywagora odiechiengʼ duto to ok idwoka, 
\q2 aywagora gotieno bende ma ok alingʼ. 
\b  
\q1  
\v 3 To eka ibet e kom duongʼ kaka Ngʼama Ler; 
\q2 in e pak mar jo-Israel. 
\q1  
\v 4 Kuomi ema wuonewa noketoe genogi; 
\q2 ne gigeni kendo ne iresogi. 
\q1  
\v 5 Ne giywakni kendo ne iwarogi; 
\q2 negigeno kuomi mine ok gineno wichkuot. 
\b  
\q1  
\v 6 An to an mana kudni ma ok dhano, 
\q2 ngʼama ji duto jaro kendo ma ji ochayo. 
\q1  
\v 7 Ji duto monena jara; 
\q2 gidiro ayany ka gikino wigi. 
\q1  
\v 8 “Ogeno kuom Jehova Nyasaye; 
\q2 koro mondo Jehova Nyasaye okonye ane. 
\q1 Koro mondo orese ane, 
\q2 nikech chunye mor kode.” 
\b  
\q1  
\v 9 To in ema ne igola e ich; 
\q2 ne ichweya mondo agen kuomi kata kane pod adhodho thund minwa. 
\q1  
\v 10 Ne oriwa kodi chakre chiengʼ mane onywolae; 
\q2 isebedo Nyasacha aa kinde mane an ei minwa. 
\b  
\q1  
\v 11 Kik ibed mabor koda, 
\q2 nikech chandruok ni koda machiegni, 
\q2 kendo onge ngʼama nyalo konya. 
\b  
\q1  
\v 12 Rwedhi mangʼeny olwora; 
\q2 rwedhi maroteke moa Bashan olwora koni gi koni. 
\q1  
\v 13 Sibuoche maruto makidho le ma gisemako 
\q2 ongʼamo dhogi malach ka dwaro kidha. 
\q1  
\v 14 Ipuka oko ka pi, 
\q2 kendo chokena duto osewil. 
\q1 Chunya olokore odok; 
\q2 oseleny morumo e iya. 
\q1  
\v 15 Tekona osetwo ka balatago, 
\q2 kendo lewa omoko e danda; 
\q2 isepiela e lop tho. 
\q1  
\v 16 Guogi oselwora; 
\q2 oganda mar joma richo oseketa diere, 
\q2 gisetucho lwetena gi tiendena. 
\q1  
\v 17 Anyalo kwano chokena duto; 
\q2 ji ranga amingʼa kendo jara. 
\q1  
\v 18 Ne gipogore lepa e kindgi giwegi 
\q2 kendo gigoyo ombulu ne nangana. 
\b  
\q1  
\v 19 To in, yaye Jehova Nyasaye, kik ibed mabor koda. 
\q2 In e tekra, bi piyo mondo ikonya. 
\q1  
\v 20 Res ngimana kuom ligangla, 
\q2 res ngimana e teko guogi. 
\q1  
\v 21 Resa e dho sibuoche; 
\q2 resa e tunge jowi mager. 
\b  
\q1  
\v 22 Abiro hulo nyingi ne owetena; 
\q2 abiro paki e nyim chokruok. 
\q1  
\v 23 Un muluoro Jehova Nyasaye, pakeuru! 
\q2 Un nyikwa Jakobo duto, miyeuru duongʼ. 
\q2 Luoreuru, un koth jo-Israel duto! 
\q1  
\v 24 Nikech pok ochayo kata ojaro 
\q2 sandruok mar joma winjo malit; 
\q1 pok opandone wangʼe 
\q2 to osewinjo ywakne mar dwaro kony. 
\b  
\q1  
\v 25 Kuomi ema thoro mara mar pak e chokruok maduongʼ aye; 
\q2 abiro chopo singruok maga e nyim joma oluori. 
\q1  
\v 26 Joma odhier biro chiemo mi yiengʼ; 
\q2 joma manyo Jehova Nyasaye biro pake, 
\q2 mad chunjeu bed mangima nyaka chiengʼ! 
\b  
\q1  
\v 27 Tunge piny duto 
\q2 biro paro miduog ir Jehova Nyasaye, 
\q1 kendo dhout ogendini duto 
\q2 biro kulore e nyime, 
\q1  
\v 28 Nikech loch en mar Jehova Nyasaye 
\q2 kendo en ema olocho ewi ogendini. 
\b  
\q1  
\v 29 Jo-mwandu duto manie piny biro chiemo kendo lemo; 
\q2 ji duto madhi piny e lowo biro kulore e nyime, 
\q2 jogo ma ok nyal siko kangima. 
\q1  
\v 30 Tienge mabiro noti ne Jehova Nyasaye, 
\q2 kendo nonyis ogendini mabiro wachne. 
\q1  
\v 31 Gibiro hulo timne makare, 
\q2 ne ji mapok onywol niya: 
\q2 “Jehova Nyasaye osewaro joge.” 
\c 23  
\cl Zaburi 23 
\d Zaburi mar Daudi. 
\q1  
\v 1 Jehova Nyasaye e jakwadha, ok anachand gimoro. 
\q2  
\v 2 Omiyo ayweyo e lum mangʼich, 
\q1 otelona e aore mokwe, 
\q2  
\v 3 odwogo chunya. 
\q1 Otaya e yore mag tim makare 
\q2 mondo nyinge oyud duongʼ. 
\q1  
\v 4 Kata ka obedo ni awuotho 
\q2 e hoho mar tipo mar tho, 
\q1 to ok analuor gimoro marach, 
\q2 nimar in koda; 
\q1 ludhi gi odungani 
\q2 ema hoya. 
\b  
\q1  
\v 5 Iloso mesa e nyima 
\q2 ka wasika neno. 
\q1 Iwiro wiya gi mo; 
\q2 kikombena opongʼ moo oko. 
\q1  
\v 6 Adier, ber gihera biro luwa 
\q2 ndalo duto mag ngimana, 
\q1 kendo abiro dak e od Jehova Nyasaye 
\q2 nyaka chiengʼ. 
\c 24  
\cl Zaburi 24 
\d Zaburi mar Daudi. 
\q1  
\v 1 Piny kaachiel gi gik moko duto manie iye gin mag Jehova Nyasaye, 
\q2 bende ji duto modakie piny gin mage; 
\q1  
\v 2 nikech ne omiyo piny obet ewi nembe 
\q2 kendo noguro misene ewi pige. 
\b  
\q1  
\v 3 En ngʼa manyalo idho wi got mar Jehova Nyasaye? 
\q2 En ngʼa manyalo chungʼ e ode maler? 
\q1  
\v 4 En mana ngʼat ma lwete ler kendo chunye bende ler, 
\q2 ngʼat ma ok lam nyiseche ma dhano oloso, 
\q2 kata kwongʼre gi miriambo. 
\b  
\q1  
\v 5 Ngʼat ma kamano Jehova Nyasaye biro gwedho 
\q2 kendo obiro yudo ber moa kuom Nyasaye ma Jawarne. 
\q1  
\v 6 Kamano e kaka tiengʼ mar joma dware chalo, 
\q2 mamanyo wangʼi, yaye Nyasach Jakobo. \qs Sela\qs* 
\b  
\q1  
\v 7 tingʼuru lodiu malo, yaye dhorangeye; 
\q2 tingʼreuru malo, yaye rangeye machon, 
\q2 mondo Ruodh duongʼ odonji. 
\q1  
\v 8 Ruoth man-gi duongʼni to en ngʼa? 
\q2 En Jehova Nyasaye Maratego kendo manyalo duto, 
\q2 En Jehova Nyasaye maloyo lweny. 
\q1  
\v 9 Tingʼuru lodiu malo, yaye un dhorangeye; 
\q2 tingʼ-giuru malo, un dhorangeye machon, 
\q2 mondo Ruodh duongʼ odonji. 
\q1  
\v 10 Ruodh duongʼni en ngʼa? 
\q2 Jehova Nyasaye Maratego, 
\q2 En e Ruodh Duongʼ. \qs Sela\qs* 
\c 25  
\cl Zaburi 25 
\d Zaburi mar Daudi. 
\q1  
\v 1 Achiwoni chunya, yaye Jehova Nyasaye; 
\q2  
\v 2 In ema aketo genona kuomi, yaye Nyasacha. 
\q1 Kik iwe ane wichkuot, 
\q2 bende kik iwe wasika loya. 
\q1  
\v 3 Onge ngʼama oketo genone kuomi 
\q2 manyalo neno wichkuot, 
\q1 to joma timo timbe maricho 
\q2 ema biro neno wichkuot. 
\b  
\q1  
\v 4 Nyisa yoreni, yaye Jehova Nyasaye, 
\q2 puonja mondo aluwgi; 
\q1  
\v 5 telna gi adierani, kendo puonja, 
\q2 nikech in Nyasaye ma Jawarna, 
\q2 kendo genona ni kuomi odiechiengʼ duto. 
\q1  
\v 6 Par kechni maduongʼ gi herani, yaye Jehova Nyasaye, 
\q2 nikech gisebedo ka gintie nyaka aa chon. 
\q1  
\v 7 Kik ipar richo mane atimo kapod an rawere 
\q2 kod yorena mobam; 
\q1 para kaluwore gi herani, 
\q2 nikech iber, yaye Jehova Nyasaye. 
\b  
\q1  
\v 8 Jehova Nyasaye ber kendo yorene oriere tir; 
\q2 mano emomiyo opuonjo joricho yorene. 
\q1  
\v 9 Otelo ni joma muol kuom gima nikare 
\q2 kendo opuonjogi yore. 
\q1  
\v 10 Yore duto mag Jehova Nyasaye opongʼ gihera kod adiera 
\q2 ni joma rito gik moko duto ma singruokne dwaro. 
\q1  
\v 11 Wena richona nikech nyingi 
\q2 kata obedo ni richona duongʼ ahinya, yaye Jehova Nyasaye, 
\q1  
\v 12 Koro ere ngʼat ma oluoro Jehova Nyasaye? 
\q2 Obiro puonje luwo yo moyierne. 
\q1  
\v 13 Obiro dak e ngima momew, 
\q2 kendo nyikwaye nokaw piny kaka girkeni margi. 
\q1  
\v 14 Jehova Nyasaye en osiep joma miye luor; 
\q2 omiyo gingʼeyo singruok mage. 
\q1  
\v 15 Achomo wangʼa kuom Jehova Nyasaye ndalo duto, 
\q2 nikech en kende ema obiro golo tiendena mobadho omako. 
\b  
\q1  
\v 16 Duog ira kendo bedna mangʼwon, 
\q2 nikech adongʼ kenda kendo an gi kuyo. 
\q1  
\v 17 Chandruok manie chunya osemedore; 
\q2 resa kuom rem ma an-go. 
\q1  
\v 18 Neye kuyo manie chunya kod rem ma an-go, 
\q2 kendo gol richona duto. 
\q1  
\v 19 Neye kaka wasika osemedore 
\q2 kendo kaka gichaya gi chunygi duto! 
\q1  
\v 20 Rit ngimana kendo iresa; 
\q2 kik iwe ane wichkuot, 
\q2 nikech in ema apondo kuomi. 
\q1  
\v 21 Mad bidhruok gi ngima moriere rita 
\q2 nikech genona ni kuomi. 
\b  
\q1  
\v 22 Res Israel, yaye Nyasaye, 
\q2 kuom chandruok mage duto! 
\c 26  
\cl Zaburi 26 
\d Zaburi mar Daudi. 
\q1  
\v 1 Ngʼadna bura makare, yaye Jehova Nyasaye, 
\q2 nikech e ngimana duto asedak ka aonge ketho; 
\q1 aseketo genona kuom Jehova Nyasaye 
\q2 ma ok adigni. 
\q1  
\v 2 Nona kendo itema, yaye Jehova Nyasaye 
\q2 nonie chunya gi pacha; 
\q1  
\v 3 nikech herani osiko kanie chunya kinde duto, 
\q2 kendo asiko kawuotho e adierani. 
\b  
\q1  
\v 4 Ok abed piny gi joma wuondore 
\q2 bende ok ariwra gi jo-miriambo. 
\q1  
\v 5 Achayo chokruok mar joma timo gik maricho 
\q2 kendo ok ayie bet piny gi joricho. 
\q1  
\v 6 Aluoko lwetena kanyisogo ni aonge ketho, 
\q2 kendo aluoro kendoni mar misango, yaye Jehova Nyasaye, 
\q1  
\v 7 ka alando pakni gi dwol maduongʼ, 
\q2 kendo anyiso timbeni duto miwuoro. 
\q1  
\v 8 Ahero hekalu kama idakie, yaye Jehova Nyasaye, 
\q2 kama duongʼni nitie. 
\b  
\q1  
\v 9 Kik ikaw chunya kaachiel gi joricho, kik ikaw ngimana 
\q2 kod joma ohero chwero remo, 
\q1  
\v 10 joma lwetegi otingʼo chenro maricho 
\q2 ma lwetegi ma korachwich asoya opongʼo. 
\q1  
\v 11 An to ngimana onge ketho; 
\q2 yie iwara kendo ikecha. 
\b  
\q1  
\v 12 Tiendena onyono kama opie; 
\q2 e chokruok mangʼongo abiro pako Jehova Nyasaye. 
\c 27  
\cl Zaburi 27 
\d Zaburi mar Daudi. 
\q1  
\v 1 Jehova Nyasaye e lerna kendo e warruokna; 
\q2 en ngʼa ma daluor? 
\q1 Jehova Nyasaye e kama ngimana opondoe. 
\q2 En ngʼa ma dibwoga? 
\b  
\q1  
\v 2 Ka joma richo lawa 
\q2 mondo oketh ngimana, 
\q1 ka wasika kod joma kedo koda monja, 
\q2 to gibiro kier mi gipodhi. 
\q1  
\v 3 Kata ka jolweny ogoyona agengʼa koni gi koni, 
\q2 to chunya ok bi luor; 
\q1 kata ka lweny otugorena, 
\q2 to pod abiro mana bedo gi chir. 
\b  
\q1  
\v 4 Gimoro achiel kende ema akwayo Jehova Nyasaye, 
\q2 ma e gima adwaro moloyo; 
\q1 ni mondo adag e od Jehova Nyasaye 
\q2 ndalo duto mag ngimana, 
\q1 mondo achom wangʼa kuom ber mar Jehova Nyasaye 
\q2 kendo amanye e hekalu mare. 
\q1  
\v 5 Nikech chiengʼ ma chandruok omaka 
\q2 obiro panda maber e kar dakne; 
\q1 obiro panda e kar pondo mar hembe maler 
\q2 kendo obiro keta malo ewi lwanda. 
\q1  
\v 6 Eka abiro bedo jaloch 
\q2 ka aloyo wasigu duto molwora; 
\q1 abiro timo misango mar pak ka akok gimor e hembe maler. 
\q2 Abiro wer kendo abiro loso wende mamit ne Jehova Nyasaye. 
\b  
\q1  
\v 7 Winj dwonda ka aluongo, yaye Jehova Nyasaye; 
\q2 kecha kendo idwoka. 
\q1  
\v 8 Chunya wuoyo kuomi kawacho niya, 
\q2 “Many wangʼ Nyasaye ka ilemo!” 
\q2 Wangʼi, yaye Jehova Nyasaye, ema abiro manyo. 
\q1  
\v 9 Kik ipandna wangʼi, 
\q2 kik iriemb jatichni ka mirima omaki, 
\q2 in ema isebedo jakonyna. 
\q1 Kik ikweda bende kik ijwangʼa, 
\q2 yaye Nyasaye Jawarna. 
\q1  
\v 10 Kata obedo ni wuonwa gi minwa ojwangʼa 
\q2 to Jehova Nyasaye biro rwaka. 
\q1  
\v 11 Puonja yoreni, yaye Jehova Nyasaye; 
\q2 telna e yo moriere tir, 
\q2 nikech joma sanda. 
\q1  
\v 12 Kik ijwangʼa ne dwach wasika, 
\q2 nikech joneno mag miriambo oramona matek, 
\q2 ka gichano mar hinya. 
\b  
\q1  
\v 13 To an gi ratiro kuom wachni: 
\q2 ni pod abiro neno ber Jehova Nyasaye, 
\q2 e piny joma ngima. 
\q1  
\v 14 Gen kuom Jehova Nyasaye; 
\q2 bed motegno ka in gi chir, 
\q2 kendo rit kuom Jehova Nyasaye. 
\c 28  
\cl Zaburi 28 
\d Zaburi mar Daudi. 
\q1  
\v 1 In ema aluongi, yaye Jehova Nyasaye Lwandana; 
\q2 kik itamri winjo ywakna. 
\q1 Nikech ka isiko ilingʼ alingʼa, 
\q2 to abiro chalo gi joma osedhi e bur. 
\q1  
\v 2 Winj ywakna mondo ikecha 
\q2 e sa ma aluongi mondo ikonya, 
\q1 e sa ma atingʼo bedena malo 
\q2 kochomo Kari Maler Moloyo. 
\b  
\q1  
\v 3 Kik iywaya oko gi joricho, 
\q2 kod joma timo gik maricho, 
\q1 joma wuoyo gi jowetegi maber 
\q2 to opando sigu e chunygi. 
\q1  
\v 4 Chulgi kuom timbegi maricho 
\q2 kendo kuom tijegi maricho; 
\q1 chulgi kuom gik ma lwetgi osetimo 
\q2 kendo dwok kuomgi gik mowinjore gi timbegi. 
\q1  
\v 5 Nikech ok gidew tije mag Jehova Nyasaye 
\q2 kod gik ma lwetene osetimo, 
\q1 obiro mukogi mi ogogi piny 
\q2 kendo ok nochak ogergi mi gichungʼ kendo. 
\b  
\q1  
\v 6 Opak Jehova Nyasaye 
\q2 nikech osewinjo ywakna ma akwayogo kony. 
\q1  
\v 7 Jehova Nyasaye e tekona kendo okumbana; 
\q2 chunya ogeno kuome kendo en e konyruokna. 
\q1 Chunya nigi mor 
\q2 kendo abiro goyone erokamano gi wer. 
\b  
\q1  
\v 8 Jehova Nyasaye e teko mar joge, 
\q2 en e ohinga mar resruok ni joge moyiero. 
\q1  
\v 9 Res jogi kendo gwedh jogi moyier 
\q2 bed Jakwadh jogi kendo telnegi nyaka chiengʼ. 
\c 29  
\cl Zaburi 29 
\d Zaburi mar Daudi. 
\q1  
\v 1 Chiwneuru Jehova Nyasaye, yaye un malaike, 
\q2 chiwneuru Jehova Nyasaye duongʼ kod teko. 
\q1  
\v 2 Chiwneuru Jehova Nyasaye duongʼ mowinjore gi nyinge; 
\q2 lamuru Jehova Nyasaye e dier lerne maduongʼ. 
\b  
\q1  
\v 3 Dwond Jehova Nyasaye mor ewi pige; 
\q2 Nyasaye mar duongʼ mor ka polo, 
\q2 Jehova Nyasaye mor ewi pige madongo. 
\q1  
\v 4 Dwond Jehova Nyasaye nigi teko, 
\q2 dwond Jehova Nyasaye nigi duongʼ. 
\q1  
\v 5 Dwond Jehova Nyasaye muko yiende mag sida, 
\q2 Jehova Nyasaye turo yiende sida mag Lebanon matindo tindo. 
\q1  
\v 6 Omiyo Lebanon chikore ka nyaroya, 
\q2 Sirion lengʼore ka jowi ma pod tin. 
\q1  
\v 7 Dwond Jehova Nyasaye mor, 
\q2 omor ka mil polo. 
\q1  
\v 8 Dwond Jehova Nyasaye yiengo piny motimo ongoro; 
\q2 Jehova Nyasaye yiengo ongoro mar Kadesh. 
\q1  
\v 9 Dwond Jehova Nyasaye ma dolo yiend bungu miyo mwanda nywol 
\q2 kendo omiyo yiend bungu dongʼ kolwerore. 
\q1 Ji duto kok ei hekalu mare kagiwacho niya, 
\q2 “Duongʼ odog ni Jehova Nyasaye!” 
\q1  
\v 10 Jehova Nyasaye obet e kom loch mare ewi ataro; 
\q2 Jehova Nyasaye obet e kom loch kaka Ruoth nyaka chiengʼ. 
\q1  
\v 11 Jehova Nyasaye miyo joge teko; 
\q2 Jehova Nyasaye gwedho joge gi kwe. 
\c 30  
\cl Zaburi 30 
\d Zaburi. Wer mar gwedho hekalu. Zaburi mar Daudi. 
\q1  
\v 1 Abiro tingʼi malo, yaye Jehova Nyasaye, 
\q2 nikech ne igola e bur matut, 
\q2 kendo ne ok iyiene wasika mondo obed mamor kuoma. 
\q1  
\v 2 Yaye Jehova Nyasaye Nyasacha, ne aluongi mondo ikonya 
\q2 kendo ne ichanga. 
\q1  
\v 3 Yaye Jehova Nyasaye, ne igola oko e liel, 
\q2 ne iresa kane oyudo aridora piny e bur matut mar joma otho. 
\b  
\q1  
\v 4 Werneuru Jehova Nyasaye, un joge maler; 
\q2 pakuru nyinge maler. 
\q1  
\v 5 Nikech mirimbe bedo mana kuom kinde matin kende, 
\q2 to ngʼwonone osiko nyaka chiengʼ; 
\q1 ywak nyalo bedo gotieno 
\q2 to mor biro mana gokinyi. 
\b  
\q1  
\v 6 Kane aparo ni adhi maber, ne awacho niya, 
\q2 “Onge gima biro bwoga.” 
\q1  
\v 7 Yaye Jehova Nyasaye, kane itimona ngʼwono, 
\q2 ne imiyo achungʼ motegno kaka got; 
\q1 to kane ipando wangʼi, 
\q2 to piny nochama. 
\b  
\q1  
\v 8 In ema ne aluongi, yaye Jehova Nyasaye; 
\q2 Ruoth Nyasaye ema ne aywakne mondo okecha. 
\q1  
\v 9 “Ere ohala ma thona biro kelo, 
\q2 ere gima dhina e liel biro konyigo? 
\q1 Buru bende nyalo paki adier? 
\q2 Bende dohul adierani kasetho? 
\q1  
\v 10 Winja, yaye Jehova Nyasaye, kendo kecha; 
\q2 yaye Jehova Nyasaye bed konyruok mara.” 
\b  
\q1  
\v 11 Ne iloko ywakna modoko miel; 
\q2 ne igolo lawa mar kuyo mi irwakona law mor, 
\q2  
\v 12 mondo chunya owerni kendo kik olingʼ. 
\q1 Yaye Jehova Nyasaye Nyasacha, 
\q2 abiro goyoni erokamano nyaka chiengʼ. 
\c 31  
\cl Zaburi 31 
\d Kuom jatend wer. Zaburi mar Daudi. 
\q1  
\v 1 Kuomi ema aseponde, yaye Jehova Nyasaye, 
\q2 kik iwe ayud wichkuot; 
\q2 gola e chandruok nikech timni makare. 
\q1  
\v 2 Winj ywakna, 
\q2 kendo bi piyo mondo iresa; 
\q1 bed lwandana mar pondo, 
\q2 kendo ohinga motegno manyalo resa. 
\q1  
\v 3 Kaka in lwandana kendo ohingana, 
\q2 telna kendo itaya nikech nyingi. 
\q1  
\v 4 Gola oko e obadho mopondo mochikna 
\q2 nikech in e kar pondona. 
\q1  
\v 5 Aketo chunya e lweti; 
\q2 resa, yaye Jehova Nyasaye, ma Nyasaye mar adiera. 
\b  
\q1  
\v 6 Asin gi joma lamo nyiseche manono ma dhano oloso; 
\q2 an to aketo genona kuom Jehova Nyasaye. 
\q1  
\v 7 Abiro bedo mamor kendo moil kuom herani, 
\q2 nikech ne ineno chandruokna, 
\q2 kendo ne ingʼeyo lit mar chunya. 
\q1  
\v 8 Ok iseketa e lwet jawasigu 
\q2 to iseguro tiendena kama lach. 
\b  
\q1  
\v 9 Kecha, yaye Jehova Nyasaye, nikech an e chandruok; 
\q2 wengena ojony nikech ywak, 
\q2 kendo chunya gi ringra bende nigi lit. 
\q1  
\v 10 Ngimana rem chamo 
\q2 kendo higni maga opongʼ gi chur; 
\q1 tekona rumo nikech lit ma an-go 
\q2 kendo chokena doko mayom yom. 
\q1  
\v 11 Nikech wasigu olwora mangʼeny, 
\q2 joma odak koda koro ochaya gi chunygi; 
\q1 alich kata mana ni osiepena 
\q2 kendo joma onena e wangʼ yo ringa. 
\q1  
\v 12 Wigi owil koda mana ka gima ne asetho chon 
\q2 bende koro achalo mana gi agulu motore. 
\q1  
\v 13 Nikech awinjo ayany mangʼeny ma ji yanyago, 
\q2 kihondko olwora koni gi koni; 
\q1 gikuodho kaka digitimna marach 
\q2 kendo gichano mar kawo ngimana. 
\b  
\q1  
\v 14 To an aketo mana genona kuomi, yaye Jehova Nyasaye; 
\q2 kendo awacho niya, “In e Nyasacha.” 
\q1  
\v 15 Ndalona ni e lweti; 
\q2 resa e lwet wasika, 
\q2 kendo kuom joma lawa. 
\q1  
\v 16 Mad ibed mamor gi jatichni; 
\q2 resa gi herani ma ok rum. 
\q1  
\v 17 Kik iwe wiya kuodi, yaye Jehova Nyasaye, 
\q2 nikech aseywakni ka alemo; 
\q1 to we joma timbegi richo oyud wichkuot 
\q2 kendo ginindi ka gilingʼ thi ei liel. 
\q1  
\v 18 Mi dhogi mawacho miriambo mondo olingʼ; 
\q2 nikech sungagi kod chuny marach ma gin-go, 
\q2 omiyo giwuoyo gi wich teko kuom joma kare. 
\b  
\q1  
\v 19 Mano kaka berni duongʼ, 
\q2 ber mikano ne joma oluori, 
\q1 mimiyo joma opondo kuomi 
\q2 ka ji duto neno. 
\q1  
\v 20 Ipandogi e bwombi iwuon 
\q2 mondo joma richo kik hinygi; 
\q1 iritogi maber e kar dak mari 
\q2 kuom lew joma hangonigi wach. 
\b  
\q1  
\v 21 Pak obed ni Jehova Nyasaye, 
\q2 nikech ne onyisa herane maduongʼ, 
\q2 kane an e dala ma wasigu ogoyona agengʼa. 
\q1  
\v 22 Kane chandruok omaka to ne awacho ni, 
\q2 “Opoga kodi!” 
\q1 Kata kamano ne iwinja ka aywakni 
\q2 mondo ikecha kane aluongi mondo ikonya. 
\b  
\q1  
\v 23 Heruru Jehova Nyasaye un joge maler duto! 
\q2 Jehova Nyasaye rito ngima joma jo-adiera, 
\q2 to josunga to ochulo moromo chuth. 
\q1  
\v 24 Beduru motegno kendo jiwuru chunyu, 
\q2 un duto mugeno kuom Jehova Nyasaye. 
\c 32  
\cl Zaburi 32 
\d Zaburi mar Daudi. Wer mower gi \tl maskil.\tl* 
\q1  
\v 1 Ogwedh ngʼat 
\q2 ma kethone owene, 
\q2 kendo ma richone oseruchi. 
\q1  
\v 2 Ogwedh ngʼatno 
\q2 ma Jehova Nyasaye ok kwan-ne richone, 
\q2 kendo ma wuondruok onge e chunye. 
\b  
\q1  
\v 3 Kane alingʼ 
\q2 to chokena ne ochiyore, 
\q2 kane achur odiechiengʼ duto ma ok aywe. 
\q1  
\v 4 Nikech odiechiengʼ gotieno 
\q2 lweti ne pek kuoma; 
\q1 tekrena ne oduono 
\q2 mana kaka timore e liet mar ndalo oro. \qs Sela\qs* 
\b  
\q1  
\v 5 Eka ne ahulo richona 
\q2 kendo ne ok apando timbena mag ketho. 
\q1 Ne awacho niya, 
\q2 “Abiro hulo ketho chik maga ne Jehova Nyasaye.” 
\q1 Omiyo ne iweyona ketho mane richona okelo. \qs Sela\qs* 
\b  
\q1  
\v 6 Kuom mano, owinjore ji duto moluoro Nyasaye olami 
\q2 kapod inyalo yudi; 
\q1 adier ka pige madongo otugore, 
\q2 to ok gibi chopo ire, 
\q1  
\v 7 In e kar pondona; 
\q2 ibiro rita e chandruok, 
\q2 kendo ibiro lwora gi wende mag loch. \qs Sela\qs* 
\b  
\q1  
\v 8 Abiro chiki kendo abiro puonji e yo monego ilu; 
\q2 adier abiro ngʼadoni rieko kendo abiro rangi maber. 
\q1  
\v 9 Kik ichal gi farese kata gi punda, 
\q2 maonge gi rieko, 
\q1 manyaka chiki mana ka otwe dhoge kendo iywayo gi kamba, 
\q2 nono to ok gibi buti. 
\q1  
\v 10 Lit mochomo joma timbegi richo ngʼeny, 
\q2 to hera ma ok rum mar Jehova Nyasaye, 
\q2 olworo ngʼat mogeno kuome. 
\b  
\q1  
\v 11 Beduru moil kuom Jehova Nyasaye, kendo beduru mamor, un joma kare; 
\q2 weruru, un duto ma urieru tir gie chunyu! 
\c 33  
\cl Zaburi 33 
\q1  
\v 1 Weruru gimor ni Jehova Nyasaye, un joma kare; 
\q2 en gima owinjore mondo joma kare opake. 
\q1  
\v 2 Pakuru Jehova Nyasaye gi nyatiti; 
\q2 werneuru wer mamit gi nyatiti. 
\q1  
\v 3 Werneuru wer manyien; 
\q2 werneuru kugoyone nyiduonge kendo weruru gi ilo. 
\b  
\q1  
\v 4 Wach Jehova Nyasaye nikare kendo en adier; 
\q2 en ja-adiera e gik moko duto motimo. 
\q1  
\v 5 Jehova Nyasaye ohero tim makare kod ratiro; 
\q2 piny duto opongʼ gi herane ma ok rem. 
\b  
\q1  
\v 6 Polo ne ochwe kuom wach Jehova Nyasaye, 
\q2 i dwe gi nyinyo duto nochweyo gi much dhoge. 
\q1  
\v 7 Ochoko pige mag nembe madongo e tawo; 
\q2 oketo kut e dere. 
\q1  
\v 8 Piny duto mondo oluor Jehova Nyasaye; 
\q2 ji duto manie e piny mondo okulrene. 
\q1  
\v 9 Nikech ne owuoyo mi piny nobetie, 
\q2 nogolo chik mi ochungʼ mongirore. 
\b  
\q1  
\v 10 Jehova Nyasaye ketho chenro duto mag pinje; 
\q2 othiro dwaro ma ogendini nigo. 
\q1  
\v 11 To chenro duto mag Jehova Nyasaye to siko kochungʼ nyaka chiengʼ; 
\q2 ochopo dwaro duto manie chunye e tienge duto. 
\b  
\q1  
\v 12 Piny ma ogeno Jehova Nyasaye ma Nyasache ogwedhi, 
\q2 nikech gin oganda mane oyiero kaka girkeni mare. 
\q1  
\v 13 Jehova Nyasaye rango piny gie polo 
\q2 kendo oneno dhano duto; 
\q1  
\v 14 ongʼiyo ji duto modak e piny gie kar dakne e polo, 
\q1  
\v 15 en ema ne ochweyo chunje ji duto, 
\q2 kendo onono gik moko duto ma gitimo. 
\b  
\q1  
\v 16 Onge ruoth minyalo reso nikech en gi jolweny mangʼeny; 
\q2 bende onge jakedo manyalo tony nikech tekone ngʼeny. 
\q1  
\v 17 Geno yudo resruok kuom faras en gima nono 
\q2 kata obedo ni en giteko mangʼeny to ok onyal reso ngʼato. 
\q1  
\v 18 To wangʼ Jehova Nyasaye neno jogo momiye luor, 
\q2 orango joma geno margi ni kuom herane ma ok rem, 
\q1  
\v 19 mondo oresgi e tho 
\q2 kendo oritgi gibed mangima e ndalo mag kech. 
\b  
\q1  
\v 20 Warito Jehova Nyasaye gi geno; 
\q2 en e konyruokwa kendo okumbawa. 
\q1  
\v 21 Chunywa mor kuome, 
\q2 nikech wageno kuom nyinge maler. 
\q1  
\v 22 Mad herani ma ok rum osik kuomwa, yaye Jehova Nyasaye, 
\q2 mana kaka waketo genowa kuomi. 
\c 34  
\cl Zaburi 34 
\d Zaburi mar Daudi. Kane owuondore ni in janeko e nyim Abimelek, mane oriembe mi oa odhi. 
\q1  
\v 1 Abiro miyo Jehova Nyasaye duongʼ kinde duto; 
\q2 dhoga biro siko kapake. 
\q1  
\v 2 Chunya biro sungore kuom Jehova Nyasaye, 
\q2 joma nigi rem mondo owinji kendo obed mamor. 
\q1  
\v 3 Miuru Jehova Nyasaye duongʼ kaachiel koda; 
\q2 watingʼuru nyinge malo kaachiel. 
\b  
\q1  
\v 4 Ne amanyo Jehova Nyasaye ka alamo, kendo nodwoka; 
\q2 ne oresa e luoro duto ma an-go. 
\q1  
\v 5 Joma oketo genogi kuome rieny; 
\q2 ok gi bi neno wichkuot. 
\q1  
\v 6 Ngʼat ma odhierni noluongo Jehova Nyasaye, 
\q2 kendo Jehova Nyasaye nowinje; 
\q2 ne orese mogole e chandruokne duto. 
\q1  
\v 7 Malaika mar Jehova Nyasaye oumo alwora mar jogo momiye luor 
\q2 kendo oresogi. 
\b  
\q1  
\v 8 Bi mondo ine ni Jehova Nyasaye ber; 
\q2 ngʼat ma pondo kuome ogwedhi. 
\q1  
\v 9 Luoruru Jehova Nyasaye, un joge maler, 
\q2 nikech joma omiye luor ok chand gimoro amora. 
\q1  
\v 10 Sibuoche nyalo ool kendo kech nyalo kayogi, 
\q2 to joma manyo Jehova Nyasaye ok ochando gima ber moro amora. 
\b  
\q1  
\v 11 Biuru nyithinda kendo winjauru. 
\q2 Abiro puonjou luoro Jehova Nyasaye. 
\q1  
\v 12 Ngʼato angʼata kuomu mohero ngima 
\q2 kendo nigi geno kuom ndalo mabiro mangʼeny mabeyo, 
\q1  
\v 13 nyaka ogengʼ lewe kik wuo marach 
\q2 kendo ogengʼ dhoge kuom wacho miriambo. 
\q1  
\v 14 Lokri iwe timbe maricho kendo itim tim maber; 
\q2 many kwe kendo iluwe. 
\b  
\q1  
\v 15 Wangʼ Jehova Nyasaye ni kuom joma kare 
\q2 kendo ite winjo ywakgi; 
\q1  
\v 16 to Jehova Nyasaye mon gi joma timo gik maricho, 
\q2 kendo omiyo wich wil kodgi e piny. 
\b  
\q1  
\v 17 Joma kare koywak to Jehova Nyasaye winjogi; 
\q2 oresogi e chandruokgi duto. 
\q1  
\v 18 Jehova Nyasaye chiegni gi joma chunygi otur 
\q2 kendo oreso joma chunygi muol. 
\b  
\q1  
\v 19 Ngʼat makare nyalo bedo gi chandruok mangʼeny, 
\q2 to Jehova Nyasaye rese kuomgi duto; 
\q1  
\v 20 orito chokene duto, 
\q2 ma kata achiel kuomgi ok notur. 
\b  
\q1  
\v 21 Timbe maricho biro nego ngʼama timbene rach, 
\q2 to jowasik joma kare, bura biro loyo. 
\q1  
\v 22 Jehova Nyasaye reso jotichne; 
\q2 onge ngʼato kata achiel mopondo kuome ma bura biro loyo. 
\c 35  
\cl Zaburi 35 
\d Zaburi mar Daudi. 
\q1  
\v 1 Yaye Jehova Nyasaye kedi gi joma kedo koda; 
\q2 ked gi joma lawa. 
\q1  
\v 2 Kaw kuodi gi okumbani; 
\q2 aa malo mondo ibi ikonya. 
\q1  
\v 3 Chom tongʼ ma dhoge bith mar kedo 
\q2 ibwog-go joma lawa. 
\q1 Wuo gi chunya kiwachone niya, “An e warruokni.” 
\q2  
\v 4 Mad joma dwaro ketho ngimana, 
\q2 ne wichkuot gi achaya. 
\q1 Mad joma chanona hinyruok, 
\q2 chunygi nyosre mi giweya. 
\q1  
\v 5 Mad gichal gi mihudhi ma yamo tero, 
\q2 ka malaika mar Jehova Nyasaye riembogi mabor; 
\q1  
\v 6 mad yore ma giluwo bed gi mudho 
\q2 bende yoregigo obed makierogi ka malaika mar Jehova Nyasaye lawogi. 
\q1  
\v 7 Nikech gichikona obadhogi kayiem nono 
\q2 kendo gikunyona bur kayiem mondo alwarie; 
\q1  
\v 8 mad kethruok jukgi apoya ka gikia 
\q2 mad obadhogi ma gisechikona makgi; 
\q2 mad gilwar ei bur ma kargi lal nono. 
\q1  
\v 9 Eka chunya nobed mamor kuom Jehova Nyasaye 
\q2 kendo anabed gimor kuom warruokne. 
\q1  
\v 10 Ringra gi chunya duto, biro hulo kawacho niya, 
\q2 “En ngʼa machalo kodi, yaye Jehova Nyasaye.” 
\q1 Ireso joma odhier e lwet joma nigi teko moloyogi, 
\q2 Adier, ikonyo joma odhier gi jochan kuom joma mayogi. 
\b  
\q1  
\v 11 Joma timo neno ma wengegi tek sudo nyime; 
\q2 gipenja gik ma ok angʼeyo gimoro amora kuomgi. 
\q1  
\v 12 Gichula rach kar ber, 
\q2 kendo giweyo chunya kochwanyore. 
\q1  
\v 13 To kane gituo magihewore to ne arwako law ywagruok 
\q2 kendo ne abolora katweyo chiemo. 
\q1 Kane lamona ok odwoki, 
\q2  
\v 14 ne awuotho koni gi koni ka chunya lit, 
\q2 mana ka gima aywago osiepna kata owadwa. 
\q1 Ne akulo wiya ka an gi kuyo maduongʼ 
\q2 mana ka gima aywago minwa. 
\q1  
\v 15 To kane achwanyora, negichokore kaachiel gi mor; 
\q2 joma ne monja nochokorena sa ma ok angʼeyo, 
\q2 negisiko ka giketho nyinga. 
\q1  
\v 16 Kaka joma ok oluoro Nyasaye chayo ji, 
\q2 ne gijara ka gichano timona marach, ne gikayona lekegi. 
\q1  
\v 17 Yaye Ruoth, ibiro siko kirango gigi katimore nyaka karangʼo? 
\q2 Res ngimana kuom kethruok duto mag-gi. 
\q2 Akwayi ni ires ngimana ma nengone tek e lwet sibuochegi. 
\q1  
\v 18 Abiro goyoni erokamano e chokruok maduongʼ; 
\q2 abiro paki e dier oganda maduongʼ mochokore kaachiel. 
\b  
\q1  
\v 19 Kik iyie ni jogo osungre ni gisenyala, 
\q2 joma obedo wasika maonge gima omiyo; 
\q1 iyie joma ochaya maonge gimoro sigre 
\q2 gi wengegi mar timona marach. 
\q1  
\v 20 Ok giwuo gi kwe, 
\q2 to gichano wacho miriambo, 
\q2 kuom joma odak mos e piny. 
\q1  
\v 21 Giyawona dhogi maduongʼ kendo nyiera ka giwachona giwacho niya, “Haa! Haa! 
\q2 Wasenene gi wengewa wawegi.” 
\b  
\q1  
\v 22 Yaye Jehova Nyasaye, iseneno timgini; kik ilingʼ. 
\q2 Kik ibed koda mabor, yaye Ruoth Nyasaye. 
\q1  
\v 23 Aa malo, kendo chungi mondo ikonya! 
\q2 Kedna, yaye Nyasacha kendo Ruodha. 
\q1  
\v 24 Yala kichwaka kuom timni makare, yaye Jehova Nyasaye ma Nyasacha; 
\q2 kik iyienegi gisungre ni gisenyala. 
\q1  
\v 25 Kik iwe giwach e chunygi niya, 
\q2 “Ero, otimorene mana kaka ne wadwaro.” 
\q2 Kata giwach niya, “Koro wasemuonye ngili.” 
\b  
\q1  
\v 26 Mad ji duto mamor nikech chandruokna 
\q2 oyud wichkuot kendo pachgi olal; 
\q1 mad joma kaworena oyud wichkuot gi achaya. 
\q1  
\v 27 Mad joma mor kuom loch ma imiya 
\q2 okog gi ilo kod mor; 
\q1 mad gisiki kagiwacho kinde duto niya, 
\q2 “Jehova Nyasaye mondo otingʼ malo 
\q2 nikech omiyo jatichne locho.” 
\q1  
\v 28 Abiro pako timni makare 
\q2 kendo kuom pakni duto odiechiengʼ duto. 
\c 36  
\cl Zaburi 36 
\d Kuom jatend wer. Zaburi mar Daudi jatich Jehova Nyasaye. 
\q1  
\v 1 An-gi wach e chunya mowuok kuom Nyasaye, 
\q2 kuom gima joricho timo: 
\q1 Ok giluoro Nyasaye 
\q2 kata matin. 
\q1  
\v 2 Nikech chunye wuonde kendo owuondore kende, 
\q2 chunye wuonde ma ok onyal neno richone mosin-go. 
\q1  
\v 3 Weche mawuok e dhoge richo kendo gin miriambo; 
\q2 oseweyo bedo mariek kod timo maber. 
\q1  
\v 4 Kata konindo e kitandane, to ochano timo gima rach; 
\q2 oseketo chunye mar luwo yor richo, 
\q2 kendo ok otamre gima rach. 
\q1  
\v 5 Herani ochopo nyaka e polo malo, yaye Jehova Nyasaye; 
\q2 adierani chopo nyaka e polo, 
\q1  
\v 6 Timni makare chalo gi gode madongo, 
\q2 ratiro mari chalo gi kut matut. 
\q1 Yaye Jehova Nyasaye, in ema irito ngima dhano gi le. 
\q2  
\v 7 Mano kaka herani ma ok rum nengone tek, yaye Nyasaye! 
\q1 Joma idewo kaachiel gi joma ni piny 
\q2 yudo kar pondo margi e bwo tipo mar bwombeni. 
\q1  
\v 8 Gichamo chiemo mangʼeny e hekalu mari ka gimor; 
\q2 imiyogi math moa e aorani mar mor. 
\q1  
\v 9 Nimar in ema in gi soko mar pi mar ngima; 
\q2 kuom lerni ema wanenoe ler. 
\b  
\q1  
\v 10 Med nyiso herani ni joma ongʼeyi, 
\q2 med nyiso timni makare ne joma gie chunygi ni kare. 
\q1  
\v 11 Mad tiend joma sungore kik nyona, 
\q2 kata lwet joma timbegi richo gola kama antie. 
\q1  
\v 12 Neye kaka joma timo gik maricho oriere piny kopodho 
\q2 osedirgi piny ma ok ginyal aa malo! 
\c 37  
\cl Zaburi 37 
\d Zaburi mar Daudi. 
\q1  
\v 1 Kik chunyi chandre nikech joma richo 
\q2 bende chunyi kik gomb gige joma timo gik maricho; 
\q1  
\v 2 nikech gibiro ner mapiyo mana kaka lum ner; 
\q2 gibiro tho mi gilal nono mapiyo mana kaka yiende mangʼich. 
\b  
\q1  
\v 3 Gen kuom Jehova Nyasaye kendo tim maber. 
\q2 Eka inidag e piny kendo inichiem gi mor e lek maber. 
\q1  
\v 4 Bed mamor kuom Jehova Nyasaye 
\q2 eka obiro miyi gik moko duto ma chunyi dwaro. 
\b  
\q1  
\v 5 Ket yoreni kuom Jehova Nyasaye; 
\q2 ket genoni kuome eka obiro timo kama: 
\q1  
\v 6 Obiro miyo timni makare rieny ka ler mar okinyi, 
\q2 kendo obiro miyo ratiro mari bed machalo 
\q2 gi wangʼ chiengʼ marieny odiechiengʼ tir. 
\b  
\q1  
\v 7 Bed mos e nyim Jehova Nyasaye, kendo rite kihori mos; 
\q2 kik chunyi chandre ka joma moko dhi nyime maber, 
\q2 ka gitimo chenrogi maricho. 
\b  
\q1  
\v 8 Ritri kik ibed gi mirima kendo lokri iwe ich wangʼ 
\q2 kik ibed gi ich wangʼ nikech okelo mana rach. 
\q1  
\v 9 Nikech joma richo ibiro ngʼad kargi oko, 
\q2 to joma oketo genogi kuom Jehova Nyasaye piny biro bedo margi. 
\b  
\q1  
\v 10 Kinde matin nono to joma timbegi richo ok nobedie; 
\q2 kata obedo ni unumanygi to ok unuyudgi. 
\q1  
\v 11 To joma muol piny biro bedo margi 
\q2 kendo gibiro winjo maber ka gin gi kwe maduongʼ. 
\b  
\q1  
\v 12 Joma timbegi richo chano timo marach ni joma kare 
\q2 kendo gimwodo lekegi ka gin gi mirima; 
\q1  
\v 13 to Ruoth Nyasaye nyiero joma timbegi richo, 
\q2 nimar ongʼeyo ni odiechieng-gi biro. 
\b  
\q1  
\v 14 Joma timbegi richo wuodho liganglagi 
\q2 kendo gidolo atungegi, 
\q1 mondo gichiel joma odhier gi jochan piny, 
\q2 mondo gineg joma yoregi oriere tir. 
\q1  
\v 15 To ligengligi biro chwoyo adundogi giwegi, 
\q2 kendo atungegi biro tur. 
\b  
\q1  
\v 16 Gima tin ma ngʼat makare nigo 
\q2 ber moloyo mwandu mathoth mag joma timbegi richo; 
\q1  
\v 17 nikech teko mar joma timbegi richo ibiro kethi, 
\q2 to Jehova Nyasaye tingʼo ngʼat makare malo. 
\b  
\q1  
\v 18 Ndalo mag joma kare ongʼere ni Jehova Nyasaye, 
\q2 kendo girkeni margi biro siko nyaka chiengʼ. 
\q1  
\v 19 E kinde mag masira mopore ok ginibed moner, 
\q2 bende gibiro bedo gi chiemo mathoth ndalo kech. 
\b  
\q1  
\v 20 To joma timbegi richo biro lal nono: 
\q2 Wasik Jehova Nyasaye biro chalo gi ber mar thiepe manie pap, 
\q2 gibiro lal nono, adier gibiro lal nono kaka iro. 
\b  
\q1  
\v 21 Joma timbegi richo holo ji gik moko to ok chul, 
\q2 to joma kare to chiwo gi ngʼwono; 
\q1  
\v 22 piny biro bedo girkeni mar joma Jehova Nyasaye ogwedho, 
\q2 to joma okwongʼo ibiro ngʼad kargi oko. 
\b  
\q1  
\v 23 Ka Jehova Nyasaye mor gi yor ngʼato, 
\q2 to omiyo yorene bedo mopie; 
\q1  
\v 24 kata ka ochwanyore to ok obi podho; 
\q2 nikech Jehova Nyasaye omako lwete. 
\b  
\q1  
\v 25 Nyaka aa e tin-na mi koro adoko ngʼama duongʼ 
\q2 pok aneno ka joma kare ojwangʼ, 
\q2 kata ka nyithindgi kwayo chiemo. 
\q1  
\v 26 Kinde duto gingʼwon kendo giholo ji gigegi nono; 
\q2 nyithindgi ibiro gwedhi. 
\b  
\q1  
\v 27 Lokri iwe timo marach mondo itim maber; 
\q2 eka inidag e piny nyaka chiengʼ. 
\q1  
\v 28 Nikech Jehova Nyasaye ohero joma joratiro, 
\q2 kendo ok obi jwangʼo joge ma jo-adiera. 
\b  
\q1 Ibiro ritgi maber nyaka chiengʼ, 
\q2 to koth joma timbegi richo, 
\q2 ibiro ngʼad kargi oko; 
\q1  
\v 29 joma kare piny biro bedo margi 
\q2 kendo gibiro dak e piny nyaka chiengʼ. 
\b  
\q1  
\v 30 Dho ngʼat makare hulo rieko 
\q2 kendo lewe wacho gima ratiro. 
\q1  
\v 31 Chik mar Nyasache ni e chunye; 
\q2 omiyo tiendene ok kier. 
\b  
\q1  
\v 32 Joma timbegi richo pondo karito joma kare 
\q2 ka gidwaro tieko ngimagi; 
\q1  
\v 33 to Jehova Nyasaye ok bi weyogi e lwetgi 
\q2 kata yie bura logi sa ma iyalogi. 
\b  
\q1  
\v 34 Bed gi geno kuom Jehova Nyasaye 
\q2 kendo luw yore. 
\q1 Obiro tingʼi malo mi omi piny bed mari; 
\q2 ka joma richo ongʼad kargi oko to ibiro neno gi wangʼi. 
\b  
\q1  
\v 35 Aseneno ngʼama timbene richo kendo makwiny 
\q2 kadhi maber mana ka yien mangʼich moti e lowo mowinjore kode. 
\q1  
\v 36 To ne okalo kamano piyo piyo nono kendo ne ok ochak onene, 
\q2 kata ne omanye to ne ok nyal yude. 
\b  
\q1  
\v 37 Ne kit ngima joma onge ketho, 
\q2 non chal joma ngimagi oriere tir, 
\q2 ngʼama ohero kwe nigi geno mar dak amingʼa. 
\q1  
\v 38 To joricho duto ibiro tieki, 
\q2 joma timbegi richo ibiro ngʼad ndalogi oko. 
\b  
\q1  
\v 39 Warruok mar joma kare aa mana kuom Jehova Nyasaye; 
\q2 En e kar pondo margi e ndalo mar chandruok. 
\q1  
\v 40 Jehova Nyasaye konyogi kendo resogi 
\q2 oresogi e lwet joma timbegi richo, 
\q2 kendo owarogi, nikech gipondo kuome. 
\c 38  
\cl Zaburi 38 
\d Zaburi mar Daudi. Lemo mar kwayo kony. 
\q1  
\v 1 Yaye Jehova Nyasaye, kik ikwera ka in gi mirima 
\q2 bende kik ikuma ka mirima mager omaki. 
\q1  
\v 2 Nikech aserni magi osechwoya, 
\q2 kendo lweti osebet kuoma. 
\q1  
\v 3 Mirimbi mager osemiyo ringra obedo maonge ngima maber; 
\q2 chokena ok winj maber nikech richona. 
\q1  
\v 4 Ketho ma asekethogo oima 
\q2 mana ka lodi mapek mohinga tingʼo. 
\b  
\q1  
\v 5 Adhondena otimo tutu kendo dungʼ marach 
\q2 nikech fupa mar timo richo. 
\q1  
\v 6 Adolora kendo akulora piny chuth odiechiengʼ duto, 
\q2 awuotho koni gi koni, ka akuyo. 
\q1  
\v 7 Ondingʼa rama gi rem malich; 
\q2 ringra onge gi ngima maber. 
\q1  
\v 8 Denda ool kendo tekra orumo chuth; 
\q2 achur nikech chunya lit. 
\b  
\q1  
\v 9 Gik ma chunya dwaro duto ongʼereni maber, yaye Jehova Nyasaye; 
\q2 chur ma achurgo ok opondoni. 
\q1  
\v 10 Chunya gwecho, tekra orumo; 
\q2 wengena otimo mudho. 
\q1  
\v 11 Osiepena gi anywolana ok dwar nena nikech adhondena; 
\q2 joma odak buta otangʼ koda. 
\q1  
\v 12 Joma dwaro kawo ngimana ochiko obadhogi, 
\q2 joma dwaro hinya chano kaka ginyalo tieka chuth. 
\q2 Gichano miriambo odiechiengʼ duto. 
\b  
\q1  
\v 13 Achalo ngʼama ite odino, ma ok nyal winjo wach, 
\q2 mana ka momo ma ok nyal yawo dhoge; 
\q1  
\v 14 Achalo gi ngʼat ma ok winj wach, 
\q2 ma dhoge ok nyal dwoko wach. 
\q1  
\v 15 To in ema ariti, yaye Jehova Nyasaye, 
\q2 kendo angʼeyo ni ibiro dwoka, yaye Ruoth Nyasacha. 
\q1  
\v 16 Nimar ne awacho niya, “Kik iyie mondo gisungrena, 
\q2 kata gigona siboi ni tienda okier.” 
\b  
\q1  
\v 17 Nimar achiegni podho, 
\q2 kendo rem ma an-go osiko koda. 
\q1  
\v 18 Ahulo kethona; 
\q2 richona chando chunya. 
\q1  
\v 19 Wasika molwora ngʼeny; 
\q2 joma ochaya maonge gima omiyo thoth mokalo akwana. 
\q1  
\v 20 Joma chulo rach kuom ber ma asetimonegi 
\q2 kuodho nyinga ka an to alawo gima ber. 
\b  
\q1  
\v 21 Yaye Jehova Nyasaye, kik ijwangʼa; 
\q2 kik ibed mabor koda, yaye Nyasacha. 
\q1  
\v 22 Bi piyo mondo ikonya, 
\q2 yaye Ruoth Nyasaye kendo Jawarna. 
\c 39  
\cl Zaburi 39 
\d Kuom jatend wer. Ne Jeduthun. Zaburi mar Daudi. 
\q1  
\v 1 Ne awacho niya, “Abiro ritora e yorena, 
\q2 kendo abiro rito lewa kik wach richo; 
\q1 abiro tweyo dhoga gi tol kinde duto 
\q2 ma joma timbegi richo ni buta.” 
\q1  
\v 2 To e seche mane ok awuo kendo alingʼ mos, 
\q2 kane ok awach gimoro amora maber, 
\q2 pek manie chunya nomedore. 
\q1  
\v 3 Chunya nodoko maliet e iya 
\q2 kendo kane amedo paro matut, to nomedo bedo malit; 
\q2 eka ne atingʼo dhoga mi awuoyo: 
\b  
\q1  
\v 4 Yaye Jehova Nyasaye, nyisa giko mar ngimana 
\q2 bende nyisa kar romb ndalona; 
\q2 mondo abed ka angʼeyo ni ndalona kadho piyo. 
\q1  
\v 5 Iseketo ndalona obedo machiek ka bad dhano; 
\q2 kar romb higni maga ok gimoro e nyimi, 
\q2 ngima dhano ka dhano en mana muya nono. \qs Sela\qs* 
\b  
\q1  
\v 6 Dhano en mana tipo makadho kata ka owuotho koni gi koni, 
\q2 orikni gi tijene mapile kayiem; 
\q2 ochoko mwandu mathoth ka ok ongʼeyo ngʼama obiro weyonegi. 
\b  
\q1  
\v 7 To koro, yaye Ruoth, en angʼo ma amanyo? 
\q2 Genona aketo kuomi. 
\q1  
\v 8 Resa kuom ketho maga duto; 
\q2 kik imi abedi ngʼama joma ofuwo jaro. 
\q1  
\v 9 Ne alingʼ alingʼa, kendo ne ok anyal yawo dhoga mondo awuo, 
\q2 nikech in ema isetimo ma. 
\q1  
\v 10 Gol chwat ma isechwadago oko; 
\q2 goch ma lweti goyago ohinga. 
\q1  
\v 11 Ikwero ji kikumogi nikech richogi; 
\q2 itieko mwandugi mana kaka thuth tieko oduma, 
\q2 dhano ka dhano en mana muya nono. \qs Sela\qs* 
\b  
\q1  
\v 12 Winj lamona, yaye Jehova Nyasaye, 
\q2 chik iti ni lamona ma adwarogo kony; 
\q2 kik idin iti ne ywakna, 
\q1 nikech adak kodi mana ka japiny moro, 
\q2 an mana wendo kaka kwerena duto ne gin. 
\q1  
\v 13 We ngʼiya, mondo achak abed moil kendo 
\q2 kapok adar aweyo pinyni mi alal e wangʼ ji. 
\c 40  
\cl Zaburi 40 
\d Kuom jatend wer. Zaburi mar Daudi. 
\q1  
\v 1 Ne arito Jehova Nyasaye ka ahora mos; 
\q2 ne odwogo ira mi owinjo ywakna. 
\q1  
\v 2 Ne oywaya oko e bur motimo otodo, 
\q2 ne ogola e chwodho gi thidhna. 
\q1 Ne oketo tiendena e lwanda 
\q2 kendo nomiya kama otegno mondo achungie. 
\q1  
\v 3 Ne oketo wer manyien e dhoga, 
\q2 en wer mipakogo Nyasachwa. 
\q1 Ji mangʼeny biro neno mi gibed maluor 
\q2 kendo gibiro keto genogi kuom Jehova Nyasaye. 
\b  
\q1  
\v 4 Ngʼat moketo Jehova Nyasaye 
\q2 kaka kar geno mare en ngʼat mogwedhi, 
\q1 ngʼat ma ok many kony kuom josunga, 
\q2 bende ok omany kony kuom joma lokore mondo olam nyiseche mag miriambo. 
\q1  
\v 5 Ranyisi misetimo thoth, 
\q2 yaye Jehova Nyasaye ma Nyasacha. 
\q1 Gigo mane ichanonwa 
\q2 onge ngʼama nyalo kwanoni; 
\q1 ka dine bed ni wanyalo wuoyo kuomgi; 
\q2 to dine gibedo mangʼeny ma ok wanyal wacho. 
\b  
\q1  
\v 6 Misengini kod chiwo ok ema ne idwaro 
\q2 to ita ema iseyawo; 
\q1 misengini miwangʼo pep kod chiwo mag golo richo 
\q2 ne ok idwaro. 
\q1  
\v 7 Eka nawacho niya, “Eri an ka, 
\q2 asebiro mana kaka ondiki kuoma e Muma. 
\q1  
\v 8 Chunya dwaro timo dwaroni, yaye Nyasacha; 
\q2 chikni ni ei chunya.” 
\b  
\q1  
\v 9 Alando tim makare e chokruok maduongʼ; 
\q2 ok aumo dhoga, 
\q2 mana kaka ingʼeyo, yaye Jehova Nyasaye. 
\q1  
\v 10 Ok apando timni makare e chunya; 
\q2 to awuoyo kuom adierani gi warruokni. 
\q1 Ok apando herani gi adierani 
\q2 ni chokruok maduongʼ. 
\b  
\q1  
\v 11 Kik itamri kecha, yaye Jehova Nyasaye; 
\q2 mad herani gi adierani osik ka rita. 
\q1  
\v 12 Nikech chandruok mokalo akwana olwora; 
\q2 richona osejuka kendo ok anyal neno. 
\q1 Gingʼeny moloyo yie wiya, 
\q2 kendo chunya onyosore gie iya. 
\b  
\q1  
\v 13 Bed mamor, yaye Jehova Nyasaye, mondo iresa. 
\q2 Bi piyo, yaye Jehova Nyasaye, mondo ikonya. 
\q1  
\v 14 Mad ji duto madwaro ketho ngimana 
\q2 wigi kuodi kendo pachgi olal; 
\q1 mad ji duto ma chunygi gombona tho 
\q2 oriemb kadok gi wich okuot. 
\q1  
\v 15 Mad joma nyiera niya, “Haa! Haa!” 
\q2 Ngʼengʼ ka gineno wichkuot. 
\q1  
\v 16 To mad ji duto madwari 
\q2 bed moil kendo mamor kuomi; 
\q1 mad joma ohero warruok mari osik kawacho niya, 
\q2 “Jehova Nyasaye mondo oyud duongʼ!” 
\b  
\q1  
\v 17 Anto adhier kendo achando, 
\q2 mad Ruoth Nyasaye parae. 
\q1 In e jakonyna kendo jawarna; 
\q2 in e Nyasacha, kik ideki. 
\c 41  
\cl Zaburi 41 
\d Kuom jatend wer. Zaburi mar Daudi. 
\q1  
\v 1 Ngʼama paro joma ok nyal en jahawi; 
\q2 Jehova Nyasaye rese ka chandruok omake. 
\q1  
\v 2 Jehova Nyasaye biro rite kendo biro miyo obed mangima; 
\q2 Jehova Nyasaye biro gwedhe e piny, 
\q2 kendo ok obi jwangʼe e lwet wasike. 
\q1  
\v 3 Jehova Nyasaye biro rite e kitandane mar tuo midekre 
\q2 kendo obiro miyo oa malo e kitandane ka ohewore. 
\b  
\q1  
\v 4 Ne awacho niya, “Yaye Jehova Nyasaye, kecha; 
\q2 changa, nikech aseketho e nyimi.” 
\q1  
\v 5 Wasika wuoyo kuoma ka chunygi rach koda, kagiwacho niya, 
\q2 “Obiro tho karangʼo mondo nyinge olal chuth?” 
\q1  
\v 6 Sa asaya ma ngʼato obiro nena, 
\q2 to owuondore ni owuoyo kuoma maber, 
\q1 to ei chunye to ofwambo weche, 
\q2 mondo okethgo nyinga eka oa odhi kendo okeyo wechego ne ji. 
\b  
\q1  
\v 7 Wasika duto kuodho wach kuoma kaachiel kaka ginyalo hinya, 
\q2 chunygi paro gik maricho mogik mondo ohinya, 
\q2 kagiwacho niya, 
\q1  
\v 8 “Tuo marach osekete piny; 
\q2 ok obi aa malo kama oninde.” 
\q1  
\v 9 Koda ka osiepna mane ageno kuome, 
\q2 ngʼat mane chiemo koda, 
\q2 bende osendhoga. 
\b  
\q1  
\v 10 To in, yaye Jehova Nyasaye, yie ikecha; 
\q2 chunga malo, mondo achulgi. 
\q1  
\v 11 Angʼeyo ni chunyi mor koda, 
\q2 nimar jowasika ok loya. 
\q1  
\v 12 Itingʼa malo nikech timna makare 
\q2 kendo ichunga e nyimi nyaka chiengʼ. 
\b  
\b  
\q1  
\v 13 Pak ne Jehova Nyasaye, ma Nyasach Israel, 
\q2 nyaka chiengʼ kendo nyaka chiengʼ. 
\qc Amin kendo Amin. 
\c 42  
\ms1 Kitabu mar Ariyo 
\mr Zaburi 42–72 
\cl Zaburi 42 
\d Kuom jatend wer. \tl Maskil\tl*\f + \fr 42:0 \fl Maskil: \ft en kit wer moro mane Daudi owero.\f* mar yawuot Kora. 
\q1  
\v 1 Mana kaka mwanda gamo yweyo kamanyo kuonde ma pi nitie, 
\q2 e kaka chunya dwari, yaye Nyasaye. 
\q1  
\v 2 Chunya riyo oloyo mar dwaro Nyasaye. 
\q2 En riyo mar dwaro Nyasaye mangima. 
\q2 Abiro dhi romo kod Nyasaye karangʼo? 
\q1  
\v 3 Aseywak mi pi wangʼa osechalo chiemba 
\q2 odiechiengʼ gotieno, 
\q1 ka ji to wachona odiechiengʼ duto niya, 
\q2 “Koro ere Nyasachino?” 
\q1  
\v 4 Aparo gigi duto 
\q2 ka chunya opongʼ giywak: 
\q1 aparo kaka ne adhi gi oganda maduongʼ 
\q2 ka atelo ni ji madhi e od Nyasaye, 
\q1 Ka akok gimor kendo agoyo erokamano 
\q2 E dier oganda maduongʼ matimo nyasi gi mor. 
\b  
\q1  
\v 5 Angʼo momiyo ikuyo, yaye chunya? 
\q2 Angʼo momiyo inyosori yaye chunya? 
\q1 Ket genoni kuom Nyasaye, 
\q2 nikech pod abiro pake, 
\q2 kaka Jawarna kendo Nyasacha. 
\b  
\q1  
\v 6 Chunya lit; 
\q2 omiyo abiro pari, 
\q1 ka an e piny mar Jordan, 
\q2 gi kuonde motingʼore mar Hermon kod e got Mizar. 
\q1  
\v 7 Kut luongore gi kut 
\q2 ei abururu mar pi; 
\q1 apaka magi duto gi ahiti mager 
\q2 oseywera motera. 
\b  
\q1  
\v 8 Jehova Nyasaye chiko herane godiechiengʼ, 
\q2 to gotieno to wende ni e chunya; 
\q1 ma e lamo ma alamogo Nyasach ngimana. 
\q1  
\v 9 Awacho ni Nyasaye ma lwandana niya, 
\q2 “Angʼo momiyo wiyi osewil koda? 
\q1 Angʼo momiyo asiko gi kuyo 
\q2 ka jawasigu sanda?” 
\q1  
\v 10 Chokena tho omako kendo rama malit 
\q2 seche ma joma kedo koda yanya kochaya, 
\q1 ka giwachona odiechiengʼ duto niya, 
\q2 “Koro ere Nyasachino?” 
\b  
\q1  
\v 11 Angʼo momiyo ikuyo, yaye chunya? 
\q2 Angʼo momiyo inyosori, yaye chunya? 
\q1 Ket genoni kuom Nyasaye, 
\q2 nikech pod abiro pake, 
\q2 en e Jawarna kendo Nyasacha. 
\c 43  
\cl Zaburi 43 
\q1  
\v 1 Ngʼadna bura makare, yaye Nyasaye, 
\q2 kendo chwaka e kind joma ok ongʼeyo Nyasaye; 
\q2 resa e lwet joma wuondore gi joma timbegi richo. 
\q1  
\v 2 In Nyasaye ma apondo kuome. 
\q2 Koro to ijwangʼa nangʼo? 
\q1 Angʼo momiyo nyaka asik ka akuyo, 
\q2 ka jawasigu sanda? 
\q1  
\v 3 Or lerni kod adierani, 
\q2 orgi mondo gitelna; 
\q1 yie mondo gikela nyaka godi maler, 
\q2 nyaka kama idakie. 
\q1  
\v 4 Eka anadhi e kendo mar misango mar Nyasaye, 
\q2 nyaka achopi e nyim Nyasaye, 
\q2 Nyasaye ma kelona mor kendo ilo. 
\q1 Abiro paki gi nyatiti, 
\q2 yaye Nyasaye kendo Nyasacha. 
\b  
\q1  
\v 5 Angʼo momiyo ikuyo, yaye chunya? 
\q2 Angʼo momiyo inyosori, yaye chunya? 
\q1 Ket genoni kuom Nyasaye, 
\q2 nikech pod abiro pake, 
\q2 en e Jawarna kendo Nyasacha. 
\c 44  
\cl Zaburi 44 
\d Kuom jatend wer. \tl Maskil\tl*\f + \fr 44:0 \fl Maskil: \ft en kit wer moro mane Daudi owero\f* mar yawuot Kora. 
\q1  
\v 1 Yaye Nyasaye, wasewinjo gi itwa; 
\q2 kendo kwerewa osenyisowa, 
\q1 gik mane itimo e ndalogi, 
\q2 ndalo machon gi lala. 
\q1  
\v 2 Ne iriembo ogendini mamoko gi lweti iwuon 
\q2 kendo ne iguro kwerewa kargi; 
\q1 ne itieko ogendinigo 
\q2 mi imiyo kwerewa okar. 
\q1  
\v 3 Ne ok giloyo pinyno gi liganglagi 
\q2 kendo kata bedegi bende ne ok okelonigi loch; 
\q1 to mana badi iwuon ma korachwich, 
\q2 kod ler mar wangʼi ema nomiyo gilocho nimar ne iherogi. 
\b  
\q1  
\v 4 In e Ruodha kendo Nyasacha, 
\q2 magolo chik mondo Jakobo olochi. 
\q1  
\v 5 Wasiro wasikwa nikech in, 
\q2 waloyo joma kedo kodwa kuom nyingi. 
\q1  
\v 6 Atungʼ mara ok ageno kuome, 
\q2 liganglana bende ok mi alochi; 
\q1  
\v 7 to in ema imiyowa loch ewi wasikwa, 
\q2 imiyo joma kedo kodwa neno wichkuot. 
\q1  
\v 8 Sungawa ni kuom Nyasaye odiechiengʼ duto, 
\q2 kendo wabiro pako nyingi nyaka chiengʼ. \qs Sela\qs*\f + \fr 44:8 \fq Sela \ft tiend wachni ok ongʼere.\f* 
\b  
\q1  
\v 9 To koro isedagiwa kendo isedwokowa piny; 
\q2 tinde ok idhi e kedo gi jolwenjwa. 
\q1  
\v 10 Ne imiyo waringo e nyim wasigu 
\q2 kendo joma kedo kodwa oseyakowa. 
\q1  
\v 11 Ne ijwangʼowa mondo ongamwa ka rombe 
\q2 kendo isekeyowa e dier pinje. 
\q1  
\v 12 Ne iuso jogi nono 
\q2 maonge ohala mane iyudo kuom usogi. 
\b  
\q1  
\v 13 Isemiyo wadoko joma iyanyo e dier joma odak butwa, 
\q2 wan joma inyiero kendo ma ocha gi joma olworowa. 
\q1  
\v 14 Isemiyo olokwa ngero e dier ogendini; 
\q2 kendo ogendini kino wigi konenowa. 
\q1  
\v 15 Wichkuot mara osiko neno e wangʼa odiechiengʼ duto, 
\q2 kendo lela wangʼa wichkuot oumo. 
\q1  
\v 16 Seche ma joma ochaya kendo yanya dirona weche, 
\q2 nikech jasigu oramo ni nyaka ochul kuor. 
\b  
\q1  
\v 17 Magi duto notimorena, kata obedo ni wiwa ne pok owil kodi, 
\q2 kata riambo ne singruok mari. 
\q1  
\v 18 Chunywa ne pok oa moweyi; 
\q2 kendo tiendewa ne pok okier moweyo yori. 
\q1  
\v 19 To pod ne igoyowa agoya mimiyo ondiegi olawowa; 
\q2 kendo ne iumowa gi mudho mandiwa. 
\b  
\q1  
\v 20 Ka dipo ni wiwa nosewil gi Nyasachwa 
\q2 kata ni ne waseyaro lwetwa ne nyasaye moro ma wendo, 
\q1  
\v 21 donge Nyasaye dine ofwenyo wachno, 
\q2 nikech ongʼeyo gik malingʼ-lingʼ manie chuny? 
\q1  
\v 22 To nikech in, tho ochomowa odiechiengʼ duto; 
\q2 ikwanowa kaka rombo mitero kar yengʼo. 
\b  
\q1  
\v 23 Chiew, yaye Ruoth Nyasaye! Inindo nangʼo? 
\q2 Yaw wangʼi inen! Kik ikwedwa nyaka chiengʼ. 
\q1  
\v 24 Ere gima omiyo ipandonwa wangʼi 
\q2 momiyo wiyi owil kod pek ma wan-go kod chandruokwa? 
\b  
\q1  
\v 25 Osedwokwa piny nyaka e buru, 
\q2 dendwa omoko piny e lowo. 
\q1  
\v 26 Aa malo mondo ikonywa; 
\q2 reswa nikech herani ma ok rem. 
\c 45  
\cl Zaburi 45 
\d Kuom jatend wer. Gi dwol mar “Ondanyo.” \tl Maskil\tl*\f + \fr 45:0 \fl Maskil: \ft en kit wer moro mane Daudi owero\f* mar yawuot Kora. Wend Arus. 
\q1  
\v 1 Chunya bedo mamor gi wer mamit 
\q2 e kinde mawero Zaburi maga ne Ruoth; 
\q2 kendo lewa chalo kalamb jandiko mongʼith. 
\b  
\q1  
\v 2 In ema iber moloyo chwo mamoko 
\q2 kendo dhogi owir gi ngʼwono, 
\q2 nikech Nyasaye osegwedhi nyaka chiengʼ. 
\b  
\q1  
\v 3 Twe liganglani e bathi, yaye ngʼat maratego; 
\q2 rwakri gi ler kod duongʼ. 
\q1  
\v 4 E duongʼni nyisri ayanga kaka jalocho 
\q2 mochungʼ ni adiera gi muolo kod tim makare; 
\q2 lweti ma korachwich mondo onyis timbeni miwuoro. 
\q1  
\v 5 Aserni mabitho mondo ochwo chunje mag wasik ruoth; 
\q2 ogendini mondo opodh piny e bwoyi. 
\q1  
\v 6 Lochni nosik nyaka chiengʼ, yaye Nyasaye; 
\q2 kendo tim makare ema nobed kaka ludh loch e pinyruodhi. 
\q1  
\v 7 Ihero tim makare to imon gi timbe maricho; 
\q2 emomiyo Nyasaye, ma Nyasachi, 
\q2 osetingʼi malo moyombo jowadu nikech osewiri gi mo mamiyi mor. 
\q1  
\v 8 Lepi maboyo duto dungʼ tik mane-mane gi poda kod kasia; 
\q2 moa e ute ruodhi molichi gi lak liech. 
\q2 Wende mindito gi gig wer miyi mor. 
\q1  
\v 9 Nyi ruodhi ni e kanyakla mag mondi moluor; 
\q2 mikach ruoth ni e bathi korachwich korwakore gi dhahabu mogol Ofir. 
\b  
\q1  
\v 10 Winji nyara, bed mos, kendo chik iti: 
\q2 Gol pachi kuom jou kaachiel gi jood wuonu monywoli. 
\q1  
\v 11 Berni otoyo ruoth; miye duongʼ, 
\q2 nikech en ruodhi. 
\q1  
\v 12 Nyar Turo biro biro gi mich, 
\q2 joma nigi mwandu biro dwaro kony kuomi. 
\q1  
\v 13 Duongʼ olworo ruoth madhako koni gi koni e kar dakne; 
\q2 law abola mare oton-oton gi dhahabu. 
\q1  
\v 14 Omake itere ne ruoth gi law mochwe gi usi; 
\q2 nyiri masilili man kode luwo bangʼe kendo ikelonegi. 
\q1  
\v 15 Irwakogi e ot gi ilo kod mor maduongʼ; 
\q2 gidonjo e dala ruoth. 
\b  
\q1  
\v 16 Yawuoti biro kawo kar wuonegi; 
\q2 ibiro ketogi ruodhi e piny duto koni gi koni. 
\q1  
\v 17 Abiro miyo ji pari e tienge duto nyaka chiengʼ; 
\q2 kuom mano ogendini biro paki mochwere manyaka chiengʼ. 
\c 46  
\cl Zaburi 46 
\d Kuom jatend wer. Mar yawuot Kora. Kaluwore gi dwond \tl alamoth\tl*\f + \fr 46:0 \fl Alamoth: \ft Ochalo ni en kit wer moro\f*. Wer. 
\q1  
\v 1 Nyasaye e kar pondowa kendo tekowa, 
\q2 en e kar konyruok man kodwa seche duto. 
\q1  
\v 2 Emomiyo ok wabi luor, 
\q2 kata bed ni piny okethore kendo gode mukore e chuny nam, 
\q1  
\v 3 Kata obedoni pige manie nam wuo kendo golo buoyo 
\q2 kata obedo ni gode yiengni kendo dhwolore. \qs Sela\qs* 
\b  
\q1  
\v 4 Nitie aora moro ma pige kelo mor e dala Nyasaye, 
\q2 e dala maler kama Nyasaye Man Malo Moloyo odakie. 
\q1  
\v 5 Nyasaye odak e iye omiyo ok obi podho; 
\q2 Nyasaye biro konye ka piny oyawore. 
\q1  
\v 6 Ogendini nigi chandruok, kendo pinjeruodhi podho; 
\q2 otingʼo dwonde mi piny leny nono. 
\b  
\q1  
\v 7 Jehova Nyasaye Maratego ni kodwa; 
\q2 Nyasach Jakobo e ohingawa. \qs Sela\qs* 
\b  
\q1  
\v 8 Biuru uneye tije Jehova Nyasaye, 
\q2 bi uneye kethruok mosekelo e piny. 
\q1  
\v 9 Omiyo lwenje rumo e tungʼ piny koni gi koni; 
\q2 oturo atungʼ kendo ochodo tongʼ matindo tindo, 
\q2 bende owangʼo kuodi gi mach. 
\q1  
\v 10 “Bed mos, kendo ngʼe ni an Nyasaye; 
\q2 ogendini biro miya duongʼ; 
\q2 piny duto biro miya duongʼ.” 
\b  
\q1  
\v 11 Jehova Nyasaye Maratego ni kodwa; 
\q2 Nyasach Jakobo e ohingawa. \qs Sela\qs* 
\c 47  
\cl Zaburi 47 
\d Kuom jatend wer. Zaburi mar yawuot Kora. 
\q1  
\v 1 Pamuru lweteu, un ogendini duto; 
\q2 Pakuru Nyasaye ka ukok matek gi mor. 
\b  
\q1  
\v 2 Mano kaka Jehova Nyasaye Man Malo Moloyo lich, 
\q2 en Ruoth Maduongʼ man-gi loch e piny duto! 
\q1  
\v 3 Ne oloyonwa ogendini mi gibet e bwowa, 
\q2 ji nopodho piny e tiendewa. 
\q1  
\v 4 Ne oyieronwa girkeni marwa, 
\q2 gik mabeyo mogik ne Jakobo mane ohero. \qs Sela\qs* 
\b  
\q1  
\v 5 Nyasaye oseidho malo ka ji pake gi mor. 
\q2 Jehova Nyasaye osetingʼ malo ka dwond turumbete ywak. 
\q1  
\v 6 Weruru wende pak ne Nyasaye, weruru wende pak; 
\q2 weruru wende pak ne Ruodhwa, weruru wende pak. 
\b  
\q1  
\v 7 Nikech Nyasaye en Ruodh piny duto, 
\q2 werneuru zaburi mar pak. 
\q1  
\v 8 Nyasaye nigi loch ewi ogendini; 
\q2 Nyasaye obet piny e kom lochne maler. 
\q1  
\v 9 Jotend ogendini ochokore kaachiel 
\q2 kaka jo-Nyasach Ibrahim, 
\q1 nikech ruodhi mag piny gin mag Nyasaye; 
\q2 omiyo Nyasaye oyud duongʼ. 
\c 48  
\cl Zaburi 48 
\d Wer. Zaburi mar yawuot Kora. 
\q1  
\v 1 Jehova Nyasaye duongʼ adier, kendo owinjore chuth gi pak, 
\q2 e dala maduongʼ mar Nyasachwa, ma en gode maler. 
\b  
\q1  
\v 2 E dala motingʼore malo kendo ober neno 
\q2 omiyo piny duto bedo mamor. 
\q1 Got Sayun chalo gi kama otingʼore malo mar Zafon, 
\q2 ma en dala maduongʼ mar Ruoth Maduongʼ. 
\q1  
\v 3 Nyasaye nitiere e dalane mochiel motegno 
\q2 kendo osenyisore ni en e ohingane. 
\b  
\q1  
\v 4 Ka ruodhi noriwo teko kanyakla, 
\q2 kane giwuokne oko kaachiel, 
\q1  
\v 5 negineno mi gibuok; 
\q2 kendo negiringo gia ka luoro omakogi. 
\q1  
\v 6 Dendgi nochako tetni kanyo 
\q2 kendo negibedo gi rem machalo gi muoch ma kayo dhako. 
\q1  
\v 7 Ne iturogi matindo tindo ka meli mag Tarshish 
\q2 ma yamb wuok chiengʼ ongʼinjo. 
\b  
\q1  
\v 8 Mana kaka wasewinjo 
\q2 e kaka waseneno gi wengewa, 
\q1 e dala maduongʼ mar Jehova Nyasaye Maratego, 
\q2 e dala mar Nyasachwa: 
\q2 Nyasaye oselose kama dak berie nyaka chiengʼ. \qs Sela\qs* 
\b  
\q1  
\v 9 Ei hekalu mari, yaye Nyasaye, 
\q2 ema wabetie ka waparo kuom herani ma ok rem. 
\q1  
\v 10 Mana kaka nyingi, yaye Nyasaye, 
\q2 e kaka pakni bende chopo nyaka tungʼ piny; 
\q2 lweti ma korachwich opongʼ gi tim makare. 
\q1  
\v 11 Got Sayun oil, 
\q2 kendo mier mag Juda nigi mor, 
\q2 nikech iyalo ji maber. 
\b  
\q1  
\v 12 Wuothi ei Sayun, luorri e iye koni gi koni, 
\q2 kwan osuche duto, 
\q1  
\v 13 par maber kuom ohinga mage, 
\q2 nee udi mag ruodhine, 
\q2 mondo ibi inyis tienge mabiro. 
\b  
\q1  
\v 14 Nikech Nyasaye en Nyasachwa manyaka chiengʼ 
\q2 obiro bedo jaritwa nyaka chop giko ndalowa e piny. 
\c 49  
\cl Zaburi 49 
\d Kuom jatend wer. Zaburi mar yawuot Kora. 
\q1  
\v 1 Winjuru wachni, un ji duto: 
\q2 chikuru itu, un duto mudak e pinyni, 
\q1  
\v 2 un joma odhier kod joma idew, 
\q2 jo-mwandu gi jodhier machalre: 
\q1  
\v 3 Dhoga biro wacho weche mag rieko, 
\q2 weche moa e chunya biro miyo ji winjo tiend weche. 
\q1  
\v 4 Abiro chiko ita ne ngero moro; 
\q2 abiro nyiso tiend midhiero mara ka agoyo nyatitina: 
\b  
\q1  
\v 5 En ngʼa monego aluor ka ndalo mag richo obiro, 
\q2 ka jo-miriambo ma timbegi richo olwora. 
\q1  
\v 6 Joma oketo genogi kuom mwandu 
\q2 kendo masungore kuom mwandugi mathoth? 
\q1  
\v 7 Onge ngʼama nyalo waro ngima nyawadgi 
\q2 kata manyalo chulo Nyasaye nengo moromo ware. 
\q1  
\v 8 Nikech yor waro dhano tek ahinya, 
\q2 maonge nengo madichul marom, 
\q1  
\v 9 ma dimi odag nyaka chiengʼ 
\q2 kendo kik odhi e liel. 
\q1  
\v 10 Nikech ongʼere ne ji duto ni joma riek tho, 
\q2 mana kaka joma ofuwo gi joma omingʼ, 
\q2 bende tho mi giwe mwandu ne joma moko. 
\q1  
\v 11 Lietegi ema biro siko kaka utegi nyaka chiengʼ 
\q2 kendo ema gibiro dakie higni gi higni ma ok rum, 
\q2 kata obedo ni negimako lope mathoth koni gi koni. 
\b  
\q1  
\v 12 To ongʼere ni dhano ok siki e piny, 
\q2 kata obed gi mwandu mathoth machal nade, 
\q2 to otho mana kaka le bende tho. 
\b  
\q1  
\v 13 Mano e gima biro timore ne joma ogenore kendgi giwegi, 
\q2 kendo ne joma luwogi, moluwo wechegi. \qs Sela\qs* 
\q1  
\v 14 Gichomo liete mokuny nigi mana kaka rombe 
\q2 kendo tho biro lokogi chiembe. 
\q1 Joma ngimagi oriere tir biro loyogi ka piny oru, 
\q2 to dendgi biro towo e liete, 
\q2 ka gin mabor gi utegi madongo machalo ute ruodhi. 
\q1  
\v 15 Anto Nyasaye biro reso chunya mi ogola e liel adier, 
\q2 obiro kawa mi odhi koda ire. \qs Sela\qs* 
\q1  
\v 16 Kik chunyi thagre ka ngʼato mwandune medore, 
\q2 kata ka duongʼ mar ode medore; 
\q1  
\v 17 nikech onge gima obiro kawo odhigo ka otho, 
\q2 duongʼ ma en-go ok bi dhi kode e liel, 
\q1  
\v 18 kata obedo ni ne okawore kaka ngʼama ogwedhi kane pod ongima 
\q2 nikech ji nyaka paki ka mwanduni medore, 
\q1  
\v 19 to obiro dhi mi oriwre gi tiengʼ machon mar kwerene, 
\q2 ma ok nyal neno ler mar wangʼ chiengʼ kendo. 
\b  
\q1  
\v 20 Ngʼat man-gi mwandu mathoth to onge winjo, 
\q2 chalo gi le ma otho. 
\c 50  
\cl Zaburi 50 
\d Zaburi mar Asaf. 
\q1  
\v 1 Jal Manyalo Duto, Nyasaye ma en Jehova Nyasaye, 
\q2 wuoyo kendo luongo ji duto modak e piny mondo ochokrene kaachiel, 
\q2 chakre wuok chiengʼ nyaka podho chiengʼ. 
\q1  
\v 2 Nyasaye rieny gie Sayun, 
\q2 dala ma berne longʼo chuth. 
\q1  
\v 3 Nyasachwa biro kendo ok obi lingʼ 
\q2 mach ni e nyime mawangʼo gik moko pep, 
\q2 kendo ahiti mager olwore. 
\q1  
\v 4 Oluongo joma odak e polo malo 
\q2 kaachiel gi joma odak e piny, mondo oyal joge: 
\q1  
\v 5 “Choknauru joga maler, 
\q2 mane otimo koda singruok e yor misango.” 
\q1  
\v 6 Kendo polo hulo timne makare, 
\q2 nikech Nyasaye owuon e jangʼad bura. \qs Sela\qs* 
\b  
\q1  
\v 7 “Winjuru, yaye joga, mondo awuo kodu, 
\q2 yaye jo-Israel, chiknauru itu mondo atim neno ma akwedougo: 
\q2 An Nyasaye ma Nyasachu. 
\q1  
\v 8 Ok akweru nikech wach misengini mutimona, 
\q2 kata nikech misango miwangʼo pep, 
\q2 mosiko ka nitie e nyima. 
\q1  
\v 9 Ok agomb rwath moro amora moa e kundeu 
\q2 kata diek moa e abilni magu, 
\q1  
\v 10 nikech le moro amora manie bungu en mara, 
\q2 kaachiel gi jamni makwayo ewi gode gana achiel. 
\q1  
\v 11 Angʼeyo nying winyo ka winyo manie wi gode, 
\q2 kendo gik mochwe duto manie pewe gin maga. 
\q1  
\v 12 Ka dine bed ni kech kaya to ok dak anyisu, 
\q2 nikech piny en mara, kaachiel gi gik moko duto manie iye. 
\q1  
\v 13 Uparo ni achamo ring rwedhi 
\q2 kata ni amadho remb diek? 
\q1  
\v 14 Chiwuru misango mar goyo erokamano ni Nyasaye, 
\q2 chopuru singruok mau ne Nyasaye Man Malo Moloyo, 
\q1  
\v 15 kendo luongauru e kinde ma un e chandruok; 
\q2 to abiro resou e chandruokugo, eka ubiro miya duongʼ.” 
\p  
\v 16 Joma timbegi richo to Nyasaye wachonegi ni: 
\q1 “Ngʼa momiyou thuolo mar olo chikena 
\q2 kata mondo ukaw singruok maga kaka mau? 
\q1  
\v 17 Ere kaka dutim kamano to uchayo puonjna 
\q2 kendo udiro wechena katoku! 
\q1  
\v 18 Ka uneno jakuo to uriworu kode 
\q2 kendo uchodo mana kaka joma moko timo. 
\q1  
\v 19 Utiyo gi dhou kuom timo richo 
\q2 kendo lewu oikore ne wuond. 
\q1  
\v 20 Usiko uwuoyo marach kuom joweteu 
\q2 kendo ukuotho koda ka oweteu mahie ma uago e ich achiel. 
\q1  
\v 21 Gigi duto usetimo ka an to alingʼ; 
\q2 useparo ni an bende achalo kodu. 
\q1 To koro akwerou kendo anyisou e wangʼu 
\q2 ni useketho kuom timo gigo duto. 
\b  
\q1  
\v 22 “Paruru matut kuom wachni, un joma wigi wil gi Nyasaye, 
\q2 nono to abiro kidhou matindo tindo, maonge ngʼama diresu: 
\q1  
\v 23 Ngʼat ma timona misango mar erokamano miya duongʼ 
\q2 mondo olos yo moriere tir, 
\q2 kendo anyise kaka warruok mar Nyasaye chalo.” 
\c 51  
\cl Zaburi 51 
\d Kuom jatend wer. Zaburi mar Daudi. Kane janabi Nathan obiro ire bangʼ ka Daudi noseterore gi Bathsheba. 
\q1  
\v 1 Kecha, yaye Nyasaye, 
\q2 kaluwore gi herani ma ok rem; 
\q1 gol kethona duto oko 
\q2 kuom ngʼwononi maduongʼ. 
\q1  
\v 2 Luok rochruokna duto oko 
\q2 kendo pwodha kuom richona. 
\b  
\q1  
\v 3 Nikech angʼeyo kethona duto 
\q2 kendo richona osiko e nyima. 
\q1  
\v 4 In iwuon ema asekethoni 
\q2 kendo asetimo richo e nyim wangʼi, 
\q1 mano omiyo in kare ka iwuoyo 
\q2 kendo iwacho adiera ka ingʼadona bura. 
\q1  
\v 5 En adier chutho ni nonywola e richo 
\q2 asebedo ka an jaricho chakre chiengʼ mane minwa omake ichna. 
\q1  
\v 6 Adier, idwaro ni dhano obed ja-adiera gie chunye iye 
\q2 emomiyo ipuonja rieko gie chunya maiye mogik. 
\b  
\q1  
\v 7 Lwoka maler gi owino eka abiro bedo maler; 
\q2 lwoka mondo abed marachar moloyo pe. 
\q1  
\v 8 We awinjie mor kod ilo; 
\q2 mi chokena misetoyo ochak obedie mamor. 
\q1  
\v 9 Pand wangʼi mondo kik ine richona 
\q2 kendo gol kethona duto oko. 
\b  
\q1  
\v 10 Chwe chuny maler e iya, yaye Nyasaye, 
\q2 kendo los chuny motegno mosiko koluori iket e iya. 
\q1  
\v 11 Kik iriemba buti 
\q2 bende kik igol Roho Maler mari kuoma. 
\q1  
\v 12 Duogna mor ma warruokni kelo 
\q2 kendo mi abed gi chuny mohero timo dwaroni, 
\q2 mondo chuny makamano orita. 
\b  
\q1  
\v 13 Eka abiro puonjo joketho yoreni 
\q2 kendo joricho biro lokore duogo iri. 
\q1  
\v 14 Resa e ketho mar chwero remo, yaye Nyasaye, 
\q2 tim kamano, yaye Nyasaye ma wara, 
\q2 eka lewa biro wer kuom timni makare. 
\q1  
\v 15 Yaye Ruoth yaw pien dhoga, 
\q2 eka dhoga biro hulo pakni. 
\q1  
\v 16 Ok imor gi misango mitimoni, nikech dine achiwonigo; 
\q2 misango miwangʼo pep ok miyi mor. 
\q1  
\v 17 Misango mar Nyasaye en chuny motur, 
\q2 chuny motur kendo mamuol, 
\q2 ok itamri, yaye Nyasaye. 
\b  
\q1  
\v 18 Mi Sayun odhi maber kuom herani; 
\q2 chak iger ohinga mag Jerusalem kendo. 
\q1  
\v 19 Eka ibiro yudo mor kuom misengni mag joma kare, 
\q2 kuom misango miwangʼo pep mochiw duto, 
\q2 kendo ibiro chiw rwedhi e kendoni mar misango. 
\c 52  
\cl Zaburi 52 
\d Kuom jatend wer. \tl Maskil\tl*\f + \fr 52:0 \fl Maskil: \ft en kit wer moro mane Daudi owero\f* mar Daudi. Kane noyudo Doeg ja-Edom nosedhi ir Saulo kendo onyise niya, “Daudi osedhi e od Ahimelek.” 
\q1  
\v 1 Angʼo momiyo isungori kuom tim marach, 
\q2 yaye ngʼat maratego? 
\q1 Angʼo momiyo isungori odiechiengʼ duto, 
\q2 in ma in gir wichkuot e nyim Nyasaye? 
\q1  
\v 2 Ichano timbe midwaro wuondogo ji, 
\q2 lewi bende chano gik modwaro hinyogo ji; 
\q2 kendo lewino chalo gi wembe mabith. 
\q1  
\v 3 Ihero rach moloyo ber, 
\q2 miriambo mitni moloyo wacho adiera. \qs Sela\qs* 
\q1  
\v 4 Ihero weche duto machwanyo ji, 
\q2 yaye in lep mohero wuondni! 
\b  
\q1  
\v 5 To Nyasaye biro tieli piny matieki chuth nyaka chiengʼ; 
\q2 obiro yudhi mi oyiechi oko e hembi; 
\q2 obiro pudhi mi ogoli e piny joma ngima. \qs Sela\qs* 
\q1  
\v 6 Joma kare biro neno mano mi gibed maluor; 
\q2 gibiro nyiere kagiwacho ni, 
\q1  
\v 7 “Koro neyeuru ngʼatno, 
\q2 mane ok okawo Nyasaye obedo kar pondo mare, 
\q1 to nogeno mana kuom mwandune mathoth 
\q2 kendo notieko joma moko mondo eka omed bedo gi teko!” 
\b  
\q1  
\v 8 An to achalo yiend zeituni 
\q2 madongo maber e od Nyasaye; 
\q1 ageno kuom hera ma ok rem mar Nyasaye 
\q2 manyaka chiengʼ. 
\q1  
\v 9 Abiro paki nyaka chiengʼ kuom gima isetimo; 
\q2 abiro paki e nyim jogi maler. 
\q1 Abiro keto geno mara kuom nyingi, 
\q2 nikech nyingi ber. 
\c 53  
\cl Zaburi 53 
\d Kuom jatend wer. Kaluwore gi dwol mar \tl mahalath.\tl*\tl Maskil\tl*\f + \fr 53:0 \fl Maskil: \ft en kit wer moro mane Daudi owero\f* mar Daudi. 
\q1  
\v 1 Ngʼat mofuwo wacho e chunye niya, 
\q2 “Nyasaye onge.” 
\q1 Gin joma okethore, kendo yoregi obam; 
\q2 onge kata ngʼato achiel matimo maber. 
\b  
\q1  
\v 2 Nyasaye ngʼiyo ji duto gie polo; 
\q2 mondo oneye ka bende nitie moro kuomgi ma nigi winjo, 
\q2 kata ka bende nitie moro kuomgi mamanyo Nyasaye. 
\q1  
\v 3 Giduto gisebaro giweyo yo; 
\q2 giduto gisekethore; 
\q1 onge ngʼama timo maber, 
\q2 onge kata achiel. 
\b  
\q1  
\v 4 Bende joma timo timbe maricho dipuonjre adier? 
\b  
\q1 Gin joma kidho joga kaka ji chamo kuon; 
\q2 kendo gin joma ok luong Nyasaye mondo okonygi. 
\q1  
\v 5 To koro gin ka, 
\q2 ka kihondko maduongʼ omakogi, 
\q2 kata obedo ni onge gima kelo kihondko. 
\q1 Nyasaye osekeyo choke joma nomonji; 
\q2 isemiyogi wichkuot, 
\q2 nikech Nyasaye nodagigi. 
\b  
\q1  
\v 6 Yaye, mad warruok mar Israel obi koa Sayun! 
\q2 Kinde ma Nyasaye duogo ne joge mwandugi, 
\q2 onego joka Jakobo obed moil kendo Israel obed mamor! 
\c 54  
\cl Zaburi 54 
\d Kuom jatend wer. Wer miwero gi thumbe man-gi waya. \tl Maskil\tl*\f + \fr 54:0 \fl Maskil: \ft en kit wer moro mane Daudi owero\f* mar Daudi. Kane jo-Zif osedhi ir Saulo kendo onyise niya, “Donge Daudi ma imanyo opondo e gwengʼwa?” 
\q1  
\v 1 Resa gi nyingi, yaye Nyasaye; 
\q2 ngʼadna bura kare gi tekoni. 
\q1  
\v 2 Winj lamona, yaye Nyasaye; 
\q2 chik iti ne weche mawuok e dhoga. 
\b  
\q1  
\v 3 Jopinje moko monja; 
\q2 acheje kawo ngimana, 
\q2 gin joma ok dew Nyasaye. \qs Sela\qs* 
\b  
\q1  
\v 4 Adier, Nyasaye e jakonyna; 
\q2 Ruoth owuon ema rita. 
\b  
\q1  
\v 5 Mad chandruok lwor joma ketho nyinga mi ketgi diere; 
\q2 tiekgi, nikech in ja-adiera. 
\b  
\q1  
\v 6 Abiro timoni misango gi chiwo mar hera; 
\q2 abiro pako nyingi, yaye Jehova Nyasaye, nikech nyingi ber. 
\q1  
\v 7 Nikech oseresa kuom gik mathaga duto, 
\q2 mi omiyo wengena ongʼiyo wasika tir bangʼ loyogi. 
\c 55  
\cl Zaburi 55 
\d Kuom jatend wer. Wer gi thumbe man-gi Waya. \tl Maskil\tl*\f + \fr 55:0 \fl Maskil: \ft en kit wer moro mane Daudi owero\f* mar Daudi. 
\q1  
\v 1 Winj lamona, yaye Nyasaye, 
\q2 kik itamri winjo ywakna; 
\q2  
\v 2 Winja kendo idwoka. 
\q1 Pacha chanda kendo chunya onge gi kwe 
\q2  
\v 3 Ka awinjo dwond wasika, 
\q2 kendo ka joma timbegi richo okwarona wengegi, 
\q1 nikech gimiyo abedo gi thagruok 
\q2 kendo giyanya ka gin gi mirima. 
\b  
\q1  
\v 4 Chunya winjo malit e iya 
\q2 kendo luoro mar tho osemaka. 
\q1  
\v 5 Aluor kendo denda tetni; 
\q2 kibaji ogoya matek. 
\q1  
\v 6 Ne awacho niya, “Yaye mad ne bed ni an gi bwombe ka akuru! 
\q2 Dine afuyo aa ka mi ayudo yweyo. 
\q1  
\v 7 Dine aringo adhi mabor 
\q2 mi adhi adak e piny ongoro; \qs Sela\qs* 
\q1  
\v 8 dine areto adhi nyaka kara mar pondo, 
\q2 kuma ni mabor gi apaka kod ahiti.” 
\b  
\q1  
\v 9 Lal pach joma timbegi richo, yaye Ruoth, 
\q2 mi lewgi moki e dandgi, 
\q2 nikech aneno ka mahundu gi dhawo opongʼo dala maduongʼ. 
\q1  
\v 10 Odiechiengʼ gotieno gilwenyo kor ohinga mare; 
\q2 himruok gi ayany ni e iye. 
\q1  
\v 11 Teko mar kethruok chopo tijgi ei dala maduongʼ, 
\q2 mecho gi wuond osiko e yorene. 
\b  
\q1  
\v 12 Ka dine ok obedo malichna ka dine ngʼat ma ok dwara ema ogarna, 
\q2 to dine apondone. 
\q1  
\v 13 To en mana in, dichwo kaka an in jawuodha 
\q2 kendo osiepna, 
\q1  
\v 14 mane wan-go gi lalruok matut 
\q2 chon kane wawuotho e dier oganda maduongʼ e od Nyasaye. 
\b  
\q1  
\v 15 Mad tho neg wasika apoya, 
\q2 mad liel mwonygi ngili kapod gingima, 
\q2 nikech richo olokogi kar dakne. 
\b  
\q1  
\v 16 An to aluongo Nyasaye, 
\q2 kendo Jehova Nyasaye resa. 
\q1  
\v 17 Odhiambo gi okinyi kod odiechiengʼ 
\q2 aywagora ka chunya lit, 
\q2 kendo owinjo dwonda. 
\q1  
\v 18 Owara kapok gimoro ohinya 
\q2 kuom lweny ma ji goyago, 
\q2 kata obedo ni ji mangʼeny kweda. 
\q1  
\v 19 Nyasaye mobet e kom loch nyaka chiengʼ, 
\q2 biro winjogi kendo biro goyogi: \qs Sela\qs* 
\q1 jogo motamore loko yoregi 
\q2 kendo ma ok mi Nyasaye luor. 
\b  
\q1  
\v 20 Jawuodha monjo osiepene; 
\q2 oseketho singruok mane otimo kodgi. 
\q1  
\v 21 Weche mowacho to yom ka mo mabuo, 
\q2 to lweny to ni e chunye; 
\q1 wechege yomo del moloyo mor wirruok, 
\q2 to kara gin mana ligangla mosewuodh oko. 
\b  
\q1  
\v 22 Ket pek manie chunyi ne Jehova Nyasaye 
\q2 to obiro riti; 
\q2 ok obi weyo ngʼat makare podhi. 
\q1  
\v 23 To in, yaye Nyasaye, 
\q2 ibiro dwoko joma timbegi richo piny nyaka 
\q2 ei bur ma gitow; 
\q1 joma joricho machwero remo 
\q2 ok bi bet mangima kata moromo nus ndalogi. 
\b  
\q1 An to ageno kuomi. 
\c 56  
\cl Zaburi 56 
\d Kuom jatend wer. E dwol mar “Akuru mopiyo e onera man mabor.” \tl Miktam\tl*\f + \fr 56:0 \fl Miktam: \ft Ochalo ni en kit wer moro\f* mar Daudi. Kane jo-Filistia osemake Gath. 
\q1  
\v 1 Kecha, yaye Nyasacha, 
\q2 nikech wasika dwaro monja; 
\q2 odiechiengʼ duto gidiya ma ok aywe. 
\q1  
\v 2 Joketh nyinga lawa odiechiengʼ duto; 
\q2 ji mangʼeny monja ka sunga omakogi. 
\b  
\q1  
\v 3 Ka luoro omaka 
\q2 to abiro geno kuomi. 
\q1  
\v 4 Kuom Nyasaye ma apako wachne, 
\q2 in Nyasaye ema aketo genona kuomi omiyo ok abi bedo maluor. 
\q2 Dhano adhana to nyalo timona angʼo? 
\b  
\q1  
\v 5 Odiechiengʼ duto gimino koda wach; 
\q2 kinde duto gichano kaka digihinya. 
\q1  
\v 6 Gikuotho kendo gijimbo wach, 
\q2 ginono okangʼ ka okangʼ ma agoyo, 
\q2 ka gidwaro kawo ngimana. 
\b  
\q1  
\v 7 Kik iyie gitony kata matin nikech richo mag-gi, 
\q2 dwok ogendini piny, yaye Nyasaye, gi mirimbi; 
\q1  
\v 8 Ndik ywak ma aywakgo 
\q2 kwan pi wangʼa machwer e kitapi, 
\q2 donge iketogi e kitabu mari? 
\b  
\q1  
\v 9 Eka wasika biro gomo dok 
\q2 ka aluongo kony moa kuomi. 
\q2 Mano ema abiro ngʼeyogo ni Nyasaye en jakora. 
\q1  
\v 10 Kuom Nyasaye ma apako wachne, 
\q2 in Jehova Nyasaye ema apako wachne, 
\q1  
\v 11 kendo Nyasaye ema aketo genona kuome; 
\q2 omiyo ok abi bedo maluor. 
\q2 Dhano adhana to nyalo timona angʼo? 
\b  
\q1  
\v 12 Asetimo kodi singruok, yaye Nyasaye; 
\q2 abiro chiwoni chiwo maga mag erokamano. 
\q1  
\v 13 Nikech iseresa e tho 
\q2 kendo isegengʼo tienda mi ok ochwanyore, 
\q1 mondo mi awuothi e nyim Nyasaye 
\q2 ma en e ler makelo ngima. 
\c 57  
\cl Zaburi 57 
\d Kuom jatend wer. E dwond “Kik iketh gik moko.” \tl Miktam\tl*\f + \fr 57:0 \fl Miktam: \ft Ochalo ni en kit wer moro\f* mar Daudi. Kane oringone Saulo mi opondo e rogo. 
\q1  
\v 1 Kecha, yaye Nyasaye, yie ikecha 
\q2 nikech kuomi ema chunya yudoe kar pondo. 
\q1 Abiro pondo e bwo tipo mar bwombeni 
\q2 nyaka chop apaka mager rum. 
\b  
\q1  
\v 2 Aywagora ne Nyasaye Man Malo Moloyo, 
\q2 Nyasaye machopona chenroge ema aywakne. 
\q1  
\v 3 Ooro wach gie polo kendo oresa, 
\q2 kokwero joma lawa gi tekregi duto; \qs Sela\qs* 
\q2 Nyasaye oro herane gi adiera mare. 
\b  
\q1  
\v 4 An e dier sibuoche; 
\q2 anindo e dier le mager mangemo, 
\q1 joma lekegi chalo tonge gi aserni, 
\q2 ma lewgi chalo ligangla mabitho. 
\b  
\q1  
\v 5 Nyingi mondo otingʼ malo moyombo polo, yaye Nyasaye; 
\q2 mad duongʼ mari opongʼ piny duto. 
\b  
\q1  
\v 6 Ne giyaro jogo mondo omak tiendena, 
\q2 kane chuny lit odola. 
\q1 Ne gikunyo bugo e yora, 
\q2 to kata kamano gin giwegi ema giselutore e iye. \qs Sela\qs* 
\b  
\q1  
\v 7 Chunya otegno, yaye Nyasaye, 
\q2 chunya otegno; 
\q2 abiro paki gi wer kendo abiro loso wer mamit. 
\q1  
\v 8 Chiew, in chunya! 
\q2 Chiewuru un orutu gi nyatiti! 
\q2 Abiro chiewo kogwen. 
\b  
\q1  
\v 9 Abiro paki e dier ogendini, yaye Jehova Nyasaye. 
\q2 Abiro werni e dier ogendini. 
\q1  
\v 10 Nikech herani maduongʼ chopo nyaka e polo; 
\q2 kendo adiera mari chopo nyaka ewi lwasi. 
\b  
\q1  
\v 11 Nyingi mondo otingʼ malo moyombo polo, yaye Nyasaye; 
\q2 mad duongʼ mari opongʼ piny duto. 
\c 58  
\cl Zaburi 58 
\d Kuom jatend wer. E dwol mar “Kik iketh gik moko.” \tl Miktam\tl*\f + \fr 58:0 \fl Miktam: \ft Ochalo ni en kit wer moro\f* mar Daudi. 
\q1  
\v 1 Un jotelo, bende uwuoyo gi adiera? 
\q2 Bende ungʼado bura moriere tir e dier ji? 
\q1  
\v 2 Ooyo, uchano mayo ji ratiro magi e chunyu, 
\q2 kendo lwetu chano kelo dhawo e piny. 
\q1  
\v 3 Joma timbegi richo chako lal ae nywolgi; 
\q2 gin jo-jendeke kendo gin jo-miriambo aa nywolgi. 
\q1  
\v 4 Kwiri margi chalo gi kwich thuol, 
\q2 chalo gi kwich thuond rachier ma tege oyienyo, 
\q1  
\v 5 ma kata ja-bochne wuone to ok owinji, 
\q2 kata bed ni ja-bochneno olony machal nadi. 
\b  
\q1  
\v 6 Muk lekegi ei dhogi, yaye Nyasaye, 
\q2 yiech kwiri mag sibuoche oko, yaye Jehova Nyasaye! 
\q1  
\v 7 Mi gilal nono ka pi mamol; 
\q2 ka giywayo atungegi to mi asernigi obed madik. 
\q1  
\v 8 Mana kaka ndach kamnie maleny nono, 
\q2 kendo mana kaka nyathi monywol kosetho, 
\q2 mad kik gine wangʼ chiengʼ. 
\b  
\q1  
\v 9 Kapok agulni magi ochako winjo liet mach, 
\q2 bed ni en mach mabebni kata maliel mos, 
\q2 to joma timbegi richo ibiro ywe oko. 
\b  
\q1  
\v 10 Joma kare biro bedo mamor kichulonigi kuor, 
\q2 ka giniluok tiendegi e remb joma timbegi richo. 
\q1  
\v 11 Eka ji nowach niya, 
\q2 “Kara en adier ni joma kare pod yudo pok; 
\q2 kara nitie Nyasaye mangʼado bura ne piny.” 
\c 59  
\cl Zaburi 59 
\d Kuom jatend wer. E dwol mar “Kik iketh gik moko.” \tl Miktam\tl*\f + \fr 59:0 \fl Miktam: \ft Ochalo ni en kit wer moro\f* mar Daudi. Kane Saulo ooro ji mondo ocher od Daudi mondo onege. 
\q1  
\v 1 Resa e lwet wasika, yaye Nyasaye; 
\q2 Rit ngimana kuom joma ogar koda. 
\q1  
\v 2 Gola e lwet joma timo gik maricho 
\q2 kendo resa kuom joma riyo mar chwero remo omako. 
\b  
\q1  
\v 3 Neye kaka gibutona ka girita e yo! 
\q2 Joma kwiny chano kaka digihinya, 
\q2 to an onge gima rach kata richo masetimo, yaye Jehova Nyasaye. 
\q1  
\v 4 Onge gima asetimo marach, 
\q2 to kata kamano gin to giikore monja. 
\q2 Aa malo ikonya; ne chandruokna. 
\q1  
\v 5 Yaye Jehova Nyasaye, ma Nyasaye Maratego, 
\q2 in Nyasach Israel, 
\q1 aa malo ikum ogendini duto; 
\q2 kik ikech andhoke ma timbegi richo. \qs Sela\qs* 
\b  
\q1  
\v 6 Gidwogo ka piny imore, 
\q2 ka gingʼur ka guogi, 
\q2 kendo giwuotho koni gi koni e dala ka gingʼanjo. 
\q1  
\v 7 Neye gik ma gingʼudho koa e dhogi, 
\q2 gingʼudho ligengni gi dhogi, 
\q2 kendo giwacho niya, “En ngʼa manyalo winjowa?” 
\q1  
\v 8 To in nyiergi, yaye Jehova Nyasaye, 
\q2 go siboi ne ogendinigo duto. 
\b  
\q1  
\v 9 Yaye tekona, in ema angʼiyi, 
\q2 in e kar pondona, yaye Nyasaye, 
\q2  
\v 10 Yaye Nyasacha ma jahera. 
\b  
\q1 Nyasaye biro telona 
\q2 kendo obiro miyo asungra ne joma ketho nyinga. 
\q1  
\v 11 To kik uneg-gi, yaye Ruoth ma okumbana 
\q2 nikech joga dipoka wigi owil. 
\q1 Mi giba abaya koni gi koni gi tekoni, 
\q2 kendo mi gidog piny. 
\q1  
\v 12 Nikech richo ma gitimo gi dhogi kuom wuoyo, 
\q2 nikech weche mawuok e dhogi, 
\q2 wegi mondo sungagi ogajgi. 
\q1 Nikech gikwongʼo ji kendo gi wuondo ji, 
\q2  
\v 13 tiekgi gi mirimbi mager, 
\q2 tiekgi mi kargi lal nono, 
\q1 eka biro ngʼere e tungʼ piny koni gi koni 
\q2 ni Nyasaye nigi loch kuom joka Jakobo. \qs Sela\qs* 
\b  
\q1  
\v 14 Gidwogo ka piny imore 
\q2 ka gingʼur ka guogi, 
\q2 kendo giwuotho koni gi koni e dala ka gingʼanjo. 
\q1  
\v 15 Gibayo koni gi koni ka gidwaro chiemo 
\q2 kendo ka ok giyiengʼ to gingʼur. 
\q1  
\v 16 Anto abiro wer kuom tekoni 
\q2 abiro wero herani gokinyi; 
\q1 nikech in e ohingana, 
\q2 in e kar pondona e kinde mag thagruok. 
\b  
\q1  
\v 17 In e tekona, omiyo abiro weroni wend pak; 
\q2 in e ohingana, yaye Nyasaye, 
\q2 in e Nyasacha ma jahera. 
\c 60  
\cl Zaburi 60 
\d Kuom jatend wer. E dwol mar “Ondanyo mar singruok.” \tl Miktam\tl*\f + \fr 60:0 \fl Miktam: \ft Ochalo ni en kit wer moro\f* mar Daudi. Mar puonjo. Kane okedo gi Aram-Naharaim kod Aram Zoba, kendo kane Joab odwogo mi onego jo-Edom alufu apar gariyo e Holo mar Chumbi. 
\q1  
\v 1 Yaye Nyasaye, isedagiwa mi imuomori kuomwa; 
\q1 isebedo ka ikecho kodwa, to koro loswa! 
\q1  
\v 2 Iseyiengo piny mi ibare diere ariyo, 
\q2 Los kuondene mosebarore, nikech oyiengni. 
\q1  
\v 3 Isenyiso jogi kinde mag chandruok mapek; 
\q2 isemiyowa kongʼo mamiyo wakwangʼ. 
\b  
\q1  
\v 4 To isechungo bandech loch ni joma oluori 
\q2 mondo oumgi ka oywanegi atungʼ. \qs Sela\qs* 
\b  
\q1  
\v 5 Reswa kendo konywa gi lweti ma korachwich 
\q2 mondo joma ihero ogol e chandruok. 
\q2  
\v 6 Nyasaye osewuoyo gie kare maler kowacho niya, 
\q2 “Abiro pogo Shekem ne ji, 
\q2 kendo abiro pimo ne ji Holo mar Sukoth. 
\q1  
\v 7 Gilead en mara, Manase bende mara; 
\q2 Efraim en oguta mar lweny, 
\q2 to Juda en osimbona mar loch. 
\q1  
\v 8 Moab en besen mara mar luok, 
\q2 to Edom e kama amoe wuochena; 
\q2 Filistia ema akoke ka aseloyo lweny.” 
\b  
\q1  
\v 9 En ngʼa mabiro kela e dala maduongʼ mochiel motegno? 
\q2 Ngʼa mabiro telona nyaka Edom? 
\q1  
\v 10 Donge in ema isedagiwa, yaye Nyasaye, 
\q2 kendo tinde ok idhi gi jolwenjwa e lweny? 
\q1  
\v 11 Miwa kony mondo walo wasikwa, 
\q2 nikech kony mar dhano onge tich. 
\q1  
\v 12 Wabiro loyo lweny ka Nyasaye nikodwa, 
\q2 kendo obiro nyono wasikwa piny. 
\c 61  
\cl Zaburi 61 
\d Kuom jatend wer. Gi gig wer man-gi tondegi. Mar Daudi. 
\q1  
\v 1 Winj ywakna, yaye Nyasaye; 
\q2 chik iti ne lamona. 
\b  
\q1  
\v 2 Aluongi gie tungʼ piny, 
\q2 aluongi ka chunya ool; 
\q2 telna nyaka lwanda mohinga gi bor. 
\q1  
\v 3 Nikech in ema isebedo kar pondona, 
\q2 isebedona ohinga motegno maponde ne jasigu. 
\b  
\q1  
\v 4 Agombo dak e hembi nyaka chiengʼ 
\q2 mondo apondie e raum mar bwombeni. \qs Sela\qs* 
\q1  
\v 5 Nikech isewinjo singruokna kodi, yaye Nyasaye; 
\q2 isemiya gweth mikano ne joma oluoro nyingi. 
\b  
\q1  
\v 6 Med ndalo mar ngima ruoth, 
\q2 mede higni e tienge mangʼeny. 
\q1  
\v 7 Mi obed e kom loch e nyim Nyasaye nyaka chiengʼ; 
\q2 ket herani kod adierani mondo orite. 
\b  
\q1  
\v 8 Eka anasik ka apako nyingi gi wer 
\q2 kendo abiro chopo singruokna kodi odiechiengʼ kodiechiengʼ. 
\c 62  
\cl Zaburi 62 
\d Kuom jatend wer. Mar Jeduthun. Zaburi mar Daudi. 
\q1  
\v 1 Chunya yudo yweyo kuom Nyasaye kende; 
\q2 warruok aa kuome. 
\q1  
\v 2 En kende ema en lwandana kendo warruokna; 
\q2 en e ohingana, onge gima biro bwoga. 
\b  
\q1  
\v 3 Ubiro siko kumonjo ngʼat achielni nyaka karangʼo? 
\q2 Angʼo momiyo uduto unywakone mondo ugoye piny? 
\q2 En ngʼat machalo mana gi chiel mayiengni madwaro mukore. 
\q1  
\v 4 Giramo ni nyaka to gigole oko 
\q2 kama entie e duongʼne; 
\q2 miriambo ema morogi. 
\q1 Dhogi gigwedhogo ji, 
\q2 to gi ei chunygi to gikwongʼo ji. \qs Sela\qs* 
\b  
\q1  
\v 5 Yud yweyo, yaye chunya, kuom Nyasaye kende; 
\q2 genona aa mana kuome. 
\q1  
\v 6 En kende ema en lwandana kendo warruokna; 
\q2 en e ohingana; onge gima biro bwoga. 
\q1  
\v 7 Warruok mara gi luor ma ayudo aa kuom Nyasaye; 
\q2 en e lwandana manyalo duto, en e kar pondona. 
\q1  
\v 8 Un ji, genuru kuome kinde duto; 
\q2 olneuru oko gik manie chunyu, 
\q2 nikech Nyasaye e kar pondo marwa. \qs Sela\qs* 
\b  
\q1  
\v 9 Joma nipiny gin mana muya nono; 
\q2 joma ni malo gin mana miriambo; 
\q1 ka opimgi e ratil, to gin nono; 
\q2 gin duto gin mana muya nono. 
\q1  
\v 10 Kik igen kuom mwandu moma ji 
\q2 kata isungri kuom gik mokwal; 
\q1 kata bed ni mwandugi medore 
\q2 to kik iket chunyi kuomgi. 
\b  
\q1  
\v 11 Nitie gimoro achiel ma Nyasaye osewacho, 
\q2 chutho nitie gik moko ariyo ma asewinjo gi ita: 
\q1 ni in, yaye Nyasaye, in ratego, 
\q2  
\v 12 kendo ni in, yaye Ruoth Nyasaye, ihero ji. 
\q1 Kuom adier, ibiro chiwo pok ne ngʼato ka ngʼato 
\q2 kaluwore gi gima osetimo. 
\c 63  
\cl Zaburi 63 
\d Zaburi mar Daudi kane en e thim mar Juda. 
\q1  
\v 1 Yaye Nyasaye, in e Nyasacha, 
\q2 adwari gi tekra duto; 
\q1 chunya riyo oloyo mar neni 
\q2 kendo denda duto dwari, 
\q1 e piny motwo kendo maliet, 
\q2 maonge pi modho. 
\b  
\q1  
\v 2 Aseneni ei kari maler 
\q2 kendo asengʼeyo tekoni gi duongʼni. 
\q1  
\v 3 Nikech herani ber moloyo ngima, 
\q2 dhoga biro miyi duongʼ. 
\q1  
\v 4 Abiro paki kapod angima, 
\q2 kendo abiro tingʼo bedena malo e nyingi. 
\q1  
\v 5 Chunya biro romo mana ka ngʼama oromo gi chiemo mabeyo mogik; 
\q2 abiro yawo dwonda ka apaki gi wer. 
\b  
\q1  
\v 6 Ka an e kitandana to apari; 
\q2 pacha osiko pari seche duto mag otieno. 
\q1  
\v 7 Nikech in e konyruokna, 
\q2 awer ka an e bwo tipo mar bwombeni. 
\q1  
\v 8 Chunya omoko kuomi; 
\q2 lweti ma korachwich orita. 
\b  
\q1  
\v 9 Joma dwaro kawo ngimana ibiro tieki; 
\q2 gibiro dhi piny nyaka ei bur kama tut. 
\q1  
\v 10 Ibiro chiwgi ne ligangla 
\q2 kendo gibiro doko chiemb ondiegi. 
\b  
\q1  
\v 11 To ruoth to biro bedo moil kuom Nyasaye; 
\q2 ji duto masingore e nying Nyasaye biro pake, 
\q2 to dho jo-miriambo ibiro um mi lingʼ. 
\c 64  
\cl Zaburi 64 
\d Kuom jatend wer. Zaburi mar Daudi. 
\q1  
\v 1 Winja, Yaye Nyasaye e kinde manyisi chandruokna; 
\q2 rit ngimana kuom jasigu ma bwoga. 
\q1  
\v 2 Panda ne chenro maricho mag joma richo, 
\q2 panda ne koko ma oganda matimo marach goyo. 
\b  
\q1  
\v 3 Gipiago lewgi ka ligangla 
\q2 kendo gichimo wechegi ka asere motimo sum. 
\q1  
\v 4 Gidiro asere kama giponde mondo gichwogo ngʼama onge ketho; 
\q2 gibaye gi asere apoya ka gionge luoro. 
\b  
\q1  
\v 5 Gijiwore ngʼato gi ngʼato kuom chenrogi maricho, 
\q2 giwuoyo kaka ginyalo pando obadhogi, 
\q2 kagiwacho niya, “En ngʼa mabiro nenogi?” 
\q1  
\v 6 Gichano timo ne ji marach kagiwacho niya, 
\q2 “Waseloso chenro malongʼo chuth!” 
\q2 Kuom adier, pach dhano gi chunye opando riekni maricho miwuoro. 
\b  
\q1  
\v 7 To Nyasaye biro bayogi gi aserni; 
\q2 apoya nono, ibiro puodgi piny. 
\q1  
\v 8 Obiro loko lewgi mi gogi gin giwegi 
\q2 mi otiekgi chuth; 
\q2 ji duto monenogi biro kino wigi gi wuoro. 
\q1  
\v 9 Ji duto biro bedo maluor, 
\q2 gibiro hulo tije Nyasaye, 
\q2 kendo gibiro paro mos kuom gima osetimo. 
\b  
\q1  
\v 10 Joma kare mondo obed moil kuom Jehova Nyasaye 
\q2 kendo gipondo kuome; 
\q2 ji duto moriere tir gie chunygi mondo opake! 
\c 65  
\cl Zaburi 65 
\d Kuom jatend wer. Zaburi mar Daudi. Wer. 
\q1  
\v 1 Pak riti e dala mar Sayun, yaye Nyasaye, 
\q2 wabiro rito singruokwa duto. 
\q1  
\v 2 Yaye in miwinjo lamo, 
\q2 in ema ji duto biro biro iri. 
\q1  
\v 3 Kane richowa turowa, 
\q2 iweyonwa kethowa. 
\q1  
\v 4 Joma iyiero gin joma ogwedhi, 
\q2 jogo ma ikelo machiegni mondo odag e hekalu mari! 
\q1 Gik mabeyo mowuok e odi oromowa chuth, 
\q2 mana gigo moa e hekalu mari maler. 
\b  
\q1  
\v 5 Idwokowa gi timbe madongo makare, 
\q2 yaye Nyasaye ma Jawarwa, 
\q1 yaye geno mar piny koni gi koni 
\q2 kendo mar nembe man maboyo mogik, 
\q1  
\v 6 in mane iloso gode gi tekoni iwuon 
\q2 kane imanori gi teko, 
\q1  
\v 7 in mane imiyo nembe olingʼ, 
\q2 wuo mar apaka margi, 
\q2 kod koko mag ogendini. 
\q1  
\v 8 Joma odak kuonde maboyo oluoro timbeni miwuoro, 
\q2 imiyo ji werni gimor, 
\q2 kuma okinyi yaworee kendo odhiambo rumoe. 
\b  
\q1  
\v 9 Irito piny kendo iolone pi, 
\q2 imiyo obedo momew moromo chuth. 
\q1 Aore mag Nyasaye opongʼ gi pi 
\q2 mamiyo ji bedo gi cham, 
\q2 nimar kamano e kaka ne ichano chon. 
\q1  
\v 10 Ipuro puothene 
\q2 kendo iloso oparane duto. 
\q1 Imiyo puothene bedo mangʼich, 
\q2 kendo igwedhe gi cham. 
\q1  
\v 11 Igwedho higa gi cham mogundho, 
\q2 kendo gechegi mwandu opongʼo. 
\q1  
\v 12 Pewe motimo lum mag piny ongoro ngʼich oromo; 
\q2 kendo gode opongʼ gi mor. 
\q1  
\v 13 Lek duto jamni kwaye ka giwinjo maber 
\q2 kendo holni cham mochiek odhure; 
\q2 gikok gimor kendo giwer. 
\c 66  
\cl Zaburi 66 
\d Kuom jatend wer. Wer. Zaburi. 
\q1  
\v 1 Go koko gi mor ne Nyasaye, in piny duto! 
\q2  
\v 2 Wer kipako duongʼ mar nyinge; 
\q2 mi pakne obed gi duongʼ! 
\q1  
\v 3 Wachne Nyasaye niya, “Mano kaka timbe mitimo dongo! 
\q2 Tekoni duongʼ manade, 
\q2 mamiyo wasiki duto leny nono koneni. 
\q1  
\v 4 Piny duto kuloreni; 
\q2 giweroni wende pak; 
\q2 giwero wende pak ka gipako nyingi.” \qs Sela\qs* 
\b  
\q1  
\v 5 Biuru uneye gik ma Nyasaye osetimo; 
\q2 bi uneye kaka gik motimo ne dhano dongo! 
\q1  
\v 6 Ne oloko nam lo motwo, 
\q2 mine gikalo pige ka giwuotho gi tiendegi, 
\q2 Biuru mondo wabed moil kuome. 
\q1  
\v 7 Olocho nyaka chiengʼ gi teko ne, 
\q2 wengene ema rito ogendini. 
\q2 Omiyo kik jongʼanyo hedhre mar kedo kode. \qs Sela\qs* 
\b  
\q1  
\v 8 Pakuru Nyasachwa, yaye ogendini, 
\q2 neuru ni pak mipakego ji duto owinjo; 
\q1  
\v 9 oserito ngimawa 
\q2 kendo osegengʼo tiendewa ni kik kier. 
\q1  
\v 10 Yaye Nyasaye ne itemowa ni in iwuon; 
\q2 ne ipwodhowa ka fedha. 
\q1  
\v 11 Ne iterowa e od twech 
\q2 kendo ne iketo lodi mapek e dier ngʼewa. 
\q1  
\v 12 Ne imiyo ji onyono wiyewa; 
\q2 kendo ne wakalo mach gi pi, 
\q2 kata kamano ne ikelowa nyaka kama omew. 
\b  
\q1  
\v 13 Abiro biro e hekalu mari gi misango miwangʼo pep 
\q2 kendo abiro chopo kwongʼruok masetimo kodi. 
\q1  
\v 14 Kwongʼruok mane asingoni e chunya kendo awacho gi dhoga 
\q2 kane an e thagruok. 
\q1  
\v 15 Abiro timoni misango gi jamni machwe 
\q2 kendo abiro miyi chiwo mar imbe; 
\q2 bende abiro chiwoni rwedhi gi diek. \qs Sela\qs* 
\b  
\q1  
\v 16 Biuru uchik itu, un duto muluoro Nyasaye; 
\q2 we anyisue gik ma osetimona. 
\q1  
\v 17 Ne aywakne gi dhoga; 
\q2 pakne ne ni e lewa. 
\q1  
\v 18 Ka dine bed ni amor gi richo manie chunya, 
\q2 to Ruoth dine ok ochikona ite, 
\q1  
\v 19 to kuom adier, Nyasaye osechikona ite 
\q2 kendo osewinjo dwonda ka alame. 
\q1  
\v 20 Pak obed ne Nyasaye, 
\q2 ma ok osedagi lamona, 
\q2 kata golo herane kuoma. 
\c 67  
\cl Zaburi 67 
\d Kuom jatend wer. Gik miwergo man-gi tondegi. Zaburi. Wer. 
\q1  
\v 1 Mad Nyasaye timnwa ngʼwono kendo owinjwa; 
\q2 mad omi wangʼe rienynwa maber, \qs Sela\qs* 
\q1  
\v 2 mondo yoreni ongʼere e piny, 
\q2 kendo ogendini duto oyud warruokne. 
\b  
\q1  
\v 3 Mad ji paki, yaye Nyasaye; 
\q2 mad ji duto opaki. 
\q1  
\v 4 Mad ogendini obed mamor kendo ower gi ilo, 
\q2 nikech irito ji gi ratiro, 
\q2 kendo itayo ogendini mag piny. \qs Sela\qs* 
\q1  
\v 5 Mad ji paki, yaye Nyasaye; 
\q2 mad ji duto opaki. 
\b  
\q1  
\v 6 Eka piny biro chiego cham kaka owinjore 
\q2 kendo Nyasaye, ma Nyasachwa, biro gwedhowa. 
\q1  
\v 7 Nyasaye biro gwedhowa, 
\q2 kendo piny duto koni gi koni biro luore. 
\c 68  
\cl Zaburi 68 
\d Kuom jatend wer. Zaburi mar Daudi. Wer. 
\q1  
\v 1 Mad Nyasaye aa malo, mad wasike ke; 
\q2 mad joma kedo kode ring konene. 
\q1  
\v 2 Mad iriembgi gi dhi mabor, 
\q2 mana kaka yamo riembo iro tero mabor; 
\q1 mad joma timbegi richo lal nono e nyim Nyasaye 
\q2 mana kaka odok leny kowinjo mach. 
\q1  
\v 3 To joma kare to mad bed mamor 
\q2 kendo moil e nyim Nyasaye; 
\q2 mad gibed mamor kendo gibed mamor chuth. 
\b  
\q1  
\v 4 Weruru ne Nyasaye, weruru wende pak ne nyinge, 
\q2 miyeuru duongʼ, En moriembo gechene e boche polo, 
\q1 nyinge en Jehova Nyasaye, 
\q2 beduru moil e nyime. 
\q1  
\v 5 Nyasaye modak kare kama ler. 
\q2 En wuoro ne joma onge gi wuonegi kendo en jachwak mon ma chwogi otho. 
\q1  
\v 6 Nyasaye keto joma odongʼ kendgi e udi 
\q2 kendo otelo ne joma otwe kower; 
\q2 to joma ohero ngʼanyo to dak e piny ma chiengʼ otwoyo kururu. 
\b  
\q1  
\v 7 Kane iwuok idhi kitelo ne jogi, yaye Nyasaye, 
\q2 kane iwuotho e piny mokethore maonge tich, \qs Sela\qs* 
\q1  
\v 8 piny noyiengni 
\q2 kendo polo noolo koth e piny, 
\q1 e nyim Nyasaye, Jal man Sinai, 
\q2 e nyim Nyasaye ma Nyasach Israel. 
\q1  
\v 9 Ne ichiwo koth mogundho, yaye Nyasaye; 
\q2 ne idwogo chuny girkeni mari mane ojony. 
\q1  
\v 10 Jogi nokawo pinyno modakie kendo nichiwo ne joma odhier gik ma gilando, 
\q2 kigolo kuom mwanduni mogundho, yaye Nyasaye. 
\b  
\q1  
\v 11 Ruoth nolando wach kendo oganda mane okawo wachno 
\q2 mi okeye ne duongʼ mokalo: 
\q1  
\v 12 “Ruodhi gi jolweny dar gi ngʼwech; 
\q2 ji pogo gik moyaki e kambi. 
\q1  
\v 13 Kata mana sa ma inindo but mach kama liet, 
\q2 to bwombe mag akuchena oum gi dhahabu, 
\q2 kendo yierene oum gi fedha maleny.” 
\q1  
\v 14 Kane Jal Maratego okeyo ruodhi manie piny, 
\q2 to ne ochal mana gi pe molwar koa e kama otingʼore gi malo mar Zalmon. 
\b  
\q1  
\v 15 Gode mag Bashan gin gode madongo miwuoro; 
\q2 godego mag Bashan ojuothore adier. 
\q1  
\v 16 Angʼo momiyo ungʼicho gi nyiego, yaye gode mojuothore, 
\q2 angʼo momiyo nyiego omakou gi got kama Nyasaye oyiero mondo ogurie lochne, 
\q2 kama Jehova Nyasaye owuon biro dakie nyaka chiengʼ? 
\q1  
\v 17 Geche mag lweny mag Nyasaye gin tara gi tara; 
\q2 gingʼeny mokalo akwana; 
\q2 Ruoth osebiro koa Sinai mondo odonji kare maler. 
\q1  
\v 18 Kane iidho idhi malo 
\q2 to ne itelone joma nimako e lweny; 
\q2 kendo ne ikawo mich mane ji omiyi, 
\q1 nyaka mich mane jongʼanyo omiyi, 
\q2 mondo in Jehova Nyasaye, idag kanyo. 
\b  
\q1  
\v 19 Pak odog ne Ruoth, ma en Nyasaye ma Jawarwa, 
\q2 Nyasaye matingʼonwa pekwa ndalo duto. \qs Sela\qs* 
\q1  
\v 20 Nyasachwa en Nyasaye ma waro ji; 
\q2 tony e tho aa kuom Jehova Nyasaye Manyalo Gik Moko Duto ma Wuon Loch. 
\q1  
\v 21 Kuom adier, Nyasaye biro toyo wiye wasike, 
\q2 obiro mayo joma dhi nyime gi timo richo osimbo motimo yier ma girwako. 
\q1  
\v 22 Ruoth wacho niya, “Abiro gologi oko Bashan; 
\q2 abiro gologi oko kama tut mar nam, 
\q1  
\v 23 mondo unyum tiendeu e remb joma kedo kodu, 
\q2 seche ma guogi magu olodho lewgi ka gichamo makorgi.” 
\b  
\q1  
\v 24 Wuodhi koro nenore maler, yaye Nyasaye, 
\q2 wuodh Nyasacha ma Ruodha nenore maler kodonjo kare maler. 
\q1  
\v 25 Joma wer gi dhogi otelo eka joma wer ka goyo thumbe luwogi, 
\q2 nyiri magoyo oyieke bende ni kodgi machiegni. 
\q1  
\v 26 Pakuru Nyasaye e dier chokruok maduongʼ; 
\q2 pakuru Jehova Nyasaye e dier chokruok mar jo-Israel. 
\q1  
\v 27 Dhoot matin mar joka Benjamin otelonegi, 
\q2 oganda maduongʼ mar ruodhi moa e dhood Juda bende ni kodgi, 
\q2 eka nitie ruodhi moa e dhout Zebulun gi Naftali. 
\b  
\q1  
\v 28 Chok tekoni kaachiel, yaye Nyasaye; nyiswa tekoni, 
\q2 yaye Nyasaye; kaka isebedo kitimo nyaka aa chon. 
\q1  
\v 29 Nikech hekalu mari man Jerusalem 
\q2 ruodhi biro keloni mich. 
\q1  
\v 30 Kwer ondiek manie dier togo, 
\q2 kwer kweth mag rwedhi manie dier nyiroye mag ogendini. 
\q1 Mi okel sirni mangʼeny mag fedha ka wiye okuot. 
\q2 Ke ogendini mohero lweny. 
\q1  
\v 31 Joote biro biro koa Misri; 
\q2 Kush bende biro bolore ne Nyasaye. 
\b  
\q1  
\v 32 Weruru ne Nyasaye, yaye pinjeruodhi mag piny, 
\q2 weruru wende pak ne Ruoth Nyasaye, \qs Sela\qs* 
\q1  
\v 33 werneuru ne Jal mariembo gechene e kor polo malo manyaka nene, 
\q2 Jal mamor gi dwol maduongʼ. 
\q1  
\v 34 Landuru teko mar Nyasaye 
\q2 ma nigi duongʼ kuom Israel, 
\q2 kendo ma nigi teko e kor polo. 
\q1  
\v 35 Ilich miwuoro ka in kari maler, yaye Nyasaye, 
\q2 Nyasach Israel chiwo teko gi nyalo ne joge. 
\b  
\q1 Pak mondo obed ne Nyasaye! 
\c 69  
\cl Zaburi 69 
\d Kuom jatend wer e dwol mar “Ondanyo.” Mar Daudi. 
\q1  
\v 1 Resa, yaye Nyasaye, 
\q2 nikech pi oseima nyaka e ngʼuta. 
\q1  
\v 2 Asechako nimo e chwodho matut, 
\q2 kama onge lowo motegno ma ngʼato nyalo chungʼie. 
\q1 Asechopo e chuny pi kama tut, 
\q2 kendo apaka olwora oketa diere. 
\q1  
\v 3 Koro aseywak mondo okonya mi aol; 
\q2 dwonda rewni. 
\q1 Wengena pek, 
\q2 ka amanyo Nyasacha. 
\q1  
\v 4 Joma ochaya maonge gima omiyo 
\q2 ngʼeny moloyo yie wiya; 
\q1 joma olokore wasika kayiem thoth adier, 
\q2 jogogo madwaro mondo otieka. 
\q1 Ichuna mondo adwok 
\q2 gima ne ok akwalo. 
\b  
\q1  
\v 5 Ingʼeyo fupa, yaye Nyasaye; 
\q2 kethona ok opondoni. 
\b  
\q1  
\v 6 Mad joma ogeno kuomi 
\q2 kik ne wichkuot nikech an, 
\q2 yaye Ruoth, Jehova Nyasaye Maratego; 
\q1 mad joma manyi 
\q2 kik ne wichkuot nikech an, 
\q2 yaye Nyasach Israel. 
\q1  
\v 7 Nimar ji yanya to alingʼ alingʼa nikech in, 
\q2 kendo wichkuot obako lela wangʼa. 
\q1  
\v 8 Achalo wendo ne owetena 
\q2 an kaka jamwa ne yawuot minwa; 
\q1  
\v 9 nikech hera matut ma aherogo odi tieka, 
\q2 kendo ayenje mag joma yanyi lwar kuoma. 
\q1  
\v 10 Ka aywak kendo atweyo chiemo 
\q2 to pod nyaka ayud ayany; 
\q1  
\v 11 ka arwako law ywak, 
\q2 to ji oloka ngero. 
\q1  
\v 12 Joma obet e rangach jara, 
\q2 kendo alokora wer ma jokongʼo wero. 
\b  
\q1  
\v 13 To alami, yaye Jehova Nyasaye, 
\q2 e kinde ma iikori mar konya; 
\q1 kuom herani maduongʼ, yaye Nyasaye, 
\q2 dwoka gi resruok mari mar adier. 
\q1  
\v 14 Gola oko e chwodho, 
\q2 kik iyie anim; 
\q1 resa e lwet joma ochaya, 
\q2 gola e chuny pi kama tut. 
\q1  
\v 15 Kik iwe ohula ywera mi tera 
\q2 kata kut mwonya duto, 
\q2 kata bur matut um dhoge ka an e iye. 
\q1  
\v 16 Dwoka, yaye Jehova Nyasaye, dwoka, nikech herani ber; 
\q2 lokri ira kuom kechni maduongʼ. 
\q1  
\v 17 Kik ipand wangʼi ne jatichni; 
\q2 dwoka piyo, nikech anie chandruok. 
\q1  
\v 18 Bi machiegni mondo ikonya, 
\q2 resa nikech joma kedo koda. 
\b  
\q1  
\v 19 Ingʼeyo kaka ijara, kaka ikuodo wiya kendo kaka aneno wichkuot; 
\q2 wasika duto ochoma tir. 
\q1  
\v 20 Ajara osechodo chunya 
\q2 kendo aonge gi kar kony. 
\q1 Ne amanyo joma hoya, 
\q2 to ne ok ayudo kata achiel. 
\q1  
\v 21 Negiketo kedhno e chiemba 
\q2 kendo negimiya kong andwayo mondo otiekna riyo. 
\b  
\q1  
\v 22 Mad mesa mochan e nyimgi lokre obadho; 
\q2 kendo mad olokrenegi gir chulo kuor kod otegu. 
\q1  
\v 23 Mad wengegi dinre mondo kik ginen 
\q2 kendo oguchgi odolre nyaka chiengʼ. 
\q1  
\v 24 Ol mirimbi kuomgi; 
\q2 we mirimbi mager omakgi. 
\q1  
\v 25 Mad miechgi dongʼ gundni; 
\q2 kendo kik iyie ne ngʼato angʼata dag e hembgi. 
\q1  
\v 26 Nimar gisando joma ihinyo 
\q2 kendo giwuoyo kuom lit mag joma ihinyo. 
\q1  
\v 27 Ket ketho e wigi kuom ketho ka ketho ma gitimo; 
\q2 kendo kik iyie giyud warruok mari. 
\q1  
\v 28 Mad ruch kargi oko e kitap joma ngima 
\q2 kendo kik kwan-gi kaachiel gi joma kare. 
\b  
\q1  
\v 29 An-gi rem kendo awinjo marach e chunya; 
\q2 mad warruokni rita, yaye Nyasaye. 
\b  
\q1  
\v 30 Abiro pako nying Nyasaye gi wer 
\q2 kendo abiro miyo nyinge duongʼ gi erokamano. 
\q1  
\v 31 Mano biro miyo Jehova Nyasaye mor moloyo rwadh pur, 
\q2 moloyo rwath mabwoch man-gi tungene kod ombongʼne. 
\q1  
\v 32 Joma odhier biro neno mi gibed mamor, 
\q2 un ma udwaro Nyasaye mad chunyu bed mangima! 
\q1  
\v 33 Jehova Nyasaye winjo joma ochando 
\q2 kendo ok olok ngʼeye ne joge motwe. 
\b  
\q1  
\v 34 Piny gi polo mondo opake, 
\q2 kaachiel gi nembe kod gik moko duto mawuothoe igi, 
\q1  
\v 35 nikech Nyasaye biro reso Sayun 
\q2 kendo obiro gero dala mag Juda kendo. 
\q1 Eka ji nodag kanyo kendo ginikawe kaka margi; 
\q2  
\v 36 enobed girkeni mar koth jotichne, 
\q2 kendo joma ohero nyinge nodag kanyo. 
\c 70  
\cl Zaburi 70 
\d Kuom jatend wer. Kwayo mar Daudi. 
\q1  
\v 1 Ret piyo mondo iresa, yaye Nyasaye; 
\q2 bi piyo mondo ikonya, yaye Jehova Nyasaye. 
\b  
\q1  
\v 2 Mad joma dwaro ngimana 
\q2 yud wichkuot kendo pachgi lal; 
\q1 mad ji duto ma gombona hinyruok 
\q2 dog kuma giaye ka giyudo achaya. 
\q1  
\v 3 Mad joma wachona niya, “Haa! Haa!” 
\q2 Dog kuma giaye ka wichkuot omakogi. 
\q1  
\v 4 To mad ji duto madwari 
\q2 bed moil kendo mamor kuomi; 
\q1 mad joma ohero warruok mari osik kawacho niya, 
\q2 “Jehova Nyasaye mondo oyud duongʼ!” 
\b  
\q1  
\v 5 Adhier kendo achando; 
\q2 bi ira piyo, yaye Nyasaye. 
\q1 In e konyruokna kendo jaresna; 
\q2 kik ideki, yaye Jehova Nyasaye. 
\c 71  
\cl Zaburi 71 
\q1  
\v 1 Kuomi ema aseponde, yaye Jehova Nyasaye; 
\q2 kik iwe ayud wichkuot. 
\q1  
\v 2 Konya kendo gola e chandruok, nikech timni makare; 
\q2 winja kendo iresa. 
\q1  
\v 3 Bedna lwanda mar pondo, 
\q2 ma anyalo ringo adhiye seche duto; 
\q1 gol chik mondo iresa, 
\q2 nimar in e lwandana kendo ohingana. 
\q1  
\v 4 Resa e lwet joma timbegi richo, yaye Nyasacha, 
\q2 gola kuom richo gi joma kwiny momaka matek. 
\b  
\q1  
\v 5 Nimar in ema isebedo genona, yaye Jehova Nyasaye Manyalo Gik Moko Duto, 
\q2 in ema isebedo kimiya chir nyaka ae tin-na. 
\q1  
\v 6 Asebedo ka ayiengora kuomi nyaka ne nywola; 
\q2 in ema ne igola ei minwa. 
\q2 Abiro apaki nyaka chiengʼ. 
\q1  
\v 7 Alokora gima bwogo ji mangʼeny 
\q2 to kata kamano in e kar pondo mara motegno. 
\q1  
\v 8 Dhoga opongʼ gi pakni, 
\q2 kendo asiko ahulo duongʼni maler odiechiengʼ duto. 
\b  
\q1  
\v 9 Kik ijog koda ka koro ati; 
\q2 kik ijwangʼa ka tekra orumo. 
\q1  
\v 10 Nimar wasika wuoyo marach kuoma; 
\q2 jogo marita mondo onega loso wach kaachiel. 
\q1  
\v 11 Giwacho niya, “Nyasaye oseweye; 
\q2 laweuru mondo umake, 
\q2 nikech onge ngʼama biro rese.” 
\q1  
\v 12 Kik ibed mabor koda, yaye Nyasaye; 
\q2 bi piyo mondo ikonya, yaye Nyasacha. 
\q1  
\v 13 Mad joma donjona lal nono ka wigi okuot; 
\q2 mad joma dwaro hinya, 
\q2 obed gi achaya kod wichkuot koni gi koni. 
\b  
\q1  
\v 14 Anto abiro siko ka an gi geno; 
\q2 abiro paki kendo abiro medo paki. 
\b  
\q1  
\v 15 Dhoga biro hulo timni makare, 
\q2 kod warruokni odiechiengʼ duto, 
\q2 kata obedo ni gingʼeny mohinga ngʼeyo. 
\q1  
\v 16 Abiro biro mondo anyis ji timbeni madongo, 
\q2 yaye Jehova Nyasaye Manyalo Gik Moko Duto; 
\q2 abiro nyiso ji timni makare, timni makare in kendi. 
\q1  
\v 17 Isepuonja nyaka aa e nyathi, yaye Nyasaye, 
\q2 kendo nyaka kawuono pod ahulo timbe miwuoro. 
\q1  
\v 18 Kata ka ochopo kinde ma ati kendo wiya oselokore lwar, 
\q2 to kik iweya, yaye Nyasaye, 
\q1 nyaka ahul tekoni ni tienge mabiro, 
\q2 kendo ahul timbeni madongo ni tienge duto mabiro. 
\b  
\q1  
\v 19 Timni makare ochopo nyaka ei kor polo, yaye Nyasaye, 
\q2 in misetimo gik madongo. 
\q2 En ngʼa ma dipim kodi, yaye Nyasaye? 
\q1  
\v 20 Kata obedo ni isemiyo aneno chandruok mathoth kendo malit, 
\q2 to pod ibiro miyo abed mangima kendo. 
\q1 Ibiro gola e bur matut 
\q2 mi achak abed gi duongʼ. 
\q1  
\v 21 Ibiro miyo duongʼ ma an-go medore 
\q2 kendo ibiro chako ihoya kendo. 
\b  
\q1  
\v 22 Abiro paki gi nyatiti 
\q2 nikech adiera mari, yaye Nyasaye; 
\q1 abiro weroni wend pak gi orutu, 
\q2 yaye Nyasaye Maler mar Israel. 
\q1  
\v 23 Abiro kok gi mor 
\q2 ka aweroni wend pak, 
\q2 nikech an ngʼat misewaro. 
\q1  
\v 24 Dhoga biro nyiso ji kuom timbeni makare 
\q2 odiechiengʼ duto, 
\q1 nimar joma ne dwaro hinya 
\q2 oseneno wichkuot kendo osengʼengʼ. 
\c 72  
\cl Zaburi 72 
\d Mar Solomon. 
\q1  
\v 1 Sidh ne ruoth adiera mari, yaye Nyasaye, 
\q2 sidh ne wuod ruoth timni makare. 
\q1  
\v 2 Obiro ngʼado ne jou bura makare, 
\q2 obiro kelo adiera ne jou masandore. 
\q1  
\v 3 Gode biro kelo mwandu ne ji, 
\q2 kendo thuche biro kelo olemb tim makare. 
\q1  
\v 4 Obiro chwako joma odhier manie dier ji 
\q2 kendo obiro reso nyithind joma ochando; 
\q2 to thiro ji, to obiro tieko pep. 
\q1  
\v 5 Obiro siko ka wangʼ chiengʼ, 
\q2 obiro siko ka dwe e tienge duto. 
\q1  
\v 6 Obiro chalo gi koth machwe e lum mongʼadi maber 
\q2 kendo gi kodh ajiki mamiyo piny ngʼich. 
\q1  
\v 7 E ndalone joma kare biro dhi maber, 
\q2 kendo kwe biro bedo mogundho nyaka chop dwe lal nono. 
\b  
\q1  
\v 8 Obiro bedo gi loch chakre nam nyaka nam 
\q2 kendo kochakore Aora maduongʼ nyaka kuma piny ogikie. 
\q1  
\v 9 Ogendini modak e piny ongoro biro kulorene 
\q2 kendo wasike biro nangʼo lowo gi dhogi. 
\q1  
\v 10 Ruodhi mag Tarshish kod mag dho nembe man maboyo 
\q2 biro miye gik moko, 
\q1 kendo ruodhi mag Sheba gi mag Seba 
\q2 biro kelone mich. 
\q1  
\v 11 Ruodhi duto biro kulorene 
\q2 kendo ogendini duto biro tiyone. 
\b  
\q1  
\v 12 Nimar obiro konyo joma ochando maywagore, 
\q2 jogo modhier maonge gi jakony. 
\q1  
\v 13 Obiro kecho joma ok nyal gi joma ochando 
\q2 kendo obiro reso ngima joma ochando. 
\q1  
\v 14 Obiro gologi e dich modigigo kendo e timbe mahundu, 
\q2 nimar okwano rembgi ka gima nengone tek. 
\b  
\q1  
\v 15 Mad odag amingʼa! 
\q2 Mad kelne dhahabu moa Sheba. 
\q1 Mad ji duto sik ka lamone 
\q2 kendo ka gwedhe odiechiengʼ duto. 
\q1  
\v 16 Mad cham bed mangʼeny e piny duto, 
\q2 bende gikwak nyaka wi godo matindo duto. 
\q1 Mad olembene ol mathoth ka Lebanon, 
\q2 kendo mad onyagi ka lum manie pap. 
\q1  
\v 17 Mad nyinge sik nyaka chiengʼ 
\q2 kendo mad odhi nyime ka wangʼ chiengʼ. 
\b  
\q1 Ogendini duto ibiro gwedhi gi gweth moa kuomi 
\q2 kendo gibiro luongi ni ngʼat mogwedhi. 
\b  
\b  
\q1  
\v 18 Jehova Nyasaye, ma Nyasach Israel, mondo oyud opak, 
\q2 en kende ema otimo gik miwuoro. 
\q1  
\v 19 Nyinge man-gi duongʼ mondo opaki nyaka chiengʼ 
\q2 kendo mad piny duto pongʼ gi duongʼne. 
\qc Amin kendo Amin. 
\b  
\b  
\q1  
\v 20 Ma e giko mag lamo mag Daudi Wuod Jesse. 
\c 73  
\ms1 Kitabu mar Adek 
\mr Zaburi 73–89 
\cl Zaburi 73 
\d Zaburi mar Asaf. 
\q1  
\v 1 Adier Nyasaye timo maber ni jo-Israel, 
\q2 otimo maber ne jogo maler ei chunygi. 
\b  
\q1  
\v 2 Anto tiendena nodwaro kier. 
\q2 Ne achiegni aa kama ne anyono. 
\q1  
\v 3 Nimar ne agombo timbe joma ochayo ji 
\q2 kane aneno kaka joma timbegi richo dhi maber. 
\b  
\q1  
\v 4 Gionge gi pek moro amora 
\q2 kendo dendgi ber kendo otegno. 
\q1  
\v 5 Chandruok mamako ji gin ok yudgi 
\q2 kendo ok githagre kaka ji mamoko thagore. 
\q1  
\v 6 Emomiyo sunga chalonegi thiwni mar ngʼut, 
\q2 kendo girwako mahundu ka law. 
\q1  
\v 7 Wengegi onyiedhore gi bor 
\q2 kendo miriambo maricho mopongʼo pachgi onge gikogi. 
\q1  
\v 8 Gijaro ji kendo giwuoyo ka gihimo ji, 
\q2 nikech gichayo ji gisiko gibwogo ji ni ji biro wuoro. 
\q1  
\v 9 Giwacho weche polo gi dhogi 
\q2 to lewgi to gimakogo mwandu mag piny. 
\q1  
\v 10 Emomiyo jogegi doknegi kendo pakogi 
\q2 kendo ok giyud rach moro amora kuomgi. 
\q1  
\v 11 Giwacho niya, “Ere kaka Nyasaye nyalo ngʼeyo? 
\q2 Nyasaye Man Malo Moloyo to ongʼeyo angʼo?” 
\b  
\q1  
\v 12 Kama e kaka joma timbegi richo chalo, 
\q2 ok gidew gimoro amora kendo mwandugi osiko medore ameda. 
\b  
\q1  
\v 13 Kare asetemo ritora mondo chunya osik kaler kayiem, 
\q2 kendo asetemo gengʼo lwetena ni kik omul richo kayiem. 
\q1  
\v 14 Nimar asiko achandora seche duto, 
\q2 kendo ayudo kum okinyi kokinyi. 
\b  
\q1  
\v 15 Ka dine bed ni awacho kamano, 
\q2 to dine andhogo nyithindi. 
\q1  
\v 16 To kane atemo winjo tiend gigi duto, 
\q2 to ne opek mohinga; 
\q1  
\v 17 nyaka ne adonjo kama ler mar lemo mar Nyasaye; 
\q2 eka nawinjo kaka gikogi nobedi. 
\b  
\q1  
\v 18 Chutho iketogi kama poth-poth, 
\q2 kendo idwokogi piny mi gikethre. 
\q1  
\v 19 Mano kaka itiekogi apoya nono, 
\q2 mi masiche malich lal kodgi nono! 
\q1  
\v 20 Gilal nono ka lek ma ngʼato oleko gokinyi, 
\q2 omiyo e kinde ma ia malo, yaye Ruoth Nyasaye, 
\q2 to ok ibi dewogi mana ka kido maonge. 
\b  
\q1  
\v 21 Kane iya owangʼ, 
\q2 kendo chunya winjo lit, 
\q1  
\v 22 to pacha nolal kendo ne abedo mofuwo, 
\q2 ne achalo le maonge rieko e nyimi. 
\b  
\q1  
\v 23 Kata kamano an kodi ndalo duto, 
\q2 kendo imaka gi bada korachwich. 
\q1  
\v 24 Itaya gi rieko mingʼadona 
\q2 kendo bangʼe ibiro tera kar duongʼ. 
\q1  
\v 25 En ngʼa ma an-go e polo makmana in? 
\q2 Piny bende onge gi gimoro amora madwaro moloyi. 
\q1  
\v 26 Ringra gi chunya nyalo doko manyap, 
\q2 to Nyasaye ema miyo chunya teko, 
\q2 kendo en e girkeni mara nyaka chiengʼ. 
\b  
\q1  
\v 27 Joma ni mabor kodi biro lal nono 
\q2 kendo ibiro tieko ji duto ma ok jo-adiera ne in. 
\q1  
\v 28 An to berna ka an but Nyasaye. 
\q2 Aseketo Jehova Nyasaye Manyalo Gik Moko Duto kar pondona, 
\q2 kendo abiro lando gik moko duto mitimo. 
\c 74  
\cl Zaburi 74 
\d \tl Maskil\tl*\f + \fr 74:0 \fl Maskil: \ft en kit wer moro mane Daudi owero\f* mar Asaf. 
\q1  
\v 1 Angʼo momiyo isedagiwa nyaka chiengʼ, yaye Nyasaye? 
\q2 Angʼo momiyo mirimbi dhwolore ka iro kochomo rombe mag lek mari iwuon? 
\q1  
\v 2 Par jogi mane ingʼiewo chon gi lala, 
\q2 oganda ma gin girkeni mari, kendo mane iwaro, 
\q2 Got Sayun, kama in iwuon idakie. 
\q1  
\v 3 Lokri ichom kuonde mosebedo kokethore nyaka nene, 
\q2 lokri ichom kethruok maduongʼ ma jasigu osekelo e kari maler mar lemo. 
\b  
\q1  
\v 4 Wasiki noruto kama iromoe kodwa; 
\q2 kendo negichungo bendechegi mochungʼ kar timbegi maricho. 
\q1  
\v 5 Negitimore marach mana ka ji mangʼawo leyegi malo 
\q2 ka gidwaro tongʼo yiende madongo dongo modongo modhigore. 
\q1  
\v 6 Negituro chumbe modol odol 
\q2 gi tindogi kod nyundogi. 
\q1  
\v 7 Ne giwangʼo kari maler mar lemo molokore buru, 
\q2 kendo ne gidwanyo kama nyingi dakie. 
\q1  
\v 8 Negiwacho e chunygi niya, “Wabiro tiekogi chuth!” 
\q2 Ne giwangʼo kuonde duto e piny mane ilame Nyasaye. 
\q1  
\v 9 Tinde ok wayud honni kata ranyisi, 
\q2 kendo onge jonabi modongʼ kata achiel, 
\q1 to onge kata ngʼato achiel kuomwa mongʼeyo 
\q2 ni mano biro bedo kamano nyaka karangʼo. 
\b  
\q1  
\v 10 Nyaka karangʼo ma jasigu biro jarie, yaye Nyasaye? 
\q2 Ibiro yiene jasigu mondo oyany nyingi nyaka chiengʼ koso? 
\q1  
\v 11 Angʼo momiyo itamo lweti tiyo tichne, 
\q2 mana lweti ma korachwich? 
\q2 Gole oko kama isoye ei lepi mondo itiekgi! 
\b  
\q1  
\v 12 To Nyasaye in e Ruodha nyaka chakre chon, yaye Nyasaye, 
\q2 kendo isebedo kikelo resruok e piny. 
\q1  
\v 13 In ema ne ipogo nam e diere ariyo gi tekoni, 
\q2 kendo ne itoyo wiye ondiek marach ei pi. 
\q1  
\v 14 In ema ne itoyo wiye Leviathan, 
\q2 mi ichiwe kaka chiemo ne le modak e thim. 
\q1  
\v 15 In ema ne iyawo sokni gi aore, 
\q2 kendo ne imiyo aore madongo ma ok dwon otwo. 
\q1  
\v 16 Odiechiengʼ en mari, kendo otieno bende mari, 
\q2 bende ne iguro wangʼ chiengʼ gi dwe keregi. 
\q1  
\v 17 In ema ne iketo tongʼ duto mag piny 
\q2 kende ne iguro oro gi chwiri. 
\b  
\q1  
\v 18 Parie kaka jasigu osejari, yaye Jehova Nyasaye. 
\q2 Parie kaka joma onge rieko osechayo nyingi. 
\q1  
\v 19 Kik iyie ichiw ngima mar akuch oduglani ne le mager mag bungu; 
\q2 kik wiyi wil gi ngima jogi mathagore nyaka chiengʼ. 
\q1  
\v 20 Par singruok mari 
\q2 nikech timbe mahundu opongʼo kuonde duto motimo mudho e piny. 
\q1  
\v 21 Kik iyie mondo joma idiyo ringa ka wigi okuot, 
\q2 to mad joma odhier gi joma ochando opak nyingi. 
\b  
\q1  
\v 22 Aa malo mondo isir tichni, yaye Nyasaye; 
\q2 parie kaka joma ofuwo jari odiechiengʼ duto. 
\q1  
\v 23 Kik wiyi wil gi sibuoch wasiki, 
\q2 chom tir sigich wasiki mosiko medore ameda. 
\c 75  
\cl Zaburi 75 
\d Kuom jatend wer. E dwol mar “Kik iketh gik moko.” Zaburi mar Asaf. Wer. 
\q1  
\v 1 Wagoyoni erokamano, yaye Nyasaye, 
\q2 wagoyoni erokamano nimar Nyingi ni machiegni, 
\q2 kendo ji lando timbeni miwuoro. 
\b  
\q1  
\v 2 Iwacho niya, “An ema ayiero ndalo mowinjore, 
\q2 kendo an ema angʼado bura kare. 
\q1  
\v 3 Ka piny kaachiel gi ji duto modakie yiengni, 
\q2 to an ema amako sirnige motegno. \qs Sela\qs*\f + \fr 75:3 \fq Sela \ft tiend wachni ok ongʼere.\f* 
\q1  
\v 4 Joma ochecho akwero ni, ‘Weuru sungoru,’ 
\q2 to joma timbegi richo to okwero niya, 
\q2 ‘Weuru tingʼo tungeu malo. 
\q1  
\v 5 Weuru sungoru ni un gi teko, 
\q2 kendo kuwuoyo kududo ngʼutu.’ ” 
\b  
\q1  
\v 6 Nimar duongʼ ok nyal medore ne ngʼato 
\q2 koa wuok chiengʼ kata podho chiengʼ kata e thim. 
\q1  
\v 7 To Nyasaye ma jangʼad bura ema dwoko ngʼato piny, 
\q2 kendo tingʼo ngʼat machielo malo. 
\q1  
\v 8 Nitiere kikombe mopongʼ gi divai mochiek e lwet Jehova Nyasaye 
\q2 en kikombe mopongʼ gi divai mokik gi apilo, 
\q1 Nyasaye ole oko, to joma timbegi richo duto manie piny 
\q2 madhe duto pep nyaka ngʼiende. 
\b  
\q1  
\v 9 An to abiro siko ka alando wachni nyaka chiengʼ 
\q2 kendo abiro wero wende pak ne Nyasach Jakobo, 
\q1  
\v 10 mawacho niya, “Abiro ngʼado oko tunge joma timbegi richo duto, 
\q2 to tunge joma kare to ibiro tingʼ malo.” 
\c 76  
\cl Zaburi 76 
\d Kuom jatend wer. Gi gig wer man-gi tondegi. Zaburi mar Asaf. Wer. 
\q1  
\v 1 Nyasaye en rahuma e piny Juda, 
\q2 kendo nyinge duongʼ e piny Israel. 
\q1  
\v 2 Hembe nitie Salem 
\q2 kar dakne ni Sayun. 
\q1  
\v 3 Kanyo ema e oturoe aserni makakni, 
\q2 kaachiel gi okumbni gi ligengni, ma gin gig lweny. \qs Sela\qs* 
\b  
\q1  
\v 4 Duongʼ mari ler okwako 
\q2 kendo iyombo gode momew gi kit le mayoreyore. 
\q1  
\v 5 Yawuowi madongo mojingʼ osema gik mane giyako 
\q2 koro ginindo nindogi mogik; 
\q1 kendo onge jolwenygo kata achiel, 
\q2 manyalo tingʼo kata mana bade. 
\q1  
\v 6 Nikech kwer misekwerogigo, yaye Nyasach Jakobo 
\q2 omiyo faras gi gari moywayo ochungʼ kar tiendegi. 
\b  
\q1  
\v 7 In kendi ema onego oluori. 
\q2 Koso en ngʼa manyalo chungʼ e nyimi ka mirima omaki? 
\q1  
\v 8 Ne ingʼado bura gie polo, 
\q2 mi piny ne luoro omako molingʼ thi. 
\q1  
\v 9 Kane ia malo mondo ingʼad bura, yaye Nyasaye, 
\q2 mondo ikony ji duto mawinjo marach e piny. \qs Sela\qs* 
\q1  
\v 10 Kuom adier, mirima ma in-go gi ji, keloni pak, 
\q2 kendo miyo joma otony ne mirimbi ritore. 
\b  
\q1  
\v 11 Singri ne Jehova Nyasaye ma Nyasachi, 
\q2 kendo chop singruokgo; 
\q1 bende jopinje duto mokiewo kodi, 
\q2 okel mich ne Jal monego ji luor. 
\q1  
\v 12 Ochodo chuny jotelo, 
\q2 kendo ruodhi duto mag piny oluore. 
\c 77  
\cl Zaburi 77 
\d Kuom jatend wer. Ne Jeduthun. Mar Asaf. Zaburi. 
\q1  
\v 1 Ne aywak ni Nyasaye mondo okonya, 
\q2 kendo ne aywak ni Nyasaye mondo owinja. 
\q1  
\v 2 Kane an e chandruok, ne amanyo Ruoth Nyasaye; 
\q2 otieno duto ne arieyo bedena malo ma ok aol, 
\q2 kendo chunya nodagi hoch. 
\b  
\q1  
\v 3 Ne apari mine ahum, yaye Nyasaye, 
\q2 ne aol kendo chunya nonyosore. \qs Sela\qs* 
\q1  
\v 4 Ne imako wengena mi ok oimore, 
\q2 kendo ne an gi pek ma ok anyal wuoyo. 
\q1  
\v 5 Ne aparo kuom ndalo machon, 
\q2 higni machon gi lala; 
\q1  
\v 6 ne aparo wendena mag otieno. 
\q2 Ne aloso gi pacha awuon, kendo chunya nopenjo kama: 
\b  
\q1  
\v 7 “Bende Ruoth Nyasaye nyalo dagi ngʼato chuth? 
\q2 Bende en adier ni ok obi ochak ongʼwon kendo? 
\q1  
\v 8 Bende herane ma ok rem dirum chuth adier? 
\q2 Bende singruokne nyalo bare ma ok ochopo nyaka chiengʼ? 
\q1  
\v 9 Dibed ni Nyasaye wiye osewil gi kecho ji? 
\q2 Koso mirimbe mager osemiyo ok okech joge?” \qs Sela\qs* 
\b  
\q1  
\v 10 Eka naparo niya, “Ma e kama abiro kwayoe kony: 
\q2 higni ma lwet Nyasaye Man Malo Moloyo ma korachwich osetieko. 
\q1  
\v 11 Abiro siko kaparo timbe Jehova Nyasaye; 
\q2 ee, abiro paro kuom honni magi machon gi lala. 
\q1  
\v 12 Abiro paro mos kuom tijeni duto, 
\q2 abiro paro matut kuom timbeni madongo duto.” 
\b  
\q1  
\v 13 Yoreni ler, yaye Nyasaye. 
\q2 En nyasaye mane maduongʼ kaka Nyasachwa? 
\q1  
\v 14 In e Nyasaye matimo honni, 
\q2 inyiso tekoni e dier ji mopogore opogore. 
\q1  
\v 15 Ne iwaro jogi gi badi maratego, 
\q2 jogi ma nyikwa Jakobo gi Josef. \qs Sela\qs* 
\b  
\q1  
\v 16 Pige noneni, yaye Nyasaye, 
\q2 pige noneni mi luoro omakogi, 
\q2 kendo kude matut notetni. 
\q1  
\v 17 Boche polo ne oolo pi piny, 
\q2 kendo polo nomor e kor polo, 
\q2 ka asernigi mil koni gi koni. 
\q1  
\v 18 Mor polo mari nowinji ei yamo mager, 
\q2 mil polo mari nomenyo piny duto, 
\q2 kendo piny notetni kendo oyiengni. 
\q1  
\v 19 Yori nongʼado dier nam, 
\q2 yo miluwo nokadho e dier pige maringo matek, 
\q2 kata obedo ni kuonde mane tiendeni onyono ne ok nyal ne gi wangʼ. 
\b  
\q1  
\v 20 Ne itelone jogi ka rombe 
\q2 ka gin e lwet Musa gi Harun. 
\c 78  
\cl Zaburi 78 
\d \tl Maskil\tl*\f + \fr 78:0 \fl Maskil: \ft en kit wer moro mane Daudi owero\f* mar Asaf. 
\q1  
\v 1 Chiknauru itu, yaye un joga, 
\q2 winjuru weche mawuok e dhoga. 
\q1  
\v 2 Abiro yawo dhoga mondo awuo gi ngeche, 
\q2 ee, abiro hulo gik mopondo ma wuoyo kuom gik mane otimore chon gi lala. 
\q1  
\v 3 Gik ma wasewinjo kendo ma wangʼeyo, 
\q2 mane wuonewa onyisowa. 
\q1  
\v 4 Ok wabi pandogi ne nyithindgi; 
\q2 to wabiro hulogi ne tiengʼ mabiro timbe mipako mag Jehova Nyasaye, 
\q2 gi tekone kod gik miwuoro mosetimo. 
\q1  
\v 5 Ne ogolo chike ne joka Jakobo 
\q2 kendo noguro chik e piny Israel, 
\q1 chike mane omiyo kwerewa 
\q2 mondo opuonj nyithindgi, 
\q1  
\v 6 mondo tiengʼ mabiro ongʼegi, 
\q2 koda ka nyithindo mapok onywol, 
\q2 kendo gin bende ginyis nyithindgi. 
\q1  
\v 7 Eka mondo mi giket genogi kuom Nyasaye 
\q2 kendo kik wigi wil gi gik mosetimo, 
\q2 to mondo girit chikene. 
\q1  
\v 8 Ne ok ginyal chalo gi kweregi; 
\q2 mane tiengʼ ma tokgi tek kendo ma jongʼanyo, 
\q1 ma chunjegi ne ok ochiwore ne Nyasaye 
\q2 kendo ne ok luwe gi adiera. 
\b  
\q1  
\v 9 Kata ka jo-Efraim nomanore gi gige lweny, 
\q2 to negiringo lweny. 
\q1  
\v 10 Ne ok girito singruok mar Nyasaye 
\q2 kendo ne gidagi dak ka giluwo chik Nyasaye. 
\q1  
\v 11 Wigi nowil gi gik mane osetimo, 
\q2 ranyisi mane osenyisogi. 
\q1  
\v 12 Ne otimo honni ka wuonegi neno 
\q2 e gwengʼ mar Zoan, e piny Misri. 
\q1  
\v 13 Ne omiyo nam opogore diere ariyo mi nomiyo gikadho 
\q2 kendo nomiyo pi ochungʼ molingʼ thi ka ohinga. 
\q1  
\v 14 Ne otayogi kod bor polo godiechiengʼ 
\q2 kendo giler moa e mach otieno duto. 
\q1  
\v 15 Ne otucho lwanda e thim 
\q2 kendo nomiyogi pi mogundho ka nembe; 
\q1  
\v 16 bende nomiyo aore obubni kawuok e lwanda kama obarore 
\q2 mi pi nomol piny mana ka aora. 
\b  
\q1  
\v 17 To eka pod negidhi mana nyime ka gitimo richo e nyime 
\q2 ka gingʼanyo e thim ne Nyasaye Man Malo Moloyo. 
\q1  
\v 18 Ne gitemo Nyasaye ka gingʼeyo, 
\q2 kuom kete mondo omigi chiemo mane gigombo. 
\q1  
\v 19 Ne giwuoyo marach kuom Nyasaye kagiwacho ni, 
\q2 “Nyasaye bende nyalo chano mesa e nyimwa e thim ka? 
\q1  
\v 20 Kane ogoyo lwanda to pi nothinyore oko 
\q2 kendo aore nochako mol mogundho. 
\q1 To chiemo bende domiwa adier? 
\q2 Ringʼo bende onyalo kelo mi opog ne joge adier?” 
\q1  
\v 21 Kane Jehova Nyasaye owinjo gi ite, iye nowangʼ ahinya, 
\q2 mi mach mare notuk kuom joka Jakobo, 
\q2 kendo mirimbe mager nobiro kuom jo-Israel, 
\q1  
\v 22 nimar ne ok giyie kuom Nyasaye 
\q2 kata geno kuom resruok mare. 
\q1  
\v 23 To eka pod nogolo chik ne kor polo malo 
\q2 kendo noyawo dhoudi mag polo; 
\q1  
\v 24 ne oolo mana piny ka koth mondo ji ocham, 
\q2 adier, nomiyogi chiemb polo. 
\q1  
\v 25 Ji nochamo makati mar malaike, 
\q2 kendo nooronegi kit chiemo duto mane ginyalo chamo. 
\q1  
\v 26 Ne ogonyo yamb ugwe moa e polo, 
\q2 kendo nogolo yamb milambo gi tekone. 
\q1  
\v 27 Nolwaro ringʼo piny kuomgi ka buru, adier, 
\q2 winy mafuyo nolwar kuomgi ka kwoyo manie dho nam. 
\q1  
\v 28 Nomiyo winyogo olwar piny nyaka ei kambi 
\q2 mine gilworo hembegi duto koni gi koni. 
\q1  
\v 29 Negichiemo mi chiemo otamogi tieko, 
\q2 nimar nomiyogi gima ne chunygi gombo. 
\q1  
\v 30 To kane pok gitieko chiembgi mar gombono, 
\q2 chutho, ka chiemo ne pod opongʼo dhogi, 
\q1  
\v 31 mirima mager mar Nyasaye nogore kuomgi, 
\q2 mi nomiyo jogi maroteke otho, 
\q2 kendo nopielo yawuot Israel ma pod tindo piny. 
\b  
\q1  
\v 32 To kata obedo ni magi duto nosetimore, 
\q2 pod negidhi mana nyime gitimo richo; 
\q1 pod ne ok giyie kuome, 
\q2 kata obedo ni ne osetimo ranyisi mathoth e diergi. 
\q1  
\v 33 Omiyo nomiyo ngimagi orumo kaonge ber 
\q2 kendo higni mag-gi nopongʼ gi masiche mabwogo ji. 
\q1  
\v 34 E kinde moro amora mane Nyasaye okumogie, to ne gimanye 
\q2 mine gilokore ka gidware gi siso. 
\q1  
\v 35 Negiparo ni Nyasaye ema ne en lwanda margi, 
\q2 kendo ni Nyasaye Man Malo Moloyo ema ne en Jawargi. 
\q1  
\v 36 To kata kamano ne gichare achara gi dhogi, 
\q2 ka giwuonde gi lewgi. 
\q1  
\v 37 Nimar chunygi ne ok omoko kuome, 
\q2 kendo ne ok gilu singruokne kuom adier. 
\q1  
\v 38 To en, kaka en ngʼama kecho ji, 
\q2 noweyonegi kethogi, 
\q2 kendo ne ok otiekogi. 
\q1 Kinde ka kinde nogengʼo mirimbe 
\q2 kendo ne ok otoyo mirimbe duto kuomgi. 
\q1  
\v 39 Noparo kaka ne gin mana dhano adhana 
\q2 machalo yamo makalo kendo ok chak duogi. 
\b  
\q1  
\v 40 Mano kaka ne gingʼanyone e thim nyadi mangʼeny 
\q2 kendo negimiye chuny lit e piny motwo! 
\q1  
\v 41 Ne gitemo Nyasaye kinde mangʼeny, 
\q2 kendo negimiyo Jal Maler mar Israel osin. 
\q1  
\v 42 Ne ok giparo tekone, 
\q2 kendo ne ok giparo odiechiengʼ mane owarogi e lwet jasigu, 
\q1  
\v 43 odiechiengʼ mane onyiso e lela honni mage e piny Misri 
\q2 kane otimo ranyisino e gwengʼ mar Zoan. 
\q1  
\v 44 Noloko aoregi remo mi koro 
\q2 ne ok ginyal modho pi moa e aoregi. 
\q1  
\v 45 Ne ooro bonyo mag lwangʼni mane omwonyogi, 
\q2 gi ogwende mane oketho pinygi. 
\q1  
\v 46 Ne ochiwo chambgi ne ongogo, 
\q2 chambgi mosechiek ne bonyo. 
\q1  
\v 47 Ne oketho olembegi mag mzabibu gi pe, 
\q2 kod yiendegi mag ngʼowu gi yamo mangʼich. 
\q1  
\v 48 Ne ochiwo jambgi ne pe, 
\q2 kendo nomiyo dhogegi polo ogoyo. 
\q1  
\v 49 Ne oolo kuomgi mirimbe maliet, 
\q2 kokecho kendo iye owangʼ kendo oger; 
\q2 oganda malaike ma jonek. 
\q1  
\v 50 Ne olosone mirimbe yo maluwo, 
\q2 kendo ne ok okechogi e tho, to ne ojwangʼogi, 
\q2 mondo tho otiekgi. 
\q1  
\v 51 Ne onego kach jo-Misri duto, 
\q2 mana olemo mokwongo chiek mag dhano e hembe mag Ham. 
\q1  
\v 52 To joge to nogolo oko mana ka kweth, 
\q2 kendo notelonegi ka rombe koyoro kodgi thim. 
\q1  
\v 53 Ne otayogi maber omiyo ne gionge gi luoro, 
\q2 to wasikgi to ne nam omwonyo. 
\q1  
\v 54 Kamano e kaka ne okelogi nyaka e tongʼ mar pinje maler, 
\q2 nyaka ne gitundo e piny motimo gode, 
\q2 ma lwete ma korachwich nosekawo. 
\q1  
\v 55 Ne oriembo ogendini e nyimgi 
\q2 kendo nomiyogi lopgi kaka girkeni margi, 
\q2 mi nomiyo dhout Israel odak e miechgi giwegi. 
\b  
\q1  
\v 56 To kata kamano ne gitemo Nyasaye, 
\q2 mine gingʼanyone Nyasaye Man Malo Moloyo; 
\q2 ka gidagi rito chikene. 
\q1  
\v 57 Mana kaka wuonegi ne ok giwinje kendo ne ok gin jo-adiera 
\q2 kendo ne gichalo atungʼ mobam ma ok nyal gen. 
\q1  
\v 58 Ne giwangʼo iye gi kuondegi motingʼore malo, 
\q2 kendo ne gichiewo nyiego mare gi nyisechegi mane giloso. 
\q1  
\v 59 Kane Nyasaye owinjogi, iye nowangʼ ahinya, 
\q2 kendo nokwedo jo-Israel chuth. 
\q1  
\v 60 Ne ojwangʼo Hemb Romo mane ni Shilo, 
\q2 mane en hema mane oguro owuon e dier ji. 
\q1  
\v 61 Nooro Sandug Muma e twech, 
\q2 mi duongʼne maler nodhi e lwet wasigu. 
\q1  
\v 62 Nochiwo joge ne ligangla, 
\q2 kendo nokecho ahinya gi girkeni mare. 
\q1  
\v 63 Mach notieko yawuotgi matindo, 
\q2 kendo nyigi ne ok owernegi wende kisera; 
\q1  
\v 64 jodologi ne onegi, 
\q2 kendo mondegi ne ywak otamo. 
\b  
\q1  
\v 65 Eka Ruoth Nyasaye nochiew ka gima oa e nindo, 
\q2 mana kaka ngʼato chiewo, bangʼ madho divai mangʼeny. 
\q1  
\v 66 Ne oriembo wasike gi goch, 
\q2 kendo nomiyo giyudo wichkuot mosiko. 
\q1  
\v 67 Ne odagi hembe mag Josef, 
\q2 bende ne ok oyiero dhood joka Efraim, 
\q1  
\v 68 to dhood joka Juda ema ne oyiero, 
\q2 ee, noyiero mana Got Sayun, mane ohero. 
\q1  
\v 69 Ne ogero kare maler mar lemo, ka gode maboyo, 
\q2 kendo mana ka piny mane oguro nyaka chiengʼ. 
\q1  
\v 70 Ne oyiero Daudi jatichne, 
\q2 kendo nogole e abich rombe; 
\q1  
\v 71 nogole e tij rito rombe mokele 
\q2 mondo okwa joge ma nyikwa Jakobo, 
\q2 mondo okwa Israel girkeni mare. 
\q1  
\v 72 Kuom mano Daudi nokwayogi gi chuny makare 
\q2 kendo notelonegi, gi lwedo mongʼith. 
\c 79  
\cl Zaburi 79 
\d Zaburi mar Asaf. 
\q1  
\v 1 Yaye Nyasaye, ogendini osemonjo girkeni mari; 
\q2 gisedwanyo hekalu mari maler, 
\q2 kendo giseketho Jerusalem modongʼ pidhe pidhe. 
\q1  
\v 2 Gisechiwo ringre jogi motho 
\q2 mondo obed chiemb winy manie kor polo, 
\q2 ring jogi maler gisechiwo ne ondiegi mag piny. 
\q1  
\v 3 Giseolo remo 
\q2 e alwora mar Jerusalem ka pi, 
\q2 kendo koro onge ngʼama nyalo yiko joma otho. 
\q1  
\v 4 Waselokore gima kuodo wich ne jobutwa, 
\q2 joma ijaro kendo inyiero gi joma olworowa. 
\b  
\q1  
\v 5 Nyaka karangʼo, yaye Jehova Nyasaye? Ibiro kecho nyaka chiengʼ koso? 
\q2 Nyaka karangʼo ma nyiego mari biro lielie ka mach? 
\q1  
\v 6 Ol mirimbi kuom pinjeruodhi, 
\q1 adier ol mirimbi kuom ogendini 
\q2 ma ok luong nyingi; 
\q1  
\v 7 nimar gisengamo Jakobo 
\q2 mi giketho gwengʼe. 
\q1  
\v 8 Kik ikwanwa kaka joketho, 
\q2 nikech richo mag wuonewa; 
\q1 mad kechni bi romnwa piyo, 
\q2 nimar osedwokwa piny marach. 
\b  
\q1  
\v 9 Konywa, yaye Nyasaye ma Jawarwa, 
\q2 nikech duongʼ mar nyingi; 
\q1 reswa kendo wenwa richowa, 
\q2 mondo nyingi oyud duongʼ. 
\q1  
\v 10 Angʼo momiyo ogendini onego owach ni, 
\q2 “Nyasachgino to ni kanye?” 
\b  
\q1 Mi ogendini ongʼe, ka waneno gi wangʼwa, 
\q2 ni ichulo kuor nikech remb jogi mosechwer. 
\q1  
\v 11 Mad chur ma joma otwe churgo chopi e nyimi; 
\q2 rit ngima joma osengʼad nigi buch tho, 
\q2 gi teko mar badi. 
\q1  
\v 12 Chul kuor ne jobutwa nyadibiriyo kigoyo bembegi. 
\q2 Kuom ayany ma gisediro kuomi, yaye Jehova Nyasaye. 
\q1  
\v 13 Eka jogi, ma gin rombegi mikwayo, 
\q2 biro paki nyaka chiengʼ, 
\q1 kendo wabiro nyiso pakni, 
\q2 koa e tiengʼ moro nyaka tiengʼ machielo. 
\c 80  
\cl Zaburi 80 
\d Kuom jatend wer. E dwol mar “Ondanyo mar Singruok.” Mar Asaf. Zaburi. 
\q1  
\v 1 Chiknwa iti, yaye Jakwadh jo-Israel, 
\q2 in mitelo ne Josef ka kweth mar dhok. 
\q1 In mibet e kom loch e kind kerubi, 
\q2 koro rieny ane  
\v 2 e nyim Efraim, gi Benjamin gi Manase. 
\q2 Nyis tekri, 
\q2 kendo bi mondo ireswa. 
\b  
\q1  
\v 3 Dwogwa iri, yaye Nyasaye; 
\q2 mi wangʼi orienynwa, 
\q2 eka mondo wayud warruok. 
\b  
\q1  
\v 4 Yaye Jehova Nyasaye, ma Nyasaye Maratego, 
\q2 mirimbi biro siko koyienyo, 
\q2 gi lamo mar jogi nyaka karangʼo? 
\q1  
\v 5 Isemiyo gichamo pi wangʼ ka kuon 
\q2 kendo isemiyo gimodho pi wangʼ agwetni modhuro. 
\q1  
\v 6 Isemiyo wadoko rachwany ne jobutwa, 
\q2 kendo wasikwa jarowa. 
\b  
\q1  
\v 7 Dwogwa iri, yaye Nyasaye Maratego; 
\q2 mi wangʼi orienynwa, eka mondo wayud warruok. 
\b  
\q1  
\v 8 Ne igolo mzabibu moro e piny Misri, 
\q2 kendo ne iriembo ogendini mi ipidhe kargi. 
\q1  
\v 9 Ne ilosone lowo maber, 
\q2 kendo nochwoyo tiendene piny mi opongʼo piny. 
\q1  
\v 10 Tipo Nyasaye noimo gode duto, 
\q2 mana ka yiende sida ma odongo ma bedene olak. 
\q1  
\v 11 Noyaro bedene madongo nyaka e Nam Mediterania 
\q2 kendo noloth mochweyo nyaka e Aora Yufrate. 
\b  
\q1  
\v 12 Koro angʼo momiyo isemuko ohinga mage, 
\q2 momiyo ji duto makadho pone ka olemo. 
\q1  
\v 13 Mbithe moa e bungu kethe, kendo le mag bungu chame. 
\q1  
\v 14 Duog irwa, yaye Nyasaye Maratego! 
\q2 Ngʼi piny gie polo mondo ine! 
\q1 Ngʼi mzabibu maber, 
\q2  
\v 15 yien ma lweti ma korachwich ema nopidho gi tiende, 
\q2 ma en wuodi misepidho in iwuon. 
\b  
\q1  
\v 16 Mzabibu mari osetongʼ mi owangʼ gi mach, 
\q2 jogi lal nono nikech isekwerogi. 
\q1  
\v 17 Mad lweti bed kuom ngʼat mobet e bathi korachwich, 
\q2 ma en wuod dhano misemiyo teko in iwuon. 
\q1  
\v 18 Eka ok wanachak walokre waweyi; 
\q2 konywa wabed mangima, kendo wabiro pako nyingi. 
\b  
\q1  
\v 19 Dwogwa iri, yaye Jehova Nyasaye, ma Nyasaye Maratego; 
\q2 mi wangʼi orienynwa, 
\q2 eka mondo wayud warruok. 
\c 81  
\cl Zaburi 81 
\d Kuom jatend wer. Wer mower kaluwore gi \tl Gitith\tl*\f + \fr 81:0 \fl Gitith: \ft Ochalo ni en kit wer moro\f*. Mar Asaf. 
\q1  
\v 1 Weruru matek gi mor ne Nyasaye mamiyowa teko, 
\q2 gouru koko matek ne Nyasach Jakobo! 
\q1  
\v 2 Chakuru wer, yiekuru oyieke; 
\q2 gweluru nyatiti gi asili mamit. 
\b  
\q1  
\v 3 Gouru tung im ka dwe manyien ochakore, 
\q2 ma en ka dwe osetegno, e odiechiengʼ mar Nyasiwa mogen. 
\q1  
\v 4 Ma en gima ochuno jo-Israel; 
\q2 chik ma Nyasach Jakobo nogolo. 
\q1  
\v 5 Kane Nyasaye mirima omako gi jo-Misri, 
\q2 to ne ogure kaka chik ne Josef. 
\b  
\q1 Ne awinjo dwol ma ok angʼeyo kuma oaye kawacho kama: 
\b  
\q1  
\v 6 “Ne agolo tingʼ mapek e gokgi, 
\q2 mi lwetgi nogony e tingʼo atonge. 
\q1  
\v 7 Ne iluongo ka in e chandruok mi akonyi, 
\q2 ne adwoki gi ei boche polo, 
\q2 kendo ne atemi e tie pige mag Meriba. \qs Sela\qs* 
\b  
\q1  
\v 8 “Winjuru wach, yaye joga, to abiro siemou, 
\q2 abiro siemou ka uikoru mar winja, yaye Israel. 
\q1  
\v 9 Kik ubed gi nyasaye ma wendo e dieru, 
\q2 kendo kik ukulru ne nyasaye ma ukia. 
\q1  
\v 10 An Jehova Nyasaye, ma Nyasachu, mane ogolou Misri. 
\q2 Ngʼamuru dhou malach mondo apongʼe. 
\b  
\q1  
\v 11 “To joga nodagi winjo dwonda 
\q2 kendo Israel nodagi timo kaka achikogi. 
\q1  
\v 12 Omiyo ne aweyogi nikech chunygi ne tek, 
\q2 kendo negiluwo yoregi giwegi. 
\b  
\q1  
\v 13 “Ka dine joga yie winja, 
\q2 ka dine Israel yie lu yorena, 
\q1  
\v 14 mano kaka dine atieko wasikgi piyo piyo 
\q2 kendo dine agoyo joma kedo kodgi gi lweta! 
\q1  
\v 15 Joma ochayo Jehova Nyasaye dine okulorene gi luoro, 
\q2 kendo kum margi osiko nyaka chiengʼ. 
\q1  
\v 16 To un dine apidhou gi ngano maber mogik, 
\q2 kendo dine aromou gi mor kich ma athodho e lwanda.” 
\c 82  
\cl Zaburi 82 
\d Zaburi mar Asaf. 
\q1  
\v 1 Nyasaye osekawo kare e dier chokruok maduongʼ, 
\q2 ongʼado bura e kind “nyiseche.” 
\b  
\q1  
\v 2 Nyaka karangʼo ma ubiro dhi nyime ka udewo wangʼ joma ok timbegi nikare 
\q2 kendo kudewo wangʼ joma timbegi richo? \qs Sela\qs* 
\q1  
\v 3 Ngʼaduru bura makare ne joma ok nyal kod nyithi kiye, 
\q2 kendo konyuru joma odhier kod joma ok nyal konyore kendgi. 
\q1  
\v 4 Resuru joma ok nyal kod joma ochando; 
\q2 golgiuru e lwet joma timbegi richo. 
\b  
\q1  
\v 5 To gisesiko ka gimemore kendo onge gima gingʼeyo. 
\q2 Giwuotho koni gi koni e mudho; 
\q2 kendo gimiyo mise duto mag piny yiengni. 
\b  
\q1  
\v 6 “Asenyisou ni, ‘Un “nyiseche;” 
\q2 kendo ni un duto un yawuot Nyasaye Man Malo Moloyo.’ 
\q1  
\v 7 To ubiro tho ka ji ajia; 
\q2 adier ubiro podho mana kaka jatelo moro amora ma ok otangʼ.” 
\b  
\q1  
\v 8 Aa malo, yaye Nyasaye, ngʼadni piny bura, 
\q2 nimar ogendini duto gin girkeni magi. 
\c 83  
\cl Zaburi 83 
\d Wer. Zaburi mar Asaf. 
\q1  
\v 1 Kik ilingʼ, yaye Nyasaye; 
\q2 kik iywe, yaye Nyasaye, bende kik ibed mos. 
\q1  
\v 2 Neye kaka wasiki piem kodi gi koko maduongʼ. 
\q2 Neye kaka joma kedo kodi ngʼanyoni. 
\q1  
\v 3 Gichano timo ne jogi marach lingʼ-lingʼ; 
\q2 giloso chenro maricho ne joma chunyi ohero. 
\q1  
\v 4 Giwacho niya, “Biuru watiekgi mi girum pep kaka oganda, 
\q2 mondo nying mar Israel kik chak par kendo.” 
\b  
\q1  
\v 5 Giloso chenro ka giriwo pachgi bedo achiel, 
\q2 gilosoni riwruok mondo giked kodi. 
\q1  
\v 6 Gin jo-Edom gi jo-Ishmael, jo-Moab gi jo-Hagri, 
\q1  
\v 7 jo-Gebal, jo-Amon kod jo-Amalek, 
\q2 jo-Filistia kaachiel gi joma odak Turo. 
\q1  
\v 8 Nyaka jo-Asuria bende oseriwore kodgi 
\q2 mondo oriw lwetgi ne nyikwa Lut. \qs Sela\qs* 
\b  
\q1  
\v 9 Timnegi kaka ne itimo ne Midian, 
\q2 mana kaka nitimo ne Sisera gi Jabin e Aora Kishon, 
\q1  
\v 10 mane jotho Endor 
\q2 modoko owuoyo mar dhok e lowo. 
\q1  
\v 11 Mi jogi momew ochal gi Oreb kod Zeb 
\q2 mi ruodhigi duto chal gi Zeba kod Zalmuna, 
\q1  
\v 12 mane jowacho niya, 
\q2 “Wakawuru pewe mag kwath mag Nyasaye mondo obed marwa.” 
\b  
\q1  
\v 13 Mi gichal gi buya mayot-yot, yaye Nyasacha, 
\q2 mi gichal gi mihudhwe ma yamo tero. 
\q1  
\v 14 Mana kaka mach wangʼo bungu maduongʼ 
\q2 kata kaka mach wangʼo wi got, 
\q1  
\v 15 e kaka in bende ilawgi gi ahiti maduongʼ 
\q2 kendo ibwog-gi gi yambi makudho matek. 
\q1  
\v 16 Pongʼ wengegi gi wichkuot 
\q2 mondo ji omany nyingi, yaye Jehova Nyasaye. 
\b  
\q1  
\v 17 Mad wigi kuodi nyaka chiengʼ kendo gisiki ka luoro omakogi; 
\q2 mad gilal nono ka gin gi wichkuot. 
\q1  
\v 18 Mi gingʼe ni in, ma nyingi Jehova Nyasaye; 
\q2 ni in kendi e Nyasaye Man Malo Moloyo kendo ni iloyo piny duto. 
\c 84  
\cl Zaburi 84 
\d Kuom jatend wer. Kaluwore gi \tl gitith\tl*\f + \fr 84:0 \fl Gitith: \ft Ochalo ni en kit wer moro\f*. Zaburi mar Yawuot Kora. 
\q1  
\v 1 Mano kaka hekalu mari ber miwuoro, 
\q2 yaye Jehova Nyasaye Maratego! 
\q1  
\v 2 Chunya gombo kendo njawni 
\q2 ka agombo bedo e od Jehova Nyasaye; 
\q1 Chunya gi denda duto wer gi mor 
\q2 ne Nyasaye mangima. 
\b  
\q1  
\v 3 Nyaka winj oyundi oseloso kar dakne, 
\q2 kendo opija bende osegero ode, 
\q2 kama onyalo nywole nyithinde, 
\q1 but kendoni mar misango, 
\q2 yaye Jehova Nyasaye Maratego, 
\q2 ma Ruodha kendo Nyasacha. 
\q1  
\v 4 Ogwedh joma odak e odi; 
\q2 mosiko ka paki. \qs Sela\qs* 
\b  
\q1  
\v 5 Ogwedh joma tekregi ni kuomi 
\q2 jogo moketo chunygi e luwo yori maler. 
\q1  
\v 6 Ka gikadho e Holo mar Baka 
\q2 to gimiyo obedo kama opongʼ gi sokni; 
\q2 kendo kodh opon bende pongʼe gi yewni. 
\q1  
\v 7 Tekreni osiko medore ameda, 
\q2 nyaka chop moro ka moro kuomgi chop Sayun e nyim Nyasaye. 
\b  
\q1  
\v 8 Yie iwinj lemona, yaye Jehova Nyasaye, ma Nyasaye Maratego; 
\q2 chikna iti, yaye Nyasach Jakobo. \qs Sela\qs* 
\q1  
\v 9 Tingʼ wangʼi ine okumbawa, yaye Nyasaye; 
\q2 rang ngʼati miwiro gi ngʼwono. 
\b  
\q1  
\v 10 Bet e laru mari kuom odiechiengʼ achiel ber 
\q2 moloyo bet kamachielo kuom higni alufu achiel; 
\q1 daher bedo jarit dhoot e od Nyasacha, 
\q2 moloyo dak e hembe joma timbegi richo. 
\q1  
\v 11 Nimar Jehova Nyasaye en chiengʼ kendo en okumba; 
\q2 Jehova Nyasaye chiwo ngʼwono gi duongʼ; 
\q1 ok otuon joma wuodhgi oriere tir 
\q2 gimoro amora maber. 
\b  
\q1  
\v 12 Yaye Jehova Nyasaye Maratego, 
\q2 ngʼama ogeno kuomi ogwedhi. 
\c 85  
\cl Zaburi 85 
\d Kuom jatend wer. Zaburi mar yawuot Kora. 
\q1  
\v 1 Ne itimo maber ne piny, yaye Jehova Nyasaye; 
\q2 ne iduogone Jakobo mwandune. 
\q1  
\v 2 Ne iweyone jogi kethogi 
\q2 kendo ne iumo richogi duto. \qs Sela\qs* 
\q1  
\v 3 Mirimbi duto ne iketo tenge, 
\q2 kendo ne ilokori iweyo mirimbi mager. 
\b  
\q1  
\v 4 Dwogwa iri kendo, yaye Nyasaye Jawarwa, 
\q2 kendo gol kecho mikechogo kodwa iter mabor. 
\q1  
\v 5 Ibiro kecho kodwa nyaka chiengʼ koso? 
\q2 Koso ibiro choro mirimbi e tienge duto? 
\q1  
\v 6 Angʼo mamoni duogowa iri kendo, 
\q2 mondo eka jogi obed mamor kuomi? 
\q1  
\v 7 Nyiswa herani ma ok rem, yaye Jehova Nyasaye, 
\q2 kendo mi wayud resruok mari. 
\b  
\q1  
\v 8 Abiro chiko ita ne gima Nyasaye, ma Jehova Nyasaye biro wacho; 
\q2 osingo kwe ne joge ma joratiro, 
\q2 to nyaka gine ni ok gidok e timbe mofuwo. 
\q1  
\v 9 Adier, resruokne ni machiegni gi joma omiye luor, 
\q2 kendo duongʼne biro bet e pinywa. 
\b  
\q1  
\v 10 Hera gi adiera biro riwore kanyakla, 
\q2 kendo tim makare gi kwe biro nyodhore. 
\q1  
\v 11 Adiera biro aa piny kochomo malo, 
\q2 kendo tim makare biro ngʼiyo piny gie polo. 
\q1  
\v 12 Jehova Nyasaye biro miyowa gima ber adier 
\q2 kendo pinywa biro chiego chambe. 
\q1  
\v 13 Tim makare biro telo nyime 
\q2 kendo biro loso yo ne okangene. 
\c 86  
\cl Zaburi 86 
\d Lemo mar Daudi. 
\q1  
\v 1 Winj lamona, yaye Jehova Nyasaye, kendo dwoka, 
\q2 nimar adhier kendo achando. 
\q1  
\v 2 Rit ngimana, nikech achiworani. 
\q2 In e Nyasacha, omiyo res ngima jatichni, 
\q2 mogeno kuomi. 
\q1  
\v 3 Kecha, yaye Ruoth Nyasaye, 
\q2 nimar aywakni odiechiengʼ duto. 
\q1  
\v 4 Mi jatichni obed mamor, yaye Ruoth Nyasaye, 
\q2 nimar in ema aketo genona kuomi. 
\b  
\q1  
\v 5 Nikech in iber kendo iweyo richo, yaye Ruoth Nyasaye 
\q2 in gihera mangʼeny kuom joma luongi. 
\q1  
\v 6 Winj lamona, yaye Jehova Nyasaye; 
\q2 chik iti ne ywakna ma akwayigo kech. 
\q1  
\v 7 Chiengʼ ma chandruok omaka 
\q2 to abiro luongi mondo ikonya, nimar ibiro dwoka. 
\b  
\q1  
\v 8 Onge nyasaye moro amora e dier nyiseche machalo kodi, yaye Ruoth Nyasaye; 
\q2 onge timbe minyalo pimo gi magi. 
\q1  
\v 9 Ogendini duto michweyo 
\q2 biro lami kapodho e nyimi, yaye Ruoth Nyasaye; 
\q2 bende gibiro miyo nyingi duongʼ. 
\q1  
\v 10 Nimar iduongʼ kendo itimo timbe miwuoro; 
\q2 in e Nyasaye kende. 
\b  
\q1  
\v 11 Puonja yoreni, yaye Jehova Nyasaye, 
\q2 mondo eka awuothi e adierani; 
\q1 miya chuny ma ok ba koni gi koni, 
\q2 mondo omi aluor nyingi. 
\q1  
\v 12 Abiro paki gi chunya duto, yaye Ruoth Nyasacha, 
\q2 abiro miyo nyingi duongʼ nyaka chiengʼ. 
\q1  
\v 13 Nimar hera ma iherago duongʼ, 
\q2 kendo isegola ei chuny bur matut. 
\b  
\q1  
\v 14 Josunga ma wengegi tek monja, yaye Nyasaye; 
\q2 migawo mar joma ok kech ngʼato dwaro tieko ngimana, 
\q2 joma ok dew kata in. 
\q1  
\v 15 In to in Nyasaye ma kecho kendo ngʼwon, yaye Jehova Nyasaye, 
\q2 iyi ok wangʼ piyo, ipongʼ gihera kendo in ja-adiera. 
\q1  
\v 16 Duog ira mondo ikecha; 
\q2 med jatichni tekoni, 
\q2 kendo res jatichni mogeni. 
\q1  
\v 17 Miyae ranyisi mar berni, 
\q2 mondo wasika one mi wigi okuodi, 
\q2 nimar in ema isebedo ka ikonya kendo ihoya, yaye Jehova Nyasaye. 
\c 87  
\cl Zaburi 87 
\d Zaburi mar yawuot Kora. Wer. 
\q1  
\v 1 Oseguro mise mare ewi got maler; 
\q2  
\v 2 Jehova Nyasaye ohero rangeye mag Sayun, 
\q2 moloyo kuonde dak duto mag Jakobo. 
\b  
\q1  
\v 3 Ji wacho gik madongo kuomi, 
\q2 yaye dala maduongʼ mar Nyasaye: \qs Sela\qs* 
\q1  
\v 4 “Abiro kwano Rahab\f + \fr 87:4 \ft Nying machielo midendogo Misri.\f* gi Babulon 
\q2 e kanyakla mar joma ongʼeya, 
\q1 nyaka Filistia bende, kod Turo, kaachiel gi Kush 
\q2 kendo abiro wacho ni, ‘Ngʼatni nonywol ei Sayun.’ ” 
\b  
\q1  
\v 5 Adier, nowachi kuom Sayun niya, 
\q2 “En min ogendini mathoth, 
\q2 kendo Nyasaye Man Malo Moloyo owuon biro chunge.” 
\q1  
\v 6 Jehova Nyasaye biro ndiko e kitabu mindikoe nying ogendini kama: 
\q2 “Jali nonywol ei Sayun.” \qs Sela\qs* 
\b  
\q1  
\v 7 Sa ma giloso wer to giniwer niya, 
\q2 “Soknina duto ni e iyi.” 
\c 88  
\cl Zaburi 88 
\d Wer. Zaburi mar yawuot Kora. Kuom jatend wer. Kaluwore gi \tl mahalath leanoth.\tl*\tl Maskil\tl*\f + \fr 88:0 \fl Maskil: \ft en kit wer moro mane Daudi owero\f* mar Heman ja-Ezra. 
\q1  
\v 1 Yaye Jehova Nyasaye, in e Nyasacha ma resa, 
\q2 aywagora e nyimi odiechiengʼ gotieno. 
\q1  
\v 2 Mad lamona chop e nyimi; 
\q2 yie ilok iti ne kwayona. 
\b  
\q1  
\v 3 Nimar chandruok opongʼo chunya 
\q2 kendo ngimana sudo machiegni gi liel. 
\q1  
\v 4 Ikwana kaachiel gi joma ridore piny ei bur matut; 
\q2 achalo ngʼama onge teko. 
\q1  
\v 5 Ojwangʼa kaachiel gi joma otho, 
\q2 mana kaka joma onegi monindo e bur, 
\q1 makoro ok ipar kuomgi kendo, 
\q2 joma ongʼad kargi oko e ritni. 
\b  
\q1  
\v 6 Iseketa ei bur matut mogik, ei piny mogik, 
\q2 kama olil ti. 
\q1  
\v 7 Mirimbi mager ogore kuoma mapek; 
\q2 isetamo wangʼa gi apaka magi duto. \qs Sela\qs* 
\q1  
\v 8 Isemiyo osiepena mane ni machiegni koda mogik oringa, 
\q2 kendo isemiyo koro achalonegi mana koko. 
\q1 Odinna ma ok anyal tony; 
\q2  
\v 9 wengena ok nen maber nikech kuyo ma an-go. 
\b  
\q1 Aluongi odiechiengʼ kodiechiengʼ, yaye Jehova Nyasaye; 
\q2 achikoni lwetena. 
\q1  
\v 10 Bende itimo honni magi ne joma otho? 
\q2 Joma otho bende nyalo chier kendo mi paki? \qs Sela\qs* 
\b  
\q1  
\v 11 Herani bende inyiso joma ni ei liel; adier, 
\q2 koso adierani bende yudore e kethruok piny? 
\q1  
\v 12 Timbeni miwuoro bende ongʼere kama otimo mudhono, 
\q2 kata timbeni makare e piny ma ilalieno? 
\b  
\q1  
\v 13 Anto aywakni mondo ikonya, yaye Jehova Nyasaye; 
\q2 lamona chopo e nyimi gokinyi. 
\q1  
\v 14 Yaye Jehova Nyasaye, 
\q2 angʼo momiyo idaga kendo ipandona wangʼi? 
\b  
\q1  
\v 15 Aseneno chandruok chakre tin-na mi adwa tho; 
\q2 asewinjo malit nikech thagruok misekelona, kendo chunya oseol. 
\q1  
\v 16 Mirimbi mager oseywaya; 
\q2 thagruok mimiya osetieka. 
\q1  
\v 17 Gilwora ka ataro odiechiengʼ duto; 
\q2 gisedinona chuth koni gi koni. 
\q1  
\v 18 Isemaya osiepena gi joherana; 
\q2 mudho mandiwa ema koro odongʼ machiegni koda kaka osiepna. 
\c 89  
\cl Zaburi 89 
\d \tl Maskil\tl*\f + \fr 89:0 \fl Maskil: \ft en kit wer moro mane Daudi owero\f* mar Ethan ja-Ezra. 
\q1  
\v 1 Abiro wer nyaka chiengʼ kuom hera maduongʼ mar Jehova Nyasaye; 
\q2 abiro nyiso ji gi dhoga mi gingʼe kuom adierani e tienge duto. 
\q1  
\v 2 Abiro nyiso ratiro ni herani ogurore motegno nyaka chiengʼ; 
\q2 kendo ni ne iguro adierani e polo owuon. 
\b  
\q1  
\v 3 Ne iwacho niya, “Asetimo muma gi ngʼata ma ayiero, 
\q2 asesingora ne Daudi jatichna ni, 
\q1  
\v 4 ‘Anachung kothi nyaka chiengʼ 
\q2 kendo anagur lochni motegno e tienge duto.’ ” \qs Sela\qs* 
\b  
\q1  
\v 5 Polo pako timbeni miwuoro kod adierani, yaye Jehova Nyasaye, 
\q2 e dier chokruok mar jomaler. 
\q1  
\v 6 Koso en ngʼa e kor polo minyalo pimo gi Jehova Nyasaye? 
\q2 En ngʼa e dier chwech mag polo machalo gi Jehova Nyasaye? 
\q1  
\v 7 E buch jomaler Nyasaye oluor gi luor maduongʼ; 
\q2 olich moloyo chwech duto molwore. 
\q1  
\v 8 Yaye Jehova Nyasaye Maratego en ngʼa machalo kodi? 
\q2 In Jehova Nyasaye iratego kendo adierani olwori. 
\b  
\q1  
\v 9 In giteko ewi nam magingore; 
\q2 ka apakane dhwolore malo, to ikweyogi. 
\q1  
\v 10 Ne ingʼinyo Rahab mana ka kitundu, 
\q2 kendo ne ikeyo wasiki gi badi maratego. 
\q1  
\v 11 Polo gin magi, kendo piny bende en mari. 
\q2 In ema ne imiyo piny obetie kaachiel gi gik moko duto manie iye. 
\q1  
\v 12 Ne ichweyo nyandwat gi milambo; 
\q2 Tabor gi Hermon pako nyingi gi wer gi mor. 
\q1  
\v 13 In-gi bat maratego, lweti bende otegno, 
\q2 kendo lweti ma korachwich nigi duongʼ. 
\b  
\q1  
\v 14 Tim makare gi adiera e mise mag lochni; 
\q2 hera gi ber otelo e nyimi. 
\q1  
\v 15 Ogwedh joma osepuonjore goyoni sigio mar mor, 
\q2 jogo mawuotho buti e lerni, yaye Jehova Nyasaye. 
\q1  
\v 16 Giil odiechiengʼ duto nikech nyingi; 
\q2 gidhialo timni makare. 
\q1  
\v 17 Nimar in e duongʼgi gi tekogi, 
\q2 kendo isedhialo tungwa kuom ngʼwononi. 
\q1  
\v 18 Adier, kuodi marwa en mar Jehova Nyasaye, 
\q2 ruodhwa en mar Jal Maler mar Israel. 
\b  
\q1  
\v 19 Kinde moko ne iwuoyo e yor fweny, 
\q2 mine iwacho ne jogi ma jo-adiera niya, 
\q1 “Asesidho teko kuom jalweny, 
\q2 asemiyo wuowi moro matin duongʼ e dier ji. 
\q1  
\v 20 Aseyudo Daudi jatichna; 
\q2 asewire gi moya maler. 
\q1  
\v 21 Lweta biro sire, adier, 
\q2 bada biro miye teko. 
\q1  
\v 22 Onge ngʼama timbene richo moro amora mane ochune mondo ogolne osuru; 
\q2 onge ngʼama timbene richo moro amora ma nosande. 
\q1  
\v 23 Abiro tieko chuth joma kedo kode koneno gi wangʼe, 
\q2 kendo abiro goyo wasike duto piny. 
\q1  
\v 24 Herana mar adier nobed kode, 
\q2 kendo tungene nomi duongʼ nikech nyinga. 
\q1  
\v 25 Abiro keyo lwete mi kwak nam, 
\q2 kendo lwete ma korachwich biro kwako aore. 
\q1  
\v 26 Obiro luonga ni, ‘In Wuonwa kendo in Nyasacha, 
\q2 lwandana ma Jawarna.’ 
\q1  
\v 27 Bende abiro ketone nyathina makayo, 
\q2 ma en Jal motingʼ malo moloyo ruodhi duto mag piny. 
\q1  
\v 28 Abiro siko ka ahere nyaka chiengʼ, 
\q2 kendo winjruok ma atimo kode ok norem mak ochopo ngangʼ. 
\q1  
\v 29 Abiro guro kothe nyaka chiengʼ, 
\q2 kendo lochne nosiki mana kaka polo osiko. 
\b  
\q1  
\v 30 “Kata ka yawuote nowe chikna 
\q2 ma ok giluwo yorena, 
\q1  
\v 31 ka ok girito buchena 
\q2 kendo ka chikena otamogi luwo, 
\q1  
\v 32 to anakum richogi gi luth, 
\q2 kendo anago kethogi gi chwat. 
\q1  
\v 33 Kata kamano ok anagol herana kuome, 
\q2 bende ok anatimne gima opogore gi adierana. 
\q1  
\v 34 Ok anawe mak achopo winjruokna kode 
\q2 kata loko gima asewacho gi dhoga. 
\q1  
\v 35 Asesingora dichiel kendo mogik kuom ler mara, 
\q2 kendo ok abi riambo ne Daudi, 
\q1  
\v 36 ni kothe nodhi nyime nyaka chiengʼ 
\q2 kendo lochne nosiki e nyima ka wangʼ chiengʼ; 
\q1  
\v 37 nogure mi osiki nyaka chiengʼ kaka dwe, 
\q2 ma en ranyisi madier e kor polo.” \qs Sela\qs* 
\b  
\q1  
\v 38 To in isekwedo, kendo iseweya, 
\q2 iyi osewangʼ matek gi ngʼati mowir. 
\q1  
\v 39 Iselokori iweyo singruok mane itimo gi jatichni, 
\q2 kendo isechido osimbone ei buru. 
\q1  
\v 40 Isegoyo ohingane duto piny 
\q2 kendo isemuko kuondege mochiel motegno mi olokore gunda. 
\q1  
\v 41 Ji duto makalo bute oseyake; 
\q2 osedoko ngʼama jobute nyiero. 
\q1  
\v 42 Isetingʼo lwedo ma korachwich mar wasike malo; 
\q2 isemiyo wasike duto oil. 
\q1  
\v 43 Bende isemiyo dho liganglane obedo madik 
\q2 kendo ok isekonye e kedo. 
\q1  
\v 44 Isemiyo duongʼne orumo 
\q2 kendo isewito lochne piny. 
\q1  
\v 45 Isengʼado ndalo mag tin-ne odoko machiek; 
\q2 isemiyo oneno wichkuot maduongʼ. \qs Sela\qs* 
\b  
\q1  
\v 46 Nyaka karangʼo, yaye Jehova Nyasaye? 
\q2 Ibiro pando wangʼi nyaka chiengʼ koso? 
\q2 Mirimbi biro liel ka mach nyaka karangʼo? 
\q1  
\v 47 Parie kaka ngimana rumo piyo. 
\q2 Neye kaka ne ichweyo dhano duto kayiem! 
\q1  
\v 48 En ngʼa manyalo bedo mangima nyaka chiengʼ mak oneno tho? 
\q2 Koso en ngʼa manyalo resore owuon e teko mar liel? \qs Sela\qs* 
\q1  
\v 49 Yaye Jehova Nyasaye, tinde ere herani maduongʼ machon, 
\q2 hera mane isingori kuom adierani, ni initim ne Daudi? 
\q1  
\v 50 Ruoth, parie kaka ji osechayo jatichni, 
\q2 parie kaka atingʼo e chunya ayenje mag ogendini duto, 
\q1  
\v 51 ayenje ma wasiki osejerogo, yaye Jehova Nyasaye, 
\q2 ayenje ma gisejarogo okangʼ kokangʼ mar jatichni mowir. 
\b  
\b  
\q1  
\v 52 Opak Jehova Nyasaye nyaka chiengʼ! 
\qc Amin kendo Amin. 
\c 90  
\ms1 Kitabu mar Angʼwen 
\mr Zaburi 90–106 
\cl Zaburi 90 
\d Lamo mar Musa ngʼat Nyasaye. 
\q1  
\v 1 Yaye Jehova Nyasaye, isebedo kar dak marwa 
\q2 nyaka nene e tienge duto. 
\q1  
\v 2 Kane pok gode obetie 
\q2 kata kane pok ichweyo piny gi ji modak e iye, 
\q2 to isebedo ka in Nyasaye nyaka nene kendo manyaka chiengʼ. 
\b  
\q1  
\v 3 Idwoko dhano e lowo, 
\q2 kiwacho niya, “Doguru e lowo un koth dhano.” 
\q1  
\v 4 Nimar higni alufu achiel e nyimi 
\q2 chalo gi odiechiengʼ manyoro mosekalo, 
\q2 kata gi sa mar otieno. 
\q1  
\v 5 Iywoyo dhano ilalgo nono ka nindo mar tho terogi; 
\q2 gichalo gi lum mangʼich mar okinyi, 
\q1  
\v 6 ma kata obedo ni loth ka ngʼich gokinyi 
\q2 to godhiambo to ner kendo two. 
\b  
\q1  
\v 7 Mirimbi tiekowa 
\q2 kendo kecho mikechogo kodwa bwogowa. 
\q1  
\v 8 Iseketo richowa e nyimi, 
\q2 ee, richowa ma watimo lingʼ-lingʼ ineno seche duto. 
\q1  
\v 9 Ndalowa kadho piyo nikech mirimbi; 
\q2 hikwa rumo piyo gi chir. 
\q1  
\v 10 Ndalowa en piero abiriyo kata piero aboro, 
\q2 ka ringrewa otegno; 
\q1 to kata kamano ndalogo duto opongʼ gi chandruok kod kuyo, 
\q2 nimar gikalo piyo, kendo gilal nono. 
\q1  
\v 11 En ngʼa mongʼeyo teko mar mirimbi? 
\q2 Nimar gero mari nigi teko machalo gi teko ma luori kelo. 
\q1  
\v 12 Omiyo puonjwa kwano ndalowa kare, 
\q2 mondo wabed gi chuny mariek. 
\b  
\q1  
\v 13 Ibiro siko kikecho nyaka karangʼo, yaye Jehova Nyasaye? 
\q2 Lokri, kech jatichni. 
\q1  
\v 14 Romwa gokinyi gi herani ma ok rem, 
\q2 mondo wawer gi ilo kendo wabed mamor ndalowa duto. 
\q1  
\v 15 Mi wabed mamor amingʼa mana kaka isemiyo waneno malit, 
\q2 marom gi higni ma wasenene chandruok. 
\q1  
\v 16 Mad tijeni nere gi jotichni, 
\q2 mad duongʼni nyisre ne nyithindi. 
\b  
\q1  
\v 17 Mad ngʼwono mar Ruoth Nyasachwa obed kodwa; 
\q2 yie igurnwa tich mar lwetwa, 
\q2 ee gurnwa tich mar lwetwa. 
\c 91  
\cl Zaburi 91 
\q1  
\v 1 Ngʼat modak ei kar pondo mar Nyasaye Man Malo Moloyo 
\q2 biro yudo yweyo e bwo tipo mar Jehova Nyasaye Maratego. 
\q1  
\v 2 Ngʼat ma kamano nyalo wacho kuom Jehova Nyasaye niya, 
\q2 “En e kar pondona kendo en e ohingana, 
\q2 en e Nyasacha ma ageno kuome.” 
\b  
\q1  
\v 3 Jehova Nyasaye biro resi adier kuom gik mochikigo 
\q2 mondo ohinyi kendo kuom tuoche maricho maneko. 
\q1  
\v 4 Obiro umi gi bwombene, 
\q2 kendo ibiro yudo konyruok e bwo bwombene; 
\q2 adierane biro bedoni ka okumba kendo ka siro. 
\q1  
\v 5 Ok iniluor masira mar otieno, 
\q2 kata asere machielore godiechiengʼ, 
\q1  
\v 6 kata tuoche maricho maliwo ji e mudho, 
\q2 kata tho matieko ngima ji e dier odiechiengʼ tir. 
\q1  
\v 7 Ji alufu achiel nyalo podho e bathi, 
\q2 ee, ji alufu apar nyalo riere e badi korachwich, 
\q2 to in onge moro ma nochop buti. 
\q1  
\v 8 Iningʼigi angʼiya gi wengeni 
\q2 kendo inine kikumo joma timbegi richo. 
\b  
\q1  
\v 9 Ka iwacho niya, “Jehova Nyasaye e kar pondona,” 
\q2 kendo iketo Nyasaye Man Malo Moloyo kar dakni, 
\q1  
\v 10 to onge gimoro amora marach ma notimreni, 
\q2 kendo onge masira ma nosud machiegni gi odi. 
\q1  
\v 11 Nimar obiro miyo malaika mage chik nikech in 
\q2 mondo giriti e yoreni duto; 
\q1  
\v 12 gibiro tingʼi malo e lwetgi, 
\q2 mondo kik ichwany tiendi e kidi. 
\q1  
\v 13 Ininyon sibuor gi thuond fu; 
\q2 adier ininyon sibuor maratego gi thuol maduongʼ man-gi kwiri marach. 
\b  
\q1  
\v 14 Jehova Nyasaye wacho niya, “Abiro rese nikech ohera; 
\q2 abiro rite nikech ohulo nyinga. 
\q1  
\v 15 Enoluonga, kendo anadwoke; 
\q2 anabed kode e chandruok, 
\q2 adier, anakonye kendo anamiye duongʼ. 
\q1  
\v 16 Anami odag amingʼa 
\q2 kendo ananyise warruokna.” 
\c 92  
\cl Zaburi 92 
\d Zaburi. Wer. Ne chiengʼ Sabato. 
\q1  
\v 1 Pako Jehova Nyasaye en gima ber kendo wero wende mapako nyingi 
\q2 bende ber, yaye Nyasaye Man Malo Moloyo, 
\q1  
\v 2 hulo herani gokinyi 
\q2 kod adierani gotieno, 
\q1  
\v 3 kiwer gi nyatiti matin 
\q2 ma tondene apar ka wer ridore gi nyatiti maduongʼ ber adier. 
\b  
\q1  
\v 4 Nimar timbeni miya mor, yaye Jehova Nyasaye; 
\q2 awer gi mor nikech tije ma lweti otimo. 
\q1  
\v 5 Mano kaka tijeni dongo, yaye Jehova Nyasaye, 
\q2 mano kaka pachi tut miwuoro! 
\q1  
\v 6 Ngʼama omingʼ ok nyal ngʼeyo, 
\q2 joma ofuwo ok winj tiend wachno, 
\q1  
\v 7 ni kata obedo ni joma timbegi richo nyalo loth kaka lum 
\q2 kendo joricho nyalo dhi maber, 
\q1 to ibiro tiekgi chuth nyaka chiengʼ. 
\q1  
\v 8 To in, yaye Jehova Nyasaye, ibiro siko kimiyi duongʼ nyaka chiengʼ. 
\q1  
\v 9 Nimar ka kuom adier, yaye Jehova Nyasaye, 
\q2 ka kuom adier to wasiki duto biro lal nono; 
\q2 joricho duto ibiro ke mel. 
\q1  
\v 10 Isemiyo tungena odoko ma roboche ka tunge jowi; 
\q2 oseol kuoma modhi maliw. 
\q1  
\v 11 Aseneno gi wengena ka iloyo wasika 
\q2 kendo asewinjo gi itena ka joma oramona ma timbegi richo itieko. 
\b  
\q1  
\v 12 Joma kare biro loth maber ka yiend othith, 
\q2 gibiro dongo ka yiend sida mar Lebanon; 
\q1  
\v 13 Nikech opidhgi e od Jehova Nyasaye, 
\q2 gibiro loth e agolni mag Nyasachwa. 
\q1  
\v 14 Kata hikgi oniangʼ to pod gininyag mana olemo, 
\q2 kendo ginisik ka ginyien kendo gingʼich, 
\q1  
\v 15 ka gilando niya “Jehova Nyasaye oriere tir; 
\q2 en e Lwandana, kendo onge richo moro amora kuome.” 
\c 93  
\cl Zaburi 93 
\q1  
\v 1 Jehova Nyasaye olocho kendo orwakore gi duongʼ, 
\q2 Jehova Nyasaye orwakore gi duongʼ, 
\q2 kendo omanore gi teko. 
\q1 Piny ochungʼ mongirore; 
\q2 onge ngʼama nyalo yienge. 
\q1  
\v 2 Lochni nogur chon gi lala; 
\q2 ionge chakruokni kata gikoni. 
\b  
\q1  
\v 3 Nembe tingʼore malo, yaye Jehova Nyasaye, 
\q2 nembe dhwolore malo ka giwuo; 
\q2 nembe tingʼore ka apaka gore matek. 
\q1  
\v 4 Jehova Nyasaye nigi teko maduongʼ moloyo mor mar pige maroteke, 
\q2 en gi teko maduongʼ moloyo apaka ma tekregi ngʼeny, 
\q2 adier Jehova Nyasaye man malo nigi teko maduongʼ. 
\b  
\q1  
\v 5 Bucheni ochungʼ mongirore; 
\q2 kendo ler opongʼo odi, 
\q2 nyaka chiengʼ, yaye Jehova Nyasaye. 
\c 94  
\cl Zaburi 94 
\q1  
\v 1 Yaye Jehova Nyasaye en Nyasaye ma jachul kuor, 
\q2 yaye Nyasaye ma jachul kuor, nyis lerni. 
\q1  
\v 2 Aa malo, yaye Jangʼad bura mar piny; 
\q2 chul josunga gima owinjore kodgi. 
\q1  
\v 3 Yaye Jehova Nyasaye, nyaka karangʼo ma joma timbegi richo, 
\q2 nyaka karangʼo ma joma timbegi richo biro goyo siboi? 
\b  
\q1  
\v 4 Gidiro weche mag wich teko; 
\q2 joma timbegi richo duto opongʼ gi sunga. 
\q1  
\v 5 Gikidho jogi, yaye Jehova Nyasaye; 
\q2 gidiyo girkeni mari. 
\q1  
\v 6 Ginego dhako ma chwore otho gi jadak; 
\q2 gideyo ngʼama onge gi wuon. 
\q1  
\v 7 Giwacho niya, “Jehova Nyasaye ok ne; 
\q2 Nyasach Jakobo ok dew gik ma watimo.” 
\b  
\q1  
\v 8 To winjuru, un joma omingʼ e dier ji; 
\q2 un joma ofuwogi, ubiro bedo mariek karangʼo? 
\q1  
\v 9 Donge ngʼama nochomo it winjo wach? 
\q2 Donge ngʼat manoloso wangʼ neno? 
\q1  
\v 10 Donge ngʼat marieyo ogendini kumo ji? 
\q2 Bende ngʼat mapuonjo dhano dibed maonge rieko? 
\q1  
\v 11 Jehova Nyasaye ongʼeyo pach dhano; 
\q2 ongʼeyo ni gionge tich. 
\q1  
\v 12 Ogwedh ngʼat mikumo, yaye Jehova Nyasaye, 
\q2 ma en ngʼama ipuonjo koa e chikeni; 
\q1  
\v 13 imiyo ngʼama kamano resruok e ndalo chandruok, 
\q2 nyaka chop kuny bur ne joma richo. 
\q1  
\v 14 Nimar Jehova Nyasaye ok bi dagi joge; 
\q2 ok obi jwangʼo girkeni mare. 
\q1  
\v 15 Yor adiera biro yudore kendo ne joma kare, 
\q2 kendo joma oriere gie chunygi biro luwe. 
\q1  
\v 16 En ngʼa mabiro radona gi joma timbegi richo? 
\q2 Ngʼatno mabiro chwaka kakedo gi joricho? 
\q1  
\v 17 Ka dine Jehova Nyasaye ok omiya kony, 
\q2 to dikoro asedhi dak e piny ma ji olingʼe thi. 
\q1  
\v 18 Kane awacho niya, “Tienda kier,” 
\q2 to herani nojola, yaye Jehova Nyasaye. 
\q1  
\v 19 Ka achiedh-nade nopongʼo chunya, 
\q2 to hochni noduogo mor e ngimana. 
\q1  
\v 20 Loch marach bende inyalo riworigo adier, 
\q2 loch mamiyo ji chandore malit nikech chikene maricho? 
\q1  
\v 21 Ginywako ne joma kare 
\q2 kendo gingʼadone joma onge ketho buch tho. 
\q1  
\v 22 To Jehova Nyasaye osebedo ohingana, 
\q2 kendo Nyasacha en lwanda ma aponde. 
\q1  
\v 23 Obiro chulogi nikech richogi 
\q2 kendo obiro tiekogi nikech timbegi maricho; 
\q2 Jehova Nyasaye ma Nyasachwa biro tiekogi. 
\c 95  
\cl Zaburi 95 
\q1  
\v 1 Biuru wawer gimor ne Jehova Nyasaye; 
\q2 wagouru koko matek ne lwanda mar warruokwa. 
\q1  
\v 2 Wabiuru e nyime gi erokamano 
\q2 kendo wami nyinge duongʼ ka wawer kendo wakok gi mor. 
\b  
\q1  
\v 3 Nimar Jehova Nyasaye e Nyasaye maduongʼ, 
\q2 en e Ruoth maduongʼ moloyo nyiseche duto. 
\q1  
\v 4 Otingʼo kuonde matut duto mag piny e lwete, 
\q2 kendo wi gode ma roboche bende mage. 
\q1  
\v 5 Nam mare, nimar en ema nolose, 
\q2 kendo lwetene ema noloso lowo motwo. 
\b  
\q1  
\v 6 Biuru wakulrene ka walame, 
\q2 biuru wago chongwa e nyim Jehova Nyasaye ma Jachwechwa; 
\q1  
\v 7 nimar en e Nyasachwa 
\q2 kendo wan e joge mokwayo, 
\q2 wan e jambe morito. 
\b  
\q1 Kawuono ka uwinjo dwonde, 
\q2  
\v 8 to kik chunyu bed mapek kaka ne utimo Meriba, 
\q2 kata kaka ne utimo chiengʼ cha Masa manie thim, 
\q1  
\v 9 kama kwereu noteme gi tem, 
\q2 kata obedo ni ne giseneno gima ne atimo. 
\q1  
\v 10 Kuom higni piero angʼwen iya nowangʼ gi tiengʼno; 
\q2 kendo nawacho niya, “Gin joma chunygi ohero rwenyo, 
\q2 kendo pok gingʼeyo yorena.” 
\q1  
\v 11 Omiyo mirima nomaka kodgi mi nasingora ka akwongʼora ni, 
\q2 “Ok ginidonji e yweyona ngangʼ.” 
\c 96  
\cl Zaburi 96 
\q1  
\v 1 Weruru ne Jehova Nyasaye wer manyien; 
\q2 piny duto mondo ower ne Jehova Nyasaye. 
\q1  
\v 2 Weruru ne Jehova Nyasaye, pakuru nyinge; 
\q2 landuru warruokne odiechiengʼ kodiechiengʼ. 
\q1  
\v 3 Huluru duongʼne e kind ogendini, 
\q2 kendo landuru tijene miwuoro ne ji duto. 
\b  
\q1  
\v 4 Nimar Jehova Nyasaye duongʼ kendo owinjore gi pak; 
\q2 onego omiye luor moloyo nyiseche mamoko duto. 
\q1  
\v 5 Nikech nyiseche duto mag ogendini gin mana gik ma dhano oloso 
\q2 to Jehova Nyasaye ema nochweyo polo. 
\q1  
\v 6 Duongʼ kod pak nitiere e nyime; 
\q2 teko kod duongʼ nitiere e kare maler mar lemo. 
\b  
\q1  
\v 7 Pakuru Jehova Nyasaye, yaye ogendini manie piny, 
\q2 wachuru ni Jehova Nyasaye duongʼ kendo en gi teko. 
\q1  
\v 8 Miuru Jehova Nyasaye duongʼ mowinjore gi nyinge; 
\q2 kelneuru mich kendo biuru e laru mage. 
\q1  
\v 9 Lamuru Jehova Nyasaye kaka Ngʼama Ler man-gi duongʼ mangʼongo; 
\q2 beduru maluor ahinya e nyime, un piny duto. 
\b  
\q1  
\v 10 Wachuru e dier ogendini niya, “Jehova Nyasaye olocho.” 
\q2 Piny osegur motegno, ok nyal yienge; 
\q2 obiro ngʼado ne ji bura maonge dewo wangʼ. 
\q1  
\v 11 Polo mondo obed moil, piny mondo obed mamor; 
\q2 nam mondo owuo kaachiel gi gik moko duto manie iye; 
\q1  
\v 12 pewe mondo okog gi mor, 
\q2 kod gik moko duto manie igi. 
\q1 Eka yiende duto manie bungu nower gi mor; 
\q2  
\v 13 giniwer e nyim Jehova Nyasaye, nimar obiro, 
\q2 adier obiro mondo ongʼad ne piny bura. 
\q1 Obiro ngʼado ne piny bura e yo makare, 
\q2 ee, obiro yalo ji gi adierane. 
\c 97  
\cl Zaburi 97 
\q1  
\v 1 Jehova Nyasaye e Ruoth, omiyo piny mondo obed mamor; 
\q2 dho nembe man mabor mondo obed moil. 
\b  
\q1  
\v 2 Boche polo gi mudho mandiwa oume; 
\q2 tim makare gi adiera e mise mar lochne. 
\q1  
\v 3 Mach liel e nyime 
\q2 kendo wangʼo wasike e alworane duto. 
\q1  
\v 4 Mil polo mare menyo piny; 
\q2 piny neno kendo yiengni. 
\q1  
\v 5 Gode leny nono ka odok e nyim Jehova Nyasaye, 
\q2 gileny nono e nyim Ruoth piny duto. 
\q1  
\v 6 Polo hulo timne makare, 
\q2 kendo ji duto neno duongʼne. 
\b  
\q1  
\v 7 Ji duto malamo gik mokedi wigi okuot; 
\q2 jogo gin joma sungore kuom nyiseche mopa; 
\q2 nyiseche duto mondo olame! 
\b  
\q1  
\v 8 Sayun nowinjo wachno mi obedo moil, 
\q2 miech Juda bende nobedo mamor, 
\q2 nikech bucheni, yaye Jehova Nyasaye. 
\q1  
\v 9 Nimar in Jehova Nyasaye, e Nyasaye Man Malo Moloyo mohewo piny duto; 
\q2 iduongʼ kendo iyombo nyiseche mamoko duto mabor. 
\b  
\q1  
\v 10 Joma ohero Jehova Nyasaye mondo osin gi gik maricho 
\q2 nimar orito ngima joge ma jo-adiera, 
\q2 kendo oresogi e lwet joma richo. 
\q1  
\v 11 Joma kare imenyonegi ler; 
\q2 joma oriere gie chunygi imiyo mor. 
\q1  
\v 12 Moruru kuom Jehova Nyasaye un joma kare, 
\q2 kendo pakuru nyinge maler. 
\c 98  
\cl Zaburi 98 
\d Zaburi. 
\q1  
\v 1 Weruru ne Jehova Nyasaye wer manyien, 
\q2 nimar osetimo gik miwuoro; 
\q1 lwete korachwich gi bade maler 
\q2 osekelone warruok. 
\q1  
\v 2 Jehova Nyasaye osemiyo warruokne ongʼere 
\q2 kendo osefwenyone ogendini timne makare. 
\q1  
\v 3 Oseparo herane 
\q2 kod adierane ne dhood Israel; 
\q1 kuonde duto ma piny ogikie 
\q2 oseneno warruok mar Nyasachwa. 
\b  
\q1  
\v 4 Koguru gi mor ni Jehova Nyasaye, un piny duto, 
\q2 weruru kod ilo gi dwol mamit; 
\q1  
\v 5 weruru mamit ne Jehova Nyasaye kugoyo nyatiti; 
\q2 werneuru mamit kugoyo nyatiti gi dwond wer molungi, 
\q1  
\v 6 werneuru gi turumbete kod tung im maywak matek, 
\q2 koguru gi mor e nyim Jehova Nyasaye ma Ruoth. 
\b  
\q1  
\v 7 Nam mondo owuo, kaachiel gi gik moko duto manie iye, 
\q2 kod piny duto, gi ji duto modak e iye. 
\q1  
\v 8 Aore mondo opam lwetgi, 
\q2 gode mondo ower kaachiel ka gimor; 
\q1  
\v 9 onego giwer e nyim Jehova Nyasaye, 
\q2 nimar obiro mondo ongʼad bura ne piny. 
\q1 Obiro ngʼado bura ne piny e yo makare 
\q2 kendo obiro yalo ji maonge dewo wangʼ. 
\c 99  
\cl Zaburi 99 
\q1  
\v 1 Jehova Nyasaye e Ruoth, 
\q2 ogendini mondo okirni; 
\q1 obet e kom lochne e kind kerubi, 
\q2 piny mondo oyiengni. 
\q1  
\v 2 Jehova Nyasaye duongʼ miwuoro e Sayun; 
\q2 otingʼe malo moyombo ogendini duto. 
\q1  
\v 3 Owinjore gipak nyingi maduongʼ kendo miwuoro, 
\q2 nyinge ler. 
\b  
\q1  
\v 4 Ruoth nyalo, ohero bura makare, 
\q2 isechungo adiera; 
\q1 isetimo ne joka Jakobo 
\q2 gima adier kendo makare. 
\q1  
\v 5 Dhialuru Jehova Nyasaye ma Nyasachwa 
\q2 kendo lameuru, 
\q2 e tiend kome mobetie nikech oler. 
\b  
\q1  
\v 6 Musa gi Harun ne gin jodolo mage e dier jodolo mamoko, 
\q2 Samuel ne en achiel kuom joma ne luongo nyinge; 
\q1 negiluongo Jehova Nyasaye 
\q2 kendo nodwokogi. 
\q1  
\v 7 Ne owuoyo kodgi e siro mar bor polo; 
\q2 negirito chikene gi buche mane omiyogi. 
\b  
\q1  
\v 8 Yaye Jehova Nyasaye ma Nyasachwa, 
\q2 ne idwokogi; 
\q1 ne in Nyasaye maweyo richo ne jo-Israel, 
\q2 kata obedo ni ne ikumo timbegi mobam. 
\q1  
\v 9 Tingʼuru nying Jehova Nyasaye ma Nyasachwa 
\q2 kendo lamuru e gode maler, 
\q2 nimar Jehova Nyasaye ma Nyasachwa ler. 
\c 100  
\cl Zaburi 100 
\d Zaburi mar goyo erokamano. 
\q1  
\v 1 Gouru koko gi mor ne Jehova Nyasaye, un piny duto. 
\q2  
\v 2 Lamuru Jehova Nyasaye ka umor; 
\q2 biuru e nyime kuwero wende mamor. 
\q1  
\v 3 Ngʼeuru ni Jehova Nyasaye en Nyasaye. 
\q2 En ema nochweyowa, kendo wan mage; 
\q2 wan joge, kendo wan rombene mokwayo. 
\b  
\q1  
\v 4 Donjuru e rangeyene kugoyo erokamano 
\q2 bende biuru e laru mare kupake. 
\q2 Goneuru erokamano kendo pakuru nyinge. 
\q1  
\v 5 Nimar Jehova Nyasaye ber kendo herane osiko nyaka chiengʼ; 
\q2 adierane ochwere e tienge duto. 
\c 101  
\cl Zaburi 101 
\d Zaburi mar Daudi. 
\q1  
\v 1 Abiro wer nikech herani gi berni; 
\q2 in ema abiro weroni wend pak, yaye Jehova Nyasaye. 
\q1  
\v 2 Abiro neno ni aritora mondo ngimana obed malongʼo chuth, 
\q2 ibiro biro ira karangʼo? 
\b  
\q1 Abiro dak e oda 
\q2 gi chuny malongʼo chuth. 
\q1  
\v 3 Ok abi yie neno 
\q2 gimoro amora mochido gi wengena. 
\b  
\q1 Achayo timbe joma chunygi richo; 
\q2 gik maricho ok adwar winjo kata gi ita. 
\q1  
\v 4 Ok anabed gi paro mochido; 
\q2 bende kata paro mar timo richo ok anapar. 
\b  
\q1  
\v 5 Ngʼato angʼata makuodho nyawadgi lingʼ-lingʼ 
\q2 abiro kwero mi lingʼ; 
\q1 ngʼato angʼata ma wangʼe tek kendo ma sungore gie chunye, 
\q2 ok anyal betgo amingʼa. 
\b  
\q1  
\v 6 Joma jo-adiera ema abiro keto wengena kuomgi; 
\q2 gin ema abiro yie dak kodgi; 
\q1 ngʼat ma wuodhe oriere tir 
\q2 ema biro tiyona. 
\b  
\q1  
\v 7 Ok abi yiene ngʼama ohero miriambo 
\q2 mondo odag e oda; 
\q1 ngʼat moro amora mawacho miriambo 
\q2 ok nochungʼ e nyima. 
\b  
\q1  
\v 8 Okinyi kokinyi abiro tieko 
\q2 joma timbegi richo modak e piny. 
\q1 Abiro nego ngʼato angʼata matimo richo 
\q2 ka agologi e dala mar Jehova Nyasaye. 
\c 102  
\cl Zaburi 102 
\d Lamo mar ngʼat mawinjo marach kendo machiwo ywakne e nyim Jehova Nyasaye. 
\q1  
\v 1 Winj lamona, yaye Jehova Nyasaye; 
\q2 yie irwak lamona ma akwayigo kony. 
\q1  
\v 2 Kik ipandna wangʼi sa ma chunya lit. 
\q2 Chikna iti; ka aluongi to dwoka mapiyo. 
\b  
\q1  
\v 3 Nimar ndalona rumo piyo ka iro; 
\q2 chokena rewni ka kit kendo maliet. 
\q1  
\v 4 Chunya orewore kendo oner ka lum; 
\q2 wiya wil kata mana gi chamo chiemba. 
\q1  
\v 5 Chur ma achurgo matek 
\q2 omiyo adhero alokora choke lilo. 
\q1  
\v 6 Achalo gi tula mar bungu, 
\q2 achalo gi tula modak e gunda. 
\q1  
\v 7 Asiko aneno anena, 
\q2 achalo gi winyo man kende ewi osuri. 
\q1  
\v 8 Odiechiengʼ duto wasika kinya ka gijara; 
\q2 joma dhawona konyore gi nyinga kaka gir kwongʼruok. 
\q1  
\v 9 Nimar achamo buch kendo kaka chiemba 
\q2 kendo ariwo mathna gi pi wangʼa, 
\q1  
\v 10 nikech mirimbi maduongʼ, 
\q2 nimar isekawa mi iwita gichien. 
\q1  
\v 11 Ndalona chalo gi tipo modhiambo; 
\q2 aner adwaro two ka lum. 
\b  
\q1  
\v 12 In to ibet e kom lochni nyaka chiengʼ, yaye Jehova Nyasaye; 
\q2 humbi osiko e tienge duto. 
\q1  
\v 13 Ibiro aa malo mi ikech Sayun, 
\q2 nimar sa osechopo monego ongʼwonee; 
\q2 sa mochanne osechopo. 
\q1  
\v 14 Nimar kitene beyo gi lala ne jotichni, 
\q2 kata mana buru madum kuome miyo ji keche. 
\q1  
\v 15 Ogendini biro luoro nying Jehova Nyasaye, 
\q2 ruodhi duto mag piny biro luoro duongʼni. 
\q1  
\v 16 Nimar Jehova Nyasaye biro gero Sayun 
\q2 kendo obiro thinyore e lela e duongʼne. 
\q1  
\v 17 Obiro dwoko lamo mar ngʼama ok nyal 
\q2 kendo ok obi chayo lamogi. 
\b  
\q1  
\v 18 Wachni mondo ondik piny ne tiengʼ mabiro, 
\q2 mondo joma pok onywol opak Jehova Nyasaye: 
\q1  
\v 19 “Jehova Nyasaye nongʼiyo piny gie kare maler man malo, 
\q2 nongʼiyo piny gie polo, 
\q1  
\v 20 mondo owinj ywak joma otwe 
\q2 kendo ogony joma ongʼadnegi buch tho.” 
\q1  
\v 21 Kuom mano nying Jehova Nyasaye ibiro hul e Sayun, 
\q2 ibiro pake e Jerusalem, 
\q1  
\v 22 ka joma odak e pinjeruodhi ochokore 
\q2 mondo olam Jehova Nyasaye. 
\q1  
\v 23 Ka noyudo ngimana dhi maber to nomiyo tekona odok chien 
\q2 kendo nongʼado ngimana odoko machiek. 
\q1  
\v 24 Omiyo ne awacho niya, 
\q1 “Kik ikaw ngimana, yaye Nyasacha, kapod an e chuny ngima; 
\q2 in to isiko ingima nyaka tienge duto. 
\q1  
\v 25 Kar chakruok ne iketo mise mag piny, 
\q2 kendo polo bende gin tij lweti. 
\q1  
\v 26 Gin to ginilal nono in to isiko manyaka chiengʼ; 
\q2 giduto giniti mana kaka law ti. 
\q1 Ibiro lokogi kaka iloko law 
\q2 kendo ibiro witgi. 
\q1  
\v 27 In to isiko ichalri mana kaka in, 
\q2 kendo hiki ok norum. 
\q1  
\v 28 Nyithind jotichni biro dak buti machiegni; 
\q2 nyikwagi nodhi maber e nyimi.” 
\c 103  
\cl Zaburi 103 
\d Mar Daudi. 
\q1  
\v 1 Pak Jehova Nyasaye, yaye chunya; 
\q2 chunya maiye duto mondo opak nyinge maler. 
\q1  
\v 2 Pak Jehova Nyasaye, yaye chunya, 
\q2 kendo kik wiyi wil gi konyruok mochiwo, 
\q1  
\v 3 en ema oweyoni richoni duto 
\q2 kendo ochango tuocheni duto, 
\q1  
\v 4 oreso ngimani kogolo e bur matut 
\q2 kendo osidhi gihera kod kech, 
\q1  
\v 5 oromo chunyi gi gik mabeyo 
\q2 momiyo tin-ni osiko nyien ka mar ongo. 
\b  
\q1  
\v 6 Jehova Nyasaye timo gik makare 
\q2 kendo otimo maber ne joma isando duto. 
\b  
\q1  
\v 7 Nonyiso Musa timbe mane ochano timo, 
\q2 nomiyo jo-Israel oneno timbene. 
\q1  
\v 8 Jehova Nyasaye kecho ji kendo ongʼwon, 
\q2 iye ok wangʼ piyo kendo en gihera mangʼeny. 
\q1  
\v 9 Ok osik komanyo ketho kuom ji, 
\q2 bende ok okan mirimbe nyaka chiengʼ; 
\q1  
\v 10 ok otimnwa mowinjore gi richowa 
\q2 bende ok ochulwa kaluwore gi kethowa. 
\q1  
\v 11 Nimar kaka polo ni malo moyombo piny, 
\q2 e kaka herane duongʼ ne joma omiye luor; 
\q1  
\v 12 mana kaka wuok chiengʼ bor gi podho chiengʼ, 
\q2 e kaka osepogowa mabor gi kethowa. 
\b  
\q1  
\v 13 Mana kaka wuoro kecho nyithinde, 
\q2 e kaka Jehova Nyasaye kecho joma omiye luor; 
\q1  
\v 14 nimar ongʼeyo kaka ochweyowa, 
\q2 ongʼeyo e pache ni wan mana buch lowo. 
\q1  
\v 15 Dhano to ndalone chalo gi lum, 
\q2 oloth piyo ka maua mopidhi; 
\q1  
\v 16 to ka yamo okudhe matin nono to kare orumo, 
\q2 kendo ok chak pare. 
\q1  
\v 17 Hera ma Jehova Nyasaye oherogo joma omiye luor, 
\q2 to osiko manyaka chiengʼ, 
\q2 kendo osiko otimo maber ne nyithind nyithindgi, 
\q1  
\v 18 ma gin joma orito singruokne kendo jogo maparo 
\q2 mondo orit chikene. 
\b  
\q1  
\v 19 Jehova Nyasaye osechungo lochne e polo, 
\q2 kendo lochne orito ji duto. 
\q1  
\v 20 Pakuru Jehova Nyasaye, un malaikane duto, 
\q2 un joge maroteke matimo kaka odwaro, 
\q2 kendo matimo kaka owacho. 
\q1  
\v 21 Pakuru Jehova Nyasaye, un jopolo duto, 
\q2 un jotichne matimo dwarone. 
\q1  
\v 22 Pakuru Jehova Nyasaye, un gik moko duto mochweyo, 
\q2 manie bwo lochne kuonde duto. 
\b  
\q1 Pak Jehova Nyasaye, yaye chunya. 
\c 104  
\cl Zaburi 104 
\q1  
\v 1 Pak Jehova Nyasaye, yaye chunya. 
\q1 Yaye Jehova Nyasaye Nyasacha, mano kaka iduongʼ, 
\q2 irwakori gi luor kod duongʼ. 
\q1  
\v 2 Oumore gi ler mana kaka nanga; oyaro polo mana kaka hema 
\q2  
\v 3 kendo ogero ode moluore ewi pi. 
\q1 Oidho boche polo kaka gache mar lweny 
\q2 kendo yamo e ndike moriembo. 
\q1  
\v 4 Omiyo yembe bedo kaka jootene, 
\q2 kendo jotichne kaka ligek mach. 
\b  
\q1  
\v 5 Iseguro piny e mise mage; 
\q2 ma ok onyal yiengni kata matin. 
\q1  
\v 6 Ne iume gi kut mana kaka nanga 
\q2 mi pige obiwore moyombo gode. 
\q1  
\v 7 To kane ikwero pigego to ne gileny nono, 
\q2 kane giwinji kimor to ne giwalore gia; 
\q1  
\v 8 ne gimol ewi gode, 
\q2 ka giridore gidhi e holni, 
\q2 kuonde mane ochan-negi. 
\q1  
\v 9 Ne iketonegi tongʼ ma ok ginyal kadho; 
\q2 mondo kik gichak giim piny kendo. 
\b  
\q1  
\v 10 Jehova Nyasaye miyo sokni olo pi 
\q2 e bugni ka gimol e kind gode. 
\q1  
\v 11 Gichiwo pi ne le mag bungu duto; 
\q2 kanyna mag bungu tieko riyo ma gin-go. 
\q1  
\v 12 Winy mafuyo e kor polo ogero utegi e bath pigego, 
\q2 kendo giwer ewi yiende. 
\q1  
\v 13 Omiyo koth chue ewi gode koa e dalane manie polo; 
\q2 piny nyago olembe moromo nikech tijene. 
\q1  
\v 14 Omiyo lum loth ne jamni, 
\q2 kod cham ma dhano doyo, 
\q2 mamiyo chiemo yudore e piny; 
\q1  
\v 15 kaachiel gi divai mamoro chuny dhano, 
\q2 gi mo mamiyo lela wangʼe leny, 
\q2 kod makati molerogo chunye. 
\q1  
\v 16 Yiende Jehova Nyasaye yudo pi moromogi, 
\q2 yiendego gin sida mag Lebanon mane opidho. 
\q1  
\v 17 Kanyo ema winy geroe utegi, 
\q2 winj nyamnaha nigi utegi ewi yiende mag obudo. 
\q1  
\v 18 Diek mag bungu odak e gode maboyo, 
\q2 to lwendni morokore gin kuonde pondo mag aidha. 
\b  
\q1  
\v 19 Dwe pogo kinde mag chwiri gi kinde mag opon 
\q2 kendo wangʼ chiengʼ ongʼeyo sa monego opodhie. 
\q1  
\v 20 Ikelo mudho mi piny lokre otieno, 
\q2 kendo le mag bungu duto lak oko. 
\q1  
\v 21 Sibuoche ruto ka gimanyo chiemo; 
\q2 gimanyo chiembgi kuom Jehova Nyasaye. 
\q1  
\v 22 To ka chiengʼ wuok to gidok e bungu; 
\q2 gidok kendo ginindo e gondegi. 
\q1  
\v 23 Eka dhano wuok oko chako tijene, 
\q2 kendo nyagore gi tich nyaka odhiambo. 
\q1  
\v 24 Mano kaka gik michweyo ngʼeny, yaye Jehova Nyasaye! 
\q2 Ne ichweyogi duto gi rieko miwuoro; 
\q2 piny opongʼ gi gik michweyo. 
\q1  
\v 25 Isechweyo nam maduongʼ kendo malach 
\q2 mopongʼ gi le mamol mathoth mokalo akwana, 
\q2 gik mangima madongo gi matindo. 
\q1  
\v 26 Kuno ema meli kwangʼie koni gi koni, 
\q2 kendo ondieg nam mane ichweyo miluongo ni Leviathan tuge. 
\b  
\q1  
\v 27 In ema gigo duto ngʼiyi 
\q2 mondo imigi chiembgi e kinde mowinjore. 
\q1  
\v 28 Ka imiyogi chiemo, to gichamo; 
\q2 ka iyawonegi lweti, to giyiengʼ gi gik mabeyo; 
\q1  
\v 29 ka ipando wangʼi, to githagore; 
\q2 ka igolo muchi kuomgi, to githo kendo gidok e lowo. 
\q1  
\v 30 Ka ioro Roho mari, to gibedo mangima; 
\q2 kendo imiyo piny bedo gi ngima manyien. 
\b  
\q1  
\v 31 Mad duongʼ mar Jehova Nyasaye sik nyaka chiengʼ; 
\q2 mad Jehova Nyasaye bed mamor gi gik mane ochweyo. 
\q1  
\v 32 En e ma kongʼiyo piny to piny yiengni, 
\q2 kendo komulo gode to gode dhwolo iro. 
\b  
\q1  
\v 33 Abiro wer ne Jehova Nyasaye e ngimana duto, 
\q2 adier, abiro wero wende pak ne Nyasacha e kinde duto ma pod angima. 
\b  
\q1  
\v 34 Mad gik ma aparo e chunya omiye mor, 
\q2 seche duto ma amor kuom Jehova Nyasaye. 
\q1  
\v 35 Joricho to owinjore orum e piny; 
\q2 joma timbegi richo ok onego obedie piny kata achiel. 
\b  
\q1 Pak Jehova Nyasaye, yaye chunya. 
\q1 Pak Jehova Nyasaye. 
\c 105  
\cl Zaburi 105 
\q1  
\v 1 Pakuru Jehova Nyasaye, luonguru nyinge; 
\q2 landuru ne ogendini duto gima osetimo. 
\q1  
\v 2 Werneuru, pakeuru gi wende; 
\q2 nyisuru kuom tijene duto miwuoro. 
\q1  
\v 3 Nyinge maler nigi duongʼ; 
\q2 chuny joma manyo Jehova Nyasaye mondo obed mamor. 
\q1  
\v 4 Ranguru Jehova Nyasaye gi tekone; 
\q2 dwaruru wangʼe kinde duto. 
\b  
\q1  
\v 5 Paruru gik miwuoro mosetimo, 
\q2 honni mage kod buche mosengʼado, 
\q1  
\v 6 yaye un nyikwa Ibrahim jatichne, 
\q2 yaye yawuot Jakobo joge moyiero. 
\q1  
\v 7 En e Jehova Nyasaye ma Nyasachwa; 
\q2 buchene ni e piny duto. 
\b  
\q1  
\v 8 Oparo singruokne nyaka chiengʼ, 
\q2 weche mane osingo e tienge tara, 
\q1  
\v 9 singruok mane otimo gi Ibrahim, 
\q2 Muma mane okwongʼorego ni Isaka. 
\q1  
\v 10 Ne ogure ne Jakobo kaka chik, 
\q2 kendo nogure ni Israel kaka singruok mochwere, kowacho ni, 
\q1  
\v 11 “Anamiyi piny Kanaan 
\q2 kaka girkeni mari.” 
\b  
\q1  
\v 12 Kane pod gin ji manok e kar rombgi, 
\q2 ne ginok ahinya kendo ne gin welo e pinyno, 
\q1  
\v 13 ne giwuotho e kind ogendini mopogore, 
\q2 ka gidhi e pinyruodhi mopogore opogore. 
\q1  
\v 14 Ne ok oyie mondo ngʼato osandgi; 
\q2 nokwero ruodhi kowachonegi niya, 
\q1  
\v 15 “Kik umul joga ma awiro; 
\q2 kik uhiny jonabi maga.” 
\b  
\q1  
\v 16 Ne okelo kech e piny 
\q2 kendo noketho yore duto mane giyudogo chiemo; 
\q1  
\v 17 kendo nooro ngʼato otelonegi, 
\q2 ngʼatno ne en Josef mane oloki kaka misumba. 
\q1  
\v 18 Ne giridho tiendene gi arungu mochuoye chuma, 
\q2 kendo ne giridho ngʼute gi chumbe, 
\q1  
\v 19 nyaka nochopo kinde ma gik mane okoro notimore, 
\q2 nyaka wach Jehova Nyasaye nochopo kare. 
\q1  
\v 20 Ruodh Misri nooro wach mi nogonye 
\q2 jatend ji nogonye thuolo. 
\q1  
\v 21 Nokete ruodh ode, 
\q2 manorito gik moko duto mane en-go, 
\q1  
\v 22 mondo en ema ne otieg jotende kaka ohero 
\q2 kendo opuonj jodonge. 
\b  
\q1  
\v 23 Bangʼe Israel duto nobiro Misri; 
\q2 Jakobo nodoko jadak e piny Ham. 
\q1  
\v 24 Jehova Nyasaye nomiyo joge onya ahinya; 
\q2 nomiyo gibedo mathoth ma wasikgi ne ok nyal nyalogi, 
\q1  
\v 25 wasikgi ma noloko chunygi mondo ocha joge, 
\q2 kendo noketo chunye mar timo ne jotichne marach. 
\q1  
\v 26 Nooro Musa jatichne, 
\q2 gi Harun, ngʼat mane oseyiero. 
\q1  
\v 27 Negitimo ranyisi mag honni e diergi, 
\q2 ee, negitimo timbene miwuoro e piny Ham. 
\q1  
\v 28 Nooro mudho mi nomiyo piny olil 
\q2 nimar donge ne gisengʼanyo ne wechene? 
\q1  
\v 29 Noloko pigegi remo, 
\q2 mi nomiyo rechgi otho. 
\q1  
\v 30 Ogwende nosieko mopongʼo pinygi, 
\q2 kendo negidonjo nyaka ei ute nindo mag ruodhigi. 
\q1  
\v 31 Nowuoyo, mi pumbi mag lwangʼni nosieko, 
\q2 kendo kikun nopongʼo pinygi. 
\q1  
\v 32 Nomiyo kodhi olokore pe 
\q2 kendo mil polo nokwako pinygi; 
\q1  
\v 33 nogoyo yiendegi mag mzabibu gi ngʼowu piny 
\q2 kendo nolwero yiende mane ni e pinygi. 
\q1  
\v 34 Nowuoyo, mi bonyo nosieko, 
\q2 ongogo mokalo akwana; 
\q1  
\v 35 negichamo gimoro amora mane loth 
\q2 e pinygi koda ka chambgi mane gipidho e puothegi. 
\q1  
\v 36 Bangʼe nonego nyithindo makayo duto mane ni e pinygi, 
\q2 kodhi mokwongo duto mane gihango nywolo. 
\q1  
\v 37 Nogolo Israel, kogangore gi fedha kod dhahabu, 
\q2 kendo onge ngʼama nodongʼ chien kuom dhout Israel duto. 
\q2  
\v 38 Misri ne mor kane giwuok, 
\q2 nikech mbi mar jo-Israel nosegore kuomgi. 
\b  
\q1  
\v 39 Noumogi gi boche polo kaka raum, 
\q2 kendo mach nochiwonegi ler gotieno. 
\q1  
\v 40 Kane gikwaye, to nokelonegi aluru 
\q2 kendo noyiengʼogi gi makati mar polo. 
\q1  
\v 41 Noyawo lwanda, mi pi nowuok gi teko; 
\q2 kendo pigno nomol ka aora mamol e piny motwo. 
\b  
\q1  
\v 42 Nimar noparo singruokne maler 
\q2 mane omiyo Ibrahim jatichne. 
\q1  
\v 43 Nogolo joge gi ilo, 
\q2 adier, nomiyo joge moyier owuok kakok gi mor; 
\q1  
\v 44 nomiyogi pinje mag ogendini, 
\q2 kendo gik ma jomoko nono nochandore ka loso nodoko girkeni magi, 
\q1  
\v 45 mondo omi gilu yorene 
\q2 kendo girit chikene. 
\b  
\q1 Pak ne Jehova Nyasaye! 
\c 106  
\cl Zaburi 106 
\q1  
\v 1 Pakuru Jehova Nyasaye! 
\q1 Gouru erokamano ne Jehova Nyasaye, nikech ober; 
\q2 kendo herane osiko manyaka chiengʼ. 
\q1  
\v 2 En ngʼa manyalo hulo gik madongo ma Jehova Nyasaye osetimo 
\q2 kata manyalo nyiso pakne duto? 
\q1  
\v 3 Ogwedh joma osiko koluwo adiera, 
\q2 joma osiko katimo gima kare. 
\b  
\q1  
\v 4 An bende parae, yaye Jehova Nyasaye, 
\q2 parae ka itimo ngʼwono ne jogi, bi ikonya ka iresogi, 
\q1  
\v 5 mondo an bende awinjie maber gi mwandu mimiyo jogi miyiero, 
\q2 mondo ayudie mor mar ogandani, 
\q2 kendo amiyi duongʼ kaachiel gi girkeni mari. 
\b  
\q1  
\v 6 Wasetimo richo mana kaka kwerewa bende notimo; 
\q2 wasetimo marach kendo wasetimo gik mamono. 
\q1  
\v 7 Kane kwerewa ni Misri, 
\q2 ne ok giparo matut kuom honni magi; 
\q1 bende ne wigi owil gi kechni mathoth, 
\q2 ne gingʼanyoni e dho nam, ma en Nam Makwar. 
\q1  
\v 8 Kata kamano noresogi nikech nyinge, 
\q2 mondo omi tekone maduongʼ ongʼere. 
\q1  
\v 9 Nokwero Nam Makwar, mi Nam Makwar notwo; 
\q2 kendo nomiyo gikalo kama tut mana ka gima ne giwuotho kama otwo. 
\q1  
\v 10 Noresogi e lwet joma ne kedo kodgi, 
\q2 adier, nowarogi e lwet wasigu. 
\q1  
\v 11 Pi noimo wasikgi; 
\q2 ma kata achiel kuomgi ne ok otony. 
\q1  
\v 12 Eka ne giyie gi singruok mage 
\q2 kendo ne gipake gi wer. 
\b  
\q1  
\v 13 To ma ok wigi nowil gi gik mane osetimo 
\q2 kendo ne ok girite mondo ongʼadnegi rieko. 
\q1  
\v 14 Wuoro mokalo tongʼ nomakogi e thim, 
\q2 kendo ne gitemo Nyasaye e piny motwo. 
\q1  
\v 15 Omiyo ne omiyogi gima negidwaro, 
\q2 to kata kamano nooronegi tuo machiyo del. 
\b  
\q1  
\v 16 Nyiego nomakogi gi Musa e kambi, 
\q2 kendo gi Harun, jatich mowal ni Jehova Nyasaye. 
\q1  
\v 17 Piny ne oyawore mi nomwonyo Dathan; 
\q2 piny noiko oganda joka Abiram. 
\q1  
\v 18 Mach nomuoch kuom joma luwogi; 
\q2 mach maliel mager nowangʼo joma timbegi richogo motiekogi pep. 
\q1  
\v 19 Negiloso nyaroya Horeb, 
\q2 mine gilamo kido molos gi chuma. 
\q1  
\v 20 Ne giwilo Duongʼ margi 
\q2 gi kido mar rwath machamo lum. 
\q1  
\v 21 Wigi nowil gi Nyasaye mane oresogi, 
\q2 Nyasaye mane osetimo gik madongo e piny Misri, 
\q1  
\v 22 Nyasaye mane osetimo honni e piny Ham 
\q2 kod timbe miwuoro e dho Nam Makwar. 
\q1  
\v 23 Emomiyo nowacho ni nobiro tiekogi 
\q2 ka dine Musa, ngʼate moyiero, 
\q1 we chungʼ kaywagore e nyime 
\q2 mondo ogengʼ mirimbe kik otiekgi. 
\b  
\q1  
\v 24 Bangʼe ne gichayo pinye ma jaber; 
\q2 nikech ne ok giyie singruokne ni en adier. 
\q1  
\v 25 Ne gingʼur ei hembegi 
\q2 kendo ne ok gitimo gik ma Jehova Nyasaye nochikogi. 
\q1  
\v 26 Emomiyo ne osingorenegi kosiemogi 
\q2 gi lwete nine obiro miyo gipodhi e thim, 
\q1  
\v 27 nonyisogi ni ne obiro miyo nyikwagi podhi e kind ogendini, 
\q2 kendo ni ne obiro keyogi e pinje duto. 
\b  
\q1  
\v 28 Ne giriwore kaachiel e lamo Baal mar jo-Peor, 
\q2 kendo negichamo misango michiwone nyiseche motho; 
\q1  
\v 29 omiyo ne giwangʼo i Jehova Nyasaye gi timbegi marichogo, 
\q2 mi masira nomakogi. 
\q1  
\v 30 Kata kamano Finehas nochungʼ kargi kendo noywagore ne Nyasaye, 
\q2 mi masirano ne ok otiekogi. 
\q1  
\v 31 Nyasaye nokwane kaka ngʼama kare nikech timneno, 
\q2 kendo ibiro kwane kamano nyaka tienge mabiro. 
\q1  
\v 32 Ne giwangʼo i Jehova Nyasaye, e dho sokni mag Meriba, 
\q2 mi timgino nokelone Musa chandruok; 
\q1  
\v 33 nimar negiketho chunye 
\q2 mi weche maricho nowuok e dhoge. 
\b  
\q1  
\v 34 Ne ok gitieko ogendini chutho 
\q2 kaka Jehova Nyasaye nosechikogi, 
\q1  
\v 35 to ne giriwore kodgi 
\q2 kendo negiluwo timbegi. 
\q1  
\v 36 Negilamo kido mag nyisechegi, 
\q2 ma bangʼe nolokorenegi obadho. 
\q1  
\v 37 Negichiwo yawuotgi gi nyigi kaka misango, 
\q2 kendo negichiwogi ne jochiende. 
\q1  
\v 38 Ne gichwero remo maonge ketho, 
\q2 remb yawuotgi gi nyigi, 
\q1 mane gichiwo kaka misango ne kido mag nyiseche mag Kanaan, 
\q2 mi piny nogak nikech rembgi. 
\q1  
\v 39 Negidoko mogak nikech gik mane gitimo; 
\q2 negibedo joma odwanyore, 
\q2 nikech timbegigo. 
\b  
\q1  
\v 40 Emomiyo Jehova Nyasaye nokecho gi joge 
\q2 kendo chunye noa kuom girkeni mare. 
\q1  
\v 41 Nochiwogi e lwet ogendini, 
\q2 mine gibet e bwo loch joma ne mon kodgi. 
\q1  
\v 42 Wasikgi nothirogi 
\q2 kendo negiketogi e bwo tekogi. 
\q1  
\v 43 Ne oresogi nyadi mangʼeny 
\q2 to kata kamano joge noketo chunygi ne ngʼanyo, 
\q2 mi richogi nochiwogi mi girumo. 
\q1  
\v 44 Kata kamano nokechogi e chandruokgi 
\q2 kane owinjo ywakgi; 
\q1  
\v 45 nikech noparo singruok mane otimo kodgi 
\q2 kendo noloko chunye nikech herane maduongʼ. 
\q1  
\v 46 Nochuno ji duto mane oketogi wasumbini 
\q2 mondo okechgi. 
\b  
\q1  
\v 47 Reswa, yaye Jehova Nyasaye ma Nyasachwa, 
\q2 kendo chokwa igolwa e dier ogendini, 
\q1 mondo wadwok erokamano ne nyingi maler 
\q2 kendo wabed mamor kwapaki. 
\b  
\b  
\q1  
\v 48 Pakuru Jehova Nyasaye, ma Nyasach Israel, 
\q2 mochwere manyaka chiengʼ. 
\b  
\q1 Ji duto mondo owach niya, “Amin!” 
\q1 Opak Jehova Nyasaye. 
\c 107  
\ms1 Kitabu mar Abich 
\mr Zaburi 107–150 
\cl Zaburi 107 
\q1  
\v 1 Gouru erokamano ne Jehova Nyasaye, nimar ober; 
\q2 herane osiko nyaka chiengʼ. 
\b  
\q1  
\v 2 Joma owar mag Jehova Nyasaye mondo owach kama 
\q2 joma ne owaro e lwet jasigu, 
\q1  
\v 3 mane ochoko kogolo e pinje, 
\q2 kochakore wuok chiengʼ gi podho chiengʼ, 
\q2 nyaka nyandwat gi milambo. 
\b  
\q1  
\v 4 Joge moko nobayo abaya e thim motwo 
\q2 nikech ne gionge yo mar chopo e dala mane ginyalo dakie gi kwe. 
\q1  
\v 5 Ne gidenyo kendo riyo noloyogi, 
\q2 chunygi noa. 
\q1  
\v 6 Eka ne giywakne Jehova Nyasaye mondo okonygi e chandruokgino 
\q2 mi noresogi e pekgino. 
\q1  
\v 7 Ne otelonegi e yo moriere tir, 
\q2 nyaka negichopo e dala, mane ginyalo dakie. 
\q1  
\v 8 Onego gigo ne Jehova Nyasaye erokamano kuom herane ma ok rem 
\q2 kendo kuom timbene miwuoro, motimo ne ji, 
\q1  
\v 9 nimar otieko riyo mar joma riyo oloyo 
\q2 kendo omiyo joma odenyo yiengʼ gi gik mabeyo. 
\b  
\q1  
\v 10 Moko kuomgi nobet e mudho, kendo e tipo mar tho, 
\q2 ne gin joma thagore motwe gi nyoroche mag chuma, 
\q1  
\v 11 nimar ne gingʼanyo giweyo weche Nyasaye 
\q2 kendo ne gichayo rieko mar Nyasaye Man Malo Moloyo. 
\q1  
\v 12 Omiyo noketogi gi tich matek mohewogi mine gigore piny 
\q2 kendo onge ngʼama ne nyalo konyogi. 
\q1  
\v 13 Eka ne giywakne Jehova Nyasaye mondo okonygi e chandruokgino, 
\q2 mi noresogi e pekgino. 
\q1  
\v 14 Nogologi e mudho kendo e tipo mar tho 
\q2 kendo noturo nyoroche mane otuegigo. 
\q1  
\v 15 Onego gigo ne Jehova Nyasaye erokamano kuom herane ma ok rem, 
\q2 kendo kuom timbene miwuoro motimo ne ji, 
\q1  
\v 16 nimar omuko rangeye mag mula, 
\q2 kendo ongʼado lodi mag nyinyo. 
\b  
\q1  
\v 17 Moko kuomgi nobedo joma ofuwo nikech yoregi mobam 
\q2 kendo negineno thagruok nikech timbegi mamono. 
\q1  
\v 18 Dhogi ne rach ma ok ginyal chamo chiemo moro amora, 
\q2 kendo ne gichiegni tho. 
\q1  
\v 19 Eka ne giywakne Jehova Nyasaye mondo okonygi e chandruokgino 
\q2 mi noresogi e pekgino. 
\q1  
\v 20 Ne ooro wachne mi nochangogi 
\q2 kendo noresogi e lak tho. 
\q1  
\v 21 Onego gigo ne Jehova Nyasaye erokamano kuom herane ma ok rem 
\q2 kendo kuom timbene miwuoro motimo ne ji. 
\q1  
\v 22 Onego gichiwne misango mar goyo erokamano 
\q2 kendo ginyis kuom gik mosetimo ka giwer gi mor. 
\b  
\q1  
\v 23 Moko kuomgi nodhi kwangʼ e nam gi meli; 
\q2 ne gin jo-ohala ma yoro nembe madongo dongo. 
\q1  
\v 24 Negineno tije Jehova Nyasaye, 
\q2 negineno tijene malich miwuoro manie kude. 
\q1  
\v 25 Nimar ne owuoyo, mi notugo ahiti mangʼongo 
\q2 ma nomiyo apaka ogingore. 
\q1  
\v 26 Apaka nodirogi malo e kor yamo, 
\q2 kendo nonyumogi kuonde matut mogik; 
\q2 mi chir mane gin-go noleny nono kane ginie masira ma kamano. 
\q1  
\v 27 Ne gipuore kendo gitagore ka joma omer; 
\q2 kendo pachgi nolalnegi. 
\q1  
\v 28 Eka ne giywakne Jehova Nyasaye mondo okonygi e chandruokgino 
\q2 mi noresogi e pekgino; 
\q1  
\v 29 ne okweyo ahiti mobet mos; 
\q2 kendo apaka nolingʼ thi. 
\q1  
\v 30 Negidoko mamor ka nam nokwe, 
\q2 kendo notelonegi nyaka negichopo e dho wath maber, kama negidwaro chopoe. 
\q1  
\v 31 Onego gigo ne Jehova Nyasaye erokamano kuom herane ma ok rem 
\q2 kendo kuom timbene miwuoro motimo ne ji. 
\q1  
\v 32 Onego gitingʼ nyinge malo e chokruok mar joge 
\q2 kendo gidende e buch jodongo. 
\b  
\q1  
\v 33 Ne omiyo aore olokore kuonde motwo, 
\q2 sokni mamol nolokore ongoro, 
\q1  
\v 34 kendo lowo manyak maber nodoko lowo motimo chumbi, 
\q1 maonge tich nikech timbe mamono 
\q2 mag joma nodak kuondego. 
\q1  
\v 35 To bende nomiyo piny ongoro odoko yewni mag pi, 
\q2 kendo lowo motwo nolokore sokni mamol; 
\q1  
\v 36 nokelo joma odenyo mondo odag kuondego, 
\q2 kendo negigero dala kama neginyalo dakie. 
\q2  
\v 37 Ne gipuro puothe kendo ne gipidho puothe mzabibu, 
\q2 mane ochiego cham maber; 
\q1  
\v 38 ne ogwedhogi, kendo negidoko ji mangʼeny ahinya, 
\q2 bende ne ok oyie mondo jambgi odog piny. 
\b  
\q1  
\v 39 Bangʼe achien kwan-gi nodok matin 
\q2 kendo ne odwokgi piny nikech sand gi masiche kod kuyo; 
\q1  
\v 40 Jal ma olo mirimbe kuom ruodhi 
\q2 nomiyo gibayo koni gi koni e thim. 
\q1  
\v 41 To jochan to noreso e thagruokgi, 
\q2 kendo nomiyo joutegi onya ka rombe. 
\q1  
\v 42 Joma kare neno kendo gidoko mamor; 
\q2 To joma timbegi richo dhogi moko. 
\b  
\q1  
\v 43 Ngʼama riek mondo omak wechegi maber, 
\q2 kendo opar matut kuom hera maduongʼ mar Jehova Nyasaye. 
\c 108  
\cl Zaburi 108 
\d Wer. Zaburi mar Daudi. 
\q1  
\v 1 Chunya ochungʼ mongirore, yaye Nyasaye; 
\q2 abiro paki gi wer kendo abiro loso mamit gi chunya duto. 
\q1  
\v 2 Chiewuru, un orutu gi nyatiti! 
\q2 Abiro chiewo kogwen. 
\q1  
\v 3 Abiro paki e dier ogendini, yaye Jehova Nyasaye, 
\q2 abiro werni e dier ogendini. 
\q1  
\v 4 Nikech herani maduongʼ chopo nyaka e polo; 
\q2 kendo adiera mari chopo nyaka ewi lwasi. 
\q1  
\v 5 Nyingi mondo otingʼ malo moyombo polo, yaye Nyasaye, 
\q2 mad duongʼ mari opongʼ piny duto. 
\b  
\q1  
\v 6 Reswa kendo konywa gi lweti ma korachwich, 
\q2 mondo joma ihero ogol e chandruok. 
\q1  
\v 7 Nyasaye osewuoyo gie kare maler kowacho niya, 
\q2 “Abiro pogo Shekem ne ji, 
\q2 kendo abiro pimo ne ji Holo mar Sukoth. 
\q1  
\v 8 Gilead en mara, Manase bende mara, 
\q2 Efraim en oguta mar lweny, 
\q2 to Juda en osimbona mar loch. 
\q1  
\v 9 Moab en besen mara mar luok, 
\q2 to Edom e kama amoe wuochena; 
\q2 Filistia ema akoke ka aseloyo lweny.” 
\b  
\q1  
\v 10 En ngʼa mabiro kela e dala maduongʼ mochiel motegno? 
\q2 En ngʼa mabiro telona nyaka Edom? 
\q1  
\v 11 Donge in ema isedagiwa, yaye Nyasaye, 
\q2 kendo tinde ok idhi gi jolwenjwa e lweny? 
\q1  
\v 12 Miwa kony mondo walo wasikwa, 
\q2 nikech kony mar dhano onge tich. 
\q1  
\v 13 Wabiro loyo lweny ka Nyasaye nikodwa, 
\q2 kendo obiro nyono wasikwa piny. 
\c 109  
\cl Zaburi 109 
\d Kuom jatend wer. Zaburi mar Daudi. 
\q1  
\v 1 Yaye Nyasaye ma apako, 
\q2 kik ilingʼ, 
\q1  
\v 2 nimar joma timbegi richo gi jo-miriambo osemonja gi wechegi; 
\q2 gisewuoyo kuomwa marach, 
\q2 adier gisewacho miriambo kuoma. 
\q1  
\v 3 Gilwora koni gi koni gi weche mag achaya; 
\q2 gibuka maonge gima omiyo. 
\q1  
\v 4 An aherogi to gin to gimon koda. 
\q2 Gitimona kamano kata obedo ni an to alemonegi. 
\q1  
\v 5 Gichula rach kar ber, 
\q2 kod achaya kar osiep. 
\b  
\q1  
\v 6 Ket ngʼat marach mondo oked kod jasika; 
\q2 we jadonj ne ji mondo ochungʼ kode e bura. 
\q1  
\v 7 Kiyale to mi mondo oyude gi ketho, 
\q2 kendo kata lemo molamo onego onyis kethone. 
\q1  
\v 8 Mad ngʼad ndalone dok manok; 
\q2 kendo mad ngʼat machielo kaw tije. 
\q1  
\v 9 Mad nyithinde dongʼ kiye 
\q2 kendo chiege dongʼ dhako ma chwore otho. 
\q1  
\v 10 Mad nyithinde lokre jokwecho mabayo abaya; 
\q2 mad riembgi gia koda ka e miechgi mosekethore. 
\q1  
\v 11 Mad jagope moro mak gige duto ma en-go 
\q2 kendo mad joma welo oyak mwandu duto moseloso. 
\q1  
\v 12 Onego ngʼato kik timne ngʼwono 
\q2 kata kecho nyithinde modongʼ kiye. 
\q1  
\v 13 Kothe duto mondo kargi olal nono, 
\q2 kendo nying-gi oruchi kik bedi e tiengʼ mabiro. 
\q1  
\v 14 Mad Jehova Nyasaye sik kaparo richo mane wuonegi otimo; 
\q2 kendo mad richo min kik ruchi. 
\q1  
\v 15 Richogi mondo osiki e nyim Jehova Nyasaye, 
\q2 eka mondo ongʼad kargi oko chuth e piny. 
\q1  
\v 16 Nimar kane ongima to ne ok odewo timo ngʼwono, 
\q2 kar timo kamano to nosando jodhier, 
\q1 kaachiel gi joma ochando gi joma chunygi lit; 
\q2 nosandogi malit nyaka ne githo. 
\q1  
\v 17 Nohero kwongʼo ji 
\q2 to koro mad kwongʼneno dogne; 
\q1 ne ok ohero gwedho ji 
\q2 omiyo koro mad gweth bed mabor kode. 
\q1  
\v 18 Ne orwako kwongʼ ka nangane; 
\q2 mad kwongʼno koro donji e dende ka pi, 
\q2 mad gibud chokene ka mo. 
\q1  
\v 19 Mad ochal nanga moumogo dende duto, 
\q2 kata kamba motweyego nyaka chiengʼ. 
\q1  
\v 20 Mano ema mondo obed chudo, ma Jehova Nyasaye chulo joma donjona; 
\q2 mano e kaka onego otim ne joma wuoyo marach kuoma. 
\b  
\q1  
\v 21 To in, yaye Jehova Nyasaye Manyalo Gik Moko Duto, 
\q2 timna maber nikech nyingi; 
\q2 konya nikech ber mar herani. 
\q1  
\v 22 Nimar adhier kendo achando, 
\q2 kendo chunya winjo marach e iya. 
\q1  
\v 23 Ndalona rumo mos mos ka tipo mar odhiambo 
\q2 kendo yamo uka ka det bonyo. 
\q1  
\v 24 Chongena onyosore nikech onge gima acham, 
\q2 kendo adhero alokora choke lilo. 
\q1  
\v 25 Alokora gima ijaro ne joma donjona; 
\q2 ka ginena to gitwenyona umgi ka gigoyona siboi. 
\b  
\q1  
\v 26 Konya, yaye Jehova Nyasaye Nyasacha, 
\q2 resa kaluwore gi herani. 
\q1  
\v 27 Mi mondo gingʼe ni achal kama nikech lweti, 
\q2 mi gingʼe ni lweti ema osetime, yaye Jehova Nyasaye. 
\q1  
\v 28 Gin ginyalo kwongʼa to angʼeyo ni in ibiro gwedha; 
\q2 ka gimonja to ibiro kuodo wigi, 
\q2 to jatichni to biro bedo mamor. 
\q1  
\v 29 Wichkuot maduongʼ biro mako joma donjona 
\q2 kendo gibiro rwako wichkuot ka kandho. 
\b  
\q1  
\v 30 Abiro dhialo Jehova Nyasaye malich gi dhoga; 
\q2 abiro pake e dier oganda maduongʼ. 
\q1  
\v 31 Nimar ochungʼ e bat korachwich mar ngʼat mochando, 
\q2 mondo ores ngimane kuom joma ngʼadone buch tho. 
\c 110  
\cl Zaburi 110 
\d Zaburi mar Daudi. 
\q1  
\v 1 Jehova Nyasaye nowachone Ruodha kama: 
\q2 “Bed e bada korachwich, 
\q1 nyaka chop aket wasiki 
\q2 e bwo tiendi.” 
\b  
\q1  
\v 2 Jehova Nyasaye biro yaro lochni chakre Sayun; 
\q2 ibiro bedo gi loch e dier wasiki. 
\q1  
\v 3 Jokedo magi biro bedo gi chuny moikore; 
\q2 gibiro riedo gokinyi kogwen gi duongʼ mamalo, 
\q1 kendo tekri nomedre odiechiengʼ kodiechiengʼ 
\q2 mana ka tho momoko e lum gokinyi. 
\b  
\q1  
\v 4 Jehova Nyasaye osekwongʼore 
\q2 kendo ok nolok pache, 
\q1 osesingore niya, “In jadolo nyaka chiengʼ, 
\q2 koluwo kit dolo mar Melkizedek.” 
\b  
\q1  
\v 5 Jehova Nyasaye ni e badi ma korachwich 
\q2 obiro loyo ruodhi chiengʼ ma mirimbe otuk. 
\q1  
\v 6 Obiro ngʼado bura ne ogendini, 
\q2 mi opiel joma otho achana-achana kotieko jotelo duto mag piny. 
\q1  
\v 7 Obiro modho e aora matin manie bath yo, 
\q2 emomiyo noyud teko mi otingʼ wiye. 
\c 111  
\cl Zaburi 111 
\q1  
\v 1 Pak ne Jehova Nyasaye! 
\q1 Abiro miyo Jehova Nyasaye duongʼ gi chunya duto, 
\q1 abiro miye duongʼ e buch joma kare kendo e dier chokruok. 
\q1  
\v 2 Tije Jehova Nyasaye dongo adier; 
\q2 joma mor kodgi osiko kaparo kuomgi. 
\q1  
\v 3 Timbene nigi duongʼ kod luor, 
\q2 kendo timne makare osiko nyaka chiengʼ. 
\q1  
\v 4 Omiyo waparo kuom honni mage; 
\q2 nikech Jehova Nyasaye ngʼwon kendo okecho ji. 
\q1  
\v 5 Ochiwo chiemo ne joma omiye luor, 
\q2 kendo oparo singruok mare nyaka chiengʼ. 
\b  
\q1  
\v 6 Osenyiso joge tekre kuom gik motimo 
\q2 komiyogi lope mag ogendini moko. 
\q1  
\v 7 Tije motimo gi lwetene nikare 
\q2 kendo beyo kendo buchene duto inyalo geno. 
\q1  
\v 8 Gingirore kendo ok gilokre mochwere manyaka chiengʼ, 
\q2 nikech osetimgi gi adiera kendo moriere. 
\q1  
\v 9 Ne ochiwo warruok ne joge, 
\q2 kendo ne oguro singruokne mosiko; 
\q2 nyinge ler kendo lich miwuoro. 
\b  
\q1  
\v 10 Luoro Jehova Nyasaye e chakruok mar rieko; 
\q2 ji duto moluwo buchene nigi winjo maber. 
\q2 En kende ema owinjore yudo pak manyaka chiengʼ. 
\c 112  
\cl Zaburi 112 
\q1  
\v 1 Pak ne Jehova Nyasaye! 
\q1 Ogwedh ngʼama oluoro Jehova Nyasaye, 
\q2 kendo marito chikene gi mor. 
\b  
\q1  
\v 2 Nyithinde nobed joma roteke e piny; 
\q2 ee, koth joma ngimagi oriere tir ibiro gwedhi. 
\q1  
\v 3 Pith gi mwandu yudore e ode, 
\q2 kendo timne makare osiko nyaka chiengʼ. 
\q1  
\v 4 Ngʼama ngimane oriere ler rienyne kata gotieno, ngʼat mangʼwon, 
\q2 ma kecho ji kendo makare. 
\q1  
\v 5 Ngʼama ngʼwon ma holo ji gige gi chuny maler biro neno ber 
\q2 ngʼat matiyo tijene gi adiera. 
\b  
\q1  
\v 6 Adier, onge gima nyalo yienge, 
\q2 ngʼat makare ibiro par nyaka chiengʼ. 
\q1  
\v 7 Ok oluoro weche makelo kuyo 
\q2 nikech chunye otegno kendo ogeno kuom Jehova Nyasaye. 
\q1  
\v 8 Chunye ok chandre kendo oonge gi luoro moro amora; 
\q2 ongʼeyo ni obiro neno ka olo wasike ka en to olocho. 
\q1  
\v 9 Gisepogo gigegi ne joma odhier, bergi osiko nyaka chiengʼ; 
\q2 duongʼne gi luor ma ji oluorego, 
\q2 biro siko nyaka chiengʼ. 
\b  
\q1  
\v 10 Ngʼama timbene richo biro nene mi iye wangʼ, 
\q2 obiro mwodo lekene kendo obiro chiyore morum; 
\q2 gik ma ngʼama timbene richo gombo ni otimrene ok bi timorene ngangʼ. 
\c 113  
\cl Zaburi 113 
\q1  
\v 1 Opak Jehova Nyasaye! 
\q1 Pakuru Jehova Nyasaye, yaye un jotichne, 
\q2 pakuru nying Jehova Nyasaye. 
\q1  
\v 2 Nying Jehova Nyasaye mondo opaki, 
\q2 sani kendo nyaka chiengʼ. 
\q1  
\v 3 Nying Jehova Nyasaye onego opaki, 
\q2 chakre kuma chiengʼ wuokie, 
\q2 nyaka kuma opodhoe. 
\b  
\q1  
\v 4 Jehova Nyasaye nigi duongʼ moyombo ogendini duto, 
\q2 kendo duongʼne maler oyombo polo. 
\q1  
\v 5 En ngʼa machalo gi Jehova Nyasaye ma Nyasachwa, 
\q2 Jal mobet e kom loch kuma bor, 
\q1  
\v 6 kendo makulore piny 
\q2 mondo ongʼi polo gi piny? 
\b  
\q1  
\v 7 Otingʼo joma odhier malo kogolo piny e lowo; 
\q2 adier, ogolo joma ochando e pidh buru, 
\q1  
\v 8 kendo oketogi gibet kaachiel gi ruodhi, 
\q2 mi kwan-gi kaachiel gi jotend jogi. 
\q1  
\v 9 Omiyo dhako ma migumba bedo gi ode 
\q2 mi obed miyo mamor man-gi nyithinde. 
\b  
\q1 Opak Jehova Nyasaye! 
\c 114  
\cl Zaburi 114 
\q1  
\v 1 Kane jo-Israel owuok Misri, 
\q2 ee, kane joka Jakobo owuok e kind joma wacho dhok mopogore, 
\q1  
\v 2 Juda nodoko kama ler mar lemo mar Nyasaye, 
\q2 kendo Israel nobedo mwandune owuon. 
\b  
\q1  
\v 3 Nam nonenogi mi oa gi ngʼwech, 
\q2 kendo Jordan ne odar oweyonigi piny, 
\q1  
\v 4 gode nolengʼore ka imbe, 
\q2 to thuche to nochikore ka nyirombe. 
\b  
\q1  
\v 5 Angʼo momiyo ne ia gi ngʼwech, yaye nam? 
\q2 Yaye Jordan, ne idar iweyonegi piny nangʼo? 
\q1  
\v 6 To un gode to ne ulengʼoru ka imbe nangʼo? 
\q2 Koso thuche to nochikore ka nyirombe nikech angʼo? 
\b  
\q1  
\v 7 Yaye piny, yiengni ka Ruoth Nyasaye ni machiegni kodi, 
\q2 yiengni e nyim Nyasach Jakobo, 
\q1  
\v 8 Nyasaye mane omiyo lwanda olokore pi mogudore, 
\q2 kendo mane omiyo lwanda matek olokore sokni mag pi. 
\c 115  
\cl Zaburi 115 
\q1  
\v 1 Ok wan, ok wan, yaye Jehova Nyasaye, 
\q2 to In ema nyingi oyud duongʼ, 
\q2 nikech herani kod adierani. 
\b  
\q1  
\v 2 Angʼo momiyo ogendini penjo niya, 
\q2 “Nyasachgino ere?” 
\q1  
\v 3 Nyasachwa ni e polo; 
\q2 otimo gimoro amora mohero. 
\q1  
\v 4 To nyisechegi mopa gin fedha gi dhahabu, 
\q2 molos gi lwet dhano. 
\q1  
\v 5 Gin gi dhogi, to kata kamano ok ginyal wuoyo, 
\q2 gin gi wenge to ok ginyal neno gimoro. 
\q1  
\v 6 Gin gi it, to ok ginyal winjo wach, 
\q2 kendo gin gi um, to ok ginyal ngʼwecho. 
\q1  
\v 7 Gin gi lwetegi, to ok ginyal mulo, 
\q2 kendo gin gi tiende to ok ginyal wuotho, 
\q2 bende ok ginyal kata temo loso gi dwondgi. 
\q1  
\v 8 Joma losogi nobed machal kodgi, 
\q2 kendo joma oketo genogi kuomgi bende biro chalo kodgi. 
\b  
\q1  
\v 9 Yaye dhood jo-Israel, genuru kuom Jehova Nyasaye, 
\q2 En e konyruokgi kendo okumbagi. 
\q1  
\v 10 Yaye dhood joka Harun, genuru kuom Jehova Nyasaye, 
\q2 En e konyruokgi kendo okumbagi. 
\q1  
\v 11 Un joma omiyo Jehova Nyasaye luor, keturu genou kuome, 
\q2 En e konyruokgi kendo okumbagi. 
\b  
\q1  
\v 12 Jehova Nyasaye parowa kendo obiro gwedhowa; 
\q2 obiro gwedho dhood Israel, 
\q2 obiro gwedho dhood joka Harun, 
\q1  
\v 13 obiro gwedho joma oluoro Jehova Nyasaye, 
\q2 ji ajia kod joma igeno. 
\b  
\q1  
\v 14 Mad Jehova Nyasaye mi imedri, 
\q2 in kaachiel gi nyithindi. 
\q1  
\v 15 Mad iyud gweth moa kuom Jehova Nyasaye, 
\q2 jachwech polo gi piny. 
\b  
\q1  
\v 16 Polo malo mogik en mar Jehova Nyasaye, 
\q2 to piny to osechiwo ne dhano. 
\q1  
\v 17 Joma osetho ok ema pak Jehova Nyasaye, 
\q2 joma oseiki molingʼ thi e bur ok pake; 
\q1  
\v 18 en wan ema wadendo Jehova Nyasaye 
\q2 tinende kendo nyaka chiengʼ. 
\b  
\q1 Pakuru Jehova Nyasaye! 
\c 116  
\cl Zaburi 116 
\q1  
\v 1 Ahero Jehova Nyasaye nikech nowinjo kwayona; 
\q2 nowinjo ywakna kane adwaro kech. 
\q1  
\v 2 Nikech ne ochikona ite, 
\q2 abiro luonge kinde duto ma angima. 
\b  
\q1  
\v 3 Tonde mag tho norida, lit mar liel nochopona, 
\q2 kendo chandruok gi chuny lit noloya. 
\q1  
\v 4 Eka naluongo nying Jehova Nyasaye, ne aywakne niya, 
\q2 “Resa, yaye Jehova Nyasaye!” 
\b  
\q1  
\v 5 Jehova Nyasaye ngʼwon kendo timo maber; 
\q2 Nyasachwa opongʼ gi kech. 
\q1  
\v 6 Jehova Nyasaye rito joma chunygi obolore; 
\q2 kane an-gi chando maduongʼ to ne oresa. 
\b  
\q1  
\v 7 Bed abeda mos, yaye chunya, 
\q2 nimar Jehova Nyasaye osebedo katimoni maber ndalo duto. 
\b  
\q1  
\v 8 Nimar in ema isegolo chunya e tho, yaye Jehova Nyasaye, 
\q2 wengena bende isereso e ywak, 
\q2 kendo tiendena isegengʼo mondo kik okier, 
\q1  
\v 9 isetimo kamano mondo awuothi e nyim Jehova Nyasaye, 
\q2 e piny joma ngima. 
\q1  
\v 10 Ne ayie; emomiyo ne awacho niya, 
\q2 “Sand oromo chunya.” 
\q1  
\v 11 Kendo kane achiedh-nade omaka, 
\q2 to ne awacho niya, “Dhano duto riambo.” 
\b  
\q1  
\v 12 Ere kaka dachul Jehova Nyasaye 
\q2 kuom berne duto mosetimona? 
\q1  
\v 13 Abiro tingʼo okumba mar warruok malo 
\q2 kendo abiro luongo nying Jehova Nyasaye. 
\q1  
\v 14 Abiro chopo singruokga ma asetimo ne Jehova Nyasaye 
\q2 e nyim ji duto. 
\b  
\q1  
\v 15 Tho mar nyithind Nyasaye 
\q2 en gima ber miwuoro e nyim Jehova Nyasaye. 
\q1  
\v 16 Yaye Jehova Nyasaye, an jatichni adier; 
\q2 an jatichni, ma wuod jatichni ma nyako; 
\q2 isegonya mi igola e nyorochena. 
\b  
\q1  
\v 17 Abiro timoni misango mar erokamano 
\q2 kendo abiro luongo nying Jehova Nyasaye. 
\q1  
\v 18 Abiro chopo singruokga 
\q2 ma asetimo ne Jehova Nyasaye e nyim ji duto, 
\q1  
\v 19 abiro chopogi e lache mag od Jehova Nyasaye 
\q2 abiro timogi e iyi, yaye Jerusalem. 
\b  
\q1 Pakuru Jehova Nyasaye! 
\c 117  
\cl Zaburi 117 
\q1  
\v 1 Pakuru Jehova Nyasaye, un ogendini duto; 
\q2 dendeuru, un ji duto manie piny. 
\q1  
\v 2 Nimar hera moherowago duongʼ, 
\q2 kendo adierane osiko nyaka chiengʼ. 
\b  
\q1 Pakuru Jehova Nyasaye. 
\c 118  
\cl Zaburi 118 
\q1  
\v 1 Gouru erokamano ne Jehova Nyasaye, nimar ober; 
\q2 kendo herane osiko nyaka chiengʼ. 
\b  
\q1  
\v 2 Jo-Israel mondo owach niya, 
\q2 “Herane osiko nyaka chiengʼ.” 
\q1  
\v 3 Jo-dhood Harun mondo owach niya, 
\q2 “Herane osiko nyaka chiengʼ.” 
\q1  
\v 4 Joma oluoro Jehova Nyasaye mondo owach niya, 
\q2 “Herane osiko nyaka chiengʼ.” 
\b  
\q1  
\v 5 Ne aywak ne Jehova Nyasaye kane chunya lit, 
\q2 kendo ne odwoka mine ogonya thuolo. 
\q1  
\v 6 Jehova Nyasaye ni koda, omiyo ok analuor. 
\q2 Ere gima dhano ditimna? 
\q1  
\v 7 Jehova Nyasaye ni koda; en e Jakonyna. 
\q2 Abiro neno gi wangʼa ka olo wasika. 
\q1  
\v 8 Ber pondo kuom Jehova Nyasaye 
\q2 moloyo geno kuom dhano. 
\q1  
\v 9 Ber pondo kuom Jehova Nyasaye 
\q2 moloyo geno kuom ruodhi. 
\b  
\q1  
\v 10 Ogendini duto nolwora koni gi koni, 
\q2 to ne atiekogi e nying Jehova Nyasaye. 
\q1  
\v 11 Ne gilwora koni gi koni, 
\q2 to ne atiekogi e nying Jehova Nyasaye. 
\q1  
\v 12 Ne ginur kuoma ka kich, 
\q2 to ne githo ka mach ma wangʼo kudho; 
\q2 mine atiekogi e nying Jehova Nyasaye. 
\b  
\q1  
\v 13 Ne gidhira gichien kendo ne achiegni podho, 
\q2 to Jehova Nyasaye nokonya. 
\q1  
\v 14 Jehova Nyasaye e tekra kendo en e wenda; 
\q2 osedoko warruok mara. 
\b  
\q1  
\v 15 Koko mag mor gi mag loch 
\q2 winjore ei hembe mag joma kare kama: 
\q1 “Lwet Jehova Nyasaye ma korachwich osetimo gik madongo! 
\q2  
\v 16 Lwet Jehova Nyasaye ma korachwich otingʼ malo; 
\q2 lwet Jehova Nyasaye ma korachwich osetimo gik madongo!” 
\b  
\q1  
\v 17 Ok abi tho, abiro bedo mangima; 
\q2 abiro bedo mangima modo ahul gik ma Jehova Nyasaye osetimo. 
\q1  
\v 18 Jehova Nyasaye osegoya modwa nega, 
\q2 to kata kamano pok oweyo tho onega. 
\b  
\q1  
\v 19 Yawna rangeye mag tim makare; 
\q2 mondo adonji kendo ago erokamano ne Jehova Nyasaye. 
\q1  
\v 20 Mano e dhoranga Jehova Nyasaye 
\q2 ma joma kare nyalo donjogo. 
\q1  
\v 21 Abiro goyoni erokamano, nikech ne idwoka; 
\q2 mi idoko warruokna. 
\b  
\q1  
\v 22 Kidi mane jogedo odagi 
\q2 koro osedoko kidi moriwo kor ot; 
\q1  
\v 23 Jehova Nyasaye ema osetimo mano 
\q2 kendo en gima iwuoro ka waneno. 
\q1  
\v 24 Ma en odiechiengʼ ma Jehova Nyasaye oseloso; 
\q2 wamoruru kendo wail e iye. 
\b  
\q1  
\v 25 Yaye Jehova Nyasaye, 
\q2 reswa yaye Jehova Nyasaye, mi walochi. 
\q1  
\v 26 Ogwedh ngʼat mabiro gi nying Jehova Nyasaye. 
\q2 Wagwedhi gie od Jehova Nyasaye. 
\q1  
\v 27 Jehova Nyasaye en Nyasaye, 
\q2 kendo osemiyo lerne orieny kuomwa. 
\q1 Riwreuru gi oganda moriedo katimo nyasi, 
\q2 nyaka uchopi e tunge mag kendo mar misango. 
\b  
\q1  
\v 28 In Nyasacha, omiyo abiro goyoni erokamano; 
\q2 in Nyasacha omiyo abiro miyi duongʼ. 
\b  
\q1  
\v 29 Gouru erokamano ne Jehova Nyasaye, nimar ober; 
\q2 herane osiko nyaka chiengʼ. 
\c 119  
\cl Zaburi 119 
\qa א Alef 
\q1  
\v 1 Ogwedh joma yoregi ler, 
\q2 mawuotho koluwore gi chik Jehova Nyasaye. 
\q1  
\v 2 Ogwedh joma orito chikene 
\q2 kendo ma manye gi chunygi duto. 
\q1  
\v 3 Gin joma ok tim gimoro amora marach, 
\q2 to gisiko ka giwuotho e yorene. 
\q1  
\v 4 Iseguro chikeni 
\q2 ni nyaka lu kaka gin. 
\q1  
\v 5 Yaye, mad ne bed ni yorena ogurore 
\q2 e luwo chikeni! 
\q1  
\v 6 Dine ok aneno wichkuot 
\q2 nikech aketo chunya e chikeni duto. 
\q1  
\v 7 Kaka amedo puonjora chikeni makare 
\q2 e kaka abiro dhi nyime gi paki gi chuny moriere tir. 
\q1  
\v 8 Abiro rito chikeni; 
\q1 omiyo kik ijwangʼa chuth. 
\qa ב Beth 
\q1  
\v 9 Ere kaka ngʼama pod tin nyalo rito ngimane mondo osik ka oler? 
\q2 Onyalo rito mana ka odak moluwore gi wachni. 
\q1  
\v 10 Amanyi gi chunya duto; 
\q2 omiyo kik iwe abar awe chikeni. 
\q1  
\v 11 Asekano wachni ei chunya 
\q2 mondo kik akethi e nyimi. 
\q1  
\v 12 Yaye Jehova Nyasaye, mad iyud pak; 
\q2 yie ipuonja chikeni. 
\q1  
\v 13 Aolo gi dhoga chike duto 
\q2 mowuok e dhogi. 
\q1  
\v 14 Luwo chikeni mora 
\q2 mana kaka ngʼato bedo mamor kuom mwandu duto. 
\q1  
\v 15 Abiro paro matut kuom chikeni 
\q2 kendo abiro tego wengena e yoreni. 
\q1  
\v 16 Amor ahinya gi chikeni; 
\q2 ok abi jwangʼo wachni. 
\qa ג Gimel 
\q1  
\v 17 Tim maber ne jatichni, 
\q2 eka abiro bedo mangima kendo abiro rito chikeni. 
\q1  
\v 18 Yaw wengena mondo eka ane 
\q2 gik mabeyo miwuoro manie chikeni. 
\q1  
\v 19 An mana wendo e piny 
\q2 omiyo kik ipandna chikeni. 
\q1  
\v 20 Chunya opongʼ kod siso 
\q2 mar chikeni kinde duto. 
\q1  
\v 21 Ikwero joma ochayo ji, ma gin joma okwongʼ, 
\q2 kendo gin joma osebaro oweyo chikeni. 
\q1  
\v 22 Gol kuoma ajara gi achaya 
\q2 nimar arito chikeni. 
\q1  
\v 23 Kata obedo ni jotelo chokorena kendo giyanya, 
\q2 to jatichni pod biro mana paro matut kuom chikeni. 
\q1  
\v 24 Chikeni e morna; 
\q2 gin e jongʼad rieko maga. 
\qa ד Daleth 
\q1  
\v 25 Osepiela ei lowo piny; 
\q2 omiyo rit ngimana kaluwore gi wachni. 
\q1  
\v 26 Kane ahulo yorena to ne idwoka; 
\q1 puonja chikeni. 
\q1  
\v 27 Mi awinj tiend gik ma chikegi puonjo; 
\q2 eka abiro paro matut kuom timbegi miwuoro. 
\q1  
\v 28 Kuyo onyoso chunya, 
\q2 omiyo meda teko kaluwore gi wachni. 
\q1  
\v 29 Gengʼa kik adonji e yore mag miriambo, 
\q1 kendo ngʼwon-na ka ipuonja chikni. 
\q1  
\v 30 Aseyiero yor adiera; 
\q2 kendo aseketo chunya e chikeni. 
\q1  
\v 31 Amako chikeni matek, yaye Jehova Nyasaye, 
\q2 omiyo kik iwe ane wichkuot. 
\q1  
\v 32 Yor chikeni ema aringe, 
\q2 nimar isegonyo chunya. 
\qa ה He 
\q1  
\v 33 Puonja mondo alu yoreni, yaye Jehova Nyasaye, 
\q2 eka abiro ritogi nyaka giko. 
\q1  
\v 34 Miya rieko mondo eka arit chikeni 
\q2 kendo atim kaka owacho gi chunya duto. 
\q1  
\v 35 Taya e yo mar chikeni, 
\q2 nimar kanyo ema ayudoe mor. 
\q1  
\v 36 Ket chunya mondo oher chikeni, 
\q2 to ok dwaro maga mag wuoro. 
\q1  
\v 37 Gol wangʼa oko kuom gik manono; 
\q2 rit ngimana kaluwore gi wachni. 
\q1  
\v 38 Chop singruok mari ne jatichni, 
\q2 mondo ji oluori. 
\q1  
\v 39 Golna achaya ma aluoro, 
\q2 nimar chikeni beyo. 
\q1  
\v 40 Mano kaka ahero yoreni! 
\q2 Rit ngimana e timni makare. 
\qa ו Waw 
\q1  
\v 41 Mad herani ma ok rem bina, yaye Jehova Nyasaye, 
\q2 mad warruokni bina kaluwore gi singruokni. 
\q1  
\v 42 Eka abiro dwokora gi ngʼat ma timona anyali, 
\q2 nimar ageno kuom wachni. 
\q1  
\v 43 Kik igol wach mar adiera e dhoga chuth, 
\q2 nimar aseketo genona e chikeni. 
\q1  
\v 44 Abiro rito chikeni ndalo duto, 
\q2 manyaka chiengʼ. 
\q1  
\v 45 Abiro wuotho ka an thuolo, 
\q2 nimar chikeni ema asebedo ka amanyo. 
\q1  
\v 46 Abiro wuoyo kuom chikeni e nyim ruodhi 
\q2 kendo wiya ok bi kuot, 
\q1  
\v 47 nimar amor gi chikeni 
\q2 nikech aherogi. 
\q1  
\v 48 Atingʼo bedena malo ne chikeni ma ahero 
\q2 kendo asiko aparo matut kuom yoreni. 
\qa ז Zayin 
\q1  
\v 49 Par wachni mane iwacho ne jatichni, 
\q2 nimar isemiya geno. 
\q1  
\v 50 Gima hoya e chandruokna en ma: 
\q2 ni singruokni rito ngimana. 
\q1  
\v 51 Joma ochayo ji jara ma ok obadhogi 
\q2 to kata kamano ok alokra awe chikeni. 
\q1  
\v 52 Asiko aparo chikeni mosebedo ka nitie nyaka nene, yaye Jehova Nyasaye, 
\q2 kendo ayudo hoch kuomgi. 
\q1  
\v 53 Mirima mager omaka nikech joma timbegi richo, 
\q2 mosejwangʼo chikeni. 
\q1  
\v 54 Chikeni e thoro mar wenda, 
\q2 kamoro amora ma abwore. 
\q1  
\v 55 Aparo nyingi gotieno, yaye Jehova Nyasaye, 
\q2 kendo abiro rito chikni. 
\q1  
\v 56 Ma osebedo timna, 
\q2 nimar asebedo ka arito yoreni. 
\qa ח Heth 
\q1  
\v 57 In e pokna, yaye Jehova Nyasaye; 
\q2 asesingora ni abiro rito chikeni. 
\q1  
\v 58 Asemanyo wangʼi gi chunya duto; 
\q2 ngʼwon-na kaluwore gi singruok mari. 
\q1  
\v 59 Asenono yorena 
\q2 kendo asechiko yorena mondo oluw yoreni. 
\q1  
\v 60 Abiro reto kendo ok abi deko 
\q2 mar rito chikeni. 
\q1  
\v 61 Kata obedo ni joma timbegi richo orida gi tonde, 
\q2 to wiya ok bi wil gi chikeni. 
\q1  
\v 62 Achiewo dier otieno mondo aduokni erokamano 
\q2 kuom chikeni makare. 
\q1  
\v 63 An osiep ji duto moluori, 
\q2 jogo duto moluwo yoreni. 
\q1  
\v 64 Piny opongʼ gi herani, yaye Jehova Nyasaye; 
\q2 yie ipuonja chikeni. 
\qa ט Teth 
\q1  
\v 65 Tim maber ne jatichni 
\q2 kaluwore gi wachni, yaye Jehova Nyasaye. 
\q1  
\v 66 Puonja ngʼeyo gi paro maber, 
\q2 nimar ayie kuom chikeni. 
\q1  
\v 67 Kane pok ayudo masira to ne abayo yo, 
\q2 to sani koro atimo gima wachni owacho. 
\q1  
\v 68 Iber, kendo gima itimo ber; 
\q2 omiyo puonja chikeni. 
\q1  
\v 69 Kata obedo ni joma ochayo ji osemiena gi miriambo, 
\q2 to pod arito yoreni gi chunya duto. 
\q1  
\v 70 Chunygi tek kendo ok dew gimoro amora; 
\q2 to an to chikni miya mor. 
\q1  
\v 71 Ne en gima ber mondo ayud chandruok 
\q2 mondo eka apuonjra chikeni. 
\q1  
\v 72 Chik moa e dhogi berna 
\q2 moloyo ngʼinjo gana gi gana mag fedha gi dhahabu. 
\qa י Yodh 
\q1  
\v 73 Lweti ema nochweya; 
\q2 miya ngʼeyo mondo apuonjra chikeni. 
\q1  
\v 74 Mad joma oluori bed mamor ka ginena, 
\q2 nimar aseketo genona e wachni. 
\q1  
\v 75 Angʼeyo, yaye Jehova Nyasaye, ni chikeni nikare, 
\q2 kendo angʼeyo ni chwat misechwadago nikare. 
\q1  
\v 76 Mad ihoya gi herani ma ok rem, 
\q2 kaluwore gi singruok mane imiyo jatichni. 
\q1  
\v 77 Orna kechni mondo abed mangima, 
\q2 nimar chikni e morna. 
\q1  
\v 78 Mad joma ochayo ji ne wichkuot kuom kwinya maonge gima omiyo, 
\q2 an to abiro paro matut kuom yoreni. 
\q1  
\v 79 Mad joma oluori dog jokora, 
\q2 kaachiel gi joma ongʼeyo bucheni. 
\q1  
\v 80 Mad chunya bed maonge ketho, kuom rito chikeni, 
\q2 mondo kik ane wichkuot. 
\qa כ Kaf 
\q1  
\v 81 Riyo mar dwaro warruokni oloyo chunya, 
\q2 kata kamano aseketo genona e wachni. 
\q1  
\v 82 Wengena ool kamanyo singruokni; 
\q2 apenjora niya, “Ibiro hoya karangʼo?” 
\q1  
\v 83 Kata obedo ni achalo pien tingʼo divai molier e iro, 
\q2 to wiya pok owil gi chikeni. 
\q1  
\v 84 Jatichni biro rito nyaka karangʼo? 
\q2 Ibiro kumo joma sanda karangʼo? 
\q1  
\v 85 Joma ochayo ji osekunyona buche mondo apodhie, 
\q2 gitimo gima chikni okwedo. 
\q1  
\v 86 Chikeni duto inyalo geno; omiyo yie ikonya, 
\q2 nikech ji sanda maonge gima omiyo. 
\q1  
\v 87 Ne gichiegni yweya oko e piny, 
\q2 to kata kamano pok aweyo chikeni. 
\q1  
\v 88 Rit ngimana kaluwore gi herani, 
\q2 mondo alu chike mowuok e dhogi. 
\qa ל Lamedh 
\q1  
\v 89 Wachni ochwere, yaye Jehova Nyasaye; 
\q2 ochungʼ mogurore e polo. 
\q1  
\v 90 Adiera mari ochwere e tienge duto; 
\q2 mana kaka ne iguro piny mi piny osiko. 
\q1  
\v 91 Chikeni osiko nyaka kawuono, 
\q2 nimar gik moko duto tiyoni. 
\q1  
\v 92 Ka dine bed ni chikeni ok ema miya mor, 
\q2 to dikoro aselal nono nikech masichena. 
\q1  
\v 93 Wiya ok bi wil gi bucheni, 
\q2 nimar gin ema iseritogo ngimana. 
\q1  
\v 94 Resa nimar an mari; 
\q2 nikech asiko amanyo chikeni ndalo duto. 
\q1  
\v 95 Joma timbegi richo obutona mondo gitieka, 
\q2 to abiro bet mos ka aparo kuom chikeni. 
\q1  
\v 96 Angʼeyo ni koda ka gik malongʼo chuth nigi gikogi, 
\q2 to chikeni onge gikogi. 
\qa מ Mem 
\q1  
\v 97 Yaye, mano kaka ahero chikni! 
\q2 Aparo kuome odiechiengʼ duto. 
\q1  
\v 98 Chikeni miyo abedo mariek moloyo wasika, 
\q2 nimar gisiko gin koda seche duto. 
\q1  
\v 99 An gi winjo moloyo jopuonjna duto, 
\q2 nimar arito chikeni. 
\q1  
\v 100 Wach donjona moloyo jodongo machon 
\q2 nimar arito chikeni. 
\q1  
\v 101 Asetamo tiendena ni kik wuothi e yore maricho, 
\q2 mondo eka atim gima wachni ochiko. 
\q1  
\v 102 Pok abaro aweyo chikeni, 
\q2 nimar in iwuon ema isepuonja. 
\q1  
\v 103 Mano kaka wechegi mit ka abilogi, 
\q2 gimit e dhoga moloyo mor kich! 
\q1  
\v 104 Chikeni miyo abedo gi winjo; 
\q2 emomiyo achayo yo moro amora marach. 
\qa נ Nun 
\q1  
\v 105 Wachni e taya mar tienda 
\q2 kendo en ler mamenyona yo. 
\q1  
\v 106 Asekwongʼora mi aketo sei ni abiro siko 
\q2 kaluwo chikeni makare. 
\q1  
\v 107 Asechandora moloyo; 
\q2 omiyo rit ngimana, yaye Jehova Nyasaye, 
\q2 kaluwore gi wachni. 
\q1  
\v 108 Rwak pak ma achiwoni gi dhoga ka ahero, yaye Jehova Nyasaye, 
\q2 kendo puonja chikeni. 
\q1  
\v 109 Kata obedo ni atingʼo ngimana e lweta kinde duto, 
\q2 to wiya ok bi wil gi chikeni. 
\q1  
\v 110 Joma timbegi richo osechikona obadho; 
\q2 to kata kamano pok abaro aweyo bucheni. 
\q1  
\v 111 Chikeni e girkeni mara manyaka chiengʼ; 
\q2 gin e mor mar chunya. 
\q1  
\v 112 Aketo chunya kuom rito chikeni 
\q2 ma ok aweyo nyaka giko. 
\qa ס Samek 
\q1  
\v 113 Achayo joma pachgi ariyo, 
\q1 to ahero chikni. 
\q1  
\v 114 In e ohingana kendo okumbana; 
\q2 omiyo aseketo genona e wachni. 
\q1  
\v 115 Ayiuru buta, un jorichogi, 
\q2 mondo arit chike mag Nyasacha! 
\q1  
\v 116 Maka motegno kaluwore gi singruokni, 
\q2 eka anabed mangima; kik iwe geno ma an-go lalna. 
\q1  
\v 117 Sira eka ananwangʼ konyruok; 
\q1 abiro siko ka ahero chikeni. 
\q1  
\v 118 Idagi ji duto mabaro weyo chikeni, 
\q2 nimar wuondruok ma giwuondorego en kayiem. 
\q1  
\v 119 Joma timbegi richo duto modak e piny ipuko oko ka yugi; 
\q2 emomiyo ahero chikeni. 
\q1  
\v 120 Denda tetni nikech oluori, 
\q2 kihondko omaka nikech chikeni. 
\qa ע Ayin 
\q1  
\v 121 asetimo gima kare kendo madier, 
\q2 omiyo kik iweya e lwet joma sanda. 
\q1  
\v 122 Ne ni jatichni dhi maber, 
\q2 kendo kik iyie joma ochayo ji osanda. 
\q1  
\v 123 Wengena ool karango resruok mikelo, 
\q2 kendo kamanyo gima kare mane isingona. 
\q1  
\v 124 Timne jatichni kaluwore gi herani, 
\q2 kendo puonja chikeni. 
\q1  
\v 125 An jatichni, omiyo yie imiya nyalo mar ngʼeyo gik mopondo 
\q2 eka awinj tiend chikeni. 
\q1  
\v 126 Sa oromo mondo koro itim gimoro, yaye Jehova Nyasaye, 
\q2 nikech iketho chikni. 
\q1  
\v 127 Nikech ahero chikeni moloyo dhahabu, 
\q2 kendo moloyo dhahabu maler mogik, 
\q1  
\v 128 kendo nikech akawo bucheni duto ni nikare, 
\q2 omiyo achayo yo moro amora marach. 
\qa פ Pe 
\q1  
\v 129 Chikeni lich miwuoro; 
\q2 emomiyo aritogi. 
\q1  
\v 130 Wachni koler tiende to kelo ler, 
\q2 omiyo joma riekogi tin bedo gi winjo. 
\q1  
\v 131 Ayawo dhoga kendo agamo yweyo, 
\q2 ka agombo chikeni. 
\q1  
\v 132 Lokri iranga mondo ikecha, 
\q2 kaka ijatimo ndalo duto ne joma ohero nyingi. 
\q1  
\v 133 Ket okangega mondo gilure gi wachni; 
\q2 kik iwe richo moro amora loya. 
\q1  
\v 134 Resa e dicho ma ji diyogo jowetegi, 
\q2 mondo eka arit bucheni. 
\q1  
\v 135 Ngʼi jatichni gi wangʼ maber 
\q2 kendo puonja chikeni. 
\q1  
\v 136 Pi wangʼ bubni kawuok e wengena, 
\q2 nimar chikni ok ji orito. 
\qa צ Tsadhe 
\q1  
\v 137 In ngʼat makare, yaye Jehova Nyasaye, 
\q2 kendo chikeni nikare. 
\q1  
\v 138 Chike misendiko nikare, 
\q2 inyalo genogi chuth. 
\q1  
\v 139 Hera matut ma aherogo wachni tieka, 
\q2 nimar wasika ok dew wachni. 
\q1  
\v 140 Singruok magi osetem maber chuth, 
\q2 omiyo jatichni oherogi. 
\q1  
\v 141 Kata obedo ni an chien kendo ji ochaya, 
\q2 to wiya ok nyal wil gi bucheni. 
\q1  
\v 142 Timni makare osiko 
\q2 kendo chikni en adier, 
\q1  
\v 143 Chandruok kod malit osebirona, 
\q2 kata kamano chikeni e morna. 
\q1  
\v 144 Chikeni nikare nyaka chiengʼ, 
\q2 omiyo miya ngʼeyo mondo abed mangima. 
\qa ק Kof 
\q1  
\v 145 Yie idwoka, yaye Jehova Nyasaye, nikech aywakni gi chunya duto 
\q2 kendo abiro timo kaka chikni dwaro. 
\q1  
\v 146 Aywakni, yie ikonya, 
\q2 eka abiro rito chikeni. 
\q1  
\v 147 Achiewo kogwen ka piny pok oyawore kendo aywagora mondo ayud kony; 
\q2 aseketo genona e wachni. 
\q1  
\v 148 Wengena neno otieno duto, 
\q2 mondo omi apar matut kuom singruok magi. 
\q1  
\v 149 Winj dwonda kaluwore gi herani; 
\q2 rit ngimana, yaye Jehova Nyasaye, kaluwore gi chikeni. 
\q1  
\v 150 Joma chanona gik maricho ni koda machiegni, 
\q2 kata kamano gin mabor gi chikni. 
\q1  
\v 151 In to in machiegni, yaye Jehova Nyasaye, 
\q2 kendo chikeni duto gin adier. 
\q1  
\v 152 Ne apuonjora kuom chikeni chon gi lala, 
\q2 ni ne igurogi mondo gisiki nyaka chiengʼ. 
\qa ר Resh 
\q1  
\v 153 Ne chandruokna mondo ikonya, 
\q2 nimar pok wiya owil gi chikni. 
\q1  
\v 154 Dog jakora mondo iresa, 
\q2 rit ngimana kaluwore gi singruokni. 
\q1  
\v 155 Warruok ni mabor gi joma timbegi richo, 
\q2 nimar ok giket chunygi kuom dwaro chikeni. 
\q1  
\v 156 Ngʼwononi duongʼ, yaye Jehova Nyasaye; 
\q2 rit ngimana kaluwore gi chikeni. 
\q1  
\v 157 Wasigu masanda thoth adier, 
\q2 to kata kamano pok abaro aweyo chikeni. 
\q1  
\v 158 Arango joma onge yie ka chunya ochido kodgi, 
\q2 nimar ok girit chikni. 
\q1  
\v 159 Neye kaka ahero bucheni; 
\q2 omiyo rit ngimana, yaye Jehova Nyasaye, 
\q2 kaluwore gi herani. 
\q1  
\v 160 Wechegi duto gin adier; 
\q2 kendo chikegi makare duto ochwere. 
\qa ש Sin gi Shin 
\q1  
\v 161 Jotelo sanda maonge gima omiyo, 
\q2 to kata kamano chunya oluoro wachni. 
\q1  
\v 162 Singruokni miya mor, 
\q2 mana ka ngʼama oyudo mwandu maduongʼ mope wasigu. 
\q1  
\v 163 Asin kendo ajok gi miriambo, 
\q2 to ahero chikni. 
\q1  
\v 164 Apaki ndalo abiriyo e odiechiengʼ achiel 
\q2 kuom chikegi makare. 
\q1  
\v 165 Joma ohero chikeni nigi kwe maduongʼ 
\q2 kendo onge gima nyalo miyo gichwanyre. 
\q1  
\v 166 Arito warruokni, yaye Jehova Nyasaye, 
\q2 kendo aluwo chikeni. 
\q1  
\v 167 Atimo gima chikeni dwaro, 
\q2 nimar aherogi gihera maduongʼ. 
\q1  
\v 168 Arito bucheni gi chikeni, 
\q2 nimar yorega duto ongʼereni maber. 
\qa ת Taw 
\q1  
\v 169 Mad ywakna chopi e nyimi, yaye Jehova Nyasaye; 
\q2 mi abed gi winjo kaluwore gi wachni. 
\q1  
\v 170 Mad kwayona chopi e nyimi, 
\q2 resa kaluwore gi singruokni. 
\q1  
\v 171 Mad dhoga pongʼ gi pak, 
\q2 nimar isepuonja chikeni. 
\q1  
\v 172 Mad lewa wer kuom wachni, 
\q2 nimar chikegi duto nikare. 
\q1  
\v 173 Mad lweti ikre mar konya, 
\q2 nimar aseyiero bucheni. 
\q1  
\v 174 Asedwaro resruok mari matek, yaye Jehova Nyasaye; 
\q2 kendo chikni e morna. 
\q1  
\v 175 We amed bedo mangima mondo apaki, 
\q2 kendo mad chikeni okonya. 
\q1  
\v 176 Aserwenyo ka rombo molal, 
\q2 omiyo yie imany jatichni, nimar wiya pok owil gi chikeni. 
\c 120  
\cl Zaburi 120 
\d Wer miwero ka ji dhi e hekalu. 
\q1  
\v 1 Ka an e chandruok to aluongo Jehova Nyasaye, 
\q2 kendo odwoka, 
\q1  
\v 2 Resa, yaye Jehova Nyasaye, kuom dho joma riambo 
\q2 kendo kuom lew joma wuondore. 
\b  
\q1  
\v 3 Bende ingʼeyo gima Nyasaye biro timoni, 
\q2 bende ingʼeyo gik mochomi adier, yaye lep mawuondore? 
\q1  
\v 4 Obiro kumi gi aserni mabitho mag jakedo, 
\q2 ee, obiro wangʼi gi maka maliel mager, 
\q2 mowangʼ gi yiend adugo. 
\b  
\q1  
\v 5 Malit ochoma adier nikech adak Meshek, 
\q2 hapa rach nikech adak e dier hembe mag Kedar! 
\q1  
\v 6 Asedak amingʼa ahinya, 
\q2 e dier joma ok dwar kwe. 
\q1  
\v 7 An ngʼat kwe; 
\q2 to ka awuoyo, to giikore ni lweny. 
\c 121  
\cl Zaburi 121 
\d Wer ma ji wero kadhi e hekalu. 
\q1  
\v 1 Atingʼo wangʼa ka arango gode, 
\q2 ere kuma konyruokna biro aye? 
\q1  
\v 2 Konyruokna aa kuom Jehova Nyasaye, 
\q2 Jachwech polo gi piny. 
\b  
\q1  
\v 3 Ok obi weyo tiendi kier, 
\q2 Jal ma riti ok bi nur; 
\q1  
\v 4 adier, Jal marito Israel 
\q2 ok nur kendo ok nindi. 
\b  
\q1  
\v 5 Jehova Nyasaye riti, 
\q2 Jehova Nyasaye e tipo moumi gi yo badi korachwich; 
\q1  
\v 6 omiyo chiengʼ ok nochami godiechiengʼ 
\q2 kendo dwe ok notimi gimoro gotieno. 
\b  
\q1  
\v 7 Jehova Nyasaye biro riti 
\q2 mondo gimoro amora kik ohinyi. 
\q1  
\v 8 Jehova Nyasaye biro riti kidonjo kendo kiwuok, 
\q2 obiro timo kamano sani kendo nyaka chiengʼ. 
\c 122  
\cl Zaburi 122 
\d Wer ma ji wero kadhi e hekalu. Mar Daudi. 
\q1  
\v 1 Ne amor gi joma nowachona niya, 
\q2 “Wadhiuru e od Jehova Nyasaye.” 
\q1  
\v 2 Tiendewa ochungʼ 
\q2 e dhorangeyeni, yaye Jerusalem. 
\b  
\q1  
\v 3 Jerusalem oger ka dala 
\q2 ma ji odakie machiegni motenore. 
\q1  
\v 4 Kanyo e kama ogendini idho dhiye, 
\q2 ogendini mag Jehova Nyasaye dhi kuno, 
\q1 mondo opak nying Jehova Nyasaye 
\q2 ka giluwo chike mane omi Israel. 
\q1  
\v 5 Kanyo ema kombe loch mag ngʼado bura nitie 
\q2 gin kombe loch mag jood Daudi. 
\b  
\q1  
\v 6 Lamuru mondo Jerusalem obed gi kwe. 
\q2 Lamuru niya, “Mad joma oheri bed gi kwe. 
\q1  
\v 7 Mad kwe yudre ei alworani, 
\q2 adier kwe mondo obedi ei ohinga mochieli.” 
\q1  
\v 8 Nikech owetena gi osiepena modak e iyi, 
\q2 awacho niya, “Jerusalem mondo obed gi kwe.” 
\q1  
\v 9 Nikech wach od Jehova Nyasaye ma Nyasachwa, 
\q2 adwaro ni idhi maber. 
\c 123  
\cl Zaburi 123 
\d Wer ma ji wero kadhi e hekalu. 
\q1  
\v 1 Atingʼo wangʼa ka arango, 
\q2 in ma kom lochni ni e polo. 
\q1  
\v 2 Mana kaka wenge wasumbini rango lwet ruodhgi, 
\q2 kendo kaka wenge jatich ma nyako mar ot rango lwet ruodhe madhako, 
\q1 e kaka wengewa rango Jehova Nyasaye ma Nyasachwa 
\q2 nyaka chop okechwa. 
\b  
\q1  
\v 3 Yie ikechwa, yaye Jehova Nyasaye, yie ikechwa, 
\q2 nikech osechawa gi kinda. 
\q1  
\v 4 Josunga osejarowa moromo 
\q2 acheje bende osechayowa moromo. 
\c 124  
\cl Zaburi 124 
\d Wer ma ji wero kadhi e hekalu. Mar Daudi. 
\q1  
\v 1 Ka dine bed ni Jehova Nyasaye ok jakorwa, 
\q2 jo-Israel mondo owach kamano, 
\q1  
\v 2 ka dine bed ni Jehova Nyasaye ok jakorwa 
\q2 kane ji omonjowa, 
\q1  
\v 3 e kinde mane mirima mabebni ka mach omakogi kodwa, 
\q2 to dine gimwonyowa ngili; 
\q1  
\v 4 ataro dine odinonwa, 
\q2 ee, kodh yamo dine oywerowa, 
\q1  
\v 5 kendo pi maringo matek 
\q2 dine odhi kodwa. 
\b  
\q1  
\v 6 Pak mondo odogne Jehova Nyasaye, 
\q2 ma ok oseyie mondo gikidhwa gi lekegi. 
\q1  
\v 7 Wasetony mana ka winyo 
\q2 mowuok e wino mar jachik winy; 
\q1 wino osechodi, 
\q2 to wan wasetony. 
\q1  
\v 8 Konyruokwa ni e nying Jehova Nyasaye, 
\q2 Jachwech polo gi piny. 
\c 125  
\cl Zaburi 125 
\d Wer ma ji wero kadhi e hekalu. 
\q1  
\v 1 Joma ogeno kuom Jehova Nyasaye chalo gi Got Sayun, 
\q2 ma ok nyal yiengi to osiko nyaka chiengʼ. 
\q1  
\v 2 Mana kaka gode olworo Jerusalem, 
\q2 e kaka Jehova Nyasaye olworo joge chakre, 
\q2 tinende kendo nyaka chiengʼ. 
\b  
\q1  
\v 3 Ludh loch mar joma timbegi richo 
\q2 ok bi siko korito piny mopog ne joma kare, 
\q1 nimar ka mano otimore 
\q2 to joma kare nyalo tiyo gi lwetgi kuom timo marach. 
\b  
\q1  
\v 4 Tim maber, yaye Jehova Nyasaye, 
\q2 kendo ni jogo moriere gie chunygi. 
\q1  
\v 5 To joma lokore luwo yore mobam 
\q2 Jehova Nyasaye biro kumo kaachiel gi joma timo timbe maricho. 
\b  
\q1 Israel mondo obed gi kwe. 
\c 126  
\cl Zaburi 126 
\d Wer ma ji wero kadhi e hekalu. 
\q1  
\v 1 Kane Jehova Nyasaye odwogo joma otwe Sayun, 
\q2 to ne ochalonwa mana lek. 
\q1  
\v 2 Ne wathungʼ gi nyiero 
\q2 kendo dhowa nopongʼ gi wende mor. 
\q1 Eka nowachore e dier ogendini niya, 
\q2 “Jehova Nyasaye osetimonegi gik madongo.” 
\q1  
\v 3 Adier, Jehova Nyasaye osetimonwa gik madongo, 
\q2 omiyo wamor mokalo. 
\b  
\q1  
\v 4 Duognwa gigewa, yaye Jehova Nyasaye, 
\q2 mondo wachal gi aore man Negev. 
\q1  
\v 5 Joma komo kodhi kaywak 
\q2 biro keyo ka wero wende mor. 
\q1  
\v 6 Ngʼat madhi oko kaywak, 
\q2 kotingʼo kodhi mikomo, 
\q1 biro duogo ka wero wende mor, 
\q2 kotingʼo cham mosechiek. 
\c 127  
\cl Zaburi 127 
\d Wer ma ji wero kadhi e hekalu. Mar Solomon. 
\q1  
\v 1 Ka Jehova Nyasaye ok ema ger ot, 
\q2 to joma gere nyagore gi tich matek kayiem nono. 
\q1 Ka Jehova Nyasaye ok ema orito dala, 
\q2 to jorito ochungʼ karito kayiem. 
\q1  
\v 2 In bende imondo chiewo chon 
\q2 kendo ineno nyaka sa molewo, 
\q1 kinyagori gi tich matek mondo iyud chiemo minyalo chamo; 
\q2 nimar Nyasaye miyo joge mohero nindo mokwe. 
\b  
\q1  
\v 3 Yawuowi gin gweth moa kuom Jehova Nyasaye, 
\q2 adier, nyithindo gin mich moa kuome. 
\q1  
\v 4 Yawuowi ma ngʼato onywolo kapod otin, 
\q2 chalo gi asere manie lwet jakedo. 
\q1  
\v 5 Ngʼat ma ofukune opongʼ kodgi 
\q2 en ngʼama ogwedhi. 
\q1 Ok ginine wichkuot 
\q2 ka gikedo gi wasikgi e dhorangach. 
\c 128  
\cl Zaburi 128 
\d Wer ma ji wero kadhi e hekalu. 
\q1  
\v 1 Ji duto moluoro Jehova Nyasaye, 
\q2 kendo ngimagi oriere gie chunygi. 
\q1  
\v 2 Ibiro chamo olemb luchi; 
\q2 iniyud gweth kendo inidhi maber. 
\q1  
\v 3 Chiegi nochal gi yiend mzabibu manyak maber 
\q2 e odi; 
\q1 nyithindi nochal gi chuny zeituni maloth 
\q2 e kinde ma gilworo mesa ka gichiemo. 
\q1  
\v 4 Kamano e kaka ngʼama oluoro Jehova Nyasaye 
\q2 ogwedhi. 
\b  
\q1  
\v 5 Jehova Nyasaye mondo ogwedhi gie Sayun, 
\q2 ndalo duto mag ngimani; 
\q1 mad ineye gi wangʼi ka Jerusalem dhi maber, 
\q2  
\v 6 kendo mad idag amingʼa nyaka ine nyithind nyithindi, 
\q2 Israel mondo obed gi kwe! 
\c 129  
\cl Zaburi 129 
\d Wer ma ji wero kadhi e hekalu. 
\q1  
\v 1 “Jogi osesanda malit nyaka aa e tin-na,” 
\q2 Israel mondo owach niya; 
\q1  
\v 2 “gisesanda malit nyaka aa e tin-na, 
\q2 to kata kamano pok gibedo gi loch kuoma. 
\q1  
\v 3 Jopur osepuro diengʼeya 
\q2 kendo gisegore opara ma roboche, 
\q1  
\v 4 to kata kamano Jehova Nyasaye en ngʼama kare; 
\q2 osegola e badho mar joma timbegi richo.” 
\b  
\q1  
\v 5 Ji duto mochayo Sayun 
\q2 lo mi dog chien gi wichkuot. 
\q1  
\v 6 Mad gichal gi lum moti ewi tado 
\q2 maner kata kapok odongo maber. 
\q1  
\v 7 Ok onyal nyago gimoro mapongʼo lwet jakeyo, 
\q2 kata ma jachoko nyalo tingʼo e bade. 
\q1  
\v 8 Mad joma kalo bute kik wachnegi niya, 
\q2 “Jehova Nyasaye mondo ogwedhi, kata ni, 
\q2 wagwedhi e nying Jehova Nyasaye.” 
\c 130  
\cl Zaburi 130 
\d Wer ma ji wero kadhi e hekalu. 
\q1  
\v 1 Aywakni ka an e chuny bur matut, yaye Jehova Nyasaye, 
\q2  
\v 2 Yaye Jehova Nyasaye, yie iwinj dwonda. 
\q1 Chik iti ne ywakna ma aywaknigo 
\q2 mondo ikecha. 
\b  
\q1  
\v 3 Yaye Jehova Nyasaye, ka dine bed ni isiko iparo richo, ma ji timo, 
\q2 yaye Jehova Nyasaye, to en ngʼa ma dichungʼ e nyimi ka ok bura oloyo? 
\q1  
\v 4 To kata kamano kuomi nitiere weyo richo; 
\q2 kuom mano watiyoni gi luor. 
\b  
\q1  
\v 5 Arito Jehova Nyasaye, chunya rite 
\q2 kendo aketo genona kuom wachne. 
\q1  
\v 6 Chunya rito Ruoth Nyasaye, 
\q2 moloyo kaka jorito rito ru piny, 
\q1 chunya riti, yaye Nyasaye, 
\q2 moloyo kaka jorito rito ru piny. 
\b  
\q1  
\v 7 Yaye jo-Israel, keturu genou kuom Jehova Nyasaye, nimar Jehova Nyasaye 
\q2 nigi hera ma ok rem, 
\q2 kendo en ema owaro ji chuth. 
\q1  
\v 8 En owuon ema obiro waro jo-Israel 
\q2 kuom richogi duto. 
\c 131  
\cl Zaburi 131 
\d Wer ma ji wero kadhi e hekalu. Mar Daudi. 
\q1  
\v 1 Ngʼayi onge e chunya, yaye Jehova Nyasaye, 
\q2 wangʼa bende ok tek; 
\q1 chunya ok chandre gi gik madongo, 
\q2 kata gi weche matek modhiera ngʼeyo. 
\q1  
\v 2 To abet mos kendo chunya okwe; 
\q2 mana ka nyathi ma pod dhoth molingʼ mos e bad min, 
\q1 ee, kaka nyathi ma kamano lingʼ mos, 
\q2 e kaka chunya bende olingʼ mos e iya. 
\b  
\q1  
\v 3 Yaye Israel, keturu genou kuom Jehova Nyasaye 
\q2 chakre tinende kendo nyaka chiengʼ. 
\c 132  
\cl Zaburi 132 
\d Wer ma ji wero kadhi e hekalu. 
\q1  
\v 1 Parie Daudi, yaye Jehova Nyasaye, 
\q2 parie Daudi gi chandruok duto moseneno. 
\b  
\q1  
\v 2 Ne okwongʼore kane osingore ne Jehova Nyasaye, 
\q2 kendo ne okwongʼore ne Nyasaye Maratego mar Jakobo kama: 
\q1  
\v 3 “Ok anadonji e oda, 
\q2 kata dhi e kitandana, 
\q1  
\v 4 Ok anayie nindo tera, 
\q2 kata ayula wangʼ lo wengena, 
\q1  
\v 5 kapok aloso ne Jehova Nyasaye kare, 
\q2 kapok ayudo ne Nyasaye Maratego mar Jakobo kar dak.” 
\b  
\q1  
\v 6 Ne wawinjo wachno Efratha, 
\q2 ee, ne wayude e puothe mag Jaar: 
\q1  
\v 7 “Wadhiuru kare modakie; 
\q2 wadhiuru mondo walame e nyim kom duongʼne, ka wawacho niya, 
\q1  
\v 8 ‘Aa malo, yaye Jehova Nyasaye, aa malo ibi kari mar yweyo, 
\q2 in kaachiel gi Sandug Muma ma en kido mar tekoni. 
\q1  
\v 9 Mad jodolo magi rwakre gi tim makare, 
\q2 kendo mad jogi maler wer gi mor.’ ” 
\b  
\q1  
\v 10 Nikech Daudi jatichni, 
\q2 kik idagi ngʼati miseyiero. 
\b  
\q1  
\v 11 Jehova Nyasaye nokwongʼore kendo osingore ne Daudi, 
\q2 kendo ne en kwongʼruok ma ok enoloki ngangʼ; 
\q1 nokwongʼorene niya, 
\q2 “Abiro keto achiel kuom kothi e lochni, 
\q1  
\v 12 ka yawuoti orito singruokna 
\q2 kod chike ma apuonjogi, 
\q1 eka yawuotgi nobedi, 
\q2 e lochni nyaka chiengʼ kendo nyaka chiengʼ.” 
\b  
\q1  
\v 13 Nimar Jehova Nyasaye oseyiero Sayun, 
\q2 osehere kaka kar dakne, osewacho ni, 
\q1  
\v 14 Ma e kar yweyona mochwere manyaka chiengʼ, 
\q2 kae ema abiro betie kom lochna, nimar asehere, 
\q1  
\v 15 abiro gwedhe gi gik moko mogundho, 
\q2 kendo joge modhier abiro romo gi chiemo. 
\q1  
\v 16 Abiro rwako jodolo mage gi warruok 
\q2 kendo jomaler modak e iye biro siko ka wero wende mor. 
\b  
\q1  
\v 17 “Ka eni ema abiro miyo tung moro donge ne Daudi 
\q2 kendo abiro chungo taya ne ngʼata mowir. 
\q1  
\v 18 Abiro bako wasike gi wichkuot, 
\q2 to en osimbo manie wiye biro medo rieny.” 
\c 133  
\cl Zaburi 133 
\d Wer ma ji wero kadhi e hekalu. Mar Daudi. 
\q1  
\v 1 Mano kaka en gima ber kendo malongʼo, 
\q2 ka jowete odak kanyakla gi kwe! 
\q1  
\v 2 Dak ma kamano chalo gi mo ma nengone tek mool e wich 
\q2 kendo mamol piny nyaka e tik, 
\q1 mamol piny koluwo tik Harun 
\q2 kamol piny mos mos nyaka e ngʼut kandhone. 
\q1  
\v 3 Ochalo bende gi thoo momoko e Got Hermon 
\q2 maridore ewi Got Sayun. 
\q1 Nimar kanyo ema Jehova Nyasaye chiwe gwethne, 
\q2 ma en ngima mochwere. 
\c 134  
\cl Zaburi 134 
\d Wer ma ji wero kadhi e hekalu. 
\q1  
\v 1 Pakuru Jehova Nyasaye, un jotich duto mag Jehova Nyasaye, 
\q2 kendo matiyo gotieno e od Jehova Nyasaye. 
\q1  
\v 2 Tingʼuru bedeu malo e kare maler mar lemo 
\q2 kendo upak Jehova Nyasaye. 
\b  
\q1  
\v 3 Mad Jehova Nyasaye ma jachwech polo gi piny, 
\q2 ogwedhu gie Sayun. 
\c 135  
\cl Zaburi 135 
\q1  
\v 1 Pakuru Jehova Nyasaye. 
\q1 Pakuru nying Jehova Nyasaye; 
\q2 pakeuru, un jotich mag Jehova Nyasaye, 
\q1  
\v 2 un mutiyo e od Jehova Nyasaye, 
\q2 e laru mag od Nyasachwa. 
\b  
\q1  
\v 3 Pakuru Jehova Nyasaye, nimar Jehova Nyasaye ber; 
\q2 pakuru nyinge gi wende pak nimar timo kamano en gima ber. 
\q1  
\v 4 Nimar Jehova Nyasaye oseyiero Jakobo, mondo obed gire owuon; 
\q2 oseyiero Israel, mondo obed mwandune mogeno. 
\b  
\q1  
\v 5 Angʼeyo ni Jehova Nyasaye duongʼ, 
\q2 angʼeyo adier ni Ruoth Nyasachwa duongʼ moloyo nyiseche duto. 
\q1  
\v 6 Jehova Nyasaye timo gimoro amora mohero, 
\q2 e polo kendo e piny, 
\q2 ei nembe kendo e kudegi. 
\q1  
\v 7 Omiyo boche wuok koa e tungʼ piny koni gi koni, 
\q2 kendo ooro mil polo ka koth chue, 
\q2 bende okelo yamo kogolo e utege mokanogie. 
\b  
\q1  
\v 8 Ne ogoyo nyithindo makayo mag Misri, 
\q2 nyithindo makayo mag dhano kod le. 
\q1  
\v 9 Ne ooro ranyisi gi honni mage e dieru, yaye Misri, 
\q2 noorogi kuom Farao kaachiel gi jotichne duto. 
\q1  
\v 10 Ne ogoyo pinje mangʼeny piny, 
\q2 kendo ne onego ruodhi maroteke, 
\q1  
\v 11 kaka Sihon ruodh jo-Amor, 
\q2 gi Og ruodh Bashan, 
\q2 kod ruodhi duto mag Kanaan, 
\q1  
\v 12 kendo nomiyogi piny jogo kaka girkeni, 
\q2 kaka girkeni ne joge ma gin jo-Israel. 
\b  
\q1  
\v 13 Yaye Jehova Nyasaye, nyingi osiko nyaka chiengʼ, 
\q2 yaye Jehova Nyasaye, humbi ochwere e tienge duto. 
\q1  
\v 14 Nimar Jehova Nyasaye biro chwako joge, 
\q2 kendo obiro kecho jotichne. 
\b  
\q1  
\v 15 Nyiseche mopa mag ogendini gin fedha gi dhahabu, 
\q2 molos gi lwet dhano. 
\q1  
\v 16 Gin gi dhogi, to kata kamano, ok ginyal wuoyo, 
\q2 gin gi wenge, to ok ginyal neno. 
\q1  
\v 17 Gin gi it, to ok ginyal winjo wach, 
\q2 kendo kata mana muya onge e dhogi. 
\q1  
\v 18 Joma losogi nobed machal kodgi, 
\q2 kendo joma oketo genogi kuomgi bende biro chalo kodgi. 
\b  
\q1  
\v 19 Un jo-Israel, pakuru Jehova Nyasaye; 
\q2 un dhood joka Harun, pakuru Jehova Nyasaye; 
\q1  
\v 20 un dhood joka Lawi, pakuru Jehova Nyasaye; 
\q2 pakuru Jehova Nyasaye, un ji duto moluore. 
\q1  
\v 21 Jehova Nyasaye mondo opaki gie Sayun, 
\q2 Jal modak Jerusalem mondo opaki. 
\b  
\q1 Pakuru Jehova Nyasaye! 
\c 136  
\cl Zaburi 136 
\q1  
\v 1 Gouru erokamano ne Jehova Nyasaye, nimar ober. 
\qr Herane osiko nyaka chiengʼ. 
\q1  
\v 2 Gouru erokamano ne Nyasach nyiseche: 
\qr Herane osiko nyaka chiengʼ. 
\q1  
\v 3 Gouru erokamano ne Ruodh ruodhi: 
\qr Herane osiko nyaka chiengʼ. 
\b  
\q1  
\v 4 Ne en kendo matimo honni madongo, 
\qr Herane osiko nyaka chiengʼ. 
\q1  
\v 5 Jal mane oloso polo gi riekone, 
\qr Herane osiko nyaka chiengʼ. 
\q1  
\v 6 Jal mane oyaro piny ewi pige, 
\qr Herane osiko nyaka chiengʼ. 
\q1  
\v 7 Jal mane oloso rameny madongo dongo, 
\qr Herane osiko nyaka chiengʼ. 
\q1  
\v 8 Nochweyo wangʼ chiengʼ mondo orit odiechiengʼ, 
\qr Herane osiko nyaka chiengʼ. 
\q1  
\v 9 kod dwe gi sulwe mondo orit otieno; 
\qr Herane osiko nyaka chiengʼ. 
\b  
\q1  
\v 10 ne En mane onego nyithindo makayo mag Misri, 
\qr Herane osiko nyaka chiengʼ. 
\q1  
\v 11 kendo mane ogolo jo-Israel oko kuomgi, 
\qr Herane osiko nyaka chiengʼ. 
\q1  
\v 12 nogologi gi lwedo motegno kod bat morie; 
\qr Herane osiko nyaka chiengʼ. 
\b  
\q1  
\v 13 ne En mane obaro Nam Makwar diere ariyo; 
\qr Herane osiko nyaka chiengʼ. 
\q1  
\v 14 mi nogolo jo-Israel koluwo diere tir, 
\qr Herane osiko nyaka chiengʼ. 
\q1  
\v 15 to Farao gi jolwenje to nomiyo Nam Makwar oywero; 
\qr Herane osiko nyaka chiengʼ. 
\b  
\q1  
\v 16 ne En mane otelo ne joge e thim, 
\qr Herane osiko nyaka chiengʼ. 
\b  
\q1  
\v 17 ne En mane ogoyo ruodhi madongo piny, 
\qr Herane osiko nyaka chiengʼ. 
\q1  
\v 18 kendo mane onego ruodhi maroteke; 
\qr Herane osiko nyaka chiengʼ. 
\q1  
\v 19 Kaka Sihon ruodh jo-Amor, 
\qr Herane osiko nyaka chiengʼ. 
\q1  
\v 20 gi Og ruodh Bashan, 
\qr Herane osiko nyaka chiengʼ. 
\q1  
\v 21 mi nochiwo pinygi kaka girkeni, 
\qr Herane osiko nyaka chiengʼ. 
\q1  
\v 22 Kaka girkeni ne Israel jatichne; 
\qr Herane osiko nyaka chiengʼ. 
\b  
\q1  
\v 23 ne En mane oparowa ka piny ochamowa, 
\qr Herane osiko nyaka chiengʼ. 
\q1  
\v 24 kendo mane ogonyowa e lwet wasikwa, 
\qr Herane osiko nyaka chiengʼ. 
\q1  
\v 25 machiwo chiemo ne chwech duto, 
\qr Herane osiko nyaka chiengʼ. 
\b  
\q1  
\v 26 Gouru erokamano ne Nyasach polo, 
\qr Herane osiko nyaka chiengʼ. 
\c 137  
\cl Zaburi 137 
\q1  
\v 1 E bath aore mag Babulon ne wabet piny kendo ne waywak 
\q2 kane waparo Sayun. 
\q1  
\v 2 Ne wangʼawo thumbewa 
\q2 ewi omburi mane ni kanyo, 
\q1  
\v 3 nimar joma ne omakowa nokwayowa wende kane wan kanyo, 
\q2 joma nesandowa nochunowa ni wawernegi wende mor; 
\q2 negiwachonwa niya, “Wernwauru achiel kuom wende Sayun!” 
\b  
\q1  
\v 4 Ere kaka wanyalo wero wende Jehova Nyasaye 
\q2 kapod wan e piny ma wendo? 
\q1  
\v 5 Ka dipo ni wiya owil kodi, yaye Jerusalem, 
\q2 to mad lweta ma korachwich wiye wil gi tichne. 
\q1  
\v 6 Mad lewa moki e danda 
\q2 ka dipo ni ok apari, 
\q1 ka dipo ni ok aketo chunya kuomi, 
\q2 yaye Jerusalem, morna maduongʼ mogik. 
\b  
\q1  
\v 7 Parie gima ne jo-Edom otimo, yaye Jehova Nyasaye, 
\q2 parie gima negitimo chiengʼ mane Jerusalem opodho. 
\q1 Ne gikok matek niya, “Mukeuru ogoye piny. 
\q2 Mukeuru ogore piny gi mise mare duto!” 
\q1  
\v 8 Yaye nyar Babulon, in mochanni kethruok, 
\q2 ngʼama nochuli kuom gima isetimonwa en jahawi, 
\q1  
\v 9 ngʼat manomak nyithindi mayom 
\q2 mi gogi piny e lwendni en jahawi. 
\c 138  
\cl Zaburi 138 
\d Zaburi mar Daudi. 
\q1  
\v 1 Abiro paki gi chunya duto, yaye Jehova Nyasaye; 
\q2 abiro paki gi wer e nyim nyiseche. 
\q1  
\v 2 Abiro kulora piny ka achomo hekalu mari maler 
\q2 kendo abiro pako nyingi, 
\q2 nikech herani kod adierani, 
\q1 nimar isetingʼo nyingi kod Wachni malo 
\q2 moyombo gik moko duto. 
\q1  
\v 3 Kane aluongo to ne idwoka, 
\q2 kendo ne imiyo abedo gi chir kod chuny motegno. 
\b  
\q1  
\v 4 Mad ruodhi duto mag piny paki, yaye Jehova Nyasaye, 
\q2 e sa ma giwinjo weche mowuok e dhogi. 
\q1  
\v 5 Mad giwer kuom yore mag Jehova Nyasaye, 
\q2 nimar duongʼ mar Jehova Nyasaye ngʼongo. 
\b  
\q1  
\v 6 Jehova Nyasaye rango joma obolore kata obedo ni en malo to josunga 
\q2 to ongʼeyo kata kapod gin gichien. 
\q1  
\v 7 Kata obedo ni awuotho e dier chandruok, 
\q2 to irito ngimana; 
\q1 irieyo lweti kuom mirimb joma kedo koda, 
\q2 kendo iresa gi lweti ma korachwich. 
\q1  
\v 8 Jehova Nyasaye biro chopona chenroge; 
\q2 yaye Jehova Nyasaye, herani osiko nyaka chiengʼ: 
\q2 kik ijwangʼ tije ma iloso gi lweti. 
\c 139  
\cl Zaburi 139 
\d Kuom jatend wer. Zaburi mar Daudi. 
\q1  
\v 1 Yaye Jehova Nyasaye, isenona 
\q2 kendo ingʼeya. 
\q1  
\v 2 Ingʼeya sa ma abet piny nyaka sa ma aa malo; 
\q2 adier, ingʼeyo parona gi kuma bor. 
\q1  
\v 3 Bende ingʼeyo yorega ma aluwo kod kuonde ma ayweyoe; 
\q2 yorena duto oyangoreni maber. 
\q1  
\v 4 Kata kapok wach moro owuok e dhoga 
\q2 to ingʼeye malongʼo, yaye Jehova Nyasaye. 
\q1  
\v 5 Ilwora koni gi koni mi iketa diere; 
\q2 adier, iseuma duto gi lweti. 
\q1  
\v 6 Rieko ma kamano lichna miwuoro, 
\q2 kendo otutna moyombo pacha. 
\b  
\q1  
\v 7 Dadhi kure eka apond ne Roho mari? 
\q2 Koso kanye ma daring adhiye mondo apondni? 
\q1  
\v 8 Ka aidho e polo, to in kuno; 
\q2 ka aloso kitandana e bur matut, to in kuno. 
\q1  
\v 9 Ka aidho yamb kogwen 
\q2 mondo otera e tok nam komachielo, 
\q1  
\v 10 to kata kuno bende lweti biro telonae, 
\q2 kendo lweti ma korachwich biro maka motegno. 
\q1  
\v 11 Ka awacho niya, “Mudho biro ima adier 
\q2 kendo ler biro lokorena otieno,” 
\q1  
\v 12 to in mudho ok timni mudho 
\q2 kendo otieno rienyni ka odiechiengʼ, 
\q2 nimar mudho chaloni ler. 
\b  
\q1  
\v 13 In ema ne ichweyo dhanda maiye, 
\q2 adier, ne ingʼina maber gi ei minwa. 
\q1  
\v 14 Apaki nikech ne ichweya mongʼith kendo malich miwuoro; 
\q2 tijeni misetimo lich, 
\q2 kendo angʼeyo mano maber. 
\q1  
\v 15 Fuonde mag ringra ne ok opondoni, 
\q2 kane ochweya ei minwa, 
\q2 kane ochwe ringra e kama opondo, 
\q1  
\v 16 wangʼi ne oneno ringra ei minwa; 
\q2 ndalona duto e piny-ka ne ondiki chon gi lala, 
\q2 e kitabu mari kane pok kata achiel kuomgi obetie. 
\q1  
\v 17 Mano kaka pachi tutna, yaye Nyasaye! 
\q2 Mano kaka gingʼeny mokalo akwana kargi duto! 
\q1  
\v 18 Ka dine bed ni anyalo kwanogi, 
\q2 to dine giloyo kuoyo gi ngʼeny. 
\q1 Sa ma achiew to ayudo 
\q2 ni pod an mana kodi. 
\b  
\q1  
\v 19 Yaye Jehova Nyasaye, mad iyie ineg joma timbegi richo! 
\q2 Ayiuru buta, un joma rich chwero remb ji omakogi! 
\q1  
\v 20 Giwuoyo kuomi gi paro marach; 
\q2 adier, wasiki tiyo gi nyingi e yo marach. 
\q1  
\v 21 Donge amon gi jomamon kodi, yaye Jehova Nyasaye, 
\q2 koso donge ok awinjra gi joma chungʼ mondo oked kodi? 
\q1  
\v 22 Achayogi kendo aonge kodgi gi tich 
\q2 adier akwanogi kaka wasika. 
\q1  
\v 23 Nona, yaye Jehova Nyasaye, mondo ingʼe chunya; 
\q2 tema, mondo ingʼe pacha. 
\q1  
\v 24 Tim kamano mondo ineane ka nitie gimoro marach kuoma, 
\q2 mondo itera e yor ngima mochwere. 
\c 140  
\cl Zaburi 140 
\d Kuom jatend wer. Zaburi mar Daudi. 
\q1  
\v 1 Resa, yaye Jehova Nyasaye, kuom joma richo, 
\q2 konya e lwet jo-mahundu, 
\q1  
\v 2 joma chano chenro maricho e chunygi 
\q2 kendo gitugo lweny pile pile. 
\q1  
\v 3 Gipiago lewgi mabith ka lew thuol 
\q2 kendo kwiri mar thuond fu ni e lewgi. \qs Sela\qs*\f + \fr 140:3 \fq Sela \ft tiend wachni ok ongʼere.\f* 
\b  
\q1  
\v 4 Rita, yaye Jehova Nyasaye, 
\q2 rita e lwet joma timbegi richo; 
\q2 konya e lwet jo-mahundu machano gajo tiendena. 
\q1  
\v 5 Josunga chikona obadho; 
\q2 giseyarona gogo mondo amokie, 
\q2 kendo gisechikona otegu e yorega ma aluwo. \qs Sela\qs* 
\b  
\q1  
\v 6 Yaye Jehova Nyasaye, awachoni niya, “In Nyasacha.” 
\q2 Omiyo yie iwinja, yaye Jehova Nyasaye, 
\q2 winj ywak ma aywaknigo mondo ikecha. 
\q1  
\v 7 Yaye Jehova Nyasaye Manyalo Gik Moko Duto, ma jakonyna motegno, 
\q2 in migengʼona wiya sa ma lweny ger. 
\q1  
\v 8 Kik iyie mondo joma timbegi richo oyud gik 
\q2 ma chunygi gombo, yaye Jehova Nyasaye; 
\q2 kik iyie mondo chenrogi otimre. \qs Sela\qs* 
\b  
\q1  
\v 9 Mi mondo chandruok ma joma olwora bwogago, 
\q2 odog e wiyegi. 
\q1  
\v 10 Mi mondo makaa maliel mager oolre kuomgi, 
\q2 ee, ne ni odirgi e mach, 
\q2 kata e thidhna ma nimo ji, ma ok ginyal wuokie kendo. 
\q1  
\v 11 Mi mondo joma ketho nying jowetegi kik dhi maber e piny, 
\q2 ee, ne ni masira olawo jo-mahundu mi ojukogi. 
\b  
\q1  
\v 12 Angʼeyo ni Jehova Nyasaye miyo jodhier yudo adieragi, 
\q2 kendo oneno ni ongʼad bura kare ne joma ochando. 
\q1  
\v 13 Joma kare biro pako nyingi adier 
\q2 kendo joma ngimagi oriere tir biro dak kangima e nyimi. 
\c 141  
\cl Zaburi 141 
\d Zaburi Mar Daudi. 
\q1  
\v 1 Aluongi, yaye Jehova Nyasaye, yie ibi ira piyo. 
\q2 Yie iwinj dwonda ka aluongi. 
\q1  
\v 2 Mad lamona osiki e nyimi mana ka ubani miwangʼo, 
\q2 kendo bedena osik koriere kochomo malo mana ka misango mitimoni godhiambo. 
\b  
\q1  
\v 3 Yaye Jehova Nyasaye, ket jarit e dhoga; 
\q2 ketna jarit mondo okonya umo dhoga. 
\q1  
\v 4 Kik iyie gimoro amora marach ywa chunya, 
\q2 ma dimi an bende atim timbe maricho, 
\q1 kaachiel gi joma timbe gi richo; 
\q2 rita mondo kik acham chiembgi mabeyonegi. 
\q1  
\v 5 Onego ngʼat makare ema ogoya, nikech mano chalo tim ngʼwono motimona; 
\q2 onego en ema okwera, nikech mano chalo mo mool e wiya; 
\q2 ok anyal dagi mondo ngʼama kare otimna kamano. 
\b  
\q1 To kata kamano obiro kwedo timbe joma richo e lemona; 
\q2  
\v 6 chiengʼ ma nowit ruodhigi piny koa ewi got mabor, 
\q2 eka joma timbegi richo nongʼe ni kare wechena ne gin adier. 
\q1  
\v 7 Giniwach niya, “Mana kaka ngʼato puro kendo toyo lowo, 
\q2 e kaka chokewa osekere e dho bur liel.” 
\b  
\q1  
\v 8 Anto atego wangʼa kuomi, yaye Jehova Nyasaye Manyalo Gik Moko Duto; 
\q2 In e kar pondona, omiyo kik iwe atho. 
\q1  
\v 9 Kik iwe obadho ma gisechikona maka, 
\q2 ee, resa kuom otegu ma joma timbegi richo ochikona. 
\q1  
\v 10 Mad joma timbegi richogo moki e gokegi giwegi 
\q2 ka anto akadho maber mak gimoro otima. 
\c 142  
\cl Zaburi 142 
\d \tl Maskil\tl*\f + \fr 142:0 \fl Maskil: \ft en kit wer moro mane Daudi owero\f* mar Daudi. Kane en ei bur. Lamo. 
\q1  
\v 1 Aywak matek ne Jehova Nyasaye; 
\q2 atingʼo dwonda ne Jehova Nyasaye mondo okecha. 
\q1  
\v 2 Ahulone gik mathaga duto; 
\q2 anyise chandruokna duto ka abet e nyime. 
\b  
\q1  
\v 3 E kinde ma chunya chandore e iya, 
\q2 to in ema ingʼeyo yor konyruokna. 
\q1 E bugo matut ma awuothoe 
\q2 ji osechikonae obadho. 
\q1  
\v 4 Rang batha korachwich; 
\q2 mondo ine kaonge ngʼama dewa. 
\q1 Aonge kar pondo; 
\q2 bende aonge ngʼama rito ngimana. 
\b  
\q1  
\v 5 Aywakni, yaye Jehova Nyasaye; 
\q2 awachoni niya, “In e kar pondona, 
\q2 kendo in e pokna e piny joma ngima.” 
\b  
\q1  
\v 6 Yie iwinj ywakna, 
\q2 nimar an-gi chandruok maduongʼ; 
\q1 resa e lwet joma lawa 
\q2 nimar gitek moloya mabor. 
\q1  
\v 7 Gonya e twech ma antie, 
\q2 mondo apak nyingi. 
\q1 Eka joma kare biro chokore buta 
\q2 nikech ber misetimona. 
\c 143  
\cl Zaburi 143 
\d Zaburi mar Daudi. 
\q1  
\v 1 Winj lamona, yaye Jehova Nyasaye, 
\q2 chik iti ne ywakna mar kech; 
\q1 bi mondo ikonya 
\q2 nikech in ja-adiera kendo itimo maber. 
\q1  
\v 2 Kik imi jatichni yud kum 
\q2 nimar onge kata ngʼato achiel matimo maber e nyimi. 
\q1  
\v 3 Jasigu lawa matek, 
\q2 oserodha piny nyaka e lowo; 
\q1 ochuna ni nyaka adag kama otimo mudho 
\q2 mana ka joma notho chon gi lala. 
\q1  
\v 4 Omiyo chunya chandore e iya, 
\q2 ee, chunya obwok. 
\q1  
\v 5 Aparo higni machon mosekalo; 
\q2 aketo pacha mos kuom tijeni duto, 
\q2 kendo ageno gik ma lweti osetimo. 
\q1  
\v 6 Ayaroni lwetena; 
\q2 chunya gombi mana kaka lowo motwo gombo koth. \qs Sela\qs* 
\b  
\q1  
\v 7 Dwoka piyo, yaye Jehova Nyasaye, 
\q2 nimar chunya ool. 
\q1 Kik ipandna wangʼi 
\q2 nono to dipoka achalo gi joma ridore e bur matut. 
\q1  
\v 8 Mi mondo okinyi oromna gi herani ma ok rem, 
\q2 nimar aketo genona kuomi. 
\q1 Nyisa yo monego alu 
\q2 nimar aketo chunya duto kuomi. 
\q1  
\v 9 Resa e lwet wasika, yaye Jehova Nyasaye, 
\q2 nimar in e jaritna. 
\q1  
\v 10 Puonja timo dwaroni, 
\q2 nimar in e Nyasacha; 
\q1 mi mondo Roho mari maber, 
\q2 otelna e yo mopie. 
\b  
\q1  
\v 11 Yaye Jehova Nyasaye, kony ngimana nikech nyingi iwuon; 
\q2 gola oko e chandruok nikech timni maber. 
\q1  
\v 12 Mi wasika olingʼ thi, 
\q2 nikech herani ma ok rem; 
\q2 tiek joma kedo koda duto nimar an jatichni. 
\c 144  
\cl Zaburi 144 
\d Mar Daudi. 
\q1  
\v 1 Pak obed ni Jehova Nyasaye ma en Lwandana, 
\q2 pakeuru en motego lwetena ne lweny, 
\q2 kendo en momiyo lith lwetena bedo mongʼith e kedo. 
\q1  
\v 2 En Nyasacha ma jahera kendo en ohingana, 
\q2 bende en kar pondona kendo en jakonyna. 
\q1 En okumbana ma agengʼorago, 
\q2 kendo en ema oloyona joma ni e bwoya. 
\b  
\q1  
\v 3 Dhano to en angʼo, yaye Jehova Nyasaye, momiyo iketo chunyi kuome, 
\q2 koso wuod dhano to en angʼo, momiyo isiko ipare? 
\q1  
\v 4 Dhano chalo gi muya nono 
\q2 kendo ndalone chalo gi tipo makadho piyo. 
\b  
\q1  
\v 5 Wuogi e polo, yaye Jehova Nyasaye, wuogi mondo ilor piny; 
\q2 lor piny imul gode, mondo gidhuol iro. 
\q1  
\v 6 Or mil polo, mondo ike wasigu; 
\q2 dir aserni magi, mondo itiekgi. 
\q1  
\v 7 Rie lweti koa e polo nyaka piny, 
\q2 mondo ikonya, kendo igola, 
\q1 e pige ma tekregi ngʼeny, 
\q2 kendo e lwet jopinje mamoko, 
\q1  
\v 8 ma dhogi opongʼ gi miriambo 
\q2 kendo ma lwetgi ma korachwich opongʼ gi wuondruok. 
\b  
\q1  
\v 9 Abiro weroni wer manyien, yaye Nyasaye; 
\q2 abiro weroni wer mamit ka agoyoni thum man-gi tonde apar, 
\q1  
\v 10 abiro werne Jal mamiyo ruodhi locho, 
\q2 kendo makonyo Daudi jatichne e dho ligangla mager. 
\b  
\q1  
\v 11 Konya kendo gola 
\q2 e lwet jopinje mamoko, 
\q1 ma dhogi opongʼ gi miriambo 
\q2 kendo ma lwetgi ma korachwich opongʼ gi wuondruok. 
\b  
\q1  
\v 12 Eka yawuotwa 
\q2 biro chalo gi yiende mayudo pi maber, 
\q1 kendo nyiwa biro chalo gi sirni modol maber 
\q2 mondo olich dala ruoth. 
\q1  
\v 13 Dechewa biro pongʼ 
\q2 gi kit mwandu duto. 
\q1 Rombewa biro medore gana gi gana, 
\q2 ee, gibiro bedo gana mathoth e lek magwa, 
\q2  
\v 14 kendo rwedhi magwa biro ywayo misike mapek. 
\q1 Jokwoge ok nodonj e kundewa, 
\q2 bende ok noterwa e twech, 
\q2 kendo yoreyore ok nogo e gwengʼwa. 
\b  
\q1  
\v 15 Ogwedh joma gigi gin adier kuomgi; 
\q2 kendo ogwedh jogo ma Nyasachgi en Jehova Nyasaye. 
\c 145  
\cl Zaburi 145 
\d Zaburi mar pak. Mar Daudi. 
\q1  
\v 1 Abiro tingʼo nyingi malo, yaye Nyasacha ma Ruoth; 
\q2 abiro pako nyingi nyaka chiengʼ kendo nyaka chiengʼ. 
\q1  
\v 2 Abiro paki pile ka pile 
\q2 kendo abiro tingʼo nyingi malo mochwere manyaka chiengʼ. 
\b  
\q1  
\v 3 Jehova Nyasaye duongʼ miwuoro kendo owinjore gi pak, 
\q2 onge ngʼama nyalo yango duongʼne. 
\q1  
\v 4 Tiengʼ achiel biro pako tijeni ne tiengʼ machielo; 
\q2 adier, gibiro nyiso ji kuom tijeni madongo. 
\q1  
\v 5 Gibiro wuoyo kuom duongʼni mangʼongo kendo marieny, 
\q2 to an abiro paro mos kuom tijeni miwuoro. 
\q1  
\v 6 Gibiro nyiso kuom tekoni mitimogo gik malich miwuoro, 
\q2 to an abiro hulo kuom tijeni madongo. 
\q1  
\v 7 Gibiro loso nyasi mar ber ni mogundho 
\q2 kendo gibiro wer gi mor kuom timbeni makare. 
\b  
\q1  
\v 8 Jehova Nyasaye ngʼwon kendo kecho ji, 
\q2 iye ok wangʼ piyo kendo en gihera mangʼeny. 
\b  
\q1  
\v 9 Jehova Nyasaye timo maber ne ji duto; 
\q2 okecho ji duto mosechweyo. 
\q1  
\v 10 Ji duto ma isechweyo biro paki, yaye Jehova Nyasaye; 
\q2 jogi maler duto biro dhiali. 
\q1  
\v 11 Gibiro nyiso ji kuom duongʼ mar pinyruodhi 
\q2 kendo gibiro wuoyo kuom tekoni, 
\q1  
\v 12 mondo ji duto ongʼe gik madongo mitimo 
\q2 kod duongʼ mangʼongo mar pinyruodhi. 
\q1  
\v 13 Pinyruodhi en pinyruoth mochwere, 
\q2 kendo lochni osiko nyaka tienge duto. 
\b  
\q1 Jehova Nyasaye chopo singruok mage duto 
\q2 kendo ohero ji duto mosechweyo. 
\q1  
\v 14 Jehova Nyasaye chungo ji duto mopodho 
\q2 kendo omiyo joma piny otaro aa malo. 
\q1  
\v 15 In ema wenge ji duto ngʼiyi, 
\q2 kendo imiyogi chiembgi e kinde mowinjore. 
\q1  
\v 16 Ka iyawo lweti 
\q2 to gik mangima duto yudo konyruokgi duto. 
\b  
\q1  
\v 17 Jehova Nyasaye nikare e yorene duto 
\q2 kendo ohero ji duto mosechweyo. 
\q1  
\v 18 Jehova Nyasaye ni machiegni gi ji duto maluongo nyinge, 
\q2 to mana joma luongo nyinge e adiera. 
\q1  
\v 19 Ochopo dwaro mag joma omiye luor; 
\q2 adier, owinjo ywakgi kendo oresogi. 
\q1  
\v 20 Jehova Nyasaye rito maber ji duto mohere, 
\q2 to ji duto ma timbegi richo obiro tieko. 
\b  
\q1  
\v 21 Dhoga biro wacho pak ne Jehova Nyasaye. 
\q2 Gik mangima duto mondo opak nyinge maler, 
\q2 nyaka chiengʼ kendo nyaka chiengʼ. 
\c 146  
\cl Zaburi 146 
\q1  
\v 1 Pak ne Jehova Nyasaye! 
\q1 Yaye chunya, pak Jehova Nyasaye. 
\q2  
\v 2 Abiro pako Jehova Nyasaye e ngimana duto; 
\q2 abiro wero wende pak ne Nyasacha kinde duto ma angima. 
\b  
\q1  
\v 3 Kik iket genoni kuom ruodhi mag piny, 
\q2 kata kuom dhano matho ma ok nyal waro ngʼato, 
\q2  
\v 4 nikech ka chunygi ochot to gidok e lowo; 
\q2 kendo chiengʼono chenrogi ogik gikanyono. 
\q1  
\v 5 Ogwedh ngʼat ma konyruokne en Nyasach Jakobo, 
\q2 ngʼat ma genone ni kuom Jehova Nyasaye ma Nyasache. 
\b  
\q1  
\v 6 En jachwech mar polo gi piny, 
\q2 gi nam kod gik moko duto manie igi, 
\q2 osiko ka en ja-adiera nyaka chiengʼ. 
\q1  
\v 7 Ochwako ngʼat misando 
\q2 kendo ochiwo chiemo ne joma odenyo. 
\q1 Jehova Nyasaye gonyo joma otwe mi gibed thuolo, 
\q2  
\v 8 kendo Jehova Nyasaye miyo muofni neno. 
\q1 Jehova Nyasaye miyo joma piny otaro aa malo, 
\q2 kendo ohero joma kare. 
\q1  
\v 9 Jehova Nyasaye rito jadak 
\q2 kendo okonyo nyathi kich gi dhako ma chwore otho, 
\q2 to yore mag ngʼama timbene richo to orocho. 
\b  
\q1  
\v 10 Jehova Nyasaye olocho nyaka chiengʼ yaye Sayun, 
\q2 Nyasachi olocho nyaka tienge duto mabiro. 
\b  
\q1 Pakuru Jehova Nyasaye! 
\c 147  
\cl Zaburi 147 
\q1  
\v 1 Pakuru Jehova Nyasaye! 
\q1 Mano kaka en gima ber wero wende pak ne Nyasachwa, 
\q2 mano kaka en gima longʼo kendo mowinjore mondo ji opake! 
\b  
\q1  
\v 2 Jehova Nyasaye gero Jerusalem kendo; 
\q2 ochoko jo-Israel mane otwe. 
\q1  
\v 3 Ochango joma chunygi tuo 
\q2 kendo othiedho adhondegi. 
\q1  
\v 4 Osekwano kendo ongʼeyo kar romb sulwe duto 
\q2 kendo oluongo moro ka moro kuomgi gi nyinge. 
\q1  
\v 5 Ruodhwa duongʼ kendo en gi teko kendo nyalo; 
\q2 ngʼeyone onge gikone. 
\q1  
\v 6 Jehova Nyasaye tingʼo joma obolore malo 
\q2 to joma timbegi richo to ochwado piny e lowo. 
\b  
\q1  
\v 7 Weruru ne Jehova Nyasaye kugoyone erokamano, 
\q2 weruru wer mamit ne Nyasachwa kugoyo nyatiti. 
\b  
\q1  
\v 8 Oumo kor polo gi boche polo, 
\q2 kendo oromo piny gi koth, 
\q2 bende omiyo lum twi ewi thuche. 
\q1  
\v 9 Ochiwo chiemo ne dhok 
\q2 kendo ne agege ka giywakne. 
\b  
\q1  
\v 10 Morne ok ni kuom teko farase 
\q2 kata kuom ogwand dhano; 
\q1  
\v 11 to Jehova Nyasaye mor gi joma omiye luor; 
\q2 joma oketo genogi kuom herane ma ok rem. 
\b  
\q1  
\v 12 Dhial Jehova Nyasaye, yaye Jerusalem; 
\q2 pak Nyasachi, yaye Sayun. 
\b  
\q1  
\v 13 Omedo sirni manie dhorangeyeni teko, 
\q2 kendo ogwedho jogi modak e iyi. 
\q1  
\v 14 Omiyo kwe bedo e tongʼ pinyu 
\q2 kendo oromou gi ngano mabeyoe mogik. 
\b  
\q1  
\v 15 Ooro chikne e piny, 
\q2 kendo wachne ringo matek ka diemo wangʼ. 
\q1  
\v 16 Oyaro pe ka yie rombo 
\q2 kendo okeyo ongʼwengʼo ka buru. 
\q1  
\v 17 Odiro pe mage e piny ka kit ombo. 
\q2 En ngʼa manyalo ngino sa ma odiro pe kamano? 
\q1  
\v 18 Ooro wachne kendo pego leny nono; 
\q2 ee, otugo yembene mi pego lokre pi mamol. 
\b  
\q1  
\v 19 Osenyiso Jakobo wachne, 
\q2 ee, osenyiso Israel chikene gi buchene. 
\q1  
\v 20 Onge oganda moro machielo mosetimone kamano 
\q2 kendo gin ok gingʼeyo chikene. 
\b  
\q1 Pakuru Jehova Nyasaye! 
\c 148  
\cl Zaburi 148 
\q1  
\v 1 Pakuru Jehova Nyasaye! 
\q1 Pakuru Jehova Nyasaye gie polo, 
\q2 ee, pakeuru gi malo kuma bor. 
\q1  
\v 2 Pakeuru, un malaikane duto, 
\q2 pakeuru, un jopolo duto. 
\q1  
\v 3 Wangʼ chiengʼ gi dwe 
\q2 bende opake, kaachiel gi sulwe duto marieny. 
\q1  
\v 4 Un polo man malo mogik, 
\q2 pakeuru, kaachiel gi un, pige manie bwo polo. 
\q1  
\v 5 Onego gipak nying Jehova Nyasaye kargi duto 
\q2 nimar nogolo chik mine gibetie. 
\q1  
\v 6 Ne ogurogi kuondegi nyaka chiengʼ 
\q2 kendo nyaka chiengʼ kaluwore gi chikne mochwere. 
\b  
\q1  
\v 7 Pakuru Jehova Nyasaye gie piny, 
\q2 un gik madongo mag nam kod kude matut duto mag ataro, 
\q1  
\v 8 kaachiel gi mil polo gi pe gi theluji gi boche, 
\q2 kod yembe maringo matek mawinjo wachne; 
\q1  
\v 9 kod un gode gi thuche 
\q2 gi yiende manyago olembe gi yiende mag sida duto; 
\q1  
\v 10 kod le mager gi jamni duto 
\q2 gi le matindo gi winy mafuyo, 
\q1  
\v 11 kod ruodhi mag piny gi ogendini duto; 
\q2 kod un jotelo gi joloch duto mag piny, 
\q1  
\v 12 kod un yawuowi matindo gi nyiri matindo, 
\q2 gi jodongo kod nyithindo. 
\b  
\q1  
\v 13 Onego gipak nying Jehova Nyasaye gin duto, 
\q2 nimar nyinge kende ema nigi duongʼ; 
\q2 kendo duongʼne maler oyombo piny gi polo. 
\q1  
\v 14 Osechungo tung ne joge, 
\q2 tung mosekelo pak ne joge maler duto, 
\q2 joge ma jo-Israel, ma gin joma ni machiegni gi chunye. 
\b  
\q1 Pakuru Jehova Nyasaye! 
\c 149  
\cl Zaburi 149 
\q1  
\v 1 Pakuru Jehova Nyasaye! 
\q1 Werneuru Jehova Nyasaye wer manyien, 
\q2 kendo dendeuru e chokruok mar jomaler. 
\b  
\q1  
\v 2 Jo-Israel mondo obed mamor gi jachwechgi; 
\q2 ee, jo-Sayun mondo obed mamor gi Ruodhgi. 
\q1  
\v 3 Onego gi pak nyinge gi miel 
\q2 kendo giwerne mamit ka gigoyo oyieke gi nyatiti. 
\q1  
\v 4 Nimar chuny Jehova Nyasaye mor gi joge 
\q2 kendo osidho joma obolore gi warruok. 
\q1  
\v 5 Jomaler mondo oil kamiye duongʼ 
\q2 kendo giwer gimor ka gibet e kitandagi. 
\b  
\q1  
\v 6 Onego pak mar Nyasaye obed e dhogi 
\q2 kendo gitingʼ ligangla ma dhoge ariyo e lwetgi, 
\q1  
\v 7 mondo gichulgo kuor ni ogendini 
\q2 kendo gikum ogendini mamoko, 
\q1  
\v 8 kendo gitwe ruodhigi gi nyoroche, 
\q2 kod jotendgi gi opingo mag chuma, 
\q1  
\v 9 ka gichopo kum mane ondik kuomgi chon. 
\q2 Ma e duongʼ mar joge maler duto. 
\b  
\q1 Pakuru Jehova Nyasaye! 
\c 150  
\cl Zaburi 150 
\q1  
\v 1 Pakuru Jehova Nyasaye! 
\q1 Pakuru Nyasaye e kare maler mar lemo; 
\q2 pakeuru ei polo mare mar nyalo. 
\q1  
\v 2 Pakeuru nikech tijene mosetimo kuom tekone maduongʼ; 
\q2 kendo nikech duongʼne moyombo duto. 
\q1  
\v 3 Pakeuru kugoyo turumbete, 
\q2 kendo kugoyo nyatiti gi asili, 
\q1  
\v 4 pakeuru kugoyo oyieke kendo umiel, 
\q2 ee, pakeuru gi gita kod oporo, 
\q1  
\v 5 pakeuru kudiemo ongengʼo gi nyawadgi, 
\q2 ee, pakeuru ka ongengʼo gore. 
\b  
\q1  
\v 6 Gimoro amora mayweyo mondo opak Jehova Nyasaye. 
\q1 Pakuru Jehova Nyasaye.