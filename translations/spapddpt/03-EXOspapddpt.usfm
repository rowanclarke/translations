\v 19 \nd \+w Yavé|strong="H3068"\+w*\nd* dijo \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w* \w en|strong="H3588"\w* \w Madián|strong="H4080"\w*: \wj Regresa \+w a|strong="H3068"\+w* \+w Egipto|strong="H4714"\+w*, \+w porque|strong="H3588"\+w* \+w murieron|strong="H4191"\+w* \+w todos|strong="H3605"\+w* \+w los|strong="H3605"\+w* \+w que|strong="H3588"\+w* buscaban tu \+w vida|strong="H5315"\+w*.\wj*   
