\v 48 രെസീൻ, നെക്കോദ, ഗസ്സാം,
\tr 
\tc1 
\v 49 ഉസ്സ, പാസേഹ, ബേസായി,
\tr 
\tc1 
\v 50 അസ്ന, മെയൂനിം, നെഫീസീം,
\tr 
\tc1 
\v 51 ബക്ക്ബൂക്ക്, ഹക്കൂഫ, ഹർഹൂർ,
\tr 
