\p
\v 1 Voici \w les|strong="H5927"\w* \w chefs|strong="H7218"\w* \w de|strong="H4428"\w* \w leurs|strong="H5927"\w* \w maisons|strong="H7218"\w* paternelles, \w et|strong="H4428"\w* voici \w la|strong="H5927"\w* \w généalogie|strong="H3187"\w* \w de|strong="H4428"\w* \w ceux|strong="H7218"\w* \w qui|strong="H4428"\w* \w montèrent|strong="H5927"\w* \w avec|strong="H5973"\w* \w moi|strong="H4428"\w* \w de|strong="H4428"\w* \w Babylone|strong="H4428"\w*, \w sous|strong="H4428"\w* \w le|strong="H5927"\w* \w règne|strong="H4438"\w* \w du|strong="H5927"\w* \w roi|strong="H4428"\w* \w Artaxerxès|strong="H4428"\w* :   
\li1
\v 2 Des fils de Phinées, Guershom.  
\li1 Des fils d'Ithamar, Daniel.  
\li1 Des fils de David, Hattush.   
\li1
\v 3 Des fils de Shecania, des fils de Pareosh, Zacharie ; et avec lui furent enregistrés par généalogie cent cinquante hommes.   
\li1
\v 4 Des fils de Pahath-Moab, Élihoénaï, fils de Zerachia ; et avec lui deux cents hommes.   
\li1
\v 5 Des fils de Shecania, le fils de Jahaziel ; et avec lui trois cents hommes.   
\li1
\v 6 Des fils d'Adin, Ébed, fils de Jonathan ; et avec lui cinquante hommes.   
\li1
\v 7 Des fils d'Élam, Ésaïe, fils d'Athalie ; et avec lui soixante-dix hommes.   
\li1
\v 8 Des fils de Shephatia, Zebadia, fils de Micaël ; et avec lui quatre-vingts hommes.   
\li1
\v 9 Des fils de Joab, Abdias, fils de Jehiel ; et avec lui deux cent dix-huit hommes.   
\li1
\v 10 Des fils de Shelomith, le fils de Josiphia ; et avec lui cent soixante hommes.   
\li1
\v 11 Des fils de Bébaï, Zacharie, fils de Bébaï ; et avec lui vingt-huit hommes.   
\li1
\v 12 Des fils d'Azgad, Johanan, fils de Hakkatan ; et avec lui cent dix hommes.   
\li1
\v 13 Des fils d'Adonikam, qui étaient les derniers, voici leurs noms : Éliphéleth, Jeïel et Shemaja ; et avec eux soixante hommes.   
\li1
\v 14 Des fils de Bigvaï, Uthaï et Zabbud ; et avec eux soixante-dix hommes.   
\p
