\id HEB Ika New Testament 2009
\h Ndị Hibru
\toc1 Ẹhụhụọ-Ozi Wẹ Dejẹnni Ndị Hibru
\toc2 Ndị Hibru
\toc3 Hib
\mt2 Ẹhụhụọ-Ozi Wẹ Dejẹnni
\mt1 Ndị Hibru
\c 1
\cl Isi Nke Ohu
\s1 Osolobuẹ E Kugụọ Nwan Oku Ghahanị Nwa a
\p 
\v 1 Ogẹn mbụ, Osolobuẹ gi ụzọ rị ichẹn-ichẹn gwasọnmẹ ndị nẹdi ẹnyi wẹ oku ghahanị ndị-amụma.
\v 2 Kanị, ogẹn ịkpazụụnnị, ọ gwaọlẹ ẹnyi oku ghahanị Nwa a. Ịya kẹ Osolobuẹ yechanrịn ihiẹn ile. Ẹka Nwa a nị kẹ Osolobuẹ gha ke ụwa ile lẹ ihiẹn ile rịn'a.
\v 3 Ịya kẹ wẹ gi a hụn kẹ ọghọ Osolobuẹ nọ. Ẹnya hụn n'a a hụngụọ Osolobuẹ\f + \fr 1:3 \ft Jọn 14.9\f*. O gi oku ẹ hụ hụn nwọn ikẹn hi-ogbe e kwọndọn ụwa ile. Ogẹn o gi chụgụụ ẹjan wẹ gi a chanchanpụ njọ, ọ nọ nọdị alị azụụn ẹka-nni Osolobuẹ, Onyẹ hụn kachanrịn ihiẹn ile ọghọ e nwọn,
\v 4 makẹni ịya ka ndị mmọn-ozi, ka wẹ ọhụnma-ọhụnma; nọkẹ kẹ ẹfan (nzere) o nwẹ dọn ka nke wẹ.
\s1 Nwa Osolobuẹ Ka Ndị Mmọn-ozi
\p 
\v 5 Ẹghẹẹ; makẹni, elee mmọn-ozi kẹ Osolobuẹ sịtu,
\q1 “Nwa m kẹ ị wụ;
\q1 a ghọsịgụọ m tannị n'ị wụ nwa m” mọbụ sịzị,
\q1 “M k'a wụrụ nẹdi ẹ,
\q1 ọ wụrụ nwa m.”?
\p 
\v 6 Ogẹn Osolobuẹ gidẹ wẹhẹ Nwa-ibuzọ a hụ imẹ ụwa, ọ sị,
\q1 “Ndị mmọn-ozi Osolobuẹ ile, fe n'ẹ.”
\p 
\v 7 Nke ndị mmọn-ozi, ihiẹn Osolobuẹ ku wụ nị
\q1 “Chuku mẹ ndị mmọn-ozi ẹ e hẹnrin ufere;
\q1 o mẹ ndị idibo ẹ e hẹnrin ọkụn rị e nwunni.”
\p 
\v 8 Kanị, nke Nwa a, ihiẹn Osolobuẹ ku wụ,
\q1 “Euu, Osolobuẹ!
\q1 Ukpo ị nọ a kị
\q2 k'a tọ jẹnrin ejẹn;
\q1 ezi-omumẹ wụ ọkpọ ị
\q2 hụn i gi a kị Alị-eze i.
\q1 
\v 9 Ihiẹn furuni wụ ihiẹn a sụọnị ị;
\q1 njọ e ze i ize.
\q1 Ịya haịn Osolobuẹ—Osolobuẹ i—
\q2 gi hukpu i udẹn-ịghọghọ,
\q2 tumẹ i,
\q2 ye i ọnọdị
\q2 hụn kachanrịn nke ibe i.”
\p 
\v 10 Osolobuẹ sịzị Nwa a,
\q1 “Di-nwọnni-ẹnyi,
\q1 ịyụ ke ụwanị ogẹn mbidọn;
\q1 ẹka ị mẹmẹ igwere
\q2 lẹ ihiẹn ndị rị n'a.
\q1 
\v 11 Wẹ k'e wiwi,
\q2 kanị ị k'a rịferi;
\q1 wẹ k'a fafụ rịkẹ ẹkwa.
\q1 
\v 12 I k'a fụma wẹ rịkẹ ẹkwa, wepụ wẹ;
\q2 gi ọzọ nọkin ẹnya wẹ,
\q2 kẹ wẹ dọn e yihutọ ẹwuru.
\q1 Kanị, yụ nwẹn egbehutọkọ;
\q2 ndụn ị enwọnkọ ọgụgụ.”
\p 
\v 13 Elee mmọn-ozi kẹ Osolobuẹ sịtu,
\q1 “Nọdị alị ẹka-nni m ebeni,
\q2 d'e ru mgbe m gigụụ ndị iṅẹnrẹn
\q2 i mẹmẹ n'i ihiẹn i gi a zọma ụkụ”?
\p 
\v 14 Kịnị kẹ ndị mmọn-ozi wụdẹ? Ẹlẹ mmọn ndị e jẹn ozi kẹ wẹ wụ; mmọn ndị Osolobuẹ zihẹ d'a rụn ọrụn makẹ ọrịnịmma ndị jẹnkọ d'e nwọn nzụọfụha?
\c 2
\cl Isi Nke Ẹbụọ
\s1 Nabanhankwọ Nị Okẹn Nzụọpụhanị!
\p 
\v 1 Ya wụ, ẹnyi k'e kwọnkẹnmẹrịrị ihiẹn ẹnyi nụ, amamgbe ẹnyi a kpahu.
\v 2 Makẹni, omẹni ozi mbụ hụ, Iwu ahụn, wẹ gha ẹka ndị mmọn-ozi ye ndị nẹdi ẹnyi ogẹn Mozizi wụkẹnmẹ ihiẹn wẹ gi dọn ẹnya, nke wụ nị onyẹ ọwụlẹ nupụ isi okpuru ẹ mọbụ dan iwu rịn'a a narịn afụnfụn furuni,
\v 3 nanị kẹ ẹnyi k'a dọn nwan wanahịn omẹni ẹnyi e lelịa okẹn nzụọfụhanị nọ ẹnịna? Nzụọpụhanị Di-nwọnni-ẹnyi lẹ enwẹn ẹ bu ụzọ zimẹ ozi ẹ; hụn ndị gha ọnụ a nụ a shịa ẹri, ghọsị ẹnyi nị ezioku k'ọ wụ,
\v 4 Chuku lẹ enwẹn ẹ nọzị shịa ẹri nị ozi wẹ wụ ezioku, ghahanị okẹn-ihiẹn rị ichẹn-ichẹn o mẹsọnmẹ—kẹ ihiẹn ahịma o gi ghọsị nị ẹka a k'ọ gha bịa kẹ ọrụn atụmẹnya kẹ hụn o gi ghọsị ikẹn ẹ. Ọ shịaghọzịkwọ ẹri ghahanị oyiye Mmọn-nsọ o yesọnmẹ k'o dọn chọ.
\s1 Jesu Wụ Onyẹ-nzụọpụha Zu-oke
\p 
\v 5 Ẹlẹ ndị mmọn-ozi kẹ Osolobuẹ tumẹ nị wẹ k'a kị ụwa hụn lalanị, hụn ẹnyi rị e ku oku ẹ. Kaka!
\v 6 O nwọnghọdẹ ebe wẹ nọ ku oku ẹ imẹ Ẹhụhụọ-nsọ, sị,
\q1 “Kịnị kẹ ịhịan wụdẹ nwan
\q2 i gi e ro ẹ?
\q1 Kị ịhịan mmaka wụdẹ
\q2 i gi e lepụ a ẹnya?
\q1 
\v 7 Y'e mẹọlẹ ndị mmọn-ozi karị a
\q2 ẹkẹrẹ ogẹn;
\q1 
\v 8 y'e gigụọ ọghọ lẹ mgbaye kpumẹ ẹ.”
\p O mẹ nwan nị Osolobuẹ “e bugụọ ihiẹn ile che ẹ okpuru ụkụ”, ya wụ nị o nwọnni ihiẹn rịlẹni okpuru ụkụ a. Bụ ẹnyi hụ a hụn a nị ihiẹn ile eke rị nwan okpuru ịhịan.
\v 9 Mba. Ihiẹn ẹnyi rị a hụn wụ nị Jizọsị, hụn Osolobuẹ mẹ “ndị mmọn-ozi karị a ẹkẹrẹ ogẹn,” “e kpurugụọ nwan ọghọ lẹ mgbaye rịkẹ okpu-eze.” Osolobuẹ mẹ “ndị mmọn-ozi karị a ẹkẹrẹ ogẹn” kẹni ọ nwụndọnni ịhịan ile ọnwụn makẹ ifiri ẹfọma Osolobuẹ: “O kpurugụọ nwan ọghọ lẹ mgbaye rịkẹ okpu-eze” makẹni ọ nwụn ya wụ ọnwụn.
\p 
\v 10 Osolobuẹ mẹ ihiẹn furuni. Ẹka a kẹ ihiẹn ile gha bịa; ihiẹn ile wụzịkwọ nke ẹ. Makẹni ọ chọ n'ọ zụọpụha ndị bu ọda, webahan wẹ ebe ọ rị, kẹni wẹ wụrụ ụmụ a, sọn ẹ nwẹ ọghọ a, ọ nọ gi afụnfụn kwademẹ onyẹ hụn o gi bidọn ya wụ nzụọfụha, mẹ ẹ ru ogo onyẹ-nzụọfụha.
\p 
\v 11 Kẹ onyẹ hụn e dọn wẹ nsọ wụ Jesu kẹ ndị ọ rị e dọn nsọ a wụrụgụọ nwan ụmụ onyẹ ohu. Ịya haịn ifẹnrẹn gilẹni e mẹ ẹ ọ gha a kpọ wẹ umunẹ ẹ.
\v 12 Ọ sị,
\q1 “M sikọ d'a gwa umunẹ m oku ẹfan ị;
\q1 ẹnyi gbakikomẹ,
\q2 m sikọ d'a ja ị mma.”
\p 
\v 13 Ọ sịzị,
\q1 “M k'e gi ẹ dọn ẹnya,” sịzịkwọ,
\q1 “E lee mmẹ lẹ ụmụ Osolobuẹ ye m.”
\p 
\v 14 Ya wụ, ebe o mẹ ni ụmụ a ndị hụ wụ ịhịan nwọn ẹhụ-lẹ-ẹdeke, ya lẹ enwẹn nọ sọn wẹ wụrụ ihiẹn ohu hụ, kẹni ọ nwụnhụn, gi ọnwụn a tikpọ ikẹn onyẹ hụn gi ikẹn ọnwụn, ya wụ Ekwensụ.
\v 15 O mẹ ẹ kẹni o gi ụzọnị tọpụ ndị hụn egun ọnwụn rị a kị rịkẹ igbọn kete w'a mụlẹ wẹ.
\v 16 Makẹni, ọ wụ ihiẹn wechanrịn ẹnya ọhụnma-ọhụnma nị ẹlẹ ndị mmọn-ozi k'ọ bịa d'e yeni ẹka, kanị ụmụ Ebraham.
\v 17 Ya haịn Osolobuẹ gi mẹ ẹ n'ọ rịchanrịn kẹ ẹnyi wụ umunẹ ẹ ụzọ ile, kẹni ọ hụn ụzọ wụrụ onyẹ-isi nchụ-ẹjan hụn nwẹ omikẹn lẹ hụn furu wẹ gi e dọn ẹnya imẹ ọrụn Osolobuẹ, n'ọ hụn ụzọ chụnị ịhịan ẹjan w'e gi wepụ njọ wẹ lẹ afụnfụn njọ te k'e buhẹ.
\v 18 Makẹni ẹnya hụn a ihiẹn ogẹn wẹ gi nwan a, ọ sa nwan ẹka e yeni ndị hụn wẹ rị a nwan ẹka.
\c 3
\cl Isi Nke Ẹtọ
\s1 Jizọsị Ka Mozizi
\r (Ditọrọnọmi 18.18-19; Luk 9.33-36)
\p 
\v 1 Umunẹ m rị nsọ wẹ kpọ mmẹ lẹ wẹ oku elu-igwee, e rokwọ nị nwan Jizọsị, hụn wụ onyẹ ozi pụ-ichẹn Osolobuẹ gi wẹhẹ okukweni ẹnyi rị imẹ ẹ, hụn wụzịkwọ onyẹ-isi nchụ-ẹjan rịn'a,
\v 2 hụn ghọsị n'o furu onyẹ wẹ gi e dọn ẹnya ebe Osolobuẹ hụn tumẹ n'ẹ rị, nọkẹ kẹ Mozizi dọn ghọsị nị ịya wụ Mozizi furu onyẹ wẹ gi e dọn ẹnya imẹ ụlọ Osolobuẹ ile.
\v 3 Kanị, o furu nị wẹ ka Jesu ọghọ e ye karị Mozizi, nọkẹ kẹ onyẹ tụn ụlọ dọn ka ụlọ ọghọ e nwọn.
\v 4 (Makẹni ụlọ ọwụlẹ nwọn onyẹ rụn n'a, kanị Osolobuẹ ya rụn ihiẹn ile).
\v 5 Eziẹ, Mozizi rụn ọhụnma imẹ ụlọ Osolobuẹ ile; kanị ọ rụnhụ ọhụnma kẹ odibo, hụn wẹ zi d'e ku oku ihiẹn ndị Osolobuẹ jẹnkọ d'e ku omẹgụụ.
\v 6 Kanị, Kraịstị rụn ọhụnma nọkẹ Nwa hụn ụlọ Osolobuẹ rị ẹka. Ẹnyi wụ ụlọ Osolobuẹ—o mẹkwọ nị obi e rusọnmẹ ẹnyi alị gisọnmẹ olile-ẹnyanị ẹnyi nwọn e dọn ẹnya.
\s1 Y'e Kwerini, Ya wụ nị Y'e Nupụgụọ Isi
\p 
\v 7 Ya wụ, nọkẹ kẹ Mmọn-nsọ dọn ku,
\q1 “Ụnụ nụ olu Osolobuẹ tannị,
\q2 
\v 8 etikinkwọlẹ ni obi ụnụ—
\q2 kẹ ndị nẹdi ụnụ dọn mẹ
\q2 ogẹn ahụn wẹ gi nupụ isi;
\q2 kẹ wẹ dọn mẹ
\q2 ụhụọhịn hụ wẹ chọ ihiẹn rị m ọnụ imẹ atụ.
\q1 
\v 9 Ndị nẹdi ụnụ nọ nọ ebẹhụ chọ ihiẹn rị m ọnụ,
\q2 m nọ ghọsị wẹ ikẹn m
\q2 ọrọgbọ ahụa ọgụnnaị—
\q1 
\v 10 makẹni iwe agbọ hụ we m.
\q1 M nọ sị,
\q2 ‘Ogẹn ile kẹ obi wẹ gi a kpahu,
\q2 w'e ke marịn kẹ m'e mẹ.’
\q1 
\v 11 M nọ gi iwe kun enwẹn m, sị,
\q2 ‘Abanyekọ wẹ d'e zu ikẹn ahụn m kwademẹ!’ ”
\p 
\v 12 Umunẹ m, kpachanpụkwọ nị nwan ẹnya amamgbe ọ gha e nwọn onyẹ ọwụlẹ imẹ ụnụ hụn nwọn eje-obi, obi hụn kwerilẹni, obi hụn k'a gha ebe Chuku hụn rị ndụn rị pụ.
\v 13 Kanị, e gi ni oku-Chuku a kpọtiẹn obi ibe ụnụ ụhụọhịn-ụhụọhịn, hụnnị “tannị” ahụn wẹ ku oku ẹ imẹ Ẹhụhụọ-nsọ kelẹni ghafe, amamgbe ọ gha e nwọn onyẹ njọ dufie, mẹ ẹ n'ọ kpọkin obi ẹ.
\v 14 Makẹni ẹnyi lẹ Kraịstị k'a rịsọnmẹ omẹni ẹnyi e kwọnkẹnmẹ obi-erumalị ahụn ẹnyi gi bidọn d'e ru njẹndemẹ.
\v 15 Nọkẹ kẹ wẹ dọn ku ẹ imẹ Ẹhụhụọ-nsọ:
\q1 “Ụnụ nụ olu Osolobuẹ tannị,
\q2 e tikinkwọlẹ ni obi ụnụ,
\q2 kẹ ndị nẹdi ụnụ dọn mẹ
\q2 ụhụọhịn hụ wẹ nufụ isi.”
\p 
\v 16 Elee ndị wụ ndị ahụn nụ olu ẹ nupụ isi? Ẹlẹ ndị hụ ile Mozizi gha alị Ijiptu dupụha?
\v 17 Elee ndị kẹ ize wẹ ze Osolobuẹ ọrọgbọ ahụa ọgụnnaị? Ẹlẹ ndị ahụn mẹ njọ? Ẹlẹ wẹ nwụntọsọnmẹ imẹ atụ?
\v 18 Elee ndị k'o kunni enwẹn ẹ nị abanyekọ wẹ d'e zu ikẹn ahụn ọ kwademẹ? Ẹlẹ ndị hụ nupụ isi?
\v 19 Ẹnyi a hụngụọ a nwan nị abanyeni wẹ makẹni ekwerini wẹ.
\c 4
\cl Isi Nke Ẹnọ
\s1 Izu-ikẹn Osolobuẹ Kwademẹ Ni Ndị Nke Ẹ
\p 
\v 1 Ya wụ, hụnnị nkwa ahụn o kwe—nị ẹnyi jẹnkọ d'a banye d'e zu ikẹn hụ ọ kwademẹ—kelẹni gharị nwan, nị ẹnyi gikwọ nị egun kpachanpụ ẹnya, makẹ ọ gha enwẹ onyẹ rị imẹ ụnụ hụn furulẹni n'ọ banye d'e zu ikẹn ahụn.
\p 
\v 2 Makẹni, ẹnyi a nụghọ oziọma kẹ wẹ dọn nụ a, kanị ozi wẹ nụ abannị nị wẹ erere, makẹni arị wẹ ndị gi okukwe nabanhan a.
\v 3 Ẹnyi ndị hụn kwerini k'a banye d'e zu ikẹn hụ nọkẹ kẹ Osolobuẹ dọn ku imẹ Ẹhụhụọ-nsọ, sị,
\q1 “Nọkẹ kẹ m dọn gi iwe kun enwẹn m, ku,
\q2 ‘Abanyekọ wẹ d'e zu ikẹn ahụn m kwademẹ!’ ”
\p Osolobuẹ ya kuzi oku izu-ikẹnni, ọsụọn'a n'ọ rụnchanrịngụọ ọrụn a kete ọ tụnlẹ iyetọ ụwa.
\v 4 O nwọnghọ ebe ọ nọ ku oku ụhụọhịn nke ẹsanị imẹ Ẹkụkwọ-nsọ, sị, “Hụn mẹ ẹ akpụ-ụhụọhịn ẹsa, Osolobuẹ nọ zu ikẹn ọrụn ile ọ rụn.”
\v 5 Ọ nọzị nwan ku hụnnị ẹnyi rị e leban ẹnya ebeni, sị,
\q1 “Abanyekọ wẹ d'e zu ikẹn ahụn m kwademẹ.”
\p 
\v 6 Ebe o mẹ ni oghere ịhịan e gi banye d'e zu ikẹn hụ hụzị a, bụ ndị hụ bu ụzọ nụ oziọma abanyeni makẹni wẹ nupụ isi,
\v 7 Osolobuẹ nọ kayezi ụhụọhịn ọzọ, kpọ a “\bd tannị\bd*.” Ọ nọ ku ẹ imẹ Ẹhụhụọ-nsọ ghahanị Defidi—ebẹhụ ẹnyi rụtụ ẹka n'ọ sị,
\q1 “Ụnụ nụ olu ẹ \bd tannị\bd*,
\q2 etikinkwọlẹ ni obi ụnụ.”
\p 
\v 8 Makẹni, omẹni Joshụa e te dubangụọ wẹ d'e zuru ikẹn ahụn, Osolobuẹ e ke kumẹzi oku ụhụọhịn ọzọ.
\p 
\v 9 Ya wụ nwan nị izu-ikẹn ọrụn hụkwọ e che ndị nke Osolobuẹ,
\v 10 makẹni, onyẹ banye d'e sọn Osolobuẹ zu ikẹn, o zu ikẹn ọrụn a, nọkẹ kẹ Osolobuẹ dọn zu ikẹn ọrụn a.
\v 11 Nị ẹnyi nwankẹnmẹ ni nwan, kẹni ẹnyi banye d'e zu ikẹn hụ, amamgbe ọ gha e nwọn onyẹ danpụnị ghahanị inupụ-isi—ụdị hụn ndị mbụ nupụ.
\p 
\v 12 Makẹni, Oku Osolobuẹ rị ndụn; ọ rụn ọrụn; ọ tụ nkọ, tụkarị ọpịa-agha ọnụnaị ọwụlẹ—o zubanchanrịn imẹ d'e rudẹ umẹ-ndụn lẹ mmọn, d'e rudẹ okẹn-ẹhụ lẹ ụmị-ọkpụkpụ. O ru imẹ obi ịhịan d'e lele iroro ẹ lẹ ihiẹn o bu obi—ku kẹ wẹ hụ mma ra arị wẹ mma.
\v 13 Ebe Osolobuẹ rị, o nwọnni ihiẹn zuerini. Ẹghẹẹ, ihiẹn ile gba ọtọ ẹnya onyẹ hụ ẹnyi jẹnkọ d'e ye mgbakọ, ọ hụnchanrịn ihiẹn ile kẹ wẹ nọ.
\s1 Jizọsị Wụ Okẹn Onyẹ-isi Nchụ-ẹjan Ẹnyi
\p 
\v 14 Ebe o mẹ ni ẹnyi e nwọnghọ okẹn onyẹ-isi nchụ-ẹjan wụ Jizọsị Nwa Osolobuẹ, hụn ghafegụụ elu-igwere, banye ebe Osolobuẹ rị, nị ẹnyi kwọnkẹnmẹ nwan ihiẹn hụ ẹnyi sị nị ya kẹ ẹnyi kweri.
\v 15 Makẹni onyẹ-isi nchụ-ẹjan ẹnyi ẹlẹ hụn marịnlẹni nị ẹnyi e nwọn ikẹn, kanị hụn wẹ nwangụụ ụzọ ile nọkẹ ẹnyi, bụ o mẹni njọ.
\v 16 Nị ẹnyi wefụ nwan egun, bịa ukpo ẹfọma Osolobuẹ, kẹni ẹnyi nwẹhẹn omikẹn, nwọnhẹnzikwọ eyemẹka a—ogẹn o gi rị ẹnyi mkpa.
\c 5
\cl Isi Nke Isẹn
\p 
\v 1 Wẹ a gha imẹ igunrun ịhịan a họrị onyẹ ọwụlẹ hụn jẹnk'a wụ onyẹ-isi nchụ-ẹjan, e tumẹ, kẹni ọ nọkin ẹnya wẹ ebe ihiẹn Osolobuẹ rị, e ye Osolobuẹ oyiye, e gi ifiri njọ a chụ ẹjan.
\v 2 Ọ marịngụọ kẹ wẹ dọn e gi ẹka alụlụa e sọn ndị marịnlẹni ihiẹn lẹ ndị-mmẹfie makẹni ọ rụnahịnzịkwọ ya lẹ enwẹn ẹ arụnahịn.
\v 3 Ịya haịn o gi mẹ ni o k'a gha a chụrịrị ẹjan makẹ njọ ya lẹ enwẹn ẹ lẹ njọ ndị hụ.
\v 4 Ịhịan ara ye enwẹn ẹ ọkwanị lẹ ọghọ rịn'a. Osolobuẹ sụọ ya a kpọ ịhịan, e ye ẹ ya. Ẹrịra k'o dọn kpọ Ẹrọnụ.
\v 5 Ẹrịrazịkwọ, ẹlẹ Kraịstị ye enwẹn ẹ ọkwa lẹ ọghọ onyẹ-isi nchụ-ẹjan—Osolobuẹ ya tumẹ ẹ, Osolobuẹ hụn sị a,
\q1 “Nwa m k'ị wụ;
\q1 a ghọsịgụọ m tannị n'ị wụ nwa m.”
\p 
\v 6 Ebe ọzọ imẹ Ẹhụhụọ-nsọ, ọ sịzị,
\q1 “Onyẹ nchụ-ẹjan k'ị wụ jẹnrin ejẹn—
\q2 ụdị nke Mẹkizẹdẹkị.”
\p 
\v 7 Ogẹn Jizọsị gi rị elu ụwanị, o mẹ ekpere, a rịọ Osolobuẹ arịrịọ; e gi okẹn-ẹkwan lẹ ẹnya-mirin a kpọku Osolobuẹ hụn k'a saẹka zụọpụha a imẹ ọnwụn, Osolobuẹ nọ nụ ekpere ẹ makẹni ọ lachanrịn enwẹn ẹ tọnị Osolobuẹ.
\v 8 Ọsụọn'a nị nwa a rọ, afụnfụn kẹ Osolobuẹ gi zụn a, ọ ta afụnfụn, humẹchanrịn isi.
\v 9 O gigụụ a nwan zu oke, ruchanrịn ogo, ọ nọ wụrụ onyẹ hụn nzụọpụha itẹbitẹ gha ẹka-a a bịanị onyẹ ọwụlẹ k'e humẹn'ẹ isi—
\v 10 makẹni Osolobuẹ e tumẹgụọ a onyẹ-isi nchụ-ẹjan, ụdị nke Mẹkizẹdẹkị.
\s1 Nkuzi Ibuzọ Rị Imẹ Ofufe Kraịstị
\p 
\v 11 Ihiẹn ẹnyi chọ nị ẹnyi ku banyeni ọnwan bu ọda, kanị ọ fụka ọrụn ọkọwa, makẹni ụnụ arịzị a s'ẹka a ghọta.
\v 12 Ẹghẹẹ, makẹni, o te furu nwan ni ụnụ rị a kuzi ndị ọzọ, kanị ụnụ e hẹnringụọzị ndị wẹ k'a kuzimẹzi ihiẹn ibuzọ rị oku Osolobuẹ! Ụnụ e hẹnringụọzị ndị wẹ k'e ye mirin-ẹran ẹlẹ ihiẹn-oriri zeni!
\v 13 Makẹni onyẹ ọwụlẹ rị a ra ẹran wụhụ ogbori ebe oku ihiẹn Osolobuẹ chọ rị, makẹni nwata k'ọ wụhụ.
\v 14 Kanị, ihiẹn-oriri zeni wụ nke ndị ka ẹhụ; nke ndị hụn zụngụụ enwẹn wẹ ghahanị imẹsọnmẹ ihiẹn wẹ rị a mụ d'e ru nị a marịn wẹ ihiẹn rị ichẹn imẹ njọ lẹ mma.
\c 6
\cl Isi Nke Isin
\s1 Nị Ẹnyi Jẹnshi Ni Ihun Imẹ Okukwe
\p 
\v 1 Ya wụ, nị ẹnyi la nị nwan nkuzi ibuzọ ndịnị w'a kuzi banyeni Kraịstị, hụn ẹnyi mụgụụ tọ, jẹnshi ihun, kẹni ẹnyi hụn ụzọ ka ẹhụ imẹ okukwe. (Ẹlẹ hụn ẹnyi e gi gbemẹzi iyetọ, kuzimẹzi banyeni irogharị mẹbehi ihiẹn ndị ahụn ghalẹni e ye ndụn, lẹ ikwerini Osolobuẹ
\v 2 lẹ nkuzi banyeni ụdị mirin-Chuku rị ichẹn-ichẹn lẹ ibu ẹka kwasị ịhịan lẹ ịgha ọnwụn lihi lẹ okinkin-ikpẹ itẹbitẹ.)
\v 3 Ẹghẹẹ, ẹnyi sikọ d'e jẹnshi nwan ihun—emẹni Osolobuẹ e kwerighọ.
\v 4 Makẹni, asakọ wẹ ẹka mẹ ndị hụn latọgụụ okukwe wẹ nị wẹ gbehutọzị obi wẹ, kwerizi: ndị hụn o mẹ ni Osolobuẹ e te shịapụgụọ wẹ ẹnya; a danmịngụọ wẹ oyiye elu-igwee; Mmọn-nsọ e rugụọ wẹ ẹka;
\v 5 a damịngụọ wẹ oku Osolobuẹ, hụn a n'ọ rịka mma; a hụngụọ wẹ ikẹn ogẹn hụ hụn lalanị—
\v 6 bụ a lazịkwọ wẹ Osolobuẹ tọ!
\p Asakọzị wẹ ẹka wekinhẹn wẹ d'e gbehutọzị obi wẹ, makẹni wẹ rị a kpọgbuzi Nwa Osolobuẹ elu obe, e gbe ifẹnrẹn e ye ẹ ihun ebe ịhịan ile rị, e gi ẹ e mẹ enwẹn wẹ.
\p 
\v 7 Alị hụn a ra mirin hụn e zueyesọnmẹn'ẹ, e gi e mẹ ihiẹn wẹ kụn e sue, a bannị ndị kụn n'a erere, ngọzi k'ọ narịn ẹka Osolobuẹ.
\v 8 Kanị, o pumẹ ogun lẹ ẹkịrịka, ọ bannị erere ọwụlẹ, lehụ nị Osolobuẹ e d'a bụ a ọnụ, ọkụn wẹ k'e gi la iwi 'ya rị e che ẹ.
\p 
\v 9 Kanị, umunẹ ẹnyi rị ẹnyi obi, ọsụọn'a nị ẹnyi rị e ku ẹnịna, obi ru ẹnyi alị nị nke ụnụ jẹnkọ d'a ka mma; nị nke ụnụ k'a wụ nzụọfụha lẹ ihiẹn ndị rịn'a.
\v 10 Makẹni, Osolobuẹ ara mẹgbu ịhịan; ọ zọkọ ọrụn ụnụ rụn lẹ ihiẹn-ọsụsụọ ụnụ gi ifiri ẹfan a ghọsị ghahanị iyeni ndị nke ẹ ẹka—hụn ụnụ rịkwọ nwan e mẹ.
\v 11 Kanị, ẹnyi chọkẹnmẹ nị onyẹ ọwụlẹ imẹ ụnụ kwọnkẹnmẹ adụdụ ohu hụ d'e ru njẹndemẹ, kẹni ihiẹn ụnụ rị a tụ ẹnya a hụn ụzọ mẹzu;
\v 12 amamgbe ụnụ a lama nzụnzụn imẹ okukwẹ ọnụ; kama, nị ụnụ e sọn nzọm'ọkụ ndị hụn gi okukwe lẹ ndidi nwọnhẹn ihiẹn ndị hụn Osolobuẹ kwe nkwa a.
\s1 Osolobuẹ K'e Mẹzurịrị Nkwa O Kwe
\p 
\v 13 Ogẹn Osolobuẹ gi kwe Ebraham nkwa, ebe o mẹ ni o nwọnni onyẹ ka Osolobuẹ, Osolobuẹ nọ kun enwẹn ẹ, sị,
\v 14 “Ezioku-ezioku, m jẹnkọ d'a gọzi i ọhụnma-ọhụnma, mẹ ụmụ ị ba ụba.”
\v 15 Ebraham nọ gichanrịn ndidi cheri; o mẹgụụ, ọ nọ nwọnhẹn ihiẹn hụ Osolobuẹ kwe ẹ nkwa.
\v 16 Ịhịan e kun ihiẹn kanị wẹ; ịhịan kunhụ ihiẹn wẹ e kun gi ghọsị nị k'o dọn ku ẹ k'ọ rị, oku e bi.
\v 17 Ẹrịrazịkwọ, ogẹn Osolobuẹ gi chọ n'ọ ghọsị ndị o kwe nkwa n'o gbehutọkọ ihiẹn o bu obi, ọ nọ kun enwẹn ẹ yen'ẹ, gi ẹ ghọsị n'o sikọ d'e mẹrịrị a:
\v 18 kẹni o gi ihiẹn ẹbụọ hụn ghalẹni e gbehutọ —ya wụ nkwa a lẹ okunkun ahụn o kun enwẹn ẹ—, hụn a ghọsị nị Osolobuẹ asaẹka tụ ntụ, gbakẹnmẹ ẹnyi ndị gbabọn ni n'ẹ umẹ, kẹni ẹnyi hụn ụzọ kwọnkẹnmẹ olile-ẹnya hụ ọ sị ẹnyi nwọn.
\v 19 Olile-ẹnyanị wụ agbụn zeni, hụn furu wẹ gi e dọn ẹnya, hụn k'e kwọndọn ẹnyi, che ẹnyi—agbụn hụn wẹ gi limẹ umẹ-ndụn ẹnyi. Olile-ẹnyanị e we ẹnyi a ghafe ẹkwa mgbọnbepụ hụ, e weban ẹnyi imẹ-imẹ ebẹhụ Osolobuẹ rị;
\v 20 ebẹhụ Jesu burugụụ nị ẹnyi ụzọ banye makẹ ufiri ẹnyi—makẹni ọ wụrụgụọ onyẹ-isi nchụ-ẹjan jẹnrin ejẹn, ụdị nke Mẹkizẹdẹkị.
\c 7
\cl Isi Nke Ẹsa
\s1 Kẹ Mẹkizẹdẹkị Nọ
\r (Jẹnẹsisi 14.17-20)
\p 
\v 1 Mẹkizẹdẹkịnị wụ eze alị Salẹm; ọ wụzịkwọ onyẹ nchụ-ẹjan Osolobuẹ, Chuku Ahụn Kachanrịnnị. O kunrun Ebraham kẹ Ebraham kinla, ogẹn Ebraham gi mẹrigụụ ndị-nze hụ agha, ọ nọ gọzi Ebraham.
\v 2 Ebraham nọ kebe ihiẹn ile o bulụa agha ụzọ iri, we ụzọ ohu ye Mẹkizẹdẹkị. Nke ibuzọ, ẹfannị wụ Mẹkizẹdẹkị wụ “Eze Ihiẹn-Chuku-chọ”. Ọzọzị, Mẹkizẹdẹkị-nị wụzịkwọ eze alị \bd Salẹm\bd*, ya wụ “Eze \bd Udọn\bd*,” makẹni Salẹm wụ Udọn.
\v 3 O nwẹ nẹdi; o nwẹ nnẹ; o nwọnni ndị wẹ sị nị uwẹ mụ a. O nwẹ mbidọn; o nwẹ ọgụgụ. Ọ nọhụ kẹ nwa Osolobuẹ. Ọ wụ onyẹ nchụ-ẹjan jẹnrin ejẹn.
\v 4 Lee k'o mẹhan okẹn-ịhịan! Nke wụ nị Ebraham nẹdi-ẹnyi kanị lẹ enwẹn ẹ kebedẹ ihiẹn ile o bulụa imẹ agha hụ, ye ẹ ụzọ ohu imẹ ụzọ iri!
\p 
\v 5 Lee nwan: nke ụmụ Livaị wụ ndị nchụ-ẹjan, Iwu Mozizi sị wẹ a narịn ụmụ Izrẹlụ ibe wẹ ụzọ ohu imẹ ụzọ iri. Ya wụ, wẹ a narịn ndị nke wẹ ụzọ-ohu-imẹ-ụzọ-iri, ọsụọn'a nị wẹ ile wụ ụmụ Ebraham.
\v 6 Kanị, okẹnnyẹni wụ Mẹkizẹdẹkị ẹlẹ onyẹ ebọn wẹ, bụ ọ narịn Ebraham' ụzọ ohu imẹ ụzọ iri, gọzidẹ ẹ—ọ gọzidẹ onyẹ nwẹn Osolobuẹ lẹ enwẹn ẹ kwe nkwa!
\v 7 Onyẹ ọwụlẹ a marịngụọ nị onyẹ kanị ya nwẹ a gọzi ibe ẹ.
\p 
\v 8 Nke ụmụ Livaị, ndị hụn a narịn ụzọ-ohu-imẹ-ụzọ-iri wụ ịhịan mmaka, hụn o mẹ ni, omẹgụụ a nwụnhụn wẹ. Kanị, ụdị nke Mẹkizẹdẹkị, onyẹ hụn a narịn nị wụ onyẹ hụn Ẹhụhụọ-nsọ ku n'ọ hụ ndụn.
\v 9 Ya wụ, ẹnyi k'a sazịdẹ ẹka sị nị Livaị lẹ enwẹn ẹ, hụn ụmụ a a narịn ụzọ-ohu-imẹ-ụzọ-iri ghaha ẹka Ebraham kụ Mẹkizẹdẹkị ụzọ-ohu-imẹ-ụzọ-iri,
\v 10 makẹni Livaị rịkwọ ẹhụ nẹdi ẹ kanị wụ Ebraham ogẹn hụ Mẹkizẹdẹkị gi bịa d'e kunrun Ebraham.
\s1 Jesu Wụ Onyẹ Nchụ-ẹjan, Ụdị Nke Mẹkizẹdẹkị
\r (Ẹbụ-ọma 110.4)
\p 
\v 11 Ya wụ, omẹni ụdị ẹjan ebọn Livaị a chụ—ẹjan ahụn ya lẹ Iwu hụ wẹ ye wẹ wị bịa, te nwọn ikẹn o gi e mẹ ihiẹn n'o zu oke kẹ Osolobuẹ dọn chọ, kị haịn nwan o gi rị Osolobuẹ mkpa ikumẹzi oku onyẹ nchụ-ẹjan ọzọ—ụdị nke Mẹkizẹdẹkị, ẹlẹzidẹ ụdị nke Ẹrọnụ?
\p 
\v 12 Wẹ wepụ ụdị ẹjan lẹ ndị nchụ-ẹjan rịnị, nị e webanhan wẹ ụdị ọzọ, wẹ k'e webanhanzịrịrị iwu ọhụn hụn ya lẹ ụdị ọhụn hụ wụ ohu.
\p 
\v 13 Jesuni, hụn ihiẹn ndịnị rị e zin ẹka, wụ onyẹ ebọn ọzọ, bụ o nwọntuni onyẹ ebọn hụ rụn ọrụn rịkẹ onyẹ nchụ-ẹjan. \fig Ukpo hụ wẹ nọ a dụn ẹjan ọkụn ihun Ọdụ-ofufe mbụ hụ|src="hk00256b.jpg" size="col" loc="HEB 7" copy="Horace Knowles; The British & Foreign Bible Society" ref="7.13"\fig*
\v 14 Makẹni, o we ẹnya nị Onyẹ-nwọnni-ẹnyi wụ onyẹ ebọn Juda, bụ Mozizi a kpọnị ya wụ ebọn ẹfan ogẹn o gi ku oku ndị nchụ-ẹjan.
\v 15 Ihiẹn o gi wekẹnmẹdẹ ẹnya wụ nị, ezioku-ezioku, ụdị onyẹ nchụ-ẹjan ọzọ, hụn nọ kẹ Mẹkizẹdẹkị a pụhagụọ nwan.
\v 16 Ẹlẹ ebọn hụ Iwu Mozizi kpọ ẹfan kẹ Onyẹ nchụ-ẹjan ọzọnị gha pụha; ya wụ, ẹlẹ ebọn ọ gha bịa k'o gi wụrụ onyẹ-isi nchụ-ẹjan, kama, ọ wụ a makẹ ikẹn o nwọn hụn o gi a rị ndụn jẹnrin ejẹn.
\v 17 Makẹni ihiẹn Ẹhụhụọ-nsọ ku banyen'ẹ wụ,
\q1 “Ị wụ onyẹ nchụ-ẹjan jẹnrin ejẹn,
\q2 ụdị nke Mẹkizẹdẹkị.”
\p 
\v 18 Ya wụ, Osolobuẹ a kagbugụọ Iwu mbụ, makẹni ndụn a rị Iwu hụ, makẹni Iwu hụ asanị ẹka mẹ ihiẹn hụn rị mkpa—
\v 19 makẹni Iwu mbụ hụ e mẹni ihiẹn ọwụlẹ n'o zu oke. Kama, Osolobuẹ e webanhangụọ nwan ụzọ ọhụn, olile-ẹnya ọhụn, hụn ka mma, hụn ẹnyi e gi s'ẹka nọkunmẹ Osolobuẹ.
\p 
\v 20 Osolobuẹ kun enwẹn ẹ gi biye ihiẹnni ẹka. O kunni ihiẹn ọwụlẹ ogẹn o gi tumẹ ndị nchụ-ẹjan mbụ hụ ndị,
\v 21 kanị o kun enwẹn ẹ tumẹ Jizọsị onyẹ nchụ-ẹjan. Makẹni Osolobuẹ sị a,
\q1 “Di-nwọnni-ẹnyi e kungụọ enwẹn ẹ,
\q2 o gbehutọkọ obi ẹ.
\q1 Ọ sị,
\q1 ‘Ị wụ onyẹ nchụ-ẹjan jẹnrin ejẹn,
\q2 ụdị nke Mẹkizẹdẹkị!’ ”
\p 
\v 22 Ihiẹn ichẹnni haịn nwan Jizọsị gi wụrụ onyẹ obi gi e ru ẹnyi alị nị nkwerigbama ọhụnnị ka mma.
\v 23 Ihiẹn ọzọ rị ichẹn rịzịkwọ: ndị nchụ-ẹjan mbụ hụ bu ọda makẹni ọnwụn a nịnị onyẹ ọwụlẹ imẹ wẹ rụnsọnmẹ ya wụ ọrụn.
\v 24 Kanị, ya nwẹn awụbehikọ onyẹ nchụ-ẹjan makẹni ọ rị a-rị jẹnrin ejẹn.
\v 25 Ya wụ n'o k'a saẹka zụọpụhachanrịn ndị hụ ghaha ẹka bịa d'e kunrun Osolobuẹ, zụọpụhachanrịn wẹ d'e ru njẹndemẹ, makẹni ọ rị ndụn jẹnrin ejẹn, a rịọdọnni wẹ ebe Osolobuẹ rị.
\v 26 Onyẹ-isi nchụ-ẹjan nọ ẹnịna e furughọ ẹnyi: onyẹ-isi nchụ-ẹjan hụn rị nsọ, hụn mẹlẹni njọ, hụn nwọnlẹni ebe ọ nọ rụ, hụn ya lẹ ndị-njọ wụlẹni ohu, hụn wẹ busigụụ elu, ye ẹ ọnọdị kachanrịnnị imẹ elu-igwee.
\v 27 Ọ nọnị kẹ ndị-isi nchụ-ẹjan ọzọ hụ; ọ rịnị mkpa n'o k'a chụsọnmẹ ẹjan ụhụọhịn-ụhụọhịn: o gigụụ ifiri njọ a chụ ẹjan, o gi ifiri njọ ndị ọzọ chụ. Ọ chụgụọ ẹjan mgbe ohu, chụchanrịn a—ogẹn hụ o gi we enwẹn ẹ ye. Ịya wụzịkwọ ẹjan ikpazụụn.
\p 
\v 28 Iwu Mozizi e tumẹ ịhịan-mmaka zulẹni oke nị wẹ wụrụ ndị-isi nchụ-ẹjan; kanị Osolobuẹ e gigụọ oku o ku tumẹ Nwa Osolobuẹ hụn zu oke jẹnrin ejẹn n'ọ wụrụ onyẹ-isi nchụ-ẹjan. Osolobuẹ kun enwẹn ẹ yeni oku ahụn o ku; o ku ya wụ oku ọsụọn'a nị Iwu Mozizi a rịgụọlẹ.
\c 8
\cl Isi Nke Ẹsatọ
\s1 Onyẹ Nchụ-ẹjan Ọhụn Lẹ Nkwerigbama Ọhụn
\r (Jẹrimaya 31.31-34; Mat 26.28)
\p 
\v 1 Isi-oku rị ihiẹnni ẹnyi rị e ku wụ nị ẹnyi nwọn nwan ụdị onyẹ-isi nchụ-ẹjan hụn rị oche ẹka-nni ukpo Osolobuẹ imẹ elu-igwee, ebẹhụ ọghọ kachanrịnnị rị—
\v 2 hụn rị a rụn Ebẹhụ Kachanrịn Nsọ imẹ Ọdụ-ofufe hụ wụ nke ezigbo ẹ hụn rị elu-igwee, Ọdụ-ofufe hụ hụn Osolobuẹ lẹ enwẹn ẹ mẹmẹ, ẹlẹ hụn ịhịan gi ẹka mẹmẹ.
\p 
\v 3 Ihiẹn haịn wẹ gi e tumẹ onyẹ-isi nchụ-ẹjan ọwụlẹ wụ kẹni ọ yesọnmẹ oyiye, a chụsọnmẹ ẹjan. Ya wụ nị o k'e nwẹzịrịrị ihiẹn onyẹ nchụ-ẹjannị ẹnyi rị e ku oku e ye.
\v 4 Omẹni elu-ụwa k'ọ rị, o ke wụ onyẹ nchụ-ẹjan kaka—ebe o mẹ ni ndị nchụ-ẹjan hụn a chụ ẹjan kẹ Iwu Mozizi dọn ku hụ a.
\p 
\v 5 Ebẹhụ wẹ nọ e fe ofufe hụn rị elu-uwa yihụ nke ezigbo ẹ hụn rị elu-igwee eyi, onyinyọn ẹ rọ. Makẹni, ogẹn hụ Mozizi gi jẹnkọ d'a rụn Ọdụ-ofufe hụ, Osolobuẹ nọ gba a mkpịnsịn-ẹka, sị a, “Hụnkwọ a nị ị rụn ihiẹn ile n'o yi hụn wẹ ghọsị ị elu-ugu.”
\v 6 Kanị, Jesu e nwẹhẹngụọ ọrụn ka nke wẹ mma, ebe o mẹ ni ọ wụ onyẹ e dọnzi ẹgbata imẹ nkwerigbama hụn ka nke wẹ mma—nkwerigbama Osolobuẹ tumẹ, kwesọnmẹ nkwa ka mma.
\p 
\v 7 Makẹni, omẹni ya wụ nkwerigbama ibuzọ zuchanrịn oke, o k'e nwọn mkpa ọ rị nị Osolobuẹ k'e webanhan nke ẹbụọ.
\v 8 Kanị Osolobuẹ hụn ihiẹn rịlẹni mma imẹ ndị nke ẹ, makẹni ya wụ nkwerigbama ibuzọ ezuchanrịnnị oke, 'ya haịn o gi sị,
\q1 “Di-nwọnni-ẹnyi sị,
\q1 ‘Lee ẹ,
\q1 ogẹn lala,
\q2 hụn m k'e gi tumẹ nkwerigbama ọhụn
\q2 ẹgbata mmẹ lẹ ndị Izrẹlụ lẹ Juda;
\q1 
\v 9 ọ rịkọ kẹ nkwerigbama hụ
\q2 mmẹ lẹ ndị nẹdi wẹ kanị nwọn,
\q2 ụhụọhịn hụ m kwọndọn wẹ ẹka
\q2 gha alị Ijiptu dupụha wẹ.
\q1 Makẹni edọnmẹni wẹ
\q2 nkwerigbama m—
\q1 'ya haịn
\q2 m gi la wẹ tọ.’
\q1 Ya kẹ Di-nwọnni-ẹnyi ku.
\q1 
\v 10 ‘Di-nwọnni-ẹnyi sị, ọnwan wụ nkwerigbama hụ
\q2 hụn m jẹnkọ d'e tumẹ
\q2 ẹgbata mmẹ lẹ ndị Izrẹlụ,
\q2 o mẹgụụ:
\q1 m jẹnkọ d'e bu iwu m rị ichẹn-ichẹn
\q2 che imẹ uche wẹ,
\q2 de wẹ ye imẹ obi wẹ.
\q1 M k'a wụ Osolobuẹ wẹ,
\q2 a wụrụ wẹ ndị nke m.
\q2 
\v 11 Ẹlẹzi hụn ịhịan k'a kuzimẹ ibe ẹ,
\q1 mọbụ gwama ibe ẹ,
\q2 “Marịnkwọ Onyẹ-nwọnni-ẹnyi.” Kaka!
\q1 Makẹni,
\q1 wẹ ile jẹnkọ d'a marịn m;
\q2 gha onyẹ kachanrịn ntịn imẹ wẹ
\q2 d'e ru onyẹ kachanrịnnị.
\q2 
\v 12 Makẹni,
\q1 m k'e mẹ ni wẹ omikẹn,
\q2 gbagharị wẹ eje-ihiẹn ndị wẹ mẹ;
\q1 a nyanhankọzị m njọ ndị hụn wẹ mẹsọnmẹ.’ ”
\p 
\v 13 Hụnnị ọ rị nwan e ku oku nkwerigbama ọhụn, ya wụ n'o mẹgụọ nke mbụ wụrụ nwan ihiẹn-akan; bụ omẹni ihiẹn wụ ihiẹn-akan bụ ọ hụ a kawaye ẹgẹdi, ya wụ nị ogẹn ẹ e d'a gụụ.
\c 9
\cl Isi Nke Itenẹi
\s1 Kẹ Wẹ E Fee Ofufe Mbụ Ahụn
\p 
\v 1 Nkwerigbama nke ibuzọ hụ nwọn ụmụ iwu ndị sọn n'ẹ hụn wẹ gi e fe Osolobuẹ, nwẹzikwọ ebe w'a nọ e fe ofufe hụn rị elu-ụwanị.
\p 
\v 2 Ọdụ-ofufe ahụn wẹ rụn nwọn mmughẹ ẹbụọ. Imẹ mmughẹ nke ibuzọ kẹ teburu lẹ obu-ukpẹ ahụn rị; ogbe brẹdi ndị ahụn w'e dọnmẹ elu teburu ogẹn ile rịzịkwọ ebẹhụ. W'a kpọ mmughẹni “Ebe rị nsọ.” Wẹ gi ẹkwa gbọnbepụ mmughẹni ihun lẹ azụụn. \fig Imẹ Ọdụ-ofufe hụ|src="bk00278c.jpg" size="col" loc="HEB 9" copy="Horace Knowles; The British & Foreign Bible Society" ref="9.2"\fig*
\v 3 Wẹ ghafe ẹkwa mgbọnbepụ hụn ẹbọ—ya wụ, hụn rị ẹgbata mmughẹ ẹbụọnị, a banye wẹ mmughẹ hụn m'ẹ ẹbụọ, hụn w'a kpọ “Ebe Kachanrịn nsọ.”
\v 4 Ebeni kẹ ihiẹn hụ wẹ gi goru mẹmẹ, hụn wẹ nọ elu ẹ a dụn nsẹnsị ọkụn, rị. Ẹkpẹti-nkwerigbama hụ rịzịkwọ ebeni. Wẹ gi osisi rụn a, gi goru nyankwama ẹhụ a ile, kẹ imẹ ẹ kẹ azụụn a. Imẹ ẹ kẹ mkpu goru hụ wẹ buche ihiẹn ahụn wẹ risọnmẹ imẹ atụ hụn wẹ kpọ mana rị; ọkpọ Ẹrọnụ ahụn gbọrịnị lẹ ibe ọmụma ẹbụọ hụ wẹ kaye Iwu iri ahụn Osolobuẹ ye Mozizi rịzịkwọ ebẹhụ.
\v 5 Elu ẹkpẹtini kẹ ndị mmọn-ozi ẹbụọ wẹ kpụ rị. Ihiẹn w'a kpọ ndị mmọn-ozi ẹbụọnị wụ cherobim. Uwẹ a ghọsị nị ọghọ Osolobuẹ rị ebẹhụ. Wẹ shịafụ nku wẹ elu ẹkpẹti ahụn. Ihiẹn w'a kpọ elu ẹkpẹti ahụn wụ Oche-omikẹn.
\p Kanị, ẹnyi a s'ẹka kuru ihiẹn ndịnị alị kikẹnni.
\p 
\v 6 Ẹnịna kẹ wẹ dọnmẹsọnmẹ ihiẹn ndịnị wẹ. Ndị nchụ-ẹjan a banyesọnmẹ mmughẹ nke ibuzọ ogẹn ile d'a rụn ọrụn rịnị nị wẹ, hụn wẹ gi e mẹzu omẹnalị ofufe.
\v 7 Kanị, onyẹ-isi nchụ-ẹjan sụọ a banye mmughẹ hụ mẹ ẹ ẹbụọ. Mgbe ohu sụọ k'ọ banye ẹ ahụa. Ọ banyekọnị, o k'e girịrị ẹdeke anụ, hụn o jẹnkọ d'e gi chụ ẹjan. Ọ chụ ya wụ ẹjan makẹ njọ ya lẹ enwẹn ẹ lẹ njọ ndị Izrẹlụ kpachanpụlẹni ẹnya mẹ.
\v 8 Mmọn-nsọ gi ihiẹn ndịnị a ghọsị nị omẹni echẹn kẹ wẹ rịkwọ e fe ofufe Ọdụ-ofufe ibuzọ hụ, ụzọ wẹ gha a banye Ebe ahụn rị nsọ nke-esi e ke pụha.
\v 9 Wẹ gi ihiẹnni a kọwa ogẹnni ẹnyi rị imẹ ẹ. Ọnwan rị a ghọsị nị oyiye w'e yesọnmẹ lẹ ẹjan ile w'a chụyeni Osolobuẹ imẹ ofufe mbụ ahụn asaẹka mẹ obi ndị rị e fe ofufe hụ rị ọchan.
\v 10 Makẹni oyiye lẹ ẹjan ndịnị wẹ wụhụ oku ihiẹn-oriri lẹ ihiẹn-ọrịra ichẹn-ichẹn lẹ nchanchan rị ichẹn-ichẹn wẹ gi e dọn ihiẹn nsọ. Ihiẹn ndịnị ile wụhụ omẹnalị ẹnya e legha, hụn Osolobuẹ tumẹ ni wẹ nị w'e mẹsọnmẹ d'e ru ogẹn o k'e gi tumẹ ihiẹn ọhụn hụn zu oke.
\s1 Kẹ Wẹ E Fee Ofufe Ọhụn
\p 
\v 11 Kanị, Kraịstị a bịagụọ nwan nọkẹ onyẹ-isi nchụ-ẹjan d'e wẹhẹ ihiẹn ọma ndị hụ rịtulẹni. Ọ banyegụọ Ọdụ-ofufe hụn kanị, hụn ka a oke e zu, hụn wẹ gilẹni ẹka mẹmẹ, ya wụ, hụn wẹ gilẹni ihiẹn ụwanị wẹ ke eke mẹmẹ.
\v 12 Ọ gigụọ nwan mgbe ohu banyechanrịn Ebe Kachanrịn Nsọ. Ẹlẹkwọ ẹdeke ewu lẹ nwa okẹn-efin k'o gi banye, kanị, ẹdeke ya lẹ enwẹn ẹ, gi ẹ wẹhẹ nzụọfụha itẹbitẹ.
\p 
\v 13 Makẹni, omẹni ifekpu wẹ hụ ẹdeke ewu lẹ okẹn-efin lẹ ntụn nwa-efin wẹ dụn ọkụn kẹ onyẹ rịlẹni ụchan (onyẹ mẹ ihiẹn Iwu a sọ) gi a rịzị ụchan, a nabanhanzị w'a,
\v 14 ya wụ nị ẹdeke Kraịstị jẹnkọ d'a sa ẹka chanchan obi ẹnyi ọhụnma-ọhụnma, chanchanpụ ihiẹn ndị ghalẹni e ye ndụn hụn ẹnyi e mẹsọnmẹ, chanchanpụchanrịn a, kẹni ẹnyi hụn ụzọ fe Osolobuẹ rị ndụn makẹni ndụn Kraịstị hụn nwẹlẹni ntụpọ kẹ Kraịstị gi chụyeni Osolobuẹ ẹjan, ghahanị Mmọn-nsọ itẹbitẹ.
\v 15 Ya wụ nị Jizọsị wụ onyẹ e wegbamanị imẹ nkwerigbama ọhụn. Ịya k'ọ wụ kẹni ndị hụ wẹ kpọ oku hụn ụzọ nwọnhẹn ihiẹn hụ k'a tọ jẹnrin ejẹn Osolobuẹ kwe nkwa a. Wẹ k'e nwẹhẹn ẹ, ebe o mẹ ni o nwọngụọ onyẹ nwụnhụnnị hụn wẹ gi ndụn a gbapụha wẹ, makẹ njọ wẹ mẹsọnmẹ okpuru nkwerigbama ibuzọ hụ gha e ri isi wẹ.
\p 
\v 16 Makẹni, ịhịan kugụụ kẹ wẹ k'a dọn ke uku ẹ, wẹ sikọ d'a ghọsịgụụ nị onyẹ hụ a nwụnhụgụọ, wẹ kebe gi ihiẹn o ku rụnma ọrụn.
\v 17 Ịhịan nwụnhụgụụ sụọ kẹ uku ẹ o ke nọ a pa ire. Egikọ w'a rụn ọrụn ebe ọ rị ndụn.
\p 
\v 18 Ya haịn nkwerigbama mbụ hụ gilẹni bidọndẹ bụ ẹdeke anụ wẹ gbu egbu arị a.
\v 19 Makẹni, ogẹn Mozizi gi gwachanrịngụụ ndị hụ ihiẹn ile Iwu hụ sị wẹ e mẹ, ya ọ nọ weri ẹdeke nwa-efin [lẹ ewu] wẹ gbu lẹ mirin, gi ẹṅẹnrẹn anụ e nwun ufie-ufie lẹ ukun ẹfịfịa w'a kpọ haịsọpụ derisọnmẹ ẹdeke lẹ mirin hụ, fekpusọnmẹ kẹ Ẹhụhụọ-Iwu hụ lẹ enwẹn ẹ kẹ ndị Izrẹlụ ile—
\v 20 a sị wẹ, “Hụnnị wụ ẹdeke wẹ rị e gi e tumẹ nkwerigbama hụ hụn Osolobuẹ kwademẹ ni ụnụ.”
\v 21 Ẹrịrazịkwọ kẹ Mozizi dọn fekpusọnmẹ Ọdụ-ofufe hụ lẹ arịa ile wẹ gi e fe ofufe.
\v 22 Ezioku-ezioku, okpuru Iwu Mozizi, o d'a wụrụ nị ẹdeke kẹ wẹ gi e dọn ihiẹn ile nsọ: omẹni egbuni wẹ anụ—omẹni ẹdeke arịa, mgbagharị njọ arịkọ.
\s1 Ẹjan Kraịstị E Wepụ Njọ
\p 
\v 23 O mẹ nwan nị omẹnalị ndị hụ ile rị mkpa igi dọn Ọdụ-ofufe rị ụwa nsọ—bụ onyinyọn mmakalaka rọ, ya wụ nị ẹjan ka ndị hụ mma kẹ nke ezigbo ẹ rị elu-igwee chọ.
\v 24 Makẹni, ẹlẹ Ebẹhụ wẹ gi ẹka mẹmẹ wẹ nọ e fe ofufe—hụn wụhụ onyinyọn nke ezigbo ẹ kẹ Kraịstị banye, kama, ọ banyegụọ nwan elu-igwee lẹ enwẹn ẹ, weri ọnọdị ebe Osolobuẹ rị makẹ ọrịnịmma ẹnyi.
\v 25 Ẹlẹkwọ hụn o k'e gi gi enwẹn ẹ chụsọnmẹ ẹjan, a chụ, achụdọnzi rịkẹ kẹ onyẹ-isi nchụ-ẹjan rị elu-ụwa dọn e mẹ, e gi ẹdeke wụlẹni nke ẹ a banye Ebẹhụ Kachanrịn Nsọ ahụa-ahụa.
\v 26 Omẹni nke Jizọsị rị ẹrịra, nkẹ ọ hụ a nwụn anwụndọnzi kete w'e kelẹ ụwa! Kanị, ezioku wụ n'ọ bịagụọ nwan mgbe ohuni sụọ ọgụgụ-ogẹnni, d'e wepụchanrịn njọ ghahanị igi enwẹn ẹ chụ-ẹjan.
\p 
\v 27 K'o dọn wụrụ nị ịhịan a nwụnhụn mgbe ohu, ọhụn mẹgụụ, okinkin-ikpe e sọn ẹ,
\v 28 ẹrịra k'o dọnzị wụrụ nị hụnnị Osolobuẹ gigụụ Kraịstị chụ ẹjan mgbe ohu sụọ chụchanrịn a, hụn Kraịstị gi buru njọ ndị bu ọda, Kraịstị lalazị hụn mẹ ẹ mgbe ẹbụọ—ẹlẹzi oku njọ k'ọ lalanị, kama, ọ lala d'a zụọpụha ndị hụn rị e lekẹnmẹ ẹnya a.
\c 10
\cl Isi Nke Iri
\s1 Jizọsị E Gigụọ Ẹjan Ohu Hụ Ọ Chụ Chụchanrịn Ẹjan Ile
\p 
\v 1 Ebe o mẹ ni ihiẹn rị imẹ Iwu Mozizi wụhụ onyinyọn ihiẹn rị mma lalanị, ẹlẹ ezigbo ẹ; ya wụ nị ẹjan hụ w'a chụsọnmẹ ahụa-ahụa asakọ nwan ẹka chanchanfụ njọ ndị a bịa d'e fe Osolobuẹ, mẹ wẹ zu oke.
\v 2 Omẹni o te sa ẹka a chanchanpụ njọ, nkẹ ndị hụn e fe ofufe a chụbehi ẹjan. Makẹni, nkẹ njọ wẹ a wụrụ ihiẹn wẹ chanchanpụ mgbe ohu hụ, chanchanpụchanrịn a, obi e ke gha e gbuzi wẹ mgbu.
\v 3 Kanị, ẹjan ndị hụ w'a chụ a nyanhansọnmẹ ni ndị rị a bịa d'e fe ofufe njọ wẹ ahụa-ahụa, a nyanhan nị wẹ nị w'e mẹsọnmẹ njọ,
\v 4 makẹni ẹdeke okẹn-efin lẹ ewu asaẹka wepụ njọ.
\v 5 Ya haịn ogẹn Kraịstị gi bịa imẹ ụwa, ọ sị,
\q1 “Kẹ ẹjan-o, kẹ oyiye-o, o nwọnni hụn ị chọ;
\q2 kama, ẹhụ k'i kwademẹni m.
\q1 
\v 6 Kẹ oyiye wẹ dụn ọkụn-o kẹ oyiye w'e ye makẹ ifiri njọ-o,
\q2 o nwọnni hụn a sụọ ị ụsụọ.
\q1 
\v 7 Ya m nọ sị ‘Lee ẹ, Osolobuẹ, a bịaọlẹ m d'e mẹ uche i—
\q2 nọkẹ kẹ wẹ dọn de banyeni m imẹ Ẹkụkwọ-nsọ.’ ”
\p 
\v 8 Nke ibuzọ, ọ sị, “Kẹ ẹjan-o, kẹ oyiye-o, kẹ oyiye wẹ dụn ọkụn-o, kẹ oyiye w'e ye makẹ ifiri njọ-o—o nwọnni hụn ị chọ, o nwọnni hụn a sụọ ị ụsụọ” (ọsụọn'a nị Iwu sị w'e mẹsọnmẹ ihiẹn ndịnị).
\v 9 Ya ọ nọzị sị, “Lee ẹ, a bịaọlẹ m d'e mẹ \bd uche\bd* i.”
\p Ya wụ nị o bugụọ nke ibuzọ che ụsụọ kẹni o tumẹ hụn mẹ ẹ ẹbụọ.
\v 10 Ịya wụ \bd uche\bd* Osolobuẹ kẹ Kraịstị mẹ nwan, hụn wẹ gi nwan dọn ẹnyi nsọ ghahanị ẹjan Kraịstị gi ẹhụ a chụ, chụ a mgbe ohu, chụchanrịn a.
\p 
\v 11 Onyẹ nchụ-ẹjan ọwụlẹ a rụn ọrụn a ụhụọhịn-ụhụọhịn, a chụsọnmẹ ụdị ẹjan ohu hụ—ẹjan hụn ghalẹni asaẹka e wepụ njọ.
\v 12 Kanị, nke Kraịstị wụ nị ogẹn o gi gigụụ ifiri njọ chụ ẹjan ohu hụ o gi chụchanrịn ẹjan ile, ọ nọ nọdị alị ẹka-nni Osolobuẹ.
\v 13 Kete mgbe hụ, ọ rị e che mgbe Osolobuẹ k'e gi gi ndị iṅẹnrẹn ẹ mẹmẹ n'ẹ ihiẹn o gi a zọma ụkụ a,
\v 14 makẹni o gigụọ ẹjan ohu mẹ ndị hụ o dọn nsọ wụrụ ndị zu oke jẹnrin ejẹn.
\v 15 Mmọn-nsọ rịzịkwọ a shịa ẹri o gi a ghọsị ẹnyi ni ihiẹnni wụ ezioku. O bu ụzọ sị,
\q1 
\v 16 “Di-nwọnni-ẹnyi sị,
\q1 ‘Ọnwan wụ nkwerigbama hụn m jẹnkọ e tumẹ
\q2 ẹgbata mẹ lẹ wẹ ogẹn hụ:
\q1 m jẹnkọ e bu iwu m che imẹ obi wẹ,
\q2 m k'e de wẹ ye imẹ uche wẹ.’ ”
\v 17 Ọ nọ sịzị, “Anyanhankọzị m njọ wẹ lẹ mmẹfie wẹ.”
\p 
\v 18 Ya wụ, ebe wẹ nọ gbagharịgụhụ njọ ndịnị wẹ, w'a ra chụzị ẹjan wẹ gi e wepụ njọ.
\s1 Nị Ẹnyi Nọkunmẹ Osolobuẹ
\p 
\v 19 Umunẹ m, ẹnyi e nwẹgụọ nwan ihiẹn obi gi e ru ẹnyi alị a banye Ebe Osolobuẹ rị makẹ ihiẹn ẹdeke Jizọsị mẹ.
\v 20 Ẹghẹẹ, makẹni Jizọsị a kwagụọ nị ẹnyi ụzọ ọhụn hụ rị ndụn ghahanị ẹhụ a, ya wụ ọnwụn a, hụn o gi dọwapụ nị ẹnyi ẹkwa mgbọnbepụ hụ.
\v 21 Ọzọzị, ẹnyi nwọn okẹn onyẹ nchụ-ẹjan hụn ụlọ Osolobuẹ rị ẹka a.
\v 22 Ifiri ihiẹn ndịnị wẹ, nị ẹnyi gi ni nwan obi ẹnyi ile lẹ obi erumalị ndị gi ya wụ onyẹ nchụ-ẹjan dọn ẹnya buruhẹ Osolobuẹ. Nị ẹnyi bịa nwan makẹni o gigụọ ẹdeke ẹ fekpu obi ẹnyi, chanchanfụ ihiẹn ile obi te gi a ma ẹnyi ikpe, gi mirin nwunni wụchanpụ ẹnyi ẹhụ.
\p 
\v 23 Nị ẹnyi kwọnkẹnmẹ ni nwan olile-ẹnya hụ ẹnyi nwọn—makẹni Osolobuẹ hụn kwe ẹnyi nkwa furu onyẹ wẹ gi e dọn ẹnya. O k'e mẹzu nkwa a.
\p 
\v 24 Nị ẹnyi a chọsọnmẹ ni ụzọ ẹnyi e gi e mẹ ibe ẹnyi e nwẹ ihiẹn-ọsụsụọ, a rụnzịkwọ ọrụn rị mma.
\v 25 Ẹlẹ hụn ẹnyi e gi a latọ isọn ibe ẹnyi a gbakikomẹ kẹ ndị hụ imẹ ẹnyi dọn e mẹ. Kama, nị ẹnyi a kasị ibe ẹnyi obi, tụmadụ hụnnị ẹnyi rị a hụn kẹ ụhụọhịn Di-nwọnni-ẹnyi rị a rịwaye nsue.
\p 
\v 26 Makẹni, omẹni ẹnyi a kpachanpụ ẹnya tọ njọ e mẹ, ebe ẹnyi marịngụụ ezioku, o nwọnzini ẹjan ọwụlẹ họdụnị hụn wẹ jẹnkọ d'a chụ gi wepụ njọ.
\v 27 Kama, ihiẹn k'a gha e che onyẹ ahụn wụ ikpe-ọmụma hụn a tụ egun lẹ okẹn ọkụn hụn jẹnkọ d'a dụnpụchanrịn ndị-iṅẹnrẹn Osolobuẹ.
\v 28 Makẹni, ebe o mẹ ni onyẹ ọwụlẹ dan Iwu Mozizi, e gbu w'ẹ, emẹni wẹ omikẹn ẹ—madụ ẹbụọ mọbụ ẹtọ shịahụ ẹri n'o mẹ ihiẹn hụ,
\v 29 nanị k'i ro nị afụnfụn furu wẹ k'e ye ndị legberi Nwa Osolobuẹ k'a jọhan njọ—ndị lenịa ẹdeke nkwerigbama hụ wẹ gi dọn wẹ nsọ, kpasu Mmọn-nsọ wẹ gha mẹn'ẹ ẹfọma iwe?
\v 30 Makẹni ẹnyi a marịnghọ Osolobuẹ, onyẹ hụn sị, “Mmẹ nwẹ e mẹgwarị; m k'a kụkin ụgwọ;” sịzị, “Di-nwọnni-ẹnyi jẹnkọ d'e kin ndị nke ẹ ikpe.”
\v 31 Ihiẹn a tụ egun k'ọ wụ nị ịhịan danye ẹka Osolobuẹ hụn rị ndụn.
\s1 Nyanhan Nị Kẹ Ụnụ Dọn Bidọn
\p 
\v 32 Ka nyanhankwọ nị ọrụrụ-alị hụ ụnụ gi kweri, ogẹn hụ wẹ gi shịapụgụụ ụnụ ẹnya; nyanhankwọ nị kẹ ụnụ dọn dingbuchanrịn eje-afụnfụn bu ọda bịanị nị ụnụ;
\v 33 kẹ wẹ dọn kparisọnmẹ ụnụ, kpokposọnmẹ ụnụ, kẹ ụnụ dọn sọndẹ ndị ọzọ wẹ rị e mẹ ẹrịra ta afụnfụn.
\v 34 Ẹghẹẹ, ụnụ a tadẹ ni ndị rị ụlọ-ngan afụnfụn ogẹn hụ; ogẹn wẹ gi napụ ụnụ ihiẹn ụnụ, ụnụ e gidẹ ịghọghọ din ẹ, makẹni ụnụ a marịnghọ nị ụnụ lẹ enwẹn ụnụ nwọn hụn ka mma lẹ hụn k'a tọ jẹnrin ejẹn.
\p 
\v 35 Etuhukwọlẹ ni obi-erumalị hụ ụnụ nwọn imẹ Di-nwọnni-ẹnyi, makẹni ụgwọ-ọrụn rịn'a e hikẹkwọ ogbe.
\v 36 Makẹni, ọ rịka mkpa nị ụnụ din ndidi, kẹni ụnụ hụn ụzọ mẹsọnmẹ uche Osolobuẹ, gi e nwọnhẹn ihiẹn hụ o kwe nkwa a.
\v 37 Nọkẹ kẹ Ẹkụkwọ-nsọ dọn ku,
\q1 “Ọ họdụ ẹkẹrẹ,
\q2 onyẹ hụn lalanị a bịa—
\q2 o biekọ.
\q1 
\v 38 Kanị,
\q1 okukwe kẹ onyẹ nke m hụn rị kẹ m chọ
\q2 k'e gi e bi.
\q1 Ọ gbakin azụụn,
\q2 ihiẹn ẹ asụọkọ m.”
\p 
\v 39 Kanị, ẹnyi a rị ndị hụn a gbakin-azụụn, gi ẹrịra tuhu; kama, ẹnyi rị ndị k'a gha e nwọn \bd okukwe\bd*, Osolobuẹ e gi ifiri ẹ zụọpụha wẹ.
\c 11
\cl Isi Nke Mmanaị
\s1 Okukwe
\p 
\v 1 Kị wụ nwan \bd okukwe\bd*? Okukwe wụ igi ẹ dọn n'i k'e nwọnhẹn ihiẹn ị rị a tụ ẹnya a; igi ihiẹn dọn, bụ y'a rịnị e leghan'a.
\p 
\v 2 Ufiri okukwe ndị mbụ ahụn nwẹ kẹ Osolobuẹ gi kunni wẹ ọhụnma.
\v 3 Okukwe kẹ ẹnyi gi a ghọta nị oku-ọnụ kẹ Osolobuẹ gi ke ụwa, ya wụ nị wẹ gha ihiẹn ẹnya ghalẹni a legha mẹmẹ ihiẹn ndị hụ ẹnya e legha.
\v 4 Ebẹlụ nwẹ okukwe: ịya k'o gi chụyeni Osolobuẹ ẹjan ka nke Keni mma. Ịya haịn Osolobuẹ gi ku ni Ebẹlụ ọhụnma, kpọ a onyẹ rị kẹ Osolobuẹ dọn chọ, shịa n'a ẹri nị oyiye o ye rị mma. Makẹni o nwẹ okukwe k'o gi wụrụ nị ọsụọn'a n'ọ nwụnhụngụọ ọ hụkwọ e ku oku\f + \fr 11:4 \ft Jẹnẹsisi 4.10\f*.
\v 5 Ẹnọkụ nwọn okukwe: ịya haịn Osolobuẹ gi weri ẹ shi elu-igwee ebe ọ rị ndụn. Ọ nwụnhụnnị. A chọ w'a, ahụnzịnị w'a, makẹni Osolobuẹ e werigụọ a. Makẹni, nị Osolobuẹ d'e weri ẹ, Ẹkụkwọ-nsọ e kuọl'a nị “ó mẹ ihiẹn a sụọ Osolobuẹ.”
\p 
\v 6 Bụ ịhịan as'ẹka mẹ ihiẹn a sụọ Osolobuẹ, mmanị o nwẹghọ okukwe. Makẹni, onyẹ ọwụlẹ bịa d'e kunrun Osolobuẹ k'e girịrị a dọn n'ọ rị arị, n'ọ kụzịkwọ ndị a chọkẹnmẹn'ẹ ụgwọ.
\v 7 Nụa nwọn okukwe. Ifiri ẹ, ogẹn Osolobuẹ gi gwatọ a nị ihiẹn mẹtulẹni jẹnkọ d'e mẹ, ọ nọ gi ẹ dọn, gi egun Osolobuẹ rụn ụgbọ-mirin pụ-ichẹn, hụn Osolobuẹ gi nwan zụọpụha ezi-lẹ-ụlọ ya wụ Nụa. Ihiẹnni Nụa mẹ kẹ ikpe gi ma ụwa. Nua nọ gi ẹ wụrụ onyẹ rị kẹ Osolobuẹ dọn chọ, wụrụ a makẹni o nwẹ okukwe.
\p 
\v 8 Ebraham nwọn okukwe. Ịya haịn o gi kweri ogẹn Osolobuẹ gi kpọ a, sị a shi ebe o jẹnkọ d'e ye ẹ, ọ nọ jẹnmẹ bụ ọ marịn ebe o jẹnkọ.
\v 9 Okukwe k'o gi kwashi alị hụ Osolobuẹ kwe ẹ nkwa d'e biri kẹ otunmuyẹ—e bisọnmẹ imẹ ọdụ. Ẹrịra kẹ Aziki lẹ Jekọpụ, ndị rịzịkwọ ndị Osolobuẹ kwe ya wụ nkwa, bisọnmẹ imẹ ọdụ.
\v 10 Ebraham mẹ ẹrịra makẹni o bu obi lẹ ẹnya zinmẹ obodo ahụn nwọn iyetọ hụn k'a tọnị, obodo ahụn Osolobuẹ gi ẹka a rofụha, tụn.
\p 
\v 11 Okukwe kẹ Ebraham gi saẹka mụ nwa, ọsụọn'a n'ọ kagụọ ẹgẹdi ọda-ọda; ọsụọn'a nị Sara lẹ enwẹn ẹ wụ agan. Makẹni, Ebraham gi ẹ dọn nị Chuku hụn kwe nkwa, furu wẹ gi e dọn ẹnya, n'o jẹnkọ d'e mẹzu nkwa a.
\v 12 Ya okẹnnyẹ ohuni ẹhụ a nwụnhụngụụ ebe ịmụ-nwa rị nọ mụ ụmụ bukẹnmẹ ọda—nọkẹ kokisẹ rị elu-igwere, nọkẹ ẹjan rị mkpẹnrẹn ohimin hụn wẹ ghalẹni a saẹka a gụngụụ.
\p 
\v 13 Ndịnị ile kwọndọn okukwe nwụn, bụ w'e ke nwọnhẹn ihiẹn ndị hụ Osolobuẹ kwe wẹ nkwa, kanị, e lechegụọnị wẹ ihiẹn ndị hụ, gi ịghọghọ nabanhan wẹ. Wẹ kwerizikwọ nị wẹ wụ itumunyẹ imẹ ụwanị, e kuzikwọ a.
\v 14 Ndị e ku ẹnịna rị a ghọsị n'o nwọngụọ alị ẹnya wẹ rị hụn wụ nke wẹ.
\v 15 Omẹni alị hụ wẹ gha pụha kẹ wẹ te rị e ro, efe te hụ a w'e gi kin-azụụn.
\v 16 Kanị, wẹ rị a chọ alị hụn ka mma, ya wụ, nke elu-igwee. Ya haịn ifẹnrẹn gilẹni e mẹ Osolobuẹ ịza Osolobuẹ wẹ, makẹni, ezioku-ezioku, o nwẹghọ obodo ọ kwademẹni wẹ.
\p 
\v 17 Makẹni Ebraham nwọn okukwe, ogẹn Osolobuẹ gi lele ẹ, ọ nọ bịa d'e gi Aziki chụ ẹjan. Onyẹ nwẹn wẹ kwe nkwa ndị hụ nọ mẹmẹ n'ọ gi akpụ nwa a ohu chụ ẹjan!
\v 18 Nwa nwẹn wẹ gwa a oku ẹ, sị, “Ẹka Aziki kẹ ụmụ wẹ jẹnkọ d'a kpọ nke i k'a gha bịa.”
\v 19 Ebraham gi ẹ dọn ni Osolobuẹ k'a saẹka weli onyẹ nwụnnị. Kẹ ihiẹn ile dọn mẹ, ọ rịchanrịnhụ kẹ ebe ọ nọ gha imẹ ọnwụn nwẹhẹnzi Aziki nke-esi.
\p 
\v 20 Aziki nwọn okukwe. Ịya haịn o gi gọzi Jekọpụ lẹ Isọ—kusọnmẹ ihiẹn k'e mẹ imẹ ndụn wẹ ihun.
\p 
\v 21 Jekọpụ nwọn okukwe: o d'a nwụn, ọ nọ gọzi onyẹ-onyẹ imẹ ụmụ Josẹfụ ẹbụọ, gi ọkpọ a wuzo, hulụa isi, fe Osolobuẹ.
\v 22 Josẹfụ nwọn okukwe: ogẹn o gi jẹnkọ d'a nwụn, ọ nọ ku oku ọpụpụ ụmụ Izrẹlụ jẹnkọ d'a gha Ijiptu pụ, gwa wẹ kẹ wẹ k'e mẹ ọkpụkpụ a.
\p 
\v 23 Ndị mụ Mozizi nwọn okukwe. Ya haịn wẹ gi zuemẹ Mozizi gha ogẹn wẹ gi mụ a d'e ru ifọn ẹtọ, makẹni wẹ hụn a nị ọ wụ nwa pu mma ọda-ọda, atụnị wẹ egun iwu hụ eze ye.
\p 
\v 24 Mozizi nwọn okukwe: ogẹn o gi suepụha, ọ nọ jụ w'a kpọl'a nwa nwa-okpoho Fẹro, eze alị Ijiptu.
\v 25 Ọ hanrịn n'ọ ka mma nị ya lẹ ndị nke Osolobuẹ wịrị ta afụnfụn karị imẹ Osolobuẹ njọ ebe ọ n'a chọ n'o ri-ụwa, iri-ụwa hụn ghalẹni a tọ.
\v 26 O gi ẹ dọn nị mkpari lẹ nlegberi hụn gi ifiri Kraịstị bịanị ịhịan wụ akụ-lẹ-ụba hụn ka akụ-lẹ-ụba rị Ijiptu. O mẹ ẹrịra makẹni o bu ẹnya zinmẹ ụgwọ-ọrụn lalanị.
\v 27 Makẹni o nwẹ okukwe, ọ nọ gha Ijiptu pụ; egun atụn'a nị iwe jẹnkọ d'e we eze wụ Fẹro. O leni ẹnya azụụn, kama, o dinsọnmẹ lẹkẹ sị ọ rị e legha Osolobuẹ, onyẹ ahụn wẹ ghalẹni e legha ẹnya.
\v 28 Okukwe k'o gi mẹ Mmẹmmẹ-Nghafe lẹ Ifesọnmẹ ẹdeke ye ọnụmụzọ, hụn o gi mẹ ni mmọn-ozi hụ rị e gbu ụmụ ikẹnnyẹ ibuzọ ndị Ijiptu e gbuni ụmụ ikẹnnyẹ ibuzọ ndị Izrẹlụ.
\p 
\v 29 Okukwe kẹ ndị Izrẹlụ gi ghafe Ohimin-Ufie lẹkẹ sị wẹ ghakọ akpakalị. Kanị, ogẹn ndị Ijiptu gi chọ nị wẹ nwẹn ghafe, mirin nọ rukpumẹ wẹ, wẹ nọ ragbu enwẹn wẹ.
\p 
\v 30 Okukwe ndị Izrẹlụ nwẹ kẹ ụgba Jẹriko gi dan ogẹn wẹ gi jẹnhunmẹgụụ a akpụ-ụhụọhịn ẹsa.
\v 31 Okukwe ịgbaraja hụ wụ Rehabụ nwẹn haịn o gilẹni sọn ndị hụn nufụ isi la ntikpọ—makẹni o gi ifiri okukwe ẹ gi udọn nabanhan ndị Izrẹlụ hụ gi nzuzue bịa d'e lele alị wẹ wụ Jẹriko.
\p 
\v 32 Kị m k'e kuzi nwan? Ogẹn arịa, nkẹ m'e te kumẹ oku Gidiọnị lẹ Barakị lẹ Samsịnị lẹ Jẹfta; oku Defidi lẹ Samuẹlụ lẹ ndị-amụma mbụ-mbụ—
\v 33 ndịnị ile nwọn okukwe—gi ẹ mẹri alị rị ichẹn-ichẹn; gi ẹ kị ọkịkị zinrinni; gi ẹ nwọnhẹn ihiẹn Osolobuẹ kwe wẹ nkwa a; gi ẹ kpukinsọnmẹ ẹwọrọ ọnụ;
\v 34 gi ẹ tinyụn okẹn-ọkụn; gi ẹ wanahịn ogbugbu wẹ te k'e gi ọpịa-agha gbu wẹ; gi ẹ nwọnhẹn ikẹn ebe ndụn gụgụụ wẹ; gi ẹ kpa ikẹn agha; gi ẹ chụzịza ndị-agha ndị alị ọzọ.
\v 35 Ikpoho ndị hụ imẹ wẹ nwẹ okukwe, Osolobuẹ nọ gi ẹ welini wẹ ndị nke wẹ nwụnhụgụnị.
\p Nke ndị ọzọ wụ nị wẹ gi ifiri okukwe wẹ mẹshi wẹ ikẹn ọda-ọda, kanị a jụ wẹ w'a hatulẹ wẹ, hụn nkẹ w'e gi tuhu okukwe wẹ, makẹni wẹ nwụn, wẹ k'e lihizi rị ndụn ka mma.
\p 
\v 36 A kpa wẹ ndị ọzọ ye ẹmụ makẹ okukwe wẹ, gbu wẹ mkpịnsịn; e kẹndẹ wẹ ndị hụ imẹ wẹ ẹgbụn, tụ wẹ ye ụlọ-ngan—makẹ okukwe wẹ.
\v 37 E gi wẹ ọmụma magbu ndị hụ imẹ wẹ; a kpọwa wẹ ndị hụ imẹ wẹ ụzọ ẹbụọ; e gi wẹ ọpịa-agha gbu ndị hụ imẹ wẹ.
\p Akpụkpọ atụnrụn lẹ akpụkpọ ewu sụọ kẹ w'a hụn e yi, e nwẹ wẹ ihiẹn ọwụlẹ mọbụ ndị e yeni wẹ ẹka; e kpokpo wẹ wẹ; e mẹja wẹ wẹ!
\v 38 Ụwanị efuruni ndị nọ ẹrịra! W'a wahunmẹ imẹ atụ lẹ elu-ugu lẹ imẹ okporo lẹ ọnụ ndị rịsọnmẹ alị.
\p 
\v 39 Eziẹ, wẹ ku oku ndịnị ile ọhụnma makẹ okukwe wẹ, kanị, o nwọnni onyẹ ọwụlẹ imẹ wẹ hụn nwọnhẹn \bd ihiẹn ahụn\bd* Osolobuẹ kwe nkwa a.
\v 40 Makẹni, Osolobuẹ kwademẹni ẹnyi ihiẹn ka mma, hụn o gi mẹ ni ezukọ wẹ oke bụ ẹnyi a rị a.
\c 12
\cl Isi Nke Mmẹbụọ
\s1 Nị Ẹnyi Sọnmẹ Nzọmụkụ Kraịstị
\r (Mat 11.28-30)
\p 
\v 1 Ya wụ, ebe o mẹ nwan ni igunrun ndị ọshẹri han ẹnịna fihunmẹ ẹnyi lẹkẹ ọgbọ\f + \fr 12:1 \fl Griki: \ft orukpu\f*, nị ẹnyi latọ nwan ihiẹn ọwụlẹ hụn a nyịndannị ẹnyi, natọzịkwọ njọ ahụn e mẹsọnmẹ ẹnyi uke. Nị ẹnyi dikẹnmẹ, gba ọsọnị Osolobuẹ ketọnị ẹnyi,
\v 2 bu ẹnya zinmẹ Jizọsị, hụn wụ mbidọn lẹ ọgụgụ okukwe ẹnyi; hụn gi ifiri ịghọghọ hụn rị e che n'ẹ dingbu obe hụ, legberi ifẹnrẹn rịn'a. Ọ nọdịgụọ nwan alị ẹka-nni ukpo Osolobuẹ.
\p 
\v 3 Rokpọ nị onyẹni dingbu ihiẹn ahụn ile ẹka ndị-njọ—amamgbe ndụn a gụụ ụnụ mọbụ ụnụ e tuhu okukwe ụnụ.
\v 4 Ọgụnnị ụnụ rị e che njọ, ụnụ e ke cherudẹ ẹ ebe ọ nọ napụ ụnụ ndụn ụnụ.
\v 5 Ụnụ a zọgụọdẹ oku nkasị-obini Osolobuẹ ku, hụn o gi a gba ụnụ umẹ nọkẹ ụmụ a ra? Ọ sị,
\q1 “Nwa m,
\q1 elegberilẹ afụnfụn Di-nwọnni-ẹnyi gi a zụn ị;
\q1 anịlẹ ndụn gụụ ị ebe ọ rị a jụgbọ ị;
\q1 
\v 6 makẹni,
\q1 afụnfụn kẹ Di-nwọnni-ẹnyi gi a zụn
\q2 onyẹ o bu obi;
\q1 onyẹ hụn ọ nabanhan nọkẹ nwa a
\q2 k'ọ fịan mkpịnsịn.”
\p 
\v 7 E digbu ni nwan afụnfụn, e weri ẹ nọkẹ ọzụnzụn. Osolobuẹ gi ẹ a ghọsị nị ụmụ a kẹ ụnụ wụ nke-esi. Elee nwa kẹ nẹdi ẹ ghalẹni e ye afụnfụn ebe ọ n'a zụn a?
\v 8 Omẹni eyeni wẹ ụnụ afụnfụn wẹ gi a zụn nwa kẹ wẹ dọn e ye onyẹ ọwụlẹ wụ nwa nke-esi, ya wụ nị ụnụ ẹlẹ ụmụ nke-esi.
\v 9 Ebe o mẹ ni ẹnyi a gbayeghọ ndị nẹdi ẹnyi rị elu ụwanị ogẹn wẹ gi e ye ẹnyi afụnfụn wẹ gi zụn ẹnyi, o furuni nị ẹnyi wepụha obi ẹnyi bu enwẹn ẹnyi che okpuru Nẹdi ẹnyi nke imẹ Mmọn wụ Osolobuẹ, kẹni ẹnyi hụn ụzọ nwọn ndụn?
\v 10 Ndị nẹdi ẹnyi e yeghọ ẹnyi afụnfụn ẹkẹrẹ ogẹn ebe wẹ n'a zụn ẹnyi kẹ wẹ marịnhan, kanị ya lẹ enwẹn ẹ wụ Osolobuẹ gi afụnfụn a zụn ẹnyi kẹni ọ rịnị ẹnyi mma nke-esi, kẹni ẹnyi sọn ẹ rị nsọ.
\v 11 Afụnfụn w'e ye ịhịan wẹ gha a zụn a ra sụọ ụsụọ ogẹn hụ ịhịan gi rị imẹ ẹ, ụfụ k'ọ fụ. Kanị, omẹgụụ, ọ mịpụha nị ndị wẹ gi ẹ zụn mkpụrụ, hụn wụ udọn lẹ ibi kẹ Chuku chọ.
\s1 Ndụnmọdụn Lẹ Ẹka-ntịn
\p 
\v 12 Gbakẹnmẹ ni nwan ẹka, ụnụ a gbakẹnmẹzịkwọ mkpụ-ụkụ ndị ahụn rị a ma nni.
\v 13 Kwa nị nị nwan ọkụ ụnụ ụzọ zinrinni, kẹni ụkụ rịlẹni ikẹn hụn ụzọ dịnhịn, amamgbe ọ kwapụ.
\s1 Ajụkwọlẹ Ni Eyemẹka Osolobuẹ!
\p 
\v 14 A lịlịma nị nị udọn a rị ẹgbata ụnụ lẹ onyẹ ọwụlẹ lẹ ni ụnụ a rịzịkwọ nsọ, makẹni onyẹ rịlẹni nsọ ahụnkọ Onyẹ-nwọnni-ẹnyi.
\p 
\v 15 Hụn n'a n'o nwọnni onyẹ ẹfọma Osolobuẹ fie; nị ize arịnị imẹ igunrun ụnụ, buhẹ nsọngbu, mẹrụ ndị bu ọda—ẹrịra mkpọgụn dọn e suepụha.
\v 16 Hụnzịkwọ n'a nị o nwọnni onyẹ rị a ghẹrẹni, mọbụ onyẹ nọkẹ Isọ—hụn nwọnlẹni ihiẹn ọ kpọ ihiẹn Osolobuẹ, hụn gi ifiri ọkwa ihiẹn-oriri ohu repụ ọnọdị nwa-ibuzọ ọ wụ.
\v 17 Ụnụ a marịnghọ nị omẹgụụ, ọ nọ chọ nị o nwọnhẹn ngọzi hụ, kanị a jụ w'a; ọ sanị ẹka gbehutọ ihiẹn, ọsụọn'a n'o gi ẹnya-mirin chọ ngọzi hụ.
\p 
\v 18 Makẹni, ẹlẹ ihiẹn wẹ a saẹka e mẹtụ ẹka kẹ ụnụ bịa d'e kunrun—nọkẹ kẹ ụmụ Izrẹlụ dọn bịa Ugu Saịnaị; ẹlẹ okẹn ọkụn rị e nwunni lẹ ishi lẹ ebe wẹ nọ a kwan “okokoko!”; ẹlẹ okẹn ufere rị a kpọnị.
\v 19 Ẹlẹ olu opi rị a hannị lẹ olu rị e ku ihiẹn o mẹ ni ndị nụn'a nọ rịọma nị asa wẹ ẹka nụzị—
\v 20 makẹni obi wẹ asanị ẹka bu iwu o ti: nị, “Ihiẹn ọwụlẹ ẹhụ a mẹtụ ugu hụ, wẹ magbu ẹ, ọsụọn'a nị anụ rọ”!
\v 21 Ihiẹn ile wẹ rị a hụn a wụkẹnmẹkẹ ihiẹn egun, nke wụ nị, Mozizi lẹ enwẹn ẹ nọdẹ sị, “Egun rị a tụ m, ẹhụ rị a ma m nni!”
\p 
\v 22 Mba! Ugu Zayọnụ kẹ ụnụ bịa, obodo uku Osolobuẹ rị ndụn, Jerusalẹm hụn rị elu-igwee; ụnụ bịa d'e kunrun igunrun ndị mmọn-ozi wẹ ghalẹni a sa ẹka a gụn; ụnụ bịa d'e kunrun ndị rị e mẹ mmẹmmẹ, a ghọghọ.
\v 23 Ụnụ a bịagụọ d'e kunrun igunrun ụmụ ibuzọ Osolobuẹ, hụn wẹ deye ẹfan wẹ elu-igwee. Ụnụ a bịagụọ d'e kunrun Osolobuẹ hụn wụ ọka-ikpe ịhịan ile. Ụnụ a bịagụọ d'e kunrun ndị bi elu kẹ Osolobuẹ dọn chọ hụn Osolobuẹ mẹgụụ nwan mmọn wẹ zu oke.
\v 24 Jizọsị kẹ ụnụ bịa d'e kunrun, onyẹ hụn e wegbama Osolobuẹ lẹ ịhịan imẹ nkwerigbama ọhụn. Ụnụ a bịagụọ d'e kunrun ẹdeke-nfesọnmẹ ahụn hụn rị e ku ihiẹn ka mma karị mmẹgwarị ahụn ẹdeke Ebẹlụ sị wẹ mẹgwarị, makẹni ọnwan sị gbagharị.
\p 
\v 25 Hụnkwọ n'a nwan nị ụnụ apanị oku Osolobuẹ, onyẹ ahụn rị a gwa ụnụ oku ogẹnni. Makẹni, omẹni awanahịnnị wẹ ogẹn hụ wẹ gi pa oku Mozizi hụn nọ elu-ụwanị ogẹn ahụn a dọ wẹ ẹka-ntịn, ẹnyi asakọkwọ ẹka wanahịn kaka, omẹni ẹnyi a pa oku Osolobuẹ hụn gha elu-igwee a dọ ẹnyi ẹka-ntịn.
\v 26 Ogẹn hụ, ụwa kẹ olu ẹ zinzin; kanị, ogẹnni, o kwegụọ nkwa, sị, “M k'e zinzinzi ihiẹn ile: ẹlẹzi ụwa sụọ kẹ m sikọ nwan d'e zinzin, m k'e zinzinzikwọ elu-igwere ile lẹ ihiẹn rịn'a.”
\v 27 Okuni o ku: “M k'e zinzinzi” rị a ghọsị nị Osolobuẹ sikọ d'e wepụ ihiẹn ndị hụ wẹ a sa ẹka e zinzinfụ, ya wụ ihiẹn wẹ ke eke, kẹni ọ hụn ụzọ họdụ hụn wẹ ghalẹni a saẹka e mẹhunmẹ.
\v 28 Ebe o mẹ nwan nị ẹnyi rị e nwọnhẹn alị-eze hụn wẹ ghalẹni a saẹka e mẹhunmẹ, nị ẹnyi gi nwan ekele lẹ egun lẹ ẹhụ-ọmụma-nni fe Osolobuẹ ofufe furu hụn ọ nabanhan;
\v 29 makẹni ezioku-ezioku, Chuku ẹnyi wụ ọkụn hụn e bu ihiẹn e ri.
\c 13
\cl Isi Nke Mmẹtọ
\s1 Obibi Hụn A Sụọ Osolobuẹ Ụsụọ
\p 
\v 1 E nwẹ ni ihiẹn-ọsụsụọ umunẹ ụnụ imẹ Kraịstị ogẹn ile.
\v 2 Egikwọlẹ ni ịnabanhan ndị ọbịa gu egu—makẹni, o nwọngụọ ndị gi ẹnịna nabanhan ndị mmọn-ozi, lee wẹ ọbịa—bụ a marịn wẹ nị ndị-mmọn ozi rọ.
\v 3 A nyanhan nị ndị rị ụlọ-ngan nọkẹ sị ụnụ lẹ wẹ rị ụlọ-ngan; a nyanhan nị ndị wẹ rị e mẹshi-ikẹn nọkẹ sị ụnụ kẹ wẹ rị e mẹshi ikẹn.
\v 4 Gbayekẹnmẹ ni ọlụlụ di-lẹ-nwunyẹ; kẹ di kẹ nwunyẹ ewiwikwọlẹ enwẹn ẹ, mẹrụ elu-ukpo wẹ\f + \fr 13:4 \ft Di esọnlẹ okpoho ọzọ; nwunyẹ esọnlẹ okẹnnyẹ ọzọ.\f*—makẹni Osolobuẹ jẹnkọ d'a ma ndị ughẹrẹ ikpe.
\v 5 Anịkwọlẹ ni egho a sụọ ụnụ; a nị nị ihiẹn ụnụ nwọn e jun ụnụ ẹfọ. Makẹni, Osolobuẹ e kuọlẹ, sị, “Ahapụkọ m ụnụ mọbụ la ụnụ tọ.”
\v 6 Ya wụ, ẹnyi k'a saẹka dụ ẹka obi, sị,
\q1 “Di-nwọnni-ẹnyi wụ onyẹ e yeni m ẹka,
\q2 egun atụkọ m;
\q1 kị ịhịan k'a saẹka mẹ m?”
\p 
\v 7 Nyanhan nị ndị-ndu ụnụ, hụn gwa ụnụ oku Osolobuẹ; lekpọ nị ihiẹn ndụn wẹ rụnpụha; kịnrịn nị okukwe wẹ.
\v 8 Kẹ Jizọsị Kraịstị rị ụnyanhụn k'ọ rị tannị; ọ k'a rị ẹrịra jẹnrin ejẹn.
\v 9 Awụkwọlẹ ni ndị wẹ gi nkuzi rị ichẹn-ichẹn e dufie; makẹni ọ rịka mma ebe ọ nọ mẹ ni eyemẹka Osolobuẹ kẹ obi gi ru ịhịan alị, nị ẹlẹ idọnmẹsọnmẹ iwu ihiẹn-oriri—iwu ihiẹn-oriri hụn bantulẹni ni ndị e dọnmẹ ni wẹ erere.
\v 10 Ukpo nchụ-ẹjan nke ẹnyi wụ ụdị hụn o mẹ ni ndị nchụ-ẹjan hụn a rụn imẹ Ọdụ-ofufe akan hụ efuruni nị wẹ ri ihiẹn rị n'a.
\p 
\v 11 Onyẹ-isi nchụ-ẹjan Ofufe-akan hụ e webanhan ẹdeke anụ wẹ gi chụ-ẹjan njọ imẹ Ebẹhụ Kachanrịn Nsọ, kanị w'e bu anụ hụ e shi ebe ịhịan bilẹni d'a dụn ọkụn.
\v 12 Ya haịn Jizọsị gilẹni nọ imẹ obodo nwụnhụn, kama wẹ gha imẹ obodo wepụ a d'e gbu, kẹni ọ hụn ụzọ gi ẹdeke ẹ dọn ndị ịhịan nsọ.
\v 13 Nị ẹnyi gha nwan imẹ obodo pụ, buru ẹ ebẹhụ ịhịan bilẹni—d'e sọn ẹ narịn ihiẹn ifẹnrẹn wẹ mẹ ẹ,
\v 14 makẹni ẹnyi e nwọn obodo ọwụlẹ hụn k'a tọnị elu ụwanị ẹnyi rị; kama, ẹnyi rị a tụ ẹnya obodo hụ lalanị.
\v 15 Nị ẹnyi ghama nị nwan ẹka Kraịstị a ja Osolobuẹ mma ogẹn ile, makẹni ebe Osolobuẹ rị, ọhụn wụ ẹjan ẹnyị rị a chụyen'ẹ—mkpụrụ ọ rị a ghọrị ụgb'ọnụ ndị rị e fen'ẹ, a kpọku ẹfan a.
\p 
\v 16 Hụn n'a nị ụnụ hụ e mẹ mma lẹ nị ụnụ e keye ibe ụnụ ihiẹn ụnụ nwọn, makẹni ụdị ẹjannị a sụọ Osolobuẹ ụsụọ.
\p 
\v 17 E humẹ ni ni ndị-ndu ụnụ isi; e bu ni enwẹn ụnụ e che okpuru wẹ. Makẹni, wẹ rị e lepụ umẹ-ndụn ụnụ ẹnya. Wẹ jẹnkọ d'e ye Osolobuẹ mgbakọ banyeni ụnụ. Hụn n'a nị wẹ gi ịghọghọ ye ya wụ mgbakọ, ẹlẹ ẹnya-mirin, makẹ ọ gha a jọ ụnụ njọ.
\p 
\v 18 E mẹ ni ni ẹnyi ekpere. Makẹni, ẹnyi a marịnghọ nị obi ẹnyi rị ọchan, nị ẹnyi a chọzịkwọ nị ẹnyi e bi obibi nwẹ ọghọ imẹ ihiẹn ile ẹnyi rị e mẹ.
\v 19 M rị a rịọkẹnmẹ ụnụ, mẹ ni ihiẹnni, kẹni wẹ hụn ụzọ wekinhẹn m ebe ụnụ rị ẹgwa.
\s1 Ekpere
\p 
\v 20 Osolobuẹ e ye udọn; ịya gha ọnwụn wekinhẹn Di-nwọnni-ẹnyi wụ Jesu, okẹn onyẹ-ndu atụnrụn ahụn wẹ gi ẹdeke ẹ (ya wụ ọnwụn a) biye nkwerigbama itẹbitẹ hụ Osolobuẹ tumẹ ẹka;
\v 21 ya dodo yechanrịn ụnụ ihiẹn ile rị mma hụn ụnụ e gi mẹ uche ẹ. Ya dodo mẹ ẹ, kẹni ihiẹn a sụọn'a hụn ụzọ e mẹ imẹ ndụn ẹnyi ghahanị Jesu Kristi. Ọghọ ya rịnị Jizọs' Kraịstị ogẹn ile jẹnrin ejẹn! Isẹẹ.
\s1 Oku Ịkpazụụn
\p 
\v 22 M rị a rịọ ụnụ umunẹ m, dodo, nabanhan nị oku nkasị-obini m de ni ụnụ, n'o suekẹni.
\p 
\v 23 M chọ nị ụnụ marịn nị a hatugụọ wẹ nwẹnẹ ẹnyi wụ Timoti—n'ọ ghagụọ ụlọ-ngan pụha. Mmẹ lẹ 'ya jẹnkọ d'a wị m lalanị d'a hụn ụnụ, omẹni ọ bịaghọ ẹgwa.
\p 
\v 24 Kele ni ndị-ndu ụnụ ile lẹ ndị-nsọ ile. Ndị hụn gha Itali bịa rị ekele ụnụ.
\v 25 Ẹfọma Osolobuẹ ya rịnị ụnụ ile. Isẹẹ.
