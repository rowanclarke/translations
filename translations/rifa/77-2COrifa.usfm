\id 2CO
\h 2 إِكُورِينْثِييّنْ 
\toc1 2 إِكُورِينْثِييّنْ 
\toc2 2 إِكُورِينْثِييّنْ 
\toc3 2 كُور. 
\mt1 2 إِكُورِينْثِييّنْ  
\c 1
\s1 أَسدْجمْ غَارْ ؤُمزْوَارُو  
\m
\v 1 بُولُوسْ، رَّاسُولْ ن يَاسُوع لْمَاسِيحْ عْلَاحْسَابْ ڒْخَاضَارْ ن أَربِّي، ذ ثَاوْمَاثْ ثِيمُوثِييُو، إِ ثْمسْمُونْثْ ن أَربِّي إِ إِدْجَانْ ذِي كُورِينْثُوسْ ؤُ إِ مَارَّا إِمْقدَّاسنْ إِنِّي إِدْجَانْ ذِي مَارَّا أَخَايَا: \f ◼ \fr 1:‏1 \ft \+bd ’رَّاسُولْ‘\+bd* - نِيغْ ’أَمَازَانْ‘.\f*  \x ◘ \xo 1:‏1 \xt فِيل. 1‏:‏1. \x*  
\v 2 أَذْ كِيذْومْ يِيڒِي أَرْضَا ذ ڒهْنَا ن أَربِّي، بَابَاثْنغْ، ؤُ ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ. \x ◘ \xo 1:‏2 \xt رُوم. 1‏:‏7؛ 1 كُور. 1‏:‏3؛ أَفا. 1‏:‏2؛ 1 بُط. 1‏:‏2. \x*   
\b  
\m  
\s1 أَربِّي إِسّْفوّجْ ذِي مَارَّا ڒحْصَارثْ  
\m
\v 3 لْبَارَاكَا أَقَا-ت إِ أَربِّي، بَابَاسْ ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ، بَابَاسْ ن أَرّحْمثْ ذ أَربِّي ن مَارَّا أَفوّجْ. \x ◘ \xo 1:‏3 \xt أَفا. 1‏:‏3؛ 1 بُط. 1‏:‏3. \x*  
\v 4 نتَّا إِسّْفوَّاجْ أَنغْ ذِي مَارَّا ڒْمحْنثْ نّغْ، حِيمَا ؤُڒَا ذ نشِّينْ نْقدّْ أَذْ نسّْفوّجْ خْ يِينِّي إِدْجَانْ ذِي مَامّشْ مَا ثدْجَا ڒْمحْنثْ أَمْ نشِّينْ، س ؤُفوّجْ إِ زِي نتّْوَاسّْفوّجْ زِي أَربِّي. \x ◘ \xo 1:‏4 \xt 2 كُور. 7‏:‏6. \x*  
\v 5 مِينْزِي أَمنْ إِفيّضْ ذَايْنغْ أَودّبْ ن لْمَاسِيحْ، أَمُّو إِفيّضْ عَاوذْ ؤُفوّجْ نّغْ س لْمَاسِيحْ. \x ◘ \xo 1:‏5 \xt إِزهد. 34‏:‏20؛ 94‏:‏19. \x*  
\v 6 مَاشَا عَاوذْ مَاڒَا حْصَارنْ أَنغْ، أَقَا نتّْوَاحْسَارْ إِ ؤُفوّجْ نْومْ ؤُ إِ ثُوذَارْثْ نْومْ. ؤُ مَاڒَا نتّْوَافوّجْ، أَقَا ذ مَانْ أَيَا حِيمَا أَذْ ثتّْوَاسّْفوّْجمْ ؤُڒَا ذ كنِّيوْ، مَاحنْذْ أَذْ غَارْومْ يِيڒِي صَّابْرْ أَڒَامِي ثْزمَّارمْ عَاوذْ أَذْ ثكْسِيمْ أَودّبْ أَمْ نكْسِي ؤُڒَا ذ نشِّينْ أَودّبْ. \x ◘ \xo 1:‏6 \xt 2 كُور. 4‏:‏17. \x*  
\v 7 أَسِيثمْ نّغْ إِ كنِّيوْ إِمْثنْ، مِينْزِي نسّنْ مَاڒَا ثْشَارّْشمْ ذڭْ ؤُودّبْ، أَذْ ثْشَارْشمْ ؤُڒَا ذڭْ ؤُفوّجْ.   
\m
\v 8 \add أَ كنِّيوْ،\add* أَيْثْمَاثْنغْ، نشِّينْ نخْسْ أَذْ ثسّْنمْ خْ ڒْمحْنثْ إِ خَانغْ د-إِكِّينْ ذِي أَسِييَا، أَقَا ثكَّا-د خَانغْ ڒْمحْنثْ سنّجْ خْ ثْزمَّارْ نّغْ، أَڒَامِي عْڒَاحَاڒْ نقْضعْ ڒَايَاسْ زِي ثُوذَارْثْ نّغْ. \x ◘ \xo 1:‏8 \xt ڒخ. 19‏:‏23. \x*  
\v 9 أَقَا نحْكمْ خْ يِيخفْ نّغْ س ڒْموْثْ، حِيمَا وَارْ نتِّيقِّي شَا ذڭْ إِخفْ نّغْ، مَاشَا ذِي أَربِّي ونِّي د-إِسّْنكَّارَانْ إِمتِّيننْ. \x ◘ \xo 1:‏9 \xt إِرْم. 17‏:‏5، 7. \x*  
\v 10 نتَّا أَقَا إِفكّْ أَنغْ زِي ڒْموْثْ إِنقّنْ ؤُشَا نتّْرَاجَا أَذْ أَنغْ إِفكّْ ثْوَاڒَا نّغْنِي \x ◘ \xo 1:‏10 \xt 1 كُور. 15‏:‏31. \x*  
\v 11 س ؤُعَاونْ ن ثْژَادْجِيثِينْ نْومْ خَانغْ، مَاحنْذْ أَذْ ثِيڒِي ثَاوْهِيبْثْ نّسْ إِ نشِّينْ ذ لْبَارَاكَا إِ وَاطَّاسْ، حِيمَا أَطَّاسْ أَذْ أَسْ قَاذَانْ زِي سِّيبّثْ نّغْ. \x ◘ \xo 1:‏11 \xt رُوم. 15‏:‏30؛ 2 كُور. 4‏:‏15؛ فِيل. 1‏:‏19. \x*   
\b  
\m  
\s1 أَبدّڒْ ن ؤُسَافَارْ ن بُولُوسْ  
\m
\v 12 مِينْزِي وَا ذ أَسمْغَارْ نّغْ، شّْهَاذثْ ن ثْنفْسشْثْ نّغْ، بلِّي أَقَا أَنغْ نڭُّورْ ذِي دُّونشْثْ س صْفَا ذ ثَازْذُوڭِي، وَارْ إِدْجِي س ثِيغِيثْ ن بْنَاذمْ، \add مَاشَا\add* ذِي أَرْضَا ن أَربِّي، ذ أَمزْوَارُو إِ كنِّيوْ.  
\v 13 مِينْزِي وَارْ ذ أَومْ نُورِي ؤُڒَا ذ إِشْثْ ن ثْمسْڒَاشْثْ مْغِيرْ مِينْ ثسّْنمْ ؤُ أَذْ أَسْ ثْفهْممْ، إِوَا سِّيثِيمغْ أَذْ ثْفهْممْ أَڒْ أَنڭَّارُو،  
\v 14 أَمْ مَامّشْ عَاوذْ ثْفهْممْ زَّايْنغْ ذْرُوسْ بلِّي أَقَا أَنغْ ذ أَسمْغَارْ نْومْ، أَمْ مَامّشْ ؤُڒَا ذ كنِّيوْ \add ذ أَسمْغَارْ\add* نّغْ ذڭْ وَاسّْ ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ.   
\m
\v 15 ذِي ڒَامَانْ-أَ ثُوغَا خْسغْ أَذْ غَارْومْ د-أَسغْ قْبڒْ، حِيمَا أَذْ غَارْومْ يِيڒِي أَرْضَا ثْنَاينْ ن ثْسقَّارْ. \x ◘ \xo 1:‏15 \xt 1 كُور. 16‏:‏5. \x*  
\v 16 ثُوغَا خْسغْ أَذْ غَارْومْ د-ؤُسِيغْ \add ذڭْ وبْرِيذْ\add* غَارْ مَاكِيذُونِييَا. أَوَارْنِي مَانْ أَيَا ثُوغَا خْسغْ أَذْ غَارْومْ د -عقْبغْ عَاوذْ زِي مَاكِيذُونِييَا، حِيمَا كنِّيوْ أَذْ أَيِي ثسّْقبّْضمْ غَارْ يَاهُوذِييَّا.  
\v 17 ڒَامِي ثُوغَاعوّْڒغْ أَذْ ڭّغْ مَانْ أَيَا، مَا قدْجْقغْ؟ نِيغْ مِينْ خَارْصغْ أَذْ ث ڭّغْ، مَا خَارْصغْ ث عْلَاحْسَابْ أَيْسُومْ \add إِنُو\add*، أَڒَامِي ذَايسْ إِتّْوَافْ ’وَاهْ، وَاهْ!‘ ؤُڒَا ذ ’لَّ، لَّا‘؟  
\v 18 مَاشَا أَربِّي ذ أَمْثِيقِّي إِ يدْجَا، أَڒَامِي أَوَاڒْ نّغْ إِ كنِّيوْ وَارْ إِدْجِي ’وَاهْ!‘ ؤُڒَا ذ ’لَّ!‘ \x ◘ \xo 1:‏18 \xt مت. 5‏:‏37؛ يَاع. 5‏:‏12. \x*  
\v 19 مِينْزِي مِّيسْ ن أَربِّي، يَاسُوع لْمَاسِيحْ، ونِّي إِ زِي إِتّْوَابَارّحْ جَارْ أَومْ زَّايْنغْ، زَّايِي ؤُ زِي سِيلْوَانُوسْ ؤُ زِي ثِيمُوثِييُو، أَقَا نتَّا وَارْ إِدْجِي ذ ’وَاهْ!‘ ؤُڒَا ذ ’لَّ!‘، مَاشَا ’وَاهْ‘ ذَايسْ إِ يدْجَا.  
\v 20 مِينْزِي مَارَّا لْوُوعُوذْ ن أَربِّي، أَقَا أَثنْ ذ ’وَاهْ!‘ ذَايسْ، ذِي لْمَاسِيحْ. س ؤُينِّي نقَّارْ زَّايسْ عَاوذْ ’أَمِينْ!‘ إِ ؤُعُودْجِي ن أَربِّي.  
\v 21 مَاشَا أَربِّي ذ ونِّي ذ أَنغْ إِضْمنْ أَكِيذْومْ ذِي لْمَاسِيحْ، \add أَقَا-ث ذ أَمذْهُونْ\add*، نِّي إِ ذ أَنغْ إِذْهنْ.  
\v 22 إِڭَّا خَانغْ أَشمِّيعْ نّسْ ؤُشَا إِوْشَا أَنغْ أَرُّوحْ ذ ڒْعَارْبُونْ ذڭْ وُوڒَاونْ نّغْ. \x ◘ \xo 1:‏22 \xt رُوم. 8‏:‏16؛ 2 كُور. 5‏:‏5؛ أَفا. 1‏:‏13؛ 4‏:‏30. \x*   
\m
\v 23 مَاشَا نشّْ شهّْذغْ زَّاثْ إِ أَربِّي خْ يِيخفْ إِنُو، أَقَا ثُوغَا أَيِي ذ أَحْنِينْ خَاومْ، ڒَامِي وَارْ د-ؤُسِيغْ غَارْ كُورِينْثُوسْ. \x ◘ \xo 1:‏23 \xt رُوم. 1‏:‏9؛ 9‏:‏1؛ 2 كُور. 11‏:‏31؛ ڭال. 1‏:‏20؛ فِيل. 1‏:‏8؛ 1 تس. 2‏:‏5؛ 1 تِيم. 5‏:‏21؛ 2 تِيم. 4‏:‏1. \x*  
\v 24 وَارْ إِدْجِي مِينْزِي نتّْصلّطْ خْ لْ-إِيمَانْ نْومْ، مَاشَا نشِّينْ ذ إِمْسخَّارنْ إِ ڒفْرَاحثْ نْومْ، مِينْزِي زِي لْ-إِيمَانْ ثْبدّمْ ثْمثْنمْ. \x ◘ \xo 1:‏24 \xt 1 بُط. 5‏:‏3. \x*   
\b  
\b  
\m  
\c 2
\s1 پُولُوسْ ذ ثْمسْمُونْثْ ذ سْمَاحثْ إِ ؤُمذْنُوبْ  
\m
\v 1 ذڭَّا أَقَا ڭِّيغْ ث ذڭْ يِيخفْ إِنُو، أَقَا وَارْ غَارْومْ د-تِّيسغْ ثْوَاڒَا نّغْنِيثْ س وشْضَانْ.  
\v 2 مِينْزِي مَاڒَا زعْمَا نشّْ سّْفُّوڭْمغْ كنِّيوْ، وِي خنِّي ذ أَيِي غَا إِسّْفَارْحنْ مْغِيرْ ونِّي ذِي ڭِّيغْ أَفُوڭمْ؟  
\v 3 ؤُرِيغْ أَومْ-د مَانْ أَيَا، حِيمَا نشّْ، خْمِي د غَا يَاوْضغْ ذِينْ، وَارْ تّْوَاسّْفُّوڭْمغْ شَا زڭْ إِنِّي إِتّْخصَّا أَذْ زَّايْسنْ فَارْحغْ. أَقَا تِّيقّغْ ذَايْومْ مَارَّا، بلِّي ڒفْرَاحثْ إِنُو، أَقَا-ت ذ ڒفْرَاحثْ نْومْ مَارَّا. \x ◘ \xo 2:‏3 \xt 2 كُور. 8‏:‏22؛ ڭال. 5‏:‏10. \x*  
\v 4 مِينْزِي ؤُرِيغْ أَومْ-د ذِي ڒْمحْنثْ ثمْغَارْ س وَاطَّاسْ ن إِمطَّاونْ ؤُڒَا س وُوڒْ يَارجْفنْ، وَارْ إِدْجِي حِيمَا أَذْ ثْفُّوڭْممْ، مَاشَا حِيمَا أَذْ ثسّْنمْ ثَايْرِي إِ غَارِي إِ كنِّيوْ س ؤُفيّضْ.   
\b  
\m
\v 5 مَاشَا مَاڒَا ذِينْ ونِّي إِسّْفُّوڭْمنْ، نتَّا وَارْ ذ أَيِي إِسّْفُّوڭمْ وَاهَا، مَاشَا زڭْ إِجّْ ن ؤُغزْذِيسْ إِ كنِّيوْ مَارَّا، أَڒَامِي وَارْ كنِّيوْ سّْضقْڒغْ \add عَاذْ كْثَارْ\add* س وَاوَاڒْ-أَ.  
\v 6 شْفَا يَاسْ إِ وَانِيثَا، أَقَا أَزْينْ أَمقّْرَانْ \add زَّايْومْ\add* ثُوغَا إِوبّخْ إِ-ث. \x ◘ \xo 2:‏6 \xt 1 كُور. 5‏:‏3. \x*  
\v 7 زِي جِّيهثْ نّغْنِي أَقَا إِتّْخصَّا أَومْ ڒخُّو أَذْ أَسْ ثْسَامْحمْ ؤُشَا أَذْ خَاسْ ثسّْفوّْجمْ، حِيمَا وَارْ خَاسْ يَارنِّي ؤُفُوڭمْ أَڒْ أَنڭَّارُو.  
\v 8 س ؤُينِّي تّْزَاوَاڭغْ كنِّيوْ مَاحنْذْ أَذْ أَسْ ثسّْثبّْثمْ ثَايْرِي نْومْ إِ نتَّا.  
\v 9 مِينْزِي عَاوذْ إِ مَانْ أَيَا ؤُرِيغْ أَومْ-د، حِيمَا أَذْ سّْنغْ س ثِيذتّْ، مَا ثتّطَّاعمْ ذِي مَارَّا.  
\v 10 ونِّي ؤُمِي ثْسَامْحمْ، نشّْ عَاوذْ أَذْ أَسْ سَامْحغْ. مِينْزِي خْ مِيخفْ ؤُمِي ذ أَسْ سَامْحغْ، سَامْحغْ ث ذِي طّْوعْ نْومْ قِيبَاتْشْ إِ وُوذمْ ن لْمَاسِيحْ،  
\v 11 حِيمَا خنِّي شِّيطَانْ وَارْ ذ أَنغْ إِزمَّارْ، مِينْزِي نسّنْ إِخَارِّيصنْ نّسْ.   
\b  
\m  
\s1 إِشْثْ ن ڒفْوَاحثْ إِشْنَانْ إِ أَربِّي  
\m
\v 12 ڒَامِي د-إِوْضغْ غَارْ ثْرُووَاسْ س ڒخْبَارْ أَصبْحَانْ ن لْمَاسِيحْ، ثنُّورْزمْ أَيِي-د ثوَّارْثْ س \add ؤُفُوسْ ن\add* سِيذِي، \x ◘ \xo 2:‏12 \xt ڒخ. 16‏:‏8. \x*  
\v 13 \add مَاشَا\add* وَارْ أَريّْحغْ شَا ذِي أَرُّوحْ إِنُو، مِينْزِي وَارْ ؤُفِيغْ شَا ؤُمَا ثِيثُوسْ. ؤُشَا مّْسبْضِيغْ خَاسنْ، ؤُيُورغْ غَارْ مَاكِيذُونِييَا.   
\m
\v 14 مَاشَا أَقَاذِي إِ أَربِّي، ونِّي ذ أَنغْ إِڭَّا أَذْ نِيڒِي نتّْبَانْ ڒبْذَا ذِي لْمَاسِيحْ، ؤُشَا إِسّْشَانْ زَّايْنغْ ڒفْوَاحثْ ن ثُوسّْنَا نّسْ ذِي مَارَّا إِمُوشَانْ. \x ◘ \xo 2:‏14 \xt كُول. 1‏:‏27. \x*  
\v 15 مِينْزِي ندْجْ ذ إِشْثْ ن ڒفْوَاحثْ إِشْنَانْ إِ أَربِّي ذِي لْمَاسِيحْ جَارْ إِنِّي إِدَّارنْ ؤُ جَارْ إِنِّي إِ غَا إِتّْوَاهلّْكنْ.  
\v 16 إِ إِنڭُّورَا أَقَا أَنغْ ذ ڒفْوَاحثْ ن ڒْموْثْ إِ ڒْموْثْ ؤُشَا إِ إِمزْوُورَا ذ ڒفْوَاحثْ ن ثُوذَارْثْ إِ ثُوذَارْثْ. ؤُشَا مَانْ ونْ ذ أَسْ إِقدّنْ إِ سُّوقْ-أَ؟ \x ◘ \xo 2:‏16 \xt لك. 2‏:‏34. \x*  
\v 17 أَقَا نشِّينْ وَارْ ندْجِي أَنشْثْ إِنّغْنِي إِنِّي إِسّْفَارَّاغنْ أَوَاڒْ ن أَربِّي، مَاشَا نسِّيوڒْ ذِي لْمَاسِيحْ قِيبَاتْشْ إِ أَربِّي عْلَاحْسَابْ ثِيذتّْ ؤُ عْلَاحْسَابْ مِينْ إِدْجَانْ زِي أَربِّي.   
\b  
\b  
\m  
\c 3
\s1 إِمْسخَّارنْ ن ڒْعَاهْذْ ن جْذِيذْ  
\m
\v 1 مَا إِتّْخصَّا أَنغْ أَذْ أَومْ نْوصَّا إِخفْ نّغْ \add مِينْ نعْنَا\add* ثْوَاڒَا نّغْنِي؟ نِيغْ نحْذَاجْ، أَمْ إِنّغْنِي، ثِيبْرَاثِينْ ن ؤُوصِّي إِ كنِّيوْ؟ نِيغْ إِتّْخصَّا أَنغْ أَذْ أَومْ نَارِي حِيمَا كنِّيوْ أَذْ أَنغْ ثْوصَّامْ؟ \x ◘ \xo 3:‏1 \xt 2 كُور. 5‏:‏12؛ 10‏:‏8. \x*  
\v 2 أَقَا كنِّيوْ ذ ثَابْرَاثْ نّغْ إِ يُورَانْ ذڭْ وُوڒَاونْ نّغْ، إِتّْوَاسّنْ ؤُ إِتّْوَاسّْغَارنْ زڭْ إِوْذَانْ مَارَّا.  
\v 3 مِينْزِي ثسّْنمْ، أَقَا كنِّيوْ ذ ثَابْرَاثْ ن لْمَاسِيحْ إِ إِتّْوَاڭّنْ س ثْسخَّارْثْ نّغْ، \add ثَابْرَاثْ\add* يُورَانْ، وَارْ ثدْجِي س سّْمخْ مَاشَا س أَرُّوحْ ن أَربِّي إِدَّارنْ، وَارْ ثدْجِي ذِي ثڒْوِيحِينْ ن وژْرُو، مَاشَا ذِي ثڒْوِيحِينْ ن وُوڒَاونْ ن ويْسُومْ. \x ◘ \xo 3:‏3 \xt ؤُف. 24‏:‏12؛ 34‏:‏1؛ إِرْم. 31‏:‏33؛ حِز. 11‏:‏19؛ 36‏:‏26؛ عبر. 8‏:‏10. \x*  
\v 4 مَاغَارْ أَمُّو إِ ثدْجَا تِّيقّثْ إِ غَارْنغْ ذِي لْمَاسِيحْ زَّاثْ إِ أَربِّي.  
\v 5 وَارْ نْزمَّارْ أَذْ نحْسبْ شَا ن ڒْحَاجّثْ أَخْمِي د-ثُوسَا زَّايْنغْ، مَاشَا ثِيزمَّارْ نّغْ ثُوسَا-د زِي أَربِّي.  
\v 6 نتَّا يَارَّا أَنغْ أَقَا نسْذَاهدْجْ أَذْ نِيڒِي ذ إِمْسخَّارنْ إِ ڒْعَاهْذْ ن جْذِيذْ، وَارْ إِدْجِي س ثِيرَا \add س لْحُورُوفْ\add*، مَاشَا س \add ثِيرَّا ن\add* أَرُّوحْ، مِينْزِي ثِيرَا \add س لْحُورُوفْ\add* نقّنْثْ، مَاشَا أَرُّوحْ إِسّدَّارْ. \x ◘ \xo 3:‏6 \xt إِرْم. 31‏:‏31؛ مت. 26‏:‏28، مك. 14‏:‏24، لك. 22‏:‏20، 1 كُور. 11‏:‏25، 2 كُور. 3‏:‏6، 5‏:‏18؛ عبر. 8‏:‏6، 8، 13؛ 9‏:‏15؛ 12‏:‏24؛ 2 كُور. 5‏:‏18؛ \x*   
\m
\v 7 مَاشَا مَاڒَا ثُوغَا ثْسخَّارْثْ ن ڒْموْثْ إِ إِتّْوَاخبْشنْ س ثِيرَا ذڭْ إِژْرَا س وَانشْثْ ؤُعُودْجِي مَاحنْذْ ثَارْوَا ن إِسْرَائِيل وَارْ زمَّارنْ أَذْ سوْضنْ غَارْ وُوذمْ ن مُوسَا خْ سِّيبّثْ ن ؤُعُودْجِي ن ؤُغمْبُوبْ نّسْ، وَاخَّا \add أَعُودْجِي نِّي\add* إِعدُّونْ، \x ◘ \xo 3:‏7 \xt ؤُف. 24‏:‏12؛ 34‏:‏1، 30؛ أَعَوذ. 10‏:‏1. \x*  
\v 8 مشْحَاڒْ كْثَارْ إِ غَا ثِيڒِي ثْسخَّارْثْ ن أَرُّوحْ ذڭْ ؤُعُودْجِي؟  
\v 9 مِينْزِي مَاڒَا ثَاسخَّارْثْ إِ إِندّْهنْ غَارْ لْحِيسَابْ ثُوغَا-ت س ؤُعُودْجِي، مَاهُو عَاذْ ثَاسخَّارْثْ إِ إِندّْهنْ غَارْ ثْسڭْذَا أَذْ د-ثَاوِي أَعُودْجِي أَڒْ أَفيّضْ.  
\v 10 مِينْزِي مِينْ إِتّْوَاسّْعُودْجنْ، إِبَانْ-د وَارْ إِتّْوَاسّْعُودْجِي شَا ذڭْ وُوذمْ ن ؤُعُودْجِي-يَا إِ خَاسْ إِعُودْجنْ.  
\v 11 مِينْزِي مَاڒَا مِينْ إِعدُّونْ ثُوغَا غَارسْ أَعُودْجِي، مَاهُو مِينْ إِقِّيمنْ أَذْ غَارسْ يِيڒِي ؤُعُودْجِي.   
\m
\v 12 أجّْ أَنغْ خنِّي، مَاغَارْ غَارْنغْ أَسِيثمْ أَمْ وَانِيثَا، أَذْ نُويُورْ س ثرْيَاسْثْ،  
\v 13 وَارْ نتّڭّْ شَا أَمْ مُوسَا، ونِّي إِڭِّينْ لّْثَامْ خْ وُوذمْ نّسْ، مَاحنْذْ ثَارْوَا ن إِسْرَائِيل وَارْ سكّْوضنْ شَا أَنڭَّارْ ن مِينْ غَا إِعْذُونْ. \x ◘ \xo 3:‏13 \xt ؤُف. 34‏:‏35؛ رُوم. 10‏:‏4. \x*  
\v 14 مَاشَا إِخَارِّيصنْ نْسنْ تّْوَاسّْذَارَاغْڒنْ، مِينْزِي أَڒْ أَسّْ-أَ إِتّْغِيمَا لّْثَامْ ذ إِجّنْ خْ ثغْرِي ن ڒْعَاهْذْ أَقْذِيمْ بْڒَا مَا ذ أَسنْ إِتّْوَاسَّارْڭبْ، أَقَا \add لّْثَامْ\add* إِتّْوَابْضڒْ ذِي لْمَاسِيحْ. \x ◘ \xo 3:‏14 \xt إِشا. 6‏:‏10؛ حِز. 12‏:‏2؛ مت. 13‏:‏11؛ ڒخ. 28‏:‏26؛ رُوم. 11‏:‏8. \x*  
\v 15 أَڒْ أَسّْ-أَ، خْمِي ذ غَا غَارنْ زڭْ \add إِذْلِيسنْ ن\add* مُوسَا، لّْثَامْ أَقَا-ث خْ وُوڒْ نْسنْ.  
\v 16 مَاشَا خْمِي د غَا إِذْوڒْ حذْ زَّايْسنْ غَارْ سِيذِي، لّْثَامْ أَذْ زَّايسْ إِتّْوَاكّسْ. \x ◘ \xo 3:‏16 \xt مت. 13‏:‏11؛ رُوم. 11‏:‏23؛ 1 كُور. 2‏:‏10. \x*  
\v 17 أَقَا سِيذِي س يِيخفْ نّسْ ذ أَرُّوحْ ؤُشَا مَانِي إِدْجَا أَرُّوحْ ن سِيذِي، أَقَا ذِينْ ثِيڒلِّي. \x ◘ \xo 3:‏17 \xt يُوح. 4‏:‏24. \x*  
\v 18 مَاشَا مَارَّا نشِّينْ نتّْوَاڒَا أَعُودْجِي ن سِيذِي س إِغمْبَابْ وَارْ إِڒحّْفنْ أَمشْنَاوْ ذِي ثِيسِيثْ، ؤُشَا أَذْ نْبدّڒْ زڭْ ؤُعُودْجِي غَارْ ؤُعُودْجِي غَارْ صِّيفثْ ذ إِشْثنْ، أَمْ \add س ؤُغمْبُوبْ ن\add* سِيذِي، أَرُّوحْ. \x ◘ \xo 3:‏18 \xt 1 كُور. 13‏:‏12؛ 2 كُور. 5‏:‏7. \x*   
\b  
\b  
\m  
\c 4
\s1 ڒْكنْزْ ذِي ڒقْشُوعْ ن ثْڒَاخْثْ  
\m
\v 1 س ؤُينِّي ثَاسخَّارْثْ إِ ذ أَنغْ إِتّْوَاڭّنْ وَارْ \add ذ أَنغْ\add* ثسِّيحڒْ شَا، زِي سِّيبّثْ ن أَرّحْمثْ إِ خَانغْ \add إِدْجَانْ\add*.  
\v 2 مَاشَا أَقَا ننْضَارْ ثِيمسْڒَايِينْ إِنُّوفَارنْ إِسّحْشِيمنْ، وَارْ نڭُّورْ شَا س ثحْرَايْمشْثْ. \add عَاوذْ\add* وَارْ نتّْژُووَّارْ شَا أَوَاڒْ ن أَربِّي، مَاشَا أَقَا نسَّارْڭبْ إِخفْ نّغْ أَمْ نَارزّمْ ثَاوَّارْثْ ن ثِيذتّْ إِ قَاعْ ثَانفْسشْثْ ن إِوْذَانْ زَّاثْ إِ أَربِّي. \x ◘ \xo 4:‏2 \xt 2 كُور. 2‏:‏17؛ 2 كُور. 6‏:‏4\x*   
\m
\v 3 مَاشَا مَاڒَا لْ-إِنْجِيلْ نّغْ عَاذْ إِڒحّفْ، أَقَا إِتّْڒحَّافْ إِ يِينِّي إِ غَا إِودَّارنْ، \x ◘ \xo 4:‏3 \xt 2 كُور. 2‏:‏15؛ 2 تس. 2‏:‏10. \x*  
\v 4 إِ يِينِّي إِسّْذَارْغڒْ أَسنْ أَربِّي ن دُّونشْثْ-أَ ڒعْقڒْ نْسنْ، حِيمَا خنِّي وَارْ خَاسنْ ثَارقّْ طّْيَا ن لْ-إِنْجِيلْ ن ؤُعُودْجِي ن لْمَاسِيحْ ونِّي إِدْجَانْ ذ صِّيفثْ ن أَربِّي. \x ◘ \xo 4:‏4 \xt إِشا. 6‏:‏10؛ يُوح. 12‏:‏40؛ 14‏:‏9. فِيل. 2‏:‏6. كُول. 1‏:‏15. عبر. 1‏:‏3. \x*   
\m
\v 5 مِينْزِي وَارْ نتّْبَارّحْ شَا إِخفْ نّغْ، مَاشَا لْمَاسِيحْ يَاسُوع، سِيذِيثْنغْ، مَاشَا نشِّينْ س إِخفْ نّغْ ذ إِمْسخَّارنْ نْومْ ذِي طّْوعْ ن يَاسُوع.  
\v 6 مِينْزِي أَربِّي ذ ونِّي إِنَّانْ: ”أَذْ ثَارقّْ ثْفَاوْثْ زِي ثَادْجسْثْ!“، أَقَا ذ ونِّي إِسّْرُوغَانْ ؤُڒَاونْ نّغْ، حِيمَا أَذْ أَنغْ إِسَّارْغْ س ثُوسّْنَا ن ؤُعُودْجِي ن أَربِّي ذڭْ وُوذمْ ن يَاسُوع لْمَاسِيحْ. \x ◘ \xo 4:‏6 \xt أَمز. 1‏:‏3؛ 2 بُط. 1‏:‏19. \x*   
\m
\v 7 مَاشَا غَارْنغْ ڒْكنْزْ-أَ ذِي ڒقْشُوعْ ن ثْڒَاخْثْ، حِيمَا خنِّي ڒمْغَارثْ ن جّهْذْ أَذْ ثِيڒِي ن أَربِّي، وَارْ ثدْجِي زَّايْنغْ. \x ◘ \xo 4:‏7 \xt 1 كُور. 2‏:‏5؛ 2 كُور. 5‏:‏1. \x*  
\v 8 مَاغَارْ نتّْوَازِييَّارْ ذِي مَارَّا، مَاشَا وَارْ نتّْوَاجيّفْ، أَقَا شَّاثنْ أَنغْ، مَاشَا وَارْ نتّْوَاحْكمْ شَا،  
\v 9 تّْذَارَّاشنْ خَانغْ، مَاشَا وَارْ نتّْوَاسْمحْ، أَقَا نمّنْضَارْ، مَاشَا وَارْ نتّْوَاهلّكْ.  
\v 10 أَقَا نَاربُّو ڒْموْثْ ن يَاسُوع ڒبْذَا ذِي أَرِّيمثْ نّغْ، حِيمَا ؤُڒَا ذ ثُوذَارْثْ ن يَاسُوع أَذْ ثتّْوَاسّضْهَارْ ذِي أَرِّيمثْ نّغْ. \x ◘ \xo 4:‏10 \xt رُوم. 8‏:‏17؛ ڭال. 6‏:‏17؛ فِيل. 3‏:‏10؛ 2 تِيم. 2‏:‏11،12؛ 1 بُط. 4‏:‏13. \x*  
\v 11 مِينْزِي مَاڒَا نشِّينْ، إِنِّي إِدَّارنْ، أَقَا نتّْوَاسلّمْ إِ ڒْموْثْ ذِي طّْوعْ ن يَاسُوع، أَذْ ثسّضْهَارْ ؤُڒَا ذ ثُوذَارْثْ ن يَاسُوع ذِي أَرِّيمثْ نّغْ إِتّْمتَّانْ. \x ◘ \xo 4:‏11 \xt إِزهد. 44‏:‏23؛ مت. 5‏:‏11؛ رُوم. 8‏:‏36؛ 1 كُور. 4‏:‏9؛ 15‏:‏49؛ كُول. 3‏:‏4. \x*  
\v 12 ڒخُّو خنِّي ثْخدّمْ ڒْموْثْ ذَايْنغْ، مَاشَا ثُوذَارْثْ ذَايْومْ.  
\v 13 أَمْ غَارْنغْ أَرُّوحْ ذ إِجّْ ن لْ-إِيمَانْ - أَمْ مَامّشْ ثُورَا: ”أَقَا ؤُمْنغْ، س ؤُيَا سِّيوْڒغْ عَاوذْ!“ - أَقَا نتَّامنْ نشِّينْ، ؤُ س ؤُيَا نسَّاوَاڒْ عَاوذْ \x ◘ \xo 4:‏13 \xt إِزهد. 116‏:‏10. \x*  
\v 14 ؤُشَا نسّنْ بلِّي ونِّي د-إِسّْنكَّارنْ سِيذِيثْنغْ يَاسُوع، أَذْ أَنغْ د-إِسّْنكَّارْ عَاوذْ أَكْ-ذ يَاسُوع ؤُشَا أَذْ أَنغْ إِڭّْ أَكِيذْومْ زَّاثسْ. \x ◘ \xo 4:‏14 \xt رُوم. 8‏:‏11؛ 1 كُور. 6‏:‏14؛ 1 Th. 4‏:‏16، 17\x*  
\v 15 مِينْزِي مَارَّا ثِيمسْڒَايِينْ-أَ تّْوَاڭّنْثْ ذِي طّْوعْ نْومْ، حِيمَا أَذْ يَارْنِي أَرْضَا إِ وَاطَّاسْ، ؤُشَا أَذْ إِفيّضْ ؤُقَاذِي إِ ؤُعُودْجِي ن أَربِّي. \x ◘ \xo 4:‏15 \xt 2 كُور. 1‏:‏11. \x*   
\m
\v 16 س ؤُينِّي وَارْ نْخسَّارْ شَا ؤُڒَاونْ، وَاخَّا بْنَاذمْ نّغْ ن بَارَّا إِتّْوَاهلَّاكْ، أَقَا بْنَاذمْ ن ذَاخڒْ إِدَّاكّْوَاڒْ ذ جْذِيذْ زڭْ وَاسّْ غَارْ ونّغْنِي.  
\v 17 وَاخَّا ڒْمحْنثْ ن ڒْوقْثْ-أَ إِفْسُوسنْ ذ ڒْمِيجَاڒْ نّسْ ذْرُوسْ وَاهَا، عَاذْ ثتَّاوِي أَنغْ-د إِجّْ ن ڒْقدّْ ن ؤُعُودْجِي إِ وَارْ غَارسْ إِدْجِي ؤُنڭَّارْ إِ ڒبْذَا قَاعْ. \x ◘ \xo 4:‏17 \xt إِزهد. 30‏:‏6؛ مت. 5‏:‏12؛ رُوم. 8‏:‏18؛ 1 يُوح. 3‏:‏2. \x*  
\v 18 مَاغَارْ وَارْ نْفَارّحْ شَا زِي مِينْ إِتّْوَاڒَانْ مَاشَا زِي مِينْ وَارْ إِتّْوِيڒِينْ، مِينْزِي مِينْ إِتّْوَاڒَانْ أَقَا إِ يِيشْثْ ن ڒْوقْثْ وَاهَا، مَاشَا مِينْ وَارْ إِتّْوِيڒِينْ أَقَا-ث إِ ڒبْذَا.   
\b  
\b  
\m  
\c 5
\s1 ثَازذِّيغْثْ نّغْ ذڭْ ؤُجنَّا  
\m
\v 1 مِينْزِي نسّنْ، بلِّي، خْمِي غَا ثفْنَا ثَادَّارْثْ نّغْ ن ثمُّورْثْ إِ يدْجَانْ ذ أَرِّيمثْ، أَذْ غَارْنغْ يِيڒِي إِجّْ ن ڒبْنِي ن أَربِّي إِ ڒبْذَا ذڭْ إِجنْوَانْ، إِشْثْ ن ثَادَّارْثْ وَارْ ثتّْوَاڭّْ شَا س إِفَاسّنْ. \x ◘ \xo 5:‏1 \xt 2 كُور. 4‏:‏7. \x*  
\v 2 خْ مَانْ أَيَا إِ نْزهَّارْ ؤُ ذَايْنغْ مژْرِي، حِيمَا أَذْ نَارْضْ ثَادَّارْثْ نّغْ ثنِّي إِدْجَانْ زڭْ ؤُجنَّا، \x ◘ \xo 5:‏2 \xt رُوم. 8‏:‏23. \x*  
\v 3 معْلِيكْ قَاعْ إِ غَا نِيڒِي نْيَارْضْ، وَارْ ذ أَنغْ تِّيفنْ ذ إِعرْيَاننْ. \x ◘ \xo 5:‏3 \xt أَسَا. 3‏:‏18؛ 16‏:‏15. \x*  
\v 4 مَاشَا مِينْ مَا غَا نكّْ عَاذْ ذِي ثَادَّارْثْ-أَ، أَذْ نقِّيمْ نْزهَّارْ س دّْقڒْ نّسْ، مِينْزِي وَارْ نخْسْ أَذْ ت نجّْ، مَاشَا نخْسْ أَذْ ت نْيَارْضْ، حِيمَا مِينْ إِفنَّانْ أَذْ إِتّْوَاصَارْذْ زِي ثُوذَارْثْ. \x ◘ \xo 5:‏4 \xt رُوم. 8‏:‏11؛ 1 كُور. 15‏:‏53. \x*  
\v 5 ونِّي ذ أَنغْ د-إِسّْوجْذنْ إِ مَانْ أَيَا ذ نتَّا ذ أَربِّي ونِّي ذ أَنغْ إِوْشِينْ أَرُّوحْ نّسْ ذ ڒْعَارْبُونْ. \x ◘ \xo 5:‏5 \xt رُوم. 8‏:‏16؛ 2 كُور. 1‏:‏22؛ أَفا. 1‏:‏13؛ 4‏:‏30. \x*   
\m
\v 6 س ؤُينِّي نسّنْ ؤُ غَارْنغْ تِّيقّثْ، أَقَا خنِّي مِينْ غَا نكّْ نْزدّغْ ذِي أَرِّيمثْ، أَذْ نِيڒِي نڭّْوجْ خْ سِيذِيثْنغْ،  
\v 7 مِينْزِي س لْ-إِيمَانْ إِ نڭُّورْ، وَارْ إِدْجِي س مِينْ إِتّْبَاننْ.\x ◘ \xo 5:‏7 \xt 1 كُور. 13‏:‏12؛ 2 كُور. 3‏:‏18. \x*  
\v 8 س ؤُينِّي نتِّيقَّا ؤُشَا ذَايْنغْ مژْرِي، مَاحنْذْ أَذْ نسْمحْ ذِي أَرِّيمثْ حِيمَا أَذْ نِيڒِي أَكْ-ذ سِيذِيثْنغْ.  
\v 9 نتّْشطَّارْ حِيمَا أَذْ أَسْ أَرْضَانْ، مَا ندْجْ نڭّْوجْ خْ ثَادَّارْثْ نِيغْ ذِي ثَادَّارْثْ.  
\v 10 مِينْزِي مَارَّا إِذْنغْ أَذْ نضْهَارْ زَّاثْ إِ ڒْكُورْسِي ن شّْرعْ ن لْمَاسِيحْ، حِيمَا كُوڒْ إِجّنْ أَذْ إِطّفْ ذِي أَرِّيمثْ نّسْ عْلَاحْسَابْ مِينْ إِڭَّا \add س أَرِّيمثْ\add*، ثْشُونِي نِيغْ ثُوعفّْنَا. \x ◘ \xo 5:‏10 \xt إِزهد. 62‏:‏13؛ إِرْم. 17‏:‏10؛ 32‏:‏19؛ مت. 16‏:‏27؛ 25‏:‏32؛ رُوم. 2‏:‏6؛ 14‏:‏10، 12؛ 1 كُور. 3‏:‏8؛ ڭال. 6‏:‏5؛ أَسَا. 2‏:‏23؛ 22‏:‏12. \x*   
\b  
\m  
\s1 ثَاسخَّارْثْ ن وصْڒَاحْ  
\m
\v 11 س ؤُينِّي، أَمْ نسّنْ أَقَا إِتّْخصَّا أَذْ نڭّْوذْ زِي سِيذِيثْنغْ، أَقَا نَارزُّو أَذْ نسّقْنعْ إِوْذَانْ، مَاشَا غَارْ أَربِّي أَقَا نشِّينْ نتّْوَاسّنْ غَارسْ، ؤُشَا سِّيثِيمغْ أَقَا نتّْوَاسّنْ غَارْومْ عَاوذْ ذِي ثْنفْسشْثْ نْومْ. \x ◘ \xo 5:‏11 \xt 2 كُور. 11‏:‏6\x*  
\v 12 وَارْ نتّْوصِّي شَا إِخفْ نّغْ ثْوَاڒَا نّغْنِيثْ، مَاشَا أَذْ أَومْ نوْشْ لْفُورْصَا إِ ؤُسمْغَارْ ذَايْنغْ زَّاثْ إِ يِينِّي إِسّمْغَارَانْ ذِي مِينْ إِتّْبَاننْ، وَارْ إِدْجِي ذِي مِينْ إِدْجَانْ ذڭْ وُوڒْ. \x ◘ \xo 5:‏12 \xt 2 كُور. 3‏:‏1؛ 10‏:‏8. \x*  
\v 13 مِينْزِي مَاڒَا ثُوغَا نتّخْڒفْ، أَقَا مَانْ أَيَا إِ أَربِّي، مَاڒَا ثُوغَا أَنغْ س ڒعْقڒْ، أَقَا مَانْ أَيَا إِ كنِّيوْ.  
\v 14 مَاغَارْ ثَايْرِي ن لْمَاسِيحْ ثْعَارّنْ أَنغْ مَاحنْذْ أَذْ نْخَارّصْ أَمُّو: \add مَاڒَا\add* إِجّنْ إِمُّوثْ ذڭْ ومْشَانْ ن مَارَّا، أَقَا مَارَّا مُّوثنْ أَكِيذسْ.  
\v 15 أَقَا نتَّا إِمُّوثْ ذڭْ ومْشَانْ ن مَارَّا، حِيمَا إِنِّي إِدَّارنْ، وَارْ دَّارنْ شَا عَاذْ إِ إِخفْ نْسنْ، مَاشَا إِ ونِّي إِمُّوثنْ ذ ونِّي د-إِتّْوَاسّْنكَّارنْ إِ نِيثْنِي. \x ◘ \xo 5:‏15 \xt رُوم. 14‏:‏7؛ ڭال. 2‏:‏20؛ 1 تس. 5‏:‏10؛ 1 بُط. 4‏:‏2. \x*   
\m
\v 16 س ؤُيَا وَارْ نسِّينْ شَا ؤُڒَا ذ إِجّْ عْلَاحْسَابْ أَرِّيمثْ. مَاڒَا ثُوغَا نسّنْ لْمَاسِيحْ ذِي أَرِّيمثْ، ڒخْذنِّي وَارْ إِتِّيڒِي عَاذْ نسّنْ ث أَمُّو ڒخُّو. \x ◘ \xo 5:‏16 \xt مت. 12‏:‏50؛ يُوح. 15‏:‏14؛ ڭال. 5‏:‏6؛ 6‏:‏15؛ كُول. 3‏:‏11. \x*  
\v 17 س ؤُينِّي مَاڒَا حذْ ذِي لْمَاسِيحْ إِ إِدْجَا، أَقَا نتَّا إِتّْوَاخْڒقْ-د جْذِيذْ. خنِّي مِينْ إِدْجَانْ ذ أَقْذِيمْ إِعْذُو \x ◘ \xo 5:‏17 \xt إِشا. 43‏:‏18؛ أَسَا. 21‏:‏5. \x*  
\v 18 ؤُ مَارَّا إِذْوڒْ ذ جْذِيذْ س أَربِّي، ونِّي ذ أَنغْ إِسّصْڒحْ أَكْ-ذ يِيخفْ نّسْ س لْمَاسِيحْ ؤُشَا إِوْشَا أَنغْ ثَاسخَّارْثْ ن وصْڒَاحْ. \x ◘ \xo 5:‏18 \xt كُول. 1‏:‏20؛ 1 يُوح. 2‏:‏2؛ 4‏:‏10. \x*  
\v 19 مِينْزِي أَربِّي ثُوغَا إِسّصْڒحْ دُّونشْثْ أَكْ-ذ ڒمْغَارثْ نّسْ ذِي لْمَاسِيحْ ذِي مَانِي وَارْ ذ أَسنْ إِحْسِيبْ شَا إِخطَّانْ نْسنْ ؤُشَا إِسَّارْسْ ذَايْنغْ أَوَاڒْ ن وصْڒَاحْ. \x ◘ \xo 5:‏19 \xt رُوم. 3‏:‏24، 25؛ كُول. 1‏:‏20. \x*   
\m
\v 20 س ؤُيَا إِ ندْجْ ذ إِمْسكَّانْ ن لْمَاسِيحْ، أَخْمِي خَاومْ د-إِڒَاغَا أَربِّي زَّايْنغْ. س ؤُيَا نتّْڒَاغَا نشِّينْ ذڭْ ومْشَانْ ن لْمَاسِيحْ: ”رُوحمْ أَذْ ثتّْوَاصڒْحمْ أَكْ-ذ أَربِّي!“ \x ◘ \xo 5:‏20 \xt 2 كُور. 3‏:‏6. \x*  
\v 21 مَاغَارْ ونِّي وَارْ إِسِّيننْ شَا دّنْبْ، إِڭَّا إِ-ث ذ دّنْبْ إِ كنِّيوْ، حِيمَا أَذْ نذْوڒْ ذ ثَاسڭْذَا ن أَربِّي ذَايسْ. \x ◘ \xo 5:‏21 \xt إِشا. 53‏:‏9، 12؛ رُوم. 8‏:‏3؛ ڭال. 3‏:‏13؛ 1 بُط. 2‏:‏22؛ 1 يُوح. 3‏:‏5. \x*   
\b  
\b  
\m  
\c 6
\m
\v 1 أَقَا نشِّينْ، أَمْ إِمْعَاشَارنْ \add ن أَربِّي\add*، نْزَاوڭْ كنِّيوْ أَمُّو، حِيمَا أَرْضَا ن أَربِّي إِ ثطّْفمْ، وَارْ ذَايْومْ إِتّْوَاسّْبطّڒْ شَا، \x ◘ \xo 6:‏1 \xt 1 كُور. 3‏:‏9؛ عبر. 12‏:‏15. \x*  
\v 2 مِينْزِي إِنَّا:  
\b  
\m \qt ”ذِي ڒْوقْثْ ن أَرْضَا سْڒِيغْ أَشْ،\qt*  
\m \qt ؤُشَا ذڭْ وَاسّْ ن ؤُسنْجمْ عَاوْنغْ شكْ!“\qt*  
\b  
\m خْزَارْ، أَقَا ذَا ڒخُّو ذ ڒْوقْثْ ن أَرْضَا، خْزَارْ، أَقَا ذَا ڒخُّو ذ أَسّْ ن ؤُسنْجمْ. \x ◘ \xo 6:‏2 \xt إِشا. 49‏:‏8. \x*   
\b  
\m  
\s1 ثَامَارَا إِ د-إِكِّينْ خْ رَّاسُولْ بُولُوسْ  
\m
\v 3 مَايمِّي غَا ثوْشذْ سِّيبّثْ إِ شَا ن يِيجّنْ أَڒَامِي إِ غَا إِنْذرْفْ؟ إِتّْخصَّا وَارْ ذِينْ إِتِّيڒِي شَا ن ڒْعِيبْ ذِي ثْسخَّارْثْ نّغْ، \x ◘ \xo 6:‏3 \xt رُوم. 14‏:‏13؛ 1 كُور. 10‏:‏32. \x*  
\v 4 مَاشَا ذِي مَارَّا نتّْوصَّا إِخفْ نّغْ أَمْ إِمْسخَّارنْ ن أَربِّي: ذڭْ وَاطَّاسْ ن صّْبَارْ، ذِي ڒمْحَايمْ، ذِي ڒغْبنْ، ذِي ڒحْبُوسَاثْ، \x ◘ \xo 6:‏4 \xt 1 كُور. 4‏:‏1؛ 2 كُور. 11‏:‏23. \x*  
\v 5 سَاذُو ثِييِّيثَا، ذِي سّْنَاسڒْ، ذڭْ ؤُغُووّغْ، ذِي ثَامَارَا، ذِي دْجْيَاڒِي بْڒَا إِضصْ، ذڭْ \add وُوسَّانْ ن\add* ؤُژُومِّي،  
\v 6 ذِي ڒصْفَايثْ، ذِي ثُوسّْنَا، ذِي تَّاسِيعْ ن ڒْخَاضَارْ، ذِي ڒضْرَافثْ، ذِي أَرُّوحْ إِقدّْسنْ، ذِي ثَايْرِي بْڒَا نِّيفَاقْ،  
\v 7 س وَاوَاڒْ ن ثِيذتّْ، ذِي جّهْذْ ن أَربِّي، س ڒسْنَاحْ ن ثْسڭْذَا غَارْ ؤُفُوسِي ذ ؤُزڒْمَاضْ،  
\v 8 س ؤُعُودْجِي ذ دّدْجْ، س شّنْعثْ ثَاعفَّانْثْ ؤُ س شّنْعثْ ثَاصبْحَانْثْ، أَمْ إِغشَّاشنْ، \add وَاخَّا أَمنِّي\add* ذ إِمْثِيقَّانْ،  
\v 9 أَخْمِي وَارْ نتّْوِيسّنْ، وَاخَّا نتّْوَاسّنْ، أَخْمِي نتّْمتَّا، ؤُ خْزَارْ، أَقَا ندَّارْ، أَخْمِي نتّْوَاعَاقبْ مَاشَا وَارْ نتّْمتِّي شَا، \x ◘ \xo 6:‏9 \xt إِزهد. 118‏:‏18؛ إِشا. 26‏:‏19. \x*  
\v 10 أَخْمِي نشِّينْ نفُّوڭمْ، مَاشَا نْفَارّحْ ڒبْذَا، أَخْمِي نزْڒضْ، وَاخَّا نتّجَّارْ أَطَّاسْ، أَخْمِي وَارْ غَارْنغْ شَا، وَاخَّا غَارْنغْ كُوڒْشِي.   
\m
\v 11 أَقمُّومْ نّغْ إِنُّورْزمْ إِ كنِّيوْ، أَ إِكُورِينْثِييّنْ، ؤُڒْ نّغْ إِمْغَارْ أَطَّاسْ.  
\v 12 كنِّيوْ وَارْ ثتّْوَاحْصَارمْ زَّايْنغْ، مَاشَا ثتّْوَاحْصَارمْ س ثْوَاشِيثْ إِ إِدْجَانْ ذِي ذَاخڒْ نْومْ.  
\v 13 مَاشَا أَذْ كِيومْ سِّيوْڒغْ أَخْمِي سَّاوَاڒغْ أَكْ-ذ إِحنْجِيرنْ: أَرّمْ أَيِي-د س مِينْ ذَايِي ثتُّورْسمْ ؤُ سْوسّْعمْ ثَايْرِي نْومْ إِ نشّْ! \x ◘ \xo 6:‏13 \xt 1 كُور. 4‏:‏14. \x*   
\b  
\m  
\s1 وَارْ تّْمُونمْ شَا ذڭْ ؤُزَايْڒُو إِفَارْغنْ  
\m
\v 14 وَارْ تّْمُونمْ شَا ذڭْ ؤُزَايْڒُو أَكْ-ذ لْكُوفَّارْ، مَاغَارْ مَانْ أَشْرَاشْ إِ غَارْ ثدْجَا غَارْ ثْسڭْذَا أَكْ-ذ ثُوعفّْنَا، ؤُ مَانْ ثَامُونْثْ إِ غَارْ ثدْجَا إِ ثْفَاوْثْ أَكْ-ذ ثَادْجسْثْ؟ \x ◘ \xo 6:‏14 \xt أَعَوذ. 7‏:‏2؛ 1 صم. 5‏:‏1، 2؛ 1 إِج. 8‏:‏21؛ 1 كُور. 5‏:‏9؛ 10‏:‏21؛ أَفا. 5‏:‏11\x*  
\v 15 نِيغْ مَانْ أَرْوَاسْ إِ ذِينْ إِدْجَا جَارْ لْمَاسِيحْ ذ شِّيطَانْ؟ نِيغْ مَانْ ثَاسْغَارْثْ ن ڒْمُومنْ أَكْ-ذ ؤُكَافْرِيوْ؟  
\v 16 نِيغْ مَانْ ثَاسْغُونْثْ إِ ذِينْ جَارْ زَّاوشْثْ ثَامقّْرَانْثْ ن أَربِّي ذ \add ثنِّي ن\add* شّْوَاطنْ؟ أَقَا كنِّيوْ ذ زَّاوشْثْ ن أَربِّي إِدَّارنْ، أَمْ مَامّشْ إِنَّا أَربِّي:  
\b  
\m \qt ”نشّْ أَذْ زذْغغْ أَكِيذْسنْ\qt*  
\m \qt ؤُشَا أَذْ ؤُيُورغْ جَارْ أَسنْ.\qt*  
\m \qt نشّْ أَذْ إِڒِيغْ ذ أَربِّي نْسنْ،\qt*  
\m \qt نِيثْنِي أَذْ إِڒِينْ ذ ڒْڭنْسْ إِنُو.\qt* \x ◘ \xo 6:‏16 \xt ؤُف. 29‏:‏45؛ لَاوِي 26‏:‏11‏-‏12؛ إِرْم. 32‏:‏38؛ حِز. 37‏:‏27؛ 1 كُور. 3‏:‏16؛ 6‏:‏19؛ 10‏:‏7، 14؛ أَفا. 2‏:‏21؛ عبر. 3‏:‏6؛ 1 بُط. 2‏:‏5\x*   
\m
\v 17 \qt س ؤُينِّي، فّْغمْ-د زِي ڒْوسْطْ نْسنْ،\qt*  
\m \qt بْضَامْ خَاسنْ، إِقَّارْ سِيذِي.\qt*  
\m \qt وَارْ تّْحَاذَامْ مِينْ إِنڭْسنْ،\qt*  
\m \qt ؤُ نشّْ أَذْ كنِّيوْ قبْڒغْ.\qt* \x ◘ \xo 6:‏17 \xt إِشا. 52‏:‏11؛ حِز. 20‏:‏34، 41؛ أَسَا. 18‏:‏4. \x*   
\m
\v 18 \qt نشّْ أَذْ أَومْ إِڒِيغْ ذ بَابَاثْومْ،\qt*  
\m \qt كنِّيوْ أَذْ أَيِي ثِيڒِيمْ ذ إِحنْجِيرنْ ذ ثْحنْجِيرِينْ،\qt*  
\m \qt إِقَّارْ سِيذِي، ونِّي ذ أَمْزمَّارْ خْ كُوڒْشِي.“\qt* \x ◘ \xo 6:‏18 \xt 2 صم. 7‏:‏8، 14\x*   
\b  
\b  
\m  
\c 7
\s1 ڒفْرَاحثْ ن بُولُوسْ  
\m
\v 1 \add أَ\add* إِمْعِيزّنْ، أَڒَامِي غَارْنغْ لْوُوعُوذْ-أَ، أجّْ أَنغْ أَذْ نسِّيزْذڭْ إِخفْ نّغْ زِي مَارَّا ڒخْمجْ ن أَرِّيمثْ ؤُ ن أَرُّوحْ، أجّْ أَنغْ أَذْ نسّْقدّسْ إِخفْ نّغْ زِي ثِيڭّْوُوذِي ن أَربِّي.   
\m
\v 2 قبْڒمْ أَنغْ، \add كنِّيوْ أَ\add* أَيْثْمَاثْنغْ، ؤُڒَا ذ إِجّْ وَارْ ذَايسْ نڭِّي ڒْغَارْ، ؤُڒَا ذ إِجّْ وَارْ ث نْغشّْ، ؤُڒَا ذ إِجّْ وَارْ زَّايسْ نسْثنْفِيعْ.  
\v 3 وَارْ سِّيوْڒغْ حِيمَا أَذْ خَاومْ حكْمغْ، مِينْ زِي إِزَّارغْ نِّيغْ، أَقَا كنِّيوْ ذڭْ وُوڒَاونْ نّغْ مَاحنْذْ أَذْ نمّثْ جْمِيعْ ؤُشَا أَذْ ندَّارْ جْمِيعْ. \x ◘ \xo 7:‏3 \xt 2 كُور. 6‏:‏11، 12، 13. \x*  
\v 4 ثَارْيَاسْثْ إِنُو قِيبَاتْشْ إِ كنِّيوْ ثمْغَارْ ؤُشَا أَسمْغَارْ إِنُو خَاومْ إِمْغَارْ. أَقَا أَيِي شُّورغْ س ؤُفوّجْ، أَقَا ڒفْرَاحثْ ثْفيّضْ ذَايِي أَطَّاسْ ذِي كُوڒْشِي ڒمْحَايمْ إِنُو. \x ◘ \xo 7:‏4 \xt مت. 5‏:‏12؛ ڒخ. 5‏:‏41؛ فِيل. 2‏:‏17؛ كُول. 1‏:‏24. \x*   
\m
\v 5 مِينْزِي زڭْ وَامِي د-نُوسَا غَارْ مَاكِيذُونِييَا، وَارْ نُوفِي أَرَّاحثْ إِ أَرِّيمثْ نّغْ، مَاشَا ثُوغَا نسّْحِيسِّيفْ زِي مَارَّا إِغزْذِيسنْ، زِي بَارَّا أَقَا ذِينْ إِمْشُوبّشنْ، زِي ذَاخڒْ أَقَا ذِينْ ثِيڭّْوُوذِي. \x ◘ \xo 7:‏5 \xt ڒخ. 16‏:‏19، 23. \x*  
\v 6 مَاشَا أَربِّي، ونِّي إِسّْفوَّاجنْ خْ إِمْوَاضْعنْ، إِسّْفوّجْ-د خَانغْ س ثْوَاسِيثْ ن ثِيثُوسْ، \x ◘ \xo 7:‏6 \xt 2 كُور. 1‏:‏4. \x*  
\v 7 وَارْ إِدْجِي س ثْوَاسِيثْ نّسْ وَاهَا، مَاشَا عَاوذْ س ؤُفوّجْ إِ زِي ثُوغَا إِتّْوَاسّْفوّجْ زَّايْومْ، مَاغَارْ إِسَّارْڭبْ أَنغْ خْ ثَايْرِي نْومْ ذ وشْضَانْ نْومْ ذ شْضَارثْ نْومْ خَانغْ. ؤُمِي سْڒِيغْ أَيَا، فَارْحغْ أَطَّاسْ.   
\m
\v 8 مِينْزِي وَاخَّا سّْفُوڭْمغْ كنِّيوْ س إِشْثْ ن ثبْرَاثْ، وَارْ نْذِيمغْ شَا، وَاخَّا نْذِيمغْ، مَاغَارْ تّْوَاڒِيغْ أَقَا ثَابْرَاثْ نِّي ثسّْفُوڭمْ إِ كنِّيوْ إِ إِشْثْ ن ثْسَاعّثْ \add وَاهَا\add*.  
\v 9 مَاشَا فَارْحغْ أَطَّاسْ، وَارْ إِدْجِي ڒَامِي ثتّْوَاسّْفُوڭْممْ، مَاشَا ؤُمِي أَفُوڭمْ نْومْ يَارَّا كنِّيوْ غَارْ تُّوبثْ، مِينْزِي أَفُوڭمْ نْومْ يُوسَا-د زِي أَربِّي، أَڒَامِي ؤُڒَا ذ إِشْثْ ن ثْخسَّارْثْ وَارْ كنِّيوْ ثْڒقّفْ شَا زَّايْنغْ ذِي شَا ن ثْمسْڒَاشْثْ.  
\v 10 مِينْزِي أَفُوڭمْ نِّي إِدْجَانْ ذِي طّْوعْ ن أَربِّي، إِندّهْ غَارْ تُّوبثْ ن بُوحْبڒْ ؤُ غَارْ وذْوَاڒْ إِ ثُوذَارْثْ، مَاشَا أَفُوڭمْ ن دُّونشْثْ إِتَّاوِي غَارْ ڒْموْثْ. \x ◘ \xo 7:‏10 \xt 2 صم. 12‏:‏13؛ مت. 26‏:‏75؛ لك. 18‏:‏13. \x*  
\v 11 مَاشَا خْزَارْ، أَقَا ذ مَانْ أَيَا إِمْسَارْ، مِينْزِي ثتّْوَاسّْفُّوڭْمنْ ذِي طّْوعْ ن أَربِّي. مشْحَاڒْ إِ كنِّيوْ إِتّجَّانْ ن شْضَارثْ ذ ؤُذَافعْ ن يِيخفْ نْومْ ذ وَارْزَامْ ن ؤُقمُّومْ ذ ثِيڭّْوُوذِي ذ ثَايْرِي ذ ثُوسْمِي ذ ؤُوبّخْ! ذِي مِينْ ذِي مَا إِفّغْ-د أَقَا كنِّيوْ س إِخفْ نْومْ ذ إِمزْذَاڭنْ ذِي ثْمسْڒَاشْثْ-أَ.   
\m
\v 12 مِينْ ذ أَومْ ؤُرِيغْ، وَارْ إِدْجِي خْ سِّيبّثْ ن ونِّي إِخطَّانْ نِيغْ خْ سِّيبّثْ ن ونِّي ؤُمِي إِ ذِي إِتّْوَاڭّْ ڒْعِيبْ، مَاشَا حِيمَا أَذْ ثْبَانْ جَارْ أَومْ شْضَارثْ نْومْ إِ نشِّينْ زَّاثْ إِ وُوذمْ ن أَربِّي.  
\v 13 س ؤُينِّي أَقَا نتّْوَاسّْفوّجْ ؤُ غَارْ ؤُفوّجْ نّغْ أَقَا نْفَارّحْ س ؤُفيّضْ كْثَارْ زِي ڒفْرَاحثْ ن ثِيثُوسْ ؤُمِي أَرُّوحْ نّسْ إِتّْوَاسَّاريّحْ أَكِيذْومْ مَارَّا.  
\v 14 مِينْزِي ذِي مِينْ ذِي سّمْغَارغْ ذَايْومْ غَارسْ، أَقَا وَارْ تّْوَاسّْحشْمغْ شَا، مَاغَارْ أَمْ ذ أَومْ ننَّا ثِيذتّْ كُوڒْشِي، أَمُّو عَاوذْ إِبَانْ-د، أَقَا أَسمْغَارْ نّغْ غَارْ ثِيثُوسْ إِبدّْ خْ ثِيذتّْ.  
\v 15 أَقَا ڒحْنُونشْثْ نّسْ خَاومْ ثمَّارْنِي أَطَّاسْ ؤُمِي إِتّْفكَّارْ ذِي طَّاعثْ نْومْ مَارَّا، أَقَا ثْقبْڒمْ ث س ثِيڭّْوُوذِي ذ ثَارْجِيجِيثْ.  
\v 16 فَارْحغْ ؤُمِي زمَّارغْ أَذْ خَاومْ تّشْڒغْ ذِي مِينْ ذِي مَّا.   
\b  
\b  
\m  
\c 8
\s1 أَسْمُونِي ن صّْذَاقِي إِ إِمْقدَّاسنْ ذِي ؤُرْشَالِيمْ  
\m
\v 1 نسَّارْڭبْ إِ كنِّيوْ، أَيْثْمَاثْنغْ، أَرْضَا ن أَربِّي إِ إِمّوْشنْ إِ ثْمسْمُونِينْ ذِي مَاكِيذُونِييَا،  
\v 2 مَاغَارْ ؤُمِي خَاسنْ د-إِكَّا ؤُقدْجبْ إِمْغَارْ ن ڒْمحْنثْ نْسنْ، ثْفيّضْ ڒفْرَاحثْ نْسنْ، ؤُ أَطَّاسْ ن وَاڭْڒَا ن ثشْرِيمثْ نْسنْ إِعْذُو زّڒْضْ نْسنْ إِمْغَارنْ،  
\v 3 مِينْزِي شهّْذغْ، أَقَا عْلَاحْسَابْ جّهْذْ نْسنْ ؤُ \add عَاذْ\add* سنّجْ إِ جّهْذْ نْسنْ - ڒَامِي تّخْسنْ س وُوڒْ نْسنْ -  
\v 4 أَقَا زَاوْڭنْ أَنغْ س جّهْذْ مَاحنْذْ أَذْ شَارْشنْ ذِي أَرْضَا ن ثْسخَّارْثْ ن إِمْقدَّاسنْ. \x ◘ \xo 8:‏4 \xt ڒخ. 11‏:‏29؛ رُوم. 15‏:‏26؛ 1 كُور. 16‏:‏2؛ 2 كُور. 9‏:‏1. \x*  
\v 5 ؤُشَا نِيثْنِي وَارْ ڭِّينْ مِينْ ثُوغَا نسِّيثِيمْ \add وَاهَا\add*، مَاشَا أَقَا وْشِينْ إِخفْ نْسنْ أَمزْوَارْ إِ سِيذِيثْنغْ، خنِّي ؤُڒَا إِ نشِّينْ عْلَاحْسَابْ مِينْ إِخْسْ أَربِّي،  
\v 6 أَڒَامِي نْزَاوڭْ ثِيثُوسْ، أَمْ مَامّشْ ثُوغَا إِبْذَا قْبڒْ، حِيمَا أَذْ إِكمّڒْ غَارْومْ ؤُڒَا ذ ثشْرِيمثْ-أَ \add ن صّْذَاقِي\add*.  
\v 7 مَاشَا أَمْ مَامّشْ ثْفيّْضمْ ذِي مَارَّا - ذِي لْ-إِيمَانْ، ذڭْ وَاوَاڒْ، ذِي ثُوسّْنَا، ذِي مَارَّا شْضَارثْ، ؤُ ذِي \add ثوْهِيبْثْ ن\add* ثَايْرِي نّغْ إِ غَارْومْ إِدْجَانْ - إِتّْخصَّا أَذْ ثْفيّْضمْ عَاوذْ ذِي ثشْرِيمثْ-أَ \add ن صّْذَاقِي\add*.   
\m
\v 8 وَارْ تُّومُورغْ كنِّيوْ \add وَاهَا\add*، مَاشَا أَرزُّوغْ أَذْ قدْجْبغْ ثِيذتّْ ن ثَايْرِي نْومْ س شْضَارثْ ن إِمدُّوكَّاڒْ نْومْ \add ذِي لْ-إِيمَانْ\add*.  
\v 9 مِينْزِي أَقَا ثسّْنمْ أَرْضَا ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ، بلِّي إِذْوڒْ ذ أَمزْڒُوضْ ذِي طّْوعْ نْومْ، وَاخَّا ثُوغَا-ث س وَاڭْڒَا، حِيمَا كنِّيوْ أَذْ ثْذوْڒمْ ذ ثْوَاجَّارْ س زّڒْضْ نّسْ.  
\v 10 أَذْ كنِّيوْ وصِّيغْ مْلِيحْ - مِينْزِي مَانْ أَيَا إِ نّْفعْ نْومْ - مَاحنْذْ مِينْ ثبْذَامْ أَذْ ثنْوَامْ ذڭْ ؤُسڭّْوَاسْ إِعْذُونْ، أَذْ ث ثڭّمْ عَاوذْ.  
\v 11 كمّْڒمْ ڒخُّو س ثْمڭَّا مِينْ ثُوغَا ثنْوَامْ، كمّْڒمْ س ثْمڭَّا مِينْ ثُوغَا كنِّيوْ ثمّژْرمْ أَذْ ث ثڭّمْ عْلَاحْسَابْ مِينْ إِدْجَانْ غَارْومْ.  
\v 12 مَاشَا مَاڒَا ذِينْ مژْرِي، أَقَا إِتّْوَاجبْ عْلَاحْسَابْ مِينْ غَارسْ، وَارْ إِدْجِي عْلَاحْسَابْ مِينْ وَارْ غَارسْ إِدْجِي. \x ◘ \xo 8:‏12 \xt أَوڒن. 3‏:‏28؛ مت. 12‏:‏43؛ لك. 21‏:‏3؛ 1 بُط. 4‏:‏10. \x*  
\v 13 مِينْزِي وَارْ إِتّْڒِيقْ حِيمَا أَذْ ذِينْ ثِيڒِي ڒفْسَاسثْ إِ إِنّغْنِي ؤُ أَذْ خَاومْ ثِيڒِي ڒْمحْنثْ،  
\v 14 مَاشَا حْضَامْ أَذْ ثِيوْضمْ غَارْ ڒْمِيزَانْ ذِي ڒْوقْثْ-أَ، ؤُشَا أجّْ أَفيّضْ نْومْ أَذْ إِعمَّارْ ڒغْبنْ نْسنْ ذِي ڒْوقْثْ-أَ، أَڒَامِي أَفيّضْ نْسنْ ذِي مَانْ أَيَا أَذْ إِعمّرْ ڒغْبنْ نْومْ، حِيمَا خنِّي أَذْ يِيڒِي ڒْمِيزَانْ،  
\v 15 أَمْ مَامّشْ ثُورَا:  
\b  
\m \qt ”ونِّي إِسّْمُوننْ أَطَّاسْ،\qt*  
\m \qt وَارْ ذ أَسْ إِشطّْ شَا،\qt*  
\m \qt ذ ونِّي ثُوغَا إِيَارّْونْ ذْرُوسْ،\qt*  
\m \qt وَارْ ذَايسْ إِقِّيمْ ڒخْصصْ.“\qt* \x ◘ \xo 8:‏15 \xt ؤُف. 16‏:‏18. \x*   
\b  
\m
\v 16 مَاشَا أَقَاذِي إِ أَربِّي ونِّي إِڭِّينْ شْضَارثْ-أَ خَاومْ ذڭْ وُوڒْ ن ثِيثُوسْ،  
\v 17 مِينْزِي إِقْبڒْ ثُوثْرَا نّغْ ؤُشَا، أَمْ ثُوغَا ذَايسْ أَمْنُوسْ \add خَاومْ\add*، إِطّوّعْ مَاحنْذْ أَذْ غَارْومْ د-يَاسْ.  
\v 18 ؤُشَا نسّكّْ-د أَكِيذسْ عَاوذْ ؤُمَاثْنغْ ونِّي غَارْ إِدْجَا ؤُوقَّارْ ذِي لْ-إِنْجِيلْ ذِي مَارَّا ثِيمسْمُونِينْ،  
\v 19 ونِّي إِتّْوَافَارْزنْ زِي سِّيبّثْ-أَ س جّهْذْ زِي ثْمسْمُونِينْ مَاحنْذْ أَذْ يُويُورْ أَكِيذْنغْ أَكْ-ذ ثشْرِيمثْ-أَ نْ ضّْذَاقِي إِ إِتّْوَاڭّنْ س ثْسخَّارْثْ نّغْ إِ ؤُعُودْجِي ن أَربِّي ؤُ إِ ؤُشجّعْ إِ نشِّينْ.   
\m
\v 20 مَاشَا نْحطَّا مَاحنْذْ وَارْ ذ أَنغْ إِضدْجمْ حذْ مَاڒَا نْسيَّارْ ثَاشْرِيمثْ-أَ ن \add صّْذَاقِي\add* إِفيّْضنْ،  
\v 21 حِيمَا مِينْ ذ أَنغْ إِشْقَانْ أَذْ إِعْذُو مْلِيحْ، وَارْ إِدْجِي وَاهَا قِيبَاتْشْ إِ أَربِّي مَاشَا عَاوذْ زَّاثْ إِ إِوْذَانْ. \x ◘ \xo 8:‏21 \xt رُوم. 12‏:‏17. \x*  
\v 22 نسّكّْ عَاوذْ أَكِيذْسنْ ؤُمَاثْنغْ، ونِّي ذ أَنغْ إِسّْشَاننْ ڒبْذَا ذڭْ وَاطَّاسْ ن ثْمسْڒَايِينْ، أَقَا نتَّا إِتّْشطَّارْ، مَاشَا ڒخُّو إِتّْشطَّارْ كْثَارْ مِينْزِي نتَّا إِتّْشَاڒْ خَاومْ أَطَّاسْ.  
\v 23 مَاڒَا خنِّي ثِيثُوسْ ذ أَمْعَاشَارْ إِنُو ذ ؤُمْعَاونْ إِنُو جَارْ أَومْ، ؤُ مَاڒَا خنِّي أَيْثْمَاثْنغْ نّغْنِي أَقَا أَثنْ ذ رُّوسُولْ ن ثْمسْمُونِينْ ن ؤُعُودْجِي ن لْمَاسِيحْ،  
\v 24 أجّْ خنِّي ثَاقدْجبْثْ ن ثَايْرِي نْومْ ؤُ ن ؤُسمْغَارْ نّغْ ذَايْونْ زِي جِّيهثْ ن ثْمسْڒَايِينْ-أَ أَذْ ثفّغْ غَارْ بَارَّا زَّاثْ إِ مَارَّا ثْمسْمُونِينْ.   
\b  
\b  
\m  
\c 9
\m
\v 1 مِينْزِي حسْبغْ بلِّي نْهْڒَا مَا ؤُرِيغْ أَومْ-د خْ ثْوِيزَا إِ إِمْقدَّاسنْ، \x ◘ \xo 9:‏1 \xt ڒخ. 11‏:‏29؛ رُوم. 15‏:‏26؛ 1 كُور. 16‏:‏2؛ 2 كُور. 8‏:‏4. \x*  
\v 2 مِينْزِي سّْنغْ نّيّثْ نْومْ إِصبْحنْ مِيخفْ خَاومْ سّمْغَارغْ جَارْ إِنِّي ن مَاكِيذُونِييَا، بلِّي أَخَايَا ثُوغَا ثوْجذْ زڭْ ؤُسڭّْوَاسْ إِعْذُونْ، ؤُشَا شْضَارثْ نْومْ أَقَا ثسْفَاقْ أَزْينْ أَمقّْرَانْ.  
\v 3 مَاشَا سّكّغْ-د أَوْمَاثنْ، مَاحنْذْ أَسمْغَارْ نّغْ ذَايْومْ وَارْ إِتِّيڒِي شَا بَاطڒْ ذِي ثْمسْڒَاشْثْ-أَ، حِيمَا أَذْ ثِيڒِيمْ ثْحزّْممْ أَمْ مَامّشْ نِّيغْ،  
\v 4 حِيمَا، خْمِي كِيذِي إِ د غَا يَاسنْ إِمَاكِيذُونِييّنْ ؤُشَا أَذْ كنِّيوْ أَفنْ وَارْ ثْحزّْممْ، نشِّينْ - مَاحنْذْ وَارْ قَّارغْ شَا ’كنِّيوْ‘ - وَارْ نْغطّرْ زڭْ ؤُسمْغَارْ إِ \add زَّايْومْ\add* نسّمْغَارْ.  
\v 5 س ؤُينِّي ڭِّيغْ أَذْ تَّارغْ أَوْمَاثنْ نِّي، مَاحنْذْ أَذْ غَارْومْ د-أَسنْ ذ أَمزْوَارُو ؤُشَا أَذْ سّوْجْذنْ قْبڒْ لْبَارَاكَا \add ن صّْذَاقِي\add* ثِينِّي خْ إِتّْوَانَّا قْبڒْ إِ كنِّيوْ، أَقَا إِتّْخصَّا أَذْ ثِيڒِي \add صّذْقثْ نِّي\add* غَارْ ؤُفُوسْ أَمْ يِيشْثْ ن لْبَارَاكَا، وَارْ إِدْجِي أَخْمِي ت-إِ-د-كّْسنْ زِي ثڒْمشْثْ نْومْ س طّْمعْ.   
\m
\v 6 مَاشَا \add سْنمْ\add* دّڭَّا:  
\b  
\m \qt ”ونِّي إِ غَا إِزَارْعنْ س ثْشطَّارْثْ،\qt*  
\m \qt أَذْ إِمْجَارْ س ثَاشطَّارْثْ،\qt*  
\m \qt ؤُشَا ونِّي إِ غَا إِزَارْعنْ س ثشْرِيمثْ،\qt*  
\m \qt أَذْ إِمْجَارْ عَاوذْ س ثشْرِيمثْ.“\qt* \x ◘ \xo 9:‏6 \xt أَوڒن. 11‏:‏24؛ ڭال. 6‏:‏7. \x*   
\b  
\m
\v 7 أَذْ إِڭّْ كُوڒْ إِجّنْ أَمْ مَامّشْ إِنْوَا ذڭْ وُوڒْ نّسْ، وَارْ إِدْجِي س إِمطَّاونْ نِيغْ س ؤُغِيڒْ، مِينْزِي أَربِّي إِتّخْسْ ونِّي إِتِّيشنْ س ڒفْرَاحثْ. \x ◘ \xo 9:‏7 \xt ؤُف. 25‏:‏2؛ 35‏:‏5؛ أَعَوذ. 15‏:‏7؛ رُوم. 12‏:‏8. \x*  
\v 8 مِينْزِي أَربِّي أَقَا إِزمَّارْ أَذْ أَومْ إِوْشْ كُوڒْ أَرْضَا س ؤُفيّضْ، حِيمَا ڒبْذَا ؤُ ذِي مَارَّا أَذْ غَارْومْ يِيڒِي مِينْ ثحْذَاجمْ ؤُشَا أَذْ ثَارْنِيمْ أَطَّاسْ ذِي مَارَّا ڒْخذْمثْ إِصبْحنْ،  
\v 9 أَمْ مَامّشْ ثُورَا:  
\b  
\m \qt ”أَقَا إِبطَّا، إِوْشَا إِ إِمزْڒَاضْ،\qt*  
\m \qt ثَاسڭْذَا نّسْ ثتّْغِيمَا إِ ڒبْذَا.“\qt* \x ◘ \xo 9:‏9 \xt إِزهد. 112‏:‏9. \x*   
\b  
\m
\v 10 مَاغَارْ ونِّي إِتِّيشنْ زَّارِيعثْ إِ ونِّي إِزَارْعنْ ؤُڒَا ذ أَغْرُومْ إِ مَاشَّا، أَذْ أَومْ إِوْشْ زَّارِيعثْ نْومْ، أَذْ يَارْنِي ذَايسْ ؤُشَا أَذْ إِسّڭْمَا ڒْغِيدْجثْ ن ثْسڭْذَا نْومْ،  
\v 11 مَاحنْذْ أَذْ ثِيڒِيمْ تّجَّارمْ ذِي مَارَّا إِ مَارَّا ثَاشْرِيمثْ نِّي إِ غَا إِسّڭْمَانْ أَقَاذِي إِ أَربِّي س ؤُفُوسْ نّغْ.  
\v 12 مِينْزِي ڒْخذْمثْ ن ثْسخَّارْثْ ثَانِيثَا وَارْ ثدْجِي وَاهَا ذِي طّْوعْ ن مِينْ إِنقْصنْ إِ إِمْقدَّاسنْ، مَاشَا ثتَّاوِي عَاوذْ غَارْ وَاطَّاسْ ن ؤُقَاذِي إِ أَربِّي.  
\v 13 مِينْزِي س ثْقدْجبْثْ ن ثْسخَّارْثْ-أَ، أَقَا سّمْغَارَانْ ذِي أَربِّي مِينْزِي ثمَّارْسمْ إِخفْ نْومْ إِ شّْهَاذثْ ن ڒخْبَارْ أَصبْحَانْ ن لْمَاسِيحْ، ؤُ مِينْزِي ثْشَارْشمْ س ثشْرِيمثْ أَكِيذْسنْ ؤُ أَكْ-ذ مَارَّا.  
\v 14 نِيثْنِي أَذْ د-قَارّْبنْ \add غَارْ أَربِّي\add* س ثْژَادْجِيثِينْ إِ كنِّيوْ، س ثَايْرِي أَطَّاسْ خْ سِّيبّثْ ن ؤُفيّضْ ن أَرْضَا ن أَربِّي نِّي خَاومْ إِدْجَانْ.  
\v 15 ثْقَاذْ أَسْ إِ أَربِّي خْ ثوْهِيبْثْ نّسْ إِ وَارْ نْزمَّارْ أَذْ زَّايسْ ننْطقْ.   
\b  
\b  
\m  
\c 10
\s1 أَذَافعْ ن بُولُوسْ خْ ثْسخَّارْثْ نّسْ  
\m
\v 1 مَاشَا نشّْ بُولُوسْ سِيمَانْثْ إِنُو تّْزَاوَاڭغْ كنِّيوْ س ثمْهِينْثْ ذ ؤُوَاضعْ ن لْمَاسِيحْ، نشّْ ذ ونِّي إِدْجَانْ ذ أَسخَّايْ خْمِي حْضَارغْ، مَاشَا خْمِي غَا غَابغْ أَقَا أَيِي س ثرْيَاسْثْ،  
\v 2 أَقَا تّْزَاوَاڭغْ كنِّيوْ، خْمِي غَارْومْ د غَا يَاسغْ، نْهْڒَا مَا أَذْ تّْوَاحْصَارغْ مَاحنْذْ أَذْ مّْعَارِّيغْ - س ثرْيَاسْثْ نِّي حسّْبغْ أَقَا-ت غَارِي - أَكْ-ذ إِوْذَانْ نِّي إِحسّْبنْ أَقَا نشِّينْ ندَّارْ ذِي \add دّْنُوبْ نّغْ ن\add* أَرِّيمثْ.  
\v 3 مِينْزِي وَاخَّا نڭُّورْ ذڭْ ويْسُومْ، وَارْ نتّْمنْغِي شَا عْلَاحْسَابْ أَيْسُومْ،  
\v 4 س مِينْزِي ڒسْنَاحْ ن ؤُمنْغِي نّغْ وَارْ دْجِينْ زڭْ ويْسُومْ، مَاشَا شُّورنْ س جّهْذْ ن أَربِّي، ؤُ زَّايسْ إِ نْثَارَّا لْبُورْجَاثْ إِغوّْغنْ سَاذُو أَفُوسْ نّغْ. \x ◘ \xo 10:‏4 \xt إِرْم. 1‏:‏10؛ أَفا. 6‏:‏13‏-‏18. \x*  
\v 5 نتّْرژَّا إِخَارِّيصنْ ذ مَارَّا ڒُوعْڒَا إِڭعّْذنْ خْ ثُوسّْنَا ن أَربِّي، ؤُشَا أَذْ نْحبّسْ مَارَّا أَرَّايْ إِ طَّاعثْ ن لْمَاسِيحْ.  
\v 6 ؤُشَا نكَّارْ مَاحنْذْ أَذْ نْوبّخْ إِنِّي وَارْ إِتّطِّيعنْ، خْمِي غَا ثِيڒِي طَّاعثْ نْومْ ثكْمڒْ.   
\m
\v 7 مَا ثْخزَّارمْ غَارْ ثْمسْڒَايِينْ س وُوذمْ؟ مَاڒَا إِتِّيقّْ حذْ ذڭْ إِخفْ نّسْ بلِّي نتَّا ن لْمَاسِيحْ، إِتّْخصَّا أَذْ إِخَارّصْ عَاوذْ، بلِّي أَمْ نتَّا ن لْمَاسِيحْ، أَمنِّي عَاوذْ نشِّينْ ن لْمَاسِيحْ إِ ندْجْ.  
\v 8 معْلِيكْ نشّْ مَاڒَا سّمْغَارغْ س شْوَايْثْ ن ؤُفيّضْ كْثَارْ ذِي صُّولْطَا نّغْ ثنِّي ذ أَيِي إِوْشَا سِيذِيثْنغْ، أَذْ يِيڒِي نهْڒَا مَا أَذْ سضْحِيغْ، مَاغَارْ نتَّا إِوْشَا أَنغْ ت إِ ڒبْنِي نْومْ، وَارْ إِدْجِي إِ وَاردّدْجْ نْومْ،  
\v 9 مَاشَا سّْبعّْذغْ أَيَا، حِيمَا وَارْ إِتّْغِيڒْ إِ شَا ن إِجّْ أَقَا خْسغْ أَذْ كنِّيوْ سِّيڭّْوذغْ س ثبْرَاثْ \add إِنُو\add*.  
\v 10 مِينْزِي أَقَا ذِينْ إِنِّي إِقَّارنْ: ”ثِيبْرَاثِينْ \add نّسْ\add* قسْحنْثْ جهْذنْثْ، مَاشَا زِي جِّيهثْ ن أَرِّيمثْ إِهيّفْ، ؤُشَا أَوَاڒنْ نّسْ تّْوَاسّحْقَارنْ.“  
\v 11 ونِّي إِسَّاوَاڒنْ أَمُّو أجّْ إِ-ث أَذْ إِعْقڒْ، أَقَا، أَمْ مَامّشْ ندْجْ نشِّينْ ذڭْ وَاوَاڒْ س ثبْرَاثِينْ مَاڒَا وَارْ نحْضَارْ، أَمُّو إِ ندْجْ س ثْمڭَّا نّغْ خْمِي غَا نحْضَارْ.   
\m
\v 12 مِينْزِي وَارْ نزْعِيمْ شَا أَذْ نحْسبْ نِيغْ أَذْ نسّمْقُودَّا إِخفْ نّغْ أَكْ-ذ شَا ن يِينِّي إِسّمْغَارَانْ إِخفْ نْسنْ، مَاغَارْ ؤُمِي عْبَارنْ نِيثْنِي إِخفْ نْسنْ س يِيخفْ نْسنْ، أَقَا نِيثْنِي وَارْ فْهِيمنْ \add وَالُو\add*.\x ◘ \xo 10:‏12 \xt 2 كُور. 3‏:‏1؛ 5‏:‏12. \x*  
\v 13 مَاشَا نشِّينْ وَارْ نسّمْغَارِي شَا بَارَّا إِ ڒعْبَارْ ن ثسْغَارْثْ نّغْ، مَاشَا عْلَاحْسَابْ ڒعْبَارْ ن ثسْغَارْثْ إِ ذ أَنغْ إِوْشَا أَربِّي، حِيمَا أَذْ غَارْومْ د-نَاوضْ. \x ◘ \xo 10:‏13 \xt أَفا. 4‏:‏7. \x*  
\v 14 مِينْزِي وَارْ إِدْجِي أَمْ مَامّشْ وَارْ غَارْومْ د-نِيوضْ، مِينْزِي نسّْوِيژّضْ إِخفْ نّغْ غَارْومْ ؤُشَا نِيوضْ-د غَارْومْ س ڒخْبَارْ أَصبْحَانْ ن لْمَاسِيحْ.  
\v 15 أَقَا وَارْ نسّمْغَارْ شَا أَمْ نكَّا سنّجْ إِ ڒعْبَارْ ن ثسْغَارْثْ نّغْ، مَانِي خذْمنْ نّغْنِي، مَاشَا نسِّيثِيمْ، ؤُمِي إِمقَّارْ لْ-إِيمَانْ نْومْ، أَذْ نتّْوَاوسّعْ أَطَّاسْ زَّايْومْ عْلَاحْسَابْ ڒعْبَارْ ن ثسْغَارْثْ نّغْ،  
\v 16 حِيمَا أَذْ نْبَارّحْ س ڒخْبَارْ أَصبْحَانْ ؤُڒَا ذڭْ إِمُوشَانْ أَغِيرِينْ خَاومْ، حِيمَا وَارْ نسّمْغَارِي شَا خْ ڒعْبَارْ ن ثسْغَارْثْ ن إِنّغْنِي، خْ ڒعْبَارْ أَڒْ مَانِي إِوْضنْ نِيثْنِي.   
\m
\v 17 مَاشَا وِي إِخْسنْ أَذْ إِسّمْغَارْ، أجّْ إِ-ث أَذْ إِسّمْغَارْ ذِي سِيذِي. \x ◘ \xo 10:‏17 \xt إِشا. 65‏:‏16؛ إِرْم. 9‏:‏22‏-‏23؛ 1 كُور. 1‏:‏31. \x*  
\v 18 س مِينْزِي وَارْ إِدْجِي ونِّي إِوصَّانْ خْ يِيخفْ نّسْ، مَاشَا ونِّي خَاسْ إِوصَّا سِيذِي، أَقَا ذ ونِّي إِتّْوَافنْ ذ أَمْقدْجبْ. \x ◘ \xo 10:‏18 \xt أَوڒن. 27‏:‏2. \x*   
\b  
\b  
\m  
\c 11
\s1 پُولُوسْ ذ رُّوسُولْ إِسّْخَارِّيقنْ  
\m
\v 1 تّْزَاوْڭغْ أَكِيذِي ثصْبَارمْ شْوَايْثْ، أَمْ يِيجّْ ن ؤُبُوهَاڒِي إِ سَّاوَاڒغْ، إِوَا حمْڒمْ أَيِي.  
\v 2 مِينْزِي شطَّارغْ خَاومْ س إِشْثْ ن شْضَارثْ ن أَربِّي، مِينْزِي خضْبغْ كنِّيوْ إِ يِيجّْ ن ورْيَازْ، مَاحنْذْ أَذْ كنِّيوْ سّْقَارّْبغْ أَمْ يِيشْثْ ن ثعْزَارشْثْ ثِيزْذِيڭْ إِ لْمَاسِيحْ. \x ◘ \xo 11:‏2 \xt لَاوِي 21‏:‏13. \x*   
\m
\v 3 مَاشَا تّڭّْوذغْ، أَمْ مَامّشْ إِغْوَا ؤُفِيغَارْ حَاوَّا س ثحْرَايْمشْثْ نّسْ، أَمنِّي \add عَاوذْ\add* إِ غَا تّْوَاغْوَانْ إِخَارِّيصنْ نْومْ زِي ڒصْفَايثْ ن وشْضَارْ إِ لْمَاسِيحْ. \x ◘ \xo 11:‏3 \xt أَمز. 3‏:‏4؛ يُوح. 8‏:‏44. \x*  
\v 4 مِينْزِي مَاڒَا يُوسَا-د حذْ إِتّْبَارّحْ أَومْ س يِيجّْ ن يَاسُوع نّغْنِي خْ ونِّي خْ تّْبَارّْحغْ نشّْ، نِيغْ مَاڒَا ثْقبْڒمْ إِجّْ ن أَرُّوحْ نّغْنِي ونِّي وَارْ ثقْبِيڒمْ شَا، نِيغْ إِجّْ ن ڒخْبَارْ أَصبْحَانْ نّغْنِي ونِّي وَارْ ثطِّيفمْ شَا، أَذْ ث ثكْسِيمْ ذغْيَا. \x ◘ \xo 11:‏4 \xt ڭال. 1‏:‏8. \x*   
\m
\v 5 وَاخَّا أَمنِّي نشّْ حسّْبغْ إِخفْ إِنُو وَارْ دْجِيغْ قلّْ إِ رُّوسُولْ \add نِّي\add* ’إِمْغَارنْ أَطَّاسْ‘.  
\v 6 وَاخَّا وَارْ زمَّارغْ إِ وَاوَاڒْ، مَاشَا إِ ثُوسّْنَا زمَّارغْ، مِينْزِي ثُوغَا أَنغْ جَارْ أَومْ س بْطَايْطَايْ زِي مَارَّا إِغزْذِيسنْ. \x ◘ \xo 11:‏6 \xt 2 كُور. 5‏:‏11\x*  
\v 7 نِيغْ خْضِيغْ ؤُمِي ثُوغَا سّْوَاضْعغْ إِخفْ إِنُو، حِيمَا كنِّيوْ أَذْ تّْوَاسُّوعْڒَامْ، أَمْ ذ أَومْ بَارّْحغْ س ڒخْبَارْ أَصبْحَانْ س بْڒَا؟ \x ◘ \xo 11:‏7 \xt 1 كُور. 9‏:‏12. \x*   
\m
\v 8 أَقَا ’كشْضغْ‘ ثْمسْمُونِينْ نّغْنِي أَمْ خَاسنْثْ طّْفغْ ثَاخْڒِيصثْ، حِيمَا أَذْ سخَّارغْ إِ كنِّيوْ. \x ◘ \xo 11:‏8 \xt ڒخ. 20‏:‏33؛ 2 كُور. 12‏:‏13؛ 1 تس. 2‏:‏9؛ 2 تس. 3‏:‏8. \x*  
\v 9 ؤُشَا ؤُمِي ثُوغَا حْضَارغْ أَكِيذْومْ ؤُشَا ثُوغَا ذَايِي ڒخْصصْ، وَارْ بسّْڒغْ ؤُڒَا خْ حذْ زَّايْومْ، مَاشَا مِينْ ذ أَيِي إِخصّنْ،عمَّارنْ ث وَاوْمَاثنْ إِنِّي د يُوسِينْ زِي مَاكِيذُونِييَا. نشّْ حْضِيغْ إِخفْ إِنُو ذِي مَارَّا، مَاحنْذْ وَارْ خَاومْ تّْبسّْڒغْ، ؤُشَا أَمُّو إِ غَا قِّيمغْ حْضِيغْ إِخفْ إِنُو. \x ◘ \xo 11:‏9 \xt فِيل. 4‏:‏15. \x*  
\v 10 ثِيذتّْ ن لْمَاسِيحْ أَقَا-ث ذَايِي، أَقَا أَسمْغَارْ-أَ وَارْ ذ أَيِي إِمنّعْ ذِي جّْوَايحْ ن أَخَايَا.  
\v 11 مَايمِّي؟ مَا مِينْزِي وَارْ كنِّيوْ تّخْسغْ؟ أَربِّي إِسّنْ.   
\m
\v 12 مَاشَا مِينْ تّڭّغْ، أَذْ قِّيمغْ تّڭّغْ ث خنِّي، حِيمَا أَذْ كّْسغْ ثِيزِي ن يِينِّي يَارزُّونْ لْفُورْصَا، مَاحنْذْ نِيثْنِي، ذِي مِينْ ذِي سّمْغَارَانْ، أَذْ بَاننْ أَمْ نشِّينْ.  
\v 13 مِينْزِي نِيثْنِي ذ رُّوسُولْ إِسّْخَارِّيقنْ ذ إِخدَّامنْ إِشمَّاثنْ إِنِّي إِتّڭّنْ إِخفْ نْسنْ أَخْمِي ذ رُّوسُولْ ن لْمَاسِيحْ.  
\v 14 مَانْ أَيَا وَارْ كنِّيوْ إِتّجِّي أَذْ ثتّْبهْثمْ، مِينْزِي ؤُڒَا ذ شِّيطَانْ إِتّڭّْ إِخفْ نّسْ أَخْمِي نتَّا ذ لْمَالَاكْ ن ثْفَاوْثْ.  
\v 15 وَاخَّا أَمُّو وَارْ ثدْجِي ذ شَا ن ڒْحَاجّثْ، مَاڒَا تَّارَّانْ عَاوذْ إِمْسخَّارنْ نّسْ إِخفْ نْسنْ ذ إِمْسخَّارنْ ن ثْسڭْذَا، إِنِّي ثَانڭَّارُوثْ نْسنْ أَذْ ثِيڒِي عْلَاحْسَابْ ڒخْذَايمْ نْسنْ.   
\b  
\m  
\s1 أَودّبْ ن بُولُوسْ  
\m
\v 16 قَّارغْ إِ ؤُمُورْ نّغْنِي، ؤُڒَا ذ إِجّنْ أَذْ أَسْ إِتّْغِيڒْ أَقَا أَيِي ذ أَبُوهَاڒِي، مَاشَا مَاڒَا وَارْ إِدْجِي أَمنِّي، حسْبمْ أَيِي ذ أَبُوهَاڒِي مَاحنْذْ خنِّي عَاوذْ نشّْ أَذْ سّمْغَارغْ شْوَايْثْ.  
\v 17 مِينْ سَّاوَاڒغْ، وَارْ ث قَّارغْ زِي سِيذِيثْنغْ، مَاشَا ڭِّيغْ ث س ثُوبُّوهڒْيَا مَاحنْذْ أَذْ ؤُفِيغْ زعْمَا لْفُورْصَا إِ ؤُسمْغَارْ.  
\v 18 ؤُمِي ذِينْ أَطَّاسْ ن إِنِّي إِسّمْغَارَانْ عْلَاحْسَابْ أَيْسُومْ، ؤُڒَا ذ نشّْ ڭُّورْ أَذْ سّمْغَارغْ. \x ◘ \xo 11:‏18 \xt 2 كُور. 10‏:‏13؛ 12‏:‏5، 6. \x*  
\v 19 مِينْزِي كنِّيوْ ثَارْضَامْ أَذْ ثسْڒمْ إِ إِبُوهَاڒِييّنْ وَاخَّا كنِّيوْ ذ إِمِيغِيسنْ إِ ثدْجَامْ.  
\v 20 أَقَا ثمَّارْسمْ إِخفْ نْومْ إِ حذْ إِ إِتَّارَّانْ كنِّيوْ ذ إِسمْغَانْ، ونِّي كنِّيوْ إِتّفّْزنْ، ونِّي إِتّكّْسنْ أَومْ مِينْ غَارْومْ، ؤُ ونِّي خَاومْ إِسُّوعْڒَانْ \add إِخفْ نّسْ\add* ذ ونِّي كنِّيوْ إِسّْمدَّارْضَارنْ.  
\v 21 سَّاوَاڒغْ أَخْمِي تّْسضْحِيغْ، أَخْمِي نضْعفْ زِي سِّيبّثْ ن ثِيغِيثْ وَارْ إِدْجِينْ: مَارَّا مِينْ \add خفْ\add* زعّْمنْ نِيثْنِي \add أَذْ سّمْغَارنْ\add*، نشّْ عَاوذْ زعّْمغْ \add أَذْ سّمْغَارغْ\add*. \x ◘ \xo 11:‏21 \xt فِيل. 3‏:‏4. \x*   
\m
\v 22 مَا نِيثْنِي ذ إِعِيبْرَانِييّنْ؟ ؤُڒَا ذ نشّْ. مَا نِيثْنِي ذ إِسْرَائِيل إِيّنْ؟ ؤُڒَا ذ نشّْ. مَا نِيثْنِي ذ زَّارِيعثْ ن إِبْرَاهِيمْ؟ ؤُڒَا ذ نشّْ. \x ◘ \xo 11:‏22 \xt ڒخ. 22‏:‏3. \x*  
\v 23 مَا نِيثْنِي ذ إِمْسخَّارنْ ن لْمَاسِيحْ، نشّْ عَاذْ مَاهُو، وَاخَّا نشّْ سَّاوَاڒغْ أَمْ ونِّي إِتّْخڒْفنْ: نشّْ كْسِيغْ ثَامَارَا مَاهُو، شِّيغْ ثِييِّيثَا كْثَارْ زَّايْسنْ، ثُوغَا أَيِي ذِي ڒحْبسْ أَطَّاسْ ن إِمُورنْ كْثَارْ زَّايْسنْ ؤُشَا ژْرِيغْ ڒْموْثْ أَطَّاسْ ن ثْوَاڒَاوِينْ. \x ◘ \xo 11:‏23 \xt ڒخ. 9‏:‏16؛ 21‏:‏11؛ 1 كُور. 15‏:‏10؛ 2 كُور. 6‏:‏4. \x*  
\v 24 وْثِينْ أَيِي وُوذَاينْ خمْسَا ن ثْوَاڒَاوِينْ \add س ؤُركُّوضْ\add* س أَربْعِينْ ن ثِييِّيثَا قلّْ إِشْثْ، \x ◘ \xo 11:‏24 \xt أَعَوذ. 25‏:‏3. \x*  
\v 25 ثْڒَاثَا ن إِمُورنْ وْثِينْ أَيِي س وعْمُوذْ، إِشْثْ ن ثْوَاڒَا حجَّارنْ أَيِي، ثْڒَاثَا ن ثْوَاڒَاثِينْ يَارّژْ زَّايِي ؤُغَارَّابُو، دْجِيڒثْ ذ ؤُزِيڒْ ذ أَقتُّوسْ ثُوغَا أَيِي ذِي ڒْبُوغَازْ ن ڒبْحَارْ بْڒَا ثْغَارَّابُوثْ. \x ◘ \xo 11:‏25 \xt ڒخ. 14‏:‏19؛ 16‏:‏22؛ 27‏:‏9، 41. \x*  
\v 26 ؤُمِي ذ أَيِي ثُوغَا ذڭْ وبْرِيذْ أَطَّاسْ ن ثْوَاڒَاوِينْ ثُوغَا أَيِي ذِي لْخَاطَارْ ن إِغزْرَانْ، ذِي لْخَاطَارْ ن إِشفَّارنْ، ذِي لْخَاطَارْ ن يِينِّي ن ڒْڭنْسْ إِنُو، ذِي لْخَاطَارْ ن يِينِّي زِي ڒڭْنُوسْ نّغْنِي، ذِي لْخَاطَارْ ذِي ثنْذِينْثْ، ذِي لْخَاطَارْ ذِي ڒخْڒَا، ذِي لْخَاطَارْ خْ ڒبْحَارْ، ذِي لْخَاطَارْ س وَاوْمَاثنْ إِسّْخَارِّيقنْ،  
\v 27 \add ذِي لْخَاطَارْ\add* ذِي ڒْخذْمثْ، ذِي ثَامَارَا، ؤُمِي ذَايِي ثُوغَا ذِي دْجْيَاڒِي بْڒَا إِضصْ أَطَّاسْ ن ثْوَاڒَاوِينْ، ذِي ڒَاژْ ذ ؤُفَاذِي، ذڭْ ؤُژُومِّي أَطَّاسْ، ؤُمِي ذَايِي ثُوغَا ذِي ثسْمضْ ذ ثُوعَارْينْثْ،  
\v 28 ؤُشَا عَاذْ وَارْ سِّيوْڒغْ شَا خْ وَاطَّاسْ ن ثْمسْڒَايِينْ نّغْنِي، نِيغْ خْ ڒْهمّْ إِنُو ن كُوڒْ أَسّْ خْ ثْمسْمُونِينْ ؤُڒَا خْ ومْنُوسْ نِّي خَافِي إِ مَارَّا ثِيمسْمُونِينْ. \x ◘ \xo 11:‏28 \xt ڒخ. 20‏:‏18. \x*  
\v 29 مَاڒَا إِضْعفْ حذْ، مَا وَارْ تِّيڒِيغْ ؤُڒَا ذ نشّْ ضعْفغْ؟ مَاڒَا إِخيّقْ حذْ زِي شَا ن ؤُنذْرفْ، مَا نشّْ وَارْ شمّْضغْ؟ \x ◘ \xo 11:‏29 \xt 1 كُور. 8‏:‏13. \x*   
\m
\v 30 مَاڒَا إِتّْخصَّا أَذْ إِتّْوَاسّمْغَارْ، أَذْ سّمْغَارغْ ذِي ثُوضْعفْثْ إِنُو.  
\v 31 أَربِّي، بَابَاسْ ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ - ونِّي إِتّْوَابَارْكنْ إِ ڒبْذَا قَاعْ - إِسّنْ أَقَا نشّْ وَارْ سّْخَارِّيقغْ شَا. \x ◘ \xo 11:‏31 \xt رُوم. 1‏:‏9؛ 9‏:‏1؛ 2 كُور. 1‏:‏23؛ ڭال. 1‏:‏20؛ فِيل. 1‏:‏8؛ 1 تس. 2‏:‏5. \x*  
\v 32 ڒْقبْطَانْ ن ڒْعسْكَارْ ن ؤُجدْجِيذْ أَرِيثَاسْ ذِي ذِيمَاشْقْ ثُوغَا إِحطَّا ثَانْذِينْثْ ن إِذِيمَاشْقِييّنْ، يَارزُّو أَذْ أَيِي إِطّفْ، \x ◘ \xo 11:‏32 \xt ڒخ. 9‏:‏24. \x*  
\v 33 \add مَاشَا\add* سّكّنْ أَيِي-د زڭْ إِجّْ ن ڒْكَازِي، سّهْوَانْ أَيِي-د زِي ڒْحِيضْ ذڭْ إِجّْ ن ؤُقْبُوبْ، أَروْڒغْ زڭْ إِفَاسّنْ نّسْ.   
\b  
\b  
\m  
\c 12
\s1 ڒوْحِييْ ن بُولُوسْ  
\m
\v 1 مَاڒَا إِتّْخصَّا أَذْ ذِينْ يِيڒِي ؤُسمْغَارْ، وَاخَّا مَانْ أَيَا وَارْ إِنفّعْ شَا، معْلِيكْ ؤُفِيغْ أَذْ إِوْضغْ نشّْ غَارْ إِوحَّانْ ذ إِسَارْڭَابنْ ن سِيذِيثْنغْ.  
\v 2 أَقَا سّْنغْ إِجّْ ن بْنَاذمْ ذِي لْمَاسِيحْ، ثُوغَا كْثَارْ زڭْ أَرْبعْطَاشْ ن إِسڭّْوُوسَا زڭْ وَامِي، مَا ثُوغَا ذِي أَرِّيمثْ نِيغْ بَارَّا إِ أَرِّيمثْ، وَارْ سِّينغْ شَا، أَربِّي إِسّنْ! \add بْنَاذمْ\add* نِّي إِمّكْسِي غَارْ ؤُجنَّا وِيسّْ ثْڒَاثَا. \x ◘ \xo 12:‏2 \xt ڒخ. 9‏:‏3؛ 22‏:‏17؛ 1 كُور. 15‏:‏8. \x*  
\v 3 ؤُشَا سّْنغْ بْنَاذمْ-أَ، مَا ثُوغَا ذِي أَرِّيمثْ نِيغْ بْڒَا أَرِّيمثْ، وَارْ سِّينغْ شَا، أَربِّي إِسّنْ.  
\v 4 \add بْنَاذمْ\add* نِّي إِمّكْسِي غَارْ جّنّثْ مَانِي إِسْڒَا أَوَاڒنْ نِّي وَارْ إِزمَّارْ أَذْ تّْوَانطْقنْ، إِنِّي وَارْ إِحدْجْڒنْ إِ بْنَاذمْ أَذْ ثنْ إِنْطقْ.  
\v 5 زڭْ بْنَاذمْ نِّي أَذْ سّمْغَارغْ، مَاشَا وَارْ سّمْغَارِيغْ شَا ذڭْ إِخفْ إِنُو، مْغِيرْ ذڭْ وضْعَافْ إِنُو.   
\m
\v 6 مَاشَا مَاڒَا خْسغْ أَذْ سّمْغَارغْ، وَارْ تِّيڒِيغْ ذ أَبُوهَاڒِي، مِينْزِي أَذْ إِنِيغْ ثِيذتّْ. مَاشَا أَذْ ث جّغْ حِيمَا ؤُڒَا ذ إِجّْ وَارْ خَافِي إِتّْخَارَّاصْ مَامّشْ دْجِيغْ سنّجْ مِينْ زَّايِي إِژْرَا نِيغْ سنّجْ مِينْ زَّايِي إِسْڒَا.  
\v 7 حِيمَا وَارْ سّْڭِيعّْذغْ شَا إِخفْ إِنُو زِي سِّيبّثْ ن طّْبِيعثْ يُوعْڒَانْ ن إِسَارْڭَابنْ \add نِّي\add*، إِمّوْشْ أَيِي إِجّْ ن ؤُسنَّانْ ذڭْ ويْسُومْ \add ن أَرِّيمثْ\add*، أَقَا-ث إِجّْ ن لْمَالَاكْ ن شِّيطَانْ إِ ذ أَيِي إِشَّاثنْ س ڒْپُونِييَّاثْ مَاحنْذْ وَارْ تّسْڭعِّيذغْ شَا إِخفْ إِنُو.  
\v 8 ثْڒَاثَا ن ثْوَاڒَاوِينْ تَّارغْ سِيذِي إِنُو، مَاحنْذْ أَذْ ث خَافِي إِسّڭّْوجْ،  
\v 9 \add مَاشَا\add* نتَّا إِنَّا أَيِي: ”أَقَا أَرْضَا إِنُو إِشْفَا، مِينْزِي جّهْذْ إِنُو إِتّْوَاكمّڒْ ذِي ثُوضْعفْثْ!“ س ؤُينِّي أَقَا مْلِيحْ مَاڒَا سّمْغَارغْ ذِي ثُوضْعفْثْ إِنُو، حِيمَا أَذْ خَافِي يَارْسَا جّهْذْ ن لْمَاسِيحْ.  
\v 10 س ؤُينِّي أَرْضِيغْ س ثُوضْعفْثْ، س ڒفْضِيحثْ، ذِي ڒغْبنْ، ذڭْ ؤُذَارّشْ، ذِي ڒحْصَارثْ ذِي طّْوعْ ن لْمَاسِيحْ، مِينْزِي خْمِي تِّيڒِيغْ ضعْفغْ، ڒخْذنِّي تِّيڒِيغْ جهّْذغْ.   
\b  
\m  
\s1 ثَايْرِي ن بُولُوسْ إِ ڒْمُومِينِينْ ذِي كُورِينْثُوسْ  
\m
\v 11 خْزَارْ، ذوْڒغْ ذ أَبُوهَاڒِي ؤُمِي ڭِّيغْ أَذْ سّمْغَارغْ ذڭْ يِيخفْ إِنُو، \add مَاشَا\add* كنِّيوْ ثحْصَارمْ أَيِي غَارسْ. مِينْزِي ثُوغَا إِتّْخصَّا إِ كنِّيوْ أَذْ أَيِي ثْقدَّارمْ، أَقَا وَارْ دْجِيغْ قلّْ ؤُڒَا ذڭْ إِشْثْ ن ڒْحَاجّثْ زِي رُّوسُولْ نِّي ’إِمْغَارنْ أَطَّاسْ‘، وَاخَّا نشّْ ذ وَالُو. \x ◘ \xo 12:‏11 \xt 1 كُور. 15‏:‏10. \x*  
\v 12 ڭِّيغْ جَارْ أَومْ ڒعْڒَامَاثْ ن رَّاسُولْ س مَارَّا صّْبَارْ، س ثْمڭَّا إِجّهْذنْ، س لْمُوعْجِيزَاثْ ؤُ س ڒعْجَايبْ.\x ◘ \xo 12:‏12 \xt 1 كُور. 9‏:‏2. \x*  
\v 13 مَاغَارْ مِينْ ذِي ثْذوْڒمْ غَارْ ضفَّارْ خْ ثْمسْمُونِينْ إِنّغْنِي، مْغِيرْ ذِي مِينْ ذِي نشّْ وَارْ خَاومْ بسّْڒغْ وَاهَا؟ سَامْحمْ أَيِي خْ ڒْفَارْزْ-أَ! \x ◘ \xo 12:‏13 \xt 1 كُور. 9‏:‏12؛ 2 كُور. 11‏:‏9. \x*   
\m
\v 14 خْزَارْ، ڒخُّو ذ ثْوَاڒَا وِيسّْ ثْڒَاثَا أَقَا أَيِي وجْذغْ حِيمَا أَذْ غَارْومْ د-أَسغْ ؤُشَا وَارْ خَاومْ تّْبسِّيڒغْ، مِينْزِي وَارْ أَرزُّوغْ مِينْ نْومْ، مَاشَا \add أَرزُّوغْ\add* خَاومْ كنِّيوْ. مِينْزِي وَارْ د-ثُوسِي إِ إِحنْجِيرنْ أَذْ خمّْڒنْ ڒكْنُوزْ إِ لْوَالِيذِينْ نْسنْ، مَاشَا لْوَالِيذِينْ إِ إِحنْجِيرنْ نْسنْ. \x ◘ \xo 12:‏14 \xt ڒخ. 20‏:‏33. \x*  
\v 15 وجْذغْ س ڒفْرَاحثْ أَذْ خدْجْصغْ ڒحْسَابْ مَارَّا، ؤُ أَذْ سبّْڒغْ إِخفْ إِنُو ذِي طّْوعْ ن ڒعْمُورْ نْومْ، عَاذْ مَاڒَا طّْفغْ زَّايْومْ ثَايْرِي قلّْ مَاڒَا وْشِيغْ أَومْ ثَايْرِي س وَاطَّاسْ. \x ◘ \xo 12:‏15 \xt 2 كُور. 6‏:‏12. \x*   
\m
\v 16 مَاشَا أَذْ ثَاغْ، وَاخَّا نشّْ وَارْ خَاومْ تّْبسِّيڒغْ، أَقَا طّْفغْ كنِّيوْ س ثحْرَايْمشْثْ أَمْ يِيجّْ ن ورْيَازْ أَقدَّاشْ؟  
\v 17 نِيغْ أَذْ ثَاغْ مژْرغْ ذِي شَا زَّايْومْ س شَا ن إِجّْ نّغْنِي إِ ثُوغَا غَارْومْ د-سّكّغْ؟  
\v 18 خْمِي تَّارغْ ثِيثُوسْ ؤُ سّكّغْ-د أَكِيذسْ ثَاوْمَاثْ، مَا يَارْزُو ثِيثُوسْ شَا زَّايْومْ \add ذِي ثِيزِي نّسْ\add*؟ مَا وَارْ نُويُورْ شَا س أَرُّوحْ ذ إِجّنْ ذ إِصُورَافْ ذ إِجّنْ؟   
\m
\v 19 مَا إِتّْغِيڒْ أَومْ عَاوذْ بلِّي نشِّينْ نسْڒقَّا خْ يِيخفْ نّغْ زَّايْومْ؟ أَقَا قِيبَاتْشْ إِ أَربِّي ذِي لْمَاسِيحْ إِ نسَّاوَاڒْ ؤُشَا مَانْ أَيَا مَارَّا، \add أَ\add* إِمْعِيزّنْ إِنُو، ذِي طّْوعْ ن ڒبْنِي نْومْ.  
\v 20 مِينْزِي أَقَا تّڭّْوذغْ، خْمِي د غَا يَاوْضغْ غَارْومْ، أَذْ ثَاغْ وَارْ كنِّيوْ تِّيفغْ شَا أَمْ مَامّشْ خْسغْ، ؤُڒَا وَارْ ذ أَيِي ثتِّيفمْ شَا أَمْ مَامّشْ ثخْسمْ كنِّيوْ، بَالَاكْ أَذْ إِڒِينْ إِمْشُوبّشنْ، ڒحْسذْ، ثَافْقحْثْ، ثَاغنَّانْثْ، ثَاخْبَارْجشْثْ، أَخوّجْ، نّْفَاخثْ ؤُڒَا ذ إِخَارْوِيضنْ،  
\v 21 خْمِي د غَا يَاوْضغْ غَارْومْ ثْوَاڒَا نّغْنِي، أَذْ ثَاغْ أَربِّي أَذْ أَيِي إِسّْوَاضعْ ؤُشَا أَذْ شضْنغْ خْ وَاطَّاسْ ن يِينِّي إِخْضَانْ، وَارْ ثُوبنْ شَا زِي ڒخْمجْ ذ فَارْقْ-شّْغڒْ ذ ؤُفُوشّحْ إِ ڭِّينْ.   
\b  
\b  
\m  
\c 13
\s1 أَعْڒَامْ أَنڭَّارُو ذ ؤُسدْجمْ  
\m
\v 1 أَقَا ثَا ذ ثْوَاڒَا وِيسّْ ثْڒَاثَا أَذْ غَارْومْ د-أَسغْ. ”خْ ؤُقمُّومْ ن ثْنَاينْ نِيغْ ثْڒَاثَا ن ڒشْهُوذْ أَذْ إِتّْوَاضْمنْ مَارَّا وَاوَاڒْ!“ \x ◘ \xo 13:‏1 \xt ڒخْڒ. 35‏:‏30؛ أَعَوذ. 17‏:‏6؛ 19‏:‏5؛ مت. 18‏:‏16؛ يُوح. 8‏:‏17؛ عبر. 10‏:‏28. \x*  
\v 2 نِّيغْ ت قْبڒْ ؤُشَا أَذْ أَومْ ت إِنِيغْ قْبڒْ عَاوذْ، أَخْمِي ت نِّيغْ ڒَامِي ذ أَيِي ثُوغَا أَكِيذْومْ وِيسّْ مَارْثَاينْ، ؤُشَا عَاوذْ ڒخُّو، ؤُمِي غَابغْ، تَّارِيغْ ت إِ يِينِّي إِخْضَانْ ؤُ إِ مَارَّا إِنّغْنِي، أَقَا، مَاڒَا ؤُسِيغْ-د ثْوَاڒَا نّغْنِيثْ، وَارْ أَرحّْمغْ شَا.  
\v 3 مِينْزِي كنِّيوْ ثَارزُّومْ لْبُورْهَانْ بلِّي أَقَا لْمَاسِيحْ إِ ذ أَيِي إِسَّاوَاڒنْ، ونِّي وَارْ إِضْعِيفنْ ذَايْومْ، مَاشَا أَقَا إِجْهذْ ذَايْومْ.  
\v 4 وَاخَّا نتَّا إِتّْوَاصلّبْ ذِي ثُوضْعفْثْ، أَقَا إِدَّارْ س جّهْذْ ن أَربِّي. ؤُڒَا ذ نشِّينْ أَقَا نضْعفْ أَكِيذسْ، مَاشَا أَذْ كِيسْ ندَّارْ زِي جّهْذْ ن أَربِّي إِ ذَايْومْ إِدْجَانْ.   
\m
\v 5 قدْجْبمْ إِخفْ نْومْ، مَا أَقَا كنِّيوْ ثتّْبدَّامْ ذِي لْ-إِيمَانْ، أَرْزُومْ ڒعْمُورْ نْومْ. نِيغْ وَارْ ثسِّينمْ شَا بلِّي يَاسُوع لْمَاسِيحْ أَقَا-ث ذَايْومْ، ؤُ مَاڒَا وَارْ إِدْجِي أَمنِّي، أَقَا كنِّيوْ ثمّنْضَارمْ؟ \x ◘ \xo 13:‏5 \xt 1 كُور. 11‏:‏28. \x*  
\v 6 مَاشَا سِّيثِيمغْ أَذْ ثسّْنمْ، بلِّي وَارْ نمّنْضَارْ.  
\v 7 تّتَّارغْ أَربِّي، مَاحنْذْ وَارْ ذَايْومْ ثتّْوِيفْ ؤُڒَا ذ إِشْثْ ن ڒْحَاجّثْ ذ ثَاعفَّانْثْ، حِيمَا أَذْ د-ثْبَانْ ثْقدْجبْثْ نّغْ ؤُشَا كنِّيوْ ثتّڭّمْ مِينْ إِدْجَانْ ذ أَصبْحَانْ، وَاخَّا نشِّينْ نْبَانْ أَخْمِي نمّنْضَارْ.  
\v 8 مِينْزِي نشِّينْ وَارْ نْزمَّارْ وَالُو ضِيدّْ إِ ثِيذتّْ، مَاشَا إِ ثِيذتّْ وَاهْ.  
\v 9 مِينْزِي نشِّينْ نْفَارّحْ، ڒَامِي نضْعفْ ؤُ كنِّيوْ ثْجهْذمْ. ؤُشَا نتّْژَادْجْ عَاوذْ أَذْ ثِيڒِيمْ ثْكمّْڒمْ.  
\v 10 س ؤُينِّي تَّارِيغْ \add أَومْ-د\add* مَانْ أَيَا أَمْ غَابغْ، مَاحنْذْ، خْمِي د غَا يَاسغْ، إِتّْخصَّا وَارْ تّقْسِيحغْ شَا عْلَاحْسَابْ صُّولْطَا إِ ذ أَيِي إِوْشَا سِيذِي إِنُو إِ ڒبْنِي، وَارْ إِدْجِي إِ وَاردّدْجْ. \x ◘ \xo 13:‏10 \xt 2 كُور. 10‏:‏8. \x*   
\b  
\m
\v 11 زِي سَّا ذ ثْسَاونْثْ، \add أَ\add* أَيْثْمَا، إِڒِيمْ ثْفَارّْحمْ ذ ثْكمّْڒمْ، إِڒِيمْ ثتّْفوّْجمْ، خَارّْصمْ س يِيجّْ ن ؤُخَارّصْ، ؤُشَا جّمْ أَذْ ذِينْ ثِيڒِي ڒْهُوذْنثْ جَارْ أَومْ، \add خنِّي\add* أَذْ كِيومْ يِيڒِي أَربِّي ن ثَايْرِي ذ ڒهْنَا. \x ◘ \xo 13:‏11 \xt رُوم. 12‏:‏16، 18؛ 15‏:‏5؛ 1 كُور. 1‏:‏10؛ فِيل. 2‏:‏2؛ عبر. 12‏:‏14؛ 1 بُط. 3‏:‏8\x*   
\m
\v 12 سدْجْممْ إِجّنْ خْ ونّغْنِي س ڒهْنَا س ؤُسُوذمْ إِقدّْسنْ. \x ◘ \xo 13:‏12 \xt رُوم. 16‏:‏16؛ 1 كُور. 16‏:‏20؛ 1 تس. 5‏:‏26؛ 1 بُط. 5‏:‏14. \x*   
\m
\v 13 مَارَّا إِمْقدَّاسنْ تّْسدْجَامنْ خَاومْ س ڒهْنَا.   
\m
\v 14 ڒهْنَا ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ ذ ثَايْرِي ن أَربِّي ذ ثْمُونْثْ ن أَرُّوحْ إِقدّْسنْ أَذْ إِڒِينْ أَكِيذْومْ مَارَّا. أَمِينْ.   