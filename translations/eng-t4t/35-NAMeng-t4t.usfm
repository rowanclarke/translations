\mt2 This book contains the account of Nahum foretelling about Nineveh and the Assyrian people being destroyed. We call this book  
\mt1 Nahum  
\c 1  
\p
\v 1  \add I am\add* \w Nahum|strong="H5151"\w*, from Elkosh \add village\add*. \add This is\add* \w a|strong="H3068"\w* \w message|strong="H4853"\w* \w about|strong="H4853"\w* \w Nineveh|strong="H5210"\w* \add city, the capital of Assyria that was given\add* \w to|strong="H5612"\w* me \w in|strong="H5612"\w* \w a|strong="H3068"\w* \w vision|strong="H2377"\w* \add by Yahweh\add*.   
\s1 Yahweh is angry with the people of Nineveh  
\q1
\v 2 \w Yahweh|strong="H3068"\w* \w our|strong="H3068"\w* \w God|strong="H3068"\w* ◄\w is|strong="H3068"\w* \w jealous|strong="H7072"\w*/\w does|strong="H3068"\w* not want \w people|strong="H6862"\w* \w to|strong="H3068"\w* worship \w any|strong="H5201"\w* other \w god|strong="H3068"\w*►.  
\q2 \w He|strong="H1931"\w* \w is|strong="H3068"\w* very \w angry|strong="H2534"\w* \add with those who worship other gods\add*,  
\q1 \w and|strong="H3068"\w* \w he|strong="H1931"\w* gets \w revenge|strong="H5358"\w* [DOU] \add on all\add* \w those|strong="H1931"\w* \w who|strong="H1931"\w* oppose \w him|strong="H1931"\w* [DOU].   
\q1
\v 3 \w Yahweh|strong="H3068"\w* \w does|strong="H3808"\w* \w not|strong="H3808"\w* quickly become angry;  
\q2 \w but|strong="H3808"\w* \w he|strong="H3068"\w* \w is|strong="H3068"\w* \w very|strong="H1419"\w* \w powerful|strong="H3581"\w*,  
\q1 \w and|strong="H3068"\w* \w he|strong="H3068"\w* \w will|strong="H3068"\w* \w certainly|strong="H3808"\w* punish [LIT] those \w who|strong="H3068"\w* \w have|strong="H3068"\w* done evil \w things|strong="H1419"\w* [MTY].  
\q1 \w He|strong="H3068"\w* shows \w his|strong="H3068"\w* \w power|strong="H3581"\w* \w by|strong="H3068"\w* sending \w whirlwinds|strong="H5492"\w* \w and|strong="H3068"\w* storms,  
\q2 \w and|strong="H3068"\w* \w clouds|strong="H6051"\w* \w are|strong="H3068"\w* \add like\add* [MET] \w the|strong="H3068"\w* dust \add stirred up by\add* \w his|strong="H3068"\w* \w feet|strong="H7272"\w*.   
\q1
\v 4 When \w he|strong="H3605"\w* commands oceans \w and|strong="H3220"\w* \w rivers|strong="H5104"\w* \w to|strong="H3220"\w* \w become|strong="H2717"\w* \w dry|strong="H3001"\w*,  
\q2 \w they|strong="H3605"\w* \w dry|strong="H3001"\w* \w up|strong="H3001"\w*.  
\q1 \add He causes the grass in the fields in\add* \w the|strong="H3605"\w* \w Bashan|strong="H1316"\w* \add region\add* \w and|strong="H3220"\w* \add on the slopes of\add* \w Carmel|strong="H3760"\w* \add Mountain\add* \w to|strong="H3220"\w* \w wither|strong="H3001"\w*,  
\q2 \add and causes\add* \w the|strong="H3605"\w* \w flowers|strong="H6525"\w* \w in|strong="H3220"\w* \w Lebanon|strong="H3844"\w* \w to|strong="H3220"\w* fade.   
\q1
\v 5 \w When|strong="H4480"\w* \w he|strong="H3605"\w* appears, \add it is as though\add* \w the|strong="H3605"\w* \w mountains|strong="H2022"\w* \w shake|strong="H7493"\w* \w and|strong="H6440"\w* \w the|strong="H3605"\w* \w hills|strong="H1389"\w* \w melt|strong="H4127"\w*;  
\q2 \w the|strong="H3605"\w* earth \w quakes|strong="H7493"\w* \w and|strong="H6440"\w* \add the people on\add* \w the|strong="H3605"\w* earth \w tremble|strong="H7493"\w*.   
\q1
\v 6 \w There|strong="H5975"\w* \w is|strong="H4310"\w* \w no|strong="H4480"\w* \w one|strong="H4480"\w* [RHQ] \w who|strong="H4310"\w* \w can|strong="H4310"\w* \w resist|strong="H5975"\w* \w him|strong="H6440"\w* \w when|strong="H4480"\w* \w he|strong="H4480"\w* becomes extremely \w angry|strong="H2534"\w*;  
\q2 \w there|strong="H5975"\w* \w is|strong="H4310"\w* \w no|strong="H4480"\w* \w one|strong="H4480"\w* [RHQ] \w who|strong="H4310"\w* \w can|strong="H4310"\w* \w survive|strong="H6965"\w* \w when|strong="H4480"\w* \w his|strong="H6440"\w* \w anger|strong="H2534"\w* \w is|strong="H4310"\w* very \w hot|strong="H2534"\w*.  
\q1 \w When|strong="H4480"\w* \w he|strong="H4480"\w* \w is|strong="H4310"\w* very \w angry|strong="H2534"\w*, \add it is as though\add* \w his|strong="H6440"\w* \w anger|strong="H2534"\w* \w is|strong="H4310"\w* \w like|strong="H2534"\w* [SIM] \w a|strong="H3068"\w* blazing fire,  
\q2 \w and|strong="H6965"\w* \add it is as though\add* mountains \w are|strong="H4310"\w* shattered \w into|strong="H4480"\w* pieces.   
\b  
\q1
\v 7 \w But|strong="H3068"\w* \w he|strong="H3117"\w* \w is|strong="H3068"\w* \w good|strong="H2896"\w*;  
\q2 \w he|strong="H3117"\w* \w protects|strong="H4581"\w* \add us his people\add* \w when|strong="H3117"\w* \w we|strong="H3068"\w* \w experience|strong="H3045"\w* \w troubles|strong="H6869"\w*.  
\q1 \w He|strong="H3117"\w* \w takes|strong="H2620"\w* care \w of|strong="H3068"\w* those \w who|strong="H3068"\w* \w trust|strong="H2620"\w* \w in|strong="H3068"\w* \w him|strong="H3045"\w*.   
\q1
\v 8 \w But|strong="H7291"\w* \w he|strong="H6213"\w* \w will|strong="H4725"\w* \w get|strong="H6213"\w* rid \w of|strong="H4725"\w* \w his|strong="H6213"\w* enemies;  
\q2 \w he|strong="H6213"\w* \w will|strong="H4725"\w* \w be|strong="H7291"\w* \w to|strong="H6213"\w* \w them|strong="H6213"\w* \add like\add* [MET] \w a|strong="H3068"\w* \w flood|strong="H7858"\w* \w that|strong="H6213"\w* destroys everything.  
\q1 \w He|strong="H6213"\w* \w will|strong="H4725"\w* \w chase|strong="H7291"\w* \w his|strong="H6213"\w* enemies  
\q2 \w into|strong="H6213"\w* \w the|strong="H6213"\w* \w darkness|strong="H2822"\w* \add of the place where the dead are\add*.   
\b  
\q1
\v 9  \add So\add*, \w it|strong="H1931"\w* \w is|strong="H3068"\w* \w useless|strong="H3808"\w* [RHQ] \w for|strong="H6213"\w* \w you|strong="H6213"\w* \add people of Nineveh\add* \w to|strong="H3068"\w* \w plot|strong="H2803"\w* \w against|strong="H6965"\w* \w Yahweh|strong="H3068"\w*.  
\q2 \w He|strong="H1931"\w* \w will|strong="H3068"\w* \w not|strong="H3808"\w* \add need to\add* strike \w you|strong="H6213"\w* \w two|strong="H6213"\w* \w times|strong="H6471"\w* \w to|strong="H3068"\w* \w destroy|strong="H6213"\w* \w you|strong="H6213"\w*;  
\q2 \w he|strong="H1931"\w* \w will|strong="H3068"\w* \w destroy|strong="H6213"\w* \w you|strong="H6213"\w* \add by striking you only once\add*.   
\q1
\v 10  \add It will be as though his enemies\add* \w are|strong="H4390"\w* \w tangled|strong="H5440"\w* \w in|strong="H5518"\w* \w thorns|strong="H5518"\w*,  
\q2 \w and|strong="H5704"\w* \w they|strong="H3588"\w* \w will|strong="H5704"\w* stagger \w like|strong="H5704"\w* people \w who|strong="H3588"\w* \w have|strong="H3588"\w* drunk \w a|strong="H3068"\w* lot \w of|strong="H4390"\w* \w wine|strong="H5435"\w*.  
\q2 \w They|strong="H3588"\w* \w will|strong="H5704"\w* \w be|strong="H3588"\w* burned \w up|strong="H5704"\w* \w like|strong="H5704"\w* [SIM] \w a|strong="H3068"\w* fire \w completely|strong="H5704"\w* burns \w up|strong="H5704"\w* \w stubble|strong="H7179"\w*/\w straw|strong="H7179"\w*.   
\b  
\q1
\v 11 \w In|strong="H5921"\w* Nineveh \add city\add* \w there|strong="H4480"\w* \w was|strong="H3068"\w* \w a|strong="H3068"\w* \w man|strong="H7451"\w* \w who|strong="H3068"\w* \w advised|strong="H3289"\w* people \w to|strong="H3318"\w* \w do|strong="H3068"\w* very \w wicked|strong="H7451"\w* \w things|strong="H7451"\w* \w to|strong="H3318"\w* \w Yahweh|strong="H3068"\w*.   
\p
\v 12 \w But|strong="H3808"\w* \w this|strong="H3651"\w* \w is|strong="H3068"\w* \w what|strong="H3541"\w* \w Yahweh|strong="H3068"\w* \w says|strong="H3541"\w* \add about you Israeli people\add*:  
\q1 “\w Although|strong="H3808"\w* \w the|strong="H3541"\w* \w people|strong="H3808"\w* \w of|strong="H3068"\w* Assyria \w have|strong="H3068"\w* \w very|strong="H3651"\w* \w many|strong="H7227"\w* \w people|strong="H3808"\w* \w and|strong="H3068"\w* \w their|strong="H3068"\w* army \w is|strong="H3068"\w* \w very|strong="H3651"\w* \w powerful|strong="H7227"\w*,  
\q2 \w they|strong="H3651"\w* \w will|strong="H3068"\w* \w be|strong="H3808"\w* destroyed \w and|strong="H3068"\w* \w will|strong="H3068"\w* disappear.  
\q1 \add I say to my people in Judah,\add*  
\q2 ‘ \w have|strong="H3068"\w* \add already\add* punished \w you|strong="H3808"\w*,  
\q2 \w but|strong="H3808"\w* \w I|strong="H3541"\w* \w will|strong="H3068"\w* \w not|strong="H3808"\w* punish \w you|strong="H3808"\w* \w again|strong="H5750"\w*.   
\q1
\v 13 \w Now|strong="H6258"\w* \w I|strong="H5921"\w* will cause \w the|strong="H5921"\w* \add people of Assyria\add* \w to|strong="H5921"\w* no longer control/oppress \w you|strong="H5921"\w* [MET];  
\q2 \add it will be as though\add* \w I|strong="H5921"\w* will \w tear|strong="H5423"\w* \w off|strong="H5921"\w* \w the|strong="H5921"\w* \w shackles|strong="H4147"\w*/\w chains|strong="H4147"\w* \w on|strong="H5921"\w* \w your|strong="H5921"\w* \add hands and feet\add*.”   
\b  
\q1
\v 14  \add And this is what\add* \w Yahweh|strong="H3068"\w* \w also|strong="H3068"\w* declares \w about|strong="H5921"\w* \w you|strong="H3588"\w* \w people|strong="H3808"\w* \w of|strong="H1004"\w* Nineveh:  
\q2 “\w You|strong="H3588"\w* \w will|strong="H3068"\w* \w not|strong="H3808"\w* \w have|strong="H3068"\w* \w any|strong="H5750"\w* descendants \w who|strong="H3068"\w* \w will|strong="H3068"\w* \w continue|strong="H5750"\w* \w to|strong="H3068"\w* \w have|strong="H3068"\w* \w your|strong="H3068"\w* \w family|strong="H1004"\w* \w names|strong="H8034"\w*.  
\q1 \w And|strong="H3068"\w* \w I|strong="H3588"\w* \w will|strong="H3068"\w* \w destroy|strong="H3772"\w* \w all|strong="H3772"\w* \w the|strong="H5921"\w* statues \w of|strong="H1004"\w* \w your|strong="H3068"\w* gods  
\q2 \w that|strong="H3588"\w* \w were|strong="H1004"\w* \w carved|strong="H6459"\w* \w or|strong="H3808"\w* \w formed|strong="H7760"\w* \w in|strong="H5921"\w* molds.  
\q1 \w I|strong="H3588"\w* \w will|strong="H3068"\w* cause \w you|strong="H3588"\w* \add to be killed and\add* \w sent|strong="H6680"\w* \w to|strong="H3068"\w* \w your|strong="H3068"\w* \w graves|strong="H6913"\w*,  
\q2 \w because|strong="H3588"\w* \w you|strong="H3588"\w* \w are|strong="H3068"\w* \w vile|strong="H7043"\w*/despicable!”   
\b  
\q1
\v 15  \add You people of Judah,\add* look! \w A|strong="H3068"\w* messenger will be coming across the mountains,  
\q2 and he [SYN] will be bringing good news \add to you\add*.  
\q2 He will be declaring \add that you will now have\add* peace \add because Assyria will have been conquered\add*.  
\q1 \add So,\add* celebrate your festivals,  
\q2 and do what you solemnly promised to do \add when your enemies were threatening to attack you\add*,  
\q1 because your wicked \add enemies\add* will not invade your country again,  
\q2 \add because\add* they will be completely destroyed.   
\c 2  
\s1 Nineveh will be destroyed  
\q1
\v 1  \add You people of\add* [APO] Nineveh,  
\q2 \w your|strong="H3605"\w* enemies \w are|strong="H7272"\w* \w coming|strong="H2009"\w* \w to|strong="H5921"\w* attack \w you|strong="H3588"\w*.  
\q2 \add So\add* \w place|strong="H3605"\w* guards \w on|strong="H5921"\w* \w the|strong="H3605"\w* tops \w of|strong="H2022"\w* \w the|strong="H3605"\w* walls \w around|strong="H5921"\w* \w the|strong="H3605"\w* city!  
\q2 Guard \w the|strong="H3605"\w* roads \add into the city\add*!  
\q2 Get ready \w to|strong="H5921"\w* fight!  
\q2 Gather \w your|strong="H3605"\w* troops/\w soldiers|strong="H5750"\w* [MTY] \w together|strong="H8085"\w*!   
\b  
\q1
\v 2 \w Even|strong="H4975"\w* though enemy \w soldiers|strong="H5927"\w* \w have|strong="H5921"\w* destroyed \w the|strong="H6440"\w* descendants \w of|strong="H6440"\w* [MTY] Jacob,  
\q2 \w Yahweh|strong="H3068"\w* \w will|strong="H5341"\w* cause \w them|strong="H5921"\w* \w to|strong="H5927"\w* \w be|strong="H1870"\w* honored \w again|strong="H6440"\w*.  
\q1 Israel \w is|strong="H1870"\w* \w like|strong="H1870"\w* \w a|strong="H3068"\w* grapevine \w that|strong="H5927"\w* \w has|strong="H5341"\w* \w been|strong="H5927"\w* ruined,  
\q2 \w but|strong="H2388"\w* Israel \w will|strong="H5341"\w* prosper \w again|strong="H6440"\w*.   
\b  
\q1
\v 3 \w The|strong="H3588"\w* shields \w of|strong="H3068"\w* \w the|strong="H3588"\w* enemy soldiers \add who are coming to attack you\add* \w will|strong="H3068"\w* shine red \add as the sun shines on them\add*,  
\q2 \w and|strong="H3478"\w* \w they|strong="H3588"\w* \w will|strong="H3068"\w* wear bright red uniforms.  
