\q1 Í̠na ti dara holeni nahabe.  
\q1 Wali agali mana bayale bule kama lalu ha howa  
\q2 tigua mana ko bule mitangi bialu kago manda bibe.   
\b  
\q1
\v 6 Mbiraga agali uruni tigua tanoha dai bialu  
\q2 wai pabe gibuni gibuni ibagabu howa  
\q2 biangome gi̱gau̱ laradagua lama ibagabu ka.   
\q1
\v 7 Uruni tigua bi ko lalu mege biraru hale habe.  
\q1 Tinaga bi nehe howa wai biaga ayu tibu ale laga ka.  
\q1 Tigua bi ko laga bialu,  
\q1 Iname bi laramago aiwa hale holebirabe, lalu ka.   
\b  
\q1
\v 8 Anigo Anduane Homogo-o í̠na ti hondowa oba haga ke.  
\q1 Dindi tara taranaga hameigini bibahende karu  
\q2 í̠na ti mege biai haga kegoni.   
\q1
\v 9 Í̠na hangu i̱ mo hongo halu handayaho haga kegoni.\x + \xo 59.9 \xt Iba 9.9, 18.17\x*  
\q1 Ngode Datagaliwabe-o í̠ni kegoha ibalu i̱ bira do haruli.   
\q1
\v 10 I̱naga Ngode Datagaliwabe ibunime i̱ gubalini timbuni ho howa  
\q2 ibugua i̱ biamogo bule ibulebira.  
\q1 Ibugua i̱naga waitigi karu bope halu howa  
\q2 i̱ni de hondoliya walia holebira.   
\b  
\q1
\v 11 Ngode Datagaliwabe-o i̱naga wali agalirume mbirale uruni embedaho waholigo  
