\v 5 \w And|strong="H1121"\w* \w now|strong="H6258"\w*, though \w we|strong="H3068"\w* share \w the|strong="H3027"\w* same \w flesh|strong="H1320"\w* \w and|strong="H1121"\w* blood \w as|strong="H1121"\w* \w our|strong="H3533"\w* \w fellow|strong="H1121"\w* countrymen, \w and|strong="H1121"\w* \w our|strong="H3533"\w* \w children|strong="H1121"\w* \w are|strong="H1121"\w* \w just|strong="H6258"\w* \w like|strong="H1121"\w* \w their|strong="H6258"\w* \w children|strong="H1121"\w*, still \w we|strong="H3068"\w* \w have|strong="H3426"\w* found \w it|strong="H5650"\w* necessary \w to|strong="H3027"\w* subject \w our|strong="H3533"\w* \w sons|strong="H1121"\w* \w and|strong="H1121"\w* \w daughters|strong="H1323"\w* \w to|strong="H3027"\w* \w slavery|strong="H5650"\w*. \w Some|strong="H3027"\w* \w of|strong="H1121"\w* \w our|strong="H3533"\w* \w daughters|strong="H1323"\w* \w have|strong="H3426"\w* \w been|strong="H6258"\w* subjected \w to|strong="H3027"\w* \w slavery|strong="H5650"\w*, \w while|strong="H2009"\w* \w we|strong="H3068"\w* \w are|strong="H1121"\w* powerless \w to|strong="H3027"\w* \w help|strong="H1323"\w*, \w since|strong="H2009"\w* \w our|strong="H3533"\w* \w fields|strong="H7704"\w* \w and|strong="H1121"\w* \w vineyards|strong="H3754"\w* \w now|strong="H6258"\w* belong \w to|strong="H3027"\w* other \w people|strong="H1121"\w*.”
\p 
\v 6 \w I|strong="H1697"\w* \w was|strong="H1697"\w* \w very|strong="H3966"\w* \w angry|strong="H2734"\w* \w when|strong="H8085"\w* \w I|strong="H1697"\w* \w heard|strong="H8085"\w* \w their|strong="H8085"\w* \w outcry|strong="H2201"\w* \w and|strong="H8085"\w* \w these|strong="H8085"\w* \w complaints|strong="H1697"\w*.
