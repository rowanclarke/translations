\p 
\v 13 \w If|strong="G1535"\w* \w we|strong="G1063"\w* \w are|strong="G5210"\w* ‘\w out|strong="G1535"\w* \w of|strong="G2316"\w* \w our|strong="G2316"\w* \w senses|strong="G1839"\w*’, \w it|strong="G1063"\w* \w is|strong="G2316"\w* \w for|strong="G1063"\w* \w God|strong="G2316"\w*; \w if|strong="G1535"\w* \w we|strong="G1063"\w* \w are|strong="G5210"\w* \w of|strong="G2316"\w* \w sound|strong="G4993"\w* \w mind|strong="G4993"\w*, \w it|strong="G1063"\w* \w is|strong="G2316"\w* \w for|strong="G1063"\w* \w you|strong="G5210"\w*.
