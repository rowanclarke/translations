\p
\v 4 Tedae tekah \w huta|strong="H0802"\w* \w hlang|strong="H0376"\w* \w rhoi|strong="H8147"\w* \w te|strong="H0853"\w* \w a\w* \w khuen|strong="H3947"\w* \w tih|strong="H9999"\w* \w a\w* \w thuh|strong="H6845"\w*. \w Te\w* \w phoeiah|strong="H9999"\w* \w hlang|strong="H0376"\w* rhoi te \w kai|strong="H9901"\w* \w taengla|strong="H0413"\w* \w halo|strong="H0935"\w* ngawn \w ue|strong="H3651"\w*. \w Tedae|strong="H9999"\w* \w amih|strong="H1992"\w* rhoi te \w me|strong="H0370"\w* \w lamkah|strong="H4480"\w* rhoi nim ka \w ming|strong="H3045"\w* \w moenih|strong="H3808"\w*.  
