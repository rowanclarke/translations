\id EZR  
\h عَننَبِ عٍسِدِرَ سِ 
\toc1 عَلَ شَ مَسٍنيِ عَننَبِ عٍسِدِرَ سِ بّ 
\toc2 عَننَبِ عٍسِدِرَ سِ 
\toc3 عٍسِ 
\mt1 عَلَ شَ مَسٍنيِ عَننَبِ عٍسِدِرَ سِ بّ 
\imt1 مَسٍنيِ ندٍ يِ كِتَابُي شَ قٍ رَ 
\ip عِسِرَيِلَ شَ تَرُشُي قِندِشِ مَسٍنيِ بٍلٍبٍلٍ نَن نَ عَلَ شَ مِشِيٍ بّ. عَلَتَلَ تٌ عِسِرَيِلَ سُفَندِ عَ شَ حَمَ رَ، عٍ حّرّ كِ عَ نُن عَلَ عٍ مّينِ كِ نَشّ، نَ مِسَالِ شُنفبٍ مَسٍنمَ. عِسِرَيِلَ نُ لُشِ نّ عَلْ دِ لْيشِ نَشَن فبِلٍنمَ عَ بَبَ شَ كِرَ سِنفٍ مَ حَشَنكَتّ سَابُي رَ. 
\ip عِسِرَيِلَ بْنسْي قُ نُن قِرِن تٌ عٍ مَرِفِ شَ كِرَ بّحِن، عَلَ نَشَ عَ نِيَ سِ فبّتّ شَ نْ عِسِرَيِلَ رَ، عٍ عٍ كٍرِ عٍ شَ بْشِ مَ، عٍ عٍ قِندِ كٌنيِيٍ رَ. نَ نَشَ رَبَ عِسِرَيِلَ سّيتِ رَ نَشَن نُ نَ كْولَ مَ، عَ مَن نَشَ رَبَ عِسِرَيِلَ سّيتِ رَ نَشَن نُ نَ يِرٍقَنيِ مَ. نَمِحْنمّ نُ نَ بِرِن كٌلٌنمَ نّ، عٍ قَ عَ قَلَ كّنّ مَ، بٍينُن عَ شَ رَبَ. عٍ شَ مَسٍنيِ كُي، عٍ نُ عَ قَلَمَ عَ عَلَتَلَ نَ عَ نِيَمَ عٍ شَ شَنِن كٌنيِيَ كُي عٍ شَ يُنُبِيٍ شَ قٍ رَ، عٍ مَن نُ عَ قَلَمَ عَ عَلَتَلَ عٍ رَفبِلٍنمَ نّ عٍ شَ بْشِ مَ حّ تٌنفٌ سٌلٌقٍرٍ دَنفِ شَنبِ. 
\ip عَننَبِ عٍسِدِرَ سِ شَ وَشَتِ، نَ حّ تٌنفٌ سٌلٌقٍرٍ نُ بَرَ كَمَلِ. عَلَتَلَ نَشَ عَ نِيَ ثٍرِ سٍ مَنفّ سِرُ سِ شَ نَتّ تٌنفٌ عِسِرَيِلَ كٌنيِيٍ رَفبِلٍنقٍ عٍ شْنيِ دَرِ سَلَمُ، عَلَكٌ عٍ شَ عَلَ شَ هْرْ مْبَنشِ تِ. سِرُ سِ نُ وَ مَ عَ شْن عٍ شَ سّرّشّيٍ بَ عَ بّ، كْنْ عَلَ نُ نَ بِرِن نَبَمَ نّ عَلَكٌ عَ شَ عَ شَ لَايِدِ رَكَمَلِ. عَ نُ نَ مّينِقٍ عَ شَ حَمَ مَ. 
\ip عِسِرَيِلَ بْنسْييٍ تٌ فبِلٍن عٍ شْنيِ، عٍ يَشُييٍ نَشَ قٍ بِرِن نَبَ عَلَكٌ عٍ نَشَ عَلَ شَ هْرْ مْبَنشِ تِ. عٍ نَشَ كَلَمُي سَ ثٍرِ سٍ مَنفّيٍ بّ عِسِرَيِلَ شَ قٍ رَ، كْنْ عَ رَحْنيِ عِسِرَيِلَ نَشَ نْ وَلِ رَبَدٍ. عَلَ شَ نَمِحْنمّ هَفِ نُن سَكَرِ نَشَ عٍ رَلِمَنِيَ نَ وَلِ كُي. نَ لِمَنِيَ لُمَ عَلَ شَ مِشِيٍ يِ رَ هَن تٌ. شَ مِشِ لُمَ عَلَ سّيتِ مَ، عٍ قَمَ تْورّ سْتْدٍ عَلَ يَشُييٍ سَابُي رَ، كْنْ عَ رَحْنيِ عٍ شَ قٍ سْونّيَمَ نّ عَلَتَلَ قْرْ مّ رَ. عَلَ شَ وٌن مَلِ لُقٍ عَ شَ سْونّيَ كِرَ شْن. عَمِنَ. 
\mt1 عَلَ شَ مَسٍنيِ عَننَبِ عٍسِدِرَ سِ بّ 
\c 1  
\s1 عِسِرَيِلَكَيٍ فبِلٍنقٍ دَرِ سَلَمُ 
\p  
\v 1 ثٍرِ سٍ مَنفّ سِرُ سِ شَ مَنفّيَ قْلْ حّ نَشَن نَ، عَلَتَلَ نَشَ وَ قٍ رَكَمَلِقٍ عَ نَشَن مَسٍن عَننَبِ يٍرٍ مِ بّ. عَلَتَلَ نَشَ عَ سَ سِرُ سِ بْحّ مَ، عَ شَ يِ مَسٍنيِ قَلَ، عَ مَن شَ عَ سّبّ مِشِيٍ بّ نَشٍيٍ نَ عَ شَ يَامَرِ بُن مَ. نَ مَسٍنيِ نَن يِ كِ؛  
\v 2 «ﭑ تَن ثٍرِ سٍ مَنفّ سِرُ سِ شُي نَن يَ. مَرِفِ عَلَتَلَ نَشَن نَ كٌورٍ مَ نَشَن دُنِحَ مَنفّيَ بِرِن قِشِ ﭑ مَ، عَ بَرَ ﭑ يَامَرِ، ﭑ شَ هْرْ مْبَنشِ تِ عَ بّ دَرِ سَلَمُ، يُدَيَ بْشِ مَ.  
\v 3 نَشٍيٍ بِرِن قِندِشِ عَلَ شَ حَمَ رَ وٌ يَ مَ، عٍ بِرِن شَ فبِلٍن دَرِ سَلَمُ، يُدَيَ بْشِ مَ، عَلَكٌ عٍ شَ هْرْ مْبَنشِ تِ عِسِرَيِلَ مَرِفِ عَلَتَلَ بّ، نَشَن نَ عَلَ رَ دَرِ سَلَمُ.  
\v 4 ثٍرِ سٍكَيٍ شَ عٍ دْشْبٌورٍ عِسِرَيِلَ مِشِيٍ كِ فبٍتِ، شّيمَ، سٍ قَنيِيٍ، نُن شُرُ سٍيٍ رَ نَشٍيٍ بَمَ سّرّشّ حَنِفٍشِيٍ رَ عَلَ شَ هْرْ مْبَنشِ كُي دَرِ سَلَمُ.» 
\p  
\v 5 يُدَ نُن بُنيَمِن بْنسْي كُنتِفِيٍ، لٍوِ بْنسْي مِشِيٍ نُن سّرّشّدُبّ نَشٍيٍ نُ نَ عٍ يَ مَ، عَ نُن عَلَ نَشٍيٍ بِرِن بْحّ رَتٍ سِفَقٍ رَ، عٍ بِرِن نَشَ سِفَ عَلَ شَ هْرْ مْبَنشِ تِدٍ دَرِ سَلَمُ.  
\v 6 عٍ دْشْبٌورٍيٍ نَشَ عٍ كِ فبٍتِ، شّيمَ، سٍ قَنيِيٍ، شُرُ سٍيٍ، نُن هَرِفٍ رَ، عَ نُن سّرّشّ حَنِفٍشِيٍ.  
\v 7 مَنفّ نٍبُكَدَنسَرِ نُ بَرَ سٍ فبٍفبٍ رَ مِنِ دَرِ سَلَمُ هْرْ مْبَنشِ كُي عَ شَ وَشَتِ، عَ قَ عٍ رَ سٌ عَ شَ عَلَ شَ بَنشِ كُي. ثٍرِ سٍ مَنفّ سِرُ سِ نَشَ نَ بِرِن نَمِنِ،  
\v 8 عَ عٍ تَشُ كْبِرِ رَفَتَمَ مِتٍرٍدَتِ رَ، عَ شَ عَ رَ سَنبَ يُدَيَ مَنفّ سّسّبَسَرِ مَ. 
\p  
\v 9 نَ سٍيٍ كْنتِ نَن يِ كِ؛ ثَانِ شّيمَ دَاشِ تٌنفٌ سَشَن، ثَانِ فبٍتِ دَاشِ وُلُ كٍرٍن، قِنّ مْشْحّن نُن سٌلٌمَنَانِ،  
\v 10 ثِلٍتِ شّيمَ دَاشِ تٌنفٌ سَشَن، ثِلٍتِ فبٍتِ دَاشِ كّمّ نَانِ، ثِلٍتِ قُ، عَ نُن يِرَبَسٍ فبّتّ وُلُ كٍرٍن.  
\v 11 نَ سٍ شّيمَ دَاشِ نُن فبٍتِ دَاشِ بِرِن كْنتِ نَشَ لَن يِرَبَسٍ وُلُ سُولِ كّمّ نَانِ مَ. عِسِرَيِلَ فٍيلِمَنِيٍ تٌ كٍلِ بَبِلْن فبِلٍنقٍ رَ دَرِ سَلَمُ، سّسّبَسَرِ نَشَ نَ نَاقُلِ بِرِن شَنِن عَ شُن مَ. 
\c 2  
\s1 مِشِ نَشٍيٍ فبِلٍن يُدَيَ 
\p  
\v 1 مِشِيٍ نَن يِ كِ مَنفّ نٍبُكَدَنسَرِ قَ نَشٍيٍ رَ بَبِلْن بْشِ مَ، نَشٍيٍ نُ وَ مَ فبِلٍنقٍ عٍ شْنيِ دَرِ سَلَمُ نُن يُدَيَ.  
\v 2 سٌرٌبَبٍلِ، يٍسُوَ، نٍهٍمِ، سٍرَيَ، رٍيلَيَ، مٌرٌدٍكَيِ، بِلٍسَن، مِسثَرِ، بٍفِقَيِ، رٍشُمِ، نُن بَاننَ نَشَ قِندِ عٍ شَ يَرٍرَتِيٍ رَ. نَ عِسِرَيِلَ شّمّيٍ كْنتِ نَن يِ كِ؛ 
\q1  
\v 3 ثَرٌ سٌ شَ دِيٍ، مِشِ وُلُ قِرِن، مِشِ كّمّ، مِشِ تٌنفٌ سٌلٌقٍرٍ نُن قِرِن. 
\q1  
\v 4 سّقَتَيَ شَ دِيٍ، مِشِ كّمّ سَشَن، مِشِ تٌنفٌ سٌلٌقٍرٍ نُن قِرِن. 
\q1  
\v 5 عَرَ شَ دِيٍ، مِشِ كّمّ سٌلٌقٍرٍ، مِشِ تٌنفٌ سٌلٌقٍرٍ نُن سُولِ. 
\q1  
\v 6 مٌوَبَ ثَشَتِ شَ دِيٍ، مِشِ وُلُ قِرِن، مِشِ كّمّ سٌلٌمَسَشَن نُن مِشِ قُ نُن قِرِن. 
\q1 مٌوَبَ ثَشَتِ كٍلِشِ يٍسُوَ نُن يٌوَبَ شَبِلّ نّ. 
\q1  
\v 7 عٍلَمَ شَ دِيٍ، مِشِ وُلُ كٍرٍن، مِشِ كّمّ قِرِن، مِشِ تٌنفٌ سُولِ نُن نَانِ. 
\q1  
\v 8 سَتُ شَ دِيٍ، مِشِ كّمّ سٌلٌمَنَانِ، مِشِ تٌنفٌ نَانِ نُن سُولِ. 
\q1  
\v 9 سَكَيِ شَ دِيٍ، مِشِ كّمّ سٌلٌقٍرٍ نُن مِشِ تٌنفٌ سٍننِ. 
\q1  
\v 10 بَنِ شَ دِيٍ، مِشِ كّمّ سٍننِ، مِشِ تٌنفٌ نَانِ نُن قِرِن. 
\q1  
\v 11 بِبَيِ شَ دِيٍ، مِشِ كّمّ سٍننِ، مِشِ مْشْحّن نُن سَشَن. 
\q1  
\v 12 عَسِفَدِ شَ دِيٍ، مِشِ وُلُ كٍرٍن، مِشِ كّمّ قِرِن، نُن مِشِ مْشْحّن نُن قِرِن. 
\q1  
\v 13 عَدٌنِكَمَ شَ دِيٍ مِشِ كّمّ سٍننِ، مِشِ تٌنفٌ سٍننِ نُن سٍننِ. 
\q1  
\v 14 بٍفِقَيِ شَ دِيٍ مِشِ وُلُ قِرِن، مِشِ تٌنفٌ سُولِ نُن سٍننِ. 
\q1  
\v 15 عَدِن شَ دِيٍ، مِشِ كّمّ نَانِ، مِشِ تٌنفٌ سُولِ نُن نَانِ. 
\q1  
\v 16 عَتّرِ شَ دِيٍ، شٍسٍكِيَ شَبِلّ، مِشِ تٌنفٌ سٌلٌمَنَانِ نُن سٌلٌمَسَشَن. 
\q1  
\v 17 بٍسٍيِ شَ دِيٍ، مِشِ كّمّ سَشَن مِشِ مْشْحّن نُن سَشَن. 
\q1  
\v 18 يْرَ شَ دِيٍ، مِشِ كّمّ، مِشِ قُ نُن قِرِن. 
\q1  
\v 19 شَسُمَ شَ دِيٍ، مِشِ كّمّ قِرِن، مِشِ مْشْحّن نُن سَشَن. 
\q1  
\v 20 فِبَرِ شَ دِيٍ، مِشِ تٌنفٌ سٌلٌمَنَانِ نُن سُولِ. 
\b  
\q1  
\v 21 بّتّلّيمُ شّمّيٍ، مِشِ كّمّ، مِشِ مْشْحّن، عَ نُن سَشَن. 
\q1  
\v 22 مِشِ نَشٍيٍ كٍلِ نٍتٌقَ، مِشِ تٌنفٌ سُولِ نُن سٍننِ. 
\q1  
\v 23 مِشِ نَشٍيٍ كٍلِ عَنَتْتِ، مِشِ كّمّ مِشِ مْشْحّن نُن سٌلٌمَسَشَن. 
\q1  
\v 24 مِشِ نَشٍيٍ كٍلِ عَسَمَقٍتِ، مِشِ تٌنفٌ نَانِ نُن قِرِن. 
\q1  
\v 25 مِشِ نَشٍيٍ كٍلِ كِرِيَتِ يٍيَرِ مِ، كٍقِرَ، نُن بٍرٌتِ، مِشِ كّمّ سٌلٌقٍرٍ، مِشِ تٌنفٌ نَانِ نُن سَشَن. 
\q1  
\v 26 مِشِ نَشٍيٍ كٍلِ رَ مَ نُن فٍبَ، مِشِ كّمّ سٍننِ، مِشِ مْشْحّن نُن كٍرٍن. 
\q1  
\v 27 مِشِ نَشٍيٍ كٍلِ مِكِمَسِ، مِشِ كّمّ، مِشِ مْشْحّن نُن قِرِن. 
\q1  
\v 28 مِشِ نَشٍيٍ كٍلِ بٍتٍلِ نُن عَيِ، مِشِ كّمّ قِرِن، مِشِ مْشْحّن نُن سَشَن. 
\q1  
\v 29 مِشِ نَشٍيٍ كٍلِ نٍبٌ، مِشِ تٌنفٌ سُولِ نُن قِرِن. 
\q1  
\v 30 مَفِبِسَ شَ دِيٍ، مِشِ كّمّ، مِشِ تٌنفٌ سُولِ نُن سٍننِ. 
\q1  
\v 31 عٍلَمَ فبّتّ شَ دِيٍ، مِشِ وُلُ كٍرٍن، مِشِ كّمّ قِرِن، مِشِ تٌنفٌ سُولِ نُن نَانِ. 
\q1  
\v 32 شَرِ مَ شَ دِيٍ، مِشِ كّمّ سَشَن، مِشِ مْشْحّن. 
\q1  
\v 33 مِشِ نَشٍيٍ كٍلِ لٌدِ نُن شَدِدِ، مِشِ كّمّ سٌلٌقٍرٍ، مِشِ مْشْحّن نُن سُولِ. 
\q1  
\v 34 مِشِ نَشٍيٍ كٍلِ يٍرِكٌ، مِشِ كّمّ سَشَن، مِشِ تٌنفٌ نَانِ نُن سُولِ. 
\q1  
\v 35 مِشِ نَشٍيٍ كٍلِ سٍنَا، مِشِ وُلُ سَشَن، مِشِ كّمّ سٍننِ، مِشِ تٌنفٌ سَشَن. 
\b  
\q1  
\v 36 سّرّشّدُبّيٍ كْنتِ نَن يِ كِ؛ 
\q1 يّدَيَ شَ دِ نَشٍيٍ كٍلِشِ يٍسُوَ شَبِلّ، مِشِ كّمّ سٌلٌمَنَانِ، مِشِ تٌنفٌ سٌلٌقٍرٍ نُن سَشَن. 
\q1  
\v 37 عِمٍرِ شَ دِيٍ، مِشِ وُلُ كٍرٍن، مِشِ تٌنفٌ سُولِ نُن قِرِن. 
\q1  
\v 38 ثَسُرَ شَ دِيٍ، مِشِ وُلُ كٍرٍن، مِشِ كّمّ قِرِن، مِشِ تٌنفٌ نَانِ، نُن سٌلٌقٍرٍ. 
\q1  
\v 39 شَرِ مَ شَ دِيٍ، مِشِ وُلُ كٍرٍن، مِشِ قُ نُن سٌلٌقٍرٍ. 
\b  
\q1  
\v 40 لٍوِ بْنسْي كْنتِ نَن يِ كِ؛ 
\q1 يٍسُوَ نُن كَدَ مِيّلِ شَ دِيٍ، مِشِ تٌنفٌ سٌلٌقٍرٍ نُن نَانِ. 
\b  
\q1  
\v 41 بّيتِبَيٍ كْنتِ نَن يِ كِ؛ 
\q1 عَسَقِ شَ دِيٍ، مِشِ كّمّ، مِشِ مْشْحّن نُن سٌلٌمَسَشَن. 
\b  
\q1  
\v 42 هْرْ مْبَنشِ مَكَنتّيٍ كْنتِ نَن يِ كِ؛ 
\q1 سَلُمُ، عَتّرِ، تَلَمْن، عَكُبُ، شَتِتَ، نُن سٌبَيِ شَ دِيٍ، 
\q1 مِشِ كّمّ، مِشِ تٌنفٌ سَشَن نُن سٌلٌمَنَانِ. 
\b  
\q1  
\v 43 هْرْ مْبَنشِ وَلِكّيٍ نَن يِ كِ؛ 
\q1 سِشَ شَ دِيٍ، شَسُقَ شَ دِيٍ، تَبَيٌتِ شَ دِيٍ، 
\q1  
\v 44 كٍرٌ سِ شَ دِيٍ، سِيَهَ شَ دِيٍ، ثَدٌن شَ دِيٍ، 
\q1  
\v 45 لٍبَنَ شَ دِيٍ، هَفَبَهَ شَ دِيٍ، عَكُبُ شَ دِيٍ، 
\q1  
\v 46 شَفَبِ شَ دِيٍ، سَلَمَيِ شَ دِيٍ، هَنَن شَ دِيٍ، 
\q1  
\v 47 فِدّلِ شَ دِيٍ، فَشَرِ شَ دِيٍ، رٍيَيَ شَ دِيٍ، 
\q1  
\v 48 رٍ سِن شَ دِيٍ، نٍكٌدَ شَ دِيٍ، فَسَمَ شَ دِيٍ، 
\q1  
\v 49 عُسَ شَ دِيٍ، ثَسٍيَ شَ دِيٍ، بِسَيِ شَ دِيٍ، 
\q1  
\v 50 عَسَنَ شَ دِيٍ، مٍوُنِمَ شَ دِيٍ، نٍقُسِمَ شَ دِيٍ، 
\q1  
\v 51 بَكِبُكِ شَ دِيٍ، شَكُقَ شَ دِيٍ، شَرِشُرِ شَ دِيٍ، 
\q1  
\v 52 بَسِلُتِ شَ دِيٍ، مٍشِدَ شَ دِيٍ، شَرَ سَ شَ دِيٍ، 
\q1  
\v 53 بَرَكْسِ شَ دِيٍ، سِسٍرَ شَ دِيٍ، تٍمَ شَ دِيٍ، 
\q1  
\v 54 نٍسِيَ شَ دِيٍ، نُن شَتِقَ شَ دِيٍ. 
\b  
\q1  
\v 55 مَنفّ سُلٍمَنِ شَ وَلِكّيٍ شَ دِيٍ نَن يِ كِ؛ 
\q1 سٌتَيِ شَ دِيٍ، سٌقٍرٍتِ شَ دِيٍ، ثٍرُدَ شَ دِيٍ، 
\q1  
\v 56 يَالَ شَ دِيٍ، دَرَكْن شَ دِيٍ، فِدّلِ شَ دِيٍ، 
\q1  
\v 57 سّقَتَيَ شَ دِيٍ، شَتِلِ شَ دِيٍ، 
\q1 ثٌكّرّتِ هَسٍبَيِمِ شَ دِيٍ، نُن عَمِ شَ دِيٍ. 
\b  
\m  
\v 58 هْرْ مْبَنشِ وَلِكّيٍ نُن سُلٍمَنِ شَ وَلِكّيٍ شَ دِيٍ بِرِن قِندِشِ مِشِ كّمّ سَشَن، مِشِ تٌنفٌ سٌلٌمَنَانِ، نُن قِرِن نَن نَ. 
\p  
\v 59 مِشِيٍ نَن يِ كِ نَشٍيٍ كٍلِ مٍلَ، شَرَ سَ، كّرُبُ عَدَن، نُن عِمٍرِ. عٍ مُ نْ عَ مَسٍندٍ عَ عٍ شَبِلّ قِندِشِ عِسِرَيِلَكَيٍ نَن نَ. 
\q1  
\v 60 دّلَيَ شَ دِيٍ، تٌبِيَ شَ دِيٍ، نُن نٍكٌدَ شَ دِيٍ، 
\q1 عٍ قِندِشِ مِشِ كّمّ سٍننِ مِشِ تٌنفٌ سُولِ نُن قِرِن نَن نَ. 
\q1  
\v 61 سّرّشّدُبّيٍ شَ دِيٍ قَن نُ نَ عٍ يَ مَ؛ 
\q1 شَبَيَ شَ دِيٍ، هَكْسِ شَ دِيٍ، نُن بَرَ سِلَيِ شَ دِيٍ. 
\q1 بَرَ سِلَيِ شَ دِيٍ بٍنبَ نُ بَرَ بَرَ سِلَيِ فَلَدِكَ شَ دِ فِنّ دْشْ، 
\q1 عَ مَن نَشَ نَ شِلِ تٌنفٌ. 
\m  
\v 62 عٍ شِلِيٍ تٌ مُ تٌ تَرُشُي كُي، عٍ مُ نْشِ سّرّشّدُبّ وَلِ رَبَدٍ.  
\v 63 مَنفّ نَشَ عَ قَلَ عٍ بّ، عَ عٍ نَشَ دٌنسٍ سّنِيّنشِ دٌن هَن سّرّشّدُبّ ندٍ نْمَ عٍ شَ قٍ رَقِيشّدٍ عَلَ شَ تْنشُمَيٍ عُرِ مِ نُن تُمِمِ سَابُي رَ تّمُي نَشّ. 
\p  
\v 64 حَمَ نَشَن فبِلٍن يُدَيَ، عَ بِرِن قِندِ مِشِ وُلُ تٌنفٌ نَانِ نُن قِرِن، مِشِ كّمّ سَشَن مِشِ تٌنفٌ سٍننِ نَن نَ.  
\v 65 كٌنيِ فِنّيٍ نُن شّمّيٍ مُ نُ نَ نَ كْنتِ يَ مَ. عٍ قَن لَنشِ مِشِ وُلُ سٌلٌقٍرٍ، مِشِ كّمّ سَشَن تٌنفٌ سَشَن نُن سٌلٌقٍرٍ نَن مَ. بّيتِبَيٍ قَن قِندِ مِشِ كّمّ قِرِن نَن نَ. 
\p  
\v 66 يِ دَالِسٍ شَسَبِ نُ نَ عٍ يِ رَ؛ سٌي كّمّ سٌلٌقٍرٍ، تٌنفٌ سَشَن نُن سٍننِ، سٌي بَنَشِ كّمّ قِرِن، تٌنفٌ نَانِ نُن سُولِ،  
\v 67 حْشْمّ كّمّ نَانِ، تٌنفٌ سَشَن نُن سُولِ، عَ نُن سٌقَلٍ وُلُ سٍننِ، كّمّ سٌلٌقٍرٍ مْشْحّن. 
\p  
\v 68 شَبِلّ كُنتِفِيٍ تٌ عَلَ شَ بَنشِ لِ دَرِ سَلَمُ، عٍ نَشَ سّرّشّ حَنِفٍشِ بَ عَلَ شَ بَنشِ شَ قٍ رَ، عَلَكٌ عَ مَن شَ تِ مّننِ.  
\v 69 عٍ نَشَ كْبِرِ بَ يِ وَلِ شَ قٍ رَ. نَ كْبِرِ قِندِ كْبِرِ كٌلٍ وُلُ تٌنفٌ سٍننِ نُن كٍرٍن نَن نَ شّيمَ دَاشِ، عَ نُن كْبِرِ كٌلٍ وُلُ سُولِ فبٍتِ دَاشِ. عٍ مَن نَشَ سّرّشّدُبّ دُفِ كّمّ بَ يِ وَلِ شَ قٍ رَ. 
\p  
\v 70 نَ نَن نَ كِ سّرّشّدُبّيٍ، لٍوِ بْنسْي مِشِيٍ، بّيتِبَيٍ، هْرْ مْبَنشِ كَنتَيٍ، نُن هْرْ مْبَنشِ وَلِكّيٍ، عٍ بِرِن نَشَ سَبَتِ عٍ فبٍ تَايٍ كُي، عَ نُن عِسِرَيِلَكَيٍ بِرِن. 
\c 3  
\s1 عَلَ شَ سّرّشّبَدٍ نُن هْرْ مْبَنشِ تِقٍ 
\p  
\v 1 كِكٍ سٌلٌقٍرٍ تٌ كَمَلِ، عِسِرَيِلَكَ نَشٍيٍ نُ نَ نَ تَايٍ كُي، نٍيٍ بِرِن نَشَ عٍ مَلَن دَرِ سَلَمُ.  
\v 2 يٌسَدَكِ شَ دِ يٍسُوَ نُن عَ بٌورٍيٍ سّرّشّدُبّيٍ، عَ نُن سَلَتِيٍلِ شَ دِ سٌرٌبَبٍلِ نُن عَ بٌورٍيٍ، عٍ نَشَ كَقُ عٍ بٌورٍ مَ، عٍ سّرّشّبَدٍ تِ عِسِرَيِلَ مَرِفِ عَلَ بّ، عَلَكٌ عٍ شَ سّرّشّ فَن دَاشِيٍ بَ عَلْ عَننَبِ مُنسَ عَ مَسٍن سّرِيّ كُي كِ نَشّ.  
\v 3 عٍ نَشَ نَ سّرّشّبَدٍ تِ عَ يِرٍ قٌرِ، عٍ مَن نَشَ سّرّشّ بَ قْلْ فّيسّفّ نُن نُنمَرٍ. عٍ نُ نَ بِرِن نَبَقٍ فَاشُي نَن كُي سِ فبّتّيٍ شَ قٍ رَ، نَشٍيٍ نُ نَ عٍ رَبِلِنيِ.  
\v 4 عٍ نَشَ بَفٍ تِ سَلِ رَبَ عَلْ عَ سّبّشِ كِتَابُي كُي كِ نَشّ، عٍ مَن نُ سّرّشّيٍ بَمَ لْشْ يٌ لْشْ سّرِيّ كِ مَ.  
\v 5 عٍ نُ سّرّشّ فَن دَاشِ بَمَ كِكٍ نّينّ سَلِ نُن سَلِ شُنفبٍيٍ وَشَتِ، عَ نُن تّمُي فبّتّ مِشِ ندٍ نَ عَ حَنِفٍ تّمُي نَشّ.  
\v 6 نَ كِكٍ سٌلٌقٍرٍ ندٍ لْشْي سِنفٍ، عٍ نَشَ سّرّشّ بَ قْلْ عَلَ بّ، كْنْ عَلَتَلَ شَ هْرْ مْبَنشِ مُ نُ كْورِنشِ سِندٍن. 
\p  
\v 7 نَ تّمُي عٍ نَشَ كْبِرِ بَ عَلَكٌ سِدْن نُن تِرٍ فّمّ مَسٌلِيٍ نُن بَنشِتِيٍ شَ قَ عٍ مَلِدٍ. عٍ نَشَ سَنسِ شْرِيٍ، وّنِ، نُن تُرٍ قَن بَ عٍ بّ، عَلَكٌ عٍ شَ قَ وُرِ رَ يٍ كِرَ رَ كٍلِقٍ لِبَن هَن يَقَ، عَلْ ثٍرِ سٍ مَنفّ سِرُ سِ عَ يَمَرِ كِ نَشّ.  
\v 8 نَ حّ عِفبِلٍنيِ، كِكٍ قِرِن ندٍ، سَلَتِيٍلِ شَ دِ سٌرٌبَبٍلِ، يٌسَدَكِ شَ دِ يٍسُوَ، عٍ نفَشَكٍرٍنيِيٍ، سّرّشّدُبّيٍ، لٍوِ بْنسْي مِشِيٍ، نُن حَمَ نَشَن كٍلِ كٌنيِيَ كُي ثٍرِ سٍ بْشِ مَ، عٍ بِرِن نَشَ وَلِ قْلْ. عَلَتَلَ شَ بَنشِ وَلِ نَشَ تَشُ لٍوِ بْنسْي مِشِيٍ رَ، نَشٍيٍ نُ بَرَ حّ مْشْحّن نُن عَ شَنبِ سْتْ.  
\v 9 يٍسُوَ نَشَ عَ شَ دِيٍ، نُن عَ نفَشَكٍرٍنيِ كَدَ مِيّلِ، نُن عَ شَ دِيٍ تِ هْرْ مْبَنشِ وَلِكّيٍ شُنيِيٍ رَ، عَ نُن شٍنَدَدِ، عَ شَ دِيٍ، نُن عَ نفَشَكٍرٍنيِ نَشٍيٍ كٍلِشِ لٍوِ بْنسْي. 
\p  
\v 10 وَلِكّيٍ تٌ فّ عَلَتَلَ شَ هْرْ مْبَنشِ كْورِندٍ، سّرّشّدُبّيٍ نُن عَسَقِ شَ دِ لٍوِ بْنسْي مِشِيٍ نَشَ عَلَتَلَ مَتْشْ سَرَيٍ نُن مَشَسٍيٍ شُي رَ، عِسِرَيِلَ مَنفّ دَوُدَ شَ سّرِيّ كِ مَ.  
\v 11 عٍ نُ عَلَتَلَ تَنتُ، عٍ عَ مَتْشْ يِ بّيتِ رَ، 
\q1 «عَلَتَلَ نَن قَن، 
\q1 عَ هِننّمَ عِسِرَيِلَ رَ عَبَدَن.» 
\m حَمَ بِرِن نَشَ عَلَتَلَ مَتْشْ عٍ شُي عِتٍشِ رَ، عَلَتَلَ شَ بَنشِ كْورِنقٍ شَ قٍ رَ.  
\v 12 قٌرِ نَشٍيٍ نُ بَرَ عَلَ شَ هْرْ مْبَنشِ سِنفٍ تٌ، عٍ قِندِ سّرّشّدُبّيٍ رَ، عٍ قِندِ كُنتِفِيٍ رَ، عٍ نَشَ وَ عٍ شُي عِتٍشِ رَ. بٌورٍيٍ نَشَ عٍ شُي رَتٍ سّيوّ كُي.  
\v 13 حَمَ مُ نْ حّلّشِنيِ شُي نُن وَ شُي تَفِ رَ سَدٍ، بَرِ مَ حَمَ شُي شَ فبٌي نُ سِفَمَ هَن يِرٍ مَكُيٍ. 
\c 4  
\s1 عِسِرَيِلَ يَشُييٍ شَ كَتّ 
\p  
\v 1 يُدَ بْنسْي نُن بُنيَمِن بْنسْي يَشُييٍ نَشَ عَ كٌلٌن، مِشِ نَشٍيٍ نُ نَ كٌنيِيَ كُي ثٍرِ سٍ بْشِ مَ، عٍ بَرَ عِسِرَيِلَ مَرِفِ عَلَتَلَ شَ هْرْ مْبَنشِ تِ قْلْ.  
\v 2 عٍ نَشَ سِفَ، عٍ عَ قَلَ سٌرٌبَبٍلِ نُن عِسِرَيِلَ كُنتِفِيٍ بّ، «مُشُ وَ مَ عَ شْن مَ نّ، وٌن بِرِن شَ كَقُ وٌن بٌرٍ مَ عَلَ شَ هْرْ مْبَنشِ تِقٍ رَ. مُشُ وٌ مَرِفِ عَلَ نَن بَتُمَ، مُشُ قَن نُ سّرّشّ بَمَ نّ عَ بّ كَبِ عَسِرِيَ مَنفّ عٍسَرِشَدٌنِ تّمُي، نَشَن قَ مُشُ رَ بٍ.» 
\p  
\v 3 كْنْ سٌرٌبَبٍلِ، يٍسُوَ، نُن عِسِرَيِلَ كُنتِفِيٍ نَشَ عٍ يَابِ، «عَ مُ لَنمَ وٌن بِرِن شَ يِ وَلِ رَبَ. مُشُ فبَنسَن نَن عَلَ شَ هْرْ مْبَنشِ تِمَ عِسِرَيِلَ مَرِفِ عَلَتَلَ بّ، عَلْ ثٍرِ سٍ مَنفّ سِرُ سِ عَ يَمَرِ كِ نَشّ.»  
\v 4 نَ كُي، مّننِكَيٍ نَشَ كَتَ لِمَنِيَ بَدٍ يُدَيَكَيٍ يِ رَ. عٍ نَشَ قٍ بِرِن نَبَ عَلَكٌ عٍ شَ نَ سَلِدٍ تِقٍ لُ نَ.  
\v 5 عٍ نَشَ كْبِرِ قِ يُدَيَ مَرَ سِمَ ندٍيٍ مَ عَلَكٌ نَ وَلِ شَ كَنَ. كٍلِقٍ ثٍرِ سٍ مَنفّ سِرُ سِ شَ تّمُي، سَ دْشْ ثٍرِ سٍ مَنفّ دَرِيُسِ شَ تّمُي رَ، عٍ نَشَ قٍ بِرِن نَبَ نَ وَلِ شُن نَكَنَقٍ رَ. 
\p  
\v 6 عَسُيٍرُ سُ تٌ مَنفّيَ سْتْ ثٍرِ سٍ بْشِ مَ، يُدَيَكَيٍ يَشُييٍ نَشَ كَلَمُي كّيدِ ندٍ سّبّ عَ مَ يُدَيَكَيٍ نُن دَرِ سَلَمُكَيٍ شَ قٍ رَ.  
\v 7 ثٍرِ سٍ مَنفّ عَتَسَكَسِ شَ وَشَتِ قَن، بِكِلَمُ، مِتٍرٍدَتِ، تَبٍيلِ نُن عٍ بٌورٍ دْنشْييٍ نَشَ بَتَاشّ سّبّ مَنفّ مَ عَرَ مِ شُي رَ.  
\v 8 فٌمِنَ رٍشُمِ شَ سّبّلِتِ سِمٍسَيِ نَشَ يِ بَتَاشّ سّبّ مَنفّ عَتَسَكَسِ مَ عَ رَكٌلٌنقٍ رَ دَرِ سَلَمُ شَ قٍ مَ. عَ يِ نَن سّبّ؛  
\v 9 «يِ بَتَاشّ قَتَنشِ فٌمِنَ رٍشُمِ نَن مَ، نُن عَ شَ سّبّلِتِ سِمٍسَيِ، عَ شَ كُنتِفِ نَشٍيٍ قِندِشِ كِيتِسَيٍ، سّبّلِتِيٍ عٍرٍكِكَيٍ، بَبِلْنكَيٍ، نُن سُسَكَ نَشٍيٍ كٍلِشِ عٍلَمَ بْشِ مَ،  
\v 10 عَ نُن سِ فبّتّ مِشِيٍ، مَنفّ شُنفبٍ عُسِنَثَرِ نَشٍيٍ رَ سِفَ عٍقِرَتِ نَاكِرِ مَ، عٍ شَ سَبَتِ سَمَرِ تَايٍ كُي.  
\v 11 مَنفّ عَتَسَكَسِ، يِ بَتَاشّ قَتَنشِ عِ شَ كٌنيِيٍ نَن نَ، نَشٍيٍ نَ شُرٍ نَاكِرِ مَ.  
\v 12 مَنفّ، عِ شَ عَ كٌلٌن يُوِقِ نَشٍيٍ كٍلِ عِ شَ بْشِ مَ، عٍ بَرَ قَ مُشُ مَبِرِ، عٍ قَ سَبَتِ دَرِ سَلَمُ. عٍ نَ نَ تَا رَكٍلِقٍ، نَشَن كٌلٌنشِ مَتَندِلَيٍ شَ تَا رَ. عٍ بَرَ عَ تّتّ يَءِلَن قْلْ.  
\v 13 مَنفّ، عِ شَ عَ كٌلٌن، شَ عٍ نَ تّتّ يَءِلَن، عٍ نَشَ نَ تَا تِ، مّننِكَيٍ مُ دُوتِ يٌ قِمَ عِ مَ سْنْن. نَ قِندِ مَ قٍ شْرْشْي نَن نَ مَنفَسَنيِ بّ.  
\v 14 نَ نَ عَ رَ، مُشُ تَن نَشَن تِشِ عِ شَنبِ رَ، مُشُ مُ نْمَ نَ قٍ بِنيّتَرٍحَ تٌدٍ، عَ قَ لُ مُشُ مُ عِ رَكٌلٌن.  
\v 15 عِ نَ عِ بَبَيٍ شَ تَرُشُييٍ شَرَن، عِ قَمَ عَ تٌدٍ نَ تَاكَ مَتَندِلَيٍ مُ مَنفّ يٌ بِنيَمَ. كَبِ تّمُي شْنكُيٍ عٍ لُمَ مَنفّيٍ مَتَندِ رَ. عٍ شَ تَا نُ بَرَ كَنَ نَ نَن مَ.  
\v 16 مَنفّ، مُشُ شَ عَ قَلَ عِ بّ، شَ يِ تَا نُن عَ تّتّ رَكٍلِ، عِ قَمَ نّ فَندٍ عِ شَ بْشِ رَ نَشَن نَ بٍبِرِ عٍقِرَتِ شُرٍ نَاكِرِ مَ.» 
\p  
\v 17 مَنفّ نَشَ عٍ يَابِ يِ سّبّلِ رَ، «عِ تَن فٌمِنَ رٍشُمِ، نُن عِ شَ سّبّلِتِ سِمٍسَيِ، نُن عِ شَ كُنتِفِ نَشٍيٍ نَ سَمَرِ نُن يِرٍ فبّتّ عٍقِرَتِ شُرٍ نَاكِرِ مَ، ﭑ بَرَ وٌ شّيبُ.  
\v 18 ﭑ مَ مِشِيٍ بَرَ وٌ شَ بَتَاشّ مَدَنفِ ﭑ مَ شُي رَ، عٍ عَ شَرَن ﭑ بّ.  
\v 19 ﭑ بَرَ عٍ يَمَرِ عٍ شَ نَ تَا تَرُشُي قٍن. نَ كُي ﭑ بَرَ عَ كٌلٌن، نَ تَا لُمَ مَنفَسَنيِ مَتَندِ رَ كَبِ تّمُي شْنكُيٍ.  
\v 20 مَنفّ فبَنفبَلَنيِ ندٍيٍ نُ نَ دَرِ سَلَمُ، نَشٍيٍ نُ حَمَنّ بِرِن يَمَرِ مَ نَشٍيٍ نُ نَ عٍقِرَتِ شُرٍ نَاكِرِ مَ. بِرِن نُ دُوتِ قِمَ عٍ مَ.  
\v 21 نَ كُي، وٌ شَ عَ قَلَ نَ مِشِيٍ بّ عَ عٍ شَ وَلِ عِتِ هَن ﭑ يَامَرِ قِمَ تّمُي نَشّ.  
\v 22 وٌ شَ نَ مَتٌ عَ قَنيِ رَ عَلَكٌ مَنفَسَنيِ شُن نَشَ رَكَنَ نَ قٍ مَ.» 
\p  
\v 23 فٌمِنَ رٍشُمِ، نُن عَ شَ سّبّلِتِ سِمٍسَيِ، نُن مَنفّ فبّتّيٍ تٌ مَنفّ عَتَسَكَسِ شَ بَتَاشّ شَرَن، عٍ نَشَ سِفَ كٍرٍن نَ دَرِ سَلَمُ يُوِقِيٍ يِرٍ، عٍ شَ نَ وَلِ عِتِ سّنبّ رَ.  
\v 24 نَ كُي عَلَ شَ بَنشِ تِقٍ دَرِ سَلَمُ نَشَ عِتِ هَن ثٍرِ سٍ مَنفّ دَرِيُسِ شَ مَنفّيَ حّ قِرِن ندٍ. 
\c 5  
\s1 فبِلٍنقٍ هْرْ مْبَنشِ تِقٍ مَ 
\p  
\v 1 نَ تّمُي عَننَبِ شَفَيِ نُن عِدٌ شَ دِ عَننَبِ سَكَرِ نَشَ عِسِرَيِلَ مَرِفِ عَلَ شَ مَسٍنيِ تِ يُوِقِيٍ بّ، نَشٍيٍ نُ نَ يُدَيَ نُن دَرِ سَلَمُ.  
\v 2 نَ دَنفِ شَنبِ، سَلَتِيٍلِ شَ دِ سٌرٌبَبٍلِ نُن يٌسَدَكِ شَ دِ يٍسُوَ، نَشَ فبِلٍن عَلَ شَ هْرْ مْبَنشِ تِ رَ دَرِ سَلَمُ. عَلَ شَ نَمِحْنمّيٍ نَشَ كَقُ عٍ مَ نَ وَلِ كُي. 
\p  
\v 3 نَ وَشَتِ، تَتٍنَيِ، نَشَن قِندِ فٌمِنَ رَ سَمَرِ بْشِ مَ، عَ نُن سٍتَرَ بٌسٍنَيِ، نُن عٍ شَ كُنتِفِيٍ نَشَ قَ، عٍ عٍ مَشْرِن، «ندٍ وٌ يَمَرِشِ وٌ شَ يِ بَنشِ نُن يِ تّتّ تِ؟  
\v 4 ندٍيٍ نَ يِ وَلِ كُي؟ وٌ شَ نَ كَنيِيٍ شِلِيٍ قَلَ مُشُ بّ.»  
\v 5 كْنْ عَلَ نُ عَ حّنفِ سَشِ يُوِقِ كُنتِفِيٍ شْن مَ. يُوِقِيٍ يَشُييٍ مُ نْ وَلِ عِتِدٍ، بٍينُن عٍ شَ بَتَاشّ سّبّ مَنفّ دَرِيُسِ مَ، عٍ مَن شَ عَ يَابِ سْتْ يِ وَلِ شَ قٍ رَ. 
\p  
\v 6 سَمَرِ فٌمِنَ تَتٍنَيِ، سٍتَرَ بٌسٍنَيِ، نُن عٍ شَ كُنتِفِيٍ نَشَ يِ بَتَاشّ سّبّ مَنفّ دَرِيُسِ مَ؛  
\v 7 «مَنفّ دَرِيُسِ، مُشُ بَرَ عِ شّيبُ.  
\v 8 مَنفّ، مُشُ شَ عِ رَكٌلٌن مُشُ بَرَ سِفَ يُدَيَ بْشِ مَ، عٍ نَ عَلَ شُنفبٍ شَ هْرْ مْبَنشِ تِقٍ دّننَشّ. يُوِقِيٍ نَ عَ تِقٍ فّمّ شُنفبٍيٍ رَ، وُرِيٍ سَشِ عَ كْن نَ. عٍ شَ وَلِ نَ سْونّيَقٍ عَ قَنيِ رَ.  
\v 9 مُشُ بَرَ عٍ شَ قٌرِيٍ مَشْرِن، ‹ندٍ وٌ يَمَرِشِ وٌ شَ يِ سَلِدٍ نُن يِ تّتّ تِ؟›  
\v 10 مُشُ مَن بَرَ عٍ شَ يَرٍرَتِيٍ شِلِيٍ مَشْرِن، عَلَكٌ مُشُ شَ نٍيٍ قَلَ عِ بّ.» 
\p  
\v 11 «كْنْ عٍ مُشُ يَابِشِ يِ مَسٍنيِ نَن نَ؛ ‹عَلَ شَ كٌنيِيٍ نَن مُشُ رَ، نَشَن كٌورٍ نُن بْشِ دَاشِ. مُشُ وَ مَ عَ شَ هْرْ مْبَنشِ نَن تِقٍ، عِسِرَيِلَ مَنفّ شُنفبٍ ندٍ نُ بَرَ نَشَن سِنفٍ تِ تّمُي شْنكُيٍ.  
\v 12 كْنْ كَبِ مُشُ بٍنبَيٍ عَلَ كٌورٍ دَا مَنفّ رَشْنْ، عَ نَشَ عٍ قِندِ بَبِلْن مَنفّ نٍبُكَدَنسَرِ شَ كٌنيِيٍ رَ. نَ كَلِدِكَ نَشَ يِ سَلِدٍ كَنَ، عَ مَن قَ بٍكَيٍ شَنِن بَبِلْن.  
\v 13 نَ وَشَتِ دَنفِ شَنبِ، سِرُ سِ نَشَ قِندِ بَبِلْن مَنفّ رَ، عَ قَ يَامَرِ قِ عَ شَ مَنفّيَ حّ سِنفٍ رَ، عَلَ شَ هْرْ مْبَنشِ مَن شَ تِ.  
\v 14 مَنفّ سِرُ سِ نَشَ شّيمَ نُن فبٍتِ بَ بَبِلْن سَلِدٍ كُي، بَبِلْن مَنفّ نٍبُكَدَنسَرِ نَشَن تٌنفٌشِ دَرِ سَلَمُ سَلِدٍ كُي، عَ نَ بِرِن سٌ سّسّبَسَرِ يِ رَ، عَ نَشَن تِ يُدَيَ فٌمِنَ رَ.  
\v 15 عَ نَشَ عَ قَلَ عَ بّ، «يِ سٍ بِرِن شَنِن دَرِ سَلَمُ، عٍ شَ رَ سٌ عَلَ شَ هْرْ مْبَنشِ كُي. وٌ شَ عَلَ شَ بَنشِ تِ عَ يِرٍ قٌرِ.»  
\v 16 سّسّبَسَرِ تٌ قَ دَرِ سَلَمُ، عَ نَشَ عَلَ شَ هْرْ مْبَنشِ كْورِن. سَ كٍلِ نَ لْشْي مَ قَ دْشْ تٌ رَ، مُشُ نَ نَ وَلِ نَن قَرِ، كْنْ عَ مُ حْنشِ سِندٍن.›» 
\p  
\v 17 «مَنفّ، نَ كُي شَ عِ بَرَ تِن عَ رَ، عِ شَ مَنفّ تَرُشُي قٌرِيٍ مَتٌ، عَلَكٌ عِ شَ عَ كٌلٌن شَ مَنفّ سِرُ سِ يَامَرِ قِ نّ عَلَ شَ هْرْ مْبَنشِ شَ تِ دَرِ سَلَمُ. نَ تّمُي، عِ شَ عِ سَفٌ مَسٍن مُشُ بّ نَ قٍ مَ.» 
\c 6  
\s1 هْرْ مْلِنفِرَ رَبِقٍ 
\p  
\v 1 مَنفّ دَرِيُسِ نَشَ مِشِيٍ يَمَرِ عٍ شَ نَ تَرُشُي قٌرِيٍ قٍن بَبِلْن نَاقُلِ رَفَتَشِ دّننَشّ.  
\v 2 عٍ نَشَ سّبّلِ ندٍ تٌ عَشَمٍتَ تَا كُي مٍدِيَ بْشِ مَ نَشَن يِ مَسٍنشِ؛  
\v 3 «مَنفّ سِرُ سِ شَ مَنفّيَ حّ سِنفٍ، عَ نَشَ عَ يَمَرِ عَ عَلَ شَ هْرْ مْبَنشِ، نَشَن نُ نَ دَرِ سَلَمُ، عَ مَن شَ فبِلٍن تِ رَ، عَلَكٌ سّرّشّيٍ شَ بَ مّننِ. عَ شَ تِ فّمّ شُنفبٍيٍ قَرِ. عَ شَ عِتٍ نُن عَ شَ فبٌي شَ لَن نْنفْن يَ تٌنفٌ سٍننِ مَ.  
\v 4 فّمّ مَسٌلِشِ شَ قِندِ سَقّ سَشَن نَ، وُرِ نّينّ قَن شَ قِندِ سَقّ كٍرٍن نَ. نَ وَلِ سَرٍ شَ كٍلِ مَنفَسَنيِ شَ نَاقُلِ كُي.  
\v 5 مَنفّ نٍبُكَدَنسَرِ سٍ نَشٍيٍ تٌنفٌ دَرِ سَلَمُ هْرْ مْبَنشِ كُي، يِرَبَسٍ شّيمَ نُن فبٍتِ دَاشِيٍ، نٍيٍ بِرِن شَ رَفبِلٍن، عٍ شَ رَ سٌ عَلَ شَ هْرْ مْبَنشِ كُي نَشَن تِمَ دَرِ سَلَمُ.» 
\p  
\v 6 «نَ نَن عَ رَ، سَمَرِ فٌمِنَ تَتٍنَيِ، سٍتَرَ بٌسٍنَيِ، نُن وٌ شَ كُنتِفِيٍ، وٌ فبِلٍن يِ قٍ قْشْ رَ.  
\v 7 وٌ شَ عَ لُ يُوِقِ فٌمِنَ نُن عٍ شَ قٌرِيٍ شَ عَلَ شَ هْرْ مْبَنشِ تِ عَ يِرٍ قٌرِ.  
\v 8 ﭑ بَرَ وٌ يَمَرِ نَ يُوِقِيٍ شَ وَلِ شَ قٍ رَ، وٌ شَ وٌ شَ دُوتِيٍ قِ عٍ تَن نَن مَ، عَ شَ قِندِ نَ وَلِ سَرٍ رَ، عَلَكٌ عَلَ شَ بَنشِ تِقٍ شَ سْونّيَ.  
\v 9 عٍ هَيِ نَ قٍ نَشَن بِرِن مَ، عَ شَ قِندِ كٌورٍ عَلَ شَ سّرّشّ فَن دَاشِ رَ، وٌ شَ نَ قِ عٍ شَ سّرّشّدُبّيٍ مَ، عَلْ تُورَ يْرّ، يّشّي كٌنتٌنيِ، يّشّي، مّنفِ، قْشْي، وّنِ، نُن تُرٍ. وٌ شَ نَ قِ عٍ مَ لْشْ يٌ لْشْ عَلْ عٍ وَ مَ عَ شْن مَ كِ نَشّ. وٌ نَشَ نَ وَلِ لُ نَ دٍ،  
\v 10 عَلَكٌ عٍ شَ سّرّشّ قَنيِ بَ كٌورٍ عَلَ بّ، عٍ مَن شَ دُبَ مَنفّ نُن عَ شَ دِيٍ بّ.  
\v 11 ﭑ بَرَ يِ يَامَرِ سَ نَ قَرِ؛ مِشِ يٌ نَشَن تٌندِ ﭑ مَ سّرِيّ رَتِنمّدٍ، وٌ شَ وُرِ كٍرٍن بَ نَ كَنيِ شَ بَنشِ مَ، وٌ شَ عَ فبَكُ نَ وُرِ مَ. عَ شَ بَنشِ شَ كَنَ عَ شَ مَتَندِ شَ قٍ رَ.  
\v 12 مَنفّ نُن مِشِ نَشَن بِرِن كَتَمَ عٍ شَ عَلَ شَ هْرْ مْبَنشِ رَبِرَ، نَشَن تِشِ دَرِ سَلَمُ، عَلَ شَ نَ كَنيِيٍ قَن نَبِرَ. ﭑ تَن دَرِيُسِ، ﭑ مَ يَمَرِ نَن نَ كِ. قٌ وٌ شَ نَ رَبَ نّ تٍكُ.» 
\p  
\v 13 نَ كُي، سَمَرِ مَنفّ تَتٍنَيِ، سٍتَرَ بٌسٍنَيِ، نُن عٍ شَ كُنتِفِيٍ نَشَ نَ يَامَرِ رَبَتُ عَلْ مَنفّ دَرِيُسِ عَ يَمَرِشِ كِ نَشّ.  
\v 14 يُوِقِ شَ وَلِ نَشَ سْونّيَ عَ قَنيِ رَ عَلْ عٍ شَ قٌرِيٍ نُ وَ مَ عَ شْن مَ كِ نَشّ. عَننَبِ شَفَيِ نُن عِدٌ شَ دِ عَننَبِ سَكَرِ قَن نَشَ لُ عَلَ شَ مَسٍنيِ كَوَندِ رَ. عَلَ شَ هْرْ مْبَنشِ نَشَ تِ عَلْ عِسِرَيِلَ مَرِفِ عَلَ عَ يَمَرِشِ كِ نَشّ، ثٍرِ سٍ مَنفّيٍ سِرُ سِ، دَرِيُسِ، نُن عَتَسَكَسِ سَفٌ بُن مَ.  
\v 15 نَ هْرْ مْبَنشِ نَشَ فّ تِدٍ عَدَرِ كِكٍ، شِ سَشَن ندٍ، دَرِيُسِ شَ مَنفّيَ حّ سٍننِ ندٍ كُي. 
\p  
\v 16 عِسِرَيِلَ سّرّشّدُبّيٍ، لٍوِ بْنسْي، نُن حَمَ بِرِن نَشَن كٍلِشِ كٌنيِيَ كُي ثٍرِ سٍ بْشِ مَ، عٍ نَشَ عَلَ شَ هْرْ مْبَنشِ رَبِ سّيوّ رَ.  
\v 17 نَ لْشْي عٍ نَشَ تُورَ كّمّ، يّشّي كٌنتٌنيِ كّمّ قِرِن، نُن يّشّي كّمّ نَانِ بَ سّرّشّ رَ. عٍ مَن نَشَ سِ كٌنتٌنيِ قُ نُن قِرِن بَ يُنُبِ شَقَرِ سّرّشّ رَ عِسِرَيِلَ بْنسْي قُ نُن قِرِن شَ يُنُبِيٍ شَ قٍ رَ.  
\v 18 عٍ نَشَ سّرّشّدُبّيٍ نُن لٍوِ بْنسْي مِشِيٍ بِرِن تِ كَنكَن شَ وَلِ رَ هْرْ مْبَنشِ كُي دَرِ سَلَمُ، عَلْ عَ سّبّشِ تَوُرٍتَ مُنسَ كُي كِ نَشّ. 
\p  
\v 19 يُوِقِ نَشٍيٍ كٍلِشِ كٌنيِيَ كُي ثٍرِ سٍ بْشِ مَ، نٍيٍ نَشَ سَيَمَلٍكّ دَنفِ سَلِ رَبَ كِكٍ سِنفٍ شِ قُ نُن نَانِ ندٍ مَ.  
\v 20 سّرّشّدُبّيٍ نُن لٍوِ بْنسْي مِشِيٍ بِرِن نُ بَرَ عٍ يّتّ رَ سّنِيّن، عَلَكٌ عٍ شَ سَيَمَلٍكّ دَنفِ سَلِ سّرّشّ بَ عٍ نفَشَكٍرٍنيِيٍ، سّرّشّدُبّيٍ، نُن حَمَ بِرِن بّ، نَشٍيٍ كٍلِشِ كٌنيِيَ كُي ثٍرِ سٍ بْشِ مَ.  
\v 21 عِسِرَيِلَكَ نَشٍيٍ كٍلِ كٌنيِيَ كُي نُن عٍ دْشْبٌورٍ نَشٍيٍ فبِلٍن نَ بْشِ شَ نَامُنيِ قْشْ رَ، عٍ بِرِن نَشَ مَلَن يِرٍ كٍرٍن عِسِرَيِلَ مَرِفِ عَلَتَلَ شَ قٍ قٍنقٍ رَ.  
\v 22 عٍ نَشَ تَامِ لّبِنِتَرٍ سَلِ رَبَ شِ سٌلٌقٍرٍ بُن مَ سّيوّ كُي، بَرِ مَ عَلَتَلَ نُ بَرَ عَسِرِيَ مَنفّ بْحّ مَقِندِ عٍ بّ، عَلَكٌ عٍ شَ عِسِرَيِلَ مَرِفِ عَلَ شَ هْرْ مْبَنشِ تِ. 
\c 7  
\s1 عَننَبِ عٍسِدِرَ سِ شَ وَلِ 
\p  
\v 1 نَ وَشَتِ تٌ دَنفِ، ثٍرِ سٍ مَنفّ عَتَسَكَسِ شَ مَنفّيَ بُن مَ، عَننَبِ عٍسِدِرَ سِ نَشَ قَ دَرِ سَلَمُ. 
\q1 عٍسِدِرَ سِ قِندِ سٍرَيَ شَ دِ نَن نَ. 
\q1 سٍرَيَ قِندِ عَسَرَيَ شَ دِ نَن نَ. 
\q1 عَسَرَيَ قِندِ شِلِكِيَ شَ دِ نَن نَ. 
\q1  
\v 2 شِلِكِيَ قِندِ سَلُمُ شَ دِ نَن نَ. 
\q1 سَلُمُ قِندِ سَدْكِ شَ دِ نَن نَ. 
\q1 سَدْكِ قِندِ عَشِتُبَ شَ دِ نَن نَ. 
\q1  
\v 3 عَشِتُبَ قِندِ عَمَرَيَ شَ دِ نَن نَ. 
\q1 عَمَرَيَ قِندِ عَسَرَيَ شَ دِ نَن نَ. 
\q1 عَسَرَيَ قِندِ مٍرَيٌتِ شَ دِ نَن نَ. 
\q1  
\v 4 مٍرَيٌتِ قِندِ سّرَشَيَ شَ دِ نَن نَ. 
\q1 سّرَشَيَ قِندِ يُسِيّلِ شَ دِ نَن نَ. 
\q1 يُسِيّلِ قِندِ بُوكِ شَ دِ نَن نَ. 
\q1  
\v 5 بُوكِ قِندِ عَبِسُوَ شَ دِ نَن نَ. 
\q1 عَبِسُوَ قِندِ قِنٍشَسِ شَ دِ نَن نَ. 
\q1 قِنٍشَسِ قِندِ عٍلٍيَسَرِ شَ دِ نَن نَ. 
\q1 عٍلٍيَسَرِ قِندِ هَرُنَ سّرّشّدُبّ كُنتِفِ شَ دِ نَن نَ. 
\p  
\v 6 عَننَبِ عٍسِدِرَ سِ نَشَ قَ دَرِ سَلَمُ كٍلِقٍ بَبِلْن بْشِ مَ. كَرَ مْشْ بٍلٍبٍلٍ نَن نُ عَ رَ، عَ تَوُرٍتَ مُنسَ كٌلٌن عَ قَنيِ رَ، عِسِرَيِلَ مَرِفِ عَلَتَلَ سّرِيّ نَشَن سٌ عَننَبِ مُنسَ يِ رَ. ثٍرِ سٍ مَنفّ نَشَ عَننَبِ عٍسِدِرَ سِ وَشْنقٍ بِرِن نَبَ عَ بّ، بَرِ مَ مِشِ نَ عَ رَ عَ مَرِفِ عَلَتَلَ حّنفِ سَشِ نَشَن شْن مَ.  
\v 7 عِسِرَيِلَكَ ندٍيٍ، سّرّشّدُبّيٍ، لٍوِكَيٍ، بّيتِبَيٍ، سَلِدٍ نَادّ كَنتَيٍ، عَ نُن وَلِكّيٍ، عٍ بِرِن نَشَ تٍ دَرِ سَلَمُ، مَنفّ عَتَسَكَسِ شَ مَنفّيَ حّ سٌلٌقٍرٍ ندٍ رَ.  
\v 8 عَننَبِ عٍسِدِرَ سِ سٌشِ دَرِ سَلَمُ، مَنفّ شَ مَنفّيَ حّ سٌلٌقٍرٍ كِكٍ سُولِ ندٍ نَن مَ.  
\v 9 عَ كٍلِ بَبِلْن كِكٍ سِنفٍ شِ سِنفٍ نّ، عَ نَشَ سٌ دَرِ سَلَمُ كِكٍ سُولِ ندٍ عَ شِ سِنفٍ ندٍ مَ، عَلَ شَ هِننّ سَابُي رَ.  
\v 10 عَننَبِ عٍسِدِرَ سِ نُ بَرَ عَ تُننَبّشِ شَرَنيِ مَ نُن عَلَتَلَ شَ سّرِيّ رَبَقٍ مَ. عَ نُ عَلَ شَ سّرِيّ تِنشِنشِ مَسٍنمَ نّ عِسِرَيِلَكَيٍ بّ. 
\p  
\v 11 مَنفّ عَتَسَكَسِ يِ بَتَاشّ نَن سّبّ عَننَبِ عٍسِدِرَ سِ مَ، نَشَن قِندِ سّرّشّدُبّ نُن كَرَ مْشْ رَ، نَشَن عَلَ شَ سّرِيّ بِرِن كٌلٌن عِسِرَيِلَ شَ قٍ رَ.  
\v 12 «يِ بَتَاشّ كٍلِشِ ﭑ تَن عَتَسَكَسِ نَن مَ، مَنفّيٍ شَ مَنفّ، كَتَرَبِ عَننَبِ عٍسِدِرَ سِ مَ، نَشَن مِشِ شَرَنمَ كٌورٍ مَرِفِ عَلَ شَ سّرِيّ رَ.  
\v 13 ﭑ بَرَ يَامَرِ قِ عَلَكٌ عِ تَن شَ نْ عِسِرَيِلَكَيٍ، سّرّشّدُبّيٍ، نُن لٍوِ بْنسْي مِشِيٍ بِرِن شَنِندٍ دَرِ سَلَمُ، نَشٍيٍ نَ بٍ ثٍرِ سٍ بْشِ مَ كْنْ عٍ وَ مَ سِفَقٍ نَا.  
\v 14 ﭑ تَن مَنفّ نُن ﭑ مَ سَنتِفِ سٌلٌقٍرٍ نَن عِ شّيشِ، عِ شَ سَ عَ مَتٌ يُدَيَكَيٍ نُن دَرِ سَلَمُكَيٍ نَ عَلَ شَ سّرِيّ رَبَتُقٍ كِ نَشّ. نَ كِتَابُي نَ عِ يِ رَ.  
\v 15 عِ مَن شَ فبٍتِ نُن شّيمَ شَنِن، ﭑ تَن نُن ﭑ مَ سَنتِفِيٍ نَشَن حَنِفٍشِ عِسِرَيِلَ مَرِفِ عَلَ بّ نَشَن نَ دَرِ سَلَمُ.  
\v 16 عِ مَن شَ فبٍتِ نُن شّيمَ شَنِن، بَبِلْنكَيٍ نَشَن سٌمَ عِ يِ رَ، عَ نُن عِسِرَيِلَكَيٍ نُن عٍ شَ سّرّشّدُبّيٍ نَشَن حَنِفٍمَ عٍ مَرِفِ عَلَ شَ هْرْ مْبَنشِ بّ نَشَن نَ دَرِ سَلَمُ.  
\v 17 عِ شَ تُورَيٍ، يّشّي كٌنتٌنيِيٍ، يّشّييٍ، مّنفِ، نُن وّنِ سَرَ نَ نَاقُلِ رَ، عٍ شَ بَ سّرّشّ رَ وٌ مَرِفِ عَلَ شَ سّرّشّبَدٍ مَ دَرِ سَلَمُ.  
\v 18 عِ تَن نُن عِ نفَشَكٍرٍنيِيٍ نَ وَ قٍ نَشَن نَبَقٍ يِ فبٍتِ نُن شّيمَ دْنشْي رَ، وٌ شَ عَ رَبَ عَلْ عَلَ وَ مَ عَ شْن مَ كِ نَشّ.  
\v 19 عِ شَ سِفَ يِرَبَسٍيٍ بِرِن نَ، مُشُ بَرَ نَشٍيٍ سٌ عِ يِ رَ، نَشٍيٍ لَن عٍ شَ رَوَلِ وٌ مَرِفِ عَلَ شَ بَنشِ كُي. عِ شَ نَ دّنتّفّ عَلَ بّ دَرِ سَلَمُ.  
\v 20 شَ عِ هَيِ نَ كْبِرِ فبّتّ مَ، عِ شَ عَ تٌنفٌ مَنفّ شَ نَاقُلِ يِرٍ عَلَكٌ عِ مَرِفِ عَلَ شَ بَنشِ وَلِ شَ سْونّيَ.» 
\p  
\v 21 «ﭑ تَن مَنفّ عَتَسَكَسِ بَرَ يَامَرِ قِ ﭑ مَ كْبِرِ يِرٍ شُنيِيٍ مَ نَشَن نَ شُرٍ نَاكِرِ مَ، شَ عَ سَ عَ لِ عَننَبِ عٍسِدِرَ سِ، عَلَ شَ سّرّشّدُبّ نَشَن مِشِ شَرَنمَ كٌورٍ عَلَ شَ سّرِيّ رَ، شَ عَ هَيِ نَ كْبِرِ ندٍ مَ، وٌ شَ عَ سٌ عَ يِ رَ،  
\v 22 هَن فبٍتِ كِلٌ وُلُ سَشَن، كِلٌ كّمّ نَانِ، مّنفِ شْرِ بُسَلِ وُلُ كٍرٍن، وّنِ لِتِرِ وُلُ قِرِن، لِتِرِ كّمّ قِرِن، تُرٍ لِتِرِ وُلُ قِرِن، لِتِرِ كّمّ قِرِن، عَ نُن قْشْي عَ نَ وَ نَشَن شَسَبِ شْن.  
\v 23 وٌ شَ كٌورٍ عَلَ شَ يَامَرِ بِرِن نَبَ عَ قَنيِ رَ عَ شَ هْرْ مْبَنشِ شَ قٍ رَ، عَلَكٌ عَ نَشَ شْنْ وٌن مَ مَنفّيَ مَ عَ نُن ﭑ مَ دِيٍ مَ.  
\v 24 وٌ نَشَ دُوتِ يٌ رَ سُشُ يِ مِشِيٍ يِ رَ، هَلِ بْشِ عِفِرِ سَرٍ. وٌ نَشَ سٍسٍ بَ يِ سّرّشّدُبّيٍ يِ رَ، عَ نُن لٍوِ بْنسْي مِشِيٍ، بّيتِبَيٍ، سَلِدٍ نَادّ كَنتَيٍ، وَلِكّيٍ، عَ نُن نَشٍيٍ بِرِن وَلِمَ عَلَ شَ بَنشِ كُي.» 
\p  
\v 25 «عِ تَن عَننَبِ عٍسِدِرَ سِ، عِ شَ مَنفّيٍ نُن كِيتِسَيٍ تِ حَمَ بّ نَشٍيٍ نَ شُرٍ نَاكِرِ مَ عَلْ عَلَ عَ مَسٍنمَ عِ بّ كِ نَشّ لْننِ كِ مَ. عٍ شَ عَلَ شَ حَمَ يَمَرِ تِنشِنيِ رَ. عِ شَ عَلَ شَ سّرِيّ مَسٍن مِشِيٍ بّ نَشٍيٍ مُ عَ كٌلٌن.  
\v 26 مِشِ يٌ نَشَن مُ عِ مَرِفِ عَلَ شَ سّرِيّ رَبَتُ، عَ نُن مَنفّ شَ سّرِيّيٍ، نَ كَنيِ شَ قَشَ، شَ نَ مُ عَ شَ كٍرِ بْشِ مَ، شَ نَ مُ عَ شَ كْبِرِ بَ، شَ نَ مُ عَ شَ سَ فٍيلِ.» 
\p  
\v 27 تَنتُي نَ عَلَتَلَ بّ، وٌن بٍنبَيٍ مَرِفِ عَلَ، نَشَن مَنفّ بْحّ رَقَلَشِ عَ شَ وَلِ بِرِن مَ عَلَتَلَ شَ هْرْ مْبَنشِ تِقٍ رَ دَرِ سَلَمُ.  
\v 28 مَرِفِ بَرَ هِننّ ﭑ نَ مَنفّ نُن عَ شَ سَنتِفِيٍ نُن عَ شَ بَتُلَيٍ يَ شْرِ. ﭑ مَرِفِ عَلَتَلَ تٌ نَ سّنبّ قِ ﭑ مَ، ﭑ نَشَ عِسِرَيِلَ كُنتِفِيٍ مَلَن عَلَكٌ مُشُ بِرِن شَ تٍ. 
\c 8  
\s1 عَننَبِ عٍسِدِرَ سِ شَ بِيَاسِ 
\p  
\v 1 دٍنبَيَ كَنيِيٍ شِلِ نَن يَ، نَشٍيٍ ﭑ مَتِ كٍلِقٍ بَبِلْن سِفَقٍ رَ دَرِ سَلَمُ مَنفّ عَتَسَكَسِ شَ وَشَتِ؛ 
\q1  
\v 2 فٍرِ سٌمِ، نَشَن كٍلِ قِنٍشَسِ شَبِلّ. 
\q1 دَنِيّلِ، نَشَن كٍلِ عِتَمَرِ شَبِلّ. 
\q1 شَتُسِ، نَشَن كٍلِ دَوُدَ شَبِلّ. 
\q1  
\v 3 سّكَنَيَ شَ دِ ندٍ. 
\q1 سَكَرِ نُن شّمّ كّمّ تٌنفٌ سُولِ، نَشٍيٍ كٍلِ ثَرٌ سٌ شَبِلّ. 
\q1  
\v 4 عٍلِيٍهٌوٍنَيِ، نَشَن كٍلِ مٌوَبَ ثَشَتِ شَبِلّ. 
\q1 سّرَشَيَ شَ دِ ندٍ نُن مِشِ كّمّ قِرِن. 
\q1  
\v 5 سّكَنَيَ شَ دِ ندٍيٍ. 
\q1 يَشَسِيٍلِ شَ دِ ندٍ نُن مِشِ كّمّ سَشَن. 
\q1  
\v 6 عٍبٍدِ، نَشَن كٍلِ عَدِن شَبِلّ. 
\q1 يٌنَتَن شَ دِ نُن مِشِ تٌنفٌ سُولِ. 
\q1  
\v 7 يّسَيَ، نَشَن كٍلِ عٍلَمَ شَبِلّ. 
\q1 عَتَلَيَ شَ دِ، نُن مِشِ تٌنفٌ سٌلٌقٍرٍ. 
\q1  
\v 8 سٍبَدَيَ، نَشَن كٍلِ سّقَتَيَ شَبِلّ. 
\q1 مِكَيٍلِ شَ دِ ندٍ نُن مِشِ تٌنفٌ سٌلٌمَسَشَن. 
\q1  
\v 9 عَبَدِيَسِ، نَشَن كٍلِ يٌوَبَ شَبِلّ. 
\q1 يّشِيّلِ شَ دِ نُن مِشِ كّمّ قِرِن مِشِ قُ نُن سٌلٌمَسَشَن. 
\q1  
\v 10 سٍلٌمِتِ شَ دِ ندٍيٍ. 
\q1 يٌسِقِيَ شَ دِ نُن مِشِ كّمّ مِشِ تٌنفٌ سٍننِ. 
\q1  
\v 11 سَكَرِ، نَشَن كٍلِ بِبَيِ شَبِلّ، عَ نُن مِشِ مْشْحّن نُن سٌلٌمَسَشَن. 
\q1  
\v 12 يٌشَنَن، نَشَن كٍلِ عَسِفَدِ شَبِلّ، عَ نُن مِشِ كّمّ مِشِ قُ. 
\q1  
\v 13 عٍلِقٍلٍتِ، يُوّلِ، نُن سٍمَيَ، نَشٍيٍ كٍلِ عَدٌنِكَمَ شَبِلّ، نُن مِشِ تٌنفٌ سٍننِ. 
\q1  
\v 14 عُتَيِ نُن سَبُدُ، نَشٍيٍ كٍلِ بٍفِقَيِ شَبِلّ، نُن مِشِ تٌنفٌ سٌلٌقٍرٍ. 
\p  
\v 15 ﭑ نَشَ يِ مِشِيٍ مَلَن شُرٍ دّ رَ، شُرٍ نَشَن فٌرٌ مَ عَهَوَ. مُشُ نَشَ لُ مّننِ شِ سَشَن. ﭑ تٌ حَمَ مَتٌ، ﭑ نَشَ عَ رَكْرْ سِ عَ سّرّشّدُبّيٍ نُ نَ، كْنْ لٍوِ بْنسْي مِشِيٍ مُ نُ نَ حَمَ يَ مَ.  
\v 16 ﭑ نَشَ يِ كُنتِفِيٍ شِلِ؛ عٍلِيٍسٍرِ، عَرِيّلِ، سٍمَيَ، عٍلِنَتَن، يَرِبُ، عٍلِنَتَن، نَتَن، سَكَرِ، نُن مٍسُلَمَ. ﭑ نَشَ كَرَ مْشْ يٌيَرِبُ نُن عٍلِنَتَن قَن شِلِ.  
\v 17 ﭑ نَشَ عٍ شّي كَسِقِيَ، مَنفّ عِدٌ شْنيِ. ﭑ نَشَ عَ قَلَ عٍ بّ عٍ شَ عِدٌ نُن عَ نفَشَكٍرٍنيِيٍ مَيَندِ عٍ شَ مِشِ ندٍيٍ سٌ مُشُ يِ رَ نَشٍيٍ نْمَ وَلِدٍ وٌن مَرِفِ عَلَتَلَ شَ هْرْ مْبَنشِ كُي.  
\v 18 وٌن مَرِفِ عَلَ نَشَ مُشُ مَلِ نَ قٍ كُي، عٍ قَ مَشَلِ شَ دِ سٍرٍبِيَ شّي، نَشَن كٍلِ لٍوِ بْنسْي مَ. شَشِلِمَ نَن نُ عَ رَ. عَ نَشَ قَ، عَ نُن عَ شَ دِيٍ، نُن عَ شُنيَيٍ. عٍ بِرِن نَلَنشِ مِشِ قُ نُن سٌلٌمَسَشَن.  
\v 19 شَسَبِيَ نُن يّسَيَ، نَشَن كٍلِ مٍرَرِ بْنسْي، نُن عٍ شُنيَيٍ نُن عٍ شَ دِيٍ، عٍ قَن نَشَ قَ. عٍ لَن مِشِ مْشْحّن نَن مَ.  
\v 20 عٍ نَشَ قَ هْرْ مْبَنشِ وَلِكّ كّمّ قِرِن نُن مْشْحّن نَ، عَلْ مَنفّ دَوُدَ نُن بْشِ كُنتِفِيٍ نُ بَرَ نَتّ تٌنفٌ كِ نَشّ. نٍيٍ شَ لُ لٍوِ بْنسْي مِشِيٍ شَ يَامَرِ بُن مَ. عٍ شِلِيٍ بِرِن نُ سّبّشِ. 
\p  
\v 21 نَ تّمُي، ﭑ نَشَ عَ قَلَ مِشِ بِرِن بّ عَهَوَ شُرٍ دّ رَ، مُشُ شَ سُنيِ سُشُ، مُشُ شَ مُشُ مَفٌرٌ مُشُ مَرِفِ عَلَ بّ، عَلَكٌ مُشُ شَ عَ مَشَندِ عَ شَ مُشُ شَ بِيَاسِ سْونّيَ مُشُ تَن نُن مُشُ شَ دِيٍ بّ. عَ شَ مُشُ هَرِفٍ بِرِن كَنتَ.  
\v 22 ﭑ يَافِشِ مَنفّ مَشْرِندٍ عَ شَ سْورِيٍ شَ سَ مُشُ مَتِ عَلَكٌ عٍ شَ مُشُ رَتَنفَ مُشُ يَشُييٍ مَ كِرَ شْن مَ. ﭑ نُ بَرَ عَ قَلَ مَنفّ بّ، «مُشُ مَرِفِ عَلَ مّينِمَ عَ قْشِرَبِرّيٍ مَ، كْنْ عَ شْنْمَ سّنبّ رَ مِشِ بِرِن مَ نَشَن عَ رَبٌلٌمَ.»  
\v 23 نَ نَن عَ تٌشِ مُشُ نَشَ سُنيِ سُشُ، مُشُ نَشَ مُشُ مَرِفِ عَلَ مَشَندِ. عَ نَشَ نَ دُبَ سُشُ. 
\p  
\v 24 ﭑ نَشَ مِشِ قُ نُن قِرِن سُفَندِ سّرّشّدُبّ كُنتِفِيٍ يَ مَ. نٍيٍ قِندِشِ سٍرٍبِيَ، شَسَبِيَ، نُن عٍ شُنيَ قُ نَن نَ.  
\v 25 ﭑ نَشَ فبٍتِ، شّيمَ، نُن يِرَبَسٍ مَنِيَ عٍ بّ، مَنفّ، عَ شَ سَنتِفِيٍ، عَ شَ مَنفّدِيٍ، نُن عِسِرَيِلَكَيٍ نَشٍيٍ سٌشِ مُشُ يِ رَ مُشُ مَرِفِ عَلَ شَ هْرْ مْبَنشِ بّ.  
\v 26 ﭑ نَشَن سٌشِ عٍ يِ رَ نَ نَن يَ؛ فبٍتِ كِلٌ وُلُ قُ نُن قِرِن، كِلٌ كّمّ، يِرَبَسٍ فبٍتِ دَاشِ كِلٌ وُلُ سَشَن كِلٌ كّمّ نَانِ، شّيمَ كِلٌ وُلُ سَشَن كِلٌ كّمّ نَانِ،  
\v 27 ثْوتِ شّيمَ دَاشِ مْشْحّن، نَشَن سَرٍ كْبِرِ كٌلٍ شّيمَ دَاشِ وُلُ كٍرٍن لِمَ، نُن يِرَبَسٍ قِرِن نَشَن يَءِلَنشِ يْشُي رَ. نَ سَرٍ فبٌ عَلْ شّيمَ سَرٍ.  
\v 28 ﭑ نَشَ عَ قَلَ عٍ بّ، «وٌ بَرَ قِندِ وٌ بٍنبَيٍ مَرِفِ عَلَتَلَ فبٍ رَ، وٌ تَن نُن يِ نَاقُلِ بِرِن. وٌ بِرِن بَرَ قِندِ سّرّشّ حَنِفٍشِ رَ عَ بّ.  
\v 29 وٌ شَ وٌ حّنفِ سَ يِ بِرِن شْن مَ هَن وٌ شَ سَ عَ دّنتّفّ سّرّشّدُبّ كُنتِفِيٍ بّ، لٍوِ بْنسْي مِشِيٍ نُن عِسِرَيِلَ شَبِلّ كُنتِفِيٍ بّ دَرِ سَلَمُ، عَلَتَلَ شَ هْرْ مْبَنشِ شَ نَاقُلِ رَفَتَمَ دّننَشّ.»  
\v 30 نَ نَن نَ كِ سّرّشّدُبّيٍ نُن لٍوِ بْنسْي مِشِيٍ نَشَ شّيمَ، فبٍتِ، نُن يِرَبَسٍ مَنِيَشِيٍ سْتْ، عٍ نَشَن شَنِنمَ دَرِ سَلَمُ مُشُ مَرِفِ عَلَ شَ بَنشِ كُي. 
\p  
\v 31 مُشُ نَشَ كٍلِ عَهَوَ شُرٍ دّ رَ سِفَقٍ رَ دَرِ سَلَمُ، كِكٍ سِنفٍ شِ قُ نُن قِرِن ندٍ رَ. عَلَ نَشَ مُشُ رَتَنفَ مُشُ يَشُييٍ مَ كِرَ شْن مَ.  
\v 32 مُشُ تٌ سٌ دَرِ سَلَمُ، مُشُ نَشَ مُشُ مَلَبُ شِ سَشَن.  
\v 33 عَ شِ نَانِ ندٍ، مُشُ نَشَ شّيمَ، فبٍتِ، نُن يِرَبَسٍيٍ مَنِيَ عَلَ شَ هْرْ مْبَنشِ كُي. مُشُ نَشَ نَ سٌ سّرّشّدُبّ مٍرٍ مٌتِ، عُرِيَ شَ دِ يِ رَ، قِنٍشَسِ شَ دِ عٍلِيٍسٍرِ، نُن يٍسُوَ شَ دِ يٌسَبَدِ، نُن بِنُوِ شَ دِ نٌوَدِيَ يَ شْرِ. عٍ بِرِن قِندِشِ لٍوِ بْنسْي مِشِيٍ نَن نَ.  
\v 34 عٍ تٌ فّ نَ بِرِن كْنتِدٍ نُن عَ مَنِيَدٍ، عٍ نَشَ نَ شَسَبِ سّبّ. 
\p  
\v 35 حَمَ نَشَن كٍلِ كٌنيِيَ ثٍرِ سٍ بْشِ مَ، نٍيٍ نَشَ سّرّشّ فَن دَاشِ بَ عِسِرَيِلَ مَرِفِ عَلَ بّ. نَ قِندِ تُورَ قُ نُن قِرِن نَن نَ عِسِرَيِلَ بْنسْي بِرِن بّ، نُن يّشّي كٌنتٌنيِ تٌنفٌ سٌلٌمَنَانِ نُن سٍننِ، يّشّي تٌنفٌ سٌلٌقٍرٍ نُن سٌلٌقٍرٍ، نُن سِكْتّ قُ نُن قِرِن. نَ قِندِ يُنُبِ شَقَرِ سّرّشّ نَن نَ عَ فَن دَاشِ.  
\v 36 عٍ نَشَ مَنفّ شَ يَامَرِ سٌ عَ رَ سِمَيٍ نُن عَ شَ فٌمِنَيٍ يِ رَ، نَشٍيٍ نُ نَ نَاكِرِ مَ، عَلَكٌ عٍ شَ عِسِرَيِلَكَيٍ مَلِ عَلَ شَ بَنشِ تِدٍ. 
\c 9  
\s1 سِ فبّتّ فِنّيٍ دْشْقٍ 
\p  
\v 1 نَ قٍ بِرِن تٌ بَ عَ رَ، كُنتِفِيٍ نَشَ قَ ﭑ يِرٍ، عٍ نَشَ عَ قَلَ ﭑ بّ، عٍ نَشّ، «عِ شَ عَ كٌلٌن عَ عِسِرَيِلَكَيٍ، سّرّشّدُبّيٍ، نُن لٍوِ بْنسْي مُ فبِلٍنشِ سِ فبّتّيٍ شَ نَامُنيِ حَاشِيٍ قْشْ رَ. عٍ بَرَ بِرَ كَنَانكَيٍ، شِتِكَيٍ، ثٍرِ سِكَيٍ، يٍبُسُكَيٍ، عَمٌنِكَيٍ، مٌوَبَكَيٍ، مِسِرَكَيٍ، نُن عَمٌرِكَيٍ شَ وَلِ كٌبِيٍ قْشْ رَ.  
\v 2 عٍ بَرَ نَ سِيٍ شَ دِ فِنّيٍ دْشْ، عٍ مَن بَرَ عٍ قٍن قُتِ رَ عٍ شَ دِيٍ بّ. عٍ بَرَ وٌن مَ سِ سّنِيّنشِ مَسُنبُ سِ فبّتّيٍ رَ. قٌرِيٍ نُن كُنتِفِيٍ نَن سِنفٍ نَ قٍ رَقْلْ.» 
\p  
\v 3 ﭑ تٌ نَ مّ، ﭑ نَشَ ﭑ مَ دٌنمَيٍ عِبْو، ﭑ نَشَ ﭑ شُنسّشّ نُن دّ شَبٍ مَتَلَ، ﭑ قَ دْشْ يِفِتّفّ كُي.  
\v 4 مِشِ نَشٍيٍ قِندِ عَلَ يَرَفَاشُييٍ رَ، نٍيٍ بِرِن نَشَ قَ ﭑ يِرٍ نَ مِشِيٍ شَ وَلِ كٌبِ شَ قٍ رَ. ﭑ نَشَ لُ نَا هَن نُنمَرٍ سّرّشّ تّمُي.  
\v 5 نُنمَرٍ سّرّشّ تّمُي، ﭑ نَشَ سِفَ، ﭑ نَشَ ﭑ شِنبِ سِن، ﭑ نَن ﭑ بّلّشّ تِ ﭑ مَرِفِ عَلَتَلَ بّ ﭑ مَ دٌنمَ عِبْوشِيٍ رَ ﭑ مَ.  
\v 6 ﭑ نَشَ عَ قَلَ، «ﭑ مَرِفِ، ﭑ بَرَ كْنتْقِلِ، ﭑ بَرَ يَافِ عِ شْن مَ، بَرِ مَ مُشُ شَ يُنُبِيٍ عِ مَبِرِ بَرَ فبٌ هَن عَ بَرَ دَنفِ عَ عِ.  
\v 7 كٍلِقٍ مُشُ بٍنبَيٍ شَ تّمُي مَ، قَ دْشْ تٌ رَ، مُشُ نَ نَ وَلِ كٌبِيٍ نَن قَرِ. نَ نَ عَ رَ، عِ بَرَ مُشُ نُن مُشُ شَ مَنفّيٍ نُن مُشُ شَ سّرّشّدُبّيٍ حَشَنكَتَ. عِ بَرَ مُشُ لُ سِ فبّتّيٍ يِ رَ، عٍ شَ مُشُ قَشَ سَنتِدّفّمَ رَ، عٍ شَ مُشُ شَنِن، عٍ شَ مُشُ هَرِفٍ بِرِن سُشُ. هَن تٌ مُشُ نَ نَ كْنتْقِلِ نَن كُي.  
\v 8 كْنْ يَكْسِ، يِ وَشَتِ دِ كُي، عِ تَن مُشُ مَرِفِ عَلَتَلَ بَرَ هِننّ مُشُ رَ، عِ بَرَ ندٍ رَكِسِ، عِ بَرَ مُشُ رَ سٌ عِ شَ يِرٍ سّنِيّنشِ، عَلَكٌ مُشُ شَ لِمَنِيَ، مُشُ شَ هّيرِ ندٍ سْتْ مُشُ شَ كٌنيِيَ كُي.  
\v 9 مُشُ نُ نَ كٌنيِيَ كُي، كْنْ مُشُ مَرِفِ عَلَ مُ مُشُ رَبٌلٌ. عَ نَشَ هِننّ مُشُ رَ ثٍرِ سٍ مَنفّيٍ يَ شْرِ. عَ نَشَ مُشُ رَكِسِ عَلَكٌ مُشُ شَ مُشُ مَرِفِ عَلَ شَ هْرْ مْبَنشِ تِ عَ نُ نَ دّننَشّ، مُشُ مَن شَ كَنتَرِ سْتْ يُدَيَ بْشِ مَ دَرِ سَلَمُ كُي.» 
\p  
\v 10 «يَكْسِ، مُشُ مَرِفِ عَلَ، مُشُ شَ مُنسٍ قَلَ سْنْن؟  
\v 11 مُشُ بَرَ عِ شَ سّرِيّ مَتَندِ، عِ سّرِيّ نَشَن سٌ مُشُ يِ رَ عِ شَ كٌنيِ دِ نَمِحْنمّيٍ سَابُي رَ. عٍ عَ قَلَ نّ، ‹وٌ قَمَ سٌدٍ بْشِ نَشَن مَ، وٌ لَن وٌ شَ دْشْ دّننَشّ، نَاكَيٍ شَ يُنُبِيٍ بَرَ فبٌ هَن عَ بَرَ دَنفِ عَ عِ. مّننِ بِرِن بَرَ قِندِ يِرٍ سّنِيّنتَرٍ رَ.  
\v 12 وٌ نَشَ تِن وٌ شَ دِيٍ قِدٍ نَاكَيٍ مَ. وٌ مَن نَشَ نَ دِ فِنّيٍ قَن تٌنفٌ وٌ شَ دِيٍ بّ. وٌ نَشَ سَاتّ يٌ تٌنفٌ عٍ بّ، وٌ مَن نَشَ بِرَ عٍ هَرِفٍ قْشْ رَ. شَ وٌ مُ بِرَ نَ قٍ حَاشِ مْولِيٍ قْشْ رَ، وٌ قَمَ نّ سّنبّ سْتْدٍ، وٌ نَ بْشِ دَشَمُي دٌنمَ نّ، وٌ شَ دِيٍ قَن قَمَ نَ بْشِ سْتْدٍ كّ رَ.›» 
\p  
\v 13 «مُشُ مَرِفِ، عِ بَرَ مُشُ حَشَنكَتَ مُشُ شَ يُنُبِيٍ شَ قٍ رَ، كْنْ نَ حَشَنكَتّ مُ فبٌ عَلْ مُشُ شَ يُنُبِ فبٌشِ كِ نَشّ. عِ بَرَ تِن مُشُ رَكِسِدٍ، مُشُ تَن نَشٍيٍ نَ بٍ يِ كِ.  
\v 14 مُنسٍ نْمَ عَ نِيَدٍ مُشُ مَن شَ فبِلٍن عِ شُي مَتَندِ رَ، هَن مُشُ نُن يِ سِ فبّتّيٍ شَ لُ يِرٍ كٍرٍن؟ شَ نَ نَ عَ رَ، عِ قَمَ شْنْدٍ مُشُ مَ هَن عِ مُشُ بِرِن هَلَكِ. مِشِ كٍرٍن مُ كِسِمَ.  
\v 15 عِسِرَيِلَ مَرِفِ عَلَتَلَ، عِ بَرَ تِن عِ شَ مُشُ رَكِسِ. مُشُ تِشِ عِ يَ تٌدٍ رَ، مُشُ تَن يُنُبِتْييٍ، هَلِ مِشِ سّنِيّنتَرٍ يٌ مُ دَشَ عَ شَ تِ عِ يَ تٌدٍ رَ.» 
\c 10  
\s1 مّيقٍ سِ فبّتّ فِنّيٍ رَ 
\p  
\v 1 عَننَبِ عٍسِدِرَ سِ تٌ نُ وَقٍ عَلَ شَ بَنشِ دّ رَ يُنُبِ شَقَرِ مَشَندِقٍ رَ، عِسِرَيِلَكَ فبٍفبٍ نَشَ قَ عَ سّيتِ مَ، شّمّيٍ، فِنّيٍ، عَ نُن دِ مّيٍ. عٍ قَن نَشَ وَ قْلْ كِ قَنيِ رَ.  
\v 2 عَوَ، يّشِيّلِ شَ دِ سّكَنَيَ، نَشَن كٍلِشِ عٍلَمَ بْنسْي، عَ نَشَ عَ قَلَ عَننَبِ عٍسِدِرَ سِ بّ، «مُشُ بَرَ وَلِ كٌبِ رَبَ نَشَن مُ رَقَن مُشُ مَرِفِ عَلَ مَ سِ فبّتّ دِ فِنّيٍ دْشْقٍ رَ. كْنْ هَلِ وٌن تٌ بَرَ نَ رَبَ، عَلَ تَن نْمَ وٌن نَكِسِدٍ.  
\v 3 وٌن شَ سَاتّ تٌنفٌ وٌن مَرِفِ عَلَ بّ مّيقٍ سِ فبّتّ فِنّيٍ رَ، عَلْ عِ تَن نُن عَلَ يَرَفَاشُييٍ وَ مَ عَ شْن مَ كِ نَشّ. وٌن شَ عَلَ شَ سّرِيّ رَبَتُ.  
\v 4 يَندِ، عِ شَ مُشُ مَلِ، مُشُ شَشِلِ تِشِ عِ تَن نَن نَ. مُشُ نَ عِ شَنبِ رَ. عِ عِ سّنبّ سٌ، عِ قٍ رَبَ نَشَن لَنمَ عَ شَ رَبَ.» 
\p  
\v 5 نَ تّمُي عَننَبِ عٍسِدِرَ سِ نَشَ سّرّشّدُبّ كُنتِفِيٍ، لٍوِ بْنسْي مِشِيٍ، نُن عِسِرَيِلَكَ بِرِن نَكَلِ نَ مَسٍنيِ رَ. عٍ تٌ فّ عٍ رَكَلِدٍ،  
\v 6 عَننَبِ عٍسِدِرَ سِ نَشَ كٍلِ عَلَ شَ بَنشِ نَادّ رَ، عَ سِفَ عٍلِيَسِبُ شَ دِ يٍهٌشَنَن شْنيِ. عَ نُ نَ نَا تّمُي نَشّ، عَ مُ سٍسٍ دٌن، عَ مَن مُ يٍ مِن حَمَ شَ وَلِ كٌبِ شَ قٍ رَ.  
\v 7 مَسٍنيِ نَشَ رَيٍنسٍن يُدَيَ نُن دَرِ سَلَمُ كُي، عَ مِشِ نَشَن بِرِن كٍلِ كٌنيِيَ كُي، عٍ شَ عٍ مَلَن دَرِ سَلَمُ.  
\v 8 كُنتِفِيٍ نُن قٌرِيٍ مَن نَشَ عَ قَلَ عَ مِشِ يٌ نَشَن تٌندِ مَ نَ رَ بٍينُن شِ سَشَن بُن، نَ كَنيِ هَرِفٍ بِرِن بَمَ نّ عَ يِ رَ، عَ مَن قَ كٍرِ عِسِرَيِلَكَيٍ يَ مَ نَشٍيٍ كٍلِشِ كٌنيِيَ كُي. 
\p  
\v 9 شِ سَشَن كَمَلِشِ لْشْي نَشّ، يُدَيَكَيٍ نُن بُنيَمِنكَيٍ نَشَ عٍ مَلَن دَرِ سَلَمُ. نَ نَشَ سَ لَن كِكٍ سٌلٌمَنَانِ شِ مْشْحّن ندٍ مَ. حَمَ نُ تِشِ عَلَ شَ بَنشِ دّ رَ. عٍ بِرِن نُ سّرّنمَ نَ لْشْي نَتّ تٌنفٌشِ شَ قٍ رَ، نُن تُنّ بٍلٍبٍلٍ قَن نُ نَ قَقٍ.  
\v 10 سّرّشّدُبّ عٍسِدِرَ سِ نَشَ كٍلِ، عَ عَ مَسٍن عٍ بّ، «وٌ بَرَ وَلِ حَاشِ رَبَ سِ فبّتّ فِنّيٍ دْشْقٍ رَ. نَ بَرَ قِندِ يُنُبِ شُنفبٍ رَ عِسِرَيِلَ بّ.  
\v 11 وٌ شَ وٌ شَ يُنُبِ مَسٍن وٌ بَبَيٍ مَرِفِ عَلَتَلَ بّ. وٌ مَن شَ عَ سَفٌ رَبَ. وٌ شَ فبِلٍن يِ سِ فبّتّ مِشِيٍ نُن عٍ شَ فِنّيٍ قْشْ رَ.» 
\p  
\v 12 حَمَ بِرِن نَشَ عَ يَابِ عٍ شُي عِتٍشِ رَ، «عَوَ، مُشُ بَرَ تِن نَ رَ، عَلْ عِ عَ قَلَشِ كِ نَشّ.  
\v 13 كْنْ حَمَ فبٌ، تُنّ قَن نَ قَقٍ يِ تّمُي. وٌن مُ نْمَ يِ قٍ يَ عِبَدٍ تَندٍ مَ. شِ كٍرٍن شَ نَ مُ عَ رَ شِ قِرِن قٍ مُ يِ كِ، بَرِ مَ مِشِ فبٍفبٍ بَرَ يُنُبِ قٍ رَبَ وٌن يَ مَ.  
\v 14 كُنتِفِيٍ شَ لُ بٍ حَمَ شِلِ رَ. نَشٍيٍ بِرِن سِ فبّتّ دِ فِنّيٍ دْشْشِ وٌن مَ تَايٍ كُي، عٍ شَ قَ كٍرٍن كٍرٍن يِ رَ وَشَتِ مَ نَشَن تٌنفٌشِ عٍ بّ. تَا يٌ تَا شَ قٌرِيٍ نُن كِيتِسَيٍ شَ نٍيٍ شَ قٍ مَتٌ هَن عَلَ دِحّمَ وٌن مَ تّمُي نَشّ.» 
\p  
\v 15 عَسَهّلِ شَ دِ يٌنَتَن نُن تِكِقَ شَ دِ يَشَسٍيَ نَشَ كَقُ مٍسُلَمَ نُن سَبّتَيِ لٍوِ بْنسْي مِشِ مَ، عٍ فبَنسَن مُ تِن نَ شَشِلِ رَ.  
\v 16 كْنْ عٍ بٌورٍ نَشٍيٍ كٍلِشِ كٌنيِيَ كُي، نٍيٍ نَشَ تِن نَ نَتّ تٌنفٌشِ رَ. عَننَبِ عٍسِدِرَ سِ سّرّشّدُبّ نَشَ كُنتِفِ كٍرٍن سُفَندِ شَبِلّ كٍرٍن كٍرٍن بِرِن يَ مَ. عٍ نَشَ نَ قٍ مَتٌ قْلْ كِكٍ قُ ندٍ، شِ سِنفٍ رَ.  
\v 17 كِكٍ سِنفٍ شِ سِنفٍ ندٍ رَ، عٍ نَشَ فّ نَ شّمّيٍ شَ قٍ يَ عِبَدٍ نَشٍيٍ فِنّ فبّتّيٍ دْشْ. 
\p  
\v 18 عَ نَشَ عَ لِ، سّرّشّدُبّيٍ قَن شَ دِ ندٍيٍ نُ بَرَ سِ فبّتّ فِنّيٍ دْشْ، عَلْ يٍسُوَ شَ دِ ندٍيٍ، يٌسَدَكِ شَ دِ، نُن عَ شُنيَيٍ، مَاسٍيَ، عٍلِيٍسٍرِ، يَرِبُ، نُن فّدَلَيَ.  
\v 19 عٍ نَشَ لَايِدِ تٌنفٌ عٍ شَ عٍ شَ فِنّيٍ بّحِن، عٍ مَن شَ يّشّي كٌنتٌنيِ بَ سّرّشّ رَ عٍ شَ يُنُبِ شَ قٍ رَ. 
\p  
\v 20 نٍيٍ شِلِيٍ نَن يَ؛ 
\q1 قَتَنقٍ عِمٍرِ شَبِلّ رَ؛ شَنَنِ نُن سٍبَدَيَ. 
\q1  
\v 21 قَتَنقٍ شَرِ مَ شَبِلّ رَ؛ مَاسٍيَ، عٍلِيَ، سٍمَيَ، يّشِيّلِ، نُن يُسِيَ. 
\q1  
\v 22 قَتَنقٍ ثَسُرَ شَبِلّ رَ؛ عٍلِيٌوٍنَيِ، مَاسٍيَ، سُمَيِلَ، نٍتَنٍيلِ، يٌسَبَدِ، عٍ نُن عٍلَاسَ. 
\q1  
\v 23 قَتَنقٍ لٍوِ بْنسْي رَ؛ يٌسَبَدِ، سِمٍيِ، كّلَيَ، نَشَن مَن شِلِ كٍلِتَ، ثٍتَشِيَ، يُدَيَ، نُن عٍلِيٍسٍرِ. 
\q1  
\v 24 كٍلِقٍ بّيتِبَيٍ يَ مَ؛ عٍلِيَسِبُ. 
\q1 كٍلِقٍ عَلَ شَ هْرْ مْبَنشِ نَادّ مَكَنتَمَيٍ يَ مَ؛ سَلُمُ، تٍلٍمِ، نُن عُرِ. 
\b  
\q1  
\v 25 بٌورٍ عِسِرَيِلَكَيٍ شِلِيٍ نَن يَ نَشٍيٍ نَ مْولِ رَبَشِ؛ 
\q1 قَتَنقٍ ثَرٌ سٌ شَبِلّ رَ؛ رَ مِيَ، يّسَيَ، مَلَكِيَ، مِيَمِن، عٍلِيٍسٍرِ، مَلَكِيَ، نُن بّنَيَ. 
\q1  
\v 26 قَتَنقٍ عٍلَمَ شَبِلّ رَ؛ مَتَنِيَ، سَكَرِ، يّشِيّلِ، عَبِدِ، يٍرٍ مٌتِ، نُن عٍلِيَ. 
\q1  
\v 27 قَتَنقٍ سَتُ شَبِلّ رَ؛ عٍلِيٌوٍنَيِ، عٍلِيَسِبُ، مَتَنِيَ، يٍرٍ مٌتِ، سَبَدِ، نُن عَسِسَ. 
\q1  
\v 28 قَتَنقٍ بِبَيِ شَبِلّ رَ يٍهٌشَنَن، شَنَنِيَ، سَبَيِ، نُن عَتّلَيِ. 
\q1  
\v 29 قَتَنقٍ بَنِ شَبِلّ رَ؛ مٍسُلَمَ، مَلُكُ، عَدَيَ، يَسُبُ، سٍيَلَ، نُن يٍرٍ مٌتِ. 
\q1  
\v 30 قَتَنقٍ مٌوَبَ ثَشَتِ شَبِلّ رَ؛ عَدِنَ، كٍلَلِ، بّنَيَ، مَاسٍيَ، مَتَنِيَ، بّسَلّلِ، بِنُوِ، نُن مَنَسِ. 
\q1  
\v 31 قَتَنقٍ شَرِ مَ شَبِلّ رَ؛ عٍلِيٍسٍرِ، يِسِيَ، مَلَكِيَ، سٍمَيَ، سِمّيْن،  
\v 32 بُنيَمِن، مَلُكُ، نُن سّمَرَيَ. 
\q1  
\v 33 قَتَنقٍ شَسُمَ شَبِلّ رَ؛ مَتٍنَيِ، مَتَتَ، سَبَدِ، عٍلِقٍلٍتِ، يٍرٍ مَيِ، مَنَسِ، نُن سِمٍيِ. 
\q1  
\v 34 قَتَنقٍ بَنِ شَبِلّ رَ؛ مَادَيِ، عَمَرَ مَ، يُوّلِ،  
\v 35 بّنَيَ، بّدٍيَ، كٍلُهَيِ،  
\v 36 قَنِيَ، مٍرٍ مٌتِ، عٍلِيَسِبُ،  
\v 37 مَتَنِيَ، مَتٍنَيِ، نُن يَاسُ. 
\q1  
\v 38 قَتَنقٍ بِنُوِ شَبِلّ رَ؛ سِمٍيِ،  
\v 39 سٍلٍمِيَ، نَتَن، عَدَيَ،  
\v 40 مَكِنَدٍبَيِ، سَسَيِ، سَرَيِ،  
\v 41 عَسَرّلِ، سٍلٍمِيَ، سّمَرَيَ،  
\v 42 سَلُمُ، عَمَرَيَ، نُن يُسُقُ. 
\q1  
\v 43 قَتَنقٍ نٍبٌ شَبِلّ رَ؛ يٍيِيٍلِ، مَتِتِيَ، سَبَدِ، سٍبِنَ، يِدٌ، يٌوٍلِ، نُن بّنَيَ. 
\m  
\v 44 يِ مِشِ بِرِن نُ بَرَ سِ فبّتّ فِنّيٍ دْشْ، ندٍ نُ بَرَ دِيٍ بَرِ.