\id ACT  
\h HECHOS 
\toc1 Le₂la₂ ca₂jmo₃ dsa₂ i₂chen₄ quián₅ Jesús 
\toc2 HECHOS 
\toc3 Hch. 
\mt1 Le₂la₂ ca₂jmo₃ dsa₂ i₂chen₄ quián₅ Jesús 
\c 1  
\s1 Jág₁ a₂cuë́₄ a₂chen₃ Diú₄ Jme₂dsí₂ Jŋió₅ 
\p  
\v 1 Ne₄ si₂ a₂ca₂jmo₃ jniá₂ le₂'uɨg₅₄, gui'₅₄ Teófilo,\f + \fr 1:1 \ft Teófilo: o₃, “'ne₂ i₂'nióg'₃ Diú₄.” \f* ca₂juá'₃ jniá₂ ca₂le₃jë́₃ a₂ca₂jmo₃ Jesús ca₂le₃ ca₂jme₃lióg₃ ca₂jme₃tag₂₃,  
\v 2 ca₂lia'₂ ca₂të́₂ jmɨg₄ a₂ca₂ŋái'₃ guei'₅₄ i₂juɨ́g₃. Né'₃ a₂dsáin'₃ guei'₅₄ i₂juɨ́g₃, ca₂quióin'₂ dsɨ₂guia₃-tɨ́n₂ i₂chen₄\f + \fr 1:2 \ft griego: apóstolous.\f* quiáin₅, ca₂chei₃ dsɨ₂'ë́₂ jág₁. Jaun₂ ca₂cuë₃ jág₁ të₂le₃ quian'₅₄ Jme₂dsí₂ Jŋió₅, ca₂le₃jë́₃ 'e₂ 'nió'₅ jmo₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ 'éi₂.  
\v 3 Cang₂ jme₁ca₂join₃, jme₁ma₂jein'₅₄ táng₃, ca₂ŋɨ₃ të₂láu₃ jmɨg₄ qui₂jme₂jniai₂₃ qui₂cuë́'₅ jág₁ dsau₅ chi'₂ dsɨ₂guia₃-tɨ́n₂ a₂të₃dsón'₂ bá₄ chain₂ ma₂jein'₅₄ táng₃; jaun₂ qui₂ca₂dsia₃ jág₁ quiain'₅₄ 'éi₂ juɨ₁lia'₂ 'a₂ lia'₂ lë́₅ ja₁gon₂ Diú₄. 
\p  
\v 4 Jme₁'en₅₄ guë́₄ Jesús quiain'₅₄ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅, jaun₂ ca₂juá'₂ ca₂tsɨ́'₃ 'éi₂ a₂tsá₃ dsɨ₃lein₃ dsɨ₂juɨ₅ juɨg₂ Jerusalén. Jaun₂ ca₂juá'₂: 
\p ―Jŋia₄ 'nia'₂, juɨ₁le₂ti₃ de'₂ jág₁ quió'₅ Ŋe'₃ a₂ma₂juɨ́g₂ 'nia'₂.  
\v 5 Dsau₅ bá₄ ca₂tióg₃ Juan₅₄ ca₂tiáin₂ jmɨg₂ dsa₂, la₁ 'nia'₂ guë'₂ në́₃ tióg₂ Diú₄ Jme₂dsí₂ Jŋió₅, të₃jë₄ la₂. 
\s1 Ca₂ŋá'₃ Jesús guei'₅₄ i₂juɨ́g₃ 
\r (Marcos 16:19; Lucas 24:50-53) 
\p  
\v 6 Co₂ráun₂ tion'₅₄ chi'₂ dsɨ₂guia₃-tɨ́n₂ le₁ŋɨi'₂ ja₁'en₅₄ Jesús, jaun₂ ca₂ŋɨ́i'₃ Jesús: 
\p ―Te₁gui'₅₄, ¿ma₂të́₂ ja₁jmó'₂ 'ne₂ a₂lión₂ dsa₂ juɨg₂ Israel? 
\p  
\v 7 Jaun₂ ca₂ŋag₃ Jesús: 
\p ―Tsá₃ ca₂tɨ́n'₂ 'nia'₂ le₃ŋi'₅₄ 'a₂ lia'₂ jmo₃ Diú₄ Jmei₂ 'éi'₃ ca₂le₃jë́₃ 'e₂ 'ió'₄, 'e₂ jmɨg₄ në́₃. 'Ŋiog₅ bá₄ Diú₄ Jmei₂ ŋi₅ a₂jaun₂.  
\v 8 Jë₁ma₂ca₂guen'₅₄ 'nia'₂ Jme₂dsí₂ quián₅ Diú₄, guéi'₁ 'nia'₂ juɨ₅bí₂, jaun₂ qui₂o₁nóg'₅ qui₂o₁'ë́'₃ jág₁ dsau₅ quió₃ juɨg₂ Jerusalén, le₂tan₅₄ juɨg₂ 'uë₃ Judea, 'uë₃ Samaria, ca₂le₃jë́₃ juɨg₂ ta₁caun₂ mɨ₂güɨ́g₃ në́₃. 
\p  
\v 9 Jme₁ma₂dsan₃ juá'₂ Jesús le₂në₅, ca₂uɨ́g₂ juɨ₅ guei'₅₄ i₂juɨ́g₃, ca₂ŋái'₃ ca₂lioin₂ jnei₅.  
\v 10 Të₃tión₂ jaun₂ chi'₂ dsɨ₂guia₃-tɨ́n₂ jág₅ guei'₅₄ jme₁ŋá'₃ Jesús, con'₂ tsá₃ jáin₅ jme₁ca₂jɨ́in₂ on₃ dsa₂ le₁qui'₂ 'mɨ'₂ tiog₂ jau₂, tión₂ cau₅ quió'₅.  
\v 11 Jaun₂ ca₂juá'₂ dsa₂ on₃ 'éi₂: 
\p ―'Nia'₂ dsa₂ chan₂ Galilea, tsá₃ ma₃ta₁ jmo₃ tión'₂ guë́₄ 'nia'₂ uë́₂ jág'₂ guei'₅₄. 'Ŋiog₅ Jesús në₅ i₂ŋá'₅ guei'₅₄ i₂juɨ́g₃ të₃jɨn'₄ 'nia'₂, le₂në₅ bá₄ jiá₃ táng₃ jë₁ma₂të́₂ rë₁jiá₃, juɨ₁lia'₂ në₂jɨin'₅₄ 'nia'₂ ŋái'₅ në₅. 
\s1 Ca₂quión'₂ dsa₂ Matías a₂jmo₃ ta₁ a₂jme₁lɨ́n₄ Judas 
\p  
\v 12 Jaun₂ në́₃ ca₂'uɨin₂ má'₂ ja₁chei₂ Olivos, ca₂o₃lein₃ táng₃ juɨg₂ Jerusalén, a₂niog₅ uɨ́ng₂ con'₂ ja₁'i₄ 'éi'₃ i₃nio₄ dsa₂ jme₁jmɨg₄ sa₅₄.\f + \fr 1:12 \ft Con'₂ tí₅ caun₂ kilómetro.\f* 
\v 13 Jme₁ca₂o₃lein₃ Jerusalén jaun₂, ca₂uɨ́g₂ cuarto guei'₅₄ ja₁ca₂jŋia₃. Dsa₂ 'éi₂ jme₁chein₂ Pe₄, Jacobo, Juan₅₄, Drë́₄, Fe₂li₄, To₁má₄, Bartolomé, Të₅₄, Jacobo ja₁ŋi'₅₄ Alfeo, Si₂mu₅₄ i₂lɨ́n₅ cananista,\f + \fr 1:13 \ft griego: celotes, co₂'nió'₄ dsa₂ i₂nau₂ quen₅; jan₂ i₂'nio₃ táun₂ 'uë₃ 'éi'₃ quió'₅ Roma. Jma₃quén₅ ca₂quioin₃ le₃on₃ Si₂mu₅₄ 'éi₂, ia₁ ŋɨ́₄ lë₃ mei'₂ tsá₃ ca₂ne₅₄ a₂chein₂.\f* quian'₅₄ Judas rɨn'₅₄ Jacobo.  
\v 14 Ca₂le₃jɨ́in₃ le₂jaun₂ jme₁ŋɨi'₂ i₂gú'₃ co₂lë₅ quiain'₅₄ o₁rɨn'₅₄ Jesús, María chog₅₄ Jesús, ca₂le₃jɨ́n₃ guë́₄ 'io₅₄ sián'₂ në́₃, a₂jme₁tsɨ́'₅ Diú₄. 
\p  
\v 15 Co₂ráun₂ jme₁lë́₂ con'₂ caun₂ 'ŋiá₂-lón₂ rë₂dsɨ́₂ guión₂ (120) dsa₂ 'én₂ i₂jme₁le₁ŋɨ'₂. Jaun₂ ca₂nau₂ Pe₄ të₃jë₄ jaun₂, jaun₂ ca₂juá'₂ ca₂tsɨ́'₃ dsa₂: 
\p  
\v 16 ―Rɨn'₅₄ jniog₄, co₂në₅ lë́₅ Si₂, tion₅₄ ca₂rë₃ti₃ jág₁ a₂ma₂'ë́₂ Jme₂dsí₂ quián₅ Diú₄ të₂le₃ quian'₅₄ 'lag₄ David, a₂ca₂'ɨin₃ Judas i₂ca₂jŋia₃ dsa₂ i₂ca₂i₁te₂ Jesús chi₁'ŋei'₂.  
\v 17 I₂jme₁quian'₅₄ bá₄ jniog₄ 'éi₂, jme₁lë́₄ rɨn'₅₄ jniog₄, i₂jme₁jmo₅ ta₁ le₂la₂ bá₄ 'éi₂ ján₃.  
\v 18 La₁ quian'₅₄ cu₄ 'lɨg'₅₄ a₂ca₂lɨ́'₃ Judas a₂ca₂'nɨi₃ Jesús, ca₂lá₃ 'uë₃. 'Uë₃ jaun₂ ca₂jmo₃ ca₂táin'₂ të₃ chi₁jɨ́in₂, qui₂ca₂'uë₂ ca₂le₃jë́₃ a₂jme₁tio'₅₄ tú'₅.  
\v 19 Jme₁ca₂rë₃ŋi₅ dsa₂ juɨg₂ Jerusalén, ca₂të́'₃ 'uë₃ jaun₂ Acéldama, co₂'nió'₄ a₂juá'₂: 'Uë₃ Jmɨ₂, quian'₅₄ jág₁ jmei₅ quió'₅.  
\v 20 Ia₁ le₂la₂ juá'₂ ne₄ Si₂ Salmos: 
\q1 Juɨ₁të₂tsɨ'₅₄ 'ŋiog₅ 'né₅ quió'₅, 
\q2 ia₁ 'i₁jan₂ tsá₃ 'ein₂ le₃tian'₃.\f + \fr 1:20 \ft Salmo 69:25.\f* 
\p Ján₃ guë'₂ juá'₂ táng₃: 
\q1 Dsa₂ sián'₂ juɨ₁jmo₅₄ ta₁ a₂jme₁lɨ́in₄.\f + \fr 1:20 \ft Salmo 109:8.\f* 
\p  
\v 21 ’Chan₂ bá₄ dsa₂ jë₄ la₂ quián₂ jniog₄ dsa₂ i₂ma₂ca₂jme₃quiong'₅₄ ca₂le₃jë́₃ jmɨg₄ lia'₂ con'₂ jme₁quian'₅₄ jniog₄ Te₁gui'₅₄ Jesús,  
\v 22 ca₂le₃ ca₂jŋó₂ Jesús jmɨg₂ a₂ca₂cho₃ Juan₅₄, ca₂lia'₂ jme₁ca₂uɨ́g₂ Jesús guei'₅₄ i₂juɨ́g₃. Jaun₂ tion₅₄ 'nió'₅ dsa₂ 'éi₂, jme₃quiong'₅₄ jniog₄, jaun₂ jáng'₃ jág₁ dsau₅ a₂ca₂jen'₅₄ táng₃ Jesús. 
\p  
\v 23 Jaun₂ ca₂jmo₃ jág₁ ca₂'ɨin₃ jan₂ i₂chen₂ José i₂të́'₂ Barsabás i₂të́'₂ Justo në́₃, quian'₅₄ jan₂ i₂chen₂ Matías.  
\v 24 Jaun₂ ca₂tsɨ́'₃ Diú₄ ca₂le₃jɨ́in₃, ca₂juá'₂ le₂la₂: 
\p ―Te₁gui'₅₄, 'ne₂ bá₄ i₂cuɨng'₂ të₂dsɨ́₅ ca₂le₃jɨ́n₃ dsa₂, 'ɨn₅₄ jnia'₅₄ 'ein₂ dsa₂ on₃ la₂ i₂ma₂quion'₅₄ 'ne₂,  
\v 25 ia₁jaun₂ jmo₃ ta₁ léin₂ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáng'₂ a₂jme₁lɨ́n₄ Judas, 'uɨg₅₄ dsáu₁ ca₂i₃'éin₂, ca₂ŋái'₃ ja₁ca₂tɨ́in₂. 
\p  
\v 26 Jaun₂ ca₂tóin'₂ ca₂co₃, ca₂dsi₂ jág₁. Jaun₂ i₂chen₂ Matías bá₄ ca₂tɨ́n₂ ta₁ jaun₂. Dsɨ₂juɨ₅ le₂jaun₂ bá₄ ca₂jme₃quiain'₅₄ dsa₂ guia₃-ján₃ i₂jme₁lë́₂ guë́₄ dsɨ₂guia₃-tɨ́n₂ i₂chen₄ quián₅ Jesús. 
\c 2  
\s1 Jme₁guan₃ Jme₂dsí₂ quián₅ Diú₄ 
\p  
\v 1 Jme₁ca₂të́₂ Jmɨg₄ Të₂láu₃-guiá₂, caun₂ bá₄ ja₁jme₁tion'₅₄ le₁ŋɨ'₂ ca₂le₃jɨ́n₃ dsa₂ i₂'én₂.  
\v 2 Con'₂ tsá₃ jáin₅ jme₁ca₂nág₂, ca₂lë₃ gau₂ ca₂jan₃ guei'₅₄ lia'₂ lë́₅ jë₁'ei₅ dsí₂ tiá₂ lɨn₃ ca₂lë₃, ca₂né'₂ ta₁caun₂ dsi₂néi₂ ja₁jme₁tion'₅₄ dsa₂.  
\v 3 Jaun₂ co₂tan₅₄ dsɨ₂juɨ₅ le₂jaun₂ qui₂ca₂séi'₂ tsɨ'₄ si₂ qui₂të₁tsɨ'₅₄ ne₄ quió'₅ dsa₂ 'éi₂, le₂jain₂ le₂jain₂.  
\v 4 Jaun₂ ca₂le₃jɨ́in₃ qui₂ca₂cain'₂ quian'₅₄ Jme₂dsí₂ Jŋió₅. Jaun₂ ca₂jme₃lióg₃ dsa₂ qui₂ca₂dsia₃ jág₁ jmei₅ siá'₂, lia'₂ con'₂ lë́₅ ca₂cuë₃ Jme₂dsí₂ a₂juá'₂ dsa₂. 
\p  
\v 5 Jmɨg₄ jaun₂ jme₁tion'₅₄ dsa₂ judíos juɨg₂ Jerusalén, i₂ja₂lén₂ ta₁caun₂ mɨ₂güɨ́g₃, a₂jme₂ti₃ con'₂ tag₄ chí'₅ quió'₅.  
\v 6 Jme₁ca₂nág₂ mɨ'₅₄ a₂ca₂lë₃ jaun₂, qui₂ca₂ŋɨ'₂ dsa₂, tsá₃ caun₂ ca₂i₃jiog₅ dsɨ́₅, ia₁ ca₂le₃jɨ́n₃ bá₄ dsa₂ 'éi₂ jma₃quén₅ qui₂ca₂nág₂ jág₁ jmei₅ quió'₅ a₂qui₂ca₂dsia₃ dsa₂ i₂tion'₅₄ 'éi₂.  
\v 7 Jaun₂ dsɨ₃gó'₃ dsɨ́₅ 'ŋio₅ lɨn₃, qui₂ca₂dsia₃ jág₁ guioin₅₄ quiain'₅₄ rɨin'₅₄, ca₂juá'₂: 
\p ―¿On₁jua'₅₄ dsa₂ chan₂ Galilea ca₂le₃jɨ́n₃ dsa₂ i₂dsia₅ jág₁ në₅?  
\v 8 ¿'A₂ bá₄ lia'₂ né'₂ dsia₂₃ jág₁ jmei₅ quió'₅ juɨg₂ go₄ jniog₄ le₂jau₂ le₂jau₂?  
\v 9 Dsa₂ i₂tion'₅₄ ja₁lá₃ i₂chan₂ juɨg₂ Partia, dsa₂ chan₂ Media, dsa₂ chan₂ Elam, dsa₂ chan₂ Mesopotamia, i₂chan₂ Judea, i₂chan₂ Capadocia, dsa₂ chan₂ Ponto, dsa₂ chan₂ 'uë₃ Asia,  
\v 10 dsa₂ chan₂ Frigia quian'₅₄ Panfilia, dsa₂ ja₂lén₂ 'uë₃ Egipto quian'₅₄ juɨg₂ 'uë₃ Africa\f + \fr 2:10 \ft griego: Libia.\f* a₂niog₅ uɨ́ng₂ con'₂ guë́₄ Cirene. Ján₃ bá₄ tion'₅₄ dsa₂ chan₂ Roma i₂ma₂tián'₅ ja₁lá₃. I₂lɨn₅₄ 'éi₂ jme₁ma₂lɨ́n₅ judíos; i₂lɨn₅₄ guë'₂ ma₂gue₃ juá'₅ quió'₅ dsa₂ judíos.  
\v 11 Ján₃ bá₄ tion'₅₄ dsa₂ chan₂ 'uë₃ Creta, dsa₂ chan₂ Arabia në́₃. La₁ ca₂le₃jág₃ bá₄ jniog₄ néi₁ quian'₅₄ jág₁ jmei₅ quián₂ a₂dsia₅ dsa₂ në₅ ca₂le₃jë́₃ a₂jlá'₁ a₂'io'₂ a₂jmo₅ Diú₄. 
\p  
\v 12 Jaun₂ 'ŋio₅ dsɨ₂gó'₃ dsɨ́₅ dsa₂, tsá₃ caun₂ qui₂ca₂'ág₂ dsɨ́₅. Jŋia'₅₄ qui₂ŋɨ́i'₅ rɨin'₅₄: 
\p ―¿'E₂ 'nió'₄ juá'₂ ca₂le₃jë́₃ a₂në₅? 
\p  
\v 13 I₂lɨn₅₄ guë'₂ tsá₃ 'éin₂, jŋia'₅₄ qui₂jmóg'₂ burlas, jaun₂ ca₂juá'₂: 
\p ―I₂le₁'en₅ bá₄ i₂në₅. 
\s1 Jág₁ a₂ca₂juá'₂ Pe₄ ca₂tsɨ́'₃ dsa₂ 
\p  
\v 14 Jaun₂ ca₂nau₂ Pe₄ jë₄ jme₁guá₄ quiain'₅₄ guë́₄ guia₃-ján₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ rɨin'₅₄. Jaun₂ ca₂juá'₂ tiá₂ ca₂tsɨ́'₃ dsa₂: 
\p ―'Nia'₂ dsa₂ chan₂ Judea quian'₅₄ ca₂le₃jɨ́ng'₃ i₂tián'₅ Jerusalén në́₃, juɨ₁le₂ŋi'₅₄ 'nia'₂ jág₁ la₂. Nei₂ 'nia'₂ dse₃ a₂juá'₄ jniá₂ la₂.  
\v 15 Tsá₃ le₁'en₅ dsa₂ la₂ juɨ₁lia'₂ lɨ́n'₂ 'nia'₂, ia₁ con'₂ hora ŋí₁ ŋi₃ të₂ o₃'iog₂\f + \fr 2:15 \ft lit. “hora 'nɨ₅.” \f* bá₄ guë́₄ la₂.  
\v 16 Të₂le₃ a₂rë₂ti₃ con'₂ lë́₅ jág₁ a₂ca₂'ë́₂ Joel ma₂lɨ́g'₂, lia'₂ con'₂ jme₁ca₂juá'₂: 
\q1  
\v 17 Jë₁ca₂tó'₂ jmɨg₄, juá'₂ Diú₄, 
\q1 tsɨng₅₄ Jme₂dsí₂ quiáng₃ jaun₂ sióin₃ 
\q2 ne₄ quió'₅ ca₂le₃jɨ́n₃ dsa₂ mɨ₂güɨ́g₃. 
\q1 Ja₂ŋí'₂ 'nia'₂, ja₁mɨ́g'₄ në́₃ 
\q2 qui₃dsia₃ o₄quió₃ jniá₂. 
\q1 Dsó₂ chi'₂ quián'₂ 'nia'₂ në́₃ 
\q2 a₂lë₁qui₃jág₃ 'e₂ qui₃jág₃, 
\q2 dsɨ₂gui'₅₄ can'₅₄ guë'₂ qui₃quɨ₃. 
\q1  
\v 18 Jmɨg₄ jaun₂, qui₁'ɨ́ng₄ Jme₂dsí₂ quiáng₃ 
\q2 ne₄ quió'₅ dsa₂ ŋe'₂, dsa₂ mɨ́₂ në́₃ 
\q2 i₂jme₂ti₃ ta₁ ne₃, 
\q1 jaun₂ guë́₄ qui₃dsia₃ o₄quió₃ jniá₂. 
\q1  
\v 19 Dsɨ₁ guei'₅₄ guë'₂ qui₁'ë́₄ jniá₂ dsa₂ 
\q2 cosas a₂dsɨ₃gó'₃ dsɨ́₅. 
\q1 Ne₄ gua'₅₄ 'uë₃ guë'₂ 
\q2 jmo₅₄ jniá₂ lé₂ léi₄, 
\q2 juɨ₁lia'₂ jmɨ₂, si₂, jnei₅ lë́₅ jme₁ŋi₁ në́₃. 
\q1  
\v 20 'Iog₂ guë'₂ co₂dsia₅ le₃lia'₂. 
\q2 Tsɨ'₂ guë'₂ lé₂ guéin₂ lia'₂ lë́₅ jmɨ₂. 
\q1 Ca₂le₃jë́₃ a₂në₅ lé₂ né'₃ guë́₄ 
\q2 a₂guá₂ jmɨg₄ quió'₅ Te₁gui'₅₄. 
\q1 Jmɨg₄ jaun₂ lé₂ caun₂ jmɨg₄ juë'₂ a₂gau₂. 
\q1  
\v 21 Jaun₂ ca₂le₃jɨ́n₃ dsa₂ i₂mɨ₅ chi₂lén'₂ Te₁gui'₅₄, 
\q2 lióin₂ bá₄.\f + \fr 2:21 \ft Joel 2:28-32.\f* 
\p  
\v 22 ’'Nia'₂ dsa₂ chan₂ Israel, nei₂ 'nia'₂ ca₂le₃jë́₃ a₂juá'₄ jniá₂ la₂. Jesús chan₂ Nazaret dsa₂ dsen₃ quián₅ Diú₄, i₂ca₂cuë́'₃ 'éi'₃ ca₂chein₃ jɨn'₄ 'nia'₂. Ca₂jmo₃ Diú₄ ca₂le₃jë́₃ léi₄ juë'₂, ca₂le₃jë́₃ 'e₂ dsɨ₂gó'₃ dsɨ́₅ dsa₂, qui₂ca₂jmo₃ të₂le₃ quian'₅₄ Jesús jɨn'₄ 'nia'₂. A₂ŋi'₅₄ rë₂ bá₄ 'nia'₂ jaun₂.  
\v 23 La₁ jme₁ca₂jáng'₂ dsa₂ o₄gog'₂ 'nia'₂ con'₂ jme₁ma₂lë́₅ jág₁ quió'₅ Diú₄ a₂ma₂ŋi₅ le₂jŋiá₅, 'nia'₂ në́₃ ca₂chang'₂ i₂'éi₂, ca₂te'₅₄ chi₁'ŋei₂₃, ca₂i₁jɨin'₅₄ 'nia'₂ o₄gú₃ dsa₂ 'lɨn'₅₄ i₂tsá₃ ŋéi₂ dsɨ́₅. Jaun₂ ca₂jŋag'₃ ca₂tion₃ cróg₄.  
\v 24 La₁ Diú₄ ca₂jme₃jein'₅₄ táng₃, ca₂lió₂ ne₄ 'mú₃. Ia₁ tsá₃ lé₂ jua'₅₄ a₂të₃roin₅₄ a₂rë₃join₅ co₂tan₅₄ jɨn₄ 'lag₄.  
\v 25 Ia₁ ca₂juá'₂ 'lag₄ Rag₅₄ David a₂'ɨin₂₃ Jesús, ca₂juá'₂: 
\q1 Ia₁ jɨn₄ bá₄ jniá₂ tián₂ Te₁gui'₅₄ 
\q2 cau₅ quió₃. 
\q1 'Éi₂ bá₄ guá₅ të₂le₃ gu₃ ne₁, 
\q2 ia₁jaun₂ 'i₁jan₂ tsá₃ 'ein₂ lé₂ jmóg'₂ jleng₃, 
\q2 'ɨ₅ dsɨ₃. 
\q1  
\v 26 Jaun₂ lë₃, 'ŋio₅ lɨn₃ ca₂jmo₃ jniá₂ 'io'₂, 
\q2 jaun₂ ca₂juá'₃ quian'₅₄ le₁tsɨ'₃ 
\q2 jág₁ a₂jéin₅ lián'₂. 
\q1 Jaun₂ lë₃ tsá₃ 'ɨ₅ dsɨ₃ jë₁ma₂ca₂jon₃ nɨ₁ŋɨ₃. 
\q1  
\v 27 Ia₁ tsá₃ cuë́'₁ jmɨg₄ a₂jŋia₃ jme₂dsí₂ quiáng₃ 
\q2 ja₁tion'₅₄ 'lag₄,\f + \fr 2:27 \ft Salmo 16:18-11.\f* 
\q1 on₃ guë'₂ cuë́'₁ jmɨg₄ a₂siá'₃ nɨ₁ŋɨ₃ jniá₂, 
\q2 dsa₂ jŋió₅ quiáng'₂ i₂'nióg'₃. 
\q1  
\v 28 Ca₂'ë'₅₄ ca₂jme₁tag'₂ juɨ₅ ja₁tɨ́n'₄ jme₂dsí₂ quiáng₃. 
\q2 Jaun₂ jmó'₂ jéin₄ lián'₂ jë₁ma₂'eng₅₄ ja₁cong'₂.\f + \fr 2:28 \ft Salmo 16:18-11.\f* 
\p  
\v 29 'Rɨn'₅₄ jniog₄, léi₄ dsón'₂ bá₄ ca₂jon₃ tsɨ₁jon₂ jmei₂ jniog₄ David, jaun₂ ca₂'oin₃. Në₅ bá₄ chí'₅ guë'₂ tau₂ 'ŋio₅ quió'₅ quian'₅₄ jniog₄ rë₂në́₃.  
\v 30 La₁ David 'éi₂ jme₁lɨ́n₄ jan₂ i₂jme₁'ë́₂ jág₁ quián₅ Diú₄, jaun₂ jme₁ŋi₅ rë₂ a₂ca₂cuë₃ Diú₄ jág₁ 'ɨin₂₃ 'ŋiog₅, a₂le₃chan₂ jë₄ quió'₅ ja₁ŋi'₅₄ chi'₂ dsio₅₄, jan₂ i₂lɨ́n₅ I₂rë₂'ɨ́n₁ quián₅ Diú₄. Jaun₂ i₂'éi₂ guá₃ goin₃ ne₄ ne₄ta₁ ja₁jme₁guá₄ 'ŋiog₅ David.  
\v 31 Co₂'nió'₄ a₂ma₂jág₂ bá₄ David le₂jŋiá₅, ca₂juá'₂ a₂jen'₅₄ I₂rë₂'ɨ́n₁ quián₅ Diú₄. Jaun₂ ca₂juá'₂ ján₃ a₂tsá₃ jŋia₃ jme₂dsí₂ quió'₅ jɨn₄ 'lag₄,\f + \fr 2:31 \ft griego: hades, co₂'nió'₄ a₂juá'₂, ja₁quió'₄ 'lag₄.\f* on₃ guë'₂ dsɨ₃'én₂ nɨ₁ŋɨ₁₂ jua'₅₄ a₂siá'₃.  
\v 32 Ia₁ Diú₄ bá₄ ca₂jmo₃ ca₂jen'₅₄ táng₃ 'ŋiog₅ Jesús 'éi₂. Ca₂le₃jág₃ bá₄ jnia'₅₄ ca₂të́₂ ne₄, jaun₂ lë₃ cuë₂ jág₁ dsau₅.  
\v 33 Jaun₂ ca₂chó'₂ Diú₄ quian'₅₄ gu₂ ne₁, ca₂jme₃juag'₂. Jaun₂ Diú₄ Jmei₂ ca₂cuɨn₃ Jme₂dsí₂ quiáin₅ ca₂cuɨin₃ Jesús, lia'₂ con'₂ lë́₅ jág₁ quió'₅ ma₂cuë₃. Jaun₂ ca₂le₃jë́₃ a₂në₅ a₂ma₂jag'₅₄ a₂ma₂nei'₂ 'nia'₂, já₅ ne₄ 'éi₂ bá₄.  
\v 34 Ia₁ on₃jua'₅₄ David ca₂uɨ́g₂ guei'₅₄ i₂juɨ́g₃, ia₁ 'ŋiog₅ David ca₂juá'₃: 
\p Ca₂juá'₂ Diú₄ ca₂tsɨ́'₃ Te₁gui'₅₄ quiáng₃: 
\q1 “Né₂ con₂ jniá₂ të₂le₃ gu₃ ne₁, 
\q1  
\v 35 ca₂lia'₂ ca₂të́₂ jmɨg₄ 
\q2 a₂tón'₁ jniá₂ dsa₂ i₂'iog₅₄ o₄tag'₄”.\f + \fr 2:35 \ft Salmo 110:1.\f* 
\p  
\v 36 Juɨ₁le₂ŋi₅ rë₂ ca₂le₃jɨ́n₃ dsa₂ chan₂ juɨg₂ Israel, jaun₂ tsá₃ juɨ₁'ei₅₄ caun₂-tɨn₃ dsɨ₅, ia₁ 'ŋiog₅ Jesús 'éi₂ bá₄, i₂ca₂tión'₃ 'nia'₂ cróg₄, Diú₄ në́₃ ma₂jmo₃ ma₂lɨ́in₅ lia'₂ Te₁gui'₅₄ lia'₂ rë'₂ I₂rë₂'ɨ́n₁ quiáin₅. 
\p  
\v 37 Jme₁ca₂nág₂ dsa₂ le₂në₅ tioin'₅₄, qui₂ca₂tá'₂ 'lia'₂ dsɨ́₅ 'ŋio₅ lɨn₃. Jaun₂ ca₂ŋɨ́i'₃ Pe₄ quiain'₅₄ chi'₂ dsɨ₂guia₃-tɨ́n₂ rɨin'₅₄ ca₂juá'₂: 
\p ―Rɨn'₅₄ jniog₄, ¿'e₂ 'nió'₅ jmó₁ jnia'₅₄? 
\p  
\v 38 Jaun₂ ca₂ŋag₃ Pe₄: 
\p ―Jme₁tsɨ́n₄ 'nia'₂ 'au'₂, jen'₄ 'nia'₂ të₂le₃ quió'₅ Diú₄, chon₅₄ 'nia'₂ jmɨg₂ le₂jang'₂ le₂jang'₂ lia'₂ con'₂ lë́₅ 'éi'₃ quió'₅ Jesús, cuë'₅₄ léi₄ a₂qui₂ma₂'én₂ dsáu'₂ 'nia'₂. Jaun₂ guë́₄ cuɨn₃ Diú₄ Jme₂dsí₂ Jŋió₅ quiáin₅.  
\v 39 Jág₁ në₅ ca₂cuë₃ Diú₄ quián'₂ 'nia'₂ ca₂le₃jɨ́ng'₃, ca₂le₃jɨ́n₃ chi'₂-guein₂ quián'₂ 'nia'₂ në́₃, quian'₅₄ ca₂le₃jɨ́n₃ guë́₄ dsa₂ i₂chan₂ uɨ́ng₂. Jág₁ në₅ quió'₅ ca₂le₃jɨ́n₃ dsa₂ i₂'nio₃ Te₁gui'₅₄ Diú₄ quián₂ jniog₄ të₂. 
\p  
\v 40 Quian'₅₄ jág₁ la₂, quian'₅₄ 'lióng₂ guë́₄ jág₁ siá'₂, ca₂juá'₂ Pe₄ tion₅₄ ca₂tsɨ́'₃ dsa₂: 
\p ―Lion₄ 'nia'₂ jɨn₄ dsa₂ i₂ma₂i₂cón'₅ rë₂në́₃. 
\p  
\v 41 Jaun₂ ca₂le₃jɨ́n₃ i₂ca₂tón'₃ juɨ₅ ca₂nág₂ jág₁ dse₃ ca₂juá'₂ Pe₄, qui₂ca₂jŋói₂ jmɨg₂. Jmɨg₄ jaun₂ con'₂ 'nɨ₅ mei₅ dsa₂ i₃ton'₅₄ të₂le₃ jɨn₄ dsa₂ i₂ma₂'én₂ të₂le₃ quió'₅ Jesucristo.  
\v 42 Ca₂le₃jɨ́n₃ dsa₂ ca₂jŋa'₃ tiá₂ ca₂le₃jë́₃ jág₁ a₂jme₂tag₅ chi'₂ dsɨ₂guia₃-tɨ́n₂. Caun₂ bá₄ jág₁ quió'₅ ca₂jmo₃ ca₂le₃jɨ́in₃, chi₂léin'₂ Diú₄, qui₂tóin'₅ co₂lë₅, jmo₂₃ dsóg₁ i₁ŋí'₄. 
\s1 'A₂ lia'₂ jme₁chan₂ dsa₂ le₂'uɨg₅₄ i₂'én₂ jág₁ dse₃ 
\p  
\v 43 'Ŋio₅ i₂gó'₃ dsɨ́₅ dsa₂ ca₂le₃jë́₃ léi₄ a₂qui₂ca₂jmo₃ Diú₄ të₂le₃ quian'₅₄ dsɨ₂guia₃-tɨ́n₂ i₂chen₄\f + \fr 2:43 \ft griego: apóstolous.\f* quiáin₅.  
\v 44 Ca₂le₃jɨ́n₃ dsa₂ i₂ma₂'én₂, caun₂ bá₄ jág₁ 'ei₅ quió'₅, jaun₂ ca₂le₃jë́₃ a₂jme₁cha₂ quió'₅, jme₁lë́₄ quió'₅ ca₂le₃jɨ́n₃ rɨin'₅₄.  
\v 45 Ca₂le₃jë́₃ 'e₂ cosa cha₂ quió'₅, qui₂ca₂'nag₃, jaun₂ jme₁qui₂dsió'₅ cu₄ jaun₂ 'ein₂ rɨin'₅₄ 'nió'₅ quió'₅.  
\v 46 Ca₂le₃jë́₃ jmɨg₄ jme₁ŋɨi'₂ i₁dsi₅ guá'₅ templo. Dsi₂néi₂ quió'₅ në́₃, jme₁dsió'₅ i₁ŋí'₄ jme₁guë́'₅ co₂dsia₅, ca₂le₃jɨ́in₃ jmo₂₃ 'io'₂, caun₂ bá₄ 'ei₅ dsɨ́₅.  
\v 47 Ca₂le₃jɨ́in₃ jme₁cuë́'₅ ti₁'mag'₄ Diú₄, jaun₂ ca₂le₃jɨ́n₃ dsa₂ sián'₂ jme₁'nioi₃ dsa₂ 'éi₂. Jaun₂ ca₂le₃jë́₃ jmɨg₄ bá₄ jmo₅ Te₁gui'₅₄ caun₂ dsɨ₂juɨ́n₂ dsa₂ i₂lón₂. 
\c 3  
\s1 Ca₂'lón₂ jan₂ dsa₂ 'lian'₂ 
\p  
\v 1 Co₂ráun₂ dsióg₃ Pe₄ quiain'₅₄ Juan₅₄ guá'₅ templo con'₂ hora ŋí₁ 'nɨ₅ të₂le₃ ca₂'láu₂,\f + \fr 3:1 \ft lit. “hora ŋi₃.” \f* ia₁ hora jaun₂ jme₁ŋɨ'₂ dsa₂ tián₂ chi₂léin'₂ Diú₄.  
\v 2 Ca₂le₃jë́₃ jmɨg₄ jme₁dsɨ₂jŋia₃ dsa₂ jan₂ dsa₂ 'lian'₂ i₂tsá₃ lé₂ ŋɨ₃, le₂jaun₂ jme₁ma₂lɨ́in₅ lia'₂ con'₂ jme₁ca₂rë₃cháin₃, jme₁dsɨ₃jiog₃ dsa₂ o₄'né₄ i₁dsi₅ guá'₅, ja₁të́'₂ dsa₂ O₄'né₄ Jlá'₁. Ja₁jaun₂ jme₁qui₂mɨ₅ dsa₂ 'lian'₂ 'éi₂ cu₄ quió'₅ dsa₂ i₂dsɨ₂lén₂ guá'₅.  
\v 3 Jme₁ca₂jág₃ dsa₂ dso'₅₄ 'éi₂ ca₂ŋó₃ Pe₄ quiain'₅₄ Juan₅₄ a₂dsɨ₃toin'₅₄ i₁dsi₅ guá'₅, jaun₂ ca₂mɨ₃ cu₄ quió'₅ dsa₂ on₃ 'éi₂.  
\v 4 Jaun₂ ca₂nau₂ Pe₄, Juan₅₄ në́₃, ca₂jɨ́in₂ dsa₂ 'éi₂. Jaun₂ ca₂juá'₂ Pe₄: 
\p ―Dse₃ jag₄ jnia'₅₄. 
\p  
\v 5 Jaun₂ guá₅ dsa₂ 'éi₂ qui₂jɨ́in₂ Pe₄ quian'₅₄ Juan₅₄, ia₁ lɨ́in₂ cuë₃ dsa₂ ca₂la₂ cu₄.  
\v 6 La₁ jaun₂ ca₂juá'₂ Pe₄: 
\p ―Tsá₃ cu₄tiog₂, on₃ guë'₂ cu₄nióg₄ cha₂ quió₃ cuë₅₄. La₁ con'₂ a₂cha₂ quió₃, cuë₅₄. Quian'₅₄ 'éi'₃ quió'₅ Jesucristo chan₂ Nazaret, nau₂, ŋɨ₄. 
\p  
\v 7 Jaun₂ ca₂jŋa'₃ Pe₄ mɨ₂gu₂ ne₁ dsa₂ 'éi₂, ca₂jme₃'o₅₄ ca₂chó'₂. Dsɨ₂juɨ₅ le₂jaun₂ ca₂rë₃bén₂ mɨ₂tag₄ dsa₂ 'éi₂.  
\v 8 Jaun₂ ca₂ráun₂ ca₂nau₂ jaun₂ ca₂jme₃lióg₃ ca₂ŋɨ₃. Jaun₂ ca₂'í₃ i₁dsi₅ guá'₅ quiain'₅₄ dsa₂ on₃ 'éi₂, qui₂ca₂ŋɨ₃ qui₂ca₂ráun₂ qui₂ca₂cuë́'₃ ti₁'mag'₄ Diú₄.  
\v 9 Ca₂le₃jɨ́n₃ dsa₂ i₂tion'₅₄ ja₁jaun₂, ca₂jɨ́in₂ dsa₂ 'éi₂ ŋɨ₂₃ cuë́'₅ ti₁'mag'₄ Diú₄.  
\v 10 Jaun₂ dsɨ₂gó'₃ dsɨ́₅ 'ŋio₅ lɨn₃, ia₁ ma₂ŋɨ₂₃. Ma₂cuɨin₂₃ bá₄ dsa₂ 'éi₂ i₂gua₂ tián₂ o₄'né₄ chei₂ Jlá'₁ qui₂mɨ₂₃ cu₄. 
\s1 Jág₁ ca₂ton₃ Pe₄ corredor ja₁të́'₂ dsa₂ quió'₅ Salomón 
\p  
\v 11 Caun₂ 'en₅₄ le₂jaun₂ bá₄ dsa₂ i₂jme₁'lian'₂ 'éi₂ quiain'₅₄, tsá₃ téin₂ Pe₄, Juan₅₄ në́₃. Jaun₂ ca₂i₃lén₂ co₂chi'₅₄ juɨn₅ dsa₂ dsɨ₂gó'₃ dsɨ́₅ ca₂ton₂ guá'₅ ja₁chei₂ Corredor quió'₅ Salomón, ja₁jme₁'en₅₄ Pe₄ quiain'₅₄ Juan₅₄ në́₃.  
\v 12 Jme₁ca₂jág₃ Pe₄ le₁ŋɨ'₂ dsa₂ juɨn₅, jaun₂ ca₂juá'₂ ca₂tsɨ́'₃ dsa₂ 'éi₂: 
\p ―'Nia'₂ dsa₂ juɨg₂ chan₂ Israel, ¿'E₂ lë₃ ŋɨ́₄ dsɨ₂gó'₃ 'au'₂ 'nia'₂? ¿'E₂ lë₃ jag'₅₄ 'nia'₂ jnia'₅₄ le₂në₅? On₃jua'₅₄ bí₂ a₂tag₂ jnia'₅₄ guio₅₄ a₂ca₂'lón₂ dsa₂ në₅ a₂ma₂lé₂ ŋɨ₃, jua'₅₄ a₂lág₅ jnia'₅₄ dsa₂ o₂dsan₂.  
\v 13 La₁ia₁ Diú₄ quián₅ tsɨ₁jon₂ jmei₂ jniog₄ Abraham, Isaac, Jacob në́₃, Diú₄ 'éi₂ ca₂jme₃juɨin'₂ 'ŋio₅ lɨn₃ Jesús ja₁ŋi'₅₄, i₂ca₂jɨn'₅₄ 'nia'₂ ne₄ dsɨ₂tan₅₄. Jme₁'nio₃ guë́₄ Dsi₄má'₂ Pilato jme₁lió₂, la₁ tsá₃ ca₂gue'₅₄ 'nia'₂.  
\v 14 'Nió'₄ jme₁lon'₄ 'nia'₂ dsa₂ jŋió₅ i₂tsá₃ 'e₂ dso₄ rɨn₂ 'éi₂, jë₂ bá₄ dsa₂ i₂ma₂jŋɨ'₃ dsa₂ ca₂mɨ'₅₄ 'nia'₂ lión₂.  
\v 15 Jaun₂ le₂në₅ ca₂jŋɨ́'₃ 'nia'₂ dsa₂ i₂cuë₅ jme₂dsí₂. La₁ Diú₄ ca₂jme₃jein'₅₄ táng₃ jɨn₄ 'lag₄, jaun₂ ca₂le₃jë́₃ a₂në₅ ca₂të́₂ ne₄ jnia'₅₄.  
\v 16 Quian'₅₄ bí₂ quió'₅ 'ŋiog₅ Jesús 'éi₂ ca₂'lión₂ dsa₂ i₂cuɨn'₂ 'nia'₂ i₂jɨn'₄ 'nia'₂ në₅, ia₁ a₂'éin₂ jnia'₅₄ të₂le₃ quió'₅ Jesús. 'Éi₂ bá₄ në₂cuë₃ bí₂ quió'₅ dsa₂ në₅, jaun₂ ca₂'lóin₂, co₂ŋei'₅₄, juɨ₁lia'₂ jɨin'₅₄ 'nia'₂ në₅. 
\p  
\v 17 ’Guion₄ bá₄ jniá₂ dse₃, rɨn'₅₄ jniog₄, a₂ca₂jmo'₅₄ 'nia'₂ caun₂ jág₁ quian'₅₄ dsa₂ can'₅₄ quián'₂ 'nia'₂, a₂ca₂jŋɨ́'₃ 'nia'₂ Jesús, ca₂jmo'₅₄ 'nia'₂ le₂jaun₂ ia₁ a₂tsá₃ ŋi'₅₄ bá₄ 'nia'₂ 'e₂ jmo'₂.  
\v 18 La₁ ca₂rë₃ti₃ jág₁ a₂ma₂'ë́₂ Diú₄ le₂jŋiá₅ të₂le₃ quian'₅₄ dsa₂ i₂jme₁'ë́₂ jág₁ quiáin₅, a₂tion₅₄ ŋág₃ uɨg₅ dsa₂ I₂rë₂'ɨ́n₁ quiáin₅.  
\v 19 Jaun₂ në́₃, jme₁tsɨ́n₄ 'nia'₂ 'au'₂, jen'₅₄ 'nia'₂ të₂le₃ quió'₅ Diú₄, ia₁jaun₂ 'én₂ dsáu'₂ 'nia'₂. Jaun₂ bá₄ jiá₃ jmɨg₄ cuë₃ Te₁gui'₅₄ a₂le₃güɨn'₂ jme₂dsí₂ quián'₂ 'nia'₂,  
\v 20 a₂chein₃ táng₃ Jesús i₂lɨ́n₅ I₂rë₂'ɨ́n₁ quián₅ Diú₄, i₂ma₂lë́₅ jág₁ le₂jŋiá₅ jiá₃ quián'₂ 'nia'₂,  
\v 21 o₁jŋia'₅₄ la₂ rë₂në́₃ tion₅₄ 'nió'₅ guá₃ Jesús guei'₅₄ i₂juɨ́g₃ ca₂lia'₂ ca₂jmo₃ Diú₄ rë₂ ca₂le₃jë́₃ lia'₂ con'₂ lë́₅ jág₁ ma₂'ë́₂ dsa₂ jŋió₅ quiáin₅ ma₂lɨ́g'₂.  
\v 22 Le₂la₂ ca₂juá'₂ 'lag₄ Moisés ca₂tsɨ́'₃ dsa₂ quián₂ jniog₄ ma₂dsi₃jo₃: “A₂chen₃ Te₁gui'₅₄ Diú₄ jan₂ dsa₂ i₂'ë́₂ jág₁ quiáin₅, i₂lɨ́n₅ dsa₂ go'₄ 'nia'₂ guiong'₅₄, juɨ₁lia'₂ ca₂chei₃ jniá₂. Jaun₂ tón'₂ 'nia'₂ juɨ₅ jme₁ti'₄ 'nia'₂ ca₂le₃jë́₃ con'₂ 'éi'₃ a₂jmo₃ 'éi₂.  
\v 23 Ia₁ ca₂le₃jɨ́n₃ i₂tsá₃ juɨ₅ tón'₂ jág₁ quió'₅ dsa₂ i₂chen₄ quiáin₅ 'éi₂, dsɨ₃'éin₂, 'uɨ́in₃ juɨg₂ Israel.”\f + \fr 3:23 \ft Deuteronomio 18:15,18-19.\f* 
\v 24 Jaun₂ le₂në₅ ca₂'ë́₂ Samuel jág₁ le₂'uɨg₅₄, ca₂le₃jɨ́n₃ guë́₄ dsa₂ i₂jme₁'ë́₂ jág₁ quián₅ Diú₄ i₂ca₂o₃lén₂ cang₂ guë́₄ jaun₂, qui₂ca₂juá'₂ lia'₂ lé₂ jmɨg₄ në₃.  
\v 25 Jág₁ a₂ca₂cuë₃ Diú₄ të₂le₃ quian'₅₄ dsa₂ i₂jme₁'ë́₂ jág₁ quiáin₅, ca₂cuë́'₃ 'nia'₂ bá₄. A₂dse₃ quián'₂ 'nia'₂ bá₄ ca₂jmo₃ Diú₄ caun₂ jág₁ quian'₅₄ dsa₂ can'₅₄ quián₂ jniog₄ ma₂lɨ́g'₂, juɨ₁lia'₂ ca₂tsɨ́'₃ Abraham: “Ca₂le₃jɨ́n₃ chi'₂-guein₂ dsa₂ mɨ₂güɨ́g₃ le₃chain₂ dse₃ të₂le₃ quian'₅₄ chi'₂ dsió'₂.”\f + \fr 3:25 \ft Génesis 22:18; 26:4.\f* 
\v 26 Lia'₂ con'₂ jme₁ca₂chón'₂\f + \fr 3:26 \ft o₃, “jme₁ca₂jme₃jen'₅₄.” \f* Diú₄ Ja₁ŋi'₅₄, ca₂chein₃ le₂'uɨg₅₄ jɨn'₄ 'nia'₂, ia₁jaun₂ jme₃gu'₅₄, ia₁jaun₂ tí'₄ 'nia'₂ le₂jang'₂ le₂jang'₂ ca₂le₃jë́₃ dso₄ qui₂'nau'₂ 'nia'₂. 
\c 4  
\s1 Pe₄ quiain'₅₄ Juan₅₄ tióin₂ ne₄ dsɨ₂tan₅₄ 
\p  
\v 1 Pe₄ quian'₅₄ Juan₅₄ tsá₃ ma₂dsan₃ bá₄ guë́₄ tsɨ́'₅ dsa₂ jág₁, jme₁ca₂dsi₃lén₂ jme₂dsa₂ quiain'₅₄ juɨg₅₄ chi'₂ 'ɨ'₅₄ quián₅ guá'₅, dsa₂ saduceos në́₃.  
\v 2 Le₁'néi₃ 'ŋio₅ lɨn₃, ia₁ jme₂tɨn₅ 'éi₂ dsa₂ a₂jen'₅₄ dsa₂ jɨn₄ 'lag₄ juɨ₁lia'₂ ca₂lë₃ léi₄ ca₂jen'₅₄ Jesús.  
\v 3 Jaun₂ ca₂jŋau'₃ chi'₂ 'ɨ'₅₄ ca₂tág₃ ca₂i₁tio'₂ né'₃ 'má₃ ca₂të₂ jme₁jnia₃, ia₁ ca₂'láu₂ bá₄ jmɨg₄ jaun₂.  
\v 4 La₁ juɨn₅ bá₄ dsa₂ i₂ca₂nág₂ ca₂rë₃'éin₂ jág₁. Con'₂ 'ŋiá₂ mei₅ dsa₂ i₂ca₂rë₃'én₂ 'éi₂, jme₁ca₂cáun₂ dsa₂ 'í₁ jmá'₃ dsa₂ ŋe'₂. 
\p  
\v 5 Jme₁jnia₃ jaun₂, ca₂ŋɨ'₂ ca₂le₃jɨ́n₃ dsa₂ dsen₅₄ i₂jmo₅ 'éi'₃ quián₅ dsa₂ judíos, dsɨ₂gui'₅₄ can'₅₄, të₅juá'₅ në́₃.  
\v 6 Ján₃ bá₄ jaun₂ jme₁'en₅₄ Anás i₂lɨ́n₅ jme₂dsa₂ dsen₅₄, Caifás, Juan₅₄, Alejandro në́₃, ca₂le₃jɨ́n₃ guë́₄ i₂lɨ́n₅ o₁rɨn'₅₄ jme₂dsa₂ dsen₅₄.  
\v 7 Jme₁ma₂le₁ŋɨi'₂ jɨin₂, jaun₂ guë́₄ ca₂i₁dsein₂₃ Pe₄ quian'₅₄ Juan₅₄, jaun₂ ca₂chei'₃ dsi₂jo₂ ja₁le₁ŋɨi'₂ jaun₂. Jaun₂ ca₂ŋag₃: 
\p ―¿'Ein₂ ca₂cuë₃ 'éi'₃, o₃ 'ein₂ ca₂cuë₃ jág₁ a₂i₂nio'₄ 'nia'₂ jme₂tɨ́ng'₁ dsa₂, a₂jmo'₂ 'nia'₂ 'e₂ jmo'₂ i₂niog'₅₄? 
\p  
\v 8 Jaun₂ ca₂juá'₂ Pe₄, rë₂rɨn₅ Jme₂dsí₂ Jŋió₅ të₂dsɨ́₅, ca₂tsɨ́'₃ dsa₂ i₂le₁ŋɨ'₂ 'éi₂: 
\p ―'Nia'₂ dsa₂ dsen₅₄ quián₅ juɨg₂, 'nia'₂ dsa₂ can'₅₄ quián₅ juɨg₂ Israel në́₃:  
\v 9 Chi₂jua'₂ a₂jaun₂ ŋag'₅₄ 'nia'₂ ia₁ ca₂jmó₁ jnia'₅₄ caun₂ a₂dse₃ quió'₅ jan₂ dsa₂ dso'₅₄ i₂tsá₃ lé₂ jme₁ŋɨ₃, chi₂jua'₂ 'niog'₂ 'nia'₂ le₃ŋi'₅₄ 'a₂ lia'₂ ca₂lë₃ a₂ca₂'lóin₂,  
\v 10 juɨ₁le₃ŋi'₅₄ bá₄ 'nia'₂, juɨ₁le₃ŋi₅ bá₄ ca₂le₃jɨ́n₃ dsa₂ juɨg₂ Israel në́₃, a₂chén'₅ dsa₂ në₅ jɨn'₄ 'nia'₂ ca₂'lóin₂ quian'₅₄ bí₂ quió'₅ Jesucristo chan₂ Nazaret i₂ca₂tión'₃ 'nia'₂ cróg₄, i₂ca₂jme₁jen'₅₄ táng₃ Diú₄ jɨn₄ 'lag₄.  
\v 11 Jesús 'éi₂: 
\q1 lɨ́n₅ nɨ₁cang₁ a₂tsá₃ jen'₅₄ 'nia'₂, 
\q2 i₂lɨ́ng'₅ të₅ i₂chi'₅ tsɨ₁'né₅, 
\q1 la₁ ca₂dsióg₃ ca₂lë₃ nɨ₁cang₁ a₂dsen₅₄ guë́₄.\f + \fr 4:11 \ft Salmo 118:22.\f* 
\m  
\v 12 Ia₁ 'i₁jan₂ i₂sián'₂ tsá₃ chan₂ i₂le₃lión₂ dsa₂. Ia₁ 'i₁jan₂ i₂sián'₂ tsá₃ ca₂cuɨn₃ Diú₄ ne₄ gua'₅₄ 'uë₃ la₂, a₂lé₂ 'ɨ́in₄ jniog₄ a₂mɨ́₁ ne₄ Diú₄ ia₁jaun₂ tág'₄ guei'₅₄ i₂juɨ́g₃, jŋia'₅₄ lia'₂ jan₂ Jesús bá₄. 
\p  
\v 13 Jme₁ca₂jág₃ dsa₂ can'₅₄ dsɨ₂gó'₃ dsɨ́₅ ca₂jɨ́in₂ Pe₄ quian'₅₄ Juan₅₄ 'a₂ lia'₂ tiá₂ dsɨ́₅ 'éi₂ ŋag₂₃ ne₅₄ le₂jaun₂, jaun₂ ca₂rë₃lí'₄ a₂lɨ́n₅ 'éi₂ dsa₂ tsá₃ lɨn₄ quen₅, i₂tsá₃ lɨn₄ si₂ cuɨ́'₅ në́₃, jaun₂ guë́₄ ca₂rë₃cuɨin₂₃ a₂lɨ́n₅ 'éi₂ dsa₂ i₂jme₁i₂nio₄ quian'₅₄ Jesús.  
\v 14 Ia₁ jaun₂ bá₄ jme₁chén'₄ dsa₂ i₂ca₂'lón₂ 'éi₂ jë₄ jaun₂, jaun₂ lë₃ tsá₃ cuɨn₅ jmɨg₄ jua'₅₄ a₂juá'₂ dsa₂ can'₅₄ a₂tsá₃ dsau₅.  
\v 15 Jaun₂ ca₂'uɨ́in'₂ bá₄ Pe₄ quian'₅₄ Juan₅₄ jë₄ jaun₂, jaun₂ ca₂jmo₃ jág₁ guioin₅₄ 'a₂ lia'₂ jmo₃.  
\v 16 Ca₂dsia₃ jág₁, juá'₂: 
\p ―¿'A₂ lia'₂ jmó₁ quian'₅₄ dsa₂ në₅ jaun₂? Ia₁ ca₂le₃jɨ́n₃ bá₄ dsa₂ juɨg₂ Jerusalén ma₂le₁ŋi₅ a₂jmo₅ i₂në₅ léi₄ juë'₂, jaun₂ tsá₃ lé₂ jua'₅₄ a₂jua'₅₄ jniog₄ a₂tsá₃ dsau₅.  
\v 17 La₁ ia₁jaun₂ tsá₃ ma₃caun₂ qui₃dsɨ₃'ag₅ jág₁ jɨn₄ dsa₂ juɨg₂, 'nió'₅ quiain₅₄ jniog₄ juë́'₅ ia₁jaun₂ tsá₃ ma₃i₃nioi₅₄ qui₃'ɨin₃ guë́₄ Jesús a₂tsɨ́'₃ dsa₂ le₃ne₄ juɨ₅ ja₁dsau₅₄ në₅. 
\p  
\v 18 Jaun₂ ca₂të₃ dsa₂ i₂le₁ŋɨ'₂ 'éi₂ ca₂të́'₃ táng₃ Pe₄ quian'₅₄ Juan₅₄, jaun₂ ca₂jmo₃ 'éi'₃ ca₂tsɨ́'₃ dsa₂ on₃ 'éi₂, a₂tsá₃ ma₃dsia₃ co₂ŋei'₅₄ on₃ guë'₂ jme₃tɨin₂₃ dsa₂ a₂'ɨin₂₃ Jesús.  
\v 19 La₁ jaun₂ ca₂ŋag₃ Pe₄ quian'₅₄ Juan₅₄ ca₂juá'₂: 
\p ―'Nio'₄ 'nia'₂ 'au'₂ chi₂jua'₂ 'ŋio₅ guë́₄ dse₃ jniá₂ ne₄ Diú₄, a₂néi₁ jnia'₅₄ gau₂ jág₁ quián'₂ 'nia'₂, 'nió'₄ a₂jme₁néi₁ jnia'₅₄ gau₂ jág₁ quió'₅ Diú₄.  
\v 20 La₁ jnia'₅₄ në́₃ tsá₃ lé₂ tí₄ a₂dsiá₁ ca₂le₃jë́₃ a₂ma₂jag₅₄, a₂ma₂néi₁ në́₃. 
\p  
\v 21 Jaun₂ ca₂quiong₃ dsɨ₂tan₅₄ juë́'₅, la₁ ca₂lió₂ bá₄ jaun₂ në́₃. Ia₁ tsá₃ ca₂dsó'₂ 'a₂ lia'₂ 'ë́₂ uɨg₅, ia₁ ca₂le₃jɨ́n₃ bá₄ dsa₂ ma₂qui₂cuë́'₃ ti₁'mag'₄ Diú₄ a₂ca₂të́₂ ne₅₄ a₂ca₂lë₃ jaun₂.  
\v 22 Jaun₂ dsa₂ ŋe'₂ i₂ca₂'lón₂ 'éi₂ quian'₅₄ léi₄ a₂dsɨ₂gó'₃ dsɨ₅, jme₁'ein₅₄ lë́₅ guë́₄ të₂láu₃ ŋi₂. 
\s1 Ca₂mɨ₃ dsa₂ 'én₂ a₂cuë₃ guë́₄ Diú₄ bí₂ quió'₅ 
\p  
\v 23 Jme₁ma₂lón₂ Pe₄ quian'₅₄ Juan₅₄, ca₂i₃léin₂ ja₁tion'₅₄ rɨin'₅₄, jaun₂ ca₂dsia₃ ca₂le₃jë́₃ 'e₂ ca₂juá'₂ juɨg₅₄ jme₂dsa₂ quian'₅₄ dsɨ₂gui'₅₄ can'₅₄ a₂ca₂tsɨ́'₃ 'éi₂.  
\v 24 Jme₁ca₂nág₂ jág₁ jaun₂, ca₂le₃jɨ́in₃ ca₂mɨ₃ co₂lë₅ ca₂tsɨ́'₃ Diú₄ ca₂juá'₂: 
\p ―Te₁gui'₅₄ quián₂ jniog₄, 'ne₂ bá₄ lɨ́ng'₅ Diú₄ i₂ca₂jmo'₅₄ guei'₅₄ i₂juɨ́g₃, quian'₅₄ gua'₅₄ 'uë₃, jmɨ₁ŋí'₄ në́₃, ca₂le₃jë́₃ guë́₄ 'e₂ a₂cha₂.  
\v 25 'Ne₂ bá₄ ca₂jua'₅₄ quian'₅₄ Jme₂dsí₂ Jŋió₅ quiáng'₂, jme₁ca₂juá'₂ 'lag₄ David dsa₂ quiáng'₂: 
\q1 ¿'E₂ lë₃ tion'₅₄ dsɨ₂nau₂ co₂mɨ'₅₄? 
\q1 ¿'E₂ lë₃ dsɨ₂jiog₅ dsɨ́₅ dsa₂ chan₂ mɨ₂güɨ́g₃ 
\q2 ca₂le₃jë́₃ ne₅₄ a₂'lɨg'₅₄ a₂tsá₃ ta₁ tí₄? 
\q1  
\v 26 Ca₂le₃jɨ́n₃ rag₅₄ ne₄ gua'₅₄ 'uë₃ 
\q2 qui₂ca₂quɨin'₂ jág₁; 
\q1 Ca₂le₃jɨ́n₃ dsɨ₂tan₅₄ quián₅ juɨg₂ 
\q1 qui₂ca₂nau₂ 'nei₂ ja₁con₂ Te₁gui'₅₄, 
\q2 ja₁con₂ I₂rë₂'ɨ́n₁ quiáin₅ në́₃.\f + \fr 4:26 \ft Salmo 2:1-2.\f* 
\p  
\v 27 ’Dsau₅ dsón'₂ bá₄ ca₂jmo₃ caun₂ jág₁ Rag₅₄ Herodes quian'₅₄ Dsi₄má'₂ Poncio Pilato juɨg₂ la₂ quian'₅₄ dsɨ₂nau₂, dsa₂ israelitas në́₃. Ca₂quɨin'₃ jág₁ ca₂jme₃'ŋiai₅₄ Jesús Ja₂ŋí'₂ jŋió₅ i₂rë₂'ɨ́n₁ quiáng'₂.  
\v 28 Quian'₅₄ a₂në₅, ca₂jme₃ti₃ dsa₂ can'₅₄ 'éi₂ ca₂le₃jë́₃ a₂'i₄ 'éi'₃ niog₅ lé₂.  
\v 29 Jaun₂ në́₃ Te₁gui'₅₄, jag₄ a₂quiong₅ dsa₂ juë́'₅ jnia'₅₄. Cuë₄ bí₂ jnia'₅₄ dsa₂ quiáng'₂ ia₁jaun₂ tián₂ qui₂jme₁tɨn₅ guë́₄ jnia'₅₄ dsa₂ jág₁ quiáng'₂, tsá₃ juɨ₁le₂go₃.  
\v 30 Cuë₄ bí₂ quiáng'₂ a₂lé₂ jme₁'lion₅₄ jnia'₅₄ dsa₂ dso'₅₄, a₂lé₂ jmó₁ léi₄ dsɨ₂gó'₃ dsɨ₅ quian'₅₄ bí₂ 'éi'₃ quió'₅ Jesús, dsa₂ jŋió₅ i₂jme₂ti₃ quiáng'₂. 
\p  
\v 31 Jme₁ca₂dsan₃ chi₂léin'₂ Diú₄ le₂në₅, ca₂i₁bi₅₄ ja₁tioin'₅₄, jaun₂ ca₂le₃jɨ́n₃ qui₂ca₂cain'₂ Jme₂dsí₂ Jŋió₅. Jaun₂ tsá₃ ma₃juë́'₅ 'i₄ dsɨ́₅ qui₂ca₂'ë́₂ jág₁ dse₃ quió'₅ Diú₄. 
\s1 Ca₂le₃jë́₃ 'e₂ cha₂ jme₁lë́₄ quió'₅ ca₂le₃jɨ́in₃ 
\p  
\v 32 Ca₂le₃jɨ́n₃ dsa₂ i₂ma₂'én₂, caun₂ bá₄ a₂dsɨ₂jiog₅ dsɨ́₅, caun₂ bá₄ 'ei₅ jme₂dsí₂ quió'₅ ca₂le₃jɨ́in₃. 'I₁jan₂ tsá₃ jua'₅₄ a₂jmo₂₃ quió'₅ 'ŋiog₅ 'e₂ caun₂ a₂cha₂ quió'₅. Jmo₂₃ bá₄ dsɨ́₅ a₂quió'₅ co₂dsia₅ quiain'₅₄ rɨin'₅₄ ca₂le₃jë́₃ 'e₂ a₂cha₂ quió'₅.  
\v 33 Caun₂ ca₂'ág₂ tiá₂ dsɨ́₅ qui₂ca₂cuë₃ jág₁ dsau₅ dsɨ₂guia₃-tɨ́n₂ i₂chen₄\f + \fr 4:33 \ft griego: apóstolous.\f* quián₅ Diú₄ 'éi₂, 'a₂ lia'₂ ca₂jen'₅₄ Te₁gui'₅₄ Jesús. Jaun₂ caun₂ qui₂ca₂cuë₃ Diú₄ bí₂ 'ŋio₅ lɨn₃ quió'₅ ca₂le₃jɨ́n₃ dsa₂ i₂'én₂.  
\v 34 'I₁jan₂ tsá₃ 'ein₂ jua'₅₄ cha₂ qui₂ca₂rë₃'nió'₅ quió'₅, ia₁ dsa₂ i₂cha₂ 'uë₃, o₃ i₂tióng₂ 'né₅ quió'₅ në́₃, qui₂ca₂'nag₃.  
\v 35 Jaun₂ ca₂o₃can₅ cu₄ jaun₂, ca₂jɨ́in'₃ dsa₂ guia₃-tɨ́n₂ i₂chen₄ quián₅ Jesús 'éi₂, jaun₂ ca₂dsió'₃ ca₂cuë́'₃ le₂jan₂ le₂jan₂ 'a₂ con'₂ 'nió'₅ quió'₅.  
\v 36 Jme₁chan₂ jɨn₄ dsa₂ 'éi₂ jan₂ dsa₂ levita i₂jme₁chen₂ José i₂chan₂ Chipre. Dsa₂ i₂chen₄ në́₃ ca₂quiain₃ Së́₄ 'éi₂ Bernabé, co₂'nió'₄ a₂juá'₂ dsa₂ i₂jmo₅ lián'₂, i₂jme₂'o₅₄.\f + \fr 4:36 \ft lit. “jaun₅ lián'₂.” \f* 
\v 37 Bernabé 'éi₂ ca₂'nag₃ caun₂ 'uë₃ quió'₅ a₂jme₁cha₂. Ca₂le₃jë́₃ cu₄ jaun₂ ca₂o₃can₅ ca₂cuë́'₃ dsa₂ guia₃-tɨ́n₂. 
\c 5  
\s1 Dso₄ a₂ca₂'náu₂ Ananías quiain'₅₄ Safira 
\p  
\v 1 La₁ jan₂ dsa₂ sián'₂ i₂jme₁chen₂ Ananías quiain'₅₄ Safira 'io₅₄ quiáin₅, ca₂'nag₃ caun₂ 'uë₃ quió'₅.  
\v 2 Dsa₂ ŋe'₂ 'éi₂ ca₂'ma₃ ca₂dsio₄ cu₄ jaun₂ 'ŋiog₅, jaun₂ ca₂dsio₄ bá₄ ca₂i₁cuë'₂ dsa₂ guia₃-tɨ́n₂ i₂chen₄\f + \fr 5:2 \ft griego: apóstolous.\f* quián₅ Jesús, lia'₂ jag₄ bá₄ a₂i₁can₅ ta₁jë₂. Ján₃ bá₄ ŋi₅ 'io₅₄ quiáin₅.  
\v 3 Jaun₂ ca₂juá'₂ Pe₄ ca₂tsɨ́'₃ Ananías: 
\p ―¿'E₂ lë₃ ca₂'í₃ Satanás të₂'au'₂ jaun₂ jmo'₂ jág₁ të₂jág₁ ne₄ Jme₂dsí₂ Jŋió₅, a₂ca₂'ma'₅₄ ca₂dsio₄ cu₄ a₂ca₂quí₃ dsa₂ 'lia'₅₄ 'uë₃ quiáng'₂?  
\v 4 ¿On₁jua'₅₄ quiáng'₂ 'uë₃ a₂në₂'nag'₅₄? ¿On₁jua'₅₄ quiáng'₂ cu₄ jaun₂ në́₃? ¿'E₂ lë₃ ca₂i₃jiog₅ 'au'₂ jmó'₂ le₂në₅? Diú₄ bá₄ në₂chei'₅₄ 'ne₂ jág₁ të₂jág₁, on₃jua'₅₄ dsa₂ mɨ₂güɨ́g₃. 
\p  
\v 5 Dsɨ₂juɨ₅ jme₁në₂néi₂ Ananías le₂në₅, ca₂quɨin'₃ ca₂join₃. Jaun₂ ca₂le₃jɨ́n₃ dsa₂ i₂ca₂rë₃ŋi₅ a₂ca₂lë₃ le₂jaun₂ ca₂rë₃gó'₅ 'ŋio₅ lɨn₃.  
\v 6 Jaun₂ ca₂o₃lén₂ on₃-ún₂ chi'₂ dsa₂ ŋe'₂, ca₂lio₃ 'mɨ'₂ nɨ₁ŋɨ₁₂, jaun₂ ca₂i₁'ó₄. 
\p  
\v 7 Tsá₃ jaun₂ ŋi₅ 'io₅₄ quián₅ Ananías a₂ca₂lë₃ le₂jaun₂, jaun₂ ca₂dsióg₃ con'₂ 'nɨ₅ hora cang₂ jaun₂.  
\v 8 Jaun₂ ca₂ŋag₃ Pe₄ ca₂ŋɨ́i'₃ 'io₅₄: 
\p ―Jua'₅₄ dsón'₂. ¿'Ma'₅₄ jaun₂ në₂'nag'₅₄ 'nia'₂ 'uë₃ con'₂ lë́₅ jág₁ juá'₂ 'nia'₂? 
\p Jaun₂ ca₂ŋag₃ 'io₅₄: 
\p ―Ján₅. 'Ma'₅₄ jaun₂ dsón'₂ bá₄ i₂'nag₄. 
\p  
\v 9 Jaun₂ ca₂juá'₂ táng₃ Pe₄: 
\p ―¿'E₂ lë₃ në₂jmo'₅₄ 'nia'₂ caun₂ jág₁ a₂cáng'₄ táu₂ Jme₂dsí₂ quián₅ Te₁gui'₅₄? Ca₁'né₄ në₅ ma₂ja₂len₃ táng₃ dsa₂ i₂ma₃i₁'ón₄ dsɨ₂i₂gog'₂. Në₃ guë́₄ të₂ táng₃ 'ne₂. 
\p  
\v 10 Dsɨ₂juɨ₅ le₂jaun₂ ca₂quɨn'₃ 'io₅₄ ca₂join₃ ja₁chén'₄ Pe₄ jaun₂. Jme₁ca₂i₃ton'₅₄ chi'₂ dsa₂ ŋe'₂ 'éi₂, ma₂jon₅ bá₄ 'io₅₄, jaun₂ ca₂tág₃ táng₃ jaun₂ ca₂i₁'ó₄ cau₅ ja₁rë₂'on₅ dsɨ₂i₂gu₂.  
\v 11 Jaun₂ ca₂rë₃gó'₅ 'ŋio₅ lɨn₃ ca₂le₃jɨ́n₃ dsa₂ 'én₂ i₂lɨ́n₅ guá'₅, ca₂le₃jɨ́n₃ guë́₄ dsa₂ sián'₂ i₂ca₂rë₃ŋi₅ a₂ca₂lë₃ jaun₂. 
\s1 'Lióng₂ léi₄ juë'₂ a₂dsɨ₂gó'₃ dsɨ₅ në́₃, ca₂lë₃ 
\p  
\v 12 Quian'₅₄ bí₂ quió'₅ Diú₄ ca₂jmo₃ dsa₂ i₂chen₄ quián₅ Jesús 'lióng₂ léi₄ juë'₂ a₂dsɨ₂gó'₃ dsɨ₅ jɨn₄ dsa₂. Jaun₂ jme₁ŋɨ'₂ dsa₂ i₁dsi₅ guá'₅ templo ja₁lë́₄ corredor ja₁të́'₂ dsa₂ quió'₅ Salomón.  
\v 13 'I₁jan₂ tsá₃ ca₂tiá₂ dsɨ́₅ jme₃quiain'₅₄ dsa₂ i₂'én₂ 'éi₂, la₁ jme₁jme₂go₃ bá₄.  
\v 14 La₁ juɨn₅ bá₄ dsa₂ ŋe'₂, lia'₂ dsa₂ mɨ́₂ në́₃, ca₂rë₃'én₂ të₂le₃ quió'₅ Te₁gui'₅₄.  
\v 15 Ca₂lia'₂ jme₁dsɨ₂jŋiai₃ jë₄ calle dsa₂ dso'₅₄ tián'₅ ne₄ cama, ne₄ tsɨ₁jein₁ në₃, ia₁jaun₂ tsá₃ a₂nag₅₄ jŋia'₅₄ 'én'₁ quió'₅ bá₄ Pe₄ të₅₄ quió'₅ i₂lɨn₅₄ dsa₂ dso'₅₄ 'éi₂.  
\v 16 Ján₃ bá₄ ca₂o₃lén₂ juɨn₅ dsa₂ chan₂ juɨg₂ ma₂quián₅ Jerusalén, le₁jŋiai₂₃ dsa₂ le₁dso'₅₄, dsa₂ i₂tion'₅₄ jme₂dsí₂ 'lɨn'₅₄ të₂dsɨ́₅ në́₃, ca₂o₃lén₂. Jaun₂ ca₂le₃jɨ́n₃ dsa₂ 'éi₂ qui₂ca₂'lóin₂. 
\s1 Ca₂co₃'ein₃ dsa₂ quió'₅ Pe₄ quian'₅₄ Juan₅₄ 
\p  
\v 17 Jaun₂ ca₂rë₃'iog₅₄ 'ŋio₅ lɨn₃ jme₂dsa₂ dsen₅₄, quiain'₅₄ rɨin'₅₄ i₂jme₁lɨ́n₄ saduceos.  
\v 18 Jaun₂ ca₂jŋai'₃ dsa₂ i₂chen₄ quián₅ Jesús, ca₂i₁tio'₂ 'né₅ 'má₃.  
\v 19 La₁ a₂'uë₂ jaun₂, ca₂ŋe₄ jan₂ ángel quián₅ Te₁gui'₅₄ ca₂niá₃ 'né₅ 'má₃, ca₂'uɨ́in'₂ dsa₂ i₂chen₄ 'éi₂, ca₂juá'₂: 
\p  
\v 20 ―O₂nó'₅ 'nia'₂ i₁dsi₅ guá'₅ templo, o₂nau₂ o₂chei'₅₄ 'nia'₂ dsa₂ jág₁ dse₃ quió'₅ Juɨ₅ 'mɨ́₂ la₂. 
\p  
\v 21 Jme₁ca₂nág₂ jág₁ në₅, të₃ o₃'iog₂ jme₁jnia₃ jaun₂ ca₂i₁lein₅₄ guá'₅ ca₂i₁jme₁tɨin₂₃ dsa₂. 
\p Jmɨg₄ jaun₂ ca₂të₃ jme₂dsa₂ dsen₅₄ ca₂ŋɨ́i'₂ dsɨ₂tan₅₄ quián₅ guá'₅, jaun₂ ca₂jmo₃ 'éi'₃ i₁të₂ dsa₂ i₂chen₄ quián₅ Jesús i₂tion'₅₄ 'né₅ 'má₃ 'éi₂.  
\v 22 La₁ jme₁ca₂dsi₃lén₂ 'lióg₂\f + \fr 5:22 \ft o₃, chi'₂ 'ɨ'₅₄ quián₅ guá'₅.\f* 'né₅ 'má₃, tsá₃ ma₃dsa₂ i₂jme₁tion'₅₄ chan₂. Jaun₂ ca₂i₃lein₃ táng₃ i₁con₂ jág₁,  
\v 23 juá'₂: 
\p ―Jme₁chi₁jnág₅ dse₃ bá₄ o₄'né₄ 'né₅ 'má₃, jme₁tión₂ bá₄ guë'₂ 'lióg₂ jmo₂₃ 'í₁ cau₅ o₄'né₄ në́₃. La₁ jme₁në₂tió'₄ jnia'₅₄ dsi₂néi₂, tsá₃ ma₃dsa₂ i₂jme₁tion'₅₄ chan₂ 'i₁jan₂. 
\p  
\v 24 Jme₁ca₂nág₂ juɨg₅₄ jme₂dsa₂, juɨg₅₄ chi'₂ 'ɨ'₅₄ quián₅ guá'₅ në́₃, jaun₂ dsɨ₂gó'₃ dsɨ́₅ qui₂ca₂ŋɨ́i'₃ rɨin'₅₄ 'a₂ dsi₁quén'₅ ca₂le₃jë́₃ a₂në₅.  
\v 25 Jaun₂ ca₂dsióg₃ jan₂ dsa₂ quian₅ jág₁, jaun₂ ca₂juá'₂: 
\p ―Dsa₂ i₂ca₂jne'₅₄ 'nia'₂ 'né₅ 'má₃, ó₃ bá₄ ma₂tióin₂ i₁dsi₅ guá'₅ jme₂tɨin₂₃ dsa₂. 
\p  
\v 26 Jaun₂ në́₃ ca₂i₃lén₂ chi'₂ 'ɨ'₅₄ quiain'₅₄ juɨg₅₄ quiáin₅, jaun₂ ca₂i₁chong'₅₄ táng₃ lia'₂ 'i₄ rë₂ jág₁. Tsá₃ uɨg₅ ca₂jmóg'₂, ia₁ gó'₅ qui₃jnáu'₂ cang₄ dsa₂ i₂le₁ŋɨ'₂ ja₁jaun₂.  
\v 27 Jme₁ca₂dsi₃lein₃ le₁te₂ dsa₂ 'éi₂, jaun₂ ca₂chei'₃ dsi₂jo₂ ja₁le₁ŋɨ'₂ dsɨ₂tan₅₄ quián₅ guá'₅. Jaun₂ ca₂juá'₂ jme₂dsa₂ dsen₅₄ ca₂tsɨ́'₃ dsa₂ 'éi₂: 
\p  
\v 28 ―Ca₂jne₅₄ jnia'₅₄ co₂ŋei'₅₄ a₂tsá₃ ma₃jme₁tɨn'₅ 'nia'₂ dsa₂, jua'₅₄ a₂'ɨ́n'₄ guë́₄ 'nia'₂ Jesús 'éi₂. ¿'E₂ ma₂jmo'₅₄ guë'₂ 'nia'₂? Caun₂ qui₂jme₂tɨ́n'₁ 'nia'₂ dsa₂, tsá₃ jág₁ cán'₁, ca₂lia'₂ ta₁caun₂ juɨg₂ Jerusalén ma₂rë₂rɨn₅ quian'₅₄ jág₁ a₂jme₂tɨ́in'₁ 'nia'₂. A₂'niog'₂ 'nia'₂ bog'₅₄ jnia'₅₄ dso₄ a₂ca₂jon₃ dsa₂ 'éi₂. 
\p  
\v 29 Jaun₂ ca₂ŋag₃ Pe₄ quiain'₅₄ dsa₂ i₂chen₄ rɨin'₅₄: 
\p ―'Ŋio₅ guë́₄ dsen₅₄ ta₁ jme₁ti₁ jnia'₅₄ 'éi'₃ quió'₅ Diú₄, con'₂ guë́₄ 'éi'₃ quió'₅ dsa₂ mɨ₂güɨ́g₃.  
\v 30 Diú₄ quián₅ dsa₂ can'₅₄ quián₂ jniog₄ ma₂lɨ́g'₂, Diú₄ 'éi₂ bá₄ ca₂jme₃jen'₅₄ Jesús i₂ca₂jŋɨ́'₃ 'nia'₂ ca₂tióin'₃ cróg₄.  
\v 31 Diú₄ në́₃ ma₂ca₂chó'₂ guei'₅₄, jaun₂ ma₂guá₅ cau₅ quió'₅ të₂le₃ gu₂ ne₁, jaun₂ ma₂dsiog₃ a₂léin₂ juɨg₅₄ jniog₄ i₂lió₂, ia₁jaun₂ cuɨn₃ jmɨg₄ jme₃tsɨ́n₃ dsɨ́₅ dsa₂ juɨg₂ Israel ia₁jaun₂ 'én₂ dsáu₁.  
\v 32 Ca₂le₃jág₃ bá₄ jnia'₅₄ ca₂të́₂ ne₄ a₂në₅, ján₃ bá₄ jáng'₅ jág₁ dsau₅ Jme₂dsí₂ Jŋió₅ i₂ma₂cuɨn₃ Diú₄ quió'₅ dsa₂ i₂nag₅ gau₂ jme₂ti₃ jág₁ quió'₅. 
\p  
\v 33 Ca₂rë₃'né₃ 'ŋio₅ lɨn₃ dsa₂ can'₅₄ jme₁ca₂nág₂ le₂në₅, a₂'nio₃ jme₁jme₃dsiain₂₃ dsa₂ i₂chen₄ quián₅ Jesús 'éi₂.  
\v 34 La₁ jë₄ quió'₅ dsɨ₂tan₅₄ jaun₂, jme₁'en₅₄ jan₂ dsa₂ fariseo i₂jme₁chen₂ Gamaliel, dsa₂ i₂lɨ́n₅ të₅juá'₅, jaun₂ jme₁jme₂go₃ dsa₂ 'ŋio₅ lɨn₃. Jaun₂ ca₂nau₂ dsa₂ 'éi₂ jë₄ quió'₅ dsɨ₂tan₅₄, ca₂mɨ₃ a₂'uɨ́in'₂ ca₂tiá₂ dsa₂ i₂chen₄ 'éi₂.  
\v 35 Jme₁ca₂'uɨn₂ 'éi₂, jaun₂ ca₂juá'₂ Gamaliel ca₂tsɨ́'₃ dsɨ₂tan₅₄: 
\p ―'Nia'₂ dsa₂ chan₂ juɨg₂ Israel, jmo₄ 'nia'₂ 'í₁ a₂jma'₅₄ 'nia'₂ dsa₂ në₅.  
\v 36 Dsá₂ 'au'₂ 'nia'₂ jmo₄ a₂ca₂lë₃, ma₂ŋó₃ ca₂la₂ 'lióng₂ ŋi₂, ca₂nau₂ Teudas a₂juá'₂ a₂lɨ́in₅ dsa₂ 'uan'₂ dsa₂ dsen₅₄. Jaun₂ ca₂jme₃quiong'₅₄ con'₂ quén₂ 'ŋiá₂-lón₂ dsa₂ ŋe'₂. La₁ jme₁ca₂jŋag'₃ dsa₂, ca₂le₃jɨ́n₃ dsa₂ i₂jme₁quiain'₅₄ në́₃ ca₂i₃léin₂ jma₃quén₅.  
\v 37 Cang₂ jaun₂, jmɨg₄ jme₁ca₂tion₃ dsa₂ si₂, ca₂nau₂ Judas i₂chan₂ Galilea. Ján₃ bá₄ le₂jaun₂ juɨn₅ dsa₂ ca₂jme₃quiong'₅₄ quió'₅. La₁ ján₃ bá₄ ca₂jŋag'₃ dsa₂. Ca₂le₃jɨ́n₃ bá₄ dsa₂ i₂jme₁quiain'₅₄ në́₃ ca₂i₃léin₂ tsɨ₁rë₂jain₅₄ táng₃ jme₁ma₂jon₅ 'éi₂.  
\v 38 Jaun₂ lë₃, tsá₃ 'e₂ jmag'₅₄ dsa₂ në₅, tsá₃ lë₁tón'₂ 'nia'₂ mɨ'₅₄ quiain'₅₄. Ia₁ në₁jua'₂ jág₁ në₅ lë́₅ cosa quió'₅ dsa₂ mɨ₂güɨ́g₃, a₂lë₁dsɨ₃'én₂ bá₄ në₅.  
\v 39 La₁ia₁ në₁jua'₂ lë́₅ cosa quió'₅ Diú₄, tsá₃ a₁jaun₂ le₃quɨ'₅₄ 'nia'₂ jmɨg₄ a₂'éng'₄. Jaun₂ 'í₁ jmo₄ ia₁ con'₂ tsá₃ ŋó₅ në₁jua'₂ quian'₅₄ Diú₄ quɨ́n'₂ 'nia'₂. 
\p  
\v 40 Jaun₂ ca₂nág₂ jág₁ jaun₂ ca₂le₃jɨ́in₃. Jaun₂ ca₂të́'₃ táng₃ dsa₂ i₂chen₄ quián₅ Jesús 'éi₂. Jaun₂ ca₂jmo₃ dsɨ₂tan₅₄ 'éi'₃ a₂bóg₂ dsa₂. Jaun₂ ca₂jné₃ táng₃ tsá₃ cuë₂₃ jmɨg₄ jua'₅₄ a₂'ë́₂ guë́₄ dsa₂ 'éi₂ jág₁ a₂'ɨin₂₃ Jesús. Jaun₂ ca₂lió₂ bá₄ jaun₂ në́₃.  
\v 41 Jme₁ca₂'uɨn₂ dsa₂ i₂chen₄ quián₅ Jesús 'éi₂, jɨn₄ dsɨ₂tan₅₄, jmo₂₃ 'io'₂, ia₁ ca₂cuë₃ Diú₄ jmɨg₄ ca₂i₃ŋɨ́i₂ o₂guí'₃ o₄quió'₄ Jesús.  
\v 42 Jaun₂ caun₂ ca₂i₁nioi₁₂ bá₄ jme₂tɨin₂₃ dsa₂ jág₁ dse₃ quió'₅ Jesucristo ca₂le₃jë́₃ jmɨg₄, lia'₂ i₁dsi₅ guá'₅ templo, lia'₂ dsi₂néi₂ quió'₅ dsa₂ në́₃. 
\c 6  
\s1 Ca₂'nai'₂ guion₃ dsa₂ i₂jme₃'o₅₄\f + \fr 6:0 \ft o₃, diáconos. 'Nio'₂ ja₁ton₅ Hechos 21:8; Filipenses 1:1.\f* 
\p  
\v 1 Jmɨg₄ jaun₂ caun₂ dsɨ₂juɨ́n₂ bá₄ dsa₂ i₂'én₂. Jaun₂ dsa₂ i₂dsia₅ jág₁ jmei₅ griego ca₂jí₂ ca₂tsɨ́'₃ dsa₂ i₂dsia₅ jág₁ jmei₅ arameo. Ca₂juá'₂ 'ɨin₂₃ 'io₅₄ 'nág₂ chan₂ quiáin₅ tsá₃ lɨn₄ dse₃ jme₁cuë́'₅ dsa₂ juɨ₁lia'₂ 'e₂ má₃ dsió'₅ ca₂le₃jë́₃ jmɨg₄.  
\v 2 Jaun₂ ta₁guia₃-tɨ́n₂ dsa₂ i₂chen₄\f + \fr 6:2 \ft griego: apóstolous.\f* quián₅ Jesús ca₂ŋɨ́i'₂ ca₂le₃jɨ́n₃ dsa₂ i₂'én₂, jaun₂ ca₂juá'₂: 
\p ―Tsá₃ dse₃ jua'₅₄ a₂tí₅ jnia'₅₄ a₂'ë́₄ jnia'₅₄ jág₁ quió'₅ Diú₄ a₂jme₁ti₁ jnia'₅₄ ne₄ mesas a₂dsio'₅₄ jnia'₅₄ má₃.  
\v 3 Jaun₂ lë₃ rɨn'₅₄ jniog₄, 'ɨn₅₄ 'nia'₂ guion₃ dsa₂ të₃jɨn'₄ 'nia'₂, i₂'ei₅ jág₁ a₂'en₅₄ dsɨ́₅, a₂rë₂rɨn₅ Jme₂dsí₂ Jŋió₅ të₂dsɨ́₅, jaun₂ cuë'₅₄ 'nia'₂ ta₁ në₅.  
\v 4 Jnia'₅₄ guë'₂ caun₂ qui₁chei₅₄ Diú₄, caun₂ qui₂jme₁tɨn₅ jnia'₅₄ dsa₂ jág₁ quió'₅ Diú₄. 
\p  
\v 5 Jaun₂ ca₂le₃jɨ́n₃ dsa₂ ca₂të́₂ dsɨ́₅ a₂në₅, jaun₂ ca₂quióin'₂ dsa₂ i₂chen₂ Esteban i₂'én₂ 'ŋio₅ lɨn₃, i₂rë₂rɨn₅ Jme₂dsí₂ Jŋió₅ të₂dsɨ́₅; Fe₂li₄ në́₃, Prócoro, Nicanor, Timón, Parmenas, Nicolás në́₃ i₂lɨ́n₅ jan₂ dsa₂ chan₂ Antioquía i₂jme₁ma₂gue₃ le₂jŋiá₅ 'Éi'₃ Juá'₅ quió'₅ dsa₂ judíos.  
\v 6 Jaun₂ ca₂o₃jŋia₃ dsa₂ dsa₂ guion₃ i₂ca₂'ɨin₃ 'éi₂ ja₁tión₂ dsa₂ guia₃-tɨ́n₂, jaun₂ qui₂ca₂quiog₂ gu₂ ne₄ quió'₅ dsa₂ guion₃ 'éi₂, ca₂chi₃léin'₂ Diú₄. 
\p  
\v 7 Jaun₂ caun₂ ca₂i₃'ág₃ jág₁ quió'₅ Te₁gui'₅₄ jë₄ juɨg₂ Jerusalén, jaun₂ caun₂ ca₂i₃juɨ́n₂ bá₄ dsa₂ i₂ca₂rë₃'én₂, ca₂të₂ i₂jme₁lɨ́n₄ jme₂dsa₂ quián₅ dsa₂ judíos ca₂guein₃ jág₁, ca₂rë₃'én₂ juɨn₅. 
\s1 Ca₂jŋa'₃ dsa₂ Esteban 
\p  
\v 8 Esteban, dsa₂ i₂'ŋio₅ lɨn₃ ma₂cuë₃ Diú₄ juɨ₅bí₂, ma₂jme₂'o₅₄ në́₃, i₂'éi₂ jme₁jmo₂₃ 'lióng₂ léi₄ dsɨ₂gó'₃ dsɨ₅ jɨn₄ dsa₂ juɨg₂.  
\v 9 Jaun₂ i₂lɨn₅₄ dsa₂ quián₅ guá'₅ sinagoga i₂jme₁të́'₂ dsa₂ Libertinos, quiain'₅₄ i₂lɨn₅₄ dsa₂ chan₂ Cirene, i₂lɨn₅₄ i₂chan₂ Alejandría, i₂chan₂ Cilicia, i₂chan₂ juɨg₂ ja₁tén₄ 'uë₃ Asia në́₃, ca₂jme₃lióg₃ ca₂tsɨ́in₂ quian'₅₄ Té₂.  
\v 10 La₁ tsá₃ ca₂tio₃, ia₁ a₂niog₅ dsi₄ 'éi₂, tɨin₂ 'a₂ lia'₂ ŋag₃, ia₁ Jme₂dsí₂ Jŋió₅ bá₄ cuë₅ bí₂.  
\v 11 Jaun₂ ca₂láin₂ dsa₂ i₂jáng'₃ jág₁ të₂jág₁, a₂juá'₂ a₂ma₂nág₂ juá'₂ Té₂ 'ɨin₂₃ 'lɨg'₅₄ Moisés, 'ɨin₂₃ 'lɨg'₅₄ Diú₄ në́₃.  
\v 12 Jaun₂ le₂jaun₂ ca₂tóin'₂ co₂mɨ'₅₄ jɨn₄ dsa₂ juɨg₂ quian'₅₄ dsɨ₂gui'₅₄ can'₅₄, të₅juá'₅ në́₃, ca₂jmái'₂ mɨ'₅₄ Té₂, ca₂jŋau'₃, ca₂i₁jo₅₄ ne₄ dsɨ₂tan₅₄ quián₅ guá'₅.  
\v 13 Jaun₂ ca₂'nai'₂ ján₃ dsa₂ i₂jmo₃ jág₁ të₂jág₁ a₂'nɨi₃ Té₂. Jaun₂ ca₂juá'₂: 
\p ―Dsa₂ në₅ caun₂ qui₂juá'₂ 'lɨg'₅₄ 'ë₂₃ guá'₅ jŋió₅, 'ë₂₃ 'Éi'₃ Juá'₅ në́₃.  
\v 14 Ján₃ bá₄ ma₂ca₂néi₁ jnia'₅₄ juá'₂ i₂në₅ a₂'én₂ Jesús chan₂ Nazaret guá'₅ a₂jme₃tsɨ́in₃ tag₄ chí'₅ ca₂quiog₂ Moisés. 
\p  
\v 15 Jaun₂ dsɨ₂tan₅₄ quiain'₅₄ ca₂le₃jɨ́n₃ guë́₄ dsa₂ i₂jme₁tion'₅₄ le₁ŋɨ'₂ ja₁jaun₂, ca₂jɨ́in₂ Té₂, a₂ma₂jniá₂ dsɨ₂ne₄ 'éi₂ lia'₂ jniá₂ jan₂ ángel. 
\c 7  
\s1 Jág₁ ca₂ton₃ Esteban 
\p  
\v 1 Jaun₂ ca₂ŋag₃ jme₂dsa₂ dsen₅₄ ca₂ŋɨ́i'₃ Té₂: 
\p ―¿Dsón'₂ dsau₅ ca₂le₃jë́₃ a₂juá'₂ dsa₂ në₅? 
\p  
\v 2 Jaun₂ ca₂ŋag₃ 'éi₂: 
\p ―Rɨn'₅₄ jniog₄, 'nia'₂ dsa₂ can'₅₄ quián₂ në́₃, nei₂ 'nia'₂ a₂juá'₄ jniá₂ la₂. Diú₄ 'uan'₂ quián₂ jniog₄ ca₂jme₃jniai₂₃ ne₄ jmei₂ jniog₄ Abraham lia'₂ con'₂ jme₁'ein₅₄ 'uë₃ Mesopotamia né'₃ a₂dsɨ₃guá₃ juɨg₂ Harán.  
\v 3 Jaun₂ ca₂juá'₂ Diú₄: “Tí₃ 'uë₃ quiáng'₂, tén₃ ca₂le₃jɨ́n₃ o₁rɨ́ng'₂, gua₂ juɨ₅ 'uë₃ ja₁i₁'ë₃ jniá₂.”\f + \fr 7:3 \ft Génesis 12:1.\f* 
\p  
\v 4 'Jaun₂ ca₂ŋó₃ Abraham ca₂o₃'ɨ́in₃ 'uë₃ Caldea jaun₂, ca₂i₁gua₂ juɨg₂ Harán. Cang₂ jaun₂ ca₂jon₃ bá₄ jmei₂. Jaun₂ Diú₄ bá₄ ca₂o₃jŋia₃ Abraham 'uë₃ la₂ ja₁tián'₄ 'nia'₂ rë₂në́₃.  
\v 5 La₁ tsá₃ jua'₅₄ 'e₂ ca₂cuë₃ Diú₄ 'uë₃ la₂, on₃ guë'₂ ja₁chi'₃ caun₂ tag₅₄ jua'₅₄ ca₂cuë₃. La₁ ca₂cuë₃ bá₄ Diú₄ jág₁ quió'₅ a₂cuë₃ 'uë₃ la₂, a₂jmo₃ le₃cha₂ quió'₅ chi'₂ quián₅ bá₄ Abraham jë₁ma₂join₂₃, o₁jŋia'₅₄ guë'₂ jmɨg₄ jaun₂ tsá₃ chi'₂ quián₅ Abraham jme₁chan₂ 'i₁jan₂.  
\v 6 Jaun₂ ca₂juá'₂ Diú₄ ján₃, ca₂le₃jɨ́n₃ chi'₂ dsio₄ Abraham tiain'₃ juɨ₁lia'₂ ja₁tián'₄ dsɨ₂nau₂ caun₂ 'uë₃ a₂tsá₃ cuɨ́'₅, qui₃ŋág₃ uɨg₅ con'₂ quén₂ 'ŋiá₂-láu₂ ŋi₂ a₂lë₁jmo₃ ta₁ jme₂ti₃ ta₁ ne₄ dsa₂.  
\v 7 La₁ ján₃ bá₄ ca₂juá'₂ Diú₄ ca₂tsɨ́'₃ Abraham: “Jniá₂ bá₄ 'ë́₄ uɨg₅ ne₄ juɨg₂ i₂jmá'₂ dsa₂ quiáng₃ i₂tion'₅₄ i₂lë₁jme₂ti₃ ta₁ ne₅₄. Cang₂ jaun₂ guion₅₄ dsa₂ juɨg₂ quiáng₃ 'uɨ́in₃ juɨg₂ jaun₂, jaun₂ ja₃léin₂ jme₃ti₃ ta₁ ne₃ ja₁lá₃.”\f + \fr 7:7 \ft Génesis 15:13-14.\f* 
\v 8 Ján₃ bá₄ ca₂jmo₃ Diú₄ caun₂ jág₁ quian'₅₄ Abraham, a₂ti₃ nɨ₁lo₁ ta₁jɨn₂ chi'₂ dsa₂ ŋe'₂ tsɨ₁jon₂ quiáin₅, a₂lɨ'₅₄ jág₁ a₂të₃ron₅₄. 'Uɨg₅₄ jaun₂, jme₁ca₂rë₃chán₃ ja₁ŋi'₅₄ i₂ca₂rë₃chén₃ Isaac, ca₂ti₃ Abraham nɨ₁lo₁ Isaac jme₁ma₂'ein₅₄ jŋia₃ jmɨg₄. Ján₃ bá₄ le₂jaun₂ ca₂jmo₃ Isaac quian'₅₄ Jacob ja₁ŋi'₅₄. Ján₃ bá₄ le₂jaun₂ ca₂jmo₃ Jacob quian'₅₄ ta₁guia₃-tɨ́n₂ ja₁ŋi'₅₄ i₂ca₂lɨn₃ jmei₂ ta₁guia₃-tɨ́n₂ juɨg₂ ja₁tén₄ Israel. 
\p  
\v 9 ’Ca₂le₃jɨ́n₃ chi'₂ ja₁ŋi'₅₄ Jacob i₂jme₁lɨ́n₄ jmei₂ jniog₄ ma₂lɨ́g'₂ 'éi₂, ca₂i₃uɨg₅₄ dsɨ́₅ jɨ́in₂ Së́₄ rɨin'₅₄. Jaun₂ ca₂'nɨi₃ 'éi₂ jaun₂ ca₂tág₃ dsa₂ ca₂të₂ 'uë₃ Egipto. La₁ Diú₄ bá₄ ca₂jmo₃ 'í₁ quió'₅ Së́₄,  
\v 10 qui₂ca₂lió₂ ca₂le₃jë́₃ 'e₂ ca₂i₃ŋɨ́i₂ ca₂jmo₃ ca₂rë₃ŋɨ́'₂ dsɨ́₅ 'ŋio₅ lɨn₃. Ján₃ bá₄ ca₂jmo₃ Diú₄ a₂chéin'₅ dse₃ quiain'₅₄ i₂të́'₂ dsa₂ Faraón, i₂lɨ́n₅ rag₅₄ quián₅ 'uë₃ Egipto. Rag₅₄ 'éi₂ ca₂'ɨin₃ Së́₄ a₂léin₂ dsi₄má'₂ 'uë₃ Egipto. Ján₃ bá₄ ca₂jmo₃ a₂nio₃ ne₄ 'éi₂ dsi₂néi₂ quió'₅. 
\p  
\v 11 ’Cang₂ jaun₂ ca₂gua₃ ŋi₂ a₂ca₂ŋág₃ uɨg₅ 'ŋio₅ lɨn₃ a₂ca₂rë₃'ɨ́n₃ a₂guë́'₃ dsa₂ ta₁caun₂ 'uë₃ Egipto quian'₅₄ 'uë₃ Cana'án. Jaun₂ ca₂le₃jɨ́n₃ jmei₂ jniog₄ ma₂lɨ́g'₂ tsá₃ ma₃'e₂ jnio'₂ a₂guë́'₃.  
\v 12 Jme₁ca₂rë₃ŋi₅ Jacob a₂cha₂ trigo 'uë₃ Egipto, jaun₂ ca₂chein₃ chi'₂ ja₁ŋi'₅₄ ja₁jaun₂, i₂ca₂lɨn₃ jmei₂ jniog₄ ma₂lɨ́g'₂. A₂jaun₂ guë́₄ le₂'uɨg₅₄ ca₂i₁lein₅₄.  
\v 13 Jme₁ca₂të́₂ tɨn₃ ráun₂ i₁len₅₄ rɨn'₅₄ Së́₄ 'uë₃ Egipto, jaun₂ ca₂jmo₃ Së́₄ a₂ca₂rë₃ŋi₅ a₂lë́₅ rɨin'₅₄ dsa₂ 'éi₂. Jaun₂ guë́₄ ca₂rë₃ŋi₅ rag₅₄ quián₅ Egipto 'e₂ tsɨ₁jon₂ lɨ́n₅ Së́₄.  
\v 14 Jaun₂ guë́₄ ca₂tsɨ́'₃ Së́₄ dsó₂ rɨin'₅₄ a₂dsɨ₃quiáin₂ gui'₅₄ Jacob jmei₂, quian'₅₄ ca₂le₃jɨ́n₃ o₁rɨin'₅₄ i₂jme₁lë́₂ 'nag'₂ ne₂guióg₂ rë₂dsɨ́₂ guia₃-'ŋiá₂ (75) dsa₂.  
\v 15 Le₂jaun₂ ca₂lë₃ a₂ca₂ŋó₃ Jacob ca₂i₁gua₂ 'uë₃ Egipto. Ja₁jaun₂ ca₂join₃ cang₂ jaun₂. Jaun₂ ja₁jaun₂ bá₄ qui₂ca₂dsan₃ chi'₂ quiáin₅ i₂'nió'₄ jmei₂ jniog₄ ma₂lɨ́g'₂.  
\v 16 Nɨ₁mu₁₂ ca₂o₃con₃ dsa₂ cang₂ jaun₂ ja₁chei₂ Siquem. Ca₂o₃'ó₃ tau₂ 'ŋio₅ a₂ca₂lá₃ Abraham quió'₅ tsɨ₁jon₂ chi'₂ quián₅ Hamor ja₁chei₂ Siquem jaun₂, quian'₅₄ caun₂ 'ma'₅₄ a₂ca₂lɨ́'₃. 
\p  
\v 17 ’Jme₁ja₂quián₃ jmɨg₄ le₃ti₃ jág₁ ca₂cuë₃ Diú₄ 'ɨin₂₃ 'ŋiog₅ ca₂cuë́'₃ Abraham, ca₂i₃juɨ́n₂ 'ŋio₅ lɨn₃ dsa₂ israelitas 'uë₃ Egipto.  
\v 18 Jaun₂ ca₂guá₂ jan₂ rag₅₄ i₂tsá₃ cuɨn₅ Së́₄, ca₂jme₃lióg₃ jmo₂₃ 'éi'₃ 'uë₃ Egipto.  
\v 19 Rag₅₄ 'éi₂ ca₂jme₃gain₂₃ dsa₂ go₄ jniog₄, ca₂jmái'₂ dsa₂ can'₅₄ quián₂ jniog₄ ca₂jmo₃ 'éi₂ tion₅₄ a₂téin₂ guein₂ dsa₂ ŋe'₂ i₂të₂ca₂rë₃chán₃, ia₁jaun₂ dsiáin₃. 
\p  
\v 20 'Jmɨg₄ jaun₂ ca₂rë₃chán₃ Moisés. Guein₂ 'éi₂ ca₂të́₂ dsɨ́₅ Diú₄, jaun₂ ca₂jme₃juag'₂ chog₅₄-jmei₂ 'nɨ₅ tsɨ'₂ dsi₂néi₂ quió'₅.  
\v 21 Jme₁ca₂të́₂ jmɨg₄ a₂tóin₂ guein₂ 'éi₂, jaun₂ ja₁mɨ́g₄ 'ŋiog₅ rag₅₄ quián₅ Egipto ca₂tág₃ ca₂jme₃juag'₂ co₂'nió'₄ ja₁ŋi'₅₄ 'ŋiog₅.  
\v 22 'Uɨg₅₄ jaun₂, ca₂rë₃tɨ́n₃ Moisés ca₂le₃jë́₃ a₂ŋi₅ dsa₂ chan₂ Egipto, jaun₂ ca₂rë₃'uáin'₃, 'ŋio₅ lɨn₃ ŋi₅ 'e₂ jág₁ dsia₃, ŋi₅ a₂ca₂jmo₃ në́₃. 
\p  
\v 23 ’Jme₁ma₂'ein₅₄ të₂láu₃ ŋi₂, jaun₂ ca₂ŋe₄ Moisés ca₂i₁jɨin₁₂ dsa₂ go₅₄ dsa₂ israelitas.  
\v 24 Ja₁jaun₂ ca₂jɨ́in₂ jan₂ dsa₂ chan₂ Egipto jmái'₂ uɨg₅ cuë́'₅ jan₂ dsa₂ go₅₄. Jaun₂ ca₂nau₂ Moisés 'nei₂ quiain'₅₄ i₂cuë́'₅ rɨin'₅₄, ca₂jŋɨi'₃ dsa₂ 'éi₂, ca₂lióin₂ dsa₂ go₅₄.  
\v 25 Ia₁ ca₂i₃jiog₅ dsɨ́₅ jaun₂ le₃lí'₄ dsa₂ israelitas rɨin'₅₄, a₂jmo₃ Diú₄ lió₂ të₂le₃ quian'₅₄ 'éi₂. La₁ tsá₃ ca₂rë₃lí'₄ guë'₂ dsa₂.  
\v 26 Jme₁jnia₃ jaun₂, ca₂jen'₂ Moisés on₃ dsa₂ israelitas i₁tion'₅₄ quɨ́n'₂. Jaun₂ jme₁'nio₃ Moisés dsioin₃ mɨ'₅₄. Jaun₂ ca₂juá'₂: “Rɨ́n'₂ bá₄ 'nia'₂. ¿'E₂ lë₃ qui₂jma'₅₄ 'nia'₂ uɨg₅ le₂jang'₂ le₂jang'₂?” 
\p  
\v 27 'Jaun₂ i₂jme₁'en₅₄ cuë́'₅ rɨn'₅₄ ca₂'liain'₃ Moisés cau₅, jaun₂ ca₂juá'₂: “¿'Ein₂ ca₂cuë́'₃ 'ne₂ ta₁ lɨ́ng'₅ dsɨ₂tan₅₄ i₂qui₂dsɨ₅ 'éi'₃ ja₁con₂ jnia'₅₄?  
\v 28 ¿'Niog'₂ jŋág'₄ jniá₂ ján₃ juɨ₁lia'₂ ca₂jŋɨ́g'₃ dsióg₂ dsa₂ chan₂ Egipto 'éi₂?”\f + \fr 7:28 \ft Éxodo 2:14.\f* 
\v 29 Jme₁ca₂nág₂ Moisés le₂në₅, co₂tan₅₄ ca₂cuɨng₃ ca₂ŋó₃ juɨ₅ 'uë₃ ja₁chei₂ Madián. Ja₁jaun₂ ca₂i₁gua₂ co₂'nió'₄ a₂lɨ́in₅ dsɨ₂nau₂. Ja₁jaun₂ ca₂rë₃chán₃ on₃ chi'₂ quiáin₅. 
\p  
\v 30 ’Të₂láu₃ ŋi₂ cang₂ jaun₂, caun₂ ja₁lë́₄ 'uë₃ quein₂ quián₅ má'₂ ja₁chei₂ Sinaí, ja₁jaun₂ ca₂jme₃jnia₅ jan₂ ángel jë₄ si₂ chi₁guí'₂ caun₂ nɨ₁'ma₂ taun₅ a₂cau₂.  
\v 31 Jaun₂ ca₂i₃gó'₃ dsɨ́₅ Moisés jme₁ca₂jág₃ a₂në₅, jaun₂ jme₁ca₂jme₃quiáin₃ guë́₄ ia₁ 'nio₃ jme₁jág₃ guë́₄ dse₃. Të₃jë₄ ŋó₃ jaun₂ jme₁ca₂nág₂ jág₁ quió'₅ Te₁gui'₅₄ a₂ca₂juá'₂:  
\v 32 “Jniá₂ bá₄ lɨ́ng₅ Diú₄ quián₅ dsa₂ quiáng'₂ ma₂lɨ́g'₂, Diú₄ quián₅ Abraham, quián₅ Isaac, quián₅ Jacob në́₃.”\f + \fr 7:32 \ft Éxodo 3:6.\f* Jaun₂ ca₂jme₃lióg₃ ca₂jlen₃ Moisés ca₂rë₃gó'₅ 'ŋio₅ lɨn₃, tsá₃ ma₃tiá₂ dsɨ́₅ jág₃. 
\p  
\v 33 'Jaun₂ ca₂juá'₂ táng₃ Te₁gui'₅₄: “Jŋiá'₃ lau₂ ton₅ tag'₅₄, ia₁ 'uë₃ jŋió₅ bá₄ ja₁chéng'₄ në₅.  
\v 34 Jág₅ bá₄ jniá₂ a₂chan₂ uɨg₅ dsa₂ quiáng₃ 'uë₃ Egipto, qui₂nag₅ bá₄ jniá₂ a₂quɨ'₂-'o₂₃. Jaun₂ lë₃ ca₂sióng₃ ia₁ a₂loin₅₄. Ŋia₅, ia₁jaun₂ tsag₅₄ jniá₂ guang'₅₄ juɨ₅ Egipto”.\f + \fr 7:34 \ft Éxodo 3:5,7,8,10.\f* 
\p  
\v 35 ’O₁jŋia'₅₄ la₂ tsá₃ jme₁'nio₃ dsa₂ go₄ Moisés le₂jŋiá₅, ia₁ ca₂juá'₂: “¿'Ein₂ ca₂'ɨn₃ 'ne₂ a₂lɨ́ng'₅ dsɨ₂tan₅₄ i₂qui₂dsɨ₅ 'éi'₃ ja₁con₂ jnia'₅₄?” la₁ Diú₄ në́₃ ca₂chein₃ Moisés a₂lɨ́in₅ co₂'nió'₄ dsɨ₂tan₅₄ i₂lió₂, të₂le₃ quian'₅₄ ángel i₂ca₂jme₃jnia₅ jë₄ nɨ₁'ma₂ taun₅ jaun₂.  
\v 36 Moisés bá₄ dsa₂ i₂ca₂'uɨ́n'₂ dsa₂ can'₅₄ quián₂ jniog₄ ma₂lɨ́g'₂ 'uë₃ Egipto i₂qui₂ca₂jmo₃ ján₃ 'lióng₂ léi₄ juë'₂ a₂dsɨ₂gó'₃ dsɨ₅ në́₃. Léi₄ jaun₂ ca₂jmo₃ Moisés 'uë₃ jaun₂, quian'₅₄ ne₄ Jmɨ₁ŋí'₄ Guéin₂,\f + \fr 7:36 \ft Ján₃ bá₄ chei₂ Jmɨ₁ŋí'₄ 'Ma₂ta₅.\f* quian'₅₄ 'uë₃ quein₂ co₂'ŋiog₅ ja₁ca₂i₁nioi₁₂ të₂láu₃ ŋi₂.  
\v 37 Jaun₂ 'ŋiog₅ Moisés 'éi₂ bá₄ ca₂tsɨ́'₃ dsa₂ israelitas: “A₂chen₃ Diú₄ jan₂ dsa₂ i₂'ë́₂ jág₁ quiáin₅, i₂lɨ́n₅ dsa₂ go'₄ 'nia'₂ guiong'₅₄, juɨ₁lia'₂ ca₂chei₃ jniá₂. Jaun₂ tón'₂ 'nia'₂ juɨ₅ jág₁ quió'₅ 'éi₂.”\f + \fr 7:37 \ft Deuteronomio 18:15.\f* 
\v 38 Ján₃ bá₄ Moisés 'éi₂ jme₁'en₅₄ quian'₅₄ dsa₂ juɨg₂ 'uë₃ quein₂ co₂'ŋiog₅ jaun₂. Jme₁'ein₅₄ quian'₅₄ ángel i₂ca₂juá'₂ jág₁ má'₂ Sinaí. Ján₃ bá₄ jme₁'ein₅₄ quian'₅₄ 'lag₄ tsɨ₁jon₂ jmei₂ jniog₄. Moisés 'éi₂ bá₄ ján₃ i₂ca₂gue₃ jág₁ ca'₅₄, jaun₂ guë́₄ ca₂ŋág₃ të₂le₃ quián₂ jniog₄ táng₃. 
\p  
\v 39 ’La₁ dsa₂ quián₂ jniog₄ ma₂lɨ́g'₂ në́₃, tsá₃ ma₃ca₂jme₃ti₃, tsá₃ ma₃ca₂nág₂ gau₂ jág₁ quió'₅ Moisés. Ca₂chei'₃ cau₅, jme₁'nio₃ jme₁dsɨ₃lein₃ táng₃ juɨ₅ 'uë₃ Egipto.  
\v 40 Jaun₂ në́₃ ca₂tsɨ́'₃ Aarón\f + \fr 7:40 \ft Jme₁lɨ́n₄ Aarón rɨn'₅₄ Moisés. 'Nio'₂ ja₁ton₅ Éxodo 4:14.\f* ca₂juá'₂: “'Niog₂ jnia'₅₄ jmog'₅₄ diú₄ dsa₂ lag₄ i₂dsɨ₃lén₂ ne₄ juɨ₅ quián₂ jniog₄. Ia₁ tsá₃ ne₄ 'e₂ ca₂jén'₃ Moisés 'éi₂ i₂ca₂'uág'₂ jniog₄ 'uë₃ Egipto.”\f + \fr 7:40 \ft Éxodo 32:1.\f* 
\v 41 Jaun₂ ca₂jmói'₂ jan₂ guein₂ ca₁juɨ₅ co₂'nió'₄ i₂lɨ́n₅ diú₄, qui₂ca₂jme₃dsiain₂₃ já'₂ quiáin₅ qui₂ca₂cuɨin₃ diú₄ lag₄ 'éi₂. Jaun₂ ca₂jmo₃ 'io'₂ quian'₅₄ a₂ca₂jmo₃ quian'₅₄ gu₂ guioin₅₄.  
\v 42 Jaun₂ co₂ŋei'₅₄ ca₂jmo₃ Diú₄ cau₅, tsá₃ ma₃ca₂jme₃quiain'₅₄ dsa₂ 'éi₂, juɨ₁jmo₁₂ bá₄ con'₂ tɨin₂ guioin₅₄. Jaun₂ ca₂jme₃lióg₃ dsa₂ 'éi₂ ca₂chi₂ca₂léin'₂ nei₅ a₂le₁'ág₄\f + \fr 7:42 \ft nei₅: Lia'₂ chi₁ton₅ ne₄ Si₂ quió'₅ Diú₄, lë́₅ caun₂ cosa a₂tsá₃ 'i₄ jme₂dsí₂.\f* guei'₅₄. Ia₁ le₂në₅ rë₂ton₅ ne₄ Si₂ a₂ca₂jmo₃ dsa₂ i₂jme₁'ë́₂ jág₁ quián₅ Diú₄ ma₂lɨ́g'₂: 
\q1 'Nia'₂ dsa₂ chan₂ Israel, ¿'e₂ lɨ́n'₂ 'nia'₂? 
\q1 ¿Ca₂jme₁dsian'₅ 'nia'₂ já'₂ 
\q2 ca₂dsia'₅₄ ca₂jen'₅₄ 'nia'₂ ne₃ jniá₂ 
\q1 lia'₂ con'₂ jme₁quian'₅₄ jniá₂ 'nia'₂ 
\q2 të₂láu₃ ŋi₂ 'uë₃ quein₂ co₂'ŋiog₅ jaun₂? 
\q1  
\v 43 On₃jua'₅₄ le₂jaun₂. 
\q1 Ia₁ guá'₅ chéi₂ quió'₅ diú₄ Moloc bá₄ ca₂quian'₂ 'nia'₂ 
\q2 quian'₅₄ nei₅ diú₄ Renfán,\f + \fr 7:43 \ft Renfán: co₂'nió'₄ a₂jme₁të́'₂ dsa₂ egipcios planeta Saturno, ca₂jme₃juag'₂ dsa₂.\f* 
\q2 nió'₄ a₂qui₂ca₂jmo'₅₄ 'nia'₂ guiong'₅₄, 
\q2 a₂jaun₂ bá₄ ca₂chi₂ca₂len'₄ 'nia'₂. 
\q1 'Uɨg₅₄ jaun₂, 'uɨ́n'₄ jniá₂ 'nia'₂ 'uë₃ quiáng'₂, 
\q2 tsag₅₄ jniá₂ të₂le₃ ó₃ guë́₄ ja₁niog₅ 'uë₃ Babilonia.\f + \fr 7:43 \ft Amós 5:25-27.\f* 
\p  
\v 44 ’'Uë₃ quein₂ jaun₂, dsa₂ can'₅₄ quián₂ jniog₄ ma₂lɨ́g'₂ jme₁quian₅ guá'₅ tabernáculo ja₁jme₁rë₂'ma₄ nɨ₁cang₁ a₂le₁ton₅ ta₁guia₃ 'Éi'₃ Juá'₅. Guá'₅ tabernáculo jaun₂ ca₂lë₃ con'₂ lë́₅ jág₁ ca₂cuë₃ Diú₄ ca₂cuë́'₃ Moisés, jme₁ca₂'ë₃ Diú₄ nió'₄ le₂jŋiá₅ 'a₂ lia'₂ lé₂.  
\v 45 Dsa₂ quián₂ jniog₄ ma₂lɨ́g'₂ ca₂gue₃ guá'₅ jaun₂ co₂'nió'₄ ca₂ŋág₃ dsa₂ can'₅₄ quiáin₅. Jaun₂ dsa₂ i₂jme₁quian'₅₄ Josué në́₃ ca₂cáun₃ lia'₂ con'₂ jme₁ca₂lɨ́'₃ 'uë₃ quió'₅ dsa₂ juɨg₂ siá'₂, i₂ca₂'uɨ́n'₂ Diú₄ ia₁jaun₂ cha₂ ja₁tian'₃ 'éi₂. Le₂jaun₂ ca₂lë₃ ca₂lia'₂ ca₂të́₂ jmɨg₄ a₂ca₂rë₃chán₃ David.  
\v 46 Ca₂jmo₃ Diú₄ dse₃ dsɨ́₅ ja₁con₂ Rag₅₄ David, jaun₂ 'éi₂ në́₃ jme₁'nio₃ jmóg'₃ caun₂ ja₁guá₃ Diú₄ quián₅ Jacob.  
\v 47 La₁ Salomón bá₄ i₂ca₂chi'₃ 'né₅ quió'₅ Diú₄. 
\p  
\v 48 'La₁ Diú₄ i₂juɨn'₂ guë́₄ lɨn₃ tsá₃ guá₅ dsi₂néi₂ guá'₅ a₂jmóg'₅ dsa₂ mɨ₂güɨ́g₃. Juɨ₁lia'₂ ca₂juá'₂ Diú₄ të₂le₃ quian'₅₄ dsa₂ i₂jme₁'ë́₂ jág₁ quiáin₅ ma₂lɨ́g'₂: 
\q1  
\v 49 Guei'₅₄ i₂juɨ́g₃ bá₄ ja₁gua₁₂ 
\q2 ja₁lë́₄ ne₄ta₁ quió₃, 
\q1 gua'₅₄ 'uë₃ në́₃ juɨ₁lia'₂ ja₁tióng₂ tag₃. 
\q1 ¿'E₂ bá₄ 'né₅ jmó'₂ 'nia'₂ quió₃? juá'₂ Te₁gui'₅₄, 
\q2 ¿O₃ já'₄ bá₄ lé₂ le₃jan₄ jniá₂? 
\q1  
\v 50 ¿On₁ jniá₂ bá₄ ca₂jmo₃ quian'₅₄ gu₃-tag₃ 
\q2 ca₂le₃jë́₃ 'e₂ a₂cha₂?\f + \fr 7:50 \ft Isaías 66:1-2.\f* 
\p  
\v 51 (Jaun₂ caun₂ ca₂juá'₂ bá₄ Té₂ tsɨ́'₅ dsa₂): 
\p ―'Nia'₂ në́₃, lia'₂ ma₂ja₂nó'₅ jaun₂ bá₄ 'nia'₂ cang₄ dsei'₂, jaun₂ lë́₅ rë₂guá'₄ 'nia'₂ quian'₅₄ të₂'au'₂ juɨ₁lia'₂ dsa₂ i₂tsá₃ cuɨn₅ Diú₄.\f + \fr 7:51 \ft lit. “juɨ₁lia'₂ dsa₂ i₂tsá₃ lo₄ rë₂uɨng₄.” \f* Caun₂ 'ŋia'₅₄ co₂tan₅₄ bá₄ 'nia'₂ Jme₂dsí₂ Jŋió₅. I₂co₂rɨn'₂ bá₄ 'nia'₂ quiang'₅₄ dsa₂ can'₅₄ quiáng'₂ ma₂lɨ́g'₂.  
\v 52 ¿'Ein₂ dsa₂ i₂jme₁'ë́₂ jág₁ quián₅ Diú₄ jua'₅₄ i₂tsá₃ ca₂jmá'₂ dsa₂ can'₅₄ quián'₂ 'nia'₂ ma₂lɨ́g'₂? Qui₂ca₂jme₃dsiain₂₃ bá₄ dsa₂ i₂qui₂ca₂'ë́₂ jág₁ le₂jŋiá₅ ca₂'ɨin₃ jan₂ i₂dsen₃ lɨn₃, i₂jiá₃. La₁ jme₁guan₃ i₂'éi₂ në́₃, ca₂jɨin'₅₄ 'nia'₂ jaun₂ ca₂jŋɨ́i'₃.  
\v 53 'Nia'₂ guë'₂ i₂ca₂gue'₅₄ 'Éi'₃ Juá'₅ të₂le₃ quian'₅₄ ángeles, tsá₃ jme₂tí'₁ guë'₂ 'nia'₂ 'Éi'₃ jaun₂. 
\s1 Ca₂jon₃ Té₂ 
\p  
\v 54 Jme₁ca₂nág₂ jág₁ a₂ca₂juá'₂ Té₂ jaun₂, ca₂rë₃'néi₃ 'ŋio₅ lɨn₃ ca₂lia'₂ qui₂ca₂quɨg'₂ mɨ₂jan₅₄ a₂'ŋiai₅₄ Té₂.  
\v 55 La₁ Té₂ në́₃, rë₂rɨn₅ Jme₂dsí₂ Jŋió₅ të₂dsɨ́₅, ca₂chóg'₃ ne₅₄ guei'₅₄ i₂juɨ́g₃ jaun₂ ca₂jág₃ a₂co₂tág₅ co₂'né'₅ quió'₅ Diú₄, jaun₂ ca₂jɨ́in₂ Jesús chéin'₅ të₂le₃ gu₂ ne₁ quió'₅ Diú₄ Jmei₂.  
\v 56 Jaun₂ ca₂juá'₂ táng₃ Té₂: 
\p ―¡Jag₄! ―juá'₂―. Jág₅ jniá₂ rë₂na₄ guei'₅₄ i₂juɨ́g₃. Jɨn₄ jniá₂ Jaun₅ dsa₂ mɨ₂güɨ́g₃ 'ein₅₄ të₂le₃ gu₂ ne₁ quió'₅ Diú₄. 
\p  
\v 57 La₁ dsa₂ 'éi₂ qui₂ca₂jne₃ rë₂gua₅₄, tsá₃ 'nio₃ nag₃, qui₂ca₂tóin'₂ co₂mɨ'₅₄ ca₂guió'₃ jmái'₂ Té₂.  
\v 58 Jaun₂ ca₂dsei₂₃ 'nɨ'₂ juɨg₂. Jaun₂ ja₁jaun₂ ca₂jŋag'₃ quian'₅₄ cang₄. Jaun₂ dsa₂ i₂qui₂ca₂jnáu'₂ cang₄ në́₃ ca₂dsia₃ nɨ₁tsɨn'₅₄ o₄gú₃ jan₂ dsó₂ chi'₂ i₂jme₁chen₂ Saulo. 
\p  
\v 59 Të₁lia'₂ tioin'₅₄ qui₂cuë́'₅ Té₂ cang₄, jaun₂ ca₂mɨ₃ Té₂ ca₂tsɨ́'₃ Diú₄ ca₂juá'₂: 
\p ―Te₁gui'₅₄ Jesús, guen'₅₄ jme₂dsí₂ quió₃. 
\p  
\v 60 Jaun₂ guë́₄ ca₂chi₃jné₃, jaun₂ ca₂guió'₃ tiá₂ ca₂juá'₂: 
\p ―Te₁gui'₅₄, tsá₃ jme₁cain'₅₄ dso₄ la₂. 
\p Jme₁ca₂lë₃ juá'₂ le₂në₅, ca₂join₃ jaun₂ në́₃. 
\c 8  
\s1 Co₂'en₅ Saulo dsa₂ i₂ma₂'én₂ 
\p  
\v 1 Jaun₂ caun₂ bá₄ 'ei₅ jág₁ quió'₅ Saulo a₂ca₂jŋɨ'₃ dsa₂ Té₂. Dsɨ₂juɨ₅ jmɨg₄ jaun₂ bá₄, ca₂jme₃lióg₃ dsa₂ qui₂co₂'ein₃ 'ŋio₅ lɨn₃ ta₁caun₂ nió'₃ dsa₂ i₂lɨ́n₅ guá'₅ jë₄ juɨg₂ Jerusalén. Ca₂le₃jɨ́n₃ dsa₂ 'éi₂ ca₂i₃léin₂ tsɨ₁rë₂jain₅₄ le₂tan₅₄ 'uë₃ Judea quian'₅₄ Samaria. Jŋia'₅₄ lia'₂ dsa₂ guia₃-tɨ́n₂ i₂chen₄ quián₅ Jesús bá₄ ca₂jŋia₃ guë́₄ juɨg₂ Jerusalén.  
\v 2 I₂lɨn₅₄ dsa₂ dsen₃ i₂'nio₃ Diú₄ ca₂'óin₂ Té₂, qui₂ca₂'o₃ 'ŋio₅ lɨn₃ o₄quió'₄ 'éi₂.  
\v 3 Të₁lia'₂ jaun₂, i₂ŋɨ₅₄ Saulo quiain'₅₄ rɨin'₅₄ qui₂co₂'ein₂₃ dsa₂ i₂'én₂, qui₂dsɨ₂toin'₅₄ të₂ dsi₂néi₂ qui₂'uɨ́in'₂ dsa₂ tsɨ₁cuɨin'₂, lia'₂ dsa₂ ŋe'₂ lia'₂ dsa₂ mɨ́₂, qui₂të₂ a₂to'₂ 'né₅ 'má₃. 
\s1 Ca₂'ë́₂ dsa₂ jág₁ dse₃ juɨg₂ Samaria 
\p  
\v 4 La₁ ca₂le₃jɨ́n₃ dsa₂ i₂ca₂'uɨn₂ juɨg₂ Jerusalén, ca₂le₃jë́₃ ja₁ca₂i₁lein₅₄ qui₂ca₂'ë́₂ jág₁ dse₃.  
\v 5 Jan₂ 'éi₂, i₂chen₂ Fe₂li₄, ca₂ŋó₃ caun₂ juɨg₂ ja₁tén₄ 'uë₃ Samaria ca₂dsia₃ jág₁ tsɨ́'₅ dsa₂ ja₁jaun₂, 'ɨin₂₃ Cristo.\f + \fr 8:5 \ft o₃, I₂rë₂'ɨ́n₁ quián₅ Diú₄.\f* 
\v 6 Jaun₂ jme₁ŋɨ'₂ dsa₂ jmo₂₃ tei₄ ca₂le₃jɨ́in₃, të₅ dsɨ́₅ nag₂₃ jág₁ a₂juá'₂ Fe₂li₄, ia₁ ján₃ bá₄ ca₂jág₃ dsa₂ léi₄ dsɨ₂gó'₃ dsɨ₅ a₂jme₁jmo₅ 'éi₂.  
\v 7 Ia₁ juɨn₅ i₂tion'₅₄ jme₂dsí₂ 'lɨn'₅₄ të₂dsɨ́₅ qui₂ca₂'lóin₂. Ca₂le₃jɨ́n₃ jme₂dsí₂ 'lɨn'₅₄ 'éi₂ qui₂ca₂'uɨin₂ qui₂guió'₅. Ján₃ bá₄ juɨn₅ dsa₂ 'lian'₂, dsa₂ guian'₅₄ në́₃, qui₂ca₂'lóin₂.  
\v 8 'Uɨg₅₄ jaun₂ 'ŋio₅ 'io'₂ ca₂jmo₃ dsa₂ juɨg₂ jaun₂. 
\p  
\v 9 Juɨg₂ jaun₂ jme₁chan₂ jan₂ dsa₂ i₂jme₁chen₂ Si₂mu₅₄, i₂jme₁jmo₅ ta₁ a₂chan₂ dsɨ́₅ le₂jŋiá₅, jme₁jme₂gain₂₃ dsa₂ juɨg₂ Samaria, a₂juá'₂ a₂lɨ́in₅ dsa₂ dsen₅₄. 
\p  
\v 10 Ca₂le₃jɨ́n₃ dsa₂, lia'₂ dsa₂ can'₅₄ lia'₂ chi'₂ në́₃, jme₁nag₂₃ të₅ dsɨ́₅ jág₁ quió'₅, qui₂dsia₂₃: 
\p ―Dsa₂ në₅ tɨin₂ quian'₅₄ juɨ₅bí₂ quió'₅ Diú₄. 
\p  
\v 11 Jme₁tón'₂ dsa₂ juɨ₅ jág₁ quió'₅ gui'₅₄ 'éi₂, ia₁ ma₂lɨ́g'₂ bá₄ ma₂já₅ qui₂jme₂gain₂₃ dsa₂ quian'₅₄ bí₂ a₂chan₂ dsɨ́₅. 
\p  
\v 12 La₁ dsɨ₂juɨ₅ jme₁ca₂rë₃'én₂ dsa₂ jág₁ dse₃ quió'₅ Jesucristo a₂ca₂'ë́₂ Fe₂li₄ juɨ₁lia'₂ ja₁gon₂ Diú₄, jaun₂ qui₂ca₂jŋó₂ dsa₂ jmɨg₂ lia'₂ dsa₂ ŋe'₂ lia'₂ dsa₂ mɨ́₂.  
\v 13 Ján₃ bá₄ ca₂rë₃'én₂ 'ŋiog₅ Si₂mu₅₄ 'éi₂, ca₂jŋói₂ jmɨg₂ ján₃. Jaun₂ guë́₄ ca₂jme₃lióg₃ ca₂jme₃quiain'₅₄ Fe₂li₄, qui₂jág₅ dsɨ₂gó'₃ dsɨ́₅ léi₄ juë'₂ a₂jmo₅ 'éi₂. 
\p  
\v 14 Jme₁ca₂rë₃ŋi₅ dsa₂ i₂chen₄ quián₅ Jesús i₂tion'₅₄ Jerusalén, a₂ma₂'én₂ dsa₂ chan₂ 'uë₃ Samaria jág₁ quió'₅ Diú₄, jaun₂ ca₂chein₃ ja₁jaun₂ Pe₄ quian'₅₄ Juan₅₄.  
\v 15 Jme₁ca₂dsi₃lén₂ 'éi₂ 'uë₃ Samaria, jaun₂ ca₂mɨ₃ ca₂tsɨ́'₃ Diú₄ o₄quió'₄ dsa₂ i₂ma₂'én₂ ja₁jaun₂, ia₁jaun₂ guen₃ dsa₂ 'éi₂ Jme₂dsí₂ Jŋió₅ ján₃.  
\v 16 Ia₁ 'i₁jan₂ dsa₂ 'éi₂ tsá₃ Jme₂dsí₂ Jŋió₅ ma₂guan₅ guë́₄ ne₄ quió'₅. Jŋia'₅₄ con'₂ ma₂jŋói₂ jmɨg₂ bá₄ lia'₂ con'₂ lë́₅ 'éi'₃ quió'₅ Te₁gui'₅₄ Jesús.  
\v 17 Jaun₂ në́₃ Pe₄ quiain'₅₄ Juan₅₄ qui₂ca₂quiog₂ gu₂ ne₄ quió'₅ dsa₂ 'éi₂, jaun₂ guë́₄ ca₂guein₃ Jme₂dsí₂ Jŋió₅. 
\p  
\v 18 Jme₁ca₂jág₃ Si₂mu₅₄ a₂ca₂sión₃ Jme₂dsí₂ Jŋió₅ jme₁ca₂quiog₂ dsa₂ i₂chen₄ 'éi₂ gu₂ ne₄ quió'₅ dsa₂, jaun₂ ca₂jen'₂ cu₄,  
\v 19 ca₂juá'₂: 
\p ―Cuë₄ jniá₂ ján₃ juɨ₁lia'₂ bí₂ a₂tɨn'₂ 'nia'₂ në₅, ia₁jaun₂ lé₂ le₃jmo₅₄ jniá₂ ján₃ a₂guen₃ dsa₂ Jme₂dsí₂ Jŋió₅ jë₁ma₂ca₂co₃ gu₃ ne₄ quió'₅ chi₂jua'₂ 'ein₂. 
\p  
\v 20 Jaun₂ ca₂ŋag₃ Pe₄ ca₂tsɨ́'₃ dsa₂ 'éi₂: 
\p ―Juɨ₁dsi₂'éng'₂ co₂dsia₅ quian'₅₄ cú'₂ ia₁ 'e₂ lë₃ dsɨ₂jiog₅ 'au'₂ le₂në₅, a₂lɨ́ng'₂ a₂lé₂ lá₃ dsa₂ quian'₅₄ cu₄ bí₂ a₂cuë₅ Diú₄.  
\v 21 Tsá₃ ca₂tɨ́n'₂ 'ne₂ a₂në₅, ia₁ tsá₃ dse₃ 'ei₅ 'au'₂ ne₄ Diú₄.  
\v 22 Co₂dsia₅ tí₃ ca₂le₃jë́₃ a₂'lɨg'₅₄ a₂dsɨ₂jiog₅ 'au'₂ në₅. Mɨ₄ ne₄ Te₁gui'₅₄ chi₂jua'₂ 'éin₂ dsáu'₂ 'e₂ lë₃ dsɨ₂jiog₅ 'au'₂ le₂në₅.  
\v 23 Ia₁ léi₄ jniá₂ rë₂rɨn₅ cosa 'lɨg'₅₄ të₂'au'₂; quian'₅₄ dsáu'₂ në₅ jmo₅ chi₁'ŋeg'₂. 
\p  
\v 24 Jaun₂ në́₃, ca₂ŋag₃ Si₂mu₅₄: 
\p ―Mɨ₄ 'nia'₂ chei'₅₄ Te₁gui'₅₄ o₄quió₃, ia₁jaun₂ tsá₃ juɨ₁dsi₂ŋɨ́g₂ a₂ma₂në₂jua'₅₄ 'nia'₂ në₅. 
\p  
\v 25 Jme₁ca₂dsan₃ jáng'₅ Pe₄ quian'₅₄ Juan₅₄ jág₁ dsau₅ a₂dsia₂₃ jág₁ quió'₅ Diú₄, jaun₂ guë́₄ ca₂i₃lein₃ juɨ₅ Jerusalén. Le₂'i₄ juɨ₅ ja₁i₃lein₃ jaun₂, qui₂ca₂'ë́₂ guë́₄ jág₁ dse₃ a₂lión₂ dsa₂ le₂tan₅₄ juɨg₂ ja₁tén₄ 'uë₃ Samaria. 
\s1 Fe₂li₄ quiain'₅₄ dsa₂ chan₂ Etiopía 
\p  
\v 26 Cang₂ jaun₂, ca₂juá'₂ jan₂ ángel quián₅ Te₁gui'₅₄ ca₂tsɨ́'₃ Fe₂li₄: 
\p ―Nau₂, gua₂ juɨ₅ ja₁'uɨn₂ dsa₂ Jerusalén a₂dsióg₄ 'uë₃ Gaza. 
\p Juɨ₅ jaun₂ dsó₅ jë₄ 'uë₃ quein₂.  
\v 27 Jaun₂ ca₂nau₂ Fe₂li₄ ca₂ŋó₃. Le₂'i₄ juɨ₅ ja₁ŋó₃ jaun₂, ca₂jein'₂ jan₂ dsa₂ chan₂ Etiopía, i₂jme₁lɨ́n₄ jan₂ dsa₂ eunuco, dsa₂ dsen₅₄ i₂niog₅ gu₂ cu₄ quió'₅ 'io₅₄ Candace i₂gon₂ 'uë₃ Etiopía. Dsa₂ 'éi₂ ŋei₅₄ i₁chi₂i₁lein'₄ Diú₄ juɨg₂ Jerusalén.  
\v 28 Ma₂'ein₅₄ juɨ₅ ŋái'₄ juɨg₂ go₅₄ guá₅ ne₄ carroza quió'₅, 'ɨ₂₃ Si₂ quió'₅ Isaías i₂jme₁'ë́₂ jág₁ quió'₅ Diú₄ ma₂lɨ́g'₂.  
\v 29 Jaun₂ ca₂juá'₂ Jme₂dsí₂ quián₅ Diú₄ ca₂tsɨ́'₃ Fe₂li₄: 
\p ―Gua₂ le₃jén'₃ cau₅ carro në₅. 
\p  
\v 30 Ca₂dsióg₃ Fe₂li₄ cau₅, jaun₂ ca₂nág₂ i₁'ɨ₅ dsa₂ 'éi₂ Si₂ quió'₅ Isaías. Jaun₂ ca₂ŋag₃ Fe₂li₄: 
\p ―¿'Ŋɨ́g'₂ 'e₂ juá'₂ si₂ a₂'ɨ'₂? 
\p  
\v 31 Jaun₂ ca₂ŋag₃ táng₃ dsa₂ 'éi₂: 
\p ―¿'A₂ bá₄ lia'₂ le₃ŋɨ́'₂ jniá₂? Tsá₃ guë'₂ 'ein₂ chan₂ i₂juá'₂ 'e₂ jein₅ jág₁ a₂juá'₂ si₂ la₂. 
\p Jaun₂ ca₂tsɨ́'₃ Fe₂li₄ a₂uɨ́g₂ 'éi₂ guei'₅₄ a₂guá₃ co₂lë₅ quiong'₅₄. 
\p  
\v 32 Jme₁'ɨ₅ dsa₂ 'éi₂ Si₂ quió'₅ Diú₄ ja₁juá'₂ le₂la₂: 
\q1 Ca₂jiog₃ dsa₂ i₁jŋag'₂ juɨ₁lia'₂ jŋɨ'₅ dsa₂ já'₂ cha'₂. 
\q1 Ján₃ guë'₂ juɨ₁lia'₂ tsá₃ guió'₅ guein₂ já'₂ cha'₂ 
\q2 të₁lia'₂ chéi₅ dsa₂ jŋí₁, 
\q2 ján₃ bá₄ le₂jaun₂ tsá₃ 'e₂ ca₂juá'₂ i₂'éi₂. 
\q1  
\v 33 Ca₂cuë₃ dsa₂ o₂guí'₃, 
\q2 tsá₃ 'éi'₃ rë₂ ca₂të₁dsɨ₅₄ quió'₅; 
\q1 chi'₂ tsɨ₁jon₂ quiáin₅ guë'₂ në́₃, 
\q2 ¿'ein₂ bá₄ lé₂ le₃dsia₃ 'ɨin₃ chi'₂ dsio₅₄? 
\q1 ton'₂ ca₂jŋióg'₂ bá₄ guë'₂ dsa₂ 
\q2 ne₄ gua'₅₄ 'uë₃ la₂.\f + \fr 8:33 \ft Isaías 53:7-8.\f* 
\p  
\v 34 Jaun₂ ca₂juá'₂ dsa₂ dsen₅₄ 'éi₂ ca₂tsɨ́'₃ Fe₂li₄: 
\p ―Jmo₄ dse₃ 'au'₂, jua'₅₄ 'e₂ jein₅ jág₁ a₂juá'₂ si₂ la₂. ¿'Ein₂ 'ɨn₅ dsa₂ quián₅ Diú₄ i₂ca₂jmo₃ si₂ la₂? ¿A₂'ɨin₂₃ 'ŋiog₅, o₃ a₂'ɨin₂₃ i₂sián'₂ 'e₂? 
\p  
\v 35 Jaun₂ ca₂jme₃lióg₃ Fe₂li₄ ca₂juá'₂ 'e₂ juá'₂ ne₄ Si₂ ja₁jme₁'ɨ₅ dsa₂ dsen₅₄ 'éi₂, qui₂ca₂cuë₃ jág₁ dse₃ 'ɨin₂₃ Jesús.  
\v 36 Jme₁ca₂dsi₃léin₂ caun₂ ja₁cha₂ jmɨg₂, jaun₂ ca₂juá'₂ dsa₂ dsen₅₄ 'éi₂ ca₂tsɨ́'₃ Fe₂li₄: 
\p ―Cha₂ jmɨg₂ ja₁lá₃. ¿Cha₁ 'e₂ lë₃ jua'₅₄ tsá₃ lé₂ tsón₄ jniá₂ jmɨg₂? 
\p  
\v 37 Jaun₂ ca₂juá'₂ Fe₂li₄: 
\p ―Chi₂jua'₂ 'éng'₂ dsón'₂ ca₂le₃jë́₃ 'au'₂, lé₂ bá₄. 
\p Jaun₂ ca₂ŋag₃ táng₃ dsa₂: 
\p ―'Én₂ bá₄ jniá₂ a₂lɨ́n₅ Jesucristo Ja₁ŋi'₅₄ Diú₄.\f + \fr 8:37 \ft A₂lɨn₅₄ chog₅₄ si₂ tsá₃ chi₁ton₅ versículo 37.\f* 
\p  
\v 38 Jaun₂ ca₂jmo₃ 'éi'₃ ca₂jŋia₃ carroza quió'₅. Jaun₂ ca₂sióin₃ le₂oin₃ chei'₅₄ jmɨg₂, jaun₂ ca₂cho₃ Fe₂li₄ jmɨg₂\f + \fr 8:38 \ft lit. “ca₂tióg₃ Fe₂li₄ jmɨg₂.” \f* quió'₅ dsa₂ 'éi₂.  
\v 39 Jme₁ca₂'uɨin₂ jmɨg₂, jaun₂ Jme₂dsí₂ quián₅ Te₁gui'₅₄ ca₂tág₃ Fe₂li₄, jaun₂ dsɨ₂tan₅₄ 'éi₂ tsá₃ ma₃ca₂jág₂ mei'₂. La₁ 'io'₂ bá₄ jmo₂₃ le₂'i₄ juɨ₅ ja₁ŋái'₄.  
\v 40 Fe₂li₄ në́₃ ma₂'ein₅₄ caun₂ juɨg₂ ja₁chei₂ Azoto, jaun₂ le₂tan₅₄ guë́₄ juɨg₂ te₁'i₁ ja₁jaun₂ ca₂ŋei₅₄ qui₂ca₂'ë́₂ jág₁ dse₃ a₂lión₂ dsa₂, ca₂lia'₂ ca₂dsióg₃ ca₂të₂ juɨg₂ Cesarea. 
\c 9  
\s1 Ca₂jme₃tsɨ́n₃ Saulo dsɨ́₅ 
\r (Hechos 22:6-16; 26:12-18) 
\p  
\v 1 Të₁lia'₂ jaun₂, dsa₂ i₂chen₂ Saulo caun₂ qui₂quiain₂₃ juë́'₅ a₂'nio₃ jme₃dsiáin₃ dsa₂ i₂'én₂ jág₁ quió'₅ Te₁gui'₅₄. Jaun₂ lë₃, ca₂ŋei₅₄ i₁jɨin₂₃ jme₂dsa₂ dsen₅₄.  
\v 2 Ca₂mɨ₃ ne₄ 'éi₂ caun₂ si₂ a₂cuë₃ bí₂ a₂dsó₃ guá'₅ sinagogas quió'₅ dsa₂ juɨg₂ Damasco a₂dsɨ₃'niai'₂ dsa₂ i₂tion'₅₄ të₂le₃ quió'₅ Juɨ₅ quió'₅ Te₁gui'₅₄. Jme₁'nio₃ Saulo dsɨ₃te₅₄ dsa₂ chi₁'ŋei'₂ ca₂të₂ Jerusalén, lia'₂ dsa₂ ŋe'₂ lia'₂ dsa₂ mɨ́₂.  
\v 3 La₁ jme₁ja₂quián₃ dsióg₄ juɨg₂ Damasco, con'₂ tsá₃ jáin₅ jme₁ca₂tág₃ caun₂ si₂ tág₅ jmá'₅ ne₄ quió'₅. Si₂ jaun₂ a₂já₃ juɨ₅ guei'₅₄ i₂juɨ́g₃.  
\v 4 Co₂tan₅₄ ca₂quɨn'₃ Saulo, jaun₂ ca₂nág₂ juá'₂ jág₁ jë₄ si₂ jaun₂: 
\p ―Saulo, Saulo, ¿'e₂ lë₃ co₂'éin'₅ jniá₂? 
\p  
\v 5 Jaun₂ ca₂ŋag₃ Saulo: 
\p ―¿'Ein₂ 'ne₂, gui'₅₄? 
\p Jaun₂ ca₂ŋag₃ táng₃ jág₁ né'₂ jë₄ si₂: 
\p ―Jesús bá₄ jniá₂ i₂co₂'én'₅ 'ne₂ ŋɨ'₂. Jŋia'₅₄ jmag'₅₄ uɨg₅ 'ŋiag'₂ bá₄ jmo'₂ juɨ₁lia'₂ jmo₅ ca₁juɨ₅ jë₁ma₂jnáu₃ nɨ₁'ma₂ chen'₂. 
\p  
\v 6 Jaun₂ ca₂jlen₃ Saulo, ca₂rë₃gó'₅, ca₂juá'₂: 
\p ―Te₁gui'₅₄, ¿'e₂ 'niog'₂ 'ne₂ jmo₅₄ jniá₂? 
\p Jaun₂ ca₂ŋag₃ táng₃ Te₁gui'₅₄: 
\p ―Nau₂, 'ú₅ juɨg₂ Damasco. Jë₁ma₂dsióg'₃, ja₁jaun₂ bá₄ juá'₂ dsa₂ 'e₂ jmó'₂. 
\p  
\v 7 Dsa₂ i₂jme₁quian'₅₄ Saulo në́₃, 'ŋio₅ lɨn₃ ca₂rë₃gó'₅, ia₁ ca₂nág₂ jág₁ a₂juá'₂ jë₄ si₂ jaun₂, ton'₂ 'i₁jan₂ guë'₂ tsá₃ 'ein₂ ca₂jɨ́in₂.  
\v 8 Jaun₂ ca₂nau₂ Saulo, la₁ jme₁ca₂nau₂ jaun₂, tsá₃ ma₃lé₂ jág₃, tsá₃ ma₃jniá₂ mɨ₂ne₅₄. Dsa₂ i₂jme₁quiain'₅₄ bá₄ ca₂tág₃ le₁chan'₂ gu₂, ca₂jiog₃ të₂ juɨg₂ Damasco.  
\v 9 Ja₁jaun₂ ca₂'í₃ tein₅₄ 'nɨ₅ jmɨg₄, tsá₃ 'e₂ ca₂guë́'₃, on₃ guë'₂ 'e₂ ca₂'ɨn'₃ 'i₁caun₂. 
\p  
\v 10 Juɨg₂ Damasco jaun₂, jme₁guá₄ jan₂ dsa₂ i₂'én₂ i₂jme₁chen₂ Ananías. I₂'éi₂ ca₂jén'₃ ca₂jɨ́in₂ Te₁gui'₅₄ i₂ca₂juá'₂: 
\p ―¡Ananías! 
\p Jaun₂ ca₂ŋag₃ 'éi₂: 
\p ―Ja₁lá₃ bá₄ 'eng₅₄, Te₁gui'₅₄. 
\p  
\v 11 Jaun₂ ca₂juá'₂ táng₃ Te₁gui'₅₄: 
\p ―Nau₂, gua₂ calle chei₂ Co₂dsau₅ ja₁quió'₄ dsa₂ chen₂ Judas. Ja₁jaun₂ o₂'nia'₂ jan₂ dsa₂ chan₂ Tarso i₂chen₂ Saulo, i₂'en₅₄ chi₂lén'₂ Diú₄ con'₂ lë́₅ la₂.  
\v 12 Ia₁ ma₂quɨ₃ a₂ma₂jɨ́in₂ jan₂ dsa₂ i₂chen₂ Ananías ca₂'í₃ ca₂quiog₂ gu₂ ne₄ quió'₅ ia₁jaun₂ jnia₃ táng₃ mɨ₂ne₅₄. 
\p  
\v 13 Jme₁ca₂nág₂ Ananías le₂në₅, jaun₂ ca₂juá'₂: 
\p ―Te₁gui'₅₄, juɨn₅ dsa₂ ma₂tság₃ jniá₂ ca₂le₃jë́₃ 'e₂ 'lɨg'₅₄ a₂jmo₅ dsa₂ 'éi₂ a₂jmái'₂ dsa₂ chan₂ Jerusalén i₂'én₂ jág₁ quiáng'₂.  
\v 14 Ta₁ jaun₂ já₅ 'éi₂ ja₁lá₃ quian'₅₄ 'éi'₃ quió'₅ juɨg₅₄ jme₂dsa₂ ia₁jaun₂ të₂ le₁'ŋe₅ ca₂le₃jɨ́n₃ dsa₂ quiáng'₂ i₂'ɨn₅ 'ne₂. 
\p  
\v 15 La₁ jaun₂ ca₂juá'₂ táng₃ Te₁gui'₅₄: 
\p ―La₁ gua₂, ia₁ i₂ma₂quion'₄ jniá₂ 'éi₂ ia₁ 'nio₃ jniá₂ dsó₃ qui₂dsɨ₃'ag₃ jniá₂ lia'₂ jɨn₄ dsɨ₂nau₂ lia'₂ ne₄ rag₅₄ quiáin₅, jɨn₄ dsa₂ israelitas në́₃.  
\v 16 Ia₁ jniá₂ bá₄ 'ë́₄ 'a₂ lia'₂ tion₅₄ niog₅ ŋág₃ uɨg₅ 'ŋio₅ lɨn₃ o₄quió₃ jniá₂. 
\p  
\v 17 Jaun₂ guë́₄ ŋó₃ Ananías ja₁chí'₄ tsɨ₁'né₅ ja₁jme₁'en₅₄ Saulo. Ca₂'í₃ dsi₂néi₂, ca₂quiog₂ gu₂ ne₄ quió'₅ Saulo, jaun₂ ca₂juá'₂: 
\p ―Saulo rɨn'₅₄ jniog₄, Te₁gui'₅₄ Jesús i₂ca₂jeng'₂ le₂'i₄ juɨ₅ lia'₂ con'₂ ŋe'₃, në₂chei₃ jniá₂ ia₁jaun₂ jnia₅₄ táng₃ mɨ₂ne'₅₄, jaun₂ guéng'₄ Jme₂dsí₂ Jŋió₅ në́₃. 
\p  
\v 18 Co₂tan₅₄ dsɨ₂juɨ₅ jaun₂ qui₂ca₂séi'₂ juɨ₁lia'₂ tsɨ₁ mɨ₂ne₄ Saulo, co₂tan₅₄ ca₂jág₃ táng₃. Jaun₂ guë́₄ ca₂nau₂ Saulo, ca₂i₁choin₃ jmɨg₂.  
\v 19 Jaun₂ ca₂guë́'₃, ca₂tɨ́in'₃ táng₃ bí₂. Jaun₂ ca₂'í₃ bá₄ guë́₄ tɨn₃-'nɨ₅ jmɨg₄ quiain'₅₄ dsa₂ 'én₂ i₂jme₁tián'₄ juɨg₂ Damasco jaun₂. 
\s1 Ca₂'ë́₂ Saulo jág₁ dse₃ juɨg₂ Damasco 
\p  
\v 20 Dsɨ₂juɨ₅ bá₄ ca₂jme₃lióg₃ Saulo ca₂ŋei₅₄ guá'₅ sinagogas ca₂i₁jme₁tɨin₂₃ dsa₂ a₂juá'₂ a₂lɨ́n₅ Jesús Ja₁ŋi'₅₄ Diú₄.  
\v 21 Ca₂le₃jɨ́n₃ dsa₂ i₂ca₂nág₂ ca₂i₃gó'₃ dsɨ́₅, qui₂ca₂dsia₃: 
\p ―¿On₃jua'₅₄ dsa₂ në₅ i₂ŋɨ́₄ lë₃ jme₁ŋɨ₅ juɨg₂ Jerusalén qui₂co₂'ein₂₃ dsa₂ i₂'én₂ le₃quió'₅ Jesús? ¿On₃jua'₅₄ i₂në₅ 'ŋiog₅ i₂ma₂guan₅ ja₁lá₃ a₂qui₂të₂ le₁'ŋe₅ dsa₂ jaun₂ qui₂dsɨ₂jang'₅₄ o₄gú₃ juɨg₅₄ jme₂dsa₂? 
\p  
\v 22 La₁ të₂le₃ lë́₅ guë́₄ ca₂'ág₂ tiá₂ dsɨ́₅ Saulo, qui₂ca₂'ë́₂ jág₁ a₂lɨ́n₅ dsón'₂ Jesús I₂rë₂'ɨ́n₁ quián₅ Diú₄. Ca₂lia'₂ ca₂i₃cón'₅ dsɨ́₅ dsa₂ judíos i₂jme₁tián'₄ juɨg₂ Damasco ia₁ ca₂'ë́₂ Saulo jág₁ le₂jaun₂. 
\s1 Ca₂lón₂ Saulo o₄gú₃ dsa₂ judíos 
\p  
\v 23 'Lióng₂ jmɨg₄ cang₂ jaun₂, ca₂jmo₃ dsa₂ judíos caun₂ jág₁ a₂jme₁jŋɨi'₃ Saulo.  
\v 24 A₂jmɨ₂ a₂'uë₂ qui₂ca₂jŋiai₃ Saulo o₄'né₄ o₄juɨ₅ juɨg₂ jaun₂, ia₁jaun₂ jŋag'₃. La₁ ca₂rë₃ŋi₅ bá₄ Saulo.  
\v 25 Jaun₂ dsa₂ 'én₂ rɨin'₅₄ në́₃, ca₂to'₂ 'ŋió'₃ caun₂ tsɨ₁mɨ'₂ pa₁, jaun₂ a₂'uë₂ ca₂sióin₂ 'éi₂ juɨ₅ ne₄ nɨ₁'ia'₂ a₂jme₁lë́₄ le₃lág'₃ juɨg₂. Jaun₂ le₂në₅ ca₂lóin₂. 
\s1 Ma₂'en₅₄ táng₃ Saulo juɨg₂ Jerusalén 
\p  
\v 26 Jme₁dsián'₃ Saulo Jerusalén, jme₁'nio₃ jme₃quiain'₅₄ dsɨ₂juɨ₅ dsa₂ 'én₂ ja₁jaun₂. La₁ ca₂le₃jɨ́n₃ dsa₂ 'éi₂ në́₃ ca₂rë₃gain₃ 'éi₂, ia₁ tsá₃ jaun₂ lɨ́in₂ a₂ma₂'én₂ Saulo jág₁ dse₃.  
\v 27 La₁ia₁ dsa₂ i₂chen₂ Bernabé ca₂jiog₃ ne₄ dsa₂ guia₃-tɨ́n₂ i₂chen₄ 'éi₂. Jaun₂ ca₂dsia₃ 'a₂ lia'₂ ca₂lë₃ a₂ca₂jme₃jein'₂ Te₁gui'₅₄ le₂'i₄ juɨ₅, 'e₂ jág₁ a₂ca₂juá'₂ në́₃, 'a₂ lia'₂ ca₂dsia₃ Saulo ján₃ tiá₂ dsɨ́₅ juɨg₂ Damasco ca₂'ë́₂ jág₁ 'ɨin₂₃ Jesús.  
\v 28 Jaun₂ bá₄ ca₂'í₃ Saulo juɨg₂ Jerusalén ca₂jme₃quiain'₅₄ dsa₂ 'éi₂.  
\v 29 Caun₂ ca₂dsia₃ tiá₂ dsɨ́₅ bá₄ qui₂ca₂'ë́₂ jág₁ 'ɨin₂₃ Te₁gui'₅₄ qui₂ca₂dsia₃ jág₁ qui₂ca₂tsɨ́in₂ quian'₅₄ dsa₂ judíos i₂dsia₅ jág₁ jmei₅ griego. La₁ dsa₂ 'éi₂ në́₃ caun₂ 'nio₃ jme₁jŋɨi'₃ bá₄ Saulo.  
\v 30 Jme₁ca₂rë₃lí'₄ rɨn'₅₄ Saulo a₂jaun₂, jaun₂ ca₂jiog₃ juɨ₅ juɨg₂ Cesarea. A₂'ein₅₄ guë́₄ ja₁jaun₂ ca₂dsióg'₂ rɨin'₅₄ juɨg₂ go₅₄ ja₁chei₂ Tarso. 
\p  
\v 31 Jaun₂ ca₂le₃jɨ́n₃ guá'₅, dsa₂ i₂'én₂, le₂tan₅₄ ja₁tén₄ 'uë₃ Judea, Galilea, Samaria në́₃, tei₄ bá₄ 'ei₅ tion'₅₄ dsa₂, caun₂ ca₂rë₃béin₂ ján₃. Jme₁jme₂gain₃ bá₄ Te₁gui'₅₄ tioin'₅₄. Quian'₅₄ bí₂ quió'₅ Jme₂dsí₂ Jŋió₅, caun₂ qui₂ca₂juɨ́n₂ bá₄ dsa₂ i₂'én₂. 
\s1 Ca₂'lón₂ dsa₂ chen₂ Eneas 
\p  
\v 32 Lia'₂ con'₂ ŋɨ₅ Pe₄ qui₂dsɨ₂jɨin₅₄ rɨin'₅₄, ca₂i₁jɨin₁₂ ján₃ dsa₂ i₂ma₂'én₂ jág₁ dse₃ i₂jme₁tián'₄ juɨg₂ ja₁chei₂ Lida.  
\v 33 Ja₁jaun₂ ca₂jɨ́in₂ jan₂ dsa₂ 'lian'₂ i₂jme₁chen₂ Eneas i₂ma₂të́₂ jŋia₃ ŋi₂ ron₅, ia₁ tsá₃ lé₂ ŋɨ₃.  
\v 34 Jaun₂ ca₂juá'₂ Pe₄ ca₂tsɨ́'₃ dsa₂ 'éi₂: 
\p ―Eneas, Jesucristo jme₂'lió₂. Nau₂, jmo₄ dse₃ tsɨ₁cama quiáng'₂. 
\p Jaun₂ dsɨ₂juɨ₅ le₂jaun₂ ca₂nau₂ Eneas.  
\v 35 Jaun₂ ca₂le₃jɨ́n₃ dsa₂ i₂tián'₅ Lida quian'₅₄ juɨg₂ Sarón ca₂jág₃ a₂ca₂'lón₂ 'éi₂, jaun₂ ca₂jéin'₃ le₃quió'₅ Te₁gui'₅₄. 
\s1 Ca₂jen'₅₄ 'io₅₄ Dorcas 
\p  
\v 36 Jmɨg₄ jaun₂ jme₁chan₂ jan₂ 'io₅₄ i₂'én₂ jë₄ juɨg₂ Jope i₂jme₁chen₂ Tabita. Quian'₅₄ jág₁ jmei₅ griego jme₁të́'₂ dsa₂ Dorcas. 'Io₅₄ 'éi₂ lia'₂ con'₂ chain₂ jme₁jmo₂₃ dse₃ jme₂'oin₅₄ dsa₂ te₂ŋé₂.  
\v 37 Të₃jë₄ jmɨg₄ jaun₂, ca₂rë₃dso'₅₄ Dorcas, ca₂join₃ bá₄ jaun₂ në́₃. Cang₂ jme₁ca₂lë₃ sei₅ dsa₂, jaun₂ ca₂i₁quio₂₃ caun₂ dsi₂néi₂ jë₁ca₂të́₂ tɨn₃ juɨ́n₃.  
\v 38 Juɨg₂ Jope ma₂quián₅ bá₄ ja₁niog₅ juɨg₂ Lida ja₁'en₅₄ Pe₄. Jaun₂ jme₁ca₂rë₃ŋi₅ dsa₂ 'én₂ a₂'en₅₄ Pe₄ ja₁jaun₂, jaun₂ ca₂chein₃ on₃ rɨin'₅₄ ca₂i₁te'₂ 'éi₂: 
\p ―Ŋia₅ të₂në₃ cón'₅ juɨ₅ Jope. 
\p  
\v 39 Jaun₂ ŋó₃ Pe₄ co₂lë₅ quiain'₅₄ dsa₂ 'éi₂. Jme₁ca₂dsióg₃, ca₂i₁jiog₃ dsa₂ ja₁rë₂quian₅ 'lag₄. Ja₁jaun₂ tion'₅₄ le₁ŋɨ'₂ ca₂le₃jɨ́n₃ 'io₅₄ 'nág₂ quɨ'₂-'o₂₃, qui₂ca₂'ë́'₃ Pe₄ 'mɨ'₂ tsɨn'₅₄ dsa₂, ta₁ a₂jme₁jmo₅ Dorcas lia'₂ con'₂ chain₂.  
\v 40 Jaun₂ ca₂jmo₃ Pe₄ 'éi'₃ ca₂'uɨn₂ dsa₂ dsi₂néi₂ ja₁rë₂quian₅ 'lag₄. Jaun₂ ca₂chi₃jné₃ ca₂chi₃léin'₂ Diú₄. Jaun₂ guë́₄ ca₂jɨ́in₂ 'lag₄, ca₂juá'₂: 
\p ―Tabita, nau₂. 
\p Dsɨ₂juɨ₅ jaun₂ ca₂ján₃ 'io₅₄ jme₁ne₁₂. Jme₁ca₂jɨ́in₂ Pe₄, ca₂guá₂ 'io₅₄ jaun₂ në́₃.  
\v 41 Jaun₂ ca₂jŋa'₃ Pe₄ mɨ₂gu₂ 'io₅₄, ca₂chó'₂. Jaun₂ ca₂të́'₃ táng₃ Pe₄ rɨin'₅₄, 'io₅₄ 'nág₂ në́₃, jaun₂ ca₂jɨ́in'₂ 'io₅₄ 'éi₂, la₁ ma₂jein'₅₄ bá₄.  
\v 42 Ta₁caun₂ juɨg₂ Jope ca₂i₃'ág₃ jág₁ a₂ca₂lë₃ le₂jaun₂. Jaun₂ juɨn₅ lɨn₃ dsa₂ ca₂rë₃'én₂ jág₁ quió'₅ Te₁gui'₅₄.  
\v 43 Ca₂'í₃ bá₄ guë́₄ Pe₄ 'lióng₂ jmɨg₄ jaun₂ ja₁quió'₄ jan₂ dsa₂ i₂chen₂ Si₂mu₅₄ i₂jme₂dse₃ lo₄ já'₂. 
\c 10  
\s1 Pe₄ quian'₅₄ Cornelio 
\p  
\v 1 Juɨg₂ Cesarea jme₁chan₂ jan₂ dsa₂ i₂jme₁chen₂ Cornelio, i₂jme₁lɨ́n₄ juɨg₅₄ co₂nió'₃ 'lióg₂ i₂të́'₂ dsa₂ i₂chan₂ Italia.  
\v 2 Juɨg₅₄ 'lióg₂ 'éi₂ jme₁jme₂gain₃ Diú₄ co₂lë₅ quiain'₅₄ dsa₂ dsi₂néi₂ quió'₅. Ján₃ bá₄ jme₁dsió'₅ cu₄ jme₁jme₂'oin₅₄ dsa₂ judíos. Ca₂le₃jë́₃ jmɨg₄ në́₃, jme₁chi₁léin'₂ Diú₄.  
\v 3 Co₂ráun₂ con'₂ hora ŋí₁ 'nɨ₅ le₃ca₂'láu₂,\f + \fr 10:3 \ft lit. “hora ŋi₃.” \f* a₂lë₁ca₂jén'₃ ca₂jág₃ ca₂jɨ́in₂ jan₂ ángel quián₅ Diú₄ ca₂'í₃ dsi₂néi₂ ja₁'ein₅₄. Jaun₂ ca₂juá'₂ ángel: 
\p ―¡Cornelio! 
\p  
\v 4 Jaun₂ ca₂jág₃ Cornelio gó'₅ 'ŋio₅ lɨn₃ ca₂jɨ́in₂ ángel. Jaun₂ ca₂ŋag₃ ca₂juá'₂: 
\p ―¿'E₂ lë́₅, gui'₅₄? 
\p Jaun₂ guë́₄ ca₂juá'₂ ángel: 
\p ―A₂nag₅ bá₄ Diú₄ a₂juɨg'₂ a₂chi₂lein'₅₄. Jág₅ bá₄ a₂jmo'₂ dse₃ 'au'₂ jme₂'ong'₅₄ dsa₂ te₂ŋé₂.  
\v 5 Jaun₂ lë₃ chen₅ dsa₂ juɨg₂ Jope dsɨ₃quiáin₂ dsa₂ i₂chen₂ Si₂mu₅₄ i₂të́'₂ dsa₂ Pe₄ ján₃.  
\v 6 I₂'en₅₄ ja₁quió'₄ Si₂mu₅₄ sián'₂ i₂jmo₅ dse₃ lo₄ já'₂, i₂chí'₅ 'ne₄ chei'₅₄ jmɨ₁ŋí'₄. 
\p  
\v 7 Jme₁ma₂ŋá'₅ ángel, jaun₂ ca₂të́'₃ Cornelio on₃ dsa₂ mozo quiáin₅, jan₂ guë'₂ 'lióg₂, dsa₂ jme₂ti₃ i₂jme₂gan₃ Diú₄ ján₃.  
\v 8 Jaun₂ ca₂dsia₃ Cornelio ca₂tsɨ́'₃ dsa₂ a₂ca₂jén'₃, jaun₂ ca₂chein₃ dsa₂ juɨ₅ juɨg₂ Jope. 
\p  
\v 9 Jme₁jnia₃ jaun₂, ca₂i₃lén₂ dsa₂ 'éi₂. Pe₄ në́₃ ca₂uɨ́g₂ le₃co'₅₄ tsɨ₁'né₅ con'₂ dsi₃ŋí'₃\f + \fr 10:9 \ft lit. “hora jŋéi₂.” \f* a₂chi₃léin'₂ Diú₄.  
\v 10 I₁cón'₅ 'ŋio₅ lɨn₃. Të₁lia'₂ jmo₅ dsa₂ má₃ në́₃, jaun₂ a₂lë₁ca₂jén'₃ ca₂jág₃ Pe₄  
\v 11 ca₂niá₃ guei'₅₄ i₂juɨ́g₃. Jaun₂ ca₂sió₃ juɨ₁lia'₂ caun₂ tsɨ₁'mɨ'₂ pa₁ a₂rë₂quein₅ ta₁quén₂ qui'₅₄.  
\v 12 'Ŋió'₃ jaun₂, jme₁tion'₅₄ ca₂le₃jɨ́n₃ ne₅₄ já'₂: já'₂ cha₂ quén₂ mɨ₂tag₄, já'₂ i₂tsë́'₅ quió'₅, já'₂ i₂'ɨn₅ guei'₅₄ në́₃.  
\v 13 Jaun₂ ca₂nág₂ Pe₄ jág₁ ca₂juá'₂: 
\p ―Nau₂ Pe₄, jme₁dsian₅ já'₂, quɨ́ng'₄. 
\p  
\v 14 Jaun₂ ca₂ŋag₃ Pe₄: 
\p ―Jan₂'ón₄, Te₁gui'₅₄. Ia₁ 'i₁co₂ráun₂ tsá₃ ma₂ca₂guë́'₃ jniá₂ nɨ₁ŋɨ₁ já'₂ a₂jmo₅ a₂rë₂'ŋio₅ dsa₂. 
\p  
\v 15 Jaun₂ ca₂ŋag₃ táng₃ jág₁ a₂juá'₂: 
\p ―Tsá₃ lë₁juá'₂ 'ne₂ 'lɨg'₅₄ cosa a₂ma₂jmo₃ Diú₄ le₁jë́₃. 
\p  
\v 16 'Nɨ₅ ráun₂ ca₂lë₃ le₂jaun₂, jaun₂ guë́₄ ca₂ŋáu'₃ táng₃ tsɨ₁'mɨ'₂ juɨ₅ guei'₅₄.  
\v 17 Të₁lia'₂ guá₅ Pe₄ 'no'₂ dsɨ́₅ 'e₂ léi₄ jáng'₅ a₂ca₂jág₃ jaun₂, jme₁ca₂dsi₃lén₂ dsa₂ i₂chen₄ quián₅ Cornelio o₄'né₄ quió'₅ Si₂mu₅₄, a₂ŋag₂₃ a₂já'₄ chí'₅ 'ne₄ Si₂mu₅₄.  
\v 18 Jme₁ca₂dsi₃lén₂ dsa₂ 'éi₂, ca₂ŋag₃ juá'₂ tiá₂ chi₂jua'₂ 'en₅₄ ja₁jaun₂ jan₂ dsa₂ i₂chen₂ Si₂mu₅₄ i₂të́'₂ dsa₂ Pe₄ ján₃.  
\v 19 Të₁lia'₂ jaun₂ caun₂ qui₂'no'₂ dsɨ́₅ Pe₄ a₂ca₂jág₃, jaun₂ ca₂juá'₂ Jme₂dsí₂ Jŋió₅: 
\p ―Jag₄; ún₂ dsa₂ o₂lén₂ 'nau'₂.  
\v 20 Nau₂, sión₅, gua₂ quiain'₅₄, tsá₃ lë₁jmo₂ 'ɨ₅ 'au'₂ jua'₅₄ lɨ́ng'₂ a₂tsá₃ tí₅ jág₁, ia₁ jniá₂ bá₄ në₂tsɨ́in₂. 
\p  
\v 21 Jaun₂ ca₂sión₃ Pe₄ ca₂i₁jɨin₁₂ dsa₂ i₂chen₄ quián₅ Cornelio, jaun₂ ca₂juá'₂ Pe₄: 
\p ―Jniá₂ bá₄ 'éi₂ i₂'na'₂ 'nia'₂. ¿Cha₁ ta₁ ja₂nó'₅ 'nia'₂? 
\p  
\v 22 Jaun₂ ca₂ŋag₃ táng₃ dsa₂: 
\p ―Gui'₅₄ juɨg₅₄ 'lióg₂ Cornelio bá₄ ca₂chei₃ jnia'₅₄ ja₂náu₅. Dsa₂ dsen₃ bá₄ 'éi₂, i₂jme₂gan₃ Diú₄; 'nio₃ dsa₂ judíos 'ŋio₅ lɨn₃, jme₂go₃ në́₃. Jan₂ ángel i₂chen₄ quián₅ Diú₄ ca₂juá'₂ a₂të́'₂ 'ne₂ ja₁quió'₄ jaun₂ nag₃ 'e₂ jág₁ cuë'₅₄. 
\p  
\v 23 Jaun₂ ca₂juá'₂ Pe₄ tón'₃ dsa₂ 'éi₂ dsi₂néi₂, jaun₂ ja₁jaun₂ ca₂jŋia₃ dsa₂ 'éi₂ quiain'₅₄ Pe₄ a₂'uë₂ jaun₂. Jme₁jnia₃ jaun₂ guë́₄ ca₂ŋó₃ Pe₄ quiain'₅₄ dsa₂ 'éi₂. Ca₂jme₃quiong'₅₄ guë́₄ i₂lɨn₅₄ dsa₂ rɨin'₅₄ i₂jme₁'én₂ i₂jme₁tián'₄ juɨg₂ Jope. 
\p  
\v 24 Jme₁jnia₃ jaun₂ guë́₄ táng₃, ca₂dsi₃léin₂ juɨg₂ Cesarea ja₁guá₄ Cornelio. 'Éi₂ guë'₂ në́₃ jme₁ma₂chi₁jŋiog₂₃ quiain'₅₄ co₂nió'₃ o₁rɨin'₅₄ a₂mei₅₄ quiáin₅ i₂jein'₂ 'ŋio₅ lɨn₃ quiain'₅₄ në́₃, i₂ca₂të́'₃. 
\p  
\v 25 Jme₁ca₂dsióg₃ Pe₄ o₄'né₄, co₂tan₅₄ ca₂o₃'ɨ́n₃ Cornelio ca₂guei₃, ca₂chi₃jné₃ ne₄ 'éi₂, ca₂jme₃juag'₂.  
\v 26 La₁ Pe₄ në́₃ ca₂chó'₂, ca₂juá'₂: 
\p ―Nau₂, ia₁ dsa₂ mɨ₂güɨ́g₃ bá₄ jniá₂, juɨ₁lia'₂ 'ne₂ ján₃. 
\p  
\v 27 Të₃ dsia₅ jág₁ Pe₄ quiong'₅₄, ca₂'í₃ dsi₂néi₂, jaun₂ ca₂jág₃ juɨn₅ bá₄ dsa₂ ma₂le₁ŋɨ'₂ dsi₂néi₂.  
\v 28 Jaun₂ ca₂juá'₂ Pe₄ ca₂tsɨ́'₃ dsa₂: 
\p ―Ŋi'₅₄ bá₄ 'nia'₂ jaun₂ tsá₃ cuë₅ jmɨg₄ 'Éi'₃ Juá'₅ quió'₅ dsa₂ judíos jua'₅₄ a₂ŋɨi'₂ quian'₅₄ dsɨ₂nau₂, on₃ guë'₂ lé₂ ŋɨ́i₃ dsi₂néi₂ quió'₅. La₁ Diú₄ ma₂'ë₃ a₂tsá₃ të́₄ jniá₂ 'i₁jan₂ dsa₂ tsá₃ le₁jɨ́in₃.  
\v 29 Jaun₂ lë₃ dsɨ₂juɨ₅ bá₄ guio₃ jme₁ca₂dsi₃lén₂ dsa₂ quiáng'₂, të́₂. Tsá₃ në₂jan₅₄ uë́₂. Jaun₂ jme₁'nio₃ le₃guion₅₄ 'e₂ lë₃, 'e₂ ta₁ në₂të'₂. 
\p  
\v 30 Jaun₂ ca₂ŋag₃ Cornelio: 
\p ―Ma₂quén₂ jmɨg₄, con'₂ hora la₂ jme₁'eng₅₄ dsi₂néi₂ la₂ quió₃, jme₁jme₂'ɨng₅₄, tsá₃ ca₂guë́'₃. Jme₁'eng₅₄ chi₁leng'₄ Diú₄ të₂le₃ ca₂'láu₂. Jaun₂ a₂lë₁ca₂jéin₃ ca₂jɨng₅₄ jan₂ dsa₂ qui'₂ 'mɨ'₂ tiog₂ jau₂.  
\v 31 Jaun₂ ca₂juá'₂ ca₂tság₃ jniá₂: “Cornelio, a₂nág₅ bá₄ Diú₄ a₂juɨg'₂. Jág₅ bá₄ a₂jmo'₂ dse₃ 'au'₂ jme₂'ong'₅₄ dsa₂ te₂ŋé₂.  
\v 32 Jaun₂ lë₃, chen₅ dsa₂ juɨg₂ Jope dsɨ₃quiáin₂ dsa₂ i₂chen₂ Si₂mu₅₄ i₂të́'₂ dsa₂ Pe₄ ján₃. I₂'en₅₄ ja₁quió'₄ Si₂mu₅₄ sián'₂ i₂jmo₅ dse₃ lo₄ já'₂, i₂chí'₅ 'ne₄ chei'₅₄ jmɨ₁ŋí'₄. Jë₁ma₂guain₂₃, dsia₃ jág₁ quian'₅₄ 'ne₂.”  
\v 33 Jaun₂ bá₄ lë₃ ca₂tsɨ́ng₂ dsa₂ dsɨ₂juɨ₅ a₂i₁'niai'₂ 'ne₂ në́₃. Dse₃ bá₄ lia'₂ në₂jmo'₅₄ ŋe'₃. Jaun₂ lë₃ tio'₅₄ jnia'₅₄ ca₂le₃jág₃ le₁ŋag'₂ ne₄ Diú₄ ia₁ 'niog₂ jnia'₅₄ néi₁ jág₁ a₂ma₂cuë₃ Te₁gui'₅₄ a₂juɨg'₅₄ jnia'₅₄. 
\s1 Jág₁ a₂ca₂ton₃ Pe₄ dsi₂néi₂ quió'₅ Cornelio 
\p  
\v 34 Jaun₂ ca₂jme₃lióg₃ Pe₄ ca₂juá'₂ ca₂tsɨ́'₃ dsa₂: 
\p ―Në₃ guë́₄ dsón'₂ ma₂ŋɨ́'₂ jniá₂, tsá₃ jma₃quén₅ jɨ́n₂ Diú₄ dsa₂ mɨ₂güɨ́g₃.  
\v 35 Ia₁ ca₂le₃jë́₃ juɨg₂ ja₁jme₂gan₃ dsa₂ Diú₄, nag₅ dsa₂ gau₂ jág₁ quió'₅, jmo₂₃ dse₃ në́₃, dsa₂ le₂'éi₂ bá₄ guén'₂ Diú₄.  
\v 36 Ca₂juá'₂ Diú₄ ca₂tsɨ́'₃ tsɨ₁jon₂ quián₅ Israel, ca₂'ë́₂ jág₁ a₂tian'₃ dsa₂ tei₄ të₂le₃ quian'₅₄ Jesucristo i₂lɨ́n₅ Te₁gui'₅₄ quián₅ ca₂le₃jɨ́n₃.  
\v 37 Ŋi'₅₄ rë₂ bá₄ 'nia'₂ 'e₂ ca₂lë₃ ta₁caun₂ juɨg₂ go₄ dsa₂ judíos, a₂ca₂jme₃lióg₃ 'uë₃ Galilea, cang₂ jme₁ma₂'ë́₂ Juan₅₄ jág₁, ca₂choin₃ dsa₂ jmɨg₂ në́₃.  
\v 38 Ŋi'₅₄ bá₄ 'nia'₂ 'a₂ lia'₂ ca₂cuë₃ Diú₄ ca₂cuë́'₃ Jesús chan₂ Nazaret juɨ₅bí₂ quió'₅ Jme₂dsí₂ Jŋió₅; 'a₂ lia'₂ ca₂ŋɨ₃ jmo₂₃ dse₃, jme₂'lióin₂ ca₂le₃jɨ́n₃ dsa₂ i₂jme₁chan₂ jmɨ₁uɨg₅ jmóg'₂ i₂së₃dsen₃. Ca₂le₃jë́₃ a₂në₅ ca₂jmo₃ ia₁ jme₁quiain'₅₄ Diú₄.  
\v 39 Ca₂të́₂ ne₄ jnia'₅₄ ca₂le₃jë́₃ a₂në₅ a₂ca₂jmo₃ Jesús, lia'₂ jë₄ juɨg₂ Jerusalén, lia'₂ le₂tan₅₄ ja₁tián'₄ dsa₂ chan₂ Judea. Cang₂ jaun₂ ca₂jŋag'₃ dsa₂ ca₂tion₃ cróg₄.  
\v 40 La₁ jë₁ca₂të́₂ 'nɨ₅ jmɨg₄, ca₂jme₃jein'₅₄ táng₃ Diú₄ Jmei₂, ca₂jmo₃ ca₂jme₃jnia₅ 'éi₂ jɨn₄ jnia'₅₄.  
\v 41 Tsá₃ ca₂jme₃jniai₂₃ jɨn₄ ca₂le₃jɨ́n₃ dsa₂. Jmá'₃ lia'₂ jë₄ quián₂ jnia'₅₄ bá₄ con'₂ dsa₂ i₂ca₂quióin'₂ le₂jŋiá₅ i₁të₃ ne₄. Ca₂que₅₄ guë́₄ jnia'₅₄ co₂lë₅ quiain'₅₄ jme₁ma₂jein'₅₄ táng₃ jɨn₄ 'lag₄.  
\v 42 Jaun₂ ca₂jmo₃ 'éi'₃ a₂qui₂dsɨ₁'ë́₄ jnia'₅₄ jág₁, a₂dsɨ₁jang'₅₄ jág₁ dsau₅ jɨn₄ dsa₂: Diú₄ ma₂dsiain₃ Jesús a₂qui₃dsɨ₅ 'éi'₃ quió'₅ dsa₂ i₂chan₂, quió'₅ i₂ma₂dsan₃ në́₃.  
\v 43 Ján₃ bá₄ le₂në₅ jáng'₅ jág₁ dsau₅ ca₂le₃jɨ́n₃ dsa₂ i₂jme₁'ë́₂ jág₁ quiáin₅, a₂qui₃'én₂ Diú₄ dsáu₁ ca₂le₃jɨ́n₃ dsa₂ i₂'én₂ jág₁ quió'₅. 
\s1 Ca₂guei₃ dsɨ₂nau₂ ca₂guein₃ Jme₂dsí₂ Jŋió₅ 
\p  
\v 44 Të₃jë₄ 'ë́₂ guë́₄ Pe₄ jág₁, jme₁ca₂sión₃ Jme₂dsí₂ Jŋió₅ ne₄ quió'₅ ca₂le₃jɨ́n₃ dsa₂ i₂tion'₅₄ nag₅ jág₁.  
\v 45 Dsa₂ judíos\f + \fr 10:45 \ft lit. “dsa₂ i₂rë₂uɨng₄ lo₄.” \f* i₂jme₁'én₂ i₂ca₂o₃lén₂ quian'₅₄ Pe₄, tióin₂ jág₅ dsɨ₂gó'₃ dsɨ́₅, ia₁ ján₃ guë'₂ ca₂guen₃ dsɨ₂nau₂ Jme₂dsí₂ Jŋió₅.  
\v 46 Ia₁ nag₂₃ dsia₅ dsa₂ jág₁ jmei₅ siá'₂, jme₂juɨin'₂ Diú₄.  
\v 47 Jaun₂ ca₂juá'₂ Pe₄: 
\p ―¿Lé₂ le₃jua'₅₄ tsá₃ jmɨg₂ lé₂ tsón₃ dsa₂ në₅, ton'₂ ma₂në₂guein₃ bá₄ guë'₂ Jme₂dsí₂ Jŋió₅, co₂rë₂ bá₄ juɨ₁lia'₂ jniog₄? 
\p  
\v 48 Jaun₂ ca₂jmo₃ 'éi'₃ a₂tsón₃ dsa₂ 'éi₂ jmɨg₂, lia'₂ con'₂ lë́₅ 'éi'₃ quió'₅ Jesucristo. Jme₁co₂lág₂ jaun₂, ca₂mɨ₃ dsa₂ ca₂tsɨ́'₃ Pe₄ a₂jŋia₃ guë́₄ tɨn₃-'nɨ₅ jmɨg₄ quiong'₅₄. 
\c 11  
\s1 Jág₁ ca₂'ë́₂ Pe₄ jɨn₄ dsa₂ 'én₂ juɨg₂ Jerusalén 
\p  
\v 1 Ca₂rë₃ŋi₅ jág₁ dsa₂ i₂chen₄ quián₅ Jesús, quiain'₅₄ rɨin'₅₄ i₂tion'₅₄ Judea, a₂ma₂ca₂rë₃'én₂ dsɨ₂nau₂ jág₁ quió'₅ Diú₄ ján₃.  
\v 2 Jme₁ca₂dsián'₃ táng₃ Pe₄ juɨg₂ Jerusalén, jaun₂ ca₂le₃jɨ́n₃ dsa₂ judíos i₂'én₂ ca₂jí₂ quió'₅  
\v 3 ca₂juá'₂: 
\p ―¿'E₂ lë₃ ŋeg'₅₄ ja₁con₂ dsɨ₂nau₂\f + \fr 11:3 \ft lit. “ja₁con₂ dsa₂ i₂tsá₃ lo₄ rë₂uɨng₄.” \f* i₁que'₅₄ quiain'₅₄ në́₃? 
\p  
\v 4 Jaun₂ ca₂juá'₂ Pe₄ ca₂tsɨ́'₃ dsa₂ ca₂le₃jë́₃ 'a₂ lia'₂ ca₂lë₃, ca₂juá'₂: 
\p  
\v 5 ―Juɨg₂ Jope bá₄ jme₁'eng₅₄, chi₁leng'₄ Diú₄. Të₃jë₄ jaun₂, ca₂jéin₃ ca₂jág₃ juɨ₁lia'₂ caun₂ tsɨ₁'mɨ'₂ tióg₃ pa₁ a₂rë₂quein₅ le₃quén₂ qui'₅₄, ca₂sió₃ juɨ₅ guei'₅₄, ca₂të₂ cau₅ quió₃.  
\v 6 Jme₁ca₂jág₃ jniá₂ dse₃ 'e₂ tio'₅₄ 'ŋió'₃, jua'₂ ca₂le₃jɨ́n₃ ne₄ já'₂ bá₄ tion'₅₄: já'₂ cha₂ quén₂ mɨ₂tag₄, já'₂ tsáu₂ dsɨ́₅, já'₂ i₂tsë́'₅ quió'₅, já'₂ i₂'ɨn₅ guei'₅₄ në́₃.  
\v 7 Jaun₂ ca₂nag₃ jág₁ a₂ca₂juá'₂ ca₂tság₃ jniá₂: “Nau₂ Pe₄, jme₁dsian₅ já'₂, quɨ́ng'₄.”  
\v 8 Jaun₂ ca₂ŋag₄ jniá₂: “Jan₂'ón₄, Te₁gui'₅₄. Ia₁ 'i₁co₂ráun₂ tsá₃ ma₂'í₅ 'o₃ 'i₁caun₂ a₂'lɨg'₅₄ a₂jmo₅ a₂rë₂'ŋio₅ dsa₂.”  
\v 9 Jaun₂ ca₂ŋag₃ táng₃ jág₁ a₂já₅ guei'₅₄, ca₂juá'₂: “Juɨ₁lia'₂ a₂ma₂jmo₃ Diú₄ le₁jë́₃, tsá₃ lë₁juá'₂ 'ne₂ 'lɨg'₅₄.”  
\v 10 'Nɨ₅ ráun₂ ca₂lë₃ le₂jaun₂, jaun₂ guë́₄ ca₂ŋáu'₃ táng₃ ca₂le₃jë́₃ juɨ₅ guei'₅₄.  
\v 11 Të₃jë₄ jaun₂ ca₂dsi₃lén₂ ún₂ dsa₂ 'né₅ ja₁jme₁'eng₅₄, i₂chen₄ quián₅ dsa₂ chan₂ Cesarea a₂'nau'₂ jniá₂.  
\v 12 Jaun₂ Jme₂dsí₂ quián₅ bá₄ Diú₄ ca₂chei₃ ca₂ŋó₃ quiang'₅₄ dsa₂ 'éi₂, caun₂ bá₄ 'ei₅ dsɨ₃ ŋó₃. Ján₃ bá₄ i₁len₅₄ jŋé₂ rɨn'₅₄ jniog₄ la₂ quiong'₅₄ jniá₂. Jaun₂ ca₂tió'₄ jnia'₅₄ ca₂le₃jág₃ dsi₂néi₂ quió'₅ dsa₂ chan₂ Cesarea 'éi₂.  
\v 13 Dsa₂ 'éi₂ ca₂dsia₃ ca₂tság₃ jnia'₅₄ 'a₂ lia'₂ ca₂jɨ́in₂ jan₂ ángel jme₁chén'₄ dsi₂néi₂ quió'₅ i₂ca₂juá'₂: “Chen₅ dsa₂ juɨg₂ Jope a₂dsɨ₃quiáin₂ Si₂mu₅₄ i₂të́'₂ dsa₂ Pe₄ ján₃.  
\v 14 Dsa₂ 'éi₂ juá'₂ 'a₂ lia'₂ jmó'₂, ia₁jaun₂ lióng'₂, quiang'₅₄ dsa₂ dsi₂néi₂ quiáng'₂.  
\v 15 Jme₁ca₂jme₁lióg₄ jniá₂ juɨ́g₂ jág₁, jaun₂ ca₂sión₃ Jme₂dsí₂ Jŋió₅ ne₄ quió'₅ dsa₂ 'éi₂, juɨ₁lia'₂ ca₂guain₃ ne₄ quián₂ jniog₄ le₂'uɨg₅₄.  
\v 16 Jaun₂ guë́₄ ca₂dsáu'₃ dsɨ₃ a₂ma₂ca₂juá'₂ Te₁gui'₅₄ le₂jŋiá₅: “Dsau₅ bá₄ ca₂tióg₃ Juan₅₄ ca₂tiáin₂ jmɨg₂ dsa₂, la₁ 'nia'₂ guë'₂ në́₃ tióg₂ Diú₄ Jme₂dsí₂ Jŋió₅.”\f + \fr 11:16 \ft Hechos 1:5.\f* 
\v 17 Jaun₂ chi₂jua'₂ co₂rë₂ bá₄ ca₂cuë₃ Diú₄ ca₂cuë́'₃ dsa₂ 'éi₂ juɨ₁lia'₂ a₂ma₂cuë₃ jniog₄ i₂ma₂'én₂ të₂le₃ quió'₅ Te₁gui'₅₄ Jesucristo, ¿i₂'ein₂ bá₄ jniá₂ jua'₅₄ jniá₂ jnɨg₅₄ 'éi'₃ quió'₅ Diú₄? 
\p  
\v 18 Jme₁ca₂nág₂ dsa₂ jág₁ në₅, tei₄ bá₄ ca₂jmo₃. Jaun₂ ca₂jme₃juɨin'₂ Diú₄, ca₂tsɨ́'₃ rɨin'₅₄: 
\p ―¡Ján₃ guë́₄ ma₂cuë₃ Diú₄ jmɨg₄ quió'₅ dsɨ₂nau₂, a₂jme₂tsɨ́in₃ dsɨ́₅ ia₁jaun₂ tɨ́in'₄ le₃chain₂ co₂tan₅₄! 
\s1 Dsa₂ 'én₂ i₂chan₂ juɨg₂ Antioquía 
\p  
\v 19 Lia'₂ con'₂ jme₁ca₂jŋɨ'₃ dsa₂ Esteban, caun₂ qui₂ca₂co₃'ein₃ bá₄ dsa₂ quió'₅ ca₂le₃jɨ́n₃ dsa₂ i₂'én₂. Jaun₂ tion₅₄ bá₄ ca₂cuɨng₃ ca₂i₃léin₂ ca₂të₂ Fenicia, Chipre, Antioquía në́₃. La₁ jmá'₃ dsa₂ judíos bá₄ ca₂cuë́'₃ jág₁ dse₃.  
\v 20 La₁ i₂lɨn₅₄ dsa₂ 'én₂ i₂chan₂ Chipre quian'₅₄ Cirene ca₂dsi₃léin₂ juɨg₂ Antioquía ca₂dsia₃ jág₁ quian'₅₄ dsa₂ chan₂ Grecia, ca₂'ë́₂ jág₁ dse₃ ca₂'ɨin₃ Te₁gui'₅₄ Jesús.  
\v 21 Ca₂jme₃'on₅₄ Te₁gui'₅₄ dsa₂ 'éi₂ ja₁jaun₂ quian'₅₄ bí₂ quió'₅, jaun₂ lë₃ juɨn₅ lɨn₃ dsa₂ ca₂jéin'₃ le₃quió'₅ Te₁gui'₅₄. 
\p  
\v 22 Jme₁ca₂rë₃ŋi₅ dsa₂ 'én₂ i₂tion'₅₄ Jerusalén, jaun₂ ca₂chein₃ Bernabé ca₂të₂ Antioquía.  
\v 23 Jme₁ca₂dsióg₃ Bernabé ja₁jaun₂, jaun₂ ca₂jág₃ a₂dse₃ dsɨ́₅ Diú₄ a₂ca₂jmo₃ ja₁con₂ dsa₂ 'éi₂, jaun₂ lë₃ ca₂jmo₃ 'io'₂. Jaun₂ ca₂toin'₂ dsa₂ jág₁ dsia₃ tiá₂ dsɨ́₅, tsán'₂ tiá₂ jág₁ 'ein₃ Te₁gui'₅₄.  
\v 24 Ia₁ dsa₂ dsen₃ bá₄ jme₁lɨ́n₄ Bernabé, jme₁rë₂rɨn₅ Jme₂dsí₂ Jŋió₅ të₂dsɨ́₅, jme₁'éin₂ 'ŋio₅ lɨn₃. Jaun₂ le₂në₅ juɨn₅ dsa₂ ca₂jén'₃ të₂le₃ ja₁con₂ Te₁gui'₅₄. 
\p  
\v 25 Cang₂ jaun₂ ca₂ŋó₃ Bernabé juɨg₂ Tarso a₂ca₂i₁'niai'₂ Saulo. Jme₁ca₂dsáin'₂ 'éi₂, jaun₂ ca₂tág₃ juɨg₂ Antioquía.  
\v 26 Ja₁jaun₂ ca₂tóin'₂ caun₂ ŋi₂ quiain'₅₄ dsa₂ i₂'én₂ ja₁jaun₂, qui₂ca₂jme₃tɨin₂₃ juɨn₅ lɨn₃ dsa₂. Juɨg₂ Antioquía jaun₂ bá₄ ja₁le₂'uɨg₅₄ ca₂quiong₃ dsa₂ ca₂quiain₃ dsa₂ i₂'én₂ “cristianos”. 
\p  
\v 27 Jmɨg₄ jaun₂, i₂lɨn₅₄ dsa₂ i₂jme₁cuë₅ jág₁ dse₃ a₂ma₂gue₃ quió'₅ Diú₄ ca₂'uɨin₂ juɨg₂ Jerusalén ca₂i₁lein₅₄ Antioquía.  
\v 28 Jan₂ i₂chen₂ Agabo ca₂nau₂ jɨn₄ rɨin'₅₄. Jaun₂ quian'₅₄ bí₂ quió'₅ Jme₂dsí₂ Jŋió₅, ca₂'ë́₂ jág₁ a₂le₃'ɨn₂ a₂guë́'₃ dsa₂ ta₁caun₂ mɨ₂güɨ́g₃. Jaun₂ le₂jaun₂ ca₂rë₃ti₃ në́₃ jmɨg₄ lia'₂ con'₂ jme₁guá₄ gui'₅₄ emperador Claudio.  
\v 29 Jaun₂ ca₂le₃jɨ́n₃ dsa₂ 'én₂ i₂chan₂ Antioquía ca₂jmo₃ caun₂ jág₁ ca₂jme₃'oin₅₄ rɨin'₅₄ i₂jme₁tián'₄ Judea, 'a₂ con'₂ jŋia'₅₄ quɨ'₅₄ jmɨg₄ cuë₃ le₂jain₂ le₂jain₂.  
\v 30 Jaun₂ le₂në₅ ca₂jmo₃. Ca₂chein₃ cu₄ ne₄ dsa₂ can'₅₄\f + \fr 11:30 \ft griego: presbúteros.\f* quián₅ dsa₂ 'én₂, ca₂i₁can₅ Bernabé quian'₅₄ Saulo. 
\c 12  
\s1 Ca₂jon₃ Jacobo, Pe₄ guë'₂ ca₂jné₂ dsa₂ 'né₅ 'má₃ 
\p  
\v 1 Jmɨg₄ jaun₂ ca₂jme₃lióg₃ Rag₅₄ Herodes qui₂ca₂jmái'₂ dsa₂ i₂'én₂.  
\v 2 Ca₂jmo₃ 'éi'₃ ca₂jŋɨ'₃ dsa₂ Jacobo rɨn'₅₄ Juan₅₄, quian'₅₄ ŋi₁tág₂.  
\v 3 Jme₁ca₂jág₃ Herodes a₂ca₂të́₂ dsɨ́₅ dsa₂ judíos, jaun₂ ca₂jmo₃ táng₃ 'éi'₃ ca₂jŋa'₃ dsa₂ Pe₄ ján₃. Ca₂le₃jë́₃ a₂në₅ ca₂lë₃ lia'₂ con'₂ jmo₅ dsa₂ jmɨg₄ a₂guë́'₅ dsa₂ i₁ŋí'₄ 'ua'₂ a₂tsá₃ levadura quian'₅₄.  
\v 4 Jme₁ma₂në₂chán'₂ dsa₂ Pe₄, jaun₂ ca₂jmo₃ Herodes 'éi'₃ ca₂to'₂ 'né₅ 'má₃, jaun₂ ca₂tón'₂ quén₂ nió'₃ 'lióg₂ i₂lë́₂ jma₃quén₂ le₂caun₂ nió'₃, qui₂ca₂jmo₃ 'í₁ Pe₄. Jme₁dsɨ₂jiog₅ dsɨ́₅ Herodes jme₁dsei₂₃ të₃jɨn₄ dsa₂ juɨg₂ jë₁ma₂ca₂ŋɨ́₂ Jmɨg₄ Të₂'ɨn₅₄.  
\v 5 Jaun₂ le₂në₅ 'en₅₄ Pe₄ né'₃ 'má₃, lë́₅ 'í₁ dse₃ lɨn₃. La₁ dsa₂ rɨin'₅₄ në́₃ caun₂ chi₂léin'₂ Diú₄ bá₄ tioin'₅₄ mɨ₂₃ 'ŋio₅ lɨn₃ o₄quió'₄ 'éi₂. 
\s1 Ca₂lión₂ Diú₄ Pe₄ 'né₅ 'má₃ 
\p  
\v 6 Caun₂ 'uë₂, juɨ₁lia'₂ 'ióg₃ jme₁ma₂lë́₅ jág₁ jme₁dsei₅ Herodes jɨn₄ dsa₂ juɨg₂, a₂'uë₂ jaun₂ jme₁rë₂quian₅ Pe₄ rë₂güɨ́in₃ rë₂'ŋei₂₃ dse₃ lɨn₃ quian'₅₄ tɨn₃ cadenas jë₄ quió'₅ on₃ 'lióg₂. 'Lióg₂ sián'₂ guë'₂ jme₁tion'₅₄ o₄'né₄ jmo₂₃ 'í₁ 'né₅ 'má₃.  
\v 7 Të₃jë₄ jaun₂, ca₂jme₃jnia₅ jan₂ ángel quián₅ Te₁gui'₅₄, jaun₂ ca₂tág₃ si₂ ta₁caun₂ dsi₂néi₂ 'né₅ 'má₃. Jaun₂ ca₂quén'₃ ángel dsɨ₂con₂ Pe₄ a₂ca₂ŋei₃. Jaun₂ ca₂juá'₂: 
\p ―Nau₂ të₂në₃ cón'₅. 
\p Jaun₂ ca₂séi'₂ 'uë₃ nɨ₁ŋí₁ cadenas a₂jme₁tio'₅₄ gu₂ Pe₄.  
\v 8 Jaun₂ ca₂juá'₂ táng₃ ángel: 
\p ―Dse₃ 'ŋéi₂ tog'₂, tio'₂ lau₂ tag'₅₄. 
\p Jme₁ca₂lë₃ jmo₅ Pe₄ a₂jaun₂, jaun₂ ca₂juá'₂ táng₃ ángel: 
\p ―Qui'₂ 'mɨ'₂ dsiog₂ quiáng'₂, 'éin₃ jniá₂. 
\p  
\v 9 Jaun₂ ca₂o₃'ɨ́n₃ Pe₄ chi₁co'₅₄ quió'₅ ángel. Tsá₃ jaun₂ ŋi₅ chi₂jua'₂ dsón'₂ dsɨ₂jó'₃ a₂ca₂jmo₃ ángel le₂jaun₂, ia₁ a₂lë₁ca₂jág₃ bá₄ lɨ́in₂.  
\v 10 Jaun₂ ca₂ŋɨi₅ ja₁le₂'uɨg₅₄ tion'₅₄ 'lióg₂, ja₁ca₂të́₂ táng₃ në́₃. Jme₁ca₂dsi₃léin₂ o₄'né₄ a₂lë́₅ quian'₅₄ nɨ₁ŋí₁, ja₁'uɨn₂ dsa₂ jë₄ calle, a₂lë₁ca₂niá₃ 'ŋiog₅ bá₄ o₄'né₄. Ca₂'uɨin₂ bá₄ jaun₂ në́₃. Jme₁ma₂i₂nioi₅₄ caun₂ calle, jaun₂ ca₂ŋá'₃ ángel 'éi₂, ca₂téin₂ Pe₄.  
\v 11 Jaun₂ guë́₄ ca₂rë₃lí'₄ Pe₄, ca₂juá'₂: 
\p ―Në₃ guë́₄ dsón'₂ guion₄ jniá₂ a₂në₂chen₃ Te₁gui'₅₄ ángel quiáin₅ a₂në₂lió₂ ja₁con₂ Herodes, ca₂le₃jë́₃ guë́₄ 'e₂ jme₁'nio₃ dsa₂ judíos jmóg'₂. 
\p  
\v 12 Të₃ dsɨ₂jiog₅ dsɨ́₅ le₂jaun₂ Pe₄, ca₂ŋó₃ juɨ₅ ja₁quió'₄ María chog₅₄ Juan₅₄ i₂chen₂ Marcos ján₃. Ja₁jaun₂ jme₁tion'₅₄ dsa₂ le₁ŋɨi'₂ chi₂léin'₂ Diú₄.  
\v 13 Jme₁ca₂quein₃ Pe₄ o₄'né₄ i₁dsi₅, jaun₂ ca₂o₃'ɨ́n₃ jan₂ 'io₅₄ bë'₅₄ i₂chen₂ Rode i₃jág₂ 'ein₂ të́₂.  
\v 14 La₁ jme₁ca₂nág₂, ca₂rë₃cuɨ́'₅ jág₁ quió'₅ Pe₄ në́₃, jaun₂ tsá₃ ca₂niá₃ dsɨ₂juɨ₅, ia₁ ŋɨ́₄ lë₃ ca₂jmo₃ 'io'₂. Jaun₂ ca₂ŋái'₃ bá₄ táng₃ dsi₂néi₂ i₁con₂ jág₁, Pe₄ bá₄ 'éi₂ ca₂dsióg₃.  
\v 15 Jaun₂ ca₂juá'₂ dsa₂ ca₂tsɨ́'₃ 'io₅₄ bë'₅₄ 'éi₂: 
\p ―¡A₂lë₁të₂'ɨ'₂ bá₄ 'ne₂! 
\p La₁ caun₂ ca₂juá'₂ bá₄ 'io₅₄, a₂dsón'₂ bá₄ 'éi₂. Jaun₂ ca₂ŋag₃ táng₃ dsa₂, ca₂juá'₂: 
\p ―¿'A₂ bá₄ lia'₂ jaun₂? On₃jua'₅₄ 'éi₂ në₅. 'Ɨn₁ ángel quiáin₅ bá₄ në₅. 
\p  
\v 16 Të₁lia'₂ jaun₂, caun₂ i₁të₅₄ bá₄ Pe₄ o₄'né₄ i₁chéin'₄. Jme₁ca₂niá₃, ca₂jɨ́in₂ Pe₄, jaun₂ ca₂i₃gó'₃ dsɨ́₅.  
\v 17 La₁ jaun₂ ca₂jmo₃ 'éi₂ léi₄ quian'₅₄ mɨ₂gu₂ a₂ca₂juá'₂ a₂jmo₃ dsa₂ tei₄. Jaun₂ ca₂dsia₃ 'a₂ lia'₂ ca₂lë₃ ca₂jmo₃ Te₁gui'₅₄ a₂ca₂i₁dsei₂₃ 'né₅ 'má₃. Jaun₂ ca₂juá'₂: 
\p ―O₂dsia₄ 'nia'₂ o₂chei'₅₄ Jacobo,\f + \fr 12:17 \ft o₃, Santiago. Rɨn'₅₄ Jesús. I₂sián'₂ bá₄ Jacobo rɨn'₅₄ Juan₅₄ (ja₁ŋi'₅₄ Zebedeo) i₂ca₂jŋag'₃ Herodes, Hechos 12:1.\f* ca₂le₃jɨ́n₃ guë́₄ rɨn'₅₄ jniog₄. 
\p Jaun₂ ca₂o₃'ɨ́in₃ táng₃, ca₂ŋó₃ ja₁siá'₂. 
\p  
\v 18 Jme₁jnia₃ jaun₂, ca₂tón'₂ 'lióg₂ go₂'i₃, ia₁ tsá₃ ŋi₅ 'e₂ ca₂lë₃ quian'₅₄ Pe₄.  
\v 19 Jaun₂ Herodes ca₂chein₃ dsa₂ dsɨ₃'niog'₂. La₁ia₁ tsá₃ ma₃ca₂dsáu'₂. Jaun₂ jme₁ca₂cáun₂ jág₁ dsau₅ quió'₅ 'lióg₂ i₂jme₁jmo₅ 'í₁ 'éi₂, ca₂jmo₃ 'éi'₃ ca₂jme₃dsiog₅ dsa₂. Cang₂ jaun₂, ca₂o₃'ɨ́n₃ Herodes 'uë₃ Judea, jaun₂ ca₂ŋó₃ ca₂i₁gua₂ Cesarea. 
\s1 Ca₂jon₃ Herodes 
\p  
\v 20 Jme₁'ne₂ Herodes quian'₅₄ dsa₂ i₂jme₁tián'₄ Tiro quian'₅₄ Sidón. La₁ dsa₂ 'éi₂ në́₃ ca₂jmo₃ caun₂ jág₁ ca₂i₁lein₅₄ ca₂jme₁jniai₂₃ ne₅₄. Ca₂jme₃'uáin₂ dsɨ́₅ jan₂ i₂chen₂ Blasto a₂jmo₃ dse₃ dsɨ́₅. Jme₁lɨ́n₄ Blasto jan₂ dsɨ₂tan₅₄ juɨn'₂ quián₅ Rag₅₄ Herodes. Ca₂nau₂ ne₄ jág₁, ca₂mɨ₃ dsian₅ mɨ'₅₄. Ia₁ juɨg₂ go₄ rag₅₄ bá₄ jme₁rau₂ a₂guë́'₅ dsa₂ chan₂ Tiro quian'₅₄ Sidón.  
\v 21 Herodes në́₃ ca₂të₃, ca₂tióng₃ caun₂ jmɨg₄ a₂chi₁jŋiog₂₃ dsi₁lén₂ dsa₂. Jme₁ca₂të́₂ jmɨg₄ jaun₂, ca₂quɨ́'₂ Herodes tsɨn'₅₄ a₂rë₂lɨin₅₄ a₂lɨ́in₅ rag₅₄, jaun₂ ca₂i₁gua₂ ne₄ ne₄ta₁ quió'₅, jaun₂ ca₂ton₃ jág₁.  
\v 22 Jaun₂ ca₂jme₃lióg₃ dsa₂ juɨg₂ qui₂ca₂guió'₃ ca₂juá'₂: 
\p ―¡I₂juá'₂ në₅, on₃jua'₅₄ dsa₂ mɨ₂güɨ́g₃! Jan₂ diú₄ bá₄ në₅. 
\p  
\v 23 Co₂tan₅₄ dsɨ₂juɨ₅ le₂jaun₂ ca₂jmo₃ ángel i₂chen₄ quián₅ Te₁gui'₅₄ a₂ca₂rë₃dso'₅₄ Herodes, ia₁ ca₂cuë₃ jmɨg₄ a₂jme₃juag'₂ dsa₂ 'ŋiog₅, 'nió'₄ a₂jme₁jme₃juɨin'₂ Diú₄. Ca₂join₃ bá₄ jaun₂ në́₃, ca₂dsó'₃ i₁ja'₅₄ quió'₅. 
\p  
\v 24 La₁ jág₁ dse₃ quió'₅ Te₁gui'₅₄ në́₃ caun₂ ca₂i₃'ág₃ bá₄, qui₂ca₂'ë́₂ dsa₂ 'lióng₂ juɨg₂. 
\p  
\v 25 Jme₁ca₂lë₃ ta₁ jaun₂ quió'₅ Bernabé quian'₅₄ Saulo, jaun₂ ca₂'uɨin₂ Jerusalén ca₂i₃lein₃\f + \fr 12:25 \ft A₂lɨn₅₄ chog₅₄ si₂: “jaun₂ ca₂i₃lein₃ Jerusalén.” \f* jŋiai₂₃ i₂jme₁chen₂ Juan₅₄ i₂jme₁të́'₂ dsa₂ Marcos ján₃. 
\c 13  
\s1 Ca₂jme₃lióg₃ Bernabé quian'₅₄ Saulo ca₂jmo₃ ta₁ a₂'ë́₂ jág₁ dse₃ 
\p  
\v 1 Co₂nió'₃ dsa₂ i₂'én₂ jág₁ quió'₅ Jesús, i₂jme₁tián'₄ juɨg₂ Antioquía, jme₁chan₂ dsa₂ i₂jme₁'ë́₂ jág₁ quiáin₅, të₅ në́₃, juɨ₁lia'₂ Bernabé quian'₅₄ Si₂mu₅₄ (i₂të́'₂ dsa₂ dsa₂ lia'₂); Lucio i₂chan₂ Cirene; Manaén në́₃ (i₂co₂lë₅ ca₂can'₅₄ quian'₅₄ Herodes i₂lɨ́n₅ dsi₄má'₂ 'uë₃ Galilea);\f + \fr 13:1 \ft griego: Herodes tetrarca.\f* quian'₅₄ Saulo në́₃.  
\v 2 Co₂ráun₂ tioin'₅₄ le₁ŋɨi'₂ jme₂juɨin'₂ Te₁gui'₅₄, a₂jme₂'ɨin₅₄, jaun₂ ca₂juá'₂ Jme₂dsí₂ Jŋió₅: 
\p ―Con'₂ chén'₂ 'nia'₂ Bernabé quian'₅₄ Saulo, ia₁jaun₂ dsɨ₃jmó₂ ta₁ a₂ma₂të́₃ jniá₂ jmo₃. 
\p  
\v 3 Jaun₂ jme₁ca₂lë₃ chi₂léin'₂ Diú₄, a₂jme₂'ɨin₅₄ në́₃, qui₂ca₂quiog₂ gu₂ ne₄ quió'₅ dsa₂ 'éi₂, jaun₂ guë́₄ qui₂ca₂'ág'₃ jág₁ rɨin'₅₄. 
\s1 Dsa₂ i₂chen₄ quián₅ Jesús 'ë́₂ jág₁ të₂ Chipre 
\p  
\v 4 Jaun₂ ca₂chei₃ Jme₂dsí₂ Jŋió₅ ca₂chein₃ Bernabé quian'₅₄ Saulo a₂ca₂i₃léin₂ juɨ₅ Seleucia. Ja₁jaun₂ ca₂tóin'₂ nɨ₁barco a₂ca₂i₃léin₂ caun₂ 'uë₃ a₂niog₅ jë₄ jmɨ₁ŋí'₄, ja₁chei₂ Chipre.  
\v 5 Jme₁ca₂dsi₃léin₂ ja₁jaun₂, caun₂ juɨg₂ a₂niog₅ chei'₅₄ jmɨ₁ŋí'₄ ja₁të́'₂ dsa₂ Salamina, ja₁jaun₂ ca₂jme₃lióg₃ qui₂ca₂'ë́'₃ dsa₂ jág₁ dse₃ quió'₅ Te₁gui'₅₄ dsi₂néi₂ guá'₅ sinagogas quió'₅ dsa₂ judíos. Jme₁quiain'₅₄ bá₄ Juan₅₄ ján₃ i₂lɨ́n₅ dsa₂ i₂jme₂'o₅₄ quió'₅. 
\p  
\v 6 Ca₂i₁nioi₂ ta₁caun₂ 'uë₃ jaun₂, ca₂dsi₃léin₂ caun₂ juɨg₂ ja₁të́'₂ dsa₂ Pafos. Ja₁jaun₂ ca₂jein'₂ jan₂ dsa₂ judío, jan₂ dsa₂ i₂chan₂ dsɨ́₅, i₂tɨn₂ jág₁ të₂jág₁, a₂jme₁jme₂gain₂₃ dsa₂ a₂juá'₂ a₂lɨ́in₅ jan₂ i₂'ë́₂ jág₁ quián₅ Diú₄. Dsa₂ 'éi₂ jme₁të́'₂ dsa₂ Barjesús.\f + \fr 13:6 \ft Barjesús: a₂jein₅ jág₁ “ja₁ŋi'₅₄ Jesús” quian'₅₄ jág₁ jmei₅ arameo.\f* 
\v 7 Jme₁ quiain'₅₄ dsi₄má'₂ i₂chen₂ Sergio Paulo. Dsi₄má'₂ 'éi₂ jme₁lɨ́n₄ jan₂ dsa₂ i₂niog₅ dsi₄ 'ŋio₅ lɨn₃. Co₂ráun₂ ca₂të́'₃ Bernabé quian'₅₄ Saulo, ia₁ a₂'nio₃ nag₃ jág₁ dse₃ quió'₅ Diú₄.  
\v 8 La₁ Barjesús 'éi₂ në́₃, i₂të́'₂ dsa₂ Elimas ján₃, tsá₃ jme₁'nio₃ a₂le₃'én₂ dsi₄má'₂. Jaun₂ jme₁jné₅ juɨ₅.  
\v 9 Jaun₂ Saulo, i₂të́'₂ dsa₂ Pablo ján₃, rë₂rɨn₅ Jme₂dsí₂ Jŋió₅ të₂dsɨ́₅, ca₂jɨ́in₂ tiá₂ dsa₂ 'éi₂,  
\v 10 jaun₂ ca₂juá'₂: 
\p ―¡'Ne₂ dsa₂ të₂jág₁, dsa₂ quián₅ i₂së₃dsen₃, i₂'io'₅₄ ca₂le₃jë́₃ cosa dse₃! ¿'E₂ lë₃ qui₁jnɨg'₄ juɨ₅ co₂dsau₅ quió'₅ Te₁gui'₅₄?  
\v 11 Të₂në₃ cón'₅ 'ë́₂ Te₁gui'₅₄ jmɨ₁uɨg₅ quiáng'₂, co₂dsia₅ téng'₂, co₂'na₂ tsá₃ ma₃lé₂ jag'₅₄ si₂ quió'₅ 'iog₂. 
\p Dsɨ₂juɨ₅ jaun₂ ca₂téin₂ co₂dsia₅, qui₁né'₃ ca₂jén'₃. Jaun₂ jme₁'nai'₂ jan₂ i₂të₂ tsán'₂ gu₂.  
\v 12 Jme₁ca₂jág₃ gui'₅₄ dsi₄má'₂ a₂ca₂lë₃ jaun₂, ca₂rë₃'éin₂ ca₂nág₂ dsɨ₂gó'₃ dsɨ́₅ jág₁ dse₃ quió'₅ Te₁gui'₅₄. 
\s1 Pablo quian'₅₄ Bernabé tioin'₅₄ Antioquía ja₁tén₄ Pisidia 
\p  
\v 13 Ca₂'í₃ Pablo quian'₅₄ rɨin'₅₄ 'ŋió'₃ nɨ₁barco juɨg₂ Pafos, ca₂i₃léin₂ juɨ₅ Perge, juɨg₂ tén₅ 'uë₃ Panfilia. Ca₂tén₂ Juan₅₄ rɨin'₅₄ ja₁jaun₂, jaun₂ ca₂ŋái'₃ juɨ₅ Jerusalén.  
\v 14 Ca₂'uɨn₂ rɨin'₅₄ Perge ca₂dsi₃léin₂ táng₃ Antioquía, juɨg₂ tén₅ 'uë₃ Pisidia. Jaun₂ ca₂i₃toin'₅₄ guá'₅ sinagoga caun₂ jmɨg₄ sa₅₄, jaun₂ ca₂tiáin'₂ dsi₂néi₂.  
\v 15 Jme₁ma₂ca₂lë₃ 'ɨ₅ dsa₂ Si₂ 'Éi'₃ quió'₅ Diú₄ quian'₅₄ Si₂ a₂ca₂jmo₃ dsa₂ i₂jme₁'ë́₂ jág₁ ma₂lɨ́g'₂ në́₃, jaun₂ ca₂chen₃ jág₁ dsa₂ can'₅₄ quián₅ guá'₅ sinagoga, ca₂juá'₂: 
\p ―Rɨn'₅₄ jniog₄, chi₂jua'₂ cha₂ jág₁ dse₃ quián'₂ 'nia'₂ a₂cuë'₅₄ dsa₂, lé₂ bá₄ jua'₅₄ 'nia'₂. 
\p  
\v 16 Jaun₂ ca₂nau₂ Pa₄ ca₂jmo₃ léi₄ quian'₅₄ gu₂ a₂mɨ₂₃ a₂jmo₃ dsa₂ tei₄, jaun₂ ca₂juá'₂: 
\p ―Nei₂ 'nia'₂ dsa₂ israelitas, 'nia'₂ guë́₄ dsa₂ sián'₂ i₂gan₃ Diú₄:  
\v 17 Diú₄ quián₂ jniog₄ dsa₂ lág₅ juɨg₂ Israel ca₂quióin'₂ dsa₂ can'₅₄ quián₂ jniog₄ ma₂lɨ́g'₂. Ca₂jmo₃ Diú₄ ca₂i₃juɨ́n₂ dsa₂ 'éi₂ lia'₂ con'₂ jme₁tiáin'₄ 'uë₃ Egipto a₂lɨ́in₅ dsɨ₂nau₂. Cang₂ jaun₂ ca₂lë₃ caun₂ juɨg₂ pa₁. Diú₄ në́₃ ca₂lió₂ quian'₅₄ bí₂ quió'₅, ca₂'uág'₂ 'uë₃ jaun₂.  
\v 18 Ca₂jme₃juɨn'₂ Diú₄ dsɨ́₅ quiong'₅₄\f + \fr 13:18 \ft A₂lɨn₅₄ chog₅₄ si₂ juá'₂: “ca₂jmo₃ Diú₄ 'í₁ quió'₅.” \f* të₂láu₃ ŋi₂ të₁lia'₂ jme₁i₂nioi₅₄ gua'₅₄ quein₂,  
\v 19 ca₂'éin₂ guio₃ juɨg₂ go₄ dsa₂ i₂jme₁tián'₄ 'uë₃ Cana'án, 'uë₃ jaun₂ në́₃ ca₂cuë́'₃ dsa₂ can'₅₄ quián₂ jniog₄ i₂jme₁chan₂ ma₂lɨ́g'₂. 
\p  
\v 20 'Cang₂ jaun₂ ca₂dsɨn₃ con'₂ quén₂ 'ŋiá₂-láu₂ rë₂dsɨ́₂ të₂láu₃-guiá₂ (450) ŋi₂, ca₂qui₃dsɨ₅ Diú₄ 'éi'₃ jɨn₄ dsa₂ 'éi₂ të₂le₃ quian'₅₄ juë́₄ ca₂lia'₂ ca₂të́₂ jmɨg₄ a₂ca₂rë₃chán₃ Samuel i₂qui₂ca₂'ë́₂ jág₁ quió'₅ Diú₄ cang₂ jaun₂.  
\v 21 Jaun₂ ca₂mɨi₃ jan₂ rag₅₄. Jaun₂ Diú₄ në́₃ ca₂cuɨin₃ Saúl ja₁ŋi'₅₄ Cis, tsɨ₁jon₂ Benjamín; ca₂jmo₃ 'éi'₃ con'₂ të₂láu₃ ŋi₂.  
\v 22 Cang₂ jaun₂ ca₂jŋiá'₂ Diú₄ ta₁ quió'₅ Saúl a₂jme₁lɨ́in₄. Jaun₂ David bá₄ ca₂chein'₃ ca₂lɨin₃ rag₅₄. Jaun₂ ca₂juá'₂ Diú₄ 'ɨin₂₃ Rag₅₄ David: “Ca₂dsó'₂ jniá₂ ja₁con₂ David ja₁ŋi'₅₄ Isaí, a₂lɨ́in₅ jan₂ dsa₂ i₂lë́₅ dsɨ́₅ lia'₂ lë́₅ dsɨ₃ jniá₂, jan₂ dsa₂ i₂jmo₃ a₂'ŋio₂ dsɨ₃.” 
\p  
\v 23 'Jaun₂ në́₃ rɨn'₅₄ jniog₄, jan₂ chi'₂ dsio₄ David 'éi₂ bá₄ lɨ́n₅ Jesús i₂ca₂chen₃ Diú₄ a₂lióin₂ dsa₂ juɨg₂ Israel lia'₂ con'₂ lë́₅ jág₁ quió'₅ ma₂cuë₃ le₂jŋiá₅.  
\v 24 Né'₃ a₂guán₂ Jesús, ca₂'ë́₂ Juan₅₄ jág₁ ca₂tsɨ́'₃ ca₂le₃jɨ́n₃ dsa₂ Israel a₂'nió'₅ qui₃choin₃ jmɨg₂, dsɨ₃quén'₅ dsɨ́₅ në́₃.  
\v 25 Jaun₂ ca₂juá'₂ Juan₅₄ jme₁ja₂quián₃ jóin₂: “On₃jua'₅₄ 'éi₂ jniá₂ juɨ₁lia'₂ dsɨ₂jiog₅ 'au'₂ 'nia'₂ lɨ́n₅ jniá₂. La₁ i₂já₅ chi₁co'₅₄ quió₃ në́₃, 'éi₂ bá₄ i₂'uan'₂ guë́₄ lia'₂ con'₂ guë́₄ jniá₂, ca₂lia'₂ jŋia'₅₄ lau₂ ton₅ tag₅₄ bá₄ tsá₃ ca₂tɨ́ng₂ tsɨ'₅₄ quió'₅.”\f + \fr 13:25 \ft Mateo 3:11.\f* 
\p  
\v 26 ’Rɨn'₅₄ jniog₄, ca₂le₃jɨ́n'₃ guë́₄ 'nia'₂ i₂lɨ́n₅ chi'₂ dsio₄ Abraham, quian'₅₄ ca₂le₃jɨ́n₃ guë́₄ 'ein₂ chan₂ quián'₂ 'nia'₂ i₂jme₂gan₃ Diú₄: a₂quián'₂ 'nia'₂ bá₄ jág₁ dse₃ la₂ a₂ca₂'ë́₂ Diú₄ a₂lión₂ dsa₂.  
\v 27 Dsa₂ i₂jme₁tián'₄ Jerusalén quian'₅₄ dsa₂ can'₅₄ quiáin₅, tsá₃ ca₂rë₃ŋi₅ 'ein₂ 'éi₂ jme₁chen₂ Jesús, on₃ guë́₄ ca₂rë₃ŋɨ́i'₂ jág₁ a₂qui₂ca₂'ë́₂ dsa₂ i₂chen₄ quián₅ Diú₄ le₂jŋiá₅. Jaun₂ lë₃, jág₁ jaun₂ a₂'ɨ₂₃ ne₄ Si₂ ca₂le₃jë́₃ jmɨg₄ sa₅₄ ca₂jme₃ti₃ guioin₅₄ jme₁ca₂jmo₃ 'éi'₃ a₂jŋɨi'₃ Jesús.  
\v 28 'I₁caun₂ dsáu₁ Jesús tsá₃ 'e₂ ca₂dsó'₂ dsa₂ jua'₅₄ a₂'i₄ 'éi'₃ a₂jŋag'₃, la₁ tion₅₄ bá₄ ca₂mɨ₃ dsa₂ jág₁ ne₄ Pilato a₂jmo₃ 'éi₂ 'éi'₃ a₂jŋag'₃.  
\v 29 Jaun₂ në́₃ jme₁ma₂lë₅ 'a₂ con'₂ lë́₅ juá'₂ ne₄ Si₂ quió'₅ Diú₄ a₂'ɨin₂₃ Jesús, jaun₂ ca₂sió₂ dsa₂ ne₄ cróg₄, jaun₂ ca₂i₁'ó₄.  
\v 30 La₁ Diú₄ në́₃, ca₂jme₃jein'₅₄ táng₃ jɨn₄ 'lag₄.  
\v 31 'Lióng₂ jmɨg₄ bá₄ qui₂ca₂jme₃jnia₅ Jesús ne₄ dsa₂ i₂jme₁quiain'₅₄ lia'₂ con'₂ jme₁ca₂ŋó₃ të₂ Galilea ca₂dsióg₃ të₂ Jerusalén. Jaun₂ në́₃ dsa₂ 'éi₂ bá₄ i₂jáng'₅ jág₁ dsau₅ tsɨ́'₅ dsa₂ rë₂në́₃. 
\p  
\v 32 ’Jaun₂ le₂në₅ bá₄ a₂cuë₂ jnia'₅₄ jág₁ dse₃ 'nia'₂, jág₁ a₂ca₂cuë₃ Diú₄ ca₂cuë́'₃ dsa₂ quián₂ jniog₄ ma₂lɨ́g'₂ jaun₂,  
\v 33 ma₂ca₂rë₃ti'₅₄ Diú₄ ja₁con₂ jniog₄ i₂lág₅ chi'₂-guein₂ quián₅ dsa₂ 'éi₂, jme₁ca₂jme₃jein'₅₄ Jesús con'₂ lë́₅ jág₁ tio'₅₄ jë₁ca₂të́₂ tɨn₃ Salmo, a₂juá'₂: 
\q1 'Ne₂ lɨ́ng'₅ jón₃ quiáng₃; 
\q2 jmɨg₄ në₃, ca₂lɨn₃ jniá₂ ŋéi'₅ 'ne₂.\f + \fr 13:33 \ft Salmo 2:7.\f* 
\p  
\v 34 'Ca₂juá'₂ Diú₄ le₂jŋiá₅ a₂jme₃jein'₅₄ jɨn₄ 'lag₄ ia₁jaun₂ tsá₃ dsɨ₃'én₂ quió'₅. Juɨ₁lia'₂ juá'₂ ne₄ Si₂ quió'₅ Diú₄: 
\q1 Ján₃ bá₄ cuë́₄ jniá₂ 'nia'₂ 
\q2 ca₂le₃jë́₃ 'e₂ cosa dse₃ 
\q1 a₂jme₁ti₁ jág₁ quió₃ a₂ca₂cuë́₃ David.\f + \fr 13:34 \ft Isaías 55:3.\f* 
\p  
\v 35 'Jaun₂ lë₃, ján₃ guë'₂ juá'₂ ne₄ Si₂ Salmos ja₁siá'₂ táng₃: 
\q1 Tsá₃ cuë́'₁ jmɨg₄ 
\q2 a₂dsɨ₃guɨ́'₂ quió'₅ dsa₂ jŋió₅ 'éi₂ quiáng'₂ 
\q2 i₂jme₂ti₃ ta₁ ne'₅₄.\f + \fr 13:35 \ft Salmo 16:10.\f* 
\p  
\v 36 'David në́₃ ca₂jme₃ti₃ bá₄ jág₁ ne₄ dsa₂ quiáin₅ të₁lia'₂ ca₂rë₃cháin₃ jmɨg₄ jaun₂, juɨ₁lia'₂ 'éi'₃ ca₂juá'₂ Diú₄. La₁ ca₂jon₃ bá₄ David në́₃, jaun₂ ca₂i₁'ó₄ dsa₂ ja₁le₁'on₅ dsa₂ can'₅₄ quiáin₅, ca₂siá'₃ bá₄ nɨ₁ŋɨ₁ 'éi₂ në́₃.  
\v 37 La₁ nɨ₁ŋɨ₁ Jesús në́₃, i₂ca₂jme₃jen'₅₄ Diú₄, tsá₃ 'e₂ ca₂'en₃. 
\p  
\v 38 'Jaun₂ në́₃ rɨn'₅₄ jniog₄, tion₅₄ 'nió'₅ le₃ŋi'₅₄ 'nia'₂ jág₁ a₂'ë́₅ jniá₂: të₂le₃ quian'₅₄ Jesús bá₄ dsón'₂ 'én₂ dsáu'₂ 'nia'₂.  
\v 39 Të₂le₃ quian'₅₄ 'éi₂, ca₂le₃jɨ́n₃ i₂'én₂ të₂le₃ quió'₅, rë₂'én₄ ca₂le₃jë́₃ dsáu₁ a₂tsá₃ o₂'én₂ dso₄ cha₂ quián'₂ 'nia'₂ të₂le₃ quian'₅₄ 'Éi'₃ quió'₅ Moisés.  
\v 40 'Í₁ jmo₄ 'nia'₂, ia₁jaun₂ tsá₃ dsɨ₃ŋɨ́'₂ 'nia'₂ juɨ₁lia'₂ juá'₂ dsa₂ i₂jme₁'ë́₂ jág₁ quián₅ Diú₄, jme₁ca₂juá'₂ ne₄ Si₂: 
\q1  
\v 41 Jag₄ 'nia'₂ dsa₂ i₂táun₂ 'lɨg'₅₄, 
\q2 juɨ₁dsi₂gó'₃ 'au'₂, juɨ₁dsian'₂ 'nia'₂. 
\q1 Ia₁ jniá₂ i₂lɨ́ng₅ Diú₄ jmo₅₄ léi₄ juë'₂ 
\q2 jmɨg₄ të₁lia'₂ chan'₂ 'nia'₂. 
\q1 La₁ léi₄ jaun₂, 'i₁jan'₂ 'nia'₂ tsá₃ le₃'én₂, 
\q2 o₁jŋia'₅₄ 'a₂ guë'₂ lia'₂ chan₂ i₂dsia₃.\f + \fr 13:41 \ft Habacuc 1:5.\f* 
\p  
\v 42 Jme₁ca₂o₃'ɨ́n₃ Pa₄ quiain'₅₄ rɨin'₅₄ guá'₅ sinagoga quió'₅ dsa₂ judíos, jaun₂ ca₂mɨ₃ dsa₂\f + \fr 13:42 \ft A₂lɨn₅₄ chog₅₄ si₂: “ca₂mɨ₃ dsɨ₂nau₂.” \f* a₂ja₃lén₂ táng₃ 'éi₂ jmɨg₄ sa₅₄ caun₂ a₂ja₃'ë́₂ jág₁ jaun₂.  
\v 43 Jme₁ca₂dsan₃ le₁ŋɨ'₂ dsa₂ dsi₂néi₂ guá'₅, jaun₂ juɨn₅ lɨn₃ dsa₂ judíos quian'₅₄ dsa₂ i₂ma₂gue₃ i₂ma₂tión₂ tiá₂ juá'₅ quió'₅ dsa₂ judíos, ca₂'ein₃ Pa₄ quiain'₅₄ Bernabé, ca₂jme₃quiong'₅₄. Jaun₂ ca₂juá'₂ dsa₂ i₂chen₄ quián₅ Jesús 'éi₂ ca₂tsɨ́'₃ dsa₂ ca₂cuë́'₃ bí₂ a₂tion₅₄ 'nió'₅ tsán'₂ tiá₂ jág₁ dse₃ quió'₅ Diú₄ i₂'ua₁ dsɨ́₅. 
\p  
\v 44 Caun₂ semana cang₂ jaun₂, jme₁ca₂të́₂ táng₃ jmɨg₄ sa₅₄, jaun₂ qui₂ca₂ŋɨ'₂ mei'₂ tsá₃ ca₂le₃jɨ́n₃ dsa₂ juɨg₂ a₂ca₂o₃néi₃ jág₁ quió'₅ Diú₄.  
\v 45 La₁ jme₁ca₂jág₃ dsa₂ judíos juɨn₅ lɨn₃ dsa₂ tion'₅₄, jaun₂ ca₂rë₃'néi₃ a₂dsí'₅ 'ŋio₅ lɨn₃, të₂le₃ jen₅ bá₄ qui₂ca₂ŋag₃ jág₁ a₂juá'₂ Pa₄, qui₂ca₂jnáu'₂ jág₁ uɨg₅ në́₃. 
\p  
\v 46 Jaun₂ ca₂juá'₂ Pa₄ quian'₅₄ Bernabé, ca₂dsia₃ tiá₂ dsɨ́₅ ca₂tsɨ́'₃ dsa₂: 
\p ―Tion₅₄ 'nió'₅ jŋiá₅ de'₂ jɨn'₄ 'nia'₂ con'₂ dsa₂ i₂lɨ́n₅ judíos, ca₂tág₂ jnia'₅₄ 'ë́₄ jág₁ dse₃ quió'₅ Diú₄. La₁ tsá₃ guë'₂ 'niog'₂ 'nia'₂ guéi'₁, jaun₂ ma₂léi₄ bá₄ a₂tsá₃ lé₂ tɨ́n'₄ 'nia'₂ guei'₅₄ i₂juɨ́g₃. Jaun₂ lë₃, dsɨ₁náu₄ jnia'₅₄ ja₁con₂ dsɨ₂nau₂.  
\v 47 Ia₁ le₂në₅ bá₄ 'éi'₃ ca₂cuë₃ Te₁gui'₅₄ jme₁ca₂juá'₂: 
\q1 Juɨ₁lia'₂ si₂ bá₄ lɨ́n'₅ 'ne₂ 
\q2 i₂ca₂dsiáng₃ quió'₅ dsɨ₂nau₂, 
\q1 ia₁jaun₂ 'ë'₅₄ dsa₂ chan₂ ta₁caun₂ mɨ₂güɨ́g₃ 
\q2 juɨ₅ ja₁tɨ́n'₄ dsa₂.\f + \fr 13:47 \ft Isaías 49:6.\f* 
\p  
\v 48 Jme₁ca₂nág₂ dsɨ₂nau₂ jág₁ në₅, qui₂ca₂jmo₃ 'io'₂, qui₂ca₂dsia₃, dsón'₂ bá₄ dse₃ jág₁ quió'₅ Te₁gui'₅₄. Jaun₂ ca₂rë₃'én₂ ca₂le₃jɨ́n₃ i₂con'₂ 'i₄ 'éi'₃ tɨ́n'₄ ja₁le₃chain₂ co₂tan₅₄.  
\v 49 Jaun₂ le₂në₅ ca₂i₃'ág₃ jág₁ dse₃ quió'₅ Te₁gui'₅₄ ta₁caun₂ 'uë₃ jaun₂.  
\v 50 La₁ dsa₂ judíos në́₃ ca₂jmo₃ jág₁ quian'₅₄ i₂lɨn₅₄ 'io₅₄ dsen₃ i₂jme₂go₃ dsa₂ juɨg₂, quian'₅₄ i₂lɨn₅₄ dsa₂ can'₅₄ në́₃, ia₁jaun₂ jme₃'iog₅₄ jme₃'ŋiai₅₄ Pa₄ quiain'₅₄ Bernabé. Jaun₂ le₂në₅ bá₄ ca₂jme₃lióg₃ ca₂jmo₃ jág₁ a₂qui₂ca₂co₃'ein₃ Pa₄ quiain'₅₄ Bernabé ca₂lia'₂ ca₂'uɨn₂ 'éi₂ juɨg₂ jaun₂.  
\v 51 Jaun₂ 'éi₂ në́₃ qui₂ca₂séi'₂ 'liog₂ mɨ₂tag₅₄.\f + \fr 13:51 \ft Co₂'nió'₄ a₂ca₂jmo₃ léi₄, guion₅₄ bá₄ dsa₂ juɨg₂ ma₂rë₂cáin'₄ ia₁ tsá₃ ca₂gue₃ jág₁ quió'₅ Diú₄. 'Nio'₂ ja₁ton₅ Marcos 6:11, Lucas 9:5, 10:11, Hechos 18:6.\f* Ca₂'uɨin₂ bá₄ jaun₂, ca₂i₃léin₂ juɨ₅ Iconio.  
\v 52 La₁ ca₂le₃jɨ́n₃ dsa₂ i₂ca₂rë₃'én₂ në́₃, 'io'₂ jmo₂₃, rë₂rɨn₅ Jme₂dsí₂ Jŋió₅ të₂dsɨ́₅. 
\c 14  
\s1 Pablo quian'₅₄ Bernabé tioin'₅₄ juɨg₂ Iconio 
\p  
\v 1 Ca₂'í₃ Pablo co₂lë₅ quian'₅₄ Bernabé dsi₂néi₂ guá'₅ sinagoga quió'₅ dsa₂ judíos juɨg₂ Iconio. Ja₁jaun₂ ca₂jme₃tɨin₂₃ táng₃ dsa₂ jág₁ dse₃ quió'₅ Diú₄. Juɨn₅ bá₄ dsa₂ ca₂rë₃'én₂, lia'₂ dsa₂ judíos lia'₂ dsɨ₂nau₂ në́₃.  
\v 2 La₁ dsa₂ judíos i₂tsá₃ 'én₂ në́₃, ca₂tsɨ́'₃ dsɨ₂nau₂ a₂chi₃'ɨin₃ 'lɨg'₅₄ dsa₂ i₂'én₂.  
\v 3 Jaun₂ lë₃, uë́₂ bá₄ ca₂'í₃ Pa₄ quiain'₅₄ Bernabé. Ca₂dsia₃ tiá₂ dsɨ́₅ quian'₅₄ bí₂ quió'₅ Te₁gui'₅₄, qui₂ca₂'ë́₂ jág₁; jaun₂ Diú₄ në́₃ ca₂cuë₃ bí₂ ca₂jmo₃ 'éi₂ léi₄ juë'₂ a₂dsɨ₃gó'₃ dsɨ₅, ia₁jaun₂ le₃lí'₄ dsa₂, jág₁ dsau₅ a₂dse₃ dsɨ́₅ Diú₄ bá₄ 'ë́₂ 'éi₂.  
\v 4 La₁ dsa₂ juɨg₂ 'éi₂ jme₁lë́₄ le₁dson'₅₄ i₂jme₁tión₂ le₃quió'₅ dsa₂ judíos, i₂jme₁tión₂ le₃quió'₅ dsa₂ i₂chen₄ quián₅ Jesús 'éi₂ në́₃. 
\p  
\v 5 Jaun₂ ca₂jmo₃ caun₂ jág₁ dsa₂ judíos quiain'₅₄ dsɨ₂nau₂, quian'₅₄ dsɨ₂tan₅₄, a₂tsɨ́'₃ jág₁ uɨg₅ dsa₂ 'éi₂, a₂qui₃jnáu'₂ cang₄ në́₃.  
\v 6 La₁ jme₁ca₂rë₃ŋi₅ Pa₄ quian'₅₄ Bernabé, ca₂cuɨng₃ juɨ₅ Listra, juɨ₅ Derbe në́₃, tɨn₃ juɨg₂ ja₁tén₄ Licaonia, ca₂i₁nioi₁₂ le₂tan₅₄ 'uë₃ jaun₂,  
\v 7 qui₂jme₂tɨin₂₃ dsa₂ jág₁ dse₃ a₂lión₂ dsa₂. 
\s1 Ca₂cuë₃ dsa₂ cang₄ ca₂cuë́'₃ Pablo juɨg₂ Listra 
\p  
\v 8 Juɨg₂ Listra jme₁chan₂ jan₂ dsa₂ i₂tsá₃ lé₂ ŋɨ₃. Lia'₂ jaun₂ lɨ́in₅, lia'₂ con'₂ jme₁ca₂rë₃cháin₃, guá₅ ja₁jaun₂, 'i₁cón'₂ tsá₃ ma₂ca₂ŋɨ₃ ca₂le₃jë́₃ jmɨg₄ a₂chain₂.  
\v 9 Ca₂nág₂ dsa₂ 'éi₂ jág₁ a₂ca₂dsia₃ Pa₄. Jaun₂ Pa₄ në́₃ ca₂jág₃ tiá₂ ca₂jɨ́in₂ dsa₂ 'éi₂, jaun₂ ca₂rë₃lí'₄ Pa₄ a₂'én₂ dsa₂ 'éi₂ a₂lé₂ 'lióin₂.  
\v 10 Jaun₂ ca₂juá'₂ tiá₂ ca₂tsɨ́'₃ dsa₂ 'éi₂: 
\p ―Rë₂ nau₂. Co₂dsau₅ chí'₂ mɨ₂tag'₅₄. 
\p Jaun₂ dsɨ₂juɨ₅ ca₂ráun₂ ca₂nau₂ dsa₂ 'éi₂, ca₂jme₃lióg₃ ca₂ŋɨ₃.  
\v 11 Jme₁ca₂jág₃ dsa₂ a₂ca₂jmo₃ Pa₄ jaun₂, ca₂tóin'₂ co₂mɨ'₅₄, ca₂guió'₃ quian'₅₄ jág₁ jmei₅ quió'₅ dsa₂ chan₂ Licaonia, ca₂juá'₂: 
\p ―¡Diú₄ i₂lɨ́n₅ dsa₂ ca₂sión₃ jë₄ quián₂ jniog₄! 
\p  
\v 12 Juá'₂ dsa₂ a₂lɨ́n₅ Bernabé diú₄ Júpiter, Pa₄ guë'₂ lɨ́n₅ diú₄ Mercurio\f + \fr 14:12 \ft griego: Hermes.\f* ia₁ 'éi₂ bá₄ i₂juá'₂ guë́₄ jág₁.  
\v 13 Jaun₂ jme₁chí'₄ guá'₅ quió'₅ diú₄ Júpiter ja₁dsi₁lén₂ dsa₂ juɨg₂ jaun₂. Dsa₂ i₂lɨ́n₅ jme₂dsa₂ quián₅ Júpiter ca₂dsióg₃ quiain'₅₄ juɨn₅ dsa₂ le₁jŋiai₂₃ ca₁juɨ₅ le₁quian₅ lí₁ në́₃, a₂jme₁'nio₃ jme₃dsiain₂₃ ca₁juɨ₅ a₂jme₁jéin'₂ ne₄ Pa₄ quian'₅₄ Bernabé.  
\v 14 La₁ jme₁ca₂rë₃lí'₄ Pa₄ quian'₅₄ Bernabé i₂chen₄ quián₅ Jesús, a₂ma₂tion'₅₄ dsa₂ jmo₂₃ le₂jaun₂, jaun₂ ca₂jme₃lióg₃ ca₂gág₃ tsɨn'₅₄.\f + \fr 14:14 \ft ca₂gág₃ tsɨn'₅₄: le₂jaun₂ jme₁jmo₅ dsa₂ léi₄ chi₂jua'₂ 'e₂ tsá₃ të₅ dsɨ́₅.\f* Jaun₂ ca₂tóin'₂ jɨn₄ dsa₂ ca₂guió'₃ ca₂juá'₂: 
\p  
\v 15 ―¡Nei₂ 'nia'₂! ¿'E₂ lë₃ jmo'₂ 'nia'₂ le₂në₅? Dsa₂ mɨ₂güɨ́g₃ bá₄ jnia'₅₄, juɨ₁lia'₂ 'nia'₂. A₂le₁quian₁ jág₁ dse₃ bá₄ jnia'₅₄ ja₂náu₅, a₂chei₅₄ 'nia'₂ a₂jŋiá'₄ 'nia'₂ ca₂le₃jë́₃ a₂në₅ a₂tsá₃ 'e₂ ta₁ tí₄, a₂jen'₅₄ 'nia'₂ të₂le₃ quió'₅ Diú₄ jén'₃ i₂ca₂jmo₃ guei'₅₄ i₂juɨ́g₃, gua'₅₄ 'uë₃, jmɨ₁ŋi'₄ në́₃, ca₂le₃jë́₃ guë́₄ 'e₂ a₂cha₂ ja₁jaun₂.  
\v 16 'Ŋiog₅ Diú₄ ca₂cuë₃ jmɨg₄ ma₂lɨ́g'₂ ca₂cuë́'₃ ca₂le₃jɨ́n₃ dsa₂ chan₂ gua'₅₄ 'uë₃ a₂jmo₃ con'₂ lë́₂ dsɨ́₅ guioin₅₄.  
\v 17 La₁ Diú₄ ca₂'ë́'₃ dsa₂ 'ein₂ lɨ́in₅, ca₂jmo₃ bá₄ léi₄ të₂le₃ quian'₅₄ ca₂le₃jë́₃ a₂dse₃ a₂qui₂ca₂jmo₃. 'Éi₂ bá₄ jmo₅ a₂tang₂ jmɨ́₅ ia₁jaun₂ qui₃ráu₃ ca₂le₃jë́₃ a₂qui₂guë́'₃ dsa₂. 'Éi₂ bá₄ jmo₅ a₂le₁'ág₄ dse₃ dsɨ́₅ dsa₂. 
\p  
\v 18 Ja₂lag₃ le₂jaun₂ bá₄ ca₂tió'₃ ca₂jme₃'uáin₂ dsɨ́₅ dsa₂, a₂tsá₃ ma₃qui₃jéin'₂ já'₂ ne₅₄. 
\p  
\v 19 Jaun₂ ca₂dsi₃lén₂ i₂lɨn₅₄ dsa₂ judíos i₂chan₂ Antioquía, quian'₅₄ i₂chan₂ Iconio, qui₂ca₂toin'₂ jág₁ dsa₂, ca₂jmo₃ jág₁. Jaun₂ ca₂cuë́'₃ cang₄ Pa₄, ca₂tsɨ₂cuang'₂ të₂'nɨ'₂ juɨg₂, a₂ma₂në₂jŋag'₃ bá₄ lɨ́in₂.  
\v 20 La₁ jme₁ca₂ŋɨ'₂ dsa₂ i₂'én₂ rɨin'₅₄ ja₁rë₂quiain₂₃, ca₂nau₂ Pa₄, ca₂ŋó₃ táng₃ juɨ₅ jë₄ juɨg₂. Jme₁jnia₃ jaun₂ guë́₄, ca₂o₃'ɨ́in₃ juɨg₂ jaun₂ quiain'₅₄ Bernabé, ca₂i₃léin₂ juɨ₅ Derbe. 
\p  
\v 21 Juɨn₅ dsa₂ chan₂ juɨg₂ Derbe ca₂rë₃'éin₂ jme₁ca₂nág₂ ca₂'ë́₂ dsa₂ 'éi₂ jág₁ dse₃ a₂tɨ́n'₄ dsa₂. Jaun₂ ca₂'uɨin₂ ja₁jaun₂, ca₂i₃léin₂ táng₃ juɨ₅ Listra, juɨ₅ Iconio në́₃, a₂ca₂dsi₃léin₂ táng₃ Antioquía.  
\v 22 Le₂tan₅₄ juɨg₂ ja₁jaun₂ qui₂ca₂cuë́'₃ bí₂ dsa₂ i₂'én₂. Qui₂ca₂toin'₂ jág₁ dsa₂ a₂'nió'₅ tsán'₂ dsa₂ tiá₂ jág₁ dse₃. Ca₂juá'₂: 
\p ―Tion₅₄ 'nió'₅ ŋag'₅₄ de'₂ 'nia'₂ jmɨ₁uɨg₅ mɨ₂güɨ́g₃ la₂, né'₃ guë́₄ a₂dsi₁no'₃ 'nia'₂ ja₁gon₂ Diú₄. 
\p  
\v 23 Ján₃ bá₄ ca₂'ɨn₃ dsa₂ dsa₂ can'₅₄\f + \fr 14:23 \ft griego: presbúteros.\f* lia'₂ caun₂ guá'₅. Jaun₂ cang₂ jme₁ca₂lë₃ chi₂lén'₂ dsa₂ Diú₄, a₂jme₂'ɨin₅₄ në́₃, ca₂dsiain₃ rɨin'₅₄ i₂'én₂ 'éi₂ o₄gú₃ Te₁gui'₅₄, ia₁ të₂le₃ quió'₅ Te₁gui'₅₄ bá₄ ma₂'én₂ dsa₂. 
\s1 Pa₄ quian'₅₄ Bernabé ca₂i₃lein₃ táng₃ Antioquía ja₁tén₄ Siria 
\p  
\v 24 Cang₂ jaun₂ ca₂ŋɨ́i₃ juɨ₅ 'uë₃ Pisidia, jaun₂ ca₂dsi₃léin₂ 'uë₃ Panfilia.  
\v 25 Qui₂ca₂'ë́₂ jág₁ juɨg₂ Perge, jaun₂ ca₂i₃léin₂ juɨg₂ Atalia.  
\v 26 Ja₁jaun₂ ca₂tóin'₂ nɨ₁barco a₂ca₂i₃lein₃ táng₃ Antioquía, juɨg₂ ja₁ca₂jáng'₂ dsa₂ rɨin'₅₄ o₄gú₃ Diú₄ le₂jŋiá₅, a₂jmo₃ ta₁, co₂'nió'₄ ta₁ a₂ma₂ca₂lë₃ jmo₂₃.  
\v 27 Jme₁ca₂dsi₃lein₃ Antioquía, ca₂ŋɨ́i'₂ ca₂le₃jɨ́n₃ rɨin'₅₄. Jaun₂ ca₂dsia₃ ca₂le₃jë́₃ 'e₂ ca₂jmo₃ Diú₄ quiong'₅₄, 'a₂ lia'₂ ca₂niá₃ Diú₄ juɨ₅ quió'₅ dsɨ₂nau₂, ia₁jaun₂ le₃'én₂ 'éi₂ ján₃.  
\v 28 Jaun₂ uë́₂ bá₄ ca₂'í₃ Pa₄ ja₁jaun₂, Bernabé në́₃ quiain'₅₄ dsa₂ i₂'én₂. 
\c 15  
\s1 Ca₂ŋɨ'₂ rɨin'₅₄ Jerusalén 
\p  
\v 1 Jmɨg₄ jaun₂ i₂lɨn₅₄ dsa₂ chan₂ Judea ca₂dsi₃léin₂ juɨg₂ Antioquía, ca₂jme₃lióg₃ ca₂jme₃tɨin₂₃ rɨin'₅₄ ja₁jaun₂, në₁jua'₂ tsá₃ ti₅ dsa₂ nɨ₁lo₁ dsa₂ ŋe'₂ lia'₂ con'₂ lë́₅ Si₂ 'Éi'₃ quió'₅ Moisés, tsá₃ lé₂ tɨ́in'₄.  
\v 2 Pablo quian'₅₄ Bernabé ca₂tsɨ́in₂ 'ŋio₅ lɨn₃ quian'₅₄ dsa₂ 'éi₂. Jaun₂ ca₂'ɨn₃ dsa₂ Pa₄ quian'₅₄ Bernabé, quiain'₅₄ i₂lɨn₅₄ guë́₄ dsa₂ sián'₂ në́₃, a₂dsɨ₃léin₂ Jerusalén a₂jme₃rë́₃ jág₁ jaun₂ quiain'₅₄ dsa₂ rɨin'₅₄ i₂chen₄\f + \fr 15:2 \ft griego: apóstolous.\f* quián₅ Jesús quian'₅₄ dsa₂ can'₅₄\f + \fr 15:2 \ft griego: presbúteros.\f* quián₅ dsa₂ 'én₂. 
\p  
\v 3 Co₂nió'₃ dsa₂ i₂'én₂ juɨg₂ Antioquía ca₂'ág'₃ jág₁ rɨin'₅₄ i₂ca₂'ɨin₃ 'éi₂, jaun₂ 'éi₂ në́₃ ca₂i₁nioi₁₂ 'uë₃ Fenicia quian'₅₄ 'uë₃ Samaria. Ja₁jaun₂ ca₂dsia₃ 'a₂ lia'₂ ca₂rë₃'én₂ dsɨ₂nau₂. Jaun₂ lë₃, 'ŋio₅ lɨn₃ 'io'₂ ca₂jmo₃ dsa₂ rɨin'₅₄ jme₁ca₂rë₃ŋi₅. 
\p  
\v 4 Jme₁ca₂dsióg₃ Pa₄ quiain'₅₄ Bernabé juɨg₂ Jerusalén, ca₂guei₃ ca₂le₃jɨ́n₃ dsa₂ 'én₂ ja₁jaun₂, dsa₂ rɨin'₅₄ i₂chen₄ quián₅ Jesús, dsa₂ can'₅₄ quián₅ dsa₂ 'én₂ në́₃. Jaun₂ ca₂dsia₃ Pa₄ quian'₅₄ Bernabé ca₂tsɨ́'₃ rɨin'₅₄ 'a₂ lia'₂ ma₂jmo₃ Diú₄ quiong'₅₄. 
\p  
\v 5 La₁ qui₂ca₂nau₂ i₂lɨn₅₄ dsa₂ fariseos i₂ma₂'én₂, jaun₂ ca₂juá'₂: 
\p ―Ca₂tɨ́n₂ dsɨ₂nau₂ ti₃ dsa₂ nɨ₁lo₁₂, jaun₂ 'nió'₅ nag₃ a₂jme₃ti₃ Si₂ 'Éi'₃ quió'₅ Moisés. 
\p  
\v 6 Jaun₂ ca₂ŋɨ'₂ dsa₂ i₂chen₄ quián₅ Jesús, quian'₅₄ dsa₂ can'₅₄ në́₃, ia₁jaun₂ 'no'₂ dsɨ́₅ 'a₂ lia'₂ jmo₃ juɨ₁lia'₂ jág₁ jaun₂.  
\v 7 Jme₁ma₂në₂dsia₃ jág₁ 'ŋio₅ lɨn₃, ca₂nau₂ Pedro jaun₂ ca₂juá'₂: 
\p ―Rɨn'₅₄ jniog₄, ŋi'₅₄ bá₄ 'nia'₂ jaun₂, jniá₂ dsa₂ i₂ca₂quión'₂ Diú₄ jɨn'₄ 'nia'₂ ma₂i₁jáun₃, ia₁jaun₂ cuë́₄ jniá₂ jág₁ dse₃ dsɨ₂nau₂, ia₁jaun₂ le₃'éin₂.  
\v 8 Jaun₂ Diú₄ në́₃, i₂cuɨ́'₅ dsɨ́₅ dsa₂, ca₂jmo₃ léi₄ a₂guei₃ bá₄, ca₂cuɨin₃ Jme₂dsí₂ Jŋió₅ quiáin₅, ca₂cuɨin₃ dsa₂ 'éi₂ juɨ₁lia'₂ ma₂cuag₃ jniog₄.  
\v 9 Tsá₃ jma₃quén₅ 'nio₃ Diú₄ jniog₄ quian'₅₄ dsa₂ 'éi₂, ia₁ ján₃ bá₄ ca₂rang₃ jme₂dsí₂ quió'₅ dsa₂ 'éi₂ ia₁ ca₂rë₃'éin₂.  
\v 10 Jaun₂ në́₃, ¿'e₂ lë₃ dsɨ₂jiog₅ 'au'₂ 'nia'₂ a₂tsá₃ dsau₅ a₂ma₂jmo₃ Diú₄? ¿'E₂ lë₃ lɨ́n'₂ 'nia'₂ a₂tion₅₄ 'nió'₅ jme₃ti₃ dsa₂ i₂'én₂ 'éi₂ Si₂ 'Éi'₃, ton'₂ ca₂lia'₂ jŋia'₅₄ dsa₂ can'₅₄ quián₂ jniog₄ tsá₃ ca₂tió'₃ jme₃ti₃, on₃ guë'₂ jniog₄ tián₂ jme₁ti₁?  
\v 11 La₁ ne₄ jniog₄, a₂dse₃ dsɨ́₅ Te₁gui'₅₄ Jesús bá₄ a₂tág'₄, co₂rë₂ quian'₅₄ dsa₂ 'éi₂. 
\p  
\v 12 Jaun₂ ca₂jmo₃ dsa₂ tei₄, jaun₂ ca₂nág₂ të₁lia'₂ ca₂juá'₂ Bernabé quian'₅₄ Pablo ca₂le₃jë́₃ léi₄ juë'₂ a₂ma₂jmo₃ Diú₄ të₂le₃ quiong'₅₄, jɨn₄ dsɨ₂nau₂.  
\v 13 Jme₁ca₂dsan₃ juá'₂ 'éi₂, jaun₂ ca₂juá'₂ táng₃ Jacobo: 
\p ―Rɨn'₅₄ jniog₄, nei₂ 'nia'₂ a₂juá'₄ jniá₂:  
\v 14 Ma₂në₂dsia₃ Si₂mu₅₄ Pe₄ 'a₂ lia'₂ ca₂jmo₃ Diú₄ dse₃ dsɨ́₅ jë₁le₂'uɨg₅₄ të₂le₃ quió'₅ dsɨ₂nau₂, 'a₂ lia'₂ ca₂quióin'₂ ján₃ jɨn₄ dsa₂ 'éi₂, co₂nió'₃ dsa₂ i₂lén₂ dsa₂ quiáin₅ 'ŋiog₅.  
\v 15 Le₂në₅ bá₄ lë́₅ jág₁ quió'₅ dsa₂ i₂jme₁'ë́₂ jág₁ quián₅ Diú₄, juɨ₁lia'₂ ca₂tióng₃ ne₄ Si₂: 
\q1  
\v 16 Guio₅₄ táng₃ cang₂, jaun₂ jmóg'₄ táng₃ ne₄ta₁ 
\q2 quió'₅ Rag₅₄ David a₂ma₂quɨ'₃; 
\q1 tsɨ'₅₄ táng₃ nɨ₁cang₁ a₂ma₂gon₃ quió'₅, 
\q1  
\v 17 ia₁jaun₂ ca₂le₃jɨ́n₃ dsɨ₂nau₂ 'nai'₂ Te₁gui'₅₄, 
\q2 ca₂le₃jë́₃ juɨg₂ në́₃, 
\q2 dsa₂ i₂chen₂ dsa₂ quián₅ Diú₄. 
\q1  
\v 18 Le₂në₅ bá₄ juá'₂ Te₁gui'₅₄ 
\q2 i₂jmo₅ ca₂le₃jë́₃ a₂në₅, 
\q2 a₂ma₂cuɨ́'₅ dsa₂ ca₃ma₂lɨ́g'₂.\f + \fr 15:18 \ft Amós 9:11-12.\f* 
\p  
\v 19 ’Jaun₂ në́₃ lɨ́n₂ jniá₂ ―juá'₂ Jacobo―, tsá₃ dse₃ cue₅₄ jniog₄ o₂me'₅₄ dsɨ₅ dsɨ₂nau₂ i₂ma₂jén'₂ të₂le₃ quió'₅ Diú₄.  
\v 20 Tió'₅ me'₂ a₂jŋia'₅₄ jmó₁ jniog₄ caun₂ si₂ a₂chei₅₄ jniog₄ a₂tsá₃ ma₃guë́'₃ má₃ a₂tsá₃ dsi₂ten₅₄ guë́'₃ juɨ₁lia'₂ a₂dsia₅ dsa₂ ne₄ ne₄chei₂ quió'₅ diú₄ lag₄. Dse₃ chei₅₄ jniog₄ a₂tsá₃ nió'₃ jág₁ quian'₅₄ dsa₂ i₂tsá₃ lɨ́n₅ dsɨ₂i₂gu₂, on₃ guë'₂ guë́'₃ má₃ a₂tsá₃ dsi₃ten₅₄ guë́'₃ dsa₂ judíos, juɨ₁lia'₂ já'₂ i₂güɨ́'₅ dsa₂ dsɨ₂lag₄, on₃ guë'₂ jmɨ₄ já'₂ në́₃.  
\v 21 Ia₁ ma₂lɨ́g'₂ bá₄ ma₂tu₁ja₂lén₂ dsa₂ qui₂'ë́₂ 'Éi'₃ Juá'₅ quió'₅ Moisés le₂caun₂ le₂caun₂ juɨg₂, qui₂'ɨ₂₃ dsi₂néi₂ guá'₅ sinagogas ca₂le₃jë́₃ jmɨg₄ sa₅₄. 
\p  
\v 22 Jaun₂ në₃, ca₂të₁gua₁ jág₁ quió'₅ dsa₂ i₂chen₄ quián₅ Jesús, quian'₅₄ dsa₂ can'₅₄, ca₂le₃jɨ́n₃ guë́₄ dsa₂ i₂lɨ́n₅ guá'₅ a₂'ɨin₃ i₂lɨn₅₄ jë₄ quió'₅ rɨin'₅₄, i₂chein₃ quian'₅₄ Pablo, Bernabé në́₃, juɨ₅ Antioquía. Jaun₂ ca₂'ɨn₃ dsa₂ Judas i₂chen₂ Barsabás ján₃, quian'₅₄ i₂chen₂ Silas i₂lɨ́n₅ dsa₂ i₂quian₅ ne₄ juɨ₅ jë₄ quió'₅ dsa₂ i₂'én₂.  
\v 23 Jaun₂ quian'₅₄ 'éi₂ ca₂chein₃ si₂ carta a₂juá'₂ le₂la₂: 
\p Jnia'₅₄ con'₂ lág₅ dsa₂ chen₄ quián₅ Jesús, quian'₅₄ dsa₂ can'₅₄ quián₂ jnia'₅₄, ca₂le₃jɨ́n₃ guë́₄ rɨn'₅₄ jnia'₅₄ i₂'én₂, chen₄ jnia'₅₄ si₂ la₂ ne'₅₄ 'nia'₂ dsɨ₂nau₂ rɨn'₅₄ jniog₄ i₂tián'₅ juɨg₂ Antioquía, quian'₅₄ i₂tián'₅ 'uë₃ Siria, quian'₅₄ i₂tián'₅ 'uë₃ Cilicia në́₃. Cuɨ́n₅ jnia'₅₄ Diú₄ 'nia'₂. 
\p  
\v 24 Ma₂ca₂rë₃ne₄ jnia'₅₄ jág₁ a₂i₁len₅₄ i₂lɨn₅₄ dsa₂ chan₂ ja₁lá₃, on₃jua'₅₄ i₂chen₄ quián₂ jnia'₅₄. Ma₂dsi₃léin₂ cuë́'₅ o₂me'₅₄ dsɨ₅ 'nia'₂ quian'₅₄ jág₁ quió'₅ a₂tsɨ́'₅ 'nia'₂ a₂tion₅₄ 'nió'₅ ti₃ dsa₂ nɨ₁lo₁ dsa₂ ŋe'₂, a₂jme₁ti'₄ 'nia'₂ 'Éi'₃ quió'₅ Moisés në́₃.  
\v 25 'Uɨg₅₄ jaun₂, ca₂jmó₁ jnia'₅₄ caun₂ jág₁, ca₂'ɨ́n₄ jnia'₅₄ rɨn'₅₄ jë₄ quián₂ jnia'₅₄ a₂dsɨ₃léin₂ co₂lë₅ quiain'₅₄ Bernabé quian'₅₄ Pa₄ i₂'nio₄ lɨn₃ quián₂ jnia'₅₄, a₂dsɨ₃jɨin₅₄ 'nia'₂. Ia₁ le₂jaun₂ bá₄ dse₃, lág₂ jnia'₅₄.  
\v 26 Ma₂le₁'ág₄ caun₂ dsɨ́₅ gue₃ 'mú₃ o₁quió'₄ Te₁gui'₅₄ Jesucristo quián₂ jniog₄.  
\v 27 Jaun₂ chen₄ jnia'₅₄ Judas quian'₅₄ Silas në́₃, jaun₂ i₂në₅ bá₄ juá'₂ quian'₅₄ jág₁ tio'₅₄ 'o₅₄ ca₂le₃jë́₃ a₂jua'₂ jnia'₅₄ la₂.  
\v 28 Jaun₂ në́₃, Jme₂dsí₂ Jŋió₅ bá₄ ca₂jme₃'o₅₄ a₂'niog'₅₄ jnia'₅₄ dsɨ₅, jaun₂ dse₃ bá₄ lág₂ jnia'₅₄ a₂tsá₃ cuë₅₄ jnia'₅₄ 'nia'₂ 'éi'₃ guei₂, jŋia'₅₄ lia'₂ jmá'₃ lia'₂ a₂léi₄ 'nió'₅ quián'₂ 'nia'₂ la₂:  
\v 29 A₂tsá₃ quë'₅₄ 'nia'₂ nɨ₁ŋɨ́₅ a₂ma₂dsia₃ dsa₂ ne₄ ne₄chei₂ quió'₅ diú₄ lag₄; ján₃ bá₄ tsá₃ quë'₅₄ 'nia'₂ jmɨ₄ já'₂, on₃ guë'₂ nɨ₁ŋɨ₁ já'₂ i₂dsan₂ i₂güɨ́'₅ dsa₂ dsɨ₂lag₄. Tsá₃ nió'₄ 'nia'₂ jág₁ quian'₅₄ dsa₂ i₂tsá₃ lɨ́n₅ dsɨ₂i₂gog'₂. Në₁jua'₂ ca₂jme₁ti'₄ 'nia'₂ jág₁ la₂, dse₃ bá₄ le₃chan'₂ 'nia'₂. 
\p Co₂në₅ bá₄ jág₁. 
\p  
\v 30 Jaun₂ në́₃, le₂në₅ bá₄ ca₂tón'₂ 'éi₂ juɨ₅, ca₂i₃léin₂ juɨ₅ Antioquía. Jaun₂ ca₂ŋɨ́i'₂ dsa₂ i₂'én₂ ja₁jaun₂. Jaun₂ ca₂jɨ́in'₃ dsa₂ si₂ carta a₂jme₁quian₅.  
\v 31 Jme₁ca₂'ɨ́₂ rɨin'₅₄ si₂, qui₂ca₂jmo₃ 'io'₂ o₁quió'₄ jág₁ a₂cuë₅ lián'₂ dsɨ́₅ jaun₂.  
\v 32 Ia₁ Judas quian'₅₄ Silas, i₂jme₁'ë́₂ jág₁ a₂cuë₅ Diú₄ ján₃, ca₂cuë₃ 'lióng₂ jág₁ dse₃ a₂ca₂jmo₃ ca₂'ág₂ dse₃ dsɨ́₅ rɨin'₅₄, 'ŋio₅ lɨn₃ ca₂cuë₃ bí₂ në́₃, quian'₅₄ jág₁ quió'₅.  
\v 33 Jme₁ma₂të́₂ 'lióng₂ jmɨg₄ tioin'₅₄ ja₁jaun₂, ca₂dsióg'₂ táng₃ dsa₂ caun₂ tei₄ ja₁con₂ rɨin'₅₄ i₂ca₂chei₃.\f + \fr 15:33 \ft A₂lɨn₅₄ chog₅₄ si₂ chi₁ton₅ versículo 34: “La₁ Silas në́₃, ca₂dsia₃ dsɨ́₅ jŋia₃.” \f* 
\v 35 La₁ ca₂jŋia₃ Pa₄ quian'₅₄ Bernabé juɨg₂ Antioquía, qui₂jme₂tɨin₂₃ dsa₂, quiain'₅₄ juɨn₅ guë́₄ i₂sián'₂, qui₂'ë́'₅ dsa₂ jág₁ dse₃ quió'₅ Te₁gui'₅₄. 
\s1 Ca₂ŋó₃ Pa₄ ca₂i₁'ë́₄ jág₁ jë₁ca₂të́₂ tɨn₃ ráun₂ 
\p  
\v 36 Cang₂ jaun₂, ca₂juá'₂ Pa₄ ca₂tsɨ́'₃ Bernabé: 
\p ―Dsau₅₄ táng₃ dsɨ₁jɨn₁ rɨn'₅₄ ca₂le₃jë́₃ juɨg₂ ja₁ma₂ca₂i₁'ë'₅₄ dsa₂ jág₁ dse₃ quió'₅ Te₁gui'₅₄, dsɨ₁jag₅₄ në₁jua'₂ 'a₂ lia'₂ chain₂. 
\p  
\v 37 Bernabé në́₃ jme₁'nio₃ jŋiai₃ Juan₅₄, i₂chen₂ Marcos ján₃.  
\v 38 La₁ Pa₄ guë'₂ në́₃ tsá₃ ca₂gue₃ jiog₃, ia₁ ca₂téi₂ bá₄ 'éi₂ lia'₂ con'₂ jme₁i₁nioi₁₂ 'uë₃ Panfilia,\f + \fr 15:38 \ft 'Nio'₂ ja₁ton₅ Hechos 13:15.\f* tsá₃ ma₃ca₂jme₃quiong'₅₄ jua'₅₄ a₂jme₃'o₅₄.  
\v 39 Jaun₂ ca₂tsɨ́in₂ 'ŋio₅ lɨn₃, ca₂lia'₂ ca₂i₃léin₂ jma₃quén₅. Jaun₂ Bernabé bá₄ ca₂jŋia₃ Marcos, ca₂tóin'₂ nɨ₁barco, ca₂i₃léin₂ juɨ₅ Chipre.  
\v 40 Pa₄ guë'₂ ca₂quióin'₂ Silas. Jme₁ma₂në₂jáng'₂ rɨin'₅₄ o₄gú₃ Te₁gui'₅₄ i₂'nio₃, jaun₂ qui₂ca₂'ág'₃ jág₁ rɨin'₅₄, ca₂i₃léin₂.  
\v 41 Jaun₂ ca₂i₁ŋɨi₁₂ le₂tan₅₄ 'uë₃ Siria quian'₅₄ Cilicia, qui₂i₁cuë'₂ bí₂ rɨin'₅₄ i₂tián'₅ ja₁jaun₂. 
\c 16  
\s1 Ca₂jme₃quiong'₅₄ Timoteo ca₂jme₃quiain'₅₄ Pa₄ quian'₅₄ Silas 
\p  
\v 1 Ca₂dsióg₃ Pa₄ quian'₅₄ Silas juɨg₂ Derbe, juɨg₂ Listra në́₃. Ja₁jaun₂ ca₂jein'₂ jan₂ dsa₂ 'én₂ i₂chen₂ Timoteo. Chog₅₄ Timoteo 'éi₂ jme₁lɨ́n₄ 'io₅₄ judía i₂ma₂'én₂ jág₁ dse₃. Jmei₂ guë'₂ jme₁lɨ́n₄ jan₂ griego.  
\v 2 Jaun₂ dsa₂ i₂'én₂ i₂jme₁tián'₄ Listra quian'₅₄ Iconio, dse₃ bá₄ jme₁'ag₂₃.  
\v 3 Jaun₂ 'nio₃ Pa₄ jiog₃ quiong'₅₄, jaun₂ ca₂ti₃ nɨ₁lo₁ 'éi₂,\f + \fr 16:3 \ft o₃, “ca₂jmo₃ a₂ca₂ti₃ dsa₂ nɨ₁lo₁ 'éi₂.” \f* ia₁jaun₂ tsá₃ jén'₄ 'lɨg'₅₄ dsa₂ judíos i₂tián'₅ ja₁jaun₂. Ia₁ ma₂ŋi₅ bá₄ ca₂le₃jɨ́n₃ dsa₂, a₂lɨ́n₅ griego jmei₂ 'éi₂.  
\v 4 Ca₂le₃jë́₃ juɨg₂ ja₁ca₂ŋɨ́i₃, qui₂ca₂jme₃jein'₂ rɨin'₅₄ ca₂cuë₃ 'éi'₃ con'₂ lë́₅ jág₁ quió'₅ dsa₂ i₂chen₄ quián₅ Jesús, jág₁ quió'₅ dsa₂ can'₅₄ i₂tián'₅ Jerusalén në́₃.  
\v 5 Jaun₂ në́₃, ca₂le₃jɨ́n₃ dsa₂ i₂lɨ́n₅ guá'₅, ca₂jŋa'₃ tiá₂ jág₁ dse₃ a₂'éin₂, jaun₂ le₂o₃ jmɨg₄ bá₄ ca₂i₃juɨ́in₂. 
\s1 Ca₂quɨ₃ Pablo a₂ca₂jɨ́in₂ jan₂ dsa₂ chan₂ Macedonia 
\p  
\v 6 Tsá₃ ca₂cuë₃ Jme₂dsí₂ Jŋió₅ jmɨg₄ a₂'ë́₂ dsa₂ jág₁ dse₃ 'uë₃ Asia. Jaun₂ lë₃ ca₂i₁lein₅₄ ca₂i₁ŋɨi₁₂ le₂tan₅₄ 'uë₃ Frigia quian'₅₄ 'uë₃ Galacia.  
\v 7 Jaun₂ ca₂dsi₃léin₂ ja₁jén₂ 'uë₃ Misia. Ja₁jaun₂ jme₁'nio₃ jme₁dsɨ₃léin₂ 'uë₃ Bitinia. La₁ tsá₃ ca₂cuë₃ jmɨg₄ Jme₂dsí₂ quián₅ Jesús dsɨ₃léin₂ ja₁jaun₂.  
\v 8 Jaun₂ con'₂ ca₂ŋɨ́i₃ bá₄ 'uë₃ Misia, ca₂dsi₃léin₂ 'o₄ jmɨ₁ŋí'₄ ja₁chei₂ Troas.  
\v 9 Ja₁jaun₂ ca₂quɨ₃ Pa₄ a₂'uë₂ jaun₂ a₂ca₂jɨ́in₂ jan₂ dsa₂ chan₂ 'uë₃ Macedonia, a₂chéin'₅ mɨ₂₃, a₂juá'₂: “Ŋɨ₅₄ juɨ₅ 'uë₃ Macedonia i₂jme₁'o₁ jnia'₅₄.”  
\v 10 Dsɨ₂juɨ₅ jme₁ca₂quɨ₃ Pa₄ le₂në₅, jaun₂ ca₂jmó₁ jnia'₅₄ co₂jŋia₅₄ a₂dsɨ₁náu₄ juɨ₅ Macedonia. Ia₁ dsón'₂ lág₂ jnia'₅₄ a₂të́₂ Diú₄ ja₁jaun₂ a₂dsɨ₁'ë́₄ jnia'₅₄ jág₁ dse₃.\f + \fr 16:10 \ft Ja₁lá₃ ca₂jme₃lióg₃ Lucas ca₂jme₃quiain'₅₄ Pa₄ quian'₅₄ rɨin'₅₄ ja₁jme₁i₂nioi₅₄. Ja₁lá₃ ca₂jme₃lióg₃ juá'₂ “jnia'₅₄” lia'₂ con'₂ jme₁ca₂jmo₃ Si₂ Hechos la₂.\f* 
\s1 Pa₄ quian'₅₄ Silas tioin'₅₄ juɨg₂ Filipos 
\p  
\v 11 Ca₂tió'₄ jnia'₅₄ 'ŋió'₃ nɨ₁barco juɨg₂ Troas. Ca₂i₃náu₅ jnia'₅₄ co₂dsau₅ juɨ₅ 'uë₃ Samotracia a₂niog₅ jë₄ jmɨ₁ŋí'₄. Jme₁jnia₃ jaun₂, ca₂dsi₃náu₅ jnia'₅₄ Neápolis.  
\v 12 Tio'₅₄ jnia'₅₄ ja₁jaun₂, i₂náu₅ táng₃ ja₁chei₂ Filipos. Ja₁jaun₂ lë́₅ caun₂ colonia romana ja₁lë́₄ juɨg₂ dsen₅₄ guë́₄ quió'₅ dsa₂ chan₂ 'uë₃ Macedonia. Ja₁jaun₂ ca₂tió'₄ jnia'₅₄ tɨn₃-'nɨ₅ jmɨg₄.  
\v 13 Caun₂ jmɨg₄ sa₅₄ ca₂i₁náu₄ juɨ₅ 'nɨ'₂ juɨg₂, cau₅ chei'₅₄ cuá₃, caun₂ ja₁jme₁lë́₄ ja₁dsɨ₂lén₂ dsa₂ a₂chi₂léin'₂ Diú₄. Ja₁jaun₂ ca₂'io₄ jnia'₅₄, ca₂jme₁tɨn₅ jnia'₅₄ 'io₅₄ i₂ca₂ŋɨ'₂, jág₁ dse₃ quió'₅ Diú₄.  
\v 14 Jan₂ 'io₅₄ i₂jme₁'en₅₄ jë₄ jaun₂ i₂chen₂ Lidia i₂chan₂ juɨg₂ Tiatira, jme₁lɨ́n₄ dsa₂ i₂'nag₅ 'mɨ'₂ 'uɨ'₃ jlá'₁. 'Io₅₄ 'éi₂, jme₁jme₂juɨn'₂ Diú₄. Jaun₂ ca₂jmo₃ Te₁gui'₅₄ ca₂lë₃ dsɨ́₅ 'io₅₄ 'éi₂ a₂nag₃ a₂tón'₂ juɨ₅ a₂juá'₂ Pa₄.  
\v 15 Jaun₂ ca₂jŋói₂ jmɨg₂ co₂dsia₅ quian'₅₄ ca₂le₃jɨ́n₃ dsa₂ dsi₂néi₂ quió'₅. Jme₁co₂lág₂ jaun₂, ca₂mɨ₃ tság₅ jnia'₅₄: 
\p ―Chi₂jua'₂ jmo'₂ 'nia'₂ 'au'₂ a₂lɨ́n₅ jniá₂ të₃dsón'₂ dsa₂ i₂'én₂ jág₁ quió'₅ Te₁gui'₅₄, i₂nó'₅ 'nia'₂ ja₁quió₃ i₁jŋia'₄. 
\p Jaun₂ ca₂juá'₂ tion₅₄ a₂ca₂jŋia₄ jnia'₅₄. 
\p  
\v 16 Co₂ráun₂ ca₂lë₃, lia'₂ con'₂ jme₁i₃náu₅ jnia'₅₄ ja₁chi₂lén'₂ dsa₂ Diú₄, ca₂jen'₂ jnia'₅₄ jan₂ 'io₅₄ chi'₂ i₂jme₁'en₅₄ jme₂dsí₂ 'lɨn'₅₄ të₂dsɨ́₅, i₂dsi₂ jág₁.\f + \fr 16:16 \ft lit. “jan₂ 'io₅₄ chi'₂ i₂jme₁jiog₅ jme₂dsí₂ quió'₅ dsɨ₂mɨ'₂ cua₁ pithón.” \f* 'Io₅₄ 'éi₂ a₂lë₁jmo₂₃ bá₄ ta₁, ia₁ juɨg₅₄ bá₄ jme₁cán₂ cu₄ a₂jme₁lɨ́'₂ a₂dsi₂ jág₁.  
\v 17 'Io₅₄ chi'₂ 'éi₂ ca₂'ein₃ Pa₄, ca₂'ein₃ jnia'₅₄ në́₃, ca₂guió'₃ ca₂tsɨ́'₃ dsa₂ i₂jme₁tion'₅₄: 
\p ―Dsa₂ në₅ i₂jme₂ti₃ ta₁ ne₄ Diú₄ juɨn'₂ guë́₄. Jaun₂ 'ë́₂ jág₁ tsɨ́'₅ 'nia'₂ 'a₂ lia'₂ lé₂ lión'₂ 'nia'₂. 
\p  
\v 18 'Lióng₂ jmɨg₄ ca₂jmo₃ le₂jaun₂. Ca₂lë₃ jme₁ca₂lë₃ ca₂i₃mé'₂ dsɨ́₅ Pa₄. Jaun₂ ca₂jí₂, ca₂juá'₂ ca₂tsɨ́'₃ jme₂dsí₂ 'lɨn'₅₄ i₂jme₁'en₅₄ quió'₅ 'io₅₄ 'éi₂: 
\p ―Quian'₅₄ bí₂ 'éi'₃ quió'₅ Jesucristo, jmo₅₄ jniá₂ 'éi'₃, jú₅ quió'₅ 'io₅₄ në₅. 
\p Jaun₂ co₂tan₅₄ dsɨ₂juɨ₅ jaun₂, ca₂o₃'ɨ́n₃ jme₂dsí₂ 'lɨn'₅₄ ca₂téin₂ 'io₅₄. 
\p  
\v 19 Jme₁ca₂rë₃lí'₄ dsa₂ juɨg₅₄ 'io₅₄ 'éi₂, a₂tsá₃ ma₃cuɨn₅ jmɨg₄ a₂lí'₂ guë́₄ cu₄ quiain'₅₄ 'éi₂, jaun₂ ca₂jŋai'₃ Pa₄ quian'₅₄ Silas, ca₂tág₃ juɨ₅ 'ma'₅₄ ne₄ dsɨ₂tan₅₄.  
\v 20 Jaun₂ ca₂i₁jo₅₄ ja₁tián'₄ juë́₄, jaun₂ ca₂juá'₂: 
\p ―Dsa₂ la₂, i₂lɨ́n₅ judíos, i₂nioi₅₄ tsɨ₂jɨin₂₃ dsa₂ juɨg₂ go₄ jniog₄.  
\v 21 Qui₂'ë́'₅ jme₂tɨin₂₃ dsa₂ tag₄ a₂tsá₃ dsi₂ten₅₄ guéi₁ jniog₄, on₃ guë'₂ dsi₂ten₅₄ jua'₅₄ a₂jmó₁, ia₁ dsa₂ romanos bá₄ lág₅. 
\p  
\v 22 Jaun₂ ca₂nau₂ dsa₂ juɨg₂ 'nei₂ ca₂jmái'₂ Pa₄ quian'₅₄ Silas. Jaun₂ ca₂dsi₂ dsɨ₂tan₅₄ a₂dsi₂uɨg₅ nɨ₁tsɨn'₅₄, jaun₂ ca₂jmo₃ 'éi'₃ a₂bóg₂ në́₃ quian'₅₄ nɨ₁'ma₂.  
\v 23 Jme₁ma₂dsan₃ bóg₂ 'ŋio₅ lɨn₃, jaun₂ guë́₄ ca₂to'₂ né'₃ 'má₃. Ca₂jmo₃ 'éi'₃ a₂jmo₃ dsa₂ i₂niog₅ gu₂ 'né₅ 'má₃ 'í₁ dse₃ lɨn₃.  
\v 24 Dsa₂ 'éi₂ në́₃, jme₁ca₂ŋɨi₂ 'éi'₃ jaun₂, ca₂i₁tio'₂ ca₂të₂ quióng₄ tsɨ₁'né₅ 'má₃, le₁tia₃ mɨ₂tag₅₄ 'ŋió'₃ tau₂ nɨ₁'ma₂. 
\p  
\v 25 La₁ con'₂ dsi₃nei₅ jme₁ca₂'ë₃ Pa₄ alabanzas quiain'₅₄ Silas qui₂ca₂tsɨ́'₃ Diú₄, qui₂ca₂nág₂ bá₄ dsa₂ sián'₂ i₂tion'₅₄ 'né₅ 'má₃.  
\v 26 Të₃jë₄ jaun₂, con'₂ tsá₃ ján₅ dsa₂, ca₂i₁bi₅₄ 'uë₃ tiá₂ lɨn₃, ca₂lia'₂ qui₂ca₂jë́'₂ 'uɨg₅₄ nɨ₁'ia'₂ tsɨ₁'né₅ 'má₃, qui₂ca₂niá₃ ca₂le₃jë́₃ o₄'né₄, qui₂ca₂gag₂ ŋí₁ cadenas a₂jme₁le₁'ŋe'₅₄ ca₂le₃jɨ́n₃ dsa₂ i₂jme₁tion'₅₄ 'ŋió'₃.  
\v 27 Jme₁ca₂ŋé₃ dsa₂ i₂jmo₅ 'í₁, ca₂jág₃ ma₂le₁na₁ jë₂ o₄'né₄ 'né₅ 'má₃, jaun₂ ca₂dsi₂ ŋi₁tág₂ quió'₅ a₂jme₁jŋɨi'₃ 'ŋiog₅. Ia₁ lɨ́in₂ ma₂ca₂lón₂ jɨn₂ bá₄ i₂le₁jnɨ́₅ né'₃ 'má₃.  
\v 28 La₁ dsɨ₂juɨ₅ ca₂guió'₃ Pa₄ ca₂juá'₂: 
\p ―Tsá₃ lë₁jmag'₅₄ uɨg₅ 'ŋiag'₂, ia₁ la₂ bá₄ tio'₅₄ jnia'₅₄ ca₂le₃jág₃. 
\p  
\v 29 Jaun₂ ca₂mɨ₃ dsa₂ 'éi₂ si₂, jaun₂ ca₂'í₃ co₂chi'₅₄ dsi₂néi₂ të₃ gó'₅ jlein₂₃ ŋó₃ ca₂chi₃jné₃ ne₄ Pa₄ quian'₅₄ Silas.  
\v 30 Jaun₂ ca₂'uág'₂ të₂ca₁'né₄, jaun₂ ca₂ŋag₃: 
\p ―'Nia'₂ dsa₂, ¿'e₂ 'nió'₅ jmo₅₄ jniá₂ ia₁jaun₂ lión₂ jniá₂? 
\p  
\v 31 Jaun₂ ca₂juá'₂ 'éi₂: 
\p ―'Én₃ të₂le₃ quió'₅ Te₁gui'₅₄ Jesucristo, jaun₂ bá₄ tɨ́ng'₄, quiang'₅₄ ca₂le₃jɨ́n₃ dsa₂ dsi₂néi₂ quiáng'₂. 
\p  
\v 32 Jaun₂ ca₂cuë₃ Pa₄ quian'₅₄ Silas jág₁ dse₃ quió'₅ Te₁gui'₅₄ ca₂cuë́'₃ dsa₂ 'éi₂ quian'₅₄ ca₂le₃jɨ́n₃ dsa₂ i₂tián'₅ dsi₂néi₂ quió'₅.  
\v 33 Hora jaun₂ a₂'uë₂, dsa₂ i₂niog₅ gu₂ 'né₅ 'má₃ 'éi₂ qui₂ca₂rɨ́n'₃ ja₁qui₂le₁cuɨ́'₃ quió'₅ Pa₄ quiain'₅₄ Silas. Jaun₂ 'éi₂ quiain'₅₄ ca₂le₃jɨ́n₃ dsa₂ dsi₂néi₂ quió'₅, ca₂jŋói₂ jmɨg₂.  
\v 34 Jme₁co₂lág₂ jaun₂, ca₂tág₃ ja₁quió'₄, ca₂i₁cuë₂ a₂guë́'₃. Jaun₂ 'io'₂ jmo₂₃ ca₂le₃jɨ́in₃, ia₁ ca₂rë₃'éin₂ jág₁ quió'₅ Diú₄. 
\p  
\v 35 Jme₁jnia₃ jaun₂, ca₂chen₃ juë́₄ chi'₂ 'ɨ'₅₄ a₂ca₂i₁chi'₄ dsa₂ i₂niog₅ gu₂ 'né₅ 'má₃, a₂lióin₂ dsa₂ 'éi₂.  
\v 36 Jaun₂ ca₂juá'₂ dsa₂ i₂niog₅ gu₂ 'né₅ 'má₃ ca₂tsɨ́'₃ Pa₄: 
\p ―Ma₂ŋɨg₂ 'éi'₃ quió'₅ juë́₄ a₂long₅₄ 'nia'₂. Jaun₂ ma₂lé₂ o₁no'₄ 'nia'₂ tei₄ quiáng'₂. 
\p  
\v 37 Jaun₂ ca₂juá'₂ Pa₄ ca₂tsɨ́'₃ chi'₂ 'ɨ'₅₄: 
\p ―Ca₂chóng'₂ dsa₂ jnia'₅₄, qui₂ca₂bóg₂ të₃jɨn₄ dsa₂ juɨn₅ të₃ tsá₃ ca₂cáun₃ de'₂ jág₁ dsau₅ quián₂ jnia'₅₄ i₂lág₅ dsa₂ tén₅ juɨg₂ Roma. Jaun₂ guë́₄ ca₂to'₂ né'₃ 'má₃. ¿Në₃ në́₃ 'nio₃ lió₂ jnia'₅₄ con'₂ të₃co'₅₄? Tsá₃ le₂jaun₂. Juɨ₁ja₂léin₂ guioin₅₄ juɨ₁ja₂'uag'₅₄, juɨ₁lia'₂ ca₂to'₂. 
\p  
\v 38 Jaun₂ guë́₄ ca₂i₁con₂ chi'₂ 'ɨ'₅₄ jág₁ jaun₂ ne₄ juë́₄, jaun₂ ca₂rë₃gó'₅ jme₁ca₂rë₃ŋi₅ a₂lɨ́n₅ Pa₄ quian'₅₄ Silas dsa₂ tén₅ Roma.  
\v 39 Jaun₂ ca₂i₁len₅₄ dsɨ₂tan₅₄ ca₂i₁mɨ₂ o₂'én₂ dso₄ ne₄ Pa₄ quian'₅₄ Silas. Ca₂'uág'₂ bá₄ jaun₂ në́₃, jaun₂ ca₂juá'₂ a₂'uɨ́n₃ 'éi₂ juɨg₂ jaun₂.  
\v 40 Jme₁ma₂'uɨn₂ 'éi₂ 'né₅ 'má₃, ca₂i₃lein₃ ja₁quió'₄ 'io₅₄ Lidia. Jme₁ca₂ŋɨi'₂ quiain'₅₄ rɨin'₅₄, qui₂ca₂cuë₃ bí₂ në́₃, jaun₂ guë́₄ ca₂'uɨin₂ ja₁jaun₂, ca₂i₁lein₅₄ guë́₄ juɨg₂ siá'₂. 
\c 17  
\s1 Ca₂lë₃ mɨ'₅₄ juɨg₂ Tesalónica 
\p  
\v 1 Juɨ₅ ja₁ca₂ŋe₄ Pa₄ quiain'₅₄ Silas jaun₂, ca₂i₁ŋɨi₁₂ juɨg₂ Anfípolis quian'₅₄ juɨg₂ Apolonia në́₃. Jaun₂ ca₂dsi₃léin₂ juɨg₂ chei₂ Tesalónica. Ja₁jaun₂ jme₁chí'₄ guá'₅ sinagoga quió'₅ dsa₂ judíos.  
\v 2 Pa₄ në́₃, ia₁ le₂jaun₂ tɨn₂ quió'₅, ca₂ŋei₅₄ guá'₅. Të₁lia'₂ ca₂'í₃ tɨn₃-'nɨ₅ semana ja₁jaun₂, qui₂ca₂dsia₃ jág₁ quian'₅₄ dsa₂ ca₂le₃jë́₃ jmɨg₄ sa₅₄, juɨ₁lia'₂ jág₁ a₂juá'₂ ne₄ Si₂.  
\v 3 Qui₂ca₂cuë₃ jág₁ dsau₅ 'a₂ lia'₂ dsón'₂ 'i₄ 'éi'₃ ne₄ Si₂ quió'₅ Diú₄ a₂juá'₂ a₂tion₅₄ ŋág₃ uɨg₅ I₂rë₂'ɨ́n₁ quián₅ Diú₄, jaun₂ cang₂ jë₁ma₂join₂₃, a₂tion₅₄ niog₅ jein'₅₄ táng₃. Jaun₂ caun₂ ca₂juá'₂ bá₄: 
\p ―Jesús i₂'ɨ́n₅ jniá₂, jág₁ a₂'ë́₅ juɨ́g₂ 'nia'₂, I₂rë₂'ɨ́n₁ quián₅ Diú₄ bá₄ 'éi₂. 
\p  
\v 4 Jaun₂ ca₂rë₃'én₂ i₂lɨn₅₄ dsa₂ judíos, ca₂jme₃quiain'₅₄ Pa₄ quian'₅₄ Silas. Ján₃ bá₄ ca₂rë₃'én₂ juɨn₅ dsa₂ griegos i₂jme₁jme₂juɨn'₂ Diú₄, ca₂rë₃'én₂ juɨn₅ 'io₅₄ dsen₅₄ në́₃.  
\v 5 La₁ dsa₂ judíos i₂tsá₃ 'én₂ në́₃, ca₂rë₃'néi₃ a₂dsí'₅. Jaun₂ ca₂jme₃quiain'₅₄ co₂nió'₃ dsa₂ juɨ́'₅ i₂lë₁jme₁i₂nio₄ tsɨ₁jɨn₁ jë₄ calle. Ca₂quɨin'₃ jág₁ quió'₅, ca₂i₁nioi₁₂ ca₂tó'₂ mɨ'₅₄, tsɨ₂jɨin₂₃ dsa₂ juɨg₂. Jaun₂ ca₂i₁toin'₁ tion₅₄-jan₃ ja₁quió'₄ Jasón, a₂jme₁'nio₃ dsein₂₃ Pa₄ quiain'₅₄ Silas, a₂jme₁të₂ 'éi₂ jɨn₄ dsa₂ juɨg₂.  
\v 6 Ia₁ tsá₃ ca₂dsáin'₂ 'éi₂ ja₁jaun₂, Jasón bá₄ qui₂ca₂tsɨ₃cuɨin'₂ quiain'₅₄ guë́₄ rɨin'₅₄ i₂'én₂, jaun₂ ca₂tág₃ juɨ₅ ne₄ta₁, ca₂i₁jang'₂ ne₄ dsɨ₂tan₅₄, jaun₂ ca₂juá'₂ ca₂lia'₂ guió'₅ tioin'₅₄: 
\p ―I₂la₂ bá₄ dsa₂ i₂ŋɨ́₄ lë₃ ma₂jmo₃ tsá₃ ma₃caun₂ 'ei₅ jág₁, qui₂ma₂jéin'₂ dsa₂ ta₁caun₂ mɨ₂güɨ́g₃. Le₂jaun₂ bá₄ 'nio₃ jmo₃ ja₁lá₃ ján₃, ta₁ jaun₂ bá₄ ja₂léin₂.  
\v 7 Jasón la₂ në₂cuë₃ jmɨg₄ në₂jŋia₃ dsa₂ 'éi₂ ja₁quió'₄. Ca₂le₃jɨ́n₃ 'éi₂ jmo₂₃ a₂tsá₃ dsi₂ten₅₄ jmo₃ lia'₂ con'₂ lë́₅ 'éi'₃ quió'₅ gui'₅₄ emperador. Ia₁ i₂nioi₅₄ tsɨ́'₅ dsa₂ a₂chan₂ guë́₄ jan₂ rag₅₄ sián'₂, jan₂ i₂chen₂ Jesús. 
\p  
\v 8 Jme₁ca₂nág₂ dsa₂ le₂në₅, ca₂tóin'₂ go₂'i₃ quian'₅₄ dsɨ₂tan₅₄.  
\v 9 La₁ Jasón quian'₅₄ rɨin'₅₄ ca₂quí₃ cu₄ ne₄ dsɨ₂tan₅₄, jaun₂ guë́₄ ca₂lió₂ dsa₂. 
\s1 Pablo quian'₅₄ Silas tioin'₅₄ juɨg₂ Berea 
\p  
\v 10 Dsɨ₂juɨ₅ le₂jaun₂ ca₂jmo₃ rɨin'₅₄ a₂ŋó₃ Pa₄ quiain'₅₄ Silas të₃ a₂'uë₂ juɨ₅ Berea. Jme₁ca₂dsi₃léin₂ ja₁jaun₂, i₁lein₅₄ dsɨ₂juɨ₅ dsi₂néi₂ guá'₅ sinagoga quió'₅ dsa₂ judíos.  
\v 11 Dsa₂ judíos i₂jme₁tián'₄ ja₁jaun₂ jme₁dsein₃ con'₂ guë́₄ dsa₂ juɨg₂ Tesalónica. Lia'₂ 'i₄ rë₂ jág₁ bá₄ ca₂gue₃ jág₁ dse₃ quió'₅ Diú₄. Jaun₂ ca₂le₃jë́₃ jmɨg₄ bá₄ jme₁'no'₂ ne₄ Si₂ quió'₅ Diú₄, ia₁ 'nio₃ le₃ŋi₅ chi₂jua'₂ dsón'₂ bá₄ le₂jaun₂ lë́₅ jág₁ a₂cuë₅ Pa₄ quian'₅₄ Silas.  
\v 12 Juɨn₅ bá₄ dsa₂ judíos 'éi₂ ca₂rë₃'én₂. Ján₃ bá₄ le₂jaun₂ juɨn₅ dsa₂ griegos, lia'₂ dsa₂ ŋe'₂ lia'₂ 'io₅₄ dsen₅₄ në́₃.  
\v 13 La₁ jme₁ca₂rë₃ŋi₅ dsa₂ chan₂ Tesalónica a₂'en₅₄ Pa₄ 'ë́'₅ dsa₂ jág₁ dse₃ quió'₅ Diú₄ juɨg₂ Berea ján₃, jaun₂ ca₂i₃léin₂ ja₁jaun₂, ca₂chi₂ca₂jain₃ dsa₂.  
\v 14 La₁ co₂tan₅₄ ca₂chei₃ rɨin'₅₄ ca₂chein₃ Pa₄ chei'₅₄ jmɨ₁ŋí'₄. Ca₂jŋia₃ bá₄ Silas quian'₅₄ Timoteo juɨg₂ Berea.  
\v 15 Ca₂i₁jiog₃ dsa₂ i₂jme₁quian'₅₄ Pa₄ ca₂i₁jŋiai₃ 'éi₂ ca₂të₂ juɨg₂ Atenas. Jaun₂ ca₂i₃lein₃ táng₃ le₁quion₂ jág₁ quió'₅ Pa₄ a₂jiá₃ Silas quiain'₅₄ Timoteo a₂dsɨ₃jme₃quiong'₅₄ dsɨ₂juɨ₅. 
\s1 'En₅₄ Pablo juɨg₂ Atenas 
\p  
\v 16 Të₁lia'₂ 'en₅₄ Pa₄ chi₁jŋiai₂₃ Silas quian'₅₄ Timoteo juɨg₂ Atenas, tsá₃ dse₃ 'ei₅ dsɨ́₅, ia₁ ca₂jɨ́in₂ juɨn₅ lɨn₃ diú₄ lag₄ tión₂ le₂tan₅₄ jë₄ juɨg₂.  
\v 17 Jaun₂ ca₂i₁'ë́₄ jág₁ dse₃ dsi₂néi₂ guá'₅ sinagoga, ca₂tsɨ́'₃ dsa₂ judíos, dsa₂ sián'₂ në́₃ i₂jme₂juɨn'₂ Diú₄ të₃dsón'₂. Ca₂le₃jë́₃ jmɨg₄ në́₃, qui₂ca₂'ë́₂ Pa₄ jág₁ dse₃ jë₄ 'ma'₅₄ ca₂tsɨ́'₃ ca₂le₃jɨ́n₃ dsa₂ i₂jme₁jein'₂ ja₁jaun₂.  
\v 18 I₂lɨn₅₄ dsa₂ i₂jme₁jme₂tag₅ si₂ quió'₅ dsa₂ i₂të́'₂ dsa₂ epicúreos, i₂lɨn₅₄ guë'₂ i₂jme₁jme₂tag₅ si₂ quió'₅ i₂të́'₂ dsa₂ estoicos, dsa₂ 'éi₂ ca₂jme₃lióg₃ ca₂dsia₃ jág₁ quiain'₅₄ Pa₄. I₂lɨn₅₄ guë'₂ dsia₅ tsɨ́'₅ rɨin'₅₄: 
\p ―Tsá₃ ne₄ 'e₂ bá₄ jág₁ quian₅ i₁ten'₅₄ në₅ a₂juá'₂ tság₃ jniog₄. 
\p I₂lɨn₅₄ guë'₂ juá'₂ táng₃: 
\p ―Mei'₂ tsá₃ i₂'ë́₂ jág₁ quió'₅ diú₄ sián'₂ i₂quián₅ dsɨ₂nau₂ bá₄ në₅. 
\p Jaun₂ bá₄ juá'₂ le₂jaun₂, ia₁ 'en₅₄ Pa₄ 'ë́₂ jág₁ dse₃ quió'₅ Jesús, 'a₂ lia'₂ ca₂jein'₅₄ táng₃.  
\v 19 Jaun₂ ca₂jŋiai₃ Pa₄ caun₂ ja₁chei₂ Areópago. Jme₁ca₂dsi₃léin₂ ja₁jaun₂, ca₂ŋɨ́i'₃ Pa₄ ca₂juá'₂: 
\p ―¿Lé₂ le₃ne₄ jnia'₅₄ 'e₂ jág₁ 'mɨ́₂ dsia'₂ a₂jme₂tág'₂?  
\v 20 'Niog₂ jnia'₅₄ le₃ne₄ 'e₂ jein₅ jág₁ a₁juá'₂ 'ne₂ në₅. Ja₂lɨn₃ guë́₄ siá'₂ né'₂. 
\p  
\v 21 Ia₁ ca₂le₃jɨ́n₃ bá₄ dsa₂ chan₂ Atenas, quian'₅₄ dsɨ₂nau₂ i₂jme₁tián'₄ ja₁jaun₂, jmá'₃ a₂jaun₂ bá₄ jme₁tɨin₂ qui₂jmo₂₃: qui₂nag₂₃, qui₂dsia₂₃ në́₃, jmá'₃ ca₂ne₅₄ jág₁ 'mɨ́₂ a₂cha₂. 
\p  
\v 22 Jaun₂ ca₂nau₂ Pa₄ dsi₂jo₂ ja₁le₁ŋɨ'₂ dsa₂ jaun₂, jaun₂ ca₂juá'₂: 
\p ―'Nia'₂ dsa₂ chan₂ Atenas, jág₅ jniá₂ 'ŋio₅ 'én'₂ 'nia'₂ të₂le₃ quió'₅ diú₄ lag₄ quián'₂ 'nia'₂.  
\v 23 Ia₁ lia'₂ con'₂ ca₂ŋɨ₅ jniá₂ ca₂jág₃ ja₁chi₁len'₄ 'nia'₂ diú₄ lag₄ quiáng'₂, ca₂jág₃ caun₂ ja₁lë́₄ ne₄chei₂ le₁ton₅ letras la₂, a₂juá'₂: “QUIÓ'₅ DIÚ₄ I₂TSÁ₃ CUƗN₅ DSA₂.” Ia₁ dse₃ bá₄ guë'₂ jaun₂. Diú₄ 'éi₂ i₂chi₁len'₄ 'nia'₂, Diú₄ i₂tsá₃ cuɨn'₂ 'nia'₂, i₂'éi₂ bá₄ 'ɨ́n₄ jniá₂, jág₁ quió'₅ 'éi₂ bá₄ 'ë́₅ jniá₂, juɨ́g₂ 'nia'₂. 
\p  
\v 24 ’Diú₄ 'éi₂ i₂ca₂jmo₃ mɨ₂güɨ́g₃, ca₂jmo₃ ca₂le₃jë́₃ 'e₂ a₂cha₂ ja₁jaun₂, 'éi₂ bá₄ quió'₅ guei'₅₄ mɨ₂güɨ́g₃ quian'₅₄ gua'₅₄ 'uë₃ në́₃. La₁ tsá₃ guá₅ dsi₂néi₂ guá'₅ a₂jmo₅ dsa₂ mɨ₂güɨ́g₃,  
\v 25 on₃ guë'₂ chi₁quiain₁₂ jmɨg₄ jua'₅₄ a₂'nió'₅ jmo₃ dsa₂ 'e₂ jmo₃ quió'₅. Ia₁ 'ŋiog₅ bá₄ Diú₄ jmo₂₃ cuë₂₃ jme₂dsí₂ quián₂ jniog₄, jmo₂₃ dsí₂ a₂quian₂ jniog₄, ca₂jmo₃ ca₂le₃jë́₃ guë́₄ 'e₂ a₂cha₂. 
\p  
\v 26 ’Quian'₅₄ ca₂cho'₅₄ dsa₂ bá₄ ca₂jmo₃ ca₂le₃jë́₃ juɨg₂, ia₁jaun₂ tiain'₃ ta₁caun₂ mɨ₂güɨ́g₃. Jaun₂ ca₂jmo₃ Diú₄ 'éi'₃ ca₂'ë₃ ja₁tian'₃ dsa₂ në́₃, 'a₂ con'₂ uë́₂ 'io₃ bí₂ le₂caun₂ le₂caun₂ juɨg₂,  
\v 27 ia₁jaun₂ 'nai'₂ Diú₄, a₂jŋia'₅₄ chi₂lá'₂ quian'₅₄ gu₂, con'₂ tsá₃ ŋó₅ në₁ca₂dsáu'₂, o₁jŋia'₅₄ la₂ tsá₃ uɨ́ng₂ guá₅ Diú₄ ja₁con₂ jniog₄ le₂jau₂ le₂jau₂.  
\v 28 Ia₁ a₂chan₂ Diú₄ bá₄ a₂chong₂ jniog₄ a₂i₂nio₄ jniog₄ në́₃.\f + \fr 17:28 \ft lit. “a₂chong₂, a₂i₂nio₄ jniog₄, a₂'i₄ jme₂dsí₂ jniog₄.” \f* Juɨ₁lia'₂ ma₂ca₂juá'₂ i₂lɨn₅₄ dsa₂ poetas quián'₂ 'nia'₂ ján₃, jme₁ca₂juá'₂: “Chi'₂-guein₂ quián₅ Diú₄ bá₄ lág₅ jniog₄.”  
\v 29 Chi₂jua'₂ lág₅ jniog₄ chi'₂-guein₂ quián₅ Diú₄, jaun₂ tsá₃ dse₃ jua'₅₄ a₂jmó₁ jniog₄ dsɨ₅ a₂lɨ́n₅ Diú₄ juɨ₁lia'₂ lë́₅ caun₂ nió'₄ dsa₂ lag₄ cu₄nióg₄, on₃ guë'₂ cu₄tiog₂, on₃ guë'₂ nɨ₁cang₁ a₂tɨn₂ dsa₂ jmo₂₃ con'₂ lë́₅ dsɨ₂jiog₅ dsɨ́₅ guioin₅₄.  
\v 30 Tsá₃ lɨn₄ ca₂tón'₃ Diú₄ juɨ₅ 'a₂ lia'₂ ca₂jmo₃ dsa₂ ma₂lɨ́g'₂, ia₁ tsá₃ 'e₂ ŋi₅ dsa₂. La₁ rë₂në́₃ në́₃, jmo₅ Diú₄ 'éi'₃ quió'₅ dsa₂ chan₂ ta₁caun₂ mɨ₂güɨ́g₃ a₂'nió'₅ dsɨ₃quén'₅ dsɨ́₅.  
\v 31 Ia₁ ma₂lë́₅ 'éi'₃ quió'₅ Diú₄ a₂já₅ caun₂ jmɨg₄ jë₁qui₃dsɨ₂₃ 'éi'₃ rë₂ con'₂ dsi₂ten₅₄ quió'₅ dsa₂ mɨ₂güɨ́g₃, të₂le₃ quian'₅₄ jan₂ dsa₂ i₂ca₂quióin'₂ quiáin₅. Jaun₂ ma₂ca₂jmo₃ léi₄ lia'₂ con'₂ jme₁ca₂jme₃jein'₅₄ 'éi₂ jɨn₄ 'lag₄. 
\p  
\v 32 Jme₁ca₂nág₂ dsa₂ ca₂juá'₂ Pa₄ a₂jen'₅₄ 'lag₄, i₂lɨn₅₄ dsa₂ jŋia'₅₄ ca₂ŋág₂ bá₄. I₂lɨn₅₄ guë'₂ ca₂juá'₂: 
\p ―Në₅ néi₁ táng₃ jnia'₅₄ caun₂ jmɨg₄ siá'₂ quiáng'₂. 
\p  
\v 33 Jaun₂ ca₂o₂'ɨ́n₃ bá₄ Pa₄ jë₄ jaun₂. 
\p  
\v 34 La₁ i₂lɨn₅₄ dsa₂ ca₂rë₃'éin₂ bá₄, jaun₂ ca₂'ein₃ 'éi₂. Jë₄ jaun₂ jme₁'en₅₄ i₂chen₂ Dionisio i₂lɨ́n₅ rɨn'₅₄ dsɨ₂tan₅₄ quián₅ Areópago; jan₂ guë'₂ 'io₅₄ në́₃ i₂chen₂ Dámaris; lë́₂ bá₄ guë́₄ dsa₂ i₂quiong'₅₄. 
\c 18  
\s1 'En₅₄ Pablo juɨg₂ Corinto 
\p  
\v 1 Cang₂ jaun₂ ca₂o₃'ɨ́n₃ Pa₄ juɨg₂ Atenas, ca₂ŋó₃ juɨ₅ Corinto.  
\v 2 Ja₁jaun₂ ca₂jein'₂ jan₂ dsa₂ judío i₂chen₂ Aquila i₂chan₂ 'uë₃ Ponto. Jme₁guá₄ 'uë₃ Italia le₃jŋiá₅, la₁ ca₂jmo₃ 'éi'₃ gui'₅₄ emperador Claudio a₂ca₂'uɨ́in'₂ ca₂le₃jɨ́n₃ dsa₂ judíos i₂jme₁tián'₄ juɨg₂ Roma. 'Uɨg₅₄ jaun₂ ca₂o₃'ɨ́in₃ quiain'₅₄ Priscila 'io₅₄ quiáin₅, a₂ma₂tiáin'₅ juɨg₂ Corinto. Jme₁ca₂dsióg₃ Pa₄ ca₂i₁jɨin₁₂ dsa₂ 'éi₂,  
\v 3 jaun₂ ca₂'í₃ ja₁quió'₄, ca₂jmo₃ ta₁ co₂lë₅ quiong'₅₄, ia₁ ján₃ bá₄ tɨin₂ 'me₃ tsɨ₁'mɨ'₂ a₂jmo₅ dsa₂ tsɨ₁'né₅.  
\v 4 Jaun₂ ca₂le₃jë́₃ jmɨg₄ sa₅₄, jme₁dsó₅ Pa₄ guá'₅ sinagoga a₂jme₂tɨin₂₃ dsa₂ jág₁ dse₃, a₂jme₁jme₂'uáin₂ dsɨ́₅ dsa₂, lia'₂ dsa₂ judíos lia'₂ dsɨ₂nau₂ në́₃.  
\v 5 Jme₁dsióg₃ Timoteo quiain'₅₄ Silas a₂ca₂'uɨin₂ Macedonia, a₂dsi₃léin₂ të₂ ja₁'en₅₄ Pa₄, jaun₂ guë́₄ ca₂'ë́₂ Pa₄ dsen₅₄ dsɨ́₅ jág₁ quió'₅ Diú₄. Jaun₂ guë́₄ ca₂tsɨ́'₃ dsa₂ judíos a₂lɨ́n₅ Jesús dsa₂ I₂rë₂'ɨ́n₁ quián₅ Diú₄.  
\v 6 La₁ dsa₂ në́₃, 'io'₅₄ ca₂tɨ́in₂ jág₁ jaun₂, jaun₂ ca₂jme₃lióg₃ qui₂ca₂jnái'₂ jág₁ uɨg₅ Pa₄. 'Éi₂ në́₃ qui₂ca₂séi'₂ 'liog₂ nɨ₁tsɨn'₅₄, jaun₂ ca₂tsɨ́'₃ dsa₂: 
\p ―Guion'₅₄ bá₄ 'nia'₂ le₁cáng'₄ a₂dsián'₃ 'nia'₂ lia'₂ jma₃quian'₅₄ dsáu'₂. Tsá₃ ma₃'e₂ le₁cán'₄ jniá₂. Le₃ne₄ juɨ₅ në́₃ nei₅₄ ja₁con₂ dsɨ₂nau₂. 
\p  
\v 7 Ca₂o₃'ɨ́n₃ bá₄ Pa₄ dsi₂néi₂ guá'₅ sinagoga jaun₂ në́₃. Ca₂ŋó₃ ja₁quió'₄ jan₂ dsa₂ i₂chen₂ Justo i₂jme₁jme₂juɨn'₂ Diú₄. Justo 'éi₂ në́₃, jme₁guá₄ cau₅ guá'₅.  
\v 8 Dsa₂ i₂jme₁lɨ́n₄ dsa₂ dsen₅₄ quián₅ guá'₅, dsa₂ i₂chen₂ Crispo, ca₂rë₃'éin₂ të₂le₃ quió'₅ Te₁gui'₅₄, co₂dsia₅ quian'₅₄ dsa₂ dsi₂néi₂ quió'₅. Juɨn₅ bá₄ dsa₂ chan₂ Corinto ca₂rë₃'én₂ jág₁ dse₃ jme₁ca₂nág₂, jaun₂ qui₂ca₂choin₃ jmɨg₂.  
\v 9 Caun₂ a₂'uë₂, a₂lë₁ca₂jén'₃ Pa₄ ca₂jɨ́in₂ Te₁gui'₅₄, a₂juá'₂: 
\p ―Tsá₃ lë₁jmo₂ gang'₃ a₂'ë́'₄ jág₁. Caun₂ dsia₄ bá₄, tsá₃ lë₁jmo₂ tei₄.  
\v 10 Ia₁ quian'₅₄ bá₄ jniá₂ 'ne₂; 'i₁jan₂ tsá₃ téi₂ gu₂ jua'₅₄ a₂jmóg'₂ uɨg₅. Ia₁ juɨn₅ dsa₂ chan₂ juɨg₂ la₂ i₂le₃'én₂ quiáng₃. 
\p  
\v 11 Caun₂ ŋi₂ të₂ ca₂'nau₅₄ ca₂'í₃ Pa₄ juɨg₂ Corinto, qui₂ca₂jme₃tɨin₂₃ dsa₂ jág₁ quió'₅ Diú₄. 
\p  
\v 12 La₁ jmɨg₄ jaun₂ ca₂lɨn₃ dsi₄má'₂ 'uë₃ Acaya jan₂ dsa₂ i₂chen₂ Galión. Jaun₂ ca₂ŋɨ'₂ dsa₂ judíos i₂'ŋia₅₄ Pa₄, ca₂tág₃ juɨ₅ ne₄ta₁.  
\v 13 Jaun₂ ca₂juá'₂ ca₂tsɨ́'₃ dsi₄má'₂ 'éi₂: 
\p ―Le₂siá'₂ bá₄ jme₂tag₅ i₂në₅, toin'₂ jág₁ dsa₂, a₂jme₃juɨin'₂ Diú₄ on₃jua'₅₄ lia'₂ con'₂ lë́₅ 'Éi'₃. 
\p  
\v 14 Jë₁jme₁ma₂ŋag₃ Pa₄, jme₁ca₂juá'₂ Dsi₄má'₂ Galión ca₂tsɨ́'₃ dsa₂ judíos: 
\p ―Jua'₅₄ mei'₂ guë́₃ dso₄ juë'₂ ca₂rë₃cán'₂ dsa₂ në₅, jme₁jmo₅₄ bá₄ jniá₂ juɨn'₂ dsɨ₃ a₂jme₁nag₅₄ jág₁ quián'₂ 'nia'₂.  
\v 15 La₁ tsá₃ le₂jaun₂. Chi₂jua'₂ 'uɨg₅₄ jág₁ 'éi'₃ juá'₅ siá'₂ quián'₂ 'nia'₂ guiong'₅₄, tsá₃ 'éi'₃ qui₁dsɨ₅ jniá₂. Jme₁rë₂ bá₄ 'nia'₂ guiong'₅₄ quiáng'₂. 
\p  
\v 16 Jaun₂ ca₂'uág'₂ ca₂'uɨ́in'₂ 'éi₂ ne₄ta₁ jaun₂.  
\v 17 Jaun₂ ca₂jŋau'₃ ca₂le₃jɨ́n₃ dsa₂ griegos ca₂jŋai'₃ Sóstenes i₂lɨ́n₅ juɨg₅₄ quián₅ guá'₅ sinagoga, qui₂ca₂bóg₂ të₃ jág₅ dsi₄má'₂. La₁ tsá₃ ma₃a₂jaun₂ dsan₂ dsɨ́₅ gui'₅₄ Galión, 'i₁caun₂. 
\s1 Ca₂jón'₃ táng₃ Pablo juɨg₂ Antioquía, jaun₂ ca₂ŋó₃ táng₃ ca₂i₁'ë́₄ jág₁ dse₃ jë₁ca₂të́₂ 'nag'₂ ráun₂ 
\p  
\v 18 Uë́₂ bá₄ guë́₄ ca₂jŋia₃ Pa₄ jë₄ juɨg₂ Corinto. Cang₂ guë́₄ jaun₂ ca₂'ág'₃ jág₁ rɨin'₅₄. Jme₁ma₂tioin'₅₄ juɨg₂ Cencrea në́₃, ca₂chéi₃ Pa₄ dsi₅₄ ca₂jmo₃ léi₄ a₂ca₂jme₃ti₃ jág₁ a₂ma₂cuë́'₃ Diú₄ le₂jŋiá₅. Jaun₂ ca₂'í₃ nɨ₁barco ca₂ŋó₃ juɨ₅ ja₁tén₄ Siria quiain'₅₄ Priscila, Aquila në́₃.  
\v 19 Jme₁ca₂dsi₃léin₂ juɨg₂ Efeso, ca₂tén₂ Pa₄ Priscila quian'₅₄ Aquila, ca₂ŋó₃ juɨ₅ guá'₅ sinagoga ca₂i₁dsia₂ jág₁ quian'₅₄ dsa₂ judíos i₂jme₁tion'₅₄ le₁ŋɨ'₂.  
\v 20 Jme₁ca₂juá'₂ guë́₄ dsa₂ ja₁jaun₂ a₂jme₁jŋia₃ guë́₄ uë́₂ Pa₄, la₁ tsá₃ ma₃ca₂gue₃ 'éi₂.  
\v 21 Jaun₂ ca₂'ág'₃ jág₁ jɨn₄ rɨin'₅₄, ca₂juá'₂: 
\p ―Tion₅₄ niog₅ nég'₄ Jerusalén i₁jmo₃ jmɨg₄ a₂já₅. La₁ guáng₂ bá₄ táng₃ i₁jɨng₁₂ 'nia'₂ në₁jua'₂ 'nio₃ Diú₄. 
\p Jaun₂ ca₂'í₃ nɨ₁barco ca₂o₃'ɨ́in₃ juɨg₂ Efeso.  
\v 22 Jme₁ca₂dsióg₃ Cesarea, ca₂ŋe₄ Pa₄ i₁cuɨin₃ Diú₄ rɨin'₅₄ i₂tián'₅ Jerusalén. Jaun₂ ca₂ŋái'₃ táng₃ juɨ₅ Antioquía.  
\v 23 Jme₁ma₂ne₁ŋó₄ jmɨg₄ 'ein₅₄ ja₁jaun₂, ca₂ŋei₅₄ táng₃ ca₂i₁ŋɨ₂ le₂caun₂ le₂caun₂ juɨg₂ ja₁tén₄ 'uë₃ Galacia quian'₅₄ Frigia, qui₂ca₂cuë́'₃ bí₂ ca₂le₃jɨ́n₃ dsa₂ i₂'én₂ rɨin'₅₄. 
\s1 Ca₂'ë́₂ Apolos jág₁ dse₃ juɨg₂ Efeso 
\p  
\v 24 Jmɨg₄ jaun₂ ca₂dsióg₃ Efeso jan₂ dsa₂ judío i₂chen₂ Apolos, dsa₂ chan₂ juɨg₂ Alejandría. 'Ŋio₅ lɨn₃ jme₁tɨn₂ dsa₂ 'éi₂ 'ë́₂ jág₁ quió'₅ Diú₄, dse₃ jme₁cuɨ́'₅ Si₂ quió'₅ Diú₄.  
\v 25 Jme₁ma₂ŋi₅ Apolos 'éi₂ 'a₂ lia'₂ lë́₅ juɨ₅ quió'₅ Te₁gui'₅₄. Jaun₂ 'ŋio₂ dsɨ́₅ qui₂ca₂dsia₃ jág₁ qui₂ca₂jme₂tɨin₂₃ dsa₂ co₂rë₂ jág₁ quió'₅ Jesús, ton'₂ jmá'₃ jŋia'₅₄ a₂jaun₂ bá₄ jme₁ŋi₅ Apolos 'a₂ lia'₂ jme₁jme₂tag₅ Juan₅₄ juɨ₁lia'₂ a₂choin₂₃ dsa₂ jmɨg₂.  
\v 26 Ca₂jme₃lióg₃ Apolos ca₂juá'₂ dsi₂néi₂ guá'₅ sinagoga ca₂tsɨ́'₃ dsa₂, ca₂dsia₃ tiá₂ dsɨ́₅; la₁ jme₁ca₂nág₂ Priscila quian'₅₄ Aquila, ca₂të́'₃ Apolos cau₅, ca₂jme₃tag₂₃ guë́₄ rë₂ 'a₂ lia'₂ lë́₅ juɨ₅ quió'₅ Diú₄.  
\v 27 Jaun₂ në́₃, lia'₂ con'₂ jme₁'nio₃ Apolos jme₁ŋɨ́i₃ juɨ₅ Acaya, ca₂cuë₃ rɨin'₅₄ bí₂, ca₂chein₃ si₂ carta ne₄ dsa₂ 'én₂ i₂tián'₅ ja₁jaun₂, a₂guein₃ 'éi₂. Jme₁ca₂dsióg₃ Apolos 'uë₃ Acaya, ca₂jme₃'oin₅₄ 'ŋio₅ dsa₂ 'én₂ i₂tián'₅ ja₁jaun₂. Ia₁ a₂dse₃ dsɨ́₅ Diú₄ ca₂jmo₃ a₂ca₂rë₃'én₂ dsa₂ 'éi₂.  
\v 28 Jaun₂ qui₂ca₂tsɨ́in₂ quian'₅₄ dsa₂ judíos, jaun₂ ca₂lɨ́'₃ bá₄ Apolos ne₄ ja₁tsɨin₂₃ jaun₂, të₃ jág₅ ca₂le₃jɨ́n₃ dsa₂. Ia₁ lia'₂ con'₂ lë́₅ Si₂ quió'₅ Diú₄ bá₄ ca₂'ë́'₃ dsa₂ 'éi₂, a₂dsón'₂ bá₄ lɨ́n₅ Jesús I₂rë₂'ɨ́n₁ quián₅ Diú₄. 
\c 19  
\s1 'En₅₄ Pablo juɨg₂ Efeso 
\p  
\v 1 Të₁lia'₂ 'en₅₄ Apolos juɨg₂ Corinto, Pa₄ guë'₂ ca₂ŋɨ́i₃ le₂tan₅₄ juɨ₅ má'₂ a₂ca₂dsióg₃ Efeso. Ja₁jaun₂ ca₂jein'₂ i₂lɨn₅₄ dsa₂ 'én₂.  
\v 2 Jaun₂ ca₂ŋag₃ 'éi₂ ca₂ŋɨ́i'₃ dsa₂ ca₂juá'₂: 
\p ―¿Ca₂guen'₅₄ 'nia'₂ Jme₂dsí₂ Jŋió₅ lia'₂ con'₂ jme₁ca₂rë₃'én'₂ 'nia'₂ jág₁ dse₃? 
\p Jaun₂ ca₂ŋag₃ dsa₂: 
\p ―Ca₂lia'₂ jŋia'₅₄ tsá₃ ma₂ne₄ jnia'₅₄ jua'₅₄ chan₂ jan₂ Jme₂dsí₂ Jŋió₅. 
\p  
\v 3 Jaun₂ ca₂ŋag₃ táng₃ Pa₄: 
\p ―¿'A₂ guë'₂ lia'₂ ca₂jŋó'₂ 'nia'₂ jmɨg₂? 
\p Ca₂ŋag₃ táng₃ dsa₂: 
\p ―Juɨ₁lia'₂ ca₂jme₃tag₅ Juan₅₄ bá₄. 
\p  
\v 4 Ca₂juá'₂ Pa₄: 
\p ―Jme₁chon₅ Juan₅₄ jmɨg₂ dsa₂ co₂'nió'₄ léi₄ a₂jme₃tsɨ́n₃ dsa₂ dsɨ́₅. La₁ jme₁juá'₂ ján₃, a₂'nió'₅ le₃'én₂ dsa₂ le₃quió'₅ i₂jiá₃ chi₁quɨ́n₃, a₂'ɨin₂₃ Jesucristo. 
\p  
\v 5 Jme₁ma₂në₂néi₂ dsa₂ le₂në₅, qui₂ca₂choin₃ jmɨg₂ lia'₂ con'₂ lë́₅ 'éi'₃ quió'₅ Te₁gui'₅₄ Jesús.  
\v 6 Jaun₂ jme₁ca₂quiog₂ Pa₄ gu₂ ne₄ quió'₅ dsa₂ 'éi₂, dsɨ₂juɨ₅ le₂jaun₂ ca₂guan₃ Jme₂dsí₂ Jŋió₅ ca₂'í₃ të₂dsɨ́₅ dsa₂. Jaun₂ qui₂ca₂dsia₃ dsa₂ jág₁ jmei₅ siá'₂, qui₂ca₂juá'₂ jág₁ a₂ca₂cuë₃ Diú₄ në́₃.  
\v 7 Con'₂ guia₃-tɨ́n₂ dsa₂ jme₁lë́₂ le₃jɨ́in₃. 
\p  
\v 8 Con'₂ 'nɨ₅ tsɨ'₂ ca₂dsɨn₃ a₂jme₁dsó₅ Pa₄ guá'₅ sinagoga ca₂dsia₃ tiá₂ dsɨ́₅ ca₂jme₃tɨin₂₃ dsa₂ qui₂co₂jéin'₂ dsa₂ të₂le₃ ja₁gon₂ Diú₄.  
\v 9 La₁ i₂lɨn₅₄ dsa₂ ca₂jmo₃ 'ua'₂ dsɨ́₅, tsá₃ ca₂rë₃'éin₂. Jŋia'₅₄ qui₂ca₂ton₃ 'lɨg'₅₄ bá₄ Juɨ₅ quió'₅ Te₁gui'₅₄ jɨn₄ dsa₂. Jaun₂ ca₂të́'₃ Pa₄ co₂nió'₃ jmá'₃ dsa₂ i₂'én₂ ca₂'uɨin₂ ja₁jaun₂ ca₂i₃léin₂ caun₂ escuela ja₁të́'₂ quió'₅ Tirano ja₁táun₂ dsa₂ jág₁. Ja₁jaun₂ ca₂i₁jme₁tɨin₂₃ dsa₂ ca₂le₃o₃ jmɨg₄.  
\v 10 Ca₂dsɨn₃ tɨn₃ ŋi₂ ca₂'í₃ ja₁jaun₂, jaun₂ le₃jɨ́n₃ dsa₂ i₂jme₁tián'₄ 'lióng₂ juɨg₂ ja₁tén₄ Asia ca₂nág₂ jág₁ quió'₅ Te₁gui'₅₄ Jesús lia'₂ dsa₂ judíos lia'₂ dsa₂ griegos në́₃.  
\v 11 Jaun₂ 'lióng₂ léi₄ juë'₂ ca₂jmo₃ Diú₄ të₂le₃ quian'₅₄ Pa₄,  
\v 12 le₂jiog₅ nɨ₁tsɨn'₅₄ dsa₂, o₃ pe₁guí₄ 'e₂ a₂qui₂ca₂nɨ́'₃ quió'₅, jme₁qui₂dsɨ₂con₃ dsa₂ ja₁con₂ dsa₂ dso'₅₄, qui₂ca₂'lón₂ dsa₂ 'e₂ caun₂ dso₄ niog₅ lɨ́in₅, qui₂ca₂'uɨn₂ jme₂dsí₂ 'lɨn'₅₄ quió'₅ dsa₂ në́₃. 
\p  
\v 13 La₁ i₂lɨn₅₄ dsa₂ judíos i₂jme₁i₂nio₄ jmo₂₃ 'uɨ́in'₂ jme₂dsí₂ 'lɨn'₅₄ quió'₅ dsa₂,\f + \fr 19:13 \ft griego: exorkiston (exorcistas).\f* dsa₂ 'éi₂ jme₁'nio₃ jme₁'ɨin₃ Te₁gui'₅₄ Jesús juɨ₁lia'₂ jë₁'uɨ́in'₂ jme₂dsí₂ 'lɨn'₅₄, ca₂juá'₂ tsɨ́'₅ jme₂dsí₂ 'lɨn'₅₄: 
\p ―'Éi'₃ jmo₅ jniá₂ quian'₅₄ bí₂ 'éi'₃ quió'₅ Jesús i₂'ɨn₅ Pa₄ në₅, 'uɨn'₂ 'nia'₂. 
\p  
\v 14 Le₂jaun₂ jme₁jmo₅ ta₁guion₃ chi'₂ ja₁ŋi'₅₄ jan₂ dsa₂ judío i₂chen₂ Esceva, i₂jme₁lɨ́n₄ jan₂ juɨg₅₄ jme₂dsa₂.  
\v 15 La₁ jme₁ca₂jmo₃ le₂jaun₂, jaun₂ ca₂ŋag₃ jme₂dsí₂ 'lɨn'₅₄: 
\p ―Cuɨ́n₅ bá₄ jniá₂ Jesús, ján₃ bá₄ guion₄ bá₄ jniá₂ 'ein₂ 'éi₂ Pa₄. La₁ 'nia'₂ në́₃, ¿'ein₂ bá₄ 'nia'₂ jmo'₂ 'éi'₃ a₂jú₄ jniá₂? 
\p  
\v 16 Jaun₂ dsa₂ i₂jme₁'en₅₄ jme₂dsí₂ 'lɨn'₅₄ quió'₅, ca₂cuë₃ 'ŋio₅ lɨn₃ ca₂cuë́'₃ ca₂le₃jɨ́n₃ dsa₂ 'éi₂, ca₂lia'₂ ca₂i₃lein₃ cuɨng₂₃ le₁cuáin'₃ qui₂le₁cuɨ́in'₂ në́₃.  
\v 17 Jaun₂ ca₂le₃jɨ́n₃ dsa₂ judíos, quian'₅₄ dsa₂ griegos në́₃, i₂jme₁tián'₄ juɨg₂ Efeso, ca₂rë₃gó'₅ 'ŋio₅ lɨn₃ jme₁ca₂rë₃ŋi₅. Jaun₂ ca₂rë₃juɨn'₂ Te₁gui'₅₄ Jesús 'ŋio₅ lɨn₃. 
\p  
\v 18 Jaun₂ juɨn₅ dsa₂ i₂ca₂rë₃'én₂, ca₂dsi₃léin₂ ca₂jmo₃ qui₂ŋí₃ quió'₅ ca₂le₃jë́₃ a₂'lɨg'₅₄ a₂qui₂ma₂jmo₃.  
\v 19 Jaun₂ juɨn₅ dsa₂ i₂jme₁jmo₅ ta₁ a₂chan₂ dsɨ́₅ në́₃, ca₂i₁quian₅₄ si₂ lia'₂ quió'₅, jaun₂ ca₂dsɨ́'₂ të₃ jág₅ dsa₂. Jme₁ca₂chen'₃ dsa₂ cuenta je₂liá'₂ dsɨn₅ 'i₄ 'ma'₅₄ le₃jë́₃ si₂ jaun₂, ca₂dsióg₃ con'₂ të₂láu₃-guiá₂ mei₅ 'éi'₃ cu₄ tiog₂.  
\v 20 Jaun₂ në́₃, quian'₅₄ bí₂ quió'₅ Te₁gui'₅₄ caun₂ ca₂i₃'ág₃ jág₁ quió'₅, caun₂ ca₂lɨ́'₃ bá₄. 
\p  
\v 21 Cang₂ jaun₂ ca₂'ág₂ Pa₄ caun₂ dsɨ́₅ a₂dsɨ₃jág₂ le₂tan₅₄ juɨg₂ ja₁tén₄ 'uë₃ Macedonia quian'₅₄ Acaya, lia'₂ ma₂ŋó₅ jaun₂ të₂ Jerusalén. Ján₃ bá₄ ca₂juá'₂ táng₃, jë₁ma₂ca₂dsióg₃ Jerusalén, a₂tion₅₄ dsó₃ ca₂të₂ Roma ján₃.  
\v 22 Jaun₂ ca₂chein₃ on₃ dsa₂ i₂jme₂'o₅₄\f + \fr 19:22 \ft griego: diákonous.\f* quiáin₅: Timoteo, quiain'₅₄ Erasto, a₂dsɨ₃léin₂ juɨ₅ Macedonia. Ca₂rë₃'ɨin₅₄ bá₄ guë́₄ 'ŋiog₅, 'uë₃ Asia. 
\s1 Ca₂nio₃ mɨ'₅₄ juɨg₂ Efeso 
\p  
\v 23 Jmɨg₄ jaun₂, 'ŋio₅ lɨn₃ ca₂nio₃ mɨ'₅₄ o₄quió'₄ Juɨ₅ quió'₅ Te₁gui'₅₄.  
\v 24 Ia₁ jan₂ dsa₂ i₂chen₂ Demetrio i₂jme₁lɨ́n₄ të₅ŋí₁ cu₄tiog₂, jme₁jmo₂₃ chéi₂ a₂rë₂lag₄ lia'₂ lë́₅ guá'₅ ja₁chén'₄ 'io₅₄ diú₄ Diana.\f + \fr 19:24 \ft griego: Artemis; (Diana chein₂ quian'₅₄ latín, jág₁ jmei₅ romano).\f* 'Ŋio₅ jme₁tɨin₂₃ cu₄ quian'₅₄ ta₁ jaun₂ quió'₅, quian'₅₄ të₅ŋí₁ rɨin'₅₄ i₂jmo₅ ta₁ le₂jaun₂.  
\v 25 Jaun₂ Demetrio në́₃, ca₂ŋɨ́i'₂ 'éi₂ quian'₅₄ guë́₄ dsa₂ sián'₂ i₂jmo₅ ta₁ le₂jaun₂ ján₃. Jaun₂ ca₂juá'₂: 
\p ―'Nia'₂ dsa₂ rɨn'₅₄ jniog₄, ŋi'₅₄ bá₄ 'nia'₂ rë₂, a₂chong₂ jniog₄ dse₃ quian'₅₄ ta₁ quián₂.  
\v 26 Jaun₂ jág'₂ bá₄ 'nia'₂ a₂jmo₅ Pa₄ ŋɨ₂₃ juá'₂ tsɨ́'₅ dsa₂, a₂tsá₃ 'e₂ quen₅ diú₄ i₂jmó'₂ dsa₂ mɨ₂güɨ́g₃, ia₁ tsá₃ lɨ́in₅ diú₄, juá'₂. Jaun₂ juɨn₅ dsa₂ i₂ma₂ca₂rë₃'én₂ në́₃, on₃jua'₅₄ jmá'₃ juɨg₂ Efeso la₂, mei'₂ tsá₃ le₂tan₅₄ 'uë₃ Asia bá₄.  
\v 27 Jaun₂ go'₂ të₂le₃ quián₂ jniog₄, ia₁ dsɨ₃'én₂ ta₁ quián₂ lé₂. Ján₃ guë'₂ le₂jaun₂, të₂le₃ quió'₅ guá'₅ quió'₅ diú₄ Diana juɨn'₂, go'₂ a₂dsɨ₃'én₂ ján₃. Ia₁ në₁jua'₂ tsá₃ ma₂'nio₃ dsa₂, jaun₂ dsɨ₃'én₂ bá₄ bí₂ quió'₅ a₂lɨ́in₅ dsa₂ juɨn'₂. Ia₁ rë₂në́₃ ta₁caun₂ 'uë₃ Asia, ta₁caun₂ mɨ₂güɨ́g₃ në́₃ jme₂go₃ dsa₂ a₂jme₂juag'₂. 
\p  
\v 28 Jme₁ca₂dsan₃ nag₅ dsa₂ le₂në₅, ca₂rë₃'néi₃ 'ŋio₅ lɨn₃, ca₂tóin'₂ ca₂guió'₃ ca₂juá'₂: 
\p ―¡'Ŋio₅ juɨn'₂ diú₄ Diana quián₅ dsa₂ juɨg₂ Efeso! 
\p  
\v 29 Jaun₂ ca₂lë₃ mɨ'₅₄ quió'₅ ca₂le₃jɨ́n₃ dsa₂ juɨg₂ jaun₂. Jaun₂ le₃on₃ dsa₂ chan₂ Macedonia i₂chen₂ Gayo quiain'₅₄ Aristarco i₂jme₁quian'₅₄ Pa₄, ca₂jŋau'₃ ca₂i₃toin'₅₄ co₂dsia₅ ca₂të₂ ja₁ŋɨ'₂ \f + \fr 19:29 \ft griego: theatron (co₂'nió'₄ caun₂ estadio a₂lë́₅ dso'₂ dsɨ₂con'₂).\f* dsa₂ juɨg₂.  
\v 30 Jaun₂ jme₁'nio₃ Pa₄ jme₁dsó₃ jɨn₄ dsa₂ juɨg₂ a₂jme₁dsɨ₃chi'₅₄ dsa₂. La₁ tsá₃ ca₂cuë₃ jmɨg₄ rɨin'₅₄ i₂'én₂.  
\v 31 I₂lɨn₅₄ dsa₂ dsen₅₄ quián₅ 'uë₃ Asia, i₂lɨ́n₅ dsa₂ a₂mei₅₄ quián₅ Pa₄, ján₃ bá₄ ca₂chein₃ jág₁ a₂tsá₃ dsi₂ten₅₄ jua'₅₄ a₂dsɨ₃'í₂ Pa₄ ja₁jaun₂.  
\v 32 Të₁lia'₂ jaun₂ në́₃ ja₁tion'₅₄ dsa₂ juɨg₂ le₁ŋɨi'₂ tioin'₅₄ co₂mɨ'₅₄, lë́₅ bá₄ qui₂juá'₂ jan₂-jan₂, tsá₃ caun₂ jág₁ 'ei₅, lë́₅ guë́₄ ca₂dsion₄ dsa₂ jŋia'₅₄ tsá₃ ŋi₅ 'e₂ lë₃ le₁ŋɨi'₂.  
\v 33 La₁ jë₄ jaun₂ jme₁tion'₅₄ bá₄ i₂lɨn₅₄ dsa₂ i₂ŋi₅. Jaun₂ ca₂juá'₂ 'a₂ lia'₂ lë́₅ ca₂tsɨ́'₃ jan₂ i₂chen₂ Alejandro i₂jme₁ca₂'lian'₃ dsa₂ judíos a₂ca₂dsióg₃ të₂ne₄ dsa₂ juɨg₂. Jaun₂ ca₂jmo₃ Alejandro léi₄ quian'₅₄ gu₂ a₂jme₁mɨ₂₃ a₂jmo₃ dsa₂ tei₄, ia₁ a₂jme₁'nio₃ juá'₂ jág₁ a₂jme₁tsɨ́'₃ dsa₂ a₂jme₁lióin₂ dsa₂ on₃ i₂ca₂jŋa'₃ dsa₂ 'éi₂.  
\v 34 La₁ jme₁ca₂rë₃lí'₄ dsa₂ a₂lɨ́n₅ Alejandro 'éi₂ jan₂ dsa₂ judío, jaun₂ ca₂tóin'₂ co₂mɨ'₅₄, con'₂ tɨn₃ hora qui₂guió'₅ ca₂juá'₂: 
\p ―¡'Ŋio₅ juɨn'₂ diú₄ Diana quián₅ dsa₂ juɨg₂ Efeso! 
\p  
\v 35 Jaun₂ dsa₂ i₂lɨ́n₅ të₅sí₃ quián₅ dsa₂ juɨg₂ jaun₂, ca₂tió'₃ jme₁ca₂tió'₃, ca₂jmo₃ ca₂i₃lén₂ dsa₂ tei₄. Jaun₂ guë́₄ ca₂juá'₂: 
\p ―'Nia'₂ dsa₂ chan₂ Efeso, ta₁caun₂ mɨ₂güɨ́g₃ bá₄ le₁ŋi₅ dsa₂ a₂ca₂tɨ́n₂ dsa₂ juɨg₂ Efeso jmo₃ 'í₁ guá'₅ quió'₅ diú₄ juɨn'₂ Diana, ton'₂ jmo₃ 'í₁ nió'₄ quió'₅ a₂ca₂sió₃ guei'₅₄ i₂juɨ́g₃.\f + \fr 19:35 \ft A₂lɨn₅₄ chog₅₄ si₂: “a₂ca₂sió₃ ja₁con₂ diú₄ Júpiter.” \f* 
\v 36 'I₁jan₂ jua'₅₄ le₃juá'₂ a₂tsá₃ ŋi₅. Jaun₂ tei₄ jmo₄ 'nia'₂, 'nio'₂ 'nia'₂ 'au'₂ dse₃ né'₃ guë́₄ a₂jmó'₂ 'e₂ jmó'₂.  
\v 37 Ia₁ dsa₂ i₂në₂chan'₂ 'nia'₂, tsá₃ 'ang₂₃ a₂ca₂tɨ́n₂ guá'₅, on₃ guë́₄ 'ɨin₂₃ 'lɨg'₅₄ diú₄ quián₂ jniog₄.  
\v 38 Chi₂jua'₂ 'nio₃ Demetrio mɨ₃ dso₄, quiain'₅₄ ca₂le₃jɨ́n₃ i₂jmo₅ ta₁ quiain'₅₄, jaun₂ guë'₂ chan₂ dsɨ₂tan₅₄ ne₄ta₁ ja₁lé₂ dsɨ₃mɨ₃ dso₄.  
\v 39 La₁ në₁jua'₂ a₂mɨ'₂ 'nia'₂ lë́₅ caun₂ dso₄ juë'₂ guë́₄ con'₂ guë́₄ a₂jaun₂, 'nió'₅ le₃rë₂ ne₄ dsɨ₂tan₅₄ jë₁ma₂le₁ŋɨ'₂ dsa₂ juɨg₂.  
\v 40 Ia₁ go'₂ quián₂ jniog₄ a₂jmo'₂ 'nia'₂ le₂në₅, në₁jua'₂ ca₂'nag₃ dsa₂ a₂ŋɨ́₄ lë₃ 'niog₂ mɨ'₅₄, juɨ₁lia'₂ mɨ'₅₄ a₂ca₂lë₃ në₃. Ia₁ në₁jua'₂ ca₂ŋag₃ dsa₂ 'e₂ 'uɨg₅₄ ca₂lë₃ mɨ'₅₄ la₂, tsá₃ 'e₂ cha₂ le₃ŋag₄. 
\p  
\v 41 Jme₁ma₂ca₂dsan₃ juá'₂ le₂në₅, ca₂jme₃dsiain₂₃ bá₄ jág₁ a₂le₁ŋɨ'₂ dsa₂. Jaun₂ ca₂dsiáin'₂ bá₄ dsa₂, qui₂ca₂i₃lein₃ quió'₅. 
\c 20  
\s1 Ca₂ŋó₃ Pablo 'uë₃ Macedonia quian'₅₄ Grecia 
\p  
\v 1 Jme₁ca₂dsan₃ mɨ'₅₄ jaun₂, qui₂ca₂të́'₃ Pa₄ le₃jɨ́n₃ dsa₂ 'én₂, qui₂ca₂cuë́'₃ bí₂. Jme₁ca₂lë₃ jaun₂, qui₂ca₂'ág'₃ jág₁ rɨin'₅₄. Jaun₂ guë́₄ ca₂ŋó₃ juɨ₅ Macedonia.  
\v 2 Jaun₂ qui₂i₁jag₅₄ le₂tan₅₄ juɨg₂ te₁'i₁ ja₁jaun₂. Quian'₅₄ jág₁ quió'₅ qui₂i₁cuë'₂ bí₂ rɨin'₅₄. Cang₂ guë́₄ jaun₂ ca₂ŋó₃ táng₃ juɨ₅ Grecia.  
\v 3 Ja₁jaun₂ ca₂'í₃ 'nɨ₅ tsɨ'₂. Jme₁ma₂'ein₅₄ juɨ₅ 'í₂ nɨ₁barco a₂dsó₃ juɨ₅ Siria, jme₁ca₂rë₃ŋi₅ a₂ma₂jmo₅ dsa₂ judíos caun₂ jág₁ a₂tsáun'₂. Jaun₂ co₂ŋei'₅₄ tsá₃ ma₃ca₂ŋái'₃ juɨ₅ jaun₂. Ca₂ŋái'₃ bá₄ táng₃ juɨ₅ 'uë₃ ca₂ŋɨ́i₃ Macedonia.  
\v 4 Jaun₂ ca₂jme₃quiong'₅₄ dsa₂ le₂'i₄ juɨ₅ i₂chen₂ Sópater ja₁ŋi'₅₄ Pirro,\f + \fr 20:4 \ft A₂lɨn₅₄ chog₅₄ si₂ tsá₃ chi₁ton₅ “ja₁ŋi'₅₄ Pirro.” \f* i₂chan₂ Berea, Aristarco quian'₅₄ Segundo i₂chan₂ Tesalónica, Gayo i₂chan₂ Derbe; Timoteo, Tíquico quian'₅₄ Trófimo në́₃ i₂chan₂ juɨg₂ gu'₂ ja₁tén₄ 'uë₃ Asia.  
\v 5 Jaun₂ në́₃, rɨn'₅₄ jniog₄ 'éi₂ ca₂i₃jŋiái₄ ca₂i₁jŋiog₁₂ juɨg₂ Troas.  
\v 6 Cang₂ jme₁ca₂gú'₃ jmɨg₄ a₂guë́'₅ dsa₂ i₁ŋí'₄ a₂tsá₃ levadura quian'₅₄, jaun₂ ca₂tió'₄ jnia'₅₄ nɨ₁barco ca₂'uag₂ Filipos. A₂'ŋiá₂ jmɨg₄ jaun₂, ca₂join₃ jnia'₅₄ juɨg₂ Troas. Ja₁jaun₂ ca₂jŋia₄ jnia'₅₄ guio₃ jmɨg₄. 
\s1 'En₅₄ Pablo juɨg₂ Troas 
\p  
\v 7 Jmɨg₄ jë₁le₂'uɨg₅₄ semana, ca₂ŋag'₂ jnia'₅₄ a₂ca₂dsió'₄ i₁ŋí'₄. Jaun₂ të₃jë₄ jaun₂ ca₂jme₃tag₅ Pa₄ ca₂jme₃tɨin₂₃ dsa₂. Caun₂ ca₂ton₃ jág₁ ca₂lia'₂ ca₂të́₂ dsi₃nei₅, ia₁ a₂ma₂'ein₅₄ juɨ₅ dsáin'₃ jë₁ma₂jnia₃ jaun₂.  
\v 8 Jme₁tio'₅₄ jnia'₅₄ le₁ŋag'₂ caun₂ dsi₂néi₂ ja₁lë́₄ guei'₅₄. 'Lióng₂ tsɨ́₅ jme₁le₁'ág₄ le₁guí'₂ si₂.  
\v 9 Jan₂ guë'₂ dsó₂ jme₁guá₄ caun₂ o₄'né₄ tau₂ quei₂ i₂jme₁chen₂ Eutico. Ia₁ a₂ŋɨ́₄ lë₃ uë́₂ qui₂ca₂dsia₃ Pa₄ jág₁, jaun₂ tsá₃ ma₃ca₂tió'₃ 'éi₂ a₂i₁güɨ́in₃. Jme₁ma₂rë₂güɨ́in₃ tsá₃ ma₃lí'₄ jme₁ca₂táin'₂ ca₂të₂ ja₁lë́₄ 'nɨ₅ juɨ́n₃ guei'₅₄. Ma₂join₂₃ jme₁ca₂i₁cho'₄ dsa₂.  
\v 10 Jaun₂ ca₂sión₃ Pa₄ ján₃, ca₂jŋai'₃ 'lag₄ ca₂quiog₂ ne₄ quió'₅, jaun₂ ca₂juá'₂ ca₂tsɨ́'₃ rɨin'₅₄: 
\p ―Tsá₃ lë₁jmo₂ 'nia'₂ gang'₃, ia₁ 'i₄ bá₄ jme₂dsí₂ quió'₅ chi'₂. 
\p  
\v 11 Jaun₂ në́₃ ca₂uɨ́g₂ táng₃ Pa₄ guei'₅₄. Jaun₂ ca₂dsió'₃ i₁ŋí'₄, ca₂guë́'₃ bá₄ jaun₂ në́₃. Caun₂ ca₂dsia₃ bá₄ guë́₄ Pa₄ jág₁ ca₂lia'₂ ca₂jnia₃. Ca₂ŋái'₃ bá₄ jaun₂ në́₃.  
\v 12 La₁ dsó₂ 'éi₂ në́₃, jéin'₃ bá₄ ca₂tág₃ dsa₂, jmo₅ dsa₂ 'io'₂ ca₂le₃jɨ́in₃. 
\s1 Ca₂'uɨn₂ dsa₂ Troas, ca₂i₃léin₂ táng₃ juɨ₅ Mileto 
\p  
\v 13 Ca₂i₃jŋióg₄ bá₄ jnia'₅₄ i₂náu₅ quian'₅₄ nɨ₁barco ca₂të₂ Asón ca₂i₁te₁ Pa₄, ia₁ jme₁ma₂lë́₅ jág₁ a₂'nio₃ dsó₃ 'ŋiog₅ juɨ₅ tag₅₄.  
\v 14 Jme₁ca₂rë₃quiain'₅₄ jnia'₅₄ juɨg₂ Asón, ca₂'í₃ nɨ₁barco quian'₅₄ jnia'₅₄ a₂ca₂i₃náu₅ juɨ₅ Mitilene.  
\v 15 Ca₂'uag₂ jnia'₅₄ ja₁jaun₂. Jme₁jnia₃ jaun₂, ca₂ŋag₅₄ cau₅ ja₁të́'₂ dsa₂ Quío, (a₂niog₅ jë₄ jmɨ₁ŋí'₄). Caun₂ jmɨg₄ cang₂ jaun₂, ca₂dsi₃náu₅ jnia'₅₄ 'o₄ jmɨ₁ŋí'₄ ja₁chei₂ Samos. [Jaun₂ ca₂jŋia₁ jnia'₅₄ juɨg₂ Trogilio].\f + \fr 20:15 \ft A₂lɨn₅₄ chog₅₄ si₂ tsá₃ le₁ton₅ jág₁ në₅.\f* Jme₁jnia₃ jaun₂ guë́₄ ca₂dsi₃náu₅ jnia'₅₄ të₂ juɨg₂ Mileto.  
\v 16 Jaun₂ le₂në₅ ca₂lë₃, ia₁ tsá₃ 'nio₃ Pa₄ 'í₂ uë́₂ 'uë₃ Asia, tsá₃ ma₃ca₂ŋei₅₄ juɨ₅ Efeso. Ia₁ 'nio₃ dsáin'₄ ŋi'₅₄ ta₁ juɨ₅ Jerusalén, a₂'nio₃ ŋɨi₅ ja₁jaun₂ Jmɨg₄ Të₂láu₃-guiá₂ në₁jua'₂ ca₂lë₃. 
\s1 Ca₂ton₃ Pablo jág₁ jɨn₄ dsa₂ can'₅₄ quián₅ rɨin'₅₄ chan₂ Efeso 
\p  
\v 17 'En₅₄ Pa₄ juɨg₂ Mileto, jaun₂ ca₂ŋɨ́i'₂ ca₂le₃jɨ́n₃ dsɨ₂gui'₅₄ can'₅₄ quián₅ rɨin'₅₄ i₂chan₂ Efeso.  
\v 18 Jme₁ca₂dsi₃lén₂ dsa₂, jaun₂ ca₂juá'₂ Pa₄: 
\p ―Ŋi'₅₄ bá₄ 'nia'₂ 'a₂ lia'₂ ma₂jmo₃ jniá₂ ca₂le₃ guang₃ le₂'uɨg₅₄ 'uë₃ Asia.  
\v 19 Ca₂le₃jë́₃ jmɨg₄ bá₄ lia'₂ con'₂ ca₂'ú₃ jɨn'₄ 'nia'₂, ca₂jme₁ti₁₂ ta₁ ne₄ Te₁gui'₅₄. Tsá₃ ca₂jme₁juɨng'₂ 'ŋió₃. Tsá₃ caun₂ ca₂i₃ŋɨ́g₂ 'uɨg₅₄ ca₂le₃jë́₃ a₂jme₁'nio₃ dsa₂ judíos jme₁jmóg'₂.  
\v 20 La₁ on₃jua'₅₄ jaun₂ tsá₃ ma₃ca₂jme₁tɨn₅ jniá₂ 'nia'₂ a₂dse₃ quián'₂ 'nia'₂, ca₂i₁'ë́₄ jɨn₄ dsa₂, ca₂ŋeg₅₄ të₂ dsi₂néi₂ quián'₂ 'nia'₂ në́₃.  
\v 21 Lia'₂ dsa₂ lɨ́n₅ judíos lia'₂ dsa₂ griegos në́₃, qui₂ma₂juɨ́g₂ jniá₂ a₂'nió'₅ jme₃tsɨ́n₃ dsa₂ dsɨ́₅ ne₄ Diú₄, a₂le₃'éin₂ të₂le₃ quió'₅ Te₁gui'₅₄ Jesucristo quián₂ jniog₄.  
\v 22 Jaun₂ në́₃, ma₂'eng₅₄ juɨ₅ nei₅₄ juɨ₅ Jerusalén, ia₁ chi₂quióng₂ jmɨg₄ Jme₂dsí₂ quián₅ Diú₄. Tsá₃ a₂jaun₂ guion₅₄ 'e₂ dsɨ₃ŋɨ́g₂ ja₁jaun₂.  
\v 23 Jŋia'₅₄ lia'₂ jaun₂ bá₄ guion₅₄, ia₁ le₂caun₂ le₂caun₂ juɨg₂ ja₁ma₂ŋeg₅₄, ma₂'ë́₂ jág₁ Jme₂dsí₂ Jŋió₅ a₂i₁ŋag₁₂ uɨg₅, a₂to'₂ dsa₂ 'né₅ 'má₃ në́₃.  
\v 24 La₁ tsá₃ a₂jaun₂ 'ɨ₅ dsɨ₃ jniá₂, o₁jŋia'₅₄ ca₂quɨ́n₂ 'mú₃ quió₃, ia₁jaun₂ bá₄ le₃tei₅₄ jniá₂ ta₁ a₂ma₂chei'₃ Te₁gui'₅₄ Jesús a₂jmo₅₄, a₂jme₁tɨng₅ dsa₂ jág₁ dse₃ a₂'ua₁ dsɨ́₅ Diú₄. 
\p  
\v 25 ’Jaun₂ në́₃ dsón'₂ lɨ́n₂ jniá₂, 'nia'₂ rɨn'₅₄ jniog₄ i₂ma₂nei'₂ jág₁ a₂ma₂qui₂ma₂'ë́₃ jniá₂ ŋɨ₂₃, o₁lɨ́g'₂ jmɨg₄ tsá₃ ma₃jag'₅₄ 'nia'₂ jniá₂ táng₃.  
\v 26 Jaun₂ lë₃ juɨ́g₂ jniá₂ 'nia'₂ tsá₃ ma₃'e₂ rë₂cán'₄ jniá₂ ja₁con₂ ca₂le₃jɨ́n₃ dsa₂,  
\v 27 ia₁ ma₂ca₂juɨ́g₂ bá₄ jniá₂ 'nia'₂ lia'₂ con'₂ lë́₅ dsɨ₂jiog₅ dsɨ́₅ Diú₄ jmo₃, tsá₃ 'e₂ ca₂'ma₃ jniá₂ ja₁con'₂ 'nia'₂.  
\v 28 Jaun₂ në́₃, jmo₄ 'nia'₂ 'í₁ guiong'₅₄, jmo₄ 'í₁ ca₂le₃jɨ́n₃ dsa₂ rɨ́ng'₂ i₂'én₂ në́₃. Ia₁ o₄gog'₂ 'nia'₂ bá₄ ma₂dsiog₃ Jme₂dsí₂ Jŋió₅ \f + \fr 20:28 \ft griego: (ma₂chei'₃ Jme₂dsí₂ Jŋió₅ a₂lén'₂ 'nia'₂) epískopos (dsa₂ i₂con₂ 'í₁).\f* a₂jmó'₂ 'í₁ dsa₂ i₂lɨ́n₅ guá'₅ quián₅ Diú₄ i₂'lian'₅₄ të₂le₃ quian'₅₄ jmɨ₂ 'an₅₄ 'ŋiog₅ ja₁ŋi'₅₄.  
\v 29 Guion₄ bá₄ jniá₂ a₂ja₃lén₂ dsa₂ sián'₂ jë₁ma₂ŋág'₅, a₂'nio₃ 'éin₂ 'nia'₂ ca₂le₃jɨ́ng'₃, a₂jmo₃ juɨ₁lia'₂ jmo₅ dsɨ₂jɨ'₅₄ náu₂ tsau₂ dsɨ́₅, jme₂dsiain₂₃ juɨ₁lia'₂ já'₂ cha'₂.  
\v 30 Náu₃ jë₄ quián'₂ 'nia'₂ guiong'₅₄ dsa₂ i₂jme₃tag₅ le₃jen₅ ia₁jaun₂ 'ein₃ juɨ₅ quió'₅ 'éi₂ juɨ₁lia'₂ dsa₂ i₂ma₂'én₂ jág₁ dse₃.  
\v 31 Jaun₂ rë₂ján'₁ 'nia'₂, dsá₂ 'au'₂ 'nia'₂ jmo₄, ia₁ 'nɨ₅ ŋi₂ ca₂dsɨn₃ ca₂cuë́₃ 'nia'₂ jág₁ lia'₂ 'uë₂-jmɨ₂, ca₂le₃jë́₃ ca₂'o₃. 
\p  
\v 32 ’Jaun₂ në́₃ rɨn'₅₄ jniog₄, dsián₄ jniá₂ 'nia'₂ o₄gú₃ Diú₄, ne₄ jág₁ dse₃ quió'₅ a₂'ua₁ dsɨ́₅, a₂lé₂ jmo₃ a₂'uan'₂ 'nia'₂, a₂lé₂ jmo₃ a₂tɨn'₅₄ 'nia'₂ a₂dse₃ a₂cha₂ quió'₅, juɨ₁lia'₂ a₂tɨn₅₄ ca₂le₃jɨ́n₃ dsa₂ i₂lë́₅ 'í₁ quiáin₅.  
\v 33 Tsá₃ 'e₂ ma₂ca₂rë₃'ɨ́n₂ dsɨ₃ a₂jmo₅₄ quió₃, juɨ₁lia'₂ a₂cha₂ quió'₅ i₂sián'₂, on₃ guë'₂ cu₄nióg₄, on₃ guë'₂ cu₄tiog₂, on₃ guë'₂ tsɨn'₅₄ në́₃.  
\v 34 Ŋi'₅₄ bá₄ 'nia'₂ rë₂, të₂le₃ ma₂jmo₃ bá₄ ta₁ 'ŋió₃ quian'₅₄ gu₂-tag₃ ma₂'no₃ a₂'nió'₅ dsɨ₃ŋɨ́g₂ quian'₅₄ i₂quiang'₅₄.  
\v 35 Ca₂le₃o₃ jmɨg₄ bá₄ ma₂'ë́₃ 'nia'₂ 'a₂ lia'₂ 'nió'₅ jmo₃ dsa₂ ta₁, a₂'nió'₅ jme₃'on₅₄ dsa₂ dsa₂ i₂'nió'₅ quió'₅. Dsá₂ 'au'₂ 'nia'₂ jmo₄ jág₁ quió'₅ Te₁gui'₅₄ Jesús, jme₁ca₂juá'₂: “Ja₂lɨn₃ guë́₄ dse₃ 'ei₅ dsɨ́₅ dsa₂ i₂cuë₅, con'₂ guë́₄ dsa₂ i₂gue₅.” 
\p  
\v 36 Jme₁ca₂dsan₃ juá'₂ Pa₄ le₂në₅, ca₂chi₃jné₃ quiain'₅₄ ca₂le₃jɨ́n₃ dsa₂, ca₂chi₃léin'₂ Diú₄.  
\v 37 Ca₂le₃jɨ́in₃ qui₂ca₂'o₃, qui₂ca₂jŋai'₃ Pa₄, ca₂chen'₃ quió'₅.  
\v 38 La₁ ja₂lɨn₃ guë́₄ 'lia'₂ dsɨ́₅ dsa₂ ca₂tóin'₂ jme₁ca₂juá'₂ Pa₄, ca₂lia'₂ o₁lɨ́g'₂ jmɨg₄ tsá₃ ma₃jɨ́in₂ guë́₄ rɨin'₅₄. Jaun₂ ca₂jme₃quiong'₅₄ dsa₂, ca₂i₁join₅₄ Pa₄ të₂ ja₁'ei₅ nɨ₁barco. 
\c 21  
\s1 Ca₂ŋá'₃ Pa₄ juɨ₅ Jerusalén 
\p  
\v 1 Jme₁ca₂tén'₂ dsɨ₅ jnia'₅₄ dsa₂ rɨn'₅₄, jaun₂ ca₂i₃náu₅ juɨ₅ ne₄ jmɨ₁ŋí'₄ co₂dsau₅ të₂ Cos (a₂niog₅ jë₄ jmɨ₁ŋí'₄). Jme₁jnia₃ jaun₂ táng₃, ca₂ŋag₅₄ ja₁chei₂ Rodas, jaun₂ guë́₄ dsi₃náu₅ jnia'₅₄ juɨg₂ Pátara.  
\v 2 Juɨg₂ Pátara jaun₂, cane₅₄ táng₃ jnia'₅₄ caun₂ nɨ₁barco a₂ŋó₃ juɨ₅ 'uë₃ Fenicia, jaun₂ ca₂tió'₄ jnia'₅₄, ca₂i₃náu₅ táng₃.  
\v 3 Jaun₂ ca₂ŋag₅₄ jnia'₅₄ ja₁jniá₂ Chipre të₂le₃ gu₂ jen₅, jaun₂ ca₂i₃náu₅ jnia'₅₄ të₂ Siria. Jaun₂ ca₂dsióg₃ nɨ₁barco juɨg₂ Tiro, ia₁ i₁con₂ lio₅₄ ja₁jaun₂. Jaun₂ ca₂sió₄ jnia'₅₄ ja₁jaun₂.  
\v 4 Jaun₂ ca₂jen'₂ jnia'₅₄ dsa₂ 'én₂ rɨn'₅₄ tián'₅ ja₁jaun₂. Jaun₂ ca₂tió'₄ jnia'₅₄ guio₃ jmɨg₄ quiain'₅₄. Dsa₂ 'éi₂ në́₃, ca₂'ë́₂ jág₁ a₂ca₂cuë₃ Jme₂dsí₂ Jŋió₅, ca₂tsɨ́'₃ Pa₄ a₂tsá₃ dsi₂ten₅₄ dsó₃ juɨ₅ Jerusalén.  
\v 5 Jme₁ca₂dsɨn₃ guio₃ jmɨg₄ tio'₅₄ jnia'₅₄ jaun₂, jaun₂ ca₂'uag₂ táng₃. Jaun₂ ca₂le₃jɨ́n₃ dsa₂ i₂'én₂, quiain'₅₄ 'io₅₄ quiáin₅, chi'₂ quiáin₅ në́₃, ca₂jme₃quiong'₅₄ të₂ 'nɨ'₂ juɨg₂, ca₂i₁jo₅₄ të₂ chei'₅₄ jmɨ₁ŋí'₄. Ja₁jaun₂ ca₂chi₁jne₁ jnia'₅₄ ca₂le₃jág₃, ca₂chi₁len'₄ jnia'₅₄ Diú₄.  
\v 6 Jaun₂ qui₂ca₂chan'₅₄ jnia'₅₄ rɨn'₅₄ ca₂'ei'₅₄ jág₁. Jaun₂ guë́₄ ca₂uɨg₅₄ jnia'₅₄ 'ŋió'₃ nɨ₁barco. 'Éi₂ në́₃ ca₂i₃lein₃ bá₄ quió'₅. 
\p  
\v 7 Jme₁ca₂'uag₂ jnia'₅₄ juɨg₂ Tiro, ca₂i₃náu₅ juɨ₅ ne₄ jmɨ₁ŋí'₄ a₂ca₂i₃náu₅ juɨ₅ Tolemaida. Ca₂cuɨn₅₄ jnia'₅₄ Diú₄ rɨn'₅₄ i₂tián'₅ ja₁jaun₂, ca₂jŋia₄ jnia'₅₄ co₂jmɨg₄ quiain'₅₄.  
\v 8 Jme₁jnia₃ jaun₂, ca₂le₃jág₃ con'₂ i₂quian'₅₄ Pa₄ ca₂'uag₂ ja₁jaun₂, ca₂dsi₃náu₅ juɨg₂ Cesarea. Ja₁jaun₂ ca₂i₁náu₄ jnia'₅₄ ja₁quió'₄ Felipe i₂'ë́₂ jág₁ dse₃, i₂lɨ́n₅ jan₂ rɨn'₅₄ dsa₂ guion₃ i₂jme₂'o₅₄\f + \fr 21:8 \ft dsa₂ guion₃ i₂jme₂'o₅₄: 'Nio'₂ ja₁ton₅ Hechos 6:1-7; Filipenses 1:1.\f* i₂ca₂quión'₂ dsa₂ le₂jŋiá₅.  
\v 9 Felipe 'éi₂ jme₁chan₂ quén₂ ja₁mɨ́g₄ on₃jua'₅₄ i₂ma₂jen'₂ gu₂. 'Io₅₄ quén₂ 'éi₂ jme₁'ë₂₃ 'ë́'₅ dsa₂ jág₁ a₂cuë₅ Diú₄.  
\v 10 Ma₂ne₁ŋó₄ ca₂la₂ jmɨg₄ tio'₅₄ jnia'₅₄ jme₁ca₂dsióg₃ jan₂ dsa₂ i₂të́'₂ dsa₂ Agabo, i₂'ë́₂ jág₁ a₂cuë₅ Diú₄, a₂ca₂o₃jag₅₄ jnia'₅₄.  
\v 11 Jaun₂ jme₁ca₂guan₃ 'éi₂ në́₃, ca₂can₃ lau₂ jén'₅ tú'₅ Pa₄, jaun₂ qui₂ca₂'néi₂ mɨ₂tag₅₄ 'ŋiog₅ quian'₅₄ mɨ₂gu₂ në́₃. Jaun₂ ca₂juá'₂: 
\p ―Le₂la₂ juá'₂ Jme₂dsí₂ Jŋió₅: “Le₂la₂ jmo₃ dsa₂ judíos jë₄ juɨg₂ Jerusalén jmái'₂ dsa₂ i₂quió'₅ nɨ₁lau₂ la₂, jaun₂ jáng'₂ o₄gú₃ dsɨ₂nau₂.” 
\p  
\v 12 Jme₁ca₂néi₁ jnia'₅₄ le₂në₅, jaun₂ ca₂mɨ́₁ jnia'₅₄ quian'₅₄ dsa₂ chan₂ Cesarea ca₂chei₅₄ Pa₄ a₂tsá₃ ma₃dsó₃ Jerusalén.  
\v 13 La₁ jaun₂ ca₂ŋag₃ Pa₄: 
\p ―¿'E₂ lë₃ quɨ'₂-'au'₂ 'nia'₂, jmo'₂ 'nia'₂ 'ag₅ 'lia'₂ dsɨ₃? Ia₁ ma₂rë₂ján₁ bá₄ jniá₂, on₃jua'₅₄ jmá'₃ ca₂ne₅₄ a₂'nei₃ dsa₂. Ján₃ bá₄ ma₂'ei₅ caun₂ dsɨ₃ a₂jóng₂, jŋag'₃ dsa₂ juɨg₂ Jerusalén, o₄quió'₄ Te₁gui'₅₄ Jesús. 
\p  
\v 14 Ia₁ tsá₃ jág₁ ca₂can₃ Pa₄ a₂ca₂chei₅₄ jnia'₅₄ a₂tsá₃ dsó₃, jaun₂ ca₂jmó₁ jnia'₅₄ tei₄ jme₁ma₂në₂jua'₅₄: 
\p ―Juɨ₁le₅₄ bá₄ a₂'ŋio₂ dsɨ́₅ Te₁gui'₅₄ jaun₂. 
\p  
\v 15 Cang₂ jaun₂ ca₂jmó₁ jnia'₅₄ co₂jŋia₅₄ quián₂, ca₂tió'₄ juɨ₅ i₃náu₅ juɨ₅ Jerusalén.  
\v 16 I₂lɨn₅₄ dsa₂ 'én₂ i₂chan₂ Cesarea ca₂jme₃quiong'₅₄. Jë₄ jaun₂ ŋó₃ jan₂ dsa₂ i₂chen₂ Mnasón i₂chan₂ Chipre. Ma₂lɨ́g'₂ bá₄ ma₂já₅ dsa₂ 'éi₂ a₂lɨ́in₅ dsa₂ i₂'én₂. Ja₁quió'₄ 'éi₂ ca₂i₁jŋia₄ jnia'₅₄ Jerusalén. 
\s1 Ca₂i₁jɨn₁ Pa₄ Jacobo 
\p  
\v 17 Jme₁ca₂dsi₃náu₅ jnia'₅₄ juɨg₂ Jerusalén, jaun₂ rɨn'₅₄ i₂tián'₅ ja₁jaun₂ ca₂guei₃ ca₂lia'₂ 'io'₂ jén'₅.  
\v 18 Jme₁jnia₃ jaun₂, ŋó₃ Pa₄ quiain'₅₄ jnia'₅₄ a₂ca₂i₁jɨn₁ jnia'₅₄ Jacobo. Ja₁quió'₄ 'éi₂ jme₁tion'₅₄ jɨn₂ gui'₅₄ can'₅₄.\f + \fr 21:18 \ft griego: presbúteros.\f* 
\v 19 Jaun₂ qui₂ca₂cuag₃ Pa₄ Diú₄. Jaun₂ ca₂dsia₃ Pa₄ ca₂le₃jë́₃ 'e₂ a₂ma₂jmo₃ Diú₄ jɨn₄ dsɨ₂nau₂ të₂le₃ quian'₅₄ 'éi₂.  
\v 20 Jme₁ca₂nág₂ dsa₂ jág₁, jaun₂ ca₂jme₃juɨin'₂ Diú₄. Jaun₂ ca₂juá'₂ ca₂tsɨ́'₃ Pa₄: 
\p ―Dse₃ jaun₂ rɨn'₅₄ jniog₄, la₁ ŋi'₅₄ bá₄ 'ne₂, të₂le₃ mei₅ bá₄ dsa₂ judíos i₂ma₂'én₂. Ca₂le₃jɨ́n₃ 'éi₂ në́₃, dsen₅₄ dsɨ́₅ le₃quió'₅ 'Éi'₃ Juá'₅.  
\v 21 Jaun₂ ma₂juá'₂ dsa₂ a₂ŋɨ'₂ 'ne₂ jme₂tɨ́ng'₁ dsa₂ judíos i₂tián'₅ go₄ dsɨ₂nau₂, a₂tsá₃ ma₃tón'₂ juɨ₅, tsá₃ ma₃jme₃ti₃ 'éi'₃ ca₂jmo₃ Moisés, a₂tsá₃ ma₃ti₃ dsa₂ nɨ₁lo₁ chi'₂ dsa₂ ŋe'₂ quiáin₅, on₃ guë'₂ jmo₃ juɨ₁lia'₂ tag₄ chí'₅ quián₂ jniog₄.  
\v 22 ¿'E₂ lé₂ në́₃? Ia₁ tion₅₄ ja₃lén₂ dsa₂ a₂ŋɨi'₂ jë₁ma₂ca₂rë₃ŋi₅ a₂'eng'₅₄ ja₁lá₃.\f + \fr 21:22 \ft A₂lɨn₅₄ chog₅₄ si₂: “Ia₁ tion₅₄ bá₄ le₃ŋi₅ dsa₂ a₂'eng'₅₄ ja₁lá₃.” \f* 
\v 23 Co₂ŋei'₅₄ guë́₄ dse₃ jmó'₂ a₂jua'₅₄ jnia'₅₄ la₂: Chan₂ jë₄ la₂ quián₂ jnia'₅₄ quén₂ dsa₂ i₂tion₅₄ niog₅ jme₃ti₃ caun₂ jág₁ quió'₅ a₂ma₂cuë́'₃ Diú₄.  
\v 24 Jŋiai₅ juɨ₁dsi₂léin₂ quian'₅₄ 'ne₂, jmo₄ le₁jë́₃ quiáng'₂ quiain'₅₄. Jaun₂ 'ne₂ bá₄ quɨ'₅₄ 'lia'₅₄ ia₁jaun₂ ma₂lé₂ jme₃ti₃ a₂chéi₃ jŋi₂ dsi₅₄, ia₁jaun₂ ca₂le₃jɨ́n₃ bá₄ dsa₂ le₃lí'₄ a₂tsá₃ dsau₅ jág₁ a₂dsia₅ dsa₂ a₂'ɨin₂₃ 'ne₂. Jaun₂ le₃ŋi₅ dsa₂ a₂jme₂ti'₅₄ bá₄ 'ne₂ ján₃ con'₂ lë́₅ 'Éi'₃ Juá'₅ quió'₅ Moisés.\f + \fr 21:24 \ft 'Í₂ Números 6. 'Nio'₂ ja₁ton₅ Hechos 18:18.\f* 
\v 25 La₁ ma₂ca₂chen₅₄ bá₄ jnia'₅₄ si₂ ne₄ dsɨ₂nau₂, a₂ca₂chei₅₄ jnia'₅₄ a₂tsá₃ lɨn₄ jmo₃ o₂i₁ dsɨ₅ quian'₅₄ 'Éi'₃ Juá'₅,\f + \fr 21:25 \ft A₂lɨn₅₄ chog₅₄ si₂ tsá₃ chi₁ton₅ “a₂tsá₃ lɨn₄ jmo₃ o₂i₁ dsɨ₅ quian'₅₄ 'Éi'₃ Juá'₅.” \f* a₂jŋia'₅₄ lia'₂ tsá₃ quɨ́g'₃ ŋɨ₄ já'₂ i₂ma₂cuɨn₃ dsa₂ diú₄ lag₄, on₃ guë'₂ guë́'₃ jmɨ₂, on₃ guë'₂ ŋɨ₄ já'₂ i₂güɨ́'₃ dsa₂ dsɨ₂lag₄, tsá₃ nió'₃ jág₁ quian'₅₄ dsa₂ i₂tsá₃ lɨ́n₅ dsɨ₂i₂gu₂ në́₃. 
\s1 Ca₂jŋa'₃ dsa₂ Pa₄ i₁dsi₅ guá'₅ templo 
\p  
\v 26 Jaun₂ ca₂jŋia₃ bá₄ Pa₄ dsa₂ quén₂ 'éi₂. Jme₁jnia₃ jaun₂ në́₃, Pa₄ quiain'₅₄ dsa₂ quén₂ 'éi₂ ca₂jmo₃ le₁jë́₃ quió'₅. Jaun₂ ca₂'í₃ i₁dsi₅ guá'₅ templo ca₂i₁'ë́₄ jág₁ i₂lɨ́g'₂ dsian₅ ta₁guio₃ jmɨg₄ a₂jmo₂₃ le₁jë́₃ quió'₅, jë₁ma₂të́₂ rë₁dsɨ́n'₂ dsa₂ já'₂ ne₄ ne₄chei₂ o₄quió'₄ le₂jain₂ le₂jain₂.\f + \fr 21:26 \ft 'Í₂ Números 6.\f* 
\p  
\v 27 La₁ jme₁ja₂quián₃ dsɨn'₅₄ ta₁guio₃ jmɨg₄ jaun₂, jan₂-on₃ dsa₂ judíos i₂chan₂ 'uë₃ Asia ca₂o₃léin₂, jaun₂ ca₂jɨ́in₂ Pa₄ i₁dsi₅ guá'₅. I₂'éi₂ ca₂jmo₃ ca₂tón'₂ dsa₂ co₂mɨ'₅₄, jaun₂ ca₂jŋa'₃ dsa₂ Pa₄.  
\v 28 Jaun₂ qui₂ca₂tóin'₂ ca₂guió'₃ ca₂juá'₂: 
\p ―¡'Nia'₂ dsa₂ juɨg₂ Israel, jme₁'o₁ jnia'₅₄! I₂la₂ bá₄ dsa₂ i₂ŋɨ́₄ lë₃ ŋɨ₅ ca₂le₃jë́₃ juɨg₂ jme₂tɨin₂₃ dsa₂ jág₁ 'lɨg'₅₄ ja₁con₂ juɨg₂ go₄ jniog₄, a₂jme₂tɨin₂₃ dsa₂ a₂tsá₃ jme₃ti₃ dsa₂ 'Éi'₃ Juá'₅ quió'₅ Moisés, a₂tsá₃ 'e₂ quen₅ guá'₅ templo la₂ quián₂ jniog₄. Në₃ në́₃, ma₂në₂tióin'₂ i₂lɨn₅₄ dsa₂ griegos i₁dsi₅ guá'₅ templo, a₂ma₂në₂jme₂'ióg₃ ja₁jŋió₅ la₂. 
\p  
\v 29 Juá'₂ le₂në₅, ia₁ ma₂jág₂ dsa₂ le₂jŋiá₅ ma₂jɨ́in₂ Trófimo i₂chan₂ Efeso a₂i₂ŋɨ₅₄ quiain'₅₄ Pa₄ jë₄ juɨg₂ Jerusalén, jaun₂ lɨ́in₂ a₂ma₂jŋia₃ Pa₄ 'éi₂ i₁dsi₅ guá'₅. 
\p  
\v 30 Ta₁caun₂ juɨg₂ ca₂tón'₂ dsa₂ co₂mɨ'₅₄, jaun₂ ca₂o₃lén₂ dsa₂ co₂chi'₅₄. Jaun₂ ca₂jŋa'₃ dsa₂ Pa₄ qui₂ca₂tsag'₂ të₂le₃ ca₁'né₄ i₁dsi₅ guá'₅, jaun₂ ca₂jnéi₃ dsa₂ dsɨ₂juɨ₅ o₄'né₄.  
\v 31 Jme₁ma₂'nio₃ jme₁jŋɨi'₃ bá₄ Pa₄ jme₁ca₂dsióg₃ jág₁ ca₂rë₃ŋi₅ juɨg₅₄ 'lióg₂ dsen₅₄, ca₂le₃jɨ́n₃ bá₄ dsa₂ juɨg₂ Jerusalén tioin'₅₄ co₂mɨ'₅₄.  
\v 32 Dsɨ₂juɨ₅ jaun₂ ca₂ŋɨ́i'₂ juɨg₅₄ 'lióg₂ quian'₅₄ ca₂le₃jɨ́n₃ 'lióg₂ quiáin₅, ca₂i₃léin₂ co₂'ei₅ ja₁tion'₅₄ dsa₂ co₂mɨ'₅₄. Jaun₂ dsɨ₂juɨ₅ jme₁ca₂jág₃ dsa₂ dsi₃lén₂ 'lióg₂ quiain'₅₄ juɨg₅₄ 'lióg₂ dsen₅₄, jaun₂ ca₂téin₂ bá₄ Pa₄, ia₁ jme₁tioin'₅₄ cuë₂₃.  
\v 33 Jaun₂ jme₁ca₂dsióg₃ juɨg₅₄ 'lióg₂ dsen₅₄, ca₂jŋai'₃ Pa₄ ca₂jmo₃ 'éi'₃ ca₂'néi₂ 'lióg₂ quian'₅₄ tɨn₃ ŋí₁ cadenas. Jaun₂ guë́₄ ca₂ŋɨ́i'₃ dsa₂ 'ein₂ 'éi₂ Pa₄, 'e₂ ca₂jmo₃.  
\v 34 Jaun₂ jma₃quén₅ qui₂ca₂guió'₃ dsa₂ juɨg₂ le₂jain₂ le₂jain₂. Ca₂lia'₂ jŋia'₅₄ tsá₃ ca₂ŋɨ́'₂ juɨg₅₄ 'lióg₂, ia₁ a₂ŋɨ́₄ chí'₅ co₂mɨ'₅₄. Jaun₂ ca₂jmo₃ 'éi'₃ ca₂tág₃ dsa₂ Pa₄ juɨ₅ 'né₅ ja₁tion'₅₄ 'lióg₂.  
\v 35 Jme₁ja₂quián₃ dsi₁len₃ dsa₂ ja₁lë́₄ nɨ₁ta₅ 'né₅ ja₁tion'₅₄ 'lióg₂, jaun₂ ca₂jiog₃ 'lióg₂ ca₂jŋiai₃ Pa₄ juɨ₅ guei'₅₄ ia₁ a₂ŋɨ́₄ 'ŋio₅ lɨn₃ 'ne₂ dsa₂ juɨg₂.  
\v 36 Ia₁ ca₂le₃jɨ́n₃ bá₄ dsa₂ juɨg₂ jme₁ja₂léin₂ chi₁co'₅₄ qui₂guió'₅ qui₂juá'₂: 
\p ―¡Juɨ₁jon₅₄ i₂në₅! 
\s1 Ca₂ton₃ Pa₄ jág₁ a₂lióin₂ 'ŋiog₅ ne₄ dsa₂ juɨg₂ 
\p  
\v 37 Jë₁jme₁ma₂to'₂ 'lióg₂ toin'₂ Pa₄ dsi₂néi₂ ne₄ta₁ quió'₅, jaun₂ ca₂juá'₂ Pa₄ ca₂tsɨ́'₃ juɨg₅₄ 'lióg₂ dsen₅₄: 
\p ―¿Lé₂ le₃juá'₄ jniá₂ ca₂jon₄ jág₁? 
\p Jaun₂ ca₂ŋag₃ juɨg₅₄ 'lióg₂: 
\p ―¿Tɨn'₂ 'ne₂ dsiá'₁ jág₁ jmei₅ griego?  
\v 38 Jaun₂, ¿on₃jua'₅₄ 'ne₂ lɨ́ng'₅ dsa₂ egipcio i₂ca₂jmo₃ mɨ'₅₄ qui₂ca₂tsɨ₂jain₃ dsa₂ ma₂i₁jáun₃, ca₂'uɨ́in'₂ quén₂ mei₅ dsa₂ i₂ma₂ca₂jme₃dsian₅ dsa₂ juɨ₅ 'uë₃ quein₂? 
\p  
\v 39 Jaun₂ ca₂juá'₂ táng₃ Pa₄: 
\p ―Dsa₂ judío bá₄ lɨ́n₅ jniá₂, i₂chan₂ juɨg₂ Tarso, caun₂ juɨg₂ dsen₅₄ tén₅ 'uë₃ Cilicia. La₁ jmo₄ dse₃ 'au'₂ cuë́'₁ jmɨg₄ a₂juɨg₅₄ jniá₂ dsa₂ juɨg₂ jág₁. 
\p  
\v 40 Ca₂cuë₃ bá₄ jmɨg₄ jaun₂ në́₃. Jaun₂ ca₂nau₂ Pa₄ ne₄ nɨ₁ta₅ jaun₂. Jaun₂ ca₂jmo₃ léi₄ quian'₅₄ gu₂ ca₂tsɨ́'₃ dsa₂ a₂jmo₃ tei₄. Jme₁ma₂chí'₅ tei₄, jaun₂ ca₂jme₃lióg₃ ca₂juá'₂ jág₁ quian'₅₄ jág₁ jmei₅ hebreo,\f + \fr 21:40 \ft o₃, arameo.\f* ca₂tsɨ́'₃ dsa₂: 
\c 22  
\p  
\v 1 ―'Nia'₂ dsa₂ go₂ rɨn'₅₄ jniog₄, gui'₅₄ can'₅₄ në́₃, nei₂ de'₂ 'nia'₂ a₂juá'₄ jniá₂ juɨg₅₄ 'nia'₂ a₂jáng'₄ jág₁ dsau₅ quió₃. 
\p  
\v 2 Të₂le₃ tei₄ guë́₄ ca₂i₃lén₂ dsa₂ jme₁ca₂nág₂ a₂juá'₂ Pa₄ quian'₅₄ jág₁ jmei₅ hebreo.\f + \fr 22:2 \ft o₃, arameo.\f* Jaun₂ caun₂ ca₂juá'₂ bá₄ 'éi₂: 
\p  
\v 3 ―Dsa₂ judío bá₄ lɨ́n₅ jniá₂. Juɨg₂ Tarso bá₄ chang₂, ja₁tén₄ 'uë₃ Cilicia. La₁ Jerusalén la₂ bá₄ ca₂i₃juɨng'₂. Ca₂'ɨ₃ jniá₂ si₂ a₂ca₂jme₃tag₅ të₅ Gamaliel. Co₂rë₂ bá₄ ca₂jme₃tag₂₃ con'₂ lë́₅ Si₂ 'Éi'₃ quió'₅ dsa₂ quián₂ jniog₄ ma₂lɨ́g'₂. A₂dsen₅₄ dsɨ₃ jme₁lɨ́ng₄ le₃quió'₅ Diú₄, juɨ₁lia'₂ jmo'₂ 'nia'₂ ca₂le₃jɨ́ng'₃ rë₂në́₃.  
\v 4 Qui₂ca₂co₃'én₃ jniá₂ dsa₂ i₂tion'₅₄ Juɨ₅ quió'₅ Te₁gui'₅₄ le₂jŋiá₅, ca₂lia'₂ ca₂quɨ́n₂ 'mú₃ quió'₅. Qui₂ca₂toin'₂ 'né₅ 'má₃ lia'₂ dsa₂ ŋe'₂ lia'₂ dsa₂ mɨ́₂.  
\v 5 Lé₂ bá₄ jáng'₃ jág₁ dsau₅ jme₂dsa₂ dsen₅₄, ca₂le₃jɨ́n₃ guë́₄ dsɨ₂gui'₅₄ can'₅₄ në́₃, ia₁ guioin₅₄ bá₄ ca₂jáng'₃ si₂ jniá₂ a₂ca₂chein₃ ne₄ rɨin'₅₄ i₂tián'₅ Damasco, ca₂jmo₃ 'éi'₃ a₂jme₁i₁chán'₃ jniá₂ rɨ́ng'₃ i₂tián'₅ ja₁jaun₂, a₂jme₁të₁₂ le₁'ŋei'₅₄ ia₁jaun₂ gue₃ uɨg₅ jë₄ juɨg₂ Jerusalén la₂. 
\s1 Ca₂dsia₃ Pa₄ 'a₂ lia'₂ jme₁ca₂jéin'₃ ca₂rë₃'éin₂ jág₁ dse₃ 
\r (Hechos 9:1-19; 26:12-18) 
\p  
\v 6 ’La₁ia₁ lia'₂ con'₂ jme₁ŋó₃ jniá₂ le₂'i₄ juɨ₅ né'₃ a₂dsióg₄ juɨg₂ Damasco, con'₂ dsi₂ŋí'₃, con'₂ tsá₃ jáng₅ jme₁ca₂téng₃ caun₂ si₂ tág₅ jmá'₅ a₂já₃ juɨ₅ guei'₅₄ i₂juɨ́g₃.  
\v 7 Jaun₂ i₃'ɨ́ng₃ 'uë₃. Dsɨ₂juɨ₅ le₂jaun₂ ca₂nag₃ jág₁ a₂juá'₂: “Saulo, Saulo, ¿'e₂ lë₃ co₂'éin'₅ jniá₂?”  
\v 8 Jaun₂ ca₂ŋag₄ jniá₂: “¿'Ein₂ 'ne₂ gui'₅₄?” Jaun₂ ca₂juá'₂ tság₅ jniá₂: “Jesús chan₂ Nazaret bá₄ jniá₂ i₂co₂'én'₅ 'ne₂.”  
\v 9 Ján₃ bá₄ ca₂jág₃ dsa₂ i₂jme₁quian'₅₄ jniá₂ si₂ jaun₂, jaun₂ ca₂rë₃gó'₅. La₁ tsá₃ ca₂nág₂ jág₁ quió'₅ i₂ca₂juá'₂ ca₂tság₃ jniá₂.  
\v 10 Jaun₂ ca₂ŋag₄ jniá₂ jaun₂ në́₃: “Te₁gui'₅₄, ¿'e₂ 'nió'₅ jmo₅₄ jniá₂?” Jaun₂ ca₂juá'₂ Te₁gui'₅₄: “Nau₂, gua₂ juɨ₅ juɨg₂ Damasco. Ja₁jaun₂ juá'₂ dsa₂ ca₂le₃jë́₃ 'e₂ 'nió'₅ jmó'₂.”  
\v 11 Ia₁ co₂dsia₅ ca₂téng₂ bá₄ quian'₅₄ si₂, jaun₂ dsa₂ i₂quiang'₅₄ bá₄ ca₂jiog₃ le₁chan'₂ gu₃ a₂ca₂dsióg₃ të₂ Damasco.  
\v 12 Ja₁jaun₂ jme₁guá₄ jan₂ dsa₂ chen₂ Ananías, i₂jme₁jme₂ti₃ con'₂ lë́₅ Si₂ 'Éi'₃ Juá'₅ quió'₅ Moisés, jaun₂ ca₂le₃jɨ́n₃ dsa₂ judíos i₂tián'₅ Damasco ca₂juá'₂ dse₃ 'ɨin₂₃ 'éi₂.  
\v 13 Jaun₂ ca₂dsióg₃ Ananías i₁jag₅₄ ja₁jme₁'eng₅₄. Jme₁ca₂dsióg₃, ca₂juá'₂: “Saulo rɨn'₅₄ jniog₄, guei'₅₄ táng₃ jme₁ne'₄.” Dsɨ₂juɨ₅ jaun₂ bá₄ ca₂lág₃ táng₃ mɨ́g₂ ne₃, jaun₂ ca₂jɨin₅₄ jaun₂ në́₃.  
\v 14 Jaun₂ ca₂tság₃ táng₃ jniá₂: “Diú₄ quián₅ dsa₂ can'₅₄ quián₂ jniog₄ ma₂ca₂quióin'₂ 'ne₂ le₂jŋiá₅, ia₁jaun₂ le₃cuɨng'₂ 'e₂ jaun₂ a₂'ŋio₂ dsɨ́₅, ia₁jaun₂ jɨng'₅₄ i₂qui₂dsɨ₅ 'éi'₃ rë₂ quiáin₅, ia₁jaun₂ nág'₁ jág₁ quió'₅ 'ŋiog₅ a₂tio'₅₄ mɨ₂'o₅₄.  
\v 15 Jaun₂ 'ne₂ gog'₅₄ a₂chi₂o₁'ɨ́in'₃ o₁dsia'₄ o₁chei'₄ ca₂le₃jɨ́n₃ dsa₂ ca₂le₃jë́₃ 'e₂ ma₂jag'₅₄ 'e₂ qui₂ma₂nei'₂ në́₃.  
\v 16 Jaun₂ në́₃, tsá₃ ma₃jme₁'ag₁₂. Nau₂, o₂chon₅₄ jmɨg₂, mɨ₄ ne₄ 'éi₂, ia₁jaun₂ jŋí₃ dsáu'₂.” 
\s1 Ca₂dsia₃ Pa₄ 'a₂ lia'₂ ca₂lë₃ a₂chein₅₄ ŋei₅₄ ja₁con₂ dsɨ₂nau₂ 
\p  
\v 17 ’Jme₁ca₂guáng'₃ Jerusalén, ŋeg₅₄ guá'₅ templo i₂chi₁leng'₄ Diú₄. Jaun₂ a₂lë₁ca₂jéin₃ ca₂jág₃,  
\v 18 ca₂jɨng₅₄ Te₁gui'₅₄, jaun₂ ca₂juá'₂: “I₂ŋáu'₂ jú₅ të₂le₃ dséi₂ juɨg₂ Jerusalén, ia₁ tsá₃ tón'₂ dsa₂ juɨ₅ jág₁ a₂juɨg'₅₄ a₂'ág'₄ jniá₂.”  
\v 19 Jaun₂ ca₂ŋag₄ jniá₂ ca₂juɨ́g₂: “Te₁gui'₅₄, ca₂le₃jɨ́n₃ bá₄ dsa₂ 'éi₂ le₁ŋi₅ a₂jme₁ŋɨ₅ jniá₂ a₂jme₁nei₂₃ ca₂le₃jë́₃ guá'₅ sinagogas a₂co₂'éng₅ qui₂cuë́₅ ca₂le₃jɨ́n₃ dsa₂ i₂'én₂ jág₁ dse₃ quiáng'₂, a₂jme₁i₂tioin'₂ 'né₅ 'má₃.  
\v 20 Jme₁ca₂jŋɨ'₃ dsa₂ Esteban, dsa₂ i₂jme₁jáng'₅ jág₁ dsau₅ quiáng'₂, jaun₂ bá₄ jme₁chén'₄ jniá₂ ján₃, ia₁ jme₁lë́₄ caun₂ jág₁ quió₃ quian'₅₄ dsa₂ i₂ca₂jŋɨ'₃ 'éi₂. Jaun₂ ca₂jmo₃ jniá₂ 'í₁ nɨ₁tsɨn'₅₄ dsa₂ i₂ca₂jŋag'₃.”  
\v 21 La₁ jaun₂ ca₂juá'₂ Te₁gui'₅₄ ca₂tság₃ jniá₂: “La₁ gua₂, ia₁ tsag₅₄ jniá₂ uɨ́ng₂ quiáng'₂, a₂o₁'ë́'₃ jág₁ ja₁con₂ dsɨ₂nau₂.” 
\s1 Ma₂niog₅ ne₄ juɨg₅₄ 'lióg₂ bá₄ Pablo 
\p  
\v 22 Co₂jaun₂ bá₄ ca₂nág₂ dsa₂ juɨg₂. Jaun₂ ca₂jme₃lióg₃ ca₂tóin'₂ co₂mɨ'₅₄ ca₂guió'₃ ca₂juá'₂: 
\p ―¡Juɨ₁jon₅₄ i₂në₅! ¡Tsá₃ ma₃'nió'₅ le₃chain₂ guë́₄! 
\p  
\v 23 Jaun₂ dsa₂ juɨg₂ në́₃, caun₂ qui₂ca₂të₂ca₂'oin'₂ bá₄ Pa₄, qui₂ca₂gág₃ tsɨn'₅₄ tioin'₅₄,\f + \fr 22:23 \ft ca₂gág₃ tsɨn'₅₄: Le₂jaun₂ jme₁jmo₅ dsa₂ léi₄ chi₂jua'₂ 'e₂ tsá₃ të₅ dsɨ́₅.\f* qui₂ca₂cho₃ dsa₂ 'liog₂ juɨ₅ guei'₅₄.  
\v 24 Jaun₂ ca₂jmo₃ juɨg₅₄ 'lióg₂ dsen₅₄ 'éi'₃ ca₂toin'₂ Pa₄ dsi₂néi₂ ja₁tion'₅₄ dsɨ₂'lióg₂. Jaun₂ ca₂jmo₃ 'éi'₃ a₂báin₂ Pa₄ ia₁jaun₂ jmo₃ jág₁ 'e₂ dso₄ rɨin₂, 'e₂ 'uɨg₅₄ ca₂rë₃'né₃ dsa₂ juɨg₂ quiong'₅₄.  
\v 25 La₁ jme₁ma₂rë₂'ŋei'₅₄ a₂jme₁ma₂bóg₂ dsa₂, ca₂juá'₂ Pa₄ ca₂tsɨ́'₃ jan₂ juɨg₅₄ 'lióg₂ i₂chén'₅ cau₅: 
\p ―¿Ca₂tɨ́n'₂ 'nia'₂ báng'₄ jan₂ dsa₂ i₂tén₅ Roma të₃ tsá₃ ma₂në₂quion'₂ 'nia'₂ jág₁ dsau₅ quió'₅? 
\p  
\v 26 Jme₁ca₂nág₂ juɨg₅₄ 'lióg₂ a₂në₅, jaun₂ ca₂ŋei₅₄ i₁chi'₂ juɨg₅₄ dsen₅₄ quiáin₅ ca₂juá'₂: 
\p ―Të₃ŋi'₅₄ quiáng'₂ në₁jua'₂ 'e₂ ca₂jmag'₅₄ dsa₂ në₅, ia₁ dsa₂ tén₅ Roma bá₄ në₅. 
\p  
\v 27 Jaun₂ ca₂jme₃quián₃ juɨg₅₄ 'lióg₂ dsen₅₄ ja₁'en₅₄ Pa₄, jaun₂ ca₂ŋag₃: 
\p ―¿Dsón'₂ lɨ́n'₅ 'ne₂ dsa₂ tén₅ Roma? 
\p Jaun₂ ca₂ŋag₃ táng₃ Pa₄: 
\p ―Ján₅. 
\p  
\v 28 Jaun₂ ca₂juá'₂ juɨg₅₄ 'lióg₂ jaun₂ në́₃: 
\p ―'Lióng₂ cu₄ ca₂quɨ́n₂ quió₃ a₂ca₂lɨng₃ dsa₂ tén₅ Roma. 
\p Jaun₂ ca₂juá'₂ táng₃ Pa₄: 
\p ―La₁ jniá₂ në́₃, a₂ma₂lɨ́n₅ bá₄ jniá₂ lia'₂ con'₂ ca₂rë₃cháng₃. 
\p  
\v 29 Dsɨ₂juɨ₅ jme₁ca₂nág₂ dsa₂ i₂jme₁bán₂ Pa₄, jaun₂ ca₂i₃léin₂ cau₅, ján₃ bá₄ le₂jaun₂ juɨg₅₄ 'lióg₂ dsen₅₄ në́₃. Ia₁ jme₁ca₂rë₃ŋi₅ a₂lɨ́n₅ Pa₄ dsa₂ tén₅ Roma, ca₂rë₃gó'₅ bá₄ jaun₂ në́₃ ia₁ a₂ca₂'nei'₂ Pa₄. 
\s1 Ma₂chén'₅ Pa₄ ne₄ dsɨ₂tan₅₄ quián₅ dsa₂ judíos 
\p  
\v 30 Jme₁jnia₃ jaun₂, jme₁'nio₃ le₃ŋi₅ juɨg₅₄ 'lióg₂ dsen₅₄ 'e₂ 'uɨg₅₄ jme₁cuë́'₅ dsa₂ judíos dso₄ Pa₄. Jaun₂ ca₂chéin'₂ 'éi₂ ia₁ a₂jme₁chi₁'ŋei'₅₄ quian'₅₄ nɨ₁ŋí₁ cadenas. Jaun₂ ca₂jmo₃ 'éi'₃ a₂ŋɨ'₂ juɨg₅₄ jme₂dsa₂ quian'₅₄ ca₂le₃jɨ́n₃ dsɨ₂tan₅₄ quián₅ dsa₂ judíos. Jaun₂ guë́₄ ca₂dsein₂₃ Pa₄ ca₂chei'₃ ne₄ dsa₂ 'éi₂. 
\c 23  
\p  
\v 1 Jme₁ma₂chén'₅ Pa₄ ne₄ dsɨ₂tan₅₄ quián₅ dsa₂ judíos, jaun₂ ca₂jɨ́in₂ ca₂le₃jɨ́n₃ dsa₂ can'₅₄ 'éi₂, jaun₂ ca₂juá'₂: 
\p ―Rɨn'₅₄ jniog₄, tei₄ bá₄ 'ei₅ dsɨ₃ ma₂guio₃, chang₂ të₂ jmɨg₄ në₃, ne₄ Diú₄. 
\p  
\v 2 Jaun₂ Ananías, i₂lɨ́n₅ jme₂dsa₂ dsen₅₄, ca₂tsɨ́'₃ dsa₂ i₂jme₁tión₂ cau₅ quió'₅ Pa₄, a₂jnáu₃ mɨ₂'o₄ 'éi₂.  
\v 3 Jaun₂ ca₂ŋag₃ Pa₄ ca₂tsɨ́'₃ jme₂dsa₂ dsen₅₄ 'éi₂: 
\p ―¡Diú₄ jnáu₃ quiáng'₂ 'ŋiag'₂, 'ne₂ i₂lɨ́ng'₅ lia'₂ lë́₅ caun₂ nɨ₁'ia'₂ a₂jŋia'₅₄ jniá₂ tiog₂ të₂le₃ co'₅₄!\f + \fr 23:3 \ft nɨ₁'ia'₂ tiog₂: 'Nio'₂ ja₁ton₅ Mateo 23:27.\f* ¿'Ŋéi'₂ 'ne₂ ja₁në₅ qui₂dsɨ́'₁ 'éi'₃ ja₁con₂ jniá₂ con'₂ lë́₅ Si₂ 'Éi'₃? ¿Jaun₂ 'e₂ lë₃ jmo'₂ 'éi'₃ a₂cuë₃ dsa₂ jniá₂, ton'₂ tsá₃ le₂jaun₂ ta₁ quí'₅ Si₂ 'Éi'₃? 
\p  
\v 4 Jaun₂ ca₂ŋag₃ dsa₂ i₂tion'₅₄ guë́₄ ja₁jaun₂: 
\p ―¿'E₂ lë₃ ŋag'₅₄ le₂në₅ ne₄ jme₂dsa₂ dsen₅₄ quián₅ Diú₄? 
\p  
\v 5 Ca₂ŋag₃ táng₃ Pa₄: 
\p ―Rɨn'₅₄ jniog₄, tsá₃ jaun₂ guion₅₄ a₂lɨ́in₅ jme₂dsa₂ dsen₅₄. Ia₁ juá'₂ ne₄ Si₂ quió'₅ Diú₄: “Tsá₃ chi₁'ɨ́ng'₄ 'lɨg'₅₄ dsɨ₂tan₅₄ juɨg₂ go'₅₄.”\f + \fr 23:5 \ft Éxodo 22:28.\f* 
\p  
\v 6 Jaun₂ ca₂rë₃lí'₄ Pa₄, i₂lɨn₅₄ dsa₂ 'éi₂ lɨ́n₅ dsa₂ saduceos, i₂lɨn₅₄ guë'₂ lɨ́n₅ dsa₂ fariseos. Jaun₂ guë́₄ ca₂juá'₂ Pa₄ tiá₂, ca₂tsɨ́'₃ dsa₂: 
\p ―Rɨn'₅₄ jniog₄, dsa₂ fariseo bá₄ lɨ́n₅ jniá₂. Fariseos bá₄ jme₁lɨ́n₄ dsa₂ can'₅₄ quiáng₃ në́₃. 'Uɨg₅₄ ia₁ a₂'éng₂ jág₁ a₂jen'₅₄ táng₃ 'lag₄ bá₄ a₂'iog₅₄ dsa₂, a₂con₂ dsa₂ jág₁ dsau₅ chéng'₅ la₂. 
\p  
\v 7 Jme₁ca₂juá'₂ Pa₄ le₂në₅, dsa₂ i₂lɨ́n₅ fariseos, quian'₅₄ dsa₂ i₂lɨ́n₅ saduceos në́₃, ca₂jme₃lióg₃ qui₂ca₂tsɨ́in₂ guioin₅₄, ca₂lë₃ le₁dsoin'₅₄.  
\v 8 Ia₁ dsa₂ saduceos, tsá₃ 'e₂ 'éin₂ a₂jen'₅₄ dsa₂ jë₁ma₂dsain₃, on₃ guë'₂ 'éin₂ a₂chan₂ ángeles, on₃ guë'₂ 'éin₂ a₂chan₂ jme₂dsí₂. La₁ dsa₂ fariseos guë'₂ në́₃, 'éin₂ bá₄ ca₂le₃jë́₃ a₂jaun₂.  
\v 9 Jaun₂ ca₂tóin'₂ ca₂tsɨ́in₂ co₂mɨ'₅₄. Jaun₂ i₂lɨn₅₄ dsa₂ i₂lɨ́n₅ të₅juá'₅ i₂tión₂ të₂le₃ quió'₅ dsa₂ fariseos, ca₂nau₂ ca₂juá'₂: 
\p ―'I₁caun₂ 'lɨg'₅₄ tsá₃ 'e₂ ma₂jmo₃ dsa₂ në₅. ¿'E₂ lé₂ chi₂jua'₂ dsón'₂ bá₄ ca₂juá'₂ jan₂ ángel, o₃ jan₂ jme₂dsí₂ 'e₂, ca₂tsɨ́'₃ i₂në₅? 
\p  
\v 10 Jaun₂ 'ŋio₅ ca₂tón'₂ dsa₂ ca₂tsɨ́in₂, ca₂lia'₂ ca₂rë₃gó'₅ juɨg₅₄ 'lióg₂ dsen₅₄ jme₁ca₂jág₃. Ia₁ në₅ tsá₃ ma₂jmo₃ dsa₂ jma₃quén₅ quió'₅ Pa₄, lɨ́in₂. Jaun₂ ca₂jmo₃ 'éi'₃ ca₂o₃lén₂ 'lióg₂ ca₂dsein₂₃ Pa₄ jë₄ quió'₅ dsa₂, ca₂tág₃ juɨ₅ ne₄ta₁ ja₁tion'₅₄ 'lióg₂. 
\p  
\v 11 Jme₁ca₂të́₂ tɨn₃ nei₅ 'en₅₄ Pa₄ ja₁jaun₂,\f + \fr 23:11 \ft o₃, “A₂'uë₂ jmɨg₄ jaun₂.” \f* ca₂jme₃jnia₅ Te₁gui'₅₄ ne₅₄, jaun₂ ca₂juá'₂: 
\p ―Quen'₂ bí₂, Pa₄, ia₁ juɨ₁lia'₂ ma₂në₂jang'₅₄ jág₁ dsau₅ në₂'ag'₅₄ jniá₂ jë₄ juɨg₂ Jerusalén la₂, le₂në₅ bá₄ o₁jang'₁ jág₁ dsau₅ o₁'ág'₃ jniá₂ jë₄ juɨg₂ Roma ján₃. 
\s1 Ca₂jmo₃ dsa₂ judíos jág₁ a₂jme₁jŋɨi'₃ Pa₄ 
\p  
\v 12 Jme₁jnia₃ jaun₂, ca₂jmo₃ jág₁ i₂lɨn₅₄ dsa₂ judíos a₂jŋɨi'₃ Pa₄. Ca₂'ɨin₃ Diú₄ a₂ca₂juá'₂ a₂tsá₃ 'e₂ guë́'₃, a₂tsá₃ 'e₂ 'ɨ́n'₂ në́₃, ca₂lia'₂ ca₂lë₃ a₂niog₅ dsɨ́₅ jmo₃.  
\v 13 Jme₁lë́₂ lë́₅ guë́₄ con'₂ të₂lón₃ dsa₂ i₂jme₁ma₂lɨ́'₅ jág₁ jmo₃ le₂jaun₂.  
\v 14 Jaun₂ ca₂i₁lein₅₄ i₁jɨin₅₄ juɨg₅₄ jme₂dsa₂, ca₂le₃jɨ́n₃ guë́₄ gui'₅₄ can'₅₄ quián₅ dsa₂ judíos në́₃, a₂ca₂i₁jua'₁: 
\p ―Jnia'₅₄ ma₂'ɨ́n₃ Diú₄ a₂tsá₃ 'e₂ tí₄ 'o₄, ca₂lia'₂ ma₂në₂jŋɨ́'₄ jnia'₅₄ Pa₄.  
\v 15 Jaun₂ 'nia'₂ në́₃, quian'₅₄ dsɨ₂tan₅₄ quián₅ guá'₅, o₂chei'₅₄ 'nia'₂ juɨg₅₄ 'lióg₂ a₂ja₂jŋiai₃ Pa₄ ne'₅₄ 'nia'₂ 'ióg₃. A₂lë₁juɨg'₅₄ bá₄ 'nia'₂ a₂caun'₅₄ jág₁ dsau₅ co₂rë₂ quió'₅, ia₁jaun₂ bá₄ ja₃jiog₃. Jaun₂ jnia'₅₄ guë'₂ në́₃, ma₂lág₅ co₂jŋia₅₄ a₂jŋɨ́i'₄ né'₃ a₂guáin₂ të₂la₂. 
\p  
\v 16 La₁ ja₁ŋi'₅₄ 'io₅₄ rɨn'₅₄ Pa₄ ca₂rë₃ŋi₅ jág₁ jaun₂. Jaun₂ ca₂ŋei₅₄ ne₄ta₁ quió'₅ 'lióg₂ ca₂i₁'ë́₄ jág₁ ne₄ Pa₄.  
\v 17 Jaun₂ Pa₄ në́₃ ca₂të́'₃ jan₂ juɨg₅₄ 'lióg₂, jaun₂ ca₂juá'₂: 
\p ―Jŋia₅ chi'₂ la₂ ne₄ juɨg'₂ 'nia'₂, ia₁ cha₂ jág₁ quian₅ dsɨ₃'ë́₃. 
\p  
\v 18 Jaun₂ ca₂ŋe₄ 'éi₂ ca₂i₁jŋiai₃ chi'₂, jaun₂ ca₂juá'₂: 
\p ―Pa₄ i₂lë́₅ 'í₁ quián₅ 'lióg₂ në₂té₂ jniá₂ a₂në₂mɨ₃ a₂i₁jŋiag₂ chi'₂ la₂, ia₁ cha₂ jág₁ quian₅ a₂'ë́₂ ne'₅₄. 
\p  
\v 19 Jaun₂ ca₂jŋa'₃ juɨg₅₄ 'lióg₂ dsen₅₄ 'éi₂ mɨ₂gu₂ chi'₂ 'éi₂, con'₂ ca₂jiog₃ cau₅, jaun₂ ca₂ŋag₃: 
\p ―¿'E₂ jág₁ quian'₅₄ juɨg'₅₄ jniá₂? 
\p  
\v 20 Jaun₂ ca₂ŋag₃ chi'₂ 'éi₂: 
\p ―Ma₂në₂jmo₃ dsa₂ judíos caun₂ jág₁ a₂mɨ₃ ne'₅₄ a₂o₁jŋiag'₂ Pa₄ 'ióg₃ ne₄ dsɨ₂tan₅₄ quián₅ dsa₂ judíos. A₂'nio₃ jme₃gain₂₃ 'ne₂ jmo₃ në₂jag₄ bá₄ a₂con₂ dsɨ₂tan₅₄ jág₁ dsau₅ quió'₅ 'éi₂.  
\v 21 La₁ tsá₃ o₁'eng'₅₄, ia₁ lë́₅ guë́₄ të₂lón₃ dsa₂ quiáin₅ ma₂le₁'mai₅₄ cau₅ juɨ₅ le₁jŋiog₂₃. Ma₂'ɨin₃ Diú₄ a₂tsá₃ 'e₂ guë́'₃, 'ɨ́n'₂, ca₂lia'₂ ca₂jŋɨi'₃ Pa₄. Jŋia'₅₄ lia'₂ a₂jaun₂ bá₄ le₁jŋia₂₃ chi₂jua'₂ 'e₂ jág₁ juɨg'₅₄ 'ne₂. 
\p  
\v 22 Jaun₂ ca₂'ág'₃ jág₁ juɨg₅₄ dsen₅₄ 'éi₂, ca₂juá'₂ a₂tsá₃ 'ein₂ tsɨ́'₃ jág₁ a₂ca₂dsia₃ jaun₂. 
\s1 Ca₂dsián'₂ dsa₂ Pa₄ ne₄ Dsi₄má'₂ Félix 
\p  
\v 23 Jaun₂ ca₂të́'₃ juɨg₅₄ 'lióg₂ dsen₅₄ on₃ juɨg₅₄ 'lióg₂ quiáin₅, ca₂jmo₃ 'éi'₃ a₂jmo₃ 'éi₂ co₂jŋia₅₄ tɨn₃ 'ŋiá₂-lón₂ 'lióg₂ a₂dsɨ₃léin₂ juɨ₅ tag₅₄; 'nag'₂ ne₂guión₂ rë₂dsɨ́₂ guian₃ guë'₂ (70) dsɨ₃lén₂ co₁dsɨn₅₄ cua₁, tɨn₃ 'ŋia₂-lón₂ guë'₂ i₂cán₂ ŋí₁ chen'₂, a₂dsɨ₃léin₂ juɨ₅ Cesarea con'₂ hora ŋí₁ ŋi₃ le₃ca₂nei₂.\f + \fr 23:23 \ft lit. “hora 'nɨ₅ a₂'uë₂.”\f* 
\v 24 Jaun₂ ca₂chein₃ jág₁ a₂jmo₃ dsa₂ co₂jŋia₅₄ cua₁ i₂co₃dsɨn₅₄ Pa₄. Ca₂jmo₃ 'éi'₃ a₂jmo₃ dsa₂ 'í₁, dsɨ₃jóin₂ 'éi₂ o₄gú₃ Dsi₄má'₂ Félix të₂dsein₃ jéin'₃ le₂jaun₂.  
\v 25 Jaun₂ quian'₅₄ dsa₂ i₂i₁jon₅₄ Pa₄, ca₂chen₃ juɨg₅₄ dsen₅₄ si₂ la₂ a₂juá'₂: 
\p  
\v 26 Jniá₂, Claudio Lisias, tsɨ́ng₂ si₂ la₂ ne'₅₄ 'ne₂, gui'₅₄ Dsi₄má'₂ juɨn'₂ Fé₁. Cuɨ́ng₅ Diú₄ 'ne₂.  
\v 27 Ca₂jŋau'₃ dsa₂ judíos ca₂jŋai'₃ dsa₂ në₅, a₂jme₁jŋag'₃. La₁ jme₁ca₂rë₃guion₅₄ a₂lɨ́in₅ dsa₂ tén₅ Roma, jaun₂ ca₂ŋeg₅₄ i₁lioin₁₂ quian'₅₄ 'lióg₂ quiáng₃.  
\v 28 Ia₁ jme₁'nio₃ le₃guion₅₄ 'e₂ 'uɨg₅₄ 'nag₅ dsa₂, jaun₂ ca₂i₁jŋiái₂ ne₄ dsɨ₂tan₅₄ quiáin₅.  
\v 29 Jaun₂ ca₂rë₃léi₄ jniá₂, 'uɨg₅₄ quió'₅ Si₂ 'Éi'₃ quió'₅ guion₅₄ bá₄ dsa₂, cuë́'₅ i₂në₅ dso₄. Jaun₂ tsá₃ cha₂ 'e₂ lë₃ jua'₅₄ a₂'i₄ 'éi'₃ a₂jŋag'₃ dsa₂, on₃ guë'₂ dsi₂ten₅₄ jua'₅₄ a₂'í₂ 'né₅ 'má₃ në́₃.  
\v 30 Jaun₂ jme₁ca₂rë₃guion₅₄ a₂ma₂jmo₃ dsa₂ judíos caun₂ jág₁ a₂jŋag'₃, jaun₂ bá₄ lë₃ dsiain'₄ jniá₂ o₄gog'₂ 'ne₂. Jaun₂ ma₂juɨ́g₂ bá₄ jniá₂ ján₃, dsa₂ i₂'nag₅ 'nɨ₅ i₂në₅, a₂dsɨ₃léin₂ ne'₅₄ 'ne₂, a₂dsɨ₃can₅ dso₄ a₂bóin'₂ i₂në₅. Co₂në₅ bá₄. 
\p  
\v 31 Jaun₂ 'lióg₂ në́₃, con'₂ lë́₅ 'éi'₃ ma₂ŋɨi₂, ca₂dsein₂₃ Pa₄ ca₂tág₃ të₃ 'uë₂ ca₂dsi₃léin₂ të₂ juɨg₂ Antípatris.  
\v 32 Jme₁jnia₃ jaun₂, 'lióg₂ i₂i₃lén₂ juɨ₅ tag₄ ca₂jéin'₃ táng₃ juɨ₅, ja₂lein₃ táng₃. Jmá'₃ 'lióg₂ i₂co₁dsɨn₅₄ cua₁ bá₄ ca₂i₃lén₂ i₃jón₂ guë́₄ Pa₄.  
\v 33 Jme₁ca₂dsi₃léin₂ të₂ juɨg₂ Cesarea, jaun₂ ca₂jɨ́in'₃ dsi₄má'₂ si₂ carta a₂quian₅. Ca₂jɨ́in'₂ Pa₄ në́₃.  
\v 34 Jme₁ma₂në₂'í₂ dsi₄má'₂ si₂, jaun₂ ca₂ŋɨ́i'₃ Pa₄ a₂já'₄ chain₂. Jme₁ca₂rë₃ŋi₅ a₂chan₂ 'éi₂ 'uë₃ Cilicia,  
\v 35 jaun₂ ca₂juá'₂: 
\p ―Në₅ nag₅₄ jág₁ quiáng'₂ jë₁ma₂o₂lén₂ dsa₂ i₂'nag₅ quiáng'₂. 
\p Jaun₂ ca₂jmo₃ dsi₄má'₂ 'éi'₃ a₂jmo₃ 'lióg₂ 'í₁ Pa₄ dsi₂néi₂ ne₄ta₁ palacio quió'₅ Rag₅₄ Herodes. 
\c 24  
\s1 Ca₂jáng'₃ Pa₄ jág₁ dsau₅ a₂lióin₂ 'ŋiog₅ ne₄ Dsi₄má'₂ Fé₁ 
\p  
\v 1 A₂'ŋiá₂ jmɨg₄ cang₂ jaun₂, ca₂dsióg₃ Ananías i₂lɨ́n₅ jme₂dsa₂ dsen₅₄, quiain'₅₄ i₂lɨn₅₄ gui'₅₄ can'₅₄ në́₃, quiain'₅₄ Tértulo i₂lɨ́n₅ i₂chén'₅ ne₄ jág₁ quiáin₅, ca₂dsi₃léin₂ Cesarea. Jaun₂ ca₂dsi₃léin₂ ne₄ dsi₄má'₂ a₂'nɨi₃ Pa₄.  
\v 2 Jme₁ca₂i₁quian₅₄ dsa₂ Pa₄, jaun₂ ca₂jme₃lióg₃ Tértulo ca₂tsɨ́'₃ dsi₄má'₂ a₂'nɨi₂₃ Pa₄, ca₂juá'₂: 
\p ―Ti₁'mag'₄ 'ne₂, tei₄ bá₄ 'ei₅ tio'₅₄ jnia'₅₄, jaun₂ dse₃ bá₄ lia'₂ con'₂ lë́₅ 'éi'₃ quiáng'₂ a₂tɨng'₂.  
\v 3 Jaun₂ con'₂ lë́₅ 'éi'₃ quí'₂ 'ne₂ bá₄ qui₂jmo₅ dsa₂, a₂jmo₂ jnia'₅₄ ján₃. Jaun₂ cuë₂ jnia'₅₄ ti₁'mag'₄ 'ne₂, Fé₁ juɨn'₂.  
\v 4 La₁ jaun₂ tsá₃ uë́₂ jme₁'ag₁₂ jnia'₅₄ quiáng'₂, mɨ₂ jnia'₅₄ jmó'₂ dse₃ 'au'₂ a₂nág'₁ jág₁ quián₂ jnia'₅₄ a₂jua'₅₄.  
\v 5 Ma₂ne₅₄ jnia'₅₄ ca₂le₃jë́₃ 'e₂ 'lɨg'₅₄ jmo₅ dsa₂ në₅, ŋɨ₂₃ ca₂le₃jë́₃ juɨg₂ qui₂dsiain₂₃ mɨ'₅₄ dsa₂ judíos qui₂jmo₃ le₁dson'₅₄ dsa₂. Jaun₂ i₂në₅ bá₄ lɨ́n₅ jan₂ dsa₂ i₂quian₅ ne₄ juɨ₅ quió'₅ co₂nió'₃ dsa₂ i₂të́'₂ dsa₂ nazarenos.  
\v 6 Jme₁'nio₃ jme₁jme₂'ióg₃ guá'₅ templo quián₂ jnia'₅₄. Jaun₂ bá₄ lë₃ ca₂chain'₅₄ jnia'₅₄, [jme₁'niog₂ jme₁qui₂dsɨ₂ 'éi'₃ con'₂ lë́₅ Si₂ 'Éi'₃ quián₂ jnia'₅₄.  
\v 7 La₁ jme₁ca₂'í₃ juɨg₅₄ 'lióg₂ Lisias, ca₂jŋiái'₂ Pa₄ jɨn₄ jnia'₅₄ quian'₅₄ bí₂ quió'₅ 'lióg₂ quiáin₅, a₂ca₂tág₃.  
\v 8 Ca₂juá'₂ Lisias 'éi₂ a₂'nió'₅ ja₃lén₂ dsa₂ i₂'nag₅ ne'₅₄ 'ne₂.]\f + \fr 24:8 \ft A₂lɨn₅₄ chog₅₄ si₂ tsá₃ le₁ton₅ jág₁ a₂tio'₅₄ 'ŋió'₃ corchetes [le₂la₂].\f* Dse₃ ŋag'₅₄ 'ne₂ 'ŋiag'₂ ia₁jaun₂ le₃ŋi'₅₄ lia'₂ tí₅ jág₁ 'e₂ lë₃ 'nɨ́i₅ jnia'₅₄. 
\p  
\v 9 Jaun₂ ca₂le₃jɨ́n₃ guë́₄ dsa₂ judíos i₂jme₁tión₂ ja₁jaun₂ ca₂juá'₂ a₂dsón'₂ dsau₅ bá₄ jág₁ në₅.  
\v 10 Jaun₂ ca₂jmo₃ léi₄ dsi₄má'₂ ca₂tsɨ́'₃ Pa₄ a₂juá'₂ 'éi₂ jág₁. Jaun₂ ca₂juá'₂ 'éi₂ jaun₂ në́₃: 
\p ―A₂'ŋio₂ dsɨ₃ jáng'₄ jág₁ dsau₅ a₂long₅₄ 'ŋió₃ ne'₅₄ 'ne₂, ia₁ guion₅₄ bá₄ jaun₂ a₂lɨ́ng'₅ dsɨ₂tan₅₄ ma₂ne₁ŋó₄ ŋi₂ a₂qui₂dsɨ́'₁ 'éi'₃ quió'₅ ta₁caun₂ 'uë₃ la₂.  
\v 11 Lé₂ bá₄ le₃caun'₅₄ jág₁ dsau₅, mei'₂ tsá₃ guia₃-tɨ́n₂ jmɨg₄ bá₄ ma₂të́₂ a₂guang₃ Jerusalén a₂chi₁leng'₄ Diú₄.  
\v 12 Tsá₃ jua'₅₄ ca₂jo₃ dsa₂ a₂tsɨ́ng₂ quian'₅₄ dsa₂, on₃ guë'₂ jua'₅₄ a₂qui₂dsia₂₃ mɨ'₅₄ i₁dsi₅ guá'₅ templo, on₃ guë'₂ dsi₂néi₂ guá'₅ sinagogas, on₃ guë'₂ jë₄ juɨg₂.  
\v 13 Tsá₃ quɨ'₅₄ jmɨg₄ i₂në₅ jme₃jniai₂₃ ca₂le₃jë́₃ a₂'nag₂₃.  
\v 14 La₁ a₂juá'₅ jniá₂ ne'₅₄, a₂jme₂ti₅₄ ne₄ Diú₄ quián₅ dsa₂ can'₅₄, con'₂ lë́₅ Juɨ₅ a₂juá'₂ i₂në₅ a₂tsá₃ dsau₅. Ia₁ 'éng₂ ca₂le₃jë́₃ a₂tio'₅₄ ne₄ Si₂ 'Éi'₃ quian'₅₄ Si₂ quió'₅ dsa₂ i₂jme₁'ë́₂ jág₁ quián₅ Diú₄ në́₃.  
\v 15 Le₂jaun₂ bá₄ 'éng₂ le₃quió'₅ Diú₄, juɨ₁lia'₂ 'éin₂ guioin₅₄ bá₄ ján₃, ia₁ 'éng₂ a₂qui₂jen'₅₄ 'lag₄, lia'₂ dsa₂ dsen₃ lia'₂ dsa₂ 'lɨn'₅₄ në́₃.  
\v 16 'Uɨg₅₄ jaun₂, le₃jë́₃ jmɨg₄ bá₄ quɨ́n'₅ jniá₂ bí₂ a₂tsá₃ 'e₂ dsɨ₃jŋi₅ dsɨ₃, lia'₂ ne₄ Diú₄ lia'₂ ne₄ dsa₂ mɨ₂güɨ́g₃ në́₃. 
\p  
\v 17 ’Jme₁ca₂dsɨn₃ tɨn₃-'nɨ₅ ŋi₂ a₂ŋɨ₂₃ juɨg₂ siá'₂, ca₂guáng'₃ táng₃ Jerusalén a₂jme₁'ong₁₂ dsa₂ te₂ŋé₂, a₂dsɨ́ng'₄ já'₂ ne₄ ne₄chei₂ në́₃.  
\v 18 A₂jaun₂ bá₄ 'eng₅₄ jmo₂₃ i₁dsi₅ guá'₅ templo jme₁ma₂në₂jmo₃ le₁jë́₃ quió₃ lia'₂ con'₂ lë́₅ tag₄ chí'₅ quián₂ jnia'₅₄. La₁ on₃jua'₅₄ a₂jme₁tion'₅₄ dsa₂ juɨn₅, on₃ guë'₂ jua'₅₄ ca₂dsia₃ jniá₂ mɨ'₅₄. Jaun₂ ca₂dsi₃lén₂ i₂lɨn₅₄ dsa₂ judíos i₂ja₂lén₂ juɨg₂ siá'₂ ja₁tén₄ 'uë₃ Asia. I₂'éi₂ bá₄ ca₂jo₃ 'eng₅₄ i₁dsi₅ guá'₅ templo.  
\v 19 I₂'éi₂ bá₄ 'nió'₅ ja₃lén₂ ja₁lá₃ ia₁jaun₂ 'nag₃ chi₂jua'₂ cha₂ a₂'nag₃ jniá₂.  
\v 20 Në₁jua'₂ tsá₃ a₂cha₂ 'nag₃ 'éi₂, jaun₂ juɨ₁'nag₅₄ i₂tión₂ në₅ chi₂jua'₂ cha₂ dso₄ ca₂'no₃ ja₁con₂ dsɨ₂tan₅₄ quián₅ dsa₂ judíos.  
\v 21 O₃ 'uɨg₅₄ jaun₂ 'e₂, ia₁ a₂'én₂ jniá₂ a₂jen'₅₄ 'lag₄, juɨ₁lia'₂ ca₂juá'₃ jniá₂ tiá₂ ca₂juɨ́g₂ 'éi₂ lia'₂ con'₂ jme₁'eng₅₄ jë₄ quió'₅, ca₂juɨ́g₂: “A₂cáun'₂ 'nia'₂ jág₁ dsau₅ quió₃ jniá₂, ia₁ a₂'éng₂ a₂jen'₅₄ 'lag₄.” 
\p  
\v 22 Jme₁ca₂nag₂ gui'₅₄ Dsi₄má'₂ Fé₁ le₂në₅, jaun₂ tsá₃ ma₃'e₂ ca₂jme₃rë́₃. Ia₁ jme₁ma₂ŋi₅ rë₂ bá₄ i₂'e₂ jaun₂ a₂të́'₂ dsa₂ “Juɨ₅”. Jaun₂ ca₂juá'₂: 
\p ―Në₅ bá₄ jme₁rë₂ jniá₂ jág₁ në₅ quián'₂ 'nia'₂, jë₁ma₂guan₅ juɨg₅₄ 'lióg₂ dsen₅₄ Lisias. 
\p  
\v 23 Jaun₂ ca₂jmo₃ gui'₅₄ dsi₄má'₂ 'éi'₃ ca₂tsɨ́'₃ juɨg₅₄ 'lióg₂ quiáin₅ a₂toin'₂ Pa₄ né'₃ 'má₃. La₁ ca₂cuë₃ bá₄ jmɨg₄ lé₂ bá₄ dsɨ₃jag₅₄ a₂mei₅₄ quián₅ Pa₄ a₂jme₃'o₅₄ në₁jua'₂ 'e₂ ca₂rë₃'nió'₅ quió'₅. 
\p  
\v 24 Jme₁ca₂dsɨn₃ tɨn₃-'nɨ₅ jmɨg₄ cang₂ jaun₂, ca₂dsióg₃ táng₃ Fé₁ quiain'₅₄ 'io₅₄ quiáin₅ i₂chen₂ Drusila, i₂lɨ́n₅ judía. Jaun₂ ca₂jmo₃ Fé₁ 'éi'₃ ca₂i₁quian₅₄ dsa₂ Pa₄, jaun₂ ca₂nág₂ të₁lia'₂ ca₂dsia₃ 'éi₂ juɨ₁lia'₂ 'a₂ lia'₂ lë́₅ a₂'éin₂ të₂le₃ quió'₅ Cristo Jesús.  
\v 25 La₁ jme₁ca₂dsia₃ Pa₄ a₂'nió'₅ cán₂ dsa₂ caun₂ juɨ₅ co₂dsau₅, a₂'nió'₅ jme₃'uán₂ dsa₂ dsɨ́₅ 'ŋiog₅; jme₁ca₂dsia₃ Pa₄ a₂já₅ caun₂ jmɨg₄ a₂con₂ Diú₄ jág₁ dsau₅ quió'₅ le₂jan₂ le₂jan₂ dsa₂, jaun₂ guë́₄ ca₂rë₃gó'₅ gui'₅₄ Fé₁. Jaun₂ ca₂juá'₂: 
\p ―Dse₃ bá₄ guang'₂ táng₃ ja₁jme₁'eng'₅₄. Në₅ bá₄ të́₄ táng₃ jmɨg₄ siá'₂ jë₁ma₂jɨng₅₄. 
\p  
\v 26 Jme₁'ɨ́n₂ dsɨ́₅ Fé₁ a₂jme₁jén'₃ Pa₄ cu₄ ia₁jaun₂ jme₁lió₂. Jaun₂ 'lióng₂ ráun₂ jme₁ca₂të₃ a₂dsia₂₃ jág₁ quiong'₅₄.  
\v 27 Tɨn₃ ŋi₂ ca₂ŋɨ́₂ le₂jaun₂ jme₁ca₂o₃'ɨ́n₃ gui'₅₄ Fé₁ ta₁ a₂jme₁lɨ́in₄, a₂ca₂'í₃ táng₃ Porcio Festo. Jaun₂ lia'₂ ma₂'en₅₄ jaun₂ bá₄ Pa₄ né'₃ 'má₃ ca₂jmo₃ Fé₁, ia₁jaun₂ të₃tsɨin'₅₄ dse₃ quian'₅₄ dsa₂ judíos. 
\c 25  
\s1 Ca₂ŋe₄ Pa₄ ne₄ Dsi₄má'₂ Festo 
\p  
\v 1 Ma₂'nɨ₅ jmɨg₄ a₂ca₂gue₃ Festo ta₁ dsi₄má'₂, ca₂'uɨin₂ juɨg₂ Cesarea ca₂uɨ́g₂ juɨg₂ Jerusalén.  
\v 2 Ja₁jaun₂ ca₂jmo₃ jme₂dsa₂ dsen₅₄ quiain'₅₄ ca₂le₃jɨ́n₃ juɨg₅₄ jme₂dsa₂ quián₅ dsa₂ judíos, ca₂mɨ₃ dso₄ ne₄ Festo a₂'nɨi₂₃ Pa₄.  
\v 3 Ján₃ bá₄ ca₂mɨ₃ a₂jmo₃ 'éi₂ dse₃ dsɨ́₅, a₂jmo₃ 'éi'₃ a₂dsɨ₃quián₂ dsa₂ Pa₄ a₂dsɨ₃jó₂ juɨg₂ Jerusalén. Ia₁ a₂jme₁ma₂lɨ'₅₄ jág₁ a₂jme₁jŋɨi'₃ Pa₄ le₂'i₄ juɨ₅.  
\v 4 La₁ jaun₂ ca₂ŋag₃ Festo a₂'ein₅₄ juɨ₅ dsáin'₃ ŋi'₅₄ ta₁ të₂ juɨg₂ Cesarea ja₁'en₅₄ Pa₄ né'₃ 'má₃.  
\v 5 Jaun₂ ca₂juá'₂: 
\p ―Juɨ₁ja₂lén₂ dsa₂ i₂lɨ́n₅ ta₁ quián'₂ 'nia'₂ quian'₅₄ jniá₂ juɨ₅ Cesarea, juɨ₁'nag₁₂ ja₁jaun₂ chi₂jua'₂ cha₂ a₂rɨin₂. 
\p  
\v 6 Jŋia'₅₄ con'₂ jŋia₃ o₃ guia₃ jmɨg₄ bá₄ ca₂'í₃ Festo Jerusalén, jaun₂ ca₂ŋái'₃ Cesarea. Jme₁jnia₃ táng₃ jaun₂, ca₂i₁gua₂ ne₄ta₁ ja₁qui₂dsɨ₂₃ 'éi'₃, jaun₂ ca₂jmo₃ 'éi'₃ a₂ca₂i₁quian₅₄ dsa₂ Pa₄.  
\v 7 Jme₁ca₂'í₃ Pa₄ dsi₂néi₂ ne₄ta₁, jaun₂ ca₂jme₃quián₃ dsa₂ judíos i₂ja₂lén₂ juɨg₂ Jerusalén. Jaun₂ 'lióng₂ ne₅₄ dso₄ juë'₂ qui₂ca₂bóin'₂ Pa₄. La₁ tsá₃ ca₂tió'₃ jme₃jniai₂₃ a₂dsón'₂ dsau₅ ca₂le₃jë́₃ dso₄ a₂bóg'₂ jaun₂.  
\v 8 Jaun₂ ca₂jáng'₃ Pa₄ jág₁ dsau₅ a₂lióin₂ 'ŋiog₅, ca₂juá'₂: 
\p ―'I₁caun₂ dso₄ në₅ tsá₃ ma₂'no₃ jniá₂, on₃ guë'₂ jua'₅₄ a₂tsá₃ ma₂ca₂rë₃tei₅₄ con'₂ lë́₅ Si₂ 'Éi'₃ quió'₅ dsa₂ judíos, on₃ guë'₂ le₃quió'₅ guá'₅ templo jua'₅₄ a₂ma₂'no₃ dso₄, on₃ guë'₂ jua'₅₄ a₂cha₂ dso₄ ma₂ca₂táng'₂ ja₁con₂ gui'₅₄ emperador romano. 
\p  
\v 9 La₁ia₁ jme₁'nio₃ Festo të₃tsɨin'₅₄ rë₂ quian'₅₄ dsa₂ judíos, jaun₂ ca₂ŋɨ́i'₃ Pa₄: 
\p ―¿'Niog'₂ guang'₅₄ të₂ juɨg₂ Jerusalén ia₁jaun₂ ja₁jaun₂ jme₁rë₂ jniá₂ quiáng'₂? 
\p  
\v 10 Jaun₂ ca₂ŋag₃ Pa₄: 
\p ―Jaun₂ guë'₂ ma₂chén'₅ jniá₂ ja₁lá₃ caun₂ ne₄ta₁ ja₁tén₄ gui'₅₄ emperador romano ja₁dsi₂ten₅₄ qui₃dsɨ₅ dsa₂ 'éi'₃ quió₃. Ia₁ rë₂ bá₄ ŋi'₅₄ 'ne₂, tsá₃ 'e₂ dso₄ rɨn₂ jniá₂ ja₁con₂ dsa₂ judíos.  
\v 11 Chi₂jua'₂ cha₂ guë'₂ dso₄ a₂ma₂'no₃, a₂ca₂tɨ́ng₂ jóng₂, jaun₂ guén₄ bá₄ jniá₂ 'mú₃ quió₃. La₁ chi₂jua'₂ tsá₃ dsau₅ dso₄ a₂bóg'₂ dsa₂ në₅, jaun₂ 'i₁jan₂ tsá₃ 'ein₂ ca₂tɨ́n₂ jua'₅₄ a₂jáng'₂ jniá₂ o₄gú₃ dsa₂ 'éi₂. Jaun₂ mɨ₅ jniá₂ nég'₄ ne₄ gui'₅₄ emperador, ia₁jaun₂ 'éi₂ qui₃dsɨ₅ 'éi'₃ ja₁cong₂. 
\p  
\v 12 Jme₁ca₂lë₃ dsia₅ Festo jág₁ quian'₅₄ dsa₂ i₂to'₂ jág₁ dse₃ quiáin₅, jaun₂ ca₂juá'₂ ca₂tsɨ́'₃ Pa₄: 
\p ―Ia₁ ma₂në₂mɨ'₅₄ guang'₅₄ ne₄ gui'₅₄ emperador, ne₄ 'éi₂ guang'₅₄ guë'₂ jaun₂. 
\s1 Ma₂chén'₅ Pa₄ ne₄ Rag₅₄ Agripa 
\p  
\v 13 Tɨn₃-'nɨ₅ jmɨg₄ cang₂ jaun₂, ca₂dsióg₃ Rag₅₄ Agripa quiain'₅₄ Berenice ca₂i₁lein₅₄ juɨg₂ Cesarea i₁cuɨin₃ Diú₄ Festo.  
\v 14 Ca₂tóin'₂ bá₄ tɨn₃-'nɨ₅ jmɨg₄ ja₁jaun₂, jaun₂ ca₂dsia₃ Festo ca₂tsɨ́'₃ Rag₅₄ Agripa jág₁ jaun₂ quió'₅ Pa₄. Jaun₂ ca₂juá'₂: 
\p ―'En₅₄ jan₂ dsa₂ 'né₅ 'má₃ ja₁lá₃, i₂ca₂ton'₂ Fé₁.  
\v 15 Lia'₂ con'₂ jme₁'en₅₄ jniá₂ juɨg₂ Jerusalén, ca₂mɨ₃ dso₄ ne₃ jniá₂ juɨg₅₄ jme₂dsa₂ quián₅ dsa₂ judíos, dsa₂ can'₅₄ quiáin₅ në́₃, a₂'nɨi₂₃ dsa₂ 'éi₂, a₂jme₁mɨ₂₃ jme₁qui₁dsɨ₅ jniá₂ 'éi'₃ quió'₅, a₂'ë́₄ uɨg₅ në́₃.  
\v 16 Jaun₂ bá₄ lë₃ ca₂ŋag₄ jniá₂ ca₂juɨ́g₂: “Tsá₃ le₂jaun₂ tɨn₂ quió'₅ dsɨ₂tan₅₄ romano jua'₅₄ qui₃dsɨ₅ 'éi'₃ quió'₅ jan₂ dsa₂, të₃ tsá₃ ma₂në₂jɨ́in₂ dsa₂ i₂qui₂'nag₅ quió'₅, të₃ tsá₃ ma₂cuɨn₅ jmɨg₄ lióin₃ 'e₂ dso₄ bóg'₂ dsa₂.”  
\v 17 Jaun₂ lë₃, jme₁ca₂o₃léin₂ ja₁lá₃, dsɨ₂juɨ₅ bá₄ ca₂i₁gua₂ ne₄ta₁ quió₃ jme₁jnia₃ jaun₂, jaun₂ ca₂jmo₃ 'éi'₃ ca₂i₁quian₅₄ dsa₂ dsa₂ 'éi₂.  
\v 18 La₁ jme₁ca₂o₃lén₂ dsa₂ i₂'nag₅, tsá₃ 'e₂ dso₄ ca₂bóg'₂ dsa₂ juɨ₁lia'₂ dso₄ jme₁lɨ́n₂ jniá₂ a₂jme₁bóg'₂.  
\v 19 Jŋia'₅₄ lia'₂ a₂jaun₂ bá₄ 'nɨi₂₃ 'éi₂ lia'₂ con'₂ lë́₅ 'Éi'₃ Juá'₅ quió'₅, ia₁ a₂juá'₂ 'ɨin₂₃ jan₂ i₂chen₂ Jesús i₂ca₂jon₃, jaun₂ juá'₂ Pa₄ i₂chan₂ bá₄ 'éi₂.  
\v 20 Ia₁ tsá₃ guion₅₄ 'a₂ lia'₂ jme₁rë₂ jág₁ jaun₂, jaun₂ bá₄ lë₃ ca₂juɨ́g₂ Pa₄ chi₂jua'₂ 'nio₃ dsó₃ juɨ₅ Jerusalén, ia₁jaun₂ qui₃dsɨ₅ dsa₂ 'éi'₃ ja₁jaun₂.  
\v 21 La₁ 'ŋiog₅ në́₃ ca₂mɨ₃ a₂qui₃dsɨ₅ 'éi'₃ gui'₅₄ emperador Augusto, jaun₂ bá₄ lë₃ ca₂jmo₃ jniá₂ 'éi'₃ lia'₂ ma₂'ein₅₄ në₅ 'né₅ 'má₃, ca₂lia'₂ ca₂cuɨn₃ jmɨg₄ a₂tsɨin₅₄ ne₄ gui'₅₄ emperador. 
\p  
\v 22 Jaun₂ ca₂juá'₂ gui'₅₄ Agripa ca₂tsɨ́'₃ Festo: 
\p ―Ján₃ bá₄ 'nio₃ jniá₂ nag₅₄ jág₁ quió'₅ dsa₂ 'éi₂. 
\p Jaun₂ ca₂ŋag₃ táng₃ Festo: 
\p ―'Ióg₃ nág'₁ jág₁ quió'₅. 
\p  
\v 23 Jaun₂ jme₁jnia₃ jaun₂, ca₂dsióg₃ gui'₅₄ Agripa quian'₅₄ Berenice. 'Ŋio₅ lɨn₃ jlá'₁ ca₂i₃toin'₅₄ dsi₂néi₂. Ca₂dsi₃lén₂ juɨg₅₄ 'lióg₂ dsen₅₄, ca₂le₃jɨ́n₃ dsa₂ dsen₅₄ quián₅ juɨg₂ ca₂dsi₃lén₂. Jaun₂ ca₂jmo₃ Festo 'éi'₃ a₂ca₂i₁quian₅₄ dsa₂ Pa₄.  
\v 24 Jaun₂ ca₂juá'₂: 
\p ―'Ne₂ Rag₅₄ Agripa, ca₂le₃jɨ́n'₃ 'nia'₂ dsa₂ i₂le₁ŋɨ'₂ ja₁lá₃ quian'₅₄ jnia'₅₄, la₂ chén'₅ dsa₂ la₂. Juɨn₅ dsa₂ judíos i₂chan₂ juɨg₂ Jerusalén, dsa₂ chan₂ juɨg₂ Cesarea ja₁lá₃ në́₃, 'nɨi₂₃ dsa₂ la₂. Jaun₂ ca₂le₃jë́₃ jmɨg₄ tsá₃ cán₂ jág₁, a₂mɨ₂₃ jón₂ i₂në₅.  
\v 25 La₁ con'₂ lɨ́n₂ jniá₂, tsá₃ 'e₂ dso₄ rɨin₂ jua'₅₄ a₂dsi₂ten₅₄ jóin₂. Ton'₂ mɨ₂₃ táng₃ 'ŋiog₅ a₂dsáin'₃ ne₄ gui'₅₄ emperador Augusto, jaun₂ lë₃ ma₂i₂jiog₅ dsɨ₃ dsiain'₅₄ co₂ŋei'₅₄ ne₄ 'éi₂.  
\v 26 Ia₁ tsá₃ guion₅₄ 'e₂ jág₁ dsón'₂ tó'₄ ne₄ si₂ a₂juɨg₅₄ gui'₅₄ emperador a₂'nɨ́g₄ i₂në₅. Jaun₂ bá₄ lë₃ i₂jŋiái₂ ne'₅₄ 'nia'₂, la₁ 'ŋio₅ dsen₅₄ guë́₄ le₂'uɨg₅₄ ne'₅₄ 'ne₂ gui'₅₄ Rag₅₄ Agripa, ia₁jaun₂ caun'₅₄ jág₁ dsau₅ quió'₅, ia₁jaun₂ cha₂ a₂tó'₄ ne₄ si₂ 'e₂ a₂rë₂cáin'₂.  
\v 27 Ia₁ tsá₃ dse₃ jniá₂, lɨ́n₂ jniá₂, jua'₅₄ a₂dsiang'₅₄ jan₂ dsa₂ chi₁'ŋei'₅₄ jua'₅₄ a₂tsá₃ juɨg₅₄ 'e₂ lë₃ 'nag₅ dsa₂. 
\c 26  
\s1 Ca₂jáng'₃ Pablo jág₁ dsau₅ quió'₅ ne₄ Rag₅₄ Agripa 
\p  
\v 1 Jaun₂ ca₂juá'₂ Rag₅₄ Agripa ca₂tsɨ́'₃ Pa₄: 
\p ―Lé₂ bá₄ jua'₅₄ jág₁ a₂jang'₅₄ jág₁ dsau₅ o₄quiáng'₂ 'ŋiag'₂. 
\p Jaun₂ ca₂chóg'₃ Pa₄ gu₂ ca₂jme₃lióg₃ ca₂juá'₂ le₂la₂: 
\p  
\v 2 ―Jmo₅ jniá₂ dsɨ₃, 'e₂ bá₄ dsen₃ jniá₂, a₂ma₂chéng'₅ ne'₅₄ 'ne₂ Rag₅₄ Agripa, a₂long₅₄, juɨg₅₄ 'ne₂ 'a₂ lia'₂ lë́₅ ca₂le₃jë́₃ dso₄ a₂bóg'₂ dsa₂ judíos jniá₂.  
\v 3 Ia₁ ma₂ŋi'₅₄ bá₄ 'ne₂ co₂rë₂ 'a₂ lia'₂ lë́₅ tag₄ a₂chí'₅ quián₂ jnia'₅₄ dsa₂ judíos, quian'₅₄ jág₁ a₂tság₂ jnia'₅₄ jɨn₄ rɨn'₅₄ në́₃. Jaun₂ lë₃ mɨ₅ jniá₂ ne'₅₄ a₂jmó'₂ juɨn'₂ 'au'₂ a₂nág'₁ jág₁ quió₃. 
\s1 Ca₂dsia₃ Pablo, le₂la₂ bá₄ jme₁lɨ́in₄ né'₃ a₂jéin'₃ le₃quió'₅ Te₁gui'₅₄ 
\p  
\v 4 ’Ca₂le₃jɨ́n₃ bá₄ dsa₂ judíos le₁ŋi₅ 'a₂ lia'₂ jme₁jmo₅ jniá₂ juɨg₂ go₃ quian'₅₄ jë₄ juɨg₂ Jerusalén në́₃. Jaun₂ le₁ŋi₅ bá₄ dsa₂ 'a₂ lia'₂ jme₁ŋɨ₅ jniá₂ lia'₂ bɨng'₅₄.  
\v 5 Le₁ŋi₅ 'éi₂ ján₃, jaun₂ lé₂ bá₄ jáng₃ jág₁ dsau₅ në₁jua'₂ 'nio₃, lia'₂ con'₂ jme₁i₃juɨng'₂ bá₄, ma₂lɨ́n₅ bá₄ jniá₂ dsa₂ fariseo. Jaun₂ jnia'₅₄ i₂jme₁lág₄ fariseos jme₁jme₂tí₁ guë́₄ 'ŋio₅ lɨn₃ juá'₅ quián₂.  
\v 6 Ia₁ a₂'éng₂ a₂jme₃jen'₅₄ Diú₄ 'lag₄, juɨ₁lia'₂ lë́₅ jág₁ quió'₅ ca₂cuë́'₃ gui'₅₄ can'₅₄ quián₂ jnia'₅₄ ma₂lɨ́g'₂, 'uɨg₅₄ jaun₂ bá₄ a₂chéng'₅ ja₁lá₃, a₂con₂ dsa₂ jág₁ dsau₅ quió₃.  
\v 7 Ta₁guia₃-tɨ́n₂ bá₄ cho'₅₄ tsɨ₁jon₂ dsa₂ juɨg₂ jnia'₅₄ jme₂juɨin'₂ Diú₄, jaun₂ lia'₂ 'uë₂-jmɨ₂ bá₄ jme₂ti₃ ta₁ ne₄ Diú₄ ia₁ le₁'ɨ́n₂ dsɨ́₅ a₂jme₂ti₃ Diú₄ jág₁ jaun₂ quió'₅ ca₂cuë₃. 'Uɨg₅₄ jaun₂ bá₄ në́₃, 'ne₂ gui'₅₄ Rag₅₄ Agripa, 'uɨg₅₄ ia₁ a₂'ɨ́n₂ dsɨ₃ jniá₂ le₂jaun₂ bá₄, a₂'nag₅ dsa₂ judíos jniá₂.  
\v 8 ¿'E₂ 'uɨg₅₄ jmo'₂ 'nia'₂ 'au'₂ a₂tsá₃ quɨ'₅₄ Diú₄ jmɨg₄ jme₃jein'₅₄ 'lag₄? 
\s1 Ca₂dsia₃ Pa₄ 'a₂ lia'₂ qui₂ca₂co₃'ein₃ quió'₅ dsa₂ quián₅ Jesús 
\p  
\v 9 ’Jniá₂ 'ŋió₃, jme₁dsɨ₂jiog₅ dsɨ₃ le₂jŋiá₅ jme₁jmo₅₄ 'lióng₂ ne₅₄ cosas a₂jme₁jmag'₅₄ dsa₂ quián₅ Jesús chan₂ Nazaret.  
\v 10 Jaun₂ le₂në₅ ca₂jmo₃ jë₄ juɨg₂ Jerusalén. Quian'₅₄ 'éi'₃ ca₂cuë₃ juɨg₅₄ jme₂dsa₂, qui₂ca₂tong'₂ 'né₅ 'má₃ juɨn₅ lɨn₃ dsa₂ 'én₂.\f + \fr 26:10 \ft lit. “juɨn₅ lɨn₃ dsa₂ jŋió₅.” \f* Caun₂ bá₄ jág₁ jme₁lë́₄ quió₃ quian'₅₄ dsa₂ i₂ca₂jme₃dsian₅ i₂lɨn₅₄ dsa₂ i₂'én₂ 'éi₂.  
\v 11 'Lióng₂ ráun₂ qui₂ca₂'ë́₃ jniá₂ uɨg₅, ia₁jaun₂ jmo₃ tion₅₄ a₂tí₂ a₂'éin₂. Le₂jaun₂ bá₄ qui₂ca₂jmo₃ jniá₂ le₂tan₅₄ guá'₅ sinagogas, ca₂lia'₂ ca₂i₁'éin₄ le₂tan₅₄ juɨg₂ go₄ dsa₂ sián'₂ në́₃, ia₁ 'ŋio₅ lɨn₃ jme₁'ŋiai₅₄ jniá₂. 
\s1 Ca₂dsia₃ táng₃ Pa₄ 'a₂ lia'₂ ca₂lë₃ a₂ca₂jéin'₃ 
\r (Hechos 9:1-19; 22:6-16) 
\p  
\v 12 ’Ta₁ jaun₂ jme₁ŋó₃ jniá₂ juɨ₅ Damasco ca₂chei₃ dsa₂ quian'₅₄ bí₂ 'éi'₃ ca₂cuë₃ juɨg₅₄ jme₂dsa₂ a₂jme₁i₂cháng'₃ dsa₂ 'én₂ i₂jme₁tion'₅₄ ja₁jaun₂.  
\v 13 La₁ lia'₂ con'₂ jme₁ŋó₃ le₂'i₄ juɨ₅, 'ne₂ gui'₅₄ rag₅₄, con'₂ dsi₃ŋí'₃ bá₄ jaun₂, ca₂jág₃ jniá₂ caun₂ si₂ a₂já₃ juɨ₅ guei'₅₄ i₂juɨ́g₃, ca₂tág₃ le₃lág'₃ quió₃, quian'₅₄ dsa₂ i₂jme₁quiang'₅₄. 'Ŋio₅ lɨn₃ guë́₄ tág₅ con'₂ guë́₄ 'iog₂.  
\v 14 Jaun₂ ca₂le₃jág₃ bá₄ jnia'₅₄ i₂gau'₅₄ 'uë₃ dsɨ₂juɨ₅ le₂jaun₂. Jaun₂ ca₂nag₃ caun₂ jág₁ ca₂juá'₂ dsa₂ quian'₅₄ jág₁ jmei₅ hebreo:\f + \fr 26:14 \ft o₃, arameo.\f* “Saulo, Saulo, ¿'e₂ lë₃ co₂'éin'₅ jniá₂? A₂jŋia'₅₄ jmag'₅₄ uɨg₅ 'ŋiag'₂ bá₄, jmo'₂ juɨ₁lia'₂ jmo₅ ca₁juɨ₅ quia'₂ 'uë₃ a₂jnáu₅ nei'₅₄ nɨ₁'ma₂ chen'₂.”  
\v 15 Jaun₂ ca₂ŋag₄ jniá₂: “¿'Ein₂ bá₄ 'ne₂, gui'₅₄?” Jaun₂ ca₂ŋag₃ táng₃: “Jesús bá₄ jniá₂ i₂co₂'én'₅ 'ne₂.  
\v 16 La₁ nau₂, chí'₂ tag'₅₄, ia₁ në₂jme₁jniag₅ ne'₅₄ 'ne₂, ia₁ 'nio₃ jme₁ti'₄ ta₁ ne₃, ia₁jaun₂ jang'₅₄ jág₁ dsau₅ 'e₂ në₂jag'₅₄ në₃, quian'₅₄ a₂jag'₅₄ guë́₄ cang₂ a₂jme₁jnia₅ jniá₂.  
\v 17 Tsɨn₅₄ jniá₂ 'ne₂, jaun₂ gog'₅₄ ja₁con₂ dsɨ₂nau₂, jaun₂ jmo₅₄ bá₄ jniá₂ 'í₁ 'ne₂ ia₁jaun₂ tsá₃ jmóg'₂ dsa₂ juɨg₂, on₃ guë'₂ dsɨ₂nau₂ në́₃.  
\v 18 Jaun₂ juɨ₅ ja₁con₂ dsa₂ 'éi₂ tsɨn₅₄ jniá₂ 'ne₂, ia₁jaun₂ le₃jnio₂ ne₄ dsa₂, ia₁jaun₂ 'uɨ́in₃ jë₄ qui₁né'₃, qui₃jéin'₃ ne₅₄ ja₁tág₅ si₂; ia₁jaun₂ tsá₃ lë́₅ jua'₅₄ tioin'₅₄ guë́₄ 'éi'₃ quió'₅ Satanás, ia₁jaun₂ dsi₁lein₃ ja₁con₂ Diú₄, dsɨ₃'én₂ bá₄ dsáu₁, ia₁jaun₂ gue₃ juɨ₁lia'₂ a₂ca₂tɨ́n₂ dsa₂ i₂lë́₅ 'í₁ quián₅ Diú₄, 'uɨg₅₄ ia₁ a₂'éin₂ le₃quió₃ jniá₂.” 
\s1 Ca₂jme₃ti₃ Pa₄ a₂ca₂jág₃ jaun₂ 
\p  
\v 19 ’Jaun₂ le₂në₅ bá₄, 'ne₂ gui'₅₄ Rag₅₄ Agripa, tsá₃ jua'₅₄ a₂tsá₃ ca₂jme₁ti₁₂ con'₂ lë́₅ a₂ca₂jág₃ a₂já₃ guei'₅₄.  
\v 20 Jaun₂ lë₃, jë₄ juɨg₂ Damasco ca₂'ë́₃ le₂'uɨg₅₄ jág₁ dse₃. Jaun₂ guë́₄ ca₂ŋeg₅₄ juɨ₅ Jerusalén, le₂tan₅₄ juɨg₂ ja₁tén₄ 'uë₃ Judea në́₃. Ján₃ bá₄ ca₂ŋeg₅₄ jɨn₄ dsɨ₂nau₂, ca₂i₁chei₁₂ a₂'nió'₅ dsɨ₃quén'₅ dsɨ́₅, jéin'₃ le₃quió'₅ Diú₄, a₂jme₃li₅₄ a₂ma₂ca₂rë₃tsɨ́n₃ dsɨ́₅ të₂le₃ quian'₅₄ ca₂le₃jë́₃ a₂jmo₂₃.  
\v 21 'Uɨg₅₄ jaun₂ bá₄ a₂ca₂jŋau'₃ dsa₂ judíos jniá₂ i₁dsi₅ guá'₅ templo a₂jme₁'nio₃ jme₁jŋag'₃.  
\v 22 La₁ Diú₄ bá₄ jme₂'o₅₄ cuë₂₃ bí₂ a₂chan'₅₄ tiá₂ jág₁ quió'₅ ca₂të₂ jmɨg₄ në₃, qui₂jáng'₅ jág₁ dsau₅ a₂juɨ́g₂ lia'₂ dsa₂ dsen₅₄ lia'₂ dsa₂ lë₁dsa₂ në́₃. 'I₁caun₂ jág₁ siá'₂ tsá₃ juɨ́g₂ jniá₂ dsa₂, jŋia'₅₄ con'₂ lë́₅ jág₁ ca₂juá'₂ dsa₂ i₂jme₁'ë́₂ jág₁ quián₅ Diú₄ ma₂lɨ́g'₂, quian'₅₄ a₂ca₂juá'₂ Moisés, jme₁ca₂juá'₂ ca₂le₃jë́₃ 'e₂ niog₅ lé₂,  
\v 23 co₂'nió'₄ a₂tion₅₄ 'nió'₅ ŋág₃ uɨg₅ I₂rë₂'ɨ́n₁ quián₅ Diú₄; jaun₂ 'éi₂ bá₄ lén₂ i₂le₂'uɨg₅₄ i₂jen'₅₄ jɨn₄ 'lag₄, ia₁jaun₂ dsɨ₃'ë́₃ jág₁ dse₃ a₂lión₂ dsa₂, juɨ₁lia'₂ caun₂ si₂ a₂tág₅ lia'₂ jɨn₄ dsa₂ juɨg₂ quián₂ jnia'₅₄, lia'₂ jɨn₄ dsɨ₂nau₂ në́₃. 
\s1 Ca₂jmo₃ Pa₄ bí₂ a₂jme₁le₂'én₂ Rag₅₄ Agripa të₂le₃ quió'₅ Jesús 
\p  
\v 24 Jme₁ca₂juá'₂ Pa₄ jág₁ jaun₂ a₂jme₁lióin₂ 'ŋiog₅ ne₄ dsɨ₂tan₅₄, jaun₂ ca₂guió'₃ Dsi₄má'₂ Festo ca₂juá'₂: 
\p ―¡A₂lë₁të₂'ɨ'₂ bá₄ 'ne₂, Pa₄! Ia₁ a₂ŋɨ́₄ lë₃ 'ɨ'₂ si₂, jaun₂ ma₂ca₂rë₃ŋág'₅. 
\p  
\v 25 Jaun₂ ca₂ŋag₃ táng₃ Pa₄: 
\p ―Tsá₃ ŋá₅ jniá₂, 'ne₂ gui'₅₄ Dsi₄má'₂ Festo. Jág₁ dsau₅ dsón'₂ bá₄ a₂juá'₅ jniá₂ la₂.  
\v 26 La₂ bá₄ guá₅ gui'₅₄ Rag₅₄ Agripa i₂cuɨ́'₅ dse₃ 'a₂ lia'₂ lë́₅ jág₁ në₅. A₂jaun₂ bá₄ lë₃ tiá₂ dsɨ₃ a₂juá'₅ ne₅₄, ia₁ dsón'₂ ŋi₅ ca₂le₃jë́₃ jág₁ në₅, ia₁ on₃jua'₅₄ a₂ca₂lë₃ caun₂ ja₁quióng₄ con'₂ të₃co'₅₄.  
\v 27 ¿'Én'₂ 'ne₂ gui'₅₄ Rag₅₄ Agripa jág₁ a₂ca₂juá'₂ dsa₂ i₂jme₁'ë́₂ jág₁ quián₅ Diú₄? Guion₄ bá₄ jniá₂ a₂'én'₂ 'ne₂. 
\p  
\v 28 Jaun₂ ca₂ŋag₃ Rag₅₄ Agripa: 
\p ―Ca₂juɨg₄ mei'₂ tsá₃ jme₂'uang'₅₄ dsɨ₃ a₂léng₂ jan₂ dsa₂ cristiano. 
\p  
\v 29 Jaun₂ ca₂juá'₂ táng₃ Pa₄: 
\p ―Chi₂jua'₂ ca₂juɨg₄ o₃ tsá₃ ca₂juɨg₄ 'e₂, 'e₂ guë́₄ dse₃ në₁jua'₂ jmo₃ Diú₄ on₃jua'₅₄ jmá'₃ 'ne₂, ján₃ bá₄ le₂jaun₂ ca₂le₃jɨ́n₃ dsa₂ i₂nag₅ jág₁ quió₃ në₃, a₂léin₂ juɨ₁lia'₂ lɨ́n₅ jniá₂, o₁jŋia'₅₄ guë́₄ on₃jua'₅₄ quian'₅₄ nɨ₁ŋí₁ cadena juɨ₁lia'₂ chén'₅ jniá₂ la₂. 
\p  
\v 30 Jme₁ma₂ca₂lë₃ juá'₂ Pa₄ le₂jaun₂, ca₂nau₂ Rag₅₄ Agripa quian'₅₄ Dsi₄má'₂ Festo, 'io₅₄ Berenice në́₃, ca₂'uɨin₂ co₂lë₅ quiain'₅₄ ca₂le₃jɨ́n₃ guë́₄ dsa₂ i₂jme₁tion'₅₄.  
\v 31 Con'₂ ca₂i₃léin₂ cau₅, ca₂i₁dsia₂ 'a₂ lia'₂ jmo₃ jág₁ jaun₂ quió'₅ Pa₄, jaun₂ ca₂juá'₂ ca₂tsɨ́'₃ rɨin'₅₄: 
\p ―'I₁ca₂juɨg₄ tsá₃ 'e₂ ma₂jmo₃ dsa₂ në₅, jua'₅₄ a₂ca₂tɨ́in₂ 'i₄ 'éi'₃ jóin₂, on₃ guë'₂ jua'₅₄ a₂dsi₂ten₅₄ 'ein₅₄ né'₃ 'má₃ në́₃. 
\p  
\v 32 Jaun₂ ca₂juá'₂ Rag₅₄ Agripa ca₂tsɨ́'₃ Dsi₄má'₂ Festo: 
\p ―Jme₁lé₂ bá₄ jme₁lión₂ dsa₂ në₅, jua'₅₄ mei'₂ guë́₃ tsá₃ ca₂mɨ₃ 'ŋiog₅ a₂jme₃rë́₃ gui'₅₄ emperador jág₁ quió'₅. 
\c 27  
\s1 Ca₂dsián'₂ dsa₂ Pa₄ juɨ₅ Roma 
\p  
\v 1 Jme₁ca₂jmo₃ dsa₂ jág₁ a₂chei₃ jnia'₅₄ juɨ₅ 'uë₃ Italia, jaun₂ Pa₄ quian'₅₄ guë́₄ dsa₂ i₂le₁'ŋe'₅₄ rɨin'₅₄ ca₂jáng'₂ dsa₂ o₄gú₃ jan₂ juɨg₅₄ 'lióg₂ i₂chen₂ Julio, i₂tén₅ të₂le₃ quió'₅ co₂nió'₃ 'lióg₂ i₂të́'₂ dsa₂ quián₅ Augusto.  
\v 2 Jaun₂ ca₂tió'₄ jnia'₅₄ caun₂ nɨ₁barco a₂já₃ juɨ₅ 'o₄ jmɨ₁ŋí'₄ ja₁chei₂ Adramitio a₂jme₁ma₂chí'₅ dsáu'₃ juɨ₅ 'o₄ jmɨ₁ŋí'₄ a₂niog₅ 'uë₃ Asia. Jme₁quian'₅₄ jnia'₅₄ Aristarco dsa₂ chan₂ Tesalónica, juɨg₂ tén₅ 'uë₃ Macedonia.  
\v 3 Jme₁jnia₃ táng₃ jaun₂, ca₂dsi₃náu₅ jnia'₅₄ 'o₄ jmɨ₁ŋí'₄ juɨg₂ Sidón. Ja₁jaun₂ ca₂dsia₃ ŋéi₂ dsɨ́₅ Julio ja₁con₂ Pa₄, ca₂cuë₃ bá₄ jmɨg₄ ca₂i₁jɨin₁₂ a₂mei₅₄ quiáin₅, ia₁jaun₂ jme₃'o₅₄ 'éi₂ 'e₂ a₂'nió'₅ quió'₅.  
\v 4 Jme₁ca₂'uag₂ jnia'₅₄ juɨg₂ Sidón, ca₂i₃náu₅ jnia'₅₄ juɨ₅ ja₁jniá₂ Chipre të₂le₃ gu₂ jen₅, ia₁ të₂le₃ siá'₂ bá₄ jme₁'ei₅ dsí₂.  
\v 5 Jaun₂ ca₂ŋag₅₄ jnia'₅₄ jmɨ₁ŋí'₄ chei'₅₄ 'uë₃ Cilicia quian'₅₄ Panfilia. Jaun₂ dsi₃náu₅ jnia'₅₄ ja₁chei₂ Mira, juɨg₂ tén₅ 'uë₃ Licia. 
\p  
\v 6 Ja₁jaun₂ ca₂dsó'₂ juɨg₅₄ 'lióg₂ caun₂ nɨ₁barco já₃ juɨg₂ Alejandría, a₂ma₂'i₄ juɨ₅ dsáu'₅ juɨ₅ Italia. Jaun₂ ca₂jmo₃ 'éi'₃ ca₂tió'₄ jnia'₅₄ nɨ₁barco, jaun₂ ca₂i₃náu₅ táng₃.  
\v 7 'Lióng₂ jmɨg₄ ca₂tió'₄ jnia'₅₄ nɨ₁barco, ia₁ a₂i₃náu₅ të₂'ua₁. Jaun₂ të₃ quian₅ ta₁ le₂jaun₂ bá₄ dsi₃náu₅ ja₁chei₂ Gnido. Ia₁ lia'₂ ma₂'ei₅ jaun₂ bá₄ dsí₂ le₃siá'₂, jaun₂ ca₂ŋag₅₄ jnia'₅₄ cau₅ ja₁chei₂ Salmón, ca₂i₁jein'₅₄ le₃ja₁chei₂ Creta, 'uë₃ 'i₄ jë₄ jmɨ₁ŋí'₄.  
\v 8 Jaun₂ të₃ quian₅ ta₁ le₂jaun₂ bá₄ ca₂dsi₃náu₅ jnia'₅₄ ja₁të́'₂ dsa₂ 'O₄ Jmɨ₁ŋí'₄ Dse₃, ja₁ma₂quián₅ juɨg₂ Lasea. 
\p  
\v 9 'Lióng₂ jmɨg₄ ca₂rë₃'ag₄ jnia'₅₄. Ma₂të́₂ jein₂ a₂ma₂go'₂ i₃nio₄ dsa₂ juɨ₅ ne₄ jmɨ₁ŋí'₄, ia₁ a₂ma₂ja₂quián₃ jein₂ güɨ́g₂. Jaun₂ lë₃, jme₁ca₂juá'₂ Pa₄ ca₂tsɨ́'₃ dsa₂: 
\p  
\v 10 ―'Nia'₂ dsa₂, jág₅ jniá₂ 'ŋio₅ ma₂go'₂ quián₂ jniog₄ të₂le₃ ja₁dsau₅₄ në₅, ia₁ dsɨ₃'én₂ nɨ₁barco, lio₅₄ në́₃, ca₂të₂ guio₅₄ jniog₄ go'₂ dsióg₃ në₁jua'₂ 'e₂ ca₂lë₃. 
\p  
\v 11 La₁ juɨg₅₄ 'lióg₂ në́₃, tsá₃ juɨ₅ ca₂tón'₃ jág₁ jaun₂ quió'₅ Pa₄. Ca₂tón'₃ bá₄ juɨ₅ jág₁ quió'₅ dsa₂ juɨg₅₄ nɨ₁barco quian'₅₄ dsa₂ i₂quian₄ nɨ₁barco në́₃.  
\v 12 Ia₁ tsá₃ dse₃ 'o₄ jmɨ₁ŋí'₄ jaun₂ jua'₅₄ a₂jŋia₃ dsa₂ jein₂ güɨ́g₂ ja₁jaun₂, jaun₂ mei'₂ tsá₃ ca₂le₃jɨ́n₃ dsa₂ ca₂jmo₃ jág₁ a₂jme₁dsɨ₁náu₄ juɨ₅ ja₁tág'₄ juɨg₂ Fenice, caun₂ 'o₄ jmɨ₁ŋí'₄ quió'₅ Creta ja₁jniá₂ të₂le₃ noroeste quian'₅₄ të₂le₃ suroeste, ia₁jaun₂ dsɨ₁jŋia₁ jnia'₅₄ ja₁jaun₂ të₁lia'₂ ŋag₅ jein₂ güɨ́g₂. 
\s1 Ca₂'ág₂ dsí₂ tiá₂ lɨn₃ ne₄ jmɨ₁ŋí'₄ 
\p  
\v 13 Jaun₂ ca₂jme₃lióg₃ ca₂'ág₂ dsí₂ 'ua₁ a₂já₃ të₂le₃ sur. Jaun₂ caun₂ lé₂ dsɨ₃léin₂ bá₄ lɨ́in₂. Jaun₂ ca₂'uɨin₂ jaun₂ në́₃, ca₂i₃léin₂ juɨ₅ ma₂quián₅ chei'₅₄ 'uë₃ Creta.  
\v 14 La₁ jme₁co₂lág₂ jaun₂, ca₂já₃ dsí₂ tiá₂ lɨn₃ a₂chei₂ Nordecte ca₂të́₂ nɨ₁barco.  
\v 15 Jaun₂ ca₂jiog₃ dsí₂ le₃siá'₂ quió'₅ nɨ₁barco, ia₁ tsá₃ ma₃lé₂ jua'₅₄ dsau₅₄ jnia'₅₄ co₂dsau₅, jaun₂ co₂ŋei'₅₄ ca₂cuë́₁ jnia'₅₄ jmɨg₄ a₂jiog₃ dsí₂.  
\v 16 Jaun₂ ca₂ŋag₅₄ jnia'₅₄ le₃co'₅₄ caun₂ 'uë₃ pí'₁ ja₁chei₂ Cauda\f + \fr 27:16 \ft A₂lɨn₅₄ chog₅₄ si₂: “Clauda.” \f* a₂niog₅ jë₄ jmɨ₁ŋí'₄. Ja₁jaun₂ tsá₃ lɨn₄ ma₃'ei₅ dsí₂ tiá₂, jaun₂ të₃ quian₅ ta₁ le₂jaun₂, ja₂lag₃ bá₄ ca₂tián₃ jnia'₅₄ a₂ca₂quiong₅₄ táng₃ tsɨ₁mu₅ a₂jme₁le₁'ɨn₁ le₃chi₁co'₅₄.  
\v 17 Jme₁ca₂lë₃ ca₂tó'₂ dsa₂ tsɨ₁mu₅ guei'₅₄ 'ŋió'₃ nɨ₁barco, jaun₂ qui₂ca₂'néi₂ dsa₂ dse₃ nɨ₁barco quian'₅₄ tsɨ₁'nei₅₄ ia₁jaun₂ jmo₃ bén₂ guë́₄. Jaun₂ ia₁ jme₁gó'₅ dsa₂ a₂'í₂ nɨ₁barco ne₄ ti₁tsag₁ ja₁të́'₂ dsa₂ Sirte, jaun₂ ca₂sió₂ tsɨ₁'mɨ'₂ quió'₅ nɨ₁barco, jaun₂ ca₂cuë₃ jmɨg₄ a₂jiog₃ dsí₂.  
\v 18 Jme₁jnia₃ jaun₂, ia₁ tiá₂ bá₄ guë́₄ 'ei₅ dsí₂, jaun₂ ca₂jme₃lióg₃ qui₂ca₂tó'₂ lio₅₄ ne₄ jmɨ₁ŋí'₄.  
\v 19 Jme₁ca₂të́₂ 'nɨ₅ jmɨg₄, jaun₂ guio₅₄ jnia'₅₄ quian'₅₄ gu₂ qui₂ca₂tio'₅₄ dsi₂jmɨg₂ le₂jiog₅ a₂jmó'₂ ta₁ nɨ₁barco 'ŋiog₅.  
\v 20 'Lióng₂ jmɨg₄ tsá₃ ma₃ca₂jnia₃ 'iog₂, on₃ guë'₂ nei₅ në́₃. Tsá₃ ma₃lág₂ jnia'₅₄ jua'₅₄ a₂tág'₄ guë́₄, ia₁ a₂ŋɨ́₄ lë₃ tiá₂ jme₁'ei₅ dsí₂. 
\p  
\v 21 Ia₁ ma₂ne₁ŋó₄ 'lióng₂ jmɨg₄ tsá₃ ma₃'ein₂ jnia'₅₄ guë́'₅, jaun₂ ca₂nau₂ Pa₄ jë₄ quió'₅ dsa₂ 'éi₂, jaun₂ ca₂juá'₂: 
\p ―'Nia'₂ dsa₂, dse₃ jua'₅₄ co₂ŋei'₅₄ ca₂tion'₂ bá₄ 'nia'₂ juɨ₅ jág₁ quió₃ a₂tsá₃ jme₁'uág₃ Creta. Jŋia'₅₄ ca₂i₃'én₂ bá₄ quián₂, ton'₂ ca₂ŋag₅₄ rë'₂ uɨg₅ në́₃.  
\v 22 La₁ në₃ në́₃, quen'₂ 'nia'₂ bí₂, ia₁ 'i₁jan'₂ 'nia'₂ tsá₃ 'ein₂ dsián₃, o₁jŋia'₅₄ dsɨ₃'én₂ nɨ₁barco.  
\v 23 Ia₁ a₂'uë₂ la₂ në₂jme₃jnia₅ jan₂ ángel ne₃, i₂chen₄ quián₅ Diú₄ i₂jme₂tí₁ jniá₂ ne₅₄.  
\v 24 Jaun₂ në₂juá'₂ ángel në₂chéi₃ jniá₂: “Tsá₃ lë₁jmo₂ gang'₃ Pa₄, ia₁ tion₅₄ niog₅ bá₄ gog'₅₄ a₂jme₁jniag'₂ ne₄ gui'₅₄ emperador romano. 'Uɨg₅₄ quián'₂ 'ne₂ bá₄ a₂lión₂ Diú₄ ca₂le₃jɨ́n₃ dsa₂ i₂quiang'₅₄ 'ŋió'₃ barco, tsá₃ ma₃dsiáin₃.”  
\v 25 Jaun₂ lë₃, 'nia'₂ rɨn'₅₄ jniog₄, quen'₂ 'nia'₂ bí₂, tsá₃ jmo₂ 'nia'₂ o₂i₁ dsɨ₅. Ia₁ dsón'₂ bá₄ 'én₂ jniá₂ të₂le₃ quió'₅ Diú₄ a₂tion₅₄ jmo₃ con'₂ lë́₅ jág₁ a₂në₂juá'₂ ángel në₂chéi₂ jniá₂.  
\v 26 La₁ tion₅₄ niog₅ dsɨ₁tió'₄ bá₄ jniog₄ caun₂ 'uë₃ dsi₂jo₂ jmɨ₁ŋí'₄. 
\p  
\v 27 Caun₂ 'uë₂ jme₁ma₂të́₂ tɨn₃ semanas a₂tio'₅₄ jnia'₅₄ juɨ₅, lia'₂ ma₂jiog₅ jaun₂ bá₄ dsí₂ ne₄ Jmɨ₁ŋí'₄ Adria,\f + \fr 27:27 \ft o₃, “Jmɨ₁ŋí'₄ Mediterráneo.” \f* jme₁ca₂rë₃lí'₄ dsa₂ i₂quian₅ nɨ₁barco con'₂ dsi₃nei₅ jaun₂, a₂ja₂quián₃ dsi₁léin₂ 'uë₃.  
\v 28 Jaun₂ ca₂can₃ dsa₂ 'éi'₃ 'a₂ con'₂ jɨ'₂ guë́₄ jmɨg₂. Jme₁ca₂jág₃ dsa₂, con'₂ guióg₂-guiá₂-jŋéi₂ (36) metros bá₄ jɨ'₂ guë́₄. Ca₂juɨg₄ guë́₄ le₃cau₅ jaun₂ ca₂can₃ táng₃ dsa₂ 'éi'₃. Jme₁ca₂jág₃ táng₃, guióg₂-guio₃ (27) metros bá₄ tí₅ guë́₄ jɨ'₂.  
\v 29 Ia₁ a₂gó'₅ dsa₂ jná'₃ nɨ₁barco con'₂ tiá₂ dso'₂ nɨ₁cang₁ 'lau₂, jaun₂ ca₂sió₂ le₃chi₁co'₅₄ nɨ₁barco quén₂ nɨ₁ŋí₁ 'lá'₁ guei₂ quian'₅₄ tsɨ₁'nei₅₄ juɨ₅ né'₃ jmɨ₁ŋí'₄. Të₃ tion'₅₄ dsa₂ gó'₅ le₂jaun₂, qui₂ca₂chi₃léin'₂ Diú₄ a₂jnia₃.  
\v 30 Të₁lia'₂ jaun₂, jme₁ma₂dsɨ₂jiog₅ dsɨ́₅ dsa₂ i₂quian₅ nɨ₁barco a₂jme₁cuɨng₃. Qui₂ca₂sió₂ tsɨ₁mu₅ ne₄ jmɨ₁ŋí'₄, a₂jmo₂₃ juɨ₁lia'₂ a₂tioin'₅₄ tó'₅ nɨ₁ŋí₁ guei₂ të₂le₃ ne₄ nɨ₁barco.  
\v 31 La₁ jaun₂ ca₂juá'₂ Pa₄ ca₂tsɨ́'₃ juɨg₅₄ 'lióg₂ quian'₅₄ ca₂le₃jɨ́n₃ guë́₄ 'lióg₂ në́₃, ca₂juá'₂: 
\p ―Në₁jua'₂ tsá₃ jŋia₅ i₂në₅ 'ŋió'₃ nɨ₁barco, tsá₃ jaun₂ lión'₂ 'nia'₂. 
\p  
\v 32 Jaun₂ qui₂ca₂ti₃ 'lióg₂ 'nei₅₄ a₂jme₁chi₁quian₅ tsɨ₁mu₅, ca₂tá'₂ jaun₂ në́₃ ne₄ jmɨg₂. 
\p  
\v 33 Të₂ o₃'iog₂ lɨn₃, ca₂juá'₂ Pa₄ ca₂tsɨ́'₃ ca₂le₃jɨ́n₃ dsa₂ a₂'nió'₅ guë́'₃. Jaun₂ ca₂juá'₂: 
\p ―Ma₂të́₂ tɨn₃ semanas a₂tsá₃ ma₂güɨn'₂ 'nia'₂ on₃ guë'₂ ma₂quë'₂.  
\v 34 Jaun₂ lë₃ juá'₅ jniá₂, qué'₂ 'nia'₂ ca₂la₂. Tion₅₄ 'nió'₅ quë'₅₄ 'nia'₂ ia₁jaun₂ bá₄ lión'₂ 'nia'₂. 'I₁jan₂ jniog₄ tsá₃ 'ein₂ dsɨ₂'én₂ ja₁lá₃. Ca₂lia'₂ jŋia'₅₄ ca₂mɨ'₂ jŋi₂ dsi₄ jniog₄ tsá₃ 'e₂ dsɨ₃'én₂. 
\p  
\v 35 Dsɨ₂juɨ₅ jme₁ca₂juá'₂ Pa₄ le₂në₅, ca₂can₃ i₁ŋí'₄ jaun₂ ca₂cuë́'₃ ti₁'mag'₄ Diú₄ të₃ jág₅ dsa₂ ca₂le₃jɨ́in₃. Jaun₂ ca₂dsion₃ Pa₄ i₁ŋí'₄ ca₂guë́'₃ jaun₂ në́₃.  
\v 36 Jaun₂ ca₂le₃jɨ́n₃ dsa₂ ca₂tɨ́in'₃ táng₃ bí₂ jme₁ma₂në₂guë́'₃.  
\v 37 Ca₂le₃jág₃ jnia'₅₄ con'₂ jme₁tio'₅₄ nɨ₁barco jme₁téi₄ tɨn₃ 'ŋiá₂-lón₂ rë₂dsɨ́₂ 'nag'₂ co₂ne₂guióg₂ rë₂dsɨ́₂ guia₃-jŋé₂ (276) dsa₂.  
\v 38 Jme₁ca₂lɨ́'₃ guë́'₅ dsa₂ con'₂ jme₁'nio₃, jaun₂ ca₂guia'₃ lio₅₄ trigo ne₄ jmɨ₁ŋí'₄ ia₁jaun₂ sión'₂ guë́₄ guei₂ nɨ₁barco. 
\s1 Ca₂i₃guen'₅₄ nɨ₁barco né'₃ jmɨ₁ŋí'₄ 
\p  
\v 39 Jme₁jnia₃ jaun₂, dsa₂ i₂quian₅ nɨ₁barco tsá₃ ca₂rë₃cuɨ́'₅ 'uë₃ jaun₂. La₁ jaun₂ ca₂jág₃ caun₂ dsiog₅ jmɨ₁ŋí'₄ a₂niog₅ jë₄ 'uë₃, ja₁'ei₅ tei₄ guë́₄ jmɨg₂. Chei'₅₄ jaun₂ tio'₅₄ 'lióng₂ ti₁tsag₁ ja₁lë́₄ jo₂ guë́₄. Jaun₂ ca₂'náu'₃ dsɨ́₅ chi₂jua'₂ lé₂ jŋióg'₃ nɨ₁barco ca₂të₂ jaun₂.  
\v 40 Jaun₂ ca₂ti₃ 'nei₅₄ a₂jme₁le₁quian₅ nɨ₁ŋí₁ 'lá'₁. Né'₃ jmɨ₁ŋí'₄ jaun₂ bá₄ ca₂tí₂ dsa₂ nɨ₁ŋí₁ jaun₂. Qui₂ca₂jiá'₂ dsa₂ 'ma₂ a₂jmo₅ dsó₃ nɨ₁barco 'a₂ juɨ₅ 'nio₃ dsa₂. Jaun₂ ca₂chóg'₃ tsɨ₁'mɨ'₂ le₃ne₄ juɨ₅ quió'₅ nɨ₁barco, ia₁jaun₂ të₃ dsí₂. Jaun₂ dsɨ₂juɨ₅ bá₄ ca₂jme₃lióg₃ ca₂ŋɨ₃ nɨ₁barco ca₂jme₃quián₃ le₃chei'₅₄ 'uë₃ ja₁lë́₄ ti₁tsag₁.  
\v 41 La₁ juɨ₅ ja₁ŋó₃ nɨ₁barco jaun₂ ca₂dsi₃quén'₅ caun₂ ja₁lë́₄ tɨn₃ ne₅₄ la'₅₄ ja₁'ei₅ tiá₂ jmɨg₂. Të₂le₃ ja₁lë́₄ le₃ne₄ juɨ₅ quió'₅ nɨ₁barco ca₂i₃'ó'₅ jë₄ ti₁tsag₁, ca₂quɨ́'₃ tiá₂ lɨn₃, ca₂lia'₂ tsá₃ ma₃ca₂tió'₃ dsa₂ dsí₃. Jaun₂ le₃ja₁lë́₄ le₃chi₁co'₅₄, qui₂ca₂juɨn₃, ia₁ a₂ŋɨ́₄ lë₃ tiá₂ qui₂jná'₅ jmɨ₁ŋí'₄.  
\v 42 Jme₁'nio₃ 'lióg₂ jme₃dsiain₂₃ dsa₂ i₂niog₅ gu₂ 'éi₂ ia₁jaun₂ tsá₃ lióin₂ jë₁ma₂qui₂ca₂'ain₂ jmɨg₂.  
\v 43 La₁ tsá₃ ca₂cuë₃ jmɨg₄ juɨg₅₄, ia₁ 'nio₃ lióin₂ Pa₄. Jaun₂ ca₂jmo₃ 'éi'₃ ca₂tsɨ́'₃ ca₂le₃jɨ́n₃ dsa₂ i₂tɨn₂ qui₃dsɨ₅ jmɨg₂, juɨ₁tioin'₅₄ jmɨg₂ le₂'uɨg₅₄ ia₁jaun₂ tɨ́in'₄ 'uë₃;  
\v 44 dsa₂ sián'₂ guë́₄ në́₃, juɨ₁'ain₅₄ jmɨg₂ le₁chan'₂ jau₅₄ 'ma₂, o₃ nɨ₁'nau₅₄ quió'₅ nɨ₁barco 'e₂. Le₂jaun₂ bá₄ ca₂lë₃ qui₂ca₂ló₂ jnia'₅₄ a₂ca₂tág'₃ táng₃ 'uë₃. 
\c 28  
\s1 'En₅₄ Pablo 'uë₃ Malta a₂niog₅ jë₄ jmɨ₁ŋí'₄ 
\p  
\v 1 Jme₁ma₂ca₂ló₂ jnia'₅₄ ca₂le₃jág₃, jaun₂ guë́₄ ca₂rë₃ne₄ jnia'₅₄ a₂chei₂ Malta 'uë₃ jaun₂, a₂niog₅ jë₄ jmɨ₁ŋí'₄.  
\v 2 Dsa₂ chan₂ ja₁jaun₂ ca₂jmo₃ bá₄ dse₃ dsɨ́₅ ja₁con₂ jnia'₅₄. Ca₂dsia₃ dsa₂ si₂ pa₁ jaun₂ ca₂të₃ jnia'₅₄ a₂jme₁dsion'₂, ia₁ a₂ŋɨ́₄ lë₃ güɨ́g₂, dsó₅ jmɨ́₅ në́₃.  
\v 3 Pa₄ guë'₂ në́₃ qui₂ca₂cág'₃ nɨ₁'ma₂ quein₂. Lia'₂ con'₂ jme₁'ein₅₄ tó'₅ dsi₂si₂, con'₂ tsá₃ jáin₅ ca₂o₃'ɨ́n₃ jan₂ dsɨ₂mɨ'₂ a₂cuɨng₂₃ jme₁ca₂'ë́'₂ dséi₂ quió'₅, ca₂chi₃dséin₂ mɨ₂gu₂ Pa₄.  
\v 4 Jme₁ca₂jág₃ dsa₂ chan₂ ja₁jaun₂ 'en₅₄ dsɨ₂mɨ'₂ chi₁dsein₅₄ mɨ₂gu₂ 'éi₂, qui₂ca₂dsia₃ jág₁ guioin₅₄ qui₂ca₂tsɨ́'₃ rɨin'₅₄: 
\p ―I₂ma₂jŋɨ'₃ dsa₂ bá₄ dsa₂ në₅. O₁jŋia'₅₄ la₂ ca₂lóin₂ ne₄ jmɨ₁ŋí'₄, la₁ tsá₃ 'i₄ 'éi'₃ a₂le₃chain₂ guë́₄. 
\p  
\v 5 La₁ qui₂ca₂bí₂ Pa₄ mɨ₂gu₂ jaun₂ në́₃, ca₂tán'₂ dsɨ₂mɨ'₂ dsi₂si₂. La₁ tsá₃ 'e₂ ca₂jén'₃ Pa₄ 'i₁ca₂juɨg₄.  
\v 6 Ca₂le₃jɨ́n₃ dsa₂ jme₁le₁jŋia₂₃ guióng₃ dsɨ₂juɨ₅ quió'₅ Pa₄, o₃ jme₁dsɨ₃'ɨin₅ 'e₂, jóin₂ dsɨ₂juɨ₅. La₁ jme₁co₂lág₂ jaun₂, ia₁ ca₂jág₃ tsá₃ 'e₂ i₁jén'₄ guë'₂ Pa₄, jaun₂ ca₂i₃jiog₅ dsɨ́₅ të₂le₃ siá'₂, qui₂ca₂tsɨ́'₃ rɨin'₅₄ a₂lɨ́n₅ Pa₄ jan₂ diú₄. 
\p  
\v 7 Cau₅ jaun₂ jme₁ron₅ 'uë₃ quió'₅ dsa₂ dsen₅₄ quián₅ dsa₂ chan₂ ja₁jaun₂, dsa₂ i₂chen₂ Publio. Ca₂jmo₃ dse₃ dsɨ́₅ ca₂ag'₃ jnia'₅₄, 'nɨ₅ jmɨg₄ ca₂tág₃ jnia'₅₄ ja₁quió'₄.  
\v 8 Jmei₂ Publio 'éi₂ jme₁ron₅ dso'₅₄ 'i₄ dséi₂, a₂tag₂₃ jmɨ₂ në́₃. Pa₄ në́₃ ca₂ŋei₅₄ ca₂i₁jɨin₁₂ dsa₂ dso'₅₄ 'éi₂. Jme₁ma₂në₂chi₃léin'₂ Diú₄, jaun₂ guë́₄ ca₂quiog₂ gu₂ ne₄ quió'₅ dsa₂ dso'₅₄, ca₂jme₃'lió₂.  
\v 9 Jme₁ca₂lë₃ le₂jaun₂, caun₂ ca₂dsi₃lén₂ bá₄ dsa₂ dso'₅₄ sián'₂ i₂chan₂ 'uë₃ jaun₂, caun₂ ca₂jme₃'lió₂ bá₄ guë'₂ Pa₄.  
\v 10 'Io'₂ ca₂jmo₃ dsa₂ quian'₅₄ jnia'₅₄. Jaun₂ ca₂cuë₃ dsa₂ ca₂le₃jë́₃ 'e₂ 'nió'₅ quián₂ jnia'₅₄ jë₁ma₂të́₂ rë₁tió'₄ táng₃ jnia'₅₄ juɨ₅. 
\s1 Ca₂dsióg₃ Pa₄ jë₄ juɨg₂ Roma 
\p  
\v 11 Cang₂ jme₁ma₂ca₂ŋɨ́₂ 'nɨ₅ tsɨ'₂, jaun₂ ca₂tió'₄ táng₃ jnia'₅₄ caun₂ nɨ₁barco a₂jme₁chí'₄ ja₁jaun₂ të₁lia'₂ jein₂ güɨ́g₂. Nɨ₁barco jaun₂ ca₂já₃ juɨg₂ Alejandría. Guei'₅₄ nɨ₁barco jaun₂ jme₁tióng₂ nió'₅ quió'₅ diú₄ Cástor quian'₅₄ diú₄ Pólux.\f + \fr 28:11 \ft griego: Dioskouri, co₂'nió'₄ le₃jua'₅₄ on₃ dsa₂ tsɨn'₅₄ i₂lɨ́n₅ ja₁ŋi'₅₄ diú₄ Zeus quian'₅₄ Leda. Co₂'nió'₄ diú₄ patrón quián₅ nɨ₁barco.\f* 
\v 12 Ca₂dsi₃náu₅ jnia'₅₄ 'o₄ jmɨ₁ŋí'₄ juɨg₂ chei₂ Siracusa. Ja₁jaun₂ ca₂jŋia₄ jnia'₅₄ 'nɨ₅ jmɨg₄.  
\v 13 Ca₂'uag₂ jnia'₅₄ ja₁jaun₂, ca₂i₁ŋag₅₄ jnia'₅₄ quián₅ chei'₅₄ 'uë₃ ca₂lia'₂ ca₂dsi₃náu₅ të₂ ja₁chei₂ Regio. Jme₁jnia₃ jaun₂, ca₂'ág₂ dsí₂ a₂já₅ të₂le₃ sur. Jë₁ca₂të́₂ tɨn₃ jmɨg₄ guë́₄ ca₂dsi₃náu₅ jnia'₅₄ ca₂të₂ juɨg₂ Puteoli.  
\v 14 Ja₁jaun₂ ca₂jen'₂ jnia'₅₄ i₂lɨn₅₄ dsa₂ rɨn'₅₄ i₂'én₂. I₂'éi₂ ca₂të₃ jnia'₅₄ ca₂i₁jŋia₁ jë₄ quió'₅ caun₂ semana. Jaun₂ guë́₄ ca₂i₃náu₅ jnia'₅₄ juɨ₅ Roma.  
\v 15 Ca₂le₃jɨ́n₃ dsa₂ rɨn'₅₄ i₂tián'₅ Roma jme₁ma₂le₁ŋi₅ a₂dsi₁náu₅ jnia'₅₄. Jaun₂ i₁lein₅₄ i₁jŋiog₁₂ le₂'i₄ juɨ₅ ca₂të₂ ja₁chei₂ Foro de Apio quian'₅₄ ja₁të́'₂ dsa₂ Las Tres Tabernas. Jme₁ca₂jág₃ Pa₄ ca₂jɨ́in₂ dsa₂ 'éi₂, jaun₂ ca₂cuë́'₃ ti₁'mag'₄ Diú₄ ca₂tɨ́in₂ táng₃ bí₂ ca₂lág₃ dsɨ́₅.  
\v 16 Jme₁ca₂dsi₃náu₅ jnia'₅₄ Roma, [ja₁jaun₂ guë́₄ ca₂jáng'₂ juɨg₅₄ 'lióg₂ ca₂jɨ́in'₂ ne₄ juɨg₅₄ 'lióg₂ i₂jmo₅ 'í₁ ja₁jaun₂ ca₂le₃jɨ́n₃ dsa₂ i₂jŋiai₂₃ i₂niog₅ gu₂. La₁]\f + \fr 28:16 \ft A₂lɨn₅₄ chog₅₄ si₂ tsá₃ le₁ton₅ jág₁ a₂tio'₅₄ 'ŋió'₃ corchetes [le₂la₂].\f* Pa₄ në́₃ ca₂cuë₃ juɨg₅₄ 'lióg₂ jmɨg₄ a₂guá₃ 'éi₂ ja₁siá'₂ con'₂ 'ŋiog₅ quian'₅₄ jan₂ 'lióg₂ i₂jmo₃ 'í₁ quió'₅. 
\s1 Ca₂'ë́₂ Pa₄ jág₁ dse₃ juɨg₂ Roma 
\p  
\v 17 'Nɨ₅ jmɨg₄ cang₂ jme₁ca₂dsióg₃ Pa₄ juɨg₂ Roma, ca₂të́'₃ ca₂le₃jɨ́n₃ dsa₂ dsen₅₄ quián₅ dsa₂ judíos juɨg₂ jaun₂. Jme₁ma₂le₁ŋɨ'₂ dsa₂, jaun₂ ca₂juá'₂ Pa₄: 
\p ―Rɨn'₅₄ jniog₄, o₁jŋia'₅₄ guë́₄ tsá₃ 'e₂ ma₂ca₂jmo₃ jniá₂ ja₁con₂ dsa₂ judíos, on₃ guë'₂ jua'₅₄ cha₂ a₂ma₂ca₂jmo₃ quian'₅₄ tag₄ chí'₅ quió'₅ dsa₂ quián₂ jniog₄ ma₂lɨ́g'₂, tion₅₄ bá₄ a₂lë₁ca₂jáng'₂ dsa₂ jniá₂ chi₁'ŋeg₂₃ o₄gú₃ dsa₂ romanos.  
\v 18 Jaun₂ jme₁ca₂ŋag₃ dsa₂, tsá₃ 'e₂ dsáu₅ jniá₂ ca₂dsó'₂, jua'₅₄ a₂'i₄ 'éi'₃ jóng₂. Jaun₂ jme₁'nio₃ jme₁lió₂.  
\v 19 La₁ dsa₂ judíos tsá₃ cán₂ jág₁. Jaun₂ bá₄ lë₃ ca₂mɨ₃ jniá₂ a₂'nio₃ jme₃rë́₃ gui'₅₄ emperador, on₃jua'₅₄ ia₁ a₂cha₂ dso₄ jme₂cán'₂ jniá₂ dsa₂ go₃.  
\v 20 'Uɨg₅₄ jaun₂ bá₄ në₂të́₃ jniá₂, ia₁ a₂'nio₃ jɨng₅₄ 'nia'₂, a₂'nio₃ dsia₅₄ jág₁ quian'₅₄ 'nia'₂. Ia₁ 'uɨg₅₄ jág₁ quió'₅ Diú₄ a₂'éin₂ jniog₄ con'₂ dsa₂ lág₅ israelitas, 'uɨg₅₄ a₂'ɨ́n₂ dsɨ₅ jniog₄ a₂jme₃ti₃ Diú₄ jág₁ quió'₅ a₂ma₂cuë₃, 'uɨg₅₄ jaun₂ bá₄ chi₁'ŋe'₅₄ jniá₂ nɨ₁ŋí₁ cadena la₂. 
\p  
\v 21 Jaun₂ ca₂ŋag₃ dsa₂ ca₂tsɨ́'₃ Pa₄: 
\p ―Tsá₃ 'e₂ si₂ ma₂ca₂gú'₃ ne₄ jnia'₅₄, quió'₅ dsa₂ chan₂ Judea, a₂'ɨin₂₃ 'ne₂. On₃ guë'₂ 'i₁jan₂ dsa₂ rɨn'₅₄ jniog₄ dsa₂ judíos i₂ja₂lén₂ ja₁jaun₂ jua'₅₄ a₂ma₂juá'₂ 'ɨin₂₃ 'ne₂ 'lɨg'₅₄.  
\v 22 'Niog₂ jnia'₅₄ néi₁ 'a₂ guë'₂ lia'₂ lë́₅ jág₁ quián'₂ 'ne₂ chi₂jua'₂ 'a₂ lia'₂ lɨ́ng'₂. Ia₁ ne₄ bá₄ jnia'₅₄ jág₁, ta₁caun₂ mɨ₂güɨ́g₃ bá₄ dsia₅ dsa₂ tsá₃ të₅ dsɨ́₅ jág₁ 'mɨ́₂ në₅ a₂'én'₂ 'nia'₂. 
\p  
\v 23 Jaun₂ në́₃, ca₂jmo₃ dsa₂ jág₁ ca₂tióng₃ caun₂ jmɨg₄. Jmɨg₄ jaun₂ në́₃ ca₂dsi₃lén₂ juɨn₅ dsa₂ ja₁'en₅₄ Pa₄. Jaun₂ ca₂jme₂lióg₃ ca₂'ë́'₃ dsa₂ të₃ o₃'iog₂ jág₁ juɨ₁lia'₂ ja₁gon₂ Diú₄, qui₂ca₂dsia₃ ca₂lia'₂ ca₂jen₃ 'iog₂ të₂le₃ ca₂'láu₂. Të₂le₃ quian'₅₄ 'Éi'₃ Juá'₅ quió'₅ Moisés, quian'₅₄ ca₂le₃jë́₃ guë́₄ Si₂ quió'₅ dsa₂ i₂jme₁'ë́₂ jág₁ quián₅ Diú₄ në́₃, qui₂ca₂cuë́'₃ dsa₂ jág₁ dsau₅ ia₁jaun₂ le₃'én₂ dsa₂ 'éi₂ të₂le₃ quió'₅ Jesús.  
\v 24 I₂lɨn₅₄ dsa₂ ca₂gue₃ bá₄ jág₁ a₂ca₂juá'₂ Pa₄ jaun₂, ca₂rë₃'éin₂ bá₄. I₂lɨn₅₄ guë'₂ tsá₃ ca₂rë₃'én₂, tsá₃ 'nio₃.  
\v 25 Ia₁ tsá₃ caun₂ jág₁ 'ei₅ quió'₅, i₂lɨn₅₄ ca₂jme₃lióg₃ ca₂'uɨin₂ bá₄ i₃lein₃. Jaun₂ ca₂juá'₂ Pa₄ ca₂tsɨ́'₃ dsa₂ 'éi₂: 
\p ―Rë₂ bá₄ juɨ₁lia'₂ ca₂juá'₂ Jme₂dsí₂ Jŋió₅ ca₂tsɨ́'₃ dsa₂ quián₂ jniog₄ ma₂lɨ́g'₂ të₂le₃ quian'₅₄ Isaías, i₂jme₁'ë́₂ jág₁ o₄quió'₄ Diú₄, jme₁ca₂juá'₂: 
\q1  
\v 26 Gua₂ o₂chei'₅₄ dsa₂ juɨg₂ në₅ le₂la₂: 
\q1 “Dsón'₂ qui₁nág'₁ bá₄ 'nia'₂, 
\q2 la₁ tsá₃ le₃ŋɨ́'₂ 'nia'₂. 
\q1 Jag'₅₄ bá₄ 'nia'₂, 
\q2 la₁ tsá₃ le₃len'₄ 'nia'₂.” 
\q1  
\v 27 Ia₁ a₂ma₂'ua'₂ dsɨ́₅ bá₄ dsa₂ la₂, 
\q2 ja₂lag₃ bá₄ nag₂₃, 
\q1 në₂jag₄ bá₄ i₂ma₂rë₂jnɨ₅ rë₂gua₄; 
\q1 ján₃ bá₄ le₂në₅, në₂jag₄ bá₄ a₂tsá₃ jniá₂ mɨ₂ne₅₄, 
\q2 ia₁jaun₂ tsá₃ jág₃ quian'₅₄ mɨ₂ne₅₄, 
\q1 on₃ guë'₂ nag₃ quian'₅₄ rë₂gua₅₄, 
\q1 on₃ guë́₄ le₃ŋɨ́'₂ dsɨ́₅, 
\q2 ia₁jaun₂ tsá₃ jéin'₃ dsɨ́₅ ja₁con₂ jniá₂ 
\q2 ia₁jaun₂ jme₁'lioin₁₂ jniá₂.\f + \fr 28:27 \ft Isaías 6:9-10.\f* 
\p  
\v 28 'Dsá₂ 'au'₂ 'nia'₂ jmo₄ ―ca₂juá'₂ Pa₄―, jág₁ dse₃ la₂ a₂lión₂ dsa₂, a₂jén'₂ Diú₄ le₃ne₄ juɨ₅ quió'₅ dsɨ₂nau₂. 'Éi₂ në́₃, tón'₃ bá₄ juɨ₅.  
\v 29 Jme₁ca₂lë₃ juá'₂ Pa₄ le₂në₅, ca₂i₃len₃ dsa₂ judíos tsɨin₂₃ 'ŋio₅ lɨn₃ quiain'₅₄ rɨin'₅₄.\f + \fr 28:29 \ft A₂lɨn₅₄ chog₅₄ si₂ tsá₃ chi₁ton₅ versículo 29.\f* 
\p  
\v 30 Tɨn₃ ŋi₂ lia'₂ tí₅ ca₂guá₂ Pa₄ 'né₅ ja₁quí₅ 'lia'₅₄. Ja₁jaun₂ ca₂guein₃ ca₂le₃jɨ́n₃ dsa₂ i₂jme₁dsɨ₂lén₂ dsɨ₂jag₅₄.  
\v 31 Jaun₂ ca₂jme₃tɨin₂₃ dsa₂ qui₂ca₂'ë́₂ jág₁ 'a₂ lia'₂ lë́₅ ja₁gon₂ Diú₄. Ca₂jme₃tɨin₂₃ bá₄ dsa₂ jág₁ quió'₅ Te₁gui'₅₄ Jesucristo. Ja₁jaun₂ ca₂'í₃ tei₄, tsá₃ 'ein₂ ca₂jné₃ juɨ₅ a₂'ë́₂ Pa₄ jág₁ dse₃. 
\p Co₂në₅.