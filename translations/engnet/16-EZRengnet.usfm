\v 2  \w they|strong="H1992"\w* \w came|strong="H5927"\w* \w to|strong="H5927"\w* \w Zerubbabel|strong="H2216"\w* \w and|strong="H4428"\w* \w the|strong="H3588"\w* \w leaders|strong="H7218"\w* \w and|strong="H4428"\w* said \w to|strong="H5927"\w* \w them|strong="H1992"\w*, “\w Let|strong="H3808"\w* \w us|strong="H3588"\w* help \w you|strong="H3588"\w* \w build|strong="H1129"\w*, \w for|strong="H3588"\w* \w like|strong="H5973"\w* \w you|strong="H3588"\w* \w we|strong="H3068"\w* \w seek|strong="H1875"\w* \w your|strong="H3588"\w* \w God|strong="H3808"\w* \w and|strong="H4428"\w* \w we|strong="H3068"\w* \w have|strong="H3117"\w* \w been|strong="H3808"\w* \w sacrificing|strong="H2076"\w* \w to|strong="H5927"\w* \w him|strong="H5973"\w* \w from|strong="H5927"\w* \w the|strong="H3588"\w* \w time|strong="H3117"\w* \w of|strong="H4428"\w* \w King|strong="H4428"\w* Esarhaddon \w of|strong="H4428"\w* Assyria, \w who|strong="H1992"\w* \w brought|strong="H5927"\w* \w us|strong="H3588"\w* \w here|strong="H6311"\w*.”  
