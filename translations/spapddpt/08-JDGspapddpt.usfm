\v 20 En los \w días|strong="H3117"\w* de los \w filisteos|strong="H6430"\w* \w juzgó|strong="H8199"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* 20 \w años|strong="H8141"\w*.
\c 16
\s1 Sansón en Gaza
\p 
\v 1 Sansón \w fue|strong="H3212"\w* \w a|strong="H3068"\w* \w Gaza|strong="H5804"\w* y \w vio|strong="H7200"\w* \w allí|strong="H8033"\w* \w a|strong="H3068"\w* una prostituta, y se unió \w a|strong="H3068"\w* \w ella|strong="H8033"\w*.
\v 2 Avisaron \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w de|strong="H5704"\w* Gaza: ¡Sansón está \w aquí|strong="H2008"\w*! Entonces \w ellos|strong="H3605"\w* \w lo|strong="H5704"\w* rodearon \w y|strong="H5704"\w* \w lo|strong="H5704"\w* acecharon \w toda|strong="H3605"\w* aquella \w noche|strong="H3915"\w* \w en|strong="H5704"\w* \w la|strong="H3605"\w* \w puerta|strong="H8179"\w* \w de|strong="H5704"\w* \w la|strong="H3605"\w* \w ciudad|strong="H5892"\w*. Estuvieron \w en|strong="H5704"\w* silencio \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w noche|strong="H3915"\w* \w y|strong="H5704"\w* dijeron: \w En|strong="H5704"\w* \w la|strong="H3605"\w* \w mañana|strong="H1242"\w*, \w cuando|strong="H5704"\w* sea \w de|strong="H5704"\w* día, \w lo|strong="H5704"\w* mataremos.
\p 
\v 3 Pero Sansón estuvo \w acostado|strong="H7901"\w* \w hasta|strong="H5704"\w* \w la|strong="H5921"\w* medianoche, \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* medianoche \w se|strong="H5921"\w* \w levantó|strong="H6965"\w*. \w Y|strong="H3068"\w* \w al|strong="H5921"\w* agarrar \w las|strong="H5921"\w* hojas \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w puerta|strong="H1817"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w* \w con|strong="H5973"\w* sus \w dos|strong="H8147"\w* jambas \w y|strong="H5921"\w* su cerrojo, \w se|strong="H5921"\w* \w las|strong="H5921"\w* echó \w al|strong="H5921"\w* \w hombro|strong="H3802"\w*. \w Se|strong="H5921"\w* \w fue|strong="H5265"\w* \w y|strong="H5921"\w* \w las|strong="H5921"\w* \w subió|strong="H5927"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w cumbre|strong="H7218"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* montaña \w que|strong="H5921"\w* \w está|strong="H6965"\w* \w enfrente|strong="H6440"\w* \w de|strong="H5921"\w* \w Hebrón|strong="H2275"\w*.
\s1 El secreto de Sansón
\p 
\v 4 \w Después|strong="H1961"\w* de \w esto|strong="H3651"\w* \w sucedió|strong="H1961"\w* \w que|strong="H1961"\w* \w se|strong="H1961"\w* enamoró de una mujer del valle de Sorec \w que|strong="H1961"\w* \w se|strong="H1961"\w* \w llamaba|strong="H8034"\w* \w Dalila|strong="H1807"\w*.
\v 5 Los jefes \w de|strong="H5414"\w* los \w filisteos|strong="H6430"\w* \w fueron|strong="H5927"\w* \w a|strong="H3068"\w* ella y le dijeron: Sedúcelo \w para|strong="H5414"\w* \w ver|strong="H7200"\w* en \w qué|strong="H4100"\w* consiste su \w gran|strong="H1419"\w* \w fuerza|strong="H3581"\w*, y \w cómo|strong="H4100"\w* podríamos atarlo \w para|strong="H5414"\w* afligirlo. Entonces cada uno \w de|strong="H5414"\w* nosotros te \w dará|strong="H5414"\w* 1.100 piezas \w de|strong="H5414"\w* \w plata|strong="H3701"\w*.
\p 
\v 6 \w Dalila|strong="H1807"\w* \w dijo|strong="H5046"\w* \w a|strong="H3068"\w* Sansón: Te \w ruego|strong="H4994"\w* \w que|strong="H4100"\w* me digas en \w qué|strong="H4100"\w* consiste tu \w gran|strong="H1419"\w* \w fuerza|strong="H3581"\w*, y con \w qué|strong="H4100"\w* podrías ser atado para afligirte.
\p 
\v 7 Sansón le respondió: \w Si|strong="H3808"\w* me atan con \w siete|strong="H7651"\w* cuerdas de arco \w que|strong="H3808"\w* \w aún|strong="H3808"\w* \w no|strong="H3808"\w* \w estén|strong="H1961"\w* secas, entonces me debilitaré y \w seré|strong="H1961"\w* \w como|strong="H1961"\w* cualquier otro hombre.
\p 
\v 8 Los jefes de los \w filisteos|strong="H6430"\w* le llevaron \w siete|strong="H7651"\w* cuerdas de arco \w que|strong="H3808"\w* \w aún|strong="H3808"\w* \w no|strong="H3808"\w* habían secado, y \w lo|strong="H3808"\w* ató con ellas.
\v 9 \w Ella|strong="H5921"\w* tenía hombres \w al|strong="H5921"\w* acecho \w en|strong="H5921"\w* una \w habitación|strong="H3427"\w* interior. Entonces \w le|strong="H5921"\w* dijo: ¡Sansón, \w los|strong="H3427"\w* \w filisteos|strong="H6430"\w* \w contra|strong="H5921"\w* \w ti|strong="H5921"\w*! Pero \w él|strong="H5921"\w* rompió \w las|strong="H5921"\w* cuerdas \w de|strong="H5921"\w* arco \w como|strong="H5921"\w* \w se|strong="H3045"\w* rompe un hilo \w de|strong="H5921"\w* estopa cuando toca \w el|strong="H5921"\w* fuego. \w Y|strong="H3068"\w* \w no|strong="H3808"\w* \w se|strong="H3045"\w* \w supo|strong="H3045"\w* \w el|strong="H5921"\w* secreto \w de|strong="H5921"\w* su \w fuerza|strong="H3581"\w*.
\p 
\v 10 \w Dalila|strong="H1807"\w* \w dijo|strong="H1696"\w* \w a|strong="H3068"\w* Sansón: \w Mira|strong="H2009"\w*, me engañaste y me \w dijiste|strong="H1696"\w* \w mentiras|strong="H3576"\w*. \w Ahora|strong="H6258"\w* te \w ruego|strong="H4994"\w* \w que|strong="H4100"\w* me \w digas|strong="H1696"\w* \w cómo|strong="H4100"\w* puedes ser atado.
\p 
\v 11 \w Y|strong="H3068"\w* \w él|strong="H6213"\w* le contestó: \w Si|strong="H3808"\w* me atan fuertemente con \w cuerdas|strong="H5688"\w* \w nuevas|strong="H2319"\w*, \w que|strong="H3808"\w* \w no|strong="H3808"\w* hayan \w sido|strong="H1961"\w* usadas, me debilitaré y \w seré|strong="H1961"\w* \w como|strong="H1961"\w* cualquier hombre.
\p 
\v 12 \w Dalila|strong="H1807"\w* \w tomó|strong="H3947"\w* \w cuerdas|strong="H5688"\w* \w nuevas|strong="H2319"\w* \w y|strong="H5921"\w* \w lo|strong="H5921"\w* ató \w con|strong="H5921"\w* \w ellas|strong="H5921"\w*, \w y|strong="H5921"\w* \w le|strong="H5921"\w* dijo: ¡Sansón, \w los|strong="H3427"\w* \w filisteos|strong="H6430"\w* \w contra|strong="H5921"\w* \w ti|strong="H5921"\w*! (\w Y|strong="H3068"\w* \w los|strong="H3427"\w* hombres permanecían \w al|strong="H5921"\w* acecho \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w habitación|strong="H3427"\w* interior.) Pero \w él|strong="H5921"\w* rompió \w las|strong="H5921"\w* \w cuerdas|strong="H5688"\w* \w de|strong="H5921"\w* sus \w brazos|strong="H2220"\w* \w como|strong="H5921"\w* un hilo.
\p 
\v 13 Entonces \w Dalila|strong="H1807"\w* \w dijo|strong="H1696"\w* \w a|strong="H3068"\w* Sansón: \w Hasta|strong="H5704"\w* \w ahora|strong="H2008"\w* \w me|strong="H5973"\w* engañas \w y|strong="H5704"\w* \w me|strong="H5973"\w* \w dijiste|strong="H1696"\w* \w mentiras|strong="H3576"\w*. Dime \w cómo|strong="H4100"\w* puedes ser atado. \w Él|strong="H5973"\w* \w le|strong="H5973"\w* \w dijo|strong="H1696"\w*: Si tejes las \w siete|strong="H7651"\w* trenzas \w de|strong="H5973"\w* mi cabellera \w con|strong="H5973"\w* tela.
\v 14 \w Ella|strong="H5921"\w*, pues, \w las|strong="H5921"\w* aseguró \w con|strong="H5921"\w* una clavija, \w y|strong="H5921"\w* \w le|strong="H5921"\w* dijo: ¡Sansón, \w los|strong="H5921"\w* \w filisteos|strong="H6430"\w* \w contra|strong="H5921"\w* \w ti|strong="H5921"\w*! \w Y|strong="H3068"\w* \w él|strong="H5921"\w*, \w al|strong="H5921"\w* despertar \w de|strong="H5921"\w* su \w sueño|strong="H8142"\w*, \w arrancó|strong="H5265"\w* \w la|strong="H5921"\w* clavija \w de|strong="H5921"\w* telar \w con|strong="H5921"\w* \w la|strong="H5921"\w* tela.
\p 
\v 15 Ella entonces le \w dijo|strong="H5046"\w*: ¿\w Cómo|strong="H4100"\w* sigues diciendo: Yo te amo, \w cuando|strong="H4100"\w* tu \w corazón|strong="H3820"\w* \w no|strong="H3808"\w* \w está|strong="H2088"\w* conmigo? \w Estas|strong="H2088"\w* \w tres|strong="H7969"\w* \w veces|strong="H6471"\w* te burlaste de mí y \w no|strong="H3808"\w* me dijiste en \w qué|strong="H4100"\w* consiste tu \w gran|strong="H1419"\w* \w fuerza|strong="H3581"\w*.
\v 16 \w Sucedió|strong="H1961"\w* \w que|strong="H3588"\w* \w como|strong="H3588"\w* \w ella|strong="H3605"\w* \w lo|strong="H1697"\w* afligía \w cada|strong="H3605"\w* \w día|strong="H3117"\w* \w con|strong="H3588"\w* sus \w palabras|strong="H1697"\w* \w y|strong="H3588"\w* \w lo|strong="H1697"\w* presionaba, \w su|strong="H3588"\w* \w alma|strong="H5315"\w* \w fue|strong="H1961"\w* reducida \w a|strong="H3068"\w* mortal \w angustia|strong="H7114"\w*.
\p 
\v 17 \w Por|strong="H5921"\w* \w lo|strong="H3808"\w* \w cual|strong="H3588"\w* \w le|strong="H5921"\w* descubrió \w todo|strong="H3605"\w* \w su|strong="H3588"\w* \w corazón|strong="H3820"\w* \w y|strong="H3588"\w* \w le|strong="H5921"\w* \w dijo|strong="H5046"\w*: \w Jamás|strong="H3808"\w* pasó \w navaja|strong="H4177"\w* \w por|strong="H5921"\w* \w mi|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w porque|strong="H3588"\w* \w soy|strong="H1961"\w* \w nazareo|strong="H5139"\w* \w de|strong="H4480"\w* \nd ʼElohim\nd* \w desde|strong="H4480"\w* \w el|strong="H5921"\w* vientre \w de|strong="H4480"\w* \w mi|strong="H5921"\w* madre. \w Si|strong="H3588"\w* \w soy|strong="H1961"\w* rapado, \w entonces|strong="H5493"\w* \w mi|strong="H5921"\w* \w fuerza|strong="H3581"\w* \w se|strong="H1961"\w* \w apartará|strong="H5493"\w* \w de|strong="H4480"\w* \w mí|strong="H5921"\w* \w y|strong="H3588"\w* \w me|strong="H4480"\w* debilitaré, \w y|strong="H3588"\w* \w seré|strong="H1961"\w* \w como|strong="H3588"\w* un hombre \w cualquiera|strong="H3605"\w*.
\p 
\v 18 \w Cuando|strong="H3588"\w* \w Dalila|strong="H1807"\w* se dio \w cuenta|strong="H5046"\w* \w de|strong="H3588"\w* \w que|strong="H3588"\w* le \w había|strong="H3588"\w* \w revelado|strong="H5046"\w* \w todo|strong="H3605"\w* \w su|strong="H3588"\w* \w corazón|strong="H3820"\w*, \w envió|strong="H7971"\w* \w a|strong="H3068"\w* \w llamar|strong="H7121"\w* \w a|strong="H3068"\w* \w los|strong="H3605"\w* jefes \w de|strong="H3588"\w* \w los|strong="H3605"\w* \w filisteos|strong="H6430"\w* \w y|strong="H3588"\w* \w dijo|strong="H5046"\w*: Suban esta \w vez|strong="H6471"\w*, \w porque|strong="H3588"\w* \w él|strong="H3588"\w* \w me|strong="H3588"\w* \w declaró|strong="H5046"\w* \w todo|strong="H3605"\w* \w su|strong="H3588"\w* \w corazón|strong="H3820"\w*. \w Y|strong="H3068"\w* \w los|strong="H3605"\w* jefes \w de|strong="H3588"\w* \w los|strong="H3605"\w* \w filisteos|strong="H6430"\w* \w subieron|strong="H5927"\w* \w a|strong="H3068"\w* \w ella|strong="H3605"\w*, \w con|strong="H3588"\w* \w la|strong="H3588"\w* \w plata|strong="H3701"\w* \w en|strong="H3588"\w* \w su|strong="H3588"\w* \w mano|strong="H3027"\w*.
\v 19 \w Ella|strong="H5921"\w* \w entonces|strong="H5493"\w* \w lo|strong="H5921"\w* adormeció \w sobre|strong="H5921"\w* sus \w rodillas|strong="H1290"\w*, \w y|strong="H5921"\w* enseguida \w llamó|strong="H7121"\w* \w al|strong="H5921"\w* hombre \w que|strong="H5921"\w* \w le|strong="H5921"\w* rapó \w las|strong="H5921"\w* \w siete|strong="H7651"\w* trenzas \w de|strong="H5921"\w* su \w cabeza|strong="H7218"\w*, \w y|strong="H5921"\w* \w ella|strong="H5921"\w* misma \w comenzó|strong="H2490"\w* \w a|strong="H3068"\w* dominarlo, pues su \w fuerza|strong="H3581"\w* \w se|strong="H5921"\w* retiró \w de|strong="H5921"\w* \w él|strong="H5921"\w*.
\p 
\v 20 \w Ella|strong="H1931"\w* exclamó: ¡Sansón, \w los|strong="H5921"\w* \w filisteos|strong="H6430"\w* \w contra|strong="H5921"\w* \w ti|strong="H5921"\w*! \w Él|strong="H1931"\w* \w entonces|strong="H5493"\w*, \w al|strong="H5921"\w* despertar \w de|strong="H5921"\w* \w su|strong="H1931"\w* \w sueño|strong="H8142"\w*, \w se|strong="H3045"\w* dijo: \w Saldré|strong="H3318"\w* \w como|strong="H3588"\w* \w las|strong="H5921"\w* otras \w veces|strong="H6471"\w* \w y|strong="H3588"\w* \w me|strong="H5921"\w* sacudiré libre. \w Pero|strong="H3588"\w* \w no|strong="H3808"\w* \w sabía|strong="H3045"\w* \w que|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w se|strong="H3045"\w* apartó \w de|strong="H5921"\w* \w él|strong="H1931"\w*.
\p 
\v 21 Entonces \w los|strong="H1961"\w* \w filisteos|strong="H6430"\w* lo agarraron, \w le|strong="H5869"\w* sacaron \w los|strong="H1961"\w* \w ojos|strong="H5869"\w* y lo \w bajaron|strong="H3381"\w* \w a|strong="H3068"\w* \w Gaza|strong="H5804"\w*. Lo ataron con cadenas \w de|strong="H5869"\w* bronce \w para|strong="H1961"\w* \w que|strong="H1961"\w* moliera en la cárcel.
\v 22 Sin embargo, después que fue rapado, el cabello de su \w cabeza|strong="H7218"\w* \w comenzó|strong="H2490"\w* \w a|strong="H3068"\w* crecer.
\s1 Muerte de Sansón
\p 
\v 23 Entonces los jefes \w de|strong="H5414"\w* los \w filisteos|strong="H6430"\w* se reunieron \w para|strong="H5414"\w* ofrecer un \w gran|strong="H1419"\w* \w sacrificio|strong="H2077"\w* \w a|strong="H3068"\w* \w Dagón|strong="H1712"\w*, su \tl ʼelohim\tl*, y con \w gran|strong="H1419"\w* regocijo afirmaron: ¡Nuestro \tl ʼelohim\tl* \w entregó|strong="H5414"\w* en nuestras \w manos|strong="H3027"\w* \w a|strong="H3068"\w* nuestro enemigo Sansón!
\p 
\v 24 \w Cuando|strong="H3588"\w* \w el|strong="H3588"\w* \w pueblo|strong="H5971"\w* lo \w vio|strong="H7200"\w*, alabó \w a|strong="H3068"\w* \w su|strong="H3588"\w* \tl ʼelohim\tl*, \w porque|strong="H3588"\w* decían:
\q1 ¡Nuestro \tl ʼelohim\tl* \w entregó|strong="H5414"\w* \w en|strong="H3588"\w* nuestras \w manos|strong="H3027"\w* \w a|strong="H3068"\w* nuestro enemigo,
\q1 Al \w que|strong="H3588"\w* devastaba nuestra tierra,
\q1 \w Y|strong="H3068"\w* multiplicaba nuestras víctimas!
\p 
\v 25 \w Sucedió|strong="H1961"\w* \w que|strong="H3588"\w* \w cuando|strong="H3588"\w* \w tuvieron|strong="H1961"\w* \w alegre|strong="H2896"\w* \w el|strong="H3588"\w* \w corazón|strong="H3820"\w*, dijeron: Llamen \w a|strong="H3068"\w* Sansón \w para|strong="H3588"\w* \w que|strong="H3588"\w* nos divierta. \w Y|strong="H3068"\w* \w llamaron|strong="H7121"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* cárcel \w a|strong="H3068"\w* Sansón, \w el|strong="H3588"\w* \w cual|strong="H3588"\w* \w los|strong="H1961"\w* divertía. Lo hicieron estar \w en|strong="H3588"\w* \w pie|strong="H5975"\w* \w entre|strong="H3588"\w* las \w columnas|strong="H5982"\w*.
\v 26 \w Y|strong="H3068"\w* Sansón dijo \w al|strong="H5921"\w* lazarillo: Acércame \w y|strong="H5921"\w* hazme palpar \w las|strong="H5921"\w* \w columnas|strong="H5982"\w* \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* cuales descansa \w el|strong="H5921"\w* \w edificio|strong="H1004"\w*, \w para|strong="H5921"\w* \w que|strong="H5921"\w* \w me|strong="H5921"\w* apoye \w contra|strong="H5921"\w* \w ellas|strong="H5921"\w*.
\v 27 \w El|strong="H5921"\w* \w edificio|strong="H1004"\w* \w estaba|strong="H1004"\w* \w lleno|strong="H4390"\w* \w de|strong="H5921"\w* hombres \w y|strong="H5921"\w* mujeres. \w Todos|strong="H3605"\w* \w los|strong="H5921"\w* jefes \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w filisteos|strong="H6430"\w* estaban \w allí|strong="H8033"\w*, \w y|strong="H5921"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* azotea estaban \w como|strong="H5921"\w* 3.000 hombres \w y|strong="H5921"\w* mujeres \w que|strong="H5921"\w* observaban \w el|strong="H5921"\w* escarnio \w a|strong="H3068"\w* Sansón.
\p 
\v 28 Entonces Sansón invocó \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*:\nd* ¡Oh \nd ʼAdonay \w Yavé|strong="H3068"\w*\nd*, \w te|strong="H5869"\w* \w ruego|strong="H4994"\w* \w que|strong="H4994"\w* \w te|strong="H5869"\w* acuerdes \w de|strong="H5869"\w* \w mí|strong="H4994"\w*! ¡Dame fuerza solo \w esta|strong="H2088"\w* \w vez|strong="H6471"\w*, oh \nd ʼElohim\nd*, para \w que|strong="H4994"\w* \w yo|strong="H4994"\w* \w de|strong="H5869"\w* \w una|strong="H6471"\w* sola \w vez|strong="H6471"\w* me vengue \w de|strong="H5869"\w* los \w filisteos|strong="H6430"\w* \w por|strong="H2088"\w* mis \w dos|strong="H8147"\w* \w ojos|strong="H5869"\w*!
\p 
\v 29 Sansón palpó \w las|strong="H5921"\w* \w dos|strong="H8147"\w* \w columnas|strong="H5982"\w* centrales \w en|strong="H5921"\w* \w las|strong="H5921"\w* cuales descansaba \w el|strong="H5921"\w* \w edificio|strong="H1004"\w*, \w se|strong="H5921"\w* apoyó \w en|strong="H5921"\w* \w ellas|strong="H5921"\w*, una \w a|strong="H3068"\w* su \w derecha|strong="H3225"\w* \w y|strong="H5921"\w* otra \w a|strong="H3068"\w* su \w izquierda|strong="H8040"\w*.
\p 
\v 30 \w Y|strong="H3068"\w* Sansón exclamó: ¡\w Muera|strong="H4191"\w* \w yo|strong="H5315"\w* \w con|strong="H5973"\w* \w los|strong="H5921"\w* \w filisteos|strong="H6430"\w*!
\p \w Y|strong="H3068"\w* \w al|strong="H5921"\w* empujar \w con|strong="H5973"\w* \w fuerza|strong="H3581"\w*, \w el|strong="H5921"\w* \w edificio|strong="H1004"\w* \w cayó|strong="H5307"\w* \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* jefes \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* \w gente|strong="H5971"\w* \w que|strong="H5921"\w* \w estaba|strong="H1961"\w* \w en|strong="H5921"\w* \w él|strong="H5921"\w*. \w De|strong="H5921"\w* modo \w que|strong="H5921"\w* \w fueron|strong="H1961"\w* \w más|strong="H5921"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* \w mató|strong="H4191"\w* \w al|strong="H5921"\w* \w morir|strong="H4191"\w* \w que|strong="H5921"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* \w mató|strong="H4191"\w* \w en|strong="H5921"\w* su \w vida|strong="H5315"\w*.
\p 
\v 31 \w Bajaron|strong="H3381"\w* \w sus|strong="H1931"\w* hermanos con \w toda|strong="H3605"\w* \w la|strong="H1931"\w* \w casa|strong="H1004"\w* de \w su|strong="H1931"\w* padre y \w lo|strong="H1931"\w* levantaron, \w lo|strong="H1931"\w* \w llevaron|strong="H5375"\w* y \w lo|strong="H1931"\w* \w sepultaron|strong="H6912"\w* entre \w Sora|strong="H6881"\w* y Estaol, junto al \w sepulcro|strong="H6913"\w* de \w Manoa|strong="H4495"\w*, \w su|strong="H1931"\w* padre. \w Juzgó|strong="H8199"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* 20 \w años|strong="H8141"\w*.
\c 17
\s1 Confusión e idolatría
\p 
\v 1 \w Hubo|strong="H1961"\w* también un hombre de la región montañosa de Efraín \w llamado|strong="H8034"\w* Micaía,
\v 2 quien le dijo \w a|strong="H3068"\w* su madre: \w Los|strong="H1121"\w* 12,1 kilogramos \w de|strong="H1121"\w* \w plata|strong="H3701"\w* \w que|strong="H1571"\w* te fueron robados, \w con|strong="H1571"\w* respecto \w a|strong="H3068"\w* \w los|strong="H1121"\w* cuales pronunciaste maldición \w a|strong="H3068"\w* mis oídos, \w mira|strong="H2009"\w*, aquella \w plata|strong="H3701"\w* está en \w mi|strong="H2009"\w* poder. \w Yo|strong="H2009"\w* \w la|strong="H1571"\w* \w tomé|strong="H3947"\w*. \w Y|strong="H3068"\w* su madre le dijo: ¡\w Bendito|strong="H1288"\w* seas por \nd \w Yavé|strong="H3068"\w*\nd*, \w hijo|strong="H1121"\w* mío!
\p 
\v 3 \w Él|strong="H1121"\w* devolvió \w los|strong="H1121"\w* 12,1 kilogramos \w de|strong="H1121"\w* \w plata|strong="H3701"\w* \w a|strong="H3068"\w* su madre, y ella dijo: En verdad \w dedico|strong="H6942"\w* esta \w plata|strong="H3701"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w para|strong="H6258"\w* mi \w hijo|strong="H1121"\w*, \w a|strong="H3068"\w* fin \w de|strong="H1121"\w* \w que|strong="H6258"\w* \w haga|strong="H6213"\w* una \w imagen|strong="H6459"\w* tallada y \w otra|strong="H6213"\w* \w de|strong="H1121"\w* \w fundición|strong="H4541"\w*. \w Ahora|strong="H6258"\w* \w pues|strong="H6258"\w*, te la devuelvo.
\p 
\v 4 Sin embargo, \w él|strong="H6213"\w* devolvió la \w plata|strong="H3701"\w* \w a|strong="H3068"\w* su madre. Ella \w tomó|strong="H3947"\w* 2,2 kilogramos \w de|strong="H5414"\w* \w plata|strong="H3701"\w*, \w los|strong="H1961"\w* \w entregó|strong="H5414"\w* al \w fundidor|strong="H6884"\w*, \w el|strong="H6213"\w* cual \w hizo|strong="H6213"\w* con ellos una \w imagen|strong="H6459"\w* tallada y \w otra|strong="H6213"\w* \w de|strong="H5414"\w* \w fundición|strong="H4541"\w*, las cuales \w quedaron|strong="H1961"\w* en la \w casa|strong="H1004"\w* \w de|strong="H5414"\w* Micaía.
\p 
\v 5 \w De|strong="H1121"\w* manera \w que|strong="H1121"\w* Micaía \w tuvo|strong="H1961"\w* un santuario. \w Hizo|strong="H6213"\w* un \tl efod\tl* \w e|strong="H3068"\w* ídolos domésticos y \w consagró|strong="H4390"\w* \w a|strong="H3068"\w* uno \w de|strong="H1121"\w* sus \w hijos|strong="H1121"\w* \w para|strong="H1961"\w* \w que|strong="H1121"\w* \w fuera|strong="H1961"\w* su \w sacerdote|strong="H3548"\w*.
\v 6 En \w aquellos|strong="H1992"\w* \w días|strong="H3117"\w* \w no|strong="H6213"\w* \w había|strong="H6213"\w* \w rey|strong="H4428"\w* en \w Israel|strong="H3478"\w*, y \w cada|strong="H3117"\w* uno \w hacía|strong="H6213"\w* \w lo|strong="H6213"\w* \w que|strong="H3117"\w* \w le|strong="H5869"\w* \w parecía|strong="H5869"\w* \w recto|strong="H3477"\w*.
\p 
\v 7 \w Hubo|strong="H1961"\w* también un joven de Belén de \w Judá|strong="H3063"\w*, de \w la|strong="H1931"\w* \w familia|strong="H4940"\w* de \w Judá|strong="H3063"\w*, \w el|strong="H1931"\w* \w cual|strong="H1931"\w* \w era|strong="H1961"\w* \w levita|strong="H3881"\w*, y vivía \w allí|strong="H8033"\w* \w como|strong="H1961"\w* forastero.
\v 8 Este hombre \w salió|strong="H3212"\w* \w de|strong="H5704"\w* la \w ciudad|strong="H5892"\w* \w de|strong="H5704"\w* Belén \w de|strong="H5704"\w* \w Judá|strong="H3063"\w* \w para|strong="H5704"\w* residir donde \w hallara|strong="H4672"\w* lugar. \w Cuando|strong="H5704"\w* \w caminaba|strong="H3212"\w* \w por|strong="H1870"\w* la región montañosa \w de|strong="H5704"\w* Efraín \w llegó|strong="H3212"\w* \w hasta|strong="H5704"\w* la \w casa|strong="H1004"\w* \w de|strong="H5704"\w* Micaía.
\p 
\v 9 Micaía le dijo: ¿De dónde vienes? \w Y|strong="H3068"\w* le respondió: Soy \w levita|strong="H3881"\w* de Belén de \w Judá|strong="H3063"\w*, y \w voy|strong="H1980"\w* \w a|strong="H3068"\w* residir donde \w halle|strong="H4672"\w* lugar.
\p 
\v 10 Micaía le dijo: \w Quédate|strong="H3427"\w* \w conmigo|strong="H5978"\w*. Me servirás \w de|strong="H5414"\w* padre y \w sacerdote|strong="H3548"\w*, y te \w daré|strong="H5414"\w* 1,1 kilogramos \w de|strong="H5414"\w* \w plata|strong="H3701"\w* \w por|strong="H5414"\w* año, tu ropa y tu comida.
\p \w Y|strong="H3068"\w* \w el|strong="H3427"\w* \w levita|strong="H3881"\w* \w se|strong="H1961"\w* \w quedó|strong="H1961"\w*.
\v 11 \w El|strong="H1121"\w* \w levita|strong="H3881"\w* convino en vivir con aquel \w hombre|strong="H1121"\w*, y \w el|strong="H1121"\w* joven \w fue|strong="H1961"\w* \w para|strong="H1961"\w* \w él|strong="H1121"\w* \w como|strong="H1961"\w* uno \w de|strong="H1121"\w* sus \w hijos|strong="H1121"\w*.
\p 
\v 12 Micaía \w consagró|strong="H4390"\w* al \w levita|strong="H3881"\w*, y el joven \w fue|strong="H1961"\w* su \w sacerdote|strong="H3548"\w* y vivía en \w casa|strong="H1004"\w* de Micaía.
\v 13 \w Y|strong="H3068"\w* Micaía dijo: ¡\w Ahora|strong="H6258"\w* \w sé|strong="H3045"\w* \w que|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w me|strong="H3588"\w* prosperará \w porque|strong="H3588"\w* tengo \w a|strong="H3068"\w* un \w levita|strong="H3881"\w* \w como|strong="H3588"\w* \w sacerdote|strong="H3548"\w*!
\c 18
\s1 La conquista de Lais
\p 
\v 1 \w En|strong="H5704"\w* \w aquellos|strong="H1992"\w* \w días|strong="H3117"\w* \w no|strong="H3808"\w* \w había|strong="H3588"\w* \w rey|strong="H4428"\w* \w en|strong="H5704"\w* \w Israel|strong="H3478"\w*. \w Y|strong="H3068"\w* \w la|strong="H1931"\w* \w tribu|strong="H7626"\w* \w de|strong="H3588"\w* \w Dan|strong="H1839"\w* \w buscaba|strong="H1245"\w* una \w heredad|strong="H5159"\w* \w donde|strong="H1931"\w* vivir, \w porque|strong="H3588"\w* \w hasta|strong="H5704"\w* \w aquel|strong="H1931"\w* momento \w no|strong="H3808"\w* \w le|strong="H1931"\w* \w había|strong="H3588"\w* \w caído|strong="H5307"\w* \w heredad|strong="H5159"\w* \w entre|strong="H8432"\w* \w las|strong="H1992"\w* \w tribus|strong="H7626"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w*.
\p 
\v 2 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5704"\w* \w Dan|strong="H1835"\w* \w enviaron|strong="H7971"\w* \w a|strong="H3068"\w* \w cinco|strong="H2568"\w* \w hombres|strong="H1121"\w* \w valientes|strong="H2428"\w* \w de|strong="H5704"\w* sus \w familias|strong="H4940"\w*, \w de|strong="H5704"\w* \w los|strong="H1121"\w* \w más|strong="H5704"\w* nobles \w entre|strong="H8033"\w* ellos, \w desde|strong="H5704"\w* Zora \w y|strong="H5704"\w* Estaol \w para|strong="H5704"\w* explorar \w y|strong="H5704"\w* reconocer la tierra, \w y|strong="H5704"\w* les dijeron: ¡\w Vayan|strong="H3212"\w* \w y|strong="H5704"\w* exploren la tierra! Ellos llegaron \w a|strong="H3068"\w* la región montañosa \w de|strong="H5704"\w* Efraín, \w hasta|strong="H5704"\w* la \w casa|strong="H1004"\w* \w de|strong="H5704"\w* Micaía \w para|strong="H5704"\w* pasar \w allí|strong="H8033"\w* la noche.
\p 
\v 3 \w Cuando|strong="H4100"\w* \w se|strong="H1992"\w* acercaban \w a|strong="H3068"\w* la \w casa|strong="H1004"\w* \w de|strong="H5973"\w* Micaía, \w reconocieron|strong="H5234"\w* la \w voz|strong="H6963"\w* \w del|strong="H5973"\w* joven \w levita|strong="H3881"\w*. Al llegar \w allá|strong="H8033"\w*, \w le|strong="H5973"\w* preguntaron: ¿\w Quién|strong="H4310"\w* \w te|strong="H5973"\w* \w trajo|strong="H5493"\w* \w aquí|strong="H6311"\w*? ¿\w Qué|strong="H4100"\w* \w haces|strong="H6213"\w* \w en|strong="H5973"\w* \w este|strong="H2088"\w* lugar? ¿\w Qué|strong="H4100"\w* tienes \w aquí|strong="H6311"\w*?
\p 
\v 4 \w Y|strong="H3068"\w* \w él|strong="H6213"\w* les respondió: Micaía \w hizo|strong="H6213"\w* \w conmigo|strong="H6213"\w* de \w esta|strong="H2088"\w* y de aquella manera, y me tomó \w a|strong="H3068"\w* sueldo \w para|strong="H1961"\w* \w que|strong="H1961"\w* \w sea|strong="H1961"\w* su \w sacerdote|strong="H3548"\w*.
\p 
\v 5 \w Ellos|strong="H5921"\w* \w le|strong="H5921"\w* dijeron: \w Te|strong="H5921"\w* rogamos \w que|strong="H4994"\w* consultes \w a|strong="H3068"\w* \nd ʼElohim\nd* \w para|strong="H5921"\w* \w que|strong="H4994"\w* \w sepamos|strong="H3045"\w* \w si|strong="H4994"\w* será \w próspero|strong="H4994"\w* \w el|strong="H5921"\w* \w viaje|strong="H1870"\w* \w que|strong="H4994"\w* \w hacemos|strong="H1980"\w*.
\p 
\v 6 El \w sacerdote|strong="H3548"\w* les respondió: ¡\w Vayan|strong="H3212"\w* \w en|strong="H3212"\w* \w paz|strong="H7965"\w*! El \w camino|strong="H1870"\w* \w por|strong="H1870"\w* el cual andan está \w en|strong="H3212"\w* presencia de \nd \w Yavé|strong="H3068"\w*\nd*.
\p 
\v 7 \w Los|strong="H1992"\w* \w cinco|strong="H2568"\w* hombres salieron y llegaron \w a|strong="H3068"\w* \w Lais|strong="H3919"\w*. \w Vieron|strong="H7200"\w* \w que|strong="H5971"\w* la población \w que|strong="H5971"\w* \w estaba|strong="H3427"\w* \w en|strong="H5973"\w* ella \w vivía|strong="H3427"\w* \w con|strong="H5973"\w* seguridad, \w a|strong="H3068"\w* la \w manera|strong="H1697"\w* \w de|strong="H5973"\w* \w los|strong="H1992"\w* \w sidonios|strong="H6722"\w*, tranquilos y seguros, porque nadie \w estaba|strong="H3427"\w* \w en|strong="H5973"\w* aquella tierra \w que|strong="H5971"\w* \w los|strong="H1992"\w* perturbara \w en|strong="H5973"\w* alguna \w cosa|strong="H1697"\w*, \w ni|strong="H5973"\w* quien \w se|strong="H1992"\w* enseñoreara \w de|strong="H5973"\w* \w ellos|strong="H1992"\w*. \w Estaban|strong="H3427"\w* \w lejos|strong="H7350"\w* \w de|strong="H5973"\w* \w los|strong="H1992"\w* \w sidonios|strong="H6722"\w* y \w con|strong="H5973"\w* nadie tenían trato.
\p 
\v 8 Regresaron \w a|strong="H3068"\w* sus hermanos en Zora y Estaol, y sus hermanos les preguntaron: ¿\w Qué|strong="H4100"\w* informan?
\p 
\v 9 \w Ellos|strong="H5921"\w* dijeron: \w Levántense|strong="H6965"\w* \w y|strong="H3588"\w* marchemos \w contra|strong="H5921"\w* \w ellos|strong="H5921"\w*, \w porque|strong="H3588"\w* \w vimos|strong="H7200"\w* \w la|strong="H5921"\w* tierra \w y|strong="H3588"\w* \w ciertamente|strong="H3588"\w* \w es|strong="H3588"\w* \w muy|strong="H3966"\w* \w buena|strong="H2896"\w*. ¿\w Y|strong="H3068"\w* ustedes \w se|strong="H5921"\w* quedarán tranquilos? \w No|strong="H3588"\w* sean perezosos \w para|strong="H5921"\w* marchar allá \w y|strong="H3588"\w* tomar posesión \w de|strong="H5921"\w* esa tierra.
\v 10 \w Cuando|strong="H3588"\w* lleguen, entrarán \w a|strong="H3068"\w* un \w pueblo|strong="H5971"\w* seguro \w y|strong="H3588"\w* \w a|strong="H3068"\w* una tierra \w espaciosa|strong="H7342"\w*. \w Ciertamente|strong="H3588"\w*, \nd ʼElohim\nd* \w la|strong="H3588"\w* \w entregó|strong="H5414"\w* \w en|strong="H3588"\w* \w su|strong="H3588"\w* \w mano|strong="H3027"\w*. \w Es|strong="H3027"\w* un \w lugar|strong="H4725"\w* \w donde|strong="H8033"\w* \w no|strong="H3588"\w* \w falta|strong="H4270"\w* \w alguna|strong="H3605"\w* \w cosa|strong="H1697"\w* \w de|strong="H3588"\w* las \w que|strong="H3588"\w* hay \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra.
\p 
\v 11 Entonces 600 hombres equipados con \w armas|strong="H3627"\w* de \w guerra|strong="H4421"\w* \w salieron|strong="H5265"\w* de Zora y Estaol, de la \w familia|strong="H4940"\w* de los danitas.
\v 12 \w Subieron|strong="H5927"\w* \w y|strong="H5921"\w* acamparon \w en|strong="H5921"\w* Quiriat-jearim, \w en|strong="H5921"\w* \w Judá|strong="H3063"\w*, \w por|strong="H5921"\w* \w lo|strong="H1931"\w* \w cual|strong="H1931"\w* \w el|strong="H1931"\w* \w lugar|strong="H4725"\w* \w se|strong="H1931"\w* \w llama|strong="H7121"\w* \w hasta|strong="H5704"\w* \w el|strong="H1931"\w* \w día|strong="H3117"\w* \w de|strong="H5921"\w* \w hoy|strong="H3117"\w* Campamento \w de|strong="H5921"\w* Dan, \w el|strong="H1931"\w* \w cual|strong="H1931"\w* \w está|strong="H2088"\w* detrás \w de|strong="H5921"\w* Quiriat-jearim.
\v 13 \w De|strong="H5704"\w* \w allí|strong="H8033"\w* avanzaron \w hacia|strong="H8033"\w* la región montañosa \w de|strong="H5704"\w* Efraín, \w y|strong="H5704"\w* llegaron \w a|strong="H3068"\w* la \w casa|strong="H1004"\w* \w de|strong="H5704"\w* Micaía.
\p 
\v 14 Aquellos \w cinco|strong="H2568"\w* hombres \w que|strong="H3588"\w* \w fueron|strong="H1980"\w* \w a|strong="H3068"\w* reconocer \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w Lais|strong="H3919"\w*, tomaron \w la|strong="H3588"\w* palabra \w y|strong="H3588"\w* dijeron \w a|strong="H3068"\w* sus hermanos: ¿\w Saben|strong="H3045"\w* \w que|strong="H3588"\w* \w en|strong="H3588"\w* esas \w casas|strong="H1004"\w* \w hay|strong="H3426"\w* \tl efod\tl*, ídolos domésticos, una \w imagen|strong="H6459"\w* tallada \w y|strong="H3588"\w* una fundida? \w Por|strong="H3588"\w* tanto, miren \w lo|strong="H4100"\w* \w que|strong="H3588"\w* \w van|strong="H1980"\w* \w a|strong="H3068"\w* \w hacer|strong="H6213"\w*.
\v 15 Se desviaron \w hacia|strong="H8033"\w* \w allá|strong="H8033"\w* y saludaron \w pacíficamente|strong="H7965"\w* al entrar \w en|strong="H5493"\w* la \w casa|strong="H1004"\w* de Micaía, \w donde|strong="H8033"\w* vivía el joven \w levita|strong="H3881"\w*,
\v 16 pero permanecían en la entrada del portón \w los|strong="H1121"\w* 600 \w hombres|strong="H1121"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Dan|strong="H1835"\w* \w que|strong="H1121"\w* tenían atadas sus \w armas|strong="H3627"\w* \w de|strong="H1121"\w* \w guerra|strong="H4421"\w*.
\v 17 Los \w cinco|strong="H2568"\w* hombres que habían ido \w a|strong="H3068"\w* reconocer la tierra, \w subieron|strong="H5927"\w*, entraron y \w tomaron|strong="H3947"\w* la imagen tallada, el \tl efod\tl*, los \w ídolos|strong="H6456"\w* domésticos y la imagen fundida, mientras el \w sacerdote|strong="H3548"\w* permanecía en la entrada del portón con los 600 hombres \w armados|strong="H2296"\w* para la \w guerra|strong="H4421"\w*.
\p 
\v 18 Aquellos, \w pues|strong="H4100"\w*, entraron en la \w casa|strong="H1004"\w* de Micaía y \w tomaron|strong="H3947"\w* la \w imagen|strong="H6459"\w* tallada, \w el|strong="H6213"\w* \tl efod\tl*, los ídolos domésticos y la \w imagen|strong="H6459"\w* fundida. Entonces \w el|strong="H6213"\w* \w sacerdote|strong="H3548"\w* les preguntó: ¿\w Qué|strong="H4100"\w* \w hacen|strong="H6213"\w*?
\p 
\v 19 \w Ellos|strong="H3027"\w* \w le|strong="H5921"\w* respondieron: \w Calla|strong="H2790"\w*, \w pon|strong="H7760"\w* \w la|strong="H5921"\w* \w mano|strong="H3027"\w* \w sobre|strong="H5921"\w* tu \w boca|strong="H6310"\w* \w y|strong="H5921"\w* \w ven|strong="H3212"\w* \w con|strong="H5973"\w* \w nosotros|strong="H5973"\w*. \w Sé|strong="H1961"\w* \w para|strong="H5921"\w* \w nosotros|strong="H5973"\w* padre \w y|strong="H5921"\w* \w sacerdote|strong="H3548"\w*. ¿\w Te|strong="H5921"\w* \w es|strong="H1961"\w* \w mejor|strong="H2896"\w* ser \w sacerdote|strong="H3548"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* un solo hombre, \w que|strong="H5921"\w* \w para|strong="H5921"\w* una \w tribu|strong="H7626"\w* \w y|strong="H5921"\w* una \w familia|strong="H1004"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*?
\v 20 Entonces el \w corazón|strong="H3820"\w* del \w sacerdote|strong="H3548"\w* \w se|strong="H5971"\w* alegró y \w tomó|strong="H3947"\w* el \nd efod,\nd* los ídolos domésticos y la \w imagen|strong="H6459"\w* tallada, y fue con aquella \w gente|strong="H5971"\w*.
\v 21 Luego, tras colocar \w a|strong="H3068"\w* los pequeños, el \w ganado|strong="H4735"\w* y el equipaje \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ellos, dieron la vuelta y salieron.
\p 
\v 22 \w Ya|strong="H3068"\w* \w se|strong="H1992"\w* habían alejado \w de|strong="H5973"\w* la \w casa|strong="H1004"\w* \w de|strong="H5973"\w* Micaía cuando \w los|strong="H1992"\w* vecinos \w de|strong="H5973"\w* esa \w casa|strong="H1004"\w* fueron convocados. \w Siguieron|strong="H1692"\w* \w tras|strong="H5973"\w* \w los|strong="H1992"\w* \w hijos|strong="H1121"\w* \w de|strong="H5973"\w* \w Dan|strong="H1835"\w* y
\v 23 les \w gritaron|strong="H7121"\w*. \w Pero|strong="H3588"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* \w Dan|strong="H1835"\w*, al volver \w su|strong="H3588"\w* \w rostro|strong="H6440"\w*, dijeron \w a|strong="H3068"\w* Micaía: ¿\w Qué|strong="H3588"\w* pasó \w que|strong="H3588"\w* \w te|strong="H3588"\w* hizo reunir gente?
\p 
\v 24 \w Él|strong="H6213"\w* contestó: \w Tomaron|strong="H3947"\w* al \w sacerdote|strong="H3548"\w* y mis \tl ʼelohim\tl* \w que|strong="H4100"\w* \w hice|strong="H6213"\w*, y \w se|strong="H4100"\w* marcharon, ¿y \w qué|strong="H4100"\w* me queda? \w Aún|strong="H5750"\w* me preguntan: ¿\w Qué|strong="H4100"\w* pasó?
\p 
\v 25 Pero \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5973"\w* \w Dan|strong="H1835"\w* \w le|strong="H5973"\w* respondieron: \w Que|strong="H6435"\w* tu \w voz|strong="H6963"\w* \w no|strong="H6435"\w* \w se|strong="H6435"\w* \w oiga|strong="H8085"\w* \w entre|strong="H5973"\w* \w nosotros|strong="H5973"\w*, \w no|strong="H6435"\w* \w sea|strong="H6435"\w* \w que|strong="H6435"\w* \w los|strong="H1121"\w* \w de|strong="H5973"\w* \w ánimo|strong="H5315"\w* colérico \w te|strong="H5315"\w* ataquen, y pierdas tu \w vida|strong="H5315"\w* y las \w vidas|strong="H5315"\w* \w de|strong="H5973"\w* tu \w familia|strong="H1004"\w*.
\v 26 \w Los|strong="H1992"\w* danitas prosiguieron \w su|strong="H1992"\w* \w camino|strong="H1870"\w*, \w y|strong="H3588"\w* \w al|strong="H4480"\w* \w ver|strong="H7200"\w* Micaía \w que|strong="H3588"\w* eran \w más|strong="H3588"\w* \w fuertes|strong="H1121"\w* \w que|strong="H3588"\w* \w él|strong="H3588"\w*, regresó \w a|strong="H3068"\w* \w su|strong="H1992"\w* \w casa|strong="H1004"\w*.
\p 
\v 27 \w Los|strong="H1992"\w* danitas \w tomaron|strong="H3947"\w* \w lo|strong="H5921"\w* \w que|strong="H5921"\w* Micaía \w hizo|strong="H6213"\w* \w y|strong="H5921"\w* \w al|strong="H5921"\w* \w sacerdote|strong="H3548"\w* \w que|strong="H5921"\w* \w él|strong="H5921"\w* \w tenía|strong="H1961"\w*, cayeron \w sobre|strong="H5921"\w* \w Lais|strong="H3919"\w*, \w pueblo|strong="H5971"\w* tranquilo \w y|strong="H5921"\w* seguro. \w Los|strong="H1992"\w* \w mataron|strong="H5221"\w* \w a|strong="H3068"\w* filo \w de|strong="H5921"\w* \w espada|strong="H2719"\w* \w e|strong="H3068"\w* incendiaron \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w*.
\v 28 \w No|strong="H3588"\w* hubo \w quien|strong="H1931"\w* \w la|strong="H1931"\w* \w librara|strong="H5337"\w*, \w porque|strong="H3588"\w* \w estaba|strong="H3427"\w* \w lejos|strong="H7350"\w* \w de|strong="H3588"\w* \w Sidón|strong="H6721"\w*, \w y|strong="H3588"\w* \w no|strong="H3588"\w* tenían trato \w con|strong="H5973"\w* algún hombre. \w Estaba|strong="H3427"\w* \w en|strong="H5973"\w* \w el|strong="H1931"\w* \w valle|strong="H6010"\w* \w de|strong="H3588"\w* Bet-rehob.
\p \w Luego|strong="H1931"\w* reedificaron \w la|strong="H1931"\w* \w ciudad|strong="H5892"\w* \w y|strong="H3588"\w* vivieron \w en|strong="H5973"\w* \w ella|strong="H1931"\w*.
\v 29 \w Llamaron|strong="H7121"\w* \w a|strong="H3068"\w* la \w ciudad|strong="H5892"\w* \w Dan|strong="H1835"\w*, según el \w nombre|strong="H8034"\w* de su antepasado \w e|strong="H3068"\w* \w hijo|strong="H3205"\w* de \w Israel|strong="H3478"\w*, aunque \w antes|strong="H7223"\w* la \w ciudad|strong="H5892"\w* se \w llamaba|strong="H7121"\w* \w Lais|strong="H3919"\w*.
