\mt1 Zacarías  
\mt2 Exhortación  
\c 1  
\s1 Primeras visiones  
\p
\v 1 En \w el|strong="H1121"\w* \w octavo|strong="H8066"\w* \w mes|strong="H2320"\w* del \w año|strong="H8141"\w* \w segundo|strong="H8147"\w* \w de|strong="H1121"\w* \w Darío|strong="H1867"\w*, la \w Palabra|strong="H1697"\w* \w de|strong="H1121"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w vino|strong="H1961"\w* al \w profeta|strong="H5030"\w* \w Zacarías|strong="H2148"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Berequías, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Iddo|strong="H5714"\w*:  
\v 2 \wj \+nd \+w Yavé|strong="H3068"\+w*\+nd* estuvo muy airado \+w contra|strong="H5921"\+w* sus antepasados.\wj*  
\v 3 \wj \+w Ahora|strong="H3541"\+w* diles: \wj*\nd \+w Yavé|strong="H3068"\+w*\nd* de las huestes \w dice|strong="H5002"\w*: \wj Regresen \+w a|strong="H3068"\+w* Mí, \wj*\w dice|strong="H5002"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* de las huestes, \wj \+w y|strong="H3541"\+w* Yo \+w me|strong="H3541"\+w* \+w volveré|strong="H7725"\+w* \+w a|strong="H3068"\+w* ustedes.\wj*  
\v 4 \wj \+w No|strong="H3808"\+w* \+w sean|strong="H1961"\+w* \+w como|strong="H1961"\+w* sus antepasados, \+w a|strong="H3068"\+w* quienes \+w los|strong="H1961"\+w* \+w primeros|strong="H7223"\+w* \+w profetas|strong="H5030"\+w* proclamaron: \+nd \+w Yavé|strong="H3068"\+w*\+nd* \+w de|strong="H7451"\+w* las huestes \+w dice|strong="H5002"\+w*: Regresen \+w ahora|strong="H4994"\+w* \+w de|strong="H7451"\+w* sus \+w malos|strong="H7451"\+w* \+w caminos|strong="H1870"\+w* \+w y|strong="H3541"\+w* \+w de|strong="H7451"\+w* sus \+w malas|strong="H7451"\+w* \+w obras|strong="H4611"\+w*. Pero \+w no|strong="H3808"\+w* \+w escucharon|strong="H8085"\+w*, \+w ni|strong="H3808"\+w* \+w me|strong="H3541"\+w* \+w atendieron|strong="H7181"\+w*, \wj*\w dice|strong="H5002"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.  
\v 5 \wj ¿Dónde están \+w sus|strong="H1992"\+w* antepasados? ¿Viven \+w los|strong="H1992"\+w* \+w profetas|strong="H5030"\+w* para \+w siempre|strong="H5769"\+w*?\wj*  
\v 6 \wj Pero mis \+w Palabras|strong="H1697"\+w* y mis Preceptos \+w que|strong="H3808"\+w* \+w ordené|strong="H6680"\+w* \+w por|strong="H1870"\+w* medio \+w de|strong="H1697"\+w* mis esclavos \+w profetas|strong="H5030"\+w*, ¿\+w no|strong="H3808"\+w* \+w alcanzaron|strong="H5381"\+w* \+w a|strong="H3068"\+w* sus antepasados? \wj*  
\p \wj \+w Entonces|strong="H3651"\+w* \+w se|strong="H3808"\+w* convirtieron y \+w dijeron|strong="H1697"\+w*: \+w Como|strong="H3651"\+w* \+nd \+w Yavé|strong="H3068"\+w*\+nd* \+w de|strong="H1697"\+w* las huestes \+w se|strong="H3808"\+w* propuso \+w hacer|strong="H6213"\+w* con nosotros \+w a|strong="H3068"\+w* \+w causa|strong="H1697"\+w* \+w de|strong="H1697"\+w* nuestros procedimientos y \+w de|strong="H1697"\+w* nuestras \+w obras|strong="H4611"\+w*, \+w así|strong="H3651"\+w* nos \+w hizo|strong="H6213"\+w*.\wj*   
\s1 Restauración de Sion  
\p
\v 7 \w El|strong="H1931"\w* \w día|strong="H3117"\w* 24 del \w mes|strong="H2320"\w* \w undécimo|strong="H6249"\w*, \w que|strong="H1931"\w* \w es|strong="H1931"\w* \w el|strong="H1931"\w* \w mes|strong="H2320"\w* \w de|strong="H1121"\w* Sebat, \w el|strong="H1931"\w* \w año|strong="H8141"\w* \w segundo|strong="H8147"\w* \w de|strong="H1121"\w* \w Darío|strong="H1867"\w*, \w la|strong="H1931"\w* \w Palabra|strong="H1697"\w* \w de|strong="H1121"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w vino|strong="H1961"\w* al \w profeta|strong="H5030"\w* \w Zacarías|strong="H2148"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Berequías, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Iddo|strong="H5714"\w*:  
\v 8 \w Vi|strong="H7200"\w* \w de|strong="H5921"\w* \w noche|strong="H3915"\w*, \w y|strong="H5921"\w* ahí \w estaba|strong="H5975"\w* un varón \w que|strong="H1931"\w* \w cabalgaba|strong="H7392"\w* \w sobre|strong="H5921"\w* un \w caballo|strong="H5483"\w* rojizo, \w el|strong="H1931"\w* \w cual|strong="H1931"\w* \w estaba|strong="H5975"\w* \w entre|strong="H5921"\w* \w los|strong="H5921"\w* mirtos \w de|strong="H5921"\w* \w la|strong="H1931"\w* hondonada. Detrás \w de|strong="H5921"\w* \w él|strong="H1931"\w* \w había|strong="H5975"\w* \w caballos|strong="H5483"\w* rojizos, \w blancos|strong="H3836"\w* \w y|strong="H5921"\w* color canela.  
\v 9 Entonces \w dije|strong="H1696"\w*: \tl ʼadón\tl* mío, ¿para \w qué|strong="H4100"\w* son \w éstos|strong="H1992"\w*?  
\p \w Y|strong="H3068"\w* \w el|strong="H1992"\w* \w ángel|strong="H4397"\w* \w que|strong="H4100"\w* \w hablaba|strong="H1696"\w* conmigo me contestó: Yo te \w mostraré|strong="H7200"\w* para \w qué|strong="H4100"\w* son \w éstos|strong="H1992"\w*.   
\p
\v 10 \w Y|strong="H3068"\w* el varón que permanecía entre los mirtos \w respondió|strong="H6030"\w*: Éstos son los que \nd \+w Yavé|strong="H3068"\+w*\nd* \w envió|strong="H7971"\w* \w a|strong="H3068"\w* recorrer la tierra.   
\p
\v 11 \add Sus jinetes\add* informaron al \w Ángel|strong="H4397"\w* de \nd \+w Yavé|strong="H3068"\+w*\nd*, \w que|strong="H3605"\w* \w estaba|strong="H5975"\w* entre \w los|strong="H3427"\w* mirtos, y dijeron: Recorrimos \w la|strong="H3605"\w* tierra, y \w ciertamente|strong="H2009"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra \w está|strong="H5975"\w* tranquila y reposada.   
\p
\v 12 Entonces el \w Ángel|strong="H4397"\w* \w de|strong="H5704"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* tomó la palabra: ¡Oh \nd \+w Yavé|strong="H3068"\+w*\nd* \w de|strong="H5704"\w* las huestes! ¿\w Hasta|strong="H5704"\w* \w cuándo|strong="H4970"\w* \w no|strong="H3808"\w* te compadecerás \w de|strong="H5704"\w* Jerusalén \w y|strong="H5704"\w* \w de|strong="H5704"\w* las \w ciudades|strong="H5892"\w* \w de|strong="H5704"\w* \w Judá|strong="H3063"\w*, contra las cuales estuviste \w airado|strong="H2194"\w* \w estos|strong="H2088"\w* 70 \w años|strong="H8141"\w*?   
\p
\v 13 \nd \+w Yavé|strong="H3068"\+w*\nd* \w respondió|strong="H6030"\w* al \w ángel|strong="H4397"\w* \w que|strong="H1697"\w* \w hablaba|strong="H1696"\w* conmigo \w buenas|strong="H2896"\w* \w palabras|strong="H1697"\w* \w de|strong="H1697"\w* consolación.  
\v 14 Entonces \w me|strong="H3541"\w* \w dijo|strong="H1696"\w* el \w ángel|strong="H4397"\w* \w que|strong="H3541"\w* \w hablaba|strong="H1696"\w* conmigo: Proclama: \nd \+w Yavé|strong="H3068"\+w*\nd* de las huestes \w dice|strong="H1696"\w*: \wj Tuve \+w gran|strong="H1419"\+w* \+w celo|strong="H7068"\+w* por Jerusalén \+w y|strong="H3541"\+w* por \+w Sion|strong="H6726"\+w*.\wj*  
\v 15 \wj Pero estoy muy airado \+w contra|strong="H5921"\+w* \+w las|strong="H1992"\+w* \+w naciones|strong="H1471"\+w* confiadas, \+w porque|strong="H5921"\+w* mientras estuve airado solo un \+w poco|strong="H4592"\+w*, \+w ellos|strong="H1992"\+w* promovieron \+w el|strong="H5921"\+w* desastre.\wj*   
\p
\v 16 \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w dice|strong="H5002"\w*: \wj \+w Me|strong="H5921"\+w* \+w volví|strong="H7725"\+w* \+w a|strong="H3068"\+w* Jerusalén \+w con|strong="H5921"\+w* compasión. \+w En|strong="H5921"\+w* \+w ella|strong="H5921"\+w* será \+w edificada|strong="H1129"\+w* \+w mi|strong="H5921"\+w* \+w Casa|strong="H1004"\+w*,\wj* \w dice|strong="H5002"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w de|strong="H5921"\w* \w las|strong="H5921"\w* huestes, \wj \+w y|strong="H5921"\+w* \+w el|strong="H5921"\+w* cordel \+w de|strong="H5921"\+w* medir será tendido \+w sobre|strong="H5921"\+w* Jerusalén.\wj*   
\p
\v 17 Proclama \w además|strong="H5750"\w*: \nd \+w Yavé|strong="H3068"\+w*\nd* \w de|strong="H5750"\w* las huestes dice: \wj \+w Otra|strong="H5750"\+w* vez rebosarán \+w de|strong="H5750"\+w* prosperidad mis \+w ciudades|strong="H5892"\+w*. \+nd \+w Yavé|strong="H3068"\+w*\+nd* volverá \+w a|strong="H3068"\+w* consolar \+w a|strong="H3068"\+w* \+w Sion|strong="H6726"\+w*, \+w y|strong="H3541"\+w* \+w otra|strong="H5750"\+w* vez escoge \+w a|strong="H3068"\+w* Jerusalén.\wj*   
\s1 Los cuatro cuernos  
\p
\v 18 Después alcé mis ojos, miré, y ahí estaban cuatro cuernos.  
\v 19 \w Y|strong="H3068"\w* dije al ángel que hablaba conmigo: ¿Qué hacen éstos?  
\p \w Y|strong="H3068"\w* me respondió: Éstos son los cuernos que dispersaron \w a|strong="H3068"\w* Judá, Israel y Jerusalén.   
\p
\v 20 \nd \+w Yavé|strong="H3068"\+w*\nd* me mostró cuatro artesanos.   
\p
\v 21 \w Y|strong="H3068"\w* yo pregunté: ¿Qué vienen \w a|strong="H3068"\w* hacer éstos?  
\p Me respondió: \wj Aquéllos eran los cuernos que dispersaron \+w a|strong="H3068"\+w* Judá, de tal manera que nadie levantaba su cabeza. Pero éstos vinieron para hacerlos temblar y derribar los cuernos de las naciones que alzaron su cuerno contra la tierra de Judá para dispersarla.\wj*   
\c 2  
\s1 Tercera visión  
\p
\v 1 Después levanté \w mis|strong="H5375"\w* \w ojos|strong="H5869"\w* y \w miré|strong="H7200"\w*, y ahí \w estaba|strong="H2009"\w* un varón con un cordel \w de|strong="H5869"\w* medir en su mano.  
\v 2 \w Y|strong="H3068"\w* le pregunté: ¿\w A|strong="H3068"\w* dónde vas?  
\p \w Y|strong="H3068"\w* me respondió: \w A|strong="H3068"\w* medir Jerusalén, para ver \w cuál|strong="H4100"\w* es su anchura y su longitud.   
\p
\v 3 Cuando salía el ángel que hablaba conmigo, otro ángel le salió al encuentro,  
\v 4 y le dijo: \wj Corre, habla \+w a|strong="H3068"\+w* ese joven, y dile: Jerusalén \+w será|strong="H3808"\+w* habitada \+w sin|strong="H3808"\+w* muros \+w a|strong="H3068"\+w* causa de la multitud de personas y de ganado \+w que|strong="H4100"\+w* habrá en ella. \wj*  
\v 5 \wj \+w Yo|strong="H2009"\+w* \+w le|strong="H5869"\+w* seré muro \+w de|strong="H5869"\+w* fuego alrededor, y \+w mi|strong="H5375"\+w* gloria estará dentro \+w de|strong="H5869"\+w* ella,\wj* dice \nd \+w Yavé|strong="H3068"\+w*\nd*.   
\p
\v 6 \wj ¡Eh, \+w eh|strong="H3068"\+w*! Huyan de la tierra del norte,\wj* dice \nd \+w Yavé|strong="H3068"\+w*\nd*. \wj \+w Pues|strong="H7200"\+w* los esparcí \+w por|strong="H4100"\+w* los cuatro puntos del cielo,\wj* dice \nd \+w Yavé|strong="H3068"\+w*\nd*.  
\v 7 \wj ¡Escapa, oh Sion, tú que vives con la hija de Babilonia!\wj*  
\v 8 Porque \nd \+w Yavé|strong="H3068"\+w*\nd* de las huestes \w dice|strong="H1696"\w*: Tras la gloria me enviará \w a|strong="H3068"\w* las naciones que \w los|strong="H3427"\w* despojaron, porque \w el|strong="H3427"\w* que \w los|strong="H3427"\w* toca, toca la niña de \w mi|strong="H3389"\w* ojo.  
\v 9 \wj Por tanto, miren: Yo levanto \+w mi|strong="H1961"\+w* mano \+w contra|strong="H1961"\+w* ellos, \+w y|strong="H3519"\+w* \+w serán|strong="H1961"\+w* despojo \+w para|strong="H1961"\+w* \+w los|strong="H1961"\+w* \+w que|strong="H1961"\+w* \+w fueron|strong="H1961"\+w* sus esclavos. \+w Y|strong="H3068"\+w* sabrán \+w que|strong="H1961"\+w* \+nd \+w Yavé|strong="H3068"\+w*\+nd* de las huestes me envió.\wj*   
\p
\v 10 \wj ¡Canta \+w y|strong="H3588"\+w* alégrate, hija \+w de|strong="H3588"\+w* Sion, \+w porque|strong="H3588"\+w* \+w ciertamente|strong="H3588"\+w* vengo, \+w y|strong="H3588"\+w* viviré \+w en|strong="H3588"\+w* medio \+w de|strong="H3588"\+w* ti! \wj*\w dice|strong="H5002"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.  
\v 11 \wj Aquel día se unirán \+w a|strong="H3068"\+w* \+nd \+w Yavé|strong="H3068"\+w*\+nd* muchas naciones y serán mi pueblo. Viviré en medio de ti, \wj*y conocerán \w que|strong="H1323"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* de las huestes me envió \w a|strong="H3068"\w* ti.  
\v 12 \nd \+w Yavé|strong="H3068"\+w*\nd* poseerá \w a|strong="H3068"\w* Judá \w como|strong="H3588"\w* \w su|strong="H3588"\w* heredad \w en|strong="H3588"\w* \w la|strong="H3588"\w* tierra santa, \w y|strong="H3588"\w* escogerá \w a|strong="H3068"\w* Jerusalén.   
\p
\v 13 ¡Calle todo mortal ante \nd \+w Yavé|strong="H3068"\+w*\nd*, \w porque|strong="H3588"\w* \w Él|strong="H5921"\w* despertó \w en|strong="H5921"\w* \w su|strong="H3588"\w* santa morada!   
\c 3  
\s1 Cuarta visión  
\p
\v 1 \w Después|strong="H5921"\w* \w me|strong="H5921"\w* \w mostró|strong="H7200"\w* \w al|strong="H5921"\w* \w sumo|strong="H1419"\w* \w sacerdote|strong="H3548"\w* \w Josué|strong="H3091"\w* puesto \w delante|strong="H6440"\w* \w del|strong="H5921"\w* \w Ángel|strong="H4397"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*. \w Satán|strong="H7854"\w* \w estaba|strong="H5975"\w* \w a|strong="H3068"\w* su mano \w derecha|strong="H3225"\w* \w para|strong="H5921"\w* acusarlo.  
\v 2 \nd \+w Yavé|strong="H3068"\+w*\nd* dijo \w a|strong="H3068"\w* \w Satán|strong="H7854"\w*: \wj ¡\+nd \+w Yavé|strong="H3068"\+w*\+nd* te reprenda, \+w Satán|strong="H7854"\+w*! \+nd \+w Yavé|strong="H3068"\+w*\+nd*, Quien escogió \+w a|strong="H3068"\+w* Jerusalén, te reprenda. ¿\+w No|strong="H3808"\+w* \+w es|strong="H2088"\+w* \+w éste|strong="H2088"\+w* un tizón \+w arrebatado|strong="H5337"\+w* del fuego?\wj*   
\p
\v 3 \w Josué|strong="H3091"\w* \w estaba|strong="H1961"\w* \w vestido|strong="H3847"\w* con ropas impuras y \w estaba|strong="H1961"\w* \w en|strong="H5975"\w* \w pie|strong="H5975"\w* \w ante|strong="H6440"\w* el \w Ángel|strong="H4397"\w*.  
\v 4 \w Éste|strong="H5975"\w* mandó \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* \w estaban|strong="H5975"\w* \w ante|strong="H6440"\w* \w Él|strong="H5921"\w*: \wj ¡Quítenle \+w las|strong="H5921"\+w* ropas impuras!\wj* \w Y|strong="H3068"\w* \w a|strong="H3068"\w* \w él|strong="H5921"\w* \w le|strong="H5921"\w* dijo: \wj \+w Mira|strong="H7200"\+w*, \+w quité|strong="H5493"\+w* \+w de|strong="H5921"\+w* \+w ti|strong="H5921"\+w* tu \+w pecado|strong="H5771"\+w*, \+w y|strong="H5921"\+w* \+w te|strong="H5921"\+w* vestí ropas \+w de|strong="H5921"\+w* \+w gala|strong="H4254"\+w*.\wj*   
\p
\v 5 Entonces dijo: \wj ¡Coloquen un turbante \+w limpio|strong="H2889"\+w* \+w sobre|strong="H5921"\+w* su \+w cabeza|strong="H7218"\+w*!\wj*  
\p \w Y|strong="H3068"\w* \w pusieron|strong="H7760"\w* un turbante \w sobre|strong="H5921"\w* su \w cabeza|strong="H7218"\w*, \w y|strong="H5921"\w* \w lo|strong="H5921"\w* vistieron \w con|strong="H5921"\w* ropas. \w Y|strong="H3068"\w* \w el|strong="H5921"\w* \w Ángel|strong="H4397"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w estaba|strong="H5975"\w* \w en|strong="H5921"\w* \w pie|strong="H5975"\w*.   
\p
\v 6 Después el \w Ángel|strong="H4397"\w* de \nd \+w Yavé|strong="H3068"\+w*\nd* amonestó \w a|strong="H3068"\w* \w Josué|strong="H3091"\w*:  
\v 7 \nd \+w Yavé|strong="H3068"\+w*\nd* \w de|strong="H5414"\w* las huestes dice: \wj \+w Si|strong="H1571"\+w* andas \+w por|strong="H1870"\+w* \+w mis|strong="H5414"\+w* \+w caminos|strong="H1870"\+w* \+w y|strong="H1571"\+w* \+w si|strong="H1571"\+w* \+w guardas|strong="H8104"\+w* mi Mandato, \+w también|strong="H1571"\+w* tú gobernarás mi \+w Casa|strong="H1004"\+w* \+w y|strong="H1571"\+w* \+w guardarás|strong="H8104"\+w* \+w mis|strong="H5414"\+w* \+w patios|strong="H2691"\+w*. Te \+w daré|strong="H5414"\+w* libre acceso entre \+w éstos|strong="H1571"\+w* \+w que|strong="H1571"\+w* están \+w presentes|strong="H5975"\+w*.\wj*  
\v 8 \wj \+w Escucha|strong="H8085"\+w* \+w ahora|strong="H4994"\+w*, \+w Josué|strong="H3091"\+w*, \+w sumo|strong="H1419"\+w* \+w sacerdote|strong="H3548"\+w*, tú \+w y|strong="H3588"\+w* tus \+w compañeros|strong="H7453"\+w* \+w que|strong="H3588"\+w* \+w se|strong="H1992"\+w* sientan \+w delante|strong="H6440"\+w* \+w de|strong="H3588"\+w* ti, \+w que|strong="H3588"\+w* \+w ciertamente|strong="H3588"\+w* \+w son|strong="H3588"\+w* \+w varones|strong="H3588"\+w* \+w simbólicos|strong="H4159"\+w*, \+w porque|strong="H3588"\+w* \+w mira|strong="H2005"\+w*, \+w Yo|strong="H3588"\+w* traigo \+w a|strong="H3068"\+w* \+w mi|strong="H4994"\+w* Esclavo, \+w el|strong="H3588"\+w* \+w Renuevo|strong="H6780"\+w*.\wj*   
\p
\v 9 \wj \+w Mira|strong="H2009"\+w*, \+w pongo|strong="H5414"\+w* una piedra \+w delante|strong="H6440"\+w* \+w de|strong="H5921"\+w* \+w Josué|strong="H3091"\+w*. \+w Es|strong="H1931"\+w* una piedra única \+w en|strong="H5921"\+w* \+w la|strong="H1931"\+w* \+w cual|strong="H1931"\+w* hay \+w siete|strong="H7651"\+w* \+w ojos|strong="H5869"\+w*. \+w Yo|strong="H3588"\+w* \+w mismo|strong="H1931"\+w* esculpiré una inscripción \+w en|strong="H5921"\+w* \+w ella|strong="H1931"\+w*, \wj*\w dice|strong="H5002"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w de|strong="H5921"\w* \w las|strong="H5921"\w* huestes. \wj \+w Yo|strong="H3588"\+w* quitaré \+w la|strong="H1931"\+w* \+w iniquidad|strong="H5771"\+w* \+w de|strong="H5921"\+w* \+w la|strong="H1931"\+w* tierra \+w en|strong="H5921"\+w* un \+w día|strong="H3117"\+w*. \wj*  
\v 10 \wj \+w En|strong="H8478"\+w* \+w aquel|strong="H1931"\+w* \+w día|strong="H3117"\+w*,\wj* \w dice|strong="H5002"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w de|strong="H8478"\w* las huestes, \wj \+w cada|strong="H3117"\+w* uno invitará \+w a|strong="H3068"\+w* \+w su|strong="H1931"\+w* \+w compañero|strong="H7453"\+w*, \+w a|strong="H3068"\+w* estar \+w debajo|strong="H8478"\+w* \+w de|strong="H8478"\+w* \+w su|strong="H1931"\+w* \+w vid|strong="H1612"\+w* y \+w debajo|strong="H8478"\+w* \+w de|strong="H8478"\+w* \+w su|strong="H1931"\+w* higuera.\wj*   
\c 4  
\s1 Quinta visión  
\p
\v 1 El \w ángel|strong="H4397"\w* que \w hablaba|strong="H1696"\w* conmigo se \w volvió|strong="H7725"\w* y me \w despertó|strong="H5782"\w*, como cuando un hombre es despertado de su \w sueño|strong="H8142"\w*.  
\v 2 \w Y|strong="H3068"\w* \w me|strong="H5921"\w* preguntó: ¿\w Qué|strong="H4100"\w* miras?  
\p Respondí: \w Ciertamente|strong="H2009"\w*, \w miro|strong="H7200"\w* un candelabro \w todo|strong="H3605"\w* \w de|strong="H5921"\w* \w oro|strong="H2091"\w*, \w con|strong="H5921"\w* su tazón \w encima|strong="H5921"\w*, \w y|strong="H5921"\w* sus \w siete|strong="H7651"\w* \w lámparas|strong="H5216"\w* \w sobre|strong="H5921"\w* \w él|strong="H5921"\w*, \w con|strong="H5921"\w* \w siete|strong="H7651"\w* canales \w para|strong="H5921"\w* \w cada|strong="H3605"\w* una \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w lámparas|strong="H5216"\w* \w que|strong="H4100"\w* \w están|strong="H2009"\w* \w encima|strong="H5921"\w*.  
\v 3 \w Y|strong="H3068"\w* \w dos|strong="H8147"\w* olivos \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w él|strong="H5921"\w*, uno \w por|strong="H5921"\w* cada lado \w del|strong="H5921"\w* tazón.   
\p
\v 4 \w Proseguí|strong="H6030"\w* y \w dije|strong="H1696"\w* al \w ángel|strong="H4397"\w* \w que|strong="H4100"\w* \w hablaba|strong="H1696"\w* conmigo: ¿\w Qué|strong="H4100"\w* es esto, \tl ʼadón\tl* mío?   
\p
\v 5 \w Y|strong="H3068"\w* \w el|strong="H1992"\w* \w ángel|strong="H4397"\w* \w que|strong="H4100"\w* \w hablaba|strong="H1696"\w* conmigo \w respondió|strong="H6030"\w*: ¿\w No|strong="H3808"\w* \w sabes|strong="H3045"\w* \w qué|strong="H4100"\w* es esto?  
\p \w Dije|strong="H1696"\w*: \w No|strong="H3808"\w*, \tl ʼadón\tl* mío.   
\p
\v 6 \w Y|strong="H3068"\w* \w él|strong="H3588"\w* \w me|strong="H3588"\w* dijo: \w Ésta|strong="H2088"\w* \w es|strong="H2088"\w* \w la|strong="H3588"\w* \w Palabra|strong="H1697"\w* \w de|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w a|strong="H3068"\w* \w Zorobabel|strong="H2216"\w*, Quien \w dice|strong="H1697"\w*: \wj \+w No|strong="H3808"\+w* \+w con|strong="H3588"\+w* \+w ejército|strong="H2428"\+w*, \+w ni|strong="H3808"\+w* \+w con|strong="H3588"\+w* \+w fuerza|strong="H3581"\+w*, \+w sino|strong="H3588"\+w* \+w con|strong="H3588"\+w* \+w mi|strong="H6030"\+w* \+w Espíritu|strong="H7307"\+w*,\wj* \w dice|strong="H1697"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w de|strong="H3588"\w* las huestes.  
\v 7 \wj ¿\+w Qué|strong="H4310"\+w* eres tú, \+w oh|strong="H4310"\+w* \+w gran|strong="H1419"\+w* montaña? ¡\+w Ante|strong="H6440"\+w* \+w Zorobabel|strong="H2216"\+w* serás una explanada! \+w Él|strong="H4310"\+w* \+w sacará|strong="H3318"\+w* la piedra \+w principal|strong="H1419"\+w* \+w de|strong="H6440"\+w* remate con aclamaciones: ¡\+w Gracia|strong="H2580"\+w*, \+w gracia|strong="H2580"\+w* \+w a|strong="H3068"\+w* ella!\wj*   
\p
\v 8 Además la \w Palabra|strong="H1697"\w* \w de|strong="H1697"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w*:  
\v 9 \wj Las \+w manos|strong="H3027"\+w* \+w de|strong="H3588"\+w* \+w Zorobabel|strong="H2216"\+w* pusieron \+w los|strong="H3588"\+w* \+w cimientos|strong="H3245"\+w* \+w de|strong="H3588"\+w* \+w esta|strong="H2088"\+w* \+w Casa|strong="H1004"\+w*, \+w y|strong="H3588"\+w* sus \+w manos|strong="H3027"\+w* \+w la|strong="H3588"\+w* acabarán. \wj*\w Entonces|strong="H3588"\w* entenderás \w que|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w de|strong="H3588"\w* las huestes \w me|strong="H3588"\w* \w envió|strong="H7971"\w* \w a|strong="H3068"\w* ustedes.  
\v 10 \w Porque|strong="H3588"\w* ¿\w quién|strong="H4310"\w* \w es|strong="H3027"\w* \w el|strong="H3588"\w* \w que|strong="H3588"\w* \w menosprecia|strong="H7200"\w* \w el|strong="H3588"\w* \w día|strong="H3117"\w* \w de|strong="H3588"\w* \w las|strong="H1992"\w* \w pequeñas|strong="H6996"\w* \w cosas|strong="H1992"\w*? \w Porque|strong="H3588"\w* \w estos|strong="H1992"\w* \w siete|strong="H7651"\w* \w se|strong="H1992"\w* alegrarán \w y|strong="H3588"\w* \w mirarán|strong="H7200"\w* \w la|strong="H3588"\w* plomada \w en|strong="H3588"\w* \w mano|strong="H3027"\w* \w de|strong="H3588"\w* \w Zorobabel|strong="H2216"\w*. \w Son|strong="H3588"\w* \w los|strong="H1992"\w* \w siete|strong="H7651"\w* \w ojos|strong="H5869"\w* \w de|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w que|strong="H3588"\w* \w recorren|strong="H7751"\w* \w toda|strong="H3605"\w* \w la|strong="H3588"\w* tierra.   
\p
\v 11 \w Y|strong="H3068"\w* \w hablé|strong="H6030"\w* \w la|strong="H5921"\w* segunda vez \w y|strong="H5921"\w* \w le|strong="H5921"\w* pregunté: ¿\w Qué|strong="H4100"\w* simbolizan estos \w dos|strong="H8147"\w* olivos, \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w derecha|strong="H3225"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w izquierda|strong="H8040"\w* \w del|strong="H5921"\w* candelabro?   
\p
\v 12 Volví \w a|strong="H3068"\w* hablar \w otra|strong="H8145"\w* vez \w y|strong="H5921"\w* pregunté: ¿\w Qué|strong="H4100"\w* simbolizan \w las|strong="H5921"\w* \w dos|strong="H8147"\w* \w ramas|strong="H7641"\w* \w de|strong="H5921"\w* olivo \w que|strong="H4100"\w* están \w al|strong="H5921"\w* \w lado|strong="H8145"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w dos|strong="H8147"\w* canales \w de|strong="H5921"\w* \w oro|strong="H2091"\w*, \w que|strong="H4100"\w* \w vierten|strong="H7324"\w* \w de|strong="H5921"\w* \w ellas|strong="H5921"\w* \w el|strong="H5921"\w* \add aceite\add* dorado?   
\p
\v 13 \w Y|strong="H3068"\w* me contestó: ¿\w No|strong="H3808"\w* \w sabes|strong="H3045"\w* \w qué|strong="H4100"\w* simbolizan estas \w cosas|strong="H3045"\w*?  
\p \w Y|strong="H3068"\w* dije: \w No|strong="H3808"\w*, \tl ʼadón\tl* mío.   
\p
\v 14 Respondió: \w Estos|strong="H3605"\w* son \w los|strong="H1121"\w* \w dos|strong="H8147"\w* ungidos \w que|strong="H5921"\w* están \w delante|strong="H5921"\w* \w del|strong="H5921"\w* \tl ʼAdón\tl* \w de|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* tierra.   
\c 5  
\s1 Sexta y séptima visiones  
\p
\v 1 \w Volví|strong="H7725"\w* \w a|strong="H3068"\w* levantar la vista, y al \w mirar|strong="H7200"\w*, \w vi|strong="H7200"\w* un \w rollo|strong="H4039"\w* que volaba.  
\v 2 \w Y|strong="H3068"\w* me preguntó: ¿\w Qué|strong="H4100"\w* \w ves|strong="H7200"\w*?  
\p Respondí: \w Veo|strong="H7200"\w* un \w rollo|strong="H4039"\w* \w que|strong="H4100"\w* vuela, de nueve metros de largo y cuatro y medio de ancho.   
\p
\v 3 \w Entonces|strong="H3588"\w* \w me|strong="H5921"\w* dijo: \w Esta|strong="H2063"\w* \w es|strong="H2088"\w* \w la|strong="H5921"\w* maldición \w que|strong="H3588"\w* \w sale|strong="H3318"\w* \w por|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* superficie \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra. \w Ciertamente|strong="H3588"\w* \w de|strong="H5921"\w* ahora \w en|strong="H5921"\w* adelante, \w según|strong="H5921"\w* \w lo|strong="H2088"\w* escrito \w en|strong="H5921"\w* un lado, \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w que|strong="H3588"\w* roba será echado \w fuera|strong="H3318"\w*, \w y|strong="H3588"\w* \w el|strong="H5921"\w* \w que|strong="H3588"\w* \w jura|strong="H7650"\w*, \w según|strong="H5921"\w* \w lo|strong="H2088"\w* escrito \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w otro|strong="H2088"\w* lado, será echado \w fuera|strong="H3318"\w*.   
\p
\v 4 \wj Yo \+add lo\+add* \+w hice|strong="H7650"\+w* \+w salir|strong="H3318"\+w*,\wj* \w dice|strong="H5002"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* de las huestes, \wj y entrará \+w en|strong="H8432"\+w* la \+w casa|strong="H1004"\+w* del \+w ladrón|strong="H1590"\+w*, y \+w en|strong="H8432"\+w* la \+w casa|strong="H1004"\+w* del que \+w jura|strong="H7650"\+w* \+w falsamente|strong="H8267"\+w* por mi \+w Nombre|strong="H8034"\+w*. \+w Pasará|strong="H3318"\+w* la noche \+w dentro|strong="H8432"\+w* de esa \+w casa|strong="H1004"\+w* hasta que su \+w madera|strong="H6086"\+w* y sus piedras se consuman.\wj*   
\s1 Una caja para medir 22 litros  
\p
\v 5 El \w Ángel|strong="H4397"\w* \w que|strong="H4100"\w* \w hablaba|strong="H1696"\w* conmigo \w salió|strong="H3318"\w* y me \w dijo|strong="H1696"\w*: \w Levanta|strong="H5375"\w* \w ahora|strong="H4994"\w* tus \w ojos|strong="H5869"\w* y \w mira|strong="H7200"\w* \w qué|strong="H4100"\w* \w es|strong="H2063"\w* \w lo|strong="H4100"\w* \w que|strong="H4100"\w* \w sale|strong="H3318"\w*.   
\p
\v 6 \w Y|strong="H3068"\w* pregunté: ¿\w Qué|strong="H4100"\w* \w es|strong="H1931"\w*?  
\p \w Y|strong="H3068"\w* respondió: \w Es|strong="H1931"\w* una caja \w que|strong="H4100"\w* \w sale|strong="H3318"\w* para medir 22 litros. Dijo además: \w Esta|strong="H2063"\w* \w es|strong="H1931"\w* \w la|strong="H1931"\w* \w apariencia|strong="H5869"\w* \w de|strong="H5869"\w* \w ellos|strong="H1931"\w* \w en|strong="H3318"\w* \w toda|strong="H3605"\w* \w la|strong="H1931"\w* tierra.  
\v 7 Vi que una tapa de plomo fue levantada, y había una mujer sentada \w en|strong="H8432"\w* \w medio|strong="H8432"\w* de \w la|strong="H2063"\w* caja.  
\v 8 \w Y|strong="H3068"\w* dijo: \w Esta|strong="H2063"\w* \w es|strong="H2063"\w* \w la|strong="H2063"\w* \w maldad|strong="H7564"\w*. \w La|strong="H2063"\w* \w echó|strong="H7993"\w* \w dentro|strong="H8432"\w* de \w la|strong="H2063"\w* caja y puso \w la|strong="H2063"\w* tapa de plomo sobre su abertura.   
\p
\v 9 \w Luego|strong="H3318"\w* levanté \w mis|strong="H5375"\w* \w ojos|strong="H5869"\w* y \w miré|strong="H7200"\w*. \w Vi|strong="H7200"\w* \w dos|strong="H8147"\w* mujeres con \w alas|strong="H3671"\w* \w como|strong="H2007"\w* \w de|strong="H5869"\w* cigüeña, quienes \w salían|strong="H3318"\w* con el \w viento|strong="H7307"\w* \w en|strong="H3318"\w* sus \w alas|strong="H3671"\w*. Levantaron la caja \w de|strong="H5869"\w* medir entre la tierra y el \w cielo|strong="H8064"\w*.  
\v 10 \w Y|strong="H3068"\w* \w dije|strong="H1696"\w* al \w ángel|strong="H4397"\w* \w que|strong="H1992"\w* \w hablaba|strong="H1696"\w* conmigo: ¿\w A|strong="H3068"\w* dónde \w llevan|strong="H3212"\w* la caja de medir?   
\p
\v 11 \w Y|strong="H3068"\w* \w me|strong="H5921"\w* respondió: \w A|strong="H3068"\w* edificarle \w templo|strong="H1004"\w* \w en|strong="H5921"\w* tierra \w de|strong="H5921"\w* Sinar, \w para|strong="H5921"\w* \w que|strong="H5921"\w* cuando esté listo sea puesta \w allí|strong="H8033"\w* \w en|strong="H5921"\w* su lugar.   
\c 6  
\s1 Octava visión  
\p
\v 1 \w Volví|strong="H7725"\w* \w a|strong="H3068"\w* levantar \w mis|strong="H5375"\w* \w ojos|strong="H5869"\w*. \w Miré|strong="H7200"\w* y \w vi|strong="H7200"\w* cuatro carrozas \w de|strong="H5869"\w* bronce que \w salían|strong="H3318"\w* \w de|strong="H5869"\w* entre \w dos|strong="H8147"\w* montañas.  
\v 2 En la \w primera|strong="H7223"\w* carroza los \w caballos|strong="H5483"\w* eran bermejos, en la \w segunda|strong="H8145"\w* carroza, \w caballos|strong="H5483"\w* \w negros|strong="H7838"\w*,  
\v 3 en la \w tercera|strong="H7992"\w* carroza, \w caballos|strong="H5483"\w* \w blancos|strong="H3836"\w*, y en la cuarta carroza eran \w caballos|strong="H5483"\w* \w overos|strong="H1261"\w* grisáceos.  
\v 4 \w Y|strong="H3068"\w* \w dije|strong="H1696"\w* al \w ángel|strong="H4397"\w* \w que|strong="H4100"\w* \w hablaba|strong="H1696"\w* conmigo: \tl ʼadón\tl* mío, ¿\w qué|strong="H4100"\w* es esto?   
\p
\v 5 \w Y|strong="H3068"\w* \w el|strong="H5921"\w* \w ángel|strong="H4397"\w* \w me|strong="H5921"\w* \w respondió|strong="H6030"\w*: \w Estos|strong="H3605"\w* son \w los|strong="H5921"\w* cuatro \w vientos|strong="H7307"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w cielos|strong="H8064"\w*, \w que|strong="H5921"\w* \w salen|strong="H3318"\w* \w después|strong="H5921"\w* \w de|strong="H5921"\w* presentarse \w delante|strong="H5921"\w* \w del|strong="H5921"\w* \nd ʼAdón\nd* \w de|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* tierra.  
\v 6 El de los \w caballos|strong="H5483"\w* \w negros|strong="H7838"\w* \w sale|strong="H3318"\w* hacia la tierra del \w Norte|strong="H6828"\w*, el de los \w blancos|strong="H3836"\w* \w sale|strong="H3318"\w* tras ellos y el de los \w overos|strong="H1261"\w* \w sale|strong="H3318"\w* hacia la tierra del Sur.  
\v 7 Los overos que \w salían|strong="H3318"\w* estaban impacientes por recorrer la tierra. \w Y|strong="H3068"\w* \add \+nd ʼAdonay\+nd*\add* dijo: \wj ¡\+w Vayan|strong="H3212"\+w*, recorran la tierra! \+w Y|strong="H3068"\+w* \+w en|strong="H3318"\+w* efecto, ellos recorrieron la tierra de un lado \+w a|strong="H3068"\+w* otro.\wj*   
\p
\v 8 \w Luego|strong="H3318"\w* me \w habló|strong="H1696"\w*: \wj Aquí están los que van hacia la tierra del \+w Norte|strong="H6828"\+w* quienes hicieron reposar mi \+w Espíritu|strong="H7307"\+w* \+w en|strong="H3318"\+w* la tierra del \+w Norte|strong="H6828"\+w*. \wj*   
\s1 Coronación de Josué  
\p
\v 9 Otra vez \w tuve|strong="H1961"\w* revelación \w de|strong="H1697"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w que|strong="H1697"\w* decía:  
\v 10 \wj \+w Toma|strong="H3947"\+w* ofrenda \+w de|strong="H1121"\+w* \+w los|strong="H1121"\+w* del \+w cautiverio|strong="H1473"\+w* \+w que|strong="H1931"\+w* regresaron \+w de|strong="H1121"\+w* Babilonia: \+w de|strong="H1121"\+w* Heldai, \+w de|strong="H1121"\+w* \+w Tobías|strong="H2900"\+w* y \+w de|strong="H1121"\+w* \+w Jedaías|strong="H3048"\+w*. \+w El|strong="H1931"\+w* \+w mismo|strong="H1931"\+w* \+w día|strong="H3117"\+w* \+w vé|strong="H3068"\+w* y entra en \+w casa|strong="H1004"\+w* \+w de|strong="H1121"\+w* \+w Josías|strong="H2977"\+w*, \+w hijo|strong="H1121"\+w* \+w de|strong="H1121"\+w* \+w Sofonías|strong="H6846"\+w*.\wj*  
\v 11 \wj \+w Toma|strong="H3947"\+w* la \+w plata|strong="H3701"\+w* y \+w el|strong="H1121"\+w* \+w oro|strong="H2091"\+w* y \+w haz|strong="H6213"\+w* una \+w gran|strong="H1419"\+w* \+w corona|strong="H5850"\+w*. La \+w pondrás|strong="H7760"\+w* en la \+w cabeza|strong="H7218"\+w* \+w de|strong="H1121"\+w* \+w Josué|strong="H3091"\+w*, \+w hijo|strong="H1121"\+w* \+w de|strong="H1121"\+w* Josadac, \+w el|strong="H1121"\+w* \+w sumo|strong="H7218"\+w* \+w sacerdote|strong="H3548"\+w*.\wj*   
\p
\v 12 \wj Hablarás \+w de|strong="H8478"\+w* él, \+w y|strong="H3541"\+w* dirás: \+nd \+w Yavé|strong="H3068"\+w*\+nd* \+w de|strong="H8478"\+w* las huestes dice: \+w Aquí|strong="H2009"\+w* está el varón cuyo \+w Nombre|strong="H8034"\+w* \+w es|strong="H3541"\+w* El \+w Renuevo|strong="H6780"\+w*. \+w Brotará|strong="H6779"\+w* \+w de|strong="H8478"\+w* sus raíces \+w y|strong="H3541"\+w* \+w edificará|strong="H1129"\+w* la Casa \+w de|strong="H8478"\+w* \+nd \+w Yavé|strong="H3068"\+w*\+nd*.\wj*  
\v 13 \wj \+w Sí|strong="H1931"\+w*, \+w edificará|strong="H1129"\+w* \+w la|strong="H1931"\+w* Casa \+w de|strong="H5921"\+w* \+nd \+w Yavé|strong="H3068"\+w*\+nd* \+w y|strong="H5921"\+w* \+w tendrá|strong="H1961"\+w* \+w la|strong="H1931"\+w* \+w gloria|strong="H1935"\+w*. \+w Se|strong="H1961"\+w* sentará \+w y|strong="H5921"\+w* reinará \+w sobre|strong="H5921"\+w* \+w su|strong="H1931"\+w* \+w trono|strong="H3678"\+w*. \+w Es|strong="H1931"\+w* \+w Sacerdote|strong="H3548"\+w* \+w sobre|strong="H5921"\+w* \+w su|strong="H1931"\+w* \+w trono|strong="H3678"\+w*, \+w y|strong="H5921"\+w* \+w habrá|strong="H1961"\+w* \+w consejo|strong="H6098"\+w* \+w de|strong="H5921"\+w* \+w paz|strong="H7965"\+w* \+w entre|strong="H5921"\+w* \+w ambos|strong="H8147"\+w*.\wj*  
\v 14 \wj La gran \+w corona|strong="H5850"\+w* le \+w será|strong="H1961"\+w* un \+w recuerdo|strong="H2146"\+w* \+w a|strong="H3068"\+w* Helem, \+w Tobías|strong="H2900"\+w*, \+w Jedaías|strong="H3048"\+w* y Hen, \+w hijo|strong="H1121"\+w* \+w de|strong="H1121"\+w* \+w Sofonías|strong="H6846"\+w* en la Casa \+w de|strong="H1121"\+w* \+nd \+w Yavé|strong="H3068"\+w*\+nd*.\wj*   
\p
\v 15 \wj \+w Los|strong="H1961"\+w* \+w que|strong="H3588"\+w* \+w están|strong="H1961"\+w* \+w lejos|strong="H7350"\+w* vendrán \+w y|strong="H3588"\+w* \+w edificarán|strong="H1129"\+w* \+w la|strong="H3588"\+w* Casa \+w de|strong="H3588"\+w* \+nd \+w Yavé|strong="H3068"\+w*\+nd*, \+w y|strong="H3588"\+w* \+w sabrán|strong="H3045"\+w* \+w que|strong="H3588"\+w* \+nd \+w Yavé|strong="H3068"\+w*\+nd* \+w de|strong="H3588"\+w* las huestes \+w me|strong="H3588"\+w* \+w envió|strong="H7971"\+w* \+w a|strong="H3068"\+w* ustedes. \+w Así|strong="H3588"\+w* \+w será|strong="H1961"\+w* \+w si|strong="H3588"\+w* diligentemente \+w obedecen|strong="H8085"\+w* \+w la|strong="H3588"\+w* \+w voz|strong="H6963"\+w* \+w de|strong="H3588"\+w* \+nd \+w Yavé|strong="H3068"\+w*\+nd* \+w su|strong="H3588"\+w* \+nd ʼElohim\+nd*. \wj*   
\c 7  
\s1 Consulta sobre el ayuno  
\p
\v 1 El \w año|strong="H8141"\w* cuarto del \w rey|strong="H4428"\w* \w Darío|strong="H1867"\w*, el día cuarto del \w mes|strong="H2320"\w* \w noveno|strong="H8671"\w*, Kislev, \w aconteció|strong="H1961"\w* \w que|strong="H1697"\w* la \w Palabra|strong="H1697"\w* \w de|strong="H1697"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w Zacarías|strong="H2148"\w*.  
\v 2 Entonces Bet-ʼEl \w envió|strong="H7971"\w* \w a|strong="H3068"\w* Sarezer, al portavoz real y \w a|strong="H3068"\w* su gente \w a|strong="H3068"\w* implorar \w el|strong="H1008"\w* favor \w de|strong="H6440"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.  
\v 3 \add También envió\add* \w a|strong="H3068"\w* hablar \w a|strong="H3068"\w* los \w sacerdotes|strong="H3548"\w* \w que|strong="H4100"\w* estaban en la \w Casa|strong="H1004"\w* de \nd \+w Yavé|strong="H3068"\+w*\nd* de las huestes y \w a|strong="H3068"\w* los \w profetas|strong="H5030"\w*: ¿Debo llorar y ayunar \w el|strong="H6213"\w* \w mes|strong="H2320"\w* \w quinto|strong="H2549"\w* \w como|strong="H4100"\w* \w lo|strong="H4100"\w* \w hice|strong="H6213"\w* tantos \w años|strong="H8141"\w*?   
