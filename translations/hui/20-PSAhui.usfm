\q1
\v 5 I̱naga Ngode Datagaliwabe mbiraore kago\x + \xo 62.5 \xt Iba 62.1\x*  
\q2 i̱na ibuni hanguni hanaho howa  
\q2 mini dunubia ho kogoni.   
\q1
\v 6 I̱ haru hagabi pele ngiagabi ibuni hanguore kagoni.  
\q1 Ibu hangu i̱naga wai pabe ale hongohe kagoni.  
\q1 I̱na wai bialu koria waitigirume i̱ bope habe naheore holebero.   
\q1
\v 7 I̱ pele ngiagabi i̱ mini lene ka lelobi  
\q2 Ngode Datagaliwabe ibuni hanguha hanaho haruli.  
\q1 Ibu i̱naga haru haga hongohe ka.  
\q1 Ibuni i̱naga wai pabe ale hongohe kagola  
\q2 waitigirume ibalu i̱ babe nahe holebira.\x + \xo 62.7 \xt Iba 46.1, 85.9\x*   
\b  
\q1
\v 8 I̱naga wali agali bu kamiru tígua Ngode Datagaliwabehondo mini mbiraore wu haabo halimu.\x + \xo 62.8 \xt 1 Sml 1.15, Iba 52.8, Ais 26.4\x*  
\q1 Genda howa tí mini dege dindi ho kamiru bibahende  
\q2 ibuhondo lamiai halimu.  
\q1 Ibu inanaga ha do haga kago  
\q2 ina ibuha howa bayale haabo holeberema.   
\b  
\q1
\v 9 Wali agali bibahende bu karuni  
\q2 ne harigaha howa buhe̱ bame latagi hagagobi hangu bu kagoni.  
\q1 Wali agali mini lene bu karubi emene karubi  
\q2 habane nabulene bame dege bu ka.  
\q1 Wali agaliru ti holenenaga galone mbira ngabe nawi hondole magi handarimayagua  
\q2 tinaga galone nawi bame dege ka.  
\q1 Ti bibahendenaga galone magi handalu  
\q2 genda magi emeneore ne harigaha buhe̱ laraligobi bameore nagalone dege ka.   
\q1
\v 10 Tígua mitangi bialu howa  
