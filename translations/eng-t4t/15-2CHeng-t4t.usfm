\h 2 CHRONICLES 
\toc1 2 Chronicles 
\toc2 2 Chronicles 
\toc3 2Ch 
\mt2 This book contains the account of the reign of King Solomon and of the other kings of Judah until the Babylonians destroyed Jerusalem. We call this book  
\mt1 2 Chronicles  
\c 1  
\s1 Solomon prayed for wisdom  
\p
\v 1 \w David|strong="H1732"\w*’s \w son|strong="H1121"\w* \add King\add* \w Solomon|strong="H8010"\w* \w was|strong="H3068"\w* able \w to|strong="H3068"\w* \w gain|strong="H2388"\w* complete \w control|strong="H2388"\w* \w over|strong="H5921"\w* \w his|strong="H3068"\w* \w kingdom|strong="H4438"\w*, \w because|strong="H5921"\w* \w Yahweh|strong="H3068"\w* \w his|strong="H3068"\w* \w God|strong="H3068"\w* \w helped|strong="H2388"\w* \w him|strong="H5921"\w* \w and|strong="H1121"\w* enabled \w him|strong="H5921"\w* \w to|strong="H3068"\w* \w become|strong="H1431"\w* \w very|strong="H4605"\w* \w powerful|strong="H2388"\w*.   
\p
\v 2-5  \add When\add* David \add was king, he had arranged for a new\add* Sacred Tent \add to be\add* made in Jerusalem. Then David \add and the Israeli leaders\add* had brought God’s Sacred Chest from Kiriath-Jearim \add city\add* to the new Sacred Tent in Jerusalem that he had prepared for it. But \add when Solomon became the king,\add* the first Sacred Tent was still at Gibeon \add city\add*. That was the tent that Moses, the man who served God \add well\add*, had \add arranged to be\add* made in the desert. And the bronze altar that Bezalel, the son of Uri and grandson of Hur, had made was also still in Gibeon, in front of the first Sacred Tent.  
\p \add One day\add* Solomon summoned the army commanders of 1,000 soldiers and the commanders of 100 soldiers and the judges and all the other leaders in Israel. He told them to go with him to Gibeon. So they all went to \w a|strong="H3068"\w* hill in Gibeon \add where the Sacred Tent was\add*, and Solomon and all the others with him worshiped \w Yahweh|strong="H3068"\w* there.  
\v 6 \w Then|strong="H5927"\w* \w Solomon|strong="H8010"\w* \w went|strong="H5927"\w* \w up|strong="H5927"\w* \w to|strong="H3068"\w* \w the|strong="H6440"\w* \w bronze|strong="H5178"\w* \w altar|strong="H4196"\w* \w in|strong="H5921"\w* \w front|strong="H6440"\w* \w of|strong="H3068"\w* \w the|strong="H6440"\w* Sacred Tent, \w and|strong="H3068"\w* \w he|strong="H8033"\w* \w offered|strong="H5927"\w* 1,000 animals \w to|strong="H3068"\w* \w be|strong="H3068"\w* \add killed and\add* completely burned \add on the altar\add*.   
\p
\v 7 \w That|strong="H7200"\w* \w night|strong="H3915"\w* \w God|strong="H5414"\w* \w appeared|strong="H7200"\w* \w to|strong="H5414"\w* \w Solomon|strong="H8010"\w* \add in a dream\add* \w and|strong="H3915"\w* said \w to|strong="H5414"\w* \w him|strong="H5414"\w*, “\w Request|strong="H7592"\w* \w whatever|strong="H4100"\w* \w you|strong="H5414"\w* want \w me|strong="H5414"\w* \w to|strong="H5414"\w* \w give|strong="H5414"\w* \w to|strong="H5414"\w* \w you|strong="H5414"\w*.”   
\p
\v 8 \w Solomon|strong="H8010"\w* replied, “\w You|strong="H6213"\w* \w were|strong="H1732"\w* \w very|strong="H1419"\w* kind \w to|strong="H6213"\w* \w David|strong="H1732"\w* \w my|strong="H1732"\w* father, \w and|strong="H1419"\w* \w now|strong="H1419"\w* \w you|strong="H6213"\w* \w have|strong="H5973"\w* \w appointed|strong="H6213"\w* \w me|strong="H6213"\w* \w to|strong="H6213"\w* \w be|strong="H1732"\w* \w the|strong="H6213"\w* \w king|strong="H4427"\w* \w to|strong="H6213"\w* succeed \w him|strong="H6213"\w*.  
\v 9 \w So|strong="H6258"\w* \w Yahweh|strong="H3068"\w* \w my|strong="H3068"\w* \w God|strong="H3068"\w*, \w you|strong="H3588"\w* \w have|strong="H3068"\w* \w caused|strong="H1697"\w* \w me|strong="H5921"\w* \w to|strong="H3068"\w* \w become|strong="H4427"\w* \w the|strong="H5921"\w* \w king|strong="H4427"\w* \w to|strong="H3068"\w* \w rule|strong="H4427"\w* \w people|strong="H5971"\w* \w who|strong="H5971"\w* \w are|strong="H5971"\w* \w as|strong="H1697"\w* \w many|strong="H7227"\w* \w as|strong="H1697"\w* \w the|strong="H5921"\w* particles \w of|strong="H3068"\w* \w dirt|strong="H6083"\w* \w on|strong="H5921"\w* \w the|strong="H5921"\w* \w earth|strong="H6083"\w*. \w So|strong="H6258"\w* \w do|strong="H3068"\w* \w what|strong="H1697"\w* \w you|strong="H3588"\w* \w promised|strong="H3068"\w* \w my|strong="H3068"\w* father \w David|strong="H1732"\w*.  
\v 10 Please enable \w me|strong="H5414"\w* \w to|strong="H3318"\w* \w be|strong="H5414"\w* \w wise|strong="H2451"\w* \w and|strong="H1419"\w* \w to|strong="H3318"\w* know \add what I should do\add*, \w in|strong="H6440"\w* order \w that|strong="H3588"\w* \w I|strong="H3588"\w* \w may|strong="H5971"\w* \w rule|strong="H8199"\w* \w these|strong="H2088"\w* \w people|strong="H5971"\w* \add well\add*, \w because|strong="H3588"\w* \w there|strong="H2088"\w* \w is|strong="H2088"\w* \w no|strong="H5414"\w* \w one|strong="H2088"\w* \w who|strong="H4310"\w* \w can|strong="H4310"\w* \w rule|strong="H8199"\w* \w all|strong="H5414"\w* \w this|strong="H2088"\w* \w great|strong="H1419"\w* \w nation|strong="H5971"\w* \w of|strong="H6440"\w* \w yours|strong="H5414"\w* \add without your help\add*.”   
\p
\v 11 \w God|strong="H3808"\w* replied, “\add I am pleased with what\add* \w you|strong="H5921"\w* \w desire|strong="H5315"\w*; \w you|strong="H5921"\w* \w have|strong="H1961"\w* \w not|strong="H3808"\w* \w requested|strong="H7592"\w* \w a|strong="H3068"\w* \w huge|strong="H7227"\w* amount \w of|strong="H3117"\w* money \w or|strong="H3808"\w* \w to|strong="H1961"\w* \w be|strong="H1961"\w* \w honored|strong="H3519"\w* \w or|strong="H3808"\w* \w that|strong="H5971"\w* \w your|strong="H5921"\w* \w enemies|strong="H8130"\w* \w be|strong="H1961"\w* killed. \w And|strong="H3117"\w* \w you|strong="H5921"\w* \w have|strong="H1961"\w* \w not|strong="H3808"\w* \w requested|strong="H7592"\w* \w that|strong="H5971"\w* \w you|strong="H5921"\w* \w live|strong="H3117"\w* \w for|strong="H5921"\w* \w a|strong="H3068"\w* \w long|strong="H3117"\w* \w time|strong="H3117"\w*. \w Instead|strong="H3808"\w*, \w you|strong="H5921"\w* \w have|strong="H1961"\w* \w requested|strong="H7592"\w* \w that|strong="H5971"\w* \add I enable\add* \w you|strong="H5921"\w* \add to\add* \w be|strong="H1961"\w* \w wise|strong="H2451"\w* \w and|strong="H3117"\w* \add to\add* know \add what you should do\add* \w in|strong="H5921"\w* order \w that|strong="H5971"\w* \w you|strong="H5921"\w* \w may|strong="H1961"\w* govern \add well\add* \w my|strong="H5921"\w* \w people|strong="H5971"\w* \w whom|strong="H5971"\w* \w I|strong="H3117"\w* \w have|strong="H1961"\w* \w appointed|strong="H4427"\w* \w you|strong="H5921"\w* \w to|strong="H1961"\w* \w rule|strong="H4427"\w*.  
\v 12 \w Therefore|strong="H3651"\w* \w I|strong="H5414"\w* \w will|strong="H1961"\w* enable \w you|strong="H5414"\w* \w to|strong="H1961"\w* \w be|strong="H1961"\w* \w wise|strong="H2451"\w* \w and|strong="H4428"\w* \w to|strong="H1961"\w* know \add what you should do to rule my people well\add*. \w But|strong="H3808"\w* \w I|strong="H5414"\w* \w will|strong="H1961"\w* \w also|strong="H4428"\w* enable \w you|strong="H5414"\w* \w to|strong="H1961"\w* \w have|strong="H1961"\w* \w a|strong="H3068"\w* huge amount \w of|strong="H4428"\w* money \w and|strong="H4428"\w* \w to|strong="H1961"\w* \w be|strong="H1961"\w* \w honored|strong="H3519"\w*, \w more|strong="H3651"\w* \w than|strong="H3808"\w* anyone \w who|strong="H4428"\w* \w was|strong="H1961"\w* \w previously|strong="H6440"\w* \w a|strong="H3068"\w* \w king|strong="H4428"\w* \w ever|strong="H3808"\w* \w was|strong="H1961"\w* \w honored|strong="H3519"\w*, \w more|strong="H3651"\w* \w than|strong="H3808"\w* anyone \w who|strong="H4428"\w* \w later|strong="H1961"\w* \w becomes|strong="H1961"\w* \w king|strong="H4428"\w* \w will|strong="H1961"\w* \w be|strong="H1961"\w* \w honored|strong="H3519"\w*.”  
\v 13 \w Then|strong="H8010"\w* \w Solomon|strong="H8010"\w* \add and the people who were with him all\add* \w left|strong="H3478"\w* \w from|strong="H6440"\w* \w being|strong="H4427"\w* \w in|strong="H5921"\w* \w front|strong="H6440"\w* \w of|strong="H6440"\w* \w he|strong="H3389"\w* Sacred Tent \add on the hill in Gibeon\add*, \w and|strong="H3478"\w* \w they|strong="H5921"\w* returned \w to|strong="H3478"\w* \w Jerusalem|strong="H3389"\w*. \w From|strong="H6440"\w* \w there|strong="H6440"\w* \w he|strong="H3389"\w* \w ruled|strong="H4427"\w* \w the|strong="H6440"\w* Israeli people.   
\s1 Solomon’s wealth  
\p
\v 14 \w Solomon|strong="H8010"\w* acquired 1,400 \w chariots|strong="H7393"\w* \w and|strong="H3967"\w* 12,000 \w men|strong="H8147"\w* \w who|strong="H4428"\w* rode \add on horses\add*. \w He|strong="H8147"\w* \w put|strong="H3240"\w* some \w of|strong="H4428"\w* \w the|strong="H1961"\w* \w chariots|strong="H7393"\w* \w and|strong="H3967"\w* \w horses|strong="H6571"\w* \w in|strong="H4428"\w* \w Jerusalem|strong="H3389"\w*, \w and|strong="H3967"\w* \w put|strong="H3240"\w* some \w of|strong="H4428"\w* \w them|strong="H8147"\w* \w in|strong="H4428"\w* various \w other|strong="H8147"\w* \w cities|strong="H5892"\w*.  
\v 15 During \w the|strong="H5414"\w* years \w that|strong="H5414"\w* Solomon \w was|strong="H4428"\w* \w king|strong="H4428"\w*, \w silver|strong="H3701"\w* \w and|strong="H3701"\w* \w gold|strong="H2091"\w* \w were|strong="H5414"\w* \w as|strong="H7230"\w* \w common|strong="H7230"\w* \w in|strong="H4428"\w* \w Jerusalem|strong="H3389"\w* \w as|strong="H7230"\w* stones, \w and|strong="H3701"\w* \add lumber from\add* cedar \w trees|strong="H8256"\w* \w were|strong="H5414"\w* \w as|strong="H7230"\w* \w plentiful|strong="H7230"\w* \w as|strong="H7230"\w* \add lumber from\add* ordinary \w sycamore|strong="H8256"\w* \w trees|strong="H8256"\w* \w in|strong="H4428"\w* \w the|strong="H5414"\w* \w foothills|strong="H8219"\w*.  
\v 16 \w Solomon|strong="H8010"\w*’s \w horses|strong="H5483"\w* \w were|strong="H4714"\w* \w imported|strong="H4161"\w*/\w brought|strong="H3947"\w* \w from|strong="H3947"\w* \w Egypt|strong="H4714"\w* \w and|strong="H4428"\w* \w from|strong="H3947"\w* \add the\add* Kue \add region in Turkey\add*.  
\v 17 \w In|strong="H4428"\w* \w Egypt|strong="H4714"\w* \w his|strong="H3605"\w* \w men|strong="H3605"\w* \w paid|strong="H3318"\w* 15 pounds \w of|strong="H4428"\w* \w silver|strong="H3701"\w* \w for|strong="H3027"\w* \w each|strong="H3605"\w* \w chariot|strong="H4818"\w* \w and|strong="H3967"\w* 3-3/4 pounds \w of|strong="H4428"\w* \w silver|strong="H3701"\w* \w for|strong="H3027"\w* \w each|strong="H3605"\w* \w horse|strong="H5483"\w*. \w They|strong="H3651"\w* \w also|strong="H3027"\w* \w exported|strong="H3318"\w*/\w sold|strong="H3318"\w* many \w of|strong="H4428"\w* \w them|strong="H3027"\w* \w to|strong="H3318"\w* \w the|strong="H3605"\w* \w kings|strong="H4428"\w* \w of|strong="H4428"\w* \w the|strong="H3605"\w* Heth \w and|strong="H3967"\w* Aram people-groups.   
\c 2  
\s1 Preparations for building the temple  
\p
\v 1 \w Solomon|strong="H8010"\w* ordered \w that|strong="H2022"\w* \w a|strong="H3068"\w* temple \w should|strong="H5608"\w* \w be|strong="H2022"\w* built \w where|strong="H5921"\w* \w Yahweh|strong="H3068"\w* \w would|strong="H8010"\w* \w be|strong="H2022"\w* worshiped \w and|strong="H3967"\w* \w also|strong="H8010"\w* \w that|strong="H2022"\w* \w a|strong="H3068"\w* palace \w should|strong="H5608"\w* \w be|strong="H2022"\w* built \w for|strong="H5921"\w* himself.  
\v 2 \w He|strong="H6213"\w* selected 70,000 \w men|strong="H6213"\w* \w to|strong="H7971"\w* \w carry|strong="H6213"\w* \w the|strong="H6213"\w* \w building|strong="H1129"\w* supplies \w and|strong="H7971"\w* 80,000 \w men|strong="H6213"\w* \w to|strong="H7971"\w* cut stones \add ◄from quarries/walls of rock► in\add* \w the|strong="H6213"\w* hills. \w He|strong="H6213"\w* \w also|strong="H1732"\w* \w chose|strong="H6213"\w* 3,600 \w men|strong="H6213"\w* \w to|strong="H7971"\w* supervise \w them|strong="H7971"\w*.   
\p
\v 3 Solomon \w sent|strong="H3068"\w* \w this|strong="H2063"\w* \w message|strong="H3068"\w* \w to|strong="H3478"\w* \w King|strong="H5921"\w* Hiram \w of|strong="H1004"\w* Tyre \add city\add*:  
\pi1 “\add Many years ago\add* \w when|strong="H3068"\w* \w my|strong="H3068"\w* father David \w was|strong="H3068"\w* \w building|strong="H1129"\w* \w his|strong="H3068"\w* \w palace|strong="H1004"\w*, \w you|strong="H6440"\w* \w sent|strong="H3068"\w* \w to|strong="H3478"\w* \w him|strong="H6440"\w* cedar \w logs|strong="H1129"\w*. \w Will|strong="H3068"\w* \w you|strong="H6440"\w* send \w me|strong="H6440"\w* cedar \w logs|strong="H1129"\w*, \w too|strong="H5921"\w*?   
\pi1
\v 4 “\w We|strong="H3588"\w* \w are|strong="H1004"\w* \w about|strong="H1004"\w* \w to|strong="H1004"\w* \w build|strong="H1129"\w* \w a|strong="H3068"\w* \w temple|strong="H1004"\w* \w where|strong="H1004"\w* \w we|strong="H3068"\w* \w will|strong="H1004"\w* worship \w Yahweh|strong="H3068"\w* \w our|strong="H3605"\w* God. \w We|strong="H3588"\w* want \w to|strong="H1004"\w* dedicate \w it|strong="H3588"\w* \w to|strong="H1004"\w* \w be|strong="H1004"\w* \w a|strong="H3068"\w* \w place|strong="H1004"\w* \w where|strong="H1004"\w* \w we|strong="H3068"\w* \w will|strong="H1004"\w* burn fragrant incense \w to|strong="H1004"\w* \add honor\add* \w him|strong="H3605"\w*, \w and|strong="H1419"\w* \w a|strong="H3068"\w* \w place|strong="H1004"\w* \w to|strong="H1004"\w* put loaves \w of|strong="H1004"\w* sacred bread, \w and|strong="H1419"\w* \w for|strong="H3588"\w* \w making|strong="H3605"\w* sacrifices \w every|strong="H3605"\w* morning \w and|strong="H1419"\w* \w every|strong="H3605"\w* evening \w and|strong="H1419"\w* \w every|strong="H3605"\w* Sabbath day, \w and|strong="H1419"\w* \w to|strong="H1004"\w* celebrate \w on|strong="H1004"\w* \w the|strong="H3605"\w* day \w of|strong="H1004"\w* \w every|strong="H3605"\w* new moon \w and|strong="H1419"\w* \w at|strong="H1004"\w* \w other|strong="H3605"\w* special religious festivals \w to|strong="H1004"\w* \add honor\add* \w Yahweh|strong="H3068"\w* \w our|strong="H3605"\w* God. \w We|strong="H3588"\w* want \w to|strong="H1004"\w* \w do|strong="H3605"\w* \w those|strong="H3605"\w* \w things|strong="H1419"\w* \w forever|strong="H3605"\w*, \w like|strong="H1004"\w* \w Yahweh|strong="H3068"\w* \w has|strong="H3588"\w* commanded.  
\v 5  \add We want\add* \w this|strong="H3588"\w* \w temple|strong="H1004"\w* \add to\add* \w be|strong="H3808"\w* \w a|strong="H3068"\w* \w great|strong="H6440"\w* \w temple|strong="H1004"\w*, \w because|strong="H3588"\w* \w our|strong="H3588"\w* \w God|strong="H3808"\w* \w is|strong="H4310"\w* greater \w than|strong="H3808"\w* \w all|strong="H6440"\w* other gods.  
\v 6 \w But|strong="H6258"\w* \w no|strong="H6213"\w* \w one|strong="H6213"\w* \w can|strong="H6213"\w* really \w build|strong="H6213"\w* \w a|strong="H3068"\w* temple \w that|strong="H3045"\w* \w would|strong="H6213"\w* \w be|strong="H3389"\w* big \w enough|strong="H6213"\w* \w for|strong="H6213"\w* \w God|strong="H7971"\w* \add to live in\add*, \w because|strong="H5973"\w* \w even|strong="H6213"\w* \w the|strong="H6213"\w* highest heavens \w are|strong="H2450"\w* \w not|strong="H3045"\w* big \w enough|strong="H6213"\w* \w for|strong="H6213"\w* \w him|strong="H7971"\w*. \w And|strong="H3063"\w* \w I|strong="H6258"\w* am worthy only \w to|strong="H7971"\w* \w build|strong="H6213"\w* \w a|strong="H3068"\w* \w place|strong="H3559"\w* where \w we|strong="H3068"\w* \w can|strong="H6213"\w* burn sacrifices \w to|strong="H7971"\w* \w him|strong="H7971"\w*.   
\pi1
\v 7 \w Therefore|strong="H7971"\w*, please \w send|strong="H7971"\w* \w me|strong="H7971"\w* \w a|strong="H3068"\w* \w man|strong="H3045"\w* \w who|strong="H5650"\w* \w knows|strong="H3045"\w* \w well|strong="H3045"\w* \w how|strong="H3588"\w* \w to|strong="H7971"\w* \w make|strong="H3772"\w* \w things|strong="H5973"\w* \w from|strong="H3772"\w* gold \w and|strong="H7971"\w* silver \w and|strong="H7971"\w* bronze \w and|strong="H7971"\w* iron, \w and|strong="H7971"\w* \w to|strong="H7971"\w* \w make|strong="H3772"\w* \w things|strong="H5973"\w* \w from|strong="H3772"\w* purple \w and|strong="H7971"\w* red \w and|strong="H7971"\w* blue cloth. \w He|strong="H3588"\w* \w should|strong="H3588"\w* \w also|strong="H3588"\w* \w know|strong="H3045"\w* \w well|strong="H3045"\w* \w how|strong="H3588"\w* \w to|strong="H7971"\w* engrave designs. \w I|strong="H3588"\w* \w want|strong="H3772"\w* \w him|strong="H7971"\w* \w to|strong="H7971"\w* work \w in|strong="H5650"\w* Jerusalem \w and|strong="H7971"\w* \w in|strong="H5650"\w* other places \w in|strong="H5650"\w* Judah \w with|strong="H5973"\w* \w my|strong="H3045"\w* skilled craftsmen, \w the|strong="H3588"\w* ones \w whom|strong="H3588"\w* \w my|strong="H3045"\w* father \w David|strong="H7971"\w* \w appointed|strong="H3045"\w*.   
\pi1
\v 8 \w I|strong="H3588"\w* know \w that|strong="H3588"\w* \w your|strong="H3588"\w* \w workers|strong="H1129"\w* \w are|strong="H1004"\w* skilled \w in|strong="H1004"\w* cutting \w timber|strong="H6086"\w*, \w so|strong="H3588"\w* \w also|strong="H3588"\w* please send \w me|strong="H3588"\w* cedar \w logs|strong="H6086"\w*, pine \w logs|strong="H6086"\w*, \w and|strong="H1419"\w* juniper \w logs|strong="H6086"\w* \w from|strong="H6086"\w* \w the|strong="H3588"\w* Lebanon mountains. \w My|strong="H3588"\w* \w workers|strong="H1129"\w* \w will|strong="H1004"\w* \w work|strong="H6381"\w* \w with|strong="H1004"\w* \w your|strong="H3588"\w* \w workers|strong="H1129"\w*.  
\v 9 \w In|strong="H5650"\w* \w that|strong="H5414"\w* way, those workers \w will|strong="H5650"\w* \w provide|strong="H5414"\w* \w me|strong="H5414"\w* \w with|strong="H3772"\w* plenty \w of|strong="H5650"\w* lumber. \add We will need plenty,\add* because \w I|strong="H5414"\w* \w want|strong="H3772"\w* \w the|strong="H5414"\w* temple \w that|strong="H5414"\w* \w we|strong="H3068"\w* \w will|strong="H5650"\w* build \w to|strong="H5414"\w* \w be|strong="H5414"\w* large \w and|strong="H6242"\w* beautiful.  
\v 10 \w I|strong="H5414"\w* \w will|strong="H3068"\w* \w pay|strong="H5414"\w* \w your|strong="H3068"\w* workers, \w the|strong="H5921"\w* \w men|strong="H5971"\w* \w who|strong="H5971"\w* cut \w the|strong="H5921"\w* logs, 100,000 bushels \w of|strong="H4428"\w* ground wheat, 100,000 bushels \w of|strong="H4428"\w* barley, 110,000 gallons \w of|strong="H4428"\w* wine, \w and|strong="H3068"\w* 110,000 gallons \w of|strong="H4428"\w* olive oil.”   
\p
\v 11  \add When\add* Hiram \add received that message, he\add* replied \w by|strong="H3068"\w* sending \w this|strong="H6213"\w* \w message|strong="H3068"\w* \w to|strong="H3478"\w* Solomon:  
\pi1 “\w Because|strong="H3068"\w* \w Yahweh|strong="H3068"\w* loves \w his|strong="H5414"\w* \w people|strong="H1121"\w*, \w he|strong="H6213"\w* \w has|strong="H3068"\w* \w appointed|strong="H5414"\w* \w you|strong="H5414"\w* \w to|strong="H3478"\w* \w be|strong="H3068"\w* \w their|strong="H3068"\w* \w king|strong="H4428"\w*.”   
\p
\v 12  \add And Hiram added,\add*  
\pi1 “Praise \w Yahweh|strong="H3068"\w*, \w the|strong="H3045"\w* \w God|strong="H7971"\w* \w to|strong="H7971"\w* whom \w the|strong="H3045"\w* Israeli \w people|strong="H3045"\w* belong, \w the|strong="H3045"\w* one \w who|strong="H2450"\w* created \w the|strong="H3045"\w* sky \w and|strong="H7971"\w* \w the|strong="H3045"\w* earth! \w He|strong="H7971"\w* \w has|strong="H3045"\w* given King \w David|strong="H7971"\w* \w a|strong="H3068"\w* \w wise|strong="H2450"\w* \w son|strong="H2450"\w*, one \w who|strong="H2450"\w* \w is|strong="H2450"\w* \w very|strong="H6258"\w* smart/intelligent \w and|strong="H7971"\w* \w who|strong="H2450"\w* \w has|strong="H3045"\w* good \w skill|strong="H3045"\w* \w and|strong="H7971"\w* understanding. \w He|strong="H7971"\w* wants \w to|strong="H7971"\w* build \w a|strong="H3068"\w* temple \w for|strong="H7971"\w* \w Yahweh|strong="H3068"\w* \w and|strong="H7971"\w* \w a|strong="H3068"\w* palace \w for|strong="H7971"\w* \w himself|strong="H3045"\w*.   
\pi1
\v 13 “\w I|strong="H5414"\w* \w will|strong="H1121"\w* \w be|strong="H1121"\w* sending \w to|strong="H6213"\w* \w you|strong="H5414"\w* Huram-Abi, \w a|strong="H3068"\w* \w man|strong="H2450"\w* \w who|strong="H3605"\w* \w is|strong="H3701"\w* \w very|strong="H6213"\w* \w skilled|strong="H2450"\w*.  
\v 14 \w His|strong="H7971"\w* mother \w was|strong="H5650"\w* \w from|strong="H7971"\w* \w the|strong="H7971"\w* tribe \w of|strong="H5650"\w* Dan, \w and|strong="H7971"\w* \w his|strong="H7971"\w* father \w was|strong="H5650"\w* \w from|strong="H7971"\w* \add here in\add* Tyre. \w He|strong="H7971"\w* \w is|strong="H5650"\w* \w very|strong="H6258"\w* able \w to|strong="H7971"\w* make \w things|strong="H8081"\w* \w from|strong="H7971"\w* gold \w and|strong="H7971"\w* silver \w and|strong="H7971"\w* bronze \w and|strong="H7971"\w* iron \w and|strong="H7971"\w* stone \w and|strong="H7971"\w* wood, \w but|strong="H6258"\w* \w he|strong="H7971"\w* also makes nice \w things|strong="H8081"\w* \w from|strong="H7971"\w* purple \w and|strong="H7971"\w* blue \w and|strong="H7971"\w* red cloth, \w and|strong="H7971"\w* \w he|strong="H7971"\w* does \w all|strong="H7971"\w* kinds \w of|strong="H5650"\w* engraving. \w He|strong="H7971"\w* \w can|strong="H5650"\w* make \w things|strong="H8081"\w* using any design/pattern \w that|strong="H8081"\w* \w you|strong="H7971"\w* give \w to|strong="H7971"\w* \w him|strong="H7971"\w*. \w He|strong="H7971"\w* \w will|strong="H5650"\w* work \w with|strong="H7971"\w* \w your|strong="H7971"\w* craftsmen, \w and|strong="H7971"\w* \w the|strong="H7971"\w* craftsmen \w who|strong="H5650"\w* \w did|strong="H5650"\w* work \w for|strong="H7971"\w* \w your|strong="H7971"\w* father, King \w David|strong="H7971"\w*.   
\pi1
\v 15 “\w Now|strong="H5921"\w* please \w send|strong="H5927"\w* \w us|strong="H5921"\w* \w the|strong="H3605"\w* wheat \w and|strong="H6086"\w* barley \w and|strong="H6086"\w* olive oil \w and|strong="H6086"\w* wine \w that|strong="H3605"\w* \w you|strong="H3605"\w* promised \w to|strong="H5927"\w* \w send|strong="H5927"\w* \w to|strong="H5927"\w* \w us|strong="H5921"\w*.  
\v 16 \w When|strong="H3478"\w* \w you|strong="H3605"\w* \w do|strong="H3605"\w* \w that|strong="H3605"\w*, \w my|strong="H3605"\w* workers \w will|strong="H3478"\w* \w cut|strong="H3478"\w* \w from|strong="H3478"\w* trees \w in|strong="H3478"\w* \w the|strong="H3605"\w* Lebanon mountains \w all|strong="H3605"\w* \w the|strong="H3605"\w* logs \w that|strong="H3605"\w* \w you|strong="H3605"\w* need \add and bring them down to the sea\add*. \w Then|strong="H1732"\w* \w we|strong="H3068"\w* \w will|strong="H3478"\w* \add tie the logs together to\add* form rafts \w with|strong="H1732"\w* \w them|strong="H4672"\w*, \w and|strong="H3967"\w* float \w them|strong="H4672"\w* \w in|strong="H3478"\w* \w the|strong="H3605"\w* sea \w to|strong="H3478"\w* Joppa \add city\add*. \w From|strong="H3478"\w* \w there|strong="H4672"\w*, \w you|strong="H3605"\w* \add can arrange for\add* \w them|strong="H4672"\w* \add to be\add* \w taken|strong="H5608"\w* \w up|strong="H3605"\w* \w to|strong="H3478"\w* Jerusalem.   
\p
\v 17 Solomon \w told|strong="H6213"\w* \w his|strong="H6213"\w* \w workers|strong="H6213"\w* \w to|strong="H6213"\w* count \w all|strong="H6213"\w* \w the|strong="H6213"\w* \w people|strong="H5971"\w* \w from|strong="H5971"\w* other countries \w who|strong="H5971"\w* \w were|strong="H5971"\w* living \w in|strong="H6213"\w* \w Israel|strong="H5971"\w*, similar \w to|strong="H6213"\w* \w what|strong="H6213"\w* \w his|strong="H6213"\w* father David \w had|strong="H5971"\w* \w done|strong="H6213"\w*. \w There|strong="H1992"\w* \w were|strong="H5971"\w* 153,600 \w of|strong="H2022"\w* \w them|strong="H1992"\w*.  
\v 18 Solomon assigned 70,000 of them to carry materials, and 80,000 to cut stone \add from quarries in\add* the hills, and 3,600 of them to supervise the others and be sure that they worked steadily.   
\c 3  
\s1 Solomon’s workers built the temple  
\p
\v 1 \w Then|strong="H7200"\w* \w Solomon|strong="H8010"\w*’s \w workers|strong="H1129"\w* \w started|strong="H2490"\w* \w to|strong="H3068"\w* \w build|strong="H1129"\w* \w the|strong="H7200"\w* \w temple|strong="H1004"\w* \w for|strong="H3068"\w* \w Yahweh|strong="H3068"\w* \w in|strong="H3068"\w* \w Jerusalem|strong="H3389"\w*. \w They|strong="H3068"\w* \w built|strong="H1129"\w* \w it|strong="H7200"\w* \w on|strong="H7200"\w* \w Moriah|strong="H4179"\w* \w Hill|strong="H2022"\w*, \w where|strong="H4725"\w* \add an angel from\add* \w Yahweh|strong="H3068"\w* \w had|strong="H3068"\w* \w appeared|strong="H7200"\w* \w to|strong="H3068"\w* \w his|strong="H3068"\w* father \w David|strong="H1732"\w*. \w They|strong="H3068"\w* \w built|strong="H1129"\w* \w it|strong="H7200"\w* \w on|strong="H7200"\w* \w the|strong="H7200"\w* \w ground|strong="H4725"\w* \w that|strong="H7200"\w* Araunah, \w a|strong="H3068"\w* descendant \w of|strong="H1004"\w* \w the|strong="H7200"\w* Jebus people-group, \w had|strong="H3068"\w* sold \w to|strong="H3068"\w* \w David|strong="H1732"\w* \w and|strong="H3068"\w* \w where|strong="H4725"\w* \w David|strong="H1732"\w* said \w that|strong="H7200"\w* \w it|strong="H7200"\w* \w should|strong="H3068"\w* \w be|strong="H3068"\w* \w built|strong="H1129"\w*.  
\v 2 \w They|strong="H8141"\w* \w began|strong="H2490"\w* \w the|strong="H1129"\w* work \w in|strong="H8141"\w* April, when Solomon \w had|strong="H1129"\w* been ruling almost four \w years|strong="H8141"\w*.   
\p
\v 3 \w The|strong="H1129"\w* \w foundation|strong="H3245"\w* \w of|strong="H1004"\w* \w the|strong="H1129"\w* \w temple|strong="H1004"\w* \w was|strong="H1004"\w* \w about|strong="H1004"\w* 90 feet long \w and|strong="H6242"\w* 30 feet \w wide|strong="H7341"\w*.  
\v 4 \w The|strong="H6440"\w* entrance \w room|strong="H1004"\w* \w across|strong="H5921"\w* \w the|strong="H6440"\w* \w front|strong="H6440"\w* \w of|strong="H1004"\w* \w the|strong="H6440"\w* \w temple|strong="H1004"\w* \w was|strong="H1004"\w* 30 feet \w wide|strong="H7341"\w* \w and|strong="H3967"\w* 30 feet \w high|strong="H1363"\w*.   
\p
\v 5 Solomon’s workers used \add panels/boards of\add* pine \add wood\add* \w to|strong="H5927"\w* line \w the|strong="H5921"\w* \w main|strong="H1419"\w* \w hall|strong="H1004"\w* \w of|strong="H1004"\w* \w the|strong="H5921"\w* \w temple|strong="H1004"\w*. \w Then|strong="H5927"\w* \w they|strong="H5921"\w* \w covered|strong="H2645"\w* \w those|strong="H5921"\w* panels \w with|strong="H1004"\w* \add very thin sheets of\add* \w pure|strong="H2896"\w* \w gold|strong="H2091"\w*. \w Then|strong="H5927"\w* \w they|strong="H5921"\w* \w decorated|strong="H5927"\w* \w the|strong="H5921"\w* walls \w with|strong="H1004"\w* \add carved images of\add* \w palm|strong="H8561"\w* \w trees|strong="H6086"\w* \w and|strong="H1419"\w* designs \w that|strong="H6086"\w* resembled \w chains|strong="H8333"\w*.  
\v 6 They decorated \w the|strong="H6823"\w* \w temple|strong="H1004"\w* \w with|strong="H1004"\w* very \w valuable|strong="H3368"\w* stones. \w The|strong="H6823"\w* \w gold|strong="H2091"\w* \w that|strong="H1004"\w* they used \w was|strong="H1004"\w* \w from|strong="H2091"\w* \add the land of\add* \w Parvaim|strong="H6516"\w*.   
\p
\v 7 \w They|strong="H5921"\w* \w covered|strong="H2645"\w* \w the|strong="H5921"\w* \w ceiling|strong="H7023"\w* \w beams|strong="H6982"\w*, \w the|strong="H5921"\w* \w door|strong="H1817"\w* frames, \w the|strong="H5921"\w* \w walls|strong="H7023"\w* \w and|strong="H1004"\w* \w the|strong="H5921"\w* \w doors|strong="H1817"\w* \w of|strong="H1004"\w* \w the|strong="H5921"\w* \w temple|strong="H1004"\w* \w with|strong="H1004"\w* \add very thin sheets of\add* \w gold|strong="H2091"\w*. \w They|strong="H5921"\w* \w also|strong="H1817"\w* \w carved|strong="H6605"\w* \add statues of\add* winged creatures \w on|strong="H5921"\w* \w the|strong="H5921"\w* \w walls|strong="H7023"\w*.  
\v 8 \w They|strong="H5921"\w* \w also|strong="H6213"\w* \w built|strong="H6213"\w* \w the|strong="H6440"\w* \w Very|strong="H6213"\w* \w Holy|strong="H6944"\w* \w Place|strong="H6944"\w* \add inside the temple\add*. \w It|strong="H5921"\w* \w was|strong="H1004"\w* 30 \w feet|strong="H6944"\w* \w wide|strong="H7341"\w* \w and|strong="H3967"\w* 30 \w feet|strong="H6944"\w* \w long|strong="H6440"\w*. \w They|strong="H5921"\w* \w covered|strong="H2645"\w* \w its|strong="H5921"\w* walls \w with|strong="H1004"\w* sheets \w of|strong="H1004"\w* \w pure|strong="H2896"\w* \w gold|strong="H2091"\w* \w that|strong="H6213"\w* altogether weighed 23 tons.  
\v 9 They used 1-1/4 pounds \w of|strong="H8255"\w* \w gold|strong="H2091"\w* \w to|strong="H2091"\w* \add cover the heads of \add* \w the|strong="H5944"\w* \w nails|strong="H4548"\w*. They also \w covered|strong="H2645"\w* \w the|strong="H5944"\w* walls \w of|strong="H8255"\w* \w the|strong="H5944"\w* \w upper|strong="H5944"\w* \w rooms|strong="H5944"\w* \w with|strong="H2645"\w* sheets \w of|strong="H8255"\w* \w gold|strong="H2091"\w*.   
\p
\v 10 Solomon’s \w workers|strong="H6213"\w* \w made|strong="H6213"\w* \w two|strong="H8147"\w* statues \w of|strong="H1004"\w* creatures \w with|strong="H1004"\w* \w wings|strong="H8147"\w* \w to|strong="H6213"\w* \w put|strong="H6213"\w* \w inside|strong="H1004"\w* \w the|strong="H6213"\w* \w Very|strong="H6213"\w* \w Holy|strong="H6944"\w* \w Place|strong="H6944"\w*. \w They|strong="H6213"\w* \w covered|strong="H6823"\w* \w those|strong="H6213"\w* statues \w with|strong="H1004"\w* \add very thin sheets of\add* \w gold|strong="H2091"\w*.  
\v 11-12  \add Each statue had two long wings\add*. One wing of each statue touched one of the walls of the Temple. The other wing of each statue touched \w a|strong="H3068"\w* wing of the other statue. It was 7-1/2 feet from the outer tip of one wing to the outer tip of the other wing. The inner wings of the two statues touched each other.   
\p
\v 13 \w It|strong="H5921"\w* \w was|strong="H1004"\w* 30 \w feet|strong="H7272"\w* \w from|strong="H6440"\w* \w the|strong="H6440"\w* \w outer|strong="H6440"\w* \w wing|strong="H3671"\w* \w of|strong="H1004"\w* \w the|strong="H6440"\w* \w one|strong="H3671"\w* statue \w to|strong="H5921"\w* \w the|strong="H6440"\w* \w outer|strong="H6440"\w* \w wing|strong="H3671"\w* \w of|strong="H1004"\w* \w the|strong="H6440"\w* \w other|strong="H3671"\w* statue. \w The|strong="H6440"\w* statues \w faced|strong="H6440"\w* \w the|strong="H6440"\w* doorway \w to|strong="H5921"\w* \w the|strong="H6440"\w* main \w room|strong="H1004"\w*.   
\p
\v 14 Solomon’s \w workers|strong="H6213"\w* \w made|strong="H6213"\w* \w a|strong="H3068"\w* \w curtain|strong="H6532"\w* \add to separate the main room from the Very Holy Place\add*. \w It|strong="H5921"\w* \w was|strong="H6213"\w* \w made|strong="H6213"\w* \w of|strong="H5921"\w* \w blue|strong="H8504"\w*, \w purple|strong="H8504"\w*, \w and|strong="H8504"\w* red thread \w and|strong="H8504"\w* \w fine|strong="H6213"\w* linen. \w There|strong="H5927"\w* \w were|strong="H3742"\w* figures \w of|strong="H5921"\w* winged creatures \w that|strong="H6213"\w* \w were|strong="H3742"\w* embroidered \w on|strong="H5921"\w* \w the|strong="H5921"\w* \w curtain|strong="H6532"\w*.  
\v 15 \w They|strong="H5921"\w* \w made|strong="H6213"\w* \w two|strong="H8147"\w* \add bronze\add* \w pillars|strong="H5982"\w* \w and|strong="H1004"\w* \w put|strong="H6213"\w* \w them|strong="H5921"\w* \w at|strong="H5921"\w* \w the|strong="H6440"\w* entrance \w of|strong="H1004"\w* \w the|strong="H6440"\w* \w temple|strong="H1004"\w*. \w They|strong="H5921"\w* \w were|strong="H8147"\w* \w each|strong="H8147"\w* 27 feet \w high|strong="H7218"\w*. \w Each|strong="H8147"\w* \w had|strong="H6213"\w* \w a|strong="H3068"\w* \w top|strong="H7218"\w* \w over|strong="H5921"\w* \w it|strong="H5921"\w* \w that|strong="H6213"\w* \w was|strong="H1004"\w* 7-1/2 feet \w high|strong="H7218"\w*.  
\v 16 \w The|strong="H5921"\w* \w workers|strong="H6213"\w* \w made|strong="H6213"\w* \add carvings that resembled\add* \w chains|strong="H8333"\w* \w and|strong="H3967"\w* \w put|strong="H5414"\w* \w them|strong="H5414"\w* \w on|strong="H5921"\w* \w top|strong="H7218"\w* \w of|strong="H7218"\w* \w the|strong="H5921"\w* \w pillars|strong="H5982"\w*. \w They|strong="H5921"\w* \w made|strong="H6213"\w* \add carvings that resembled\add* \w pomegranates|strong="H7416"\w* \w and|strong="H3967"\w* \w attached|strong="H5414"\w* \w them|strong="H5414"\w* \w to|strong="H5921"\w* \w the|strong="H5921"\w* \w chains|strong="H8333"\w*.  
\v 17 \w They|strong="H5921"\w* \w set|strong="H6965"\w* \w up|strong="H6965"\w* \w the|strong="H6440"\w* \w pillars|strong="H5982"\w* \w in|strong="H5921"\w* \w front|strong="H6440"\w* \w of|strong="H6440"\w* \w the|strong="H6440"\w* \w temple|strong="H1964"\w*, \w one|strong="H3225"\w* \w on|strong="H5921"\w* \w the|strong="H6440"\w* \w south|strong="H3225"\w* \w side|strong="H3225"\w* \add of the entrance\add* \w and|strong="H6965"\w* \w the|strong="H6440"\w* \w other|strong="H7121"\w* \w on|strong="H5921"\w* \w the|strong="H6440"\w* \w north|strong="H8040"\w* \w side|strong="H3225"\w*. \w The|strong="H6440"\w* \w one|strong="H3225"\w* \w on|strong="H5921"\w* \w the|strong="H6440"\w* \w south|strong="H3225"\w* \w side|strong="H3225"\w* \w was|strong="H8034"\w* \w named|strong="H7121"\w* \w Jakin|strong="H3199"\w* \w and|strong="H6965"\w* \w the|strong="H6440"\w* \w one|strong="H3225"\w* \w on|strong="H5921"\w* \w the|strong="H6440"\w* \w north|strong="H8040"\w* \w side|strong="H3225"\w* \w was|strong="H8034"\w* \w named|strong="H7121"\w* \w Boaz|strong="H1162"\w*.   
\c 4  
\s1 The furnishings for the temple  
\p
\v 1 Solomon’s \w workers|strong="H6213"\w* \w made|strong="H6213"\w* \w a|strong="H3068"\w* square \w bronze|strong="H5178"\w* \w altar|strong="H4196"\w* \w that|strong="H4196"\w* \w was|strong="H6967"\w* 10 yards \w wide|strong="H7341"\w* \w on|strong="H6213"\w* each side, \w and|strong="H6242"\w* \w it|strong="H6213"\w* \w was|strong="H6967"\w* 5 yards \w high|strong="H6967"\w*.  
\v 2 \w They|strong="H6213"\w* \w also|strong="H6213"\w* \w made|strong="H6213"\w* \w a|strong="H3068"\w* \w very|strong="H6213"\w* large \w round|strong="H5439"\w* tank \w that|strong="H6213"\w* \w was|strong="H6967"\w* \w made|strong="H6213"\w* \w of|strong="H8193"\w* \w metal|strong="H6213"\w* \w and|strong="H7970"\w* \w cast|strong="H3332"\w* \add in a clay mold\add*. \w It|strong="H6213"\w* \w was|strong="H6967"\w* 10 \w yards|strong="H5439"\w* wide/across, \w and|strong="H7970"\w* 5 \w yards|strong="H5439"\w* \w high|strong="H6967"\w*. \w It|strong="H6213"\w* \w was|strong="H6967"\w* 15 \w yards|strong="H5439"\w* \w around|strong="H5439"\w* \w it|strong="H6213"\w*.  
\v 3 \w Below|strong="H8478"\w* \w the|strong="H8478"\w* outer rim \w there|strong="H8478"\w* \w were|strong="H1241"\w* \w two|strong="H8147"\w* \w rows|strong="H2905"\w* \w of|strong="H8478"\w* \add small figures of\add* \w bulls|strong="H1241"\w* \w that|strong="H1241"\w* \w were|strong="H1241"\w* part \w of|strong="H8478"\w* \w the|strong="H8478"\w* metal \w of|strong="H8478"\w* \w the|strong="H8478"\w* basin. \w Each|strong="H5439"\w* \w row|strong="H2905"\w* had 300 \w figures|strong="H1823"\w* \w of|strong="H8478"\w* \w bulls|strong="H1241"\w*.   
\p
\v 4 \w The|strong="H3605"\w* basin \w was|strong="H1004"\w* \w set|strong="H5975"\w* \w on|strong="H5921"\w* \w twelve|strong="H8147"\w* \add statues of\add* \w bulls|strong="H1241"\w*. \w There|strong="H5975"\w* \w were|strong="H1241"\w* \w three|strong="H7969"\w* statues \w that|strong="H3605"\w* \w faced|strong="H6437"\w* \w north|strong="H6828"\w*, \w three|strong="H7969"\w* \w that|strong="H3605"\w* \w faced|strong="H6437"\w* \w west|strong="H3220"\w*, \w three|strong="H7969"\w* \w that|strong="H3605"\w* \w faced|strong="H6437"\w* \w south|strong="H5045"\w*, \w and|strong="H1004"\w* \w three|strong="H7969"\w* \w that|strong="H3605"\w* \w faced|strong="H6437"\w* \w east|strong="H4217"\w*.  
\v 5 \w The|strong="H2388"\w* sides \w of|strong="H4639"\w* \w the|strong="H2388"\w* tank \w were|strong="H7969"\w* 3 inches \w thick|strong="H5672"\w*, \w and|strong="H2388"\w* its \w rim|strong="H8193"\w* \w was|strong="H8193"\w* \w shaped|strong="H4639"\w* \w like|strong="H7799"\w* \w a|strong="H3068"\w* \w cup|strong="H3563"\w* \w that|strong="H8193"\w* curved outward \w like|strong="H7799"\w* \w the|strong="H2388"\w* petals \w of|strong="H4639"\w* \w flowers|strong="H6525"\w*. \w The|strong="H2388"\w* basin \w held|strong="H2388"\w* about 16,500 \w gallons|strong="H1324"\w* \add of water\add*.   
\p
