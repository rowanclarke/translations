\id PHP - Fakai Translation
\h Firipi-ne̱
\toc3 Firi
\toc2 Firipi-ne̱
\toc1 Ran-u Burus u̱ do̱'e̱ u̱du̱ Firipi-ne̱
\mt2 Ran-u Burus u̱ do̱'e̱ u̱du̱
\mt1 Firipi-ne̱
\c 1
\cl U-bo̱r u-gan
\s1 U̱s-vu̱k
\p 
\v 1 Uno̱ ran-o̱ o̱o̱n du̱gu̱-du̱ Burus e̱ Timoti, to̱k-ne̱ Ye̱so̱ Kiristi, m-ha u̱du̱ ne̱t-u̱t Ye̱so̱ Kiristi u̱t-be̱e̱t u̱ bo̱-u̱ Firibi, u̱r-kot u̱ i o̱ tu̱-shu̱ u̱ a-u̱r-se̱ge̱ du̱ ank-m Ye̱so̱ ne̱.
\p 
\v 2 U̱m o̱ u̱s-to̱o̱g u̱du̱ u-Ru̱, wu̱ o̱o̱ge̱ U̱so-u in, u̱ Wa-ko-uyan Ye̱so̱ Kiristi ne̱, wa ya' no̱ u-nya u̱ ru̱s-du̱ jab ne̱.
\s1 U̱t-vam u̱s-to̱o̱g ne̱
\p 
\v 3 U̱m no̱mu̱ Ru̱-u ri u̱t-vam, u-da u-be̱e̱t da-u̱ u̱m bakse̱ u̱ no̱ ne̱.
\v 4 Da-u̱ u̱m nome̱ no̱ be̱e̱t to̱o̱g-u̱s ri u̱ u-da u-be̱e̱t, u̱m no̱m se̱ u̱r-so̱ ne̱,
\v 5 remu̱ same̱-du̱ u̱t-hi no̱ u̱ me̱ ne̱, u̱ re̱-u̱ u-shu̱ Rem-su̱ m-Re̱me̱r du̱gu̱ ho̱-du̱ u̱r-taku̱n du̱ no̱ ho̱ge̱ se̱ u̱ haan u̱ da-o̱.
\v 6 Tu̱msu̱ u̱m zatte̱ u-sakna da u̱zu̱, u-Ru̱ wu̱ tak-ne̱ no̱m-du̱ no̱m-u̱t so̱-to̱ u̱-me̱ jab-u̱s no̱, wa u̱t-re̱ u-shu̱ u̱ no̱m-du̱ to̱ m-te u̱r-vaste̱ kanda da-u̱ Kiristi Ye̱so̱ do̱'e̱ mu̱u̱n.
\p 
\v 7 No̱ng ho̱n-ho̱n u̱m no̱m dorog-u̱s se̱ u̱ka u̱m nomte̱ u̱ mo̱t-u̱t no̱ ne̱ be̱e̱t, remu̱ zu̱ u̱m o̱ m-ho̱g-u̱ no̱ ne̱ u̱-me̱ jab-u̱ ri. U̱m zu̱u̱g iya remu̱ u̱zu̱ no̱ be̱e̱t no̱ samge̱ u̱t-kom u̱-me̱ nya-u̱ u-Ru̱ u̱r-kot u̱ me̱ ne̱, m-ha u̱-me̱ bu-u̱ m-to̱k, tu̱msu̱ u̱ ruut du̱ Rem-su̱ m-Re̱me̱r.
\v 8 Ru̱-u̱ nak u̱zu̱ u̱m cwanu̱g no̱ sok, u̱ka Kiristi o̱tte̱ cwan-u̱t no̱ ne̱.
\p 
\v 9 Tu̱msu̱ to̱o̱g-u̱s ri se̱ u̱zu̱, cwan-u̱t no̱ u̱ rogom u̱-me̱ m-nap, u̱ zu̱n-mu̱ ko-uyan ne̱.
\v 10 U̱m no̱ng sin-se̱ to̱o̱g-se̱ remu̱ no̱ du̱g-u̱t no̱m-tu̱ kame̱, no̱ shu̱'u̱te̱ u-he̱n ne̱ tu̱msu̱ za u̱r-pyap, kanda ho̱-du̱ Kiristi de̱ mu̱u̱n.
\v 11 U̱m no̱ng u̱s-to̱o̱g u̱zu̱ Ru̱-u̱ do̱'e̱ u̱t-no̱m iya u̱ remu̱ no̱ nom-u̱t yu̱-u̱r no̱ u-he̱n ne̱ tu̱msu̱ shu̱yi-shu̱yi. U̱m nak u̱zu̱ no̱ u̱t-no̱m iya remu̱ zu̱ Kiristi Ye̱so̱ o̱ no̱mu̱ no̱ u̱r-se̱ge̱. Da-u̱ ne̱t-tu̱ hyane̱ shin-m no̱ e̱ u̱t-ya u-Ru̱ m-sek tu̱msu̱ e̱ no̱mu̱ wa u̱t-vam.
\s1 Burus no̱ng u̱r-so̱ u̱zu̱ ne̱t-tu̱ // o̱ bu̱t-tu̱ Rem-su̱ m-Re̱me̱r
\p 
\v 12 O̱r-u̱t ri ne̱, u̱m u̱t-sa no̱ nap u̱zu̱, no̱m-u̱ kume̱ me̱ u̱ ane̱ wa'ag re̱-u̱ u-shu̱ u̱ Rem-su̱ m-Re̱me̱r.
\v 13 Remu̱ iya, karma-ne̱ be̱e̱t i o̱ e'-du̱ u-pada, u̱ ko̱wan u̱-me̱ bo̱-u uno̱ nak u̱ da-o̱ u̱zu̱, na wa'ag me̱ u̱ bu-u̱ m-to̱k remu̱ bu̱t-u̱t Kiristi.
\v 14 Tu̱msu̱ tage̱-tu̱ na tagu̱ me̱ u̱ bu-u̱ m-to̱k, wa'ag o̱ru̱ ri a-dor-ne̱ u-tát sur u̱r-be̱b u̱du̱ Wa-ko-uyan u̱ shiriktin-mu̱ jab ne̱ mu̱ bu̱t-tu̱ rem-su̱ u-Ru̱ za u-gye̱r.
\p 
\v 15 Nip-to̱ u̱zu̱ e̱ke̱n a-dor-ne̱ o̱ bu̱t-tu̱ rem-u̱s Kiristi u̱-te̱k u̱r-shu̱b m-dum ne̱. Se̱di e̱ke̱n o̱ bu̱t-u̱t Kiristi u̱ te̱k-u̱ jab-u̱ so̱-o̱.
\v 16 A-dor-ne̱ o̱ u̱t-bu̱t u̱ te̱k-u̱ jab-u̱ so̱-o̱, e̱ o̱ u̱t-no̱m remu̱ e̱ o̱ cwan-u̱t ri, tu̱msu̱ e̱ nak u̱zu̱ na wa'ag me̱ ane̱ remu̱ u̱m ruute̱ Rem-su̱ m-Re̱me̱r su̱ mo̱t-u̱t Kiristi.
\v 17 Ne̱t-tu̱ o̱ bu̱t-u̱t Kiristi remu̱ u̱r-shu̱b m-dum ne̱, e̱ o̱ rogmu̱ssu̱ hi-u̱r e̱ remu̱ cwan-tu̱ u̱r-hi tu̱ jab-u̱s e̱, za remu̱ jab u̱t-nip da. Cwan-m e̱, e̱ sur m-wa u̱m swa u̱r-ko̱b u̱-me̱ bu-u̱ m-to̱k.
\v 18 Se̱di o̱ko̱n zarra. Ko̱ du̱gu̱ jab-u̱s u̱s-bi ko̱ du̱gu̱ jab u̱t-nip, no̱m-u̱ ze̱ge̱ u̱r-zwar u-be̱e̱t o̱ u̱zu̱, na no̱ng bu̱t-tu̱ rem-su̱ mo̱t-u̱t Kiristi. U̱m ho̱k u̱r-zwar remu̱ ne̱t-tu̱ o̱ ho̱g-du̱ Rem-su̱ m-Re̱me̱r.
\p Tu̱msu̱ u̱m de̱ re̱-du̱ shu̱ u̱r-so̱ ne̱,
\v 19 remu̱ zu̱ u̱m nak u̱ remu̱ to̱o̱g-u̱s no̱, u̱r-se̱ge̱ ne̱ du̱ Yar-u Ye̱so̱ Kiristi, no̱mu̱ kume̱ me̱ o̱ u̱t-wa u̱m kum u-u̱ku̱r.
\v 20 U̱m o̱ wadu̱ jab tu̱msu̱ u-kar ne̱ sok u̱zu̱, na za yadu̱ me̱ m-e̱' da u̱ o̱ko̱n no̱m-o̱ ko̱ yaku̱n fu̱n-ya da. Se̱di u̱m re̱ u-shu̱ u̱ shiriktin-mu̱ jab ne̱ remu̱ Kiristi, u̱ka u̱m o̱tte̱ ko̱-uyan da-o̱ u̱ da-u̱ dim, remu̱ war-u ri de̱ hatu̱n m-sek u̱du̱ Kiristi, ko̱ ana ho̱ me̱ ko̱ ana yagu̱ me̱ u̱r-fat.
\v 21 U̱ mu̱ri gwat-mo̱, a u̱m o̱ u̱r-fat, u̱m o̱ u̱r-yu̱ remu̱ Kiristi. Tu̱msu̱ a u̱m mare̱ swu̱r-mo̱ u̱du̱ ri.
\v 22 Se̱di a u̱m re̱ shu̱ u̱r-yu̱, me̱ no̱mu̱ ank-m Kiristi u̱ka ku̱mte̱, remu̱ iya u̱m nak no̱m-u̱ u̱m de̱ u̱t-dag da.
\v 23 Jab-su̱ mo̱ko̱t me̱ u̱s-yu̱r. No̱m-u̱ u̱m ze̱ge̱ m-cwan, u̱m do̱'e̱ u̱m shu̱'u̱t u̱du̱ Kiristi, u̱ ze̱gu̱ me̱ u̱r-zwar iya sok.
\v 24 Ko̱ ba shu̱'u̱te̱ u̱zu̱ ze̱k u̱r-zwar u̱m shu̱'u̱t u̱r-fat remu̱ u̱m no̱m-tu̱ no̱ u̱r-se̱ge̱.
\v 25 U̱m o̱tte̱ m-nap iya za u-sakna. Tu̱msu̱ u̱m nak u̱zu̱ me̱ u̱t-shu̱'u̱t u̱r-fat tu̱msu̱ me̱ u̱t-re̱ u-shu̱ u̱r-shu̱'u̱t u̱ no̱ ne̱ be̱e̱t remu̱ no̱ rogomte̱ u̱-me̱ u̱r-so̱ u̱ yadu̱ jab-u̱ no̱ ne̱.
\v 26 Remu̱ zu̱ da-u̱ u̱m sure̱ m-haan u̱du̱ no̱, so̱-u̱r no̱ remu̱ no̱m-u̱ Kiristi Ye̱so̱ no̱me̱ de̱ u̱t-no̱m u-tát remu̱ no̱m-u̱ wa o̱ u̱t-no̱m u̱ me̱ ne̱.
\p 
\v 27 No̱m-u̱ ze̱ge̱ u̱r-zwar o̱ u̱zu̱, no̱ no̱m shu̱'u̱t-u̱r no̱ ho̱n-ho̱n u̱ka Rem-su̱ m-Re̱me̱r u̱ mo̱t-u̱t Kiristi. Se̱di, ko̱ a u̱m haane̱ hyan-du̱ no̱, ko̱ a u̱m ho̱ge̱ u̱ mo̱t-u̱t no̱ da-u̱ u̱m za u̱r-kot u̱ no̱ ne̱ da, me̱ u̱t-nap u̱zu̱ no̱ o̱ ees u̱r-be̱b ne̱ u̱ u-Yar ne̱ u-gan, tu̱msu̱ no̱ o̱ no̱m-du̱ m-gag u̱r-kot u̱ te̱k-u̱ same̱-du̱ u̱t-hi remu̱ ya-du̱ jab-u̱ o̱ u̱s-gan u̱ Rem-su̱ m-Re̱me̱r ne̱.
\v 28 A no̱ ho̱g u-gye̱r u̱ hu̱u̱b-u̱t yo̱-to̱ no̱ u̱ ko̱yu̱he̱ fu̱n-ya da. O̱ de̱ u̱t-shu̱'u̱t sha-mu̱ swadu̱ u̱r-ko̱b-u̱ u̱n du̱ m-mo̱mmo̱, se̱di u̱t-shu̱'u̱t nap-su̱ kwu̱m-du̱ u̱ku̱r-u no̱, tu̱msu̱ o̱ u̱t-rwu̱u̱n du̱gu̱-du̱ u-Ru̱.
\v 29 U̱m zu̱u̱g iya remu̱ zu̱ na yaag no̱ u̱r-ke̱r remu̱ Kiristi za remu̱ yadu̱ jab-u̱ war-o̱ u̱du̱ rò da, se̱di no̱ swa u̱r-ko̱b u̱ remu̱ wu̱n,
\v 30 remu̱ u̱zu̱ no̱ o̱ te̱k-u̱ u̱s-pama u̱s-gan u̱ su̱ no̱ hyane̱ me̱ u̱t-no̱m, tu̱msu̱ u̱ da-o̱ no̱ ho̱k u̱zu̱ u̱m o̱ te̱k u̱t-no̱m.
\c 2
\s1 U̱r-shu̱'u̱t u̱ka Kiristi
\p 
\v 1 Kiristi yaag no̱ shiriktin-mu̱ jab du̱gu̱ yu̱-u̱r no̱ u̱ wa ne̱, tu̱msu̱ wa yaag no̱ ru̱s-du̱ jab du̱gu̱ cwan-u̱t wa, tu̱msu̱ no̱ o̱tte̱ same̱-du̱ u̱t-hi u̱ Yar-u̱ Kiristi ne̱, tu̱msu̱ no̱ ko̱ske̱ cwan-u̱t no̱ u̱ u̱r-o̱n ne̱ u̱du̱ o̱r-u̱t no̱ ne̱.
\v 2 Remu̱ iya, u̱m o̱ ko̱n-u̱s no̱. Yagu̱n u̱ so̱-u̱r ri u̱ shi u-tát, u̱du̱ same̱-du̱ u̱t-hi no̱ ne̱ u̱r-koto, u̱du̱ cwan-tu̱ o̱r-u̱t no̱ tu̱msu̱ no̱ shu̱'u̱t jab-u̱s no̱ u̱s-gan tu̱msu̱ u̱ dorog-u̱s no̱ ne̱.
\v 3 A no̱ o̱ m-no̱m o̱ko̱n u̱ remu̱ cwan-tu̱ u̱r-hi da, se̱di no̱ ko̱se̱ hi-u̱r no̱ u̱zu̱ o̱ko̱n no̱m-o̱ no̱ o̱o̱ge̱ da. Se̱di no̱ shu̱'u̱t swu̱u̱ne̱, gwatu̱n o̱r-u̱t no̱ ne̱ m-ze̱g hi-u̱t no̱.
\v 4 A no̱ gwat hi-u̱r no̱ u̱ bo̱ru̱ no̱ da, se̱di no̱ gwat o̱r-u̱t no̱ ne̱ ko̱'e̱.
\p 
\v 5 Yagu̱n u̱ dorog-u̱s no̱ shu̱'u̱t u̱ka su̱ o̱o̱ge̱ ba sha-mu̱ su̱ Kiristi Ye̱so̱:
\q1 
\v 6 Ko̱ ba shu̱'u̱te̱ u̱zu̱ wa o̱ u̱ka u-Ru̱
\q2 u̱ ko̱yu̱he̱ fu̱n-ya,
\q1 wa muute̱ shu̱'u̱t-u̱r wa u̱s-gan u-Ru̱ ne̱
\q2 no̱m-u̱ wa do̱'e̱ u̱t-shu̱p da.
\q1 
\v 7 Se̱di wa muute̱ hi-u̱r wa u̱zu̱ wa otte̱
\q2 m-shin u̱ shu̱'u̱te̱ u̱s-gan u-Ru̱ ne̱ da,
\q1 tu̱msu̱ wa ku̱b o̱g-du̱ to̱k,
\q2 tu̱msu̱ na mu̱u̱t wu̱n u̱ sha-mu̱ ne̱t.
\q1 
\v 8 Da-u̱ wa haane̱ u̱ sha-mu̱ ne̱t,
\q2 wa muut hi-u̱r wa swu̱.
\q1 Tu̱msu̱ wa ye m-ze̱g u̱du̱ u-Ru̱,
\q2 tu̱msu̱ m-ha m-mar ne̱,
\q1 mar-mu̱ do̱m-u u-kan.
\q1 
\v 9 Remu̱ iya ne̱,
\q2 Ru̱-u̱ fu̱bu̱sse̱ wa u̱ be-du̱ ze̱ge̱,
\q1 tu̱msu̱ wa ye wu̱n u̱r-dim
\q2 du̱ ze̱ge̱ ko̱du̱he̱ dim-de̱.
\q1 
\v 10 Remu̱ u̱-me̱ dim-u̱r Ye̱so̱ ko̱du̱he̱
\q2 jwu̱n-de̱ do̱'e̱ u̱t-kwu̱ku̱t,
\q1 u̱-do̱m u-ru̱ u-dak ne̱
\q2 tu̱msu̱ u̱-ta u-dak ne̱,
\q1 
\v 11 Tu̱msu̱ ko̱du̱he̱ rem-de̱ do̱'e̱ u̱t-war
\q2 u̱zu̱ Ye̱so̱ Kiristi Wa-ko-uyan wa,
\q1 remu̱ sek-mu̱ u-Ru̱ u-U̱so.
\s1 M-zu̱n u̱-me̱ u-dak u-be̱e̱t
\p 
\v 12 Se̱di, hu̱u̱b-u̱t ri, ka no̱ yu̱te̱ me̱ m-ze̱g u-da u-be̱e̱t da-u̱ u̱m o̱o̱ge̱ u̱r-kot u̱ no̱ ne̱, ze̱k u̱r-zwar u̱ da-o̱ u̱zu̱ no̱ ya' me̱ m-ze̱g da-u̱ u̱m o̱o̱ge̱ m-ra u̱ no̱ ne̱. Re̱e̱n u-shu̱ m-ank ne̱ u-gye̱r ne̱ u̱ m-zap ne̱ u̱ no̱ shu̱u̱ste̱ u̱ku̱r-u no̱.
\v 13 U̱m zu̱u̱g iya re̱mu̱ Ru̱-o̱ o̱ m-ank u̱-me̱ no̱, remu̱ wa ye'et no̱ jab tu̱msu̱ m-shin ne̱ no̱ no̱m no̱m-u̱ wa o̱ u̱t-sa no̱ no̱m.
\p 
\v 14 No̱ no̱m ko̱-uyan za u̱s-rem tu̱msu̱ za u-gwu̱z,
\v 15 remu̱ no̱ shu̱'u̱te̱ tu̱msu̱ za u̱r-pyap u-he̱n ne̱, u̱ka ya'ag-u̱ u-Ru̱, u̱ te̱k-u̱ u̱-me̱ ne̱t-u̱t yo̱-to̱ u̱ a-u̱t-ba'as-ne̱. Se̱ no̱ no̱ng yu̱-u̱r so̱de̱ u̱-me̱ u̱n sha-mu̱ re̱ge̱r u̱ mo̱k-du̱ m-zu̱n u̱-me̱ dak-u̱ u-cwu̱m
\v 16 Shu̱pu̱n gom-du̱ u̱r-fat u̱r-zwar ne̱, remu̱ u̱zu̱ ho̱-du̱ mu̱u̱n-u̱r Kiristi me̱ u̱t-ker no̱m-du̱ u̱t-u̱k u̱zu̱ u̱m no̱ng m-so̱m ko̱ ank-mu̱ m-zan da.
\v 17 Se̱di me̱ u̱t-no̱m u̱r-so̱ ko̱ zu̱ u̱m tagte̱ u̱ fat-u̱r ri, du̱ na azge̱ u̱ka to̱o̱g, u̱ka ank-m no̱ mu̱ u̱t-nip, u̱ka u̱r-to̱o̱g u̱du̱ u-Ru̱. Tu̱msu̱ u̱m no̱ng u̱r-so̱ tu̱msu̱ u̱m o̱ u̱r-so̱ u̱ no̱ ne̱ be̱e̱t.
\v 18 Du̱pke̱ no̱ shu̱'u̱t u̱ mo̱k-du̱ jab u̱r-so̱ ne̱ u̱r-ko̱t u̱ me̱ ne̱.
\s1 Timoti e̱ E̱paraditus
\p 
\v 19 A Wa-ko-uyan Ye̱so̱ zu̱ye̱, u̱m o̱ wadu̱ jab u̱zu̱ me̱ to̱mto̱n no̱ Timoti za m-tumb. Me̱ u̱t-ha u̱t-no̱m iya ko̱ me̱ u̱m kum-u̱t m-shiriktin da-u̱ u̱m ho̱ge̱ u̱ka no̱ o̱tte̱ u̱t-no̱m.
\v 20 U̱m o̱ u̱t-sa no̱ nap u̱zu̱ u̱m zatte̱ waku̱n u̱ka wu̱n da, wu̱ do̱'e̱ gwat-du̱ cwan-tu̱ shu̱'u̱t-du̱ m-yaru̱ no̱ so̱k.
\v 21 U̱m zu̱u̱g iya remu̱ zu̱ ko̱wan mu̱tte̱ jab-u̱ dorog-su̱ cwan-tu̱ no̱m-u̱ o̱ u̱ wa, za no̱m-u̱ o̱ u̱ Ye̱so̱ Kiristi da.
\v 22 Se̱di no̱ nak go̱-du̱ ne̱t-u̱ Timo̱ti o̱ye̱, u̱ka wa ya'aste̱ hi-u̱r wa, u̱ka wa' u̱du̱ u̱so-u wa, u̱ka wa nomte̱ u̱s-pama u̱ me̱ ne̱ u̱ warru̱ Rem-su̱ m-Re̱me̱r.
\v 23 Remu̱ iya, da-u̱ u̱m hyane̱ ka ko̱-uyan o̱tte̱ m-da u̱ me̱ne̱, u̱m o̱ wadu̱ jab to̱mo̱n wu̱n u̱du̱ no̱ za m-tumb.
\v 24 U̱m zatte̱ u-sakna da u̱zu̱ a Wa-ko-uyan u̱ tane̱, me̱ u̱t-haan me̱ hi-u̱r ri za m-tumb.
\p 
\v 25 Se̱di u̱m dorogte̱ u̱zu̱ kamu̱g u̱m u̱ da-o̱ mu̱u̱tu̱n no̱ Abafariditus. O̱ru̱ ri wa doru̱ Ye̱so̱ wa, hu̱u̱b m-ank u̱ ri, hu̱u̱b u̱r-se̱ge̱ ri u̱du̱ m-gag. Tu̱msu̱ wu̱ nome̱ m-ank mu̱ sha-mu̱ wa-to̱m-u̱ no̱ remu̱ wa no̱m-tu̱ me̱ u̱r-se̱ge̱ u̱ da-u̱ u̱m o̱ u̱ssa.
\v 26 U̱m o̱ to̱mnu̱ wu̱n remu̱ zu̱ wu̱n tumbte̱ u̱t-sa wu̱n hyan no̱, tu̱msu̱ wu̱n e̱ku̱ste̱ sok remu̱ u̱zu̱ no̱ ho̱k u̱zu̱ wa zatte̱ m-yar da.
\v 27 Tu̱msu̱ iya-o̱ wa no̱ng ko̱b-du̱ m-yar so̱k, har wa o̱o̱g u̱ssa m-mar. Se̱di Ru̱-u̱ ho̱k o̱n-u̱r wa, tu̱msu̱ u̱ o̱n-u̱r ri ne̱, taas u̱m no̱m namu̱ jab u̱-me̱ mo̱ko̱n namu̱ jab mu̱ da.
\v 28 Remu̱ iya u̱m e̱ku̱ste̱ sok u̱m to̱mto̱n no̱ wu̱n, remu̱ u̱zu̱ da-u̱ no̱ hyane̱ wu̱n no̱ u̱t-no̱m u̱r-so̱ du̱ hyan-du̱ wu̱n, tu̱msu̱ u̱m za na-su̱ jab so̱k da.
\v 29 Remu̱ iya, kabu̱n wu̱n u̱r-so̱ ne̱ so̱k, u̱ka a-doru̱ Wa-ko-uyan ku̱bte̱ o̱r-u̱t e̱ a-dor-ne̱. Ya'an u̱t-ne̱t go̱-du̱ wu̱n ne̱ m-ze̱g.
\v 30 Yaan wu̱n m-ze̱g remu̱ zu̱ wa ko̱ko̱t m-mar remu̱ ank-m Kiristi. Da-u̱ wa o̱o̱ge̱ no̱mu̱ me̱ u̱r-se̱ge̱, du̱ no̱ kerge̱ no̱mu̱ me̱ da. Wa no̱ng iya remu̱ u̱zu̱ no̱ kerge̱ u̱r-haan no̱ no̱mu̱ me̱ u̱r-se̱ge̱ hi-u̱r no̱ da.
\c 3
\s1 Jab-u̱ so̱-o̱ u̱t-nip
\p 
\v 1 U̱ da-o̱ hen o̱r-u̱t ri ne̱, no̱mo̱n u̱r-so̱ u̱-me̱ Wa-ko-uyan! U̱m poot u̱ ge̱nu̱ no̱ tun-to̱ no̱m-to̱ tu̱ u̱m de̱ u̱t-swu̱r m-waru̱ no̱ da tu̱msu̱ u̱m o̱ no̱m-du̱ to̱ remu̱ e̱'-du̱ yar-m no̱.
\p 
\v 2 Gwatu̱n u̱r-zwar ne̱ u̱ a-no̱m-du̱ no̱m-u̱t yo̱-to̱ ne̱, e̱ u̱ka o̱', i o̱o̱ge̱ a-kwu̱p-du̱ u-war, i zu̱ye̱ se̱ na no̱ngu̱ no̱ u̱r-pe̱s kanda no̱ kum-u̱t u-u̱ku̱r.
\v 3 Remu̱ in i nome̱ u̱t-huuk u̱ Yar u-Ru̱ i na o̱ye̱ i na no̱me̱ u̱r-pe̱s du̱ u̱t-nip. In to̱ste̱ u̱ no̱mu̱ Ru̱-u̱ no̱mu̱ in ne̱ u̱-me̱ Kiristi Ye̱so̱. In to̱ste̱ u̱ be̱b-du̱ ne̱t da,
\v 4 Ko̱ ba shu̱'u̱te̱ u̱zu̱ me̱ u̱ hi-u̱r ri u̱m o̱tte̱ no̱mu̱ de̱ kere̱ wadu̱ me̱ yadu̱ jab-u̱ no̱m-u̱t to̱.
\p A waku̱n o̱ u̱s-dorog u̱zu̱ wa kere̱ kwu̱m-du̱ u̱ku̱r du̱gu̱-du̱ be̱b-du̱ ne̱t, u̱m o̱tte̱ m-ze̱g wa:
\v 5 Na no̱ngu̱ me̱ u̱r-pe̱s u̱ ho̱-du̱ roog-mu̱ u̱t-eer. Me̱ ne̱t-tu̱ Isra wa, du̱gu̱ ko̱-u̱r Banyami. Me̱ matu̱ ne̱t-u̱ Ibraniya-ne̱ wa. U̱ka wa Farisa u̱m no̱ng yu̱-u̱r ri du̱ do̱rru̱ bo̱r-u̱t Yahuda-ne̱.
\v 6 U̱m o̱o̱g u̱m cwanu̱g u-Ru̱ sok u̱ wa me̱ u̱ yadu̱ a-doru̱ Ye̱so̱ ne̱ u̱r-ko̱b. U̱m o̱o̱g u̱ jab-u̱ so̱-o̱ ne̱ sok, u̱ wa me̱ do̱rru̱ bo̱r-u̱t Yahuda-ne̱ za pas-du̱ u-bo̱r.
\p 
\v 7 U̱m o̱o̱g u̱m kabu̱g no̱m-u̱t to u̱ka m-swu̱r, se̱di u̱ da-o̱ u̱m kabu̱g to̱ m-zan remu̱ no̱mu̱ Kiristi no̱mu̱ me̱.
\v 8 No̱mu̱ ze̱ge̱ iya, u̱m kabu̱g ko̱-uyan m-zan remu̱ swu̱r-mu̱ zare̱ senu̱sse̱ da mu̱ nap-m Kiristi Ye̱so̱ Wa-ko-uyan u ri. Remu̱ wa o̱ u̱m taagte̱ ko̱-uyan tu̱msu̱ u̱m kabu̱g to̱ no̱m-tu̱ u̱s-gu̱r, remu̱ u̱m kum-u̱t Kiristi,
\v 9 tu̱msu̱ zu̱ u̱m shu̱'u̱te̱ u̱s-gan u̱ wu̱n ne̱. U̱m zamu̱n u̱ to̱stu̱ jab-u̱ ri remu̱ no̱m-u̱ u̱m o̱ u̱t-no̱m da se̱di u̱m shu̱'u̱te̱ wa jab-u̱ so̱-o̱ remu̱ do̱rru̱ u̱t-bo̱r da. Se̱di u̱m shu̱'u̱te̱ wa jab-u̱ so̱-o̱ remu̱ ya-du̱ jab-u̱ u̱du̱ Kiristi. Jab-u̱ so̱-o̱ uno̱ rwu̱gu̱n du̱gu̱ u-Ru̱ remu̱ ya-du̱ jab.
\v 10 U̱m u̱t-sa m-nap Kiristi tu̱msu̱ u̱m nap shin-m mo̱ mu̱ yu̱nse̱ wa du̱gu̱ m-mar. Tu̱msu̱ u̱m u̱t-sa u̱m swa u̱r-ko̱b u̱ka wa soote̱ u̱r-ko̱b, tu̱msu̱ u̱m shu̱'u̱t u̱s-gan u̱ wa ne̱ u̱ mar-m wa,
\v 11 u̱m u̱t-sa tunto̱ no̱m-to̱ no̱m remu̱ u̱zu̱ Ru̱-o̱ u̱t-wa u̱m shu̱'u̱t u̱r-fat tu̱msu̱ ba u̱m mare̱.
\s1 Re̱-du̱ u-shu̱
\p 
\v 12 Za zu̱ u̱m kwu̱mu̱g no̱m-u̱t to̱ u̱t-be̱e̱t da, ko̱ u̱zu̱ u̱m shu̱u̱g u-be̱e̱t u̱ka Ru̱-u̱ o̱tte̱ u̱ssa da. Se̱di u̱m o̱ u̱t-swu̱r u̱r-no̱k u-shu̱ u̱m shu̱'u̱t u̱ka Kiristi remu̱ u̱zu̱ wa dak me̱ u̱m shu̱'u̱t ba wa.
\v 13 O̱r-u̱t ri ne̱, u̱m kabu̱g hi-u̱r ri u̱zu̱ u̱m shu̱pu̱k to̱ da. Se̱di no̱m-u̱ u̱m o̱ u̱t-no̱m u-gan: U̱m o̱ u̱t-ku̱u̱s u̱t-to̱ u̱ no̱mu̱ o̱o̱ge̱ dim ne̱ tu̱msu̱ u̱m o̱ bu̱z-du̱ no̱m-u̱ o̱ u-shu̱.
\v 14 U̱m o̱ m-so̱m u̱m te be-du̱ re̱-du̱ u̱r-ko̱rro̱ remu̱ u̱m reet u̱r-o̱g, du̱ Ru̱-u̱ u̱t-sa u̱du̱ ri. Wa u̱t-sa u̱m shu̱'u̱t sha-m Ye̱so̱ Kiristi tu̱msu̱ u̱m shu̱'u̱t u̱t-mo̱r u̱ wa ne̱.
\p 
\v 15 In be̱e̱t i Yar u-Ru̱ se̱ste̱ yage̱ in shu̱'u̱t u̱ go̱-du̱ uno̱ jab o̱ ne̱. Se̱di a waku̱n o̱ se̱ke̱n dorogse̱ ne̱ su̱ kit, Ru̱-u̱ de̱ u̱t-wa wa nap m-zu̱n.
\v 16 No̱m-u̱ zu̱ge̱ u̱r-zwar hen, yagu̱n in du̱u̱t yu̱-u̱r in remu̱ nip-tu̱ in kume̱.
\p 
\v 17 O̱r-u̱t ri ne̱, dorton fat-u̱t no̱ u̱ka u̱m nomte̱ du̱ ri yu̱-de̱, tu̱msu̱ isu̱n du̱gu̱-du̱ ne̱t-tu̱ o̱ do̱rru̱ da-tu̱ it yasu̱ no̱.
\v 18 No̱mu̱ wu̱te̱ u̱m o̱tte̱ waru̱ no̱ u̱zu̱ no̱ gwat yu̱-u̱r no̱ u̱r-zwar ne̱, u̱ da-o̱ tu̱msu̱ u̱m o̱ waru̱ no̱ m-is ne̱ u̱ is-u̱ ri, u̱zu̱ e̱ke̱n o̱ro u-tát i o̱ gu̱g-mu̱ ko̱se̱-tu̱ mo̱ttu̱ mar-m Kiristi u̱-do̱m u-kan.
\v 19 Vaste̱-m u̱n be-du̱ m-mar de̱ u̱n sa-e̱, ru̱-u u̱n no̱m-tu̱ war-u̱t u̱n u̱t-sa to̱, tu̱msu̱ u̱n u-da u-be̱e̱t u̱n o̱ u̱t-u̱k tu̱ no̱m-tu̱ m-e̱. Dorog-u̱s u̱n o̱ du̱ no̱m-tu̱ u-dak.
\v 20 Se̱di in ne̱t-tu̱ do̱m u-ru̱ to̱. Tu̱msu̱ in e̱ku̱ste̱ u̱ e'-du̱ wa-u-u̱ku̱r du̱gu̱ ku̱n, wu̱na o̱ Wa-ko-uyan Ye̱so̱ Kiristi.
\v 21 Wa do̱'e̱ kab-du̱ war-tu̱ za m-sek u̱ in tu̱msu̱ wa muut to̱ sha-mu̱ war-u̱ m-sek u̱ wa. Wa u̱t-no̱m iya u̱ be̱b-u̱r wa, remu̱ gandi be̱b-u̱r re du̱ muute̱ ko̱-uyan u̱du̱ faru̱k-u̱r wa.
\c 4
\p 
\v 1 Remu̱ iya, o̱r-u̱t ri ne̱ i u̱m u̱t-cwan, shu̱'u̱tu̱n u̱r-be̱b ne̱ u̱du̱ Wa-ko-uyan! U̱m cwanu̱g no̱ o̱r-u̱t ri ne̱, tu̱msu̱ u̱m tumbte̱ u̱ssa u̱m m-hyan no̱, remu̱ zu̱ no̱ o̱ye̱ so̱-u̱r ri u̱ to̱p-u ri ne̱ u̱ u̱m kume̱ remu̱ ank-m ri.
\s1 Gom-tu̱ m-shiriktin // mu̱ jab
\p 
\v 2 U̱m ko̱no̱g Yudiya u̱ Sintiki remu̱ u̱zu̱ no̱ ne̱t-u̱t Wa-ko-uyan to̱ ho̱ngsu̱n ko̱b-du̱ same̱-du̱ u̱t-hi no̱.
\v 3 Tu̱msu̱ u̱m ko̱no̱g bo̱, hu̱u̱b m-ank-u̱ ri wu̱ u̱t-nip, bo̱ no̱mu̱ ne̱ta-u̱t to̱ u̱r-se̱ge̱, remu̱ zu̱ u̱n no̱ng m-ank so̱k u̱ me̱ ne̱ u̱du̱ warru̱ Rem-su̱ m-Re̱me̱r. U̱n no̱ng m-ank u̱r-ko̱t u̱ Ke̱re̱me̱n ne̱ u̱ to̱ko̱n hu̱u̱b-tu̱ m-ank-u̱ ri ne̱, i dim-u̱t e̱ o̱o̱ge̱ m-pan u̱-me̱ Ran-u̱ u̱r-fat.
\p 
\v 4 Ko̱-uyan da no̱mu̱n u̱r-so̱ u̱-me̱ Wa-ko-uyan. Me̱ u̱t-swu̱r m-zu̱: No̱m u̱r-so̱!
\v 5 Yage̱ ko̱wan hyan yar-mu̱ jab no̱. Wa-ko-uyan no̱ng u̱t-mo̱r u̱ mu̱u̱n ne̱.
\v 6 A jab-u̱ no̱ yu̱ne̱ remu̱ o̱ko̱n no̱m-o̱ da, se̱di te̱k-u̱ ko̱-uyan, u̱-me̱ u̱s-to̱o̱g u̱s-ko̱n ne̱, u̱t-vam ne̱ hu̱u̱tu̱n ko̱n-u̱s no̱ u̱du̱ u-Ru̱.
\v 7 Tu̱msu̱ ru̱s-du̱ jab ne̱ du̱ u-Ru̱, u̱ ze̱ge̱ nap-mu̱ ne̱t, o̱ de̱ e'-du̱ jab-u̱s no̱ u̱ dorog-u̱s no̱ ne̱ remu̱ same̱-du̱ u̱t-hi no̱ u̱ Kiristi Ye̱so̱ ne̱.
\p 
\v 8 M-vaste̱, o̱r-u̱t ri, Ko̱-uyan o̱ no̱ iise̱ du̱gu̱-du̱ ri, ko̱-uyan o̱ no̱ o̱nke̱ du̱gu̱-du̱ ri, ko̱-uyan o̱ no̱ ho̱ge̱ du̱gu̱-du̱ ri, ko̱-uyan o̱ no̱ hyane̱ me̱ u̱t-no̱m, waan to̱ u̱-me̱ u-iis. Tu̱msu̱ Ru̱-u̱ ru̱s-du̱ jab u̱t-no̱m u̱r-kot u̱ no̱ ne̱.
\v 9 Ko̱-uyan o̱ no̱ iise̱ du̱gu̱-du̱ ri ko̱-uyan o̱ no̱ o̱nke̱ du̱gu̱-du̱ ri, ko̱-uyan o̱ no̱ ho̱ge̱ du̱gu̱-du̱ ri, ko̱-uyan o̱ no̱ hyane̱ me̱ u̱t-no̱m, waan to̱ u̱-me̱ u-iis. A no̱ no̱me̱ tunto̱ no̱m-to̱ Ru̱-u̱ ru̱s-du̱ jab u̱t-no̱m u̱r-kot u̱ no̱ ne̱.
\s1 U̱t-vam remu̱ nya-u u̱n
\p 
\v 10 U̱m no̱ngu̱ Wa-ko-uyan u̱t-vam, remu̱ zu̱ u̱ da-o̱ no̱ mu̱ttu̱n jab-u̱s no̱ tu̱msu̱ u̱du̱ ri. U̱m nak u̱zu̱ u̱m o̱o̱g u̱ jab-u̱s no̱, se̱di no̱ kwu̱mu̱g keru̱ no̱mu̱ me̱ u̱r-se̱ge̱ da.
\v 11 Za u̱zu̱ u̱m zu̱u̱g iya remu̱ u̱zu̱ u̱m tagte̱ o̱kon da, remu̱ u̱zu̱ u̱m iiste̱ u̱r-shu̱'u̱t u̱ no̱mu̱ u̱m o̱tte̱ ne̱ u-be̱e̱t u̱ ko̱yu̱he̱ fu̱n-ya.
\v 12 U̱m nak yu̱-du̱ u̱r-ko̱b, tu̱msu̱ u̱m nak yu̱-du̱ u̱t-kwu̱m. U̱m iiste̱ u̱r-shu̱'u̱t u̱ no̱mu̱ u̱m o̱tte̱ ne̱ u-be̱e̱t u̱ ko̱yu̱he̱ fu̱n-ya, ko̱ u̱m re̱e̱g u̱m shig ko̱ u̱m o̱ u̱s-me̱r, ko̱ u̱m o̱ shu̱'u̱t-du̱ u̱t-kwu̱m u-tát ko̱ da-u̱ swa-u̱ u̱r-ko̱b.
\v 13 Me̱ kere̱ no̱m-du̱ ko̱-uyan u̱ remu̱ Kiristi wu̱ yu̱'e̱ me̱ u̱r-be̱b.
\p 
\v 14 Se̱di no̱ng u̱r-zwar u̱ no̱ no̱m-tu̱ me̱ u̱r-se̱ge̱ u̱-me̱ swadu̱ u̱r-ko̱bu̱ ri.
\v 15 Ne̱t-tu̱ Firipi-ne̱, da-u̱ u̱m haatu̱n no̱ rem-su̱ m-re̱me̱r su̱ u-Ru̱, no̱ nak ank-m ri du̱gu̱ u̱r-taku̱n. A tase̱, da-u̱ u̱m yage̱ no̱ m-ha dak-u̱ Makidoniya, no̱ nak u̱zu̱ no̱ o̱o̱ge̱ mo̱ro̱g-du̱ a-doru̱ Ye̱so̱ ne̱ i no̱mu̱ me̱ u̱r-se̱ge̱ u̱ war-no̱. No̱ o̱ ne̱t-tu̱ no̱mu̱ me̱ se̱ge̱-du̱ shik-u̱ war-no̱. No̱ no̱ng iya remu̱ u̱m ye'et u̱n Rem-su̱ m-Re̱me̱r su̱ u-Ru̱.
\v 16 Remu̱ da-u̱ u̱m o̱o̱ge̱ u̱ bo̱-u̱ Tasaronika no̱ to̱mo̱tto̱n me̱ u̱r-se̱ge̱ m-ze̱g u-so u-gan.
\v 17 U̱m zu̱u̱g iya tass no̱ dorog u̱zu̱ ho̱s-mo̱ u̱m u̱t-sa du̱gu̱-du̱ no̱ da, se̱di u̱m u̱t-sa no̱ kum u-to̱p du̱gu̱-du̱ u-Ru̱ remu̱ ho̱s-m no̱.
\v 18 U̱m kwu̱mu̱g ko̱-uyan u̱m u̱t-sa, u̱t-nip u̱m o̱tte̱ u-tát m-ze̱g no̱m-u̱ u̱m u̱t-sa. U̱m o̱tte̱ no̱m-u̱ u̱m u̱t-sa u-be̱e̱t remu̱ u̱m kwu̱mu̱g ho̱s-mu̱ no̱ yasu̱n Abafariditus. Ho̱s-mo̱ u̱ka ho̱s-mu̱ sha-mu̱ wu̱s u-haku̱n, to̱o̱g-o̱ u̱ Ru̱-u̱ o̱nke̱ tu̱msu̱ wa ho̱g zwarru̱ o̱.
\v 19 Tu̱msu̱ Ru̱-u ri de̱ to̱s-du̱ no̱ no̱m-u̱ no̱ u̱t-sa u-be̱e̱t du̱gu̱ sek-mu̱ kwu̱m-u̱t wa, remu̱ Kiristi Ye̱so̱.
\p 
\v 20 M-sek u̱du̱ u-Ru̱ U̱so-u in m-mo̱mmo̱. U̱ shu̱'u̱t iya.
\s1 Vu̱k-su̱ m-vaste̱ Burus
\p 
\v 21 Vu̱ksu̱n ne̱t-u̱t Kiristi Ye̱so̱ u̱t-be̱e̱t. A-dor-ne̱ i o̱o̱ge̱ u̱r-ko̱t u̱ me̱ ne̱ e̱ o̱ vu̱k-su̱ no̱.
\v 22 Ne̱t-tu̱ u-Ru̱ u̱t-be̱e̱t e̱ o̱ vu̱k-su̱ no̱, u̱r-same̱ u̱ a-dor-ne̱ i o̱o̱ge̱ u̱-me̱ bu-u Kaisar.
\p 
\v 23 Nya-u Wa-ko-uyan in Ye̱so̱ Kiristi o̱ u̱r-kot u̱ yar-u no̱ ne̱. U̱ shu̱'u̱t iya.
