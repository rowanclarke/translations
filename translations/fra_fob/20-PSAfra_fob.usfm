\v 1 Lorsque Nathan \w le|strong="H1732"\w* prophète \w vint|strong="H1732"\w* \w à|strong="H1732"\w* \w lui|strong="H1732"\w*, après que \w David|strong="H1732"\w* \w fut|strong="H1732"\w* allé vers Bath-Shéba.
\v 2 \w O|strong="H3068"\w* Dieu, aie pitié \w de|strong="H5030"\w* moi, selon ta miséricorde! Selon \w la|strong="H5030"\w* grandeur \w de|strong="H5030"\w* tes compassions, efface mes forfaits!
\v 3 Lave-moi parfaitement \w de|strong="H7230"\w* \w mon|strong="H2603"\w* iniquité, \w et|strong="H2617"\w* nettoie-moi \w de|strong="H7230"\w* \w mon|strong="H2603"\w* \w péché|strong="H6588"\w*!
\v 4 Car \w je|strong="H2403"\w* connais \w mes|strong="H7235"\w* transgressions, \w et|strong="H7235"\w* \w mon|strong="H7235"\w* \w péché|strong="H2403"\w* \w est|strong="H2403"\w* toujours devant moi.
\v 5 \w J|strong="H3068"\w*'ai \w péché|strong="H2403"\w* contre \w toi|strong="H3588"\w*, contre \w toi|strong="H3588"\w* \w seul|strong="H3588"\w*, \w et|strong="H3045"\w* j'ai fait \w ce|strong="H3588"\w* \w qui|strong="H3045"\w* \w est|strong="H2403"\w* mal \w à|strong="H3588"\w* \w tes|strong="H3045"\w* yeux, \w de|strong="H2403"\w* sorte \w que|strong="H3588"\w* \w tu|strong="H3588"\w* \w seras|strong="H3588"\w* juste \w quand|strong="H3588"\w* \w tu|strong="H3588"\w* parleras, \w et|strong="H3045"\w* \w sans|strong="H3588"\w* reproche \w quand|strong="H3588"\w* \w tu|strong="H3588"\w* jugeras.
\v 6 Voilà, \w j|strong="H5869"\w*'\w ai|strong="H6213"\w* \w été|strong="H6213"\w* \w formé|strong="H6213"\w* \w dans|strong="H6213"\w* l'\w iniquité|strong="H5869"\w*, \w et|strong="H6213"\w* \w ma|strong="H6213"\w* \w mère|strong="H6213"\w* m'\w a|strong="H3068"\w* conçu \w dans|strong="H6213"\w* \w le|strong="H6213"\w* \w péché|strong="H2398"\w*.
\v 7 Voilà, tu aimes \w la|strong="H2342"\w* vérité \w dans|strong="H3179"\w* \w le|strong="H2342"\w* cœur, tu m'\w as|strong="H5771"\w* fait connaître \w la|strong="H2342"\w* sagesse \w au-dedans|strong="H2342"\w* \w de|strong="H5771"\w* moi.
\v 8 Purifie-moi \w de|strong="H2451"\w* \w mon|strong="H3045"\w* péché \w avec|strong="H3045"\w* l'hysope, \w et|strong="H3045"\w* \w je|strong="H2005"\w* \w serai|strong="H3045"\w* net; lave-moi \w et|strong="H3045"\w* \w je|strong="H2005"\w* \w serai|strong="H3045"\w* \w plus|strong="H3045"\w* blanc \w que|strong="H3045"\w* \w la|strong="H3045"\w* neige.
\v 9 Fais-moi entendre \w la|strong="H2398"\w* joie \w et|strong="H2398"\w* l'allégresse; \w que|strong="H3835"\w* \w les|strong="H2891"\w* os \w que|strong="H3835"\w* tu as brisés, se réjouissent!
\v 10 Détourne \w ta|strong="H8085"\w* face \w de|strong="H8085"\w* \w mes|strong="H8085"\w* péchés; efface \w toutes|strong="H8085"\w* \w mes|strong="H8085"\w* iniquités!
\v 11 \w O|strong="H3068"\w* \w Dieu|strong="H6440"\w*, crée \w en|strong="H6440"\w* \w moi|strong="H6440"\w* \w un|strong="H6440"\w* \w cœur|strong="H6440"\w* pur, \w et|strong="H6440"\w* renouvelle \w en|strong="H6440"\w* \w moi|strong="H6440"\w* \w un|strong="H6440"\w* esprit droit!
\v 12 \w Ne|strong="H3820"\w* \w me|strong="H7307"\w* rejette pas loin \w de|strong="H7307"\w* \w ta|strong="H3559"\w* face, \w et|strong="H7307"\w* \w ne|strong="H3820"\w* \w m|strong="H7307"\w*'ôte pas \w ton|strong="H3820"\w* \w esprit|strong="H7307"\w* saint!
\v 13 Rends-moi \w la|strong="H6440"\w* joie \w de|strong="H6440"\w* \w ton|strong="H6440"\w* salut, \w et|strong="H6440"\w* \w que|strong="H6440"\w* \w l|strong="H6440"\w*'\w esprit|strong="H7307"\w* \w de|strong="H6440"\w* \w bonne|strong="H7307"\w* \w volonté|strong="H7307"\w* \w me|strong="H6440"\w* soutienne!
\v 14 \w J|strong="H3068"\w*'enseignerai \w tes|strong="H7725"\w* voies \w aux|strong="H7725"\w* transgresseurs, \w et|strong="H7725"\w* \w les|strong="H7725"\w* pécheurs \w se|strong="H7307"\w* \w convertiront|strong="H7725"\w* \w à|strong="H7725"\w* \w toi|strong="H7725"\w*.
\v 15 Délivre-moi \w du|strong="H1870"\w* sang versé, ô \w Dieu|strong="H7725"\w*, \w Dieu|strong="H7725"\w* \w de|strong="H1870"\w* \w mon|strong="H7725"\w* salut! \w Ma|strong="H7725"\w* langue chantera hautement \w ta|strong="H7725"\w* justice.
\v 16 Seigneur, ouvre \w mes|strong="H5337"\w* lèvres, \w et|strong="H6666"\w* \w ma|strong="H5337"\w* \w bouche|strong="H3956"\w* publiera \w ta|strong="H7442"\w* louange.
\v 17 Car \w tu|strong="H6310"\w* \w ne|strong="H8193"\w* prends pas plaisir \w aux|strong="H5046"\w* sacrifices, autrement j'\w en|strong="H5046"\w* donnerais; l'holocauste \w ne|strong="H8193"\w* t'\w est|strong="H6310"\w* \w point|strong="H5046"\w* agréable.
\v 18 \w Le|strong="H5414"\w* \w sacrifice|strong="H2077"\w* \w agréable|strong="H7521"\w* \w à|strong="H5414"\w* \w Dieu|strong="H3588"\w*, c'est \w un|strong="H5414"\w* esprit brisé; ô \w Dieu|strong="H3588"\w*, \w tu|strong="H3588"\w* \w ne|strong="H3808"\w* méprises \w pas|strong="H3808"\w* \w le|strong="H5414"\w* \w cœur|strong="H3808"\w* contrit \w et|strong="H3808"\w* brisé.
\v 19 \w Fais|strong="H3808"\w* \w du|strong="H3820"\w* \w bien|strong="H3820"\w* \w à|strong="H3820"\w* Sion \w dans|strong="H3808"\w* \w ta|strong="H3820"\w* bienveillance; édifie \w les|strong="H7665"\w* murs \w de|strong="H7307"\w* Jérusalem.
\v 20 Alors tu prendras plaisir \w aux|strong="H3190"\w* sacrifices \w de|strong="H2346"\w* justice, \w à|strong="H3389"\w* l'holocauste \w et|strong="H3389"\w* \w à|strong="H3389"\w* \w la|strong="H1129"\w* victime entière; alors on offrira \w de|strong="H2346"\w* jeunes taureaux \w sur|strong="H2346"\w* \w ton|strong="H1129"\w* autel.
