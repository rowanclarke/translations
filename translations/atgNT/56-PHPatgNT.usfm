\id PHP - Okphela
\h iFilipia
\toc1 iFilipia
\toc2 iFilipia
\toc3 iFili
\mt2 Ebe ni iPọlu ọ kẹkẹ ghi ẹgbọ
\mt1 IFilipia
\mt2 Eni e miesuọ
\c 1
\p 
\v 1 Mhẹmhẹ iPọlu ali iTimoti eni ẹẹ ga eyi iJesu iKirisiti anye ga khi.\f + \fr 1:1 \ft Li zẹ \fq Ika 16.12\f*
\p Mhẹmhẹ mhi kẹkẹ ebe ona a ghi ẹgbọ ni e mie iJesu iKirisiti suọ nya ni e la ekẹ iFilipi shi eni e ri ukpẹloe e khu eyi igbaa oyi eni e mie iJesu iKirisiti suọ ali eni e la aghọ ọ kpaghiẹ obọ.
\p 
\v 2 Ẹshinẹgba Ita awa ali iJesu iKirisiti Ọnọmhuẹ e ka li okhale na ẹ, e gbo ri opfọmhẹ ghi ẹ.
\p 
\v 3 Ẹghẹghẹ kpa ni mhi rọ da sato ẹ egbe ne, eri mhia kphẹmhi na Ẹshinẹgba.
\v 4 Ẹghẹghẹ kpa ni mhi rọ da a sọ iromhi na ẹ nya ne, eri oghẹlẹ ọọ la mhẹ udu ke sọ iromhi.
\v 5 Irari odẹ ni a te nu mhẹ ri oni usomhi onete kia, rọte ẹlẹ nododẹ ya ramhi amo.
\v 6 Mhi rọ shọ khi, Ẹshinẹgba ni ọ gba ikanya enete ekẹ le shi agbọ oyẹẹ, lọli ọ ya nu ẹ tsua li ramhi ẹlẹ ni iJesu iKirisiti ọ rọ ya nyenẹ egbe bhale.
\p 
\v 7 O ti ni mhi lina ke saa ingme oyẹẹ ẹghẹghẹ kpa irari khi ingme oyẹẹ o la mhẹ udu. O kha ririẹ khi ighumha mhi la, okekhi ini mhia khẹ oni usomhi onete shi ekẹ, ali ini mhia pfi ọtsẹlẹ rọ lama shi emini oni usomhi onete o riẹlẹ. Irari khi eri Ẹshinẹgba ọ ri oni afu ona ga na awa, ni awa rọ gue oni usomhi onete le.
\v 8 Ẹshinẹgba ọ khi ọtsẹlẹ ọyẹmhẹ khi igẹsikia mhia ngme ini mhiẹ khi inono ekelemhi udu ona iJesu iKirisiti mhi mhuẹ na ẹ.
\p 
\v 9 Iromhi ni mhia sọ na ẹ khi, inono ni a mhuẹ ena, o ke nga shọ, rọte ilẹsingme ali ilẹsẹ udi ingme,
\v 10 ni a rọ dobẹ ke zẹ emini o ti nẹ. Ini a pfuasẹ, ni a khi eni ẹa mhuẹ umha-guẹkia ya ramhi ẹlẹ ni iKirisiti ọ ya nyenẹ egbe bhale.
\v 11 Ni agbọ oyẹẹ o vọ ingeli ipfuasẹ ni e rọte obọ oyi iJesu iKirisiti bhale. Ni a rọ mẹ asha ri ufumhi ali ikuẹghiẹ na Ẹshinẹgba.
\s1 IKirisiti a la agbọ ọ na
\p 
\v 12 Mena, mhia nono ni a lẹsẹ khi emini mhi mẹ khi eri o kpaghiẹ obọ ti usomhi onete je odalo.
\v 13 Irarighọ, ekhe-khẹ na agbala nya e she lẹsẹ khi itobọ khi mhi khi aghiusomhi ọyi iKirisiti a rọ mu mhẹ shi owa ighumha.\f + \fr 1:13 \ft Li zẹ \fq Ika 28.30\f*
\v 14 Ọgba ighumha ni a mu mhẹ shi o she ri inyọghuo awa ebubu regbenga Ọnọmhuẹ, ni a rọ bhale ya ẹ khi e zese udu-a ẹghẹghẹ kpa rọ gue usomhi onete oyi Ẹshinẹgba le, ni o khia khi ulishi ọa mu wẹ.
\p 
\v 15 Egbegbọ lọ, khi, rọte ayẹmhẹ ubọgbọ ali ofuma, ẹgbọ eghuo e rọ ri iKirisiti ẹ tse abọ, ama eghuo é rọte udu igẹsikia rọli ẹ tse abọ.
\v 16 Eni e rọte udu igẹsikia a tse abọ, ayẹmhẹ inono e rọ ọ riẹlẹ ọli, irari khi e lẹsẹ khi itobọ ighọ Ẹshinẹgba ọ rọ rẹmhẹ shi akana ni mhi migha ke khẹ oni usomhi onete shi ekẹ.
\v 17 Elese é rọte udu arọ-timhẹnga ri iKirisiti ẹ tsabọ. Ọa khi odẹ igẹsikia e te rọli ẹ tse abọ. Eri o li wẹ egbe abinẹ khi e kha mẹ asha to ingme shi ekẹ na mhẹ abi mhi la owa ighumha ena.
\v 18 Abiabi e li ri iKirisiti tsabọ kpa, ọa mhuẹ abi o ngme. O ke khi odẹ ẹgbhọli o, o khi egbegbi odẹ oo, mhi mema ya ke ghẹlẹ shi ọ.
\p Ighọ lọ e, mhi mema ya ke ghẹlẹ shi ọ.
\v 19 Itobọ khi mhi lẹsẹ khi rọte iromhi ni a sọ, ali ikpaghiobọ ni o rọte Ayẹmhẹ oyi iJesu iKirisiti bhale, a ya rue mhẹ elemhi owa ighumha ona lasele.
\v 20 Mhi ma tọ ẹloe ekẹ, mhi gbo mhuẹ irudushi ọ khi, mhi aa ya tigbe zẹ ni akanya oyẹmhẹ o ba mhẹ ku. Ama ẹghẹghẹ kpa ali memena mhi ya ri igbedu ke ngme ni mhi ke ri ufumhi ghi iKirisiti rọte angeli oyẹmhẹ, mhi la agbọ oo, okekhi ini mhi ghua.
\v 21 Irari ini ẹ oyẹmhẹ, agbọ ni mhi la, iKirisiti mhi la ọ na. Mhi kha ghua, eleli o khi na mhẹ.
\v 22 Ama ini mhi kie la agbọ a lẹ, mhi kha kie mhọli ikanya enete ni mhi kha gbe na iKirisiti. Ama onoghuo ọ, mhi kha zẹ mena? Mhi aa lẹsẹ e!
\v 23 Udu o zẹ mhẹ eva, mhi aa lẹsẹ oni mhi ya zẹ ọ. Mhi ga nono ni mhi deba iKirisiti ni mhi lase agbọ le. Ona o ga ti mhẹ egbe nẹ.
\v 24 Ama itobọ oyẹ ẹ, o ti ni mhi la agbọ.
\v 25 Mhi lama shi ona, mhi lẹsẹ khi mhi ya la agbọ. Mhi ya nu ẹẹ nya la agbọ ni a ke je odalo, ali ni a mhọli oghẹlẹ ni o la irudunga.
\v 26 Ni a rọ bhale ya ẹ khi ini mhi nyenẹ egbe bhale gbo nu ẹ la, a ya mẹ asha ke titi egbe irari oyẹmhẹ, rọte elemhi agbọ oyẹẹ ni o kuma iJesu iKirisiti ọ.
\p 
\v 27 Abibi o riẹ li, ke ngeli abi ungmemhi oyi iKirisiti o ngme. Ni a rọ bhale ya ẹ khi, mhi bhale ya mẹ ẹ o, okekhi eri mhi suọ eko ẹ o, mhi kẹ lẹsẹ khi a kie migha egbegbọ elemhi ayẹmhẹ oghuo. A khọli okhuẹ usomhi onete elemhi ikudugbe abi ogbọ ọghuo.
\v 28 A khi zẹ ni ulishi ebe ẹ o mu ẹ, ona o ya rẹ wẹ lẹsẹ khi a ya mhuẹ eleli, ama wẹwẹ e ya pfua, irari khi Ẹshinẹgba lọli o ri imuọle na ẹ.
\v 29 Irari khi a she ri ẹghẹghẹ na ẹ ni a rọ ga iKirisiti, ni ọa khi irari khi a lẹsẹ ya miesuọ tsẹ, ama ni a rọ li ya mẹ osue na li.
\v 30 Memena, a li kuma mhẹ ọ shi oni okhọli. Oni a mẹ khi mhii khọli ẹghẹghẹ ni o dọsẹ, ni mhi kiele ẹ khọli memena.\f + \fr 1:30 \ft Li zẹ \fq Ika 16.19-40\f*
\c 2
\s1 A ke khọnya iregbe-tiemhie onabi oyi iJesu
\p 
\v 1 Agbọ oyẹẹ ni o kugbe iKirisiti ọ, o zẹ ni a rọ toto. Inono ni ọ mhuẹ na ẹ o ri udu shi ẹ ọ. Ẹẹ ali Ayẹmhẹ oyọli a mhuẹ ikugbe. A gbo mhuẹ isomhelemhi ali ilẹlemhi na egbe ẹ.
\v 2 Irarighọ, mhia nono ni a rẹmhẹ ke ghẹlẹ shi abi a mhuẹ isamhi eghuo, ni a riẹlẹ inono na egbe, a gbo khili ọghuo elemhi ayẹmhẹ ali udu.
\v 3 A khi ri ayẹmhẹ a ba timhẹ nga ali ni a ba mẹ asha ke tono obọ udu, riẹlẹ emhikhọghuo. Ama a nyẹsẹ ukhomhi na egbe. A bino khi ọgbọẹse ọ somhi dọsẹ ẹ.
\v 4 A nono onete oyi egbe ẹ, ọa khi onete oyi yẹyẹghuo tsẹ.
\p 
\v 5 Mhuẹ angeli nabi iJesu iKirisiti ọ mhuẹ.
\q1 
\v 6 Abi o riẹ khia khi
\q2 eri iKirisiti ọ li abi Ẹshinẹgba.
\q1 Ọa tigbe sa li khi
\q2 otu lọli ali Ẹshinẹgba e khi.
\q1 
\v 7 Ochoghọ, eri ọ rọte udu oyọli
\q2 rue emini ọ mhuẹ nya obọ-a,
\q2 ọ mele ọni ọọ ga ọgbọ-a.
\q1 Ọ mele ọgbọ-a,
\q2 ọ ri ẹkuẹ ọgbọ ku egbe bhale.
\q1 
\v 8 Ọ ri egbọli tiemhile,
\q2 ọ kia okiali isuesọ
\q2 ya ramhi ni ọ rọ ghua, ikhi eghuli oyọli na apfida.
\q1 
\v 9 Itobọ ona, Ẹshinẹgba ọ yasẹ ọli
\q2 nga obini o yagha nẹ nya.
\q2 Ọ ri eva ni o fu dọsẹ eva nya nali,
\q1 
\v 10 ni a rọ bhale ya ẹ khi
\q2 ashiashini a da la
\q2 lu eva oyi iJesu ne,
\q1 ikhomhẹgbhẹ nya e nyẹsẹ
\q2 ghe emhi nya ni e la idane
\q1 ali eni e la ekẹ, ali eni e la elemhi ekẹ,
\q1 
\v 11 emhi nya e ya pfi ọtsẹlẹ
\q2 khi iJesu iKirisiti ọ khi Ọnọmhuẹ,
\q1 ni a rọ ri ufumhi
\q2 na Ẹshinẹgba Ita.\f + \fr 2:11 \ft Li zẹ \fq Aza 45.23\f*
\p 
\v 12 Itobọ ighọ, emọle mhẹ, abi a liẹ suesọ ukpẹloe oyẹmhẹ a gbo lighọ ke suesọ odukhokho oyẹmhẹ. A ri ulishi ali ikpheli ke gbe ikanya, ni irudunga oyẹẹ o gba pfo.
\v 13 Itobọ khi ẹghẹghẹ kpa Ẹshinẹgba ọ rọ la ẹ egbe ẹ gbe akanya ni ọ rẹ ẹ mhuẹ ọghuẹmhẹ, ni a gbo dobẹ ke riẹlẹ emini o de shi omhẹsẹ onete oyọli.
\p 
\v 14 A khi ri awọlọ wẹ ekhakọ riẹlẹ emhikhọghuo.
\v 15 Ni a khi ẹgbọ ni ẹa mhuẹ umhaguẹkia, ni e pfuasẹ abi imi Ẹshinẹgba ni e gba pfo, elemhi agbọ ni ẹgbọ ali ena ikanya ichimhi e la. A mema la wẹ iteva ke gẹ abi ikpẹtata ni e la idane,\f + \fr 2:15 \ft Li zẹ \fq iDẹut 32.5\f*
\v 16 abi a liẹ gue ungmemhi agbọ ke yẹ wẹ. Ini a li ghọ, mhi ya mẹ asha ke rẹ ẹ titi egbe ẹlẹ ni iKirisiti ọ ya nyenẹ egbe bhale. Irari khi eri ona o ya rọkhasẹ khi irọshẹka ni mhi rọshi ali ikanya ni mhi gbe, ẹa khi afuẹ.
\p 
\v 17 Ini a tseku ku ọlia eyẹmhẹ abi onyọ shi iluasobo ali ikanya enete ni o rọte irudunga oyẹẹ lasele, eri egbe e mu mhẹ shi ọ, mhi nu ẹ ghẹlẹ.
\v 18 Irarighọ, egbe e li ke mu ẹ, a li nu mhẹ ke ghẹlẹ.
\s1 ITimoti ali Epafuroditusi
\p 
\v 19 Ini o ghọle Ẹshinẹgba, mhi khọkhọ khi mhi ya dobẹ kẹlẹ ghie iTimoti ghi ẹ. Ni mhi rọ suọ eko ẹ, ni mhi mhuẹ oghẹlẹ ini ọ jele.
\v 20 Lọlighuo kpe ọ lẹsẹ abi o li mhẹ egbe, ni ingme oyẹẹ o gbo mu egbe.
\v 21 Ẹgbọ eni e kpọle nya, eleli oyẹwẹ e na khu, ama ọa khi eleli oyi iJesu iKirisiti.
\v 22 Ama, ẹẹ, a lẹsẹ abi iTimoti ọ li ri egbọli khasẹ ẹ abi ọ la ọ shi. Abi mhẹmhẹ ali luẹ anye li kugbe gbe akanya oyi usomhi onete oyi Ẹshinẹgba abi ita ali ọmọ ẹẹ li.
\v 23 Mhi ya kẹlẹ ghie ọli ghi ẹ ini mhi da lẹsẹ abi o ya li mhẹ egbe.
\v 24 Mhi ri egbe da Ọnọmhuẹ khi mhi ya kẹlẹ bhale.
\p 
\v 25 Mhi kie gbo li khọkhọ khi o ti ni mhi ghie inyọghuo awa ghi ẹ, ikhi Epafuroditusi ni ọ she gbe akanya deba mhẹ, ni ọ she gbo nu mhẹ gbe akanya odẹ-khodẹ. Ni ọ gbo khi aghiusomhi oyẹẹ ni ọọ kpaghiẹ mhẹ obọ.
\v 26 Egbe ẹẹ kphakpha li ni ọ rọ mẹ ẹ. Egbe ẹ a ke sheshe ọli itobọ khi a suọ khi ọọ ghua.
\v 27 Egbegbọ lọ, ọọ ghua gba, ukukuọ o kpọli eghuli le. Ama Ẹshinẹgba ọ mhuẹ ilẹlemhi na li. Ọa khi lọlighuo Ẹshinẹgba ọ mhuẹ ilẹlemhi na tsẹ, ọ li mhuẹ na mhẹ, ọ tsumhi mhẹ elemhi osue ni o to-nga osoli.
\v 28 Mhẹmhẹ egbe ẹẹ kphakpha nẹ ni mhi rọ ghie ọli ghi ẹ. Ni a gbo mhuẹ oghẹlẹ ini a mẹ ọli, ni osoli oyẹmhẹ o kelea.
\v 29 A ri oghẹlẹ kpe abọ mie ọli abi inyọghuo na elemhi oni irudunga. A mu ekpẹ nofunẹ na ẹgbọ nya nabi lọli.
\v 30 Itobọ khi ọ ri agbọ oyọli shi okhẹna, ukukuọ o kpọle suii ni ọ kha rọ ghu-a shi akanya oyi iKirisiti, ini ọ mẹ asha ri ikpaghiobọ na mhẹ ni ẹẹ aa dobẹ rọna mhẹ.
\c 3
\s1 Angeli ni o migha shi ipfuasẹ
\p 
\v 1 Ni mhi rọ gbe ọli ukhomhi, inyọghuo, a ke ghẹlẹ shi abi a li kuma Ọnọmhuẹ ọ. Ọa mhuẹ abi o ngme mhẹ ini mhi riẹlẹ emini mhi kpẹ kẹkẹ ghi ẹ gbo kẹkẹ, lọli o ya ti ẹ egbe nẹ.
\p 
\v 2 A mu egbe ẹ shi ẹgbọ eghọ ni e li abi ewa, ni ẹẹ gbe ikanya ebe. Ikhi eni ẹ liẹ khi ọgbọ mema shẹlẹ-a neni imiepfuese oyọli o gba pfo.
\v 3 Anye ena, a shẹlẹ egbegbi ishẹlẹ-a, irari khi anye te odẹ ayẹmhẹ ẹ ga Ẹshinẹgba. Anye mhọli oghẹlẹ shi elemhi agbọ oyi anye khi anye kuma iJesu iKirisiti ọ, ni anye ẹa ri egbe da ikanya idiegbe.
\v 4 Ama mhẹmhẹ mhii kha ri egbe da ikanya idiegbe eghọghọ nẹ.
\p Ini àá nono ọgbọ ni ọ kha regbeda ikanya idiegbe eghọghọ lọ, mhẹmhẹ o kha khi.
\v 5 Irari khi ẹlẹ-nuzi-elele ni a rọ bia mhẹ, a rọ shẹlẹ mhẹ-a. Ọngi iZirẹni a bia mhẹ, mhi rọte unuẹkpẹ oyi iBẹjami lasele, egbegbi ọngi Iburu. Ini ẹẹ, iri ushi oyi ẹgbọ iJu gbe akanya, iFarisi mhi khi.\f + \fr 3:5 \ft Li zẹ \fq Ika 23.6; 26.5; iRom 11.1\f*
\v 6 Mhi mhuẹ ọmuegbe ramhi ni mhi rọ mu okhọli vule shi igbaa oyi eni e mie iJesu iKirisiti suọ ọ. Ini ẹẹ abi ọgbọ ọ liẹ pfuasẹ, odẹ irushi-gbe akanya, mhi aa mhuẹ ashini o kpọ mhẹ shi.\f + \fr 3:6 \ft Li zẹ \fq Ika 8.3; 22.4; 26.9-11\f*
\p 
\v 7 Ama emhi eghọghọ ni mhi kha leli shi eleli, mhi rẹwẹ shi afuẹ, itobọ oyi iKirisiti.
\v 8 Ọa khi eghọ tsẹ, mhi lama emhikpa o limhẹ opfu-a, itobọ ufumhi ni o la ilẹsẹ ni mhi lẹsẹ iJesu iKirisiti Ọnọmhuẹ oyẹmhẹ. Itobọ oyọli mhi rọ tsua emhi nya kua. Eri mhi ga bino wẹ shi iku, ni mhi mẹ asha mhuẹ iKirisiti,
\v 9 ali ni mhi ga toma li ọ pfo. Mhi aa ke mhuẹ angeli no migha shi ipfuasẹ oyẹmhẹ, angeli ipfuasẹ onabi mhi ri itobọ khi mhi ri ushi ẹ gbe akanya mhọli. Ama angeli ni o migha shi ipfuasẹ ni a rọte irudunga oyi iKirisiti rọ na mhẹ mhi ke mhọli memena, angeli ipfuasẹ ni o rọte obọ oyi Ẹshinẹgba bhale, ni o rọte irudunga bhale.
\v 10 Emini mhia nono ni mhi lolo lẹsẹ khi iKirisiti ali ekpabọ ni o rọte eghuli guise ọli le. Ni mhi rọ nu ọli mẹ osoli ni ọ mẹ, ni mhi nu ọli ghu eghuli onabi ọ ghu.
\v 11 Itobọ khi mhi mhọli ọli shi udu khi a ya li rọte eghuli guise mhẹ le.
\s1 Rọshẹka na ya ramhi ukpẹsẹ elemhi irudunga
\p 
\v 12 Mhi a liẹ khi mhi she ramhi ashini mhia nono ni mhi ramhi ne, wẹkhi eri mhi she gba pfo. Ama eri mhi rọshẹka ni mhi li abi iKirisiti. Onana o zẹ khi iKirisiti ọ pfi obọ rue mhẹ.
\v 13 Igẹsikia, inyọghuo, mhi aa bino egbemhẹ shi ọni ọ she lo owa ne. Emhi oghuo ni mhia li, khi, ni mhi rọ rue ẹloe emini e je ikhokho a, ni mhi rọshẹka ri obọ ramhi emini e la odalo.
\v 14 Irarighọ, eri mhi na lẹ talala, ni mhi rọ mhuẹ ifata, ni o khi ulumhi ni Ẹshinẹgba ọ lu mhẹ, rọte iJesu iKirisiti je agbọ ni o la iloghie.
\p 
\v 15 Awa nya ni awa mhọli iwomhẹloe shi elemhi ayẹmhẹ, awa li mhuẹ udu onana. Ama ini eghuo elemhi ẹ, e mhuẹ udu ọda shi ingme onana, Ẹshinẹgba ọ ya rọli khasẹ ẹ.
\v 16 Abibi o ya li, awa ke je odalo shi ushi oghuo ni awa deba ramhi ana.
\p 
\v 17 A ke khọnya mhẹ inyọghuo. A ri esọ shi ẹgbọ ni ẹ deba oni odẹ onete ni anye rọ shi ekẹ na ẹ.\f + \fr 3:17 \ft Li zẹ \fq 1 iKọri 4.16; 11.1\f*
\v 18 Mhi she kpẹ gueyẹ ẹ ne, mhi gbolo ri eviẹ shi alo a gueyẹ ẹ memena, khi ẹgbọ eghuo e la no khia khi uwali agbọ ni e la, o she rẹ wẹ khi ọbe oyi eghuli ni iKirisiti ọ ghu shi apfida.
\v 19 Owa erẹ ẹẹ je, irari khi ọghuẹmhẹ idiegbe oyẹwẹ o khi olitsa oyẹwẹ. Eri ẹẹ titi egbe shi emini e kha rọ shi omama. Usamhi emhi agbọ ona e lẹsẹ ẹ sa.
\v 20 Ama awa, udiokutẹ oyawa o la iloghie, awa lolo ri alo shi ekẹ ke khẹ Ọmiepfuese ikhi iJesu iKirisiti ni ọ rọte iloghie jele.
\v 21 Ọ ya ọọghiẹ idiegbe oyawa ona ni ọọ ghu, ọ ri idiegbe oyi ufumhi onabi oyọli to-ẹloli ọli. Itoto oghọ ni ọ rọ dobẹ ri emhikpa bhale omhẹsẹ oyọli ọ rọ ya riẹlẹ wẹ.
\c 4
\s1 Ungmemhi irudushọ
\p 
\v 1 Itobọ ighọ, inyọghuo, ingme oyẹẹ oo mu mhẹ egbe gba. Ẹloli ẹ, o she nga mhẹ. A ma ri egbe a mu mhẹ, mhi gbo rẹ ẹ titi egbe, ighọ o ti ni a kha li migha agbọ oyẹẹ na Ọnọmhuẹ.
\p 
\v 2 Mhi lema Euodia ali iSitaiki, a kpẹkpẹ a lama na egbe abi inyọghuo ni e mie Ọnọmhuẹ suọ.
\v 3 Ali yẹyẹ ọnuzava ọyẹmhẹ, iSizigusi, kpaghiẹ eni ikpotso ena obọ irari khi e she nu mhẹ mẹ osue shi itsabọ usomhi onete ona kia kia. Ghe iKilẹmẹti ali eni anye ga gbe akanya kugbe ali elese nekpọle, eni eva oyẹwẹ o la ebe ni a kẹkẹ eva oyi eni e ya mhọli agbọ na agbọagbọ.
\p 
\v 4 Ẹshinẹgba o zẹ ni a ke mhọli oghẹlẹ ẹghẹghẹ kpa irari khi a kugbe Ọnọmhuẹ ọ. Mhi gbolo ẹ i, a ke ghẹlẹ!
\v 5 Zẹ ni ọgbọkpa ọ ke mẹ iguẹ riẹlẹ emhi shi ẹghẹghẹ oyẹ gboo. Irari khi Ọnọmhuẹ ọ kẹlẹ ya bhale.
\p 
\v 6 A khi zẹ ni emhikhọghuo o mu ẹ egbe dọsẹ. Ama, emhikpa, a ri udu ikphẹmhi ke sọ iromhi mhila Ẹshinẹgba emini u wa nono.
\v 7 Ni opfọmhẹ oyi Ẹshinẹgba ni o dọsẹ ilẹsẹ oyi ọgbọ nya, o ri igbe udu ali ayẹmhẹ ni o migha na ẹ, irari ikugbe ni a kugbe iJesu iKirisiti ọ.
\p 
\v 8 Ni mhi rọ gbe ọli ukhomhi i, inyọghuo-mhẹ, a zẹ ni isamhi eminete ni a kuẹghiẹ ọgbọ ọ shi e vọ ẹ udu, li shi emini e khi egbegbọ, ni e mu ẹloe, ni e rọte odẹ ipfuasẹ bhale, ni e khi eyi inono, ni a mu ekpẹ shi.
\v 9 A ri emini a wẹna obọ oyẹmhẹ ali eni a mie obọ oyẹmhẹ, okekhi eni a mẹ agbọ oyẹmhẹ ke gbe akanya. Shi eni mhi ri unu ngme ali eni mhi riẹlẹ. Ẹshinẹgba ni ọ ri opfọmhẹ ẹ na ọgbọ ọ ya nu ẹ la.
\s1 IPọlu ọ tsẹ obodẹ shi isomhopfa
\p 
\v 10 Abi ọgbọ ni ọ mie Ọnọmhuẹ suọ, egbe ma mu mhẹ shi ọ gba, khi, abi o tseku tẹsẹ, khi a kie gbo mẹ asha ri inono ni a mhuẹ na mhẹ khasẹ mhẹ. Ọa ke khia khi eri mhi ri ona liẹ khi aa ke kpẹ ri ẹloe e khu mhẹ, ama eri áá ke kpẹ mẹ asha kpaghiẹ mhẹ obọ.
\v 11 Ọa khi eri mhia ngme ona irari khi o limhẹ egbe abinẹ khi a pfi mhẹ esọ-a, itobọ khi abi oni mhi mhuẹ o liẹ khuese mhẹ o she ma mhẹ-a.
\v 12 Mhi lẹsẹ abi ọọ li egbe ini ọgbọ ọ la umhamẹ ali abi ọọ li ini ọgbọ ọ la ọsuemhẹ. Mhi she wẹna osheli ona ni a rọ bhale ya ẹ khi oni mhi mhuẹ o bu mhẹ. Obiobini o khi oo, ashiashini o khi oo, mhi le khue oo, o ke khia khi okiamhi ọọ gbe mhẹ.
\v 13 Mhi dobẹ riẹlẹ emhikpa rọte itoto ni iKirisiti ọ rọ na mhẹ.
\p 
\v 14 A ma khale, abi a li kpaghiẹ mhẹ obọ abi mhi rọ la ọmunu.
\v 15 Ẹẹ ẹgbọ iFilipi, a lẹsẹ khi abi mhi rọ rọte ekẹ iMasidonia vu, ni mhi rọ lẹsẹ gba akanya itsabọ usomhi onete le, ẹẹghuo kpe a khi eni e miesuọ ni e kpaghiẹ mhẹ obọ elemhi irọna ali imẹmie.
\v 16 Ọa khi utoghuo tsẹ, a kpaghiẹ mhẹ obini ekẹ iTẹsalonika abi mhi rọ nono ikpaghiobọ.\f + \fr 4:16 \ft Li zẹ \fq Ika 17.1\f*\f + \fr 4:16 \ft Li zẹ \fq 2 iKọri 11.9\f*
\v 17 Ọa khia khi isomhopfa mhi lẹsẹ nono, ama emini a ya kẹkẹ shi ẹkuẹ oyẹ na iloghie mhia nono.
\v 18 A she fali mhẹ ota gba pfo, e gbo gba nga ọ. A she ri itsua ghi mhẹ ni e vọ mhẹ ekẹ, abi mhi rọ mie Epafuroditusi emini a rọna li ghi mhẹ ena, eri e li abi irọna ni ẹẹ kphela, ikhi iluasobo ni a mie, ni e ti Ẹshinẹgba ẹloe.\f + \fr 4:18 \ft Li zẹ \fq Okiali 29.18\f*
\v 19 Ẹshinẹgba ọyẹmhẹ ọ ya ri emini ẹ ghọle ẹ nya na ẹ. Ẹpfue ni o funẹ ni o la iJesu iKirisiti onayi ọli ọ te ya riẹlẹ ọli.
\p 
\v 20 Ufumhi o khi oyi Ẹshinẹgba Ita awa ya ramhi ẹlẹ ni agbọagbọ, Atsẹ!
\s1 Otsẹ ni o kpukhokho
\p 
\v 21 Mhia tsẹ ọgbọkpa ni ọ khi Omi Ẹshinẹgba ni ọ khi oyi iJesu iKirisiti. Inyọghuo nya ni e nu mhẹ la ana ẹẹ tsẹ ẹ.
\v 22 Ẹgbọ eyi Ẹshinẹgba ni e la ana nya ẹẹ tsẹ ẹ, ghe eni e la agbala oyi iSiza.
\p 
\v 23 Okhale oyi iJesu iKirisiti Ọnọmhuẹ o ka nu ayẹmhẹ oyẹ ẹ la. Atsẹ.
