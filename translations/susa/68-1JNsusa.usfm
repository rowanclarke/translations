\id 1JN 1 JEAN SOSO scy/cdb 2003
\h يَيَ عِ
\toc1 عَلَ شَ مَسٍنيِ سِنفٍ عَننَبِ يَيَ نَشَن سّبّ
\toc2 يَيَ عِ
\mt1 عَلَ شَ مَسٍنيِ سِنفٍ
\mt1 عَننَبِ يَيَ نَشَن سّبّ
\imt1 مَسٍنيِ ندٍ يِ كِتَابُي شَ قٍ رَ
\ip عَننَبِ يَيَ نَشَن يِ بَتَاشّ سّبّ، عَ نُ نَ عِسَ شَ شّيرَ قُ نُن قِرِنيِيٍ نَن يَ مَ. عَ نَشَ عِنيِلَ عِسَ سّبّ، عَ مَن نَشَ بَتَاشّ سَشَن سّبّ دَنشَنِيَتْييٍ بّ، عَلَكٌ عٍ شَ عَلَ شَ لْننِ نُن لِمَنِيَ سْتْ. عَ دْنشْي رَ، عَننَبِ يَيَ نَشَ كِتَابُي ندٍ سّبّ نَشَن شِلِ «عَلَ شَ وَشَيِ.» عَ نَ سّبّ عِسَيَنكَيٍ نَن مَ نَشٍيٍ نُ نَ حَشَنكَتّ سْتْقٍ عٍ شَ دَنشَنِيَ شَ قٍ رَ.
\ip يِ بَتَاشّ سِنفٍ سّبّ نّ عِسَيَنكَيٍ مَ عَلَكٌ عٍ نَشَ عٍ مَدَشُ وُلٍ شَرَنيِ رَ، نَشَن نُ يٍنسٍنشِ نَ وَشَتِ، عَ قَلَقٍ رَ عِسَ مُ نُ قَشِ دُنِحَ عَ عَدَ مَ كِ مَ. عَننَبِ يَيَ عَ مَسٍنشِ عَ عِسَ قِندِشِ عَدَ مَدِ يَتِ يَتِ نَن نَ، عَلَ نَشَن شّيشِ كٍلِقٍ كٌورٍ مَ عَ سَفٌ رَبَقٍ مَ. عِسَ قَتَنشِ عَلَ نَن نَ، كْنْ عَلَ نَشَ عَ رَفِرِ عَ شَ قِندِ شّمّ رَ دُنِحَ بّندّ قُحِ قَرِ، عَلَكٌ عَ شَ نْ عَ يّتّ بَدٍ سّرّشّ رَ عِبُنَدَ مَ بّ.
\ip عِسَ شَ سّرّشّ تِدٍ فبٌ عَدَ مَ بّ، بَرِ مَ نَ فبَنسَن نْمَ عَ نِيَدٍ عَدَ مَدِيٍ شَ كِسِ سْتْ. مِشِ نَشَن بَرَ كِسِ سْتْ عِسَ وُلِ سَابُي رَ، عَ عَ كٌلٌن عَ بْحّ كُي عَ عَ كِسِشِ عَبَدَن. سِيكّ يٌ مُ لُمَ عَ يِ رَ سْنْن، بَرِ مَ عَ عَ كٌلٌن عَلَ قَمَ نّ عَ شَ لَايِدِ رَكَمَلِدٍ.
\ip نَ سّرّشّ مَن قِندِ مَ مِسَالِ رَ دَنشَنِيَتْييٍ بّ. عَننَبِ يَيَ عَ مَسٍنمَ عَ وٌن شَ وٌن بٌرٍ شَنُ عَلْ عَلَ وٌن شَنُشِ كِ نَشّ. عَلَ وَ مَ عَ قْشِرَبِرّيٍ شَ قِندِ مِشِيٍ رَ نَشٍيٍ عٍ بٌرٍ شَنُمَ. مِشِ نَشَن عَ قَلَمَ عَ عَلَ شَنُمَ، كْنْ عَ مُ عَ بٌورٍ عِبُنَدَ مَ شَنُشِ، نَ كَنيِ بَرَ قِندِ وُلٍ قَلّ رَ.
\ip عَلَ كٌلٌنقٍ مُنَقَنيِ فبٌ عَدَ مَ بّ. نَ نْمَ عَ نِيَدٍ عَ شَ عَرِيَننَ سْتْ يَرٍ، عَ مَن شَ دُنِحّءِفِرِ قَنيِ سْتْ بٍ. عَلَ شَ وٌن مَلِ عَ شَ شَنُنتٍيَ كٌلٌنقٍ رَ، عَلَكٌ وٌن شَ كِسِ سْتْ، وٌن مَن شَ قِندِ مِشِيٍ رَ نَشٍيٍ عٍ بٌرٍ شَنُشِ. عَمِنَ.
\mt1 عَلَ شَ مَسٍنيِ سِنفٍ
\mt1 عَننَبِ يَيَ نَشَن سّبّ
\cl سٌرَ
\c 1
\s1 كِسِ مَسٍنيِ
\q1 
\v 1 كِسِ مَسٍنيِ،
\q1 نَشَن نُ نَ كَبِ عَ قْلّ،
\q1 مُشُ تُلِ نَشَن مّشِ،
\q1 مُشُ يَ نَشَن تٌشِ،
\q1 مُشُ بّلّشّ نَشَن مَسُشُشِ،
\q1 مُشُ بَرَ نَ سٍيدٍ بَ.
\q1 
\v 2 نَشَن نَ كِسِ رَ، نَ بَرَ عَ يّتّ مَسٍن.
\q1 مُشُ بَرَ عَ تٌ،
\q1 مُشُ بَرَ نَ كِسِ شَ قٍ كَوَندِ تِ،
\q1 نَشَن مُ حْنمَ عَبَدَن،
\q1 نَشَن نُ نَ بَبَ عَلَ قّ مَ،
\q1 بٍينُن عَ شَ عَ يّتّ مَسٍن مُشُ بّ.
\q1 
\v 3 مُشُ نَشَن تٌشِ،
\q1 مُشُ نَشَن مّشِ،
\q1 مُشُ وٌ قَن كَوَندِقٍ نَ نَن نَ،
\q1 عَلَكٌ وٌن بِرِن شَ لُ لَنيِ كُي،
\q1 وٌن نُن بَبَ عَلَ نُن عَ شَ دِ عِسَ، عَ شَ مِشِ سُفَندِشِ.
\q1 
\v 4 مُشُ يِ قٍ سّبّقٍ نّ وٌ مَ،
\q1 عَلَكٌ مُشُ شَ سّيوّ شَ كَمَلِ.
\p 
\v 5 مُشُ نَشَن مّشِ عِسَ رَ، مُشُ شَ نَ دّنتّفّ سَ وٌ بّ. عَلَ قِندِشِ نَءِيَلَنيِ نَن نَ. دِ مِ يٌ مُ نَ عَ عِ.
\v 6 شَ وٌن عَ قَلَ وٌن نُن عَلَ نَ عَ رَ، كْنْ وٌن حّرّ مَ دِ مِ كُي، وٌن بَرَ وُلٍ قَلَ، وٌن مُ حّرّقٍ نْندِ كِرَ شْن مَ.
\v 7 كْنْ، شَ وٌن حّرّ مَ نَءِيَلَنيِ كُي عَلَ شَ كِرَ شْن، وٌن نُن دَنشَنِيَتْييٍ نَن لُمَ لَنيِ كُي. عَلَ شَ دِ عِسَ وُلِ نَن وٌن نَسّنِيّنمَ يُنُبِ بِرِن مَ.
\p 
\v 8 شَ وٌن عَ قَلَ يُنُبِ يٌ مُ نَ وٌن مَ، وٌن بَرَ وٌن يّتّ مَدَشُ، نْندِ يٌ مُ نَ وٌن بّ.
\v 9 شَ وٌن نَ وٌن تِ وٌن مَ يُنُبِيٍ رَ، عَلَ عٍ شَقَرِ مَ نّ، عَ وٌن نَسّنِيّن وٌن مَ تِنشِنتَرٍيَ مَ. عَلَ تِنشِن، وٌن نْمَ وٌن شَشِلِ تِدٍ عَ رَ.
\v 10 شَ وٌن عَ قَلَ يُنُبِ يٌ مُ نَ وٌن مَ، وٌن بَرَ عَلَ قِندِ وُلٍ قَلّ رَ، عَ شَ مَسٍنيِ مُ نَ وٌن بْحّ كُي.
\c 2
\s1 وٌن شُنمَقَلَمَ
\p 
\v 1 ﭑ مَ دِيٍ، ﭑ بَرَ نَ بِرِن سّبّ وٌ مَ، عَلَكٌ وٌ نَشَ يُنُبِ رَبَ، كْنْ شَ عَ سَ لِ مِشِ ندٍ نَشَ بِرَ نَ كُي، عَلَ شَ مِشِ سُفَندِشِ عِسَ قَمَ وٌن شُنمَقَلَدٍ بَبَ عَلَ بّ. عِسَ تِنشِن.
\v 2 عَ تَن نَن قِندِشِ سّرّشّ رَ وٌن مَ يُنُبِيٍ شَقَرِقٍ رَ. عَ مُ وٌن مَ يُنُبِيٍ فبَنسَن شَقَرِشِ، عَ نَ نَن نَبَشِ دُنِحَ مِشِ بِرِن بّ.
\p 
\v 3 شَ وٌن سَ عَلَ شَ يَامَرِيٍ رَبَتُ، نَ نَن عَ مَسٍنمَ عَ وٌن عَلَ كٌلٌن.
\v 4 شَ مِشِ ندٍ عَ قَلَ، «ﭑ تَن عَلَ كٌلٌن»، كْنْ عَ مُ عَ شَ يَامَرِيٍ رَبَتُمَ، وُلٍ قَلّ نَن عَ رَ، نْندِ مُ نَ عَ بّ.
\v 5 كْنْ مِشِ نَشَن عَلَ شُي سُشُمَ، عَلَ شَ شَنُنتٍيَ بَرَ فّ كَمَلِدٍ نَ كَنيِ بّ. نَ كُي، وٌن نْمَ عَ كٌلٌندٍ وٌن نَ عَلَ قْشْ رَ.
\v 6 نَشَن يٌ عَ قَلَمَ عَ نُن عَلَ نَن عَ رَ، عَ لَنمَ عَ شَ عَ حّرّ عِسَ شَ كِرَ شْن.
\p 
\v 7 ﭑ شَنُنتٍنيِيٍ، ﭑ يَامَرِ نَشَن مَسٍنمَ وٌ بّ، قٍ نّينّ مُ عَ رَ. وٌ عَ كٌلٌن كَبِ عَ قْلّ. يَامَرِ قٌرِ نَن عَ رَ، وٌ نَشَن سِنفٍ مّ نُ.
\v 8 كْنْ عِ مَن نَ مَتٌ ﭑ يَامَرِ نّينّ نَن سّبّقٍ وٌ مَ. نْندِ نَن عَ رَ نَشَن مَكّنّنشِ عِسَ حّرّ كِ كُي عَ نُن وٌ تَن قَن حّرّ كِ كُي، بَرِ مَ دِ مِ نَ حْنقٍ، عَلَ شَ نَءِيَلَنيِ لَشِشّ بَرَ مِنِ قْلْ.
\p 
\v 9 نَشَن عَ قَلَمَ عَ عَ نَ عَلَ شَ نَءِيَلَنيِ كُي، كْنْ عَ عَ نفَشَكٍرٍنيِ شْنشِ، نَ كَنيِ مَن نَ دِ مِ نَن كُي.
\v 10 نَشَن عَ نفَشَكٍرٍنيِ شَنُمَ، نَ كَنيِ سَبَتِشِ عَلَ شَ نَءِيَلَنيِ نَن كُي، قٍقٍ مُ نَ نَشَن عَ رَبِرَ مَ.
\v 11 كْنْ نَشَن عَ نفَشَكٍرٍنيِ شْنمَ، نَ كَنيِ نَ دِ مِ نَن كُي. عَ حّرّ مَ دِ مِ نَن كُي، عَ مُ عَ سِفَدٍ يَتِ تٌمَ، بَرِ مَ دِ مِ بَرَ عَ يَ دْنشُ.
\q1 
\v 12 ﭑ مَ دِيٍ، ﭑ شَ عَ مَسٍن وٌ بّ يِ سّبّلِ رَ؛
\q1 وٌ شَ يُنُبِيٍ بَرَ شَقَرِ عِسَ شِلِ سَابُي رَ.
\q1 
\v 13 قٌرِيٍ، ﭑ شَ عَ مَسٍن وٌ بّ يِ سّبّلِ رَ؛
\q1 وٌ بَرَ عَ كٌلٌن عَ تَن نَشَن نُ نَ كَبِ عَ قْلّ.
\q1 قٌنِكٍيٍ، ﭑ شَ عَ مَسٍن وٌ بّ يِ سّبّلِ رَ؛ وٌ بَرَ نْ سٍنتَنّ رَ.
\q1 
\v 14 ﭑ مَ دِيٍ، ﭑ بَرَ نَ مَسٍن وٌ بّ يِ سّبّلِ رَ،
\q1 بَرِ مَ وٌ بَرَ بَبَ عَلَ كٌلٌن.
\q1 قٌرِيٍ، ﭑ بَرَ نَ مَسٍن وٌ بّ يِ سّبّلِ رَ،
\q1 بَرِ مَ وٌ عَ كٌلٌن نَشَن نَ نَ كَبِ عَ قْلّ.
\p قٌنِكٍيٍ، ﭑ بَرَ نَ مَسٍن وٌ بّ يِ سّبّلِ رَ؛
\q1 بَرِ مَ وٌ سّنبّ فبٌ.
\q1 عَلَ شَ مَسٍنيِ سَبَتِشِ وٌ بْحّ كُي.
\q1 وٌ بَرَ نْي سْتْ سٍنتَنّ شُن مَ.
\p 
\v 15 وٌ نَشَ دُنِحَ قٍ شَنُ، شَ نَ مُ عَ رَ وٌ مُ نْمَ بَبَ عَلَ شَنُدٍ.
\v 16 نَشَن قِندِشِ دُنِحَ قٍ رَ، عَلْ عِبُنَدَ مَ وَشْنقٍ كٌبِ، مِلّ، نُن يّتّ عِفبٌحَ نَشَن كٍلِشِ سٍيٍ سْتْقٍ مَ، نَ سٍسٍ مُ كٍلِشِ بَبَ عَلَ مَ. عَ كٍلِشِ يِ دُنِحَ نَن مَ.
\v 17 دُنِحَ نُن عَ وَشْنقٍ حْنمَ نّ، كْنْ نَشٍيٍ عَلَ وَشْنقٍ رَبَمَ، عٍ كِسِمَ نّ عَبَدَن.
\s1 عَلَ شَ مِشِ سُفَندِشِ يَشُي
\p 
\v 18 ﭑ مَ دِيٍ، وٌن نَ وَشَتِ دْنشْي نّ يِ كِ. وٌ بَرَ عَ مّ، عَ عَلَ شَ مِشِ سُفَندِشِ يَشُي ندٍ نَ قَقٍ. وٌ بَرَ عَ كٌلٌن عَ يَشُي فبٍفبٍ بَرَ قَ. وٌن عَ كٌلٌن نَ نَن مَ عَ وٌن نَ وَشَتِ دْنشْي نّ يِ كِ.
\v 19 نَ مِشِيٍ كٍلِشِ وٌن تَن نَن شُن مَ، كْنْ وٌن نفَشَكٍرٍنيِ مُ نُ عٍ رَ، شَ نَ مُ عَ رَ عٍ مُ نُ كٍلِمَ وٌن شُن مَ نُ. كْنْ عٍ تٌ مُ تِن لُدٍ وٌن يَ مَ، عٍ بَرَ عَ مَسٍن عَ وٌن نفَشَكٍرٍنيِيٍ مُ نُ عٍ رَ.
\p 
\v 20 عَلَ شَ سّنِيّنتْي بَرَ وٌ سُفَندِ، عَ شَشِلِ سّنِيّنشِ قِ وٌ مَ. نَ نَن عَ تٌشِ وٌ بِرِن نْندِ كٌلٌنشِ.
\v 21 ﭑ مُ يِ بَتَاشّ سّبّشِ وٌ مَ وٌ شَ نْندِ كٌلٌنتَرٍيَ شَ مَ. ﭑ عَ سّبّشِ وٌ شَ نْندِ كٌلٌنيِ شَ قٍ نَن مَ، وُلٍ يٌ مُ نَ نَشَن كُي.
\p 
\v 22 وُلٍ قَلّ نَ ندٍ رَ؟ نَشَن عَ قَلَمَ عَ عِسَ مُ قِندِشِ عَلَ شَ مِشِ سُفَندِشِ رَ. نَ كَنيِ بَرَ قِندِ عَلَ شَ مِشِ سُفَندِشِ يَشُي رَ. عَ بَرَ تٌندِ بَبَ عَلَ نُن عَ شَ دِ رَ.
\v 23 مِشِ نَشَن تٌندِ مَ عَلَ شَ دِ رَ، عَ بَرَ تٌندِ بَبَ عَلَ قَن نَ. نَشَن بَرَ تِن عَلَ شَ دِ رَ، عَ بَرَ تِن بَبَ عَلَ قَن نَ.
\p 
\v 24 وٌ مَسٍنيِ نَشَن مّ عَ قْلّ، وٌ شَ نَ رَفَتَ وٌ بْحّ مَ. شَ عَ نَ نَ كِ نّ، عَ لِمَ وٌ بَرَ سَبَتِ بَبَ عَلَ شَ دِ نُن بَبَ عَلَ عِ.
\v 25 عَلَ شَ مِشِ سُفَندِشِ بَرَ كِسِ لَايِدِ تٌنفٌ وٌن بّ، كِسِ نَشَن مُ حْنمَ عَبَدَن.
\p 
\v 26 ﭑ بَرَ يِ بَتَاشّ سّبّ وٌ مَ مِشِ ندٍيٍ نَن مَ قٍ رَ نَشٍيٍ وَ مَ وٌ مَدَشُقٍ.
\v 27 عَلَ بَرَ عَ شَشِلِ قِ وٌ مَ، عَ نَ وٌ بْحّ عِ. وٌ هَيِ مُ نَ كَرَ مْشْ فبّتّ مَ. عَلَ شَشِلِ نَن وٌ مَتِنكَنمَ نْندِ بِرِن نَ. وُلٍ يٌ مُ نَ عَ شَ مَسٍنيِ كُي. وٌ شَ بِرَ عَ قْشْ رَ تُن.
\p 
\v 28 ﭑ مَ دِيٍ، وٌ نُن عِسَ شَ لُ عَ رَ، عَلَكٌ عَ نَ فبِلٍن تّمُي نَشّ يَافِ يٌ نَشَ وٌن مَكُيَ عَ رَ. وٌن شَ لَ عَ رَ تّمُي بِرِن.
\v 29 وٌ تٌ عَ كٌلٌن عَ تِنشِن، وٌ شَ عَ كٌلٌن قَن عَ تِنشِنتْي بِرِن قَتَنشِ عَ تَن نَن نَ.
\c 3
\s1 عَلَ شَ دِيٍ
\p 
\v 1 وٌ شَ عَ كٌلٌن، بَبَ عَلَ وٌن شَنُشِ نّ هَن عَ وٌن شِلِ «عَ شَ دِيٍ». وٌن قِندِشِ عَ شَ دِيٍ يَتِ يَتِ نَن نَ. دُنِحَ مُ نْمَ وٌن كٌلٌندٍ نَ رَ، بَرِ مَ عٍ مُ عَلَ كٌلٌن.
\v 2 ﭑ شَنُنتٍنيِيٍ، يَكْسِ عَلَ شَ دِيٍ نَن وٌن نَ. عَ مُ مَسٍنشِ سِندٍن وٌن لُمَ كِ نَشّ، كْنْ وٌن عَ كٌلٌن، عَ عِسَ نَ قَ، وٌن مَسَرَ مَ نّ، وٌن قَ لُ عَلْ عَ تَن، بَرِ مَ وٌن عَ تٌمَ نّ عَ نَ كِ نَشّ يَتِ.
\v 3 مِشِ نَشَن عَ يِفِ تِشِ عِسَ رَ، عَ عَ يّتّ رَ سّنِيّنمَ، عَلْ عِسَ سّنِيّنشِ كِ نَشّ.
\p 
\v 4 مِشِ نَشَن يُنُبِ رَبَمَ، عَ قِندِشِ سّرِيّ مَتَندِلَ نَن نَ، بَرِ مَ يُنُبِ، سّرِيّ مَتَندِ نَن عَ رَ.
\v 5 وٌ عَ كٌلٌن عَ عِسَ قَ وٌن مَ يُنُبِ نَن شَقَرِدٍ. يُنُبِ يٌ مُ نُ نَ عَ تَن مَ.
\v 6 مِشِ نَشَن سَبَتِشِ عِسَ عِ، نَ كَنيِ مُ لُمَ يُنُبِ رَبَ رَ سْنْن. نَشَن لُمَ يُنُبِ رَبَ رَ، نَ كَنيِ مُ عِسَ تٌشِ، عَ مَن مُ عَ كٌلٌن.
\p 
\v 7 ﭑ مَ دِيٍ، مِشِ يٌ نَشَ وٌ مَدَشُ. مِشِ نَشَن تِنشِنيِ رَبَمَ، عَ تِنشِن عَلْ مَرِفِ تِنشِنشِ كِ نَشّ.
\v 8 يُنُبِتْي تَن قَتَنشِ عِبُلِسَ نَن نَ، بَرِ مَ عِبُلِسَ نَن يُنُبِ رَبَ كَبِ دُنِحَ قْلّ. عَلَ شَ دِ قَ نّ عَلَكٌ عَ شَ عِبُلِسَ شَ وَلِ كَنَ.
\p 
\v 9 مِشِ يٌ قِندِ عَلَ شَ دِ رَ، عَ مُ لُمَ يُنُبِ رَبَ رَ، بَرِ مَ عَلَ بَرَ وَلِ ندٍ قْلْ عَ بْحّ كُي. عَ مُ نْمَ لُدٍ يُنُبِ كُي، بَرِ مَ عَ قَتَنشِ عَلَ نَن نَ.
\v 10 عَلَ شَ دِيٍ نُن عِبُلِسَ شَ دِيٍ تَفِ رَ سَمَ يِ كِ نّ؛ نَشَن مُ تِنشِن، عَلَ شَ دِ مُ عَ رَ. نَشَن مُ عَ بٌورٍ عَدَ مَدِيٍ شَنُمَ، عَ مُ عَلَ كٌلٌن.
\s1 شَنُنتٍيَ
\p 
\v 11 مَسٍنيِ نَن يَ وٌ نَشَن مّشِ كَبِ عَ قْلّ؛ وٌن شَ وٌن بٌرٍ شَنُ.
\v 12 وٌن نَشَ لُ عَلْ كَبِلَ، نَشَن قَتَن سٍنتَنّ رَ، عَ قَ عَ شُنيَ يَتِ قَشَ. عَ نَ رَبَ مُنقٍ رَ؟ عَ نَ رَبَ نّ بَرِ مَ عَ حّرّ كِ مُ نُ فّشِ تِنشِندٍ عَلْ عَ شُنيَ حّرّ كِ.
\p 
\v 13 ﭑ نفَشَكٍرٍنيِيٍ، وٌ نَشَ وٌ مَحِن دُنِحَ شَ شْننَنتٍيَ شَ قٍ رَ وٌ مَبِرِ.
\v 14 شَنُنتٍيَ نَشَن لُمَ وٌن بْحّ كُي وٌن بٌورٍ عَدَ مَدِيٍ بّ، عَ عَ مَسٍنمَ عَ وٌن بَرَ قَشّ كِرَ لُ نَ، وٌن تِ كِسِ كِرَ شْن مَ. شَنُنتٍيَتَرٍ تَن تِشِ قَشّ كِرَ نَن شْن مَ.
\v 15 مِشِ نَشَن عَ بٌورٍ عَدَ مَدِ شْنمَ، نَ كَنيِ لُشِ نّ عَلْ قَشّتِ. وٌ عَ كٌلٌن عَ كِسِ مُ نَ قَشّتِ بّ.
\p 
\v 16 وٌن شَنُنتٍيَ كٌلٌنمَ عَلَ شَ مِشِ سُفَندِشِ عِسَ شَ مِسَالِ نَن سَابُي رَ، نَشَن تِنشِ عَ نِي قِدٍ وٌن بّ. وٌن قَن لَن نّ وٌن شَ تِن نَ رَبَدٍ وٌن بٌورٍ عَدَ مَدِيٍ بّ.
\v 17 سٍ كَنيِ نَشَن عَ بْحّ بَلَنمَ تْورْ مِشِ يَ رَ، عَ مُ عَلَ شَ شَنُنتٍيَ كٌلٌن.
\v 18 ﭑ مَ دِيٍ، وٌن مَ شَنُنتٍيَ نَشَ قِندِ وْيّنيِ تُن نَ، عَ شَ قِندِ مَرَبَ نَن نَ، شَ نَ مُ عَ رَ نْندِ يٌ مُ نَ عَ كُي.
\p 
\v 19 نَ كُي، وٌن نْمَ عَ كٌلٌندٍ عَ نْندِ نَ وٌن يِ، وٌن بْحّ قَ سَ عَلَ مَبِرِ.
\v 20 هَلِ وٌن بْحّ سَ وٌن مَكِيتِ، عَلَ فبٌ وٌن بْحّ بّ، عَ قٍ بِرِن كٌلٌن.
\v 21 ﭑ شَنُنتٍنيِيٍ، شَ وٌن بْحّ مُ وٌن مَكِيتِ، وٌن بَرَ شَشِلِسَ سْتْ عَلَ يَ عِ.
\v 22 عَلَ وٌن مَ دُبَ بِرِن سُشُمَ نّ، بَرِ مَ وٌن بِرَ مَ عَ شَ سّرِيّيٍ نُن عَ وَشْنقٍ نَن قْشْ رَ.
\p 
\v 23 عَ شَ سّرِيّ نَن يَ؛ وٌن شَ دَنشَنِيَ عَ شَ دِ مَ، عَ شَ مِشِ سُفَندِشِ عِسَ. وٌن مَن شَ وٌن بٌرٍ شَنُ، عَلْ عَلَ وٌن يَمَرِشِ كِ نَشّ.
\v 24 مِشِ نَشَن عَلَ شَ سّرِيّ رَبَتُمَ، نَ كَنيِ نُن عَلَ نَ عَ رَ. عَ عَ كٌلٌنمَ عَلَ شَشِلِ سّنِيّنشِ نَن مَ، عَلَ نَشَن قِشِ وٌن مَ.
\c 4
\s1 تَفِ رَ سَ عَلَ شَشِلِ نُن سٍنتَنّ شَشِلِ
\p 
\v 1 ﭑ شَنُنتٍنيِيٍ، وٌ نَشَ لَ شَشِلِ بِرِن نَ. وٌ شَ عَ مَتٌ عَ قَنيِ رَ شَ نَ شَشِلِ قَتَنشِ عَلَ نَن نَ، بَرِ مَ وُلٍ قَلّيٍ بَرَ فبٌ دُنِحَ نَشٍيٍ عٍ يّتّ قِندِشِ نَمِحْنمّيٍ رَ.
\v 2 مِشِ نَشَن بِرِن لَشِ عَ رَ عَ عَلَ شَ مِشِ سُفَندِشِ عِسَ بَرَ قَ دُنِحَ مَ عَ عَدَ مَ كِ مَ، وٌ نْمَ نّ عَ كٌلٌندٍ عَ نَ كَنيِ تَن شَشِلِ قَتَنشِ عَلَ نَن نَ.
\v 3 كْنْ مِشِ نَشَن بِرِن مُ لَشِ عِسَ رَ، نَ فبٍ شَشِلِ مُ قَتَنشِ عَلَ رَ، عَ قَتَنشِ عَلَ شَ مِشِ سُفَندِشِ يَشُي نَن نَ، وٌ بَرَ نَشَن مَ قٍ مّ، عَ عَ نَ قَقٍ دُنِحَ مَ. ﭑ شَ عَ قَلَ وٌ بّ، عَ حَن بَرَ قَ.
\p 
\v 4 ﭑ مَ دِيٍ، وٌ تَن، عَلَ نَن فبٍ وٌ رَ. وٌ بَرَ نْ نَ نَمِحْنمّ وُلٍ قَلّيٍ رَ، بَرِ مَ عَلَ شَشِلِ نَشَن نَ وٌ قْشْ رَ، نَ سّنبّ فبٌ سٍنتَنّ شَشِلِ بّ نَشَن نَ دُنِحَ مِشِيٍ قْشْ رَ.
\v 5 عٍ تَن دُنِحَ نَن فبٍ عٍ رَ. نَ نَن عَ رَ عٍ وْيّنمَ دُنِحَ كِ مَ، دُنِحَ قَ عٍ شُي سُشُ.
\v 6 كْنْ وٌن تَن، عَلَ نَن فبٍ وٌن نَ. نَ نَن عَ رَ عَلَ كٌلٌنيِيٍ وٌن شُي سُشُمَ. عَلَ كٌلٌنتَرٍيٍ تَن مُ وٌن شُي سُشُمَ. نْندِ شَشِلِ نُن وُلٍ شَشِلِ تَفِ رَ سَمَ نَ كِ نّ.
\s1 شَنُنتٍيَ قَتَنمَ عَلَ نَن نَ
\q1 
\v 7 ﭑ شَنُنتٍنيِيٍ، وٌن شَ وٌن بٌرٍ شَنُ،
\q1 بَرِ مَ شَنُنتٍيَ قَتَنشِ عَلَ نَن نَ.
\q1 مِشِ نَشَن عَ بٌورٍ عَدَ مَدِ شَنُمَ،
\q1 نَ بَرَ قِندِ عَلَ شَ دِ رَ، عَ عَلَ كٌلٌن.
\q1 
\v 8 مِشِ نَشَن مُ عَ بٌورٍ عَدَ مَدِ شَنُمَ،
\q1 نَ كَنيِ مُ عَلَ كٌلٌن،
\q1 بَرِ مَ عَلَ، شَنُنتٍيَ نَن عَ رَ.
\q1 
\v 9 عَلَ شَ شَنُنتٍيَ كٌلٌنمَ يِ نَن مَ؛
\q1 عَلَ نَشَ عَ شَ دِ كٍرٍنيِ شّي دُنِحَ،
\q1 عَلَكٌ وٌن شَ كِسِ عَ تَن سَابُي رَ.
\q1 
\v 10 شَنُنتٍيَ يَتِ يَتِ نَن يَ؛
\q1 وٌن تَن شَ مُ عَلَ شَنُشِ،
\q1 عَ تَن نَن وٌن شَنُشِ،
\q1 عَ قَ عَ شَ دِ كٍرٍنيِ شّي
\q1 عَ شَ قِندِ وٌن مَ يُنُبِ شَقَرِ سّرّشّ رَ.
\p 
\v 11 ﭑ شَنُنتٍنيِيٍ، عَلَ تٌ بَرَ وٌن شَنُ نَ كِ، وٌن قَن لَن نّ وٌن شَ وٌن بٌرٍ شَنُ.
\v 12 مِشِ يٌ مُ نَ نَشَن عَلَ تٌشِ، كْنْ شَ وٌن وٌن بٌرٍ شَنُ، عَلَ لُمَ نّ وٌن عِ. عَ شَ شَنُنتٍيَ كَمَلِمَ نّ وٌن عِ.
\p 
\v 13 وٌن عَ كٌلٌن وٌن نُن عَلَ نَ عَ رَ، بَرِ مَ عَ بَرَ عَ شَشِلِ قِ وٌن مَ.
\v 14 مُشُ تَن بَرَ عَ تٌ، مُشُ بَرَ قِندِ سٍيدٍ رَ، عَ بَبَ عَلَ عَ شَ دِ شّي نّ دُنِحَ مَ عَدَ مَدِيٍ رَكِسِدٍ.
\v 15 مِشِ نَشَن عَ قَلَمَ عَ عِسَ قِندِشِ عَلَ شَ دِ نَن نَ، نَ كَنيِ نُن عَلَ نَ عَ رَ.
\v 16 وٌن بَرَ عَلَ شَ شَنُنتٍيَ كٌلٌن، وٌن بَرَ لَ عَ رَ. عَلَ قِندِشِ شَنُنتٍيَ نَن نَ. مِشِ نَشَن حّرّ مَ شَنُنتٍيَ كُي، نَ كَنيِ نُن عَلَ نَ عَ رَ.
\p 
\v 17 نَ كُي، شَنُنتٍيَ بَرَ كَمَلِ وٌن تَفِ، عَلَكٌ فَاشُي نَشَ لُ وٌن يِ رَ كِيتِسَ لْشْي، بَرِ مَ وٌن بِرَ مَ عِسَ شَ مِسَالِ قْشْ رَ يِ دُنِحَ بّندّ قُحِ قَرِ.
\v 18 فَاشُي مُ لُمَ شَنُنتٍنيِيٍ تَفِ شَ عٍ شَ شَنُنتٍيَ بَرَ كَمَلِ. مِشِ فَاشُمَ حَشَنكَتّ نَن شَ قٍ رَ، كْنْ شَنُنتٍيَ كَمَلِشِ كَنيِ مُ فَاشُمَ.
\v 19 وٌن نْمَ مِشِ شَنُدٍ، بَرِ مَ عَلَ سِنفٍ نَن بَرَ وٌن شَنُ.
\v 20 مِشِ نَشَن عَ قَلَمَ عَ عَلَ شَنُشِ، كْنْ عَ لُمَ مِشِ شْن نَ، نَ كَنيِ بَرَ قِندِ وُلٍ قَلّ رَ. مِشِ نَشَن مُ قَتَ عَ بٌورٍ عَدَ مَدِ شَنُدٍ عَ نَشَن تٌمَ، نَ مُ نْمَ عَلَ شَنُدٍ عَ مُ نَشَن تٌشِ.
\v 21 عَلَ وٌن يَمَرِشِ يِ نَن نَ؛ نَشَن عَلَ شَنُشِ، عَ شَ نُ عَ بٌورٍ عَدَ مَدِ قَن شَنُ.
\c 5
\s1 دَنشَنِيَقٍ عَلَ شَ دِ مَ
\p 
\v 1 مِشِ نَشَن لَمَ عَ رَ عَ عِسَ نَن قِندِشِ عَلَ شَ مِشِ سُفَندِشِ رَ، نَ كَنيِ بَرَ قِندِ عَلَ شَ دِ رَ. نَشَن بَبّ ندٍ شَنُمَ، عَ نَ بَبّ شَ دِ قَن شَنُمَ نّ.
\v 2 وٌن نَ عَلَ شَنُ، وٌن قَ عَ شَ يَامَرِ بِرِن نَبَتُ، نَ نَن عَ مَسٍنمَ عَ وٌن عَلَ شَ دِيٍ قَن شَنُمَ.
\v 3 عَلَ شَنُقٍ عَ نِيَمَ وٌن شَ عَ شَ يَامَرِيٍ قَن نَبَتُ. نَ مُ قِندِ مَ كٌتٍ شْرْشْي رَ،
\v 4 بَرِ مَ عَلَ شَ دِيٍ نْمَ دُنِحَ بِرِن نَ عٍ شَ دَنشَنِيَ سَابُي رَ.
\v 5 ندٍ شُننَكٍلِ سْتْمَ دُنِحَ شُن نَ، شَ دَنشَنِيَتْي مُ عَ رَ، نَشَن لَمَ عَ رَ عَ عَلَ شَ دِ نَن عِسَ رَ؟
\p 
\v 6 عَلَ شَ مِشِ سُفَندِشِ عِسَ نَن قَ يٍ نُن وُلِ رَ. عَ مُ قَشِ يٍ فبَنسَن شَ رَ، عَ قَشِ يٍ نُن وُلِ نَن نَ. عَلَ شَشِلِ نَن نَ سٍيدٍ بَشِ، بَرِ مَ عَلَ شَشِلِ نْندِ نَن عَ رَ.
\v 7 سٍيدٍ سَشَن نَن نَ؛
\v 8 عَلَ شَشِلِ سّنِيّنشِ، يٍ، نُن وُلِ. نَ سَشَنيِ بِرِن سٍيدٍحْشْيَ كٍرٍن نَن بَمَ.
\v 9 وٌن تِنمَ مِشِيٍ شَ سٍيدٍحْشْيَ رَ، كْنْ عَلَ شَ سٍيدٍحْشْيَ دَنفِ نَ بِرِن نَ. عَلَ نَن سٍيدٍ بَمَ عَ شَ دِ شَ قٍ رَ.
\v 10 مِشِ نَشَن لَمَ عَلَ شَ سٍيدٍحْشْيَ رَ، نَ كَنيِ دَنشَنِيَمَ عَلَ شَ دِ مَ، كْنْ مِشِ نَشَن مُ لَمَ عَلَ رَ، نَ كَنيِ بَرَ عَلَ قِندِ وُلٍ قَلّ رَ، بَرِ مَ عَ مُ لَشِ عَلَ شَ سٍيدٍحْشْيَ رَ، عَ نَشَن بَشِ عَ شَ دِ شَ قٍ رَ.
\v 11 نَ سٍيدٍحْشْيَ عَ مَسٍنمَ عَ عَلَ كِسِ قِشِ وٌن مَ عَ شَ دِ نَن سَابُي رَ. نَ كِسِ مُ حْنمَ عَبَدَن.
\v 12 مِشِ نَشَن بِرَ مَ عَلَ شَ دِ قْشْ رَ، نَ كَنيِ بَرَ كِسِ، كْنْ مِشِ نَشَن مُ بِرَ مَ عَلَ شَ دِ قْشْ رَ، نَ كَنيِ مُ كِسِمَ.
\p 
\v 13 ﭑ بَرَ يِ قٍ بِرِن سّبّ وٌ مَ، وٌ تَن نَشٍيٍ دَنشَنِيَشِ عَلَ شَ دِ مَ، عَلَكٌ وٌ شَ عَ كٌلٌن عَ وٌ بَرَ كِسِ سْتْ، نَشَن مُ حْنمَ عَبَدَن.
\v 14 وٌن مَ لَنلَنتٍيَ نَ عَ مَ كِ نَشّ، وٌن بَرَ عَ كٌلٌن عَ وٌن مَ دُبَ بِرِن سُشُمَ نّ نَشَن قِندِشِ عَ وَشْنقٍ رَ.
\v 15 وٌن تٌ عَ كٌلٌن عَ وٌن مَ مَشَندِ بِرِن مّمَ، وٌن مَن عَ كٌلٌن عَ عَلَ وٌن مَ دُبَ بِرِن سُشُمَ نّ.
\p 
\v 16 مِشِ نَشَن عَ بٌورٍ ندٍ تٌمَ يُنُبِ رَبَ رَ، يُنُبِ نَشَن مُ مِشِ بْنْمَ عَبَدَن، عَ شَ عَلَ مَشَندِ عَ بّ. عَلَ عَ رَكِسِمَ نّ شَ يُنُبِ نَ عَ رَ نَشَن مُ مِشِ بْنْمَ عَبَدَن. يُنُبِ ندٍ نَ نَشَن مِشِ بْنْمَ عَبَدَن. ﭑ مُ عَ قَلَ وٌ شَ عَلَ مَشَندِ نَ مْولِ شَ قٍ رَ.
\v 17 سّرِيّ مَتَندِقٍ بِرِن قِندِشِ يُنُبِ نَن نَ، كْنْ يُنُبِ بِرِن شَ مُ مِشِ بْنْمَ.
\p 
\v 18 وٌن عَ كٌلٌن مِشِ نَشَن قِندِشِ عَلَ شَ دِ رَ، عَ مُ لُمَ يُنُبِ رَبَ رَ، بَرِ مَ عَلَ شَ دِ، عَ عَ كَنتَمَ. سٍنتَنّ مُ نْمَ عَ رَ.
\v 19 وٌن عَ كٌلٌن عَ عَلَ شَ دِيٍ نَن وٌن نَ، كْنْ دُنِحَ مِشِ دْنشْي بِرِن نَ سٍنتَنّ سَفٌ نَن بُن مَ.
\p 
\v 20 وٌن مَن عَ كٌلٌن عَ عَلَ شَ دِ بَرَ قَ. عَ شَشِلِ قَنيِ نَن قِشِ وٌن مَ، عَلَكٌ وٌن شَ عَلَ نْندِ كَنيِ كٌلٌن. وٌن نُن عَلَ نْندِ كَنيِ نَن عَ رَ عَ شَ دِ عِسَ سَابُي رَ، عَ شَ مِشِ سُفَندِشِ. عَ تَن نَن نَ عَلَ نْندِ كَنيِ رَ، نَشَن كِسِ قِشِ وٌن مَ عَبَدَن.
\p 
\v 21 ﭑ مَ دِيٍ، وٌ وٌ يّتّ رَتَنفَ كُيٍيٍ مَ.
