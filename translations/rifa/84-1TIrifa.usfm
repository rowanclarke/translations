\id 1TI
\h 1 ثِيمُوثِييُو
\toc1 1 ثِيمُوثِييُو
\toc2 1 ثِيمُوثِييُو
\toc3 1 تِيم.
\mt1 1 ثِيمُوثِييُو
\c 1
\s1 أَسدْجمْ غَارْ ؤُمزْوَارُو ذ إِعْڒَامنْ
\m 
\v 1 بُولُوسْ، رَّاسُولْ ن يَاسُوع لْمَاسِيحْ، عْلَاحْسَابْ ڒُومُورْ ن أَربِّي، ونِّي ذ أَنغْ إِتِّيشنْ ثُوذَارْثْ، ؤُ ن لْمَاسِيحْ يَاسُوع، ونِّي ذ أَسِيثمْ نّغْ. \f ◼ \fr 1:‏1 \ft \bd ’رَّاسُولْ‘\bd* - نِيغْ ’أَمَازَانْ‘.\f*  \x ◘ \xo 1:‏1 \xt ڒخ. 9‏:‏15؛ كُول. 1‏:‏27. \x*
\v 2 إِ ثِيمُوثِييُو، مِّي ذ ثِيذتّْ ذِي لْ-إِيمَانْ: أَرْضَا ذ أَرّحْمثْ ذ ڒهْنَا \add أَذْ أَشْ إِڒِينْ\add* زِي أَربِّي، بَابَاثْنغْ، ؤُ زِي لْمَاسِيحْ يَاسُوع، سِيذِيثْنغْ. \x ◘ \xo 1:‏2 \xt ڒخ. 16‏:‏1؛ 1 كُور. 4‏:‏17؛ ڭال. 1‏:‏3؛ 1 تس. 3‏:‏2؛ 1 بُط. 1‏:‏2. \x*
\b
\m 
\v 3 ڒَامِي رُوحغْ غَارْ مَاكِيذُونِييَا زَاوْڭغْ شكْ أَذْ ثقِّيمذْ ذِي أَفَاسُوسْ، حِيمَا أَذْ ثُومُورذْ إِ شَا ن يرْيَازنْ حِيمَا وَارْ سّڒْمِيذنْ شَا إِسڒْمَاذنْ نّغْنِي، \x ◘ \xo 1:‏3 \xt ڒخ. 20‏:‏1. \x*
\v 4 \add ؤُ\add* حِيمَا وَارْ تِّيشنْ شَا ثَايْنِيثْ إِ ثْحُوجَا إِخْوَانْ ذ ثَاصِيڒَاثْ وَارْ إِقطِّينْ نِّي د-إِتَّاوْينْ غَارْ إِمْحَارْوَاضنْ كْثَارْ، وَارْ إِدْجِي غَارْ مِينْ إِدْجَانْ إِ ڒبْنِي ذِي لْ-إِيمَانْ ن أَربِّي. \x ◘ \xo 1:‏4 \xt 1 تِيم. 4‏:‏7؛ 6‏:‏4، 20؛ 2 تِيم. 2‏:‏16؛ ثِيث. 1‏:‏14؛ 3‏:‏9. \x*
\v 5 سُّومْ ن ثْوصَّا أَقَا ذ ثَايْرِي زڭْ وُوڒْ أَمزْذَاڭْ ذ ثْنفْسشْثْ إِشْنَانْ ؤُ زِي لْ-إِيمَانْ ذ ثِيذتّْ. \x ◘ \xo 1:‏5 \xt رُوم. 13‏:‏8؛ ڭال. 5‏:‏14. \x*
\v 6 أَقَا ذِينِّي شَا إِنِّي إِهيّْضنْ خْ مَانْ أَيَا ؤُشَا نّْقڒْبنْ غَارْ ڒْهَارْذْ إِخْوَانْ.
\v 7 نِيثْنِي خْسنْ أَذْ إِڒِينْ ذ إِمسْغَارنْ ن شَّارِيعَا بْڒَا ڒفْهَامثْ ذِي مِينْ قَّارنْ ؤُ خْ مِينْ خفْ تّمْشُوبُّوشنْ.
\v 8 مَاشَا نسّنْ بلِّي شَّارِيعَا ثصْبحْ مَاڒَا حذْ إِجَّا إِخفْ نّسْ أَذْ إِتّْوَانْذهْ زَّايسْ عْلَاحْسَابْ شَّارِيعَا، \x ◘ \xo 1:‏8 \xt رُوم. 7‏:‏12. \x*
\v 9 أَمْ نسّنْ أَقَا شَّارِيعَا وَارْ ثمّوْشْ شَا إِ ؤُمْسڭَّاذنْ، مَاشَا إِ يِينِّي وَارْ إِسڭّْذنْ ؤُ إِ إِمْغوَّاغنْ، إِ إِعفَّاننْ ذ إِمذْنَابْ، إِ إِمقْجَاحْ، إِ إِمخْمُوجنْ، إِ يِينِّي إِوْثِينْ بَابَاثْسنْ ؤُ إِ يِينِّي إِوْثِينْ يمَّاثْسنْ ؤُ إِ يِينِّي إِنقّنْ \add إِوْذَانْ\add*، \x ◘ \xo 1:‏9 \xt ڭال. 5‏:‏23. \x*
\v 10 إِ أَيْثْ ن فَارْقْ-شّْغڒْ ذ زّْوَامڒْ، إِ يِينِّي إِتّْسبَّابنْ ذڭْ إِوْذَانْ، إِ أَيْثْ ن بُو-إِخَارِّيقنْ ذ يِينِّي إِتَّارژَّانْ ثَاجَادْجِيثْ نْسنْ ؤُشَا زعْمَا إِ مَارَّا مِينْ وَارْ د-إِتِّيسنْ شَا أَكْ-ذ ؤُسڒْمذْ إِصحّنْ
\v 11 ن لْ-إِنْجِيلْ إِ ذ أَيِي إِتّْوَاوكّْڒنْ، زِي جِّيهثْ ن ؤُعُودْجِي ن أَربِّي إِتّْوَابَارْكنْ. \x ◘ \xo 1:‏11 \xt 1 تس. 2‏:‏4؛ 1 تِيم. 6‏:‏15. \x*
\b
\s1 أَرْضَا ن أَربِّي إِ بُولُوسْ
\m 
\v 12 نشّْ تّْقَاذِيغْ ونِّي ذ أَيِي إِسّْجهْذنْ، أَقَا سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ، ؤُمِي إِحْسبْ أَيِي-د ذ أَمْثِيقِّي ڒَامِي ذ أَيِي إِڭَّا ذِي ڒْخذْمثْ ن ثْسخَّارْثْ \add نّسْ\add*،
\v 13 نشّْ ذ ونِّي ثُوغَا إِدْجَانْ قْبڒْ ذ أَمْشقَّافْ ذ إِجّْ ن ؤُمَارَّاثْ \add ن إِمَاسِيحِييّنْ\add* ؤُڒَا ذ إِجّْ ن بُو-ڒْْعُونْفْ. مَاشَا ثمّوْشْ أَيِي-د أَرّحْمثْ، مِينْزِي ڭِّيغْ ث وَارْ سِّينغْ، \add ؤُمِي ذ أَيِي ثُوغَا\add* بْڒَا لْ-إِيمَانْ. \x ◘ \xo 1:‏13 \xt يُوح. 9‏:‏39،41؛ ڒخ. 3‏:‏17؛ 8‏:‏3؛ 9‏:‏1؛ 22‏:‏4؛ 26‏:‏9؛ 1 كُور. 15‏:‏9؛ ڭال. 1‏:‏13. \x*
\v 14 أَرْضَا ن سِيذِيثْنغْ ثُوغَا إِفيّضْ ذَايِي س وَاطَّاسْ، ؤُڒَا ذ لْ-إِيمَانْ ذ ثَايْرِي ثنِّي إِدْجَانْ ذِي يَاسُوع لْمَاسِيحْ.
\v 15 وَا ذ أَوَاڒْ ذَايسْ ڒَامَانْ، إِ إِسْذَاهدْجنْ أَذْ يِيڒِي إِڭُّورْ، أَقَا يَاسُوع لْمَاسِيحْ يُوسَا-د غَارْ دُّونشْثْ حِيمَا أَذْ إِسّنْجمْ إِمذْنَابْ، إِنِّي زَّايْسنْ نشّْ ذ أَمزْوَارُو. \x ◘ \xo 1:‏15 \xt مت. 9‏:‏13؛ مك. 2‏:‏17؛ لك. 5‏:‏32؛ 19‏:‏10؛ 1 يُوح. 3‏:‏5. \x*
\v 16 مَاشَا خْ ؤُيَا كْسِيغْ أَرّحْمثْ مَاحنْذْ يَاسُوع لْمَاسِيحْ أَذْ إِسّْشنْ ذَايِي ذ أَمزْوَارُو مَارَّا تَّاسِيعْ ن ڒْخَاضَارْ نّسْ، ذ لْمِيثَالْ إِ يِينِّي زَّايسْ إِ غَا يَامْننْ إِ ثُوذَارْثْ إِتّْذُومَانْ.
\m 
\v 17 أَقَا إِ ؤُجدْجِيذْ ن زّْمَانَاثْ، ذ ونِّي وَارْ إِفنِّينْ، ذ ونِّي وَارْ إِتّْوِيڒِينْ، ونِّي ذ أَربِّي ذ إِجّْ، أَذْ غَارسْ يِيڒِي شَّانْ ذ ؤُعُودْجِي إِ زّْمَانْ ن زّْمَانَاثْ قَاعْ. أَمِينْ. \x ◘ \xo 1:‏17 \xt 1 تِيم. 6‏:‏16\x*
\m 
\v 18 ثَاسخَّارْثْ-أَ، \add أَ\add* مِّي ثِيمُوثِييُو، سّْوكّْڒغْ شكْ خَاسْ، حِيمَا أَذْ ثمّنْغذْ أَمنْغِي أَصبْحَانْ عْلَاحْسَابْ مِينْ خَاكْ إِتّْوَانَابّنْ قْبڒْ، \x ◘ \xo 1:‏18 \xt 1 تِيم. 6‏:‏12. \x*
\v 19 س لْ-إِيمَانْ ذ ثْنفْسشْثْ إِشْنَانْ، مَاغَارْ إِنِّي ؤُڭِينْ مَانْ أَيَا، أَقَا سّخْوَانْ إِخفْ نْسنْ زِي لْ-إِيمَانْ. \x ◘ \xo 1:‏19 \xt 1 تِيم. 3‏:‏9. \x*
\v 20 جَارْ أَسنْ هِيمِينِييُوسْ ذ أَلِيكْسَانْذِيرْ، إِنِّي سلّْمغْ إِ شِّيطَانْ حِيمَا أَذْ ڒمْذنْ مَاحنْذْ وَارْ تّْشقَّافنْ. \x ◘ \xo 1:‏20 \xt 1 كُور. 5‏:‏5؛ 2 تِيم. 2‏:‏17؛ 4‏:‏14. \x*
\b
\b
\c 2
\s1 أَسڒْمذْ ن بُولُوسْ خْ وعْبَاذْ ن ثْمسْمُونْثْ إِ أَربِّي
\m 
\v 1 س ؤُينِّي تّْزَاوَاڭغْ كنِّيوْ، حِيمَا أَذْ ثْقَارّْبمْ ذ أَمزْوَارُو غَارْ أَربِّي س ثُوثْرَا ذ ثْژَادْجِيثِينْ ذ ثْكسِّيثْ س ڒْمعْرُوفْ ذ ؤُقَاذِي ذِي طّْوعْ ن مَارَّا إِوْذَانْ،
\v 2 ذِي طّْوعْ ن إِجدْجِيذنْ ذ إِمقّْرَاننْ، حِيمَا خنِّي أَذْ ندَّارْ ذِي ڒهْنَا ذ ڒْهُوذْنثْ ؤُ س مَارَّا ثِيڭّْوُوذِي ذ ثزْذُوڭِي زَّاثْ أَربِّي. \x ◘ \xo 2:‏2 \xt إِرْم. 29‏:‏7. \x*
\v 3 مِينْزِي مَانْ أَيَا ذ أَصبْحَانْ ؤُ يُوسَا أَسْ-د إِ ڒْخَاضَارْ إِ أَربِّي، ونِّي ذ أَنغْ إِتِّيشنْ ثُوذَارْثْ،
\v 4 ونِّي إِخْسنْ أَقَا مَارَّا إِوْذَانْ أَذْ طّْفنْ ثُوذَارْثْ ؤُشَا أَذْ د-ذوْڒنْ غَارْ ثُوسّْنَا ن ثِيذتّْ. \x ◘ \xo 2:‏4 \xt حِز. 18‏:‏23؛ 2 بُط. 3‏:‏9. \x*
\v 5 مِينْزِي أَقَا ذِينْ إِجّْ ن أَربِّي ذ إِجّْ ن لْوَاسِيثْ جَارْ أَربِّي ذ إِوْذَانْ، أَقَا نتَّا ذ مِّيسْ ن بْنَاذمْ، يَاسُوع لْمَاسِيحْ، \x ◘ \xo 2:‏5 \xt يُوح. 17‏:‏3؛ رُوم. 3‏:‏30؛ ڭال. 3‏:‏19؛ عبر. 9‏:‏15. \x*
\v 6 ونِّي إِوْشِينْ إِخفْ نّسْ ذ أَصْڒَاحْ إِ مَارَّا بْنَاذمْ، أَقَا-ت ذ شّْهَاذثْ إِ د-يُوسِينْ ذِي ڒْوقْثْ نّسْ. \x ◘ \xo 2:‏6 \xt مت. 20‏:‏28؛ أَفا. 1‏:‏7؛ كُول. 1‏:‏14. \x*
\v 7 إِ مَانْ أَيَا تّْوَاڭّغْ ذ أَمْبَارّحْ ذ رَّاسُولْ، أَقَا قَّارغْ ثِيذتّْ، وَارْ سّْخَارِّيقغْ شَا، حِيمَا أَذْ إِڒِيغْ ذ أَمْسغَّارْ ن ڒڭْنُوسْ ذِي لْ-إِيمَانْ ن ثِيذتّْ. \x ◘ \xo 2:‏7 \xt ڒخ. 9‏:‏15؛ 13‏:‏2؛ 22‏:‏21؛ رُوم. 1‏:‏9؛ 9‏:‏1؛ ڭال. 1‏:‏16؛ 2‏:‏8؛ أَفا. 3‏:‏8؛ 2 تِيم. 1‏:‏11. \x*
\m 
\v 8 س ؤُيَا خْسغْ بلِّي إِرْيَازنْ أَذْ ژَّادْجنْ ذِي مْكُوڒْ أَمْشَانْ، أَمْ سّْڭعَّاذنْ إِفَاسّنْ نْسنْ س ثزْذُوڭِي، بْڒَا أَخيّقْ ذ ؤُمْشُوبّشْ. \x ◘ \xo 2:‏8 \xt إِزهد. 134‏:‏2؛ يُوح. 4‏:‏21. \x*
\m 
\v 9 أَمُّو ؤُڒَا ذ ثِيمْغَارِينْ أَذْ يَارْضنْثْ س ؤُوقَّارْ، إِتّْخصَّا أَذْ زهّْجنْثْ إِخفْ نْسنْثْ س إِجّْ ن وبْرِيذْ ن ڒحْيَا ؤُ ن ثْسخَّايْثْ، وَارْ إِدْجِي س ؤُمُوذِي ن ؤُشُوَّافْ نِيغْ س وُورغْ نِيغْ س ثْيَاقُوثِينْ نِيغْ س وَارُّوضْ إِغْڒَانْ، \x ◘ \xo 2:‏9 \xt ثِيث. 2‏:‏3؛ 1 بُط. 3‏:‏3. \x*
\v 10 مَاشَا \add أَذْ زهّْجنْثْ إِخفْ نْسنْثْ\add* س ڒخْذَايمْ إِصبْحنْ أَمْ مَامّشْ د-يُوسَا خْ ثمْغَارِينْ، ثِينِّي إِتّْنجْبَاذنْ غَارْ ؤُوقَّارْ ن أَربِّي.
\m 
\v 11 أجّْ ثَامْغَارْثْ أَذْ ثڒْمذْ ذِي ڒْهُوذْنثْ، أَكْ-ذ مَارَّا ثَامْوَاضعْثْ،
\v 12 مَاشَا نشّْ وَارْ تّجِّيغْ ثَامْغَارْثْ أَذْ ثسّڒْمذْ نِيغْ أَذْ غَارسْ يِيڒِي جّهْذْ خْ ورْيَازْ، مَاشَا أَذْ ثِيڒِي ثسْقَارْ. \x ◘ \xo 2:‏12 \xt أَمز. 3‏:‏16؛ 1 كُور. 14‏:‏34؛ أَفا. 5‏:‏24. \x*
\v 13 مِينْزِي أَذَامْ إِتّْوَاڭّْ ذ أَمزْوَارْ، أَوَارْنِي أَسْ حَاوَّا. \x ◘ \xo 2:‏13 \xt أَمز. 1‏:‏27؛ 2‏:‏22. \x*
\v 14 ؤُشَا أَذَامْ وَارْ إِتّْوَاغَارّْ شَا، مَاشَا ثَامْغَارْثْ ثتّْوَاغَارّْ، خنِّي ثخْضَا خْ ثوْصيّثْ. \x ◘ \xo 2:‏14 \xt أَمز. 3‏:‏6. \x*
\v 15 مَاشَا أَذْ ثدَّارْ س ثَارْوَا نّسْ، مَاڒَا تّْغِيمَانْ نِيثْنِي تّْشبَّارنْ ذِي لْ-إِيمَانْ ذ ثَايْرِي ذ ثْقدَّاسْثْ ذ ڒحْيَا.
\b
\b
\c 3
\s1 إِمحْضَاينْ ذ إِمْسيَّارنْ ن ثْمسْمُونْثْ
\m 
\v 1 وَا ذ أَوَاڒْ ذَايسْ ڒَامَانْ: مَاڒَا إِخْسْ حذْ أَذْ يِيڒِي ذ أَمْغَارْ، أَقَا إِتّْمژْرِي ذڭْ إِشْثْ ن ڒْخذْمثْ ثشْنَا.
\v 2 مَاشَا إِتّْخصَّا إِ ؤُمْغَارْ أَذْ إِثْوَافْ بْڒَا ڒْعِيبْ، أَذْ يِيڒِي ذ أَرْيَازْ ن إِشْثْ ن ثمْغَارْثْ، غَارسْ أَمكّنْ ن نّفْسْ، أَذْ يِيڒِي ذ أَسخَّايْ، أَذْ إِڭّْ س ؤُستّفْ، أَذْ يَارحّبْ س إِنوْجِيونْ، إِزمَّارْ أَذْ إِسّڒْمذْ. \x ◘ \xo 3:‏2 \xt 2 تِيم. 2‏:‏24؛ ثِيث. 1‏:‏6. \x*
\v 3 نتَّا وَارْ إِتِّيڒِي ذ أَمسْشَارْ نِيغْ إِوّثْ ذغْيَا س ؤُفُوسْ نّسْ، مَاشَا أَذْ يِيڒِي ذ أَمْوَاضعْ، وَارْ إِتّمْشُوبُّوشْ، وَارْ إِتِّيڒِي ذ أَقزَّازْ.
\v 4 أَقَا نتَّا إِسّڭُّورْ ثَادَّارْثْ نّسْ مْلِيحْ ؤُشَا إِحكّمْ خْ إِحنْجِيرنْ نّسْ س مَارَّا ڒصْفَايثْ.
\v 5 مَاشَا مَاڒَا نتَّا وَارْ إِزمَّارْ أَذْ إِسُّويُورْ ثَادَّارْثْ نّسْ، مَامّشْ غَا إِڭّْ أَذْ إِحْضَا ثَامسْمُونْثْ ن أَربِّي؟
\v 6 وَارْ إِتِّيڒِي ذ أَمحْضَارْ ن جْذِيذْ \add ذِي لْ-إِيمَانْ\add*، حِيمَا وَارْ إِتُّوفّْ \add س ڒفْيُوشْ\add* ؤُشَا أَذْ إِوْضَا ذِي شّْرعْ ن شِّيطَانْ.
\v 7 عَاوذْ إِتّْخصَّا أَذْ غَارسْ ثِيڒِي صُّومْعثْ ثشْنَا غَارْ يِينِّي ذِي بَارَّا، حِيمَا وَارْ خَاسْ تّْعيِّيبنْ ؤُشَا وَارْ إِوطِّي شَا ذِي ڒفْخُوخْ ن شِّيطَانْ.
\m 
\v 8 إِتّْخصَّا عَاوذْ إِ إِمْسخَّارنْ \add ذِي ثْمسْمُونْثْ\add* أَذْ إِڒِينْ ذ إِمزْذَاڭنْ، وَارْ سِّيوِيڒنْ شَا س ثْنَاينْ ن إِڒْسَاونْ، وَارْ خزَّارنْ شَا غَارْ بِينُو أَطَّاسْ، وَارْ ضمّْعنْ ذِي أَرّْبحْ وَارْ إِحْڒِينْ. \x ◘ \xo 3:‏8 \xt ڒخ. 6‏:‏3. \x*
\v 9 إِتّْخصَّا أَسنْ أَذْ طّْفنْ ذِي سِّيرّْ ن لْ-إِيمَانْ س ثْنفْسشْثْ ثصْفَا. \x ◘ \xo 3:‏9 \xt 1 تِيم. 1‏:‏19. \x*
\v 10 أجّْ إِ-ثنْ أَذْ تّْوَاقدْجْبنْ ذ أَمزْوَارُو، ڒخْذنِّي، مَاڒَا إِبَانْ-د وَارْ ذَايْسنْ إِتِّيڒِي بُو ڒْعِيبْ، أَذْ سخَّارنْ.
\v 11 أَمُّو إِتّْخصَّا ؤُڒَا إِ ثِيمْغَارِينْ أَذْ أَرْسِينْثْ س ثْسخَّايْثْ، أَذْ حْضَانْثْ ذِي ڒعْقُوڒْ نْسنْثْ، أَذْ ذَايْسنْثْ ثِيڒِي ڒْمَانثْ ذِي مَارَّا، وَارْ ذ تِّيڒِينْثْ ذ ثِيمْشقَّافِينْ.
\v 12 إِتّْخصَّا إِ إِمْسخَّارنْ \add ذِي ثْمسْمُونْثْ\add*، أَقَا \add كُوڒْ إِجّنْ زَّايْسنْ\add* أَذْ يِيڒِي س إِشْثْ ن ثمْغَارْثْ، ؤُشَا إِتّْخسْصَا أَسْ أَذْ إِسُّويُورْ مْلِيحْ إِحنْجِيرنْ نّسْ ذ ثَادَّارْثْ نّسْ.
\v 13 مِينْزِي إِنِّي إِتّڭّنْ ثَاسيَّارْثْ نْسنْ مْلِيحْ، أَذْ طّْفنْ إِ يِيخفْ نْسنْ إِجّْ ن ومْشَانْ إِشْنَا ذ وَاطَّاسْ ن ثرْيَاسْثْ ذِي لْ-إِيمَانْ ن يَاسُوع لْمَاسِيحْ. \x ◘ \xo 3:‏13 \xt مت. 25‏:‏21. \x*
\m 
\v 14 ؤُرِيغْ أَشْ-د مَانْ أَيَا ؤُشَا سِّيثِيمغْ أَذْ غَاركْ د-أَسغْ ذغْيَا.
\v 15 مَاشَا مَاڒَاعطَّاڒغْ خَاكْ، أَذْ ثسّْنذْ مَامّشْ إِتّْخصَّا أَذْ نُويُورْ ذِي ثَادَّارْثْ ن أَربِّي، ثنِّي إِدْجَانْ ذ ثَامسْمُونْثْ ن أَربِّي إِدَّارنْ، أَپِيلَارْ ذ ذْسَاسْ ن ثِيذتّْ. \x ◘ \xo 3:‏15 \xt أَفا. 2‏:‏19؛ عبر. 10‏:‏21؛ 1 بُط. 4‏:‏17\x*
\v 16 سِّيرّْ وَانِيثَا ن ثْسڭْذَا ذ أَمقّْرَانْ س ثِيذتّْ!
\b
\m \qt ”ذ ونِّي إِتّْوَاسَّارْڭْبنْ ذِي دَّاثْ،\qt*
\m \qt إِتّْوَاسڭّْذنْ ذِي أَرُّوحْ،\qt*
\m \qt إِضْحَارنْ-د إِ لْمَالَاكَاثْ،\qt*
\m \qt إِتّْوَابَارّْحنْ زَّايسْ جَارْ ڒڭْنُوسْ،\qt*
\m \qt ذ ونِّي \tl زَّايسْ\tl* يُومْننْ ذِي دُّونشْثْ،\qt*
\m \qt إِمّكْسِينْ ذڭْ ؤُعُودْجِي.“\qt* \x ◘ \xo 3:‏16 \xt مك. 16‏:‏19؛ لك. 9‏:‏51؛ يُوح. 1‏:‏14؛ ڒخ. 1‏:‏2؛ أَفا. 3‏:‏5، 6. \x*
\b
\b
\c 4
\s1 ؤُقَارِّي ن شَّايَاطِينْ ذ ثْهُوجَا ثِيپُوهَاڒِييّنْ
\m 
\v 1 مَاشَا أَرُّوحْ إِقَّارْ نِيشَانْ بلِّي ذِي زّْمَانَاثْ ثِينڭُّورَا شَا أَذْ حيّْذنْ خْ لْ-إِيمَانْ ؤُمِي غَا ضْفَارنْ ڒَارْيَاحْ إِسّْغكّْوَانْ ذ ثْغُورِي ن شّْوَاطنْ. \x ◘ \xo 4:‏1 \xt مت. 24‏:‏23؛ 2 تس. 2‏:‏3؛ 2 تِيم. 3‏:‏1؛ 2 بُط. 3‏:‏3؛ يَاه. 18. \x*
\v 2 نِيثْنِي سْغكّْوَانْ أَمْ سّْنِيعْمِيڒنْ إِخفْ نْسنْ، سّْخَارِّيقنْ ؤُ تّقّْذنْ ثَانفْسشْثْ نْسنْ.
\v 3 نِيثْنِي تّطّْفنْ ڒمْڒَاشْ ؤُشَا تَّامَارنْ أَسْبعّذْ خْ مَاشَّا نِّي د-إِتّْوَاخڒْقنْ زِي أَربِّي مَاحنْذْ أَذْ ثِيڒِي إِ نّْفعْ ذ ؤُقَاذِي إِ يِينِّي يُومْننْ ؤُ سّْننْ ثِيذتّْ. \x ◘ \xo 4:‏3 \xt أَمز. 1‏:‏29؛ 9‏:‏3؛ رُوم. 14‏:‏6؛ 1 كُور. 10‏:‏30. \x*
\v 4 مِينْزِي مَارَّا مِينْ د-إِتّْوَاخڒْقنْ زِي أَربِّي إِصْبحْ ؤُشَا وَارْ ذَايسْ مِينْ غَا نَاڭِي مَاڒَا نقْبڒْ زَّايسْ س ؤُقَاذِي، \x ◘ \xo 4:‏4 \xt أَمز. 1‏:‏31؛ ڒخ. 10‏:‏15؛ رُوم. 14‏:‏14. \x*
\v 5 مِينْزِي أَذْ إِتّْوَاقدّسْ س وَاوَاڒْ ن أَربِّي ذ ثْژَادْجِيثْ.
\b
\m 
\v 6 مَاڒَا ثسّْڒمْذذْ مَانْ أَيَا إِ وَاوْمَاثنْ نّشْ، أَذْ ثِيڒِيذْ ذ أَمْسخَّارْ ن يَاسُوع لْمَاسِيحْ، أَقَا ثتّْوَاربِّيذْ ذڭْ وَاوَاڒنْ ن لْ-إِيمَانْ ؤُ ثتّْوَاسّْڒمْذذْ ذِي ثْغُورِي ن صَّاحْ. \x ◘ \xo 4:‏6 \xt 2 تِيم. 1‏:‏5؛ 3‏:‏14، 15. \x*
\v 7 مَاشَا أَڭّْوجْ خْ ثْحُوجَا إِخْوَانْ ن ثْوسُّورَا ؤُ مَارّسْ إِخفْ نّشْ ذِي ثْسڭْذَا. \x ◘ \xo 4:‏7 \xt 1 تِيم. 1‏:‏4؛ 6‏:‏20؛ 2 تِيم. 2‏:‏16؛ ثِيث. 1‏:‏14؛ 3‏:‏9. \x*
\v 8 مِينْزِي أَرِّييَاضَا ن أَرِّيمثْ ثتَّاوِي غَارْ نّْفَاعْ إِ ذْرُوسْ ن ڒْوقْثْ وَاهَا، مَاشَا ثَاسڭْذَا ثْنفّعْ ڒبْذَا، ؤُشَا أَقَا غَارسْ لْوَاعْذْ ن ثُوذَارْثْ إِ يِيضَا ؤُ إِ ڒْوقْثْ إِ د غَا يَاسنْ. \x ◘ \xo 4:‏8 \xt كُول. 2‏:‏23. \x*
\m 
\v 9 وَا ذ أَوَاڒْ ذَايسْ ڒَامَانْ، إِسْذَاهدْجْ أَذْ إِتّْوَاقْبڒْ.
\v 10 مِينْزِي إِ مَانْ أَيَا ؤُمِي نْخدّمْ ؤُ نتّْوَاسّحْقَارَا عَاوذْ، مِينْزِي أَسِيثمْ نّغْ أَقَا-ث ذِي أَربِّي إِدَّارنْ، ونِّي إِتِّيشنْ ثُوذَارْثْ إِ مَارَّا إِوْذَانْ، أَمزْوَارُو إِ يِينِّي يُومْننْ.
\v 11 سڒْمذْ، ثُومُورذْ س مَانْ أَيَا.
\m 
\v 12 أجّْ ؤُڒَا ذ إِجّْ وَارْ شكْ إِسّحْقِيرِي شَا خْ ثمْژِي نّشْ، مَاشَا إِڒِي ذ لْمِيثَالْ إِ يِينِّي يُومْننْ، س وَاوَاڒْ، س ونْذَاهْ، س ثَايْرِي، س لْ-إِيمَانْ ؤُ س ثَازْذُوڭِي. \x ◘ \xo 4:‏12 \xt ثِيث. 2‏:‏7، 15؛ 1 بُط. 5‏:‏3. \x*
\v 13 إِڒِي ثشْضَارذْ ذِي ثْغُورِي \add إِ ثْمسْمُونْثْ\add*، ذِي طْژَادْجِيثْ ؤُ ذڭْ ؤُسڒْمذْ أَڒْ د غَا يَاسغْ.
\v 14 وَارْ سْحقَّارَا شَا ثَاوْهِيبْثْ إِ ذَايكْ، ثنِّي إِ ذ أَشْ إِمّوْشنْ ؤُمِي ثُوغَا تّْنَابّنْ ؤُ سَّارْسنْ إِمْغَارنْ خَاكْ إِفَاسّنْ. \x ◘ \xo 4:‏14 \xt ڒخ. 6‏:‏6؛ 8‏:‏17؛ 13‏:‏3؛ 19‏:‏6؛ 1 تِيم. 5‏:‏22؛ 2 تِيم. 1‏:‏6. \x*
\v 15 عْقڒْ خْ ثْمسْڒَايِينْ-أَ، شبَّارْ ذَايْسنْثْ، حِيمَا ثِيشْڒِي نّشْ غَارْ زَّاثْ أَذْ ثْبَانْ إِ مَارَّا.
\v 16 حْضَا إِخفْ نّشْ ؤُ حْضَا خْ ؤُسڒْمذْ، صْبَارْ ذِي مَانْ أَيَا، مِينْزِي مَاڒَا ثڭِّيذْ دّڭَّا، أَذْ ثحْضِيذْ إِخفْ نّشْ ذِي ثُوذَارْثْ ؤُڒَا ذ إِنِّي ذ أَشْ إِتّسْڒَانْ.
\b
\b
\c 5
\s1 خْ ؤُذبَّارْ ن ثْمسْمُونْثْ
\m 
\v 1 وَارْ ثِيڒِيذْ ثوْعَارذْ إِ ؤُوسَّارْ، مَاشَا نسْحْ إِ-ث أَمْ بَابَاشْ، ؤُشَا إِبْڒِيغنْ أَمْ وَاوْمَاثنْ نّشْ، \x ◘ \xo 5:‏1 \xt لَاوِي 19‏:‏32. \x*
\v 2 ثِيوسُّورَا أَمْ ثِييمَّاثِينْ، ؤُشَا ثِيعزْرِييِّينْ أَمْ سُويثْمَاشْ نّشْ، س مَارَّا ڒصْفَايثْ.
\m 
\v 3 وقَّارْ ثِيجَّاڒْ، ثِينِّي ذ ثِيذتّْ دْجَانْثْ ذ ثِيجَّاڒْ.
\v 4 مَاڒَا شَا ن ثَاجَّاتْشْ غَارسْ إِحنْجِيرنْ نِيغْ أَيَّاونْ، أجّْ إِ-ثنْ أَذْ ڒمْذنْ ذ أَمزْوَارْ مَاحنْذْ أَذْ ڭّنْ مِينْ إِتّْڒِيقنْ ذِي طّْوعْ ن ڒَادْجْ نْسنْ، أَذْ د-أَرّنْ إِ لْوَالِيذِينْ مِينْ تُّورْسنْ، مِينْزِي دّڭَّا يُوسَا-د خْ ڒْخَاضَارْ ن أَربِّي. \x ◘ \xo 5:‏4 \xt أَمز. 45‏:‏10، 11؛ مت. 15‏:‏4؛ مك. 7‏:‏10؛ أَفا. 6‏:‏1، 2. \x*
\v 5 مَاشَا ثَاجَّاتْشْ نِيشَانْ ذ ثنِّي إِدْجَانْ وحّْذسْ، ثسِّيثِيمْ ذِي أَربِّي ؤُشَا ثْصبَّارْ ذِي ثُوثْرَا ذ ثْژَادْجِيثِينْ، دْجِيڒثْ ذ وَاسّْ. \x ◘ \xo 5:‏5 \xt لك. 2‏:‏36؛ 1 كُور. 7‏:‏32. \x*
\v 6 مَاشَا ثنِّي إِوْضَانْ ذِي ثُوذَارْثْ ن نّشْوثْ، أَقَا ثمُّوثْ وَاخَّا ثدَّارْ.
\v 7 وصَّا إِ-ثنْثْ ثِيمسْڒَايِينْ-أَ، حِيمَا أَذْ إِڒِينْثْ بْڒَا ڒْعِيبْ.
\v 8 مِينْزِي مَاڒَا شَا ن يِيجّْ وَارْ إِتّْهِيلِّي شَا ذِي وِي إِدْجَانْ نّسْ، ذ أَموَارُو ذڭْ يِينِّي إِدْجَانْ ذ أَيْثْبَابْ ن ثَادَّارْثْ ن فَامِيلْيَا ن يِينِّي يُومْننْ، أَقَا وَانِيثَا إِمّنْضَارْ لْ-إِيمَانْ ؤُشَا نتَّا مَاهُو خْ يِينِّي وَارْ يُومِيننْ شَا. \x ◘ \xo 5:‏8 \xt ڭال. 6‏:‏10. \x*
\m 
\v 9 إِخْضَارْ خنِّي إِشْثْ ن ثَاجَّاتْشْ إِلَّا مَاڒَا غَارسْ زِي ستِّينْ ن إِسڭّْوُوسَا أَڒْ ثْسَاونْثْ، إِشْثْ ن ثَاجَّاتْشْ نِّي ثُوغَا \add ذ ثَامْغَارْثْ\add* ن إِجّْ ن ورْيَازْ،
\v 10 ثنِّي غَارْ ثدْجَا شّْهَاذثْ أَقَا ثڭَّا ڒخْذَايمْ ثِيصبْحَانِينْ: نِيغْ ثسّيْمِي إِحنْجِيرنْ نّسْ، نِيغْ ثَارحّبْ س إِبَارَّانِييّنْ، نِيغْ ثسِّيرذْ إِضَارنْ ن إِمْقدَّاسنْ، نِيغْ ثوْشَا فُوسْ إِ يِينِّي إِتّْوَاحْصَارنْ، \add وَاهْ،\add* أَقَا ثڭَّا مَارَّا ڒْخذْمثْ ثَاصبْحَانْثْ. \x ◘ \xo 5:‏10 \xt أَمز. 18‏:‏4؛ 19‏:‏2؛ لك. 7‏:‏38،44؛ 1 بُط. 4‏:‏9. \x*
\m 
\v 11 مَاشَا وَارْ قبّڒْ ثِيجَّاڒْ ثِيمژْيَانِينْ، مِينْزِي نِيثنْثِي تّخْسنْثْ أَذْ سَّارْخُونْثْ إِ لْمَاسِيحْ س نّشْوَاثْ نْسنْثْ، أَرزُّونْثْ خْ إِجّْ ن ورْيَازْ.
\v 12 أَقَا شّْرعْ نْسنْثْ إِمْثنْ، مِينْزِي سَّارْسنْثْ لْ-إِيمَانْ نْسنْثْ أَمزْوَارْ غَارْ ؤُغزْذِيسْ.
\v 13 مَاغَارْ نِيثنْثِي سّْڒمْذنْثْ \add إِنّغْنِي\add* ڒعْقزْ أَمْ ڭُّورنْثْ خْ ثُوذْرِينْ، وَارْ إِدْجِي سّْڒمْذنْثْ وَاهَا ڒعْڭزْ، مَاشَا نِيثنْثِي تّْعَاوَاذنْثْ ڒخْبُورَاثْ، تَّاذْفنْثْ ذِي شْغُوڒَاثْ \add ن مِيدّنْ\add*، قَّارنْثْ مِينْ وَارْ إِشُووَّارنْ. \x ◘ \xo 5:‏13 \xt ثِيث. 2‏:‏3. \x*
\v 14 س ؤُينِّي خْسغْ أَذْ مڒْشنْثْ ثِيجَّاڒْ ثِيمژْيَانِينْ، أَذْ د-جّنْثْ إِحنْجِيرنْ، أَذْ سُّويُورنْثْ ثَادَّارْثْ نْسنْ، وَارْ تّجِّينْثْ شَا إِ ڒعْذُو سِّيبّثْ حِيمَا أَذْ إِشقّفْ. \x ◘ \xo 5:‏14 \xt 1 كُور. 7‏:‏9. \x*
\v 15 مِينْزِي أَقَا شَا \add زَّايْسنْثْ\add* بْذَانْثْ أَذْ فّْغنْثْ أَبْرِيذْ، ضفَّارنْثْ شِّيطَانْ.
\m 
\v 16 مَاڒَا ذِينْ إِرْيَازنْ نِيغْ ثِيمْغَارِينْ يُومْننْ غَارْسنْ ثِيجَّاڒْ، أجّْ إِ-ثنْ أَذْ ذَايْسنْثْ ثْهِيلَّانْ، مَاحنْذْ وَارْ إِتِّيڒِي دّْقڒْ عَاذْ خْ ثْمسْمُونْثْ، حِيمَا \add ثَامسْمُونْثْ\add* أَذْ غَارسْ يِيڒِي مَاحنْذْ أَذْ ثْعَاونْ ثِينِّي إِدْجَانْ ذ ثِيجَّاڒْ س ثِيذتّْ.
\b
\s1 إِمْغَارنْ ن ثْمسْمُونْثْ
\m 
\v 17 إِمْغَارنْ نِّي إِتّْضبَّارَانْ مْلِيحْ، سْذَاهْدْجنْ أَوقَّارْ ثْنَاينْ ن إِمُورنْ، أَبعْذَا إِنِّي إِخدّْمنْ ذڭْ وَاوَاڒْ ؤُ ذڭْ ؤُسڒْمذْ. \x ◘ \xo 5:‏17 \xt رُوم. 15‏:‏27؛ 1 كُور. 9‏:‏11؛ ڭال. 6‏:‏6؛ فِيل. 2‏:‏29؛ 1 تس. 5‏:‏12؛ عبر. 13‏:‏17. \x*
\v 18 مِينْزِي ثِيرَا \add إِقدّْسنْ\add* قَّارنْثْ: ”وَارْ تّڭّْ ثَاشْمَانْثْ إِ ؤُينْذُوزْ إِسَّارْوَاثنْ!“، ؤُ: ”أَخدَّامْ إِسْذَاهدْجْ ڒْمُونثْ نّسْ!“ \x ◘ \xo 5:‏18 \xt لَاوِي 19‏:‏13؛ أَعَوذ. 24‏:‏14؛ 25‏:‏4؛ مت. 10‏:‏10؛ لك. 10‏:‏7؛ 1 كُور. 9‏:‏9. \x*
\v 19 وَارْ قبّڒْ شَا ثَانْفُوتْشْ ضِيدّْ إِ ؤُمْغَارْ، مْغِيرْ خْ ؤُقمُّومْ ن ثْنَاينْ نِيغْ ن ثْڒَاثَا ن ڒشْهُوذْ. \x ◘ \xo 5:‏19 \xt أَعَوذ. 19‏:‏15. \x*
\v 20 إِنِّي إِخْضَانْ،عيّبْ إِ-ثنْ زَّاثْ إِ مَارَّا، حِيمَا إِنّغْنِي أَذْ ڭّْوذنْ عَاوذْ.
\v 21 زِييَّارغْ خَاكْ زَّاثْ إِ أَربِّي ذ سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ ذ لْمَالَاكَاثْ نّسْ إِتّْوَافَارْزنْ، أَذْ ثحْضِيذْ مَانْ أَيَا بْڒَا ڒْفَارْزْ، وَارْ تّڭّْ ؤُڒَا ذ إِشْثْ ن ثْمسْڒَاشْثْ عْلَاحْسَابْ ؤُذْمَاونْ. \x ◘ \xo 5:‏21 \xt أَعَوذ. 17‏:‏4؛ 19‏:‏18؛ رُوم. 1‏:‏9؛ 9‏:‏1؛ 2 كُور. 1‏:‏23؛ 11‏:‏31؛ ڭال. 1‏:‏20؛ فِيل. 1‏:‏8؛ 1 تس. 2‏:‏5؛ 5‏:‏27؛ 1 تِيم. 6‏:‏13. \x*
\v 22 وَارْ سّْرُوسَا إِفَاسّنْ نّشْ خْ حذْ س ؤُقدْجقْ، وَارْ شَارّشْ ذِي دّْنُوبْ ن إِنّغْنِي، حْضَا إِخفْ نّشْ ذِي ڒصْفَايثْ. \x ◘ \xo 5:‏22 \xt ڒخ. 6‏:‏6؛ 8‏:‏17؛ 13‏:‏3؛ 19‏:‏6؛ 1 تِيم. 4‏:‏14؛ 2 تِيم. 1‏:‏6. \x*
\m 
\v 23 وَارْ سسّْ أَمَانْ وَاهَا، مَاشَا سُو ذْرُوسْ ن بِينُو إِ سْثُومَاغُو نّشْ ؤُ إِ ڒحْڒَاشْ نّشْ أَزِيرَارْ. \x ◘ \xo 5:‏23 \xt إِزهد. 104‏:‏15. \x*
\m 
\v 24 أَقَا ذِينْ إِوْذَانْ إِ غَارْ إِدْجَا دّْنُوبْ نْسنْ بَاننْ مْلِيحْ ذغْيَا، أَقَا \add دّْنُوبْ نْسنْ\add* تِّيزَّارنْ أَسنْ غَارْ شّْرعْ، ؤُشَا أَقَا ذِينْ شَا نّغْنِي ضفَّارنْ ثنْ \add دّْنُوبْ نْسنْ\add*. \x ◘ \xo 5:‏24 \xt ڭال. 5‏:‏19. \x*
\v 25 أَمُّو د-بَاننْثْ ؤُڒَا ذ ڒخْذَايمْ ثِيصبْحَانِينْ، مَاشَا \add ؤُڒَا ذ\add* ثِينِّي إِ وَارْ  إِدْجِينْ أَمُّو، وَارْ زمَّارنْثْ أَذْ قِّيمنْثْ نُّوفَّارنْثْ.
\b
\b
\c 6
\s1 إِمْسخَّارنْ ذ أَيْثْبَابْ نْسنْ
\m 
\v 1 إِتّْخصَّا إِ مَارَّا إِنِّي إِدْجَانْ سَاذُو أَزَايْڒُو ن ثسْمُوغِي أَذْ وقَّارنْ أَيْثْبَابْ نْسنْ ذِي مَارَّا، حِيمَا وَارْ إِتِّيڒِي ؤُشقّفْ ذڭْ يِيسمْ ن أَربِّي ؤُ ذِي ثْغُورِي نّسْ. \x ◘ \xo 6:‏1 \xt أَفا. 6‏:‏5؛ كُول. 3‏:‏22؛ ثِيث. 2‏:‏9؛ 1 بُط. 2‏:‏18. \x*
\v 2 أجّْ \add إِسمْغَانْ\add* نِّي غَارْ إِدْجَا إِمَاسنْ ؤُمْننْ وَارْ ثنْ سّحْقِيرِينْ شَا، ؤُمِي نِيثْنِي ذ أَوْمَاثنْ إِ إِدْجَانْ. مَاشَا س ڒْعكْسْ أجّْ إِ-ثنْ أَذْ أَسنْ سخَّارنْ \add مْلِيحْ\add*، مِينْزِي نِيثْنِي ؤُمْننْ ؤُ أَقَا أَثنْ ذ \add أَوْمَاثنْ\add* إِعِيزّنْ، إِنِّي غَارْسنْ خدّْمنْ نِيثْنِي ذِي ڒَامَانْ. سڒْمذْ مَانْ أَيَا ؤُ زيَّارْ خَاسنْ.
\b
\s1 لْخَاطَارْ ن وَاطَّاسْ ن وَاڭْڒَا
\m 
\v 3 مَاشَا مَاڒَا ذِينْ حذْ إِسّڒْمذْ إِشْثْ ن ڒْحَاجّثْ نّغْنِي ؤُشَا وَارْ يَاردّفْ شَا أَوَاڒنْ إِصحّنْ ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ ذ ثْغُورِي خْ مَامّشْ إِشُووَّارْ أَذْ نعْبذْ أَربِّي س ثِيڭّْوُوذِي،
\v 4 أَقَا نتَّا إِتُّوفّْ أَمْ وَارْ إِسِّينْ وَالُو، إِودَّارْ ذڭْ إِمْحَارْوَاضنْ ذ إِمْشُوبّشنْ إِ-د-إِتَّاوْينْ ڒحْسذْ ذ ؤُمنْغِي ذ ؤُشقّفْ ذ إِشْثْ ن نّيّثْ ذ ثَاعفَّانْثْ \x ◘ \xo 6:‏4 \xt 1 تِيم. 1‏:‏4؛ 2 تِيم. 2‏:‏23؛ ثِيث. 3‏:‏9. \x*
\v 5 ؤُڒَا ذ ثَامَارَا إِ د-يكِّينْ زڭْ إِوْذَانْ إِنِّي إِتّْوَاغشّنْ ذِي ڒعْقڒْ نْسنْ، ثْودَّارْ أَسنْ تِّيذثْ، إِتّْغِيڒْ أَسنْ أَقَا أَرْبحْ إِقِّيمْ غَارْ ثِيڭّْوُوذِي زِي أَربِّي. بعّذْ خَاسنْ. \x ◘ \xo 6:‏5 \xt 1 كُور. 11‏:‏16. \x*
\v 6 مَاشَا أَرْبحْ نّغْ ذ أَمقّْرَانْ. أَقَا-ث ذ ثِيڭّْوُوذِي زِي أَربِّي، \add أَمْ\add* غَارْنغْ مِينْ نحْذَاجْ. \x ◘ \xo 6:‏6 \xt أَوڒن. 15‏:‏16؛ عبر. 13‏:‏5. \x*
\v 7 مِينْزِي وَارْ د-نِيوِي وَالُو غَارْ دُّونشْثْ ؤُشَا أَقَا نسّنْ وَارْ نْزمَّارْ أَكِيذْنغْ نكْسِي وَالُو زَّايسْ. \x ◘ \xo 6:‏7 \xt أَيُوبْ 1‏:‏21؛ 27‏:‏19؛ إِزهد. 49‏:‏18. \x*
\v 8 س ؤُينِّي، مَاڒَا غَارْنغْ ڒْمعْثقْ ذ دُّورِي، أَقَا نقْنعْ. \x ◘ \xo 6:‏8 \xt إِزهد. 55‏:‏23؛ أَوڒن. 27‏:‏26؛ مت. 6‏:‏25؛ 1 بُط. 5‏:‏7. \x*
\v 9 مَاشَا إِنِّي إِخْسنْ أَذْ سّْمُوننْ أَڭْڒَا، أَذْ وْضَانْ ذڭْ إِجَارِّيبنْ ؤُ ذِي ڒفْخُوخْ ؤُ ذڭْ وَاطَّاسْ ن نّشْوَاثْ ثِيفْغَاڒْ إِتّْضَارَّانْ، ثِينِّي إِتّجَّانْ إِوْذَانْ أَذْ غَارْقنْ ذڭْ ؤُثحِّي ذ ڒكْحضْ. \x ◘ \xo 6:‏9 \xt أَوڒن. 11‏:‏28؛ مت. 13‏:‏22؛ يَاع. 5‏:‏1. \x*
\m 
\v 10 مِينْزِي أَژْوَارْ ن مَارَّا ثُوعفّْنَا أَقَا ث ذ طّْمعْ ن ثْمنْيَاثْ. أَقَا ذِينْ شَا إِنِّي ثُوغَا إِتّْمژْڒِينْ ذِي مَانْ أَيَا، إِودَّارْ أَسنْ لْ-إِيمَانْ ؤُشَا جبّْذنْ أَطَّاسْ ن ثَامَارَا إِ يِيخفْ نْسنْ. \x ◘ \xo 6:‏10 \xt ؤُف. 23‏:‏8؛ أَعَوذ. 16‏:‏19؛ أَوڒن. 15‏:‏16. \x*
\m 
\v 11 مَاشَا شكْ، أَ بْنَاذمْ ن أَربِّي، أَرْوڒْ زِي مَانْ أَيَا ؤُشَا أَرْزُو خْ ثْسڭْذَا، خْ ثْنِيشَانْثْ، خْ لْ-إِيمَانْ، خْ ثَايْرِي، خْ صّْبَارْ ؤُ خْ ثمْهِينْثْ. \x ◘ \xo 6:‏11 \xt 2 تِيم. 2‏:‏22. \x*
\v 12 مْنغْ أَمنْغِي أَصبْحَانْ ن لْ-إِيمَانْ، شبَّارْ ذِي ثُوذَارْثْ إِتّْذُومَانْ نِّي ؤُمِي غَارْ د-ثتّْوَاڒَاغِيذْ، مِينْ خفْ ثْشهْذذْ شّْهَاذثْ ثَاصبْحَانْثْ زَّاثْ إِ وَاطَّاسْ ن ڒشْهُوذْ. \x ◘ \xo 6:‏12 \xt 1 تِيم. 1‏:‏18. \x*
\v 13 شهّْذغْ إِ شكْ زَّاثْ إِ أَربِّي، ونِّي إِوْشِينْ ثُوذَارْثْ إِ مَارَّا، ؤُ زَّاثْ إِ يَاسُوع لْمَاسِيحْ، ونِّي ثُوغَا إِشهّْذنْ شّْهَاذثْ ثَاصبْحَانْثْ أَطَّاسْ زَّاثْ إِ بُونْطِييُوسْ بِيلَاطُوسْ، \x ◘ \xo 6:‏13 \xt أَعَوذ. 32‏:‏39؛ 1 صم. 2‏:‏6؛ مت. 27‏:‏11؛ يُوح. 18‏:‏37؛ 1 تِيم. 5‏:‏21. \x*
\v 14 حِيمَا أَذْ ثحْضِيذْ تّوْصيّثْ بْڒَا سُّوسّْ نِيغْ ڒْعِيبْ أَڒْ د غَا إِبَانْ سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ.
\v 15 نتَّا أَذْ إِتّْوَاسّضْهَارْ ذِي ڒْوقْثْ نّسْ: أَربِّي إِتّْوَابَارْكنْ، أَمْزمَّارْ كُوڒْشِي خْ مَارَّا مِينْ إِدْجَانْ، أَجدْجِيذْ خْ \add مَارَّا\add* إِجدْجِيذنْ ذ سِيذِي ن إِسِيذِيثنْ، \x ◘ \xo 6:‏15 \xt 1 تِيم. 1‏:‏17؛ أَسَا. 17‏:‏14؛ 19‏:‏16. \x*
\v 16 ونِّي وحّْذسْ وَارْ إِفنِّينْ، ونِّي إِزدّْغنْ ذِي ثْفَاوْثْ إِ وَارْ إِزمَّارْ أَذْ غَارسْ يَاذفْ حذْ، ونِّي وَارْ إِژْرِي بْنَاذمْ نِيغْ إِزمَّارْ عَاذْ أَذْ ث إِژَارْ، إِ نتَّا ؤُمِي غَارْ إِدْجَا شَّانْ ذ صُّولْطَا إِ ڒبْذَا قَاعْ. أَمِينْ. \x ◘ \xo 6:‏16 \xt ؤُف. 33‏:‏20؛ أَعَوذ. 4‏:‏12؛ 1 يُوح. 4‏:‏12؛ 1 تِيم. 1‏:‏17.\x*
\m 
\v 17 عْڒمْ إِ أَيْثْبَابْ ن وَاڭْڒَا ذِي دُّونشْثْ-أَ وَارْ تِّيڒِينْ ذ إِمْعفَّارنْ، وَارْ تّْشَاڒنْ خْ وَاڭْڒَا وَارْ يَاركّْننْ، مَاشَا \add أَذْ تّشْڒنْ\add* خْ أَربِّي إِدَّارنْ، ونِّي ذ أَنغْ إِتِّيشنْ مَارَّا ثِيمسْڒَايِينْ س ؤُفيّضْ حِيمَا أَذْ خَانغْ إِفوّجْ، \x ◘ \xo 6:‏17 \xt مك. 4‏:‏18؛ لك. 8‏:‏14. \x*
\v 18 ؤُشَا \add عْڒمْ\add* إِ-ثنْ أَذْ ڭّنْ ڒخْذَايمْ إِصبْحنْ، أَذْ غَارْسنْ إِڒِينْثْ ثْمڭَّا ثِيصبْحَانِينْ، أَذْ وجْذنْ مَاحنْذْ أَذْ وْشنْ ؤُ أَذْ شَارْشنْ.
\v 19 أجّْ إِ-ثنْ أَذْ سَّارْسنْ \add أَمُّو\add* ذْسَاسْ أَصبْحَانْ إِ يِيخفْ نْسنْ إِ ڒْوقْثْ إِ د غَا يَاسنْ، مَاحنْذْ أَذْ غَارْسنْ ثِيڒِي ثُوذَارْثْ ذ ثِيذتّْ. \x ◘ \xo 6:‏19 \xt مت. 6‏:‏20؛ لك. 12‏:‏33؛ 16‏:‏9. \x*
\m 
\v 20 أَ ثِيمُوثِييُو، حْضَا مِينْ ذ أَشْ إِتّْوَاوكّْڒنْ، أَڭّْوجْ خْ ڒْهَارْذْ إِخْوَانْ ؤُڒَا خْ ڒْعكَاسَاثْ إِ د-إِتّفّْغنْ زِي ثُوسّْنَا إِسّْخَارِّيقنْ. \x ◘ \xo 6:‏20 \xt 1 تِيم. 1‏:‏4؛ 4‏:‏7؛ 2 تِيم. 2‏:‏16؛ ثِيث. 1‏:‏14؛ 3‏:‏9. \x*
\v 21 أَقَا ذِينْ شَا ن إِوْذَانْ ڒَامِي سعْفنْ مَانْ أَيَا، سمْحنْ ذِي لْ-إِيمَانْ. أَذْ كِيذكْ يِيڒِي أَرْضَا! أَمِينْ. 
