\id PHM - Chácobo NT -Bolivia 2010 (DBL -2013)
\h Filemón
\toc1 La Carta Del Apostol San Pablo a Filemón
\toc2 Filemón
\toc3 Flm
\mt2 La Carta Del Apostol San Pablo a
\mt1 Filemón
\c 1
\p 
\v 1 Jabi mi qui naa chani raati ibo ca Pablo ca ëa xo naa. Nobë xatë Timoteo yaxo tsi mia joihuaquia, Filemón. Jasca, mia ri tsi xo nobë xatë ri, naa no bëta Dios bax yonocoriabëquihai cato. Jabi Jesucristo tahëhax preso qui ë nanëhacani quiha.
\v 2 Jasca, mi xobó ca catihai ca chahahuacanaibo, noba poi maxco Apia, nobë xatë Arquipo, naa no bëta yonocoriabëquihai cato, tihi cabo joihuaquia.
\v 3 Noba Jahëpa Dios, noba Ibo Jesucristo, tihi cabá mato shomahuano. Mato ja ranihuacano ra.
\s1 Shinajiaxëni ca Filemón
\p 
\v 4 Mi bax bëhoxpama tsi Dios qui “Gracias” iroha-irohaquia, mi jabi jia ca yoati ë nicani quëshpi na.
\v 5 Jiaria tsi xo toa noba Ibo Jesu, toá ca chahahuacanaibo, tihi cabo mi noihaina iquia. Jasca, anomaria tsi xo toa Dios qui mi chitimihai ri. Tihi tsi nicahax “Gracias” iroha-irohaquia ranihi na.
\v 6 Jasca, jaboqui Ibo qui mi chitimihai ca huëtsa bo qui mi yoaxëti xo iquia. Tocapimino tsi noqui Cristó shomahuariahai ca cahëyoicaxëcani quiha jato ri. Tihi tsi nicaquia jaboqui mi bax bëhoxquí na.
\v 7 Jasca, mi noihai ca iqui tsi rani-raniquia ra. “Dios nohiria bo mëbi-mëbiriahi quiha Filemón” i ë qui jaca ni quiha ra, ëbë xatë́. Jiaria tsi xo toa mi noihaina iquia.
\s1 Pabló bënanina
\p 
\v 8-9 Noiriahai ca mi nori iqui tsi huësti ca jahuë pistia mia nicacasquia ë bax ati. Jabi Cristo ó ca chama jaya xo ëa, mia yonati, jia ca mia amati. Jishopë. Tocacasyama xo ëa. Jama, mia nicaquia. Shinaparihuë. Huësti ca joni siri cato, naa Jesucristo tahëhax tsi presó nori ca Pablo ca tsi xo naa mia nicahaina.
\v 10 Nëá tsi ë bëta tsi xo ëbë baquë Onésimo, mi jabahuanish ca yonati. Preso xo tsi naa joni ë bëboniquë Ibo qui. \fig Filemón qui Onésimo Pabló raanina|src="cn02090b.tif" size="span" copy="©1978 David C. Cook Publishing Company" ref="PHM 1.11"\fig*
\v 11 Jabi chahahuanox pari tsi quiha mahitsa ja i-ipaoniquë mi qui. Jama, jaboqui ëa mëbiriahi quiha; jasca, jaboqui mia mëbiriapixëhai ca ja nori.
\v 12 Jatsi jaboqui jahari mi yonati raacasquia. Jabi ja cano tsi cohuëxëquia tia.
\v 13 Jasca, mi yonati chitiacasquia ra, mia ja ratino iquish na. Ea mëbiti mëtsaria xo mi yonati, presó tsi ë iquë no, Cristo Chani tahëhax na.
\v 14 Jama, tocayamaxëquia ra, mi qui jia yama ja imitsa iqui na. Jasca, tocati mia ë nicarohano tsi noihaxma tsi “ahuë” i ë qui mi quë aquë iquia. E qui yoi tsi xo toa acaina. Noba xatë bo no mëbixëti xo, noixo na.
\v 15 Jabi siri tsi mi quima mi yonati jabani quiha. Jama, tanaroha pistia tsi xo iquia, jaboqui mi i-ipaohai ca yonati ja nori iqui na. Shoma ixëqui mia ja bacaquë no.
\v 16 Bacahax yonati oquë-oquëria ixëhi quiha. Jaboqui mibë xatë tsi xo ra. Jasca, anomaria tsi xo toa mi yonati ë noihaina. Tsayahuë. Mi yonati yoi jatsi Cristo ó ca xatë, tihi cabo tsi xo toa mi yonati jaboqui ra.
\p 
\v 17 Mi rabëti pi ë no tsi jia tsi mi yonati joihuahuë, ëa mi joihuacatsai jasca cato.
\v 18 ¿Tonia yoi ca mia pasomaha ja ayamayamani? ¿Mi nohó ca cuenta ja jayamayamani? Tocapijaquë tsi noho cuenta ó tsi janahuë ra.
\v 19 Jahari mia copixëquia, naa Pablo cato. Jabi noho mëquë yoí tsi naa chani mi qui quënëquia ra. Jasca, ¿ë nohó ca cuenta jayamani mia ra? Toa nicaquia. Jatsi shinaparihuë. Mi shina yoi ë qui mi axëti xo ra mi bax ë ani quëshpi na.
\v 20 Ja iqui tsi jia tsi jahari mi yonati mi joihuano, ëbë xatë́. Jatsi Ibo tahëxo tsi ëa ranihuahuë, mi Cristo ó ca xatë ë nori quëshpi na.
\p 
\v 21 Jabi tocaxëqui mia tia. Ja iqui tsi raquëxoma tsi naa chani mi qui quënëquia. Tonia mi yonati cahëno tsi mia ë nicahai ca oquë tsi jahari bixëqui mia tonia.
\v 22 Quënëpama tsi ë bax chitëti iti mi shomahuano. Toa mia nicaquia. Preso quima tsëquëti ó pasoquia mi qui caxëna, ë bax mi bëhoxhai ca iqui na.
\s1 Chani rëso
\p 
\v 23 Mia joihuahi quiha ë bëtá ca Epafras. Jesucristo tahëhax preso xara xo naa joni ri, ëa jascaria.
\v 24 Jasca, nëá xo ë bëta yonocobëquicanaibo huëtsa bo, naa Marcos, Aristarco, Demas, Lucas. Mato joihuacani quiha tihi cabo ri.
\p 
\v 25 Noba Ibo Jesucristó mia shomahuano. Iquë. Amén.
