\id COL
\h Kolosa
\toc1 Kolosa
\toc2 Kolosa
\toc3 Kolosa
\mt1 Kolosa
\c 1
\s1 O KA EPISETOLE A PAULO KA LUNAOLELO I KO
\q1 
\v 1 NA Paulo aku, na ka lunaolelo a Iesu Kristo ma ka manao mai o ke Akua, na Timoteo hoi ka hoahanau,
\q1 
\v 2 I ka poe haipule a me na hoahanau manaoio iloko o Kristo, ma Kolosa; no oukou ke aloha a me ka malu mai ke Akua mai, o ko kakou Makua, a me ka Haku o Iesu Kristo.
\b
\q1 
\v 3 Ke hoomaikai aku nei maua i ke Akua, i ka Makua o ko kakou Haku o Iesu Kristo, e pule mau ana no oukou,
\q1 
\v 4 Ua lohe maua i ko oukou manaoio ana ia Kristo Iesu, a me ko oukou aloha ana i na haipule a pau,
\q1 
\v 5 No ka pono e manaolanaia'i, e waiho ana no oukou ma ka lani: o ka mea a oukou i lohe mua ai maloko o ka olelo oiaio o ka eua nelio;
\q1 
\v 6 I hiki mai io oukou la e like me ia ma ka honua a pau; a ua hua mai hoi i ka hua, me ia hoi iwaena o oukou, mai ka la i lohe ai oukou, a i ike ai hoi i ke aloha o ke Akua, ma ka oiaio.
\q1 
\v 7 E like mo ka oukou hoolohe ana ia Epapera i ko maua hoakauwa aloha, i ko Kristo kahunapule hoopono no oukou;
\q1 
\v 8 Nana no i hoike mai ia maua i ko oukou aloha ma ka naau.
\b
\q1 
\v 9 Nolaila hoi, mai ka manawa mai i lohe ai maua, aole maua i hooki i ka pule no oukou, me ka noi aku i hoopihaia mai oukou me ka ike i kona makemake, a me ka naanao io ma ka Uhane;
\q1 
\v 10 I hele oukou ma ka pono o ka Haku, i na mea a pau i oluoluia mai ai, e hua mai ana i ka hua ma na hana maikai a pau, me ka mahuahua ana ae o ka ike ana i ke Akua.
\q1 
\v 11 E hooikaika nui ia mai oukou e kona mana nani, i ke kupaa ana, a me ke ahonui a me ka olioli;
\q1 
\v 12 Me ka hoomaikai aku i ka Makua nana kakou i hoopono mai, i loaa mai ai ia kakou ka pono e ili mai ana i ka poe haipule i ke ao.
\q1 
\v 13 Nana hoi kakou i hoola, mai ka mana mai o ka pouli, a ua lawe hoi oia ia kakou iloko o ke aupuni o kana Keiki punahele;
\q1 
\v 14 Iloko ona ke ola no kakou i kona koko, o ke kala ana'e o ka hewa.
\q1 
\v 15 Oia hoi ka like me ke Akua i nana ole ia, oia hoi ka mua o na mea a pau i hanaia'i.
\q1 
\v 16 No ka mea, ua hanaia e ia na mea a pau, o ko ka lani a me ko ka honua, i nanaia, a i nana ole ia, o na nohoalii, o na haku, o na luna, a me na'lii: ua hauaia na mea a pau ma ona la, a nona no hoi.
\q1 
\v 17 Oia hoi ka mua o na mea a pau, a ma ona la no hoi i mau ai na mea a pau.
\q1 
\v 18 Oia hoi ke poo o ke kino, o ka ekalesia: oia ka makamua, o ka hanau mua hoi mai ka make mai; i lilo ia i pookela iwaena o na mea a pau.
\q1 
\v 19 No ka mea, o ka pono no ia i ka Makua e noho nui ka pono a pau iloko ona;
\q1 
\v 20 A ma ona la e hoolaulea ai i na mea a pau ia ia iho, e hoomaiu ana ma ke koko o kona kea; ma ona la, i ko ka honua nei, a me ko ka lani.
\q1 
\v 21 O oukou kekahi, ka poe i ku e i kekahi manawa, ka poe enemi i ko oukou manao ana ma na hana hewa, o kana ia i hoolaulea ae nei,
\q1 
\v 22 Ma kona kino kanaka, i ka make ana, e hoike oia ia oukou he hemolele, he hala ole, a me ka hoohewa ole ia, imua o kona alo;
\q1 
\v 23 Ke noho mau aku oukou ma ka manaoio, i hookumuia oukou me ka hoopaaia, ke hoonee ole ia ku hoi mai ka manaolana aku o ka euanelio a oukou i lohe ai, ka mea i haiia'ku i na mea a pau i hanaia malalo ae o ka lani, nona iho au o Paulo i hooliloia'e nei i lunalawehana.
\b
\q1 
\v 24 ke hauoli nei au i ko'u ehaeha no oukou, e hoopau ana iloko o ko'u kino, i ke koena o ko Kristo ehaeha ana, no kona kino, oia no ka ekalesia.
\q1 
\v 25 Nona wau i hooliloia'e nei i lunalawehana, e like me ke kauoha a ke Akua i haawi mai ai ia'u no oukou, e hoolaha ae i ka olelo a ke Akua;
\q1 
\v 26 I ka mea pohihihi hunaia'e mai ka wa kahiko mai, a me na hanauna mai, aka i keia manawa, ua hoikeia mai nei i kana mau haipule;
\q1 
\v 27 I ka poe a ke Akua i hoomaopopo ai i ka waiwai nani o keia mea pohihihi iwaena o ko na aina e; oia no o Kristo iloko o oukou, ka manaolana no ka nani:
\q1 
\v 28 Oia ka makou e hai aku nei, e ao ana i na kanaka a pau, a e hoonaauao ana i na kanaka a pau i ka naauao io, e hiki ia makou ke hoike i na kanaka a pau i hemolele iloko o Kristo Iesu.
\q1 
\v 29 Nalaila hoi ka'u hana e hooikaika nui nei, e like me kana hana i hooikaika nui mai nei iloko o'u.
\c 2
\b
\q1 
\v 1 NO ka mea, ke ake nei au e ike oukou i ko'u ehaeha nui ana no oukou, a me ko Laodikeia, a me ka poe i ike ole mai i ko'u maka, i ke Kino nei;
\q1 
\v 2 I hooluolu pu ia ko lakou naau, i hookui pu ia hoi i ke aloha, a i ka waiwai a pau o ka manao maopopo loa, i ka ike paka ana i ka mea pohihihi a ke Akua ka Makua a me Kristo;
\q1 
\v 3 Kahi i hunaia'i ka waiwai nui o ke akamai, a me ka naauao.
\q1 
\v 4 O ka'u ia e olelo nei, o puni oukou i kekahi, i na olelo hoowalewale.
\q1 
\v 5 No ka mea, i ko'u kaawale ana ma ke kino, owau pu kekahi me oukou ma ka uhane, e hauoli ana, me ka nana ana i ko oukou pono like, a me ke kupaa ana o ko oukou manaeio ia Kristo.
\b
\q1 
\v 6 Nolaila hoi, no ka loaa ana mai o Kristo ia oukou, e hele oukou iloko ona;
\q1 
\v 7 I hookumuia, a i hookukuluia iloko ona, a me ka hoomauia i ka manaoio i hoikeia mai ia oukou, a malaila e hoomahuahua ae ia me ka hoomaikai aku.
\b
\q1 
\v 8 E malama hoi, o hokai mai kekahi ia oukou me ka manao maalea, a me ka hoopunipuni lapuwale, mamuli o ka mooolelo o Kanaka, mamuli o na kumu o ko ke ao nei, aole hoi mamuli o Kristo.
\q1 
\v 9 No ka mea, maloko ona e noho ana ka pono nui a pau o ke Akua ma ko kino.
\q1 
\v 10 Ua hemolele oukou maloko ona, oia ke poo o na'lii a pau a me ka mana.
\q1 
\v 11 Iloko ona, ua okipoepoeia oukou i ke okipoepoe hana ole ia e ka lima, i ke pale ana aku i ke kino o ka hewa o ka io, ma ko Kristo okipoepoe ana;
\q1 
\v 12 I kanu pu ia me ia, i ka bapetizo ana, a ilaila hoi e ala pu hou ai me ia, ma ka manaoio i ka hana a ke Akua, a ka mea i hoala ia ia, mai ka make mai.
\q1 
\v 13 O oukou hoi ka poe i make iloko o ka hewa, a me ke okipoepoe ole ia o ko oukou kino, o oukou Kana i hoala pu hou mai nei me ia, a ua kala mai i ko oukou hewa a pau;
\q1 
\v 14 E hokai ana i ka palapala lima o na oihana i pono ole ai Kakou, o ka mea i ku e mai ia kakou, oia kana i lawe aku ai, a makia aku la ma kona kea.
\q1 
\v 15 A kaili ae la oia i ko na'lii, a me ko na mea mana, ua hoike ia lakou ma ke akea, e lanakila ana maluna o lakou ma keia.
\b
\q1 
\v 16 Nolaila, mai hoahewa mai kekahi ia oukou, i ka mea ai, a me ka mea inu, aole hoi no kahi la hoano, a me ka mahina hou, a me na sabati.
\q1 
\v 17 He aka no ia mau mea no na mea e hiki mai ana: aka o ke kino, no Kristo no ia.
\q1 
\v 18 Mai hoonele mai kekahi ia oukou i ko oukou uku ma ka hoohaahaa wale ana, a me ka hoomana ana i na anela, e maoi wale ana iloko o na mea ana i ike ole ai, e hookano wale ana kona naau kanaka,
\q1 
\v 19 Me ka malama ole i ke Poo, i ka mea i hanaiia mai ai ke kino a pau, i paa i na ami a me na olona, ua mahuahua aku ia i ko ke Akua hoomahuahua ana mai.
\b
\q1 
\v 20 Ina hoi i make pu oukou me Kristo, a kaawale na kumu liilii o ko ke ao nei, no ke aha hoi oukou, e like me ka noho ana ma keia ao, i malama ai i na kapu,
\q1 
\v 21 (Mai hoopa, mai hoao, mai lawelawe;
\q1 
\v 22 O na mea ia e make ai ma ka lawe ana;) mamuli o na kauoha a me na oleloao a kanaka?
\q1 
\v 23 He mau mea hookohukohu naauao, i ka hoomana e, a i ka hoohaahaa, a i ka malama ole i ke kino, aole nae i ka mea nui e oluolu ai ke kino.
\c 3
\b
\q1 
\v 1 I NA hoi i ala pu oukou me Kristo, e imi oukou i na mea maluna, ma kahi e noho ai o Kristo, ma ka lima akau o ke Akua.
\q1 
\v 2 E paulele oukou i na mea oluna, aole i na mea ma ka honua nei.
\q1 
\v 3 No ka mea, ua make oukou, a ua hunaia'ku ko oukou ola me Kristo iloko o ke Akua.
\q1 
\v 4 Aia ikea aku o Kristo o ko kakou ola, alaila e ikea pu oukou me ia iloko o ka nani.
\b
\q1 
\v 5 E uumi hoi i ko oukou mau lala ma ka honua; i ka moe ko lohe, i ka maemae ole, i ke kuko wale, i ka makemake ino, a me ka makee waiwai, o ka hoomanakii no ia.
\q1 
\v 6 No ia mau mea e hiki mai ai ka inaina o ke Akua maluna iho o na keiki a ka hoolohe ole.
\q1 
\v 7 Ilaila hoi ko oukou hele ana I kekahi manawa, ia oukou i noho pu ai me lakou.
\q1 
\v 8 Aka, menei ua pau ia oukou i ka hemo o keia mau mea; o ka huhu, o ka inaina, o ka ukiuki, o ka hoino wale, o ke kamailio haumia mai loko mai o ko oukou waha.
\q1 
\v 9 Mai hoopunipuni kekahi i kekahi, no ka mea, ua hemo ia oukou ke kanaka kahiko a me kana hana;
\q1 
\v 10 A ua hookomo hou oukou i ke kanaka hou, i ka mea i hana hou ia i ka naauao ma ka like o ka mea nana ia i hana;
\q1 
\v 11 Kahi i ole ai he Helene, he Iudaio, he okipoepoe, a me ke okipoepoe ole, ka malihini, a me ka Sekute, ke kauwa a me ke kauwa ole; aka, o Kristo no ka mea a pau, oia hoi ko loko o na mea a pau.
\b
\q1 
\v 12 Nolaila hoi, me he poe i waeia la e ke Akua, i hoolaaia, a i alohaia hoi, e hookomo oukou i ka naau menemene, a i ka lokomaikai, a i ka manao haahaa, a i ke akahai, a me ke ahonui;
\q1 
\v 13 E hoomanawanui ana kekahi i kekahi, e kala ana hoi kekahi i kekahi, ke loaa ka hala o kekahi i kekahi; e like me ka Kristo kala ana mai ia oukou, pela aku hoi oukou.
\q1 
\v 14 A o ke aloha kekahi, maluna iho o neia mau mea a pau, oia ka mea hemolele e paa pono ai.
\q1 
\v 15 A e noho hoomalu mai ka main o ke Akua iloko o ko oukou naau, no ia mea hoi e heaia mai ai oukou i kino hookahi; a e hoomaikai aku hoi oukou.
\q1 
\v 16 A e noho lako mai ka olelo a Kristo iloko o oukou, me ka naauao loa; e ao ana a e hoonaauao ana hoi kekahi i kekahi i na halelu, a me na himeni, a me na mele ma ka Uhane, a oli ana i ka Haku me ka maikai iloko o ko oukou naau.
\q1 
\v 17 A o ka oukou mea e lawelawe ai ma ka olelo, a ma ka hana, e pau ia i ka hanaia iloko o ka inoa o ka Haku, o Iesu, a e hoomaikai aku i ke Akua, i ka Makua, ma ona la.
\q1 
\v 18 E na wahine, e hoolohe oukou i ka oukou mau kane ponoi, o ka pono no ia iloko o ka Haku.
\q1 
\v 19 E na kane, e aloha oukou i ka oukou mau wahine, mai noho a hoawahia aku ia lakou.
\q1 
\v 20 E na keiki, e hoolohe oukou i ko oukou mau makua, ma na mea a pau; no ka mea, he pono ia i ka Haku.
\q1 
\v 21 E na makuakane, mai hoonaukiuki i ka oukou mau keiki, o pauaho lakou.
\q1 
\v 22 E na kauwa, e hoolohe ma na mea a pau, i ko oukou mau haku ma ke kino; aole ka hooiaio maka me he mea hoolealea kanaka la; aka, me ka naau hookahi e hopohopo ana i ke Akua.
\q1 
\v 23 A o ka oukou mea e hana'i a pau, e hana aku no ia me ka naau, me he mea la no ka Haku, aole hoi no kanaka.
\q1 
\v 24 Ua ike hoi oukou, na ka Haku mai e loaa mai ana ia oukou ka uku e ili mai ana; no ka mea, ua hookauwa aku oukou na ka Haku na Kristo.
\q1 
\v 25 Aka, o ka mea hana hewa la, e hoopaiia ia no ka hewa ana i hana'i; aole loa e manao ewaewa ia mai na kino.
\c 4
\b
\q1 
\v 1 E NA a haku, e haawi aku na na kauwa i ka mea pono, a me ka ewaewa ole; ua ike oukou ho Haku ko oukou ma ka lani.
\b
\q1 
\v 2 E hoomau i ka pule, e makaala hoi ma ia mea, me ka hoomaikai aku.
\q1 
\v 3 No makou kekahi e pule ai oukou, i wehe mai ke Akua i ka puka no makou e olelo ai, e hai aku i ka mea pohihihi o Kristo i ko'u mea i hoopeaia mai nei:
\q1 
\v 4 I hiki ia'u ke hoomaopopo ia mea, me he mea pono la ia u ke olelo aku.
\q1 
\v 5 E hele naauao oukou mamua o ka poe mawaho, e malama pono ana i ka manawa.
\q1 
\v 6 E hoomauia ka maikai o ka oukou olelo, i miko ia i ka paakai, i ike oukou i ka mea e pono ai ke olelo i kela kanaka a i keia kanaka.
\b
\q1 
\v 7 A o ko'u noho ana, na Tukiko ia e hai aku ia oukou, na ka hoahanau aloha, ka lawehana hoopono, ka hoakauwa iloko o ka Haku.
\q1 
\v 8 Oia ka'u i hoouna aku nei io oukou la, no ia mea, i ike aku ia i ko oukou noho ana, a e hooluolu aku hoi i ko oukou mau naau;
\q1 
\v 9 Me Oneaimo, ka hoahanau aloha hoopono, no oukou mai ia; na laua e hoike aku ia oukou i na mea a pau o nei.
\b
\q1 
\v 10 Ke uwe aku nei o Arisetareko, ko'u hoapio ia oukou, laua o Mareko ke keiki a ko Barenaba kaikuwahine, (nona oukou i kauohaia aku ai, oia ka oukou e hookipa ai, ke hiki aku ia io oukou la,)
\q1 
\v 11 A me Iesou, i kapa hou ia'i Iouseto, no ke okipoepoe laua O lakou wale no ko'u mau hoalawehana ma ke aupuni o ke Akua, na mea i hooluolu mai nei ia'u.
\q1 
\v 12 Ke uwe aku nei o Epapera ia oukou, no oukou ia, o ke kauwa a Kristo, e hooikaika mau ana no oukou, i ka pule, i ku hemolele oukou me ke kina ole, ma ka makemake a pau o ke Akua.
\q1 
\v 13 Ke hoike aku nei au nona, he ikaika nui kona no oukou, a no ka poe ma Laodikeia, a me ka poe i Hierapoli.
\q1 
\v 14 Ke uwe aku nei ia oukou o Luka, ke kahuna lapaau punahele, a me Dema.
\q1 
\v 15 E aloha aku oukou i ka poe hoahanau i Laodikeia, a ia Numepana, a me ka ekalesia iloko o kona hale.
\q1 
\v 16 Aia heluheluia keia episetole, iwaena o oukou la na oukou e heluhelu hou aku ia i ka ekalesia o ko Laodikeia; a e heluhelu hoi oukou i ka episetole mai Laodikeia mai.
\q1 
\v 17 E i aku ia Arekipo, E malama oe i ka oihana i loaa ia oe iloko o ka Haku, nau ia e hooponopono.
\b
\q1 
\v 18 O ke aloha nae, na ka lima ia o'u nei o Paulo. E hoomanao mai i ko'u mea i paa ai. E alohaia mai oukou. Amene. 
