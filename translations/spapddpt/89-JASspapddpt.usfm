\v 9 Hermanos, \w no|strong="G3361"\w* se quejen \w unos|strong="G3588"\w* \w contra|strong="G2596"\w* \w otros|strong="G3588"\w* \w para|strong="G2443"\w* \w que|strong="G3588"\w* \w no|strong="G3361"\w* sean juzgados. Observen, \w el|strong="G3588"\w* \w Juez|strong="G2923"\w* \w está|strong="G3588"\w* \w en|strong="G2596"\w* \w la|strong="G3588"\w* \w puerta|strong="G2374"\w*.  
\v 10 Hermanos, tomen \w como|strong="G2532"\w* modelo \w del|strong="G3588"\w* sufrimiento \w y|strong="G2532"\w* \w la|strong="G3588"\w* \w longanimidad|strong="G3115"\w* \w a|strong="G1722"\w* \w los|strong="G3588"\w* \w profetas|strong="G4396"\w* \w que|strong="G3588"\w* \w hablaron|strong="G2980"\w* \w en|strong="G1722"\w* \w el|strong="G3588"\w* \w Nombre|strong="G3686"\w* \w del|strong="G3588"\w* \w Señor|strong="G2962"\w*.  
\v 11 Consideramos \w como|strong="G2532"\w* inmensamente felices a \w los|strong="G3588"\w* \w que|strong="G3754"\w* sufren. Oyeron \w de|strong="G3588"\w* \w la|strong="G3588"\w* \w paciencia|strong="G5281"\w* \w de|strong="G3588"\w* Job, \w y|strong="G2532"\w* vieron \w el|strong="G3588"\w* propósito \w del|strong="G3588"\w* \w Señor|strong="G2962"\w*, \w porque|strong="G3754"\w* \w el|strong="G3588"\w* \w Señor|strong="G2962"\w* es compasivo \w y|strong="G2532"\w* \w misericordioso|strong="G3629"\w*.   
