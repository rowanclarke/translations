\id HOS
\h حُوشِيعَا 
\toc1 حُوشِيعَا 
\toc2 حُوشِيعَا 
\toc3 حُوش. 
\mt1 حُوشِيعَا  
\c 1
\m
\v 1 أَوَاڒْ ن سِيذِي إِ د-يُوسِينْ غَارْ حُوشِيعَا، مِّيسْ ن بِيرِي، ذڭْ وُوسَّانْ ن عُوزِّييَا، يُوثَامْ، أَحَازْ ذ حِيزْقِييَا، إِجدْجِيذنْ ن يَاهُوذَا، ؤُ ذڭْ وُوسَّانْ ن يَارُوبْعَامْ، مِّيسْ ن يُووَاشْ، أَجدْجِيذْ ن إِسْرَائِيل. \f ◼ \fr 1:‏1 \ft \+bd ’حُوشِيعَا‘\+bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَسنْجمْ‘ نِيغْ ’أَفْڒَاحْ‘. \+bd ’بِيرِي‘\+bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَنُو إِنُو‘. \+bd ’حَازَاقِييَا‘\+bd* - إِسمْ نّسْ إِكمّْڒنْ ’يَاحَازَاقِييَا‘.\f*   
\b  
\m  
\s1 حُوشِيعَا يجّْ-د ثْڒَاثَا ن إِحنْجِيرنْ غَارْ خُومَارْ  
\m
\v 2 أَبدُّو ن وَاوَاڒْ ن سِيذِي س هُوشِيعَا. سِيذِي إِنَّا إِ هُوشِيعَا: ”رُوحْ، أَوِي إِشْثْ ن ثمْغَارْثْ ن فَارْقْ-شّْغڒْ ؤُڒَا ذ ثَارْوَا ن فَارْقْ-شّْغڒْ، مَاغَارْ س فَارْقْ-شّْغڒْ \add نّسْ\add* ثزْنَا ثمُّورْثْ \add ثفّغْ\add* زڭْ أَوَارْنِي إِ سِيذِي.“  
\v 3 ؤُشَا يُويُورْ نتَّا، يِيوِي جُومَارْ، يدْجِيسْ ن ذِيبْلَايِيمْ، ؤُ نتَّاثْ ثكْسِي س دّيْسثْ، ثُورُووْ أَسْ-د إِجّْ ن مِّيسْ. \f ◼ \fr 1:‏3 \ft \+bd ’ذِيبْلَايِيمْ‘\+bd* - ’ثْنَاينْ ن ثْغَايِيطَاثْ ن ثَازَارْثْ‘.\f*  
\v 4 \add خنِّي\add* إِنَّا أَسْ سِيذِي: ”ڒَْاغَا أَسْ س يِيسمْ ن ’يَازْرَاعِيلْ‘، مَاغَارْ شْوَايْثْ نْ ڒْوقْثْ \add وَاهَا\add* ؤُ \add خنِّي\add* نشّْ أَذْ خدْجْصغْ إِذَامّنْ ن يَازْرَاعِيلْ خْ ثَادَّارْثْ ن يَاهُو ؤُ نشّْ أَذْ قْضِيغْ خْ ثْڭلْذَا ن ثَادَّارْثْ ن إِسْرَائِيل. \f ◼ \fr 1:‏4 \ft \+bd ’يَازْرَاعِيلْ‘\+bd* - أَذْ ثَاغْ إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَربِّي أَذْ إِزدْجعْ‘ نِيغْ ’أَربِّي أَذْ إِزَارْعْ‘ نِيغْ ’أَغِيڒْ ن أَربِّي‘.\f*  
\v 5 \bd ذڭْ وَاسّْ نِّي\bd* أَذْ يِيڒِي، أَقَا نشّْ أَذْ أَرْژغْ ڒْقوْسْ ن إِسْرَائِيل ذِي ڒوْضَا ن ثغْزُورْثْ ن يَازْرَاعِيلْ.“ \f ◼ \fr 1:‏5 \ft \+bd ’ڒْقوْسْ ن إِسْرَائِيل‘\+bd* - ثُوغَا إِسْرَائِيل إِتّْوَاسّْننْ بلِّي غَارسْ أَطَّاسْ ن إِمجَّابنْ ن ڒْقوْسْ.\f*   
\m
\v 6 ؤُشَا ثكْسِي نتَّاثْ عَاوذْ س دّيْسثْ، ثُورُووْ-د يدْجِيسْ ؤُشَا إِنَّا أَسْ \add سِيذِي\add*: ”ڒَْاغَا أَسْ س يِيسمْ ن لُو-رُوحَامَا، مَاغَارْ وَارْ أَرّحّْمغْ عَاذْ خْ ثَادَّارْثْ ن إِسْرَائِيل، وَارْ تّْغِيمِيغْ سمّْحغْ أَسنْ. \f ◼ \fr 1:‏6 \ft \+bd ’لُو-رُوحَامَا‘\+bd* - إِسمْ وَانِيثَا-أَ إِخْسْ أَذْ يِينِي ’وَارْ أَرّحْمغْ‘.\f*  
\v 7 \add مَاشَا\add* أَذْ أَرّحْمغْ خْ ثَادَّارْثْ ن يَاهُوذَا ؤُ نشّْ أَذْ ثنْ سّْنجْمغْ س \add ؤُفُوسْ ن\add* سِيذِي، أَربِّي نْسنْ! نشّْ وَارْ ثنْ سّنْجْمغْ س ڒْقوْسْ نِيغْ س سِّيفْ نِيغْ س إِيْسَانْ ؤُڒَا س إِمْنَاينْ.“ \x ◘ \xo 1:‏7 \xt زَاك. 4‏:‏6\x*   
\m
\v 8 \add أَڒَامِي\add* ثكّسْ ؤُطُّوضْ إِ لُو-رُوحَامَا، ثكْسِي \add عَاوذْ\add* س دّيْسثْ ؤُشَا ثُورُووْ-د إِجّْ ن مِّيسْ.  
\v 9 ؤُشَا إِنَّا \add سِيذِي\add*: ”ڒَْاغَا أَسْ س يِيسمْ ن لُو-عَامِّي، مَاغَارْ كنِّيوْ وَارْ ثدْجِيمْ عَاذْ ذ ڒْڭنْسْ إِنُو ؤُ نشّْ وَارْ دْجِيغْ \add عَاذْ ذَا\add* إِ كنِّيوْ.“ \f ◼ \fr 1:‏9 \ft \+bd ’لُو-عَامِّي‘\+bd* - إِسمْ وَانِيثَا-أَ إِخْسْ أَذْ يِينِي ’وَارْ إِدْجِي ڒْڭنْسْ إِنُو‘.\f*   
\b  
\b  
\m  
\c 2
\s1 أَمنْضَارْ ن إِسْرَائِيل ذ وعْذَاڒْ نّسْ  
\m
\v 1 ”أَذْ يِيڒِي ڒْقدّْ ن أَيْثْ ن إِسْرَائِيل أَمْ يجْذِي ن ڒبْحَارْ إِ وَارْ إِزمَّارْ أَذْ إِتّْوَاعْبَارْ ؤُ وَارْ إِزمَّارْ أَذْ إِتّْوَاحْسبْ، ؤُشَا أَذْ ثَافذْ مَانِي ذ أَسنْ نَّانْ: ’كنِّيوْ وَارْ ثدْجِيمْ ذ ڒْڭنْسْ إِنُو!‘، أَذْ أَسنْ إِتّْوَانَّا: ’كنِّيوْ ذ إِحنْجِيرنْ ن أَربِّي إِدَّارنْ!‘ \x ◘ \xo 2:‏1 \xt أَمز. 32‏:‏11؛ رُوم. 9‏:‏25، 26\x*  
\v 2 أَيْثْ ن يَاهُوذَا ذ أَيْثْ ن إِسْرَائِيل أَذْ تّْوَاسّْمُوننْ، أَذْ ڭّنْ إِجّْ ن ؤُمْغَارْ إِ يِيخفْ نْسنْ ؤُ أَذْ ڭعّْذنْ زِي \add مَارَّا\add* ثمُّورْثْ، مَاغَارْ أَسّْ ن يَازْرَاعِيلْ أَذْ يِيڒِي ذ إِجّْ ن وَاسّْ ذ أَمقّْرَانْ. \x ◘ \xo 2:‏2 \xt إِشا. 11‏:‏13؛ إِرْم. 3‏:‏18؛ حِز. 37‏:‏16، 22؛ أَفا. 2‏:‏14، 15، 16\x*  
\v 3 إِنِيمْ إِ وَاوْمَاثنْ نْومْ: ’عمِّي!‘ ؤُ إِ سُويثْمَاثْومْ ’رُوحَامَا!‘ “   
\b  
\m
\v 4 ”ذْعَامْ أَكْ-ذ يمَّاثْومْ، ذْعَامْ، مَاغَارْ نتَّاثْ وَارْ ثدْجِي ذ ثَامْغَارْثْ إِنُو ؤُ نشّْ وَارْ دْجِيغْ ذ أَرْيَازْ نّسْ. أجّْ إِ-ت أَذْ ثكّسْ فَارْقْ-شّْغڒْ نّسْ زڭْ ؤُغمْبُوبْ نّسْ ؤُڒَا ذ زِّينَا زِي جَارْ إِبَّاشْ نّسْ.  
\v 5 نِيغْ أَقَا أَذْ أَسْ كّْسغْ أَرُّوضْ أَذْ ت جّغْ ذ ثَاعَارْيَانْثْ¸ أَذْ ت سَّارْسغْ \add ذِيهَا\add* أَمْ ذڭْ وَاسّْ أَمزْوَارُو إِ ذِي د-ثخْڒقْ، \add وَاهْ،\add* أَذْ ت أَرّغْ ذ إِشْثْ ن ڒخْڒَا، أَذْ ت أَرّغْ أَمْ يِيشْثْ ن ثمُّورْثْ يُوژْغنْ ؤُشَا أَذْ ت جّغْ أَذْ ثمّثْ س ؤُفَاذِي.  
\v 6 نشّْ وَارْ أَرّحْمغْ خْ إِحنْجِيرنْ نّسْ، مَاغَارْ نِيثْنِي ذ إِحنْجِيرنْ \add إِ د-إِخڒْقنْ\add* زِي فَارْقْ-شّْغڒْ.  
\v 7 مَاغَارْ يمَّاثْسنْ أَقَا ثفْسذْ إِخفْ نّسْ، \add وَاهْ،\add* ثنِّي ثُوغَا س دّيْسثْ زَّايْسنْ، ثڭَّا ڒفْضِيحثْ، مَاغَارْ ثقَّارْ: ’أَذْ ضْفَارغْ إِنِّي ذ أَيِي إِعشّْقنْ، إِنِّي ذ أَيِي إِتِّيشنْ أَغْرُومْ إِنُو ذ وَامَانْ إِنُو ذ ثَاضُوفْثْ إِنُو ذ ثِيفّسْثْ إِنُو ذ زّشْثْ إِنُو ذ ثْسسِّيثْ إِنُو.‘  
\v 8 س ؤُيَا، أَقَا أَذْ بلّْعغْ أَبْرِيذْ نّمْ س شْبَارْقْ أَكْ-ذ إِسنَّاننْ ؤُ أَذْ سّْبدّغْ أَغْبَارْ نّسْ، حِيمَا وَارْ ثتِّيفْ \add عَاذْ\add* إِمسْرَاقْ نّسْ.  
\v 9 نتَّاثْ أَذْ ثضْفَارْ إِنِّي ت إِعشْقنْ، مَاشَا وَارْ خَاسنْ ثْحَارّثْ. نتَّاثْ أَذْ خَاسنْ ثَارْزُو، \add مَاشَا\add* وَارْ ثنْ ثتِّيفْ. خنِّي أَذْ ثِينِي: ’نشّْ أَذْعقْبغْ، أَذْ ذوْڒغْ غَارْ ورْيَازْ إِنُو أَمزْوَارُو، مَاغَارْ ذڭْ وُوسَّانْ نِّي ثُوغَا أَيِي مْلِيحْ خْ ڒخُّو.‘  
\v 10 نتَّاثْ وَارْ ثعْقِيڒْ، أَقَا ذ نشّْ إِ ثُوغَا ذ أَسْ إِوْشِينْ إِمنْذِي ذ بِينُو ن جْذِيذْ ذ زّشْثْ، ؤُ أَقَا ذ نشّْ إِ ثُوغَا ذ أَسْ إِوْشِينْ نُّوقَارْثْ س وَاطَّاسْ، ؤُشَا ؤُرغْ \add إِ ذ أَسنْ وْشِيغْ\add* أَقَا ڭِّينْ ث غَارْ بَاعْلْ.  
\v 11 س ؤُيَا إِ غَاعقْبغْ، أَذْ كّْسغْ إِمنْذِي إِنُو ذِي ڒْوقْثْ ن صَّابثْ ؤُڒَا ذ بِينُو إِنُو ن جْذِيذْ ذِي ڒْوقْثْ نّسْ إِتّْوَاڭّنْ ؤُ ثَاضُوفْثْ إِنُو ذ ثِيفّسْثْ إِنُو إِ زِي ثدَّاڒْ ثُوعَّارْينْثْ نّسْ أَذْ \add ثنْثْ\add* قڒْعغْ \add زَّايسْ\add*.  
\v 12 \add خنِّي\add* ڒخُّو أَذْ عَارِّيغْ خْ ڒحْيَا نّسْ زَّاثْ إِ ثِيطَّاوِينْ ن يِينِّي ت إِتّخْسنْ ؤُشَا ؤُڒَا ذ إِجّنْ وَارْ إِزمَّارْ أَذْ ت إِفكّْ زڭْ إِفَاسّنْ إِنُو.  
\v 13 نشّْ أَذْ سّْبدّغْ مَارَّا ڒفْرَاحثْ نّسْ، ؤُرَارنْ نّسْ، ؤُسَّانْ نّسْ ن ؤُبذِّي ن ؤُيُورْ ؤُڒَا ذ ؤُسَّانْ نّسْ ن سّبْثْ، \add وَاهْ،\add* مَارَّا ؤُسَّانْ نّسْ إِتّْوَاڭّنْ.  
\v 14 أَذْ أَردّْدْجغْ ثَازَايَارْثْ نّسْ ذ \add ثْشجَّارْثْ ن\add* وَارْثُو نّسْ إِ زِي ثنَّا: ’ثِينَا ذ ڒْمُونثْ إِ ذ أَيِي وْشِينْ يِينِّي ذ أَيِي إِتّخْسنْ.‘ أَذْ ثنْثْ أَرّغْ ذ إِجّْ ن وزْغَارْ ؤُ ڒْمَاڒْ ن ييَّارْ أَذْ زَّايْسنْثْ شّنْ. \f ◼ \fr 2:‏14 \ft \+bd ’أَزْغَارْ‘\+bd* - نِيغْ ’ڒْغَابثْ‘ نِيغْ ’ثَازْڭَانْثْ‘.\f*  \x ◘ \xo 2:‏14 \xt إِزهد. 80‏:‏13؛ إِشا. 5‏:‏5\x*  
\v 15 نشّْ أَذْ ت وْثغْ خْ ؤُسَّانْ ن ’إِبَاعْلنْ‘، \add ؤُسَّانْ\add* إِ ذِي ثِيوِي-د أَسنْ ثِيوْهِيبِينْ ن ڒبْخُورْ ؤُ ثڭَّا ثَاخْرَازْثْ نّسْ ذ ثْسدّشْثْ نّسْ، ؤُ ثضْفَارْ إِنِّي ت إِتّخْسنْ، \add مَاشَا\add* نتَّاثْ ثتُّو أَيِي!“، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.   
\b  
\m
\v 16 ”س ؤُيَا، خْزَارْ، نشّْ أَذْ ت غَارّغْ، أَذْ ت نذْهغْ غَارْ ڒخْڒَا، ؤُ \add ذِينْ\add* أَذْ سِّيوْڒغْ أَكْ-ذ وُوڒْ نّسْ.  
\v 17 سّنِّي أَذْ أَسْ وْشغْ إِمَارْجَاعنْ نّسْ ن ؤُضِيڒْ ؤُ أَذْ أَرّغْ ثَاغْزُورْثْ ن أَخُورْ ذ ثَاوَّارْثْ ن ڒَايَاسْ. نتَّاثْ أَذْ ذِينِّي ثْغنّجْ أَمْ \add ثْغنّجْ\add* ذڭْ وُوسَّانْ ن ثمْژِي نّسْ، أَمْ خْ وَاسّْ ؤُمِي د-ثفّغْ زِي ثمُّورْثْ ن مِيصْرَا.  
\v 18 \bd ذڭْ وَاسّْ نِّي\bd* إِقَّارْ سِيذِي، أَذْ أَيِي ثْڒَاغِيذْ: ’أَرْيَازْ إِنُو!‘، ؤُ وَارْ ذ أَيِي ثقَّارذْ عَاذْ: ’بَاعْلْ إِنُو!‘  
\v 19 أَذْ أَسْ كّْسغْ إِسْمَاونْ ن ’إِبَاعْلنْ‘ زڭْ ؤُقمُّومْ نّسْ. وَارْ تّْفكَّارنْ عَاذْ ذڭْ إِسْمَاونْ نْسنْ.  
\v 20 \bd ذڭْ وَاسّْ نِّي\bd* أَذْ ڭّغْ إِجّْ ن ڒْعَاهْذْ ذِي طّْوعْ نْسنْ أَكْ-ذ ڒوْحُوشْ ن ڒخْڒَا، أَكْ-ذ إِجْضَاضْ ن ؤُجنَّا ؤُ أَكْ-ذ إِمُودَّارنْ نِّي إِتّْبُوعنْ خْ وُوذمْ ن ثمُّورْثْ. أَذْ كّْسغْ ڒْقوْسْ ذ سِّيفْ ذ ؤُمنْغِي زِي ثمُّورْثْ ؤُ أَذْ ثنْ سَّارّيْحغْ ذِي ڒْهُوذْنثْ. \f ◼ \fr 2:‏20 \ft \+bd ’أَذْ ڭّغْ‘\+bd* - س ثْعِيبْرَانِيثْ ’أَذْ قسّغْ‘. \+bd ’أَذْ كّْسغْ‘\+bd* - س ثْعِيبْرَانِيثْ ’أَذْ أَرْژغْ‘.\f*  \x ◘ \xo 2:‏20 \xt أَيُوبْ 5‏:‏23؛ إِشا. 11‏:‏6؛ حِز. 14‏:‏21؛ 34‏:‏25\x*  
\v 21 نشّْ أَذْ شمْ خضْبغْ إِ ڒبْذَا، \add وَاهْ،\add* أَذْ شمْ خضْبغْ س ثْسڭْذَا ذ ڒْهقّْ، س ثْمخْسِيوْثْ إِشوَّارنْ ذ أَرّحْمثْ.  
\v 22 نشّْ أَذْ شمْ خضْبغْ س ڒَامَانْ، ؤُ شمْ أَذْ ثسّْنذْ سِيذِي. \x ◘ \xo 2:‏22 \xt إِرْم. 31‏:‏33، 34\x*  
\v 23 \bd ذڭْ وَاسّْ نِّي\bd*، إِقَّارْ سِيذِي، أَذْ إِمْسَارْ أَقَا نشّْ أَذْ سْڒغْ غَارْ ؤُجنَّا ؤُ أَجنَّا أَذْ إِسڒْ غَارْ ثمُّورْثْ  
\v 24 ؤُ ثَامُّورْثْ أَذْ ثْسڒْ غَارْ إِمنْذِي ؤُڒَا غَارْ بِينُو ن جْذِيذْ ذ زّشْثْ، ؤُ إِنَا أَذْ سْڒنْ غَارْ يَازْرَاعِيلْ.  
\v 25 نشّْ أَذْ ت زَارْعغْ إِ نشّْ ذِي ثمُّورْثْ ؤُ نشّْ أَذْ أَرّحْمغْ خْ لُو-رُوحَامَا، ؤُ أَذْ إِنِيغْ إِ لُو-عَامِّي: ’شمْ ذ ڒْڭنْسْ إِنُو إِ ثدْجِيذْ!‘، ؤُ \add ڒْڭنْسْ\add* أَذْ يِينِي: ’أَربِّي إِنُو!‘ “ \x ◘ \xo 2:‏25 \xt حُوش. 2‏:‏1؛ رُوم. 9‏:‏26؛ 1 بُط. 2‏:‏10\x*   
\b  
\b  
\m  
\c 3
\s1 حُوشِيعَا أَذْ إِسغْ إِشْثْ ن ثمْغَارْثْ إِزنَّانْ  
\m
\v 1 سِيذِي إِنَّا أَيِي: ”رُوحْ إِشْثْ ن ثْوَاڒَا نّغْنِي، أخْسْ ثَامْغَارْثْ نِّي إِتّْوَاسّْعِيزّنْ زڭْ ؤُمدُّوكّڒْ \add نّسْ\add*، \add مَاشَا\add* ثزْنَا، أَمْ مَامّشْ سِيذِي إِتّخْسْ أَيْثْ ن إِسْرَائِيل، \add مَاشَا\add* نِيثْنِي خزَّارنْ غَارْ إِربِّيثنْ نّغْنِي ؤُ تّخْسنْ \add صّذْقثْ\add* ن وغْرُومْ س زّْبِيبْ.“ \f ◼ \fr 3:‏1 \ft \+bd ’ثنِّي إِتّْوَاسّْعِيزّنْ زڭْ ؤُمدُّوكّڒْ‘\+bd* - إِنِّي إِتّْفسَّارنْ أَذْلِيسْ إِقدّْسنْ غَارْسنْ أَرَّايْ إِفَارْزنْ، مَاشَا نشِّينْ نْضفَّارْ أَرَّايْ إِ إِنَّا أَربِّي إِ حُوشِيعَا بلِّي أَذْ يَاوِي جُومِيرْ عَاوذْ ذ ثَامْغَارْثْ نّسْ. ذِي أَيَا د-إِتَّاسنْ أَوَارْنِي ثَانِيثَا إِبَانْ-د أَقَا إِتّْخصَّا إِ حُوشِيعَا أَذْ إِخدْجصْ صَّاذَاقْ عَاوذْ، مَاشَا قلّْ خْ مِينْ ثُوغَا نُّومنْ يرْيَازنْ أَذْ خدْجْصنْ (ڒْقِيمثْ ن صَّاذَاقْ ثُوغَا ت 50 ن ڒْوزْنَاثْ ن نُّوقَارْثْ - خْزَارْ أَعَوذ. 22‏:29)، مَاشَا أَمُورَا إِخدْجصْ حُوشِيعَا ڒْقِيمثْ ن 30 ن ڒْوزْنَاثْ ن نُّوقَارْثْ وَاهَا. أَقَا بَالَاكْ ثُوغَا مَانْ أَيَا مِينْزِي جُومِيرْ ثُوغَا ثْفسّذْ أَرِّيمثْ نّسْ.\f*  
\v 2 \add س ؤُينِّي\add* سْغِيغْ ت إِ نشّْ س خمّسْطَاشْ ن \add ؤُقِييَّاثْ ن\add* نُّوقَارْثْ ؤُ س إِجّْ ن ؤُحُومِيرْ إِفيّْضنْ ن إِمنْذِي.  
\v 3 نشّْ نِّيغْ أَسْ: ”شمْ أَذْ غَارِي ثقِّيمذْ أَطَّاسْ ن وُوسَّانْ. وَارْ تّڭّْ شَا فَارْقْ-شّْغڒْ ؤُ وَارْ تِّيڒِي ن إِجّْ ن ورْيَازْ نّغْنِي، ؤُشَا ؤُڒَا ذ نشّْ أَذْ ڭّغْ أَمنِّي أَكِيذْسمْ.“ \x ◘ \xo 3:‏3 \xt أَعَوذ. 21‏:‏11\x*  
\v 4 مَاغَارْ أَيْثْ ن إِسْرَائِيل أَذْ قِّيمنْ أَطَّاسْ ن وُوسَّانْ بْڒَا أَجدْجِيذْ، بْڒَا ڒْحَاكمْ، بْڒَا ثَاغَارْصْثْ، بْڒَا أَمَايْضُو \add إِقدّْسنْ\add*، بْڒَا أَپَالْطُو \add ن ؤُكهَّانْ\add* ذ ڒخْيَاڒَاثْ ن لْ-أَصْنَامْ. \x ◘ \xo 3:‏4 \xt حُوش. 10‏:‏3\x*  
\v 5 أَوَارْنِي أَسْ أَذْ د-ذوْڒنْ أَيْثْ ن إِسْرَائِيل¸ أَذْ أَرْزُونْ خْ سِيذِي، أَربِّي نْسنْ ؤُ خْ ذَاوُوذْ، أَجدْجِيذْ نْسنْ. ذڭْ ؤُنڭَّارْ ن وُوسَّانْ أَذْ د-أَسنْ تَّارْجِيجِينْ غَارْ سِيذِي ذ ثْشُونِي نّسْ. \x ◘ \xo 3:‏5 \xt إِشا. 2‏:‏2؛ إِرْم. 30‏:‏9؛ حِز. 34‏:‏23؛ 37‏:‏22؛ مِيخَا 4‏:‏1\x*   
\b  
\b  
\m  
\c 4
\s1 أَوَاڒْ ن سِيذِي ضِيدّْ إِ إِكهَّاننْ ذ ڒْڭنْسْ  
\m
\v 1 ”سْڒمْ إِ وَاوَاڒْ ن سِيذِي، أَيْثْ ن إِسْرَائِيل، مَاغَارْ سِيذِي إِكْسِي ثَانْفُوتْشْ ضِيدّْ إِ إِمزْذَاغْ ن ثمُّورْثْ، مِينْزِي وَارْ ذِينْ يدْجِي ڒَامَانْ نِيغْ ثَامخْسِيوْثْ إِشوَّارنْ ؤُڒَا ذ ثُوسّْنَا ن أَربِّي ذِي ثمُّورْثْ. \x ◘ \xo 4:‏1 \xt مِيخَا 6‏:‏2\x*  
\v 2 ثِيكّْوُورَا ذ إِخَارِّيقنْ ذ ؤُمنْغِي ذ ثُوشّفّْرَا ذ زِّينَا! أَقَا أَثنْ دُّوقّْزنْ، أَسِيزّڒْ ن إِذَامّنْ أَوَارْنِي إِ ؤُسِيزّڒْ ن إِذَامّنْ.  
\v 3 خْ ؤُيَا ثْشطّنْ ثَامُّورْثْ ؤُ كُوڒْ إِجّنْ إِ ذَايسْ إِزدّْغنْ إِتَّاژغْ: ڒوْحُوشْ ن ييَّارْ ذ يِيجْضَاضْ ن ؤُجنَّا، \add وَاهْ،\add* ؤُڒَا ذ إِسڒْمَانْ ذِي ڒبْحَارْ تّْوَاكّْسنْ.  
\v 4 مَاشَا ؤُشْثْ خْ ورْيَازْ نِّي إِ ذ غَا إِكْسِينْ ثَانْفُوتْشْ ؤُ ؤُشْثْ خْ ورْيَازْ نِّي إِ غَا إِشثْشَانْ. ڒْڭنْسْ نّشْ أَخْمِي يِينِّي إِتّمْشُوبّْشنْ أَكْ-ذ ؤُكهَّانْ.  
\v 5 س ؤُزِيڒْ أَذْ ثنْقَارْضذْ ؤُ س دْجِيڒثْ أَذْ إِنْقَارْضْ عَاذْ أَنَابِي أَكِيذكْ، ؤُ يمَّاشْ أَذْ ت سّْهلّْكغْ.  
\v 6 ڒْڭنْسْ إِنُو إِذْوڒْ ذ أَيْنَاوْ، مِينْزِي أَقَا-ث بْڒَا ثُوسّْنَا. ؤُمِي شكْ ثنْضَارذْ ثُوسّْنَا، نْضَارغْ شكْ مَاحنْذْ وَارْ ذ أَيِي ثْسخَّارذْ \add عَاذْ\add* أَمْ ؤُكهَّانْ. \add ؤُمِي\add* شكْ ثتُّوذْ شَّارِيعَا ن أَربِّي، ؤُڒَا ذ نشّْ أَذْ تُّوغْ إِحنْجِيرنْ نّشْ.  
\v 7 مَامّشْ مَا وسْعنْ¸ أَرْنِينْ ذِي دّْنُوبْ أَكِيذِي. أَذْ أَرّغْ شَّانْ نْسنْ ذْ ڒفْضِيحثْ.  
\v 8 نِيثْنِي تّتّنْ زِي دّْنُوبْ ن ڒْڭنْسْ إِنُو ؤُ س وُوڒْ نْسنْ تَّارَّانْ مژْرِي إِ ڒْمُوعْصِييّثْ نْسنْ.  
\v 9 أَمْ مَامّشْ \add إِ إِدْجَا\add* ؤُكهَّانْ، أَمُّو إِ غَا يِيڒِي ؤُڒَا ذ ڒْڭنْسْ. نشّْ أَذْ ذَايسْ خڒْفغْ إِبْرِيذنْ نّسْ ؤُ ثِيمڭَّا نّسْ أَذْ أَسْ ثنْثْ خدْجْصغْ. \x ◘ \xo 4:‏9 \xt إِشا. 24‏:‏2\x*  
\v 10 نِيثْنِي أَذْ شّنْ، مَاشَا وَارْ ثتّْجِّيوِيننْ شَا، نِيثْنِي أَذْ سّْفسْذنْ إِخفْ نْسنْ، مَاشَا وَارْ تّْمَارنْينْ، مِينْزِي نِيثْنِي سمْحنْ ذڭْ ؤُحتُّو ن \add ثْسخَّارْثْ إِ\add* سِيذِي. \x ◘ \xo 4:‏10 \xt مِيخَا 6‏:‏14\x*  
\v 11 فَارْقْ-شّْغڒْ ذ بِينُو ؤُ بِينُو ن جْذِيذْ أَقَا كّْسنْ ؤُڒْ \add إِ بْنَاذمْ\add*.  
\v 12 ڒْڭنْسْ إِنُو إِتّْسقْسَا \add صَّانَامْ نّسْ\add* ن ؤُكشُّوضْ ؤُ ثَاغَّارْشْثْ نّسْ أَذْ أَسْ ثوْشْ ڒخْبَارْ، مِينْزِي بُوحْبڒْ ن فَارْقْ-شّْغڒْ إِغَارَّا إِ-ثنْ أَڒَامِي فّْغنْ س فَارْقْ-شّْغڒْ نْسنْ زِي سَاذُو \add أَحطُّو ن\add* أَربِّي نْسنْ. \x ◘ \xo 4:‏12 \xt حُوش. 5‏:‏4\x*  
\v 13 خْ ثْقِيشَّاثْ ن إِذُورَارْ تّْقدَّامنْ ثِيغَارْصَا ؤُ خْ ثوْرِيرِيرِينْ تَّاوْينْ ثِيوْهِيبِينْ ن ڒبْخُورْ، سَاذُو ڒْبدْجُوضْ ذ صّفْصَافْ ذ ثْشجَّارْثْ ن يِيڭّْ، مِينْزِي ثِيڒِي نْسنْ ثصْبحْ. خْ ؤُيَا سّفْسَاذنْثْ يسِّيثْومْ إِخفْ نْسنْثْ ؤُ ثِيسْڒَاثِينْ نْومْ تَّارژَّانْثْ ڒمْڒَاشْ س زِّينَا. \x ◘ \xo 4:‏13 \xt إِشا. 1‏:‏29؛ 57‏:‏7؛ حِز. 20‏:‏28\x*  
\v 14 مَاشَا نشّْ وَارْ سِّيوِيضغْ ڒْحُوكْمْ خْ يسِّيثْومْ ؤُمِي سّْفسْذنْثْ إِخفْ نْسنْثْ ؤُڒَا خْ ثسْڒَاثِينْ نْومْ ؤُمِي تَّارژَّانْثْ ڒمْڒَاشْ س زِّينَا. أَقَا نِيثنْثِي حُوزنْثْ إِخفْ نْسنْثْ أَكْ-ذ ثمْغَارِينْ ن فَارْقْ-شّْغڒْ ؤُ تّْقدَّامنْثْ ثِيغَارْصَا \add جْمِيعْ\add* أَكْ-ذ ثمْغَارِينْ ن فَارْقْ-شّْغڒْ ن زَّاوشْثْ. أَذْ إِوْضَا ڒْڭنْسْ إِ وَارْ غَارْ إِدْجِي ڒعْقڒْ.“   
\m
\v 15 ”وَاخَّا شكْ، إِسْرَائِيل، ثسّفْسذذْ إِخفْ نّشْ، وَارْ تَّارِّي ؤُڒَا ذ يَاهُوذَا ذ بُو-ؤُمَارْوَاسْ. وَارْ د-تِّيسِيمْ غَارْ جِيلْجَالْ، وَارْ تّْڭعَّاذمْ غَارْ بَايْثْ-أَوَانْ ؤُ وَارْ تّْجَادْجَامْ: ’\add س ثِيذتّْ أَمْ\add* إِدَّارْ سِيذِي!‘  
\v 16 مِينْزِي إِسْرَائِيل ذَايسْ ثَاغنَّانْثْ أَمْ يِيشْثْ ن ثْفُونَاسْثْ ثْعَارّنْ. \add خنِّي\add* ڒخُّو، أَذْ ثنْ يَارْوسْ سِيذِي أَمْ يِيجّْ ن يزْمَارْ أَمژْيَانْ ذڭْ إِيَّارْ إِوسْعنْ أَطَّاسْ.  
\v 17 إِفْرَايِيمْ إِقّنْ إِخفْ نّسْ أَكْ-ذ ڒخْيَاڒَاثْ ن لْ-أَصْنَامْ، أجّْ إِ-ث، إِسْمحْ ذَايسْ.  
\v 18 ثَاسسِّيثْ نْسنْ ذَايسْ سّمْ، تّڭّنْ فَارْقْ-شّْغڒْ أَوَارْنِي إِ فَارْقْ-شّْغڒْ، ؤُ إِمحْضَاينْ نْسنْ تّخْسنْ مْغِيرْ ڒفْضِيحثْ وَاهَا.  
\v 19 إِشْثْ ن ثْحَارْيَاضْثْ ثسّْجبْذْ إِ-ت س وَافْرِيونْ نّسْ: أَقَا نِيثْنِي أَذْ ذوْڒنْ تّْسضْحَانْ زِي ثْغَارْصِي نْسنْ.“   
\b  
\b  
\m  
\c 5
\s1 ڒْحُوكْمْ خْ إِسْرَائِيل ذ إِكهَّاننْ نّسْ  
\m
\v 1 ”سْڒمْ أَيَا، \add كنِّيوْ\add* إِكهَّاننْ، حْضَامْ \add كنِّيوْ أَيْثْ ن\add* ثَادَّارْثْ ن إِسْرَائِيل ؤُ وْشمْ أَمزُّوغْ، كنِّيوْ، \add أَيْثْبَابْ ن\add* ثَادَّارْثْ ن ؤُجدْجِيذْ، مَاغَارْ ثْذوْڒمْ ذ إِجّْ ن ڒْفخْ ذِي مِيصْفَاثْ ذ إِشْثْ ن ثْرَاشَّا يَارزْمنْ خْ \add وذْرَارْ ن\add* ثابُورْ.  
\v 2 إِنِّي إِ د-إِتّفّْغنْ زڭْ وبْرِيذْ سِّيدْجْغنْ ثَاسْرَافْثْ ن ونْغَايْ، مَاشَا نشّْ أَذْ ثنْ عَاقْبغْ مَارَّا.  
\v 3 نشّْ سّْنغْ إِفْرَايِيمْ ؤُ إِسْرَائِيل وَارْ إِزمَّارْ أَذْ زَّايِي إِنُّوفَّارْ. مَاغَارْ ڒخُّو إِسّفْسذْ إِفْرَايِيمْ إِخفْ نّسْ، إِسْرَائِيل إِسّخْمجْ إِخفْ نّسْ.  
\v 4 ثِيمڭَّا نْسنْ ثْمنّْعنْثْ إِ-ثنْ أَذْ د-ذوْڒنْ غَارْ أَربِّي، مَاغَارْ إِجّْ ن بُوحْبڒْ ن فَارْقْ-شّْغڒْ أَقَا-ث ذِي ڒْوسْطْ نْسنْ ؤُشَا وَارْ سِّيننْ سِيذِي. \x ◘ \xo 5:‏4 \xt حُوش. 4‏:‏12\x*  
\v 5 أَعفَّارْ ن إِسْرَائِيل أَذْ خَاسْ إِذْعَا س بْطَايْطَايْ. إِسْرَائِيل ذ إِفْرَايِيمْ أَذْ نْقَارْضنْ زِي ڒْمُوعْصِييّثْ نْسنْ ؤُڒَا ذ يَاهُوذَا أَذْ كِيذْسنْ إِنْقَارْضْ. \x ◘ \xo 5:‏5 \xt حُوش. 7‏:‏10\x*  
\v 6 نِيثْنِي أَذْ أَڭّْوجنْ أَكْ-ذ وُودْجِي نْسنْ ذ إِفُونَاسنْ ذ ثْفُونَاسِينْ نْسنْ، حِيمَا أَذْ أَرْزُونْ خْ سِيذِي، مَاشَا نِيثْنِي وَارْ ث تِّيفنْ. نتَّا أَقَا إِسّْنُوفَّارْ إِخفْ نّسْ خَاسنْ.  
\v 7 نِيثْنِي غْذَارنْ سِيذِي مَاغَارْ نِيثْنِي جِّينْ-د ثَارْوَا ن فَارْقْ-شّْغڒْ. ڒخُّو أَذْ ثنْ يشّْ ؤُيُورْ أَمَايْنُو أَكْ-ذ ثْسقَّاڒْ نْسنْ ن ڒْوَارْثْ.“   
\m
\v 8 ”سُوضمْ ذڭْ ؤُيِيشّْ ن إِشَارِّي ذِي جِيبْعَا، ذِي ڒْبُوقْ ذِي رَامَا، أَذْ سْغُوينْ \add إِمزْذَاغْ ن\add* بَايْثْ-أَوَانْ: ’أَوَارْنِي أَشْ، أَ بِينْيَامِينْ!‘  
\v 9 إِفْرَايِيمْ أَذْ إِذْوڒْ ذ \add إِشْثْ ن ڒْقشْعثْ ن\add* ؤُنخْڒِيعْ ذڭْ وَاسّْ ن لْعِيقَابْ. نشّْ بَارّْحغْ جَارْ ثْقبَّاڒْ ن إِسْرَائِيل مِينْ إِتّْوَاڭّْ أَذْ إِمْسَارْ.  
\v 10 ڒْحُوكَّامْ ن يَاهُوذَا تّڭّنْ أَمْ يِينِّي إِسّْمُوطُّوينْ إِژْرَا ن ويْمِيرْ. نشّْ أَذْ خَاسنْ زدْجْعغْ أَذُوقّزْ إِنُو \add ن ؤُفُوڭمْ\add* أَمْ وَامَانْ.“   
\m
\v 11 ”إِفْرَايِيمْ إِتّْوَاحْصَارْ، ڒْحقّْ إِتّْوَاڒْبزْ، مَاغَارْ إِعْجبْ أَسْ مَاحنْذْ أَذْ إِضْفَارْ إِشْثْ ن ثوْصيّثْ \add ن ڒْبَاطڒْ\add*.  
\v 12 نشّْ أَمْ ثْشِينْذَا إِ إِفْرَايِيمْ ؤُ أَمْ ؤُرصُّوضْ إِ ثَادَّارْثْ ن يَاهُوذَا.  
\v 13 \add ؤُمِي\add* إِژْرَا إِفْرَايِيمْ ڒهْڒَاشْ نّسْ ؤُ يَاهُوذَا ثَارحْسِيثْ نّسْ، يُويُورْ إِفْرَايِيمْ غَارْ أَشُّورْ، إِسّكّْ \add إِجّْ ن ؤُرقَّاسْ\add* غَارْ ؤُجدْجِيذْ يَارِيبْ. \add مَاشَا\add* وَانِيثَا وَارْ إِزمَّارْ أَذْ كنِّيوْ إِسّْڭنْفَا ؤُ وَارْ خَاومْ إِكسِّي ثَارحْسِيثْ نْومْ. \f ◼ \fr 5:‏13 \ft \+bd ’يَارِيبْ‘\+bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَمْشُوبّشْ‘.\f*  
\v 14 مَاغَارْ نشّْ أَذْ إِڒِيغْ إِ إِفْرَايِيمْ أَمْ ويْرَاذْ إِزهَّارنْ ؤُ أَمْ ويْرَاذْ أَمژْيَانْ إِ ثَادَّارْثْ ن يَاهُوذَا. نشّْ، \add وَاهْ\add* نشّْ، أَذْ مزّْقغْ ؤُ \add خنِّي\add* أَذْ ؤُيُورغْ، أَذْ ث أَوْيغْ ؤُشَا وَارْ ذِينْ وِي غَا إِفكّنْ.  
\v 15 نشّْ أَذْ فّْغغْ ؤُ \add خنِّي\add* أَذْعقْبغْ غَارْ ومْشَانْ إِنُو، أَڒْ غَا نعْمنْ ؤُ أَذْ أَرْزُونْ ؤُذمْ إِنُو. ذِي ڒحْصَارثْ نْسنْ أَذْ خَافِي أَرْزُونْ زِيشْ غَارْ صّْبحْ.“   
\b  
\b  
\m  
\c 6
\s1 أَڒَاغِي ن حُوشِيعَا إِ تُّوبثْ  
\m
\v 1 ”أَسمْ-د، أَذْ د-نذْوڒْ غَارْ سِيذِي، مَاغَارْ نتَّا إِقزَّارْ، \add مَاشَا\add* أَذْ أَنغْ إِسّْڭنْفَا، نتَّا إِوْثَا، \add مَاشَا\add* أَذْ أَنغْ إِشْفنْ.  
\v 2 أَوَارْنِي ثْنَاينْ ن وُوسَّانْ أَذْ أَنغْ يَارّْ غَارْ ثُوذَارْثْ، ذڭْ وَاسّْ وِيسّْ ثْڒَاثَا أَذْ أَنغْ إِسّْنكَّارْ ؤُ نشِّينْ أَذْ ندَّارْ زَّاثْ إِ وُوذمْ نّسْ.  
\v 3 \add خنِّي\add* أَذْ نسّنْ، أَذْ نضْفَارْ مَاحنْذْ أَذْ نسّنْ سِيذِي. أَضْهَارْ نّسْ إِمْثنْ أَمْ ثُوفُّوثْ ن ڒفْجَارْ. أَذْ غَارْنغْ د-يَاسْ أَمْ ونْژَارْ، أَمْ ونْژَارْ ن أَرْبِيعْ نِّي إِسَّارْضَابنْ ثَامُّورْثْ.“ \f ◼ \fr 6:‏3 \ft \+bd ’أَرْبِيعْ‘\+bd* - نِيغْ ’ثَافْسُوثْ‘\f*  \x ◘ \xo 6:‏3 \xt إِزهد. 19‏:‏5، 6\x*   
\m
\v 4 ”مِينْ أَكِيذكْ غَا ڭّغْ، \add أَ\add* إِفْرَايِيمْ، مِينْ أَكِيذكْ غَا ڭّغْ، \add أَ\add* يَاهُوذَا. ثَامخْسِيوْثْ نْومْ إِشوَّارنْ ثتّڭّْ أَمْ ؤُسيْنُو غَارْ ثفُّوثْ ؤُ أَمْ نّْذَا إِڭعّْذنْ ؤُشَا \add خنِّي\add* إِقطَّا.  
\v 5 خْ ؤُيَا نشّْ قسّغْ \add ثنْ\add* س \add ثْمِيجَّا ن\add* إِنَابِييّنْ \add أَمْ\add* س إِجّْ ن ؤُيڒْزِيمْ. نشّْ نْغِيغْ ثنْ س وَاوَاڒنْ ن ؤُقمُّومْ إِنُو. ڒحْكَامَاثْ خَاكْ \add أَمشْنَاوْ\add* ثْفَاوْثْ إِنُّوفْسْڒنْ.  
\v 6 مِينْزِي تّخْسغْ ثَامخْسِيوْثْ إِشوَّارنْ، وَارْ إِدْجِي ثَاغَارْصْثْ، ؤُ ثُوسّْنَا ن سِيذِي \add تّخْسغْ ت\add* خْ ثْغَارْصَا ن وشْمَاضْ.“ \x ◘ \xo 6:‏6 \xt مت. 9‏:‏13؛ 12‏:‏7\x*   
\m
\v 7 ”نِيثْنِيعدَّانْ خْ ڒْعَاهْذْ أَمْ أَذَامْ. ذِينِّي إِ ذ أَيِي غْذَارنْ. \x ◘ \xo 6:‏7 \xt حُوش. 8‏:‏1\x*  
\v 8 جِيلْعَاذْ ذ إِشْثْ ن ثنْذِينْثْ ن يِينِّي إِتّڭّنْ ڒْمُوعْصِييّثْ، ثشُّورْ س إِذَامّنْ.  
\v 9 أَمْ يِيجّْ ن بَانْذِييَّا ن إِخوَّاننْ إِ إِتّْرَاجَانْ شَا ن يِيجّنْ، أَمُّو \add إِ ثدْجَا\add* ثرْفِيقْثْ ن إِكهَّاننْ. نِيثْنِي نقّنْ ذڭْ وبْرِيذْ إِ د إِتَّاوْينْ غَارْ شَاكِيمْ، مَاغَارْ نِيثْنِي تّڭّنْ ڒفْضَايحْ \add وَاهَا\add*.  
\v 10 نشّْ تّْوَاڒِيغْ ثَامسْڒَاشْثْ ثسّْنخْڒَاعْ ذِي ثَادَّارْثْ ن إِسْرَائِيل، خْزَارْ، فَارْقْ-شّْغڒْ ن إِفْرَايِيمْ، إِسْرَائِيل ثسّخْمجْ إِخفْ نّسْ.“   
\m
\v 11 ”\add وَاخَّا أَمنِّي\add*، \add أَ\add* يَاهُوذَا، أَقَا ثمَّارْسْ إِشْثْ ن صَّابثْ إِ شكْ، خْمِي د غَا سّْعقْبغْ إِمحْبَاسْ ن ڒْڭنْسْ إِنُو.“   
\b  
\b  
\m  
\c 7
\s1 إِفْرَايِيمْ وَارْ إِخْسْ أَذْ إِثُوبْ  
\m
\v 1 ”أَمْ سّْڭنْفِيغْ إِسْرَائِيل، ثتّْوَاعَارّْ ڒْمُوعْصِييّثْ ن إِفْرَايِيمْ ذ ثُوعفّْنَا ن سَامَارْيَا، مَاغَارْ نِيثْنِي تّڭّنْ س ڒْغشّْ. أَشفَّارْ إِتَّاذفْ ؤُ إِشْثْ ن بَانْذِييَّا ثتّْكشَّاضْ ذِي بَارَّا.  
\v 2 \add مَاشَا\add* وَارْ قَّارنْ \add عمَّارْصْ\add* ذڭْ وُوڒْ نْسنْ، أَقَا نشّْ أَذْ خَارّْصغْ ذِي مَارَّا ڒْغَارْ نْسنْ. خنِّي ڒخُّو، نّْضنْثْ أَسنْ ثْمڭَّا نْسنْ، أَقَا أَثنْثْ زَّاثْ إِ وُوذمْ إِنُو.  
\v 3 نِيثْنِي سّْفْرَاحنْ أَجدْجِيذْ س ڒْغَارْ نْسنْ ؤُ ڒْحُوكَّامْ \add سّْفْرَاحنْ ثنْ\add* س إِخَارِّيقنْ نْسنْ.  
\v 4 نِيثْنِي مَارَّا ذ إِمْزنَّاينْ، أَقَا أَثنْ أَمْ يِيجّْ ن ؤُفَارَّانْ نِّي إِتّْوَاسّحْمَانْ زڭْ ؤُخبَّازْ. وَانِيثَا أَذْ إِسّْبدّْ زڭْ ؤُشمُّوضْ أَوَارْنِي ڒَامِي ڭّْوِينْ أَرشْثِي أَڒْ إِسْممْ \add قَاعْ\add*.  
\v 5 ذڭْ وَاسّْ ن ؤُجدْجِيذْ نّغْ سّْهڒْشنْ ڒْحُوكَّامْ إِخفْ نْسنْ س ڒْحَاذُوقْ ن بِينُو. نتَّا إِسّْوِيژّضْ أَفُوسْ نّسْ إِ يِيمسْثهْزَاينْ.  
\v 6 خْمِي د-تّْقَارَّابنْ، \add يَارقّْ\add* ؤُڒْ نْسنْ أَمْ يِيجّْ ن ؤُفَارَّانْ زِي ثْحْرَايْمشْثْ نْسنْ. إِتّطّصْ ؤُخبَّازْ نْسنْ دْجِيڒثْ ثكْمڒْ. غَارْ صّْبحْ يَارقّْ \add ؤُفَارَّانْ\add* أَمْ ثْمسِّي إِتّحْذُوذُوقنْ.  
\v 7 نِيثْنِي مَارَّا حمَّانْ أَمْ يِيجّْ ن ؤُفَارَّانْ ؤُ نِيثْنِي تّتّنْ ڒْقُوضَاثْ نْسنْ. مَارَّا إِجدْجِيذنْ نْسنْ أَذْ وْضَانْ، وَارْ ذِينْ ؤُڒَا ذ إِجّْ جَارْ أَسنْ إِ د خَافِي غَا إِڒَاغَانْ.“   
\b  
\m
\v 8 ”إِفْرَايِيمْ إِجَّا إِخفْ نّسْ إِسُّورْ جَارْ ڒڭْنُوسْ، إِفْرَايِيمْ ذ إِشْثْ ن ثفْضِيڒْثْ وَارْ ثتّْوَاسّْنقْڒبْ شَا. \x ◘ \xo 7:‏8 \xt إِزهد. 106‏:‏35\x*  
\v 9 إِبَارَّانِييّنْ سَارْضنْ جّهْذْ نّسْ، وَارْ أَكِيذسْ إِتِّيشِي. ؤُڒَا ذ أَشُوَّافْ نّسْ إِتّْشَابْ، وَارْ أَكِيذسْ إِتِّيشِي.  
\v 10 أَعفَّارْ ن إِسْرَائِيل أَذْ خَاسْ إِذْعَا، \add مَاغَارْ\add* نِيثْنِي وَارْ دِّيكّْوِيڒنْ شَا غَارْ سِيذِي، أَربِّي نْسنْ، ؤُ وَارْ ث أَرْزُونْ شَا ذِي مَارَّا مَانْ أَيَا. \x ◘ \xo 7:‏10 \xt حُوش. 5‏:‏5\x*  
\v 11 إِفْرَايِيمْ إِڭَّا أَمْ يِيشْثْ ن ثذْبِيرْثْ أَحَافِي، وَارْ ذَايسْ ڒفْهَامثْ. نِيثْنِي تّْڒَاغَانْ خْ مِيصْرَا، ڭُّورنْ غَارْ أَشُّورْ.  
\v 12 خْمِي ڭُّورنْ نِيثْنِي، تّْبزَّاعغْ نشّْ ثْرَاشَّا إِنُو خَاسنْ، أَذْ ثنْ د-سّهْوِيغْ أَمْ يِيجْضَاضْ ن ؤُجنَّا، أَذْ ثنْ وبّْخغْ خْ ڒحْسَابْ ن ڒخْبَارْ زِي جّْهثْ ن ثْمسْمُونْثْ نْسنْ.  
\v 13 ؤُشْثْ خَاسنْ مَاغَارْ نِيثْنِي أَروْڒنْ زَّايِي. أَكحّضْ خَاسنْ، مَاغَارْ نِيثْنِيعدَّانْ خَافِي. نشّْ ڭِّيغْ أَذْ ثنْ فْذِيغْ، مَاشَا نِيثْنِي نَّانْ خَافِي إِخَارِّيقنْ.  
\v 14 نِيثْنِي وَارْ د-سْغُوينْ شَا غَارِي س وُوڒْ نْسنْ، خْمِي طّْصنْ نِيثْنِي خْ ڒشْثُو نْسنْ تّْشثْشَانْ. نِيثْنِي تّْمُونَانْ ذِي طّْوعْ ن إِمنْذِي ذ بِينُو ن جْذِيذْ، أَقَا تّْغنَّانْ خَافِي.  
\v 15 نشّْ ذَارّْبغْ ؤُ سّْجهْذغْ إِغَادْجنْ نْسنْ، \add مَاشَا\add* نِيثْنِي تّْخَارَّاصنْ ذَايِي ذِي ڒْغَارْ.  
\v 16 نِيثْنِي تّْعَاقَّابنْ، مَاشَا وَارْ إِدْجِي غَارْ ؤُمْعُودْجِي خْ كُوڒْشِي. أَقَا أَثنْ أَمْ يِيجّْ ن ڒْقوْسْ إِخطَّانْ، ڒْحُوكَّامْ نْسنْ وطَّانْ زِي سِّيفْ، زِي سمّْ إِنقّنْ ن يِيڒسْ نْسنْ. س ؤُينِّي أَذْ خَاسنْ ڭّنْ ثِيضحَّاشْ ذِي ثمُّورْثْ ن مِيصْرَا.“ \x ◘ \xo 7:‏16 \xt إِزهد. 78‏:‏57\x*   
\b  
\b  
\m  
\c 8
\s1 إِقَارّبْ-د ڒْحُوكْمْ خْ وعْبذْ ن إِفْرَايِيمْ إِ لْ-أَصْنَامْ  
\m
\v 1 ”ڭّمْ إِشّْ ن إِشَارِّي \add إِ ؤُسُوضِي\add* غَارْ ؤُقمُّومْ نّشْ. أَمْ يِيجّْ ن ؤُڭِيذرْ \add إِطَّاوْ نتَّا\add* سنّجْ إِ ثَادَّارْثْ ن سِيذِي، مَاغَارْ نِيثْنِيعدَّانْ خْ ڒْعَاهْذْ إِنُو ؤُغوّْغنْ خْ شَّارِيعَا إِنُو. \x ◘ \xo 8:‏1 \xt أَعَوذ. 28‏:‏49؛ حُوش. 6‏:‏7 \x*  
\v 2 نِيثْنِي أَذْ خَافِي د-ڒَْاغَانْ: ’أَربِّي إِنُو، نشِّينْ، إِسْرَائِيل، أَقَا نسّنْ شكْ!‘  
\v 3 إِسْرَائِيل إِنْضَارْ مِينْ إِصبْحنْ، ڒعْذُو أَذْ ث إِضْفَارْ.   
\m
\v 4 نِيثْنِي ڭِّينْ \add خَاسنْ\add* إِجدْجِيذنْ، \add مَاشَا\add* نِيثْنِي وَارْ دْجِينْ شَا زَّايِي، نِيثْنِي أَرشّْحنْ ڒْحُوكَّامْ، مَاشَا نشّْ وَارْ \add ت\add* سِّينغْ. نِيثْنِي ڭِّينْ ڒخْيَاڒَاثْ ن لْ-أَصْنَامْ إِ يِيخفْ نْسنْ، س ؤُينِّي أَذْ إِتّْوَاقسّْ \add ڒخْيَاڒْ نِّي\add*.  
\v 5 أَعجْمِي نّشْ ذ إِجّْ ن نّْعِي، \add أَ\add* سَامَارْيَا! أَغْضَابْ إِنُو يَارقّْ قِيبَاتْشْ نْسنْ. أَڒْ مڒْمِي غَا قِّيمنْ نِيثْنِي وَارْ زمَّارنْ أَذْ كْسِينْ ثَازْذُوڭِي؟ \f ◼ \fr 8:‏5 \ft \+bd ’أَعجْمِي نّكْ‘\+bd* - أَعجْمِي-يَا وَارْ ثُوغِي إِبدّْ ذِي سَامَارْيَا، مَاشَا ذِي بِيثِيلْ (خْزَارْ حُوشِيعَا 10‏:5، 15).\f*  
\v 6 مَاغَارْ \add إِفّغْ-د ڒخْيَاڒْ ن صَّانَامْ\add* زِي إِسْرَائِيل، أَقَا إِجّْ ن بُو-صّنْعثْ إِڭَّا إِ-ث ؤُ وَانِيثَا وَارْ إِدْجِي ذ أَربِّي. وَاهْ، \add أَذْ إِذْوڒْ ڒخْيَاڒْ\add* ذ إِوثْوِيثنْ، أَعجْمِي ن سَامَارْيَا.  
\v 7 مَاغَارْ نِيثْنِي زَارّْعنْ أَسمِّيضْ ؤُ مجَّارنْ ثَاحَارْيَاضْثْ. وَارْ تِّيفنْ \add ثِيذْرِينْ\add* غَارْ إِغدُّوينْ، ؤُ زڭْ إِمنْذِي إِبدّنْ وَارْ زَّايْسنْ تّڭّنْ سّْمِيذْ، نِيغْ أَذْ إِتّْوَاڭّْ، \add مَاشَا\add* أَذْ ث صَارْضنْ إِبَارَّانِييّنْ.“   
\m
\v 8 ”أَقَا إِسْرَائِيل إِتّْوَاصَارْضْ. \bd ڒخُّو\bd* ذوْڒنْ أَمْ يِيشْثْ ن ڒْقشْعثْ جَارْ ڒڭْنُوسْ، وَارْ د-ثُوسِي خْ ڒْخَاضَارْ إِ حذْ.  
\v 9 مَاغَارْ نِيثْنِي ڭعّْذنْ غَارْ أَشُّورْ. إِجّْ ن وغْيُوڒْ ن ڒخْڒَا إِتّْغِيمَا إِ يِيخفْ نّسْ وَاهَا، \add مَاشَا إِنِّي ن\add* إِفْرَايِيمْ تّْخدْجَاصنْ إِ إِمْحِيبَّانْ \add نْسنْ\add*.  
\v 10 وَاخَّا نِيثْنِي زّنْزنْ إِخفْ نْسنْ إِ ڒڭْنُوسْ، مَاشَا ڭُّورْ \bd ڒخُّو\bd* أَذْ ثنْ يَارْوغْ. نِيثْنِي وَارْ زمَّارنْ أَذْ ڭّنْ مْغِيرْ ذْرُوسْ وَاهَا زِي سِّيبّثْ ن زّيَّارْ ن ؤُجدْجِيذْ ن ڒْحُوكَّامْ.  
\v 11 مَاغَارْ إِفْرَايِيمْ إِڭَّا إِعَالْطَارنْ نّسْ ذ أَطَّاسْ، حِيمَا أَذْ \add زَّايْسنْ\add* إِدّنْبْ. أَقَا ذوْڒنْ ذ إِعَالْطَارنْ ن دّنْبْ إِ نتَّا.  
\v 12 نشّْ ؤُرِيغْ أَسْ أَطَّاسْ ن ثْمسْڒَايِينْ زِي شَّارِيعَا إِنُو، \add مَاشَا\add* نِيثْنِي حسْبنْ خَاسنْثْ أَمْ شَا ن ڒْحَاجّثْ ذ ثَاغْرِيبْثْ.  
\v 13 زِي ثْغَارْصَا ن صّْذَاقِي إِنُو، أَقَا نِيثْنِي وهّْبنْ زَّايْسنْثْ أَيْسُومْ ؤُشَا تّتّنْ زَّايسْ، \add مَاشَا\add* سِيذِي وَارْ زَّايْسنْ يَارطِّي. \bd ڒخُّو\bd* أَذْ إِخَارّصْ ذِي ڒْمُوعْصِييّثْ نْسنْ ؤُ نتَّا أَذْ إِخدْجصْ دّْنُوبْ نْسنْ. أَذْ د-ذوْڒنْ غَارْ مِيصْرَا.  
\v 14 مَاغَارْ إِسْرَائِيل إِتُّو ونِّي ث إِڭِّينْ، إِبْنَا ثِيزَاوِييِّينْ، ؤُشَا يَاهُوذَا إِكتَّارْ ثِيندَّامْ إِفَارْينْ، \add مَاشَا\add* نشّْ أَذْ سّكّغْ إِشْثْ ن ثْمسِّي ذِي ثْندَّامْ نّسْ، أَذْ ثشّْ ڒقْصُورْ نّسْ.“   
\b  
\b  
\m  
\c 9
\m
\v 1 ”وَارْ فَارّحْ شَا أَمُّو، إِسْرَائِيل، أَڒَامِي إِ غَا ثسْڒِيوْڒِيوذْ أَمْ ڒڭْنُوسْ. مَاغَارْ ثِيڭّْوجذْ خْ أَربِّي نّشْ أَمْ ثسّفْسذذْ إِخفْ نّشْ. ثتّخْسذْ ڒْمُونثْ ن إِشْثْ ن ثمْغَارْثْ ن فَارْقْ-شّْغڒْ ذِي مَارَّا إِنذْرَارْ ن ؤُسَارْوثْ ن إِمنْذِي.  
\v 2 أَنْذْرَارْ ذ ثْسِيرْثْ ن ؤُضِيڒْ وَارْ ذ أَسنْ سّشّنْ شَا ؤُ بِينُو ن جْذِيذْ أَذْ ت إِخيّبْ.  
\v 3 نِيثْنِي وَارْ تّْغِيمَانْ شَا ذِي ثمُّورْثْ ن سِيذِي. إِفْرَايِيمْ أَذْ د-إِذْوڒْ غَارْ مِيصْرَا ؤُ نِيثْنِي أَذْ شّنْ مِينْ إِخمْجنْ ذِي أَشُّورْ.  
\v 4 نِيثْنِي وَارْ سيّْبنْ شَا \add ثِيوْهِيبِينْ ن\add* بِينُو إِ سِيذِي ؤُ ثِيغَارْصَا نْسنْ وَارْ خَاسْ أَرطَّانْثْ. أَذْ أَسنْ إِڒِينْثْ أَمْ وغْرُومْ ن يِينِّي إِشطّْننْ. مَارَّا إِنِّي ث إِشّنْ، أَذْ ذوْڒنْ خمْجنْ، مَاغَارْ أَغْرُومْ نْسنْ \add أَذْ يِيڒِي\add* إِ ڒعْمَارْ نْسنْ، وَارْ د-إِتِّيسْ ذِي ثَادَّارْثْ ن سِيذِي.  
\v 5 مِينْ غَا ثڭّمْ \add خنِّي\add* ذڭْ إِجّْ ن وَاسّْ \add ن ڒْعِيذْ\add* إِتّْوَاڭّنْ، ذڭْ وَاسّْ ن ڒْعِيذْ ن سِيذِي؟  
\v 6 مَاغَارْ، خْزَارْ، أَقَا نِيثْنِي تَّاڭّْوجنْ زِي سِّيبّثْ ن ؤُردّدْجْ. مِيصْرَا أَذْ ثنْ إِسّْمُونْ، مُوفْ أَذْ ثنْ ثنْضڒْ. إِرزَّازنْ أَذْ مژّْرنْ ذِي نُّوقَارْثْ نْسنْ، شْبَارْقْ أَكْ-ذ إِسنَّاننْ أَذْ إِطّفْ أَمْشَانْ ن إِقِيضَانْ نْسنْ. \f ◼ \fr 9:‏6 \ft \+bd ’مُوفْ‘\+bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’مِيمْفِيسْ‘، ثَانْذِينْثْ ثَاقْذِيمْثْ أَطَّاسْ ن مِيصْرَا. أَذْ ثَافذْ إِسمْ وَانِيثَا ذِي إِشا. 19:13، إِرْم. 2:16، 44:1 ذ حِز. 30:13، 16 ذ هُوشِييَا 9:6.\f*   
\m
\v 7 أَقَا ؤُسَّانْ ن ؤُجَارّبْ ؤُسِينْ-د، أَقَا ؤُسَّانْ ن لْعِيقَابْ ؤُسِينْ-د. نِيثْنِي أَذْ \add ت\add* سّْننْ، \add إِنِّي ن\add* إِسْرَائِيل. أَنَابِي \add أَمْ يِيجّْ ن\add* أَبُوهَاڒِي \add إِ نِيثْنِي\add*، أَرْيَازْ أَرُّوحَانِي \add أَمْ يِيجّْ ن\add* بُو-جْنُونْ زڭْ وَاطَّاسْ ن ڒْمُوعْصِييّثْ نّشْ ذ وَاطَّاسْ ن ڒعْذَاوثْ نّشْ.  
\v 8 أَعسَّاسْ ن إِفْرَايِيمْ \add إِتّْعسَّاسْ\add* أَكْ-ذ \add ؤُعَاونْ ن\add* أَربِّي إِنُو، \add وَاهْ، نتَّا،\add* أَنَابِي \add إِتَّافْ\add* إِجّْ ن ڒْفخْ ن ؤُنڭْمَارْ ذِي مَارَّا إِبْرِيذنْ نّسْ، ڒعْذَاوثْ ذِي ثَادَّارْثْ ن أَربِّي نّسْ. \x ◘ \xo 9:‏8 \xt إِرْم. 6‏:‏17\x*  
\v 9 \add مَاغَارْ\add* أَقَا أَثنْ غَارْقنْ أَڒْ إِڒِي، أَمْ ذڭْ وُوسَّانْ نِّي ن جِيبْعَا. نتَّا أَذْ إِعْقڒْ خْ ڒْمُوعْصِييّثْ نْسنْ ؤُ أَذْ إِخْڒفْ دّْنُوبْ نْسنْ.“   
\m
\v 10 ”نشّْ ؤُفِيغْ إِسْرَائِيل أَمْ ؤُضِيڒْ ذِي ڒخْڒَا، ژْرِيغْ ڒجْذُوذْ نْومْ أَمْ يِيمنْزَا ن وَارْثُو ذِي ثمْژِي نْسنْ. نِيثْنِي \add مَاشَا\add* ؤُذْفنْ غَارْ بَاعْلْ-فَاغُورْ ؤُشَا وْشِينْ إِخفْ نْسنْ س ڒفْضِيحثْ \add إِ نتَّا\add* ؤُشَا نِيثْنِي ذوْڒنْ ذ نّْعَاوَاثْ أَمْ ونِّي ثُوغَا تّخْسنْ. \x ◘ \xo 9:‏10 \xt ڒخْڒ. 25‏:‏3؛ إِزهد. 106‏:‏28\x*  
\v 11 \add خْ يِينِّي ن\add* إِفْرَايِيمْ، أَقَا أَعُودْجِي نْسنْ أَذْ إِضُو أَمْ وجْضِيضْ، \add أَذْ يَاڭّْوجْ\add* خْ وخْڒَاقْ ؤُ خْ ؤُعذِّيسْ \add ن يمَّاسْ\add* ؤُ خْ ثْكسِّيثْ ن ثَارْوَا.  
\v 12 وَاخَّا نِيثْنِي سّْيَامنْ إِحنْجِيرنْ نْسنْ أَڒْ غَا مْغَارنْ، نشّْ أَذْ ثنْ أَرّغْ نْهْڒَا إِحنْجِيرنْ أَڒَامِي وَارْ ذِينْ إِقِّيمْ بْنَاذمْ. مَاغَارْ ؤُڒَا إِ نِيثْنِي \add س ثِيذتّْ\add*، ؤُشْثْ، خْمِي خَاسنْ غَا حيّْذغْ.  
\v 13 أَخْمِي ژْرِيغْ صُورْ، أَمُّو إِ إِتّْوَاژُّو إِفْرَايِيمْ ذڭْ إِشْثْ ن جِّيهثْ أَرْضَانْ. ؤُ ڒخُّو \add إِتّْخصَّا إِ\add* إِفْرَايِيمْ أَذْ إِسلّمْ ثَارْوَا نّسْ إِ ؤُقتَّاڒْ.  
\v 14 أوْشْ أَسنْ، \add أَ\add* سِيذِي! مِينْ إِ غَا ثوْشذْ؟ أوْشْ أَسنْ إِجّْ ن ؤُعذِّيسْ س وطُّووْ ن إِسيْمَانْ ذ يبَّاشْ يُوژْغنْ. \x ◘ \xo 9:‏14 \xt لك. 23‏:‏29\x*  
\v 15 مَارَّا ثَاعفَّانْثْ نْسنْ \add ثْعَارَّا\add* ذِي جِيلْجَالْ، مَاغَارْ ذِينِّي شَارْهغْ ثنْ خْ ثْعفَّانْثْ ن ثْمڭَّا نْسنْ. نشّْ أَذْ خَاسنْ أَژّْڒغْ زِي ثَادَّارْثْ إِنُو.عمَّارْصْ عَاذْ أَذْ ثنْ خْسغْ \add عَاذْ\add*، مَارَّا ڒْحُوكَّامْ نْسنْ ذ إِمْغوّْغنْ. \x ◘ \xo 9:‏15 \xt إِشا. 1‏:‏23؛ حُوش. 4‏:‏15؛ 12‏:‏12\x*  
\v 16 إِفْرَايِيمْ إِتّْوَاوّثْ، إِژوْرَانْ نْسنْ ؤُژْغنْ، وَارْ تِّيرْونْ عَاذْ. وَاخَّا نِيثْنِي تَّارْونْ، نشّْ أَذْ نْغغْ إِمْعِيزَّانْ ن ؤُعذِّيسْ نْسنْ.  
\v 17 أَربِّي إِنُو أَذْ ثنْ إِنْضَارْ، مَاغَارْ نِيثْنِي وَارْ غَارسْ تّسْڒِينْ، ؤُ نِيثْنِي أَذْ ذوْڒنْ تّثْلِيعنْ جَارْ ڒڭْنُوسْ.“   
\b  
\b  
\m  
\c 10
\m
\v 1 ”إِسْرَائِيل ذ إِشْثْ ن ثْزَايَارْثْ ثوْسعْ، ثنِّي إِ د إِتَّاوْينْ ڒْغِيدْجثْ إِ يِيخفْ نّسْ. مَامّشْ ثُوغَا ڒْغِيدْجثْ نّسْ ثمَّارْنِي، أَمُّو إِ د-مَّارنْينْ ؤُڒَا ذ إِعَالْطَارنْ نّسْ، مشْحَاڒْ ثشْنَا ثمُّورْثْ نّسْ، أَمُّو إِ ڭِّينْ نِيثْنِي ؤُڒَا ذ إِمَايْضُوثنْ \add إِقدّْسنْ\add* شْنَانْ. \x ◘ \xo 10:‏1 \xt حُوش. 8‏:‏11\x*  
\v 2 ؤُڒْ نْسنْ أَقَا إِتّْوَابْضَا، ڒخُّو أَقَا ذَايْسنْ ڒْعِيبْ. نتَّا أَذْ يَارْژْ إِعَالْطَارنْ نْسنْ، نتَّا أَذْ إِهْذمْ إِمَايْضُوثنْ نْسنْ \add إِقدّْسنْ\add*  
\v 3 مَاغَارْ ڒخُّو قَّارنْ: ’نشِّينْ وَارْ غَارْنغْ بُو ؤُجدْجِيذْ، مَاغَارْ نشِّينْ وَارْ نڭّْوِيذْ شَا سِيذِي، ؤُ \add عَاذْ مَاڒَا ثُوغَا ذِينْ\add* أَجدْجِيذْ: ’مِينْ إِزمَّارْ أَذْ أَنغْ إِڭّْ؟‘ \x ◘ \xo 10:‏3 \xt حُوش. 3‏:‏4\x*  
\v 4 سَّاوَاڒنْ أَوَاڒنْ \add إِخْوَانْ\add*، تّْجَادْجَانْ ژُورْ أَمْ تّڭّنْ إِجّْ ن ڒْعَاهْذْ، ؤُشَا ڒْحُوكْمْ \add إِذْوڒْ\add* إِتّْڭعّذْ أَمْ يِيجّْ ن ڒعْشبْ أَمسْمُومْ ذِي ڒخْضُوضْ ن إِيَّارنْ.  
\v 5 إِمزْذَاغْ ن سَامَارْيَا أَذْ نّْخڒْعنْ زِي سِّيبّثْ ن ؤُعجْمِي ن بَايْثْ-أَوَانْ، مَاغَارْ ڒْڭنْسْ نّسْ أَذْ خَاسْ إِشْضنْ، ؤُشَا ؤُڒَا ذ إِكهَّاننْ نّسْ أَذْ خَاسْ شضْننْ، خْ ؤُعُودْجِي نّسْ، مَاغَارْ وَانِيثَا إِتّْوَاكّسْ زَّايسْ.  
\v 6 أَذْ ث أَوْينْ غَارْ أَشُّورْ ذ ثَارْزفْثْ إِ ؤُجدْجِيذْ يَارِيبْ. إِفْرَايِيمْ أَذْ إِڭّْ ڒفْضِيحثْ إِ ؤُزدْجِيفْ نّسْ ؤُ إِسْرَائِيل أَذْ إِسضْحَا زِي لْقَارَارْ نّسْ.  
\v 7 إِتّْوَاسّسْقَارْ ؤُجدْجِيذْ ن سَامَارْيَا أَمْ ؤُكُوفُّو خْ وُوذمْ ن وَامَانْ.  
\v 8 أَذْ تّْوَاهذْمنْثْ ڒڭْعُوذِي ن أَوَانْ، أَقَا-ثنْثْ ذ دّنْبْ ن إِسْرَائِيل. إِسنَّاننْ ذ ثْزڭّْوَارْثْ أَذْ ؤُعْڒَانْ خْ إِعَالْطَارنْ نْسنْ ؤُ نِيثْنِي أَذْ إِنِينْ إِ إِذُورَارْ: ’ذْڒمْ أَنغْ!‘ ؤُ إِ ثوْرِيرِينْ: ’وْضَانْثْ-إِ-د خَانغْ!‘ \x ◘ \xo 10:‏8 \xt إِشا. 2‏:‏19؛ لك. 23‏:‏30؛ أَسَا. 6‏:‏16؛ 9‏:‏6\x*  
\v 9 زڭْ وُوسَّانْ ن جِيبْعَا ثڭِّيذْ دّْنُوبْ، \add أَ\add* إِسْرَائِيل. ذِينِّي قِّيمنْ نِيثْنِي بدّنْ، \add إِوَا،\add* وَارْ ثنْ إِڒقِّيفْ ڒَاثَارْ ن ؤُمنْغِي أَكْ-ذ أَيْثْ ن ڒْمُوعْصِييّثْ ذِي جِيبْعَا. \x ◘ \xo 10:‏9 \xt حُوش. 9‏:‏9\x*  
\v 10 أَقَا ذَايِي مژْرِي حِيمَا أَذْ ثنْ شَارْفغْ ؤُ أَذْ خَاسنْ سّْمُونغْ ڒڭْنُوسْ خْمِي ثنْ غَا شَارْفغْ س ثْنَاينْ ن إِخطَّانْ نْسنْ.“   
\b  
\m
\v 11 ”إِفْرَايِيمْ ذ إِشْثْ ن ثْعجْمِيثْ إِتّْوَاذَارّْبنْ، ثتّخْسْ أَذْ ثسَّارْوثْ. نشّْ عْذُوغْ خْ ثْشُونِي ن يِيرِي نّسْ. نشّْ أَذْ نذْهغْ إِفْرَايِيمْ، يَاهُوذَا أَذْ إِشَارْزْ، يَاعْقُوبْ أَذْ إِنْقشْ \add ثمُّورْثْ\add* إِ يِيخفْ نّسْ. \f ◼ \fr 10:‏11 \ft \+bd ’نشّْ عْذُوغْ خْ ثْشُونِي ن يِيرِي نّسْ‘\+bd* - إِخْسْ أَذْ يِينِي بلِّي إِتّْوَاڭّْ إِجّْ ن زَّايْرُو خْ يِيرِي نّسْ.\f*  
\v 12 زَارْعمْ ثَاسڭْذَا إِ يِيخفْ نْومْ، مْجَارمْ ثَامخْسِيوْثْ إِشوَّارنْ مَاحنْذْ أَذْ \add زَّايسْ\add* ثْعمَّارمْ أَقمُّومْ نْومْ، شَارْزمْ إِجّْ ن ييَّارْ إِخْوَا إِ يِيخفْ نْومْ، مِينْزِي أَقَا-ث ذ ڒْحَاڒْ مَاحنْذْ أَذْ ثَارْزُومْ خْ سِيذِي، أَڒْ د غَا يَاسْ نتَّا ؤُ أَذْ يَارَّا ثَاسڭْذَا أَذْ خَاومْ ثشَّاثْ أَمْ ونْژَارْ.“\x ◘ \xo 10:‏12 \xt إِرْم. 4‏:‏3\x*   
\m
\v 13 ”أَقَا كنِّيوْ ثْشَارْزمْ مِينْ وَارْ إِحْڒِينْ، ثْصيّْفمْ ڒْمُوعْصِييّثْ، ثشِّيمْ ڒْغِيدْجثْ ن ؤُخَارِّيقْ، مَاغَارْ شكْ ثثشْڒذْ خْ وبْرِيذْ \add إِ ثِيخْضَارذْ سِيمَانْثْ\add* نّشْ، خْ ؤُبَارُّو ن أَيْثْ ن بُو-ثغْرُوضْثْ نّشْ.  
\v 14 أَذْ إِكَّارْ إِجّْ ن دّْرِيزْ ن ؤُمنْغِي ضِيدّْ إِ ڒْڭنْسْ نّشْ ؤُ مَارَّا لْقلْعَاثْ نّشْ أَذْ تّْوَاهذْمنْثْ أَمْ مَامّشْ إِهْذمْ شَالْمَانْ بَايْثْ-أَرْبِيلْ ذڭْ وَاسّْ ن ؤُمنْغِي، ؤُمِي ثتّْوَاڒْبزْ إِشْثْ ن يمَّاسْ أَكْ-ذ إِحنْجِيرنْ \add نّسْ\add*.  
\v 15 أَمُّو إِ إِڭَّا بَايْثْ-إِلْ أَكِيذْومْ زِي سِّيبّثْ ن ثُوعفّْنَا نْومْ يُودْجْغنْ. غَارْ ڒفْجَارْ أَذْ إِتّْوَاسغْضْ ؤُجدْجِيذْ ن إِسْرَائِيل س إِجّْ ن ؤُسغْذْ قَاعْ.“   
\b  
\b  
\m  
\c 11
\m
\v 1 ”أَڒَامِي ثُوغَا إِسْرَائِيل \add عَاذْ\add* ذ أَحنْجِيرْ، ثُوغَا تّخْسغْ ث ؤُ نشّْ ڒَاغِيغْ-د إِ مِّي زِي مِيصْرَا. \x ◘ \xo 11:‏1 \xt ؤُف. 4‏:‏22‏-‏23‏:‏ مت. 2‏:‏15\x*  
\v 2 \add ؤُڒَا ذ إِنَابِييّنْ إِنُو\add* ڒَاغَانْ خَاسنْ، \add مَاشَا خنِّي\add* أَڭّْوجنْ نِيثْنِي \add ذغْيَا\add* خْ إِغمْبَابْ نْسنْ مَاحنْذْ أَذْ أَوْينْ ثِيغَارْصَا إِ ’إِبَاعْلنْ‘ ذ ثوْهِيبِينْ ن ڒبْخُورْ إِ ڒخْيَاڒَاثْ نْسنْ إِنقْشنْ.  
\v 3 ذ نشّْ إِ ثُوغَا إِسّڒْمَاذنْ ثِيشْڒِي إِ إِفْرَايِيمْ، \add وَاهْ،\add* نتَّا إِكْسِي ثنْ خْ إِغَادْجنْ نّسْ، \add مَاشَا\add* نِيثْنِي وَارْ سِّيننْ شَا أَقَا نشّْ ذ ونِّي إِ ثنْ إِسّْڭنْفَانْ.  
\v 4 س ثسْغُونِينْ ن بْنَاذمْ جبْذغْ ثنْ-د \add غَارِي\add*، س ثْمُورَارْ ن ثْمخْسِيوْثْ، ؤُ نشّْ ثُوغَا إِ نِيثْنِي أَمْ ونِّي د-إِسّْڭعَّاذنْ زَّايْڒثْ زڭْ إِغسْمِيرنْ نْسنْ، ؤُ نشّْ سّْوِيژّْضغْ أَسْ \add إِفَاسّنْ إِنُو\add* مَاحنْذْ أَذْ أَسْ وْشغْ أَذْ إِشّْ.“   
\b  
\m
\v 5 ”نتَّا وَارْ د-إِتَّارِّي س ؤُزدْجِيفْ غَارْ مِيصْرَا. أَشُّورْ، نتَّا \add أَذْ يِيڒِي\add* ذ أَجدْجِيذْ نّسْ، مَاغَارْ نِيثْنِي ؤُڭِينْ أَذْ د-ذوْڒنْ.  
\v 6 سِّيفْ أَذْ إِنّضْ ذِي ثْندَّامْ نْسنْ ؤُشَا أَذْ يَاردّدْجْ إِعُومَاذْ نّسْ \add ن ؤُبلّعْ ن ثوُّورَا\add* ؤُ أَذْ ثنْ يشّْ زِي سِّيبّثْ ن إِخَارِّيصنْ \add ن يِيخفْ\add* نْسنْ.  
\v 7 \add مَاغَارْ\add* ڒْڭنْسْ إِنُو إِقِّيمْ إِتّْنقْڒَابْ خَافِي. نِيثْنِي تّْڒَاغَانْ جْمِيعْ غَارْ سنّجْ، \add مَاشَا\add* نتَّا وَارْ ثنْ إِسّْعُودْجِي شَا.“   
\b  
\m  
\s1 أَرّحْمثْ ن سِيذِي خْ إِفْرَايِيمْ  
\m
\v 8 ”مَامّشْ زمَّارغْ نشّْ أَذْ شكْ سلّْمغْ، إِفْرَايِيمْ؟ \add مَامّشْ زمَّارغْ نشّْ\add* أَذْ شكْ سلّْمغْ، إِسْرَائِيل؟ \add مَامّشْ زمَّارغْ نشّْ\add* أَذْ شكْ سلّْمغْ أَمْ أَذَامَا، أَذْ شكْ ڭّغْ \add ذ أَمذْيَا\add* أَمْ صابُويِيمْ؟ ؤُڒْ إِنُو إِنّحْوڒْ زَّايِي، أَزِيدْجزْ إِنُو إِتّخْثُوخْ جْمِيعْ. \x ◘ \xo 11:‏8 \xt أَمز. 19‏:‏24؛ أَعَوذ. 29‏:‏22\x*  
\v 9 نشّْ وَارْ ثجِّيغْ أَذْ أَرْخُوغْ ڒْحَاذُوقْ ن وغْضَابْ إِنُو، نشّْ وَارْ د-دِّيكّْوِيڒغْ شَا مَاحنْذْ أَذْ أَردّْدْجغْ إِفْرَايِيمْ، مَاغَارْ نشّْ ذ أَربِّي ؤُ نشّْ وَارْ دْجِيغْ ذ بْنَاذمْ، نشّْ ذ أَمْقدَّاسْ ذِي ڒْوسْطْ نّشْ، وَارْ د-تِّيسغْ شَا س ثْمسِّي \add ن لْغَاضَابْ إِنُو\add*.  
\v 10 نِيثْنِي أَذْ ڭُّورنْ أَوَارْنِي إِ سِيذِي. نتَّا أَذْ إِسّْمُوهْرُوثْ أَمْ يِيجّْ ن ويْرَاذْ، مَاغَارْ أَذْ إِسّْمُوهْرُوثْ نتَّا ؤُشَا إِحنْجِيرنْ أَذْ د-أَسنْ تَّارْجِيجِينْ زِي ثْمَا ن ڒبْحَارْ.  
\v 11 أَمْ إِجْضَاضْ أَذْ د-أَسنْ تَّارْجِيجِينْ زِي ثمُّورْثْ ن مِيصْرَا ؤُ أَمْ ثذْبِيرْثْ زِي ثمُّورْثْ ن أَشُّورْ ؤُ نشّْ أَذْ ثنْ سّْزذغْ ذِي ثُوذْرِينْ نْسنْ، إِقَّارْ سِيذِي.“   
\b  
\b  
\m  
\c 12
\s1 إِفْرَايِيمْ ذ ؤُسْڒِيفْ نّسْ يَاعْقُوبْ  
\m
\v 1 ”إِفْرَايِيمْ إِتّنّضْ أَيِي س ؤُخَارِّيقْ ؤُ ثَادَّارْثْ ن إِسْرَائِيل س ڒْغشّْ، \add مَاشَا\add* يَاهُوذَا إِتّثْلِيعْ عَاذْ أَكْ-ذ أَربِّي ؤُ أَكْ-ذ ؤُمْقدَّاسْ أَمقّْرَانْ ذ أَمْثِيقِّي.  
\v 2 إِفْرَايِيمْ ذ إِجّْ ن ؤُمكْسَاوْ يُويُورْ أَوَارْنِي إِ ؤُسمِّيضْ. أَسّْ مَارَّا يَارنِّي إِخَارِّيقنْ ذ ؤُردّدْجْ. نِيثْنِي ڭِّينْ إِجّْ ن ڒْعَاهْذْ أَكْ-ذ أَشُّورْ ؤُشَا تَّاوْينْ زّشْثْ غَارْ مِيصْرَا.“   
\b  
\m
\v 3 ”سِيذِي غَارسْ إِجّْ ن ؤُمْشُوبّشْ أَكْ-ذ يَاهُوذَا ؤُ نتَّا أَذْ إِڭّْ س يَاعْقُوبْ عْلَاحْسَابْ إِبْرِيذنْ نّسْ، أَذْ ث إِخدْجصْ أَمْ مَامّشْ ثِيمڭَّا نّسْ.  
\v 4 ذڭْ ؤُعذِّيسْ ن يمَّاسْ إِطّفْ ؤُمَاسْ غَارْ ؤُنِيرْزْ ؤُ ڒَامِي ثُوغَا \add ذ أَرْيَازْ\add* إِجْهذْ إِمّْعَاڒَا أَكْ-ذ أَربِّي. \x ◘ \xo 12:‏4 \xt أَمز. 25‏:‏26؛ 35‏:‏9، 10 \x*  
\v 5 نتَّا ثُوغَا إِمّْنغْ أَكْ-ذ لْمَالَاكْ ؤُشَا إِغْڒبْ. إِرُو، إِحشّمْ إِ-ث. يُوفَا إِ-ث ذِي بَايْثْ-إِلْ ؤُ ذِينِّي إِسِّيوڒْ نتَّا أَكِيذْنغْ، \x ◘ \xo 12:‏5 \xt أَمز. 28‏:‏12، 19؛ 35‏:‏7، 14، 15\x*  
\v 6 \add وَاهْ،\add* سِيذِي، أَربِّي ن ڒْعسْكَارَاثْ، سِيذِي ذ إِسمْ نّسْ إِ ڒِيذَارثْ.  
\v 7 ذْوڒْ غَارْ أَربِّي نّشْ، حْضَا ثَامخْسِيوْثْ إِشوَّارنْ ذ ڒْحقّْ، ؤُ سِيثِيمْ ڒبْذَا إِ أَربِّي نّشْ.“   
\b  
\m
\v 8 ”كنْعَانْ غَارسْ إِجّْ ن ڒْمِيزَانْ إِغشّْ ذڭْ ؤُفُوسْ نّسْ، إِتّعْجِيبْ أَسْ أَذْ إِبعّجْ.  
\v 9 \add مَاشَا\add* إِفْرَايِيمْ إِقَّارْ: ’نشّْ ذوْڒغْ ذ بُو-وَاڭْڒَا، يَارْوغْ إِشْثْ ن ڒكْسِيبثْ ذ ثَامقّْرَانْثْ إِ يِيخفْ إِنُو. \add ذِي\add* مَارَّا ڒْخذْمثْ إِنُو وَارْ ذَايِي تِّيفنْ شَا ڒْمُوعْصِييّثْ نِّي \add إِدْجَانْ\add* ذ دّنْبْ.‘ “   
\b  
\m
\v 10 ”نشّْ ذ سِيذِي، أَربِّي نّشْ، زڭْ \add وَامِي ثفّْغمْ كنِّيوْ زِي\add* ثمُّورْثْ ن مِيصْرَا. نشّْ أَذْ شكْ جّغْ أَذْ ثْزذْغذْ ذڭْ إِقِيضَانْ أَمْ ذڭْ وُوسَّانْ ن ثْمسْمُونْثْ \add ذِي ڒخْڒَا\add*. \x ◘ \xo 12:‏10 \xt إِشا. 43‏:‏11\x*  
\v 11 نشّْ أَذْ سِّيوْڒغْ غَارْ إِنَابِييّنْ ؤُ نشّْ أَذْ أَرْنِيغْ ڒوْحِييْ أَطَّاسْ ؤُ س ؤُفُوسْ ن إِنَابِييّنْ أَذْ سِّيوْڒغْ س ڒمْثُوڒْ.“   
\b  
\m
\v 12 ”مَاڒَا \add ثُوغَا\add* جِيلْعَاذْ ذ ڒْمُوعْصِييّثْ، \add خنِّي\add* ذوْڒنْ نِيثْنِي خْوَانْ قَاعْ ذِي جِيلْعَاذْ. أَقَا قدّْمنْ \add ذِينْ\add* إِفُونَاسنْ. ؤُڒَا ذ إِعَالْطَارنْ نْسنْ ذوْڒنْ ذ إِعُورِّيشنْ ن إِژْرَا ذِي ڒخْضُوضْ ن إِيَّارنْ.\x ◘ \xo 12:‏12 \xt حُوش. 4‏:‏15؛ 6‏:‏8؛ 9‏:‏15\x*  
\v 13 يَاعْقُوبْ يَارْوڒْ غَارْ جّْوَايهْ ن أَرَامْ ؤُ إِسْرَائِيل ثُوغَا إِتّْسخَّارْ خْ يِيشْثْ ن ثمْغَارْثْ، ؤُ نتَّا يَارْوسْ \add ثَاحِيمَارْثْ\add* ذِي طّْوعْ ن يِيشْثْ ن ثمْغَارْثْ، \x ◘ \xo 12:‏13 \xt أَمز. 28‏:‏5؛ 29‏:‏20، 28\x*  
\v 14 \add مَاشَا\add* س يِيجّْ ن ؤُنَابِي إِسّْڭعّذْ سِيذِي إِسْرَائِيل زِي مِيصْرَا ؤُ س يِيجّْ ن ؤُنَابِي يَارْوسْ إِ-ث.  
\v 15 إِفْرَايِيمْ ثُوغَا إِسْعَارْ إِ-ث أَطَّاسْ. س ؤُيَا أَذْ يجّْ \add سِيذِي\add* إِذَامّنْ نّسْ أَذْ خَاسْ د-أَسنْ ؤُ سِيذِي نّسْ أَذْ أَسْ إِخدْجصْ ڒْحڭْرَا نّسْ.“ \x ◘ \xo 12:‏15 \xt إِشا. 65‏:‏7\x*   
\b  
\b  
\m  
\c 13
\s1 سِيذِي ذ أَربِّي ن إِفْرَايِيمْ  
\m
\v 1 ”ؤُمِي إِسِّيوڒْ إِفْرَايِيمْ، \add أَقَا ذِينْ\add* ثَارْجِيجثْ \add س ؤُوقَّارْ\add*. نتَّا إِسّْڭعّذْ إِخفْ نّسْ ذِي إِسْرَائِيل ؤُشَا إِذْوڒْ ذ أَمذْنُوبْ زِي سِّيبّثْ \add ن وعْبذْ نّسْ إِ\add* بَاعْلْ، ؤُشَا \add خنِّي\add* إِمُّوثْ.  
\v 2 ؤُشَا ڒخُّو \add عَاوذْ\add* أَرْنِينْ تّڭّنْ دّْنُوبْ ؤُ ڭِّينْ س نُّوقَارْثْ نْسنْ إِجّْ ن ڒخْيَاڒْ إِفسْينْ عْلَاحْسَابْ ڒعْقڒْ نْسنْ، أَقَا-ثنْثْ ذ ڒخْيَاڒَاثْ ن لْ-أَصْنَامْ مَارَّا، ڒْخذْمثْ ن ؤُمْزِيڒْ. نِيثْنِي قَّارنْ خَاسنْ: ’أجّْ إِوْذَانْ إِنِّي إِ غَا إِوهّْبنْ ثِيغَارْصَا أَذْ سُّوذُومنْ إِعجْمِييّنْ-أَ!‘ \x ◘ \xo 13:‏2 \xt حُوش. 8‏:‏6\x*  
\v 3 س ؤُيَا أَذْ ذوْڒنْ أَمْ يِيجّْ ن ؤُسيْنُو ن صّْبحْ ؤُ أَمْ نّْذَا غَارْ ثُوفُّوثْ نِّي ذغْيَا إِعدُّونْ، أَمْ ؤُڒُومْ إِطَّاونْ زڭْ ؤُنذْرَارْ ؤُ أَمْ دّخَّانْ \add إِتّفّْغنْ\add* زِي ثْبُورْجثْ.“   
\b  
\m
\v 4 ”نشّْ ذ سِيذِي، أَربِّي نّشْ، زڭْ \add وَامِي د-ثفّْغمْ كنِّيوْ زِي\add* ثمُّورْثْ ن مِيصْرَا. شكْ وَارْ ثتّسّْنذْ بُو أَربِّي نّغْنِي مْغِيرْ نشّْ ؤُ وَارْ ذِينْ أَمْسنْجمْ مْغِيرْ نشّْ. \x ◘ \xo 13:‏4 \xt 2 صم. 22‏:‏32؛ إِزهد. 18‏:‏32؛ إِشا. 43‏:‏11؛ حُوش. 12‏:‏10\x*  
\v 5 نشّْ سّْنغْ شكْ ذِي ڒخْڒَا، ذڭْ إِشْثْ ن ثمُّورْثْ ن ڒحْمُو يَارقّنْ.  
\v 6 أَڒَامِي \add إِوْضنْ\add* غَارْ دّمْنثْ نْسنْ ن ثَاروْسَا، ذوْڒنْ جِّيوْننْ. أَڒَامِي جِّيوْننْ، إِنُّورْفعْ وُوڒْ نْسنْ. خْ ؤُيَا تُّونْ أَيِي. \x ◘ \xo 13:‏6 \xt أَعَوذ. 32‏:‏15؛ حُوش. 8‏:‏14\x*  
\v 7 س ؤُينِّي نشّْ ذوْڒغْ إِ نِيثْنِي أَمْ ويْرَاذْ إِزهَّارنْ، أَمْ ؤُغِيڒَاسْ ڒبْثغْ ذڭْ وبْرِيذْ.  
\v 8 نشّْ ؤُسِيغْ-د غَارْسنْ أَمْ يِيجّْ ن دُّوبْ ونِّي ؤُمِي ؤُشَارنْ ثَارْوَا نّسْ ؤُ نشّْ أَڒْژغْ إِذْمَارنْ نْسنْ ؤُ صَارْضغْ ثنْ ذِينْ أَمْ ثِيزمْثْ. ڒوْحُوشْ ن ڒخْڒَا مزّْقنْ ثنْ.“ \f ◼ \fr 13:‏8 \ft \+bd ’إِذْمَارنْ‘\+bd* - س ثْعِيبْرَانِيثْ ’أَڒحّفْ ن وُوڒْ نْسنْ‘.\f*   
\b  
\m
\v 9 ”مَانْ أَيَا إِذْوڒْ ذ أَكحّضْ نّشْ، \add أَ\add* إِسْرَائِيل، أَقَا \add ثْعكّْسذْ\add* أَيِي، ضِيدّْ إِ ونِّي إِدْجَانْ ذ أَمْعَاونْ نّشْ.  
\v 10 مَانِي \add إِدْجَا خنِّي\add* ؤُجدْجِيذْ نّشْ، ذ ونِّي إِزمَّارنْ أَذْ شكْ إِسّنْجمْ ذِي مَارَّا ثِيندَّامْ نّشْ! ؤُ \add مَانِي دْجَانْ\add* ڒْقُوضَاثْ نّشْ ؤُمِي ثنِّيذْ: ’أوْشْ أَيِي إِجّْ ن ؤُجدْجِيذْ ؤُڒَا ذ ڒْحُوكَّامْ‘؟  
\v 11 س وغْضَابْ إِنُو وْشِيغْ أَشْ إِجّْ ن ؤُجدْجِيذْ ؤُ س ؤُذُوقّزْ إِنُو \add ن ؤُفُوڭمْ\add* كّْسغْ أَشْ ث. \x ◘ \xo 13:‏11 \xt 1 صم. 8‏:‏5؛ 15‏:‏23؛ 16‏:‏1\x*  
\v 12 ڒْمُوعْصِييّثْ ن إِفْرَايِيمْ ثتّْوَاقبّضْ \add أَمْ ذڭْ إِشْثْ ن ثْقبِّيضْطْ\add*، دّْنُوبْ نّسْ تّْوَاحْضَانْ.  
\v 13 ڒحْرِيقْ ن ثَارْوَا أَذْ غَارسْ د-يَاسْ. نتَّا ذ إِجّْ ن ؤُحنْجِيرْ \add إِقِّيمْ\add* بْڒَا ثِيغِيثْ، مَاغَارْ نتَّا وَارْ ذِينْ إِبدّْ ذِي ڒْوقْثْ نّسْ \add مَاحنْذْ أَذْ إِفّغْ\add*  
\m خْمِي إِ غَا ثَارْزمْ \add ڒمْڒَاوْڒثْ\add* حِيمَا \add أَذْ فّْغنْ\add* إِحنْجِيرنْ.   
\b  
\m
\v 14 ”زڭْ ؤُفُوسْ ن ڒَاخَارْثْ أَذْ ثنْ فْذِيغْ، أَذْ ثنْ فكّغْ زِي ڒْموْثْ. \add أَ\add* ڒْموْثْ، مَانِي دْجَانْ \add ڒحْڒَاشَاثْ ن\add* طَّاعُونْ نّمْ، \add أَ\add* ڒَاخَارْثْ، مَانِي \add ثدْجَا\add* ثُورْصُوضِي نّمْ؟ \add مَا\add* أَذْ نذْمغْ \add عَاذْ\add*؟ \add لَّ،\add* أَيَا إِنُوفَّارْ زَّاثْ إِ ثِيطَّاوِينْ إِنُو. \x ◘ \xo 13:‏14 \xt إِشا. 25‏:‏8؛ 1 كُور. 15‏:‏55\x*   
\b  
\m
\v 15 وَاخَّا ڭُّورْ إِفْرَايِيمْ أَذْ إِوْشْ ڒْغِيدْجثْ جَارْ أَيْثْمَاسْ، \add عَاذْ\add* أَذْ د-يَاسْ إِجّْ ن ؤُسمِّيضْ زِي شَّارْقْ، إِجّْ ن ؤُسمِّيضْ ن سِيذِي نِّي إِ-د إِ غَا إِكَّارنْ، - ثَاڒَا نّسْ ڭُّورْ أَذْ ثَاژغْ، أَنُو نّسْ ڭُّورْ أَذْ إِوْضَا - ڭُّورْ أَذْ إِكشّضْ ؤُسمِّيضْ إِشْثْ ن ثْخَابشْثْ زِي مْكُوڒْ ڒقْشُوعْ إِغْڒَانْ.“   
\b  
\b  
\m  
\c 14
\s1 ثَاڒَاغِيثْ إِ تُّوبثْ  
\m
\v 1 ”سَامَارْيَا أَذْ ثطّفْ أَخدْجصْ، مِينْزِي ثْغوّغْ خْ أَربِّي نّسْ. أَذْ وْضَانْ س سِّيفْ. إِحنْجِيرنْ إِمژْيَاننْ نْسنْ أَذْ تّْوَاڒبْزنْ ؤُ ثِيمْغَارِينْ نْسنْ س دّيْسثْ أَذْ تّْوَاشَارّْڭنْثْ. \x ◘ \xo 14:‏1 \xt حُوش. 10‏:‏14\x*  
\v 2 \add أَ\add* إِسْرَائِيل، ذْوڒْ-د غَارْ سِيذِي، أَربِّي نّشْ، مَاغَارْ ثنْذرْفذْ س ڒْمُوعْصِييّثْ نّشْ. \x ◘ \xo 14:‏2 \xt حُوش. 12‏:‏7\x*  
\v 3 كْسِيمْ أَوَاڒنْ\add -أَ\add* \add ن تُّوبثْ\add* أَكِيذْومْ ؤُ ذوْڒمْ-د غَارْ سِيذِي. إِنِيمْ أَسْ: كْسِي \add خَانغْ\add* ڒْمُوعْصِييّثْ مَارَّا ؤُ قْبڒْ \add زَّايْنغْ\add* مِينْ إِشْنَانْ، \add خنِّي\add* أَذْ نَاوِي \add س ثِيذتّْ\add* إِفُونَاسنْ ذ ثَاضْحِييثْ \add عْلَاحْسَابْ ڒْوُوعُوذْ\add* ن إِينْشِيشنْ نّغْ.  
\v 4 أَشُّورْ وَارْ ذ أَنغْ إِسّنْجَامْ، وَارْ نڭُّورْ خْ ييْسَانْ ؤُ وَارْ نقَّارْ إِ ثْمڭَّا ن إِفَاسّنْ نّغْ: ’أَربِّي نّغْ‘، مَاغَارْ زَّايكْ إِ غَا إِتّْوَارْحمْ ؤُيُوجِيڒْ.‘ “   
\b  
\m
\v 5 ”نشّْ أَذْ ثنْ سّْڭنْفِيغْ زِي ثْغنَّانْثْ نْسنْ، أَذْ ثنْ تّخْسغْ س ڒْخَاضَارْ، مَاغَارْ أَغْضَابْ إِنُو إِحيّذْ خَاسْ.  
\v 6 نشّْ أَذْ إِڒِيغْ إِ إِسْرَائِيل أَمْ نّْذَا. نتَّا أَذْ إِنُووَّارْ أَمْ ثْنوَّاشْثْ ن ثلِّيلِيشْثْ، أَذْ إِوّثْ \add إِسْرَائِيل\add* إِژوْرَانْ نّسْ أَمْ \add إِذُورَارْ ن\add* لُوبْنَانْ. \f ◼ \fr 14:‏6 \ft \+bd ’ثِيلِّيلِيشِينْ‘\+bd* - إِجّْ ن مَارْكَا ن ثْنُووَّاشِينْ ذَايْسنْ أَژْرِي أَطَّاسْ.\f*  
\v 7 ڒفْرُوعْ نّسْ أَذْ زُّوڭَّارْثنْ ؤُ أَوقَّارْ نّسْ أَذْ يِيڒِي أَمْ ؤُزمُّورْ ؤُ ڒفْوَاحْ نّسْ أَمْ \add ڒفْوَاحْ ن ثْشجُّورَا خْ إِذُورَارْ\add* ن لُوبْنَانْ.  
\v 8 نِيثْنِي أَذْ د-ذوْڒنْ، أَذْ قِّيمنْ ذِي ثِيڒِي نّسْ، أَذْ سّدَّارنْ إِمنْذِي، أَذْ نوَّارنْ أَمْ ثْزَايَارْثْ. ڒِيذَارثْ نّسْ أَذْ ثِيڒِي أَخْمِي بِينُو ن لُوبْنَانْ.  
\v 9 \add أَ\add* إِفْرَايِيمْ أَذْ يِينِي: ’مِينْ غَارِي عَاذْ أَكْ-ذ ڒخْيَاڒَاثْ ن لْ-أَصْنَامْ؟‘ نشّْ سْڒِيغْ \add أَسْ\add* ؤُ أَذْ خَاسْ سِّيجّغْ. أَذْ إِڒِيغْ أَمْ يِيشْثْ ن ثْشجَّارْثْ ن ؤُمرْزِي أَزِيزَا، زَّايِي إِ ثتّْوَافْ ڒْغِيدْجثْ نّشْ.“\f ◼ \fr 14:‏9 \ft \+bd ’أَمرْزِي‘\+bd* - نِيغْ ’أَمضْزِي‘.\f*   
\b  
\m
\v 10 ”مَانْ ونْ إِدْجَانْ ذ أَمِيغِيسْ ذ أَفهَّامْ ذِي ثْمسْڒَايِينْ-أَ، مَانْ ونْ إِ غَارْ ثدْجَا ڒفْهَامثْ ؤُ مَانْ ونْ إِ ثنْثْ إِسّْننْ؟ وَاهْ، إِبْرِيذنْ ن سِيذِي نِيشَانْ إِ يدْجَانْ ؤُ إِمْسڭَّاذنْ أَذْ ذَايْسنْ ؤُيُورنْ، مَاشَا إِنِّي إِعدَّانْ أَذْ ذَايْسنْ نّْذرْفنْ.“   