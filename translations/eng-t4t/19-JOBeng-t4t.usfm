\c 1  
\s1 Job and his family  
\p
\v 1 \w In|strong="H3477"\w* \w the|strong="H5493"\w* land \w named|strong="H8034"\w* \w Uz|strong="H5780"\w*, \w there|strong="H1961"\w* \w was|strong="H8034"\w* \w a|strong="H3068"\w* \w man|strong="H7451"\w* \w named|strong="H8034"\w* Job. \w He|strong="H1931"\w* \w was|strong="H8034"\w* \w a|strong="H3068"\w* very \w godly|strong="H3477"\w*/\w righteous|strong="H3477"\w* [DOU] \w man|strong="H7451"\w*, \w who|strong="H1931"\w* greatly respected/revered God \w and|strong="H8034"\w* always avoided \w doing|strong="H7451"\w* \w evil|strong="H7451"\w* \w things|strong="H7451"\w*.  
