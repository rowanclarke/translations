\v 10 \w Y|strong="H3068"\w* \w aquellos|strong="H1992"\w* hombres \w temieron|strong="H3372"\w* \w sobremanera|strong="H1419"\w*, \w y|strong="H3588"\w* dijéronle: ¿\w Por|strong="H3588"\w* \w qué|strong="H3588"\w* has \w hecho|strong="H6213"\w* \w esto|strong="H2063"\w*? \w Porque|strong="H3588"\w* \w ellos|strong="H1992"\w* \w entendieron|strong="H3045"\w* \w que|strong="H3588"\w* \w huía|strong="H1272"\w* \w de|strong="H3588"\w* \w delante|strong="H6440"\w* del \w SEÑOR|strong="H3068"\w*, \w porque|strong="H3588"\w* \w se|strong="H3045"\w* \w lo|strong="H1931"\w* \w había|strong="H3588"\w* \w declarado|strong="H5046"\w*.   
