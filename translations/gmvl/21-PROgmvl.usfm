\q2 ba shemppo naagees; 
\q2 gido attiin 
\q2 izo ixxizaadey hayqqees. 
\q1  
\v 17 Manqos kiyiza asi 
\q2 GODAAS tal7ees; 
\q2 GODAY he lo7o ooso 
\q2 waaga qanxxana. 
\q1  
\v 18 Wodera ne naa seera; 
\q2 izi hayqos bishin 
\q2 co7u ga xeellofa. 
\q1  
\v 19 Eeson yiillotiza asi 
\q2 qaxxayettanaas bessees; 
\q2 neni agga aadhdhiko 
\q2 hara wodekka 
\q2 nees hessaththo oosoy attenna. 
\q1  
\v 20 Zore siya; seerakka ekka. 
\q2 Histtiko neni wurseththan 
\q2 aadho eranchcha gidana. 
\q1  
\v 21 Asa wozinan daro halchchoy dees; 
\q2 gido attiin 
\q2 GODAA qofay polettees. 
\q1  
\v 22 Asappe koyettizay mino siiqo; 
\q2 wordanchcha gidanaappe 
\q2 manqoteththi lo7o. 
\q1  
\v 23 GODAAS yashshi de7os kaaleththees; 
\q2 hessa mala asi woppan dees; 
\q2 iitaykka iza bochchenna. 
\q1  
\v 24 Azallay ba kushe maaddan yeddees; 
\q2 gido attiin pude ba doonan 
\q2 zaaranawu waayettees. 
\q1  
\v 25 Qilccizaade shocikko 
\q2 wozina pacey akeeka taamarana; 
\q2 akeekanchcha asa seerikko 
\q2 izi erateth demmana. 
\q1  
\v 26 Ba aawa bonqqiza nay, 
\q2 ba aayokka kessi yedeththiza nay 
\q2 izi yeellateththinne 
\q2 kawushshateth ehiza naa. 
\q1  
\v 27 Ta naazoo! 
\q2 Ta zore ne siyontta aggiko, 
\q2 ne eriza qaalaakka balana. 
\q1  
\v 28 Wordo markkay 
\q2 suure pirda bolla qilccees; 
\q2 iita asa doonay 
\q2 iitateth banchikees. 
\q1  
\v 29 Qilccizaytas pirday, 
\q2 eeyata zokkos lissoy 
\q2 giigi uttides. 
\c 20  
\q1  
\v 1 Maththosiza ushshi uyizay 
\q2 qilccizaadenne eeya gidees; 
\q2 haytanttan balettida ubbay 
\q2 aadho eranchcha gidenna. 
\q1  
\v 2 Kawo hanqoy gaammo xaago mala; 
\q2 iza yiillochchizay 
\q2 ba shemppo bolla pirdees. 
\q1  
\v 3 Palamappe haakoy 
\q2 izaades bonchcho; 
\q2 gido attiin eeya asi ubbay 
\q2 ooshshas eesotees. 
\q1  
\v 4 Azalla goshshanchchay 
\q2 wodera goyenna; 
\q2 kath shiishshiza wode 
\q2 shiishshanaas koyees; 
\q2 gido attiin aykkoka demmenna. 
