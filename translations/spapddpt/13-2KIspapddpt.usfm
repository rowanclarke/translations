\v 15 \wj \w porque|strong="H3282"\w* \w hicieron|strong="H6213"\w* \w lo|strong="H2088"\w* \w malo|strong="H7451"\w* \w delante|strong="H5869"\w* \w de|strong="H4480"\w* \w Mí|strong="H1961"\w* \w y|strong="H5704"\w* \w me|strong="H4480"\w* provocaron \w a|strong="H3068"\w* \w ira|strong="H3318"\w* \w desde|strong="H4480"\w* \w el|strong="H6213"\w* \w día|strong="H3117"\w* \w cuando|strong="H3117"\w* sus antepasados \w salieron|strong="H3318"\w* \w de|strong="H4480"\w* \w Egipto|strong="H4714"\w* \w hasta|strong="H5704"\w* \w hoy|strong="H3117"\w*.\wj*
\p 
\v 16 \w También|strong="H1571"\w* \w Manasés|strong="H4519"\w* \w derramó|strong="H8210"\w* \w mucha|strong="H7235"\w* \w sangre|strong="H1818"\w* \w inocente|strong="H5355"\w*, \w hasta|strong="H5704"\w* llenar \w de|strong="H5704"\w* ella \w a|strong="H3068"\w* Jerusalén \w de|strong="H5704"\w* un extremo \w a|strong="H3068"\w* otro, \w además|strong="H1571"\w* \w de|strong="H5704"\w* su \w pecado|strong="H2403"\w* \w con|strong="H1571"\w* \w el|strong="H6213"\w* cual estimuló \w a|strong="H3068"\w* \w pecar|strong="H2398"\w* \w a|strong="H3068"\w* \w Judá|strong="H3063"\w* \w para|strong="H5704"\w* \w que|strong="H5704"\w* hiciera \w lo|strong="H6213"\w* \w malo|strong="H7451"\w* ante \nd \w Yavé|strong="H3068"\w*\nd*.
\p 
\v 17 \w Todo|strong="H3605"\w* \w lo|strong="H1697"\w* \w que|strong="H3808"\w* \w hizo|strong="H6213"\w* \w Manasés|strong="H4519"\w* \w y|strong="H5921"\w* \w todo|strong="H3605"\w* \w su|strong="H1992"\w* \w pecado|strong="H2403"\w*, ¿\w no|strong="H3808"\w* están \w escritos|strong="H3789"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* rollo \w de|strong="H5921"\w* \w las|strong="H1992"\w* Crónicas \w de|strong="H5921"\w* \w los|strong="H1992"\w* \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*?
\v 18 \w Manasés|strong="H4519"\w* reposó \w con|strong="H5973"\w* sus antepasados, y fue \w sepultado|strong="H6912"\w* \w en|strong="H5973"\w* \w el|strong="H5973"\w* jardín \w de|strong="H8478"\w* Uza \w que|strong="H1121"\w* \w era|strong="H1121"\w* \w el|strong="H5973"\w* \w de|strong="H8478"\w* su \w casa|strong="H1004"\w*. \w Reinó|strong="H4427"\w* \w en|strong="H5973"\w* su \w lugar|strong="H8478"\w* su \w hijo|strong="H1121"\w* Amón.
\s1 Reinado de Amón en Judá
\p 
\v 19 Amón tenía 22 \w años|strong="H8141"\w* cuando comenzó \w a|strong="H3068"\w* reinar, y \w reinó|strong="H4427"\w* \w dos|strong="H8147"\w* \w años|strong="H8141"\w* \w en|strong="H4480"\w* Jerusalén. \w El|strong="H1121"\w* \w nombre|strong="H8034"\w* \w de|strong="H4480"\w* su madre fue Mesulemet, \w hija|strong="H1323"\w* \w de|strong="H4480"\w* Haruz \w de|strong="H4480"\w* \w Jotba|strong="H3192"\w*.
\v 20 \w Hizo|strong="H6213"\w* \w lo|strong="H6213"\w* \w malo|strong="H7451"\w* ante \nd \w Yavé|strong="H3068"\w*\nd*, como \w hizo|strong="H6213"\w* su padre \w Manasés|strong="H4519"\w*.
\v 21 \w Anduvo|strong="H1980"\w* \w en|strong="H3212"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w caminos|strong="H1870"\w* \w en|strong="H3212"\w* \w los|strong="H3605"\w* cuales estuvo su padre. \w Sirvió|strong="H5647"\w* y \w adoró|strong="H7812"\w* \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w ídolos|strong="H1544"\w* de su padre.
\v 22 Abandonó \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*, el \nd ʼElohim\nd* de sus antepasados y \w no|strong="H3808"\w* \w anduvo|strong="H1980"\w* en el \w camino|strong="H1870"\w* de \nd \w Yavé|strong="H3068"\w*\nd*.
\p 
\v 23 \w Los|strong="H5921"\w* esclavos \w de|strong="H5921"\w* Amón \w conspiraron|strong="H7194"\w* \w contra|strong="H5921"\w* \w él|strong="H5921"\w*, \w y|strong="H5921"\w* \w lo|strong="H5921"\w* \w mataron|strong="H4191"\w* \w en|strong="H5921"\w* su \w casa|strong="H1004"\w*.
\v 24 Pero \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w mató|strong="H5221"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w que|strong="H5921"\w* \w conspiraron|strong="H7194"\w* \w contra|strong="H5921"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* Amón, \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra proclamó \w a|strong="H3068"\w* su \w hijo|strong="H1121"\w* \w Josías|strong="H2977"\w* \w como|strong="H5921"\w* \w rey|strong="H4428"\w* \w en|strong="H5921"\w* su \w lugar|strong="H8478"\w*.
\p 
\v 25 \w Los|strong="H1992"\w* demás \w hechos|strong="H1697"\w* \w de|strong="H5921"\w* Amón, ¿\w no|strong="H3808"\w* están \w escritos|strong="H3789"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* rollo \w de|strong="H5921"\w* \w las|strong="H1992"\w* Crónicas \w de|strong="H5921"\w* \w los|strong="H1992"\w* \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*?
\v 26 Fue \w sepultado|strong="H6912"\w* \w en|strong="H6912"\w* su \w sepulcro|strong="H6912"\w* \w en|strong="H6912"\w* \w el|strong="H1121"\w* \w huerto|strong="H1588"\w* \w de|strong="H8478"\w* Uza, y su \w hijo|strong="H1121"\w* \w Josías|strong="H2977"\w* \w reinó|strong="H4427"\w* \w en|strong="H6912"\w* su \w lugar|strong="H8478"\w*.
\c 22
\s1 Reinado de Josías en Judá
\p 
\v 1 Cuando \w Josías|strong="H2977"\w* comenzó \w a|strong="H3068"\w* reinar tenía \w ocho|strong="H8083"\w* \w años|strong="H8141"\w*, y \w reinó|strong="H4427"\w* en Jerusalén 31 \w años|strong="H8141"\w*. \w El|strong="H1121"\w* \w nombre|strong="H8034"\w* \w de|strong="H1121"\w* su madre fue Jedida, \w hija|strong="H1323"\w* \w de|strong="H1121"\w* Adaía, \w de|strong="H1121"\w* Boscat.
\v 2 \w Hizo|strong="H6213"\w* \w lo|strong="H3808"\w* \w recto|strong="H3477"\w* ante \nd \w Yavé|strong="H3068"\w*\nd*, \w anduvo|strong="H3212"\w* \w en|strong="H5493"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w camino|strong="H1870"\w* \w de|strong="H5869"\w* \w David|strong="H1732"\w* su antepasado y \w no|strong="H3808"\w* \w se|strong="H3808"\w* apartó \w ni|strong="H3808"\w* \w a|strong="H3068"\w* \w la|strong="H3605"\w* \w derecha|strong="H3225"\w* \w ni|strong="H3808"\w* \w a|strong="H3068"\w* \w la|strong="H3605"\w* \w izquierda|strong="H8040"\w*.
\p 
\v 3 \w El|strong="H1121"\w* \w año|strong="H8141"\w* 18 del \w rey|strong="H4428"\w* \w Josías|strong="H2977"\w* \w aconteció|strong="H1961"\w* \w que|strong="H1121"\w* \w el|strong="H1121"\w* \w rey|strong="H4428"\w* \w envió|strong="H7971"\w* \w a|strong="H3068"\w* Safán, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Azalías, \w hijo|strong="H1121"\w* del \w escriba|strong="H5608"\w* Mesulam, \w a|strong="H3068"\w* la \w Casa|strong="H1004"\w* \w de|strong="H1121"\w* \nd \w Yavé|strong="H3068"\w*\nd* y le dijo:
\v 4 \w Vé|strong="H5927"\w* al \w sumo|strong="H1419"\w* \w sacerdote|strong="H3548"\w* \w Hilcías|strong="H2518"\w* y dile \w que|strong="H5971"\w* recoja el \w dinero|strong="H3701"\w* \w que|strong="H5971"\w* fue traído \w a|strong="H3068"\w* \w la|strong="H8104"\w* \w Casa|strong="H1004"\w* \w de|strong="H5971"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w que|strong="H5971"\w* los guardianes \w de|strong="H5971"\w* \w la|strong="H8104"\w* puerta recogieron del \w pueblo|strong="H5971"\w*,
\v 5 \w y|strong="H5921"\w* \w lo|strong="H5921"\w* entreguen \w en|strong="H5921"\w* \w manos|strong="H3027"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* supervisan \w el|strong="H5921"\w* arreglo \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w* \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w a|strong="H3068"\w* fin \w de|strong="H5921"\w* \w que|strong="H5921"\w* \w lo|strong="H5921"\w* entreguen \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* \w hacen|strong="H6213"\w* \w la|strong="H5921"\w* \w obra|strong="H4399"\w* \w para|strong="H5921"\w* reparar \w las|strong="H5921"\w* grietas \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w*,
\v 6 es decir, \w a|strong="H3068"\w* los \w carpinteros|strong="H2796"\w*, constructores y \w albañiles|strong="H2796"\w* para comprar \w madera|strong="H6086"\w* y piedra labrada \w a|strong="H3068"\w* fin de reparar la \w Casa|strong="H1004"\w*.
\v 7 \w Que|strong="H3588"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* \w les|strong="H1992"\w* pida cuenta \w del|strong="H5921"\w* \w dinero|strong="H3701"\w* \w que|strong="H3588"\w* entregan \w en|strong="H5921"\w* \w sus|strong="H1992"\w* \w manos|strong="H3027"\w*, \w porque|strong="H3588"\w* trabajan \w con|strong="H5921"\w* fidelidad.
\p 
\v 8 Entonces \w el|strong="H5921"\w* \w sumo|strong="H1419"\w* \w sacerdote|strong="H3548"\w* \w Hilcías|strong="H2518"\w* dijo \w al|strong="H5921"\w* \w escriba|strong="H5608"\w* Safán: ¡\w Hallé|strong="H4672"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w* \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w el|strong="H5921"\w* Rollo \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w Ley|strong="H8451"\w*! \w Hilcías|strong="H2518"\w* \w entregó|strong="H5414"\w* \w el|strong="H5921"\w* Rollo \w a|strong="H3068"\w* Safán, quien \w lo|strong="H5921"\w* \w leyó|strong="H7121"\w*.
\v 9 \w El|strong="H5921"\w* \w escriba|strong="H5608"\w* Safán fue \w al|strong="H5921"\w* \w rey|strong="H4428"\w* \w y|strong="H5921"\w* \w le|strong="H5921"\w* llevó \w respuesta|strong="H1697"\w*: Tus esclavos sacaron \w el|strong="H5921"\w* \w dinero|strong="H3701"\w* \w que|strong="H5921"\w* \w se|strong="H5921"\w* \w halló|strong="H4672"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w*, \w y|strong="H5921"\w* \w lo|strong="H1697"\w* entregaron \w en|strong="H5921"\w* \w manos|strong="H3027"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* supervisores \w de|strong="H5921"\w* \w los|strong="H5921"\w* trabajos \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w* \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\v 10 El \w escriba|strong="H5608"\w* Safán también informó \w al|strong="H4428"\w* \w rey|strong="H4428"\w*: El \w sacerdote|strong="H3548"\w* \w Hilcías|strong="H2518"\w* me \w entregó|strong="H5414"\w* un rollo. \w Y|strong="H3068"\w* Safán \w lo|strong="H5612"\w* \w leyó|strong="H7121"\w* \w delante|strong="H6440"\w* del \w rey|strong="H4428"\w*.
\p 
\v 11 \w Aconteció|strong="H1961"\w* \w que|strong="H1697"\w* \w cuando|strong="H1961"\w* el \w rey|strong="H4428"\w* \w escuchó|strong="H8085"\w* las \w palabras|strong="H1697"\w* del Rollo \w de|strong="H1697"\w* la \w Ley|strong="H8451"\w*, \w rasgó|strong="H7167"\w* sus ropas.
\v 12 Luego \w el|strong="H1121"\w* \w rey|strong="H4428"\w* dio \w orden|strong="H6680"\w* \w al|strong="H4428"\w* \w sacerdote|strong="H3548"\w* \w Hilcías|strong="H2518"\w*, \w a|strong="H3068"\w* Ahicam, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Safán, \w a|strong="H3068"\w* Acbor, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Micaías, \w al|strong="H4428"\w* \w escriba|strong="H5608"\w* Safán, y \w a|strong="H3068"\w* \w Asaías|strong="H6222"\w* esclavo del \w rey|strong="H4428"\w*, y dijo:
\v 13 \w Vayan|strong="H3212"\w* \w y|strong="H3588"\w* consulten \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w por|strong="H5921"\w* \w mí|strong="H5921"\w*, \w por|strong="H5921"\w* \w el|strong="H1931"\w* \w pueblo|strong="H5971"\w* \w y|strong="H3588"\w* \w por|strong="H5921"\w* \w todo|strong="H3605"\w* \w Judá|strong="H3063"\w*, \w con|strong="H5921"\w* respecto \w a|strong="H3068"\w* \w las|strong="H5921"\w* \w Palabras|strong="H1697"\w* \w de|strong="H5921"\w* \w este|strong="H2088"\w* rollo \w que|strong="H3588"\w* \w se|strong="H1931"\w* \w halló|strong="H4672"\w*. \w Grande|strong="H1419"\w* \w es|strong="H1931"\w* \w la|strong="H1931"\w* \w ira|strong="H2534"\w* \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w que|strong="H3588"\w* \w se|strong="H1931"\w* encendió \w contra|strong="H5921"\w* \w nosotros|strong="H3605"\w*, \w porque|strong="H3588"\w* nuestros antepasados \w no|strong="H3808"\w* \w escucharon|strong="H8085"\w* \w las|strong="H5921"\w* \w Palabras|strong="H1697"\w* \w de|strong="H5921"\w* \w este|strong="H2088"\w* rollo \w con|strong="H5921"\w* \w el|strong="H1931"\w* fin \w de|strong="H5921"\w* \w hacer|strong="H6213"\w* \w según|strong="H5921"\w* \w todo|strong="H3605"\w* \w lo|strong="H1931"\w* \w que|strong="H3588"\w* \w fue|strong="H3212"\w* \w escrito|strong="H3789"\w* \w para|strong="H5921"\w* \w nosotros|strong="H3605"\w*.
\p 
\v 14 \w El|strong="H1931"\w* \w sacerdote|strong="H3548"\w* \w Hilcías|strong="H2518"\w* y Ahicam, Acbor, Safán y \w Asaías|strong="H6222"\w* \w fueron|strong="H3212"\w* \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w profetisa|strong="H5031"\w* Hulda, esposa \w de|strong="H1121"\w* Salum, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Ticva, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Harhas, guardián \w de|strong="H1121"\w* las ropas, \w quien|strong="H1931"\w* \w vivía|strong="H3427"\w* \w en|strong="H3212"\w* \w el|strong="H1931"\w* \w segundo|strong="H4932"\w* sector \w de|strong="H1121"\w* Jerusalén, y \w hablaron|strong="H1696"\w* con \w ella|strong="H1931"\w*.
\p 
\v 15 \w Y|strong="H3068"\w* ella les dijo: \nd \w Yavé|strong="H3068"\w* ʼElohim\nd* de \w Israel|strong="H3478"\w* dice: \wj Digan al varón \w que|strong="H3541"\w* los \w envió|strong="H7971"\w* \w a|strong="H3068"\w* mí: \wj*
\v 16 \wj \nd \w Yavé|strong="H3068"\w*\nd* \w dice|strong="H1697"\w*: \w Ciertamente|strong="H2005"\w* Yo \w traigo|strong="H7121"\w* \w el|strong="H5921"\w* \w mal|strong="H7451"\w* \w sobre|strong="H5921"\w* \w este|strong="H2088"\w* \w lugar|strong="H4725"\w* \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* sus \w habitantes|strong="H3427"\w*, \w como|strong="H5921"\w* dicen \w las|strong="H5921"\w* \w Palabras|strong="H1697"\w* \w del|strong="H5921"\w* rollo \w que|strong="H5921"\w* \w leyó|strong="H7121"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, \wj*
\v 17 \wj \w porque|strong="H3808"\w* me abandonaron y quemaron incienso \w a|strong="H3068"\w* otros \tl ʼelohim\tl* \w para|strong="H4616"\w* provocarme \w a|strong="H3068"\w* \w ira|strong="H2534"\w* con \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w obra|strong="H4639"\w* \w de|strong="H8478"\w* sus \w manos|strong="H3027"\w*. \w Así|strong="H2088"\w* \w pues|strong="H2088"\w*, mi \w ira|strong="H2534"\w* \w se|strong="H3808"\w* encendió contra \w este|strong="H2088"\w* \w lugar|strong="H4725"\w* y \w no|strong="H3808"\w* \w será|strong="H3808"\w* apagada. \wj*
\p 
\v 18 \wj Pero \w al|strong="H4428"\w* \w rey|strong="H4428"\w* \w de|strong="H1697"\w* \w Judá|strong="H3063"\w*, \w que|strong="H1697"\w* los \w envió|strong="H7971"\w* \w a|strong="H3068"\w* consultar \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*, le dirán: \nd \w Yavé|strong="H3068"\w* ʼElohim\nd* \w de|strong="H1697"\w* \w Israel|strong="H3478"\w* \w dice|strong="H1697"\w*: Las \w Palabras|strong="H1697"\w* \w que|strong="H1697"\w* \w oíste|strong="H8085"\w* se cumplirán, \wj*
\v 19 \wj \add pero\add* \w porque|strong="H5921"\w* tu \w corazón|strong="H3824"\w* \w se|strong="H1961"\w* enterneció, \w te|strong="H5921"\w* humillaste \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w al|strong="H5921"\w* \w escuchar|strong="H8085"\w* \w lo|strong="H2088"\w* \w que|strong="H5921"\w* \w hablé|strong="H1696"\w* \w contra|strong="H5921"\w* \w este|strong="H2088"\w* \w lugar|strong="H4725"\w* \w y|strong="H1571"\w* sus \w habitantes|strong="H3427"\w*, \w que|strong="H5921"\w* \w ellos|strong="H5921"\w* \w serán|strong="H1961"\w* una desolación \w y|strong="H1571"\w* \w maldición|strong="H7045"\w*, \w y|strong="H1571"\w* tú rasgaste tus ropas \w y|strong="H1571"\w* lloraste \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w Mí|strong="H5921"\w*, Yo \w también|strong="H1571"\w* \w escuché|strong="H8085"\w*, \w dice|strong="H5002"\w* \nd \w Yavé|strong="H3068"\w*\nd*.\wj*
\p 
\v 20 \wj \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w*, \w ciertamente|strong="H2005"\w* Yo \w te|strong="H5869"\w* recogeré \w con|strong="H5921"\w* tus antepasados. Serás llevado \w a|strong="H3068"\w* tu \w sepulcro|strong="H6913"\w* \w en|strong="H5921"\w* \w paz|strong="H7965"\w* \w y|strong="H5921"\w* tus \w ojos|strong="H5869"\w* \w no|strong="H3808"\w* \w verán|strong="H7200"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w mal|strong="H7451"\w* \w que|strong="H3808"\w* Yo traigo \w sobre|strong="H5921"\w* \w este|strong="H2088"\w* \w lugar|strong="H4725"\w*.\wj* \w Y|strong="H3068"\w* \w ellos|strong="H5921"\w* llevaron \w la|strong="H5921"\w* \w respuesta|strong="H1697"\w* \w al|strong="H5921"\w* \w rey|strong="H4428"\w*.
\c 23
\s1 Reformas del rey Josías
\p 
\v 1 Entonces \w el|strong="H3605"\w* \w rey|strong="H4428"\w* convocó \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w ancianos|strong="H2205"\w* de \w Judá|strong="H3063"\w* y Jerusalén para \w que|strong="H3605"\w* se reunieran con \w él|strong="H3605"\w*.
\v 2 \w El|strong="H3605"\w* \w rey|strong="H4428"\w* \w subió|strong="H5927"\w* \w a|strong="H3068"\w* \w la|strong="H3605"\w* \w Casa|strong="H1004"\w* \w de|strong="H5704"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w y|strong="H5704"\w* \w todo|strong="H3605"\w* hombre \w de|strong="H5704"\w* \w Judá|strong="H3063"\w* \w y|strong="H5704"\w* \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* \w de|strong="H5704"\w* Jerusalén iban \w con|strong="H5704"\w* \w él|strong="H3605"\w*, así \w como|strong="H5704"\w* \w los|strong="H3427"\w* \w sacerdotes|strong="H3548"\w*, \w los|strong="H3427"\w* \w profetas|strong="H5030"\w* \w y|strong="H5704"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w*, \w desde|strong="H5704"\w* \w el|strong="H3605"\w* \w menor|strong="H6996"\w* \w hasta|strong="H5704"\w* \w el|strong="H3605"\w* \w mayor|strong="H1419"\w*. Entonces \w él|strong="H3605"\w* \w leyó|strong="H7121"\w* \w a|strong="H3068"\w* oídos \w de|strong="H5704"\w* \w ellos|strong="H3605"\w* \w todas|strong="H3605"\w* las \w Palabras|strong="H1697"\w* del rollo del \w Pacto|strong="H1285"\w* \w que|strong="H5704"\w* \w fue|strong="H3063"\w* \w hallado|strong="H4672"\w* \w en|strong="H5704"\w* \w el|strong="H3605"\w* \w Templo|strong="H1004"\w* \w de|strong="H5704"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\v 3 \w El|strong="H5921"\w* \w rey|strong="H4428"\w* \w se|strong="H5921"\w* colocó \w en|strong="H5921"\w* \w pie|strong="H5975"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w columna|strong="H5982"\w*. \w Hizo|strong="H3772"\w* \w pacto|strong="H1285"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w de|strong="H5921"\w* seguirlo, \w guardar|strong="H8104"\w* sus \w Mandamientos|strong="H4687"\w*, Testimonios \w y|strong="H5921"\w* Preceptos \w con|strong="H5921"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w corazón|strong="H3820"\w* \w y|strong="H5921"\w* \w toda|strong="H3605"\w* \w el|strong="H5921"\w* \w alma|strong="H5315"\w*, \w y|strong="H5921"\w* cumplir \w las|strong="H5921"\w* \w Palabras|strong="H1697"\w* \w del|strong="H5921"\w* \w Pacto|strong="H1285"\w* \w escritas|strong="H3789"\w* \w en|strong="H5921"\w* \w ese|strong="H2088"\w* rollo. \w Y|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w confirmó|strong="H5975"\w* \w el|strong="H5921"\w* \w Pacto|strong="H1285"\w*.
