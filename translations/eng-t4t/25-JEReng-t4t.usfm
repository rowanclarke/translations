\c 20  
\s1 Pashhur arrested Jeremiah  
\p
\v 1 \w Pashhur|strong="H6583"\w*, \w the|strong="H8085"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Immer, \w was|strong="H3068"\w* \w a|strong="H3068"\w* \w priest|strong="H3548"\w* \w who|strong="H1931"\w* supervised \w the|strong="H8085"\w* \w temple|strong="H1004"\w* guards. \w He|strong="H1931"\w* \w heard|strong="H8085"\w* \w those|strong="H8085"\w* \w things|strong="H1697"\w* \w that|strong="H8085"\w* \w I|strong="H1697"\w* \w had|strong="H3068"\w* \w prophesied|strong="H5012"\w*.  
