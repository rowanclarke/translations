\id ISA - Biblica® Open Igbo Contemporary Bible 2020
\h Aịzaya
\toc1 Aịzaya
\toc2 Aịzaya
\toc3 Aịz
\mt1 Aịzaya
\c 1
\p 
\v 1 Ọhụ Aịzaya nwa Emọz, nke ọ hụrụ banyere Juda na Jerusalem nʼoge ọchịchị Ụzaya, Jotam, Ehaz na Hezekaya, bụ ndị eze Juda.
\b
\s1 Mba na-enupu isi
\q1 
\v 2 Gee ntị, gị eluigwe, gee ntị, gị ụwa!
\q2 Nʼihi na \nd Onyenwe anyị\nd* ekwuola okwu:
\q1 “Azụrụ m ụmụntakịrị, zụlite ha,
\q2 ma ha enupula isi megide m.
\q1 
\v 3 Ehi maara onyenwe ya,
\q2 ịnyịnya ibu makwaara ebe onyenwe ya na-anọ azụ ya nri,
\q1 ma Izrel amaghị m,
\q2 ndị m adịghị aghọtakwa.”
\b
\q1 
\v 4 Ahụhụ dịrị mba ndị mmehie,
\q2 ndị ajọ omume riri ahụ,
\q1 ụmụ ndị ajọ omume,
\q2 ụmụ ndị nyefere onwe ha na mmerụ!
\q1 Ha agbakụtala \nd Onyenwe anyị\nd* azụ,
\q2 ha elelịala Onye dị Nsọ nke Izrel,
\q2 ha agbakụtala ya azụ ha.
\b
\q1 
\v 5 Gịnị mere a ga-eji nọgide na-eti unu ihe?
\q2 Gịnị mere unu ji nọgide na nnupu isi?
\q1 Lee ọnya juru unu isi,
\q2 leekwa na ọrịa na-arịa obi unu.
\q1 
\v 6 O nweghị akụkụ ahụ unu zuruoke,
\q2 site nʼọbọ ụkwụ unu ruo nʼopi isi unu;
\q1 ọnya, na ntihịa ahụ,
\q2 na ọnya mmerụ ahụ, jupụtara unu nʼahụ;
\q1 e kechikwaghị ha,
\q2 e tekwaghị ha mmanụ.
\b
\q1 
\v 7 Ala unu tọgbọrọ nʼefu,
\q2 agbaakwala obodo unu ọkụ.
\q1 Ndị mbịarambịa ewerechaala ihe dị nʼubi unu
\q2 nʼihu unu,
\q2 ha emeela ka ọ tọgbọrọ nʼefu dịka mgbe onye ọbịa kpochapụrụ ihe dị nʼime ya.\f + \fr 1:7 \ft Amaokwu a na-akọwa ihe mere nʼoge ndị agha Asịrịa busoro ha agha mgbe eze Senakerib na-achị \xt 2Ez 18:13\xt*\f*
\q1 
\v 8 Ada Zayọn ka a hapụrụ
\q2 dịka ụlọ nche dị nʼubi vaịnị,
\q1 dịka ụlọ nta dị nʼubi kukumba,
\q2 dịka obodo ndị iro gbara gburugburu.
\q1 
\v 9 Ọ bụrụ na \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile
\q2 emeghị ka mmadụ ole na ole fọdụ ndụ nʼime anyị,
\q1 anyị gara adị ka Sọdọm,
\q2 anyị gaara adịkwa ka Gọmọra.
\b
\q1 
\v 10 Nụrụnụ okwu \nd Onyenwe anyị\nd*,
\q2 unu ndị na-achị Sọdọm;
\q1 geenụ ntị nʼozizi Chineke anyị,
\q2 unu ndị Gọmọra.
\q1 
\v 11 “Nʼihi gịnị ka unu ji na-achụrụ m ọtụtụ aja,
\q2 gịnị ka ihe ndị a bụ nye m?”
\q2 ka \nd Onyenwe anyị\nd* sịrị.
\q1 “Afọ ejula m nʼaja nsure ọkụ niile
\q2 nke eji ebule na anụmanụ e mere ka ha gbaa abụba chụọ;
\q1 Ọbara oke ehi na nke ụmụ atụrụ na mkpi
\q2 adịghị atọkwa m ụtọ.
\q1 
\v 12 Mgbe unu na-abịa ka ahụ unu nʼihu m,
\q2 onye chọrọ nke a nʼaka unu?
\q2 Kwụsịnụ ịzọtọ ogige m.
\q1 
\v 13 Kwụsị iweta onyinye niile na-enweghị isi.
\q2 Ihe nsure ọkụ na-esi isi ụtọ unu bụrụ m ihe arụ.
\q1 Mmemme ọnwa ọhụrụ, na nke ụbọchị izuike, na nzukọta unu niile,
\q2 apụghị m ịnagide mkpọkọta unu nke na-abaghị uru.
\q1 
\v 14 Mkpụrụobi m kpọrọ mmemme ọnwa ọhụrụ, na mmemme unu ndị ọzọ
\q2 a kara aka asị.
\q1 Ha bụụrụ m ibu arọ,
\q2 ike agwụkwala m ibu ha.
\q1 
\v 15 Mgbe unu na-agbasa aka unu nʼekpere,
\q2 agaghị m aṅa unu ntị;
\q1 ọ bụladị mgbe unu na-ekpe ọtụtụ ekpere,
\q2 agaghị m aṅa ntị.”
\b
\q1 Nʼihi na aka unu jupụtara nʼọbara!
\b
\q1 
\v 16 Sachapụnụ onwe unu, dịkwanụ ọcha.
\q2 Wezuganụ ajọ omume unu niile site nʼihu m;
\q2 kwụsịnụ ime ihe na-adịghị mma.
\q1 
\v 17 Mụtanụ otu e si eme ihe ziri ezi; chọọnụ ikpe ziri ezi,
\q2 nyerenụ ndị a na-emegbu aka.
\q1 Werenụ ọnọdụ nna nʼebe ndị na-enweghị nna nọ,
\q2 ma kwuchitenụ ọnụ ụmụ nwanyị di ha nwụrụ.
\b
\q1 
\v 18 “Bịanụ ka anyị kparịtaa ụka,”
\q2 bụ ihe \nd Onyenwe anyị\nd* na-asị.
\q1 “A sịkwarị na mmehie unu dị ka uwe uhie,
\q2 ha ga-adị ọcha dịka akụmmiri igwe,\f + \fr 1:18 \ft Ihe ndị ọcha na-akpọ snoo.\f*
\q1 a sịkwa na ha dị uhie uhie dịka ogho uhie,
\q2 ha ga-adịkwa ka ajị anụ ọcha.
\q1 
\v 19 Ọ bụrụ na unu ga-ekwenye, ọ bụrụ na unu ga-erubere m isi,
\q2 aga m eme ka unu nwee ezi ihe nke unu ga-eri nʼala a.
\q1 
\v 20 Ma ọ bụrụ na unu ajụ ma nupu isi,
\q2 ọ bụ mma agha ka a ga-eji gbuchapụ unu.”
\q1 Nʼihi na ọnụ \nd Onyenwe anyị\nd* ekwula ya.
\b
\q1 
\v 21 Lee ka obodo ahụ kwesiri ntụkwasị obi
\q2 aghọọla onye akwụna!
\q1 Ọ bụ nke jupụtararị nʼikpe ziri ezi;
\q2 ezi omume na-anọbu nʼime ya,
\q2 ma ugbu a, ọ bụzi ndị ogbu mmadụ.
\q1 
\v 22 Ọlaọcha gị aghọọla unyi,
\q2 ezi mmanya gị aghọọla nke a gwafere mmiri oke.
\q1 
\v 23 Ndị ndu gị niile bụ ndị nnupu isi,
\q2 ndị bụkwa ndị enyi ndị ohi,
\q1 onye ọbụla nʼime ha hụrụ iri ngarị nʼanya,
\q2 na-agbasokwa onyinye.
\q1 Ha adịghị echebe ndị na-enweghị nna
\q2 ikpe gbasara ndị inyom di ha nwụrụ adịghị abịa nʼihu ha.
\b
\q1 
\v 24 Nʼihi ya, Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile,
\q2 Onye dị ike nke Izrel, kwubiri sị,
\q1 “Aga m abọ ọbọ megide ndị iro m,
\q2 ime ka unu gharakwa inye m nsogbu ọzọ.
\q1 
\v 25 Aka m ga-abịakwasị unu.
\q2 Aga m anụcha unu dịka e si anụcha ọlaedo,
\q2 si otu a wepụchaa unyi niile dị nʼime unu.
\q1 
\v 26 Emesịa, aga m enye unu ndị na-ekpe ikpe ziri ezi.
\q2 Ndị na-adụ unu ọdụ ga-abụkwa ndị nwere uche dịka ndị unu nwere na mbụ.
\q1 Ọzọ, a ga-akpọ obodo unu
\q2 Obodo Ezi Omume,
\q2 Obodo kwesiri Ntụkwasị Obi.”
\b
\q1 
\v 27 A ga-eji ikpe ziri ezi zọpụta Zayọn.
\q2 Ọ ga-ejikwa ezi omume zọpụta ndị niile lọghachikwutere ya.
\q1 
\v 28 Ma ndị mmehie niile na ndị niile na-enupu isi ka ọ ga-ala nʼiyi;
\q2 ọ ga-egbukwa ndị niile na-agbakụta \nd Onyenwe anyị\nd* azụ.
\b
\q1 
\v 29 “Ihere ga-eme unu nʼihi osisi ook nsọ ndị ahụ niile
\q2 obi unu na-enwe aṅụrị nʼime ha.
\q1 Ihere ga-eme unu nʼihi ubi a gbara ogige ndị ahụ
\q2 unu jiri aka unu họrọ.
\q1 
\v 30 Unu ga-ala nʼiyi dịka osisi ook na-akpọnwụ akpọnwụ
\q2 maọbụ ka ubi a gbara ogige nke mmiri kọrọ.
\q1 
\v 31 Onye kachasị ike nʼetiti unu ga-ala nʼiyi dịka ahịhịa na-ere ọkụ;
\q2 ọrụ ya ga-abụ icheku ọkụ
\q1 nke ga-emenye ọkụ ahụ ga-erepịa unu.
\q2 Ọ dịkwaghị onye pụrụ imenyụ ya.”
\c 2
\s1 Ugwu nsọ \nd Onyenwe anyị\nd*
\p 
\v 1 Nke a bụ ihe Aịzaya nwa Emọz hụrụ banyere Juda na Jerusalem.
\b
\p 
\v 2 Nʼụbọchị ikpeazụ,
\q1 ugwu nke ụlọnsọ ukwu \nd Onyenwe anyị\nd*, ga-abụ nke eguzobere
\q2 dịka ugwu dị elu karịa ugwu niile,
\q1 a ga-ebuli ya elu karịa ugwu nta niile,
\q2 mba niile dị iche iche ga-eruba nʼime ya dịka iyi.
\p 
\v 3 Ọtụtụ ndị mmadụ ga-abịa ma sịkwa,
\q1 “Bịanụ, ka anyị rigoruo ugwu \nd Onyenwe anyị\nd*,
\q2 ka anyị gaa nʼụlọnsọ ukwu Chineke nke Jekọb.
\q1 Ọ ga-akụziri anyị ụzọ\f + \fr 2:3 \ft Ya bụ, ụkpụrụ\f* ya niile,
\q2 ka anyị nwe ike jee ije nʼokporoụzọ ya niile.”\f + \fr 2:3 \ft \xt Zek 8:21-23\xt*\f*
\q1 Iwu ga-esi na Zayọn pụta,
\q2 okwu \nd Onyenwe anyị\nd* ga-esitekwa na Jerusalem pụta.\f + \fr 2:3 \ft \xt Luk 24:47\xt*\f*
\q1 
\v 4 Ọ ga-ekpe ikpe nʼetiti mba niile,
\q2 doziekwa esemokwu dị nʼetiti ndị dị iche iche.
\q1 Ha ga-akpụgharịkwa mma agha ha niile mee ka ha bụrụ mma oge;
\q2 kpụgharịkwa ùbe ha mee ya ka ọ ghọọ mma ịkwacha osisi.
\q1 Mba ọbụla agakwaghị ebuli mma agha megide mba ọzọ,
\q2 maọbụ zụọ onwe ha nʼịlụ agha ọzọ.
\b
\q1 
\v 5 Unu ụlọ Jekọb, bịanụ
\q2 ka anyị na-agbaso ìhè nke \nd Onyenwe anyị\nd* anyị.
\s1 Ụbọchị \nd Onyenwe anyị\nd*
\q1 
\v 6 Gị, bụ \nd Onyenwe anyị\nd*, Ị gbakụtala ndị gị,
\q2 bụ ụlọ Jekọb azụ.
\q1 Nʼihi na ha jupụtara nʼikpere arụsị nke si nʼọwụwa anyanwụ.
\q2 Ha na-ajụkwa ase dịka ndị Filistia.
\q2 Ha na ndị na-ekpere arụsị na-ejikọkwa aka.
\q1 
\v 7 Ala ha jupụtara nʼọlaọcha na ọlaedo,
\q2 ha bara ụba nke ukwuu.
\q1 Ala ha jupụtara nʼịnyịnya.
\q2 Ụgbọ agha ha dịkwa ukwuu.
\q1 
\v 8 Ala ha jupụtara nʼarụsị,
\q2 ha na-akpọ isiala nye ihe ndị ahụ ha ji aka ha kpụọ,
\q2 ihe ndị ahụ mkpịsịaka ha kpụrụ.
\q1 
\v 9 Nʼihi ya, a ga-eme ka mmadụ bụrụ ihe e wedara nʼala,
\q2 meekwa ka mmadụ niile bụrụ ndị e wedara nʼala.
\q2 Ya mere, agbagharala ha.
\b
\q1 
\v 10 Gaanụ nʼime nkume,
\q2 zoonụ nʼime ala nʼihi ihe egwu si nʼebe \nd Onyenwe anyị\nd*,
\q2 na nʼihi ịma mma ebube nke ịdị ukwuu ya.
\q1 
\v 11 Anya nke onye nganga ka a ga-eweda nʼala,
\q2 mpako nke ndị mmadụ ka a ga-ewedakwa nʼala.
\q1 Ọ bụ naanị \nd Onyenwe anyị\nd* ka a ga-ebuli elu nʼụbọchị ahụ.
\b
\q1 
\v 12 \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, nwere ụbọchị ọ kwadooro
\q2 nye ndị mpako na ndị na-ebuli onwe ha elu,
\q1 nʼihi na ihe niile e buliri elu
\q2 (ka a ga-eweda nʼala),
\q1 
\v 13 nye osisi sida niile topụrụ ogologo ma maa mma nke Lebanọn,\f + \fr 2:13 \ft Lebanọn bụ obodo dị nʼakụkụ ọwụwa anyanwụ osimiri Jọdan. Ihe e ji mara obodo a bụ osisi ook na-eto nʼebe ahụ na ehi \xt Zek 11:1-2\xt*\f*
\q2 na osisi ook niile nke Bashan,
\q1 
\v 14 nye ugwu ukwu niile nke dị elu,
\q2 na ugwu nta niile e buliri elu,
\q1 
\v 15 nye ụlọ elu niile,
\q2 na mgbidi niile e wusiri ike,
\q1 
\v 16 nye ụgbọ mmiri niile e ji azụ ahịa,\f + \fr 2:16 \ft Ụgbọ niile nke Tashish\f*
\q2 na ụgbọ mmiri ndị ọzọ niile buru ibu maa mma.
\q1 
\v 17 Onye nganga ka a ga-eweda nʼala,
\q2 mpako nke ndị mmadụ niile ka a ga-eweda nʼala.
\q1 Naanị \nd Onyenwe anyị\nd* ka a ga-ebuli elu nʼụbọchị ahụ.
\q2 
\v 18 A ga-ala arụsị niile nʼiyi, mee ka ha ghara ịdịkwa.
\b
\q1 
\v 19 Ndị mmadụ ga-agba ọsọ gbaba nʼọnụ dị na nkume,
\q2 na nʼọnụ e gwuru nʼala,
\q1 nʼihi egwu \nd Onyenwe anyị\nd*,
\q2 na nʼihi ịma mma ebube nke ịdị ukwuu ya,
\q2 mgbe ọ ga-ebili ịyọgharị ụwa.
\q1 
\v 20 Nʼụbọchị ndị ahụ,
\q2 ha ga-atụfusị arụsị ọlaedo na nke ọlaọcha ha kpụrụ,
\q1 nke ha kpụrụ ma na-efe,
\q2 hapụrụ ha ụmụ oke, na ụmụ ụsụ.
\q1 
\v 21 Mgbe ahụ, ha ga-ezo onwe ha nʼoghere niile dị nʼoke nkume,
\q2 na nʼime ọgba niile nke oke nkume
\q1 nʼihi ịgbanarị iwe ọkụ \nd Onyenwe anyị\nd*,
\q2 na ịma mma ebube nke ịdị ukwuu ya,
\q2 mgbe o biliri ịyọgharị ụwa.
\b
\q1 
\v 22 Kwụsị ịtụkwasị mmadụ efu obi.
\q2 O nweghị ihe ọ bụ karịa naanị nkuume ahụ dị ya nʼime,
\q2 nʼihi gịnị ka e ji agụnye ya?
\c 3
\s1 Ahụhụ dịrị Juda na Jerusalem
\q1 
\v 1 Nʼihi na, lee, Onyenwe anyị,
\q2 bụ \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile,
\q1 na-akwado isite na Jerusalem na Juda
\q2 wezuga ihe nnweta na ihe nkwado niile,
\q1 ya na ihe oriri niile na mmiri ọṅụṅụ niile.
\q2 
\v 2 Ọ ga-ewezugakwa ndị bụ dike nʼetiti ha, na onye agha,
\q1 na onye ikpe, na onye amụma,
\q2 na onye na-ajụ ase, na ndị okenye ha,
\q1 
\v 3 na onyeisi agha na-achị ndị agha iri ise, na onye a na-asọpụrụ,
\q2 na onye ndụmọdụ, na onye ọka maara ọrụ, na onye nwere ezi mmụọ nghọta ịkọ mmadụ ibe ya ọgwụ.
\b
\q1 
\v 4 “Aga m eme ka ụmụ okorobịa ghọọ ndị ozi ha,
\q2 meekwa ka ụmụ na-aṅụ ara bụrụ ndị ịchị isi dị nʼaka ha.”
\b
\q1 
\v 5 Ndị mmadụ ga-emegbu ibe ha,
\q2 otu onye megide onye ọzọ, onye agbataobi megide onye agbataobi ibe ya.
\q1 Ụmụ okorobịa ga-ebili megide ndị okenye,
\q2 ndị a na-elelị ga-emegide ndị a na-asọpụrụ.
\b
\q1 
\v 6 Otu nwoke ga-ejide nwanne ya nwoke
\q2 nʼụlọ nna ya sị ya,
\q1 “I nwere akwa mgbochi, bụrụ onyendu anyị;
\q2 lekọta mkpọmkpọ ebe a anya.”
\q1 
\v 7 Ma ọ ga-azaghachi nʼụbọchị ahụ sị,
\q2 “O nweghị ihe m pụrụ ime.
\q1 Enweghị m nri maọbụ akwa mgbochi nʼụlọ m.
\q2 Emela m onyendu ndị a.”
\b
\q1 
\v 8 Lee na Jerusalem na-asọ ngọngọ.
\q2 Juda na-adakwa.\f + \fr 3:8 \ft \xt 2Ih 36:17\xt*\f*
\q1 Nʼihi na ndị bi nʼime ya ekwujọọla \nd Onyenwe anyị\nd*.
\q2 Ha na-elelịkwa, ma na-enupu isi nʼebube Onyenwe anyị.
\q1 
\v 9 Ihu ha na-egosi ihe ha bụ. Ọ na-ezipụta ajọ omume ha.
\q2 Ha na-anya isi nʼime mmehie ha dịka Sọdọm.
\q2 Ihere adịghịkwa eme ha.
\q1 Ahụhụ ga-adịrị ha,
\q2 nʼihi na ha ejirila aka ha kpatara onwe ha ahụhụ.
\b
\q1 
\v 10 Zie ndị ezi omume niile ozi sị ha, na ihe ga-agara ha nke ọma,
\q2 nʼihi na mkpụrụ sitere nʼomume ha niile ka ha ga-eri.\f + \fr 3:10 \ft \xt Abụ 128:2\xt*\f*
\q1 
\v 11 Ma gwa ndị na-emebi iwu na ahụhụ dịrị ha.
\q2 Mbibi adakwasịla ha!
\q1 Ha ga-eketa oke ruoru ha,
\q2 nʼihi ihe aka ha kpataara ha.
\b
\q1 
\v 12 Ụmụ okorobịa na-emegbu ndị m,
\q2 ụmụ nwanyị na-achịkwa ha.
\q1 Ndị m, lee na ndị na-achị unu na-eduhie unu ụzọ.
\q2 Ha na-eme ka unu kpafuo; ha esitela nʼezi ụzọ wezuga unu.
\b
\q1 
\v 13 \nd Onyenwe anyị\nd* anyị ewerela ọnọdụ ya nʼụlọikpe;
\q2 ọ na-eguzo ikpe ndị ya niile ikpe.
\q1 
\v 14 Onyenwe anyị na-aba nʼikpe
\q2 megide ndị okenye na ndị ndu nke ndị ya niile.\f + \fr 3:14 \ft Nʼihi na ọ bụ ha na-emegbu ndị ya\f*
\q1 Ọ bụ unu bụ ndị lara ubi vaịnị m nʼiyi;
\q2 ihe unu ji aka ike pụnara ndị ogbenye jupụtara nʼụlọ unu.
\q1 
\v 15 Gịnị mere unu ji azọpịa ndị m,
\q2 “Gịnị mere unu ji si otu a na-egwepịa ihu ndị ogbenye?”
\q2 Otu a ka Onyenwe anyị, bụ \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwupụtara.
\b
\q1 
\v 16 Ọzọkwa, \nd Onyenwe anyị\nd* kwuru sị,
\q2 “Ndị inyom Zayọn bụ ndị mpako.
\q1 Ha ji olu e setịrị eseti,
\q2 na anya na-achọgharị ndị ikom ha ga-aghọgbuta na-ejegharị.
\q1 Ha na-ejegharịkwa na-arọ mma na-aṅagharịkwa ukwu,
\q2 na-emekwa ka ihe ịchọ mma ọla ụkwụ ha na-ada ụda.
\q1 
\v 17 Nʼihi ya, Onyenwe anyị ga-eme ka ọnya jupụta nʼisi ndị inyom Zayọn,
\q2 \nd Onyenwe anyị\nd* ga-emekwa ka ha gharakwa inwe agịrị isi nʼisi ha.”
\p 
\v 18 Nʼụbọchị ahụ, Onyenwe anyị ga-anapụ ha ihe ịchọ mma ha niile, ma mgbaaka, ma ịchafọ ịgbado isi, ma ihe olu nke dị nʼụdịdị ọnwa ọhụrụ,
\v 19 ma ọlantị, ma mgbaaka, ma akwa e ji ekpuchi ihu,
\v 20 ma akwa ha na-eyi nʼisi, na ọla ụkwụ, ma ihe ha na-eke nʼukwu, ma karama mmanụ isi ụtọ, ma ọgwụ dị iche iche;
\v 21 ma ọlaaka ha niile na ọla imi ha niile,
\v 22 ma uwe mmemme ha niile ma uwe mwụda niile, ma akwa akwa mgbochi, ma akpa nta niile,
\v 23 ma enyo ha niile, ma akwa ọcha niile, ma okpu ọma niile, ma mgbokwasị ha niile.
\q1 
\v 24 Nʼọnọdụ ụda ọma, ha ga-esi ure ure;
\q2 nʼọnọdụ ihe ike nʼukwu, ha ga-ekekwasị onwe ha eriri;
\q1 nʼọnọdụ agịrị isi e doziri edozi, ha agaghị enwe ọ bụladị otu agịrị isi;
\q2 nʼọnọdụ akwa ọcha, ọ bụ akwa mkpe ka ha ga-eyi;
\q2 nʼọnọdụ ịma mma, anụ ahụ ha ga-achakpọsị.
\q1 
\v 25 Ndị ikom unu ka a ga-eji mma agha gbuo,
\q2 ndị bụ dike ka a ga-egbu nʼagha.
\q1 
\v 26 Ọnụ ụzọ ama niile nke Zayọn ga-eti mkpu akwa ruokwa ụjụ.
\q2 Ọ ga-atọgbọrọ nʼefu. Ọ ga-anọdụ nʼala.
\c 4
\q1 
\v 1 Nʼoge ahụ, ndị ikom ole na ole ga-afọdụ ndụ.
\q2 Nke a ga-eme ka ndị inyom asaa na-azọ otu nwoke.
\q1 Ha ga-abịakwute ya sị ya “Kwere ka anyị niile bụrụ ndị nwunye gị!
\q2 Anyị ga-akpara onwe anyị nri,
\q1 zụọra onwe anyị akwa. Naanị kwere ka anyị na-aza aha gị,
\q2 ka a ghara ịkọ anyị ọnụ.”
\s1 Alaka \nd Onyenwe anyị\nd*
\p 
\v 2 Nʼụbọchị ahụ, \nd Onyenwe anyị\nd* ga-eme ka Alaka \nd Onyenwe anyị\nd* mabiga mma oke, ma nwekwa ebube dị ukwuu. Ndị fọdụrụ ndụ nʼIzrel ga-enweta ihe ubi ga-enye ha ọṅụ, na nke ga-ewetara ha obi nganga na mmụọ ịnya isi.
\v 3 Ndị ahapụrụ na Zayọn, ndị nọ na Jerusalem ka a ga-akpọ ndị dị nsọ, bụ ndị ahụ niile e dere aha ha nʼetiti ndị bi nʼime Jerusalem.
\v 4 Onyenwe anyị ga-asachapụ unyi niile nke ndị inyom Zayọn, ọ ga-asachapụkwa ọbara niile dị na Jerusalem site na mmụọ nke ikpe, na mmụọ nke ọkụ.
\v 5 Mgbe ahụ, \nd Onyenwe anyị\nd* ga-ewuru ugwu Zayọn niile na ndị niile zukọrọ nʼebe ahụ ndo ga-ekpuchi ha niile. Ihe ọ ga-eji mee ndo a bụ igwe ojii na anwụrụ ọkụ nke ga-adịrị ha nʼehihie, na ọkụ na-enwu enwu, nke ga-adịrị ha nʼabalị. Ebube ahụ ga-abụ ihe mkpuchi nye ha.
\v 6 Ọ ga-abụrụ ha ebe mgbaba na ndo ime ka okpomọkụ nke ehihie hapụ ịchagbu ha. Ọ ga-abụkwara ha ebe izere ndụ, na ebe nzuzo pụọ nʼoke ifufe na mmiri.
\c 5
\s1 Abụ banyere ubi vaịnị a gbara ogige
\q1 
\v 1 Aga m abụ abụ nye onye m hụrụ nʼanya,
\q2 abụ banyere ubi vaịnị ya.
\q1 Onye m hụrụ nʼanya nwere ubi ya
\q2 nʼelu ugwu nta nke bụ ezi ala.
\q1 
\v 2 O gwuzere ya, wepụsịa okwute niile dị nʼime ya,
\q2 werekwa mkpụrụ vaịnị mara mma kụọ nʼime ya.
\q1 O wuru ụlọ nche nʼetiti ya,
\q2 sitekwa na nkume wapụtakwa ebe ịzọcha mmanya.
\q1 Emesịa, ọ nọdụrụ chere oge owuwe ihe ubi.
\q2 Mgbe oge ahụ ruru, ọ chọpụtara na nʼọnọdụ mkpụrụ vaịnị mara mma, ọ bụ ndị jọrọ njọ mịrị.
\b
\q1 
\v 3 “Ugbu a, ndị ikom Jerusalem na Juda, unu anụla ihe mere.
\q2 Kpebienụ ikpe a dị nʼetiti mụ na ubi vaịnị m.
\q1 
\v 4 Olee ihe ọzọ m gaara emere ya
\q2 karịa ihe m mere?
\q1 Gịnị mere ubi vaịnị m ji mịara m mkpụrụ jọrọ njọ
\q2 nʼọnọdụ mkpụrụ na-atọ ụtọ?
\q1 
\v 5 Ugbu a, lee,
\q2 ihe m na-aga ime ubi vaịnị m a.
\q1 Aga m ewepụ ihe mgbochi a gbara ya,
\q2 hapụ ya ka ọ ghọọ ebe anụ ụlọ na-ata nri.
\q1 Aga m etida mgbidi ya
\q2 hapụ ya ka ọ bụrụ ebe a na-azọtọ ụkwụ.
\q1 
\v 6 Agaghị m akwachakwa ya ọzọ.
\q2 Agakwaghị m egwuru ya ala,
\q2 aga m ahapụ ya ka ogwu na uke too nʼime ya.
\q1 Aga m enyekwa igwe ojii iwu
\q2 ka mmiri ghara izokwasị ya ọzọ.”
\b
\q1 
\v 7 Ubi vaịnị nke \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile,
\q2 bụ mba Izrel
\q1 na ndị Juda,
\q2 ha bụ vaịnị ahụ nke nʼatọ obi ya ụtọ.
\q1 Ma o lere anya ikpe ziri ezi, ma ihe ọ hụrụ bụ iwusi ọbara.
\q2 O lere anya ezi omume, ma ihe ọ nụrụ bụ mkpu akwa ndị a na-emegbu emegbu.
\s1 Ahụhụ na ikpe ọmụma
\q1 
\v 8 Ahụhụ dịrị unu ndị na-azụkọta ala
\q2 ma ndị ọzọ ahụghị ebe ha ga-ebi,
\q1 unu ndị na-ewu ụlọ na-ewukwasị ụlọ nʼala buru ibu,
\q2 ime ka ọ bụrụ naanị unu bi nʼụwa.
\p 
\v 9 Ma \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile ekwuola ihe banyere unu, na ọnọdụ unu. Eji m ntị m abụọ nụ mgbe ọ na-asị,
\q1 “Nʼezie, ọtụtụ ụlọ mara mma ga-atọgbọrọ nʼefu,
\q2 ụlọ ukwu mara mma ndị nwe ha agaghị anọkwa.
\q1 
\v 10 Ubi vaịnị ahụ a ga-eji ehi abụọ kọọ ụbọchị iri ga-ewepụta naanị ihe nwere ike iru galọọnụ mmanya isii,
\q2 ma ọka a kọrọ, nke ruru akpa ọka atọ ga-amịpụta ihe ruru otu akpa nʼọkara.”
\b
\q1 
\v 11 Ahụhụ ga-adịrị unu niile ndị na-ebili nʼisi ụtụtụ
\q2 ịgbaso mmanya.
\q1 Ndị na-amụgide anya abalị
\q2 tutu ruo mgbe ha ṅụbigara mmanya oke.
\q1 
\v 12 Unu na-eji ụbọ akwara dị iche iche na une,
\q2 na ihe iti egwu na opi, na mmanya na-eme onwe unu obi ụtọ nʼoge mmemme oriri unu,
\q1 ma unu na-elelị \nd Onyenwe anyị\nd* anya;
\q2 unu adịghịkwa asọpụrụ akaọrụ ya.
\q1 
\v 13 Nʼihi ya, ndị m ga-eje biri na mba ọzọ,
\q2 nʼihi amaghị ihe;
\q1 ndị ọkwa ha dị elu ga-anwụ nʼihi agụụ,
\q2 ndị mmadụ efu ga-abụ ndị akpịrị ga-akpọ nkụ nʼihi agụụ mmiri.
\q1 
\v 14 Nʼihi ya, ala mmụọ na-eme ka ọchịchọ ya saa mbara,
\q2 ọ na-asaghebigakwa ọnụ ya oke;
\q1 ndị ukwu na ndị nta bi nʼime ala a ka ọ ga-elo,
\q2 tinyere ndị na-emebiga mkpọtụ oke, na ndị na-egwuribiga egwu ọṅụ oke.
\q1 
\v 15 Nʼụbọchị ahụ, a ga-eweda nʼala ndị dị elu,
\q2 na ndị dị ala,
\q2 ndị mpako ka a ga-eweda nʼala.
\q1 
\v 16 Ma \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, nwee ọnọdụ dịkarịsịrị elu, nʼihi ikpe ikpe ziri ezi ya,
\q2 Chineke onye dị nsọ na-egosikwa onwe ya na ọ dị nsọ site nʼezi omume ya.
\q1 
\v 17 Mgbe ahụ, ụmụ atụrụ ga-akpa nri ha dị ka ọ bụ nʼọzara ka ha nọ,
\q2 ehi na anụ ụlọ ga-akpa nri ha nʼụlọ ndị ọgaranya niile e tikpọrọ etikpọ.
\b
\q1 
\v 18 Ahụhụ ga-adịrị ndị ji aghụghọ na-adọkpụgharị mmehie ha;
\q2 ahụhụ dịkwara ndị na-adọkpụgharị ajọ omume ha dịka ụdọ eji adọkpụgharị ụgbọala.
\q1 
\v 19 Nye ndị ahụ na-asị “Ka Chineke mee ngwa;
\q2 ya rụọ ọrụ ya ọsịịsọ,
\q2 ka anyị hụ ya.
\q1 Atụmatụ nke Onye nsọ nke Izrel,
\q2 ka ọ bịaruo nso, ka ọ pụta ìhè,
\q2 ka anyị nwe ike mara ihe o zubere.\f + \fr 5:19 \ft \xt Jer 17:15\xt*\f*”
\b
\q1 
\v 20 Ahụhụ dịrị ndị na-akpọ ihe ọjọọ ezi ihe
\q2 ndị na-akpọkwa ezi ihe ihe ọjọọ,
\q1 ndị na-etinye ọchịchịrị nʼọnọdụ ìhè
\q2 na ìhè nʼọnọdụ ọchịchịrị
\q1 ndị na-etinye ihe dị ilu nʼọnọdụ ihe ụtọ,
\q2 na ihe ụtọ nʼọnọdụ ihe ilu.
\b
\q1 
\v 21 Ahụhụ ga-adịrị ndị maara ihe nʼanya nke onwe ha,
\q2 ndị na-elekwa onwe ha anya na ha bụ ndị nwere nghọta.
\b
\q1 
\v 22 Ahụhụ ga-adịrị ndị bụ dike nʼịṅụ mmanya,
\q2 na ndị bụkwa dimkpa nʼịgwakọta mmanya,
\q1 
\v 23 ndị na-asị onye ikpe maara nʼikpe amaghị ya nʼihi ịnata ngarị,\f + \fr 5:23 \ft \xt Ọpụ 23:8; Ilu 17:15\xt*\f*
\q2 ma wezuga ikpe ziri ezi site nʼebe onye aka ya dị ọcha nọ.\f + \fr 5:23 \ft \xt Abụ 94:21\xt*\f*
\q1 
\v 24 Nʼihi ya, dịka ire ọkụ si erechapụ ahịhịa ọka,
\q2 na dịka ahịhịa kpọrọ nkụ si ada nʼime ọkụ na-enwu enwu,
\q1 otu a ka mgbọrọgwụ ha ga-ere ure
\q2 okoko ha ka ikuku ga-ebufu dịka uzuzu;
\q1 nʼihi na ha ajụla iwu niile \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile nyere,
\q2 lelịakwa okwu nke Onye nsọ Izrel.
\q1 
\v 25 Nʼihi nke a, iwe \nd Onyenwe anyị\nd* dị ọkụ megide ndị ya;
\q2 o setịpụrụ aka ya na-etitu ha nʼala.
\q1 Ugwu niile ga-ama jijiji,
\q2 ozu ndị ahụ dịka ihe na-abaghị uru nʼokporoụzọ niile.
\b
\q1 Ma nʼagbanyeghị ihe ndị a niile, iwe ya alaghachibeghị azụ,
\q2 aka ya ka setịpụkwara esetipụ.
\b
\q1 
\v 26 Ọ ga-eweli ọkọlọtọ nye mba niile dị nʼebe dị anya,
\q2 ọ na-akpọkọta ndị niile nọ na nsọtụ ụwa.
\q1 Ma lee, ka ha na-abịa,
\q2 ha na-eme ngwa bịa ọsịịsọ.\f + \fr 5:26 \ft Ndị bịara buo agha a bụ ndị agha mba Asịrịa.\f*
\q1 
\v 27 Ọ dịghị onye na-ada mba, ọ dịkwaghị onye nʼasụ ngọngọ nʼime ha,
\q2 ọ dịghị onye nʼatụ oru ụra maọbụ rahụ ụra,
\q1 ọ dịghị ihe ike nʼukwu ha nke tọpụrụ atọpụ
\q2 ọ dịghị ihe ikechi akpụkpọụkwụ nke dọbiri adọbi.\f + \fr 5:27 \ft \xt Jul 2:8\xt*\f*
\q1 
\v 28 Àkụ ha niile dị nkọ,
\q2 ekweela ụta ha niile,
\q1 ụkwụ ịnyịnya dị ka nkume ọkụ,
\q2 ụkwụ ụgbọ agha ha dị ka oke ifufe.
\q1 
\v 29 Ha na-ebigbọ dịka ọdụm,
\q2 ha na-ebigbọkwa dịka ụmụ ọdụm;
\q1 ha na-asụ mgbe ha wụkwasịrị nʼelu ihe ndọgbu.
\q2 Ha na-ejide ndị m, kpụrụ ha laa, ọ dịkwaghị onye nnapụta ha nwere.
\q1 
\v 30 Nʼụbọchị ahụ, ha ga-ebigbọ nʼelu ya
\q2 dịka mbigbọ nke oke osimiri.
\q1 A sịkwa na mmadụ elegide ala ahụ anya,
\q2 ọ ga-ahụ na ọchịchịrị na ihe mgbu,
\q2 ọ bụladị anyanwụ ka igwe ojii ga-eme ka ọ gbaa ọchịchịrị.
\c 6
\s1 Ọkpụkpọ Aịzaya
\p 
\v 1 Nʼafọ ahụ, mgbe eze bụ Ụzaya nwụrụ, ahụrụ m Onyenwe anyị ka ọ nọ nʼocheeze ya dị oke elu. Ọnụ ọnụ ala uwe ya jupụtara ụlọnsọ ukwuu ya.
\v 2 Ndị na-erugharị nʼelu ocheeze ya bụ ndị mmụọ ozi a na-akpọ seraf, ndị nwere nku isii. Ha ji nku ha abụọ kpuchie ihu ha; abụọ ka ha ji kpuchie ụkwụ ha, abụọ nke fọdụrụ ka ha ji na-efegharị.
\v 3 Ha na-abụrịtara onwe ha abụ, sị,
\q1 “Nsọ, Nsọ, Nsọ, ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile dị.
\q2 Ụwa niile jupụtara nʼebube ya.”
\m 
\v 4 Nʼihi ụda olu ha, ọnụ ụzọ na mgbidi ụlọnsọ mara jijiji, ụlọ ahụ jupụtara nʼanwụrụ ọkụ.
\p 
\v 5 Etiri m mkpu akwa sị. “Ewoo! Onye nwụrụ anwụ ka m bụ, nʼihi na onye mmehie ka m bụ, egbugbere ọnụ m bụ egbugbere ọnụ rụrụ arụ; ọ bụkwa nʼetiti ndị egbugbere ọnụ ha rụrụ arụ ka m bi. Ugbu a, ejirila m anya m hụ \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, onye bụ Eze ukwu ahụ!”
\p 
\v 6 Mgbe ahụ, otu nʼime seraf ndị ahụ sitere nʼebe ọ nọ fekwute m, were mkpa gụta otu icheku dị ọkụ site nʼebe ịchụ aja.\f + \fr 6:6 \ft Ebe ịchụ aja a, nke dị nʼetiti ebe nsọ ahụ, ka a na-achụ aja ụda ndị ahụ na-esi isi ụtọ \xt Mkp 8:3\xt*\f*
\v 7 O weere icheku ọkụ ahụ sọtụ m nʼọnụ, sị m, “Ugbu a, a gụọla gị dịka onye dị ọcha, nʼihi na icheku a emetụla gị nʼọnụ. A gbagharakwala gị mmehie gị niile.”
\p 
\v 8 Mgbe ahụ, anụrụ m olu Onyenwe anyị ka ọ na-ajụ, “Onye ka m ga-eziga? Onye ga-ejekwara anyị?”
\p Asịrị m, “Lee m, ziga m.”
\p 
\v 9 Ọ siri, “Gaa gwa ndị a sị,
\q1 “ ‘Na-anụnụ, ma unu aghọtala,
\q2 na-elenụ anya ma unu ahụla.\f + \fr 6:9 \ft \xt Mat 13:14; Mak 4:12; Luk 8:10\xt*\f*’
\q1 
\v 10 Mee ka obi ndị a maa abụba, dịkwa arọ,\f + \fr 6:10 \ft \xt Abụ 119:70; Ọrụ 7:51\xt*\f*
\q2 mee ka ntị ha kpọchie,
\q2 mechiekwa anya ha.
\q1 Ma ọ bụghị otu a, ha nwere ike iji anya ha hụ ụzọ,
\q2 jiri ntị ha nụ ihe,
\q2 jirikwa obi ha ghọta,
\q1 ma chigharịa bụrụ ndị a gwọrọ.”
\p 
\v 11 Ma ekwuru m sị, “Onyenwe m, ọ bụ ruo ole mgbe?”
\p Ọ zara,
\q1 “Ọ bụ ruo mgbe obodo ha tọgbọrọ nʼefu,
\q2 mgbe ọ na-adịghị onye ga-afọdụ nʼime ya;
\q1 mgbe ụlọ obibi ha niile ga-atọgbọrọ nʼefu,
\q2 mgbe e bibisịrị ala ubi ha niile.
\q1 
\v 12 Ọ bụ ruo mgbe \nd Onyenwe anyị\nd* zigara onye ọbụla gaa ebe dị anya,
\q2 ala niile atọgbọkwara nʼefu.
\q1 
\v 13 Ma ọ bụrụkwa na otu ụzọ nʼime ụzọ iri nʼime ha niile afọdụ nʼala a,
\q2 a ga-eme ka ọ laa nʼiyi.
\q1 Ma dịka osisi terebint na osisi ook
\q2 na-ahapụ ogwe mgbe e gbujiri ha,
\q2 ya mere mkpụrụ nsọ ahụ ga-abụ ogwe osisi nʼala ahụ.”
\c 7
\s1 Ihe ama Ịmanụel
\p 
\v 1 Mgbe Ehaz,\f + \fr 7:1 \ft Nʼime senchuri nke asaa, tupu a mụọ Kraịst, ndị Izrel na Siria jikọrọ aka buso ndị Asịrịa agha. Nʼoge ahụ ha gbalịrị ịkwagide Ehaz, eze Juda, ka o soro ha ga buo agha ahụ.\f* nwa Jotam, nwa nwa Ụzaya bụ eze na Juda, Rezin eze Aram, na Peka eze Izrel, nwa Remalaya, busoro Jerusalem agha. Ma ha emerighị ya; obodo ahụ guzosiri ike.
\p 
\v 2 Ma mgbe e mesịrị, ozi ruru ụlọ Devid ntị sị, “Ndị Aram na Ifrem ejikọọla onwe ha ọnụ”; nke a mere ka ụlọeze, na obi ndị ọ na-achị maa jijiji, dịka osisi dị nʼọhịa si ama jijiji mgbe oke ifufe na-efe.
\p 
\v 3 Mgbe ahụ, \nd Onyenwe anyị\nd* gwara Aịzaya okwu sị ya, “Jekwuru Ehaz bụ eze. Mgbe ị na-aga, kpọrọ Shịa-Jashub nwa gị nwoke. Unu ga-ahụ Ehaz nʼakụkụ Elu elu olulu ọdọ mmiri nke dị nʼụzọ ahụ gawara nʼAla ọsụ akwa.
\v 4 Gwa ya ka ọ ghara inye ndụ ya nsogbu, ka ọ gharakwa ịtụ egwu. Sị ya, ‘Lezie anya, nọ jụụ, echegbula onwe ya banyere icheku ọkụ abụọ ahụ na-anyụ anyụ. Atụla egwu nʼihi iwe Rezin nwa Aram, na iwe Peka nwa Remalaya.
\v 5 E, Aram, na Ifrem, na nwa nwoke Remalaya, agbaala izu ibuso gị agha ịla gị nʼiyi. Ha ekwuola sị,
\v 6 “Ka anyị wakpo Juda, ka anyị dọwaa ya ma kee ya nʼetiti onwe anyị, mee nwa Tabeel ka ọ bụrụ eze ya.”
\v 7 Ma otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru,
\q1 “ ‘Ọ gaghị adị ire!
\q2 Ọ gaghị emezukwa.
\q1 
\v 8 Nʼihi isi obodo Aram bụ Damaskọs.\f + \fr 7:8 \ft \xt 2Sa 8:6\xt*\f*
\q2 Onyeisi Damaskọs bụ naanị Rezin.
\q1 Ma tupu afọ iri isii na ise agafee
\q2 a ga-etikpọkwa Ifrem.
\q1 
\v 9 Isi obodo Ifrem bụ Sameria.
\q2 Onyeisi Sameria bụ naanị nwa Remalaya.
\q1 Ọ bụrụ na unu eguzosighị ike nʼokwukwe unu,
\q2 unu agaghị eguzo ma ọlị.’ ”
\p 
\v 10 Ọ dịghị anya, \nd Onyenwe anyị\nd* ziri Ehaz ozi ndị a sị,
\v 11 “Jụọ m bụ \nd Onyenwe anyị\nd* Chineke gị, ka m meere gị ihe ịrịbama nke ga-egosi gị na m ga-ebibi ndị iro gị niile dịka m kwuru. Rịọọ m ihe masịrị gị, nʼebe dị elu nʼeluigwe maọbụ nʼebe kachasị omimi nʼụwa.”
\p 
\v 12 Ma Ehaz zara sị, “Mba, agaghị arịọ, agaghị m anwakwa \nd Onyenwe anyị\nd* m otu a.”
\p 
\v 13 Ma Aịzaya sịrị, “Ṅaanụ ntị unu ụlọ Devid. Ọ bụ na o zurughị unu ime ka ike gwụ mmadụ? Unu ga-emekwa ka ike gwụ Chineke nʼonwe ya?
\v 14 Ya mere, Onyenwe anyị nʼonwe ya ga-enye gị ihe ịrịbama! Lee, nwaagbọghọ ahụ na-amaghị nwoke ga-atụrụ ime, mụọ nwa nwoke. Ọ ga-akpọ aha ya Ịmanụel, nke pụtara, Chineke nọnyeere anyị.
\v 15 Mmiri ara ehi rahụrụ arahụ na mmanụ aṅụ ka nwantakịrị ahụ ga-eri mgbe ọ matara ịjụ ihe ọjọọ na ịhọrọ ezi ihe.
\v 16 Tupu a zụlite nwantakịrị ahụ ịmata ịhọrọ ezi ihe na ịjụ ajọ ihe, ndị eze abụọ ndị ị na-atụ egwu ha, ga-anwụcha.
\v 17 \nd Onyenwe anyị\nd* ga-eme ka ọbụbụ ọnụ dị ukwuu bịakwasị gị na obodo gị, na ezinaụlọ gị. Ihe egwu ga-adịkwa, ụdị nke a na-ahụbeghị mbụ, site nʼoge e kewapụrụ Ifrem site na Juda. Eze Asịrịa ga-edu ndị agha ya bịa.\f + \fr 7:17 \ft \xt 2Ih 28:19-20\xt*\f*”
\s1 Asịrịa, ngwa ọrụ \nd Onyenwe anyị\nd*
\p 
\v 18 Nʼụbọchị ahụ, \nd Onyenwe anyị\nd* ga-akpọku ijiji site na nsọtụ Naịl dị nʼIjipt nakwa aṅụ sitere nʼala Asịrịa.
\v 19 Ha ga-abịa nʼigwe, bichie ndagwurugwu ala gị niile, na nʼọgba nkume niile, na nʼọhịa ogwu ogwu niile, na nʼọzara niile, na nʼezi ala niile.
\v 20 Nʼụbọchị ahụ, Onyenwe anyị ga-eji agụba e gotara nʼofe osimiri, nke bụ eze Asịrịa, kpụchapụ unu agịrị isi na ajị ụkwụ, kpụchapụkwa afụọnụ unu niile.
\v 21 Nʼụbọchị ahụ, otu onye ga-edebe otu nwa ehi na ewu abụọ ndụ.
\v 22 Onye ọbụla kwa nʼala ahụ ga-eri mmiri ara ehi rahụrụ arahụ, ya na mmanụ aṅụ, nʼihi na mmiri ara ehi ga-aba ụba nke ukwuu nʼala ahụ.
\v 23 Nʼụbọchị ahụ, ala ọbụla nke nwere otu puku osisi vaịnị nke ọnụahịa ya ruru otu puku shekel ọlaọcha ga-abụ naanị ogwu na uke.
\v 24 Ndị dinta ga-achịrị àkụ na ùta gaa nʼebe ahụ, nʼihi na uke na ogwu ga-ekpuchi ala ahụ.
\v 25 Ma banyere ugwu eji ọgụ kọọ na mbụ, ị gaghị abakwa nʼebe ahụ ọzọ nʼihi egwu uke na ogwu; ha ga-abụ ebe a na-atọpụ ehi na ebe atụrụ na-agbagharị.
\c 8
\s1 Aịzaya na ụmụ ya dịka ihe ịrịbama
\p 
\v 1 \nd Onyenwe anyị\nd* siri m, “Were otu mbadamba ihe dị ukwuu, were odee nke onye ọbụla na-eji ede ihe dekwasị ya Maha-shalal-Hash-Baz.
\v 2 Aga m akpọbata Ụraya onye nchụaja na Zekaraya nwa Jeberekaya dịka ndị akaebe kwesiri ntụkwasị obi.”
\v 3 Emesịa, mụ na nwunye m, bụ onye amụma dinakọrọ, ọ tụụrụ ime, mụọrọ m nwa nwoke. Ma \nd Onyenwe anyị\nd* sịrị m, “Gụọ ya Maha-shalal-Hash-Baz.
\v 4 Nʼihi na tupu nwantakịrị ahụ etolite ịkpọ nne maọbụ nna, eze ndị Asịrịa ga-ebuso Damaskọs na Sameria agha, bukọrọkwa akụ ha niile.”
\p 
\v 5 \nd Onyenwe anyị\nd* gwakwara m okwu ọzọ sị,
\q1 
\v 6 “Nʼihi na ndị a ajụla
\q2 mmiri Shiloa\f + \fr 8:6 \ft Mmiri a, si nʼisi iyi Gaihọn na-asọbata nʼime Jerusalem, inye ndị bi nʼime obodo mmiri ọṅụṅụ \xt 2Ih 32:4,30\xt*\f* nke ji nwayọọ na-asọ
\q1 ma na-aṅụrị ọṅụ nʼihi Rezin
\q2 na nwa nwoke Remalaya,
\q1 
\v 7 ya mere, Onyenwe anyị na-aga iweta
\q2 iju mmiri nke osimiri Yufretis megide ha,
\q2 bụ eze ndị Asịrịa ya na ebube ya niile.
\q1 Ọ ga-erubiga oke, gafee ụzọ ya niile,
\q2 ọ ga-erubiga ma tofeekwa ọnụ ya niile,
\q1 
\v 8 wụsịakwa nʼala Juda niile. Ọ ga-erikpu ala Juda niile,
\q2 ọ ga-agabiga, kpuchiekwa ọ bụladị nʼolu ka ọ ga-eru.
\q1 Nku ya ga-agbasa kpuchie obosara niile nke ala gị,
\q2 O Ịmanụel.”
\b
\q1 
\v 9 Tienụ mkpu agha unu mba dị iche iche, ma a ga-etipịa unu.
\q2 Geenụ ntị unu mba niile dị ebe dị anya.
\q1 Kwadoonụ maka agha ma a ga-etipịa unu.
\q2 Kwadoonụ maka agha ka e tipịa unu.
\q1 
\v 10 Tụọnụ atụmatụ unu ma a ga-ekposa ya.
\q2 Wepụtanụ atụmatụ unu ma ọ gaghị eguzo
\q2 nʼihi na Chineke nọnyere anyị.\f + \fr 8:10 \ft \xt Rom 8:31\xt*\f*
\s1 Tụọ egwu Onyenwe anyị
\p 
\v 11 Otu a ka \nd Onyenwe anyị\nd* sịrị m nʼike nke aka ya dị nʼahụ, ọ dọrọ m aka na ntị ka m ghara ije ije nʼụzọ ndị nke a, na-asị:
\q1 
\v 12 “Adịnyerela ha
\q2 nʼihe niile ha na-ezube ime na nzuzo megide ọchịchị;
\q1 ka ihe ha na-atụ egwu
\q2 hapụ ịbụ ihe ga-eme ka ị tụọ egwu.\f + \fr 8:12 \ft Mgbe ndị Juda nụrụ ihe banyere njikọta aka dị nʼetiti ndị Izrel na Siria, nʼihi ibuso ha agha, oke egwu tụrụ ha.\f*
\q1 
\v 13 \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, ya ka unu ga-edo nsọ.
\q2 Ya bụ onye unu kwesiri ịtụ ụjọ.
\q2 Ya bụ onye unu ga-atụ egwu ma jijiji.
\q1 
\v 14 Ọ ga-abụkwa ebe nsọ;\f + \fr 8:14 \ft Maọbụ, \fqa Ebe mgbaba\f*
\q2 nye ụlọ Izrel na Juda, ọ ga-aghọrọ ha
\q1 nkume nke na-eme ka ndị mmadụ sọọ ngọngọ,
\q2 oke nkume nke na-eme ka ha daa.
\q1 Ọ ga-abụkwara ndị Jerusalem
\q2 igbudu na ọnya nke ha ga-adaba nʼime ya.
\q1 
\v 15 Ọtụtụ nʼime ha ga-asọ ngọngọ;
\q2 ha ga-ada bụrụ ndị e tipịara.
\q2 Ha ga-abụ ndị ọnya ga-ama, na ndị a ga-anwude.”
\b
\q1 
\v 16 Kechie ihe ịgba ama nke iwu a
\q2 kpuchie ntụziaka Chineke nke ọma nʼetiti ndị na-eso ụzọ ya.
\q1 
\v 17 Aga m echere \nd Onyenwe anyị\nd*,
\q2 onye na-ezonarị ụlọ Jekọb ihu ya ugbu a.
\q1 Aga m atụkwasị obi m na ya.
\p 
\v 18 Lee mụ onwe m, na ụmụ ndị \nd Onyenwe anyị\nd* nyere m. Anyị bụ ihe ịrịbama na ihe iji cheta ihe nye ndị Izrel site na \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, onye na-ebi nʼugwu Zayọn.
\s1 Ọchịchịrị ghọrọ ìhè
\p 
\v 19 Mgbe onye ọbụla sịrị unu, jụtanụ ndị na-ajụ mmụọ ọjọọ ase na ndị dibịa afa ihe, bụ ndị na-ekwu okwu nʼolu dị nta nke mmadụ na-adịghị anụ nke ọma na ndị na-atamu atamu, ndị mmadụ ọ gaghị ajụ Chineke ha ase? Ọ bụ nʼihi gịnị ka eji jụta ndị nwụrụ anwụ ase nʼihi ndị dị ndụ?
\v 20 Lezienụ okwu ntụziaka na nke ịdọ aka na ntị Chineke anya. Ọ bụrụ na ozi ha dị iche na nke a, o gosiri na ha enweghị ìhè maọbụ eziokwu ọbụla nʼime ha.
\v 21 Ndị a ga-awagharị nʼala a niile. Agụụ ga-agụ ha, ha ga-adakwa mba. Nʼọnọdụ oke agụụ nke ga-agụ ha, iwe dị ukwuu ga-ewe ha, mee ka ha lelie anya ha nʼelu, kọchaa eze ha, na Chineke ha.
\v 22 Mgbe ahụ, ọ bụrụ na ha eledata anya ha nʼala ọ bụ naanị oke nsogbu na oke ihe mgbu ka ha ga-ahụ. Ha ga-ahụkwa oke ihe egwu na ọchịchịrị. Ụzọ mgbapụ agaghị adịkwara ha nʼoge nsogbu a. A ga-achụbanye ha nʼime ọchịchịrị.
\c 9
\s1 A mụụrụ anyị otu nwa
\p 
\v 1 Ma otu ọbụla o siri dị, oge ahụhụ na ọchịchịrị na iru ụjụ ahụ agaghị adịgide nye ndị ahụ nọ na nkpa. Nʼihi na nʼoge gara aga, o mere ka e lelịa ala Zebụlọn na ala Naftalị anya, ma nʼoge dị nʼihu, ọ ga-eme ka a asọpụrụ Galili nke mba niile, nke dị nʼakụkụ osimiri, nʼofe Jọdan.
\q1 
\v 2 Ndị nọ na-agagharị nʼọchịchịrị
\q2 ahụla ìhè dị ukwuu;
\q1 ndị ahụ bi nʼala nke onyinyo ọnwụ
\q2 ka ìhè nwukwasịrị.
\q1 
\v 3 I meela ka mba ahụ baa ụba dịrị ukwuu,
\q2 mee ka ọṅụ ha dịkwa ukwuu,
\q1 ha na-enwe ọṅụ nʼihu gị,
\q2 dịka ọṅụ nke ndị ọrụ ubi nʼoge owuwe ihe ubi,
\q1 dịka ndị agha na-etegharị egwu ọṅụ
\q2 mgbe ha na-ekesa ihe a kwatara nʼagha.\f + \fr 9:3 \ft Nke a bụ banyere mmeri Gidiọn meriri ndị Midia \xt Nkp 7; 8:1-21\xt*\f*
\q1 
\v 4 Nʼihi na dịka nʼụbọchị nke Midia,
\q2 i gbajisiela
\q1 ibu arọ niile e bokwasịrị ha,
\q2 ihe mgbochi nke dị nʼubu ha,
\q2 nke bụ mkpara ndị na-akpagbu ha.
\q1 
\v 5 Nʼihi na akpụkpọụkwụ nke ndị agha na-eyi,
\q2 na uwe agha nke ọbara mechuru,
\q1 ha ga-abụ ihe a ga-agba ọkụ,
\q2 ha ga-abụ ihe ndị ga-eme ka ọkụ ree nke ọma.
\q1 
\v 6 Nʼihi na amụọrala anyị otu nwa,
\q2 e nyekwala anyị otu nwa nwoke.
\q2 Ọ ga-abụkwa onye ga-achị anyị.
\q1 Ndị a ga-abụ aha ya,
\q2 Onye Ndụmọdụ dị Ebube, Chineke bụ dike,
\q2 Nna nke mgbe ebighị ebi, Eze Udo.
\q1 
\v 7 Alaeze\f + \fr 9:7 \ft Mgbe a kpọrọ Jekọb, maọbụ Izrel, maọbụ Ifrem na Sameria, ha niile dịnyere otu alaeze. Alaeze dị nʼakụkụ ugwu obodo ahụ nke isi obodo ya bụ Sameria.\f* ya ga-aba ụba, ọchịchị eze ya ga-abụ nʼọnọdụ udo
\q2 nke na-enweghị ọgwụgwụ.
\q1 Ọ bụ nʼocheeze Devid ka ọ ga-anọkwasị,
\q2 chịakwa nʼalaeze ya.
\q1 Ọ ga-eme ka alaeze ahụ guzosie ike;
\q2 ọ bụkwa ikpe ziri ezi na ezi omume ka ọ ga-eji chịa
\q2 site nʼoge ahụ ruo mgbe ebighị ebi.
\q1 Ịnụ ọkụ nke \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile,
\q2 ga-emezukwa nke a.
\s1 Iwe \nd Onyenwe anyị\nd* megide Izrel
\q1 
\v 8 Onyenwe anyị eziela ozi megide Jekọb
\q2 ọ ga-adakwasịkwa Izrel.
\q1 
\v 9 Ndị ahụ niile ga-amatakwa ya,
\q2 Ifrem na ndị bi na Sameria ga-amatakwa
\q1 bụ ndị na-eji nganga
\q2 na mpako na-ekwu sị,
\q1 
\v 10 “Nkume brik ndị ahụ adakpọsịala
\q2 ma anyị ga-eji nkume a waziri awazi wughachi ha;
\q1 ọ bụ ezie na e gbutusịala osisi sikamọ niile anyị ji wuo ụlọ anyị,
\q2 ma anyị ga-eji osisi ọma sida dochie ha.”
\q1 
\v 11 Ma \nd Onyenwe anyị\nd* a kpaliela ndị iro Rezin\f + \fr 9:11 \ft Ndị iro Rezin bụ ndị Siria, Filistia, Tiglat-Pilesa na ndị agha ya so buso Izrel agha.\f* ka ha bilie megide ha,
\q2 ọ kwaliekwala ndị iro ha.
\q1 
\v 12 Ndị Aram sitere nʼọwụwa anyanwụ, na ndị Filistia sitere nʼọdịda anyanwụ
\q2 ha e werela ọnụ ghere oghe richapụ Izrel.
\b
\q1 Ma nʼagbanyeghị ihe ndị a niile, iwe ya alaghachibeghị azụ,
\q2 aka ya ka setịpụkwara esetipụ.
\b
\q1 
\v 13 Ma ọ bụ ezie na \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile ataala ha ahụhụ dị otu a,
\q2 ndị Izrel echegharibeghị, ha alọghachikwutebeghị ya.
\q1 
\v 14 Nʼihi ya, nʼotu ụbọchị, \nd Onyenwe anyị\nd* ga-ebibi ndịisi Izrel na ndị ọdụdụ,
\q2 ọ ga-ebibikwa alaka nkwụ na osisi achara niile.
\q1 
\v 15 Ndị okenye na ndị a maara aha ha bụ ndịisi ha,
\q2 ndị amụma ụgha bụ ọdụdụ ha.
\q1 
\v 16 Nʼihi na ndị ndu nke ndị ya eduhiela ha;
\q2 ndị na-ezi ha ụzọ emeela ka ha kpafuo.
\q1 
\v 17 Ya mere, Onyenwe anyị agaghị enwe mmasị nʼụmụ okorobịa ahụ,
\q2 ọ gaghị enwekwa obi ebere nʼebe ụmụ ndị na-enweghị nna maọbụ nʼebe ụmụ nwanyị na-enweghị dị nọ,
\q1 nʼihi na onye ọbụla nʼime ha adịghị asọpụrụ Chineke, bụrụkwa ndị ajọ omume,
\q2 ọnụ onye ọbụla na-ekwu ihe nzuzu.
\b
\q1 Ma nʼagbanyeghị ihe ndị a niile, iwe ya alaghachibeghị azụ,
\q2 aka ya ka setịpụkwara esetipụ.
\b
\q1 
\v 18 Nʼezie, ajọ omume na-ere dị ka ọkụ:
\q2 ọ na-erepịa ogwu na uke,
\q1 ọ na-emekwa ka oke ọhịa nwuru ọkụ,
\q2 mee ka anwụrụ ọkụ si na ya rigoruo na mbara eluigwe.
\q1 
\v 19 Nʼihi iwe ahụ \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile na-ewe,
\q2 ahụhụ ọ ga-enye ga-adị ka ọkụ na-ere ere;
\q1 ọ na-erepịa ala ahụ niile na ndị bi nʼime ya;
\q2 ọ dịkwaghị onye ga-azọpụta ibe ya.
\q1 
\v 20 Nʼala ahụ niile, ma nʼaka nri ma nʼaka ekpe,
\q2 onye ọbụla ga-agbalị ịdọtara onwe ya ihe oriri.
\q1 Ha ga-eri
\q2 ma afọ agaghị eju ha;
\q1 nʼezie, ha ga-eri ọ bụladị anụ ahụ ụmụ nke aka ha.
\q2 
\v 21 Ndị Manase ga-alụso ndị Ifrem ọgụ, ndị Ifrem ga-alụsokwa ndị Manase ọgụ.
\q2 Ha abụọ kwa ga-ejikọta aka lụso Juda ọgụ.
\b
\q1 Ma nʼagbanyeghị ihe ndị a niile, iwe ya alaghachibeghị azụ.
\q2 Aka ya ka setịpụkwara esetipụ.
\b
\b
\c 10
\q1 
\v 1 Ahụhụ na-adịrị ndị niile na-atụpụta iwu na-ezighị ezi;
\q2 ndị niile na-atụpụta iwu mmegbu,
\q1 
\v 2 iji napụ ndị ogbenye ihe ruru ha
\q2 nakwa ịnapụ ndị m a na-emegbu emegbu ikpe ziri ezi,
\q1 na-emekwa ka ụmụ nwanyị di ha nwụrụ bụrụ anụ oriri ha
\q2 na izunara ụmụ na-enweghị nne na nna ihe ha nwere.
\q1 
\v 3 Gịnị ka unu ga-eme nʼụbọchị m ga-abịa ileta unu?
\q2 Gịnị ka unu ga-eme nʼụbọchị m ga-eweta ịla nʼiyi, nke ga-esi nʼebe dị anya bịara unu?
\q1 Onye ka unu ga-agbakwuru maka enyemaka?
\q2 Ọ bụ ebe ka unu ga-ahapụ akụ unu niile?
\q1 
\v 4 Mba, ọ dịghị ihe ga-afọdụ; karịa na a ga-egbu unu nʼihu ọgụ,
\q2 maọbụ dọkpụrụ unu dịka ndị mkpọrọ.
\b
\q1 Ma nʼagbanyeghị ihe ndị a niile, iwe ya alaghachibeghị azụ,
\q2 aka ya ka setịpụkwara esetipụ.
\s1 Ikpe ọmụma Chineke nke dịrị Asịrịa
\q1 
\v 5 “Ahụhụ ga-adịrị Asịrịa onye bụ mkpara nke iwe m.
\q2 Nʼaka ya ka mkpọ nke ọnụma\f + \fr 10:5 \ft Maọbụ, \fqa oke iwe\f* m dị.
\q1 
\v 6 Ana m ezipu ya imegide mba a na-amaghị Chineke,
\q2 m na-eziga ya imegide ndị na-akpasu m iwe,
\q1 ka ha kwakọrọ ihe nkwata nʼagha ha, pụnakwara ha ụfọdụ nʼike,
\q2 nakwa ịzọtọ ndị ha niile nʼala dịka apịtị nke okporoụzọ.
\q1 
\v 7 Ma ọ bụghị ihe a ka o zubere,
\q2 nke a abụghị ihe ọ na-eche nʼobi ya;
\q1 o zubere ịla ndị m nʼiyi,
\q2 na ibibi ọtụtụ mba dị iche iche.
\q1 
\v 8 Ọ sịrị, ‘Ndị ọchịagha m niile ha abụghị ndị eze?’
\q2 
\v 9 ‘Ọnọdụ Kalno ọ dịghị ka nke Kakemish?
\q1 Hamat ọ dịghị ka Apad;
\q2 Sameria ọ dịghịkwa ka Damaskọs?
\q1 
\v 10 Dịka aka m si chịkọta alaeze dị iche iche nke ọtụtụ arụsị,
\q2 alaeze dị iche iche nke arụsị apịrị apị ha karịrị nke Jerusalem na Sameria.
\q1 
\v 11 Ọ bụ na m agaghị emekwa Jerusalem na arụsị ya niile apịrị apị
\q2 dịka m mere Sameria na arụsị ya niile?’ ”
\p 
\v 12 Mgbe Onyenwe anyị rụsịrị ọrụ ya niile megide ugwu Zayọn na Jerusalem, ọ ga-asị, “Aga m ata eze ndị Asịrịa ahụhụ nʼihi nganga nke obi ha, na ịnya isi nke anya mpako ya.
\v 13 Nʼihi na ọ na-asị,
\q1 “ ‘Ọ bụ site nʼike aka m, ka m ji mee nke a,
\q2 ọ bụkwa na amamihe m, nʼihi na m nwere nghọta.
\q1 Ewezugara m oke ala mba niile dị iche iche,
\q2 apụnara m ha akụ ha niile;
\q2 dịka onye dị ike, e wedara m ndị eze ha niile nʼokpuru m.
\q1 
\v 14 Dịka mmadụ si agbatị aka nʼime akwụ nnụnụ,
\q2 otu a ka m chịkọtara akụnụba mba dị iche iche,
\q1 dịka mmadụ si achịkọta akwa ahapụrụ ahapụ,
\q2 otu a ka m chịkọtara mba ụwa niile;
\q1 Ọ dịghị onye megharịrị otu nku,
\q2 maọbụ saghee ọnụ ya ime mkpọtụ!’ ”
\b
\q1 
\v 15 Anyụike ọ ga-anya isi sị na ya dị ukwuu karịa onye na-eji ya awa nkụ,
\q2 ka ọ bụ mma nkwọ, ọ ga-aja onwe ya karịa onye na-eji ya akpọwa ihe?
\q1 Dịka a ga-asị na okporo igwe ga-ebuli onye na-eweli ya elu,
\q2 maọbụ mkpọ ọ ga-efegharị onye na-abụghị osisi.
\q1 
\v 16 Nʼihi ya, Onyenwe anyị, bụ \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile,
\q2 ga-ezitere ndị agha gị mara abụba ihe otiti;
\q1 ọ ga-akwanye ọkụ nʼokpuru ihe ngosipụta nke ịdị ebube ya
\q2 dịka ire ọkụ nke na-ere ere.
\q1 
\v 17 Ìhè nke Izrel, ga-aghọ ọkụ,
\q2 Onye nsọ ha, ga-aghọkwa ire ọkụ nke ga-ala ihe niile nʼiyi.
\q1 Nʼotu abalị ka ọ ga-erechapụ
\q2 ogwu niile na uke niile ọkụ.
\q1 
\v 18 A ga-ala ịma mma nke oke ọhịa ya na ala ya na-amị ezi mkpụrụ
\q2 nʼiyi kpamkpam,
\q2 dịka mgbe ọrịa na-ala mmadụ nʼiyi.
\q1 
\v 19 Naanị osisi ole na ole ga-afọdụ,
\q2 ha ga-adị ntakịrị ruo na nwantakịrị nwere ike gụọ ha ọnụ.
\s1 Ndị ga-afọdụ nʼIzrel
\q1 
\v 20 Nʼụbọchị ahụ, ndị fọdụrụ nʼala Izrel,
\q2 na ndị fọdụrụ ndụ nʼụlọ Jekọb,
\q1 agaghịkwa adabere nʼonye\f + \fr 10:20 \ft Nʼebe a na-ekwu banyere mba Asịrịa.\f* ahụ
\q2 tidara ha,
\q1 kama ha ga-adabere naanị na \nd Onyenwe anyị\nd*,
\q2 Onye nsọ nke Izrel.
\q1 
\v 21 Ndị fọdụrụ ga-alọghachi, bụ ndị Nke Jekọb fọdụrụ
\q2 ga-alọghachikwute Chineke dị ukwuu.
\q1 
\v 22 Ọ bụ ezie na ndị gị Izrel dị ukwuu dịka aja dị nʼakụkụ osimiri,
\q2 ọ bụ naanị mmadụ ole na ole ga-alọghachi.
\q1 A kabiela ịla nʼiyi,
\q2 nke dị oke ukwuu ya na ezi omume.
\q1 
\v 23 E, Onyenwe anyị, \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, ekpebiela
\q2 na ọ ga-ebibi ala ahụ niile.
\p 
\v 24 Ya mere, ihe a ka Onyenwe anyị, bụ \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, sịrị,
\q1 “Unu ndị m, ndị bi na Zayọn,
\q2 unu atụkwala ndị Asịrịa egwu
\q1 bụ ndị na-eti unu mkpara igwe,
\q2 na-ewelikwa mkpọ megide unu dịka ndị Ijipt mere.
\q1 
\v 25 Nʼoge na-adịghị anya, iwe m ga-adajụ nʼebe unu nọ,
\q2 ma ọ ga-ebili megide ha, laakwa ha nʼiyi.”
\b
\q1 
\v 26 \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, ga-eji ụtarị tie ha ihe
\q2 dịka o sịrị tie ndị Midia ihe na nkume Oreb.
\q1 Ọ ga-eweli mkpanaka ya nʼelu oke osimiri,
\q2 ọ ga-eweli ya dịka o mere nʼIjipt.
\q1 
\v 27 Nʼụbọchị ahụ, aga m eme ka unu nwere onwe
\q2 unu site nʼebe ndị Asịrịa nọ.
\q1 Ụdọ igwe ha kenyere unu nʼolu ka m ga-adọbisi,
\q2 wezuga ibu arọ unu.
\b
\q1 
\v 28 Ha erutela Ayịat;
\q2 ugbu a, ha nọ na Migrọn.
\q2 Ha na-edokọta ngwa agha ha na Mikmash.
\q1 
\v 29 Lee ka ha na-agabiga ụzọ warawara;
\q2 ha ekpebiela ịnọ ọnọdụ abalị na Geba!
\q1 Ndị Rema na-ama jijiji,
\q2 obodo Gibea nke bụ obodo Sọl agbapụla ọsọ ndụ.
\q1 
\v 30 Tienụ mkpu akwa unu ada Galim,
\q2 geenụ ntị unu ndị Laisha!
\q2 Leenụ ihe na-adanyere gị, gị Anatot!
\q1 
\v 31 Lee na Madmena nọ nʼọsọ,
\q2 ndị Gebim na-ezo onwe ha.
\q1 
\v 32 Ndị iro akwụsịla nʼobodo Nob taa;
\q2 ha na-atụ ugwu Zayọn
\q1 na Jerusalem aka,
\q2 na-ekwere ya nʼisi.
\b
\q1 
\v 33 Lee Onyenwe anyị, \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile,
\q2 ga-eji oke ike gbutuo ngalaba osisi niile.
\q1 Ọ ga-egbutukwa osisi ndị dị elu,
\q2 meekwa ka ndị toro ogologo dị ala.
\q1 
\v 34 Ya onwe ya ga-egbutu ha niile ka e si eji anyụike egbutu osisi dị nʼoke ọhịa.
\q2 Lebanọn ga-adakwa nʼihu Onye ahụ dị ike dịka osisi dị nʼoke ọhịa si ada.
\c 11
\s1 Ome si nʼezinaụlọ Jesi
\q1 
\v 1 Ome ga-epupụta site nʼogwe osisi Jesi;
\q2 otu Alaka ga-esitekwa na mgbọrọgwụ ya tolite ga-amịkwa mkpụrụ.
\q1 
\v 2 Mmụọ \nd Onyenwe anyị\nd* ga-enwekwa ọnọdụ nʼime ya,
\q2 inye ya Mmụọ amamihe na Mmụọ nghọta,
\q2 Mmụọ ndụmọdụ na ike,
\q2 Mmụọ ihe ọmụma na nke ịtụ egwu \nd Onyenwe anyị\nd*.
\q1 
\v 3 Ihe ga-amasị ya bụ egwu \nd Onyenwe anyị\nd*.
\b
\q1 Ọ gaghị ekpe ikpe site naanị nʼihe o ji anya ya abụọ hụ,
\q2 maọbụ gbubie ikpe site naanị nʼihe ọ nụrụ na ntị ya.
\q1 
\v 4 Kama ọ bụ ezi omume ka ọ ga-eji kpee ndị ogbenye ikpe;
\q2 ọ bụkwa ikpe ziri ezi ka ọ ga-ekpere ndị na-adịghị ike nke ụwa.
\q1 Okwu ọnụ ka ọ ga-eji nye ndị mmadụ ahụhụ,
\q2 ọ bụ okwu ọnụ ka ọ ga-eji maa ndị ajọ omume ikpe ọnwụ.
\q1 
\v 5 Ezi omume ya ga-adị ka ihe ike nʼume,
\q2 ma ikwesi ntụkwasị obi ga-abụ ihe okike ukwu ya.
\b
\q1 
\v 6 Nʼụbọchị ahụ, nkịta ọhịa na nwa atụrụ ga-ebikọ nʼudo;
\q2 agụ na nwa ewu ga-amakpukọkwa.
\q1 Nwa ehi na ụmụ ọdụm na nwa ịnyịnya mara abụba ga-anọkọtakwa,
\q2 ọ bụkwa nwantakịrị ga na-edugharị ha.
\q1 
\v 7 Nne ehi na anụ ọhịa bịa ga-atakọkwa ahịhịa nʼotu ebe,
\q2 ụmụ ha ga-amakpukọkwa nʼudo nʼotu ebe.
\q2 Ọdụm ga-atakwa ahịhịa dịka ehi.
\q1 
\v 8 Ụmụntakịrị ga-egwugharị egwu nʼakụkụ ọnụ ajụala;
\q2 nwantakịrị ga-etinyekwa aka nʼakwụ ibi.
\q1 
\v 9 Ha agaghị eme ihe mmerụ maọbụ bibikwa ihe,
\q2 nʼelu ugwu nsọ m niile.
\q1 Nʼihi na ụwa niile ga-ejupụta na ihe ọmụma
\q2 nke \nd Onyenwe anyị\nd* dịka mmiri si ekpuchi oke osimiri.
\p 
\v 10 Nʼụbọchị ahụ, mgbọrọgwụ Jesi ga-eguzo ka ọkọlọtọ nye ndị dị iche iche. Mba niile ga-abịakwute ya; ebe izuike ya ga-ejupụtakwa nʼebube.
\v 11 Nʼụbọchị ahụ, Onyenwe anyị ga-esetikwa aka nke ugboro abụọ\f + \fr 11:11 \ft Okwu a, “nke ugboro abụọ,” na-egosi na onwe mgbe ha lọtara nʼoge gara aga. Nlọghachi mbụ ha, bụ oge ha si Ijipt lọta.\f* inwetaghachiri onwe ya ndị ya fọdụrụ site na Asịrịa, sitekwa na ndịda Ijipt, sitekwa na Mgbago Ijipt,\f + \fr 11:11 \ft Maọbụ, \fqa Patros\f* sitekwa na Kush, sitekwa na Elam, sitekwa na Babilọn, bụ Shaịna, sitekwa na Hamat na obodo niile dị nʼala niile osimiri gbara gburugburu.
\q1 
\v 12 Ọ ga-ebuliri mba niile ọkọlọtọ
\q2 ọ ga-akpọghachite ụmụ Izrel achụpụrụ achụpụ,
\q1 ọ ga-esite na nsọtụ anọ nke ụwa
\q2 kpokọta ndị Juda niile site nʼebe a chụsasịrị ha.
\q1 
\v 13 Ekworo Ifrem ga-akwụsị,
\q2 a ga-ebipụ ndị iro Juda.
\q1 Nʼikpeazụ, ekworo ahụ nke dị nʼetiti Izrel na Juda ga-akwụsị\f + \fr 11:13 \ft \xt Aịz 9:21; Jer 3:18; Izk 37:16,17,22\xt*\f*;
\q2 ha agaghị alụsokwa onwe ha ọgụ ọzọ.
\q1 
\v 14 Ha ga-ejikọta aka ha buso ndị Filistia nọ nʼakụkụ ọdịda anyanwụ ala ha agha;
\q2 ha ga-ebusokwa ndị bichiri nʼakụkụ ọwụwa anyanwụ ala ahụ agha.
\q1 Ha ga-emeri ndị Edọm na Moab.
\q2 Ndị Amọn ga-erubekwara ha isi.
\q1 
\v 15 \nd Onyenwe anyị\nd* ga-eme
\q2 ka warawara ọnụ osimiri Ijipt taa.
\q1 Ọ ga-eji ifufe siri ike, nke na-ekpo ọkụ
\q2 mikọrọ mmiri dị nʼosimiri Yufretis.
\q1 Ọ ga-ekewa ya ka ọ bụrụ isi iyi asaa,
\q2 nke mmadụ nwere ike iji ụkwụ gafee.
\q1 
\v 16 Ọ ga-esite nʼAsịrịa kpawaa ụzọ
\q2 nʼihi ndị ya fọdụrụ nʼebe ahụ,
\q1 dịka o si meere ndị Izrel nʼoge gara aga,
\q2 mgbe ha si nʼIjipt na-alọta.
\c 12
\s1 Abụ Otuto
\p 
\v 1 Nʼụbọchị ahụ, ị ga-ekwu sị,
\q1 “Aga m eto gị \nd Onyenwe anyị\nd*.
\q2 Ọ bụ ezie na ị wesara m iwe,
\q1 ma ugbu a, iwe gị adajụọla;
\q2 ị kasịkwara m obi.
\q1 
\v 2 Nʼezie, Chineke bụ onye nzọpụta m;
\q2 aga m atụkwasị ya obi, ụjọ agaghị atụkwa m.
\q1 \nd Onyenwe anyị\nd*, Onyenwe anyị ya onwe ya, bụ ike m bụrụkwa abụ m,
\q2 ọ ghọrọla m onye nzọpụta.”
\q1 
\v 3 Ị ga-eji ọṅụ dọrọ mmiri
\q2 site nʼolulu mmiri nke nzọpụta.
\p 
\v 4 Nʼụbọchị ahụ, ị ga-ekwukwa sị,
\q1 “Nyenụ \nd Onyenwe anyị\nd* otuto, Kwupụtakwa aha ya\f + \fr 12:4 \ft \xt 1Ih 16:8; Abụ 105:1\xt*\f*;
\q2 meenụ ka amata nʼetiti mba niile ihe niile ọ rụrụ\f + \fr 12:4 \ft \xt Abụ 145:4-6.\xt*\f*;
\q2 kwusaanụ na aha ya bu ihe e buliri elu.
\q1 
\v 5 Bụkuonụ \nd Onyenwe anyị\nd* abụ, nʼihi na o meela oke ihe dị ebube.
\q2 Meekwanụ ka ụwa niile mara ihe ọ rụrụ.
\q1 
\v 6 Ka ndị niile bi na Zayọn tie mkpu ọṅụ,\f + \fr 12:6 \ft \xt Zef 3:14,15\xt*\f* bụkwaa abụ.
\q2 Nʼihi na Onye nsọ nke Izrel.\f + \fr 12:6 \ft \xt Abụ 89:18\xt*\f* dị ukwuu, e, ọ dị ike nke ukwuu, bụ Onye ahụ na-ebi nʼetiti unu.”\f + \fr 12:6 \ft \xt Zef 3:17\xt*\f*
\c 13
\s1 Amụma e buru megide Babilọn
\p 
\v 1 Nke a bụ amụma megide Babilọn nke Aịzaya nwa Emọz hụrụ.
\q1 
\v 2 Welienụ ọkọlọtọ agha nʼelu ugwu tọgbọrọ nʼefu.
\q2 Kpọkuonụ ndị agha.
\q1 Feerenụ ha aka,
\q2 ka ha site nʼọnụ ụzọ ama nke ndị a maara aha ha bata nʼime obodo ukwu ahụ na-anya isi.
\q1 
\v 3 Enyela m ndị m kwadoro maka agha iwu;
\q2 akpọọla m ndị ọka agha m oku, bụ ndị na-aṅụrị ọṅụ na mmeri m, ka ha gosipụta oke iwe m.
\q2 E, ndị m kpọrọ bụ ndị ahụ na-aṅụrị ọṅụ ịhụ na m meriri ndị iro m.
\b
\q1 
\v 4 Gee ntị nụrụ ụzụ na-ada nʼugwu niile;
\q2 gee ntị nụrụ ụzụ yiri ụzụ nke igwe mmadụ na-eme.
\q1 Gee ntị nụrụ mkpọtụ na-ada nʼetiti alaeze dị iche iche.
\q2 Dịka mkpọtụ na-eme mgbe ọtụtụ mba na-ezukọta nʼotu ebe.
\q1 Ọ bụ \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile
\q2 na-achịkọta ndị agha ya nʼihi ibu agha.
\q1 
\v 5 Ha si nʼobodo dị iche iche, nke dị anya
\q2 na nke dị na nsọtụ ụwa na-abịa.
\q1 Ha bu ngwa agha na-egosi oke iwe \nd Onyenwe anyị\nd*
\q2 na-abịa imebi ala ahụ niile.
\b
\q1 
\v 6 Kwasienụ akwa ike nʼihi na ụbọchị \nd Onyenwe anyị\nd* dị nso,\f + \fr 13:6 \ft \xt Izk 30:3; Ems 5:18; Zef 1:7; Mkp 6:17\xt*\f*
\q2 ụbọchị ahụ oke mbibi ga-esi nʼaka Onye pụrụ ime ihe niile bịara unu.
\q1 
\v 7 Nʼihi nke a, aka ndị mmadụ ga-ada mba,
\q2 obi ga-alọkwa ndị mmadụ mmiri.
\q1 
\v 8 Ha ga-ama jijiji nʼihi oke egwu.
\q2 Ahụ mgbu ga-abịakwasị ha
\q2 mee ka ha sụọ ude dịka nwanyị ime na-eme.
\q1 Ha ga-elerịta onwe ha anya nʼọnọdụ mgbagwoju anya, ha agaghị amakwa ihe ha ga-eme.
\q2 Ọnọdụ dị otu a ga-apụta ihe nʼihu ha.
\b
\q1 
\v 9 Nʼihi na lee, ụbọchị \nd Onyenwe anyị\nd* na-abịa,
\q2 ụbọchị nke obi ebere na-agaghị adịkwa, ụbọchị iwe na oke ọnụma.
\q1 A ga-ekpochapụ ala ahụ,
\q2 ya na ndị mmehie niile dị nʼime ya.
\q1 
\v 10 Nʼihi na kpakpando niile nke eluigwe na kpakpando ndị ọzọ gbara ha gburugburu
\q2 agaghị egosipụta ìhè ha.
\q1 Anyanwụ ga-agba ọchịchịrị nʼọwụwa ya
\q2 ọnwa agakwaghị enye ìhè ya.
\q1 
\v 11 Aga m ata ụwa ahụhụ nʼihi mmehie ya,
\q2 taakwa ndị na-emebi iwu ahụhụ nʼihi mmehie ha.
\q1 Ịnya isi nke onye mpako ka m ga-egwepịa,
\q2 ya na nganga onye na-adịghị eme ebere.
\q1 
\v 12 Aga m eme ka mmadụ dị ụkọ karịa ọlaedo a nụchara anụcha,
\q2 ha ga-akọ ụkọ karịa ọlaedo si Ọfịa.
\q1 
\v 13 Nʼihi na m ga-eme ka eluigwe maa jijiji,
\q2 meekwa ka e wezuga ụwa site nʼọnọdụ ya,\f + \fr 13:13 \ft \xt Heg 2:6\xt*\f*
\q1 nʼihi oke iwe\f + \fr 13:13 \ft \xt Abụ 110:5; Akw 1:12\xt*\f* ga-ewe \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile.
\q2 Ha ga-emezu nʼụbọchị ahụ ọ ga-ezipụta oke iwe ya dị ọkụ.
\b
\q1 
\v 14 Ọ ga-erukwa na onye ọbụla nʼime ha ga-eche ihu ya nʼụzọ gawara ebe ndị ya nọ.
\q2 Ha ga-agbarakwa ọsọ laghachi nʼala nke aka ha
\q1 dịka mgbada na-agbanarị ndị na-achụ nta,
\q2 maọbụ ụmụ atụrụ ndị na-enweghị onye na-azụ ha.
\q1 
\v 15 Onye ọbụla e jidere nʼime ha ka a ga-amapu afọ,
\q2 onye ọbụla nke e jidere ka a ga-eji mma agha gbuo.
\q1 
\v 16 A ga-etipịa ụmụ ha na-aṅụ ara nʼihu ha;
\q2 a ga-anapụ ha ụlọ ha, merụkwaa ndị nwunye ha.
\b
\q1 
\v 17 Nʼihi na lee, aga m eme ka ndị Midia pụọ imegide ha;
\q2 ọ dịkwaghị ọlaedo
\q2 maọbụ ọlaọcha ha pụrụ iji megharịa ha anya.
\q1 
\v 18 Ha ga-eji ụta ha gbatusịa ụmụ okorobịa;
\q2 ha agaghị emekwara ụmụntakịrị ebere,
\q2 maọbụ gosi ụmụ na-etopụta etopụta obi ebere.
\q1 
\v 19 Babilọn, bụ ọla mma nke alaeze niile,
\q2 ịma mma na ebube ndị Kaldịa,
\q1 mgbe Chineke ga-akwatu ya
\q2 ọ ga-adị ka Sọdọm na Gọmọra.
\q1 
\v 20 Ọ gaghị abụ ebe obibi ọzọ ruo mgbe ebighị ebi.
\q2 Site nʼotu ọgbọ ruo nʼọgbọ ọzọ ndị mmadụ agaghị ebi nʼime ya.
\q1 Ọ dịghị onye Arebịa na-ejegharị ejegharị ga-ama ụlọ ikwu ya nʼime ya;
\q2 ndị ọzụzụ atụrụ agaghị ekwe ka atụrụ ha makpuru nʼebe ahụ.
\q1 
\v 21 Ọ ga-abụ ebe obibi nye anụ ọhịa niile bi nʼọzara.
\q2 Ụlọ dị nʼebe ahụ ga-abụkwa ebe obibi nye nkịta ọhịa,
\q1 na ikwighịkwighị,
\q2 nʼebe ahụ kwa ka ụmụ mkpi ọhịa ga na-awụgharị.
\q1 
\v 22 A ga-anụkwa ụda akwa anụ ọhịa, na ịgbọ ụja nkịta ọhịa nʼime ụlọ ha niile e wusiri ike.
\q2 Nkịta ọhịa ga-ebikwa nʼime ụlọ ọma niile dị nʼebe ahụ.
\q1 Lee na oge ha ji emezu adịla nso,
\q2 a gaghị emekwa ka oge imezu ihe ndị a dị anya.
\b
\b
\c 14
\q1 
\v 1 Ma \nd Onyenwe anyị\nd* ga-emekwara Jekọb ebere;
\q2 ọ ga-ahọpụtakwa ndị Izrel ọzọ,
\q2 meekwa ka ha lọghachi bịa biri nʼala nke aka ha.
\q1 Ọtụtụ ndị ọbịa dị iche iche ga-adịnyere ha,
\q2 soro ezinaụlọ Jekọb bikọtaa ọnụ.
\q1 
\v 2 Mba dị iche iche ga-enyere ha aka ịlọghachi nʼala ha,
\q2 nke Onyenwe anyị nyere ha.
\q1 Mba ndị a ga-aghọkwa ndị dị nʼokpuru ụmụ Izrel,
\q2 ghọọkwara ha ndị ohu nwoke na nwanyị.
\q1 Ụmụ Izrel ga-adọtakwa nʼagha ndị ahụ dọtara ha nʼagha na mbụ,
\q2 ma chịakwa ndị ahụ kpagburu ha nʼoge gara aga.
\p 
\v 3 Nʼụbọchị ahụ, Onyenwe anyị ga-eme ka ị pụọ site nʼihe mgbu na ihe mwute, sitekwa na ndọgbu onwe unu nʼọrụ nke ịbụ ohu unu wetaara onwe unu,
\v 4 unu ga-achị eze Babilọn ọchị sị ya, Leenụ gị.
\q1 Ahaa, lee ka i si daa gị onye na-emegbu ndị mmadụ.
\q2 Lee ka ịkpa ike gị si gwụsịa!
\q1 
\v 5 Nʼihi na \nd Onyenwe anyị\nd* anyajiela mkpara ndị na-eme ajọ ihe,
\q2 meekwa ka mkpara ndị na-achị achị,
\q1 
\v 6 nke sitere nʼiwe tidasịa ndị mmadụ
\q2 na-esepụghị aka nʼiti ha ihe,
\q1 nke ji nrubiga oke nke iwe ya megbuo mba dị iche iche
\q2 ya na oke mmekpa ahụ na-enweghị nkwusi.
\q1 
\v 7 Ụwa niile adaala jụ, ha enwekwaala izuike,
\q2 ha na-etipụ olu ịbụ abụ.
\q1 
\v 8 Ọ bụladị osisi junipa na osisi sida niile nke Lebanọn
\q2 na-aṅụrị ọṅụ megide gị na-asị,
\q1 “Agbajiela ike gị;
\q2 ugbu a ọ dịkwaghị onye ga-esogbu anyị ọzọ.”
\b
\q1 
\v 9 Ala mmụọ na-eme mkpọtụ,
\q2 na-eche izute gị nʼọbịbịa gị;
\q1 ọ na-akpọte mmụọ nke ndị nwụrụ anwụ ịbịa kelee gị,
\q2 bụ ndị niile bụburịị ndị ndu nʼụwa,
\q1 ọ na-eme ka ha si nʼocheeze ha niile bilie
\q2 bụ ndị niile ahụ bụ eze na mba niile dị iche iche.
\q1 
\v 10 Ha niile ga-eji otu olu zaa,
\q2 ha ga-asị gị,
\q1 “Gị onwe gị adịghịkwa ike, dịka anyị na-adịghị ike;
\q2 Ị ghọọla otu onye nʼime anyị.”
\q1 
\v 11 Nganga ịbụ eze gị niile, na oke ụzụ ụbọ akwara gị,
\q2 ka a na-elikọta nʼaja.
\q1 Ikpuru ga-aghọrọ anụ ahụ gị ebe ndina;
\q2 ọ bụkwa ikpuru ga-aghọ ihe mkpuchi ahụ gị.
\b
\q1 
\v 12 Lee ka i si site nʼeluigwe daa,
\q2 gị kpakpando ụtụtụ, nwa chi ọbụbọ.
\q1 Ọ bụ ezie na ị dị ukwuu nʼebe mba niile nke ụwa nọ na mbụ,
\q2 ma lee ka e si mee ka ị bụrụ onye a tụdara nʼala.
\q1 
\v 13 Nʼihi na i kwuru ya nʼobi gị sị,
\q2 “Aga m arịgoro nʼeluigwe,
\q1 doo ocheeze m
\q2 nʼelu kpakpando niile Chineke kere;
\q1 aga m anọdụkwa nʼugwu nzukọ,
\q2 na nsọtụ ugwu nsọ ahụ dị nʼelu elu ugwu, tụọ iwu.
\q1 
\v 14 Aga m arịgo nʼebe kachasị elu nke eluigwe,
\q2 mee onwe m ka m dịrị ka Onye kachasị ihe niile elu.”
\q1 
\v 15 Ma a ga-ewedata gị ala ruo nʼili,
\q2 ruo na nsọtụ ala mmụọ.
\b
\q1 
\v 16 Ndị niile hụrụ gị na-elegide gị anya,
\q2 na-atule banyere ndụ gị, sị,
\q1 “Ọ bụ nwoke a bụ onye ahụ mere ka ụwa maa jijiji,
\q2 onye mekwara ka alaeze mee mkpọtụ.
\q1 
\v 17 Ọ bụ onye a bụ onye ahụ mebiri ụwa mee ya ka ọ dị ka ọzara?
\q2 Ọ bụ ya tikpọrọ obodo ukwu ya niile,
\q2 jụkwa ịhapụ ndị ọ dọtara nʼagha ka ha laa?”
\b
\q1 
\v 18 Ndị eze mba niile dị iche iche
\q2 na-edina na nsọpụrụ nʼime ili ha.
\q1 
\v 19 Ma ozu gị ka a tụpụrụ
\q2 dịka alaka osisi rụrụ arụ, nke gbajiri agbaji.
\q1 Ọ bụkwa ozu ndị niile e gburu nʼagha,
\q2 na ozu ndị e ji mma agha mapuo afọ,
\q2 ndị na-arịdaru nʼolulu nkume, ka e ji kpuchie gị nʼili gị.
\q1 E, ozu gị dị ka ozu nke ịnyịnya zọtọrọ ụkwụ.
\q2 
\v 20 A gaghị eli gị dịka e si lie ndị eze ndị ọzọ,
\q1 nʼihi na i bibiela ala gị.
\q2 I gbukwaala ndị gị.
\b
\b
\q1 A gaghị akpọtụkwa aha ụmụ ụmụ
\q2 ndị na-emebi iwu ọzọ.
\q1 
\v 21 Dozienụ ebe a ga-anọ gbuo ụmụ ya ndị ikom,
\q2 nʼihi mmehie nke ndị bụ nna ha.
\q1 Ha agaghị ebili nweta ala ahụ,
\q2 mee ka elu ụwa jupụta nʼobodo ha niile.
\b
\q1 
\v 22 Nʼihi na mụ bụ \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwupụtara sị,
\q2 “Aga m ebili megide ha;
\q1 aga m esitekwa na Babilọn bipụ aha ndị fọdụrụ,
\q2 na ụmụ ha na ụmụ ụmụ ha.
\q2 Otu a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwubiri ya.
\q1 
\v 23 Aga m eme ka Babilọn ghọọ ụlọ obibi nye ikwighịkwighị,
\q2 na ebe mmiri ga na-adọkọ.
\q1 M ga-eji azịza ịla nʼiyi zachapụ ha.”
\q2 Otu a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwubiri ya.
\s1 Amụma e buru megide Asịrịa
\p 
\v 24 \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile aṅụọla iyi kwuo sị,
\q1 “Nʼezie, dịka m si tụọ ya nʼobi m, otu a ka ọ ga-emekwa.
\q2 Ọ ga-eguzosikwa ike dịka m si zube ya.
\q1 
\v 25 M ga-etipịa ndị Asịrịa nʼala m,
\q2 nʼelu ugwu m ka m ga-anọ zọpịa ha nʼokpuru ụkwụ.
\q1 A ga-ebupụ ibu arọ ya site nʼahụ ndị m,
\q2 a ga-ewezugakwa ibu arọ ya site nʼubu ha.”
\b
\q1 
\v 26 Nke a bụ nzube ahụ nke ezubere maka ụwa niile;
\q2 nke a bụkwa aka ahụ esetipụrụ nʼelu mba niile dị iche iche.
\q1 
\v 27 Nʼihi na \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, bụ dike nʼagha, ezubela ime ya. Onye kwa pụrụ ịgbanwe nzube ya?
\q2 O setịpụla aka ya, onye pụrụ ime ka o weghachi ya azụ?
\s1 Amụma e buru megide ndị Filistia
\p 
\v 28 Amụma a bịara nʼafọ ahụ eze Ehaz nwụrụ:
\q1 
\v 29 Unu aṅụrịla ọṅụ, unu ndị Filistia,
\q2 maka na mkpọrọ e ji eti unu ihe agbajiela;
\q1 Ọ bụ ezie na ọ gbajiela, ma ihe ga-esite nʼọdụdụ agwọ ahụ pụta bụ ajụala,
\q2 mkpụrụ ya ga-abụ agwọ ọjọọ, nke na-amagharị ebe niile.
\q1 
\v 30 Ndị bụ nnọọ ogbenye ga-achọta ihe oriri,
\q2 ndị mkpa na-akpa ga-ebikwa nʼudo.
\q1 Ma aga m eji agụụ na ụnwụ
\q2 laa ndị fọdụrụ ndụ nʼetiti unu nʼiyi.
\b
\q1 
\v 31 Kwasie akwa ike gị ọnụ ụzọ ama! Tie mkpu gị obodo!
\q2 Tụọnụ oke egwu unu ndị Filistia.
\q1 Nʼihi na lee, ndị agha a zụziri azụzi si nʼugwu na-abịa imegide gị.
\q2 Ọ dịghị onye na-aga iche nʼetiti ahịrị ha.
\q1 
\v 32 Ọsịsa dị aṅaa ka anyị ga-enye
\q2 ndị ozi si na mba ahụ?
\q1 Gwa ha na \nd Onyenwe anyị\nd* emeela ka Zayọn guzosie ike.
\q2 Ọ bụkwa nʼime ya ka ndị ya e wedara nʼala ga-achọtara onwe ha ebe mgbaba.
\c 15
\s1 Amụma e buru banyere Moab
\p 
\v 1 Amụma megide Moab:
\q1 Ar dị na Moab a laala nʼiyi,
\q2 a lara ya nʼiyi naanị nʼotu abalị.
\q1 Kia dị na Moab a laala nʼiyi,
\q2 a lara ya nʼiyi naanị nʼotu abalị.\f + \fr 15:1 \ft Obodo Ar na Kia, bụ obodo abụọ dị mkpa nʼala ndị Moab.\f*
\q1 
\v 2 Ndị niile bi na Dibọn
\q2 na-aga nʼihu ụlọ mmụọ ha ịkwa akwa. Ndị
\q2 Moab na-akwa akwa nʼihi Nebo na Medeba.
\q1 Isi ha niile bụ isi nkwọcha,
\q2 afụọnụ ha niile ka akpụchakwara.
\q1 
\v 3 Ha na-eyi akwa mkpe na-agagharị nʼezi,
\q2 mkpu akwa na-ada nʼelu ụlọ, na nʼama.
\q1 Ha niile ji iti mkpu na ịkwa akwa
\q2 na-ada nʼala.
\q1 
\v 4 Heshbọn na Eleale na-eti mkpu akwa,
\q2 a na-anụ olu akwa ha ọ bụladị ruo Jehaz.
\q1 Nʼihi nke a, ndị agha Moab na-eti mkpu akwa,
\q2 mkpụrụobi ha na-amakwa jijiji.
\b
\q1 
\v 5 Ọ na-ewute mkpụrụobi m nʼihi Moab,\f + \fr 15:5 \ft \xt Aịz 16:11; Jer 48:31\xt*\f*
\q2 ndị ya na-agba ọsọ ruo ọ bụladị nʼobodo Zoa
\q2 na Eglat Shelishiya.
\q1 Ha na-akwa akwa
\q2 dịka ha na-arịgo Luhit.\f + \fr 15:5 \ft \xt Jer 48:5\xt*\f*
\q1 Mgbe ha na-agbago ụzọ Heronaim,
\q2 ha na-ebe akwa mwute nʼihi mbibi bịakwasịrị ha.
\q1 
\v 6 Mmiri Nimrim atachaala!
\q2 Ahịhịa akpọnwụọkwala;
\q1 ahịhịa ndụ niile agwụkwala
\q2 o nwekwaghị akwụkwọ ndụ nke fọrọ.
\q1 
\v 7 Ya mere akụnụba ha kpakọbara ndị ha chekwara
\q2 ka ha buuru gafee ofe ndagwurugwu warawara nke ọdọ mmiri osisi pọpla niile.
\q1 
\v 8 Mkpu akwa ha na-ada ụda gburugburu oke ala Moab niile;
\q2 akwa ha na-ebesi ike na-ada ruo obodo Eglaim;
\q2 abụ akwa ha na-erukwa Bịa-Elim.
\q1 
\v 9 Iyi Dibọn jupụtara nʼọbara,
\q2 ma aga m atụkwasịkwa ọ bụladị ọtụtụ ihe ndị ọzọ nʼelu Dibọn!
\q1 Ọdụm ka a ga-atụkwasịrị ndị Moab\f + \fr 15:9 \ft \xt 2Ez 17:25; Jer 50:17\xt*\f* gbapụrụ
\q2 tụkwasịkwara ndị fọdụrụ nʼala ahụ.
\b
\b
\c 16
\q1 
\v 1 Ziganụ ụmụ atụrụ dịka onyinye
\q2 nye onye na-achị ala ahụ
\q1 site na Sela, gafee nʼụzọ ọzara
\q2 ruo ugwu nke Ada Zayọn.
\q1 
\v 2 Ndị inyom Moab
\q2 nọkwa nʼọnụ mmiri Anọn\f + \fr 16:2 \ft Mmiri Anọn nke dị nʼakụkụ ugwu oke ala ahụ, bụ iyi dị mkpa nʼala Moab \xt Ọnụ 21:13-14\xt*\f*
\q1 na-akwụgharị
\q2 dịka ụmụ nnụnụ e si nʼakwụ ha chụpụ.
\b
\q1 
\v 3 Moab na-asị, “Nwee mkpebi na mmụọ gị,”
\q2 “Kwubie okwu nʼihe ị kpebiri.
\q1 Mee ka onyinyo gị dịrị ka abalị
\q2 nʼetiti oke ehihie.
\q1 Zobe ndị gbapụrụ ọsọ ndụ,
\q2 ekpugheela onye na-achọ ebe nchebe.
\q1 
\v 4 Ka ndị Moab achụpụrụ achụpụ nọrọ nʼetiti unu,
\q2 ghọrọ ha ebe nchebe pụọ nʼaka onye mbibi ahụ.”
\b
\q1 Onye mmegbu ahụ nwere ọgwụgwụ,
\q2 mbibi ga-akwụsịkwa,
\q2 onye ahụ na-azọda mmadụ ga-agwụchakwa site nʼala ahụ.
\q1 
\v 5 A ga-ehiwe otu ocheeze site nʼịhụnanya;
\q2 otu nwoke ga-anọkwasị nʼelu ya site nʼikwesị ntụkwasị obi,
\q2 otu onye sitere nʼụlọ ikwu Devid,
\q1 bụ, onye mgbe ọ na-ekpe ikpe, na-achọ ikpe ziri ezi,\f + \fr 16:5 \ft \xt Aịz 9:6-7; Aịz 32:1; Dan 7:14; Luk 1:33; Mkp 11:15\xt*\f*
\q2 na-emekwa ngwa ime ezi omume.
\b
\q1 
\v 6 Anyị anụla akụkọ banyere Moab,
\q2 nụkwa ihe banyere nganga\f + \fr 16:6 \ft \xt Jer 48:29; Ọbd 3; Zef 2:8\xt*\f* ya na aghụghọ ya niile.
\q1 Obodo ahụ na-anya isi, nke nganga juru obi?
\q2 Ugbu a, lee na ịnya isi ha erijughị afọ.
\q1 
\v 7 Ya mere, ndị Moab niile na-eti mkpu akwa,
\q2 ha na-ebetara Moab akwa.
\q1 Kwasie akwa ike, nwee mwute,
\q2 nʼihi achịcha e ji mkpụrụ osisi a mịkpọrọ amịkpọ mee nke Kia Hereset.
\q1 
\v 8 Lee ka ubi niile nke Heshbọn si tọgbọrọ nʼefu;
\q2 osisi vaịnị ha niile dị na Sibma akpọnwụsịala.
\q1 E, ndị eze mba dị iche iche azọdala
\q2 ọtụtụ osisi vaịnị ọma ndị a niile nʼụkwụ.
\q1 E, osisi vaịnị ndị gbatịrị ruo Jeza,
\q2 ruokwa nʼọzara,
\q1 nke mgbọrọgwụ ha gbasara
\q2 ruo nʼọnụ osimiri.
\q1 
\v 9 Nʼihi ya, ana m akwa akwa dị ka ndị Jeza\f + \fr 16:9 \ft \xt Aịz 15:4\xt*\f* si akwa akwa
\q2 nʼihi ubi vaịnị Sibma.
\q1 Anya mmiri akwa m ga-ede gị ahụ
\q2 gị Heshbọn, na gị Eleale,\f + \fr 16:9 \ft \xt Ọnụ 32:3; Jer 48:34\xt*\f*
\q1 nʼihi na e meela ka ụzụ mkpu ọṅụ nke na-ada
\q2 mgbe a na-ewe ihe ubi nʼime gị gharakwa ịdị ọzọ.
\q1 
\v 10 Ewepụla ọṅụ na obi ụtọ site nʼubi na-amị mkpụrụ ọma,
\q2 ọ dịghị onye na-abụ maọbụ tie mkpu ọṅụ nʼubi vaịnị a gbara ogige;
\q1 ọ dịkwaghị onye na-azọchapụta mmanya m vaịnị nʼebe ịzọcha mmanya;
\q2 nʼihi na emeela m ka iti mkpu ọṅụ niile kwụsị.
\q1 
\v 11 Mkpụrụobi m na-enwe mwute nʼihi Moab dịka ụbọ akwara,
\q2 ime mmụọ m kwa nʼihi Kia Heres.
\q1 
\v 12 Mgbe Moab ga-egosipụta onwe ya nʼebe ya dị elu,
\q2 ọ na-eme naanị ka ike gwụ ya,
\q1 mgbe ọ ga-aga ikpe ekpere nʼihu mmụọ ya,
\q2 o nweghị uru nke a ga-abara ha.
\p 
\v 13 Ihe ndị a niile bụ okwu \nd Onyenwe anyị\nd* kwuru banyere Moab na mbụ,
\v 14 ma ugbu a \nd Onyenwe anyị\nd* na-ekwu, sị, “Tupu afọ atọ agachaa, dịka onye e goro ọrụ\f + \fr 16:14 \ft \xt Job 7:1; 14:6; Aịz 21:16\xt*\f* si agụ afọ, a ga-eleli ugwu niile Moab nwere, ya na igwe mmadụ ya bara ụba. Ndị fọdụkwara ndụ ga-adị naanị mmadụ ole na ole bụrụkwa ndị na-adịghị ike.”
\c 17
\s1 Ozi e ziri banyere Damaskọs
\p 
\v 1 Nke a bụ amụma megide Damaskọs,\f + \fr 17:1 \ft \xt Jen 14:15; 15:2; 2Ez 16:9; Jer 49:23; Ems 1:3-5; Zek 9:1; Ọrụ 9:2\xt*\f* isi obodo Siria.
\q1 “Lee, Damaskọs agaghị adịkwa! Ọ gaghị abụkwa obodo ọzọ,
\q2 kama ọ ga-aghọ mkpọmkpọ ebe, nke zedara ezeda.
\q1 
\v 2 Ọ dịkwaghị onye ga-ebi nʼime nʼobodo niile nke Aroea,
\q2 ọ ga-adịrị igwe atụrụ na ehi dị iche iche, ndị ga-amakpu,
\q2 ọ dịkwaghị onye ga-eme ka egwu tụọ ha nʼebe ahụ.
\q1 
\v 3 Ebe e wusiri ike nke Ifrem agaghị adịkwa,
\q2 ya na ike alaeze nke sị Damaskọs,
\q1 ndị fọdụrụ nke Aram ga-adị ka
\q2 ebube nke ndị Izrel,”
\q2 otu a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwubiri ya.
\b
\q1 
\v 4 “Nʼụbọchị ahụ, a ga-eme ka nsọpụrụ Jekọb nwere bụrụ ihe e wedara nʼala.
\q2 Abụba dịkwa ya nʼahụ ga-atalata.
\q1 
\v 5 Ọ ga-adị ka ubi e si nʼime ya wee ihe mkpụrụ site nʼọka guzoro ọtọ,
\q2 na-achịkọta mkpụrụ nʼogwe aka ha
\q1 dịka mgbe mmadụ na-atụtụkọta mkpụrụ site nʼigbo ọka
\q2 nʼime Ndagwurugwu Refaim.
\q1 
\v 6 Ma ọ bụ ole na ole nʼime mkpụrụ ahụ ga-afọdụkwa,
\q2 dịka mgbe a kuchasịrị osisi oliv,
\q1 hapụ mkpụrụ abụọ maọbụ atọ, nke dị nʼalaka kachasị elu,
\q2 maọbụ mkpụrụ anọ maọbụ ise a hapụrụ nʼọnụ ọnụ alaka nke ahụ mịrị mkpụrụ.”
\q2 Otu a ka \nd Onyenwe anyị\nd*, Chineke Izrel kwubiri ya.
\b
\q1 
\v 7 Nʼụbọchị ahụ, ha ga-echeta onye kere ha,
\q2 nweekwa nsọpụrụ nʼebe Onye nsọ nke Izrel nọ.
\q1 
\v 8 Nʼụbọchị ahụ, ha agaghị elekwasịkwa chi ha dị iche iche anya ka ha nyere ha aka.
\q2 Ha agakwaghị efe ihe ndị ahụ ha ji aka ha mee.\f + \fr 17:8 \ft \xt Aịz 2:8; 31:7\xt*\f*
\q1 Ha agakwaghị asọpụrụ chi nwanyị ha bụ Ashera,\f + \fr 17:8 \ft Ashera bụ chi nwanyị ndị Kenan. Ọ bụ osisi ka e ji egosipụta oyiyi ya na ọtụtụ ebe ịchụ aja ya. \xt Nkp 3:7; Dit 12:3; 16:21\xt*\f*
\q2 maọbụ ebe ịchụ aja ụda na-esi isi ụtọ nke mkpịsịaka kpụrụ.
\p 
\v 9 Nʼụbọchị ahụ, obodo ha niile e wusiri ike, nke ha hapụrụ nʼihi ndị Izrel, ga-adị ka ebe ahapụrụ ahapụ nye oke ọhịa na ahịhịa nke ọhịa. Ebe niile ga-abụ nnọọ mkpọmkpọ ebe.
\q1 
\v 10 Nʼihi na ị chezọla Chineke onye na-azọpụta gị.
\q2 I chetaghị Nkume ahụ, nke bụ ebe mgbaba gị.
\q1 Ya mere, ọ masịkwa gị kụọ ihe ọkụkụ dị iche iche nke dị ụtọ,
\q2 maọbụ manye alaka osisi vaịnị ị si nʼala ọzọ bubata,
\q1 
\v 11 ọ bụrụkwa na i mee ka ha too nʼụbọchị ahụ ị kụnyere ha nʼala,
\q2 maọbụ na ha mara ifuru nʼụtụtụ ụbọchị ahụ ị kụnyere ha nʼala,
\q1 ị gaghị aghọta mkpụrụ ọ mịrị,
\q2 nʼihi na ọ bụ naanị ọrịa na ihe mgbu ka ha ga-ewetara gị.
\b
\q1 
\v 12 Ahaa, lee ụzụ nke ọtụtụ mmadụ na-eme,
\q2 nke yiri mkpọtụ oke osimiri.
\q1 Ọ bụ mkpọtụ nke mba dị iche iche;
\q2 ha na-eme mkpọtụ dị ka nnugharị nke ọtụtụ osimiri.
\q1 
\v 13 Ọ bụ ezie na ha na-agbọ ụja dịka mkpọtụ nke oke osimiri,
\q2 ma Chineke ga-abara ha mba nke ga-eme ka ha gbaa ọsọ.
\q1 A ga-achụsa ha dịka ifufe si efesa igbugbo ọka,
\q2 na dịka mpempe akwụkwọ ifufe siri ike na-ebugharị gburugburu gburugburu.
\q1 
\v 14 Nʼanyasị, ha na-eme ka oke egwu dịrị,
\q2 tutu ruo ụtụtụ, ha adịghịkwa.
\q1 Nke a bụ ihe nketa dịịrị ndị ahụ na-apụnara anyị ihe anyị nwere nʼike.
\q2 E, ọ bụ ihe nza ruru ndị ahụ ji ike na-anakọrọ anyị ihe anyị nwere.
\c 18
\s1 Amụma e buru banyere Kush
\q1 
\v 1 Ahụhụ ga-adịrị ala ahụ a na-anụ ụzụ ọtụtụ nku nʼime ya,\f + \fr 18:1 \ft Maọbụ, \fqa ụzụ igurube\f*
\q2 ala ahụ dị nʼofe iyi ukwu niile nke Kush.\f + \fr 18:1 \ft Nʼoge Aịzaya onye amụma, ndị Kush nʼachị Ijipt. Mgbe ha chọrọ ibuso ndị Asịrịa agha, ha rịọrọ ndị Palestin ka ha nyere ha aka.\f*
\q1 
\v 2 Ala nke na-ezipụ ndị ozi ya site nʼosimiri,
\q2 bụ ndị na-eji ụgbọ mmiri papịrọs nʼaga nʼelu mmiri.
\b
\q1 Gaanụ ngwangwa, unu ndị ozi dị nkọ
\q1 gakwuru ndị toro ogologo nke ahụ ha na-akwọ mụrụmụrụ,
\q2 gakwuru ndị a na-atụ egwu nʼebe niile,
\q1 mba na-achọ okwu na ụka, nke na-azọpịakwa azọpịa,
\q2 ndị osimiri dị iche iche kewara ala ha.
\b
\q1 
\v 3 Unu niile bi nʼelu ụwa dum,
\q2 na unu ndị nwere ebe obibi nʼụwa, geenụ m ntị.
\q1 Mgbe e buliri ọkọlọtọ elu nʼelu ugwu niile,
\q2 lee anya;
\q1 mgbe a fụrụ opi ike,
\q2 gee ntị.
\q1 
\v 4 Nʼihi na ihe ndị a bụ ihe \nd Onyenwe anyị\nd* gwara m,
\q2 “Aga m anọ jụụ na-elepụ anya site nʼebe obibi m,
\q1 dịka mgbe igirigi na-ada nʼoge okpomọkụ nke owuwe ihe ubi,
\q2 na dịka anyanwụ si acha nʼoge okpomọkụ.”
\q1 
\v 5 Nʼihi na tupu oge owuwe ihe ubi eruo, mgbe ifuru dapụsịrị,
\q2 mgbe okoko na-aghọ mkpụrụ vaịnị nke ka na-achata achata,
\q1 ọ ga-eji mma oge gbuchapụ ụmụ alaka ya,
\q2 ọ ga-egbutu ma wezugakwa alaka ndị ahụ na-awasa awasa.
\q1 
\v 6 A ga-ahapụ ozu ndị agha ha
\q2 ka anụ ufe nke ugwu na ụmụ anụ ọhịa rie ha.
\q1 Ụmụ nnụnụ ga-eri anụ ha nʼoge okpomọkụ,
\q2 ma ụmụ anụ ọhịa ga-eri ha nʼoge oyi.
\p 
\v 7 Ma mgbe ahụ, a ga-ewetara \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile onyinye dị iche iche,
\q1 site na ndị toro ogologo, ndị ahụ na-akwọ mụrụmụrụ,
\q2 site na ndị a na-atụ egwu nʼebe niile,
\q1 bụ mba ndị okwu na ụka,\f + \fr 18:7 \fqa Maọbụ, \fqa asụsụ dị iche\f* nke na-azọpịakwa azọpịa,
\q2 ndị osimiri dị iche iche kewara ala ha.
\m A ga-eweta onyinye\f + \fr 18:7 \ft \xt Abụ 72:10; Aịz 16:2; Zef 3:10\xt*\f* a nʼUgwu Zayọn, nʼebe ahụ a na-akpọku aha \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile.
\c 19
\s1 Amụma e buru banyere Ijipt
\p 
\v 1 Nke a bụ amụma megide Ijipt:
\q1 Lee, \nd Onyenwe anyị\nd* na-abịa imegide Ijipt,
\q2 ọ na-anọkwasịkwa nʼeluigwe ojii nke na-agba ọsọ.
\q1 Arụsị ndị Ijipt niile na-ama jijiji nʼihu ya.
\q2 Ọzọ, nʼihi ụjọ obi ndị Ijipt na-agbaze nʼime onwe ha.
\b
\q1 
\v 2 “Aga m akpali ndị Ijipt mee ka ha lụọ ọgụ nʼetiti onwe ha.
\q2 Nwanne ga-emegide nwanne ya,
\q2 onye agbataobi ga-emegidekwa onye agbataobi ya;
\q2 obodo ga-emegide isi obodo;
\q2 otu a kwa, alaeze ga-emegidekwa alaeze.
\q1 
\v 3 Ndị Ijipt ga-ada mba nʼime mmụọ ha,
\q2 aga m eme ka nzube ha niile bụrụ ihe efu,
\q1 ha ga-ajụta arụsị na mmụọ ndị nwụrụ anwụ ase,
\q2 jụọkwa ndị na-ajụta mmụọ ọjọọ ase na ndị dibịa afa.
\q1 
\v 4 Onyenwe anyị, bụ \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile ekwuola ya sị,
\q2 Ọ bụ nʼaka eze afọ tara mmiri,\f + \fr 19:4 \ft Eze Shabaka, onye Kush chịrị ala Ijipt na senchuri nke asaa. \xt Aịz 20:4; Jer 46:26; Izk 29:19\xt*\f*
\q1 nke na-adịghị eme ebere,
\q2 ka m ga-enyefe ndị Ijipt, ka ọ bụrụ onye ga-achị ha.”
\b
\q1 
\v 5 Mmiri dị nʼosimiri ga-atada;
\q2 ọ ga-atakwa takọrọkwa.
\q1 
\v 6 Ụzọ niile osimiri Ijipt ahụ si asọgharị
\q2 ga-atalata bido nʼisi isi.
\q1 Ahịhịa riidi niile na amị niile ga-akpọnwụsịkwa.
\q2 
\v 7 Ahịhịa ndụ niile dị nʼakụkụ Naịl ga-akpọnwụ,
\q2 ifufe ga-efesakwa ha.
\q1 Mkpụrụ niile a kụrụ nʼebe ahụ ga-ala nʼiyi,
\q2 ihe niile ga-anwụ.
\q1 
\v 8 Ndị ọkụ azụ ga-asụ ude, kwaa ụwa,
\q2 na ndị niile na-atụba nko azụ nʼime Naịl,
\q1 ndị na-agha ụgbụ nʼelu mmiri
\q2 ga-ata ahụ.
\q1 
\v 9 Ndị nʼarụ ọrụ flakisi etiri eti ga-eru ụjụ,
\q2 na ndị na-akpa akwa ọcha ka olileanya ha ga-agharịpụ.
\q1 
\v 10 Obi ụtọ agaghị adịkwara ndị na-esite nʼịkpa akwa enweta ego,
\q2 ha na ndị ọrụ dị iche iche a na-akwụ ụgwọ.
\b
\q1 
\v 11 Naanị ndị nzuzu ka ndịisi Zoan bụ,
\q2 ndụmọdụ na-enweghị isi ka ndị na-adụ eze Ijipt ọdụ na-enye.
\q1 Ị ga-esi aṅaa gwa Fero,
\q2 “Abụ m otu nʼime ndị maara ihe,
\q2 onye si nʼagbụrụ ndị eze ochie”?
\b
\q1 
\v 12 Ebee ka ndị ikom gị ahụ maara ihe nọ ugbu a?
\q2 Ka ha gosi gị ma meekwa ka ị maara,
\q1 ihe \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile
\q2 zubere megide Ijipt.
\q1 
\v 13 Ndịisi obodo Zoan aghọọla ndị nzuzu,
\q2 ndịisi obodo Memfis\f + \fr 19:13 \ft Memfis bụ isi obodo ndị Ijipt nʼoge ochie. \xt Izk 30:13; Hos 9:6\xt*\f* aghọkwaala ndị e duhiere eduhie;
\q1 ndị bụ nkume isi nkuku nke ndị ya niile
\q2 eduhiela ndị Ijipt ụzọ.
\q1 
\v 14 \nd Onyenwe anyị\nd* awụnyela nʼime ha
\q2 mmụọ nzuzu nke uche na-ezughị oke;
\q1 nke mere ka Ijipt na-adagharị nʼihe niile ọ na-eme
\q2 dịka onye ṅụbigara mmanya oke si adagharị nʼihe ọ gbọrọ.
\q1 
\v 15 Ọ dịghị ihe Ijipt nwere ike ime,
\q2 isi maọbụ ọdụ; alaka nkwụ maọbụ osisi achara.
\p 
\v 16 Nʼụbọchị ahụ, ndị ikom Ijipt ga-adị ka ndị inyom, ha ga na-ama jijiji nʼegwu nʼihi aka ahụ \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile weliri elu imegide ha.
\v 17 Ala Juda ga-ewetara ndị Ijipt oke egwu, oke ụjọ ga-atụ onye ọbụla akpọtaara aha Juda, nʼihi ihe \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile na-ezube megide ha.
\p 
\v 18 Nʼụbọchị ahụ, obodo ise nʼime ala Ijipt ga-asụ asụsụ Kenan, ṅụọ iyi irubere \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile isi. Otu nʼime obodo ndị a ka a ga-akpọ Obodo anwụ.
\p 
\v 19 Nʼụbọchị ahụ, ebe ịchụrụ \nd Onyenwe anyị\nd* aja ga-adị nʼetiti ala Ijipt.\f + \fr 19:19 \ft \xt Jen 28:18; Ọpụ 24:4; Jos 22:10,26,27\xt*\f* A ga-ewukwa otu ogidi ncheta nye \nd Onyenwe anyị\nd* nʼoke ala ha.
\v 20 Nke a ga-abụ ihe ama na ihe ngosi, na \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile nọkwa nʼIjipt. Mgbe ha kpọkuru \nd Onyenwe anyị\nd* maka ndị na-emegbu ha, ọ ga-aza ha, ọ ga-ezitere ha onye nzọpụta, onye ga-azọpụta ha.
\v 21 Ya mere, \nd Onyenwe anyị\nd* ga-eme ka ndị Ijipt mara onye ọ bụ, nʼụbọchị ahụ, ha ga-amata \nd Onyenwe anyị\nd*, jirikwa ịchụ aja na onyinye fee ya. Ha ga-ekwe \nd Onyenwe anyị\nd* nkwa debekwa ya.
\v 22 \nd Onyenwe anyị\nd* ga-eti Ijipt ihe otiti, ma ọ ga-agwọkwa ha. Ndị Ijipt ga-alọghachikwute \nd Onyenwe anyị\nd*, ọ ga-aṅakwa ntị nʼarịrịọ ha gwọọkwa ha.
\p 
\v 23 Nʼụbọchị ahụ, a ga-enwe okporoụzọ atụliri atụli nke ga-esite na Ijipt ruo Asịrịa. Ndị Asịrịa ga-aga Ijipt, ndị Ijipt ga-agakwa Asịrịa, ndị Ijipt na ndị Asịrịa ga-eso fee ofufe.
\v 24 Nʼụbọchị ahụ ka Izrel ga-abụ nke atọ imezu Ijipt na Asịrịa, bụrụ ngọzị nʼụwa.
\v 25 \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile ga-agọzi ha, na-asị, “Ka ngọzị dịrị Ijipt, ndị m, dịrị Asịrịa nke bụ akaọrụ m, na Izrel ihe nketa nke m.”
\c 20
\s1 Amụma e bụrụ banyere Ijipt na Kush
\p 
\v 1 Nʼafọ ahụ, Sagọn, eze Asịrịa, zipụrụ ọchịagha onye ọkwa ya kasị ukwuu, ka ọ gaa buso Ashdọd agha. Ọ gara meriekwa ya nʼagha.
\v 2 Nʼoge ahụ \nd Onyenwe anyị\nd* kwuru okwu site nʼọnụ Aịzaya nwa Emọz. Ọ sịrị ya, “Yipụ uwe mkpe iyi nʼahụ, ya na akpụkpọụkwụ dị gị nʼụkwụ.” O mere otu a, ọ gbaara ọtọ, jegharịakwa nʼụkwụ efu.
\p 
\v 3 Mgbe ahụ, \nd Onyenwe anyị\nd* sịrị, “Dị ka ohu m Aịzaya si gbara ọtọ jegharịa nʼụkwụ efu afọ atọ ndị a niile, ọ bụ ihe ama na ihe ịdọ aka na ntị na-egosi ihe gaje ịbịakwasị ndị Ijipt na ndị Kush.\f + \fr 20:3 \ft Nke a bụ mgbago Naịl\f*
\v 4 Nʼihi na otu a ka eze Asịrịa ga-esi kpụrụ ndị Ijipt na ndị Kush ọ dọtara nʼagha. Ha ga-agba ọtọ na-ejegharị nʼụkwụ efu, ma nwantakịrị ma okenye. Otule ha gba ọtọ ga-abụrụ Ijipt ihe ihere.
\v 5 Egwu ga-ejide ndị ahụ niile nwere nchekwube nʼike Kush, na ndị ahụ niile jiri Ijipt nyaa isi ga-ada mba. Ihere ga-emekwa ha.\f + \fr 20:5 \ft \xt Aịz 30:3-5; 31:1; Izk 29:6-7\xt*\f*
\v 6 Nʼụbọchị ahụ, ndị ahụ dịnyeere ha, bụ ndị bi nʼọnụ mmiri ha ga-asị, ‘Ọ bụrụ na ihe dị otu a dakwasịrị ndị Ijipt anyị tụkwasịrị obi inyere anyị aka, na ịnapụta anyị site nʼaka eze Asịrịa, ebeekwanụ ka anyị ga-agbaga?’ ”
\c 21
\s1 Amụma e buru banyere Babilọn
\p 
\v 1 Amụma megide ọzara nke dị nʼakụkụ oke osimiri:
\q1 Dịka oke ifufe si nʼọzara Negeb na-efebiga,
\q2 ka onye na-eme ihe ike ga-esi nʼọzara bịa,
\q2 site nʼala nke oke egwu.
\b
\q1 
\v 2 Ahụrụ m ọhụ dị egwu, ọhụ oke mbibi,
\q2 na ọhụ oke nrara nye nʼaka ndị mbibi, nʼebe onye na-apụnara mmadụ ihe nʼike na-akwakọta ngwongwo.
\q1 Bilienụ unu ndị agha Elam, buonu agha! Unu ndị agha Midia, gbaanụ obodo gburugburu!
\q2 Aga m eme ka ịsụ ude na mmegbu niile kwụsị.
\b
\q1 
\v 3 Nʼihi nke a, ahụ m niile nọ nʼoke ihe mgbu,
\q2 oke ihe mgbu\f + \fr 21:3 \ft Ya bụ, ahụ ụfụ\f* zuru m ahụ, dịka ihe mgbu nke nwanyị ime na-eme.
\q1 Amara m jijiji nʼihi ihe m nụrụ,
\q2 ihe m na-ahụ na-agbagwoju m anya.
\q1 
\v 4 Obi m anọkwaghị jụụ,
\q2 oke ọma jijiji na-eme ka m tụọ egwu;
\q1 chi ojiji nke m na-ele anya ya
\q2 aghọọlara m ihe ịma jijiji.
\b
\q1 
\v 5 Ha na-akwado tebul.
\q2 Ha na-edozi ute ịnọdụ ala,
\q2 ha na-eri, ha na-aṅụ.
\q1 Bilienụ ndịisi agha,
\q2 teekwanụ ọta niile mmanụ!
\p 
\v 6 Ihe a ka Onyenwe anyị gwara m,
\q1 “Gaa, guzobe onye nche,
\q2 ka o kwuo ihe ọ na-ahụ.
\q1 
\v 7 Mgbe ọ hụrụ ụgbọ agha,
\q2 na usuu ịnyịnya,
\q1 na ndị na-agba ịnyịnya ibu,
\q2 maọbụ ndị na-agba ịnyịnya kamel ka ha na-abịa abụọ abụọ,
\q1 gwa ya ka o lezie ha anya nke ọma,
\q2 nọọkwa na njikere.”
\p 
\v 8 Onye nche na-elepụ anya tiri mkpu dịka ọdụm, sị,
\q1 “Onyenwe m, nʼehihie ụbọchị niile ka m na-eguzo nʼelu ụlọ nche,
\q2 nʼọnọdụ nche m ka m na-eguzokwa abalị niile.
\q1 
\v 9 Lee, otu nwoke nọ nʼime ụgbọ agha na-abịa,
\q2 ya na ndị nọ nʼelu ịnyịnya na-abịa abụọ abụọ.
\q1 O nyeghachiri ọsịsa ahụ,
\q2 ‘Babilọn adaala, e ọ daala,
\q1 arụsị niile apịrị apị nke chi ya niile
\q2 a kurisiela tọgbọrọ nʼala.’ ”
\b
\q1 
\v 10 O, ndị m, ndị a zọchara azọcha, dịka ọka a zọchara nʼebe ịzọcha ọka,
\q2 agwala m unu ihe
\q1 \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile
\q2 bụ Chineke Izrel kwuru.
\s1 Amụma banyere Edọm
\p 
\v 11 Nke a bụ amụma megide Duma:
\q1 Otu onye si na Sia na-akpọ m oku,
\q2 “Onye nche, gịnị ka ọ fọdụrụ tupu chi abọọ?
\q2 Onye nche, gịnị ka ọ fọdụrụ tupu chi abọọ?”
\q1 
\v 12 Onye nche zara sị,
\q2 “Chi ọbụbọ na-abịa, abalị na-abịakwa.
\q1 Ọ bụrụ na ị chọrọ ịjụ ajụjụ, jụọnụ ajụjụ,
\q2 ma laghachikwa ọzọ.”
\s1 Amụma e buru banyere Arebịa
\p 
\v 13 Amụma megide Arebịa:
\q1 Unu ndị ije niile nke Dedan,
\q2 ndị na-anọ ọnọdụ abalị nʼoke ọhịa nke Arebịa,
\q2 
\v 14 kuterenụ ndị ahụ bịakwutere unu akpịrị na-akpọ nkụ mmiri ọṅụṅụ;
\q1 unu ndị bi nʼala Tema,
\q2 buterenụ ndị gbakwutere unu ọsọ ndụ nri.
\q1 
\v 15 Nʼihi na ọ bụ site nʼagha
\q2 nke e ji mma agha egbu ndị mmadụ,
\q1 na agha e ji akụ agbatu mmadụ
\q2 ka ha si na-agbapụ ọsọ.
\p 
\v 16 Nke a bụ ihe Onyenwe anyị sịrị m, “Tupu otu afọ agwụ, dị ka esi agụ afọ onye ohu e goro ọrụ, ịma mma Keda ga-agwụsị.
\v 17 Ndị fọdụrụ ndụ nʼime ndị na-agba ụta, ndị bụ dike nʼagha na Keda, ga-adị mmadụ ole na ole.” \nd Onyenwe anyị\nd*, bụ Chineke Izrel ekwuola ya.
\c 22
\s1 Amụma e buru banyere Jerusalem
\p 
\v 1 Amụma megide ndagwurugwu nke ọhụ.
\q1 Ọ bụkwa gịnị na-eme unu ugbu a
\q2 nke mere na unu niile rịgooro nʼelu ụlọ?
\q1 
\v 2 Gị obodo jupụtara nʼoke ọgbaaghara,
\q2 gị obodo oke ụzụ na-aṅụrị obi ụtọ?
\q1 Ndị unu niile nwụrụ anwụghị nʼime ọgbọ agha,
\q2 ma ọ bụkwanụ site na mma agha.
\q1 
\v 3 Ndịisi unu niile agbapụchaala.\f + \fr 22:3 \ft Maọbụ, \fqa agbaala ọsọ\f*
\q2 E jidechara ha niile na-enweghị àkụ ọbụla a gbapụrụ.
\q1 Unu niile e jidere ka a dọkpụụrụ nʼotu dịka ndị mkpọrọ
\q2 bụ ndị ahụ gbapụrụ ọsọ mgbe ndị iro ka nọrịị ebe dị anya.
\q1 
\v 4 Nʼihi nke a, asịrị m, “Lepụnụ m anya ka m nọọrọ onwe m;
\q2 ka m bee akwa dị ilu.
\q1 Unu anwakwala ịkasị m obi,
\q2 nʼihi mbibi e bibiri ndị m.”
\b
\q1 
\v 5 Onyenwe anyị, bụ \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, nwee otu ụbọchị
\q2 ụbọchị ọgbaaghara na nzọda na ihe nke ịgba mmadụ gharịị,
\q2 nʼime ndagwurugwu nke ọhụ,
\q1 ọ bụ ụbọchị itida mgbidi
\q2 na nke itiku ugwu niile mkpu akwa.
\q1 
\v 6 Elam bu akpa àkụ,
\q2 ya na ndị nọkwasịrị nʼelu ụgbọala na ịnyịnya ha;
\q2 Kia ewepụtakwala ọta.
\q1 
\v 7 Ụgbọala jupụtara na ndagwurugwu unu niile mara mma;
\q2 ndị na-agba ịnyịnya anọchisiela ọnụ ụzọ niile e si abanye nʼobodo unu.
\b
\q1 
\v 8 Onyenwe anyị wezugara ihe nchedo niile nke Juda,
\q2 nʼụbọchị ahụ unu legidere anya
\q2 na ngwa agha dị nʼỤlọeze dị nʼOke ọhịa.
\q1 
\v 9 Unu hụrụ na mgbidi obodo Devid
\q2 nwere ọtụtụ mgbawa nʼebe dị iche iche na ya.
\q1 Unu chekọtara mmiri
\q2 nʼọdọ mmiri nke ala ala.
\q1 
\v 10 Unu gụrụ ụlọ dị na Jerusalem ọnụ,
\q2 tiwaa ụfọdụ ụlọ iji mee ka mgbidi sie ike.
\q1 
\v 11 Unu gwuru ọdọ mmiri nʼetiti mgbidi abụọ
\q2 maka ichekwa mmiri si nʼọdọ mmiri ochie,
\q1 ma unu elekwasịghị Onye ahụ kere ya anya,
\q2 unu ejikwaghị Onye ahụ tụrụ atụmatụ ya site na mgbe gara aga kpọrọ ihe.
\b
\q1 
\v 12 Onyenwe anyị, \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile,
\q2 kpọrọ unu ụbọchị ahụ
\q1 ka unu kwaa akwa, ruo ụjụ,
\q2 kpụchaa agịrị isi unu ma yirikwa akwa mkpe.
\q1 
\v 13 Ma lee, e nwere obi ụtọ, na-egwuri egwu;
\q2 igbu ehi na igbu atụrụ,
\q2 iri anụ nakwa ịṅụ mmanya.
\q1 Unu na-asị, “Ka anyị rienụ, ṅụọkwanụ,
\q2 nʼihi na echi ka anyị ga-anwụ.”
\p 
\v 14 \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, ekpugheerala m mee ka m nụrụ, “Nʼezie, agaghị ekpuchiri unu mmehie a ruo ụbọchị unu ga-anwụ.” Ọ bụ ihe Onyenwe anyị, bụ \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwuru.
\p 
\v 15 Otu a ka Onyenwe anyị, bụ \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, kwuru:
\q1 “Gaa, gwa odozi akụ a bụ Shebna,
\q2 nke bụ onye na-elekọta ụlọ ukwu eze:
\q1 
\v 16 Gịnị ka ị na-eme nʼebe a, onye nyekwara gị ikike
\q2 na i gwuwaara onwe gị ili nʼebe a,
\q1 na-egwuwakwa ili gị nʼebe dị elu
\q2 na-akapụtara onwe gị ebe izuike nʼime nkume ahụ?
\b
\q1 
\v 17 “Kpachara anya, \nd Onyenwe anyị\nd* na-aga ịkpata gị aka,
\q2 tufuo gị nʼebe dị anya, gị dike na nwoke.
\q1 
\v 18 Ọ ga-afịkọta gị okirikiri dịka bọlụ,
\q2 tufuo gị nʼobodo sara mbara.
\q1 Nʼebe ahụ ka ị ga-anọ nwụọ,
\q2 nʼebe ahụ kwa ka ụgbọala gị nke i ji anya isi
\q2 ga-aghọ ihe ihere nye ezinaụlọ onyenwe gị.
\q1 
\v 19 Onyenwe anyị ga-achụpụkwa gị site nʼọkwa gị,
\q2 na sitekwa nʼọnọdụ gị dị elu, dọda gị nʼala.
\p 
\v 20 “Nʼụbọchị ahụ, aga m akpọ ohu m, Eliakịm, nwa Hilkaya.
\v 21 Aga m eyikwasị ya uwe ọrụ gị, kekwasịkwa ya ihe ike nʼukwu, werekwa ike ọchịchị ahụ i nwere na mbụ nyefee ya. Ọ ga-abụkwara ndị Jerusalem na ndị Juda nna.
\v 22 Aga m enyefekwa ya nʼaka ihe ntụghe ụzọ nke ụlọ Devid. A ga-emeghe ihe niile ọ sị na a ga-emeghe, mechiekwa ihe niile ọ sị na a ga-emechi,
\v 23 Aga m eme ka o guzosie ike dịka ǹtu a kpọgidere nʼaja ụlọ. Ocheeze ya ga-ewetara ụlọ nna ya nsọpụrụ.
\v 24 A ga-ekokwasị ya ebube nke ezinaụlọ ya, ụmụ ya na ụmụ ụmụ ya, ihe niile nke dị nta, site na ite na efere, sitekwa nʼọba ruo na karama niile.
\p 
\v 25 “Nʼụbọchị ahụ,” ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwubiri, “Nʼoge ahụ, ǹtu ahụ a kpọgidesịrị ike nʼaja ụlọ ga-apụ nʼọnọdụ ya, a ga-akpajipụ ya ọ dapụ nʼala. Ibu niile nke kokwasịrị nʼelu ya ka a ga-egbuda nʼala.” Nʼihi na \nd Onyenwe anyị\nd* ekwuola ya.
\c 23
\s1 Amụma e buru banyere Taịa
\p 
\v 1 Nke a bụ amụma megide Taịa:
\q1 Tienụ mkpu akwa, unu ụgbọ mmiri nke Tashish
\q2 nʼihi na e bibiela Taịa,
\q2 ahapụla ya na-enweghị ụlọ ọbụla maọbụ ọnụ mmiri mbata.
\q1 Ozi erutela ha aka
\q2 site nʼobodo Saiprọs.
\b
\q1 
\v 2 Derenụ duu, unu ndị bi nʼala ahụ osimiri gbara gburugburu.
\q2 Unu ndị na-azụ ahịa na Saịdọn,
\q2 ndị na-ezipụ ụgbọ mmiri na-aga nʼosimiri, kwaanụ akwa.
\q1 
\v 3 Nʼelu ọtụtụ mmiri dị ukwuu,
\q2 ka mkpụrụ ọkụkụ Shihoa si bịa,
\q1 owuwe ihe ubi nke Naịl bụ ihe uru ahịa Taịa,
\q2 ọ ghọrọ ọma ahịa nke mba dị iche iche.
\b
\q1 
\v 4 Ka ihere mee gị, Saịdọn, na gị bụ ebe e wusiri ike nke osimiri,
\q2 nʼihi na oke osimiri ekwuola okwu;
\q1 “Ime emetụbeghị m, nke m ji amụpụta nwa;
\q2 o nwebeghị mgbe m ji zụpụta ụmụ ndị ikom maọbụ ụmụ ndị inyom tozuru oke.”
\q1 
\v 5 Mgbe ozi ga-abịara ndị Ijipt,
\q2 ha ga-anọ na mwute nʼihi ozi si Taịa.
\b
\q1 
\v 6 Gabiganụ ruo Tashish
\q2 tisienụ mkpu akwa ike, unu ndị bi nʼala mmiri gbara gburugburu.
\q1 
\v 7 Nke a ọ bụ obodo ahụ ọṅụ na-ejupụta nʼime ya oge niile?
\q2 Obodo ahụ dịrịla kemgbe oge gara aga?
\q1 Nke a ọ bụ ihe fọdụrụ nʼobodo ahụ
\q2 ndị ya na-esi nʼime ya pụọ gaa nʼebe dị anya iwu obodo ọzọ?
\q1 
\v 8 Onye zubere ihe dị otu a megide Taịa,
\q2 bụ mba na-ekpube ndị ọzọ okpueze,
\q1 mba nke ndị ahịa ya bụ ụmụ eze,
\q2 nke ndị ọzụ ahịa ya bụ ndị a na-asọpụrụ nʼụwa?
\q1 
\v 9 Ọ bụ \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile zubere ya,
\q2 nʼihi iweda nʼala mpako na ịma mma ya niile,
\q2 na iwetara ndị niile a na-asọpụrụ nʼụwa nlelị.
\b
\q1 
\v 10 Gaanụ kọọ ala ubi unu dịka ha na-eme nʼakụkụ Naịl,
\q2 unu ụmụada Tashish,
\q2 nʼihi na unu enwekwaghị ọnụ mmiri.
\q1 
\v 11 \nd Onyenwe anyị\nd* esetipụla aka ya nʼelu osimiri
\q2 mee ka alaeze ha niile maa jijiji.
\q1 O nyela iwu banyere Fonisia\f + \fr 23:11 \ft Ya bụ, Kenan\f*
\q2 ka e bibie ebe ya niile nke wusiri ike.
\q1 
\v 12 Ọ sịrị, “Ị gaghị aṅụrị ọṅụ ịṅụ mmanya nʼoke oriri ọzọ,
\q2 gị ada Saịdọn na-amaghị nwoke, nke a na-emegbu emegbu.
\b
\q1 “Bilie, gafee garuo Saiprọs,
\q2 ọ bụladị nʼebe ahụ, ị gaghị enweta ezumike.”
\q1 
\v 13 Lee anya nʼala ndị Kaldịa,
\q2 ndị a gụpụrụla ugbu a na mmadụ!
\q1 Ndị Asịrịa mere ya
\q2 ka ọ bụrụ ebe obibi nye anụ ọhịa na-ebi nʼọzara.
\q1 Ha wuliri ụlọ nche ha niile dị elu gburugburu
\q2 tikpọọ ebe ya niile e wusiri ike,
\q2 mee ha ka ha tọgbọrọ nʼefu ghọọ mkpọmkpọ ebe.
\b
\q1 
\v 14 Tienụ mkpu akwa, unu ụgbọ mmiri Tashish niile dị nʼoke osimiri,
\q2 nʼihi na e mebiela ebe unu niile e wusiri ike.
\p 
\v 15 A gaghị echeta Taịa ọzọ, tutu iri afọ asaa agafee, nke bụ ogologo ụbọchị ndụ onye eze. Mgbe oge ahụ zuru, Taịa ga-adịkwa ka nwanyị akwụna e jiri rọọ abụ dị otu a:
\q1 
\v 16 “Welite ụbọ akwara, jegharịa nʼime obodo,
\q2 gị nwanyị akwụna e chefuru echefu;
\q1 kpọzie ụbọ gị nke ọma, bụọ ọtụtụ abụ,
\q2 ka e si otu a mee ka ị bụrụ onye e chetara echeta.”
\p 
\v 17 E, mgbe iri afọ asaa gasịrị, \nd Onyenwe anyị\nd* ga-eleta Taịa. Ọ ga-alaghachi nʼọrụ ya dịka nwanyị akwụna, ya na alaeze niile dị nʼihu elu ụwa niile.
\v 18 Ma uru ahịa ya niile, na ego niile ọ kpatara site nʼịzụ ahịa ka ọ ga-edo nsọ nye \nd Onyenwe anyị\nd*. Ha agaghị edokọkwa ha nʼotu ebe izo ha, kama uru ahịa ha niile ga-adịrị ndị niile na-ebi ezi ndụ nʼihu \nd Onyenwe anyị\nd*. Ha ga-ejikwa ego ahụ zụọ ihe oriri na uwe dị mma.
\c 24
\s1 Mbibi \nd Onyenwe anyị\nd* ga-ebibi ụwa
\q1 
\v 1 Lee, na \nd Onyenwe anyị\nd* na-aga ịgba ụwa ọtọ.
\q2 Ọ na-aga ime ka ọ tọgbọrọ nʼefu.
\q1 Ọ na-aga ibibicha ihe dị nʼelu ụwa,
\q2 mee ka ndị bi nʼime ya gbasasịa.
\q1 
\v 2 Otu ihe ahụ ka ọ ga-eme mmadụ niile,
\q2 nye ndị nchụaja ma ndị mmadụ,
\q2 nye ụmụodibo na ndị nwe ha,
\q2 nye ndị odibo nwanyị, na nne ha ukwu,
\q2 nye ndị na-azụ ihe a na-ere ere, na ndị na-ere ihe orire;
\q2 nye ndị na-ebinye ego, na ndị a na-ebinye ego;
\q2 nye ndị ji ụgwọ, na ndị e ji ụgwọ.
\q1 
\v 3 O nweghị onye ọ ga-ahapụ.
\q2 A ga-agba ala ahụ ọtọ kwakọrọ ihe niile dị nʼime ya.
\q1 Nke a ka \nd Onyenwe anyị\nd* kwuru.
\b
\q1 
\v 4 Ala atakọchaala, ma kpọnwụọ.
\q2 Ụwa ahụjuola anya ma kpọnwụọ.
\q2 Eluigwe na nʼụwa so na-ahụjukwa anya.
\q1 
\v 5 Ụwa bụ ihe e merụrụ emerụ site na ndị ya;
\q2 ha enupula isi nʼiwu niile,
\q1 ha agbanweela ụkpụrụ ya,
\q2 mebie ọgbụgba ndụ ebighị ebi ahụ.
\q1 
\v 6 Ya mere, ọbụbụ ọnụ na-eripịa ụwa;
\q2 ndị bi nʼime ya aghaghị ịnatakwa ikpe ọmụma ha.
\q1 Ya mere ndị niile bi nʼụwa na-ere ọkụ,
\q2 ọ bụkwa naanị mmadụ ole na ole fọdụrụ.
\q1 
\v 7 Mmanya ọhụrụ atakọrọla, osisi vaịnị akpọnwụọkwala,
\q2 nʼihi ya, ndị ahụ niile ọṅụ na-ejupụta nʼobi ha na-asụ ude.
\q1 
\v 8 Egwu ụtọ niile akwụsịla,
\q2 mkpọtụ nke ndị na-eri oriri dị iche iche akwụsịla.
\q2 Ụda obi ụtọ nke ụbọ akwara adịghịkwa.
\q1 
\v 9 Abụ obi ụtọ nke ya na mmanya na-eso adịghịkwa;
\q2 mmanya dị ike na-akụzi ilu nʼọnụ ndị na-aṅụ ya.
\q1 
\v 10 Obodo atọgbọrọla nʼefu;
\q2 a kpọchichaala ọnụ ụzọ e si abata ụlọ ndị mmadụ ka onye ọbụla ghara inwe ike ịbata.
\q1 
\v 11 Igwe ndị mmadụ nọ nʼokporoụzọ na-eti mkpu nʼihi na mmanya adịghịkwa.
\q2 Ọṅụ adịghịkwa,
\q2 otu a, ewezugakwala obi ụtọ site nʼụwa.
\q1 
\v 12 Obodo ahụ aghọọla mkpọmkpọ ebe,
\q2 e tikpọọla ọnụ ụzọ ya niile.
\q1 
\v 13 Otu a ka ọ ga-adị nʼụwa niile,
\q2 nakwa nʼetiti mba niile,
\q1 dịka mgbe a na-etitusi mkpụrụ dị nʼelu osisi oliv,
\q2 maọbụ mgbe ahapụrụ ụfọdụ mkpụrụ grepu nʼelu osisi mgbe a ghọchasịrị ihe ubi.
\b
\q1 
\v 14 Ma ndị niile fọdụrụ ga-eti mkpu ọṅụ;
\q2 ndị nọ nʼọdịda anyanwụ ga-eto ịdị ebube nke \nd Onyenwe anyị\nd*.
\q1 
\v 15 Ndị nọ nʼọwụwa anyanwụ ga-enye \nd Onyenwe anyị\nd* otuto.
\q2 Ndị bi nʼala nta niile osimiri gbara gburugburu
\q2 ga-ebuli aha \nd Onyenwe anyị\nd*, Chineke Izrel elu.
\q1 
\v 16 Anyị ga-anụ abụ ọma dị iche iche site na nsọtụ ụwa.
\q2 Ha ga-abụ abụ na-asị, “Otuto dịrị Onye ezi omume ahụ.”
\b
\q1 Ma nʼezie, o nweghị olileanya dịịrị m. “Lee ka anụ ahụ m si na-akpọnwụ!
\q2 Ahụhụ dịrị m!
\q1 Nʼihi na ndị ahụ na-ekwesighị ntụkwasị obi ereela anyị.
\q2 Akpịrị ego ha ka ha ji refuo anyị.”
\q1 
\v 17 Ihe egwu, na olulu, na igbudu nke onye na-esi ọnya dị na-eche unu,
\q2 unu ndị niile bi nʼụwa.
\q1 
\v 18 Onye ọbụla nʼime unu nke gbara ọsọ nʼihi ihe egwu
\q2 ga-adaba nʼolulu;
\q1 onye ọbụla sitekwara nʼolulu rịpụta
\q2 ga-azọnye ụkwụ ya nʼọnya.
\b
\q1 Nʼihi na mmiri nke ịla nʼiyi esitela na mbara eluigwe na-ezokwasị unu.
\q2 Ntọala ụwa na-amakwa jijiji.
\q1 
\v 19 Ụwa adapịasịala;
\q2 ụwa agbawasịala;
\q2 e jirila oke ike nugharịa ụwa.
\q1 
\v 20 Ụwa ga-adagbugharị dịka onye mmanya na-egbu.
\q2 Ọ ga-aṅagharịkwa dịka osisi nke oke ifufe na-efegharị.
\q1 Ọ daala, ọ pụghịkwa ibili ọzọ,
\q2 nʼihi na njehie ya dị arọ na-anyịdakwa ya.
\b
\q1 
\v 21 Nʼụbọchị ahụ,
\q2 \nd Onyenwe anyị\nd* ga-ata ike usuu niile dị nʼeluigwe ahụhụ.
\q2 Ọ ga-atakwa ndị eze niile nʼụwa ahụhụ.
\q1 
\v 22 A ga-achịkọta ha dịka ndị mkpọrọ,
\q2 kpọchiekwa ha nʼụlọ mkpọrọ
\q1 nʼebe ahụ ka ha ga-anọgide,
\q2 tutu ruo mgbe a ga-ekpe ha ikpe.
\q1 
\v 23 Ọnwa ga-ada mba,
\q2 anwụ ka ihere ga-eme;
\q1 nʼihi na \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, ga-achị
\q2 nʼugwu Zayọn nakwa nʼime Jerusalem,
\q2 ọ ga-eji oke ebube chịa nʼihu ndị okenye ya.
\c 25
\s1 Toonu \nd Onyenwe anyị\nd*
\q1 
\v 1 O \nd Onyenwe anyị\nd*, ị bụ Chineke m;
\q2 aga m ebuli gị elu, nye aha gị otuto,
\q1 nʼihi na site na ntụkwasị obi zuruoke,
\q2 ị rụọla ọtụtụ ihe ịrịbama,
\q2 nke i tụrụ atụmatụ ha siterị nʼoge gara aga.
\q1 
\v 2 Nʼihi na i meela ka obodo ghọọ mkpọmkpọ ebe;
\q2 mee ka obodo e wusiri ike ghọọ ebe dakpọrọ adakpọ;
\q1 meekwa ka ebe siri ike nke ndị mba ọzọ ghọọ ebe obodo na-adịghịzi,
\q2 agaghị ewukwa ya ruo mgbe ebighị ebi.
\q1 
\v 3 Nʼihi nke a, ndị niile dị ike ga-asọpụrụ gị.
\q2 Obodo ndị ahụ na-emenye ndị mba ọzọ egwu ga-atụ gị egwu.
\q1 
\v 4 Nʼihi na ị bụụrụ onye na-enweghị ike ebe mgbaba;
\q2 ị bụkwaara ndị ogbenye ebe mgbaba nʼoge mkpa ha,
\q1 ebe nchebe siri ike nʼoge oke mmiri ozuzo,
\q2 na ndo nʼoge okpomọkụ.
\q1 Nʼihi na nkuume nke ndị na-adịghị emere mmadụ ebere
\q2 dị ka oke mmiri ozuzo nke na-amakwasị mgbidi,
\q2 
\v 5 dịkwa ka okpomọkụ nke na-adị nʼọzara.
\q1 Ị na-eme ka mkpọtụ nke ndị mba ọzọ kwụsị,
\q2 dịka ndo nke igwe ojii na-eweta si eme ka okpomọkụ dajụọ,
\q2 otu a ka abụ ọma nke ndị na-adịghị eme ebere si kwụsị.
\b
\q1 
\v 6 Nʼelu ugwu a, ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile
\q2 ga-anọ kwadooro ụwa niile oke oriri.
\q1 Ọ ga-abụ oke oriri nke ga-adịrị ndị niile.
\q2 Oke oriri nke ezi anụ na mmanya dị mma ga-adị.
\q1 
\v 7 Nʼelu ugwu a, ka ọ ga-ewepụ ihe ndị ahụ niile na-eweta ihu mgbarụ,
\q2 nke dị ka akwa e ji kpuchie mmadụ niile,
\q1 nke kpuchikwara ihu ndị mba niile.
\q2 
\v 8 Ọ ga-elomi ọnwụ ruo mgbe ebighị ebi.
\q1 Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* ga-ehicha anya mmiri niile
\q2 site nʼihu mmadụ niile,
\q1 ọ ga-ewezuga ihe ịta ụta\f + \fr 25:8 \ft Maọbụ, \fqa Ihe ihere\f* niile
\q2 dakwasịrị ndị ya site nʼụwa niile.
\q1 \nd Onyenwe anyị\nd* ekwuola ya.
\p 
\v 9 Nʼụbọchị ahụ, ndị mmadụ ga-asị,
\q1 “Nke a bụ Chineke anyị nʼezie,
\q2 anyị tụkwasịrị ya obi, ọ zọpụtakwara anyị.
\q1 Nke a bụ \nd Onyenwe anyị\nd* ahụ, anyị tụkwasịrị ya obi,
\q2 ka anyị nwee ọṅụ ma ṅụrịakwa na nzọpụta ya.”
\b
\q1 
\v 10 Nʼihi na aka \nd Onyenwe anyị\nd* ga-adịgide nʼelu ugwu a,
\q2 ma a ga-azọtọ ndị Moab nʼọnọdụ ha,
\q2 dịka esi azọda ahịhịa dị nʼokpuru ụkwụ mmadụ.
\q1 
\v 11 Ha ga-agbasa aka ha abụọ nʼime ya,
\q2 dịka onye na-egwu mmiri si agbasapụ aka ya,
\q1 ma Chineke ga-eweda mpako ha niile,
\q2 nʼagbanyeghị ọrụ aghụghọ niile nke aka ha.
\q1 
\v 12 Ọ ga-akwatu mgbidi gị niile dị elu nke e wusiri ike,
\q2 mee ka ha daruo ala,
\q1 ọ ga-eme ka ha daruo ala,
\q2 ruo mgbe ha ghọrọ uzuzu.
\c 26
\s1 Abụ Otuto
\p 
\v 1 Nʼụbọchị ahụ, a ga-abụ abụ a nʼala Juda niile:
\q1 Anyị nwere obodo e wusiri ike.
\q2 Chineke na-eme ka mgbidi ya
\q2 na ebe ya niile e wusiri ike bụrụ nzọpụta nye anyị.
\q1 
\v 2 Meghee ụzọ ama niile,
\q2 ka mba ndị ahụ na-eme ezi omume bata,
\q2 e, bụ mba ahụ kwesiri ntụkwasị obi.
\q1 
\v 3 Ị na-eme ka ndị niile echiche uche ha guzosiri ike
\q2 nwee udo zuruoke,
\q2 nʼihi na ọ bụ na gị ka ha na-atụkwasị obi ha.
\q1 
\v 4 Tụkwasị \nd Onyenwe anyị\nd* Chineke obi mgbe niile,
\q2 nʼihi na \nd Onyenwe anyị\nd* Chineke bụ oke nkume nke mgbe ebighị ebi.
\q1 
\v 5 Ndị na-akpa nganga ka ọ na-ewedata ala,
\q2 na-emekwa ka obodo na-anya isi kpọọ ọnụ nʼala.
\q1 Mgbidi ya
\q2 ka ọ na-eme ka ọ daruo ala.
\q1 
\v 6 Ọ na-enyefe obodo ahụ
\q2 nʼaka ndị a na-emegbu emegbu,
\q2 na nʼaka ndị ogbenye ka ha zọtọọ ya ụkwụ.
\b
\q1 
\v 7 Ụzọ nke onye ezi omume ha nʼotu,
\q2 gị, Onye ziri ezi, na-eme ka okporoụzọ ndị ezi omume dị larịị.
\q1 
\v 8 E, \nd Onyenwe anyị\nd*, anyị na-aga nʼụzọ nke ikpe gị niile,
\q2 na-ele anya gị.
\q1 Aha gị na ihe niile e ji mara gị
\q2 bụ ihe na-agụsị obi anyị agụ ike.
\q1 
\v 9 Abalị niile ka obi m na-achọsi gị ike,
\q2 nʼụtụtụ eji m mmụọ m niile na-achọsi gị ike,
\q1 nʼihi na ọ bụ naanị mgbe ị bịara kpee ụwa ikpe
\q2 ka mmadụ ga-esi nʼajọ omume tụgharịa ime ezi ihe.
\q1 
\v 10 Obi ebere gị nʼebe ndị na-emebi iwu nọ
\q2 adịghị eme ka ha gbanwee.
\q1 Ọ bụladị nʼala a, ebe ndị ezi omume bi, ha na-anọgide na-eme ihe ọjọọ.
\q2 Ha adịghị echeta ịdị ukwuu gị, \nd Onyenwe anyị\nd*.
\q1 
\v 11 \nd Onyenwe anyị\nd* ebuliela aka ya elu,
\q2 ha adịghị ahụ ya.
\q1 Gosi ha ekworo gị banyere ndị gị, ka e si otu a mee ka ihere mee ha.
\q2 E, ka ọkụ ahụ ị kwadooro ndị iro gị rechapụ ha.
\b
\q1 
\v 12 \nd Onyenwe anyị\nd*, ị na-enye anyị udo;
\q2 nʼihi na ihe niile anyị nwere sitere nʼaka gị.
\q1 
\v 13 O, \nd Onyenwe anyị\nd* Chineke anyị, ọ dị mgbe anyị nọ nʼokpuru ọchịchị ndị ọzọ dị iche iche,
\q2 ma ugbu a, ọ bụ naanị aha gị ka anyị na-efe.
\q1 
\v 14 Ndị niile anyị fere na mbụ anwụchaala; ha adịghịkwa ndụ;
\q2 mmụọ ha agakwaghị alọghachi ọzọ.
\q1 Nʼihi na ị tara ha ahụhụ, laa ha nʼiyi;
\q2 e chefukwaala ha.
\q1 
\v 15 I meela ka mba a dị ukwuu, \nd Onyenwe anyị\nd*;
\q2 i meela ka mba a saa mbara.
\q1 I wetarala onwe gị nsọpụrụ,
\q2 i meela ka oke ala ahụ niile gbatịa.
\b
\q1 
\v 16 \nd Onyenwe anyị\nd*, nʼime mkpagbu ha, ha gbakwutere gị.
\q2 Mgbe iwe gị bịakwasịrị ha,
\q2 ọ bụ olu dị nta ka ha ji kpeere gị ekpere.
\q1 
\v 17 Gị, \nd Onyenwe anyị\nd*, emeela ka anyị kwaa akwa,
\q2 dị ka nwanyị ime na-eme si ata ikikere eze na akwa akwa nʼihi ihe mgbu.
\q2 Otu a ka anyị nọ nʼihu gị.
\q1 
\v 18 Anyị anọọla ọnọdụ ihe mgbu, na ịta ikikere eze,
\q2 ma o nweghị ihe ọma anyị nwetara nʼime ya.
\q1 Mgbalị anyị niile emeghị ka nzọpụta rute ụwa aka.
\q2 O nwekwaghị ihe nwere isi anyị rụpụtara.
\b
\q1 
\v 19 Ma ndị gị niile nwụrụ anwụ ga-adị ndụ, O \nd Onyenwe anyị\nd*.
\q2 Ozu ha ga-esite nʼọnwụ bilie.
\q1 Unu ndị niile bi nʼaja
\q2 tetanụ ma tie mkpu ọṅụ.
\q1 Nʼihi na igirigi gị dị ka igirigi nke ụtụtụ,
\q2 ala ga-amụpụtakwa ndị ya niile nwụrụ anwụ.
\b
\q1 
\v 20 Baanụ nʼụlọ, ndị m,
\q2 kpọchienụ ụzọ unu!
\q1 Zoonụ onwe unu naanị nwa oge nta,
\q2 tutu ruo mgbe iwe Chineke ga-agabiga.
\q1 
\v 21 Lee anya! \nd Onyenwe anyị\nd* si nʼebe obibi ya
\q2 na-abịa ikpe ndị bi nʼụwa ikpe nʼihi mmehie ha niile.
\q1 Ụwa ga-ekpughepụ gosi ọbara niile a wụsiri nʼelu ya,
\q2 ọ gaghị ezokwa ndị niile e gburu lie nʼime ya.
\c 27
\s1 Mgbapụta dịrị Izrel
\p 
\v 1 Nʼụbọchị ahụ,
\q1 \nd Onyenwe anyị\nd* ga-eji mma agha ya
\q2 iwe ya, dị ukwuu dịkwa ezigbo ike,
\q1 taa agwọ ahụ na-akpụ akpụ bụ Leviatan ahụhụ.
\q2 Leviatan bụ agwọ mgbakọ ahụ;
\q1 ọ ga-egbukwa nnukwu anụ ọjọọ ahụ nke bi na mmiri.
\p 
\v 2 Nʼụbọchị ahụ,
\q1 abụ a ga-adị nʼọnụ ha, abụ ha ga-abụ banyere ubi vaịnị nke na-amị ezi mkpụrụ.
\q2 
\v 3 “Mụ onwe m bụ \nd Onyenwe anyị\nd* na-elekọta ya,
\q2 ana m agba ya mmiri ụbọchị niile,
\q1 na-eche ya nche ehihie na abalị.
\q2 Ka onye ọbụla ghara iji ihe ọjọọ leta ya.
\q2 
\v 4 Adịghị m ewekwa iwe.
\q1 Ọ bụrụ na ọ bụ naanị ogwu na uke na-echere m aka mgba,
\q2 aga m ebili buso ha agha,
\q2 aga m esurekwa ha ọkụ.
\q1 
\v 5 Ma ọ bụghị otu a, ka ha bịakwute m maka nchekwa,
\q2 ha bịa ka mụ na ha mee udo.
\q2 E, ha bịa ka mụ na ha mee udo.”
\b
\q1 
\v 6 Nʼụbọchị ndị na-abịa, Jekọb ga-agba mgbọrọgwụ.
\q2 Izrel ga-agbawa okoko dịka osisi, maakwa ifuru,
\q2 jirikwa mkpụrụ mejupụta ụwa niile.
\b
\q1 
\v 7 \nd Onyenwe anyị\nd* atabeghị Izrel ahụhụ
\q2 dịka o si taa ndị iro ya.
\q1 O mebekwaghị ka e gbuo ndị ya
\q2 dị ka e si gbuo ndị iro ha.
\q1 
\v 8 \nd Onyenwe anyị\nd* tara ndị ya ahụhụ, mee ka a dọrọ ha nʼagha ma buru ha gaa mba ọzọ.
\q2 Ọ bụ ifufe ọjọọ nke si nʼọwụwa anyanwụ
\q2 ka o ji bupụ ha.
\q1 
\v 9 Ọ bụ nʼụzọ dị otu a ka a ga-esi bupụ ikpe ọmụma dịrị Jekọb,
\q2 nke a bụkwa iju eju nke mkpụrụ e ji wezuga mmehie ya:
\q1 Mgbe ha gweriri nkume niile ha ji wuo ebe ịchụ aja arụsị ha
\q2 dịka ntụ,
\q1 mgbe ha wezugara ogidi arụsị Ashera,
\q2 na ebe ịchụ aja ihe nsure ọkụ na-esi isi ụtọ niile.
\q1 
\v 10 Obodo ahụ e wusiri ike adakpọsịala.
\q2 Ọ ghọọla ọzara nke ndị mmadụ na-ebighị nʼime ya.
\q1 Ọ ghọọkwala ebe ụmụ ehi na-akpa nri,
\q2 ebe ha na-amakpu na-ezu ike.
\q2 Ha ga-atacha ahịhịa dị nʼalaka osisi.
\q1 
\v 11 Mgbe alaka osisi ndị ahụ kpọnwụrụ daa,
\q2 ụmụ nwanyị ga-abịa chịkọtaa ha were ha kwanye ọkụ.
\q1 Nʼihi na ndị a bụ ndị na-enweghị nghọta.
\q2 Ọ bụ nke a mere Onye kere ha adịghị emere ha ebere.
\q2 Onye ahụ kpụrụ ha agakwaghị egosi ha obi ebere.
\p 
\v 12 Nʼụbọchị ahụ, \nd Onyenwe anyị\nd* ga-ahọcha site nʼebe mmiri na-eru eru Yufretis ruo na Wadi nke Ijipt, ma gị, bụ Izrel ka a ga-achịkọta otu nʼotu.
\v 13 Nʼụbọchị ahụ, opi ike ga-ada. Ndị ahụ na-ala nʼiyi nʼAsịrịa na ndị ahụ e mere ka ha gaa biri nʼIjipt dịka ndị mba ọzọ ga-abịa fee \nd Onyenwe anyị\nd* ofufe nʼugwu nsọ ya dị na Jerusalem.
\c 28
\s1 Ahụhụ dịrị ndịisi Ifrem na Juda
\q1 
\v 1 Ahụhụ ga-adịrị okpueze okoko\f + \fr 28:1 \ft Okpueze okoko nʼebe a, na-ekwu banyere obodo Sameria.\f* ọhịa ahụ, nke bụ mpako Ifrem,
\q2 obodo ahụ ndị ya na-aṅụbiga mmanya oke ji anya isi.
\q1 Obodo ahụ e wukwasịrị na mbara ala ndagwurugwu mara mma.
\q2 Obodo ahụ ịma mma ya na-ada dịka okoko osisi e kpukwasịrị ndị ndu ya mmanya na-egbu nʼisi.
\q1 
\v 2 Lee, Onyenwe anyị nwere otu onye dị ike,\f + \fr 28:2 \ft Nʼebe a otu onye ahụ dị ike bụ eze ndị Asịrịa.\f* onye nwekwara ume,
\q2 dịka oke mmiri ozuzu nke akụmmiri igwe na dịka oke ifufe na-eweta mbibi,
\q1 dịka oke mmiri ozuzo na-erubiga oke na dịka oke mmiri ozuzo bu idee mmiri ji ike ekwo,
\q2 ọ ga-eji ike tụpụ ya nʼala.
\q1 
\v 3 Okpueze okoko osisi, bụ mpako nke ndị Ifrem na-aṅụbiga mmanya oke,
\q2 ga-abụ ihe a ga-azọtọkwa nʼokpuru ụkwụ.
\q1 
\v 4 Okoko ọhịa nke na-akpọnwụ akpọnwụ, nke bụ ebube ịma mma ya,
\q2 nke dị nʼisi ndagwurugwu na-emepụta ihe,
\q1 ga-adị ka mkpụrụ fiig chara tupu oge owuwe ihe ubi eruo,
\q2 nke mgbe onye ọbụla hụrụ ha na-ewere ha nʼaka,
\q2 tinye nʼọnụ ya, loo ha.
\b
\q1 
\v 5 Nʼụbọchị ahụ, \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile nʼonwe ya,
\q2 ga-aghọrọ ndị ya fọdụrụ nʼala ahụ
\q1 okpueze mara mma,
\q2 ọ ga-aghọkwara ha okoko mara mma.
\q1 
\v 6 Ọ ga-abụ mmụọ nke ikpe ziri ezi
\q2 nye ndị ikpe.
\q1 Ọ ga-abụkwa ike
\q2 nye ndị na-achụghachi ndị iro azụ nʼọnụ ụzọ ama.
\b
\q1 
\v 7 Ndị a kwa na-adagharị site na mmanya
\q2 sitekwa nʼihe ọṅụṅụ na-aba nʼanya.
\q1 Ndị nchụaja na ndị amụma na-adagharị site na ihe ọṅụṅụ na-aba nʼanya,
\q2 mmanya emeela na ha amakwaghị ihe ha na-eme;
\q1 ha na-adagharị site nʼihe ọṅụṅụ na-aba nʼanya
\q2 ha na-adagharị mgbe ha na-ahụ ọhụ dị iche iche,
\q2 ha na-asọ ngọngọ mgbe ha nʼekpe ikpe.
\q1 
\v 8 Nʼihi na tebul ha niile jupụtara nʼihe ọgbụgbọ ruru unyi.
\q2 O nwekwaghị ebe dị ọcha.
\b
\q1 
\v 9 “Ọ bụ onye ka ọ na-achọ ikuziri ihe?
\q2 Ọ bụ onye ka ọ na-achọ ka ọ ghọta ozi ya?
\q1 Ọ bụ ụmụnta ndị a kwusịrị ịṅụ mmiri ara,
\q2 bụ ndị a ka napụrụ ara?
\q1 
\v 10 Nʼihi na ọ na-agbalị izi anyị ihe dịka e si dee ya,
\q2 ahịrị ime nke a, nʼahịrị ime nke ọzọ,
\q2 nʼusoro tụkwasị nʼusoro,
\q2 nwantịntị nʼebe a, nwantịntị nʼebe ahụ.”
\b
\q1 
\v 11 Nʼezie, Chineke ga-eji ndị na-asụ asụsụ unu na-amaghị
\q2 zi unu ihe.
\q1 
\v 12 Nʼihi na ọ gwara unu okwu sị,
\q2 “Lee, nke a bụ ebe izuike ahụ, ebe onye ike gwụrụ nwere ike ịnọ zuru ike;
\q1 nke a bụ ebe ịgbaume ahụ.”
\q2 Ma ha jụrụ ige ya ntị.
\q1 
\v 13 Ọ bụ nʼihi ya ka e ji na-ezi unu okwu \nd Onyenwe anyị\nd*
\q2 nʼahịrị nʼahịrị,
\q2 nʼusoro nʼusoro;
\q2 nwantịntị nʼebe a, nwantịntị nʼebe ahụ,
\q1 ka unu gaa sụọ ngọngọ dalaa azụ,
\q2 ka unu bụrụ ndị e tihịara ahụ, ndị ọnya mara, ndị e jidekwara.
\b
\q1 
\v 14 Nʼihi nke a, nụrụnụ okwu \nd Onyenwe anyị\nd*, unu ndị na-akwa emo,
\q2 ndị ọchịchị Jerusalem dị nʼaka.
\q1 
\v 15 Nʼihi na unu ekwuola sị, “Anyị na ọnwụ agbaala ndụ,
\q2 anyị na ala mmụọ enwekọọkwala otu mkpebi.
\q1 Mgbe ịla nʼiyi ahụ dị ukwuu ga-esi nʼebe anyị nọ gafee,
\q2 ọ gaghị erute anyị,
\q1 nʼihi na anyị emeela ka okwu ụgha bụrụ ebe mgbaba anyị;
\q2 ọ bụkwa nʼime okwu ụgha ka anyị na-ezo onwe anyị.”
\p 
\v 16 Ma otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* sịrị,
\q1 “Lee, ana m atọgbọ na Zayọn otu nkume, nke anwapụtarala.
\q2 Nkume nkuku dị oke ọnụahịa, nʼihi ntọala siri ike.\f + \fr 28:16 \ft Onye ọbụla na-ewukwasị ndụ ya nʼelu ya agaghị enwe ihe egwu ọbụla;\f*
\q1 Onye nke kweere na ya
\q2 egwu agaghị ejide ya.\f + \fr 28:16 \ft Agaghị eme ọsịịsọ laghachi azụ.\f*
\q1 
\v 17 Ikpe ziri ezi ga-abụ eriri ọtụtụ nke ji atụ ihe,
\q2 ezi omume ga-abụkwa ihe ịtụ mgbidi;
\q1 akụmmiri nke oke mmiri ozuzo, ga-ekpochapụ ebe mgbaba unu, okwu ụgha unu,
\q2 mmiri ga-etojukwa nʼebe nzuzo unu.
\q1 
\v 18 Mgbe ahụ, a ga-akagbu ọgbụgba ndụ ahụ unu na ọnwụ gbara;
\q2 mkpebi unu na ala mmụọ agaghị eguzokwa.
\q1 Mgbe oke ịla nʼiyi ahụ si nʼebe unu nọ na-agafe,
\q2 ọ ga-azọda unu.
\q1 
\v 19 Mgbe ọbụla o si nʼebe unu nọ na-agafe, ọ ga-eburu unu,
\q2 maọbụ nʼụtụtụ, ehihie, maọbụ nʼabalị,
\q2 oge niile, mgbe mgbe.”
\b
\q1 Mgbe ahụ, obi unu ga-aghọta okwu Chineke;
\q2 ọ ga-ewetara unu ahụ ịma jijiji.
\q1 
\v 20 Ihe ndina dị mkpụmkpụ, mmadụ enweghị ike esetipụ onwe ya nʼelu ya;
\q2 akwa mkpuchi dị oke warawara, mmadụ enweghị ike iji ya fụchizie ahụ nke ọma.
\q1 
\v 21 \nd Onyenwe anyị\nd* ga-ebili dịka o mere nʼugwu Perazim,
\q2 ọ ga-akpalị onwe ya dịka o mekwara na Ndagwurugwu Gibiọn,
\q1 ịrụ ọrụ ya, ọrụ ya nke dị ike nʼịkọwa,
\q2 na ịrụzu ọrụ ya, ụdị nke a na-atụghị anya ya.
\q1 
\v 22 Ugbu a, ya mere, kwụsịnụ ịkwa emo,
\q2 ka a ghara ime ka ahụhụ unu dị ukwuu karịa.
\q1 Nʼihi na Onyenwe anyị, \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile
\q2 agwala m na o kpebiela ịla unu nʼiyi.
\b
\q1 
\v 23 Geenụ ntị, nụrụnụ olu m,
\q2 ṅaanụ ntị nʼihe m na-agwa unu.
\q1 
\v 24 Ọ bụ ụbọchị niile ka onye ọrụ ubi na-akọ ala ubi ya hapụ ịkụnye ya mkpụrụ?
\q2 Ọ bụ mgbe niile ka ọ na-egwuze ala ubi ya ime ka ọ dị larịị, ma ọ gaghị akụnye ya mkpụrụ ọbụla?
\q1 
\v 25 Mgbe o gwuzesịrị ya,
\q2 ọ naghị aghasa mkpụrụ karawe, ghasaakwa kumin?
\q1 Ọ bụ na ọ naghị akụnye ọka wiiti nʼahịrị nke ya,
\q2 ọka balị nʼebe o kwesiri,
\q2 na spelti nʼebe o kwesiri?
\q1 
\v 26 Ọ maara ihe o kwesiri ime,
\q2 nʼihi na Chineke na-ezi ụzọ ziri ezi.
\b
\q1 
\v 27 Nʼihi na ejighị igwe eji azọcha mkpụrụ ọka etichapụta mkpụrụ karawe,
\q2 maọbụ kpọree ụkwụ igwe\f + \fr 28:27 \ft Lit. \fqa wịịlu\f* nʼelu kumin,
\q1 kama ọ bụ mkpọrọ ka e ji etichapụta kumin,
\q2 werekwa osisi nta kwesiri ekwesi kupụta karawe.
\q1 
\v 28 A na-akwọ ọka e ji eme achịcha akwọ,
\q2 ọ bụghị ruo mgbe ebighị ebi ka a na-anọgide na-etichapụta ya.
\q1 E nwere ike jiri ụkwụ igwe ụgbọala ịnyịnya na-adọkpụ zọchaa ha,
\q2 ma ọ bụghị ka a kwọpịasịa mkpụrụ ha.
\q1 
\v 29 Ihe ndị a niile na-esite nʼaka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile na-abịa,
\q2 onye nzube ya dị ịtụnanya,
\q2 onye amamihe ya dị ebube.
\c 29
\s1 Ahụhụ dịrị obodo Devid
\q1 
\v 1 Ahụhụ ga-adịrị gị, gị bụ Ariel, Ariel,\f + \fr 29:1 \ft Nke a bụ aha ọzọ e ji mara Jerusalem.\f*
\q2 gị obodo ebe Devid bi.
\q1 Gbakọnyenụ otu afọ nʼafọ ọzọ
\q2 nke unu ga-eji rie oriri, mee mmemme.
\q1 
\v 2 Ma aga m akpagbu Ariel,
\q2 ọ ga-eru ụjụ, ma bee akwa,
\q2 ọ ga-adị ka ala ebe ịchụ aja.
\q1 
\v 3 Aga m ama ụlọ ikwu m nʼakụkụ gị niile gburugburu,
\q2 aga m eji ọtụtụ ụlọ elu gba gị gburugburu
\q2 dokwaa ihe nnọchibido m niile megide gị.
\q1 
\v 4 Nʼọnọdụ mweda nʼala, ị ga-ekwu okwu site nʼala,
\q2 okwu ọnụ gị ga-esikwa nʼuzuzu pụta.
\q1 Olu gị ga-ada ka nke onye mmụọ site nʼala,
\q2 ọ bụ site nʼuzuzu ka okwu ọnụ gị na-ada ntakịrị ntakịrị ga-esi pụta.
\b
\q1 
\v 5 Ma igwe ndị iro gị\f + \fr 29:5 \ft Ya bụ, ndị ala ọzọ na-emegide gị\f* ga-aghọ ntụ,
\q2 igwe ndị na-adịghị eme obi ebere ga-adịkwa ka igbugbo ọka nke ifufe na-ebufu.
\q1 Mgbe ahụ, na mberede,
\q2 
\v 6 mụ onwe m, bụ \nd Onyenwe anyị\nd*,
\q1 Onye pụrụ ime ihe niile, ga-eji egbe eluigwe na ala ọma jijiji
\q2 na oke ifufe na oke ụzụ, na ọkụ na-erepịa erepịa, bịakwute ha.
\q1 
\v 7 Mba niile ahụ, ndị na-ebuso Ariel agha,
\q2 bụ ndị na-ebuso ya na ebe ya e wusiri ike agha,
\q1 ga-efu dịka nrọ,
\q2 onye na-arahụ ụra nʼabalị rọrọ.
\q1 
\v 8 Dịka mgbe onye agụụ na-agụ, nke na-arọ nrọ ebe ọ na-eri nri,
\q2 ma agụụ nọkwa na-agụ ya mgbe o si nʼụra teta.
\q1 Dịka onye agụụ mmiri na-agụ, nke nọ na nrọ hụ mmiri ọ na-aṅụ,
\q2 ma teta nʼụra chọpụta na akpịrị na-akpọsị ya nkụ ike, na-adakwa mba.
\q1 E, otu a ka ọ ga-adị
\q2 mgbe igwe ndị agha mba ahụ niile ga-ebuso ugwu Zayọn agha.
\b
\q1 
\v 9 Ka ọ gbagwojuo unu anya. Ka o jukwa unu anya.
\q2 Kpuonụ onwe unu ìsì ka unu ghara ịhụ ụzọ.
\q1 Ṅagharịanụ ma ọ bụghị site na mmanya unu ṅụrụ,
\q2 sọọnụ ngọngọ ma ọ bụghị site na mmanya na-aba nʼanya.
\q1 
\v 10 Nʼihi na \nd Onyenwe anyị\nd* awụkwasịla unu mmụọ nke oke ụra.
\q2 O mechiela anya ndị amụma unu niile,
\q2 kpuchie isi ndị niile na-ahụ ọhụ.
\p 
\v 11 Ihe ndị a niile na-aga ime nʼoge dị nʼihu dịka akwụkwọ a kara akara. Mgbe e weere ya nye onye ma akwụkwọ ka ọ gụọ, ọ ga-asị, “Enweghị m ike, nʼihi na a kaala ya akara.”
\v 12 Mgbe e weere ya nye onye na-amaghị akwụkwọ, ọ ga-asị, “Ewela iwe, amaghị m agụ.”
\p 
\v 13 Onyenwe anyị sịrị,
\q1 “Ndị a ji ọnụ ha na-abịa m nso,
\q2 ha ji egbugbere ọnụ ha na-asọpụrụ m,
\q2 ma obi ha dị anya nʼebe m nọ.
\q1 Ofufe ha na-efe m, bụ nke
\q2 gbadoro ụkwụ nʼihe mmadụ nyere nʼiwu, bụkwa nke a kuziiri ha.
\q1 
\v 14 Ya mere, otu ugboro ọzọ, aga m eme ndị a ihe oke iju anya
\q2 jiri ihe ịtụnanya tụkwasị nʼelu ihe ịtụnanya,
\q1 amamihe nke ndị maara ihe ga-ala nʼiyi,
\q2 nghọta nke ndị nwere nghọta ga-agba barịị.”
\q1 
\v 15 Ahụhụ ga-adịrị ndị na-eche
\q2 na ha na-ezonarị Onyenwe anyị nzube ha,
\q1 ndị na-agbalịsị ike ime ihe ha zubere na nzuzo, ma na-asịrịta onwe ha,
\q2 “Chineke agaghị ahụ anyị. Ọ maghị ihe anyị na-eme!”
\q1 
\v 16 Lee ka unu si ekpu ihe ihu nʼala,\f + \fr 29:16 \ft Ka unu si bụrụ ndị nzuzu\f*
\q2 ka a ga-asị na ọkpụ ite dị ka ụrọ e ji akpụ ite.
\q1 Ihe mmadụ kpụrụ o nwere ike ịtụgharị gwa onye kpụrụ ya, sị,
\q2 “Ị kpụghị m”?
\q1 Ka ite o nwere ike ị sị ọkpụ ite,
\q2 “Ị ghọtaghị ihe ọbụla”?
\b
\q1 
\v 17 Mgbe na-adịghị anya ọ bụ na Lebanọn agaghị aghọ ala ubi na-emepụta ihe,
\q2 ala ubi ahụ na-emepụta ihe ga-adịkwa ka oke ọhịa?
\q1 
\v 18 Nʼụbọchị ahụ, ndị ntị chiri ga-anụ ihe a na-agụpụta site nʼakwụkwọ ahụ,
\q2 ndị ìsì, ndị ahụ naara ejegharị nʼọchịchịrị ga-emeghe anya ha,
\q2 hụkwa ụzọ ọzọ.
\q1 
\v 19 Ndị dị umeala nʼobi, na ndị ogbenye nʼetiti ndị mmadụ ga-achọta ọṅụ na obi ụtọ
\q2 nke \nd Onyenwe anyị\nd* Onye dị nsọ nke Izrel na-enye.
\q1 
\v 20 Ndị na-adịghị enwe obi ebere agaghị adịkwa;
\q2 ndị niile na-akwa emo agaghị adịkwa,
\q2 ndị niile echiche ha bụ ime ajọ ihe ka a ga-ebipụ ndụ ha,
\q1 
\v 21 bụ ndị ahụ na-eme ka e site nʼokwu ọnụ ha mee onye ọzọ onye ikpe mara,
\q2 ndị na-eme ka onye na-ekpechite ọnụ onye a na-emegbu emegbu maa nʼọnya,
\q2 ndị na-eji ịgba akaebe ụgha mee ka ikpe ziri ezi hapụ irute ndị ezi omume aka.
\p 
\v 22 Ya mere, nke a bụ ihe \nd Onyenwe anyị\nd* onye gbapụtara Ebraham na-agwa ụlọ Jekọb,
\q1 “Ndị m, a gaghị emekwa ka ihere mee unu ọzọ.
\q2 Ihu unu agaghị agbarụkwa ọzọ.
\q1 
\v 23 Mgbe ha hụrụ ụmụ ha,
\q2 bụ ọrụ aka m abụọ, nʼetiti ha,
\q1 ha ga-edo aha m nsọ,
\q2 ha ga-ekwupụta, nabatakwa ịdị nsọ nke Onye nsọ Jekọb,
\q2 ha ga-eguzokwa nʼihu Chineke Izrel nʼegwu na nʼịma jijiji.
\q1 
\v 24 Ndị na-akpafu nʼime mmụọ ha ga-enweta nghọta,
\q2 ndị ntamu ga-achọkwa ka ha mụta ihe.”
\c 30
\s1 Ahụhụ dịrị mba na-eme isiike
\q1 
\v 1 “Ahụhụ ga-adịrị ụmụ ndị nnupu isi,”\f + \fr 30:1 \ft Nke a bụ nʼihi mmekọrịta ha na ndị Ijipt \xt 2Ez 18:21.\xt*\f*
\q2 otu a ka \nd Onyenwe anyị\nd* kwupụtara,
\q1 “bụ ndị na-agbaso nzube nke na-esiteghị nʼaka m,
\q2 ndị ha na ndị ọzọ na-agba ndụ nke Mmụọ m na-anabataghị,
\q2 si otu a na-eme ka mmehie na-aba ụba nʼelu mmehie.
\q1 
\v 2 Ndị na-aga Ijipt ịchọ enyemaka
\q2 ma ha ajụtaghị ase site nʼaka m.
\q1 Ndị were obi ha tụkwasị na Fero maka nchebe,
\q2 chọsiekwa ike ime Ijipt ebe mgbaba.
\q1 
\v 3 Ma nchekwa Fero ga-aghọrọ unu ihe ihere,
\q2 ndo ndị Ijipt ga-etinye unu nʼọnọdụ mweda nʼala.
\q1 
\v 4 Ọ bụ ezie na ha nwere ndị ozi na Zoan
\q2 ndị nnọchi anya ha erutekwala Hans,
\q1 
\v 5 ihere ga-eme onye ọbụla
\q2 nʼihi ndị na-abaghị uru nye ha,
\q1 ndị na-abụghị ihe inyeaka maọbụ ihe iba uru,
\q2 kama naanị ihe ihere na ịta ụta.”
\p 
\v 6 Amụma banyere ụmụ anụmanụ bi na Negev.
\q1 Nʼala ahụhụ na mkpagbu,
\q2 nke ọdụm na nne ọdụm,
\q2 nke ajụala na agwọ ọjọọ na-efe ka ọkụ,
\q1 ndị nnọchite anya obodo na-ebu akụ ha niile nʼelu ịnyịnya ibu,
\q2 na-ebukwa akụnụba ha dị oke ọnụahịa nʼelu ịnyịnya kamel,
\q1 na-agakwuru mba ahụ na-abaghị uru,
\q2 
\v 7 bụ Ijipt, ndị inyeaka ha na-enye enweghị isi.
\q1 Nʼihi nke a, ana m agụ ya
\q2 Rehab, onye na-enweghị ihe ọ na-arụ.
\b
\q1 
\v 8 Gaa ugbu a, dekwasịrị ha ya nʼelu mbadamba nkume,
\q2 detuokwa ha nʼime akwụkwọ,
\q1 ka ọ dịrị maka ụbọchị na-abịa
\q2 dịka ihe akaebe ruo mgbe ebighị ebi.
\q1 
\v 9 Nʼihi na ndị a bụ ndị na-enupu isi, ụmụ aghụghọ
\q2 ndị kpachaara anya jụ ịnabata ozizi \nd Onyenwe anyị\nd* na-ezi.
\q1 
\v 10 Ha na-agwa ndị ọhụ ụzọ,
\q2 “Unu ahụkwala ọhụ, o zuola,”
\q1 ma sịkwa ndị amụma,
\q2 “Mechienụ ọnụ! Unu ahụtakwarala anyị ihe ziri ezi nʼọhụ unu.
\q1 Gwanụ anyị ihe na-atọ ụtọ na ntị,
\q2 buonu amụma nduhie.
\q1 
\v 11 Unu na-anọchiri anyị ụzọ,
\q2 nyenụ anyị ohere.
\q1 Anyị achọkwaghị ịnụ ihe ọbụla
\q2 banyere onye ahụ unu na-akpọ Onye dị nsọ nke Izrel.”
\p 
\v 12 Ya mere, ihe a ka Onye dị nsọ nke Izrel na-ekwu,
\q1 “Nʼihi na unu kpọrọ okwu m na-agwa unu asị,
\q2 ma dabere na mmegbu
\q2 na-atụkwasịkwa obi unu nʼaghụghọ,
\q1 
\v 13 mmehie a ga-aghọrọ unu
\q2 ihe dịka mgbidi dị elu, nke gbawara agbawa,
\q2 nke ga-ada na mberede, nʼotu ntabi anya.
\q1 
\v 14 Ọ ga-etipịasị dịka ite aja,
\q2 nke etipịara na-enweghị obi ebere,
\q1 nke a na-enweghị ike ịchọta mpekele ejuju ọbụla nʼetiti ya,
\q2 iji gụta ọkụ site na-ekwu,
\q2 maọbụ kupụta mmiri site nʼite.”
\p 
\v 15 Nʼihi na otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* bụ Onye nsọ nke Izrel sịrị,
\q1 “Ọ bụ na nchegharị na izuike ka a ga-azọpụta unu,
\q2 na ịnọ juu na ntụkwasị obi ka ịdị ike unu ga-adị,
\q2 ma unu ekweghị na nke ọbụla.
\q1 
\v 16 Kama unu na-asị, ‘Anyị ga-arịkwasị nʼelu ịnyịnya gbapụ.’
\q2 E, unu ga-agba ọsọ nʼezie.
\q1 Unu sịrị, ‘Anyị ga-arịkwasị nʼịnyịnya ndị na-efe ọsọ.’
\q2 Ya mere, ndị ga-achụ unu ga-adị ngwa.
\q1 
\v 17 Otu onye nʼime ndị iro unu
\q2 ga-achụ puku mmadụ nʼime unu ọsọ.
\q1 Mmadụ ise si nʼime ha
\q2 ezuola ịchusasị unu,
\q1 ruo mgbe unu ga-adị
\q2 ka osisi a manyere ọkọlọtọ debe nʼelu ugwu,
\q2 e, ka ọkọlọtọ a hapụrụ nʼelu ugwu nta.”
\b
\q1 
\v 18 Ma \nd Onyenwe anyị\nd* nọkwa na-echere ka unu bịakwute ya,
\q2 ka o gosi unu ịhụnanya ya.
\q1 O jikeere imere unu ebere, nʼihi na \nd Onyenwe anyị\nd* bụ Chineke na-ekpe ikpe ziri ezi.
\q2 Ngọzị na-adịkwara ndị niile na-ele anya inyeaka ya.
\p 
\v 19 Unu ndị Zayọn ndị bi na Jerusalem, ndị nke m, unu agaghị ebekwa akwa ọzọ, nʼihi na Onyenwe anyị bụ onye obi ebere. Ọ ga-enyere unu aka mgbe ọbụla unu kpọkuru ya.
\v 20 Nʼagbanyeghị na Onyenwe anyị na-enye unu achịcha nke nhụju anya na mmiri nke ahụhụ, ndị ozizi unu agaghị abụkwa ndị zoro onwe ha ọzọ, kama unu ga-eji anya unu hụ ha.
\v 21 Ma unu tụgharịrị nʼaka nri ma ọ bụkwanụ nʼaka ekpe, ntị unu ga-anụ otu olu nʼazụ unu, nke na-asị, “Nke a bụ ụzọ, Jeenụ ije nʼime ya.”
\v 22 Mgbe ahụ kwa, unu ga-emebi arụsị unu niile, nke e ji ọlaọcha na ọlaedo kpụọ. Unu ga-atụfukwa ha dịka ihe ruru unyi, nke na-asọ oyi. Unu ga-asị ha, “Pụọnụ nʼebe a!”
\p 
\v 23 Ọ ga-ezitekwa mmiri ozuzo maka mkpụrụ unu kụrụ nʼala ubi unu, ihe omume nke ga-esite nʼala ahụ pụta ga-ama abụba baakwa ụba. Nʼụbọchị ahụ anụ ụlọ unu ga-ata nri nʼebe ịta nri sara mbara.
\v 24 Ehi na ịnyịnya ibu ndị na-arụ ọrụ ubi ga-ata nri a gwara nke ọma nke nnu dị, nke eji ngwa ọrụ ịfụcha ọka na shọvel kpasaa nke ọma.
\v 25 Nʼelu ugwu ọbụla dị elu na nʼelu ugwu nta ọbụla dị elu, ka iyi na mmiri niile ga-eru, nʼụbọchị oke ogbugbu, mgbe ụlọ elu niile ga-ada.
\v 26 Ọnwa ga-amụke dịka anwụ, ìhè anyanwụ ga-adịkwa okpukpu asaa dịka ìhè ụbọchị asaa e mere ka ọ mụọ nʼotu ụbọchị! Ihe ndị a ga-emezu nʼụbọchị ahụ \nd Onyenwe anyị\nd* malitere ikechi na ịgwọ ọnya o mere ka o rute ndị ya aka.
\q1 
\v 27 Lee, Aha \nd Onyenwe anyị\nd* ka o si nʼebe dị anya na-abịa!
\q2 Ọ na-abịa nʼoke iwe, anwụrụ ọkụ gbakwara ya gburugburu.
\q1 Iwe jupụtara nʼegbugbere ọnụ ya,
\q2 okwu ya na-erechapụ dịka ọkụ.
\q1 
\v 28 Iku ume ya dịkwa ka iyi rubigara oke, nke na-achị ọkụ,
\q2 nke na-etoru onye nọ nʼime ya nʼolu.
\q1 Ọ na-ayọcha mba niile nʼime nyọ ịla nʼiyi,
\q2 ọ na-etinye nʼagba ndị mmadụ
\q2 eriri igwe nke na-edufu ha.
\q1 
\v 29 Ma unu ga-abụ abụ
\q2 dịka unu na-abụ nʼabalị mmemme dị nsọ,
\q1 obi unu ga-aṅụrị ọṅụ
\q2 dịka mgbe ndị na-egbu opi na-arịgo elu
\q1 na-aga nʼugwu nsọ \nd Onyenwe anyị\nd*,
\q2 na-agakwuru Oke Nkume Izrel.
\q1 
\v 30 \nd Onyenwe anyị\nd* ga-eme ka ndị mmadụ nụ olu ya dị ebube,
\q2 ọ ga-emekwa ka ha hụ aka ya na-arịdata ala
\q1 jiri ọnụma nke iwe ya na ọkụ na-erepịa erepịa,
\q2 jirikwa oke mmiri ozuzo, na egbe eluigwe, na akụmmiri igwe.
\q1 
\v 31 Olu \nd Onyenwe anyị\nd* ga-emenye ndị Asịrịa egwu;
\q2 ọ ga-eji mkpara igwe ya kụdaa ha nʼala.
\q1 
\v 32 Ihe otiti ọbụla nke \nd Onyenwe anyị\nd* na-eji mkpọ ya,
\q2 tie ha nʼahụ
\q1 ga-adị ka egwu ụbọ akwara na une dị iche iche na-enye,
\q2 mgbe ọ na-eweli aka ya na-eti ha oke ihe otiti dịka ọ na-alụso ha ọgụ.
\q1 
\v 33 Edoolarị ihe niile nʼusoro site nʼoge gara aga.
\q2 A kwadoola ebe a ga-akwanye ọkụ nke ga-erechapụ eze ahụ.
\q1 Ọ bụ ebe sara mbara, nke dị omimi,
\q2 na nke a kwajuru nkụ.
\q1 Ọ bụ iku ume \nd Onyenwe anyị\nd*
\q2 nke dịka mwụpụta nke nkume na-enwu ọkụ
\q2 ka a ga-eji mụnye ya ọkụ.
\c 31
\s1 Ahụhụ dịrị ndị ahụ na-atụkwasị Ijipt obi
\q1 
\v 1 Ahụhụ dịrị ndị na-aga Ijipt ịchọ enyemaka,
\q2 ndị nchekwube ha dị nʼike ndị ha na-agba ịnyịnya,
\q1 ndị na-atụkwasị obi ha nʼụgbọala ha, nke dị ọtụtụ,
\q2 ndị na-atụkwasịkwa obi ha nʼịdị ike nke ndị Ijipt na-agba ịnyịnya.
\q1 Ma ha adịghị ele anya inyeaka site nʼaka Onye Nsọ Izrel;
\q2 ha adịghị arịọkwa ya ka \nd Onyenwe anyị\nd* nyere ha aka.
\q1 
\v 2 Ma ya onwe ya maara ihe, ọ pụrụ iweta ịla nʼiyi.
\q2 Ọ dịkwaghị agbanwe okwu ya.
\q1 Ọ ga-ebili megide ndị mba na-eme ihe ọjọọ;
\q2 ha na ndị niile na-enyere ndị na-eme ajọ ihe aka.
\q1 
\v 3 Nʼihi na ndị Ijipt bụ naanị mmadụ, ha abụghị Chineke!
\q2 Ịnyịnya ha nwekwara anụ ahụ, ha abụghị mmụọ.
\q1 Mgbe \nd Onyenwe anyị\nd* setịpụrụ aka ya imegide ha,
\q2 ha ga-asọ ngọngọ;
\q2 ndị ha na-enyere aka ga-adakwa.
\q2 Ha niile ga-alakọkwa nʼiyi.
\p 
\v 4 Ma ihe ndị a ka \nd Onyenwe anyị\nd* gwara m,
\q1 “Dịka ọdụm na-agbọ ụja,
\q2 na-ebigbọ nʼelu anụ ọ dọgburu,
\q1 nʼagbanyeghị na-akpọkọtara igwe ndị ọzụzụ atụrụ
\q2 imegide ya,
\q1 ọ naghị atụ egwu mkpu ha,
\q2 mkpọtụ ụzụ ha adịghị enyekwa ya nsogbu,
\q1 Otu a kwa, \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile ga-arịdata
\q2 ibu agha nʼugwu Zayọn, na nʼugwu nta ya niile.
\q1 
\v 5 Dịka nnụnụ si efegharị nʼelu akwụ ya ichebe ụmụ ya,
\q2 otu a ka mụ bụ \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile ga-esi chebe Jerusalem,
\q1 ọ ga-ekpuchi ya napụta ya,
\q2 ọ ghaghị ịgabiga ya, gbapụtakwa ya.”
\p 
\v 6 Lọghachitenụ azụ, unu bụ Izrel, laghachikwurunụ onye ahụ nke unu nupuru isi nʼebe ọdị ukwuu megide.
\v 7 Amaara m nke ọma na ụbọchị ahụ na-abịa, mgbe onye ọbụla nʼime unu ga-atụfu arụsị ọlaedo na ọlaọcha niile nke aka mmehie unu kpụrụ.
\q1 
\v 8 “Mgbe ahụ, Asịrịa ga-ada, kama ọ bụghị site na mma agha mmadụ,
\q2 mma agha na-abụghị nke mmadụ efu ga-erichapụ ha.
\q1 Ha ga-esi nʼihu mma agha gbaa ọsọ,
\q2 ma ụmụ okorobịa ha ka a ga-akpụrụ tinye nʼọrụ mmanye.
\q1 
\v 9 Obodo ha niile e wusiri ike ga-ada nʼihi oke egwu,
\q2 ndị ọchịagha ha ga-atụkwa ụjọ mgbe ha hụrụ ọkọlọtọ agha.”
\q1 Otu a ka \nd Onyenwe anyị\nd* kwubiri ya.
\q2 Onye ọkụ ya dị na Zayọn,
\q2 onye ekwu igwe ọkụ ya dị na Jerusalem.
\c 32
\s1 Alaeze dabeere nʼezi omume
\q1 
\v 1 Lee, eze ga-achị nʼezi omume na-abịa,
\q2 ya na ndịisi kwesiri ntụkwasị obi, ndị ga-ekpe ikpe ziri ezi.
\q1 
\v 2 Onye ọbụla nʼime ha ga-aghọrọ ndị mmadụ ebe a na-ezere ndụ nʼoge oke ifufe,
\q2 na ebe mgbaba nʼoge oke mmiri ozuzo.
\q1 Ha ga-adị ka mmiri na-asọ nʼọzara,
\q2 maọbụ dịka ndo nke nkume dị elu na-enye nʼebe okpomọkụ na-eweta ike ọgwụgwụ dị.
\b
\q1 
\v 3 Mgbe ahụ, agaghị emechikwa anya ndị niile na-ahụ ụzọ,
\q2 agakwaghị eme ka ntị na-anụ ihe kwụsị ịnụ ihe.
\q1 
\v 4 Ọ bụladị obi ndị nzuzu nʼetiti ha ga-ejupụta nʼakọnuche na nghọta,
\q2 ndị ahụ na-asụ nsụ ga-ekwukwa okwu nke ọma.
\q1 
\v 5 Nʼụbọchị ahụ, a gaghị ahụkwa onye nzuzu sị na ọ bụ onye maara ihe.
\q2 A gaghị enyekwa onye aghụghọ nsọpụrụ ọzọ.
\q1 
\v 6 Nʼihi na ndị nzuzu na-ekwu okwu na-echeghị echiche,
\q2 obi ha niile dị na-ime ajọ ihe.
\q1 Ọ na-ebi ndụ asọpụrụghị Chineke,
\q2 na-ekwusakwa okwu njehie megide \nd Onyenwe anyị\nd*;
\q1 ndị agụụ na-agụ ka ha na-agbaba aka
\q2 ndị akpịrị na-akpọ nkụ, ha adịghị enye ha mmiri ọṅụṅụ.
\q1 
\v 7 Ndị ọjọọ na-eji ụzọ aghụghọ niile eme ihe ọjọọ,
\q2 ha na-echepụta nzube ajọ ihe niile,
\q1 iji okwu ụgha laa onye ogbenye nʼiyi,
\q2 ọ bụladị mgbe arịrịọ nke onye ahụ nọ na mkpa bụ nke ziri ezi.
\q1 
\v 8 Ma onye a na-asọpụrụ na-atụpụta atụmatụ dị ezi mma,
\q2 ọ na-eguzokwa chịm nye ezi ihe.
\s1 Ndị inyom Jerusalem
\q1 
\v 9 Unu ndị inyom na-ebi ndụ ndị afọ juru,
\q2 bilie ọtọ, gee m ntị;
\q1 unu ndị ada ndị nwere ntụkwasị obi,
\q2 nụrụnụ ihe m nwere ikwu.
\q1 
\v 10 Nʼoge na-adịghị anya, mgbe otu afọ na abalị ole na ole gasịrị,
\q2 unu bụ ndị nwere ntụkwasị obi ga-ama jijiji;
\q1 nʼihi na mkpụrụ ubi vaịnị unu ga-emebi,
\q2 owuwe mkpụrụ ihe ubi agaghị abịa.
\q1 
\v 11 Maanụ jijiji, unu ndị inyom afọ juru,
\q2 tụọ egwu unu ndị ada ndị nwere ntụkwasị obi.
\q1 Yipụnụ uwe ọma unu,
\q2 kekwasịnụ onwe unu akwa mkpe.
\q1 
\v 12 Tienụ aka nʼobi nʼihi ubi unu na-enye afọ ojuju,
\q2 nʼihi osisi vaịnị na-amị mkpụrụ.
\q1 
\v 13 Nʼihi na ogwu na uke ga-epupụta nʼala unu.
\q2 Ruonụ uju, nʼihi na ụlọ niile unu na-anọ nʼime ya enwe obi ụtọ,
\q1 na obodo niile unu na-anọ nʼime ya na-eri, na-aṅụ
\q2 agakwaghị adị.
\q1 
\v 14 Nʼihi na a ga-ahapụ ebe niile e wusiri ike,
\q2 gbahapụkwa obodo ahụ ụzụ na-adị nʼime ya;
\q1 ụlọ elu nche niile na ebe niile ewusiri ike ga-abụ ebe ga-atọgbọrọ nʼefu ruo mgbe ebighị ebi,
\q2 ha ga-aghọ ebe ịnyịnya ibu ọhịa ga na-enwe obi ụtọ, na ebe igwe anụ ụlọ ga na-akpa nri ha.
\q1 
\v 15 Ha niile ga-adịgide otu a tutu ruo mgbe a ga-esite nʼeluigwe wụkwasị anyị Mmụọ Nsọ.
\q2 Mgbe ahụ ọzara ga-aghọ ala ubi mara mma,
\q2 ala ubi ọma ahụ ga-adịkwa ka ọhịa.
\q1 
\v 16 A ga-emekwa ka ikpe ziri ezi ga-ebi nʼọzara,\f + \fr 32:16 \ft Ga-erute onye ọbụla aka\f*
\q2 ezi omume ga-adịkwa nʼubi ọma ahụ.
\q1 
\v 17 Mkpụrụ nke ezi omume ahụ ga-abụ udo;
\q2 ihe ga-esikwa na ya pụta ga-abụ ị nọ jụụ na ntụkwasị obi mgbe niile ebighị ebi.
\q1 
\v 18 Ndị m ga-ebi nʼebe obibi nke udo,
\q2 nʼụlọ nwere ezi nchekwa,
\q2 nʼebe izuike nke nsogbu na-adịghị.
\q1 
\v 19 A sikwa na mkpụrụ mmiri ezoo nʼoke ọhịa niile,
\q2 a sikwa na e bibie obodo niile,
\q1 
\v 20 ndị a gọziri agọzi ka unu ga-abụ,
\q2 mgbe unu na-agha mkpụrụ unu nʼakụkụ iyi,
\q2 mgbe ehi unu na ịnyịnya ibu unu na-akpagharị na-aga ebe ọbụla ha chọrọ.
\c 33
\s1 Nsogbu na enyemaka
\q1 
\v 1 Ahụhụ dịrị gị, onye mbibi,
\q2 onye bibiri ihe niile dị gị gburugburu, ma ọ dịbeghị mbibi rutere gị aka.
\q1 Ahụhụ dịrị gị, onye nrafu,
\q2 onye na-enwebeghị ndị rafuru gị.
\q1 Mgbe ị kwụsịrị ibibi ihe
\q2 ka a ga-ebibi gị,
\q1 mgbe ị kwụsịkwara nrafu
\q2 ka a ga-arafu gị.
\b
\q1 
\v 2 Biko, \nd Onyenwe anyị\nd*, nwee obi ebere nʼebe anyị nọ,
\q2 nʼihi na ọ bụ gị ka anyị na-ele anya.
\q1 Bụụrụ anyị ike nʼụtụtụ ụbọchị niile,
\q2 bụrụkwara anyị onye nzọpụta mgbe niile anyị nọ na mkpa.
\q1 
\v 3 Ndị iro na-agba ọsọ mgbe ha nụrụ olu gị.
\q2 Mgbe ị guzoro ọtọ, mba niile na-agbalaga.
\q1 
\v 4 Dịka igurube si atachapụ ihe dị nʼubi,
\q2 otu a ka a ga-esi kwakọrọ ihe niile unu nwere nʼagha, unu mba dị iche iche.
\b
\q1 
\v 5 \nd Onyenwe anyị\nd* dị elu, nʼihi na o bi nʼebe dị elu.
\q2 Ọ ga-eji ikpe ya ziri ezi, na ezi omume mejupụta Zayọn.
\q1 
\v 6 Ọ ga-abụ ntọala guzosiri ike nke oge unu niile,
\q2 ụlọakụ dị ukwu nke nzọpụta, na amamihe na ihe ọmụma;
\q2 egwu \nd Onyenwe anyị\nd* bụ igodo nke akụ a.
\b
\q1 
\v 7 Lee ndị ha dị ike ka ha na-eti mkpu akwa nʼokporoụzọ niile;
\q2 ndị na-anọchite anya ha, ndị bịara ikwu otu udo ga-esi dịrị na-akwa akwa.
\q1 
\v 8 Ọ dịkwaghị onye a na-ahụ anya nʼokporoụzọ ọbụla.
\q2 E meela ka ọgbụgba ndụ niile ghara ịdịkwa ire.
\q1 A na-elelị ndị e sitere nʼakaebe ha
\q2 mee ka ọgbụgba ndụ ahụ guzosie ike.
\q2 Ọ dịkwaghị onye a na-asọpụrụ.
\q1 
\v 9 Ala ahụ niile na-eru ụjụ. Ọ tọgbọkwara nʼefu.
\q2 Oke ọhịa Lebanọn akpọnwụọla bụrụ ihe ihere.
\q1 Sharọn aghọkwaala ọzara;
\q2 osisi dị na Bashan na nʼelu ugwu Kamel na-agbụchakwa akwụkwọ ha.
\b
\q1 
\v 10 Ma \nd Onyenwe anyị\nd* na-asị, “Ugbu a, m ga-ebili.”
\q2 “Ugbu a, ka a ga-eme ka m dị elu;\f + \fr 33:10 \ft Mgbe a ga-asọpụrụ m\f*
\q2 ugbu a, ka a ga-ebuli m elu.
\q1 
\v 11 Unu na-atụ ime ahịhịa kpọrọ nkụ,
\q2 unu na-amụpụta ahịhịa,
\q2 nkuume unu na-ekupụta bụ ọkụ ga-erepịa unu.
\q1 
\v 12 Ndị gị ga-ere ọkụ, dịka osisi ogwu e gbuturu egbutu tụnye nʼọkụ;
\q2 ha ga-ere ọkụ dịka avụvụ nkwụ.”
\b
\q1 
\v 13 Geenụ ntị nụrụ ihe m mere, unu mba niile dị nʼebe dị anya!
\q2 Unu ndị nọ nso, kwerenụ nʼezie na m siri ike!
\q1 
\v 14 Ndị mmehie na ndị ajọ omume nọ na Zayọn na-ama jijiji nʼegwu,
\q2 ha na-akwa akwa na-asị,
\q1 “Onye nʼime anyị pụrụ ibi nʼebe a, nʼetiti onye a bụ ọkụ na-erepịa erepịa,
\q2 ọkụ nke na-ere ruo mgbe ebighị ebi?”
\q1 
\v 15 Ndị na-ejegharị nʼezi omume
\q2 na-ekwu ihe ziri ezi,
\q1 ndị na-ajụ uru sitere nʼụzọ nʼezighị ezi,
\q2 ndị na-ewezuga aka ha site na ịnata ngarị dị iche iche,
\q1 ndị na-emechi ntị megide izu ịkwafu ọbara,
\q2 na-amụchi anya ha abụọ ka ha ghara ịtụgharị uche nʼihe ọjọọ.
\q1 
\v 16 Ha bụ ndị ahụ ga-ebi nʼebe dị elu,
\q2 ndị ebe mgbaba ha ga-abụ ebe e wusiri ike nke ugwu.
\q1 A ga-enye ha nri,
\q2 mmiri a gaghị akọkwa ha.
\b
\q1 
\v 17 Anya unu ga-ahụ eze nʼebube ya;
\q2 unu ga-ahụkwa alaeze ya nke nsọtụ oke ya dị nʼebe dị anya.
\q1 
\v 18 Nʼime echiche obi unu, unu ga na-atule ihe oke egwu nke oge ndị ahụ gara aga.
\q2 “Olee ebe onyeisi ọchịchị ahụ nọ ugbu a?
\q1 Ebee ka onye na-anakọta ụtụ ahụ nọ?
\q2 Ebeekwa ka onyeisi ahụ nke ụlọ elu nche niile dị nʼaka ya nọ?”
\q1 
\v 19 Nʼoge ahụ, unu agaghị ahụkwa ndị nganga ahụ ọzọ,
\q2 bụ ndị ahụ na-asụ asụsụ nke unu na-amaghị,
\q2 nke unu na-adịghị aghọtakwa.
\b
\q1 
\v 20 Lekwasịnụ Zayọn anya, obodo anyị na-anọ eme mmemme anyị niile;
\q2 anya unu ga-ahụkwa Jerusalem,
\q2 ụlọ obibi dị jụụ, ụlọ ikwu nke a na-apụghị ibupụ ebupụ;
\q1 apụghịkwa iholite ǹtu jidere ya,
\q2 maọbụ dọbie nke ọbụla nʼime ụdọ ji ya.
\q1 
\v 21 Ebe ahụ ka \nd Onyenwe anyị\nd* ga-abụrụ anyị Onye dị ike.
\q2 Ọ ga-adịkwara anyị ka osimiri na iyi dị obosara.
\q1 Ọ dịghị ụgbọ amara
\q2 maọbụ ụgbọ ukwu ga-abịa na mmiri ahụ.
\q1 
\v 22 Nʼihi na \nd Onyenwe anyị\nd* bụ onye ikpe anyị.
\q2 \nd Onyenwe anyị\nd* bụ onye na-enye anyị iwu.
\q1 \nd Onyenwe anyị\nd* bụ eze anyị,
\q2 ọ bụ ya na-azọpụta anyị.
\b
\q1 
\v 23 A tọsaala ụdọ niile:
\q2 Ha adịghị ejidesikwa ọkọlọtọ gị ike,
\q2 a gbasaghịkwa akwa igbochi ifufe.
\q1 Mgbe ahụ, a ga-ekesa ụba ihe a kwatara nʼagha
\q2 ọ bụladị ndị ngwụrọ ga-ebute ihe nkwata nʼagha.
\q1 
\v 24 Ọ dịkwaghị onye bi na Zayọn ga-asị, “Ahụ esighị m ike,”\f + \fr 33:24 \ft Ana m arịa ọrịa\f*
\q2 nʼihi na a ga-agbaghara ndị bi nʼime ya mmehie ha niile.
\c 34
\s1 Ahụhụ dịrị mba niile
\q1 
\v 1 Bịanụ nso, unu ndị mba niile, ṅaa ntị.
\q2 Geenụ ntị, unu mba niile nke ụwa.
\q1 Ka ụwa na ihe niile dị nʼime ya,
\q2 na ihe niile na-esi nʼime ya apụta nụrụ.
\q1 
\v 2 Nʼihi na \nd Onyenwe anyị\nd* na-eweso mba niile nke ụwa iwe,
\q2 iwe ya dị ọkụ megide ndị agha ha niile.
\q1 Ọ ga-ala ha nʼiyi kpamkpam,
\q2 nyefee ha nʼaka ndị ga-egbu ha.
\q1 
\v 3 Ndị ha e gburu egbu ka a ga-atụpụ.
\q2 Ozu ha ga-esikwa isi.
\q2 Ugwu niile ga-ejupụta nʼọbara ha.
\q1 
\v 4 Nʼoge ahụ, kpakpando niile nke eluigwe ga-agbaze,
\q2 a ga-apịakọtakwa mbara eluigwe dịka akwụkwọ,
\q1 kpakpando niile ga-ada
\q2 dịka ahịhịa osisi vaịnị kpọrọ nkụ,
\q2 dịka mkpụrụ osisi fiig chakpọrọ achakpọ.
\b
\q1 
\v 5 Nʼihi na mma agha m arụchaala ọrụ ya nʼeluigwe,
\q2 lezie anya ihe gaje ime, ọ ga-adakwasị Edọm,
\q2 ndị m mara ikpe mbibi.
\q1 
\v 6 Mma agha \nd Onyenwe anyị\nd* jupụtara nʼọbara,
\q2 abụba kpuchikwara ya,
\q1 ọbara ụmụ atụrụ na mkpi
\q2 na abụba sitere nʼakụrụ ebule
\q1 nʼihi na \nd Onyenwe anyị\nd* nwere ịchụ aja na Bozra.
\q2 O nwekwara oke ogbugbu ga-adị nʼala Edọm.
\q1 
\v 7 Oke ehi ọhịa ga-esokwa ha daa,
\q2 ha na oke ehi ukwu na oke ehi nta.
\q1 Ala ga-ejupụta nʼọbara ha.
\q2 Uzuzu nke obodo ahụ ga-amịkọrọ ọbara ha.
\b
\q1 
\v 8 Nʼihi na \nd Onyenwe anyị\nd* nwere ụbọchị ahụ bụ ụbọchị ịbọ ọbọ.
\q2 Ọ bụ afọ ịkwụghachi Edọm ihe ha mere Zayọn.
\q1 
\v 9 Isi iyi ndị Edọm niile ga-agbanwe gbajie ojii,
\q2 uzuzu dị nʼala ga na-ere ọkụ dịka sọlfọ (ntụ ọkụ),
\q2 ala ahụ niile ga-enwuru ọkụ dị ka unyi ojii.
\q1 
\v 10 Ọ gaghị anyụ anyụ nʼabalị maọbụ nʼehihie;
\q2 anwụrụ ọkụ ya ga na-ala nʼelu ruo ebighị ebi.
\q1 Ala ahụ ga-atọgbọrọ nʼefu site nʼọgbọ ruo nʼọgbọ;
\q2 ọ dịghị onye ga-esitekwa nʼebe ahụ gafee ọzọ.
\q1 
\v 11 Ikwighịkwighị nke ọzara na okwolo ga-enweta ya,
\q2 ikwighịkwighị ukwu na ugolọma ga-akpa akwụ ha birikwa nʼebe ahụ.
\q1 Chineke ga-eseti nʼelu Edọm,
\q2 eriri ọtụtụ nke ọgbaaghara,
\q2 na ihe ịtụ mgbidi nke e tikpọrọ etikpọ, tọgbọrọ nʼefu.
\q1 
\v 12 Ndị ya a na-asọpụrụ agaghị ahụkwa ihe ọbụla nʼebe ahụ nke ha ga-akpọ alaeze.
\q2 Otu a kwa, ụmụ ndị eze ya niile agaghị adịkwa.
\q1 
\v 13 Ogwu ga-etochi ụlọ ukwu ya niile;
\q2 ebe ya niile e wusiri ike ga-aghọ ahịhịa ogwu,
\q1 ọ ga-abụkwa ụlọ nkịta ọhịa
\q2 na nke ikwighịkwighị.
\q1 
\v 14 Anụ ọhịa niile nke ọzara ga-ezute nkịta ọhịa nʼebe ahụ.
\q2 Ụmụ mkpi ọhịa ga-awagharị nʼebe ahụ na-ebeku ibe ha akwa.
\q1 Nʼebe ahụ ka ụmụ anụ ọhịa na-akpagharị nʼabalị ga-ezo onwe ha,
\q2 chọtakwara onwe ha ọnọdụ ebe izuike.
\q1 
\v 15 Ikwighịkwighị ga-akpa akwụ ya nʼebe ahụ.
\q2 Ọ ga-anọkwa nʼebe ahụ yie akwa, zụọ ụmụ ya,
\q2 lekọtaa ha site nʼiji nku ya kpuchie ha.
\q1 Ebe ahụ kwa ka ndagbụ ga-ezukọkwa,
\q2 nke ọbụla na ibe ya.
\p 
\v 16 Nyochaa akwụkwọ nsọ ka ị gụọ ihe \nd Onyenwe anyị\nd* gaje ime:
\q1 Ọ dịghị anụ ọhịa ọbụla ga-efu.
\q2 Ọ dịghị nke ọbụla ga-anọ nʼebe ahụ hapụ ịkpọ ibe ya,
\q1 nʼihi na ọnụ ya enyela iwu a.
\q2 Mmụọ ya ga-achịkọtakwa ha.
\q1 
\v 17 Ọ bụ ya onwe ya ga-ekewa ala ahụ,
\q2 jiri ihe ọtụtụ nʼaka keere ha oke ahụ.
\q1 Ha ga-enweta ya ruo mgbe ebighị ebi,
\q2 nwekwa ebe obibi nʼebe ahụ site nʼọgbọ ruo nʼọgbọ.
\c 35
\s1 Ọnụ ndị a gbapụtara
\q1 
\v 1 Nʼụbọchị ahụ, ọzara na ala kpọrọ nkụ ga-enwe obi ụtọ;
\q2 okoko osisi mara mma ga-awapụtakwa nʼọzara.
\q1 Dịka rozu,
\v 2 ọ ga-agbawa ifuru jupụta;
\q2 ọ ga-aṅụrị ọṅụ nke ukwuu, tiekwa mkpu ọṅụ.
\q1 A ga-enye ya nsọpụrụ nke ugwu Lebanọn,
\q2 nyekwa ya ịma mma nke ala ubi Sharọn na Kamel.
\q1 Ha ga-ahụ ebube \nd Onyenwe anyị\nd* nʼebe ahụ,
\q2 ha ga-ahụkwa ịdị ukwuu\f + \fr 35:2 \ft Maọbụ, \fqa ịma mma\f* nke Chineke anyị.
\b
\q1 
\v 3 Meenụ ka aka ndị ahụ kụdara akụda dịkwa ike,
\q2 gbaakwanụ ụkwụ ndị ahụ na-asọ ngọngọ ume.
\q1 
\v 4 Gwanụ ndị ahụ na-atụ egwu sị ha,
\q2 “Dịrịnụ ike, unu atụla egwu,
\q1 nʼihi na Chineke unu na-abịa.
\q2 Ọ ga-abịa ịbọtara unu ọbọ,
\q1 ịkwụghachi ndị iro unu ihe ruuru ha.
\q2 Ọ ga-abịa ịzọpụta unu.”
\b
\q1 
\v 5 Mgbe ọ bịara, ọ ga-emeghe anya ndị kpuru ìsì,
\q2 meekwa ka ndị ntị chiri nụ ihe.
\q1 
\v 6 Ọ ga-eme ka onye ngwụrọ wulie elu dịka ele,
\q2 meekwa ka ndị na-adịghị ekwu okwu tie mkpu ọṅụ.
\q1 Mmiri ga-agbawapụta sọọ nʼọzara,
\q2 mmiri iyi ga-ejupụtakwa nʼala kpọrọ nkụ.
\q1 
\v 7 Elu ala ahụ na-ere ọkụ nʼụkwụ ga-aghọ ọdọ mmiri.
\q2 Ala ahụ nke mmiri kọrọ ga-aghọ isi iyi nke mmiri ga-ejupụta.
\q1 Ebe ahụ nkịta ọhịa naara ebi ga-aghọ ala mmiri mmiri;
\q2 ahịhịa, na ahịhịa riidi, na ahịhịa papịrọs, ga-epupụta nʼime ya.
\b
\q1 
\v 8 Okporoụzọ ga-adịkwa nʼebe ahụ,
\q2 nke a ga-akpọ, Okporoụzọ Ịdị Nsọ,
\q2 Ọ ga-adịrị naanị ndị ahụ na-agbaso Ụzọ ahụ.
\q1 Ndị na-adịghị ọcha agaghị eje ije nʼelu ya,
\q2 ndị nzuzu ajọ omume\f + \fr 35:8 \ft Ndị nwere uche gbagọrọ agbagọ\f* agaghị ejegharị nʼelu ya.
\q1 
\v 9 Ọdụm agaghị anọ nso ụzọ ahụ.
\q2 Ọ dịkwaghị anụ ọhịa na-egbu mmadụ ga-aga nʼelu ya.
\q2 E, agaghị ahụ anụ dị otu a nʼebe ahụ.
\q1 Kama, ọ bụ naanị ndị a gbapụtara ga-eje ije na ya.
\q2 
\v 10 Ma ndị ahụ \nd Onyenwe anyị\nd* gbapụtara ga-alọtakwa.
\q1 Ha ga-eji abụ bata na Zayọn;
\q2 ọṅụ na-adịgide ga-adịkwasị nʼisi ha.
\q1 Oke ọṅụ na obi ụtọ ga-ejupụta nʼobi ha.
\q2 Iru ụjụ na ịsụ ude\f + \fr 35:10 \ft Ya bụ, ize ume\f* ga-efelaga.
\c 36
\s1 Senakerib ebuso Jerusalem agha
\p 
\v 1 Nʼafọ nke iri na anọ nke ọchịchị eze Hezekaya, Senakerib, bụ eze Asịrịa, busoro obodo Juda niile e wusiri ike agha, meriekwa ha.
\v 2 Mgbe ahụ, eze Asịrịa sitere na Lakish zipụ ọchịagha ya, ya na usuu ndị agha ijekwuru Hezekaya na Jerusalem. Mgbe ọchịagha ahụ kwụsịrị nʼụzọ mmiri nke ọdọ mmiri dị Elu, nʼụzọ jere nʼebe ọhịa Ọsụ akwa.
\v 3 Eliakịm, nwa Hilkaya, onye nlekọta ụlọeze, na Shebna, bụ ode akwụkwọ eze, na Joa nwa Asaf, onye ndekọ akụkọ ihe mere, pụrụ jekwuru ya.
\p 
\v 4 Ọchịagha ahụ sịrị ha, “Gwanụ Hezekaya:
\pm “ ‘Otu a ka eze ukwu ahụ, bụ eze Asịrịa, na-ekwu, Ọ bụ na gịnị ka ntụkwasị obi gị dabere?
\v 5 Ị na-ekwu na i nwere ndụmọdụ na ike ibu agha, maọbụ naanị egbe ọnụ ka ị na-agba. Ọ bụ onye ka ị na-atụkwasị obi, mere i ji enupu isi nʼokpuru m?
\v 6 Lee, amatara m na ị na-atụkwasị obi nʼIjipt, mkpanaka achara ahụ gbajiri agbaji, nke na-adụwa aka onye ọbụla na-adabere na ya. Otu a ka Fero, eze Ijipt dị nye ndị niile na-atụkwasị ya obi.
\v 7 Ma ọ bụrụ na unu asị m, “Anyị na-atụkwasị \nd Onyenwe anyị\nd* bụ Chineke anyị obi.” Ọ bụghị ya ka Hezekaya wezugara ebe ya niile dị elu na ebe ịchụ aja ya niile, na-asị Juda na Jerusalem, “Unu aghaghị ịkpọ isiala nʼebe ịchụ aja a?”
\pm 
\v 8 “ ‘Ma ugbu a, bịa kwee nna m ukwu, bụ eze Asịrịa nkwa. Aga m enye gị puku ịnyịnya abụọ ma ọ bụrụ na i nwere ike ịchọta ndị ga-agba ha.
\v 9 Ị ga-esi kwa aṅaa jụ otu onyeisi nke dịkarịsịrị nta nʼime ndịisi ọrụ onyenwe m, na-agbanyeghịkwa na i na-atụkwasị obi nʼIjipt maka inweta ụgbọ agha na ndị na-agba ịnyịnya?
\v 10 Tinyere nke a, abịara m ibuso ala a agha na ibibi ya ma ọ bụghị nkwado \nd Onyenwe anyị\nd*? \nd Onyenwe anyị\nd* ya onwe ya gwara m ka m bilie megide obodo a, lakwaa ya nʼiyi.’ ”
\p 
\v 11 Mgbe ahụ Eliakịm, Shebna na Joa sịrị ọchịagha ahụ, “Biko, gwa ndị ohu gị okwu nʼasụsụ Aramaik,\f + \fr 36:11 \ft Asụsụ Aramaik nke ndị Siria, bụ asụsụ mba na mba ji emekọrịta ihe nʼoge ahụ, ma ọ mesịrị ghọọ asụsụ ndị Juu, site na senchuri nke ise tupu a mụọ Kraịst.\f* ebe ọ bụ na anyị na-aghọta ya. Agwala anyị okwu nʼasụsụ Hibru, ebe ndị nọ nʼelu mgbidi ga-anụ.”
\p 
\v 12 Ma ọchịagha ahụ zaghachiri, “Ọ bụ nʼihi naanị nna unu ukwu na nye unu onwe unu ka nna m ukwu ji zite m, ka m kwuo ihe ndị a? Ọ bụghị nʼihi ndị mmadụ ahụ na-anọdụ nʼelu mgbidi, ndị, dịka unu, ha ga-eso rie nsị ha nyụrụ, ṅụọkwa mamịrị ha nyụrụ?”
\p 
\v 13 Mgbe ahụ, ọchịagha ahụ guzoro were oke olu kwuo nʼasụsụ Hibru, sị, “Nụrụnụ okwu niile nke eze ukwu ahụ, bụ eze Asịrịa.
\v 14 Nke a bụ ihe eze sịrị, Unu ekwela ka Hezekaya duhie unu. Ọ pụghị ịzọpụta unu.
\v 15 Unu ekwela ka Hezekaya mee ka unu tụkwasị \nd Onyenwe anyị\nd* obi, mgbe ọ na-asị, ‘Nʼezie, \nd Onyenwe anyị\nd* aghaghị ịnapụta anyị. A gaghị enyefe obodo a nʼaka eze Asịrịa.’
\p 
\v 16 “Unu aṅakwala Hezekaya ntị. Ihe a ka eze Asịrịa kwuru: Pụkwutenụ m, bịanụ ka mụ na unu mee udo. Mgbe ahụ, onye ọbụla nʼime unu ga-eri mkpụrụ si nʼubi vaịnị ya na nke si nʼosisi fiig ya, ṅụọkwa mmiri nke si nʼihe icheta mmiri ya:
\v 17 ruo mgbe m ga-abịa duru unu gaa nʼala dịka nke unu, bụ ala mkpụrụ ọka na nke mmanya ọhụrụ, ala achịcha na ubi vaịnị jupụtara nʼime ya.
\p 
\v 18 “Unu ekwela ka Hezekaya rafuo unu mgbe ọ na-asị, ‘\nd Onyenwe anyị\nd* ga-anapụta anyị.’ O nweela chi niile nke ndị mba ọzọ, nke napụtarala ala ha site nʼaka eze Asịrịa.
\v 19 Olee ebe ka chi ndị Hamat na Apad nọ? Olee ebe ka chi ndị Sefavaim nọkwa? Ha anapụtala Sameria site nʼaka m?
\v 20 Olee chi nʼime chi mba ndị a niile, bụ ndị zọpụtarala ala ha site nʼaka m? Unu si aṅaa chee na \nd Onyenwe anyị\nd* pụrụ ịzọpụta Jerusalem site nʼaka m?”
\p 
\v 21 Ma ndị ahụ niile gbara nkịtị, ha ekwughị ihe ọbụla, nʼihi na eze nyere ha iwu sị, “Unu azaghachila ya.”
\p 
\v 22 Mgbe Eliakịm nwa Hilkaya, onyeisi ọchịchị, na Shebna ode akwụkwọ eze, na Joa nwa Asaf, ode akwụkwọ akụkọ eze laghachikwuuru Hezekaya, ha dọwara uwe ha mgbe ha na-aga igosi ya ịda mba nke obi ha. Ha gwakwara ya ihe niile onyeisi agha ndị Asịrịa kwuru.
\c 37
\s1 Amụma banyere mgbapụta a gbapụtara Jerusalem
\p 
\v 1 Mgbe eze Hezekaya nụrụ nke a, ọ dọwara uwe ya, yikwasị akwa mkpe, baa nʼime ụlọnsọ ukwu \nd Onyenwe anyị\nd*.
\v 2 O zipụrụ Eliakịm, onye nlekọta ụlọeze, Shebna ode akwụkwọ na ndị okenye nʼetiti ndị nchụaja, bụ ndị yikwa akwa mkpe, ka ha jekwuru Aịzaya onye amụma, nwa Emọz.
\v 3 Ha sịrị ya, “Otu a ka Hezekaya sịrị, Ụbọchị taa bụ ụbọchị ahụhụ, ịba mba na nke ihe ihere. Ụbọchị jọgburu onwe ya dịka ụbọchị nwanyị nọ nʼoke ihe mgbu nke ịmụ nwa ma ike adịkwaghị o ji amụpụta nwa ya.
\v 4 Ma eleghị anya \nd Onyenwe anyị\nd* Chineke gị, ga-anụ okwu ahụ nke Rabashaka, bụ ọchịagha, onye nna ya ukwu bụ eze Asịrịa, zitere ịkwa Chineke dị ndụ emo. Eleghị anya \nd Onyenwe anyị\nd* Chineke gị ga-abara ya mba nʼihi okwu ndị a niile o kwuru, bụ ndị ọ nụrụ. Ya mere, kpeere anyị ekpere, anyị bụ ndị fọdụrụ ndụ.”
\p 
\v 5 Mgbe ndị ọrụ eze Hezekaya bịakwutere Aịzaya,
\v 6 ọ sịrị ha, “Otu a ka unu ga-asị nna unu ukwu, ‘Ihe a ka \nd Onyenwe anyị\nd* kwuru: Atụla egwu nʼihi okwu niile nke ị nụrụ, bụ nke ndị na-ejere eze Asịrịa ozi ji kwuluo m.
\v 7 Gee ntị, mgbe ọ nụrụ akụkọ dị aṅaa, aga m eme ka ọ chọọ ịlaghachi nʼobodo nke aka ya. Nʼebe ahụ ka m ga-emekwa ka e jiri mma agha gbuo ya.’ ”
\p 
\v 8 Mgbe ọchịagha ahụ nụrụ na eze Asịrịa e sitela nʼobodo Lakish pụa, ọ laghachiri hụ na eze Asịrịa na-ebuso obodo Libna agha.
\p 
\v 9 Nʼoge ahụ, Senakerib natara ozi na Tiahaka, eze Kush, na-apụta ịbịa ibuso ya agha. Mgbe ọ nụrụ nke a, o zipụrụ ndị ozi ka ha ga zie Hezekaya ozi, sị,
\v 10 “Gwanụ Hezekaya, eze Juda: Ekwela ka Chineke onye ị na-atụkwasị obi duhie gị, mgbe ọ na-asị, ‘Agaghị enyefe Jerusalem nʼaka eze Asịrịa.’
\v 11 Nʼezie a, ị nụla ihe ndị eze Asịrịa mere obodo niile ha busoro agha, otu ha si bibie ha kpamkpam. Ma a ga-anapụtakwa gị onwe gị?
\v 12 Chi niile nke mba niile, ndị ahụ nna nna m ha lara nʼiyi, ha napụtara ha, bụ chi ndị Gozan, Haran, Rezef na nke ndị Eden ndị nọ na Tel Asa?
\v 13 Olee ebe eze ndị Hamat maọbụ eze ndị Apad nọ? Olee ebe eze obodo Lair, Sefavaim, Hena na Iva nọkwa?”
\s1 Ekpere Hezekaya
\p 
\v 14 Mgbe Hezekaya natara akwụkwọ ozi a site nʼaka ndị ozi ahụ, gụọ ya, o weere ya gaa nʼime ụlọnsọ \nd Onyenwe anyị\nd*, gbasaa ya nʼihu \nd Onyenwe anyị\nd*.
\v 15 Hezekaya kpere ekpere nye \nd Onyenwe anyị\nd*, sị:
\v 16 “O, \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, Chineke nke Izrel, onye ocheeze ya dị nʼetiti ndị cherubim, naanị gị bụ Chineke na-achị alaeze niile nke ụwa. Ọ bụkwa naanị gị kere eluigwe na ụwa.
\v 17 Tọọ ntị gị nʼala, o \nd Onyenwe anyị\nd* ma nụrụ; meghee anya gị abụọ \nd Onyenwe anyị\nd*, ka ịhụ; gee ntị nụkwa okwu niile ndị ahụ Senakerib zitere, nke o ji ekwulu Chineke dị ndụ.
\p 
\v 18 “Nʼeziokwu, \nd Onyenwe anyị\nd*, ndị eze Asịrịa alala ndị a niile na ala ha nʼiyi, mee ka ha tọgbọrọ nʼefu,
\v 19 ha atụnyekwala chi ha niile nʼime ọkụ, repịakwa ha, nʼihi na ọ bụghị chi ka ha bụ, kama ha bụ naanị ihe a kpụrụ akpụ, nke mmadụ ji osisi na nkume pịa.
\v 20 Ma ugbu a, \nd Onyenwe anyị\nd* Chineke anyị, biko, zọpụta anyị site nʼaka ya, ka alaeze niile nke ụwa mata na naanị gị \nd Onyenwe anyị\nd* bụ Chineke, na ọ dịkwaghị chi ọzọ ma ọ bụghị gị.”
\s1 Ọdịda Senakerib
\p 
\v 21 Mgbe ahụ, Aịzaya nwa Emọz, zigaara Hezekaya ozi, sị, “Otu a ka \nd Onyenwe anyị\nd*, Chineke Izrel, sịrị, Nʼihi ekpere gị niile nye m banyere Senakerib, eze Asịrịa,
\v 22 nke a bụ okwu \nd Onyenwe anyị\nd* kwuru megide ya.
\q1 “Nwaagbọghọ na-amaghị nwoke, bụ ada Zayọn,
\q2 na-elelị gị anya, jirikwa gị na-eme ihe ọchị,
\q1 Nwaada Jerusalem
\q2 na-efufekwa isi ya mgbe ị na-agbapụ ọsọ.
\q1 
\v 23 Onye ka ị kparịrị ma kwulukwaa?
\q2 Ọ bụ onye ka i sitere na nganga gị
\q1 welie olu okwu gị na anya gị elu megide?
\q2 Ọ bụ megide onye Nsọ nke Izrel?
\q1 
\v 24 I sitere nʼaka ndị ozi gị
\q2 kparịa Onyenwe anyị, kwuluo ya,
\q1 ị sịkwara,
\q2 ‘Eji m ọtụtụ ụgbọala m
\q1 rigoruo ebe dị elu nke nʼelu ugwu niile,
\q2 nʼebe kachasị elu nke ugwu Lebanọn.
\q1 Egbudasịala m osisi sida ya niile toro ogologo,
\q2 na osisi junipa ya niile kachasị mma.
\q1 Ejeruola m na nsọtụ ya kachasị nʼịdị elu,
\q2 bụ ebe kachasị maa mma nʼoke ọhịa ya niile.
\q1 
\v 25 Egwuola m ọtụtụ olulu mmiri nʼala ndị mba ọzọ,
\q2 ṅụkwa mmiri dị nʼebe ahụ.
\q1 Ọ bụ ọbụ ụkwụ m ka m ji mee
\q2 ka isi iyi niile dị nʼIjipt takpọọ.’
\b
\q1 
\v 26 “Ọ bụ na ị nụbeghị?
\q2 Na mgbe ochie ka m kpebiri ya.
\q1 Nʼụbọchị ndị ahụ gara aga ka nọ pịa ọpịpịa ya,
\q2 ugbu a, emeela m ka ọ bịa na mmezu,
\q1 na ị meela ka obodo nke mgbidi gbara gburugburu,
\q2 ghọọ mkpokọta nkume.
\q1 
\v 27 Ndị bi nʼime ha, ndị a napụrụ ike ha nwere,
\q2 bụ ndị dara mba, ndị e tinyekwara nʼọnọdụ ihere.
\q1 Ha dịka ahịhịa ndụ puru nʼala ubi,
\q2 na ome na-epupụta epupụta,
\q1 nakwa ahịhịa na-etopụta nʼelu ụlọ
\q2 nke anwụ na-achakpọ tupu o tolite.
\b
\q1 
\v 28 “Ma amaara m ebe ị nọ ọnọdụ,
\q2 marakwa ọpụpụ gị na mbata gị,
\q2 marakwa oke iwe gị megide m.
\q1 
\v 29 Nʼihi ọnụma dị gị nʼobi megide m,
\q2 nʼihi na mkparị gị eruola m ntị,
\q1 aga m etinye nko\f + \fr 37:29 \ft Ọ bụrụ na ndị agha Asịrịa e merie obodo nʼagha, ha na-eji nko tinye nʼimi ndị ha dọtara nʼagha, jirikwa eriri igwe tinye nʼọnụ ha.\f* m nʼimi gị,
\q2 werekwa mkpụmkpụ igwe m kpachie egbugbere ọnụ gị,
\q1 mee ka ị laghachi
\q2 site nʼụzọ ahụ nke i siri bịa.
\p 
\v 30 “Ma nke a ga-abụ ihe ịrịbama\f + \fr 37:30 \ft Ya bụ, akara\f* nye gị, Hezekaya.
\q1 “Nʼafọ a, unu ga-eri ihe na-epu nʼonwe ya,
\q2 nʼafọ nke abụọ unu ga-eri ihe si na nke ahụ pupụta.
\q1 Ma nʼafọ nke atọ ghaanụ mkpụrụ ubi, weenụ ihe ubi,
\q2 kụọ vaịnị nʼubi vaịnị, riekwanụ mkpụrụ ha.
\q1 
\v 31 Ọzọkwa, ndị fọdụrụ nʼalaeze Juda
\q2 ga-agba mgbọrọgwụ nʼokpuru ala, mịkwaa mkpụrụ nʼelu.
\q1 
\v 32 Nʼihi na ọ bụ site na Jerusalem ka ndị fọdụrụ ga-esi pụta,
\q2 otu ndị fọdụrụ ndụ\f + \fr 37:32 \ft Gbapụrụ a gbapụ maka ụjọ\f* ga-esitekwa nʼugwu Zayọn pụta.
\q1 Ọ bụ site nʼịnụ ọkụ nʼobi nke \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile,
\q2 ga-emezu nke a.
\p 
\v 33 “Ya mere, nke a bụ ihe \nd Onyenwe anyị\nd* kwuru banyere eze Asịrịa.
\q1 “Ọ gaghị azọbata ụkwụ ya nʼime obodo a
\q2 maọbụ gbaa ọ bụladị otu àkụ nʼebe a.
\q1 Ọ gaghị eji ọta jegharịa nʼọnụ ụzọ ama ya,
\q2 maọbụ wuo mgbidi nnọchibido megide ya.
\q1 
\v 34 Ụzọ o si bịa ka ọ ga-esi laghachi;
\q2 ọ gaghị abanye nʼobodo a.”
\q2 Otu a ka \nd Onyenwe anyị\nd* kwubiri ya.
\q1 
\v 35 “Aga m echebe obodo a, zọpụtakwa ya nʼihi aha m,
\q2 na nʼihi Devid, bụ ohu m.”
\p 
\v 36 Mmụọ ozi \nd Onyenwe anyị\nd* pụrụ gaa tigbuo otu puku narị na puku iri asatọ na ise nʼụlọ ikwu ndị Asịrịa. Mgbe ndị mmadụ tetara nʼisi ụtụtụ, lee, ozu ka ha jupụtara ebe niile.
\v 37 Ya mere, Senakerib, eze Asịrịa, biliri ije, laghachi nʼala ya. Ọ laghachiri biri nʼobodo Ninive.
\p 
\v 38 Otu ụbọchị, mgbe ọ nọ na-akpọ isiala nʼụlọ chi ya a na-akpọ Nisrọk, ụmụ ya ndị ikom aha ha bụ Adramelek na Shareza were mma agha gbuo ya. Ha gbapụrụ ọsọ gbaga nʼala Ararat. Isahadon, bụ nwa ya nwoke ghọrọ eze nʼọnọdụ ya.
\c 38
\s1 Ọrịa Hezekaya rịara
\p 
\v 1 Nʼoge ahụ, Hezekaya rịara ọrịa ruo na ọ gaara anwụ. Aịzaya onye amụma, nwa Emọz, bịakwutere ya, sị ya, “Otu a ka \nd Onyenwe anyị\nd* sịrị: Dozie ezinaụlọ gị, nʼihi na ị ga-anwụ. Ị gaghị esite nʼute ọrịa a bilie.”
\p 
\v 2 Hezekaya tụgharịrị chee ihu ya nʼaja ụlọ kpee ekpere nye \nd Onyenwe anyị\nd* sị,
\v 3 “Chetakwa, \nd Onyenwe anyị\nd*, otu m si jegharịa nʼihu gị nʼikwesị ntụkwasị obi, jiri obi m niile fee gị ofufe, ma meekwa ihe dị mma nʼanya gị.” Hezekaya bekwara akwa nke ukwuu.
\p 
\v 4 Mgbe ahụ, okwu nke \nd Onyenwe anyị\nd* rutere Aịzaya,
\v 5 “Gaa, gwa Hezekaya, sị ‘Otu a ka \nd Onyenwe anyị\nd*, bụ Chineke nna gị Devid kwuru, anụla m ekpere gị, ahụkwala m anya mmiri akwa gị. Aga m atụkwasị afọ iri na ise nʼụbọchị ndụ gị.
\v 6 Aga m anapụtakwa gị na obodo a site nʼaka eze Asịrịa. Aga m echebe obodo a.
\p 
\v 7 “ ‘Nke a bụ ihe ịrịbama site nʼaka \nd Onyenwe anyị\nd* nye gị, na \nd Onyenwe anyị\nd* ga-emezu ihe a nke o kwere na nkwa.
\v 8 Aga m eme ka anyanwụ laa azụ nzọ ụkwụ iri nʼihe nrigo ụlọ elu Ehaz.’ ” Ya mere, anyanwụ laghachiri azụ nzọ ụkwụ iri.
\p 
\v 9 Ederede Hezekaya eze Juda, mgbe ọrịachara ọrịa, nwee ahụ ike:
\q1 
\v 10 Asịrị m, “Ọ bụ nʼoge m bụ okorobịa
\q2 ka m ga-agabiga nʼọnụ ụzọ nke ọnwụ,
\q2 bụrụ onye anapụrụ oge ndụ m nke fọdụrụ afọdụ?”
\q1 
\v 11 Asịrị m, “Ọ dịkwaghị mgbe m ga-ahụ \nd Onyenwe anyị\nd* ọzọ
\q2 nʼala ndị dị ndụ,
\q1 m gaghị elegidekwa mmadụ ibe m anya ọzọ,
\q2 maọbụ bie nʼetiti ndị bi nʼime ụwa a.
\q1 
\v 12 Esila nʼọnọdụ ya bupụ ụlọ m
\q2 dịka ụlọ ikwu nke onye ọzụzụ atụrụ.
\q1 Apịakọtala m ndụ m dịka ọkpa akwa si apịakọta akwa
\q2 o bipụla ndụ site nkwe-akwa,
\q2 ehihie na nʼabalị, ị mere ka ndụ m gwụsịa.
\q1 
\v 13 Enwere m ntachiobi chere chi ọbụbọ.
\q2 Ma dịka ọdụm ka ọ na-agbaji ọkpụkpụ m niile.
\q2 Ehihie na nʼabalị ka ị na-eme ka ndụ m gwụsịa.
\q1 
\v 14 Dịka eleke maọbụ ụgbala ka m na-ebe akwa.
\q2 Ana m asụ ude dịka nduru na-eru ụjụ.
\q1 Ike gwụrụ anya m nʼihi ile anya nʼeluigwe.
\q2 Anọ m nʼọnọdụ mkpagbu, Onyenwe anyị, bịa nyere m aka.”
\b
\q1 
\v 15 Ma gịnị ka m ga-ekwu?
\q2 Ya onwe ya gwara m sị na ọ bụ ya mere nke a.
\q1 M ga-eji obi umeala gagharịa ụbọchị ndụ m niile
\q2 nʼihi ihe mwute nke obi m.
\q1 
\v 16 Onyenwe anyị, ọ bụ nʼihi ihe ndị a ka mmadụ ji adị ndụ.
\q2 Mmụọ m na-adịkwa ndụ nʼime ha.
\q1 I nyeghachila m ahụ ike,
\q2 mee ka m dị ndụ.
\q1 
\v 17 Nʼezie, ọ bụ nʼihi ọdịmma m,
\q2 ka m ji taa ahụhụ nke ihe mgbu dị otu a.
\q1 Nʼịhụnanya gị ka ị zọpụtara m
\q2 site nʼolulu nke ịla nʼiyi.
\q1 I werela mmehie m niile
\q2 wefee nʼazụ gị.
\q1 
\v 18 Nʼihi nʼala mmụọ agaghị eto gị,
\q2 ọnwụ agakwaghị abụku gị abụ otuto.
\q1 Ndị na-arịda nʼolulu
\q2 agaghị ele anya ikwesi ntụkwasị obi gị.
\q1 
\v 19 Ọ bụ ndị dị ndụ, e, naanị ndị dị ndụ ga-eto gị otuto,
\q2 dị ka m na-eme taa.
\q1 Ọ bụ otu ọgbọ na-eme ka ọgbọ na-eso ha
\q2 mata ihe banyere ikwesi ntụkwasị obi gị.
\b
\q1 
\v 20 \nd Onyenwe anyị\nd* ga-azọpụta m,
\q2 anyị ga-abụ abụ kpọọ ụbọ akwara
\q1 nʼụbọchị niile nke ndụ anyị,
\q2 nʼime ụlọnsọ ukwu \nd Onyenwe anyị\nd*.
\p 
\v 21 Aịzaya ekwuolarị sị, “Kwadoonụ mmanụ fiig dị ọkụ tee ya nʼelu etuto ahụ, ahụ ga-adịkwa ya mma.”
\p 
\v 22 Hezekaya jụrụ sị, “Gịnị ga-abụ ihe ịrịbama na m ga-aga nʼụlọnsọ ukwu \nd Onyenwe anyị\nd*?”
\c 39
\s1 Ndị ozi si Babilọn bịa
\p 
\v 1 Nʼoge ahụ, Merodak-Baladan, nwa Baladan, bụ eze Babilọn zigaara Hezekaya akwụkwọ ozi ekele na onyinye, nʼihi na ọ nụrụ na Hezekaya rịara ọrịa ma nwe ahụ ike.
\v 2 Hezekaya nabatara ndị ozi ahụ nke ọma gosi ha ihe ndị dị nʼụlọakụ ya, ọlaọcha, na ọlaedo, ụda dị iche iche na-esi isi ụtọ, ezigbo mmanụ oliv, ụlọ niile ebe ngwa agha ya niile dị, na ihe niile bụ akụ o nwere. Ọ dịghị ihe dị nʼụlọeze ya maọbụ nʼalaeze ya niile nke ọ na-egosighị ha.
\p 
\v 3 Mgbe ahụ, Aịzaya onye amụma jekwuru eze Hezekaya jụọ ya sị, “Gịnị ka ndị ikom ndị ahụ kwuru? Ebeekwa ka ha si bịakwute gị?”
\p Hezekaya zara sị, “Ọ bụ nʼala dị anya ka ha si bịakwute m, ha si Babilọn.”
\p 
\v 4 Onye amụma jụrụ, “Gịnị ka ha hụrụ nʼụlọ gị?”
\p Hezekaya zara sị, “Ihe niile nke dị nʼụlọ m ka ha hụrụ. Ọ dịghị ihe niile dị nʼụlọakụ m nke m na-egosighị ha.”
\p 
\v 5 Mgbe ahụ, Aịzaya sịrị Hezekaya, “Gee ntị nụrụ okwu \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile.
\v 6 Lee, oge na-abịa mgbe a ga-eburu ihe niile dị nʼụlọeze gị, na ihe niile nke nna nna gị ha debere nʼụlọakụ ruo taa, buru ha bulaa Babilọn. Ọ dịkwaghị ihe ga-afọdụ, otu a ka \nd Onyenwe anyị\nd* kwuru.
\v 7 A ga-ebupụ ụfọdụ nʼime ụmụ gị, ndị bụ ahụ na ọbara gị, ndị a ga-amụtara gị, buru ha pụọ nʼebe dị anya, ha ga-abụ ndị onozi nʼụlọeze nke eze Babilọn.”
\p 
\v 8 Hezekaya zaghachiri, “Okwu \nd Onyenwe anyị\nd* nke i kwuru dị mma.” Nʼihi na o chere nʼobi ya sị, “Udo na nchekwa ga-adị nʼoge ndụ m.”
\c 40
\s1 Nkasiobi dịrị ndị Chineke
\q1 
\v 1 Kasịenụ ndị m obi, kasịenụ ha obi,
\q2 ka Chineke gị kwuru.
\q1 
\v 2 Were nwayọọ gwa Jerusalem okwu,
\q2 gwa ya;
\q1 na ụbọchị ọjọọ ya niile agwụla,
\q2 na a kwụzuola ụgwọ mmehie ya niile,
\q1 na o sitela nʼaka \nd Onyenwe anyị\nd*
\q2 nata ụgwọ ọrụ karịrị okpukpu abụọ nke mmehie ya niile.
\b
\q1 
\v 3 Otu onye na-eti mkpu sị,
\q1 “Dozienụ ụzọ nye \nd Onyenwe anyị\nd*
\q2 nʼime ọzara,
\q1 meenụ ka ụzọ atụliri atụli
\q2 guzozie kwem nʼime ọzara nye Chineke anyị.
\q1 
\v 4 A ga-eme ka ndagwurugwu ọbụla dị elu,
\q2 ugwu ọbụla na ugwu nta ọbụla ka a ga-emekwa ka ọ dị ala,
\q1 ebe niile dị mkputamkpu ka a ga-eme ka o guzo kwem,
\q2 meekwa ka ebe niile dị ndakoro ndakoro dịrị larịị.
\q1 
\v 5 Nʼihi na a ga-ekpughepụ ebube Onyenwe anyị,
\q2 mmadụ niile ga-ahụkọkwa ya nʼotu.
\q1 Nʼihi na ọnụ \nd Onyenwe anyị\nd* ekwuola ya.”
\b
\q1 
\v 6 Olu ahụ sịrị, “Tie mkpu!”
\q2 Ma ajụrụ m sị, “Gịnị ka m ga-eti?”
\b
\q1 “Mmadụ niile dị ka ahịhịa,
\q2 ikwesi ntụkwasị obi ha niile dịkwa ka okoko osisi ọhịa.
\q1 
\v 7 Ahịhịa na-akpọnwụ, okoko osisi na-achanwụ,\f + \fr 40:7 \ft Otu a ka ọ dịrị mmadụ.\f*
\q2 nʼihi nʼokuku ume nke \nd Onyenwe anyị\nd* na-ekukwasị ya.
\q2 Nʼezie, ahịhịa ka ndị mmadụ bụ.
\q1 
\v 8 E, ahịhịa na-akpọnwụ, okoko na-achanwụkwa,
\q2 ma okwu Chineke anyị na-eguzogide ruo mgbe ebighị ebi.”
\b
\q1 
\v 9 Gị onye na-eweta oziọma nye Zayọn,
\q2 rigoro nʼelu ugwu;
\q1 gị onye na-eweta oziọma nye Jerusalem,
\q2 welie olu gị elu tisie mkpu ike;
\q1 e, tisie mkpu ike, atụla egwu.
\q2 Gwa obodo niile nke Juda okwu sị ha:
\q2 “Chineke unu na-abịa.”
\q1 
\v 10 Lee, Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* na-abịa nʼike,
\q2 ike aka ya ka o ji achị.
\q1 Lee, ụgwọ ọrụ ya dị ya nʼaka,
\q2 ọ na-abịa ịkwụghachi ụgwọ.
\q1 
\v 11 Ọ ga-azụ igwe atụrụ ya dịka onye ọzụzụ atụrụ.
\q2 Ọ na-achịkọta ụmụ atụrụ.
\q1 Nʼaka ya abụọ ka ọ ga-ekuru ụmụ atụrụ nʼobi ya.
\q2 Ọ ga-eji nwayọọ duo ndị na-enye ụmụ ara.
\b
\q1 
\v 12 Onye jirila ọbụ aka ya tụọ mmiri dị nʼoke osimiri?
\q2 Maọbụ onye jiri ntu-aka ya tụọ mbara eluigwe?
\q1 Onye ka ọ bụ jirila nkata kute uzuzu?
\q2 Maọbụ jiri ihe ọtụtụ tụọ ugwu ukwu?
\q2 Onye kwa ji ihe ọtụtụ tụọ ugwu nta?
\q1 
\v 13 Onye nwere ike ịghọta Mmụọ nke \nd Onyenwe anyị\nd*,
\q2 maọbụ dịka onye ndụmọdụ Onyenwe anyị na-ezi ya ihe?
\q1 
\v 14 Ọ bụ onye ka \nd Onyenwe anyị\nd* gakwuru gbaa izu ka ọ kọwaara ya ihe,
\q2 ọ bụ onye ziri ya ụzọ bụ nke dị mma?
\q1 Onye bụ onye ahụ kuziri ya ihe ọmụma,
\q2 maọbụ gosi ya ụzọ nke nghọta?
\b
\q1 
\v 15 Nʼezie, mba niile dị iche iche dịka otu ntupụta mmiri tanyere nʼime efere;
\q2 a na-agụnye ha dịka uzuzu dị nʼelu ihe ọtụtụ e ji atụ ihe;
\q2 ọ na-atụ ala ndị ahụ mmiri gbara gburugburu dịka a ga-asị na ha bụ uzuzu ọma na-adịghị arọ.
\q1 
\v 16 Osisi niile dị na Lebanọn ezughị iji kwanye ọkụ e ji a chụrụ Chineke anyị aja.
\q2 Otu a kwa, anụmanụ niile dị nʼọhịa Lebanọn niile erughị iji chụọrọ Chineke anyị aja.
\q1 
\v 17 O nweghị ihe ọbụla mba niile dị nʼụwa bụ nʼihu ya;
\q2 ọ na-agụ ha ka ihe na-abaghị uru,
\q2 dịka ihe na-erughị ihe efu.
\b
\q1 
\v 18 Onye kwanụ ka unu ga-eji tụnyere Chineke?
\q2 Olee ụdị oyiyi unu ga-eji kọwaa ihe o yiri?
\q1 
\v 19 Ma gbasara arụsị apịrị apị, nke onye na-akwa nka ọla tụrụ,
\q2 nke onye ọkpụ ụzụ ọlaedo na-eji ọlaedo techie ya,
\q2 ọ bụkwa ya ka ọ na-akpụrụ ọlaọcha.
\q1 
\v 20 Ma onye ogbenye na-enweghị ịchụ aja dị otu a
\q2 na-ahọrọ osisi nke na-agaghị ere ure.
\q1 Ọ na-akpọtara onwe ya onye maara akwa ǹka osisi nke ọma,
\q2 onye ga-apịtara ya oyiyi arụsị nke na-agaghị ada ada.
\b
\q1 
\v 21 Ọ bụ na unu amaghị?
\q2 Ọ ga-abụ na unu anụbeghị ya?
\q1 Ọ pụtara na a kọbereghị unu ya site na mmalite?
\q2 Ọ bụ na unu aghọtabeghị site na mgbe a tọrọ ntọala ụwa?
\q1 
\v 22 Na Chineke nọ nʼelu ocheeze ya nke gbara ụwa gburugburu.
\q2 Ndị nọ nʼụwa dịkwa ka ụmụ ụkpana.
\q1 Ọ bụ ya tụsara eluigwe dịka akwa,
\q2 were ya mere ebe obibi ya.
\q1 
\v 23 Ọ na-eweda ndị ukwu niile nke ụwa,
\q2 mee ha ka ha ghọọ ihe efu.
\q1 
\v 24 Mgbe a na-ele ha anya, ha na-adị ka ihe a kụrụ nʼubi nke na-epute epute.
\q2 Mgbe a kụrụ ha, mgbe ha na-epute,
\q2 mgbe ha na-amanye mgbọrọgwụ nʼala,
\q1 mgbe ahụ kwa ka Onyenwe anyị na-ezite ifufe nke na-akpọnwụ ha,
\q2 bufuo ha dịka ahịhịa kpọrọ nkụ.
\b
\q1 
\v 25 “Olee onye unu ga-eji tụnyere m?
\q2 Onye kwa ka mụ na ya ha?” Nke a bụ ihe Onye Nsọ Izrel na-ajụ.
\q1 
\v 26 Lee anya nʼeluigwe;
\q2 onye kere kpakpando ndị a niile?
\q1 Onye na-edu ha dịka onye ọzụzụ atụrụ?
\q2 Onye na-akpọ nke ọbụla aha ya?
\q1 Ọ bụ site nʼamamihe na ike ya dị ukwuu,
\q2 ka o ji eme ka ha ghara ịkpafu.
\b
\q1 
\v 27 Ọ bụ nʼihi gịnị ka i ji na-asị, gị Jekọb?
\q2 Ọ bụkwa gịnị mere gị Izrel, i ji na-atamu ntamu na-asị,
\q1 “Ụzọ m bụ ihe ezonarịrị \nd Onyenwe anyị\nd*,
\q2 Chineke adịghị etinyekwa anya ya nʼihe metụtara m?”
\q1 
\v 28 Ọ bụ na ị matabeghị?
\q2 Ọ ga-abụ na ị nụbeghị ya?
\q1 \nd Onyenwe anyị\nd* bụ Chineke nke mgbe niile ebighị ebi,
\q2 Onye kere nsọtụ niile nke ụwa.
\q1 Ọ naghị ada mba; ike adịghịkwa agwụ ya.
\q2 O nwekwaghị onye pụrụ ịmata ịdị omimi nke nghọta ya.
\q1 
\v 29 Ọ na-enye ndị na-ada mba ike,
\q2 na-emekwa ka ndị na-enweghị ume nwee ume.
\q1 
\v 30 Ọ bụladị ụmụ okorobịa na-ada mba, ike na-agwụkwa ha.
\q2 E, ụmụ okorobịa na-asọ ngọngọ daa,
\q1 
\v 31 ma ndị niile olileanya ha dị na \nd Onyenwe anyị\nd*,
\q2 ga-agbanwe ike ha, nweta ike ọhụrụ.
\q1 Ha ga-eji nku felie elu dịka ugo.
\q2 Ha ga-agba ọsọ, ma ike agaghị agwụ ha;
\q2 ha ga-aga ije ma ha agaghị ada mba.
\c 41
\s1 Onye na-enyere Izrel aka
\q1 
\v 1 Nọrọnụ jụụ nʼihu m, unu mba niile mmiri gbara gburugburu!
\q2 Ka mba niile gbanwee ike ha.
\q1 Ka ha pụta kwuo okwu.
\q2 Ka anyị zukọtaa nʼebe ikpe ikpe.
\b
\q1 
\v 2 “Onye kpọtere onye a sitere nʼọwụwa anyanwụ na-abịa,
\q2 onye e sitere nʼezi omume kpọọ ya ije ozi?
\q1 O weere mba niile nyefee ya nʼaka,
\q2 meriekwa ndị eze nʼihu ya.
\q1 O ji mma agha ya tie ha mee ka ha ghọọ uzuzu,
\q2 jiri ụta ya mee ka ha ghọọkwa igbugbo ọka nke ifufe na-ebugharị.
\q1 
\v 3 Ọ na-achụ ha ọsọ, ma na-agakwa nʼihu na-enweghị mmerụ ahụ ọbụla.
\q2 E, ọ na-agbasokwa ụzọ nke ọ na-agabeghị mbụ.
\q1 
\v 4 Ọ bụ onye rụrụ ọrụ dị otu a mezukwa ya,
\q2 na-akpọ ọgbọ niile site na mmalite?
\q1 Ọ bụ mụ onwe m, bụ \nd Onyenwe anyị\nd*, onye dị siterị na mbido ihe niile,
\q2 onye ga-adịgidekwa ruo ọgwụgwụ ihe niile. Ọ bụ mụ onwe m bụ onye ahụ.”
\b
\q1 
\v 5 Mba niile bi nʼala mmiri gbara gburugburu ahụla ọrụ m rụrụ. Ha hụrụ ya tụọ egwu;
\q2 ndị niile bi na nsọtụ ụwa na-amakwa jijiji.
\q1 Ha zukọtara bịa nso.
\q2 
\v 6 Onye ọbụla nʼime ha na-agba ibe ya ume na-asị,
\q2 “Nwee obi ike.”
\q1 
\v 7 Onye ọkpụ ụzụ ọla na-agba onye ọkpụ ụzụ ọlaedo ume.
\q2 Onye ji mkpirisi igwe eme ka ihe dị mụrụmụrụ,
\q2 na-agba onye na-akụ osiama ume.
\q1 Otu onye na-ekwu banyere nkpukọta ya, na-asị, “A kpụziri ya akpụzi.”
\q2 Onye nke ọzọ, na-eji ǹtu kpọgidesie ihe ahụ apịrị apị ike ka ọ ghara ịda.
\b
\q1 
\v 8 “Ma gị onwe gị, Izrel, ohu m,
\q2 Jekọb, onye m họpụtara,
\q2 gị mkpụrụ Ebraham, bụ enyi m.
\q1 
\v 9 Esitere m na nsọtụ niile nke ụwa kpọghachi unu,
\q2 gwa unu na ohu m ka unu bụ,
\q1 nʼihi na ahọpụtala m unu,
\q2 agakwaghị m ahapụ unu.
\q1 
\v 10 Ya mere, unu atụla egwu nʼihi na anọnyeere m unu.
\q2 Ka obi ghara ịlọ unu mmiri nʼihi na abụ m Chineke unu.
\q1 Aga m eme ka unu dịrị ike; aga m enyere unu aka;
\q2 aga m ejikwa aka nri nke ezi omume m kwagide unu.
\b
\q1 
\v 11 “Lee! A ga-etinye ndị niile iwe ha dị ọkụ megide unu nʼọnọdụ ihe ihere,
\q2 ihere ga-emekwa ha.
\q1 Ndị niile na-eguzogide unu ga-aghọ ihe efu,
\q2 bụrụ ndị lara nʼiyi.
\q1 
\v 12 Unu ga-ele anya ha, chọọ ha,
\q2 ma ọ dịghị onye ọbụla nʼime ha ga-afọdụ ndụ.
\q1 Ndị a na-ebuso unu agha
\q2 ga-abụ naanị ihe efu.
\q1 
\v 13 Nʼihi na mụ onwe m, bụ \nd Onyenwe anyị\nd* Chineke gị,
\q2 onye na-ejidesi aka nri gị ike
\q1 bụ onye na-asị gị, ‘Atụla egwu;
\q2 aga m enyere gị aka.’
\q1 
\v 14 Atụla egwu, gị idide, bụ Jekọb,
\q2 unu Izrel dị nta, atụla egwu,
\q1 nʼihi na mụ onwe m ga-enyere gị aka,” otu a ka \nd Onyenwe anyị\nd* kwupụtara,
\q2 Onye mgbapụta gị, bụ Onye nsọ nke Izrel.
\q1 
\v 15 “Lee, aga m eme ka unu ghọọ igwe ọhụrụ eji azọcha mkpụrụ ọka
\q2 nke dị nkọ, nwekwa ọtụtụ eze.
\q1 Unu ga-azọcha ugwu niile zọpịa ha,
\q2 meekwa ka ugwu nta niile dịka igbugbo ọka.
\q1 
\v 16 Unu ga-ayọgharị, fụchaa ha; ikuku ga-eburu ha bufuo,
\q2 oke ikuku ga-ekposasị ha.
\q1 Ma unu ga-aṅụrị ọṅụ nʼime \nd Onyenwe anyị\nd*,
\q2 nyaakwa isi nʼime Onye dị nsọ nke Izrel.
\b
\q1 
\v 17 “Mgbe mmiri ọṅụṅụ kọrọ ndị ogbenye na ndị mkpa na-akpa,
\q2 mgbe ha na-enweghị ike ịchọta mmiri ọṅụṅụ
\q2 mgbe akpịrị na-akpọ ha nkụ nʼihi agụụ mmiri,
\q1 mụ onwe m bụ \nd Onyenwe anyị\nd* ga-aza ha.
\q2 Mụ onwe m, bụ Chineke nke Izrel, agaghị agbakụta ha azụ.
\q1 
\v 18 Aga m eme ka mmiri site nʼala kpọrọ nkụ nke ugwu niile na-erudatara ha.
\q2 Aga m eme ka isi iyi na-asọpụta na ndagwurugwu niile.
\q1 Aga m eme ka mmiri jupụta nʼọzara,
\q2 meekwa ka isi iyi mmiri site nʼala kpọrọ nkụ na-asọpụta.
\q1 
\v 19 Aga m akụ nʼọzara,
\q2 osisi sida, na osisi akashia, na osisi mietul, na osisi oliv.
\q1 M ga-eji osisi junipa,
\q2 na osisi saipres na osisi fịa, kụkọta ha ọnụ nʼala ahụ tọgbọrọ nʼefu,
\q1 
\v 20 ka ndị mmadụ hụ, matakwa,
\q2 tuleekwa uche ma ghọta,
\q1 na ọ bụ aka \nd Onyenwe anyị\nd* mere nke a,
\q2 na ọ bụ Onye nsọ nke Izrel kere ya.
\b
\q1 
\v 21 “Wepụtanụ mkpesa unu,”
\q2 ka \nd Onyenwe anyị\nd* sịrị,
\q1 “Doo okwu unu nʼusoro,”
\q2 ka Eze nke Jekọb na-asịkwa.
\q1 
\v 22 “Ka ha bubata arụsị ndị a, ma gwa anyị,
\q2 ihe gaje ime.
\q1 Ka ha gwa anyị ihe mere nʼoge gara aga, ihe ha pụtara,
\q2 ka anyị nwee ike tulee ha
\q2 matakwa ihe ga-abụ ikpeazụ ha.
\q1 Maọbụ kwupụtara anyị ihe ndị ahụ na-abịa,
\q2 
\v 23 gwa anyị ihe ọdịnihu ji,
\q2 ka anyị mara na unu bụ chi.
\q1 Meenụ ezi ihe, maọbụ ihe ọjọọ,
\q2 nke ga-eme ka anya gbagwojuo anyị, ka anyị jupụtakwa nʼegwu.
\q1 
\v 24 Ma unu dị nta karịa ihe efu.
\q2 Ọrụ unu niile bụkwa ihe na-abaghị uru.
\q2 Onye họọrọ unu emeela onwe ya ihe arụ.
\b
\q1 
\v 25 “Akpọliela m otu onye site nʼakụkụ ugwu, ọ na-abịakwa.
\q2 Otu onye na-asọpụrụ aha m sikwa nʼọwụwa anyanwụ.
\q1 Ọ na-azọpịa ndị ọchịchị niile dịka ha bụ ụrọ,
\q2 ọ ga-azọpịa ha dịka onye na-akpụ ite si azọpịa aja ụrọ.
\q1 
\v 26 O kwuru maka nke a site na mmalite, ka anyị nwee ike mara,
\q2 maọbụ mgbe na o mebeghị, ka anyị nwee ike sị, ‘Ihe o kwuru ziri ezi’?
\q1 O nweghị onye kwuru ihe banyere nke a,
\q2 o nweghịkwa onye mere ka amata ya,
\q2 o nwekwaghị onye si nʼọnụ gị nụ okwu ọbụla.
\q1 
\v 27 Abụ m onye mbụ gwara Zayọn, ‘Lee, nʼebe a ka ha dị!’
\q2 Ọ bụ m ziteere Jerusalem onyeozi oziọma.
\q1 
\v 28 Elegharịrị m anya ma o nweghị onye m hụrụ.
\q2 O nweghị onye nọ nʼetiti chi ha nke nwere ike inye ndụmọdụ;
\q2 o nweghị onye inye ọsịsa ajụjụ mgbe m jụrụ ha.
\q1 
\v 29 Lee, ha niile bụ ụgha!
\q2 Ọrụ ha niile pụtara ihe efu,
\q2 arụsị ha niile awuru awu bụ naanị ifufe na ọgbaaghara.
\c 42
\s1 Ohu \nd Onyenwe anyị\nd*
\q1 
\v 1 “Lee ohu m, onye m na-agba ume,
\q2 onye m họpụtara, onye ihe ya na-atọ mkpụrụobi m ụtọ.
\q1 Aga m eme ka Mmụọ m dịrị nʼime ya.
\q2 Ọ ga-emekwa ka ikpe ziri ezi rute mba niile aka.
\q1 
\v 2 Ọ gaghị eti mkpu maọbụ welie olu ya kwaa akwa,
\q2 maọbụ welie olu ya elu, ọ gaghị eme ka a nụ olu ya nʼezi.
\q1 
\v 3 Ọ gaghị agbaji ahịhịa riidi\f + \fr 42:3 \ft Ya bụ, osisi achara\f* azọpịara azọpịa,
\q2 maọbụ menyụọ ogho oriọna na-enwu ntakịrị ntakịrị.
\q1 Ọ ga-esite nʼikwesị ntụkwasị obi wepụta ikpe ziri ezi.
\q2 
\v 4 Ọ gaghị asọ ngọngọ maọbụ daa mba,
\q1 ruo mgbe o hiwere ikpe ziri ezi nʼelu ụwa.
\q2 Ọ bụkwa nʼozizi ya ka agwa etiti niile ga-atụkwasị olileanya ha.”
\b
\q1 
\v 5 Nke a bụ ihe Chineke bụ \nd Onyenwe anyị\nd* kwuru,
\q1 onye ahụ kere eluigwe niile, onye gbasapụkwara ha,
\q2 onye gbasapụkwara ụwa nʼihe niile nke si nʼime ya apụta,
\q2 onye na-enye ndị niile bi nʼime ya ume,
\q2 na-enyekwa ndị na-agagharị nʼime ya ndụ.
\q1 
\v 6 “Mụ onwe m, bụ \nd Onyenwe anyị\nd*, akpọla gị ka i gosi ezi omume m.
\q2 Aga m echebe gị, gbaa gị ume,
\q1 nʼihi na eweere m gị nye ndị m
\q2 ka ị bụrụ ihe imesi ọgbụgba ndụ m ike.
\q2 Ị ga-abụkwa ìhè nye mba niile.
\q1 
\v 7 Ị ga-emeghe anya ndị kpuru ìsì,
\q2 gbapụtakwa ndị nọ nʼụlọ mkpọrọ,
\q2 meekwa ka ndị nọ nʼụlọ mkpọrọ gbara ọchịchịrị nwere onwe ha.
\b
\q1 
\v 8 “Mụ onwe m bụ \nd Onyenwe anyị\nd*! Nke a bụkwa aha m.
\q2 Agaghị m enye onye ọzọ ugwu na nsọpụrụ m.
\q2 Mụ na arụsị a pịrị apị agakwaghị azọ otuto m.
\q1 
\v 9 Lee ihe ochie emezuola
\q2 ma nke ọhụrụ ka m na-ekwupụta.
\q1 Tupu ha pụta ìhè
\q2 ana m akpọsa ha nye unu.”
\s1 Abụ otuto nye \nd Onyenwe anyị\nd*
\q1 
\v 10 Bụkuonụ \nd Onyenwe anyị\nd* abụ ọhụrụ; tookwanụ ya,
\q2 unu ndị niile bi na nsọtụ niile nke ụwa,
\q1 unu ndị na-arịda nʼosimiri, na ihe niile bi nʼime ya.
\q2 Toonu ya unu ndị bi nʼala ebe mmiri gbara gburugburu.
\q1 
\v 11 Ka ọzara na obodo niile dị nʼime ya welie olu ha elu,
\q2 ka ndị bi na Keda ṅụrịa ọṅụ.
\q1 Ka ndị bi na Sela tie mkpu ọṅụ,
\q2 ka ha si nʼelu ugwu niile tisie mkpu ọṅụ ike.
\q1 
\v 12 Ka ha nye \nd Onyenwe anyị\nd* ebube,
\q2 kpọsaakwa otuto ya nʼala niile mmiri gbara gburugburu.
\q1 
\v 13 \nd Onyenwe anyị\nd* ga-apụta buo agha dịka dike.
\q2 Ọ bụ site nʼịnụ ọkụ nʼobi nke onye agha ka ọ ga-eji buo agha.
\q1 Ọ ga-eti mkpu agha megide ndị iro ya,
\q2 ma merie ha.
\b
\q1 
\v 14 “Ọ dịla anya kemgbe m gbara nkịtị;
\q2 ejidesịrị m onwe m aka ike.
\q1 Ma ugbu a, aga m egosi iwe m;
\q2 aga m asụ ude, kwaa akwa dị ka nwanyị ime na-eme.
\q1 
\v 15 Aga m eme ka ugwu ukwu na ugwu nta niile dị larịị,
\q2 meekwa ka ihe ọkụkụ ha niile kpọnwụọ.
\q1 Aga m eme ka osimiri ghọọ ọzara,
\q2 meekwa ka ọdọ mmiri niile takpọọ.
\q1 
\v 16 Aga m edu ndị kpuru ìsì, site nʼụzọ nke ha na-amaghị,
\q2 nʼokporoụzọ ha agatụbeghị ka m ga-edu ha;
\q1 Aga m eme ka ọchịchịrị ghọọ ìhè nʼihu ha,
\q2 meekwa ka ebe niile gbagọrọ agbagọ guzozie.
\q1 Ihe ndị a niile ka m ga-eme.
\q2 Agaghị m agbakụta ha azụ.
\q1 
\v 17 Ma ndị niile na-atụkwasị arụsị obi,
\q2 ndị na-asị ihe ndị ahụ a pịrị apị, ‘Unu bụ chi anyị,’
\q2 a ga-achụghachi ha azụ nʼọnọdụ ihere.
\s1 Izrel kpuru ìsì, chie ntị
\q1 
\v 18 “Geenụ ntị, unu ndị ntị chiri,
\q2 leenụ anya unu ndị ìsì kpuru, ma hụ ụzọ.
\q1 
\v 19 Olee onye kpuru ìsì dịka ohu m?
\q2 Onye kwa ka ntị chiri dịka onyeozi nke eziokwu m?
\q1 Ọ dị onye ọzọ kpuru ìsì
\q2 dịka onye a m họpụtara ka ọ bụrụ ohu \nd Onyenwe anyị\nd*?
\q1 
\v 20 Ị hụla ọtụtụ ihe, ma ị dịghị atụkwasị uche gị na ha.
\q2 Ntị gị ghere oghe, ma ị dịghị eji ya anụ ihe.”
\q1 
\v 21 \nd Onyenwe anyị\nd* emeela ka iwu ya dị ukwuu,
\q2 meekwa ka ọ dị ebube,
\q2 nʼihi na ọ tọrọ ya ụtọ isite na ya mee ka ezi omume ya pụta ìhè.
\q1 
\v 22 Ma e meela ka ndị ya bụrụ ndị e zukpọrọ ihe ha nwere nʼoge agha.
\q2 A kpọchikwara ha nʼolulu e gwuru nʼala,
\q2 zoo ha nʼime ụlọ mkpọrọ dị iche iche.
\q1 Ha aghọọla ihe a kwatara nʼagha,
\q2 ma ọ dịghị onye na-anapụta ha.
\q1 Ha aghọkwaala ihe e si nʼaka mmadụ pụnara ya nʼike,
\q2 ma ọ dịghị onye na-asị ndị iro ha, “Nyeghachikwa m ihe m i ji aka ike were.”
\b
\q1 
\v 23 Onye ka ọ bụ nʼetiti unu nke ga-ege ntị nʼihe ndị a?
\q2 Onye ga-aṅa ntị si otu a mata ihe na-aga ime nʼoge dị nʼihu?
\q1 
\v 24 Onye weere Jekọb nyefee nʼaka ndị na-ebibi ihe,
\q2 onye were Izrel nyefee ndị ohi?
\q1 Ọ bụ na ọ bụghị \nd Onyenwe anyị\nd*
\q2 onye ha mehiere megide?
\q1 Nʼihi na ha ekweghị eso ụzọ ya niile,
\q2 ha erubeghị isi nye iwu ya.
\q1 
\v 25 Ọ bụ ya mere o ji wụkwasị ndị ya iwe ọkụ ya,
\q2 ihe ike nke agha.
\q1 Ọ bụ ezie na iwe ya bịakwasịrị ha dịka ọkụ na-erepịa erepịa, ma ha aghọtaghị ihe kpatara ya;
\q2 o repịara ha, ma ha atụgharịa uche ha banyere ya.
\c 43
\s1 Onye nzọpụta ndị Izrel nwere
\q1 
\v 1 Ma ugbu a, nke a bụ ihe \nd Onyenwe anyị\nd* kwuru,
\q2 bụ onye kere gị, Jekọb,
\q2 na onye kpụrụ gị Izrel,
\q1 “Atụla egwu, nʼihi na agbapụtala m gị.
\q2 Akpọọla m gị aha, ị bụkwa nke m.
\q1 
\v 2 Mgbe ị si na mmiri dị omimi na-agafe,
\q2 aga m anọnyere gị.
\q1 Mgbe i si na mmiri nke na-ekwo oke okwukwo,
\q2 agaghị m ekwe ka o bufuo gị.
\q1 Mgbe ị na-eje ije nʼime ọkụ,
\q2 ọ gaghị eregbu gị.
\q2 Ire ọkụ ahụ agakwaghị erepịa gị.
\q1 
\v 3 Nʼihi na mụ onwe m bụ \nd Onyenwe anyị\nd* Chineke gị,
\q2 Onye nzọpụta gị, na Onye nsọ nke Izrel.
\q1 Ewerela m Ijipt
\q2 na Kush na Seba nye ka ha bụrụ ihe i ji gbara onwe gị.
\q1 
\v 4 Ebe ị bụ ihe dị oke ọnụahịa nʼanya m,
\q2 ebe ọ bụkwa na m hụrụ gị nʼanya,
\q1 aga m ewere ndị mmadụ nye nʼihi ịgbapụta gị.
\q2 Aga m ebibi ndụ ndị mmadụ nʼihi ichebe gị ndụ.
\q1 
\v 5 Atụla egwu nʼihi na anọnyeere m gị.
\q2 Aga m esite nʼọwụwa anyanwụ
\q2 na nʼọdịda anyanwụ chịkọtaa ụmụ gị.
\q1 
\v 6 Aga m enyekwa ugwu na ndịda iwu sị ha,
\q2 ‘Hapụnụ ha ka ha laa,
\q1 unu egbochikwala ha.’
\q2 Hapụnụ ndị m ka ha site nʼala niile dị anya nke nsọtụ ụwa lọghachi,
\q1 
\v 7 onye ọbụla nke a na-akpọ aha m,
\q2 onye m kere nʼihi otuto m,
\q2 onye m kpụrụ, ma meekwa.”
\b
\q1 
\v 8 Kpọpụtanụ ha, bụ ndị ahụ nwere anya ma ha adịghị ahụ ụzọ,
\q2 ndị nwere ntị ma ha adịghịkwa anụ ihe.
\q1 
\v 9 Mba niile dị iche iche ezukọtala,
\q2 mmadụ niile agbakọtakwala.
\q1 Onye nʼime chi ha kwuru na ihe dị otu a ga-eme,
\q2 onye kwa kwuru ihe ndị a mere nʼoge gara aga?
\q1 Ka ha kpọbata ndị akaebe ha izipụta na ihe ha kwuru ziri ezi,
\q2 ka ndị ọzọ nụ ya ma sị na, “Ọ bụ eziokwu.”
\q1 
\v 10 “Unu bụ ndị akaebe m,” ka \nd Onyenwe anyị\nd* kwupụtara,
\q2 “bụrụkwa ndị ohu m họpụtara,
\q1 ka unu mara m, ma kwerekwa na m,
\q2 ghọtakwa na Mụ onwe m bụ onye ahụ.
\q1 Ọ dịghị chi a kpụrụ tupu m dịrị,
\q2 ọ dịkwaghị nke ga-eso m nʼazụ.
\q1 
\v 11 Mụ, ọ bụ na naanị m, bụ \nd Onyenwe anyị\nd*,
\q2 ọ dịkwaghị onye nzọpụta ọzọ dị ma ewezuga m.
\q1 
\v 12 Mụ onwe m egosila, zọpụta ma kwupụtakwa ya, mee ka unu nụrụ ya,
\q2 mụ onwe m, ọ bụghị chi ndị mba ọzọ nọ nʼetiti unu.
\q1 Unu bụkwa ndị akaebe m, na mụ onwe bụ Chineke,” otu a ka \nd Onyenwe anyị\nd* kwubiri ya.
\q2 
\v 13 “E, site nʼebighị ebi ruo nʼebighị ebi, mụ onwe m bụ Chineke.
\q1 Ọ dịghị onye pụrụ ịnapụta m ihe m ji nʼaka.
\q2 Mgbe m rụrụ ọrụ, onye pụrụ ịgbanwe ya?”
\s1 Ebere Onyenwe anyị, na-ekwesighị ntụkwasị obi Izrel
\q1 
\v 14 Nke a bụ ihe \nd Onyenwe anyị\nd* kwuru,
\q2 Onye mgbapụta unu na Onye nsọ nke Izrel.
\q1 “Nʼihi unu, aga m eziga ozi na Babilọn
\q2 budata ndị Kaldịa niile dịka ndị gbapụrụ agbapụ,
\q2 nʼime ụgbọ mmiri ahụ niile ha ji anya isi.
\q1 
\v 15 Mụ onwe m bụ \nd Onyenwe anyị\nd*, Onye nsọ gị,
\q2 onye kere Izrel, Eze unu.”
\b
\q1 
\v 16 Otu a ka \nd Onyenwe anyị\nd* kwuru,
\q2 bụ onye ahụ kwara ụzọ nʼime osimiri,
\q2 nke mere ka okporoụzọ dịrị nʼime oke osimiri.
\q1 
\v 17 Nke na-eme ka ụgbọ ndị agha dị ukwuu, na ịnyịnya pụta,
\q2 ndị agha na ụsụ ha achịkọtara ọnụ,
\q1 mee ha ka ha dinaa nʼebe ahụ, ghara ibilitekwa ọzọ,
\q2 dịka ha bụ ọkụ ogho oriọna e menyụrụ emenyụ.
\q1 
\v 18 “Chefuonu ihe ndị ahụ niile mere nʼoge gara aga;
\q2 unu atụgharịkwala uche unu na ha.
\q1 
\v 19 Kama leenụ anya ihe ọhụrụ nke m na-aga ime.
\q2 Leenụ ya nʼihi na o bidolarị ịpụta ihe. Ọ ga-abụ na unu adịghị ahụ ya?
\q1 Nʼihi na ana m akwa okporoụzọ nʼọzara,
\q2 na-emekwa ka mmiri jupụta nʼala tọgbọrọ nʼefu.
\q1 
\v 20 Anụ ọhịa niile na-asọpụrụ m,
\q2 nkịta ọhịa, na enyi nnụnụ niile na-ekele m,
\q1 nʼihi na emeela m ka mmiri jupụta nʼọzara,
\q2 meekwa ka isi iyi na-asọ nʼala ebe tọgbọrọ nʼefu,
\q1 nye ndị nke m ihe ọṅụṅụ, bụ ndị m họpụtara.
\q2 
\v 21 Ndị m kpụrụ nye onwe m,
\q2 ka ha kọsaa akụkọ otuto m.
\b
\q1 
\v 22 “Ma unu akpọkughị m, Jekọb,
\q2 kama ihe banyere m agwụla gị ike, Izrel.
\q1 
\v 23 I kpụrụghị atụrụ wetara m maka aja nsure ọkụ,
\q2 maọbụ jiri aja niile sọpụrụ m.
\q1 O nweghị mgbe m kwagidere gị ka i wetara m onyinye mkpụrụ ọka,
\q2 maọbụ mee ka ike gwụ gị site nʼịna gị ụda na-esi isi ụtọ.
\q1 
\v 24 Unu ewetabereghị m ụda kalamus na-esi isi ụtọ,
\q2 maọbụ were abụba anụ nke aja unu niile mee ka obi tọọ m ụtọ.
\q1 Kama ọ bụ naanị mmehie unu ka unu na-ebokwasị m,
\q2 unu ejirila ajọ omume unu mee ka ike gwụsịa m.
\b
\q1 
\v 25 “Mụ onwe m, ọ bụ naanị mụ onwe m, bụ onye na-ehichapụ mmehie unu.
\q2 Ana m emekwa ya nʼihi na ọ dị m mma nʼobi ime ya.
\q2 Agakwaghị m echeta mmehie unu ọzọ.
\q1 
\v 26 Chetara m ihe gara aga,
\q2 ka anyị rụrịta ụka nʼetiti onwe anyị,
\q2 doo okwu gị nʼusoro igosi na ị bụ onye ikpe na-amaghị.
\q1 
\v 27 Site na mmalite, nna nna unu ha mehiere megide m.
\q2 Ndị m dunyere ka ha kuziere unu ihe nupukwara isi megide m.
\q1 
\v 28 Ya mere, m ji menye ndị a maara aha ha nʼụlọnsọ ihere.
\q2 Enyefere m Jekọb ka ọ bụrụ onye ewezugara nye mbibi,
\q2 nyekwa Izrel ka ọ bụrụ ihe mkparị.
\c 44
\s1 Izrel onye a họpụtara
\q1 
\v 1 “Ma ugbu a, gee ntị gị Jekọb, bụ ohu m,
\q2 geekwanụ ntị, unu ndị Izrel m họpụtara.
\q1 
\v 2 Nke a bụ ihe \nd Onyenwe anyị\nd* na-ekwu,
\q2 bụ onye kere unu, onye kpụrụ unu nʼime nʼafọ,
\q2 na onye ga-enyere unu aka:
\q1 Atụla egwu, gị Jekọb,\f + \fr 44:2 \ft Maọbụ, \fqa Izrel\f* ohu m,
\q2 atụkwala egwu gị Jeshurun, onye nke m họpụtara.
\q1 
\v 3 Nʼihi na aga m eme ka ala ahụ kpọrọ nkụ nweta mmiri,
\q2 mee ka mmiri na-asọgharị nʼala ahụ akpịrị na-akpọ nkụ.
\q1 Aga m awụkwasị ụmụ ụmụ unu Mmụọ m,
\q2 meekwa ka ngọzị m dịrị ha.
\q1 
\v 4 Ha ga-etopụta etopụta dịka ahịhịa a gbara mmiri,
\q2 e, dịka osisi pọpla nʼakụkụ iyi jupụtara na mmiri.
\q1 
\v 5 Ha ga-eji nganga sị, ‘Abụ m nke \nd Onyenwe anyị\nd*,’
\q2 maọbụ ‘Abụ m nwa nwa Jekọb,’
\q1 ebe ndị ọzọ ga-edepụta nʼaka ha, ‘Nke \nd Onyenwe anyị\nd* ka m bụ,’
\q2 ha ga-agụkwa onwe ha Izrel.
\s1 \nd Onyenwe anyị\nd*, ọ bụghị arụsị
\q1 
\v 6 “Nke a bụ ihe \nd Onyenwe anyị\nd* na-ekwu,
\q2 onye bụ Eze Izrel na Onye mgbapụta ya, \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile:
\q1 Mụ onwe bụ Mmalite na Ọgwụgwụ;
\q2 ọ dịkwaghị Chineke ọzọ dị ma ewezuga m.
\q1 
\v 7 Ọ bụkwa onye dị ka m? Ya kwupụta ya.
\q2 Ya kwupụta ya, doo ya nʼusoro ka ntị nụrụ!
\q1 Ya kwupụta ihe niile mere kemgbe m mere ka ndị m guzosie ike.
\q2 Ya kwupụtakwa, ma dokwaa ha nʼusoro,
\q2 ihe niile na-aga ime nʼoge dị nʼihu.
\q1 
\v 8 Unu atụla egwu. Unu amakwala jijiji.
\q2 Ọ bụ na m akọpụtaghị ihe ndị a ma kwupụta ha nʼoge gara aga.
\q1 Unu onwe unu bụ ndị akaebe m. Ọ dị chi ọzọ dị ma e wezuga m?
\q2 Mba! O nweghị Oke nkume ọzọ dị, nke m maara ihe banyere ya.”
\b
\q1 
\v 9 Ndị a niile na-apị arụsị bụ ndị nzuzu.
\q2 Chi ndị ahụ niile ha na-agụ dị ka ihe ukwu bụkwa ihe na-enweghị isi.
\q1 Ndị niile na-akpọ isiala nye chi ndị a bụ ndị kpuru ìsì,
\q2 na ndị amamihe kọrọ, ndị ihere ga-emekwa.
\q1 
\v 10 Ọ baghị uru mmadụ ịkpụrụ onwe ya arụsị maọbụ chi a pịrị apị,
\q2 nke na-apụghị inyere ya aka nʼụzọ ọbụla?
\q1 
\v 11 Lee ihere ga-eme ndị niile na-akpọ isiala nye ya.
\q2 Ndị kpụrụ ha bụ naanị ndị mmadụ.
\q1 Ka ha niile chịkọta onwe ha, guzo, nwee mkpebi ha,
\q2 ha ga-anọ nʼọnọdụ nʼihere, na nʼoke egwu.
\b
\q1 
\v 12 Ọkpụ ụzụ na-ewere ngwa ọrụ ya
\q2 na-ahụ ya nʼime icheku ọkụ,
\q1 ọ na-eji mkpirisi igwe onye ọka tipịa ya nʼụdịdị arụsị,
\q2 ọ bụ ike nke ogwe aka ya ka o ji akpụ ụzụ.
\q1 Agụ na-agụ ya, ike na-agwụsịkwa ya;
\q2 ọ ṅụghị mmiri ọbụla, ọ na-adakwa mba.
\q1 
\v 13 Onye ọka osisi na-esite nʼeriri ọtụtụ tụpụta osisi
\q2 were pensụlụ kaa ya;
\q1 ọ na-ewere ngwa ọrụ ya kpụchaa osisi ahụ,
\q2 were ngwa ọrụ ịka akara, kaa ya akara.
\q1 Ọ na-arụ ya dịka oyiyi mmadụ,
\q2 oyiyi mmadụ nʼịma mma ya niile,
\q2 maka ibi nʼime ụlọ arụsị.
\q1 
\v 14 Ọ na-egbutu osisi sida dị iche iche,
\q2 maọbụ osisi saipres ma ọ bụkwa osisi ook.
\q1 Ọ na-ahapụ ya ka o too nʼetiti osisi dị iche iche nke oke ọhịa,
\q2 maọbụ kụọ osisi fịa, nke mmiri ozuzo na-eme ka o too nke ọma.
\q1 
\v 15 Ọ bụkwa nkụ ka eji ya e mere;
\q2 ụfọdụ ka ọ na-ewere nya ọkụ,
\q2 ọ na-eji ya afụnwu ọkụ ghee achịcha.
\q1 Sitekwa na ya pịa chi, kpuo ihu nʼala nye ya;
\q2 ọ na-emekwa arụsị apịrị apị, kpọọ isiala nye ya.
\q1 
\v 16 Ọkara nʼime osisi ndị a ka o ji emenwu ọkụ;
\q2 nʼelu ya kwa ka ọ na-esi nri ya,
\q2 ọ na-ahụnye anụ, were tajuo afọ ya.
\q1 Nkụ ahụ ka o ji anya ọkụ na-asị,
\q2 “Ahaa, ahụ ekpola m ọkụ; ahụla m ọkụ.”
\q1 
\v 17 Ihe fọdụrụ nʼime osisi ahụ ka ọ na-ewere kwaara onwe ya arụsị a pịrị apị;
\q2 Ọ na-ada nʼala nʼihu ya, fee ya ofufe.
\q1 Ọ na-ekpekwara ya ekpere na-asị,
\q2 “Biko, Zọpụta m, nʼihi na chi m ka ị bụ!”
\q1 
\v 18 Ha amaghị ihe ọbụla; ha adịghị aghọtakwa,
\q2 nʼihi na-emechiela anya ha ka ha ghara ịhụ ụzọ,
\q2 mechiekwa uche ha, ka ha ghara ịghọta.
\q1 
\v 19 Ọ dịghị onye na-anọdụ chee echiche,
\q2 ọ dịghịkwa onye nwere ihe ọmụma maọbụ nghọta ị sị,
\q1 “Ụfọdụ nʼime osisi a ka m ji kwanye ọkụ,
\q2 Ọ bụladị ghee achịcha nʼelu icheku ọkụ ya,
\q2 ejikwa m ụfọdụ nʼime ya hụọ anụ m tara.
\q1 M ga-esite na nke fọdụrụ mepụta ihe rụrụ arụ?
\q2 Ọ bụ ogwe osisi ka m ga-akpọ isiala nye?”
\q1 
\v 20 Onye na-adịghị eche ụdị echiche a bụ onye nzuzu, nke na-eji ntụ si nʼebe a kwanyere ọkụ na-azụ onwe ya.
\q2 Ọ pụghị ịnapụta onwe ya, maọbụ jụọ onwe ya ajụjụ sị,
\q2 “Ihe a m ji nʼaka m, nke m na-akpọ chi, ọ bụghị okwu ụgha ka ọ bụ?”
\b
\q1 
\v 21 “Cheta ihe ndị a, gị Jekọb,
\q2 nʼihi na gị bụ Izrel, ị bụ ohu m.
\q1 Ọ bụ m kpụrụ gị, ị bụ ohu m;
\q2 gị bụ Izrel, agaghị m echezọ gị.
\q1 
\v 22 Ehichapụla m njehie gị niile; dịka igwe ojii,
\q2 hichapụkwa mmehie gị dịka igirigi ụtụtụ.
\q1 Lọghachikwute m,
\q2 nʼihi na akwụọla m ụgwọ ịgbapụta gị.”
\b
\q1 
\v 23 Bụọnụ abụ oke ọṅụ, unu eluigwe, nʼihi na \nd Onyenwe anyị\nd* emeela ya;
\q2 tienụ oke mkpu, unu ụwa dị nʼala.
\q1 Tienụ mkpu ọṅụ, unu ugwu niile,
\q2 unu bụ oke ọhịa niile na osisi ọbụla nke dị nʼime gị,
\q1 nʼihi na \nd Onyenwe anyị\nd* agbapụtala Jekọb,
\q2 na-egosikwa ebube ya nʼIzrel.
\s1 A ga-ebikwa na Jerusalem
\q1 
\v 24 “Otu a, \nd Onyenwe anyị\nd* na-ekwu,
\q2 Onye mgbapụta unu, onye ahụ kpụrụ unu nʼime afọ:
\b
\q1 Mụ onwe bụ \nd Onyenwe anyị\nd*,
\q2 Onye kere ihe niile,
\q2 onye gbatipụrụ eluigwe,
\q2 onye gbasara ụwa naanị mụ onwe m,
\q1 
\v 25 onye na-emebi ihe ịrịbama niile nke ndị amụma ụgha
\q2 na-emekwa ka ndị na-ajụta ase ghọọ ndị nzuzu,
\q1 onye na-ekpu ihe ọmụmụ ndị maara ihe ihu nʼala
\q2 tụgharịa ya, ha ghọọ ihe nzuzu,
\q1 
\v 26 onye na-eme ka okwu ndị ohu ya mezuo
\q2 meekwa ka amụma ndị ozi ya buru mezuo,
\b
\q1 onye na-asị banyere Jerusalem, ‘A ga-ebikwa nʼime ya ọzọ,’
\q2 na-asịkwa banyere obodo niile nke Juda, ‘A ga-ewughachi ha,’
\q2 banyere mkpọmkpọ ebe ha niile, ‘Aga m ewulikwa ha.’
\q1 
\v 27 Onye ahụ na-asị, ogbu mmiri, ‘Takọrọ,
\q2 aga m emekwa ka iyi ya niile takọrọsịa,’
\q1 
\v 28 Onye na-asị banyere Sairọs, ‘Ọ bụ onye ọzụzụ atụrụ m,
\q2 ọ ga-emezukwa ihe niile na-adị m mma;
\q1 Ọ ga-asịkwa banyere Jerusalem, “Ka ewugharịa ya,”
\q2 ma banyere ụlọnsọ, “Ka ehiwe ntọala ya.” ’
\b
\b
\c 45
\q1 
\v 1 “Nke a ka \nd Onyenwe anyị\nd* na-ekwu nye ohu ya nke o tere mmanụ,
\q2 bụ Sairọs, onye m ga-eji aka nri ya
\q1 megide mba niile, mee ka ha nọrọ nʼokpuru ya,
\q2 napụkwa ndị eze ngwa agha ha niile,
\q1 megheere ya ọnụ ụzọ niile
\q2 nke na ọ dịkwaghị ọnụ ụzọ ama a ga-emechibido ya.
\q1 
\v 2 Mụ onwe m ga-ebu ụzọ gaa nʼihu gị
\q2 kwazee ugwu ukwu niile,
\q1 tiwasịa ibo ọnụ ụzọ bronz niile
\q2 gbuwakwaa mkpọrọ igwe dị iche iche.
\q1 
\v 3 Aga m enye gị akụ niile e zoro nʼebe ọchịchịrị gbara,
\q2 akụnụba niile e zoro nʼebe nzuzo dị iche iche.
\q1 Ka ị mata na ọ bụ mụ onwe m bụ \nd Onyenwe anyị\nd*,
\q2 bụ Chineke nke Izrel, onye ahụ kpọrọ gị aha, na-eme ihe ndị a niile.
\q1 
\v 4 Nʼihi Jekọb bụ ohu m,
\q2 nʼihi Izrel onye m họpụtara nye onwe m,
\q1 ka m ji kpọọ gị aha gị
\q2 nyekwa gị aha nke nsọpụrụ,\f + \fr 45:4 \ft Tuo gị aha nsọpụrụ\f*
\q2 maọbụ ezie na ị maghị onye m bụ.
\q1 
\v 5 Ọ bụ m bụ \nd Onyenwe anyị\nd*, ọ dịghịkwa onye ọzọ dị;
\q2 ewezuga m, ọ dịkwaghị Chineke ọzọ dị.
\q1 Ọ bụ ezie na ị maghị m,
\q2 ma aga m eme ka ị dịrị ike.
\q1 
\v 6 Mgbe ahụ, ụwa niile, site nʼọwụwa anyanwụ
\q2 ruo nʼọdịda anyanwụ,
\q1 ga-amata nʼezie na Chineke ọzọ adịghị, karịa m.
\q2 Abụ m \nd Onyenwe anyị\nd*, ọ dịghịkwa onye ọzọ dị.
\q1 
\v 7 Ọ bụ m kpụrụ ìhè, keekwa ọchịchịrị.
\q2 Ọ bụ m na-ezite ọganihu, na-ekekwa ịla nʼiyi.
\q2 Mụ onwe m, bụ \nd Onyenwe anyị\nd*, na-eme ihe ndị a niile.
\b
\q1 
\v 8 “Gị, eluigwe, zodata ezi omume m
\q2 ka mbara eluigwe na-ezodakwa ya dịka mmiri.
\q1 Ka ala meghee onwe ya,
\q2 ka nzọpụta pupụta,
\q1 ka ezi omume soro ya puokwa dịka ahịhịa.
\q2 Ọ bụ mụ onwe m, bụ \nd Onyenwe anyị\nd* kere ha niile.
\b
\q1 
\v 9 “Ahụhụ na-adịrị mmadụ ahụ nke na-alụso onye kere ya ọgụ,
\q2 mmadụ ahụ bụ otu mpekele ejuju
\q2 nʼetiti mpekele ejuju niile dị nʼala.
\q1 Ụrọ ọ na-ajụ onye ji ya akpụ ihe ajụjụ sị,
\q2 ‘Gịnị ka i ji m akpụ?’
\q1 Ka ọrụ gị ọ ga-asị,
\q2 ‘Lee, ọ dịghị aka abụọ o nwere’?
\q1 
\v 10 Ahụhụ na-adịrị nwantakịrị ahụ gwara nna ya okwu sị,
\q2 ‘Gịnị ka ị mụtara na nwa?’
\q1 maọbụ sịkwa nne ya,
\q2 ‘Gịnị bụ ihe ị mụpụtara?’\f + \fr 45:10 \ft Ime gịnị na-eme gị\f*
\b
\q1 
\v 11 “Otu a ka \nd Onyenwe anyị\nd*, Onye nsọ nke Izrel,
\q2 Onye kere Izrel na-ajụ ajụjụ sị;
\q1 banyere ihe ndị gaje ime
\q2 ị na-ajụ m ajụjụ banyere ụmụ m,
\q2 maọbụ nye m iwu banyere ọrụ aka m?
\q1 
\v 12 Ọ bụ mụ onwe m kere ụwa,
\q2 keekwa mmadụ ka o biri nʼime ya.
\q1 Aka m abụọ ka m ji gbasaa mbara igwe,
\q2 nyekwa kpakpando niile iwu.
\q1 
\v 13 M ga-akpọlite Sairọs nʼezi omume m:
\q2 M ga-eme ka ụzọ ya niile zie ezi.
\q1 Ọ ga-ewughachi obodo m,
\q2 mee ka ndị m a dọtara nʼagha nwere onwe ha,
\q1 ma ọ bụghị nʼihi ọnụahịa maọbụ ihe nrite,
\q2 ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwuru.”
\p 
\v 14 Otu a ka \nd Onyenwe anyị\nd* sịrị,
\q1 “Ihe ndị Ijipt rụpụtara na ngwa ahịa ndị Kush
\q2 na ndị Saba ahụ toro ogologo,
\q1 ha ga-abịakwute gị,
\q2 ha ga-abụ nke gị;
\q1 ha ga-esokwa gị nʼazụ
\q2 dịka ndị mkpọrọ e kere agbụ.
\q1 Ha ga-akpọ isiala nʼihu gị
\q2 rịọ gị arịrịọ, na-asị,
\q1 ‘Nʼezie, ọ bụ naanị otu Chineke dị, onye nọnyere gị,
\q2 ọ dịkwaghị chi ọzọ dị.’ ”
\b
\q1 
\v 15 Nʼezie, gị onwe gị bụ Chineke, Onye nzọpụta Izrel.
\q2 Ị bụkwa Chineke, onye na-ezonarị mmadụ onwe ya.
\q1 
\v 16 A ga-eme ndị niile na-akpụ arụsị ihe ihere,
\q2 e, ihere ga-eme ha nʼihi na a ga-etinye ha nʼọnọdụ oke ihere.
\q1 
\v 17 Ma \nd Onyenwe anyị\nd* ga-eji nzọpụta
\q2 nke ga-adị ruo mgbe ebighị ebi zọpụta Izrel.
\q1 Ihere agaghị eme ha.
\q2 A gaghị etinyekwa ha nʼọnọdụ ihe ihere ruo mgbe ebighị ebi.
\b
\q1 
\v 18 Nʼihi na otu a ka \nd Onyenwe anyị\nd* onye kere eluigwe sịrị,
\q1 ọ bụ ya dobekwara ihe niile nʼọnọdụ ha.
\q2 Ọ bụ ya, bụ Chineke,
\q1 onye zubere ma kee ụwa,
\q2 tọkwaa ntọala ya.
\q1 O keghị ụwa ka ọ tọgbọrọ nʼefu,
\q2 kama ọ bụ ka e biri nʼime ya ka o ji kee ya.
\q1 Ọ sịrị,
\q1 “Mụ onwe m bụ \nd Onyenwe anyị\nd*;
\q2 ọ dịkwaghị Chineke ọzọ dị.
\q1 
\v 19 Ọ bụghị na nzuzo ka m kwuru okwu,
\q2 site nʼotu ebe nʼala nke ọchịchịrị.
\q1 Agwaghị m mkpụrụ Jekọb
\q2 ‘Chọọnụ m nʼefu.’
\q1 Mụ onwe m, bụ \nd Onyenwe anyị\nd* na-ekwu eziokwu,
\q2 Ana m ekwupụta ihe ziri ezi.
\b
\q1 
\v 20 “Chịkọtaanụ onwe unu, gbakọtanụ,
\q2 bịanụ nso, unu ndị si na mba niile gbapụta ọsọ ndụ.
\q1 Ha amaghị ihe bụ ndị a na-ebugharị chi osisi e ji aka mee,
\q2 ndị na-ekpekwara chi ndị ahụ na-enweghị ike ịzọpụta ekpere.
\q1 
\v 21 Kwupụtanụ ihe kwesiri ịdị, gosinụ ya,
\q2 ka ha gbaakọkwa izu.
\q1 Onye buru ụzọ kwuo ihe ndị a nʼoge gara aga,
\q2 onye kwupụtara ya site na mgbe ochie?
\q1 Ọ bụghị mụ onwe m, bụ \nd Onyenwe anyị\nd*?
\q2 Ọ dịkwaghị Chineke ọzọ dị ma ọ bụghị mụ onwe m,
\q1 Chineke onye ezi omume na Onye nzọpụta;
\q2 ọ dịghị onye ọzọ dị ma ewezuga m.
\b
\q1 
\v 22 “Laghachikwutenụ m, ka m zọpụta unu.
\q2 Laghachikwutenụ m, unu ndị bi na nsọtụ niile nke ụwa.
\q2 Nʼihi na ọ bụ naanị m bụ Chineke, ọ dịkwaghị chi ọzọ dị.
\q1 
\v 23 Ejirila m onwe m ṅụọ iyi,
\q2 ọnụ m ekwupụla okwu nʼezi omume,
\q2 bụ okwu nke na-enweghị mgbanwe:
\q1 Nʼihu m ka ikpere niile ọbụla ga-egbu nʼala;
\q2 mụ ka ire niile ọbụla ga-aṅụrụ iyi.
\q1 
\v 24 E, ha ga-ekwupụta sị, ‘Ọ bụ nʼime \nd Onyenwe anyị\nd* naanị
\q2 ka ezi omume na ike dị.’ ”
\q1 Ndị niile na-akpọ ya asị ga-abịakwute ya.
\q2 Ihere ga-emekwa ha.
\q1 
\v 25 Ma agbụrụ niile nke Izrel
\q2 ga-achọta nnapụta ha nʼime \nd Onyenwe anyị\nd*,\f + \fr 45:25 \ft NʼOnyenwe anyị ka a ga-agụ agbụrụ niile nke Izrel ka ndị ezi omume.\f*
\q2 ọ bụkwa na ya ka ha ga-anya isi.
\c 46
\s1 Chi dị iche iche nke ndị Babilọn
\q1 
\v 1 Bel na Nebo, arụsị ndị Babilọn makpu amakpu.
\q2 Lee, arụsị niile ha ka ebukwasịrị ha nʼazụ ịnyịnya ibu.
\q1 Arụsị niile apịrị apị bụ nke a na-ebugharị bụ ibu dị arọ,
\q2 ibu arụ nye ụmụ anụmanụ na-ada mba!
\q1 
\v 2 Ha makpuuru, rudakọkwa ala nʼotu;
\q2 ha enweghị ike iwezuga ibu ndị a nʼonwe ha,
\q2 ha onwe ha kwa, a dọtala ha nʼagha.
\b
\q1 
\v 3 “Geenụ m ntị, unu ụmụ ụmụ Jekọb,
\q2 unu ndị fọdụrụ nʼụlọ Izrel,
\q1 unu bụ ndị m na-elekọta siterị na mgbe a mụrụ unu
\q2 na-akpọgharịkwa unu siterị na mgbe amụpụtara unu.
\q1 
\v 4 Mụ onwe m, bụ onye ahụ, ọ bụ m ga-elekọtakwa unu anya,
\q2 ọ bụladị ruo mgbe isi awọ jupụtara unu nʼisi, nʼagadi unu.
\q1 Nʼihi na ọ bụ m kere unu, aga m elekọtakwa unu.
\q2 Aga m agba unu ume, bụrụkwa onye nzọpụta unu.
\b
\q1 
\v 5 “Onye ka unu ga-asị na o yiri m? Onye kwa ka mụ na ya ha?
\q2 Onye ka unu ga-eji tụnyere m?
\q1 
\v 6 Ụfọdụ mmadụ na-emeghe akpa ego ha wụpụta ọlaedo dị nʼime ya,
\q2 na-atụpụtakwa ọlaọcha nʼihe ọtụtụ,
\q1 were ya goo onye ọkpụ ụzụ ọlaedo ka o jiri ya kpụọrọ ha chi,
\q2 emesịa, ha na-akpọ isiala na-efe arụsị ahụ ofufe.
\q1 
\v 7 Ha na-ebuli arụsị ahụ buru ya nʼubu ha,
\q2 buru ya debe ya nʼọnọdụ ya, nʼebe ahụ ka ọ na-akwụrụ.
\q2 Ọ dịghị apụ site nʼebe ahụ jegharịa.
\q1 Ọ bụrụ na mmadụ e tikuo ya mkpu, ọ gaghị aza,
\q2 ọ pụghị ịzọpụtakwa ha pụọ na nsogbu ha niile.
\b
\q1 
\v 8 “Chetanụ nke a, ma tuleekwa ya,
\q2 ka ọ dịgidekwa unu nʼobi, unu ndị na-enupu isi.
\q1 
\v 9 Chetakwanụ ihe ndị ahụ niile mere nʼoge gara aga,
\q2 nʼihi na abụ m Chineke, chi ọzọ adịghịkwa.
\q2 Naanị m bụ Chineke, ọ dịkwaghị onye ọzọ dị ka m.
\q1 
\v 10 Ọ bụ m na-egosi ikpeazụ site na mmalite,
\q2 ọ bụ m na-ekwu site na mgbe ochie ihe ga-eme nʼọdịnihu.
\q1 Ana m asị, ‘nzube m ga-eguzogide.
\q2 Ọ bụkwa ihe dị m mma nʼobi ka m ga-eme.’
\q1 
\v 11 Aga m esite nʼọwụwa anyanwụ kpọọ anụ ufe,
\q2 e, sitekwa nʼala ebe dị anya kpọọ nwoke\f + \fr 46:11 \ft Sairọs, ka a na-ekwu ihe banyere ya nʼebe a.\f* ahụ ga-abịa mee nzube m.
\q1 Nʼihi na ihe m kwuru ya ka m ga-eme ka o mezuo;
\q2 ọ bụkwa atụmatụ m ka m ga-emekwa.
\q1 
\v 12 Geenụ m ntị, unu ndị isi ike,
\q2 unu ndị nọpụrụ ezi omume m nʼebe dị anya.
\q1 
\v 13 Ana m eweta ezi omume nso,
\q2 ọ dịghị nʼebe dị anya,
\q2 nzọpụta m agaghị anọkwa ọdụ.
\q1 Aga m enye Zayọn nzọpụta,
\q2 nyekwa Izrel ịma mma m.
\c 47
\s1 Ọdịda Babilọn
\q1 
\v 1 “Rịda nʼala, nọdụ na uzuzu,
\q2 gị nwaagbọghọ na-amaghị nwoke, bụ ada Babilọn,
\q1 nọdụ nʼala na-ejighị ocheeze,
\q2 gị eze nwanyị obodo ndị Babilọn.
\q1 Agaghị akpọkwa gị
\q2 onye dị nro, maọbụ onye dị pekepeke.
\q1 
\v 2 Were nkume igwe nri gwee ọka,
\q2 wepụ akwa ahụ i ji kpuchie ihu gị.
\q1 Chilite uwe mwụda gị, kpughepụ ogwe ụkwụ gị,
\q2 mgbe ị na-agabiga iyi dị iche iche.
\q1 
\v 3 A ga-ekpughe ọtọ gị,
\q2 tinyekwa gị nʼọnọdụ ihere.
\q1 Nʼihi na aga m abọtara ndị m ọbọ,
\q2 agaghị m elekwa anya nʼazụ.”
\b
\q1 
\v 4 Otu a ka Onye mgbapụta anyị kwuru, Onye ga-azọpụta Izrel. Aha ya bụ \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile,
\q2 Onye nsọ Izrel.
\b
\q1 
\v 5 “Nọdụ duu, baa nʼime ọchịchịrị,
\q2 gị eze obodo nke ndị Kaldịa;
\q1 Ọ dịkwaghị mgbe ọzọ a ga-akpọ gị
\q2 nwanyị nwe alaeze dị iche iche.
\q1 
\v 6 Ewesoro m ndị m iwe,
\q2 mee ndị ahụ bụ ihe nketa m ka ha ghọọ ihe na-adịghị nsọ.
\q1 Eweere m ha tinye gị nʼaka,
\q2 ma i gosighị ha obi ebere.
\q1 Ọ bụladị ndị bụ agadi nʼetiti ha
\q2 ka ị bokwasịrị ibu arọ.
\q1 
\v 7 I kwuru sị,
\q2 ‘Abụ m eze nwanyị ruo mgbe ebighị ebi!’
\q1 Ma i cheghị echiche banyere ihe ndị a,
\q2 ị tụgharịghị uche banyere ihe pụrụ ime.
\b
\q1 
\v 8 “Ugbu a gee ntị, gị onye na-eme dịka o si tọọ gị ụtọ.
\q2 Gee ntị, gị onye na-anọ nʼudo,
\q1 na-asị onwe gị,
\q2 ‘Ọ bụ naanị m dị, o nweghị onye ọzọ ka m nʼụwa.
\q1 O nweghị mgbe m ga-adị ka nwanyị di ya nwụrụ,
\q2 maọbụ dịka nwanyị ụmụ ya nwụrụ.’
\q1 
\v 9 Ma lee anya!
\q2 Ihe abụọ ndị a na-aga ịbịakwasị gị
\q2 na mberede.
\q1 Nʼotu ụbọchị di gị ga-anwụ, ụmụ gị ga-anwụchakwa.
\q2 Mgbaasị gị niile, na ịdị ike nke ọgwụ okike gị niile,
\q2 agaghị egbochi ihe ndị a ịbịakwasị gị nʼuju.
\q1 
\v 10 Nʼihi na i werela obi gị tụkwasị nʼajọ omume gị
\q2 ị na-asị, ‘O nweghị onye na-ahụ m.’
\q1 Ma amamihe gị na ihe ọmụma gị na-eduhie gị,
\q2 mgbe ị na-asị onwe gị,
\q2 ‘Ọ bụ naanị mụ onwe m, ọ dịghịkwa onye ọzọ ma ewezuga m.’
\q1 
\v 11 Ihe ọjọọ ga-abịakwasị gị,
\q2 ị gaghị ama otu ị ga-esi gbaa afa iwezuga ya.
\q1 Oke mbibi ga-adakwasị gị
\q2 nke ị na-agaghị enwe ike iji ego gbara onwe gị;
\q1 Ịla nʼiyi nke ị na-atụghị anya ya
\q2 ga-abịakwasị gị na mberede.
\b
\q1 
\v 12 “Dokọtazie ọgwụ okike gị niile,
\q2 na ihe mgbaasị gị niile.
\q2 Ihe ndị ahụ niile i jirila na-eche onwe gị siterị na mgbe ị bụ nwantakịrị.
\q1 Ma eleghị anya ha pụrụ inyere gị aka nʼoge dị nʼihu.
\q2 Ị pụrụ iji ha menye ndị iro gị ụjọ, maọbụ mee ka ha maa jijiji.
\q1 
\v 13 Ndụmọdụ niile a na-enye gị adịghị enyere gị aka.
\q2 Mee ka ndị ahụ ihe banyere ngagharị ọnwa na kpakpando doro anya bịa nso.
\q1 Kpọpụta ndị ahụ na-esite nʼihe ha hụrụ na kpakpando akọwa ihe ga-eme site nʼotu ọnwa ruo nʼọnwa nke ọzọ.
\q2 Kpọkuo ha ka ha zọpụta gị site na nsogbu nke na-aga ịbịakwasị gị.
\q1 
\v 14 Lee, ha bụ ihe efu dịka ahịhịa kpọrọ nkụ.
\q2 Ọkụ ga-erechapụkwa ha.
\q1 Ha apụghịkwa ịzọpụta onwe ha
\q2 site nʼọkụ ahụ na-enwusi ike.
\q1 Nʼihi na ọkụ ahụ adịghị ka ọkụ a na-akwanye,
\q2 nke a na-anya nʼoge oyi.
\q1 
\v 15 Lee ihe ndị a na-enyocha kpakpando ga-emere gị,
\q2 bụ ndị ị na-aṅa ntị na ndụmọdụ ha
\q2 site na mgbe ị bụ nwantakịrị.
\q1 Ha ga-ahapụ gị gaa nʼụzọ nke aka ha;
\q2 ị gaghị enwekwa onye ga-azọpụta gị.
\c 48
\s1 Izrel Onye isiike
\q1 
\v 1 “Geenụ ntị na nke a, unu agbụrụ Jekọb,
\q2 unu ndị a na-akpọ nʼaha Izrel,
\q2 ndị si nʼagbụrụ Juda pụta.
\q1 Unu ndị na-eji aha \nd Onyenwe anyị\nd* na-aṅụ iyi,
\q2 ndị na-akpọku aha Chineke nke Izrel,
\q2 ma ọ bụghị nʼeziokwu maọbụ nʼezi omume.
\q1 
\v 2 Unu ndị na-akpa nganga na unu bụ ndị bi nʼobodo dị nsọ,
\q2 ndị na-anyakwa isi na unu na-adabere na Chineke Izrel.
\q2 Onye aha ya bụ \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile.
\q1 
\v 3 Nʼoge gara aga ka m kwuru ihe na-aga ime nʼoge dị nʼihu.
\q2 Mgbe m kwupụrụ ya,
\q2 emekwara m ka ihe ahụ m kwuru mezuo.
\q1 
\v 4 Nʼihi na amaara m na unu bụ ndị isiike,
\q2 matakwa na akwara dị unu nʼolu bụ igwe a na-apụghị ịrọji arọji.
\q2 Amakwaara m na egedege ihu unu bụ bronz.
\q1 
\v 5 Ọ bụ ya mere m ji buru ụzọ gwa unu nʼoge gara aga
\q2 ihe m gaje ime,
\q1 ka unu ghara ị sị,
\q2 ‘Ọ bụ arụsị anyị mere ya.
\q2 Ọ bụ arụsị anyị a pịrị apị na chi ọla m nyere iwu ka ha mee!’
\q1 
\v 6 Unu anụla ama m na-agba, hụkwa ka ha na-emezu,
\q2 ma unu ajụla ikwere na ọ bụ eziokwu.
\b
\q1 “Site ugbu a gawa, aga m agwa unu ihe ọhụrụ
\q2 nke m na-agwabeghị unu na mbụ.
\q1 
\v 7 Ọ bụ ugbu a ka e kere ya, ọ bụghị na mgbe ochie.
\q2 Unu anụtụbeghị ihe banyere ya mbụ,
\q1 ya mere, unu agaghị asị,
\q2 ‘Ọ bụ ihe maara ihe banyere ya.’
\q1 
\v 8 E, ị nụbeghị, ị maghịkwa,
\q2 site na mgbe ochie ntị gị egheghị oghe.
\q1 Nʼihi na amaara m na ị bụ onye aghụghọ na-ekwesighị ntụkwasị obi,
\q2 onye a na-akpọ onye nnupu isi site nʼafọ nne ya.
\q1 
\v 9 Ma nʼihi aha m, ka m na-eme ka ọnụma m jụrụ
\q2 nʼihi otuto m, a na m egbochi ya nʼebe ị nọ,
\q2 ka a ghara ikpochapụ unu kpamkpam.
\q1 
\v 10 Lee, anụchaalam unu, ma ọ bụghị dịka e si anụcha ọlaọcha nʼọkụ.
\q2 E, anwaleela m unu nʼoke ọkụ nke ahụhụ.
\q1 
\v 11 Nʼihi mụ onwe m, e, nʼihi mụ onwe m, ka m na-eme nke a.
\q2 Aga m esi aṅaa hapụ ka m bụrụ onye emere ka aha m ghara ịdị nsọ?
\q2 Agaghị m enye onye ọzọ otuto m.
\s1 Izrel enwere onwe ya
\q1 
\v 12 “Geenụ m ntị, gị Jekọb,
\q2 na gị Izrel onye m kpọrọ.
\q1 Mụ onwe m bụ onye ahụ;
\q2 Abụ m onye mbụ, bụrụkwa onye ikpeazụ.
\q1 
\v 13 Ọ bụ aka m tọrọ ntọala ụwa.
\q2 Ọ bụkwa aka nri m gbasara eluigwe.
\q1 Mgbe m kpọrọ ha oku
\q2 ha na-abịa guzo nʼihu m.
\b
\q1 
\v 14 “Chịkọtaanụ onwe unu, unu niile, geenụ ntị.
\q2 Onye nʼetiti arụsị ndị a gosiri ihe ndị a na-aga ime?
\q1 Onye ahụ \nd Onyenwe anyị\nd* họọrọ ka ya na ya dị na mma
\q2 ga-emezu nzube ya megide Babilọn,
\q2 aka ya ga-emegide ndị Kaldịa.
\q1 
\v 15 Mụ onwe m, ọ bụladị mụ onwe m ekwuola ya;
\q2 e, akpọọla m ya.
\q1 Aga m eme ka ọbịa
\q2 nʼije ya, ọ ga-agakwa nke ọma.
\p 
\v 16 “Bịakwutenụ m nso, geenụ ntị na nke a:
\q1 “Site na mkpọsa mbụ ọ bụghị na nzuzo ka m kwuru okwu;
\q2 mgbe o mere anọ m nʼebe ahụ.”
\b
\q1 Ma ugbu a, Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* ezitela m,
\q2 o mejupụtala m na Mmụọ ya.
\b
\q1 
\v 17 Otu a ka \nd Onyenwe anyị\nd* sịrị,
\q2 Onye mgbapụta unu, bụ Onye nsọ Izrel,
\q1 “Mụ onwe m bụ \nd Onyenwe anyị\nd* Chineke gị,
\q2 onye na-ezi unu ihe nʼihi ọdịmma unu,
\q2 na-eduzikwa unu nʼụzọ unu kwesiri iso.
\q1 
\v 18 A sịkwarị na unu ṅara ntị nʼiwu m niile,
\q2 udo unu gaara na-eru dịka osimiri,
\q2 ọdịmma\f + \fr 48:18 \ft Maọbụ, \fqa ezi omume\f* unu adịkwa ka mmali nke ebili oke osimiri.
\q1 
\v 19 Mkpụrụ gị gaara amụba dịka aja,
\q2 ụmụ unu gaara a dị ka mkpụrụ ọkụkụ a na-enweghị ike ịgụta ọnụ,
\q1 a gaghị ehichapụkwa aha ha,
\q2 maọbụ bibie nʼihu ha.”
\b
\q1 
\v 20 Sitenụ na Babilọn pụọ,
\q2 gbanarịnụ ndị Kaldịa!
\q1 Werenụ olu iti mkpu ọṅụ
\q2 kwusaa inwere onwe unu a.
\q1 Meenụ ka ndị bi na nsọtụ niile nke ụwa nụrụ ya
\q2 sịnụ, “\nd Onyenwe anyị\nd* agbapụtala ohu ya Jekọb.”
\q1 
\v 21 Mgbe O duuru ndị ya jee ije nʼọzara, ala kpọrọ nkụ, akpịrị akpọghị ha nkụ.
\q2 O mere ka mmiri si nʼoke nkume sọpụtara ha,
\q1 e, ọ kpọwara oke nkume
\q2 mee ka mmiri sọpụta.
\b
\q1 
\v 22 \nd Onyenwe anyị\nd* sịrị, “Ọ dịghị udo dịrị ndị na-emebi iwu.”
\c 49
\s1 Ohu nke \nd Onyenwe anyị\nd*
\q1 
\v 1 Geenụ m ntị, unu niile ndị bi nʼala mmiri gbara gburugburu,
\q2 nụrụkwanụ nke a, unu ndị nọ na mba dị anya.
\q1 \nd Onyenwe anyị\nd* kpọrọ m tupu amụọ m.
\q2 Ọ kpọrọ m aha m mgbe m ka nọ nʼime afọ nne m.
\q1 
\v 2 O mere ka okwu sị m nʼọnụ dịrị nkọ dịka mma agha.
\q2 O zobere m nʼaka ya kpuchie m.
\q1 O mere m ka m dịrị ka àkụ dị nkọ
\q2 nke o zoro nʼime akpa àkụ ya.
\q1 
\v 3 Ọ sịrị m, “Ị bụ ohu m, Izrel.
\q2 Ọ bụkwa site na gị ka m ga-eji gosi ịma mma\f + \fr 49:3 \ft Maọbụ, \fqa ịdị ukwuu\f* na ike m.”
\q1 
\v 4 Ma mụ onwe m sịrị, “Ọ bụ nʼefu ka m dọgburu onwe m nʼọrụ.
\q2 Etufuola m ike m niile nʼihi ihe na-abụghị ihe.
\q1 Ma ihe ruru m dị nʼaka \nd Onyenwe anyị\nd*,
\q2 ụgwọ ọrụ m dịkwa nʼaka Chineke m.”
\b
\q1 
\v 5 Ma ugbu a \nd Onyenwe anyị\nd* na-asị,
\q2 Onye ahụ kpụrụ m nʼafọ nne m ka m bụrụ onye na-ejere ya ozi;
\q1 ka ọ kpọghachite Jekọb nye ya
\q2 ka achịkọtakwa ndị Izrel nyekwa ya onwe ya,
\q1 nʼihi na-abụ m onye nsọpụrụ dịrị nʼanya \nd Onyenwe anyị\nd*,
\q2 Chineke m aghọkwaarala m ike m.
\q1 
\v 6 Ọ sịrị,
\q1 “Ọ bụ ihe dị nta karịa, gị ị bụrụ m ohu,
\q2 ịkpọghachita ebo niile nke Jekọb
\q2 na ịkpọghachita ndị Izrel ndị m chebere.
\q1 Aga m emekwa ka ị bụrụ ìhè nye ndị mba ọzọ,
\q2 ka nzọpụta m site nʼaka gị ruo ndị bi na nsọtụ ụwa niile.”
\b
\q1 
\v 7 Nke a bụ ihe \nd Onyenwe anyị\nd* kwuru,
\q2 Onye mgbapụta na Onye nsọ Izrel
\q1 na-agwa onye ahụ a na-elelị anya, onye ahụ mba kpọrọ ihe arụ,
\q2 e, onye ahụ ndị na-achị achị mere ka ọ ghọọ ohu ha,
\q1 “Ndị eze ga-eguzo ọtọ mgbe ị na-agafe.
\q2 Ndịisi na-achị achị ga-akpọ isiala nye gị,
\q1 nʼihi na \nd Onyenwe anyị\nd*, Onye kwesiri ntụkwasị obi,
\q2 Onye nsọ Izrel, ahọpụtala gị.”
\s1 Nlọghachi nke Izrel
\p 
\v 8 Otu a ka \nd Onyenwe anyị\nd* na-ekwu:
\q1 “Nʼoge amara m, aga m aza unu,
\q2 nʼụbọchị nzọpụta aga m enyere unu aka.
\q1 Aga m echebe unu, mee ka unu
\q2 bụrụ ọgbụgba ndụ nye ndị mmadụ,
\q1 iweghachite ala ahụ
\q2 na ikegharịkwa ihe nketa ya nke tọgbọrọ nʼefu;
\q1 
\v 9 na-asị ndị mkpọrọ,\f + \fr 49:9 \ft Maọbụ, \fqa ndị a dọtara nʼagha\f* ‘Pụtanụ,’
\q2 na-asịkwa ndị nọ nʼọchịchịrị, ‘Pụtanụ nʼihe.’
\b
\q1 “Ha ga-adịkwa ka atụrụ m, nọọ nʼakụkụ ụzọ,
\q2 ndị na-ata ahịhịa nʼebe ịta nri nke ahịhịa ndụ, nʼakụkụ ugwu nta niile.
\q1 
\v 10 Agụ agaghị agụ ha, akpịrị agaghị akpọkwa ha nkụ.
\q2 Oke anwụ otiti nke ọzara agaghị acha ha ọzọ.
\q1 Nʼihi na Onyenwe anyị ga-esite nʼobi ebere ya duo ha
\q2 nʼakụkụ isi iyi jupụtara na mmiri.
\q1 
\v 11 Aga m emekwa ka ugwu ukwu niile ghọọ okporoụzọ,
\q2 meekwa ka okporoụzọ niile guzozie.
\q1 
\v 12 Lee, ndị m ga-alọghachi, ha ga-esitekwa nʼebe dị anya,
\q2 ụfọdụ ga-esite nʼugwu, ụfọdụ nʼọdịda anyanwụ,
\q2 ndị ọzọ ga-esite na mpaghara Aswan.\f + \fr 49:12 \ft Nʼime akwụkwọ ndị mgbe ochie, aha ị ga-ahụ bụ Sinim.\f*”
\b
\q1 
\v 13 Tienụ mkpu ọṅụ, eluigwe niile;
\q2 ka ụwa ṅụrịa ọṅụ.
\q2 Ugwu ukwu niile, bụọnụ abụ,
\q1 nʼihi na \nd Onyenwe anyị\nd* akasịela ndị ya obi.
\q2 Ọ ga-enwekwa obi ebere nʼihi iru ụjụ ha.
\b
\q1 
\v 14 Ma Zayọn sịrị, “\nd Onyenwe anyị\nd* agbakụtala m azụ;
\q2 Onyenwe m echefuola m.”
\b
\q1 
\v 15 “Nwanyị ọ pụrụ ichezọ nwa ya na-aṅụ ara,
\q2 hapụ inwe obi ebere nʼahụ nwa si nʼafọ ya?
\q1 Eleghị anya ọ pụrụ ichezọ,
\q2 ma agaghị m echezọ unu.
\q1 
\v 16 Lee, edeela m aha gị nʼọbụaka m,
\q2 nʼihu m kwa ka m debere foto mgbidi gị nke ga-adịgide.
\q1 
\v 17 Ụmụ gị emeela ngwangwa lọghachite,
\q2 ndị ahụ mere ka ị tọgbọrọ nʼefu ga-esi nʼime gị pụọ.
\q1 
\v 18 Welie anya gị abụọ lee gburugburu, legharịa anya,
\q2 ụmụ gị niile na-ezukọta na-alọghachikwute gị.
\q1 Dịka m na-adị ndụ,” ka \nd Onyenwe anyị\nd* kwubiri.
\q2 “Ị ga-eyi ha niile dịka ọla ịchọ mma,
\q2 ị ga-ekekwa ha dịka nwanyị a na-alụ ọhụrụ si eme.
\b
\b
\q1 
\v 19 “Ọ bụ ezie na e bibiri gị, mee ka ị tọgbọrọ nʼefu,
\q2 ala gị abụrụ nkpọnkpọ ebe,
\q1 ma ugbu a, ị gaghị ezuru ndị gị,
\q2 otu a kwa, ndị ahụ ripịara gị ga-anọ gị nʼebe dị anya.
\q1 
\v 20 Ụmụ niile a mụrụ nʼoge ọnwụ gbabara gị aka,\f + \fr 49:20 \ft Ndị a nọ na mba ọzọ mụọ ga-alọta\f*
\q2 ga-asịkwa na ntị gị,
\q1 ‘Ebe a dịrị anyị oke ntakịrị,
\q2 nye anyị ebe sara mbara karịa nke anyị ga-ebi nʼime ya.’
\q1 
\v 21 Mgbe ahụ, ị ga-eche nʼime onwe gị sị,
\q2 ‘Onye mụtaara m ọtụtụ ụmụ ndị a niile?
\q1 A dịrị m ka nwanyị na-amụghị nwa maọbụ onye ụmụ ya nwụchara.
\q2 Onye ajụrụ ajụ na nke e mere ka ọ gaa biri nʼala ọzọ.
\q2 Mụ onwe m fọdụrụ, naanị m.
\q1 Onye kwa mụụrụ m ụmụ ndị a?
\q2 Onye zụlitere ha?’ ”
\p 
\v 22 Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru,
\q1 “Lee, aga m akpọku ndị mba ọzọ,
\q2 weliere ha ọkọlọtọ m,
\q1 ha ga-ekulatara gị ụmụ gị ndị ikom nʼaka ha.
\q2 Ụmụ ndị inyom ka ha ga-ekukwasị nʼubu ha kulatakwa ha.
\q1 
\v 23 Ndị eze ga-abụkwa ndị nna na-azụ ụmụ gị,
\q2 ndị eze nwanyị ha ga-abụkwa ndị inyom na-enye ụmụ gị ara.
\q1 Ha ga-akpọ isiala nye gị,
\q2 rachakwaa aja dị nʼụkwụ gị abụọ.
\q1 Mgbe ahụ, ị ga-amata na mụ onwe m bụ \nd Onyenwe anyị\nd*,
\q2 matakwa na ihere agaghị eme ndị niile na-ele anya inyeaka m.”
\b
\q1 
\v 24 A ga-anara dike nʼagha ihe ọ lụtara nʼagha,
\q2 maọbụ zọpụta ndị a dọọrọ nʼagha site nʼaka onye afọ tara mmiri\f + \fr 49:24 \ft Ndị onye ezi omume dọtara nʼagha, a ga-eme ka ha wezuga onwe ha.\f*?
\p 
\v 25 Ma otu a ka \nd Onyenwe anyị\nd* sịrị,
\q1 “Nʼezie, a ga-esi nʼaka ndị bụ dike nʼagha pụnara ha ndị ha dọtara nʼagha.
\q2 A ga-esitekwa nʼaka onye na-akpa ike napụta ya ihe ọ dọtara nʼagha.
\q1 Nʼihi na aga m ebuso ha agha bụ ndị niile na-ebuso gị agha.
\q2 Aga m anapụtakwa ụmụ gị.
\q1 
\v 26 Aga m eme ka ndị na-akpagbu gị rie anụ ahụ onwe ha;
\q2 ha ga-aṅụ ọbara onwe ha ṅụbiga ya oke, dịka mmanya.
\q1 Mgbe ahụ, ihe niile bụ mmadụ nʼụwa ga-amata,
\q2 na mụ onwe m \nd Onyenwe anyị\nd*, bụ Onye na-azọpụta gị,
\q2 Onye mgbapụta gị, na Onye dị ike nke Jekọb.”
\c 50
\s1 Mmehie Izrel na nrube isi nke ohu ahụ
\p 
\v 1 Otu a ka \nd Onyenwe anyị\nd* sịrị,
\q1 “Olee ebe akwụkwọ m ji gbaa nne unu alụkwaghị m dị
\q2 bụ nke m ji chụpụ ya?
\q1 Ma ọ bụ onye nʼime ndị m ji ụgwọ
\q2 ka m resiri unu?
\q1 Ọ bụ nʼihi mmehie unu ka e ji ree unu;
\q2 nʼihi mmebi iwu unu ka e jiri chụọ nne unu.
\q1 
\v 2 Gịnị mere o ji bụrụ na o nweghị onye nọ ya mgbe m bịara?
\q2 Gịnị mere o nweghị onye zara m mgbe m kpọrọ oku?
\q1 Ọ pụtara na aka m dị mkpụmkpụ ịzọpụta unu?
\q2 Ọ ga-abụ na m enwekwaghị ike ịzọpụta?
\q1 Nʼihi na enwere m ike ịbara osimiri mba mee ya ka ọ ghọọ ala akọrọ.
\q2 Enwere m ike ime ka osimiri ghọrọ ọzara,
\q1 ka azụ niile dị nʼime ya nwụọ
\q2 nʼihi enweghị mmiri.
\q1 
\v 3 Ọ bụ mụ bụ onye ahụ na-eme ka ọchịchịrị kpuchie ihu eluigwe,
\q2 ka ihu eluigwe dịrị ka ihu onye na-eru ụjụ.”
\b
\q1 
\v 4 Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* enyela m amamihe ya
\q2 ka m nwee ike ịmata ihe m ga-agwa ndị a ike gwụrụ.
\q1 Ụtụtụ niile ka ọ na-akpọte mmụọ m,
\q2 meghee akpa uche m, ime ka m ghọta uche ya.
\q1 
\v 5 Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* emeghela ntị m abụọ,
\q2 ma enupughị m isi,
\q2 a tụgharịkwaghị m azụ.
\q1 
\v 6 Azụ m ka m megheere ndị tiri m ihe;
\q2 agba nti m abụọ ka m hapụụrụ ndị hopusiri m afụọnụ m.
\q1 Ezopụghị m ihu m
\q2 nʼebe ndị na-akwa emo, na ndị na-agbụ ọnụ mmiri nọ.
\q1 
\v 7 Ebe ọ bụ na Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* na-enyere m aka,
\q2 ihere agaghị eme m.
\q1 Nʼihi ya, ejikerela m onwe m ime uche ya; agaghị m elekwa anya nʼazụ,
\q2 a maara m na ihere agaghị eme m.
\q1 
\v 8 Nʼihi na onye na-agụ m nʼonye ezi omume nọ nso.
\q2 Onye ga-apụta ibo m ebubo?
\q2 Ya pụta ka anyị guzo ihu na ihu!
\q1 Onye nwere ebubo megide m?
\q2 Ya bịa ka anyị kwuo ya.
\q1 
\v 9 Lee, Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* bụ onye na-enyere m aka.
\q2 Onye pụrụ ịma m ikpe?
\q1 Lee, ha niile ga-aka nka dịrị ka uwe,
\q2 nla ga-erichapụkwa ha.
\b
\q1 
\v 10 Onye nʼetiti unu bụ onye ahụ na-atụ egwu \nd Onyenwe anyị\nd*,
\q2 na-egekwa ntị nʼokwu odibo ya?
\q1 Ka onye ahụ na-eje ije nʼọchịchịrị,
\q2 nke na-enweghị ìhè ọbụla,
\q1 tụkwasị obi nʼaha \nd Onyenwe anyị\nd*
\q2 daberekwa na Chineke ha.
\q1 
\v 11 Ma lee, unu niile ndị na-amụnye ọkụ,
\q2 ndị meere onwe ha ọwaọkụ,
\q1 nke unu ji na-ejegharị nʼọchịchịrị,
\q2 gaanụ nʼihu na-ejegharị nʼìhè ọkụ ahụ unu mụnyeere onwe unu.
\q1 Ihe unu ga-anata site nʼaka Onyenwe anyị
\q2 bụ ihe mwute nke ga-abịakwasị unu.
\c 51
\s1 Nzọpụta ebighị ebi dịrị Zayọn
\q1 
\v 1 Geenụ m ntị, unu ndị niile na-agbaso ezi omume,
\q2 ndị na-achọ \nd Onyenwe anyị\nd*!
\q1 Legidenụ oke nkume ahụ e sitere na ya wapụta unu anya.
\q2 E, legidenụ ọgba nkume ahụ e si nʼime ya gwupụta unu anya!
\q1 
\v 2 Legidenụ Ebraham bụ nna unu
\q2 na Sera anya, bụ ndị mụrụ unu.
\q1 Ebraham nọ naanị ya mgbe m kpọrọ ya,
\q2 ma a gọziri m ya, mee ka ọ ghọọ oke mba.
\q1 
\v 3 \nd Onyenwe anyị\nd* aghaghị ịkasị Zayọn obi,
\q2 werekwa obi ebere leta ebe ya niile e tikpọrọ etikpọ,
\q1 ọ ga-eme ala ọzara ya niile ka ọ dịka Iden,
\q2 ala ya nke niile ihe na-adịghị ga-adịkwa ka ubi a gbara ogige nke \nd Onyenwe anyị\nd*.
\q1 Ọṅụ na obi ụtọ ga-ejupụta nʼime ya,
\q2 inye ekele na ụda abụ ụtọ dị iche iche ga-adịkwa.
\b
\q1 
\v 4 Ndị m, geenụ m ntị;
\q2 ṅaa ntị, gị Izrel mba nkem,
\q1 nʼihi na iwu m ga-esi nʼọnụ m pụọ;
\q2 ikpe ikpe ziri ezi m ga-aghọkwara mba niile ìhè.
\q1 
\v 5 Ezi omume m na-abịaru unu nso ọsịịsọ,
\q2 nzọpụta m na-adịkwa nso.
\q2 Aga m achịkwa mba niile.
\q1 Mba dị anya ga na-ele anya ọbịbịa m;
\q2 ha ga na-ele anya nzọpụta nke m ga-azọpụta ha.
\q1 
\v 6 Welienụ anya unu lee anya nʼelu,
\q2 leekwanụ anya nʼụwa,
\q1 nʼihi na mbara eluigwe ga-agba barịị fuo, dịka anwụrụ ọkụ;
\q2 ụwa ga-aka nka dịka akwa,
\q2 ndị bi nʼime ya ga-anwụkwa dịka ijiji.
\q1 Ma nzọpụta m ga-adịgide ruo mgbe ebighị ebi,
\q2 ezi omume m ga-adịgidekwa, ọ gaghị agwụ agwụ.
\b
\q1 
\v 7 Geenụ m ntị, unu niile ndị maara ihe ọma,
\q2 unu ndị na-anabata iwu m nʼobi unu.
\q1 Unu atụla egwu ihe ndị mmadụ ga-asị unu,
\q2 unu atụkwala egwu nkwutọ ha ga-ekwutọ unu.
\q1 
\v 8 Nʼihi na nla ga-eri ha dịka o si eri akwa.
\q2 Ikpuru ga-erichapụ ha dịka o si eri ajị anụ.
\q1 Ma ezi omume m, na obi ebere, ga-adị ruo mgbe ebighị ebi.
\q2 Nzọpụta m ga-adịkwa site nʼọgbọ ruo nʼọgbọ.
\b
\q1 
\v 9 Teta, teta, yikwasị onwe gị ike,
\q2 gị aka \nd Onyenwe anyị\nd*,
\q1 bilie, dịka ụbọchị ndị gara aga,
\q2 dịka ọgbọ nke mgbe ochie.
\q1 Ọ bụghị gị gbubisịrị Rehab
\q2 ma dụgbukwaa anụ ọjọọ ahụ?
\q1 
\v 10 Ọ bụghị gị mere ka osimiri taa?
\q2 Mmiri ahụ dị omimi.
\q1 Ọ bụghị gị mekwara ka okporoụzọ dịrị nʼetiti ya,
\q2 ebe ndị ahụ ị gbapụtara si gafee?
\q1 
\v 11 Ndị ahụ \nd Onyenwe anyị\nd* gbapụtara ga-alọtakwa.
\q2 Ha ga-eji abụ bata na Zayọn;
\q2 ọṅụ na-adịgide ga-adịkwasị nʼisi ha,
\q1 oke ọṅụ na obi ụtọ ga-ejupụta nʼobi ha,
\q2 iru ụjụ na ịsụ ude ga-efelaga.
\b
\q1 
\v 12 “Mụ, ọ bụladị mụ onwe m, bụ Onye ahụ na-akasị unu obi.
\q2 Onye ka ị bụ, na ị na-atụ egwu nwa mmadụ nke ga-anwụ anwụ,
\q2 ị na-atụ egwu nwa mmadụ nke bụ naanị ahịhịa,
\q1 
\v 13 na ị na-echefu \nd Onyenwe anyị\nd* bụ onye kere unu,
\q2 onye na-esetipụ eluigwe,
\q2 onye tọkwara ntọala niile nke ụwa;
\q1 na-ebi ndụ ịtụ oke egwu ụbọchị niile
\q2 nʼihi oke iwe nke onye mkpagbu ahụ,
\q2 onye nke kpebiri ibibi unu?
\q1 Ma olee ebe oke iwe nke onye mkpagbu ahụ dị?
\q2 
\v 14 Nʼoge na-adịghị anya, a ga-agbapụta ndị mkpọrọ egwu mere ka ha rudata ala.
\q1 Ha agaghị anwụ nʼime olulu,
\q2 nri agakwaghị akọ ha.
\q1 
\v 15 Nʼihi na abụ m \nd Onyenwe anyị\nd* Chineke unu,
\q2 onye na-akpali oke osimiri mee ka ebili mmiri ya bigbọọ,
\q2 \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile bụ aha ya.
\q1 
\v 16 Etinyela m okwu m nʼọnụ gị,
\q2 chebekwa gị nʼọbụaka m.
\q1 Ọ bụ m tinyere eluigwe nʼọnọdụ ya,
\q2 dokwaa ntọala nke ụwa.
\q2 Ọ bụkwa m na-asị Zayọn, ‘Ndị m ka unu bụ.’ ”
\s1 Iko ọnụma Onyenwe anyị
\q1 
\v 17 Teta, teta,
\q2 bilie gị Jerusalem,
\q1 gị onye ṅụrụ site nʼaka \nd Onyenwe anyị\nd*,
\q2 bụ iko nke oke iwe ya.
\q1 Gị onye ṅụrụ ihe niile dị nʼime iko ahụ
\q2 nke na-eme ka ụmụ mmadụ dagbugharịa.
\q1 
\v 18 Ọ dịghị otu nwa ya nke fọdụrụ,
\q2 nke ga-agwa ya ihe ọ ga-eme,
\q1 maọbụ nke ga-edu ya nʼụzọ
\q2 o kwesiri ịgbaso.
\q1 
\v 19 Ihe abụọ ndị a adakwasịla gị.
\q2 Onye ga-akasị gị obi?
\q1 Mbibi na ịla nʼiyi, ụnwụ na mma agha,
\q2 onye ga-akasị gị obi?
\q1 
\v 20 Nʼihi na ụmụ gị ndị ikom adaala mba.
\q2 Ha na-atọgbọkwa nʼakụkụ okporoụzọ niile,
\q2 dịka mgbada ọnya mara.
\q1 Ha bụ ndị jupụtara nʼọnụma \nd Onyenwe anyị\nd*
\q2 na ịba mba nke Chineke gị.
\b
\q1 
\v 21 Ya mere, nụrụ nke a, unu ndị a na-akpagbu,
\q2 ndị ihe na-egbu ma ọ bụghị mmanya.
\q1 
\v 22 Lee ihe \nd Onyenwe anyị\nd* kwuru,
\q2 bụ Chineke unu, onye ihe banyere ndị ya na-emetụ nʼobi.
\q1 “Lee, aga m esite nʼaka gị
\q2 wezuga iko ahụ mere ka ị dagbugharịa,
\q1 ị gaghị aṅụkwa
\q2 site nʼiko ọnụma ahụ ọzọ.
\q1 
\v 23 Ma m ga-etinye ya nʼaka ndị ahụ na-akpagbu gị,
\q2 bụ ndị sịrị gị,
\q2 ‘makpuru nʼala ka anyị gaa ije nʼelu ahụ gị.’
\q1 I mere azụ gị ka ọ dị ka ala, dịka okporoụzọ
\q2 ebe ndị mmadụ si aga ije.”
\b
\b
\c 52
\q1 
\v 1 Teta, teta gị Zayọn,
\q2 yikwasị onwe gị ike dịka uwe!
\q1 Yikwasị onwe gị uwe mara mma,
\q2 gị Jerusalem, obodo dị nsọ.
\q1 Ndị a na-ebighị ugwu na ndị rụrụ arụ
\q2 agaghị abata nʼime gị ọzọ.
\q1 
\v 2 Kụchapụ aja dị nʼahụ gị,
\q2 bilie ọtọ, gị Jerusalem, nọdụ ala nʼocheeze gị.
\q1 Tọpụ onwe gị site nʼagbụ igwe e kere gị nʼolu,
\q2 gị ada Zayọn, a dọtara nʼagha.
\p 
\v 3 Nʼihi na otu a ka \nd Onyenwe anyị\nd* sịrị,
\q1 “Nʼefu ka erere unu, anaghị ndị zụrụ unu ego ọbụla,
\q2 ọ bụghịkwa ego ka a ga-eji gbapụta unu.”
\p 
\v 4 Nʼihi na otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwuru,
\q1 “Na mbụ, ọ bụ nʼala Ijipt ka ndị m gara biri,
\q2 ugbu a, ọ bụ ndị Asịrịa na-akpagbu ha.
\p 
\v 5 “Ma ugbu a, gịnị ka m nwere nʼebe a?” bụ ihe \nd Onyenwe anyị\nd* kwupụtara.
\q1 “Ebe ọ bụ na e durula ndị m pụọ nʼefu,
\q2 ndị na-achị ha na-akwakwa ha emo na-achị ha ọchị nlelị,”
\q2 ka \nd Onyenwe anyị\nd* kwupụtara.
\q1 “Ha na-ekwulukwa aha m
\q2 ogologo ụbọchị niile.
\q1 
\v 6 Nʼihi ya, ndị m ga-ama aha m;
\q2 nʼihi nke a, ha ga-amarakwa nʼụbọchị ahụ
\q1 na ọ bụ Mụ onwe m kwuru na ọ ga-eme.
\q2 E, ọ bụ mụ onwe m.”
\b
\q1 
\v 7 Lee ka ha si maa mma nʼelu ugwu
\q2 bụ ụkwụ ndị na-eweta\f + \fr 52:7 \ft Maọbụ, \fqa na-ezisa\f* oziọma,
\q1 onye na-ekwusa okwu udo,
\q2 e, onye na-eweta akụkọ ọma,
\q2 onye na-agbasa akụkọ banyere nzọpụta,
\q1 onye na-asị Zayọn,
\q2 “Lee, Chineke gị bụ eze!”
\q1 
\v 8 Geenụ ntị! Nụrụnụ olu ndị nche unu,
\q2 ndị na-eweli olu ha elu na-eti mkpu ọṅụ.
\q1 Nʼihi na mgbe \nd Onyenwe anyị\nd* ga-alọghachi Zayọn,
\q2 ha ga-ahụ ya anya.
\q1 
\v 9 Tienụ mkpu ọṅụ
\q2 unu mkpọmkpọ ebe niile e tikpọrọ etikpọ na Jerusalem,
\q1 nʼihi na \nd Onyenwe anyị\nd* akasịela ndị ya obi.
\q2 Ọ gbapụtala Jerusalem.
\q1 
\v 10 \nd Onyenwe anyị\nd* ga-eme
\q2 ka mba niile hụrụ ike ya dị nsọ;
\q1 ebe niile ụwa sọtụrụ ga-ahụkwa
\q2 nzọpụta Chineke anyị.
\b
\q1 
\v 11 Wezuganụ onwe unu, wezuganụ onwe unu, sinụ nʼebe ahụ pụọ.
\q2 Unu emetụkwala ihe ọbụla rụrụ arụ aka.
\q1 Sitenụ nʼetiti ya pụta, dịrịnụ ọcha,
\q2 unu ndị na-ebu ihe dị iche iche nke ụlọ \nd Onyenwe anyị\nd*.
\q1 
\v 12 Ma unu agaghị eji ọkụ ọkụ pụọ,
\q2 unu agakwaghị agbapụ ọsọ,
\q1 nʼihi na \nd Onyenwe anyị\nd* ga-ebutere unu ụzọ,
\q2 ọ bụkwa ya, Chineke Izrel, ga-echebe unu nʼazụ.
\s1 Ahụhụ na Ebube nke ohu ahụ
\q1 
\v 13 Lee, ohu m ga-enwe uche,
\q2 a ga-ebulikwa ya elu, ọ ga-abụkwa onye a na-asọpụrụ.
\q1 
\v 14 Dịka ibubo si nwụọ ọtụtụ ndị mmadụ nʼahụ;
\q2 otu a ka ihu ya bụ ihe e bibiri ebibi nke ukwuu, nke mere na ọ dịkwaghị ka ihu mmadụ ọzọ,
\q2 anụ ahụ ya ka ebibikwara nʼụzọ ọ na-agaghị eyikwa anụ ahụ mmadụ.
\q1 
\v 15 Otu a ka ọ ga-esi fesaa ọtụtụ mba dị iche iche,\f + \fr 52:15 \ft Maọbụ, \fqa otu a ka ọtụtụ mba dị iche iche ga-anọ na mgbagwoju anya.\f*
\q2 ndị eze ga-emechikwa ọnụ ha nʼihi ya,
\q1 ọ bụ ihe a na-agwaghị ha ka ha ga-ahụ,
\q2 ihe ha a ka anụbeghị, ka ha ga-aghọtakwa.
\b
\c 53
\q1 
\v 1 Onye kweere ozi anyị,
\q2 ọ bụkwa nʼahụ onye ka e kpugheere ogwe aka \nd Onyenwe anyị\nd*?
\q1 
\v 2 Nʼihi na o tolitere nʼihu Onyenwe anyị dịka ome,
\q2 dịka mgbọrọgwụ nke puputara nʼala kpọrọ nkụ.
\q1 O nweghị ụdịdị ọma maọbụ ịma mma nke ga-eme ka anyị lee ya anya.
\q2 O nweghị ihe ọbụla dị nʼụdịdị ya nke ga-eme ka ihe banyere ya masị anyị, maọbụ mee ka anyị chọsie ya ike.
\q1 
\v 3 Ndị mmadụ ledara ya anya, jụkwa ya.
\q2 Ọ bụ onye nwere ọtụtụ ihe mgbu, bụrụkwa onye hụrụ ọtụtụ ahụhụ.
\q1 Ma anyị gbakụtara ya azụ, jụ ilenye anya nʼebe ọ nọ.
\q2 E, anyị ledara ya anya, jụ ịgụ ya dịka ọ bụ ihe ọbụla.
\b
\q1 
\v 4 Nʼezie, ihe mgbu niile anyị ka o buuru,
\q2 burukwa ahụhụ nke ọrịa anyị niile,
\q1 ma anyị gụrụ ya ka onye Chineke tara ahụhụ,
\q2 onye o tiri ihe otiti, na onye o mekpara ahụ.
\q1 
\v 5 Ma e tipụrụ ya ọnya nʼihi mmehie anyị:
\q2 ọ bụkwa nʼihi ajọ omume anyị ka e ji merụchaa ya ahụ.
\q1 E mere ka anyị nwee udo nʼihi ahụhụ ọ hụrụ;
\q2 ọ bụkwa ubiri ụtarị dị ya nʼahụ mere anyị ji bụrụ ndị ahụ dị ike.
\q1 
\v 6 Anyị niile akpafuola dịka igwe atụrụ;
\q2 onye ọbụla nʼime anyị etinyela isi ya nʼụzọ nke aka ya.
\q1 Ma \nd Onyenwe anyị\nd* ebokwasịla ya
\q2 ajọ omume anyị niile.
\b
\q1 
\v 7 A kpagburu ya, mesie ya ihe ike,
\q2 ma otu mkpụrụ okwu esighị ya nʼọnụ pụta.
\q1 E duuru ya pụọ dịka atụrụ a na-aga igbu egbu,
\q2 dịka atụrụ a na-akpachapụ ajị ya si anọ nwayọọ nʼihu ndị na-akpacha ya ajị,
\q2 otu a ka o si nọdụ na-asagheghị ọnụ ya.
\q1 
\v 8 Site na mmegbu na ikpe ka e ji wepụ ya.
\q2 Ma, onye nʼetiti ndị ọgbọ\f + \fr 53:8 \ft Ya bụ, kwụpụtara\f* ya weliri olu kwuo okwu?
\q1 Nʼihi na e bipụrụ ya site nʼala ndị dị ndụ;
\q2 maka njehie ndị m ka e ji tie ya ihe.\f + \fr 53:8 \ft Ya bụ, taa ya ahụhụ\f*
\q1 
\v 9 E nyefere ya ka e lie ya dịka onye na-emebi iwu,
\q2 ọ bụkwa nʼetiti ndị ọgaranya ka e liri ya,
\q1 ọ bụ ezie na o nweghị ihe ọjọọ ọbụla o mere,
\q2 ọ dịkwaghị okwu aghụghọ si nʼọnụ ya pụta.
\b
\q1 
\v 10 Ma ọ bụ ọchịchọ \nd Onyenwe anyị\nd* ịzọpịa ya, na ime ka ọ taa ahụhụ.
\q2 Nʼihi na ọnwụ ya bụ aja a chụrụ nʼihi ikpe ọmụma nke mmehie.
\q1 Ọ ga-ahụ ọtụtụ ụmụ na ụmụ ụmụ ya; ọ ga-adịkwa ndụ ogologo oge.
\q2 Nzube Chineke niile ga-emezukwa site na ya.
\q1 
\v 11 Mgbe ọ hụsịrị ahụhụ,
\q2 ọ ga-emesịa hụ ìhè nke ndụ, afọ ga-ejukwa ya,
\q1 site nʼihe ọmụma ya, ka onye ezi omume ahụ, bụ ohu m ga-eme ka a gụọ ọtụtụ mmadụ dịka ndị ezi omume,
\q2 ọ ga-ebukwa mmehie ha niile.
\q1 
\v 12 Nʼihi ya, aga m enye ya oke nʼetiti ndị bara ụba,\f + \fr 53:12 \ft Maọbụ, \fqa ndị dị ike\f*
\q2 ọ ga-esokwa ndị bụ dike keta ihe nkwata nʼagha,
\q1 nʼihi na ọ wụpụrụ ndụ ya nye ọnwụ,
\q2 a gụkọtara ya na ndị na-emebi iwu.
\q1 Ma ya onwe ya buuru mmehie ọtụtụ mmadụ,
\q2 rịọọkwara ndị na-emebi iwu arịrịọ.
\c 54
\s1 Ebube dị nʼihu nye Zayọn
\q1 
\v 1 “Bụọ abụ, gị nwanyị aga,
\q2 gị onye na-amụtaghị nwa;
\q1 tie mkpu ọṅụ, tiwakwaa olu abụ,
\q2 gị onye ime nwa na-emetụbeghị;
\q1 nʼihi na ụmụ nwanyị ahụ a hapụrụ naanị ya ga-adị ọtụtụ
\q2 karịa ụmụ nke nwanyị nwere di,”
\q2 Otu a ka Onyenwe anyị kwuru.
\q1 
\v 2 “Mee ka ebe ụlọ ikwu gị saa mbara,
\q2 gbasapụ akwa mgbochi ụlọ ikwu gị,
\q2 egbochila gbasapụ aka;
\q1 mee ka ụdọ gị dị ogologo,
\q2 meekwa ka o sie ike nke ọma.
\q1 
\v 3 Nʼihi na nʼaka nri na nʼaka ekpe ka ị ga-agbasa gaa;
\q2 ụmụ gị ga-achụpụ mba dị iche iche site nʼala ha,
\q2 bichikwaa nʼobodo ha niile dakpọsịrị adakpọsị, nke tọgbọrọ nʼefu.
\b
\q1 
\v 4 “Atụla egwu, nʼihi na ihere agaghị emekwa gị ọzọ.
\q2 Ị gaghị abụkwa onye e wedara nʼala.
\q1 Ị gakwaghị echeta ihere mere gị mgbe ị bụ nwantakịrị,
\q2 na ịta ụta dịrị gị nʼihi ọnwụ di gị.
\q1 
\v 5 Nʼihi na onye kere gị ga-abụrụ gị di.
\q2 Aha ya bụ \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile;
\q1 Onye nsọ Izrel bụ Onye mgbapụta gị,
\q2 Chineke nke ụwa niile ka a na-akpọ ya.
\q1 
\v 6 Nʼihi na \nd Onyenwe anyị\nd* ga-akpọghachi gị
\q2 dịka a ga-asị na ị bụ nwunye a hapụrụ ahapụ, nke ọ na-ewutakwa nʼime mmụọ ya
\q1 bụ nwunye alụtara na nwantakịrị,
\q2 naanị ka ọ bụrụ onye ajụrụ ajụ,” ka Chineke gị na-ekwu.
\q1 
\v 7 “Naanị nwa mgbe nta ka m hapụrụ gị.
\q2 Ma aga m eji obi ebere ukwuu kpọghachikwa gị
\q1 
\v 8 Na nwa oge, esitere m nʼoke iwe na-ewe m
\q2 zonarị gị ihu m,
\q1 ma site nʼịhụnanya m nke na-adịgide ruo mgbe ebighị ebi,
\q2 aga m enwe ọmịiko nʼahụ gị.”
\q2 Otu a ka \nd Onyenwe anyị\nd*, onye mgbapụta gị kwuru.
\b
\q1 
\v 9 “Dịka m si ṅụọ iyi nʼoge Noa sị na m agaghị ekwekwa ka mmiri kpuchie ụwa ọzọ,
\q2 bibie ndụ ndị dị nʼime ya,
\q1 ana m aṅụkwa iyi ugbu a na mụ agaghị ekwe ka iwe m bịakwasị gị ọzọ.
\q2 Agakwaghị m abasiri gị mba ike.
\q1 
\v 10 Nʼihi na a pụrụ iwezuga ugwu ukwu niile,
\q2 wezugakwa ugwu nta niile site nʼọnọdụ ha,
\q1 ma obi ebere m agaghị esi nʼebe ị nọ pụọ,
\q2 agaghị ewezugakwa ọgbụgba ndụ nke udo m,”
\q2 ka \nd Onyenwe anyị\nd*, onye nwere ọmịiko nʼahụ gị, kwuru.
\b
\q1 
\v 11 “Gị, onye a na-emekpa ahụ, onye oke ikuku ụwa a na-ebugharị, nke onye ọbụla na-adịghị akasị obi,
\q2 lee, aga m e ji nkume tọkwọisi wugharịa gị,
\q2 jirikwa nkume ọma safaia dị oke ọnụahịa tọọ ntọala gị niile.
\q1 
\v 12 Aga m eji nkume rubi wugharịa akụkụ ụlọ gị niile,
\q2 jiri nkume na-egbu nweghenweghe wuo ọnụ ụzọ ama gị niile.
\q2 Aga m ejikwa nkume dị oke ọnụahịa wuo mgbidi obodo gị.
\q1 
\v 13 Ụmụ gị niile ga-abụ ndị \nd Onyenwe anyị\nd* ga-akụziri ihe.
\q2 Udo ha ga-adịkwa ukwu.
\q1 
\v 14 Nʼezi omume ka a ga-eme ka ị guzosie ike.
\q1 Mmegbu ga-adịkwa anya site nʼebe ị nọ,
\q2 nʼihi ya, ị gaghị atụ egwu ihe ọjọọ ọbụla.
\q1 Ọ dịghị ihe egwu ga-abịaru gị nso,
\q2 nʼihi na a ga-ewezuga ha site nʼebe ị nọ.
\q1 
\v 15 Ọ bụrụ na onye ọbụla abịa ịlụso gị ọgụ, ọ siteghị nʼaka m;
\q2 onye ọbụla nke na-alụso gị ọgụ ga-abụ onye e meriri emeri.
\b
\q1 
\v 16 “Lee, ọ bụ mụ onwe m kere ọkpụ ụzụ
\q2 nke na-eji icheku afụ ọkụ
\q2 o ji akpụ ihe agha nke mbibi.
\q1 Ọ bụkwa m kere ndị agha ahụ mbibi bụ ọrụ ha.
\q2 
\v 17 Nʼụbọchị ahụ, ọ dịghị ihe agha a kpụrụ megide gị nke ga-adị ire.
\q2 Ọzọ, ị ga-emeri ndị niile kpọrọ gị ikpe mmegide.
\q1 Nʼihi na nke a bụ ihe nketa dịrị ndị ohu \nd Onyenwe anyị\nd*.
\q2 Mkpepụta\f + \fr 54:17 \fqa Mmeri ha \ft maọbụ, \fqa ezi omume\f* ha na-esite na m.”
\q2 Otu a ka \nd Onyenwe anyị\nd* kwubiri ya.
\c 55
\s1 Bịanụ ndị akpịrị na-akpọ nkụ
\q1 
\v 1 Gee ntị, bịa onye ọbụla akpịrị na-akpọ nkụ,
\q2 bịanụ na mmiri,
\q1 unu ndị na-enweghị ego
\q2 bịanụ zụọ, riekwa.
\q1 Bịanụ, zuru mmanya na mmiri ara ehi
\q2 na-ejighị ego na-arụghị ọnụahịa ọbụla.
\q1 
\v 2 Nʼihi gịnị ka i ji na-atụfu ego gị ịzụ ihe na-abụghị ezi nri?
\q2 Gịnị mere i ji na-adọgbu onwe gị nʼọrụ nʼihe na-apụghị iju gị afọ?
\q1 Gee ntị, geenụ m ntị nke ọma, rie ezigbo nri
\q2 mkpụrụobi gị ga-enwe afọ ojuju na nri dị ezi mma!
\q1 
\v 3 “Tọọnụ ntị unu nʼala, bịakwute m!
\q2 Gee ntị, ka inwe ike dị ndụ.
\q1 Mụ na unu ga-aba nʼọgbụgba ndụ ebighị ebi,
\q2 bụ ịhụnanya m kwesiri ntụkwasị obi nke m kwere Devid na nkwa.
\q1 
\v 4 Lee, emere m ya ka ọ ghọọrọ ndị niile dị iche iche onyeama,
\q2 ka ọ bụrụ onyendu na onyeisi ọchịchị nye ndị niile dị iche iche.
\q1 
\v 5 Nʼezie, gị onwe gị ga-akpọku mba dị iche iche na i maghị,
\q2 mba ndị ahụ na-amaghị gị ga-ejikwa ọsọ gbakwute gị,
\q1 nʼihi \nd Onyenwe anyị\nd* Chineke gị,
\q2 Onye nsọ nke Izrel,
\q2 nʼihi na o meela ka ị bụrụ ihe dị oke mma.”
\b
\q1 
\v 6 Chọọnụ \nd Onyenwe anyị\nd* mgbe a ga-achọta ya.
\q2 Kpọkuonụ ya mgbe ọ nọ nso.
\q1 
\v 7 Ka onye na-eme ihe ọjọọ hapụ ụzọ ya,
\q2 ka onye ajọ omume hapụ echiche ọjọọ ya niile.
\q1 Ka ha tụgharịa bịakwute \nd Onyenwe anyị\nd*, ọ ga-emere ha ebere,
\q2 ha bịakwute Chineke anyị, nʼihi na ọ ga-agbaghara ha mmehie ha niile.
\b
\q1 
\v 8 “Nʼihi na echiche m ha abụghị echiche unu,
\q2 ụzọ unu niile, ha abụkwaghị ụzọ m,”
\q2 ka \nd Onyenwe anyị\nd* kwupụtara.
\q1 
\v 9 “Nʼihi na dịka eluigwe si dị elu karịa ụwa,
\q2 otu a ka ụzọ m niile si dị elu karịa ụzọ unu niile,
\q2 otu a kwa ka echiche m niile si dị elu karịa echiche unu niile.
\q1 
\v 10 Dịka mmiri na mkpụrụ mmiri
\q2 si esi nʼeluigwe ada nʼụwa
\q1 na-alaghachighị nʼeluigwe
\q2 ma ọ bụrụ na o meghị ka mmiri dee ala,
\q1 mee ka ihe ubi pupụta, too eto,
\q2 meekwa ka ọ mịa mkpụrụ nye onye na-akụ ihe ọkụkụ, bụrụkwa ihe oriri nye onye na-eri nri.
\q1 
\v 11 Otu a ka okwu si m nʼọnụ pụọ si adị.
\q2 Ana m ezipu ya, ọ gaghị alọghachikwute m nʼefu.
\q1 Ọ ga-emezu ihe niile m chọrọ ka o mee,
\q2 baakwa ụba ebe ọbụla m zigara ya.
\q1 
\v 12 Nʼihi na unu ga-eji ọṅụ pụọ,
\q2 a ga-esikwa nʼebe ahụ dupụta unu nʼudo.
\q1 Ugwu ukwu niile, na ugwu nta niile
\q2 na osisi niile nke ubi,
\q1 ga-eti mkpu ọṅụ,
\q2 kụọkwa aka nʼobi ụtọ.
\q1 
\v 13 Ebe ogwu na-eto na mbụ, osisi junipa ga-eto na ya;
\q2 ebe uke toro, osisi mietul ga-eto na ya.
\q1 Ihe ndị a ga-aghọrọ \nd Onyenwe anyị\nd* aha dị ukwuu,
\q2 nke ga-abụkwa ihe ịrịbama
\q2 ga-adị ruo mgbe ebighị ebi.”
\c 56
\s1 Nzọpụta dịrị ndị ọzọ
\p 
\v 1 Nke a bụ ihe \nd Onyenwe anyị\nd* sịrị,
\q1 “Debenụ ikpe ziri ezi,
\q2 meekwanụ ihe ziri ezi.
\q1 Nʼihi na nzọpụta m dị nso,
\q2 ezi omume m ga-apụta ihe mgbe na-adịghị anya.
\q1 
\v 2 Ngọzị na-adịrị onye na-eme nke a,
\q2 bụ onye ahụ nke na-ejidesi ya aka ike,
\q1 onye ahụ nke na-edebe ụbọchị izuike m na-emerụghị ya,
\q2 nke na-edebekwa aka ya ka ọ ghara ime ihe ọjọọ.”
\b
\q1 
\v 3 Ka onye ala ọzọ bụ onye jikọrọ onwe ya na \nd Onyenwe anyị\nd* sị,
\q2 “\nd Onyenwe anyị\nd* aghaghị i site na ndị ya kewapụ m.”
\q1 Ka onye onozi ọbụla gharakwa ị sị
\q2 “Mụ onwe m bụ naanị osisi kpọnwụrụ akpọnwụ.”
\p 
\v 4 Nʼihi na otu a ka \nd Onyenwe anyị\nd* kwuru:
\q1 “Nye ndị onozi ahụ na-edebe ụbọchị izuike m niile,
\q2 ndị na-ahọrọ ihe na-atọ m ụtọ,
\q2 na ndị na-ejidesikwa ọgbụgba ndụ m ike.
\q1 
\v 5 Aga m enye ha nʼime ụlọ m na nʼetiti mgbidi ya,
\q2 ihe ncheta na aha
\q2 dị mma karịa ụmụ ndị ikom na ụmụ ndị inyom.
\q1 Aga m enye ha aha ga-adị ruo ebighị ebi
\q2 nke a na-agaghị echezọ ruo ebighị ebi.
\q1 
\v 6 Ma ndị mba ọzọ ndị gbakwuuru \nd Onyenwe anyị\nd*
\q2 ijere ya ozi,
\q1 na ịhụ aha \nd Onyenwe anyị\nd* nʼanya,
\q2 nakwa ị bụ ndị ohu ya,
\q1 ndị niile na-edebe ụbọchị izuike nsọ na-emerụghị ya,
\q2 na ndị jidesiri ọgbụgba ndụ m ike,
\q1 
\v 7 ndị a ka m ga-akpọta nʼugwu nsọ m,
\q2 meekwa ka ha ṅụrịa ọṅụ nʼime ụlọ ekpere m.
\q1 Aga m anabata aja nsure ọkụ ha na onyinye niile ha nyere
\q2 nʼebe ịchụ aja m.
\q1 Nʼihi na a ga-akpọ ụlọ m
\q2 Ụlọ Ekpere nye mba niile dị iche iche.”
\q1 
\v 8 Otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* kwupụtara,
\q2 bụ onye ahụ na-eme ka Izrel si nʼebe ha gbapụrụ ọsọ lọta,
\q1 “Aga m achịkọtakwa ndị ọzọ tinyere ha
\q2 tinyekọtara na ndị ya achịkọtarala.”
\s1 Ebubo Chineke megide ndị ajọọ omume
\q1 
\v 9 Bịanụ, unu anụmanụ niile nke oke ọhịa.
\q2 Bịanụ dọgbuo, unu ụmụ anụmanụ nke oke ọhịa.
\q1 
\v 10 Nʼihi na ndị na-eche ndị m nche kpuru ìsì.
\q2 Ha niile bụ ndị amamihe kọrọ.
\q1 Ha dị ka nkịta dara ogbi,
\q2 nke na-adịghị agbọ ụja.
\q1 Ha hụrụ ịrahụ ụra na ịrọ nrọ,
\q2 na idina ndina nʼanya.
\q1 
\v 11 Ha bụ nkịta na-eribiga nri oke;
\q2 ha adịghị enwe afọ ojuju.
\q1 Ha bụ ndị ọzụzụ atụrụ na-enweghị nghọta,
\q2 ha niile echela ihu nʼụzọ nke aka ha,
\q2 onye ọbụla na-agbalịsị ike ịchọta uru nke ya.
\q1 
\v 12 Onye ọbụla na-asị, “Bịa ka m weta mmanya,
\q2 ka anyị ṅụjuokwa mmanya nʼaba nʼanya afọ anyị.
\q1 Echi ga-adịkwa ka taa,
\q2 ma ọ bụkwanụ dị mma karịa.”
\b
\b
\c 57
\q1 
\v 1 Ndị ezi omume na-ala nʼiyi,
\q2 ma ọ dịghị onye ọbụla na-etinye ya nʼobi;
\q1 a na-ewezuga ndị ji obi ha niile na-efe Chineke,
\q2 ma ọ dịghị onye na-aghọta,
\q1 na-ewezugara onye ezi omume
\q2 pụọ nʼihu ihe ọjọọ.
\q1 
\v 2 Ndị na-agazi agazi nʼụzọ ha
\q2 na-abanye nʼudo.
\q2 Ha na-enwekwa izuike mgbe ha dinara nʼọnwụ.
\b
\q1 
\v 3 “Ma unu onwe unu, bịanụ nʼebe a, unu ụmụ ndị mgbaasị,
\q2 unu ụmụ ndị na-akwa iko, na ụmụ ndị akwụna.
\q1 
\v 4 Onye ka unu na-akwa emo?
\q2 Onye ka unu na-akọcha,
\q2 na-arapụtakwara ire unu?
\q1 Unu ọ bụghị ụmụ ndị nnupu isi,
\q2 mkpụrụ ndị na-ekwu okwu ụgha?
\q1 
\v 5 Unu na-emejupụta ihe ọjọọ niile na-agụ obi unu agụụ
\q2 mgbe unu zukọrọ na-efe arụsị unu nʼokpuru osisi ook ọbụla.
\q1 Unu na-ewerekwa ụmụ unu chụọ aja
\q2 na ndagwurugwu niile, na nʼokpuru nkume niile dị elu.
\q1 
\v 6 Chi unu na-efe bụ nkume niile na-akwọ mụrụmụrụ,\f + \fr 57:6 \ft Nkume ndị a na-akwọ mụrụmụrụ bụ ihe ha ji ejere chi ndị ahụ na-abụghị chi ozi.\f*
\q2 nke dị na ndagwurugwu niile, ha bụ ihe nketa nza unu fere.
\q1 E, ọ bụ ha ka unu na-awụpụrụ onyinye mmanya unu niile
\q2 na onyinye mkpụrụ ọka unu niile.
\q2 Nʼihi ihe ndị a niile, m ga-esi aṅaa dere duu?
\q1 
\v 7 Ọ bụ nʼelu ugwu dị elu ka unu doziiri onwe unu ihe ndina,
\q2 nʼebe ahụ kwa ka unu gara chụọ aja unu.
\q1 
\v 8 Ọ bụkwa nʼazụ ọnụ ụzọ niile, na ibo ụzọ niile,
\q2 ka ị kwụbara oyiyi arụsị gị.
\q1 Ị gbakụtara m azụ,
\q2 yipụ uwe gị rịbanye nʼime ihe ndina gị,
\q1 ebe gị na ndị ahụ ị hụrụ nʼanya dinakọrọ,
\q2 imejupụta ihe ọjọọ ahụ na-agụ obi gị agụụ.
\q1 
\v 9 Ị were mmanụ jekwuru Molek\f + \fr 57:9 \ft Maọbụ, \fqa eze\f*
\q2 meekwa ka mmanụ otite gị na-esi isi ụtọ baa ụba.
\q1 Ị zipụrụ ndị nnọchite anya gị\f + \fr 57:9 \ft Ya bụ, arụsị apịrị apị\f* gaa na mba dị anya;
\q2 ị gbadara ruo nʼime ime ala mmụọ.
\q1 
\v 10 Oke mwagharị ndị a niile emeela ike gwụsịa gị,
\q2 ma ị dịghị asị, ‘Olileanya adịghị.’
\q1 Ị chọtara ntute nye ndụ gị,
\q2 ya mere, na ị daghị mba.
\b
\q1 
\v 11 “Onye na-emenye gị ụjọ na egwu dị otu a?
\q2 Nke mere na ị dịghị agwa m eziokwu?
\q1 Ị naghị echetakwa m,
\q2 ị naghị atụgharịkwa ihe banyere m nʼobi gị?
\q1 Ọ bụ nʼihi na m gbara nkịtị oge ndị a niile
\q2 ka i ji hapụ ịtụ m egwu?
\q1 
\v 12 Lee, aga m ekpughe ezi omume gị na ọrụ ọma gị,
\q2 igosi gị na ihe ndị a ị gụrụ dị ka ezi ihe agaghị enyere gị aka.
\q1 
\v 13 Mgbe ị ga-eti mkpu akwa maka enyemaka,
\q2 ka arụsị niile ndị ịchịkọbara zọpụta gị.
\q1 Ikuku ga-eburu ha niile bufuo,
\q2 naanị otu nkuume ga-ekutu ha.
\q1 Ma onye ọbụla gbabara nʼime m izere ndụ
\q2 ga-eketa ala ahụ;
\q2 ha ga-enwetakwa ugwu nsọ m.”
\s1 Nkasiobi dịrị ndị dị umeala nʼobi
\p 
\v 14 A ga-asịkwa,
\q1 “Dozienụ ụzọ! Dozienụ ụzọ, mee ya ka ọ maa mma.
\q2 Bupụsịanụ ihe ịsọ ngọngọ niile nʼụzọ ndị m.”
\q1 
\v 15 Nʼihi ihe a ka onye dị elu, onye e mere ka ọ dị ukwuu,
\q2 onye dị mgbe ebighị ebi, onye aha ya dị nsọ kwuru:
\q1 “Ebi m nʼebe dị elu nke dịkwa nsọ,
\q2 ibinyere onye dị umeala nʼobi, na onye wedara mmụọ ya nʼala,
\q1 itute mmụọ nke onye e wedara nʼala,
\q2 na ịkpọlite mmụọ nke onye dị umeala nʼobi.
\q1 
\v 16 Nʼihi na ọ bụghị ruo ebighị ebi ka m ga na-emegide gị,
\q2 maọbụ na-egosi iwe m.
\q1 Ọ bụrụ na m emee otu a, mmụọ ndị mmadụ ụwa niile ga-ada mba,
\q2 ya na mkpụrụobi niile ahụ m ji aka m kpụọ.
\q1 
\v 17 Ewesoro m ha iwe nʼihi mmehie ha na oke ọchịchọ ha.
\q2 Ọ bụkwa nʼihi ya ka m ji taa ha ahụhụ, gbakụtakwa ha azụ.
\q2 Ma lee, ha nọgidesikwara ike na-eme mmehie, na-eme ihe ọbụla nke na-atọ obi ha ụtọ.
\q1 
\v 18 Ahụla m ihe niile ha mere ma aga m agwọ ha.
\q2 Aga m edu ha, kasịekwa ndị na-eru ụjụ nʼIzrel obi.
\q2 
\v 19 Aga m eme ka abụ otuto dị nʼegbugbere ọnụ ha.
\q1 Udo, udo, dịrị ndị nọ nso na ndị nọ nʼebe dị anya,”
\q2 ka \nd Onyenwe anyị\nd* kwuru.
\q1 “Aga m agwọkwa ha.”
\q1 
\v 20 Ma ndị niile na-emebi iwu dị ka oke osimiri na-amagharị amagharị,
\q2 nke na-adịghị ezu ike mgbe ọbụla.
\q2 Ọ na-amapụtakwa ụrọ na apịtị.
\q1 
\v 21 “Ọ dịkwaghị udo dịrị onye na-emebi iwu,” ka Chineke kwuru.
\c 58
\s1 Ezi ibu ọnụ
\q1 
\v 1 “Welie olu gị tie mkpu, egbochikwala iti mkpu.
\q2 Welie olu gị dịka opi ike.\f + \fr 58:1 \ft Opi ike bụ ihe e ji akpọkọta ndị agha nʼoge agha.\f*
\q1 Gwa ndị m nnupu isi ha,
\q2 gwakwa ụlọ Jekọb mmehie ha.
\q1 
\v 2 Kwa ụbọchị ka ha na-achọ m
\q2 ha na-eme dịka ọ na-agụ ha agụ ịmara ụzọ m niile,
\q1 dịka a ga-asị na ha bụ mba na-eme ihe ziri ezi,
\q2 ndị na-agbakụtaghị iwu Chineke ha azụ.
\q1 Ha na-ajụ m maka ikpe ziri ezi,
\q2 na-eme dịka ọ na-agụ ha agụụ ka Chineke bịaruo ha nso.
\q1 
\v 3 Ha na-asị, ‘Nʼihi gịnị ka anyị ji ebu ọnụ,
\q2 ma ị dịghị ahụta ya?
\q1 Nʼihi gịnị ka anyị ji weda onwe anyị nʼala,
\q2 ma ị dịghị ahụta nke a?’
\b
\q1 “Ma nʼụbọchị unu na-ebu ọnụ, unu na-eme ihe masịrị unu,
\q2 unu na-eji anya ike nara ndị na-arụrụ unu ọrụ ihe ha rụpụtara.
\q1 
\v 4 Nʼoge ahụ, ọ bụ ise okwu na ịlụ ọgụ,
\q2 ya na iti ibe unu ọkpọ nʼihi ajọọ obi ka unu ji emechi ụbọchị ibu ọnụ unu.
\q1 Unu apụghị ibu ọnụ otu unu si eme taa
\q2 na-ele anya ka anụ olu unu nʼelu.
\q1 
\v 5 Nke a ọ bụ ụdị obubu ọnụ nke m họpụtara,
\q2 naanị ụbọchị nke ndị mmadụ ji eweda onwe ha nʼala?
\q1 Ọ bụ naanị nke mmadụ ji ehulata isi ya nʼala dịka osisi achara,
\q2 nke i dina nʼakwa mkpe na ntụ?
\q1 Ọ bụ nke a ka unu na-akpọ obubu ọnụ,
\q2 ụbọchị nke \nd Onyenwe anyị\nd* nabatara?
\b
\q1 
\v 6 “Nke a ọ bụghị ụdị obubu ọnụ m họpụtara:
\q1 Ịtọpụ agbụ niile nke ikpe na-ezighị ezi,
\q2 na ịtọpụ ụdọ niile nke mmegbu,
\q1 na ime ka ndị a na-emegbu nwere onwe ha
\q2 na itiji yoku ọbụla?
\q1 
\v 7 Ka i kenye ndị agụụ na-agụ ihe oriri gị,
\q2 ka ị kpọbata nʼime ụlọ gị ndị na-enweghị onye inyeaka, ma ndị ogbenye.
\q1 Ka i nye ndị na-agba ọtọ uwe,
\q2 ka ị hapụ izo onwe gị nʼebe ndị ikwu gị chọrọ inyeaka gị nọ.
\q1 
\v 8 Ọ bụrụ na i mee ihe ndị a, aga m eme ka ihuọma m chakwasị gị dịka ìhè isi ụtụtụ.
\q2 A ga-agwọkwa ọrịa gị niile.
\q1 Mgbe ahụ, ezi omume gị ga-edu gị,
\q2 ebube \nd Onyenwe anyị\nd* ga-echekwa gị nʼazụ.
\q1 
\v 9 Mgbe ahụ, ị ga-akpọ, \nd Onyenwe anyị\nd* ga-azakwa,
\q2 ị ga-eti mkpu akwa maka enyemaka, ọ ga-asị gị, Lekwa m nʼebe a.
\b
\q1 “Ọ bụrụ na ị wezuga yoku mmegbu,
\q2 ọ bụrụkwa na ịkwụsị ịtụ mkpịsịaka, na ịgbasa okwu ịkpọ asị,
\q1 
\v 10 ọ bụrụ na inye ndị agụụ na-agụ nri,
\q2 nyere ndị nọ na mkpa aka,
\q1 mgbe ahụ, ìhè gị ga-achawapụta,
\q2 ọchịchịrị niile gbara gị gburugburu ga-aghọ ìhè, na-achakwa ka ehihie.
\q1 
\v 11 \nd Onyenwe anyị\nd* ga na-edu gị mgbe niile.
\q2 Ọ ga-eme ka afọ jụ gị nʼala kpọrọ nkụ,
\q2 meekwa ka ị nọrọ nʼahụ isiike.
\q1 Ị ga-adịkwa ka ubi a gbara ogige nke a na-agba mmiri nke ọma,
\q2 dịka isi iyi na-adịghị ata ata.
\q1 
\v 12 Ndị gị ga-edozi mkpọmkpọ ebe ochie niile.
\q2 Ha ga-ebulikwa ntọala nke mgbe ochie.
\q1 A ga-akpọ unu ndị na-edozi mgbidi dara ada,
\q2 ndị na-arụzikwa okporoụzọ nke ebe obibi.
\b
\q1 
\v 13 “Ọ bụrụ na i debe ụkwụ gị site na-edebeghị ụbọchị izuike nsọ,
\q2 sitekwa na-ime ihe ndị na-atọ gị ụtọ nʼụbọchị nsọ m,
\q1 ọ bụrụ na ịkpọ ụbọchị izuike m ihe mmasị
\q2 na ụbọchị nsọ \nd Onyenwe anyị\nd* ihe a na-akwanyere ugwu,
\q1 ọ bụrụ na ị sọpụrụ ya site na-emeghị ihe nʼụzọ nke gị,
\q2 na-emeghị ọchịchọ nke obi gị, maọbụ ikwugheri ọnụ,
\q1 
\v 14 mgbe ahụ, ị ga-achọta ọṅụ gị nʼime \nd Onyenwe anyị\nd*,
\q2 m ga-emekwa ka ịnọkwasị nʼebe dị elu niile nke ala ahụ,
\q2 meekwa ka irie oriri na ihe nketa nke nna gị Jekọb.”
\q1 Nʼihi na ọnụ \nd Onyenwe anyị\nd* ekwuola ya.
\c 59
\s1 Mmehie, ikwupụta mmehie, na mgbapụta
\q1 
\v 1 Nʼezie, aka Onyenwe anyị adịghị mkpụmkpụ nke na o nweghị ike ịzọpụta,
\q2 ntị ya adịghịkwa arọ nke na o nweghị ike ịnụ ihe.
\q1 
\v 2 Kama mmehie unu ekewapụla unu
\q2 site nʼebe Chineke unu nọ;
\q1 mmehie niile unu ezokwala ihu ya site nʼebe unu nọ,
\q2 nke mere na ọ chọkwaghị ige ntị ọzọ.
\q1 
\v 3 Nʼihi na aka unu jupụtara na ntụpọ ọbara,
\q2 mkpịsịaka unu bụkwa nke mmehie merụrụ.
\q1 Egbugbere ọnụ unu ekwuola okwu ụgha,
\q2 ire unu na-atamukwa ihe ọjọọ.
\q1 
\v 4 Ọ dịghị onye na-ekpe ikpe ziri ezi,
\q2 ọ dịkwaghị onye na-eji ikwesi ntụkwasị obi kpee ikpe.
\q1 Ha na-adabere nʼịrụ ụka nʼenweghị isi, ha na-ekwu okwu ụgha,
\q2 ha na-atụrụ ime okwu na ụka mụọkwa ajọ ihe.
\q1 
\v 5 Ha na-avụ akwa ajụala,
\q2 na-akpakwa akwụ udide.
\q1 Onye ọbụla riri akwa ha ga-anwụ,
\q2 mgbe ọbụla otu kụwara, ọ bụ agwọ ajụala na-esi nʼime ya apụta.
\q1 
\v 6 Akwụ udide ha abaghị uru iji mee uwe,
\q2 ha enweghị ike iji ihe ha mepụtara kpuchie onwe ha.
\q1 Ọrụ ha niile bụ ajọ ọrụ,
\q2 omume ihe ike jupụtara ha nʼaka.
\q1 
\v 7 Ụkwụ ha na-eme ngwangwa ịgbaba nʼime mmehie,
\q2 ha na-emekwa ngwa ịkwafu ọbara ndị o nweghị ihe ọjọọ ha mere.
\q1 Ha na-achụso echiche ajọ ihe,
\q2 ọrụ mbibi na ntipịa bụ ejiri mara nke ụzọ ha niile.
\q1 
\v 8 Ha amaghị ihe ụzọ udo bụ,
\q2 ikpe ziri ezi adịghị nʼụzọ ha na-eso.
\q1 Ha e mela ụzọ ha ka ha gbagọọ agbagọ.
\q2 Ndị niile na-eso ya anaghị enweta udo.
\b
\q1 
\v 9 Ya mere ikpe ziri ezi dị anya nʼebe anyị nọ,
\q2 ezi omume adịghị erute anyị nso.
\q1 Anyị na-ele anya ìhè, ma lee, ọchịchịrị ka anyị na-ahụ.
\q2 Anyị na-ele anya mmụke ìhè ma anyị na-ejegharị nʼime oke ọchịchịrị.
\q1 
\v 10 Anyị na-asọgharị ìsì na mgbidi dịka ndị na-enweghị anya,
\q2 na-asọgharị isi dịka ndị na-enweghị anya;
\q1 anyị na-ada na-akpọbi ukwu nʼetiti ehihie dịka a ga-asị na ọ bụ oge chi ojiji,
\q2 nʼetiti ndị nwere ezi ndụ, anyị nọ ka ndị nwụrụ anwụ.
\q1 
\v 11 Anyị na-agbọ ụja dịka bịa;
\q2 anyị na-akwasị akwa ike dịka nduru nʼeru ụjụ.
\q1 Anyị na-ele anya ikpe ziri ezi, ma ọ dịghị eru anyị aka;
\q2 anyị na-ele anya nzọpụta, ma ọ dị anya nʼebe anyị nọ.
\b
\q1 
\v 12 Nʼihi na mmehie anyị amụbaala nʼihu Onyenwe anyị;
\q2 ọ na-agbakwa ama megide anyị.
\q1 E, anyị makwaara ụdị ndị mmehie anyị bụ,
\q2 nʼihi na mmehie anyị dịkwa nʼihu anyị mgbe niile.
\q1 
\v 13 Anyị maara nnupu isi anyị na ngọnarị anyị gọnarịrị \nd Onyenwe anyị\nd*;
\q2 anyị esitela nʼiso \nd Onyenwe anyị\nd* Chineke anyị wezuga onwe anyị,
\q1 nọgide na-akpali mmegbu na nnupu isi.
\q2 Okwu ọnụ anyị bụ okwu ụgha, nke anyị si nʼobi anyị tụpụta.
\q1 
\v 14 Ụlọ ikpe anyị niile adịghị achọ onye ezi omume;
\q2 anyị amaghị ihe a na-akpọ ikpe ziri ezi.
\q1 Eziokwu asọọla ngọngọ nʼama niile,
\q2 ihe ziri ezi apụghị ịbata.
\q1 
\v 15 E, eziokwu alaala;
\q2 onye ọbụla kwa nke na-achọ ibi ndụ ọma na-etinye onwe ya na nsogbu.
\b
\q1 \nd Onyenwe anyị\nd* lere anya hụ ihe ọjọọ ndị a niile, nke na-enyeghị ya obi ụtọ;
\q2 ọ hụkwara na ikpe ziri ezi adịghị.
\q1 
\v 16 Ọ hụrụ na anyị enweghị onye inyeaka ọbụla;
\q2 o wutere ya na ọ dịghị onye na-arịọrọ anyị arịrịọ.
\q1 Ọ bụ ya mere o ji bata site nʼike aka ya na nʼezi omume ya,
\q2 bịa ịzọpụta anyị.
\q1 
\v 17 Ọ na-eyikwasị ezi omume dịka ngwa agha ikpuchi obi ya.
\q2 Okpu nke nzọpụta ka ọ na-eyikwasịkwa nʼisi ya.
\q1 Ọ bụkwa uwe ịbọ ọbọ na nke ekworo
\q2 na ịnụ ọkụ na obi ka o ji kpuchie onwe ya.
\q1 
\v 18 Ọ ga-akwụghachi ndị iro ya
\q2 dịka ajọ omume ha niile si dị.
\q1 Iwe ọkụ ya
\q2 ka ọ ga-eji megide ndị iro ya niile
\q2 bi na mba dị anya.
\q1 
\v 19 Site nʼọdịda anyanwụ, ndị mmadụ ga-asọpụrụ aha \nd Onyenwe anyị\nd*,
\q2 sitekwa nʼọwụwa anyanwụ, ha ga-atụ egwu ebube ya.
\q1 Nʼihi na ọ ga-abịa dịka idee mmiri
\q2 nke nkume, \nd Onyenwe anyị\nd* na-agba na-aga.\f + \fr 59:19 \ft Maọbụ, \fqa mgbe onye iro ga-abata dịka idee mmiri, mmụọ nke \nd Onyenwe anyị\nd* ga-ebuli ọkọlọtọ imegide ya.\f*
\b
\q1 
\v 20 “Onye mgbapụta ga-abịa na Zayọn;
\q2 ọ ga-abịakwute ụmụ Jekọb ndị na-esite na mmehie ha chegharịa.”
\q2 Otu a ka \nd Onyenwe anyị\nd* kwubiri.
\p 
\v 21 “Ma mụ onwe m, nke a bụ ọgbụgba ndụ m nke dị nʼetiti mụ na ha,” ka \nd Onyenwe anyị\nd* na-ekwu. “Mmụọ m, nke dị nʼahụ gị, na okwu m niile nke m tinyere nʼọnụ gị, agaghị apụ nʼegbugbere ọnụ gị, maọbụ nʼegbugbere ọnụ ụmụ gị, maọbụ nʼegbugbere ọnụ agbụrụ gị. Ha ga-adịgide site ugbu a ruo mgbe niile ebighị ebi,” ka \nd Onyenwe anyị\nd* kwuru.
\c 60
\s1 Ebube nke Zayọn
\q1 
\v 1 “Bilie, mụkee, nʼihi na ìhè gị abịala,
\q2 ebube \nd Onyenwe anyị\nd* awaakwala nʼahụ gị dịka anyanwụ.
\q1 
\v 2 Lee, ọchịchịrị na-ekpuchi ụwa niile,
\q2 oke ọchịchịrị na-ekpuchi ndị niile bi nʼụwa,
\q1 ma \nd Onyenwe anyị\nd* ga-awa dịka anyanwụ nʼahụ gị
\q2 ebube ya ga-achakwa ka ihe nʼebe i nọ.
\q1 
\v 3 Mba niile dị iche iche ga-abịakwute ìhè gị,
\q2 ndị eze niile ga-abịaru mmụke nke ọwụwa gị.
\b
\q1 
\v 4 “Welienụ anya unu abụọ elu legharịa gburugburu unu,
\q2 ha niile na-ezukọta na-abịakwute gị;
\q1 ụmụ gị ndị ikom na-esi nʼebe dị anya bịa,
\q2 ụmụ gị ndị inyom ka a ga-ekukwa nʼụkwụ.
\q1 
\v 5 Mgbe ahụ, ị ga-elepụ anya ma chakee,
\q2 obi gị ga-atọ gị ụtọ, saa mbara nʼihi ọṅụ,
\q1 nʼihi na akụ niile nke osimiri ka a ga-ewebatara gị,
\q2 akụnụba nke ọtụtụ mba ga-abịara gị.
\q1 
\v 6 Ọtụtụ igwe ịnyịnya kamel nke si Midia
\q2 na Efaa ga-ejupụta nʼala gị,\f + \fr 60:6 \ft Ndị ebo Midia, bụ ndị sitere nʼakụkụ ndịda ọdịda anyanwụ osimiri Jọdan. Ha na-achị anụ ụlọ na-agagharị nʼihi izu ha. Efaa bụ nwa nwoke Midian \xt Jen 25:4.\xt*\f*
\q1 ma ndị sikwa nʼobodo Sheba
\q2 ga-ebutere gị ọlaedo na ụda na-esi isi ụtọ.
\q2 Ha ga-ekwusakwa otuto Onyenwe anyị.
\q1 
\v 7 A ga-enye gị igwe ewu na atụrụ niile nke ndị Keda.
\q2 Ebule niile nke Nebaiot ga-abụ nke gị.
\q1 A ga-anabata ha dịka onyinye nʼelu ebe ịchụ aja m.
\q2 Aga m edozi ụlọnsọ m dị ebube, mee ya ka ọ maa mma karịa.
\b
\q1 
\v 8 “Olee ndị bụ ndị a na-efegharị dịka igwe ojii,
\q2 ndị na-efegharị dịka ụmụ nduru na-efeba nʼakwụ ha?
\q1 
\v 9 Nʼezie, mụ ka ala ndị ahụ mmiri gbara gburugburu na-echere;
\q2 ụgbọ niile nke Tashish ga-ebukwa ụzọ,
\q1 na-ebughachi ụmụ gị site nʼebe dị anya,
\q2 ha na ọlaọcha na ọlaedo ha niile.
\q1 Inye \nd Onyenwe anyị\nd* bụ Chineke gị nsọpụrụ,
\q2 Onye nsọ nke Izrel,
\q2 nʼihi na ọ jirila ịma mma gọzie gị.
\b
\b
\q1 
\v 10 “Ndị mba ọzọ ga-abịa wuziere unu mgbidi unu niile.
\q2 Ndị na-achị achị na ndị eze ha niile ga-ejere unu ozi.
\q1 Ọ bụ ezie na m tikpọrọ gị nʼiwe m,
\q2 ma site nʼamara m, aga m emere gị ebere.
\q1 
\v 11 Ọnụ ụzọ ama gị ga-eghe oghe oge niile
\q2 site nʼụtụtụ ruo nʼụtụtụ,
\q1 ịnabata akụ niile si na mba dị iche iche.
\q2 A ga-edurukwa ndị eze dị iche iche bata nʼime ya nʼọnọdụ ndị a dọtara nʼagha.
\q1 
\v 12 Mba ọbụla jụrụ ijere gị ozi ga-ala nʼiyi;
\q2 a ga-ekpochapụ ha.
\b
\q1 
\v 13 “Otuto niile na ịma mma niile nke Lebanọn ga-abụ nke gị.
\q2 Osisi junipa, na osisi fịa, na osisi junipa, na osisi saipres,
\q1 ka a ga-eji chọọ ụlọnsọ m mma.
\q2 Aga m emekwa ka ebube jupụta nʼebe ahụ ụkwụ m na-adị mgbe niile.
\q1 
\v 14 Ụmụ ndị na-emegbu gị ga-abịa kpọọ isiala nye gị.
\q2 Ndị ahụ niile na-elelị gị ga-abịa daa nʼala nʼihu gị sutu ụkwụ gị ọnụ.
\q1 Ha ga-akpọ Jerusalem, Obodo \nd Onyenwe anyị\nd*,
\q2 Zayọn nke Onye nsọ Izrel.
\b
\q1 
\v 15 “Ọ bụ ezie na ọ dị mgbe ị bụ onye a kpọrọ asị, onye a na-emegbu,
\q2 onye mmadụ niile na-eweda nʼala,
\q1 ma ugbu a, ị ga-ama mma ruo ebighị ebi;
\q2 ị ga-abụ ihe na-ewetara ọgbọ niile nke ụwa ọṅụ, nʼihi na otu a ka m ga-eme gị.
\q1 
\v 16 Ị ga-aṅụ mmiri ara nke mba dị iche iche,
\q2 ọ bụkwa ara ndị eze ka a ga-eji zuo gị.\f + \fr 60:16 \ft Ọ bụkwa ara ndị eze ka ị ga-amị\f*
\q1 Mgbe ahụ, ị ga-amata nʼezie na mụ onwe m, bụ \nd Onyenwe anyị\nd* bụ Onye nzọpụta gị
\q2 na Onye mgbapụta gị, Onye dị ike nke Jekọb.
\q1 
\v 17 Nʼọnọdụ bronz, aga m eweta ọlaedo,
\q2 nʼọnọdụ igwe aga m eweta ọlaọcha.
\q1 Nʼọnọdụ osisi, ọ ga-abụ ọla,
\q2 nʼọnọdụ nkume, ọ ga-abụ igwe.
\q1 M ga-eme ka udo bụrụ ndị nlekọta gị
\q2 ezi omume ga-abụ onye na-achị gị.
\q1 
\v 18 Ihe ike agaghị adịkwa nʼala gị ọzọ.
\q2 Agha niile ga-akwụsị, mbibi na ịla nʼiyi agaghị adịkwa.
\q1 Mgbidi gị ga-aghọ Nzọpụta,
\q2 ị ga-akpọkwa ọnụ ụzọ ama gị niile Otuto.
\q1 
\v 19 Anyanwụ agaghị abụkwara gị ìhè nʼehihie ọzọ,
\q2 maọbụ maramara nke ọnwa amụkwasị gị ihe,
\q1 nʼihi na \nd Onyenwe anyị\nd* Chineke gị ga-abụrụ gị ìhè ruo ebighị ebi,
\q2 Chineke gị ga-abụkwa ebube gị.
\q1 
\v 20 Anwụ gị agaghị ada ada,
\q2 ọnwa gị agaghị akwụsịkwa ịcha;
\q1 nʼihi na \nd Onyenwe anyị\nd* ga-abụrụ gị ìhè ụbọchị gị niile,
\q2 iru ụjụ gị niile ga-agabigakwa.
\q1 
\v 21 Mgbe ahụ, ndị gị niile ga-abụ ndị ezi omume,
\q2 ha ga-enwetakwa ala ahụ ruo ebighị ebi.
\q1 Ha bụ ome nke m kụrụ,
\q2 bụ ọrụ aka m,
\q2 ime ka ịma mma m pụta ìhè.
\q1 
\v 22 Ezinaụlọ dị nta ga-aba ụba ghọọ obodo,
\q2 mba nta ga-aghọ obodo buru ibu.
\q1 Mụ onwe m bụ \nd Onyenwe anyị\nd*,
\q2 ga-eme ka ha niile mezuo ọsịịsọ nʼoge ya.”
\c 61
\s1 Afọ ngosi ihuọma Onyenwe anyị
\q1 
\v 1 Mmụọ nke Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* dị nʼahụ m,
\q2 nʼihi na \nd Onyenwe anyị\nd* eteela m mmanụ
\q2 ka m kwusaa oziọma nye ndị ogbenye.
\q1 O zitela m ịkasị ndị obi ha tiwara etiwa obi,
\q2 ikwupụta inwere onwe nye ndị a dọtara nʼagha,
\q2 na ntọghapụ site nʼọchịchịrị nye ndị mkpọrọ.\f + \fr 61:1 \ft Imeghe anya ndị kpuru ìsì\f*
\q1 
\v 2 O zitere m ikwupụta afọ mgbe Onyenwe anyị ga-eji ihuọma leta ndị mmadụ,
\q2 na ụbọchị ịbọ ọbọ nke Chineke anyị.
\q1 O zitekwara m ịkasị ndị niile na-eru ụjụ obi,
\q2 
\v 3 na igboro ndị niile na-eru ụjụ na Zayọn ihe na-akpa ha.
\q1 O zitere m inye ha okpueze mara mma
\q2 nʼọnọdụ ntụ,
\q1 inye ha ọṅụ,
\q2 nʼọnọdụ ịkwa akwa,
\q1 na iyikwasị ha mmụọ otuto
\q2 nʼọnọdụ mmụọ ịda mba.
\q1 Nʼihi na Chineke akụọla ezi omume nʼime ha,
\q2 dịka osisi ook siri ike,
\q2 igosi ịma mma \nd Onyenwe anyị\nd*.
\b
\q1 
\v 4 Ha ga-ewugharịkwa ebe niile e tikpọrọ etikpọ nʼoge ochie,
\q2 doziekwa ebe niile tọgbọrọ nʼefu site nʼoge dị anya;
\q1 ha ga-eme ka obodo e tikpọrọ etikpọ dị ọhụrụ,
\q2 bụ ebe tọgbọrọrị nʼefu nke ọtụtụ ọgbọ gara aga.
\q1 
\v 5 Ndị ọbịa ga-azụrụ gị igwe ewu na atụrụ unu;
\q2 ndị mba ọzọ ga-akọrọ unu ala ubi unu, lekọtakwa ubi vaịnị unu niile.
\q1 
\v 6 A ga-akpọ unu ndị nchụaja \nd Onyenwe anyị\nd*,
\q2 kpọkwa unu ndị ozi Chineke anyị.
\q1 A ga-eji akụ niile si na mba dị iche iche zụọ unu.
\q2 Ọ bụkwa akụnụba ha ka unu ga-eji nyaa isi.
\b
\q1 
\v 7 Nʼọnọdụ ihere dịịrị ha ugbu a,
\q2 ndị m ga-enweta ngọzị okpukpu abụọ,
\q1 nʼọnọdụ nkọcha dịịrị ha
\q2 ha ga-aṅụrị ọṅụ nʼihi ihe nketa ha nwetara.
\q1 Ha ga-enweta okpukpu ihe nketa ala abụọ,
\q2 ketakwa ọṅụ nke ga-adịgidere ha ruo mgbe ebighị ebi.
\b
\q1 
\v 8 “Nʼihi na mụ onwe m, \nd Onyenwe anyị\nd*, na-ahụ ikpe ziri ezi nʼanya.
\q2 Ma ana m akpọ izu ohi na ajọ omume niile asị.
\q1 Aga m esite nʼikwesị ntụkwasị obi m kwụghachi ndị m nʼihi ahụhụ ha tara,
\q2 mụ na ha ga-agbakwa ndụ ebighị ebi.
\q1 
\v 9 Mkpụrụ ha ga-abụ ndị a ma ama,
\q2 a ga-asọpụkwara ha nʼetiti mba niile.
\q1 Ndị niile hụrụ ha ga-amata,
\q2 kwupụtakwa na ha bụ ndị \nd Onyenwe anyị\nd* gọziri.”
\b
\q1 
\v 10 Obi na-atọ m ụtọ nke ukwuu nʼime \nd Onyenwe anyị\nd*,
\q2 mkpụrụobi m ga-etegharịkwa egwu ọṅụ nʼime Chineke m.
\q1 Nʼihi na o werela uwe nzọpụta kpuchie m,
\q2 werekwa uwe oke ọṅụ nke ezi omume ya yikwasị m nʼahụ.
\q1 Adị m ka nwoke na-alụ nwanyị ọhụrụ, onye na-emezi isi ya ka ọ dịrị ka nke onye nchụaja.
\q2 E, adị m ka nwaagbọghọ na-alụ di, nke ji ọla ọma dị iche iche chọọ onwe ya mma.
\q1 
\v 11 Dịka aja dị nʼubi si eme ka ihe a kụrụ nʼubi pupụta,
\q2 dịka ubi a gbara ogige si eme ka mkpụrụ ubi too,
\q1 otu a ka Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* ga-esi mee ka ezi omume na otuto
\q2 pupụta nʼihu mba niile.
\c 62
\s1 Aha ọhụrụ nke Zayọn
\q1 
\v 1 Nʼihi Zayọn agaghị m emechi ọnụ,
\q2 nʼihi Jerusalem agaghị m anọ jii,
\q1 ruo mgbe ezi omume ya ga-enwuwa dịka ihe ụtụtụ;
\q2 mgbe nzọpụta ya kwa ga-enwukwa dịka ọwaọkụ na-enwu enwu.
\q1 
\v 2 Mba niile ga-ahụ ezi omume gị.
\q2 Ndị eze niile ga-ahụkwa ebube gị.
\q1 A ga-akpọkwa gị aha ọhụrụ ahụ
\q2 nke ọnụ \nd Onyenwe anyị\nd* ga-agụ gị.
\q1 
\v 3 Ị ga-aghọ okpueze nke ịma mma nʼaka \nd Onyenwe anyị\nd*,
\q2 ihe iyi nʼisi nke ndị ụlọeze nʼaka Chineke gị.
\q1 
\v 4 A gakwaghị akpọ gị onye ahapụrụ ahapụ,
\q2 maọbụ kpọọ ala gị ala tọgbọrọ nʼefu.
\q1 Ma a ga-akpọ gị Hefziba,
\q2 kpọkwa ala gị Beula,
\q1 nʼihi na ihe gị ga-atọ \nd Onyenwe anyị\nd* ụtọ,
\q2 a ga-alụkwa ala gị dịka nwunye.
\q1 
\v 5 Dịka nwokorobịa si alụrụ nwaagbọghọ na-amaghị nwoke,
\q2 otu a ka Onye na-ewu gị\f + \fr 62:5 \ft Ụmụ gị ndị ikom\f* ga-alụ gị,
\q1 dịka onye lụrụ nwunye ọhụrụ sị aṅụrị ọṅụ nʼebe nwunye ọhụrụ ya nọ,
\q2 otu a ka Chineke gị ga-aṅụrị ọṅụ nʼihi gị.
\b
\q1 
\v 6 Enyela m ndị nche ọnọdụ ọrụ nʼelu mgbidi gị niile, Jerusalem.
\q2 Ha agaghị edebe ọnụ ha duu mgbe ọbụla, ma ehihie ma abalị.
\q1 Unu ndị na-akpọku \nd Onyenwe anyị\nd*,
\q2 unu enyela onwe unu izuike.
\q1 
\v 7 Unu enyekwala ya izuike tutu ruo mgbe ọ ga-eme ka Jerusalem guzosie ike,
\q2 meekwa ya otuto nke ụwa niile.
\b
\q1 
\v 8 \nd Onyenwe anyị\nd* ewerela aka nri ya
\q2 werekwa ogwe aka ya ṅụọ iyi sị,
\q1 “Ọ dịghịkwa mgbe m ga-enye mkpụrụ ubi gị
\q2 ka ọ bụrụ nri nye ndị iro gị ọzọ,
\q1 ọ dịghịkwa mgbe ndị ọbịa ga-aṅụkwa mmanya ọhụrụ ahụ
\q2 bụ nke ị dọgburu onwe gị nʼọrụ nʼihi ya.
\q1 
\v 9 Ma ndị were ya ka ihe ubi ga-eri ya,
\q2 tookwa \nd Onyenwe anyị\nd*,
\q1 ndị kpokọtara oroma grepu ga-aṅụ ya
\q2 nʼime ogige ebe nsọ m.”
\b
\q1 
\v 10 Gabiganụ! Gabiganụ sitenụ nʼọnụ ụzọ ama niile.
\q2 Dozienụ ụzọ maka ndị m.
\q1 Wuzienụ ụzọ niile, wuzienụ okporoụzọ niile.
\q2 Bupụsịanụ nkume niile,
\q1 weliekwanụ ọkọlọtọ maka mba niile.
\b
\q1 
\v 11 \nd Onyenwe anyị\nd* ekwusaala okwu
\q2 nye nsọtụ niile nke ụwa sị,
\q1 “Gwanụ Ada Zayọn,
\q2 ‘Lee Onye Nzọpụta gị na-abịa!
\q1 Lee, ụgwọ ọrụ ya dị ya nʼaka,
\q2 nkwụghachi nke ọ ga-akwụghachi sokwa ya na-abịa.’ ”
\q1 
\v 12 A ga-akpọ ha Ndị Nsọ,
\q2 ndị \nd Onyenwe anyị\nd* gbapụtara;
\q1 a ga-akpọkwa unu ndị a na-achọsi ike,
\q2 Obodo a na-agbakụtaghị azụ.
\c 63
\s1 Ụbọchị ịbọ ọbọ na mgbapụta nke Chineke
\q1 
\v 1 Onye bụ onye a si nʼEdọm na-abịa,
\q2 onye si Bozra, nke uwe ya dị ọbara ọbara?
\q1 Onye bụ onye a, yi uwe mara oke mma,
\q2 onye na-azọ ije dịka ịba ụba nke ike ya si dị?
\b
\q1 “Ọ bu mụ onwe m, onye na-ekwu okwu nʼezi omume,\f + \fr 63:1 \ft Maọbụ, \fqa mmeri\f*
\q2 onye dị ike ịzọpụta!”
\b
\q1 
\v 2 Gịnị mere uwe gị ji na-acha ọbara ọbara,
\q2 dịka uwe onye na-azọcha mkpụrụ vaịnị?
\b
\q1 
\v 3 “Azọchaala m ebe ịzọcha mkpụrụ vaịnị, naanị m zọchara ya;
\q2 o nweghị onye sị na mba niile dị iche iche bịa nyere m aka.
\q1 Azọchara m ha nʼiwe m,
\q2 zọpịasịakwa ha nʼime oke ọnụma m;
\q1 ọbara ha gbasasịrị nʼuwe m,
\q2 ma metọsịa uwe m niile.
\q1 
\v 4 Nʼihi na ọ bụ ụbọchị m ji abọ ọbọ;
\q2 afọ mgbapụta m kwadoro eruola.
\q1 
\v 5 Elere m anya ma o nweghị onye bịara inyere m aka.
\q2 O juru m anya, jukwa m ọnụ, na o nweghị onye pụtara inyere m aka.
\q1 Nʼihi ya, aka m wetara m mmeri.
\q2 Ọ bụkwa ọnụma juru m obi gbara m ume imezu ya.
\q1 
\v 6 Nʼiwe m, azọpịara mba niile dị iche iche;
\q2 esitere m nʼọnụma juru m obi zọpịasịa ha.
\q2 Emekwara ka ọbara ndụ ha bụrụ ihe a wụsiri nʼala.”
\s1 Ekpere na otuto
\q1 
\v 7 Aga m ekwupụta ihe banyere ịhụnanya Onyenwe anyị.
\q2 Aga m eto ya nʼihi ihe niile o mere.
\q2 Aga m aṅụrị ọṅụ nʼihi ịdị mma ya nʼebe Izrel nọ,
\q1 e, nʼihi ọtụtụ ihe ọma o mere
\q2 nʼihi mmeso ọma niile o mesoro ụlọ Izrel,
\q2 nke ọ na-emeso ha dịka obi ebere ya na ọmịiko ya si dị.
\q1 
\v 8 Nʼihi na Onyenwe anyị sịrị, “Ndị a bụ nke m;
\q2 e, ha agakwaghị agọnarị m ọzọ.”
\q2 Ya mere, ọ ghọọrọ ha Onye nzọpụta.
\q1 
\v 9 Nʼime mkpagbu ha niile, a kpagbukwara ya onwe ya,
\q2 ọ bụkwa mmụọ ozi nke ihu ya zọpụtara ha.
\q1 Nʼime ịhụnanya ya na obi ebere ya, ọ gbapụtara ha,
\q2 bulie ha elu, kuru ha
\q2 ogologo ụbọchị ndị a niile ndị gara aga.
\q1 
\v 10 Ma ha nupuru isi megide ya,
\q2 meekwa ka obi jọọ Mmụọ Nsọ ya njọ.
\q1 Ọ bụ ya mere o ji ghọọ onye iro ha,
\q2 lụsokwa ha ọgụ nʼonwe ya.
\b
\q1 
\v 11 Mgbe ahụ, ndị ya chetara ụbọchị ndị ahụ gara aga,
\q2 ụbọchị Mosis na ndị nke ya.
\q1 Olee ebe onye ahụ nọ nke mere ka ha si nʼoke osimiri rigopụta,
\q2 ya na onye ọzụzụ atụrụ nke igwe atụrụ ya?
\q1 Olee ebe onye ahụ tinyere
\q2 Mmụọ Nsọ ya nʼetiti ha nọ.
\q1 
\v 12 Olee onye ahụ ike ya
\q2 mere ka osimiri kewaa abụọ nʼihu ha,
\q1 mgbe Mosis weliri aka ya elu,
\q2 meekwa ka aha ya dịgide ruo ebighị ebi?
\q1 
\v 13 Onye duuru ha gafee mmiri dị oke omimi?
\q1 Dịka ịnyịnya na-agba ọsọ nʼọzara,
\q2 ike agwụghị ha.
\q1 
\v 14 Dịka ehi na-ata ahịhịa na ndagwurugwu,
\q2 Mmụọ \nd Onyenwe anyị\nd* nyere ha izuike.
\q1 Otu a ka i si duo ndị gị,
\q2 ime ka aha gị bụrụ ihe a na-asọpụrụ asọpụrụ.
\b
\q1 
\v 15 Onyenwe anyị, biko site nʼeluigwe,
\q2 ebe obibi nsọ gị, lee anyị anya.
\q1 Olee ebe nʼịnụ ọkụ nʼobi na ike gị dị?
\q2 Olee ebe obi ebere gị na ọmịiko gị dịkwa?
\q1 
\v 16 Ma gị onwe gị, bụ Nna anyị,
\q2 a sịkwarị na Ebraham amaghị anyị
\q2 maọbụ Izrel agọnarị anyị,
\q1 gị onwe gị, \nd Onyenwe anyị\nd*, bụ Nna anyị,
\q2 onye Mgbapụta anyị ka ị na-azakwa siterị na mgbe ochie.
\q1 
\v 17 \nd Onyenwe anyị\nd*, gịnị mere i ji na-eme ka anyị si nʼụzọ gị kpafuo
\q2 na-eme ka obi anyị sie ike otu a, na anyị adịghị atụ egwu gị?
\q1 Lọghachi nʼihi ndị ohu gị,
\q2 nʼihi ebo ndị ahụ bụ ihe nketa gị.
\q1 
\v 18 Ọ bụ naanị nwa oge nta ka ndị gị nwetara ebe nsọ gị,
\q2 ma ugbu a, ndị iro anyị azọdala ebe nsọ gị.
\q1 
\v 19 Anyị bụ nke gị site na mgbe ochie,
\q2 ma ị naghị achị nʼebe ha nọ,
\q2 ha bụ ndị a na-akpọkwasịghịkwa aha gị.
\b
\b
\c 64
\q1 
\v 1 Ọ gaara adị mma ma asị na ị ga-adọwa eluigwe rịdata nʼala,
\q2 ma asị nʼugwu ukwu niile ga-ama jijiji nʼihu gị!
\q1 
\v 2 Dịka mgbe ọkụ na-agba ụmụ osisi,
\q2 na-eme ka mmiri e sikwasịrị nʼọkụ gbọọ.
\q1 Si nʼelu rịdata bịa mee ka ndị iro\f + \fr 64:2 \ft Ya bụ, ndị na-emegide gị\f* gị niile maara aha gị,
\q2 meekwa ka mba niile dị iche iche maa jijiji nʼihu gị.
\q1 
\v 3 Nʼihi na ọ bụ mgbe i mere ọtụtụ ihe egwu dị iche iche nke anyị na-atụghị anya ya
\q2 ka ị rịdatara mee ka ugwu ukwu niile maa jijiji nʼihu gị.
\q1 
\v 4 Nʼihi na site na mgbe ochie, ọ dịbeghị onye nụrụ,
\q2 ọ dịbeghị ntị ghọtara,
\q1 o nwebeghị anya hụrụ Chineke ọzọ karịa gị,
\q2 onye na-emejupụtara ndị na-echere ya ihe na-akpa ha.
\q1 
\v 5 Ị na-enyere ndị na-eme ezi ihe aka,
\q2 bụ ndị ji ọṅụ na-echeta ụzọ gị nʼechiche uche ha.
\q1 Ma mgbe anyị nọgidere na-emehie megide ha,
\q2 iwe were gị.
\q2 A ga-esikwanụ aṅaa zọpụta anyị?
\q1 
\v 6 Anyị niile dịka onye rụrụ arụ,
\q2 ezi omume anyị niile kwa dịka nkịrịnka akwa ruru unyi.
\q1 Anyị akpọnwụọla dịka akwụkwọ osisi,
\q2 mmehie anyị na-ebufukwa anyị dịka ifufe.
\q1 
\v 7 Ọ dịghị onye nʼime anyị na-arịọ gị arịrịọ;
\q2 ọ dịkwaghị onye na-akpọku aha gị.
\q1 Nʼihi ya, i zoola ihu gị site nʼebe anyị nọ,
\q2 meekwa ka anyị bụrụ ndị gbazere agbaze nʼihi mmehie anyị.
\b
\q1 
\v 8 Ma otu ọbụla o si dị, gị \nd Onyenwe anyị\nd* bụ Nna anyị.
\q2 Anyị bụ ụrọ, ma ị bụ ọkpụ ite.
\q2 Ọ bụ aka gị kpụrụ anyị niile.
\q1 
\v 9 Biko, \nd Onyenwe anyị\nd*, anọgidela na-eweso anyị iwe;
\q2 echetakwala mmehie anyị ọzọ ruo mgbe ebighị ebi.
\q1 Biko, lekwasị anyị anya
\q2 nʼihi na ndị gị ka anyị bụ.
\q1 
\v 10 Obodo nsọ gị niile aghọọla ọzara;
\q2 ọ bụladị Zayọn aghọọla ọzara, Jerusalem, ebe tọgbọrọ nʼefu.
\q1 
\v 11 Ụlọnsọ ukwu anyị ahụ mara mma, nke dịkwa nsọ, ebe nna anyị ha nọ too gị, ma feekwa gị ofufe,
\q2 abụrụla ihe a gbara ọkụ.
\q2 Ihe niile mara mma nʼime ya alaala nʼiyi.
\q1 
\v 12 Mgbe ihe niile gasịrị, \nd Onyenwe anyị\nd*, ị ga-ejisi onwe gị ike?
\q2 Ị ga-agba nkịtị, taa anyị ahụhụ ebe ọ gafere oke?
\c 65
\s1 Ikpe na nzọpụta
\q1 
\v 1 “Ana m egosipụta onwe m nye ndị ahụ na-adịghị ajụ ase m.
\q2 Ọ bụkwa ndị ahụ na-adịghị achọsi m ike na-achọta m.
\q1 Ana m agwa mba ahụ nke na-adịghị akpọku aha m,
\q2 asịrị m, ‘Lee m, anọ m nʼebe a.’
\q1 
\v 2 Ogologo ụbọchị niile ka m gbasapụrụ aka m abụọ
\q2 nye ndị na-enupu isi,
\q1 bụ ndị na-agbaso ụzọ na-ezighị ezi
\q2 ndị a na-agbaso ihe ọbụla ha tụpụtara nʼuche ha,
\q1 
\v 3 ndị na-anọgide na-akpasu m iwe
\q2 nʼihu m mgbe niile,
\q1 ndị na-achụ aja nʼubi ha a gbara ogige,
\q2 nʼebe ịchụ aja eji brik wuo,
\q1 
\v 4 ndị na-anọdụ nʼetiti ili,
\q2 ma na-anọdụkwa ọnọdụ abalị nʼebe nzuzo dị iche iche;
\q1 ndị na-eri anụ ezi,
\q2 ndị ite ofe ha jupụtara nʼanụ na-adịghị ọcha;
\q1 
\v 5 ndị na-asịrịta onwe ha, ‘Nọdụ iche, Abịala m nso,
\q2 nʼihi na ị ga-emerụ m, adị m nsọ karịa gị!’
\q1 Ma ndị dị otu a dịka anwụrụ ọkụ nʼimi m.
\q2 Ha bụ ọkụ na-enwu ehihie na nʼabalị.
\b
\q1 
\v 6 “Lee, edeela ya rịị nʼihu m sị:
\q2 Agaghị m agba nkịtị, aga m akwụghachi nʼuju.
\q2 E, aga m akwụghachi ha.
\q1 
\v 7 Ọ bụghị naanị maka mmehie ha, kama maka mmehie nna nna ha niile,”
\q2 Otu a ka \nd Onyenwe anyị\nd* kwuru,
\q1 “Nʼihi na ha surere aja nsure ọkụ nʼelu ugwu dị iche iche,
\q2 kparịakwa m nʼelu ugwu nta niile.
\q1 Aga m akwụghachi ha nʼuju,
\q2 nʼihi ihe ndị a niile ha mere nʼoge gara aga.”
\p 
\v 8 Otu a ka \nd Onyenwe anyị\nd* na-ekwu,
\q1 “Dịka a na-achọta mmanya site nʼụyọkọ mkpụrụ vaịnị
\q2 ndị mmadụ asị, ‘Ebibila ya,
\q2 nʼihi na ngọzị ka dị nʼime ha,’
\q1 otu a ka m ga-eme nʼihi ndị ohu m;
\q2 Agaghị m ebibicha ha niile.
\q1 
\v 9 Aga m eme ka mkpụrụ site na Jekọb pụta,
\q2 sitekwa na Juda nweta ndị ga-enweta ugwu m niile.
\q1 Ndị m họpụtara ga-eketa ha,
\q2 ndị ohu m ga-ebikwa nʼebe ahụ.
\q1 
\v 10 Sharọn ga-aghọkwa ebe ịta nri nke igwe anụ ụlọ;
\q2 Ndagwurugwu Akọ ga-abụkwa ebe izuike nye igwe ehi,
\q2 na ndị m na-achọsi m ike.
\b
\q1 
\v 11 “Ma unu ndị wezugara onwe unu site nʼebe \nd Onyenwe anyị\nd* nọ,
\q2 ndị chezọrọ ugwu nsọ m,
\q1 ndị na-edozi tebul maka Ihuọma,
\q2 ndị na-agbaju mmanya agwara ọgwa nʼiko maka Akara aka.\f + \fr 65:11 \ft Ndị na e doro Gad tebul nʼusoro, na-agbaju mmanya agwara ọgwa nye Meni\f*
\q1 
\v 12 Aga m eme ka unu zute mma agha;
\q2 unu niile ga-adakwa mgbe a na-egbu unu.
\q1 Nʼihi na akpọrọ m unu ma unu azaghị;
\q2 mgbe m gwara unu okwu, unu aṅaghị ntị.
\q1 Unu kpachapụrụ anya mehie megide m nʼihu,
\q2 họrọkwa ime ihe ndị ahụ unu maara nke ọma na m kpọrọ asị.”
\p 
\v 13 Ya mere, nke a bụ ihe Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* na-ekwu,
\q1 “Ndị ohu m ga-eriju afọ,
\q2 ma unu ga-anọ agụụ,
\q1 akpịrị ga-akpọkwa unu nkụ,
\q2 ma ha ga-aṅụ mmiri.
\q1 Unu ga-anọ nʼọnụma na ihere,
\q2 ma ha ga-anọ nʼọṅụ.
\q1 
\v 14 Ndị ohu m ga-abụ abụ
\q2 nʼihi ọṅụ nke jupụtara nʼobi ha,
\q1 ma unu ga-akwa akwa,
\q2 nʼihi ihe mgbu nke obi unu,
\q2 tiekwa mkpu akwa nʼihi obi ntiwa nke mmụọ unu.
\q1 
\v 15 Unu ga-ahapụ aha unu
\q2 nye ndị m họpụtara nye onwe m ka ọ bụrụ ihe ha ji abụ ọnụ;
\q1 nʼihi na Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* ga-etigbu unu,
\q2 ma ọ ga-akpọ ndị ohu ya aha ọzọ.
\q1 
\v 16 Onye ọbụla na-ekpe ekpere nʼala ahụ,
\q2 ga-eme otu a nʼaha Chineke nke eziokwu,
\q1 onye ọbụla na-aṅụkwa iyi nʼime ala ahụ
\q2 ga-aṅụ iyi nʼaha Chineke nke eziokwu.
\q1 Nʼihi na-echezolam nsogbu niile ndị gara aga,
\q2 zokwa ha site nʼanya m.
\s1 Ụwa ọhụrụ na eluigwe ọhụrụ
\q1 
\v 17 “Nʼihi na lee, ana m eke
\q2 eluigwe ọhụrụ na ụwa ọhụrụ.
\q1 Ọ dịghị onye ga-echetakwa ndị ochie ahụ ọzọ;
\q2 ọ gaghị abatakwa nʼechiche onye ọbụla.
\q1 
\v 18 Ma ṅụrịanụ ọṅụ, tegharịakwa mgbe niile nʼobi ụtọ
\q2 nʼihi ihe nke mụ onwe m na-eke,
\q1 nʼihi na-aga eke Jerusalem ka ọ bụrụ ihe ọṅụ
\q2 ndị ya ga-abụkwa ihe obi ụtọ.
\q1 
\v 19 Aga m aṅụrị ọṅụ nʼihi Jerusalem,
\q2 nweekwa obi ụtọ nʼihi ndị m;
\q1 a gaghị anụkwa olu ịkwa akwa nʼime ya ọzọ,
\q2 maọbụ olu iti mkpu akwa.
\b
\q1 
\v 20 “Ọ dịghịkwa nwa ọhụrụ nwụchuru anwụchu
\q2 ga-adị nʼebe ahụ ọzọ,\f + \fr 65:20 \ft Nwa nwụrụ mgbe ọ ka dị naanị abalị ole na ole\f*
\q2 a gaghị ahụkwa agadi nwoke nke na-anọzughị ụbọchị ndụ ya;
\q1 nʼihi na a ga-agụnye onye nwụrụ mgbe ọ gbara narị afọ tupu ọ nwụọ
\q2 dị ka nwantakịrị;
\q1 a ga-agụkwa onye na-anọrughị narị afọ
\q2 dịka onye a bụrụ ọnụ.
\q1 
\v 21 Ha ga-ewu ụlọ, biekwa nʼime ya;
\q2 ha ga-akụkwa ubi vaịnị, riekwa mkpụrụ ha.
\q1 
\v 22 Ndị m agaghị ewukwa ụlọ hapụrụ ya ndị ọzọ,
\q2 maọbụ ghaa mkpụrụ nʼubi nke ndị ọzọ ga-aghọrọ rie.
\q1 Nʼihi na dịka osisi si adị ndụ ogologo oge
\q2 otu a ka ndị m ga-esi dịkwa ndụ ogologo oge.
\q1 Ha ga-aṅụrịkwa ọṅụ
\q2 nʼihe ahụ ha ji aka ha rụpụta.
\q1 
\v 23 Ha agaghị adọgbu onwe ha nʼọrụ nʼefu.
\q2 Ha agaghị amụtakwa ụmụ ndị ga-emesịa nwụchuo ọnwụ.
\q1 Nʼihi na ha ga-abụ ndị \nd Onyenwe anyị\nd* gọziri,
\q2 ha na ụmụ ụmụ ha.
\q1 
\v 24 Tupu ha akpọkuo m, aga m aza ha.
\q2 Mgbe ha ka nọ na-agwa m banyere mkpa ha, aga m anụ, zakwa ekpere ha.
\q1 
\v 25 Nkịta ọhịa na nwa atụrụ ga-atakọ nri nʼotu ebe,
\q2 ọdụm ga-ata ahịhịa dịka ehi,
\q2 ma agwọ ọjọọ niile ga-ata aja!
\q1 Ha agaghị emerụ ihe ọbụla ahụ,
\q2 maọbụ bibie ihe ọbụla nʼugwu nsọ m.”
\q2 Ka Onyenwe anyị kwuru.
\c 66
\s1 Ikpe ikpe na olileanya
\p 
\v 1 Ihe ndị a ka Onyenwe anyị na-ekwu,
\q1 “Eluigwe bụ ocheeze m,
\q2 ụwa bụkwa ebe mgbakwasị ụkwụ m.
\q1 Ọ bụ ụdị ụlọ gịnị ka ị ga-ewuru m?
\q2 Ebee ka ebe izuike m ga-adị?”
\q1 
\v 2 Ọ bụghị aka m mere ihe ndị a niile,
\q2 mee ka ha ji dịrị?
\q2 Otu a ka \nd Onyenwe anyị\nd* kwupụtara.
\b
\q1 “Ma olee ndị ihe ha na-atọ m ụtọ,
\q2 ọ bụ ndị ahụ nwere obi umeala, ndị na-adịghị ebuli onwe ha elu,
\q2 ndị na-amakwa jijiji nʼokwu m.
\q1 
\v 3 Ma onye ọbụla nke na-achụ aja ehi
\q2 dịka nwoke na-egbu mmadụ,
\q1 onye ọbụla jikwa nwa atụrụ achụ aja
\q2 dị ka onye na-agbaji nkịta olu,
\q1 onye ọbụla na-achụ aja mkpụrụ ọka
\q2 dị ka onye na-eche ọbara ezi,
\q1 otu a kwa, onye ọbụla na-esure ụda na-esi isi ụtọ nke ncheta
\q2 dị ka onye na-efe arụsị.
\q1 Ha ahọpụtarala onwe ha ụzọ nke ha,
\q2 ha na-enwekwa mmasị nʼihe arụ ha niile.
\q1 
\v 4 Ya mere, aga m ezitere ha ahụhụ dị egwu,
\q2 mee ka ihe ahụ ha na-atụ egwu ya bịakwasị ha.
\q1 Nʼihi na mgbe m kpọrọ ha oku, ha azaghị,
\q2 mgbe m gwara ha okwu, ha egeghị ntị.
\q1 Kama ha mere ihe ọjọọ nʼihu m,
\q2 họrọkwa ime ihe ndị ahụ ha maara na m kpọrọ asị.”
\b
\q1 
\v 5 Nụrụnụ okwu \nd Onyenwe anyị\nd*,
\q2 unu ndị na-ama jijiji nʼokwu ya,
\q1 “Ụmụnna unu, ndị kpọrọ unu asị,
\q2 ndị chụpụkwara unu nʼihi aha m, ekwuola sị,
\q1 ‘Ka a sọpụrụ Onyenwe anyị!
\q2 Ka anyị lee ụdị ọṅụ ga-abụ nke unu!’
\q2 Ma a ga-etinye ha nʼọnọdụ ihere.
\q1 
\v 6 Ọ bụ gịnị bụ mkpọtụ dị nʼime obodo?
\q2 Gịnị bụ oke ụzụ na-ada nʼime ụlọnsọ ukwu Onyenwe anyị?
\q1 Ọ bụ ụzụ \nd Onyenwe anyị\nd* na-eme.
\q2 Onye ahụ na-akwụghachi ndị iro ya ụgwọ ruuru ha.
\b
\q1 
\v 7 “Tupu ime amalite ime ya,
\q2 ọ mụpụtalarị nwa ya.
\q1 Tupu ihe mgbu ya ebido,
\q2 ọ mụpụtala nwa nwoke.
\q1 
\v 8 Onye jiri ntị ya nụtụ ihe dị otu a mbụ?
\q2 Onye kwa ji anya ya hụ ihe dị otu a?
\q1 A pụrụ ịmụpụta otu mba nʼotu ụbọchị?
\q2 Ka e nwere ike ime ka otu obodo malite ịdị nʼotu ntabi anya?
\q1 Lee na tupu ihe mgbu nke ọmụmụ nwa ya ebido
\q2 Zayọn amụpụtala ụmụ ya.
\q1 
\v 9 Mụ onwe m, m ga-eme ka nwa rute nʼoge ọmụmụ
\q2 gharakwa ime ka a mụọ ya?”
\q2 ka \nd Onyenwe anyị\nd* na-ekwu.
\q1 “M ga-emechi akpanwa
\q2 mgbe m na-eme ka a mụpụta ya?”
\q2 ka Chineke gị jụrụ.
\q1 
\v 10 “Soronụ Jerusalem ṅụrịa ọṅụ, soronụ ya nwee obi ụtọ,
\q2 unu ndị niile hụrụ ya nʼanya;
\q1 soronụ ya ṅụrịa ọṅụ nke ukwuu,
\q2 unu ndị ruru ụjụ nʼihi ya.
\q1 
\v 11 Nʼihi na ihe banyere Jerusalem ga-atọ unu ụtọ.
\q2 Unu ga-aṅụjukwa ara nkasiobi ya afọ,
\q1 ọ bụladị dịka nwantakịrị si enwe obi ụtọ
\q2 mgbe ọ na-aṅụ ara nne ya nke na-agba nke ọma.”
\p 
\v 12 Nʼihi na ihe ndị a ka \nd Onyenwe anyị\nd* kwuru,
\q1 “Aga m eme ka udo bara ya ụba dịka osimiri,
\q2 mee ka akụnụba niile nke ndị mba ọzọ dịrị ka mmiri na-asọbiga oke.
\q1 Ọ ga-elekọta gị, kurukwa gị, makụọkwa gị nʼaka ya,
\q2 wugharịakwa gị nʼikpere ya.
\q1 
\v 13 Dịka nne si akasị nwa ya obi,
\q2 otu a ka m ga-esi kasịe unu obi.
\q2 Ọ bụ nʼime Jerusalem ka a ga-akasị unu obi.”
\b
\q1 
\v 14 Mgbe ị hụrụ ihe ndị a, obi gị ga-aṅụrị ọṅụ,
\q2 ịga awasa dịka ahịhịa ọhụrụ;
\q1 a ga-emekwa ka aka \nd Onyenwe anyị\nd* pụta ìhè nʼebe ndị ohu ya nọ,
\q2 ma a ga-egosi ndị iro ya oke iwe ya.
\q1 
\v 15 Nʼihi na lee, \nd Onyenwe anyị\nd* ga-eji ọkụ bịa.
\q2 Ụgbọala ya ga-adịkwa ka oke ifufe.
\q1 Ọ ga-eji ọnụma gosi iwe ya,
\q2 werekwa ọkụ na-enwu enwu baa mba.
\q1 
\v 16 Nʼihi na \nd Onyenwe anyị\nd* ga-eji ọkụ na mma agha ya
\q2 kpee ndị mmadụ niile ikpe.
\q2 Ọ ga-egbukwa ọtụtụ mmadụ.
\p 
\v 17 “Ndị ahụ niile na-edo onwe ha nsọ, ndị na-eme onwe ha ka ha dị ọcha nʼihi ịbanye nʼubi a gbara ogige, ndị ahụ na-eso onye ahụ nọ nʼetiti ndị ahụ na-eri anụ ezi, na oke, na ihe ndị ọzọ ahụ niile rụrụ arụ, ga-ezute ọnwụ nke nọ na-eche ha niile.” Otu a ka \nd Onyenwe anyị\nd* kwubiri ya.
\p 
\v 18 “Ma mụ onwe m, amaara m nke ọma ihe ha zubere ma meekwa, ana m abịa ịchịkọta mba niile na-asụ asụsụ dị iche iche. Ha niile ga-abịakwa hụ ebube m.
\p 
\v 19 “Aga m edokwa ihe ịrịbama nʼetiti ha, zipụkwa ndị fọdụrụ ndụ nʼetiti ha ka ha gaa nʼobodo Tashish, na Libiya,\f + \fr 66:19 \ft Ụfọdụ akwụkwọ mgbe ochie na-ede \fqa Put \ft ma ndị Hibru na-ede \fqa Pul\f* na Lidiya\f + \fr 66:19 \ft Maọbụ, \fqa ndị Lud\f* (ndị na-agba àkụ nʼụta nke ọma) na Tubal, na Griis. E, ha ga-eje na mba niile nke dị anya, nʼofe osimiri, ebe ndị bi nʼime ya na-anụbeghị ihe banyere ịdị ukwuu nke m, maọbụ hụ ebube m. Ha ga-ekwusakwa ihe banyere ebube m nʼetiti mba niile dị iche iche.
\v 20 Ha ga-akpọghachi ụmụnne unu niile site na mba niile, bịa nʼugwu nsọ m dị na Jerusalem, dịka onyinye a na-ewetara \nd Onyenwe anyị\nd*. Ha ga-ebute ha nʼelu ịnyịnya, nʼụgbọ agha, nʼelu ụgbọala a na-adọkpụ adọkpụ, nʼelu ịnyịnya muul na nʼelu ịnyịnya kamel,” ka \nd Onyenwe anyị\nd* na-ekwu. “Ha ga-ebubata ha dịka mgbe ndị Izrel na-ewebata onyinye mkpụrụ ha nʼụlọnsọ \nd Onyenwe anyị\nd* nʼefere mmemme dị ọcha.
\v 21 Aga m ahọrọkwa ụfọdụ ka ha bụrụ ndị nchụaja na ndị Livayị,” ka \nd Onyenwe anyị\nd* kwuru.
\p 
\v 22 “Dịka eluigwe ọhụrụ na ụwa ọhụrụ ahụ nke m ga-eke ga-esi dịgide nʼihu m, otu a ka aha unu na agbụrụ unu ga-adịgide, ka \nd Onyenwe anyị\nd* kwubiri.
\v 23 Ọ ga-abụkwa na site nʼotu Ọnwa ọhụrụ ruo nke ọzọ, sitekwa nʼotu ụbọchị izuike ruo na nke ọzọ ya, anụ ahụ niile bụ mmadụ ga-abịa, daa, kpọọ isiala nʼihu m,” ka \nd Onyenwe anyị\nd* kwuru.
\v 24 “Ha ga-apụ, jee, lekwasị ozu ndị ahụ niile nwụrụ anwụ anya, bụ ndị ahụ niile nupuru isi megide m. Nʼihi na ikpuru ha agaghị anwụ anwụ, ọkụ a kwanyere agakwaghị anyụ anyụ. Ha ga-abụkwara mmadụ niile ihe na-asọ oyi.”
