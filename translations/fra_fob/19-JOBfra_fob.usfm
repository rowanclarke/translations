\v 19 \w C|strong="H1931"\w*'\w est|strong="H1931"\w* \w le|strong="H6213"\w* chef-d'\w œuvre|strong="H6213"\w* \w de|strong="H6213"\w* \w Dieu|strong="H6213"\w*, \w son|strong="H6213"\w* \w créateur|strong="H6213"\w* \w lui|strong="H1931"\w* \w a|strong="H3068"\w* \w donné|strong="H1931"\w* \w son|strong="H6213"\w* \w épée|strong="H2719"\w*.  
\v 20 \w Les|strong="H5375"\w* \w montagnes|strong="H2022"\w* \w portent|strong="H5375"\w* \w pour|strong="H3588"\w* \w lui|strong="H3588"\w* \w leur|strong="H5375"\w* herbe; \w là|strong="H5375"\w* \w se|strong="H3588"\w* \w jouent|strong="H7832"\w* \w toutes|strong="H3588"\w* \w les|strong="H5375"\w* \w bêtes|strong="H2416"\w* \w des|strong="H2416"\w* \w champs|strong="H7704"\w*.  
\v 21 Il se \w couche|strong="H7901"\w* \w sous|strong="H8478"\w* \w les|strong="H8478"\w* \w lotus|strong="H6628"\w*, \w dans|strong="H7901"\w* l'ombre \w des|strong="H8478"\w* \w roseaux|strong="H7070"\w* \w et|strong="H7901"\w* \w dans|strong="H7901"\w* \w le|strong="H8478"\w* limon.  
\v 22 \w Les|strong="H5437"\w* \w lotus|strong="H6628"\w* \w le|strong="H5437"\w* \w couvrent|strong="H5526"\w* \w de|strong="H5158"\w* leur \w ombre|strong="H6752"\w*, \w et|strong="H5437"\w* \w les|strong="H5437"\w* \w saules|strong="H6155"\w* \w du|strong="H6155"\w* \w torrent|strong="H5158"\w* l'\w environnent|strong="H5437"\w*.  
\v 23 Vois, \w le|strong="H6310"\w* \w fleuve|strong="H5104"\w* déborde \w avec|strong="H3808"\w* \w violence|strong="H6231"\w*, \w il|strong="H3588"\w* n'\w a|strong="H3068"\w* \w point|strong="H3808"\w* peur; \w il|strong="H3588"\w* \w serait|strong="H3808"\w* tranquille \w quand|strong="H3808"\w* \w le|strong="H6310"\w* \w Jourdain|strong="H3383"\w* monterait \w à|strong="H3588"\w* \w sa|strong="H6310"\w* \w gueule|strong="H6310"\w*.  
\v 24 Qu'\w on|strong="H3947"\w* \w le|strong="H3947"\w* \w prenne|strong="H3947"\w* \w à|strong="H5869"\w* force \w ouverte|strong="H5869"\w*! \w Ou|strong="H5869"\w* qu'\w à|strong="H5869"\w* l'aide \w de|strong="H5869"\w* \w filets|strong="H4170"\w* \w on|strong="H3947"\w* \w lui|strong="H5869"\w* \w perce|strong="H5344"\w* \w le|strong="H3947"\w* nez!   
\c 41
\p
\v 1 \w Tu|strong="H1571"\w* tireras \w le|strong="H2904"\w* Léviathan \w avec|strong="H1571"\w* un hameçon? \w et|strong="H4758"\w* \w tu|strong="H1571"\w* serreras \w sa|strong="H2904"\w* langue \w avec|strong="H1571"\w* \w une|strong="H1571"\w* corde?  
\v 2 Mettras-tu \w un|strong="H6440"\w* jonc \w dans|strong="H6440"\w* \w ses|strong="H6440"\w* \w narines|strong="H6440"\w*, perceras-tu \w sa|strong="H6440"\w* joue \w avec|strong="H6440"\w* \w un|strong="H6440"\w* crochet?  
\v 3 T'adressera-t-il beaucoup \w de|strong="H3605"\w* prières, \w et|strong="H8064"\w* \w te|strong="H4310"\w* dira-t-il \w de|strong="H3605"\w* douces \w paroles|strong="H3605"\w*?  
\v 4 \w Fera-t-il|strong="H3808"\w* \w un|strong="H1697"\w* accord \w avec|strong="H1697"\w* \w toi|strong="H3808"\w*, \w et|strong="H3808"\w* \w le|strong="H2790"\w* prendras-tu \w pour|strong="H1697"\w* esclave \w à|strong="H1697"\w* toujours?  
\v 5 \w En|strong="H6440"\w* joueras-tu \w comme|strong="H3830"\w* \w d|strong="H6440"\w*'\w un|strong="H6440"\w* oiseau, \w et|strong="H6440"\w* \w l|strong="H6440"\w*'attacheras-tu \w pour|strong="H6440"\w* amuser \w tes|strong="H6440"\w* filles?  
\v 6 \w Les|strong="H6440"\w* associés \w en|strong="H6440"\w* feront-ils commerce, \w le|strong="H6440"\w* partageront-ils entre \w des|strong="H6440"\w* marchands?  
\v 7 Perceras-tu sa peau d'un dard, \w et|strong="H4043"\w* sa tête d'un harpon?  
\v 8 Mets \w ta|strong="H3808"\w* main sur \w lui|strong="H7307"\w*: \w tu|strong="H3808"\w* \w te|strong="H3808"\w* souviendras \w de|strong="H7307"\w* \w la|strong="H3808"\w* bataille, \w et|strong="H3808"\w* \w tu|strong="H3808"\w* n'y reviendras \w pas|strong="H3808"\w*.  
\v 9 Voici, tout espoir \w de|strong="H3808"\w* \w le|strong="H3808"\w* \w prendre|strong="H3920"\w* est trompé; \w à|strong="H3808"\w* \w son|strong="H3808"\w* seul aspect \w on|strong="H3808"\w* est jeté \w à|strong="H3808"\w* terre!  
\v 10 \w Il|strong="H5869"\w* n'y \w a|strong="H3068"\w* \w point|strong="H5869"\w* d'homme si hardi \w qui|strong="H5869"\w* l'ose réveiller; \w et|strong="H5869"\w* \w qui|strong="H5869"\w* \w se|strong="H5869"\w* tiendra debout \w devant|strong="H5869"\w* moi?  
\v 11 Qui m'\w a|strong="H3068"\w* \w fait|strong="H1980"\w* \w des|strong="H6310"\w* avances, \w et|strong="H6310"\w* \w je|strong="H6310"\w* \w lui|strong="H6310"\w* rendrai? \w Tout|strong="H1980"\w* ce qui \w est|strong="H6310"\w* sous \w les|strong="H1980"\w* cieux \w est|strong="H6310"\w* \w à|strong="H6310"\w* \w moi|strong="H6310"\w*.  
\v 12 \w Je|strong="H3068"\w* \w ne|strong="H3318"\w* me tairai pas \w sur|strong="H3318"\w* \w ses|strong="H3318"\w* membres, \w sur|strong="H3318"\w* \w ses|strong="H3318"\w* forces, \w et|strong="H3318"\w* \w sur|strong="H3318"\w* \w la|strong="H3318"\w* beauté \w de|strong="H3318"\w* \w sa|strong="H3318"\w* stature.  
\v 13 \w Qui|strong="H5315"\w* \w a|strong="H3068"\w* soulevé \w le|strong="H3318"\w* dessus \w de|strong="H3318"\w* \w son|strong="H3318"\w* vêtement? \w Qui|strong="H5315"\w* \w est|strong="H5315"\w* \w entré|strong="H3318"\w* \w dans|strong="H3318"\w* \w sa|strong="H6310"\w* double mâchoire?  
\v 14 \w Qui|strong="H6440"\w* \w a|strong="H3068"\w* ouvert \w les|strong="H6440"\w* \w portes|strong="H6440"\w* \w de|strong="H6440"\w* \w sa|strong="H6440"\w* \w gueule|strong="H6440"\w*? \w La|strong="H6440"\w* terreur \w est|strong="H6440"\w* autour \w de|strong="H6440"\w* \w ses|strong="H6440"\w* dents.  
\v 15 \w Ses|strong="H5921"\w* puissants boucliers \w sont|strong="H1077"\w* superbes; \w ils|strong="H5921"\w* \w sont|strong="H1077"\w* fermés, étroitement scellés.  
\v 16 \w Ils|strong="H3644"\w* \w se|strong="H3820"\w* touchent l'\w un|strong="H3820"\w* l'autre, \w le|strong="H3820"\w* vent \w ne|strong="H3820"\w* passe point \w entre|strong="H3820"\w* eux.  
\v 17 Ils \w sont|strong="H2398"\w* adhérents l'\w un|strong="H2398"\w* \w à|strong="H2398"\w* l'autre; ils se tiennent, ils ne se séparent point.  
\v 18 Ses éternuements jettent \w un|strong="H6965"\w* \w éclat|strong="H6965"\w* \w de|strong="H6965"\w* \w lumière|strong="H6965"\w*, \w et|strong="H6965"\w* ses yeux \w sont|strong="H2719"\w* \w comme|strong="H6965"\w* \w les|strong="H6965"\w* paupières \w de|strong="H6965"\w* l'aurore.  
\v 19 \w De|strong="H6086"\w* \w sa|strong="H2803"\w* bouche sortent \w des|strong="H6086"\w* lueurs, \w et|strong="H6086"\w* s'échappent \w des|strong="H6086"\w* étincelles \w de|strong="H6086"\w* feu.  
\v 20 \w De|strong="H1121"\w* \w ses|strong="H1121"\w* narines \w sort|strong="H1121"\w* \w une|strong="H1121"\w* fumée, \w comme|strong="H1121"\w* d'\w un|strong="H1121"\w* vase \w qui|strong="H1121"\w* bout \w ou|strong="H1121"\w* d'\w une|strong="H1121"\w* chaudière.  
\v 21 \w Son|strong="H2803"\w* souffle enflammerait \w des|strong="H2803"\w* charbons, et \w une|strong="H2803"\w* flamme sort \w de|strong="H2803"\w* \w sa|strong="H2803"\w* gueule.  
\v 22 \w Dans|strong="H5921"\w* \w son|strong="H5921"\w* cou réside \w la|strong="H5921"\w* force, \w et|strong="H5921"\w* \w la|strong="H5921"\w* terreur marche devant \w lui|strong="H5921"\w*.  
\v 23 \w Les|strong="H7760"\w* fanons \w de|strong="H3220"\w* \w sa|strong="H7760"\w* chair \w sont|strong="H3220"\w* adhérents; \w ils|strong="H7760"\w* \w sont|strong="H3220"\w* massifs, inébranlables.  
\v 24 \w Son|strong="H2803"\w* cœur est massif \w comme|strong="H2803"\w* \w une|strong="H2803"\w* pierre, massif \w comme|strong="H2803"\w* \w la|strong="H2803"\w* meule \w de|strong="H2803"\w* dessous.  
\v 25 \w Quand|strong="H5921"\w* \w il|strong="H6083"\w* \w se|strong="H6083"\w* lève, \w les|strong="H6213"\w* \w plus|strong="H5921"\w* forts tremblent, \w ils|strong="H6213"\w* défaillent d'\w effroi|strong="H2844"\w*.  
\v 26 \w Quand|strong="H5921"\w* \w on|strong="H1121"\w* l'\w approche|strong="H7200"\w*, l'épée \w ne|strong="H1121"\w* sert \w à|strong="H1121"\w* rien, \w ni|strong="H1121"\w* \w la|strong="H7200"\w* lance, \w ni|strong="H1121"\w* \w le|strong="H7200"\w* dard, \w ni|strong="H1121"\w* \w la|strong="H7200"\w* cuirasse.  
\v 27 Il regarde le fer comme de la paille, et l'airain comme du bois pourri.  
\v 28 La flèche ne le fait pas fuir, les pierres de la fronde sont pour lui comme du chaume;  
\v 29 Comme du chaume, la massue; il se rit du frémissement des javelots.  
\v 30 Son ventre \w a|strong="H3068"\w* des tessons pointus: il étend une herse sur le limon.  
\v 31 Il fait bouillonner le gouffre comme une chaudière, il rend la mer semblable à un vase de parfumeur.  
\v 32 Il laisse après lui une trace brillante, on dirait sur l'abîme une blanche chevelure.  
\v 33 Il n'\w a|strong="H3068"\w* pas son pareil sur la terre; il \w a|strong="H3068"\w* été fait pour ne rien craindre.  
\v 34 Il regarde tout ce qui est élevé; il est roi des plus fiers animaux.   
\c 42
\p
\v 1 \w Alors|strong="H3068"\w* \w Job|strong="H3068"\w* \w répondit|strong="H6030"\w* \w à|strong="H3068"\w* l'\w Éternel|strong="H3068"\w*, \w et|strong="H3068"\w* \w dit|strong="H6030"\w*:  
\v 2 \w Je|strong="H3068"\w* \w sais|strong="H3045"\w* \w que|strong="H3588"\w* \w tu|strong="H3588"\w* \w peux|strong="H3201"\w* \w tout|strong="H3605"\w*, \w et|strong="H3045"\w* \w qu|strong="H3588"\w*'\w on|strong="H3588"\w* \w ne|strong="H3808"\w* \w saurait|strong="H3808"\w* t'empêcher d'accomplir \w un|strong="H3588"\w* dessein.  
\v 3 “\w Qui|strong="H4310"\w* obscurcit \w mes|strong="H3045"\w* plans \w sans|strong="H3808"\w* \w science|strong="H1847"\w*? “ \w J|strong="H3068"\w*'\w ai|strong="H4310"\w* \w parlé|strong="H5046"\w* \w et|strong="H3045"\w* \w je|strong="H3808"\w* \w ne|strong="H3808"\w* comprenais \w pas|strong="H3808"\w*; \w ce|strong="H2088"\w* \w sont|strong="H3808"\w* \w des|strong="H3808"\w* \w choses|strong="H5046"\w* \w trop|strong="H3808"\w* merveilleuses \w pour|strong="H1847"\w* \w moi|strong="H4480"\w*, \w et|strong="H3045"\w* \w je|strong="H3808"\w* \w ne|strong="H3808"\w* \w les|strong="H3045"\w* \w connais|strong="H3045"\w* \w point|strong="H3808"\w*.  
\v 4 “\w Écoute|strong="H8085"\w* \w donc|strong="H3045"\w* \w et|strong="H8085"\w* \w je|strong="H3045"\w* \w parlerai|strong="H1696"\w*; \w je|strong="H3045"\w* t'\w interrogerai|strong="H7592"\w* \w et|strong="H8085"\w* \w tu|strong="H3045"\w* m'\w instruiras|strong="H3045"\w*. “  
\v 5 \w Mes|strong="H8085"\w* \w oreilles|strong="H8085"\w* \w avaient|strong="H7200"\w* \w entendu|strong="H8085"\w* \w parler|strong="H8085"\w* \w de|strong="H5869"\w* \w toi|strong="H5869"\w*; mais, \w maintenant|strong="H6258"\w*, \w mon|strong="H7200"\w* \w œil|strong="H5869"\w* t'\w a|strong="H3068"\w* \w vu|strong="H7200"\w*.  
