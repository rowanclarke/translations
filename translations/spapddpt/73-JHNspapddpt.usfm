\s1 Destino del discípulo amado  
\p
\v 20 \w Pedro|strong="G4074"\w* \w se|strong="G2532"\w* \w volvió|strong="G1994"\w* \w y|strong="G2532"\w* vio \w que|strong="G3588"\w* \w los|strong="G3588"\w* seguía \w el|strong="G3588"\w* \w discípulo|strong="G3101"\w* \w a|strong="G1909"\w* \w quien|strong="G5101"\w* \w Jesús|strong="G2424"\w* amaba, \w el|strong="G3588"\w* \w que|strong="G3588"\w* \w en|strong="G1722"\w* \w la|strong="G3588"\w* \w cena|strong="G1173"\w* \w se|strong="G2532"\w* reclinó \w a|strong="G1909"\w* \w su|strong="G3588"\w* lado \w y|strong="G2532"\w* preguntó: \w Señor|strong="G2962"\w*, ¿\w quién|strong="G5101"\w* \w es|strong="G3739"\w* \w el|strong="G3588"\w* \w que|strong="G3588"\w* \w te|strong="G4771"\w* \w entrega|strong="G3860"\w*?   
\p
\v 21 \w Entonces|strong="G1161"\w* \w al|strong="G3588"\w* verlo \w Pedro|strong="G4074"\w*, le preguntó \w a|strong="G1161"\w* \w Jesús|strong="G2424"\w*: \w Señor|strong="G2962"\w*, ¿\w y|strong="G1161"\w* \w qué|strong="G3588"\w* \add dices\add* \w de|strong="G3588"\w* \w éste|strong="G3778"\w*?   
\p
\v 22 \w Jesús|strong="G2424"\w* \w le|strong="G4314"\w* contestó: \wj \+w Si|strong="G1437"\+w* \+w lo|strong="G3588"\+w* \+w quiero|strong="G2309"\+w* dejar \+w hasta|strong="G2193"\+w* \+w que|strong="G3588"\+w* \+w venga|strong="G2064"\+w*, ¿\+w qué|strong="G3588"\+w* \+w te|strong="G4771"\+w* importa? Sígueme \+w tú|strong="G4771"\+w*.\wj*   
\p
\v 23 \w Entre|strong="G4314"\w* \w los|strong="G3588"\w* hermanos \w salió|strong="G1831"\w* \w el|strong="G3588"\w* comentario \w que|strong="G3754"\w* \w ese|strong="G3778"\w* \w discípulo|strong="G3101"\w* \w no|strong="G3756"\w* moriría. \w Pero|strong="G1161"\w* \w Jesús|strong="G2424"\w* \w no|strong="G3756"\w* \w le|strong="G4314"\w* \w dijo|strong="G3004"\w*: \wj \+w No|strong="G3756"\+w* morirás,\wj* \w sino|strong="G1161"\w*: \wj \+w Si|strong="G1437"\+w* \+w lo|strong="G3588"\+w* \+w quiero|strong="G2309"\+w* dejar \+w hasta|strong="G2193"\+w* \+w que|strong="G3754"\+w* \+w venga|strong="G2064"\+w*. \wj*   
\p
\v 24 \w Éste|strong="G3778"\w* \w es|strong="G3778"\w* \w el|strong="G3588"\w* \w discípulo|strong="G3101"\w* \w que|strong="G3754"\w* \w da|strong="G3140"\w* \w testimonio|strong="G3141"\w* \w de|strong="G4012"\w* \w estas|strong="G3778"\w* cosas \w y|strong="G2532"\w* \w quien|strong="G3588"\w* \w las|strong="G3588"\w* \w escribió|strong="G1125"\w*. \w Y|strong="G2532"\w* \w sabemos|strong="G1492"\w* \w que|strong="G3754"\w* \w su|strong="G3588"\w* \w testimonio|strong="G3141"\w* \w es|strong="G3778"\w* verdadero.   
\p
\v 25 \w También|strong="G2532"\w* \w Jesús|strong="G2424"\w* \w hizo|strong="G4160"\w* \w muchas|strong="G4183"\w* otras cosas, las cuales, \w si|strong="G1437"\w* \w se|strong="G2532"\w* escribieran \w una|strong="G1520"\w* \w por|strong="G2596"\w* \w una|strong="G1520"\w*, supongo \w que|strong="G1437"\w* \w en|strong="G2596"\w* \w el|strong="G1437"\w* \w mundo|strong="G2889"\w* \w no|strong="G1437"\w* cabrían \w los|strong="G2532"\w* rollos escritos.   