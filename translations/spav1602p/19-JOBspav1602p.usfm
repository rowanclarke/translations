\v 22 \w Él|strong="H1931"\w* \w no|strong="H3808"\w* creerá \w que|strong="H4480"\w* \w ha|strong="H3808"\w* \w de|strong="H4480"\w* \w volver|strong="H7725"\w* \w de|strong="H4480"\w* las \w tinieblas|strong="H2822"\w*, y \w está|strong="H1931"\w* \w mirando|strong="H6822"\w* \w a|strong="H3068"\w* \w la|strong="H1931"\w* \w espada|strong="H2719"\w*.
