\id ROM - Okphela
\h iRoma
\toc1 iRoma
\toc2 iRoma
\toc3 iRom
\mt2 Ebe ni iPọlu ọ kẹkẹ ghi ẹgbọ
\mt1 IRoma
\mt2 Eni e miesuọ
\c 1
\s1 Otsẹ oyi iPọlu
\p 
\v 1 Mhẹmhẹ iPọlu, ọni ọọ ga ọyi iJesu iKirisiti ni a lu mhi khi aghiusomhi na kẹẹ, ni a zẹ ọ le mhi ke tsabọ usomhi onete oyi Ẹshinẹgba. Mhẹmhẹ mhi kẹkẹ ebe ona.
\v 2 Oni usomhi onete ona khi, oni Ẹshinẹgba ọ shobọ shi ekẹ, rọte unu oyi emekẹguele eyọli ni a kẹkẹ shi Ebe-no-pfuasẹ.
\v 3 Oni usomhi onete o ya khi, ingme oyi omi ọli ni ọ rọte unuẹkpẹ oyi iDefidi lasele elemhi idiegbe.
\v 4 A rọte ekpabọ oyi Ayẹmhẹ-nọ-pfuasẹ rọli khasẹ, ikhi iJesu iKirisiti Ọnọmhuẹ ọyawa, khi, Omi Ẹshinẹgba ọ khi, abi ọ rọ rọte eghuli guise ọli le.
\v 5 Rọte obọ oyi iKirisiti ali eva oyọli anye te mie afu rọ khi ighiusomhi na kẹẹ eyọli, ni anye rọ ri ẹgbọ iJẹta nya bhale ya suesọ na Ẹshinẹgba. Isuesọ ni o rọte irudunga bhale.
\v 6 Ẹẹ ẹgbọ iRomu a li la eni Ẹshinẹgba ọ lu, ni a li khi enayi iJesu iKirisiti.
\p 
\v 7 Ẹẹ ni a la iRomu nya a kẹkẹ ebe ona ghi. Ẹẹ ni Ẹshinẹgba ọ nono ingme oyẹwẹ ni ọ zẹ, ni a khi ẹgbọ eyọli.
\p Okhale ali opfọmhẹ e ka khi eyẹ ẹ, rọte obọ oyi Ẹshinẹgba ita awa ali rọte obọ oyi iJesu iKirisiti Ọnọmhuẹ.
\p 
\v 8 Onododẹ, mhi ri eva oyi iJesu iKirisiti tsẹ Ẹshinẹgba ọyẹmhẹ uwegbe shi agbọ oyẹ ẹ nya, irari khi a she la ashakpa elemhi ekẹ agbọ suọ eko irudunga ni a mhọli.
\v 9 Ẹshinẹgba ni mhi ri udu oyẹmhẹ nya a ga, ni mhi a tse abọ usomhi onete oyi omi ọli, ọ khi ọtsẹlẹ ọyẹmhẹ, khi igẹsikia mhia ngme, khi ẹghẹghẹ kpa mhi rọ ọ sa to ẹ egbe ini mhia sọ iromhi.
\v 10 Mhia lema Ẹshinẹgba ọ khueghie odẹ-a na mhẹ ni mhi mẹ asha bhale ya mẹ ẹ ikpukhokho abi o ghọle ọli shi.
\p 
\v 11 O ma ghọle mhẹ gba ni mhi rọ mẹ ẹ, ni mhi ri osẹsẹ eyi ayẹmhẹ na ẹ, ni ó rẹ ẹ ya toto irudunga.
\v 12 Emini mhi ri ọna ngme khi ni a rọ bhale ya ẹ khi awa mhuẹ ikpaghiobọ na egbe. Mhi kha zese ẹ-a, ẹẹ a zese mhẹ-a.
\v 13 Emọle mhẹ, mhia nono ni a lẹsẹ khi, ebubu ẹghẹghẹ mhi she gba li khi mhi bhale ya fẹli ẹ, ni mhi gbo ri ẹgbọ bhale irudunga abi mhi kpe liẹ riẹlẹ ọli ifuabọ ẹgbọẹse ni e khi iJẹta, ama, ọzuodẹ o zu mhẹ odẹ.\f + \fr 1:13 \ft Li zẹ \fq Ika 19.21\f*
\v 14 Ẹgboli oyẹmhẹ o khi ni mhi rọ tse abọ ona ye ẹgbọ kpa, ghe ẹgbọ iGiriki ali eni ẹa khi iGiriki, ene fialo-a ali eni ẹa fialo-a, shi eni mhọli ẹgbhali ali eni ẹa mhọli ẹgbhali.
\v 15 Ighọ, o gbo liẹ kphakpha mhẹ egbe ni mhi rọ li gue oni usomhi onete yẹ ẹ ni a la iRomu.
\s1 Ekpabọ ni o la oni usomhi onete
\p 
\v 16 Omama oni usomhi onete ọa ya mu mhẹ, irari khi lọli o khi ekpabọ oyi Ẹshinẹgba ni a rọ ọ tsumhi ọgbọkpa ni ọ miesuọ, ẹgbọ iJu o kpẹ ramhi egbe, neni o tigbe ramhi ẹgbọ iJẹta egbe.\f + \fr 1:16 \ft Li zẹ \fq iMak 8.38\f*
\v 17 Oni usomhi onete ona o guele abi Ẹshinẹgba ọ liẹ mie ọgbọkpa ni ọ mhọli irudunga. Ẹzẹzẹ abi Ebe-no-pfuasẹ ọ ngme khi, “Ọni Ẹshinẹgba ọ ri irari irudunga oyọli pfa na, ọ ya la agbọ.”\f + \fr 1:17 \ft Li zẹ \fq Abak 2.4\f*
\s1 Elemhi ibibi oyi Ẹshinẹgba
\p 
\v 18 Idane elemhi ibibi oyi Ẹshinẹgba o te ẹ tiemhile shi ẹgbọ ni ẹa miesuọ ali ena ọkhọlọ nya ọ, ni e ri ọkhọlọ oyẹwẹ ẹ khukhu ẹgbọ alo ini e khi lẹsẹ igẹsikia oyi Ẹshinẹgba.
\v 19 Aborọkhia khi e lẹsẹ emini a dobẹ a lẹsẹ ingme oyi Ẹshinẹgba, itobọ khi ọ khueghie ọli-a khasẹ wẹ gboo.
\v 20 Irari khi rọte igbaekẹle agbọ a te mẹ ekpabọ ali ufumhi ali abi Ẹshinẹgba ọ li gboo. Emini ọ ma nya o ri awa mhọli ilẹsẹ abi ọ li. Onana o zẹ khi ẹgbọ ẹa mhuẹ emini e ya liẹ khi o zẹ ni wẹwẹ ẹa rọ miesuọ.
\p 
\v 21 E lẹsẹ Ẹshinẹgba, ama ẹa kuẹghiẹ ọli abi Ẹshinẹgba, wẹkhi eri e kphẹmhi ọli. Ochoghọ, isamhi afuẹ ẹẹ sa, ighọ udu ọọyẹghẹ oyẹwẹ o bishi-a.\f + \fr 1:21 \ft Li zẹ \fq Ẹfi 4.17-18\f*
\v 22 Ẹ khi, eni e fialo-a wẹwẹ e khi, ama e mele eyẹghẹ-a.
\v 23 E ya ọghiẹ ufumhi ni a rọ na Ẹshinẹgba ni ọ la agbọagbọ na ikhumhi ni a mama rọ khọkhọ ọgbọ ni ọọ ghu ali ipfeli ali elamhakọ ali emini ẹẹ ti akpidi ekẹ.\f + \fr 1:23 \ft Li zẹ \fq iDẹut 4.16-18\f*
\p 
\v 24 Irarighọ, Ẹshinẹgba ọ rọ rue wẹ obọ-a na ọghuẹmhẹ olamhẹ oyi udu eyẹwẹ ali itsẹbọ ni e nu egbewẹ ẹ li.
\v 25 E ri ẹgbhọli ọghiẹ igẹsikia oyi Ẹshinẹgba. Ee ga emini a ma, ocho ni e kha rọ ke ga Ima, ọni ọ khi ọni a kuẹghiẹ ya ramhi ẹlẹ ni agbọagbọ. Atsẹ.
\p 
\v 26 Itobọ ona, Ẹshinẹgba ọ rọ rue wẹ obọ-a na ọghuẹmhẹ omama. Egbegbi ikpotso eyẹwẹ, e nu egbe wẹ ẹ gbhẹ.
\v 27 Ighọ li khi eni emọse, ocho ni e kha rọ le ke deba ikpotso, emọse na abi wẹwẹ ẹẹ ghọle wẹ inu-gbhẹ. Emọse ẹ gbe ikanya omama ke deba emọse, irarighọ, e she mie ifata ikanya ebe eyẹwẹ.
\p 
\v 28 Irari khi ẹa lama ri egbegbi ilẹsẹ oyi Ẹshinẹgba ni e mhuẹ shi udu, Ẹshinẹgba ọ rọ zẹ wẹ obọ na isamhi ebe udu oyẹwẹ ni e ke riẹlẹ emini ẹa kha riẹlẹ.
\v 29 Ọkhọlọ khi ọkhọlọ nya o kẹsẹ wẹ-a, ghe ingmobe, ghe emhi ito-egbe, ghe ubọgbọ. Ofuma ikpekpe o vọ wẹ egbe, ghe ugbeli, ghe okhọli, ghe ikpamhika, ghe ọbe-imumu. Eni ẹ tsue ẹgbọ kiakia e khi.
\v 30 E ri unu ẹ yese ọgbọ-a, ẹẹ biselemhi Ẹshinẹgba, ezunu-obe, ni ẹa mhuẹ ekpẹ, ni ẹẹ tono obọ udu. Odẹ ebe ni a rọ li ọkhọlọ enegbọ, ẹẹ sa rọ lasele ẹghẹghẹ kpa. Ẹa ya suọ esọ na itawẹ.
\v 31 Ẹa mhuẹ ilẹsingme, ẹa ri ishobọ oyẹwẹ a gbe akanya, ẹa ya ti elemhi ọgbọ wẹkhi eri e mhuẹ ilẹlemhi na ọgbọ.
\v 32 E lẹsẹ khi ushi oyi Ẹshinẹgba, ọọ khi, ẹgbọ ni e li na ngeli, eni e ya pfua e khi, ọa khi eri e lẹsẹ ẹ riẹlẹ emhi eghọghọ tsẹ, ama ẹẹ mie obọ shi eni ẹ gbe ikanya eghọghọ ọ.
\c 2
\s1 Iguẹzọ oyi Ẹshinẹgba
\p 
\v 1 Yẹyẹ ni u wa gue ẹgbọẹse ẹzọ, waa mhọli obini u pfue ọ ya je, irari khi ẹghẹghẹ kpa ni u rọ gue ọgbọẹse ẹzọ ne, egbe ẹ wa gue ẹzọ, itobọ khi yẹyẹ oyẹ u lili ẹ riẹlẹ eni emhi.\f + \fr 2:1 \ft Li zẹ \fq iMat 7.1; iLuk 6.37\f*
\v 2 Awa lẹsẹ khi ẹzọ ni Ẹshinẹgba ọ gue ẹgbọ ni ẹẹ riẹlẹ emhi eghọghọ, khi igẹsikia ọ deba gue ọli.
\v 3 Eri u dabi khi ini yẹyẹ ọgbọ afuafuafuẹ u gue ẹgbọẹse ẹzọ, khi yẹyẹ u li riẹlẹ oni emhi oghọghọ, khi u ya pfue ẹzọ oyi Ẹshinẹgba?
\v 4 Abi khi eri u ri ẹloe ẹ gbe isomhelemhi ali iregbemie ali irabọmudu eniẹmhi eyọli, nu waa lẹsẹ khi isomhelemhi oyi Ẹshinẹgba o rẹ ramhi imupfi?
\p 
\v 5 Ama irari igbiti ali udu ni ọa mhuẹ imupfi ni a mhuẹ, a rọ khi ma ofu oyi Ẹshinẹgba, ni ọ rọ ya na ẹ osoli, ẹghẹghẹ ni iguẹzọ oyọli ni ọa mhuẹ azẹba o rọ ya feli lasele.
\v 6 Ẹshinẹgba, “Ọ ya fali ọgbọgbọ ota abi ọ li gbe.”\f + \fr 2:6 \ft Li zẹ \fq Iwolo 62.12; Ekpi 24.12\f*
\v 7 Ọ ya ri agbọ na agbọagbọ na ẹgbọ ni e mhuẹ irabọmudu ẹ riẹlẹ onete, ni ẹẹ nono ufumhi ali agbọ ni ọa mhuẹ ukpẹsẹ.
\v 8 Ama ẹgbọ ni ẹẹ na shi oyẹwẹ tsẹ, ni ẹa ri esọ shi igẹsikia ni o la ungmemhi oyi Ẹshinẹgba, ni e deba onobe vu, Ẹshinẹgba ọ ya tiese ofu ali elemhi ibibi oyọli le shi wẹ ọ.
\v 9 Ẹgbọ eni ẹẹ riẹlẹ onobe nya e ya mẹ osoli ali oya. Okekhi ẹgbọ iJu, okekhi ẹgbọ iJẹta.
\v 10 Ama Ẹshinẹgba ọ ya ri ufumhi ali itinga ali opfọmhẹ na ẹgbọ nya ni ẹ riẹlẹ onete. Okekhi ẹgbọ iJu, okekhi ẹgbọ iJẹta
\v 11 Irari khi Ẹshinẹgba ọa ya zọlọ ọgbọkhọghuo.\f + \fr 2:11 \ft Li zẹ \fq iDẹut 10.17\f*
\p 
\v 12 Ẹgbọkpa ni e lamhẹ olamhẹ ni ẹa mẹ ebe ushi deba, ọgbọ ọa rọte ebe ushi ya gue wẹ ẹzọ, ama ẹgbọkpa ni e mhuẹ ushi deba ni e lamhẹ olamhẹ, a ya rọte ushi gue wẹ ẹzọ.
\v 13 Irari khi ọa khi ẹgbọ ni e suọ abi ushi ọ ngme tsẹ Ẹshinẹgba ọ ya liẹ khi e pfuasẹ, ama eni e suọ abi ushi ọ ngme ni e rọli ẹ gbe akanya, Ẹshinẹgba ọ ya pfa na khi e pfuasẹ.
\v 14 Ẹghẹghẹ kpa ni ẹgbọ iJẹta, ni ẹa mhọli ushi, e rọ rọte angeli oyẹwẹ ri ushi gbe akanya ne, eri e rọkhasẹ khi e lẹsẹ emini ọa ti ali emini o ti ni a riẹlẹ, ini ẹa ririẹ mhuẹ ushi.
\v 15 Eri angeli oyẹwẹ o rọkhasẹ khi emini ushi ọọ a ke riẹlẹ, khi e kẹkẹ ọli shi udu, udu oyẹwẹ ọ pfi ọtsẹlẹ shi ọ, isamhi eyẹwẹ ni ẹ gue wẹ ẹzọ isheghuo, e gbo khẹ wẹ shi ekẹ.
\v 16 Ighọ o ya li ogbẹlẹ ni Ẹshinẹgba ọ ya rọte obọ oyi iJesu iKirisiti gue wẹ ẹzọ ri osheli oyẹwẹ lasele abi mhi li ri usomhi onete tse abọ.
\s1 Ẹgbọ iJu ali ushi
\p 
\v 17 Ini a lu egbe ẹ ẹgbọ iJu, a ri egbe da ushi ri Ẹshinẹgba a tono obọ udu,
\v 18 Ini a zẹ Ebe-no-pfuasẹ lẹsẹ ọghuẹmhẹ oyi Ẹshinẹgba, ni a gbo lẹsẹ emini o gbe akanya,
\v 19 ini a lẹsẹ khi ẹẹ a khi eni ẹẹ sẹsẹ ezalo odẹ, ni a rọ gbo khi ákpá na ẹgbọ ni e la alo ebili,
\v 20 a ye ẹgbọ ni e khi eyẹghẹ ude, a sẹsẹ eni ẹa lẹsẹ. A mhọli ọli shi udu khi ilẹsẹ ali igẹsikia o gba pfo shi elemhi ushi.
\v 21 Ẹẹ ni a sẹsẹ ẹgbọẹse, elọ o zẹ khi aa ya sẹsẹ egbe ẹ? Ẹẹ ni a liẹ ọgbọ ọ khi do ughiatọ, àá liẹ do?
\v 22 Ẹẹ ni a liẹ ọgbọ ọ khi kia okia, aa liẹ kia okia? Ẹẹ ni ikhumhi igaga ọọ kpasẹ, aa liẹ do ughiatọ elemhi Owa oyi Ẹshinẹgba?
\v 23 Ẹẹ ni a tono obọ udu khi a mhuẹ ishi eyi Ẹshinẹgba, aa ri omama mu Ẹshinẹgba abi a liẹ gbe eni ishi-a?
\v 24 Ebe-no-pfuasẹ ọọ khi: “Irari ẹẹ ni a khi ẹgbọ iJu ẹgbọ iJẹta e rọ ọ zẹ ẹmuẹbe na eva oyi Ẹshinẹgba.”\f + \fr 2:24 \ft Li zẹ \fq Aza 52.5\f*
\v 25 Ini a ri ishi a gbe ikanya, oshẹlẹ oyẹ ẹ o rọ mu ẹloe, ama ini a gbe ushi-a, eri a li abinẹ khi aa shẹlẹ-a.
\v 26 Ini ọgbọ ni ọa khi iJu ni ọgbọ aa shẹlẹ-a ọ ri ushi oyi Ẹshinẹgba gbe akanya, Ẹshinẹgba ọa ya leli ọli shi ọni aa shẹlẹ-a?
\v 27 Itobọ ighọ, ẹgbọ iJẹta e ya pfa ẹzọ mu ẹ iJu itobọ khi a gbe ushi-a, aboriẹkhia khi a kẹkẹ oni ushi shi ebe na ẹ ni a gbo shẹlẹ-a, ama wẹwẹ e ri ushi ẹ gbe akanya ini aa ririẹ shẹlẹ wẹ-a.
\v 28 Ọa khi itobọ khi ọgbọ ọọ ngeli abi ọgbọ iJu ali itobọ khi a da shẹlẹ ọli-a ọ rọ khi egbegbi iJu.
\v 29 Ama ọni ọ khi egbegbi iJu ọ khi ọni ọ ri ushi ẹ gbe akanya, Oshẹlẹ na ekelemhi udu o khi igẹsikia oyi oshẹlẹ, ọa khi ona ẹkuẹ idiegbe oyẹ. Ọgbọ ọghọghọ Ẹshinẹgba ọọ kuẹghiẹ ọli, aa khi ẹgbọ ẹẹ kuẹghiẹ ọli.\f + \fr 2:29 \ft Li zẹ \fq iDẹut 30.6\f*
\c 3
\p 
\v 1 Ighe eleli ni ẹgbọ iJu, ikhi eni a lu eni a shẹlẹ-a, e mhọli dọsẹ ẹgbọ iJẹta? Ighe eleli ni o la ọ na ẹgbọ ni ẹ lu egbewẹ eni a shẹlẹ-a?
\v 2 Èleli o la ọ na ọgbọgbọ odẹ khi odẹ. Ododẹ, ẹgbọ iJu Ẹshinẹgba ọ kpẹ ri oni ungmemhi nga obọ.
\p 
\v 3 Ini o fẹ khia khi eghuo ọ ẹa mhuẹ irudunga? Eri umha mhuẹ irudunga oyẹwẹ o ya liẹ khi Ẹshinẹgba ọa ke zẹ ri egbe ẹ nga?
\v 4 Iiye e! Ini ọgbọkpa o tseku khi ọloẹgbhuẹ, igẹsikia Ẹshinẹgba ọ khi. Abi Ebe-no-pfuasẹ o ngme, ni ọọ.\f + \fr 3:4 \ft Li zẹ \fq Iwolo 51.4\f*
\q1 “A mema mẹ khi
\q1 yẹyẹ u te odẹ ini u ngme,
\q2 ali khi u ya mu ọ le
\q2 ini a gue ẹ ẹzọ.”
\p 
\v 5 Ama ini umha guẹ ẹ ngeli oyawa o ri ipfuasẹ oyi Ẹshinẹgba khasẹ gboo, sẹẹ awa ke fẹ ya ngme? Eri awa ya liẹ khi Ẹshinẹgba ọ gbe awa azẹba ini ọ na awa osoli tọ onobe ni awa li? Eri mhi la ana ngme abi ọgbọ ọ liẹ ngme.
\v 6 Emini a sọ shi ona khi, IIye o, ini o khia khi Ẹshinẹgba ọọ gbe azẹba lọ, se ọ kha li dobẹ gue agbọ ẹzọ?
\v 7 Ẹgbọ eghuo e ya ke khakọ, ẹẹ li, “Ini o khia khi ẹgbhọli ni mhi lo o ri izẹ-ri-egbenga oyi Ẹshinẹgba khasẹ, ni o khi ma ufumhi oyọli, sẹ a ke gbo liẹ pfa ẹzọ mu mhẹ abi ọgbọ ọna olamhẹ?”
\v 8 Elọ o ke zẹ ni awa a rọ liẹ khi o tinẹ ni awa ke li ingmobe ni onete o rọte ọ lasele? A ya gue ọgbọgbọ eni e ngme na ẹzọ. Ẹzẹzẹ abi ẹgbọ eghuo e she kpẹ li kiẹnọ ẹgbhọli ma mhẹ khi emini mhia sẹsẹ ẹgbọ ghọ.
\s1 Aa mẹ ọni ọ guẹ ẹ ngeli
\p 
\v 9 Ini a fẹ bino ọ bie, eri awa iJu awa fẹ ti dọsẹ iJẹta? IIye o! Mhi she kpẹ rọli khasẹ khi ẹgbọ iJu ali ẹgbọ iJẹta nya elemhi olamhẹ awa la a kia.
\v 10 Abi Ebe-no-pfuasẹ o ngme ni ọọ:
\q1 “Ọgbọkhọghuo ọa la ọ
\q1 ni ọ guẹ ẹ ngeli, ọgbọ aa mẹ,
\q2 
\v 11 Aa mẹ ọni ọ mhuẹ ilẹsẹ,
\q2 wẹkhi eri ọgbọkhọghuo
\q2 ọọ ga Ẹshinẹgba.
\q1 
\v 12 Ẹgbọ nya e she sọ
\q1 ukhokho gbe Ẹshinẹgba.
\q2 Wẹwẹ nya e she rọte
\q2 odẹ oboese ni ọa ti.
\q1 Ọgbọkhọghuo ọa la ni
\q1 ọọ riẹlẹ onete,
\q2 ọgbọ aa mẹ ọghuo kpe!”\f + \fr 3:12 \ft Li zẹ \fq Iwolo 14.1-3; 53.1-3\f*
\q1 
\v 13 “Eri ukokoluọluọ oyẹwẹ
\q1 o li abi uji ni o
\q1 khueghie-a shi ekẹ.
\q2 Eri ẹlẹmhi oyẹwẹ
\qm2 O ri udimhi ẹ pfi itsee.”\f + \fr 3:13 \ft Li zẹ \fq Iwolo 5.9; 140.3\f*
\q1 “Osuẹ ẹnyẹ afue o la wẹ unu.”
\q2 
\v 14 “Inu eyẹwẹ o vọ
\q2 itsẹ ebe ikuku ali oyala.”\f + \fr 3:14 \ft Li zẹ \fq Iwolo 10.7\f*
\q1 
\v 15 “Ọa ya mu wẹ unu
\q2 ni e rọ gbe ugbeli,
\q1 
\v 16 epfua ali oyese ẹẹ pfi
\q2 shi obini e je kpa,
\q1 
\v 17 Ẹa lẹsẹ abi a liẹ la opfọmhẹ.”\f + \fr 3:17 \ft Li zẹ \fq Aza 59.7-8\f*
\q2 
\v 18 “Wẹkhi eri e mhọli
\q2 ekpẹ na Ẹshinẹgba.”\f + \fr 3:18 \ft Li zẹ \fq Iwolo 36.1\f*
\p 
\v 19 Mena, awa lẹsẹ khi emini a kẹkẹ shi ushi nya, khi eni e deba ushi ẹ ngeli a kẹkẹ ọli na. Ni a rọ bhale ya ẹ khi ọgbọ okhọghuo ọa ya liẹ khi emini o zẹ ni luẹ rọ gbe ushi-a na, ini Ẹshinẹgba ọ gue agbọ nya ẹzọ.
\v 20 Ọgbọ ọa la ọ ni a ya pfa na khi ọ pfuasẹ irari khi ọ ri ushi ẹ gbe akanya. Ochoghọ eri ushi o zẹ awa lẹsẹ khi olamhẹ o la ọ.\f + \fr 3:20 \ft Li zẹ \fq Iwolo 143.2; iGal 2.16\f*
\s1 Iguẹ-ngeli ni o rọte irudunga bhale
\p 
\v 21 Ama Ẹshinẹgba ọ she ri odẹ onogbọ ni ọ te pfa na awa khasẹ awa ni ọa khi abi ushi o sẹsẹ awa. Ni ebe Ushi ali emekẹguele e pfi ọtsẹlẹ shi.
\v 22 Oni odẹ onogbọ ona ni Ẹshinẹgba ọ rọ bhale, irudunga iJesu iKirisiti o te ẹ bhale deba eni e mie ọli suọ nya. Ikhiọda ọa la ọ na eni e khi iJu ali iGiriki.\f + \fr 3:22 \ft Li zẹ \fq iGal 2.16\f*
\v 23 Irari khi ọgbọkpa ọ she lamhẹ, ẹgbọ e she nuata shi Ẹshinẹgba ni ọọ tsumhi ọ.
\v 24 Ama afuẹ afuẹ ọ ri okhale oyọli pfa na awa khi awa pfuasẹ, rọte ipfashekẹ ni o te obọ oyi iJesu iKirisiti bhale.
\v 25-26 Eri Ẹshinẹgba ọ ri iKirisiti khasẹ agbọ nya, khi lọli ọ khi ọni ọ dobẹ ya ri olamhẹ topfa agbọ, abi ọ li ku ọlia eyọli kua ukhomhi apfida. Awa kha regbenga emini iKirisiti ọ riẹlẹ, awa mhọli ipfashekẹ ni o rọ rọkhasẹ khi Ẹshinẹgba ọa ya gbe azẹba. Itobọ khi Ẹshinẹgba ọ mhọli irabọmudu ali khi ọa ya gbe azẹba, ọ rọọ gbe olamhẹ kua na ẹgbọ, ọ guele khi ọgbọkpa ni ọ ri udu nga iJesu, khi ọni a pfa na ọ khi.
\p 
\v 27 Elọ awa ke tono obọ udu ẹ shi? Afuẹ! Elọ o zẹ ona? Itobọ khi awa ma rọ ri ushi a gbe lọ? Iiye o, ama itobọ khi awa miesuọ.
\v 28 Irari khi awa zọli ukhomhi khi eri Ẹshinẹgba ọọ pfa na ẹgbọ ni e mhuẹ irudunga ni ọa khi irari iri-ushi-gbe akanya.
\v 29 Ẹshinẹgba ọyi ẹgbọ iJu tsẹ ọ lẹsẹ khi, ọa ke li khi Ẹshinẹgba oyi ẹgbọ iJẹta? Ọyẹwẹ ọ khi guẹguẹguẹ.
\v 30 Ẹshinẹgba ọghuo ọ khi, ọni ọọ pfa na ẹgbọ eni e shẹlẹ-a rọte irudunga oyẹwẹ ali eni áà shẹlẹ-a rọte oni irudunga oghuo.\f + \fr 3:30 \ft Li zẹ \fq iDẹut 6.4; iGal 3.20\f*
\v 31 Eri ona o ke liẹ khi itobọ irudunga oyawa, khi awa a ke mhuẹ emini awa ri ushi ẹ li? IIye e. Ochoghọ awa kie mu ushi mhuẹ.
\c 4
\s1 Irudunga o ri Aburaamu migha shi ipfuasẹ
\p 
\v 1 Sẹ awa ke ya ngme shi ingme oyi Aburaamu ni ọ khi ititawa? Elọ ọ fẹ mẹ eni ingme ipfana rọte irudunga onana?
\v 2 Ini o khia khi ikanya ni Aburaamu ọ gbe a rọ pfa na li lọ, ọ kha mẹ emhi rọ ke tono obọ udu, ama ọa khi odalo oyi Ẹshinẹgba.
\v 3 Eri Ebe-no-pfuasẹ ọọ, “Eri Aburaamu ọ mie Ẹshinẹgba suọ, lọli a rọ leli ọli na li shi ipfuasẹ.”\f + \fr 4:3 \ft Li zẹ \fq Igbae 15.6; iGal 3.6\f*
\v 4 Ini ọgbọ gbe akanya, ọgbọ ọa ya liẹ khi ifata ni ọ mie khi isomhopfa lọ, ama eri ọ gbe akanya shi ọ.
\v 5 Ama ọgbọ ni ọa ri egbe da ikanya obọ oyọli ni ọ gbe, ni ọ regbenga Ẹshinẹgba ni ọọ pfa na ọna ọkhọlọ, oni irudunga ni ọ mhọli eghọ a deba guele khi ọ pfuasẹ.
\v 6 Abi iDefidi ọ rọ ngme nga ikhivọsẹ oyi ọni Ẹshinẹgba ọ pfa na, ni ọa khi itobọ ikanya obọ oyi lọlighuo, ọ mu ma ingme ena, abi ọ rẹẹ,
\q1 
\v 7 “Oghẹlẹ o khi na ẹgbọ
\q2 ni Ọnọmhuẹ ọ gbe
\q1 umha guẹli oyẹwẹ kua,
\q1 ni a ri olamhẹ oyẹwẹ
\q2 topfa wẹ.
\q1 
\v 8 Oghẹlẹ o khi na ọgbọ
\q2 ni Ọnọmhuẹ ọa kẹkẹ
\q1 olamhẹ eyọli shi na li.”\f + \fr 4:8 \ft Li zẹ \fq Iwolo 32.2\f*
\p 
\v 9 Oni ikhivọsẹ ona, ẹgbọ ni a shẹlẹ-a e lẹsẹ mhọli ọli? Abi khi ẹgbọ ni aa shẹlẹ-a e li mhọli ọli? Awa kie kpẹ ẹ ngme ọli khi irudunga ni Aburaamu ọ mhuẹ, lọli a rọ guele khi ọ pfuasẹ.
\v 10 Ẹghẹghẹ onoghuo a rọ leli ọli na li? Abi a rọ shẹlẹ ọli-a se lọ, abi khi neni a shẹlẹ ọli-a? Ọa khi abi a rọ shẹlẹ ọli-a se, ama abi aa rọ shẹlẹ ọli-a ne lọ.
\v 11 Itobọ khi ọ mhọli irudunga, Ẹshinẹgba ọ rọ pfa na li khi ọ mhọli ipfuasẹ neni ọ shẹlẹ-a. Irarighọ, ọ rọ khi ita ọyi ẹgbọ nya ni e miesuọ, ini aa tseku shẹlẹ wẹ-a. Ẹghẹghẹ aghọ ni e khi eni a pfa na khi e pfuasẹ.\f + \fr 4:11 \ft Li zẹ \fq Igbae 17.10\f*
\v 12 Ita oyi ẹgbọ eni e shẹlẹ-a ọ li khi. Aa khi itobọ khi a shẹlẹ wẹ-a tsẹ, ama irari khi e deba ẹtẹ-awẹ agbọ irudunga nabi itawa Aburaamu, neni a shẹlẹ ọli-a.
\s1 Irudunga a te a mie ishobọ eyi Ẹshinẹgba
\p 
\v 13 Ọa khi iri ushi gbe akanya Aburaamu ali imimi ọli e te mie oni ishobọ khi lọli ọ ya le ugu agbọ nya, ama rọte angeli ipfuasẹ ni o rọte irudunga bhale oyọli lọ.\f + \fr 4:13 \ft Li zẹ \fq Igbae 17.4-6; 22.17-18; iGal 3.29\f*
\v 14 Irari khi ini eni e ri ushi gbe akanya e le oni ugu lọ, irudunga ọa kha ke mu ẹloe, oni ishobọ o mele afuẹ-a.\f + \fr 4:14 \ft Li zẹ \fq iGal 3.18\f*
\v 15 Eri ushi o ri ofu oyi Ẹshinẹgba bhale, irari khi ini ushi ọa la ọ, igbushi-a ọa kha la ọ.
\p 
\v 16 Irarighọ, oni ishobọ, irudunga o te ẹ bhale, isheghọ ni o khi oyi okhale, ali ni o migha na imimi Aburaamu. Ọa khi oyi ẹgbọ ni e ri ushi ẹ gbe akanya tsẹ, ama li shi oyi eni e miesuọ abi Aburaamu. Irari khi Aburaamu ọ khi ita awa nya elemhi ayẹmhẹ.\f + \fr 4:16 \ft Li zẹ \fq iGal 3.7\f*
\v 17 Abi Ebe-no-pfuasẹ o ngme ni ọọ, “Mhi she rẹ mele ita ọyi ushishi ebubu-a.” Irudunga ni Aburaamu ọ mhuẹ Ẹshinẹgba ọ rọ shobọ na li. Ẹshinẹgba ni ọọ ri eni e ghu-a guale bhale agbọ, ni ọ ma emhi enegbọ.\f + \fr 4:17 \ft Li zẹ \fq Igbae 17.5\f*
\v 18 Eri Aburaamu ọ miesuọ, ọ mhuẹ irudushi, abi ọa rọ tseku mẹ emini ọ ri udu shi ne, itobọ ighọ ọ rọ khi, “Ita ishishi ebubu.” Abi a kie kpẹ li gue ọli ye ọli khi, “Imimiẹ e ya bu abi ikpẹtata.”\f + \fr 4:18 \ft Li zẹ \fq Igbae 15.5\f*
\v 19 Ọa tigbe lọsẹ Aburaamu shi irudunga oyọli, aboriẹkhia khi ọ she gbe ikpe egbhuẹshe, ni ọ gbo lẹsẹ khi lọli she womhẹ ramhi eghuli ali khi iSera ughuọli ọ she li womhẹ dọsẹ ni ọ ke dobẹ ya bia eniyẹ.\f + \fr 4:19 \ft Li zẹ \fq Igbae 17.17\f*
\v 20 Irudunga oyọli ọa mhuẹ ọlọsẹmhẹ wẹkhi eri ọ khọkhọ udu shi emini Ẹshinẹgba ọ ngme. Oni irudunga oyọli o ri itoto na li, ọ kuẹghiẹ Ẹshinẹgba.
\v 21 Eri ọ lama shi ọ egbegbọ khi Ẹshinẹgba ọ ya dobẹ riẹlẹ emini ọ shobọ na luẹ.
\v 22 Lọli o zẹ khi, “A pfa na li khi ọ pfuasẹ.”
\v 23 Ungmemhi khi, “A leli ọli na li shi angeli ipfuasẹ,” ọa khi lọlighuo tsẹ a kẹkẹ ọli na.
\v 24 Ama a li kẹkẹ ọli na awa, eni Ẹshinẹgba ọ liẹ leli angeli ipfuasẹ na, ni awa mie ọli suọ ikhi lọli ni ọ rọte eghuli guise iJesu Ọnọmhuẹ ọyawa le.
\v 25 Eri Ẹshinẹgba ọ rue ọli obọ-a ni ọ ghu-a shi ingmobe eyawa. O guise ọli le bhale agbọ ni ọ khuẹsẹ awa pfuasẹ.\f + \fr 4:25 \ft Li zẹ \fq Aza 53.4-5\f*
\c 5
\s1 Opfọmhẹ ali Oghẹlẹ
\p 
\v 1 Irarighọ, aborọkhia khi a she pfa na awa eghọ khi awa pfuasẹ rọte irudunga oyawa, awa she mhuẹ opfọmhẹ odalo oyi Ẹshinẹgba rọte obọ oyi iJesu iKirisiti Ọnọmhuẹ oyawa.
\v 2 Lọli awa rọte obọ oyọli mhọli odẹ lo isomhelemhi oyi Ẹshinẹgba, te irudunga ni awa migha nga memena. Awa ke ghẹlẹ shi irudushi oyi ufumhi oyi Ẹshinẹgba.
\v 3 Ọa khi ighọ tsẹ, ama awa liẹ ghẹlẹ shi osoli oyawa, irari khi awa lẹsẹ khi eri osoli ọọ sẹsẹ ọgbọ iregbemie.
\v 4 Iregbemie o ri ọgbọ ọ mhuẹ egbegbi angeli, egbegbi angeli o ri ọgbọ ọ mhuẹ irudushi.
\v 5 Oni irudushi ona, ọa ya zẹ awa mẹ omama. Irari khi Ẹshinẹgba ọ she tutu inono oyọli ku awa udu rọte Ayẹmhẹ-nọ-pfuasẹ, ni ọ rọ na awa.
\v 6 Irari khi ẹghẹghẹ ni awa aa rọ mhọli ekpabọ ni awa rọ khi ena olamhẹ, iKirisiti ọ bhale ya ghu-a na awa.
\v 7 O ma munu ni ọgbọ ọ rọ ghu-a na ọgbọ ni ọ guẹ ẹ ngeli, otsẹ ọgbọ ọ ya rọshẹka ni luẹ ghu-a na ọgbọ onete.
\v 8 Ama eri Ẹshinẹgba ọ ri inono ni ọ mhọli na awa khasẹ. Lọli o zẹ khi ẹghẹghẹ ni awa rọ kie khi ena olamhẹ, iKirisiti ọ rọ bhale ya ghu-a na awa.
\p 
\v 9 Aborọkhia khi a she rọte ọlia eyọli pfa na awa mena, sẹẹ ọa liẹ tsumhi awa ofu oyi Ẹshinẹgba!
\v 10 Irari khi ini ẹghẹghẹ ni awa rọ khi ebe Ẹshinẹgba khi a rọte eghuli ni omiọli ọ ghu ri awa nu ọli mhuẹ irọ-riẹlẹ, sẹẹ awa ni a she rọ nu Ẹshinẹgba somhi awa aa li gbo ya rọte agbọ oyọli mhuẹ imiepfuese!
\v 11 Ọa khi ighọ tsẹ, ama awa li mhọli oghẹlẹ ayi Ẹshinẹgba rọte iJesu iKirisiti Ọnọmhuẹ ọyawa, ọni awa rọte obọ oyọli mhuẹ irọsomhi.
\s1 Adamu ọ ri eghuli bhale, iKirisiti ọ ri agbọ bhale
\p 
\v 12 Olamhẹ ni Adamu ọ lamhẹ o ri eghuli lo agbọ le. Olamhẹ oyọli o zẹ khi ọgbọkpa ọ khi ọna olamhẹ, irarighọ ọgbọkpa ọ rọ ya ghua.\f + \fr 5:12 \ft Li zẹ \fq Igbae 3.6\f*
\v 13 Irari khi neni a ri ushi bhale olamhẹ, ọ she kpẹ lo agbọ le, ama ashini ushi ọa la, aa ya leli olamhẹ na ọgbọkhọghuo.
\v 14 Aboriẹkhi ighọ, eri eghuli o kie rọte ẹghẹghẹ oyi Adamu gbe ẹgbọ ya ramhi ẹghẹghẹ oyi iMosisi, li shi ẹgbọ ni ẹa gbe ushi-a abi Adamu ọ li da omhẹsẹ oyi Ẹshinẹgba. Adamu ọ khi irọkhọkhọ oyi ọni ọ ya bhale.
\p 
\v 15 Ama wẹwẹ aava ẹa li abeghuo irari khi isomhopfa onayi Ẹshinẹgba ọa li abi olamhẹ oyi Adamu. Igẹsikia o khi, khi ebubu ẹgbọ e ghu-a irari olamhẹ oyi ọgbọghuo ọghọ. Ama okhale oyi Ẹshinẹgba o funẹ. Ighọ khi isomhopfa ni ọ rọ na ebubu ẹgbọ rọte isomhelemhi oyi ọgbọ ọghuo, ikhi iJesu iKirisiti.
\v 16 Ikhiọda o la isomhopfa oyi Ẹshinẹgba ali olamhẹ oyi Adamu. Oni olamhẹ oghuo oghọ o ri ina-osoli bhale. Ama isomhopfa oyi Ẹshinẹgba o ri ipfana bhale ghi awa aboriẹkhia khi eni e lamhẹ awa khi.
\v 17 Igẹsikia o khi, khi rọte olamhẹ oyi ọgbọ ọghuo, eghuli o te bhale agbọ. Ama emini ọgbọ ọghuo ọ riẹlẹ, ikhi iJesu iKirisiti, o funẹ. Ẹgbọ nya ni e mie okhale oniẹmhi ali isomhopfa afuẹ afuẹ oyi ipfuasẹ oyi Ẹshinẹgba, e ya mu olamhẹ ọ le, rọte obọ oyi iKirisiti.
\v 18 Abi olamhẹ oyi Adamu o li ri ina-osoli ghi ẹgbọkpa, ighọ ipfuasẹ oghuo oyi iKirisiti o li ri ipfana ali isomhopfa agbọ oyi Ẹshinẹgba na ọgbọkpa.
\v 19 Irari khi, abi umha-suesọ oyi ọgbọ oghuo o ri ẹgbọ nya khi ena olamhẹ, ighọ a li ya pfa na ebubu ẹgbọ shi odẹ oyi Ẹshinẹgba irari isuesọ oyi ọgbọ oghuo.
\p 
\v 20 Eri ushi o bhale ni ẹgbọ lẹsẹ ashini e khi ena olamhẹ ramhi, ama abibi olamhẹ e tseku li bu, ilẹlemhi oyi Ẹshinẹgba o bu dọsẹ wẹ.
\v 21 Ẹghẹghẹ aghọ ni a bhale ya ẹ khi ẹzẹzẹ abi olamhẹ o ri eghuli bhale, okhale oyi Ẹshinẹgba o ri ipfuasẹ leghie, o ri agbọ na agbọagbọ bhale, rọte obọ oyi iJesu iKirisiti Ọnọmhuẹ ọyawa.
\c 6
\s1 Ghu pfa Olamhẹ, u nu iKirisiti la agbọ
\p 
\v 1 Sẹ awa ya ngme mena, eri awa ya ke li ingmobe lẹ tsẹ ni okhale oyi Ẹshinẹgba o ke bua shi ọ dọsẹ aghọ?
\v 2 Iiye o! Awa ni idiegbe oyawa o ghu pfa olamhẹ, sẹẹ awa ke gbo liẹ ke lamhẹ?
\v 3 Abi khi aa lẹsẹ khi awa nya ni a batazi shi iJesu iKirisiti, khi eri awa batazi shi eghuli oyọli?
\v 4 Irarighọ, eri a ri awa nu ọli tọ abi a rọ sọ awa okẹ batazi awa shi eghuli oyọli, ni a bhale ya ẹ khi abi a li rọte eghuli guise iKirisiti le rọte ufumhi oyi Ita, ni awa li mhọli agbọ onogbọ.\f + \fr 6:4 \ft Li zẹ \fq iKolo 2.12\f*
\p 
\v 5 Abi a rọ ku awa ali lọli gbe she eghuli oyọli eghọ, ighọ a gbo liẹ ku awa ali lọli gbe shi iguisele oyọli.
\v 6 Awa lẹsẹ ona khi idiegbe oyawa onodiọ khi eri o nu iJesu ghu-a shi apfida, ni a rọ bhale ya ẹ khi idiegbe olamhẹ oyawa o mele afuẹ-a. Ini awa khi ke gbo khi ighumha olamhẹ.
\v 7 Itobọ khi ini ọgbọ ọ ghu-a, ọ she pfue ekpabọ olamhẹ.
\v 8 Mena, ini awa she nu iKirisiti ghua, awa miesuọ khi awa ya li nu ọli la agbọ.
\v 9 Irari khi awa lẹsẹ khi abi a she rọte eghuli guise iKirisiti le eghọ, ọa ke gbo ya ghu ghue, eghuli ọa ke gbo mhọli ekpabọ shi ọli egbe.
\v 10 Eghuli ni ọ ghu, utoghuokpe ọ ghu ọli rọ mu ekpabọ eyi olamhẹ ọ le. Agbọ ni ọ la, ọ la ọ na Ẹshinẹgba.
\v 11 A li lighọ leli egbe ẹ shi eni e ghu pfa olamhẹ, ama a la agbọ na Ẹshinẹgba elemhi iJesu iKirisiti.
\v 12 Irarighọ, a khi zẹ ni olamhẹ o le eghie shi ẹ egbe ni a ri ọghuẹmhẹ ebe eyọli ke gbe akanya.
\v 13 A khi ri ukiẹkiẹ idiegbe okhọghuo oyẹẹ na olamhẹ, wẹkhi eri u rẹ wẹ shi ekẹ shi akanya ọkhọlọ, ochoghọ, a ri egbe ẹ na Ẹshinẹgba abi eni a she rọte eghuli nyenẹ bhale agbọ, ama a ri idiegbe oyẹẹ na li abi itsua ipfuasẹ.
\v 14 Irari khi olamhẹ ọa ke ya khi ọga ọyẹẹ, itobọ khi ushi ọa kẹ ẹ ke mhẹsẹ na ẹ, ama elemhi okhale oyi Ẹshinẹgba a ke la.
\s1 Ighumha eyi angeli ipfuasẹ a ke khi
\p 
\v 15 Sẹ o ke li mena? Awa ke lamhẹ itobọ khi ushi ọa ke mhẹsẹ ẹ na awa, sẹ ni okhale oyi Ẹshinẹgba? Iiye o!
\v 16 Aa lẹsẹ khi oghumha ọyi emini a suọ esọ ọ na a khi? U dobẹ ya khi oghumha ọyi olamhẹ ni o ri eghuli ẹ bhale, u gbo dobẹ ẹ zẹ isuesọ na Ẹshinẹgba ni o ri ọgbọ ọ bhale angeli ipfuasẹ.
\v 17 Ama awa tse Ẹshinẹgba uwegbe, irari khi ẹghẹghẹ ni o dọsẹ, a kpẹ khi ighumha eyi olamhẹ, ẹghẹghẹ aghọ a ga ri udu oyẹ ẹ nya a suọ esọ na osẹsẹ ni a sẹsẹ ẹ.
\v 18 A she pfuese ẹ olamhẹ, ama ighumha eyi Ẹshinẹgba a ke khi, ni a ke riẹlẹ emini o ghọle Ẹshinẹgba.
\p 
\v 19 Eri mhi ngme ona abi ọgbọ liẹ ngme, itobọ khi aa lolo toto. Abi a kpẹ li ri idiegbe eyẹ ẹ shi ighumha na ikanya ichimhi ali ọkhọlọ, a li lighọ ri egbe ẹ shi ighumha angeli ni o ghọle Ẹshinẹgba, ni o ri ipfuasẹ ẹ bhale.
\v 20 Abi a rọ khi ighumha olamhẹ, aa mhuẹ emini a ri angeli ni o ghọle Ẹshinẹgba riẹlẹ.
\v 21 Ighe eleli ni a mhuẹ oni ẹghẹghẹ shi ikanya ni e ke tigbe ri omama a mu ẹ ena? Emhi eghọghọ eghuli ẹẹ pfi.
\v 22 Ama mena ni a she rọte olamhẹ pfuese ẹ, ni a ke rọ khi ighumha eyi Ẹshinẹgba eghọ, eleli ni a khiẹsẹ, ipfuasẹ o rẹ ẹ ya khuẹ pfuasẹ, o ri agbọ na agbọagbọ ọ na ẹ.
\v 23 Irari khi ifata oyi olamhẹ khi eghuli lọ, ama isomhopfa oyi Ẹshinẹgba agbọ na agbọagbọ lọ rọte obọ oyi iJesu iKirisiti Ọnọmhuẹ oyawa.
\c 7
\s1 Abi a liẹ ngeli elemhi ughuẹ
\p 
\v 1 A lẹsẹ inyọghuo, khi eri mhi nu ẹ ngme abi ẹgbọ ni e lẹsẹ ushi, khi ushi o mhọli ekpabọ shi ọgbọ egbe ini ọni ọgbọ ọ kie da la agbọ ne.
\v 2 Ẹzẹzẹ abi ushi o ngme khi ọkpotso ni ọ la ughuẹ ọa gbudu vu ọdọ li obọ ini ọni ọmọse ọ kie da la agbọ ne, ama khi ini ọ ghu-a oni ushi ọa ke mu ọli.
\v 3 Irarighọ, ini ọ vu ya ngeli na ọmọse ọlese, abi ọdọli ọ li kie la agbọ eghọ, a ya lu ọli ọkiokia. Ama ini ọdọ li ọ ghua, oni ushi oghọ ọa ke mu ọli, ọa ke khi ọkiokia, ini ọ tseku ngeli na ọmọse ọlese.
\v 4 Ighọ o li khi shi ẹ ọ inyọghuo-mhẹ. Idiegbe oyi iKirisiti a ke khi, ẹẹ a she li ghu-a pfa ekpabọ oyi ushi. A she ga li mhọli ẹghẹghẹ ni a rọ mele ọyi ọgbọẹse-a, ikhi ọni a rọte eghuli guise le, ni a mẹ asha ke gbe akanya enete na Ẹshinẹgba.
\v 5 Irari khi abi idiegbe olamhẹ o rọ ọ mhẹsẹ na awa, ighọ ọghuẹmhẹ oyi olamhẹ ni ushi o zese-a o la awa idiegbe gbe akanya, ena e ri awa ngeli angeli ni ọọ pfi eghuli.
\v 6 Ama mena, abi awa rọ she ghu pfa emini e ke kpẹ gẹnọ awa eghọ, a she pfuese awa obọ oyi ushi, ni awa mẹ asha rọte odẹ onogbọ oyi Ayẹmhẹ ke ga, ni ọa ke khi odẹ oyi ushi ni a kẹkẹ.
\s1 Inu-olamhẹ khẹ abọ
\p 
\v 7 Sẹ awa ke ya ngme mena? Olamhẹ oni ushi o ke khi shọ? Iiye o. Egbegbọ lọ khi, mhi aa kha lẹsẹ emini olamhẹ o khi, ini ọa khi ushi lọ. Irari khi mhi aa kha lẹsẹ emini iviẹ shi emhi ọgbọ o khi ini ushi ọa liẹ, “Khi viẹ shi emhi ọgbọ.”\f + \fr 7:7 \ft Li zẹ \fq Okiali 20.17; iDẹut 5.21\f*
\v 8 Rọte oni ushi oghọ, olamhẹ o te mẹ asha guise iwali ọghuẹmhẹ ukphẹ nya ni e la mhẹ egbe le. Ini a rue ushi odẹ-a eri olamhẹ o ghua.
\v 9 Eri mhi kpẹ la agbọ tse abi mhi aa rọ lẹsẹ ushi ne, ama abi ushi o ke rọ bhale, olamhẹ o gbo bhale agbọ, lọli mhi rọ ghua.
\v 10 Mhi mẹ khi ushi ni o kha ri agbọ bhale, khi eghuli o rọ bhẹ.
\p 
\v 11 Olamhẹ o mẹ asha migha rọte ushi di mhẹ. Rọte oni ushi, eghuli o gbe mhẹ.\f + \fr 7:11 \ft Li zẹ \fq Igbae 3.13\f*
\v 12 Abokieli khi, oni ushi o pfuasẹ, omhẹsẹ o pfuasẹ, e migha, e ti.
\p 
\v 13 Eri emini o ti oghọ o ke ri eghuli ghi mhẹ eghọ? Iiye o! Ama ni a rọ lẹsẹ olamhẹ shi olamhẹ o rọ pfi eghuli na mhẹ, rọte emini o ti, ni a bhale ya ẹ khi rọte oni ushi, olamhẹ o mema khi olamhẹ egbegbọ.
\v 14 Irari khi awa lẹsẹ khi ushi emhi Ayẹmhẹ o khi, ama mhẹmhẹ ọgbọ tsẹ, mhi khi ọni a rọ na olamhẹ dẹ.
\v 15 Mhi aa lẹsẹ emini e li mhẹ, irari khi emini mhia nono ni mhi ke riẹlẹ, mhi aa dobẹ riẹlẹ ọli. Ama emini ọa ghọle mhẹ, mhia riẹlẹ.\f + \fr 7:15 \ft Li zẹ \fq iGal 5.17\f*
\v 16 Ini mhi riẹlẹ emini mhi aa nono ni mhi riẹlẹ, mhi lama shi ọ khi ushi o ti.
\v 17 Abi oli khi, ọa ke khi mhẹmhẹ mhia riẹlẹ ọli ama olamhẹ ni o la mhẹ egbe lọ.
\v 18 Mhi lẹsẹ khi emhikhọghuo ni o ti ọa lamhẹ egbe, ikhi idiegbe olamhẹ oyẹmhẹ. Irari khi ini o tseku ghọle mhẹ ni mhi riẹlẹ emini o ti, mhia dobẹ ẹ riẹlẹ ọli.
\v 19 Irari khi emini mhia riẹlẹ ọa khi emini o ti ni mhia nono ni mhi riẹlẹ, ochoghọ onobe ni mhi aa nono ni mhi riẹlẹ, mhi kiele ẹ riẹlẹ.
\v 20 Mena, ini mhia riẹlẹ emini mhi aa nono ni mhi riẹlẹ, ona o rọkhasẹ khi ọa khi mhẹmhẹ mhi riẹlẹ ọli, olamhẹ ni o la agbọ oyẹmhẹ ọọ riẹlẹ oli.
\v 21 Ina o ga limhẹ egbe ẹghẹghẹkpa. Ini mhia nono ni mhi riẹlẹ onete, onobe o nu mhẹ la aghọ.
\v 22 Irari khi ekelemhi udu oyẹmhẹ, ushi oyi Ẹshinẹgba o te ẹ ghọle mhẹ.
\v 23 Ama mhi mẹ khi ushi olese o la mhẹ egbe ẹ gbe akanya, ni o mu okhọli vule shi ushi ni o la mhẹ udu ọ, o rẹmhẹ mele oghumha ushi oyi olamhẹ-a, ni o la mhẹ egbe a gbe akanya.
\v 24 Ọgbọ umẹobinuje nabisẹ mhi fẹ khi ena. Ọghuo ọ ya tsumhi mhẹ idiegbe eghuli ona lasele?
\v 25 Mhi kphẹmhi na Ẹshinẹgba rọte obọ oyi iJesu iKirisiti Ọnọmhuẹ ọyawa.
\p Irarighọ, mhẹmhẹ oyẹmhẹ, oghumha ọyi ushi oyi Ẹshinẹgba mhi khi udu oyẹmhẹ, elemhi idiegbe olamhẹ, mhi khi oghumha ọyi ushi olamhẹ.
\c 8
\s1 Angeli na Ayẹmhẹ
\p 
\v 1 Irarighọ, ipfẹzọ-mu ọa ke la ọ na ẹgbọ ne mie iJesu iKirisiti suọ, ni ẹa kẹ ngeli rọte odẹ olamhẹ, ama eni ẹẹ ngeli rọte odẹ Ayẹmhẹ-nọ-pfuasẹ.
\v 2 Ayẹmhẹ ni o ri agbọ a na awa itobọ khi awa mie iJesu iKirisiti suọ, ọ she taghiẹ mhẹ obọ oyi ushi olamhẹ ali eghuli-a.
\v 3 Emini Ushi oyi iMosisi ọa dobẹ riẹlẹ irari khi idiegbe olamhẹ o mie ọli ekpabọ, Ẹshinẹgba lọlighuo ọ ke ya pfuese awa abi ọ ghie Omi ọli, ni ọ li abi awa ẹgbọ olamhẹ ali ni ọ ya khi iluasobo shi olamhẹ eyawa. Oni idiegbe ọgbọ ni ọni iKirisiti ọ zẹ ọ rọ pfuẹchẹ olamhẹ-a shi idiegbe ọgbọ olamhẹ.
\v 4 Eri Ẹshinẹgba ọ riẹlẹ ona ni ipfuasẹ ni ushi oo nono ni awa mhọli o tsẹ shi awa egbe, ini awa khi kẹ ngeli te odẹ olamhẹ, ama ni awa ke ngeli rọte odẹ Ayẹmhẹ.
\p 
\v 5 Ẹgbọ ni ẹ ngeli rọte odẹ olamhẹ, eri e ri udu shi emini idiegbe oyẹwẹ ọọ nono. Eri ẹgbọ ni ẹẹ ngeli rọte odẹ Ayẹmhẹ, e ri udu shi emini Ayẹmhẹ ọọ nono.
\v 6 Irari khi udu oyi ọgbọ eghuli o tsua. Ama udu ọ riẹlẹ emini Ayẹmhẹ ọ gueyẹ ọli, eri ọ ya la agbọ ọ mhuẹ opfọmhẹ.
\v 7 Ọbe Ẹshinẹgba ọgbọ ọọ khi, ini udu olamhẹ oyọli ọọ mhẹsẹ na li, irari khi ọa ya suọ esọ na Ẹshinẹgba. Irari khi ọa zẹ ni ushi oyi Ẹshinẹgba o mhẹsẹ ke na li, wẹkhi eri ọ́ tigbe ya lama ghue ni ọ mhẹsẹ na li.
\v 8 Ẹgbọ ni idiegbe olamhẹ oyẹwẹ o mhẹsẹ ẹ na, ẹa dobẹ riẹlẹ emini o ghọle Ẹshinẹgba.
\p 
\v 9 Yẹyẹ oyẹ idiegbe olamhẹ ọa ke mhẹsẹ ẹ nẹ ama Ayẹmhẹ o ke mhẹsẹ ẹ nẹ, ini Ayẹmhẹ ọyi Ẹshinẹgba o da la agbọ oyẹ ne. Ọgbọ ni ọa da mhuẹ Ayẹmhẹ oyi iKirisiti ne, ọa khi ọnayọli.
\v 10 Eri-tsẹ khi ini iKirisiti ọ da la agbọ oyẹ ne, idiegbe oyẹ o fu pfa olamhẹ, ayẹmhẹ oyẹ o kie la agbọ irari ipfuasẹ ni awa rọte obọ oyi iKirisiti mhuẹ.
\v 11 Ini Ayẹmhẹ oyi ọni ọ rọte eghuli guise iJesu le o da la agbọ oyẹ ne, lọli ni ọ rọte eghuli guise iJesu le ọ ya rọte Ayẹmhẹ oyọli ni o la agbọ oyẹ ri agbọ na idiegbe ni ọọ ghu oyẹ.\f + \fr 8:11 \ft Li zẹ \fq 1 iKọri 3.16\f*
\p 
\v 12 Irarighọ, inyọghuo-mhẹ, awa mema ya ke ngeli abi ayẹmhẹ Ẹshinẹgba o gueyẹ awa. Awa khi ke ngeli abi o ghọle idiegbe olamhẹ.
\v 13 Irari khi, ini u wa ngeli abi idiegbe olamhẹ o gueyẹ, eri u ya ghu-a, ama ini u wa ngeli abi Ayẹmhẹ o gueyẹ, eri u wa gbe ekpabọ olamhẹ a shi idiegbe oyẹ, u la agbọ.
\v 14 Ẹgbọ ni Ayẹmhẹ oyi Ẹshinẹgba ọ mhẹsẹ ẹ na imi Ẹshinẹgba e khi.
\v 15 Irari khi Ayẹmhẹ ni Ẹshinẹgba ọ rọ nẹ, ọa khi oni o gbolo rẹ khi oghumha ulishi, ama Ayẹmhẹ ni ọ rọ rẹ khi Ọmọ ọyọli u mie. Ọni Ayẹmhẹ ọ ri awa mhuẹ itoto ẹ viẹ lu Ẹshinẹgba, awa lu ọli Itamhẹ, Itamhẹ.\f + \fr 8:15 \ft Li zẹ \fq iMak 14.36; iGal 4.6\f*
\v 16 Ọni Ayẹmhẹ lọlighuo ọ pfi ọtsẹlẹ shi ayẹmhẹ oyawa khi eniyẹ eyi Ẹshinẹgba awa khi.
\v 17 Ayẹmhẹ oyọli ọ zẹ ni awa lẹsẹ khi awa ya nu iKirisiti mhọli okemhi shi emini Ẹshinẹgba ọ rọ shobọ khi lọli ya riẹlẹ. Ẹghẹghẹ aghọ awa nu iJesu mhọli okemhi ufumhi oyọli ini awa li mẹ osoli.\f + \fr 8:17 \ft Li zẹ \fq iGal 4.5-7\f*
\s1 Ufumhi na ogbenakọ
\p 
\v 18 Mhi mẹ ọli mẹ khi osoli ni awa a mẹ memena khi ọa khi oni a rọ khọkhọ emini a rọ ya khasẹ elemhi agbọ oyawa ikpukhokho.
\v 19 Irari khi eri emini Ẹshinẹgba ọ ma nya e ri ikphakpha-egbe migha khẹ ẹghẹghẹ ni Ẹshinẹgba ọ rọ ya ri eni e khi egbegbi imiọli khasẹ.
\v 20 Irari khi emini a ma nya, a rọ mele afuẹ-a, ni ọa khi ọghuẹmhẹ oyẹwẹ, ama abi o li ghọle ọni Ẹshinẹgba lọ, ni ọ rẹwẹ mele afuẹ-a, elemhi irudushi,\f + \fr 8:20 \ft Li zẹ \fq Igbae 3.17-19\f*
\v 21 khi ọ ya tsumhi emini ọ ma nya ini e khi ke kẹ-a ali khi e ya nu imi Ẹshinẹgba kemhi ẹpfua ni o mhọli ufumhi.
\p 
\v 22 Awa lẹsẹ khi emini a ma nya e kiele ẹ lomhẹ memena e la ọtomhẹ, abi ọkpotso ni oku ọọ to.
\v 23 Ọa khi emini a ma wẹwẹghuo tsẹ, ama li shi awa ni awa mie Ayẹmhẹ-nọ-pfuasẹ ni o khi igbaekẹle agbọ onogbọ oyi Ẹshinẹgba. Awa liẹ lomhẹ abi awa li ri ẹloe shi ekẹ ẹ khẹ ogbẹlẹ ni Ẹshinẹgba ọ ya la ukpẹloe ọgbọkpa guele khi imi Ẹshinẹgba awa khi ali ni a rọ ya pfa awa ikẹ-a shi ekẹ.\f + \fr 8:23 \ft Li zẹ \fq 2 iKọri 5.2-4\f*
\v 24 Irari khi rọte irudushi ona a te mie awa pfuese. Eri-tsẹ khi irudushi ni aa mẹ gboo ọa fẹ khi irudushi. Ọghuo ọ gbo ri ẹloe shi ekẹ ẹ khẹ emini ọ she mẹ ẹloe ne?
\v 25 Eri-tsẹ khi ini awa ri udu shi emini awa aa mẹ ne, irabọmudu awa rọ ke ẹ khẹ ọli.
\p 
\v 26 Ighọ Ayẹmhẹ ọ liẹ kpaghiẹ awa obọ umhagbapfo oyawa, Irari khi awa aa lẹsẹ abi a liẹ sọ iromhi, ọni Ayẹmhẹ lọlighuo ọ ri ilomhẹ ẹ sọ iromhi na awa shi emini unu ọa dobẹ ẹ ngme.
\v 27 Ọni Ẹshinẹgba ni ọ́ọ́ mẹ elemhi udu oyi ẹgbọ, ọ́ lẹsẹ usamhi eyi Ayẹmhẹ. Irari khi eri ọni Ayẹmhẹ ọ sọ iromhi na ẹgbọ eyi Ẹshinẹgba abi o li de shi ọghuẹmhẹ oyi Ẹshinẹgba.
\v 28 Awa lẹsẹ khi eri Ẹshinẹgba ọ́ọ́ riẹlẹ emhi nya te odẹ onete na ẹgbọ ni ẹ nono ingme oyọli. Ẹgbọ ni o khia khi ọ lu shi omhẹsẹ oyọli.
\v 29 Eni Ẹshinẹgba ọ she kpẹ lẹsẹ, wẹwẹ ọ zẹ ọda kẹ ni e ya li abi Omi ọli, ni ọni Omi ọli ọ khi ọnododẹ elemhi inyọghuo ebubu.
\v 30 Ighọ eni Ẹshinẹgba ọ zẹ ọda kẹ, wẹwẹ ọ li lu. Eni ọ lu, wẹwẹ ọ li pfa na, eni ọ pfa na wẹwẹ ọ li rọ khi eni e mhuẹ ufumhi onabi oyọli.
\v 31 Abi awa ke rọ mhuẹ ena shi udu oyawa, sẹ awa ke ya sọ shi ena mena? Ini Ẹshinẹgba ọ nu awa la, ọghuo o ya dobẹ mu okhuẹ vule shi awa ọ?
\v 32 Lọli ni ọa to ukphẹ Omi ọli na awa, ni ọ rọli luasobo na awa nya, sẹẹ ọa ya pfo udu gbo ri emhi nya ma ọni Omi ọli na awa?
\v 33 Ọghuo ọ ya gue ingme shi ẹgbọ ni Ẹshinẹgba ọ she zẹ egbe? Ẹshinẹgba luẹghuo ọ pfa na ọgbọ.
\v 34 Ọghuo ọ dobẹ pfa ẹzọ ọ mu ọgbọ? IJesu iKirisiti luẹghuo lọ, ọni ọ ghua. O gbo dọsẹ aghọ, Ọni a guise le bhale agbọ, mena ọ shitọ obọ ita oyi Ẹshinẹgba, ọ sọ iromhi ẹ na awa.
\v 35 Ọghuo ọ ke dobẹ ya vasẹ awa rọte inono ni iKirisiti ọ nono awa lasele? Osoli abi khi ọmunu abi okhọli ni a mu vule shi awa ọ o ya dobẹ? Abi khi okiamhi abi khi umha mẹ sọ lọ, abi khi ini i igbe-a tsekha deba lọ?
\v 36 Abi a li kẹkẹ ọli shi ebe-no-pfuasẹ, khi,
\q1 “Itobọ oyẹẹ anye rọ
\q1 la okhẹna eghuli ẹlẹkpa,
\q2 a ri anye khọkhọ
\q2 isumha ni a ya gbolo a.\f + \fr 8:36 \ft Li zẹ \fq Iwolo 44.22\f*”
\m 
\v 37 Iiye, abi a riẹ mẹ eni emhi enana nya, anye fu dọsẹ ọni ọ khọli mu ọ le, rọte obọ oyi ọni ọ nono ingme oyanye.
\v 38 Irari khi mhi mẹ ọli mẹ khi emhikhọghuo ọa la agbọ ona, eghuli wẹkhi agbọ ilala, wẹkhi igẹni wẹkhi iyẹmhẹ ọkphaghiẹ ali emini e la irarogbe ẹ mhẹsẹ shi agbọ ni awa la memena okekhi agbọ ni o ke ẹ bhale wẹkhi ekpabọ,
\v 39 wẹkhi iyagha ali ilimhi, wẹkhi emhikhọghuo ni a ma, o dobẹ ya vasẹ awa rọte inono ni Ẹshinẹgba ọ nono awa rọte iJesu ọyawa lasele.
\c 9
\s1 Uzẹmhi ni Ẹshinẹgba ọ zẹ ẹgbọ iZirẹni
\p 
\v 1 Egbegbi ingme mhia ngme itobọ khi ọnayi iKirisiti mhi khi. Ọa khi ẹgbhọli mhia lo. Udu oyẹmhẹ o pfi ọtsẹlẹ shi ọ elemhi Ayẹmhẹ-nọ-pfuasẹ,
\v 2 ini mhiẹ khi mhi mhọli oya ali udu ialamhẹ ni ọa mhuẹ ukpẹsẹ,
\v 3 na ẹgbọ eyẹmhẹ ni anye khi ẹgbọ eghuo ali ọlia eghuo. Itobọ oyẹwẹ, eri mhia liẹ khi Ẹshinẹgba ọ kha pfi unu na mhẹ ali khi a kha rue mhẹ ikugbe ni mhi kugbe iKirisiti ọ le, ini lọli rẹwẹ mhọli imiepfuese.
\v 4 Wẹwẹ e khi imimi iZirẹni ni Ẹshinẹgba ọ zẹ, ni ọ rọ khi imi ọli, ọ ri ufumhi oyọli khasẹ wẹ, ọ nu wẹ riẹlẹ ilama kugbe, ọ ri ushi oyọli na wẹ. Wẹwẹ e mhọli egbegbi ugamhi, e she mie ishobọ oyi Ẹshinẹgba.\f + \fr 9:4 \ft Li zẹ \fq Okiali 4.22\f*
\v 5 Wẹwẹ e mhọli eni egbhali ena ẹlẹlẹ ni a suọ eko, ni e gba ushishi Iburu ekẹ le. Wẹwẹ e li khi itita iKirisiti. Ẹshinẹgba ni ọọ mhẹsẹ na emhikpa, ọ khi ọni áá kuẹghiẹ agbọagbọ.
\p 
\v 6 Mhi aa liẹ khi ishobọ ni Ẹshinẹgba ọ shi, khi, o fia kua. Irari khi ọa khi ẹgbọ ni e rọte iZirẹni lasele nya, e khi ẹgbọ eyi Ẹshinẹgba.
\v 7 Wẹkhi imimi Aburaamu nya e khi egbegbi imi Aburaamu. Ẹshinẹgba ọ gueyẹ Aburaamu khi, “Imimi Aziki a ya leli shi eni u bia.”\f + \fr 9:7 \ft Li zẹ \fq Igbae 21.12\f*
\v 8 Onana o guele khi eniyẹ ni ọ bia elemhi ọghuẹmhẹ idiegbe nya ẹa khi imi Ẹshinẹgba. Ama eniyẹ ni a bia rọte ishobọ onayi Ẹshinẹgba wẹwẹ a leli shi egbegbi imimi Aburaamu.
\v 9 Irari khi ishobọ onayi Ẹshinẹgba khi, “Ẹghẹghẹ ni ọ rọshi ekẹ o kha da ramhi ne, mhi ya ri ishobọ oyẹmhẹ tsẹ, iSera ọ bia ọmọ ọmọse.”\f + \fr 9:9 \ft Li zẹ \fq Igbae 18.10\f*
\p 
\v 10 Ọa pfo ghọ. Irari khi itsema emọse eyi iRebeka, ita ọghuo ọ bia wẹ ikhi Aziki itita awa.
\v 11-12 Ọgbọ a bia itsema ena ne wẹkhi eri e lẹsẹ ingme e riẹlẹ onete ali onobe ne, ni Ẹshinẹgba ọ rọ she gueyẹ inyẹwẹ iRebeka khi, “Ọnọgbhali ọ ya ke ga ọnikeke.” Eri Ẹshinẹgba ọ riẹlẹ ona rọkhasẹ khi, uzẹmhi ni lọli ẹ zẹ ọgbọ ni ọ khi emini ọ ya khi elemhi agbọ, khi ọa khi itobọ akanya ni ọ gbe ama abi o ghọle Ẹshinẹgba ọ li lu ọli.\f + \fr 9:11-12 \ft Li zẹ \fq Igbae 25.23\f*
\v 13 Abi Ebe-no-pfuasẹ o ngme ni ọọ, “IGiekọpu mhi nono dọsẹ iSọ.”\f + \fr 9:13 \ft Li zẹ \fq iMala 1.2-3\f*
\p 
\v 14 Sẹ awa kẹ ngme mena? Khi Ẹshinẹgba ọọ zọlọ? Iiye o, ọa khi ighọ kpa!
\v 15 Irari khi ọ gueyẹ iMosisi ọọ li,
\q1 “Mhi ya mhọli ilẹlemhi na
\q1 ọni mhi ya mhọli ilẹlemhi na,
\q2 mhi viẹ osue na
\q2 ọni mhi ya viẹ osue na.”\f + \fr 9:15 \ft Li zẹ \fq Okiali 33.19\f*
\m 
\v 16 Itobọ ighọ, ọa khi abi o ghọle ọgbọ wẹkhi emini ọgbọ ọ riẹlẹ ama rọte ilẹlemhi oyi Ẹshinẹgba.
\v 17 Irari khi Ebe-no-pfuasẹ o ngme na shi iFero egbe, ọọ li, “Itobọ ona mhi rọ rẹ khi oghie ni mhi rọte emini mhi ya li ẹ ri ekpabọ eyẹmhẹ khasẹ, ni mhi rọ zẹ agbọ nya lẹsẹ eva oyẹmhẹ.”\f + \fr 9:17 \ft Li zẹ \fq Okiali 9.16\f*
\v 18 Irarighọ, eri Ẹshinẹgba ọọ mhọli ilẹlemhi na ọni ọ ghọle ọli, ọ zese ọni ọ ghọle ọli udu-a.
\p 
\v 19 U dobẹ ya mhila mhẹ ogbọ ona, “Elọ o zẹ ni Ẹshinẹgba ọ rọ kiele ẹ mẹ umhaguẹli oyawa shọ, aborọkhia khi lọli ọ ri awa ngeli abi o ghọle ọli? Irari khi ọgbọkhọghuo ọ dobẹ ya nu Ẹshinẹgba khẹ abọ?”
\v 20 Ama ọghuo u khi, yẹyẹ ọgbọ ni gbudu ya mie Ẹshinẹgba unu? Emini a ma o dobẹ ya liẹ ọni ọ ma li, “Elọ o zẹ ni u rọ lina ma mhẹ?”\f + \fr 9:20 \ft Li zẹ \fq Aza 29.16; 45.9\f*
\v 21 Ọmekhe ọa fẹ mhuẹ afu ni ọ rọ ri ekẹ ẹmẹ ẹ ma emini o ghọle ọli? Ọ kha ma eghuo shi eni a rọ riẹlẹ emini e mu ẹloe, ọ manọ elese shi ni a rọ riẹlẹ emini a mẹ kpa.
\p 
\v 22 Ighọ li khi emini Ẹshinẹgba ọ riẹlẹ. Aboriẹkhia khi ọ mhọli afu ni ọ kha rọ ri ofu ali ekpabọ oyọli khasẹ ẹgbọ ni e kha pfua, ni ọ mẹ ofu oyẹwẹ eghọ, ama eri ọ kie mhuẹ irabọmudu na wẹ.
\v 23 Ilẹlemhi ni ọ mhọli na ẹgbọ ni ọ zẹ, ikhi ẹgbọ ni e ya mhọli okemhi ufumhi oyọli, ọ rọ ri abi ufumhi oniẹmhi oyọli o li khasẹ.
\v 24 Li shi awa, eni ọ li lu. Ọa khi ẹgbọ iJu tsẹ ama shi ẹgbọ iJẹta.
\v 25 Abi ọ ngme shi ebe Osia ni ọ,
\q1 “Ẹgbọ ni ẹa khi eyẹmhẹ,
\q2 mhi ya lu wẹ ẹgbọ eyẹmhẹ.
\q1 Ushishi ni mhi aa
\q2 nono ingme oyẹwẹ,
\q1 mhi ya lu,
\q2 ‘Ẹgbọ ni mhi nono.’ ”\f + \fr 9:25 \ft Li zẹ \fq Osia 2.23\f*
\m 
\v 26 Ali khi,
\q1 “A ya mẹ khi,
\q1 ashini a ga la liẹ wẹ,
\q2 ‘Aa khi ẹgbọ eyẹmhẹ,’
\q1 aghọ a gbo la lu wẹ,
\q1 ‘Imi Ẹshinẹgba ni ọ la ọ.’ ”\f + \fr 9:26 \ft Li zẹ \fq Osia 1.10\f*
\p 
\v 27 Azaya o ngme ingme
\q1 oyi iZirẹni lasele gboo, khi,
\q1 “Ini o tseku khia khi
\q1 ẹgbọ iZirẹni e bu abi ekhashẹ
\q1 ne la okẹ oniẹmhi,
\q2 ikuku ẹgbọ ọ a ya tsumhi.
\q1 
\v 28 Irari khi Ẹshinẹgba ọ ya
\q2 ri inyanya sọ ẹzọ oyọli
\q2 ekẹ agbọ-a zeghele.”\f + \fr 9:28 \ft Li zẹ \fq Aza 10.22-23\f*
\p 
\v 29 Ẹzẹzẹ abi Azaya ọ kpẹ li ngme ọli khi:
\q1 “Ini Ẹshinẹgba ni ọ
\q1 mhẹsẹ shi emhi nya
\q2 ọa kẹsẹ imi-imi le na awa lọ,
\q1 a kha li na awa osoli
\q2 abi ẹgbọ iSodomu,
\q1 a pfuse awa abi ẹgbọ iGomora.”\f + \fr 9:29 \ft Li zẹ \fq Aza 1.9\f*
\s1 Umha-miesuọ oyi ẹgbọ iZirẹni
\p 
\v 30 Sẹ awa ke ya ngme? Khi ẹgbọ iJẹta ni ẹa na khu ipfuasẹ, khi a pfa na rọte irudunga,
\v 31 ama ẹgbọ iZirẹni ni e na khu ushi iguẹ-ngeli, ẹa kie tẹ ọ?
\v 32 Sẹẹ ọ li khi ighọ? Itobọ khi ẹa rọte irudunga na khu ọli, ama e rọte odẹ ikanya khu ọli. E kholo awẹ shi, “ẹchẹ ọzuodẹ.”
\v 33 Abi Ebe-no-pfuasẹ o ngme, ni ọọ, “Bino, mhi tsua ẹchẹ shi iZayọ ni o ya ri ẹgbọ kholo awẹ. Ẹchẹli ni o ya rẹ wẹ de. Ama ọni ọ da mie ọli suọ ne, ọa ya mẹ omama.”\f + \fr 9:33 \ft Li zẹ \fq Aza 28.16\f*
\c 10
\p 
\v 1 Inyọghuo-mhẹ, emini ẹ ghọle udu oyẹmhẹ ali olema ni mhia lema Ẹshinẹgba khi, ni a bhale ya ẹ khi ẹgbọ iZirẹni eyẹmhẹ e khi eni a mie pfuese.
\v 2 Mhi pfi ọtsẹlẹ shi ọ khi e mhuẹ ọmuegbe shi ugamhi oyi Ẹshinẹgba. Ama egbegbi ilẹsingme ọa la ọmuegbe oyẹwẹ.
\v 3 Aborọkhia khi ẹa lẹsẹ ipfuasẹ ni o rọte obọ oyi Ẹshinẹgba bhale, ni e rọ nono abi e li ya ri oyẹwẹ kọ eghọ, eri ẹa ri egbe wẹ na ipfuasẹ oyi Ẹshinẹgba.
\v 4 Irari khi iKirisiti ọ ri emini ushi o ngme nya gba pfo, ni o zẹ khi Ẹshinẹgba ọ pfa na ọgbọkpa ni ọ miesuọ.
\s1 Imiepfuese, oyi ọgbọkpa lọ
\p 
\v 5 IMosisi ọ lina gue ọli le emini ipfuasẹ ushi o khi, ni ọ rẹ, “Ọni ọ da ri ushi nya gbe ne, ọ ya la agbọ.”\f + \fr 10:5 \ft Li zẹ \fq iLẹv 18.5\f*
\v 6 Ama eri ipfuasẹ ni o rọte irudunga bhale ọọ, “Khi la ekelemhi udu oyẹ liẹ, ‘Ọghuo ọ ya nga iloghie?’ ” (Ni ọ ya rue iKirisiti tiemhile.)
\v 7 “Okekhi eri u wẹ, ‘Ọghuo ọ ya tiemhi ilimhi na ningọlọ?’ ” (Ni ọ ya rue iKirisiti rọte eghuli ngale.)
\v 8 Abi o ngme na: “Ungmemhi oyi Ẹshinẹgba o la mama ẹ. O lẹ unu, o lẹ udu,” ikhi ungmemhi irudunga ni anye rọ ọ tse abọ.\f + \fr 10:8 \ft Li zẹ \fq iDẹut 30.12-14\f*
\v 9 Ini u ri unu oyẹ ẹ khi, “IJesu ọ khi Ọnọmhuẹ,” ni u rọ miesuọ shi udu oyẹ khi Ẹshinẹgba ọ rọte eghuli guise ọli le, a ya mie ẹ pfuese.
\v 10 Irari khi udu ọgbọ ọ rọ miesuọ ni a rọ pfa na li, ali khi unu ọgbọ ọ rọ ngme lasele ni ọ rọ mhuẹ imiepfuese.
\v 11 Abi Ebe-no-pfuasẹ o ngme, ni ọọ, “Ọnini ọ da regbenga li ne, ọa tigbe ya mẹ omama.”\f + \fr 10:11 \ft Li zẹ \fq Aza 28.16\f*
\v 12 Ọgbọkpa ona o nu ngme, irari khi ikhiọda ọa la shi ẹgbọ iJu ali ẹgbọ iJẹta ọ. Ẹshinẹgba ọ ga khi Ọnọmhuẹ ọyi ẹgbọ nya, ọọ khivọsẹ egbegbọ na ọni ọ da lu ọli.
\v 13 Irari khi, “Ọnini ọ da lu eva oyi Ọnọmhuẹ ọ ya khi ọni a mie pfuese.”\f + \fr 10:13 \ft Li zẹ \fq iJọẹ 2.32\f*
\p 
\v 14 Ama sẹ e li ya lu ọli ini ẹa mie ọli suọ? Sẹ e li ya mie ọli suọ ini ẹa suọ oni ungmemhi? Sẹ e li ya suọ ini a ri oni ungmemhi tsabọ.
\v 15 Sẹ a li ya ri oni ungmemhi tsabọ ini ọgbọ a ghie eni ẹẹ tsabọ fiẹ lase? Abi Ebe-no-pfuasẹ o ngme ọ khi, “Eri ibhale oyi ẹgbọ ni e tsua usomhi onete bhale o ri oghẹlẹ bhale!”\f + \fr 10:15 \ft Li zẹ \fq Aza 52.7\f*
\p 
\v 16 Ama ẹgbọ iZirẹni nya ẹa mie oni usomhi onete ona suọ. Azaya ọ liẹ, “Ẹshinẹgba, ọghuo ọ mie usomhi oyi anye suọ?\f + \fr 10:16 \ft Li zẹ \fq Aza 53.1\f*
\v 17 Ighọ irudunga o li rọte ini ọgbọ ọ suọ oni usomhi ẹ bhale, ali khi usomhi oyi ingme iKirisiti irọ-tse abọ a te ẹ suọ oni usomhi.
\v 18 Ama mhi mhila, eri aa suọ oni usomhi? Eeli, e suọ.
\q1 “Uruli oyẹwẹ o she ramhi
\q1 ashakpa ekẹ agbọ,
\q2 ungmemhi oyẹwẹ
\q2 o ramhi ukpẹsẹ agbọ.”\f + \fr 10:18 \ft Li zẹ \fq Iwolo 19.4\f*
\m 
\v 19 Mhi gbo mhila, Eri ọa lo ẹgbọ iZirẹni esọ? Ododẹ IMosisi ọ liẹ,
\q1 “Mhi ya ri ẹgbọ eyẹmhẹ
\q1 ke kpe ofuma oyi ẹgbọ
\q1 ni ẹa khi eyẹmhẹ ne,
\q2 Mhi ya rẹ ẹ mhuẹ iyese elemhi-a
\q2 deba ushishi ni ẹa lẹsẹ mhẹ ne.”\f + \fr 10:19 \ft Li zẹ \fq iDẹut 32.21\f*
\m 
\v 20 Eri Azaya ọ ri igbeudu ngme ọli khi,
\q1 “Ẹgbọ ni ẹa rọshẹka
\q1 nono mhẹ e mẹ mhẹ.
\q2 Mhi ri egbe mhẹ khasẹ
\q2 eni ẹa mhila ogbọ mhẹ.”\f + \fr 10:20 \ft Li zẹ \fq Aza 65.1\f*
\q1 
\v 21 Ama abi ọ ngme shi
\q1 ẹgbọ iZirẹni egbe khi,
\q1 “Ogbẹlẹ nya mhi nise obọ oyẹmhẹ-a
\q2 na ẹgbọ ni ẹa ya suọ esọ,
\q2 ni ẹa lama mu pfi.”\f + \fr 10:21 \ft Li zẹ \fq Aza 65.2\f*
\c 11
\s1 Ikhẹrẹmhi ẹgbọ iZirẹni ni e kpọle
\p 
\v 1 Mhiẹ i. Eri Ẹshinẹgba ọ kie ẹgbọ eyi lọlighuo? Iiye e! Mhẹmhẹ oyẹmhẹ ọngi iZirẹni mhi khi. Omi-omi Aburaamu, Mhi rọte ẹdẹli oyi iBẹjami lasele.\f + \fr 11:1 \ft Li zẹ \fq iFili 3.5\f*
\v 2 Ẹshinẹgba ọa kie ẹgbọ eyọli ni ọ rọte igbaekẹle zẹ. Waa lẹsẹ abi Ebe-no-pfuasẹ o ngme shi ashini Elaja ọ rọ sọ iromhi ri awọlọ gueyẹ Ẹshinẹgba emini ẹgbọ iZirẹni ẹ riẹlẹ?
\v 3 Ni ọ rẹẹ, “Ẹshinẹgba, e she gbolo emekẹguele eyẹ-a, e guọghọ itẹtẹ eyẹ-a. Mhẹmhẹ-ghuo kpele mhi ke kpọle, e gbolo ẹ nono ni e gbe mhẹ-a.”\f + \fr 11:3 \ft Li zẹ \fq 1 Ighie 19.10,14\f*
\v 4 Sẹ Ẹshinẹgba ọ sọ li? Eri ọọ Elaja, “Mhi kẹsẹ emọse agbẹlẹ ishilua le ni ẹa lama nyẹsẹ ukhomhi na olitsa iBali.”\f + \fr 11:4 \ft Li zẹ \fq 1 Ighie 19.18\f*
\v 5 Ighọ o kie li khi memena. Itobọ khi ẹgbọ iZirẹni e la ọ ni e kiele ẹ suọ esọ na Ẹshinẹgba irari okhale oyọli ni ọ rọ zẹ wẹ.
\v 6 Ini oni uzẹmhi o khi itobọ okhale, ọa ke khi itobọ ikanya. Ini o khi irari ikanya lọ, okhale ọa ke khi egbegbi okhale.
\v 7 Elọ a ke mẹ, Ẹgbọ iZirẹni ẹa mẹ emini e nono. Ikuku ẹgbọ ni Ẹshinẹgba ọ zẹ, wẹwẹ e mẹ emini e nono. Eni e kpọle e le esọ shi ulumhi ni Ẹshinẹgba ọ lu wẹ,
\v 8 Abi Ebe-no-pfuasẹ o ngme khi,
\q1 “Ẹshinẹgba o rẹ wẹ
\q2 lesẹ-a ningọlọ.
\q1 Alo eyẹwẹ e zuse
\q2 ni ẹa zẹ wẹ mẹ ekẹ,
\q1 ali esọ eyẹwẹ e zuse
\q2 ni ẹa zẹwẹ ke rọ ọ suọ esọ,
\q1 ramhi ogbe-namo.”\f + \fr 11:8 \ft Li zẹ \fq iDẹut 29.4; Aza 29.10\f*
\q1 
\v 9 IDefidi ọ̀ọ̀ liẹ,
\q1 “Ẹshinẹgba ọ ka zẹ
\q2 ni akhe ni e nye,
\q1 e mu okhọli vule shi wẹ ọ.
\q2 Ni o rẹwẹ kholo awẹ,
\q2 ni o nasẹ wẹ.
\q1 
\v 10 Alo eyẹwẹ e ka zuse
\q1 ini e khi mẹ ekẹ.
\q2 Ugugu oyẹwẹ o nyẹsẹ
\q2 abi ighumha, agbọagbọ.”\f + \fr 11:10 \ft Li zẹ \fq Iwolo 69.22-23\f*
\s1 Iguabọ ni a toma ọara
\p 
\v 11 Mhi gbo mhila, eri e kholo awẹ ini e de, ni ẹa ke dobẹ ya vule? Iiye e! Ama itobọ olamhẹ ni e lamhẹ lọ. Imiepfuese o she bhale deba ẹgbọ iJẹta, ini ẹgbọ iJu e ba ke kpe ofuma.
\v 12 Mena, ini o khia khi a khivọsẹ na ẹgbọ iJẹta itobọ khi ẹgbọ iJu ẹa lama mie imiepfuese ni Ẹshinẹgba ọ rọ ghi wẹ. Sa ọ ghue, abi ikhivọsẹ ni agbọ nya e ya mhọli o ke bẹshi ya fu ramhi, ini eni ẹgbọ iJu e lama mie oni imiepfuese ikpukhokho.
\p 
\v 13 Mena, ẹẹ ẹgbọ iJẹta mhi nu ẹ ngme. Aborọkhia khi eri Ẹshinẹgba ọ zẹ mhẹ mhi khi aghiusomhi na kẹẹ na ghie ghi ẹgbọ iJẹta eghọ, eri akanya oyẹmhẹ o mu mhẹ egbe.
\v 14 Eri mhia riẹlẹ ona ini mhi ri ẹgbọ iJu eyẹmhẹ ke kpe ofuma, isheghọ ni mhi dobẹ tsumhi eghuo elemhi wẹ.
\v 15 Ini ukiẹmhi ni a kie ẹgbọ iZirẹni o ri ẹgbọ na agbọ enekpọle nu Ẹshinẹgba rọ riẹlẹ, sẹẹ o ke bẹshi ya li ti ramhi, ini eni iZirẹni e ke mie ọni Ẹshinẹgba suọ? Eri o ya li abinẹ khi a rọte eghuli guise ọgbọ le.
\v 16 Ini a ri ukiẹkiẹ ibulẹdi onododẹ mele oni o pfuasẹ-a irari khi a rọli ga Ẹshinẹgba, oni ibulẹdi nya oni o pfuasẹ o ke khi. Ini imhili ọọra o pfuasẹ oni ọọra nya o ya khi oni o pfuasẹ.\f + \fr 11:16 \ft Emini a ri onana ngme khi: Ini Aburaamu ali Aziki ali iGiekọpu ni e khi itititawa e da khi eni e pfuasẹ, eni e pfuasẹ awa imimi wẹ e li khi.\f*
\p 
\v 17 Ama eri ẹẹ ẹgbọ iJẹta a li abi uguabọ ọọra olivu onokpo ni a khi gbọsẹ shi idiegbe oyi egbegbi ọọra olivu ni a rọte ekẹ kuẹlẹ vule. Eri ẹẹ a ke ya migha ashini iguabọ eni a rọte oni egbegbi ọọra olivu kanọ kua. Itobọ ona, ikhivọsẹ ni e rọte imhili oni ọọra olivu ẹ lasele ẹẹ a ke rọ li agbọ.
\v 18 Itobọ ighọ, a khi ri ẹloe gbe eni iguabọ ni a kanọ-a eghọ. Elọ o rẹ ẹ ya ke vuse ike? Iguabọ tsẹ a lẹsẹ khi. Aa mu imhili mhuẹ, imhili e mu ẹ mhuẹ.
\v 19 A dobẹ ya mẹ khi a sa khi eri a kanọ eni iguabọ eghọ kua ni a ba mẹ asha to-ẹoli wẹ.
\v 20 Igẹsikia onana o khi. Eri a kanọ wẹ-a irari khi ẹa mhọli irudunga. Ẹẹ la ashini a la irari khi a mhọli irudunga. Ama a khi zẹ ni a ke vuse ike shi ona, ochoghọ a zẹ ni ulishi o ke mu ẹ.
\v 21 Irari khi ini Ẹshinẹgba ọ kholo ẹgbọ iJu ni e khi egbegbi iguabọ kua, ọ mema ya li dobẹ kholo ẹ kua.
\p 
\v 22 Ama a sa abi isomhelemhi ali izese-inmge-a oyi Ẹshinẹgba o li. Ọọ zese ingme-a deba eni e de ọ le, ama o somhi elemhi ẹ, a kha da la angeli isomhelemhi ne, ọ ti elemhi ẹ ini a da suọ esọ na li. Ini ọa khi ighọ eri ọ ya khi ẹ kua.
\v 23 Ini eni ẹgbọ iJu e lase umha miesuọ oyẹwẹ le, a ya gbo gbọsẹ wẹ shi egbegbi oni ọọra olivu. Ẹshinẹgba ọ dobẹ ya gbo gbọsẹ wẹ shi ashini e kpe la.
\v 24 Eri ẹẹ ẹgbọ iJẹta a li abi uguabọ ọọra olivu onokpo na ifuegua. Ini Ẹshinẹgba ọ lina riẹlẹ emini aa ya riẹlẹ, ni ọ rọ gbọsẹ ẹ shi egbegbi ọọra olivu. Ona o li abi ẹgbọ iJu. A lẹsẹ khi ọni Ẹshinẹgba ọ ya gbo dobẹ gbọsẹ oni uguabọ oyi egbegbi olivu ni a kanọ kwa, shi oni olivu ni a kpẹ te kanọ wẹ kwa.
\s1 A ya mie ẹgbọ iZirẹni pfuese ikpukhokho agbọ
\p 
\v 25 Mhia nono ni a lẹsẹ igẹsikia oyi osheli ni o la akaghọ inyọghuo. Ini a khi dabi khi a lẹsẹ ingme. Oni osheli khi, umha suọ esọ oyi ẹgbọ iJu ọa khi ona agbọagbọ. Ama oni umha-suesọ oyẹwẹ o ya laọ ramhi ni ẹgbọ iJẹta otuongmẹ ni Ẹshinẹgba ọ nono ni e bhale deba li, e rọ gba pfo.
\v 26 Ona o khi abi a li ya tsumhi ẹgbọ iZirẹni nya. Abi Ebe-no-pfuasẹ o ngme, khi,
\q1 “Ọmiepfuese ọ ya rọte
\q1 iZayọ bhale,
\q2 ọ ya khu irẹloegbe Ẹshinẹgba
\q2 idiegbe imimi iGiekọpu-a.\f + \fr 11:26 \ft Li zẹ \fq Aza 59.20\f*
\q1 
\v 27 Onana khi ilama-kugbe
\q1 ni mhi mhọli na wẹ,
\q2 oni ẹghẹghẹ ni mhi rọ ya rue
\q2 olamhẹ oyẹwẹ odẹ-a.”\f + \fr 11:27 \ft Li zẹ \fq iJere 31.33-34\f*
\p 
\v 28 Itobọ khi ẹgbọ iJu e kie usomhi onete ona, e rọ khi ebe Ẹshinẹgba, itobọ onete oyẹẹ ni aa khi iJu. Ama itobọ ititita wẹ, e khi ọmọle Ẹshinẹgba itobọ khi ọ zẹ wẹ.
\v 29 Irari khi Ẹshinẹgba ọa ya mu udu pfi shi isomhopfa ni ọ rọ na ọgbọ ali uzẹmhi ni ọọ zẹ ọgbọ.
\v 30 Ẹzẹzẹ abi ẹẹ ẹgbọ iJẹta a kpẹ riẹlẹ umha-suesọ deba Ẹshinẹgba ẹghẹghẹ ni o dọsẹ, a li mie ilẹlemhi oyi Ẹshinẹgba irari umha-suesọ ni ẹgbọ iJu e riẹlẹ.
\v 31 Ẹzẹzẹ abi ẹẹ ni aa khi iJu a li mie ilẹlemhi itobọ khi ẹgbọ iJu e khi ena umha-suọesọ memena, ighọ wẹwẹ e ke ya li mie ilẹlemhi.
\v 32 Irari khi eri Ẹshinẹgba ọ ri ẹgbọ nya khili ighumha umha-suesọ ni ọ ba mhọli ilẹlemhi na wẹ nya.
\s1 A kuẹghiẹ Ẹshinẹgba
\q1 
\v 33 Ọghuo ọ dobẹ ya mhẹsẹ
\q2 abi ẹpfue, ali ẹgbhali ali ilẹsẹ
\q2 oyi Ẹshinẹgba o limhi ramhi?
\q1 Ọghuo ọ dobẹ ya lẹsẹ
\q2 emini o la li udu ni ọ ya riẹlẹ,
\q1 ali ni ọ dobẹ ya guanọ odẹ eyọli?\f + \fr 11:33 \ft Li zẹ \fq Aza 55.8\f*
\q1 
\v 34 “Ọghuo ọ she lẹsẹ
\q2 udu oyi Ọnọmhuẹ?
\q2 Ọghuo o dobẹ ya ye ọli ude?”\f + \fr 11:34 \ft Li zẹ \fq Aza 40.13\f*
\q1 
\v 35 “Ọghuo ọ ri ongmomhi
\q2 na Ẹshinẹgba ghue,
\q2 ni ọ ya nyenẹ egbe fali ọli luẹ?”\f + \fr 11:35 \ft Li zẹ \fq iJobu 41.11\f*
\q1 
\v 36 Irari khi lọli ọ ma emhi nya,
\q2 obọ oyọli e te la agbọ.
\q2 E la ọ gbo na li.
\q1 Lọli a ri ufumhi a na agbọagbọ. Atsẹ\f + \fr 11:36 \ft Li zẹ \fq 1 iKọri 8.6\f*
\c 12
\s1 Iluasobo ni o la agbọ
\p 
\v 1 Itobọ ighọ, inyọghuo-mhẹ, mhi ri itobọ ilẹlemhi oniẹmhi ni Ẹshinẹgba ọ mhuẹ na awa lema ẹ, a ri idiegbe eyẹ ẹ na Ẹshinẹgba, abi iluasobo ni o kie la agbọ, ni o pfuasẹ, ni o ti Ẹshinẹgba ẹloe. Onana o khi egbegbi ugamhi na elemhi ayẹmhẹ ni a dobẹ ya ga.
\v 2 A khi zẹ ni ingeli eyẹ ẹ ali eyi ẹgbọ na agbọ e li abeghuo. Ama a zẹ ni Ẹshinẹgba ọ mu udu eyẹẹ pfi mele udu enegbọ-a. Ẹghẹghẹ aghọ a ya dobẹ lẹsẹ abi ọghuẹmhẹ oyi Ẹshinẹgba o li, a lẹsẹ emini o ti, ni o gba pfo ni o ri egbe ẹ mu Ẹshinẹgba.
\p 
\v 3 Itobọ okhale ni Ẹshinẹgba ọ rọ na mhẹ, mhi rọ gue ọli ẹ yẹ ẹ nya, a khi ke ti egbe ẹ nga dọsẹ ashini á fu ramhi. Ochoghọ, a ke ri ukpẹloe itiegbe-tiemhi ekẹ bino egbe ẹ, ni o de shi abi irudunga ni Ẹshinẹgba ọ rọ nẹ o fu ramhi.
\v 4 Ẹzẹzẹ abi awa li zẹ idiegbe oghuo ni o mhuẹ iguabọ ọdọda ni e bu, ni ẹa ya gbe akanya oghuo,
\v 5 ighọ o li khi elemhi iKirisiti ni awa rọte idiegbe oghuo lasele, ni uguabọ ọgbọgbọ ali enekpọle nya e li kugbe iguabọ enekpọle.\f + \fr 12:5 \ft Li zẹ \fq 1 iKọri 12.12\f*
\v 6 Isomhopfa ọdọda Ẹshinẹgba ọ rọ na awa abi ọ ri ekpabọ na awa ramhi. O kha khi isomhopfa imekẹguele ọgbọ ọ mhọli, ọ rọli ke gbe akanya ni o de shi irudunga ni awa nya awa mhọli.
\v 7 Ini o khi oyi oni a rọ ọ ga ẹgbọẹse, ọ ke ga. O kha ke khi oyi oni a rọ ọ sẹsẹ, ọ ke sẹsẹ.
\v 8 O kha khi oyi irudushi ẹgbọ ọ o khi ni ọ mie, ọ ke ri udu shi ẹgbọ ọ. Ini oni a rọ ọ kpaghiẹ ẹgbọẹse obọ, ini e mhọli emini o to wẹ lọ, ọ ke rue obọ-a na ẹgbọ, abi o li pfo ọli udu. Ini oni a la ralo ke mhẹsẹ na ẹgbọ lọ, ọ ri ẹloe shi omhẹsẹ ke mhẹsẹ, o kha khi oyi ilẹlemhi, o ri egbe mu ọli ke riẹlẹ.\f + \fr 12:8 \ft Li zẹ \fq 1 iKọri 12.4-11\f*
\s1 Inono
\p 
\v 9 Rọte ekelemhi udu oyẹ ke riẹlẹ inono. A kie emhi onobe, a mu eminete mhuẹ egbegbọ.
\v 10 A nono ingme oyi egbe ẹ egbegbọ, abi ọgbọ ali inyọghuo. A mhuẹ ekpẹ na ẹgbọ elese ke dọsẹ abi u li mu ekpẹ na egbe ẹ.
\v 11 Khi li ọwaza akanya igbegbe, ama ri ọmuegbe elemhi ayẹmhẹ ke ga Ọnọmhuẹ.
\v 12 Zẹ ni irudushi ni u mhuẹ o ri egbe ke muẹ. Mhuẹ irabọmudu ini u mhuẹ osoli, ke lema ẹghẹghẹ kpa.
\v 13 Ke kpaghiẹ inyọghuẹ ni e mhuẹ ọtomhẹ obọ. Ke mu ẹgbọ epfẹse.
\p 
\v 14 Ke sọ iromhi ikhivọsẹ na ẹgbọ ni e mu okhọli ẹ vule shi ẹ ọ. Ke khivọsẹ na ẹgbọ, khi ku itsẹ na ọgbọ.\f + \fr 12:14 \ft Li zẹ \fq iMat 5.44; iLuk 6.28\f*
\v 15 Nu ẹgbọ ni e mhuẹ oghẹlẹ ke ghẹlẹ, u nu eni ẹẹ viẹ, ẹẹ viẹ.
\v 16 A ri opfọmhẹ nu egbe ẹ ke la. Khi khi ọgbọ ni ọọ ti ike ẹ nga, ama ke timama ẹgbọ ni ẹa pfue. Khi riẹlẹ khi u ma lẹsẹ dọsẹ.\f + \fr 12:16 \ft Li zẹ \fq Ekpi 3.7\f*
\p 
\v 17 Khi ri onobe fali ota onobe. Kuegbe-a ke riẹlẹ emini o ti ẹgbọ nya ẹloe.
\v 18 Ini o zẹ ya riẹlẹ, rọshẹka odẹkhodẹ, ni u rọ nu ẹgbọ nya la kugbe elemhi opfọmhẹ, ini o khi obọ oyẹ o kpọle shi.
\v 19 Emọlemhẹ, a khi mie abọ okhọli, ochoghọ a zẹ Ẹshinẹgba ọ mie abọ okhọli na ẹ. Irari khi Ebe-no-pfuasẹ o liẹ, “Mhẹmhẹ mhi mhọli imieabọ okhọli, mhi ya fali wẹ ota.” Ighọ Ẹshinẹgba ọ ngme.\f + \fr 12:19 \ft Li zẹ \fq iDẹut 32.35\f*
\v 20 Ochoghọ a ke riẹlẹ abi Ebe-no-pfuasẹ o ngme khi, “Ini okiamhi ọọ gbe ọbe ẹ, ri eminale na li le. Ini okiamẹ ọọ gbe ọli ri amẹ nali da. Irari khi ini u li na, eri u wẹ ingamhi erẹ a nga li ukhomhi.”\f + \fr 12:20 \ft Li zẹ \fq Ekpi 25.21-22\f*
\m 
\v 21 Khi zẹ ni onobe o mu ẹ le, ama ri onete mu onobe ọ le.
\c 13
\s1 Iregbe-tiemhie na eni ẹ la ukpẹkhomhi omhẹsẹ
\p 
\v 1 Ọgbọkpa ọ ke suọ esọ na eni e la ukpẹkhomhi omhẹsẹ. Irari khi Ẹshinẹgba lọlighuo tsẹ ọ dobẹ zẹ ẹ ọgbọ shi ukpẹkhomhi omhẹsẹ. Ẹshinẹgba ọ ri eni e la ukpẹkhomhi omhẹsẹ nya leghie.
\v 2 Irarighọ, ọgbọ ni ọ da mu okhọli vule ẹ shi eni ẹẹ mhẹsẹ ọ ne, eri e mu okhọli ẹ vule shi emini Ẹshinẹgba ọ rọ migha. Eni e da lighọ ne, ipfẹzọmu e nono ẹ ghi egbewẹ.
\v 3 Irari khi eni ẹa guẹ ngeli a zẹ enighie e ke nasẹ, ọa khi eni e guẹ ngeli. Irarighọ ọni ọọ riẹlẹ ọkhọlọ ọ na ulishi ena omhẹsẹ. Waa nono ni u pfue ulishi oyi ẹgbọ ni e la ukpẹkhomhi? Ke riẹlẹ emini o gbe akanya. Ini u li ghọ, e ya kuẹghiẹ.
\v 4 Irari khi eni e la ukpẹkhomhi omhẹsẹ, Ẹshinẹgba ọ zẹ wẹ ni e ke kpaghiẹ ẹ obọ. Ama u kha riẹlẹ emini ọa gbe akanya, ke na ulishi oyẹwẹ, irari khi e mhuẹ itoto ni e rọ ya nasẹ. Eni ẹẹ ga eyi Ẹshinẹgba e khi, ni ẹẹ nasẹ eni ẹa ya suọ esọ, ni o rọ khasẹ khi elemhi ẹẹ bi Ẹshinẹgba shi ọ.
\v 5 Irarighọ, zẹ ni u ke nyẹsẹ ukhomhi na eni e la ukpẹkhomhi omhẹsẹ, itobọ khi emini o ti lọ ni u ke riẹlẹ, aa khi itobọ elemhi ibibi oyi Ẹshinẹgba tsẹ.
\p 
\v 6 Onana o li zẹ khi u mema ya zẹ oga, irari khi eni e la ukpẹkhomhi omhẹsẹ eni ẹẹ ga eyi Ẹshinẹgba e khi, ni e ri ẹghẹghẹ oyẹwẹ nya na akanya omhẹsẹ.
\v 7 Fali ọgbọkpa ota ni u lo ọli. Ini u lo ota oga, zẹ ọli, okekhi ozẹla, zẹ ọli, ri ekpẹ ke na ẹgbọ, u nyẹsẹ ukhomhi na wẹ.\f + \fr 13:7 \ft Li zẹ \fq iMat 22.21; iMak 12.17; iLuk 20.25\f*
\s1 A ke riẹlẹ inono irari oni ogbẹlẹ o she ti ramhi ana
\p 
\v 8 Khi lo ọgbọ ota emhikhọghuo, sẹ ni ota inono ingme oyi ọnuzava ọyẹ tsẹ! Irari khi ọgbọ ni ọ da nono ingme oyi ọnuzava ọyọli ne, ọ she ri ushi gbe akanya.
\v 9 Ishi ni ẹẹ, “Khi kia okia,” “Khi gbe ugbeli,” “Khi do ughiatọ,” “Khi zẹ ni emhi ọgbọ o to ẹ egbe,” Ali elese ni e kpọle nya, ushi oghuo o zẹ wẹwẹ nya ukhomhi, ni ọọ, “Nono ingme oyi ọnuzava oyẹ abi u li nono ingme oyi egbe ẹ.”\f + \fr 13:9 \ft Li zẹ \fq Okiali 20.13-15,17; iDẹut 5.17-19,21; iLẹv 19.18\f*
\v 10 Ọni ọ da nono ingme oyi ọnuzava ọyọli ne, ọa tigbe ya li ọ li onobe. Irarighọ, inono o khi irushi gbe akanya.
\p 
\v 11 Ke riẹlẹ ona, lẹsẹ ẹghẹghẹ ni a la memena. Ẹghẹghẹ o she ramhi ni u rọ ya rọte olesẹ guale. Irari khi ẹghẹghẹ imiepfuese oyawa ni o kpe ukhokho o she ti bhale dọsẹ ẹghẹghẹ ni awa rọte ododẹ miesuọ.
\v 12 Ẹlẹ iyọsẹ ọ she ẹ dọsẹ, ogbe o she ẹ gbe-a. Awa khi ke ngeli abi ẹgbọ ni e la alo ebili, awa mema mu egbe ni awa rọ ya la elemhi ákpá.
\v 13 Awa guẹ ke ngeli abi ẹgbọ ni e la ákpá. Awa khi nu wẹ ye ukue ebe ni e la riẹlẹ efiala, ali idonyọ guọghọ-a. Awa khi kia okia ke mu ighuẹ ebe. Awa khi la agbọ okhọli wẹkhi agbọ iviẹ shi emhi ọgbọ.
\v 14 Ochoghọ awa ri iJesu iKirisiti Ọnọmhuẹ sọ abi awulu. Khi ke sa abi u li ya riẹlẹ ọghuẹmhẹ eyi idiegbe olamhẹ.
\c 14
\s1 A khi ke ri unu zẹ ẹgbọẹse ifue
\p 
\v 1 A mie ọgbọ ni irudunga oyọli ọa lolo toto. Khi nu ọli ke khakọ shi emini ọ mieshi ni o khi ọda shi oyẹ.
\v 2 Irari khi ẹgbọ eghuo e miesuọ khi o ti ni a ke le emhikpa. Ama ọgbọẹse ni irudunga oyọli ọa lolo toto, ọ lẹsẹ le ebe tsẹ.
\v 3 Ọgbọ ni ọ le emhikpa, ọ khi ri ẹloe gbe ọni ọa ya le, ọgbọ ni ọa ya le emhikpa, ọ khi gue oni ọ le emhikpa ẹzọ. Irari khi Ẹshinẹgba ọ ga mie wẹ.
\v 4 Ọghuo u khi ni wa ke gue aghiusomhi ọyi ọgbọẹse ẹzọ? Ọga ọyọli tse ọ dobẹ ẹ liẹ khi ọ guẹli, ali khi ọa guẹli. Ọ ya migha, irari khi Ọnọmhuẹ ọ dobẹ ya rọli migha.
\p 
\v 5 Eri ẹgbọ eghuo e dabi khi ogbẹlẹ oghuo o mu ẹloe dọsẹ olese. Ọgbọ ọlese ọọ khi abeghuo ogbẹlẹ nya e li. Ọgbọgbọ ọ ri udu oyọli shi asha ni ọ migha shi.
\v 6 Ọni ọ bino khi ogbẹlẹ okhọghuo o la ọ ni o mu ẹloe ne, eri ọ rọli ri ufumhi na Ọnọmhuẹ. Ọgbọ ni ọ le eminale, o le ọli ri ufumhi na Ọnọmhuẹ, irari khi Ẹshinẹgba ọ kphẹmhi na, ọni ọa le, Ọnọmhuẹ ọ rọli mu ekpẹ na, ọ kphẹmhi na Ẹshinẹgba.\f + \fr 14:6 \ft Li zẹ \fq iKolo 2.16\f*
\v 7 Aa mẹ ọngẹ-awa ni ọ la agbọ na egbọli tsẹ, wẹ khi eri a mẹ ọngẹ-awa ni ọọ ghu-a na egbọli tsẹ.
\v 8 Ini awa la agbọ, Ọnọmhuẹ awa la ọ agbọ na. Ini awa ghu-a, Ọnọmhuẹ awa ghu-a na. Awa la agbọ o, awa ghu-a o, ọyi Ọnọmhuẹ awa khi.
\p 
\v 9 Onana o zẹ khi iKirisiti ọ ghu-a, ọ guale ni ọ rọ khi Ọnọmhuẹ ọyi ẹgbọ ni e ghu-a ali ẹgbọ ne la agbọ.
\v 10 Yẹyẹ o yẹ, elọ o zẹ ni u rọ a gue inyọghuo ẹ ẹzọ mena? Yẹyẹ o yẹ, elọ o zẹ ni u rọ ri ẹloe ẹ gbe inyọghuẹ. Awa nya awa ya migha odalo oyi Ẹshinẹgba ni ọ gue awa ẹzọ.\f + \fr 14:10 \ft Li zẹ \fq 2 iKọri 5.10\f*
\v 11 Irari Ẹshinẹgba ọ lina ngme ọli shi Ebe-no-pfuasẹ khi,
\q1 “ ‘Aborọkhia khi mhi la ọ eghọ,’
\q2 Ọnọmhuẹ ọ lina ngme,
\q2 ‘Ọgbọkpa ọ ya wugha mhẹ odalo,
\q2 Ọgbọkpa ọ ya guele khi
\q2 mhẹmhẹ mhi khi Ẹshinẹgba.’ ”\f + \fr 14:11 \ft Li zẹ \fq Aza 45.23\f*
\m 
\v 12 Itobọ ighọ, ọgbọkpa ọ ya gue khasẹ Ẹshinẹgba abi ọ li gbe.
\s1 A khi yẹsẹ egbe ẹ de
\p 
\v 13 Itobọ ighọ, lase iguegbe-ẹzọ le. Ochoghọ, mhọli ọli shi udu oyẹ khi u waa ya kpẹ emhi wẹkhi ọzuodẹ shi ekẹ ni inyọghuo ẹ ọ khọlọ awẹ shi.
\v 14 Ikugbe ni mhẹmhẹ ali iJesu anye kugbe, o rọkhasẹ mhẹ khi emhi khọghuo ọa la ọ ni ọa pfuasẹ. Ama ini ọgbọ ọ mhọli ọli shi udu khi emhi ọa pfuasẹ, lọli oni emhi oghọ ọa pfuasẹ shi ọ.
\v 15 Ini u yese inyọghuo udu-a, irari eminale ni u le, inono ọa ke la oni angeli. Khi zẹ ni eminale nu le, o ri inyọghuo ẹ ni iJesu ọ ghu-a na de.
\v 16 Khi zẹ afa ni u mhọli rọ ọ le emhikpa, ni u rọli ri omama ghi iKirisiti.
\v 17 Irari khi Eghiele oyi Ẹshinẹgba ọa khi ingme eminale ali onyọ idada, ama oyi ipfuasẹ, ali opfọmhẹ ali oghẹlẹ na Ayẹmhẹ-nọ-pfuasẹ.
\v 18 Ọgbọ ni ọ da lina ga iKirisiti, ọ ma ti Ẹshinẹgba ẹloe, ẹgbọ e mu ekpẹ na li.
\p 
\v 19 Itobọ ighọ, ke riẹlẹ emini e ri opfọmhẹ ẹ bhale, ni e gbo ya kpaghiẹ ọgbọkpa rọ mhọli imiesuọ ni o toto.
\v 20 Khi ri itobọ eminale pfuẹchẹ emini Ẹshinẹgba ọ riẹlẹ-a. A dobẹ ya le emhikpa, ama ọa ti ni a rọ bhale ya ẹ khi emini u wa le, o zẹ ni ọgbọ olese ọ de pfilo olamhẹ.
\v 21 O tinẹ ini u waa bie le emhikhọghuo wẹkhi eri u da onyọ, wẹkhi eri u riẹlẹ emhikhọghuo ni o ya zẹ inyọghuẹ de.
\p 
\v 22 Irarighọ, emini u mieshi ingme enana nya rọli shi iteva oyẹ ali Ẹshinẹgba. Oghẹlẹ o khi ni ọgbọ ni ọa pfa ẹzọ mu egbọli shi emini ọ riẹlẹ ni ọ mie shi khi o gbe akanya.
\v 23 Ama ini ọgbọ ni ọ mhuẹ akhọkhọmhẹ ọ da kie le, a she pfa ẹzọ mu ọli. Irari khi ulemhi ni ọ le ọa khi rọte irudunga. Emini ọa da rọte irudunga bhale ne, olamhẹ o khi.
\c 15
\p 
\v 1 Awa ni awa toto shi irudunga, awa kha ke ri egbe mie na eni ẹa toto irudunga. Awa khi ke lẹsẹ riẹlẹ egbe awa ti tsẹẹ.
\v 2 Ochoghọ, ọgbọgbọ o ke riẹlẹ inyọghuo ọli emini o ti ọli egbe, ni o rọ kpaghiẹ irudunga oyọli, ni o vule.
\v 3 Irari khi iKirisiti ọa riẹlẹ egbọli tsẹẹ ti. Ochoghọ, abi Ebe-no-pfuasẹ o ngme ni ọọ, “Ẹshinẹgba, itsuemhi ni ẹgbọ e tsue ẹ, o de nga mhẹ egbe.”\f + \fr 15:3 \ft Li zẹ \fq Iwolo 69.9\f*
\v 4 Emini a kẹkẹ shi Ebe-no-pfuasẹ nya, eri a kẹkẹ ọli ni a rọ sẹsẹ awa ingme, ni a bhale ya ẹ khi iregbemie ali irudushọ ni Ebe-no-pfuasẹ o rọ na awa, o ri awa mhọli irudushi.
\p 
\v 5 Ẹshinẹgba ni ọ khi ọni ọ ri iregbemie, ali irudushọ ọ na ọgbọ, ọ ka rẹ ẹ mhuẹ usamhi oghuo abi a liẹ deba ẹtẹ-awẹ eyi iJesu iKirisiti.
\v 6 Ni ẹẹ nya a ri udu oghuo ali uruli oghuo kuẹghiẹ Ẹshinẹgba ni ọ khi ita iJesu iKirisiti Ọnọmhuẹ ọyawa.
\p 
\v 7 Awa ke lama ingme egbe abi iKirisiti ọ li lama ingme oyawa, ni o ri ikuẹghiẹ bhale ghi Ẹshinẹgba.
\v 8 Itobọ khi mhi gueyẹ ẹ khi iKirisiti ọ she bhale abi ọni ọọ ga ọgbọ na ẹgbọ iJu, ni o rọkhasẹ khi Ẹshinẹgba igẹsikia ọ khi, ni o rọ mu ma ishobọ ni ọ shi na itita awa,
\v 9 ni iJẹta e kuẹghiẹ Ẹshinẹgba shi ilẹlemhi oyọli. Abi a li kẹkẹ ọli khi,
\q1 “Irarighọ, mhi ya kuẹghiẹ ẹ
\q2 iteva ẹgbọ iJẹta.
\q1 Mhi ya to uwolo
\q2 kuẹghiẹ eva oyẹ.”\f + \fr 15:9 \ft Li zẹ \fq 2 iSam 22.50; Iwolo 18.49\f*
\m 
\v 10 O gbolo ẹ,
\q1 “Ẹẹ iJẹta, ni a kuma
\q2 ẹgbọ eyọli ke ghẹlẹ.”\f + \fr 15:10 \ft Li zẹ \fq iDẹut 32.43\f*
\m 
\v 11 O gbolo ẹ,
\q1 “A kuẹghiẹ Ẹshinẹgba
\q2 ẹẹ ẹgbọ iJẹta,
\q2 a to uwolo kuẹghiẹ ọli
\q2 ẹgbọ nya.”\f + \fr 15:11 \ft Li zẹ \fq Iwolo 117.1\f*
\m 
\v 12 Azaya ọ gbolo liẹ,
\q1 “Omiomi iJese ọ ya fu vule,
\q2 ọni ọ ya vule mhẹsẹ na ẹ iJẹta,
\q1 ẹgbọ iJẹta e ya ri udu nga li.”\f + \fr 15:12 \ft Li zẹ \fq Aza 11.10\f*
\p 
\v 13 Ẹshinẹgba ni a rọte obọ oyọli ẹ mhuẹ irudushi, ọ ri oghẹlẹ ali opfọmhẹ nẹ rọte iregbenga ni a mhuẹ nali, ni a rọ bhale ya ẹ khi irudushi oyẹẹ ọ fu shọ rọte ekpabọ oyi Ayẹmhẹ-nọ-pfuasẹ.
\s1 IPọlu ọni a zẹ ọ khi ọni ọ gbe akanya na ẹgbọ iJẹta
\p 
\v 14 Inyọghuo-mhẹ, mhẹmhẹ oyẹmhẹ mhi mhuẹ imieshiọ khi onete o vọ ẹ egbe, khi ilẹsẹ o gba na ẹ ni a rọ dobẹ ya ke sẹsẹ egbe ẹ.
\v 15 Mhi she kpẹ gue ingme eghuo yẹ ẹ gboo elemhi ebe ona ni mhi gbolo ẹ yele ẹ le ena. Itobọ afu ni Ẹshinẹgba ọ rọ na mhẹ,
\v 16 ni mhi rọ khi aghiusomhi na kẹẹ ọyi iJesu iKirisiti na ẹgbọ iJẹta. Eri mhia gbe akanya ọkpodalo-ugamhi ọyi Ẹshinẹgba, ni a rọ tsabọ usomhi onete oyi Ẹshinẹgba, ni a rọ bhale ya ẹ khi ẹgbọ iJẹta e li khi iluasobo, ni Ẹshinẹgba ọ mie, eni Ayẹmhẹ-nọ-pfuasẹ ọ khuẹsẹ-a pfuasẹ.
\v 17 Rọte iJesu iKirisiti mhi te ẹ mhọli egbe-imumhẹ shi ugamhi ni mhia ga Ẹshinẹgba.
\v 18 Mhi aa ya gbudu ngme emhikhọghuo, sẹẹ ni emini iKirisiti ọ rọte obọ oyẹmhẹ riẹlẹ rọ ri ẹgbọ iJẹta suọ esọ na Ẹshinẹgba, rọte ungmemhi ali ikanya oyẹmhẹ,
\v 19 rọte ekpabọ eyi ọlẹlẹ ali ọnyaloa, ali rọte ekpabọ oyi Ayẹmhẹ-nọ-pfuasẹ. Ighọ mhi rọte iJerusalẹmu ngme ungmemhi usomhi onete oyi iKirisiti ya ramhi iLirikumu.
\v 20 O ma kie kpẹ khi emini o la mhẹ udu ni mhi rọ ngme ungmemhi usomhi onete ye ẹgbọ ni ẹa kie suọ ungmemhi oyi iKirisiti ne, ini mhi khi ya tọ nga irọgbekẹ ni ọgbọẹse ọ rọ gbe.
\v 21 Abi Ebe-no-pfuasẹ o ngme ọ khi,
\q1 “Ẹgbọ ni aa kpẹ
\q2 gue ingme oyọli yẹ ne,
\q1 e ya mẹ, ali khi eni ẹa kpẹ suọ,
\q2 o ya ye wẹ.”\f + \fr 15:21 \ft Li zẹ \fq Aza 52.15\f*
\s1 Ugbamhi ni iPọlu ọ gba, khi lọli ya ye iRomu
\p 
\v 22 Akanya oyẹmhẹ ona o zu mhẹ ode, ni mhi aa rọ mẹ asha bhale deba ẹ.\f + \fr 15:22 \ft Li zẹ \fq iRom 1.13\f*
\v 23 Aborọkhia khi mhi aa ke mhuẹ ikanya ni e kpọ mhẹ le shi ikpe ena, ali ni o rọ gbo khia khi ikpe ebubu na ni mhi te ẹ nono ni mhi bhale ya mẹ eghọ,
\v 24 o la mhẹ udu khi mhi ya rọte olieyẹ ẹ ini mhia lẹ iSipeni. Mhi sa khi a dobẹ ya ri ikpaghiobọ na mhẹ ni mhi rọ ti okiali oyẹmhẹ je odalo, ini awa ri egbe mu egbe ukuku ẹghẹghẹ se.
\v 25 Mena, mhia je iJerusalẹmu ni mhi ya kpaghiẹ ẹgbọ eyi Ẹshinẹgba obọ.
\v 26 Irari khi o ghọle eni miesuọ ni e la ekẹ iMasidonia ali Akhaya ni e ri ikpaghiobọ na ẹgbọ eyi Ẹshinẹgba ni e la iJerusalẹmu.\f + \fr 15:26 \ft Li zẹ \fq 1 iKọri 16.1-4\f*
\v 27 Egbe ẹ mu wẹ khi wẹwẹ e lighọ riẹlẹ ọli, e rue ọli shi khi ota wẹwẹ e lo wẹ. Irari khi ini ẹgbọ iJẹta e kemhi ikhivọsẹ ayẹmhẹ oyi ẹgbọ iJu, eri o li abi ota ni ẹgbọ iJẹta e lo ẹgbọ iJu.\f + \fr 15:27 \ft Li zẹ \fq 1 iKọri 9.11\f*
\v 28 Ini mhi gbe akanya ona se ni mhi rọ mẹ ọli mẹ khi e she mie ikpaghọ ena se, mhi ya je iSipeni, mhi ya kọ fẹli ẹ ini mhia lẹ.
\v 29 Mhi lẹsẹ ọli gboo khi ini mhi bhale, ikhivọsẹ oyi iKirisiti ni o vọ tsululu mhi rọ ya bhale.
\v 30 Mhi ri iJesu iKirisiti Ọnọmhuẹ ọyawa ali inono ni Ayẹmhẹ o rọ na awa lema ẹ inyọghuo, a nu mhẹ sọ iromhi ali a gbo sọ iromhi na mhẹ.
\v 31 Sọ iromhi Ẹshinẹgba ọ tsumhi mhẹ obọ oyi ẹgbọ ni ẹa miesuọ na ekẹ iJudia ali ni ẹgbọ Ẹshinẹgba ni e la ẹoli iJerusalẹmu ni e mie eni ikpaghọ ni mhi rọọ ghi wẹ.
\v 32 Ni a rọ bhale ya ẹ khi rọte ọghuẹmhẹ oyi Ẹshinẹgba, mhi dobẹ ri udu oghẹlẹ bhale deba ẹ ali ni awa ri udu shi egbe ọ.
\v 33 Ẹshinẹgba ọyi opfọmhẹ ọ ka nu ẹẹ nya la, Atsẹ.
\c 16
\s1 Otsẹ ni iPọlu lọlighuo ọ tsẹ ẹgbọ kẹ
\p 
\v 1 Mhi gue ingme onete oyi iFobi yẹ ẹ, ikhi inyọghuo awa ni ọkpotso, ni ọ khi ọni ọ ralo shi eni e miesuọ ni e la ẹoli iKẹnkhiria.
\v 2 A ri eva oyi Ọnọmhuẹ kpẹ abọ mie ọli, abi ẹgbọ eyi Ẹshinẹgba e yẹ ni e li. A ri ikpaghiẹ obọ onini ọ da ya nono obọ oyẹ ẹ na li. Irari khi anamẹlo ọyẹmhẹ ali ebubu ẹgbọẹse ọ khi.
\p 
\v 3 Mhia tsẹ iPisilia ali Akuila ni e kpaghiẹ mhẹ obọ shi akanya oyi iJesu iKirisiti.\f + \fr 16:3 \ft Li zẹ \fq Ika 18.2\f*
\v 4 E ri agbọ oyẹwẹ shi okhẹna irari oyẹmhẹ. Ọa khi wẹwẹghuo tsẹ mhia tsẹ uwegbe, ama li shi igbaa nya eyi eni e mie iKirisiti suọ enayi ẹgbọ iJẹta.
\v 5 Mhi gbo li tsẹ igbaa oyi eni e mie iJesu iKirisiti suọ ni o la owa oyẹwẹ.
\p Mhia tsẹ egbegbi ọmọlemhẹ Epanẹtusi ni ọ khi ọgbọ ọnododẹ ni ọ mie iKirisiti suọ ukiẹkiẹ ekẹ Esha.
\p 
\v 6 Mhi tsẹ iMeli ni ọ toto obọ a gbe akanya na ẹ.
\p 
\v 7 Mhi tsẹ Adironikusi ali iJunayasi, ẹgbọ iJu nabi mhẹmhẹ ni anye ga la owa ighumha. Eni a mu ekpẹ na e khi elemhi idiegbe oyi ighiusomhi na kẹẹ. Ama e kpẹ miesuọ khẹ mhẹ.
\p 
\v 8 Mhia tsẹ Amipiliatusi, egbegbi ọmọlemhẹ, ni mhi mhuẹ inono na elemhi Ọnọmhuẹ.
\p 
\v 9 Mhia tsẹ Urubane, ni ọ kpaghiẹ anye obọ akanya oyi iKirisiti.
\p Mhi gbo tsẹ iSitachisi, egbegbi ọmọlemhẹ.
\p 
\v 10 Mhia tsẹ Apẹlẹsi, ni a mẹ gboo khi igẹsikia ọ rọ deba iKirisiti.
\p Mhi tsẹ ena ọmhuẹ-apfẹ oyi Arisitobulusi.
\p 
\v 11 Mhi tsẹ Erọdiọni ni ọ khi inyọghuo-mhẹ.
\p Tsẹ eni e miesuọ na ọmhuẹ-apfẹ oyi iNakisusi.
\p 
\v 12 Mhia tsẹ iTirifẹana ali iTirifosa eni ikpotso eghọ ni e gbe akanya oyi Ọnọmhuẹ egbegbọ.
\p Mhi li tsẹ egbegbi ọmọlemhẹ iPesisi ọni ọkpotso ni ọ gbe ukpokpomhi akanya na Ọnọmhuẹ.
\p 
\v 13 Mhia tsẹ iRufọsi, ọgbakanya ni a zẹ ọyi Ọnọmhuẹ, ali inyọli ni ọ li abi inyọ shi mhẹ ọ.\f + \fr 16:13 \ft Li zẹ \fq iMak 15.21\f*
\p 
\v 14 Mhi tsẹ Asikiritusi, ali iFilegọni, ali Amẹsi ali iPatirobasi ali Amasi ali eni e miesuọ ni e ga la.
\p 
\v 15 Mhia tsẹ iFilologusi ali iJulia ali iNirusi ali inyọghuo ọli ni ọkpotso ali Olimpasi ali ẹgbọ Ẹshinẹgba nya ni e nu wẹ la.
\p 
\v 16 A tsẹ egbe ẹ otsẹ onete, a ghẹlẹ mu egbe abi inyọghuo.
\p Igbaa nya eyi eni e mie iKirisiti suọ, ẹ tsẹ ẹ.
\p 
\v 17 Mhi lema ẹ, inyọghuo, a ke tọ ọkpẹ ẹgbọ ni ẹ pfi okemhi ali ni e ri ẹgbọ de irudunga ni e mhuẹ-a, eni osẹsẹ oyẹwẹ ọa de shi osẹsẹ ni a sẹsẹ awa. A nuata shi wẹ ọ.
\v 18 Irari khi ẹgbọ ni ẹ riẹlẹ emhi eghọghọ ẹa ya ga iKirisiti Ọnọmhuẹ ọyawa, ama elemhi oyẹwẹ ẹ ga. Rọte eta-ọlẹlẹmhunu ni ẹ ngme, e rọ ọ di usamhi udu oyi ẹgbọ eghuo ni ẹa mhuẹ ilẹsẹ.
\v 19 Ọgbọkpa ọ she suọ abi a li ri ungmemhi oyi Ẹshinẹgba a gbe akanya. Itobọ ona mhi rọ ghẹlẹ shi ingme oyẹẹ. Ama mhia nono ni a fialo-a shi emini o khi onete, ama a khi fialo-a shi emhi onobe.
\p 
\v 20 Ẹshinẹgba ọyi opfọmhẹ ọ ya kẹlẹ guọghọ ọkphaghiẹ-a shi ẹ ẹkowẹ. Okhale oyi iJesu iKirisiti Ọnọmhuẹ ọyawa o ke deba ẹ nya.
\p 
\v 21 ITimoti ni anye ga a gbe akanya, ọọ tsẹ ẹ. Ighọ khi iLushọsi ali iJasi ali iSosipata, ni anye ga khi iJu.\f + \fr 16:21 \ft Li zẹ \fq Ika 16.1\f*
\v 22 Mhẹmhẹ iTẹtiusi ni mhi ri ugba ma a kẹkẹ ebe ona na iPọlu, mhi tsẹ ẹ, abi ọni ọ miesuọ.
\v 23 IGayusi ni ọ ri owa oyọli na mhẹ kushi, ni ọ gbo ri ukpẹloe ẹ khu mhẹ, ni ọ lama eni e miesuọ e ke legba owa oyọli, ọọ tsẹ ẹ.
\p Erasitọsi, ni ọ ri ikpaghọ ọ shi na ẹoli oyẹwẹ ali inyọghuo anye ikhi iKaritusi, ẹẹ tsẹ ẹ.\f + \fr 16:23 \ft Li zẹ \fq Ika 19.29; 1 iKọri 1.14; 2 iTimo 4.20\f*
\v 24 [Okhale oyi iJesu iKirisiti Ọnọmhuẹ ọyawa o ka nu ẹ la, Atsẹ.]
\p 
\v 25 Ufumhi khi oyi Ẹshinẹgba! Lọli ọ dobẹ rẹ migha shi irudunga oyẹ ẹ abi o li de shi oni usomhi onete oyi iJesu iKirisiti ni mhi rọ ọ tse abọ, ali ni o de shi irọkhasẹ oyi osheli ni a rọ sheli agbọagbọ elemhi ikpe ebubu ni e dọsẹ.
\v 26 Ama mena, a she ri oni igẹsikia khasẹ, rọte akẹkẹ shi ekẹ enayi emekẹguele, abi Ẹshinẹgba ni ọ la ọ agbọagbọ ọ mhẹsẹ ọli a li rọli khasẹ ishishi nya, ini e ba miesuọ ni e suọ esọ na luẹ.
\v 27 Ẹshinẹgba ọna ilẹsẹ, a ri ufumhi na agbọagbọ, rọte obọ oyi iJesu iKirisiti! Atsẹ.
