\id 1CH - Biblica® Open Kurdi Sorani Standard Version
\h یەکەم پوختەی مێژوو
\toc1 یەکەم پوختەی مێژوو
\toc2 یەکەم پوختەی مێژوو
\toc3 یەکەم پوختەی مێژوو
\mt1 یەکەم پوختەی مێژوو
\c 1
\s1 ڕەچەڵەکی ئادەم هەتا ئیبراهیم
\s2 هەتا کوڕەکانی نوح
\li1 
\v 1 ئادەم، شیت، ئەنۆش،
\li1 
\v 2 قێنان، مەهلەلئێل، یارەد،
\li1 
\v 3 حەنۆخ، مەتوشالح، لامەخ
\li1 و نوح.
\b
\li4 
\v 4 کوڕەکانی نوح: سام، حام و یافەت.
\s2 یافەتییەکان
\li1 
\v 5 کوڕەکانی یافەت:
\li2 گۆمەر، ماگۆگ، مادەی، یاڤان، توبال، مەشەک و تیراس.
\li1 
\v 6 کوڕەکانی گۆمەر:
\li2 ئەشکەنەز، ڕیفەت و تۆگەرما.
\li1 
\v 7 کوڕەکانی یاڤان:
\li2 ئەلیشا، تەرشیش، کیتیم و ڕۆدانیم.
\s2 حامییەکان
\li1 
\v 8 کوڕەکانی حام:
\li2 کوش، میسر، پووت و کەنعان.
\li1 
\v 9 کوڕەکانی کوش:
\li2 سەبا، حەڤیلا، سەڤتا، ڕەعما و سەبتەکا.
\li1 کوڕەکانی ڕەعما:
\li2 شەبا و دیدان.
\li1 
\v 10 نەمرود لە نەوەی کوش لەدایکبوو،
\li2 کە بووە جەنگاوەرێکی مەزن لەسەر زەوی.
\li1 
\v 11 میسر باوکی
\li2 لوودی، عەنامی، لەهابی، نەفتوحی،
\v 12 پاتروسی و کەفتۆری بوو، هەروەها باوکی کەسلوحییەکانیش بوو کە فەلەستییەکانیان لێ کەوتنەوە.
\li1 
\v 13 کەنعان باوکی سەیدا بوو،
\li2 کە نۆبەرەکەی بوو، لەگەڵ حیتییەکان،
\v 14 هەروەها یەبوسی، ئەمۆری، گرگاشی،
\v 15 حیڤی، عەرقی، سینی\f + \fr 1:15 \ft سینییەکان: لەوانەیە خەڵکی شارێک لە نزیکی شاری عەرقە لە لوبنان بووبێت. بڕوانە \xt پەیدابوون 10‏:17‏\xt*\ft ‏.‏\f*،
\v 16 ئەرڤادی، چیماری و حەماتییەکانیشی بوو.
\s2 سامییەکان
\li1 
\v 17 کوڕەکانی سام:
\li2 ئیلام، ئەشوور، ئەرپەکشاد، لوود و ئارام.
\li1 کوڕەکانی ئارام:
\li2 عوچ، حوول، گەتەر و مەشەک.
\li1 
\v 18 ئەرپەکشاد باوکی شالەح بوو،
\li2 شالەحیش باوکی عێبەر بوو،
\li1 
\v 19 عێبەریش دوو کوڕی بوو،
\li2 یەکێکیان ناوی پەلەگ\f + \fr 1:19 \ft پەلەگ واتا دابەشکردن.‏\f* بوو، چونکە لە سەردەمی ئەودا زەوی دابەش کرا. براکەشی ناوی یۆقتان بوو.
\li1 
\v 20 یۆقتان ئەم کوڕانەی هەبوو:
\li2 ئەلمۆداد، شەلەف، حەچەرماڤەت، یارەح،
\v 21 هەدۆرام، ئوزال، دیقلە،
\v 22 عۆبال، ئەبیمائێل، شەبا،
\v 23 ئۆفیر، حەڤیلا و یۆڤاڤ. هەموو ئەمانە کوڕانی یۆقتان بوون.
\b
\li1 
\v 24 سام، ئەرپەکشاد، شالەح،
\li1 
\v 25 عێبەر، پەلەگ، ڕەعو،
\li1 
\v 26 سەروگ، ناحۆر، تارەح و
\li1 
\v 27 ئەبرام، کە ئیبراهیمە.
\s1 نەوەی ئیبراهیم
\li4 
\v 28 کوڕەکانی ئیبراهیم: ئیسحاق و ئیسماعیل.
\s2 نەوەی هاجەر
\li1 
\v 29 ئەمانەش نەوەکانیانن:
\li2 نەبایۆت کە نۆبەرەی ئیسماعیل بوو، هەروەها قێدار، ئەدبەئێل، میبسام،
\v 30 میشماع، دوما، مەسسا، حەدەد، تێما،
\v 31 یەتور، نافیش و قێدما،
\li4 ئەمانە کوڕەکانی ئیسماعیل بوون.
\s2 نەوەی قەتورە
\li1 
\v 32 قەتورە کە کەنیزەی ئیبراهیم بوو ئەم کوڕانەی هەبوو:
\li2 زیمران، یۆقشان، مەدان، میدیان، یەشباق و شوەح.
\li1 کوڕەکانی یۆقشانیش:
\li2 شەبا و دیدان.
\li1 
\v 33 کوڕەکانی میدیان:
\li2 عێفا، عێفەر، حەنۆک، ئەبیداع و ئەلداعە.
\li4 هەموو ئەمانە نەوەی قەتورە بوون.
\s2 نەوەی سارا
\li4 
\v 34 ئیبراهیم ئیسحاقی بوو.
\li1 کوڕەکانی ئیسحاق:
\li2 عیسۆ و ئیسرائیل.
\s1 کوڕەکانی عیسۆ
\li1 
\v 35 کوڕەکانی عیسۆ:
\li2 ئەلیفاز، ڕەعوئێل، یەعوش، یەعلام و قۆرەح.
\li1 
\v 36 کوڕەکانی ئەلیفاز:
\li2 تێمان، ئۆمار، چەفۆ، گەعتام و قەنەز؛
\li2 هەروەها لە ئەلیفاز تیمنەع عەمالێقی\f + \fr 1:36 \ft تیمنەعی دایکی عەمالێق کەنیزەی ئەلیفاز بوو، بڕوانە \xt پەیدابوون 36‏:12‏\xt*\ft ‏.‏\f* بوو.
\li1 
\v 37 کوڕەکانی ڕەعوئێل:
\li2 نەحەت، زەرەح، شەمما و میزا.
\s2 خەڵکی سێعیر لە ئەدۆم
\li1 
\v 38 کوڕەکانی سێعیر:
\li2 لۆتان، شۆڤاڵ، چیبعۆن، عەنا، دیشۆن، ئێچەر و دیشان.
\li1 
\v 39 کوڕەکانی لۆتان: حۆری و هۆمام.
\li2 تیمنەعیش خوشکی لوتان بوو.
\li1 
\v 40 کوڕەکانی شۆڤاڵ:
\li2 عەلڤان، مانەحەت، عێبال، شەفۆ و ئۆنام.
\li1 کوڕەکانی چیبعۆن:
\li2 ئەییا و عەنا.
\li1 
\v 41 کوڕەکەی عەنا:
\li2 دیشۆن.
\li1 کوڕەکانی دیشۆن:
\li2 حەمدان، ئەشبان، یەتران و کران.
\li1 
\v 42 کوڕەکانی ئێچەر:
\li2 بلهان، زەعەڤان و عەقان.
\li1 کوڕەکانی دیشان:
\li2 عوچ و ئەران.
\s2 فەرمانڕەوایانی ئەدۆم
\li4 
\v 43 ئەمانەش ئەو پاشایانەن کە لە خاکی ئەدۆم پاشایەتییان دەکرد پێش ئەوەی هیچ پاشایەکی ئیسرائیلی پاشایەتی بکات:
\li1 بەلەعی کوڕی بەعۆر، ناوی شارەکەشی دینهابە بوو.
\li1 
\v 44 کە بەلەع مرد، یۆڤاڤی کوڕی زەرەحی خەڵکی بۆزرا وەک پاشا جێگەی گرتەوە.
\li1 
\v 45 کە یۆڤاڤ مرد، حوشامی خەڵکی خاکی تێمانییەکان وەک پاشا جێگەی گرتەوە.
\li1 
\v 46 کە حوشام مرد، هەدەدی کوڕی بەدەد وەک پاشا جێگەی گرتەوە، لە وڵاتی مۆئاب شکستی بە میدیان هێنا. ناوی شارەکەشی عەڤیت بوو.
\li1 
\v 47 کە هەدەد مرد، سەمڵەی خەڵکی مەسرێقە وەک پاشا جێگەی گرتەوە.
\li1 
\v 48 کە سەمڵە مرد، شائوولی خەڵکی ڕەحۆبۆت، ئەو شارەی لە کەناری ڕووبار\f + \fr 1:48 \ft لەسەر ڕووبارە: دەشێت ڕووباری فورات بێت.‏\f* بوو، وەک پاشا جێگەی گرتەوە.
\li1 
\v 49 کە شائوول مرد، بەعل‌حانانی کوڕی عەکبۆر وەک پاشا جێگەی گرتەوە.
\li1 
\v 50 کە بەعل‌حانان مرد، هەدەد وەک پاشا جێگەی گرتەوە. ناوی شارەکەشی پاعوو بوو، ژنەکەشی ناوی میهێتەبێل بوو، کچی مەترێدی کچی مێزاهاب بوو.
\v 51 ئینجا هەدەدیش مرد.
\b
\li4 میرەکانی ئەدۆم ئەمانە بوون:
\li1 تیمنەع، عەلڤا، یەتێت،
\v 52 ئۆهۆلیبامە، ئێلە، پینۆن،
\v 53 قەنەز، تێمان، میبسار،
\v 54 مەگدئێل و عیرام.
\li4 ئەمانە میرەکانی ئەدۆم بوون.
\c 2
\s1 کوڕەکانی یاقوب
\li4 
\v 1 ئەمانەش کوڕەکانی ئیسرائیلن: ڕەئوبێن، شیمۆن، لێڤی، یەهودا، یەساخار، زەبولون،
\v 2 دان، یوسف، بنیامین، نەفتالی، گاد و ئاشێر.
\s1 یەهودا
\s2 هەتا کوڕەکانی حەسرۆن
\li1 
\v 3 کوڕەکانی یەهودا:
\li2 ئێر، ئۆنان و شالەح، کە هەرسێکیان لە کچەکەی شوەعی کەنعانی بوون.
\li2 ئێر کوڕە نۆبەرەکەی یەهودا لەبەرچاوی یەزدان کەسێکی خراپەکار بوو، یەزدانیش لەناوی برد.
\li2 
\v 4 تاماری بووکیشی، پێرێز و زەرەحی بوو.
\li4 ئەمانە هەر پێنج کوڕەکەی یەهودا بوون.
\b
\li1 
\v 5 کوڕەکانی پێرێز:
\li2 حەسرۆن و حامول.
\li1 
\v 6 کوڕەکانی زەرەح:
\li2 زیمری، ئێیتان، هێیمان، کەلکۆل و دەردەع، هەموویان پێنج بوون.
\li1 
\v 7 کوڕەکەی کەرمی:
\li2 عاخار\f + \fr 2:7 \ft \tl عاخار‏\tl* لە زمانی عیبریدا واتا تێکدان. لە یەشوع بەشی 7 ناوەکەی (عاخان)ـە.‏\f* کە تێکدەری ئیسرائیل بوو، ئەوەی کە ناپاکی کرد و شتە تەرخانکراوەکانی\f + \fr 2:7 \ft لە زمانی عیبری ئەم زاراوەیە دەگەڕێتەوە بۆ شتێک یان کەسێک کە دەبەخشرێت بە یەزدان. لە کاتی شەڕدا دەستکەوتەکە دابەش ناکرێت و بەخشینەکە دەرئەنجامەکەی لەناوبردنی تەواوە.‏\f* برد.
\li1 
\v 8 کوڕەکەی ئێیتان:
\li2 عەزەریا بوو.
\li1 
\v 9 حەسرۆن ئەم کوڕانەی خستەوە:
\li2 یەرەحمێل، ڕام و کالێب.
\s2 نەوەی ڕامی کوڕی حەسرۆن
\li1 
\v 10 ڕام عەمینادابی بوو،
\li1 عەمیناداب نەحشۆنی بوو سەرۆکی نەوەی یەهودا.
\li1 
\v 11 نەحشۆن سەلمۆنی بوو
\li1 و سەلمۆن بۆعەزی بوو،
\li1 
\v 12 بۆعەز عوبێدی بوو
\li1 و عوبێد یەسای بوو.
\b
\li1 
\v 13 یەسا باوکی ئەمانە بوو:
\li2 ئەلیاب کوڕە نۆبەرەکەی؛ دووەمین ئەبیناداب،
\li2 سێیەمین شیمەعە،
\v 14 چوارەمین نەتەنێل،
\li2 پێنجەمین ڕەدەی،
\v 15 شەشەمین ئۆچەم
\li2 و حەوتەمین داود.
\li2 
\v 16 هەروەها خوشکەکانیان چەرویا و ئەبیگایل بوون،
\li3 چەرویا سێ کوڕی هەبوو: ئەبیشەی، یۆئاب و عەساهێل.
\li3 
\v 17 ئەبیگایل عەماسای لێبوو، باوکی عەماسا یەتەری ئیسماعیلی بوو.
\s2 کالێبی کوڕی حەسرۆن
\li1 
\v 18 کالێبی کوڕی حەسرۆن لە عەزوڤای ژنی و لە یەریعۆت منداڵی بوو، کچێک بە ناوی یەریعۆت و سێ کوڕ بەم ناوانە:
\li2 یێشەر، شۆڤاڤ و ئەردۆن.
\li1 
\v 19 کە عەزوڤا مرد، کالێب ئەفراتی هێنا و حووری بۆ خستەوە.
\li2 
\v 20 حووری ئوری بوو و ئوری بەسەلئێلی بوو.
\b
\li1 
\v 21 پاشان حەسرۆن لە تەمەنی شەست ساڵیدا کچەکەی ماکیری باوکی گلعادی هێنا و لەگەڵی جووت بوو، ئەویش سگوڤی بۆ خستەوە.
\li2 
\v 22 سگوڤ یائیری بوو کە بیست و سێ شارۆچکەی لە خاکی گلعاددا لەژێر دەستدا بوو.
\li2 
\v 23 بەڵام گەشوور و ئارام، حەڤۆت یائیریان لێ داگیر کرد لەگەڵ قەنات و دەوروبەری کە شەست شارۆچکە بوون.
\li4 هەموو ئەمانە نەوەی ماکیری باوکی گلعاد بوون.
\li1 
\v 24 پاش مردنی حەسرۆن لە کالێب ئەفراتەدا، ئەبیای ژنی حەسرۆن ئەشحووری باوکی تەقۆعەی بۆ خستەوە.
\s2 یەرەحمێلی کوڕی حەسرۆن
\li1 
\v 25 کوڕەکانی یەرەحمێلی نۆبەرەی حەسرۆن:
\li2 ڕام کە کوڕە نۆبەرەکەی بوو، پاشان بونا، ئۆرەن، ئۆچەم و ئاحییا.
\v 26 یەرەحمێل ژنێکی دیکەی هەبوو ناوی عەتارا بوو و دایکی ئۆنام بوو.
\li1 
\v 27 کوڕەکانی ڕامی نۆبەرەی یەرەحمێل:
\li2 مەعەچ، یامین و عێقەر.
\li1 
\v 28 کوڕەکانی ئۆنام:
\li2 شەمەی و یاداع.
\li1 کوڕەکانی شەمەی:
\li2 ناداب و ئەبیشوور.
\v 29 ناوی ژنەکەی ئەبیشووریش ئەبیهەیل بوو و ئەحبان و مۆلیدی بۆ خستەوە.
\li1 
\v 30 کوڕەکانی ناداب:
\li2 سەلەد و ئەپەیم. سەلەد بە وەجاخکوێری مرد.
\li1 
\v 31 کوڕەکەی ئەپەیم یەشعی بوو،
\li2 کوڕەکەی یەشعیش شێشان بوو، کوڕەکەی شێشانیش ئەحلای بوو.
\li1 
\v 32 کوڕەکانی یاداعی برای شەمەی:
\li2 یەتەر و یۆناتان. یەتەر بە وەجاخکوێری مرد.
\li1 
\v 33 کوڕەکانی یۆناتان:
\li2 پەلەت و زازا.
\li4 ئەمانە نەوەی یەرەحمێل بوون.
\b
\li1 
\v 34 شێشان هیچ کوڕی نەبوو و تەنها کچی هەبوو.
\li2 شێشان خزمەتکارێکی میسری هەبوو ناوی یەرحاع بوو.
\v 35 شێشان کچێکی خۆی دا بە یەرحاعی خزمەتکاری ببێت بە ژنی، جا عەتەیی بۆ خستەوە.
\li1 
\v 36 عەتەی ناتانی بوو،
\li1 ناتان زاڤادی بوو،
\li1 
\v 37 زاڤاد ئەفلالی بوو،
\li1 ئەفلال عوبێدی بوو،
\li1 
\v 38 عوبێد یێهوی بوو،
\li1 یێهو عەزەریای بوو،
\li1 
\v 39 عەزەریا حەلەچی بوو،
\li1 حەلەچ ئەلیعاسای بوو،
\li1 
\v 40 ئەلیعاسا سیسمەیی بوو،
\li1 سیسمەی شەلومی بوو،
\li1 
\v 41 شەلوم یەقەمیای بوو و
\li1 یەقەمیاش ئەلیشاماعی بوو.
\s2 خێڵەکانی کالێب
\li1 
\v 42 کوڕەکانی کالێبی برای یەرەحمێل:
\li2 مێشا کوڕە نۆبەرەکەی ئەوەی کە باوکی زیف بوو
\li2 و ئەوی دیکەیان مارێشا کە باوکی حەبرۆن بوو.
\li1 
\v 43 کوڕەکانی حەبرۆن:
\li2 قۆرەح، تەپووەح، ڕاقەم و شەمەع.
\li1 
\v 44 شەمەع ڕەحەمی بوو کە
\li2 باوکی یۆرقاعام بوو
\li1 و ڕاقەم شەمەی بوو.
\li1 
\v 45 کوڕەکەی شەمەی ماعۆن بوو
\li2 و ماعۆنیش باوکی بێت‌چوور بوو.
\li1 
\v 46 هەروەها عێفای کەنیزەی کالێب
\li2 حاران، مۆچا و گەزێزی بوو،
\li2 هەروەها حارانیش گەزێزی بوو.
\li1 
\v 47 کوڕەکانی یاهدای
\li2 ڕەگەم، یۆتام، گێشان، پالەت، عێفا و شەعەف بوون.
\li1 
\v 48 مەعکای کەنیزەی کالێبیش،
\li2 شەڤەر و تیرحەنای بوو،
\li2 
\v 49 هەروەها ئەمانەشی بوو: شەعەفی باوکی مەدمەنا،
\li2 شێڤای باوکی مەخبێنا، باوکی گیبعا
\li1 و کچەکەی کالێبیش کە ناوی عەکسا بوو.
\li4 
\v 50 ئەمانە نەوەی کالێب بوون.
\b
\li1 کوڕەکانی حوور کە نۆبەرەی ئەفراتە بوو:
\li2 شۆڤاڵی باوکی قیریەت یەعاریم،
\v 51 سەلمای باوکی بێت‌لەحم و حارێفی باوکی بێت‌گادێر.
\li1 
\v 52 نەوەکانی شۆڤاڵی باوکی قیریەت یەعاریمیش ئەمانە بوون:
\li2 هەرۆئە و نیوەی مانەحەتییەکان و
\v 53 خێڵەکانی قیریەت یەعاریم کە یەسری، پوتی، شوماتی و مشراعی بوون. لەمانەوە چۆرعاتی و ئەشتائۆلییەکان کەوتنەوە.
\li1 
\v 54 نەوەی سەلما:
\li2 بێت‌لەحم، نەتۆفاییەکان، عەترۆت بێت‌یۆئاڤ، چۆرعییەکان و نیوەی مانەحەتییەکان،
\v 55 هەروەها خێڵە قەڵەمگرەکانی دانیشتووی ناوچەی یەعبێچ ئەمانە بوون: تیرعاتییەکان، شیمەعاتییەکان و سوکاتییەکان. ئەمانە ئەو قێنییانە بوون کە لە حەممەتی باوکی بنەماڵەی ڕێکابەوە هاتبوون.
\c 3
\s2 کوڕەکانی داود
\li4 
\v 1 ئەمانەش کوڕەکانی داودن کە لە حەبرۆن لەدایک بوون:
\b
\li1 ئەمنۆن کوڕی نۆبەرەی بوو کە لە ئەحینۆعەمی یەزرەعیلی بوو؛
\li1 دووەمیان دانیال کە لە ئەبیگایلی کارمەلی بوو؛
\li1 
\v 2 سێیەمیان ئەبشالۆمی کوڕی مەعکای کچی تەلمەی پاشای گەشوور،
\li1 چوارەمیان ئەدۆنیای کوڕی حەگیس،
\li1 
\v 3 پێنجەمیان شەفەتیا کە لە ئەبیتەل بوو،
\li1 شەشەمیان یەترعام کە لە عەگلای ژنی بوو.
\b
\li4 
\v 4 داود لە حەبرۆن ئەم شەش منداڵەی بوو، لەوێش حەوت ساڵ و شەش مانگ پاشایەتی کرد.
\b
\b
\li4 داود سی و سێ ساڵیش لە ئۆرشەلیم پاشایەتی کرد.
\v 5 ئەم منداڵانەشی لە ئۆرشەلیم لەدایک بوون:
\b
\li1 شەموع، شۆڤاڤ، ناتان و سلێمان هەر چواریان لە بەتشەبەعی کچی عەمیێلەوە بوون.
\li1 
\v 6 هەروەها ئیڤحار، ئەلیشوع، ئەلیفەلەت،
\v 7 نۆگە، نەفەگ، یافیع،
\v 8 ئەلیشاماع، ئەلیاداع و ئەلیفەلەت کە نۆ منداڵ بوون.
\b
\li4 
\v 9 هەموو ئەمانە کوڕانی داود بوون، بێجگە لە کوڕانی کەنیزەکان و تاماری خوشکیان.
\s2 پاشاکانی یەهودا
\li1 
\v 10 کوڕەکەی سلێمان ناوی ڕەحەڤەعام بوو،
\li1 ئەبیا کوڕی ڕەحەڤەعام،
\li1 ئاسا کوڕی ئەبیا،
\li1 یەهۆشافات کوڕی ئاسا،
\li1 
\v 11 یەهۆرام کوڕی یەهۆشافات،
\li1 ئەحەزیا کوڕی یەهۆرام،
\li1 یۆئاش کوڕی ئەحەزیا،
\li1 
\v 12 ئەمەسیا کوڕی یۆئاش،
\li1 عەزەریا کوڕی ئەمەسیا،
\li1 یۆتام کوڕی عەزەریا،
\li1 
\v 13 ئاحاز کوڕی یۆتام،
\li1 حەزقیا کوڕی ئاحاز،
\li1 مەنەشە کوڕی حەزقیا،
\li1 
\v 14 ئامۆن کوڕی مەنەشە و
\li1 یۆشیا کوڕی ئامۆن.
\li1 
\v 15 کوڕەکانی یۆشیا:
\li2 یۆحانان کوڕە نۆبەرەکەی بوو،
\li2 دووەمیان یەهۆیاقیم و
\li2 سێیەمیان سدقیا و
\li2 چوارەمیشیان شەلوم بوو.
\li1 
\v 16 ئەوانەی کە وەک پاشا جێگەی یەهۆیاقیمیان گرتەوە:
\li2 یەهۆیاکین کە کوڕی یەهۆیاقیم بوو،
\li2 دوای ئەویش سدقیا جێگەی یەهۆیاکینی گرتەوە.
\s2 نەوەکانی بنەماڵەی پاشایەتی
\li1 
\v 17 نەوەکانی یەهۆیاکینی دیل:
\li2 شەئەلتیێلی کوڕی،
\v 18 هەروەها مەلکیرام، پەدایا، شەنئەچەر، یەقەمیا، هۆشاماع و نەدەڤیا.
\li1 
\v 19 کوڕەکانی پەدایا:
\li2 زروبابل و شیمعی.
\li1 کوڕەکانی زروبابل:
\li2 مەشولام و حەنەنیا و شەلۆمیتی خوشکیان.
\v 20 هەروەها زروبابل پێنج کوڕی دیکەی هەبوو: حەشوڤا، ئۆهەل، بەرەخیا، حەسەدیا و یوشەڤ‌حەسەد.
\li1 
\v 21 نەوەکانی حەنەنیا:
\li2 پەلەتیا و یەشەعیا، هەروەها کوڕانی ڕەفایا، کوڕانی ئەرنان، کوڕانی عۆبەدیا و کوڕانی شەخەنەیا.
\li1 
\v 22 کوڕەکانی شەخەنەیا شەش بوون:
\li2 شەمەعیای کوڕی و نەوەکانی: حەتوش، یەگال، بارییەح، نەعەریا و شافات.
\li1 
\v 23 کوڕەکانی نەعەریا:
\li2 ئەلیۆعێنەی، حیزقیا و عەزریقام، سێ بوون.
\li1 
\v 24 کوڕەکانی ئەلیۆعێنەی:
\li2 هۆدەڤیا، ئەلیاشیڤ، پەلایا، عەقوڤ، یۆحانان، دەلایا و عەنانی، حەوت بوون.
\c 4
\s2 خێڵەکانی دیکەی یەهودا
\li1 
\v 1 نەوەکانی یەهودا:
\li2 پێرێز، حەسرۆن، کەرمی، حوور و شۆڤاڵ.
\li1 
\v 2 ڕەئایای کوڕی شۆڤاڵیش یەحەتی بوو، یەحەتیش ئەحومەی و لاهەدی بوو، لەمانیشەوە خێڵەکانی چۆرعاتی دروستبوون.
\li1 
\v 3 ئەمانەش کوڕەکانی عێتام بوون:
\li2 یەزرەعیل، یەشما و یەدباش، ناوی خوشکەکەشیان هەچەلەلپۆنی بوو.
\v 4 پەنوئێلیش باوکی گەدۆر و عێزەریش باوکی حوشا بوو.
\li1 ئەمانە نەوەکانی حووری نۆبەرەی ئەفراتەی باوکی بێت‌لەحم بوون.
\li1 
\v 5 ئەشحووری باوکی تەقۆعە دوو ژنی هەبوو، حەلا و نەعەرا.
\li1 
\v 6 نەعەراش ئەحوزام، حێفەر، تێمەنی و هەئەهەشتاری بۆ خستەوە، ئەمانە نەوەکانی نەعەرا بوون.
\li1 
\v 7 کوڕەکانی حەلا:
\li2 چەرەت، چۆحەر و ئەتنان.
\v 8 قۆچیش باوکی عانوڤ و هەچۆڤێڤا بوو، هەروەها باپیرە گەورەی خێڵەکانی ئەحەرحێلی کوڕی هاروم بوو.
\b
\p 
\v 9 یەعبێچیش لە براکانی پایەدارتر بوو و دایکیشی ناوی لێنا یەعبێچ\f + \fr 4:9 \ft یەعبێچ لەو وشە عیبرییەوە نزیکە کە بە واتای ئازار دێت.‏\f* و گوتی: «لەبەر ئەوەی بە ئازارەوە بووم.»
\v 10 یەعبێچ بۆ خودای ئیسرائیل هاواری کرد و گوتی: «خۆزگە بەڕاستی بەرەکەتدارت دەکردم و سنوورەکانت فراوان دەکردم! با دەستت لەگەڵمدا بێت و لە خراپە بمپارێزیت، تاکو ئازار نەچێژم.» خوداش ئەوەی پێدا کە داوای کرد.
\b
\li1 
\v 11 کەلووڤی برای شوحاش مەحیری بوو، مەحیریش باوکی ئەشتۆن بوو،
\v 12 ئەشتۆنیش بێت‌ڕافا و پاسێیەح و تەحینای باوکی عیر ناحاشی\f + \fr 4:12 \ft دەشێت ناوی کەسێک یان شارێک بێت، (شاری ناحاش).‏\f* بوو. ئەمانەش پیاوانی ڕێخا بوون.
\b
\li1 
\v 13 کوڕەکانی قەنەز:
\li2 عۆسنیێل و سەرایا.
\li1 کوڕەکانی عۆسنیێل:
\li2 حەتەت و مەعۆنۆتەی.
\v 14 مەعۆنۆتەیش عۆفرای بوو و
\li1 سەرایاش یۆئابی بوو،
\li2 کە باوکی گێی حەراشیم\f + \fr 4:14 \ft \tl گێی حەراشیم‏\tl* واتا دۆڵی پیشەوەران.‏\f* بوو، شوێنەکەش ناوی ئەوە بوو، چونکە دانیشتووانەکەی پیشەوەر بوون.
\li1 
\v 15 کوڕەکانی کالێبی کوڕی یەفونە:
\li2 عیرو، ئێلە و نەعەم.
\li1 کوڕەکەی ئێلە ناوی
\li2 قەنەز بوو.
\li1 
\v 16 کوڕەکانی یەهەلەلئێل:
\li2 زیف، زیفا، تیریا و ئەسەرئێل.
\li1 
\v 17 کوڕەکانی عەزرە:
\li2 یەتەر، مەرەد، عێفەر و یالۆن.
\li1 یەکێک لە ژنەکانی مەرەد بە مریەم و شەمەی و یەشباحی باوکی ئەشتەمۆعی سکی پڕ بوو،
\v 18 ئەمانە کوڕەکانی بیتیای کچی فیرعەون بوون، کە مەرەد هێنای،
\li1 ئەو ژنەشی کە لە هۆزی یەهودا بوو، یەرەدی باوکی گەدۆر و حەڤەری باوکی سۆخۆ و یەقوتیێلی باوکی زانۆوەحی خستەوە.
\li1 
\v 19 هۆدیا خوشکی نەحەمی هێنا و ئەم کوڕانەی بوو:
\li2 باوکی قەعیلای گارمی و ئەشتەمۆعی مەعکاتی.
\li1 
\v 20 کوڕەکانی شیمۆن:
\li2 ئەمنۆن، ڕینا، بەن‌حانان و تیلۆن.
\li1 نەوەکانی یەشعی:
\li2 زۆحێت و بەن‌زۆحێت.
\li1 
\v 21 کوڕەکانی شالەحی کوڕی یەهودا ئەمانە بوون:
\li2 ئێری باوکی لێخا؛ لەعدای باوکی مارێشا، هەروەها باپیرە گەورەی ئەو بنەماڵانە بوو کە کاری کەتانیان دەکرد و لە بێت‌ئەشبێعە دەژیان؛
\li2 
\v 22 یۆقیم؛ خەڵکی کوزێڤا؛ لەگەڵ یۆئاش و ساراف، ئەوانەی کە لە مۆئاب و یاشوڤی لەحەم فەرمانڕەوایەتییان دەکرد. ئەم ڕەچەڵەکنامەیە لە کۆنەوە تۆمار کرابوو.
\v 23 ئەوانە ئەو گۆزەکەرانە بوون کە دانیشتووانی نەتاعیم و گەدێرا بوون، لەوێدا نیشتەجێ بوون و کاریان بۆ پاشا دەکرد.
\s1 شیمۆن
\li1 
\v 24 نەوەکانی شیمۆن:
\li2 نەموئێل، یامین، یاریڤ، زەرەح و شائوول.
\li2 
\v 25 شەلوم کوڕی شائوول بوو، میبسام کوڕی شەلوم، میشماع کوڕی میبسام.
\li1 
\v 26 نەوەکانی میشماع:
\li2 حەموئێل کوڕی میشماع، زەکور کوڕی حەموئێل، شیمعی کوڕی زەکور.
\b
\p 
\v 27 شیمعیش شازدە کوڕ و شەش کچی هەبوو، بەڵام براکانی کوڕی زۆریان نەبوو و هەموو خێڵەکانیشیان وەک نەوەی یەهودا زیادیان نەکرد.
\v 28 لە بیری شابەع، لە مۆلادا، لە حەچەر شوعال،
\v 29 لە بیلهە، لە عەچەم، لە تۆلاد،
\v 30 لە بتوئێل، لە حۆرما، لە چیقلەگ،
\v 31 لە بێت‌مەرکاڤۆت، لە حەچەر سوسیم، لە بێت‌برئی و لە شەعەرایم نیشتەجێ بوون. ئەمانە شارۆچکەکانیان بوون، هەتا کاتی بەپاشابوونی داود.
\v 32 دەوروبەریشیان عێتام، عەین، ڕیمۆن، تۆخەن و عاشان، واتا پێنج شارۆچکە بوون،
\v 33 لەگەڵ هەموو گوندەکانیان لە چواردەوری ئەو شارۆچکانە هەتا بەعەلات. ئەمانە شوێنی نیشتەجێبوونیان بوون.
\b
\li4 ڕەچەڵەکنامەی ئەمانیش تۆمار کرابوو.
\b
\li1 
\v 34 مەشۆڤاڤ، یەملێک،
\li1 یۆشای کوڕی ئەمەسیا،
\v 35 یۆئێل،
\li1 یێهوی کوڕی یۆشیڤیای کوڕی سەرایای کوڕی عەسیێل،
\li1 
\v 36 هەروەها ئەلیۆعێنەی، یەعقۆڤا، یەشۆحایا،
\li1 عەسایا، عەدیێل، یەسیمیێل، بەنایا و
\li1 
\v 37 زیزای کوڕی شیفعیی کوڕی ئەلۆنی کوڕی یەدایای کوڕی شیمریی کوڕی شەمەعیا.
\b
\li4 
\v 38 ئەوانەی کە ناویان لە سەرەوە تۆمار کراوە سەرۆک خێڵەکانیان بوون.
\b
\p بنەماڵەکانیان زۆر پەلیان هاویشتووە،
\v 39 بۆ گەڕان بەدوای لەوەڕگا بۆ مەڕوماڵاتەکانیان هەتا ڕۆژهەڵاتی دۆڵەکە ڕۆیشتن هەتا گەیشتنە گەدۆر.
\v 40 ئینجا لەوەڕگایەکی بەپیت و چاکیان دۆزییەوە و خاکەکەش بەرفراوان و ئاشتی و ئاسوودەیی تێیدا بەرقەرار بوو، هەروەها هەندێک لە حامییەکان پێشتر لەوێ نیشتەجێ بوون.
\p 
\v 41 ئەوانەی کە ناویان تۆمار کراوە، لە ماوەی پاشایەتی حەزقیای پاشای یەهودا هاتن و پەلاماری چادرەکانی حامییەکان و ئەو مەعونییانەیان دا کە لەوێدا بوون و بە تەواوی قڕیان کردن\f + \fr 4:41 \ft قڕیان کردن: لە زمانی عیبری ئەم زاراوەیە دەگەڕێتەوە بۆ شتێک یان کەسێک کە دەبەخشرێت بە یەزدان، زۆر جار بەخشینەکە بە تەواوی لە ناودەبردرێت.‏\f*. هەتا ئەمڕۆش هیچ مەعۆنییەکی لێ نییە، بەڵکو لە جێی ئەوان نیشتەجێ بوون، چونکە لەوێدا لەوەڕگای لێبوو بۆ مەڕوماڵاتەکانیان.
\v 42 هەروەها لەوان لە نەوەی شیمۆن پێنج سەد پیاو چوون بۆ ناوچە شاخاوییەکانی سێعیر، بە ڕابەری کوڕەکانی یەشعی کە ئەمانە بوون: پەلەتیا، نەعەریا، ڕەفایا و عوزیێل.
\v 43 لە پاشماوەی عەمالێقییە هەڵاتووەکانیان دا و هەتا ئەمڕۆ لەوێدا نیشتەجێ بوون.
\c 5
\s1 ڕەئوبێن
\li4 
\v 1 ڕەئوبێن کوڕە نۆبەرەی ئیسرائیل بوو، بەڵام کاتێک کە پێخەفی باوکی گڵاوکرد، مافی نۆبەرایەتییەکەی درا بە نەوەی یوسفی کوڕی ئیسرائیل، ئیتر لە ڕەچەڵەکنامە بە نۆبەرە تۆمارنەکرا.
\v 2 هەرچەندە یەهودا لە هەموو براکانی بەهێزتر بوو و پاشایەک لە پشتی ئەو دەرچوو، بەڵام نۆبەرایەتییەکە بۆ یوسف بوو.
\v 3 کوڕەکانی ڕەئوبێنی کوڕە نۆبەرەی ئیسرائیل:
\b
\li2 حەنۆک، پەڵو، حەسرۆن و کەرمی.
\li1 
\v 4 نەوەکانی یۆئێل:
\li2 شەمەعیا کوڕی یۆئێل، گۆگ کوڕی شەمەعیا،
\li2 شیمعی کوڕی گۆگ،
\v 5 میخا کوڕی شیمعی،
\li2 ڕەئایا کوڕی میخا، بەعل کوڕی ڕەئایا،
\li2 
\v 6 بئێرە کوڕی بەعل. بئێرەش ئەو کەسە بوو کە تگلەت پلەسەری پاشای ئاشور ڕاپێچی کرد. بئێرە سەرۆکی ڕەئوبێنییەکان بوو.
\li1 
\v 7 خزمەکانیان بەگوێرەی خێڵەکانیان و بەپێی تۆمارکردنیان لە ڕەچەڵەکنامە:
\li2 یەعیێلی سەرکردە، زەکەریا و
\v 8 بەلەعی کوڕی عازازی کوڕی شەمەعی کوڕی یۆئێل.
\b
\p لە عەرۆعێرەوە هەتا نیبۆ و بەعل‌مەعۆن نیشتەجێ بوون.
\v 9 بەرەو ڕۆژهەڵاتیش هەتا دەهاتە بیابانی دەم ڕووباری فورات پەلیان هاویشت، چونکە ئاژەڵەکانیان لە خاکی گلعاددا زۆر ببوون.
\p 
\v 10 لە سەردەمی پاشایەتی شاولدا، جەنگیان لە دژی هاجەرییەکان بەرپا کرد و بەزاندنیان و لە خێوەتەکانی هاجەرییەکان نیشتەجێ بوون لە تەواوی ڕۆژهەڵاتی گلعاددا.
\s1 گاد
\li4 
\v 11 نەوەی گادیش لەتەنیشت نەوەی ڕەئوبێنەوە نیشتەجێ بوون لە خاکی باشانەوە هەتا سەلخە:
\b
\li1 
\v 12 لە باشان یۆئێل سەرکردە و شافام لە پلەی دووەم و یەعنەی و شافات لە پلەی سێیەم بوون.
\li1 
\v 13 خزمەکانیان بەپێی بنەماڵەکانیان حەوت بوون:
\li2 میکائیل، مەشولام، شەڤەع، یۆرەی، یەعکان، زیەع و ئێبەر.
\li2 
\v 14 ئەمانەش کوڕەکانی ئەبیحەیلی کوڕی حوریی کوڕی یارۆحای کوڕی گلعادی کوڕی میکائیلی کوڕی یەشیشەیی کوڕی یەحدۆی کوڕی بووز بوون.
\li2 
\v 15 ئەحیی کوڕی عەبدیێلی کوڕی گۆنی گەورەی بنەماڵەکانیان بوو.
\b
\p 
\v 16 جا گادییەکان لە گلعاد، لە باشان، لە گوندەکانیدا و لە هەموو دەشتاییەکانی شارۆن لەسەر سنوورەکانی نیشتەجێ بوون.
\p 
\v 17 ڕەچەڵەکی هەموو ئەمانە لە ماوەی پاشایەتی یۆتامی پاشای یەهودا و یارۆڤعامی پاشای ئیسرائیلدا تۆمار کران.
\b
\p 
\v 18 نەوەی ڕەئوبێن و گادییەکان و نیوەی هۆزی مەنەشە\f + \fr 5:18 \ft هۆزی مەنەشە دابەش ببوون بۆ سەر دوو بەش، هەریەکەیان کەوتبووە لایەکی ڕووباری ئوردونەوە.‏\f*، لە پیاوە ئازاکان ئەوانەی قەڵغان و شمشێریان هەڵگرتبوو، تیرئەنداز بوون و مەشقی جەنگیان کردبوو، چل و چوار هەزار و حەوت سەد و شەست جەنگاوەر بوون.
\v 19 جەنگیان لە دژی هاجەرییەکان و یەتور و نافیش و نۆداڤ بەرپا کرد و
\v 20 یارمەتییان بۆ هات. هاجەرییەکان و هەموو ئەوانەی لەگەڵیاندا بوون درانە دەستیانەوە، چونکە لە جەنگەکەدا هاواریان بۆ خودا کرد، ئەویش وەڵامی دانەوە، لەبەر ئەوەی پشتیان پێی بەست.
\v 21 هەروەها دەستیان بەسەر ئاژەڵە ماڵییەکانی هاجەرییەکاندا گرت، پەنجا هەزار وشتر و دوو سەد و پەنجا هەزار سەر مەڕ و دوو هەزار گوێدرێژ و لە مرۆڤیش سەد هەزار کەس و
\v 22 ژمارەیەکی زۆر کوژران، لەبەر ئەوەی جەنگەکە لە خوداوە بوو. ئیتر هەتا ڕاپێچکردنەکە لە جێی ئەوان نیشتەجێ بوون.
\s1 نیوەی هۆزی مەنەشە
\p 
\v 23 نیوەی هۆزی مەنەشەش لە خاکەکە نیشتەجێ بوون، لە باشانەوە هەتا بەعل‌حەرمۆن پەلیان هاویشت، کە پێی دەگوترێ سنیر، یان چیای حەرمۆن.
\p 
\v 24 ئەمانەش گەورەکانی بنەماڵەکانیان بوون: عێفەر، یەشعی، ئەلیێل، عەزریێل، یەرمیا، هۆدەڤیا و یەحدیێل، کە هەموو ئەمانە پیاوانی پاڵەوانی ئازا و پیاوانی ناودار و گەورەی بنەماڵەکانیان بوون.
\v 25 بەڵام ناپاکییان لە خودای باوباپیرانیان کرد و بەدوای خوداوەندەکانی گەلانی خاکەکەوە لەشفرۆشییان\f + \fr 5:25 \ft بە واتای لەشفرۆشی جەستەیی و ڕۆحیش دێت. بەو کەسە دەگوترێت کە لاف لێدەدات بەوەفایە بۆ یەزدان، بەڵام لە هەمان کاتدا ستایش و قوربانی بۆ خودایەکی دیکە دەکات. واتا لە بنەڕەتدا کەسەکە بێوەفایە لەگەڵ یەزدان، هەروەک چۆن پیاوێک بێوەفا بێت بەرامبەر بە ژنەکەی.‏\f* کرد، ئەوانەی خودا لەبەردەمیاندا لەناوی بردن.
\v 26 لەبەر ئەوە خودای ئیسرائیل ڕۆحی پولی پاشای ئاشوری هەژاند، کە بە تگلەت پلەسەر بەناوبانگە، ئەویش ڕەئوبێنی و گادییەکان لەگەڵ نیوەی هۆزی مەنەشەی ڕاپێچ کرد. ئەوانی هێنایە حەلەح و خابوور و هارا و ڕووباری گۆزان، هەتا ئەمڕۆش لەوێ ماونەتەوە.
\c 6
\s1 لێڤی
\li1 
\v 1 کوڕەکانی لێڤی:
\li2 گێرشۆن، قەهات و مەراری.
\li1 
\v 2 کوڕەکانی قەهات:
\li2 عەمرام، یەسهار، حەبرۆن و عوزیێل.
\li1 
\v 3 منداڵەکانی عەمرام:
\li2 هارون، موسا و مریەم.
\li1 کوڕەکانی هارون:
\li2 ناداب، ئەبیهو، ئەلعازار و ئیتامار.
\li2 
\v 4 ئەلعازار فینەحاسی بوو،
\li2 فینەحاس ئەبیشوەعی بوو،
\li2 
\v 5 ئەبیشوەع بوقی بوو،
\li2 بوقی عوزیی بوو،
\li2 
\v 6 عوزی زەرەحیای بوو،
\li2 زەرەحیا مەرایۆتی بوو،
\li2 
\v 7 مەرایۆت ئەمەریای بوو،
\li2 ئەمەریا ئەحیتوڤی بوو،
\li2 
\v 8 ئەحیتوڤ سادۆقی بوو،
\li2 سادۆق ئەحیمەعەچی بوو،
\li2 
\v 9 ئەحیمەعەچ عەزەریای بوو،
\li2 عەزەریا یۆحانانی بوو،
\li2 
\v 10 یۆحانانیش عەزەریای بوو ئەوەی کاهینیێتی کرد لەو پەرستگایەدا کە سلێمان لە ئۆرشەلیم بنیادی نا.
\li2 
\v 11 هەروەها عەزەریا ئەمەریای بوو،
\li2 ئەمەریا ئەحیتوڤی بوو،
\li2 
\v 12 ئەحیتوڤ سادۆقی بوو،
\li2 سادۆق شەلومی بوو،
\li2 
\v 13 شەلوم حیلقیای بوو،
\li2 حیلقیا عەزەریای بوو،
\li2 
\v 14 عەزەریا سەرایای بوو و
\li2 سەرایا یەهۆچاداقی بوو.
\li2 
\v 15 یەهۆچاداقیش بەر ئەو ڕاپێچکردنە کەوت کە یەزدان بەسەر یەهودا و ئۆرشەلیمدا هێنای بەدەستی نەبوخودنەسر.
\b
\li1 
\v 16 کوڕەکانی لێڤی:
\li2 گێرشۆن، قەهات و مەراری.
\li1 
\v 17 ئەمەش ناوی دوو کوڕەکەی گێرشۆنە:
\li2 لیبنی و شیمعی.
\li1 
\v 18 کوڕەکانی قەهاتیش:
\li2 عەمرام، یەسهار، حەبرۆن و عوزیێل.
\li1 
\v 19 کوڕەکانی مەراریش:
\li2 مەحلی و موشی.
\b
\li4 ئەمانەش خێڵەکانی لێڤین بەپێی باوباپیرانیان:
\li1 
\v 20 لە گێرشۆن بەرەو خوارەوە:
\li2 لیبنی کوڕی گێرشۆن، یەحەت کوڕی لیبنی،
\li2 زیما کوڕی یەحەت،
\v 21 یۆئاح کوڕی زیما،
\li2 عیدۆ کوڕی یۆئاح، زەرەح کوڕی عیدۆ و
\li2 یەئاتەرەی کوڕی زەرەح.
\li1 
\v 22 نەوەی قەهات:
\li2 عەمیناداب کوڕی قەهات، قۆرەح کوڕی عەمیناداب،
\li2 ئەسسیر کوڕی قۆرەح،
\v 23 ئەلقانە کوڕی ئەسسیر،
\li2 ئەبیاساف کوڕی ئەلقانە، ئەسسیر کوڕی ئەبیاساف،
\li2 
\v 24 تەحەس کوڕی ئەسسیر، ئوریێل کوڕی تەحەس،
\li2 عوزیا کوڕی ئوریێل، شائوول کوڕی عوزیا.
\li1 
\v 25 نەوەی ئەلقانە:
\li2 عەماسەی و ئەحیمۆت کوڕی ئەلقانە بوون،
\li2 
\v 26 ئەحیمۆتیش کوڕەکەی ناوی ئەلقانە بوو، چۆفەییش کوڕی ئەلقانە،
\li2 نەحەت کوڕی چۆفەی،
\v 27 ئەلیاب کوڕی نەحەت،
\li2 یەرۆحام کوڕی ئەلیاب، ئەلقانە کوڕی یەرۆحام،
\li2 ساموئێل کوڕی ئەلقانە.
\li1 
\v 28 کوڕەکانی ساموئێلیش:
\li2 نۆبەرەکەی یۆئێل و
\li2 دووەمیان ئەبیا.
\li1 
\v 29 نەوەی مەراری:
\li2 مەحلی کوڕی مەراری، لیبنی کوڕی مەحلی،
\li2 شیمعی کوڕی لیبنی، عوزا کوڕی شیمعی،
\li2 
\v 30 شیمەعە کوڕی عوزا، حەگییا کوڕی شیمەعە
\li2 و عەسایا کوڕی حەگییا.
\s2 مۆسیقاژەنەکانی پەرستگا
\p 
\v 31 ئەم کەسانە ئەوانە بوون کە داود بۆ سەرپەرشتیکردنی ژەنینی مۆسیقا داینان لە ماڵی یەزدان، پاش ئەوەی سندوقەکەی پەیمان جێگیر بوو.
\v 32 ئەوان لەبەردەم چادری چاوپێکەوتن لەناو چادری پەرستندا بە ژەنینی مۆسیقا خزمەتیان دەکرد، هەتا ئەو کاتەی سلێمان پەرستگای یەزدانی لە ئۆرشەلیمدا بنیاد نا، هەروەها ئەرکەکانیان جێبەجێ دەکرد بەپێی ئەو ڕێکخستنەی بۆیان دانرابوو.
\b
\li4 
\v 33 ئەمانە ئەوانەن لەگەڵ کوڕەکانیاندا خزمەتیان دەکرد:
\b
\li1 لە نەوەی قەهاتییەکان:
\li2 هێیمانی مۆسیقاژەن
\li2 کوڕی یۆئێلی، کوڕی ساموئێلی،
\li2 
\v 34 کوڕی ئەلقانەی، کوڕی یەرۆحامی،
\li2 کوڕی ئەلیێلی، کوڕی تۆوەحی،
\li2 
\v 35 کوڕی چوفی، کوڕی ئەلقانەی،
\li2 کوڕی مەحەتی، کوڕی عەماسەیی،
\li2 
\v 36 کوڕی ئەلقانەی، کوڕی یۆئێلی،
\li2 کوڕی عەزەریای، کوڕی سەفەنیای،
\li2 
\v 37 کوڕی تەحەسی، کوڕی ئەسسیری،
\li2 کوڕی ئەبیاسافی، کوڕی قۆرەحی،
\li2 
\v 38 کوڕی یەسهاری، کوڕی قەهاتی،
\li2 کوڕی لێڤی، کوڕی ئیسرائیل.
\li1 
\v 39 ئاسافی یاریدەدەری دەستەڕاستی هێیمانیش:
\li2 ئاساف کوڕی بەرەخیای، کوڕی شیمەعەی،
\li2 
\v 40 کوڕی میکائیلی، کوڕی بەعەسێیای،
\li2 کوڕی مەلکیای،
\v 41 کوڕی ئەتنیی،
\li2 کوڕی زەرەحی، کوڕی عەدایای،
\li2 
\v 42 کوڕی ئێیتانی، کوڕی زیمای،
\li2 کوڕی شیمعیی،
\v 43 کوڕی یەحەتی،
\li2 کوڕی گێرشۆنی، کوڕی لێڤی؛
\li1 
\v 44 هەروەها لە یاریدەدەرەکانیان کە لە نەوەی مەراری بوون، یاریدەدەری دەستە چەپی هێیمان:
\li2 ئێیتانی کوڕی قیشی، کوڕی عەبدی،
\li2 کوڕی مەلوخی،
\v 45 کوڕی حەشەڤیای،
\li2 کوڕی ئەمەسیای، کوڕی حیلقیای،
\li2 
\v 46 کوڕی ئەمچی، کوڕی بانی،
\li2 کوڕی شەمەری،
\v 47 کوڕی مەحلی،
\li2 کوڕی موشی، کوڕی مەراری،
\li2 کوڕی لێڤی.
\b
\p 
\v 48 برا لێڤییەکانی دیکەیان هەموو خزمەتەکانی دیکەی چادری پەرستنی ماڵی خودایان پێ سپێردرا.
\v 49 بەڵام هارون و نەوەکانی لەسەر قوربانگای قوربانی سووتاندن و قوربانگای بخوور، پێشکەشکراویان پێشکەش دەکرد، لەگەڵ هەموو کارەکانی پەیوەست بەو لە شوێنی هەرە پیرۆز و کەفارەتکردن بۆ ئیسرائیل، بەپێی هەموو ئەوەی موسای بەندەی خودا فەرمانی پێی کرد.
\b
\li1 
\v 50 ئەمانەش نەوەی هارونن:
\li2 ئەلعازار کوڕی هارون، فینەحاس کوڕی ئەلعازار،
\li2 ئەبیشوەع کوڕی فینەحاس،
\v 51 بوقی کوڕی ئەبیشوەع،
\li2 عوزی کوڕی بوقی، زەرەحیا کوڕی عوزی،
\li2 
\v 52 مەرایۆت کوڕی زەرەحیا، ئەمەریا کوڕی مەرایۆت،
\li2 ئەحیتوڤ کوڕی ئەمەریا،
\v 53 سادۆق کوڕی ئەحیتوڤ
\li2 و ئەحیمەعەچ کوڕی سادۆق.
\b
\li4 
\v 54 ئەمانەش ئەو ناوچانەیە کە نەوەی هارون لە خێڵی قەهاتییەکان تێیدا نیشتەجێ بوون، چونکە یەکەم تیروپشک بۆ ئەوان دەرچوو:
\li1 
\v 55 حەبرۆنیان پێدان لە خاکی یەهودا لەگەڵ لەوەڕگاکانی دەوروبەریدا.
\v 56 بەڵام کێڵگە و گوندەکانی دەوروبەری شارەکە بە کالێبی کوڕی یەفونە درا.
\v 57 حەبرۆن کە شارێکی پەناگا بوو درایە نەوەی هارون، هەروەها لیڤنا، یەتیر، ئەشتەمۆع،
\v 58 حیلێن، دەڤیر،
\v 59 عاشان، یوتا و بێت‌شەمەش بە لەوەڕگاکانیانەوە.
\li1 
\v 60 لە خاکی هۆزی بنیامینیش، شارۆچکەکانی گبعۆن\f + \fr 6:60 \ft گبعۆن: بڕوانە \xt یەشوع 21‏:7‏\xt*\ft ‏.‏\f*، گەڤەع، عالەمەت و عەناتۆت بە لەوەڕگاکانیانەوە بەوان درا.
\li4 هەموو شارۆچکەکانیان سێزدە شارۆچکە بوون، بەگوێرەی خێڵەکانیان.
\b
\li1 
\v 61 بە قەهاتییەکانی دیکەش لە خاکی خێڵەکانی نیوەی هۆزی مەنەشە دە شارۆچکە بە تیروپشک درا.
\li1 
\v 62 بە نەوەی گێرشۆنیش، بەگوێرەی خێڵەکانیان، لە خاکی هۆزەکانی یەساخار، ئاشێر، نەفتالی و لەو بەشەی هۆزی مەنەشەش کە لە باشانن، سێزدە شارۆچکە درا.
\li1 
\v 63 بە نەوەی مەراریش بەگوێرەی خێڵەکانیان، لە بەشی هۆزەکانی ڕەئوبێن، گاد و زەبولون بە تیروپشک، دوازدە شارۆچکە درا.
\b
\li4 
\v 64 ئیتر نەوەی ئیسرائیل ئەم شارۆچکانەیان بە لەوەڕگاکانیانەوە بە لێڤییەکان بەخشی.
\b
\li1 
\v 65 هەروەها بە تیروپشک لە هۆزی نەوەی یەهودا و لە هۆزی نەوەی شیمۆن و لە هۆزی نەوەی بنیامین ئەو شارۆچکانەیان دا کە پێشتر ناویان برا.
\b
\li4 
\v 66 هەندێک لە خێڵەکانی قەهاتییەکانیش شارۆچکەکانی سنووریان لە خاکی هۆزی ئەفرایم بوو.
\li1 
\v 67 لە ناوچە شاخاوییەکانی ئەفرایم شاری شەخەم وەک شاری پەناگا و گەزەر و
\v 68 یۆقمەعام و بێت‌حۆرۆن و
\v 69 ئەیالۆن و گەت ڕیمۆن بە لەوەڕگاکانیانەوە درا پێیان.
\li1 
\v 70 لە خاکی نیوەکەی دیکەی هۆزی مەنەشەش، شارۆچکەکانی عانێر و بیلەعام بە لەوەڕگاکانیانەوە، بە خێڵەکانی دیکەی قەهاتییەکان درا.
\b
\li4 
\v 71 نەوەی گێرشۆن ئەم شارۆچکانەیان وەرگرت:
\li1 لە خاکی نیوەی هۆزی مەنەشە، شارۆچکەی گۆلان لە باشان و شارۆچکەی عەشتارۆت بە لەوەڕگاکانیانەوە؛
\li1 
\v 72 لە خاکی هۆزی یەساخاریش، شارۆچکەکانی قەدەش، داڤەرەت،
\v 73 ڕامۆت و عانێم بە لەوەڕگاکانیانەوە؛
\li1 
\v 74 لە خاکی هۆزی ئاشێریش، شارۆچکەکانی ماشال، عەبدۆن،
\v 75 حوقۆق و ڕەحۆڤ بە لەوەڕگاکانیانەوە؛
\li1 
\v 76 لە خاکی هۆزی نەفتالیش، شارۆچکەی قەدەش لە جەلیل و شارۆچکەکانی حەمۆن و قیریاتەیم بە لەوەڕگاکانیانەوە.
\b
\li4 
\v 77 لێڤییەکانی دیکە کە لە نەوەی مەراری بوون ئەم شارۆچکانەیان وەرگرت:
\li1 لە خاکی هۆزی زەبولون، شارۆچکەکانی یۆقنەعام، قەرتا، ڕمۆنۆ و تاڤۆر بە لەوەڕگاکانیانەوە؛
\li1 
\v 78 لە خاکی هۆزی ڕەئوبێن لە بەری ڕۆژهەڵاتی ڕووباری ئوردون بەرامبەر ئەریحا، شارۆچکەی بەچەر لە چۆڵەوانی و شارۆچکەکانی یەهچا،
\v 79 قەدێمۆت و مێفەعەت بە لەوەڕگاکانیانەوە؛
\li1 
\v 80 هەروەها لە خاکی هۆزی گادیش، شارۆچکەی ڕامۆت لە گلعاد و شارۆچکەکانی مەحەنەیم،
\v 81 حەشبۆن و یەعزێر بە لەوەڕگاکانیانەوە.
\c 7
\s1 یەساخار
\li1 
\v 1 کوڕەکانی یەساخاریش چوار بوون:
\li2 تۆلاع، پوڤە، یاشوڤ و شیمرۆن.
\li1 
\v 2 کوڕەکانی تۆلاع:
\li2 عوزی، ڕەفایا، یەریێل، یەحمەی، یەڤسام و ساموئێل، کە گەورەکانی بنەماڵەکانیان بوون. نەوەی تۆلاع بوون و لە ماوەی پاشایەتی داود، ژمارەیان بیست و دوو هەزار و شەش سەد جەنگاوەر بوو، بەپێی ڕەچەڵەکیان کە لە تۆمارەکاندا هاتووە.
\li1 
\v 3 کوڕەکەی عوزی:
\li2 یزرەحیا بوو،
\li1 کوڕەکانی یزرەحیاش:
\li2 میکائیل، عۆبەدیا، یۆئێل و یەشیا، ئەمانە هەر پێنجیان سەرکردە بوون.
\v 4 بەپێی ڕەچەڵەک و بنەماڵەکانیان، سی و شەش هەزار جەنگاوەری ئامادەباشیان هەبوو بۆ جەنگ، چونکە ژن و منداڵیان زۆر بوو.
\li4 
\v 5 خزمەکانیشیان لە هەموو خێڵەکانی یەساخار، جەنگاوەری ئازا بوون بەپێی ڕەچەڵەکیان کە لە تۆمارەکاندا هاتووە بە هەموویانەوە هەشتا و حەوت هەزار جەنگاوەر بوون.
\s1 بنیامین
\li1 
\v 6 کوڕەکانی بنیامینیش سێ بوون:
\li2 بەلەع، بەکەر و یەدیعێل.
\li1 
\v 7 کوڕەکانی بەلەع پێنج بوون:
\li2 ئەچبۆن، عوزی، عوزیێل، یەریمۆت و عیری، ئەمانیش گەورەی بنەماڵەکانیان بوون، نەوەکانیان بەپێی ڕەچەڵەکیان بیست و دوو هەزار و سی و چوار جەنگاوەر بوون.
\li1 
\v 8 کوڕەکانی بەکەریش:
\li2 زەمیرا، یۆعاش، ئەلیعەزەر، ئەلیۆعێنەی، عۆمری، یەرێمۆت، ئەبیا، عەناتۆت و عالەمەت، هەموو ئەمانە کوڕی بەکەر بوون.
\v 9 لەناو ڕەچەڵەکنامەکەیان بیست هەزار و دوو سەد جەنگاوەر تۆمار کران، بەپێی گەورەی بنەماڵەکانیان.
\li1 
\v 10 کوڕەکەی یەدیعێلیش:
\li2 بلهان بوو،
\li1 کوڕەکانی بلهانیش:
\li2 یەعوش، بنیامین، ئێهود، کەنعەنا، زێتان، تەرشیش و ئەحیشاحەر.
\v 11 هەموو ئەوانە گەورەی بنەماڵەکانی یەدیعێل بوون، حەڤدە هەزار و دوو سەد جەنگاوەری ئامادەباش بۆ جەنگ.
\li1 
\v 12 شوپیم و حوپیم لە نەوەی عیر بوون، حوشیمیش لە نەوەی ئەحێر بوو.
\s1 نەفتالی
\li1 
\v 13 کوڕەکانی نەفتالی:
\li2 یەحزئێل، گۆنی، یێچەر و شلێم کە نەوەی بیلهە\f + \fr 7:13 \ft کەنیزەی ڕاحێل بوو، بڕوانە \xt پەیدابوون 29‏:29‏\xt*\ft ‏.‏\f* بوون.
\s1 مەنەشە
\li1 
\v 14 نەوەکانی مەنەشە:
\li2 نەوەی مەنەشە لە کەنیزە ئارامییەکەی: ماکیری باوکی گلعاد. هەروەها ئەسریێل لە نەوەکانیان بوو.
\v 15 ماکیر ژنێکی هێنا ناوی مەعکا بوو، کە خوشکی شوپیم و حوپیم بوو. هەروەها سەلۆفحاد لە نەوەکانی بوو، کە تەنها کچی هەبوو.
\v 16 مەعکای ژنی ماکیر کوڕێکی بوو ناوی لێنا پەرەش و براکەشی ناوی شەرەش بوو، کوڕەکانیشی ناویان ئولام و ڕەقەم بوون.
\li1 
\v 17 کوڕەکەی ئولامیش:
\li2 بدان بوو.
\li1 ئەوانە نەوەی گلعادی کوڕی ماکیری کوڕی مەنەشە بوون.
\li1 
\v 18 هەمۆلەخەتی خوشکی گلعادیش ئیشهۆد و ئەبیعەزەر و مەحلەی بوو.
\li1 
\v 19 کوڕەکانی شەمیداعیش:
\li2 ئەحیان، شەخەم، لیقحی و ئەنیعام.
\s1 ئەفرایم
\li1 
\v 20 نەوەی ئەفرایمیش بەرەو خوارەوە:
\li2 شوتەلەح کوڕی ئەفرایم، بەرەد کوڕی شوتەلەح،
\li2 تەحەس کوڕی بەرەد، ئەلیعادا کوڕی تەحەس،
\li2 تەحەس کوڕی ئەلیعادا،
\v 21 زاڤاد کوڕی تەحەس و
\li2 شوتەلەح کوڕی زاڤاد.
\li2 ئەفرایم دوو کوڕی دیکەشی بوو بە ناوی عێزەر و ئەلعاد، بەڵام کاتێک چوون بۆ ئەوەی ئاژەڵی گەتییەکان ببەن، لەلایەن پیاوانی گەتەوە کە خەڵکی خاکەکە بوون، کوژران.
\v 22 جا ئەفرایمی باوکیان ماوەیەکی درێژ ماتەمینی بۆ گرتن و خزمەکانیشی هاتن بۆ ئەوەی سەرەخۆشی لێ بکەن.
\v 23 پاشان لەگەڵ ژنەکەیدا جووت بووەوە و ژنەکەی سکی پڕ بوو و کوڕێکی بوو و ناوی لێنا بەریعە، چونکە بەڵایەک بەسەر ماڵەکەیدا هاتبوو.
\v 24 هەروەها کچەکەی ناوی شەئرا بوو کە بێت‌حۆرۆنی خواروو و ژووروو و ئوزێن شەئرای بنیاد نا.
\li2 
\v 25 ڕەفەحیش کوڕی ئەفرایم بوو، ڕەشەف کوڕی ڕەفەح،
\li2 تەلەح کوڕی ڕەشەف، تەحەن کوڕی تەلەح،
\li2 
\v 26 لەعدان کوڕی تەحەن، عەمیهود کوڕی لەعدان،
\li2 ئەلیشاماع کوڕی عەمیهود،
\v 27 نون کوڕی ئەلیشاماع و
\li2 یەشوع کوڕی نون.
\li4 
\v 28 زەوی و زار و نشینگەکانیشیان شارۆچکەی بێت‌ئێل و گوندەکانی دەوروبەری بوون، بەرەو ڕۆژهەڵاتیش نەعەران و بەرەو ڕۆژئاواش شارۆچکەی گەزەر و گوندەکانی، هەروەها شارۆچکەی شەخەم و گوندەکانی هەتا عەییا و گوندەکانی.
\v 29 بەلای سنوورەکانی نەوەی مەنەشەشدا، بێت‌شان و تەعنەک و مەگیدۆ و دۆر بوون. لەناو ئەم شارۆچکانە و دەوروبەریاندا نەوەی یوسفی کوڕی ئیسرائیل نیشتەجێ بوون.
\s1 ئاشێر
\li1 
\v 30 کوڕەکانی ئاشێر:
\li2 یمنە، یەشڤە، یەشڤی و بەریعە و سەرەح خوشکیان بوو.
\li1 
\v 31 کوڕەکانی بەریعە:
\li2 حەڤەر و مەلکیێل، مەلکیێل باوکی بیرزایت بوو.
\li1 
\v 32 کوڕەکانی حەڤەر: یەفلێت، شۆمێر و حۆتام و شوەع خوشکیان بوو.
\li1 
\v 33 کوڕەکانی یەفلێت:
\li2 پاسەک، بیمهال و عەشڤات.
\li4 ئەمانە کوڕەکانی یەفلێت بوون.
\li1 
\v 34 کوڕەکانی شۆمێر:
\li2 ئەحی، ڕوهگا، هوبا و ئارام.
\li1 
\v 35 کوڕەکانی هێلەمی براشی:
\li2 چۆفەح، یەمناع، شێلەش و عامال.
\li1 
\v 36 کوڕەکانی چۆفەح:
\li2 سووەح، حەرنەفەر، شوعال، بێری، یەمرا،
\v 37 بەچەر، هۆد، شەما، شیلشا، یەتران و بئێرا.
\li1 
\v 38 کوڕەکانی یەتەر:
\li2 یەفونە، پیسپا و ئەرا.
\li1 
\v 39 کوڕەکانی عولا:
\li2 ئارەح، حەنیێل و ڕیچیا.
\li4 
\v 40 هەموو ئەوانە لە نەوەی ئاشێر بوون. گەورەی بنەماڵە و پیاوی هەڵبژاردە و جەنگاوەر و سەرکردەی دیار بوون. بەپێی ڕەچەڵەکیان لە تۆمارەکاندا ژمارەی ئەو پیاوانەی ئامادەباش بوون بۆ جەنگ بیست و شەش هەزار بوون.
\c 8
\s1 بنەچەی شاولی بنیامینی
\li1 
\v 1 بنیامین بەلەعی بوو کە کوڕە نۆبەرەکەی بوو،
\li2 ئەشبێل دووەم، ئەحەرەح سێیەم،
\li2 
\v 2 نۆحا چوارەم و ڕافا پێنجەم بوو.
\li1 
\v 3 کوڕانی بەلەع:
\li2 ئەدار، گێرا، ئەبیهود،
\v 4 ئەبیشوەع، نەعمان، ئەحۆحا،
\v 5 گێرا، شەفوفان و حورام.
\li1 
\v 6 ئەمانەش نەوەکانی ئیحودن، کە گەورەی بنەماڵەکانی دانیشتووانی گەڤەع بوون و بۆ مەناحەت ڕاگوێزران:
\li2 
\v 7 نەعمان، ئاحییا و گێرا. گێراش سەرپەرشتیاری کۆچکردنیان بوو، هەروەها باوکی عوزە و ئەحیحود بوو.
\li1 
\v 8 شەحەرەیم لە وڵاتی مۆئاب چەند کوڕێکی بوو، پاش ئەوەی حوشیم و بەعرای ژنی تەڵاق دا،
\v 9 لە حۆدەشی ژنی، یۆڤاڤ، چیبیا، مێشا، مەلکام،
\v 10 یەعوچ، ساخیا و میرمای بوو، ئەوانە کوڕەکانی بوون و گەورەی بنەماڵەکانیان بوون.
\v 11 لە حوشیمی ژنیشی ئەبیتوڤ و ئەلپەعەلی بوو.
\li1 
\v 12 کوڕەکانی ئەلپەعەل:
\li2 عێبەر، میشعام و شەمەد، شەمەد ئەوەی کە شارۆچکەی ئۆنۆ و شارۆچکەی لۆد و دەوروبەری بنیاد نا.
\v 13 هەروەها بەریعە و شەمەع، ئەوان گەورەی بنەماڵەکانی دانیشتووانی ئەیالۆن بوون و ئەوان دانیشتووانی گەتیان وەدەرنا.
\li1 
\v 14 هەروەها ئەحیۆ، شاشاق، یەرێمۆت،
\v 15 زەڤەدیا، عەراد، عەدەر،
\v 16 میکائیل، یەشپا و یۆحا، کوڕی بەریعە بوون.
\li1 
\v 17 زەڤەدیا، مەشولام، حیزقی، حەڤەر،
\v 18 یەشمەری، یزلیا و یۆڤاڤ کوڕی ئەلپەعەل بوون.
\li1 
\v 19 یاقیم، زکری، زەبدی،
\v 20 ئەلیعێنەی، چیلەتەی، ئەلیێل،
\v 21 عەدایا، بەرایا و شیمرات کوڕی شیمعی بوون.
\li1 
\v 22 یەشپەن، عێبەر، ئەلیێل،
\v 23 عەبدۆن، زکری، حانان،
\v 24 حەنەنیا، ئیلام، عەنتۆتیا،
\v 25 یەفدەیا و پەنوئێل کوڕی شاشاق بوون.
\li1 
\v 26 شەمشەرەی، شەحەریا، عەتەلیا،
\v 27 یەعەرەشیا، ئەلیاس و زکری کوڕی یەرۆحام بوون.
\li4 
\v 28 ئەمانە گەورەی بنەماڵەکانیان و بەپێی ڕەچەڵەکیان کە لە تۆمارەکاندا هاتووە سەرکردە بوون و لە ئۆرشەلیمدا نیشتەجێ بوون.
\b
\li1 
\v 29 یەعیێلی باوکی گبعۆنیش لە گبعۆندا نیشتەجێ بوو.
\li2 ژنەکەی ناوی مەعکا بوو،
\v 30 عەبدۆن کوڕە نۆبەرەکەی بوو، پاشان چوور، قیش، بەعل، نێر، ناداب،
\v 31 گەدۆر، ئەحیۆ، زەکەریا و
\v 32 میقلۆت بوو، میقلۆتیش شیمەعای بوو. ئەوانیش لەگەڵ خزمەکانیان، لە نزیکی یەکتر لە ئۆرشەلیم نیشتەجێ بوون.
\li1 
\v 33 نێر قیشی بوو، قیش شاولی بوو، شاولیش ئەم کوڕانەی بوو: یۆناتان، مەلکی‌شوەع، ئەبیناداب و ئەشبەعل\f + \fr 8:33 \ft ئەشبەعل: هەروەها بە ناوی ئیشبۆشەت ناسراوە.‏\f*.
\li1 
\v 34 یۆناتان مەریڤ‌بەعلی بوو،
\li2 مەریڤ‌بەعلیش\f + \fr 8:34 \ft مەریڤ‌بەعل: هەروەها بە ناوی مەفیبۆشەت ناسراوە.‏\f* میخای بوو.
\li1 
\v 35 ئەمانە کوڕەکانی میخا بوون:
\li2 پیتۆن، مەلەخ، تەرێیەع و ئاحاز.
\li2 
\v 36 ئاحاز یەهۆعەدای بوو، یەهۆعەداش ئەم کوڕانەی بوو: عالەمەت، عەزماڤێت و زیمری؛ زیمریش مۆچای بوو.
\v 37 مۆچا بینەعای بوو، بینەعا ڕافەی بوو، ڕافە ئەلیعاسای بوو، ئەلیعاسا ئاچێلی بوو.
\li1 
\v 38 ئاچێل شەش کوڕی هەبوو، ئەمەش ناوەکانیانە:
\li2 عەزریقام، بۆخەرو، ئیسماعیل، شەعەریا، عۆبەدیا و حانان. هەموو ئەمانە کوڕەکانی ئاچێل بوون.
\li1 
\v 39 کوڕەکانی عێشەقی برای:
\li2 ئولام کوڕە نۆبەرەکەی بوو، یەعوش دووەم و ئەلیفەلەت سێیەم بوو.
\v 40 کوڕەکانی ئولامیش پاڵەوانی ئازا و تیرئەنداز بوون و کوڕ و کوڕەزایەکی زۆریان هەبوو و هەموویان سەد و پەنجا کەس بوون.
\li1 ئەمانە هەموویان لە نەوەی بنیامین بوون.
\b
\c 9
\p 
\v 1 ڕەچەڵەکی هەموو ئیسرائیل تۆمارکرا و لە پەڕتووکی پاشاکانی ئیسرائیل و یەهودا نووسراون. بەهۆی ناپاکییانەوە بۆ بابل ڕاپێچ کران.
\s1 دانیشتووانی ئۆرشەلیم
\li4 
\v 2 ئەوانەی کە یەکەم جار گەڕانەوە و لەناو زەوی و زار و شارۆچکەکانی خۆیاندا نیشتەجێ بوون، هەندێک ئیسرائیلی و کاهین و لێڤی و خزمەتکارانی پەرستگا بوون.
\b
\li4 
\v 3 ئەوانەی لە نەوەی یەهودا، لە نەوەی بنیامین، لە نەوەی ئەفرایم و مەنەشە لە ئۆرشەلیمدا نیشتەجێ بوون، ئەمانە بوون:
\li1 
\v 4 عوتەیی کوڕی عەمیهودی کوڕی عۆمری کوڕی ئیمریی کوڕی بانی لە نەوەی پێرێزی کوڕی یەهودا بوو؛
\li1 
\v 5 لە شالەحییەکان:
\li2 عەسایای نۆبەرە و کوڕەکانی؛
\li1 
\v 6 لە نەوەی زەرەح:
\li2 یەعوئێل؛
\li4 سەرجەم ئەوانەی لە نەوەی یەهودا لە ئۆرشەلیم نیشتەجێ بوون شەش سەد و نەوەد کەس بوون.
\b
\li4 
\v 7 لە نەوەی بنیامین:
\li1 سەلوی کوڕی مەشولامی کوڕی هۆدەڤیای کوڕی هەسەنوئا؛
\li1 
\v 8 یەڤنەیای کوڕی یەرۆحام؛
\li1 ئێلەی کوڕی عوزی کوڕی میخری
\li1 و مەشولامی کوڕی شەفەتیای کوڕی ڕەعوئێلی کوڕی یەڤنییا.
\li4 
\v 9 سەرجەم نەوەی بنیامین کە بەپێی ڕەچەڵەکیان تۆمار کرابوون، نۆ سەد و پەنجا و شەش کەس بوون. هەموو ئەم پیاوانەی گەورەی بنەماڵەکانیان بوون.
\b
\li4 
\v 10 لە کاهینەکان:
\li1 یەدایا، یەهۆیاریڤ، یاکین،
\li1 
\v 11 عەزەریای کوڕی حیلقیای کوڕی مەشولامی کوڕی سادۆقی کوڕی مەرایۆتی کوڕی ئەحیتوڤی لێپرسراوی ماڵی خودا بوو؛
\li1 
\v 12 عەدایای کوڕی یەرۆحامی کوڕی پەشحوری کوڕی مەلکیا
\li1 و مەعسەیی کوڕی عەدیێلی کوڕی یەحزێرای کوڕی مەشولامی کوڕی مەشیلێمیتی کوڕی ئیمێر.
\li4 
\v 13 سەرجەم کاهینەکان، کە گەورەی بنەماڵەکانیان بوون، هەزار و حەوت سەد و شەست کەس بوون. بە توانا و بەرپرسیار بوون بۆ ئەنجامدانی خزمەتی ماڵی خودا.
\b
\li4 
\v 14 لە لێڤییەکان:
\li1 شەمەعیای کوڕی حەشوڤی کوڕی عەزریقامی کوڕی حەشەڤیا لە نەوەی مەراری؛
\li1 
\v 15 بەقبەقەر و حەرەش و گالال و مەتەنیای کوڕی میکای کوڕی زکری کوڕی ئاساف؛
\li1 
\v 16 عۆبەدیای کوڕی شەمەعیای کوڕی گالالی کوڕی یەدوتون؛
\li1 هەروەها بەرەخیای کوڕی ئاسای کوڕی ئەلقانە، کە لە گوندەکانی نەتۆفاییەکان نیشتەجێ بوو.
\b
\li4 
\v 17 دەرگاوانەکان:
\li1 شەلوم، عەقوڤ، تەلمۆن، ئەحیمەن و براکانیان، شەلوم سەرۆکیان بوو.
\v 18 هەتا ئەو کاتەش لەلای ڕۆژهەڵاتی دەروازەی پاشا، ئەوان دەرگاوانی ئۆردوگای نەوەی لێڤی بوون.
\li1 
\v 19 شەلومی کوڕی قۆرێی کوڕی ئەبیاسافی کوڕی قۆرەح و براکانی، ئەوانەی لە بنەماڵەی قۆرەحییەکان بوون، ئەرکی خزمەت و پاسەوانیێتی بەردەرگاکانی پەرستگاکەیان\f + \fr 9:19 \ft لە زمانی عیبری بە وشەی \tl ئۆهەل‏\tl* واتا (چادرەکە) هاتووە، کە مەبەستی لە پەرستگاکەیە، لێرە و لە ئایەتەکانی 21‏،23.‏\f* لە ئەستۆ بوو، هەروەک چۆن باوباپیرانیشیان ئەرکی پاسەوانیێتی دەروازەی چادری پەرستنی یەزدانیان لە ئەستۆ گرتبوو.
\li1 
\v 20 پێشتر فینەحاسی کوڕی ئەلعازار سەرۆکی دەرگاوانەکان بوو و یەزدانیش لەگەڵیدا بوو.
\li1 
\v 21 زەکەریای کوڕی مەشەلەمیاش دەرگاوانی دەرگای چادری چاوپێکەوتن بوو.
\li4 
\v 22 هەموو ئەوانەی بە دەرگاوانی بەردەرگاکان هەڵبژێردران دوو سەد و دوازدە کەس بوون و بەپێی ڕەچەڵەکیان لە گوندەکانیاندا تۆمار کران.
\b
\p باوباپیرانیان لەلایەن داود و ساموئێلی پێشبینیکەرەوە لەسەر ئەو بەرپرسیاریێتییە دانرابوون.
\v 23 خۆیان و نەوەکانیان ئەرکی پاسەوانیێتی دەرگاکانی ماڵی یەزدانیان لە ئەستۆ بوو، ئەو ماڵەی کە پێ دەگوترا چادری چاوپێکەوتن.
\v 24 دەرگاوانەکان لە هەر چوار لادا بوون، ڕۆژهەڵات و ڕۆژئاوا و باکوور و باشوور.
\v 25 دەبووایە برا لێڤییەکانیشیان بە نۆرە لە گوندەکانیانەوە بێن و لە جێی ئەوان بۆ ماوەی حەوت ڕۆژ پاسەوان بن.
\v 26 بەڵام هەر چوار سەرۆکی دەرگاوانەکان، کە لێڤی بوون، بەرپرسی ژوور و گەنجینەکانی ماڵی خودا بوون.
\v 27 لە چواردەوری ماڵی خودا شەویان بەسەردەبرد، چونکە پاسەوانیێتییان لەسەر بوو، هەروەها هەموو بەیانییەک لێپرسراوی کردنەوەی بوون.
\p 
\v 28 هەندێکیشیان لێپرسراوی قاپوقاچاغەکانی خزمەتکردن\f + \fr 9:28 \ft خزمەتکردن: واتا خزمەت لە پەرستگادا.‏\f* بوون، چونکە بە ژمارە دەیانهێنانە دەرەوە و بە ژمارەش دەیانبردنەوە ژوورەوە.
\v 29 هەندێکی دیکەشیان ئەمینداری قاپوقاچاغەکان و هەموو کەلوپەلەکانی پیرۆزگا و باشترین ئارد و شەراب و زەیتی زەیتوون و بخوور و بۆنوبەرام بوون.
\v 30 هەندێک لە نەوەی کاهینەکانیش بۆنوبەرامەکانیان دەگرتەوە.
\v 31 مەتیسیا یەکێک بوو لە لێڤییەکان، ئەو نۆبەرەی شەلومی قۆرەحی بوو، بەرپرسیار بوو بۆ ئامادەکردنی نانی پێشکەشکراو.
\v 32 هەندێکیش لە نەوەی قەهاتییەکان، لە برا لێڤییەکانیان، بەرپرسیار بوون لە ئامادەکردنی نانی تەرخانکراو هەموو ڕۆژانێکی شەممە.
\p 
\v 33 مۆسیقاژەنەکان کە گەورەی بنەماڵەی لێڤییەکان بوون لە ژوورەکانی پەرستگا جێگیر بوون و لە کاری دیکە بەخشرابوون، چونکە ئەوان بەردەوام بە ڕۆژ و بە شەو سەرقاڵی کارەکەیان بوون.
\p 
\v 34 ئەمانە گەورەی بنەماڵە لێڤییەکان بوون، بەپێی ڕەچەڵەکیان کە لە تۆمارەکاندا هاتووە سەرکردە بوون و لە ئۆرشەلیم نیشتەجێ بوون.
\s1 بنەچەی شاول
\li1 
\v 35 یەعیێلی باوکی گبعۆنیش لە گبعۆندا نیشتەجێ بوو.
\li2 ژنەکەی ناوی مەعکا بوو،
\v 36 عەبدۆن کوڕە نۆبەرەکەی بوو، پاشان چوور، قیش، بەعل، نێر، ناداب،
\v 37 گەدۆر، ئەحیۆ، زەکەریا و میقلۆت،
\v 38 میقلۆتیش شیمەئامی بوو. ئەوانیش لەگەڵ خزمەکانیان، لە نزیکی یەکتر لە ئۆرشەلیم نیشتەجێ بوون.
\li1 
\v 39 نێر قیشی بوو، قیش شاولی بوو، شاولیش ئەم کوڕانەی بوو: یۆناتان، مەلکی‌شوەع، ئەبیناداب و ئەشبەعل\f + \fr 9:39 \ft ئەشبەعل: هەروەها بە ناوی ئیشبۆشەت ناسراوە.‏\f*.
\li1 
\v 40 یۆناتان مەریڤ‌بەعلی بوو،
\li2 مەریڤ‌بەعلیش\f + \fr 9:40 \ft مەریڤ‌بەعل: هەروەها بە ناوی مەفیبۆشەت ناسراوە.‏\f* میخای بوو.
\li1 
\v 41 ئەمانە کوڕەکانی میخا بوون:
\li2 پیتۆن، مەلەخ، تەحرێیەع و ئاحاز.
\li2 
\v 42 ئاحاز یادای بوو، یاداش ئەم کوڕانەی بوو: عالەمەت، عەزماڤێت و زیمری، زیمریش مۆچای بوو.
\v 43 مۆچا بینەعای بوو، بینەعا ڕەفایای بوو، ڕەفایا ئەلیعاسای بوو، ئەلیعاسا ئاچێلی بوو.
\li1 
\v 44 ئاچێل شەش کوڕی هەبوو، ئەمەش ناوەکانیانە:
\li2 عەزریقام، بۆخەرو، ئیسماعیل، شەعەریا، عۆبەدیا و حانان. ئەمانە کوڕەکانی ئاچێل بوون.
\c 10
\s1 خۆکوشتنی شاول
\p 
\v 1 فەلەستییەکان لە دژی ئیسرائیل جەنگان و پیاوانی ئیسرائیل لەبەردەم فەلەستییەکان هەڵاتن، ژمارەیەکی زۆریان بە کوژراوی لە کێوی گلبۆع کەوتن.
\v 2 فەلەستییەکان بە گوڕەوە دوای شاول و کوڕەکانی کەوتن، یۆناتان و ئەبیناداب و مەلکی‌شوەعی کوڕەکانی شاولیان کوشت.
\v 3 جەنگەکە لەسەر شاول توندتر بوو، تیرهاوێژەکان دۆزییانەوە و پێکایان.
\p 
\v 4 شاول بە هەڵگری تفاقەکانی گوت: «شمشێرەکەت دەربێنە و بمکوژە، نەوەک ئەو خەتەنەنەکراوانە بێن و سووکایەتیم پێ بکەن.»
\p بەڵام هەڵگری تفاقەکانی ڕازی نەبوو، چونکە زۆر ترسا. جا شاول شمشێرەکەی برد و خۆی بەسەریدا دا.
\v 5 کاتێک هەڵگری تفاقەکانی بینی شاول مردووە، ئەویش خۆی بەسەر شمشێرەکەیدا دا و مرد.
\v 6 شاول و هەر سێ کوڕەکەی و هەموو ماڵەکەی پێکەوە مردن.
\p 
\v 7 کاتێک هەموو ئەو ئیسرائیلییانەی لەناو دۆڵەکەدا بوون، بینییان کە سوپاکە هەڵاتوون و شاول و کوڕەکانی مردوون، شارۆچکەکانیان بەجێهێشت و هەڵاتن، فەلەستییەکانیش هاتن و تێیاندا نیشتەجێ بوون.
\p 
\v 8 بۆ ڕۆژی دوای ئەوە کاتێک فەلەستییەکان بۆ تاڵانکردنی کوژراوەکان هاتن، شاول و کوڕەکانی ئەویان دۆزییەوە لە کێوی گلبۆع کەوتبوون.
\v 9 ئینجا ڕووتیان کردەوە و کەللەسەر و زرێیەکەیان\f + \fr 10:9 \ft زرێ: بەڕگێکی کانزاییە کە لە کاتی شەڕ دەپۆشرێت.‏\f* برد، بە هەموو لایەکدا نێردراویان بۆ خاکی فەلەستییەکان نارد، تاوەکو مژدە بدەنە بتەکانیان و گەلەکەیان.
\v 10 ئینجا زرێیەکەیان لە پەرستگای خوداوەندەکانیاندا دانا و کەللەسەریشیان لەناو پەرستگای داگۆن هەڵواسی.
\p 
\v 11 کاتێک هەموو دانیشتووانی یاڤێش گلعاد ئەو شتانەیان بیستەوە کە فەلەستییەکان بە شاولیان کردبوو،
\v 12 هەموو پیاوە دلێرەکانیان هەستان و لاشەکەی شاول و لاشەی کوڕەکانی ئەویان هەڵگرت و هێنایاننە یاڤێش. لەژێر دار بەڕووەکەی یاڤێش ئێسکەکانیان ناشت، حەوت ڕۆژ بەڕۆژوو بوون.
\p 
\v 13 شاول مرد بەهۆی ناپاکییەکەی کە لە بەرامبەر یەزدان کردی، کە فەرمایشتی یەزدانی پەیڕەو نەکرد، تەنانەت پرسوڕای بە نێوانگر\f + \fr 10:13 \ft نێوانگر: لێرەدا بەو واتایە دێت، کەسێکە کە گوایە هۆی پەیوەندی ڕێکخەرە لەنێوان خەڵکی مردوو و زیندوودا. بڕوانە \xt لێڤییەکان 20‏:6‏\xt*\ft ‏.‏\f* کرد بۆ ڕێنمایی و
\v 14 داوای ڕێنمایی لە یەزدان نەکرد، جا یەزدان کوشتی و پاشایەتییەکەشی دایە دەست داودی کوڕی یەسا.
\c 11
\s1 بەپاشابوونی داود لە ئیسرائیل
\p 
\v 1 هەموو ئیسرائیل هاتنە حەبرۆن بۆ لای داود و گوتیان: «ئەوەتا ئێمە لە گۆشت و خوێنی تۆین.
\v 2 لە ڕابردوودا و تەنانەت کاتێک کە شاولیش پاشامان بوو، تۆ هەر ڕابەرایەتی سوپای ئیسرائیلت دەکرد، یەزدانی پەروەردگاریشت پێی فەرموویت: ”تۆ شوانایەتی ئیسرائیلی گەلەکەم دەکەیت و دەبیتە فەرمانڕەوایان.“»
\p 
\v 3 هەروەها هەموو پیرانی ئیسرائیل هاتنە حەبرۆن بۆ لای پاشا، داودیش لەبەردەم یەزدان لە حەبرۆن پەیمانی لەگەڵدا بەستن، ئەوانیش بەپێی فەرمایشتی یەزدان کە لە ڕێگەی ساموئێلەوە فەرمووبووی، داودیان بە پاشای ئیسرائیل دەستنیشان کرد.
\s1 داود ئۆرشەلیم داگیر دەکات
\p 
\v 4 داود و هەموو ئیسرائیل چوونە ئۆرشەلیم (کە لەو کاتەدا پێی دەگوترا یەبوسە). یەبوسییەکانی دانیشتووانی خاکەکەش
\v 5 بە داودیان گوت: «تۆ ناتوانیت بێیت بۆ ئێرە.» بەڵام داود دەستی بەسەر قەڵای سییۆندا گرت کە ئێستا بە شاری داود ناسراوە.
\p 
\v 6 داود پێشتر گوتبووی: «ئەوەی یەکەم جار لە یەبوسییەکان بدات دەبێتە فەرماندەی گشتی سوپا.» یۆئابی کوڕی چەرویا یەکەم جار سەرکەوت و بووە سەرکردە.
\p 
\v 7 پاشان داود لە قەڵاکە نیشتەجێ بوو، لەبەر ئەوە ناویان نا شاری داود.
\v 8 شارەکەی بە چواردەوریدا فراوان کرد، لە تەلانەکانەوە\f + \fr 11:8 \ft تەلان: بەرازاییەکانیان لە شێوەی پایە ڕێکخستووە، بۆ پاڵپشتی کۆشکی پاشا سوودی لێ وەرگیراوە.‏\f* هەتا شووراکەی چواردەوری. یۆئابیش پاشماوەی شارەکەی نۆژەن کردەوە.
\v 9 هەروەها داود هەتا دەهات مەزنتر دەبوو، یەزدانی سوپاسالاریش لەگەڵی بوو.
\s1 پاڵەوانەکانی داود
\p 
\v 10 ئەمانەش سەرکردە پاڵەوانەکانی داود بوون، ئەوانەی کە لەگەڵ هەموو ئیسرائیل پشتگیری بەهێزیان لە پاشایەتییەکەی دەکرد، بۆ ئەوەی هەموو خاکەکە بخەنە ژێر ڕکێفی داود، هەروەک چۆن یەزدان بەڵێنی پێدابوو.
\v 11 ئەمەش لیستی پاڵەوانەکانی داودە:
\p یاشۆڤەعامی کوڕی حەکمۆنی یەکێک بوو لە سێ پاڵەوانەکەی نێو هێزی تایبەت. ئەو بوو بە ڕمەکەی لە شەڕێکدا سێ سەد کەسی کوشت.
\p 
\v 12 پاش ئەویش، ئەلعازاری کوڕی دۆدایی ئەحۆحی هەبوو، کە یەکێک بوو لە سێ پاڵەوانەکە.
\v 13 ئەو لە پەس دەممیم لەگەڵ داود بوو، کاتێک فەلەستییەکان لەوێ بۆ جەنگ کۆببوونەوە. لە کێڵگەیەکی پڕ لە جۆ لەشکرەکە لەبەردەم فەلەستییەکاندا هەڵات،
\v 14 بەڵام ئەلعازار و داود لە ناوەڕاستی کێڵگەکەدا ڕاوەستان. بەرگرییان کرد و لە فەلەستییەکانیان دا، یەزدانیش سەرکەوتنێکی گەورەی پێ بەخشین.
\p 
\v 15 سێ پاڵەوانی هەڵبژاردە لە ڕیزی سی پاڵەوانەکەی هێزی تایبەت بۆ لای داود دابەزین، بۆ سەر گابەردەکە لە ئەشکەوتی عەدولام، لەشکری فەلەستییەکانیش لە دۆڵی ڕفایم دامەزرابوون.
\v 16 لەو کاتەدا داود لە قەڵاکە بوو، سەربازگەی فەلەستییەکانیش لە بێت‌لەحم بوو.
\v 17 داود ئاهی هەڵکێشا و گوتی: «خۆزگە کەسێک لە بیرەکەی لای دەروازەکەی بێت‌لەحم ئاوی بۆ دەهێنام!»
\v 18 ئیتر ئەو سێیە هێڵی ئۆردوگای فەلەستییەکانیان بەزاند و لە بیرەکەی بێت‌لەحمەوە ئەوەی لەلای دەروازەکەیە ئاویان هەڵکێشا و هەڵیانگرت، هێنایان بۆ داود، ئەویش نەیویست بیخواتەوە، بەڵکو وەک پێشکەشکراوێک بۆ یەزدان ڕشتی.
\v 19 گوتی: «ئەی خودایە، لە من بەدوور بێت، ئەمە بکەم. ئایا خوێنی ئەم پیاوانە بخۆمەوە کە ژیانی خۆیان خستە مەترسییەوە؟» لەبەر ئەوەی بە هێنانی ئەم ئاوە ژیانی خۆیان خستە مەترسییەوە، داود نەیویست بیخواتەوە.
\p ئەمانە چەند نموونەیەک بوون لە ئازایەتییەکانی سێ پاڵەوانەکە.
\p 
\v 20 ئەبیشەی برای یۆئاب ڕابەری سێ پاڵەوانەکەی هێزی تایبەت بوو. ئەو بە ڕمەکەی لەگەڵ سێ سەد کەس جەنگا و کوشتنی، وەک سێ پاڵەوانەکە ناوبانگی هەبوو.
\v 21 ئەو دوو ئەوەندە زیاتر لە سێ پاڵەوانەکە ڕێزی لێ دەگیرا و بووە فەرماندەیان، بەڵام ناوبانگی نەدەگەیشتە سێیەکەی یەکەم.
\p 
\v 22 بەنایای کوڕی یەهۆیاداعی خەڵکی قەڤچەئێل کوڕێکی بەجەرگ بوو، زۆر قارەمانیێتی نواندبوو. هەر ئەو لە دوو شێرە پیاوەکەی مۆئابی دا، هەروەها لە ڕۆژێکی بەفردا دابەزییە ناو چاڵێک و شێرێکی کوشت.
\v 23 ئەویش بوو کە لە پیاوێکی میسری زەبەلاحی دا، باڵای پێنج باڵ\f + \fr 11:23 \ft پێنج باڵ: نزیکەی 2,3 مەتر.‏\f* بوو، پیاوە میسرییەکە ڕمێکی بەدەستەوە بوو وەک نۆردی جۆڵاکان بوو، بەنایاش بە گۆچانێکەوە بۆی دابەزی. ڕمەکەی لە دەستی میسرییەکە ڕفاند و بە ڕمەکەی خۆی کوشتی.
\v 24 ئەمانە چەند نموونەیەک بوون لە ئازایەتییەکانی بەنایای کوڕی یەهۆیاداع، وەک سێ پاڵەوانەکە ناوبانگی پەیدا کرد.
\v 25 لە سی پاڵەوانەکە زیاتر ڕێزی لێ دەگیرا، بەڵام ناوبانگی نەگەیشتە سێیەکە، ئیتر داود کردییە بەرپرسی پاسەوانەکانی خۆی.
\b
\li4 
\v 26 ئەمانەش جەنگاوەرە قارەمانەکان بوون:
\b
\li1 عەساهێلی برای یۆئاب،
\li1 ئێلحانانی کوڕی دۆدۆی بێت‌لەحمی،
\li1 
\v 27 شەمۆتی هەراری،
\li1 حەلەچی پەلۆنی،
\li1 
\v 28 عیرای کوڕی عیقێشی تەقۆعی،
\li1 ئەبیعەزەری عەناتۆتی،
\li1 
\v 29 سیبەخەیی حوشاتی،
\li1 عیلەیی ئەحۆحی،
\li1 
\v 30 مەهەرەیی نەتۆفایی،
\li1 حێلەدی کوڕی بەعەنای نەتۆفایی،
\li1 
\v 31 ئیتەیی کوڕی ڕیڤەی کە خەڵکی گیڤعای بنیامین بوو،
\li1 بەنایای پیرعاتۆنی،
\li1 
\v 32 حورەیی لە شیوەکانی گاعەشەوە،
\li1 ئەبیێلی عەرڤاتی،
\li1 
\v 33 عەزماڤێتی بەحەرومی،
\li1 ئەلیەحبای شەعەلڤۆنی،
\li1 
\v 34 کوڕەکانی هاشێمی گیزۆنی،
\li1 یۆناتانی کوڕی شاگێی هاراری،
\li1 
\v 35 ئەحیامی کوڕی ساکاری هاراری،
\li1 ئەلیفەلی کوڕی ئوور،
\li1 
\v 36 حێفەری مەخێراتی،
\li1 ئاحییای پەلۆنی،
\li1 
\v 37 حەسرۆی کارمەلی،
\li1 نەعرەیی کوڕی ئەزبای،
\li1 
\v 38 یۆئێلی برای ناتان،
\li1 میڤحاری کوڕی هەگری،
\li1 
\v 39 چەلەقی عەمۆنی،
\li1 نەحەرەیی بئێرۆتی کە هەڵگری تفاقەکانی یۆئابی کوڕی چەرویا بوو،
\li1 
\v 40 عیرای یەتری،
\li1 گارێڤی یەتری،
\li1 
\v 41 ئوریای حیتی،
\li1 زاڤادی کوڕی ئەحلای،
\li1 
\v 42 عەدینای کوڕی شیزای ڕەئوبێنی کە سەرۆکی ڕەئوبێنییەکان بوو و سی پیاوی لەگەڵدا بوو،
\li1 
\v 43 حانانی کوڕی مەعکا،
\li1 یۆشافاتی میسنی،
\li1 
\v 44 عوزییای عەشتەراتی،
\li1 کوڕەکانی حۆتامی عەرۆعێری کە شاماع و یەعیێل بوون،
\li1 
\v 45 یەدیعێلی کوڕی شیمری و
\li1 براکەشی بە ناوی یۆحای تیچی،
\li1 
\v 46 ئەلیێلی مەحەڤی،
\li1 هەردوو کوڕەکەی ئەلناعەم کە یەریڤەی و یۆشەڤیا بوون،
\li1 هەروەها یەتمای مۆئابی،
\li1 
\v 47 ئەلیێل، عوبێد و یەعسیێلی مەچۆڤایای.
\c 12
\s1 هاتنەپاڵی پاڵەوانان بۆ لای داود
\li4 
\v 1 ئەمەش ناوی ئەو پیاوانەیە کە هاتنە لای داود بۆ چیقلەگ، کاتێک کە هێشتا لە ئامادەبوونی لەبەردەم شاولی کوڕی قیش دوورخرابووەوە. ئەوانە لەو پاڵەوانانە بوون کە لە جەنگدا یارمەتیدەری بوون.
\v 2 لە خزم و کەسوکارە نزیکەکانی شاول و لە هۆزی بنیامین بوون، ئەوان دەیانتوانی بە دەستی ڕاست و دەستی چەپیشیان تیر بە کەوان بهاوێژن و بەردیش بە قۆچەقانی:
\b
\li1 
\v 3 ئەمانە بە سەرکردایەتی ئەحیعەزەری هاتن لەگەڵ یۆئاشی برای، هەردوو کوڕەکەی شەماعای گیڤعایی بوون.
\li1 هەردوو کوڕەکەی عەزماڤێت، یەزیێل و پالەت،
\li1 بەراخا و یێهوی عەناتۆتی،
\v 4 یەشمەعیای گبعۆنی پاڵەوانێک بوو لەنێو سی پاڵەوانەکە و فەرماندەیان بوو.
\li1 هەروەها یەرمیا و یەحەزیێل و یۆحانان و یۆزاڤادی گەدێراتی و
\v 5 ئەلعوزەی و یەریمۆت و بەعەلیاهو و شەمەریاهو و شەفەتیای حەروفی؛
\li1 
\v 6 ئەلقانە و ییشیا و عەزەرئێل و یۆعەزەر و یاشۆڤەعام لە بنەماڵەی قۆرەحییەکان؛
\li1 
\v 7 هەروەها یۆعێلە و زەڤەدیا کە هەردوو کوڕی یەرۆحامی خەڵکی گەدۆر بوون.
\b
\p 
\v 8 کاتێک داود لەو قەڵایە بوو کە لە چۆڵەوانی بوو، هەندێک لە گادییەکان هاتنە پاڵ داود کە پاڵەوانی ئازا و پیاوی مەشقپێکراو بۆ جەنگ و شارەزا لە بەکارهێنانی قەڵغان و ڕم، ڕوویان وەک ڕووی شێر و وەک ئاسک لەسەر چیادا خێرا بوون.
\b
\li1 
\v 9 عێزەر فەرماندە بوو،
\li1 عۆبەدیا دووەم و ئەلیاب سێیەم و
\li1 
\v 10 میشمەنا چوارەم و یەرمیا پێنجەم و
\li1 
\v 11 عەتەی شەشەم و ئەلیێل حەوتەم و
\li1 
\v 12 یۆحانان هەشتەم و ئەلزاڤاد نۆیەم و
\li1 
\v 13 یەرمیا دەیەم و مەخبەنەی یازدەیەم بوو.
\b
\p 
\v 14 ئەمانە لە نەوەی گاد بوون و هەموویان سەرکردەی سوپا بوون، بچووکەکەیان بەسەر سەد کەسدا زاڵ دەبوو، گەورەکەشیان بەسەر هەزار کەسدا زاڵ دەبوو.
\v 15 ئەمان بوون لە مانگی یەک لە ڕووباری ئوردون پەڕینەوە، کاتێک ئاو هەتا هەموو کەنارەکانی هەڵچوو بوو، هەموو خەڵکی دۆڵەکانیان بەزاند، لە ڕۆژهەڵات و ڕۆژئاوادا.
\p 
\v 16 هەروەها هەندێک لە نەوەی بنیامین و یەهوداش بۆ لای داود هاتنە قەڵاکە.
\v 17 داود بۆ پێشوازییان چوو و پێی گوتن: «ئەگەر بۆ ئاشتی و یارمەتیدان هاتوونەتە لام، یەک دڵم دەبێت لەگەڵتان، بەڵام ئەگەر بۆ بەدەستەوەدانم بۆ دوژمنەکەم هاتوون لە کاتێکدا کە هیچ ستەمێکم نەکردووە، با خودای باوباپیرانمان تەماشا بکات و دادوەری بکات.»
\p 
\v 18 ئینجا ڕۆحی خودا ڕژایە سەر عەماسەیی سەرۆکی سییەکە و گوتی:
\q1 «ئەی داود، ئێمە هی تۆین!
\q2 ئەی کوڕەکەی یەسا، لەگەڵتداین!
\q1 سەرکەوتن، سەرکەوتن بۆ تۆ بێت،
\q2 با یارمەتیدەرانت سەرکەوتوو بن،
\q3 چونکە خودات یارمەتیدەرتە.»
\p ئینجا داود وەریگرتن و کردنییە سەرکردەی یەکەکانی سوپا.
\p 
\v 19 کاتێک کە داود لەگەڵ فەلەستییەکاندا لە دژی شاول بۆ جەنگ چوو، هەندێک لە پیاوانی نەوەی مەنەشەش چوونە پاڵی. بەڵام داود و پیاوەکانی یارمەتی فەلەستییەکانیان نەدا، چونکە حوکمڕانە فەلەستییەکان پاش ڕاوێژکردن، گەڕاندیانەوە و گوتیان: «بە کەللەسەری ئێمەوە دەگەڕێتەوە پاڵ شاولی گەورەی.»
\v 20 ئەمە ناوی هەندێک لەو پیاوانەی نەوەی مەنەشەیە کە کاتێک داود چوو بۆ چیقلەگ، چوونە پاڵی: عەدنەح و یۆزاڤاد و یەدیعێل و میکائیل و یۆزاڤاد و ئەلیهو و چیلەتەی، هەموو ئەمانەش فەرماندەی یەکەی هەزارانی مەنەشە بوون.
\v 21 ئەوان یارمەتی داودیان دا لە دژی چەتەکان، چونکە هەموویان پاڵەوانی ئازا بوون و فەرماندەی سوپا بوون.
\v 22 هەروەها ڕۆژ لەدوای ڕۆژ پیاوان بۆ یارمەتیدانی داود دەهاتن، هەتا بوونە سوپایەکی گەورە، وەک سوپای خودا.
\s1 هاتنەپاڵی پیاوانی دیکە بۆ لای داود
\li4 
\v 23 ئەمەش ژمارەی ئەو پیاوە چەکدارانەیە کە هاتنە حەبرۆن بۆ لای داود، بۆ ئەوەی بەپێی فەرموودەی یەزدان پاشایەتییەکەی شاولی ڕادەست بکەن:
\b
\li1 
\v 24 لە نەوەی یەهودا، شەش هەزار و هەشت سەد پیاوی چەکدار بە ڕم و قەڵغان.
\li1 
\v 25 لە نەوەی شیمۆن، حەوت هەزار و سەد پاڵەوانی ئازای ئامادەباش بۆ جەنگ.
\li1 
\v 26 لە نەوەی لێڤی چوار هەزار و شەش سەد پیاو،
\v 27 لەوانە سێ هەزار و حەوت سەد پیاو لەگەڵ یەهۆیاداعی سەرۆکی بنەماڵەی هارونییەکان بوون.
\v 28 سادۆقیش لاوێکی پاڵەوانی ئازا بوو، لەگەڵ بیست و دوو ئەفسەر کە لە بنەماڵەی ئەو بوون.
\li1 
\v 29 لە نەوەی بنیامینیش، لە خزم و کەسوکاری شاول، سێ هەزار کە زۆربەیان هەتا ئەو کاتەش دڵسۆز بوون لەگەڵ ماڵی شاول.
\li1 
\v 30 لە نەوەی ئەفرایم، بیست هەزار و هەشت سەد پاڵەوانی ئازا و ناوداری بنەماڵەکانیان.
\li1 
\v 31 لە نیوەی هۆزی مەنەشەش، هەژدە هەزار پیاو کە بە ناو دیاری کرابوون هەتا بێن و داود بکەنە پاشا.
\li1 
\v 32 لە نەوەی یەساخار، دوو سەد سەرکردە کە شارەزای بارودۆخی ڕۆژگار بوون، دەیانزانی ئیسرائیل دەبێت چی بکات، هەروەها هەموو خزم و کەسەکانیشیان لەژێر فەرمانی ئەواندا بوون.
\li1 
\v 33 لە زەبولونیش، پەنجا هەزار پیاوی مەشقپێکراو هەبوون لەسەر شەڕ و هەموو جۆرە چەکێکی جەنگ، کە بەبێ دوو دڵی ئامادە بوون بۆ یارمەتیدانی داود.
\li1 
\v 34 لە نەفتالی، هەزار سەرکردە و سی و حەوت هەزار پیاوی چەکدار بە قەڵغان و ڕمیان لەگەڵ بوو.
\li1 
\v 35 لە دانیش، بیست و هەشت هەزار و شەش سەد پیاوی ئامادەباش بۆ جەنگ.
\li1 
\v 36 لە ئاشێریش، چل هەزار ڕاهێنراو لەسەر شەڕ و ئامادەکراو بۆ جەنگ.
\li1 
\v 37 لە بەری ڕۆژهەڵاتی ڕووباری ئوردونیشەوە، لە ڕەئوبێن و گادییەکان و نیوەی هۆزی مەنەشە، سەد و بیست هەزار پیاوی پڕچەککراو بە هەموو جۆرە چەکێکی جەنگ.
\b
\li4 
\v 38 هەموو ئەمانە جەنگاوەری خۆبەخش بوون لە ڕیزی لەشکرەکانی و بە هەموو دڵیانەوە هاتبوونە حەبرۆن هەتا داود بکەنە پاشای هەموو ئیسرائیل، هەروەها هەموو پاشماوەی ئیسرائیلیش یەک بڕیار بوون بۆ ئەوەی داود بکەنە پاشا.
\v 39 لەوێ بۆ ماوەی سێ ڕۆژ لەگەڵ داود مانەوە، دەیانخوارد و دەیانخواردەوە لە هەموو ئەوەی کەسوکارەکانیان بۆیان ئامادە کردبوون،
\v 40 هەروەها نزیکەکانیشیان لە یەساخار و زەبولون و نەفتالییەوە، بە گوێدرێژ و وشتر و هێستر و مانگا نانیان دەهێنا. خواردنێکی زۆریان هەبوو لە ئارد و نانە هەنجیر و هێشووی کشمیش و شەراب و زەیت و مانگا و مەڕ، چونکە لەناو ئیسرائیل خۆشی هەبوو.
\c 13
\s1 گەڕاندنەوەی سندوقی پەیمان
\p 
\v 1 داود ڕاوێژی لەگەڵ هەموو ئەفسەرەکانی کرد، فەرماندەی هەزاران و سەدان،
\v 2 ئینجا بە هەموو کۆمەڵی ئیسرائیلی گوت: «ئەگەر پێتان باشە و بەپێی خواستی یەزدانی پەروەردگارمانە، با بەدوای هەموو هاونیشتیمانەکانماندا بنێرین لە هەموو لایەکی خاکی ئیسرائیل، هەروەها لەدوای ئەو کاهین و لێڤییانەی کە لە شارۆچکەکان و دەشتەکان لەگەڵیان دەژین، هەتا لەگەڵمان کۆببنەوە.
\v 3 با سندوقی خودامان بهێنینەوە لای خۆمان، چونکە بە درێژایی پاشایەتی شاول لێمان نەپرسیوەتەوە.»
\v 4 هەموو کۆمەڵەکەش گوتیان ئاوا دەکەین، چونکە لەلای هەموو گەل پەسەند بوو.
\p 
\v 5 ئیتر داود هەموو ئیسرائیلی لە ڕووباری شیحۆری میسرەوە هەتا دەروازەی حەمات کۆکردەوە، هەتا سندوقی خودا لە قیریەت یەعاریمەوە بهێنن.
\v 6 ئینجا داود و هەموو ئیسرائیل چوونە بەعلەی یەهودا کە قیریەت یەعاریمە، بۆ ئەوەی لەوێوە سندوقی خودای پەروەردگار بهێننەوە، ئەوەی لەنێوان کەڕوبەکان\f + \fr 13:6 \ft لەنێوان کەڕوبەکان: جووتێک پەیکەری بوونەوەری ئاسمانی باڵدارە، لە شێوەی ئاژەڵ و مرۆڤدایە، بۆ پارێزگاریکردن لە سندوقی پەیمان دانرابوو، بڕوانە \xt دەرچوون 25‏:18 و عیبرانییەکان 9‏:5‏\xt*\ft ‏.‏\f* لەسەر تەخت دانیشتووە، ئەو سندوقە کە ناوی لێنراوە «ناوەکە».
\p 
\v 7 لە ماڵی ئەبینادابەوە سندوقی خودایان لە عەرەبانەیەکی نوێ بارکرد، عوزا و ئەحیۆ عەرەبانەکەیان لێدەخوڕی.
\v 8 داود و هەموو ئیسرائیلیش بە هەموو توانایانەوە لەبەردەم خودا ئاهەنگیان دەگێڕا، بە سروود و قیسارە و ساز و دەف و سەنج و کەڕەناوە.
\p 
\v 9 کاتێک گەیشتنە سەر جۆخینەکەی\f + \fr 13:9 \ft جۆخین یان سەرخەرمان ئەو زەوییە تەرخانکراوەیە کە لەلایەن وەرزێر و جوتیارەوە بەکارهێنراوە بۆ کوتانی دانەوێڵە لەسەری لەدوای کۆکردنەوەی لە کێڵگە.‏\f* کیدۆن، عوزا دەستی بۆ سندوقەکە درێژکرد و گرتی، چونکە گایەکان سەرسمیان دا.
\v 10 ئەو ساتە تووڕەیی یەزدان بەسەر عوزادا جۆشا و لێیدا، لەبەر ئەوەی دەستی بۆ سندوقەکە درێژکرد و هەر لەوێدا لەبەردەم خودا مرد.
\p 
\v 11 داودیش تووڕە بوو، چونکە یەزدان بە تەواوی عوزای لەناوبرد، ئەو شوێنەش هەتا ئەمڕۆ بە پێرێز عوزا\f + \fr 13:11 \ft واتا هەڵکوتانە سەر عوزا.‏\f* ناودەبردرێت.
\p 
\v 12 ئەو ڕۆژە داود لە خودا ترسا و گوتی: «چۆن سندوقی خودا بۆ لای خۆم بهێنم؟»
\v 13 لەبەر ئەوە داود سندوقەکەی نەگواستەوە بۆ لای خۆی بۆ شاری داود، بەڵکو بردییە ماڵی عوبێد ئەدۆمی گەتی.
\v 14 سێ مانگ سندوقی خودا لە ماڵی عوبێد ئەدۆم مایەوە، یەزدانیش ماڵی عوبێد ئەدۆم و هەموو ئەو شتانەی کە هی ئەو بوون بەرەکەتداری کردن.
\c 14
\s1 کۆشک و خێزانی داود
\p 
\v 1 پاشان حیرامی پاشای سور چەند نێردراوێکی بۆ لای داود نارد لەگەڵ داری ئورز و نەقاڕ و دارتاش بۆ ئەوەی کۆشکێکی بۆ دروستبکەن.
\v 2 ئینجا داود زانی کە یەزدان وەک پاشای ئیسرائیل جێگیری کردووە، پاشایەتییەکەشی لە پێناوی ئیسرائیلی گەلەکەیدا زۆر پایەدار کردووە.
\p 
\v 3 هەروەها داود چەند ژنێکی دیکەی لە ئۆرشەلیم هێنا، ئینجا کوڕ و کچی دیکەی داود لەدایک بوون.
\v 4 ئەمەش ناوی ئەو منداڵانەیەتی کە لە ئۆرشەلیم لەدایک بوون: شەموع، شۆڤاڤ، ناتان، سلێمان،
\v 5 ئیڤحار، ئەلیشوع، ئەلپەلەت،
\v 6 نۆگە، نەفەگ، یافیع،
\v 7 ئەلیشاماع، بەعەلیاداع و ئەلیفەلەت.
\s1 بەزاندنی فەلەستییەکان
\p 
\v 8 کاتێک فەلەستییەکان بیستیانەوە کە داود بە پاشای هەموو ئیسرائیل دەستنیشان کراوە، هەموویان هاتن بۆ ئەوەی بەدوای داوددا بگەڕێن، بەڵام داود ئەمەی بیستەوە و دابەزی بۆ بەرەنگاربوونەوەیان.
\v 9 ئەو کاتە فەلەستییەکان هاتبوون و دەستیان کردبوو بە تاڵانکردنی دۆڵی ڕفایم.
\v 10 داودیش پرسیاری لە خودا کرد و گوتی: «ئایا بچم بۆ پەلاماردانی فەلەستییەکان؟ ئایا دەیاندەیتە دەستم؟»
\p یەزدانیش بە داودی فەرموو: «بڕۆ، دەیاندەمە دەستت.»
\p 
\v 11 ئینجا داود و پیاوەکانی چوونە بەعل‌پراچیم\f + \fr 14:11 \ft بەعل‌پراچیم: لە عیبری بە واتای ئەو خوداوەندەی دڕپێدەدات.‏\f* و لەوێ دوژمنەکانی بەزاند و گوتی: «خودا بە دەستی من دڕی بە دوژمنەکانم دا وەک دڕپێدادانی ئاو.» لەبەر ئەوە ئەو شوێنە بە بەعل‌پراچیم ناو برا.
\v 12 فەلەستییەکان لەوێدا بتەکانیان بەجێهێشت و داود فەرمانی دا کە لەنێو ئاگردا بیانسووتێنن.
\p 
\v 13 دووبارە فەلەستییەکان هاتنەوە و دەستیان کردەوە بە تاڵانکردن لە دۆڵەکە،
\v 14 داودیش پرسیاری لە خودا کرد، خوداش پێی فەرموو: «بەدوایاندا مەڕۆ، بەڵکو بسووڕێوە بۆ پشتیان و بەرامبەر بە دار بەلسەمەکان پەلاماریان بدە.
\v 15 کاتێک لەسەر دار بەلسەمەکانەوە گوێت لە دەنگی پێ بوو، لەو کاتەدا وەرە دەرەوە بۆ جەنگ، چونکە خودا بۆ لێدانی ئۆردوگای فەلەستییەکان لەپێشتەوە ڕۆیشتووە.»
\v 16 داودیش بەو جۆرەی کرد کە خودا فەرمانی پێ کرد و لە گبعۆنەوە هەتا گەزەر لە سوپای فەلەستییەکانیان دا.
\p 
\v 17 بەو شێوەیە ناوبانگی داود بەناو هەموو خاکەکاندا بڵاو بووەوە و یەزدانیش ترسی ئەوی خستە ناو دڵی هەموو نەتەوەکانەوە.
\c 15
\s1 هێنانی سندوقی پەیمان بۆ ئۆرشەلیم
\p 
\v 1 داود چەند تەلارێکی بۆ خۆی لە شاری داود دروستکرد و شوێنێکی بۆ سندوقی خودا ئامادە کرد و چادرێکی بۆی هەڵدا.
\v 2 ئینجا داود گوتی: «کەس بۆی نییە سندوقی خودا هەڵبگرێت، تەنها لێڤییەکان نەبێت، چونکە یەزدان ئەوانی هەڵبژاردووە بۆ هەڵگرتنی سندوقی یەزدان و خزمەتکردنی هەتاهەتایە.»
\p 
\v 3 داود هەموو ئیسرائیلی لە ئۆرشەلیم کۆکردەوە بۆ هێنانی سندوقی یەزدان بۆ ئەو شوێنەی کە بۆی ئامادە کردبوو.
\b
\li4 
\v 4 هەروەها داود نەوەی هارون و لێڤییەکانی کۆکردەوە.
\b
\li1 
\v 5 لە نەوەی قەهات،
\li2 ئوریێلی سەرکردە و سەد و بیست کەس لە خزم و نزیکەکانی.
\li1 
\v 6 لە نەوەی مەراری،
\li2 عەسایای سەرکردە و دوو سەد و بیست کەس لە خزم و نزیکەکانی.
\li1 
\v 7 لە نەوەی گێرشۆن،
\li2 یۆئێلی سەرکردە و سەد و سی کەس لە خزم و نزیکەکانی.
\li1 
\v 8 لە نەوەی ئەلیچافان،
\li2 شەمەعیای سەرکردە و دوو سەد کەس لە خزم و نزیکەکانی.
\li1 
\v 9 لە نەوەی حەبرۆن،
\li2 ئەلیێلی سەرکردە و هەشتا کەس لە خزم و نزیکەکانی.
\li1 
\v 10 لە نەوەی عوزیێل،
\li2 عەمینادابی سەرکردە و سەد و دوازدە کەس لە خزم و نزیکەکانی.
\b
\p 
\v 11 ئینجا داود بانگی سادۆق و ئەبیاتاری کرد کە هەردووکیان کاهین بوون، هەروەها بانگی ئوریێل و عەسایا و یۆئێل و شەمەعیا و ئەلیێل و عەمینادابی کرد کە لە لێڤییەکان بوون.
\v 12 پێی گوتن: «ئێوە گەورەی بنەماڵەکانی لێڤین، خۆتان و براکانتان تەرخان بکەن و سندوقی یەزدانی پەروەردگاری ئیسرائیل بۆ ئەو شوێنە بهێنن کە بۆم ئامادە کردووە،
\v 13 چونکە یەکەم جار ئێوەی لێڤی ئەوتان هەڵنەگرت، ئیتر یەزدانی پەروەردگارمان دڕی پێداین، لەبەر ئەوەی پرسمان بە خودا نەکرد کە چۆن ئەو کارە بکەین.»
\v 14 ئینجا کاهین و لێڤییەکان خۆیان تەرخان کرد بۆ هێنانی سندوقی یەزدانی پەروەردگاری ئیسرائیل.
\v 15 نەوەی لێڤییەکان هەروەک چۆن موسا بەپێی فەرمایشتی یەزدان فەرمانی دابوو ئاوا سندوقی خودایان بە دوو دارەکەی لەسەر شانیان هەڵگرت.
\p 
\v 16 داود بە سەرکردە لێڤییەکانی گوت کە برا گۆرانیبێژەکانیان بە ئامێرەکانی مۆسیقاوە دابنێن، بە ساز و قیسارە و سەنجەوە، هەتا بە خۆشییەوە و بە دەنگی بەرز گۆرانی بڵێن.
\p 
\v 17 لێڤییەکانیش ئەمانەیان دانا: هێیمانی کوڕی یۆئێل و لە براکانیشی ئاسافی کوڕی بەرەخیا و لە نەوەی مەراریش لە براکانیان، ئێیتانی کوڕی قوشایاهو،
\v 18 لەگەڵیشیان خزم و کەسە پلە دووەکانیان: زەکەریا، یەعزیێل، شەمیرامۆت، یەحیێل، عونی، ئەلیاب، بەنایا، مەعسێیاهو، مەتیسیا، ئەلیفەلێهو و میقنێیاهو و هەردوو دەرگاوانەکان، عوبێد ئەدۆم و یەعیێل.
\p 
\v 19 مۆسیقاژەنەکانیش، هێیمان و ئاساف و ئێیتان سەنجی بڕۆنزیان لێدەدا.
\v 20 زەکەریا و عەزیێل و شەمیرامۆت و یەحیێل و عونی و ئەلیاب و مەعسێیاهو و بەنایا سازیان بە شێوەی عەلامۆت\f + \fr 15:20 \ft جۆرە ئاوازێکە، واتا بە دەنگی کیژۆڵەکان. بڕوانە زەبوورەکان 46.‏\f* دەژەند.
\v 21 مەتیسیا و ئەلیفەلێهو و میقنێیاهو و عوبێد ئەدۆم و یەعیێل و عەزەزیاهو قیسارەیان بۆ ڕابەرایەتیکردن بە شێوەی شەمینیت\f + \fr 15:21 \ft دەشێت زاراوەیەکی مۆسیقی بێت. بڕوانە زەبوورەکان 6.‏\f* دەژەند.
\v 22 کەنەنیاهوی بەهۆی شارەزاییە باشەکەی لە مۆسیقا، ڕابەرایەتی ژەنیارە لێڤییەکانی دەکرد.
\p 
\v 23 بەرەخیا و ئەلقانەش دەرگاوانی سندوقی پەیمانەکە بوون.
\v 24 کاهینەکانیش شەڤەنیا و یۆشافات و نەتەنێل و عەماسەی و زەکەریا و بەنایا و ئەلیعەزەر لەبەردەم سندوقی خودا فوویان بە کەڕەنادا دەکرد و عوبێد ئەدۆم و یەحیاش دەرگاوانی سندوقی پەیمانەکە بوون.
\p 
\v 25 داود و پیرانی ئیسرائیل و فەرماندەی یەکەکانی هەزاران بە خۆشییەوە چوون بۆ هێنانی سندوقی پەیمانی یەزدان لە ماڵی عوبێد ئەدۆمەوە.
\v 26 کاتێک خودا یارمەتی لێڤییەکانی هەڵگرانی سندوقی پەیمانی یەزدانی دا، حەوت گا و حەوت بەرانیان وەک قوربانی سەربڕی.
\v 27 داود و هەموو لێڤییەکانی کە سندوقی پەیمانیان هەڵدەگرت، مۆسیقاژەنەکان و کەنەنیاهوی ڕابەری مۆسیقای تیپی گۆرانیبێژەکان، هەمووان کەوای کەتانی ناسکیان لەبەردا بوو، هەروەها داود ئێفۆدێکی کەتانی لەبەردا بوو.
\v 28 هەموو ئیسرائیل بە هاواری خۆشی و بە لێدانی کەڕەنا و کەڕەنای قۆچە بەران و سەنج، هەروەها بە ژەنینی ساز و قیسارە، سندوقی پەیمانی یەزدانیان هێنا.
\p 
\v 29 کاتێک سندوقی پەیمانی یەزدان هاتە ناو شاری داود، میخەلی کچی شاول لە پەنجەرەکەوە سەیری خوارەوەی کرد و بینی داودی پاشا سەما دەکات و هەڵدەبەزێتەوە، لە دڵی خۆیدا بە سووکی زانی.
\c 16
\s1 خزمەتکردن لەبەردەم سندوقی یەزدان
\p 
\v 1 ئیتر سندوقی خودایان هێنایە ژوورەوە بۆ ناوەڕاستی ئەو چادرەی کە داود بۆی دامەزراندبوو، هەروەها قوربانی سووتاندن و قوربانی هاوبەشییان\f + \fr 16:1 \ft قوربانی هاوبەشی: ئەم قوربانییە هاودەمی قوربانی سووتاندن بوو. تەنها یەک کەس هەڵدەستا بە دابینکردنی ئەم قوربانییە، بەڵام لەگەڵ خەڵکی دیکە بەشی زۆری ئەم قوربانییەیان لەبەردەم خودا دەخوارد وەک هێمایەک بۆ پێکەوە ژیان. بڕوانە \xt لێڤییەکان 7‏:11‏-15.‏\xt*\ft ‏\f* لەبەردەم خودا سەرخست.
\v 2 پاش ئەوەی داود لە پێشکەشکردنی قوربانی سووتاندنەکان و قوربانییەکانی هاوبەشی بووەوە، بە ناوی یەزدانەوە داوای بەرەکەتی بۆ گەل کرد.
\v 3 بەسەر هەموو ئیسرائیلدا لە ژن و لە پیاو، کولێرەیەک و نانە خورمایەک و نانە کشمیشێکی دابەش کرد.
\p 
\v 4 چەند خزمەتکارێکیشی لە لێڤییەکان لەبەردەم سندوقی یەزدان بۆ یادکردنەوە و سوپاسکردن و ستایشکردنی یەزدانی پەروەردگاری ئیسرائیل دانا:
\v 5 ئاساف ڕابەرایەتی دەکرد و زەکەریاش لەدوای ئەو بە پلەی دووەم دەهات، پاشان یەعیێل، شەمیرامۆت، یەحیێل، مەتیسیا، ئەلیاب، بەنایا، عوبێد ئەدۆم و یەعیێل دەهاتن. ئەمانە ئامێرەکانی ساز و قیسارەیان دەژەند، ئاسافیش سەنجی لێدەدا،
\v 6 بەنایا و یەحەزیێلی کاهینیش بە بەردەوامی کەڕەنایان دەژەند لەبەردەم سندوقی پەیمانی خودا.
\p 
\v 7 ئینجا لەو ڕۆژەدا یەکەم جار داود ئەم زەبوورەی دایە دەست ئاساف و هاوکارەکانی، کە بۆ ستایشکردنی یەزدانە:
\q1 
\v 8 ستایشی یەزدان بکەن و بە ناوی ئەوەوە نوێژ بکەن،
\q2 کردارەکانی بە گەلان بناسێنن.
\q1 
\v 9 گۆرانی بۆ بڵێن، ستایشی بکەن،
\q2 هەموو کارە سەرسوڕهێنەرەکانی ڕابگەیەنن،
\q1 
\v 10 شانازی بە ناوی پیرۆزیەوە بکەن،
\q2 با دڵی ئەوانە خۆش بێت کە ڕوو لە یەزدان دەکەن.
\q1 
\v 11 پشت بە یەزدان و هێزەکەی ببەستن،
\q2 بەردەوام ڕووتان لەو بکەن.
\b
\q1 
\v 12 باسی ئەو کارە سەرسوڕهێنەرانە بکەن کە کردوونی،
\q2 پەرجوو\f + \fr 16:12 \ft پەرجوو: موعجیزە.‏\f* و حوکمەکانی دەمی.
\q1 
\v 13 ئەی نەوەی ئیسرائیلی بەندەی ئەو،
\q2 ئەی کوڕانی یاقوب، هەڵبژاردەکانی.
\q1 
\v 14 ئەو یەزدانی پەروەردگارمانە،
\q2 حوکمەکانیشی لە سەراپای زەوییە.
\b
\q1 
\v 15 بۆ هەتاهەتایە پەیمانەکەی لە یادە،
\q2 ئەو بەڵێنەی دەیدات بۆ هەزار پشتە،
\q1 
\v 16 ئەو پەیمانەی لەگەڵ ئیبراهیم بەستی،
\q2 ئەو سوێندەی بۆ ئیسحاقی خوارد،
\q1 
\v 17 وەک فەرز بۆ یاقوب چەسپاندی،
\q2 وەک پەیمانێکی هەمیشەیی بۆ ئیسرائیل.
\q1 
\v 18 فەرموویەتی: «خاکی کەنعان دەدەمە تۆ،
\q2 بەشە میراتی خۆتانە.»
\b
\q1 
\v 19 ئەو کاتەی ژمارەیان کەم بوو،
\q2 کەم و نامۆ بوون لەو خاکە،
\q1 
\v 20 لە نەتەوەیەکەوە دەچوونە نەتەوەیەکی دیکە،
\q2 لە پاشایەتییەکەوە بۆ گەلێکی دیکە.
\q1 
\v 21 لێ نەگەڕا کەس ستەمیان لێ بکات،
\q2 بەڵکو لەبەر ئەوان پاشایانی سەرزەنشت کرد:
\q1 
\v 22 «دەست لە دەستنیشانکراوەکانم مەدەن،
\q2 خراپە لەگەڵ پێغەمبەرەکانم مەکەن.»
\b
\q1 
\v 23 ئەی هەموو زەوی، گۆرانی بۆ یەزدان بڵێن،
\q2 ڕۆژ بە ڕۆژ مژدەی ڕزگاریی ئەو ڕابگەیەنن.
\q1 
\v 24 لەنێو نەتەوەکان شکۆمەندی ئەو ڕابگەیەنن،
\q2 لەنێو هەموو گەلان کارە سەرسوڕهێنەرەکانی.
\b
\q1 
\v 25 یەزدان مەزنە و شایانی ستایشی زۆرە،
\q2 سامناکە بەسەر هەموو خوداوەندەکانەوە،
\q1 
\v 26 چونکە هەموو خوداوەندەکانی گەلان بتن،
\q2 بەڵام یەزدان ئاسمانی دروستکردووە.
\q1 
\v 27 شکۆ و سەربەرزی لەبەردەمیدان،
\q2 هێز و شادمانی لە نشینگەکەیدان.
\b
\q1 
\v 28 ئەی هەموو خێڵەکانی گەلان، ستایشی یەزدان بکەن،
\q2 ستایشی شکۆ و هێزی یەزدان بکەن.
\q1 
\v 29 ستایشی ناوی شکۆداری یەزدان بکەن،
\q2 دیاری بهێنن و وەرنە بەردەمی،
\q1 کڕنۆش بۆ یەزدان ببەن، چونکە شکۆدار و پیرۆزە.
\q2 
\v 30 ئەی هەموو خەڵکی زەوی لەبەردەمی بلەرزن،
\q2 جیهان چەسپاوە و هەرگیز نالەقێت.
\b
\q1 
\v 31 با ئاسمان شادبێت و زەوی دڵخۆش بێت،
\q2 لەنێو نەتەوەکاندا بڵێن: «یەزدان پاشایەتی دەکات!»
\q1 
\v 32 با دەریا و هەرچی تێدایە بخرۆشێن،
\q2 با کێڵگە و هەرچی تێدایە شاگەشکە بن.
\q1 
\v 33 ئینجا هەموو درەختەکانی دارستان لەبەردەم یەزدان گۆرانی دەڵێن،
\q2 چونکە دێت بۆ ئەوەی دادوەری زەوی بکات.
\b
\q1 
\v 34 ستایشی یەزدان بکەن لەبەر ئەوەی چاکە،
\q2 خۆشەویستییە نەگۆڕەکەی هەتاهەتاییە.
\q1 
\v 35 بڵێن: «ئەی خودای ڕزگارکەرمان، ڕزگارمان بکە،
\q2 لەنێو نەتەوەکان کۆمان بکەرەوە و فریامان بکەوە،
\q1 بۆ ئەوەی ستایشی ناوی پیرۆزی تۆ بکەین و
\q2 شانازی بە ستایشکردنی تۆوە بکەین.»
\q1 
\v 36 ستایش بۆ یەزدانی پەروەردگاری ئیسرائیل،
\q2 لە ئەزەلەوە و بۆ هەتاهەتایە.
\m ئینجا هەموو گەل گوتیان «ئامین!» و «ستایشی یەزدان بکەن.»
\b
\p 
\v 37 داود لەوێدا لەبەردەم سندوقی پەیمانی یەزدان، ئاساف و هاوکارەکانی بەجێهێشت تاکو بە بەردەوامی لەبەردەم سندوقەکە خزمەت بکەن، هەر خزمەتێک لە ڕۆژی خۆیدا.
\v 38 هەروەها عوبێد ئەدۆم و هاوکارەکانیشی کە شەست و هەشت کەس بوون، بۆ یارمەتیدانی ئەوان، بەجێی هێشتن. عوبێد ئەدۆمی کوڕی یەدوتون و حۆسا هەردووکیان دەرگاوان بوون.
\p 
\v 39 داود سادۆقی کاهین و برا کاهینەکانیشی لەبەردەم چادری پەرستنی یەزدان، ئەوەی لەسەر بەرزاییەکەی گبعۆن بوو، بەجێی هێشتن،
\v 40 بۆ ئەوەی بە بەردەوامی قوربانی سووتاندن لەسەر قوربانگاکەی قوربانی سووتاندن پێشکەش بکەن، بەیانییان و ئێواران بەپێی هەموو ئەوەی لە تەوراتی یەزداندا نووسراوە، ئەوەی فەرمانی بە ئیسرائیل کرد.
\v 41 لەگەڵ ئەوانیش، هێیمان و یەدوتون و پاشماوەی هەڵبژێردراوەکان ئەوانەی ناویان هات تاکو سوپاسی یەزدان بکەن، چونکە «خۆشەویستییە نەگۆڕەکەی هەتاهەتاییە.»
\v 42 لەگەڵ ئەوانیش هێیمان و یەدوتون بەرپرسی ژەنینی کەڕەنا و سەنج و ئامێرە مۆسیقییەکانی دیکە بوون لە کاتی گۆرانی و ستایشەکانیان بۆ خودا. کوڕەکانی یەدوتونیش دەرگاوان بوون.
\p 
\v 43 پاشان هەموو گەل هەرکەسە و بۆ ماڵی خۆی بەڕێکەوت و داودیش گەڕایەوە بۆ ئەوەی داوای بەرەکەت بۆ ماڵەکەی خۆی بکات.
\c 17
\s1 بەڵێنی خودا بۆ داود
\p 
\v 1 پاش ئەوەی داود لە کۆشکەکەی نیشتەجێ بوو، داود بە ناتانی پێغەمبەری گوت: «من لێرە لە کۆشکێکی دروستکراو بە داری ئورز نیشتەجێم و سندوقی پەیمانی یەزدانیش لەژێر چادردایە.»
\p 
\v 2 ناتانیش بە داودی گوت: «هەموو ئەوەی لە دڵتدایە بیکە، چونکە یەزدانت لەگەڵە.»
\p 
\v 3 بەڵام هەر لەو شەوەدا فەرمایشتی خودا بۆ ناتان هات:
\pm 
\v 4 «بڕۆ بە داودی بەندەم بڵێ: ”یەزدان ئەمە دەفەرموێت: ئەو کەسە تۆ نیت کە ماڵێک بۆ نیشتەجێبوونم بنیاد دەنێت.
\v 5 لەو ڕۆژەوەی کە ئیسرائیلم لە میسر دەرهێناوە هەتا ئەمڕۆ لە ماڵدا نیشتەجێ نەبووم، بەڵکو لە شوێنێکەوە بۆ شوێنێکی دیکە چووم، هەر لەنێو چادری پەرستندا بووم.
\v 6 لە هەموو هاتوچۆکردنەکانم لەگەڵ هەموو ئیسرائیل، ئایا هیچ قسەیەکم کرد لەگەڵ یەکێک لە ڕابەرەکانی ئیسرائیل، ئەوانەی فەرمانم پێکردن بۆ ئەوەی شوانایەتی گەلەکەم بکەن، ’بۆچی ماڵێکتان لە داری ئورز بۆ دروستنەکردووم؟‘ “
\pm 
\v 7 «ئێستاش ئاوا بە داودی بەندەم بڵێ: ”یەزدانی سوپاسالار ئەمە دەفەرموێت: من تۆم لە شوانایەتی مەڕەوە برد و تۆم کردە فەرمانڕەوای ئیسرائیلی گەلەکەی خۆم.
\v 8 لەگەڵتدا بووم بۆ هەر شوێنێک چووبیت و هەموو دوژمنەکانی تۆم لەبەردەمت بڕیوەتەوە. ئێستا ناوێکت بۆ دروستدەکەم وەک ناوی گەورەکان کە لەسەر زەوین.
\v 9 شوێنێکیش بۆ ئیسرائیلی گەلەکەم دیاری دەکەم و دەیچێنم و لە جێی خۆی نیشتەجێی دەکەم، ئیتر وەک پێشوو بێزار ناکرێن و خەڵکانی ناڕەوا نایانچەوسێننەوە،
\v 10 وەک ئەو سەردەمانەی ڕابەرم لەسەر ئیسرائیلی گەلەکەم دادەنا. منیش تۆ لە دەستی هەموو دوژمنەکانت دەحەوێنمەوە.
\pm «”پێت ڕادەگەیەنم کە یەزدان خۆی ماڵت بۆ دروستدەکات.
\v 11 کاتێک ژیانت تەواو دەبێت و دەچیتە پاڵ باوباپیرانت، من وەچەکەت دادەمەزرێنم، ئەوەی لەدوای خۆت لە کوڕەکانت دەبێت، پاشایەتییەکەی جێگیر دەکەم.
\v 12 ئەو ماڵێکم بۆ بنیاد دەنێت و منیش بۆ هەتاهەتایە تەختەکەی جێگیر دەکەم.
\v 13 من دەبمە باوکی ئەو و ئەویش دەبێتە کوڕی من. خۆشەویستییە نەگۆڕەکەم بۆ ئەو داناماڵرێت، هەروەک چۆن دامماڵی لەوەی لەپێش تۆ بوو.
\v 14 بۆ هەتاهەتایەش لە ماڵەکەم و لەناو پاشایەتییەکەمدا دایدەنێم، هەتاهەتایە تەختەکەی جێگیر دەبێت.“»
\p 
\v 15 ئینجا ناتان بەپێی وشەکانی ئەم سروشە قسەی لەگەڵ داود کرد.
\s1 نوێژی داود
\p 
\v 16 ئەوسا داودی پاشا چوو و لەبەردەم یەزدان دانیشت و گوتی:
\pm «یەزدانی پەروەردگار، من کێم و بنەماڵەکەی من کێیە کە تۆ بەم پایەیەت گەیاندووم؟
\v 17 ئەی خودایە، تۆ هێشتا ئەمەت بە کەم زانی، هەر لەبەر ئەوە هاتیت بۆ ئەوەی سەبارەت بە ئاییندەی ماڵی ئەم بەندەیەت بەڵێنی گەورەتر بدەیت. ئەی یەزدانی پەروەردگار، بە کەسێکی پایەبەرز داتنام و تەماشات کردم.
\pm 
\v 18 «ئیتر داود چی زیاتر بە تۆ بڵێت کە بەندەکەتت پایەدار کردووە؟ چونکە تۆ بەندەکەی خۆت دەناسیت.
\v 19 ئەی یەزدان، تۆ لە پێناوی بەندەکەت و بە خواستی دڵی خۆت ئەم کارە گەورەت کردووە، بۆ ئەوەی ئەم هەموو بەڵێنە گەورانە بزانرێن.
\pm 
\v 20 «ئەی یەزدان، کوا هاوتای تۆ؟ بێجگە لە تۆ خودایەک نییە لە هەموو ئەوەی بە گوێی خۆمان گوێمان لێبووە.
\v 21 هەروەها کێ وەک ئیسرائیلی گەلەکەی تۆیە؟ ئەم گەلە تاکە نەتەوەیەکە لە زەویدا کە خودا هات بۆ ئەوەی گەلێک بۆ خۆی بکڕێتەوە، بۆ ئەوەی ناوێک بۆ خۆی دابنێت و کاری مەزن و سامناک بکات، بە دەرکردنی نەتەوەکان لەبەردەم گەلەکەت، ئەوەی لە میسر بۆ خۆت کڕیتەوە.
\v 22 ئەی یەزدان، تۆ گەلی ئیسرائیلت بۆ هەتاهەتایە کردە گەلی خۆت و تۆش بوویتە خودایان.
\pm 
\v 23 «ئەی یەزدان، ئێستاش ئەو بەڵێنەی سەبارەت بە بەندەکەت و بە ماڵەکەی فەرمووت، با بۆ هەتاهەتایە بچەسپێت. هەروەک فەرمووت ئاوا بکە،
\v 24 بیچەسپێنە، تاوەکو بۆ هەتاهەتایە ناوت مەزن بێت و بگوترێت: ”یەزدانی سوپاسالاری خودای ئیسرائیل، خودای ئیسرائیلە!“ با ماڵی داودی بەندەشت لەبەردەمتدا جێگیر بێت.
\pm 
\v 25 «ئەی خودای من، بۆ بەندەکەی خۆتت ئاشکرا کرد کە ماڵێکی بۆ بنیاد دەنێیت، لەبەر ئەمە بەندەکەت ئازایەتی لە خۆیدا بینی لەبەردەمتدا نزا بکات.
\v 26 ئەی یەزدان، تۆ خودایت، بەڵێنی ئەم چاکەیەت بە بەندەکەت داوە.
\v 27 ئێستاش ڕەزامەندی بفەرموو بۆ ئەوەی ماڵی بەندەکەت بەرەکەتدار بکەیت، تاوەکو بۆ هەتاهەتایە لەبەردەمت بێت، ئەی یەزدان، چونکە تۆ بەرەکەتدارت کردووە و بۆ هەتاهەتایە بەرەکەتدار دەبێت.»
\c 18
\s1 سەرکەوتنەکانی داود
\p 
\v 1 ئەوە بوو پاش ئەمە داود فەلەستییەکانی بەزاند و زەلیلی کردن، گەت و شارۆچکەکانی لە فەلەستییەکان سەند.
\p 
\v 2 هەروەها داود مۆئابییەکانیشی بەزاند. مۆئابییەکان هاتنە ژێر دەسەڵاتی داود و سەرانەیان بۆ دەهێنا.
\p 
\v 3 هەروەها داود هەدەدعەزەری پاشای چۆڤای لە نزیکی حەمات بەزاند، کاتێک چوو بۆ ئەوەی تاشەبەردێک بۆ یادەوەری لە کەناری ڕووباری فورات بنەخشێنێت.
\v 4 داود هەزار گالیسکە و حەوت هەزار گالیسکەسوار و بیست هەزار پیادەی بە دیل گرت، ئینجا داود جومگە پێی ئەسپی گالیسکەکانیانی بڕییەوە و تەنها سەد ئەسپی گالیسکەی هێشتەوە.
\p 
\v 5 کاتێک ئارامییەکانی دیمەشق بۆ یارمەتیدانی هەدەدعەزەری پاشای چۆڤا هاتن، داود بیست و دوو هەزار پیاوی لە ئارامییەکان کوشت.
\v 6 ئیتر داود لە شانشینی ئارامییەکانی دیمەشق سەربازگەی دانا، ئارامییەکانیش هاتنە ژێر دەسەڵاتی داود و سەرانەیان بۆ دەهێنا. داودیش ڕووی لە هەرکوێ دەکرد، یەزدان سەرکەوتووی دەکرد.
\p 
\v 7 پاشان داود قەڵغانە زێڕینەکانی ئەفسەرەکانی هەدەدعەزەری برد و هێنایە ئۆرشەلیم.
\v 8 هەروەها داود بڕۆنزێکی زۆریشی لە تەڤەح و کوون برد کە شارۆچکەی هەدەدعەزەر بوون، بەوە بوو کە سلێمان حەوزە بڕۆنزییەکە\f + \fr 18:8 \ft کۆگای ئاو بووە، هەروەها پێی گوتراوە دەریا، بڕوانە \xt دەرچوون 30‏:17‏-21.‏\xt*\ft ‏\f* و کۆڵەکەکان و قاپوقاچاغە بڕۆنزییەکانی دروستکرد.
\p 
\v 9 کاتێک تۆعوی پاشای حەمات بیستی کە داود هەموو سوپاکەی هەدەدعەزەری پاشای چۆڤای بەزاندووە،
\v 10 هەدۆرامی کوڕی نارد بۆ لای داودی پاشا بۆ ئەوەی لە سەلامەتی بپرسێت و پیرۆزبایی لێ بکات کە لەگەڵ هەدەدعەزەر جەنگاوە و بەزاندوویەتی، چونکە هەدەدعەزەر لە جەنگدا بوو لە دژی تۆعو. هەدۆرامیش لەگەڵ دەستی خۆیدا هەموو جۆرە کەلوپەلێکی زێڕ و زیو و بڕۆنزی هێنابوو.
\p 
\v 11 داودی پاشا ئەم کەلوپەلانەی بۆ یەزدان تەرخان کرد، هەروەک ئەو زێڕ و زیوەی تەرخان کرد کە لە هەموو ئەم نەتەوانە بردبووی: ئەدۆم، مۆئاب، عەمۆن، فەلەستی و عەمالێقییەکان.
\p 
\v 12 ئەبیشەیی کوڕی چەرویاش لە دۆڵی خوێ\f + \fr 18:12 \ft دۆڵی خوێ: دەکەوێتە باشووری دەریای مردوو. بڕوانە زەبوورەکان 60.‏\f* هەژدە هەزاری لە ئەدۆمییەکان کوشت.
\v 13 لە خاکی ئەدۆم سەربازگەی دانا و هەموو ئەدۆمییەکان هاتنە ژێر دەسەڵاتی داود، داود ڕووی لە هەرکوێ دەکرد، یەزدان سەرکەوتووی دەکرد.
\s1 کاربەدەستەکانی داود
\p 
\v 14 داود پاشایەتی هەموو ئیسرائیلی کرد، دادپەروەری و ڕاستودروستی بۆ هەموو گەلەکەی پەیڕەو کرد.
\b
\li1 
\v 15 یۆئابی کوڕی چەرویاش سوپاسالار بوو؛
\li1 یەهۆشافاتی کوڕی ئەحیلودیش تۆمارکار بوو؛
\li1 
\v 16 سادۆقی کوڕی ئەحیتوڤ و ئەحیمەلەخی کوڕی ئەبیاتار کاهین بوون؛
\li1 شەڤشا خامەی نهێنی\f + \fr 18:16 \ft ڕازپۆش.‏\f* بوو؛
\li1 
\v 17 بەنایای کوڕی یەهۆیاداع فەرماندەی کریتی و پەلەتییەکان\f + \fr 18:17 \ft کریتییەکان و پەلەتییەکان دوو لەشکری ڕاهێنراو بوون لەسەر مەشقی سەربازی.‏\f* بوو؛
\li1 کوڕەکانی داودیش دەستەڕاستی پاشا بوون.
\c 19
\s1 بەزاندنی عەمۆنییەکان
\p 
\v 1 دوای ماوەیەک ناحاشی پاشای عەمۆنییەکان مرد و کوڕەکەی لەدوای ئەو بوو بە پاشا.
\v 2 داود گوتی: «لەگەڵ حانوونی کوڕی ناحاش دڵسۆز دەبم، چونکە باوکی لەگەڵم دڵسۆز بوو.» لەبەر ئەوە داود شاندێکی نارد بۆ ئەوەی سەرەخۆشی لە حانوون بکەن سەبارەت بە باوکی.
\p کاتێک شاندەکەی داود هاتنە لای حانوون لە خاکی عەمۆنییەکان بۆ ئەوەی سەرەخۆشی لێ بکەن،
\v 3 میرەکانی عەمۆنییەکان بە حانوونیان گوت: «تۆ لەو باوەڕەدایت کە داود لەبەر ڕێزگرتن لە باوکت شاندی ناردووە بۆ ئەوەی سەرەخۆشیت لێ بکات؟ ئایا خزمەتکارەکانی بۆ پشکنین و سەرەوژێرکردن و سیخوڕیکردن بەسەر خاکەکەوە نەهاتوون بۆ لات؟»
\v 4 ئیتر حانوون پیاوەکانی داودی گرت و ڕیشی تاشین، جلەکانیشیان لە نیوەوە هەتا پاشەڵیانی دادڕی و بەڕەڵای کردن.
\p 
\v 5 کاتێک هەندێک کەس چوون و سەبارەت بەو پیاوانە بە داودیان ڕاگەیاند، ئەویش چەند کەسێکی نارد بۆ پێشوازییان، چونکە پیاوەکان زۆر شەرمیان دەکرد، پاشاش گوتی: «هەتا ڕیشتان دێتەوە لە ئەریحا بمێننەوە، ئینجا بگەڕێنەوە.»
\p 
\v 6 کاتێک عەمۆنییەکان بینییان لەلایەن داودەوە قێزەون بوون، حانوون و عەمۆنییەکان هەزار تالنت\f + \fr 19:6 \ft هەزار تالنت: نزیکەی 34 تەن.‏\f* زیویان نارد بۆ ئەوەی لە ئارامییەکانی میسۆپۆتامیا و لە ئارامییەکانی مەعکا و لە چۆڤا گالیسکە و گالیسکەسوار بەکرێ بگرن.
\v 7 جا سی و دوو هەزار گالیسکە و گالیسکەسواریان بەکرێ گرت، هەروەها پاشای مەعکا لەگەڵ سوپاکەی هات و لە بەرامبەر مادەبا دامەزران، عەمۆنییەکانیش لە شارۆچکەکانیانەوە کۆبوونەوە و هاتن بۆ جەنگ.
\p 
\v 8 کاتێک داود ئەمەی بیستەوە یۆئاب و هەموو سوپا شەڕکەرەکانی نارد.
\v 9 عەمۆنییەکان هاتنە دەرەوە و لە دەمی دەروازەی شارەکەیان بۆ جەنگ ڕیزیان بەست، بەڵام ئەو پاشایانەی کە هاتبوون بە جیا لە دەشتودەر بوون.
\p 
\v 10 کاتێک یۆئاب بینی کە بەرەکانی جەنگ لەپێشی و لەپاشییەوەن، لە باشترین جەنگاوەرانی ئیسرائیل چەند هێزێکی هەڵبژارد، بۆ بەرەنگاربوونەوەی ئارامییەکان ڕیزی کردن.
\v 11 ئەو پیاوانەی کە مانەوە دایە دەست ئەبیشەیی برای و ئەویش بۆ بەرەنگاربوونەوەی عەمۆنییەکان ڕیزی کردن.
\v 12 یۆئاب گوتی: «ئەگەر ئارامییەکان لە من بەهێزتر بوون، ئەوا تۆ بەهانامەوە دێیت؛ بەڵام ئەگەر عەمۆنییەکان لە تۆ بەهێزتر بوون، ئەوا من بەهاناتەوە دێم.
\v 13 ئازابە و با بەهێز بین لە پێناوی گەلەکەمان و لە پێناوی شارەکانی خوداکەمان، یەزدانیش چی پێ باشە ئەوە دەکات.»
\p 
\v 14 ئینجا یۆئاب و ئەو لەشکرەی لەگەڵی بوون بۆ جەنگ لە دژی ئارامییەکان چوونە پێشەوە، ئەوانیش لەبەردەمیدا هەڵاتن.
\v 15 کاتێک عەمۆنییەکان بینییان ئارامییەکان هەڵدەهاتن، ئەوانیش لەبەردەم ئەبیشەی هەڵاتن و چوونە ناو شارەکە. ئیتر یۆئاب گەڕایەوە ئۆرشەلیم.
\p 
\v 16 کاتێک ئارامییەکان بینییان لە بەرامبەر ئیسرائیل تێکشکاون، چەند نێردراوێکیان نارد و ئارامییەکانی ئەوبەری ڕووباری فوراتیان هێنا و شوفەخی سەرکردەی سوپاکەی هەدەدعەزەریش لەپێشیانەوە بوو.
\p 
\v 17 کاتێک بە داود ڕاگەیەنرا، ئەویش هەموو ئیسرائیلی کۆکردەوە و لە ڕووباری ئوردونەوە پەڕییەوە و بۆیان هات و ڕیزی لێیان بەست، داود بۆ بەرەنگاربوونەوەی ئارامییەکان ڕیزی بەست بۆ جەنگ و ئەوانیش لە دژی جەنگان.
\v 18 بەڵام ئارامییەکان لەبەردەم ئیسرائیلدا هەڵاتن، داودیش حەوت هەزار گالیسکەسوار و چل هەزار پیادەی لە ئارامییەکان کوشت، هەروەها شوفەخی سەرکردەی سوپاکەشی کوشت.
\p 
\v 19 کاتێک ژێردەستەکانی هەدەدعەزەر بینییان کە ئەوان لە بەرامبەر ئیسرائیل تێکشکاون، لەگەڵ داود ئاشت بوونەوە و بوونە ژێردەستەی ئیسرائیل.
\p ئیتر ئارامییەکان نەیانوێرا بەهانای عەمۆنییەکانەوە بچن.
\c 20
\s1 گرتنی شاری ڕەبە
\p 
\v 1 لە بەهاری ساڵ، لە کاتی ڕۆیشتنی پاشاکان بۆ جەنگ، یۆئاب ڕابەرایەتی هێزە چەکدارەکانی دەکرد. خاکی عەمۆنییەکانی وێران کرد و چوو بۆ ڕەبە و گەمارۆی دا، بەڵام داود لە ئۆرشەلیم مایەوە، جا یۆئاب لە ڕەبەی دا و وێرانی کرد.
\v 2 داود تاجی سەری پاشاکەی ئەوانی برد، دەرکەوت کێشەکەی نزیکەی تالنتێک\f + \fr 20:2 \ft تالنتێک: نزیکەی 34 کیلۆگرام.‏\f* زێڕ بوو، بەردی گرانبەهاشی تێدابوو، ئینجا لەسەر سەری داود دانرا. دەستکەوتێکی زۆریشی لە شارەکە دەرهێنا،
\v 3 ئەو گەلەشی کە تێیدا بوو هێنایە دەرەوە و بێگاری پێکردن بە ئیشکردن بە مشار و پاچی ئاسنین و تەوری ئاسنین. داود ئەم کارەی بە هەموو شارۆچکەکانی عەمۆنییەکان کرد. پاشان داود و هەموو سوپا گەڕانەوە ئۆرشەلیم.
\s1 جەنگی فەلەستییەکان
\p 
\v 4 پاش ئەمانە لە گەزەر جەنگ لەگەڵ فەلەستییەکان هەڵگیرسا و لەو کاتەدا سیبەخەیی حوشاتی سیپەیی کوشت کە یەکێک بوو لە نەوەی ڕفائییەکان، دواجار فەلەستییەکان تێکشکان.
\p 
\v 5 جارێکی دیکەش لەگەڵ فەلەستییەکان جەنگ هەڵگیرسایەوە و ئێلحانانی کوڕی یاعیر، لەحمیی برای گۆلیاتی\f + \fr 20:5 \ft هەرچەندە لە \xt دووەم ساموئێل 21‏:19‏\xt*\ft ‏ نووسراوە کە ئێلحانان گۆلیاتی خۆی کوشت، بەڵام دەشێت چەند جەنگاوەرێکی فەلەستی هەبێت کە ناویان گۆلیات بوو.‏\f* گەتی کوشت، کە دەسکی ڕمەکەی وەک نۆردی جۆڵاکان بوو.
\p 
\v 6 دیسان لە گەت جەنگ هەڵگیرسایەوە، پیاوێکی زەبەلاح هەبوو هەر پەلێکی شەش پەنجەی هەبوو، واتا بیست و چوار پەنجەی هەبوو. ئەویش هەر لە نەوەی ڕافا بوو.
\v 7 کاتێک سووکایەتی بە ئیسرائیل کرد، یۆناتانی کوڕی شیمەعەی برای داود کوشتی.
\p 
\v 8 ئەوانە لە نەوەی ڕافا بوون لە گەت، بە دەستی داود و خزمەتکارەکانی کوژران.
\c 21
\s1 سەرژمێری بۆ پێکهێنانی سوپا
\p 
\v 1 شەیتان لە دژی ئیسرائیل ڕاوەستا و داودی لێ هاندان بۆ سەرژمێریکردنی ئیسرائیل.
\v 2 داودیش بە یۆئاب و فەرماندەکانی سوپای گوت: «بڕۆن و سەرژمێری ئیسرائیل بکەن، لە بیری شابەعەوە هەتا دان. پاشان وەرنەوە لام بۆ ئەوەی ژمارەیان بزانم.»
\p 
\v 3 بەڵام یۆئاب وەڵامی دایەوە: «با یەزدان جەنگاوەرەکانی سەد ئەوەندە زیاتر بکات. ئەی پاشای گەورەم، ئایا هەموویان خزمەتکاری گەورەم نین؟ ئیتر بۆچی گەورەم داوای ئەمە دەکات؟ بۆچی ئیسرائیل تووشی تاوان بکات؟»
\p 
\v 4 لەگەڵ ئەوەشدا پاشا بڕیارەکەی خۆی بەسەر یۆئابدا سەپاند، ئیتر یۆئاب چووە دەرەوە و بە هەموو ئیسرائیلدا گەڕا، ئینجا هاتەوە ئۆرشەلیم.
\v 5 یۆئاب ئەنجامی سەرژمێرییەکەی دایە داود: لە هەموو ئیسرائیل ملیۆنێک و سەد هەزار پیاوی بە توانا لە بەکارهێنانی شمشێر هەبوون، لە یەهوداش چوار سەد و حەفتا هەزار هەبوون.
\p 
\v 6 بەڵام یۆئاب لێڤی و بنیامینییەکانی لەگەڵیان نەژمارد، چونکە ڕقی لە فەرمانەکەی پاشا دەبووەوە.
\v 7 ئەم فەرمانە لەلای خوداش خراپ بوو، لەبەر ئەوە سزای ئیسرائیلی دا.
\p 
\v 8 داودیش بە خودای گوت: «بەم کارەم گوناهێکی زۆر گەورەم کرد، ئێستاش تکایە لە تاوانی بەندەکەت خۆشبە، چونکە ڕەفتارێکی زۆر گێلانەم کرد.»
\p 
\v 9 یەزدان بە گادی فەرموو، کە پەیامی خودای بە داود ڕادەگەیاند:
\v 10 «بڕۆ بە داود بڵێ: ”یەزدان ئەمە دەفەرموێت: من سێ هەڵبژاردە دەخەمە بەردەمت و تۆش یەکێکیان هەڵبژێرە بۆ ئەوەی جێبەجێی بکەم لەسەرت.“»
\p 
\v 11 ئیتر گاد چوو بۆ لای داود و پێی گوت: «یەزدان ئەمە دەفەرموێت: ”بۆ خۆت هەڵبژێرە،
\v 12 سێ ساڵ قاتوقڕی، یان سێ مانگ هەڵاتن لەبەردەم دوژمنەکەت کە بە شمشێر ڕاوت دەنێت، یان سێ ڕۆژ شمشێری یەزدان بە دەرد لە خاکەکە دەدات و فریشتەی یەزدانیش لە هەموو سنوورەکانی ئیسرائیلدا وێرانکاری دەکات.“ ئێستا ببینە چی وەڵامی خودا بدەمەوە کە منی ناردووە.»
\p 
\v 13 داودیش بە گادی گوت: «زۆر لە تەنگانەدام، با بکەومە دەستی یەزدان، چونکە ئەو بەزەیی زۆر زۆرە، بەڵام با نەکەومە ژێر دەستی مرۆڤەوە.»
\p 
\v 14 لەبەر ئەوە یەزدان دەردی خستە ناو ئیسرائیلەوە، ئیتر حەفتا هەزار پیاو لە ئیسرائیل مردن.
\v 15 هەروەها خودا فریشتەیەکی بۆ سەر ئۆرشەلیم نارد بۆ ئەوەی وێرانی بکات، کاتێک وێرانی دەکرد، یەزدان تەماشای کرد و کارەساتەکەی ڕاگرت، بە فریشتە وێرانکەرەکەی فەرموو: «بەسە! ئێستا دەست هەڵبگرە!» فریشتەکەی یەزدان لەو کاتەدا لەسەر جۆخینەکەی ئەرەونای یەبوسی ڕاوەستابوو.
\p 
\v 16 داود سەری هەڵبڕی و بینی فریشتەکەی یەزدان لەنێوان زەوی و ئاسماندا ڕاوەستاوە، شمشێرەکەی بەدەستەوەیە و بەسەر ئۆرشەلیمدا ڕایکێشاوە. داود و ئەو پیرانەی کە جلوبەرگی گوشیان\f + \fr 21:16 \ft لە کاتی ماتەمگێڕان و تۆبەکردندا جلوبەرگی لە گوش دروستکراویان لەبەرکردووە کە ئەزیەتی پێستیانی داوە.‏\f* پۆشیبوو بەسەر ڕوویاندا کەوتن.
\p 
\v 17 داود بە خودای گوت: «ئایا من نەبووم کە فەرمانم دا سەرژمێری گەل بکەن؟ منم ئەوەی کە گوناهم کردووە، لە ڕاستیدا من خراپەم کرد، بەڵام ئەم مەڕانە چییان کردووە؟ ئەی یەزدان، خودای من، تکایە با سزاکەت بۆ من و بنەماڵەکەم بێت، نەک ئەم دەردە لەسەر گەلەکەت بەردەوام بێت.»
\p 
\v 18 ئینجا فریشتەکەی یەزدان بە گادی فەرموو، کە بە داود بڵێت، با داود سەربکەوێت و لەسەر جۆخینەکەی ئەرەونای یەبوسی قوربانگایەک بۆ یەزدان دابمەزرێنێت.
\v 19 داودیش بەپێی قسەکەی گاد کە بە ناوی یەزدانەوە گوتی، سەرکەوت.
\p 
\v 20 لە کاتێکدا ئەرەونا گەنمی دەکوتا، ئاوڕی دایەوە و فریشتەکەی بینی، چوار کوڕەکەی ئەرەونا کە لەگەڵیدا بوون خۆیان شاردەوە.
\v 21 پاشان داود بەرەو لای ئەرەونا هات، ئەرەونا چاوی هەڵبڕی بینی کە داود بەرەو لای ئەو دێت، لە جۆخینەکە چووە دەرەوە، کڕنۆشی بۆ داود برد و سەری خستە سەر زەوی.
\p 
\v 22 داود بە ئەرەونای گوت: «شوێنی جۆخینەکەم بدەرێ تاکو قوربانگایەک بۆ یەزدان بنیاد بنێم و دەردەکە لە کۆڵ گەل ببێتەوە، بە نرخی تەواوی خۆی بمدەرێ.»
\p 
\v 23 ئەرەوناش بە داودی گوت: «بۆ خۆتی ببە و با پاشای گەورەم چی بە چاک دەزانێت ئەوە بکات. تەماشا بکە. ئەوە گا بۆ قوربانی سووتاندن و جەنجەڕ بۆ دار و گەنمەکەش بۆ پێشکەشکراوی دانەوێڵە. هەمووی دەدەم.»
\p 
\v 24 بەڵام داودی پاشا بە ئەرەونای گوت: «نەخێر، بەڵکو بە نرخی تەواوی خۆی دەیکڕم، چونکە ئەوەی هی تۆیە نایبەم بۆ یەزدان، قوربانی سووتاندنی بەخۆڕایی سەر ناخەم.»
\p 
\v 25 لەبەر ئەوە داود بەرامبەر بە شوێنەکە شەش سەد شاقل زێڕی دایە ئەرەونا.
\v 26 داود لەوێ قوربانگایەکی بۆ یەزدان بنیاد نا و قوربانی سووتاندن و قوربانی هاوبەشی سەرخست. لە یەزدان پاڕایەوە، ئەویش بە ئاگر لە ئاسمانەوە بۆ سەر قوربانگاکەی قوربانی سووتاندن وەڵامی دایەوە.
\p 
\v 27 پاشان یەزدان فەرمانی بە فریشتەکە کرد و ئەویش شمشێرەکەی گەڕاندەوە ناو کێلانەکەی\f + \fr 21:27 \ft یان کالانەکەی.‏\f*.
\v 28 لەو کاتەدا کە داود بینی یەزدان لەسەر جۆخینەکەی ئەرەونای یەبوسی وەڵامی دایەوە، لەوێدا قوربانی سەربڕی.
\v 29 لەو کاتەدا چادرەکەی پەرستنی یەزدان کە موسا لە چۆڵەوانیدا دروستی کردبوو، لەگەڵ قوربانگاکەی قوربانی سووتاندن، لەسەر بەرزاییەکەی گبعۆن بوون.
\v 30 بەڵام داود نەیتوانی بچێتە بەردەمی هەتا پرسیار لە خودا بکات، چونکە لە شمشێرەکەی فریشتەی یەزدان دەترسا.
\c 22
\p 
\v 1 ئینجا داود گوتی: «ئێرە ماڵی یەزدانی پەروەردگارە، هەر ئێرەش قوربانگای قوربانی سووتاندنی ئیسرائیلە.»
\s1 ئامادەکاری بۆ پەرستگاکە
\p 
\v 2 ئیتر داود فەرمانی دا بە کۆکردنەوەی ئەو نامۆیانەی لە خاکی ئیسرائیل بوون، هەندێکی لێ کردنە نەقاڕ بۆ تاشینی بەردی چوارگۆشەیی بۆ بنیادنانی ماڵی خودا.
\v 3 داود ئاسنێکی زۆری بۆ بزمار و ئەڵقەڕیزی دەرگاکان ئامادە کرد، بڕۆنزێکی زۆری لەکێش نەهاتووشی ئامادە کرد.
\v 4 هەروەها داری ئورزیشی ئامادە کرد کە لە ژمارە نەدەهات، چونکە سەیدائییەکان و سورییەکان دار ئورزێکی زۆریان بۆ داود هێنا.
\p 
\v 5 داود گوتی: «سلێمانی کوڕم منداڵە و پێنەگەیشتووە، ئەم ماڵەش کە بۆ یەزدان بنیاد دەنرێت دەبێت لەبەرچاوی هەموو گەلان زۆر گەورە و بەناوبانگ و شکۆدار بێت، لەبەر ئەوە من ئێستا ئامادەکاری بۆ دەکەم.» جا داود بەر لە مردنی ئامادەکارییەکی زۆری بۆ کرد.
\p 
\v 6 پاشان سلێمانی کوڕی بانگکرد و ڕایسپارد کە ماڵێک بۆ یەزدانی پەروەردگاری ئیسرائیل بنیاد بنێت.
\v 7 داود بە سلێمانی گوت: «کوڕی خۆم، من لە دڵمدا بوو ماڵێک بۆ ناوی یەزدانی پەروەردگارم بنیاد بنێم.
\v 8 بەڵام فەرمایشتی یەزدانم بۆ هات، پێی فەرمووم: ”تۆ خوێنێکی زۆرت ڕشتووە و جەنگی گەورەشت کردووە، لەبەر ئەوە ماڵ بۆ ناوەکەم دروستناکەیت، چونکە لەبەردەمم خوێنێکی زۆرت ڕشتووەتە سەر زەوی.
\v 9 بەڵام کوڕێکت دەبێت، دەبێتە پیاوی ئاشتی و حەسانەوە، لە هەموو دوژمنەکانی دەوروبەری دەیحەسێنمەوە. ناوی سلێمان\f + \fr 22:9 \ft ناوەکە لە زمانی عیبریدا \tl شەلۆمۆ‏\tl*یە کە لە ڕووی دەنگەوە لە وشەی (ئاشتی)ی عیبری نزیکە.‏\f* دەبێت، لە ماوەی پاشایەتی ئەودا ئاشتی و ئارامی بە ئیسرائیل دەبەخشم.
\v 10 ئەو ماڵێک بۆ ناوەکەم بنیاد دەنێت، من دەبمە باوکی ئەو و ئەویش دەبێتە کوڕی من، تەختی پاشایەتییەکەشی هەتاهەتایە لەسەر ئیسرائیل جێگیر دەکەم.“
\p 
\v 11 «کوڕی خۆم، ئێستاش یەزدانت لەگەڵدا بێت و سەرکەوتوو بیت و ماڵەکەی یەزدانی پەروەردگارت بنیاد بنێیت بەو شێوەیەی سەبارەت بە تۆ فەرمووی.
\v 12 کاتێک فەرمانڕەوایەتی ئیسرائیل دەکەیت یەزدان دانایی و تێگەیشتنت بداتێ بۆ ئەوەی فێرکردنەکانی یەزدانی پەروەردگارت پەیڕەو بکەیت.
\v 13 ئەگەر ئاگاداربیت لەوەی ئەو فەرز و حوکمانە بەجێبهێنیت کە یەزدان لە ڕێگەی موساوە فەرمانی بە گەلی ئیسرائیل کرد، ئەو کاتە سەرکەوتوو دەبیت. ئیتر بەهێزبە و ئازابە، مەترسە و ورە بەرمەدە.
\p 
\v 14 «من ناخۆشی زۆرم چێژتووە بۆ دابینکردنی ئەمانە بۆ پەرستگای یەزدان، سەد هەزار تالنت\f + \fr 22:14 \ft سەد هەزار تالنت: نزیکەی 3450 تەن.‏\f* زێڕ و ملیۆنێک تالنت\f + \fr 22:14 \ft ملیۆن تالنت: نزیکەی 34500 تەن.‏\f* زیو، بڕۆنز و ئاسنێکی زۆری لە کێش نەهاتووش، دار و بەردیشم ئامادە کردووە. تۆش دەتوانیت زیاتریان بکەیت.
\v 15 کرێکارێکی زۆرت لەلایە، لە نەقاڕ و بەنا و دارتاش و کەسانی شارەزا لە هەموو کار و پیشەیەک
\v 16 لەسەر زێڕ و زیو و بڕۆنز و ئاسن، وەستاکان لە ژمارە نایەن. ئیتر هەستە و دەستبەکار بە و یەزدانت لەگەڵ بێت.»
\p 
\v 17 پاشان داود فەرمانی بە هەموو سەرکردەکانی ئیسرائیل کرد هاریکاری سلێمانی کوڕی بکەن:
\v 18 «ئایا یەزدانی پەروەردگارتان لەگەڵتان نییە؟ ئایا لە هەموو لایەکەوە نەیحەساندوونەتەوە؟ دانیشتووی خاکەکەی داوەتە دەستم و خاکەکەی ژێردەستەی یەزدان و گەلەکەی کردووە.
\v 19 ئێستاش بە هەموو دڵ و گیانتانەوە ڕووتان لە یەزدانی پەروەردگارتان بکەن. هەستن و پیرۆزگای یەزدانی پەروەردگار بنیاد بنێن، بۆ ئەوەی سندوقی پەیمانی یەزدان و قاپوقاچاغی پیرۆزگای خودا بهێنرێتە ناو ئەو پەرستگایەی کە بۆ ناوی یەزدان بنیاد دەنرێت.»
\c 23
\s1 لێڤییەکان
\p 
\v 1 پاش ئەوەی داود پیر بوو و بە ساڵا چوو، سلێمانی کوڕی کرد بە پاشای ئیسرائیل.
\p 
\v 2 هەموو سەرکردەکانی ئیسرائیل و کاهین و لێڤییەکانی کۆکردەوە و
\v 3 ئەو لێڤییانەشی تەمەنیان سی ساڵ و بەرەو سەرەوە بوو سەرژمێری کران و کۆی ژمارەیان سی و هەشت هەزار پیاو بوو.
\v 4 داود گوتی: «بیست و چوار هەزار لەمانە بۆ سەرپەرشتیکردنی کاری پەرستگای یەزدان و شەش هەزاریان کوێخا و دادوەر و
\v 5 چوار هەزاریان دەرگاوان و چوار هەزاری دیکەشیان بۆ ستایشکردنی یەزدان بەو ئامێرە مۆسیقییانەی کە بۆ ستایشکردن دروستم کردن.»
\b
\li4 
\v 6 ئینجا داود لێڤییەکانی کردە چەند بەشێک، بەپێی کوڕەکانی لێڤی: گێرشۆن و قەهات و مەراری.
\s1 گێرشۆنییەکان
\li1 
\v 7 لە گێرشۆنییەکان:
\li2 لەعدان و شیمعی.
\li1 
\v 8 کوڕەکانی لەعدان:
\li2 یەحیێلی کوڕە گەورەی بنەماڵەکە، ئینجا زێتام و یۆئێل، سێ کوڕ بوون.
\li1 
\v 9 کوڕەکانی شیمعی:
\li2 شەلۆمۆت، حەزیێل و هاران، سێ کوڕ بوون.
\li2 ئەمانە گەورەی بنەماڵەکانی لەعدان بوون.
\li1 
\v 10 کوڕەکانی شیمعیش:
\li2 یەحەت و زیزا و یەعوش و بەریعە.
\li2 ئەمانە چوار کوڕەکەی شیمعی بوون.
\li2 
\v 11 یەحەت کوڕە گەورەی بنەماڵەکە بوو و زیزا دووەم بوو، بەڵام یەعوش و بەریعە کوڕی زۆریان نەبوو، لەبەر ئەوە وەک یەک بنەماڵە هەژمارد کران.
\s1 قەهاتییەکان
\li1 
\v 12 کوڕەکانی قەهات:
\li2 عەمرام، یەسهار، حەبرۆن و عوزیێل، چوار کەس بوون.
\li1 
\v 13 کوڕەکانی عەمرام:
\li2 هارون و موسا.
\li2 هارون و نەوەکانی بۆ هەتاهەتایە بۆ تەرخانکردنی شتی هەرەپیرۆز هەڵبژێردران، بۆ قوربانی کردن لەبەردەم یەزدان و داواکردنی بەرەکەت بە ناوی ئەوەوە بۆ هەتاهەتایە.
\v 14 هەروەها کوڕەکانی موسای پیاوی خودا وەک بەشێک لە هۆزی لێڤی دانران.
\li1 
\v 15 کوڕەکانی موسا
\li2 گێرشۆم و ئەلیعەزەر بوون.
\li1 
\v 16 نەوەکانی گێرشۆم:
\li2 شوڤائێل کوڕە گەورەی بنەماڵەکە بوو.
\li1 
\v 17 نەوەی ئەلیعەزەریش:
\li2 ئەلیعەزەر تەنها یەک کوڕی هەبوو ناوی ڕەحەڤیا بوو،
\li2 بەڵام ڕەحەڤیا کوڕی زۆر بوو.
\li1 
\v 18 کوڕەکانی یەسهار:
\li2 شەلۆمیت کوڕە گەورەی بنەماڵەکە بوو.
\li1 
\v 19 کوڕەکانی حەبرۆن:
\li2 یەرییاهو کوڕە گەورەی بنەماڵەکە بوو،
\li2 ئەمەریا دووەم و یەحەزیێل سێیەم و یەقەمەعام چوارەمیان بوو.
\li1 
\v 20 کوڕەکانی عوزیێل:
\li2 میخا کوڕە گەورەی بنەماڵەکە بوو و ییشیا دووەمیان بوو.
\s1 مەرارییەکان
\li1 
\v 21 کوڕەکانی مەراری:
\li2 مەحلی و موشی.
\li1 کوڕەکانی مەحلی:
\li2 ئەلعازار و قیش.
\li2 
\v 22 ئەلعازار مرد و کوڕی نەبوو، تەنها کچی هەبوو، جا کوڕەکانی قیشی برای هێنایانن.
\li1 
\v 23 کوڕەکانی موشی:
\li2 مەحلی، عێدەر و یەریمۆت، سێ کوڕ بوون.
\b
\li4 
\v 24 ئەمانە نەوەی لێڤی بوون بەگوێرەی بنەماڵەکانیان. گەورەی بنەماڵەکان کە بەپێی ناوەکانیان تۆمار کران و یەک بە یەک سەرژمێر کران، لە گەنجی بیست ساڵ بەرەو سەرەوە کە لە پەرستگای یەزدان خزمەتیان دەکرد،
\v 25 چونکە داود گوتبووی: «لەبەر ئەوەی یەزدانی پەروەردگاری ئیسرائیل گەلەکەی حەساندووەتەوە و بۆ هەتاهەتایە یەزدان لە ئۆرشەلیم نیشتەجێ بووە،
\v 26 ئیتر پێویست ناکات لێڤییەکان چادرەکەی پەرستن یان هیچ یەکێک لەو قاپوقاچاغانەی کە لە خزمەتی چادرەکەی پەرستن بەکاردەهێنرێت هەڵبگرن و بگوازنەوە.»
\v 27 بەپێی دوایین فەرمانی داود، لێڤییەکان لە گەنجی بیست ساڵ بەرەو سەرەوە سەرژمێری کران.
\b
\p 
\v 28 لێڤییەکان بەردەستی نەوەی هارونیان دەکرد لە خزمەتکردنی پەرستگای یەزدان: بەرپرس بوون بۆ حەوشە و ژوورە لاتەنیشتەکان، بۆ پاککردنەوەی شتە پیرۆزەکان، بۆ خزمەتکردنی دیکەش لە ماڵی خودا؛
\v 29 بەرپرسیاریێتیشیان هەبوو بۆ نانی تەرخانکراو و باشترین ئارد بۆ پێشکەشکراوی دانەوێڵە و ناسکە نانی\f + \fr 23:29 \ft ناسکە نان: ناوەشکێنە.‏\f* فەتیرەی و خۆراکی سەر ساج و تێکەڵکردنی هەرچی کە تێکەڵ دەکرێت و بۆ هەموو ئەندازە و پێوانەکردنێک؛
\v 30 هەروەها بۆ ڕاوەستان هەموو بەیانییەک بۆ سوپاسکردن و ستایشکردنی یەزدان ئێوارانیش بە هەمان شێوە؛
\v 31 هەروەها بۆ هەموو سەرخستنێکی قوربانی سووتاندن لە شەممە و سەرەمانگ و جەژنەکان. پێویست بوو لێڤییەکان بەو ژمارەیە و بەو چەشنەی کە ڕێسایە لەسەریان، بە بەردەوامی لەبەردەم یەزدان خزمەت بکەن.
\p 
\v 32 ئیتر لێڤییەکان لە چادری چاوپێکەوتن و شوێنی پیرۆز پارێزگاریان دەکرد، هەروەها بەردەستی نەوەی هارونیان دەکرد لە خزمەتکردنی پەرستگای یەزدان.
\c 24
\s1 دابەشکردنی کاهینەکان بەسەر لقەکاندا
\p 
\v 1 ئەمانەش بەشەکانی نەوەی هارون بوون:
\p کوڕەکانی هارون، ناداب و ئەبیهو و ئەلعازار و ئیتامار بوون.
\v 2 ناداب و ئەبیهو پێش باوکیان مردن و کوڕیان نەبوو، لەبەر ئەوە ئەلعازار و ئیتامار بوون بە کاهین.
\v 3 بە یارمەتی سادۆق لە نەوەی ئەلعازار و ئەحیمەلەخ لە نەوەی ئیتامار، داود نەوەی هارونی بەپێی خشتەی خزمەتکردنەکانیان دابەش کرد.
\v 4 جا بینییان نەوەی ئەلعازار ژمارەی ڕابەرەکانیان زیاترە لە نەوەی ئیتامار، لەبەر ئەوە نەوەی ئەلعازاریان دابەش کرد بە شازدە گەورەی بنەماڵە و نەوەی ئیتاماریش بە هەشت گەورەی بنەماڵە.
\v 5 لەبەر ئەوەی لە هەردوو نەوەی ئەلعازار و ئیتاماریش کاربەدەستانی پیرۆزگا و کاربەدەستانی خودا هەبوون، بێ لایەن تیروپشکیان بۆ کرا و دابەشیان کردن.
\p 
\v 6 شەمەعیای کوڕی نەتەنێل لە نەوەی لێڤییەکان کە سەرقەڵەم بوو، بە ئامادەبوونی پاشا و کاربەدەستەکان، سادۆقی کاهین، ئەحیمەلەخی کوڕی ئەبیاتار و گەورەی بنەماڵەکانی کاهین و لێڤییەکان، ناوەکانی ئەوانی بەم چەشنە نووسی: یەک بنەماڵە سەر بە ئیتامار لەدوای یەک سەر بە ئەلعازار.
\b
\li1 
\v 7 یەکەم تیروپشک بۆ یەهۆیاریڤ دەرچوو و
\li1 دووەم بۆ یەدایا و
\li1 
\v 8 سێیەم بۆ حاریم و
\li1 چوارەم بۆ سەعۆریم و
\li1 
\v 9 پێنجەم بۆ مەلکیا و
\li1 شەشەم بۆ میامین و
\li1 
\v 10 حەوتەم بۆ هەقۆچ و
\li1 هەشتەم بۆ ئەبیا و
\li1 
\v 11 نۆیەم بۆ یێشوع و
\li1 دەیەم بۆ شەخەنەیا و
\li1 
\v 12 یازدەیەم بۆ ئەلیاشیڤ و
\li1 دوازدەیەم بۆ یاقیم و
\li1 
\v 13 سێزدەیەم بۆ حوپا و
\li1 چواردەیەم بۆ یەشەڤەئاڤ و
\li1 
\v 14 پازدەیەم بۆ بیلگا و
\li1 شازدەیەم بۆ ئیمێر و
\li1 
\v 15 حەڤدەیەم بۆ حێزیر و
\li1 هەژدەیەم بۆ هەپیچێچ و
\li1 
\v 16 نۆزدەیەم بۆ پەتەحیا و
\li1 بیستەم بۆ یەحەزقیێل و
\li1 
\v 17 بیست و یەکەم بۆ یاکین و
\li1 بیست و دووەم بۆ گاموول و
\li1 
\v 18 بیست و سێیەم بۆ دەلایا و
\li1 بیست و چوارەمیش بۆ مەعەزیاهو دەرچوو.
\b
\p 
\v 19 کە هاتنە ناو پەرستگای یەزدان بەپێی ئەم خشتەیە خزمەتیان دەکرد بەگوێرەی ئەو ڕێسایانەی کە هارونی باپیرە گەورەیان بۆی دیاری کردن، بەپێی ئەوەی یەزدانی پەروەردگاری ئیسرائیل فەرمانی پێی کردبوو.
\s1 پاشماوەی لێڤییەکان
\li4 
\v 20 سەبارەت بەو نەوانەی لێڤی کە ماونەتەوە:
\b
\li1 لە نەوەی عەمرام: شوڤائێل؛
\li2 لە نەوەی شوڤائێل: یەحدەیاهو.
\li1 
\v 21 لە نەوەی ڕەحەڤیا: ییشیا کوڕە گەورەی بنەماڵەکە بوو.
\li1 
\v 22 لە یەسهارییەکان: شەلۆمۆت؛
\li2 لە نەوەی شەلۆمۆت: یەحەت.
\li1 
\v 23 لە نەوەی حەبرۆن:
\li2 یەرییاهوی کوڕە گەورەی بنەماڵەکە بوو و ئەمەریا دووەم و یەحەزیێل سێیەم و یەقەمەعام چوارەم.
\li1 
\v 24 لە نەوەی عوزیێل: میخا و
\li2 لە نەوەی میخا: شامیر و
\li1 
\v 25 ییشیای برای میخا؛ و
\li2 لە نەوەی ییشیا: زەکەریا.
\li1 
\v 26 کوڕەکانی مەراری: مەحلی و موشی.
\li2 کوڕەکەی یەعزیا: بەنۆ.
\li1 
\v 27 لە نەوەی مەراری:
\li2 لە یەعزیا: بەنۆ، شۆهەم، زەکور و عیڤری.
\li1 
\v 28 لە مەحلی: ئەلعازار و ئەلعازاریش کوڕی نەبوو.
\li1 
\v 29 لە قیش: یەرەحمێلی کوڕی قیش،
\li1 
\v 30 هەروەها نەوەی موشی: مەحلی، عێدەر و یەریمۆت.
\b
\li4 ئەمانە نەوەی لێڤی بوون بەپێی بنەماڵەکانیان.
\b
\p 
\v 31 هەروەها ئەمانیش وەک براکانیان لە نەوەی هارون تیروپشکیان کرد، لەبەردەم داودی پاشا و سادۆق و ئەحیمەلەخ و گەورەی بنەماڵەکانی کاهین و لێڤییەکان، جیاوازی نەکرا لەنێوان بنەماڵەکانی برا گەورە و بنەماڵەکانی برا بچووکەکاندا، هەردوو وەک یەک.
\c 25
\s1 گۆرانیبێژەکان
\p 
\v 1 داود و سەرکردەکانی سوپا هەندێک لە کوڕەکانی ئاساف و هێیمان و یەدوتونیان بۆ خزمەتی ڕاگەیاندنی پەیامی خودا تەرخان کرد، ئەم خزمەتەشیان بە قیسارە و ساز و سەنج دەکرد. لیستی تۆماری پیاوە ژەنیارەکان بەگوێرەی خزمەتەکەیان بەم جۆرە بوو:
\b
\li1 
\v 2 لە کوڕەکانی ئاساف:
\li2 زەکور، یوسف، نەتەنیاهۆ و ئەسەرئێلا. کوڕەکانی ئاساف لەژێر سەرپەرشتی ئاسافدا بوون کە لەبەردەستی پاشادا پەیامی خودایان ڕادەگەیاند.
\li1 
\v 3 لە یەدوتون، کوڕەکانی یەدوتون:
\li2 گەدەلیاهو، چەری، یەشەعیا، شیمعی، حەشەڤیا و مەتیسیا، واتا شەش کەس لەژێر سەرپەرشتی یەدوتونی باوکیاندا بوون، کە بە قیسارەوە پەیامی خودای ڕادەگەیاند و سوپاس و ستایشی یەزدانی دەکرد.
\li1 
\v 4 لە هێیمان، کوڕەکانی هێیمان:
\li2 بوقیاهو، مەتەنیا، عوزیێل، شوڤائێل، یەریمۆت، حەنەنیا، حەنانی، ئەلییاتا، گیدەلتی، ڕۆمەمتی عەزەر، یۆشبەقاشا، مەلۆتی، هۆتیر و مەحەزیۆت.
\v 5 هەموو ئەمانە کوڕەکانی هێیمان بوون کە پەیامی خودای بە پاشا ڕادەگەیاند. خودا بەڵێنی پێدابوو کە ناوی بەرز بکاتەوە و چواردە کوڕ و سێ کچی پێدا.
\b
\p 
\v 6 هەموو ئەمانە لەژێر دەستی باوکیاندا بوون بۆ گۆرانی گوتن بۆ پەرستگای خودا بە سەنج و ساز و قیسارەش، بۆ خزمەتکردنی ماڵی خودا.
\p ئاساف، یەدوتون و هێیمان لەژێر دەستی پاشادا بوون.
\v 7 ژمارەی ئەمان و خزمەکانیان، کە فێری مۆسیقاژەندن بوون و شارەزا بوون لە مۆسیقاژەندن بۆ یەزدان، دوو سەد و هەشتا و هەشت کەس بوون.
\v 8 جا تیروپشکیان کرد بۆ کار و ئەرکەکانیان، بچووک و گەورە وەک یەک، هەروەها قوتابی و مامۆستا وەک یەک.
\b
\li1 
\v 9 تیروپشکی یەکەم کە هی ئاساف بوو، بۆ یوسف دەرچوو، خۆی و کوڕەکانی و براکانی؛
\li1 دووەم بۆ گەدەلیاهو، خۆی و براکانی و کوڕەکانی کە دوازدە بوون؛
\li1 
\v 10 سێیەم بۆ زەکور، کوڕەکانی و براکانی کە دوازدە بوون؛
\li1 
\v 11 چوارەم بۆ یەچری، کوڕەکانی و براکانی کە دوازدە بوون؛
\li1 
\v 12 پێنجەم بۆ نەتەنیاهۆ، کوڕەکانی و براکانی کە دوازدە بوون؛
\li1 
\v 13 شەشەم بۆ بوقیاهو، کوڕەکانی و براکانی کە دوازدە بوون؛
\li1 
\v 14 حەوتەم بۆ یەسەرێلا، کوڕەکانی و براکانی کە دوازدە بوون؛
\li1 
\v 15 هەشتەم بۆ یەشەعیا، کوڕەکانی و براکانی کە دوازدە بوون؛
\li1 
\v 16 نۆیەم بۆ مەتەنیا، کوڕەکانی و براکانی کە دوازدە بوون؛
\li1 
\v 17 دەیەم بۆ شیمعی، کوڕەکانی و براکانی کە دوازدە بوون؛
\li1 
\v 18 یازدەیەم بۆ عەزەرئێل، کوڕەکانی و براکانی کە دوازدە بوون؛
\li1 
\v 19 دوازدەیەم بۆ حەشەڤیا، کوڕەکانی و براکانی کە دوازدە بوون؛
\li1 
\v 20 سێزدەیەم بۆ شوڤائێل، کوڕەکانی و براکانی کە دوازدە بوون؛
\li1 
\v 21 چواردەیەم بۆ مەتیسیا، کوڕەکانی و براکانی کە دوازدە بوون؛
\li1 
\v 22 پازدەیەم بۆ یەریمۆت، کوڕەکانی و براکانی کە دوازدە بوون؛
\li1 
\v 23 شازدەیەم بۆ حەنەنیا، کوڕەکانی و براکانی کە دوازدە بوون؛
\li1 
\v 24 حەڤدەیەم بۆ یۆشبەقاشا، کوڕەکانی و براکانی کە دوازدە بوون؛
\li1 
\v 25 هەژدەیەم بۆ حەنانی، کوڕەکانی و براکانی کە دوازدە بوون؛
\li1 
\v 26 نۆزدەیەم بۆ مەلۆتی، کوڕەکانی و براکانی کە دوازدە بوون؛
\li1 
\v 27 بیستەم بۆ ئەلییاتا، کوڕەکانی و براکانی کە دوازدە بوون؛
\li1 
\v 28 بیست و یەکەم بۆ هۆتیر، کوڕەکانی و براکانی کە دوازدە بوون؛
\li1 
\v 29 بیست و دووەم بۆ گیدەلتی، کوڕەکانی و براکانی کە دوازدە بوون؛
\li1 
\v 30 بیست و سێیەم بۆ مەحەزیۆت، کوڕەکانی و براکانی کە دوازدە بوون؛
\li1 
\v 31 بیست و چوارەمیش بۆ ڕۆمەمتی عەزەر، کوڕەکانی و براکانی کە دوازدە بوون.
\c 26
\s1 دەرگاوانەکان
\li4 
\v 1 بەشی دەرگاوانەکان بریتی بوون لە بنەماڵەی قۆرەح:
\b
\li4 لە قۆرەحییەکان:
\li1 مەشەلەمیای کوڕی قۆرێ لە نەوەی ئاساف.
\v 2 مەشەلەمیا چەند کوڕێکی هەبوو:
\li2 زەکەریا نۆبەرە و یەدیعێل دووەم و
\li2 زەڤەدیا سێیەم و یەسنیێل چوارەم و
\li2 
\v 3 ئیلام پێنجەم و یەهۆحانان شەشەم
\li2 و ئەلیهۆعێینەی حەوتەم.
\li1 
\v 4 عوبێد ئەدۆمیش چەند کوڕێکی هەبوو،
\li2 شەمەعیا نۆبەرە و یەهۆزاڤاد دووەم و
\li2 یۆئاح سێیەم و ساکار چوارەم و
\li2 نەتەنێل پێنجەم و
\v 5 عەمیێل شەشەم و
\li2 یەساخار حەوتەم و پەعولەتەی هەشتەم،
\li2 چونکە خودا عوبێد ئەدۆمی بەرەکەتدار کردبوو.
\li1 
\v 6 شەمەعیای کوڕی عوبێد ئەدۆمیش چەند کوڕێکی هەبوو، کە ڕابەری بنەماڵەکەیان بوون، چونکە ئەوان پیاوی زۆر بە توانا بوون.
\v 7 کوڕەکانی شەمەعیا:
\li2 عۆسنی، ڕفائێل، عوبێد و ئەلزاڤاد؛
\li2 هەروەها ئەلیهو و سەمەکیاهوی خزمانی شەمەعیا لە پیاوانی بەهێز بوون.
\li4 
\v 8 هەموو ئەمانە نەوەی عوبێد ئەدۆم بوون؛ خۆیان و کوڕەکانیان و کەسەکانیان پیاوانی بەهێز و بە توانا بوون لە خزمەتەکەیان، شەست و دوو کەس لە نەوەی عوبێد ئەدۆم بوون.
\li4 
\v 9 مەشەلەمیا و کوڕ و کەسەکانی کە لە پیاوە بەهێزەکان بوون، هەژدە کەس بوون.
\b
\li1 
\v 10 حۆسا کە لە نەوەی مەراری بوو، چەند کوڕێکی هەبوو:
\li2 شیمری لەگەڵ ئەوەی نۆبەرەش نەبوو، بەڵام باوکی کردی بە پێشەنگی کوڕەکانی؛
\li2 
\v 11 حیلقیا دووەم بوو و تەڤەلیاهو سێیەم
\li2 و زەکەریا چوارەم.
\li4 هەموو کوڕ و کەسەکانی حۆسا سێزدە کەس بوون.
\b
\li4 
\v 12 ئەم بەشی دەرگاوانانەش لەژێر سەرپەرشتی ڕابەرەکانیان ئەرکی خزمەتکردنیان لە پەرستگای یەزدان پێ سپێردرا، هەروەک کەسەکانیان.
\v 13 جا تیروپشک بۆ هەموو دەروازەکان کرا، بۆ پیران وەک گەنجان بەگوێرەی بنەماڵەکانیان بەبێ جیاوازی.
\li1 
\v 14 تیروپشکی دەروازەی ڕۆژهەڵات بۆ شەلەمیاهو دەرچوو،
\li1 بۆ زەکەریای کوڕیشی کە ڕاوێژکارێکی وریا بوو، تیروپشک کرا و دەروازەی باکووری بۆ دەرچوو.
\li1 
\v 15 تیروپشکی دەروازەی باشوور بۆ عوبێد ئەدۆم دەرچوو، تیروپشکی کۆگاکەش بۆ کوڕەکانی.
\li1 
\v 16 بۆ تیروپشکی دەروازەی ڕۆژئاوا و دەروازەی شەلەخەت لەسەر ئەو ڕێگایەی کە بەرەو ژوور دەبووەوە، بۆ شوپیم و حۆسا دەرچوو.
\b
\li4 پاسەوان بەرامبەر بە پاسەوان بوو:
\li1 
\v 17 ڕۆژانە شەش لە لێڤییەکان لەلای ڕۆژهەڵات
\li1 و چوار لەلای باکوور
\li1 و چوار لەلای باشوور بوون،
\li1 لەلای کۆگاکەش دوو دوو پاسەوانیێتییان دەکرد.
\li1 
\v 18 بۆ ڕێڕەوە سەر داپۆشراوکەی لای ڕۆژئاوا کە هەردوو لای بە کۆڵەکە گیرابوو، چوار لێڤی لەسەر ڕێگاکە و دووانیش لەناو ڕێڕەوەکە بوون.
\b
\li4 
\v 19 ئەمانە بەشی دەرگاوانەکان بوون، لە نەوەی قۆرەحییەکان و لە نەوەی مەراری.
\s1 خەزنەدار و کاربەدەستانی دیکە
\p 
\v 20 هەندێک لە لێڤییەکان لێپرسراوی گەنجینەکانی ماڵی خودا و گەنجینەکانی شتە تەرخانکراوەکان بوون.
\p 
\v 21 یەحیێلی و کوڕەکانی گەورەی بنەماڵەکانی لەعدانی گێرشۆنی بوون.
\v 22 هەروەها یەحیێلی و کوڕەکانی، زێتام و یۆئێلی برای، لێپرسراوی گەنجینەکانی پەرستگای یەزدان بوون.
\b
\li4 
\v 23 لەگەڵ ئەمانیش هەریەک لە بنەماڵەی عەمرامی، یەسهاری، حەبرۆنی و عوزیێلییەکان ئەرک و بەرپرسیاریێتی پێ سپێردرا:
\b
\li2 
\v 24 شوڤائێلی نەوەی گێرشۆمی کوڕی موسا لێپرسراوی گەنجینەکان بوو.
\v 25 کەسەکانی لە نەوەی ئەلیعەزەر: ڕەحەڤیا کوڕی ئەلیعەزەر، یەشەعیا کوڕی ڕەحەڤیا، یۆرامی کوڕی یەشەعیا، زکری کوڕی یۆرام و شەلۆمیتی کوڕی زکری.
\li2 
\v 26 شەلۆمیت لەگەڵ کەسەکانی لێپرسراوی هەموو گەنجینەکانی شتە تەرخانکراوەکان بوون کە داودی پاشا و گەورەی بنەماڵەکان، فەرماندەی هەزاران و سەدان و سەرکردەکانی سوپا تەرخانیان کردبوون.
\v 27 ئەوان بەشێک لە دەستکەوتەکانی جەنگیان بۆ چاککردنەوەی پەرستگای یەزدان تەرخان کرد.
\v 28 هەروەها هەموو ئەو شتانەی ساموئێلی پێشبینیکەر و شاولی کوڕی قیش و ئەبنێری کوڕی نێر و یۆئابی کوڕی چەرویا تەرخانیان کردبوون، لەگەڵ هەموو شتە تەرخانکراوەکانی دیکە، شەلۆمیت و کەسەکانی لێی بەرپرس بوون.
\li2 
\v 29 لە یەسهارییەکانیش:
\li2 کەنەنیاهو و کوڕەکانی بۆ کارەکانی دەرەوەی پەرستگاکە، کوێخا و دادوەر بوون بەسەر ئیسرائیلەوە.
\li2 
\v 30 لە حەبرۆنییەکان:
\li2 حەشەڤیا و کەسەکانی کە لە بەتواناکان بوون، هەزار و حەوت سەد کەس سەرپەرشتیاری ئیسرائیل بوون لەوبەری ڕووباری ئوردون بەلای ڕۆژئاوادا لە هەموو کارەکانی یەزدان و خزمەتەکانی پاشادا.
\v 31 لە حەبرۆنییەکانیش، یەرییاهو گەورەی بنەماڵەی حەبرۆنییەکان بوو بەپێی ڕەچەڵەکنامەیان.
\li2 لە چلەمین ساڵی پاشایەتی داود لێکۆڵینەوەیەک لە تۆمارەکانی کرا و بینییان پیاوانی بە توانا لەنێو حەبرۆنییەکانی دانیشتووانی یەعزێر لە ناوچەی گلعاد هەبوون.
\v 32 داودی پاشا دوو هەزار و حەوت سەد کەس لە برا و کەسەکانی یەرییاهو کە لە پیاوە بەهێزەکان و گەورەی بنەماڵەکان بوون، کردنی بە لێپرسراوی ڕەئوبێنییەکان و گادییەکان و نیوەی هۆزی مەنەشە لە هەموو کاروبارەکانی خودا و پاشا.
\c 27
\s1 لەشکرەکان
\li4 
\v 1 ئەمە لیستی پلەدارەکانی نەوەی ئیسرائیلە، کە گەورەی بنەماڵەکان و فەرماندەی هەزاران و سەدان بوون، لەگەڵ ئەفسەرەکانیان کە لە هەموو کاروباری لەشکرەکانیان خزمەتی پاشایان دەکرد. ئەمانە بە نۆبە دەهاتنە سەربازی و دەڕۆیشتنەوە، بە درێژایی ساڵ، مانگ بە مانگ، هەر لەشکرێکیش بریتی بوو لە بیست و چوار هەزار پیاو.
\b
\li1 
\v 2 یاشۆڤەعامی کوڕی زەبدیێل فەرماندەی لەشکری یەک بوو بۆ مانگی یەک، لەشکرەکەی لە بیست و چوار هەزار پیاو پێکهاتبوو،
\v 3 لە نەوەی پێرێز بوو، فەرماندەی هەموو ئەفسەرەکانی لەشکری مانگی یەک\f + \fr 27:3 \ft سەربازەکانی لەشکر بۆ ماوەی یەک مانگ لە ساڵێک لە ئەرکدا بوون و دوای ئەوە دەگەڕانەوە سەر کاری ئاسایی خۆیان.‏\f* بوو.
\li1 
\v 4 دۆدایی ئەحۆحیش فەرماندەی لەشکری مانگی دوو بوو، لە لەشکرەکەی ئەودا میقلۆت سەرکردە بوو، لە بیست و چوار هەزار پیاو پێکهاتبوو.
\li1 
\v 5 بەنایای کوڕی یەهۆیاداعی کاهین فەرماندەی لەشکری مانگی سێ بوو، لەشکرەکەشی لە بیست و چوار هەزار پیاو پێکهاتبوو.
\v 6 ئەمە ئەو بەنایایە کە پاڵەوان بوو لەنێو سییەکە و سەرکردەیان بوو، عەمیزاڤادی کوڕیشی فەرماندەی ئەفسەرەکانی ناو لەشکرەکەی بوو.
\li1 
\v 7 عەساهێلی برای یۆئاب فەرماندەی لەشکری مانگی چوار بوو، لەشکرەکەی لە بیست و چوار هەزار پیاو پێکهاتبوو، پاشان زەڤەدیای کوڕی جێگەی گرتەوە.
\li1 
\v 8 شەمهوتی یزراحی فەرماندەی لەشکری مانگی پێنج بوو، لەشکرەکەشی لە بیست و چوار هەزار پێکهاتبوو.
\li1 
\v 9 عیرای کوڕی عیقێشی تەقۆعی فەرماندەی لەشکری مانگی شەش بوو، لەشکرەکەشی لە بیست و چوار هەزار پیاو پێکهاتبوو.
\li1 
\v 10 حەلەچی پەلۆنی لە نەوەی ئەفرایم فەرماندەی لەشکری مانگی حەوت بوو، لەشکرەکەشی لە بیست و چوار هەزار پیاو پێکهاتبوو.
\li1 
\v 11 سیبەخەیی حوشاتی لە خێڵی زەرەحییەکان فەرماندەی لەشکری مانگی هەشت بوو، لەشکرەکەشی لە بیست و چوار هەزار پیاو پێکهاتبوو.
\li1 
\v 12 ئەبیعەزەری عەناتۆتی لە نەوەی بنیامین فەرماندەی لەشکری مانگی نۆ بوو، لەشکرەکەشی لە بیست و چوار هەزار پیاو پێکهاتبوو.
\li1 
\v 13 مەهەرەیی نەتۆفایی لە خێڵی زەرەحییەکان فەرماندەی لەشکری مانگی دە بوو، لەشکرەکەشی لە بیست و چوار هەزار پیاو پێکهاتبوو.
\li1 
\v 14 بەنایای پیرعاتۆنی لە نەوەی ئەفرایم فەرماندەی لەشکری مانگی یازدە بوو، لەشکرەکەشی لە بیست و چوار هەزار پیاو پێکهاتبوو.
\li1 
\v 15 حەلدەیی نەتۆفایی لە نەوەی عۆسنیێل فەرماندەی لەشکری مانگی دوازدە بوو، لەشکرەکەشی لە بیست و چوار هەزار پیاو پێکهاتبوو.
\s1 سەرۆکی هۆزەکان
\li4 
\v 16 ئەمانە سەرۆک هۆزەکانی ئیسرائیل بوون:
\b
\li1 بۆ هۆزی ڕەئوبێنییەکان: ئەلیعەزەری کوڕی زکری؛
\li1 بۆ شیمۆنییەکان: شەفەتیای کوڕی مەعکا؛
\li1 
\v 17 بۆ لێڤییەکان: حەشەڤیای کوڕی قەموئێل؛
\li1 بۆ هارون: سادۆق؛
\li1 
\v 18 بۆ یەهودا: ئەلیهو کە یەکێک لە براکانی داود بوو؛
\li1 بۆ یەساخار: عۆمری کوڕی میکائیل؛
\li1 
\v 19 بۆ زەبولون: یەشمەعیای کوڕی عۆبەدیا؛
\li1 بۆ نەفتالی: یەریمۆتی کوڕی عەزریێل؛
\li1 
\v 20 بۆ نەوەی ئەفرایم: هۆشێیەعی کوڕی عەزەزیاهو؛
\li1 بۆ نیوەی هۆزی مەنەشە: یۆئێلی کوڕی پەدایا؛
\li1 
\v 21 بۆ نیوەکەی دیکەی هۆزی مەنەشە لە گلعاد: ییدۆی کوڕی زەکەریا؛
\li1 بۆ بنیامین: یەعسیێلی کوڕی ئەبنێر؛
\li1 
\v 22 بۆ دان: عەزەرئێلی کوڕی یەرۆحام.
\b
\li4 ئەمانە سەرۆکی هۆزەکانی ئیسرائیل بوون.
\b
\p 
\v 23 داودیش ژمارەی ئەوانەی وەرنەگرت کە گەنجی بیست ساڵ و کەمتر بوون، چونکە یەزدان بەڵێنی دابوو کە ئیسرائیل وەک ئەستێرەکانی ئاسمان زۆر دەکات.
\v 24 یۆئابی کوڕی چەرویاش دەستی بە سەرژمێرییەکە کرد، بەڵام تەواوی نەکرد، چونکە ئەم سەرژمێرییە تووڕەیی خودای هێنایە سەر ئیسرائیل، هەروەها ئاماری سەرژمێرییەکەش لە پەڕتووکی کاروباری ڕۆژانەی داود پاشادا تۆمار نەکرا.
\s1 لێپرسراوانی ماڵوموڵکەکانی پاشا
\li1 
\v 25 عەزماڤێتی کوڕی عەدیێل لێپرسراوی گەنجینەکانی پاشا بوو.
\li1 یۆناتانی کوڕی عوزیا لێپرسراوی ئەو ئەمبارانە بوو کە لە کێڵگە و شارۆچکە و گوند و لەناو قوللەکانی چاودێری بوون.
\li1 
\v 26 عەزری کوڕی کەلووڤیش لێپرسراوی وەرزێرەکانی کێڵگە بوو، ئەوانەی زەوییان دەکێڵا.
\li1 
\v 27 شیمعی ڕاماتی لێپرسراوی ڕەزەمێوەکان بوو.
\li1 زەبدی شیفەمی لێپرسراوی بەروبوومەکانی ڕەز بوو بۆ ئەمبارەکانی شەراب.
\li1 
\v 28 بەعل‌حانانی گەدەری لێپرسراوی دار زەیتوون و دار هەنجیرەکانی کە لە زوورگەکانی\f + \fr 27:28 \ft زوورگ: لە تەپۆڵکە بەرزترە، هەروەک بەرزاییەکانی زوورگەزراو لە کوردستان.‏\f* یەهودا بوو.
\li1 یۆعاشی بەرپرسیاری ئەمبارەکانی زەیت بوو.
\li1 
\v 29 شیترەیی شارۆنی لێپرسراوی ئەو مانگایانە بوو کە لە دەشتاییەکانی شارۆندا دەلەوەڕان.
\li1 شافاتی کوڕی عەدلای لێپرسراوی مانگاکانی ناو دۆڵەکان بوو.
\li1 
\v 30 ئۆبیلی ئیسماعیلی لێپرسراوی وشترەکان بوو.
\li1 یەحدەیاهوی مێرۆنۆتی لێپرسراوی گوێدرێژەکان بوو.
\li1 
\v 31 یازیزی هاجەری لێپرسراوی مەڕەکان بوو.
\li4 هەموو ئەمانە لێپرسراوی ماڵوموڵکەکانی داودی پاشا بوون.
\b
\li1 
\v 32 یۆناتانی مامی داودیش ڕاوێژکار بوو، پیاوێکی تێگەیشتوو و سەرقەڵەم بوو،
\li1 یەحیێلی کوڕی حەکمۆنیش چاودێری کوڕەکانی پاشا بوو.
\li1 
\v 33 ئەحیتۆفەل ڕاوێژکاری پاشا بوو.
\li1 حوشەی ئەرکیش هاوڕێی پاشا بوو.
\li4 
\v 34 لەپاش ئەحیتۆفەلیش یەهۆیاداعی کوڕی بەنایا بوو بە ڕاوێژکار، دوای ئەمیش ئەبیاتار جێگەی گرتەوە.
\li1 یۆئابیش سەرکردەی سوپاکەی پاشا بوو.
\c 28
\s1 نەخشەی داود بۆ پەرستگا
\p 
\v 1 داود هەموو ڕابەرانی ئیسرائیلی لە ئۆرشەلیم کۆکردەوە: سەرۆک هۆزەکان؛ فەرماندەی ئەو لەشکرانەی کە لە خزمەتی پاشا بوون، لەگەڵ فەرماندەی هەزاران و سەدان؛ ئەو کاربەدەستانەی کە لێپرسراوی ماڵوموڵک و ئاژەڵەکانی پاشا و کوڕەکانی بوون، لەگەڵ کاربەدەستانی کۆشکی پاشا؛ پاڵەوانەکان و هەموو جەنگاوەرە دلێر و ئازاکان.
\p 
\v 2 داودی پاشا هەستایە سەر پێ و گوتی: «گوێم لێ بگرن ئەی گەلی برام، من لە دڵمدا بوو ماڵێکی حەوانەوە بۆ سندوقی پەیمانی یەزدان و بۆ تەختەپێی خودامان بنیاد بنێم و خۆمم بۆ بنیادنان ئامادە کرد.
\v 3 بەڵام خودا پێی فەرمووم: ”ماڵ بۆ ناوەکەم بنیاد مەنێ، چونکە تۆ پیاوی جەنگیت و خوێنت ڕشتووە.“
\p 
\v 4 «لەگەڵ ئەوەشدا یەزدانی پەروەردگاری ئیسرائیل لە هەموو ماڵی باوکم منی هەڵبژارد تاکو بۆ هەتاهەتایە ببمە پاشای ئیسرائیل، چونکە یەهودای وەک ڕابەر هەڵبژارد، لە هۆزی یەهوداش ماڵی باوکم، لە کوڕەکانی باوکیشم بە من خۆشحاڵ بوو بۆ ئەوەی بمکاتە پاشای هەموو ئیسرائیل.
\v 5 لەنێو هەموو ئەو کوڕانەم کە یەزدان پێی بەخشیوم، سلێمانی کوڕمی هەڵبژاردووە هەتا لەسەر تەختی پاشایەتی یەزدانی ئیسرائیل دابنیشێت.
\v 6 پێی فەرمووم: ”سلێمانی کوڕت ماڵەکەم و حەوشەکەم بۆ بنیاد دەنێت، چونکە ئەوم بە کوڕی خۆم هەڵبژاردووە و منیش دەبمە باوکی ئەو،
\v 7 ئەگەر بەردەوام بێت لە کارکردن بە فەرمان و حوکمەکانم، ئەوا پاشایەتییەکەی هەتاهەتایە جێگیر دەکەم.“
\p 
\v 8 «ئێستاش لەبەرچاوی هەموو ئیسرائیل کە کۆمەڵی یەزدانە و لەبەردەم خوداشمان، ڕاتاندەسپێرم: ئاگاداربن بە جێبەجێکردنی هەموو فەرمانەکانی یەزدانی پەروەردگارتان، بۆ ئەوەی ببنە خاوەنی ئەم خاکە چاکە و هەتاهەتایە وەک میراتیش بۆ نەوەکانتان بیهێڵنەوە.
\p 
\v 9 «سلێمانی کوڕی خۆم، تۆش خودای باوکت بناسە و پڕ بە دڵ و بە هەموو بیرتەوە بیپەرستە، چونکە یەزدان هەموو دڵەکان دەپشکنێت و هەموو شێوەکانی بیرکردنەوە تێدەگات، ئەگەر ڕووی لێ بکەیت بۆت دەردەکەوێت و ئەگەر فەرامۆشی بکەیت هەتاهەتایە ڕەتت دەکاتەوە.
\v 10 ئێستاش ببینە، چونکە یەزدان هەڵیبژاردوویت بۆ ئەوەی ماڵێک بۆ پیرۆزگاکە بنیاد بنێیت، جا بەهێزبە و کار بکە.»
\p 
\v 11 پاشان داود نەخشەی هەیوانەکەی پەرستگا و تەلار و گەنجینە و ژوورەکانی سەرەوەی و ناوەوەی و قەپاغی کەفارەتی\f + \fr 28:11 \ft قەپاغی کەفارەت لە زێڕی بێگەرد دروستکرابوو کە دوو باڵ و نیو درێژییەکەی و باڵ و نیوێک پانییەکەی بوو. بڕوانە \xt دەرچوون 25‏:17‏\xt*\ft ‏.‏\f* دایە سلێمانی کوڕی.
\v 12 نەخشەکانی هەموو ئەو شتانەش کە بەهۆی ڕۆحی خوداوە لە دڵیدا بوو، ئەوەی حەوشەکانی پەرستگای یەزدان و هەموو ژوورەکانی دەوروبەری و گەنجینەکانی پەرستگای خودا و گەنجینەکانی شتە تەرخانکراوەکان.
\v 13 هەروەها ڕێنمایی پێدا لەسەر چۆنیەتی ڕێکخستنی بەشەکانی کاهین و لێڤییەکان و هەموو کارەکانی خزمەتکردنی پەرستگای یەزدان و هەموو قاپوقاچاغەکانی خزمەتکردنی پەرستگای یەزدان.
\v 14 کێشی زێڕ و زیوی ئەو قاپوقاچاغە زێڕین و زیوینەی دیاری کرد کە لە خزمەتە جۆراوجۆرەکاندا بەکاردەهێنران:
\v 15 کێشی چرادانە زێڕینەکە و چراکانیشیان کە لە زێڕ بوو، کێشی زێڕ بۆ هەر چرادانێک و چراکانی؛ بۆ چرادانە زیوینەکانیش، کێشی زیو بۆ هەر چرادانێک و چراکانی، بەپێی جۆری خزمەتی هەر چرادانێک؛
\v 16 کێشی زێڕ بۆ هەر مێزێکی نانی تەرخانکراو؛ کێشی زیویش بۆ مێزە زیوینەکان؛
\v 17 کێشی زێڕی بێگەرد بۆ چەنگاڵ و تاس\f + \fr 28:17 \ft کاهین ئەم تاسانەی بۆ پرژاندنی خوێنی قوربانی بەکاردەهێنا، وەک هێمایەک بۆ کەفارەتی گوناهەکانی خەڵک. بڕوانە \xt دەرچوون 29‏:20 و زەکەریا 9‏:15؛ 14‏:20 و عیبرانییەکان 9‏:13‏\xt*\ft ‏.‏\f* و دۆلکەکان؛ بۆ جامە زێڕینەکانیش کێش بۆ هەر جامێک و بۆ جامە زیوینەکانیش کێش بۆ هەر جامێک؛
\v 18 کێشی زێڕی پوختەکراویش بۆ قوربانگای بخوورەکە. هەروەها نەخشەی گالیسکەی کەڕوبەکانی\f + \fr 28:18 \ft بڕوانە \xt یەکەم پاشایان 6‏:3‏\xt*\ft ‏.‏\f* پێدا، کە باڵیان کردووەتەوە و سێبەریان بۆ سندوقی پەیمانی یەزدان کردووە.
\p 
\v 19 داود گوتی: «هەموو ئەمانەم نووسیوەتەوە سروشی یەزدانە بۆ من، ڕوونکردنەوەکانی ئەم نەخشەیەش یەزدان تێیگەیاندم.»
\p 
\v 20 هەروەها داود بە سلێمانی کوڕی گوت: «بەهێزبە و ئازابە، کار بکە و مەترسە، ورە بەرمەدە، چونکە یەزدانی پەروەردگار، خودای من لەگەڵتدایە. ئەو وازت لێ ناهێنێت و بەجێت ناهێڵێت هەتا هەموو کارەکانی خزمەتکردنی پەرستگای یەزدان تەواو دەکەیت.
\v 21 بەشەکانی کاهین و لێڤییەکان بۆ هەموو خزمەتێکی پەرستگای خودا ئامادەن، هەموو وەستایەکی شارەزا و خۆبەخشت لەگەڵدایە بۆ هەموو کارێک، سەرکردەکان و هەموو گەلیش پەیڕەوی هەموو فەرمانێکی تۆ دەکەن.»
\c 29
\s1 پیتاک بەخشین بۆ بنیادنانی پەرستگا
\p 
\v 1 پاشان داودی پاشا بە هەموو کۆمەڵەکەی گوت: «سلێمانی کوڕم، ئەوەی کە خودا هەڵیبژاردووە، گەنجێکی پێنەگەیشتووە. کارەکەش گەورەیە، چونکە پەرستگاکە بۆ مرۆڤ نییە، بەڵکو بۆ یەزدانی پەروەردگارە.
\v 2 منیش بە هەموو توانامەوە ئەمانەم بۆ پەرستگای خودام ئامادە کردووە، زێڕ بۆ زێڕنگەری، زیو بۆ زیوگەری، بڕۆنز بۆ بڕۆنزگەری، ئاسن بۆ ئاسنگەری، تەختە بۆ دارتاشی، بڕێکی زۆر لە بەردی عاشقبەند و بەردە پیرۆزە\f + \fr 29:2 \ft بەردە پیرۆزە: بەردێکی شینی سەوزباو. بڕوانە \xt دەرچوون 28‏:18‏\xt*\ft ‏.‏\f* و چەندین جۆرە بەردی ڕەنگاوڕەنگ، هەروەها هەموو جۆرە بەردێکی باش و مەڕمەڕی سپی.
\v 3 لەسەر هەموو ئەوەی بۆ پەرستگا پیرۆزەکە ئامادەم کردووە، لەبەر خۆشحاڵیم بە پەرستگای خوداکەم، ئێستا گەنجینەیەکی تایبەتی خۆشم لە زێڕ و زیو دەبەخشم:
\v 4 سێ هەزار تالنت\f + \fr 29:4 \ft سێ هەزار تالنت: نزیکەی سەد تەن.‏\f* زێڕ لە زێڕی ئۆفیر و حەوت هەزار تالنت\f + \fr 29:4 \ft حەوت هەزار تالنت: نزیکەی 240 تەن.‏\f* زیوی پوختەکراو بۆ ڕووکەشکردنی دیواری تەلارەکان و
\v 5 هەر کارێک کە بە زێڕ و زیو دەکرێت، هەموو کارێکی دەستی وەستا پیشەوەرەکانیش. ئێستا کێ خوازیارە خۆی بۆ یەزدان تەرخان بکات؟»
\p 
\v 6 ئینجا گەورەی بنەماڵە و سەرۆک هۆزەکانی ئیسرائیل و فەرماندەی هەزاران و سەدان، لێپرسراوانی کارەکانی پاشاش هەموویان بە خواستی خۆیان پیتاکیان بەخشی.
\v 7 بۆ کاری بیناسازی پەرستگای خودا پێنج هەزار تالنت\f + \fr 29:7 \ft پێنج هەزار تالنت: نزیکەی 170 تەن.‏\f* زێڕ و دە هەزار درهەمی\f + \fr 29:7 \ft دە هەزار درهەم: نزیکەی 84 کیلۆگرام، درهەم پارە و پولێکی فارسی بووە.‏\f* زێڕ، دە هەزار تالنت\f + \fr 29:7 \ft نزیکەی 345 تەن.‏\f* زیو، هەژدە هەزار تالنت\f + \fr 29:7 \ft نزیکەی 610 تەن.‏\f* بڕۆنز و سەد هەزار تالنت\f + \fr 29:7 \ft نزیکەی 3450 تەن.‏\f* ئاسنیان بەخشی.
\v 8 ئەوەی بەردی گرانبەهای هەبوو دایە گەنجینەی پەرستگای یەزدان کە یەحیێلی گێرشۆنی بەرپرسی بوو.
\v 9 گەل بە بەخشندەیی ڕابەرەکانیان دڵخۆش بوون، چونکە بە هەموو دڵیانەوە پیتاکەکانیان بە یەزدان بەخشی، داودی پاشاش زۆر دڵخۆش بوو.
\s1 نوێژی داود
\p 
\v 10 داود لەبەردەم هەموو کۆمەڵەکە ستایشی یەزدانی کرد و گوتی:
\q1 «ستایش بۆ تۆ ئەی یەزدان،
\q2 خودای ئیسرائیل، باوکمانی
\q2 لە ئەزەلەوە و بۆ هەتاهەتایە.
\q1 
\v 11 ئەی یەزدان، بۆ تۆیە گەورەیی و توانا،
\q2 مەزنی و پایەبەرزی و شکۆ،
\q2 چونکە هەموو ئەوەی لە ئاسمان و لە زەویدایە هی تۆیە.
\q1 ئەی یەزدان، پاشایەتی هی تۆیە و
\q2 تۆ هەرەبەرزیت و لە هەمووان پایەبەرزتری.
\q1 
\v 12 دەوڵەمەندی و ڕێز لەلای تۆوە دێن،
\q2 تۆ فەرمانڕەوای هەمووانیت.
\q1 هێز و توانا لە دەستی تۆدان
\q2 تاکو هەمووان بەهێز و ورەبەرز بکەیت.
\q1 
\v 13 ئێستاش ئەی خودای ئێمە، سوپاست دەکەین و
\q2 ستایشی ناوە شکۆدارەکەت دەکەین.
\p 
\v 14 «بەڵام من کێم و گەلەکەم کێیە هەتا بتوانین بەم دڵفراوانییەوە ببەخشین؟ هەموو شتێک لە تۆوە دێت، لەوەی کە هی تۆیە بە تۆمان بەخشییەوە.
\v 15 ئێمە لەبەرچاوی تۆدا نامۆین و وەک هەموو باوباپیرانمان ئاوارەین\f + \fr 29:15 \ft ئاوارەین: بڕوانە \xt پەیدابوون 23‏:4‏\xt*\ft ‏.‏\f*. ڕۆژانمان لەسەر زەوی وەک سێبەرن و ئومێدیش نییە.
\v 16 ئەی یەزدانی پەروەردگارمان، هەموو ئەم سامانەی کە ئامادەمان کردووە بۆ ئەوەی پەرستگایەک بۆ ناوی پیرۆزت بنیاد بنێین، هەمووی لە تۆوە هاتووە و هەموو شتێکیش هی تۆیە.
\v 17 خودایە من دەزانم کە تۆ دڵەکان تاقی دەکەیتەوە و بە دڵی پاک دڵخۆش دەبیت. من بە خواستی خۆم و بە ڕاستگۆییەوە هەموو ئەم شتانەم بەخشیوە. ئێستاش دڵخۆش بووم کە گەلەکەی تۆم لێرە بینی چۆن بە خواستی دڵی خۆیان پیتاکیان پێ بەخشیت.
\v 18 ئەی یەزدان، خودای ئیبراهیم و ئیسحاق و ئیسرائیلی باوباپیرانمان، ئەم بیرکردنەوەیە بۆ هەتاهەتایە لە دڵی گەلەکەتدا بپارێزە و دڵیان بەلای خۆتدا ڕابکێشە.
\v 19 هەروەها وا بکە سلێمانی کوڕم پڕ بە دڵ فەرمان و یاسا و فەرزەکانت بەجێبهێنێت، هەموویان پەیڕەو بکات و ئەو پەرستگایە بنیاد بنێت کە ئامادەکاریم بۆی کردووە.»
\p 
\v 20 پاشان داود بە هەموو کۆمەڵەکەی گوت: «تکایە ستایشی یەزدانی پەروەردگارتان بکەن.» ئینجا هەموو کۆمەڵەکە ستایشی یەزدانی پەروەردگاری باوباپیرانی خۆیان کرد و بە چۆکدا هاتن و کڕنۆشیان بۆ یەزدان و پاشا برد.
\s1 دانپێدانانی پاشایەتی سلێمان
\p 
\v 21 پاشان لە ڕۆژی دواتر قوربانییان بۆ یەزدان سەربڕی و قوربانی سووتاندنیان بۆ یەزدان سەرخست، هەزار گا و هەزار بەران و هەزار بەرخی نێر لەگەڵ شەرابە پێشکەشکراوەکانیان و قوربانی سەربڕاوی زۆر بۆ هەموو ئیسرائیل.
\v 22 جا لەو ڕۆژەدا بە ئەوپەڕی خۆشییەوە لەبەردەم یەزدان خواردیان و خواردیانەوە.
\p پاشان دووبارە سلێمانی کوڕی داودیان وەک پاشا ڕاگەیاند و وەک فەرمانڕەوایەک لەلایەن یەزدانەوە دەستنیشان کرا، سادۆقیش وەک کاهین دانرایەوە.
\v 23 ئیتر سلێمان وەک پاشا لەسەر کورسی یەزدان دانیشت، لە جێی داودی باوکی. سەرکەوتوو بوو و هەموو ئیسرائیلیش گوێڕایەڵی بوون.
\v 24 هەروەها هەموو سەرکردە و پاڵەوان و سەرجەم کوڕەکانی داودی پاشا سوێندیان خوارد ملکەچی سلێمانی پاشا بن.
\p 
\v 25 یەزدانیش سلێمانی لەبەرچاوی هەموو ئیسرائیل زۆر مەزن کرد، شکۆیەکی شاهانەی وای پێدا کە پێش خۆی لە ئیسرائیل نەدرابووە هیچ پاشایەکی دیکە.
\s1 مردنی داود
\p 
\v 26 داودی کوڕی یەسا پاشایەتی هەموو ئیسرائیلی کرد،
\v 27 ئەو ماوەیەش کە پاشایەتی ئیسرائیلی کرد چل ساڵ بوو، حەوت ساڵ لە حەبرۆن و سی و سێ ساڵیش لە ئۆرشەلیم پاشایەتی کرد.
\v 28 لە تەمەنێکی باشی پیریدا مرد و لە ژیان و دەوڵەمەندی و ڕێز، تێری خواردبوو. پاشان سلێمانی کوڕی لەدوای خۆی بوو بە پاشا.
\p 
\v 29 ڕووداوەکانی پاشایەتی داود لە سەرەتاوە هەتا کۆتایی لە پەڕتووکی تۆمارەکانی ساموئێلی پێشبینیکەر و لە تۆمارەکانی ناتانی پێغەمبەر نووسراون، هەروەها لە تۆمارەکانی گادی پێشبینیکەر،
\v 30 لەگەڵ هەموو وردەکارییەکانی پاڵەوانیێتی و پاشایەتییەکەی و هەموو ئەو ڕۆژگارانەشی کە بەسەر خۆی و بەسەر ئیسرائیل و هەموو پاشایەتییەکانی خاکەکاندا تێپەڕین.
