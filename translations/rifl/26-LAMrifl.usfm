\id LAM
\h Izřan s Igejduren
\toc1 Izřan s Igejduren
\toc2 Izřan s Igejduren
\toc3 Igjd.
\mt1 Izřan s Igejduren
\c 1
\s1 Izři amezwaru - X Urcalim
\m 
\v 1 \bd Alif.\bd* Mammec teqqim \add diha\add*
\m tendint weḥḥdes!
\m Tuɣa řebda teccur s řɣaci,
\m tedweř am yict n tajjač,
\m tuɣa-tt d tameqqrant jar řegnus,
\m iǧis n ujeǧid jar lɛamalat,
\m tedweř ɣar tesmuɣi.
\b
\m 
\v 2 \bd Bit.\bd* Tᵉttru imeṭṭawen imerzagen s ǧiřet,
\m imeṭṭawen nnes x imeggizen nnes.
\m War ɣares wi tt ɣa iɛezzan
\m zi marra inni tt ittexsen,
\m marra imeddukkař nnes ɣdaren-tt,
\m dewřen as d řɛedyan. \x ◘ \xo 1:2 \xt Izhd. 6:7\x*
\b
\m 
\v 3 \bd Gimel.\bd* Tᵉttwaḥebbes \add temmurt n\add* Yahuda
\m zi ssibbet n řeɣben,
\m u zi ssibbet n řqedd
\m n txemmast nnes iqesḥen.
\m Tᵉttɣima jar řegnus, war tufi arraḥet,
\m marra inni tt iḍaffaren ḥarrten xas
\m di řwesṭ n řeḥṣarat nnes.
\b
\m 
\v 4 \bd Dalit.\bd* Ibriden ɣar Ṣihyun ceḍnen,
\m minzi uřa d ijj war iggur \add ɛad\add* ɣar řɛid.
\m Marra tiwwura nnes xřant,
\m ikehhanen nnes zehharen,
\m tiɛzariyyin nnes ceḍnent,
\m uca nettat simant nnes teccur s tarzugi.
\b
\m 
\v 5 \bd Hi.\bd* Iɣrimen nnes dewřen ḥekkmen \add xas\add*,
\m řɛedyan nnes farrḥen,
\m maɣar SIDI issecḍen i-tt
\m zi ssibbet n řqedd n řmuɛṣiyyet nnes.
\m Iḥenjiren nnes imeẓyanen uyuren
\m di tmeḥbast zzat i tiṭṭawin n iɣrimen nsen.
\b
\m 
\v 6 \bd Waw.\bd* Acewwar n yeǧis n Ṣihyun
\m ingez zzayes,
\m marra řḥukkam nnes ggin am udaden
\m inni war ittifen ddemnet n tarewsa.
\m Gguren nitni břa jjehd
\m zzat i tiṭṭawin n wenni ten iḍaffaren.
\b
\m 
\v 7 \bd Zayin.\bd* Deg wussan n řeɣben nnes
\m u deg waṭṭas n wetlaɛ nnes
\m ad teɛqeř Urcalim x marra min dayes iɣřan,
\m min ɣares tuɣa zic.
\m Řami iwḍa řgens nnes s ufus n weɣrim,
\m tuɣa war din wi d as i ɣa iwcen afus.
\m Iɣrimen nnes ẓrin tt,
\m stehzan zeg ureddeǧ nnes.
\b
\m 
\v 8 \bd Xit.\bd* Urcalim tuɣa txeṭṭa aṭṭas.
\m X uya tedweř am yict n temɣart
\m deg \add wussan n\add* weɛzař nnes.
\m Marra inni tuɣa tt ittweqqaren,
\m sseḥqaran tt,
\m minzi ẓrin řeḥya nnes.
\m Uřa nettat simant nnes tzehhar,
\m tedweř ɣar ḍeffar. \x ◘ \xo 1:8 \xt Ica. 47:3\x*
\b
\m 
\v 9 \bd Tit.\bd* Taxmuji nnes \add teřṣeq\add*
\m ɣar tmuwwa \add n ubeḥrur\add* nnes,
\m aneggaru nnes war dayes txemm.
\m Aqa tehwa-dd ɣar řaǧaɣ
\m s ijj n webrid isstebhten,
\m uřa d ijj war tt iɛezzi.
\m Xzar maca řeɣben inu, \add a\add* SIDI,
\m maɣar řeɛdu issmeqqar ixef nnes. \x ◘ \xo 1:9 \xt Aɛwd. 32:29\x*
\b
\m 
\v 10 \bd Yud.\bd* Aɣrim isswiẓẓeḍ afus nnes
\m ɣar marra min dayes iɣřan.
\m Iwa teẓra nettat mammec udfen řegnus
\m ɣar Zzawect nnes Iqeddsen,
\m \add řegnus\add* min xef tumured,
\m war iɛeddeř ad dd-adfen
\m ɣar wegraw \add n řgens\add* nnec.
\b
\m 
\v 11 \bd Kaf.\bd* Qaɛ imezdaɣ nnes zehharen,
\m arezzun aɣrum.
\m Nitni wcin řeqcuɛ iɣřan nsen
\m di ṭṭweɛ n macca,
\m maḥend ad dd-arren asefsi ɣar řeɛmar nsen.
\m Xzar, \add a\add* SIDI, wařa
\m mammec dewřeɣ ttwasseḥqareɣ. \x ◘ \xo 1:11 \xt Irm. 52:6\x*
\b
\m 
\v 12 \bd Lamid.\bd* Ma war daywem icqi,
\m kenniw inni iɛeddun x webrid?
\m Wařam u xzarem,
\m ma \add din\add* ca n řeḥriq am řeḥriq i d ayi ittwaggen,
\m i zi d ayi issxeyyeq SIDI,
\m deg wass n řḥaduq n weɣḍab nnes.
\b
\m 
\v 13 \bd Mim.\bd* Zi sennej i dd-issekk Netta timessi
\m deg iɣsan inu,
\m tcebbar daysen.
\m Netta inḍar-dd tracca ɣar iḍaren inu,
\m yarra ayi ad dewřeɣ ɣar ḍeffar,
\m aqa yareddeǧ ayi,
\m issehřec \add ayi\add* ass am ikmeř.
\b
\m 
\v 14 \bd Nun.\bd* Ittwacedd uzayřu n iɛediyyen inu
\m s ufus nnes,
\m aqa ttwamuden, geɛɛden-dd x yiri inu.
\m Netta yarra jjehd inu ad ifceř.
\m Iwca ayi Sidi inu deg ifassen nsen,
\m necc war zemmareɣ ad beddeɣ \add ɛad\add*.
\b
\m 
\v 15 \bd Samix.\bd* Inḍar Sidi inu
\m marra ayt n bu-ṣṣulṭa inu di řwest inu,
\m am mammec ibarreḥ
\m s ijj n umuni ifarzen ḍidd inu,
\m maḥend ad yarẓ iḥudriyyen inu,
\m Sidi inu aqa iɛfes di tsirt n uḍiř,
\m n teɛzarect, n yeǧis n Yahuda. \x ◘ \xo 1:15 \xt Irm. 14:17\x*
\b
\m 
\v 16 \bd Ɛayin.\bd* S man aya ttruɣ,
\m \add a\add* tiṭṭ inu, \add a\add* tiṭṭ inu issazzařen imeṭṭawen,
\m minzi amesfewwej nni izemmaren
\m ad dd-yarr řeɛmar inu,
\m iggʷej xafi.
\m Ttwateḥḥan iḥenjiren inu,
\m minzi řeɛdu ijhed \add xasen\add*.\x ◘ \xo 1:16 \xt Irm. 13:17\x*
\b
\m 
\v 17 \bd Pi.\bd* Tesswiẓẓeḍ Ṣihyun ifassen nnes,
\m \add maca\add* nettat war ɣares wi tt ɣa issfewwjen.
\m Yumur SIDI x Yaɛqub,
\m aqa iɣrimen nnes ad as dd-nnḍen.
\m Urcalim tedweř jar asen am yict n temɣart
\m \add deg wussan n\add* weɛzař nnes.
\b
\m 
\v 18 \bd Tsadi.\bd* SIDI d amsegged,
\m maɣar necc tuɣa ɣewwɣeɣ x řumurat nnes.
\m Sřem xenni, marra řegnus,
\m xzarem ɣar řehřiq inu.
\m Tiɛzariyyin inu d iḥudriyyen inu
\m uyuren di tmeḥbast.\f ◼ \fr 1:18 \fk x řumurat nnes\ft - s Tɛibranit ‘x uqemmum nnes’.\f*
\b
\m 
\v 19 \bd Quf.\bd* Necc řaɣiɣ x yinni d ayi ittexsen,
\m maca nitni cemten ayi.
\m Ikehhanen inu d imɣaren inu
\m ḍeřqen i buḥbeř di tendint,
\m umi tuɣa arezzun macca i yixef nsen,
\m ḥima ad ssmeḥḍen řeɛmar nsen. \x ◘ \xo 1:19 \xt Irm. 30:14\x*
\b
\m 
\v 20 \bd Rix.\bd* Xzar, \add a\add* SIDI, maɣar necc di řeḥṣaret,
\m takrict inu tenneḥweř,
\m uř inu inneqřeb-dd zi daxeř inu,
\m maɣar tuɣa ɣewwɣeɣ aṭṭas.
\m Di barra i d ayi yucar ssif iḥenjiren inu,
\m daxeř \add iḥekkem\add* řmewt. \x ◘ \xo 1:20 \xt Ica. 16:11; Irm. 48:36\x*
\b
\m 
\v 21 \bd Cin.\bd* Sřin mammec zehhareɣ,
\m \add maca\add* necc war ɣari uřa d ijj n umesfewwej,
\m marra řɛedyan inu sřin x arẓiyyet inu.
\m Farḥen aqa Cek i tt iggin.
\m Xmi dd ɣa tessiwḍed ass i zi dd-tɛeřmed,
\m \add xenni\add* ad iřin am mammec ǧiɣ necc.
\b
\m 
\v 22 \bd Taf.\bd* Ejj ad dd-yas marra řɣar nsen zzatek,
\m egg zzaysen am mammec zzayi teggid
\m zi ssibbet n marra iɛeddiyen inu,
\m minzi izehharen inu d aṭṭas,
\m uř inu yuḥeř aṭṭas.
\b
\b
\c 2
\s1 Izři wiss tnayen - Lɣaḍab n SIDI
\m 
\v 1 \bd Alif.\bd* Mammec idřa Sidi inu
\m yeǧis n Ṣihyun
\m s iseynuten \add ibarcanen\add*?
\m Aqa aɛuǧi n Israil inḍar i-t
\m zeg ujenna ɣar temmurt,
\m Netta war ixarreṣ di tnebdat n iḍaren nnes
\m deg wass n weɣḍab nnes.
\b
\m 
\v 2 \bd Bit.\bd* Iqḍa Sidi inu
\m x marra tizeddaɣ n Yaɛqub,
\m war tent ijji ad nejment.
\m Deg uduqqez nnes \add n ufugem\add*
\m ihdem lqelɛat n yeǧis n Yahuda,
\m ibeqqeḍ i-tent x temmurt,
\m issɛarra tageldit d řḥukkam nnes.
\b
\m 
\v 3 \bd Gimel.\bd* Di řḥaduq n weɣḍab nnes
\m iqess qaɛ icc n Israil.
\m Yarra afus afusi nnes ɣar ḍeffar
\m zzat i řeɛdu,
\m u Netta yarɣa ḍidd i Yaɛqub
\m am tmessi itteḥduduqen,
\m tᵉttett marra min i d as dd-innḍen.
\b
\m 
\v 4 \bd Dalit.\bd* Netta imḥeḍ řqews nnes am řeɛdu,
\m issgeɛɛed afusi nnes am řeɛdu,
\m wenni iwtin marra min temmeẓri tiṭṭ.
\m Deg Uqiḍun n yeǧis n Ṣihyun
\m ifarreɣ asɛar nnes am tmessi.
\b
\m 
\v 5 \bd Hi.\bd* Sidi inu idweř am řeɛdu,
\m iṣarḍ Israil,
\m iṣarḍ marra řeqṣur nnes,
\m ihdem lqelɛat nnes,
\m u yarni \add ɛad\add* deg wecḍan d iɣuyyan
\m ɣar yeǧis n Yahuda.
\b
\m 
\v 6 \bd Waw.\bd* Netta iqřeɛ s lɛunf aɛiccu nnes,
\m am ijj n weḥwic.
\m Yareyyeb amcan n umsagar.
\m Issettu SIDI di Ṣihyun
\m ass n řɛid d ass n ssebt,
\m u deg wesxeḍ nnes
\m inḍar ajeǧid d ukehhan.
\b
\m 
\v 7 \bd Zayin.\bd* Idweř Sidi inu icarreh
\m aɛalṭar nnes,
\m inḍar Zzawect Iqeddsen nnes,
\m iwca řeḥyuḍ n yexxamen n řeqṣar
\m deg ufus n řeɛdu.
\m Nitni ggin ad sřen i tmijja nsen
\m di Taddart n SIDI, am deg ijj n wass n řɛid.
\b
\m 
\v 8 \bd Xit.\bd* SIDI ixarreṣ ad ihdem
\m řḥiḍ n yeǧis n Ṣihyun,
\m isarreḥ \add xas\add* fiřu n řeɛbar,
\m war dd-ijbid ɣares afus nnes zeg uṣarḍ.
\m Ijja acbar n zzat d řḥiḍ ad ceḍnen,
\m aqa ttwaɣeḍřen \add jmiɛ\add* ɣar temmurt.
\b
\m 
\v 9 \bd Tit.\bd* Tiwwura nnes ɣarqent deg ucař,
\m iɛumad nnes n ubelleɛ yareddeǧ i-ten,
\m yarẓa i-ten.
\m Ajeǧid nnes d řḥukkam nnes \add aqa aten\add* jar řegnus,
\m war din \add bu useřmed n\add* Ccariɛa,
\m inabiyyen nnes war ttᵉṭṭifen ca řewḥiy n SIDI.
\b
\m 
\v 10 \bd Yud.\bd* Imɣaren n yeǧis n Ṣihyun
\m qqimen x temmurt, bekmen,
\m zuzzaran ucař x uzeǧif nsen,
\m beysen ixef nsen s txuncay \add n wecḍan\add*.
\m Tiɛzariyyin n Urcalim ssaḍarent
\m azeǧif nsent ɣar temmurt.
\b
\m 
\v 11 \bd Kaf.\bd* Tiṭṭawin inu uhřent zeg imeṭṭawen,
\m takrict inu tᵉttenhezza,
\m tᵉttwazeǧeɛ tsa inu x temmurt,
\m x treẓẓit n yeǧis n řgens inu,
\m minzi aḥenjir d useymi
\m ttɣacan x wazzayen n tendint.
\b
\m 
\v 12 \bd Lamid.\bd* Nitni qqaren i yemmatsen:
\m “Mani iǧa \add ɛad\add* imendi d binu?”,
\m xmi weṭṭan x wazzayen n tendint
\m am yinni ittwanɣen,
\m xmi ttwakksen zi tudart nsen
\m x ifadden n yemmatsen.
\b
\m 
\v 13 \bd Mim.\bd* Min d am i ɣa iniɣ,
\m min ɣar cem i ɣa ssemquddiɣ,
\m \add a\add* yeǧis n Urcalim?
\m Min ɣar cem i ɣa ssemquddiɣ,
\m ařami cem i ɣa ssfewwjeɣ,
\m \add a cem\add* taɛzarect, yeǧis n Ṣihyun,
\m maɣar tareẓẓit nnem d tameqqrant am řebḥar,
\m wi izemmaren ad cem issgenfa?
\b
\m 
\v 14 \bd Nun.\bd* Inabiyyen nnem ẓrin
\m \add iweḥḥan\add* ixarriqen d ibuḥařiyyen,
\m war ssɛarran ca x řmuɛṣiyyet nnem
\m ařami i ɣa ssenqeřben tameḥbast nnem.
\m Di ṭṭweɛ nnem ẓrin nitni
\m \add mɣir\add* řeḥkamat ixarriqen d tḥuja n uɣarri.
\b
\m 
\v 15 \bd Samix.\bd* Marra inni \add xam\add* dd-ittekken
\m ccaten deg ifassen \add s unexřiɛ\add* zi ssibbet nnem.
\m Nitni ttṣeffaren u ssenhezzan azeǧif nsen
\m x yeǧis n Urcalim,
\m qqaren: ‘Ma d ta d tandint nni umi nnan:
\m “Ma war iǧi aẓri nnes ikmeř,
\m d \add řɛunṣar\add* n řefraḥet i marra ddunect!”?
\b
\m 
\v 16 \bd Pi\bd* Marra řɛedyan nnem arezmen-dd ɣarwem
\m iqemmumen nsen,
\m ttṣeffaren u ttɣezzan tiɣmas,
\m qqaren: “Neccin nṣarḍ i-tt.
\m Wa d ass i tuɣa nettraja,
\m řexxu nufa i-t, nettwařa i-t!”
\b
\m 
\v 17 \bd Ɛayin.\bd* Igga SIDI min ixarreṣ,
\m ikemmeř awař nnes
\m wenni yumur zi mecḥař uya.
\m Ihdem i \add cem\add*, war \add xam\add* iḥiweř.
\m Řeɛdu ijja i-t ifarḥ zzayem,
\m issgeɛɛed icc n iɣrimen nnem.
\b
\m 
\v 18 \bd Tsadi.\bd* Uř nsen isɣuyyu ɣar Sidi inu,
\m “\add A\add* řḥiḍ n yeǧis n Ṣihyun,
\m ejj ad azzřen imeṭṭawen \add nnem\add* am teɣzart,
\m ass d ǧiřet břa ma ad neqṣen,
\m war ttejji mummu n tiṭṭawin nnem ad ibedd!” \x ◘ \xo 2:18 \xt Irm. 14:17; Igjd. 1:16\x*
\b
\m 
\v 19 \bd Quf.\bd* Kkar, sɣuyy di ǧiřet,
\m ɣar umezwaru n tɛessast n ǧiřet,
\m zeǧeɛ uř nnem am waman
\m zzat i wudem n Sidi inu.
\m Sgeɛɛed ɣares ifassen nnem
\m i tudart n iḥenjiren nnem imeẓyanin,
\m inni iwḍan ɣar temmurt s řaẓ,
\m ɣar tɣemmar n marra ibriden.
\b
\m 
\v 20 \bd Rix.\bd* Xzar, \add a\add* SIDI, wařa \add mliḥ\add*
\m umi teggid man aya?
\m Ma ittxeṣṣa \add xenni\add* ad ccent temɣarin
\m řɣiǧet n uɛeddis nsent,
\m iḥenjiren nsent i di tthillant nitenti?
\m Ma ittxeṣṣa ad ittwaneɣ unabi d ukehhan
\m di Zzawect Iqeddsen n Sidi? \x ◘ \xo 2:20 \xt Igjd. 4:10\x*
\b
\m 
\v 21 \bd Cin.\bd* Iḥudriyyen d iwessura buzzřen
\m x temmurt deg ibriden.
\m Tiɛzariyyin inu d iḥudriyyen inu wḍan s ssif.
\m Tenɣid \add ten\add* deg wass n weɣḍab nnec,
\m tɣarṣeḍ \add asen\add*, war \add xasen\add* tḥiwřed ca.
\b
\m 
\v 22 \bd Taf.\bd* Tɛarrned-dd ɣari min issaggʷaden
\m zi marra iɣezdisen,
\m am mammec ibarreḥ s ijj n umuni ifarzen.
\m War inejjim niɣ ittarekkwař uřa d ijj
\m deg wass n weɣḍab n SIDI.
\m Inni i di tthilliɣ u arebbiɣ
\m iqḍa i-ten řeɛdu inu.
\b
\b
\c 3
\s1 Izři wiss třata - Aweddeb d ufewwej n unabi
\m 
\v 1 \bd Alif.\bd* Necc d aryaz nni iẓrin řeɣben
\m s weɛmud n uduqqez nnes \add n ufugem\add*.
\m 
\v 2 \bd Alif.\bd* Netta indeh ayi
\m uca ijja ayi ad uyureɣ di taǧest,
\m war iǧi di tfawt.
\m 
\v 3 \bd Alif.\bd* S tidett,
\m Netta yarra řebda afus nnes ḍidd inu,
\m ass ikmeř.
\b
\m 
\v 4 \bd Bit.\bd* Netta iḍeyyeɛ aysum inu d teřmect inu,
\m yarẓa iɣsan inu.
\m 
\v 5 \bd Bit.\bd* Netta bna ict n řebniyyet xafi
\m u iquwwar ayi
\m s arrhaj d tamara.
\m 
\v 6 \bd Bit.\bd* Di ṭṭřam ijja ayi zeddɣeɣ,
\m am imettan n waṭṭas zeg wami.
\b
\m 
\v 7 \bd Gimel.\bd* Netta ibelleɛ ayi jar řeḥyuḍ,
\m war zemmareɣ ad nejmeɣ.
\m Issedqeř xafi ssnaseř inu n nnḥas.
\m 
\v 8 \bd Gimel.\bd* Ɛad meřmi ttřaɣiɣ u sɣuyyuɣ,
\m Netta iqqim ibkem ɣar tẓaǧit inu.
\m 
\v 9 \bd Gimel.\bd* S tṣuḍar injaren
\m ibelleɛ xafi abrid,
\m issfarɣ imesraq inu.
\b
\m 
\v 10 \bd Dalit.\bd* Tuɣa Netta i necc \add am\add* ddub ittḥaman,
\m \add am\add* wayrad deg imucan innufaren.
\m 
\v 11 \bd Dalit.\bd* Netta yuẓẓeř xafi zeg webrid,
\m imezzeq ayi,
\m war d ayi ijji ca.
\m 
\v 12 \bd Dalit.\bd* Netta issemḥeḍ řqews nnes
\m uca ijja ayi ad iřiɣ d awaḍ i fřitca \add nnes\add*.
\b
\m 
\v 13 \bd Hi.\bd* Fřitcat zeg weqrab nnes
\m ijja i-tent ad adfent di tiẓẓař inu.
\m 
\v 14 \bd Hi.\bd* Dewřeɣ d taseḍhact i marra řgens inu,
\m d izři nsen n uzawar ass imun.
\m 
\v 15 \bd Hi.\bd* Netta issjjiwen ayi s tarzugi,
\m issessu ayi s cciḥ.
\b
\m 
\v 16 \bd Waw.\bd* Tiɣmas inu ijja i-tent zeɛɛfent
\m deg uqayas ařami arẓint,
\m idřa ayi s yiɣɣed.
\m 
\v 17 \bd Waw.\bd* Cek tessiggʷejed řeɛmar inu x řehna,
\m necc ttuɣ \add marra\add* tcuni.
\m 
\v 18 \bd Waw.\bd* Necc nniɣ: “Jjehd inu iqḍa,
\m uřa d asitem inu di SIDI.”
\b
\m 
\v 19 \bd Zayin.\bd* Ɛqeř x řeɣben inu d tmeḥbast inu,
\m x cciḥ d arrhaj.
\m 
\v 20 \bd Zayin.\bd* Řeɛmar inu ittxarreṣ nican di man aya,
\m aqa icḍen dayi.
\m 
\v 21 \bd Zayin.\bd* Aya xseɣ ad t arreɣ ɣar wuř,
\m x uya ad qqimeɣ ssitimeɣ ɛad.
\b
\m 
\v 22 \bd Xit.\bd* S tmegga n tmexsiwt n SIDI,
\m aqa war nettwahellek ca,
\m minzi arreḥmet nnes \add ɛemmarṣ\add* war tᵉttbeddi.\x ◘ \xo 3:22 \xt Ica. 1:9; Ḥab. 3:13\x*
\m 
\v 23 \bd Xit.\bd* Aqa-tt d jdid kuř ṣṣbeḥ,
\m řaman nnec d ameqqran. \x ◘ \xo 3:23 \xt Izhd. 30:6\x*
\m 
\v 24 \bd Xit.\bd* Tasɣart inu d SIDI,
\m \add ammu i\add* iqqar řeɛmar inu,
\m x uya ttɣimiɣ ssitimeɣ dayes. \x ◘ \xo 3:24 \xt Ḥab. 2:3\x*
\b
\m 
\v 25 \bd Tit.\bd* Iṣbeḥ SIDI i yinni dayes issitimen,
\m i řeɛmar nni xas yarezzun.
\m 
\v 26 \bd Tit.\bd* Aqa mliḥ araji s usitem ɣar zzat,
\m \add araji\add* di řhudnet ɣar usenjem zi SIDI.
\m 
\v 27 \bd Tit.\bd* Mliḥ i weryaz ad yarbu azayřu
\m di temẓi nnes.
\b
\m 
\v 28 \bd Yud.\bd* Ejj i-t ad iqqim ḥafi, ad isseɣd,
\m maɣar SIDI igga i-tt xas.
\m 
\v 29 \bd Yud.\bd* Ejj i-t ad igg aqemmum nnes di tɛejjajt,
\m \add ad yini:\add* “Ad taɣ iǧa řayas!” \x ◘ \xo 3:29 \xt Řex. 8:22\x*
\m 
\v 30 \bd Yud.\bd* Ejj i-t ad iwc ameggiz i wenni t iccaten,
\m ejj i-t ad ittwajjiwen s useḥqar.
\b
\m 
\v 31 \bd Kaf.\bd* Minzi Sidi inu war ineṭṭar \add ḥed\add* i řebda,
\m 
\v 32 \bd Kaf.\bd* maca mařa Netta issecḍen \add ḥed\add*,
\m ad \add xas\add* iḥinn ɛawed
\m ɛlaḥsab řemɣaret n tmexsiwt nnes icuwwaren,
\m 
\v 33 \bd Kaf.\bd* maɣar Netta war iḥeṣṣar
\m niɣ issecḍin tarwa n weryaz s wuř.
\b
\m 
\v 34 \bd Lamid.\bd* Xmi ɣa řebzen sadu iḍaren
\m marra imeḥbas n temmurt,
\m 
\v 35 \bd Lamid.\bd* xmi ɣa ḥarrfen tasɣart n weryaz
\m zzat i wudem n Umɛuǧi x kuřci,
\m 
\v 36 \bd Lamid.\bd* xmi ɣa qeřben ddeɛwet n bnadem,
\m ma zeɛma Sidi inu war ittwiři \add man aya\add*?
\b
\m 
\v 37 \bd Mim.\bd* Man wen i iqqaren \add ca n řḥajjet\add*
\m uca \add xenni\add* temsar,
\m \add mařa\add* war tt yumur Sidi inu? \x ◘ \xo 3:37 \xt Izhd. 33:9\x*
\m 
\v 38 \bd Mim.\bd* Ma war dd-ittis
\m zeg uqemmum n Umɛuǧi x kuřci
\m \add marra\add* min war iḥřin uřa d \add marra\add* min iṣebḥen? \x ◘ \xo 3:38 \xt Ica. 45:7; Ɛam. 3:6\x*
\m 
\v 39 \bd Mim.\bd* Mammec ittcetca bnadem iddaren \add ɛad\add*?
\m \add Ejj\add* weryaz \add ad icetca\add* zi ssibbet n ddnub nnes.
\b
\m 
\v 40 \bd Nun.\bd* Ejj aneɣ ad nexzar ibriden nneɣ,
\m ad daysen narzu,
\m ejj aneɣ ad dd-nedweř ɣar SIDI.
\m 
\v 41 \bd Nun.\bd* Ejj aneɣ ad nessgeɛɛed ak-d ifassen nneɣ
\m uřa d wuřawen nneɣ,
\m ɣar Arebbi deg ujenna.
\m 
\v 42 \bd Nun.\bd* Neccin nɛedda u nɣewweɣ,
\m cek war teɣfared ca i \add uya\add*.
\b
\m 
\v 43 \bd Samix.\bd* Cek třeḥḥfed aneɣ s weɣḍab,
\m teḍfareḍ aneɣ,
\m tenɣid, war \add xaneɣ\add* tḥiwřed ca.
\m 
\v 44 \bd Samix.\bd* Třeḥḥfed ixef nnec deg useynu,
\m maḥend ad taf taẓaǧit war tzemmar ad teɛdu.
\m 
\v 45 \bd Samix.\bd* Cek tarrid-dd aneɣ
\m d taxmuji d wefraḍ
\m di řwesṭ n řegnus.
\b
\m 
\v 46 \bd Pi.\bd* Marra řɛedyan nneɣ
\m arzmen-dd ɣarneɣ aqemmum nsen.
\m 
\v 47 \bd Pi.\bd* Tiggʷuda d řfex dewřen \add d azyen\add* zzayneɣ,
\m axarreb d arẓiyyet.
\m 
\v 48 \bd Pi.\bd* Zi tiṭṭawin inu ttazzřent imeṭṭawen
\m x tareẓẓit n yeǧis n řgens inu.
\b
\m 
\v 49 \bd Ɛayin.\bd* Tiṭṭ inu teqqim tᵉttazzeř \add s imeṭṭawen\add*,
\m war tᵉttareyyiḥ, war tessbeddi,
\m 
\v 50 \bd Ɛayin.\bd* ař d i ɣa issijj SIDI zeg ujenna,
\m uca ad ittwařa.
\m 
\v 51 \bd Ɛayin.\bd* Tiṭṭ inu tᵉttegg ayi řeḥriq
\m di řeɛmar inu,
\m zi ssibbet n marra yessis n tendint inu.
\b
\m 
\v 52 \bd Tsadi.\bd* Areddfen ayi-dd řɛedyan inu břa qeṭṭu,
\m am yijj n wejḍiḍ, \add maca\add* břa ssibbet.
\m 
\v 53 \bd Tsadi.\bd* Nitni ssbekmen tudart inu deg wanu,
\m uca nḍaren aẓru xafi.
\m 
\v 54 \bd Tsadi.\bd* Aman ḥemřen-dd x uzeǧif inu,
\m nniɣ: “Aqa war qqimeɣ ǧiɣ!”
\b
\m 
\v 55 \bd Quf.\bd* \add A\add* SIDI, necc řaɣiɣ x Yisem nnec,
\m zi řaǧaɣ n wanu.
\m 
\v 56 \bd Quf.\bd* Cek tesřid i tmijja inu,
\m war tteqqen amezzuɣ nnec zzat i uzehhar inu,
\m zzat i iɣuyyan inu!
\m 
\v 57 \bd Quf.\bd* Cek tusid-dd ɣari
\m deg wass i d ac dd-řaɣiɣ,
\m tennid: “War tteggʷed ca!”
\b
\m 
\v 58 \bd Rix.\bd* Cek, \add a\add* Sidi inu,
\m tarefɛed ddɛawi x řeɛmar inu,
\m Cek tfekked tudart inu.
\m 
\v 59 \bd Rix.\bd* \add A\add* SIDI, teẓrid ddeǧ i dayi iggin,
\m aɣ ayi tasɣart inu.
\m 
\v 60 \bd Rix.\bd* Cek teẓrid marra axřaf nsen,
\m marra min nwan ḍidd inu.
\b
\m 
\v 61 \bd Cin.\bd* Cek tesřid řḥegra nsen, \add a\add* SIDI,
\m marra min nwan ḍidd inu,
\m 
\v 62 \bd Cin.\bd* \add awařen nni dd-itteffɣen\add*
\m \add zi jar\add* iyencicen n yinni xafi ikkaren,
\m uřa d řemwayař nsen n uxarreṣ xafi ass imun.
\m 
\v 63 \bd Cin.\bd* Xzar ɣar uɣimi d ubeddi nsen,
\m necc d izři nsen n ustehzi.
\b
\m 
\v 64 \bd Taf.\bd* \add A\add* SIDI, xeǧeṣ i-ten řmunet nsen
\m i isdaheǧen,
\m ɛlaḥsab timegga n ifassen nsen.
\m 
\v 65 \bd Taf.\bd* Sdaɣreř uřawen nsen,
\m ejj nneɛřet nnec ad dd-xasen-\add tewḍa\add*.
\m 
\v 66 \bd Taf.\bd* Ḍfar \add i-ten\add* deg weɣḍab \add nnec\add*,
\m qḍa xasen zi sadu ujenna n SIDI.
\b
\b
\c 4
\s1 Izři wiss arebɛa - Řmuɛṣiyyet n yeǧis n Urcalim
\m 
\v 1 \bd Alif.\bd* Mammec igga ibbarcen wureɣ ammu,
\m \add mammec\add* ibeddeř wureɣ icna qaɛ \add ammu\add*!
\m Mammec ttwabezzɛen iẓra n Zzawect Iqeddsen
\m x tɣemmura n ibriden!
\b
\m 
\v 2 \bd Bit.\bd* Iḥenjiren iɣřan n Ṣihyun
\m ttwaḥesben am wureɣ iqquren.
\m Mammec d asen tteggen \add řexxu\add*
\m am yiɣarrafen n třaxt,
\m \add am\add* řxedmet n bu-třaxt!
\b
\m 
\v 3 \bd Gimel.\bd* Ɛad tuccanin n řexřa
\m i dd-issuffɣen tibbicin,
\m ssuṭṭuḍent imeẓyanen nsent,
\m \add maca\add* yeǧis n řgens inu tedweř tewɛar,
\m am nnɛamat di řexřa.
\b
\m 
\v 4 \bd Dalit.\bd* Iřes n weḥḍiḍ
\m iřṣeq ɣar waneɣ nnes s ufadi,
\m iḥenjiren imeẓyanen tᵉttaren aɣrum,
\m \add maca\add* uřa d ijjen war d asen t yebḍi.
\b
\m 
\v 5 \bd Hi.\bd* Inni tuɣa ittetten \add zic\add* macca iředden,
\m ɣacan deg ibriden,
\m inni ittwasseymen
\m \add deg warruḍ\add* azeggʷaɣ iḥedqen,
\m ḥennḍen řexxu di řeɣbar.
\b
\m 
\v 6 \bd Waw.\bd* Řmuɛṣiyyet n yeǧis n řgens inu
\m d tameqqrant x ddnub n \add tendint n\add* Sadum,
\m tenni inqeřben deg ijj n umur,
\m břa ttsaxxur n ifassen.
\b
\m 
\v 7 \bd Zayin.\bd* Tuɣa tarwa n taṣiřet nnes
\m ṣfan x wedfeř, d icemřařen x uɣi,
\m arrimat nsen zewɣen x řmarjan,
\m addud nsen \add yareqq\add* am ṣaffir aziza.
\b
\m 
\v 8 \bd Xit.\bd* \add Řexxu\add* ibeddeř waddud nsen,
\m idweř d abarcan x taǧest,
\m war ttwaɛqiřen deg ibriden \add ɛad\add*.
\m Tiřmect nsen teřṣeq x yeɣsan nsen,
\m tuẓeɣ, tedweř am ukeccuḍ.
\b
\m 
\v 9 \bd Tit.\bd* Iḥřa inni ittwanɣen s ssif,
\m x yinni ittwanɣen s řaẓ,
\m maɣar nitni ad fesyen,
\m ttwařeqfen s \add wenqas n\add* ṣṣabet n yeyyar.
\b
\m 
\v 10 \bd Yud.\bd* Ifassen n temɣarin \add nni tuɣa\add* ittḥinnan \add qbeř\add*,
\m ssnennan i iḥenjiren nsen.
\m Nitni dewřen asent d macca,
\m zi ssibbet n treẓẓit n yeǧis n řgens inu.
\b
\m 
\v 11 \bd Kaf.\bd* SIDI yarxu i wesɛar nnes,
\m issfarreɣ řḥaduq n weɣḍab nnes.
\m Netta issarɣ timessi di Ṣihyun,
\m \add timessi\add* tenni iccen dsusa nnes.
\b
\m 
\v 12 \bd Lamid.\bd* Ɛemmarṣ war tᵉttɣiř
\m i ijeǧiden n temmurt
\m d imezdaɣ n ddunect,
\m aqa aɣrim d řeɛdu ad dd-adfen
\m ɣar tewwura n Urcalim.
\b
\m 
\v 13 \bd Mim.\bd* D man aya di ssibbet
\m n ddnub n inabiyyen nnes,
\m \add di ssibbet\add* n řmuɛṣiyyet n ikehhanen nnes,
\m inni issizzřen idammen n imseggaden di řwesṭ nnes.
\b
\m 
\v 14 \bd Nun.\bd* Tettliɛen amecnaw idarɣařen deg ibriden,
\m mesřen s idammen,
\m ařami war izemmar uřa d ijjen ad iḥada arruḍ nsen.
\b
\m 
\v 15 \bd Samix.\bd* “Aggʷejem, \add aqa idammen\add* xemjen!”,
\m řaɣan asen:
\m “Aggʷejem, aggʷejem, war t ttḥadam!”
\m Uca xenni arewřen, qqimen weddaren.
\m Ittwanna jar řegnus:
\m “War iɛeddeř ad qqimen \add din\add* ɛad ktar
\m \add am ibarraniyyen\add*!”
\b
\m 
\v 16 \bd Pi.\bd* Aɣembub n SIDI yareyyec i-ten,
\m War iqqim ad daysen ixzar ɛad.
\m Tuɣa war ɣarsen aweqqar i ikehhanen,
\m iwessura war d asen ssecnen aḥinni.
\b
\m 
\v 17 \bd Ɛayin.\bd* Řebda ttefciřent tiṭṭawin nneɣ,
\m umi xzarent ɣar twiza.
\m Tuɣa-t baṭeř!
\m Ɣar marra axezzar nneɣ nettraja ijj n řgens
\m i war izemmaren ad issenjem. \x ◘ \xo 4:17 \xt Ḥiz. 29:16\x*
\b
\m 
\v 18 \bd Tsadi.\bd* Nitni ḥṣaren aneɣ,
\m ařami war neqqim nzemmar
\m ad nuyur x wazzayen nneɣ.
\m Qeṭṭu nneɣ tuɣa yiweḍ-dd,
\m ussan nneɣ qḍan,
\m wah, qeṭṭu nneɣ yusa-dd. \x ◘ \xo 4:18 \xt Izhd.49:6\x*
\b
\m 
\v 19 \bd Quf.\bd* Inni d aneɣ iḍeffaren
\m tuɣa fsusen x igidaren deg ujenna.
\m Nitni uẓẓřen xaneɣ x idurar,
\m ggin aneɣ ijj n řfex di řexřa.
\b
\m 
\v 20 \bd Rix.\bd* Nnefs n wenzaren nneɣ, lmasiḥ n SIDI,
\m ittwaḥebbes di iḥufar nsen,
\m wenni x nenna:
\m “Ad neddar jar řegnus di tiři nnes!”
\b
\m 
\v 21 \bd Cin.\bd* Sřiwřew u farḥ, \add a\add* yeǧis n Idum,
\m tenni izeddɣen di temmurt n Ɛuṣ!
\m \add Maca\add* uřa d cem ad ɣarem dd-yas řkas,
\m cem ad zzayes tescared,
\m ad tᵉttwaɛarrid.
\b
\m 
\v 22 \bd Taf.\bd* Ɣar řmuɛṣiyyet nnem ad yiři uneggar,
\m \add a\add* yeǧis n Ṣihyun!
\m Netta war i cem ittḥewwis ɛad.
\m \add Maca\add* Netta ad zzayem ixeǧeṣ řmuɛṣiyyet nnem,
\m \add a\add* yeǧis n Idum!
\m Netta ad iɛarra x ddnub nnem.
\b
\b
\c 5
\s1 Izři wiss xemsa - Taẓaǧit i usenjem
\m 
\v 1 Ɛqeř, \add a\add* SIDI, x min i d aneɣ imsaren,
\m xzar-dd u wařa řḥegra nneɣ.
\m 
\v 2 Tewḍa tesɣart n řwart nneɣ i ibarraniyyen,
\m uřa d tudrin nneɣ ruḥent tt ɣar midden.
\m 
\v 3 Neccin nedweř d iyujiřen břa babatneɣ,
\m tiyemmatin nneɣ dewřent am tijjař.
\m 
\v 4 Aman nneɣ nsess i-ten s tmenyat,
\m akeccuḍ nneɣ nettxeǧaṣ xas.
\m 
\v 5 Ḍeffaren aneɣ x yiri nneɣ,
\m neccin nemmut s řweḥřan,
\m \add maca\add* war d aneɣ jjin arraḥet.
\m 
\v 6 Aqa nsarreḥ afus ɣar Miṣra, ɣar Accur,
\m maḥend ad nejjiwen aɣrum.
\m 
\v 7 Ibabaten nneɣ xḍan,
\m war ǧin ɛad.
\m U neccin narebbu řmuɛṣiyyet nsen.
\m 
\v 8 Imsexxaren ddebbaran xaneɣ,
\m uřa d ijj war d aneɣ issenfekki
\m zeg ifassen nsen.
\m 
\v 9 Neccin nsebbeř tudart nneɣ
\m maḥend ad dd-nawi aɣrum nneɣ,
\m zi ssibbet n ssif di řexřa.
\m 
\v 10 Tiřmect nneɣ tᵉtteḥduduq am tefqunt,
\m zi řḥaduq n tmessi n řaẓ.
\m 
\v 11 Ssxargen timɣarin di Ṣihyun,
\m uřa d tiɛzariyyin di tneddam n Yahuda.
\m 
\v 12 Řḥukkam yuyřen ten s ifassen n yixef nsen,
\m iwessura war ten weqqaren \add ɛad\add*.
\m 
\v 13 Iryazen ijehden qaɛ arebbun \add iẓra n\add* tsirt,
\m u iḥudriyyen ttneqraḍen
\m sadu \add řeḥmeř n\add* ukeccuḍ.
\m 
\v 14 Imɣaren ssbedden aɣimi di tewwura n tendint,
\m iḥudriyyen \add ssbedden\add* zeg uzenzun nsen \add x ifiřan\add*.
\m 
\v 15 Tweddar řefraḥet n wuř nneɣ,
\m ccḍiḥ nneɣ s nnubtat idweř d acḍan.
\m 
\v 16 Iwḍa aneɣ tajj x uzeǧif nneɣ.
\m Uct xaneɣ, maɣar neccin nexḍa.
\m 
\v 17 S uyenni ihřec wuř nneɣ aṭṭas,
\m s uyenni bbarecnent tiṭṭawin nneɣ,
\m 
\v 18 zi ssibbet n wedrar n Ṣihyun
\m nni ittwaxarrben,
\m mani ttawyen ttarran iceɛbawen.
\m 
\v 19 Cek, \add a\add* SIDI, ad teqqimed i řebda,
\m řkursi igellden nnec aqa-t zi jjiř ař jjiř.
\m 
\v 20 Mayemmi texsed Cek ad aneɣ tᵉttud i řebda?
\m Mayemmi i dayneɣ tsemḥed qaɛ anect uya n wussan?
\m 
\v 21 \add A\add* SIDI, arr aneɣ-dd ɣarek,
\m \add xenni\add* ad ɣarek dd-nedweř.
\m Arr aneɣ-dd ussan nneɣ d jdid am zic.
\m 
\v 22 Maɣar ma s tidett tenḍared aneɣ kuřci?
\m Ma teffugmed xaneɣ ammu qaɛ? 
