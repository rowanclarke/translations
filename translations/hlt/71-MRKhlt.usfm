\v 15 \wj \+w He|strong="G3778"\+w* tah \+w longpuei|strong="G3598"\+w* \+w kaep|strong="G3844"\+w* \+w kah|strong="G3588"\+w* a \+w soem|strong="G4687"\+w* \+w ol|strong="G3056"\+w* \+w te|strong="G3699"\+w* \+w ni|strong="G1526"\+w*. A \+w yaak|strong="G0191"\+w* \+w vaengah|strong="G3752"\+w* \+w Satan|strong="G4567"\+w* \+w tlek|strong="G2117"\+w* \+w cet|strong="G2064"\+w* \+w tih|strong="G2532"\+w* \+w amih|strong="G0848"\+w* \+w khuiah|strong="G1519"\+w* a \+w soem|strong="G4687"\+w* \+w ol|strong="G3056"\+w* a \+w loh|strong="G0142"\+w* pah\wj*.  
\v 16 \wj Te \+w phoeiah|strong="G2532"\+w* \+w he|strong="G3778"\+w* rhoek tah \+w lungrhong|strong="G4075"\+w* \+w sokah|strong="G1909"\+w* a \+w haeh|strong="G4687"\+w* \+w rhoek|strong="G3588"\+w* \+w ni|strong="G1526"\+w*. \+w Te|strong="G3739"\+w* rhoek loh \+w ol|strong="G3056"\+w* \+w te|strong="G3588"\+w* a \+w yaak|strong="G0191"\+w* uh \+w vaengah|strong="G3752"\+w* \+w omngaihnah|strong="G5479"\+w* \+w neh|strong="G3326"\+w* \+w tlek|strong="G2117"\+w* a \+w doe|strong="G2983"\+w*\wj*.  
\v 17 \wj \+w Tedae|strong="G2532"\+w* \+w a|strong="G1438"\+w* \+w khuiah|strong="G1722"\+w* a \+w yung|strong="G4491"\+w* \+w om|strong="G2192"\+w* uh \+w pawt|strong="G3756"\+w* tih \+w kolkalh|strong="G4340"\+w* \+w bueng|strong="G0235"\+w* \+w om|strong="G1526"\+w* uh. Te \+w phoeiah|strong="G1534"\+w* \+w olka|strong="G3056"\+w* \+w kongah|strong="G1223"\+w* \+w phacipphabaem|strong="G2347"\+w* \+w neh|strong="G2228"\+w* \+w hnaemtaeknah|strong="G1375"\+w* a \+w om|strong="G1096"\+w* atah \+w voeng|strong="G2117"\+w* a \+w khah|strong="G4624"\+w* uh\wj*.  
\v 18 \wj A \+w tloe|strong="G0243"\+w* rhoek \+w hling|strong="G0173"\+w* \+w lakli|strong="G1519"\+w* ah a \+w tuh|strong="G4687"\+w* \+w khaw|strong="G2532"\+w* \+w om|strong="G1526"\+w*. \+w Te|strong="G3778"\+w* rhoek khaw \+w ol|strong="G3056"\+w* aka \+w ya|strong="G0191"\+w* \+w rhoek|strong="G3588"\+w* \+w ni|strong="G1526"\+w*\wj*.  
