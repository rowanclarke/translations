\id 1TH  
\h 1 Tesalonicenses 
\toc1 Xo̱jo̱n carta‑la̱ San Pablo xi kiskiì ítjòn‑la̱ xi̱ta̱ na̱xa̱ndá‑la̱ Cristo xi títsa̱jna Tesalónica 
\toc2 1 Tesalonicenses 
\toc3 1 Ts. 
\mt1 Xo̱jo̱n carta‑la̱ San Pablo xi kiskiì ítjòn‑la̱ xi̱ta̱ na̱xa̱ndá‑la̱ Cristo xi títsa̱jna Tesalónica 
\c 1  
\s1 Kó tsò Pablo nga síhixat'aà jñà xi̱ta̱ na̱xa̱ndá‑la̱ Cristo xi títsa̱jna Tesalónica 
\p  
\v 1 Jñò xi xi̱ta̱ na̱xa̱ndá‑la̱ Nainá maà xi titsa̱jnaà ya̱ na̱xa̱ndá Tesalónica nga ya̱ titsa̱jnakjoòko̱o Nainá xi Na̱'èn‑ná ko̱ jè Jesucristo xi otíxoma‑ná, 'a̱n xi 'mì‑na Pablo titsa̱nìhixot'aà‑nòje̱n ko̱ Silvano [ti̱jé‑ne xi 'mì Silas] ko̱ Timoteo. Nainá kàtatsjá‑nò kjo̱ndaà ko̱ kjoa̱'nchán ya̱ i̱jiìn ini̱ma̱‑nò. 
\s1 Kó tsò Pablo nga tsjá‑la̱ kjo̱ndaà Nainá 
\p  
\v 2 K'e̱ nga nokjoàt'aà‑la̱je̱n Nainá, kjit'aà na̱chrjein 'biì‑la̱je̱n kjo̱ndaà i̱t'aà tsa̱jòn.  
\v 3 Bítsjeèn‑naje̱n nga nguixko̱n Nainá xi Na̱'èn‑ná koni s'ín nga titsa̱nìxá, koií kjoa̱‑la̱ nga mokjeiín‑nò i̱t'aà ts'e̱ Cristo, ti̱koa̱ ndaà nìxá‑là xi̱ta̱ xi kj'ei̱í nga matsjacha, nga ti̱koa̱ kixi̱ titsa̱jnaà nga titsa̱chiñà‑là Jesucristo xi otíxoma‑ná.  
\v 4 Ndí 'ndsè, Nainá matsjakeè‑nò. 'Ya‑náje̱n nga xó k'oa̱s'ín jaàjiìn‑nò nga xi̱ta̱ na̱xa̱ndá‑la̱ ko̱maà.  
\v 5 Nga jè 'én ndaà‑la̱ Nainá xi kjoa̱ ts'e̱ Cristo xi tsibèno̱jmí‑nòje̱n, mìtsà ta 'én tsa̱je̱n xi kinokjoáko̱‑nòje̱n. Jè Ini̱ma̱ Tsjeè‑la̱ Nainá kitsjaà‑naje̱n nga'ñó, ko̱ ti̱koa̱ 'ñó ndaà kjòchi̱ya‑naje̱n nga nguì kixi̱ kjoa̱. Jñò, ndaà ki'yaà k'e̱ nga ya̱ tsakítsa̱jna‑je̱n, ndaà kinìchját'aà‑nòje̱n xi kjo̱ndaà tsa̱jòn. 
\p  
\v 6 Jñò, k'oa̱á s'ín ki'nè koni s'ín ki'nè‑je̱n ko̱ koni s'ín s'ín Cristo. Jè Ini̱ma̱ Tsjeè‑la̱ Nainá kitsjaà‑nò kjo̱tsja nga komà kichjoétjò 'én‑la̱ Nainá na̱s'ín 'ñó tse kjo̱'in tsatojioòn.  
\v 7 K'oa̱á ma‑ne jñò tsakoò jngoò‑là kjoa̱ xi ndaà tjín nga kiskinguì ngats'iì xi̱ta̱ xi jye kòkjeiín‑la̱ 'én‑la̱ Nainá ya̱ nangui Macedonia ko̱ Acaya.  
\v 8 Nga ya̱á kjòts'ia̱‑ne i̱t'aà tsa̱jòn nga tsabísòn jè 'én ndaà‑la̱ Na̱'èn‑ná; mìtsà tà ya̱ nangui Macedonia ko̱ Acaya; xki̱ xi ján kina'yà‑la̱ nga jñò, ndaà mokjeiín‑nò i̱t'aà ts'e̱ Nainá. K'oa̱á ma‑ne nga mì ti̱ kiì mochjeén‑ne nga ngaje̱n kéno̱jmí‑la̱je̱n xi̱ta̱ i̱t'aà tsa̱jòn, nga jyeé beè‑nò xi̱ta̱.  
\v 9 Nga̱ ti̱jñà béno̱jmí‑ne nga ndaà kichjoétjò‑náje̱n k'e̱ nga ijchochoòn‑nòje̱n. Ti̱koa̱á tsò‑né nga jñò jyeé kinìkíjna kjoa̱ ts'e̱ xkósòn. I̱'ndei̱ jyeé ya̱ tjaàt'aà‑là xi nguì jè sobà Nainá xi kixi̱ kjoa̱ nga tíjnakon.  
\v 10 Ti̱koa̱á béno̱jmí‑né nga titsa̱chiñà‑là Ki'ndí‑la̱ Nainá nga ki̱tjojen ìjngoò k'a‑ne ngajmiì, jè xi ti̱jè‑ne Jesús xi Nainá kisìkjaáya‑la̱ k'e̱ nga k'en, nga jè‑né xi ko̱chrjekàjiìn‑ná kjo̱'in ts'e̱ kjoa̱jti‑la̱ Nainá xi sa̱ nchrobá. 
\c 2  
\s1 Xá xi kis'iìn Pablo ya̱ na̱xa̱ndá Tesalónica 
\p  
\v 1 Jñò ndí 'ndsè ko̱ ndí tichjaá, 'ya‑nò k'e̱ nga ijchochón‑nòje̱n mìtsà ta kjo̱tjò.  
\v 2 Nga jyeé ndaà tíjiìn‑nò koni s'ín komàt'in‑je̱n ján na̱xa̱ndá Filipos, nga 'ñó tse kjo̱'in kinìkjeiín‑je̱n; 'ñó kijtseètoòn‑naje̱n xi̱ta̱; ta̱nga Nainá kisìchját'aà‑naje̱n nga kitsjaà‑naje̱n nga'ñó nga komà tsanguì‑je̱n ya̱ na̱xa̱ndá‑nò nga komà tsibèno̱jmí‑nòje̱n 'én ndaà‑la̱ Nainá na̱s'ín 'ñó kjìn ma kondra̱‑naje̱n.  
\v 3 Nga 'én kixi̱í kinokjoàya‑je̱n, mìtsà jò tjín ini̱ma̱‑na̱je̱n nga tsibèno̱jmí‑nòje̱n, ti̱koa̱ mìtsà xi̱ta̱ kichona̱cha̱n‑la̱je̱n.  
\v 4 Nga̱ Nainá jyeé kiskoòt'aà‑naje̱n ko̱ k'oa̱á kitsò nga ok'ín‑naje̱n nga ngaje̱n kjònga̱tsja‑je̱n 'én ndaà‑la̱ Nainá xi kjoa̱ ts'e̱ Cristo mé‑ne nga ko̱ma ki̱nókjoa̱ya‑je̱n. Mìtsà jè xi mejèn‑naje̱n nga ndaà ki̱tsa̱jna‑je̱n nguixko̱n xi̱ta̱; jè‑né nga ndaà ki̱tsa̱jna‑je̱n nguixko̱n Nainá nga jè xi tíbeè ini̱ma̱‑ná.  
\v 5 Jyeé ndaà tíjiìn‑nò nga mìtsà 'én tsjén nokjoà‑je̱n koni tsà mé xi mejèn‑naje̱n nga k'oi̱‑náje̱n, ti̱koa̱á mìtsà to̱n binchaàtsji'ma‑je̱n. Kjoa̱ koi, Nainá tíbeè‑né.  
\v 6 Mìtsà jè binchaàtsji‑je̱n nga jñò, ko̱ xi̱ta̱ xi kj'ei̱í, nga 'nga si̱ìkítsa̱jna‑náje̱n. Tsà ji̱n xi mejèn‑naje̱n nga tsibìnè‑nòje̱n kjo̱tíxoma xi tjín‑naje̱n nga i̱t'aà ts'e̱ Cristo kisìxáya‑naje̱n, komaá‑la o̱kinìko̱‑nòje̱n.  
\v 7 Ta̱nga mìtsà ko̱s'ín kinìko̱‑nòje̱n. Ta sa̱á k'oa̱s'ín kinìko̱‑nòje̱n koni ndí i̱xti. K'oa̱á ngaya‑la̱ koni jngoò nea̱ xi síkaki i̱xti‑la̱ nga ndaà síjchá i̱xti‑la̱.  
\v 8 'Ñó tjòcha ki'ya‑nòje̱n. K'oa̱á ma‑ne nga ko̱ kjo̱tsja‑naje̱n tsibèno̱jmí‑nòje̱n 'én ndaà‑la̱ Nainá xi kjoa̱ ts'e̱ Cristo. Ti̱koa̱á matsjaá‑naje̱n nga ndaà kinìko̱‑nòje̱n ni̱ta̱ mé kjoa̱ xi komàt'ioòn ta koií kjoa̱‑la̱ nga 'ñó matsjacha‑nòje̱n.  
\v 9 Ndí 'ndsè ko̱ ndí tichjaá, bítsjeèn‑nò kós'ín kinìxá‑je̱n nga binchaàtsji'a‑je̱n yijo‑naje̱n. Ko̱ na̱chrjein ko̱ ni̱tje̱n nìxá‑je̱n, mé‑ne nga mì jñò si̱jti‑nòje̱n jñà na̱chrjein k'e̱ nga kinokjoàyajiìn‑nòje̱n 'én ndaà‑la̱ Nainá. 
\p  
\v 10 Jñò, ndaà ki'yaà, ti̱koa̱á Nainá kijtseè‑né, nga ngaje̱n ndaà kinìko̱‑nòje̱n. K'oa̱á s'ín kinìko̱‑nòje̱n koni s'ín sasén‑la̱ Nainá koni s'ín tjín xi kjoa̱ kixi̱. Ko̱ ni̱yá xi jé ko̱ònè‑naje̱n koni s'ín kinìko̱‑nòje̱n jñò xi mokjeiín‑nò 'én ndaà‑la̱ Nainá.  
\v 11 Ti̱koa̱á jyeé ndaà tíjiìn‑nò nga je̱n, ndaà kinìko̱‑nòje̱n nga jngoò ìjngoò koni s'ín síko̱ i̱xti‑la̱ jngoò xi̱ta̱ xi na̱'èn ma.  
\v 12 Kinìje ikon‑nòje̱n koa̱ kinì'ñójiìn‑je̱n takòn ko̱ k'oa̱s'ín tsibìnè‑nòje̱n nga k'oa̱s'ín s'e̱en koni s'ín ok'ìn‑la̱ xi xi̱ta̱‑la̱ Nainá maà; nga jè‑né xi síkí'nchré‑nò nga ya̱ titsa̱jnajiìn‑là xi̱ta̱ xi jye jè tíhotíxoma‑la̱ ko̱ ti̱koa̱ ya̱ titsa̱jnajñoò kjoa̱jeya‑la̱. 
\p  
\v 13 Kjit'aà na̱chrjein 'biì‑la̱je̱n kjo̱ndaà Nainá koni s'ín ndaà kichjoétjò 'én‑la̱ nga mìtsà k'oa̱s'ín kichjoétjò koni 'én‑la̱ xi ta̱xki̱ xi̱ta̱. K'oa̱á s'ín kichjoétjò koni tjín xi nguì kjoa̱ kixi̱ nga 'én‑la̱ Nainá‑né. Jñà 'én koi, tí'yaá‑la̱ nga nchisíxájiìn ini̱ma̱‑nò jñò xi mokjeiín‑nò.  
\v 14 Jñò ndí 'ndsè ko̱ ndí tichjaá, k'oa̱á s'ín komàt'ioòn koni s'ín komàt'in jñà xi̱ta̱ na̱xa̱ndá‑la̱ Nainá xi mokjeiín‑la̱ i̱t'aà ts'e̱ Cristo Jesús xi títsa̱jna ján nangui Judea. Ti̱jñà‑ne xi̱ta̱ na̱xa̱ndá judío xíkjín kiìtji̱ngui kondra̱‑la̱. Jñò ti̱jñà‑ne xi̱ta̱ na̱xa̱ndá tsa̱jòn kiìtji̱ngui kondra̱‑nò.  
\v 15 Jñà xi̱ta̱ judío kisìk'en Na̱'èn‑ná Jesús ko̱ ti̱jñà‑ne xi̱ta̱ jchínga‑la̱ kisìk'en jñà xi̱ta̱ xi kiìchja̱ya̱ nga̱jo̱‑la̱ Nainá kjòtseé. I̱'ndei̱, tákó k'oa̱á síko̱‑naje̱n nga fìtji̱ngui kondra̱‑naje̱n. Nainá mìkiì sasén‑la̱ kjoa̱ xi s'ín xi̱ta̱ koi, nguì kondra̱á fì‑la̱ ngats'iì kjoa̱,  
\v 16 nga mìkiì tsjá'nde nga nokjoà‑la̱je̱n jñà xi mìtsà xi̱ta̱ judío mé‑ne nga ti̱koa̱ ki̱tjokàjiìn‑ne kjo̱'in. K'oa̱á ma‑ne xi̱ta̱ koi, skanda nchisíkatonè‑la̱ nga ótsji jé‑la̱ yijo‑la̱. Jyeé kjo̱meè f'iìkanè‑la̱ kjo̱'in xi tji̱ko̱ kjo̱jti‑la̱ Nainá. 
\s1 Kó kitsò Pablo nga mejèn‑la̱ kji̱kon jñà xi̱ta̱‑la̱ Cristo xi títsa̱jna ya̱ na̱xa̱ndá Tesalónica 
\p  
\v 17 'Ndseé ko̱ tichjaá, k'e̱ nga chinchat'aàxìn chiba na̱chrjein‑nòje̱n, na̱s'ín mì ti̱ kiì kiyaxkon‑ná xinguia̱á, ngaje̱n 'ñó nìkítsjeèn‑nòje̱n. 'Ñó mejèn‑naje̱n nga onguíchoòn‑nòje̱n.  
\v 18 Mejèn tsanguì‑je̱n. 'A̱n xi 'mì‑na̱ Pablo, kjìn k'a mejèn kiaà, ta̱nga jè xi̱ta̱ nei̱í mìkiì kitsjaà'nde‑naje̱n.  
\v 19 Kjoa̱ tsa̱jòn‑nò nga titsa̱chiñá‑la̱je̱n nga 'ñó ko̱tsja‑naje̱n ko̱ nga ndaà ki̱tjo‑je̱n k'e̱ nga kjoi̱í ìjngoò k'a Na̱'èn‑ná Jesucristo.  
\v 20 Kixi̱í kjoa̱ i̱t'aà tsa̱jòn‑nò nga ndaà ki̱tjongui‑je̱n ko̱ nga s'e̱‑naje̱n kjoa̱ tsja. 
\c 3  
\s1 Mé‑ne ya̱ kinìkasén‑ne Timoteo ján na̱xa̱ndá Tesalónica 
\p  
\v 1 K'e̱ nga mì ti̱ kiì komà kichìkjoa̱ ìsa̱‑naje̱n nga mejèn‑naje̱n si̱jiìn‑naje̱n kó s'ín titsa̱jnaà ján Tesalónica, k'oa̱á komà‑ne nga kichibàya‑naje̱n nga kinìkasén‑je̱n jè 'ndsè Timoteo, ko̱ ngaje̱n ya̱á tsitsa̱jna‑je̱n Atenas.  
\v 2 Kinìkasén‑je̱n jè 'ndseé Timoteo, chi̱'nda‑la̱ Nainá‑né nga ti̱koa̱á chja̱ya 'én ndaà‑la̱ Nainá xi kjoa̱ ts'e̱ Cristo koni ngaje̱n. Koií xá kiìkon‑nò mé‑ne nga kàtatsjá‑ìsa‑nò nga'ñó nga ìsa̱ 'ñó ndaà kixi̱ ki̱tsa̱jnaà koni s'ín mokjeiín‑nò,  
\v 3 mé‑ne nga ni̱jngoò xi si̱hindaà‑ne kjoa̱ ts'e̱ kjo̱'in xi titsa̱nìkjioón. Jñò, jyeé ndaà tíjiìn‑nò nga k'oa̱á s'ín tjínè‑la̱ nga ko̱s'ín ko̱mat'iaán.  
\v 4 K'e̱ nga ti̱sa̱ ya̱ titsa̱jnako̱‑nòje̱n, k'oa̱á ki'mì‑nòje̱n nga kjo̱'iín s'e̱‑ná. I̱'ndei̱, jyeé titsa̱'yaà nga k'oa̱á s'ín tímat'ioòn.  
\v 5 Koií kjoa̱‑la̱ nga mì ti̱ kiì kiskoòñà kjoa̱‑na; kisìkasén Timoteo nga mejèn‑na skoeè kós'ín titsa̱jnako̱o jè 'én xi mokjeiín‑nò. Tìmakájno‑na tsà jye kiskoòna̱cha̱n‑nò jè xi̱ta̱ nei̱í. Tsà koií na̱chrjein‑la, xá xi ki'nè‑je̱n, tsà ta kichijà‑né. 
\p  
\v 6 I̱'ndei̱, jè Timoteo jyeé j'iì‑ne nga kiì Tesalónica; ndaà tsò o̱kixi̱ xi 'ya‑naje̱n i̱t'aà tsa̱jòn koni s'ín mokjeiín‑nò ko̱ nga tjín‑nò kjo̱tsjacha. K'oa̱á s'ín tsibéno̱jmí‑naje̱n nga kjit'aà na̱chrjein tsjaá ma‑nò nga nìkítsjeèn‑náje̱n. Ti̱koa̱á mejèn‑nò nga jcha̱xkoòn‑náje̱n koni ngaje̱n ti̱koa̱á mejèn‑naje̱n jcha̱xkoòn‑nòje̱n.  
\v 7 K'oa̱á ma‑ne ndí 'ndsè ko̱ ndí tichjaá, na̱s'ín kjo̱'in ko̱ kjoa̱ kondra̱ titsa̱jnajiìn‑je̱n, k'e̱ nga kina'yà‑je̱n i̱t'aà tsa̱jòn nga 'ñó ndaà mokjeiín‑nò i̱t'aà ts'e̱ Cristo, ti̱koa̱á ngaje̱n, 'ñó ndaà kjòtsja‑naje̱n.  
\v 8 K'e̱ nga kina'yà‑je̱n nga kixi̱ onguít'aà‑là Na̱'èn‑ná, ngaje̱n jyeé mì ti̱ mé makájno‑naje̱n.  
\v 9 Ngaje̱n, 'ñó tse kjo̱tsja tjín‑naje̱n nga nguixko̱n Nainá xi kjoa̱ tsa̱jòn skanda mì‑la kiì kjoe̱het'aà na̱chrjein nga k'oi̱‑la̱je̱n kjo̱ndaà Nainá.  
\v 10 Ko̱ na̱chrjein ko̱ ni̱tje̱n nokjoàt'aà‑la̱je̱n Nainá mé‑ne nga tsjá'nde‑ne nga ko̱ma ko̱nguíchoòn‑nòje̱n. Ti̱koa̱ ko̱ma ko̱kòya‑ìsa‑nòje̱n mé‑ne nga ko̱jngoò‑ne 'én xi chijat'aà‑nò koni s'ín mokjeiín‑nò. 
\s1 Kjoa̱ bítsi'ba‑la̱ Pablo 
\p  
\v 11 Mejèn‑naje̱n nga ti̱jè‑ne Na̱'èn‑ná xi Nainá ko̱ jè Jesucristo xi otíxoma‑ná, kàtatsjá'nde‑naje̱n nga ko̱ma ko̱nguíchoòn‑nòje̱n.  
\v 12 Jè kjo̱tsjacha‑la̱ Na̱'én‑ná ìsa̱ ndaà kàtasijiìn ini̱ma̱‑nò, mé‑ne nga ìsa̱ ndaà ko̱tsjacha‑nò xinguio̱o ko̱ ngats'iì xi̱ta̱ xi kj'ei̱í, koni ngaje̱n, ndaà matsjacha‑nòje̱n.  
\v 13 Jè Na̱'èn‑ná kàtatsjá‑la̱ nga'ñó ini̱ma̱‑nò mé‑ne nga ni̱mé jé sa̱kòt'aà‑nò ko̱ tsjeè ki̱tsa̱jnaà nga nguixko̱n Nainá xi Na̱'èn‑ná k'e̱ nga kjoi̱í ìjngoò k'a‑ne Jesucristo xi otíxoma‑ná nga tji̱ko̱ ngats'iì xi ya̱ chja̱‑ne. 
\c 4  
\s1 Kjoa̱ xi sasén‑la̱ Nainá 
\p  
\v 1 Ndí 'ndsè ko̱ ndí tichjaá, k'oa̱á s'ín tsakoòya‑nòje̱n nga k'oa̱s'ín si̱jchá yijo‑nò koni s'ín sasén‑la̱ Nainá. Ko̱ kixi̱í kjoa̱, jyeé ko̱s'ín titsa̱'nè. Ta̱nga i̱'ndei̱ bítsi'ba‑nòje̱n ti̱koa̱ bìnè‑nòje̱n i̱t'aà ts'e̱ Jesús xi otíxoma‑ná nga ìsa̱ 'ñó ndaà tjiì‑là nga'ñó yijo‑nò nga ko̱s'ín ti̱kitasòn. 
\p  
\v 2 Jyeé tíjiìn‑nò kó s'ín tjín kjo̱tíxoma xi kits'iì‑nòje̱n koni s'ín kitsjaà‑naje̱n Jesucristo xi otíxoma‑ná.  
\v 3 Jè xi mejèn‑la̱ Nainá nga nguì tsjeè si̱jchá yijo‑nò, mì ti̱ kjoa̱ chijngui si̱s'in‑là.  
\v 4 Nga jngoò ìjngoò‑nò ti̱kinda̱a yijo‑nò; k'oa̱s'ín ti̱kjeén nga nguì tsjeè ti̱tsa̱jna koni s'ín sasén‑la̱ Nainá.  
\v 5 Kì biì'nde‑là nga síkijne‑nò jñà kjoa̱ ch'o xi síjé yijo‑nò koni s'ín jñà xi̱ta̱ xi mìkiì beèxkon Nainá.  
\v 6 Jñò xi 'ndseé chibá i̱t'aà ts'e̱ Cristo, kì k'oa̱á tjín kjoa̱ xi kaàjñoò mé‑ne nga mì xinguio̱o chóna̱cha̱n‑là nga mì xinguio̱o jcha̱toòn. Tsà k'oa̱s'ín s'e̱en, kjo̱'iín tsjá‑nò Nainá. Jyeé k'oa̱s'ín tsibèno̱jmí‑nòje̱n.  
\v 7 Nainá mìtsà koi xá kiìchja̱‑ná nga ch'o s'e̱én, jè xi mejèn‑la̱ nga tsjeè ki̱tsa̱jnaá.  
\v 8 Jè xi ochrjekàngui kjoa̱ koi, mìtsà kjo̱hítsjeèn ts'e̱ xi̱ta̱ ochrjekàngui, kjo̱hítsjeèn ts'e̱ Nainá ochrjekàngui; nga jè xi tsjá‑nò Ini̱ma̱ Tsjeè‑la̱. 
\p  
\v 9 Mìkiì mochjeén nga xo̱jo̱n skiìt'aà‑ìsa‑nò xi ts'e̱ kjoa̱tjòcha. Nainá jye tsakóya‑nò kós'ín si̱tjòchaà xinguio̱o nga jngoò ìjngoò.  
\v 10 Jyeé ko̱s'ín titsa̱'nè nga matsjacha ngats'iì xi̱ta̱ xinguio̱o xi títsa̱jna kóho̱kji ya̱ nangui Macedonia. Ta̱nga k'oa̱á s'ín bìtsi'ba‑nòje̱n nga ìsa̱ ndaà ti̱tsjacha xinguio̱o.  
\v 11 Tìnè‑là yijo‑nò nga 'nchán ti̱tsa̱jna, kì kjoa̱‑la̱ xinguio̱o chingàjñoò, t'e̱en xá‑nò koni tjín xá xi ma‑nò, koni s'ín jye ki'mì‑nòje̱n ngats'iì kjoa̱ koi.  
\v 12 Mé‑ne nga skoe̱xkón‑nò jñà xi̱ta̱ xi mìkiì mokjeiín‑la̱ 'én‑la̱ Nainá. Koa̱ jñò, ni̱mé chijat'aà‑nò. 
\s1 K'e̱ nga kjoi̱í ìjngoò k'a‑ne Na̱'èn‑ná Jesucristo 
\p  
\v 13 Ndí 'ndsè ko̱ ndí tichjaá, mejèn‑naje̱n nga kàtasijiìn‑nò mé kjoa̱ xi mat'in jngoò xi̱ta̱ xi biyaà, mé‑ne nga mì ko̱baá‑nò koni jñà xi̱ta̱ xi ni̱mé nchikoña‑la̱.  
\v 14 Koni s'ín mokjeiín‑ná nga Jesús k'en, i̱kjoàn jaáya‑la̱, k'oa̱ ti̱s'ín mokjeiín‑ná nga Nainá si̱ìkjaáya‑la̱ xi̱ta̱ xi jye k'en, jñà xi mokjeiín‑la̱ i̱t'aà ts'e̱ Jesús. 
\p  
\v 15 Nga̱ koií 'én bèno̱jmíya‑je̱n koni tsò 'én xi tsibíjna Jesús nga jñá xi titsa̱jnakoaán skanda k'e̱ nga kjoi̱í ìjngoò k'a Na̱'èn‑ná Jesucristo, mìtsà jñá kjiín ítjòn‑lá jñà xi jye k'en.  
\v 16 Nga̱ jè sobà Na̱'èn‑ná ki̱tjojen ìjngoò k'a‑ne ngajmiì; 'ñó ki̱chja̱ nga tsjá o̱kixi̱, ki̱ná'ya jngoò‑la̱ jta̱ ts'e̱ àkja̱le̱ ítjòn, ko̱ ki̱ná'ya‑la̱ chrjo‑la̱ Nainá; i̱kjoàn jñà xi̱ta̱ xi jye k'en nga mokjeiín‑la̱ i̱t'aà ts'e̱ Cristo, kjoa̱áya ítjòn‑la̱.  
\v 17 I̱kjoàn jñá xi tákó titsa̱jnakoaán jè na̱chrjein jè, ya̱á tjámijìn‑tje̱n‑koa̱á i̱jiìn ifi nga kixokjoaá Nainá ya̱ i̱jiìn i̱sén. K'oa̱á s'ín ko̱ma nga ya̱ ki̱tsa̱jnakoa̱á Nainá ni̱ta̱ mé na̱chrjein‑ne.  
\v 18 K'oa̱á ma‑ne nga ti̱je takòn xinguio̱o nga tèno̱jmíya‑là koni tsò jñà 'én koi. 
\c 5  
\p  
\v 1 Ndí 'ndsè ko̱ ndí tichjaá, mìkiì mochjeén nga xo̱jo̱n si̱t'aà‑nò mé na̱chrjein‑ne nga o̱ko̱ma.  
\v 2 Jñò, nga̱ jyeé ndaà tíjiìn‑nò, jè na̱chrjein k'e̱ nga kjoi̱í ìjngoò k'a Na̱'èn‑ná Jesucristo, k'oa̱á s'ín kjoi̱í koni jngoò xi̱ta̱ chijé xi f'iì nga ni̱tje̱n k'e̱ nga ni̱yá xi nchikoñaá‑la̱.  
\v 3 K'e̱ nga ki̱tso̱ jñà xi̱ta̱: “'Nchán titsa̱jnaá, ni̱mé kjoa̱ tjín.” K'e̱é tà ni̱to̱ón ki̱tjojenè‑la̱ kjo̱xkón koni s'ín mat'in jngoò chjo̱ón xi bijchó na̱chrjein‑la̱ nga ki'ndí 'beé, mìkiì ko̱jno‑la̱.  
\v 4 Ta̱nga jñò ndí 'ndsè ko̱ ndí tichjaá, mìtsà i̱jiìn jñò titsa̱jnaà jñò. Ko̱ k'oa̱á ma‑ne nga mì k'oa̱á s'ín ko̱mat'ioòn jè na̱chrjein jè, koni ma k'e̱ nga ta ni̱to̱ón fì jngoò xi̱ta̱ chijé.  
\v 5 Ta̱nga jñò, ngats'ioò, iseèn choòn ñánda titsa̱jnaà, ko̱ na̱chrjein‑né. Nga̱ jñá, mìtsà i̱jiìn jñò titsa̱jnaá ko̱ mìtsà ni̱tje̱n titsa̱jnaá.  
\v 6 K'oa̱á ma‑ne nga mìkiì k'oa̱ s'e̱én koni s'ín xi̱ta̱ xi kj'ei̱í nga mì titsa̱jnandaà‑jèn mé kjoa̱ xi tjín k'oa̱á ngaya‑la̱ koni tsà kjiyijòfè. Mochjeén‑né nga ki̱tsa̱jnandaá koni jngoò xi̱ta̱ xi tíjnakon, xi nguì ndaà tjín ikon.  
\v 7 Nga jñà xi̱ta̱ xi oyijòfè, k'e̱é oyijòfè k'e̱ nga jñò. Ko̱ jñà xi mach'i̱, k'e̱é mach'i̱ k'e̱ nga jñò.  
\v 8 Ta̱nga jñá, ya̱á titsa̱jnaá ñánda iseèn choòn. K'oa̱á ma‑ne nga ndaà si̱jchá yijo‑ná. Jè 'én xi mokjeiín‑ná ko̱ jè kjoa̱tjòcha, jñà ko̱si̱ko̱ ini̱ma̱‑ná koni jngoò soldado xi ndaà kijtsa ini̱ma̱‑la̱ jè chrjoa̱ xi 'mì coraza. Ko̱ k'e̱ nga nguì tíjngoò takoán nga chiñá‑lá jè na̱chrjein k'e̱ nga ki̱tjokàjñaá kjo̱'in, jè ngaya‑la̱ tsí'nguién ki̱cha̱ xi osìko̱ sko̱ soldado.  
\v 9 Nainá mìtsà koi xá jaàjiìn‑ná nga kjo̱'in tsjá‑ná, jé‑né nga ki̱tjokàjñaá kjo̱'in i̱t'aà ts'e̱ Jesucristo xi otíxoma‑ná.  
\v 10 Nga jè k'en ngajo‑ná mé‑ne k'e̱ nga kjoi̱í ìjngoò k'a‑ne, tsà titsa̱jnakoaán, ko̱ tsà jye k'eén, ya̱á ki̱tsa̱jnakoa̱á.  
\v 11 K'oa̱á ma‑ne nga ti̱jetakòn ko̱ tjiì‑la nga'ñó xinguio̱o koni s'ín jye titsa̱'nè. 
\s1 Kjo̱tíxoma xi kitsjaà Pablo 
\p  
\v 12 Ndí 'ndsè ko̱ ndí tichjaá, nìjé‑nòje̱n kjo̱ndaà, jcha̱xkón xi̱ta̱ xi síxáko̱‑nò nga jñà títsa̱jna ítjòn ya̱ i̱jiìn na̱xa̱ndá‑la̱ Nainá ko̱ nga okóya‑nò.  
\v 13 Ndaà jcha̱xkón ti̱koa̱ ndaà ti̱tsjacha xi̱ta̱ koi, jè kjoa̱‑la̱ xá xi s'ín. 'Nchán titsa̱jnako̱o xinguio̱o. 
\p  
\v 14 K'oa̱ ti̱s'ín bìtsi'ba‑nòje̱n ndí 'ndsè ko̱ ndí tichjaá, ko̱t'ìn‑là nga kàtasíxá jñà xi̱ta̱ xi ta jyò tjíma nga majìn‑la̱ síxá; ti̱'ñó ikon jñà xi indaà tjín ikon; ti̱chját'aà‑là jñà xi tsjìn‑la̱ nga'ñó ya̱ i̱jiìn ini̱ma̱‑la̱; ko̱ kàtas'e‑nò kjoa̱tsejta i̱t'aà ts'e̱ ngats'iì xi̱ta̱‑la̱ Nainá. 
\p  
\v 15 Tsà k'e̱ nga mé kjoa̱ xi ch'o síko̱‑nò xi̱ta̱ xi kj'ei̱í, ti̱kinda̱a xinguio̱o nga mì si̱ìjndà ngajo‑ne. Ta̱ sa̱á tìnè‑là yijo‑nò nga kjit'aà na̱chrjein ndaà ti̱ko̱o xinguio̱o ko̱ ngats'iì xi̱ta̱ xi kj'ei̱í. 
\p  
\v 16 Kjit'aà na̱chrjein tsja t'è‑là ini̱ma̱‑nò.  
\v 17 Titsi'ba kjit'aà‑là Nainá.  
\v 18 Ni̱ta̱ mé kjoa̱‑ne, tjiì kjit'aà‑là kjo̱ndaà Nainá. K'oa̱á s'ín mejèn‑la̱ Nainá nga k'oa̱s'ín s'e̱en ngats'ioò xi mokjeiín‑nò i̱t'aà ts'e̱ Cristo Jesús. 
\p  
\v 19 Kì bichjoá ikòn‑là xá xi s'ín Ini̱ma̱ Tsjeè‑la̱ Nainá.  
\v 20 Kì nachrjekànguioò 'én‑la̱ xi̱ta̱ xi chja̱ ngajo‑la̱ Nainá.  
\v 21 Ndaà ndaà chít'aà yije ngats'iì 'én. Jñà ti̱kítsa̱jnatjò xi ndaà tsò.  
\v 22 Ngats'iì xi ch'o tsò, kì kiì nìkitasòn. 
\p  
\v 23 Jè Nainá xi tsjá kjoa̱'nchán, jngoò k'a tsjeè kàtasíkítsa̱jna‑nò. Ndaà kàtasíkinda̱ ini̱ma̱‑nò, yijo‑nò ko̱ kjo̱hítsjeèn‑nò mé‑ne nga ni̱mé jé s'e̱‑nò jè na̱chrjein k'e̱ nga kjoi̱í ìjngoò k'a jè Jesucristo xi otíxoma‑ná.  
\v 24 Nga xi̱ta̱ kixi̱‑né jè Nainá xi xó kiìchja̱‑nò, si̱ìkitasòn yijeé kjoa̱ koi. 
\s1 Kó kitsò Pablo nga síhixat'aà xi̱ta̱ 
\p  
\v 25 'Ndseé ko̱ tichjaá, titsi'batjì‑náje̱n. 
\p  
\v 26 Ti̱ixot'aà ngats'iì xi̱ta̱ 'ndseé nga nguì ko̱ ini̱ma̱‑nò. 
\p  
\v 27 'A̱n, tsja‑nò o̱kixi̱ nga nguixko̱n Na̱'èn‑ná nga kàtaxke̱jiìn‑la̱ xo̱jo̱n jè ngats'iì xi̱ta̱ na̱xa̱ndá‑la̱ Nainá. 
\p  
\v 28 Jè kàtìjnako̱‑nò kjo̱ndaà‑la̱ Jesucristo xi otíxoma‑ná.