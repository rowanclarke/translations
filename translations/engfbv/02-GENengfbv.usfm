\p
\v 45 “\w I|strong="H2009"\w* hadn't \w even|strong="H5869"\w* \w finished|strong="H3615"\w* \w praying|strong="H1696"\w* silently \w when|strong="H3615"\w* \w I|strong="H2009"\w* \w saw|strong="H2009"\w* \w Rebekah|strong="H7259"\w* \w coming|strong="H3318"\w* \w to|strong="H1696"\w* \w get|strong="H3318"\w* \w water|strong="H8248"\w*, carrying \w her|strong="H5921"\w* \w water|strong="H8248"\w* \w jar|strong="H3537"\w* \w on|strong="H5921"\w* \w her|strong="H5921"\w* \w shoulder|strong="H7926"\w*. \w She|strong="H5921"\w* \w went|strong="H3318"\w* \w down|strong="H3381"\w* \w to|strong="H1696"\w* \w the|strong="H5921"\w* \w spring|strong="H3318"\w* \w to|strong="H1696"\w* \w get|strong="H3318"\w* \w water|strong="H8248"\w*, \w and|strong="H5869"\w* \w I|strong="H2009"\w* \w said|strong="H1696"\w* \w to|strong="H1696"\w* \w her|strong="H5921"\w*, ‘\w Please|strong="H4994"\w* \w give|strong="H8248"\w* \w me|strong="H4994"\w* \w a|strong="H3068"\w* \w drink|strong="H8248"\w*.’  
