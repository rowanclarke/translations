\v 1 \w La|strong="H1931"\w* \w mano|strong="H3027"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w vino|strong="H1961"\w* \w sobre|strong="H5921"\w* \w mí|strong="H5921"\w*. \nd \+w Yavé|strong="H3068"\+w*\nd* \w me|strong="H5921"\w* llevó \w en|strong="H5921"\w* \w su|strong="H1931"\w* \w Espíritu|strong="H7307"\w* \w y|strong="H5921"\w* \w me|strong="H5921"\w* puso \w en|strong="H5921"\w* \w medio|strong="H8432"\w* \w de|strong="H5921"\w* un valle \w que|strong="H1931"\w* \w estaba|strong="H1961"\w* \w lleno|strong="H4392"\w* \w de|strong="H5921"\w* \w huesos|strong="H6106"\w*.  
\v 2 \w Me|strong="H5921"\w* impulsó \w a|strong="H3068"\w* \w pasar|strong="H5674"\w* \w cerca|strong="H5921"\w* \w y|strong="H5921"\w* \w alrededor|strong="H5439"\w* \w de|strong="H5921"\w* \w ellos|strong="H5921"\w*. Vi \w que|strong="H5921"\w* había muchísimos \add huesos\add* \w en|strong="H5921"\w* \w la|strong="H5921"\w* superficie \w del|strong="H5921"\w* valle \w y|strong="H5921"\w* \w que|strong="H5921"\w* estaban \w muy|strong="H3966"\w* \w secos|strong="H3002"\w*.  
\v 3 Me preguntó: \wj \+w Hijo|strong="H1121"\+w* \+w de|strong="H1121"\+w* \+w hombre|strong="H1121"\+w*, ¿podrán \+w vivir|strong="H2421"\+w* estos \+w huesos|strong="H6106"\+w*?\wj*  
\p \w Y|strong="H3068"\w* respondí: ¡\w Oh|strong="H1121"\w* \nd ʼAdonay \+w Yavé|strong="H3068"\+w*\nd*, Tú \w sabes|strong="H3045"\w*!   
\p
\v 4 Entonces \w me|strong="H5921"\w* dijo: \wj \+w Profetiza|strong="H5012"\+w* \+w sobre|strong="H5921"\+w* estos \+w huesos|strong="H6106"\+w*: ¡\+w Huesos|strong="H6106"\+w* \+w secos|strong="H3002"\+w*, \+w oigan|strong="H8085"\+w* \+w la|strong="H5921"\+w* \+w Palabra|strong="H1697"\+w* \+w de|strong="H5921"\+w* \+nd \+w Yavé|strong="H3068"\+w*\+nd*! \wj*  
\v 5 \nd ʼAdonay \+w Yavé|strong="H3068"\+w*\nd* dice \w a|strong="H3068"\w* estos \w huesos|strong="H6106"\w*: \wj \+w Ciertamente|strong="H2009"\+w* \+w Yo|strong="H2009"\+w* causo \+w que|strong="H3541"\+w* entre \+w espíritu|strong="H7307"\+w* en ustedes, \+w y|strong="H3541"\+w* \+w vivirán|strong="H2421"\+w*.\wj*  
\v 6 \wj \+w Pondré|strong="H5414"\+w* tendones \+w sobre|strong="H5921"\+w* ustedes \+w y|strong="H3588"\+w* \+w carne|strong="H1320"\+w* \+w sobre|strong="H5921"\+w* \+w ellos|strong="H5921"\+w*. \+w Los|strong="H5921"\+w* \+w cubriré|strong="H7159"\+w* \+w con|strong="H5921"\+w* \+w piel|strong="H5785"\+w*, infundiré \+w en|strong="H5921"\+w* ustedes \+w espíritu|strong="H7307"\+w* \+w y|strong="H3588"\+w* \+w vivirán|strong="H2421"\+w*. \+w Y|strong="H3068"\+w* \+w sabrán|strong="H3045"\+w* \+w que|strong="H3588"\+w* \+w Yo|strong="H3588"\+w* soy \+nd \+w Yavé|strong="H3068"\+w*\+nd*.\wj*   
\p
\v 7 \w Profeticé|strong="H5012"\w*, \w pues|strong="H1961"\w*, \w como|strong="H1961"\w* me \w fue|strong="H1961"\w* \w mandado|strong="H6680"\w*. Mientras profetizaba \w hubo|strong="H1961"\w* un \w ruido|strong="H6963"\w*, vi un estremecimiento y \w los|strong="H1961"\w* \w huesos|strong="H6106"\w* \w se|strong="H1961"\w* unieron, \w hueso|strong="H6106"\w* con \w hueso|strong="H6106"\w*.  
\v 8 Mientras \w yo|strong="H2009"\w* \w miraba|strong="H7200"\w*, \w ciertamente|strong="H2009"\w* tendones \w y|strong="H5921"\w* \w carne|strong="H1320"\w* crecieron \w sobre|strong="H5921"\w* \w ellos|strong="H5921"\w*. \w La|strong="H5921"\w* \w piel|strong="H5785"\w* \w los|strong="H5921"\w* \w cubrió|strong="H7159"\w*, pero \w no|strong="H5921"\w* había \w espíritu|strong="H7307"\w* \w en|strong="H5921"\w* \w ellos|strong="H5921"\w*.   
\p
\v 9 Entonces \w me|strong="H3541"\w* dijo: \wj ¡\+w Profetiza|strong="H5012"\+w* al \+w espíritu|strong="H7307"\+w*! \+w Profetiza|strong="H5012"\+w*, \+w oh|strong="H1121"\+w* \+w hijo|strong="H1121"\+w* \+w de|strong="H1121"\+w* \+w hombre|strong="H1121"\+w*, \+w y|strong="H3541"\+w* dí al \+w espíritu|strong="H7307"\+w*: \+nd ʼAdonay \+w Yavé|strong="H3068"\+w*\+nd* dice: ¡Ven \+w de|strong="H1121"\+w* \+w los|strong="H1121"\+w* cuatro puntos cardinales, \+w oh|strong="H1121"\+w* \+w espíritu|strong="H7307"\+w*, \+w y|strong="H3541"\+w* sopla sobre estos asesinados para \+w que|strong="H1121"\+w* vivan!\wj*   
\p
\v 10 \w Profeticé|strong="H5012"\w* \w como|strong="H5921"\w* \w me|strong="H5921"\w* fue \w mandado|strong="H6680"\w*. \w Y|strong="H3068"\w* \w el|strong="H5921"\w* \w espíritu|strong="H7307"\w* entró \w en|strong="H5921"\w* \w ellos|strong="H5921"\w* \w y|strong="H5921"\w* vivieron. Un \w ejército|strong="H2428"\w* \w muy|strong="H3966"\w* \w grande|strong="H1419"\w* \w se|strong="H5921"\w* \w puso|strong="H5975"\w* \w en|strong="H5921"\w* \w pie|strong="H7272"\w*.   
\p
\v 11 Entonces me dijo: \wj \+w Hijo|strong="H1121"\+w* \+w de|strong="H1121"\+w* \+w hombre|strong="H1121"\+w*, \+w todos|strong="H3605"\+w* \+w estos|strong="H1992"\+w* \+w huesos|strong="H6106"\+w* son \+w la|strong="H3605"\+w* \+w Casa|strong="H1004"\+w* \+w de|strong="H1121"\+w* \+w Israel|strong="H3478"\+w*. \+w Mira|strong="H2009"\+w*, \+w ellos|strong="H1992"\+w* dicen: Nuestros \+w huesos|strong="H6106"\+w* \+w están|strong="H2009"\+w* secos. Nuestra \+w esperanza|strong="H8615"\+w* pereció. Estamos totalmente destruidos.\wj*  
\v 12 \wj \+w Por|strong="H3651"\+w* \+w tanto|strong="H3651"\+w* \+w profetiza|strong="H5012"\+w*: \+nd ʼAdonay \+w Yavé|strong="H3068"\+w*\+nd* dice: ¡Oh \+w pueblo|strong="H5971"\+w* \+w mío|strong="H5971"\+w*! ¡\+w Ciertamente|strong="H2009"\+w* \+w Yo|strong="H2009"\+w* \+w abro|strong="H6605"\+w* sus \+w sepulcros|strong="H6913"\+w*, los sacaré \+w de|strong="H5971"\+w* sus tumbas, \+w y|strong="H3541"\+w* los traeré \+w a|strong="H3068"\+w* la tierra \+w de|strong="H5971"\+w* \+w Israel|strong="H3478"\+w*!\wj*  
\v 13 \wj \+w Cuando|strong="H3588"\+w* abra sus \+w sepulcros|strong="H6913"\+w* \+w y|strong="H3588"\+w* \+w los|strong="H3588"\+w* \+w saque|strong="H5927"\+w* \+w de|strong="H3588"\+w* sus tumbas, oh \+w pueblo|strong="H5971"\+w* \+w mío|strong="H5971"\+w*, \+w sabrán|strong="H3045"\+w* \+w que|strong="H3588"\+w* \+w Yo|strong="H3588"\+w* soy \+nd \+w Yavé|strong="H3068"\+w*\+nd*.\wj*  
\v 14 \wj Infundiré \+w mi|strong="H5921"\+w* \+w Espíritu|strong="H7307"\+w* \+w en|strong="H5921"\+w* ustedes \+w y|strong="H3588"\+w* \+w vivirán|strong="H2421"\+w*. \+w Los|strong="H5921"\+w* estableceré \+w en|strong="H5921"\+w* \+w su|strong="H3588"\+w* propia tierra. \+w Y|strong="H3068"\+w* \+w sabrán|strong="H3045"\+w* \+w que|strong="H3588"\+w* \+w Yo|strong="H3588"\+w*, \+nd \+w Yavé|strong="H3068"\+w*\+nd*, \+w hablé|strong="H1696"\+w* \+w y|strong="H3588"\+w* \+w lo|strong="H5921"\+w* cumplí,\wj* \w dice|strong="H5002"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.   
\s1 Acción simbólica de dos varas  
\p
\v 15 La \w Palabra|strong="H1697"\w* \w de|strong="H1697"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w mí|strong="H1961"\w*:  
\v 16 \wj \+w Hijo|strong="H1121"\+w* \+w de|strong="H5921"\+w* \+w hombre|strong="H1121"\+w*, \+w toma|strong="H3947"\+w* una vara \+w y|strong="H5921"\+w* \+w escribe|strong="H3789"\+w* \+w en|strong="H5921"\+w* \+w ella|strong="H5921"\+w*: \+w Para|strong="H5921"\+w* \+w Judá|strong="H3063"\+w*, \+w y|strong="H5921"\+w* \+w para|strong="H5921"\+w* \+w los|strong="H1121"\+w* \+w hijos|strong="H1121"\+w* \+w de|strong="H5921"\+w* \+w Israel|strong="H3478"\+w*, sus compañeros. Luego \+w toma|strong="H3947"\+w* otra vara \+w y|strong="H5921"\+w* \+w escribe|strong="H3789"\+w* \+w en|strong="H5921"\+w* \+w ella|strong="H5921"\+w*: \+w Para|strong="H5921"\+w* \+w José|strong="H3130"\+w*, \+w la|strong="H5921"\+w* vara \+w de|strong="H5921"\+w* Efraín, \+w y|strong="H5921"\+w* \+w toda|strong="H3605"\+w* \+w la|strong="H5921"\+w* \+w Casa|strong="H1004"\+w* \+w de|strong="H5921"\+w* \+w Israel|strong="H3478"\+w*, sus compañeros.\wj*  
\v 17 \wj Luego, júntalas tú mismo la una con la otra \+w como|strong="H1961"\+w* una sola vara, \+w para|strong="H1961"\+w* \+w que|strong="H1961"\+w* \+w sean|strong="H1961"\+w* una en tu \+w mano|strong="H3027"\+w*.\wj*   
\p
\v 18 \wj \+w Cuando|strong="H4100"\+w* \+w los|strong="H1121"\+w* \+w hijos|strong="H1121"\+w* \+w de|strong="H1121"\+w* tu \+w pueblo|strong="H5971"\+w* te pregunten: ¿\+w No|strong="H3808"\+w* \+w nos|strong="H4100"\+w* dirás \+w qué|strong="H4100"\+w* quieres significar con éstas?\wj*  
