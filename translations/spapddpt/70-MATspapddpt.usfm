\v 11 \w Al|strong="G3588"\w* entrar \w en|strong="G1519"\w* \w la|strong="G3588"\w* \w casa|strong="G3614"\w*, vieron \w al|strong="G3588"\w* \w Niño|strong="G3813"\w* \w con|strong="G3326"\w* \w su|strong="G3588"\w* \w madre|strong="G3384"\w* \w María|strong="G3137"\w*, \w se|strong="G2532"\w* postraron \w y|strong="G2532"\w* \w lo|strong="G3588"\w* \w adoraron|strong="G4352"\w*. Abrieron \w sus|strong="G3588"\w* \w tesoros|strong="G2344"\w* \w y|strong="G2532"\w* \w le|strong="G1519"\w* \w ofrecieron|strong="G4374"\w* regalos: \w oro|strong="G5557"\w*, incienso \w y|strong="G2532"\w* \w mirra|strong="G4666"\w*.  
