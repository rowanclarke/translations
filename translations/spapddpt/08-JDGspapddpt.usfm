\v 20 \w Pues|strong="H7200"\w* \w sucedió|strong="H1961"\w* \w que|strong="H5921"\w* mientras \w la|strong="H5921"\w* \w llama|strong="H3851"\w* \w subía|strong="H5927"\w* \w del|strong="H5921"\w* \w altar|strong="H4196"\w* \w hacia|strong="H5921"\w* \w el|strong="H5921"\w* \w cielo|strong="H8064"\w*, \w el|strong="H5921"\w* \w Ángel|strong="H4397"\w* \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* ascendió \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w llama|strong="H3851"\w* \w del|strong="H5921"\w* \w altar|strong="H4196"\w*. \w Al|strong="H5921"\w* \w ver|strong="H7200"\w* esto \w Manoa|strong="H4495"\w* \w y|strong="H5921"\w* su esposa \w cayeron|strong="H5307"\w* \w a|strong="H3068"\w* tierra \w sobre|strong="H5921"\w* sus \w rostros|strong="H6440"\w*.
