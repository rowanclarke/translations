\p
\v 29 \wj \+w Esto|strong="H2063"\+w* será \+w la|strong="H5921"\+w* señal, \wj*\w dice|strong="H5002"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \wj \+w de|strong="H5921"\+w* \+w que|strong="H3588"\+w* \+w Yo|strong="H3588"\+w* \+w los|strong="H5921"\+w* \+w castigo|strong="H7451"\+w* \+w en|strong="H5921"\+w* \+w este|strong="H2088"\+w* \+w lugar|strong="H4725"\+w* \+w para|strong="H4616"\+w* \+w que|strong="H3588"\+w* \+w sepan|strong="H3045"\+w* \+w que|strong="H3588"\+w* mis \+w Palabras|strong="H1697"\+w* \+w ciertamente|strong="H3588"\+w* \+w permanecerán|strong="H6965"\+w* \+w contra|strong="H5921"\+w* ustedes \+w para|strong="H4616"\+w* daño.\wj*  
\v 30 \nd \+w Yavé|strong="H3068"\+w*\nd* dice: \wj En verdad \+w Yo|strong="H5315"\+w* \+w entrego|strong="H5414"\+w* \+w a|strong="H3068"\+w* Faraón Hofra, \+w rey|strong="H4428"\+w* \+w de|strong="H5414"\+w* \+w Egipto|strong="H4714"\+w*, en la \+w mano|strong="H3027"\+w* \+w de|strong="H5414"\+w* sus enemigos \+w y|strong="H3541"\+w* \+w de|strong="H5414"\+w* los \+w que|strong="H3541"\+w* \+w buscan|strong="H1245"\+w* su \+w vida|strong="H5315"\+w*, \+w así|strong="H3541"\+w* como \+w entregué|strong="H5414"\+w* \+w a|strong="H3068"\+w* Sedequías, \+w rey|strong="H4428"\+w* \+w de|strong="H5414"\+w* \+w Judá|strong="H3063"\+w*, en la \+w mano|strong="H3027"\+w* \+w de|strong="H5414"\+w* \+w Nabucodonosor|strong="H5019"\+w*, \+w rey|strong="H4428"\+w* \+w de|strong="H5414"\+w* Babilonia, su enemigo \+w que|strong="H3541"\+w* \+w buscaba|strong="H1245"\+w* su \+w vida|strong="H5315"\+w*.\wj*   
\c 45  
\s1 Palabra de \nd Yavé\nd* para el escriba Baruc  
\p
\v 1 \w La|strong="H5921"\w* \w Palabra|strong="H1697"\w* \w que|strong="H5921"\w* \w habló|strong="H1696"\w* \w el|strong="H5921"\w* \w profeta|strong="H5030"\w* \w Jeremías|strong="H3414"\w* \w a|strong="H3068"\w* Baruc, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Nerías, cuando éste \w escribió|strong="H3789"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* rollo aquellas \w Palabras|strong="H1697"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w boca|strong="H6310"\w* \w de|strong="H5921"\w* \w Jeremías|strong="H3414"\w*, \w el|strong="H5921"\w* \w año|strong="H8141"\w* \w cuarto|strong="H7243"\w* \w de|strong="H5921"\w* \w Joacim|strong="H3079"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Josías|strong="H2977"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*:  
\v 2 \nd \+w Yavé|strong="H3068"\+w*\nd*, \w el|strong="H5921"\w* \nd ʼElohim\nd* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w te|strong="H5921"\w* dice, oh Baruc:  
\v 3 \wj Tú dijiste: ¡Ay \+w de|strong="H5921"\+w* \+w mí|strong="H5921"\+w*, \+w porque|strong="H3588"\+w* \+nd \+w Yavé|strong="H3068"\+w*\+nd* \+w añadió|strong="H3254"\+w* \+w tristeza|strong="H3015"\+w* \+w a|strong="H3068"\+w* \+w mi|strong="H5921"\+w* \+w dolor|strong="H4341"\+w*! ¡Estoy \+w cansado|strong="H3021"\+w* \+w de|strong="H5921"\+w* gemir \+w y|strong="H3588"\+w* \+w no|strong="H3808"\+w* \+w hallo|strong="H4672"\+w* \+w descanso|strong="H4496"\+w*!\wj*   
\p
\v 4 \wj \+w Le|strong="H1931"\+w* dirás: \+nd \+w Yavé|strong="H3068"\+w*\+nd* dice: \+w Mira|strong="H2009"\+w*, \+w Yo|strong="H2009"\+w* estoy \+w a|strong="H3068"\+w* punto de destruir \+w lo|strong="H1931"\+w* \+w que|strong="H1931"\+w* \+w edifiqué|strong="H1129"\+w* \+w y|strong="H3541"\+w* de arrancar \+w lo|strong="H1931"\+w* \+w que|strong="H1931"\+w* \+w planté|strong="H5193"\+w*, \+w es|strong="H1931"\+w* decir, \+w toda|strong="H3605"\+w* \+w la|strong="H1931"\+w* tierra.\wj*  
\v 5 \wj ¿\+w Y|strong="H3068"\+w* tú \+w buscas|strong="H1245"\+w* \+w grandes|strong="H1419"\+w* \+w cosas|strong="H7451"\+w* \+w para|strong="H5921"\+w* \+w ti|strong="H5921"\+w*? ¡\+w No|strong="H3588"\+w* \+w las|strong="H5921"\+w* \+w busques|strong="H1245"\+w*! \+w Porque|strong="H3588"\+w* \+w mira|strong="H2005"\+w*, \+w Yo|strong="H3588"\+w* traigo \+w mal|strong="H7451"\+w* \+w sobre|strong="H5921"\+w* \+w todo|strong="H3605"\+w* \+w ser|strong="H5315"\+w* vivo, \wj*\w dice|strong="H5002"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*. \wj \+w Pero|strong="H3588"\+w* tu \+w vida|strong="H5315"\+w* \+w te|strong="H5921"\+w* \+w será|strong="H5414"\+w* \+w dada|strong="H5414"\+w* \+w como|strong="H3588"\+w* un botín \+w en|strong="H5921"\+w* \+w todos|strong="H3605"\+w* \+w los|strong="H5921"\+w* \+w lugares|strong="H4725"\+w* adonde tú \+w vayas|strong="H3212"\+w*.\wj*   
\c 46  
\s1 Profecía contra las naciones  
\p
\v 1 \w Palabra|strong="H1697"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w que|strong="H5921"\w* \w vino|strong="H1961"\w* \w al|strong="H5921"\w* \w profeta|strong="H5030"\w* \w Jeremías|strong="H3414"\w* \w contra|strong="H5921"\w* \w las|strong="H5921"\w* \w naciones|strong="H1471"\w*:   
\s1 Contra Egipto  
\p
\v 2 \w Con|strong="H5921"\w* respecto \w a|strong="H3068"\w* \w Egipto|strong="H4714"\w*. \w Contra|strong="H5921"\w* \w el|strong="H5921"\w* \w ejército|strong="H2428"\w* \w de|strong="H5921"\w* Faraón Necao, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w*, quien llegó \w hasta|strong="H5921"\w* Carquemis, \w junto|strong="H5921"\w* \w al|strong="H5921"\w* \w Éufrates|strong="H6578"\w*, \w y|strong="H5921"\w* \w fue|strong="H1961"\w* derrotado \w por|strong="H5921"\w* \w Nabucodonosor|strong="H5019"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Babilonia, \w el|strong="H5921"\w* \w año|strong="H8141"\w* \w cuarto|strong="H7243"\w* \w de|strong="H5921"\w* \w Joacim|strong="H3079"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Josías|strong="H2977"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*:  
\v 3 \wj Preparen \+w escudo|strong="H4043"\+w* embrazado y \+w escudo|strong="H4043"\+w* más largo que ancho, y salgan \+w a|strong="H3068"\+w* la \+w guerra|strong="H4421"\+w*.\wj*  
\v 4 \wj Ustedes \+w jinetes|strong="H6571"\+w*, preparen los \+w caballos|strong="H5483"\+w* y monten. Preséntense con sus yelmos\wj*,\f + \fr 46:4 \ft Yelmo: Parte de la armadura antigua que cubría la cabeza y la cara por completo.\f* \wj pulan las \+w lanzas|strong="H7420"\+w* y cúbranse con las corazas.\wj*  
\v 5 \wj ¿\+w Por|strong="H4069"\+w* \+w qué|strong="H3808"\+w* \+w los|strong="H1992"\+w* \+w veo|strong="H7200"\+w* atemorizados y \+w se|strong="H3808"\+w* devuelven? Están aterrorizados. \+w Sus|strong="H1992"\+w* \+w valientes|strong="H1368"\+w* fueron derrotados, huyen y buscan \+w refugio|strong="H4498"\+w* \+w sin|strong="H3808"\+w* \+w mirar|strong="H7200"\+w* atrás. \+w El|strong="H1992"\+w* terror \+w está|strong="H1992"\+w* \+w por|strong="H4069"\+w* \+w todas|strong="H5439"\+w* \+w partes|strong="H5439"\+w*, \wj*\w dice|strong="H5002"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.  
\v 6 \wj \+w Que|strong="H5921"\+w* \+w no|strong="H5921"\+w* huya \+w el|strong="H5921"\+w* \+w hombre|strong="H1368"\+w* veloz, ni \+w escape|strong="H4422"\+w* \+w el|strong="H5921"\+w* \+w valiente|strong="H1368"\+w*. \+w Tropiezan|strong="H3782"\+w* \+w y|strong="H5921"\+w* \+w caen|strong="H5307"\+w* \+w en|strong="H5921"\+w* \+w el|strong="H5921"\+w* \+w norte|strong="H6828"\+w*, \+w junto|strong="H5921"\+w* \+w a|strong="H3068"\+w* \+w la|strong="H5921"\+w* ribera \+w del|strong="H5921"\+w* \+w Éufrates|strong="H6578"\+w*.\wj*   
\p
\v 7 ¿\w Quién|strong="H4310"\w* \w es|strong="H2088"\w* \w ése|strong="H2088"\w* \w que|strong="H4310"\w* crece como \w el|strong="H4310"\w* Nilo, y encrespa sus \w aguas|strong="H4325"\w* como \w ríos|strong="H2975"\w*,  
\v 8 \w que|strong="H4325"\w* dice: Creceré, inundaré la tierra, destruiré \w ciudades|strong="H5892"\w* y \w a|strong="H3068"\w* sus \w habitantes|strong="H3427"\w*? Es \w Egipto|strong="H4714"\w*, \w que|strong="H4325"\w* crece como \w el|strong="H2975"\w* Nilo, y sus \w aguas|strong="H4325"\w* se encrespan como \w ríos|strong="H2975"\w*.  
\v 9 Avancen, \w caballos|strong="H5483"\w*, corran locamente, carruajes. Marchen los \w hombres|strong="H1368"\w* \w valientes|strong="H1368"\w*. Etíopes y libios \w que|strong="H1869"\w* embrazan el \w escudo|strong="H4043"\w*, Lidios \w que|strong="H1869"\w* toman y entesan el \w arco|strong="H7198"\w*.  
\v 10 \w Porque|strong="H3588"\w* \w ese|strong="H1931"\w* \w día|strong="H3117"\w* pertenece \w a|strong="H3068"\w* \nd ʼAdonay \+w Yavé|strong="H3068"\+w*\nd* \w de|strong="H3588"\w* las huestes, un \w día|strong="H3117"\w* \w de|strong="H3588"\w* retribución \w para|strong="H3588"\w* vengarse \w de|strong="H3588"\w* \w sus|strong="H1931"\w* \w enemigos|strong="H6862"\w*. \w La|strong="H1931"\w* \w espada|strong="H2719"\w* devora \w y|strong="H3588"\w* \w está|strong="H1931"\w* saciada, \w se|strong="H1931"\w* embriaga \w de|strong="H3588"\w* \w sangre|strong="H1818"\w*. \w Pues|strong="H3588"\w* hay una matanza \w para|strong="H3588"\w* \nd ʼAdonay \+w Yavé|strong="H3068"\+w*\nd* \w de|strong="H3588"\w* las huestes \w en|strong="H3588"\w* \w la|strong="H1931"\w* tierra del \w norte|strong="H6828"\w*, junto al \w río|strong="H5104"\w* \w Éufrates|strong="H6578"\w*.  
\v 11 \w Sube|strong="H5927"\w* \w a|strong="H3068"\w* \w Galaad|strong="H1568"\w* y consigue \w bálsamo|strong="H6875"\w*, oh \w virgen|strong="H1330"\w* \w hija|strong="H1323"\w* de \w Egipto|strong="H4714"\w*. En vano multiplicas los remedios. No hay sanidad para ti.  
\v 12 Las \w naciones|strong="H1471"\w* \w oyeron|strong="H8085"\w* \w de|strong="H3588"\w* tu vergüenza \w y|strong="H3588"\w* \w la|strong="H3588"\w* tierra está \w llena|strong="H4390"\w* \w de|strong="H3588"\w* tu clamor. \w Porque|strong="H3588"\w* \w un|strong="H3162"\w* guerrero \w tropezó|strong="H3782"\w* \w con|strong="H3588"\w* otro, \w y|strong="H3588"\w* \w ambos|strong="H8147"\w* \w cayeron|strong="H5307"\w*.   
\p
\v 13 \w Palabra|strong="H1697"\w* \w de|strong="H1697"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w que|strong="H1697"\w* vino \w al|strong="H4428"\w* \w profeta|strong="H5030"\w* \w Jeremías|strong="H3414"\w* sobre la llegada \w de|strong="H1697"\w* \w Nabucodonosor|strong="H5019"\w*, \w rey|strong="H4428"\w* \w de|strong="H1697"\w* Babilonia, para asolar la tierra \w de|strong="H1697"\w* \w Egipto|strong="H4714"\w*:  
\v 14 \wj Díganlo \+w en|strong="H3588"\+w* \+w Egipto|strong="H4714"\+w*. Proclámenlo \+w en|strong="H3588"\+w* \+w Migdol|strong="H4024"\+w*. Anúncienlo \+w en|strong="H3588"\+w* Menfis \+w y|strong="H3588"\+w* \+w en|strong="H3588"\+w* Tafnes. Digan: \+w Ponte|strong="H3320"\+w* \+w en|strong="H3588"\+w* pie \+w y|strong="H3588"\+w* \+w está|strong="H3320"\+w* alerta, \+w porque|strong="H3588"\+w* \+w la|strong="H3588"\+w* \+w espada|strong="H2719"\+w* ya devora \+w alrededor|strong="H5439"\+w*.\wj*  
\v 15 \wj ¿\+w Por|strong="H3588"\+w* \+w qué|strong="H3588"\+w* \+w está|strong="H5975"\+w* postrado Apis, tu buey sagrado? Tu toro \+w no|strong="H3808"\+w* \+w permaneció|strong="H5975"\+w* \+w en|strong="H3588"\+w* \+w pie|strong="H5975"\+w* \+w porque|strong="H3588"\+w* \+nd \+w Yavé|strong="H3068"\+w*\+nd* \+w lo|strong="H3808"\+w* empujó\wj*  
\v 16 \wj \+w e|strong="H3068"\+w* \+w hizo|strong="H5307"\+w* tropezar \+w a|strong="H3068"\+w* \+w muchos|strong="H7235"\+w*. Cada uno \+w cayó|strong="H5307"\+w* sobre su \+w compañero|strong="H7453"\+w*, hasta \+w que|strong="H1571"\+w* dijeron: \+w Levantémonos|strong="H6965"\+w* \+w y|strong="H1571"\+w* huyamos \+w de|strong="H6440"\+w* \+w la|strong="H1571"\+w* \+w espada|strong="H2719"\+w* del opresor. Regresemos \+w a|strong="H3068"\+w* nuestro \+w pueblo|strong="H5971"\+w* \+w y|strong="H1571"\+w* \+w a|strong="H3068"\+w* nuestra tierra natal.\wj*  
\v 17 \wj \+w Y|strong="H3068"\+w* \+w allí|strong="H8033"\+w* \+w gritaron|strong="H7121"\+w*: \+w Faraón|strong="H6547"\+w*, \+w rey|strong="H4428"\+w* de \+w Egipto|strong="H4714"\+w*: Un gran rugido.\wj*   
\p
\v 18 \wj ¡\+w Vivo|strong="H2416"\+w* \+w Yo|strong="H3588"\+w*! \wj*Palabra del \w Rey|strong="H4428"\w*, cuyo \w Nombre|strong="H8034"\w* \w es|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w de|strong="H3588"\w* las huestes: \wj \+w Como|strong="H3588"\+w* \+w la|strong="H3588"\+w* montaña \+w Tabor|strong="H8396"\+w* \+w es|strong="H3588"\+w* \+w real|strong="H4428"\+w*, \+w y|strong="H3588"\+w* \+w la|strong="H3588"\+w* montaña Carmelo se levanta frente \+w al|strong="H4428"\+w* \+w mar|strong="H3220"\+w*, \+w así|strong="H3588"\+w* \+w él|strong="H3588"\+w* vendrá.\wj*  
\v 19 \wj Prepara \+w tu|strong="H6213"\+w* equipaje \+w para|strong="H3588"\+w* \+w el|strong="H3588"\+w* \+w cautiverio|strong="H1473"\+w*, oh \+w hija|strong="H1323"\+w* \+w que|strong="H3588"\+w* vives \+w en|strong="H3588"\+w* \+w Egipto|strong="H4714"\+w*. Menfis \+w será|strong="H1961"\+w* una desolación. \+w Será|strong="H1961"\+w* arrasada hasta \+w no|strong="H6213"\+w* \+w quedar|strong="H1961"\+w* habitante.\wj*   
\p
