\id ISA
\h عَننَبِ عٍسَيِ
\toc1 عَلَ شَ مَسٍنيِ عَننَبِ عٍسَيِ بّ
\toc2 عَننَبِ عٍسَيِ
\toc3 عٍسَ
\mt1 عَلَ شَ مَسٍنيِ عَننَبِ عٍسَيِ بّ
\imt1 مَسٍنيِ ندٍ يِ كِتَابُي شَ قٍ رَ
\ip عَننَبِ عٍسَيِ شَ كِتَابُي قِندِشِ مَسٍنيِ بٍلٍبٍلٍ نَن نَ دُنِحَ بِرِن بّ. عَلَتَلَ عَ شِلِشِ نّ، عَ شَ يُدَيَ مَنفّيٍ عٌسِيَسِ، يٌتَمِ، عَشَسِ، نُن شٍسٍكِيَ مَلِ عَ سَفٌ كٌلٌندٍ. مَنفّ ندٍيٍ نُ بِرَ مَ كُيٍيٍ قْشْ رَ، ندٍيٍ نُ عٍ يّتّ تَشُمَ مَنفّ بٌورٍيٍ رَ نَشٍيٍ سّنبّ فبٌ عٍ بّ. نَ بِرِن كُي عَننَبِ عٍسَيِ نَشَ عَ مَسٍن عٍ بّ، عَ عَلَتَلَ فبَنسَن نَن نْمَ مِشِ مَلِدٍ. كُيٍ تَن قِندِشِ وُرِ سّنبّتَرٍ نَن نَ. دُنِحَ مَنفّيٍ قَن قِندِشِ عِبُنَدَ مَ فبَنسَن نَن نَ، نَشٍيٍ مُ نْمَ سٍسٍ رَ عَلَ شَ مَرَفِرِ يَ رَ. عَلَتَلَ نَن قِندِشِ دُنِحَ مَنفّ سّنِيّنشِ رَ.
\ip عِسِرَيِلَ بْنسْي قُ نُن قِرِنيِ نُ قَتَنشِ مَنفّيَ قِرِن نَن نَ. نَشَن نُ نَ كْولَ مَبِرِ، عَ شِلِ عِسِرَيِلَ. نَشَن نُ نَ يِرٍقَنيِ مَبِرِ، عَ شِلِ يُدَيَ. عَننَبِ عٍسَيِ شَ كِتَابُي عَ مَسٍنمَ عٍ قِرِن بِرِن عَلَ مَتَندِشِ كِ نَشّ، عٍ قَ شَنِن كٌنيِيَ كُي حَمَنّ مَ نَ شَ قٍ رَ. بٍينُن نَ شَ رَبَ يُدَيَ، عَلَتَلَ نَشَ يِ مَسٍنيِ قِ عَ شَ نَمِحْنمّ مَ عَلَكٌ عَ شَ حَمَ شَ رَتَنفَ نَ بِرِن مَ، كْنْ حَمَ مُ تِن عٍ تُلِ مَتِدٍ عَلَ رَ. مَنفّ ندٍ عَلْ شٍسٍكِيَ نَشَ كَتَ بِرَدٍ عَلَ قْشْ رَ، كْنْ بٌورٍيٍ تَن مُ تِن نَ رَ قٍقٍ مَ.
\ip نَ كُي عَلَ شَ حَشَنكَتّ نَشَ بِرَ عٍ بِرِن قْشْ رَ، عٍ قَ شَنِن كٌنيِيَ كُي بَبِلْن بْشِ مَ. نَمِحْنمّ شَ كَوَندِ قِندِشِ مَرَ سِ نَن نَ وٌن بِرِن بّ. مِشِ نَشَن تٌندِ مَ عَ تُلِ مَتِدٍ عَلَتَلَ رَ، عَ شَ قٍ قَمَ نّ شُن نَكَنَدٍ. كْنْ عَننَبِ عٍسَيِ شَ مَسٍنيِ لُمَ نّ عَلْ بٌورٍ نَمِحْنمّيٍ شَ مَسٍنيِ. عٍ بِرِن عَ قَلَمَ عَ عِبُنَدَ مَ شَ يُنُبِيٍ عَ نِيَمَ نّ عٍ شَ حَشَنكَتّ سْتْ، كْنْ عٍ مَن عَلَ شَ هِننّ مَسٍنمَ نَشَن عَ نِيَمَ مِشِيٍ شَ تُوبِ، عٍ فبِلٍن عٍ شَ يُنُبِيٍ قْشْ رَ، عَلَ قَ عٍ رَكِسِ.
\ip عَلَ شَ كِسِ حْشُن. عَ قْلْمَ دُنِحَ نَن مَ، عَ قَ عَلِفِيَمَ لِ. مِشِ نَشٍيٍ بِرَ مَ عَلَ وَشْنقٍ قْشْ رَ، عٍ هّيرِ تٌمَ نّ نَ حّرّ كُي. دُنِحّءِفِرِ شْرْشْ، كْنْ نَشَن لُمَ عَلَ شَ قٍ كُي، عَ شُننَكٍلِ تٌمَ نّ. عَننَبِ عٍسَيِ مَن عَ مَسٍنمَ، يِ دُنِحَ نَ حْن، عَلَ قَمَ نّ عَ شَ حَمَ رَ سٌدٍ عَ شْنيِ، بْحّسَ نُن بَرَكَ لُمَ دّننَشّ. نَ كِسِ قَن. عَلَ شَ وٌن مَلِ نَ سْتْدٍ عَ شَ هِننّ سَابُي رَ. عَمِنَ.
\mt1 عَلَ شَ مَسٍنيِ عَننَبِ عٍسَيِ بّ
\c 1
\s1 عِسِرَيِلَ شَ سّرّشّ كَنَشِيٍ عَ شَ يُنُبِيٍ شَ قٍ رَ
\p 
\v 1 مَسٍنيِ نَشٍيٍ فٌرٌ عَمٌسُ شَ دِ عٍسَيِ مَ، يُدَيَ نُن دَرِ سَلَمُ شَ قٍ رَ، يُدَيَ مَنفّيٍ عٌسِيَسِ، يٌتَمِ، عَشَسِ، نُن شٍسٍكِيَ شَ وَشَتِ.
\b
\q1 
\v 2 عَلَتَلَ نَن مَسٍنيِ تِقٍ،
\q1 كٌورٍ نُن بْشِ بِرِن شَ عٍ تُلِ مَتِ عَ رَ.
\q1 عَلَتَلَ نَشّ،
\q1 «ﭑ بَرَ دِيٍ شُرُ، ﭑ عٍ رَ مْ،
\q1 كْنْ عٍ بَرَ مُرُتَ ﭑ مَ.
\q1 
\v 3 نِنفٍ يَتِ عَ كَنيِ كٌلٌن،
\q1 سٌقَلٍ قَن عَ كٌلٌن عَ كَنيِ دٌنسٍ سَمَ عَ بّ دّننَشّ.
\q1 كْنْ عِسِرَيِلَ تَن مُ سٍسٍ كٌلٌن،
\q1 ﭑ مَ حَمَ مُ سٍسٍ قَهَامُشِ.»
\b
\q1 
\v 4 حَشَنكَتّ نَ يِ حَمَ يُنُبِتْي بّ،
\q1 نَشَن يُنُبِ كٌتٍ شَنِنمَ،
\q1 نَشَن قِندِشِ قٍ حَاشِ رَبَيٍ رَ،
\q1 نَشَن قِندِشِ دِ مُرُتَشِيٍ رَ.
\q1 عٍ بَرَ مّ عَلَتَلَ رَ،
\q1 عٍ عِسِرَيِلَ شَ سّنِيّنتْي مَبٍرٍ،
\q1 عٍ عٍ كٌبٍ رَ سٌ عَ رَ.
\b
\q1 
\v 5 وٌ نَ حَشَنكَتّ قٍنقٍ مُنقٍ رَ؟
\q1 وٌ تٌندِشِ فبِلٍندٍ عَلَتَلَ مَ مُنسٍ مَ؟
\q1 وٌ بَرَ قُرَ وٌ شُنيِ مَ، وٌ تْورْشِ وٌ بْحّ مَ.
\q1 
\v 6 كٍلِقٍ وٌ سَنيِ مَ هَن وٌ شُنيِ،
\q1 وٌ شَ قٍقٍ مُ لَنشِ.
\q1 وٌ شَ قِيٍ يَ مُ عِشَشِ، عٍ مُ مَشِرِشِ، تُرٍ يٌ مُ سَشِ عٍ مَ.
\q1 
\v 7 وٌ شَ بْشِ بَرَ كَنَ، وٌ شَ تَايٍ بَرَ فَن.
\q1 سِ فبّتّيٍ نَ وٌ شَ دَشَمُي دٌنقٍ وٌ يَ شْرِ،
\q1 عٍ نَ عَ بِرِن تٌنفٌقٍ عٍ يّتّ بّ.
\q1 
\v 8 سِيٌنِ تَا نَ عَ كٍرٍنيِ مَ عَلْ بَفٍ دِ شّ تَفِ،
\q1 عَلْ لٍيلٍ نَشَن تِشِ مّرّ مَ،
\q1 عَلْ تَا نَشَن نَبِلِنشِ يَشُييٍ رَ.
\q1 
\v 9 شَ عَلَتَلَ سّنبّمَ مُ مِشِ ندٍيٍ رَكِسِ وٌن بّ نُ،
\q1 وٌن بَرَ لُ نُ عَلْ سٌدٌ مَ نُن فٌمٌرَ تَايٍ.
\b
\q1 
\v 10 وٌ وٌ تُلِ مَتِ عَلَتَلَ شَ مَسٍنيِ رَ،
\q1 وٌ تَن نَشٍيٍ مَنِيَشِ سٌدٌ مَ كُنتِفِيٍ رَ.
\q1 وٌ شَ وٌن مَرِفِ عَلَتَلَ شَ سّرِيّ رَ مّ،
\q1 وٌ تَن نَشٍيٍ لُشِ عَلْ فٌمٌرَ حَمَ.
\q1 
\v 11 عَلَتَلَ نَشّ،
\q1 «ﭑ مُنسٍ رَبَمَ وٌ شَ سّرّشّ وُيَشِيٍ رَ؟
\q1 ﭑ بَرَ لُفَ يّشّ كٌنتٌنيِ سّرّشّيٍ رَ،
\q1 ﭑ بَرَ لُفَ شُرُ سٍ بْرّفّشِيٍ تُرٍ رَ.
\q1 تُورَيٍ، يّشّييٍ نُن سِ كٌنتٌنيِيٍ وُلِ مُ رَقَن ﭑ مَ.
\q1 
\v 12 ندٍ وٌ شِلِشِ قَقٍ رَ ﭑ مَ هْرْ مْبَنشِ تّتّ كُي، تِقٍ رَ ﭑ يَ عِ؟
\q1 
\v 13 وٌ بَ قَقٍ هَدِيَ قُقَقُ رَ.
\q1 سُرَيِ شِرِ مُ رَقَن ﭑ مَ قٍقٍ مَ.
\q1 وٌ شَ كِكٍ نّينّ سَلِيٍ، وٌ شَ مَلَبُي لْشْييٍ، وٌ شَ مَلَنيِيٍ، نُن وٌ شَ سَلِيٍ شُنفبٍيٍ،
\q1 عٍ سٍسٍ مُ رَقَنشِ ﭑ مَ.
\q1 
\v 14 ﭑ وٌ شَ كِكٍ نّينّ سَلِيٍ شْنشِ،
\q1 وٌ شَ سَلِ بِرِن بَرَ ﭑ بْحّ رَحَاشُ ﭑ مَ.
\q1 
\v 15 وٌ نَ وٌ بّلّشّيٍ عِتَلَ سَلِ كُي تّمُي نَشّ،
\q1 ﭑ نَ ﭑ يَ رَفَلِمَ نّ عَلَكٌ ﭑ نَشَ قَ عَ تٌ.
\q1 هَلِ وٌ مَشَندِيٍ بِرَ عٍ بٌورٍ قْشْ رَ،
\q1 ﭑ مُ عٍ رَ مّمَ، بَرِ مَ قَشّتِيٍ نَن وٌ رَ.
\q1 
\v 16 وٌ لُ قٍ قِيشّ كُي، وٌ وٌ يّتّ رَ سّنِيّن،
\q1 وٌ بَ يُنُبِيٍ رَبَقٍ ﭑ يَ عِ.
\q1 
\v 17 وٌ وٌ مَتِنكَن قٍ قَنيِ رَبَدٍ،
\q1 وٌ لُ تِنشِنيِ كُي،
\q1 وٌ مِشِ كٌبِيٍ مَكِيتِ،
\q1 وٌ كِرِدِيٍ نُن كَاحّ فِنّيٍ شُن مَقَلَ.»
\b
\q1 
\v 18 عَلَتَلَ نَشّ، «وٌ قَ، وٌن شَ وْيّن.
\q1 هَلِ وٌ شَ يُنُبِيٍ تٌ بَرَ وٌ مَنْشْ،
\q1 وٌ نْمَ قِيشّدٍ قْين.
\q1 هَلِ عٍ سَ شْسِ نّ عَلْ فَرّ فبٍيلِ،
\q1 عٍ نْمَ نّ قِيشّدٍ عَلْ شُرُ سٍ قِيشّ قَتٍ مَشَبٍ.
\q1 
\v 19 شَ وٌ تِن وٌ تُلِ مَتِدٍ ﭑ نَ،
\q1 وٌ يِ بْشِ دَشَمُي دٌنمَ نّ،
\q1 
\v 20 كْنْ شَ وٌ سَ تٌندِ ﭑ نَتِنمّدٍ،
\q1 سَنتِدّفّمَ نَن وٌ سْنتْمَ.»
\q1 عَلَتَلَ شُي نَن نَ كِ.
\b
\q1 
\v 21 يِ تَا لُشِ نّ عَلْ فِنّ نَشَن نُ دُفُتّفّشِ عَ شَ مْرِ مَ
\q1 عَ قَ مّ عَ رَ، عَ قِندِ لَنفٌي فِنّ رَ.
\q1 عَ سِنفٍ عَ نُ تِنشِن عَ قَنيِ رَ،
\q1 كْنْ يَكْسِ عَ بَرَ قِندِ قَشَتِ رَ؟
\q1 
\v 22 عِ شَ فبٍتِ بَرَ قِندِ سٍ كَنَشِ رَ،
\q1 عِ شَ وّنِ بَرَ سُنبُ يٍ رَ.
\q1 
\v 23 عِ شَ مَنفّيٍ بَرَ مُرُتَ، عٍ قِندِ مُحّتِيٍ رَ،
\q1 بُحَ تِنشِنتَرٍ رَقَن نَشٍيٍ مَ.
\q1 نَ كُي عٍ مُ كِرِدِيٍ مَلِمَ،
\q1 عٍ مُ كِيتِ قَنيِ سَمَ كَاحّ فِنّ شَ تْورّ شَ قٍ رَ.
\q1 
\v 24 عَلَتَلَ سّنبّمَ شُي نَن يَ، نَ شَ قٍ رَ.
\q1 عِسِرَيِلَ مَرِفِ عَلَ سّنبّمَ نَشّ،
\q1 «ﭑ حَشَنكَتّ دْشْمَ نّ ﭑ فٍرٍقَيٍ مَ،
\q1 ﭑ نَ ﭑ فبٍ حْشْ ﭑ يَشُييٍ مَ.
\q1 
\v 25 ﭑ فبِلٍنمَ نّ ﭑ يِ سَ رَ عِ مَ عَ شْرْشْي رَ،
\q1 ﭑ عِ رَ سّنِيّن عَلْ فبٍتِ فبِ بَمَ كِ نَشّ تّ رَ،
\q1 عَلَكٌ عِ شَ بَ تِنشِنتَرٍيَ مَ.
\q1 
\v 26 ﭑ كِيتِسَ تِنشِنشِيٍ تِمَ نّ وٌ شُن عَلْ سِنفٍ،
\q1 ﭑ مَرَ سِمَ قَنيِيٍ لُمَ نّ وٌ تَفِ عَلْ تّمُي دَنفِشِ.
\q1 نَ دَنفِ شَنبِ، عِ شِلِ قَمَ نّ قَلَدٍ
\q1 ‹تَا تِنشِنشِ نَشَن دُفُتّفّشِ.›»
\b
\q1 
\v 27 سِيٌنِ شُن سَرَ مَ نّ تِنشِنيِ رَ،
\q1 تُوبِ مِشِيٍ كِسِمَ نّ تِنشِنيِ سَابُي رَ.
\q1 
\v 28 كْنْ فبَلٌي فٌرٌ مَ نّ مُرُتّلَيٍ نُن يُنُبِتْييٍ مَ،
\q1 هَلَكِ لُ مِشِيٍ قْشْ رَ، نَشٍيٍ عٍ كٌبٍ سٌمَ عَلَتَلَ رَ.
\q1 
\v 29 وٌ قَمَ نّ يَافِدٍ قْتْنيِ رَ وٌ نُ كُيٍ بَتُمَ دّننَشّ.
\q1 وٌ يَافِ بٍلٍبٍلٍ سْتْمَ نّ نَ يِرٍيٍ شَ قٍ رَ.
\q1 
\v 30 وٌ قَمَ نّ لُدٍ عَلْ وُرِ بِلِ لِسِشِ،
\q1 يٍ مُ نَ نَشَن مَ.
\q1 
\v 31 سّنبّمَ سّنبّ حْنمَ نّ،
\q1 عَ تَن نُن عَ شَ وَلِ بِرِن فَن،
\q1 عَ رَكِسِمَ يٌ مُ لُ نَ.
\c 2
\s1 عَلَ شَ شُننَكٍلِ نُن عَ شَ شْنّ
\p 
\v 1 عَمٌسُ شَ دِ عَننَبِ عٍسَيِ شَ مَسٍنيِ نَن يَ يُدَ نُن دَرِ سَلَمُ شَ قٍ رَ.
\q1 
\v 2 وَشَتِ دْنشْي عَلَتَلَ شَ بَنشِ تِشِ فٍيَ نَشَن قَرِ،
\q1 نَ قَمَ نّ لُدٍ فٍيَيٍ بِرِن شُن مَ.
\q1 سِ بِرِن عٍ شُن تِمَ نّ نَ يِرٍ عِتٍشِ رَ.
\q1 
\v 3 بْنسْي وُيَشِ سِفَمَ نّ نَا، عٍ عَ قَلَ،
\q1 «وٌ قَ، وٌن شَ تٍ عَلَتَلَ شَ فٍيَ قَرِ،
\q1 يَشُبَ مَرِفِ عَلَ شَ بَنشِ نَ دّننَشّ.
\q1 عَ وٌن شَرَنمَ نّ عَ شَ سّرِيّ رَ،
\q1 عَلَكٌ وٌن شَ بِرَ عَ شَ كِرَ قْشْ رَ.»
\q1 عَلَتَلَ شَ سّرِيّ مِنِمَ سِيٌنِ فٍيَ مَ،
\q1 عَ شَ مَسٍنيِ قْلْمَ دَرِ سَلَمُ تَا كُي.
\q1 
\v 4 عَلَتَلَ نَن كِيتِ سَمَ حَمَنّيٍ تَفِ،
\q1 عَ قِندِ سِ وُيَشِ تَفِ عِبَمَ رَ.
\q1 عٍ قَمَ عٍ شَ سَنتِدّفّمَيٍ شَبُدٍ كٍرِيٍ نَن نَ،
\q1 عٍ عٍ شَ تَنبّيٍ قِندِ وْرْتّيٍ رَ.
\q1 فٍرٍ حْنمَ نّ سِيٍ تَفِ،
\q1 سْورِحَ مُ مَتِنكَنمَ سْنْن.
\b
\q1 
\v 5 يَشُبَ بْنسْي، وٌ قَ،
\q1 وٌن شَ وٌن حّرّ عَلَتَلَ شَ نَءِيَلَنيِ مَ.
\q1 
\v 6 عَلَتَلَ، عِ بَرَ عِ شَ حَمَ رَبٌلٌ،
\q1 بَرِ مَ عٍ بِرَ مَ نَامُنيِيٍ قْشْ رَ،
\q1 نَشٍيٍ كٍلِشِ سٌفٍتٍدٍ مَبِرِ.
\q1 سٍ مَتٌي بَرَ وُيَ نَشٍيٍ وَلِمَ عَلْ قِلِسِتَكَيٍ.
\q1 عِ شَ حَمَ نُن سِ عَلَ كٌلٌنتَرٍيٍ بَرَ لَنيِ شِرِ.
\q1 
\v 7 عِ شَ حَمَ بَرَ شّيمَ نُن فبٍتِ فبٍفبٍ سْتْ،
\q1 عٍ شَ نَاقُلِ مُ حْنمَ.
\q1 عٍ شَ بْشِ بَرَ رَقٍ سْورِ شَ سٌييٍ نُن عٍ رَفِسٍيٍ رَ.
\q1 
\v 8 كُيٍيٍ تٌمَ نّ يِرٍ بِرِن.
\q1 كَنكَن عَ شِنبِ سِنمَ كُيٍيٍ بّ، عٍ نَشٍيٍ مَسٌلِشِ عٍ بّلّشّ رَ.
\q1 
\v 9 عٍ قٍلٍنمَ نّ عٍ بّ، عٍ عٍ مَفٌرٌ عٍ بَتُقٍ رَ.
\q1 نَ كُي، عِ نَشَ دِحّ عٍ مَ قٍوٌ.
\b
\q1 
\v 10 وٌ وٌ نْشُن قَنيٍيٍ تَفِ بْشِ مَ،
\q1 عَلَكٌ وٌ شَ وٌ مَكُيَ عَلَتَلَ شَ شْنّ رَ،
\q1 نَشَن قَمَ عَ شَ نْرّ مَكَابَشِ كُي.
\q1 
\v 11 عَدَ مَدِ شَ يّتّ عِفبٌيَ مَفٌرٌ مَ نّ،
\q1 مِشِيٍ شَ يّتّ عِتٍيَ كُنتِن.
\q1 عَلَتَلَ كٍرٍن نَن عَ يّتّ عِتٍمَ نَ لْشْي.
\q1 
\v 12 عَلَتَلَ سّنبّمَ شَ كِيتِ لْشْي قَمَ يّتّ عِفبٌي بّ.
\q1 نَشٍيٍ بَرَ عٍ يّتّ عِتٍ، عَلَ قَمَ نّ عٍ رَفٌرٌدٍ.
\q1 
\v 13 عَ لِبَن سّدِرِ بِلِ نُن بَسَن شَ وُرِ بِلِ عِتٍشِ بِرِن نَفٌرٌ مَ نّ.
\q1 
\v 14 عَ فٍيَ عِتٍشِ قَن بَمَ نّ.
\q1 
\v 15 عَ مِشِيٍ شَ بَنشِ مَكَنتَشِيٍ كَنَمَ نّ،
\q1 عَ عٍ شَ تّتّيٍ رَبِرَ.
\q1 
\v 16 عَ عٍ شَ كُنكُي شُنفبٍيٍ رَدُلَمَ نّ.
\q1 
\v 17 عَلَتَلَ قَمَ نّ عَدَ مَدِ شَ يّتّ عِفبٌيَ رَفٌرٌدٍ،
\q1 عَ مِشِيٍ شَ يّتّ عِتٍيَ كُنتِن.
\q1 عَلَتَلَ كٍرٍن نَن عَ يّتّ عِتٍمَ نَ لْشْي.
\q1 
\v 18 كُيٍ قٍ بِرِن كَنَمَ نّ.
\b
\q1 
\v 19 مِشِيٍ عٍ نْشُنمَ نّ قْنمّيٍ تَفِ فّمّ لٌنفٌرِ رَ،
\q1 عٍ يِلِ فٍمَ نّ بْشِ كُي، عٍ قَ عٍ نْشُن عَلَتَلَ شَ شْنّ مَ،
\q1 نَشَن قَمَ عَ شَ نْرّ مَكَابَشِ كُي،
\q1 عَ نَ كٍلِ بْشِ رَ سّرّندٍ تّمُي نَشّ.
\q1 
\v 20 نَ لْشْي، مِشِيٍ قَمَ نّ عٍ شَ كُيٍ وْلّدٍ بَلٍ نُن تُوكّ مَ،
\q1 عٍ نُ نَشٍيٍ يَءِلَنشِ شّيمَ نُن فبٍتِ رَ عٍ بَتُقٍ رَ.
\q1 
\v 21 عٍ عٍ نْشُنمَ نّ يِلِيٍ نُن قْنمّيٍ كُي قَنيٍ لٌنفٌرِ رَ،
\q1 عٍ شَ عٍ مَكُيَ عَلَتَلَ شَ شْنّ رَ،
\q1 نَشَن قَمَ عَ شَ نْرّ مَكَابَشِ كُي،
\q1 عَ نَ كٍلِ بْشِ رَ سّرّندٍ تّمُي نَشّ.
\b
\q1 
\v 22 وٌ بَ وٌ يّتّ تَشُقٍ عَدَ مَدِ رَ،
\q1 حّنفِ كٍرٍن ثٍتِ نَ نَشَن بّ.
\q1 تِدٍ مُندُن نَ عَ مَ؟
\c 3
\s1 حَشَسِ بِرَقٍ يُدَيَ كُي
\p 
\v 1 مَرِفِ عَلَتَلَ سّنبّمَ بَرَ نَتّ تٌنفٌ
\q1 دَرِ سَلَمُ نُن يُدَيَ شُن نَكَنَقٍ رَ.
\q1 عَ شَ بَلٌي نُن يٍ بَ عٍ يِ رَ،
\q1 
\v 2 عَ شَ عٍ شَ حَلَمَيٍ نُن عٍ شَ سْورِيٍ رَفٌرٌ،
\q1 عَ شَ عٍ شَ كِيتِسَيٍ نُن نَمِحْنمّيٍ رَ سَبَرِ،
\q1 عَ شَ عٍ شَ سٍمَتٌي نُن عٍ شَ قٌرِيٍ مَكُيَ عٍ بٌورٍ رَ،
\q1 
\v 3 عَ شَ عٍ شَ سْورِ مَنفّيٍ، عٍ شَ مَرَ سِمَيٍ، عٍ شَ وَلِكّ قَنيِيٍ،
\q1 نُن عٍ شَ مِشِ كْوتَشِ بِرِن بَ عٍ يِ رَ.
\q1 
\v 4 ﭑ قَمَ قٌنِكٍيٍ نَن تِدٍ مَنفّيَ رَ عٍ شُن مَ،
\q1 دِ مّيٍ نَن قَمَ دْشْدٍ عٍ قَرِ.
\q1 
\v 5 كَنكَن قُمَ نّ عَ بٌورٍ مَ،
\q1 قٌنِكٍيٍ تِمَ نّ شّمْشِيٍ كَنكٍ،
\q1 قُيَنتٍيٍ قَن بَفَن مِشِ بِنيّ مَ.
\b
\q1 
\v 6 نَ كُي، مِشِ ندٍ عَ قَلَمَ نّ عَ بَرِ بٌورٍ ندٍ بّ،
\q1 «دٌنمَ قَنيِ تٌ نَ عِ تَن يِ رَ،
\q1 عِ شَ قِندِ مُشُ شَ يَرٍرَتِ رَ،
\q1 عِ شَ مَنفّيَ تٌنفٌ يِ حَشَسِ كُي.»
\q1 
\v 7 كْنْ عَ نفَشَكٍرٍنيِ عَ يَابِمَ نّ،
\q1 «سٍرِبَ مُ نَ ﭑ نَ،
\q1 دٌنمَ نُن دٌنسٍ يٌ مُ نَ ﭑ مَ بَنشِ كُي.
\q1 وٌ نَشَ ﭑ قِندِ حَمَ شَ مَنفّ رَ.»
\b
\q1 
\v 8 دَرِ سَلَمُ نَ بِرَقٍ، يُدَيَ شُن نَ كَنَقٍ،
\q1 بَرِ مَ عٍ عَلَتَلَ مَتَندِ مَ عٍ شَ وْيّنيِ نُن عٍ شَ وَلِ رَ،
\q1 عٍ بَرَ مُرُتَ عَلَتَلَ شَ مَنفّيَ مَ.
\q1 
\v 9 عٍ شَ كَارِنيِ قِندِ سٍيدٍ حَاشِ نَن نَ عٍ شِلِ مَ.
\q1 عٍ يُنُبِ رَبَمَ كّنّ نَن مَ،
\q1 عَلْ سٌدٌ مَكَ نَشٍيٍ مُ عٍ شَ يُنُبِ نْشُن.
\q1 حَشَنكَتّ نَ عٍ بّ،
\q1 عٍ نَ فبَلٌي نَن بّندُنقٍ عٍ يّتّ مَ نَ كِ.
\b
\q1 
\v 10 وٌ عَ قَلَ تِنشِنتْي بّ، عَ نَ كِرَ قَنيِ شْن مَ،
\q1 عَ قَمَ نّ عَ شَ تِنشِنيِ سَرٍ سْتْدٍ.
\q1 
\v 11 حَشَنكَتّ نَ مِشِ حَاشِ تَن بّ،
\q1 فبَلٌي قَمَ نّ عَ لِدٍ عَ حَاشِ رَ،
\q1 عَ قَمَ نّ عَ شَ تِنشِنتَرٍيَ سَرٍ سْتْدٍ.
\b
\q1 
\v 12 دِ مّيٍ نَن نَ ﭑ مَ حَمَ حَشَنكَتَقٍ،
\q1 فِنّيٍ نَن نْي دْشْشِ عَ مَ،
\q1 مَنفّيٍ نَ عَ رَلْيقٍ كِرَ حَاشِ شْن مَ.
\q1 
\v 13 كْنْ عَلَتَلَ بَرَ عَ عِكٍلِ كِيتِسَ يِرٍ،
\q1 عَ شَ كَلَمُي تِنشِنشِ مَسٍن، عَ شَ كِيتِ سَ نْندِ رَ.
\q1 
\v 14 عَلَتَلَ نَ عَ شَ حَمَ كُنتِفِيٍ نُن عَ مَنفّيٍ مَكِيتِقٍ يِ وْيّنيِ رَ،
\q1 «وٌ بَرَ ﭑ مَ حَمَ شُن نَكَنَ.
\q1 وٌ بَرَ مِسِكِينّيٍ مُحَ.
\q1 
\v 15 وٌن ﭑ مَ حَمَ هَلَكِمَ مُنقٍ رَ؟
\q1 وٌ سٍتَرٍيٍ تْورْ مَ مُنقٍ رَ؟»
\q1 مَرِفِ عَلَتَلَ سّنبّمَ شُي نَن نَ كِ.
\b
\q1 
\v 16 عَلَتَلَ نَشّ، «سِيٌنِ فِنّيٍ قِندِشِ يّتّ عِفبٌي نَن نَ،
\q1 نَشٍيٍ عٍ حّرّ مَ عٍ شُنيِ رَكٍلِشِ،
\q1 عٍ عٍ حّرّ مّرّ مّرّ رَ عٍ سَنكْنيِ شُنمَسٍيٍ نُ عٍ شُي رَ مِنِ.
\q1 
\v 17 عَلَتَلَ قَمَ نّ سُورِ رَ مِنِدٍ عٍ شُنيِ مَ،
\q1 عَ عٍ شُنسّشّ بِرِن بَ عٍ مَ.»
\p 
\v 18 نَ لْشْي، عَلَتَلَ عٍ شَ شُنمَسٍ بِرِن بَمَ نّ عٍ يِ رَ؛ عٍ شَ سَنكْنيِ شُنمَسٍ تٌقَنيِيٍ، عٍ شَ كْنمَفٌرٍ، عٍ شَ شُنمَسٍ نَشٍيٍ مِسَالِشِ كِكٍ رَ،
\v 19 عٍ شَ تُلِرَ سٌي، عٍ شَ بّلّشّرَ سٌي، عٍ شَ مَقٍلٍنيِيٍ،
\v 20 عٍ شَ شُن مَشِرِ سٍيٍ، عٍ شَ سَنكْنيِ شُنمَسٍيٍ، عٍ شَ بّلّتِيٍ، عٍ شَ لَبُندّ سَسٍيٍ، عٍ شَ مَكَنتَسٍيٍ،
\v 21 عٍ شَ بّلّشّسٌلٍ شُرُندّيٍ، عٍ شَ حْي شُرُندّيٍ،
\v 22 عٍ شَ شُلُن دُفِيٍ، عٍ شَ دٌنمَ كُيٍيٍ، عٍ شَ دٌنمَ قَرِ عِفٌرٌي، عٍ شَ فبْنقْييٍ،
\v 23 عٍ شَ دُفِيٍ، عٍ شَ دٌنمَ بُنمَفٌرٍ، عٍ شَ شُنمَشِرِيٍ، نُن عٍ شَ مَقٍلٍنيِيٍ. عَلَتَلَ نَ بِرِن بَمَ نّ عٍ يِ رَ.
\q1 
\v 24 سٍ بْرْشِ نَن قِندِ مَ عٍ شَ لَبُندّ رَ.
\q1 لُوتِ نَن قِندِ مَ عٍ شَ بّلّتِ رَ.
\q1 عٍ شُنيِ دّنبّشِ بِمَ نّ.
\q1 بّكِ نَن قِندِ مَ عٍ شَ دُفِ رَ.
\q1 عٍ قَتٍ كِرِ تٌقَنيِ فَنمَ نّ.
\b
\q1 
\v 25 سَنتِدّفّمَ عٍ شَ مْرِيٍ قَشَمَ نّ،
\q1 عٍ شَ حَلَمَيٍ قَشَمَ فٍرٍ نَن كُي.
\q1 
\v 26 سِيٌنِ حَمَ وَ شُي مِنِمَ نّ سُننُنيِ كُي،
\q1 عَلْ كَاحّ فِنّ نَشَن دْشْ بْشِ مَ، عَ وَ.
\c 4
\s1 حَشَنكَتّ رَحْنيِ
\q1 
\v 1 نَ لْشْي فِنّ سٌلٌقٍرٍ عَ قَلَمَ نّ شّمّ كٍرٍن بّ،
\q1 «مُشُ شَ بَلٌي نُن مُشُ شَ مَشِرِ سٍيٍ شَ قِندِ مُشُ شَ كٌتٍ رَ،
\q1 كْنْ عِ تَن شَ مُشُ دْشْ، عِ شِلِ شَ لُ مُشُ شُن،
\q1 عَلَكٌ يَافِ شَ بَ مُشُ مَ.»
\b
\q1 
\v 2 نَ لْشْي عَلَتَلَ شَ سَلٌنيِ تٌقَنيِ مِنِمَ نّ عَ شَ نْرّ كُي،
\q1 عِسِرَيِلَ بْشِ شَ دَشَمُي قَنيِ شَ لُ عَ شَ مِشِيٍ بّ نَشٍيٍ كِسِشِ.
\q1 
\v 3 مِشِ نَشٍيٍ قَمَ لُدٍ سِيٌنِ نُن دَرِ سَلَمُ،
\q1 عٍ قِندِ مَ نّ سّنِيّنتْييٍ رَ نَشٍيٍ شِلِ سّبّشِ كِسِ مِشِيٍ يَ مَ.
\q1 
\v 4 مَرِفِ قَمَ نّ سِيٌنِ فِنّيٍ شَ سّنِيّنتَرٍحَ مَشَدٍ،
\q1 عَ دَرِ سَلَمُكَيٍ رَ سّنِيّن عٍ شَ قَشّ تِقٍ مَ كِيتِ تِنشِنشِ سَابُي رَ،
\q1 عَ قَ عٍ سَرٍ رَفبِلٍن عٍ مَ.
\q1 
\v 5 نَ تّمُي عَلَتَلَ قَمَ سِيٌنِ فٍيَ مَكٌتٌدٍ نُشُي نُن تُورِ نَن نَ يَنيِ رَ،
\q1 عَ تّ شُنفبٍ رَ مِنِ عٍ شُن مَ كْي رَ.
\q1 عَ شَ نْرّ نَن لُمَ سٍ بِرِن شُن مَ،
\q1 
\v 6 عَلْ بَفٍ شُنفبٍ نَشَن نِينِ مِشِ مَكَنتَمَ سٌفٍ مَ،
\q1 عَ قِندِ يِرٍ كَنتَشِ رَ تُنّ فٌرٌ تّمُي.
\c 5
\s1 عَلَتَلَ شَ سَنسِ يِرٍ
\q1 
\v 1 ﭑ شَ بّيتِ بَ ﭑ شَنُنتٍنيِ بّ،
\q1 ﭑ شَنُنتٍنيِ نَشَن بَرَ وّنِ شّ سَ.
\q1 وّنِ شّ نُ نَ ﭑ شَنُنتٍنيِ يِ رَ بْشِ تُرَشِ مَ.
\q1 
\v 2 عَ نَشَ بْشِ بُشَ، عَ فّمّيٍ مَتٌنفٌ، عَ سَنسِ قَنيِيٍ سِ عَ مَ.
\q1 عَ نَشَ تِدٍ عِتٍشِ تِ نَا تَفِ،
\q1 عَ يِلِ فٍ وّنِ بٌفِ بُندُ مَ دّننَشّ.
\q1 عَ حْشْ نُ عَ مَ عَ سَنسِ قَمَ نّ وّنِ بٌفِ رَ مِنِدٍ،
\q1 كْنْ عَ بٌفِ كَنَشِ نَن نَمِنِشِ.
\b
\q1 
\v 3 دَرِ سَلَمُكَيٍ نُن يُدَيَكَيٍ، وٌ كِيتِ ﭑ تَن نُن ﭑ مَ وّنِ شّ مَ.
\q1 
\v 4 مُنسٍ مَن لُشِ، ﭑ مُ نَشَن نَبَشِ ﭑ مَ شّ بّ؟
\q1 مُنقٍ رَ ﭑ شَشِلِ تٌ نُ تِشِ بٌفِ قَنيِ رَ، عَ قَ بٌفِ كَنَشِ رَ مِنِ ﭑ بّ؟
\q1 
\v 5 ﭑ شَ عَ قَلَ وٌ بّ ﭑ نَشَن نَبَمَ ﭑ مَ شّ رَ.
\q1 ﭑ سَنسَنيِ تَلَمَ نّ عَلَكٌ شُرُ سٍيٍ شَ عَ مَشِن.
\q1 ﭑ تّتّ بَمَ نّ عَلَكٌ عَ شَ مَبٌرٌن.
\q1 
\v 6 ﭑ عَ رَبٌلٌمَ نّ عَلَكٌ تُنبٍ نُن حٌوفٍ شَ بُلَ سَنسِ قَنيِ حْشْ رَ.
\q1 ﭑ نُشُييٍ يَمَرِ مَ، عٍ نَشَ تُنّ يٌ رَيٌلٌن عَ مَ.
\b
\q1 
\v 7 نَ وّنِ شّ مِسَالِشِ عَلَتَلَ سّنبّمَ شَ حَمَ عِسِرَيِلَ نَن نَ،
\q1 عَ مَن مِسَالِ يُدَيَ حَمَ قَن نَ.
\q1 عَلَتَلَ نُ وَ مَ تِنشِنيِ نَن شْن، كْنْ عَ قَشّ تِقٍ نَن تُن تٌ نَا.
\q1 عَ نُ وَ مَ قٍ قَنيِ نَن شْن، كْنْ عَ وَ شُي نَن تُن مّ نَا.
\b
\q1 
\v 8 حَشَنكَتّ نَ مِشِيٍ بّ، نَشٍيٍ بَنشِيٍ تِمَ عٍ قَرِ عِدْشْ،
\q1 نَشٍيٍ شّيٍ دْشْمَ عٍ بٌرٍ رَ، هَن عٍ بْشِ بِرِن تٌنفٌ،
\q1 عٍ تَن كٍرٍن فبَنسَن لُ نَا.
\q1 
\v 9 عَلَتَلَ سّنبّمَ عَ مَسٍن نّ ﭑ بّ،
\q1 «نَ بَنشِ فَلِيٍ قَمَ نّ تُشُنسَندٍ،
\q1 مِشِ مُ سَبَتِمَ نَ بَنشِ تٌقَنيِيٍ كُي قَ.
\q1 
\v 10 وّنِ شّ شُنفبٍ، بٌفِ دٌندٌرٌنتِ رَ مِنِمَ نّ.
\q1 سَنسِ شْرِ فبٍفبٍ، قِندِ مَ مَالٍ دٌندٌرٌنتِ نَن نَ.»
\b
\q1 
\v 11 حَشَنكَتّ نَ مِشِيٍ بّ نَشٍيٍ كٍلِمَ سُبَشّ مَ سِفَقٍ رَ بٍيرٍ قٍندٍ،
\q1 عٍ قَ نَ مِن هَن عٍ يَ فبٍيلِ كْي رَ.
\q1 
\v 12 عٍ كْرَيٍ، مَشَسٍيٍ، نُن سَرَيٍ رَبٍرٍ مَ عٍ شَ شُلُنيِيٍ كُي،
\q1 كْنْ عٍ مُ عَلَتَلَ شَ وَلِ تَن كٌلٌنمَ، عٍ مُ عَ بّلّشّ قْشِ تٌمَ.
\q1 
\v 13 نَ قَهَامُتَرٍحَ نَن عَ نِيَمَ عٍ شَ شَنِن كٌنيِيَ كُي حَمَنّ مَ.
\q1 عٍ شَ حَلَمَيٍ قَشَمَ نّ كَامّ رَ،
\q1 عٍ شَ مِشِيٍ تْورْ مَ نّ يٍ شْلِ مَ.
\q1 
\v 14 عَلِفِيَمَ نَادّ رَبِمَ نّ عٍ بّ،
\q1 سِيٌنِ كُنتِفِيٍ نُن عٍ شَ حَمَ شَ سٌ نَا،
\q1 عَ نُن تَا شُرُتَرٍيٍ نُن مِشِ حَاشِيٍ.
\q1 
\v 15 عَدَ مَ شَ قٍ شُن نَكَنَمَ نّ،
\q1 يّتّ عِفبٌي شَ قٍ فٌرٌ مَ نّ.
\q1 
\v 16 كْنْ عَلَتَلَ سّنبّمَ تَنتُمَ نّ عَ شَ تِنشِنيِ شَ قٍ رَ.
\q1 عَلَ سّنِيّنتْي عَ يّتّ مَسٍنمَ عَ شَ قٍ قَنيِيٍ نَن سَابُي رَ.
\q1 
\v 17 نَ تّمُي يّشّييٍ عٍ دّ مَدٌنمَ نّ نَ يِرٍ كَنَشِيٍ مَ عَلْ عٍ نَ عٍ شْنيِ نّ،
\q1 شْحّيٍ قَن بَلٌي تٌمَ نَا.
\b
\q1 
\v 18 حَشَنكَتّ نَ مِشِيٍ بّ، نَشٍيٍ يُنُبِيٍ بّندُنمَ عٍ يّتّ مَ وُلٍ رَ،
\q1 نَشٍيٍ عٍ عٍ يّتّ شِرِ مَ قٍ حَاشِيٍ رَ عَلْ كٌتٍ نَشَن شِرِ مَ سٌقَلٍ قَرِ.
\q1 
\v 19 نَ مِشِيٍ نُ قَ عَ قَلَ عٍ دّ رَ،
\q1 «عَلَتَلَ شَ عَ شُلُن عَ شَ وَلِ رَبَ رَ، عَلَكٌ مُشُ شَ عَ تٌ.
\q1 عِسِرَيِلَ مَرِفِ عَلَ سَفٌ سّنِيّنشِ شَ رَبَ، عَلَكٌ مُشُ شَ عَ كٌلٌن.»
\b
\q1 
\v 20 حَشَنكَتّ نَ مِشِيٍ بّ، نَشٍيٍ قٍ حَاشِ قِندِ مَ قٍ قَنيِ رَ،
\q1 عٍ قٍ قَنيِ قِندِ قٍ حَاشِ رَ.
\q1 عٍ دِ مِ شِلِ نَءِيَلَنيِ،
\q1 عٍ نَءِيَلَنيِ شِلِ دِ مِ.
\q1 قٍ شْنّ لُشِ نّ عَ بّ عَلْ قٍ حْشُنمّ،
\q1 قٍ حْشُنمّ لُ عٍ بّ عَلْ قٍ شْنّ.
\b
\q1 
\v 21 حَشَنكَتّ نَ مِشِيٍ بّ، نَشٍيٍ عٍ يّتّ مَحْشُنشِ قٍ كٌلٌنيِيٍ رَ،
\q1 عٍ عٍ يّتّ قِندِ شَشِلِمَيٍ رَ.
\b
\q1 
\v 22 حَشَنكَتّ نَ مِشِيٍ بّ، نَشٍيٍ شِلِ شُنفبٍ سْتْمَ بٍيرٍ مِنقٍ كُي،
\q1 عٍ قِسَ عٍ بٌورٍ بّ سِيسِ قٍ كُي.
\q1 
\v 23 عٍ نْندِ قِ قُنمَلَ مَ كْبِرِ شَ قٍ رَ،
\q1 عٍ نْندِ بَ نْندِ كَنيِ يِ رَ.
\q1 
\v 24 نَ مِشِيٍ شَ قٍ شُن نَكَنَمَ نّ عَلْ سّشّ شَرَشِ فَنمَ كِ نَشّ.
\q1 عٍ لُمَ نّ عَلْ سَنسِ نَشٍيٍ سَنكٍيٍ بْرْ مَ، عٍ قُفٍيٍ يٍنسٍن عَلْ شُبٍ،
\q1 بَرِ مَ عٍ بَرَ مّ عَلَتَلَ سّنبّمَ شَ سّرِيّ رَ،
\q1 عٍ عِسِرَيِلَ شَ سّنِيّنتْي شَ مَسٍنيِ مَبٍرٍ.
\q1 
\v 25 نَ نَن عَ رَ عَلَتَلَ بْحّ تٍشِ عَ شَ حَمَ شِلِ مَ،
\q1 عَ بّلّشّ عِتَلَشِ، عَ شَ عٍ بْنبْ.
\q1 فٍيَيٍ بَرَ سّرّن، بِنبِيٍ بَرَ يٍنسٍن تَا كُي.
\q1 هَلِ نَ بِرِن تٌ رَبَشِ، عَ شَ شْنّ مُ حْنشِ،
\q1 عَ بّلّشّ مَن عِتَلَشِ عٍ شِلِ مَ.
\b
\q1 
\v 26 عَلَتَلَ بَرَ تْنشُمَ مَسٍن حَمَنّ مَ،
\q1 عَ عٍ شِلِ عٍ شَ قَ كٍلِقٍ يِرٍ مَكُيٍ.
\q1 
\v 27 مِشِ تَفَنشِ يٌ مُ نَ عٍ يَ مَ،
\q1 مِشِ يٌ سَنيِيٍ مُ بِنيَشِ عَ بُن مَ،
\q1 مِشِ يٌ مُ كِنسْنقٍ عَ شَ شِ،
\q1 مِشِ يٌ شَ بّلّتِ مُ قُلُنشِ عَ تَفِ،
\q1 مِشِ يٌ شَ سَنكِرِ لُوتِ مُ بٌلٌنشِ.
\q1 
\v 28 نَ مِشِيٍ شَ شَلِيٍ حْييٍ رَشَحّنشِ،
\q1 عٍ شَ تَنبّ وٌلِ سٍيٍ بِرِن عِتَلَشِ عَ قَنيِ رَ،
\q1 عٍ شَ سٌي تٌرٍيٍ شْرْشْ عَلْ فّمّ،
\q1 عٍ شَ سْورِ رَفِسٍ سَنيِيٍ شُي فبٌ عَلْ تُرُننَادّ.
\q1 
\v 29 عٍ حَرَندَن عَلْ يّتّ نَشَن سُبٍ سُشُمَ،
\q1 عَ عَ شَنِن يِرٍ مَكُيٍ.
\q1 
\v 30 نَ لْشْي عٍ حَرَندَنيِ مّمَ نّ عَلْ بَا مْرْنيِيٍ،
\q1 تْورّ نَن تُن تٌمَ بْشِ مَ،
\q1 نَءِيَلَنيِ قِندِ مَ دِ مِ نَن نَ،
\q1 نُشُي عِقْورْشِيٍ لُ كٌورٍ مَ.
\c 6
\s1 عٍسَيِ قِندِقٍ عَلَ شَ شّيرَ رَ
\p 
\v 1 مَنفّ عٌسِيَسِ قَشَ حّ نَشَن نَ، ﭑ نَشَ ﭑ مَرِفِ عَلَ تٌ عَ شَ كِبَنيِ عِتٍشِ كُي. عَ شَ نْرّ نُ فبٌ، عَ شَ دٌنمَ شُنفبٍ نُ عِتَلَشِ عَ شَ هْرْ مْلِنفِرَ كُي.
\v 2 مَلٍكّيٍ نُ نَ عَ شُن مَ. فَبُتٍنيِ سٍننِ نُ نَ كَنكَن بّ؛ فَبُتٍنيِ قِرِن نُ عٍ يَتَفِ مَكٌتٌشِ، قِرِن نُ عٍ سَنيِيٍ مَكٌتٌشِ، قِرِن نَن نُ عَ نِيَمَ عٍ شَ حّرّ كٌورٍ مَ.
\v 3 عٍ نُ قَ عَ قَلَ عٍ بٌورٍ بّ عٍ شُي عِتٍشِ رَ،
\q1 عَلَتَلَ سّنبّمَ سّنِيّن هَن!
\q1 عَ شَ نْرّ دُنِحَ بِرِن لِمَ نّ!
\m 
\v 4 عٍ شُي نُ هْرْ مْبَنشِ نَادّيٍ رَ سّرّنمَ، بَنشِ قَ رَقٍ تُورِ رَ.
\p 
\v 5 نَ كُي ﭑ نَشَ فبٍلٍفبٍلٍ، «حَشَنكَتّ نَ ﭑ بّ، بَرِ مَ ﭑ قِندِشِ عَدَ مَدِ سّنِيّنتَرٍ نَن نَ، نَشَن سَبَتِشِ حَمَ سّنِيّنتَرٍ يَ مَ. ﭑ يَيٍ نَ ﭑ مَرِفِ عَلَ سّنبّمَ تٌ، ﭑ قَشَمَ نّ!»
\p 
\v 6 نَ تّمُي نَ مَلٍكّ كٍرٍن نَشَ تُفَن، عَ قَ ﭑ يِرٍ، تّ وٌلٍ كٍرٍن نَ عَ يِ رَ عَ نُ بَرَ نَشَن تٌنفٌ سّرّشّبَدٍ كُي.
\v 7 عَ نَشَ عَ دْشْ ﭑ دّ رَ عَ قَ عَ قَلَ، «يِ تٌ بَرَ دِن عِ دّ رَ، عِ شَ تِنشِنتَرٍيَ بَرَ بَ، عِ شَ يُنُبِ بَرَ شَقَرِ.»
\p 
\v 8 ﭑ نَشَ ﭑ مَرِفِ شُي مّ عَ مَسٍن نَ، «ﭑ نَ ﭑ ندٍ شّيمَ؟ ندٍ سِفَمَ شّيرَ عِبَدٍ مُشُ بّ؟» ﭑ نَشَ عَ يَابِ، «ﭑ تَن نَن يَ. عِ شَ ﭑ تَن شّي.»
\v 9 عَوَ، عَ نَشَ عَ قَلَ ﭑ بّ،
\q1 «سَ عَ قَلَ يِ حَمَ بّ،
\q1 ‹وٌ وٌ تُلِ مَتِمَ ﭑ نَ، كْنْ وٌ مُ قَهَامُي سْتْ؟
\q1 وٌ قٍ مَتٌمَ، كْنْ وٌ مُ عَ كُي كٌلٌن؟›
\q1 
\v 10 عِ شَ يِ حَمَ شَشِلِ رَشْرْشْ،
\q1 عِ شَ عٍ تُلِ دّ سّ، عِ شَ عٍ يَ رَفَلِ.
\q1 عٍ يَ نُ نْمَ تٌ تِدٍ،
\q1 عٍ تُلِ نُ نْمَ قٍ مّدٍ،
\q1 عٍ شَشِلِ نُ نْمَ قَهَامُي سْتْدٍ،
\q1 عٍ قَ تُوبِ، عٍ كِسِ.»
\p 
\v 11 ﭑ نَشَ عَ مَشْرِن، «ﭑ مَرِفِ، نَ بُمَ هَن تّمُي مُندُن؟» عَ نَشَ ﭑ يَابِ،
\q1 «هَن عٍ شَ تَايٍ نَ فّ كَنَدٍ،
\q1 مِشِيٍ شَ حْن نَا، عٍ شَ بَنشِ شَ بِرَ، عٍ شَ شّيٍ شَ فَن.
\q1 
\v 12 هَن عَلَتَلَ نَ فّ حَمَ شَنِندٍ يِرٍ مَكُيٍ،
\q1 عٍ شَ بْشِ قَ رَبّحِن.
\q1 
\v 13 هَلِ مِشِ ندٍيٍ قَ كِسِ نَا،
\q1 فبَلٌي مَن قَمَ نّ دِندٍ نَا رَ.»
\b
\q1 «كْنْ وُرِ بِلِ شُنفبٍ نَ سّفّ،
\q1 عَ سَنكٍ سّنِيّنشِ لُمَ نّ بْشِ بُن مَ.»
\c 7
\s1 عَلَتَلَ شَ مَسٍنيِ مَنفّ عَشَسِ بّ
\p 
\v 1 يُدَيَ مَنفّ عَشَسِ شَ وَشَتِ، نَشَن قِندِشِ يٌتَمِ شَ دِ نُن عٌسِيَسِ شَ مَمَدِ رَ، عَرَ مِ مَنفّ رٍ سِن نُن عِسِرَيِلَ مَنفّ ثٍكَ، رٍ مَلِيَهُ شَ دِ، عٍ نَشَ سِفَ دَرِ سَلَمُ فٍرٍدٍ، كْنْ عٍ مُ نْ عَ رَ.
\p 
\v 2 دَوُدَ بْنسْي مِشِيٍ تٌ عَ كٌلٌن عَ عَرَ مِكَيٍ بَرَ لَنيِ شِرِ عٍقِرَ مِ بْنسْي رَ، مَنفّ عَشَسِ نُن عَ شَ حَمَ نَشَ سّرّن فَاشُي كُي، عَلْ قٌيٍ وُرِ بِلِيٍ رَ مَشَمَ كِ نَشّ.
\v 3 نَ تّمُي عَلَتَلَ نَشَ عَ مَسٍن عَننَبِ عٍسَيِ بّ، «عِ تَن نُن عِ شَ دِ سٍيَرَ يَسُبُ، وٌ شَ سِفَ مَنفّ عَشَسِ نَرَلَندٍ يٍ رَفَتَدٍ شُنفبٍ شَنبِ رَ، كِرَ نَشَن سِفَمَ دُفِ شَمَ دّننَشّ.
\v 4 عَ قَلَ عَ بّ، ‹عِ نَشَ كْنتْقِلِ. عِ شَ لِمَنِيَ. هَلِ عِ مُ فَاشُ يِ مِشِ قِرِنيِ رَ، نَشٍيٍ لُمَ عَلْ تّ شُبٍنشِ نَشَن تُورِ تُن رَ مِنِمَ. عِ نَشَ فَاشُ عَرَ مِ مَنفّ رٍ سِن نُن رٍ مَلِيَهُ بْنسْي يَ رَ.
\v 5 عَرَ مِكَيٍ، نُن رٍ مَلِيَهُ شَ مِشِيٍ عٍقِرَ مِكَيٍ بَرَ يَنقَنتٍيَ نَن شِرِ عِ شُن مَ نَ كِ، عَ قَلَقٍ رَ،
\v 6 «وٌن شَ يُدَيَ فٍرٍ، وٌن شَ عَ يَ عِسٌ، وٌن شَ نْ عَ رَ، تَبٍيلِ شَ قِندِ عٍ شَ مَنفّ رَ.»›»
\p 
\v 7 كْنْ عَلَتَلَ شَ مَسٍنيِ نَن يَ نَ شَ قٍ رَ،
\q1 «نَ مُ سْونّيَمَ، ﭑ مُ نَ رَبَمَ قٍوٌ،
\q1 
\v 8 بَرِ مَ دَ مَسِ مَنفّ رٍ سِن نَن عَرَ مِ يَمَرِ مَ.
\q1 حّ تٌنفٌ سٍننِ نُن سُولِ فبَنسَن نَن لُشِ،
\q1 عٍقِرَ مِ بْنسْي شَ يٍنسٍن.
\q1 
\v 9 سَمَرِ مَنفّ رٍ مَلِيَهُ نَن عٍقِرَ مِ يَمَرِ مَ.
\q1 شَ وٌ مُ وٌ يّتّ تَشُ وٌ مَرِفِ عَلَ رَ،
\q1 وٌ مُ كِسِمَ.»
\p 
\v 10 عَلَتَلَ نَشَ يِ مَسٍنيِ قَن تِ عَشَسِ بّ، عَ نَشّ،
\v 11 «عِ شَ ﭑ تَن عِ مَرِفِ عَلَتَلَ مَشَندِ تْنشُمَ مَ ﭑ مَ مَسٍنيِ شَ قٍ رَ.»
\v 12 عَشَسِ نَشَ عَ يَابِ، «ﭑ مُ سٍسٍ مَشَندِ مَ عِ مَ، بَرِ مَ ﭑ مُ وَ مَ عِ تَن عَلَتَلَ مَتٌقٍ سِيكّ كُي.»
\p 
\v 13 نَ كُي عَننَبِ عٍسَيِ نَشَ عَ قَلَ، «دَوُدَ بْنسْي، وٌ لُمَ مِشِيٍ رَتَفَن نَ، كْنْ يَكْسِ وٌ وَ مَ عَلَتَلَ نَن قَن نَتَفَنقٍ؟
\v 14 عَلَتَلَ يّتّ يَتِ قَمَ نّ تْنشُمَ ندٍ قِدٍ وٌ مَ؛ فِنّ دِ مّدِ ندٍ قَمَ تّفّدٍ، عَ دِ بَرِ، عَ نَ دِ شِلِ سَ عٍمَنُوّلِ، نَشَن قَسَرِشِ، ‹عَلَ نَ وٌن يَ مَ.›
\v 15 عَ شِحّ قّنّ نُن كُمِ نَن دٌنمَ هَن عَ مْ، عَ نْ قٍ كٌبِ نُن قٍ قَنيِ تَفِ رَبَ كٌلٌندٍ.
\v 16 كْنْ بٍينُن عَ شَ نَ سِمَيَ سْتْ، نَ مَنفّ قِرِنيِ عِ فَاشُشِ نَشٍيٍ رَ، نٍيٍ شَ بْشِيٍ قَمَ نّ كَنَدٍ.
\v 17 نَ تّمُي عَلَتَلَ قَمَ نّ فبَلٌي ندٍ رَ وٌ شُن مَ نَشَن مُ كٌلٌنشِ وٌ نُن وٌ بَبَيٍ شَ وَشَتِ كَقِ عٍقِرَ مِ عَ مَكُيَشِ يُدَيَ رَ تّمُي نَشّ. عَلَتَلَ عَسِرِيَ مَنفّ نَن شّيمَ وٌ يِرٍ.»
\p 
\v 18 نَ لْشْي، عَلَتَلَ شّيرِيٍ رَقَمَ نّ كٍلِقٍ مِسِرَ شُرٍيٍ مَ، عَ نُن كُمِيٍ كٍلِقٍ عَسِرِيَ بْشِ مَ.
\v 19 عٍ قَمَ نّ لُدٍ قٌلٍيٍ كُي، فّمّ لٌنفٌرِيٍ رَ، كُنسِيٍ قَرِ، نُن يٍ يِرٍيٍ.
\v 20 نَ لْشْي مَرِفِ قَمَ نّ عَسِرِيَ مَنفّ رَ كٍلِقٍ شُرٍ شُنفبٍ نَاكِرِ مَ، عَ شَ وٌ رَيَافِ عَ حَاشِ رَ، عَلْ مِشِ نَشَن قَتٍ مَشَبٍ بِرِن مَبِمَ.
\v 21 نَ لْشْي، مِشِ قَمَ نِنفٍ كٍرٍن نُن سِ قِرِن نَن فبَنسَن سْتْدٍ،
\v 22 عٍ شِحّ قّنّ سْتْمَ نَشَن نَ. عٍ لُمَ نَ نُن كُمِ فبَنسَن نَن دٌن نَ.
\v 23 نَ لْشْي، وّنِ بِلِ وُلُ كٍرٍن نُ نَ شّ نَشَن مَ، نَشَن سَرٍ نُ فبٍتِ كٌلٍ وُلُ كٍرٍن لِمَ، نَا قِندِ مَ نّ تُنبٍ نُن بَافِ يِرٍ رَ،
\v 24 كٌيِنمَيٍ شَلِيٍ وٌلِمَ دّننَشّ.
\v 25 شّيٍ نُ سَمَ فٍيَ نَشٍيٍ قَرِ، تُنبٍ نُن بَافِ دِنمَ نّ نَا رَ، مِشِ يٌ مُ سُو سَ سِفَدٍ نَا سْنْن. نَا قِندِ مَ شُرُ سٍيٍ مَدٌندٍ نَن فبَنسَن نَ.
\c 8
\s1 عَننَبِ عٍسَيِ شَ دِ شِلِ سَقٍ
\p 
\v 1 عَلَتَلَ نَشَ عَ مَسٍن ﭑ بّ، عَ نَشّ، «عِ شَ كّيدِ تٌنفٌ، عَ سّبّ كَلٍ رَ، ‹مَهٍرِ سَلَلِ هَسِ بَسِ،› نَشَن قَسَرِشِ ‹كَسَرّ تِ، سٍ بِرِن شَنِنمَ مَقُرٍن مَقُرٍن.›
\v 2 عِ شَ سّرّشّدُبّ عُرِ نُن يٍبٍرٍكِيَ شَ دِ سَكَرِ شِلِ سٍيدٍيٍ رَ ﭑ بّ.»
\p 
\v 3 نَ تّمُي، ﭑ نَشَ ﭑ مَسٌ ﭑ مَ فِنّ رَ، عَ نَشَ تّفّ عَ دِ بَرِ. عَلَتَلَ نَشَ عَ مَسٍن ﭑ بّ، «عَ شِلِ سَ، ‹مَهٍرِ سَلَلِ هَسِ بَسِ.›
\v 4 بٍينُن نَ دِ شَ مْ، عَ قَ نْ عَ قَلَدٍ، ‹ﭑ نفَ، ﭑ بَ،› عَسِرِيَ مَنفّ قَمَ نّ نَاقُلِ شَنِندٍ عَ نَشَن تٌمَ دَ مَسِ تَا كُي نُن سَمَرِ بْشِ مَ.»
\p 
\v 5 عَلَتَلَ مَن نَشَ عَ مَسٍن ﭑ بّ، عَ نَشّ،
\q1 
\v 6 «يِ حَمَ تٌ بَرَ سِلٌوَ شُرٍ شَ بَرَكَ بّحِن،
\q1 عَلَ نَشَن قِشِ عٍ مَ،
\q1 عٍ قَ بِرَ رٍ سِن نُن رٍ مَلِيَهُ شَ دِ شَ قٍ قْشْ رَ،
\q1 
\v 7 ﭑ تَن عَلَتَلَ قَمَ نّ بَنبَرَنيِ شُنفبٍ رَ عٍ شِلِ مَ،
\q1 نَشَن قِندِ عَسِرِيَ مَنفّ يّتّ عِفبٌي رَ.
\q1 عَ سّنبّ لُمَ نّ عَلْ بَنبَرَنيِ نَشَن كٍلِمَ شُرٍ،
\q1 عَ قَ دَنفِ بْشِ بِرِن مَ،
\q1 
\v 8 عَ دِن يُدَيَ رَ، عَ تٍ هَن عَ فبٍ مُ نُ لُشِ مّننِكَيٍ قَن شَ مَدُلَ.
\q1 عٍمَنُوّلِ، نَ قَمَ نّ وٌ شَ بْشِ بِرِن شُن نَكَنَدٍ.»
\b
\q1 
\v 9 «وٌ تَن حَمَنّ نَشٍيٍ نَ دُنِحَ،
\q1 وٌ فٍرٍ شُي رَتٍ، كْنْ وٌ شُن نَكَنَمَ نّ.
\q1 وٌ وٌ يّتّ يَءِلَن فٍرٍ شِلِ مَ، كْنْ وٌ قَشَمَ نّ.
\q1 وٌ شَ تِ فٍرٍ كِ مَ، كْنْ وٌ بِرَ مَ نّ.
\q1 
\v 10 وٌ نَتّيٍ تٌنفٌ، كْنْ عَ مُ سْونّيَمَ.
\q1 وٌ لَنيِ شِرِ وٌ بٌورٍ تَفِ، كْنْ وٌ مُ تِمَ نّ،
\q1 بَرِ مَ عَلَ نَ مُشُ يَ مَ.»
\p 
\v 11 عَلَتَلَ نَشَ ﭑ نَسِ سّنبّ رَ، عَ قَلَقٍ رَ ﭑ بّ، عَ ﭑ نَشَ بِرَ يِ حَمَ حّرّ كِ كٌبِ قْشْ رَ. عَ نَشّ،
\q1 
\v 12 «عِ نَشَ يَنقَنتٍيَ شِلِ قَلَ قٍ مَ، يِ حَمَ عَ قَلَمَ قٍ نَشَن مَ يَنقَنتٍيَ.
\q1 عِ نَشَ فَاشُ قٍ يَ رَ، يِ حَمَ فَاشُمَ قٍ نَشَن يَ رَ.
\q1 
\v 13 عِ شَ مَنفّ عَلَتَلَ نَن كٌلٌن سّنِيّنتْي رَ،
\q1 عِ شَ شَنمّ عَ تَن نَن شَ قٍ رَ،
\q1 عِ شَ فَاشُ عَ تَن نَن يَ رَ.
\q1 
\v 14 نَ كُي عَ قِندِ مَ نّ وٌ بّ يِرٍ سّنِيّنشِ رَ.
\q1 كْنْ عِسِرَيِلَ بْنسْي قِرِنيِيٍ بّ،
\q1 عَ قِندِ مَ نّ فّمّ رَ عٍ دِنمَ نَشَن نَ، عٍ قَ بِرَ،
\q1 عَ قِندِ مَ نّ فَنتَنيِ رَ دَرِ سَلَمُكَيٍ بّ.
\q1 
\v 15 مِشِ فبٍفبٍ عٍ سَنيِ رَدِنمَ نّ عَ رَ،
\q1 عٍ بِرَ، عٍ عٍ مَشْنْ، عٍ شَنِن كٌنيِيَ كُي.»
\p 
\v 16 يِ سٍيدٍحْشْيَ نَشَن سّبّشِ، وٌ شَ تْنشُمَ سَ عَ مَ، وٌ شَ عَ رَفَتَ ﭑ مَ قْشِرَبِرّيٍ يِرٍ.
\v 17 ﭑ تَن شَشِلِ تِشِ عَلَتَلَ رَ، نَشَن عَ كٌبٍ سٌشِ يَشُبَ بْنسْي رَ سِندٍن. ﭑ بَرَ ﭑ مَ لَنلَنتٍيَ سَ عَ مَ.
\v 18 ﭑ تَن نُن ﭑ مَ دِيٍ، عَلَتَلَ نَشٍيٍ قِشِ ﭑ مَ، مُشُ قِندِشِ تْنشُمَيٍ نَن نَ عِسِرَيِلَ بْشِ مَ مَنفّ عَلَتَلَ بّ، نَشَن سَبَتِشِ سِيٌنِ فٍيَ قَرِ.
\p 
\v 19 مِشِ ندٍيٍ عَ قَلَمَ وٌ بّ، وٌ شَ سِفَ كَرَ مْشْييٍ يِرٍ، نَشٍيٍ مِشِ قَشَشِيٍ رَوْيّنمَ مَكْيِكْيِ رَ، وٌ شَ فُندٌ كٌلٌن. كْنْ عَ مُ لَنمَ مِشِيٍ شَ عٍ شَ مَشْرِنيِيٍ تِ عٍ مَرِفِ عَلَ تَن مَ؟ عَ لَنمَ مِشِ بَلٌشِ شَ مَشْرِنيِ تِ مِشِ قَشَشِ مَ؟
\v 20 وٌن شَ وٌن تُلِ مَتِ عَلَ شَ سّرِيّ رَ عَ سٍيدٍحْشْيَ قِشِ نَشَن مَ. شَ نَ مُ عَ رَ، حَمَ لُمَ دِ مِ نَن تُن كُي،
\v 21 عٍ بْشِ عِفِرِ مَ كَامّ نُن كْنتْقِلِ نَن نَ. كَامّ نَ شْرْشْ عٍ مَ تّمُي نَشّ، عٍ عٍ يَ رَتٍمَ نّ كٌورٍ مَ، عٍ عٍ شَ مَنفّ نُن عٍ مَرِفِ عَلَ دَنكَ.
\v 22 عٍ نَ فّ نَ رَبَدٍ، عٍ قَ عٍ يَ رَفٌرٌ دُنِحَ مَ، عٍ مُ سٍسٍ تٌمَ قٌ تْورّ، دِ مِ، نُن بْحّسَتَرٍيَ.
\p 
\v 23 كْنْ نَ دِ مِ مُ لُمَ بْشِ مَ عَبَدَن، تْورّ مُ نْمَ نَ حَمَ رَ. سَبُلٌن نُن نَقَتَلِ بْشِ هَلَكِ نّ تّمُي دَنفِشِ، كْنْ نَ بْشِ نَشَن شِلِ قَلَمَ «حَمَنّ شَ فَلِلٍ،» نَ قَمَ نّ نْرْدٍ كٍلِقٍ بَا دّ رَ، هَن يُرُدّن نَاكِرِ مَ.
\c 9
\s1 دِ نَشَن قِندِ مَ مَنفّ رَ
\q1 
\v 1 حَمَ نَشَن نُ نَ عَ حّرّقٍ دِ مِ كُي،
\q1 عٍ بَرَ نَءِيَلَنيِ شُنفبٍ تٌ.
\q1 تْورّ شَ نْي نُ نَ نَشٍيٍ قَرِ،
\q1 نَءِيَلَنيِ شُنفبٍ بَرَ يَنبَ عٍ مَ.
\q1 
\v 2 عَلَتَلَ، عِ بَرَ نَ حَمَ شُن نَكٍلِ،
\q1 عِ بَرَ سّيوّ شُنفبٍ قِ عٍ مَ.
\q1 عٍ سّيوَشِ عِ يَ رَ
\q1 عَلْ مِشِيٍ سّيوَ مَ سَنسِ شَبَ تّمُي كِ نَشّ،
\q1 عَلْ مِشِيٍ سّيوَ مَ هَرِفٍ سْتْقٍ رَ كِ نَشّ.
\b
\q1 
\v 3 عٍ سّيوَشِ بَرِ مَ كٌتٍ بِنيٍ نَشَن نُ دّتّنشِ عٍ مَ،
\q1 عِ بَرَ نَ بَ نَا،
\q1 لُشُسِنيِ نَشَن نُ عٍ بْنبْمَ عٍ قَرِ مَ،
\q1 عِ بَرَ نَ كَنَ عَلْ عِ مَدِيَنكَيٍ رَبِرَ تّمُي نَشّ.
\q1 
\v 4 عٍ يَشُييٍ شَ سَنكِرِ نَشٍيٍ نُ عٍ مَبٌرٌنمَ،
\q1 عٍ دٌنمَ نَشٍيٍ نْشْشِ وُلِ رَ،
\q1 نٍيٍ بِرِن بَرَ وْلّ تّ شْورَ، عٍ فَن قٍوٌ.
\q1 
\v 5 بَرِ مَ عَلَ بَرَ عَ نِيَ وٌن شَ دِ ندٍ سْتْ،
\q1 عَ مَنفّيَ قِشِ نَشَن مَ.
\q1 نَ دِ قَمَ شِلِدٍ يِ كِ نّ؛
\q1 مَرَ سِمَ قِسَمَنتٍ، عَلَ سّنبّمَ،
\q1 بَبَ نَشَن بُمَ عَبَدَن، بْحّسَ مَنفّ.
\q1 
\v 6 عَ شَ مَنفّيَ نُن عَ شَ بْحّسَ مُ حْنمَ.
\q1 عَ دْشْمَ نّ دَوُدَ شَ كِبَنيِ كُي عَبَدَن.
\q1 عَ نَ مَنفّيَ رَبَمَ تِنشِنيِ نُن نْندِ نَن نَ،
\q1 كٍلِقٍ يَكْسِ مَ هَن دَن مُ نَشَن مَ.
\q1 مَنفّ عَلَتَلَ قَمَ نَ نَن نَبَدٍ،
\q1 بَرِ مَ عَ مُ وَ مَ عَ قِرِن ندٍ شْن.
\b
\q1 
\v 7 مَرِفِ نُ بَرَ كِيتِ حَاشِ سَ يَشُبَ بْنسْي مَ،
\q1 عَ نَشَن دْشْ عِسِرَيِلَ مَ.
\q1 
\v 8 عٍقِرَ مِكَيٍ نُن سَمَرِكَيٍ نُ بَرَ نَ كٌلٌن،
\q1 كْنْ عٍ نَشَ عَ قَلَ عٍ شَ يّتّ عِفبٌيَ كُي،
\q1 
\v 9 «بِرِكِ بَنشِ بَرَ بِرَ، كْنْ مُشُ قَمَ عَ تِدٍ فّمّ مَسٌلِشِيٍ نَن نَ.
\q1 سِكٌمٌرٌ بِلِيٍ بَرَ سّفّ، كْنْ مُشُ قَمَ سّدِرِ بِلِيٍ سِدٍ عٍ حْشْي رَ.»
\q1 
\v 10 نَ وْيّنيِ مَ عَلَتَلَ قَمَ نّ رٍ سِن يَشُييٍ رَفٍينِدٍ عٍ شِلِ مَ،
\q1 
\v 11 عَ قَمَ نّ عَرَ مِكَيٍ رَ كٍلِقٍ سٌفٍتٍدٍ،
\q1 عَ قَ قِلِسِتَكَيٍ قَن نَ كٍلِ سٌفٍفٌرٌدٍ،
\q1 عَلَكٌ عٍ شَ عِسِرَيِلَكَيٍ سْنتْ عَ حَاشِ رَ.
\q1 هَلِ نَ بِرِن تٌ رَبَ،
\q1 عَلَتَلَ شَ شْنّ مُ فبِلٍنشِ عٍ قْشْ رَ،
\q1 عَ بّلّشّ مَن عِتٍشِ عٍ شِلِ مَ،
\q1 
\v 12 بَرِ مَ حَمَ تَن تٌندِ نّ عَ يّتّ رَفبِلٍندٍ عَ بْنبْمَ مَ،
\q1 عٍ مُ مَنفّ عَلَتَلَ قٍن.
\q1 
\v 13 نَ كُي عَلَتَلَ عِسِرَيِلَ شُنيِ نُن عَ شُلِ بٌلٌنمَ نّ،
\q1 عَ تُفِ بِلِ نُن كَلٍ شُنشُرِ رَبِرَ مَ نّ.
\q1 
\v 14 عِسِرَيِلَ شُنيِ نَ عَ شَ يَرٍرَتِيٍ نَن نَ،
\q1 عَ شُلِ نَ عَ شَ نَمِحْنمّ وُلٍ قَلّيٍ نَن نَ.
\q1 
\v 15 نَ يَرٍرَتِيٍ بَرَ حَمَ رَلْي، عٍ بَرَ عٍ عِقُ.
\q1 
\v 16 نَ نَن عَ رَ، عَلَتَلَ مُ حّلّشِنمَ عٍ شَ قٌنِكٍيٍ رَ،
\q1 عَ مُ كِنِكِنِمَ عٍ شَ كِرِدِيٍ نُن كَاحّ فِنّيٍ مَ،
\q1 بَرِ مَ عٍ بِرِن يُنُبِ حَاشِيٍ رَبَمَ،
\q1 وْيّن كٌبِيٍ نَن تُن مِنِمَ عٍ دّ عِ.
\b
\q1 
\v 17 فبَلٌي نَ قَقٍ عٍ مَ عَلْ تّ نَشَن نَ قِلِ مَ،
\q1 عَ قَ حٌوفٍ حَاشِ نُن تُنبٍ بِرِن فَن، تُورِ قَ تٍ كٌورٍ مَ.
\q1 
\v 18 مَنفّ عَلَتَلَ شَ شْنّ بَرَ دُنِحَ رَ سّرّن،
\q1 عَدَ مَدِيٍ بَرَ لُ عَلْ تّ نَشٍيٍ عٍ بٌورٍ فَن، مِشِ يٌ مُ كِسِ.
\q1 
\v 19 عٍ بَرَ عٍ بٌورٍ مُحَ نَشَن نُ نَ عٍ يِرٍقَنيِ مَ،
\q1 كْنْ عٍ نَشَ لُ كَامّ كُي.
\q1 عٍ بَرَ ندٍ مُحَ نَشَن نُ نَ عٍ كْولَ مَ،
\q1 كْنْ عٍ مُ وَ سَ، كَنكَن نَشَ دِن عَ بٌورٍ رَ.
\q1 
\v 20 مَنَسِكَيٍ بَرَ عٍقِرَ مِكَيٍ تْورْ،
\q1 عٍقِرَ مِكَيٍ بَرَ مَنَسِكَيٍ تْورْ،
\q1 عٍ قِرِن بَرَ دِن يُدَيَ رَ.
\b
\q1 هَلِ نَ بِرِن تٌ رَبَ،
\q1 عَلَتَلَ شَ شْنّ مُ فبِلٍنشِ عٍ قْشْ رَ،
\q1 عَ بّلّشّ مَن عِتٍشِ عٍ شِلِ مَ.
\c 10
\s1 عَلَتَلَ شْنْقٍ يَرٍرَتِ حَاشِيٍ مَ
\q1 
\v 1 حَشَنكَتّ نَ يَرٍرَتِيٍ بّ،
\q1 نَشٍيٍ يَامَرِ حَاشِيٍ سّبّمَ، نَشٍيٍ تْوحّفّ تِمَ،
\q1 
\v 2 عَلَكٌ عٍ شَ مِسِكِينّ تْورْ كِيتِ حَاشِ رَ،
\q1 عٍ تِنشِنتَرٍيَ رَبَ سٍتَرٍيٍ رَ نَشَن بَلٌي بَمَ كَاحّ فِنّيٍ نُن كِرِدِيٍ يِ رَ.
\q1 
\v 3 وٌ مُنسٍ رَبَمَ دّنتّفّ سَ لْشْي عَلَتَلَ يَ عِ؟
\q1 وٌ وٌ شَشِلِ تِمَ ندٍ رَ عَلَكٌ وٌ شَ رَتَنفَ؟
\q1 
\v 4 وٌ بِرَ مَ نّ فٍيلِمَنِيٍ بُن مَ،
\q1 وٌ بْنْ مِشِ قَشَشِيٍ يَ مَ.
\q1 هَلِ نَ بِرِن تٌ رَبَمَ،
\q1 عَلَتَلَ شَ شْنّ مُ فبِلٍنمَ وٌ قْشْ رَ،
\q1 عَ بّلّشّ مَن عِتٍمَ نّ وٌ شِلِ مَ.
\s1 عَسِرِيَ شَ حَشَنكَتّ
\q1 
\v 5 حَشَنكَتّ نَ عَسِرِيَ بّ،
\q1 نَشَن قِندِشِ ﭑ مَ وُرِ بْنبْ تِ سٍ رَ ﭑ مَ شْنّ كُي.
\q1 ﭑ مَ فبٍندٍفٍلَ نَ عَ رَ.
\q1 
\v 6 ﭑ عٍ تَن نَن شّيمَ حَمَنّ مُرُتَشِ شِلِ مَ،
\q1 ﭑ عٍ تَن نَن نَسِفَمَ حَمَ شِلِ مَ، نَشَن ﭑ نَشْنْشِ،
\q1 عَلَكٌ عٍ شَ نَاقُلِ بَ نَ حَمَ يِ رَ،
\q1 عٍ قَ عٍ مَبٌرٌن تَا كُي عَلْ بٌورَ.
\b
\q1 
\v 7 كْنْ عَسِرِيَكَيٍ شَ نَتّ تَن نُ نَ قٍ فبّتّ نَن مَ.
\q1 عٍ نُ بَرَ نَتّ تٌنفٌ عٍ شَ عٍ شُن نَكَنَ كٍرٍنيِ رَ،
\q1 عَلْ عٍ لُمَ عَ رَبَ رَ دُنِحَ مَ كِ نَشّ.
\q1 
\v 8 عٍ شَ مَنفّ نَشّ، «ﭑ مَ سْورِ يَرٍرَتِيٍ بِرِن مُ قِندِشِ مَنفّيٍ شَ رَ؟
\q1 
\v 9 كَلَنٌ تَا مُ سْنتْ شّ عَلْ كَرَكٍمِسِ؟
\q1 شَمَتَ قَن مُ قَشَ شّ عَلْ عَرَثَدِ؟
\q1 سَمَرِ مُ كَنَ شّ عَلْ دَ مَسِ؟
\q1 
\v 10 شَ ﭑ بَرَ نْ نَ بْشِيٍ رَ عَ نُن عٍ شَ كُيٍيٍ،
\q1 كُيٍ نَشٍيٍ سّنبّ فبٌ دَرِ سَلَمُ نُن سَمَرِ فبٍيٍ بّ،
\q1 
\v 11 ﭑ مُ نَ مْولِ رَبَمَ شّ دَرِ سَلَمُ قَن نُن عَ شَ كُيٍيٍ رَ؟
\q1 ﭑ نَشَن نَبَشِ سَمَرِ نُن عَ شَ كُيٍ رَ،
\q1 ﭑ مُ نْمَ شّ نَ قَن نَبَدٍ دَرِ سَلَمُ رَ شّ؟»
\p 
\v 12 «كْنْ ﭑ تَن عَلَتَلَ نَ فّ ﭑ مَ وَلِ بِرِن نَكَمَلِدٍ سِيٌنِ فٍيَ قَرِ نُن دَرِ سَلَمُ، ﭑ قَمَ نّ ﭑ يَ رَقِندِدٍ عَسِرِيَ مَنفّ مَ، ﭑ عَ شَ يّتّ عِفبٌيَ سَرٍ رَفبِلٍن عَ مَ،
\v 13 بَرِ مَ عَ لُمَ عَ قَلَ رَ،
\q1 ‹ﭑ بَرَ يِ بِرِن نَبَ ﭑ يّتّ سّنبّ رَ،
\q1 ﭑ مَ قَهَامُي نَن عَ نِيَ دُنِحَ بْشِ بِرِن شَ لُ ﭑ يِ رَ،
\q1 ﭑ بَرَ سِيٍ شَ نَاقُلِ تٌنفٌ ﭑ يّتّ بّ،
\q1 ﭑ بَرَ نْ مَنفّ بِرِن نَ، ﭑ قِندِشِ مَنفّ سّنبّمَ نَن نَ.
\q1 
\v 14 ﭑ بَرَ ﭑ بّلّشّ عِتَلَ سِيٍ شَ بَننَيَ تَفِ،
\q1 ﭑ قَ نَاقُلِ تٌنفٌ عَلْ مِشِ شْنِ شّلّيٍ بَمَ عَ تّي كُي كِ نَشّ.
\q1 مِشِ يٌ مُ نْ تْنيِ دْشْدٍ ﭑ مَ.›»
\b
\q1 
\v 15 «بٍرَ كٌلٍ عَ يّتّ مَتْشْمَ عَ رَوَلِمَ بّ؟
\q1 سّرَ عَ يّتّ مَتْشْمَ كَمُدّرِ بّ؟
\q1 بْنبْ وُرِ نْمَ مِشِ بّلّشّ رَتٍدٍ؟
\q1 لُشُسِنيِ نْمَ مِشِ بْنبْدٍ؟
\q1 
\v 16 نَ كُي عَلَتَلَ سّنبّمَ قَمَ نّ عَ شَ سْورِ شُنفبٍيٍ شْسِدٍ،
\q1 عَ قَ عٍ فَن تّ شْرْشْي رَ.
\q1 
\v 17 عِسِرَيِلَ مَرِفِ عَلَتَلَ لُمَ نّ عَلْ تّ سّنِيّنشِ،
\q1 نَشَن عٍ شَ تُنبٍ نُن بَافِ بِرِن فَنمَ لْشْ كٍرٍن.
\q1 
\v 18 عِسِرَيِلَ شَ قْتْنيِ نُن عَ شَ شّيٍ شُن قَمَ نّ كَنَدٍ عَلْ قُرٍ مَ نَشَن نَ شْسِقٍ.
\q1 
\v 19 دِ مّدِ يَتِ نْمَ عَ شَ وُرِ بِلِ دْنشْييٍ كْنتِدٍ نَشٍيٍ لُمَ عَ شَ قْتْنيِيٍ كُي.»
\s1 عِسِرَيِلَ مِشِ دْنشْييٍ
\q1 
\v 20 نَ لْشْي عِسِرَيِلَ مِشِ دْنشْييٍ مُ عٍ شَشِلِ تِمَ مِشِيٍ رَ سْنْن،
\q1 نَشٍيٍ نُ بَرَ نْ عٍ رَ.
\q1 يَشُبَ بْنسْي عٍ شَشِلِ تِمَ عَلَتَلَ نَن نَ،
\q1 نَشَن قِندِشِ عِسِرَيِلَ شَ سّنِيّنتْي رَ.
\q1 
\v 21 يَشُبَ بْنسْي مِشِ دْنشْييٍ قَمَ نّ فبِلٍندٍ عَلَ سّنبّمَ مَ.
\q1 
\v 22 عِسِرَيِلَ، هَلِ عِ شَ حَمَ سَ فبٌ نّ
\q1 عَلْ مّيّنيِ نَشَن نَ بَا دّ رَ،
\q1 دٌندٌرٌنتِ نَن تُن فبِلٍنمَ عٍ شْنيِ.
\q1 عَلَتَلَ بَرَ نَتّ تٌنفٌ تِنشِنيِ كُي عِسِرَيِلَكَيٍ سْنتْقٍ رَ.
\q1 
\v 23 عَلَتَلَ سّنبّمَ قَمَ نّ نَ نَتّ رَكَمَلِدٍ بْشِ بِرِن كَنَقٍ رَ.
\b
\q1 
\v 24 نَ كُي عَلَتَلَ سّنبّمَ بَرَ يِ مَسٍنيِ تِ، عَ نَشّ،
\q1 «وٌ تَن، ﭑ مَ حَمَ نَشَن سَبَتِشِ سِيٌنِ،
\q1 هَلِ وٌ مُ فَاشُ عَسِرِيَكَيٍ يَ رَ،
\q1 نَشٍيٍ نَ وٌ بْنبْقٍ لُشُسِنيِ نُن وُرِ رَ،
\q1 عَلْ مِسِرَكَيٍ نُ عَ رَبَمَ كِ نَشّ.
\q1 
\v 25 عَ فبٍ مُ لُشِ ﭑ مَ شْنّ شَ فبِلٍن وٌ قْشْ رَ،
\q1 عَ قَ عٍ تَن شُن نَكَنَ.»
\b
\q1 
\v 26 عَلَتَلَ سّنبّمَ قَمَ نّ عَ شَ لُشُسِنيِ عِتٍدٍ عٍ شِلِ مَ،
\q1 عَلْ عَ نَشَن نَبَ مَدِيَنكَيٍ شَ مَنفّ عٌرٍبِ رَ.
\q1 عَ قَمَ نّ عَ شَ يِسُشُوُرِ عِتٍدٍ بَا شُن مَ،
\q1 عَلْ عَ رَبَ مِسِرَ بْشِ مَ كِ نَشّ.
\q1 
\v 27 نَ لْشْي عَلَ وٌ شَ كٌتٍ بِنيٍ بَمَ نّ وٌ تُنكِ مَ عٍ نَشَن سَشِ وٌ شُن مَ.
\q1 وٌ شُن نَكٍلِمَ نّ هَن نَ كٌتٍ بِرِن بَ وٌ شُن مَ.
\b
\q1 
\v 28 وٌ يَشُييٍ سٌمَ نّ عَيَتَ، عٍ دَنفِ مِفِرٌن رَ، عٍ كٌتٍ ندٍ لُ مِكِمَسِ.
\q1 
\v 29 عٍ دَنفِمَ مّننِ نّ، عٍ يٌنكِن فٍبَلِ.
\q1 فَاشُي رَ مَكَيٍ سُشُمَ نّ،
\q1 مِشِيٍ عٍ فِمَ نّ سْلُ شَ بْشِ مَ فِبٍيَ.
\q1 
\v 30 بَتِ فَلِمُكَيٍ نَ وَقٍ.
\q1 «لَيِسَكَيٍ، وٌ شَ وٌ تُلِ مَتِ.
\q1 عَنَتْتِكَيٍ، وٌ مَكِنِكِنِ.»
\q1 
\v 31 مَدَ مٍنَكَيٍ نَ يٍسٍنقٍ،
\q1 فٍبِمِكَيٍ نَ عٍ نْشُنقٍ.
\q1 
\v 32 نَ لْشْي نَ يَشُييٍ دَنمَ نٌبٌ نّ،
\q1 عٍ عٍ بّلّشّ رَ مَشَ سِيٌنِ فٍيَ شِلِ مَ دَرِ سَلَمُ.
\b
\q1 
\v 33 مَرِفِ عَلَتَلَ سّنبّمَ مَتٌ،
\q1 عَ نَ وُرِ بِلِ سَلٌنيِ بٌلٌنقٍ سّنبّ رَ.
\q1 عَ نَ وُرِ بِلِ عِتٍشِ رَبِرَقٍ بْشِ مَ.
\q1 
\v 34 عَ قَمَ نّ لِبَن قْتْنيِ بٍلٍبٍلٍ قْندٍ عَ شَ بٍرَ رَ.
\c 11
\s1 عَل مَسِيهُ شَ مَنفّيَ
\q1 
\v 1 سَلٌنيِ ندٍ بُلَمَ نّ يِسَيِ بْنسْي مَ،
\q1 عَ سَنكٍ عَ نِيَمَ نّ عَ شَ بٌفِ قَنيِ رَ مِنِ.
\q1 
\v 2 عَلَتَلَ شَشِلِ فٌرٌ مَ نّ عَ مَ،
\q1 عَ قِندِ قَهَامُي، كٌلٌنيِ، مَرَ سِ، سّنبّ، نُن عَلَ يَرَفَاشُي رَ.
\q1 
\v 3 عَ سّيوَ مَ نّ عَلَتَلَ شَ يَرَفَاشُي كُي.
\q1 عَ مُ كِيتِ سَمَ قٍ تٌشِ شَ نَ مُ عَ رَ قٍ مّشِ تُن شَ مَ.
\q1 
\v 4 عَ مِسِكِينّيٍ مَكِيتِمَ نّ تِنشِنيِ رَ،
\q1 عَ نَتّ قَنيِ تٌنفٌ سٍتَرٍيٍ بّ.
\q1 عَ دُنِحَ مَكِيتِمَ نّ عَ شْرْشْي رَ،
\q1 عَ يَامَرِ قِ مِشِ حَاشِيٍ شَ سْنتْ.
\q1 
\v 5 عَ قٍ بِرِن نَبَمَ تِنشِنيِ نَن نَ،
\q1 عَ شَ لَايِدِ مُ كَنَمَ قٍوٌ.
\b
\q1 
\v 6 نَ لْشْي، وُلَءِ بَرٍ نُن يّشّي لُمَ نّ يِرٍ كٍرٍن،
\q1 شُلُمَسٍ نُن سِ، نِنفٍ يْرّ نُن يّتّ،
\q1 عٍ بِرِن لُمَ نّ يِرٍ كٍرٍن،
\q1 دِ مّدِ ندٍ قَ عٍ دّ مَدٌن.
\q1 
\v 7 نِنفٍ نُن بَرَتّ عٍ دّ مَدٌنمَ نّ يِرٍ كٍرٍن،
\q1 عٍ شَ دِيٍ سَ يِرٍ كٍرٍن.
\q1 يّتّ نُن نِنفٍ بِرِن قَمَ سّشّ نَن دٌندٍ.
\q1 
\v 8 نَ لْشْي دِيْرّ بٍرٍ مَ نّ تَنبَلُنبٍ رَ،
\q1 دِ مّدِ عَ بّلّشّ رَ سٌ سَفَلٍ يِلِ كُي.
\q1 
\v 9 قٍ شْرْشْي يٌ مُ سْتْمَ ﭑ تَن عَلَتَلَ شَ فٍيَ سّنِيّنشِ قَرِ،
\q1 دُنِحَ بِرِن ﭑ كٌلٌنمَ نّ عَلْ يّشّيٍ بَا كٌلٌنمَ كِ نَشّ.
\b
\q1 
\v 10 نَ لْشْي، يِسَيِ بْنسْي قِندِ مَ تْنشُمَ نَن نَ سِ بِرِن بّ،
\q1 عٍ قَ عٍ شُن تِ عَ رَ بِنيّ كُي.
\b
\q1 
\v 11 نَ لْشْي، عَلَتَلَ مَن عَ شْنيّ عِتَلَمَ نّ
\q1 عَ شَ حَمَ دْنشْي رَكِسِقٍ رَ،
\q1 نَشٍيٍ نُ لُمَ عَسِرِيَ، مِسِرَ، ثَتِرٌ سِ، كُسِ، عٍلَمَ، سِنَرَ، شَمَتَ، نُن بَا سُرِيٍ مَ.
\q1 
\v 12 عَ تْنشُمَ مَسٍنمَ نّ سِ بِرِن بّ.
\q1 عَ عِسِرَيِلَ نُن يُدَيَ مِشِيٍ مَلَنمَ نّ،
\q1 نَشٍيٍ نُ رَيٍنسٍنشِ دُنِحَ تُنشُن نَانِ مَ.
\q1 
\v 13 عٍقِرَ مِ بْنسْي شَ تْونّ حْنمَ نّ،
\q1 يُدَ بْنسْي شَ فٍرٍ مَسٌقٍ قَن حْنمَ نّ.
\q1 عٍقِرَ مِ بْحّ شِنبٍلِمَ نّ يُدَيَ مَبِرِ،
\q1 يُدَيَ قَن فٍرٍ لُمَ نّ.
\q1 
\v 14 عٍ لَنمَ نّ قِلِسِتَكَيٍ فٍرٍقٍ مَ سٌفٍتٍدٍ مَبِرِ،
\q1 عٍ عٍ يَشُييٍ قَن فٍرٍ نَشٍيٍ نَ سٌفٍفٌرٌدٍ مَبِرِ.
\q1 عٍ نْمَ نّ عٍدٌنكَيٍ نُن مٌوَبَكَيٍ رَ،
\q1 عَمٌنِكَيٍ قَن لُ عٍ سَفٌي.
\q1 
\v 15 عَلَتَلَ بَا عِتَشُن نّ عَ شَ حَمَ بّ عٍ تٌ كٍلِ مِسِرَ بْشِ مَ.
\q1 عَ عٍقِرَتِ شُرٍ قَن عِتَشُنمَ نّ عَ شَ قٌيٍ مَفَاشُشِ رَ،
\q1 عَ قَ قِندِ كِرَ رَ، حَمَ نَشٍيٍ عِفِرِ مَ عٍ شَرَشِ رَ.
\q1 
\v 16 عَلَتَلَ كِرَ قِمَ نّ عَ شَ حَمَ دْنشْي مَ،
\q1 عَلَكٌ عٍ شَ كٍلِ عَسِرِيَ، عَلْ عٍ بٍنبَيٍ عِسِرَيِلَكَيٍ مِنِ مِسِرَ بْشِ رَ كِ نَشّ.
\c 12
\s1 مَرَكِسِ مَنفّ شَ مَتْشْي
\q1 
\v 1 نَ لْشْي وٌ قَمَ نّ عَ قَلَدٍ،
\q1 «مُشُ بَرَ عِ تَن عَلَتَلَ مَتْشْ.
\q1 عِ نُ بَرَ شْنْ مُشُ مَ،
\q1 كْنْ عِ شَ شْنّ بَرَ فبِلٍن مُشُ قْشْ رَ،
\q1 عِ قَ مُشُ مَدُندُ.
\q1 
\v 2 مُشُ رَكِسِمَ نَن نَ عَلَ رَ.
\q1 مُشُ بَرَ لَ عِ رَ، سٍسٍ مُ مُشُ مَفَاشُمَ سْنْن،
\q1 بَرِ مَ عِ تَن عَلَتَلَ نَن نَ مُشُ سّنبّ رَ،
\q1 عِ تَن نَن نَ مُشُ شَ كِسِ رَ.
\q1 نَ بَرَ عَ نِيَ مُشُ شَ بّيتِ بَ عِ مَتْشْقٍ رَ.»
\b
\q1 
\v 3 وٌ قَمَ نّ يٍ بَدٍ كِسِ دُلٌنيِ كُي سّيوّ رَ.
\q1 
\v 4 نَ لْشْي، وٌ قَمَ نّ عَ قَلَدٍ،
\q1 «وٌ شَ عَلَتَلَ مَتْشْ،
\q1 وٌ شَ عَ شِلِ مَسٍن دُنِحَ بّ،
\q1 وٌ شَ عَ شَ وَلِ قَنيِيٍ قَلَ حَمَنّ مَ.
\q1 
\v 5 وٌ شَ عَلَتَلَ مَتْشْ بّيتِيٍ رَ عَ شَ كَابَنَكٌي شَ قٍ رَ.
\q1 وٌ شَ دُنِحَ بِرِن نَكٌلٌن عَ شَ نْرّ رَ.
\q1 
\v 6 وٌ تَن سِيٌنِكَيٍ، وٌ شَ وٌ شُي رَ مِنِ سّيوّ رَ،
\q1 بَرِ مَ عِسِرَيِلَ شَ سّنِيّنتْي سّنبّ فبٌ وٌ تَفِ!»
\c 13
\s1 بَبِلْن شَ قٍ رَحْنيِ
\p 
\v 1 عَلَتَلَ شَ مَسٍنيِ عَمٌسِ شَ دِ عَننَبِ عٍسَيِ بّ بَبِلْن شِلِ مَ.
\q1 
\v 2 وٌ تْنشُمَ رَبَ فٍيَ قَرِ،
\q1 وٌ وٌ شُي رَتٍ عٍ يَمَرِقٍ رَ،
\q1 عٍ شَ كُنتِفِيٍ شَ نَادّيٍ عِفبُسَن.
\q1 
\v 3 ﭑ بَرَ يَامَرِ قِ ﭑ مَ مِشِ سُفَندِشِيٍ مَ،
\q1 ﭑ بَرَ ﭑ مَ حَلَمَيٍ شِلِ ﭑ مَ شْنّ مَسٍندٍ شُننَكٍلِ كُي.
\b
\q1 
\v 4 حَمَ شُي وُندُ مَ فٍيَيٍ قَرِ،
\q1 حَمَيٍ نَ عٍ مَلَنقٍ نَا.
\q1 مَنفّ عَلَتَلَ نَ عَ شَ سْورِيٍ شِلِقٍ فٍرٍ مَ،
\q1 
\v 5 عٍ كٍلِشِ يِرٍ مَكُيٍ كٌورٍ بَانيِ.
\q1 عَلَتَلَ نُن عَ شَ مِشِيٍ قَمَ نّ يِ بْشِ حَشَنكَتَدٍ عَ شَ شْنّ كُي.
\b
\q1 
\v 6 وٌ شَ فبٍلٍفبٍلٍ تْورّ كُي،
\q1 بَرِ مَ عَلَتَلَ شَ لْشْي بَرَ مَكْرّ،
\q1 عَ نَ قَقٍ عَلْ فبَلٌي نَشَن كٍلِشِ عَلَ سّنبّمَ مَ.
\q1 
\v 7 مِشِيٍ سّنبّ حْنمَ نّ،
\q1 لِمَنِيَ بَ عٍ بْحّ مَ.
\q1 
\v 8 فَاشُي نُن تْورّ نْمَ نّ عٍ رَ،
\q1 عٍ عٍ كُتُن شْنّ بّ عَلْ فِنّ دِ قُرِ نَ كٍلِ عَ رَ.
\q1 فَاشُي بٍلٍبٍلٍ تٌمَ نّ عٍ يَتَفِيٍ مَ.
\b
\q1 
\v 9 عَلَتَلَ شَ لْشْي شْرْشْي نَ قَقٍ،
\q1 عَ قَمَ نّ عَ شَ شْنّ رَ نَشَن بْشِ شُن نَكَنَمَ،
\q1 نَشَن يُنُبِتْييٍ سْنتْمَ.
\q1 
\v 10 تُنبُييٍ شَ يَنبّ حْنمَ نّ،
\q1 سٌفٍ عِقْورْ مَ نّ، كِكٍ مُ يَنبَمَ سْنْن.
\q1 
\v 11 ﭑ دُنِحَ رَتْنمَ نّ عَ شَ قٍ حَاشِ شَ قٍ رَ،
\q1 ﭑ يُنُبِتْي حَشَنكَتَ عٍ شَ يُنُبِيٍ شَ قٍ رَ.
\q1 ﭑ يّتّ عِفبٌي شُن نَكَنَمَ نّ،
\q1 ﭑ قُنمَلَيٍ شَ نْي رَبِرَ.
\q1 
\v 12 ﭑ عَدَ مَدِيٍ شُرُنمَ نّ،
\q1 عَلْ شّيمَ قَنيِ شُرُنمَ كِ نَشّ.
\q1 
\v 13 ﭑ تَن مَنفّ عَلَتَلَ، ﭑ كٌورٍ نُن بْشِ رَ سّرّنمَ نّ ﭑ مَ شْنّ كُي.
\q1 
\v 14 مِشِيٍ لُمَ نّ عٍ فِ رَ عَلْ بٌلٍ نَشَن نَ وُلَ عِ،
\q1 عٍ لُ عَلْ شُرُ سٍ كَنتَمَ مُ نَشَن قْشْ رَ.
\q1 عٍ فبِلٍنمَ نّ عٍ شْنيِ عٍ كٍلِشِ دّننَشّ.
\q1 
\v 15 عٍ نَشٍيٍ سُشُمَ كِرَ رَ، عٍ قَمَ نّ عٍ سْشْدٍ تَنبّ رَ،
\q1 عٍ قَ قَشَدٍ سَنتِدّفّمَ رَ.
\q1 
\v 16 عٍ شَ دِيٍ سْنتْمَ نّ عَ حَاشِ رَ عٍ يَ شْرِ،
\q1 عٍ شَ بَنشِيٍ كَسَرَ، عٍ شَ فِنّيٍ مَسَ عٍ يَ شْرِ.
\b
\q1 
\v 17 ﭑ نَ بِرِن نَبَمَ مٍدٍكَيٍ نَن سَابُي رَ،
\q1 فبٍتِ نُن شّيمَ مُ نَشٍيٍ مَدَشُمَ.
\q1 
\v 18 عٍ شَ شَلِيٍ قٌنِكٍيٍ رَبِرَ مَ نّ،
\q1 عٍ مُ كِنِكِنِمَ دِيْرّيٍ مَ،
\q1 عٍ مُ كِنِكِنِمَ دِ مّدِيٍ مَ.
\q1 
\v 19 عَلَتَلَ نَن بَبِلْن شَ قٍ شُن نَكَنَمَ،
\q1 عَلْ عَ رَبَشِ سٌدٌ مَ نُن فٌمٌرَ رَ كِ نَشّ.
\q1 بَبِلْن، نَشَن شَ نْرّ فبٌ دُنِحَ مَ،
\q1 عَ بِرَ مَ نّ عَ شَ يّتّ عِفبٌحَ كُي.
\q1 
\v 20 مِشِ يٌ مُ سَبَتِمَ مّننِ سْنْن.
\q1 هَلِ بِيَاسِلَيٍ نُن شُرُ سٍ دّ مَدٌنيِيٍ مُ يٌنكِنمَ نَا.
\q1 
\v 21 وُلَءِ سُبٍيٍ فبَنسَن نَن لُمَ نَا.
\q1 وُلَءِ بَرٍيٍ نُن شُندِيٍ نَن شِمَ نَا بَنشِ كَنَشِيٍ كُي.
\q1 وُلَءِ سِيٍ تٌمَ نّ نَا تُفَنقٍ رَ.
\q1 سِكْتّ تٌمَ نّ نَا عٍ تُفَنمَ.
\q1 
\v 22 شُلُمَسٍيٍ نَن لُمَ عٍ شُي رَ مِنِ رَ مَنفّ بَنشِيٍ كُي،
\q1 وُلَءِ بَرٍيٍ عٍ حّرّ نَ لٌنفٌرِ بِرِن.
\q1 بَبِلْن حَشَنكَتَ تّمُي بَرَ عَ لِ،
\q1 عَ فبٍ مُ لُشِ سْنْن.
\c 14
\s1 بَبِلْن شَ حَشَنكَتّ
\p 
\v 1 عَلَتَلَ كِنِكِنِمَ نّ يَشُبَ بْنسْي مَ، عَ قَ عٍ رَ سَبَتِ عٍ شْنيِ عِسِرَيِلَ بْشِ مَ. شْحّيٍ قَن كَقُمَ نّ عٍ مَ، عٍ لُ لَنيِ كُي يَشُبَ بْنسْي يَ مَ.
\v 2 سِيٍ عٍ مَلِمَ نّ سَبَتِدٍ عٍ شْنيِ، نَ سِيٍ قَ قِندِ عِسِرَيِلَ شَ كٌنيِيٍ رَ. مِشِ نَشٍيٍ نُ بَرَ عٍ سُشُ، عٍ تَن يَتِ بَرَ قِندِ عِسِرَيِلَ شَ كٌنيِيٍ رَ.
\p 
\v 3 عَلَتَلَ نَ مَلَبُي قِ وٌ مَ وٌ شَ تْورّ نُن قٍ شْرْشْي شَ قٍ رَ تّمُي نَشّ، عَ قَ وٌ رَ مِنِ وٌ شَ كٌنيِحَ وَلِ شْرْشْي كُي نَشَن نُ بَرَ دْشْ وٌ مَ،
\v 4 وٌ قَمَ نّ يِ مَسٍنيِ تِدٍ بَبِلْن مَنفّ بّ،
\q1 «مُنسٍ حَشَنكَتّ كَنيِ رَلْيشِ؟
\q1 عَ تْورّ نَشَن دْشْشِ مِشِيٍ مَ، نَ حْنشِ دِ؟
\q1 
\v 5 عَلَتَلَ بَرَ مِشِ حَاشِ شَ وُرِ بْنبْ تِ سٍ عِبٌلٌن،
\q1 عَ بَرَ مَنفّ كٌبِ شَ مُنيَاتِ عِفِرَ،
\q1 
\v 6 نَشَن نُ حَمَيٍ بْنبْمَ عَ شَ بْحّ تٍ رَ، نَشَن مُ دَنمَ
\q1 نَشَن نُ نْي دْشْمَ حَمَنّيٍ مَ عَ شَ شْنّ كُي.»
\b
\q1 
\v 7 «يَكْسِ دُنِحَ نَ مَلَبُي نُن شَشِلِسَ نَن كُي قَ،
\q1 بِرِن نَ عٍ شُي عِتٍقٍ سّيوّ كُي.
\q1 
\v 8 هَلِ وُرِ بِلِ نَشٍيٍ نَ لِبَن، عٍ نَ حّلّشِنقٍ عِ شَ قٍ دَنيِ رَ، عٍ نُ قَ عَ قَلَ،
\q1 ‹كَقِ عِ بِرَ، مِشِ يٌ مُ مُشُ قْنمَ سْنْن.›
\q1 
\v 9 عَلِفِيَمَ نَ عَ يَءِلَنقٍ عِ قَقٍ رَ.
\q1 كُنتِفِيٍ قُرٍيٍ رَكٍلِمَ نّ عِ يَ رَ عَلِفِيَمَ دِ مِ كُي،
\q1 سِ مَنفّيٍ بِرِن نَكٍلِمَ نّ عٍ شَ كِبَنيِيٍ كُي،
\q1 
\v 10 عِ رَ سّنّقٍ يِ وْيّنيِ رَ،
\q1 ‹عِ قَن سّنبّ بَرَ كَنَ عَلْ مُشُ تَن،
\q1 وٌن بِرِن بَرَ لُ يِرٍ كٍرٍن.
\q1 
\v 11 عِ شَ يّتّ عِفبٌيَ بَرَ رَفٌرٌ فَبُرِ كُي،
\q1 عِ شَ سِفِيٍ بَرَ دُندُ، كُلِيٍ بَرَ لُ عِ شَ سَدٍ مَ.›»
\b
\q1 
\v 12 «عِ بَرَ بِرَ كٍلِقٍ كٌورٍ مَ،
\q1 عِ تَن نَشَن نُ يَنبَمَ عَلْ سُبَشّ لٌولٌي.
\q1 عٍ بَرَ عِ رَبِرَ بْشِ، عِ تَن نَشَن نُ نْشِ حَمَنّيٍ رَ.
\q1 
\v 13 عِ نُ عَ قَلَ نّ عِ بْحّ كُي،
\q1 ‹ﭑ تَن تٍمَ نّ هَن عَرِيَننَ،
\q1 ﭑ قِندِ نَا مَنفّ رَ، ﭑ دْشْ ﭑ مَ كِبَنيِ كُي
\q1 مَلَنيِ يَ مَ نَشَن نَبَمَ نَ فٍيَ سّنِيّنشِ قَرِ.
\q1 
\v 14 ﭑ تٍمَ نّ نُشُي قَرِ، ﭑ لُ عَلْ عَلَ سّنبّمَ.›»
\b
\q1 
\v 15 «كْنْ عِ شَ نَتٍ بَرَ كَنَ، عٍ بَرَ عِ رَفٌرٌ كٍلِقٍ كٌورٍ مَ هَن فَبُرِ كُي،
\q1 عِ شَ لُ يِلِ تِلِنشِ كُي عَلِفِيَمَ.
\q1 
\v 16 قَشَ مِشِ نَشٍيٍ عِ تٌمَ نَا،
\q1 نٍيٍ عٍ يَ بَنبَنمَ نّ عِ رَ، عٍ قَ عَ مَحْشُن،
\q1 ‹يِ نَن قِندِشِ نَ مِشِ رَ نَشَن نُ دُنِحَ عِمَشَمَ،
\q1 نَشَن نُ مَنفّيَ كَنَمَ،
\q1 
\v 17 نَشَن نُ دُنِحَ قِندِ مَ فبٍنفبٍرٍنيِ رَ عَ شَ تَايٍ كَنَقٍ رَ،
\q1 نَشَن نُ تٌندِ مَ عَ شَ فٍيلِمَنِيٍ بّحِندٍ؟›»
\b
\q1 
\v 18 «حَمَنّ مَنفّيٍ بِرِن نَفَتَشِ عٍ شَ فَبُرِ بِنيّ نَن كُي،
\q1 
\v 19 كْنْ عِ تَن مُ رَفَتَشِ عِ شَ فَبُرِ كُي،
\q1 عَلْ سَلٌنيِ نَشَن سّفّمَ وُرِ مَ،
\q1 عَلْ سْورِ نَشَن قَشَشِ سَنتِدّفّمَ رَ عَ لُ عَ بٌورٍيٍ قُرٍيٍ يَ مَ،
\q1 عٍ بِرِن قَ فٌرٌ عَلِفِيَمَ يِلِ كُي.
\q1 
\v 20 بِنيّ يٌ مُ لُمَ عِ شَ حْن قٍ كُي عَلْ عٍ تَن،
\q1 بَرِ مَ عِ بَرَ عِ شَ بْشِ تُشُنسَن، عِ بَرَ عِ شَ حَمَ سْنتْ.»
\b
\q1 «مِشِ حَاشِ شَ دِيٍ شِلِ نّيمُمَ نّ دُنِحَ رَ.
\q1 
\v 21 عٍ شَ دِيٍ كْن شَ رَشَبَ عٍ بَبَيٍ شَ يُنُبِيٍ شَ قٍ رَ،
\q1 عٍ نَشَ عٍ عِكٍلِ قَ، عٍ بْشِ سْتْ عٍ تَايٍ تِمَ دّننَشّ.
\q1 
\v 22 ﭑ تَن عَلَتَلَ سّنبّمَ كٍلِمَ نّ عٍ شِلِ مَ،
\q1 ﭑ بَبِلْن شِلِ نُن عَ بْنسْي دْنشْي رَحْنمَ نّ،
\q1 عٍ شَ دِ يٌ مُ لُمَ نَا.
\q1 
\v 23 ﭑ عٍ شْنيِ قِندِ مَ شُندِ يِرٍ نَن نَ يٍ حَاشِ لُمَ دّننَشّ.
\q1 ﭑ نٍيٍ شُن نَكَنَمَ قٍوٌ.»
\q1 عَلَتَلَ سّنبّمَ شَ مَسٍنيِ نَن نَ كِ.
\s1 عَسِرِيَ شَ حَشَنكَتّ
\q1 
\v 24 مَنفّ عَلَتَلَ بَرَ عَ كَلِ يِ مَسٍنيِ رَ،
\q1 «ﭑ نَتّ نَشَن تٌنفٌشِ عَ قَمَ كَمَلِدٍ،
\q1 ﭑ وَشْنقٍ مُ كَنَمَ.
\q1 
\v 25 ﭑ عَسِرِيَ بُتُشُنمَ نّ ﭑ مَ بْشِ كُي،
\q1 ﭑ عٍ بٌرٌنمَ نّ ﭑ مَ فٍيَيٍ قَرِ.
\q1 عٍ شَ نْي بَمَ نّ ﭑ مَ حَمَ قَرِ،
\q1 ﭑ عٍ شَ كٌتٍ بَمَ نّ ﭑ مَ مِشِيٍ شُن.»
\b
\q1 
\v 26 نَتّ نَن نَ كِ نَشَن تٌنفٌشِ دُنِحَ بِرِن شِلِ مَ.
\q1 عَلَتَلَ سّنبّمَ بّلّشّ نَن نَ كِ،
\q1 عَ نَشَن عِتَلَشِ حَمَنّيٍ بِرِن شِلِ مَ.
\q1 
\v 27 عَلَتَلَ بَرَ نَ نَتّ تٌنفٌ.
\q1 ندٍ نَ كَنَمَ؟
\q1 عَلَتَلَ نَن بّلّشّ عِتَلَشِ.
\q1 ندٍ نَ عِسٌمَ؟
\s1 قِلِسِتَ شَ حَشَنكَتّ
\p 
\v 28 مَنفّ عَشَسِ قَشَ حّ نَشَن نَ، عَلَ يِ مَسٍنيِ نَن تِ،
\q1 
\v 29 «قِلِسِتَكَيٍ، وٌ نَشَ سّيوَ وٌ يَشُييٍ بِرَقٍ رَ.
\q1 كٍلِقٍ بْشِمَسٍ ندٍ مَ، بْشِمَسٍ فبّتّ نَن بَرِ مَ،
\q1 نَشَن شُلُن، عَ شْنْ نَ سِنفٍ بّ.
\q1 
\v 30 نَ كُي، مِسِكِينّيٍ قَمَ نّ بَلٌدٍ،
\q1 تْورْ مِشِيٍ مَلَبُمَ نّ شَشِلِسَ كُي،
\q1 كْنْ وٌ تَن قِلِسِتَكَيٍ، ﭑ وٌ قَشَمَ نّ كَامّ رَ،
\q1 ﭑ وٌ بْنسْي دْنشْي سْنتْمَ نّ.
\q1 
\v 31 وَ شُي شَ مِنِ وٌ يَ مَ،
\q1 لِمَنِيَ شَ بَ وٌ يِ!
\q1 تُورِ قْورّ نَ تٍقٍ كْولَ بِرِ رَ،
\q1 سْورِ يٌ مُ بَشِ عٍ رَ.»
\b
\q1 
\v 32 يَابِ مُندُن قِمَ سِيٍ شَ شّيرَيٍ مَ؟
\q1 عٍ عَ قَلَمَ نّ، «عَلَتَلَ نَن سِيٌنِ شَ قٍ مَبَنبَنشِ،
\q1 عَ عَ شَ حَمَ تْورْشِ كَنتَ.»
\c 15
\s1 مٌوَبَ شَ حَشَنكَتّ
\q1 
\v 1 مَسٍنيِ نَن يَ مٌوَبَ شَ قٍ رَ؛
\q1 عَ شَ تَا عَرِ شُن بَرَ رَكَنَ كْي كٍرٍن كُي.
\q1 عَ شَ تَا كِرِ شُن بَرَ رَكَنَ كْي كٍرٍن كُي.
\q1 
\v 2 دِبٌنكَيٍ سِفَمَ نّ وَدٍ عٍ شَ كُيٍيٍ يِرٍ.
\q1 مٌوَبَكَيٍ نَ وَقٍ عٍ شَ تَايٍ نٍبٌ نُن مٍدٍبَ شَ قٍ رَ،
\q1 عٍ عٍ شُنيِ بِي، عٍ عٍ دّ شَبٍيٍ مَشَبَ سُننُنيِ كُي.
\q1 
\v 3 عٍ حْنيِ دُفِيٍ رَفٌرٌ مَ عٍ مَ كِرَ رَ.
\q1 عٍ بِرِن وَ مَ نّ عٍ شُي عِتٍشِ رَ عٍ شَ بَنشِيٍ كْن نَ نُن عٍ شَ تَا مَلَندٍيٍ كُي.
\q1 
\v 4 شّسِبْنكَيٍ نُن عٍلٍيَلٍكَيٍ نَ فبٍلٍفبٍلٍقٍ،
\q1 عٍ وَ شُي سَ مّمَ هَن يَهَسِ تَا كُي.
\q1 مٌوَبَ سْورِيٍ نَ فبٍلٍفبٍلٍقٍ نَ نَن مَ،
\q1 لِمَنِيَ بَرَ بَ عٍ يِ رَ.
\b
\q1 
\v 5 ﭑ بْحّ قَن نَ وَقٍ مٌوَبَكَيٍ شَ قٍ رَ.
\q1 عٍ شَ مِشِيٍ عٍ فِمَ نّ هَن سٌوَرِ تَا، هَن عٍفٍلَتِ سٍلِسِيَ تَا.
\q1 عٍ تٍمَ نّ وَ رَ لُشِتِ،
\q1 عٍ وَ شٌرٌنَيِمِ كِرَ رَ،
\q1 
\v 6 بَرِ مَ نِمِرِن شُرٍ بَرَ شْرِ،
\q1 قِيلِيٍ بَرَ شَرَ، سَنسِيٍ بَرَ كَنَ، بُرّشّ شِندٍ يٌ مُ نَ سْنْن.
\q1 
\v 7 نَ بَرَ عَ نِيَ عٍ شَ عٍ شَ سٍ دْنشْييٍ شَنِن كٌندٍ يِرٍ شُرٍ قّ مَ.
\q1 
\v 8 مٌوَبَ وَ شُي مّمَ نّ نَانِنيِيٍ رَ،
\q1 هَن عٍفٍلَيِمِ، هَن بٍيرَ عٍلِمِ.
\q1 
\v 9 دِ مْن شُرٍيٍ رَفبٍيلِشِ وُلِ رَ،
\q1 كْنْ ﭑ مُ فّشِ سِندٍن.
\q1 فبَلٌي دِنمَ نّ مٌوَبَكَيٍ بِرِن نَ،
\q1 نَشٍيٍ عٍ فِمَ، نُن نَشٍيٍ لُمَ عٍ شَ بْشِ مَ.
\c 16
\s1 مٌوَبَكَيٍ دّ مّرِ قٍنقٍ دَرِ سَلَمُ
\q1 
\v 1 وٌ شَ يّشّي كٌنتٌنيِ ندٍ رَ سَنبَ بْشِ مَنفّ شْن مَ،
\q1 كٍلِقٍ سٍلَ نَشَن نَ مٌوَبَ وُلَ عِ، هَن سِيٌنِ فٍيَ تٌقَنيِ.
\q1 
\v 2 مٌوَبَ فِنّيٍ عٍ فِمَ نّ عَرِنٌن شُرٍ عِفِرِدٍيٍ،
\q1 كْنْ عٍ لُمَ نّ عَلْ شْنِ نَشٍيٍ كٍرِشِ عٍ تّي كُي.
\q1 
\v 3 مٌوَبَكَيٍ نَشّ، «دَرِ سَلَمُكَيٍ، وٌ شَ وٌ بٌرٍ تٌ،
\q1 وٌ شَ نَتّ ندٍ تٌنفٌ مُشُ شَ قٍ رَ.
\q1 وٌ شَ مُشُ نْشُن وٌ شْنيِ،
\q1 وٌ نَشَ مُشُ يَنقَ وٌن يَشُييٍ مَ.
\q1 
\v 4 وٌ شَ مٌوَبَكَيٍ رَتَنفَ كَسَرَتِ مَ،
\q1 نَشٍيٍ كَنتَرِ قٍنمَ وٌ شْنيِ، وٌ شَ عٍ مَكَنتَ.»
\b
\q1 كَسَرَتِ قَمَ سِفَدٍ،
\q1 عَ شَ نَتّ مُ كَمَلِمَ بْشِ كَنَقٍ رَ.
\q1 
\v 5 مَنفّ كِبَنيِ قَمَ نّ مَبَنبَندٍ دُفُتّفّيَ رَ.
\q1 تِنشِنتْي ندٍ نَشَن قَتَنشِ دَوُدَ بْنسْي رَ،
\q1 نَشَن كِيتِ سَمَ نْندِ رَ تِنشِنتْييٍ بّ،
\q1 عَ قَمَ نّ عَ مَفٌرٌدٍ عَ شَ كِبَنيِ كُي.
\b
\q1 
\v 6 مُشُ بَرَ مٌوَبَكَيٍ شَ يّتّ عِفبٌحَ كٌلٌن.
\q1 عَ حْشْ عَ مَ عَ قِسَ مِشِ بِرِن بّ.
\q1 عَ عَ يّتّ مَتْشْمَ تّمُي بِرِن،
\q1 كْنْ نْندِ يٌ مُ نَ نَ مَتْشْي كُي.
\q1 
\v 7 يَكْسِ مٌوَبَكَيٍ نَ وَقٍ عٍ شَ بْشِ شَ قٍ رَ،
\q1 عٍ نَ سُننُنيِ كُي كِرٍ شَرٍ سٍتِ شَ دَشَمُي كَنّ شَ قٍ رَ.
\q1 
\v 8 شّسِبْن نُن سِبِمَ وّنِ بِلِيٍ بَرَ كَنَ.
\q1 حَمَنّ مَنفّيٍ بَرَ نٍيٍ بِرِن كَنَ،
\q1 نَشٍيٍ نُ سِفَمَ يَاسّرِ تَا مَبِرِ، هَن فبٍنفبٍرٍنيِ مَ، هَن بَا دّ رَ.
\q1 
\v 9 نَ كُي ﭑ قَن وَ مَ نّ يَاسّرِ سّيتِ مَ سِبِمَ وّنِ شّ شَ قٍ رَ.
\q1 ﭑ يَيٍ شّسِبْن نُن عٍلٍيَلٍ لِمَ نّ،
\q1 بَرِ مَ وٌ مُ سّيوّ شُي رَ مِنِمَ سْنْن وٌ شَ شّيٍ نُن وٌ شَ وّنِ بٌفِيٍ شَ قٍ رَ.
\q1 
\v 10 سّيوّ شُي بَرَ حْن وٌ شَ سَنسِ يِرٍيٍ.
\q1 حّلّشِن شُي مُ مّمَ وٌ شَ وّنِ شّيٍ يِرٍ سْنْن.
\q1 وّنِ يَءِلَنمَيٍ مُ وّنِ بٌفِ بُندُ مَ سْنْن،
\q1 عٍ مُ حّلّشِن سِفِ سَمَ نَ وَلِ شَ قٍ رَ.
\q1 
\v 11 ﭑ بْحّ نَ تْورْقٍ مٌوَبَ شَ قٍ رَ،
\q1 ﭑ سٌندٌنيِ نَ وَقٍ كِرِ شَرٍ سٍتِ شَ قٍ رَ.
\q1 
\v 12 مٌوَبَكَيٍ بَرَ مِنِ سِفَقٍ رَ عٍ شَ كُيٍيٍ يِرٍ،
\q1 عٍ شَ سَ عٍ شَ عَلَيٍ مَكُلَ،
\q1 كْنْ نَ قَن قِندِ مَ قٍ قُقَقُ نَن نَ.
\b
\p 
\v 13 عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ مٌوَبَ شَ قٍ رَ، نَشَن مَسٍنشِ تّمُي دَنفِشِ.
\v 14 كْنْ يَكْسِ عَلَتَلَ نَشّ، «بٍينُن حّ سَشَن شَ كَمَلِ، عَلْ عَ كَمَلِمَ وَلِكّ بّ عَ شَ لَنيِ كُي كِ نَشّ، مٌوَبَكَيٍ شَ شُننَكٍلِ حْنمَ نّ، عَ شَ حَمَ مَبٍرٍ. مِشِ دٌندٌرٌنتِ نَن نَتَنفَمَ فبَلٌي مَ.»
\c 17
\s1 دَ مَسِ شَ حَشَنكَتّ
\p 
\v 1 مَسٍنيِ نَن يَ دَ مَسِ شَ قٍ رَ؛
\q1 دَ مَسِ تَا شُن نَكَنَمَ نّ.
\q1 
\v 2 عَرٌوٍرِ تَايٍ رَبّحِنمَ نّ،
\q1 عٍ قِندِ قِيلِ رَ شُرُ سٍ دّ مَدٌنمَ دّننَشّ.
\q1 مِشِ يٌ مُ لُمَ نَا نَشَن شُرُ سٍيٍ تْورْ مَ.
\q1 
\v 3 عٍقِرَ مِ تَا مَكَنتَشِ شُن نَكَنَمَ نّ.
\q1 دَ مَسِ مُ قِندِ مَ مَنفَتَا رَ سْنْن.
\q1 عَرَ مِ مِشِ دْنشْييٍ لُمَ نّ عَلْ عِسِرَيِلَكَيٍ.
\b
\q1 
\v 4 «نَ لْشْي يَشُبَ شَ دَرِيّ شُرُنمَ نّ،
\q1 عَ قَتٍ شْسِمَ نّ.
\q1 
\v 5 عَ لُمَ نّ عَلْ شّي شَبَ تّمُي رٍقَ فُلُنبَ كُي.
\q1 سَنسِيٍ تِشِ، عٍ شَبَمَيٍ قَ عٍ شَبَ.
\q1 
\v 6 بٌفِ كٍرٍن كٍرٍن نَن لُمَ عَ سَنسِ كْن نَ،
\q1 عَلْ عٌلِوِ بٌفِ كٍرٍن كٍرٍن لُمَ عَ بِلِ كْن نَ كِ نَشّ،
\q1 قِرِن شَ نَ مُ عَ رَ سَشَن لُ عَ كْن نَ،
\q1 نَانِ شَ نَ مُ عَ رَ سُولِ تٌ سَلٌنيِ كٍرٍن مَ.»
\q1 عِسِرَيِلَ مَرِفِ عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ.
\p 
\v 7 نَ لْشْي مِشِيٍ قَمَ نّ دَالِ مَرِفِ تٌدٍ، نَشَن قِندِشِ عِسِرَيِلَ شَ سّنِيّنتْي رَ.
\v 8 عٍ مُ عٍ يَ رَقِندِ مَ كُيٍيٍ مَ سْنْن، عٍ بّلّشّ نَشٍيٍ يَءِلَنشِ. عٍ مُ سِفَمَ سُرَيِ فَندٍ عٍ شَ وُرِ مَسٌلِشِيٍ يِرٍ، عٍ بّلّشّ سٌلٍ نَشٍيٍ رَقَلَشِ.
\p 
\v 9 نَ لْشْي عٍ شَ تَا سّنبّمَيٍ رَبّحِنمَ نّ، عٍ قِندِ قْتْنيِ رَ فٍيَ قَرِ، عَلْ عَمٌرِ شَ تَايٍ رَبّحِن كِ نَشّ عِسِرَيِلَكَيٍ يَ رَ. عَ بِرِن كَنَمَ نّ.
\q1 
\v 10 وٌ بَرَ نّيمُ وٌ رَكِسِمَ عَلَ مَ،
\q1 نَشَن قِندِشِ وٌ كَنتَمَ رَ.
\q1 وٌ بَرَ سَنسِ قَنيِ سِ نَشَن كٍلِشِ يِرٍ مَكُيٍ.
\q1 
\v 11 وٌ تٌ عٍ سِ، عٍ نَشَ بُلَ وٌ يَ شْرِ نَ كُيٍ عِبَ فّيسّفّ.
\q1 عٍ نَشَ قُفَ كٍرٍن نَ، كْنْ عَ شَبَ تّمُي وٌ مُ بٌفِ يٌ تٌمَ نَا.
\q1 وٌ لُمَ تْورّ نَن تُن كُي.
\b
\q1 
\v 12 حَشَنكَتّ شُنفبٍ نَن نَ كِ.
\q1 حَمَ فبٍفبٍ نَ وُندُقٍ عَلْ بَا مْرْنيِ،
\q1 عٍ نَ سْنشْي رَتٍقٍ عَلْ سُسُي بٍلٍبٍلٍ.
\q1 
\v 13 كْنْ هَلِ عٍ وُندُ،
\q1 عٍ عٍ فِمَ نّ عَلَتَلَ شَ شَاحّ يَ رَ،
\q1 عٍ سِفَ يِرٍ مَكُيٍ عَلْ قٌيٍ مَالٍ لَفِ شَنِنمَ كِ نَشّ،
\q1 عَلْ قٌيٍ سّشّ شَنِنمَ كِ نَشّ فٍيَيٍ قَرِ،
\q1 عَلْ تُرُننَادّ شُبٍ رَكٍلِمَ كِ نَشّ.
\q1 
\v 14 عٍ قَمَ فٍرٍ رَ نُنمَرٍ تّمُي نّ،
\q1 كْنْ بٍينُن كُيٍ شَ عِبَ، سٍسٍ مُ لُمَ نَا سْنْن.
\q1 نَشٍيٍ دُ سُمَ وٌن شُن نَ، عٍ قُ وٌن مَ،
\q1 نٍيٍ شَ قٍ رَبَمَ نَ كِ نّ.
\q1 نَشٍيٍ بَفَنمَ وٌن مَ، عٍ وٌن مَ نَاقُلِ تٌنفٌ، عٍ شَ قٍ رَحْنمَ نَ كِ نّ.
\c 18
\s1 كُسِ شَ حَشَنكَتّ
\q1 
\v 1 وٌ تَن نَشٍيٍ نَ كُسِ شُرٍيٍ نَاكِرِ مَ،
\q1 شْنِ فَبُتٍنيِ شُي مّمَ دّننَشّ،
\q1 
\v 2 نَشٍيٍ شّيرَيٍ شّيمَ كُنكُي كُي بَا مَ.
\b
\q1 ﭑ تَن بَرَ شّيرَيٍ شُلُنشِيٍ شّي نَ سِ مَ،
\q1 سِ بْنسْي كُيٍ رَيَبُشِ،
\q1 نَشَن مَفَاشُ كَبِ عٍ قْلّ فٍرٍ شَ قٍ رَ،
\q1 نَشَن سَبَتِشِ بْشِ مَ شُرٍ وُيَشِ نَ دّننَشّ.
\b
\q1 
\v 3 وٌ تَن دُنِحَ مِشِ بِرِن،
\q1 نَشٍيٍ سَبَتِشِ وٌ شَ بْشِ مَ،
\q1 وٌ نَ تْنشُمَ تٌ فٍيَ قَرِ، وٌ وٌ يَ تِ نَ رَ.
\q1 وٌ نَ سَرٍ شُي مّ، وٌ وٌ تُلِ مَتِ نَ رَ،
\q1 
\v 4 بَرِ مَ عَلَتَلَ يِ نَن مَسٍنشِ ﭑ بّ، عَ نَشّ،
\q1 «ﭑ مَفٌرٌشِ ﭑ شْنيِ شَشِلِسَ كُي،
\q1 عَلْ وُيٍنيِ لُشِ سَنسِ مَ سٌفٌقُرٍ تّمُي كِ نَشّ،
\q1 عَلْ نُشُي نَ تِ شّ شُن مَ حّمّ رَ.»
\q1 
\v 5 بٍينُن سَنسِ شَبَ تّمُي شَ عَ لِ،
\q1 سَنسِ نَ فّ قُفَدٍ، كْنْ عَ بٌفِ مُ مِنِشِ سِندٍن،
\q1 عَلَتَلَ قَمَ نّ سَنسِ قُفٍ بٌلٌندٍ قِنّ رَ،
\q1 عَ قَ سَلٌنيِيٍ يَتِ مَسّفّ.
\q1 
\v 6 عَ بٌفِ نَن لُمَ شْنِيٍ نُن وُلَءِ سُبٍ بّ،
\q1 عٍ نَشَن دٌنمَ سٌفٌقُرٍ نُن حّمّ رَ.
\q1 
\v 7 نَ تّمُي سِ سّنبّمَ ندٍ قَمَ نّ هَدِيَ رَ مَنفّ عَلَتَلَ بّ،
\q1 سِ بْنسْي كُيٍ، رَيَبُشِ،
\q1 نَشَن مَفَاشُ يِرٍ بِرِن،
\q1 نَشَن شَ شُي قَلَ شْنْ.
\q1 عٍ قَمَ نَ هَدِيَ رَ سِيٌنِ فٍيَ نَن قَرِ،
\q1 عَلَتَلَ سّنبّمَ شِلِ مَتْشْمَ دّننَشّ.
\c 19
\s1 مِسِرَ شَ حَشَنكَتّ نُن عٍ شَ كِسِ
\q1 
\v 1 حَشَنكَتّ نَ مِسِرَ بّ.
\q1 عَلَتَلَ نَ قَقٍ مِسِرَكَيٍ شِلِ مَ نُشُي قَرِ.
\q1 عٍ شَ كُيٍيٍ نَ سّرّنقٍ عَ يَ رَ،
\q1 فَاشُي بَرَ لُ عٍ بْحّ مَ.
\b
\q1 
\v 2 ﭑ مِسِرَكَيٍ رَدِنمَ نّ عٍ بٌورٍ رَ،
\q1 كَنكَن نُ قَ عَ نفَشَكٍرٍنيِ نُن عَ دّ قَن بٌورٍ فٍرٍ تَا نُن مَنفّيَ شَ قٍ رَ.
\q1 
\v 3 لِمَنِيَ بَمَ نّ مِسِرَكَيٍ يِ رَ،
\q1 ﭑ عٍ شَ نَتّ بِرِن كَنَ نّ عٍ رَ.
\q1 عٍ مَرَ سِ قٍنمَ نّ عٍ شَ عَلَيٍ رَ،
\q1 عٍ عٍ بٍنبَ قَشَشِيٍ مَشَندِ سٍمَتٌييٍ نُن دُورٍيٍ سَابُي رَ.
\q1 
\v 4 ﭑ مِسِرَكَيٍ سٌمَ نّ مَنفّيٍ يِ رَ نَشٍيٍ شَ قٍ مَشْرْشْ،
\q1 نَشٍيٍ شَ يَامَرِ قِندِ تْورّ رَ حَمَ بّ.
\q1 عَلَتَلَ سّنبّمَ شَ مَسٍنيِ نَن يَ.
\b
\q1 
\v 5 بَا نُن شُرٍيٍ يٍ شْرِ مَ نّ.
\q1 
\v 6 يٍ نَشَن لُمَ شُرٍفُلِ، عَ بْرْ مَ نّ، عَ شِرِ حَاشِ قَ تٍ.
\q1 سَنسِ بِرِن نَشٍيٍ نَ شُرٍ دّ رَ عٍ لِسِمَ نّ.
\q1 
\v 7 هَلِ نَشٍيٍ نَ نِلِ شُرٍ شُنفبٍ دّ رَ، عَ سٌمَ بَا مَ دّننَشّ، عٍ قَن لِسِمَ نّ.
\q1 شّ نَشٍيٍ نَ شُرٍ دّ رَ، عٍ شَرَ مَ نّ، قٌيٍ قَ عَ بِرِن شَنِن.
\q1 
\v 8 يّشّ سُشُي بِرِن وَ مَ نّ،
\q1 نَشٍيٍ كْنيِ نُن يّلّ وٌلِمَ شُرٍ مَ.
\q1 
\v 9 نَشٍيٍ فّسّ رَوَلِمَ، عٍ قَن لُمَ نّ تْورّ كُي، لِمَنِيَ بَ عٍ يِ رَ.
\q1 
\v 10 نَشٍيٍ دُفِيٍ رَوَلِمَ، عٍ شُن نَكَنَمَ نّ، عٍ بْحّ رَحَاشُ عٍ مَ.
\b
\q1 
\v 11 سٌوَن مَنفّيٍ مُ سٍسٍ قَهَامُمَ،
\q1 قِرَوُنَ شَ مَرَ سِيٍ مُ شَشِلِ قَنيِ يٌ سْتْشِ يِ قٍ كُي.
\q1 مِشِ عَ قَلَمَ دِ قِرَوُنَ بّ،
\q1 «مُشُ تَن قِندِشِ لْننِلَيٍ نَن نَ،
\q1 مَنفّ قٌرِيٍ شَ دِيٍ نَن مُشُ رَ؟»
\q1 
\v 12 وٌ شَ لْننِلَيٍ نَ مِندٍن؟
\q1 عٍ شَ وٌ رَكٌلٌن مَنفّ عَلَتَلَ قَمَ نَشَن نَبَدٍ مِسِرَ رَ.
\q1 
\v 13 سٌوَن مَنفّيٍ قِندِشِ شَشِلِتَرٍ نَن نَ،
\q1 نٌقَ مَنفّيٍ مُ فّشِ قَهَامُي سْتْدٍ.
\q1 مِسِرَ بْنسْي يَرٍرَتِيٍ نَ مِسِرَكَيٍ رَلْيقٍ نّ.
\q1 
\v 14 مَرِفِ بَرَ عٍ شَشِلِ يَ عِسٌ،
\q1 عَلَكٌ عٍ شَ مِسِرَكَيٍ رَلْي عٍ شَ قٍ بِرِن كُي،
\q1 عٍ قَ لُ عَلْ سِيسِلَ نَشَن بِرَ مَ عَ شَ بْشُنيِ مَ.
\q1 
\v 15 مِسِرَكَيٍ مُ نْمَ سٍسٍ رَ عٍ شَ مَنفّيٍ نُن عٍ شَ كُنتِفِيٍ سَابُي رَ.
\p 
\v 16 نَ لْشْي مِسِرَكَيٍ نَ مَنفّ عَلَتَلَ شَ سّنبّ تٌ، عٍ سّرّنمَ نّ فَاشُي كُي عَلْ فِنّيٍ.
\v 17 يُدَيَ شِلِ نَن قَمَ مِسِرَكَيٍ مَفَاشُدٍ عَ حَاشِ رَ، قٍ مَ عَلَتَلَ سّنبّمَ نَشَن نَتّشِ عٍ شِلِ مَ.
\p 
\v 18 نَ لْشْي تَا سُولِ نَن لُمَ مِسِرَ بْشِ مَ، نَشٍيٍ كَنَان شُي قَلَمَ، عٍ مَن لُ عَلَتَلَ سّنبّمَ يِ رَ. نَ تَا ندٍ قَمَ نّ شِلِدٍ هٍرٍ سِ.
\p 
\v 19 نَ لْشْي سّرّشّبَدٍ كٍرٍن لُمَ نّ عَلَتَلَ بّ مِسِرَ بْشِ تَفِ، تْنشُمَ فّمّ قَن تِمَ نّ عَ بّ مِسِرَ نَانِنيِ رَ.
\v 20 نَ قِندِ مَ عَلَتَلَ سّنبّمَ شَ تْنشُمَ نُن سٍيدٍحْشْيَ نَن نَ مِسِرَ بّ. عٍ نَ عٍ شُي رَتٍ عَلَتَلَ مَ، عَ مَرَكِسِمَ شّيمَ نّ عٍ رَتَنفَدٍ عٍ شَ حَشَنكَتَمَيٍ مَ.
\p 
\v 21 نَ لْشْي عَلَتَلَ عَ يّتّ مَسٍنمَ نّ مِسِرَكَيٍ بّ، عٍ قَ عَ كٌلٌن عَلَ رَ. عٍ قَمَ عَ بَتُدٍ سّرّشّ نُن سَنسِ شْرِ هَدِيَ نَن نَ، عٍ كّرّ تٌنفٌ عَ بّ عٍ نَشَن نَكَمَلِمَ.
\v 22 عَلَتَلَ فبَلٌي رَفٌرٌ مَ نّ مِسِرَكَيٍ مَ، كْنْ عٍ نَ عٍ يّتّ رَفبِلٍن عَ مَ، عَلَتَلَ مَن كِنِكِنِمَ نّ عٍ مَ عَ شَ هِننّ رَ.
\p 
\v 23 نَ لْشْي كِرَ لُمَ نّ مِسِرَ نُن عَسِرِيَ تَفِ. عَسِرِيَكَيٍ سِفَمَ نّ مِسِرَ، مِسِرَكَيٍ قَن سِفَ عَسِرِيَ. عٍ مَلَنمَ نّ يِرٍ كٍرٍن عَلَتَلَ بَتُقٍ رَ.
\p 
\v 24 نَ لْشْي عِسِرَيِلَ، مِسِرَ، نُن عَسِرِيَ، بَرَكّ لُمَ نّ عٍ سَشَنيِ بِرِن مَ دُنِحَ.
\v 25 عَلَتَلَ سّنبّمَ دُبَمَ نّ عٍ بّ، عَ عَ مَسٍن، «بَرَكّ شَ لُ ﭑ مَ حَمَ مِسِرَ مَ، بَرَكّ شَ لُ ﭑ مَ دَالِسٍ عَسِرِيَ بّ، بَرَكّ شَ لُ ﭑ كّ تٌنفٌمَ عِسِرَيِلَ بّ.»
\c 20
\s1 تْنشُمَ مِسِرَ نُن كُسِ شَ قٍ رَ
\p 
\v 1 عَسِرِيَ مَنفّ سَرَفْن تٌ عَ شَ سْورِ مَنفّ شّ عَسِدٌدِ تَا فٍرٍدٍ، عَ قَ نْ عَ رَ، عَ عَ سُشُ،
\v 2 عَلَتَلَ نَشَ يَامَرِ ندٍ قِ عَمٌسُ شَ دِ عَننَبِ عٍسَيِ مَ. عَ نَشّ، «عِ شَ عِ شَ سُننُنيِ دُفِ نُن عِ شَ سَنكِرِ بَ، عِ لُ نَ كِ قَ.» عٍسَيِ نَشَ عَ رَبَتُ، عَ قَ عَ حّرّ عَ مَفٍلِ رَ.
\p 
\v 3 حّ سَشَن تٌ دَنفِ، عَلَتَلَ نَشَ عَ مَسٍن، «ﭑ مَ كٌنيِ عٍسَيِ عَ حّرّشِ عَ مَفٍلِ نَن نَ يِ حّ سَشَن بُن مَ تْنشُمَ كِ مَ مِسِرَ نُن كُسِ شَ قٍ رَ.
\v 4 عَسِرِيَ مَنفّ قَمَ مِسِرَكَ نُن كُسِكَ مِشِ سُشُشِيٍ شَنِندٍ نَ كِ نّ. دِ مّدِيٍ نُن قٌرِيٍ بِرِن سِفَمَ عٍ مَفٍلِ نَن نَ يَافِ كُي.
\v 5 مِشِ نَشٍيٍ شَشِلِ نُ تِشِ مِسِرَ نُن كُسِ رَ، عٍ لُمَ فَاشُي نُن يَافِ نَن كُي.
\v 6 نَ لْشْي نَشٍيٍ نُ سَبَتِشِ بَا دّ رَ عٍ عَ قَلَمَ نّ، ‹قٍ مَتٌ نَشَن نَبَشِ مِسِرَكَيٍ نُن كُسِكَيٍ رَ. مُشُ شَشِلِ نُ تِشِ عٍ تَن نَن نَ عٍ شَ مُشُ رَتَنفَ عَسِرِيَ مَ. يَكْسِ مُشُ قَ رَتَنفَمَ دِ قَ؟›»
\c 21
\s1 بَبِلْن شَ حَشَنكَتّ
\p 
\v 1 حَشَنكَتّ مَسٍنيِ نَن يَ فبٍنفبٍرٍنيِ بّ نَشَن نَ بَا دّ رَ.
\q1 مِشِ مَفَاشُشِيٍ نَ قَقٍ عَلْ تُرُننَادّ
\q1 كٍلِقٍ نٍفٍوِ فبٍنفبٍرٍنيِ مَ
\q1 قٍ شْرْشْي كٍلِمَ دّننَشّ.
\b
\q1 
\v 2 ﭑ بَرَ لَامَتُنيِ مَفَاشُشِ تٌ.
\q1 «يَنقَنتٍ نَ يَنقّ تِقٍ، كَسَرَتِ نَ كَسَرّ تِقٍ.
\q1 عٍلَمَ، فٍرٍ تِ عَ بّ. مٍدِيَ، عَ رَبِلِن.
\q1 ﭑ قَمَ تْورّ دَندٍ بَبِلْن قِندِشِ نَشَن سَابُي رَ.»
\b
\q1 
\v 3 «نَ كُي ﭑ قَتٍ يَتِ نَ تْورْقٍ عَلْ فِنّ دِ قُرِ نَ كٍلِ عَ رَ.
\q1 ﭑ نَشَن تٌ، ﭑ نَشَن مّ، نَ بَرَ ﭑ كَابَ.
\q1 
\v 4 ﭑ بْحّ نَ تْورْقٍ، ﭑ نَ سّرّنقٍ فَاشُي كُي.
\q1 ﭑ نُ نَ بْحّسَ مَمّقٍ عَلَكٌ ﭑ شَ مَلَبُي سْتْ،
\q1 كْنْ يَكْسِ نَ بَرَ قِندِ قٍ مَفَاشُشِ رَ ﭑ بّ.»
\b
\q1 
\v 5 «دٌنسٍ يَءِلَن، وٌن شَ وٌن دّفّ يِرٍ كٍرٍن.
\q1 سْورِ يَرٍرَتِيٍ وٌ وٌ شَ كَنتَ سٍيٍ يَءِلَن.»
\q1 
\v 6 عَلَتَلَ عَ مَسٍن نّ ﭑ بّ، عَ نَشّ،
\q1 «يِرٍ مَكَنتّ تِ، عَلَكٌ عَ قٍ نَشَن تٌمَ عَ شَ نَ مَسٍن وٌ بّ.
\q1 
\v 7 عَ قَمَ نّ سْورِيٍ تٌدٍ قِرِن قِرِن نَ، سٌييٍ، سٌقَلٍيٍ، نُن حْشْمّيٍ قَرِ.
\q1 عَ شَ عٍ مَتٌ عَ قَنيِ رَ.»
\b
\q1 
\v 8 عَ مُ بُ، يِرٍ مَكَنتّ نَشَ عَ شُي رَ مِنِ عَلْ يّتّ شَاحّ، عَ قَلَقٍ رَ،
\q1 «لْشْ يٌ لْشْ ﭑ تِمَ نَا قٍ مَتٌدٍ،
\q1 كْي يٌ كْي ﭑ مَمّ تِمَ نَا.
\q1 
\v 9 ﭑ سْورِ رَفِيٍ تٌمَ قَ رَ قِرِن قِرِن نَ.
\q1 عٍ نَشّ، ‹بَبِلْن بَرَ بِرَ،
\q1 عٍ شَ كُيٍيٍ بِرِن سَشِ بْشِ مَ شُنتُن شُنتُنيِ رَ.›
\q1 
\v 10 وٌ تَن ﭑ مَ حَمَ نَشَن بَرَ بْنبْ عَلْ مَالٍ نَشَن نَ لٌنيِ مَ،
\q1 عِسِرَيِلَ مَرِفِ عَلَتَلَ سّنبّمَ شَ مَسٍنيِ نَن يِ كِ.»
\s1 دُ مَ شَ حَشَنكَتّ
\q1 
\v 11 حَشَنكَتّ نَ دُ مَكَيٍ بّ.
\q1 مِشِ ندٍ ﭑ شِلِمَ كٍلِقٍ سٍيِرِ، عَ نَشّ،
\q1 «يِرٍ كَنتَمَ، مُنسٍ رَبَشِ يِ كْي رَ؟
\q1 مُنسٍ دَنفِشِ نَا؟»
\q1 
\v 12 يِرٍ كَنتَمَ قَ عَ يَابِ،
\q1 «كُيٍ نَ عِبَقٍ، كْنْ كْي مَن سٌمَ نّ.
\q1 شَ وٌ وَ مَ نَ كٌلٌنقٍ،
\q1 وٌ مَن شَ قَ ﭑ مَشْرِن.
\q1 عِيٌ، وٌ مَن شَ قَ.»
\s1 عَرَبُ شَ حَشَنكَتّ
\q1 
\v 13 حَشَنكَتّ نَ عَرَبُيٍ بّ.
\q1 وٌ تَن دٍدَنكَ نَشٍيٍ يٌنكِنمَ كْي رَ عَرَبُ وُلَ عِ،
\q1 
\v 14 وٌ شَ قَ يٍ رَ مِشِيٍ بّ يٍ شْلِ نَ نَشٍيٍ مَ.
\q1 تٍمَكَيٍ وٌ شَ قَ تَامِ رَ مِشِ بّ
\q1 
\v 15 نَشٍيٍ نَ عٍ فِقٍ سَنتِدّفّمَ يَ رَ نَشَن وَ مَ عٍ قَشَقٍ،
\q1 نَشٍيٍ نَ عٍ فِقٍ شَلِ يَ رَ نَشَن وَ مَ عٍ سْنتْقٍ.
\p 
\v 16 عَلَتَلَ يِ نَن مَسٍنشِ ﭑ بّ، «حّ كٍرٍن نَن تُن لُشِ كٍدَرِ شَ قٍ شَ دَن، عَلْ وَلِكّ حّ كْنتِمَ كِ نَشّ.
\v 17 كٍدَرِ شَ سْورِيٍ شَ شَلِيٍ شُرُنمَ نّ.» عَلَتَلَ نَن شُي عَ رَ، عِسِرَيِلَ مَرِفِ عَلَ.
\c 22
\s1 دَرِ سَلَمُ شَ حَشَنكَتّ
\q1 
\v 1 حَشَنكَتّ نَ فُلُنبَ بّ تٌي تِمَ دّننَشّ.
\q1 مُنسٍ عَ نِيَشِ وٌ بِرِن تٍشِ وٌ شَ بَنشِيٍ قَرِ؟
\q1 
\v 2 سِنفٍ وٌ نُ شُلُنيِ رَبَمَ، وٌ نُ وٌ شُي عِتٍ حّلّشِنيِ كُي،
\q1 كْنْ يَكْسِ وٌ شَ قٍ نَ دِ؟
\q1 وٌ شَ مِشِيٍ مُ قَشَ سَنتِدّفّمَ رَ،
\q1 عٍ مُ قَشَ فٍرٍ كُي.
\q1 
\v 3 وٌ شَ مَنفّيٍ نَن تُن عٍ فِشِ عٍ سِفَ يِرٍ مَكُيٍ.
\q1 مِشِ نَشٍيٍ لُشِ، نٍيٍ بَرَ سُشُ فٍرٍ يٌ مُ سٌ.
\q1 
\v 4 نَ كُي ﭑ نَشَ عَ قَلَ، «وٌ ﭑ لُ نَ، ﭑ شَ وَ عَ شْرْشْي رَ.
\q1 وٌ نَشَ كَتَ ﭑ مَدُندُقٍ رَ ﭑ مَ حَمَ شَ كَسَرّ مَ.»
\b
\q1 
\v 5 عَلَتَلَ سّنبّمَ شَ لْشْي يَ عِسٌشِ نَن نُ عَ رَ،
\q1 كَسَرّ نُن تْورّ نُ فبٌشِ تّمُي نَشّ فُلُنبَ كُي تٌي تِمَ دّننَشّ.
\q1 تّتّ نُ بِرَ مَ، سْنشْي نُ تٍمَ فٍيَ قَرِ.
\q1 
\v 6 عٍلَمَكَيٍ عٍ شَ شَلِ سَسٍ فبَكُمَ عٍ مَ،
\q1 عٍ نُ سِفَمَ سْورِ رَفِسٍيٍ كُي نُن سٌي قَرِ.
\q1 كِرِكَيٍ عٍ شَ وُرٍ لٍقَيٍ مَبَمَ.
\q1 
\v 7 سْورِ نُ بَرَ وُيَ وٌ شَ فُلُنبَ قَنيِيٍ كُي،
\q1 عٍ نُ وُيَ وٌ شَ تَا نَادّ رَ.
\q1 
\v 8 سٍسٍ مُ لُشِ وٌ نُن وٌ يَشُييٍ تَفِ سْنْن.
\q1 نَ لْشْي وٌ نَشَ فٍرٍ سٌسٍيٍ تٌنفٌ نَشَن نُ نُ مَنفّ شَ بَنشِ كُي.
\q1 
\v 9 وٌ نَشَ عَ تٌ يَلٍ فبٍفبٍ نُ بَرَ تِ دَوُدَ شَ تَا تّتّ مَ.
\q1 وٌ نَشَ يٍ رَفَتَ يِرٍ ندٍ لَنبَنيِ.
\q1 
\v 10 وٌ نَشَ دَرِ سَلَمُ بَنشِيٍ مَتٌ، وٌ قَ ندٍ رَبِرَ عَلَكٌ وٌ شَ تّتّ سّنبّ سٌ.
\q1 
\v 11 وٌ نَشَ يٍ رَفَتَدٍ يَءِلَن تّتّ قِرِنيِيٍ تَفِ،
\q1 يٍ سَمَ نَشَن كُي كٍلِقٍ يٍ رَفَتَدٍ قٌرِ.
\q1 كْنْ وٌ مُ وٌ يَ رَقِندِشِ عَلَ مَ نَشَن نُ بَرَ نَ قٌرِ يَءِلَن.
\q1 وٌ مُ لَ عَ يَءِلَنمَ رَ نَشَن نُ بَرَ نَتّ تٌنفٌ نَ وَلِ شَ قٍ رَ كَقِ عَ رَكُيَ.
\q1 
\v 12 ﭑ مَرِفِ عَلَتَلَ نُ بَرَ شِلِ تِ نَ لْشْي حَمَ شَ وَ سُننُنيِ كُي،
\q1 وٌ شَ وٌ شُنيِيٍ بِ، وٌ شَ سُننُنيِ دُفِ رَفٌرٌ وٌ مَ.
\q1 
\v 13 كْنْ وٌ مُ تِن نَ رَ، وٌ نَشَ شُلُنيِ تِ حّلّشِنيِ كُي،
\q1 وٌ نِنفٍ نُن يّشّي قَشَ وٌ نَشٍيٍ دٌنمَ،
\q1 وٌ وّنِ مِن عَ قَلَقٍ رَ،
\q1 «وٌن شَ وٌن دّفٍ، وٌن شَ وٌ مِن، بَرِ مَ تِنَ وٌن قَشَمَ نّ.»
\q1 
\v 14 عَلَتَلَ سّنبّمَ بَرَ عَ مَسٍن ﭑ بّ، عَ نَشّ،
\q1 «وٌ شَ يِ يُنُبِ تَن مُ شَقَرِ مَ هَن وٌ قَشَ لْشْي.»
\q1 مَنفّ عَلَتَلَ شُي نَن يِ كِ.
\b
\p 
\v 15 ﭑ مَنفّ عَلَتَلَ نَشَ عَ مَسٍن ﭑ بّ، عَ نَشّ،
\q1 «سِفَ مَنفّ بَنشِ شُنيِ سٍبِنَ يِرٍ، عَ قَلَ عَ بّ،
\q1 
\v 16 ‹عِ فبٍ نَ مُنسٍ رَ بٍ؟
\q1 ندٍ نَ عِ بّ بٍ نَشَن عَ نِيَمَ عِ شَ فَبُرِ تٌقَنيِ فٍ يِ فٍيَ قَرِ؟
\q1 
\v 17 عَ فبٍ مُ لُشِ، عَلَتَلَ شَ عِ سُشُ، عَ شَ عِ وٌلِ يِرٍ مَكُيٍ.
\q1 عَ عِ مَشِرِ مَ نّ عَلْ كٌتٍ،
\q1 
\v 18 عَ عِ وٌلِ بْشِ بٍلٍبٍلٍ ندٍ مَ.
\q1 عِ تَن نُن عِ شَ سْورِ رَفِسٍ قَنيِيٍ شَ قٍ حْنمَ مّننِ نّ،
\q1 عِ تَن نَشَن عِ شَ مَنفّ بْنسْي رَيَافِ.
\q1 
\v 19 ﭑ عِ كٍرِ مَ نّ عِ شَ وَلِدٍ،
\q1 ﭑ عِ تِدٍ بَمَ نّ عِ يِ رَ.›»
\p 
\v 20 «نَ لْشْي ﭑ شِلِكِيَ شَ دِ عٍلِيَكِمِ شِلِمَ نّ، عَ شَ ﭑ مَ وَلِ رَبَ.
\v 21 ﭑ عِ شَ مَنفّ فُبَ رَفٌرٌ مَ نّ عَ مَ، ﭑ عِ شَ بّلّتِ شِرِ عَ تَفِ، ﭑ قَ عِ شَ مَنفّيَ قِ عَ مَ. عَ قِندِ مَ دَرِ سَلَمُكَيٍ نُن يُدَيَكَيٍ بَبَ نَن نَ.
\v 22 ﭑ دَوُدَ شَ مَنفّيَ سَابِ سٌمَ نّ عَ يِ رَ. عَ نَ نَادّ ندٍ رَبِ، مِشِ يٌ مُ عَ بَلَنمَ. عَ نَ نَادّ ندٍ بَلَن، مِشِ يٌ مُ عَ رَبِمَ.
\v 23 عَ قَمَ نّ بِنيّ رَ عَ بَبَ بْنسْي بّ. ﭑ عَ تِمَ نّ عَلْ وُرِ دِ نَشَن بَنبَنشِ عَ قَنيِ رَ بَنشِ بِلِ مَ،
\v 24 عَ بَبَ بْنسْي شَ قٍ بِرِن فبَكُمَ نَشَن نَ، قٍ شُنشُرِيٍ نُن قٍ شُنفبٍيٍ.»
\p 
\v 25 مَنفّ عَلَتَلَ مَن نَشَ عَ مَسٍن، «كْنْ لْشْي ندٍ نَ وُرِ دِ نَشَن نُ بَنبَنشِ عَ قَنيِ رَ بَنشِ بِلِ مَ، عَ قَمَ نّ بٌلٌندٍ، عَ بِرَ عَ نُن قٍ نَشَن بِرِن نُ فبَكُشِ عَ رَ.» عَلَتَلَ شُي نَن نَ كِ.
\c 23
\s1 تِرٍ شَ حَشَنكَتّ
\q1 
\v 1 حَشَنكَتّ نَ تِرٍكَيٍ بّ.
\q1 «تَرَ سِسِ كُنكُي كَنيِيٍ، وٌ شَ وٌ وَ شُي عِتٍ،
\q1 بَرِ مَ تِرٍ بْشِ شُن بَرَ رَكَنَ.
\q1 بَنشِ مُ لُمَ نَا سْنْن،
\q1 وَقُ بِرِن بَرَ كَنَ.»
\q1 سِثِرِكَ ندٍيٍ شَ مَسٍنيِ نَن نَ كِ.
\b
\q1 
\v 2 وٌ وٌ سَبَرِ، وٌ تَن نَشٍيٍ سَبَتِشِ بَا دّ رَ،
\q1 وٌ تَن نَشٍيٍ قِندِشِ يُلّيٍ رَ سِدْن تَا كُي،
\q1 وٌ تَن نَشٍيٍ بَرَ نَاقُلِ سْتْ يُلّيَ رَ وَقُ دّ سَابُي رَ.
\q1 
\v 3 بَا بَرَ عَ نِيَ وٌ شَ سَنسِ شْرِ سْتْ كٍلِقٍ سِشٌرِ.
\q1 دَشَمُي نَشَن مِنِ نِلِ شُرٍ دّ رَ، نَ نَن قِندِشِ بَننَيَ رَ وٌ بّ.
\q1 حَمَنّيٍ شَ مَكِتِ شُنفبٍ رَبَ نّ وٌ شْنيِ.
\b
\q1 
\v 4 سِدْنكَيٍ، وٌ يَافِ، وٌ تَن نَشٍيٍ شَ نْي نُ نَ بَا شُن مَ.
\q1 شُي ندٍ مِنِمَ كٍلِقٍ بَا مَ، عَ نَشّ،
\q1 «ﭑ لُشِ نّ عَلْ دِ بَرِتَرٍ،
\q1 نَشَن مُ دِ بَرِ شْنّ كٌلٌن،
\q1 نَشَن مُ دِ يٌ بَرِ مَ،
\q1 نَشَن مُ دِ يٌ رَ مْمَ، شّمّ شَ نَ مُ عَ رَ فِنّ.»
\q1 
\v 5 مِسِرَكَيٍ نَ نَ شِبَارُ مّ تِرٍ شَ قٍ رَ،
\q1 عٍ قَمَ نّ فَاشُدٍ.
\b
\q1 
\v 6 وٌ شَ سِفَ تَرَ سِسِ.
\q1 وٌ تَن نَشٍيٍ نَ بَا دّ رَ، وٌ شَ وٌ وَ شُي عِتٍ.
\q1 
\v 7 سِنفٍ وٌ شَ تَا نُ نَ حّلّشِنيِ نَن كُي،
\q1 كْنْ يَكْسِ ندٍ وٌ شَ مِشِيٍ شَنِنشِ يِرٍ مَكُيٍ؟
\q1 
\v 8 ندٍ يِ نَتّ تٌنفٌشِ تِرٍ شِلِ مَ،
\q1 عَ تَن نَشَن نُ مَنفّ تِمَ،
\q1 عَ تَن نَشَن شَ يُلّيٍ نُ قِندِشِ كُنتِفِيٍ رَ،
\q1 عَ تَن نَشَن شَ يُلّيٍ نُ بِنيَشِ دُنِحَ بِرِن مَ؟
\q1 
\v 9 عَلَتَلَ سّنبّمَ نَن يِ نَتّ تٌنفٌشِ،
\q1 عَلَكٌ يّتّ عِفبٌيَ شَ كَنَ،
\q1 شِلِ شُنفبٍ كَنيِيٍ شَ مَفٌرٌ.
\b
\q1 
\v 10 تَرَ سِسِكَيٍ، وٌ شَ بْشِ رَوَلِ عَلْ عَ رَبَمَ نِلِ شُرٍ دّ رَ كِ نَشّ،
\q1 بَرِ مَ سِدْن نُن تِرٍ شَ وَقُيٍ مُ نَ سْنْن.
\q1 
\v 11 عَلَتَلَ بَرَ عَ بّلّشّ عِتَلَ بَا شُن مَ،
\q1 عَ بَرَ مَنفّيَيٍ رَ سّرّن.
\q1 عَ بَرَ يَامَرِ قِ قٍنِسِيَ شَ يِرٍ مَكَنتَشِيٍ شَ كَنَ.
\q1 
\v 12 عَ نَشّ، «عِ تَن سِدْن تَا تٌقَنيِ،
\q1 عِ مُ لُمَ بٍرٍ رَ سْنْن،
\q1 عٍ قَمَ نّ عِ شُن نَكَنَدٍ قٍوٌ.
\q1 هَلِ وٌ وٌ فِ سِثِرِ سُرِ مَ،
\q1 وٌ مُ بْحّسَ سْتْمَ.
\q1 
\v 13 كَلِدٍ بْشِ مَتٌ بَ. عٍ شُن بَرَ رَكَنَ.
\q1 عَسِرِيَكَيٍ بَرَ سَ وُلَءِ سُبٍيٍ سَفٌي.
\q1 عٍ بَرَ عٍ شَ يِرٍ مَكَنتَشِيٍ رَبِلِن،
\q1 عٍ قَ عٍ فٍرٍ هَن سٍسٍ مُ لُشِ سْنْن.»
\b
\q1 
\v 14 «تَرَ سِسِ كُنكُي كَنيِيٍ، وٌ شَ وٌ وَ شُي عِتٍ،
\q1 بَرِ مَ وٌ شَ وَقُ مَكَنتَشِ شُن بَرَ رَكَنَ.»
\p 
\v 15 تِرٍ لُمَ نّيمُي نَن كُي هَن حّ تٌنفٌ سٌلٌقٍرٍ، مَنفّ كٍرٍن شَ بُي شَسَبِ. حّ تٌنفٌ سٌلٌقٍرٍ رَحْنيِ، قٍ قَمَ رَبَدٍ تِرٍ بّ عَلْ عَ قَلَشِ سِفِ كُي لَنفٌي فِنّ شَ قٍ رَ كِ نَشّ،
\q1 
\v 16 «عِ تَن لَنفٌي فِنّ، بِرِن نّيمُشِ نَشَن مَ،
\q1 عِ شَ كْرَ بْنبْ عَ قَنيِ رَ تَا كُي،
\q1 عِ شَ سِفِ سَ عَلَكٌ مِشِيٍ شَ رَتُ عِ شَ قٍ مَ.»
\p 
\v 17 حّ تٌنفٌ سٌلٌقٍرٍ رَحْنيِ، مَرِفِ عَ يَ رَقِندِ مَ نّ تِرٍ مَ. عَ فبِلٍنمَ نّ عَ شَ لَنفٌيحَ قٌرِ مَ، عَ عَ يّتّ سَ دُنِحَ مَنفّيَيٍ بِرِن سَفٌي كْبِرِ شَ قٍ رَ.
\v 18 كْنْ عَ شَ فٍينِ قَمَ رَوَلِدٍ عَلَتَلَ شَ قٍ نَن كُي. عَ مُ نْمَ نَ رَفَتَدٍ عَ يّتّ بّ، عَ لُمَ مِشِيٍ نَن بّ نَشٍيٍ بِرَ مَ عَلَتَلَ قْشْ رَ، عَلَكٌ عٍ شَ دٌنمَ قَنيِيٍ نُن بَلٌي فبٍفبٍ سْتْ.
\c 24
\s1 دُنِحَ شَ حَشَنكَتّ
\q1 
\v 1 عَلَتَلَ قَمَ نّ دُنِحَ كَنَدٍ،
\q1 سٍسٍ مُ لُ بْشِ مَ سْنْن،
\q1 عَدَ مَدِيٍ يٍنسٍنمَ نّ.
\q1 
\v 2 مِشِ بِرِن لُمَ تْورّ نَن كُي؛
\q1 سّرّشّدُبّ نُن حَمَ، كُنتِفِ نُن كٌنيِ،
\q1 فِنّ بَنشِ كَنيِ نُن كٌنيِ فِنّ، يُلّ نُن سَرٍ سٌي،
\q1 يٍقُ تِ نُن سٍتَرٍ، دٌنِ تٌنفٌي نُن دٌنِ كَنيِ.
\q1 
\v 3 دُنِحَ قَمَ نّ كَنَدٍ،
\q1 عَ عِسٍيٍ بِرِن حْنمَ نّ عَ مَ.
\q1 عَلَتَلَ شُي نَن نَ كِ.
\b
\q1 
\v 4 دُنِحَ تُشُنسَنمَ نّ، عَ عِشَرَ مَ نّ،
\q1 كُنتِفِيٍ يَتِ هَلَكِمَ نّ.
\q1 
\v 5 دُنِحَ مِشِيٍ بَرَ دُنِحَ كْسْ،
\q1 عٍ بَرَ عٍ كٌبٍ سٌ سّرِيّ رَ،
\q1 عٍ عَلَ شَ يَامَرِيٍ مَتَندِ،
\q1 عٍ عَ شَ سَاتّ كَنَ.
\q1 
\v 6 نَ نَن عَ رَ عَلَتَلَ دُنِحَ هَلَكِمَ،
\q1 نَ كٌتٍ دُ سُ عَدَ مَدِيٍ شُن نَ،
\q1 دُنِحَ مِشِيٍ مُ فبٌ سْنْن.
\q1 
\v 7 شّ شَبَ تّمُي سَنسِيٍ شُرُنمَ نّ،
\q1 شّ شَبَيٍ نِمِسَ.
\q1 
\v 8 سَنبَنيِ نُن كْرَ شُي دَنمَ نّ،
\q1 شُلُنيِ يٍنسٍن.
\q1 
\v 9 مِشِيٍ مُ عٍ سّيوَ مَ سِفِ شُي رَ،
\q1 دٌنسٍ يَتِ مُ رَقَنمَ عٍ مَ.
\q1 
\v 10 تَا كَنَشِ لُمَ نَ كِ نّ تُن،
\q1 عَ بَنشِيٍ بِرِن بَلَن.
\q1 
\v 11 سْنشْي تٍمَ نّ تَا كُي مِنسٍ نُن دٌنسٍ شَ قٍ رَ.
\q1 سّيوّ بَرَ حْن، حّلّشِنيِ بَرَ سِفَ.
\q1 
\v 12 سْنتْي نَن تُن لُمَ تَا كُي قَ،
\q1 تَا نَادّ كَنَ قٍوٌ.
\b
\q1 
\v 13 نَ حَشَنكَتّ نَ حْن دُنِحَ بّندّ قُحِ قَرِ حَمَنّيٍ تَفِ،
\q1 نَ لُمَ نّ عَلْ عٌلِوِ بِلِ نَشَن عِمَشَمَ عَلَكٌ عَ بٌفِيٍ شَ بَ،
\q1 نَ لُمَ نّ عَلْ سَنسِ تْنسْي كٍرٍن كٍرٍن نَشٍيٍ لُمَ شّ مَ شّ شَبَيٍ دَنفِ شَنبِ.
\b
\q1 
\v 14 كْنْ نَشٍيٍ نَ سٌفٍفٌرٌدٍ بِرِ،
\q1 نٍيٍ عٍ شُي عِتٍمَ نّ سّيوّ رَ،
\q1 عٍ بّيتِ بَ عَلَتَلَ مَتْشْقٍ رَ.
\q1 
\v 15 نَشٍيٍ نَ سٌفٍتٍدٍ بِرِ،
\q1 نٍيٍ عَلَتَلَ مَتْشْمَ نّ،
\q1 عٍ عِسِرَيِلَ مَرِفِ عَلَتَلَ شِلِ مَتْشْ بَا سُرِيٍ مَ.
\q1 
\v 16 كٍلِقٍ دُنِحَ تُنشُن نَانِيٍ رَ،
\q1 وٌن بّيتِ مّمَ نّ نَشَن عَ قَلَمَ،
\q1 «نْرّ كَنيِ نَن تِنشِنتْي رَ.»
\b
\q1 كْنْ ﭑ تَن نَشَ عٍ يَابِ،
\q1 «ﭑ شُن نَكَنَقٍ، ﭑ قَتٍ نَ بَقٍ ﭑ مَ.
\q1 حَشَنكَتّ نَ ﭑ بّ.
\q1 تِنشِنتَرٍيٍ بَرَ ﭑ يَنقَ عَ حَاشِ رَ.»
\q1 
\v 17 فبَلٌي نَن وٌ لِمَ، وٌ تَن دُنِحَ مِشِيٍ.
\q1 
\v 18 نَشَن نَ عَ فِ نَ فبَلٌي يَ رَ، عَ بِرَ مَ يِلِ نَن كُي.
\q1 نَشَن نَ تٍ نَ يِلِ كُي، يّلّ نَن دُ سُمَ عَ شُن نَ.
\q1 كٌورٍ وَلَشّ بِرَ مَ نّ،
\q1 بْشِ قَن سّرّن.
\q1 
\v 19 دُنِحَ كَنَمَ نّ، عَ عِبْو، عَ سّرّن.
\q1 
\v 20 عَ دَفَلَنمَ نّ عَلْ سِيسِلَ،
\q1 عَ عِمَشَ عَلْ بَفٍ تُرُننَادّ مِنِ تّمُي،
\q1 بَرِ مَ عَ شَ يُنُبِيٍ بَرَ فبٌ.
\q1 عَ بِرَ مَ نّ، عَ مُ كٍلِمَ سْنْن.
\b
\q1 
\v 21 نَ لْشْي عَلَتَلَ كٌورٍ دَالِيٍ نُن دُنِحَ مَنفّيٍ حَشَنكَتَمَ نّ عٍ شَ وَلِيٍ مَ.
\q1 
\v 22 عٍ قَمَ نّ مَلَندٍ يِرٍ كٍرٍن عَلْ فٍيلِمَنِيٍ نَشٍيٍ نَ فٍيلِ كُي.
\q1 عٍ بُمَ نّ نَا هَن عٍ قَ كِيتِ.
\q1 
\v 23 كِكٍ نُن سٌفٍ لْيمَ نّ،
\q1 مَنفّ عَلَتَلَ يَامَرِ تِمَ نّ سِيٌنِ فٍيَ قَرِ دَرِ سَلَمُ
\q1 قٌرِيٍ يَ عِ عَ نْرّ قَنيِ بُن مَ.
\c 25
\s1 تْورْ مِشِ شَ كَنتَرِ نَ عَلَ نَن نَ
\q1 
\v 1 عَلَتَلَ، ﭑ مَرِفِ نَ عِ تَن نَن نَ.
\q1 ﭑ عِ شِلِ مَتْشْمَ نّ عِ شَ قٍ مَكَابَشِيٍ شَ قٍ رَ،
\q1 عِ نَشٍيٍ نَتّشِ كَبِ تّمُي شْنكُيٍ دُفُتّفّحَ كُي.
\q1 
\v 2 عِ بَرَ مُشُ يَشُييٍ شَ تَا مَكَنتَشِ رَبِرَ،
\q1 عَ قِندِ فّمّ يٍنسٍنشِيٍ رَ نَشَن مُ تِمَ سْنْن.
\q1 
\v 3 نَ نَن عَ رَ حَمَ سّنبّمَيٍ عِ مَتْشْمَ نّ،
\q1 سِ حَاشِيٍ قَ عِ بِنيَدٍ.
\q1 
\v 4 عِ قِندِشِ مِسِكِينّ شَ كَنتَرِ نَن نَ،
\q1 يِرٍ مَكَنتَشِ تْورْ مِشِ لُمَ دّننَشّ.
\q1 عِ لُشِ عَلْ بَنشِ قَنيِ تُرُننَادّ كُي،
\q1 عَلْ بَفٍ نَشَن تِشِ سٌفٍ يَ مَ.
\q1 سِ حَاشِ مَنِيَشِ تُرُننَادّ نَن نَ نَشَن بْنبْمَ بَنشِ رَ،
\q1 
\v 5 عَ لُ عَلْ وُيٍنيِ نَشَن نَ فبٍنفبٍرٍنيِ مَ.
\q1 عِ حَمَنّ شَ سْنشْي رَشِنبٍلِمَ نّ،
\q1 عَلْ نُشُي نِينِ ندٍ بَمَ سٌفٍ شَ وُيٍنيِ رَ كِ نَشّ.
\q1 نَ حَمَ حَاشِ شَ سِفِ سَ دَنمَ نَ كِ نّ.
\b
\q1 
\v 6 يِ فٍيَ قَرِ، عَلَتَلَ سّنبّمَ قَمَ نّ شُلُنيِ بٍلٍبٍلٍ تِدٍ،
\q1 حَمَ بِرِن شَ مِنسٍ نُن دٌنسٍ حْشُنمّيٍ لِ نَا.
\q1 
\v 7 يِ فٍيَ قَرِ، عَلَتَلَ قَمَ نّ مَقٍلٍنيِ بَدٍ بْنسْي بِرِن مَ،
\q1 
\v 8 عَ سَيَ شَ قٍ كَنَمَ نّ عَبَدَن.
\q1 وٌن مَرِفِ عَلَتَلَ يَيٍ مَقُرُكُمَ نّ يَتَفِ بِرِن مَ،
\q1 عَ عَ شَ حَمَ شَ يَافِ بِرِن بَ دُنِحَ يَ شْرِ.
\q1 عَلَتَلَ شُي نَن نَ كِ.
\q1 
\v 9 نَ لْشْي عٍ عَ قَلَمَ نّ،
\q1 «وٌن مَرِفِ عَلَ نَن يِ كِ وٌن وٌن شَشِلِ تِشِ نَشَن نَ.
\q1 عَ بَرَ وٌن نَكِسِ.
\q1 عَلَتَلَ نَن يِ كِ وٌن وٌن شَشِلِ تِشِ نَشَن نَ.
\q1 وٌن شَ سّيوَ عَ شَ كِسِ رَ.»
\b
\q1 
\v 10 عَلَتَلَ شْنيّ لُمَ نّ يِ فٍيَ قَرِ،
\q1 كْنْ مٌوَبَكَيٍ مَبٌرٌنمَ نّ عَلْ سّشّ.
\q1 
\v 11 عٍ كَتَمَ نّ عٍ شَ عٍ بَ عَ يِ رَ،
\q1 كْنْ عَلَتَلَ عٍ شَ يّتّ عِفبٌيَ رَفٌرٌ مَ نّ،
\q1 عَ عٍ سّنبّ بِرِن حْن.
\q1 
\v 12 عَ عٍ شَ يِرٍ مَكَنتَشِيٍ رَبِرَ مَ نّ،
\q1 عَ نَ بِرِن بُتُشُن هَن عَ قِندِ شُبٍ رَ.
\q1 عَ عٍ شَ يّتّ عِفبٌيَ رَفٌرٌ مَ نّ قٍوٌ.
\c 26
\s1 تَا سّنبّمَ شَ بّيتِ
\p 
\v 1 نَ لْشْي عٍ يِ بّيتِ نَن بَمَ يُدَيَ بْشِ مَ؛
\q1 عَلَ بَرَ تَا سّنبّمَ قِ وٌن مَ،
\q1 نَشَن شَ تّتّ قِندِ مَ كِسِ رَ وٌن بّ.
\q1 
\v 2 نَادّ شَ رَبِ، حَمَ تِنشِنشِ شَ سٌ،
\q1 حَمَ نَشَن مُ لَنلَنتٍيَ كَنَ.
\q1 
\v 3 مِشِ نَشَن حَنِفٍ قَن،
\q1 عَ قِندِ مَ بْحّسَ كَنيِ نَن نَ،
\q1 بَرِ مَ عَ لَشِ عِ رَ.
\b
\q1 
\v 4 وٌ وٌ يّتّ تَشُ عَلَتَلَ رَ تّمُي بِرِن،
\q1 بَرِ مَ عَلَتَلَ نَن نَ عَلَ رَ نَشَن نَ عَبَدَن،
\q1 نَشَن سّنبّ فبٌ عَلْ قَنيٍ.
\q1 
\v 5 عَ بَرَ يّتّ عِفبٌي رَفٌرٌ،
\q1 عَ عٍ شَ تَا عِتٍشِ عِفٌرٌ، عَ قِندِ شُبٍ رَ،
\q1 
\v 6 مِسِكِينّيٍ نُن سٍتَرٍيٍ نَشَن عِبٌرٌنمَ.
\b
\q1 
\v 7 عِ تَن عَلَتَلَ تِنشِنشِ، عِ تِنشِنتْي شَ قٍ سْونّيَمَ نّ.
\q1 
\v 8 مُشُ حّرّ مَ عِ شَ سّرِيّ نَن مَ، مُشُ شَشِلِ تِشِ عِ رَ.
\q1 مُشُ عِ شِلِ مَتْشْمَ مُشُ بْحّ بِرِن نَ.
\q1 
\v 9 مُشُ نِي يَتِ هَيِ نَ عِ مَ كْي رَ، عَ عِ قٍنمَ فّيسّفّ.
\q1 عِ نَ عِ شَ كِيتِ سَ دُنِحَ مَ،
\q1 نَ نَن دُنِحَ مِشِيٍ مَتِنكَنمَ تِنشِنيِ رَ.
\q1 
\v 10 كْنْ مِشِ حَاشِيٍ تَن، هَلِ عٍ كِنِكِنِ عٍ مَ،
\q1 عٍ مُ بِرَ مَ تِنشِنيِ قْشْ رَ.
\q1 هَلِ حَمَ بِرِن بِرَ مَ تِنشِنيِ قْشْ رَ،
\q1 عٍ تَن تٌندِ مَ نّ فبِلٍندٍ قٍ حَاشِ قْشْ رَ،
\q1 عٍ مُ فَاشُمَ عَلَتَلَ شَ مَنفّيَ يَ رَ.
\q1 
\v 11 عَلَتَلَ، عِ سّنبّ فبٌ، كْنْ عٍ مُ نَ تٌمَ.
\q1 عِ شَنُنتٍيَ نَشَن سَشِ عِ شَ حَمَ مَ، عَ نِيَ عٍ شَ نَ تٌ،
\q1 نَ شَ قِندِ عٍ بّ يَافِ رَ، عِ شَ تّ قَ عٍ فَن.
\b
\q1 
\v 12 عَلَتَلَ، عِ بَرَ بْحّسَ قِ مُشُ مَ،
\q1 بَرِ مَ عِ تَن نَن مُشُ شَ وَلِ بِرِن نَكَمَلِمَ مُشُ بّ.
\q1 
\v 13 مُشُ مَرِفِ عَلَتَلَ، مَرِفِ فبّتّيٍ بَرَ نْي دْشْ مُشُ مَ بَقٍ رَ عِ تَن نَ،
\q1 كْنْ مُشُ عِ تَن نَن كٍرٍن بَتُمَ.
\q1 
\v 14 نَ مَرِفِيٍ بَرَ قَشَ، عٍ مُ بَلٌمَ سْنْن،
\q1 عٍ نِي مُ كٍلِمَ عَبَدَن.
\q1 عِ بَرَ كٍلِ عٍ شِلِ مَ، عِ عٍ سْنتْ.
\q1 عِ بَرَ عٍ شَ قٍ بِرِن نَلْي.
\q1 
\v 15 عَلَتَلَ، عِ بَرَ عِ شَ حَمَنّ رَفبٌ يّ،
\q1 عِ بَرَ عٍ شَ بْشِ نَانِنيِيٍ مَسَرَ، بْشِ شَ فبٌ.
\q1 عِ بَرَ مَتْشْي سْتْ نَ قٍ كُي.
\b
\q1 
\v 16 عَلَتَلَ، عٍ نُ نَ عِ قٍنقٍ عِ شَ حَشَنكَتّ كُي،
\q1 عٍ قَ عِ مَشَندِ.
\q1 
\v 17 عٍ نُ عٍ شُي عِتٍمَ عِ مَ عَلْ فِنّ نَشَن نَ دِ بَرِقٍ تْورّ كُي.
\q1 
\v 18 مُشُ بَرَ تْورْ نَ دِ بَرِقٍ كُي،
\q1 كْنْ نَ قٍ قِندِشِ قُقَقُ نَن نَ.
\q1 مُشُ مُ وَلِ يٌ رَبَشِ نَشَن قِندِشِ كِسِ رَ دُنِحَ بّ،
\q1 عٍ مُ كِسِ سْتْ مُشُ سَابُي رَ.
\q1 
\v 19 كْنْ عِ تَن نَن قَشَ مِشِيٍ رَكٍلِمَ قَشّ مَ.
\q1 «وٌ تَن نَشٍيٍ سَشِ بّندّ بُن مَ،
\q1 وٌ شَ كٍلِ، وٌ شَ سّيوَ.
\q1 وٌ لُشِ نّ عَلْ شِنِ سٌفٍ نَشَن رَلْيمَ.
\q1 وٌ قَن نَلْيمَ نَ كِ نّ.»
\b
\q1 
\v 20 ﭑ مَ حَمَ، وٌ شَ فبِلٍن وٌ شْنيِ،
\q1 وٌ شَ نَادّ بَلَن سَابِ رَ.
\q1 وٌ شَ وٌ نْشُن دٌندٌرٌنتِ هَن يِ شْنّ شَ دَنفِ سِندٍن.
\q1 
\v 21 عَلَتَلَ قَمَ نّ كٍلِقٍ عَ شْنيِ،
\q1 عَ قَ دُنِحَ مِشِيٍ رَتْن عٍ شَ يُنُبِيٍ شَ قٍ رَ.
\q1 بْشِ وُلِ دّنتّفّمَ نّ عَ نَشَن مِنشِ،
\q1 عَ مُ مِشِ قَشَشِيٍ رَفَتَمَ سْنْن.
\c 27
\s1 عِسِرَيِلَ شَ كِسِ
\q1 
\v 1 نَ لْشْي، عَلَتَلَ نِنفِنَنفّ مَفَاشُشِ حَشَنكَتَمَ نّ عَ شَ سَنتِدّفّمَ شُنفبٍ رَ.
\q1 نَ شِلِ لٍوِتَن، عَ سَبَتِشِ بَا نَن مَ.
\q1 عَ سُشُقٍ شْرْشْ، بَرِ مَ عَ سَلَشُن عَ فبٍ رَ،
\q1 كْنْ عَلَتَلَ عَ سْنتْمَ نّ.
\b
\q1 
\v 2 نَ لْشْي، وٌ شَ بّيتِ بَ ﭑ مَ وّنِ بِلِ قَنيِيٍ شَ قٍ رَ.
\q1 
\v 3 ﭑ تَن عَلَتَلَ نَن نَ عَ كَنتَمَ رَ.
\q1 ﭑ يٍ سَمَ نّ عَ مَ تّمُي بِرِن.
\q1 ﭑ عَ كَنتَمَ نّ كْي نُن يَنيِ رَ عَلَكٌ مِشِ يٌ نَشَ عَ تْورْ.
\q1 
\v 4 ﭑ شْنْ شْنْ، كْنْ شَ ﭑ سَ تُنبٍيٍ لِ نَا،
\q1 ﭑ عٍ فٍرٍ مَ نّ، ﭑ تّ دِن عٍ رَ.
\q1 
\v 5 شَ عَ سَ لِ عٍ نَشَ قَ ﭑ يِرٍ لَنيِ شِرِدٍ،
\q1 ﭑ تِنمَ نّ عَ رَ عَ قَنيِ رَ.
\b
\q1 
\v 6 لْشْي نَ قَقٍ، يَشُبَ بْنسْي عَ سَنكٍ سْرْنمَ نّ،
\q1 عِسِرَيِلَ بْنسْي عَ سَلٌنيِيٍ نُن عَ قُفٍيٍ رَ مِنِ،
\q1 عَ دُنِحَ رَقٍ عَ بٌفِيٍ رَ.
\b
\q1 
\v 7 عَلَتَلَ يَشُبَ بْنسْي بْنبْ نّ،
\q1 عَلْ عَ عٍ يَشُييٍ بْنبْ كِ نَشّ؟
\q1 عَ عٍ قَشَ نّ، عَلْ عَ عٍ قَشَ كِ نَشّ؟
\q1 
\v 8 عَ شَ شْنّ نَشَ دِن عٍ رَ،
\q1 عَ عٍ شَنِن عَلْ قٌيٍ شُنفبٍ.
\q1 
\v 9 يَشُبَ بْنسْي شَ يُنُبِيٍ شَقَرِ نَ كِ نّ.
\q1 نَ كُي، عٍ نَشَ كُيٍ سّرّشّبَدٍيٍ كَنَ،
\q1 عٍ نَشَ عَسٍرَ وُرِ مَسٌلِشِيٍ بَ عٍ شَ بْشِ مَ،
\q1 عٍ نَشَ كُيٍ شَ سُرَيِ فَنسٍيٍ كَنَ.
\q1 
\v 10 تَا سّنبّمَيٍ بَرَ كِرٌ،
\q1 عٍ قِندِ نّ يِرٍ رَبّحِنشِ رَ عَلْ فبٍنفبٍرٍنيِ.
\q1 نِنفٍيٍ نُ لُمَ نَا عٍ دّ مَدٌندٍ،
\q1 عٍ عٍ سَ، عٍ مّننِ وُرِ بُرّشّ بِرِن دٌن.
\q1 
\v 11 وُرِ سَلٌنيِيٍ نَ شَرَ، فِنّيٍ نُ عٍ فَن تّ رَ.
\q1 حَمَ شَشِلِتَرٍ نَن نُ عَ رَ.
\q1 عٍ دَالِ مَنفّ مُ كِنِكِنِشِ عٍ مَ نَ نَن مَ.
\q1 نَشَن عٍ دَاشِ، نَ مُ هِننّشِ عٍ رَ.
\p 
\v 12 نَ لْشْي، عَلَتَلَ وُرِ بِلِيٍ عِمَشَمَ نّ، كٍلِ عٍقِرَتِ شُرٍ دّ رَ هَن مِسِرَ شُرٍ دّ رَ. عَ وٌ تَن عِسِرَيِلَ شَ دِيٍ بِرِن مَتٌنفٌمَ نّ كٍرٍن كٍرٍن.
\p 
\v 13 نَ لْشْي، قٍرِ شُنفبٍ قٍمَ نّ، عَلَكٌ مِشِ نَشٍيٍ نُ لْيشِ عَسِرِيَ بْشِ مَ، عَ نُن نَشٍيٍ نُ يٍنسٍنشِ مِسِرَ بْشِ مَ، عٍ بِرِن فبِلٍنمَ نّ، عٍ قَ سُيِدِ عَلَتَلَ بّ فٍيَ سّنِيّنشِ قَرِ دَرِ سَلَمُ.
\c 28
\s1 حَشَنكَتّ نَ سَمَرِ بّ
\q1 
\v 1 حَشَنكَتّ نَ عٍقِرَ مِ تَا يّتّ عِفبٌي سِيسِلَيٍ بّ،
\q1 نَشَن تِشِ فُلُنبَ كٌورٍ رَ،
\q1 كْنْ عَ شَ تٌقَنيِ لُشِ نّ عَلْ سَنسِ قُفٍ لِسِشِ.
\q1 
\v 2 سّنبّمَيٍ نَن قَقٍ يِ كِ مَرِفِ شِلِ رَ،
\q1 نَشَن لُشِ عَلْ تُرُننَادّ قٌيٍ شُنفبٍ،
\q1 عَلْ بَلَبَلَن تُنّ نَشَن سّنبّ سَمَرِ شُن نَفٌرٌ مَ.
\q1 
\v 3 عٍقِرَ مِ تَا يّتّ عِفبٌي سِيسِلَيٍ بِرَ مَ نّ، عٍ مَبٌرٌن.
\q1 
\v 4 نَ سَنسِ قُفٍ لِسِشِ نَشَن تِشِ فُلُنبَ كٌورٍ رَ،
\q1 عَ لُشِ نّ عَلْ شْرّ بٌفِ مْشِ نَشَن دٌنمَ كٍرٍنيِ رَ.
\b
\q1 
\v 5 نَ لْشْي، عَلَتَلَ سّنبّمَ لُمَ نّ عَلْ مَنفّ كَتَنيِ تٌقَنيِ عَ شَ حَمَ دْنشْييٍ بّ.
\q1 
\v 6 عَ شَشِلِ تِنشِنشِ قِمَ نّ كِيتِسَيٍ مَ،
\q1 عَ سّنبّ قِ سْورِيٍ مَ نَشٍيٍ نَ فٍرٍ كُي.
\b
\q1 
\v 7 كْنْ وٌ شَ سّرّشّدُبّيٍ نُن نَمِحْنمّيٍ بَرَ لْي.
\q1 بٍيرٍ عٍ دَفَلَنمَ نّ،
\q1 عٍ دَشُ لَامَتُنيِ تٌ تّمُي،
\q1 عٍ مُ قَتَ قٍ تَفِ رَبَدٍ.
\q1 
\v 8 عٍ تِشِ عٍ يّتّ شَ بْشُنيِ تَفِ،
\q1 عٍ بِرِن نْشْشِ عَ حَاشِ رَ.
\b
\q1 
\v 9 «عَلَ وَ مَ عٍ شَرَنقٍ؟
\q1 عَ قَهَامُي قِمَ عٍ مَ؟
\q1 عٍ لُشِ عَلْ دِيْرّ نَشٍيٍ دّ بَشِ عٍ نفَ شِحّ رَ.
\q1 
\v 10 قٌ عَ شَ وْيّن عٍ بّ دِيْرّ دَاشِ.»
\b
\q1 
\v 11 عَلَتَلَ قَمَ عَ مَسٍندٍ يِ حَمَ بّ شْحّ سَابُي رَ،
\q1 
\v 12 «مَلَبُدٍ نَن يِ كِ، وٌ شَ وٌ مَلَبُ.
\q1 يِرٍ رَشَرَشِ نَ عَ رَ.»
\q1 كْنْ عٍ مُ تِن عٍ تُلِ مَتِدٍ عَ رَ.
\q1 
\v 13 نَ كُي عَلَتَلَ قَمَ نّ مَسٍنيِ تِدٍ عٍ بّ دِيْرّ دَاشِ،
\q1 عَلَكٌ عٍ شُن شَ رَكَنَ، يَشُييٍ شَ عٍ سُشُ، عٍ عٍ شَنِن.
\b
\q1 
\v 14 عَوَ، وٌ تَن مِشِ مَيٍلٍيٍ،
\q1 وٌ تَن نَشٍيٍ دَرِ سَلَمُ يَمَرِ مَ،
\q1 وٌ وٌ تُلِ مَتِ عَلَتَلَ شَ مَسٍنيِ رَ.
\q1 
\v 15 وٌ نَشّ، «مُشُ نُن سَيَ بَرَ سَاتَ،
\q1 مُشُ نُن فَبُرِ بَرَ لَنيِ شِرِ.
\q1 فبَلٌي يٌ مُ مُشُ لِمَ وٌن مَ كَنتَرِ كُي.»
\q1 كْنْ عٍ نَ عٍ نْشُنقٍ وُلٍ شَنبِ رَ.
\q1 
\v 16 عَلَتَلَ عٍ يَابِمَ نّ،
\q1 «ﭑ بَرَ فّمّ هَفِفّ دْشْ سِيٌنِ،
\q1 فّمّ قَنيِ نَشَن مُ كَنَمَ.
\q1 لِمَنِيَ مُ بَمَ مِشِ يِ رَ نَشَن عَ تَشُمَ نَ فّمّ رَ.
\q1 
\v 17 ﭑ بَرَ تِنشِنيِ تِ سّرِيّ رَ،
\q1 ﭑ بَرَ نْندِ سَ كِيتِ كِ رَ.
\q1 وٌ شَ وُلٍ نَشٍيٍ قِندِشِ وٌ شَ كَنتَرِ رَ،
\q1 بَنبَرَنيِ قَمَ نّ عٍ شَنِندٍ.
\q1 
\v 18 وٌ شَ سَاتّ، وٌ نُن سَيَ رَ، عَ كَنَمَ نّ،
\q1 وٌ شَ لَنيِ، وٌ نُن فَبُرِ رَ، عَ قُلُنمَ نّ.
\q1 فبَلٌي نْمَ نّ وٌ رَ عَ قَنيِ رَ.
\q1 
\v 19 قٍ شْرْشْي نَ وٌ لِ، عَ وٌ شُن نَكَنَمَ نّ،
\q1 فّيسّفّ يٌ فّيسّفّ، قّيحّن يٌ قّيحّن، كْي يٌ كْي.
\q1 وٌ نَ سٌ يِ قٍ كُي، وٌ عِقُمَ نّ فَاشُي رَ.»
\b
\q1 
\v 20 «وٌ شَ سَدٍ شُرُن، وٌ مُ نْمَ وٌ سَدٍ عَ مَ.
\q1 وٌ شَ شِنبٍلِ دُفِ شُرُن، عَ مُ وٌ كَنتَمَ شِنبٍلِ رَ.
\q1 
\v 21 عَلَتَلَ كٍلِمَ نّ عَلْ عَ كٍلِ ثٍرَ سِمِ فٍيَ قَرِ كِ نَشّ،
\q1 عَ شْنْمَ نّ عَلْ عَ شْنْ فَبَيٌن فُلُنبَ كُي كِ نَشّ،
\q1 عَلَكٌ عَ شَ عَ شَ وَلِ مَكَابَشِ رَبَ.
\q1 
\v 22 نَ كُي وٌ بَ مَيٍلٍ تِقٍ،
\q1 عَلَكٌ عَ نَشَ قَ فبِلٍن وٌ شِرِ رَ،
\q1 بَرِ مَ عَلَ بَرَ عَ شَ نَتّ مَسٍن ﭑ بّ بْشِ كَنَقٍ رَ.»
\b
\q1 
\v 23 «وٌ وٌ تُلِ مَتِ ﭑ شُي رَ،
\q1 وٌ وٌ تُلِ مَتِ ﭑ مَ مَسٍنيِ رَ.
\q1 
\v 24 شّ سَ شّ بُشَمَ تّمُي بِرِن؟
\q1 عَ بّندّ رَ مَشَمَ لْشْي بِرِن؟
\q1 
\v 25 عَ نَ فّ بْشِ بُشَدٍ، عَ مُ سَنسِ فَرَنسَنمَ؟
\q1 عَ مُ سَنسِ شْرِ بِرِن وٌلِمَ عَ كِ مَ؟
\q1 
\v 26 عَ مَرِفِ عَلَ عَ شَرَن عَ سِ كِ رَ.
\q1 
\v 27 سَنسِ مْولِ ندٍ مُ بْنبْمَ وُرٍ رَ،
\q1 عَ بْنبْمَ وُرِ نَن نَ.
\q1 
\v 28 سَنسِ مْولِ فبّتّ نْمَ بْنبْدٍ وُرٍ رَ،
\q1 كْنْ عَ مُ رَدَنفِمَ عَ عِ.
\q1 
\v 29 نَ وَلِ كِ بِرِن قَتَنشِ عَلَتَلَ سّنبّمَ نَن مَ.
\q1 عَ شَ وَلِيٍ مَكَابَ، عَ شَ قٍ قَنيِيٍ فبٌ.»
\c 29
\s1 حَشَنكَتّ نَ دَرِ سَلَمُ بّ
\q1 
\v 1 حَشَنكَتّ نَ عَرِيّلِ تَا بّ،
\q1 مَنفّ دَوُدَ نُ سَبَتِشِ دّننَشّ.
\q1 وٌ شَ نُ وٌ شَ سَلِيٍ رَبَ رَ حّ يٌ حّ عَلْ وٌ دَرِشِ عَ رَ كِ نَشّ،
\q1 
\v 2 كْنْ ﭑ قَمَ نّ عَرِيّلِ شَ تّتّ رَبِلِندٍ،
\q1 عَ قَ تْورْ فٍرٍ كُي، عَ شَ لُ عَلْ سّرّشّبَدٍ نَشَن دّشّشِ.
\q1 
\v 3 ﭑ قَمَ نّ وٌ رَبِلِندٍ ﭑ مَ سْورِيٍ رَ،
\q1 مُشُ شَ وَلِ رَبَ وٌ شَ تّتّ كَنَدٍ.
\q1 
\v 4 وٌ شَ قٍ قَمَ نّ مَفٌرٌدٍ هَن عَ لُ عَلْ وٌ شُي نَ مِنِقٍ بْشِ نَن بُن مَ.
\q1 وٌ شَ وْيّنيِ مَكْلِكْلِمَ نّ كٍلِقٍ فَبُرِ كُي.
\q1 
\v 5 وٌ يَشُييٍ وُيَمَ نّ عَلْ شُبُتَنيِ،
\q1 عٍ شَ سْورِيٍ لُمَ نّ عَلْ مَالٍ لَفِ قٌيٍ مَ.
\q1 كْنْ نَ تّمُي يَ مَفِرّ كٍرٍن كُي،
\q1 
\v 6 عَلَتَلَ سّنبّمَ قَمَ نّ سٍسَرِنيِ نُن فَلَنيِ رَ،
\q1 بْشِ سّرّنمَ نّ، تُرُننَادّ فٌرٌ مَ نّ، تّ مِنِمَ نّ.
\q1 
\v 7 نَ تّمُي عَرِيّلِ يَشُييٍ لْيمَ نّ كٍرٍن نَ،
\q1 عٍ قَ لُ عَلْ شِيٍ حَاشِ مِشِ رَشُنُمَ تّمُي نَشّ.
\q1 نَ سْورِيٍ نُن عٍ شَ فٍرٍ سٌ وَلِ بِرِن حْنمَ نّ قٍوٌ.
\q1 
\v 8 عَ لُمَ نّ عَلْ كَامّتْي نَشَن شِيٍ سَ عَ نَ عَ دّفٍقٍ،
\q1 كْنْ عَ قَ شُنُ كَامّ رَ عَ مَ.
\q1 عَ لُمَ نّ عَلْ مِشِ نَشَن شِيٍ سَ عَ نَ يٍ مِنقٍ،
\q1 كْنْ عَ قَ شُنُ يٍ شْلِ رَ عَ مَ.
\q1 عَ لُمَ نَ كِ نّ نَ سْورِ فَلِ شَ قٍ رَ نَشَن نَ سِيٌنِ مِشِيٍ فٍرٍقٍ.
\b
\q1 
\v 9 عَ شَ قِندِ وٌ بّ تّرّننَ رَ، وٌ دّ شَ عِشَرَ.
\q1 وٌ وٌ يَيٍ رَشِ، وٌ شَ قِندِ دْنشُييٍ رَ.
\q1 وٌ نَ دَفَلَنقٍ سِيسِ دَاشِ، كْنْ بٍيرٍ مُ عَ رَ.
\q1 
\v 10 عَلَتَلَ نَن وٌ رَشِشِ،
\q1 عَ بَرَ وٌ شَ نَمِحْنمّيٍ يَيٍ بَلَن،
\q1 عَ بَرَ وٌ شَ سٍمَتٌي شُنيِ مَكٌتٌ.
\p 
\v 11 يِ لَامَتُنيِ لُشِ نّ عَلْ سّبّلِ مَتْنشُمَشِ. نَ سٌمَ مِشِ نَن يِ نَشَن قَتَ عَ شَرَندٍ عَلَكٌ عَ شَ عَ شَرَن، كْنْ عَ قَ عَ يَابِ، «ﭑ مُ نْمَ عَ شَرَندٍ وٌ بّ، بَرِ مَ عَ بَلَنشِ تْنشُمَ رَ.»
\v 12 شَ نَ مُ عَ رَ، عَ لُشِ عَلْ سّبّلِ نَشَن سٌمَ مِشِ شَرَنتَرٍ يِ رَ عَلَكٌ عَ شَ عَ شَرَن، كْنْ عَ قَ عَ يَابِ، «ﭑ تَن مُ قَتَ عَ شَرَندٍ.»
\q1 
\v 13 عَلَتَلَ شَ مَسٍنيِ نَن يَ؛
\q1 «يِ حَمَ بَرَ قَ، عٍ شَ ﭑ مَتْشْ عٍ دّ رَ،
\q1 كْنْ عٍ بْحّ تَن مَكُيَ ﭑ نَ.
\q1 عٍ شَ بَتُي قِندِشِ عَدَ مَدِيٍ شَ يَامَرِ رَتِنمّقٍ نَن تُن نَ.
\q1 
\v 14 نَ نَن عَ تٌشِ ﭑ مَن يِ حَمَ دّ عِشَرَ مَ نّ كَابَنَكٌي رَ.
\q1 لْننِلَيٍ شَ لْننِ مُ فّمَ نَ كٌلٌندٍ،
\q1 قٍ كٌلٌنيِيٍ مُ سٌمَ نَ قٍ كُي.
\q1 
\v 15 حَشَنكَتّ نَ مِشِيٍ بّ نَشٍيٍ عٍ نْشُنمَ عَلَتَلَ مَ نَتّ كٌبِ رَبَقٍ رَ.
\q1 عٍ تٌ عٍ شَ وَلِيٍ رَبَمَ دِ مِ نَن كُي،
\q1 عٍ مَحْشُن، ‹ندٍ مُشُ تٌشِ؟ ندٍ عَ كٌلٌن مُشُ نَشَن نَبَمَ؟›
\q1 
\v 16 وٌ شَ دَشُحَ سّنبّ فبٌ.
\q1 بّندّ نْمَ لُدٍ عَلْ عَ يَءِلَنمَ؟
\q1 سٍ يَءِلَنشِ نْمَ عَ قَلَدٍ عَ يَءِلَنمَ بّ، عَ مُ ﭑ يَءِلَنشِ؟
\q1 قّحّ نْمَ عَ قَلَدٍ عَ يَءِلَنمَ بّ، عَ شَشِلِ مُ قَن؟»
\b
\q1 
\v 17 عَ فبٍ مُ لُشِ لِبَن وٌندِ شَ مَسَرَ شّ رَ،
\q1 شّ قَن شَ مَسَرَ وٌندِ رَ.
\q1 
\v 18 نَ لْشْي، تُلِ شْرِيٍ كِتَابُي شَرَنمَيٍ شُي مّمَ نّ،
\q1 دْنشُييٍ قَن مِنِمَ نّ دِ مِ شْورَ، عٍ سٍ تٌ.
\q1 
\v 19 يّتّ مَفٌرٌي سّيوَ مَ نّ عَلَتَلَ رَ،
\q1 مِسِكِينّيٍ سّيوَ مَ نّ عِسِرَيِلَ شَ سّنِيّنتْي رَ.
\q1 
\v 20 قُنمَلَ مُ لُمَ نَا سْنْن،
\q1 مِشِ مَيٍلٍ لْيمَ نّ.
\q1 قٍ كٌبِ رَبَيٍ لْيمَ نّ.
\q1 
\v 21 عٍ مِشِ تْوحّفّمَ وُلٍ رَ، عٍ فَنتَنيِ عِتَلَمَ تِنشِنتْييٍ بّ.
\b
\q1 
\v 22 يَشُبَ بْنسْي مَرِفِ شَ مَسٍنيِ نَن يَ نَشَن عِبُرَهِمَ شُن سَرَشِ؛
\q1 «تٌ دَنفِ شَنبِ، يَشُبَ بْنسْي مُ يَافِمَ سْنْن،
\q1 عَ بْحّ مُ رَحَاشُمَ عَ مَ.
\q1 
\v 23 عَ شَ دِيٍ نَ ﭑ مَ وَلِيٍ تٌ عٍ تَفِ،
\q1 عٍ ﭑ شِلِ بِنيَمَ نّ،
\q1 عٍ عٍ مَفٌرٌ مَ نّ يَشُبَ شَ سّنِيّنتْي بّ،
\q1 عٍ فَاشُمَ نّ عِسِرَيِلَ مَرِفِ عَلَ يَ رَ.
\q1 
\v 24 مِشِ عِقُشِ قَهَامُي سْتْمَ نّ،
\q1 سْنشْي رَتٍيٍ تِنمَ نّ لْننِ رَ.»
\c 30
\s1 حَشَنكَتّ بْنسْي مُرُتّلَ بّ
\q1 
\v 1 عَلَتَلَ شَ مَسٍنيِ نَن يَ،
\q1 «حَشَنكَتّ نَ بْنسْي مُرُتّلَ بّ.
\q1 عٍ نَتّيٍ تٌنفٌمَ، نَشٍيٍ مُ كٍلِشِ ﭑ تَن مَ.
\q1 عٍ سَاتّيٍ شِرِ مَ، ﭑ شَشِلِ مُ عٍ يَمَرِشِ نَشٍيٍ رَ.
\q1 نَ كُي عٍ يُنُبِ شُن مَسَمَ تُن.
\q1 
\v 2 عٍ سِفَمَ مِسِرَ، عٍ عٍ يّتّ تَشُ مّننِ مَنفّ رَ.
\q1 عٍ وَ مَ لُقٍ عَ شَ كَنتّ بُن مَ.
\q1 عٍ نَ بِرِن نَبَ ﭑ تَن شَنبِ.
\q1 
\v 3 مِسِرَ مَنفّ شَ كَنتّ قِندِ مَ يَافِ نَن نَ وٌ بّ،
\q1 لُقٍ عَ شَ نِينِ بُن مَ نَ وٌ تْورْ مَ نّ تُن.
\q1 
\v 4 هَلِ وٌ كُنتِفِيٍ شّي سٌوَن نُن شَنّسِ مِسِرَ بْشِ مَ،
\q1 
\v 5 عٍ بِرِن قَمَ لُدٍ يَافِ نَن كُي نَ حَمَ شَ قٍ رَ نَشَن مُ عٍ مَلِمَ.
\q1 عٍ مُ وٌ دّ مّنمَ، عٍ وٌ رَيَافِمَ تُن.»
\b
\q1 
\v 6 حَشَنكَتّ نَ نٍفٍوِ فبٍنفبٍرٍنيِ سُبٍيٍ بّ.
\q1 عٍ بْشِ شْرْشْي نَن عِفِرِ مَ يّتّيٍ نُن بْشِمَسٍيٍ نَ دّننَشّ،
\q1 عٍ شَ بَننَيَ شَنِنقٍ رَ سٌقَلٍيٍ نُن حْشْمّيٍ قَرِ حَمَ شْن مَ،
\q1 نَشَن مُ قَتَ عٍ مَلِدٍ قٍقٍ مَ.
\q1 
\v 7 مِسِرَ شَ مَلِ قِندِ مَ قٍ قُقَقُ نَن تُن نَ!
\q1 نَ نَن عَ رَ، ﭑ نَشَ يِ شِلِ سَ عَ شُن مَ؛ تُرُننَادّ تَفَنشِ.
\b
\q1 
\v 8 يِ قٍ سّبّ وَلَشّ مَ عٍ بّ،
\q1 عَ سّبّ بُكِ مَ عَلَكٌ عَ شَ قِندِ سٍيدٍ رَ عَبَدَن.
\q1 
\v 9 حَمَ مُرُتّلَ نَن عَ رَ، نَشَن عَ بٌورٍيٍ مَدَشُمَ،
\q1 نَشَن مُ وَ مَ عَ تُلِ مَتِقٍ عَلَتَلَ شَ سّرِيّ رَ.
\q1 
\v 10 عٍ عَ قَلَمَ سٍمَتٌي بّ، «وٌ نَشَ لَامَتُنيِيٍ تٌ.»
\q1 عٍ عَ قَلَمَ نَمِحْنمّيٍ بّ، «وٌ نَشَ مَسٍنيِ تِنشِنشِ تِ.»
\q1 عٍ نَشّ، «وٌ شَ مَسٍنيِ حْشُنمّيٍ تِ،
\q1 وٌ شَ وْيّن قَنيِ قَلَ، هَلِ نْندِ مُ عَ رَ.
\q1 
\v 11 وٌ شَ كٍلِ يِ كِرَ شْن مَ،
\q1 وٌ شَ عِسِرَيِلَ شَ سّنِيّنتْي مَسٍنيِ لُ نَا.»
\b
\q1 
\v 12 عِسِرَيِلَ شَ سّنِيّنتْي شَ يَابِ نَن يَ،
\q1 «وٌ تٌ تٌندِ يِ مَسٍنيِ رَ،
\q1 وٌ قَ لَ تْورّ نُن مَدَشُي رَ،
\q1 
\v 13 يِ يُنُبِ لُمَ نّ وٌ بّ عَلْ تّتّ كَنَشِ،
\q1 نَشَن بِرَ مَ تّرّننَ رَ.
\q1 
\v 14 عَ كَنَمَ نّ عَلْ قّحّ كَنَشِ،
\q1 هَلِ تّ كْ سٍ، شَ نَ مُ عَ رَ يٍ بَسٍ مُ مِنِ عَ كُي.»
\b
\q1 
\v 15 مَرِفِ عَلَ نَشَن قِندِشِ عِسِرَيِلَ سّنِيّنتْي رَ، عَ شَ مَسٍنيِ نَن يَ؛
\q1 «شَ وٌ فبِلٍن ﭑ مَ، وٌ قَ وٌ رَشَرَ،
\q1 ﭑ وٌ رَكِسِمَ نّ.
\q1 شَ وٌ دْشْ، وٌ قَ وٌ تَشُ ﭑ نَ،
\q1 ﭑ سّنبّ قِمَ نّ وٌ مَ.
\q1 كْنْ وٌ مُ تِن نَ رَ.
\q1 
\v 16 وٌ نَشّ، ‹عَدٍ، مُشُ تَن مُشُ فِمَ سٌييٍ نَن قَرِ.›
\q1 عَوَ يِرٍ، وٌ قَمَ فِدٍ.
\q1 وٌ نَشّ، ‹مُشُ تَن مُشُ فِمَ سٌي شُلُنشِيٍ نَن قَرِ.›
\q1 عَوَ يِرٍ، كْنْ وٌ كٍرِ مَيٍ شُلُن وٌ بّ.
\q1 
\v 17 وٌ وُلُ كٍرٍن، وٌ فِمَ نّ وٌ يَشُي كٍرٍن يَ رَ.
\q1 شَ يَشُي سُولِ نَ عَ رَ، وٌ بِرِن وٌ فِمَ نّ،
\q1 وٌ قَ لُ عَلْ فٍيَ وُرِ كٍرٍن فبَنسَن تِشِ نَشَن قَرِ.»
\q1 
\v 18 كْنْ نَ كُي عَلَتَلَ نَ مَمّ تِقٍ عَلَكٌ عَ شَ هِننّ وٌ رَ.
\q1 عَ قَمَ نّ كٍلِدٍ، عَ كِنِكِنِ وٌ مَ،
\q1 بَرِ مَ عَلَتَلَ تِنشِن.
\q1 سّيوّ نَ مِشِ بّ، نَشَن عَ شَشِلِ تِشِ عَ رَ.
\b
\q1 
\v 19 سِيٌنِكَيٍ، وٌ تَن نَشٍيٍ سَبَتِشِ دَرِ سَلَمُ،
\q1 وٌ مُ يَيٍ رَ مِنِمَ سْنْن.
\q1 وٌ نَ عَ شِلِ، عَ هِننّمَ نّ وٌ رَ،
\q1 عَ نَ وٌ شُي مّ، عَ وٌ يَابِمَ نّ كٍرٍن نَ.
\q1 
\v 20 هَلِ وٌ مَرِفِ عَ نِيَ وٌ شَ لُ قٍ شْرْشْي كُي،
\q1 وٌ كَرَ مْشْييٍ مُ عٍ نْشُنمَ وٌ مَ سْنْن،
\q1 وٌ قَمَ نّ عٍ تٌدٍ وٌ يَيٍ رَ.
\q1 
\v 21 وٌ نَ سِفَ يِرٍقَنيِ مَ، وٌ نَ سِفَ كْولَ مَ،
\q1 وٌ قَمَ نّ مَسٍنيِ مّدٍ وٌ شَنبِ رَ نَشَن عَ قَلَمَ وٌ بّ،
\q1 «كِرَ قَنيِ نَن يَ، وٌ شَ وٌ حّرّ عَ شْن مَ.»
\q1 
\v 22 نَ كُي وٌ شَ كُيٍ نَشٍيٍ يَءِلَنشِ فبٍتِ نُن شّيمَ رَ،
\q1 وٌ قَمَ نّ نٍيٍ وٌلِدٍ عَلْ سٍ سّنِيّنتَرٍيٍ،
\q1 وٌ قَ عَ قَلَ، «وٌ كٍلِ بٍ!»
\b
\q1 
\v 23 نَ تّمُي عَلَتَلَ تُنّ رَقَمَ نّ وٌ شَ سَنسِيٍ مَ،
\q1 وٌ شَ بْشِ دَشَمُي فبٌمَ نّ.
\q1 نَ تّمُي وٌ شَ شُرُ سٍيٍ سِفَمَ نّ عٍ دّ مَدٌندٍ قِيلِ شُنفبٍيٍ مَ.
\q1 
\v 24 نِنفٍ نُن سٌقَلٍ نَشٍيٍ شّ بُشَمَ،
\q1 عٍ قَمَ سٍ قَنيِ نَن دٌندٍ نَشَن نَقَلَشِ عٍ بّ.
\q1 
\v 25 شُرٍيٍ وُيَمَ نّ وٌ شَ فٍيَيٍ قَرِ.
\q1 نَ تّمُي قَشّ شُنفبٍ نَن تِمَ،
\q1 يِرٍ سّنبّمَ عِتٍشِيٍ رَبِرَ مَ نّ.
\q1 
\v 26 عَلَتَلَ قَمَ نّ عَ شَ حَمَ شَ مَشْنّيٍ نُن قِيٍ رَيَلَندٍ.
\q1 نَ لْشْي كِكٍ يَنبَمَ نّ عَلْ سٌفٍ،
\q1 سٌفٍ شَ يَنبّ قَن شُن مَسَمَ نّ دْشْ سٌلٌقٍرٍ.
\b
\q1 
\v 27 عَلَتَلَ نَ قَقٍ كٍلِقٍ يِرٍ مَكُيٍ،
\q1 عَ شْنْشِ عَ شْرْشْي رَ، عَ قَمَ نّ تُورِ بٍلٍبٍلٍ كُي.
\q1 تّ مِنِمَ نّ عَ كّرّ كُي شْنّ شَ قٍ رَ.
\q1 
\v 28 عَ حّنفِ لُشِ نّ عَلْ بَنبَرَنيِ نَشَن تٍمَ هَن مِشِ كْنيِ.
\q1 عَ حَمَنّيٍ سُشُمَ نّ،
\q1 عَ كَرَقٌي سَ عٍ مَ، عَ سٍ ندٍ رَ سٌ عٍ بَنفَنيِيٍ رَ،
\q1 عَ عٍ شَنِن يِرٍ عٍ مُ وَ مَ سِفَقٍ دّننَشّ.
\b
\q1 
\v 29 كْنْ وٌ تَن بّيتِ بَمَ نّ نَ لْشْي عَلْ سَلِ تّمُي،
\q1 وٌ بْحّيٍ سّيوَ مَ نّ عَلْ مِشِ نَشٍيٍ شُلٍ قٍمَ سِفَقٍ رَ عَلَتَلَ شَ فٍيَ قَرِ،
\q1 عَلَتَلَ نَشَن لُشِ عَلْ قَنيٍ عِسِرَيِلَ بّ.
\q1 
\v 30 عَلَتَلَ عَ شُي شَاحّ رَ مِنِمَ نّ،
\q1 عَ عَ سّنبّ مَسٍنمَ نّ شْنّ بٍلٍبٍلٍ نُن تّ كَسَرّ رَ.
\q1 عَ قَمَ نّ سٍسَرِنيِ، فَلَنيِ، تُنّ شُنفبٍ، تُرُننَادّ، نُن بَلَبَلَنيِ رَ.
\q1 
\v 31 عَلَتَلَ شُي قَمَ نّ عَسِرِيَكَيٍ بُتُشُندٍ،
\q1 عَ عٍ رَبِرَ عَ شَ مَنفّيَ رَ.
\q1 
\v 32 عَ نَ عٍ بْنبْ وُرِ شْرْشْي رَ تّمُي نَشّ،
\q1 عَ شَ حَمَ بّيتِ بَمَ نّ مَشَسٍيٍ نُن كْرَيٍ شُي رَ.
\q1 
\v 33 تّ يِرٍ بَرَ يَءِلَن مَنفّ شِلِ مَ عَ رَكُيَ.
\q1 عَ تِلِن، عَ عِفبٌ.
\q1 يٍفٍ فبٍفبٍ مَلَنشِ نَ تّ بٍلٍبٍلٍ شَ قٍ رَ.
\q1 عَلَتَلَ حّنفِ لُشِ نّ عَلْ تّ حَاشِ نَشَن فَنمَ عَ قَنيِ رَ.
\c 31
\s1 مِسِرَ شَ مَلِ
\q1 
\v 1 حَشَنكَتّ نَ وٌ بّ،
\q1 وٌ تَن نَشٍيٍ وٌ يّتّ تَشُمَ مِسِرَ رَ،
\q1 وٌ تَن نَشٍيٍ لَمَ عٍ شَ سْورِ رَفِسٍ وُيَشِيٍ رَ،
\q1 وٌ تَن نَشٍيٍ عٍ شَ سٌي رَفِمَيٍ مَتٌمَ.
\q1 وٌ مُ عِسِرَيِلَ شَ سّنِيّنتْي قٍنمَ،
\q1 وٌ مُ وَ مَ عَلَتَلَ شَ مَلِ شْن مَ.
\q1 
\v 2 كْنْ عَلَ شَشِلِ نَن فبٌ،
\q1 عَ قَتَ حَشَنكَتّ رَفٌرٌدٍ مِشِيٍ مَ.
\q1 عَ شُي مُ كَنَمَ.
\q1 عَ كٍلِمَ حَمَ حَاشِ شِلِ مَ،
\q1 نَشٍيٍ مِشِ كٌبِيٍ مَلِمَ.
\q1 
\v 3 مِسِرَكَيٍ مُ قِندِشِ عَلَ رَ،
\q1 عَدَ مَدِيٍ نَن تُن نَ عٍ رَ.
\q1 عٍ شَ سٌييٍ مُ قِندِشِ شَشِلِ شَ رَ،
\q1 سُبٍ نَن تُن نَ عٍ رَ.
\q1 عَلَتَلَ نَ كٍلِ تّمُي نَشّ مِشِيٍ شِلِ مَ،
\q1 نَشَن مَلِ تِمَ يٌ، نَشَن مَلِ قٍنمَ يٌ،
\q1 عَ عٍ بِرِن هَلَكِمَ نّ.
\b
\q1 
\v 4 عَلَتَلَ شَ مَسٍنيِ نَن يَ؛
\q1 «يّتّ نَ يِرِندِن عَ شَ سُبٍ سُشُشِ شُن مَ،
\q1 هَلِ شُرُ سٍ دّ مَدٌنيِ فبٍفبٍيٍ كَتَمَ نّ عَ كٍرِدٍ،
\q1 عَ مُ فَاشُمَ عٍ شَ سْنشْي رَتٍ يَ رَ،
\q1 عَ مُ كٍلِمَ نَ سُبٍ شُن مَ قٍقٍ مَ.
\q1 عَلَتَلَ سّنبّمَ قَن فٌرٌ مَ نّ فٍرٍ سٌدٍ سِيٌنِ فٍيَ قَرِ نَ كِ نّ.
\q1 
\v 5 عَلَتَلَ سّنبّمَ دَرِ سَلَمُ مَكَنتَمَ نّ،
\q1 عَلْ شْنِ عَ فَبُتٍنيِيٍ عِتَلَمَ عَ يْرّيٍ شُن مَ كِ نَشّ،
\q1 عَ عٍ كَنتَ، عَ عٍ رَكِسِ، عَ عَ تِ عٍ شُن مَ.»
\p 
\v 6 عِسِرَيِلَكَيٍ، وٌ شَ فبِلٍن عَلَ مَ وٌ بَرَ وٌ مَكُيَ نَشَن نَ.
\v 7 نَ لْشْي وٌ قَمَ نّ وٌ شَ كُيٍيٍ رَبّحِندٍ وٌ نَشٍيٍ يَءِلَنشِ فبٍتِ نُن شّيمَ رَ يُنُبِ شَ قٍ رَ.
\q1 
\v 8 «عَسِرِيَكَيٍ قَمَ نّ سْنتْدٍ سَنتِدّفّمَ رَ،
\q1 نَشَن مُ قَتَنشِ حّنفِ كَنيِ رَ.
\q1 عٍ عٍ فِمَ نّ نَ يَ رَ، عٍ شَ قٌنِكٍيٍ شَنِنمَ نّ كٌنيِيَ كُي.
\q1 
\v 9 عٍ شَ يِرٍ مَكَنتَشِ بِرَ مَ نّ فَاشُي كُي،
\q1 لِمَنِيَ بَمَ نّ عٍ شَ سْورِ مَنفّيٍ يِ رَ فٍرٍ قَ تّمُي.»
\q1 عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ،
\q1 نَشَن نَ فٍرٍ تّ رَدّشّمَ سِيٌنِ فٍيَ مَ دَرِ سَلَمُ كُي.
\c 32
\s1 مَنفّيَ تِنشِنشِ
\q1 
\v 1 مَنفّ قَمَ نّ مَنفّيَ رَحّرّدٍ تِنشِنيِ رَ،
\q1 عَ شَ كُنتِفِيٍ كِيتِ سَمَ نّ سّرِيّ كِ مَ.
\q1 
\v 2 كَنكَن لُمَ نّ عَلْ بَنشِ قَنيِ تُرُننَادّ دِنمَ نَشَن نَ،
\q1 عَلْ شُرٍ نَشٍيٍ يٍ شَنِنمَ فبٍنفبٍرٍن يِرٍ،
\q1 عَلْ فّمّ نِينِ بْشِ عِشَرَشِ مَ.
\q1 
\v 3 نَ تّمُي يَ نَشٍيٍ سٍ قٍنمَ، نٍيٍ سٍ عِفبّمَ نّ.
\q1 تُلِ نَشٍيٍ عٍ مَتِمَ، نٍيٍ قٍ مّمَ نّ.
\q1 
\v 4 شَشِلِتَرٍيٍ قَمَ نّ قَهَامُي سْتْدٍ،
\q1 بٌبٌي نّنيِ قَمَ نّ كٍلِدٍ، نٍيٍ قَ وْيّن عَ قَنيِ رَ.
\q1 
\v 5 مِشِ كٌبِ مُ شِلِمَ كُنتِفِ،
\q1 مِشِ تِنشِنتَرٍ مُ بِنيّ سْتْمَ سْنْن،
\q1 
\v 6 بَرِ مَ عٍ مُ نْندِ قَلَمَ،
\q1 عٍ مُ قٍ قَنيِ مَحْشُنمَ.
\q1 عَ قٍ سّنِيّنشِ بْتّ رَبَمَ،
\q1 عَ وُلٍ قَلَمَ عَلَتَلَ شَ قٍ رَ،
\q1 عَ كَامّتْي لُمَ عَ شَ كَامّ كُي،
\q1 عَ تٌندِ يٍ مَ مِشِ بّ، يٍ شْلِ نَ نَشَن مَ.
\q1 
\v 7 مِشِ حَاشِ وَلِ كِ مُ قَن،
\q1 عَ عَ مَتٌ عَ مِسِكِينّ شُن نَكَنَمَ تْوحّفّ رَ كِ نَشّ.
\q1 
\v 8 كْنْ مِشِ قَنيِ تَن عَ مَتٌمَ نّ عَ قٍ قَنيِ رَبَمَ كِ نَشّ،
\q1 عَ شُن نَكٍلِ عَ شَ وَلِ قَنيِ سَابُي رَ،
\b
\q1 
\v 9 بَننَ فِنّيٍ، وٌ شَ وٌ تُلِ مَتِ ﭑ شُي رَ.
\q1 وٌ تَن نَشٍيٍ لَشِ وٌ يّتّ رَ، وٌ شَ ﭑ مَ مَسٍنيِ رَ مّ.
\q1 
\v 10 بٍينُن حّ كٍرٍن شَ دَنفِ، وٌ سّرّنمَ نّ فَاشُي رَ،
\q1 وٌ تَن نَشٍيٍ لَشِ وٌ يّتّ رَ،
\q1 بَرِ مَ وّنِ بٌفِيٍ كَنَمَ نّ،
\q1 شّ شَبّ قَن مُ قَنمَ.
\q1 
\v 11 بَننَ فِنّيٍ، وٌ شَ وٌ مَفٌرٌ،
\q1 وٌ تَن نَشٍيٍ لَشِ وٌ يّتّ رَ، وٌ شَ فَاشُ.
\q1 وٌ شَ وٌ شَ دُفِ قَنيِ مَسَرَ كَاحّ دُفِ رَ.
\q1 
\v 12 وٌ شَ وَ وٌ شَ وّنِ بٌفِ نُن شّ كَنَشِيٍ شَ قٍ رَ.
\q1 
\v 13 وٌ شَ وَ ﭑ مَ حَمَ شَ بْشِ شَ قٍ رَ،
\q1 نَشَن بَرَ قِندِ حٌوفٍ نُن تُنبٍ يِرٍ رَ.
\q1 وٌ شَ وَ وٌ شَ تَايٍ شَ قٍ رَ حّلّشِنيِ حْنشِ دّننَشّ.
\q1 
\v 14 وٌ شَ يِرٍ مَكَنتَشِ رَبٌلٌمَ نّ،
\q1 وٌ شَ تَا قَنيِ قِندِ مَ نّ وُلَ رَ،
\q1 سٌقَلٍ نُن شُرُ سٍيٍ دّ مَدٌنمَ دّننَشّ.
\q1 
\v 15 عَ لُمَ نَ كِ نّ هَن عَلَ عَ شَشِلِ سّنِيّنشِ رَفٌرٌ مَ وٌن مَ تّمُي نَشّ كٍلِ كٌورٍ مَ.
\q1 نَ تّمُي نَ فبٍنفبٍرٍنيِ قِندِ مَ نّ سَنسِ يِرٍ رَ،
\q1 عَ فبٌ يّ عَلْ قْتْنيِ.
\q1 
\v 16 سّرِيّ رَحّرّ مَ نّ فبٍنفبٍرٍنيِ مَ،
\q1 تِنشِنيِ قَن سَبَتِمَ نّ سَنسِ يِرٍ.
\q1 
\v 17 تِنشِنيِ شَ وَلِ قِندِ مَ بْحّسَ نَن نَ،
\q1 عَ قِندِ شَشِلِسَ نُن كَنتَرِ رَ وَشَتِ بِرِن.
\q1 
\v 18 ﭑ مَ حَمَ لُمَ نّ نَا بْحّسَ كُي، مَرَشَرّ كُي.
\q1 
\v 19 هَلِ قْتْنيِ كَنَ، تَا بِرَ،
\q1 
\v 20 هّيرِ نَن لُمَ وٌ بّ،
\q1 وٌ تَن نَشٍيٍ سَنسِ سِمَ شُرٍ دّ رَ،
\q1 وٌ تَن نَشٍيٍ تِنمَ وٌ شَ نِنفٍيٍ نُن وٌ شَ سٌقَلٍيٍ شَ عٍ دّ مَدٌن.
\c 33
\s1 فبَلٌي نُن كِسِ
\q1 
\v 1 حَشَنكَتّ نَ عِ بّ، عِ تَن نَشَن فبَلٌي رَبَمَ.
\q1 حَشَنكَتّ نَ عِ بّ، عِ تَن نَشَن يَنقّ تِمَ.
\q1 عِ نَ فّ نَ رَبَدٍ، عِ شُن قَ رَكَنَ، يَنقّ فبِلٍن عِ مَ.
\b
\q1 
\v 2 عَلَتَلَ هِننّ مُشُ رَ، مُشُ شَشِلِ تِشِ عِ تَن نَن نَ.
\q1 عِ شَ مُشُ سّنبّ شُن مَسَ، عِ شَ مُشُ رَتَنفَ قٍ شْرْشْي مَ.
\q1 
\v 3 سِيٍ عٍ فِمَ نّ عِ شُي يَ رَ،
\q1 حَمَنّيٍ يٍنسٍنمَ نّ عِ شَ فٍرٍ شُي رَ.
\b
\q1 
\v 4 وٌ تَن سِيٍ، مِشِيٍ قَمَ نّ وٌ شَ نَاقُلِ سُشُدٍ،
\q1 عَلْ كَتٌي دِنمَ شّ رَ كِ نَشّ.
\b
\q1 
\v 5 وٌ تَن سِيٌنِكَيٍ، عَلَتَلَ فبٌ، عَ سَبَتِشِ كٌورٍ نَن مَ.
\q1 عَ تِنشِنيِ نُن نْندِ قِمَ نّ وٌ مَ.
\q1 
\v 6 عَ وٌ بُن تِ.
\q1 عَ كِسِ، شَشِلِ قَنيِ، نُن قَهَامُي رَفَتَمَ نّ وٌ بّ،
\q1 وٌ تَن نَشٍيٍ فَاشُمَ عَ يَ رَ.
\b
\q1 
\v 7 وٌ عَ مَتٌ، حَلَمَيٍ نُن شّيرَيٍ نَ وَقٍ تَندٍ.
\q1 
\v 8 مِشِ يٌ مُ تٌمَ كِرَيٍ مَ سْنْن.
\q1 سَاتّ بَرَ كَنَ، سَاتّ سٍيدٍيٍ بَرَ يَافِ، بِنيّ يٌ مُ نَ سْنْن.
\q1 
\v 9 بْشِ نَ سُننُنيِ نُن هَلَكِ نَن كُي.
\q1 لِبَن شَ مّرّ بَرَ مَشَرَ،
\q1 بَسَن نُن كَرٍ مٍلٍ قْتْنيِ بُرّشّيٍ نَ يٌلٌنقٍ.
\b
\q1 
\v 10 عَلَتَلَ نَشّ، «يَكْسِ ﭑ كٍلِمَ نّ قَ، وٌ قَ ﭑ مَتْشْ.
\q1 
\v 11 وٌ تٌ نَتّ قُقَقُ تٌنفٌ، وٌ مَن قٍ قُقَقُ نَن سْتْمَ.
\q1 وٌ حّنفِ لُشِ نّ عَلْ تّ نَشَن قَمَ وٌ فَندٍ.
\q1 
\v 12 تّ دِنمَ نّ سِيٍ رَ، عٍ فَن عَلْ تُنبٍ مَسّفّشِ، سٍسٍ مُ لُ.»
\b
\q1 
\v 13 وٌ تَن نَشٍيٍ مَكُيَ ﭑ نَ، وٌ شَ وٌ تُلِ مَتِ ﭑ مَ قٍ رَبَشِيٍ رَ.
\q1 وٌ تَن نَشٍيٍ مَكْرّ ﭑ نَ، وٌ شَ لَ ﭑ سّنبّ رَ.
\q1 
\v 14 يُنُبِتْي نَشٍيٍ نَ سِيٌنِ، عٍ بَرَ فَاشُ.
\q1 عَلَتَلَ يَشُييٍ بَرَ سّرّن قْلْ.
\q1 «ندٍ نْمَ لُدٍ تّ كَسَرَتِ سّيتِ مَ؟
\q1 ندٍ رَتَنفَمَ تّ شُبٍنتَرٍ مَ وٌن يَ مَ؟»
\q1 
\v 15 مِشِ نَن عَ رَ نَشَن حّرّ مَ تِنشِنيِ رَ،
\q1 نَشَن نْندِ قَلَمَ، نَشَن تٌندِ مَ فٍينِ سْتْ كِ حَاشِ رَ،
\q1 نَشَن مُ عَ بّلّشّ عِتَلَمَ بُحَ كٌبِ بّ،
\q1 نَشَن مُ عَ تُلِ مَتِمَ مِشِ قَشَقٍ نَتّ تٌنفٌي رَ،
\q1 نَشَن مُ عَ شَشِلِ تِمَ قٍ حَاشِ رَ.
\q1 
\v 16 نَ مِشِ مْولِ تَن سَبَتِمَ نّ فٍيَ قَرِ يِرٍ مَكَنتَشِ كُي،
\q1 عَ بَلٌي نُن يٍ سْتْ عَ قَنيِ رَ.
\b
\q1 
\v 17 وٌ يَيٍ مَنفّ تٌمَ نّ عَ شَ تٌقَنيِ كُي،
\q1 وٌ مَن قَ بْشِ تٌ نَشَن شَ فبٌي مُ حْنمَ.
\q1 
\v 18 وٌ رَتُمَ نّ وٌ فَاشُ كِ مَ، عَ قَلَقٍ رَ،
\q1 «نَ مَنفّ نَ مِندٍن؟ دُوتِ مَشِلِ فٌ؟ يِرٍ مَكَنتَشِ شُنمَتٌ فٌ؟»
\q1 
\v 19 وٌ مُ قَمَ نَ بْنسْي يّتّ عِفبٌي تٌدٍ سْنْن،
\q1 نَشٍيٍ شَ شُي قَهَامُقٍ شْرْشْ.
\b
\q1 
\v 20 سِيٌنِ مَتٌ، وٌن مَ سَلِ رَبَمَ دّننَشّ.
\q1 مّننِ وٌ دَرِ سَلَمُ تٌمَ نّ،
\q1 تَا نَشَن نَشَرَشِ، حَمَ نَشَن مُ تَلَمَ عٍ شْنيِ سْنْن.
\q1 
\v 21 وٌن مَرِفِ سّنبّمَ لُمَ نّ نَا وٌن يَ مَ شُرٍيٍ سّيتِ مَ.
\q1 وٌن يَشُييٍ مُ نْمَ تِدٍ نَ شُرٍيٍ مَ عٍ شَ كُنكُييٍ كُي،
\q1 
\v 22 بَرِ مَ عَلَتَلَ نَن نَ وٌن مَ كِيتِسَ رَ،
\q1 عَ سّرِيّ يَتِ نَن قِمَ وٌن مَ.
\q1 عَلَتَلَ نَن نَ وٌن مَ مَنفّ رَ،
\q1 عَ وٌن نَتَنفَمَ قٍ حَاشِ نَن مَ.
\b
\q1 
\v 23 وٌ تَن سِيٍ، وٌ شَ لُوتِيٍ بَرَ يْنتْن،
\q1 وٌ شَ كُنكُي وُرِ مُ تِشِ،
\q1 وٌ شَ بّلَ مُ فّشِ عِتَلَدٍ.
\q1 نَ كُي وٌ شَ نَاقُلِ قَمَ نّ شَنِندٍ،
\q1 هَلِ مَبّنيِيٍ نْمَ نَ رَبَدٍ.
\q1 
\v 24 سِيٌنِكَ يٌ مُ عَ قَلَمَ، «ﭑ مُ يَلَنشِ.»
\q1 عٍ شَ يُنُبِيٍ قَمَ نّ شَقَرِدٍ.
\c 34
\s1 عٍدٌن شَ كِيتِ
\q1 
\v 1 وٌ وٌ مَسٌ، وٌ تَن حَمَنّيٍ، عَلَكٌ وٌ شَ وٌ تُلِ مَتِ.
\q1 سِيٍ، وٌ شَ وٌ تُلِ مَتِ ﭑ نَ عَ قَنيِ رَ.
\q1 دُنِحَ حَمَ بِرِن شَ عٍ تُلِ مَتِ ﭑ مَ مَسٍنيِ رَ،
\q1 
\v 2 بَرِ مَ عَلَتَلَ شْنْشِ حَمَنّ نُن عٍ شَ سْورِ فَالِ بِرِن مَ.
\q1 عَ قَمَ نّ دِندٍ عٍ رَ، عَ عٍ رَتْن.
\q1 
\v 3 عٍ شَ مِشِ قَشَشِيٍ مُ رَفَتَمَ.
\q1 عٍ بِنبِيٍ بْرْ مَ نّ، عٍ شِرِ قَ تٍ كٌورٍ مَ.
\q1 عٍ وُلِ عِقِلِمَ نّ فٍيَيٍ مَ.
\b
\q1 
\v 4 هَلِ تُنبُي نَشٍيٍ نَ كٌورٍ مَ، عٍ بِرَ مَ نّ،
\q1 عَلْ بُرّشّيٍ نُن شْرّيٍ بِرَ مَ كِ نَشّ.
\q1 كٌورٍ وَلَشّ مَكُنتَنمَ نّ عَلْ دَفِ.
\q1 
\v 5 عَلَتَلَ نَشّ، «ﭑ مَ سَنتِدّفّمَ نَ فّ نَ وَلِ رَ،
\q1 عَ فٌرٌ مَ نّ عٍدٌن حَمَ شِلِ مَ،
\q1 ﭑ قَ عٍ سْنتْ كِيتِ شَ قٍ رَ.»
\q1 
\v 6 وُلِ نَ عَلَتَلَ شَ سَنتِدّفّمَ مَ.
\q1 عَ بَرَ فّ سّرّشّ كْن نَشَبَدٍ عَ رَ،
\q1 شُرُ سٍيٍ وُلِ نُن تُرٍ نَ عَ مَ.
\q1 عَلَتَلَ نَ سّرّشّ ندٍ كْن نَشَبَقٍ بٌسَرَ،
\q1 عَ نَ قَشّ تِقٍ عَ حَاشِ رَ عٍدٌن بْشِ مَ.
\q1 
\v 7 حَمَ سْنتْمَ نّ، سّشّ نِنفٍيٍ نُن تُورَيٍ قَن قَشَ،
\q1 هَن بْشِ يَتِ بَرَ نْشْ نَ وُلِ بِرِن نَ.
\q1 
\v 8 عَلَتَلَ شَ نَتّ نَن نَ كِ،
\q1 عَلَكٌ سِيٌنِ فبٍ شَ حْشْ عٍدٌن شَ يَشُيَ شَ قٍ رَ.
\q1 
\v 9 عٍدٌن شَ شُرٍيٍ نُن بْشِ لُمَ نّ عَلْ دٌلٍ، عَ قَ لُ فَن نَ.
\q1 
\v 10 عَ مُ شُبٍنمَ كْي نُن يَنيِ رَ،
\q1 عَ تُورِ لُمَ نّ تٍ رَ تُن.
\q1 مّننِ قِندِ مَ فبٍنفبٍرٍنيِ يِرٍ نَن نَ عَبَدَن،
\q1 مِشِ يٌ مُ دَنفِمَ نَا سْنْن.
\q1 
\v 11 شْنِ نُن وُلَءِ سُبٍ مْولِ بِرِن لُمَ نّ نَا.
\q1 عَلَتَلَ بَرَ نَتّ تٌنفٌ مّننِ شَ قِندِ فبٍنفبٍرٍن يِرٍ رَ.
\q1 
\v 12 مّننِ مَنفّ مُ سٍسٍ تٌمَ نَا عٍ يَمَرِ مَ رَبَمَ نَشَن شُن نَ،
\q1 عٍ شَ كُنتِفِيٍ يٍنسٍنمَ نّ قٍوٌ.
\q1 
\v 13 مّننِ شَ يِرٍ مَكَنتَشِيٍ قِندِ مَ تُنبٍيٍ يِرٍ،
\q1 عٍ شَ تَايٍ لُمَ نّ عَلْ وُلَءِ، وُلٍ بَرٍيٍ نُن شْنِيٍ لُمَ دّننَشّ.
\q1 
\v 14 وُلَءِ سُبٍيٍ مْولِ بِرِن سَبَتِمَ نَا،
\q1 
\v 15 بْشِمَسٍ عَ شَلّ سَمَ نّ نَا،
\q1 عَ قَ عٍ رَ سّفّ، عَ عٍ كَنتَ.
\q1 هَلِ يُبّيٍ سَبَتِمَ مّننِ نّ، عٍ قَ دِيٍ رَ سّفّ.
\q1 
\v 16 عَلَتَلَ شَ سّبّلِ مَتٌ عَ قَنيِ رَ.
\q1 يِ سُبٍ بِرِن قَمَ نّ لُدٍ نَا، عٍ قَ وُيَ.
\q1 عَلَتَلَ بَرَ نَ نَتّ تٌنفٌ، عَ شَشِلِ يَتِ قَمَ نّ نَ رَكَمَلِدٍ.
\q1 
\v 17 عَ تَن نَن يَتِ عٍ شَ قٍ مَتٌمَ، عَ نَ بْشِ عِتَشُن عٍ رَ،
\q1 عَ قَ قِندِ عٍ فبٍ رَ عَبَدَن.
\c 35
\s1 عَلَ شَ كِرَ
\q1 
\v 1 حّلّشِنيِ شَ لُ فبٍنفبٍرٍن يِرٍ،
\q1 سّيوّ شَ لُ وُلَءِ عَلْ سَنسِ قُفَشِيٍ يِرٍ.
\q1 
\v 2 سَنسِ تٌقَنيِيٍ شَ لُ نَا،
\q1 سّيوّ شُي شَ عِتٍ.
\q1 عَ شَ لُ عَلْ لِبَن قْتْنيِ، عَ شَ تٌقَن عَلْ كَرٍ مٍلٍ فٍيَ نُن سَرْن يِرٍ.
\q1 وٌن مَرِفِ عَلَتَلَ شَ نْرّ تٌمَ نّ نَا عَ قَنيِ رَ.
\b
\q1 
\v 3 وٌ تَن نَشٍيٍ بَرَ فَاشُ هَن وٌ بّلّشّ مُ سٍ سُشُمَ، وٌ شِنبِ قَ سّرّن،
\q1 وٌ سّنبّ شَ سٌ.
\q1 
\v 4 وٌ عَ قَلَ مِشِيٍ بّ نَشٍيٍ بَرَ فَاشُ،
\q1 «وٌ شَ لِمَنِيَ، هَلِ وٌ مُ فَاشُ!
\q1 وٌ مَرِفِ عَلَ بَرَ قَ وٌ فبٍ حْشْدٍ.
\q1 عَ قَمَ وٌ رَكِسِدٍ عَ سّنبّ رَ.»
\q1 
\v 5 نَ تّمُي، دْنشُييٍ يَ رَبْو مَ نّ، تُلِشْرِيٍ قٍ مّمَ نّ.
\q1 
\v 6 مَبّنيِيٍ تُفَنمَ نّ عَلْ شٍلِ، بٌبٌي قَن سّيوّ شُي رَ مِنِمَ نّ،
\q1 بَرِ مَ شُرٍيٍ مِنِمَ نّ فبٍنفبٍرٍنيِ مَ.
\q1 
\v 7 بْشِ مَشَرَشِ مَقِندِ مَ نّ بَا رَ،
\q1 دُلٌنيِ مِنِمَ نّ فبٍنفبٍرٍن يِرٍ.
\q1 وُلَءِ بَرٍيٍ شْنيِ بَرَ قِندِ يٍ يِرٍ رَ.
\q1 
\v 8 كِرَ مَبَمَ نَا نَشَن شِلِ قَلَمَ، «كِرَ سّنِيّنشِ.»
\q1 مِشِ سّنِيّنتَرٍ مُ دَنفِمَ مّننِ، قٌ نَشَن لَنمَ عَ شَ دَنفِ نَ.
\q1 شَشِلِتَرٍيٍ مُ تِمَ نَ كِرَ شْن مَ.
\q1 
\v 9 يّتّيٍ نُن بُرُنيِ سُبٍ مُ تٌمَ نَا، قٌ لَسِرِ مِشِ.
\q1 
\v 10 عَلَتَلَ نَشٍيٍ شْرّيَشِ، نٍيٍ نَن فبِلٍنمَ عٍ شْنيِ نَ كِرَ شْن مَ.
\q1 عٍ سٌمَ نّ سِيٌنِ سّيوّ رَ نَشَن مُ حْنمَ.
\q1 عٍ حّلّشِنمَ نّ تُن.
\q1 سُننُنيِ نُن تْورّ بَمَ نّ عٍ مَ عَبَدَن.
\c 36
\s1 عَسِرِيَ مَنفّ شَ مَسٍنيِ
\p 
\v 1 مَنفّ شٍسٍكِيَ شَ مَنفّيَ حّ قُ نُن نَانِ ندٍ رَ، عَسِرِيَ مَنفّ سٍنَشٍرِبِ نَشَ نْ يُدَيَ تَا سّنبّمَيٍ رَ.
\v 2 عَ تٌ فّ نَ رَبَدٍ، عَسِرِيَ مَنفّ نَشَ عَ شَ سْورِ مَنفّ شّي دَرِ سَلَمُ مَنفّ شْن مَ، كٍلِقٍ رَ لَكِسِ، عَ تَن نُن عَ شَ سْورِ سّنبّمَيٍ. عٍ نَشَ تِ يٍ يِرٍ شُنفبٍ قّ مَ، مِشِيٍ نُ فَرّ سٌمَ دّننَشّ.
\v 3 شِلِكِيَ شَ دِ عٍلِيَكِمِ، مَنفّ شَ بَنشِ شُنيِ، مَنفّ شَ سّبّلِتِ سٍبٍنَ، نُن عَسَقِ شَ دِ يٌوَ، نَشَن قِندِشِ مَنفّ شَ كّيدِ رَفَتّ رَ، نٍيٍ نَشَ مِنِ عَسِرِيَكَيٍ رَلَندٍ.
\p 
\v 4 عَسِرِيَ مَنفّ رَ سِمَ سِنفٍ نَشَ يِ مَسٍنيِ تِ عٍ بّ، «وٌ عَ قَلَ شٍسٍكِيَ بّ، عَسِرِيَ مَنفّ شُنفبٍ يِ نَن مَسٍنشِ، ‹عِ شَشِلِ تِشِ مُنسٍ رَ؟
\v 5 عِ وْيّن قُقَقُ نَن تُن قَلَشِ! عِ حْشْ عَ مَ عِ بَرَ قّيرّ نُن سّنبّ سْتْ ﭑ فٍرٍقٍ رَ؟ عِ لَشِ ندٍ رَ، نَشَن عَ نِيَمَ عِ شَ ﭑ مَتَندِ؟
\v 6 عِ عِ شَ لَنلَنتٍيَ سَشِ مِسِرَكَيٍ نَن مَ قَ؟ عٍ لُشِ عَلْ وُرِ ثٌنثٌي نَشَن فِرَ مَ، عَ قَ عِ سْشْ عِ كِلْنمَ عَ رَ تّمُي نَشّ. مِسِرَ مَنفّ قِرَوُنَ نَ نَ كِ نّ مِشِ بِرِن بّ، نَشٍيٍ عٍ شَشِلِ تِشِ عَ رَ.
\v 7 تّمُندٍ وٌ ﭑ يَابِمَ نّ، «مُشُ شَشِلِ تِشِ مُشُ مَرِفِ عَلَتَلَ نَن نَ.» كْنْ ﭑ شَ عَ قَلَ وٌ بّ شٍسٍكِيَ بَرَ فّ سّرّشّبَدٍيٍ كَنَدٍ فٍيَيٍ قَرِ، عَ قَ عَ قَلَ يُدَيَكَيٍ نُن دَرِ سَلَمُكَيٍ بّ، «وٌ عَلَتَلَ بَتُ دَرِ سَلَمُ شَ سّرّشّبَدٍ فبَنسَن نّ.»›»
\p 
\v 8 «شَ عِ سَ نْمَ سٌي رَفِ وُلُ قِرِن سْتْدٍ عِ شَ حَمَ يَ مَ، ﭑ مَرِفِ عَسِرِيَ مَنفّ سٌي قِمَ نّ عِ مَ، عٍ نَشٍيٍ رَفِمَ.
\v 9 هَلِ عِ عِ شَشِلِ تِ مِسِرَكَيٍ رَ، سٌي رَفِيٍ نُن فِسٍيٍ شَ قٍ رَ، عِ سّنبّ شُرُن ﭑ مَ مَنفّ شَ مِشِ شُرِ دِ ندٍ نْقٍ رَ.
\v 10 بَقٍ نَ رَ، وٌ مَرِفِ عَلَتَلَ شَ مُ وَشِ ﭑ شَ بٍ فٍرٍ؟ عَلَتَلَ نَن عَ قَلَشِ ﭑ بّ، ‹سِفَ، عِ نَ بْشِ كَنَ.›»
\p 
\v 11 نَ تّمُي عٍلِيَكِمِ، سٍبٍنَ، نُن يٌوَ نَشَ عَ قَلَ عَسِرِيَ مَنفّ رَ سِمَ بّ، «يَندِ، عِ شَ وْيّن مُشُ بّ عَرَ مِ شُي رَ، مُشُ تَن عِ شَ كٌنيِيٍ نَ شُي قَهَامُمَ. عِ نَشَ وْيّن مُشُ بّ يُدَ شُي رَ حَمَ يَ شْرِ نَشَن نَ تّتّ قَرِ مَ.»
\v 12 كْنْ عَسِرِيَ مَنفّ رَ سِمَ نَشَ عٍ يَابِ، «ﭑ مَرِفِ ﭑ شّيشِ يِ مَسٍنيِ قَلَدٍ عِ شَ مَنفّ نُن عِ تَن نَن فبَنسَن بّ؟ ﭑ مُ وْيّنقٍ يِ مِشِيٍ قَن شَ بّ، نَشٍيٍ دْشْشِ تّتّ قَرِ يِ كِ، نَشٍيٍ قَمَ عٍ يّتّ شَ فبِ قُشِ دٌندٍ نُن عٍ يّتّ شْلِ مِندٍ نُن وٌ تَن نَ؟»
\p 
\v 13 مَنفّ رَ سِمَ نَشَ كٍلِ، عَ عَ قَلَ عَ شُي عِتٍشِ رَ يُدَيَ شُي رَ، عَ نَشّ، «وٌ وٌ تُلِ مَتِ عَسِرِيَ مَنفّ شُنفبٍ شَ مَسٍنيِ رَ،
\v 14 ‹وٌ نَشَ تِن شٍسٍكِيَ شَ وٌ مَدَشُ، بَرِ مَ عَ مُ قَتَ وٌ رَتَنفَدٍ ﭑ بّلّشّ عِ!
\v 15 وٌ نَشَ تِن عَ شَ وٌ مَدَشُ وٌ شَشِلِ تِقٍ عَلَتَلَ رَ، عَ قَلَقٍ رَ، «عَلَتَلَ مُشُ رَكِسِمَ نّ، يِ تَا مُ لُمَ عَسِرِيَكَيٍ شَ مَنفّ سَفٌي.»
\v 16 وٌ نَشَ وٌ تُلِ مَتِ شٍسٍكِيَ رَ دٍ! عَسِرِيَ مَنفّ يِ نَن قَلَشِ، «شَ وٌ تِن لُدٍ ﭑ مَ يَامَرِ بُن مَ، كَنكَن قَمَ نّ عَ شَ شّي بٌفِسٍيٍ دٌندٍ، كَنكَن عَ شَ كْلْنيِ يٍ مِن،
\v 17 هَن ﭑ سَ قَمَ وٌ شَنِندٍ بْشِ ندٍ مَ تّمُي نَشّ، نَشَن لُشِ عَلْ وٌ شَ بْشِ، مّنفِ نُن وّنِ قَنيِ، تَامِ نُن وّنِ شّيٍ نَ دّننَشّ.»
\v 18 وٌ نَشَ وٌ تُلِ مَتِ شٍسٍكِيَ رَ، نَشَن وَ مَ وٌ مَدَشُقٍ عَ قَلَقٍ رَ، «مَرِفِ عَلَتَلَ وٌن نَكِسِمَ نّ.» سِ فبّتّيٍ شَ عَلَيٍ نْ نّ عٍ شَ مِشِيٍ بَدٍ عَسِرِيَ مَنفّ بّلّشّ عِ؟
\v 19 شَمَتَ نُن عَرَثَدِ شَ عَلَيٍ فٌ؟ سٍقَرَوَيِمِ، هٍنَ نُن عِوَ شَ عَلَيٍ فٌ؟ نٍيٍ بَرَ سَمَرِ بَ ﭑ بّلّشّ عِ؟
\v 20 حَمَنّيٍ بِرِن شَ عَلَيٍ يَ مَ، عَلَ مُندُن عَ شَ مِشِيٍ رَكِسِشِ ﭑ بّلّشّ عِ؟ عَلَتَلَ تَن نْمَ دَرِ سَلَمُ رَتَنفَدٍ ﭑ مَ؟›»
\p 
\v 21 حَمَ نَشَ دُندُ، عٍ مُ عَ يَابِ، بَرِ مَ مَنفّ عَ قَلَ نّ، «وٌ نَشَ عَ يَابِ دٍ.»
\v 22 شِلِكِيَ شَ دِ عٍلِيَكِمِ، مَنفّ شَ بَنشِ شُنيِ، سٍبٍنَ سّبّلِتِ، نُن عَسَقِ شَ دِ يٌوَ كّيدِ رَفَتّ، نٍيٍ نَشَ سِفَ مَنفّ شٍسٍكِيَ يِرٍ عٍ شَ سٌسٍيٍ عِبْوشِ رَ عٍ مَ سُننُنيِ كُي، عٍ قَ عَسِرِيَ مَنفّ رَ سِمَ شَ مَسٍنيِ دّنتّفّ عَ بّ.
\c 37
\s1 مَنفّ شٍسٍكِيَ مَرَ سِ قٍنقٍ عَننَبِ عٍسَيِ رَ
\p 
\v 1 مَنفّ شٍسٍكِيَ تٌ نَ قٍ مّ، عَ نَشَ عَ شَ دٌنمَ عِبْو عَ مَ، عَ بّكِ دُفِ رَفٌرٌ عَ مَ سُننُنيِ كُي، عَ قَ سِفَ عَلَتَلَ شَ بَنشِ كُي.
\v 2 عَ نَشَ عَ شَ بَنشِ شُنيِ عٍلِيَكِمِ، عَ شَ سّبّلِتِ سٍبٍنَ، نُن سّرّشّدُبّ قٌرِيٍ شّي عَمٌسُ شَ دِ عَننَبِ عٍسَيِ شْن، بّكِ دُفِ رَفٌرٌشِ عٍ مَ.
\v 3 عٍ نَشَ عَ قَلَ عَ بّ، شٍسٍكِيَ يِ نَن قَلَشِ، «تٌ قِندِشِ سُننُنيِ، حَشَنكَتّ، نُن بْحّ مَحَاشُ لْشْي نَن نَ. عَ لُشِ عَلْ دِيٍ بَرِ تّمُي بَرَ عَ لِ، كْنْ سّنبّ مُ نَ سْنْن عٍ شَ بَرِ.
\v 4 عِ مَرِفِ عَلَتَلَ نَ عَسِرِيَ مَنفّ شَ شّيرَ شَ مَسٍنيِ مّ عَلَ حِحّ رَ سْتْقٍ رَ، تّمُندٍ عَ عَ حَشَنكَتَمَ نّ عَ شَ نَ وْيّنيِيٍ مَ. عِ شَ عَلَ مَشَندِ عَلَكٌ وٌن مَ مِشِ دْنشْييٍ نَشَ قَشَ.»
\p 
\v 5 مَنفّ شٍسٍكِيَ شَ مِشِيٍ نَشَ سِفَ عَننَبِ عٍسَيِ يِرٍ.
\v 6 عٍسَيِ نَشَ عَ مَسٍن عٍ بّ، «وٌ عَ قَلَ وٌ شَ مَنفّ بّ، عَلَتَلَ يِ مَسٍنيِ نَن تِشِ، ‹عِ نَشَ فَاشُ عَسِرِيَ مَنفّ شَ شّيرَيٍ شَ مَرَ سْتْييٍ شَ قٍ رَ، عَ نَشٍيٍ قَلَشِ ﭑ بّ.
\v 7 ﭑ قَمَ عَ شَشِلِ مَقِندِدٍ شِبَارُي ندٍ رَ، عَ قَ فبِلٍن عَ شْنيِ. ﭑ عَ قَشَمَ سَنتِدّفّمَ رَ مّننِ نّ.›»
\p 
\v 8 مَنفّ شَ شّيرَ تٌ فبِلٍن عَسِرِيَ مَنفّ يِرٍ، عَ نَشَ عَ لِ عَ شَ مَنفّ نُ بَرَ كٍلِ لَكِسِ، عَ نُ نَ لِبِنَ فٍرٍقٍ.
\v 9 نَ تّمُي عَسِرِيَ مَنفّ نَشَ عَ كٌلٌن عَ كُسِ مَنفّ تِرِهَكَ نَ قَقٍ عَ فٍرٍدٍ. نَ كُي عَ مَن نَشَ شّيرَيٍ شّي شٍسٍكِيَ مَ، عَ قَلَقٍ رَ،
\v 10 «وٌ عَ قَلَ يُدَيَ مَنفّ شٍسٍكِيَ بّ، ‹عِ شَ عَلَ، عِ لَشِ نَشَن نَ، نَ نَشَ عِ مَدَشُ دٍ عَ قَلَقٍ رَ، «دَرِ سَلَمُ مُ لُمَ عَسِرِيَ مَنفّ بّلّشّ عِ.»
\v 11 عِ عَ كٌلٌن عَ قَنيِ رَ عَسِرِيَ مَنفّيٍ نَشَن نَبَشِ حَمَنّيٍ بِرِن نَ. عٍ عٍ سْنتْ نّ عَ حَاشِ رَ. عِ تَن قَ قَمَ عِ بَدٍ ﭑ يِ رَ دِ؟
\v 12 ﭑ بٍنبَيٍ سِ نَشٍيٍ بْنبْ، عٍ شَ عَلَيٍ عٍ رَتَنفَ نّ، عَلْ فٌسَن، شَرَنِ، رٍ سٍقَ، نُن عٍدٍن بْنسْي نَشٍيٍ نَ تٍلِ عَسَرِ؟
\v 13 شَمَتَ مَنفّ، عَرَثَدِ مَنفّ، سٍقَرَوَيِمِ مَنفّ، هٍنَ مَنفّ، نُن عِوَ مَنفّ نَ مِندٍن؟›»
\p 
\v 14 شٍسٍكِيَ نَشَ بَتَاشّ رَ سُشُ شّيرَيٍ يِ رَ، عَ نَشَ عَ شَرَن. نَ دَنفِ شَنبِ، عَ نَشَ تٍ عَلَتَلَ شَ بَنشِ، عَ عَ عِتَلَ عَلَتَلَ يَ عِ.
\v 15 شٍسٍكِيَ نَشَ عَلَتَلَ مَشَندِ، عَ نَشّ،
\v 16 «عِسِرَيِلَ مَرِفِ عَلَتَلَ، نَشَن مَفٌرٌشِ مَلٍكّيٍ تَفِ، عِ تَن نَن نَ دُنِحَ بِرِن مَرِفِ رَ، عِ تَن نَن كٌورٍ نُن بْشِ دَاشِ.
\v 17 عَلَتَلَ، عِ عِ تُلِ مَتِ عَ قَنيِ رَ، عِ شَ سٍنَشٍرِبِ شَ مَسٍنيِ رَ مّ، نَشَن عَ شَ مِشِ شّيشِ عَلَ حِحّ رَ سْتْدٍ.
\v 18 عَلَتَلَ، نْندِ نَ عَ رَ، عَسِرِيَ مَنفّيٍ بَرَ سِ بِرِن سْنتْ، عَ عٍ شَ قٍ شُن نَكَنَ.
\v 19 عٍ نَشَ نٍيٍ شَ عَلَيٍ وٌلِ تّ عِ، عٍ عٍ كَنَ. عَ نْندِ كِ مَ، نَ كُيٍيٍ مُ قِندِشِ عَلَ رَ، بَرِ مَ عِبُنَدَ مَ نَن نٍيٍ يَءِلَنشِ وُرِ نُن فّمّ رَ.
\v 20 يَندِ، مُشُ مَرِفِ عَلَتَلَ، عِ شَ مُشُ رَتَنفَ سٍنَشٍرِبِ مَ، عَلَكٌ دُنِحَ بِرِن شَ عَ كٌلٌن، عَ عِ تَن نَن كٍرٍن نَ عَلَ رَ.»
\p 
\v 21 عَوَ، عَمٌسُ شَ دِ عَننَبِ عٍسَيِ نَشَ شّيرَ شّي مَنفّ شٍسٍكِيَ مَ، عَ نَشّ، «عِسِرَيِلَ مَرِفِ عَلَتَلَ يِ نَن مَسٍنشِ، ‹ﭑ بَرَ عِ شَ مَشَندِ سُشُ عِ نَشَن تِشِ عَسِرِيَ مَنفّ سٍنَشٍرِبِ شَ قٍ رَ.
\v 22 عَلَتَلَ شَ مَسٍنيِ نَن يَ عَ شِلِ مَ،
\q1 سِيٌنِ تَا قَمَ نّ يٌدٍ عِ مَ،
\q1 دَرِ سَلَمُ تٌقَنيِ قَ عِ مَبٍرٍدٍ.
\q1 
\v 23 عِ ندٍ كٌنبِشِ، عِ ندٍ مَبٍرٍشِ؟
\q1 عِ سْنشْشِ ندٍ مَ؟
\q1 عِ بَرَ عِ يّتّ عِفبٌ عِسِرَيِلَ سّنِيّنتْي مَ.
\q1 
\v 24 عِ شَ شّيرَيٍ بَرَ مَرِفِ رَ سْتْ.
\q1 عِ بَرَ عَ قَلَ، «ﭑ تَن بَرَ تٍ هَن لِبَن فٍيَيٍ قَرِ
\q1 ﭑ مَ فِسٍيٍ كُي.
\q1 ﭑ سّدِرِ وُرِ عِتٍشِيٍ قْن،
\q1 ﭑ سِثِرّ وُرِ تٌقَنيِيٍ سّفّ قْتْنيِ دّحّشِ كُي.
\q1 
\v 25 ﭑ تِفِيٍ فٍ حَمَنّيٍ مَ، ﭑ عٍ يٍ مِن.
\q1 ﭑ نِلِ شُرٍ سّنكِنّيٍ بِرِن شْرِ مَ نّ ﭑ سَنيِيٍ رَ.»›»
\b
\q1 
\v 26 عَلَتَلَ نَشّ، «عِ مُ عَ مّشِ بَ،
\q1 ﭑ بَرَ يِ قٍيٍ نَتّ نُ عَ رَكُيَ،
\q1 كَقِ ﭑ عِ دَا تّمُي؟
\q1 ﭑ قَ نَ عٍ رَبَقٍ نّ.
\q1 عِ تَن قِندِشِ تَا سّنبّمَيٍ سْنتْمَ نَن تُن نَ،
\q1 
\v 27 نَ تَا مِشِيٍ سّنبّ مُ نَ عٍ شَ تِ وٌ كَنكٍ.
\q1 فَاشُي نُن يَافِ نَن تُن عٍ سْتْمَ.
\q1 عٍ لُمَ نّ عَلْ حٌوفٍ شَرٍ، عَلْ سّشّ نَشَن نَ بَنشِ كْن نَ،
\q1 عَلْ مّنفِ بِلِ نَشَن شَرَ مَ بٍينُن عَ شَ بٌفِ.
\q1 
\v 28 كْنْ ﭑ عِ دْشْ تّمُي، عِ مِنِ تّمُي سِفَقٍ رَ فٍرٍ سٌدٍ، عِ قَ تّمُي، ﭑ نَ بِرِن كٌلٌن.
\q1 عِ مَن نَ ﭑ مَتَندِ، ﭑ نَ قَن كٌلٌن.
\q1 
\v 29 عِ تٌ بَرَ ﭑ مَتَندِ نَ كِ، عِ عِ يّتّ عِفبٌ ﭑ مَ،
\q1 ﭑ نَ ﭑ مَ شُرُندّ فبَكُمَ نّ عِ حْي رَ،
\q1 ﭑ نَ ﭑ مَ كَرَقٌي سْتِ عِ دّ كُي،
\q1 ﭑ عِ رَفبِلٍن عِ كٍلِدٍ.»
\b
\q1 
\v 30 عَلَتَلَ نَشّ، «شٍسٍكِيَ، تْنشُمَ نَن يَ عِ بّ؛
\q1 تٌوقَرٍ وٌ سَنسِ شْرِ يٌلٌنشِ نَن دٌنمَ.
\q1 تَمُنَ وٌ سَنسِ بَلِ نَن دٌنمَ.
\q1 كْنْ تَمُنَ بٌورٍ، وٌ سَنسِيٍ نَن دٌنمَ وٌ نَشٍيٍ سِمَ وٌ عٍ شَبَ،
\q1 وٌ وّنِ مِن نَشَن كٍلِمَ وّنِ بِلِيٍ مَ، وٌ نَشٍيٍ سِمَ.
\q1 
\v 31 يُدَ بْنسْييٍ نَشٍيٍ كِسِمَ،
\q1 نٍيٍ لُمَ نّ عَلْ وُرِ بِلِ
\q1 نَشَن سَنكٍ نَ بْشِ بُن مَ،
\q1 عَ قَ عَ بٌفِ رَ مِنِ.
\q1 
\v 32 بَرِ مَ مِشِ ندٍيٍ رَتَنفَمَ نّ قَشّ مَ دَرِ سَلَمُ،
\q1 سِيٌنِ مِشِ ندٍيٍ كِسِمَ نّ.
\q1 عَلَتَلَ سّنبّمَ عَ مَقُرَ مَ نّ نَ بِرِن نَبَدٍ.»
\p 
\v 33 نَ كُي، عَلَتَلَ يِ مَسٍنيِ نَن تِشِ عَسِرِيَ مَنفّ شَ قٍ رَ،
\q1 «عَ مُ سٌمَ يِ تَا كُي،
\q1 عَ مُ شَلِ يٌ وٌلِمَ بٍ،
\q1 عَ مُ تِمَ وٌ كَنكٍ عَ شَ وُرٍ لٍقَ رَ،
\q1 عَ مُ بّندّ مَتٍمَ تُفَنقٍ رَ وٌ شَ تّتّ رَ.
\q1 
\v 34 عَ فبِلٍنمَ عَ قَ كِرَ نَن نَ،
\q1 عَ مُ سٌمَ يِ تَا كُي!
\q1 عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ.
\q1 
\v 35 ﭑ يِ تَا مَكَنتَمَ نّ،
\q1 ﭑ عَ رَكِسِمَ نّ ﭑ شِلِ نُن ﭑ مَ كٌنيِ دَوُدَ شَ قٍ رَ.»
\p 
\v 36 نَ كْي رَ عَلَتَلَ شَ مَلٍكّ نَشَ مِنِ، عَ سَ عَسِرِيَكَ وُلُ كّمّ تٌنفٌ سٌلٌمَسَشَن نُن سُولِ قَشَ. عَ دْنشْييٍ تٌ كٍلِ فّيسّفّ، عٍ نَشَ نَ قُرٍيٍ تٌ عٍ يَ مَ.
\v 37 نَ كُي، عَسِرِيَ مَنفّ سٍنَشٍرِبِ نَشَ فبِلٍن عَ شْنيِ نِنٍوٍ.
\v 38 لْشْي ندٍ، عَ تٌ نُ نَ سَلِقٍ عَ شَ عَلَ نِسِرِ شَ بَنشِ كُي، عَدَرَ مٍلٍكِ نُن سَرٍ سٍرِ نَشَ عَ قَشَ سَنتِدّفّمَ رَ، عٍ عٍ فِ عَرَرَتِ بْشِ مَ. عٍسَرِشَدٌنِ نَشَ تِ مَنفّ رَ عَ بَبَ سٍنَشٍرِبِ حْشْي رَ.
\c 38
\s1 شٍسٍكِيَ شَ يَلَنيِ
\p 
\v 1 نَ لْشْييٍ مَنفّ شٍسٍكِيَ نَشَ قُرَ عَ حَاشِ رَ. عَ فبٍ مُ نُ لُشِ عَ شَ قَشَ. عَمٌسُ شَ دِ عَننَبِ عٍسَيِ نَشَ سِفَ عَ يِرٍ، عَ عَ قَلَ عَ بّ، عَلَتَلَ يِ نَن مَسٍنشِ، «عِ شَ يَامَرِيٍ قِ عِ شَ مِشِيٍ مَ، بَرِ مَ عِ نَ قَشَقٍ نّ يِ كِ، عِ مُ كِسِمَ يِ قُرٍ مَ.»
\v 2 شٍسٍكِيَ نَشَ عَ يَتَفِ مَقِندِ بَنشِ شَلّ مَ، عَ عَلَتَلَ مَشَندِ، عَ نَشّ،
\v 3 «عَلَتَلَ، يَندِ هِننّ ﭑ نَ، عِ عَ كٌلٌن ﭑ نَن حّرّشِ نّ كِرَ تِنشِنشِ نَن شْن مَ ﭑ مَ دُنِحّءِفِرِ كُي ﭑ بْحّ قِيشّ رَ. ﭑ مُ عِ مَتَندِ، ﭑ مُ فبِلٍن عِ وَشْنقٍ قْشْ رَ.» شٍسٍكِيَ نَشَ وَ كِ قَنيِ رَ.
\p 
\v 4 عَننَبِ عٍسَيِ مُ نُ فّشِ مِنِدٍ مَنفّ بَنشِ تّتّ كُي، عَلَتَلَ مَن نَشَ عَ مَسٍن عَ بّ، عَ نَشّ،
\v 5 «فبِلٍن عِ شَ سَ عَ قَلَ ﭑ مَ حَمَ يَرٍرَتِ شٍسٍكِيَ بّ، عِ بٍنبَ دَوُدَ مَرِفِ عَلَتَلَ يِ نَن مَسٍنشِ، ‹ﭑ بَرَ عِ شَ مَشَندِ مّ، ﭑ بَرَ عِ يَيٍ تٌ. ﭑ عِ يَلَنمَ نّ، عَ شِ سَشَن ندٍ. ﭑ حّ قُ نُن سُولِ سَمَ نّ عِ شَ سِمَيَ شُن مَ.
\v 6 ﭑ عِ تَن نُن يِ تَا رَتَنفَمَ نّ عَسِرِيَ مَنفّ مَ. ﭑ يِ تَا مَكَنتَمَ نّ ﭑ مَ كٌنيِ دَوُدَ شَ قٍ رَ.›»
\p 
\v 7 عَننَبِ عٍسَيِ نَشَ عَ يَابِ، «يِ نَن قِندِ مَ عَلَتَلَ شَ تْنشُمَ رَ عِ بّ، عَلَكٌ عِ شَ عَ كٌلٌن عَ عَلَتَلَ عَ شَ مَسٍنيِ رَكَمَلِمَ نّ.
\v 8 عَلَ نَشّ، ‹ﭑ عَ نِيَمَ نّ سٌفٍ نِينِ شَ فبِلٍن عَ شَنبِ شَنبِ مَ دْشْ قُ عَشَسِ تٍدٍ مَ.›» نَ تّمُي، سٌفٍ نِينِ نَشَ مَفبِلٍن عَ شَنبِ شَنبِ مَ دْشْ قُ عَ فٌرٌشِ كِ نَشّ.
\p 
\v 9 يُدَيَ مَنفّ شٍسٍكِيَ شَ بّيتِ نَن يَ، عَ نَشَن سّبّشِ عَ تٌ يَلَن عَ شَ قُرٍ مَ؛
\q1 
\v 10 ﭑ نُ عَ قَلَ نّ نُ،
\q1 «عَ لَنمَ ﭑ شَ لَاشِرَ يِ وَشَتِ قَنيِ ﭑ مَ دُنِحّءِفِرِ كُي؟
\q1 ﭑ مَ سِمَيَ شَ دُنكٍ نَ كِ؟»
\q1 
\v 11 ﭑ مَن نُ عَ قَلَ نّ نُ،
\q1 «ﭑ مُ عَلَتَلَ تٌمَ يِ دُنِحَ مَ سْنْن،
\q1 ﭑ مَن مُ عِبُنَدَ مَ يٌ تٌمَ قَ نَشَن سَبَتِشِ يِ بّندّ قُحِ قَرِ.
\q1 
\v 12 ﭑ مَ لِنفِرَ بَرَ تٌنفٌ ﭑ شُن،
\q1 عَلْ شُرُ سٍ كَنتّ شَ لٍيلٍ عِتَلَمَ كِ نَشّ.
\q1 ﭑ مَ سِمَيَ نَ مَقِلِنقٍ عَلْ مَبْي شَ فّسّ.
\q1 مَبْي نَ فّ فّسّ سْشْدٍ، عَ دْنشْي نَشَن لُشِ، عَ نَ شَبَ.
\q1 عَلَتَلَ، عِ تَن قَن، بٍينُن نُنمَرٍ شَ سٌ، عِ بَرَ ﭑ مَ سِمَيَ رَحْن.
\q1 
\v 13 ﭑ نَشَ مَمّ تِ هَن فّيسّفّ،
\q1 كْنْ عِ بَرَ ﭑ شْرِيٍ عِفِرَ عَلْ يّتّ عَ رَبَمَ كِ نَشّ.
\q1 بٍينُن كْي شَ سٌ، عِ بَرَ دَن تِ ﭑ مَ سِمَيَ مَ.
\q1 
\v 14 ﭑ نُ ﭑ شُي شُرُدِ رَ مِنِمَ نّ عَلْ دٍبٍلِن شْنِ،
\q1 ﭑ نُ وَ مَ نّ عَلْ فَنبّ سُننُنشِ.
\q1 ﭑ نُ ﭑ يَ رَتٍ كٌورٍ مَ، ﭑ نُ قَ عَ قَلَ،
\q1 ‹ﭑ مَرِفِ ﭑ نَ تْورْقٍ، عِ شَ ﭑ مَلِ.›»
\b
\q1 
\v 15 «ﭑ نْمَ نَ تَفِ رَبَدٍ دِ؟
\q1 عَ تَن يَتِ بَرَ ﭑ يَابِ، عَ قَ ﭑ مَ دُبَ سُشُ.
\q1 نَ كُي ﭑ قَمَ ﭑ حّرّدٍ يّتّ مَفٌرٍ نَن كُي ﭑ مَ سِمَيَ بِرِن نَ.
\q1 
\v 16 ﭑ مَرِفِ، عِبُنَدَ مَ كِسِمَ نَ كِ نّ.
\q1 ﭑ حّنفِقٍ تٌ نَ نَن مَ.»
\b
\q1 «عِ تَن بَرَ ﭑ مَ يَلَنيِ رَفبِلٍن ﭑ مَ، ﭑ شَ كِسِ.
\q1 
\v 17 عِ بَرَ ﭑ مَلِ نَ تْورّ كُي.
\q1 عِ شَ شَنُنتٍيَ بَرَ ﭑ نَتَنفَ قَشّ مَ،
\q1 عِ بَرَ ﭑ مَ يُنُبِيٍ بِرِن وٌلِ عِ كٌبٍ رَ.
\q1 
\v 18 عِ عَ كٌلٌن عَ ﭑ مَ فَبُرِ مُ قِندِ مَ مَتْشْي رَ عِ بّ،
\q1 سَيَ مُ عِ مَتْشْمَ،
\q1 قَشَ مِشِيٍ قَن مُ عِ تَنتُمَ بّيتِ رَ.
\q1 نَشٍيٍ فٌرٌ مَ فَبُرِ كُي، نٍيٍ شَشِلِ مُ تِشِ عِ شَ هِننّ رَ سْنْن.
\q1 
\v 19 مِشِ حِحّ نَن عِ مَتْشْمَ، عَلْ ﭑ نَ عِ مَتْشْقٍ كِ نَشّ تٌ لْشْي.
\q1 بَبَيٍ مَسٍنيِ تِمَ عٍ شَ دِيٍ بّ عِ شَ هِننّ شَ قٍ رَ.»
\b
\q1 
\v 20 عَلَتَلَ بَرَ ﭑ نَكِسِ.
\q1 وٌن شَ بّيتِ بَ عَ بّ كْرَيٍ رَ عَ شَ هْرْ مْبَنشِ كُي.
\q1 وٌن شَ لُ نَ رَبَ رَ وٌن مَ سِمَيَ بِرِن نَ.
\b
\p 
\v 21 عَننَبِ عٍسَيِ نُ بَرَ عَ قَلَ، عَ عٍ شَ قَ شْرّ بٌفِ يَءِلَن، عٍ عَ قَتُ مَنفّ شٍسٍكِيَ شَ قِ مَ، عَلَكٌ عَ شَ يَلَن.
\v 22 شٍسٍكِيَ نُ بَرَ عَ يَابِ، «تْنشُمَ مُندُن عَ نِيَمَ ﭑ شَ عَ كٌلٌن ﭑ مَن نْمَ تٍدٍ عَلَتَلَ شَ هْرْ مْبَنشِ؟»
\c 39
\s1 شٍسٍكِيَ بَبِلْن مَنفّ شَ شّيرَيٍ رَ سّنّقٍ
\p 
\v 1 نَ تّمُي بَبِلْن مَنفّ مٍرٌدَكِ بَلَدَن نَشَ بَتَاشّ نُن بُحَ رَ سَنبَ شٍسٍكِيَ مَ، بَرِ مَ عَ نُ بَرَ شٍسٍكِيَ قُرَقٍ نُن عَ يَلَنقٍ مّ.
\v 2 شٍسٍكِيَ نَشَ نَ شّيرَيٍ رَ سّنّ، عَ عَ شَ نَاقُلِ بِرِن مَسٍن عٍ بّ، عَلْ فبٍتِ، شّيمَ، سُرَيِ، لَبُندّ نُن تُرٍ شِرِ حْشُنمّ، عَ شَ فٍرٍ سٌسٍ رَفَتَدٍ نُن عَ شَ بَننَيَ بِرِن نَ دّننَشّ. سٍسٍ مُ لُ، شٍسٍكِيَ مُ نَشَن مَسٍن عٍ بّ عَ شَ بَنشِ نُن عَ شَ بْشِ كُي.
\v 3 نَ دَنفِ شَنبِ، عَننَبِ عٍسَيِ نَشَ قَ شٍسٍكِيَ يِرٍ، عَ عَ مَشْرِن، «نَ مِشِيٍ مُنسٍ قَلَشِ عِ بّ؟ عٍ كٍلِشِ مِندٍن؟» شٍسٍكِيَ نَشَ عَ يَابِ، «عٍ كٍلِشِ بْشِ مَكُيٍ ندٍ نّ، دّننَشّ شِلِ بَبِلْن.»
\v 4 عٍسَيِ مَن نَشَ عَ مَشْرِن، «عٍ مُنسٍ مَتٌشِ عِ شَ بَنشِ كُي؟» شٍسٍكِيَ نَشَ عَ يَابِ، «سٍ نَشَن بِرِن نَ ﭑ مَ بَنشِ كُي. سٍسٍ مُ لُشِ ﭑ شْنيِ ﭑ مُ نَشَن مَسٍنشِ عٍ بّ.»
\p 
\v 5 نَ كُي، عَننَبِ عٍسَيِ نَشَ عَ قَلَ شٍسٍكِيَ بّ، «عِ تُلِ مَتِ عَلَتَلَ شَ مَسٍنيِ رَ،
\v 6 ‹لْشْي نَ قَقٍ، يِ مِشِيٍ قَمَ نّ عِ هَرِفٍ بِرِن شَنِندٍ بَبِلْن، عِ بٍنبَيٍ نَشَن لُشِ عِ يِ رَ. عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ.
\v 7 عٍ قَمَ نّ عِ شَ دِيٍ سُشُدٍ، عِ نَشٍيٍ بَرِشِ، عٍ عٍ بَنَ بَبِلْن مَنفّ بّ.›»
\v 8 شٍسٍكِيَ نَشَ عَ قَلَ عٍسَيِ بّ، «عَلَتَلَ شَ مَسٍنيِ عِ نَشَن تِشِ، عَ قَن.» عَ نَ قَلَ نّ بَرِ مَ عَ نَشّ، «بْحّسَ نُن كَنتَرِ تَن لُمَ نّ بٍ، ﭑ مَ سِمَيَ بِرِن كُي.»
\c 40
\s1 عَلَ عَ شَ حَمَ شُنسَرَقٍ
\q1 
\v 1 عَلَ شَ مَسٍنيِ نَن يَ؛
\q1 «وٌ شَ ﭑ مَ حَمَ مَدُندُ عٍ شَ تْورّ كُي.
\q1 
\v 2 وٌ شَ عَ قَلَ دَرِ سَلَمُ بّ عَ عَ شَ حَشَنكَتّ بَرَ حْن،
\q1 عَ شَ يُنُبِيٍ سَرٍ بَرَ فّ قِدٍ،
\q1 عَ عَلَتَلَ بَرَ نَ رَفبِلٍن عَ مَ هَن دْشْ قِرِن.»
\b
\q1 
\v 3 مِشِ ندٍ نَ عَ شُي رَ مِنِقٍ فبٍنفبٍرٍن يِرٍ عَ قَلَقٍ رَ،
\q1 «وٌ شَ كِرَ يَءِلَن عَلَتَلَ بّ،
\q1 وٌ سَنكِرَ مَتِنشِن وٌ مَرِفِ يَ رَ.
\q1 
\v 4 فُلُنبَ شَ عِتٍ، فٍيَ شَ عِفٌرٌ،
\q1 كِرَ حَاشِ شَ يَءِلَن عَ قَنيِ رَ.
\q1 
\v 5 عَلَتَلَ شَ نْرّ مَكّنّنمَ نّ دَالِ بِرِن يَ شْرِ.»
\q1 عَلَتَلَ شَ مَسٍنيِ يَتِ نَن نَ كِ.
\b
\q1 
\v 6 مِشِ ندٍ بَرَ عَ قَلَ ﭑ بّ، «عِ شُي رَتٍ.»
\q1 ﭑ بَرَ عَ يَابِ، «ﭑ شَ مُنسٍ قَلَ؟»
\q1 عَ نَشّ، «عَدَ مَ شَ نْرّ لُشِ نّ عَلْ سَنسِيٍ.
\q1 
\v 7 عٍ لِسِمَ نّ، عَلَتَلَ شَ قٌيٍ عٍ قُفٍ كَنَ.
\q1 عَدَ مَدِيٍ مَنِيَشِ سَنسِيٍ نَن نَ.
\q1 
\v 8 سَنسِيٍ شَرَ مَ نّ، عٍ قُفٍ كَنَ،
\q1 كْنْ عَلَتَلَ تَن شَ مَسٍنيِ مُ كَنَمَ عَبَدَن.»
\b
\q1 
\v 9 سِيٌنِ، عِ شَ تٍ فٍيَ عِتٍشِ ندٍ قَرِ.
\q1 دَرِ سَلَمُ، عِ شَ عِ شُي عِتٍ سّنبّ رَ لِمَنِيَ كُي.
\q1 عَ قَلَ يُدَيَ تَايٍ بّ، «وٌ مَرِفِ عَلَ نَ بٍ.»
\q1 
\v 10 مَرِفِ عَلَتَلَ نَ قَقٍ سّنبّ رَ، نْي شَنشِ عَ بّلّشّ عِ.
\q1 شُننَكٍلِ نَ عَ بّ.
\q1 
\v 11 عَ مّينِمَ نّ عَ شَ شُرُ سٍيٍ مَ،
\q1 عَ عَ شَ يّشّ يْرّيٍ تٌنفٌمَ نّ، عَ عٍ سَ عَ كَنكٍ مَ،
\q1 عَ عٍ نفَيٍ رَفبّنفبّن.
\b
\q1 
\v 12 ندٍ بَا يٍ مَنِيَشِ عَ بّلّشّ كُي؟
\q1 ندٍ كٌورٍ وَلَشّ مَنِيَشِ؟
\q1 ندٍ دُنِحَ بّندّ مَنِيَشِ؟
\q1 ندٍ فٍيَيٍ دْشْشِ سِكٍيلِ رَ؟
\q1 
\v 13 ندٍ عَلَتَلَ شَشِلِ كٌلٌن؟
\q1 ندٍ نْمَ مَرَ سِ قِدٍ عَ مَ؟
\q1 
\v 14 ندٍ عَ يَمَرِ مَ؟ ندٍ عَ مَتِنكَنمَ؟
\q1 ندٍ قٍ كٌلٌنيِ مَسٍنمَ عَ بّ؟
\q1 ندٍ عَ مَسٍنمَ عَ بّ سٍ يَءِلَنمَ كِ نَشّ؟
\b
\q1 
\v 15 حَمَنّيٍ لُشِ نّ عَ بّ عَلْ سٍ شُنشُرِيٍ.
\q1 عَ عٍ رَكٍلِمَ نّ عَ قَنيِ رَ.
\q1 
\v 16 لِبَن سُبٍ بِرِن نَلَنشِ مُ سّرّشّ فَن دَاشِ لِمَ نَشَن دَشَ عَ بّ،
\q1 لِبَن قْتْنيِ بٍلٍبٍلٍ مُ يٍفٍ لِمَ عَ شَ سّرّشّ فَنقٍ رَ.
\q1 
\v 17 سٍسٍ مُ حَمَنّيٍ رَ عَ يَ عِ، عٍ قِندِشِ عَ بّ قٍ قُقَقُ نَن نَ.
\q1 
\v 18 وٌ وَ مَ عَلَ مَنِيَقٍ ندٍ رَ؟
\q1 وٌ عَ مِسَالِمَ مُنسٍ رَ؟
\q1 
\v 19 يِرَوَلِ كُيٍ نَن مَسٌلِمَ،
\q1 شَبُي شّيمَ رَدِن عَ مَ،
\q1 عَ قَ فبٍتِ يْلْنشْنيِيٍ يَءِلَن عَ كُيٍ فبَكُمَ نَشَن نَ.
\q1 
\v 20 سٍتَرٍيٍ وُرِ ندٍ نَن قٍنمَ نَشَن مُ كَنَمَ مَقُرٍن مَقُرٍن،
\q1 عَ مِشِ قٍن نَشَن قَتَ عَ مَسٌلِدٍ عَلَكٌ عَ نَشَ بِرَ.
\b
\q1 
\v 21 وٌ مُ عَ كٌلٌن؟ وٌ مُ نَ قٍ مّشِ كَبِ تّمُي شْنكُيٍ؟
\q1 وٌ مُ نَ قَهَامُشِ كَبِ دُنِحَ دَا تّمُي؟
\q1 
\v 22 عَ تَن نَن سَبَتِشِ دُنِحَ بِرِن شُن مَ.
\q1 دُنِحَ مِشِيٍ لُشِ نّ عَ بّ عَلْ كَتٌييٍ.
\q1 عَ تَن كٌورٍ وَلَشّ عِتَلَشِ نّ عَلْ دُفِ نَشَن سَمَ لٍيلٍ مَ.
\q1 
\v 23 عَ تَن نَن مَنفّيٍ شُن نَكَنَمَ، عَ مِشِ شُنفبٍيٍ شَ قٍ مَفٌرٌ.
\q1 
\v 24 عٍ لُشِ نّ عَلْ سَنسِ نَشَن سِ تٌ،
\q1 كْنْ بٍينُ عٍ شَ مْ، عَ قَ وُيٍنيِ رَدِن عٍ مَ نَشَن عٍ شَرَ مَ فبٍن.
\q1 نَ تّمُي قٌيٍ شُنفبٍ عٍ شَنِنمَ نّ عَلْ سّشّ شَرٍ.
\b
\q1 
\v 25 عَلَ سّنِيّنتْي شَ مَسٍنيِ نَن يَ؛
\q1 «وٌ ﭑ تَن عَلَ مَنِيَمَ ندٍ رَ؟
\q1 ﭑ مِسَالِشِ ندٍ بّ؟
\q1 
\v 26 وٌ وٌ يَيٍ رَكٍلِ كٌورٍ مَ.
\q1 ندٍ نَ سٍ يَنبَشِيٍ دَاشِ؟
\q1 عَلَ نَن عٍ يَمَرِ مَ، عَ عٍ شِلِيٍ كٌلٌن.
\q1 عَ سّنبّ شَ سَابُي رَ، سٍسٍ مُ لُشِ عٍ مَ.»
\b
\q1 
\v 27 «نَ كُي، وٌ تَن ﭑ مَ حَمَ،
\q1 نَشَن قَتَنشِ يَشُبَ رَ، نَشَن قِندِشِ عِسِرَيِلَ رَ،
\q1 مُنقٍ رَ وٌ عَ قَلَمَ،
\q1 ‹عَلَتَلَ مُ قٍ تٌشِ نَشَن دْشْشِ مُشُ مَ.
\q1 مُشُ مَرِفِ عَلَتَلَ مُ وَ مَ مُشُ فبٍ حْشْقٍ.›
\q1 
\v 28 وٌ مُ عَ كٌلٌن؟ وٌ مُ نَ قٍ مّشِ؟
\q1 عَلَتَلَ قِندِشِ عَلَ نَن نَ كَبِ عَبَدَن،
\q1 عَ دُنِحَ يَتِ نَن دَاشِ عَ قْلّ رَ.
\q1 عَ مُ تَفَنمَ، دَنيِ مُ نَ عَ شَشِلِ مَ.
\q1 
\v 29 عَ سّنبّ قِمَ نّ مِشِ تَفَنشِ مَ،
\q1 عَ لِمَنِيَ قِ سّنبّتَرٍيٍ مَ.
\q1 
\v 30 هَلِ دِ مّدِيٍ عٍ تَفَنمَ، سّفّتَلَيٍ بِرَ مَ،
\q1 
\v 31 كْنْ نَشٍيٍ عٍ شَشِلِ تِمَ عَلَتَلَ رَ،
\q1 نٍيٍ سّنبّ نّينّ سْتْمَ نّ، عٍ قَ تُفَن عَلْ سّفّيٍ.
\q1 عٍ عٍ حّرّ، عٍ عٍ فِ، عٍ مُ تَفَنمَ قٍقٍ مَ.»
\c 41
\s1 عَلَ نَن نَ عِسِرَيِلَ شَ مَلِ رَ
\q1 
\v 1 «حَمَنّيٍ، وٌ وٌ سَبَرِ.
\q1 سِ يٍنسٍنشِيٍ، وٌ لِمَنِيَ، وٌ شَ وٌ مَسٌ ﭑ مَ كِيتِ يِرٍ رَ.»
\b
\q1 
\v 2 «ندٍ مِشِ تِشِ كِرَ شْن مَ كٍلِ سٌفٍتٍدٍ،
\q1 وٌ شَ كِيتِ سَمَ نَشَن شِلِ رَ؟
\q1 ندٍ حَمَنّيٍ سَشِ عَ سَفٌي، عَ مَنفّيٍ شَ قٍ عِفٌرٌ عَ بّ؟
\q1 عَ شَ سَنتِدّفّمَ عٍ شُن نَكَنَمَ نّ، عَ شَ شَلِ عٍ رَيٍنسٍن يّ.
\q1 
\v 3 عَ عٍ كٍرِ مَ نّ سّنبّ رَ، عَ مَن سِفَ يِرٍ فبّتّ نَ رَبَدٍ.
\q1 
\v 4 ندٍ نَ قٍيٍ رَفِرِشِ عَ شَ يَامَرِ رَ كَبِ دُنِحَ قْلّ؟
\q1 ﭑ تَن عَلَتَلَ، نَشَن نَ قٍ قْلّ نُن قٍ رَحْنيِ رَ،
\q1 ﭑ تَن بَرَ نَ مْولِ بِرِن نَفِرِ.»
\b
\q1 
\v 5 «حَمَنّيٍ فَاشُمَ نّ نَ بِرِن يَ رَ،
\q1 سِيٍ سّرّن فَاشُي رَ دُنِحَ بِرِن.
\q1 
\v 6 عٍ لِمَنِيَ قِمَ عٍ بٌرٍ مَ، عَ قَلَقٍ رَ، ‹وٌ وٌ سّنبّ سٌ!›
\q1 
\v 7 يِرَوَلِيٍ عٍ بٌرٍ مَلِمَ عَلَكٌ شّيمَ شَ سَ كُيٍ مَ.
\q1 عٍ نَشّ، ‹عَ قَن نَ كِ نّ.›
\q1 عٍ كُيٍ بَنبَنمَ لَنتُمَيٍ رَ عَلَكٌ عَ نَشَ قَ بِرَ.»
\b
\q1 
\v 8 «كْنْ وٌ تَن عِسِرَيِلَ قِندِشِ ﭑ مَ كٌنيِ نَن نَ.
\q1 ﭑ وٌ تَن يَشُبَ بْنسْي نَن سُفَندِشِ،
\q1 نَشَن قَتَنشِ ﭑ شَنُنتٍنيِ عِبُرَهِمَ بْنسْي.
\q1 
\v 9 ﭑ وٌ تٌنفٌشِ دُنِحَ تُنشُنيِيٍ نَن نَ، عَ قَلَقٍ رَ،
\q1 ‹ﭑ مَ كٌنيِ سُفَندِشِيٍ نَن وٌ رَ، ﭑ مُ مّمَ نَشٍيٍ رَ.›
\q1 
\v 10 وٌ نَشَ فَاشُ، بَرِ مَ ﭑ نَ وٌ قْشْ رَ.
\q1 وٌ نَشَ كْنتْقِلِ، بَرِ مَ ﭑ تَن نَن نَ وٌ مَرِفِ عَلَ رَ.
\q1 ﭑ سّنبّ قِمَ وٌ مَ ﭑ بّلّشّ تِنشِنشِ نَن نَ.»
\b
\q1 
\v 11 «نَشٍيٍ بِرِن وٌ مَبٍرٍقٍ، عٍ قَمَ يَافِ نَن تُن سْتْدٍ.
\q1 نَشٍيٍ وٌ قٍنقٍ فٍرٍ رَ، عٍ هَلَكِمَ نّ، عٍ حْن.
\q1 
\v 12 وٌ نَ وٌ يَشُييٍ قٍن، وٌ مُ قَمَ عٍ تٌدٍ، بَرِ مَ عٍ لْيمَ نّ.
\q1 نَشٍيٍ وٌ قٍنمَ فٍرٍ رَ، نٍيٍ حْنمَ نّ.
\q1 
\v 13 نَ رَبَمَ نّ بَرِ مَ ﭑ تَن نَن نَ وٌ مَرِفِ عَلَتَلَ رَ،
\q1 نَشَن وٌ بّلّشّ رَ سُشُ،
\q1 عَ عَ قَلَ، ‹وٌ نَشَ فَاشُ، ﭑ قَقٍ وٌ مَلِدٍ.›
\q1 
\v 14 يَشُبَ بْنسْي، وٌ نَشَ فَاشُ.
\q1 عِسِرَيِلَ، وٌ وٌ سّنبّ سٌ.
\q1 هَلِ وٌ قِندِشِ مِشِ شُنشُرِيٍ نَن نَ عَلْ كُلِ دِ،
\q1 ﭑ تَن نَشَن لَنشِ وٌ رَكِسِمَ مَ، نَشَن قِندِشِ وٌ شَ سّنِيّنتْي رَ،
\q1 ﭑ تَن يّتّ يَتِ قَمَ نّ وٌ مَلِدٍ.
\q1 ﭑ شُي نَن نَ كِ.»
\b
\q1 
\v 15 «ﭑ عَ نِيَمَ نّ وٌ شَ سّنبّ مَفَاشُشِ سْتْ وٌ يَشُييٍ يَ رَ.
\q1 وٌ لُمَ نّ عَلْ وُرٍ وَلِ سٍ نَشَن فٍيَيٍ رَبْو مَ، عَ عٍ قِندِ شُبٍ رَ.
\q1 
\v 16 وٌ يَشُييٍ رَيٍنسٍنمَ نّ
\q1 عَلْ شّ سَ نَشٍيٍ مَالٍ بْنبْ، قٌيٍ قَ مَالٍ لَفِ شَنِن.
\q1 وٌ سّيوَ مَ نّ عَلَتَلَ رَ،
\q1 وٌ عِسِرَيِلَ شَ سّنِيّنتْي تَنتُمَ نّ.»
\b
\q1 
\v 17 «مِسِكِينّيٍ نُن سٍتَرٍيٍ يٍ قٍنمَ، كْنْ عٍ مُ عَ تٌمَ.
\q1 عٍ نّنيِ شَرَ مَ يٍ شْلِ رَ.
\q1 كْنْ ﭑ تَن عَلَتَلَ، ﭑ عٍ شَ مَشَندِ تٌنفٌمَ نّ.
\q1 ﭑ تَن عِسِرَيِلَ مَرِفِ عَلَ، ﭑ مُ نّيمُمَ عٍ مَ.
\q1 
\v 18 ﭑ شُرٍيٍ رَبْو مَ نّ فٍيَ مَشَرَشِيٍ مَ،
\q1 ﭑ دُلٌنيِ رَ مِنِمَ مَ فُلُنبَيٍ كُي.
\q1 ﭑ فبٍنفبٍرٍنيِ مَقِندِ مَ نّ يٍ يِرٍ رَ.
\q1 
\v 19 ﭑ سّدِرِ، كَسِيَ، مِرِتِ، نُن عٌلِوِ وُرِ بِلِيٍ سِمَ نّ فبٍنفبٍرٍنيِ مَ.
\q1 ﭑ سِثِرّ، عٌرِ مِ، نُن بُيِسِ سَنسِ بِلِيٍ سِ وُلَ عِ،
\q1 
\v 20 عَلَكٌ حَمَ شَ نَ تٌ، عٍ قَ قَهَامُي سْتْ،
\q1 عَ نَ بِرِن قِندِشِ عِسِرَيِلَ شَ سّنِيّنتْي عَلَتَلَ سّنبّ وَلِ نَن نَ.»
\b
\q1 
\v 21 عَلَتَلَ نَشّ، «وٌ قَ، وٌ وٌ شَ مَرَكْرْ سِ مَسٍن ﭑ بّ.
\q1 وٌ شَ نَ بِرِن تَفِ رَبَ عَ قَنيِ رَ يَشُبَ مَرِفِ بّ.
\q1 
\v 22 وٌ شَ قَ وٌ شَ كُيٍيٍ رَ عَلَكٌ عٍ شَ عَ قَلَ مُشُ بّ قٍ نَشٍيٍ قَمَ رَبَدٍ.
\q1 قٍ نَشٍيٍ سِنفٍ رَبَشِ، عٍ شَ عٍ رَبَ كِ قَلَ مُشُ بّ،
\q1 عَلَكٌ مُشُ شَ شَشِلِ سْتْ نَ كُي.
\q1 عٍ شَ عَ قَلَ مُشُ بّ قٍ نَشَن قَمَ رَبَدٍ،
\q1 
\v 23 عَلَكٌ مُشُ شَ عَ كٌلٌن عَ عٍ قِندِشِ عَلَيٍ نَن نَ.
\q1 عٍ شَ قٍ ندٍ رَبَ، عَ نَ قِندِ قٍقٍ يٌ رَ،
\q1 نَشَن نْمَ مُشُ دّ عِشَرَدٍ، مُشُ شَ فَاشُ عٍ يَ رَ.
\q1 
\v 24 وٌ تَن كُيٍيٍ، ‹وٌ مُ نْمَ نَ سٍسٍ رَ، وٌ تِدٍ يٌ مُ نَ.
\q1 مِشِ نَشَن وٌ بَتُمَ، نَ مِشِ قِندِشِ مِشِ شْنشِ نَن نَ.›»
\b
\q1 
\v 25 «ﭑ بَرَ مِشِ ندٍ رَكٍلِ كْولَ مَبِرِ،
\q1 عَ قَمَ ﭑ شِلِ رَ كٍلِقٍ سٌفٍتٍدٍ مَبِرِ.
\q1 عَ مَنفّيٍ عِبٌرٌنمَ نّ عَلْ قّحّ رَقَلّ بّندّ عِبٌرٌنمَ كِ نَشّ.
\q1 
\v 26 ندٍ نَ قٍ مَسٍنشِ كَبِ عَ قْلّ، عَلَكٌ مُشُ شَ نَ كٌلٌن بٍينُن عَ شَ رَبَ؟
\q1 ندٍ نَ قَلَشِ، عَلَكٌ مُشُ شَ عَ كٌلٌن نْندِ قَلّ نَن عَ رَ؟
\q1 كُيٍ يٌ مُ نَ قٍ مَسٍن.
\q1 كُيٍ يٌ مُ نَ شِبَارُي قِ.
\q1 كُيٍ يٌ مُ عٍ شُي عِتٍ.
\q1 
\v 27 ﭑ تَن نَن نَ سِنفٍ مَسٍن سِيٌنِ بّ،
\q1 ‹يِ نَن قَمَ رَبَدٍ.›
\q1 ﭑ تَن شّيرَ نَن شّي دَرِ سَلَمُ.
\q1 
\v 28 ﭑ نَشَن تٌمَ يِ كُيٍيٍ تَفِ،
\q1 كٍرٍن مُ نَ نَشَن نْمَ مَسٍنيِ ندٍ تِدٍ،
\q1 نَشَن نْمَ ﭑ مَ مَشْرِنيِيٍ يَابِدٍ.
\q1 
\v 29 وٌ شَ عٍ مَتٌ؛ كُيٍ قُقَقُ نَن عٍ رَ!
\q1 عٍ وَلِ قْشِ يٌ مُ نَ!
\q1 سٍسٍ مُ نَ يِ كُيٍيٍ رَ!»
\c 42
\s1 عَلَتَلَ شَ كٌنيِ سُفَندِشِ
\q1 
\v 1 ﭑ مَ كٌنيِ سُفَندِشِ نَن يِ كِ، ﭑ حْشْ سَشِ نَشَن شْن مَ،
\q1 ﭑ نَشَن شَنُمَ ﭑ نِي بِرِن نَ.
\q1 ﭑ بَرَ ﭑ شَشِلِ رَفٌرٌ عَ مَ.
\q1 عَ تِنشِنيِ مَسٍنمَ نّ حَمَنّيٍ بّ،
\q1 
\v 2 كْنْ عَ مُ شَاحّمَ عٍ مَ، عَ مُ سْنشْي رَتٍمَ عٍ مَ،
\q1 عَ مُ عَ يّتّ عِفبٌمَ.
\q1 
\v 3 عَ مُ كَلٍ كُنتِنشِ عِفِرَ مَ،
\q1 عَ مُ لَنثُي دّشّ شُرِ رَشُبٍنمَ.
\q1 عَ كِيتِ سَمَ عَ سّرِيّ كِ نَن مَ.
\q1 
\v 4 عَ مُ دَفَلَنمَ، عَ مُ بِرَ مَ،
\q1 هَن عَ فّ تِنشِنيِ رَ سَبَتِدٍ دُنِحَ مَ.
\q1 حَمَنّيٍ شَشِلِ تِمَ عَ شَ يَامَرِ تِنشِنشِ نَن نَ.
\q1 
\v 5 عَلَتَلَ نْندِ كَنيِ شَ مَسٍنيِ نَن يَ،
\q1 عَلَ نَشَن كٌورٍ دَا، عَ عَ وَلَشّ عِتَلَ،
\q1 نَشَن بْشِ دَا، عَ نُن سٍ بِرِن نَشَن تٌمَ نَا،
\q1 نَشَن حّنفِ قِشِ دُنِحَ مِشِيٍ مَ، عَلَكٌ عٍ شَ دُنِحَ عِفِرِ.
\b
\q1 
\v 6 «ﭑ تَن عَلَتَلَ نَن نَ،
\q1 نَشَن عِ شّيشِ، نَشَن عِ مَكَنتَشِ،
\q1 نَشَن عَ نِيَ عِ شَ قِندِ سَاتّ سَابُي رَ عِبُنَدَ مَ بّ،
\q1 نَشَن عَ نِيَ عِ شَ قِندِ نَءِيَلَنيِ رَ حَمَنّيٍ بّ،
\q1 
\v 7 عَلَكٌ عِ شَ دْنشُييٍ يَ رَبْو، عِ شَ فٍيلِمَنِيٍ رَ مِنِ فٍيلِ،
\q1 عِ شَ مِشِيٍ شْرّيَ نَشٍيٍ نَ دِ مِ كُي.»
\b
\q1 
\v 8 «عَلَتَلَ نَن ﭑ نَ، ﭑ شِلِ نَن نَ كِ.
\q1 ﭑ مُ وَ مَ ﭑ قِرِن ندٍ شْن،
\q1 ﭑ مُ تِنمَ ﭑ مَ مَتْشْي شَ قِ كُيٍيٍ مَ.
\q1 
\v 9 ﭑ مَ مَسٍنيِ سِنفٍيٍ بَرَ رَكَمَلِ،
\q1 ﭑ مَن قٍ نّينّ مَسٍنمَ نّ وٌ بّ نَشَن قَمَ رَكَمَلِدٍ.
\q1 ﭑ نٍيٍ شَ قٍ رَكٌلٌن وٌ رَ بٍينُ عٍ شَ رَبَ.»
\b
\q1 
\v 10 «وٌ شَ بّيتِ نّينّ بَ عَلَتَلَ بّ،
\q1 وٌ عَ مَتْشْ سَ كٍلِ دُنِحَ بَانيِ رَ،
\q1 وٌ تَن نَشٍيٍ بِيَاسِمَ بَا شُن مَ،
\q1 وٌ تَن نَشٍيٍ بَلٌمَ بَا كُي،
\q1 وٌ تَن نَشٍيٍ سَبَتِشِ حَمَنّيٍ كُي.
\q1 
\v 11 فبٍنفبٍرٍنيِ نُن تَايٍ شَ عٍ شُي عِتٍ،
\q1 كٍدَرِكَيٍ سَبَتِشِ دّننَشّ.
\q1 سٍلَكَيٍ شَ عٍ سّيوّ شُي عِتٍ فٍيَيٍ قَرِ.
\q1 
\v 12 عٍ شَ عَلَتَلَ مَتْشْ عَلْ عَ لَن عَ شَ مَتْشْ كِ نَشّ.
\q1 حَمَنّ بِرِن شَ عَ مَتْشْ.
\q1 
\v 13 عَلَتَلَ مِنِمَ نّ عَلْ حَلَمَ،
\q1 عَ بْحّ تٍ فٍرٍ شَ قٍ رَ، عَ فٍرٍ سٌ شُي رَ مِنِ سّنبّ رَ.»
\b
\q1 
\v 14 «كَبِ عَ رَكُيَ ﭑ سَبَرِشِ، ﭑ دُندُشِ، ﭑ نَن ﭑ يّتّ سُشُشِ.
\q1 كْنْ يَكْسِ ﭑ نَن ﭑ شُي رَ مِنِمَ عَلْ فِنّ نَشَن دِ بَرِقٍ.
\q1 
\v 15 ﭑ سَنسِيٍ رَلِسِمَ نّ فٍيَيٍ قَرِ،
\q1 فٍيَ قِندِ فبٍنفبٍرٍنيِ رَ.
\q1 ﭑ شُرٍيٍ مَقِندِ مَ نّ شَرٍ رَ،
\q1 ﭑ يٍ يِرٍيٍ شْرِ.
\q1 
\v 16 ﭑ دْنشُييٍ رَحّرّ مَ نّ كِرَ ندٍ رَ، عٍ مُ نَشَن كٌلٌن،
\q1 ﭑ دِ مِ قِندِ عٍ بّ نَءِيَلَنيِ رَ،
\q1 ﭑ بْشِ مَفٍشِ قِندِ بْشِ سَشِ رَ عٍ حّرّ مَ دّننَشّ.
\q1 ﭑ نَ نَن يَتِ رَبَمَ عٍ بّ، ﭑ مُ عٍ رَبّحِنمَ.
\q1 
\v 17 نَشٍيٍ عٍ شَشِلِ تِشِ كُيٍيٍ رَ،
\q1 عٍ فبِلٍنمَ نّ يَافِ كُي.
\q1 نَ كُيٍيٍ يَءِلَنشِ وُرٍ رَشُنُشِ نَن تُن نَ،
\q1 كْنْ نَ مِشِيٍ عَ قَلَمَ عٍ بّ، ‹وٌ قِندِشِ وٌن مَ عَلَيٍ نَن نَ.›»
\b
\q1 
\v 18 «تُلِشْرِيٍ، وٌ وٌ تُلِ مَتِ.
\q1 دْنشُييٍ، وٌ وٌ يَ تِ ﭑ نَ.
\q1 
\v 19 ندٍ دْنشُشِ، شَ ﭑ مَ كٌنيِ شَ مُ عَ رَ؟
\q1 ندٍ تُلِ شْرِشِ، شَ ﭑ ﭑ مَ شّيرَ شَ مُ عَ رَ؟
\q1 ندٍ دْنشُشِ، شَ ﭑ مَ كٌنيِ بْحّ سَشِ شَ مُ عَ رَ؟
\q1 
\v 20 وٌ بَرَ قٍ فبٍفبٍ تٌ، كْنْ وٌ مُ وٌ حْشْ سَشِ عٍ شْن مَ.
\q1 عٍ بَرَ عٍ تُلِ مَتِ، كْنْ عٍ مُ قٍقٍ قَهَامُشِ.
\q1 
\v 21 تِنشِنيِ تٌ رَقَن عَلَتَلَ مَ،
\q1 عَ بَرَ وَ عَ شَ سّرِيّ بِنيَقٍ، حَمَ شَ عَ كٌلٌن.
\q1 
\v 22 كْنْ يِ حَمَ شُن بَرَ رَكَنَ،
\q1 عٍ سُشُشِ يِلِ نُن فٍيلِ نَن كُي.
\q1 عٍ يَشُييٍ بَرَ عٍ شَنِن، مِشِ يٌ مُ نَ نَشَن عٍ رَكِسِمَ،
\q1 مِشِ يٌ مُ نَ نَشَن مَشَندِ تِمَ عٍ بّ عٍ شَ فبِلٍن.»
\b
\q1 
\v 23 ندٍ عَ تُلِ مَتِمَ نَ قٍيٍ رَ وٌ يَ مَ؟
\q1 ندٍ عَ حْشْ سَمَ نَ قٍيٍ شْن مَ تّمُي نَشَن سَ قَمَ؟
\q1 
\v 24 ندٍ يَشُبَ سٌشِ مُحّتِ يِ رَ؟
\q1 ندٍ عِسِرَيِلَ سٌشِ كَسَرَتِيٍ يِ رَ؟
\q1 عَلَتَلَ شَ مُ عَ رَ، وٌن يُنُبِ رَبَشِ نَشَن نَ؟
\q1 عٍ مُ وَشِ حّرّقٍ عَ شَ كِرَ شَ شْن مَ،
\q1 عٍ مَن مُ عٍ تُلِ مَتِشِ عَ شَ سّرِيّ شَ رَ.
\q1 
\v 25 نَ كُي عَ نَشَ عَ شَ شْنّ دُ سُ عِسِرَيِلَ شُن نَ،
\q1 عَ نِيَ فٍرٍ شَ عٍ شُن نَكَنَ.
\q1 نَ تّ بَرَ دّشّ عٍ رَبِلِنيِ،
\q1 كْنْ عٍ مُ عٍ حْشْ سَشِ نَ شْن مَ.
\c 43
\s1 عِسِرَيِلَ رَكِسِمَ كٍرٍنيِ
\q1 
\v 1 عَلَتَلَ شَ مَسٍنيِ نَن يَ،
\q1 نَشَن يَشُبَ دَاشِ،
\q1 نَشَن عِسِرَيِلَ يَءِلَنشِ بّندّ رَ؛
\q1 «هَلِ وٌ مُ فَاشُ، بَرِ مَ ﭑ بَرَ وٌ شُن سَرَ،
\q1 ﭑ بَرَ وٌ شِلِ وٌ شِلِ رَ، بَرِ مَ ﭑ فبٍ نَن وٌ رَ.
\q1 
\v 2 وٌ نَ بَا عِفِرِ، وٌن بِرِن نَن عَ رَ.
\q1 وٌ نَ شُرٍ عِفِرِ، عَ مُ وٌ شَنِنمَ.
\q1 وٌ نَ دَنفِ تّ شْورَ، عَ مُ وٌ فَنمَ، عَ مُ وٌ تْورْ مَ،
\q1 
\v 3 بَرِ مَ ﭑ تَن عَلَتَلَ نَن نَ وٌ مَرِفِ عَلَ رَ،
\q1 عِسِرَيِلَ شَ سّنِيّنتْي، وٌ رَكِسِمَ.
\q1 ﭑ مِسِرَ نَن قِشِ عِ شُنسَرٍ رَ،
\q1 ﭑ عٍتِيٌثِ نُن سٍبَ قِشِ وٌ حْشْي نَن نَ.
\q1 
\v 4 وٌ تِدٍ تٌ فبٌ ﭑ بّ ﭑ مَ شَنُنتٍيَ شَ قٍ رَ،
\q1 ﭑ مِشِيٍ نَن بَمَ وٌ حْشْي رَ، ﭑ حَمَ قِ وٌ نِي رَكِسِقٍ رَ.
\q1 
\v 5 وٌ نَشَ فَاشُ، ﭑ نَ وٌ قْشْ رَ.
\q1 ﭑ قَمَ نّ وٌ بْنسْي رَ، كٍلِقٍ سٌفٍتٍدٍ نُن سٌفٍفٌرٌدٍ مَبِرِ،
\q1 
\v 6 ﭑ قَمَ وٌ شِلِدٍ كٍلِقٍ يِرٍقَنيِ نُن كْولَ مَ.
\q1 ‹وٌ قَ ﭑ مَ دِيٍ رَ، كٍلِقٍ يِرٍ مَكُيٍ،
\q1 
\v 7 عٍ بِرِن نَشٍيٍ شِلِشِ ﭑ شِلِ رَ،
\q1 ﭑ نَشَن دَاشِ ﭑ مَ نْرّ شَ قٍ رَ.›
\q1 
\v 8 حَمَيٍ شَ قَ نَشٍيٍ يَ نَ كْنْ عٍ مُ سٍ تٌمَ،
\q1 عٍ تُلِ نَ كْنْ عٍ مُ قٍ مّمَ.
\q1 
\v 9 حَمَيٍ نُن سِيٍ شَ عٍ مَلَن.
\q1 ندٍ نَ عٍ يَ مَ نَشَن نُ بَرَ يِ قٍ مَسٍن وٌن بّ بٍينُ عَ شَ رَبَ؟
\q1 عٍ شَ سٍيدٍيٍ رَ مِنِ، نَشٍيٍ نْمَ عَ قٍ رَقِيشّدٍ،
\q1 عَلَكٌ بٌورٍيٍ شَ عَ كٌلٌن عَ نْندِ نَ عَ رَ.»
\b
\q1 
\v 10 عَلَتَلَ شَ مَسٍنيِ نَن يَ،
\q1 «وٌ تَن نَن نَ ﭑ مَ سٍيدٍيٍ رَ، ﭑ مَ كٌنيِ سُفَندِشِ،
\q1 عَلَكٌ وٌ شَ ﭑ كٌلٌن، وٌ شَ لَ ﭑ نَ.
\q1 عَلَ يٌ مُ نُ نَ ﭑ يَ رَ، عَلَ يٌ مُ قَمَ ﭑ شَنبِ رَ.
\q1 
\v 11 ﭑ تَن كٍرٍن نَن نَ عَلَتَلَ رَ.
\q1 مِشِ رَكِسِمَ يٌ مُ نَ بَقٍ ﭑ تَن نَ.
\q1 
\v 12 ﭑ تَن نَن نْندِ مَسٍنشِ، ﭑ تَن نَن وٌ رَكِسِشِ،
\q1 ﭑ تَن نَن قٍ نّينّ مَسٍنمَ وٌ بّ.
\q1 عَلَ شْحّ ندٍ شَ مُ ﭑ نَ وٌ تَفِ.
\q1 وٌ تَن نَن نَ ﭑ مَ سٍيدٍيٍ رَ عَ ﭑ كٍرٍن نَن نَ عَلَ رَ.
\q1 
\v 13 كَبِ قْلْ قْلّ ﭑ تَن نَن عَلَ رَ.
\q1 مِشِ يٌ مُ نْمَ مِشِ بَدٍ ﭑ بّلّشّ،
\q1 مِشِ يٌ مُ نْمَ ﭑ مَ قٍ رَبَشِ مَسَرَدٍ.»
\b
\q1 
\v 14 عَلَتَلَ شَ مَسٍنيِ نَن يَ،
\q1 عَلَ نَشَن وٌ شُن سَرَ،
\q1 عَلَ نَشَن قِندِشِ عِسِرَيِلَ شَ سّنِيّنتْي رَ.
\q1 عَ نَشّ، «ﭑ يَامَرِ قِمَ نّ بَبِلْن فٍيلِمَنِيٍ شَ قَ عٍ شَ كُنكُييٍ كُي،
\q1 عٍ نُ لَشِ نَشٍيٍ رَ.
\q1 
\v 15 عَلَتَلَ نَ ﭑ تَن نَن نَ، وٌ شَ سّنِيّنتْي،
\q1 نَشَن عِسِرَيِلَ دَا، نَشَن قِندِشِ وٌ شَ مَنفّ رَ.»
\b
\q1 
\v 16 عَلَتَلَ شَ مَسٍنيِ نَن يَ، عَلَ نَشَن كِرَ بْو بَا تَفِ،
\q1 نَشَن دَنفِدٍ رَ مِنِ مْرْنيِيٍ شْورَ،
\q1 
\v 17 نَشَن عَ نِيَ سْورِ رَفِ سٍيٍ نُن سٌي رَفِيٍ شَ كَتَ دَنفِدٍ مّننِ،
\q1 عٍ قَ لُ بَا شْورَ عَبَدَن، عٍ مُ تٍ.
\q1 نَ سْورِ فَلِ شُبٍنشِ نّ عَلْ لَنثُي شُبٍنمَ كِ نَشّ.
\q1 
\v 18 «وٌ نَشَ وٌ مَحْشُن قٍ سِنفٍيٍ مَ،
\q1 وٌ قٍ قٌرِيٍ لُ نَ.
\q1 
\v 19 وٌ مُ عَ تٌشِ، ﭑ نَ قٍ نّينّيٍ رَبَقٍ؟
\q1 وٌ مُ فّشِ نَ كٌلٌندٍ؟
\q1 ﭑ نَ كِرَ ندٍ بْوقٍ فبٍنفبٍرٍنيِ مَ،
\q1 ﭑ نَ شُرٍيٍ رَ مِنِقٍ يِرٍ مَشَرَشِ مَ.
\q1 
\v 20 بُرُنيِ دَالِسٍ ﭑ مَتْشْمَ،
\q1 عَلْ وُلَءِ بَرٍ نُن شُندِ، بَرِ مَ ﭑ يٍ رَ مِنِمَ فبٍنفبٍرٍنيِ مَ،
\q1 ﭑ شُرٍ شُنفبٍيٍ رَبْو يِرٍ مَشَرَشِ مَ،
\q1 عَلَكٌ ﭑ مَ حَمَ سُفَندِشِ شَ يٍ مِن،
\q1 
\v 21 عَلَكٌ ﭑ حَمَ نَشَن دَاشِ عَ شَ ﭑ مَتْشْ.»
\b
\q1 
\v 22 «يَشُبَ، وٌ مُ مَشَندِ تِمَ ﭑ شِلِ رَ.
\q1 عِسِرَيِلَ، وٌ مُ قٍقٍ رَبَقٍ بِرَقٍ رَ ﭑ قْشْ رَ.
\q1 
\v 23 وٌ مُ تِن يّشّييٍ بَدٍ سّرّشّ رَ ﭑ بّ،
\q1 وٌ مُ تِن ﭑ بِنيَدٍ سّرّشّيٍ رَ.
\q1 ﭑ مُ كٌتٍ دْشْشِ وٌ شُن مَ سَنسِ سّرّشّ رَ،
\q1 ﭑ مُ وٌ كَرَشَن سُرَيِ فَنقٍ رَ.
\q1 
\v 24 وٌ مُ لَبُندّ قَنيِ سَرَ ﭑ بّ،
\q1 وٌ مُ نِنفٍ تُرٍ فبٍفبٍ بَ سّرّشّ رَ.
\q1 وٌ نَشَن نَبَشِ، وٌ بَرَ ﭑ نَتَفَن وٌ شَ يُنُبِيٍ رَ،
\q1 وٌ بَرَ ﭑ نَشْنْ وٌ شَ حَاشُحَ رَ.»
\b
\q1 
\v 25 «ﭑ تَن نَن عَ رَ، نَشَن عِ شَ يُنُبِيٍ شَقَرِ مَ ﭑ شِلِ شَ قٍ رَ،
\q1 ﭑ قَ نّيمُ عِ شَ يُنُبِيٍ مَ قٍوٌ.
\q1 
\v 26 عِ شَ عِ شَ قٍ دَنفِشِ مَسٍن ﭑ بّ،
\q1 وٌن شَ عَ مَتٌ كِيتِ نَ كِ نَشّ.
\q1 
\v 27 عِ بٍنبَ سِنفٍ يُنُبِ رَبَ نّ.
\q1 عِ شَ يَرٍرَتِ مُرُتَ نّ ﭑ شِلِ مَ.
\q1 
\v 28 نَ نَن عَ رَ، ﭑ قَمَ عِ شَ سّرّشّدُبّيٍ رَيَافِدٍ،
\q1 نَشٍيٍ وَلِمَ ﭑ مَ هْرْ مْلِنفِرَ كُي.
\q1 ﭑ عَ نِيَمَ نّ يَشُبَ بْنسْي شُن شَ رَكَنَ،
\q1 عِسِرَيِلَ بْنسْي شَ يَافِ.»
\c 44
\s1 كُيٍ يَءِلَنمَ شَ وَلِ
\q1 
\v 1 «ﭑ مَ كٌنيِ يَشُبَ بْنسْي، وٌ شَ وٌ تُلِ مَتِ،
\q1 ﭑ مَ حَمَ سُفَندِشِ عِسِرَيِلَ، وٌ شَ ﭑ شُي رَ مّ.
\q1 
\v 2 عَلَتَلَ شَ مَسٍنيِ نَن يَ،
\q1 نَشَن وٌ دَاشِ وٌ نفَ تّيفّ عِ،
\q1 نَشَن وٌ بُن تِمَ.
\q1 ﭑ مَ كٌنيِ يَشُبَ، هَلِ عِ مُ هَنمّ،
\q1 وٌ تَن يٍسُرُن ﭑ نَشَن سُفَندِشِ،
\q1 
\v 3 بَرِ مَ ﭑ يٍ رَفٌرٌ مَ نّ وٌ شَ بْشِ مَشَرَشِ مَ،
\q1 ﭑ شُرٍ رَ مِنِمَ نّ فبٍنفبٍرٍن يِرٍ مَ.
\q1 ﭑ نَن ﭑ شَشِلِ رَفٌرٌ مَ نّ وٌ بْنسْي مَ،
\q1 ﭑ بَرَكّ سَمَ نّ وٌ شَ دِيٍ مَ.
\q1 
\v 4 عٍ قَنمَ نّ عَلْ حٌوفٍ نَشَن تٌمَ قِيلِ تَفِ،
\q1 عَلْ وُرِ نَشٍيٍ سِشِ شُرٍ دّ عِ.
\q1 
\v 5 ندٍ عَ قَلَمَ نّ، ‹عَلَتَلَ فبٍ نَن ﭑ نَ،›
\q1 عَ يَشُبَ شِلِ سَ عَ شُن مَ.
\q1 ندٍ عَ سّبّمَ نّ عَ بّلّشّ مَ، ‹عَلَتَلَ فبٍ،›
\q1 عَ عِسِرَيِلَ شِلِ سَ عَ شُن مَ.»
\b
\q1 
\v 6 «عَلَتَلَ شَ مَسٍنيِ نَن يَ،
\q1 عَلَتَلَ سّنبّمَ نَشَن قِندِشِ عِسِرَيِلَ مَنفّ نُن عَ رَكِسِمَ رَ.
\q1 ﭑ تَن نَن نَ قٍ قْلّ رَ، ﭑ تَن نَن نَ قٍ رَحْنيِ رَ.
\q1 عَلَ فبّتّ يٌ مُ نَ بَقٍ ﭑ تَن نَ.
\q1 
\v 7 ندٍ مَنِيَشِ ﭑ تَن نَ؟ عَ شَ نَ قَلَ.
\q1 نَ كَنيِ شَ وْيّن بَ، عَ شَ قٍ دَنفِشِ مَسٍن كَبِ ﭑ مَ حَمَ دَا تّمُي.
\q1 عَ شَ قٍ مَسٍن نَشَن قَمَ رَبَدٍ، عِيٌ عَ شَ نَ قَلَ كّنّ مَ.
\q1 
\v 8 وٌ نَشَ فَاشُ، وٌ نَشَ سّرّن.
\q1 ﭑ مُ نَ مَسٍنشِ وٌ بّ شّ، بٍينُ نَ قٍيٍ شَ رَبَ؟
\q1 ﭑ مَ سٍيدٍيٍ نَن وٌ رَ.
\q1 عَلَ فبّتّ نَ نَ، بَ ﭑ تَن نَ؟
\q1 عَدٍ، قَنيٍ فبّتّ مُ نَ هَلِ كٍرٍن.»
\b
\q1 
\v 9 قُيَنتٍيٍ نَن كُيٍ يَءِلَنمَيٍ رَ.
\q1 عٍ شَ وَلِ تِدٍ يٌ مُ نَ.
\q1 عٍ شَ سٍيدٍيٍ يَ مُ نَ، عٍ شَشِلِ عِقُشِ.
\q1 عٍ قَمَ لُدٍ نَ يَافِ نَن كُي.
\q1 
\v 10 ندٍ كُيٍ يَءِلَنمَ، نَشَن مُ نْمَ عَ مَلِدٍ قٍقٍ رَ؟
\q1 
\v 11 نَ كَنيِيٍ يَافِمَ نّ.
\q1 عَدَ مَدِ نَن تُن نَ عٍ رَ.
\q1 عٍ بِرِن شَ عٍ مَلَن، عٍ شَ تِ ﭑ يَ رَ.
\q1 ﭑ عٍ بِرِن نَفٌرٌ مَ نّ فَاشُي نُن حَشَنكَتّ رَ.
\b
\q1 
\v 12 كُيٍ يَءِلَنمَ وُرٍ شَبُمَ تّ شْورَ،
\q1 عَ كُيٍيٍ يَءِلَن دّرّ مَ رَ، عَ عَ رَوَلِ عَ يّتّ سّنبّ رَ.
\q1 كَامّ نُن يٍ شْلِ لُمَ نّ عَ سُشُ رَ، عَ قَ تَفَن.
\q1 
\v 13 كَمُدّرِ لُوتِ عِتَلَمَ نّ عَ مَنِيَقٍ رَ، عَ عَ كْورِن.
\q1 عَ وَلِ قْلْ وَلِ سٍيٍ رَ،
\q1 عَ عَ يَءِلَن هَن عَ لُ عَلْ مِشِ تٌقَنيِ نَشَن تِمَ عَ شَ بَنشِ كُي.
\q1 
\v 14 عَ نُ وُرِ ندٍيٍ سِ قْتْنيِ يِرٍ،
\q1 عَ مَمّ تِ هَن تُنّ يٍ عَ رَ مْ، عَ قَ عَ سّفّ.
\q1 
\v 15 عَ ندٍ قِندِ يٍفٍ رَ، عَلَكٌ شِنبٍلِ نَشَ عَ سُشُ،
\q1 عَ ندٍ رَوَلِ تَامِ فَنقٍ رَ.
\q1 كْنْ نَشَن لُشِ، عَ نَ قِندِ عَلَ رَ عَ نَشَن بَتُمَ،
\q1 عَ كُيٍ رَقَلَ، عَ سُيِدِ عَ بّ.
\q1 
\v 16 عَ سّيتِ قِندِ يٍفٍ رَ،
\q1 عَ سُبٍ فَنمَ نَشَن نَ،
\q1 عَ قَ عَ دّفٍ، عَ عَ قَلَ، «يِ تّ قَن. شِنبٍلِ مُ ﭑ سُشُمَ بٍ.»
\q1 
\v 17 عَ وُرِ دْنشْي نَن قِندِ مَ عَ شَ كُيٍ عَلَ رَ،
\q1 عَ سُيِدِ نَشَن بّ عَ بَتُقٍ رَ.
\q1 عَ مَشَندِ تِ عَ بّ، عَ قَلَقٍ رَ،
\q1 «ﭑ نَكِسِ، بَرِ مَ عِ تَن نَن ﭑ مَ عَلَ رَ.»
\q1 
\v 18 كْنْ نَ مِشِ مُ فّشِ قَهَامُي سْتْدٍ.
\q1 عَ لُشِ عَلْ دْنشُي نَشَن مُ سٍ تٌمَ،
\q1 عَ شَشِلِ مُ قَتَ قٍيٍ تَفِ رَبَدٍ.
\q1 
\v 19 سٍسٍ مُ عَ عَ بْحّ رَتِمَ سْنْن، عَ شَ عَ مَحْشُن،
\q1 «ﭑ بَرَ وُرِ سّيتِ سَ تّ عِ،
\q1 عَلَكٌ ﭑ شَ تَامِ نُن سُبٍ فَن عَ تّ وٌلٍ رَ ﭑ نَشَن دٌنمَ.
\q1 عَ لَنمَ ﭑ شَ نَ وُرِ دْنشْي رَقَلَ كُيٍ رَ عَلَ نَشَن شْنمَ؟
\q1 ﭑ شَ ﭑ سُيِدِ وُرِ شُنتُنيِ بّ؟»
\q1 
\v 20 نَ كُيٍ يَءِلَنمَ بِرَ مَ سٍ نَن قْشْ رَ نَشَن قِندِ مَ تّ شُبٍ رَ.
\q1 عَ بْحّ بَرَ عَ يّتّ يَنقَ.
\q1 عَ مُ قَتَ عَ يّتّ رَكِسِدٍ،
\q1 عَ مَن مُ شَشِلِ سْتْ عَ قَلَقٍ رَ، «ﭑ نَشَن تِشِ ﭑ بّلّشّ رَ وُلٍ عَلَ نَن عَ رَ.»
\b
\q1 
\v 21 «يَشُبَ بْنسْي، وٌ شَ رَتُ يِ قٍيٍ مَ،
\q1 وٌ تَن عِسِرَيِلَ حَمَ نَشَن قِندِشِ ﭑ مَ كٌنيِ رَ.
\q1 ﭑ وٌ دَا نّ، عَلَكٌ وٌ شَ قِندِ ﭑ مَ كٌنيِ رَ.
\q1 عِسِرَيِلَ، ﭑ مُ نّيمُمَ وٌ مَ.
\q1 
\v 22 ﭑ بَرَ وٌ شَ يُنُبِيٍ شَقَرِ، وٌ نَشَن سْتْ وٌ شَ مُرُتّ كُي،
\q1 ﭑ بَرَ نٍيٍ بَ نَا عَلْ نُشُي بَمَ كٌورٍ مَ كِ نَشّ.
\q1 وٌ شَ فبِلٍن ﭑ مَ، بَرِ مَ ﭑ بَرَ وٌ شُن سَرَ.»
\b
\q1 
\v 23 كٌورٍ شَ سّيوَ عَلَتَلَ شَ وَلِ شَ قٍ رَ.
\q1 بْشِ بُنيِ شَ عَ شُي رَ مِنِ.
\q1 فٍيَيٍ شَ عٍ شُي عِتٍ عَلْ وُرِ نَشٍيٍ نَ قْتْنيِ كُي،
\q1 بَرِ مَ عَلَتَلَ بَرَ يَشُبَ شُن سَرَ،
\q1 عَ بَرَ عَ نْرّ مَسٍن عِسِرَيِلَ يَ مَ.
\b
\q1 
\v 24 وٌ رَكِسِمَ عَلَتَلَ شَ مَسٍنيِ نَن يَ نَشَن وٌ رَقَلَشِ وٌ نفَ تّيفّ،
\q1 «ﭑ تَن، عَلَتَلَ نَن ﭑ نَ، نَشَن قٍ بِرِن دَاشِ،
\q1 نَشَن كٌورٍ عِتَلَ،
\q1 نَشَن بْشِ رَقَلَ عَ بّلّشّ رَ،
\q1 
\v 25 نَشَن نَمِحْنمّ وُلٍ قَلّيٍ شَ تْنشُمَيٍ كَنَ،
\q1 نَشَن سٍمَتٌي رَيَافِ،
\q1 نَشَن لْننِلَيٍ شَ مَرَ سِ مَقِندِ لْننِتَرٍحَ رَ،
\q1 
\v 26 نَشَن عَ شَ نَمِحْنمّ كٌنيِيٍ شَ مَسٍنيِيٍ رَكَمَلِ،
\q1 نَشَن عَ شَ شّيرَيٍ شُي قِندِ نْندِ رَ،
\q1 نَشَن عَ مَسٍنمَ دَرِ سَلَمُ شَ قٍ رَ، ‹حَمَ قَمَ سَبَتِدٍ نَا،›
\q1 نَشَن عَ مَسٍنمَ يُدَيَ تَايٍ شَ قٍ رَ، ‹عٍ مَن قَمَ نّ تِدٍ،›
\q1 
\v 27 نَشَن عَ قَلَمَ بَا بّ، ‹شَرَ، ﭑ عِ شَ يٍ رَشْرِ مَ نّ،›
\q1 
\v 28 نَشَن مَنفّ سِرُ سِ شّيمَ عَ سَفٌ رَبَدٍ، عَلْ شُرُ سٍ مَدٌنيِ عَ رَبَمَ كِ نَشّ،
\q1 نَشَن عَ مَسٍنمَ دَرِ سَلَمُ شَ قٍ رَ، ‹عَ مَن شَ تِ،›
\q1 نَشَن عَ مَسٍنمَ هْرْ مْبَنشِ شَ قٍ رَ، ‹عَ مَن شَ تِ!›»
\c 45
\s1 عَلَ شَ وَلِ نُن سِرُ سِ
\q1 
\v 1 عَلَتَلَ شَ مَسٍنيِ نَن يَ عَ شَ مِشِ سُفَندِشِ سِرُ سِ بّ،
\q1 عَ نَشَن شّيشِ حَمَنّيٍ شُن نَكَنَقٍ رَ، عٍ شَ لُ عَ شَ يَامَرِ بُن مَ،
\q1 عَ نَادّ رَبِشِ نَشَن بّ عَلَكٌ عَ شَ وَلِ شَ سْونّيَ.
\q1 
\v 2 «ﭑ تِمَ نّ عِ يَ رَ، ﭑ تٍنتٍنيِ مَفٌرٌ عِ بّ،
\q1 ﭑ وُرٍ فبٍيلِ نَادّيٍ كَنَ، ﭑ وُرٍ نَادّيٍ يٍنسٍن يّ عِ يَ رَ.
\q1 
\v 3 ﭑ نَاقُلِ نْشُنشِ قِمَ نّ عِ مَ،
\q1 عَلَكٌ عِ شَ عَ كٌلٌن ﭑ تَن نَن عِسِرَيِلَ مَرِفِ عَلَتَلَ رَ،
\q1 نَشَن عِ شِلِشِ عِ شِلِ يَتِ رَ.
\q1 
\v 4 ﭑ مَ كٌنيِ يَشُبَ شَ قٍ رَ،
\q1 ﭑ مَ حَمَ سُفَندِشِ عِسِرَيِلَ،
\q1 ﭑ عِ شِلِشِ عِ شِلِ نَن نَ، ﭑ بِنيّ قِمَ نّ عِ مَ هَلِ عِ تٌ مُ ﭑ كٌلٌنشِ سِندٍن.
\q1 
\v 5 ﭑ تَن نَن نَ عَلَتَلَ رَ،
\q1 عَلَ فبّتّ يٌ مُ نَ بَقٍ ﭑ تَن نَ.
\q1 ﭑ سّنبّ قِمَ نّ عِ مَ هَلِ عِ تٌ مُ ﭑ كٌلٌنشِ سِندٍن.
\q1 
\v 6 نَ كُي مِشِ بِرِن قَمَ نّ عَ كٌلٌندٍ عَ عَلَ كٍرٍنيِ نَن ﭑ نَ،
\q1 كٍلِقٍ سٌفٍتٍدٍ هَن سٌفٍفٌرٌدٍ،
\q1 عَلَ فبّتّ يٌ مُ نَ.
\q1 
\v 7 ﭑ تَن نَن كٌورٍ عِيَلَنمَ، ﭑ دِ مِ رَ سِن،
\q1 ﭑ تَن نَن هّرِ رَ مِنِمَ، ﭑ فبَلٌي رَبَ.
\q1 ﭑ تَن عَلَتَلَ نَ ﭑ نَ قٍيٍ بِرِن نَبَمَ.»
\b
\q1 
\v 8 «تُنّ يٍ شَ فٌرٌ كٍلِقٍ كٌورٍ مَ، نُشُي شَ رَبِ يٍ رَ مِنِقٍ رَ.
\q1 بْشِ قَن شَ رَبِ نَ يٍ سْتْقٍ رَ.
\q1 كِسِ شَ سْتْ عَلْ سَنسِ بُلَمَ كِ نَشّ، تِنشِنيِ شَ لُ نَ.
\q1 ﭑ تَن عَلَتَلَ نَن نَ بِرِن دَاشِ.»
\b
\q1 
\v 9 حَشَنكَتّ نَ مِشِ بّ، نَشَن عَ يَءِلَنمَ مَتَندِ مَ،
\q1 نَشَن قِندِشِ قّحّ شُنتُنيِ تُن نَ.
\q1 بّندّ دٌلٌشِ عَ قَلَمَ قّحّ يَءِلَنمَ بّ،
\q1 «عِ ﭑ يَءِلَنقٍ مُنسٍ رَ؟ عِ شَ وَلِ مُ قَن!»
\q1 
\v 10 حَشَنكَتّ نَ مِشِ بّ، نَشَن عَ قَلَمَ عَ بَبَ نُن عَ نفَ بّ،
\q1 «وٌ مُنسٍ بَرِشِ؟»
\b
\q1 
\v 11 عَلَتَلَ شَ مَسٍنيِ نَن يَ،
\q1 عِسِرَيِلَ شَ سّنِيّنتْي نَشَن وٌ دَاشِ،
\q1 «وٌ وَ مَ ﭑ مَشْرِنقٍ تِنَ قٍ نَن مَ ﭑ نَشَن نَبَمَ ﭑ مَ دِيٍ رَ؟
\q1 وٌ وَ مَ ﭑ يَمَرِقٍ ﭑ مَ وَلِ شَ قٍ نَن نَ؟
\q1 
\v 12 ﭑ تَن نَن بْشِ يَءِلَنشِ، ﭑ قَ مِشِ دَا عَ قَرِ.
\q1 ﭑ تَن نَن كٌورٍ عِتَلَ ﭑ بّلّشّ رَ، ﭑ تُنبُييٍ يَمَرِ.
\q1 
\v 13 ﭑ تَن نَن مَن سِرُ سِ شّيمَ ﭑ مَ تِنشِنيِ شَ قٍ رَ.
\q1 ﭑ كِرَ رَبْو مَ نّ عَ بّ عَلَكٌ عَ شَ ﭑ مَ تَا تِ،
\q1 عَ شَ ﭑ مَ حَمَ شْرْيَ شُنسَرٍ شَنبِ.»
\q1 عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ.
\b
\q1 
\v 14 عَلَتَلَ شَ مَسٍنيِ نَن يَ،
\q1 «مِسِرَ نُن عٍتِيٌثِ شَ نَاقُلِ لُمَ نّ عِ يِ رَ،
\q1 سٍبَكَيٍ قِندِ مَ نّ عِ شَ كٌنيِيٍ رَ،
\q1 عٍ بِرَ عِ قْشْ رَ يْلْنشْنيِ كُي، عٍ سُيِدِ عِ بّ، عٍ عَ قَلَ عِ بّ،
\q1 ‹عَلَ نَ عِ قْشْ رَ، عَ مَنِيّ مُ نَ، عَلَ فبّتّ مُ نَ.›»
\b
\q1 
\v 15 عِسِرَيِلَ مَرِفِ عَلَ، عَ رَكِسِمَ،
\q1 عَلَ نَن عِ رَ، نَشَن مُ عَ يّتّ مَسٍنمَ كّنّ مَ.
\q1 
\v 16 كُيٍ يَءِلَنمَيٍ قَمَ نّ لُدٍ يَافِ كُي، عٍ عٍ بِرِن شَنِن،
\q1 
\v 17 كْنْ عَلَتَلَ عِسِرَيِلَ تَن رَكِسِمَ نّ عَبَدَن،
\q1 عَ مُ قَمَ يَافِدٍ قٍوٌ.
\q1 
\v 18 عَلَتَلَ نَشَن كٌورٍ دَاشِ، نَشَن قِرِن ندٍ مُ نَ،
\q1 نَشَن دُنِحَ دَاشِ عَ كِ نُن عَ كّحَ نَن مَ،
\q1 عَ قَ عَدَ مَدِيٍ رَ سَبَتِ عَ مَ،
\q1 عَ قَ عَ قَلَ، «عَلَتَلَ نَن نَ، عَلَ فبّتّ يٌ مُ نَ.
\q1 
\v 19 ﭑ مُ وْيّنشِ دُنشُي شَ رَ دٍ.
\q1 ﭑ مُ عَ قَلَ يَشُبَ بْنسْي بّ عٍ شَ ﭑ قٍن نَ كِ تُن.
\q1 ﭑ تَن عَلَتَلَ نْندِ نَن قَلَمَ، ﭑ تِنشِنيِ نَن مَسٍنمَ.»
\b
\q1 
\v 20 «وٌ وٌ مَلَن، وٌ قَ، وٌ وٌ مَسٌ، وٌ تَن مِشِ فِشِيٍ كٍلِقٍ حَمَنّيٍ مَ،
\q1 كُيٍ بَتُييٍ مُ سٍسٍ كٌلٌن،
\q1 عٍ كُيٍ مَشَندِ مَ نَشٍيٍ مُ نْمَ مِشِ رَكِسِدٍ.
\q1 
\v 21 وٌ وٌ شُي رَ مِنِ، وٌ شَ مَرَكٌلٌنيِ تِ عٍ بّ.
\q1 عٍ شَ عٍ بٌرٍ رَ سِ.
\q1 ندٍ يِ مَسٍنيِ تِشِ كَبِ تّمُي شْنكُيٍ؟ ﭑ تَن شَ مُ عَ رَ؟
\q1 عَلَ فبّتّ يٌ مُ نَ بَقٍ ﭑ تَن نَ،
\q1 عَلَ نَشَن تِنشِن، نَشَن مِشِ رَكِسِمَ.
\q1 
\v 22 وٌ شَ فبِلٍن ﭑ مَ، وٌ تَن نَشٍيٍ كٍلِمَ دُنِحَ تُنشُنيِيٍ مَ،
\q1 عَلَكٌ وٌ شَ كِسِ سْتْ،
\q1 بَرِ مَ عَلَ فبّتّ يٌ مُ نَ بَقٍ ﭑ تَن نَ.
\q1 
\v 23 ﭑ بَرَ ﭑ كَلِ ﭑ يّتّ رَ نْندِ كِ مَ،
\q1 ﭑ مَ مَسٍنيِ مُ كَنَمَ قٍقٍ مَ.
\q1 شِنبِ بِرِن سِنمَ نّ ﭑ بُن مَ،
\q1 كَلِ بِرِن نَبَمَ ﭑ تَن نَن شِلِ رَ.
\q1 
\v 24 حَمَ عَ قَلَمَ نّ ﭑ بّ،
\q1 ‹تِنشِنيِ نُن سّنبّ تٌمَ عِ تَن عَلَتَلَ نَن فبَنسَن يِ.›»
\b
\q1 مِشِ نَشٍيٍ نُ مُرُتَشِ عَ مَ،
\q1 عٍ قَمَ نّ عَ يِرٍ يَافِ كُي.
\q1 
\v 25 كْنْ عِسِرَيِلَ بْنسْي فبٍ حْشْمَ نّ عَلَتَلَ سَابُي رَ،
\q1 عٍ قَ شُننَكٍلِ سْتْ.
\c 46
\s1 بَبِلْن شَ عَلَيٍ
\q1 
\v 1 بَبِلْن شَ كُيٍ بٍلِ عَ شِنبِ سِنمَ.
\q1 عَ شَ كُيٍ نٍبٌ قَن عَ قٍلٍنمَ بْشِ مَ.
\q1 سٌقَلٍيٍ عٍ بّندُنمَ شَنِن سٍ قَرِ.
\q1 نَ كٌتٍ بِنيَ، عَ سٌقَلٍيٍ رَتَفَنمَ نّ.
\q1 
\v 2 عٍ مُ نْ نَ كُيٍيٍ رَتَنفَدٍ.
\q1 عٍ بِرِن شَ سِفَ كٌنيِيَ كُي.
\b
\q1 
\v 3 «يَشُبَ بْنسْي، وٌ وٌ تُلِ مَتِ ﭑ نَ.
\q1 عِسِرَيِلَكَ نَشٍيٍ لُشِ، وٌ وٌ تُلِ مَتِ ﭑ نَ.
\q1 كَبِ وٌ بَرِشِ تّمُي نَشّ، ﭑ بَرَ وٌ شَنِن ﭑ بّلّشّ، ﭑ بَرَ وٌ بُن تِ.
\q1 
\v 4 ﭑ نُ نَ رَبَ نّ هَن وٌ قٌرِ وَشَتِ.
\q1 وٌ شُنسّشّ تٌ نُ قِيشّمَ، ﭑ تَن نَن مَن نُ وٌ بُن تِمَ.
\q1 ﭑ تٌ وٌ دَا، ﭑ مَن نُ وٌ مَلِمَ نّ، ﭑ وٌ شَنِن، ﭑ وٌ رَكِسِ.
\q1 
\v 5 وٌ ﭑ مَ مَنِيّ تٌمَ مِندٍن؟ وٌ ﭑ قِرِن ندٍ كٌلٌن؟
\q1 
\v 6 نَاقُلِ كَنيِ شّيمَ نُن فبٍتِ رَ مِنِمَ، عَ عَ سَ سِكٍيلِ قَرِ،
\q1 عَلَكٌ شَبُي شَ كُيٍ ندٍ يَءِلَن عَ بّ،
\q1 عَ عَ شِنبِ سِنمَ نَشَن بّ عَ بَتُقٍ رَ.
\q1 
\v 7 عٍ نَ تٌنفٌ، عٍ عَ دْشْ عٍ تُنكِ قَرِ، عٍ عَ شَنِن يِرٍ، عٍ عَ تِمَ دّننَشّ.
\q1 مّننِ عَ تِشِ تُن، عَ مُ سِفَمَ دّدّ.
\q1 هَلِ مِشِ ندٍ عَ مَوَ عَ بّ، عَ مُ عَ يَابِمَ،
\q1 عَ مُ مِشِ رَتَنفَمَ عَ شَ تْورّ مَ.»
\b
\q1 
\v 8 «وٌ تَن مُرُتّلَيٍ، وٌ شَ رَتُ نَ قٍيٍ مَ، عَلَكٌ وٌ شَ نْ كِسِدٍ.
\q1 
\v 9 وٌ شَ رَتُ ﭑ نَشَن نَبَشِ تّمُي دَنفِشِ.
\q1 عَلَ فبّتّ يٌ مُ نَ بَقٍ ﭑ تَن نَ، ﭑ قِرِن ندٍ مُ نَ.
\q1 
\v 10 عَلَ فبّتّ مُ نَ نَشَن قٍ مَسٍنمَ بٍينُن عَ شَ رَبَ،
\q1 نَشَن نْمَ عَ قَلَدٍ،
\q1 ‹ﭑ وَشْنقٍ قَمَ نّ رَكَمَلِدٍ. ﭑ تَن نَن عَ رَفِرِ مَ.›
\q1 
\v 11 ﭑ تَن نَن شْنِ ندٍ شِلِمَ كٍلِقٍ سٌفٍتٍدٍ مَبِرِ،
\q1 نَشَن ﭑ وَشْنقٍ رَبَمَ ﭑ بّ.
\q1 عِيٌ، ﭑ نَشَن قَلَشِ، ﭑ عَ رَبَمَ نّ،
\q1 ﭑ نَشَن نَتّشِ، ﭑ عَ رَكَمَلِمَ نّ.
\q1 
\v 12 وٌ وٌ تُلِ مَتِ ﭑ نَ، وٌ تَن نَشٍيٍ شَشِلِ شْرْشْ،
\q1 وٌ تَن نَشٍيٍ مَكُيَشِ تِنشِنيِ رَ.
\q1 
\v 13 ﭑ مَ كِيتِ تِنشِنشِ بَرَ مَكْرّ، عَ مُ مَكُيَ قٍوٌ.
\q1 ﭑ قَمَ ﭑ مَ كِسِ قَن نَ، عَ مُ بُمَ.
\q1 ﭑ سِيٌن رَكِسِمَ نّ،
\q1 ﭑ نَن ﭑ مَ نْرّ رَفٌرٌ مَ نّ عِسِرَيِلَ مَ.»
\c 47
\s1 بَبِلْن بِرَقٍ
\q1 
\v 1 «بَبِلْن تَا، كٍلِ عِ شَ كِبَنيِ كُي، عِ دْشْ بْشِ مَ.
\q1 عِ شَ تٌقَنيِ نُن عِ شَ بَننَيَ بَمَ نّ عِ يِ.
\q1 
\v 2 وَلِ سٍيٍ تٌنفٌ كُرِ سٌقٍ رَ.
\q1 عِ شَ مَقٍلٍنيِ بَمَ نّ عِ مَ، عِ شَ دُفِ مَتٍ، عِ شُرٍ عِفِرِ عِ مَفٍلِ رَ.
\q1 
\v 3 عِ حَءِبْمَ نّ يَافِ كُي،
\q1 ﭑ قَمَ نّ ﭑ فبٍ حْشْدٍ كِنِكِنِ شَنبِ.»
\q1 
\v 4 عَلَتَلَ سّنبّمَ نَن قِندِ مُشُ شُنسَرَ مَ رَ، عِسِرَيِلَ شَ سّنِيّنتْي.
\b
\q1 
\v 5 «بَبِلْن حَمَ، وٌ دْشْ، وٌ وٌ دّ بَلَن.
\q1 وٌ شَ مَنفّيَ بَرَ حْن.
\q1 
\v 6 ﭑ نُ شْنْشِ ﭑ مَ حَمَ مَ، ﭑ قَ عٍ كّ تٌنفٌمَيٍ شُن نَكَنَ.
\q1 ﭑ نَشَ عٍ لُ وٌ سَفٌي، كْنْ وٌ مُ كِنِكِنِ عٍ مَ قٍقٍ مَ.
\q1 هَلِ قٌرِيٍ، وٌ بَرَ عٍ حَشَنكَتَ عَ حَاشِ رَ.
\q1 
\v 7 وٌ نُ عَ قَلَمَ نّ، ‹ﭑ مَ مَنفّيَ مُ حْنمَ عَبَدَن!›
\q1 كْنْ وٌ مُ وٌ حْشْ سَشِ قٍ شْن مَ نَشَن نْمَ وٌ لِدٍ.»
\b
\q1 
\v 8 «يَكْسِ وٌ وٌ تُلِ مَتِ ﭑ نَ،
\q1 وٌ تَن بَننَ نَشٍيٍ عَ مَحْشُنشِ عَ قٍقٍ مُ نْمَ وٌ تْورْدٍ،
\q1 نَشٍيٍ عَ قَلَمَ، ‹ﭑ كٍرٍن نَن تِدٍ فبٌ دُنِحَ،
\q1 ﭑ مُ قِندِ مَ كَاحّ رَ، ﭑ مَ دِيٍ مُ بَمَ ﭑ يِ.›
\q1 
\v 9 كْنْ ﭑ شَ عَ قَلَ وٌ بّ، نَ قٍ قِرِنيِيٍ وٌ لِمَ نّ قّيحّن كٍرٍن كُي.
\q1 وٌ فَنمَ نّ وٌ شَ دِيٍ رَ، وٌ قِندِ كَاحّ رَ
\q1 هَلِ وٌ دُورٍيَ نُن كَرَ مْشْ وَلِ رَوُيَ.
\q1 
\v 10 وٌ نُ لَشِ وٌ شَ حَاشُحَ نَن نَ،
\q1 وٌ حْشْ عَ مَ نَ مُ تٌمَ.
\q1 وٌ شَ قٍ كٌلٌنيِ بَرَ وٌ مَدَشُ.
\q1 وٌ بَرَ عَ قَلَ وٌ بْحّ مَ، ‹ﭑ كٍرٍن نَن بٍ، ﭑ تَن نَن فبَنسَن تِدٍ فبٌ.›
\q1 
\v 11 فبَلٌي قَمَ نّ وٌ لِدٍ، وٌ مُ نْمَ وٌ يّتّ رَتَنفَدٍ نَشَن مَ وٌ شَ نَاقُلِ رَ،
\q1 فبَلٌي نَشَن وٌ تّرّننَمَ.»
\b
\q1 
\v 12 «وٌ تٌ لَشِ نَ قٍ مْولِ نَن نَ، وٌ شَ لُ وٌ شَ دُورٍيَ،
\q1 نُن وٌ شَ مَندُرُيَ كُي وٌ دَرِشِ نَشَن نَ.
\q1 وٌ عَ مَحْشُن عَ نَ سْونّيَمَ نّ وٌ بّ، وٌ قَ فٍينِ وٌ يَشُي شُن مَ،
\q1 
\v 13 كْنْ نَ بِرِن قَمَ نّ وٌ رَتَفَندٍ.
\q1 وٌ شَ سٍ مَتٌي شِلِ، نَشٍيٍ كٌورٍ مَتٌمَ، عٍ قٍ قَلَ نَشَن قَمَ وٌ لِدٍ.
\q1 
\v 14 نٍيٍ تَن قَن لُمَ نّ عَلْ سّشّ نَشَن فَنمَ تّ رَ.
\q1 عٍ مُ نْمَ عٍ يّتّ رَكِسِدٍ تّ شْورَ.
\q1 سٍسٍ مُ لُمَ عٍ يِ رَ، هَلِ تّ شُنشُرِ عٍ دْشْمَ نَشَن سّيتِ مَ شِنبٍلِ تّمُي.
\q1 
\v 15 عٍ مُ نْمَ قٍقٍ رَبَدٍ وٌ بّ،
\q1 هَلِ وٌ تٌ بَرَ وٌ شَشِلِ تِ عٍ رَ كَبِ وٌ دِ مّدِ تّمُي.
\q1 عٍ سِفَمَ نّ يَرٍ عٍ شَ كِرَ حَاشِ شْن مَ.
\q1 مِشِ يٌ مُ نْمَ وٌ رَكِسِدٍ.»
\c 48
\s1 عِسِرَيِلَ نُن عَلَ شَ لَنيِ
\q1 
\v 1 «يَشُبَ بْنسْي نَشَن شِلِ عِسِرَيِلَ، نَشَن قَتَنشِ يُدَيَ رَ،
\q1 وٌ وٌ تُلِ مَتِ ﭑ نَ.
\q1 وٌ تَن نَشٍيٍ وٌ كَلِمَ عَلَتَلَ شِلِ رَ،
\q1 وٌ تَن نَشٍيٍ عِسِرَيِلَ مَرِفِ عَلَ مَشَندِ مَ تِنشِنتَرٍيَ كُي،
\q1 
\v 2 وٌ تَن نَشٍيٍ وٌ يّتّ شِلِمَ تَا سّنِيّنشِ كَنيِيٍ،
\q1 وٌ تَن نَشٍيٍ وٌ شَشِلِ تِمَ عِسِرَيِلَ مَرِفِ عَلَتَلَ رَ،
\q1 
\v 3 ﭑ نَشَن مَسٍنشِ وٌ بّ تّمُي دَنفِشِ، ﭑ بَرَ فّ نَ رَفِرِدٍ.
\q1 
\v 4 ﭑ تٌ عَ كٌلٌن وٌ شَشِلِ شْرْشْ عَلْ وُرٍ،
\q1 
\v 5 ﭑ نَشَ وٌ رَكٌلٌن نَ قٍ رَ بٍينُن عَ شَ رَبَ،
\q1 عَلَكٌ وٌ نَشَ قَ عَ قَلَ،
\q1 ‹مُشُ شَ كُيٍ وُرِ دَاشِيٍ نُن وُرٍ دَاشِيٍ نَن نَ قٍ نَتّشِ.›
\q1 
\v 6 وٌ بَرَ نَ مّ؟ وٌ بَرَ سٌ نَ قٍ كُي؟»
\b
\q1 «يَكْسِ ﭑ قٍ نّينّيٍ مَسٍنمَ نّ وٌ بّ،
\q1 نَشٍيٍ نُ بَرَ نْشُن وٌ مَ.
\q1 
\v 7 نٍيٍ مِنِشِ يِ وَشَتِ نّ،
\q1 وٌ مُ نُ نَشٍيٍ كٌلٌن.
\q1 نَ كُي وٌ مُ نْمَ عَ قَلَدٍ، ‹عِيٌ، مُشُ نُ نٍيٍ كٌلٌن.›
\q1 
\v 8 وٌ مُ نَ قٍيٍ قَهَامُشِ تّمُي دَنفِشِ بَرِ مَ وٌ تُلِ شْرْشْ.
\q1 يَنقَنتٍيٍ نَن وٌ رَ كَبِ وٌ بَرِ تّمُي.
\q1 
\v 9 ﭑ شِلِ شَ قٍ رَ، ﭑ مُ ﭑ مَ شْنّ رَ مِنِ وٌ مَ كٍرٍنيِ رَ.
\q1 ﭑ مَ مَتْشْي شَ قٍ رَ، ﭑ مُ وٌ رَبٌلٌ.
\q1 
\v 10 ﭑ بَرَ وٌ مَتٌ، كْنْ ﭑ مُ عَ رَبَشِ عَلْ شَبُي عَ رَبَمَ كِ نَشّ فبٍتِ رَ.
\q1 ﭑ وٌ مَتٌمَ تْورّ نَن سَابُي رَ.
\q1 
\v 11 ﭑ يِ رَبَمَ ﭑ يّتّ بّ عَلَكٌ ﭑ شِلِ نَشَ كَنَ،
\q1 عَلَكٌ ﭑ مَ مَتْشْي نَشَ قِ ﭑ قِرِن ندٍ مَ.»
\b
\q1 
\v 12 «يَشُبَ بْنسْي، وٌ وٌ تُلِ مَتِ ﭑ نَ.
\q1 عِسِرَيِلَ ﭑ نَشَن شِلِشِ، وٌ وٌ تُلِ مَتِ ﭑ نَ.
\q1 ﭑ تَن نَن نَ عَ سِنفٍ رَ، ﭑ تَن نَن نَ عَ دْنشْي رَ.
\q1 
\v 13 ﭑ بّلّشّ نَن دُنِحَ بُنيِ سَشِ،
\q1 ﭑ سّنبّ نَن كٌورٍ عِتَلَشِ.
\q1 ﭑ نَ عٍ شِلِ، عٍ تِمَ نّ كٍرٍن نَ.»
\b
\q1 
\v 14 «وٌ شَ وٌ مَلَن، وٌ شَ وٌ تُلِ مَتِ ﭑ نَ.
\q1 كُيٍ مُندُن بَرَ يِ قٍ مَسٍن وٌ بّ بٍينُن عَ شَ رَبَ؟
\q1 عَلَتَلَ بَرَ مِشِ ندٍ سُفَندِ نَشَن عَ سَفٌي رَبَمَ بَبِلْن نَ،
\q1 نَشَن عٍ شِلِ شُن نَكَنَمَ.
\q1 
\v 15 عِيٌ، ﭑ تَن يَتِ بَرَ ﭑ مَ مَسٍنيِ تِ،
\q1 ﭑ بَرَ عَ شِلِ، عَ شَ نَ وَلِ رَكَمَلِ.»
\b
\q1 
\v 16 «وٌ وٌ مَسٌ ﭑ نَ، وٌ شَ وٌ تُلِ مَتِ.
\q1 كَبِ عَ قْلّ، ﭑ مُ وْيّن دُنشُي رَ.
\q1 نَ قٍ رَبَمَ ﭑ يَ شْرِ.»
\b
\q1 يَكْسِ، ﭑ مَرِفِ عَلَتَلَ نَ ﭑ شّيقٍ، عَ عَ شَشِلِ رَفٌرٌشِ ﭑ مَ.
\b
\q1 
\v 17 وٌ رَكِسِمَ عَلَتَلَ، عِسِرَيِلَ شَ سّنِيّنتْي، عَ شَ مَسٍنيِ نَن يَ،
\q1 «ﭑ تَن قِندِشِ وٌ مَرِفِ عَلَتَلَ نَن نَ،
\q1 نَشَن وٌ شَ قٍ سْونّيَ كِ مَسٍنمَ،
\q1 نَشَن وٌ رَحّرّ مَ حّرّ كِ قَنيِ رَ.
\q1 
\v 18 شَ وٌ وٌ حْشْ سَ ﭑ مَ سّرِيّ شْن مَ نُ،
\q1 بْحّسَ نُن كِسِ نُ فبٌمَ نّ وٌ يِ رَ عَلْ يٍ نَشَن نَ بَا مَ.
\q1 
\v 19 وٌ بْنسْي نُ وُيَمَ نّ عَلْ مّيّنيِ نَشَن نَ بَا دّ رَ،
\q1 وٌ شَ دِيٍ شِلِيٍ مُ نُ بَمَ ﭑ يَ عِ.
\q1 
\v 20 وٌ شَ كٍلِ بَبِلْن سّيوّ شُي رَ.
\q1 وٌ شَ نَ مَسٍن دُنِحَ بِرِن بّ.
\q1 وٌ شَ عَ قَلَ، ‹عَلَتَلَ بَرَ عَ كٌنيِ يَشُبَ شُن سَرَ.›
\q1 
\v 21 يٍ شْلِ مُ لُمَ عٍ مَ فبٍنفبٍرٍنيِ مَ،
\q1 عَ قَنيٍ عِبْو مَ، عَ يٍ رَ مِنِ عَ كُي.
\q1 
\v 22 مِشِ حَاشِ شَ قٍ مُ سْونّيَمَ.»
\q1 عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ.
\c 49
\s1 عَلَتَلَ شَ كٌنيِ
\q1 
\v 1 سِ يٍنسٍنشِيٍ، وٌ شَ وٌ تُلِ مَتِ ﭑ نَ.
\q1 يِرٍ مَكُيٍيٍ، وٌ شَ وٌ حْشْ سَ ﭑ وْيّن شُي شْن مَ.
\q1 عَلَتَلَ ﭑ شِلِ نّ كَبِ ﭑ نفَ تّفّ،
\q1 عَ نَشَ ﭑ شِلِ قَلَ بٍينُن ﭑ شَ مِنِ قٌيٍ رَ.
\q1 
\v 2 عَ نَشَ ﭑ دّ لُ عَلْ سَنتِدّفّمَ شّحّنشِ عَ بّلّشّ،
\q1 عَ نَشَ ﭑ قِندِ شَلِ حْي رَ مٍلُشِ رَ،
\q1 عَ نَشَ ﭑ سَ عَ شَ شَلِ فبْنقْي كُي.
\q1 
\v 3 عَ نَشَ عَ قَلَ ﭑ بّ، «عِسِرَيِلَ، ﭑ مَ كٌنيِ نَن عِ رَ،
\q1 ﭑ نَ ﭑ مَ نْرّ مَسٍنمَ نَشَن سَابُي رَ.»
\q1 
\v 4 كْنْ ﭑ نَشَ عَ يَابِ، «ﭑ مَ وَلِ مُ سْونّيَشِ،
\q1 ﭑ بَرَ كَتَ، كْنْ قُقَقُ نَ عَ رَ.
\q1 ﭑ مَ وَلِ سَرٍ نَ ﭑ مَرِفِ عَلَتَلَ نَن يِ.»
\b
\q1 
\v 5 نَ كُي عَلَتَلَ نَشَ مَسٍنيِ ندٍ تِ،
\q1 نَشَن ﭑ دَا ﭑ نفَ تّفّ عِ، ﭑ شَ قِندِ عَ شَ كٌنيِ رَ،
\q1 عَلَكٌ ﭑ شَ يَشُبَ بْنسْي رَفبِلٍن عَ مَ،
\q1 عِسِرَيِلَ حَمَ مَن شَ مَلَن عَ قّ مَ.
\q1 عَلَتَلَ بَرَ بِنيّ شُنفبٍ قِ ﭑ مَ،
\q1 عَ تَن نَشَن قِندِشِ ﭑ سّنبّ رَ.
\q1 
\v 6 عَ نَشّ، «يَشُبَ بْنسْي عِسِرَيِلَ رَفبِلٍنقٍ ﭑ مَ،
\q1 وَلِ نَ عَ رَ نَشَن شُرُن عِ بّ ﭑ مَ كٌنيِ.
\q1 ﭑ مَن عِ قِندِ مَ نّ نَءِيَلَنيِ رَ سِ فبّتّيٍ بّ،
\q1 عَلَكٌ ﭑ مَ كِسِ شَ مَسٍن دُنِحَ يِرٍ بِرِن.»
\b
\q1 
\v 7 عَلَتَلَ شَ مَسٍنيِ نَن يَ،
\q1 عَلَتَلَ نَشَن قِندِشِ عِسِرَيِلَ شُنسَرَ مَ رَ، عِسِرَيِلَ شَ سّنِيّنتْي،
\q1 وٌن بْنسْي نَشَن شْنشِ،
\q1 نَشَن وَلِشِ مَنفّيٍ بّ،
\q1 «مَنفّيٍ نَ وٌ تٌ، عٍ تِمَ نّ،
\q1 كُنتِفِيٍ نَ وٌ تٌ، عٍ عٍ شِنبِ سِنمَ نّ وٌ بُن مَ،
\q1 بَرِ مَ دُفُتّفّ عَلَتَلَ نَشَن عِسِرَيِلَ شَ سّنِيّنتْي رَ،
\q1 نَ نَن وٌ سُفَندِشِ.»
\b
\q1 
\v 8 عَلَتَلَ شَ مَسٍنيِ نَن يَ،
\q1 «ﭑ وٌ يَابِمَ يَابِ تّمُي نّ،
\q1 ﭑ وٌ رَكِسِمَ كِسِ لْشْي نّ.
\q1 ﭑ وٌ مَكَنتَمَ نّ،
\q1 ﭑ وٌ تِمَ نّ عَلْ حَمَ ﭑ سَاتّ تٌنفٌ نَشَن بّ،
\q1 عَلَكٌ وٌ شَ بْشِ شَ قَن، نَشَن كَنَشِ عَ شَ يَءِلَن.
\q1 
\v 9 فٍيلِمَنِيٍ مِنِمَ نّ،
\q1 مِشِ نَشٍيٍ نَ دِ مِ شْورَ، نٍيٍ شْرّيَ سْتْمَ نّ.
\q1 
\v 10 عٍ لُمَ نّ عَلْ شُرُ سٍيٍ نَشٍيٍ عٍ دّ مَدٌنمَ قِيلِيٍ مَ،
\q1 كَامّ نُن يٍ شْلِ مُ عٍ سُشُمَ،
\q1 كُيٍقُرٍ نُن سٌفٍ شْنّ مُ عٍ تْورْ مَ.
\q1 عٍ رَهِننّمَ نَن لُمَ عٍ رَحّرّ رَ،
\q1 عَ عٍ شُن تِ دُلٌن يِرٍ رَ.
\q1 
\v 11 تٍنتٍنيِ رَفٌرٌ مَ نّ، يِلِ رَقٍ،
\q1 عَلَكٌ عٍ شَ كِرَ شَ قَن.
\q1 
\v 12 عٍ قَمَ نّ كٍلِقٍ يِرٍ مَكُيٍ،
\q1 كٍلِقٍ كْولَ نُن سٌفٍفٌرٌدٍ مَ،
\q1 كٍلِقٍ عَسُوَن بْشِ مَ.»
\b
\q1 
\v 13 «نَشٍيٍ نَ كٌورٍ مَ، عٍ شَ عٍ سّيوّ شُي عِتٍ،
\q1 نَشٍيٍ نَ بْشِ مَ، عٍ شَ حّلّشِن،
\q1 نَشٍيٍ نَ فٍيَيٍ قَرِ، عٍ شَ بّيتِ بَ،
\q1 بَرِ مَ عَلَتَلَ عَ شَ حَمَ مَدُندُ مَ نّ،
\q1 عَ كِنِكِنِ تْورْ مِشِيٍ مَ.»
\b
\q1 
\v 14 كْنْ سِيٌنكَيٍ نُ عَ قَلَمَ نّ،
\q1 «عَلَتَلَ بَرَ مُشُ رَبٌلٌ،
\q1 مُشُ مَرِفِ بَرَ نّيمُ مُشُ مَ.»
\b
\q1 
\v 15 «دِنفّ نْمَ نّيمُدٍ عَ شَ دِيْرّ مَ؟
\q1 عَ مُ كِنِكِنِمَ شّ عَ شَ دِ مَ؟
\q1 هَلِ عَ تَن نّيمُ،
\q1 ﭑ تَن مُ نّيمُمَ وٌ مَ.
\q1 
\v 16 وٌ شِلِيٍ كٌرِنشِ ﭑ بّلّشّ كُي،
\q1 ﭑ يَيٍ تِشِ نّ عِ شَ بَنشِ رَ تّمُي بِرِن.
\q1 
\v 17 وٌ شَ دِيٍ نَ فبِلٍنقٍ وٌ شْنيِ.
\q1 نَشٍيٍ وٌ تْورْشِ، نٍيٍ نَ كٍلِقٍ وٌ شُن مَ.
\q1 
\v 18 وٌ وٌ يَ عِتٍ. وٌ شَ دِيٍ بَرَ عٍ مَلَن، عٍ نَ قَقٍ.
\q1 ﭑ تَن عَلَتَلَ بَرَ ﭑ كَلِ ﭑ يّتّ رَ،
\q1 وٌ شَ مِشِيٍ قَمَ نّ لُدٍ وٌ سّيتِ مَ،
\q1 عَلْ دُفِ تٌقَنيِيٍ لُمَ فِنّ مَ كِ نَشّ عَ شَ قُتِ شِرِ لْشْي.»
\b
\q1 
\v 19 «هَلِ وٌ يَشُييٍ تٌ وٌ شْنيِ كَنَشِ، عٍ وٌ شَ حَمَ رَيٍنسٍن يّ،
\q1 يَكْسِ وٌ قَمَ نّ وُيَدٍ هَن وٌ فبٌ وٌ شَ بْشِ بّ.
\q1 مِشِ نَشٍيٍ كَسَرّ تِشِ وٌ شْنيِ، عٍ بَرَ سِفَ.
\q1 
\v 20 وٌ شَ دِ نَشٍيٍ بَرِشِ يِ تْورْ وَشَتِ،
\q1 عٍ قَمَ نّ عَ قَلَدٍ، ‹بٍ شُرُن وٌن بّ.
\q1 وٌن شَ يِرٍ نّينّ تِ وٌن لُمَ دّننَشّ.›
\q1 
\v 21 نَ تّمُي وٌ قَمَ نّ عَ قَلَدٍ،
\q1 ‹ندٍ يِ دِيٍ بَرِشِ ﭑ بّ؟
\q1 مِشِ رَبّحِنشِ نَن نُ نَ ﭑ نَ.
\q1 عَلَ نُ بَرَ ﭑ نَبٌلٌ، عَ مّي ﭑ نَ.
\q1 ندٍ يِ دِيٍ رَ مْشِ؟
\q1 ﭑ كٍرٍن ثٍتِ نَن نُ عَ رَ.
\q1 يِ دِيٍ كٍلِشِ مِندٍن؟›»
\b
\q1 
\v 22 وٌن مَرِفِ عَلَتَلَ شَ مَسٍنيِ نَن يَ،
\q1 «ﭑ نَن ﭑ بّلّشّ عِتٍمَ نّ حَمَنّيٍ بّ،
\q1 ﭑ تْنشُمَ مَسٍن عٍ بّ،
\q1 عَلَكٌ عٍ شَ قَ وٌ شَ دِ شّمّيٍ رَ عٍ بّلّشّ،
\q1 عٍ شَ قَ وٌ شَ دِ فِنّيٍ رَ عٍ تُنكِ مَ.
\q1 
\v 23 مَنفّيٍ مّينِمَ نّ وٌ شَ دِيٍ مَ،
\q1 مَنفّ فِنّيٍ عٍ رَ مْ.
\q1 نَ مِشِ شُنفبٍيٍ عٍ شِنبِ سِنمَ نّ وٌ بُن مَ،
\q1 عٍ وٌ سَنيِيٍ مَسُنبُمَ نّ.
\q1 نَ كُي وٌ قَمَ نّ عَ كٌلٌندٍ عَ عَلَتَلَ نَ ﭑ تَن نَن نَ.
\q1 مِشِ نَشٍيٍ عٍ شَشِلِ تِمَ ﭑ نَ، نَ كَنيِ مُ يَافِمَ.»
\b
\q1 
\v 24 سْورِ شَ سٍ تٌنفٌشِ نْمَ رَ سُشُدٍ عَ يِ رَ؟
\q1 سّنبّمَ شَ مِشِ سُشُشِ نْمَ بَدٍ عَ يِ رَ؟
\q1 
\v 25 عَلَتَلَ وٌ يَابِمَ يِ كِ نّ؛
\q1 «عِيٌ، ﭑ سْورِ شَ سٍ تٌنفٌشِ رَ سُشُمَ نّ عَ يِ رَ،
\q1 ﭑ سّنبّمَ شَ مِشِ سُشُشِ بَمَ نّ عَ يِ رَ.
\q1 ﭑ وٌ فٍرٍقَيٍ فٍرٍ مَ نّ، ﭑ وٌ شَ دِيٍ رَكِسِ.
\q1 
\v 26 نَشٍيٍ وٌ حَشَنكَتَمَ، عٍ قَمَ نّ عٍ يّتّ سُبٍ دٌندٍ،
\q1 عٍ سِيسِمَ نّ عٍ يّتّ وُلِ رَ.
\q1 نَ كُي عِبُنَدَ مَ بِرِن عَ كٌلٌنمَ نّ،
\q1 عَ ﭑ تَن نَن عَلَتَلَ رَ، وٌ رَكِسِمَ، وٌ شُنسَرَ مَ، يَشُبَ شَ سّنبّمَ.»
\c 50
\s1 يُنُبِ سَرٍ
\q1 
\v 1 عَلَتَلَ شَ مَسٍنيِ نَن يَ؛
\q1 «ﭑ كّيدِ مُندُن سّبّشِ ﭑ شَ مّي وٌ نفَ رَ؟
\q1 ﭑ سَرٍ مُندُن سْتْشِ وٌ مَتِقٍ رَ؟
\q1 وٌ مَتِشِ وٌ يّتّ شَ يُنُبِيٍ نَن مَ قٍ رَ.
\q1 ﭑ مّيشِ وٌ نفَ رَ عَ شَ مَتَندِ نَن مَ.
\q1 
\v 2 مُنقٍ رَ وٌ مُ ﭑ يَابِمَ؟
\q1 مُنقٍ رَ وٌ مُ تِمَ ﭑ يَ رَ؟
\q1 وٌ عَ مَحْشُنشِ نّ ﭑ بّلّشّ مُ قَتَ وٌ قُلُندٍ؟
\q1 وٌ عَ مَحْشُنشِ نّ ﭑ سّنبّ مُ نْمَ وٌ رَكِسِدٍ؟
\q1 ﭑ مَ وْيّن كٍرٍن نْمَ بَا شَرَدٍ.
\q1 ﭑ نْمَ شُرٍ قِندِدٍ فبٍنفبٍرٍنيِ رَ، يّشّيٍ شَ قَشَ، عٍ شَ بْرْ.
\q1 
\v 3 ﭑ قَتَ كٌورٍ رَقْورْدٍ،
\q1 عَلْ مِشِ نَ كَاحّ دُفِ رَفٌرٌشِ عَ مَ.»
\b
\q1 
\v 4 ﭑ مَرِفِ عَلَتَلَ بَرَ مَسٍنيِ سٌ ﭑ يِ رَ
\q1 نَشَن نْمَ مِشِ تَفَنشِ مَلِدٍ.
\q1 عَ ﭑ نَ نَشُنُمَ فّيسّفّ بِرِن، عَ ﭑ تُلِ عِبَمَ،
\q1 عَلَكٌ ﭑ شَ ﭑ تُلِ مَتِ عَ رَ عَلْ شَرَندِ قَنيِ.
\q1 
\v 5 ﭑ مَرِفِ عَلَتَلَ بَرَ ﭑ تُلِ رَبِ،
\q1 ﭑ تَن مُ تٌندِ مَ بِرَدٍ عَ قْشْ رَ.
\q1 
\v 6 ﭑ نَن ﭑ قَرِ تِمَ نّ ﭑ يَشُييٍ شَ ﭑ بْنبْ.
\q1 ﭑ نَ ﭑ شّرّ قَن تِمَ نّ عٍ شَ ﭑ دّ شَبٍ مَتَلَ.
\q1 ﭑ مُ ﭑ يَ تَفِ نْشُن عٍ شَ كٌنبِيٍ مَ،
\q1 ﭑ مُ تٌندِ عٍ شَ عٍ دّ يٍ بْشُن ﭑ مَ.
\b
\q1 
\v 7 ﭑ مَرِفِ عَلَتَلَ تٌ ﭑ مَلِ،
\q1 ﭑ مُ يَافِ، ﭑ مُ ﭑ فِ.
\q1 ﭑ لُمَ نّ عَلْ قَنيٍ، بَرِ مَ ﭑ عَ كٌلٌن ﭑ مُ لُمَ يَافِ كُي.
\q1 
\v 8 نَشَن ﭑ فبٍ حْشْمَ عَ نَ ﭑ سّيتِ مَ.
\q1 ندٍ وَ مَ ﭑ سْنشْقٍ؟ وٌن شَ وْيّن.
\q1 ندٍ وَ مَ ﭑ كَلَمُقٍ؟ كِيتِ شَ سَ.
\q1 
\v 9 ﭑ مَرِفِ عَلَتَلَ نَن ﭑ مَلِقٍ.
\q1 ندٍ نْمَ عَ رَ؟
\q1 عٍ شَ كَلَمُي كَنَمَ نّ عَلْ دُفِ قٌرِ تٍيسٍ نَشَن دٌنمَ.
\b
\q1 
\v 10 ندٍ فَاشُمَ عَلَتَلَ يَ رَ وٌ يَ مَ،
\q1 عَ عَلَ شَ كٌنيِ شُي سُشُ؟
\q1 نَشَن بِرِن نَ حّرّقٍ دِ مِ شْورَ نَءِيَلَنيِ شَنبِ،
\q1 عَ شَ عَ شَشِلِ تِ عَلَتَلَ شِلِ رَ، عَ لَ عَ رَ.
\q1 
\v 11 ﭑ شَ عَ قَلَ وٌ بّ،
\q1 وٌ تَن نَشٍيٍ تّ رَدّشّمَ،
\q1 وٌ قَ تَنبّ رَشَحّنمَ فٍرٍ شِلِ مَ،
\q1 ﭑ قَمَ نّ وٌ تْورْدٍ عَ شْرْشْي رَ.
\c 51
\s1 عِسِرَيِلَ قَتَنشِ دّننَشّ رَ
\q1 
\v 1 «وٌ وٌ تُلِ مَتِ ﭑ نَ، وٌ تَن نَشٍيٍ تِنشِنيِ نُن عَلَتَلَ قٍنقٍ.
\q1 وٌ شَ وٌ يَ تِ قَنيٍ رَ عَلَتَلَ وٌ رَ مِنِشِ دّننَشّ.
\q1 
\v 2 وٌ شَ وٌ يَ تِ وٌ بَبَ عِبُرَهِمَ نُن وٌ نفَ سَرَ رَ نَشٍيٍ وٌ بَرِشِ.
\q1 ﭑ تٌ عَ شِلِ عَ كٍرٍن نَن نُ عَ رَ،
\q1 كْنْ ﭑ تٌ فّ دُبَدٍ عَ بّ،
\q1 عَ قِندِ نّ بْنسْي وُيَشِ بٍنبَ رَ.
\q1 
\v 3 عَلَتَلَ سِيٌن مَدُندُ مَ نّ،
\q1 عَ كِنِكِنِ عَ شَ كَسَرّ بِرِن مَ.
\q1 عَلَتَلَ عَ شَ فبٍنفبٍرٍنيِ قِندِ مَ نّ يِرٍ قَنيِ رَ عَلْ عٍدٍن بْشِ،
\q1 عَ عَ شَ بْشِ رَتٌقَنمَ نّ عَلْ عَ دَرِشِ عَ رَ كِ نَشّ.
\q1 سّيوّ نُن حّلّشِنيِ لُ نَا،
\q1 سُوكِ نُن بّيتِ بَ تّمُي بِرِن.»
\b
\q1 
\v 4 «ﭑ مَ حَمَ، وٌ وٌ تُلِ مَتِ ﭑ نَ.
\q1 ﭑ مَ سِ، وٌ شَ ﭑ شُي رَ مّ.
\q1 سّرِيّ قَتَنشِ ﭑ تَن نَن نَ،
\q1 ﭑ مَ كِيتِ تِنشِنشِ قِندِ مَ نّ نَءِيَلَنيِ رَ سِيٍ بّ.
\q1 
\v 5 ﭑ مَ كِيتِ تِنشِنشِ بَرَ مَكْرّ،
\q1 ﭑ مَ كِسِ نَ قَقٍ،
\q1 سِيٍ قَمَ نّ عٍ شَشِلِ تِدٍ ﭑ سّنبّ رَ.
\q1 
\v 6 وٌ وٌ يَ رَتٍ كٌورٍ مَ.
\q1 مّننِ لْيمَ نّ عَلْ قٌيٍ تُورِ رَلْيمَ كِ نَشّ.
\q1 وٌ وٌ يَ تِ بْشِ رَ.
\q1 مّننِ حْنمَ نّ عَلْ دُفِ قٌرِ.
\q1 مّننِكَيٍ قَشَمَ نّ عَلْ تُفِتُفِ.
\q1 كْنْ ﭑ مَ كِسِ تَن عَبَدَن نَن عَ رَ،
\q1 ﭑ مَ تِنشِنيِ مُ كَنَمَ.»
\b
\q1 
\v 7 «وٌ شَ وٌ تُلِ مَتِ ﭑ شُي رَ، وٌ نَشَن كٌلٌن تِنشِنيِ رَ.
\q1 ﭑ مَ سّرِيّ سَبَتِشِ وٌ بْحّ كُي.
\q1 وٌ نَشَ فَاشُ مِشِيٍ شَ مَبٍرٍ يَ رَ،
\q1 وٌ نَشَ وٌ فِ عٍ شَ سْنشْي يَ رَ.
\q1 
\v 8 نِمَسٍ شُنشُرِيٍ عٍ دٌنمَ نّ عَلْ دُفِ،
\q1 تٍيسٍ عٍ رَحْن عَلْ فّسّ قُتٍ.
\q1 كْنْ ﭑ مَ تِنشِنيِ بُمَ نّ عَبَدَن،
\q1 ﭑ مَ كِسِ لُمَ نّ بْنسْي يَ مَ تّمُي بِرِن.»
\b
\q1 
\v 9 عَلَتَلَ، عِ شَ كٍلِ سّنبّ رَ.
\q1 عِ شَ كٍلِ عَلْ سِنفٍ رَ.
\q1 عِ تَن شَ مُ مِسِرَكَيٍ بْنبْ عَلْ وُلَءِ سُبٍ مَفَاشُشِ؟
\q1 
\v 10 عِ تَن شَ مُ بَا شُنفبٍ رَشْرِ،
\q1 عِ قَ كِرَ عِبْو بَا تَفِ عِ شَ مِشِ رَكِسِشِيٍ دَنفِمَ دّننَشّ؟
\q1 
\v 11 عَلَتَلَ شَ مِشِ شْرّيَشِيٍ فبِلٍنمَ نّ،
\q1 عٍ قَ سٌ سِيٌن كُي بّيتِ رَ،
\q1 سّيوّ نَن لُمَ عٍ بّ عَبَدَن.
\q1 عٍ بْحّ رَقَنشِ عٍ مَ، حّلّشِنيِ لُمَ نّ عٍ سٌندٌنيِ كُي.
\q1 نِمِسّ نُن يَيٍ مَكُيَمَ نّ عٍ رَ.
\b
\q1 
\v 12 «ﭑ تَن نَن وٌ بْحّ مَدُندُ مَ.
\q1 ندٍ نْمَ فَاشُدٍ عَدَ مَدِ يَ رَ،
\q1 نَشَن قَشَمَ، نَشَن حْنمَ عَلْ سّشّ؟
\q1 
\v 13 مُنقٍ رَ وٌ قَ نّيمُشِ وٌ دَالِمَ عَلَتَلَ مَ،
\q1 نَشَن كٌورٍ عِتَلَشِ، عَ بْشِ بُنيِ سَ؟
\q1 مُنقٍ رَ وٌ لُمَ فَاشُي كُي تّمُي بِرِن وٌ يَشُييٍ يَ رَ نَشٍيٍ وَ مَ وٌ تْورْقٍ؟
\q1 وٌ فَاشُمَ عٍ يَ رَ مُنقٍ رَ؟
\q1 
\v 14 عَ فبٍ مُ لُشِ، وٌ شَ فٍيلِمَنِيٍ قَمَ نّ شْرّيَ سْتْدٍ،
\q1 عٍ مُ قَشَمَ فٍيلِ كُي، عٍ مُ قَشَمَ كَامّ رَ.
\q1 
\v 15 ﭑ تَن نَن نَ وٌ مَرِفِ عَلَتَلَ رَ،
\q1 نَشَن بَا عِمَشَمَ، عَ مْرْنيِيٍ رَ مِنِ.
\q1 ﭑ شِلِ نّ عَلَتَلَ سّنبّمَ.
\q1 
\v 16 ﭑ نَن ﭑ مَ مَسٍنيِ سَشِ نّ عِ دّ عِ،
\q1 ﭑ نَ ﭑ بّلّشّ تِ عِ شُن مَ،
\q1 ﭑ تَن نَشَن كٌورٍ عِتَلَ، ﭑ بْشِ بُنيِ سَ،
\q1 نَشَن سِيٌنكَيٍ شِلِمَ، ‹ﭑ مَ حَمَ.›»
\b
\q1 
\v 17 «دَرِ سَلَمُكَيٍ، وٌ كٍلِ كٍرٍن نَ،
\q1 وٌ تَن نَشٍيٍ عَلَتَلَ شَ مِنسٍ شْرْشْي مِنشِ،
\q1 وٌ تَن نَشٍيٍ عَ شَ شْنّ كٌلٌنشِ،
\q1 عَ تٌ دِن وٌ رَ، عَ قَ عَ لُ وٌ شَ بِرَ عَلْ سِيسِلَيٍ.
\q1 
\v 18 عَ شَ دِ يٌ مُ نُ نَ نَشَن عَ مَلِمَ عَ شَ حّرّ كُي،
\q1 نَشَن لُ عَ سّيتِ مَ عَ سُشُقٍ رَ.
\q1 
\v 19 نَ فبَلٌي شْرْشْي بَرَ وٌ سْتْ،
\q1 كَسَرّ نُن سْنتْي، كَامّ نُن فٍرٍ،
\q1 ندٍ نْمَ وٌ مَدُندُدٍ؟
\q1 
\v 20 وٌ شَ دِيٍ بَرَ بِرَ، عٍ سَشِ كِرَ شُنيِ رَ،
\q1 عَلْ شٍلِ نَشَن سُشُشِ يّلّ رَ.
\q1 عَلَتَلَ شَ شْنّ بَرَ دِن عٍ رَ، عَ بَرَ عٍ حَشَنكَتَ عَ حَاشِ رَ.»
\b
\q1 
\v 21 نَ كُي وٌ تَن تْورْ مِشِيٍ، وٌ شَ وٌ تُلِ مَتِ يِ مَسٍنيِ رَ
\q1 وٌ تَن نَشٍيٍ لُشِ عَلْ سِيسِلَيٍ بٍيرٍ شَنبِ.
\q1 
\v 22 وٌ مَرِفِ عَلَتَلَ نَشَن عَ شَ حَمَ مَكَنتَمَ،
\q1 عَ شَ مَسٍنيِ نَن يَ،
\q1 «عَوَ، ﭑ مُ شْنْشِ وٌ مَ سْنْن،
\q1 نَ شْنّ مُ وٌ لِمَ سْنْن.
\q1 
\v 23 ﭑ مَ شْنّ سِفَمَ وٌ يَشُييٍ نَن مَ نَشٍيٍ بَرَ وٌ تْورْ،
\q1 عٍ قَ عَ قَلَ ‹وٌ وٌ قٍلٍن بْشِ مَ، مُشُ شَ تِ وٌ قَرِ.›
\q1 عٍ بَرَ وٌ تْورْ نَ كِ، عٍ قَ حّرّ وٌ قَرِ عَلْ بْشِ.»
\c 52
\s1 شِبَارُ قَنيِ دَرِ سَلَمُ بّ
\q1 
\v 1 سِيٌنِكَيٍ، وٌ شَ كٍلِ سّنبّ رَ،
\q1 وٌ شَ دُفِ تٌقَنيِ رَفٌرٌ وٌ مَ، وٌ تَن تَا سّنِيّنشِ.
\q1 سُننَتَرٍيٍ نُن سّنِيّنتَرٍيٍ مُ سٌمَ وٌ شْنيِ سْنْن.
\q1 
\v 2 دَرِ سَلَمُكَيٍ، وٌ شَ كٍلِ، وٌ شُبٍ بَ وٌ مَ، وٌ دْشْ كِبَنيِ كُي.
\q1 يْلْنشْنيِ شَ بَ وٌ كْنيِ مَ.
\q1 
\v 3 عَلَتَلَ شَ مَسٍنيِ نَن يَ،
\q1 «عٍ وٌ مَتِشِ نّ قُقَقُ، وٌ شُن مُ سَرَ مَ كْبِرِ رَ.»
\q1 
\v 4 عَلَتَلَ سّنبّمَ شَ مَسٍنيِ نَن يَ،
\q1 «سِنفٍ ﭑ مَ حَمَ نُ نَ مِسِرَ بْشِ نَن مَ كٌنيِيَ كُي.
\q1 نَ دَنفِ شَنبِ، عَسِرِيَكَيٍ نَشَ عٍ حَشَنكَتَ، عٍ عٍ شَنِن.
\q1 
\v 5 يَكْسِ نَ قِندِشِ مُنسٍ رَ ﭑ بّ؟
\q1 عٍ بَرَ ﭑ مَ حَمَ شَنِن قُقَقُ، عٍ قَ يٌ عٍ مَ عٍ شَ يَامَرِ كُي.»
\q1 عَلَتَلَ شَ مَسٍنيِ نَن يَ،
\q1 «تّمُي بِرِن ﭑ شِلِ نَ كَنَقٍ.
\q1 
\v 6 نَ كُي ﭑ بَرَ نَتّ تٌنفٌ عَ ﭑ مَ حَمَ قَمَ نّ ﭑ شِلِ كٌلٌندٍ،
\q1 عٍ قَ عَ كٌلٌن عَ ﭑ تَن نَن يِ مَسٍنيِ تِشِ، عَ ﭑ تَن نَن نَ عٍ سّيتِ مَ.»
\b
\q1 
\v 7 شّيرَ تٌقٍ قَ رَ فٍيَ قَرِ، قٍ قَنيِ نَ عَ رَ.
\q1 عَ قَمَ نّ شِبَارُ قَنيِ رَ نَشَن بْحّسَ قِمَ مِشِ مَ،
\q1 نَشَن قِندِ مَ كِسِ رَ،
\q1 نَشَن عَ مَسٍنمَ سِيٌنِ بّ، «وٌ مَرِفِ عَلَ نَن مَنفّ رَ!»
\q1 
\v 8 وٌ وٌ تُلِ مَتِ وٌ كَنتَمَيٍ رَ،
\q1 عٍ بَرَ عٍ شُي عِتٍ سّيوّ رَ.
\q1 عَلَتَلَ نَ فبِلٍن سِيٌنِ، عٍ قَمَ نّ عَ تٌدٍ عٍ يَيٍ رَ.
\q1 
\v 9 دَرِ سَلَمُكَيٍ، وٌ بِرِن شَ وٌ شُي عِتٍ سّيوّ رَ،
\q1 بَرِ مَ عَلَتَلَ نَ عَ شَ حَمَ مَيٌتٌقٍ،
\q1 عَ نَ دَرِ سَلَمُ شُن سَرَقٍ.
\q1 
\v 10 عَلَتَلَ نَ عَ سّنبّ سّنِيّنشِ مَسٍنقٍ حَمَنّ مَ.
\q1 دُنِحَ بِرِن قَمَ نّ عَلَتَلَ شَ كِسِ تٌدٍ.
\b
\q1 
\v 11 وٌ سِفَ، وٌ سِفَ.
\q1 وٌ نَشَ وٌ مَسٌ سٍ سّنِيّنتَرٍ يٌ رَ.
\q1 وٌ شَ مِنِ نَ كُي سّنِيّنيِ كُي،
\q1 وٌ تَن نَشٍيٍ هْرْ مْلِنفِرَ سٍيٍ شَنِنمَ عَلَتَلَ بّ.
\q1 
\v 12 كْنتْقِلِ نَشَ عَ نِيَ وٌ شَ فبَتَ،
\q1 فَاشُي نَشَ عَ نِيَ وٌ شَ وٌ فِ،
\q1 بَرِ مَ عَلَتَلَ نَن تِشِ وٌ يَ رَ،
\q1 عِسِرَيِلَ مَرِفِ عَلَ نَن تِشِ وٌ شَنبِ رَ.
\b
\q1 
\v 13 «ﭑ مَ كٌنيِ شَ قٍ سْونّيَمَ نّ،
\q1 عَ شَ قٍ تٍ، عَ شُن نَكٍلِ، عَ تِدٍ شُنفبٍ سْتْ.
\q1 
\v 14 عَ شَ قٍ مَفٌرٍ قِندِ مَ تّرّننَ نَن نَ مِشِ فبٍفبٍ بّ،
\q1 عَ لَهَلّ مَقِندِ، عَ مُ لُ عَدَ مَ كِ مَ سْنْن،
\q1 
\v 15 عَ مَن مَنفّيٍ دّ عِشَرَ مَ نّ مَرَ سّنِيّنيِ رَ،
\q1 عَ نَشَن قِمَ بْنسْي فبٍفبٍ مَ.
\q1 عٍ قِندِ مَ نّ سٍيدٍيٍ رَ قٍ ندٍ مَ، عٍ مُ نَشَن سِنفٍ تٌشِ،
\q1 عٍ قَهَامُي سْتْمَ نّ قٍ ندٍ شَ قٍ رَ، عٍ مُ نَشَن سِنفٍ مّشِ.»
\c 53
\s1 عَلَ شَ كٌنيِ قِندِقٍ سّرّشّ رَ
\q1 
\v 1 ندٍ لَشِ وٌن مَ مَسٍنيِ رَ؟
\q1 ندٍ عَلَتَلَ سّنبّ تٌشِ؟
\q1 
\v 2 عَ شَ كٌنيِ لُ نّ عَلْ سَنسِ شُرِ، نَشَن تِشِ بْشِ شَرٍ مَ.
\q1 عَ تٌ كِ مُ نُ رَيَبُ، عَ شَ تٌقَنيِ مُ فبٌ.
\q1 
\v 3 مِشِ رَحَاشُشِ نَن نُ عَ رَ حَمَ مُ تِنشِ نَشَن نَ.
\q1 تْورْ مِشِ نَن نُ عَ رَ، نَشَن دَرِشِ حَشَنكَتّ رَ.
\q1 مِشِيٍ مُ تِنشِ عٍ يَ تِدٍ عَ بّ.
\q1 عٍ نُ يٌ عَ مَ، عٍ مُ تِدٍ يٌ قِشِ عَ مَ.
\b
\q1 
\v 4 عَ بَرَ وٌن مَ تْورّ قِندِ عَ فبٍ رَ،
\q1 عَ بَرَ وٌن مَ كْنتْقِلِ قِندِ عَ فبٍ رَ.
\q1 وٌن تَن بَرَ عَ مَحْشُن عَ عَلَ نَن عَ دَنكَشِ،
\q1 عَ عَ شَ تْورّ قَتَنشِ عَلَ نَن نَ.
\q1 
\v 5 كْنْ عَ سْشْ نّ وٌن مَ يُنُبِيٍ شَ قٍ رَ،
\q1 عَ بُتُشُن وٌن مَ حَاشُحَ شَ قٍ رَ.
\q1 عَ حَشَنكَتّ سْتْ نّ عَلَكٌ وٌن شَ يَلَنيِ سْتْ،
\q1 عَ شَ قِيٍ قِندِشِ كِسِ نَن نَ وٌن بّ.
\q1 
\v 6 وٌن بِرِن نُ لْيشِ نّ عَلْ شُرُ سٍ نَشٍيٍ يٍنسٍنمَ وُلَ عِ،
\q1 كَنكَن نَشَ سِفَ عَ شَ كِرَ شْن مَ.
\q1 كْنْ عَلَتَلَ بَرَ وٌن مَ يُنُبِيٍ كٌتٍ دْشْ عَ شُن.
\b
\q1 
\v 7 تْورّ نُن قٍ شْرْشْي تٌ عَ لِ،
\q1 عَ مُ عَ دّ رَبِ هَلِ كٍرٍن.
\q1 عَ لُ نّ عَلْ يّشّي نَشَن شَنِنقٍ عَ قَشَدٍ.
\q1 عَ عَ سَبَرِ نّ تْورّ كُي،
\q1 عَلْ يّشّي شَبٍ مَشَبَ تّمُي.
\q1 
\v 8 عَ تٌ فّ كِيتِ تِنشِنتَرٍ سْتْدٍ، عَ نَشَ قَشَ.
\q1 ندٍ نْ عَ بَدٍ دُنِحَ مِشِيٍ يِ رَ؟
\q1 عَ حَشَنكَتَشِ ﭑ مَ حَمَ شَ يُنُبِيٍ نَن مَ قٍ رَ.
\q1 
\v 9 عٍ نُ وَ مَ عَ قُرٍ رَفَتَقٍ مِشِ حَاشِيٍ نَن يَ مَ،
\q1 كْنْ عَ رَحْنيِ عَ رَفَتَ مِشِ بَننَشِيٍ نَن يَ مَ،
\q1 بَرِ مَ عَ مُ مِشِ تْورْ، عَ مُ مِشِ مَدَشُ.
\b
\q1 
\v 10 عَلَتَلَ بَرَ نَتّ تٌنفٌ عَ شَ عَ حَشَنكَتَ تْورّ رَ،
\q1 كْنْ سّرّشّ نَ بَ يُنُبِيٍ شَ قٍ رَ،
\q1 عَ قَمَ نّ عَ بْنسْي تٌدٍ، عَ بُ عَبَدَن.
\q1 عَلَتَلَ وَشْنقٍ رَكَمَلِمَ عَ تَن نَن سَابُي رَ.
\q1 
\v 11 عَ نَ فّ عَ شَ وَلِ رَبَدٍ،
\q1 عَ قَمَ نّ سّيوَدٍ.
\b
\q1 «ﭑ مَ كٌنيِ تِنشِنشِ حَمَ قِندِ مَ نّ تِنشِنتْييٍ رَ،
\q1 عَ عٍ شُن سَرَ عٍ شَ يُنُبِيٍ شَ قٍ رَ.
\q1 
\v 12 ﭑ تِدٍ شُنفبٍ سٌمَ نّ عَ يِ رَ،
\q1 عَ شُننَكٍلِ سَرٍ سْتْ سّنبّ رَ،
\q1 عَ تٌ قَشَ مَتَندِلَيٍ يِ رَ،
\q1 عَ نُ بَرَ عَ يّتّ قِ سّرّشّ رَ مِشِ فبٍفبٍ شَ يُنُبِيٍ شَ قٍ رَ.»
\c 54
\s1 سِيٌنِ شَ شُننَكٍلِ
\q1 
\v 1 «دِبَرِتَرٍ، نَشٍيٍ مُ نْمَ دِ بَرِدٍ، وٌ شَ سّيوَ،
\q1 وٌ شَ بّيتِ بَ، وٌ تَن نَشٍيٍ مُ دِ سْتْشِ سِندٍن.
\q1 وٌ قَمَ نّ دِ وُيَشِ سْتْدٍ دَنفِقٍ فِنّ فبّتّيٍ رَ.
\q1 عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ.»
\b
\q1 
\v 2 «وٌ شَ وٌ شْنيِ رَشُنفبٌ،
\q1 وٌ شَ ندٍ سَ وٌ شَ بَنشِيٍ شَ فبٌي شُن،
\q1 وٌ شَ نَ بِرِن يَءِلَن عَ قَنيِ رَ،
\q1 
\v 3 بَرِ مَ وٌ يِرِوَ مَ نّ يِرٍقَنيِ نُن كْولَ مَ وٌ شَ بْشِ كُي.
\q1 وٌ شَ مِشِيٍ حَمَنّ ندٍ مِشِيٍ كٍرِ مَ نّ،
\q1 عٍ قَ سَبَتِ عٍ شَ تَايٍ كُي.
\q1 
\v 4 هَلِ وٌ مُ هَنمّ، وٌ مُ يَافِ يٌ سْتْمَ.
\q1 وٌ نَشَ فَاشُ نَ يَ رَ، وٌ شَ قٍ مُ رَفٌرٌ مَ نّ.
\q1 وٌ قَمَ نّ نّيمُدٍ نَ يَافِ شَ قٍ رَ وٌ نَشَن سْتْ وٌ قٌنِكٍ تّمُي،
\q1 وٌ مُ لُ رَ مَحْشُن نَ وٌ شَ كَاحّ قٍ رَ،
\q1 
\v 5 بَرِ مَ وٌ دَالِ مَنفّ مّينِمَ وٌ مَ
\q1 عَلْ شّمّ مّينِمَ عَ شَ فِنّ مَ كِ نَشّ،
\q1 نَشَن شِلِ قَلَمَ وٌ مَرِفِ عَلَتَلَ سّنبّمَ،
\q1 نَشَن قِندِشِ عِسِرَيِلَ شَ سّنِيّنتْي رَ،
\q1 نَشَن وٌ رَكِسِمَ،
\q1 نَشَن شِلِ عَلَ دُنِحَ كَنيِ.
\q1 
\v 6 عَلَتَلَ قَمَ نّ وٌ رَفبِلٍندٍ عَ مَ،
\q1 عَلْ فِنّ نَشَن نُ بَرَ رَبٌلٌ، عَ قَ لُ تْورّ كُي،
\q1 عَلْ سُنفبُتُنيِ نَشَن شَ مْرِ بَرَ مّي عَ رَ.
\q1 عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ.»
\b
\q1 
\v 7 «عَلَ نَشّ، ‹ﭑ عِ رَبٌلٌ نّ تّمُي دُنكٍ دِ،
\q1 كْنْ ﭑ مَن عِ مَسٌمَ نّ ﭑ نَ ﭑ مَ شَنُنتٍيَ شُنفبٍ كُي.
\q1 
\v 8 ﭑ عِ كٍرِ بْحّتٍ شُنفبٍ نَن كُي تّمُي دُنكٍ دِ،
\q1 كْنْ ﭑ مَن كِنِكِنِمَ نّ عِ مَ مَرَقَنيِ كُي عَبَدَن.›
\q1 ﭑ تَن عَلَتَلَ وٌ كَنتَمَ شَ مَسٍنيِ نَن نَ كِ.»
\b
\q1 
\v 9 «عَ لُمَ نّ ﭑ بّ عَلْ نُهَ شَ تّمُي،
\q1 ﭑ تٌ ﭑ كَلِ عَ بَنبَرَنيِ مُ دُنِحَ كَنَمَ سْنْن.
\q1 ﭑ بَرَ ﭑ كَلِ عَ ﭑ مُ شْنْمَ وٌ مَ، ﭑ مُ وٌ سْنتْمَ سْنْن.
\q1 
\v 10 هَلِ فٍيَيٍ سَ سّرّنقٍ نّ، تٍنتٍنيِيٍ نَشَ فِرَ عَ رَ،
\q1 ﭑ مَ شَنُنتٍيَ مُ نْمَ شُرُندٍ وٌ بّ،
\q1 ﭑ مُ مَ بْحّسَ سَاتّ كَنَمَ ﭑ نَشَن تٌنفٌشِ وٌن بّ.
\q1 عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ نَشَن كِنِكِنِمَ وٌ مَ.»
\b
\q1 
\v 11 «وٌ تَن بْنسْي حَشَنكَتَشِ،
\q1 نَشٍيٍ بَرَ تْورْ كِنِكِنِتَرٍحَ كُي،
\q1 ﭑ مَن وٌ شَ تَا تِمَ نّ فّمّ قَنيِ قَرِ،
\q1 ﭑ وٌ رَشُنمَ دِيَمَن نَ،
\q1 
\v 12 ﭑ وٌ شَ يِرٍ عِتٍشِ يَءِلَنمَ فّمّ تٌقَنيِيٍ نَن نَ،
\q1 ﭑ وٌ شَ نَادّيٍ رَشُنمَ فّمّ رَيَبُشِيٍ رَ،
\q1 ﭑ وٌ شَ تّتّ تِ فّمّ يَنبَشِيٍ رَ.
\q1 
\v 13 وٌ شَ دِيٍ بِرِن بِرَ مَ نّ عَلَتَلَ قْشْ رَ،
\q1 عٍ شَ قٍ بِرِن سْونّيَ.
\q1 
\v 14 ﭑ تٌ وٌ فبٍ حْشْمَ، وٌ مَن قَمَ نّ تِدٍ سّنبّ رَ.
\q1 وٌ يَشُييٍ مُ وٌ تْورْ مَ سْنْن،
\q1 وٌ مُ لُمَ فَاشُي كُي.
\q1 وٌ مُ فَاشُمَ قٍقٍ يَ رَ سْنْن.
\q1 
\v 15 شَ فٍرٍ سَ بُلَ وٌ شِلِ مَ،
\q1 نَ مُ كٍلِشِ ﭑ تَن شَ مَ.
\q1 ﭑ شَ عَ قَلَ وٌ بّ، وٌ فٍرٍقَيٍ شَ قٍ كَنَمَ نّ.
\q1 
\v 16 ﭑ تَن نَن شَبُي دَا،
\q1 نَشَن وُرٍ رَشُنُمَ تّ رَ، عَ قَ فٍرٍ سٌسٍ يَءِلَن.
\q1 نَ كُي ﭑ مَن قَ سْورِ دَا، نَشَن عَ يَشُييٍ شَ قٍ كَنَمَ.
\q1 
\v 17 كْنْ فٍرٍ سٌسٍ نَشَن بِرِن يَءِلَنشِ وٌ تَن شِلِ مَ،
\q1 ﭑ عَ نِيَمَ نّ عٍ مُ وٌ لِ قٍقٍ مَ.
\q1 نَشَن يٌ وٌ تْوحّفّ، كِيتِ نَن كَنَمَ نَ كَنيِ رَ.
\q1 عَلَتَلَ عَ شَ كٌنيِيٍ فبٍ حْشْمَ نّ.
\q1 عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ.»
\c 55
\s1 عَلَ شَ كِسِ عِبُنَدَ مَ بّ
\q1 
\v 1 «يٍ شْلِ نَ وٌ تَن نَشٍيٍ مَ،
\q1 وٌ قَ يٍ يِرٍ، وٌ شَ قَ يٍ مِن.
\q1 هَلِ كْبِرِ مُ نَ وٌ يِ رَ،
\q1 وٌ قَ، وٌ شَ قَ دٌنسٍ سْتْ، وٌ شَ وٌ دّفٍ.
\q1 وٌ قَ، وٌ شَ وّنِ نُن شِحّ مِن هَلِ وٌ مُ عَ سَرٍ قِ.
\q1 
\v 2 مُنقٍ رَ وٌ كْبِرِ بَمَ سٍيٍ شَ قٍ رَ نَشٍيٍ مُ قِندِ بَلٌي رَ؟
\q1 مُنقٍ رَ وٌ وَلِ رَبَمَ نَشَن تِدٍ مُ نَ وٌ بّ؟
\q1 وٌ وٌ تُلِ مَتِ ﭑ نَ،
\q1 وٌ شَ وٌ بَلٌ قٍ قَنيِ رَ
\q1 نَشَن سّيوّ قِمَ وٌ مَ.
\q1 
\v 3 وٌ وٌ تُلِ مَتِ ﭑ نَ،
\q1 وٌ شَ قَ ﭑ يِرٍ عَلَكٌ وٌ شَ بَلٌي سْتْ.
\q1 نَ كُي ﭑ قَمَ شَنُنتٍيَ سَاتّ شِرِدٍ وٌن تَفِ نَشَن مُ كَنَمَ.
\q1 نَ لُمَ نّ عَلْ ﭑ سَاتّ نَشَن شِرِ عَننَبِ دَوُدَ نُن ﭑ تَن تَفِ عَ سّرِيّ كِ مَ،
\q1 
\v 4 ﭑ نَشَن تِشِ سٍيدٍ رَ سِيٍ بّ،
\q1 عَ قِندِ مَنفّ شُنفبٍ رَ عٍ بّ.
\q1 
\v 5 وٌ قَمَ نّ سِيٍ شِلِدٍ وٌ مُ نَشٍيٍ كٌلٌن،
\q1 سِيٍ قَمَ نّ وٌ يِرٍ نَشٍيٍ مُ نُ وٌ كٌلٌن،
\q1 بَرِ مَ وٌ مَرِفِ عَلَتَلَ، عِسِرَيِلَ شَ سّنِيّنتْي قَمَ نّ بِنيّ قِدٍ وٌ مَ.
\q1 
\v 6 وٌ شَ فبِلٍن عَلَتَلَ مَ، عَ تٌ نْمَ تٌدٍ.
\q1 وٌ شَ عَ شِلِ، عَ تٌ نَ يِرٍ مَكْرّشِ.
\q1 
\v 7 مِشِ حَاشِ شَ فبِلٍن عَ شَ كِرَ كٌبِ قْشْ رَ،
\q1 يُنُبِتْي شَ عَ شَ نَتّ لُ نَا.
\q1 عَ شَ فبِلٍن وٌن مَرِفِ عَلَتَلَ مَ،
\q1 عَلَكٌ عَ شَ كِنِكِنِ عَ مَ،
\q1 عَ شَ عَ شَ يُنُبِيٍ شَقَرِ.
\q1 
\v 8 ﭑ مَ مَحْشُنيِيٍ نُن وٌ تَن شَ مَحْشُنيِيٍ، عٍ كٍرٍن مُ عَ رَ.
\q1 ﭑ مَ كِرَيٍ نُن وٌ شَ كِرَيٍ قَن، عٍ كٍرٍن مُ عَ رَ.
\q1 عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ.»
\b
\q1 
\v 9 «كٌورٍ مَكُيَشِ بْشِ رَ كِ نَشّ،
\q1 ﭑ مَ كِرَ مَكُيَشِ وٌ فبٍيٍ رَ نَ كِ نّ.
\q1 ﭑ مَ مَحْشُنيِيٍ مَكُيَ وٌ فبٍيٍ رَ ثٌن.
\q1 
\v 10 تُنّ نَ فٌرٌ بْشِ مَ،
\q1 عَ مُ فبِلٍنمَ قٌ عَ بْشِ بُندَ، عَ سَنسِيٍ رَقَن، نَشٍيٍ عَدَ مَدِيٍ بِرِن نَبَلٌمَ.
\q1 
\v 11 ﭑ مَ مَسٍنيِ قَن نَ نَ كِ نّ نَشَن مِنِمَ ﭑ دّ عِ.
\q1 عَ مُ فبِلٍنمَ ﭑ مَ قٌ عَ ﭑ سَفٌي رَكَمَلِ،
\q1 عَ ﭑ وَشْنقٍ رَبَ، ﭑ عَ شّيشِ نَشَن مَ.
\q1 
\v 12 وٌ مِنِمَ سّيوّ نُن بْحّسَ نَن كُي،
\q1 فٍيَيٍ يَتِ حّلّشِنيِ سِفِ سَمَ نّ وٌ يَ رَ،
\q1 دَاشَ سَنسِيٍ عٍ بّلّشّ بْنبْمَ نّ وٌ بّ.
\q1 
\v 13 سِثِرّ وُرِ بُلَمَ نّ تُنبٍ سَنسِ نُ نَ دّننَشّ،
\q1 وُرِ فبّتّيٍ بُلَمَ نّ حٌوفٍ حَاشِ نُ نَ دّننَشّ.
\q1 نَ بِرِن قِندِ مَ تْنشُمَ نَن نَ عَلَتَلَ شَ قٍ رَ،
\q1 تْنشُمَ نَشَن مُ كَنَمَ عَبَدَن.»
\c 56
\s1 بْنسْي فبّتّيٍ كِسِ سْتْقٍ
\q1 
\v 1 عَلَتَلَ شَ مَسٍنيِ نَن يَ؛
\q1 «وٌ بِرَ نْندِ نُن تِنشِنيِ قْشْ رَ،
\q1 بَرِ مَ ﭑ مَ كِسِ نَ قَقٍ،
\q1 عَ فبٍ مُ لُشِ ﭑ مَ تِنشِنيِ شَ تٌ.
\q1 
\v 2 بَرَكَ نَ مِشِ بّ نَشَن وَلِمَ نَ كِ،
\q1 نَشَن نَ سّرِيّ سُشُمَ عَ قَنيِ رَ،
\q1 نَشَن عَ حْشْ سَمَ مَلَبُ لْشْي شَ قٍ شْن مَ،
\q1 عَ مُ عَ مَبٍرٍ، عَ مُ عَ بّلّشّ تِ وَلِ حَاشِ مَ.»
\b
\q1 
\v 3 «شْحّ نَشَن عَ شَشِلِ تِ عَلَتَلَ رَ،
\q1 نَ نَشَ عَ قَلَ،
\q1 ‹عَلَتَلَ ﭑ بَمَ نّ عَ شَ حَمَ يَ مَ ﭑ مَ شْحّيَ شَ قٍ رَ.›
\q1 مِشِ بَنَشِ نَشَ عَ قَلَ،
\q1 ‹ﭑ لُشِ نّ عَلَ بّ عَلْ وُرِ شَرَشِ نَشَن تِدٍ مُ فبٌ.›»
\q1 
\v 4 عَلَتَلَ شَ مَسٍنيِ نَن يَ؛
\q1 «مِشِ بَنَشِ نَشٍيٍ عٍ حْشْ سَمَ مَلَبُي لْشْي شَ قٍ شْن مَ،
\q1 نَشٍيٍ ﭑ وَشْنقٍ رَبَمَ،
\q1 نَشٍيٍ ﭑ مَ سَاتّ مَبَنبَنمَ،
\q1 
\v 5 ﭑ تْنشُمَ ندٍ تِمَ نّ نٍيٍ بّ ﭑ مَ بَنشِ كُي،
\q1 نَشَن تِدٍ دَنفِ دِ بَرِقٍ رَ.
\q1 ﭑ عٍ شِلِ شُنفبٌمَ نّ عَبَدَن،
\q1 نَ بِنيّ مُ بَمَ عٍ مَ قٍقٍ مَ.
\q1 
\v 6 شْحّ نَشٍيٍ عٍ شَشِلِ تِمَ عَلَتَلَ رَ،
\q1 عٍ بِرَ عَ شِلِ قْشْ رَ شَنُنتٍيَ كُي،
\q1 عٍ عَ بَتُ،
\q1 عٍ عٍ حْشْ سَ عَ شَ مَلَبُي لْشْي شَ قٍ شْن مَ،
\q1 عٍ مُ عَ مَبٍرٍ،
\q1 نَشٍيٍ ﭑ مَ سَاتّ مَبَنبَنمَ،
\q1 
\v 7 ﭑ عٍ شَنِنمَ نّ ﭑ مَ فٍيَ سّنِيّنشِ مَ،
\q1 عٍ شَ سّيوَ ﭑ مَ بَنشِ كُي مِشِ ﭑ مَشَندِ مَ دّننَشّ.
\q1 ﭑ عٍ شَ سّرّشّ فَن دَاشِ نُن عٍ شَ سّرّشّ فبّتّيٍ سُشُمَ نّ ﭑ مَ سّرّشّبَدٍ قَرِ،
\q1 بَرِ مَ ﭑ مَ بَنشِ شِلِ قَلَمَ نّ ‹سَلِدٍ بَنشِ سِ بِرِن بّ.›
\q1 
\v 8 عَلَتَلَ شَ مَسٍنيِ نَن يَ، عَلَ نَشَن عِسِرَيِلَ دِ رَيٍنسٍنشِيٍ مَلَنمَ،
\q1 عَ نَشّ، ‹ﭑ مَن عٍ مَلَنمَ نّ ﭑ يِرٍ.›»
\b
\q1 
\v 9 وٌ تَن سُبٍ نَشٍيٍ نَ بُرُنيِ،
\q1 وٌ قَ وٌ دّ مَدٌن.
\q1 
\v 10 عٍ كَنتَمَيٍ لُشِ نّ عَلْ دْنشُييٍ،
\q1 عٍ مُ فّشِ قَهَامُي سْتْدٍ.
\q1 عٍ لُشِ نّ عَلْ بَرٍ نَشٍيٍ مُ نْمَ وٌنوٌندٍ،
\q1 عٍ سَشِ تّمُي بِرِن، شِ شْلِ نَن تُن حْشُن عٍ بّ.
\q1 
\v 11 عٍ لُشِ نّ عَلْ بَرٍ نَشٍيٍ مُ لُفَمَ عٍ شَ دٌنسٍ رَ.
\q1 عٍ لُشِ نّ عَلْ شُرُ سٍ كَنتّيٍ نَشٍيٍ مُ فّشِ قَهَامُي سْتْدٍ،
\q1 كَنكَن بِرَشِ عَ يّتّ شَ كِرَ نَن قْشْ رَ فٍينِ شَ قٍ رَ.
\q1 
\v 12 عٍ عَ قَلَمَ عٍ بٌورٍيٍ بّ،
\q1 «وٌ قَ، وٌن شَ بٍيرٍ قٍن، وٌن شَ سِسِ.
\q1 تِنَ قَن وٌن شَ فبِلٍن نَ رَبَ رَ.
\q1 تّمُندٍ تِنَ قَمَ نّ قِسَدٍ تٌ بّ.»
\c 57
\s1 بْحّسَ كَنيِ
\q1 
\v 1 تِنشِنتْي نَ سَيَ كِرَ شْن مَ،
\q1 كْنْ مِشِ يٌ مُ عَ حْشْ سَ نَ هِننّتْي شَ قٍ شْن مَ.
\q1 مِشِيٍ مُ عَ كٌلٌن عَ عَلَ نَن تِنشِنتْييٍ بَمَ تْورّ كُي.
\q1 
\v 2 نَشَن لُمَ تِنشِنيِ شَ كِرَ شْن مَ،
\q1 عَ مَلَبُي قَنيِ سْتْمَ نّ يَرٍ.
\b
\q1 
\v 3 «كْنْ وٌ تَن سٍمَتٌي بْنسْي،
\q1 نَشٍيٍ قَتَنشِ يّنّ نُن لَنفٌيحَ رَ، وٌ قَ بٍ.
\q1 
\v 4 وٌ ندٍ مَيٍلٍقٍ؟ وٌ ندٍ مَبٍرٍقٍ وٌ دّ رَ؟
\q1 مَتَندِلَيٍ نَن وٌ رَ نَشٍيٍ قَتَنشِ وُلٍ قَلّيٍ رَ.
\q1 
\v 5 وٌ يّنّ رَبَمَ وُرِيٍ بُن مَ مِشِ كُيٍيٍ بَتُمَ دّننَشّ.
\q1 وٌ دِيٍ قَشَمَ سّرّشّ رَ قٌلٍ كُي نَ كُيٍيٍ بّ.
\q1 
\v 6 نَ كُيٍيٍ قِندِشِ وٌ شَ عَلَيٍ نَن نَ وٌ بِرَ مَ نَشٍيٍ قْشْ رَ.
\q1 وٌ مِنسٍ سّرّشّ بَمَ عٍ بّ، وٌ سَنسِ شْرِ قِمَ عٍ مَ.
\q1 عَ مُ لَنمَ ﭑ شَ ﭑ فبٍ حْشْ نَ قٍ مَ؟»
\b
\q1 
\v 7 «وٌ بَرَ سَدٍ يَءِلَن فٍيَ قَرِ وٌ سّرّشّيٍ بَمَ دّننَشّ.
\q1 
\v 8 وٌ وٌ شَ كُيٍ تْنشُمَيٍ تِمَ وٌ شَ نَادّ سّيتِ مَ.
\q1 وٌ بَرَ فبِلٍن ﭑ تَن قْشْ رَ، وٌ قَ كُيٍيٍ شِلِ عٍ شَ سَ وٌ قّ مَ سَدٍ مَ.
\q1 وٌ تٌ فّ سَاتّ شِرِدٍ وٌ بٌرٍ تَفِ، وٌ نَشَ سَدٍ قٍ رَبَ.
\q1 
\v 9 وٌ بَرَ تُرٍ نُن لَبُندّ شَنِن وٌ شَ مَنفّ شْن،
\q1 وٌ بَرَ شّيرَيٍ شّي هَن عَلِفِيَمَ.
\q1 
\v 10 نَ بِرِن قِندِشِ تَفَنيِ نَن نَ وٌ بّ،
\q1 كْنْ وٌ مَن تٌندِشِ فبِلٍندٍ نَ قْشْ رَ.
\q1 وٌ وٌ سّنبّ نَن تُن سٌقٍ، لُقٍ رَ نَ كِرَ شْن مَ.»
\b
\q1 
\v 11 «ثٍ، وٌ كْنتْقِلِشِ ندٍ شَ قٍ رَ، نَشَن عَ نِيَمَ وٌ شَ نّيمُ ﭑ مَ؟
\q1 وٌ فَاشُشِ ندٍ يَ رَ، نَشَن عَ نِيَمَ وٌ مُ ﭑ مَ قٍ مَتٌ سْنْن؟
\q1 مُنسٍ عَ نِيَشِ وٌ شَ ﭑ يَنقَ؟
\q1 ﭑ تٌ دُندُشِ عَ شْنكُيٍ رَ، نَ نَن عَ نِيَشِ وٌ مُ فَاشُشِ ﭑ يَ رَ سْنْن؟
\q1 
\v 12 ﭑ وٌ مَكِيتِمَ نّ وٌ شَ وَلِ مَ، وٌ نَشَن شِلِمَ وَلِ قَنيِ.
\q1 نَ مُ قَنمَ وٌ بّ قٍقٍ مَ.
\q1 
\v 13 وٌ شَ وٌ شَ كُيٍيٍ شِلِ.
\q1 وٌن شَ عَ مَتٌ شَ عٍ نْمَ وٌ مَلِدٍ.
\q1 قٌيٍ عٍ شَنِنمَ نّ!
\q1 كْنْ نَشَن يٌ نَ عَ شَشِلِ تِ ﭑ تَن نَ،
\q1 عَ يِ بْشِ سْتْمَ نّ كّ رَ،
\q1 عَ تٍ ﭑ مَ فٍيَ سّنِيّنشِ نَن قَرِ.»
\b
\q1 
\v 14 عَلَتَلَ عَ قَلَمَ نّ،
\q1 «وٌ وَكِلِ، وٌ شَ كِرَ يَءِلَن،
\q1 وٌ شَ سٍ حَاشِ بِرِن بَ ﭑ مَ حَمَ يَ رَ!»
\q1 
\v 15 مَرِفِ عَلَ، نَشَن مَ قٍ مُ كَنَمَ عَبَدَن،
\q1 نَشَن شِلِ سّنِيّن، عَ شَ مَسٍنيِ نَن يَ،
\q1 «ﭑ سَبَتِشِ كٌورٍ نَن نَ سّنِيّنيِ كُي.
\q1 ﭑ مِشِ شِلِمَ نّ ﭑ سّيتِ مَ نَشَن بْحّ تْورْشِ،
\q1 نَشَن بَرَ عَ يّتّ مَفٌرٌ.
\q1 ﭑ وَ مَ عٍ رَلِمَنِيَقٍ،
\q1 ﭑ وَ مَ عٍ شُن نَكٍلِقٍ.
\q1 
\v 16 ﭑ مُ وَ مَ ﭑ مَ شْنّ شَ بُ عٍ قْشْ رَ،
\q1 شَ نَ مُ ﭑ نَ ﭑ شَشِلِ قِشِ مِشِ نَشٍيٍ مَ، نٍيٍ تَفَنمَ نّ.
\q1 
\v 17 عِسِرَيِلَ تٌ مِلَ يُنُبِ رَبَقٍ مَ،
\q1 ﭑ نَشَ عٍ حَشَنكَتَ، ﭑ عٍ رَبٌلٌ،
\q1 كْنْ عٍ شَ مُرُتّ نَن تُن شُن نُ مَسَمَ.
\q1 
\v 18 ﭑ بَرَ عٍ وَلِ كِ يَتِ تٌ،
\q1 كْنْ ﭑ عٍ دَندَنمَ نّ، ﭑ عٍ مَلِ، ﭑ عٍ بْحّ دْشْ،
\q1 
\v 19 عَلَكٌ عٍ مَن شَ بّيتِ بَ ﭑ بّ.
\q1 ﭑ تَن عَلَتَلَ نَشّ،
\q1 ‹بْحّسَ شَ لُ يِرٍ مَكُيٍكَيٍ بّ!
\q1 ﭑ عٍ رَيَلَنمَ نّ.›
\q1 
\v 20 كْنْ مِشِ حَاشِيٍ تَن لُمَ نّ عَلْ بَا مْرْنيِيٍ،
\q1 نَشٍيٍ مُ رَشَرَ، نَشٍيٍ نْشْي تُن نَتٍمَ.
\q1 
\v 21 ﭑ تَن عَلَتَلَ نَشّ،
\q1 ‹بْحّسَ يٌ مُ نَ مِشِ حَاشِيٍ تَن بّ.›»
\c 58
\s1 سُنيِ قَنيِ
\q1 
\v 1 «عِ شَ عِ شُي عِتٍ عَلْ سَرَ قٍ شُي،
\q1 عَ قَلَقٍ رَ ﭑ مَ حَمَ بّ عٍ بَرَ مُرُتَ،
\q1 يَشُبَ بْنسْي بَرَ يُنُبِ سْتْ.
\q1 
\v 2 لْشْ يٌ لْشْ عٍ يَ رَقِندِشِ ﭑ مَ.
\q1 عَ لُشِ نّ عَلْ عٍ وَ مَ ﭑ وَشْنيِ نَن كٌلٌنقٍ،
\q1 عَلْ حَمَ نَشَن وَ مَ تِنشِنيِ شْن،
\q1 نَشَن مُ فبِلٍنشِ عَلَ شَ يَامَرِ قْشْ رَ.
\q1 عٍ ﭑ مَشَندِ مَ كِيتِ تِنشِنشِ سَقٍ رَ،
\q1 عَ لُشِ نّ عَلْ عٍ نَ وَ عَلَ شَ مَكْرّ عٍ رَ.»
\b
\q1 
\v 3 «كْنْ عٍ عَ قَلَمَ، ‹مُنقٍ رَ مُشُ سُنمَ، كْنْ عِ مُ عَ سُشُمَ؟
\q1 مُنقٍ رَ مُشُ مُشُ سُيِدِ مَ عِ بّ، كْنْ عِ مُ عَ تٌمَ؟›
\q1 ﭑ شَ عَ قَلَ وٌ بّ وٌ شَ سُنيِ كُي وٌ وٌ يّتّ وَشْنقٍ نَن تُن نَبَمَ،
\q1 وٌ كٌتٍ شْرْشْي دْشْ وٌ شَ وَلِكّيٍ شُن مَ.
\q1 
\v 4 وٌ سُنشِ تّمُي نَشّ، وٌ وٌ بٌرٍ فٍرٍ مَ،
\q1 وٌ سْنشْي رَتٍمَ، وٌ وٌ بٌرٍ بْنبْ مِشِ كٌبِحَ كُي.
\q1 ﭑ مُ نَ سُنيِ مْولِ سُشُمَ قٍوٌ!
\q1 
\v 5 ﭑ وَ مَ سُنيِ نَشَن شْن، نَ قِندِ مَ مِشِ شَ سُيِدِ نَن تُن نَ؟
\q1 مِشِ عَ تِفِ تِقٍ بْشِ، عَلْ مَالٍ مْشِ قٌيٍ نَشَن رَ مَشَمَ،
\q1 نَ كٍرٍن قِندِ مَ سُنيِ رَ؟
\q1 سُننُنيِ دُفِ رَفٌرٌقٍ مِشِ مَ، شُبٍ تٍقٍ مِشِ شُنيِ رَ،
\q1 نَ شِلِ قَلَمَ سُنيِ قَنيِ نَشَن نَقَن عَلَتَلَ مَ؟»
\b
\q1 
\v 6 «ﭑ وَ مَ سُنيِ مْولِ نَشَن شْن،
\q1 وٌ شَ فبِلٍن تِنشِنتَرٍيَ قْشْ رَ، وٌ شَ كٌتٍ شْرْشْي بَ مِشِ شُن مَ.
\q1 فٍيلِمَنِ شَ شْرّيَ، كٌتٍ شْرْشْي شَ بَ مِشِ شُن مَ.
\q1 
\v 7 وٌ شَ دٌنسٍ قِ كَامّتْي مَ،
\q1 وٌ شَ شِدٍ قِ مِشِ مَ عَ مُ نَشَن يِ،
\q1 وٌ شَ دُفِ رَفٌرٌ مِشِ مَ عَ مُ نَشَن يِ،
\q1 وٌ نَشَ عَ لُ وٌ نفَشَكٍرٍنيِ شَ سِفَ عَ بّلّشّ عِفٍلِ رَ.
\q1 
\v 8 نَ كُي وٌ يَنبَمَ نّ عَلْ سُبَشّ لٌولٌي،
\q1 وٌ يَلَنمَ مَقُرٍن مَقُرٍن،
\q1 وٌ شَ تِنشِنيِ كٌلٌنمَ نّ وٌ يَ رَ،
\q1 عَلَتَلَ شَ نْرّ وٌ كَنتَمَ نّ وٌ شَنبِ رَ.
\q1 
\v 9 نَ تّمُي وٌ عَلَتَلَ مَشَندِ مَ نّ، عَ قَ نَ سُشُ.
\q1 وٌ نَ عَ شِلِ عَ شَ وٌ مَلِ، عَ وٌ شَ شِلِ رَتِنمَ نّ، ‹ﭑ نَ بٍ.›»
\b
\q1 «شَ وٌ مُ مِشِ تْورْ مَ،
\q1 شَ وٌ مُ مِشِ تْوحّفّمَ،
\q1 
\v 10 شَ وٌ كَامّتْي مَلِمَ،
\q1 شَ وٌ تْورْ مِشِ كِمَ،
\q1 نَ كُي وٌ يَنبَمَ نّ دِ مِ كُي، وٌ قَ دِ مِ كَنَ عَلْ سٌفٍ يَنيِ تَفِ.
\q1 
\v 11 عَلَتَلَ وٌ رَحّرّ مَ نّ تّمُي بِرِن،
\q1 عَ وٌ هَيِ قَنمَ نّ وٌ بّ هَلِ تّمُي شْرْشْي كُي.
\q1 عَ سّنبّ قِمَ نّ وٌ مَ،
\q1 وٌ قَ لُ عَلْ لَاكْي يٍ مُ شْرِ مَ نَشَن مَ.
\q1 
\v 12 وٌ شَ حَمَ قَمَ نّ وٌ شَ يِرٍ كَنَشِيٍ تِدٍ عَلْ عَ سِنفٍ.
\q1 عٍ قَمَ نّ وٌ شِلِ قَلَدٍ، ‹تَا بِلِتِيٍ، بَنشِتِيٍ، نُن تَا يَلَنمَيٍ.›»
\b
\q1 
\v 13 «شَ وٌ مَلَبُي لْشْي سّرِيّ رَبَتُ،
\q1 شَ وٌ مُ وٌ وَشْنقٍ رَبَ ﭑ مَ لْشْي سّنِيّنشِ كُي،
\q1 شَ وٌ سّيوَ نَ لْشْي شَ قٍ رَ،
\q1 وٌ عَ بِنيَ وٌ شَ حّرّ كِ قَنيِ رَ،
\q1 وٌ مُ تِن وْيّنيِ قُقَقُ رَ،
\q1 
\v 14 نَ كُي وٌ قَمَ نّ سّيوَدٍ عَلَتَلَ شَ قٍ كُي،
\q1 ﭑ قَ وٌ شَ قٍ عِتٍ وٌ شَ بْشِ قَنيِ مَ،
\q1 وٌ شَ حّلّشِنيِ نَ وٌ بٍنبَ يَشُبَ كّ نَن نَ.»
\b
\q1 عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ.
\c 59
\s1 تِنشِنتَرٍحَ رَحْنيِ
\q1 
\v 1 عَلَتَلَ قَتَ وٌ رَكِسِدٍ،
\q1 عَ قَتَ وٌ شَ دُبَ رَ مّدٍ،
\q1 
\v 2 كْنْ وٌ شَ وَلِ حَاشِ نَن وٌ مَكُيَشِ وٌ مَرِفِ عَلَ رَ،
\q1 وٌ شَ يُنُبِيٍ نَن عَ يَتَفِ نْشُنشِ وٌ مَ.
\q1 نَ نَن عَ رَ، عَ مُ وٌ شَ مَشَندِ سُشُمَ.
\q1 
\v 3 وُلِ نَ وٌ بّلّشّيٍ مَ، يُنُبِ نَ وٌ مَ.
\q1 وٌ وُلٍ قَلَمَ، قٍ حَاشِ نَ وٌ دّ كُي.
\q1 
\v 4 مِشِ يٌ مُ بِرَ مَ كِيتِ تِنشِنشِ قْشْ رَ،
\q1 نْندِ تِدٍ مُ نَ وٌ شَ كِيتِقٍ كُي.
\q1 وٌ بِرَ مَ وْيّنيِ قُقَقُ نَن قْشْ رَ،
\q1 وٌ وُلٍيٍ قَلَمَ نَشٍيٍ تْورّ نُن قٍ حَاشِ رَ مِنِمَ.
\q1 
\v 5 وٌ لُشِ نّ عَلْ بْشِمَسٍ شّلّ.
\q1 نَشَن نَ دٌنمَ، عَ كَنيِ قَشَمَ نّ.
\q1 نَ شَلّ نَ بُلَ، بْشِمَسٍ نَن مِنِمَ.
\q1 وٌ لُشِ نّ عَلْ سَيّلّ.
\q1 
\v 6 عَ فّسّ مُ قِندِ مَ دُفِ رَ.
\q1 عَ نَشَن يَءِلَنمَ نَ مُ نْمَ عَ مَكٌتٌدٍ.
\q1 قٍ حَاشِ نَ عَ رَ، نَشَن مُ تِنشِن قٍوٌ.
\q1 
\v 7 عٍ شُلُن قٍ حَاشِ رَبَدٍ،
\q1 عٍ فبَتَ مِشِ تْوحّفّدٍ، عٍ عَ قَشَ.
\q1 عٍ شَ مَحْشُنيِ كٌبِ، عٍ قٍ شُن نَكَنَمَ نَن تُن.
\q1 
\v 8 عٍ مُ وَ مَ بْحّسَ شْن مَ،
\q1 تِنشِنيِ يٌ مُ نَ عٍ شَ كِرَ شْن مَ.
\q1 عٍ كِرَ مَدَلِنشِيٍ نَن يَءِلَنشِ،
\q1 نَشَن مِشِ شُن تِمَ تِنشِنتَرٍيَ شْن.
\b
\q1 
\v 9 نَ نَن عَ رَ، وٌن مَكُيَشِ تِنشِنيِ رَ،
\q1 عَ مُ نْمَ وٌن لِدٍ.
\q1 وٌن نَءِيَلَنيِ نَن قٍنمَ،
\q1 كْنْ دِ مِ نَن تُن سِنمَ وٌن مَ.
\q1 وٌن كُيٍ عِبَ نَن مَمّقٍ، كْنْ وٌن لُمَ كْي تَن نَن كُي.
\q1 
\v 10 وٌن نَ وٌن سَنتِدٍ قٍنقٍ عَلْ دْنشُي نَشَن حّرّ مَ عَ يِرٍ مَسُشُ مَ.
\q1 وٌن بِرَ مَ يَنيِ رَ، عَلْ وٌن نَ حّرّقٍ دِ مِ نَن كُي.
\q1 وٌن لُشِ نّ عَلْ مِشِ قَشَشِ سّنبّمَيٍ تَفِ.
\q1 
\v 11 وٌن شُرُندُنمَ عَلْ بُرُن سُبٍيٍ،
\q1 وٌن وَ شُي رَ مِنِمَ عَلْ فَنبّ.
\q1 وٌن فبٍ حْشْي نَن قٍنقٍ، كْنْ وٌن مُ عَ سْتْمَ.
\q1 وٌن شَشِلِ تِشِ كِسِ نَن نَ، كْنْ عَ مَكُيَ وٌن نَ.
\b
\q1 
\v 12 مُشُ نَ نَ كِ نّ، بَرِ مَ مُشُ شَ يُنُبِيٍ وُيَ،
\q1 عٍ قِندِشِ سٍيدٍ نَن نَ مُشُ شِلِمَ.
\q1 مُشُ شَ يُنُبِيٍ تٌمَ نّ مُشُ يَ مَ،
\q1 مُشُ بَرَ عٍ كٌلٌن، مُشُ بَرَ مُشُ تِ عٍ رَ.
\q1 
\v 13 مُشُ بَرَ عِ مَتَندِ، مُشُ بَرَ عِ يَنقَ.
\q1 مُشُ بَرَ فبِلٍن مُشُ مَرِفِ عَلَ قْشْ رَ.
\q1 مُشُ بَرَ قٍ شْرْشْي دْشْ مُشُ نفَشَكٍرٍنيِيٍ مَ،
\q1 مُشُ بَرَ وُلٍ قَلَ نَشٍيٍ قَتَنشِ مُشُ بْحّ كُي.
\q1 
\v 14 مُشُ نُن تِنشِنيِ تَفِ عِكُيَ.
\q1 نْندِ مُ تٌمَ وٌن يَ مَ سْنْن.
\q1 يَنقَنتٍيَ فبٌ.
\q1 
\v 15 نْندِ تٌ شْنْ، تِنشِنتْي نَن تُن تْورْ مَ.
\b
\q1 عَلَتَلَ تٌ عَ تٌ، عَ تِنشِنيِ مُ نَ سْنْن، نَ مُ رَقَن عَ مَ.
\q1 
\v 16 عَ عَ تٌشِ نّ مِشِ يٌ مُ نِمِسَشِ،
\q1 عَ عَ دّ رَوَ عَلَتَلَ شْن مَ نَ قٍ مَ.
\q1 نَ كُي عَ بَرَ نَ كِسِ وَلِ سُشُ عَ يّتّ رَ عَ شَ تِنشِنيِ شَ قٍ مَ.
\q1 
\v 17 عَ شَ تِنشِنيِ لُشِ نّ عَلْ كَنكٍ مَكَنتَسٍ،
\q1 عَ شَ كِسِ لُ عَلْ عَ شُنيِ مَكَنتَسٍ.
\q1 فبٍحْشْي لُشِ نّ عَ بّ عَلْ دٌنمَ عَ نَشَن نَفٌرٌ مَ عَ مَ،
\q1 عَ شَ وَكِلِ لُ عَ بّ عَلْ شِنبٍلِ دٌنمَ.
\q1 
\v 18 عَلَ كَنكَن سَرٍ قِمَ نّ عَ شَ وَلِ رَ،
\q1 عَ شْنْ عَ يَشُييٍ مَ يِرٍ مَكُيٍ،
\q1 عَ عٍ سَرٍ قِ.
\q1 
\v 19 عِبُنَدَ مَ فَاشُمَ نّ عَلَتَلَ شِلِ يَ رَ،
\q1 عٍ عَ شَ نْرّ بِنيَ كٍلِقٍ سٌفٍتٍدٍ مَ هَن سٌفٍفٌرٌدٍ،
\q1 بَرِ مَ عَلَتَلَ سّنبّ عٍ لِمَ نّ عَلْ يٍ نَشَن دِكِ بْو مَ عَ رَ.
\b
\q1 
\v 20 «شُنسَرَ مَ نَ قَقٍ سِيٌن،
\q1 يَشُبَ بْنسْي بّ نَشٍيٍ تُوبِمَ عٍ شَ يُنُبِيٍ شَ قٍ رَ.
\q1 عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ.»
\b
\q1 
\v 21 عَلَتَلَ نَشّ، «ﭑ مَ سَاتّ نَن يَ عٍ بّ؛
\q1 ‹ﭑ شَشِلِ نَشَن فٌرٌشِ عِ مَ،
\q1 نَ ﭑ مَ مَسٍنيِ نَشَن سَشِ عِ دّ عِ،
\q1 نٍيٍ مُ كٍلِمَ وٌ شُن مَ،
\q1 نٍيٍ مُ كٍلِمَ وٌ شَ دِيٍ شُن مَ،
\q1 نٍيٍ مُ كٍلِمَ عٍ قَن شَ دِيٍ شُن مَ عَبَدَن.›
\q1 عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ.»
\c 60
\s1 دَرِ سَلَمُ شَ دَرِيّ
\q1 
\v 1 «وٌ كٍلِ، وٌ شَ نَءِيَلَنيِ بَرَ قَ،
\q1 عَلَتَلَ شَ نْرّ بَرَ تِ وٌ مَ.
\q1 
\v 2 دِ مِ بَرَ دُ سُ بْشِ بِرِن شُن نَ،
\q1 كُيٍ بَرَ عِقْورْ نَ حَمَيٍ مَ،
\q1 كْنْ عَلَتَلَ بَرَ تِ وٌ شُن مَ،
\q1 عَ شَ نْرّ بَرَ لُ وٌ يَ مَ.
\q1 
\v 3 حَمَنّيٍ قَمَ نّ وٌ شَ نْرّ مَ،
\q1 مَنفّيٍ بّندُنمَ نّ وٌ شَ لٌولٌي شَ يَنبّ مَ.»
\b
\q1 
\v 4 «وٌ وٌ يَ رَفٍ وٌ رَبِلِنيِ.
\q1 عٍ بِرِن مَلَنشِ وٌ يِرٍ،
\q1 وٌ شَ دِيٍ قَقٍ كٍلِقٍ يِرٍ مَكُيٍ،
\q1 وٌ شَ دِ فِنّيٍ دْشْشِ مِشِيٍ تُنكِ قَرِ.
\q1 
\v 5 وٌ نَ نَ تٌ، وٌ سّيوَ مَ نّ هّرِ رَ،
\q1 وٌ بْحّ حّلّشِن.
\q1 بَننَيَ نَشَن نَ بَا نَاكِرِ مَ عَ قِندِ مَ نّ وٌ فبٍ رَ،
\q1 حَمَنّيٍ شَ بَننَيَ قَ لُ وٌ شْنيِ.
\q1 
\v 6 حْشْمّ فَلِ وُيَمَ نّ وٌ شَ بْشِ مَ،
\q1 قَقٍ رَ كٍلِقٍ مَدِيَن نُن عٍقَ بْشِ مَ.
\q1 نَشٍيٍ قَمَ كٍلِقٍ سٍيبَ،
\q1 عٍ قَمَ شّيمَ نُن سُرَيِ نَن نَ،
\q1 عٍ نُ عَلَتَلَ مَتْشْ.
\q1 
\v 7 كٍدَرِ شَ شُرُ سٍيٍ مَلَنمَ نّ وٌ شْنيِ،
\q1 نٍبَيٌتِ يّشّي كٌنتٌنيِيٍ لُ وٌ سَفٌي،
\q1 ندٍيٍ بَ سّرّشّ فَن دَاشِ رَ ﭑ مَ سّرّشّبَدٍ قَرِ.
\q1 ﭑ مَ هْرْ مْبَنشِ يَنبَمَ نّ ﭑ مَ نْرّ رَ.»
\b
\q1 
\v 8 «لَابَ قِيشّيٍ حّرّ مَ كٌورٍ مَ عَلْ فَنبّ نَشٍيٍ فبِلٍنمَ عٍ شْنيِ.
\q1 
\v 9 حَمَنّيٍ شَشِلِ تِشِ ﭑ نَ،
\q1 تَرَ سِسِ كُنكُييٍ نَ يَرٍ قَقٍ رَ وٌ شَ دِيٍ رَ كٍلِقٍ يِرٍ مَكُيٍ.
\q1 عٍ قَمَ نّ فبٍتِ نُن شّيمَ رَ وٌ مَرِفِ عَلَتَلَ بِنيَقٍ رَ،
\q1 عِسِرَيِلَ شَ سّنِيّنتْي نَشَن بَرَ وٌ شُن نَكٍلِ.»
\b
\q1 
\v 10 «شْحّيٍ يَتِ قَمَ نّ وٌ شَ تّتّ رَكٍلِدٍ،
\q1 حَمَنّيٍ مَنفّيٍ وَلِمَ نّ وٌ بّ.
\q1 هَلِ ﭑ تٌ وٌ حَشَنكَتَ ﭑ مَ شْنّ كُي،
\q1 ﭑ قَمَ نّ هِننّدٍ وٌ رَ ﭑ مَ كِنِكِنِ شَ قٍ رَ.
\q1 
\v 11 هَلِ وٌ مُ وٌ شَ تَا نَادّيٍ بَلَن،
\q1 بَرِ مَ مِشِيٍ قَمَ نّ نَاقُلِ رَ كٍلِقٍ حَمَنّ مَ،
\q1 عٍ شَ مَنفّيٍ تِشِ يَرٍ.
\q1 
\v 12 سِ يٌ نَشَن تٌندِ مَ وَلِدٍ وٌ بّ، عَ شُن نَكَنَمَ نّ.»
\b
\q1 
\v 13 «لِبَن شَ وُرِ قَنيِيٍ شَنِنمَ نّ وٌ شْنيِ،
\q1 عَلَكٌ ﭑ مَ هْرْ مْبَنشِ شَ رَكٍلِ،
\q1 نْرّ شَ لُ ﭑ سَنيِ تِدٍ.
\q1 
\v 14 وٌ فٍرٍقَيٍ شَ دِيٍ قَمَ نّ عٍ يّتّ مَفٌرٌدٍ وٌ بّ،
\q1 وٌ يَشُييٍ عٍ شِنبِ سِن وٌ بُن مَ.
\q1 عٍ قَمَ نّ وٌ شِلِ قَلَدٍ، ‹سِيٌنِ، عِسِرَيِلَ مَرِفِ سّنِيّنشِ عَلَتَلَ شَ تَا.›»
\b
\q1 
\v 15 «هَلِ ﭑ وٌ رَبٌلٌ نّ نُ،
\q1 مِشِ يٌ مُ لُ وٌ شَ بْشِ مَ،
\q1 ﭑ قَمَ نّ وٌ قِندِدٍ سِ شُنفبٍ رَ،
\q1 نَشَن لُمَ شُننَكٍلِ كُي عَبَدَن.
\q1 
\v 16 حَمَنّيٍ شَ مَنفّيٍ شِحّ قِمَ نّ وٌ مَ.
\q1 نَ كُي وٌ عَ كٌلٌنمَ نّ عَ ﭑ تَن نَن نَ عَلَتَلَ رَ،
\q1 وٌ رَكِسِمَ، وٌ شُنسَرَ مَ، يَشُبَ مَرِفِ سّنبّمَ.
\q1 
\v 17 ﭑ شّيمَ قِمَ نّ وٌ مَ وُرٍ فبٍيلِ حْشْي رَ،
\q1 ﭑ فبٍتِ قِ وٌ مَ وُرٍ حْشْي رَ،
\q1 ﭑ وُرٍ فبٍيلِ قِ وٌ مَ وُرِ حْشْي رَ،
\q1 ﭑ وُرٍ قِ وٌ مَ فّمّ حْشْي رَ.
\q1 بْحّسَ نُن تِنشِنيِ نَن قِندِ مَ وٌ شَ مَنفّيٍ رَ.
\q1 
\v 18 قٍ كٌبِ مُ تٌمَ وٌ شَ بْشِ مَ،
\q1 فبَلٌي مُ وٌ شْنيِ لِمَ.
\q1 وٌ شَ تّتّ شِلِ قَلَمَ نّ ‹كِسِ،›
\q1 وٌ شَ تَا نَادّ شِلِ قَلَ ‹مَتْشْي.›
\q1 
\v 19 سٌفٍ شَ مُ يِرٍ عِيَلَنمَ وٌ بّ يَنيِ رَ سْنْن،
\q1 كِكٍ شَ مُ يِرٍ عِيَلَنمَ وٌ بّ كْي رَ سْنْن.
\q1 عَ كٍلِمَ عَلَتَلَ يَتِ نَن مَ،
\q1 عَ عَ شَ نْرّ قِمَ نّ وٌ مَ عَبَدَن.
\q1 
\v 20 سٌفٍ نُن كِكٍ مُ دُلَمَ سْنْن،
\q1 عَلَتَلَ نَن قِندِ مَ وٌ شَ نَءِيَلَنيِ رَ تّمُي بِرِن.
\q1 وٌ شَ سُننُنيِ تّمُي حْنمَ نّ.
\q1 
\v 21 وٌ شَ حَمَ لُمَ تِنشِنيِ نَن كُي،
\q1 وٌ شَ بْشِ لُ وٌ بّ عَبَدَن.
\q1 وٌ لُشِ نّ عَلْ سَنسِ سٌلِيٍ ﭑ نَشٍيٍ سِشِ ﭑ بّلّشّ رَ،
\q1 عَلَكٌ ﭑ شَ ﭑ مَ نْرّ مَسٍن دُنِحَ بّ.
\q1 
\v 22 هَلِ وٌ شُرُن، وٌ سّنبّ لُمَ نّ عَلْ فَلِ بٍلٍبٍلٍ.
\q1 عَلَتَلَ نَن ﭑ نَ.
\q1 ﭑ يِ وَلِ رَبَمَ نّ مَقُرٍن مَقُرٍن.»
\c 61
\s1 عَلَ شَ شّيرَ كِسِشِ
\q1 
\v 1 ﭑ مَرِفِ عَلَتَلَ شَشِلِ نَ ﭑ مَ،
\q1 بَرِ مَ عَ بَرَ ﭑ سُفَندِ شِبَارُ قَنيِ كَوَندِدٍ تْورْ مِشِيٍ بّ،
\q1 ﭑ شَ عٍ بْحّ نِمِسَشِ رَيَلَن.
\q1 عَ بَرَ ﭑ شّي فٍيلِمَنِيٍ شْرّيَدٍ،
\q1 ﭑ شَ مِشِيٍ رَ مِنِ عٍ شَ دِ مِ كُي.
\q1 
\v 2 ﭑ شَ مِشِيٍ رَكٌلٌن عَ عَلَتَلَ شَ هِننّ تّمُي بَرَ قَ،
\q1 عَ عٍ فبٍ حْشْمَ نّ.
\q1 عَ قَمَ نّ عٍ مَدُندُدٍ،
\q1 
\v 3 عَ شَ هِننّ رَ عَ نَشَن قِمَ سِيٌنِكَيٍ مَ، نَشٍيٍ نَ سُننُنيِ كُي.
\q1 عَ دَرِيّ قِمَ نّ عٍ مَ عٍ شَ تْورّ حْشْي رَ،
\q1 عَ عٍ وَ شُي مَدُندُ مَ سّيوّ نَن نَ.
\q1 عٍ شَ نِمِسّ قِندِ مَ مَتْشْي نَن نَ.
\q1 عٍ شِلِ قَلَمَ نّ «كٌندٍ قَنيِ عَلَتَلَ نَشَن سِشِ،»
\q1 عَلَكٌ عَ شَ عَ نْرّ مَسٍن دُنِحَ مَ.
\q1 
\v 4 عٍ عٍ شَ تَا كَنَشِ يَءِلَنمَ نّ،
\q1 عٍ عٍ شَ تّتّ بِرَشِ رَكٍلِ،
\q1 عٍ شَ يِرٍ كَنَشِ قٌرِ قِندِ يِرٍ قَنيِ رَ.
\q1 
\v 5 شْحّيٍ قَمَ نّ وٌ شَ شُرُ سٍيٍ دّ مَدٌندٍ،
\q1 عٍ وٌ شَ شّيٍ رَوَلِمَ نّ.
\q1 
\v 6 وٌ تَن شِلِ قَلَمَ نّ «عَلَتَلَ شَ سّرّشّدُبّ،
\q1 نَشٍيٍ عَلَ شَ وَلِ رَبَمَ.»
\b
\q1 
\v 7 «ﭑ مَ حَمَ شَ يَافِ مَسَرَ مَ هّيرِ فبٍفبٍ نَن نَ،
\q1 عٍ كّ بٍلٍبٍلٍ نَن سْتْمَ عٍ شَ يَافِ حْشْ رَ.
\q1 عٍ يِرٍ بٍلٍبٍلٍ سْتْمَ نّ عٍ شَ بْشِ سِنفٍ تَفِ،
\q1 عٍ قَ سّيوَ عَبَدَن.»
\b
\q1 
\v 8 «تِنشِنيِ نَن نَقَن ﭑ تَن عَلَتَلَ مَ،
\q1 كْنْ قُنمَيَ رَحَاشُ ﭑ مَ كِ قَنيِ.
\q1 ﭑ مِشِ سَرٍ قِمَ ﭑ شُي بّرّ نَن نَ،
\q1 ﭑ مُ ﭑ مَ سَاتّ كَنَمَ عَبَدَن.
\q1 
\v 9 عٍ بْنسْي كٌلٌنمَ نّ سِيٍ تَفِ،
\q1 عٍ بْنسْي لُمَ نّ بْنسْي فبّتّ يَ مَ.
\q1 مِشِ نَشٍيٍ عٍ تٌمَ،
\q1 عٍ عَ كٌلٌن عَلَتَلَ شَ حَمَ بَرَكَشِ نَن عٍ رَ.»
\b
\q1 
\v 10 ﭑ بَرَ سّيوَ عَلَتَلَ رَ كِ قَنيِ،
\q1 ﭑ حّلّشِنشِ ﭑ مَرِفِ عَلَ شَ قٍ رَ،
\q1 بَرِ مَ عَ بَرَ ﭑ نَكِسِ،
\q1 عَ بَرَ ﭑ مَتِنشِن،
\q1 عَلْ فُبَ رَفٌرٌ مَ مِشِ مَ كِ نَشّ.
\q1 عَ لُشِ نّ عَلْ تْنشُمَ نَشَن تِمَ سّرّشّدُبّ شُن مَ،
\q1 عَلْ كْنمَفٌرٍ نَشَن فبَكُمَ كْن مَ.
\q1 
\v 11 عَلَتَلَ تِنشِنيِ نُن مَتْشْي رَ مِنِمَ نّ دُنِحَ يَ مَ،
\q1 عَلْ سَنسِ شْرِيٍ قِندِ مَ سٌلِيٍ رَ كِ نَشّ لَاكْي تَفِ.
\c 62
\s1 سِيٌنِ شَ قُتِ
\q1 
\v 1 «ﭑ مُ دُندُ مَ سِيٌنِ شَ قٍ رَ،
\q1 ﭑ مُ تَفَنمَ دَرِ سَلَمُ شَ قٍ رَ،
\q1 هَن عٍ فبٍ حْشْمَ تّمُي نَشّ،
\q1 هَن عٍ كِسِ سْتْ.
\q1 
\v 2 نَ تّمُي حَمَنّيٍ وٌ شَ تِنشِنيِ تٌمَ نّ،
\q1 عٍ شَ مَنفّيٍ كَابَمَ نّ وٌ شَ دَرِيّ مَ.
\q1 عَلَتَلَ شِلِ نّينّ قِمَ نّ وٌ مَ.
\q1 
\v 3 وٌ قِندِ مَ نّ حَمَ تٌقَنيِ رَ عَلَتَلَ بّلّشّ كُي،
\q1 وٌ شَ مَنفّيَ يَنبَ عَ يِ.
\q1 
\v 4 عٍ مُ وٌ شِلِ قَلَمَ سْنْن ‹بْشِ رَبٌلٌشِ،›
\q1 شَ نَ مُ عَ رَ ‹بْشِ كَنَشِ.›
\q1 عٍ وٌ شِلِ قَلَمَ نّ ‹ﭑ مَ بَاتّ،›
\q1 عٍ وٌ شَ بْشِ شِلِ قَلَ ‹فِنّ دْشْي.›
\q1 عٍ وٌ شِلِمَ نَ كِ نّ بَرِ مَ عَلَ وٌ شَنُشِ،
\q1 عَ بَرَ وٌ شَ بْشِ تٌنفٌ عَ يّتّ بّ
\q1 عَلْ شّمّ فِنّ تٌنفٌمَ كِ نَشّ.
\q1 
\v 5 وٌ قَن وٌ شَ بْشِ تٌنفٌمَ وٌ يّتّ بّ نَ كِ نّ،
\q1 عَلَ قَن حّلّشِن وٌ رَ.
\q1 
\v 6 ﭑ كَنتَمَيٍ تِمَ نّ دَرِ سَلَمُ تّتّ قَرِ،
\q1 نَشٍيٍ لُمَ عَلَ مَشَندِ رَ وٌ بّ يَنيِ نُن كْي رَ.
\q1 وٌ تَن نَشٍيٍ عَلَتَلَ شِلِمَ،
\q1 وٌ نَشَ تَفَن نَ رَبَ رَ،
\q1 
\v 7 وٌ نَشَ وٌ سَبَرِ
\q1 هَن عَ شَ دَرِ سَلَمُ رَ سَبَتِ،
\q1 عَ قَ قِندِ تَنتُي رَ دُنِحَ بِرِن مَ.»
\b
\q1 
\v 8 عَلَتَلَ عَ كَلِشِ نّ عَ سّنبّ رَ،
\q1 «ﭑ مُ عِ شَ دٌنسٍ سَمَ عِ يَشُييٍ بّلّشّ سْنْن،
\q1 عٍ مُ وٌ شَ وّنِ نّينّ مِنمَ
\q1 وٌ نَشَن نَوَلِشِ.
\q1 
\v 9 نَشٍيٍ شّ سَمَ، نٍيٍ نَن عَ دٌنمَ تَنتُي رَ عَلَتَلَ بّ.
\q1 نَشٍيٍ وّنِ بٌفِ بُندُ مَ، نٍيٍ نَن عَ مِنمَ ﭑ مَ هْرْ مْبَنشِ بُنتُنيِ رَ.»
\b
\q1 
\v 10 «وٌ مِنِ تَا كُي نَادّيٍ رَ،
\q1 وٌ سَ ﭑ مَ حَمَ شَ كِرَ رَقَلَ!
\q1 وٌ عَ يَءِلَن، وٌ فّمّيٍ بَ كِرَيٍ رَ!
\q1 وٌ شَ تْنشُمَ تِ سِيٍ بّ.
\q1 
\v 11 عَلَتَلَ شَ مَسٍنيِ نَن يِ كِ دُنِحَ بّ،
\q1 ‹وٌ عَ قَلَ سِيٌنِكَيٍ بّ،
\q1 وٌ رَكِسِمَ نَ قَقٍ.
\q1 عَ قَمَ وٌ سَرٍ رَ.›
\q1 
\v 12 عٍ شِلِ قَلَمَ نّ ‹حَمَ سّنِيّنشِ،›
\q1 عَلَتَلَ نَشَن شُن سَرَشِ.
\q1 وٌ شِلِ قَلَمَ نّ ‹حَمَ قٍنشِ،› ‹حَمَ نَشَن مُ رَبٌلٌشِ.›»
\c 63
\s1 فبٍحْشْي لْشْي
\q1 
\v 1 ندٍ نَ قَقٍ كٍلِقٍ عٍدٌن بْشِ مَ،
\q1 دُفِ فبٍيلِ رَفٌرٌشِ نَشَن مَ،
\q1 دُفِ نَشَن يَءِلَنشِ بٌسَرَ تَا كُي؟
\q1 عَ سّنبّ فبٌ، عَ تٌقَن.
\q1 عَ قَ عَ قَلَ، «ﭑ شَ عَ قَلَ وٌ بّ نْندِ كِ مَ،
\q1 ﭑ قَشِ وٌ رَكِسِدٍ نّ!»
\b
\q1 
\v 2 «مُنقٍ رَ عِ شَ دُفِ فبٍيلِشِ عَلْ مِشِ نَشَن وّنِ بٌفِ بُندُ مَ؟»
\q1 
\v 3 «ﭑ تَن كٍرٍن بَرَ وَلِ عَلْ مِشِ نَشَن وّنِ بُندُ مَ.
\q1 سِ يٌ مُ ﭑ مَلِشِ نَ وَلِ كُي.
\q1 ﭑ بَرَ عٍ بٌرٌن ﭑ مَ شْنّ كُي،
\q1 عٍ وُلِ قَ كَسَن ﭑ مَ دُفِ مَ هَن عَ فبٍيلِ سٌي.
\q1 
\v 4 ﭑ بْحّ نُ وَ مَ فبٍ حْشْي نَن شْن.
\q1 شُنسَرٍ تّمُي بَرَ عَ لِ.
\q1 
\v 5 ﭑ مُ مِشِ تٌ نَشَن ﭑ مَلِمَ،
\q1 نَ كُي ﭑ بَرَ كِسِ وَلِ سُشُ ﭑ يّتّ رَ،
\q1 ﭑ مَ شْنّ قَ ﭑ تُتُن يَرٍ.
\q1 
\v 6 ﭑ بَرَ سِيٍ بٌرٌن ﭑ مَ شْنّ كُي،
\q1 عٍ قَ لُ عَلْ سِيسِلَيٍ، عٍ وُلِ لُ بْشِ مَ.»
\b
\q1 
\v 7 ﭑ عَلَتَلَ شَ هِننّ قٍ قَلَمَ نّ وٌ بّ.
\q1 وٌن شَ عَ تَنتُ عَ شَ قٍ رَبَشِيٍ شَ قٍ رَ،
\q1 عَ نَشَن نَبَشِ وٌن بّ.
\q1 عَ بَرَ قٍ قَنيِ وُيَشِ رَبَ عِسِرَيِلَ بْنسْي بّ،
\q1 عَ شَ هِننّ نُن كِنِكِنِ سَابُي رَ.
\q1 
\v 8 عَ عَ قَلَ نّ، «ﭑ لَشِ عَ رَ ﭑ مَ حَمَ نَن يِ كِ،
\q1 مَءِقُيَ مُ نَ نَشٍيٍ يَ مَ!»
\q1 نَ كُي عَ نَشَ قِندِ عٍ رَكِسِمَ رَ.
\q1 
\v 9 عٍ شَ تْورّ شَ قٍ نُ عَ تْورْ مَ،
\q1 كْنْ عَ قَقٍ بَرَ قِندِ عٍ شُنسَرٍ رَ.
\q1 عَ بَرَ عٍ تٌنفٌ،
\q1 عَ عٍ شَنِن عَ شَ شَنُنتٍيَ نُن كِنِكِنِ كُي كَبِ تّمُي شْن كُيٍ.
\q1 
\v 10 كْنْ عٍ نَشَ مُرُتَ عَ مَ،
\q1 عٍ قَ عَ شَشِلِ سّنِيّنشِ تْورْ.
\q1 نَ كُي عَ نَشَ عٍ بّحِن،
\q1 عَ قِندِ عٍ يَشُي رَ عٍ فٍرٍقَ.
\b
\q1 
\v 11 حَمَ بَرَ عَ مَحْشُن قٍ سِنفٍيٍ مَ،
\q1 نَشَن نَبَشِ عَننَبِ مُنسَ شَ وَشَتِ.
\q1 عٍ بَرَ عٍ يّتّ مَشْرِن،
\q1 «عَلَ نَشَن عِسِرَيِلَكَيٍ رَفِرِ شُلُنيُمِ بَا مَ،
\q1 نَ نَ مِندٍن؟
\q1 عَلَ نَشَن عَ شَ حَمَ تٌنفٌ عَلْ شُرُ سٍ دّ مَدٌنيِ،
\q1 نَ نَ مِندٍن؟
\q1 عَلَ نَشَن عَ شَشِلِ سّنِيّنشِ رَفٌرٌ عَ شَ حَمَ مَ،
\q1 نَ نَ مِندٍن؟
\q1 
\v 12 عَلَ نَشَن مُنسَ مَلِ عَ سّنبّ كَرَلَنكٍ رَ،
\q1 نَشَن بَا عِبْو عٍ يَ رَ عٍ رَفِرِقٍ رَ،
\q1 عَلَكٌ عَ شِلِ شَ بِنيَ عَبَدَن،
\q1 
\v 13 نَ نَ مِندٍن؟»
\q1 نَ كُي عٍ مُ بِرَ.
\q1 عٍ سّنبّ نُ فبٌ عَلْ سٌي نَشَن عَ فِمَ.
\q1 
\v 14 عَلَتَلَ شَشِلِ نُ مَلَبُي قِمَ عٍ مَ،
\q1 عٍ قَ لُ عَلْ نِنفٍ نَشَن حٌوفٍ دٌنمَ قِيلِ مَ.
\q1 عِ بَرَ عِ شَ حَمَ رَحّرّ نَ كِ.
\q1 عِ بَرَ شِلِ قَنيِ سْتْ نَ مَ.
\b
\q1 
\v 15 عِ شَ عِ يَ رَفٌرٌ كٍلِ كٌورٍ مَ،
\q1 كٍلِقٍ عِ شَ كِبَنيِ سّنِيّنشِ كُي،
\q1 نَشَن عِتٍشِ، نَشَن لُمَ نْرّ كُي،
\q1 عِ قَ عَ مَتٌ عِ شَ شَنُنتٍيَ نُن سّنبّ نَ عٍ يّتّ مَسٍنقٍ دِ؟
\q1 عِ شَ هِننّ نُن كِنِكِنِ مَكُيَ مُشُ رَ.
\q1 
\v 16 كْنْ هَلِ عِبُرَهِمَ نُن عِسِرَيِلَ نّيمُ مُشُ مَ،
\q1 عِ تَن نَن نَ مُشُ بَبَ رَ.
\q1 عَلَتَلَ نَن مُشُ بَبَ رَ،
\q1 مُشُ شُنسَرَ مَ كَبِ تّمُي شْنكُيٍ.
\q1 
\v 17 مُنقٍ رَ عِ عَ نِيَمَ، مُشُ شَ عِ شَ كِرَ رَبّحِن؟
\q1 مُنقٍ رَ عِ مُشُ بْحّ شْرْشْمَ هَن مُشُ شَ سُسَ عِ رَ؟
\q1 مُشُ مَرِفِ، عِ شَ مُشُ رَفبِلٍن عِ شَ يَرَفَاشُي كُي.
\q1 
\v 18 عِ شَ هْرْ مْبَنشِ نُ نَ مُشُ بّلّشّ،
\q1 كْنْ يَكْسِ مُشُ يَشُييٍ بَرَ مّننِ بٌرٌن.
\q1 
\v 19 عِ فبٍ نَن مُشُ رَ كَبِ تّمُي شْنكُيٍ،
\q1 كْنْ عٍ تَن مُ تِنشِ عِ شَ يَامَرِ رَ،
\q1 عٍ مُ عِ شِلِ قَلَمَ.
\b
\q1 شَ عِ سَ كٌورٍ رَبِ نّ نُ فٌرٌقٍ رَ دُنِحَ،
\q1 فٍيَيٍ سّرّنمَ نّ عِ يَ رَ نُ.
\c 64
\s1 عِسِرَيِلَ شَ مَشْرِنيِ
\q1 
\v 1 دُنِحَ رَكٌلٌن عِ شِلِ سّنبّمَ رَ،
\q1 عَلَكٌ سِيٍ شَ سّرّن فَاشُي كُي عِ يَ رَ.
\q1 عَ شَ لُ عَلْ يٍفٍ نَشَن دّشّمَ،
\q1 عَ قَ يٍ سَتُن عَ شْرْشْي رَ.
\q1 
\v 2 عِ بَرَ كَابَنَكٌي رَبَ نَشٍيٍ بَرَ مُشُ تّرّننَ،
\q1 عِ بَرَ فٌرٌ، فٍيَيٍ قَ سّرّن عِ يَ رَ.
\q1 
\v 3 يِ قٍ مْولِ مُ كٌلٌنشِ سِندٍن.
\q1 عِ كٍرٍن نَن بَرَ نَ قٍ مْولِ كٌلٌن،
\q1 عِ تَن نَشَن مِشِ مَلِمَ نَشٍيٍ لَشِ عِ رَ.
\q1 
\v 4 عِ قَ نّ مِشِ مَلِدٍ نَشٍيٍ تِنمَ تِنشِنيِ رَ،
\q1 نَشٍيٍ وَ مَ بِرَقٍ عِ شَ كِرَ قْشْ رَ.
\b
\q1 كْنْ مُشُ تَن بَرَ يُنُبِ رَبَ،
\q1 عِ قَ شْنْ مُشُ مَ.
\q1 مُشُ نْمَ كِسِدٍ سْنْن؟
\q1 
\v 5 مُشُ بِرِن بَرَ قِندِ مِشِ سّنِيّنتَرٍ رَ.
\q1 مُشُ نَشَن نَبَمَ عِ بّ عَ نْشْشِ عَلْ دُنكٌبِ.
\q1 مُشُ شَ قٍ لُشِ نّ عَلْ بُرّشّ لِسِشِ.
\q1 مُشُ شَ يُنُبِيٍ نَ مُشُ شَنِنقٍ عَلْ قٌيٍ بُرّشّ شَنِنمَ كِ نَشّ.
\q1 
\v 6 كْنْ مِشِ يٌ مُ نَ مُشُ يَ مَ نَشَن عِ شِلِمَ،
\q1 عٍ مُ عِ شَ قٍ سُشُمَ،
\q1 بَرِ مَ عِ بَرَ عِ يّتّ مَكُيَ مُشُ رَ،
\q1 عِ بَرَ مُشُ تْورْ مُشُ شَ يُنُبِ شَ قٍ رَ.
\b
\q1 
\v 7 كْنْ يَكْسِ، مُشُ مَرِفِ، مُشُ بَبَ،
\q1 مُشُ بَرَ لُ عَلْ بّندّ دٌلٌشِ عِ يِ رَ،
\q1 عِ نَشَن نَوَلِمَ عَ شَ قِندِ قّحّ تٌقَنيِ رَ.
\q1 مُشُ تَن نَن عِ بّلّشّ وَلِ قْشِ مَسٍنمَ.
\q1 
\v 8 عِ نَشَ شْنْ مُشُ مَ مَرِفِ.
\q1 عِ نَشَ رَتُ مُشُ شَ يُنُبِيٍ مَ.
\q1 عِ يَ تِ مُشُ رَ، عِ شَ حَمَ.
\q1 
\v 9 عِ شَ تَا سّنِيّنشِيٍ بَرَ قِندِ فبٍنفبٍرٍن يِرٍ رَ،
\q1 سِيٌنِ بَرَ قِندِ يِرٍ مَشَرَشِ رَ،
\q1 دَرِ سَلَمُ بَرَ كَنَ،
\q1 
\v 10 عِ شَ هْرْ مْبَنشِ مُشُ نُ سّيوَشِ نَشَن نَ،
\q1 نَ بَرَ فَن.
\q1 مُشُ هَرِفٍ قَنيِ بِرِن بَرَ كَنَ.
\q1 
\v 11 نَ بِرِن كُي، عِ تٌندِشِ مُشُ مَلِدٍ؟
\q1 عِ عِ سَبَرِ مَ هَن مُن تّمُي؟
\q1 عِ مُشُ حَشَنكَتَمَ نَن تُي؟
\c 65
\s1 كِيتِ نُن كِسِ
\q1 
\v 1 «ﭑ بَرَ ﭑ يّتّ مَسٍن مِشِيٍ بٍ نَشٍيٍ مُ نُ ﭑ شِلِشِ،
\q1 مِشِيٍ بَرَ ﭑ تٌ نَشٍيٍ مُ نُ ﭑ قٍنمَ.
\q1 ﭑ بَرَ عَ قَلَ، ‹ﭑ تَن نَن يَ،›
\q1 سِ ندٍ بّ نَشَن مُ نُ شِلِمَ.
\q1 
\v 2 ﭑ نَ ﭑ بّلّشّ تِ نّ لْشْي بِرِن حَمَ تُلِ شْرْشْشِ بّ،
\q1 نَشَن حّرّ مَ كِرَ حَاشِ شْن عٍ يّتّ وَشْنيِ قٍنقٍ رَ.
\q1 
\v 3 نَ حَمَ كَتَمَ تّمُي بِرِن ﭑ نَشْنْقٍ رَ.
\q1 عٍ سّرّشّيٍ بَمَ سَنسِ يِرٍ،
\q1 عٍ سُرَيِ قَن فَن سّرّشّ رَ عٍ شَ عَلَيٍ بّ.
\q1 
\v 4 عٍ دْشْمَ فَبُرِ سّيتِ مَ كْي رَ،
\q1 عٍ شْسّ سُبٍ دٌن، عَ نُن سٍ سّنِيّنتَرٍ فبّتّيٍ.
\q1 
\v 5 عٍ عَ قَلَمَ مِشِيٍ بّ، ‹وٌ نَشَ وٌ مَسٌ ﭑ نَ دٍ،
\q1 بَرِ مَ ﭑ سّنِيّنشِ دَنفِقٍ وٌ رَ.›
\q1 نَ مِشِ مْولِ شَ قٍ شْرْشْ
\q1 عَلْ تُورِ نَشَن تٍمَ تّ يِرٍ، عَ سِفَ مِشِ مَ.»
\b
\q1 
\v 6 «يِ نَن سّبّشِ ﭑ يَ عِ،
\q1 ﭑ مُ دُندُ مَ نَ مَ قٍوٌ.
\q1 ﭑ نَ سَرٍ بِرِن قِمَ نّ عٍ مَ.
\q1 
\v 7 ﭑ تَن وٌ مَرِفِ نَشّ،
\q1 ‹ﭑ وٌ شَ يُنُبِ سَرٍ قِمَ نّ،
\q1 وٌ تَن نُن وٌ بٍنبَيٍ مَ،
\q1 بَرِ مَ وٌ نُ سّرّشّيٍ بَمَ فٍيَيٍ نَن قَرِ،
\q1 وٌ نُ قٍ حَاشِ رَبَ ﭑ نَ مّننِ.
\q1 نَ كُي ﭑ وٌ شَ يُنُبِ سَرٍ قِمَ نّ وٌ مَ،
\q1 وٌ شَ قٍ حَاشِيٍ شَ قٍ رَ.›»
\b
\q1 
\v 8 عَلَتَلَ شَ مَسٍنيِ نَن يَ،
\q1 «مِشِ نَ بٌفِ ندٍ بُندُقٍ تّمُي نَشّ،
\q1 عٍ قَ وَ نَ بٌفِ وْلّقٍ،
\q1 مِشِ فبّتّ عَ قَلَمَ نّ عٍ بّ،
\q1 ‹عِ نَشَ نَ وْلّ. يٍ ندٍ مَن لُشِ عَ كُي.›
\q1 ﭑ قَن نَ مْولِ رَبَمَ نّ ﭑ قْشِرَبِرّيٍ رَ.
\q1 ﭑ مُ عٍ بِرِن حَشَنكَتَمَ.
\q1 
\v 9 ﭑ يَشُبَ شَ دِ ندٍيٍ رَكٍلِمَ نّ،
\q1 ﭑ يُدَ شَ دِ ندٍيٍ كِ ﭑ مَ فٍيَيٍ رَ.
\q1 ﭑ نَ ﭑ مَ فٍيَيٍ قِمَ نّ ﭑ مَ حَمَ سُفَندِشِ مَ،
\q1 عٍ شَ سَبَتِ نَا، عَ قَ قِندِ عٍ كّ رَ.
\q1 
\v 10 سَرْن قِيلِ قِمَ نّ عٍ مَ عٍ شُرُ سٍيٍ مَدٌنمَ دّننَشّ،
\q1 عَكٌرِ فُلُنبَ قِندِ مَ مَلَبُدٍ نَن نَ عٍ شَ فْورّ بٍ.
\q1 ﭑ نَ بِرِن نَبَمَ نّ ﭑ مَ حَمَ بّ نَشَن ﭑ قٍنمَ.»
\b
\q1 
\v 11 «كْنْ وٌ تَن نَشٍيٍ وٌ كٌبٍ سٌشِ ﭑ تَن عَلَتَلَ رَ،
\q1 وٌ قَ نّيمُ ﭑ مَ فٍيَ سّنِيّنشِ مَ،
\q1 وٌ قَ سّرّشّ بَ وٌ شَ عَلَيٍ بّ،
\q1 نَشَن شِلِمَ فَدِ ‹شُننَقَنيِ كَنيِ›
\q1 شَ نَ مُ عَ رَ، نَشَن شِلِمَ مٍنِ ‹مَرَفِرِ كَنيِ،›
\q1 
\v 12 ﭑ بَرَ نَتّ تٌنفٌ وٌ تَن حَشَنكَتَمَ سَنتِدّفّمَ نَن نَ،
\q1 وٌ بِرِن قَ قَشَ.
\q1 ﭑ بَرَ وٌ شِلِ، كْنْ وٌ مُ قَ.
\q1 ﭑ بَرَ وْيّن، كْنْ وٌ مُ وٌ تُلِ مَتِ.
\q1 وٌ بَرَ قٍ حَاشِ رَبَ نَشَن مُ رَقَن ﭑ مَ قٍوٌ.»
\b
\q1 
\v 13 نَ كُي وٌ مَرِفِ عَلَ يِ نَن قَلَ،
\q1 «ﭑ مَ كٌنيِيٍ عٍ دّفٍمَ نّ،
\q1 كْنْ ﭑ وٌ تَن لُمَ كَامّ نَن كُي.
\q1 ﭑ مَ كٌنيِيٍ عٍ مِنمَ،
\q1 كْنْ يٍ شْلِ لُمَ نّ وٌ تَن مَ.
\q1 ﭑ مَ كٌنيِيٍ سّيوَ مَ نّ،
\q1 كْنْ يَافِ دُ سُمَ نّ وٌ تَن شُن نَ.
\q1 
\v 14 ﭑ مَ كٌنيِيٍ بّيتِ بَمَ سّيوّ نَن كُي،
\q1 كْنْ وٌ تَن وَ مَ نّ تْورّ كُي، وٌ بْحّ قَ رَحَاشُ وٌ مَ.
\q1 
\v 15 وٌ شِلِ قِندِ مَ نّ دَنكّ رَ ﭑ مَ حَمَ تَفِ.
\q1 عَلَتَلَ سّنبّمَ وٌ قَشَمَ نّ،
\q1 كْنْ عَ شِلِ نّينّ قِمَ نّ عَ شَ كٌنيِيٍ مَ.
\q1 
\v 16 مِشِ نَشَن دُبّ رَبَمَ يِ بْشِ مَ،
\q1 عَ نَ رَبَمَ نْندِ نَن كُي عَلَ شِلِ رَ.
\q1 مِشِ نَشَن كَلِ تِمَ يِ بْشِ مَ،
\q1 عَ نَ رَبَمَ نْندِ نَن كُي عَلَ شِلِ رَ.
\q1 تْورّ دَنفِشِ نّيمُمَ نّ ﭑ نَ، عَ بَ ﭑ يَ عِ.»
\b
\q1 
\v 17 «وٌ شَ عَ كٌلٌن ﭑ قَمَ نّ كٌورٍ نُن بْشِ نّينّ دَادٍ.
\q1 مِشِ مُ رَتُمَ قٍ قٌرِيٍ مَ سْنْن.
\q1 
\v 18 كْنْ ﭑ مَ دَالِ، وٌ شَ سّيوَ عَبَدَن،
\q1 بَرِ مَ ﭑ دَرِ سَلَمُ دَامَ نّ عَ شَ وٌ رَ سّيوَ هَن.
\q1 
\v 19 ﭑ سّيوَ مَ نّ دَرِ سَلَمُ تَفِ،
\q1 ﭑ قٍ قَنيِ رَبَ ﭑ مَ مِشِيٍ بّ،
\q1 وَ شُي مُ مّمَ سْنْن.
\q1 
\v 20 دِ يٌ مُ قَشَمَ عَ يْرّ رَ سْنْن،
\q1 مِشِ مْشِ يٌ قَن مُ قَشَمَ قٌ عَ شَ سِمَيَ كَمَلِ.
\q1 مِشِ نَشَن حّ كّمّ سِمَيَ سْتْمَ، عَ قَ قَشَ،
\q1 عَ لُمَ نّ عَلْ عَ نَ قَشَ عَ دِ مّدِ تّمُي، عَ قِندِ مِشِ دَنكَشِ رَ.
\q1 
\v 21 عٍ بَنشِيٍ تِمَ نّ، عٍ سَبَتِ عٍ كُي.
\q1 عٍ وُرِ بِلِيٍ سِمَ نّ، عٍ عٍ بٌفِ دٌن.
\q1 
\v 22 عٍ مُ بَنشِيٍ تِمَ سْنْن، مِشِ فبّتّيٍ قَ سَبَتِ نٍيٍ كُي.
\q1 عٍ مُ سَنسِ سِمَ سْنْن، مِشِ فبّتّيٍ قَ نَ بٌفِ دٌن.
\q1 ﭑ مَ حَمَ بُمَ نّ، عَلْ وُرِ شُنفبٍيٍ.
\q1 ﭑ مَ مِشِ سُفَندِشِيٍ سّيوَ مَ نّ عٍ شَ وَلِ رَ.
\q1 
\v 23 عٍ مُ وَلِمَ قُ رَ، عٍ شَ دِيٍ مُ فبَلٌي سْتْمَ.
\q1 عٍ قِندِ مَ عَلَ بْنسْي بَرَكَشِ نَن نَ،
\q1 عٍ تَن نُن عٍ شَ دِيٍ لُمَ نَ كِ نّ عَبَدَن.
\q1 
\v 24 بٍينُ عٍ شَ ﭑ مَشَندِ، عَ لِمَ نّ ﭑ حَن بَرَ عٍ شُي سُشُ.
\q1 بٍينُ عٍ شَ فّ قٍ ندٍ قَلَدٍ، ﭑ حَن بَرَ نَ مّ.
\q1 
\v 25 شُلُمَسٍ نُن سِ لُمَ نّ كُلّ كٍرٍن.
\q1 يّتّ نُن نِنفٍ حٌوفٍ دٌنمَ نّ يِرٍ كٍرٍن.
\q1 كْنْ بْشِمَسٍ لُمَ عَ بَلٌ رَ شُبُتَنيِ نَن نَ.
\q1 عٍ مُ قٍ يٌ كَنَمَ ﭑ مَ فٍيَ سّنِيّنشِ قَرِ.»
\q1 عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ.
\c 66
\s1 كِيتِ نُن كِسِ
\q1 
\v 1 مَرِفِ شَ مَسٍنيِ نَن يَ،
\q1 «كٌورٍ نَن نَ ﭑ مَ كِبَنيِ رَ،
\q1 دُنِحَ نَن نَ ﭑ سَن تِدٍ رَ.
\q1 بَنشِ مْولِ مُندُن نْمَ تِدٍ ﭑ تَن بّ؟
\q1 يِرٍ مُندُن نْمَ قِندِدٍ ﭑ مَلَبُدٍ رَ؟
\q1 
\v 2 ﭑ بّلّشّ نَن سٍيٍ بِرِن نَقَلَشِ نَشٍيٍ نَ دُنِحَ.»
\q1 عَلَتَلَ شَ مَسٍنيِ نَن نَ كِ.
\b
\q1 «مِشِ نَشَن نَقَن ﭑ مَ،
\q1 عَ قِندِشِ يّتّ مَفٌرٍ نَن نَ،
\q1 عَ فَاشُ ﭑ يَ رَ، عَ ﭑ شُي سُشُ.
\q1 
\v 3 كْنْ مِشِ نَشَن نِنفٍ بَمَ سّرّشّ رَ فبَنسَن،
\q1 نَ تَن لُمَ نّ عَلْ قَشّتِ.
\q1 مِشِ نَشَن يّشّي بَمَ سّرّشّ رَ فبَنسَن،
\q1 نَ تَن لُمَ نّ عَلْ مِشِ نَشَن بَرٍ كْنيِ فِرَ مَ.
\q1 مِشِ نَشَن سَنسِ شْرِ بَمَ سّرّشّ رَ فبَنسَن،
\q1 نَ تَن لُمَ نّ عَلْ مِشِ نَشَن شْسّ وُلِ بَمَ سّرّشّ رَ.
\q1 مِشِ نَشَن سُرَيِ فَنمَ سّرّشّ رَ فبَنسَن،
\q1 نَ تَن لُمَ نّ عَلْ كُيٍ بَتُي.
\q1 عٍ بَرَ عٍ شَ كِرَ سُفَندِ،
\q1 كِرَ نَشَن قِندِشِ سّنِيّنتَرٍحَ شْنشِ رَ.
\q1 
\v 4 نَ كُي ﭑ قَن عٍ حَشَنكَتَمَ نّ،
\q1 ﭑ قٍ مَفَاشُشِ رَفٌرٌ مَ نّ عٍ مَ،
\q1 بَرِ مَ ﭑ تٌ عٍ شِلِ، عٍ مُ ﭑ مَ شِلِ رَتِنشِ،
\q1 ﭑ تٌ وْيّن، عٍ مُ عٍ تُلِ مَتِ ﭑ نَ.
\q1 عٍ بَرَ قٍ حَاشِ رَبَ ﭑ يَ شْرِ،
\q1 عٍ بَرَ كِرَ سُفَندِ، نَشَن مُ رَقَن ﭑ مَ.»
\b
\q1 
\v 5 وٌ شَ وٌ تُلِ مَتِ عَلَتَلَ شُي رَ،
\q1 وٌ تَن نَشٍيٍ فَاشُشِ عَ يَ رَ،
\q1 «وٌ نفَشَكٍرٍنيِ نَشٍيٍ وٌ شْنمَ،
\q1 عٍ وٌ كٍرِ ﭑ شِلِ شَ قٍ رَ، عٍ نَشّ،
\q1 ‹وٌ شَ عَلَتَلَ تَنتُ عَلَكٌ مُشُ شَ وٌ شَ سّيوّ تٌ.›
\q1 كْنْ عٍ قَمَ نّ يَافِدٍ.
\q1 
\v 6 وٌ بَرَ نَ سْنشْي مّ كٍلِقٍ تَا كُي،
\q1 كٍلِقٍ عَلَ شَ هْرْ مْبَنشِ كُي؟
\q1 عَلَتَلَ نَ عَ يَشُييٍ سَرٍ قِقٍ.
\q1 نَ قِندِشِ نَ شُي نَن نَ وٌ نَشَن مّمَ.»
\b
\q1 
\v 7 بٍينُ دِ بَرِ شْنّ شَ عَ لِ،
\q1 عَ حَن فّ دِ بَرِدٍ.
\q1 بٍينُ تْورّ شَ قَ،
\q1 عَ حَن بَرَ دِ شّمّ سْتْ.
\q1 
\v 8 ندٍ سِنفٍ بَرَ يِ قٍ مْولِ مّ؟
\q1 ندٍ سِنفٍ بَرَ يِ قٍ مْولِ تٌ؟
\q1 حَمَنّ نْمَ قِندِدٍ عَ رَ لْشْي كٍرٍن كُي؟
\q1 بْنسْي نْمَ سّنبّ سْتْدٍ تّمُي كٍرٍن كُي؟
\q1 كْنْ سِيٌنِ بَرَ قٌيٍ تٌ كٍرٍن نَ.
\q1 
\v 9 وٌ مَرِفِ عَلَتَلَ نَشّ،
\q1 «ﭑ مِشِ مَلِمَ هَن عٍ دِ بَرِ تّمُي، ﭑ قَ عٍ رَبٌلٌ نَ كُي؟
\q1 فِنّ قُرِ نَ مْ، ﭑ مُ قَمَ نَ دِ بَرِ سْونّيَدٍ شّ؟»
\q1 
\v 10 وٌ تَن دَرِ سَلَمُ رَقَن نَشٍيٍ مَ،
\q1 وٌ شَ سّيوَ عَ شَ قٍ رَ.
\q1 وٌ تَن نَشٍيٍ وَ مَ عَ بّ،
\q1 وٌ شَ حّلّشِن عَ شَ قٍ رَ.
\q1 
\v 11 وٌ قَمَ نّ عَ شِحّ مِندٍ هَن وٌ لُفَ،
\q1 وٌ بْحّسَ سْتْ عَ سَابُي رَ،
\q1 عَ وٌ هَيِ بِرِن قَن.
\q1 
\v 12 عَلَتَلَ شَ مَسٍنيِ نَن يَ،
\q1 «ﭑ بْحّسَ قِمَ نّ عَ مَ عَلْ شُرٍ شُنفبٍ،
\q1 ﭑ حَمَنّ نَاقُلِ شَنِنمَ نّ عَ شْن مَ عَلْ بَنبَرَنيِ.
\q1 عَ قَمَ نّ مّينِدٍ وٌ مَ عَلْ دِنفّ مّينِمَ عَ شَ دِ مَ كِ نَشّ.
\q1 
\v 13 ﭑ وٌ شَ تْورّ بَمَ نّ وٌ مَ عَلْ دِنفّ عَ شَ دِ شَ تْورّ بَمَ كِ نَشّ.
\q1 نَ بِرِن تٌمَ نّ دَرِ سَلَمُ.»
\b
\q1 
\v 14 وٌ نَ نَ تٌ، وٌ بْحّ سّيوَ مَ نّ،
\q1 وٌ شَ قٍ سْونّيَ عَلْ حٌوفٍ نَشَن تٌمَ قِيلِ مَ.
\q1 عَلَتَلَ عَ سّنبّ مَسٍنمَ نّ عَ شَ كٌنيِيٍ بّ،
\q1 عَ يَشُي قَمَ نّ عَ شَ شْنّ كٌلٌندٍ.
\q1 
\v 15 عَلَتَلَ نَن نَ كِ، عَ نَ قَقٍ تّ شْورَ،
\q1 عَ حّرّ مَ قٌيٍ شُنفبٍ قَرِ.
\q1 عَ عَ شَ شْنّ رَفٌرٌ مَ نّ سّنبّ رَ،
\q1 عَ حَشَنكَتّ تِ تّ رَ.
\q1 
\v 16 عَلَتَلَ عَ شَ كِيتِ سَمَ نّ تّ نُن سَنتِدّفّمَ رَ،
\q1 عَ قَ مِشِ فبٍفبٍ سْنتْدٍ.
\p 
\v 17 عَلَتَلَ نَشّ، «مِشِ نَشٍيٍ سّرّشّ بَمَ وٌندِ كُي، عٍ قَ شْسّ نُن بَلٍ سُبٍ دٌن، عَ نُن دٌنسٍ سّنِيّنتَرٍ فبّتّيٍ عَلَتَلَ نَشٍيٍ شْنشِ، عٍ شَ قٍ قَمَ نّ رَحْندٍ كٍرٍنيِ رَ.»
\p 
\v 18 «ﭑ قَمَ نّ سِ بِرِن مَلَندٍ، سِ نَشٍيٍ شُي وُيَشِ قَلَمَ، ﭑ قَ ﭑ مَ نْرّ مَسٍن عٍ بّ عٍ شَ قٍ رَبَشِيٍ نُن عٍ شَ مَحْشُنيِيٍ شَ قٍ رَ.
\v 19 ﭑ تْنشُمَ ندٍ لُمَ نّ عٍ تَفِ، ﭑ قَ عٍ شَ مِشِ كِسِشِيٍ شّي بْنسْييٍ تَفِ، عَلْ تَرَ سِسِ، ثُلُ، لُدُ شَلِ وٌلِيٍ، تُبَلِ، يَوَنِ، نُن سِ فبّتّ نَشٍيٍ نَ يِرٍ مَكُيٍيٍ، نَشٍيٍ مُ ﭑ شِلِ كٌلٌن، نَشٍيٍ مُ ﭑ مَ نْرّ تٌشِ سِندٍن. ﭑ مَ شّيرَيٍ قَمَ نّ ﭑ مَ نْرّ مَسٍندٍ عٍ بّ.
\v 20 عٍ مَن قَمَ نّ وٌ نفَشَكٍرٍنيِيٍ رَ نَشٍيٍ تٌمَ نَ حَمَنّيٍ تَفِ. عٍ قَمَ نّ عٍ رَ ﭑ مَ فٍيَ سّنِيّنشِ قَرِ عَلْ سّرّشّ قَمَ كِ نَشّ. عٍ قَمَ نّ عٍ رَ سٌييٍ نُن حْشْمّيٍ قَرِ، عٍ تِشِ سَرّتِيٍ كُي. عٍ قَمَ نّ نَ بِرِن نَ عَلْ عِسِرَيِلَكَيٍ قَمَ عٍ شَ هَدِيَيٍ رَ سٍسَسٍ سّنِيّنشِيٍ كُي كِ نَشّ عَلَتَلَ شَ هْرْ مْبَنشِ كُي.
\v 21 ﭑ سّرّشّدُبّ ندٍيٍ سُفَندِ مَ نّ عٍ قَن يَ مَ، عٍ شَ لُ لٍوِ بْنسْي سّيتِ مَ.»
\p 
\v 22 «ﭑ تَن عَلَتَلَ، ﭑ شَ عَ قَلَ وٌ بّ، عَ ﭑ قَمَ نّ كٌورٍ نّينّ نُن بْشِ نّينّ يَءِلَندٍ وٌ بّ. نَ بُمَ كِ نَشّ، وٌ شِلِ نُن وٌ بْنسْي بُمَ نَ كِ نّ عَبَدَن.
\v 23 كٍلِ كِكٍ نّينّ سّرّشّ مَ هَن كِكٍ نّينّ سّرّشّ فبّتّ، كٍلِ مَلَبُ لْشْي مَ هَن مَلَبُ لْشْي فبّتّ، عِبُنَدَ مَ بِرِن قَمَ نّ سُيِدِدٍ ﭑ يَ عِ.
\v 24 عٍ مِشِ قَشَشِيٍ تٌمَ نّ نَشٍيٍ مُرُتَشِ ﭑ مَ. نِمَسٍيٍ عٍ قُرٍيٍ دٌنمَ نّ، تّ قَن عٍ سُبٍ فَن، عٍ قَ قِندِ قٍ مَفَاشُشِ رَ عَدَ مَدِيٍ بّ.»
