\id PSA
\h  إِزهِّيذنْ 
\toc1  إِزهِّيذنْ 
\toc2  إِزهِّيذنْ 
\toc3 إِزهد. 
\mt1 إِزهِّيذنْ  
\c 1
\s1 أَذْلِيسْ أَمزْوَارُو - إِزهِّيذنْ 1-41  
\m
\v 1 سّعْذْ ن ورْيَازْ،  
\m ونِّي وَارْ إِڭُّورنْ  
\m ذِي شّْوَارْ ن إِعفَّاننْ،  
\m ذ ونِّي وَارْ إِبدّنْ  
\m ذڭْ وبْرِيذْ ن إِمذْنَابْ،  
\m ذ ونِّي وَارْ إِقِّيمنْ  
\m خْ ڒْكُورْسِي ن إِمسْثهْزَاينْ، \x ◘ \xo 1:‏1 \xt إِزهد. 26‏:‏4؛ أَوڒن. 1‏:‏10، 15؛ 4‏:‏14، 15؛ 1 كُور. 15‏:‏33؛ أَفا. 5‏:‏11\x*   
\m
\v 2 مَاشَا ڒفْرَاحثْ نّسْ  
\m أَقَا-ت ذِي شَّارِيعَا ن سِيذِي  
\m ؤُ إِتّْخَارّصْ ذِي شَّارِيعَا نّسْ أَسّْ ذ دْجِيڒثْ. \x ◘ \xo 1:‏2 \xt أَعَوذ. 6‏:‏6‏-‏9؛ 17‏:‏19؛ ياش. 1‏:‏8؛ إِزهد. 119‏:‏1\x*   
\m
\v 3 أَذْ يِيڒِي أَمْ يِيشْثْ ن ثْشجَّارْثْ  
\m إِ إِتّْوَاژُّونْ غَارْ ثْغزْرَاثِينْ ن وَامَانْ،  
\m ثنِّي إِتِّيشنْ ڒْغِيدْجثْ نّسْ ذِي ڒْوقْثْ نّسْ،  
\m أَفَارْ نّسْ وَارْ إِتِّيژغْ.  
\m مَارَّا مِينْ إِتّڭّْ، أَذْ يِيڒِي. \f ◼ \fr 1:‏3 \ft \+bd ’ثَاشجَّارْثْ‘\+bd* - نِيغْ ’أَدَّاڭْ‘ (’إِدَّاڭنْ‘).\f*  \x ◘ \xo 1:‏3 \xt إِرْم. 17‏:‏8\x*   
\b  
\m
\v 4 وَارْ \add تِّيڒِينْ\add* إِعفَّاننْ أَمُّو،  
\m مِينْزِي \add نِيثْنِي\add* أَمْ إِشَارْفَا إِتَّاوِي-يْ-إِ-ث ؤُسمِّيضْ. \x ◘ \xo 1:‏4 \xt أَيُوبْ 21‏:‏18؛ إِزهد. 35‏:‏5؛ إِشا. 17‏:‏13؛ 29‏:‏5؛ حُوش. 13‏:‏3\x*   
\m
\v 5 خْ ؤُيَا إِعفَّاننْ وَارْ تّْبذِّينْ شَا  
\m ذڭْ وَاسّْ ن ڒحْسَابْ،  
\m ؤُڒَا ذ إِمذْنَابْ ذِي ثْمسْمُونْثْ ن إِمْسڭَّاذنْ.   
\m
\v 6 مِينْزِي سِيذِي إِسّنْ أَبْرِيذْ ن إِمْسڭَّاذنْ،  
\m \add مَاشَا\add* أَبْرِيذْ ن إِعفَّاننْ أَذْ إِفْنَا.   
\b  
\b  
\m  
\c 2
\m
\v 1 مَايمِّي تّْهَاجنْ ڒڭْنُوسْ،  
\m تّْخَارِّيصنْ شُّوعُوبْ ذِي ڒْبَاطرْ؟ \x ◘ \xo 2:‏1 \xt ڒخ. 4‏:‏25\x*   
\m
\v 2 كَّارنْ إِجدْجِيذنْ ن ثمُّورْثْ،  
\m أَيْثْ ن بُو-صُّولْطَا مْشَاوَارنْ  
\m ضِيدّْ إِ سِيذِي ؤُ ضِيدّْ إِ لْمَاسِيحْ نّسْ:   
\m
\v 3 ’أجّْ أَنغْ أَذْ نْقسّْ إِشذِّييّنْ نْسنْ،  
\m أَذْ خَانغْ نسّْبعّذْ ثِيسغْوِينْ نْسنْ!‘   
\b  
\m
\v 4 ونِّي إِزدّْغنْ ذڭْ ؤُجنَّا إِضحّشْ،  
\m سِيذِي إِنُو أَذْ زَّايْسنْ إِسّْثهْزَا.   
\m
\v 5 خنِّي أَذْ كِيذْسنْ إِسِّيوڒْ س وغْضَابْ نّسْ،  
\m س ڒْحَاذُوقْ ن وغْضَابْ نّسْ أَذْ ثنْ إِسِّيڭّْوذْ.   
\m
\v 6 ”\bd نشّْ\bd* أَقَا ذهْنغْ أَجدْجِيذْ إِنُو،  
\m خْ صِيهْيُونْ، أَذْرَارْ إِنُو إِقدّْسنْ!“   
\b  
\m
\v 7 نشّْ أَذْ بَارّْحغْ ثِيكّسْثْ ن وَاوَاڒْ!  
\m سِيذِي إِنَّا أَيِي:  
\m ”شكْ ذ مِّي، أَسّْ-أَ جِّيغْ-د شكْ! \x ◘ \xo 2:‏7 \xt ڒخ. 13‏:‏33؛ عبر. 1‏:‏5؛ 5‏:‏5\x*   
\m
\v 8 تَّارْ زَّايِي  
\m ؤُ نشّْ أَذْ أَشْ وْشغْ ڒڭْنُوسْ ذ ڒْوَارْثْ،  
\m ثِينڭُّورَا ن ثمُّورْثْ  
\m أَذْ غَاركْ إِڒِينْثْ  
\m ذ أَڭْڒَا إِ شكْ. \x ◘ \xo 2:‏8 \xt إِزهد. 22‏:‏28؛ 72‏:‏8\x*   
\m
\v 9 أَذْ ثنْ ثْڒبْزذْ س يِيجّْ ن وقْضِيبْ ن وُوزَّاڒْ،  
\m أَذْ ثنْ ثَارْژِيذْ ذ ثَارژِّيثْ  
\m أَمْ يِيجّْ ن ؤُغَارَّافْ ن ثْڒَاخْثْ.“\x ◘ \xo 2:‏9 \xt أَسَا. 2‏:‏27؛ 19‏:‏15\x*   
\b  
\m
\v 10 ڒخُّو \add خنِّي\add*، أَ إِجدْجِيذنْ،  
\m إِڒِيمْ ذ إِفهَّامنْ،  
\m ثبّْثمْ إِخفْ نْومْ،  
\m أَ ڒْقُوضَاثْ ن ثمُّورْثْ! \f ◼ \fr 2:‏10 \ft \+bd ’ڒْقُوضَاثْ‘\+bd* - نِيغْ ’إِمزُورْفَا‘.\f*   
\m
\v 11 سخَّارمْ إِ سِيذِي س ثڭّْوُوذِي،  
\m فَارْحمْ س ثَارْجِيجثْ.   
\m
\v 12 سُوذْممْ مِّيسْ، حِيمَا نتَّا وَارْ إِسعَّارْ  
\m ؤُ أَذْ ثتّْوَاهلّْكمْ ذڭْ وبْرِيذْ،  
\m وَاخَّا إِتّْوَاسَّارْغْ وغْضَابْ نّسْ  
\m مْغِيرْ ذْرُوسْ وَاهَا.  
\b  
\m سّعْذْ نْسنْ إِ يِينِّي غَارسْ يَاركّْوَاڒنْ. \x ◘ \xo 2:‏12 \xt إِزهد. 34‏:‏9؛ أَوڒن. 16‏:‏20؛ إِشا. 30‏:‏18؛ إِرْم. 17‏:‏7؛ رُوم. 9‏:‏33؛ 10‏:‏11؛ 1 بُط. 2‏:‏6\x*   
\b  
\b  
\m  
\c 3
\m
\v 1 \add أَزهّذْ ن ذَاوُوذْ، ؤُمِي يَارْوڒْ زڭْ وُوذمْ ن مِّيسْ أَبْشَالُومْ.\add*\x ◘ \xo 3:‏1 \xt 2 صم. 15‏-‏18. \x*   
\b  
\m
\v 2 \add أَ\add* سِيذِي، إِنِّي ذ أَيِي إِحصَّارنْ  
\m أَقَا كتَّارنْ،  
\m أَطَّاسْ أَقَا أَثنْ ضِيدّْ إِنُو.   
\m
\v 3 أَطَّاسْ أَقَا قَّارنْ خْ ڒعْمَارْ إِنُو:  
\m ”إِ نتَّا وَارْ ذِينْ \add إِدْجِي\add* ؤُسنْجمْ غَارْ أَربِّي!“  
\m سِيلَاهْ.   
\b  
\m
\v 4 \add أَحقَّا\add* شكْ، \add أَ\add* سِيذِي،  
\m ذ ثَاسدَّارْثْ ن ؤُسڒْقِي إِ نشّْ،  
\m أَعُودْجِي إِنُو،  
\m شكْ ذ ونِّي إِسّْڭعّْذنْ أَزدْجِيفْ إِنُو.   
\m
\v 5 س ثْمِيجَّا إِنُو ڒَاغِيغْ إِ سِيذِي،  
\m ؤُشَا نتَّا يَارَّا-د خَافِي  
\m زڭْ وذْرَارْ نّسْ إِقدّْسنْ. سِيلَاهْ.   
\b  
\m
\v 6 سنّْذغْ ؤُشَا إِكَّا خَافِي يِيضصْ،  
\m فَاقغْ-د، مِينْزِي سِيذِي إِتّْعَاونْ أَيِي. \x ◘ \xo 3:‏6 \xt إِزهد. 4‏:‏9\x*   
\m
\v 7 وَارْ تّڭّْوِيذغْ زِيعشْرَا ن ڒُوڒُوفْ ن ڒْڭنْسْ،  
\m إِنِّي ذ أَيِي د-إِنّْضنْ،  
\m سّْبدَّانْ إِخفْ نْسنْ خْ إِغزْذِيسنْ إِنُو. \x ◘ \xo 3:‏7 \xt إِزهد. 27‏:‏3\x*   
\b  
\m
\v 8 كَّارْ، أَ سِيذِي، سنْجمْ أَيِي، \add أَ\add* أَربِّي إِنُو،  
\m مِينْزِي شكْ ثوْثِيذْ مَارَّا ڒْعذْيَانْ إِنُو  
\m غَارْ ؤُغسْمِيرْ،  
\m أَقَا ثدّْزذْ ثِيغْمَاسْ ن إِعفَّاننْ.   
\m
\v 9 أَسنْجمْ أَقَا-ث ن سِيذِي،  
\m لْبَارَاكَا نّشْ أَقَا-ت خْ ڒْڭنْسْ نّشْ. سِيلَاهْ. \x ◘ \xo 3:‏9 \xt أَوڒن. 21‏:‏31؛ إِشا. 43‏:‏11؛ إِرْم. 3‏:‏23؛ حُوش. 13‏:‏4؛ أَسَا. 7‏:‏10؛ 19‏:‏1\x*   
\b  
\b  
\m  
\c 4
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. أَكْ-ذ ؤُزنْزُونْ خْ إِفِيڒَانْ. أَزهّذْ ن ذَاوُوذْ.\add*   
\b  
\m
\v 2 أَرّْ-د خَافِي خْمِي د تّْڒَاغِيغْ،  
\m \add أَ\add* أَربِّي ن ثْسڭْذَا إِنُو!  
\m ذِي ڒحْصَارثْ أَقَا شكْ ثڭِّيذْ أَيِي تَّاسِيعْ.  
\m حِينّْ خَافِي ؤُ سڒْ-د غَارْ ثْژَادْجِيثْ إِنُو!   
\b  
\m
\v 3 ثَارْوَا ن \add يِيجّْ ن\add* ورْيَازْ،  
\m أَڒْ مڒْمِي إِ غَا يِيڒِي ؤُعُودْجِي إِنُو ذ ڒْعَارْ؟  
\m أَڒْ مڒْمِي غَا ثخْسمْ ڒْبَاطڒْ،  
\m أَذْ ثَارْزُومْ خْ إِخَارِّيقنْ؟ سِيلَاهْ.   
\m
\v 4 سْنمْ \add خنِّي\add*، أَقَا سِيذِي إِحُوزّْ  
\m إِجّْ ن ؤُمدُّوكّڒْ أَمْثِيقِّي إِ يِيخفْ نّسْ.  
\m سِيذِي أَذْ أَيِي إِسڒْ خْمِي ذ أَسْ إِ غَا ڒَاغِيغْ.   
\b  
\m
\v 5 أَرْجِيجمْ، \add مَاشَا\add* وَارْ خطِّيمْ.  
\m سِيوْڒمْ ذڭْ وُوڒْ نْومْ  
\m ذِي ڒشْثُو نْومْ ؤُشَا سُوسْممْ. سِيلَاهْ. \x ◘ \xo 4:‏5 \xt أَفا. 4‏:‏26\x*   
\m
\v 6 قدّْممْ ثِيغَارْصَا ن ثْسڭْذَا،  
\m تّشْڒمْ خْ سِيذِي. \x ◘ \xo 4:‏6 \xt أَعَوذ. 33‏:‏19؛ إِزهد. 51‏:‏21\x*   
\b  
\m
\v 7 أَطَّاسْ قَّارنْ:  
\m ”وِي ذ أَنغْ إِ غَا إِسّشْننْ ڒْخَارْ؟“  
\m أجّْ أَذْ خَانغْ د-ثنْقَارْ  
\m ثْفَاوْثْ ن وُوذمْ نّشْ، \add أَ\add* سِيذِي!   
\m
\v 8 شكْ ثسِّيذْفذْ ڒفْرَاحثْ غَارْ وُوڒْ إِنُو،  
\m كْثَارْ \add خْ ڒفْرَاحثْ\add* إِ \add ذِينْ\add* إِدْجَانْ ذِي ڒْوقْثْ  
\m ؤُمِي ثُوغَا فيّْضنْ  
\m إِمنْذِي نْسنْ ذ بِينُو نْسنْ ن جْذِيذْ.   
\b  
\m
\v 9 ذِي ڒهْنَا أَذْ زّْڒغْ ؤُ أَذْ طّْصغْ،  
\m مِينْزِي مْغِيرْ شكْ، أَ سِيذِي،  
\m أَذْ أَيِي ثسّْزذْغذْ ذِي ڒَامَانْ. \x ◘ \xo 4:‏9 \xt لَاوِي 26‏:‏5؛ أَعَوذ. 12‏:‏10؛ 33‏:‏28؛ إِزهد. 3‏:‏6\x*   
\b  
\b  
\m  
\c 5
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. أَكْ-ذ ثمْجَا. أَزهّذْ ن ذَاوُوذْ.\add*   
\b  
\m
\v 2 \add أَ\add* سِيذِي، سڒْ إِ مِينْ غَا إِنِيغْ،  
\m فهْمثْ إِ ؤُنِيخْسسْ إِنُو.   
\m
\v 3 حكَّارْ إِ ثْمِيجَّا ن ثُوثْرَا إِنُو،  
\m \add أَ\add* أَجدْجِيذْ إِنُو ذ أَربِّي إِنُو،  
\m أَقَا إِ شكْ ؤُمِي تّْژَادْجِيغْ.   
\m
\v 4 غَارْ ثُوفُّوثْ، \add أَ\add* سِيذِي، ثسْڒِيذْ شكْ إِ ثْمِيجَّا إِنُو،  
\m غَارْ ثُوفُّوثْ نّْقڒْبغْ-د غَاركْ،  
\m ؤُشَا قِّيمغْ تّْرَاجِيغْ شكْ.   
\b  
\m
\v 5 شكْ وَارْ ثدْجِيذْ شَا ذ أَربِّي  
\m نِّي إِتّخْسنْ ثُوعفّْنَا،  
\m بْنَاذمْ أَعفَّانْ وَارْ غَاركْ إِتِّيفْ أَغِيمِي.   
\m
\v 6 إِبُوحَاڒِييّنْ وَارْ تّْغِيمِينْ تّْبدَّانْ  
\m زَّاثْ إِ ثِيطَّاوِينْ نّشْ،  
\m شكْ ثْشَارّْهذْ مَارَّا إِنِّي إِتّڭّنْ ڒْغَارْ.   
\m
\v 7 أَذْ ثْهلّْكذْ أَيْثْ ن بُو-إِخَارِّيقنْ،  
\m سِيذِي إِتّْعِيفَّا أَرْيَازْ ن إِذَامّنْ ذ ڒْغشّْ.   
\b  
\m
\v 8 مَاشَا س ڒمْغَارثْ ن ثْمخْسِيوْثْ نّشْ إِشوَّارنْ  
\m أَذْ أَذْفغْ غَارْ ثَادَّارْثْ نّشْ،  
\m أَذْ سجْذغْ غَارْ زَّاوشْثْ نّشْ ثَامقّْرَانْثْ  
\m س ثِيڭّْوُوذِي زَّايكْ.   
\m
\v 9 \add أَ\add* سِيذِي، سُويُورْ أَيِي خْ وبْرِيذْ ن ثْسڭْذَا نّشْ،  
\m ذِي طّْوعْ ن يِينِّي إِ ذ أَيِي إِحصَّارنْ،  
\m سڭّمْ أَبْرِيذْ نّشْ زَّاثْ إِ وُوذمْ إِنُو.   
\m
\v 10 مِينْزِي ذڭْ ؤُقمُّومْ نْسنْ وَارْ ذِينْ بُو ڒَامَانْ،  
\m جُّوفْ نْسنْ ذ أَخيّبْ،  
\m ثْمِيجَّا نْسنْ ذ أَنْضڒْ يَارزْمنْ،  
\m أَربُّونْ ثْخَانْشثْ س يِيڒسْ نْسنْ. \x ◘ \xo 5:‏10 \xt إِزهد. 34‏:‏17؛ 94‏:‏20؛ رُوم. 3‏:‏13\x*   
\b  
\m
\v 11 خْڒفْ زَّايْسنْ، \add أَ\add* أَربِّي،  
\m أجّْ إِ-ثنْ أَذْ وْضَانْ  
\m س ڒشْوَارْ \add ن يِيخفْ\add* نْسنْ،  
\m أَژّڒْ خَاسنْ ذِي سِّيبّثْ  
\m ن وَاطَّاسْ ن إِخطَّانْ نْسنْ،  
\m مِينْزِي نِيثْنِيغوّْغنْ خَاكْ.   
\m
\v 12 مَارَّا إِنِّي غَاركْ يَاركّْوَاڒنْ  
\m أَذْ فَارْحنْ،  
\m أَذْ سْڒِيوڒْونْ إِ ڒبْذَا.  
\m شكْ ثْفَارْيذْ خَاسنْ!  
\m أَقَا إِنِّي إِتّخْسنْ إِسمْ نّشْ  
\m أَذْ نڭْزنْ س ڒفْرَاحثْ \add إِ غَارْسنْ\add* ذَايكْ.   
\m
\v 13 مِينْزِي شكْ، \add أَ\add* سِيذِي، أَذْ ثْبَارْكذْ أَمْسڭَّاذْ،  
\m أَذْ أَسْ ثْقُووَّارذْ س ؤُحِينِّي  
\m أَمْ س ثْسدَّارْثْ ن ؤُسڒْقِي ثَامقّْرَانْثْ.   
\b  
\b  
\m  
\c 6
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. أَكْ-ذ ؤُزنْزُونْ خْ ؤُفِيڒُو وِيسّْ ثْمنْيَا. أَزهّذْ ن ذَاوُوذْ.\add*   
\b  
\m
\v 2 \add أَ\add* سِيذِي، وَارْ ذ أَيِي تّْودَّابْ  
\m ذڭْ وغْضَابْ نّشْ،  
\m وَارْ ذ أَيِي تَّاربِّي شَا ذڭْ وسْعَارْ نّشْ! \x ◘ \xo 6:‏2 \xt إِزهد. 38‏:‏2\x*   
\m
\v 3 حِينّْ خَافِي، \add أَ\add* سِيذِي،  
\m مَاغَارْ نشّْ أَقَا أَرْخُوغْ.  
\m سْڭنْفَا أَيِي، \add أَ\add* سِيذِي،  
\m مَاغَارْ إِغْسَانْ إِنُو تَّارْجِيجِينْ!   
\m
\v 4 وَاهْ، ڒعْمَارْ إِنُو يَارْجفْ أَطَّاسْ،  
\m ؤُ شكْ، \add أَ\add* سِيذِي، أَڒْ مڒْمِي؟   
\b  
\m
\v 5 ذْوڒْ-د، \add أَ\add* سِيذِي، فكّْ ڒعْمَارْ إِنُو،  
\m سنْجمْ أَيِي ذِي طّْوعْ  
\m ن ثْمخْسِيوْثْ نّشْ إِشوَّارنْ.   
\m
\v 6 مِينْزِي ذِي ڒْموْثْ وَارْ  
\m ذِينِّي بُو ڒِيذَارثْ نّشْ.  
\m وِي شكْ إِ غَا إِقَاذَانْ ذِي ڒَاخَارْثْ؟   
\m
\v 7 نشّْ ؤُحْڒغْ س إِنِيخْسِيسنْ إِنُو.  
\m دْجِيڒثْ ثكْمڒْ سُّوفّغْ قَامَا إِنُو،  
\m ؤُڒَا ذ ثَاسُّوثْ إِنُو ثطّبْطبْ قَاعْ س إِمطَّاونْ.   
\m
\v 8 ثِيطّْ إِنُو ثغْڒِي س وشْضَانْ،  
\m جّهْذْ نّسْ إِرُوحْ زِي مَارَّا  
\m إِنِّي ذ أَيِي إِحصَّارنْ.   
\b  
\m
\v 9 أَڭّْوجمْ خَافِي،  
\m مَارَّا إِنِّي إِتّڭّنْ ڒْمُوعْصِييّثْ،  
\m مِينْزِي سِيذِي إِسْڒَا إِ ثْمِيجَّا ن إِمطَّاونْ إِنُو. \x ◘ \xo 6:‏9 \xt مت. 7‏:‏23؛ 25‏:‏41؛ لك. 13‏:‏27\x*   
\m
\v 10 سِيذِي إِسْڒَا إِ ثُوثْرَا إِنُو،  
\m سِيذِي أَذْ إِقْبڒْ ثَاژَادْجِيثْ إِنُو.   
\m
\v 11 مَارَّا ڒْعذْيَانْ إِنُو أَذْ ثنْ ثڒْقفْ  
\m ڒفْضِيحثْ ذ ؤُنخْڒِيعْ،  
\m أَذْ د-ذوْڒنْ غَارْ ضفَّارْ،  
\m أَكْ-ذ ورْمَاشْ ن وَابْڒِيونْ أَذْ سضْحَانْ.   
\b  
\b  
\m  
\c 7
\m
\v 1 \add إِزْڒِي ن ذَاوُوذْ ذڭْ وَاطَّاسْ ن ثْمِيجِّيوِينْ، إِزْڒِي نِّي إِغنّجْ إِ سِيذِي ذِي سِّيبّثْ ن وَاوَاڒنْ ن كُوشْ، ونِّي إِدْجَانْ زڭْ أَيْثْ ن بِينْيَامِينْ.\add*   
\b  
\m
\v 2 \add أَ\add* سِيذِي، أَربِّي إِنُو،  
\m أَقَا غَاركْ أَركّْوَاڒغْ!  
\m سنْجمْ أَيِي زِي مَارَّا إِنِّي خَافِي إِتَّاژّْڒنْ  
\m ؤُشَا فكّْ أَيِي،   
\m
\v 3 مَاحنْذْ نتَّا وَارْ ذ أَيِي إِزعّفْ  
\m أَمْ ويْرَاذْ،  
\m أَذْ أَيِي إِمزّقْ،  
\m \add ڒَْامِي\add* وَارْ ذِينْ وِي غَا إِفكّنْ!   
\b  
\m
\v 4 \add أَ\add* سِيذِي، أَربِّي إِنُو،  
\m مَاڒَا نشّْ ڭِّيغْ مَانْ أَيَا،  
\m مَاڒَا ذِينْ شَا ن ڒْغشّْ إِڒْصقْ  
\m ذڭْ إِفَاسّنْ إِنُو، \x ◘ \xo 7:‏4 \xt أَيُوبْ 31‏:‏1‏-‏34؛ إِزهد. 15‏:‏2‏-‏5\x*   
\m
\v 5 مَاڒَا نشّْ خڒْفغْ  
\m ونِّي أَكِيذِي إِدَّارنْ ذِي ڒهْنَا س ڒْغَارْ،  
\m - \add مَاشَا س ڒْعكْسْ\add* ونِّي ذ أَيِي إِحصَّارنْ خْ وَالُو،  
\m جِّيغْ ث أَذْ يُويُورْ -   
\m
\v 6 أجّْ \add خنِّي\add* أَذْ يَاژّڒْ ڒعْذُو خْ ڒعْمَارْ إِنُو،  
\m أَذْ أَيِي إِعْذُو،  
\m أَذْ إِعْفسْ خْ ثُوذَارْثْ إِنُو ذِي ثمُّورْثْ،  
\m \add أجّْ إِ-ث\add* أَذْ إِسّزْذغْ أَعُودْجِي إِنُو ذِي ثْعجَّاجْثْ!  
\m سِيلَاهْ.   
\b  
\m
\v 7 كَّارْ-د، \add أَ\add* سِيذِي، ذڭْ وغْضَابْ نّشْ،  
\m سُوعْڒَا إِخفْ نّشْ خْ ؤُذُوقّزْ  
\m ن يِينِّي ذ أَيِي إِحصَّارنْ،  
\m فَاقْ ذِي طّْوعْ إِنُو،  
\m أَقَا ثڭِّيذْ ثُومُورذْ ڒْحقّْ.   
\m
\v 8 أَڭْرَاوْ ن ڒڭْنُوسْ أَذْ أَشْ د-إِنّضْ،  
\m \add خنِّي\add* ذْوڒْ ثِيوَا نْسنْ غَارْ سنّجْ.   
\m
\v 9 سِيذِي أَذْ إِحَاكمْ ڒڭْنُوسْ.  
\m أَغْ أَيِي ثَاسْغَارْثْ، \add أَ\add* سِيذِي،  
\m عْلَاحْسَابْ ثَاسڭْذَا إِنُو،  
\m عْلَاحْسَابْ ڒكْمَارثْ إِ ذَايِي.   
\b  
\m
\v 10 سْبدّْ ثُوعفّْنَا ن إِعفَّاننْ،  
\m سمْثنْ أَمْسڭّذْ،  
\m \add شكْ،\add* ونِّي إِقدْجْبنْ ؤُڒَاونْ ذ ثِيژَّاڒْ،  
\m \add أَ\add* أَربِّي إِسڭّْذنْ! \f ◼ \fr 7:‏10 \ft \+bd ’ثِيژَّاڒْ‘\+bd* - نِيغْ ’ثِيڭژْڒِينْ‘.\f*  \x ◘ \xo 7:‏10 \xt 1 إِم. 28‏:‏9؛ إِرْم. 11‏:‏20؛ 17‏:‏10؛ 20‏:‏12؛ أَسَا. 2‏:‏23\x*   
\m
\v 11 ثَاسدَّارْثْ إِنُو إِ ؤُسڒْقِي غَارْ أَربِّي،  
\m أَمْسنْجمْ ن إِمْسڭّْمنْ ن وُوڒَاونْ.   
\b  
\m
\v 12 أَربِّي ذ إِجّْ ن ڒْقَاضِي إِسڭّْذنْ،  
\m أَربِّي نِّي إِسخّْضنْ كُوڒْ أَسّْ. \x ◘ \xo 7:‏12 \xt أَسَا. 16‏:‏\x*   
\m
\v 13 مَاڒَا نتَّا وَارْ د-إِعْقِيبْ،  
\m أَذْ إِسّقْضعْ نتَّا سِّيفْ نّسْ،  
\m أَذْ إِمْحضْ ڒْقوْسْ نّسْ  
\m ؤُشَا أَذْ \add خَاسْ\add* إِنيّشْ.   
\m
\v 14 إِڭَّا خَاسْ ڒسْنَاحْ إِنقّنْ،  
\m أَذْ يَارّْ فْڒِيثْشَاثْ نّسْ  
\m ذ إِصفْضَاونْ يَارقّنْ.   
\b  
\m
\v 15 خْزَارْ، أَقَا وْضَانْ-د خَاسْ  
\m ڒوْجعْ ن ثَارُوثْ ن ڒْمُوعْصِييّثْ،  
\m إِكْسِي دّيْسثْ ن ثَامَارَا  
\m ؤُشَا أَذْ يَارُو إِخَارِّيقنْ. \x ◘ \xo 7:‏15 \xt أَيُوبْ 15‏:‏35؛ إِشا. 59‏:‏4\x*   
\m
\v 16 إِقَّازْ إِجّْ ن وحْفُورْ ؤُشَا إِسُّودْجغْ إِ-ث،  
\m مَاشَا ذ نتَّا \add س يِيخفْ نّسْ\add* إِ إِوْضَانْ  
\m ذڭْ \add وحْفُورْ ن\add* ثُورْصُوضِي إِ إِڭَّا. \x ◘ \xo 7:‏16 \xt أَيُوبْ 4‏:‏8؛ إِزهد. 9‏:‏16؛ 10‏:‏2؛ أَوڒن. 5‏:‏22؛ 26‏:‏27؛ أَمب. 10‏:‏8\x*   
\m
\v 17 ثَامَارَا نّسْ أَذْ د-ثذْوڒْ  
\m خْ ؤُزدْجِيفْ نّسْ،  
\m ڒخْشُونثْ نّسْ أَذْ د-ثهْوَا  
\m خْ ؤُشقُّوفْ نّسْ.   
\m
\v 18 أَذْ قَاذِيغْ سِيذِي عْلَاحْسَابْ ثَاسڭْذَا نّسْ،  
\m أَذْ زهّْذغْ إِ يِيسمْ ن سِيذِي، أَمْعُودْجِي خْ كُوڒْشِي.   
\b  
\b  
\m  
\c 8
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. س ثغْنِينْثْ ن ؤُجْتِّي، ورْيَازْ زِي جَاثْ. أَزهّذْ ن ذَاوُوذْ.\add*   
\b  
\m
\v 2 \add أَ\add* سِيذِي، أَربِّي نّغْ، مَامّشْ إِجْهذْ  
\m يِيسمْ نّشْ خْ مَارَّا ثَامُّورْثْ،  
\m \add شكْ\add* ذ ونِّي إِڭِّينْ لْعَاضَامَا نّشْ  
\m سنّجْ إِ إِجنْوَانْ. \x ◘ \xo 8:‏2 \xt أَيُوبْ 36‏:‏30\x*   
\m
\v 3 زڭْ ؤُقمُّومْ ن إِحنْجِيرنْ ذ إِسيْمَانْ،  
\m ثڭِّيذْ ذْسَاسْ إِجْهذْ  
\m زِي سِّيبّثْ ن يِينِّي شكْ إِحصَّارنْ،  
\m حِيمَا أَذْ ثْبلّْعذْ أَبْرِيذْ خْ ڒعْذُو  
\m ؤُ خْ ونِّي يَارزُّونْ أَذْ إِخْڒفْ. \x ◘ \xo 8:‏3 \xt مت. 21‏:‏16\x*   
\b  
\m
\v 4 مَاڒَا ثْوَاڒِيغْ أَجنَّا،  
\m ڒْْخذْمثْ ن إِضوْضَانْ نّشْ،  
\m ثَازِيرِي ذ يثْرَانْ، إِنِّي ثڭِّيذْ،   
\m
\v 5 مِينْ إِعْنَا \add خنِّي\add* بْنَاذمْ،  
\m أَقَا شكْ ثْخَارّْصذْ ذَايسْ،  
\m مِّيسْ ن بْنَاذمْ،  
\m أَقَا شكْ ثْخزَّارذْ غَارسْ؟ \x ◘ \xo 8:‏5 \xt أَيُوبْ 7‏:‏17؛ إِزهد. 144‏:‏3؛ عبر. 2‏:‏6\x*   
\m
\v 6 شكْ ثَارِّيذْ ث مْغِيرْ  
\m شْوَايْثْ وَاهَا قلّْ إِ أَربِّي،  
\m ثوْشِيذْ أَسْ تَّاجْ ن ؤُعُودْجِي ذ ڒْعزّْ.   
\b  
\m
\v 7 شكْ ثَارِّيذْ ث أَذْ إِحْكمْ  
\m خْ ثْمڭَّا ن إِفَاسّنْ نّشْ،  
\m ثسَّارْسذْ مَارَّا سْوَادَّايْ إِ إِضَارنْ نّسْ: \x ◘ \xo 8:‏7 \xt 1 كُور. 15‏:‏27؛ أَفا. 1‏:‏22\x*   
\m
\v 8 ؤُدْجِي ذ إِفُونَاسنْ، مَارَّا إِنَا،  
\m ؤُڒَا ذ ڒْمَاڒْ ن ييَّارْ،   
\m
\v 9 إِجْضَاضْ ن ؤُجنَّا ذ إِسڒْمَانْ ن ڒبْحَارْ،  
\m \add مَارَّا\add* مِينْ إِتّْشُوقَانْ إِبْرِيذنْ ن ڒبْحُورْ.   
\b  
\m
\v 10 \add أَ\add* سِيذِي، سِيذِيثْنغْ،  
\m مَامّشْ إِجْهذْ يِيسمْ نّشْ  
\m ذِي مَارَّا ثَامُّورْثْ!   
\b  
\b  
\m  
\c 9
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. س ثغْنِينْثْ ن ’ڒْْموْثْ ن مِّيسْ‘. أَزهّذْ ن ذَاوُوذْ.\add*   
\b  
\m
\v 2 \bd أَلِيفْ.\bd* أَذْ قَاذِيغْ سِيذِي س مَارَّا ؤُڒْ إِنُو،  
\m أَذْ بَارّْحغْ مَارَّا لْمُوعْجِيزَاثْ نّشْ.   
\m
\v 3 أَذْ زَّايكْ فَارْحغْ أَذْ زَّايكْ سْڒِيوْڒِيوغْ.  
\m نشّْ أَذْ زهّْذغْ إِ يِيسمْ نّشْ،  
\m \add أَ\add* شكْ، أَمْعُودْجِي خْ كُوڒْشِي!   
\b  
\m
\v 4 \bd بِيثْ.\bd* ؤُمِي ڒْعذْيَانْ إِنُو ذوْڒنْ  
\m غَارْ ضفَّارْ،  
\m وْضَانْ ؤُغڒْينْ زَّاثْ إِ وُوذمْ نّشْ.   
\m
\v 5 مَاغَارْ شكْ ثْونِّيذْ أَيِي ثَاسْغَارْثْ إِنُو  
\m ؤُ ثْبلّْعذْ دّعْوثْ إِنُو،  
\m ثقِّيمذْ خْ ڒْعَارْشْ،  
\m \add أَ شكْ،\add* ذ ڒْقَاضِي أَمْسڭّذْ.   
\b  
\m
\v 6 \bd ڭِيملْ.\bd* شكْ ثْوبّْخذْ ڒڭْنُوسْ،  
\m ثْهلّْكذْ أَعفَّانْ،  
\m ثمْحِيذْ إِسمْ نْسنْ إِ ڒبْذَا قَاعْ.   
\m
\v 7 \bd هِي.\bd* ڒعْذُو، أَقَا نِيثْنِي تّْوَاقْضَانْ،  
\m أَقَا أَثنْ ذ ڒْخِيرْبَاثْ إِ ڒبْذَا.  
\m ثْغضْڒذْ إِغْرِيمنْ نْسنْ،  
\m ڒِْيذَارثْ نْسنْ ثفْنَا.   
\b  
\m
\v 8 \bd وَاوْ.\bd* سِيذِي إِتّْغِيمَا إِ ڒبْذَا،  
\m أَقَا إِسّْبدّْ ڒْعَارْشْ نّسْ إِ ڒحْكَامْ.   
\m
\v 9 نتَّا أَذْ إِشَارّعْ دُّونشْثْ س ثْسڭْذَا،  
\m أَذْ إِحْكمْ شُّوعُوبْ س ڒْحقّْ. \x ◘ \xo 9:‏9 \xt إِزهد. 96‏:‏13؛ 98‏:‏9\x*   
\b  
\m
\v 10 سِيذِي ذ لْبُورْجْ يُوعْڒَانْ إِ ونِّي إِحْصَارنْ،  
\m إِجّْ ن لْبُورْجْ يُوعْڒَانْ ذِي ڒْوقْثْ ن ڒحْصَارثْ. \x ◘ \xo 9:‏10 \xt إِزهد. 37‏:‏39؛ 46‏:‏2؛ 91‏:‏2\x*   
\m
\v 11 إِنِّي إِسّْننْ إِسمْ نّشْ، أَذْ خَاكْ تّشْڒنْ،  
\m مَاغَارْ إِنِّي خَاكْ يَارزُّونْ،  
\m وَارْ ذَايْسنْ ثْسمّْحذْ، \add أَ\add* سِيذِي.   
\b  
\m
\v 12 \bd زَايِينْ.\bd* زهّْذمْ إِ سِيذِي،  
\m ونِّي إِزدّْغنْ ذِي صِيهْيُونْ،  
\m بَارّْحمْ س ثْمڭَّا نّسْ جَارْ ڒڭْنُوسْ.   
\m
\v 13 مِينْزِي نتَّا يَارزُّو  
\m خْ ؤُسِيزّڒْ ن إِذَامّنْ،  
\m إِتّْخَارَّاصْ ذَايْسنْ.  
\m وَارْ إِتُّو شَا إِغُويَّانْ  
\m ن يِينِّي إِتّْوَاحصَّارنْ.   
\b  
\m
\v 14 \bd خِيثْ.\bd* حِينّْ خَافِي، \add أَ\add* سِيذِي،  
\m خْزَارْ غَارْ ڒغْبنْ إِنُو  
\m إِ د-يُوسِينْ زڭْ إِنِّي ذ أَيِي إِشَارّْهنْ،  
\m شكْ ذ ونِّي ذ أَيِي غَا إِسّْڭعّْذنْ  
\m زِي ثوُّورَا ن ڒْموْثْ،   
\m
\v 15 حِيمَا أَذْ بَارّْحغْ س مَارَّا شَّانْ نّشْ،  
\m ذِي ثوُّورَا ن يدْجِيسْ ن صِيهْيُونْ.  
\m نشّْ فَارّْحغْ خْ ؤُسنْجمْ نّشْ.   
\b  
\m
\v 16 \bd ثِيث.\bd* ڒڭْنُوسْ وْضَانْ ذڭْ \add وحْفُورْ ن\add* ثُورْصُوضِي  
\m إِ ڭِّينْ نِيثْنِي \add س يِيخفْ نْسنْ\add*،  
\m إِضَارنْ نْسنْ تّْوَاشدّنْ ذِي ثْرَاشَّا  
\m نِّي سّْنُوفَّارنْ نِيثْنِي \add س يِيخفْ نْسنْ\add*،. \x ◘ \xo 9:‏16 \xt إِزهد. 7‏:‏16\x*   
\m
\v 17 سِيذِي إِڭَّا إِخفْ نّسْ أَذْ ث سّْننْ،  
\m نتَّا يُوغَا ثَاسْغَارْثْ.  
\m أَعفَّانْ إِنُّوغْ ذِي ثْمڭَّا ن إِفَاسّنْ نّسْ.  
\m أجّْ إِفِيڒَانْ أَذْ دّنْذْننْ. سِيلَاهْ.   
\b  
\m
\v 18 \bd يُوذْ.\bd* إِعفَّاننْ أَذْ د-ذوْڒنْ غَارْ ڒَاخَارْثْ،  
\m مَارَّا ڒڭْنُوسْ نِّي إِتُّونْ أَربِّي.   
\m
\v 19 مَاشَا أَمزْڒُوضْ وَارْ إِتّْوَاتُّو إِ ڒبْذَا،  
\m وَارْ إِتّْوَاقطّعْ ڒَايَاسْ  
\m ن يِينِّي إِتّْوَاحْصَارنْ إِ ڒبْذَا.   
\b  
\m
\v 20 \bd قُوفْ.\bd* كَّارْ، \add أَ\add* سِيذِي،  
\m حِيمَا وَارْ إِذِّيكّْوِيڒْ بْنَاذمْ إِجْهذْ كْثَارْ.  
\m أجّْ ڒڭْنُوسْ أَذْ تّْوَاشَارّْعنْ  
\m زَّاثْ إِ وُوذمْ نّشْ.   
\m
\v 21 سِيڭّْوذْ إِ-ثنْ، \add أَ\add* سِيذِي،  
\m أجّْ ڒڭْنُوسْ أَذْ سّْننْ أَقَا أَثنْ ذ إِوْذَانْ! سِيلَاهْ.   
\b  
\b  
\m  
\c 10
\m
\v 1 \add مِينْ إِقِّيمنْ ن ؤُزهّذْ 9\add*  
\m \bd لَامِيذْ.\bd* \add أَ\add* سِيذِي،  
\m مَايمِّي ثقِّيمذْ ثِيڭّْوجذْ \add أَمُّو\add*؟  
\m مَايمِّي ثسّْنُوفَّارذْ إِخفْ نّشْ  
\m ذِي ڒْوقْثْ ن ڒحْصَارثْ؟   
\m
\v 2 س نّْفَاخثْ إِضفَّارْ ؤُعفَّانْ ڒْمسْكِينْ.  
\m أَذْ تّْوَاطّْفنْ س ثْمعْمَاتْشْ إِ ذِي تّْخَارّْصنْ. \x ◘ \xo 10:‏2 \xt إِزهد. 7‏:‏16؛ 9‏:‏16؛ أَوڒن. 5‏:‏22\x*   
\b  
\m
\v 3 مَاغَارْ أَعفَّانْ إِسّْعُودْجْ إِخفْ نّسْ  
\m غَارْ مژْرِي ن ڒعْمَارْ نّسْ،  
\m إِتّْبَاركْ أَضمَّاعْ، إِتّْشقَّافْ ذِي سِيذِي.   
\m
\v 4 أَعفَّانْ أَمْ ونِّي إِسّْڭعَّاذنْ  
\m ثِينْزَارْثْ نّسْ غَارْ ؤُجنَّا،  
\m وَارْ إِتّْبقّشْ، \add إِقَّارْ\add*.  
\m ”وَارْ ذِينْ أَربِّي“،  
\m مَانْ أَيَا ذ مَارَّا مِينْ ذِي إِزمَّارْ أَذْ إِتّْخَارّصْ. \x ◘ \xo 10:‏4 \xt إِزهد. 14‏:‏1؛ 53‏:‏2\x*   
\b  
\m
\v 5 مَارَّا إِبْرِيذنْ نّسْ  
\m تّفّْغنْ أَسْ مْلِيحْ كُوڒْ ثْوَاڒَا.  
\m ڒهْكَامَاثْ نّشْ تُّوعْڒَانْثْ خَاسْ.  
\m إِتّْزَاوَارْ مَارَّا إِنِّي ث إِحصَّارنْ.   
\b  
\m
\v 6 نتَّا إِقَّارْ ذڭْ وُوڒْ نّسْ: ”وَارْ تّنْهزِّيغْ،  
\m زِي جِّيڒْ أَڒْ جِّيڒْ وَارْ ذ أَيِي إِڒقّفْ  
\m ؤُڒَا ذ إِجّْ ن ڒْغَارْ.“   
\m
\v 7 أَقمُّومْ نّسْ إِشُّورْ س نّعْڒثْ  
\m ذ إِخَارِّيقنْ ذ دّدْجْ.  
\m سَاذُو يِيڒسْ نّسْ  
\m \add أَقَا ذِينْ\add* ثَامَارَا ذ ڒْمُوعْصِييّثْ. \x ◘ \xo 10:‏7 \xt رُوم. 3‏:‏14\x*   
\b  
\m
\v 8 نتَّا إِتّْغِيمَا غَارْ وشْبَارْ ذِي ذْشُورَاثْ،  
\m ذڭْ إِمُوشَانْ إِنُّوفَّارنْ  
\m إِنقّْ إِنِّي وَارْ إِڭِّينْ س شَا.  
\m ثِيطَّاوِينْ نّسْ مّنْضَارنْثْ خْ ڒْمسْكِينْ.   
\b  
\m
\v 9 إِڒْبثْ ذڭْ ومْشَانْ إِنُّوفَارنْ  
\m أَمْ ويْرَاذْ ذڭْ ؤُذُورِّي ن ؤُعِيشُّو نّسْ.  
\m نتَّا إِتّْحكَّارْ حِيمَا أَذْ يَاشَارْ ڒْمسْكِينْ.  
\m إِتَّاشَارْ ڒْمسْكِينْ ؤُمِي ث إِجبّذْ  
\m ذِي ثْرَاشَّا نّسْ.   
\b  
\m
\v 10 نتَّا إِهكّْوَا-د غَارْ وَادَّايْ،  
\m إِتَّاضَارْ، \add أَقَا\add* ڒْمسْكِينْ إِوطَّا  
\m جَارْ \add وَاشَّارنْ\add* نّسْ إِجهْذنْ.   
\m
\v 11 إِقَّارْ ذڭْ وُوڒْ نّسْ: ”أَربِّي إِتُّو،  
\m نتَّا إِسّْنُوفَّارْ ؤُذمْ نّسْ،  
\m عمَّارْصْ أَذْ ث إِژَارْ.“ \x ◘ \xo 10:‏11 \xt إِزهد. 94‏:‏7\x*   
\b  
\m
\v 12 \bd قُوفْ.\bd* كَّارْ، \add أَ\add* سِيذِي،  
\m أَربِّي، سْڭعّذْ أَفُوسْ نّشْ،  
\m وَارْ تّتُّو ڒْمُوسَاكِينْ.   
\m
\v 13 مَايمِّي إِتّْشقَّافْ ؤُعفَّانْ ذِي أَربِّي،  
\m \add مَايمِّي\add* إِقَّارْ ذڭْ وُوڒْ نّسْ:  
\m ”شكْ وَارْ ثتّْبقَّاشذْ!“؟   
\b  
\m
\v 14 \bd رِيخْ.\bd* أَقَا شكْ ثژْرِيذْ،  
\m مِينْزِي \bd شكْ\bd* ثتّْوَاڒِيذْ ثَامَارَا ذ وشْضَانْ،  
\m مَاحنْذْ أَذْ \add ثنْ\add* ثسَّارْسذْ ذڭْ ؤُفُوسْ نّشْ.  
\m ڒْْمسْكِينْ إِتَّارّْ-د غَاركْ س ؤُزدْجِيفْ.  
\m \bd شكْ\bd* ذ أَمْعَاونْ ن ؤُيُوجِيڒْ. \f ◼ \fr 10:‏14 \ft \+bd ’أَيُوجِيڒْ‘\+bd* - نِيغْ ’أَڭُوڭِيلْ‘.\f*   
\b  
\m
\v 15 \bd شِينْ.\bd* أَرْژْ أَغِيڒْ ن ؤُعفَّانْ،  
\m خْڒفْ ڒْغَارْ زڭْ ونِّي إِتّڭّنْ ثُوعفّْنَا،  
\m \add أَڒْ\add* وَارْ ثتِّيفذْ وَالُو \add عَاذْ\add*.   
\m
\v 16 سِيذِي ذ أَجدْجِيذْ إِ ڒبْذَا قَاعْ.  
\m تّْوَاثحَّانْ ڒڭْنُوسْ زِي ثمُّورْثْ نّسْ. \x ◘ \xo 10:‏16 \xt إِزهد. 29‏:‏10؛ 145‏:‏13، 146‏:‏10؛ إِرْم. 10‏:‏10؛ إِڭجذ. 5‏:‏19؛ دَان. 3‏:‏33؛ 6‏:‏27؛ 1 تِيم. 1‏:‏17\x*   
\b  
\m
\v 17 \bd ثَافْ.\bd* \add أَ\add* سِيذِي، شكْ ثسْڒِيذْ إِ مژْرِي ن إِمْوَاضْعنْ،  
\m أَذْ ثسّْجهْذذْ ؤُڒَاونْ نْسنْ،  
\m أَذْ غَارْسنْ ثْميّْڒذْ أَمزُّوغْ نّشْ،   
\m
\v 18 حِيمَا أَذْ ثَاغذْ ثَاسْغَارْثْ إِ ؤُيُوجِيڒْ  
\m ؤُ إِ ونِّي إِتّْوَاحصَّارنْ،  
\m مَاحنْذْ ؤُڒَا ذ إِجّْ ن بْنَاذمْ خْ ثمُّورْثْ  
\m وَارْ إِتّْغِيمِي إِسَّاڭّْوَاذْ \add عَاذْ ؤُڒَا ذ إِجّْ\add*.   
\b  
\b  
\m  
\c 11
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. ن ذَاوُوذْ.\add*  
\b  
\m غَارْ سِيذِي أَركّْوَاڒغْ.  
\m مَامّشْ ثقَّارمْ إِ ڒعْمَارْ إِنُو:  
\m ”ضْوُو غَارْ وذْرَارْ نْومْ، \add أَ\add* إِجْضَاضْ!“ \f ◼ \fr 11:‏1 \ft \+bd أَفسَّارْ\+bd* - أَذْ ثَاغْ خْسنْ أَذْ إِنِينْ أَوَاڒنْ-أَ أَقَا إِتّْخصَّا إِ ذَاوُوذْ أَذْ يَارْوڒْ غَارْ إِذُورَارْ أَمْ ث إِڭَّا ذڭْ وُوسَّانْ ن شَاوُولْ (خْزَارْ 1 صم. 26‏:20، 23‏:14).\f*   
\m
\v 2 مَاغَارْ خْزَارْ،  
\m إِعفَّاننْ أَقَا محّْضنْ ڒْقوْسْ،  
\m سّْرُوسَانْ فْڒِيثْشَاثْ نْسنْ غَارْ ؤُفِيڒُو،  
\m حِيمَا أَذْ وْثنْ ذِي ثَادْجسْثْ  
\m ذڭْ إِنِّي ؤُمِي إِسڭّذْ وُوڒْ.   
\m
\v 3 وَاهْ، ذْسُوسَا ن دُّونشْثْ تّْوَاردّْدْجنْ!  
\m مِينْ \add إِزمَّارْ خنِّي\add* أَذْ يڭّْ ؤُمْسڭّذْ؟   
\b  
\m
\v 4 سِيذِي \add إِزدّغْ\add*  
\m ذِي زَّاوشْثْ نّسْ ثَامقّْرَانْثْ إِقدّْسنْ،  
\m ڒْْعَارْشْ ن سِيذِي أَقَا-ث ذڭْ إِجنْوَانْ.  
\m ثِيطَّاوِينْ نّسْ تّْوَاڒَانْثْ،  
\m ڒْْخزْرَاثْ نّسْ أَرزُّونْثْ ذِي ثَارْوَا ن بْنَاذمْ.   
\m
\v 5 سِيذِي إِتّْبقّشْ أَمْسڭّذْ،  
\m \add مَاشَا\add* ڒعْمَارْ نّسْ إِتّْعِيفَّا أَعفَّانْ  
\m ذ ونِّي إِتّخْسنْ لْعُونْفْ.   
\m
\v 6 نتَّا أَذْ إِوّثْ إِعفَّاننْ  
\m س إِجّْ ن ونْژَارْ ن ڒفْخُوخْ،  
\m ثِيمسِّي ذ ڒشْبَارِييّثْ  
\m ذ ثْحَارْيَاضْثْ ثَامقّْرَانْثْ  
\m \add أَذْ إِڒِينْثْ\add* ذ ثَاسْغَارْثْ ن ڒْكَاسْ نْسنْ.   
\b  
\m
\v 7 مِينْزِي سِيذِي ذ أَمْسڭّذْ،  
\m إِتّخْسْ ثِيمڭَّا إِسڭّْذنْ.  
\m إِنِّي إِڭُّورنْ نِيشَانْ  
\m أَذْ ژَترنْ ؤُذمْ نّسْ.   
\b  
\b  
\m  
\c 12
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. خْ ؤُفِيڒُو وِيسّْ ثْمنْيَا. أَزهّذْ ن ذَاوُوذْ.\add*   
\b  
\m
\v 2 سنْجمْ، \add أَ\add* سِيذِي،  
\m مِينْزِي أَمدُّوكّڒْ أَمْثِيقِّي  
\m وَارْ إِقِّيمْ عَاذْ،  
\m مَاغَارْ وَارْ ذِينْ \add عَاذْ\add* إِمْثِيقَّانْ  
\m جَارْ ثَارْوَا ن بْنَاذمْ. \x ◘ \xo 12:‏2 \xt إِشا. 57‏:‏1\x*   
\m
\v 3 نِيثْنِي سَّاوَاڒنْ جَارْ أَسنْ س إِخَارِّيقنْ،  
\m س إِينْشِيشنْ شُّورنْ  
\m س وَاوَاڒنْ إِمِيزِيضنْ،  
\m أَقَا سَّاوَاڒنْ س ثْنَاينْ ن إِغمْبَابْ. \f ◼ \fr 12:‏3 \ft \+bd ’س ثْنَاينْ ن إِغمْبَابْ‘\+bd* - س ثِيعْبْرَانِيثْ ’س وُوڒْ ذ وُوڒْ‘.\f*   
\b  
\m
\v 4 أجّْ سِيذِي أَذْ إِقْضعْ  
\m مَارَّا إِينْشِيشنْ شُّورنْ  
\m س وَاوَاڒنْ إِمِيزِيضنْ،  
\m ؤُڒَا ذ إِڒسْ س وَاوَاڒنْ ن ؤُكبَّارْ،   
\m
\v 5 إِنِّي إِقَّارنْ:  
\m ”س يِيڒسْ نّغْ  
\m أَذْ غَارْنغْ يِيڒِي ؤُقَارُّو إِمْغَارْ،  
\m إِينْشِيشنْ أَقَا أَثنْ نّغْ!  
\m مَانْ ونْ \add إِدْجَانْ\add* خَانغْ ذ سِيذِي؟“   
\b  
\m
\v 6 ”ذِي سِّيبّثْ ن وَاردّدْجْ ن ڒْمُوسَاكِينْ،  
\m ؤُڒَا ذِي سِّيبّثْ ن إِغُويَّانْ ن إِمزْڒَاضْ  
\m أَذْ كَّارغْ ڒخُّو نشّْ“، إِنَّا سِيذِي،  
\m ”ونِّي خْ ثُوغَا إِدُّوقزْ نتَّا،  
\m نشّْ أَذْ ث أَوْيغْ ذِي ڒَامَانْ.“   
\m
\v 7 ثِيوَاڒِينْ ن سِيذِي أَقَا أَثنْثْ ذ ثِيوَاڒِينْ صْفَانْثْ،  
\m تّْوَاسِّيزْذْڭنْثْ \add أَمْ\add* نُّوقَارْثْ  
\m ذڭْ إِجّْ ن ڒْكَاسْ إِ ؤُفسْيِي ذڭْ ؤُشَاڒْ،  
\m تّْوَاصفَّانْثْ سبْعَا ن ثْوَاڒَاوِينْ. \f ◼ \fr 12:‏7 \ft \+bd ’سبْعَا ن ثْوَاڒَاوِينْ‘\+bd* - إِخْسْ أَذْ يِينِي أَطَّاسْ ن ثْوَاڒَاوِينْ، وَارْ إِزمَّارْ بْنَاذمْ أَذْ ثنْثْ إِحْسبْ.\f*  \x ◘ \xo 12:‏7 \xt 2 صم. 22‏:‏31؛ إِزهد. 18‏:‏31؛ 119‏:‏140؛ أَوڒن. 30‏:‏5\x*   
\b  
\m
\v 8 \bd شكْ\bd*، \add أَ\add* سِيذِي، أَذْ ثنْ ثحْضِيذْ،  
\m أَذْ أَنغْ ثسَّارذْ زِي جِّيڒْ-أَ،  
\m إِ ڒبْذَا قَاعْ.   
\m
\v 9 إِعفَّاننْ ڭُّورنْ تّنّْضنْ مَانِي مَا  
\m خْمِي غَا إِكَّارْ دّدْجْ جَارْ ثَارْوَا ن بْنَاذمْ.   
\b  
\b  
\m  
\c 13
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. أَزهّذْ ن ذَاوُوذْ.\add*   
\b  
\m
\v 2 مشْحَاڒْ عَاذْ، \add أَ\add* سِيذِي، إِ ذ أَيِي غَا ثتُّوذْ؟  
\m أَڒْ مشْحَاڒْ عَاذْ  
\m إِ خَافِي إِ غَا ثسّْنُوفَّارذْ ؤُذمْ نّشْ؟   
\m
\v 3 مشْهَاڒْ إِ إِقِّيمنْ أَذْ ڭّغْ عَاذْ  
\m ڒهْمُومْ ذِي ڒعْمَارْ إِنُو،  
\m أَشْضَانْ ذڭْ وُوڒْ إِنُو مْكُوڒْ أَسّْ؟  
\m أَڒْ مڒْمِي غَا إِسّْعُودْجْ ڒعْذُو إِنُو  
\m إِخفْ نّسْ خَافِي؟   
\b  
\m
\v 4 خْزَارْ-د، أَرّْ-د خَافِي،  
\m \add أَ\add* سِيذِي، أَربِّي إِنُو!  
\m أڭّْ ثْفَاوْثْ غَارْ ثِيطَّاوِينْ إِنُو،  
\m حِيمَا وَارْ تّطّْصغْ إِضصْ ن ڒْموْثْ،   
\m
\v 5 حِيمَا ڒعْذُو إِنُو وَارْ إِقَّارْ:  
\m ”نشّْغلّْبغْ خَاسْ!“،  
\m \add حِيمَا\add* ونِّي ذ أَيِي إِحصَّارنْ  
\m وَارْ إِفَارّحْ مَاڒَا فَارْغغْ.   
\b  
\m
\v 6 نشّْ تّشْڒغْ  
\m خْ ثْمخْسِيوْثْ نّشْ إِشوَّارنْ.  
\m ؤُڒْ إِنُو أَذْ إِفَارْحْ خْ ؤُسنْجمْ نّشْ.  
\m نشّْ أَذْغنّْجغْ إِ سِيذِي،  
\m مَاغَارْ نتَّا إِڭَّا ذَايِي ڒْخِيرْ.   
\b  
\b  
\m  
\c 14
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. ن ذَاوُوذْ.\add*  
\b  
\m أَبُوهَاڒِي إِنَّا ذڭْ وُوڒْ نّسْ:  
\m ”وَارْ ذِينْ بُو أَربِّي!“  
\m نِيثْنِي تَّاردّْدْجنْ،  
\m تّڭّنْ ثِيمسْڒَايِينْ إِضخْسنْ،  
\m وَارْ ذِينْ ؤُڒَا ذ إِجّْ إِتّڭّْ مِينْ إِشْنَانْ. \x ◘ \xo 14:‏1 \xt إِزهد. 10‏:‏4؛ 53‏:‏2؛ رُوم. 3‏:‏10\x*   
\b  
\m
\v 2 سِيذِي إِخزَّارْ-د زڭْ ؤُجنَّا  
\m غَارْ ثَارْوَا ن بْنَاذمْ،  
\m حِيمَا أَذْ إِژَارْ، مَا ذِينْ حذْ ذَايسْ ڒفْهَامثْ،  
\m إِجّْ ونِّي يَارزُّونْ أَربِّي.   
\b  
\m
\v 3 مَارَّا فّْغنْ زڭْ وبْرِيذْ،  
\m \add أَقَا أَثنْ جْمِيعْ\add* ذوْڒنْ ذ إِعفَّاننْ،  
\m وَارْ ذِينْ ؤُڒَا ذ إِجّْ إِتّڭّْ ڒْخَارْ،  
\m ؤُڒَا ذ إِجّْ.   
\b  
\m
\v 4 مَارَّا إِنِّي إِتّڭّنْ ڒْمُوعْصِييّثْ  
\m مَا وَارْ غَارْسنْ بُو ثُوسّْنَا،  
\m إِنِّي إِتّتّنْ ڒْڭنْسْ إِنُو  
\m أَخْمِي تّتّنْ أَغْرُومْ؟  
\m نِيثْنِي وَارْ تّْڒَاغَانْ خْ سِيذِي.   
\b  
\m
\v 5 أَقَا ثوْضَا-د خَاسنْ ذِينْ  
\m إِڭّْوُوذِي ثمْغَارْ،  
\m مَاغَارْ أَربِّي  
\m أَقَا-ث أَكْ-ذ جِّيڒْ نْ إِمْسڭَّاذنْ.   
\b  
\m
\v 6 كنِّيوْ ثْنفْضمْ أَرَّايْ ن ڒْمُوسَاكِينْ،  
\m مَاشَا سِيذِي ذ أَمْشَانْ نّسْ ن ثَاروْڒَا.   
\b  
\m
\v 7 مَانْ ونْ زِي صِيهْيُونْ  
\m إِ غَا يِيوْينْ أَسنْجمْ ن إِسْرَائِيل!  
\m خْمِي د غَا يَارّْ سِيذِي  
\m إِمحْبَاسْ ن ڒْڭنْسْ نّسْ،  
\m أَذْ يَارْشقْ يَاعْقُوبْ،  
\m أَذْ إِفَارْحْ إِسْرَائِيل.   
\b  
\b  
\m  
\c 15
\m
\v 1 \add أَزهّذْ ن ذَاوُوذْ.\add*  
\b  
\m \add أَ\add* سِيذِي، مَانْ ونْ إِ غَا إِقِّيمنْ  
\m ذڭْ ؤُقِيضُونْ نّشْ؟  
\m مَانْ ونْ إِ غَا إِزذْغنْ  
\m خْ وذْرَارْ نّشْ إِقدّْسنْ؟ \x ◘ \xo 15:‏1 \xt إِزهد. 7‏:‏4‏-‏6؛ أَيُوبْ 31‏:‏1‏-‏34.\x*   
\m
\v 2 ونِّي إِڭُّورنْ  
\m ذِي ڒكْمَاڒثْ ن ثُوذَارْثْ نّسْ  
\m ونِّي إِتّڭّنْ ثَاسڭْذَا،  
\m \add ونِّي\add* إِسَّاوَاڒنْ ثِيذتّْ ذڭْ وُوڒْ نّسْ. \x ◘ \xo 15:‏2 \xt إِزهد. 24‏:‏4؛ إِشا. 33‏:‏15‏-‏17\x*   
\b  
\m
\v 3 ونِّي وَارْ إِتّْشقَّافنْ س يِيڒسْ نّسْ،  
\m \add ونِّي\add* وَارْ إِتّڭّنْ ڒْغَارْ إِ إِمْعَاشَارنْ نّسْ،  
\m ؤُ وَارْ إِتّْزَاوَارْ أَجَّارْ نّسْ.   
\m
\v 4 ونِّي إِمّنْضَارنْ \add زِي أَربِّي\add*  
\m أَقَا إِتّْوَاسّحْقَارْ ذِي ثِيطَّاوِينْ نّسْ،  
\m \add مَاشَا\add* إِنِّي إِتّڭّْوذنْ سِيذِي،  
\m إِتّْوقَّارْ إِ-ثنْ.  
\m مَاڒَا إِجُّودْجْ نتَّا إِ ثْخسَّارْثْ نّسْ،  
\m وَارْ \add ث\add* إِتّْبذِّيڒْ.   
\m
\v 5 ونِّي وَارْ إِتِّيشنْ  
\m \add ثَامنْيَاثْ ن\add* نُّوقَارْثْ نّسْ س أَرِّيبَا،  
\m ونِّي وَارْ إِتّطّْفنْ أَرّشْوثْ  
\m ضِيدّْ ن يِينِّي وَارْ إِڭِّينْ س شَا.  
\m ونِّي إِتّڭّنْ مَانْ أَيَا،  
\m وَارْ إِفَارّغْ إِ ڒبْذَا.   
\b  
\b  
\m  
\c 16
\m
\v 1 \add ثِيرَا إِنقْشنْ. ن ذَاوُوذْ.\add*  
\b  
\m حْضَا خَافِي، \add أَ\add* أَربِّي،  
\m مَاغَارْ نشّْ أَركّْوَاڒغْ غَاركْ.   
\m
\v 2 \add ڒعْمَارْ إِنُو\add* ثنَّا إِ سِيذِي:  
\m ”شكْ ذ سِيذِي إِنُو،  
\m \add شكْ\add* ذ ڒْخَارْ إِنُو، وَارْ ذِينْ مِينْ خَاكْ يُوعْڒَانْ!“ \x ◘ \xo 16:‏2 \xt أَيُوبْ 22‏:‏2؛ 35‏:‏7؛ رُوم. 11‏:‏35\x*   
\m
\v 3 خْ إِمْقدَّاسنْ إِ \add إِزدّْغنْ\add* خْ ثمُّورْثْ،  
\m نِيثْنِي ذ أَيْثْ ن جّهْذْ  
\m زِي \add سِّيبّثْ ن\add* مَارَّا أَرْضَا إِنُو إِ ذَايْسنْ \add إِدْجَانْ\add*.   
\b  
\m
\v 4 ثَامَارَا ن يِينِّي إِضفَّارنْ \add أَمُّو\add* ذغْيَا  
\m إِجّْ ن \add أَربِّي\add* نّغْنِي أَذْ تّْوَاكْثَارنْثْ.  
\m نشّْ وَارْ تّْفَارِّيغغْ ثَاوْهِيبْثْ نْسنْ  
\m ن ؤُسيّبْ ن إِذَامّنْ،  
\m وَارْ تِّيذَارغْ إِسْمَاونْ نْسنْ  
\m خْ إِينْشِيشنْ إِنُو.   
\m
\v 5 سِيذِي ذ ثَاسْغَارْثْ إِنُو ذ ڒْكَاسْ إِنُو.  
\m \bd شكْ\bd* ثطّْفذْ ثَاقدُّوحْثْ إِنُو ذڭْ ؤُفُوسْ نّشْ. \x ◘ \xo 16:‏5 \xt إِڭجذ. 3‏:‏24\x*   
\b  
\m
\v 6 إِفِيڒَانْ \add ن ڒعْبَارْ\add* كَّارنْ أَيِي-د  
\m ذڭْ إِمُوشَانْ إِصبْحنْ،  
\m وَاهْ، ثَاسْغَارْثْ \add إِنُو\add* \add أَقَا\add* ثُوسَا-د خَافِي مْلِيحْ.   
\m
\v 7 أَذْ بَارْكغْ سِيذِي، ونِّي ذ أَيِي إِنصْحنْ.  
\m ؤُڒَا س دْجِيڒثْ سّْڒمْذنْثْ أَيِي ثِيژَّاڒْ إِنُو. \f ◼ \fr 16:‏7 \ft \+bd ’ثِيژَّاڒْ‘\+bd* - نِيغْ ’ثِيڭژْڒِينْ‘.\f*   
\m
\v 8 تّڭّغْ سِيذِي ڒبْذَا جَارْ ثِيطَّاوِينْ إِنُو.  
\m ؤُمِي نتَّا \add إِدْجَا\add* خْ ؤُفُوسْ أَفُوسِي إِنُو،  
\m نشّْ وَارْ تّفْشِيرغْ. \x ◘ \xo 16:‏8 \xt ڒخ. 2‏:‏25\x*   
\b  
\m
\v 9 س ؤُيَا إِفَارّحْ ؤُڒْ إِنُو،  
\m إِتَّارْشِيقْ ڒعْمَارْ إِنُو.  
\m وَاهْ، \add ؤُڒَا ذ\add* دَّاثْ إِنُو أَذْ إِدَّارْ س ڒَامَانْ.   
\m
\v 10 مَاغَارْ شكْ وَارْ ثْسمّْحذْ شَا  
\m ذِي ڒعْمَارْ إِنُو ذِي ڒَاخَارْثْ،  
\m وَارْ ثتَّارِّيذْ أَمْثِيقِّي نّشْ أَذْ إِكِيشُّو. \x ◘ \xo 16:‏10 \xt إِزهد. 49‏:‏10؛ ڒخ. 2‏:‏31؛ 13‏:‏35\x*   
\m
\v 11 شكْ أَذْ أَيِي ثسّشْنذْ أَبْرِيذْ ن ثُوذَارْثْ،  
\m ثْيَاوَانْثْ زِي ڒفْرَاحثْ  
\m أَقَا-ث زَّاثْ إِ وُوذمْ نّشْ،  
\m نِّيعْمَاثْ أَقَا أَثنْثْ ذڭْ ؤُفُوسْ نّشْ إِ ڒبْذَا.   
\b  
\b  
\m  
\c 17
\m
\v 1 \add ثَاژَادْجِيثْ ن ذَاوُوذْ.\add*  
\b  
\m \add أَ\add* سِيذِي، سڒْ غَارْ ثْسڭْذَا،  
\m أڭّْ ڒْبَاڒْ إِ ؤُغُويِّي إِنُو،  
\m أوْشْ أَمزُّوغْ خْمِي تّْژَادْجِيغْ  
\m س إِينْشِيشنْ وَارْ زَّايْسنْ د-إِتّكّْ شَا ڒْغشّْ.   
\m
\v 2 أجّْ ڒْحقّْ إِنُو أَذْ إِفّغْ  
\m زِي زَّاثْ إِ وُوذمْ نّشْ،  
\m أجّْ ثِيطَّاوِينْ نّشْ أَذْ خزَّارنْثْ  
\m غَارْ مِينْ إِدْجَانْ إِسڭّْذنْ.   
\b  
\m
\v 3 شكْ ثْقدْجْبذْ ؤُڒْ إِنُو،  
\m ثَارْزُوذْ \add ذَايسْ\add* سْ دْجِيڒثْ.  
\m ثْجَارّْبذْ أَيِي، \add مَاشَا\add* وَارْ ثُوفِيذْ وَالُو.  
\m \add مَاڒَا\add* نْوِيغْ أَذْ خَارّْصغْ ذِي شَا وَارْ إِحْڒِي،  
\m وَارْ إِتّفِّيغْ زڭْ إِينْشِيذنْ إِنُو.   
\m
\v 4 خْ مِينْ تّڭّنْ إِوْذَانْ،  
\m أَقَا \bd نشّْ\bd* حْضِيغْ إِخفْ إِنُو  
\m زِي ثبْرِيذِينْ ن أَيْثْ ن بُو-ڒخْشُونثْ،  
\m عْلَاحْسَابْ أَوَاڒْ زڭْ إِينْشِيشنْ نّشْ.   
\m
\v 5 أڭّْ إِصُورَافْ إِنُو ذِي جُّورَّاثْ \add ن إِضَارنْ\add* نّشْ،  
\m \add حِيمَا\add* وَارْ فَارّْغنْ إِضَارنْ إِنُو.   
\b  
\m
\v 6 \bd نشّْ\bd* ڒَاغِيغْ خَاكْ،  
\m مِينْزِي شكْ أَذْ خَافِي د-ثَارّذْ، \add أَ\add* أَربِّي،  
\m أوْشْ أَيِي أَمزُّوغْ، سڒْ إِ مِينْ غَا إِنِيغْ.   
\m
\v 7 سْشنْ ڒعْجَايبْ  
\m ن ثْمخْسِيوْثْ نّشْ إِشوَّارنْ،  
\m شكْ ذ ونِّي إِسّنْجَامنْ  
\m إِنِّي غَاركْ يَاركّْوَاڒنْ،  
\m \add شكْ ذ ونِّي ثنْ إِسّنْجَامنْ\add*  
\m زڭْ يِينِّي إِتّْغوّْغنْ س ؤُفُوسْ نّشْ أَفُوسِي.   
\b  
\m
\v 8 حْضَا أَيِي أَمْ مُومُّو ن ثِيطّْ نّشْ،  
\m سْنُوفَّارْ أَيِي ذِي ثِيڒِي ن وَافْرِيونْ نّشْ \f ◼ \fr 17:‏8 \ft \+bd ’أَرْيَازْ أَمژْيَانْ‘\+bd* - خْمِي ثْخزَّارذْ ذِي ثِيسِي، إِتّضْهَارْ ڒبْذَا إِجّْ ن ورْيَازْ أَمژْيَانْ ذِي مُومُّو ن ثِيطّْ نكّْ ونِّي ذ ثَاصْوِيرْثْ ن يِيخفْ نّكْ. \+bd ’مُومُّو ن ثِيطّْ نّكْ‘\+bd* - س ثْعِيبْرَانِيثْ ’يدْجِيسْ ن ثِيطّْ‘.\f*   
\m
\v 9 زڭْ إِعفَّاننْ إِنِّي إِخْسنْ أَذْ ذَايِي حْصَارنْ،  
\m إِنِّي ذ ڒْعذْيَانْ ن ڒعْمَارْ إِنُو،  
\m إِنِّي ذ أَيِي إِتّْقُووَّارنْ.   
\b  
\m
\v 10 نِيثْنِي بلّْعنْ \add ؤُڒْ نْسنْ\add* س ثَاذُونْثْ نْسنْ،  
\m س ؤُقمُّومْ نْسنْ سَّاوَاڒنْ س نّْفَاخثْ.   
\m
\v 11 ڒخُّو قُووَّارنْ عَاذْ إِ إِصُورَافْ نّغْ،  
\m ثِيطَّاوِينْ نْسنْ مُّوقّْڒنْثْ  
\m مَاحنْذْ أَذْ \add أَيِي\add* نْضَارنْ غَارْ ثمُّورْثْ.   
\m
\v 12 نتَّا يَارْوسْ ذڭْ ويْرَاذْ نِّي إِمژّْرنْ  
\m مَاحنْذْ أَذْ إِمزّقْ \add ثَايْمَارْثْ نّسْ\add*،  
\m ذڭْ إِجّْ ن ويْرَاذْ ذ أَمژْيَانْ  
\m إِ إِقِّيمنْ ذڭْ إِمُوشَانْ إِنُّوفَّارنْ.   
\b  
\m
\v 13 كَّارْ، \add أَ\add* سِيذِي، رُوحْ مْسَاڭَارْ أَكِيذسْ،  
\m غْضڒْ-إِ-ث غَارْ ثمُّورْثْ.  
\m فكّْ ڒعْمَارْ إِنُو س سِّيفْ نّشْ زڭْ ؤُعفَّانْ،   
\m
\v 14 س ؤُفُوسْ نّشْ زڭْ إِرْيَازنْ، \add أَ\add* سِيذِي،  
\m زڭْ إِرْيَازنْ ن دُّونشْثْ-أَ  
\m نِّي غَارْسنْ ثُوذَارْثْ-أَ ذ ثَاسْغَارْثْ \add نْسنْ\add*،  
\m إِنِّي زِي ثتّْعمَّارذْ أَعذِّيسْ نْسنْ  
\m س ڒكْنُوزْ إِنُوفَّارنْ،  
\m \add ؤُڒَا ذ\add* إِحنْجِيرنْ \add نْسنْ\add* تّْوَايَاوَاننْ،  
\m تّجَّانْ مِينْ إِشطّنْ إِ ثَارْوَا نْسنْ.   
\m
\v 15 \bd نشّْ\bd* أَذْ ژَترغْ ؤُذمْ نّشْ ذِي ثْسڭْذَا،  
\m أَذْ ذوْڒغْ جِّيوْنغْ س وَادُّوذْ نّشْ  
\m خْمِي د غَا فَاقغْ.   
\b  
\b  
\m  
\c 18
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. ن ؤُمْسخَّارْ ن سِيذِي.\add* \add ن ذَاوُوذْ، ونِّي إِسِّيوْڒنْ أَوَاڒنْ ن يزْڒِي-يَا إِ سِيذِي،\add* \add ذڭْ وَاسّْ ؤُمِي ث إِفكّْ سِيذِي\add* \add زڭْ ؤُفُوسْ ن مَارَّا ڒْعذْيَانْ نّسْ\add* \add ؤُ زڭْ ؤُفُوسْ ن شَاوُولْ.\add*\f ◼ \fr 18:‏1 \ft \+bd أَفسَّارْ\+bd* - ثْزمَّارذْ أَذْ ثَافذْ أَزهّذْ-أَ عَاوذْ ذِي 2 صَامْ. 22\f*  \x ◘ \xo 18:‏1 \xt 2 صم. 22\x*   
\b  
\m
\v 2 نتَّا إِنَّا:  
\m ”نشّْ تّخْسغْ شكْ، \add أَ\add* سِيذِي،  
\m جّهْذْ إِنُو \add ذ شكْ\add*. \x ◘ \xo 18:‏2 \xt 1 صم. \x*   
\m
\v 3 سِيذِي ذ ثَاسْضَارْثْ إِنُو  
\m ذ لْبُورْجْ إِنُو ذ أَمْفكِّي إِنُو،  
\m أَربِّي إِنُو، ثَاصْضَارْثْ إِنُو،  
\m نشّْ غَارسْ أَركّْوَاڒغْ.  
\m \add شكْ\add* ذ ثَاسدَّارْثْ إِنُو ن ؤُسڒْقِي  
\m ذ يِيشّْ ن ؤُسنْجمْ إِنُو،  
\m لْبُورْجْ إِنُو يُوعْڒَانْ.   
\m
\v 4 نشّْ ڒَاغِيغْ-د خْ سِيذِي،  
\m ونِّي إِسْذَاهدْجنْ أَسمْغَارْ،  
\m ؤُ نشّْ أَقَا تّْوَاسّْنجْمغْ  
\m زِي ڒْعذْيَانْ إِنُو.   
\b  
\m
\v 5 إِسغْوَانْ ن ڒْموْثْ نّْضنْ أَيِي-د،  
\m سِّيڭّْوذنْثْ أَيِي ڒْحمْڒَاثْ ن وَامَانْ إِهَاجنْ.   
\m
\v 6 إِسغْوَانْ ن ڒَاخَارْثْ شَارْفنْ أَيِي،  
\m ثِيخشْفِينْ ن ڒْموْثْ حْصَارنْثْ أَيِي.   
\m
\v 7 ذِي ڒحْصَارثْ إِنُو ڒَاغِيغْ-د خْ سِيذِي،  
\m خْ أَربِّي إِنُو إِ خْ د-ڒَاغِيغْ.  
\m زِي زَّاوشْثْ نّسْ ثَامقّْرَانْثْ  
\m إِسْڒَا نتَّا إِ ثْمِيجَّا إِنُو،  
\m إِغُويَّانْ إِنُو \add ؤُذْفنْ\add*  
\m غَارْ إِمزُّوغنْ نّسْ.   
\b  
\m
\v 8 \add خنِّي\add* ثنْهزّْ ؤُ ثَارْجِيجْ ثمُّورْثْ،  
\m ذْسُوسَا ن إِذُورَارْ  
\m تّْرَاحنْ-د تَّاسنْ-د ؤُ نْهزّنْ،  
\m مَاغَارْ إِتّْوَاسَّارْغْ \add وغْضَابْ نّسْ\add*.   
\m
\v 9 إِڭعّذْ دّخَّانْ زڭْ ونْزَارنْ نّسْ،  
\m ثِيمسِّي زڭْ ؤُقمُّومْ نّسْ ثْصَارْضْ،  
\m إِتّْوَاسَّارْغْ زَّايسْ ڒفْحمْ.   
\m
\v 10 نتَّا إِجَّا أَجنَّا أَذْ يَاضَارْ  
\m ؤُشَا \add خنِّي\add* إِهْوَا-د نتَّا،  
\m \add أَقَا ذِينْ\add* إِجّْ ن ؤُسيْنُو إِبُّومْبسْ  
\m سَاذُو إِضَارنْ نّسْ.   
\b  
\m
\v 11 إِنْذهْ خْ إِجّْ ن ؤُكِيرُوبْ، \add وَاهْ،\add* إِضْوَا،  
\m نتَّا إِحوّمْ خْ وَافْرِيونْ ن ؤُسمِّيضْ. \f ◼ \fr 18:‏11 \ft \+bd ’أَخِيرُوبْ‘\+bd* - إِشْثْ ن مَارْكَا ن لْمَالَاكَاثْ.\f*   
\m
\v 12 نتَّا إِڭَّا ثَادْجسْثْ  
\m أَمْ يِيجّْ ن ؤُسڒْقِي خْ يِيخفْ نّسْ،  
\m أَعِيشُّو نّسْ أَقَا-ث ذڭْ ونّضْ نّسْ،  
\m أَمَانْ إِبُّوبّْسنْ،  
\m إِسيْنُوثنْ إِبَّارشْننْ.   
\m
\v 13 زِي ثِيسِّيقْثْ قِيبَاتْشْ نّسْ  
\m تّكّنْ إِسيْنُوثنْ نّسْ،  
\m \add أَكْ-ذ\add* ثبْرُورِي ذ ڒفْحمْ إِتّحْذُوذُوقنْ. \x ◘ \xo 18:‏13 \xt ؤُف. 9‏:‏23، 24\x*   
\b  
\m
\v 14 سِيذِي إِڭَّا أَجَّاجْ أَذْ إِدُّوقّزْ ذڭْ إِجنْوَانْ،  
\m أَمْعُودْجِي خْ كُوڒْشِي إِڭَّا ثْمِيجَّا نّسْ تّْنفْرَارَا:  
\m ثَابْرُورِي ذ ڒفْحمْ إِتّحْذُوذُوقنْ.   
\m
\v 15 نتَّا إِسّكّْ فْڒِيثْشَاثْ \add ن ڒْقوْسْ نّسْ\add*  
\m ؤُشَا إِبزّعْ إِ-ثنْ،  
\m \add إِزَّارْيضْ\add* أَسَّامنْ ؤُشَا إِسِّيڭّْوذْ إِ-ثنْ.   
\m
\v 16 ثِيسِيوِينْ ن إِغزْرَانْ ذوْڒنْثْ تّْبَاننْثْ،  
\m ذْسُوسَا ن دُّونشْثْ ذوْڒنْ عَارَّانْ  
\m زڭْ ؤُودّبْ نّشْ، \add أَ\add* سِيذِي،  
\m زڭْ ؤُسُوضِي ن ڒعْوِينْ زڭْ ونْزَارنْ نّشْ.   
\b  
\m
\v 17 زِي سنّجْ إِسّْوِيژّضْ-د \add أَفُوسْ نّسْ\add*،  
\m يِيوِي أَيِي،  
\m إِجْبذْ أَيِي-د زڭْ وَامَانْ مْغَارنْ.   
\m
\v 18 نتَّا إِفكّْ أَيِي-د زِي ڒعْذُو إِنُو إِجهْذنْ،  
\m زڭْ إِنِّي ذ أَيِي إِشَارّْهنْ،  
\m مِينْزِي نِيثْنِي ثُوغَا جهّْذنْ خَافِي.   
\m
\v 19 نِيثْنِي حْصَارنْ أَيِي  
\m ذڭْ وَاسّْ ن أَرْژِييّثْ إِنُو،  
\m مَاشَا سِيذِي ثُوغَا ذ أَمْعمّذْ إِنُو.   
\m
\v 20 نتَّا إِنْذهْ أَيِي غَارْ تَّاسِيعْ  
\m ؤُشَا إِسّنْجمْ أَيِي،  
\m مَاغَارْ نتَّا ثُوغَا إِسّْعِيزَّا أَيِي.   
\b  
\m
\v 21 سِيذِي إِخْڒفْ أَيِي عْلَاحْسَابْ ثَاسڭْذَا إِنُو،  
\m عْلَاحْسَابْ ثَازْذُوڭِي ن إِفَاسّنْ إِنُو إِخدْجصْ أَيِي.   
\m
\v 22 مَاغَارْ نشّْ حْضِيغْ إِبْرِيذنْ ن سِيذِي،  
\m وَارْ حيّْذغْ شَا خْ أَربِّي إِنُو س ؤُخيّبْ.   
\m
\v 23 مَاغَارْ مَارَّا لْفَارَايِيضْ نّسْ  
\m \add ثُوغَا\add* جَارْ \add ثِيطَّاوِينْ\add* إِنُو،  
\m وَارْ حيِّيذغْ شَا خْ ثْوصَّا نّسْ.   
\m
\v 24 أَقَا-يِي كمّْڒغْ نِيشَانْ أَكِيذسْ،  
\m حْضِيغْ إِخفْ إِنُو زِي ڒْمُوعْصِييّثْ إِنُو.   
\b  
\m
\v 25 سِيذِي إِخْڒفْ أَيِي أَنشْثْ ن ثْسڭْذَا إِنُو،  
\m أَنشْثْ ن ثَازْذُوڭِي ن إِفَاسّنْ إِنُو  
\m زَّاثْ إِ ثِيطَّاوِينْ نّسْ.   
\m
\v 26 إِ ؤُمدُّوكّڒْ أَمْثِيقِّي  
\m إِ ثدْجِيذْ شكْ ذ أَمدُّوكّڒْ أَمْثِيقِّي،  
\m إِ بُو-ثغْرُوضْثْ إِكمّْڒنْ  
\m إِ ثدْجِيذْ شكْ ثْكمّْڒذْ.   
\m
\v 27 إِ ونِّي إِتّْوَاسِّيزذْڭنْ  
\m أَقَا شكْ ذ أَمزْذَاڭْ،  
\m أَكْ-ذ ونِّي إِفَارْغنْ، أَقَا ثتّْمُوغْزْڒذْ.   
\m
\v 28 شكْ ثسّْنجْمذْ ڒْڭنْسْ إِتّْوَاحْصَارنْ،  
\m \add مَاشَا\add* ثِيطَّاوِينْعفَّارنْثْ  
\m أَذْ ثنْثْ ثسّهْوِيذْ.   
\b  
\m
\v 29 مِينْزِي شكْ ذ ڒفْنَارْ إِنُو، \add أَ\add* سِيذِي!  
\m أَربِّي إِنُو إِتّڭّْ ثَافَاوْثْ ذِي ثَادْجسْثْ إِنُو.   
\m
\v 30 مِينْزِي أَكِيذكْ أَذْ أَزّْڒغْ خْ إِشْثْ ن بَانْذِييَّا،  
\m أَكْ-ذ أَربِّي إِنُو أَذْ نڭْزغْ خْ إِجّْ ن ڒْحِيضْ.   
\m
\v 31 أَبْرِيذْ ن أَربِّي إِكْمڒْ،  
\m مِينْ إِقَّارْ سِيذِي إِتّْوَاصفَّا \add ذِي ثْمسِّي\add*.  
\m نتَّا ذ أَسڒْقِي  
\m إِ مَارَّا إِنِّي غَارسْ يَاركّْوَاڒنْ.   
\b  
\m
\v 32 مَاغَارْ مَانْ ونْ إِ إِدْجَانْ ذ أَربِّي،  
\m مْغِيرْ سِيذِي،  
\m ؤُ مَانْ ونْ إِ إِدْجَانْ ذ ثَاصْضَارْثْ،  
\m مْغِيرْ أَربِّي نّغْ؟   
\m
\v 33 أَربِّي ونِّي ذ أَيِي إِتّْبيْسنْ س جّْهذْ،  
\m ونِّي ذ أَيِي إِتِّيشنْ أَبْرِيذْ إِنُو إِكْمڒْ.   
\b  
\m
\v 34 نتَّا إِڭَّا إِضَارنْ إِنُو  
\m أَمْ يِينِّي ن ثُوذَاذِينْ،  
\m نتَّا يَارَّا أَيِي أَذْ بدّغْ خْ ڒڭْعُوذِي إِنُو. \x ◘ \xo 18:‏34 \xt حَاب. 3‏:‏19\x*   
\m
\v 35 إِسّڒْمذْ إِفَاسّنْ إِنُو إِ ؤُمنْغِي،  
\m إِغَادْجنْ إِنُو مَاحنْذْ أَذْ محْضنْ  
\m إِجّْ ن ڒْقوْسْ ن نّْحَاسْ.   
\b  
\m
\v 36 ثوْشِيذْ أَيِي ثَاسدَّارْثْ ن ؤُسڒْقِي  
\m ن ؤُسنْجمْ نّشْ،  
\m أَفُوسْ نّشْ أَفُوسِي ذ أَسنّذْ إِنُو،  
\m أَوَاضعْ نّشْ ثسّمْغَارذْ أَيِي.   
\m
\v 37 أَقَا ثڭِّيذْ تَّاسِيعْ  
\m إِ إِصُورِيفْ\add أنْ\add* إِنُو سَاذُو إِنُو،  
\m ثِيشعْبِينْ إِنُو وَارْ ميّْڒنْثْ.   
\b  
\m
\v 38 نشّْ ضْفَارغْ ڒْعذْيَانْ إِنُو ؤُ حَارْثغْ خَاسنْ،  
\m وَارْ تّْعِيقِيبغْ أَڒْ ثنْ قْضِيغْ.   
\m
\v 39 نشّْ أَردّْدْجغْ ثنْ،  
\m \add أَڒَامِي\add* وَارْ زمَّارنْ أَذْ كَّارنْ عَاوذْ.  
\m نِيثْنِي وْضَانْ-د سَاذُو إِضَارنْ إِنُو.   
\m
\v 40 شكْ ثْبيْسذْ أَيِي س جّهْذْ إِ ؤُمنْغِي،  
\m ثَارِّيذْ-د إِنِّي غَارِي د-إِكَّارنْ  
\m أَذْ أَضَارنْ سَاذُو إِنُو.   
\m
\v 41 شكْ ثوْشِيذْ أَيِي ثِيمجَّارْثْ ن ڒْعذْيَانْ إِنُو،  
\m ن يِينِّي ذ أَيِي إِشَارّْهنْ،  
\m ؤُ نشّْ أَردّْدْجغْ ثنْ.   
\b  
\m
\v 42 نِيثْنِي ڒَاغَانْ،  
\m \add مَاشَا\add* وَارْ ذِينْ ثُوغِي أَمْسنْجمْ،  
\m \add ڒَاغَانْ\add* خْ سِيذِي،  
\m مَاشَا نتَّا وَارْ خَاسنْ د-يَارِّي.   
\m
\v 43 نشّْ ودَّارغْ ثنْ أَمْ ثْعجَّاجْثْ  
\m زَّاثْ إِ ؤُسمِّيضْ،  
\m أَمْ ؤُبدْجَاعْ خْ إِبْرِيذنْ فَارْضغْ زَّايْسنْ.   
\b  
\m
\v 44 شكْ ثْفكّذْ أَيِي زڭْ إِمْشُوبّْشنْ ن ڒْڭنْسْ،  
\m ثڭِّيذْ أَيِي ذ أَزدْجِيفْ ن ڒڭْنُوسْ،  
\m إِجّْ ن ويْذُوذْ وَارْ ث سِّينغْ، أَذْ أَيِي إِسخَّارْ. \x ◘ \xo 18:‏44 \xt 2 صم. 22‏:‏44\x*   
\m
\v 45 مْغِيرْ ڒَامِي ذ أَيِي إِسْڒَا ؤُمزُّوغْ \add نْسنْ\add* وَاهَا،  
\m سْڒِينْ-د غَارِي.  
\m إِبَارَّانِييّنْ سّْنِيعْمِيڒنْ سُّوبُوضنْ أَيِي.   
\m
\v 46 فشْڒنْ إِبَارَّانِييّنْ،  
\m \add وَاخَّا\add* نّْضنْ أَسنْ-د لْبَارَاجَاثْ نْسنْ.   
\b  
\m
\v 47 ثُوذَارْثْ إِ سِيذِي! أَذْ ثتّْوَابَاركْ ثصْضَارْثْ إِنُو.  
\m أَذْ إِتّْوَاسّْڭعّذْ أَربِّي ن ؤُسنْجمْ إِنُو.   
\m
\v 48 أَربِّي ونِّي خَافِي إِتّنْثَاقَامنْ  
\m ونِّي ذ أَيِي إِتّڭّنْ ڒڭْنُوسْ سَاذُو ؤُفُوسْ إِنُو،   
\m
\v 49 ونِّي ذ أَيِي إِتّْفكَّانْ  
\m زڭْ \add ؤُفُوسْ ن\add* ڒْعذْيَانْ إِنُو،  
\m \add وَاهْ\add*، شكْ ثسّْڭعَّاذذْ أَيِي  
\m ثِيوَا ن يِينِّي ذ أَيِي إِتّْضَادَّانْ،  
\m شكْ ثسّنْجَامذْ أَيِي زڭْ ورْيَازْ ن ڒخْشُونثْ.   
\b  
\m
\v 50 خْ ؤُيَا، سِيذِي، خْسغْ أَذْ شكْ قَاذِيغْ،  
\m أَذْ زهّْذغْ إِسمْ نّشْ.   
\m
\v 51 نتَّا إِڭَّا إِسنْجِيمنْ  
\m ن ؤُجدْجِيذْ نّسْ مْغَارنْ،  
\m إِسّْشنْ ثَامخْسِيوْثْ نّسْ إِشوَّارنْ  
\m إِ ؤُمذْهُونْ نّسْ،  
\m إِ ذَاوُوذْ ؤُ إِ زَّارِيعثْ نّسْ إِ ڒبْذَا.   
\b  
\b  
\m  
\c 19
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. أَزهّذْ ن ذَاوُوذْ.\add*   
\b  
\m
\v 2 إِجنْوَانْ تّْبَارّْحنْ س ؤُعُودْجِي ن أَربِّي،  
\m ڒْقُوبّثْ ثسَّاوَاڒْ  
\m خْ ڒْخذْمثْ ن إِفَاسّنْ نّسْ.   
\m
\v 3 أَسّْ إِسَّازَّاڒْ أَوَاڒنْ إِ وَاسّْ،  
\m دْجِيڒثْ ثسّْشَانْ ثُوسّْنَا غَارْ دْجِيڒثْ.   
\m
\v 4 وَارْ إِدْجِي ذ ڒْهَارْذْ ؤُ وَارْ دْجِينْ شَا ذ أَوَاڒنْ،  
\m ثْمِيجَّا نْسنْ وَارْ ذ أَسْ إِتّسْڒِي حذْ.   
\b  
\m
\v 5 ڒُْومُورَاثْ نْسنْ فّْغنْثْ خْ ثمُّورْثْ مَارَّا،  
\m أَوَاڒنْ نْسنْ \add فّْغنْ\add* أَڒْ طَّارْفْ ن دُّونشْثْ.  
\m نتَّا إِڭَّا ذِيهَا إِجّْ ن ؤُقِيضُونْ إِ ثْفُوشْثْ، \x ◘ \xo 19:‏5 \xt حُوش. 6‏:‏3؛ رُوم. 10‏:‏18\x*   
\m
\v 6 أَمْ مُوڒَايْ نِّي د-إِسِّيجّنْ  
\m زڭْ وخَّامْ ن ڒمْڒَاشْ،  
\m إِسْڒِيوْڒوْ أَمْ يِيجّْ ن بُو-ثرْيَاسْثْ،  
\m حِيمَا أَذْ إِكْسِي ذِي ثِيشْڒِي نّسْ. \x ◘ \xo 19:‏6 \xt أَمب. 1‏:‏5\x*   
\m
\v 7 إِفّغْ-د زڭْ إِجّْ ن طَّارْفْ ن ؤُجنَّا،  
\m ؤُشَا يُويُورْ أَڒْ طَّارْفْ نّسْ نّغْنِي،  
\m وَارْ ثتّْنُوفَّارْ ؤُڒَا ذ إِشْثْ نْ ڒْحَاجثْ  
\m إِ ڒْحَاذُوقْ نّسْ.   
\b  
\m
\v 8 أَقَا ثكْمڒْ شَّارِيعَا ن سِيذِي،  
\m ثِيوِي-د أَڭنْفُو إِ بُوحْبڒْ.  
\m شّْهَاذَاثْ ن سِيذِي ذَايْسنْثْ ڒَامَانْ،  
\m تِّيشّنْثْ ثِيغِيثْ إِ ؤُحَافِي. \x ◘ \xo 19:‏8 \xt 2 صم. 22‏:‏31؛ إِزهد. 18‏:‏31\x*   
\m
\v 9 ڒُْومُورَاثْ ن سِيذِي سڭّْذنْثْ،  
\m سّْفَارّْحنْثْ ؤُڒْ.  
\m ثَاوْصِييّثْ ن سِيذِي ثصْفَا،  
\m ثسّْشَانَا ثَافَاوْثْ إِ ثِيطَّاوِينْ.   
\m
\v 10 ثِيڭّْوُوذِي زِي سِيذِي ثصْفَا،  
\m ثقِّيمْ ثْبدّْ إِ ڒبْذَا.  
\m ڒحْكَامَاثْ ن سِيذِي ذ ثِيذتّْ،  
\m أَقَا أَثنْثْ ذ ڒْحقّْ مَارَّا.   
\b  
\m
\v 11 نِيثنْثِي جبّْذنْثْ مژْرِي كْثَارْ خْ وُورغْ،  
\m \add وَاهْ\add*، كْثَارْ زڭْ وُورغْ إِتّْوَاصفَّانْ،  
\m أَقَا أَثنْثْ ذ ثِيمِيژِيذِينْ خْ ثَامّنْثْ  
\m نِيغْ خْ ثَامّنْثْ ن ثغْرَاصْثْ. \x ◘ \xo 19:‏11 \xt إِزهد. 119‏:‏72، 103، 127؛ أَوڒن. 8‏:‏11 \x*   
\m
\v 12 ؤُڒَا ذ أَمْسخَّارْ نّشْ  
\m إِتّْوَاوبّخْ زَّايْسنْثْ،  
\m ذڭْ ؤُحطُّو نْسنْثْ \add ثتّْنُوفَّارْ\add*  
\m ذَايسْ ڒْمُونثْ ثَامقّْرَانْثْ.   
\m
\v 13 أَودَّارْ، وِي زَّايسْ يُوشِينْ؟  
\m سِيزْذڭْ أَيِي زِي \add مِينْ\add* وَارْ إِتّْبِيننْ.   
\m
\v 14 حْضَا أَمْسخَّارْ نّشْ عَاوذْ زڭْ ؤُعفَّارْ،  
\m حِيمَا وَارْ خَافِي إِتّْصدْجِيضْ،  
\m \add حِيمَا\add* أَذْ إِڒِيغْ ذ أَمزْذَاڭْ  
\m زڭْ ؤُخطُّو إِمْغَارنْ.   
\m
\v 15 أَذْ د-أَسنْ وَاوَاڒنْ ن ؤُقمُّومْ إِنُو  
\m ذ إِخَارِيصّنْ ن وُوڒْ إِنُو،  
\m خْ ڒْخَاضَارْ نّشْ، \add أَ\add* سِيذِي،  
\m \add أَ\add* ثَاصْضَارْثْ إِنُو ذ أَمفْذِي إِنُو!   
\b  
\b  
\m  
\c 20
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. أَزهّذْ ن ذَاوُوذْ.\add*   
\b  
\m
\v 2 أَذْ خَاكْ د-يَارّْ سِيذِي  
\m ذڭْ وَاسّْ ن ڒحْصَارثْ،  
\m أَذْ شكْ إِسِّيزْذغْ إِسمْ ن أَربِّي ن يَاعْقُوبْ  
\m \add ذڭْ ومْشَانْ\add* يُوعْڒَانْ إِفَارْينْ.   
\m
\v 3 أَذْ أَشْ إِوْشْ أَفُوسْ زِي زَّاوشْثْ إِقدّْسنْ،  
\m أَذْ شكْ د-إِعَاونْ زِي صِيهْيُونْ.   
\m
\v 4 أَذْ شكْ يِيذَارْ ذِي ثوْهِيبِينْ \add ن ڒْغِيدْجثْ\add* نّشْ،  
\m أَذْ ثِيڒِي ثْغَارْصْثْ ن وشْمَاضْ نّشْ  
\m أَمْ ثَاذُونْثْ إِ نتَّا. سِيلَاهْ.   
\m
\v 5 أَذْ أَشْ إِوْشْ عْلَاحْسَابْ  
\m \add مِينْ إِمّژْرِي\add* وُوڒْ نّشْ،  
\m أجّْ إِ-ث أَذْ إِكمّڒْ مَارَّا إِنْوَاينْ نّشْ.   
\m
\v 6 نشِّينْ أَذْ نسْڒِيوْڒوْ  
\m خْ ؤُسنْجمْ س ؤُفُوسْ نّشْ،  
\m أَذْ نسُّوعْڒَا إِبَانْذُوثنْ  
\m ذڭْ يِيسمْ ن أَربِّي نّغْ.  
\m أَذْ إِسّْجِيونْ سِيذِي مَارَّا مژْرِي نّشْ.   
\m
\v 7 ڒخُّو سّْنغْ، أَقَا سِيذِي أَذْ يَاوِي أَسنْجمْ  
\m إِ ؤُمذْهُونْ نّسْ.  
\m نتَّا أَذْ ث-إِ-د-يَارّْ  
\m زڭْ إِجنْوَانْ ن زَّاوشْثْ نّسْ إِقدّْسنْ،  
\m س ثْمڭَّا ثِيمقّْرَانِينْ ن ؤُسنْجمْ  
\m س ؤُفُوسْ أَفُوسِي نّسْ.   
\b  
\m
\v 8 إِنَا تّْخَارَّاصنْ ذڭْ إِكَارُّوثنْ  
\m ؤُ إِنَا ذڭْ إِيْسَانْ،  
\m مَاشَا \bd نشِّينْ\bd* أَذْ نْخَارّصْ  
\m ذڭْ إِسمْ ن سِيذِي، أَربِّي نّغْ.   
\m
\v 9 \bd نِيثْنِي\bd* ؤُضَارنْ ؤُشَا وْضَانْ،  
\m \bd نشِّينْ\bd* نكَّارْ ؤُ نقِّيمْ نْبدّْ.   
\b  
\m
\v 10 \add أَ\add* سِيذِي، أَوِي-د أَسنْجمْ!  
\m أجّْ أَذْ أَنغْ د-يَارّْ ؤُجدْجِيذْ  
\m ذڭْ وَاسّْ إِ ذِي نْڒَاغَا.   
\b  
\b  
\m  
\c 21
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. أَزهّذْ ن ذَاوُوذْ.\add*   
\b  
\m
\v 2 \add أَ\add* سِيذِي، أَجدْجِيذْ إِفَارْحْ س جّهْذْ نّشْ،  
\m مَامّشْ إِفَارْحْ أَطَّاسْ س ؤُسنْجمْ نّشْ!   
\m
\v 3 ثوْشِيذْ أَسْ مژْرِي ن وُوڒْ نّسْ،  
\m شكْ وَارْ ثُوڭِيذْ شَا  
\m أَزَاوڭْ ن إِينْشِيشنْ نّسْ. سِيلَاهْ.   
\b  
\m
\v 4 مَاغَارْ شكْ ثُوسِيذْ-د إِ ؤُمْسَاڭَارْ أَكِيذسْ  
\m س لْبَارَاكَاثْ \add شُّورنْثْ س\add* ڒْخَارْ،  
\m ثقّْنذْ أَسْ تَّاجْ ن وُورغْ إِتّْوَاصفَّانْ  
\m خْ ؤُزدْجِيفْ نّسْ.   
\m
\v 5 إِتَّارْ أَشْ ثُوذَارْثْ،  
\m ثوْشِيذْ أَسْ ت،  
\m ثُوزّڭَّارْثْ ن وُوسَّانْ إِ ڒبْذَا قَاعْ.   
\b  
\m
\v 6 إِمْغَارْ ؤُعُودْجِي نّسْ س ؤُسنْجمْ نّشْ،  
\m ثسّْزهّْجذْ ث س ثِيسِّيقْثْ ذ ڒْعزّْ. \f ◼ \fr 21:‏6 \ft \+bd ’أَسنْجمْ‘\+bd* - نِيغْ ’أَسلّكْ‘.\f*   
\m
\v 7 مِينْزِي شكْ ثَارِّيذْ إِ-ث  
\m ذ لْبَارَاكَا ثَامقّْرَانْثْ إِ ڒبْذَا،  
\m شكْ ثشُّورذْ ث س ڒفْرَاحثْ  
\m غَارْ وُوذمْ نّشْ.   
\b  
\m
\v 8 مَاغَارْ أَجدْجِيذْ إِتّْشَاڒْ خْ سِيذِي،  
\m وَارْ إِتّفْرِيغْ س ثْمخْسِيوْثْ إِشوَّارنْ  
\m ن ؤُمْعُودْجِي خْ كُوڒْشِي.   
\m
\v 9 أَفُوسْ نّشْ أَذْ يَافْ مَارَّا ڒْعذْيَانْ نّشْ،  
\m أَفُوسْ أَفُوسِي نّشْ أَذْ يَافْ  
\m مَارَّا إِنِّي شكْ إِشَارّْهنْ.   
\b  
\m
\v 10 شكْ أَذْ ثنْ ثَارِّيذْ أَمْ ثفْقُونْثْ إِشمّْضنْ  
\m ذِي ڒْوقْثْ ن وضْحَارْ نّشْ،  
\m سِيذِي أَذْ ثنْ إِسَارْضْ س وغْضَابْ نّسْ،  
\m ثِيمسِّي أَذْ ثنْ ثشّْ.   
\m
\v 11 أَذْ ثمْحِيذْ ڒْغِيدْجثْ نْسنْ زِي ثمُّورْثْ،  
\m زَّارِيعثْ نْسنْ زِي ثَارْوَا ن بْنَاذمْ.   
\b  
\m
\v 12 مَاغَارْ نِيثْنِي نذْينْ أَشْ ڒْغَارْ،  
\m ڭِّينْ إِشْثْ ن ثْمعْمُوتْشْ،  
\m مَاشَا وَارْ زمَّارنْ وَالُو.   
\m
\v 13 مَاغَارْ شكْ أَذْ ثنْ ثڭّذْ جَارْ ثِيطَّاوِينْ،  
\m س إِفِيڒَانْ \add ن ڒْقوْسْ\add* نّشْ أَذْ ثْنيّْشذْ  
\m خْ وُوذْمَاونْ نْسنْ.   
\b  
\m
\v 14 سْڭعّذْ إِخفْ نّشْ، \add أَ\add* سِيذِي، س جّْهذْ نّشْ!  
\m أجّْ أَنغْ أَذْ نْغنّجْ  
\m ؤُ أَذْ نْزهّذْ إِ ثْزمَّارْ نّشْ.   
\b  
\b  
\m  
\c 22
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ، س ثغْنِينْثْ ن ’ثُوذَاذْثْ ن ثُوفُّوثْ‘. أَزهّذْ ن ذَاوُوذْ.\add*   
\b  
\m
\v 2 أَربِّي إِنُو، أَربِّي إِنُو،  
\m مَايمِّي إِ ذ أَيِي ثجِّيذْ؟  
\m زِي ڒَاڭّْوَاجْ \add إِ ثدْجِيذْ\add* زڭْ ؤُسنْجمْ إِنُو،  
\m زڭْ وَاوَاڒنْ إِ سْغُويُّوغْ \add أَمْ ويْرَاذْ\add*. \x ◘ \xo 22:‏2 \xt مت. 27‏:‏46؛ مك. 15‏:‏34\x*   
\m
\v 3 \add أَ\add* أَربِّي إِنُو، ڒَاغِيغْ ذڭْ وَاسّْ،  
\m \add مَاشَا\add* شكْ وَارْ خَافِي د-ثَارِّيذْ شَا،  
\m س دْجِيڒثْ، \add مَاشَا\add* نشّْ وَارْ \add ؤُفِيغْ\add* أَرَّاحثْ.   
\b  
\m
\v 4 شكْ ذ أَمْقدّسْ \add إِ ثدْجِيذْ\add*،  
\m ثْزدّْغذْ \add ذِي ڒْوسْطْ ن\add* إِزْڒَانْ  
\m ن ؤُصبّحْ ن إِسْرَائِيل.   
\m
\v 5 تّشْڒنْ خَاكْ ڒجْذُوذْ نّغْ،  
\m ثُوغَا تّشْڒنْ ؤُ شكْ ثَارِّيذْ ثنْ أَذْ نجْمنْ.   
\m
\v 6 نِيثْنِي سْغُوينْ-د غَاركْ  
\m ؤُشَا تّْوَاسّْنجْمنْ،  
\m ثُوغَا تّشْڒنْ خَاكْ ؤُ وَارْ نّْحشْمنْ شَا. \x ◘ \xo 22:‏6 \xt إِزهد. 25‏:‏3؛ 31‏:‏2؛ إِشا. 49‏:‏23؛ رُوم. 9‏:‏33\x*   
\b  
\m
\v 7 نشّْ ذ إِشْثْ ن ثْكشَّا، وَارْ إِدْجِي ذ أَرْيَازْ،  
\m \add نشّْ ذ\add* ڒْحڭْرَا ن بْنَاذمْ  
\m تّْوَاسّحْقَارغْ جَارْ ڒْڭنْسْ. \f ◼ \fr 22:‏7 \ft \+bd ’أَكشَّا‘\+bd* - أَمَارِيرْ ن ؤُزهّذْ-أَ إِسَّارْوَاسْ إِخفْ نّسْ ذڭْ ؤُزهّذْ-أَ أَكْ-ذ إِشْثْ ن ثْكشَّا نِّي إِتّْخصَّا أَذْ ثمّثْ ڒَامِي إِ د-ثَارُو. أَوَارْنِي إِ ڒْموْثْ نّسْ تّْغِيمَانْ إِذَامّنْ نّسْ إِزڭّْوَاغنْ، وَارْ إِزمَّارنْ أَذْ تّْوَامصْهنْ. إِذَامّنْ نِّي أَقَا إِغْڒَانْ أَطَّاسْ، سّْخدَّامنْ ثنْ حِيمَا أَذْ زَّايسْ ڭّنْ إِشْثْ ن سّْبَاغثْ. مَانْ أَيَا ذ إِجّْ ن ؤُشيَّارْ غَارْ إِذَامّنْ ن يَاسُوع لْمَاسِيحْ، ونِّي ذ أَنغْ إِتّخْسنْ ؤُ ونِّي ذ أَنغْ إِتّْفكَّانْ زِي دّْنُوبْ نّغْ س إِذَامّنْ نّسْ (أَسَا. 1‏:5).\f*   
\m
\v 8 مَارَّا إِنِّي ذ أَيِي إِژْرِينْ،  
\m سْثْهزَّانْ زَّايِي،  
\m أَرزّْمنْ إِينْشِيشنْ \add نْسنْ\add*،  
\m سّنْهزَّانْ أَزدْجِيفْ. \x ◘ \xo 22:‏8 \xt مت. 27‏:‏39\x*   
\m
\v 9 \add قَّارنْ\add*: ”سعْذُو ث خْ سِيذِي،  
\m أجّْ وَانِيثَا أَذْ ث إِفكّْ، أَذْ ث إِسّنْجمْ،  
\m مَاغَارْ نتَّا يَارْضَا خَاسْ.“ \x ◘ \xo 22:‏9 \xt مت. 27‏:‏43\x*   
\b  
\m
\v 10 شكْ ثْجبّْذذْ أَيِي-د  
\m زڭْ ؤُعذِّيسْ ن يمَّا،  
\m شكْ ثَارِّيذْ أَيِي ذِي ڒَامَانْ  
\m خْ وَابُّوشنْ ن يمَّا.   
\m
\v 11 زِي ڒمْرَاوثْ تّْوَامّنْضَارغْ خَاكْ،  
\m زڭْ ؤُعذِّيسْ ن يمَّا  
\m أَقَا شكْ ذ أَربِّي إِنُو.   
\m
\v 12 وَارْ تّْغِيمِي بُو غَارْ ڒَاڭّْوَاجْ زَّايِي،  
\m مَاغَارْ ڒحْصَارثْ ثُوذسْ  
\m ؤُ وَارْ ذِينْ شَا أَمْعَاوَانْ.   
\b  
\m
\v 13 أَطَّاسْ ن إِفُونَاسنْ نّْضنْ أَيِي-د،  
\m \add إِفُونَاسنْ\add* إِجهْذنْ زِي بَاشَانْ  
\m قُووَّارنْ أَيِي-د، \f ◼ \fr 22:‏13 \ft \+bd ’بَاشَانْ‘\+bd* - ذڭْ وُوسَّانْ-أَ بَاشَانْ ذ ثَامُّورْثْ ن ڒڭْعُوذِي ن جُولَانْ جَارْ سُورِييَا ذ إِسْرَائِيل.\f*   
\m
\v 14 أَرْزْمنْ-د غَارِي أَقمُّومْ نْسنْ  
\m أَمشْنَاوْ إِجّْ ن ويْرَاذْ  
\m إِتّْمزَّاقنْ، إِزهَّارنْ.   
\b  
\m
\v 15 نشّْ تّْوَافَارّْغغْ أَمْ وَامَانْ  
\m ؤُ مَارَّا إِغْسَانْ إِنُو تّْوَامّْسبْضَانْ.  
\m ؤُڒْ إِنُو أَمْ شّْمعْ،  
\m أَقَا إِفْسِي ذَاخڒْ إِنُو.   
\m
\v 16 جّهْذْ إِنُو يُوژغْ  
\m أَمْ يِيجّْ ن ؤُشدْجِيقْ ن إِشْثْ ن ثْقدُّوحْثْ،  
\m إِڒسْ إِنُو إِڒْصقْ غَارْ وَانغْ إِنُو.  
\m شكْ ثسَّارْسذْ أَيِي ذِي ثْعجَّاجْثْ ن ڒْموْثْ.   
\b  
\m
\v 17 مَاغَارْ إِطَانْ نّْضنْ أَيِي-د،  
\m إِشْثْ ن بَانْذِييَّا ن ثَارْوَا ن ڒحْرَامْ  
\m قُووَّارنْ أَيِي-د،  
\m أَقَا أَمْ ويْرَاذْ إِفَاسّنْ ذ إِضَارنْ إِنُو. \f ◼ \fr 22:‏17 \ft \+bd ’أَقَا أَمشْنَاوْ أَيْرَاذْ إِفَاسّنْ ذ إِضَارنْ إِنُو‘\+bd* - حِيمَا أَذْ نفْهمْ أَوَاڒنْ-أَ كْثَارْ نْزمَّارْ أَذْ نْغَارْ ’أَقَا أَمشْنَاوْ أَيْرَاذْ إِخْسْ أَذْ إِزْعفْ إِفَاسّنْ ذ إِضَارنْ إِنُو‘. أَوَاڒنْ-أَ ذَايْسنْ إِجّْ ن ؤُشيَّارْ غَارْ ڒْموْثْ ن يَاسُوع لْمَاسِيحْ خْ صَّالِيبْ ڒَامِي سّْنُوقّْبنْ إِرُومَانِييّنْ إِفَاسّنْ ذ إِضَارنْ نّسْ، وَاخَّا ڒْموْثْ نّسْ ثمْسَارْ كْثَارْ زڭْ وَاڒفْ ن إِسڭّْوُوسَا أَوَارْنِي مَا أَذْ إِتّْوَارِي ؤُزهّذْ-أَ. س ؤُينِّي نْثَافْ إِشْثْ ن نُّوپُووَا ذ ثَامقّْرَانْثْ ذڭْ وَاوَاڒنْ ن ؤُزهّذْ-أَ نِّي إِسَّاوَاڒنْ خْ ڒْموْثْ ن يَاسُوع لْمَاسِيحْ س يِيجّْ ن شّكْلْ إِسّذْهَاشنْ ؤُ س يِيجّْ ن ؤُسْفَارْزْ ذ أَمقّْرَانْ.\f*  \x ◘ \xo 22:‏17 \xt إِشا. 38‏:‏13؛ مت. 27‏:‏35؛ مك. 15‏:‏24؛ لك. 23‏:‏33؛ يُوح. 19‏:‏23، 37؛ 20‏:‏25\x*   
\m
\v 18 زمَّارغْ أَذْ حسْبغْ  
\m مَارَّا إِغْسَانْ إِنُو.  
\m \bd نِيثْنِي\bd* تّْوَاڒَانْ أَيِي، خزَّارنْ-د غَارِي.   
\m
\v 19 نِيثْنِي بْضَانْ أَرُّوضْ  إِنُو جَارْ أَسنْ،  
\m ؤُشَا نْضَارنْ ثَاقدُّوحْثْ خْ ڒعْبَايثْ إِنُو. \x ◘ \xo 22:‏19 \xt لك. 23‏:‏34؛ يُوح. 19‏:‏24\x*   
\b  
\m
\v 20 شكْ، \add أَ\add* سِيذِي، وَارْ \add تِّيڒِي\add*  
\m غَارْ ڒَاڭّْوَاجْ، \add أَ\add* جّهْذْ إِنُو،  
\m أَسْ-د ذغْيَا حِيمَا أَذْ أَيِي ثْعَاوْنذْ.   
\m
\v 21 فكّْ ڒعْمَارْ إِنُو زِي سِّيفْ،  
\m أَينِّي زڭْ ؤُقطّسْ ن وقْزِينْ.   
\m
\v 22 فكّْ أَيِي زڭْ ؤُقمُّومْ ن ويْرَاذْ،  
\m \add فكّْ أَيِي\add* زڭْ وَاشَّاونْ ذ إِزِيرَارنْ  
\m ن إِغَايْضْ نْ ڒخْڒَا!  
\m أَقَا شكْ ثسْڒِيذْ أَيِي.   
\b  
\m
\v 23 أَذْ بَارّْحغْ إِسمْ نّشْ إِ وَاوْمَاثنْ إِنُو،  
\m أَذْ خَاكْ صبْحغْ ذِي ڒْوسْطْ ن وڭْرَاوْ نْ ڒْڭنْسْ. \x ◘ \xo 22:‏23 \xt عبر. 2‏:‏12\x*   
\m
\v 24 كنِّيوْ، إِنِّي إِتّڭّْوْذنْ سِيذِي،  
\m سمْغَارمْ ث،  
\m \add أَ كنِّيوْ،\add* مَارَّا زَّارِيعثْ ن يَاعْقُوبْ،  
\m سْعُودْجمْ ث ؤُ وقَّارمْ ث،  
\m \add أَ كنِّيوْ،\add* مَارَّا زَّارِيعثْ ن إِسْرَائِيل!   
\b  
\m
\v 25 مَاغَارْ وَارْ إِسّحْقِيرْ شَا  
\m ڒحْصَارثْ ن ونِّي إِتّْوَاحْصَارنْ،  
\m وَارْ ت إِعِيفّْ شَا،  
\m وَارْ خَاسْ إِسّْنُوفَّارْ شَا ؤُذمْ نّسْ،  
\m \add مَاشَا\add* نتَّا إِسْڒَا أَسْ مَاڒَا إِڒَاغَا أَسْ-د.   
\b  
\m
\v 26 زَّايكْ أَذْ د-يَاسْ ؤُقَاذِي إِنُو  
\m ذڭْ إِجّْ ن وڭْرَاوْ \add ن ڒْڭنْسْ\add* أَمقّْرَانْ،  
\m أَذْ كمّْڒغْ لْوُوعُوذْ إِنُو  
\m زَّاثْ إِ يِينِّي زَّايسْ إِتّڭّْوذنْ.   
\m
\v 27 إِمْوَاضْعنْ أَذْ شّنْ ؤُ أَذْ جِّيوْننْ،  
\m إِنِّي أَرزُّونْ خْ سِيذِي أَذْ أَسْ صبّْحنْ،  
\m ؤُڒَاونْ نْسنْ أَذْ دَّارنْ إِ ڒبْذَا.   
\b  
\m
\v 28 مَارَّا ثِينڭُّورَا ن ثمُّورْثْ أَذْ ث إِذَارنْثْ،  
\m أَذْ د-ذوْڒنْثْ غَارْ سِيذِي،  
\m مَارَّا ڒَادْجَاثْ ن ڒڭْنُوسْ  
\m أَذْ سجْذنْثْ زَّاثْ إِ وُوذمْ نّشْ، \x ◘ \xo 22:‏28 \xt إِزهد. 2‏:‏8؛ 72‏:‏11؛ 86‏:‏9؛ أَسَا.15‏:‏4\x*   
\m
\v 29 مِينْزِي ثَاڭلْذِيثْ إِ سِيذِي \add إِ ثدْجَا\add*،  
\m نتَّا إِحكّمْ جَارْ ڒڭْنُوسْ.   
\m
\v 30 مَارَّا إِنِّي إِصحّنْ ذِي ثمُّورْثْ  
\m أَذْ شّنْ، أَذْ سجْذنْ،  
\m مَارَّا إِنِّي د-إِهكّْوَانْ ذِي ثْعجَّاجْثْ  
\m أَذْ سجْذنْ زَّاثْ إِ وُوذمْ نّسْ،  
\m \add كُوڒْ إِجّنْ\add* إِ وَارْ إِزمَّارنْ  
\m أَذْ إِحْضَا ڒعْمَارْ نّسْ.   
\m
\v 31 زَّارِيعثْ أَذْ أَسْ ثْسخَّارْ،  
\m أَذْ ثتّْوَازمّْ ذ أَرَّاوْ إِ سِيذِي إِنُو.   
\m
\v 32 أَذْ د-أَسنْ، أَذْ بَارّْحنْ ثَاسڭْذَا نّسْ  
\m إِ يِيجّْ ن ڒْڭنْسْ إِ غَا د-إِتّْوَاخڒْقنْ،  
\m مَاغَارْ نتَّا أَقَا إِڭَّا إِ-ت. \x ◘ \xo 22:‏32 \xt إِزهد. 52‏:‏11\x*   
\b  
\b  
\m  
\c 23
\m
\v 1 \add أَزهّذْ ن ذَاوُوذْ.\add*  
\b  
\m سِيذِي ذ أَمكْسَاوْ إِنُو،  
\m وَارْ خَافِي إِتّكّْ شَا زّْعَافْ. \x ◘ \xo 23:‏1 \xt إِشا. 40‏:‏11؛ إِرْم. 23‏:‏4؛ حِز. 34‏:‏23؛ يُوح. 10‏:‏11؛ 1 بُط. 2‏:‏25؛ أَسَا. 7‏:‏17\x*   
\m
\v 2 نتَّا إِسَّاريَّاحْ أَيِي  
\m ذِي دّْمَانِي ن ثَاروْسَا إِزِيزَاونْ،  
\m إِندّهْ أَيِي غَارْ وَامَانْ يَارْسَانْ.   
\m
\v 3 نتَّا إِسّْفَاقَا ڒعْمَارْ إِنُو،  
\m إِندّهْ أَيِي ذِي ڒَاثَارَاثْ ن ثْسڭْذَا  
\m ذِي طّْوعْ ن يِيسمْ نّسْ.   
\b  
\m
\v 4 وَاخَّا ڭُّورغْ  
\m ذِي ثغْزُورْثْ ن ثِيڒِي ن ڒْموْثْ،  
\m وَارْ تّڭّْوْذغْ زِي ڒْغَارْ،  
\m مَاغَارْ شكْ أَكِيذِي.  
\m أَعكَّازْ نّشْ ذ ثَاغَّارْشْثْ نّشْ  
\m سّْفوَّاجنْ خَافِي. \x ◘ \xo 23:‏4 \xt إِزهد. 3‏:‏6؛ 118‏:‏6\x*   
\m
\v 5 ثسّوْجَاذذْ طَّابْڒَا إِنُو  
\m زَّاثْ إِ وُوذمْ ن يِينِّي ذ أَيِي إِحصَّارنْ.  
\m ثْذهّْنذْ أَزدْجِيفْ إِنُو س زّشْثْ،  
\m ڒْْكَاسْ إِنُو إِفيّضْ.   
\b  
\m
\v 6 إِوَا، ڒْخِيرْ ذ ثْمخْسِيوْثْ إِشوَّارنْ  
\m أَذْ أَيِي ضْفَارنْ،  
\m مَارَّا ؤُسَّانْ ن ثُوذَارْثْ إِنُو،  
\m نشّْ أَذْ زذْغغْ ذِي ثَادَّارْثْ ن سِيذِي،  
\m أَڒْ أَنڭَّارْ ن وُوسَّانْ.   
\b  
\b  
\m  
\c 24
\m
\v 1 \add أَزهّذْ ن ذَاوُوذْ.\add*  
\m \add أَ. أَزهّذْ ؤُمِي تّْڭعّْذنْ غَارْ وذْرَارْ ن صِيهْيُونْ\add*  
\m \add مَارَّا إِمغْنَاجنْ ن ڒْغَاشِي إِتّْعيّْذنْ:\add*  
\b  
\m إِ سِيذِي ثدْجَا ثمُّورْثْ ذ ؤُعمَّارْ نّسْ،  
\m دُّونشْثْ ذ إِمزْذَاغْ نّسْ.\x ◘ \xo 24:‏1 \xt ؤُف. 19‏:‏5؛ أَعَوذ. 10‏:‏14؛ أَيُوبْ 41‏:‏3؛ إِزهد. 50‏:‏12؛ 1 كُور. 10‏:‏26، 28\x*   
\m
\v 2 مَاغَارْ \bd نتَّا\bd* إِسَّارْسْ ذْسَاسْ نّسْ خْ ڒبْحُورْ،  
\m إِسّمْثنْ إِ-ث خْ سّحْڒَاثْ.   
\b  
\m
\v 3 \add ثْمِيجَّا:\add*  
\m وِي إِزمَّارنْ أَذْ إِڭعّذْ أَذْرَارْ ن سِيذِي،  
\m وِي إِزمَّارنْ أَذْ إِبدّْ  
\m ذڭْ ومْشَانْ نّسْ إِقدّْسنْ؟ \x ◘ \xo 24:‏3 \xt إِزهد. 15‏:‏1؛ إِشا. 33‏:‏14، 15\x*   
\b  
\m
\v 4 \add ثْمِيجَّا نّغْنِي:\add*  
\m ونِّي غَارْ إِدْجَا إِفَاسّنْ إِمزْذَاڭنْ  
\m ذ وُوڒْ إِصْفَا،  
\m ونِّي وَارْ د-إِتَّارِّي ڒعْمَارْ نّسْ  
\m خْ ڒْغشّْ،  
\m وَارْ إِتّْجَّادْجْ ژُورْ!   
\b  
\m
\v 5 \add مَارَّا إِمغْنَاجنْ:\add*  
\m نتَّا أَذْ إِكْسِي لْبَارَاكَا زِي سِيذِي،  
\m ؤُڒَا ذ ثَاسڭْذَا زِي أَربِّي ن ؤُسنْجمْ نّسْ.   
\m
\v 6 ذ وَا ذ جِّيڒْ ن يِينِّي خَاسْ يَارزُّونْ،  
\m إِنِّي يَارزُّونْ خْ وُوذمْ نّشْ،  
\m أَقَا-ث ذ يَاعْقُوبْ. سِيلَاهْ.   
\b  
\m
\v 7 \add بْ. أَزهّذْ ؤُمِي ؤُذْفنْ غَارْ ثنْذِينْثْ ن صِيهْيُونْ\add*  
\m \add مَارَّا إِمغْنَاجنْ ن ڒْغَاشِي إِتّْعيّْذنْ:\add*  
\m سْڭعّْذنْثْ إِزدْجِيفنْ نْومْ، \add أَ\add* ثِيوُّورَا،  
\m سْڭعّْذنْثْ إِخفْ نْكنْثْ، \add أَ\add* ثِيوُّورَا ن ڒبْذَا،  
\m \add حِيمَا\add* أَذْ يَاذفْ ؤُجدْجِيذْ ن ؤُعُودْجِي!   
\b  
\m
\v 8 \add ثْمِيجَّا زِي ثوُّورْثْ ن ثنْذِينْثْ:\add*  
\m مَانْ ونْ إِ إِدْجَانْ ذ أَجدْجِيذْ ن ؤُعُودْجِي وَانِيثَا؟  
\m \add مَارَّا إِمغْنَاجنْ:\add*  
\m ذ سِيذِي، إِجْهذْ إِجبَّارْ،  
\m سِيذِي أَقَا-ث ذ أَجبَّارْ ذڭْ ؤُمنْغِي.   
\m
\v 9 سْڭعّْذنْثْ إِزدْجِيفنْ نْكنْثْ، \add أَ\add* ثِيوُّورَا،  
\m سْڭعّْذنْثْ إِخفْ نْكنْثْ، \add أَ\add* ثِيوُّورَا ن ڒبْذَا،  
\m \add حِيمَا\add* أَذْ يَاذفْ ؤُجدْجِيذْ ن ؤُعُودْجِي!   
\b  
\m
\v 10 \add ثْمِيجَّا زِي ثوَّارْثْ ن ثنْذِينْثْ:\add*  
\m مِينْ إِعْنَا نتَّا، أَجدْجِيذْ-أَ ن ؤُعُودْجِي؟  
\m \add مَارَّا إِمغْنَاجنْ:\add*  
\m سِيذِي ن ڒْعسْكَارَاثْ  
\m ذ نتَّا ذ أَجدْجِيذْ ن ؤُعُودْجِي. سِيلَاهْ.   
\b  
\b  
\m  
\c 25
\m
\v 1 \add أَزهّذْ ن ذَاوُوذْ.\add*  
\b  
\m \bd أَلِيفْ.\bd* \add أَ\add* سِيذِي،  
\m غَاركْ إِ د-سّْڭعَّاذغْ ڒعْمَارْ إِنُو.   
\m
\v 2 \bd بِيثْ.\bd* \add أَ\add* أَربِّي إِنُو، نشّْ تّشْڒغْ خَاكْ.  
\m أجّْ أَيِي وَارْ تّْسضْحِيغْ،  
\m أجّْ ڒْعذْيَانْ إِنُو  
\m وَارْ خَافِي تّسْڒِيوْڒِيونْ س ڒفْرَاحثْ. \x ◘ \xo 25:‏2 \xt إِزهد. 22‏:‏6؛ 31‏:‏2؛ 34‏:‏6\x*   
\m
\v 3 \bd ڭِيملْ.\bd* وَاهْ، مَارَّا إِنِّي شكْ إِتّْرَاجَانْ  
\m وَارْ تّْسضْحِينْ.  
\m إِنِّي إِڭِّينْ س ڒغْذَارْ بْڒَا سِّيبّثْ،  
\m أَذْ سضْحنْ. \x ◘ \xo 25:‏3 \xt إِشا. 28‏:‏16؛ رُوم. 10‏:‏11\x*   
\m
\v 4 \bd ذَالِيثْ.\bd* \add أَ\add* سِيذِي، سْشنْ أَيِي إِبْرِيذنْ نّشْ،  
\m سْغَارْ أَيِي إِمسْرَاقْ نّشْ. \x ◘ \xo 25:‏4 \xt إِزهد. 27‏:‏11؛ 86‏:‏11\x*   
\m
\v 5 \bd هِي.\bd* نْذهْ أَيِي ذِي ثِيذتّْ نّشْ ؤُ سْغَارْ أَيِي،  
\m مِينْزِي شكْ ذ أَربِّي ن ؤُسنْجمْ إِنُو،  
\m نشّْ سِّيثِيمغْ ذَايكْ أَسّْ مَارَّا.   
\m
\v 6 \bd زَايِينْ.\bd* عْقڒْ، \add أَ\add* سِيذِي، خْ أَرّحْمثْ نّشْ،  
\m خْ ثْمڭَّا ن ثْمخْسِيوْثْ نّشْ إِشوَّارنْ،  
\m مَاغَارْ أَقَا أَثنْثْ \add دْجَانْثْ\add* زِي ڒبْذَا. \x ◘ \xo 25:‏6 \xt إِزهد. 103‏:‏17؛ 106‏:‏1؛ 107‏:‏1؛ 117‏:‏2، 136؛ إِرْم. 33‏:‏11\x*   
\m
\v 7 \bd خِيثْ.\bd* وَارْ تِّيذَارْ شَا دّْنُوبْ ن ثمْژِي إِنُو  
\m ؤُڒَا ذ إِخطَّانْ إِنُو.  
\m خمّْ \add مَاشَا\add* غَارِي  
\m ذِي ثْمخْسِيوْثْ نّشْ إِشوَّارنْ،  
\m ذِي طّْوعْ ن ثْشُونِي نّشْ، \add أَ\add* سِيذِي.   
\m
\v 8 \bd ثِيث.\bd* سِيذِي إِصْبحْ، إِشْنَا،  
\m خْ ؤُيَا أَذْ إِسّْغَارْ أَبْرِيذْ إِ إِمذْنَابْ.   
\m
\v 9 \bd يُوذْ.\bd* نتَّا أَذْ إِڭوّذْ إِمْهِيننْ س ڒْحقّْ،  
\m نتَّا أَذْ إِسّڒْمذْ أَبْرِيذْ نّسْ إِ إِمْهِيننْ.   
\m
\v 10 \bd كَافْ.\bd* مَارَّا إِمسْرَاقْ ن سِيذِي  
\m أَقَا أَثنْ ذ ثَامخْسِيوْثْ إِشوَّارنْ ذ ڒَامَانْ،  
\m إِ يِينِّي إِحطَّانْ ڒْعَاهْذْ نّسْ  
\m ذ شَّاهَاذَاثْ نّسْ.   
\m
\v 11 \bd لَامِيذْ.\bd* ذِي طّْوعْ ن يِيسمْ نّشْ، \add أَ\add* سِيذِي،  
\m غْفَارْ ڒْمُوعْصِييّثْ إِنُو،  
\m مَاغَارْ أَقَا-ت ذ أَطَّاسْ.   
\m
\v 12 \bd مِيمْ.\bd* مَانْ ونْ ذ أَرْيَازْ  
\m إِ إِتّڭّْوذنْ سِيذِي؟  
\m نتَّا أَذْ أَسْ إِسّڒْمذْ أَبْرِيذْ  
\m إِ إِتّْخصَّا أَذْ إِخْضَارْ.   
\m
\v 13 \bd نُونْ.\bd* ڒعْمَارْ نّسْ أَذْ إِسّنْسْ ذِي ڒْخِيرْ،  
\m ثَارْوَا نّسْ أَذْ ثْوَارْثْ ثَامُّورْثْ.   
\m
\v 14 \bd سَامِيخْ.\bd* ڒَامَانْ إِ ذِينْ ن سِيذِي  
\m إِ يِينِّي زَّايسْ إِتّڭّْوذنْ،  
\m ڒْْعَاهْذْ نّسْ أَقَا-ث ذِينْ  
\m مَاحنْذْ أَذْ أَسنْ ث إِسَّارْڭبْ.   
\m
\v 15 \bd عَايِينْ.\bd* ثِيطَّاوِينْ إِنُو ڒبْذَا ذِي سِيذِي،  
\m مِينْزِي \bd نتَّا\bd* أَذْ إِفكّْ إِضَارنْ إِنُو زِي ثْرَاشَّا.   
\m
\v 16 \bd بِي.\bd* أَرّْ-د غَارِي س وُوذمْ نّشْ، حِينّْ خَافِي،  
\m مَاغَارْ نشّْ أَقَا أَيِي وحّْذِي ؤُ ذِي ڒغْبنْ.   
\m
\v 17 \bd ثْسَاذِي.\bd* ڒحْصَارَاثْ ن وُوڒْ إِنُو  
\m أَقَا مَّارْنِينْثْ.  
\m سُوفّغْ أَيِي زِي دِّيقَاثْ إِ ذ أَيِي.   
\m
\v 18 \bd رِيخْ.\bd* خْزَارْ-د غَارْ ڒغْبنْ إِنُو ذ وَارْبرْ إِنُو،  
\m كْسِي خَافِي مَارَّا دّْنُوبْ إِنُو.   
\m
\v 19 \bd رِيخْ.\bd* خْزَارْ غَارْ ڒْعذْيَانْ إِنُو،  
\m مِينْزِي تّْوَاكتَّارنْ،  
\m نِيثْنِي شَارّْهنْ أَيِي س يِيجّْ ن وشْرَاهْ إِقسْحنْ.   
\m
\v 20 \bd شِينْ.\bd* حْضَا خْ ڒعْمَارْ إِنُو ؤُ فكّْ أَيِي!  
\m وَارْ ذ أَيِي تّجِّي شَا أَذْ سضْحِيغْ،  
\m مِينْزِي غَاركْ إِ غَا أَركّْوَاڒغْ.   
\m
\v 21 \bd ثَافْ.\bd* أَذْ ثحْضَا أَيِي ڒكْمَارثْ ذ ڒصْفَايثْ،  
\m مَاغَارْ سِّيثِيمغْ ذَايكْ.   
\m
\v 22 \add أَ\add* أَربِّي، فْذِي إِسْرَائِيل زِي مَارَّا ڒحْصَارَاثْ نّسْ.   
\b  
\b  
\m  
\c 26
\m
\v 1 \add أَزهّذْ ن ذَاوُوذْ.\add*  
\b  
\m أَغْ أَيِي ثَاسْغَارْثْ إِنُو، \add أَ\add* سِيذِي،  
\m مَاغَارْ \bd نشّْ\bd* ڭُّورغْ ذِي ڒصْفَايثْ إِنُو.  
\m نشّْ تّشْڒغْ خْ سِيذِي،  
\m وَارْ تّفْرِيغغْ شَا. \x ◘ \xo 26:‏1 \xt إِزهد. 7‏:‏9\x*   
\m
\v 2 قدْجبْ أَيِي، \add أَ\add* سِيذِي، جَارّبْ أَيِي،  
\m سصْفَا ثِيژَّاڒْ إِنُو ذ وُوڒْ إِنُو. \f ◼ \fr 26:‏2 \ft \+bd ’ثِيژَّاڒْ‘\+bd* - نِيغْ ’ثِيڭژْڒِينْ‘.\f*   
\m
\v 3 مِينْزِي ثَامخْسِيوْثْ نّشْ إِشوَّارنْ  
\m أَقَا-ت زَّاثْ إِ ثِيطَّاوِينْ إِنُو،  
\m نشّْ ڭُّورغْ ذِي ثِيذتّْ نّشْ.   
\b  
\m
\v 4 نشّْ وَارْ تّْغِيمِيغْ  
\m أَكْ-ذ إِرْيَازنْ وَارْ إِسكّْوِينْ،  
\m وَارْ تّْمُونغْ أَكْ-ذ يِينِّي إِشمّْثنْ. \x ◘ \xo 26:‏4 \xt أَيُوبْ 31‏:‏5؛ إِزهد. 1‏:‏1\x*   
\m
\v 5 نشّْ شَارّْهغْ أَڭْرَاوْ ن ثَارْوَا ن ڒهْرَامْ،  
\m وَارْ تّْغِيمِيغْ أَكْ-ذ إِعفَّاننْ.   
\b  
\m
\v 6 نشّْ سِّيرِيذغْ إِفَاسّنْ إِنُو  
\m أَمْ وَارْ ذَايِي ڒْعِيبْ،  
\m تّنّْضغْ إِ ؤُعَالْطَارْ نّشْ،  
\m \add ڒْمذْبحْ نّشْ ن وشْمَاضْ\add*، \add أَ\add* سِيذِي،   
\m
\v 7 مَاحنْذْ أَذْ سّْڭعّْذغْ  
\m ثْمِيجَّا ثشُّورْ س ؤُقَاذِي،  
\m مَاحنْذْ أَذْ بَارّْحغْ س مَارَّا لْمُوعْجِيزَاثْ نّشْ.   
\m
\v 8 \add أَ\add* سِيذِي، نشّْ تّخْسغْ  
\m ثَازذِّيغْثْ ن ثَادَّارْثْ نّشْ،  
\m ؤُڒَا ذ أَمْشَانْ ن ثْزذِّيغْثْ ن ؤُعُودْجِي نّشْ.   
\b  
\m
\v 9 وَارْ سْمُونَا ڒعْمَارْ إِنُو أَكْ-ذ إِمذْنَابْ،  
\m ؤُڒَا ذ ثُوذَارْثْ إِنُو غَارْ إِرْيَازنْ  
\m \add إِ إِسَّازَّاڒنْ\add* إِذَامّنْ.   
\m
\v 10 إِنِّي غَارْ إِدْجَا إِفَاسّنْ نْسنْ  
\m \add شُّورنْ س\add* ثُوعفّْنَا،  
\m أَفُوسْ نْسنْ أَفُوسِي \add إِشُّورْ\add* س ڒْغشّْ.   
\m
\v 11 \bd نشّْ\bd* ڭُّورغْ ذِي ڒصْفَايثْ إِنُو،  
\m فْذِي أَيِي ؤُ حِينّْ خَافِي.   
\b  
\m
\v 12 أَضَارْ إِنُو إِبدّْ خْ ثمُّورْثْ إِوَاطَانْ.  
\m نشّْ أَذْ بَارْكغْ سِيذِي ذِي ثْمسْمُونِينْ.   
\b  
\b  
\m  
\c 27
\m
\v 1 \add أَزهّذْ ن ذَاوُوذْ.\add*  
\b  
\m سِيذِي ذ ثَافَاوْثْ إِنُو ذ ؤُسنْجمْ إِنُو،  
\m وِي زِي غَا ڭّْوذغْ؟  
\m سِيذِي ذ لْقلْعَا إِجهْذنْ إِ ثُوذَارْثْ إِنُو،  
\m وِي زِي غَا نّْخڒْعغْ \add عَاذْ\add*؟ \x ◘ \xo 27:‏1 \xt إِشا. 10‏:‏17؛ 60‏:‏19، 20؛ مِيخَا 7‏:‏8؛ لك. 1‏:‏79؛ يُوح. 1‏:‏4؛ 8‏:‏12؛ أَسَا. 21‏:‏23\x*   
\m
\v 2 ؤُمِي غَارِي د-قَارّْبنْ إِعفَّاننْ  
\m حِيمَا أَذْ شّنْ دَّاثْ إِنُو،  
\m إِنِّي ذ أَيِي إِحصَّارنْ ذ ڒْعذْيَانْ إِنُو،  
\m نّْقَارْضنْ نِيثْنِي، وْضَانْ \add غَارْ ثمُّورْثْ\add*.   
\m
\v 3 وَاخَّا أَذْ خَافِي إِحْجمْ إِجّْ ن ڒْعسْكَارْ،  
\m ؤُڒْ إِنُو وَارْ إِتّڭّْوذْ شَا.  
\m وَاخَّا أَذْ خَافِي إِكَّارْ ؤُمنْغِي،  
\m \add عَاذْ\add* نشّْ تّْغِيمِيغْ تّشْڒغْ. \x ◘ \xo 27:‏3 \xt لك. 10‏:‏42؛ فِيل. 3‏:‏14\x*   
\b  
\m
\v 4 إِشْثْ ن ڒْحَاجّثْ تَّارغْ زِي سِيذِي،  
\m ثَا أَذْ خَاسْ أَرْزُوغْ:  
\m مِينْ غَا كّغْ دَّارغْ أَذْ قِّيمغْ  
\m أَذْ زذْغغْ ذِي ثَادَّارْثْ ن سِيذِي،  
\m حِيمَا أَذْ ژَترغْ ڒضْرَافثْ ن سِيذِي،  
\m حِيمَا أَذْ بقْشغْ  
\m ذِي زَّاوشْثْ نّسْ ثَامقّْرَانْثْ.   
\m
\v 5 مَاغَارْ نتَّا إِسّْذُورُّويْ أَيِي  
\m ذڭْ ؤُعُوشِّي نّسْ  
\m ذڭْ وَاسّْ ن ڒْغَارْ.  
\m نتَّا إِسّْڒقَّا أَيِي  
\m ذڭْ ؤُسڒْقِي ن ؤُقِيضُونْ نّسْ،  
\m نتَّا إِسّْڭعَّاذْ أَيِي خْ إِشْثْ ن ثصْضَارْثْ.   
\b  
\m
\v 6 ڒخُّو أَذْ إِتّْوَاسّْڭعّذْ ؤُزدْجِيفْ إِنُو  
\m خْ ڒْعذْيَانْ إِنُو إِنِّي ذ أَيِي د-إِنّْضنْ،  
\m غَارْ وسْرُودّحْ \add ذِي ڒْبُوقْ\add* أَذْ أَوْيغْ ثِيغَارْصَا  
\m غَارْ ؤُقِيضُونْ نّسْ،  
\m أَذْغنّْجغْ، \add وَاهْ،\add* أَذْ زهّْذغْ إِ سِيذِي.   
\b  
\m
\v 7 سڒْ غَارْ ثْمِيجَّا إِنُو، \add أَ\add* سِيذِي، خْمِي غَا ڒَاغِيغْ،  
\m حِينّْ خَافِي ؤُ أَرّْ-د خَافِي.   
\m
\v 8 زَّايكْ إِ إِسَّاوَاڒْ وُوڒْ إِنُو:  
\m ”أَرْزُو خْ وُوذمْ إِنُو!“  
\m نشّْ أَرزُّوغْ خْ وُوذمْ نّشْ، \add أَ\add* سِيذِي.   
\b  
\m
\v 9 وَارْ زَّايِي تّفَّارْ ؤُذمْ نّشْ،  
\m وَارْ تّْخِييَّابْ أَمْسخَّارْ نّشْ  
\m ذڭْ وغْضَابْ.  
\m ثُوغَا شكْ ذ أَمْعَاونْ إِنُو.  
\m وَارْ ذ أَيِي تّْسمْحذْ ؤُ وَارْ ذ أَيِي تّجِّي،  
\m \add أَ\add* أَربِّي ن ؤُسنْجمْ إِنُو.   
\m
\v 10 مَاغَارْ بَابَا ذ يمَّا أَقَا سمْحنْ ذَايِي،  
\m \add مَاشَا\add* سِيذِي أَذْ أَيِي إِكْسِي \add غَارسْ\add*.   
\b  
\m
\v 11 سْشنْ أَيِي أَبْرِيذْ نّشْ، \add أَ\add* سِيذِي،  
\m نْذهْ أَيِي غَارْ وبْرِيذْ إِسڭّْمنْ،  
\m ذِي سِّيبّثْ ن يِينِّي ذ أَيِي إِحصَّارنْ. \x ◘ \xo 27:‏11 \xt إِزهد. 25‏:‏4؛ 86‏:‏11؛ 119‏:‏27\x*   
\m
\v 12 وَارْ ذ أَيِي تّْسلّمْ غَارْ \add مژْرِي\add*  
\m \add ذڭْ\add* ڒعْمَارْ ن يِينِّي ذ أَيِي إِحصَّارنْ،  
\m مَاغَارْ ڒشْهُوذْ إِسّْخَارِّيقنْ كَّارنْ خَافِي،  
\m إِنِّي \add إِ خَافِي\add* إِتّْسُوضنْ س ڒخْشُونثْ.   
\b  
\m
\v 13 \add ؤُهْ\add*، مَاڒَا نشّْ زعْمَا  
\m وَارْ ؤُمِينغْ أَذْ ژَترغْ ڒْخَارْ ن سِيذِي  
\m ذِي ثمُّورْثْ ن يِينِّي إِدَّارنْ!   
\m
\v 14 رَاجَا سِيذِي، رَاجَا إِ-ث، إِڒِي ذ أَرْيَازْ،  
\m نتَّا أَذْ ذَايكْ يڭّْ ؤُڒْ،  
\m \add وَاهْ\add* رَاجَا سِيذِي. \x ◘ \xo 27:‏14 \xt إِشا. 25‏:‏9؛ 33‏:‏2؛ حَاب. 2‏:‏3\x*   
\b  
\b  
\m  
\c 28
\m
\v 1 \add ن ذَاوُوذْ.\add*  
\b  
\m إِ شكْ ؤُمِي ڒَاغِيغْ،  
\m \add أَ\add* سِيذِي، أَقَا شكْ ذ ثَاصْضَارْثْ إِنُو.  
\m وَارْ تّڭّْ شَا إِخفْ نّشْ  
\m وَارْ غَارِي ثتّسْڒِيذْ،  
\m أَڒَامِي، س وسْقَارْ نّشْ زَّاثِي،  
\m وَارْ تَّاركّْوِيسغْ  
\m أَكْ-ذ يِينِّي د-إِهكّْوَانْ ذڭْ ونْضڒْ. \x ◘ \xo 28:‏1 \xt إِزهد. 30‏:‏4؛ 143‏:‏7\x*   
\m
\v 2 سڒْ إِ ثْمِيجَّا ن ثُوثْرَا إِنُو،  
\m خْمِي خَاكْ تّْڒَاغِيغْ،  
\m خْمِي كسِّيغْ إِفَاسّنْ إِنُو  
\m غَارْ وخَّامْ \add ن ذَاخڒْ\add*  
\m ن زَّاوشْثْ نّشْ إِقدّْسنْ.   
\m
\v 3 وَارْ ذ أَيِي تّْجَارِّي أَكْ-ذ إِعفَّاننْ،  
\m أَكْ-ذ يِينِّي إِتّڭّنْ ڒْمُوعْصِييّثْ،  
\m إِنِّي إِسَّاوَاڒنْ خْ ڒهْنَا  
\m أَكْ-ذ جِّيرَانْ نْسنْ،  
\m أَمْ غَارْسنْ إِدْجَا ڒْغَارْ ذڭْ وُوڒْ نْسنْ. \x ◘ \xo 28:‏3 \xt إِزهد. 12‏:‏3؛ إِرْم. 9‏:‏7\x*   
\m
\v 4 خدْجصْ أَسنْ عْلَاحْسَابْ مِينْ تّڭّنْ،  
\m عْلَاحْسَابْ ثُوعفّْنَا ن ثْمڭَّا نْسنْ.  
\m خدْجصْ أَسنْ  
\m عْلَاحْسَابْ ڒْخذْمثْ ن إِفَاسّنْ نْسنْ،  
\m أوْشْ أَسنْ ڒْمُونثْ نْسنْ إِ إِسْذَاهدْجنْ،   
\m
\v 5 مِينْزِي نِيثْنِي وَارْ خزَّارنْ  
\m غَارْ ڒفْعَايڒْ ن سِيذِي،  
\m ؤُڒَا غَارْ ڒْخذْمثْ ن إِفَاسّنْ نّسْ.  
\m نتَّا أَذْ ثنْ إِغْضڒْ، وَارْ ثنْ إِبنِّي شَا.   
\b  
\m
\v 6 أَذْ إِتّْوَابَاركْ سِيذِي،  
\m مَاغَارْ نتَّا إِسْڒَا إِ ثْمِيجَّا ن ثُوثْرَا إِنُو.   
\m
\v 7 سِيذِي ذ ڒْعزّْ إِنُو  
\m ذ ثَاسدَّارْثْ إِنُو ن ؤُسڒْقِي،  
\m ؤُڒْ إِنُو إِتّْشڒْ خَاسْ ؤُشَا تّْوَاعَاوْنغْ.  
\m ؤُڒْ إِنُو إِنڭّزْ س ڒفْرَاحثْ،  
\m س يزْڒِي إِنُو أَذْ ث قَاذِيغْ.   
\m
\v 8 سِيذِي ذ جّهْذْ نْسنْ،  
\m نتَّا ذ لْبُورْجْ إِجهْذنْ ن إِسنْجِيمنْ  
\m إِ ؤُمذْهُونْ نّسْ.   
\m
\v 9 سنْجمْ ڒْڭنْسْ نّشْ، بَاركْ ثَاسْغَارْثْ نّشْ،  
\m أَرْوسْ إِ-ثنْ ؤُ أَرْبُو ثنْ إِ ڒبْذَا قَاعْ.   
\b  
\b  
\m  
\c 29
\m
\v 1 \add أَزهّذْ ن ذَاوُوذْ.\add*  
\b  
\m وْشمْ إِ سِيذِي، أَرَّاوْ ن إِربِّيثنْ،  
\m وْشمْ إِ سِيذِي أَعُودْجِي ذ ثْزمَّارْ. \x ◘ \xo 29:‏1 \xt إِزهد. 96‏:‏7، 8\x*   
\m
\v 2 وْشمْ إِ سِيذِي أَعُودْجِي ن يِيسمْ نّسْ،  
\m بنْذْقمْ زَّاثْ إِ سِيذِي  
\m ذِي ڒْعزّْ ن زَّاوشْثْ إِقدّْسنْ.   
\b  
\m
\v 3 \bd ثْمِيجَّا ن سِيذِي\bd* \add ثدَّارْضحْ\add* ثِيوَا إِ وَامَانْ،  
\m أَربِّي ن ؤُعُودْجِي إِسّْهمْهمْ،  
\m سِيذِي، خْ وَامَانْ أَطَّاسْ. \x ◘ \xo 29:‏3 \xt ؤُف. 9‏:‏23\x*   
\m
\v 4 \bd ثْمِيجَّا ن سِيذِي\bd* \add ثشُّورْ س\add* جّهْذْ،  
\m \bd ثْمِيجَّا ن سِيذِي\bd* \add ثشُّورْ س\add* ڒْعزّْ.   
\b  
\m
\v 5 \bd ثْمِيجَّا ن سِيذِي\bd* ثتَّارژَّا  
\m \add ثِيشجُّورَا ن\add* ثْنڭْلِينْ،  
\m سِيذِي إِتَّارژَّا ثِينڭْلِينْ ن لُوبْنَانْ.   
\m
\v 6 يَارَّا إِ-ثنْ أَذْ نڭْزنْ أَمْ ؤُعجْمِي،  
\m \add أَذْرَارْ ن\add* لُوبْنَانْ ذ \add وذْرَارْ ن\add* سِيرْيُونْ،  
\m أَمْ ؤُمژْيَانْ ن إِغَايْضْ ن ڒخْڒَا  
\m أَكْ-ذ وَاشَّاونْ ذ إِزِيرَارنْ. \f ◼ \fr 29:‏6 \ft \+bd ’أَفُونَاسْ ن ڒخْڒَا‘\+bd* - نِيغْ ’أَينْذُوزْ ن ڒخْڒَا‘.\f*   
\m
\v 7 \bd ثْمِيجَّا ن سِيذِي\bd* ثْنقّشْ  
\m إِشعَّاڒنْ ن ثْمسِّي.   
\b  
\m
\v 8 \bd ثْمِيجَّا ن سِيذِي\bd* ثَارَّا ڒخْڒَا إِتَّارْجِيجِي،  
\m سِيذِي يَارَّا ڒخْڒَا ن قَاذَاشْ إِتَّارْجِيجِي.   
\m
\v 9 \bd ثْمِيجَّا ن سِيذِي\bd* ثَارَّا ثُوذَاذِينْ تَّارْونْثْ،  
\m نتَّا إِتّْعَارَّا إِزغْرَانْ،  
\m \add مَاشَا\add* ذِي زَّاوشْثْ نّسْ ثَامقّْرَانْثْ  
\m مَارَّا ثسَّاوَاڒْ خْ ؤُعُودْجِي نّسْ.   
\b  
\m
\v 10 سِيذِي ثُوغَا إِتّْغِيمَا \add أَمْ ڒْقَاضِي\add*  
\m غَارْ سّحْڒثْ ن وَامَانْ،  
\m سِيذِي إِتّْغِيمَا \add أَمْ\add* ؤُجدْجِيذْ إِ ڒبْذَا. \f ◼ \fr 29:‏10 \ft \+bd ’ڒْقَاضِي‘\+bd* - نِيغْ ’أَمزْرُوفْ‘.\f*   
\m
\v 11 سِيذِي أَذْ إِوْشْ جّهْذْ إِ ڒْڭنْسْ نّسْ،  
\m سِيذِي أَذْ إِبَاركْ ڒْڭنْسْ نّسْ س ڒهْنَا.   
\b  
\b  
\m  
\c 30
\m
\v 1 \add أَزهّذْ. إِزْڒِي إِ ؤُذشّنْ ن ثَادَّارْثْ. ن ذَاوُوذْ.\add*   
\b  
\m
\v 2 نشّْ أَذْ شكْ سُّوعْڒِيغْ، \add أَ\add* سِيذِي،  
\m مَاغَارْ شكْ ثسّْڭعّْذذْ أَيِي،  
\m وَارْ ثجِّيذْ شَا ڒْعذْيَانْ إِنُو  
\m أَذْ فَارْحنْ خْ وعْرُورْ إِنُو.   
\m
\v 3 \add أَ\add* سِيذِي، أَربِّي إِنُو، نشّْ ڒَاغِيغْ أَشْ،  
\m ؤُشَا شكْ ثسّْڭنْفِيذْ أَيِي.   
\m
\v 4 \add أَ\add* سِيذِي، شكْ ثسُّوعْڒِيذْ ڒعْمَارْ إِنُو  
\m زِي ڒَاخَارْثْ،  
\m ثَارِّيذْ أَيِي-د غَارْ ثُوذَارْثْ  
\m جَارْ يِينِّي د-إِهكّْوَانْ ذڭْ وحْفُورْ.   
\b  
\m
\v 5 زهّْذمْ إِ سِيذِي،  
\m \add أَ كنِّيوْ،\add* إِمْثِيقَّانْ نّسْ،  
\m قَاذَامْ،عقْڒمْ خْ ثْقدَّاسْثْ نّسْ. \x ◘ \xo 30:‏5 \xt إِزهد. 97‏:‏12\x*   
\m
\v 6 مَاغَارْ أَغْضَابْ نّسْ \add إِتّكّْ\add* ذْرُوسْ \add وَاهَا\add*،  
\m مَاشَا أَرْضَا نّسْ إِتّْغِيمَا \add مَارَّا\add* ثُوذَارْثْ.  
\m ذِي ثْمذِّيثْ أَقَا ذِينْ إِمطَّاونْ أَڒْ دْجِيڒثْ،  
\m \add مَاشَا\add* غَارْ ثُوفُّوثْ أَقَا ذِينْ أَسْڒِيوْڒوْ.   
\b  
\m
\v 7 ذڭْ ؤُفْڒَاحْ إِنُو نِّيغْ \bd نشّْ\bd*:  
\m ”وَارْ تّْفَارِيغغْ شَا إِ ڒبْذَا!“   
\m
\v 8 \add أَ\add* سِيذِي، ذِي ڒْخَاضَارْ نّشْ  
\m ثسّْمثْنذْ أَذْرَارْ إِنُو  
\m س ؤُمتّنْ إِجهْذنْ،  
\m \add مَاشَا\add* ؤُمِي ثْڒحّْفذْ ؤُذمْ نّشْ،  
\m ذوْڒغْ تّڭّْوذغْ.   
\b  
\m
\v 9 نشّْ ڒَاغِيغْ أَشْ-د، \add أَ\add* سِيذِي،  
\m تَّارغْ أَرْضَا زِي سِيذِي إِنُو.   
\m
\v 10 مَانْ ڒفْضڒْ نْ إِذَامّنْ إِنُو،  
\m ن ؤُهكّْوُو إِنُو غَارْ ثُورْصُوضِي \add ذڭْ ونْضڒْ\add*؟  
\m مَا أَذْ شكْ ثْقَاذَا ثْعجَّاجْثْ؟  
\m مَا أَذْ ثْبَارّحْ س ڒَامَانْ نّشْ؟   
\m
\v 11 سڒْ-د غَارِي، \add أَ\add* سِيذِي، حِينّْ خَافِي،  
\m \add أَ\add* سِيذِي، إِڒِي ذ أَمْعَاونْ إِنُو.   
\b  
\m
\v 12 شكْ أَقَا ثَارِّيذْ ثْغُويِّيثْ إِنُو \add ن وشْضَانْ\add*  
\m ذ شّْضِيحْ س نُّوبْثَاثْ،  
\m ثسَّارْخُوذْ ثَاخَانْشثْ إِنُو \add ن وشْضَانْ\add*،  
\m ثسّْبيْسذْ أَيِي س ڒفْرَاحثْ،   
\m
\v 13 حِيمَا أَعُودْجِي \add إِنُو\add*  
\m أَذْ أَشْ إِزهّذْ ؤُ وَارْ إِتّْسُوسُومْ.  
\m \add أَ\add* سِيذِي، أَربِّي إِنُو،  
\m نشّْ أَذْ شكْ قَاذِيغْ إِ ڒبْذَا.   
\b  
\b  
\m  
\c 31
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. أَزهّذْ ن ذَاوُوذْ.\add*   
\b  
\m
\v 2 نشّْ أَركّْوَاڒغْ غَاركْ، \add أَ\add* سِيذِي،  
\m وَارْ تّجِّي أَذْ سضْحِيغْ إِ ڒبْذَا،  
\m فكّْ أَيِي س ثْسڭْذَا نّشْ. \x ◘ \xo 31:‏2 \xt إِزهد. 22‏:‏6؛ 25‏:‏2، 3؛ 71‏:‏1، 2؛ إِشا. 49‏:‏23\x*   
\m
\v 3 أوْشْ أَيِي أَمزُّوغْ نّشْ، فكّْ أَيِي ذغْيَا.  
\m إِڒِي ذ ثَاصْضَارْثْ إِجهْذنْ إِ نشّْ،  
\m إِجّْ ن لْبُورْجْ حِيمَا أَذْ أَيِي ثسّْنجْمذْ.   
\m
\v 4 مَاغَارْ شكْ ذ ثَاصْضَارْثْ إِنُو ذ لْبُورْجْ إِنُو.  
\m نْذهْ أَيِي، ثْهِيلَّا ذَايِي  
\m ذِي طّْوعْ ن يِيسمْ نّشْ.   
\m
\v 5 فكّْ أَيِي زِي ثْرَاشَّا  
\m نِّي خَافِي ڭِّينْ س ثْنُوفّْرَا،  
\m مَاغَارْ شكْ ذ جّهْذْ إِنُو.   
\m
\v 6 ذڭْ ؤُفُوسْ نّشْ إِ ڭِّيغْ بُوحْبڒْ  إِنُو.  
\m شكْ ثفْذِيذْ أَيِي، \add أَ\add* سِيذِي، أَربِّي،  
\m ذ أَمْثِيقِّي \add إِ ثدْجِيذْ\add*. \x ◘ \xo 31:‏6 \xt لك. 23‏:‏46\x*   
\m
\v 7 نشّْ شَارّْهغْ إِنِّي إِتّْشغْڒنْ إِخفْ نْسنْ  
\m س \add ڒخْيَاڒَاثْ\add* إِبطّْڒنْ.  
\m \bd نشّْ\bd* تّشْڒغْ خْ سِيذِي.   
\m
\v 8 نشّْ أَذْ أَرشْقغْ ؤُ أَذْ فَارْحغْ  
\m زِي ثْمخْسِيوْثْ نّشْ إِشوَّارنْ،  
\m مِينْزِي شكْ ثتّْوَاڒِيذْ ڒغْبنْ إِنُو  
\m \add ؤُ\add* ثَارڭّْبذْ خْ ڒحْصَارَاثْ إِنُو،   
\m
\v 9 \add مِينْزِي\add* وَارْ ذ أَيِي ثَارِّيذْ  
\m غَارْ ؤُفُوسْ ن ڒعْذُو إِنُو،  
\m \add مَاشَا\add* ثڭِّيذْ أَيِي تَّاسِيعْ غَارْ إِضَارنْ إِنُو.   
\b  
\m
\v 10 حِينّْ خَافِي، \add أَ\add* سِيذِي، مَاغَارْ تّْوَاحصَّارغْ،  
\m ثِيطّْ إِنُو ذ ڒعْمَارْ إِنُو ذ ثكْرِيشْثْ إِنُو  
\m أَقَا فشْڒنْ.   
\m
\v 11 مَاغَارْ ثُوذَارْثْ إِنُو ثْكمّڒْ س وشْضَانْ،  
\m إِسڭّْوُوسَا إِنُو س ؤُزهَّارْ.  
\m جّْهذْ إِنُو إِهيّفْ زِي ڒْمُوعْصِييّثْ إِنُو،  
\m إِخْسَانْ إِنُو أَقَا أَرْشَانْ.   
\m
\v 12 إِ مَارَّا إِنِّي ذ أَيِي إِحصَّارنْ  
\m ذوْڒغْ ذ أَسْثهْزِي،  
\m إِ جِّيرَانْ إِنُو \add قَاعْ\add* أَطَّاسْ،  
\m إِ يِينِّي ذ أَيِي إِسّْننْ  
\m \add ذوْڒغْ\add* ذ إِجّنْ إِ إِسّْنخْڒِيعنْ.  
\m إِنِّي ذ أَيِي إِتّْوَاڒِينْ ذڭْ وبْرِيذْ،  
\m تّْرَاكّْوَاڒنْ زَّايِي. \x ◘ \xo 31:‏12 \xt أَيُوبْ 19‏:‏13؛ إِزهد. 38‏:‏12\x*   
\m
\v 13 تُّونْ أَيِي س وُوڒْ أَمْ يِيجّْ ن ؤُمتِّينْ،  
\m ذوْڒغْ أَمْ يِيشقْفَانْ ن وقْذِيحْ،   
\m
\v 14 مَاغَارْ سْڒِيغْ أَقَا أَطَّاسْ شقّْفنْ \add ذَايكْ\add*،  
\m أَسِّيڭّْوذْ ثُوغَا إِتّنّضْ أَيِي-د  
\m ؤُمِي خَافِي ڭِّينْ ثَامعْمُوتْشْ.  
\m ثُوغَا أَرزُّونْ أَذْ كّْسنْ ثُوذَارْثْ إِنُو.   
\b  
\m
\v 15 \add مَاشَا\add* \bd نشّْ\bd* تّشْڒغْ خَاكْ، \add أَ\add* سِيذِي،  
\m قَّارغْ: ’شكْ ذ أَربِّي إِنُو!‘   
\m
\v 16 ڒْوقْثْ إِنُو أَقَا-ت ذڭْ ؤُفُوسْ نّشْ.  
\m فكّْ أَيِي زڭْ ؤُفُوسْ ن ڒْعذْيَانْ إِنُو  
\m ؤُ زڭْ إِنِّي ذ أَيِي إِضفَّارنْ،   
\m
\v 17 أجّْ ؤُذمْ نّشْ أَذْ يَارْغْ  
\m خْ ؤُمْسخَّارْ نّشْ،  
\m سنْجمْ أَيِي س ثْمخْسِيوْثْ نّشْ إِشوَّارنْ.   
\m
\v 18 \add أَ\add* سِيذِي، وَارْ تّجِّي أَذْ ذوْڒغْ تّْسضْحِيغْ،  
\m مَاغَارْ خَاكْ إِ تّْڒَاغِيغْ.  
\m أَرّْ إِعفَّاننْ أَذْ ذوْڒنْ تّْسضْحَانْ،  
\m أَرّْ إِ-ثنْ أَذْ سُّوسْمنْ ذِي ڒَاخَارْثْ.   
\m
\v 19 أجّْ أَذْ سْقَارنْ إِينْشِيشنْ إِسّْخَارِّيقنْ،  
\m إِنِّي إِسَّاوَاڒنْ س نّْفَاخثْ  
\m ضِيدّْ إِ ؤُمْسڭّذْ،  
\m س ؤُعفَّارْ ذ ؤُسحْقَارْ.   
\b  
\m
\v 20 مشْحَاڒْ إِمقَّارْ ڒْخَارْ نّشْ إِ ثْخمّْڒذْ  
\m إِ يِينِّي شكْ إِتّڭّْوذنْ،  
\m نِّي ثسّْوجْذذْ إِ يِينِّي غَاركْ يَاركّْوَاڒنْ  
\m زِي ثَارْوَا ن بْنَاذمْ! \x ◘ \xo 31:‏20 \xt إِشا. 64‏:‏3؛ 1 كُور. 2‏:‏9\x*   
\m
\v 21 شكْ ثسّْذُورُّويذْ إِ-ثنْ س ؤُڒحَّافْ  
\m ن وُوذمْ نّشْ،  
\m زِي نّْفَاخثْ ن بْنَاذمْ.  
\m شكْ ثسّْنُوفَّارذْ إِ-ثنْ ذِي ثخْزَانْثْ،  
\m زڭْ ؤُمْشُوبّشْ ن إِينْشِيشنْ.   
\m
\v 22 أَذْ إِتّْوَابَاركْ سِيذِي،  
\m مَاغَارْ نتَّا يَارَّا أَيِي-د  
\m ثَامخْسِيوْثْ نّسْ إِشوَّارنْ ذ ڒعْجبْ،  
\m ذڭْ إِشْثْ ن ثنْذِينْثْ إِفَارْينْ.   
\m
\v 23 نشّْ ذغْيَا نِّيغْ:  
\m ”نشّْ تّْوَاقسّغْ  
\m زِي زَّاثْ إِ ثِيطَّاوِينْ نّشْ!‘  
\m مَاشَا عَاذْ شكْ ثسْڒِيذْ إِ ثْمِيجَّا إِنُو،  
\m ؤُمِي د خَاكْ ڒَاغِيغْ. \x ◘ \xo 31:‏23 \xt يُون. 2‏:‏5\x*   
\m
\v 24 سْعِيزّمْ سِيذِي، مَارَّا إِمْثِيقَّانْ نّسْ،  
\m مَاغَارْ سِيذِي إِحطَّا خْ يِينِّي إِتَّامْننْ،  
\m ؤُ ونِّي إِتّڭّنْ س نّْفَاخثْ،  
\m إِتّْخدْجصْ إِ-ث س أَطَّاسْ.   
\m
\v 25 إِڒِيمْ ذ إِرْيَازنْ  
\m ؤُ نتَّا أَذْ ذَايْومْ يڭّْ ؤُڒْ،  
\m \add وَاهْ\add*، مَارَّا إِنِّي إِتّْرَاجَانْ سِيذِي. \x ◘ \xo 31:‏25 \xt إِزهد. 27‏:‏14\x*   
\b  
\b  
\m  
\c 32
\m
\v 1 \add ن ذَاوُوذْ. أَخمِّي.\add*  
\b  
\m سّعْذْ ن ونِّي  
\m ؤُمِي ثتّْوَاغْفَارْ ثْعذِّيثْ نّسْ،  
\m ونِّي ؤُمِي ذْڒِينْ خْ دّْنُوبْ نّسْ. \x ◘ \xo 32:‏1 \xt رُوم. 4‏:‏6، 7\x*   
\m
\v 2 سّعْذْ ن ورْيَازْ  
\m ونِّي ؤُمِي وَارْ إِحصّبْ سِيذِي  
\m ڒْمُوعْصِييّثْ نّسْ،  
\m ونِّي غَارْ إِدْجَا بُوحْبڒْ وَارْ ذَايسْ بُو ڒْغشّْ.   
\b  
\m
\v 3 ؤُمِي سْقَارغْ، أَرْشَانْ إِغْسَانْ إِنُو،  
\m س ؤُزهَّارْ إِنُو، أَسّْ مَارَّا.   
\m
\v 4 مَاغَارْ أَسّْ ذ دْجِيڒثْ  
\m إِسّذْقڒْ أَيِي ؤُفُوسْ نّشْ،  
\m إِذَامّنْ ن ثُوذَارْثْ إِنُو ذوْڒنْ  
\m \add أَمْ\add* ڒَاژَاغْ ن ؤُنبْذُو. سِيلَاهْ.   
\m
\v 5 سَّارڭْبغْ أَشْ دّنْبْ إِنُو،  
\m وَارْ سّْذُورْيغْ ڒْمُوعْصِييّثْ إِنُو.  
\m نشّْ نِّيغْ:  
\m ”أَذْ نعْمغْ خْ إِخطَّانْ إِنُو غَارْ سِيذِي!“،  
\m \add خنِّي\add* \bd شكْ\bd* ثغْفَارذْ أَيِي  
\m ڒْمُوعْصِييّثْ ن دّنْبْ إِنُو. سِيلَاهْ. \x ◘ \xo 32:‏5 \xt أَوڒن. 28‏:‏13؛ 1 يُوح. 1‏:‏9\x*   
\b  
\m
\v 6 س ؤُينِّي مَارَّا أَمْثِيقِّي أَذْ أَشْ إِسْجذْ  
\m ذِي ڒْوقْثْ ؤُمِي غَا ثجّذْ \add بْنَاذمْ\add*  
\m أَذْ شكْ يُوفَا.  
\m خْمِي ذِينْ إِشْثْ ن سّحْڒثْ ن وَامَانْ أَطَّاسْ،  
\m وَارْ ث ثْڒقّفْ قَاعْ.   
\m
\v 7 شكْ ذ أَمْشَانْ ن ؤُذُورِّي إِ نشّْ،  
\m ثسَّارذْ أَيِي زِي ڒحْصَارثْ،  
\m ثْقُووَّارذْ أَيِي  
\m س إِغُويَّانْ ن ڒفْرَاحثْ ن ؤُفكِّي. سِيلَاهْ. \x ◘ \xo 32:‏7 \xt إِزهد. 27‏:‏5؛ 31‏:‏21\x*   
\b  
\m
\v 8 نشّْ أَذْ شكْ وْشغْ ڒفْهَامثْ  
\m ؤُشَا أَذْ أَشْ سّْڒمْذغْ  
\m أَبْرِيذْ إِتّْخصَّا أَذْ ذَايسْ ثُويُورذْ.  
\m نشّْ أَذْ شكْ وصِّيغْ، أَذْ خَاكْ ثِيڒِي ثِيطّْ إِنُو.   
\m
\v 9 وَارْ تِّيڒِي أَمْ ؤُيِيسْ،  
\m أَمْ ؤُسَارْذُونْ بْڒَا ڒعْقڒْ،  
\m نِّي إِتّْخصَّا أَذْ ثنْ قمّْعنْ  
\m س سّْرِيمثْ ذ ورْيَامْ،  
\m نِيغْ وَارْ إِزمَّارْ أَذْ غَاركْ د-إِقَارّبْ. \x ◘ \xo 32:‏9 \xt أَوڒن. 26‏:‏3؛ يَاع. 3‏:‏3\x*   
\m
\v 10 أَطَّاسْ \add دْجَانْثْ\add* ثَامَارَا ن ؤُعفَّانْ،  
\m \add مَاشَا\add* ونِّي إِتّْشَاڒنْ خْ سِيذِي،  
\m أَذْ أَسْ إِقُووَّارْ نتَّا  
\m س ثْمخْسِيوْثْ نّسْ إِشوَّارنْ.   
\b  
\m
\v 11 فَارْحمْ ذِي سِيذِي، أَرشْقمْ، \add أَ\add* إِمْسڭَّاذنْ،  
\m سْڒِيوڒْومْ، \add أَ\add* مَارَّا  
\m إِنِّي غَارْ إِدْجَا وُوڒْ إِسڭّْمنْ!   
\b  
\b  
\m  
\c 33
\m
\v 1 سْڒِيوڒْومْ إِ سِيذِي، \add أَ\add* إِمْسڭَّاذنْ،  
\m أَصبَّاحْ ذ إِشْثْ ن ثلْوِيزْثْ إِ يِينِّي إِسڭّْمنْ. \x ◘ \xo 33:‏1 \xt إِزهد. 147‏:‏1\x*   
\m
\v 2 قَاذَامْ سِيذِي س ڒْڭَامْبْرِي،  
\m زهّْذمْ أَسْ س لْعُوذْ  
\m ؤُ س لهَارْپَا أَكْ-ذعشْرَا ن إِفِيڒَانْ.   
\m
\v 3 غنّْجمْ أَسْ س يِيجّْ ن يزْڒِي أَمَايْنُو،  
\m إِرَارمْ مْلِيحْ س وسْرُودّحْ \add ن ڒْبُوقْ\add*. \x ◘ \xo 33:‏3 \xt إِزهد. 40‏:‏4؛ 96‏:‏1؛ 98‏:‏1؛ 144‏:‏9؛ إِشا. 42‏:‏10؛ أَسَا. 5‏:‏9؛ 14‏:‏3\x*   
\b  
\m
\v 4 مِينْزِي أَوَاڒْ ن سِيذِي إِسڭّمْ،  
\m مَارَّا مِينْ إِتّڭّْ، \add إِتّڭّْ إِ-ث\add* س ڒَامَانْ.   
\m
\v 5 نتَّا إِتّخْسْ ثَاسڭْذَا ذ ڒْحقّْ.  
\m ثَامُّورْثْ ثشُّورْ  
\m س ثْمخْسِيوْثْ إِشوَّارنْ ن سِيذِي. \x ◘ \xo 33:‏5 \xt إِزهد. 45‏:‏8؛ 119‏:‏64؛ عبر. 1‏:‏9\x*   
\b  
\m
\v 6 زڭْ وَاوَاڒْ ن سِيذِي تّْوَاڭّنْ إِجنْوَانْ،  
\m زِي أَرُّوحْ ن ؤُقمُّومْ نّسْ  
\m \add تّْوَاڭّنْثْ\add* مَارَّا ڒْعسْكَارَاثْ نْسنْ. \x ◘ \xo 33:‏6 \xt أَمز. 1‏:‏6، 7\x*   
\m
\v 7 نتَّا إِسّْمُونْ أَمَانْ ن ڒبْحَارْ  
\m أَمْ يِيجّْ ن وغْبَارْ.  
\m نتَّا إِخمّڒْ \add أَمَانْ\add* إِهوْڒنْ  
\m ذڭْ إِخَّامنْ ن ڒخْزنْ.   
\b  
\m
\v 8 أَذْ ثڭّْوذْ مَارَّا ثَامُّورْثْ زِي سِيذِي،  
\m أَذْ زَّايسْ ڭّْوذنْ  
\m مَارَّا إِمزْذَاغْ ن دُّونشْثْ.   
\m
\v 9 مَاغَارْ \bd نتَّا\bd* إِسَّاوَاڒْ ؤُشَا أَقَا-ث ذِينْ،  
\m \bd نتَّا\bd* إِتَّامَارْ ؤُشَا أَذْ يِيڒِي إِبدّْ ذِينْ.   
\b  
\m
\v 10 سِيذِي إِتَّارژَّا شّْوَارْ ن ڒڭْنُوسْ،  
\m إِسّبْضڒْ إِخَارِّيصنْ نْ ڒڭْنُوسْ. \x ◘ \xo 33:‏10 \xt إِشا. 19‏:‏3\x*   
\m
\v 11 شّْوَارْ ن سِيذِي أَذْ إِقِّيمْ إِبدّْ إِ ڒبْذَا،  
\m إِخَارِّيصنْ ن وُوڒْ نّسْ زِي جِّيڒْ أَڒْ جِّيڒْ. \x ◘ \xo 33:‏11 \xt أَوڒن. 19‏:‏21؛ 21‏:‏30؛ إِشا. 46‏:‏10\x*   
\b  
\m
\v 12 سّعْذْ ن ڒْڭنْسْ  
\m إِ غَارْ إِدْجَا أَربِّي نّسْ ذ سِيذِي،  
\m ڒْڭنْسْ نِّي إِخْضَارْ إِ-ث نتَّا  
\m ذ ثَاسْغَارْثْ إِ يِيخفْ نّسْ.\x ◘ \xo 33:‏12 \xt إِزهد. 65‏:‏5؛ 144‏:‏15\x*   
\m
\v 13 سِيذِي إِخزَّارْ-د زڭْ ؤُجنَّا،  
\m إِتّْوَاڒَا مَارَّا ثَارْوَا ن بْنَاذمْ.   
\b  
\m
\v 14 زِي ثْزذِّيغْثْ نّسْ إِمثْننْ إِخزَّارْ  
\m غَارْ مَارَّا إِمزْذَاغْ ن ثمُّورْثْ.   
\m
\v 15 نتَّا وحّْذسْ  
\m ذ ونِّي إِكوّْننْ ؤُڒْ نْسنْ،  
\m نتَّا إِحكَّارْ إِ مَارَّا ثِيمڭَّا نْسنْ.   
\b  
\m
\v 16 أَجدْجِيذْ وَارْ إِتّْوَاسّنْجَامْ  
\m س يِيجّْ ن ڒْعسْكَارْ ذ أَمقّْرَانْ،  
\m بُو-ثغْرُوضْثْ وَارْ إِتّْوَافكِّي  
\m س جّهْذْ أَطَّاسْ.   
\m
\v 17 أَقَا ذ أَخَارِّيقْ  
\m \add بلِّي\add* أَيِيسْ أَذْ د-يَاوِي أَسنْجمْ،  
\m \add عَاذْ\add* س جّهْذْ نّسْ أَمقّْرَانْ  
\m وَارْ د-إِتّنْفكِّي.   
\b  
\m
\v 18 خْزَارْ، ثِيطّْ ن سِيذِي  
\m خْ يِينِّي زَّايسْ إِتّڭّْوذنْ،  
\m خْ يِينِّي إِتّْرَاجَانْ  
\m ثَامخْسِيوْثْ نّسْ إِشوَّارنْ، \x ◘ \xo 33:‏18 \xt أَيُوبْ 36‏:‏7؛ إِزهد. 34‏:‏16؛ 1 بُط. 3‏:‏12\x*   
\m
\v 19 حِيمَا أَذْ إِفكّْ ڒعْمَارْ نْسنْ زِي ڒْموْثْ،  
\m حِيمَا أَذْ ثنْ يجّْ قِّيمنْ دَّارنْ ذِي ڒَاژْ.   
\b  
\m
\v 20 ڒعْمَارْ نّغْ إِتّْرَاجَا سِيذِي،  
\m أَقَا نتَّا ذ أَعَاونْ نّغْ  
\m ذ ثَاسدَّارْثْ نّغْ إِ ؤُسڒْقِي.   
\m
\v 21 مَاغَارْ زَّايسْ إِفَارّحْ وُوڒْ نّغْ،  
\m مِينْزِي نتّْشَاڒْ خْ يِيسمْ نّسْ إِقدّْسنْ.   
\m
\v 22 أَذْ خَانغْ ثَارْسَا  
\m ثْمخْسِيوْثْ نّشْ إِشوَّارنْ، \add أَ\add* سِيذِي،  
\m أَمْ مَامّشْ إِ شكْ نتّْرَاجَا.   
\b  
\b  
\m  
\c 34
\m
\v 1 \add ن ذَاوُوذْ، ؤُمِي إِسّْنِيعْمِيڒْ، إِڭَّا إِخفْ نّسْ ذ أَبُوهَاڒِي زَّاثْ إِ وُوذمْ ن أَبِيمِيلِيكْ،\add* \add ونِّي إِ خَاسْ يُوژّْڒنْ أَڒَامِي يُويُورْ نتَّا.\add*\x ◘ \xo 34:‏1 \xt 1 صم. 21‏:‏13\x*   
\b  
\m
\v 2 \bd أَلِيفْ.\bd* نشّْ خْسغْ أَذْ بَارْكغْ إِ سِيذِي ڒبْذَا،  
\m أَصبِّيحْ نّسْ أَذْ يِيڒِي  
\m ذڭْ ؤُقمُّومْ إِنُو بْڒَا قطُّو.   
\m
\v 3 \bd بِيثْ.\bd* ڒعْمَارْ إِنُو أَذْ إِصبّحْ إِ سِيذِي.  
\m إِمْهِيننْ أَذْ أَسْ سْڒنْ ؤُ أَذْ فَارْحنْ.   
\m
\v 4 \bd ڭِيملْ.\bd* سمْغَارمْ أَكِيذِي سِيذِي،  
\m أجّْ أَنغْ أَذْ نسُّوعْڒَا إِسمْ نّسْ جْمِيعْ.   
\b  
\m
\v 5 \bd ذَالِيثْ.\bd* نشّْ أَرْزُوغْ خْ سِيذِي  
\m ؤُ نتَّا يَارَّا-د خَافِي،  
\m إِفكّْ أَيِي زِي مَارَّا إِنّخْڒِيعنْ إِنُو.   
\m
\v 6 \bd هِي.\bd* نِيثْنِي خزَّارنْ غَارسْ ؤُشَا شعْشعنْ،  
\m إِغمْبَابْ نْسنْ  
\m وَارْ دِّيكّْوِيڒنْ زوْغنْ  
\m س ؤُسضْحِيعمَّارْصْ.   
\m
\v 7 \bd زَايِينْ.\bd* ڒْمسْكِينْ-أَ \add ذَانِيثَا\add* إِڒَاغَا  
\m ؤُ سِيذِي إِسْڒَا \add غَارسْ\add*،  
\m إِفكّْ إِ-ث زِي مَارَّا ڒحْصَارَاثْ نّسْ.   
\b  
\m
\v 8 \bd خِيثْ.\bd* لْمَالَاكْ ن سِيذِي إِقُووَّارْ س ڒْمَارْڭحْ نّسْ  
\m خْ يِينِّي ث إِتّڭّْوذنْ،  
\m نتَّا إِفكّْ إِ-ثنْ.   
\m
\v 9 \bd ثِيث.\bd* قَاسمْ ؤُشَا خْزَارمْ، أَقَا سِيذِي إِشْنَا.  
\m سّعْذْ ن ورْيَازْ ونِّي غَارسْ يَاركّْوَاڒنْ.   
\m
\v 10 \bd يُوذْ.\bd* ڭّْوذمْ سِيذِي،  
\m \add أَ كنِّيوْ،\add* إِمْقدَّاسنْ نّسْ،  
\m مَاغَارْ إِنِّي ث إِتّڭّْوذنْ  
\m وَارْ ثنْ إِتّْخصِّي وَالُو.   
\m
\v 11 \bd كَافْ.\bd* إِيْرَاذنْ إِمژْيَاننْ تّحْوَاجنْ،  
\m ذَايْسنْ ڒَاژْ،  
\m \add مَاشَا\add* إِنِّي يَارزُّونْ خْ سِيذِي،  
\m وَارْ ثنْ إِتّْخصِّي وَالُو  
\m زِي مَارَّا \add مِينْ إِدْجَانْ\add* ذ ڒْخَارْ. \x ◘ \xo 34:‏11 \xt أَيُوبْ 4‏:‏11\x*   
\b  
\m
\v 12 \bd لَامِيذْ.\bd* أَسمْ-د،  
\m \add أَ، كنِّيوْ\add* إِحنْجِيرنْ، سْڒمْ-د غَارِي!  
\m نشّْ أَذْ أَومْ سّْڒمْذغْ  
\m ثِيڭّْوُوذِي ن سِيذِي.   
\m
\v 13 \bd مِيمْ.\bd* مَانْ ونْ إِ إِدْجَانْ ذ أَرْيَازْ  
\m ونِّي ذِي إِدْجَا مژْرِي ذِي ثُوذَارْثْ،  
\m ونِّي إِتّخْسنْ ؤُسَّانْ \add ن ثُوذَارْثْ نّسْ\add*  
\m حِيمَا أَذْ إِژَارْ ڒْخَارْ؟ \x ◘ \xo 34:‏13 \xt 1 بُط. 3‏:‏10\x*   
\m
\v 14 \bd نُونْ.\bd* مْنعْ إِڒسْ نّشْ زِي ڒْغَارْ،  
\m ؤُڒَا ذ إِينْشِيشنْ نّشْ زڭْ وَاوَاڒْ نْ ڒْغشّْ.   
\m
\v 15 \bd سَامِيخْ.\bd* حيّذْ خْ ثُوعفّْنَا ؤُ أڭّْ ڒْخَارْ،  
\m أَرْزُو خْ ڒهْنَا ؤُ ضْفَارْ إِ-ث.   
\b  
\m
\v 16 \bd عَايِينْ.\bd* ثِيطَّاوِينْ ن سِيذِي خْ إِمْسڭَّاذنْ،  
\m إِمزُّوغنْ نّسْ ميّْڒنْ  
\m غَارْ إِغُويَّانْ نْسنْ. \x ◘ \xo 34:‏16 \xt أَيُوبْ 36‏:‏7؛ إِزهد. 33‏:‏18؛ 1 بُط. 3‏:‏12\x*   
\m
\v 17 \bd بِي.\bd* ؤُذمْ ن سِيذِي  
\m ضِيدّْ إِ يِينِّي إِتّڭّنْ ڒْغَارْ،  
\m حِيمَا أَذْ إِكّسْ ڒِيذَارثْ ذَايْسنْ زِي ثمُّورْثْ.   
\m
\v 18 \bd ثْسَاذِي.\bd* نِيثْنِي ڒَاغَانْ ؤُ سِيذِي إِسْڒَا \add غَارْسنْ\add*،  
\m نتَّا إِفكّْ إِ-ثنْ زِي مَارَّا ڒحْصَارَاثْ نْسنْ.   
\m
\v 19 \bd قُوفْ.\bd* سِيذِي يُوذسْ إِ مَارَّا  
\m إِنِّي ؤُمِي إِتّْوَارْژْ وُوڒْ نْسنْ،  
\m إِسّنْجَامْ إِنِّي ؤُمِي إِتّْوَاڒْبزْ بُوحْبڒْ نْسنْ. \x ◘ \xo 34:‏19 \xt 2 تِيم. 3‏:‏11\x*   
\m
\v 20 \bd رِيخْ.\bd* أَطَّاسْ \add إِدْجَانْ\add* إِفقُّوسنْ ن إِمْسڭَّاذنْ،  
\m \add مَاشَا\add* سِيذِي إِفكّْ إِ-ثنْ زَّايْسنْ مَارَّا. \x ◘ \xo 34:‏20 \xt 2 تِيم. 3‏:‏12\x*   
\m
\v 21 \bd شِينْ.\bd* نتَّا إِحطَّا إِغْسَانْ نّسْ مَارَّا،  
\m ؤُڒَا ذ إِجّْ زَّايْسنْ وَارْ إِتَّارژِّي. \x ◘ \xo 34:‏21 \xt يُوح. 19‏:‏36\x*   
\m
\v 22 \bd ثَافْ.\bd* أَقَا ڒْغَارْ أَذْ إِنغْ أَعفَّانْ،  
\m إِنِّي إِشَارّْهنْ أَمْسڭّذْ أَذْ تّْوَاعَاقْبنْ.   
\b  
\m
\v 23 سِيذِي أَذْ إِفْذِي ڒعْمَارْ ن إِمْسخَّارنْ نّسْ،  
\m مَارَّا إِنِّي غَارسْ يَاركّْوَاڒنْ،  
\m وَارْ تّْوَاعَاقْبنْ. \f ◼ \fr 34:‏23 \ft \+bd ’أَذْ إِفْذِي‘\+bd* - خْزَارْ ’أَمفْذِي‘ - إِزهد. 78‏:35.\f*   
\b  
\b  
\m  
\c 35
\m
\v 1 \add ن ذَاوُوذْ.\add*  
\b  
\m مْشُوبّشْ، \add أَ\add* سِيذِي،  
\m أَكْ-ذ يِينِّي أَكِيذِي إِتّمْشُوبُّوشنْ،  
\m مْنغْ أَكْ-ذ يِينِّي كِيذِي إِتّْمنْغَانْ.   
\m
\v 2 طّفْ ثَاسدَّارْثْ ن ؤُسڒْقِي  
\m ذ ثْسدَّارْثْ ثَامقّْرَانْثْ،  
\m ؤُشَا كَّارْ، أوْشْ أَيِي أَفُوسْ.   
\m
\v 3 جْبذْ-د لَانْسَا، قّنْ \add أَبْرِيذْ\add* إِ ؤُمْسَاڭَارْ  
\m أَكْ-ذ يِينِّي د أَيِي إِضَافَّارنْ،  
\m إِنِي إِ ڒعْمَارْ إِنُو:  
\m ”أَسنْجمْ نّشْ أَقَا ذ نشّْ!“   
\b  
\m
\v 4 أَرّْ إِنِّي يَارزُّونْ خْ ڒعْمَارْ إِنُو  
\m أَذْ تّْوَاخَاروْضنْ ؤُ أَذْ تّْوَافضْحنْ،  
\m أجّْ إِنِّي إِتّْخَارِّيصنْ ذِي ڒْغَارْ خَافِي  
\m أَذْ تّْوَاعَارّْننْ غَارْ ضفَّارْ،  
\m أجّْ إِ-ثنْ أَذْ ذوْڒنْ تّْسضْحَانْ. \x ◘ \xo 35:‏4 \xt إِزهد. 40‏:‏15؛ 70‏:‏3\x*   
\m
\v 5 أجّْ إِ-ثنْ أَذْ ذوْڒنْ أَمْ يِيشَارْفَا  
\m ذڭْ ؤُسمِّيضْ،  
\m أجّْ لْمَالَاكْ ن سِيذِي أَذْ ثنْ إِعَارْنْ. \x ◘ \xo 35:‏5 \xt أَيُوبْ 21‏:‏18؛ إِزهد. 1‏:‏4؛ إِشا. 29‏:‏5؛ حُوش. 13‏:‏3\x*   
\m
\v 6 أجّْ أَذْ إِذْوڒْ وبْرِيذْ نْسنْ ذ ثَادْجسْثْ،  
\m أَذْ يِيڒِي إِتّحْڒُودْجُوضْ،  
\m ؤُشَا أجّْ لْمَالَاكْ ن سِيذِي أَذْ ثنْ إِضْفَارْ.   
\b  
\m
\v 7 مَاغَارْ بْڒَا سِّيبّثْ  
\m سّْنُوفَّارنْ خَافِي \add أَحْفُورْ ن\add* ثُورْصُوضِي  
\m ذ ثْرَاشَّا نْسنْ،  
\m بْڒَا سِّيبّثْ غْزِينْ ث إِ ڒعْمَارْ إِنُو.   
\m
\v 8 أجّْ أَردّدْجْ أَذْ خَاسْ د-يَاسْ بْڒَا مَا إِسّنْ،  
\m أجّْ ثْرَاشَّا نّسْ نِّي إِسّْنُوفَّارْ  
\m أَذْ ث ثطّفْ سِيمَانْثْ نّسْ،  
\m أجّْ إِ-ث أَذْ \add ذَايسْ\add* د-إِوْضَا سِيمَانْثْ نّسْ،  
\m \add س إِجّْ ن ؤُوطُّو\add* إِ ث إِ غَا يَاردّْدْجنْ.   
\b  
\m
\v 9 ڒعْمَارْ إِنُو أَذْ إِفَارْحْ زِي سِيذِي،  
\m أَذْ يَارْشقْ ذڭْ ؤُسنْجمْ نّسْ.   
\m
\v 10 أَذْ إِنِينْ مَارَّا إِغْسَانْ إِنُو:  
\m ”\add أَ\add* سِيذِي، مَانْ ونْ \add إِدْجَانْ\add* أَمْ شكْ!  
\m شكْ ذ ونِّي إِتّْفكَّانْ ڒْمسْكِينْ  
\m زڭْ ونِّي خَاسْ إِجهّْذنْ،  
\m ڒْمسْكِينْ ذ ؤُمزْڒُوضْ  
\m زڭْ إِنِّي ذ أَسنْ إِكشّْضنْ.“   
\b  
\m
\v 11 إِشهَّاذنْ إِقْطَاطْعِييّنْ كَّارنْ.  
\m مِينْ وَارْ سِّينغْ، تّْسقْسَانْ أَيِي.   
\m
\v 12 أَرِّينْ أَيِي-د ڒْغَارْ ذِي ڒْخَارْ،  
\m \add ڭِّينْ ذَايِي\add* ڒحْوجْ ن يِينِّي خَافِي إِعِيزّنْ.   
\m
\v 13 نشّْ \add مَاشَا\add* أَرْضغْ  
\m إِشْثْ ن ثْخَانْشثْ \add ن وشْضَانْ\add*،  
\m ڒَْامِي ثُوغَا هدْجْشنْ نِيثْنِي،  
\m ڭِّيغْ أَذْ إِژُومّْ ڒعْمَارْ إِنُو،  
\m ؤُشَا ثَاژَادْجِيثْ إِنُو \add ثتّْغِيمَا\add*  
\m ثدّكّْوَاڒْ-د غَارِي  
\m ذِي ذَاخڒْ إِنُو.   
\b  
\m
\v 14 أَخْمِي ث ثُوغَا ذ أَمدُّوكّڒْ إِنُو  
\m نِيغْ ذ ؤُمَا،  
\m أَمُّو إِ ثُوغَا ڭُّورغْ،  
\m أَمْ شَا ن إِجّْ إِشطّْ خْ يمَّاسْ،  
\m أَمُّو ثُوغَا أَيِي ڭُّورغْغنّْسغْ  
\m \add ذڭْ وَارُّوضْ\add* ذ أَبَارْشَانْ.   
\m
\v 15 \add مَاشَا\add* خْمِي تّْقجْذِيحغْ، فَارّْحنْ نِيثْنِي،  
\m تّْمُوننْ أَكْ-ذ وَايَاوْيَا.  
\m تّْمُوننْ ضِيدّْ إِنُو إِنِّي ن وَادَّايْ،  
\m بْڒَا مَا أَذْ \add ث\add* سّْنغْ.  
\m شقّْفنْ ذَايِي، وَارْ سُّوسْمنْ.   
\m
\v 16 أَمْ إِنِّي إِغطّْصنْ \add بْنَاذمْ\add*  
\m إِ يِيجّْ ن ؤُڒقُّوزْ ن وغْرُومْ،  
\m \add أَمُّو\add*غزَّانْ-د غَارِي ثِيغْمَاسْ.   
\b  
\m
\v 17 \add أَ\add* سِيذِي إِنُو، أَڒْ مشْحَاڒْ إِ غَا ثكّذْ  
\m ثْخزَّارذْ \add وَاهَا\add*؟  
\m سنْجمْ أَيِي زڭْ وَاردّدْجْ نْسنْ إِ إِڭِّينْ،  
\m أَينِّي إِنُو زڭْ ويْرَاذنْ إِمژْيَاننْ.   
\m
\v 18 نشّْ أَذْ شكْ قَاذِيغْ  
\m ذڭْ يِيجّْ ن وڭْرَاوْ \add ن ڒْڭنْسْ\add* ذ أَمقّْرَانْ،  
\m أَذْ شكْ صبّْحغْ جَارْ إِجّْ ن ڒْڭنْسْ  
\m إِمْغَارْ أَطَّاسْ.\x ◘ \xo 35:‏18 \xt إِزهد. 40‏:‏10، 11؛ 111‏:‏1\x*   
\b  
\m
\v 19 إِنِّي إِدْجَانْ ذ ڒْعذْيَانْ إِنُو ذِي ڒْبَاطرْ،  
\m وَارْ ثنْ تّجِّي أَذْ خَافِي فَارْحنْ،  
\m إِنِّي ذ أَيِي إِشَارّْهنْ، وَارْ ثنْ تّجِّي  
\m أَذْ خَافِي مّْسغْمَازنْ بْڒَا سِّيبّثْ. \x ◘ \xo 35:‏19 \xt يُوح. 15‏:‏25\x*   
\m
\v 20 مَاغَارْ نِيثْنِي وَارْ سِّيوِيڒنْ شَا خْ ڒهْنَا،  
\m مَاشَا تّْخَارِّيصنْ ذڭْ إِنْوَاينْ  
\m \add شُّورنْ\add* س ڒْغشّْ  
\m ضِيدّْ إِنِّي يَارزُّونْ ڒْهُوذْنثْ ذِي ثمُّورْثْ.   
\m
\v 21 نِيثْنِي أَرزّْمنْ أَقمُّومْ نْسنْ قَاعْ،  
\m قَّارنْ: ”هَا، هَا، ثِيطّْ نّغْ سِيمَانْثْ نّسْ  
\m ثژْرَا إِ-ت!“   
\b  
\m
\v 22 \add أَ\add* سِيذِي، شكْ ثژْرِيذْ ت،  
\m وَارْ تّسْقَارَا، سِيذِي إِنُو،  
\m وَارْ خَافِي تّڭّْوِيجْ شَا.   
\m
\v 23 فَاقْ، كَّارْ ذِي طّْوعْ ن ڒْحقّْ إِنُو،  
\m \add أَ\add* أَربِّي إِنُو ذ سِيذِي إِنُو،  
\m ذِي طّْوعْ ن دّعْوثْ إِنُو.   
\m
\v 24 حْكمْ خَافِي س ڒْحقّْ  
\m عْلَاحْسَابْ ثَاسڭْذَا نّشْ،  
\m \add أَ\add* سِيذِي، أَربِّي إِنُو،  
\m وَارْ ثنْ تّجِّي أَذْ خَافِي فَارْحنْ.   
\b  
\m
\v 25 وَارْ \add ثنْ\add* تّجِّي أَذْ إِنِينْ ذڭْ وُوڒْ نْسنْ:  
\m ”هَا، أَقَا أَنغْ مْلِيحْ!“،  
\m وَارْ ثنْ تّجِّي أَذْ إِنِينْ:  
\m ”أَقَا نْسَارْضْ إِ-ث!“   
\m
\v 26 أجّْ إِنِّي إِفَارّْحنْ خْ أَرْژِييّثْ إِنُو،  
\m أَذْ تّْوَاخَاروْضنْ  
\m ؤُ أَذْ سّْنُوفَّارنْ إِخفْ نْسنْ جْمِيعْ،  
\m أجّْ إِنِّي إِڭِّينْ إِخفْ نْسنْ مْغَارنْ زَّاثِي،  
\m أَذْ يَارْضنْ س ؤُسضْحِي ذ ڒفْضِيحثْ.   
\b  
\m
\v 27 أجّْ إِنِّي يَارْضَانْ ذِي ثْسڭْذَا  
\m أَذْ سْڒِيوڒْونْ ؤُ أَذْ فَارْحنْ،  
\m أجّْ إِ-ثنْ أَذْ إِنِينْ:  
\m ”ذ أَمقّْرَانْ إِ يدْجَا سِيذِي ونِّي يَارْضَانْ  
\m ذِي ڒهْنَا ن ؤُمْسخَّارْ نّسْ.“   
\m
\v 28 \add خنِّي\add* إِڒسْ إِنُو  
\m أَذْ إِبَارّحْ ثَاسڭْذَا نّشْ  
\m ذ ؤُصبّحْ نّشْ أَسّْ مَارَّا.   
\b  
\b  
\m  
\c 36
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. زڭْ ؤُمْسخَّارْ ن سِيذِي. ن ذَاوُوذْ.\add*   
\b  
\m
\v 2 إِسَّاوَاڒْ ؤُخطُّو ن ؤُعفَّانْ ذَاخڒْ ذڭْ وُوڒْ إِنُو:  
\m ”وَارْ غَارسْ ثِيڭّْوُوذِي ن أَربِّي  
\m زَّاثْ إِ ثِيطَّاوِينْ نّسْ.“   
\m
\v 3 مِينْزِي \add أَخطُّو-يَا\add* إِسّْحِينَّابْ إِ-ث  
\m ذِي ثِيطَّاوِينْ نّسْ،  
\m أَقَا يُوفَا ڒْمُوعْصِييّثْ نّسْ  
\m \add ثَارَّا إِ-ث-إِ-د\add* غَارْ وشْرَاهْ.   
\b  
\m
\v 4 أَوَاڒنْ ن ؤُقمُّومْ نّسْ  
\m أَقَا أَثنْ ذ ڒْغشّْ ذ وشْمَاثْ،  
\m نتَّا إِسّْبدّْ حِيمَا أَذْ يَارْزُو ڒفْهَامثْ  
\m حِيمَا أَذْ إِڭّْ ڒْخَارْ.   
\m
\v 5 إِتّْخمّمْ ذِي ڒْغشّْ ذِي قَامَا نّسْ،  
\m إِڭُّورْ أَذْ إِبدّْ  
\m ذڭْ إِجّْ ن وبْرِيذْ وَارْ إِصبْحنْ.  
\m ڒْغَارْ وَارْ ث إِتّْمنْضِيرْ.   
\b  
\m
\v 6 \add أَ\add* سِيذِي، ثَامخْسِيوْثْ نّشْ إِشوَّارنْ  
\m \add ثتَّاكّْوَاضْ\add* أَڒْ ذَاخڒْ ن إِجنْوَانْ،  
\m ڒَْامَانْ نّشْ أَڒْ إِسيْنُوثنْ. \x ◘ \xo 36:‏6 \xt إِزهد. 57‏:‏11؛ 108‏:‏5\x*   
\m
\v 7 ثَاسڭْذَا نّشْ \add ثڭَّا\add* أَمْ يِيذُورَارْ ن أَربِّي،  
\m ڒحْكَامَاثْ نّشْ أَمْ \add وَامَانْ\add* إِهوْڒنْ.  
\m سِيذِي إِسّنْجَامْ بْنَاذمْ ذ ڒْمَاڒْ.   
\b  
\m
\v 8 مشْحَاڒْ ثِيغْڒَا  
\m ثْمخْسِيوْثْ نّشْ إِشوَّارنْ، \add أَ\add* أَربِّي!  
\m \add س ؤُينِّي\add* أَركّْوَاڒنْ غَاركْ  
\m ثَارْوَا ن بْنَاذمْ،  
\m غَارْ ثِيڒِي ن وَافْرِيونْ نّشْ.   
\m
\v 9 تّْوَاسْجَاوْننْ س ؤُفيّضْ  
\m س ثَاذُونْثْ ن ثَادَّارْثْ نّشْ،  
\m إِغْزَارْ س نّْعَامِي نّشْ ثوْشذْ \add أَسنْ\add*  
\m مَاحنْذْ أَذْ \add زَّايسْ\add* سْونْ.   
\m
\v 10 مَاغَارْ غَاركْ إِ إِدْجَا ڒْعُونْصَارْ ن ثُوذَارْثْ،  
\m ذِي ثْفَاوْثْ نّشْ أَقَا نتّْوَاڒَا ثَافَاوْثْ.   
\b  
\m
\v 11 سْوِيژّضْ ثَامخْسِيوْثْ نّشْ إِشوَّارنْ  
\m خْ يِينِّي إِ شكْ إِسّْننْ،  
\m ثَاسڭْذَا نّشْ خْ يِينِّي  
\m إِ غَارْ إِدْجَا وُوڒْ إِسڭّْمنْ.   
\m
\v 12 وَارْ تّجِّي أَذْ خَافِي د-يَاسْ  
\m ؤُضَارْ ن أَيْثْ ن بُو-نّْفَاخثْ،  
\m وَارْ تّجِّي أَفُوسْ ن إِعفَّاننْ  
\m أَذْ أَيِي د-يَارّْ أَذْ ثلّْعغْ مَانِي مَا.   
\m
\v 13 أَقَا ذِينْ إِ وْضَانْ،  
\m إِنِّي إِتّڭّنْ ڒْمُوعْصِييّثْ،  
\m تّْوَاغضْڒنْ غَارْ ثمُّورْثْ،  
\m وَارْ زمَّارنْ عَاذْ أَذْ كَّارنْ عَاوذْ.   
\b  
\b  
\m  
\c 37
\m
\v 1 \add ن ذَاوُوذْ.\add*  
\b  
\m \bd أَلِيفْ.\bd* وَارْ ثتّْوَارقّْ \add ثفْقحْثْ نّشْ\add*  
\m خْ إِعفَّاننْ،  
\m وَارْ تَّاسمْ خْ يِينِّي إِتّڭّنْ ڒْغشّْ. \x ◘ \xo 37:‏1 \xt أَوڒن. 23‏:‏17؛ 24‏:‏1\x*   
\m
\v 2 مَاغَارْ أَذْ وْضَانْ ذغْيَا أَمْ أَرْبِيعْ،  
\m أَمْ أَرْبِيعْ أَزِيزَا أَذْ سْڒَاونْ.   
\m
\v 3 \bd بِيثْ.\bd* تّْشڒْ خْ سِيذِي ؤُ أڭّْ ڒْخَارْ،  
\m زْذغْ ذِي ثمُّورْثْ ؤُ إِڒِي ذ أَمْثِيقِّي.   
\m
\v 4 أَرّْ مژْرِي ذِي سِيذِي،  
\m ؤُ نتَّا أَذْ شكْ إِوْشْ  
\m مِينْ ذِي إِتّْمژْرِي وُوڒْ نّشْ.   
\m
\v 5 \bd ڭِيملْ.\bd* أَرّْ ثِيشْڒِي نّشْ غَارْ سِيذِي،  
\m تّْشَاڒْ خَاسْ ؤُ نتَّا أَذْ \add ت\add* إِڭّْ. \x ◘ \xo 37:‏5 \xt إِزهد. 22‏:‏9؛ 55‏:‏23؛ أَوڒن. 16‏:‏3؛ مت. 6‏:‏25؛ لك. 12‏:‏22؛ 1 بُط. 5‏:‏7\x*   
\m
\v 6 نتَّا أَذْ إِسّضْهَارْ ثَاسڭْذَا نّشْ  
\m أَمْ ثْفَاوْثْ،  
\m ڒْْحقّْ نّشْ أَمْ يِيشعْشِيعنْ ن ثْفُوشْثْ  
\m ذِي طّْحَا ن ؤُزِيڒْ.   
\m
\v 7 \bd ذَالِيثْ.\bd* سُوسمْ زَّاثْ إِ سِيذِي ؤُ رَاجَا ث.  
\m وَارْ تّجِّي \add ثَافْقحْثْ نّشْ\add* أَذْ ثَاسمْ  
\m خْ ونِّي إِفڒْهنْ ذڭْ وبْرِيذْ نّسْ،  
\m خْ ورْيَازْ نِّي إِتّڭّنْ ثَاحْرَايْمشْثْ.   
\m
\v 8 \bd هِي.\bd* أجّْ أَغْضَابْ نّشْ أَذْ يَارْسَا  
\m ؤُ أجّْ أَسْعَارْ نّشْ أَذْ إِرَاحْ.  
\m وَارْ تّجِّي \add ثَافْقحْثْ نّشْ\add*  
\m أَذْ ثتّْوَاسَّارغْ.  
\m \add مَانْ أَيَا أَذْ يَاوِي\add* مْغِيرْ ثُوعفّْنَا وَاهَا.   
\m
\v 9 مَاغَارْ إِعفَّاننْ أَذْ تّْوَاثحَّانْ،  
\m \add مَاشَا\add* إِنِّي إِسِّيثِيمنْ خْ سِيذِي  
\m أَذْ وَارْثنْ ثَامُّورْثْ.   
\m
\v 10 \bd وَاوْ.\bd* مْغِيرْ شْوَايْثْ وَاهَا  
\m ؤُشَا أَعفَّانْ وَارْ إِتّْغِيمِي \add عَاذْ\add*.  
\m أَذْ ثْحكَّارذْ مْلِيحْ ومْشَانْ نّسْ،  
\m \add مَاشَا\add* وَارْ ذِينْ إِتِّيڒِي \add عَاذْ\add*.   
\m
\v 11 إِمْهِيننْ أَذْ وَارْثنْ ثَامُّورْثْ،  
\m أَذْ أَرّنْ مژْرِي ذِي ڒهْنَا أَمقّْرَانْ. \x ◘ \xo 37:‏11 \xt مت. 5‏:‏5\x*   
\b  
\m
\v 12 \bd زَايِينْ.\bd* أَعفَّانْ إِتّْخَارّصْ  
\m ذِي ثْمعْمَاتْشْ ثِيحْرَايْمِييِّينْ ضِيدّْ إِ ؤُمْسڭّذْ،  
\m إِتّْغزَّا خَاسْ ثِيغْمَاسْ.   
\m
\v 13 سِيذِي إِنُو إِضحّشْ خَاسْ،  
\m مَاغَارْ إِتّْوَاڒَا أَقَا أَسّْ نّسْ  
\m أَذْ د-يَاسْ.   
\m
\v 14 \bd خِيثْ.\bd* إِعفَّاننْ جبْذنْ-د سِّيفْ  
\m ؤُ محْضنْ ڒْقوْسْ،  
\m حِيمَا أَذْغضْڒنْ ڒْمسْكِينْ ذ ؤُمزْڒُوضْ،  
\m حِيمَا أَذْ غَارْصنْ إِ يِينِّي إِڭُّورنْ  
\m ذڭْ وبْرِيذْ نْسنْ نِيشَانْ.   
\m
\v 15 سِّيفْ نْسنْ أَذْ ثنْ إِڒْقفْ ذڭْ وُوڒْ نْسنْ،  
\m ڒقْوَاسْ نْسنْ أَذْ تّْوَارْژنْ.   
\m
\v 16 \bd ثِيث.\bd* ذْرُوسْ إِ غَارسْ غَارْ ؤُمْسڭّذْ،  
\m حْسنْ زڭْ ؤُفيّضْ ن وَاطَّاسْ ن إِعفَّاننْ.   
\m
\v 17 مَاغَاڒْ إِغَادْجنْ ن إِعفَّاننْ أَذْ تّْوَارْژنْ،  
\m \add مَاشَا\add* سِيذِي أَذْ إِسنّذْ إِمْسڭَّاذنْ.   
\m
\v 18 \bd يُوذْ.\bd* سِيذِي إِسّنْ ؤُسَّانْ  
\m ن يِينِّي إِڭُّورنْ نِيشَانْ،  
\m ثَاسْغَارْثْ نْسنْ أَذْ ثقِّيمْ إِ ڒبْذَا.   
\m
\v 19 وَارْ تّْوَاقمِّيحنْ ذِي ڒْوقْثْ ثَاعفَّانْثْ،  
\m ذڭْ وُوسَّانْ ن ڒَاژْ أَذْ تّْوَاسّْجِيوْننْ.   
\m
\v 20 \bd كَافْ.\bd* مَاغَارْ إِعفَّاننْ أَذْ فْنَانْ،  
\m ڒْْعذْيَانْ ن سِيذِي أَذْ ودَّارنْ،  
\m أَذْ تّْوَاقْضَانْ أَمْ ونِّي إِدْجَانْ إِغْڒَانْ قَاعْ  
\m زڭْ إِزْمَارنْ إِقبُّوزنْ،  
\m أَذْ ضْونْ ذِي ثَايُّوثْ.   
\b  
\m
\v 21 \bd لَامِيذْ.\bd* أَعفَّانْ يَارطّڒْ،  
\m وَارْ إِتَّارِّي \add أَمَارْوَاسْ\add*،  
\m مَاشَا أَمْسڭّذْ إِتّْحِينّْ، إِتِّيشْ.   
\m
\v 22 مَاغَارْ إِنِّي زَّايسْ إِتّْوَابَارْكنْ  
\m أَذْ وَارْثنْ ثَامُّورْثْ،  
\m \add مَاشَا\add* إِنِّي زَّايسْ إِتّْوَانعْڒنْ،  
\m أَذْ تّْوَاثحَّانْ.   
\m
\v 23 \bd مِيمْ.\bd* إِصُورَافْ ن ورْيَازْ إِجهْذنْ  
\m تّْوَاسّْمتّْننْ زِي سِيذِي،  
\m نتَّا يَارطَّا خْ وبْرِيذْ نّسْ.   
\m
\v 24 مَاڒَا إِوْضَا، وَارْ إِتّْمنْضَارْ،  
\m مَاغَارْ سِيذِي إِوْشَا أَسْ أَفُوسْ نّسْ.   
\m
\v 25 \bd نُونْ.\bd* نشّْ ثُوغَا أَيِي ذ أَمژْيَانْ، \add ڒخُّو\add* وْسَارغْ،  
\m \add مَاشَا\add*عمَّارْصْ وَارْ ژْرِيغْ  
\m أَمْسڭّذْ إِتّْوَاجّْ،  
\m نِيغْ ثَارْوَا نّسْ أَرزُّونْ خْ وغْرُومْ.   
\m
\v 26 أَسّْ إِكْمڒْ إِتّْحِينَّا  
\m ؤُ يَاڒطّڒْ \add إِ إِمزْڒَاضْ\add*،  
\m زَّارِيعثْ نّسْ أَذْ ثِيڒِي إِ لْبَارَاكَا.   
\m
\v 27 \bd سَامِيخْ.\bd* حيّذْ خْ ڒْغَارْ ؤُ أڭّْ ڒْخَارْ،  
\m \add خنِّي\add* أَذْ غَاركْ ثِيڒِي ثْزذِّيغْثْ إِ ڒبْذَا قَاعْ.   
\m
\v 28 مَاغَارْ سِيذِي إِتّخْسْ ڒْحقّْ،  
\m وَارْ إِسمّحْ ذڭْ إِمْثِيقَّانْ نّسْ.  
\m \bd عَايِينْ.\bd* أَذْ تّْوَاحْضَانْ إِ ڒبْذَا قَاعْ،  
\m مَاشَا زَّارِيعثْ ن إِعفَّاننْ أَذْ ثتّْوَاثحَّا.   
\m
\v 29 إِمْسڭَّاذنْ أَذْ وَارْثنْ ثَامُّورْثْ،  
\m أَذْ ذَايسْ زذْغنْ إِ ڒبْذَا.   
\m
\v 30 \bd بِي.\bd* أَقمُّومْ ن ؤُمْسڭّذْ  
\m إِتّْبَارّحْ س ثِيغِيثْ،  
\m إِڒسْ نّسْ إِسَّاوَاڒْ س ڒْحقّْ.   
\m
\v 31 شَّارِيعَا ن أَربِّي نّسْ ذڭْ وُوڒْ نّسْ،  
\m إِصُورَافْ نّسْ وَارْ تّفْرِيغنْ. \x ◘ \xo 37:‏31 \xt إِزهد. 40‏:‏9؛ إِشا. 51‏:‏7\x*   
\b  
\m
\v 32 \bd ثْسَاذِي.\bd* أَعفَّانْ إِڒبّثْ إِ ؤُمْسڭّذْ،  
\m يَارزُّو أَذْ ث إِنغْ،   
\m
\v 33 \add مَاشَا\add* سِيذِي وَارْ زَّايسْ يَارخُّو  
\m أَفُوسْ نّسْ،  
\m وَارْ خَاسْ إِحْكمْ خْمِي ث غَا إِحَاكمْ.   
\m
\v 34 \bd قُوفْ.\bd* سِيثِيمْ خْ سِيذِي  
\m ؤُ طّفْ ذڭْ وبْرِيذْ نّسْ.  
\m نتَّا أَذْ شكْ إِسّْڭعّذْ  
\m حِيمَا أَذْ ثْوَارْثذْ ثَامُّورْثْ.  
\m أَذْ ثْژَارذْ أَقَا إِعفَّاننْ أَذْ تّْوَاثحَّانْ.   
\m
\v 35 \bd رِيخْ.\bd* نشّْ ژْرِيغْ إِجّْ ن ؤُعفَّانْ  
\m ذ بُو-ڒخْشُونثْ،  
\m إِمقَّارْ أَمْ ثْشجَّارْثْ ن ثنْڭلْثْ ثَازِيزَاوْثْ. \f ◼ \fr 37:‏35 \ft \+bd ’ثَاشجَّارْثْ‘\+bd* - نِيغْ ’أَدَّاڭْ‘ (’إِدَّاڭنْ‘).\f*   
\m
\v 36 أَقَا إِعْذُو، ؤُشَا خْزَارْ، وَارْ ث ثُوغِي شَا عَاذْ ذِينْ.  
\m أَرْزُوغْ خَاسْ، مَاشَا إِذْوڒْ وَارْ إِدْجِي \add عَاذْ\add*.   
\m
\v 37 \bd شِينْ.\bd* حْضَا خْ ونِّي إِدْجَانْ إِكْمڒْ  
\m ؤُ خزَّارْ غَارْ ونِّي إِڭُّورنْ نِيشَانْ،  
\m مَاغَارْ أَنڭَّارْ ن ورْيَازْ نِّي  
\m أَذْ يِيڒِي ذ ڒهْنَا.   
\m
\v 38 إِنِّي إِتّْعدَّانْ أَذْ تّْوَاردّْدْجنْ جْمِيعْ،  
\m مِينْ إِقِّيمنْ ن إِعفَّاننْ  
\m أَذْ إِتّْوَاثحَّا.   
\m
\v 39 \bd ثَافْ.\bd* أَسنْجمْ ن إِمْسڭَّاذنْ  
\m \add أَذْ د-يَاسْ\add* زِي سِيذِي،  
\m أَقَا نتَّا ذ أَروْڒَا نْسنْ  
\m ذِي ڒْوقْثْ ن ڒحْصَارثْ.   
\m
\v 40 سِيذِي أَذْ أَسنْ إِوْشْ أَفُوسْ ؤُ أَذْ ثنْ إِفكّْ.  
\m نتَّا أَذْ ثنْ إِفكّْ زڭْ إِعفَّاننْ  
\m ؤُ أَذْ ثنْ إِسّنْجمْ،  
\m مَاغَارْ نِيثْنِي أَركّْوَاڒنْ غَارسْ.   
\b  
\b  
\m  
\c 38
\m
\v 1 \add أَزهّذْ ن ذَاوُوذْ. إِ ڒِيذَارثْ.\add*   
\b  
\m
\v 2 \add أَ\add* سِيذِي، وَارْ ذ أَيِي تّْعَاقَابْ  
\m ذڭْ ؤُذُوقّزْ ن وغْضَابْ نّشْ،  
\m وَارْ ذ أَيِي تّْودَّابْ س وسْعَارْ نّشْ. \x ◘ \xo 38:‏2 \xt إِزهد. 6‏:‏2\x*   
\m
\v 3 مَاغَارْ فْڒِيثْشَاثْ نْ ڒْقوْسْ نّشْ  
\m ؤُذْفنْثْ ذَايِي،  
\m أَفُوسْ نّشْ إِتّْزيَّارْ خَافِي.   
\b  
\m
\v 4 وَارْ \add ذِينْ\add* إِقِّيمْ مِينْ إِدْجَانْ إِكمّْڒنْ  
\m ذِي أَرِّيمثْ إِنُو زڭْ وسْخضْ نّشْ،  
\m وَارْ إِقِّيمْ مِينْ إِصحّنْ ذڭْ إِغْسَانْ إِنُو  
\m زِي سِّيبّثْ ن دّنْبْ إِنُو. \f ◼ \fr 38:‏4 \ft \+bd ’أَرِّيمثْ‘\+bd* - س ثْعِيبْرَانِيثْ ’أَيْسُومْ‘، أَوَاڒْ-أَ إِخْسْ أَذْ يِينِي ’أَرِّيمثْ‘.\f*   
\m
\v 5 مَاغَارْ ڒْمُوعْصِييَّاثْ إِنُو  
\m ڭعّْذنْثْ أَيِي غَارْ ؤُزدْجِيفْ إِنُو،  
\m ذقّْڒنْثْ خَافِي  
\m أَمْ يِيجّْ ن دّْقڒْ إِمْغَارْ أَطَّاسْ.   
\b  
\m
\v 6 إِيزِّيمنْ إِنُو ذَايْسنْ أَرِّيحثْ،  
\m ڭيّْحنْ س ثُوبُّوهڒْيَا إِنُو.   
\m
\v 7 ذوْڒغْ قوْسغْ، ذوْڒغْغنْسغْ أَڒْ طَّارْفْ.  
\m أَسّْ مَارَّا ڭُّورغْ  
\m ذڭْ \add وَارُّوضْ ن وشْضَانْ ذ\add* أَبَارْشَانْ.   
\b  
\m
\v 8 مَاغَارْ تَّاشِيغْ ثِيجْعِينَّاثِينْ إِنُو  
\m أَرْغِينْثْ س ثْمسِّي مَارَّا،  
\m وَارْ ذِينْ إِقِّيمْ مِينْ إِدْجَانْ إِكمّْڒنْ  
\m ذِي أَرِّيمثْ إِنُو.   
\m
\v 9 نشّْ جمّْذغْ ؤُ تّْوَاغضْڒغْ قَاعْ،  
\m سْغُويُّوغْ س زّْهِيرْ ن وُوڒْ إِنُو.   
\b  
\m
\v 10 \add أَ\add* سِيذِي إِنُو، مَارَّا مِينْ ذِي غَارِي مژْرِي  
\m أَقَا-ث زَّاثكْ، أَوعّضْ إِنُو  
\m وَارْ زَّايكْ إِتّْنُوفَّارْ.   
\m
\v 11 ؤُڒْ إِنُو إِدّنْذُونْ، مَارَّا جّهْذْ إِفّغْ أَيِي،  
\m ؤُڒَا ذ ثَافَاوْثْ \add ثفّغْ\add* زِي ثِيطَّاوِينْ إِنُو،  
\m \add وَاهْ\add* ؤُڒَا ذ نِيثنْثِي وَارْ غَارِي بدّنْثْ \add عَاذْ\add*.   
\b  
\m
\v 12 إِمْعِيزّنْ إِنُو ذ إِمدُّوكَّاڒْ إِنُو  
\m بدّنْ أَرنْذَاذْ \add إِنُو غَارْ\add* جّْرِيحشْثْ إِنُو،  
\m ؤُڒَا ذ إِنِّي إِ ذ أَيِي يُوذْسنْ تَّاڭّْوجنْ خَافِي.   
\m
\v 13 إِنِّي يَارزُّونْ أَذْ كّْسنْ ثُوذَارْثْ إِنُو،  
\m نذْينْ أَيِي ڒفْخُوخْ،  
\m إِنِّي يَارزُّونْ أَذْ أَيِي ڭّنْ ڒْغَارْ،  
\m سَّاوَاڒنْ أَمْ مّژْرنْ أَذْ أَردّْدْجنْ،  
\m نِيثْنِي شڒْغنْ س ڒْغشّْ أَسّْ مَارَّا.   
\b  
\m
\v 14 \add مَاشَا\add* نشّْ تّڭّغْ إِخفْ إِنُو  
\m أَخْمِي ذ أَذهْشُورْ،  
\m أَمْ ويْنَاوْ نِّي وَارْ يَارزّْمنْ  
\m أَقمُّومْ نّسْ.   
\m
\v 15 نشّْ أَمْ ورْيَازْ وَارْ إِتّسْڒِينْ،  
\m ونِّي وَارْ غَارْ إِدْجِي ثْوَارِّيثْ  
\m زڭْ ؤُقمُّومْ نّسْ.   
\b  
\m
\v 16 مَاغَارْ تّْرَاجِيغْ شكْ، \add أَ\add* سِيذِي،  
\m شكْ أَذْ د-ثَارِّيذْ، \add أَ\add* سِيذِي إِنُو،  
\m \add أَ\add* أَربِّي إِنُو!   
\m
\v 17 مَاغَارْ نِّيغْ:  
\m ”أجّْ إِ-ثنْ وَارْ خَافِي فَارّْحنْ،  
\m خْمِي غَا فَارْغنْ إِضَارنْ إِنُو،  
\m أجّْ إِ-ثنْ وَارْ سّمْغَارَانْ إِخفْ نْسنْ خَافِي.   
\b  
\m
\v 18 مَاغَارْ نشّْ أَقَا أَذْ نْقَارْضغْ،  
\m ڒحْرِيقْ إِنُو أَقَا-ث ڒبْذَا زَّاثِي.   
\m
\v 19 مَاغَارْ سَّارْڭْبغْ أَشْ ڒْمُوعْصِييّثْ إِنُو،  
\m أَقَا تّْوَاحصَّارغْ زِي دّنْبْ إِنُو. \x ◘ \xo 38:‏19 \xt إِزهد. 32‏:‏5\x*   
\b  
\m
\v 20 ڒْعذْيَانْ إِنُو دَّارنْ،  
\m أَقَا أَثنْ س جّهْذْ،  
\m أَطَّاسْ \add دْجَانْ\add* إِنِّي ذ أَيِي إِشَارّْهنْ  
\m بْڒَا سِّيبّثْ.   
\m
\v 21 إِنِّي إِتَّارَّانْ ڒْخَارْ س ڒْغَارْ  
\m سّْبدّنْ إِخفْ نْسنْ ضِيدّْ إِنُو،  
\m ؤُمِي نشّْ أَرزُّوغْ خْ مِينْ إِصبْحنْ.   
\b  
\m
\v 22 وَارْ ذَايِي سمّحْ، \add أَ\add* سِيذِي، أَربِّي إِنُو،  
\m وَارْ خَافِي تَّاڭّْوجْ.   
\m
\v 23 ذغْيثْ حِيمَا أَذْ أَيِي ثوْشِيذْ أَفُوسْ،  
\m \add أَ\add* سِيذِي إِنُو، أَسنْجمْ إِنُو.   
\b  
\b  
\m  
\c 39
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. إِ يَاذُوثُونْ. أَزهّذْ ن ذَاوُوذْ.\add*   
\b  
\m
\v 2 نِّيغْ: ”نشّْ أَذْ كَّارغْ أَذْ حْضِيغْ إِبْرِيذنْ إِنُو  
\m زِي دّنْبْ ن يِيڒسْ إِنُو،  
\m أَذْ طّْفغْ أَحطُّو غَارْ ؤُقمُّومْ إِنُو  
\m س إِشْثْ ن ثشْمَانْثْ،  
\m مِينْ غَا يكّْ ؤُعفَّانْ زَّاثِي.“   
\m
\v 3 نشّْ ذوْڒغْ أَمْ ويْنَاوْ،  
\m \add ڒحّْفغْ إِخفْ إِنُو س\add* ؤُسغْذْ،  
\m بكْمغْ ؤُڒَا خْ ڒْخَارْ،  
\m \add مَاشَا\add* ڒحْرِيقْ إِنُو ثُوغَا يَارنِّي.   
\m
\v 4 ؤُڒْ  إِنُو إِذْوڒْ  إِحمَّا ذِي ذَاخڒْ إِنُو،  
\m ثتّْوَاسَّارغْ إِشْثْ ن ثْمسِّي  
\m غَارْ ؤُنِيخْسسْ إِنُو.  
\m \add خنِّي\add* سِّيوْڒغْ س يِيڒسْ إِنُو:   
\b  
\m
\v 5 ”\add أَ\add* سِيذِي، سْشنْ أَيِي أَنڭَّارْ إِنُو،  
\m مَانْ إِدْجَا ڒْقدّْ ن وُوسَّانْ إِنُو،  
\m حِيمَا أَذْ سّْنغْ مَامّشْ أَرخْفغْ.   
\m
\v 6 خْزَارْ، شكْ ثَارِّيذْ ؤُسَّانْ إِنُو  
\m أَمْ يِيشْبَارنْ ن ؤُفُوسْ،  
\m ڒْْمِيجَاڒْ ن ثُوذَارْثْ إِنُو زَّاثْ إِ شكْ  
\m أَخْمِي ذ وَالُو.  
\m كُوڒْ بْنَاذمْ، مَامّشْ مَا إِبدّْ إِمْثنْ،  
\m نِيشَانْ أَمْ يِيشْثْ ن ثَايُّوثْ.“ سِيلَاهْ. \x ◘ \xo 39:‏6 \xt إِزهد. 62‏:‏10؛ 144‏:‏4\x*   
\m
\v 7 إِوَا، بْنَاذمْ إِڭُّورْ أَمْ يِيجّْ ن ڒخْيَاڒْ،  
\m وَاهْ، \add أَمْ\add* إِشْثْ ن ثَايُّوثْ  
\m \add أَمُّو إِ\add* إِتّْرَاحْ إِتَّاسْ-د.  
\m نتَّا إِسّْمُونْ،  
\m وَارْ إِسِّينْ مَانْ ونْ ث إِ غَا إِكْسِينْ \add غَارسْ\add*.   
\b  
\m
\v 8 ؤُ ڒخُّو، مِينْ غَا سِّيثْمغْ، \add أَ\add* سِيذِي إِنُو؟  
\m أَقَا نشّْ تّْرَاجِيغْ شكْ!   
\m
\v 9 فكّْ أَيِي زِي مَارَّا إِخطَّانْ إِنُو،  
\m وَارْ ذ أَيِي تّڭّْ شَا ذ ثِيسضْحَاشْ إِ ؤُبُوحَاڒِي.   
\m
\v 10 نشّْ ذوْڒغْ أَمْ ويْنَاوْ،  
\m وَارْ أَرزّْمغْ أَقمُّومْ إِنُو،  
\m مَاغَارْ ذ شكْ إِ إِڭِّينْ أَيَا.   
\m
\v 11 كْسِي زَّايِي جّْرِيحشْثْ نّشْ،  
\m أَقَا فنِّيغْ س ؤُطفُّو إِحصَّارنْ ن ؤُفُوسْ نّشْ.   
\m
\v 12 \add مَاڒَا\add* ثْسڭّْذذْ شَا ن ورْيَازْ س ثِييِّيثَا  
\m ذِي سِّيبّثْ ن ڒْمُوعْصِييّثْ نّسْ،  
\m \add خنِّي\add* ثسّْفسْيذْ أَشوَّارْ ن وَادُّوذْ نّسْ  
\m أَمْ ثْشِينْذَا.  
\m إِوَا كُوڒْ بْنَاذمْ \add أَذْ إِفْنَا\add*  
\m \add أَمْ يِيشْثْ ن\add* ثَايُّوثْ. سِيلَاهْ.   
\b  
\m
\v 13 سڒْ إِ ثْژَادْجِيثْ إِنُو، \add أَ\add* سِيذِي،  
\m سْحسّْ إِ ؤُغُويِّي إِنُو.  
\m وَارْ تّبْكِيمْ غَارْ إِمطَّاونْ إِنُو،  
\m مَاغَارْ أَقَا أَيِي ذ أَبَارَّانِي،  
\m ذ أَمْعزّبْ غَاركْ،  
\m أَمْ مَارَّا ڒجْذُوذْ إِنُو. \x ◘ \xo 39:‏13 \xt لَاوِي 25‏:‏23؛ 1 إِم. 29‏:‏15؛ إِزهد. 119‏:‏19؛ عبر. 11‏:‏13؛ 1 بُط. 2‏:‏11\x*   
\m
\v 14 سْحيّذْ خَافِي  
\m مَاحنْذْ أَذْ شعْشعغْ \add عَاذْ س ڒفْرَاحثْ\add*،  
\m قْبڒْ أَذْ رَاحغْ ؤُ وَارْ \add ذَا\add* تِّيڒِيغْ عَاذْ.   
\b  
\b  
\m  
\c 40
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. ن ذَاوُوذْ. أَزهّذْ.\add*   
\b  
\m
\v 2 سِّيثِيمغْ قَاعْ خْ سِيذِي.  
\m نتَّا يَارَّا-د غَارِي س ؤُزدْجِيفْ،  
\m إِسّْحسّْ غَارْ ؤُغُويِّي إِنُو.   
\m
\v 3 نتَّا إِسّْڭعّذْ أَيِي-د  
\m زڭْ إِجّْ ن وَانُو إِنقّنْ،  
\m زڭْ ؤُبدْجَاعْ ذ ؤُبَارْيُوضْ،  
\m نتَّا إِسَّارْسْ إِضَارنْ إِنُو خْ ثصْضَارْثْ،  
\m إِسّمْثنْ إِصُورَافْ إِنُو.   
\m
\v 4 نتَّا إِڭَّا أَيِي إِجّْ ن يزْڒِي ذ أَمَايْنُو  
\m ذڭْ ؤُقمُّومْ إِنُو،  
\m إِجّْ ن إِزْڒِي ن ؤُصبّحْ إِ أَربِّي.  
\m أَطَّاسْ أَذْ ث ژَترنْ،  
\m أَذْ ثشْڒنْ خْ سِيذِي.   
\b  
\m
\v 5 سّعْذْ ن ورْيَازْ  
\m ونِّي إِتّشْڒنْ خْ سِيذِي،  
\m ونِّي وَارْ إِتّْميّْڒنْ  
\m غَارْ أَيْثْ ن بُو-نّْفَاخثْ،  
\m ؤُڒَا غَارْ يِينِّي إِودَّارنْ غَارْ ؤُخَارِّيقْ.   
\m
\v 6 أَطَّاسْ، \add أَ\add* سِيذِي، أَربِّي إِنُو، ذ لْمُوعْجِيزَاثْ  
\m نِّي ثڭِّيذْ، ؤُڒَا ذ مِينْ ثنْوِيذْ خَانغْ.  
\m ؤُڒَا ذ إِجّْ إِزمَّارْ  
\m أَذْ إِعْبَارْ إِخفْ نّسْ أَكِيذكْ.  
\m نشّْ أَذْ ثنْثْ هَاجِيغْ، أَذْ زَّايْسنْثْ سِّيوْڒغْ.  
\m أَقَا نِيثنْثِي ذڭْ وَاطَّاسْ،  
\m وَارْ زمَّارنْثْ أَذْ تّْوَاحسْبنْثْ. \x ◘ \xo 40:‏6 \xt إِزهد. 89‏:‏7؛ إِشا. 40‏:‏18\x*   
\b  
\m
\v 7 وَارْ ثخْسذْ ثَاغَارْصْثْ  
\m ذ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add*.  
\m شكْ ثَارْزْمذْ إِمزُّوغنْ إِنُو.  
\m ثَاغَارْصْثْ ن وشْمَاضْ ذ ثْغَارْصْثْ ن دّنْبْ  
\m وَارْ ثنْثْ ثتَّارذْ. \x ◘ \xo 40:‏7 \xt عبر. 10‏:‏5\x*   
\m
\v 8 خنِّي نِّيغْ: ”خْزَارْ، نشّْ أَذْ د-أَسغْ،  
\m ذڭْ وذْلِيسْ إِتّْوَانّْضنْ يُورَا خَافِي.   
\m
\v 9 نشّْ غَارِي مژْرِي، \add أَ\add* أَربِّي،  
\m حِيمَا أَذْ ڭّغْ مِينْ ثخْسذْ شكْ.  
\m شَّارِيعَا نّشْ أَقَا-ت ذِي ذَاخڒْ إِنُو.“ \x ◘ \xo 40:‏9 \xt إِزهد. 37‏:‏31؛ إِشا. 51‏:‏7\x*   
\b  
\m
\v 10 نشّْ تّْبَارّْحغْ ڒخْبَارْ أَصبْحَانْ  
\m ن ثْسڭْذَا \add نّشْ\add*  
\m ذڭْ وڭْرَاوْ \add ن ڒْڭنْسْ\add* أَمقّْرَانْ.  
\m خْزَارْ، وَارْ تّقّْنغْ إِينْشِيشنْ إِنُو،  
\m \add أَ\add* سِيذِي، شكْ ثسّْنذْ ث. \x ◘ \xo 40:‏10 \xt إِزهد. 35‏:‏18؛ 111‏:‏1\x*   
\m
\v 11 وَارْ تّْخمّْڒغْ ثَاسڭْذَا نّشْ  
\m ذَاخڒْ ذڭْ وُوڒْ إِنُو،  
\m سَّاوَاڒغْ خْ ثِيذتّْ نّشْ ؤُ خْ ؤُسنْجمْ نّشْ.  
\m ثَامخْسِيوْثْ نّشْ إِشوَّارنْ  
\m ذ ڒَامَانْ إِ ذَايكْ  
\m وَارْ ثنْ سّْنُوفَّارغْ  
\m ذڭْ وڭْرَاوْ \add ن ڒْڭنْسْ\add* أَمقّْرَانْ.   
\b  
\m
\v 12 شكْ، \add أَ\add* سِيذِي،  
\m وَارْ خَافِي ثسّْبذِّيذْ أَرّحْمثْ نّشْ.  
\m أجّْ ثَامخْسِيوْثْ نّشْ إِشوَّارنْ  
\m ذ ڒَامَانْ إِ ذَايكْ أَذْ أَيِي حْضَانْثْ ڒبْذَا.   
\m
\v 13 مَاغَارْ وَارْ إِزمَّارْ أَذْ إِتّْوَاحصّبْ  
\m ڒْْغَارْ إِ ذ أَيِي إِقُووَّارنْ،  
\m ڒْْمُوعْصِييَّاثْ إِنُو تّْمنْعنْثْ أَيِي-د،  
\m ذوْڒغْ وَارْ تّْوِيڒِيغْ عَاذْ \add س مَانْ أَيَا\add*.  
\m أَقَا-ثنْثْ ذ أَطَّاسْ خْ ؤُشُوَّافْ ن ؤُزدْجِيفْ إِنُو،  
\m ؤُڒْ إِنُو إِتّفْشِيڒْ.   
\b  
\m
\v 14 \add أَ\add* سِيذِي، أَذْ أَشْ يَارْضَا  
\m حِيمَا أَذْ أَيِي ثْفكّذْ،  
\m \add أَ\add* سِيذِي، ذغْيَاثْ حِيمَا أَذْ أَيِي ثوْشذْ أَفُوسْ.   
\m
\v 15 أجّْ إِنِّي يَارزُّونْ ڒعْمَارْ إِنُو  
\m حِيمَا أَذْ ث ثحَّانْ  
\m أَذْ تّْوَاخَارْوضنْ،  
\m أَذْ سّْنُوفَارنْ إِخفْ نْسنْ \add جْمِيعْ\add*،  
\m أجّْ إِنِّي إِفَارّْحنْ ذڭْ ؤُعدّبْ إِنُو  
\m أَذْ ذوْڒنْ غَارْ ضفَّارْ ؤُ أَذْ تّْوَاسّْبهْذْڒنْ. \x ◘ \xo 40:‏15 \xt إِزهد. 35‏:‏4، 26؛ 70‏:‏3؛ 71‏:‏13\x*   
\m
\v 16 أجّْ إِ-ثنْ أَذْ تّْوَاردّْدْجنْ  
\m أَمْ ؤُخدْجصْ إِ ڒفْضِيحثْ نْسنْ \add إِ إِڭِّينْ\add*،  
\m إِنِّي ذِينْ إِقَّارنْ: ”هَا، هَا!“   
\b  
\m
\v 17 أجّْ مَارَّا إِنِّي خَاكْ يَارزُّونْ،  
\m أَذْ أَرّنْ مژْرِي، أَذْ زَّايكْ فَارْحنْ.  
\m أجّْ إِنِّي إِتّخْسنْ أَسنْجمْ نّشْ  
\m أَذْ إِنِينْ ڒبْذَا: ”سِيذِي ذ أَمقّْرَانْ!“   
\m
\v 18 نشّْ ذِي ڒغْبنْ ؤُ زڒْضغْ،  
\m \add مَاشَا\add* سِيذِي إِنُو إِعْقڒْ خَافِي.  
\m شكْ ذ ونِّي ذ أَيِي إِوْشِينْ أَفُوسْ  
\m ذ ونِّي ذ أَيِي إِسّْنجْمنْ.  
\m \add أَ\add* أَربِّي إِنُو، وَارْ تّْعطَّاڒْ شَا.   
\b  
\b  
\m  
\c 41
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. أَزهّذْ ن ذَاوُوذْ.\add*   
\b  
\m
\v 2 سّعْذْ ن ونِّي إِفهّْمنْ إِ ؤُمَارْخُو.  
\m سِيذِي أَذْ ث إِفكّْ ذڭْ وَاسّْ ن ڒْغَارْ.   
\m
\v 3 سِيذِي ڭُّورْ أَذْ ث إِحْضَا،  
\m أَذْ ث يجّْ أَذْ إِدَّارْ،  
\m نتَّا أَذْ يَارّْ مژْرِي ذِي ثمُّورْثْ.  
\m وَارْ ث تّْسلَّامْ شَا  
\m غَارْ \add مِينْ ذِينْ إِدْجَانْ\add*  
\m \add ذِي\add* ڒعْمَارْ ن ڒْعذْيَانْ نّسْ.   
\m
\v 4 سِيذِي أَذْ كِيذسْ إِبدّْ  
\m ذِي ثَاسُّوثْ ن ڒهْڒَاشْ.  
\m شكْ ثتّْبدّْڒذْ مَارَّا ڒشْثُو نّسْ  
\m ؤُمِي إِهدْجشْ.   
\b  
\m
\v 5 نشّْ نِّيغْ: ”\add أَ\add* سِيذِي، حِينّْ خَافِي،  
\m سْڭنْفَا ڒعْمَارْ إِنُو،  
\m مَاغَارْ خْضِيغْ أَكِيذكْ.“   
\m
\v 6 ڒْعذْيَانْ إِنُو سَّاوَاڒنْ خَافِي س ڒْغَارْ:  
\m ”مڒْمِي إِ غَا إِمّثْ  
\m ؤُ أَذْ إِتّْوَاكّسْ إِسمْ نّسْ؟“   
\m
\v 7 مَاڒَا يُوسَا-د \add حذْ\add*  
\m مَاحنْذْ أَذْ \add أَيِي\add* إِژَارْ،  
\m إِسَّاوَاڒْ ذِي ڒْبَاطڒْ.  
\m ؤُڒْ نّسْ إِسّْمُونْ غَارسْ ڒْغشّْ،  
\m \add خنِّي\add* إِتّفّغْ غَارْ بَارَّا، إِسَّاوَاڒْ.   
\b  
\m
\v 8 مَارَّا إِنِّي ذ أَيِي إِشَارّْهنْ  
\m تّمْثَامنْ خَافِي جْمِيعْ،  
\m أَقَا أَثنْ تّْخَارِّيصنْ ذَايِي،  
\m مَاحنْذْ \add أَذْ\add* أَيِي \add ڭّنْ\add* ڒْغَارْ.   
\m
\v 9 إِڒْقفْ إِ-ث أَشْثَابْ أَبَارْشَانْ  
\m ؤُ ونِّي د-إِوْضَانْ \add أَمُّو\add*،  
\m وَارْ د-إِتّكَّارْ عَاذْ.   
\m
\v 10 ؤُڒَا ذ أَرْيَازْ وِي أَكْ-ذ دَّارغْ ذِي ڒهْنَا،  
\m ونِّي ذِي تِّيقّغْ،  
\m ونِّي إِشّنْ أَغْرُومْ إِنُو،  
\m أَقَا إِسّمْغَارْ خَافِي أَنِيرْزْ نّسْ. \x ◘ \xo 41:‏10 \xt عُوب. 1‏:‏7، يُوح. 13‏:‏18\x*   
\b  
\m
\v 11 \add مَاشَا\add* شكْ، \add أَ\add* سِيذِي، حِينّْ خَافِي،  
\m سْنكَّارْ أَيِي-د،  
\m \add خنِّي\add* نشّْ أَذْ ثنْ خدْجْصغْ.   
\m
\v 12 س مَانْ أَيَا أَذْ سّْنغْ  
\m أَقَا ؤُسِيغْ أَشْ-د خْ ڒْخَاضَارْ،  
\m مَاحنْذْ ڒعْذُو إِنُو  
\m وَارْ خَافِي إِتّْذُوقّزْ س ؤُسْڒِيوْڒوْ.   
\m
\v 13 ؤُ خَافِي، أَقَا شكْ تِّيشذْ أَيِي أَفُوسْ  
\m \add س وَاوَاڒْ نّكْ\add* خْ ڒكْمَارثْ إِنُو،  
\m ثسّْبدّذْ أَيِي  
\m زَّاثْ إِ وُوذمْ نّشْ إِ ڒبْذَا. \x ◘ \xo 41:‏13 \xt 2 صم. 7‏:‏16\x*   
\b  
\m
\v 14 أَذْ إِتّْوَابَاركْ سِيذِي، أَربِّي ن إِسْرَائِيل،  
\m زِي ڒبْذَا أَڒْ إِ ڒبْذَا! أَمِينْ، \add وَاهْ،\add* أَمِينْ!   
\b  
\b  
\m  
\c 42
\s1 أَذْلِيسْ وِيسّْ ثْنَاينْ - إِزهِّيذنْ 42-72  
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. أَخمِّي ن أَيْثْ ن قُورَاحْ.\add*   
\b  
\m
\v 2 أَمْ إِغَايْضْ ن وزْغَارْ إِتّْمژْرِي  
\m غَارْ ثْغزْرَاثِينْ ن وَامَانْ،  
\m أَمُّو ؤُڒَا ذ ؤُڒْ  إِنُو  
\m إِتّْمژْرِي غَاركْ، \add أَ\add* أَربِّي.   
\m
\v 3 ڒعْمَارْ إِنُو إِتّْفَاذَا غَارْ أَربِّي،  
\m غَارْ أَربِّي إِدَّارنْ.  
\m مڒْمِي إِ غَا أَذْفغْ،  
\m أَذْ بَانغْ زَّاثْ إِ وُوذمْ ن أَربِّي؟ \x ◘ \xo 42:‏3 \xt إِزهد. 63‏:‏2\x*   
\m
\v 4 إِمطَّاونْ إِنُو  
\m ثُوغَا أَثنْ ذ أَغْرُومْ إِنُو  
\m أَسّْ ذ دْجِيڒثْ،  
\m ؤُمِي ذ أَيِي قَّارنْ أَسّْ إِمُونْ:  
\m ”مَانِي إِدْجَا أَربِّي نّشْ؟“ \x ◘ \xo 42:‏4 \xt إِزهد. 80‏:‏6\x*   
\m
\v 5 نشّْ تِّيذَارغْ ذِي مَانْ أَيَا  
\m ؤُ سّْفَارّْغغْ ڒعْمَارْ إِنُو ذَايِي،  
\m مَاغَارْ نشّْ تّْنُومغْ ڭّعّْذغْ  
\m ذڭْ إِجّْ ن ؤُهِيمُورْ إِقّنْ،  
\m أَمْ ڭُّورغْ أَكِيذْسنْ  
\m غَارْ ثَادَّارْثْ ن أَربِّي،  
\m س ڒْحسّْ ن ؤُسْڒِيوْڒوْ ذ ؤُقَاذِي،  
\m إِجّْ نْ ڒْغَاشِي إِتّْعيّْذنْ.   
\m
\v 6 \add أَ\add* ڒعْمَارْ إِنُو،  
\m مَايمِّي ثْقنْضذْ أَمُّو،  
\m ثْهكّْوڒذْ ذَايِي؟  
\m رَاجَا أَربِّي،  
\m مَاغَارْ أَذْ قِّيمغْ أَذْ ث قَاذِيغْ عَاذْ  
\m خْ إِسنْجَامنْ \add إِ د-إِتّفّْغنْ\add*  
\m \add زِي زَّاثْ\add* ن وُوذمْ نّسْ. \x ◘ \xo 42:‏6 \xt إِزهد. 43‏:‏5؛ إِزهد. 42‏:‏12؛ 43‏:‏5 \x*   
\b  
\m
\v 7 \add أَ\add* أَربِّي، ڒعْمَارْ إِنُو  
\m إِقْنضْ أَمُّو ذَايِي.  
\m خْ ؤُيَا تِّيذَارغْ شكْ  
\m زِي ثمُّورْثْ ن لْ-ؤُرْذُونْ،  
\m زڭْ \add إِذُورَارْ ن\add* هِيرْمُونْ،  
\m زڭْ إِذُورَارْ ن مِيصْعَارَا.   
\m
\v 8 ڒْحمْڒثْ ثتّْڒَاغَا إِ ڒْحمْڒثْ نّغْنِي  
\m غَارْ زّْهِيرْ ن إِشرْشُورنْ نّشْ،  
\m مَارَّا ڒمْهَامذْ نّشْ  
\m ذ ڒمْوَاجْ نّشْ كِّينْ خَافِي.   
\m
\v 9 أجّْ سِيذِي أَذْ إِوصَّا  
\m ثَامخْسِيوْثْ نّسْ إِشوَّارنْ س وَاسّْ،  
\m \add ؤُشَا\add* أَذْ غَارِي يِيڒِي يِيجّْ ن إِزْڒِي ذِي دْجِيڒثْ،  
\m أَقَا-ث ذ ثْژَادْجِيثْ إِ أَربِّي ن ثُوذَارْثْ إِنُو.   
\m
\v 10 نشّْ أَذْ إِنِيغْ إِ أَربِّي:  
\m ”ثَاصْضَارْثْ إِنُو \add ذ شكْ\add*، مَايمِّي ذ أَيِي ثتُّوذْ؟  
\m مَايمِّي ڭُّورغْ \add ذڭْ ورُّوضْ\add* ذ أَبَارْشَانْ  
\m زِي سِّيبّثْ ن دّدْجْ ن ڒعْذُو؟“ \x ◘ \xo 42:‏10 \xt إِزهد. 35‏:‏14؛ 38‏:‏7؛ 43‏:‏2\x*   
\m
\v 11 إِنِّي ذ أَيِي إِحصَّارنْ سّْبهْتّْڒنْ أَيِي  
\m س إِشْثْ ن ثَاجُّوثْ إِنقّنْ ذڭْ إِغْسَانْ إِنُو،  
\m ؤُمِي ذ أَيِي قَّارنْ:  
\m ”مَانِي إِدْجَا أَربِّي نّشْ؟“   
\m
\v 12 \add أَ\add* ڒعْمَارْ إِنُو،  
\m مَايمِّي ثْقنْضذْ أَمُّو،  
\m ثْهكّْوڒذْ ذَايِي؟  
\m رَاجَا أَربِّي، مَاغَارْ أَذْ ث قَاذِيغْ عَاذْ  
\m خْ إِسنْجَامنْ \add إِ د-إِتّفّْغنْ\add*  
\m \add زِي زَّاثْ\add* ن وُوذمْ إِنُو،  
\m ؤُ \add زِي زَّاثْ ن\add* أَربِّي إِنُو. \x ◘ \xo 42:‏12 \xt إِزهد. 42‏:‏6؛ إِزهد. 43‏:‏5\x*   
\b  
\b  
\m  
\c 43
\m
\v 1 \add مِينْ إِقِّيمنْ ن ؤُزهّذْ 42\add*  
\m أَغْ أَيِي ثَاسْغَارْثْ، \add أَ\add* أَربِّي،  
\m نْذهْ دّعْوثْ إِنُو.  
\m فكّْ أَيِي زڭْ إِجّْ ن ڒْڭنْسْ  
\m وَارْ ذَايسْ بُو ثْمخْسِيوْثْ،  
\m زڭْ ورْيَازْ ن ثحْرَايْمشْثْ ذ دّدْجْ.   
\m
\v 2 أَقَا شكْ ذ أَربِّي ن جّهْذْ إِنُو،  
\m مَايمِّي \add خنِّي\add* ذ أَيِي ثنْضَارذْ؟  
\m مَايمِّي ڭُّورغْ \add ذڭْ ورُّوضْ\add* ذ أَبَارْشَانْ  
\m زِي سِّيبّثْ ن دّدْجْ ن ڒعْذُو؟“ \x ◘ \xo 43:‏2 \xt إِزهد. 35‏:‏14؛ 38‏:‏7؛ 42‏:‏10\x*   
\m
\v 3 سكّْ-د ثَافَاوْثْ نّشْ ذ ثِيذتّْ نّشْ،  
\m مَاحنْذْ أَذْ أَيِي ڭوّْذنْثْ،  
\m أَذْ أَيِي نذْهنْثْ  
\m غَارْ وذْرَارْ نّشْ إِقدّْسنْ  
\m ؤُ غَارْ ثْزذِّيغِينْ نّشْ،   
\m
\v 4 \add أَڒَامِي\add* إِ غَا د-أَسغْ غَارْ ؤُعَالْطَارْ،  
\m \add ڒْمذْبحْ ن وشْمَاضْ\add* ن أَربِّي،  
\m غَارْ أَربِّي ن ڒفْرَاحثْ، \add ونِّي ذ\add* أَرْشقْ إِنُو.  
\m نشّْ أَذْ شكْ قَاذِيغْ س ڒْڭَامْبْرِي،  
\m \add أَ\add* أَربِّي، أَربِّي إِنُو!   
\m
\v 5 \add أَ\add* ڒعْمَارْ إِنُو، مَايمِّي ثْقنْضذْ أَمُّو،  
\m ثْهكّْوڒذْ ذَايِي؟  
\m رَاجَا أَربِّي، مَاغَارْ أَذْ ث قَاذِيغْ عَاذْ  
\m خْ إِسنْجَامنْ \add إِ د-إِتّفّْغنْ\add*  
\m \add زِي زَّاثْ\add* ن وُوذمْ إِنُو،  
\m ؤُ \add زِي زَّاثْ ن\add* أَربِّي إِنُو. \x ◘ \xo 43:‏5 \xt إِزهد. 42‏:‏6، 12\x*   
\b  
\b  
\m  
\c 44
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. زڭْ أَيْثْ ن قُورَاحْ. أَخمِّي.\add*   
\b  
\m
\v 2 \add أَ\add* أَربِّي، نشِّينْ نسْڒَا ت  
\m س إِمزُّوغنْ نّغْ،  
\m ڒجْذُوذْ نّغْ حَاجَانْ أَنغْ ت:  
\m شكْ ثڭِّيذْ إِشْثْ ن ثْمڭِّيثْ  
\m ذڭْ وُوسَّانْ نْسنْ،  
\m ذڭْ وُوسَّانْ ن وشْحَاڒْ ؤُيَا.   
\m
\v 3 س ؤُفُوسْ نّشْ أَقَا ثسُّوفّْغذْ ڒڭْنُوسْ  
\m زِي ثسْغَارْثْ \add نْسنْ\add*،  
\m \add خنِّي\add* ثژُّوذْ ثنْ \add ذَايسْ\add*.  
\m شكْ ثڭِّيذْ ڒْغَارْ ذِي شُّوعُوبْ،  
\m ثْبزّْعذْ ثنْ. \x ◘ \xo 44:‏3 \xt ؤُف. 15‏:‏17؛ إِزهد. 80‏:‏9\x*   
\m
\v 4 نِيثْنِي مَاشَا وَارْ وَارْثنْ ثَامُّورْثْ س سِّيفْ،  
\m أَغِيڒْ نْسنْ وَارْ ذ أَسنْ د-يِيوِي أَسنْجمْ،  
\m \add مَاشَا\add* أَفُوسْ نّشْ أَفُوسِي،  
\m أَغِيڒْ نّشْ ذ ثْفَاوْثْ ن وُوذمْ نّشْ،  
\m مِينْزِي نِيثْنِي ؤُفِينْ أَرْضَا \add ذِي ثِيطَّاوِينْ نّشْ\add*.   
\b  
\m
\v 5 أَقَا شكْ ذ أَجدْجِيذْ إِنُو، \add أَ\add* أَربِّي!  
\m أوْشْ \add عَاذْ ڒخُّو\add* ڒُومُورْ  
\m إِ إِسنْجَامنْ ن يَاعْقُوبْ.   
\m
\v 6 أَكِيذكْ أَذْ نغْضڒْ إِنِّي ذ أَنغْ إِحصَّارنْ،  
\m س يِيسمْ نّشْ أَذْ نعْفسْ  
\m خْ يِينِّي خَانغْ إِتّمْعَاڒَانْ.   
\m
\v 7 مَاغَارْ وَارْ تّشْڒغْ خْ ڒْقوْسْ إِنُو،  
\m سِّيفْ إِنُو وَارْ ذ أَيِي إِسّنْجَامْ.   
\m
\v 8 مَاغَارْ شكْ ثسّنْجَامذْ أَنغْ  
\m زڭْ إِنِّي ذ أَنغْ إِحصَّارنْ،  
\m ثسّْبهْذِيڒذْ إِنِّي ذ أَنغْ إِشَارّْهنْ.   
\m
\v 9 نْصبّحْ إِ أَربِّي أَسّْ مَارَّا،  
\m أَذْ نْقَاذَا إِسمْ نّشْ إِ ڒبْذَا. سِيلَاهْ.   
\b  
\m
\v 10 مَاشَا ڒخُّو ثنْضَارذْ أَنغْ،  
\m ثسّْبهْذَاڒذْ أَنغْ،  
\m شكْ وَارْ ثتّفِّيغذْ شَا  
\m أَكْ-ذ ڒْعسْكَارَاثْ نّغْ \add غَارْ ؤُمنْغِي\add*. \x ◘ \xo 44:‏10 \xt إِزهد. 60‏:‏3؛ 74‏:‏1؛ 89‏:‏39؛ 108‏:‏12\x*   
\m
\v 11 شكْ ثجِّيذْ أَنغْ نتّْرَاكّْوَاڒْ  
\m زَّاثْ إِ ونِّي ذ أَنغْ إِحصَّارنْ،  
\m إِنِّي ذ أَنغْ إِشَارّْهنْ  
\m تّْكشّْضنْ \add مِينْ تّخْسنْ\add* إِ يِيخفْ نْسنْ.   
\m
\v 12 شكْ ثوْشِيذْ أَنغْ أَمْ وُودْجِي إِ مَاشَّا،  
\m ثزُّوزَارذْ أَنغْ جَارْ ڒڭْنُوسْ.   
\m
\v 13 شكْ ثزّْنُوزِيذْ ڒْڭنْسْ نّشْ س وَالُو،  
\m ذڭْ ؤُزّنْزِي نْسنْ وَارْ غَاركْ بُو ڒفْضڒْ.   
\b  
\m
\v 14 شكْ ثتّڭّذْ أَنغْ ذ ڒْحڭْرَا  
\m إِ وَاجَّارنْ نّغْ،  
\m ذ أَسْثهْزِي ذ ؤُبهْذڒْ  
\m غَارْ يِينِّي ذ أَنغْ-د إِتّنّْضنْ. \x ◘ \xo 44:‏14 \xt إِزهد. 79‏:‏4؛ 80‏:‏7؛ إِرْم. 24‏:‏9\x*   
\m
\v 15 شكْ ثتّڭّذْ أَنغْ ذ أَمذْيَا  
\m جَارْ ڒڭْنُوسْ،  
\m \add ثتّڭّذْ\add* أَذْ خَانغْ هزّنْ  
\m أَزدْجِيفْ جَارْ شُّوعُوبْ.   
\m
\v 16 أَسّْ مَارَّا ڒْعَارْ إِنُو أَقَا-ث زَّاثِي  
\m \add جَارْ ثِيطَّاوِينْ إِنُو\add*،  
\m ڒحْيَا إِذْڒَا أَغمْبُوبْ إِنُو،   
\m
\v 17 زِي ثْمِيجَّا ن يِينِّي إِسّحْقَارَّانْ،  
\m تّْشقَّافنْ، زِي سِّيبّثْ ن ڒعْذُو  
\m ؤُ ن ونِّي يَارزُّونْ أَنْثَاقمْ.   
\b  
\m
\v 18 أَيَا مَارَّا إِكَّا خَانغْ،  
\m \add مَاشَا\add* وَارْ شكْ نتُّو،  
\m وَارْ نْغشّْ شَا ذِي ڒْعَاهْذْ نّشْ.   
\m
\v 19 ؤُڒْ نّغْ وَارْ إِذْوِيڒْ غَارْ ضفَّارْ،  
\m إِصُورَافْ نّغْ وَارْ د-فِّيغنْ شَا  
\m زڭْ ؤُمسْرُوقْ نّشْ،   
\m
\v 20 وَاخَّا شكْ ثْڒبْزذْ أَنغْ  
\m ذڭْ ومْشَانْ ن وُوشَّاننْ ن ڒخْڒَا،  
\m ثذْڒِيذْ أَنغْ س ثِيڒِي ن ڒْموْثْ.   
\m
\v 21 مْڒِي ثُوغَا نتُّو إِسمْ ن أَربِّي نّغْ،  
\m نسّْوِيژّضْ إِفَاسّنْ نّغْ  
\m غَارْ يِيجّْ ن أَربِّي ذ أَغْرِيبْ،   
\m
\v 22 مَا إِڒِي أَربِّي وَارْ يَارزُّو ذِي مَانْ أَيَا؟  
\m أَقَا نتَّا يَارڭّبْ  
\m خْ مِينْ إِنُّوفَّارنْ ذڭْ وُوڒْ.   
\b  
\m
\v 23 مَاغَارْ ذِي طّْوعْ نّشْ  
\m نقّنْ أَنغْ كُوڒْ أَسّْ،  
\m أَقَا حسّْبنْ أَنغْ أَمْ وُودْجِي ن ثْغَارْصْثْ. \x ◘ \xo 44:‏23 \xt رُوم. 8‏:‏36\x*   
\m
\v 24 فَاقْ، مَايمِّي ثطّْصذْ، سِيذِي إِنُو؟  
\m فَاقْ، وَارْ ذ أَنغْ نطَّارْ إِ ڒبْذَا!   
\m
\v 25 مَايمِّي غَا ثفَّارذْ ؤُذمْ نّشْ،  
\m أَذْ ثتُّوذْ ڒغْبنْ ذ دّدْجْ نّغْ؟   
\m
\v 26 مَاغَارْ ڒعْمَارْ نّغْ إِتَّاضَارْ غَارْ ثْعجَّاجْثْ،  
\m أَعذِّيسْ نّغْ إِڒصّقْ ذِي ثمُّورْثْ.   
\m
\v 27 كَّارْ، أوْشْ أَنغْ أَفُوسْ، فْذِي خَانغْ  
\m ذِي طّْوعْ ن ثْمخْسِيوْثْ نّشْ إِشوَّارنْ. \f ◼ \fr 44:‏27 \ft \+bd ’فْذِي‘\+bd* - خْزَارْ ’أَمفْذِي‘ - إِزهد. 78‏:35.\f*   
\b  
\b  
\m  
\c 45
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. س ثغْنِينْثْ ن ’ثْلِيلِّيشِينْ‘.\add* \add زڭْ أَيْثْ ن قُورَاحْ. أَخمِّي. إِزْڒِي ن ثَايْرِي.\add*\f ◼ \fr 45:‏1 \ft \+bd ’ثِيلِيلِّيشِينْ‘\+bd* - إِشْثْ ن مَارْكَا ن إِنُّووَّارنْ ذَايْسنْ أَژْرِي أَطَّاسْ.\f*   
\b  
\m
\v 2 زڭْ وُوڒْ إِنُو إِدُّوقّزْ-د  
\m إِجّْ ن وَاوَاڒْ ذ أَصبْحَانْ،  
\m قَّارغْ إِ ؤُجدْجِيذْ مِينْ سّْوجْذغْ،  
\m إِڒسْ إِنُو ذ ڒقْڒمْ ن إِجّْ ن ؤُمَارِيرْ إِمحْضنْ. \f ◼ \fr 45:‏2 \ft \+bd ’ڒقْڒمْ‘\+bd* - نِيغْ ’سْثِيلُو‘ نِيغْ ’بْلُومُو‘.\f*   
\m
\v 3 ”شكْ ثشْنِيذْ خْ مَارَّا ثَارْوَا ن بْنَاذمْ،  
\m ڒْْخَاضَارْ إِتّْوَازدْجعْ خْ إِينْشِيشنْ نّشْ،  
\m خْ ؤُيَا إِبَاركْ إِ شكْ أَربِّي إِ ڒبْذَا.   
\b  
\m
\v 4 بْيسْ سِّيفْ خْ ثْمسَّاضْثْ نّشْ،  
\m \add أَ\add* بُو-ثغْرُوضْثْ،  
\m ثِيسِّيقْثْ نّشْ ذ ڒْعزّْ نّشْ.   
\m
\v 5 \add وَاهْ\add*، ڒْعزّْ نّشْ! إِڒِي ثْفڒْحذْ،  
\m نْذهْ ذِي طّْوعْ ن ثِيذتّْ،  
\m \add ضِيدّْ إِ\add* ڒحْصَارثْ ن ثْسڭْذَا.  
\m أَفُوسْ نّشْ أَفُوسِي أَذْ شكْ إِسّڒْمذْ  
\m ثِيمسْڒَايِينْ سَّاڭّْوَاذنْثْ.   
\m
\v 6 فْڒِيثْشَاثْ نّشْ قضْعنْثْ،  
\m - \add وَاهْ،\add* ڒڭْنُوسْ أَذْ وْضَانْ سَاذُو \add ؤُفُوسْ\add* نّشْ -  
\m شُوقنْثْ ؤُڒْ ن ڒْعذْيَانْ ن ؤُجدْجِيذْ.   
\b  
\m
\v 7 ڒْكُورْسِي نّشْ إِڭلّْذنْ، \add أَ\add* أَربِّي،  
\m أَقَا-ث إِ ڒبْذَا قَاعْ.  
\m أَزدْجَاضْ ن ثْڭلْذِيثْ نّشْ  
\m ذ إِجّْ ن ؤُزدْجَاضْ ن ثْسڭْذَا. \x ◘ \xo 45:‏7 \xt عبر. 1‏:‏8\x*   
\m
\v 8 شكْ ثتّخْسذْ ثَاسڭْذَا ؤُ ثْشَارّْهذْ ڒْغَارْ.  
\m خْ ؤُيَا إِ شكْ إِذْهنْ، \add أَ\add* أَربِّي، أَربِّي نّشْ  
\m س زّشْثْ ن ڒفْرَاحثْ  
\m ثِيوَا إِ إِعْشِيرنْ نّشْ. \x ◘ \xo 45:‏8 \xt عبر. 1‏:‏9\x*   
\b  
\m
\v 9 مَارَّا ڒعْبَايَاثْ نّشْ  
\m أَمْ مِيرُّو ذ وشْفِيڒْ ذ ڒْقَارْفَا،  
\m زِي ڒقْصُورْ ن ڒْعَاجْ سّْفَارَّاحنْ شكْ  
\m س ؤُزنْزُونْ خْ إِفِيڒَانْ \add ن ڒْڭَامْبْرِي\add*، \f ◼ \fr 45:‏9 \ft \+bd ’أَشْفِيرْ‘\+bd* - إِخْسْ أَذْ يِينِي ’أَلُووِي‘ (’أَلُووِيسْ‘).\f*   
\m
\v 10 يسِّيسْ ن ؤُجدْجِيذْ أَقَا-ثنْثْ  
\m جَارْ ثِينوْجِيوِينْ نّشْ إِوقَّارنْ،  
\m ثَاسْڒِيثْ ن ؤُجدْجِيذْ ثْبدّْ أَشْ خْ ؤُفُوسِي،  
\m س \add ورُّوضْ زڭْ\add* وُورغْ إِغْڒَانْ قَاعْ زِي ؤُفِيرْ.   
\b  
\m
\v 11 سڒْ، \add أَ\add* يدْجِي، خْزَارْ، أوْشْ أَمزُّوغْ نّمْ!  
\m تُّو ڒْڭنْسْ نّمْ ذ ثَادَّارْثْ ن بَابَامْ!   
\m
\v 12 \add خنِّي\add* أَجدْجِيذْ أَذْ إِمّژْرِي ذڭْ وَاژْرِي نّمْ،  
\m مَاغَارْ نتَّا ذ سِيذِي نّمْ!  
\m بنْذقْ زَّاثسْ!   
\m
\v 13 يدْجِيسْ ن صُورْ س إِشْثْ ن ثَارْزفْثْ،  
\m \add وَاهْ،\add* أَيْثْ ن بُو-وَاڭْڒَا ن إِجّْ ن ڒْڭنْسْ  
\m أَذْ أَرْزُونْ أَذْ خَامْ أَرْضَانْ. \x ◘ \xo 45:‏13 \xt إِزهد. 72‏:‏10\x*   
\b  
\m
\v 14 يدْجِيسْ ن ؤُجدْجِيذْ  
\m أَقَا-ت ذ أَعُودْجِي مَارَّا ذَاخڒْ،  
\m أَرُّوضْ نّسْ ذ إِجّْ ن ؤُمُوذِي  
\m \add زڭْ ؤُفِيڒُو\add* ن وُورغْ.   
\m
\v 15 أَذْ ثتّْوَانْذهْ غَارْ ؤُجدْجِيذْ  
\m ذڭْ وَارُّوضْ س ثِينْثَاثْ إِفَارْزنْ.  
\m ثِيعْزَارِييِّينْ ثِينِّي ت إِضفَّارَانْ،  
\m أَقَا أَثنْثْ ذ ثِيمدُّوكَّاڒْ نّسْ  
\m نِّي د غَاركْ تّْوَاوْينْثْ.   
\m
\v 16 أَقَا تّْوَاوْينْثْ س ڒفْرَاحثْ ذ وَارْشقْ،  
\m \add أَمُّو\add* إِ غَا أَذْفنْثْ  
\m غَارْ ڒقْصَارْ ن ؤُجدْجِيذْ.   
\b  
\m
\v 17 ثَارْوَا نّشْ أَذْ إِڒِينْ  
\m ذڭْ ومْشَانْ ن ڒجْذُوذْ نّشْ،  
\m شكْ أَذْ ثنْ ثڭّذْ ذ ڒْحُوكَّامْ  
\m ذِي مَارَّا ثَامُّورْثْ.   
\m
\v 18 نشّْ أَذْ إِذَارغْ إِسمْ نّشْ  
\m ذِي كُوڒْ جِّيڒْ ذ \add كُوڒْ\add* جِّيڒْ \add أَوَارْنِي أَسْ\add*.  
\m خْ ؤُيَا، أَذْ شكْ قَاذَانْ  
\m مَارَّا ڒڭْنُوسْ إِ ڒبْذَا قَاعْ.“   
\b  
\b  
\m  
\c 46
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. زڭْ أَيْثْ ن قُورَاحْ.\add* \add س لهَارْپَاثْ إِتّْوَارِّيڭْلَانْ غَارْ سنّجْ. إِزْڒِي.\add*   
\b  
\m
\v 2 أَربِّي ذ أَمْشَانْ ن ثَاروْڒَا  
\m ذ جّهْذْ إِ نشِّينْ.  
\m أَقَا إِبَانْ-د إِتِّيشْ أَفُوسْ أَطَّاسْ  
\m ذِي ڒحْصَارَاثْ.   
\m
\v 3 خْ ؤُيَا وَارْ نتّڭّْوذْ شَا،  
\m وَاخَّا أَذْ ثْبدّڒْ ثَامُّورْثْ،  
\m أَذْ وْضَانْ إِذُورَارْ ذڭْ وُوڒْ نْ ڒبْحُورْ، \x ◘ \xo 46:‏3 \xt أَسَا. 16‏:‏18‏-‏21\x*   
\m
\v 4 أَذْ هَاجَانْثْ ڒْحمْڒَاثْ نّسْ،  
\m أَذْ ڭّنْثْ أَكُوفُّو،  
\m أَذْ نْهزّنْ إِذُورَارْ س ؤُنّقْڒبْ نّسْ! سِيلَاهْ.   
\b  
\m
\v 5 ثِيغزْرَاثِينْ ن إِغْزَارْ  
\m أَذْ سّْفَارّْحنْثْ ثَانْذِينْثْ ن أَربِّي،  
\m زَّاوشْثْ إِقدّْسنْ  
\m ن ثْزذِّيغِينْ ن ؤُمْعُودْجِي خْ كُوڒْشِي. \x ◘ \xo 46:‏5 \xt أَسَا. 22‏:‏1\x*   
\m
\v 6 أَربِّي أَقَا-ث ذِي ڒْوسْثْ نّسْ،  
\m وَارْ ثتّنْهزَّا،  
\m أَربِّي أَذْ أَسْ إِوْشْ أَفُوسْ  
\m خْمِي د غَا ثسِّيجْ ثُوفُّوثْ. \x ◘ \xo 46:‏6 \xt أَسَا. 14‏:‏1؛ 21‏:‏22، 23؛ زَاك.14‏:‏4‏-‏9\x*   
\m
\v 7 ڒڭْنُوسْ مُوزَّارنْ،  
\m ثِيڭلْذِيوِينْ نْهزّنْثْ.  
\m نتَّا إِڭَّا ثْمِيجَّا نّسْ أَذْ ثتّْوَاسڒْ،  
\m ثَامُّورْثْ أَقَا ثفْسِي.   
\m
\v 8 سِيذِي ن ڒْعسْكَارَاثْ أَقَا-ث أَكِيذْنغْ،  
\m أَربِّي ن يَاعْقُوبْ  
\m ذ لْبُورْجْ نّغْ يُوعْڒَانْ. سِيلَاهْ.   
\b  
\m
\v 9 أَسمْ-د، خْزَارمْ ثِيمڭَّا ن سِيذِي،  
\m نتَّا إِ إِڭِّينْ أَنخْڒِيعْ خْ ثمُّورْثْ.   
\m
\v 10 نتَّا إِسّْبدَّا إِمنْغَانْ  
\m أَڒْ أَنڭَّارْ ن ثمُّورْثْ،  
\m نتَّا أَذْ يَارْژْ ڒْقوْسْ،  
\m إِشَّاثْ لَانْسَا ذِي إِوثْوِيثنْ،  
\m إِكَارُّوثنْ إِسّشْمَاضْ إِ-ثنْ س ثْمسِّي. \x ◘ \xo 46:‏10 \xt مِيخَا 4‏:‏3؛ أَسَا. 2‏:‏26‏-‏28؛ \x*   
\m
\v 11 سْبدّْ، سْنمْ إِلَّا أَقَا نشّْ ذ أَربِّي.  
\m نشّْ أَذْ تّْوَاسّْڭعّْذغْ جَارْ ڒڭْنُوسْ،  
\m نشّْ أَذْ تّْوَاسّْڭعّْذغْ خْ ثمُّورْثْ.   
\m
\v 12 سِيذِي ن ڒْعسْكَارَاثْ أَقَا-ث أَكِيذْنغْ،  
\m أَربِّي ن يَاعْقُوبْ  
\m ذ لْبُورْجْ يُوعْڒَانْ إِ نشِّينْ.  
\m سِيلَاهْ.   
\b  
\b  
\m  
\c 47
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. زڭْ أَيْثْ ن قُورَاحْ. أَزهّذْ.\add*   
\b  
\m
\v 2 \add أَ\add* مَارَّا ڒڭْنُوسْ، وْثمْ ذڭْ إِفَاسّنْ،  
\m ذُوقّْزمْ س ؤُسْڒِيوْڒوْ زَّاثْ إِ أَربِّي.   
\m
\v 3 مَاغَارْ سِيذِي، أَمْعُودْجِي خْ كُوڒْشِي،  
\m أَقَا إِسَّاڭّْوَاذْ،  
\m نتَّا ذ إِجّْ ن ؤُجدْجِيذْ ذ أَمقّْرَانْ  
\m خْ مَارَّا ثَامُّورْثْ.   
\m
\v 4 نتَّا إِسَّاضَارَا أَنغْ ڒڭْنُوسْ،  
\m نتَّا \add يَارَّا\add* شُّوعُوبْ سَاذُو إِضَارنْ نّغْ.   
\m
\v 5 نتَّا إِفَارّزْ ثَاسْغَارْثْ نّغْ إِ نشِّينْ،  
\m \add ثنِّي ذ\add* أَفيّشْ ن يَاعْقُوبْ  
\m ونِّي ثُوغَا إِتّخْسْ. سِيلَاهْ.   
\b  
\m
\v 6 أَربِّي يُوڒِي سنّجْ س ؤُسْڒِيوْڒوْ،  
\m سِيذِي، غَارْ ثْمِيجَّا ن ؤُسُوضِي  
\m ذڭْ ؤُيِيشّْ ن إِشَارِّي.   
\m
\v 7 زهّْذمْ إِ أَربِّي، زهّْذمْ!  
\m زهّْذمْ إِ ؤُجدْجِيذْ، زهّْذمْ!   
\m
\v 8 مَاغَارْ أَربِّي ذ أَجدْجِيذْ  
\m خْ مَارَّا ثَامُّورْثْ.  
\m زهّْذمْ \add أَيَا\add* إِ ؤُخمِّي ذَايسْ.   
\m
\v 9 أَربِّي إِحكّمْ خْ ڒڭْنُوسْ،  
\m أَربِّي إِتّْغِيمَا  
\m خْ ڒْعَارْشْ نّسْ إِقدّْسنْ.   
\b  
\m
\v 10 ثَارْوَا ن ثَاصِيڒثْ نْ ڒڭْنُوسْ  
\m تّْوَاسّْمُوننْ  
\m أَكْ-ذ ڒْڭنْسْ ن أَربِّي ن إِبْرَاهِيمْ،  
\m مَاغَارْ ثِيسدَّارِييّنْ إِ ؤُسڒْقِي ن ثمُّورْثْ  
\m إِ أَربِّي.  
\m نتَّا أَقَا إِتّْوَاسّْعُودْجْ قَاعْ.   
\b  
\b  
\m  
\c 48
\m
\v 1 \add إِزْڒِي، أَزهّذْ زڭْ أَيْثْ ن قُورَاحْ.\add*   
\b  
\m
\v 2 سِيذِي ذ أَمقّْرَانْ،  
\m إِسْذَاحدْجْ أَذْ إِتّْوَاسّمْغَارْ أَطَّاسْ،  
\m ذِي ثنْذِينْثْ ن أَربِّي نّغْ،  
\m خْ وذْرَارْ نّسْ إِقدّْسنْ.   
\m
\v 3 ڒُْوعْڒَا \add نّسْ\add* ذ ڒمْڒَاحثْ،  
\m أَذْرَارْ ن صِيهْيُونْ أَقَا-ث ذ ڒفْرَاحثْ  
\m إِ مَارَّا ثَامُّورْثْ،  
\m غَارْ ؤُغزْذِيسْ ن شَّامَالْ  
\m ن ثنْذِينْثْ ن ؤُجدْجِيذْ ذ أَمقّْرَانْ. \x ◘ \xo 48:‏3 \xt إِزهد. 2‏:‏8، 9؛ مت. 5‏:‏35؛ عبر. 12‏:‏22، 23\x*   
\b  
\m
\v 4 أَربِّي أَقَا-ث ذِي ڒقْصُورْ نّسْ،  
\m نتَّا إِتّْوَاسّنْ أَمْ يِيجّْ ن لْبُورْجْ يُوعْڒَانْ.   
\m
\v 5 مَاغَارْ خْزَارْ، إِجدْجِيذنْ مُوننْ،  
\m أَقَا فّْغنْ جْمِيعْ.   
\m
\v 6 \add ڒَْامِي ث\add* ژْرِينْ، ثْبهْثنْ،  
\m أَقَا نّْجرْفَانْ ؤُشَا أَروْڒنْ ذغْيَا.   
\m
\v 7 ذِينِّي ثطّفْ إِ-ثنْ ثَارْجِيجِيثْ،  
\m أَمْ ڒحْرِيقْ ن إِشْثْ ن \add ثمْغَارْثْ\add* ثتَّارُو.   
\m
\v 8 س ؤُسمِّيضْ زِي شَّارْقْ  
\m ثتَّارژِّيذْ إِغَارُّوبَا ن ثَارْشِيشْ.   
\b  
\m
\v 9 أَمْ مَامّشْ ثُوغَا ت نسْڒَا،  
\m أَمُّو إِ ت نثْوَاڒَا  
\m ذِي ثنْذِينْثْ ن سِيذِي ن ڒْعسْكَارَاثْ،  
\m ذِي ثنْذِينْثْ ن أَربِّي نّغْ.  
\m أَربِّي أَذْ ت إِسّمْثنْ إِ ڒبْذَا. سِيلَاهْ.   
\b  
\m
\v 10 \add أَ\add* أَربِّي،  
\m نِيذَارْ ثَامخْسِيوْثْ نّشْ إِشوَّارنْ،  
\m ذِي ڒْوسْطْ ن زَّاوشْثْ نّشْ ثَامقّْرَانْثْ.   
\m
\v 11 أَمْ إِسمْ نّشْ، \add أَ\add* أَربِّي،  
\m أَمُّو إِتَّاكّْوَاضْ ؤُڒَا ذ شَّانْ نّشْ  
\m أَڒْ ثِينڭُّورَا ن ثمُّورْثْ.  
\m أَفُوسْ نّشْ أَفُوسِي إِشُّورْ س ثْسڭْذَا.   
\m
\v 12 أجّْ أَذْرَارْ ن صِيهْيُونْ أَذْ إِفَارْحْ،  
\m جّمْ يسِّيسْ ن يَاهُوذَا أَذْ أَرشْقنْثْ  
\m زِي سِّيبّثْ ن ڒحْكَامَاثْ نّشْ.   
\b  
\m
\v 13 كّمْ خْ صِيهْيُونْ، نّْضمْ أَسْ-د،  
\m حسْبمْ صُّومْعَاثْ نّسْ!   
\m
\v 14 ڭّمْ ؤُڒْ نْومْ خْ ڒْحِيضْ نّسْ إِجهْذنْ،  
\m خْزَارمْ مْلِيحْ ذِي ڒقْصُورْ نّسْ،  
\m حِيمَا أَذْ ت تّْعَاوْذذْ إِ جِّيڒْ  إِ د غَا يَاسنْ.   
\m
\v 15 مَاغَارْ أَربِّي وَانِيثَا  
\m ذ أَربِّي نّغْ  
\m \add إِ\add* ڒبْذَا قَاعْ.  
\m نتَّا أَذْ أَنغْ إِنْذهْ  
\m غَارْ ؤُجمَّاضْ ن ڒْموْثْ.   
\b  
\b  
\m  
\c 49
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. زڭْ أَيْثْ ن قُورَاحْ. أَزهّذْ.\add*   
\b  
\m
\v 2 سْڒمْ \add إِ\add* ؤُيَا، مَارَّا ڒڭْنُوسْ،  
\m سْحسّمْ مَارَّا، \add أَ\add* إِمزْذَاغْ ن دُّونشْثْ،   
\m
\v 3 أَمْ ثَارْوَا ن أَذَامْ،  
\m أَمْ ثَارْوَا ن إِجّْ ن ورْيَازْ،  
\m أَيْثْبَابْ ن وَاڭْڒَا ذ إِمزْڒَاضْ  
\m جْمِيعْ أَكْ-ذ وَايَاوْيَا!   
\m
\v 4 أَقمُّومْ إِنُو إِسَّاوَاڒْ ثِيغِيثْ،  
\m إِخَارِّيصنْ ن وُوڒْ إِنُو  
\m \add شُّورنْ\add* س ڒفْهَامثْ.   
\m
\v 5 نشّْ أَذْ وْشغْ أَمزُّوغْ إِنُو  
\m إِ وَاوَاڒْ إِوزْننْ،  
\m أَذْ سَّارْڭْبغْ ثْحَاجِيثْ إِنُو ن ثْوَافِيثْ  
\m غَارْ \add ثِيرَارْثْ ن\add* ڒْڭَامْبْرِي. \x ◘ \xo 49:‏5 \xt إِزهد. 78‏:‏2؛ مت. 13‏:‏35\x*   
\b  
\m
\v 6 مَايمِّي غَا ڭّْوذغْ  
\m ذڭْ وُوسَّانْ إِعفَّاننْ،  
\m خْمِي د أَيِي ثتّنّضْ ڒْمُوعْصِييّثْ  
\m ن يِينِّي ذ أَيِي د-إِضفَّارنْ ذِي ثِيرِي إِنُو. \f ◼ \fr 49:‏6 \ft \+bd ’ذِي ثِيرِي إِنُو‘\+bd* - س ثْعِيبْرَانِيثْ ’ذڭْ إِنَارْزِيونْ إِنُو‘.\f*  \x ◘ \xo 49:‏6 \xt إِڭجذ. 4‏:‏18\x*   
\m
\v 7 \add أَقَا ذِينْ\add* إِنِّي إِتّْشَاڒنْ  
\m خْ ڒكْسِيبثْ نْسنْ،  
\m تّْفيّْشنْ س وَاڭْڒَا نْسنْ أَمقّْرَانْ،   
\m
\v 8 \add مَاشَا\add* ؤُڒَا ذ إِجّْ ن ثَاوْمَاثْ  
\m وَارْ إِزمَّارْ أَذْ إِفْذِي يِيجّْ ن ورْيَازْ،  
\m وَارْ إِزمَّارْ أَذْ إِخدْجصْ  
\m دّيّثْ ن يِيخفْ نّسْ إِ أَربِّي. \f ◼ \fr 49:‏8 \ft \+bd ’إِفْذِي‘\+bd* - خْزَارْ إِزهد. 78‏:35.\f*   
\m
\v 9 تَّامَانْ ن وصْڒَاحْ ن ڒعْمَارْ نْسنْ  
\m ثِيغْڒَا أَطَّاسْ، وَارْ د-ثتِّيسْ إِ ڒبْذَا،   
\m
\v 10 حِيمَا نتَّا أَذْ إِدَّارْ إِ ڒبْذَا،  
\m عمَّارْصْ وَارْ إِتّْكِيشُّو.   
\m
\v 11 مَاغَارْ إِتّْوَاڒَا إِمِيغِيسنْ مُّوثنْ،  
\m \add ؤُڒَا ذ\add* أَبُوهَاڒِي ذ ؤُقفُّوحْ  
\m أَذْ تّْوَاقسّنْ س ثْنَاينْ،  
\m أَذْ جّنْ ڒكْسِيبثْ نْسنْ  
\m إِ إِنّغْنِي أَوَارْنِي أَسنْ.   
\m
\v 12 أَخَارّصْ ن وُوڒْ نْسنْ  
\m أَقَا ثُوذْرِينْ نْسنْ \add أَذْ قِّيمنْثْ\add* إِ ڒبْذَا،  
\m ثِيزذِّيغِينْ نْسنْ زِي جِّيڒْ أَڒْ جِّيڒْ.  
\m \add وَاخَّا\add* ؤُڒَا ذ ثِيمُّورَا  
\m ڭِّينْ أَسنْثْ إِسْمَاونْ نْسنْ.   
\m
\v 13 بْنَاذمْ إِ غَارْ إِدْجَا شَّانْ، وَارْ إِتّْغِيمِي شَا،  
\m نتَّا أَمْ ڒبْهِيمثْ إِفنَّانْ.   
\b  
\m
\v 14 وَا ذ أَبْرِيذْ إِ غَارْسنْ،  
\m مِينْ خفْ تّْسنَّاذنْ،  
\m ؤُشَا إِنِّي ثنْ إِضفَّارنْ أَذْ جِّيوْننْ  
\m س ؤُقمُّومْ نْسنْ. سِيلَاهْ. \f ◼ \fr 49:‏14 \ft \+bd ’إِنِّي ثنْ إِضفَّارنْ‘\+bd* - أَوَاڒنْ إِ نْثَافْ ذِي أَيَاثْ 13-15 سَّارْوَاسنْ أَبْرِيذْ ن إِوْذَانْ إِمْعفَّارنْ أَكْ-ذ وبْرِيذْ ن إِشْثْ ن ثْحِيمَارْثْ ن وُودْجِي نِّي إِڭُّورنْ أَكْ-ذ وَايَاوْيَا أَمْ تّتّنْ أَرّْبِيعْ (سّْيَاوَاننْ إِخفْ نْسنْ س ؤُقمُّومْ نْسنْ) ؤُشَا ضفَّارنْ إِجّْ ونّغْنِي ؤُ غَارْ ؤُنڭَّارُو سَّاريّْحنْ إِخفْ نْسنْ ذِي ڒَاخَارْثْ. نِيثْنِي ڭُّورنْ أَمْ تّتّنْ أَرّْبِيعْ، أَمُّو ذ أَبْرِيذْ ن إِمْعفَّارنْ ذِي ثُوذَارْثْ-أَ. نِيثْنِي أَرِّينْ مژْرِي نْسنْ، وَارْ فكَّارنْ شَا ذِي أَربِّي، مْغِيرْ ذِي مِينْ خْسنْ نِيثْنِي. ثَانڭَّارُوثْ ن إِوْذَانْ-أَ ثْبَانْ ذِي أَيثْ ن 15.\f*   
\m
\v 15 أَمْ وُودْجِي سَّاريّْحنْ نِيثْنِي إِخفْ نْسنْ  
\m ذِي ڒَاخَارْثْ،  
\m ڒْموْثْ أَذْ ثنْ ثَارْوسْ.  
\m إِمْسڭَّاذنْ أَذْ خَاسنْ حكْمنْ خْ صّْبحْ،  
\m أَدُّوذْ نْسنْ \add أَذْ إِذْوڒْ\add* إِ ڒْغشّْ ذِي ڒَاخَارْثْ،  
\m \add تّْوَاسُّوفّْغنْ نِيثْنِي\add* زِي ثْزذِّيغْثْ نْسنْ. \f ◼ \fr 49:‏15 \ft \+bd ’ثَازذِّيغْثْ‘\+bd* - أَرِّيمثْ ذ ثَازذِّيغْثْ مَانِي إِخْسْ أَربِّي أَذْ ذِينْ إِزْذغْ. س ؤُينِّي أَرِّيمثْ ذ ثَازذِّيغْثْ ن أَربِّي، مَاشَا بْنَاذمْ إِ وَارْ إِتّخْسنْ أَذْ يَارْزمْ ثَازذِّيغْثْ نِّي إِ أَربِّي، أَذْ إِتّْوَاسُّوفّغْ زِي ثْزذِّيغْثْ ن أَربِّي أَوَارْنِي ڒْموْثْ نّسْ، مِينْزِي ثَازذِّيغْثْ نِّي وَارْ ثدْجِي ذ ڒْمُوڒْكْ ن بْنَاذمْ، مَاشَا ن أَربِّي.\f*   
\m
\v 16 مَاشَا أَربِّي أَذْ إِفْذِي ڒعْمَارْ إِنُو  
\m زڭْ ؤُفُوسْ ن ڒَاخَارْثْ،  
\m مَاغَارْ نتَّا أَذْ أَيِي يَاوِي \add أَكِيسْ\add*. سِيلَاهْ. \f ◼ \fr 49:‏16 \ft \+bd ’إِفْذِي‘\+bd* - خْزَارْ إِزهد. 78‏:35.\f*   
\m
\v 17 وَارْ تّڭّْوذْ شَا مَاڒَا شَا ن ورْيَازْ  
\m إِذْوڒْ ذ بُو-وَاڭْڒَا،  
\m خْمِي إِ غَا يَارْنِي ؤُشُووَّارْ ن ثَادَّارْثْ نّسْ،   
\m
\v 18 مَاغَارْ ذِي ڒْموْثْ نّسْ  
\m وَارْ كِيذسْ إِكسِّي شَا مَارَّا أَيَا،  
\m أَشُووَّارْ نّسْ وَارْ إِهكّْوِي أَكِيذسْ  
\m أَوَارْنِي أَسْ.   
\m
\v 19 وَاخَّا إِبَاركْ ڒعْمَارْ نّسْ  
\m ذِي ثُوذَارْثْ نّسْ،  
\m وَاخَّا نِيثْنِي أَذْ شكْ سّمْغَارنْ  
\m مَاغَارْ ثڭِّيذْ مِينْ إِصبْحنْ إِ يِيخفْ نّشْ،   
\m
\v 20 أَقَا أَذْ د-يَاوضْ \add ڒعْمَارْ\add* نّسْ  
\m غَارْ جِّيڒْ ن ڒجْذُوذْ نّسْ،  
\m \add نِّي\add* وَارْ ژَترّنْ ثَافَاوْثْ إِ ڒبْذَا.   
\m
\v 21 بْنَاذمْ إِ غَارْ إِدْجَا شَّانْ،  
\m \add مَاشَا\add* وَارْ إِفهّمْ،  
\m نتَّا أَمْ ڒبْهِيمثْ إِفنَّانْ.   
\b  
\b  
\m  
\c 50
\m
\v 1 \add إِجّْ ن ؤُزهّذْ ن أَسَافْ. أَربِّي خْ مَارَّا إِربِّيثنْ،\add* \add سِيذِي إِسَّاوَاڒْ. نتَّا إِتّْڒَاغَا إِ ثمُّورْثْ\add* \add زِي مَانِي د-ثنْقَارْ ثْفُوشْثْ أَڒْ مَانِي ثغْڒِي.\add*   
\b  
\m
\v 2 زِي صِيهْيُونْ، أَژْرِي إِكمّْڒنْ،  
\m إِتّْبَانْ أَربِّي إِتِّيسِّيقْ.   
\m
\v 3 أَربِّي نّغْ أَذْ د-يَاسْ،  
\m وَارْ إِسّغْذْ شَا.  
\m ثِيمسِّي زَّاثسْ أَذْ ثشّْ،  
\m ثَاحَارْيَاضْثْ إِ ذ أَسْ د-إِتّنّْضنْ  
\m أَذْ ثْسُوضْ أَطَّاسْ.   
\b  
\m
\v 4 نتَّا أَذْ إِڒَاغَا إِ إِجنْوَانْ سنّجْ،  
\m إِ ثمُّورْثْ حِيمَا أَذْ إِحْكمْ خْ ڒْڭنْسْ نّسْ:   
\m
\v 5 ”سْمُونمْ-د غَارِي إِمْثِيقَّانْ إِنُو،  
\m إِنِّي كِيذِي إِتّڭّنْ ڒْعَاهْذْ س ثْغَارْصْثْ.“   
\m
\v 6 إِجنْوَانْ تّْبَارّْحنْ ثَاسڭْذَا نّسْ،  
\m مَاغَارْ أَربِّي س يِيخفْ نّسْ  
\m أَقَا-ث ذ ڒْقَاضِي. سِيلَاهْ. \f ◼ \fr 50:‏6 \ft \+bd ’ڒْقَاضِي‘\+bd* - نِيغْ ’أَمزْرُوفْ‘.\f*   
\b  
\m
\v 7 ”سڒْ، \add أَ\add* ڒْڭنْسْ إِنُو،  
\m ؤُ نشّْ أَذْ سِّيوْڒغْ، إِسْرَائِيل،  
\m نشّْ أَذْ شهْذغْ ضِيدّْ نّشْ:  
\m أَقَا نشّْ، أَربِّي، ذ أَربِّي نّشْ!   
\m
\v 8 وَارْ إِدْجِي خْ ثْغَارْصَا نّشْ  
\m أَذْ شكْ وبّْخغْ،  
\m مَاغَارْ ثِيغَارْصَا نّشْ  
\m أَقَا أَثنْثْ ڒبْذَا زَّاثِي.   
\m
\v 9 وَارْ كسِّيغْ شَا أَفُونَاسْ أَمژْيَانْ  
\m زِي ثَادَّارْثْ نّشْ،  
\m ؤُڒَا ذ إِغَايْضنْ زِي ثقْوِيرِينْ نّشْ.   
\m
\v 10 مَاغَارْ مَارَّا إِمُودَّارْ ن وزْغَارْ،  
\m أَقَا إِنُو، ڒْمَاڒْ خْ وَاڒفْ إِذُورَارْ. \f ◼ \fr 50:‏10 \ft \+bd ’أَزْغَارْ‘\+bd* - نِيغْ ’ڒْغَابثْ‘ نِيغْ ’ثَازْڭَانْثْ‘.\f*   
\m
\v 11 نشّْ سّْنغْ مَارَّا إِجْضَاضْ ن إِذُورَارْ،  
\m \add مَارَّا\add* مِينْ إِتّنْهزَّانْ ذڭْ إِيَّارْ،  
\m أَقَا-ث إِنُو.   
\m
\v 12 مْڒِي ثُوغَا ذَايِي ڒَاژْ،  
\m مَا وَارْ ذ أَشْ ث قَّارغْ،  
\m مَاغَارْ إِنُو دُّونشْثْ ذ ؤُعمَّارْ نّسْ. \x ◘ \xo 50:‏12 \xt ؤُف. 19‏:‏5؛ أَعَوذ. 10‏:‏14؛ أَيُوبْ 41‏:‏3؛ إِزهد. 24‏:‏1؛ 1 كُور. 10‏:‏26، 28\x*   
\m
\v 13 مَا أَذْ شّغْ \add خنِّي\add*  
\m أَيْسُومْ ن \add إِفُونَاسنْ\add* إِجهْذنْ،  
\m نِيغْ إِذَامّنْ ن إِغَايْضنْ؟   
\m
\v 14 أَوِي-د إِ أَربِّي ثَاوْهِيبْثْ ن ؤُقَاذِي،  
\m كمّڒْ لْوُوعُوذْ نّشْ إِ ؤُمْعُودْجِي خْ كُوڒْشِي. \x ◘ \xo 50:‏14 \xt أَعَوذ. 23‏:‏22؛ أَيُوبْ 22‏:‏27؛ إِزهد. 76‏:‏12؛ أَمب. 5‏:‏3، 4، 5\x*   
\m
\v 15 ڒَاغَا أَيِي-د ذڭْ وَاسّْ ن ڒحْصَارثْ،  
\m \add خنِّي\add* أَذْ شكْ سّْنجْمغْ  
\m ؤُشَا شكْ أَذْ أَيِي ثڭّذْ شَّانْ.“   
\b  
\m
\v 16 \add مَاشَا\add* إِ ؤُعفَّانْ إِقَّارْ أَربِّي:  
\m ”مَايمِّي ثْبَارّْحذْ ثِيوصَّا إِنُو،  
\m \add مَايمِّي إِ\add* ثڭِّيذْ ڒْعَاهْذْ إِنُو  
\m ذڭْ ؤُقمُّومْ نّشْ،   
\m
\v 17 \add ؤُمِي\add* ثْشَارّْهذْ تَّارْبِييّثْ إِنُو  
\m ؤُ ثنْضَارذْ أَوَاڒنْ إِنُو أَوَارْنِي أَشْ.   
\m
\v 18 مَاڒَا ثژْرِيضْ إِجّْ ن ؤُخوَّانْ،  
\m أَمُّو إِ ثڭُّورذْ أَكِيذسْ،  
\m ثتّْصُورِيذْ أَكْ-ذ يِينِّي إِزنَّانْ.   
\m
\v 19 أَقمُّومْ نّشْ ثتَّارِّيذْ إِ-ث إِ ڒْغَارْ،  
\m إِڒسْ نّشْ إِتّْخَارّصْ ذڭْ وشْمَاثْ.   
\m
\v 20 ثتّْغِيمِيذْ \add ذِينِّي،\add* ثسَّاوَاڒذْ خْ ؤُمَاشْ،  
\m ثسّفْذَاحضْ زِي مِّيسْ ن يمَّاسْ.   
\m
\v 21 أَيَا ثتّڭّذْ ؤُ نشّْ سّغْذِيغْ.  
\m تّْغِيڒْ أَشْ، أَقَا أَيِي أَمْ شكْ.  
\m نشّْ أَذْ شكْ وبّْخغْ،  
\m أَذْ سَّارْسغْ \add دّْنُوبْ نّشْ\add*  
\m زَّاثْ إِ ثِيطَّاوِينْ نّشْ.   
\b  
\m
\v 22 فْهمْ أَيَا \add خنِّي\add*، \add أَ شكْ\add* إِ إِتُّونْ أَربِّي،  
\m حِيمَا وَارْ \add شكْ\add* ثْمزّْقغْ  
\m \add أَمْ\add* وَارْ ذِينْ إِتِّيڒِي ؤُفكِّي.“   
\m
\v 23 ونِّي د-إِتَّاوْينْ ثَاغَارْصْثْ ن ؤُقَاذِي،  
\m إِتّڭّْ أَيِي شَّانْ ؤُ إِسّوْجَاذْ أَبْرِيذْ،  
\m حِيمَا أَذْ أَسْ سّشْنغْ أَسنْجمْ ن أَربِّي.   
\b  
\b  
\m  
\c 51
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. أَزهّذْ ن ذَاوُوذْ.\add*   
\m
\v 2 \add أَڒَامِي إِ غَارسْ د-يُوسَا ؤُنَابِي نَاثَانْ، أَوَارْنِي ڒَامِي يُوذفْ ذَاوُوذْ خْ بَاثْ-شَابَاعْ.\add* \f ◼ \fr 51:‏2 \ft \+bd ’ذَاوُوذْ‘\+bd* - س ثِيعْبْرَانِيثْ ’نتَّا‘.\f*  \x ◘ \xo 51:‏2 \xt 2 صم. 11‏:‏4؛ 12‏:‏1 \x*   
\b  
\m
\v 3 حِينّْ خَافِي، \add أَ\add* أَربِّي،  
\m عْلَاحْسَابْ ثَامخْسِيوْثْ نّشْ إِشوَّارنْ.  
\m مْسحْ إِخطَّانْ إِنُو  
\m عْلَاحْسَابْ أَفيّضْ ن أَرّحْمثْ نّشْ.   
\m
\v 4 سِّيرْذْ ڒْمُوعْصِييّثْ إِنُو زَّايِي مَارَّا،  
\m سِيزْذڭْ أَيِي زِي دّنْبْ إِنُو،   
\b  
\m
\v 5 مَاغَارْ نشّْ سّْنغْ إِخطَّانْ إِنُو،  
\m دّنْبْ إِنُو ڒبْذَا إِبدّْ أَيِي-د  
\m غَارْ ثِيطَّاوِينْ. \f ◼ \fr 51:‏5 \ft \+bd ’إِبدّْ أَيِي-د غَارْ ثِيطَّاوِينْ‘\+bd* - س ثْعِيبْرَانِيثْ ’إِبدّْ قِيبَاتْشْ إِ نّشْ‘.\f*   
\m
\v 6 أَكِيذكْ، \add أَكِيذكْ\add* وَاهَا إِ خْضِيغْ،  
\m ڭِّيغْ مِينْ إِدْجَانْ ذ أَعفَّانْ  
\m جَارْ ثِيطَّاوِينْ نّشْ،  
\m أَڒَامِي شكْ ثْسڭّْذذْ  
\m ذڭْ وَاوَاڒنْ نّشْ،  
\m ثصْفِيذْ ذِي ڒحْكَامَاثْ نّشْ. \x ◘ \xo 51:‏6 \xt رُوم. 3‏:‏4\x*   
\b  
\m
\v 7 خْزَارْ، تّْوَاخڒْقغْ-د ذِي دّْنُوبْ،  
\m ذِي دّْنُوبْ ثكْسِي أَيِي يمَّا.   
\m
\v 8 خْزَارْ، شكْ ثتّخْسذْ ثِيذتّْ ذِي ذَاخڒْ،  
\m ذِي ثْنُوفّْرَا ثسّْشَانذْ أَيِي ثِيغِيثْ.   
\b  
\m
\v 9 كْسِي خَافِي دّْنُوبْ س ثْعلْدْجثْ،  
\m خنِّي أَذْ ذوْڒغْ قُّورغْ،  
\m سِيرْذْ أَيِي، \add خنِّي\add* أَذْ ذوْڒغْ  
\m ذ أَشمْڒَاڒْ خْ وذْفڒْ. \x ◘ \xo 51:‏9 \xt لَاوِي 14‏:‏4، 6؛ ڒخْڒ. 19‏:‏6، 18؛ إِشا. 1‏:‏18\x*   
\m
\v 10 أَرّْ أَيِي أَذْ سْڒغْ أَرْشُوقْ ذ ڒفْرَاحثْ،  
\m حِيمَا إِغْسَانْ نِّي ثْڒبْزذْ شكْ،  
\m أَذْ شضْهنْ س ڒفْرَاحثْ.   
\m
\v 11 سْنُوفَّارْ ؤُذمْ نّشْ  
\m زَّاثْ إِ دّْنُوبْ إِنُو،  
\m مْسحْ إِ مَارَّا ڒْمُوعْصِييّثْ إِنُو.   
\b  
\m
\v 12 خْڒقْ-د ذَايِي ؤُڒْ إِزْذِيڭْ، \add أَ\add* أَربِّي،  
\m جدّذْ ذِي ذَاخڒْ إِنُو  
\m إِجّْ ن أَرُّوحْ إِمثْننْ.   
\m
\v 13 وَارْ ذ أَيِي نطَّارْ زڭْ وُوذمْ نّشْ،  
\m وَارْ زَّايِي تّكّسْ  
\m أَرُّوحْ إِقدّْسنْ نّشْ.   
\b  
\m
\v 14 أوْشْ أَيِي عَاوذْ  
\m ڒفْرَاحثْ ن ؤُسنْجمْ نّشْ،  
\m ؤُڒَا ذ إِجّْ ن بُوحْبڒْ أَمْسعَّافْ  
\m إِ كِيذِي غَا إِبدّنْ.   
\m
\v 15 \add خنِّي\add* أَذْ سّْغَارغْ إِبْرِيذنْ نّشْ  
\m إِ يِينِّي \add خَاكْ\add* إِعدَّانْ،  
\m \add حِيمَا\add* أَذْ غَاركْ د -عقْبنْ إِمذْنَابْ.   
\b  
\m
\v 16 فكّْ أَيِي زڭْ ؤُمَارْوَاسْ ن إِذَامّنْ،  
\m \add أَ\add* أَربِّي، أَربِّي ن ؤُسنْجمْ إِنُو،  
\m \add خنِّي\add* أَذْ إِسْڒوْڒِيوْ إِڒسْ إِنُو  
\m خْ ثْسڭْذَا نّشْ.   
\m
\v 17 أَرْزمْ أَيِي إِينْشِيشنْ إِنُو، \add أَ\add* سِيذِي إِنُو،  
\m \add خنِّي\add* أَذْ إِبَارّحْ ؤُقمُّومْ إِنُو  
\m س شَّانْ نّشْ،   
\m
\v 18 مَاغَارْ وَارْ ذ أَكْ ثشْقِي ثْغَارْصْثْ،  
\m إِڒِي وْشِيغْ أَشْ ت،  
\m ثَاغَارْصْثْ ن وشْمَاضْ  
\m وَارْ ذ أَشْ د-ثتِّيسْ خْ ڒْخَاضَارْ.   
\m
\v 19 ثِيغَارْصَا ن أَربِّي  
\m أَقَا أَثنْثْ ذ إِجّْ ن بُوحْبڒْ يَارژْ،  
\m إِجّْ ن وُوڒْ إِدّزْ  
\m وَارْ ث ثسّحْقَارِيذْ، \add أَ\add* أَربِّي!   
\b  
\m
\v 20 أڭّْ ڒْخَارْ إِ صِيهْيُونْ عْلَاحْسَابْ أَرْضَا نّشْ،  
\m بْنَا ڒحْيُوضْ ن ؤُرْشَالِيمْ!   
\m
\v 21 خنِّي أَذْ ثَارْضِيذْ ذِي ثْغَارْصَا ن ڒْمُوعْصِييّثْ،  
\m ذِي ثْغَارْصْثْ ن وشْمَاضْ إِكمّْڒنْ.  
\m \add خنِّي\add* أَذْ قدّْمنْ إِفُونَاسنْ إِمژْيَاننْ  
\m خْ ؤُعَالْطَارْ نّشْ،   
\b  
\b  
\m  
\c 52
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. أَخمِّي ن ذَاوُوذْ.\add*   
\m
\v 2 \add ڒَْامِي د-يُوسَا ذُووَاعْ، زِي إِذُومْ،\add* \add إِخبَّارْ شَاوُولْ، إِنَّا أَسْ:\add*  
\m \add ”أَقَا ذَاوُوذْ يُوسَا-د غَارْ ثَادَّارْثْ ن أَخِيمَالِيكْ.“\add* \x ◘ \xo 52:‏2 \xt 1 صم. 22‏:‏9‏-‏23\x*   
\b  
\m
\v 3 مَامّشْ ثْفيّْشذْ زِي ثْعفَّانْثْ، \add أَ\add* جِّيهڒْ؟  
\m ثَامخْسِيوْثْ إِشوَّارنْ ن أَربِّي  
\m \add ثتّكّْ\add* أَسّْ إِمُونْ.   
\m
\v 4 إِڒسْ نّشْ إِتّْخَارّصْ ذِي ڒْغَارْ،  
\m أَمْ مَامّشْ ڒْمُوسْ إِقضْعنْ إِ ؤُحفِّي  
\m يِيوْيِي ذْرُوشْثْ س ڒْغفْڒثْ.   
\m
\v 5 شكْ ثتّخْسذْ ثَاعفَّانْثْ أَطَّاسْ خْ ثْصبْحَانْثْ،  
\m ڒْهَارْذْ س إِخَارِّيقنْ  
\m كْثَارْ خْ ڒْهَارْذْ ن ثْسڭْذَا. سِيلَاهْ.   
\m
\v 6 شكْ ثتّخْسذْ أَوَاڒنْ إِتَّاكّْوَارنْ،  
\m ؤُڒَا ذ إِڒسْ \add إِشُّورْ\add* س وشْمَاثْ.   
\b  
\m
\v 7 مَاشَا أَربِّي أَذْ شكْ يَاردّدْجْ إِ ڒبْذَا،  
\m نتَّا أَذْ شكْ إِطّفْ،  
\m أَذْ شكْ إِكّسْ زِي ثْزذِّيغْثْ.  
\m نتَّا أَذْ شكْ إِقْڒعْ زڭْ إِژوْرَانْ نّشْ  
\m زِي ثمُّورْثْ ن يِينِّي إِدَّارنْ. سِيلَاهْ.   
\m
\v 8 إِمْسڭَّاذنْ أَذْ ث ژَترنْ أَذْ ڭّْوذنْ.  
\m أَذْ خَاسْ ضحْشنْ، \add أَذْ إِنِينْ\add*:   
\m
\v 9 ”خْزَارْ أَرْيَازْ إِجهْذنْ  
\m ونِّي ؤُمِي وَارْ إِڭِّي أَربِّي جّهْذْ نّسْ،  
\m مَاشَا ثُوغَا إِتّْشڒْ  
\m خْ وَاڭْڒَا نّسْ أَمقّْرَانْ.  
\m ثُوغَا إِذْوڒْ إِجْهذْ  
\m س طّْبِيعثْ نّسْ إِغشّنْ.“   
\b  
\m
\v 10 نشّْ أَذْ إِڒِيغْ  
\m أَمْ يِيشْثْ ن ثْزِيثُونْثْ ثَازيْزَاوْثْ  
\m ذِي ثَادَّارْثْ ن أَربِّي.  
\m إِ ڒبْذَا قَاعْ إِ غَا تِّيقّغْ  
\m ذِي ثْمخْسِيوْثْ إِشوَّارنْ ن أَربِّي.   
\m
\v 11 نشّْ أَذْ شكْ قَاذِيغْ إِ ڒبْذَا قَاعْ،  
\m مَاغَارْ شكْ ثڭِّيذْ \add ث\add*.  
\m أَذْ سِّيثِيمغْ ذڭْ يِيسمْ نّشْ،  
\m مَاغَارْ نتَّا ذ أَصبْحَانْ  
\m إِ إِمْثِيقَّانْ نّشْ.   
\b  
\b  
\m  
\c 53
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. س ثغْنِينْثْ ن ’إِزْڒِي ن وشْضَانْ‘.\add* \add أَخمِّي ن ذَاوُوذْ.\add*   
\b  
\m
\v 2 أَبُوهَاڒِي إِنَّا ذڭْ وُوڒْ نّسْ:  
\m ”وَارْ ذِينْ بُو أَربِّي!“  
\m نِيثْنِي تَّاردّْدْجنْ،  
\m تّڭّنْ مِينْ إِدْجَانْ ذ نّْعِي ن ڒْغشّْ،  
\m وَارْ ذِينْ ؤُڒَا ذ إِجّْ إِتّڭّْ مِينْ إِشْنَانْ. \x ◘ \xo 53:‏2 \xt إِزهد. 10‏:‏4؛ إِزهد. 14؛ رُوم. 3‏:‏12 \x*   
\m
\v 3 أَربِّي إِخزَّارْ-د زڭْ ؤُجنَّا  
\m غَارْ ثَارْوَا ن بْنَاذمْ،  
\m حِيمَا أَذْ إِژَارْ مَا ذِينْ حذْ  
\m غَارسْ ڒفْهَامثْ،  
\m إِجّنْ إِ يَارزُّونْ أَربِّي. \x ◘ \xo 53:‏3 \xt رُوم. 3‏:‏11\x*   
\m
\v 4 مَارَّا فّْغنْ زڭْ وبْرِيذْ،  
\m \add أَقَا أَثنْ جْمِيعْ\add* ذوْڒنْ ذ إِعفَّاننْ،  
\m وَارْ ذِينْ ؤُڒَا ذ إِجّْ إِتّڭّْ ڒْخَارْ،  
\m ؤُڒَا ذ إِجّْ.   
\b  
\m
\v 5 إِنِّي إِتّڭّنْ ڒْمُوعْصِييّثْ  
\m مَا وَارْ غَارْسنْ ثُوسّْنَا،  
\m إِنِّي إِتّتّنْ ڒْڭنْسْ إِنُو  
\m أَخْمِي تّتّنْ أَغْرُومْ؟  
\m نِيثْنِي وَارْ تّْڒَاغَانْ خْ أَربِّي.   
\b  
\m
\v 6 أَقَا ذِينْ إِ خَاسنْ ثوْضَا  
\m ثِيڭّْوُوذِي إِمْغَارنْ،  
\m ؤُمِي وَارْ ذِينْ \add مِينْ زِي\add* إِ غَا ڭّْوذنْ،  
\m مَاغَارْ أَربِّي إِطَارّشْ إِغْسَانْ  
\m ن ونِّي خَاكْ إِهجّْمنْ.  
\m شكْ ثسّْبهْذْڒذْ إِ-ثنْ،  
\m مِينْزِي أَربِّي إِنْضَارْ إِ-ثنْ.   
\m
\v 7 أَهْ، إِڒِي أَسنْجمْ أَمقّْرَانْ ن إِسْرَائِيل  
\m أَذْ د-يَاسْ \add ذغْيَا\add* زِي صِيهْيُونْ!  
\m خْمِي د غَا إِنّقْڒبْ أَربِّي  
\m ثَامحْبَاسْثْ ن ڒْڭنْسْ نّسْ،  
\m أَذْ يَارْشقْ يَاعْقُوبْ،  
\m أَذْ إِفَارْحْ إِسْرَائِيل. \x ◘ \xo 53:‏7 \xt يُوح. 4‏:‏22؛ أَسَا. 14‏:‏1\x*   
\b  
\b  
\m  
\c 54
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. أَكْ-ذ ؤُزنْزُونْ خْ إِفِيڒَانْ. أَخمِّي ن ذَاوُوذْ.\add*   
\b  
\m
\v 2 \add ڒَْامِي د-ؤُسِينْ إِزِيفِييّنْ، نَّانْ أَسْ إِ شَاوُولْ: ”مَا وَارْ إِسّْنُوفَّارْ ذَاوُوذْ إِخفْ نّسْ غَارْنغْ؟“\add*\x ◘ \xo 54:‏2 \xt 1 صم. 23‏:‏19‏-‏28؛ 26‏:‏1\x*   
\b  
\m
\v 3 سنْجمْ أَيِي، \add أَ\add* أَربِّي، س يِيسمْ نّشْ،  
\m أَغْ أَيِي ثَاسْغَارْثْ س ثْزمَّارْ نّشْ إِجهْذنْ.   
\m
\v 4 \add أَ\add* أَربِّي، سڒْ إِ ثْژَادْجِيثْ إِنُو،  
\m سْحسّْ إِ وَاوَاڒنْ ن ؤُقمُّومْ إِنُو.   
\m
\v 5 مَاغَارْ إِبَارَّانِييّنْ كَّارنْ أَكِيذِي،  
\m أَيْثْ ن بُو-ڒخْشُونثْ أَرزُّونْ أَذْ أَيِي نْغنْ.  
\m وَارْ تّڭّنْ شَا أَربِّي  
\m زَّاثْ إِ ثِيطَّاوِينْ نْسنْ. سِيلَاهْ. \f ◼ \fr 54:‏5 \ft \+bd ’أَرزُّونْ أَذْ ذ أَيِي نْغنْ‘\+bd* - س ثْعِيبْرَانِيثْ ’أَرزُّونْ أَذْ نْغنْ ڒعْمَارْ إِنُو‘.\f*   
\b  
\m
\v 6 خْزَارْ، أَربِّي ذ أَمْعَاونْ إِنُو.  
\m سِيذِي إِنُو أَقَا-ث جَارْ يِينِّي ذ أَيِي إِسنّْذنْ.   
\m
\v 7 نتَّا أَذْ إِخدْجصْ ڒْغَارْ  
\m إِ يِينِّي ذ أَيِي إِحصَّارنْ.  
\m قْضَا خَاسنْ ذِي ڒَامَانْ نّشْ.   
\m
\v 8 س ڒْخَاضَارْ أَذْ أَشْ د-أَوْيغْ ثِيغَارْصَا،  
\m أَذْ قَاذِيغْ إِسمْ نّشْ، \add أَ\add* سِيذِي،  
\m مَاغَارْ \add نتَّا\add* ذ أَصبْحَانْ،   
\m
\v 9 مَاغَارْ نتَّا إِفكّْ أَيِي  
\m زِي مَارَّا ڒحْصَارثْ،  
\m ؤُشَا يَارَّا أَيِي-د أَذْ خزَّارغْ  
\m خْ ڒْعذْيَانْ إِنُو سْوَادَّايْ.   
\b  
\b  
\m  
\c 55
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ.\add* \add أَكْ-ذ ؤُزنْزُونْ خْ إِفِيڒَانْ.\add* \add أَخمِّي ن ذَاوُوذْ.\add*   
\b  
\m
\v 2 \add أَ\add* أَربِّي، سڒْ إِ ثْژَادْجِيثْ إِنُو،  
\m وَارْ سّْنُوفَّارَا شَا إِخفْ نّشْ  
\m زَّاثْ إِ ثُوثْرَا إِنُو.   
\m
\v 3 حْضَا أَيِي ؤُ أَرّْ-د خَافِي.  
\m نشّْ تّْرَاحغْ تَّاسغْ-د  
\m غَارْ زَّاثْ ذ ضفَّارْ،  
\m أَمْ تّْشثْشِيغْ ؤُ سّْغُونْفِيغْ،   
\m
\v 4 زِي سِّيبّثْ ن ڒْحسّْ ن ڒعْذُو،  
\m زڭْ ؤُهُوذِّي ن ؤُعفَّانْ.  
\b  
\m مَاغَارْ نِيثْنِي هجْمنْ-د خَافِي س ڒْمُوعْصِييّثْ،  
\m ضفَّارنْ أَيِي س ؤُخيّقْ.   
\m
\v 5 ؤُڒْ إِنُو إِتّْفَارْفِيرْ ذَايِي ذَاخڒْ،  
\m إِنخْڒِيعنْ ن ڒْموْثْ وْضَانْ-د خَافِي.   
\m
\v 6 ثِيڭّْوُوذِي ذ ثَارْجِيجِيثْ تّطّْفنْثْ أَيِي،  
\m ؤُڒَا ذ أَرْجفْ إِحصَّارْ أَيِي.   
\b  
\m
\v 7 نشّْ نِّيغْ:  
\m ”مْڒِي ذ أَيِي وْشِينْ أَفْرِيونْ أَمْ ثذْبِيرْثْ،  
\m \add خنِّي\add* إِڒِي ضْوِيغْ، أَذْ زذْغغْ  
\m ذِي شَا ن ومْشَانْ \add نّغْنِي\add*.“   
\m
\v 8 خْزَارْ، أَذْ أَروْڒغْ غَارْ ڒَاڭّْوَاجْ قَاعْ،  
\m أَذْ سّنْسغْ ذِي ڒخْڒَا. سِيلَاهْ.   
\m
\v 9 أَذْ ذغْيغْ غَارْ ومْشَانْ ن ؤُفكِّي،  
\m حِيمَا أَذْ تّْوَافكّغْ  
\m زڭْ ؤُسمِّيضْ، زِي ثْحَارْيَاضْثْ.   
\b  
\m
\v 10 صَارْضْ إِ-ثنْ، \add أَ\add* سِيذِي إِنُو، سبْضَا إِڒسْ نْسنْ،  
\m مِينْزِي تّْوَاڒِيغْ لْعُونْفْ ذ ؤُمنْغِي ذِي ثنْذِينْثْ.   
\m
\v 11 أَسّْ ذ دْجِيڒثْ قُووَّارنْ نِيثْنِي إِ ڒحْيُوضْ نّسْ.  
\m غَارْ ذَاخڒْ ن ثنْذِينْثْ \add أَقَا ذِينْ\add* ڒغْبنْ ذ ثَامَارَا،   
\m
\v 12 ڒْغشّْ أَقَا-ث ذَاخڒْ نّسْ،  
\m أَزَّايْ نّسْ وَارْ زَّايسْ إِتّْحيِّيذْ شَا  
\m دّدْجْ ذ وشْمَاثْ.   
\b  
\m
\v 13 مَاغَارْ وَارْ إِدْجِي ذ ڒعْذُو  
\m ونِّي ذ أَيِي إِسّحْقَارَانْ،  
\m \add مِينْزِي\add* أَيَا زمَّارغْ أَذْ ث كْسِيغْ.  
\m \add وَارْ إِدْجِي\add* ؤُڒَا ذ ونِّي ذ أَيِي إِشَارّْهنْ  
\m ذ ونِّي إِسّمْغَارَانْ إِخفْ نّسْ  
\m \add س وَاوَاڒْ\add* خَافِي،  
\m \add مِينْزِي\add* زَّايسْ زمَّارغْ أَذْ نُّوفَّارغْ!   
\m
\v 14 \add مَاشَا\add* أَقَا ذ شكْ، \add أَ\add* بْنَاذمْ،  
\m شكْ ذ أَقْرِينْ إِنُو،  
\m أَمدُّوكّڒْ إِنُو ذ جَّارْ إِنُو!   
\m
\v 15 نشِّينْ إِنِّي إِڭُّورنْ ذ لمْلِيحْ  
\m أَكْ-ذ وَايَاوْيَا ذِي تِّيقّثْ،  
\m نڭُّورْ غَارْ ثَادَّارْثْ ن أَربِّي  
\m ذڭْ ؤُهِيمُورْ.   
\b  
\m
\v 16 أَذْ خَاسنْ ثوْضَا ڒْموْثْ  
\m \add أَڒَامِي\add* إِ غَا هْوَانْ أَمْ دَّارنْ ذِي ڒَاخَارْثْ،  
\m مَاغَارْ أَقَا ذِينْ ڒْغَارْ ذِي ثْزذِّيغِينْ نْسنْ،  
\m ذڭْ وُوڒَاونْ نْسنْ. \f ◼ \fr 55:‏16 \ft \+bd ’ذڭْ وُوڒَاونْ نْسنْ‘\+bd* - س ثْعِيبْرَانِيثْ ’ذِي ذَاخڒْ نْسنْ‘.\f*   
\m
\v 17 نشّْ، \add وَاهْ،\add* نشّْ أَذْ ڒَاغِيغْ خْ أَربِّي،  
\m سِيذِي أَذْ أَيِي إِسّنْجمْ.   
\b  
\m
\v 18 غَارْ ثْمذِّيثْ، غَارْ ثُوفُّوثْ ؤُ س ؤُزِيڒْ  
\m أَذْ شثْشِيغْ، أَذْ سّْغُونْفغْ  
\m ؤُ نتَّا أَذْ إِسڒْ إِ ثْمِيجَّا إِنُو.   
\m
\v 19 نتَّا إِڭَّا أَصْڒَاحْ خْ ڒعْمَارْ إِنُو س ڒهْنَا  
\m زڭْ إِنِّي غَارِي د-إِقَارّْبنْ \add إِ وهْجَامْ\add*،  
\m مِينْزِي أَقَا-ثنْ ذڭْ وَاطَّاسْ ضِيدّْ إِنُو. \f ◼ \fr 55:‏19 \ft \+bd ’إِفْذِي‘\+bd* - خْزَارْ إِزهد. 78‏:35.\f*   
\m
\v 20 أَربِّي أَذْ إِسڒْ، أَذْ ثنْ د-إِسّهْوَا.  
\m نتَّا إِتّْغِيمَا \add خْ ڒْعَارْشْ\add*  
\m زڭْ وشْحَاڒْ ؤُيَا. سِيلَاهْ.  
\m أَقَا نِيثْنِي وَارْ تّْبذِّيڒنْ،  
\m وَارْ تّڭّْوذنْ شَا أَربِّي.   
\b  
\m
\v 21 نتَّا إِنطَّارْ أَفُوسْ ذڭْ إِنِّي  
\m أَكْ-ذ وِي \add إِڭَّا\add* ڒهْنَا،  
\m نتَّا إِسّخْسَارْ ڒْعَاهْذْ نّسْ.   
\m
\v 22 أَقمُّومْ نّسْ يَارْضبْ حْسنْ زِي ثْرُوسِّي،  
\m مَاشَا ذڭْ وُوڒْ نّسْ إِتُّورْجَا أَمنْغِي.  
\m أَوَاڒنْ نّسْ ذ إِڒقَّاغنْ خْ زّشْثْ،  
\m \add مَاشَا\add* أَقَا أَثنْ \add أَمْ\add* ڒسْيُوفْ تّْوَاجبْذنْ.   
\b  
\m
\v 23 نْضَارْ أَمْنُوسْ نّشْ خْ سِيذِي  
\m ؤُ نتَّا أَذْ ذَايكْ إِتّْهِيلَّا.  
\m عمَّارْصْ وَارْ إِتّجِّي  
\m أَمْسڭّذْ أَذْ إِفَارْغْ.   
\m
\v 24 شكْ \add مَاشَا\add*، \add أَ\add* أَربِّي،  
\m أَذْ ثنْ ثسّهْوِيذْ ذڭْ وحْفُورْ ن ثُورْصُوضِي.  
\m إِرْيَازنْ ن إِذَامّنْ ذ ڒْغشّْ  
\m وَارْ تّْكمّْڒنْ  
\m أَزْينْ ن وُوسَّانْ نْسنْ.  
\m \add مَاشَا\add* نشّْ تّشْڒغْ خَاكْ.   
\b  
\b  
\m  
\c 56
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. س ثغْنِينْثْ ن ’إِشْثْ ن ثذْبِيرْثْ إِبكّْممْ ذڭْ إِمُوشَانْ إِڭّْوجنْ‘.\add* \add ن ذَاوُوذْ. ثِيرَا إِنقْشنْ،\add* \add ڒَْامِي ث طّْفنْ إِفِيلِيسْطِينِييّنْ ذِي جَاثْ.\add* \x ◘ \xo 56:‏1 \xt 1 صم. 21‏:‏12، 13، 14\x*   
\b  
\m
\v 2 حِينّْ خَافِي، \add أَ\add* أَربِّي،  
\m مَاغَارْ إِجّْ ن بْنَاذمْ يَارزُّو  
\m أَذْ أَيِي إِسَارْضْ،  
\m إِحصَّارْ أَيِي ؤُمْجَاهذْ أَسّْ مَارَّا.   
\m
\v 3 إِنِّي ذ أَيِي إِحصَّارنْ خْسنْ  
\m أَذْ أَيِي صَارْضنْ أَسّْ مَارَّا،  
\m مَاغَارْ إِنِّي كِيذِي إِتّْمنْغَانْ س نّْفَاخثْ،  
\m أَقَا أَثنْ ذڭْ وَاطَّاسْ!   
\m
\v 4 ذڭْ وَاسّْ إِ ذِي إِ غَا ڭّْوذغْ،  
\m أَذْ خَاكْ تّشْڒغْ،   
\m
\v 5 خْ أَربِّي، ونِّي ؤُمِي غَا صبْحغْ  
\m أَوَاڒْ نّسْ،  
\m خْ أَربِّي إِ تّشْڒغْ،  
\m وَارْ تّڭّْوِيذغْ شَا،  
\m \add مَاغَارْ\add* مِينْ زمَّارنْ  
\m أَذْ أَيِي ڭّنْ مِيدّنْ؟ \f ◼ \fr 56:‏5 \ft \+bd ’مِيدّنْ‘\+bd* - س ثْعِيبْرَانِيثْ ’بَاشَارْ‘ نِيغْ ’أَيْسُومْ‘، إِخْسْ أَذْ يِينِي ’بْنَاذمْ‘ نِيغْ ’مِيدّنْ‘ (خْزَارْ إِزهد. 118‏:6).\f*   
\b  
\m
\v 6 نِيثْنِي قدْجْبنْ أَوَاڒنْ إِنُو أَسّْ إِكْمڒْ،  
\m مَارَّا ثْنَاوِي نْسنْ أَقَا أَثنْ خَافِي ذ ڒْغَارْ.   
\m
\v 7 نِيثْنِي مُوننْ، نُوفَّارنْ،  
\m نِيثْنِي حطَّانْ إِنَارْزِيونْ إِنُو،  
\m خْمِي أَرزُّونْ \add أَذْ نْغنْ\add* ڒعْمَارْ إِنُو.   
\m
\v 8 مَا زمَّارنْ أَذْ أَروْڒنْ  
\m وَاخَّا ڭِّينْ ڒْغشّْ؟  
\m سهْوَا ڒڭْنُوسْ  
\m ذڭْ وغْضَابْ نّشْ، \add أَ\add* أَربِّي!   
\b  
\m
\v 9 شكْ ثْحسّْبذْ \add ؤُسَّانْ ن\add* وطْلَاعْ إِنُو.  
\m أڭّْ إِمطَّاونْ إِنُو ذِي ثْزيَّاثْ ن وَامَانْ نّشْ،  
\m - مَا وَارْ دْجِينْ ذڭْ وذْلِيسْ نّشْ؟ -   
\m
\v 10 خنِّي أَذْ ذوْڒنْ ڒْعذْيَانْ إِنُو غَارْ ضفَّارْ،  
\m ذڭْ وَاسّْ ؤُمِي غَا ڒَاغِيغْ.  
\m نشّْ سّْنغْ أَيَا: أَربِّي أَقَا-ث أَكِيذِي.   
\m
\v 11 خْ أَربِّي، ونِّي ؤُمِي  
\m غَا سّمْغَارغْ أَوَاڒْ نّسْ،  
\m خْ سِيذِي، ونِّي ؤُمِي  
\m غَا سّمْغَارغْ أَوَاڒْ نّسْ،   
\m
\v 12 خْ أَربِّي إِ خفْ تّشْڒغْ،  
\m وَارْ تّڭّْوِيذغْ شَا،  
\m \add مَاغَارْ\add* مِينْ إِزمَّارْ بْنَاذمْ  
\m أَذْ أَيِي يڭّْ؟ \x ◘ \xo 56:‏12 \xt إِزهد. 118‏:‏6\x*   
\b  
\m
\v 13 خَافِي، \add أَ\add* أَربِّي،  
\m أَرْسِينْ لْوُوعُوذْ إِ شكْ \add إِتّْوَاڭّنْ\add*.  
\m أَذْ \add ثنْ\add* كمّْڒغْ إِ شكْ س ؤُقَاذِي.   
\m
\v 14 مَاغَارْ شكْ ثْفكّذْ ڒعْمَارْ إِنُو  
\m زِي ڒْموْثْ!  
\m مَا \add وَارْ ثحْضِيذْ\add* إِضَارنْ إِنُو  
\m زڭْ ؤُنقْرَاضْ،  
\m حِيمَا أَذْ ؤُيُورغْ  
\m زَّاثْ إِ وُوذمْ ن أَربِّي  
\m ذِي ثْفَاوْثْ ن ثُوذَارْثْ؟   
\b  
\b  
\m  
\c 57
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. ’وَارْ ث تَّاردّدْجْ!‘ ن ذَاوُوذْ.\add* \add ثِيرَا إِنقْشنْ. ؤُمِي يَارْوڒْ زِي شَاوُولْ ذڭْ إِفْرِي.\add*\x ◘ \xo 57:‏1 \xt 1 صم. 22‏:‏1؛ 24‏:‏4\x*   
\b  
\m
\v 2 حِينّْ خَافِي، \add أَ\add* أَربِّي، حِينّْ خَافِي،  
\m مَاغَارْ ڒعْمَارْ إِنُو يَاركّْوَاڒْ-د غَاركْ.  
\m نشّْ ؤُفِيغْ أَذُورِّي  
\m ذِي ثِيڒِي ن وَافْرِيونْ نّشْ،  
\m أَڒْ غَا عْذُونْثْ ڒْمُوصِيبَاثْ.   
\b  
\m
\v 3 نشّْ أَذْ ڒَاغِيغْ غَارْ أَربِّي،  
\m أَمْعُودْجِي خْ كُوڒْشِي،  
\m غَارْ أَربِّي ونِّي ذ أَيِي غَا إِنذْهنْ  
\m غَارْ ؤُنڭَّارْ \add إِصبْحنْ\add*.   
\m
\v 4 نتَّا أَذْ د-إِسّكّْ أَسنْجمْ إِنُو  
\m زڭْ ؤُجنَّا،  
\m أَذْ إِسّْبهْذڒْ ونِّي إِخْسنْ  
\m أَذْ أَيِي إِسَارْضْ. سِيلَاهْ.  
\m أَربِّي أَذْ إِسّكّْ  
\m ثَامخْسِيوْثْ نّسْ إِشوَّارنْ  
\m ذ ڒَامَانْ نّسْ.   
\b  
\m
\v 5 ڒعْمَارْ إِنُو أَقَا-ث جَارْ إِيْرَاذنْ،  
\m زّْڒغْ جَارْ إِصفْضَاونْ يَارقّنْ،  
\m ثَارْوَا ن بْنَاذمْ، إِنِّي ثِيغْمَاسْ نْسنْ  
\m \add أَمْ\add* لَانْسَاثْ ذ فْڒِيثْشَاثْ \add ن ڒْقوْسْ\add*،  
\m إِڒسْ نْسنْ أَمْ يِيجّْ ن سِّيفْ إِقْضعْ.   
\m
\v 6 \add أَ\add* أَربِّي، سْڭعّذْ إِخفْ نّشْ  
\m ثِيوَا إِ إِجنْوَانْ،  
\m \add أَرّْ\add* أَعُودْجِي نّشْ  
\m سنّجْ إِ مَارَّا ثَامُّورْثْ. \x ◘ \xo 57:‏6 \xt إِزهد. 108‏:‏6\x*   
\b  
\m
\v 7 نِيثْنِي ڭِّينْ ثْرَاشَّا إِ إِصُورَافْ إِنُو،  
\m ڒعْمَارْ إِنُو ثُوغَا إِغْنسْ.  
\m نِيثْنِي غْزِينْ أَيِي أَحْفُورْ،  
\m \add مَاشَا\add* وْضَانْ ذَايسْ سِيمَانْثْ نْسنْ.  
\m سِيلَاهْ. \x ◘ \xo 57:‏7 \xt إِزهد. 7‏:‏16؛ 9‏:‏16\x*   
\b  
\m
\v 8 \add أَ\add* أَربِّي، ؤُڒْ إِنُو يَاركّنْ،  
\m ؤُڒْ إِنُو يَاركّنْ.  
\m أَقَا نشّْ أَذْغنّْجغْ أَذْ زهّْذغْ. \x ◘ \xo 57:‏8 \xt إِزهد. 108‏:‏2‏-‏6\x*   
\m
\v 9 فَاقْ، أَعُودْجِي إِنُو! فَاقْ،  
\m لْهَارْبَا ذ ڒْڭَامْبْرِي!  
\m نشّْ تّخْسغْ أَذْ سّْفَاقغْ  
\m ثَافَاوْثْ ن ڒفْجَارْ.   
\b  
\m
\v 10 نشّْ أَذْ شكْ قَاذِيغْ جَارْ ڒڭْنُوسْ،  
\m \add أَ\add* سِيذِي إِنُو،  
\m أَذْ زهّْذغْ جَارْ شُّوعُوبْ إِ شكْ. \x ◘ \xo 57:‏10 \xt إِزهد. 108‏:‏4\x*   
\m
\v 11 مَاغَارْ ثَامخْسِيوْثْ نّشْ إِشوَّارنْ  
\m \add ثتَّاكّْوَاضْ\add* أَڒْ إِجنْوَانْ،  
\m ڒَْامَانْ نّشْ أَڒْ إِسيْنُوثنْ. \x ◘ \xo 57:‏11 \xt إِزهد. 36‏:‏6؛ 108‏:‏5\x*   
\m
\v 12 \add أَ\add* أَربِّي، سْڭعّذْ إِخفْ نّشْ  
\m ثِيوَا إِ إِجنْوَانْ،  
\m \add أَرّْ\add* أَعُودْجِي نّشْ  
\m سنّجْ إِ مَارَّا ثَامُّورْثْ.   
\b  
\b  
\m  
\c 58
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. ’وَارْ ث تَّاردّدْجْ!‘\add* \add ن ذَاوُوذْ. ثِيرَا إِنقْشنْ.\add*   
\m
\v 2 مَا ثسَّاوَاڒمْ س ثِيذتّْ  
\m ثَاسڭْذَا ذڭْ ؤُسغْذِي؟  
\m مَا ثْحكّْممْ ثَارْوَا ن بْنَاذمْ  
\m س ڒْحقّْ؟   
\m
\v 3 لَّ، \add مَاشَا\add* ذڭْ وُوڒْ \add نْومْ\add*  
\m ثتّڭّمْ ڒْغشّْ،  
\m خْ ثمُّورْثْ ثْوزّْنمْ  
\m لْعُونْفْ ن إِفَاسّنْ نْومْ.   
\b  
\m
\v 4 زڭْ \add وَامِي دْجَانْ ذِي\add* ڒمْڒَاوثْ  
\m فّْغنْ إِعفَّاننْ زڭْ وبْرِيذْ،  
\m زڭْ ؤُعذِّيسْ ن يمَّاثْسنْ  
\m ودَّارنْ أَيْثْ ن بُو-إِخَارِّيقنْ.   
\m
\v 5 أَقَا ذَايْسنْ سّمْ أَمْ سمّْ ن ؤُفِيغَارْ.  
\m نِيثْنِي أَمْ يِيشْثْ ن ثْڒفْسَا ثَاذهْشُورْثْ،  
\m ثنِّي إِقّْننْ أَمزُّوغْ نّسْ، \x ◘ \xo 58:‏5 \xt إِزهد. 140‏:‏4\x*   
\m
\v 6 ثنِّي وَارْ إِتّسْڒِينْ  
\m غَارْ ثْمِيجَّا ن إِعزَّامنْ،  
\m \add ؤُڒَا غَارْ ثْمِيجَّا\add* ن ؤُسحَّارْ  
\m نِّي إِتّْحَاكَانْ أَطَّاسْ ذِي ثْسحَّارْثْ.   
\b  
\m
\v 7 \add أَ\add* أَربِّي، أَرْژْ أَسنْ ثِيغْمَاسْ  
\m ذڭْ ؤُقمُّومْ نْسنْ،  
\m أَرْژْ ثِيغْمَاسْ ن ثغْمَارْثْ  
\m ن إِيْرَاذنْ إِمژْيَاننْ، \add أَ\add* سِيذِي!   
\m
\v 8 أجّْ إِ-ثنْ أَذْ فسْينْ أَمْ وَامَانْ،  
\m أَڒَامِي أَذْ فّْغنْ.  
\m مَاڒَا إِمحّضْ \add ڒْْقوْسْ\add* س فْڒِيثْشَاثْ نّسْ،  
\m أجّْ إِ-ثنْ وَارْ قْضِيعنْ.   
\m
\v 9 أجّْ إِ-ث أَذْ إِفْنَا أَمْ ؤُبُوشّڒْ إِرِيزّنْ.  
\m أجّْ إِ-ثنْ وَارْ ژَترّنْ ثْفُوشْثْ،  
\m أَمْ وطُّو ن ؤُعذِّيسْ ن ثْمطُّوثْ. \f ◼ \fr 58:‏9 \ft \+bd ’عَارْيَانْ‘\+bd* - إِخْسْ أَذْ يِينِي ’نْبْڒَا ثَادَّارْثْ خْ وعْرُورْ نّسْ‘.\f*   
\m
\v 10 قْبڒْ  إِ غَا أَشَانْثْ مَارْمِيثَاثْ نْومْ  
\m أَكْ-ذ \add ڒحْمُو ن\add* شْبَارْقْ أَكْ-ذ إِسنَّاننْ،  
\m أَذْ ذَايسْ إِسُوضْ أَڒَامِي أَذْ يَاژّڒْ  
\m خْ \add ويْسُومْ\add* ذ أَزِيزَا  
\m نِيغْ \add خْ ويْسُومْ\add* إِتّحْذُوذُوقنْ.   
\b  
\m
\v 11 أَمْسڭّذْ أَذْ إِفَارْحْ  
\m خْمِي غَا إِژَارْ أَنْثَاقمْ.  
\m نتَّا أَذْ إِسِّيرْذْ إِضَارنْ نّسْ  
\m ذڭْ إِذَامّنْ ن إِعفَّاننْ.   
\m
\v 12 أَذْ يِينِي بْنَاذمْ:  
\m ”وَاهْ، أَقَا ذِينْ ڒْغِيدْجثْ إِ ؤُمْسڭّذْ،  
\m أَقَا ذِينْ إِجّْ ن أَربِّي  
\m نِّي إِحكّْمنْ ذِي ثمُّورْثْ.“   
\b  
\b  
\m  
\c 59
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. ’وَارْ ث تَّاردّدْجْ!‘\add* \add ن ذَاوُوذْ. ثِيرَا إِنقْشنْ.\add* \add ؤُمِي شَاوُولْ إِجَّا أَذْ حْضَانْ ثَادَّارْثْ ن ذَاوُوذْ حِيمَا أَذْ ث نْغنْ.\add*\x ◘ \xo 59:‏1 \xt 1 صم. 19‏:‏12\x*   
\b  
\m
\v 2 فكّْ أَيِي زِي ڒْعذْيَانْ إِنُو، \add أَ\add* أَربِّي،  
\m سْڭعّذْ أَيِي سنّجْ غَارْ ؤُحطُّو  
\m زڭْ إِنِّي خَافِي إِتّكَّارنْ.   
\m
\v 3 فكّْ أَيِي زڭْ إِنِّي إِتّڭّنْ ڒْغشّْ،  
\m سنْجمْ أَيِي زڭْ إِرْيَازنْ ن إِذَامّنْ.   
\m
\v 4 أَقَا، خْزَارْ، نِيثْنِي ڭِّينْ  
\m إِجّْ ن ڒْفخْ إِ ڒعْمَارْ إِنُو،  
\m أَيْثْ ن بُو-صُّولْطَا مُوننْ خَافِي.  
\m وَارْ ذِينْ أَخطُّو  
\m ؤُڒَا ذ دّنْبْ غَارِي، \add أَ\add* سِيذِي!   
\m
\v 5 \add وَاخَّا\add* وَارْ ڭِّيغْ لْجَارِيمَا،  
\m أَقَا نِيثْنِي \add زعْمَا\add* ؤُسِينْ-د  
\m تَّازّْڒنْ-د غَارِي  
\m ؤُ سّْوجَّاذنْ إِخفْ نْسنْ.  
\m فَاقْ، أَسْ-د غَارْ ؤُمْسَاڭَارْ أَكِيذِي ؤُ خْزَارْ.   
\m
\v 6 شكْ، \add أَ\add* سِيذِي، أَربِّي ن ڒْعسْكَارَاثْ،  
\m أَربِّي ن إِسْرَائِيل،  
\m فَاقْ حِيمَا أَذْ ثْڒقْفذْ مَارَّا ڒڭْنُوسْ.  
\m وَارْ تّْحِينِّي خْ ؤُڒَا ذ إِجّْ  
\m زِي مَارَّا إِغدَّارنْ  
\m إِنِّي إِتّڭّنْ ڒْغشّْ. سِيلَاهْ.   
\b  
\m
\v 7 أَقَا تّْعقْبنْ غَارْ ثْمذِّيثْ،  
\m تّْزُونْ أَمْ وقْزِينْ،  
\m تّنّْضنْ إِ ثنْذِينْثْ. \x ◘ \xo 59:‏7 \xt إِزهد. 59‏:‏15\x*   
\m
\v 8 خْزَارْ، س ؤُقمُّومْ نْسنْ سُّوسُوفنْ \add قَاعْ\add*،  
\m ڒسْيُوفْ نْسنْ أَقَا أَثنْ  
\m خْ إِينْشِيشنْ نْسنْ،  
\m مِينْزِي مَانْ ونْ إِ غَا إِسْڒنْ؟ \x ◘ \xo 59:‏8 \xt إِزهد. 10‏:‏11؛ 55‏:‏22؛ 57‏:‏5؛ 94‏:‏7 \x*   
\m
\v 9 شكْ \add مَاشَا\add*، \add أَ\add* سِيذِي، أَذْ خَاسنْ ثْضحْشذْ،  
\m شكْ أَذْ ثْحشّذْ خْ مَارَّا ڒڭْنُوسْ. \x ◘ \xo 59:‏9 \xt إِزهد. 2‏:‏4\x*   
\m
\v 10 \add أَ\add* جّهْذْ نّسْ، نشّْ أَذْ ث رَاجِيغْ،  
\m مَاغَارْ أَربِّي ذ لْبُورْجْ إِنُو يُوعْڒَانْ.   
\b  
\m
\v 11 ثَامخْسِيوْثْ إِشوَّارنْ ن أَربِّي إِنُو  
\m أَذْ أَيِي ثِيزْوَارْ،  
\m أَربِّي أَذْ أَيِي يَارّْ  
\m أَذْ ژَترغْ إِنِّي ذ أَيِي إِحصَّارنْ.   
\m
\v 12 وَارْ ثنْ نقّْ شَا،  
\m مَاحنْذْ ڒْڭنْسْ إِنُو وَارْ ث إِتّتُّو.  
\m أجّْ إِ-ثنْ أَذْ ودَّارنْ س جّهْذْ نّشْ،  
\m منْضَارْ إِ-ثنْ سْوَادَّايْ،  
\m \add مَاغَارْ شكْ ذ\add* ثَاسدَّارْثْ نّغْ إِ ؤُسڒْقِي،  
\m \add أَ\add* سِيذِي إِنُو.   
\m
\v 13 \add خْ\add* دّْنُوبْ ن ؤُقمُّومْ نْسنْ،  
\m \add خْ\add* وَاوَاڒنْ إِ د-إِتّفّْغنْ  
\m زڭْ إِينْشِيشنْ نْسنْ،  
\m \add خْ ؤُيَا\add* أجّْ إِ-ثنْ أَذْ تّْوَاحبّْسنْ  
\m ذِي نّْفَاخثْ نْسنْ،  
\m ؤُڒَا خْ نّعْڒثْ ؤُ خْ ؤُخَارِّيقْ  
\m نِّي خفْ تّْحَارْذنْ.   
\m
\v 14 كحّضْ إِ-ثنْ ذڭْ وسْعَارْ \add نّشْ\add*،  
\m كحّضْ إِ-ثنْ أَڒَامِي وَارْ دْجِينْ \add عَاذْ\add*،  
\m أَرّْ إِ-ثنْ أَذْ سّْننْ،  
\m أَقَا أَربِّي ذ ڒْحَاكمْ ذِي يَاعْقُوبْ،  
\m أَڒْ ثِينڭُّورَا ن ثمُّورْثْ. سِيلَاهْ.   
\b  
\m
\v 15 أَقَا أَذْعقْبنْ غَارْ ثْمذِّيثْ،  
\m تّْزُونْ أَمْ وقْزِينْ  
\m ؤُ تّنّْضنْ إِ ثنْذِينْثْ. \x ◘ \xo 59:‏15 \xt إِزهد. 59‏:‏7\x*   
\m
\v 16 أجّْ إِ-ثنْ تّمْهَافَانْ ذَا ذ ذِيهَا خْ مَاشَّا،  
\m أجّْ إِ-ثنْ \add خنِّي\add* أَذْ قِّيمنْ سّْنُوسَانْ،  
\m مَاڒَا وَارْ جِّيوْننْ،   
\m
\v 17 نشّْ أَذْغنّْجغْ خْ جّْهذْ نّشْ،  
\m غَارْ ثفُّوثْ أَذْ سْڒِيوْڒوغْ  
\m خْ ثْمخْسِيوْثْ نّشْ إِشوَّارنْ،  
\m مَاغَارْ ثُوغَا شكْ  
\m ذ إِجّْ ن لْبُورْجْ يُوعْڒَانْ إِ نشّْ،  
\m ذ أَمْشَانْ ن ثَاروْڒَا  
\m ذڭْ وَاسّْ ن ڒحْصَارثْ إِنُو.   
\m
\v 18 جّهْذْ إِنُو، نشّْ أَذْ زهّْذغْ إِ شكْ،  
\m مَاغَارْ شكْ أَربِّي ذ لْبُورْجْ إِنُو يُوعْڒَانْ،  
\m أَربِّي ن ثْمخْسِيوْثْ إِنُو إِشوَّارنْ.   
\b  
\b  
\m  
\c 60
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. س ثغْنِينْثْ ن ’ثَالِيلّشْثْ ذ أَشهَّاذْ‘.\add* \add ثِيرَا إِنقْشنْ ن ذَاوُوذْ إِ ؤُسڒْمذْ.\add* \f ◼ \fr 60:‏1 \ft \+bd ’ثَالِيلّشْثْ‘\+bd* - إِشْثْ ن مَارْكَا ن إِنُّووَّارنْ ذَايْسنْ أَژْرِي أَطَّاسْ.\f*   
\m
\v 2 \add خْ ڒَامِي ثُوغَا إِتّْمنْغَا أَكْ-ذ إِمزْذَاغْ ن أَرَامْ-نَاهْرَايْنْ، أَقَا-ت ذ مِيسُوپُوثَامْيَا،\add* \add ؤُ أَكْ-ذ أَيْثْ ن أَرَامْ زِي صُوبَا، ؤُمِي د-إِذْوڒْ يُووَابْ،\add* \add إِوْثَا أَيْثْ ن إِذُومْ ذِي ثغْزُورْثْ ن ثْمدْجَاحْثْ،عشْرَا أَڒَافْ ن يرْيَازنْ.\add*\x ◘ \xo 60:‏2 \xt 2 صم. 8‏:‏3، 13؛ 1 إِم. 18‏:‏3، 12\x*   
\b  
\m
\v 3 \add أَ\add* أَربِّي، شكْ ثنْضَارضْ أَنغْ،  
\m ثَارْژِيذْ أَنغْ.  
\m ثُوغَا ثسْعَارذْ \add أَطَّاسْ\add*!  
\m سْبدّْ أَنغْ عَاوذْ! \x ◘ \xo 60:‏3 \xt إِزهد. 144‏:‏10\x*   
\m
\v 4 شكْ ثسّنْهزّذْ ثَامُّورْثْ،  
\m ثْفدْجْقذْ ت.  
\m سْڭنْفَا ثِيرژَّا نّسْ،  
\m مَاغَارْ أَقَا ثتّنْهزَّا.   
\m
\v 5 شكْ ثسّشْنذْ \add إِخفْ نّشْ\add*  
\m إِ ڒْڭنْسْ نّشْ س ڒقْسَاحثْ.  
\m شكْ ثوْشِيذْ أَنغْ  
\m أَذْ نْسُو شّْرَابْ إِسّْذوَّاخنْ. \x ◘ \xo 60:‏5 \xt إِشا. 51‏:‏17‏-‏23\x*   
\m
\v 6 إِنِّي شكْ إِتّڭّْوذنْ،  
\m ثڭِّيذْ أَسنْ ثَاعدْجَانْثْ  
\m إِ غَارْ تّْرَاكّْوَاڒنْ  
\m زِي \add فْڒِيثْشَاثْ ن\add* ڒْقوْسْ. سِيلَاهْ.   
\m
\v 7 حِيمَا إِمْعِيزّنْ نّشْ أَذْ تّْوَافكّنْ،  
\m أَوِي أَسنْجمْ س ؤُفُوسْ أَفُوسِي نّشْ  
\m ؤُ أَرّْ-د خَانغْ. \x ◘ \xo 60:‏7 \xt إِزهد. 108‏:‏7‏-‏14\x*   
\b  
\m
\v 8 أَربِّي ثُوغَا إِسَّاوَاڒْ  
\m ذِي زَّاوشْثْ نّسْ إِقدّْسنْ،  
\m س ؤُينِّي أَذْ نڭْزغْ س ڒفْرَاحثْ.  
\m نشّْ أَذْ بْضِيغْ شَاكِيمْ،  
\m أَذْعبَّارغْ ثَاغْزُورْثْ ن سُوكُّوثْ.   
\m
\v 9 جِيلْعَاذْ إِنُو، مَانَاسَّا إِنُو،  
\m إِفْرَايِيمْ ذ أَسڒْقِي إِجهْذنْ ن ؤُزدْجِيفْ إِنُو،  
\m يَاهُوذَا ذ أَمْڭوّذْ إِنُو.   
\m
\v 10 مُوآبَ ذ سَّارِيجْ إِنُو إِ ؤُسِيرْذْ،  
\m خْ إِذُومْ أَذْ نْضَارغْ سَانْذَالِييَاثْ إِنُو،  
\m نشّْ أَذْ دُّوقْزغْ س ؤُسْڒِيوْڒوْ  
\m خْ \add ثمُّورْثْ ن\add* فِيلِيشِيثْ.   
\b  
\m
\v 11 وِي ذ أَيِي إِ غَا إِنذْهنْ  
\m \add ذِي\add* ثنْذِينْثْ إِفَارْينْ؟  
\m وِي ذ أَيِي غَا إِڭوّْذنْ غَارْ إِذُومْ؟   
\m
\v 12 مَا وَارْ ذ أَنغْ ثنْضَارذْ، \add أَ،\add* أَربِّي،  
\m ؤُ أَكْ-ذ ڒْعسْكَارَاثْ نّغْ  
\m مَا وَارْ أَكِيذْسنْ د-ثفِّيغذْ \add عَاذْ\add*،  
\m \add أَ\add* أَربِّي؟   
\m
\v 13 أوْشْ أَنغْ أَفُوسْ  
\m \add حِيمَا أَذْ أَنغْ ثسّْنجْمذْ\add* زِي ڒحْصَارثْ،  
\m \add مَاغَارْ\add* أَسنْجمْ \add س ؤُفُوسْ ن\add* يِيجّْ ن بْنَاذمْ  
\m أَقَا-ث بَاطڒْ.   
\m
\v 14 أَكْ-ذ أَربِّي أَذْ نڭّْ س ومْحَاذْ،  
\m نتَّا أَذْ إِعْفسْ خْ يِينِّي ذ أَنغْ إِحصَّارنْ.   
\b  
\b  
\m  
\c 61
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. أَكْ-ذ ؤُزنْزُونْ خْ إِفِيڒَانْ. ن ذَاوُوذْ.\add*   
\b  
\m
\v 2 \add أَ\add* أَربِّي، سڒْ إِ ؤُڒَاغِي إِنُو،  
\m سڒْ مْلِيحْ إِ ثْژَادْجِيثْ إِنُو.   
\m
\v 3 زِي طَّارْفْ أَنڭَّارْ ن ثمُّورْثْ  
\m تّْڒَاغِيغْ خَاكْ،  
\m خْمِي إِتّفْشِيڒْ وُوڒْ إِنُو.  
\m نْذهْ أَيِي خْ إِجّْ ن جَّارْفْ يُوعْڒَانْ خَافِي.   
\m
\v 4 مَاغَارْ شكْ ذ أَمْشَانْ ن ثَاروْڒَا إِ نشّْ،  
\m ذ لْبُورْجْ إِجهْذنْ ضِيدّْ إِ ڒعْذُو.   
\m
\v 5 نشّْ أَذْ قِّيمغْ  
\m ذڭْ ؤُقِيضُونْ نّشْ إِ ڒبْذَا،  
\m أَذْ أَروْڒغْ  
\m سَاذُو ؤُذُورِّي ن وَافْرِيونْ نّشْ. سِيلَاهْ.   
\b  
\m
\v 6 مَاغَارْ شكْ، \add أَ\add* أَربِّي،  
\m ثسْڒِيذْ غَارْ لْوُوعُوذْ إِنُو.  
\m شكْ ثوْشِيذْ \add أَيِي\add* ثَاسْغَارْثْ  
\m ن يِينِّي إِتّڭّْوذنْ إِسمْ نّشْ.   
\m
\v 7 أَرْنِي \add عَاذْ\add* ؤُسَّانْ خْ وُوسَّانْ ن ؤُجدْجِيذْ،  
\m أجّْ أَذْ أَرذْفنْ إِسڭّْوُوسَا نّسْ  
\m إِجّْ إِ ونّغْنِي  
\m أَمْ جِّيڒْ إِضْفَارْ ؤُمَاسْ.   
\m
\v 8 نتَّا أَذْ إِقِّيمْ  
\m زَّاثْ إِ وُوذمْ ن أَربِّي إِ ڒبْذَا.  
\m أَذْ خَاسْ ثحْضَا  
\m ثَامخْسِيوْثْ إِشوَّارنْ ذ ڒَامَانْ.   
\m
\v 9 خنِّي أَذْ زهّْذغْ إِ يِيسمْ نّشْ إِ ڒبْذَا،  
\m حِيمَا أَذْ كمّْڒغْ لْوُوعُوذْ إِنُو،  
\m أَسّْ \add أَوَارْنِي\add* ؤُمَاسْ.   
\b  
\b  
\m  
\c 62
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. سَاذُو ؤُفُوسْ ن يَاذُوثُونْ. ن ذَاوُوذْ.\add*   
\b  
\m
\v 2 وَاهْ، ڒعْمَارْ إِنُو يَارسَّا،  
\m إِتّْرَاجَا أَربِّي وَاهَا،  
\m أَقَا زَّايسْ \add د-إِتَّاسْ\add* ؤُسنْجمْ إِنُو.   
\m
\v 3 وَاهْ، نتَّا ذ ثَاصْضَارْثْ إِنُو ذ ؤُسنْجمْ إِنُو،  
\m لْبُورْجْ إِنُو يُوعْڒَانْ، وَارْ تّفْرِيغغْ أَطَّاسْ.   
\m
\v 4 مشْحَاڒْ \add عَاذْ\add* إِ غَا ثكّمْ  
\m ثْهجّْممْ خْ ورْيَازْ؟  
\m \add مشْحَاڒْ عَاذْ\add* أَقَا ثْڒهَّامْ  
\m مَاحنْذْ أَذْ ث ثغْضْڒمْ،  
\m أَمْ إِجّْ ن ڒْحِيضْ إِوطَّا،  
\m أَمْ يِيجّْ ن وغْبَارْ إِتّْوَاغْضڒْ؟   
\b  
\m
\v 5 وَاهْ، نِيثْنِي تّمْشَاوَارنْ وَاهَا  
\m حِيمَا أَذْ ث-إِ-د -غضْڒنْ  
\m زڭْ ومْشَانْ نّسْ يُوعْڒَانْ.  
\m نِيثْنِي أَرطَّانْ س إِخَارِّيقنْ.  
\m تّْبَارْكنْ س ؤُقمُّومْ نْسنْ،  
\m \add مَاشَا\add* ذڭْ وُوڒْ نْسنْ نعّْڒنْ. سِيلَاهْ. \f ◼ \fr 62:‏5 \ft \+bd ’ذڭْ وُوڒْ‘\+bd* - ذِي ثْعِيبْرَانِيثْ ’ذِي ذْوَاخڒْ نْسنْ‘.\f*   
\b  
\m
\v 6 وَاهْ، رَاجَا إِ أَربِّي، \add أَ\add* ڒعْمَارْ إِنُو،  
\m مِينْزِي زَّايسْ ڒَايَاسْ إِنُو.   
\m
\v 7 وَاهْ، نتَّا ذ ثَاصْضَارْثْ إِنُو ذ ؤُسنْجمْ إِنُو،  
\m لْبُورْجْ إِنُو يُوعْڒَانْ، وَارْ تّفْرِيغغْ شَا.   
\m
\v 8 أَسنْجمْ إِنُو ذ ؤُعُودْجِي إِنُو  
\m أَقَا أَثنْ ذِي أَربِّي،  
\m \add نتَّا ذ\add* ثَاصْضَارْثْ إِنُو إِجهْذنْ،  
\m أَمْشَانْ إِنُو ن ثَاروْڒَا  
\m أَقَا-ث ذِي أَربِّي.   
\b  
\m
\v 9 ثِيقّمْ ڒبْذَا ذَايسْ، \add أَ\add* ڒْڭنْسْ!  
\m زدْجْعمْ ؤُڒْ نْومْ زَّاثْ إِ وُوذمْ نّسْ.  
\m أَربِّي ذ أَمْشَانْ نّغْ ن ثَاروْڒَا. سِيلَاهْ.   
\b  
\m
\v 10 وَاهْ، ثَارْوَا ن أَذَامْ  
\m أَقَا أَثنْ ذ ڒعْوِينْ،  
\m ثَارْوَا ن ورْيَازْ أَقَا ذَايْسنْ أَخَارِّيقْ.  
\m أَذْ ڭعّْذنْ ذِي ڒْمِيزَانْ  
\m س ثْنَاينْ ن طَّاوْيَاثْ،  
\m أَقَا أَثنْ جْمِيعْ \add فْسُوسنْ\add* خْ ڒعْوِينْ.   
\m
\v 11 وَارْ تّشْڒمْ خْ دّدْجْ،  
\m وَارْ تّجِّيمْ أَذْ كنِّيوْ جبّْذنْ  
\m \add زڭْ وبْرِيذْ\add* س ؤُكَّارْضَا.  
\m مَاڒَا أَڭْڒَا إِمقَّارْ،  
\m وَارْ خَاسْ سّْرُوسَامْ ؤُڒْ نْومْ.   
\m
\v 12 أَربِّي إِسِّيوڒْ  إِشْثْ ن ثْوَاڒَا،  
\m سْڒِيغْ ثْنَاينْ ن ثْوَاڒَاوِينْ،  
\m أَقَا: ”جّهْذْ زِي أَربِّي“.   
\m
\v 13 ثَامخْسِيوْثْ إِشوَّارنْ إِ شكْ، \add أَ\add* سِيذِي إِنُو!  
\m مِينْزِي شكْ أَذْ ثْخدْجْصذْ  
\m كُوڒْ إِجّْ عْلَاحْسَابْ مِينْ إِڭَّا. \x ◘ \xo 62:‏13 \xt أَيُوبْ 34‏:‏11؛ أَوڒن. 24‏:‏12؛ إِرْم. 32‏:‏19؛ حِز. 7‏:‏27؛ 33‏:‏20؛ مت. 16‏:‏27؛ رُوم. 2‏:‏6؛ 2 كُور. 5‏:‏10؛ أَفا. 6‏:‏8؛ كُول. 3‏:‏25؛ 1 بُط. 1‏:‏17؛ أَسَا. 22‏:‏12\x*   
\b  
\b  
\m  
\c 63
\m
\v 1 \add أَزهّذْ ن ذَاوُوذْ، أَڒَامِي ث ثُوغَا ذِي ڒخْڒَا ن يَاهُوذَا.\add*\x ◘ \xo 63:‏1 \xt 1 صم. 22‏:‏5؛ 23‏:‏14، 15\x*   
\b  
\m
\v 2 \add أَ\add* أَربِّي، شكْ ذ أَربِّي إِنُو!  
\m غَارْ ثُوفُّوثْ أَرزُّوغْ خَاكْ،  
\m ڒعْمَارْ إِنُو إِتّْفَاذَا غَاركْ،  
\m أَيْسُومْ إِنُو إِتّْمژْرِي ذَايكْ،  
\m ذڭْ إِشْثْ ن ثمُّورْثْ يُوژْغنْ  
\m إِتّْفَاذَانْ بْڒَا أَمَانْ. \f ◼ \fr 63:‏2 \ft \+bd ’أَيْسُومْ إِنُو‘\+bd* - أَيَا إِخْسْ أَذْ يِينِي ’أَرِّيمثْ إِنُو‘.\f*   
\m
\v 3 أَمُّو إِ ذَايكْ خزَّارغْ  
\m ذِي زَّاوشْثْ إِقدّْسنْ،  
\m حِيمَا أَذْ ژَترغْ جّهْذْ نّشْ ذ ؤُعُودْجِي نّشْ.   
\m
\v 4 مَاغَارْ ثَامخْسِيوْثْ نّشْ إِشوَّارنْ  
\m ثحْڒَا خْ ثُوذَارْثْ،  
\m س ؤُينِّي أَذْ شكْ صبّْحنْ  
\m إِينْشِيشنْ إِنُو.   
\b  
\m
\v 5 أَمُّو إِ ذ أَشْ غَا بَارْكغْ ذِي ثُوذَارْثْ إِنُو،  
\m أَذْ سّْڭعّْذغْ إِفَاسّنْ إِنُو ذڭْ يِيسمْ نّشْ.   
\m
\v 6 ڒعْمَارْ إِنُو أَذْ إِجِّيونْ  
\m أَمْ زِي ثَاذُونْثْ ذ مِينْ إِمسْڒنْ،  
\m س إِينْشِيشنْ إِسْڒِيوْڒونْ  
\m أَذْ \add شكْ\add* إِصبّحْ ؤُقمُّومْ إِنُو،   
\m
\v 7 مَاڒَا تّْخَارّْصغْ ذَايكْ ذِي ثَاسُّوثْ،  
\m تّْخمَّامغْ ذَايكْ  
\m غَارْ ؤُضُوفنْ ن وشْبَارْ ن دْجِيڒثْ.   
\m
\v 8 مِينْزِي ثُوغَا شكْ ذ أَمْعَاونْ إِنُو،  
\m ذِي ثِيڒِي ن وَافْرِيونْ نّشْ أَذْ سْڒِيوْڒوغْ.   
\m
\v 9 ڒعْمَاڒْ إِنُو إِڒصّقْ ذَايكْ أَوَارْنِي أَشْ،  
\m أَفُوسْ نّشْ أَفُوسِي إِتّطّفْ ذَايِي.   
\b  
\m
\v 10 إِنِّي إِتّخْسنْ أَذْ أَردّْدْجنْ ڒعْمَارْ إِنُو،  
\m أَذْ إِوْضنْ غَارْ إِمُوشَانْ يُودْجْغنْ قَاعْ  
\m سَاذُو ثمُّورْثْ.   
\m
\v 11 نِيثْنِي أَذْ تّْوَاسلّْمنْ  
\m إِ ثْزمَّارْ ن سِّيفْ،  
\m أَذْ ذوْڒنْ ذ ثَاكشَّاضْثْ إِ إِشعْبَاونْ.   
\m
\v 12 مَاشَا أَجدْجِيذْ أَذْ إِفَارْحْ زِي أَربِّي.  
\m كُوڒْ  إِجّْ زڭْ إِنِّي إِ غَارسْ إِ غَا إِتّْجَادْجَانْ  
\m أَذْ إِفيّشْ،  
\m مِينْزِي أَقمُّومْ ن يِينِّي إِسَّاوَاڒنْ  
\m س إِخَارِّيقنْ أَذْ إِتّْوَابلّعْ.   
\b  
\b  
\m  
\c 64
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. أَزهّذْ ن ذَاوُوذْ.\add*   
\b  
\m
\v 2 سڒْ، \add أَ\add* أَربِّي، إِ ثْمِيجَّا إِنُو خْمِي تّْشثْشِيغْ،  
\m حْضَا ثُوذَارْثْ إِنُو زڭْ ؤُسِيڭّْوذْ ن ڒعْذُو.   
\m
\v 3 سْذُورِّي أَيِي زِي ثْمعْمُوتْشْ ن إِعفَّاننْ،  
\m زِي ڒْغَاشِي ن يِينِّي إِتّڭّنْ ڒْمُوعْصِييّثْ،   
\m
\v 4 إِنِّي إِسّقْضَاعنْ إِڒسْ نْسنْ  
\m أَمْ يِيجّْ ن سِّيفْ،  
\m قَارّْصنْ أَوَاڒْ يَارزْڭنْ  
\m أَمْ فْڒِيثْشَا \add ن ڒْقوْسْ\add* نْسنْ،   
\m
\v 5 حِيمَا أَذْ وْثنْ \add س ڒْقوْسْ\add*  
\m خْ ونِّي إِكمّْڒنْ  
\m زڭْ إِمُوشَانْ إِنُوفَّارنْ.  
\m ذغْيَا أَذْ خَاسْ نيّْشنْ،  
\m \add إِوَا\add* وَارْ ذِينْ مِينْزِي إِ غَا ڭّْوذنْ.   
\b  
\m
\v 6 نِيثْنِي حزّْمنْ  
\m مَاحنْذْ أَذْ ڭّنْ مِينْ وَارْ إِحْڒِينْ،  
\m سَّاوَاڒنْ س ثْنُوفّْرَا  
\m مَاحنْذْ أَذْ نذْينْ ثِيخْشِيفِينْ.  
\m قَّارنْ: ”وِي ثنْ إِ غَا إِژَارنْ!“   
\m
\v 7 نِيثْنِي تّْخَارّْصنْ  
\m ذِي \add مَارَّا مِينْ إِدْجَانْ ذ\add* أَعفَّانْ: ”أَقَا نوْجذْ،  
\m إِشْثْ ن ثْمعْمُوتْشْ ن ثحْرَايْمشْثْ!“  
\m أَقَا مِينْ إِدْجَانْ ذَاخڒْ ذڭْ ورْيَازْ  
\m ؤُ ذڭْ وُوڒْ نّسْ أَقَا يُودْجغْ.   
\b  
\m
\v 8 أَربِّي أَذْ ثنْ إِوّثْ س فْڒِيثْشَا \add ن ڒْقوْسْ\add*،  
\m ذغْيَا أَذْ بَاننْ جّْرَايحْ نْسنْ.   
\m
\v 9 إِڒسْ نْسنْ أَذْ ثنْ يَارّْ  
\m أَذْ نْقَارْضنْ ذڭْ إِخفْ نْسنْ،  
\m كُوڒْ إِجّْ، زڭْ إِنِّي ثنْ إِتّْوَاڒَانْ،  
\m أَذْ يَارْوڒْ.   
\m
\v 10 \add خنِّي\add* أَذْ ڭّْوذنْ مَارَّا إِوْذَانْ،  
\m أَذْ بَارّْحنْ ثِيمڭَّا ن أَربِّي  
\m ؤُشَا أَذْ خْزَارنْ مْلِيحْ ذِي مِينْ د إِتّڭّْ.   
\m
\v 11 أَمْسڭّذْ أَذْ إِفَارْحْ ذِي سِيذِي  
\m ؤُ أَذْ غَارسْ د-يَارْوڒْ،  
\m مَارَّا إِنِّي ؤُمِي إِسڭّذْ وُوڒْ أَذْ فَارْحنْ.   
\b  
\b  
\m  
\c 65
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. أَزهّذْ ن ذَاوُوذْ. إِزْڒِي.\add*   
\b  
\m
\v 2 أَصبّحْ إِتّْرَاجَا إِ شكْ ذِي ڒْهُوذْنثْ،  
\m \add أَ،\add* أَربِّي، ذِي صِيهْيُونْ،  
\m \add إِتّْخصَّا\add* أَذْ إِتّْوَاكمّڒْ لْوَاعْذْ إِ شكْ.   
\m
\v 3 شكْ ثسْڒِيذْ إِ ثْژَادْجِيثْ،  
\m مَارَّا دَّاثْ أَذْ غَاركْ د-يَاسْ.   
\m
\v 4 ڒْمُوعْصِييّثْ ثُوغَا ثجْهذْ خَافِي،  
\m \add مَاشَا\add* شكْ ثتّڭّذْ أَصْڒَاحْ خْ إِخطَّانْ نّغْ.   
\m
\v 5 سّعْذْ ن ونِّي إِ ثْفَارّْزذْ شكْ  
\m ؤُ ثسّْقَارّْبذْ ث-إِ-د \add غَاركْ\add*،  
\m حِيمَا أَذْ إِزْذغْ ذِي ڒمْرَاحَاثْ نّشْ.  
\m نشِّينْ أَذْ نجِّيونْ  
\m س ڒْخَارْ ن ثَادَّارْثْ نّشْ،  
\m س ثْقدَّاسْثْ ن زَّاوشْثْ نّشْ ثَامقّْرَانْثْ.   
\b  
\m
\v 6 شكْ أَذْ خَانغْ د-ثَارّذْ ذِي ثْسڭْذَا  
\m س ثْمڭَّا إِسَّاڭّْوَاذنْ،  
\m \add أَ\add* أَربِّي ن ؤُسنْجمْ نّغْ.  
\m أَقَا \add شكْ\add* ذ ڒَامَانْ  
\m ن مَارَّا ثِينڭُّورَا ن ثمُّورْثْ،  
\m ن ڒبْحُورْ إِڭّْوجنْ قَاعْ.   
\m
\v 7 \add شكْ\add* ذ ونِّي إِسّْرُوسَانْ إِذُورَارْ  
\m س جّْهذْ نّسْ،  
\m شكْ ثْبكّْسذْ س جّهْذْ.   
\m
\v 8 \add شكْ\add* ذ ونِّي إِتَّارَّانْ  
\m ڒهْوڒْ ن ڒبْحُورْ يَارسَّا،  
\m ڒهْوڒْ نْ ڒمْوَاجْ  
\m زّْهِيرْ نْ شُّوعُوبْ.   
\m
\v 9 إِنِّي إِزدّْغنْ غَارْ ثْنڭُّورَا \add ن ثمُّورْثْ\add*  
\m تّڭّْوذنْ زِي ڒعْڒَامَاثْ نّشْ،  
\m أَقَا شكْ ثتَّارِّيذْ ڒفْجَارْ ن ثُوفُّوثْ  
\m ذ وطُّو ن ثْمذِّيثْ أَذْ سْڒِيوڒْونْ.   
\b  
\m
\v 10 شكْ ثَارزّْفذْ ثَامُّورْثْ،  
\m ثتَّارِّيذْ \add ثِيغزْرَاثِينْ\add* أَذْ ت شُوقنْثْ،  
\m أَقَا شكْ ثتَّارِّيذْ ت-إِ-د  
\m س ڒْخِيرْ أَطَّاسْ.  
\m إِغْزَارْ ن أَربِّي \add نِّي ت إِتّْشُوقَا\add*  
\m أَقَا إِتّْشُورْ س وَامَانْ.  
\m شكْ ثسّوْجَاذذْ إِمنْذِي نْسنْ،  
\m مَاغَارْ إِ ؤُيَا إِ ثڭِّيذْ ثَامُّورْثْ.   
\m
\v 11 شكْ ثتّْسَاوذْ مْسقّمْ  
\m ڒَْاثَارَاثْ ن وشْرَازْ،  
\m ثسّْهكّْوِيذْ إِبُوذَا نّسْ.  
\m ثسَّارْضَابذْ ثَامُّورْثْ س إِنشْنَاشنْ،  
\m ثتّْبَارْكذْ أَغمُّويْ نّسْ.   
\b  
\m
\v 12 شكْ ثتّڭّذْ تَّاجْ  
\m إِ ؤُسڭّْوَاسْ ن ڒْخَارْ نّشْ،  
\m ڒَْاثَارَاثْ نّشْ تُّوذُومنْثْ س ثَاذُونْثْ.   
\m
\v 13 أَقَا تُّوذُومنْثْ خْ دّْمَانِي ن ڒخْڒَا،  
\m ثِيوْرِيرِينْ بكّْسنْثْ س ڒفْرَاحثْ.   
\m
\v 14 دّْمَانِي ن ثَاروْسَا سُّونْثْ س وُودْجِي،  
\m ثِيغْزُورِينْ ذْڒِينْثْ س إِمنْذِي.  
\m نِيثْنِي دُّوقُّوزنْ س ؤُسْڒِيوْڒوْ،  
\m \add وَاهْ\add*، تّْغنَّاجنْ.   
\b  
\b  
\m  
\c 66
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. إِزْڒِي. أَزهّذْ.\add*  
\b  
\m ذُوقّْزمْ س ؤُسْڒِيوْڒوْ إِ أَربِّي،  
\m \add وَاهْ،\add* مَارَّا ثَامُّورْثْ!   
\m
\v 2 زهّْذمْ إِ ؤُعُودْجِي ن يِيسمْ نّسْ،  
\m سّْعُودْجْ \add إِ-ث\add* إِ ؤُسمْغَارْ نّسْ. \x ◘ \xo 66:‏2 \xt أَعَوذ. 10‏:‏21\x*   
\m
\v 3 إِنِيمْ إِ أَربِّي:  
\m ”مَامّشْ سَّاڭّْوَاذنْثْ ثْمڭَّا نّشْ!“  
\m زِي ڒمْغَارثْ ن جّْهذْ نّشْ  
\m أَذْ \add خَاكْ\add* سّْنِيعْمِيڒنْ ڒْعذْيَانْ نّشْ  
\m أَذْ أَضَارنْ إِ شكْ.   
\m
\v 4 مَارَّا ثَامُّورْثْ،  
\m \add وَاهْ مَارَّا\add* أَذْ أَشْ سجْذنْ  
\m ؤُ أَذْ زهّْذنْ،  
\m أَذْ زهّْذنْ إِ يِيسمْ نّشْ. سِيلَاهْ.   
\b  
\m
\v 5 أَسمْ-د، خْزَارمْ ثِيمڭَّا ن أَربِّي.  
\m مِينْ إِڭَّا زَّاثْ إِ ثَارْوَا ن بْنَاذمْ  
\m أَقَا إِسَّاڭّْوَاذْ.   
\m
\v 6 نتَّا يَارَّا ڒبْحَارْ ذ ڒْبَارْ.  
\m نِيثْنِي ژْوَانْ إِغْزَارْ خْ إِضَارنْ.  
\m ذِينِّي إِ زَّايسْ نْفَارّحْ. \x ◘ \xo 66:‏6 \xt ؤُف. 14‏:‏21‏-‏31؛ ياش. 3‏:‏14 \x*   
\m
\v 7 س جّهْذْ نّسْ إِحكّمْ إِ ڒبْذَا.  
\m ثِيطَّاوِينْ نّسْ تّْعسّنْثْ خْ ڒڭْنُوسْ.  
\m غَارْومْ أَذْ مّْعَاڒَانْ إِنِّي إِتّْغوّْغنْ.  
\m سِيلَاهْ. \x ◘ \xo 66:‏7 \xt 2 إِم. 16‏:‏9؛ أَيُوبْ 28‏:‏24؛ إِزهد. 33‏:‏13\x*   
\b  
\m
\v 8 بَارْكمْ أَربِّي نّغْ، \add كنِّيوْ أَ\add* ڒڭْنُوسْ،  
\m ڭّمْ أَذْ إِتّْوَاسڒْ ڒْحسّْ ن ؤُصبّحْ نّسْ.   
\m
\v 9 \add نتَّا\add* ذ ونِّي ذ أَنغْ إِتِّيشنْ ثُوذَارْثْ،  
\m ذ ونِّي وَارْ إِجِّينْ أَضَارْ نّغْ أَذْ إِفَارْغْ.   
\m
\v 10 مِينْزِي شكْ، \add أَ\add* أَربِّي، ثْقدْجْبذْ أَنغْ،  
\m شكْ ثسِّيزذْڭذْ أَنغْ  
\m أَخْمِي سِّيزْذَاڭنْ نُّوقَارْثْ.   
\m
\v 11 شكْ ثْنذْهذْ أَنغْ ذِي ثْرَاشَّا \add ن ڒْفخْ\add*.  
\m ثسَّارْسذْ خَانغْ إِجّْ ن دّْقڒْ  
\m خْ ثجْعِينَّا نّغْ.   
\m
\v 12 شكْ ثجِّيذْ إِوْذَانْ أَذْ نْينْ  
\m خْ إِزدْجِيفنْ نّغْ،  
\m أَقَا نذْوڒْ ذِي ثْمسِّي ذ وَامَانْ،  
\m \add مَاشَا\add* شكْ ثسُّوفّْغذْ أَنغْ  
\m س إِجّْ ن ڒْقدّْ إِفيّضْ.   
\b  
\m
\v 13 نشّْ أَذْ د-أَذْفغْ غَارْ ثَادَّارْثْ نّشْ  
\m س ثْغَارْصَا ن وشْمَاضْ،  
\m أَذْ أَشْ خدْجْصغْ لْوُوعُوذْ إِنُو،   
\m
\v 14 \add لْوُوعُوذْ\add* نِّي زَّايْسنْ نطْقنْ  
\m إِينْشِيشنْ إِنُو،  
\m نِّي \add زَّايْسنْ\add* إِسِّيوڒْ ؤُقمُّومْ إِنُو،  
\m ڒَْامِي ثُوغَا أَيِي ذِي ڒحْصَارثْ.   
\m
\v 15 ثِيغَارْصَا ن وشْمَاضْ نْ ڒْمَارْ إِصحّنْ  
\m أَذْ أَشْ ثنْثْ-إِ-د-أَوْيغْ  
\m أَكْ-ذ ڒبْخُورْ ن إِشَارِّييّنْ.  
\m نشّْ أَذْ \add أَشْ\add* سّْوجْذغْ إِفُونَاسنْ ذ إِغَايْضنْ.  
\m سِيلَاهْ.   
\b  
\m
\v 16 مَارَّا كنِّيوْ إِ إِتّڭّْوْذنْ أَربِّي،  
\m أَسّتِّيوْ-د، سْڒمْ،  
\m نشّْ خْسغْ أَذْ أَومْ عَاوْذغْ  
\m مِينْ إِ ذ أَيِي إِڭَّا ذِي ڒعْمَارْ إِنُو.   
\m
\v 17 \add عَاذْ\add* إِڒَاغَا خَاسْ ؤُقمُّومْ إِنُو،  
\m \add خنِّي\add* أَقَا نتَّا إِتّْوَاسّمْغَارْ  
\m سَاذُو يِيڒسْ إِنُو.   
\m
\v 18 مْڒِي ثُوغَا نْوِيغْ ڒْمُوعْصِييّثْ  
\m ذڭْ وُوڒْ إِنُو،  
\m \add خنِّي\add* أَقَا سِيذِي إِنُو وَارْ ذ أَيِي إِتّسْڒِي شَا.   
\m
\v 19 أَربِّي \add مَاشَا\add* أَقَا إِسْڒَا أَيِي،  
\m أَقَا نتَّا إِوْشَا ثَايْنِيثْ  
\m إِ ثْمِيجَّا ن ثْژَادْجِيثْ إِنُو.   
\m
\v 20 أَذْ إِتّْوَابَاركْ أَربِّي  
\m ونِّي وَارْ إِنْضَارنْ ثَاژَادْجِيثْ إِنُو،  
\m وَارْ ذ أَيِي إِكِّيسْ  
\m ثَامخْسِيوْثْ نّسْ إِشوَّارنْ.   
\b  
\b  
\m  
\c 67
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. أَكْ-ذ ؤُزنْزُونْ خْ إِفِيڒَانْ. أَزهّذْ. إِزْڒِي.\add*   
\b  
\m
\v 2 أَذْ خَانغْ إِحِينّْ أَربِّي.  
\m نتَّا إِتّجَّا ؤُذمْ نّسْ  
\m أَذْ خَانغْ يَارْغْ - سِيلَاهْ - \x ◘ \xo 67:‏2 \xt ڒخْڒ. 6‏:‏25؛ إِزهد. 4‏:‏7\x*   
\b  
\m
\v 3 مَاحنْذْ أَذْ سّْننْ أَبْرِيذْ نّشْ  
\m خْ ثمُّورْثْ،  
\m \add أَذْ سّْننْ\add* أَسنْجمْ نّشْ  
\m جَارْ مَارَّا ڒڭْنُوسْ!   
\b  
\m
\v 4 ڒڭْنُوسْ أَذْ شكْ قَاذَانْ، \add أَ\add* أَربِّي،  
\m مَارَّا ڒڭْنُوسْ أَذْ شكْ قَاذَانْ.   
\b  
\m
\v 5 ڒڭْنُوسْ أَذْ فَارْحنْ، أَذْ سْڒِيوڒْونْ،  
\m مَاغَارْ شكْ أَذْ ثْحكْمذْ  
\m خْ ڒڭْنُوسْ نِيشَانْ،  
\m شكْ أَذْ ثسُّويُورذْ شُّوعُوبْ  
\m خْ ثمُّورْثْ - سِيلَاهْ -   
\b  
\m
\v 6 ڒڭْنُوسْ أَذْ شكْ قَاذَانْ، \add أَ\add* أَربِّي،  
\m مَارَّا ڒڭْنُوسْ أَذْ شكْ قَاذَانْ.   
\b  
\m
\v 7 ثَامُّورْثْ ثتِّيشْ ڒْغِيدْجثْ نّسْ.  
\m أَربِّي، أَربِّي نّغْ،  
\m أَذْ أَنغْ إِبَاركْ.   
\b  
\m
\v 8 أَربِّي أَذْ أَنغْ إِبَاركْ  
\m ؤُ مَارَّا ثِينڭُّورَا ن ثمُّورْثْ  
\m أَذْ زَّايسْ ڭّْوذنْثْ.   
\b  
\b  
\m  
\c 68
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. ن ذَاوُوذْ. أَزهّذْ. إِزْڒِي.\add*   
\b  
\m
\v 2 أَربِّي أَذْ إِكَّارْ،  
\m ڒْْعذْيَانْ نّسْ أَذْ تّْوَاريّْشنْ،  
\m إِنِّي ث إِشَارّْهنْ أَذْ أَروْڒنْ  
\m زَّاثْ إِ وُوذمْ نّسْ. \x ◘ \xo 68:‏2 \xt ڒخْڒ. 10‏:‏35\x*   
\m
\v 3 شكْ أَذْ ثنْ ثسِّيڭّْوجذْ  
\m أَمْ دّخَّانْ \add إِطَّاوْ\add*،  
\m أَمْ شّْمعْ إِفسِّي ذِي ثْمسِّي،  
\m \add أَمُّو\add* إِ غَا فْنَانْ إِعفَّاننْ  
\m زَّاثْ إِ وُوذمْ ن أَربِّي.   
\b  
\m
\v 4 إِمْسڭَّاذنْ أَذْ فَارْحنْ،  
\m أَذْ سْڒِيوْڒِيونْ س ڒفْرَاحثْ  
\m زَّاثْ إِ وُوذمْ ن أَربِّي  
\m ؤُ أَذْغبَّانْ ڒفْرَاحثْ. \x ◘ \xo 68:‏4 \xt ڒخْڒ. 10‏:‏10\x*   
\m
\v 5 غنّْجمْ إِ أَربِّي، زهّْذمْ  
\m إِ يِيسمْ نّسْ،  
\m ڭّمْ إِجّْ ن وبْرِيذْ يُوعْڒَانْ  
\m إِ ونِّي إِندّْهنْ ذِي ڒوْضَا.  
\m سِيذِي ذ إِسمْ نّسْ.  
\m نڭْزمْ سْ ڒفْرَاحثْ  
\m زَّاثْ إِ وُوذمْ نّسْ. \x ◘ \xo 68:‏5 \xt ڒخْڒ. 22‏:‏1؛ 26‏:‏3، 63؛ 31‏:‏12؛ 33‏:‏48، 49، 50؛ 35‏:‏1، 13؛ أَعَوذ. 34‏:‏1، 8؛ ياش. 13‏:‏32\x*   
\b  
\m
\v 6 بَابَاثْسنْ ن إِيُوجِيڒنْ ذ ڒْقَاضِي ن ثِيجَّاڒْ،  
\m \add أَمُّو إِ يدْجَا\add* أَربِّي  
\m ذِي ثْزذِّيغْثْ نّسْ إِقدّْسنْ، \f ◼ \fr 68:‏6 \ft \+bd ’ڒْقَاضِي‘\+bd* - نِيغْ ’أَمزْرُوفْ‘.\f*   
\m
\v 7 \add أَمُّو إِ يدْجَا\add* أَربِّي  
\m ونِّي إِسّْزدَّاغنْ إِنِّي وحّذْسنْ  
\m ذڭْ إِشْثْ ن ثْوَاشُونْثْ،  
\m ونِّي إِسُّوفُّوغنْ إِمحْبَاسْ س ؤُفْڒَاحْ،  
\m مَاشَا إِمْغوَّاغنْ أَذْ زذْغنْ  
\m ذڭْ إِشْثْ ن ثمُّورْثْ  
\m إِتّْوَاسّْشمْضنْ \add زِي ثْفُوشْثْ\add*.   
\b  
\m
\v 8 \add أَ\add* أَربِّي، أَڒَامِي ثِيزَّارذْ  
\m زَّاثْ إِ وُوذمْ ن ڒْڭنْسْ نّشْ،  
\m أَڒَامِي ثُوغَا ثڭُّورذْ ذِي ثْنزْرُوفْثْ - سِيلَاهْ -   
\m
\v 9 ثنْهزّْ ثمُّورْثْ ؤُشَا ؤُشْرُورنْ إِجنْوَانْ،  
\m زَّاثْ إِ وُوذمْ ن أَربِّي،  
\m ؤُڒَا ذ أَذْرَارْ ن سِينَا \add إِنْهزّْ\add*  
\m زَّاثْ إِ وُوذمْ ن أَربِّي، أَربِّي ن إِسْرَائِيل. \f ◼ \fr 68:‏9 \ft \+bd ’سِينَا‘\+bd* - ذَانِيثَا إِذْوڒْ أَربِّي ذ أَجدْجِيذْ ن إِسْرَائِيل (يَاشُورُونْ). خْزَارْ أَعَوذ. 33‏:5. ذڭْ ومْشَانْ-أَ ثبْذَا عَاوذْ ثسْغُونْثْ ن ڒْعَاهْذْ ن ڒْڭنْسْ أَكْ-ذ شَّارِيعَا ن مُوسَا: تَّاوْرَاثْ.\f*  \x ◘ \xo 68:‏9 \xt ؤُف. 19\x*   
\b  
\m
\v 10 \add أَكْ-ذ\add* ونْژَارْ إِفْسُوسنْ  
\m ثْرُوشّذْ \add ثَامُّورْثْ\add*، \add أَ،\add* أَربِّي،  
\m \add خْمِي\add* إِ غَا إِسْڒَاوْ ڒْوَارْثْ نّشْ،  
\m ثوْشِيذْ أَسْ شكْ \add عَاوذْ\add* جّهْذْ.   
\m
\v 11 ثَاحِيمَارْثْ نّشْ ثُوغَا ثْزدّغْ ذَايسْ.  
\m س ثْشُونِي نّشْ ثسّْوجْذذْ ت إِ ڒْمسْكِينْ،  
\m \add أَ\add* أَربِّي! \f ◼ \fr 68:‏11 \ft \+bd ’ثَاهِيمَارْثْ نّكْ‘\+bd* - نِيغْ ’ثُوذَارْثْ نّكْ‘، أَقَا مَارَّا مِينْ إِدْجَانْ ذ أَڭْرَا إِدَّارنْ غَارْ إِجّْ ن بْنَاذمْ. أَوَاڒْ-أَ ذ إِجّْ ن ؤُشيَّارْ غَارْ ڒْڭنْسْ ن أَربِّي، غَارْ إِسْرَائِيل.\f*   
\b  
\m
\v 12 سِيذِي إِنُو إِوْشَا أَوَاڒْ،  
\m ثِيمْغَارِينْ نِّي د-إِتَّاوْينْ  
\m ڒخْبَارْ أَصبْحَانْ  
\m \add تّْكوّْننْثْ\add* إِجّْ ن ؤُبَارُّو  
\m أَمقّْرَانْ ن ثْرقَّاسِينْ.   
\m
\v 13 إِجدْجِيذنْ ن ڒْعسْكَارَاثْ تّْرَاكّْوَاڒنْ،  
\m أَقَا تّْرَاكّْوَاڒنْ،  
\m ؤُ ثنِّي إِقِّيمنْ ذِي ثَادَّارْثْ،  
\m ثْبطَّا ثَاكشَّاضْثْ. \f ◼ \fr 68:‏13 \ft \+bd ’ثنِّي إِقِّيمنْ ذِي ثَادَّارْثْ‘\+bd* - أَذْ ثَاغْ أَوَاڒْ-أَ ذ إِجّْ ن ؤُشيَّارْ غَارْ يَاعِيلْ (خْزَارْ ڒقض. 5‏:24). خْزَارْ عَاوذْ 2 صم. 1:‏24.\f*   
\b  
\m
\v 14 مَا كنِّيوْ وَارْ ثبُّوزّْڒمْ  
\m جَارْ ثْنَاينْ ن ثَارْيِيوِينْ،  
\m \add أَمْ وذْبِيرْ جَارْ\add* وَافْرِيونْ \add نّسْ\add*  
\m إِ إِتّْوَاڒحّْفنْ س نُّوقَارْثْ،  
\m \add جَارْ\add* أَرِّيشْ نّسْ س وُورغْ أَزِيزَا إِتِّيسِّيقنْ،   
\m
\v 15 ڒَامِي أَمْزمَّارْ خْ كُوڒْشِي  
\m إِسَّاريّشْ إِجدْجِيذنْ ذِي ثمُّورْثْ،  
\m إِشَّاثْ وذْفڒْ خْ صَالْمُونْ. \f ◼ \fr 68:‏15 \ft \+bd ’ذِي ثمُّورْثْ‘\+bd* - س ثِيعِيبْرَانِيثْ ’ذَايسْ‘. \+bd ’صَالْمُونْ‘\+bd* - نشِّينْ وَارْ نسِّينْ شَا نِيشَانْ مَانِي إِدْجْ وذْرَارْ نْ صَالْمُونْ. أَقَا ذِينْ إِنِّي إِقَّارنْ أَقَا-ث ذ إِجّْ وذْرَارْ ذِي ڒْوسْثْ ن ثمُّورْثْ ن إِسْرَائِيل ؤُ إِنّغْنِي قَّارنْ أَقَا-ث ذ إِجّْ ن وذْرَارْ جَارْ إِذُورَارْ ن بَاشَانْ (إِخْسْ أَذْ يِينِي ڒڭْعُوذِي ن جُولَانْ ذڭْ وُوسَّانْ نّغْ). أَقَا بَالَاكْ أَقَا-ث ذِي بَاشَانْ.\f*   
\b  
\m
\v 16 أَذْرَارْ ن أَربِّي! أَذْرَارْ ن بَاشَانْ!  
\m أَذْرَارْ ن بَاشَانْ ذ إِجّْ ن وذْرَارْ  
\m س ثْقِيشِّيثِينْ \add أَطَّاسْ\add*. \f ◼ \fr 68:‏16 \ft \+bd ’أَذْرَارْ ن أَربِّي‘\+bd* - أَقَا-ث ذ أَذْرَارْ ن مُورِييَا مَانِي إِقدّمْ إِبْرَاهِيمْ مِّيسْ إِسْحَاقْ ذ ثَاغَارْصْثْ إِ أَربِّي. ذڭْ وُوسَّانْ ن سُولِيمَانْ بْنَانْ ذِينْ زَّاوشْثْ ثَامْقدَّاسْثْ ذِي ؤُرْشَالِيمْ ؤُشَا أَذْرَارْ إِذْوڒْ إِثْوَاسّْننْ أَمْ وذْرَارْ ن صِيهْيُونْ. \+bd ’بَاشَانْ‘\+bd* - إِذُورَارْ ن بَاشَانْ ن زِيشْ أَقَا-ثنْ ذ ڒڭْعُوضِي ن جُولَانْ ذڭْ وُوسَّانْ نّغْ، غَارْ شَّامَالْ ن ثمُّورْثْ ن إِسْرَائِيل، ؤُ جَارْ أَسنْ أَذْرَارْ ن هِيرْمُونْ ونِّي غَارْ إِدْجْ إِجّْ ن ڒُوعْرَا ن 2800 مِيثْرُو. أَذْرَارْ ن صِيحْيُونْ غَارْسْ مْغِيرْ 800 مِيثْرُو ن ڒُوعْڒَا.\f*   
\m
\v 17 مَايمِّي ثْخزَّارمْ  
\m أَمُّو س وَاسَامْ،  
\m \add كنِّيوْ أَ\add* إِذُورَارْ  
\m س مَارَّا ثِيقِيشِّيثِينْ \add نْومْ\add*،  
\m غَارْ وذْرَارْ إِ إِمژْرِي إِ-ث أَربِّي  
\m ذ ثَازذِّيغْثْ إِ يِيخفْ نّسْ؟  
\m \add وَاهْ، نِيشَانْ\add* سِيذِي أَذْ ذِينْ إِزْذغْ إِ ڒبْذَا. \x ◘ \xo 68:‏17 \xt إِزهد. 87‏:‏1، 2؛ 132‏:‏13\x*   
\b  
\m
\v 18 إِكَارُّوثنْ ن أَربِّي  
\m أَقَا أَثنْ ذعشْرَايَاثْ ن ڒُوڒُوفْ  
\m ذعشْرَايَاثْ ن ڒُوڒُوفْ،  
\m ؤُڒَا ذ أَڒفْ ؤُ عَاوذْ \add أَڒفْ\add*.  
\m سِيذِي إِنُو أَقَا-ث جَارْ أَسنْ،  
\m \add أَذْرَارْ ن\add* سِينَا \add أَقَا إِتّْوَاڒحّفْ\add*  
\m س ثْقدَّاسْثْ. \x ◘ \xo 68:‏18 \xt أَعَوذ. 33‏:‏2\x*   
\m
\v 19 شكْ ثُوڒْيذْ غَارْ سنّجْ،  
\m ثْنذْهذْ إِمحْبَاسْ ذِي ثْمحْبَاسْثْ،  
\m شكْ ثْمنْعذْ ثَارْزِيفِينْ زڭْ إِوْذَانْ،  
\m \add إِوَا عَاذْ\add* زڭْ إِمْغوّْغنْ،  
\m حِيمَا سِيذِي، أَربِّي، أَذْ إِزْذغْ \add ذِينِّي\add*. \x ◘ \xo 68:‏19 \xt أَفا. 4‏:‏8؛ ڒخْڒ. 17‏:‏21؛ ياش. 9‏:‏23؛ عِز. 8‏:‏20\x*   
\b  
\m
\v 20 أَذْ إِتّْوَابَاركْ سِيذِي إِنُو.  
\m أَسّْ خْ وَاسّْ يَاربُّو إِ نشِّينْ دّْقُوڒَاثْ.  
\m أَربِّي نِّي ذ أَسنْجمْ نّغْ - سِيلَاهْ - \f ◼ \fr 68:‏20 \ft \+bd ’أَمْسنْجمْ‘\+bd* - نِيغْ ’أَمْسلّكْ‘.\f*   
\m
\v 21 أَربِّي نِّي  
\m ذ إِجّْ ن أَربِّي ن إِسنْجَامنْ إِ نشِّينْ.  
\m أَقَا ذِينْ إِفكِّيثنْ زِي ڒْموْثْ  
\m غَارْ سِيذِي، سِيذِي إِنُو.   
\b  
\m
\v 22 س ثِيذتّْ، أَربِّي، أَذْ إِڒْبزْ  
\m أَزدْجِيفْ ن ڒْعذْيَانْ نّسْ،  
\m أَشقُّوفْ س ؤُشُوَّافْ  
\m ن ونِّي إِقِّيمنْ إِتّنّضْ  
\m س إِمرْوُوسَا \add ن دّْنُوبْ\add* نّسْ. \x ◘ \xo 68:‏22 \xt أَمز. 3‏:‏15؛ ڒقض. 4‏:‏21\x*   
\m
\v 23 سِيذِي إِنُو إِنَّا:  
\m ”نشّْ أَذْ \add كنِّيوْ\add* د-أَرّغْ زِي بَاشَانْ،  
\m أَذْ \add كنِّيوْ\add* د-أَرّغْ  
\m زِي ڒَادْجَاغْ ن ڒبْحَارْ، \x ◘ \xo 68:‏23 \xt ؤُف. 14‏:‏29؛ ڒخْڒ. 21‏:‏33 \x*   
\m
\v 24 حِيمَا أَذْ ثْحَارّْشذْ س ؤُضَارْ نّشْ  
\m ذڭْ إِذَامّنْ،  
\m \add ؤُشَا ؤُڒَا ذ\add* إِڒسْ ن يِيطَانْ نّشْ  
\m \add أَذْ إِطّفْ\add* ثَاسْغَارْثْ نّسْ زِي ڒْعذْيَانْ.“   
\b  
\m
\v 25 نِيثْنِي ژْرِينْ إِبْرِيذنْ نّشْ  
\m مَامّشْ ثنْ ثُويُورذْ، \add أَ\add* أَربِّي،  
\m إِبْرِيذنْ ن أَربِّي إِنُو، أَجدْجِيذْ إِنُو،  
\m \add ڒحّْفنْ\add* ذِي ثْقدَّاسْثْ.   
\m
\v 26 إِمغْنَاجنْ ثُوغَا ڭُّورنْ غَارْ زَّاثْ،  
\m إِنِّي إِشَّاثنْ خْ إِفِيڒَانْ أَوَارْنِي أَسنْ،  
\m ثِيعْزَارِييِّينْ، ثِينِّي إِتِّيرَارنْ  
\m خْ إِبنْذِيڒنْ نْسنْثْ ذِي ڒْوسْطْ.   
\m
\v 27 بَارْكمْ أَربِّي ذِي ثْمسْمُونِينْ، \add أَ\add* سِيذِي،  
\m زِي ڒْعُونْصَارْ ن إِسْرَائِيل.   
\m
\v 28 أَقَا ذِينْ بِينْيَامِينْ أَمژْيَانْ،  
\m ونِّي خَاسنْ إِتّْصدْجَاضنْ،  
\m \add خنِّي\add* ڒْحُوكَّامْ ن يَاهُوذَا  
\m أَكْ-ذ ؤُبَارُّو ن إِعْشِيرنْ نْسنْ،  
\m \add ؤُڒَا ذ\add* ڒْحُوكَّامْ ن زابُولُونْ  
\m \add ذ\add* ڒْحُوكَّامْ ن نَافْثَالِي.   
\b  
\m
\v 29 أَربِّي نّشْ إِوصَّا  
\m \add مَاحنْذْ أَذْ أَسْ إِمّوْشْ\add* جّهْذْ نّشْ.  
\m \add أَ،\add* أَربِّي، سجْهذْ  
\m مِينْ ثڭِّيذْ ذِي طّْوعْ نّغْ،   
\m
\v 30 زِي زَّاوشْثْ نّشْ ثَامقّْرَانْثْ،  
\m سنّجْ إِ ؤُرْشَالِيمْ.  
\m إِجدْجِيذنْ أَذْ أَشْ إِوْينْ ثَارْزِيفِينْ. \x ◘ \xo 68:‏30 \xt 1 إِج. 10‏:‏10، 24، 25؛ 2 إِم. 32‏:‏23؛ إِزهد. 72‏:‏10؛ 76‏:‏12؛ إِشا. 60‏:‏6‏-‏17؛ حِز. 20‏:‏40؛ حِز. 40‏:‏2؛ حِز. 43‏:‏12 \x*   
\m
\v 31 سِيڭّْوذْ ڒْوحْشْ نِّي \add ذڭْ\add* ؤُغَانِيمْ،  
\m أَبَارُّو ن \add إِفُونَاسنْ\add* إِجهْذنْ  
\m أَكْ-ذ إِعجْمِييّنْ ن ڒڭْنُوسْ،  
\m أَڒَامِي إِڭَّا إِخفْ نّسْ أَمْ إِتّْوَاڒْبزْ،  
\m \add أَمْ\add* نُّوقَارْثْ إِدّزْ.  
\m نتَّا إِزدْجعْ ڒڭْنُوسْ  
\m نِّي ثُوغَا تّْمژْرنْ ذڭْ ؤُمنْغِي. \f ◼ \fr 68:‏31 \ft \+bd ’أَمْوَا‘\+bd* - نِيغْ ’أَينْذُوزْ‘ نِيغْ ’يُوڭُّو‘.\f*   
\m
\v 32 أَذْ د-أَسنْ إِمْشنّْعنْ زِي مِيصْرَا،  
\m كُوشْ أَذْ إِسّْوِيژّضْ إِفَاسّنْ نّسْ  
\m غَارْ أَربِّي س ثزْڒَا.   
\b  
\m
\v 33 \add أَ\add* ثِيڭلْذِيوِينْ ن ثمُّورْثْ،  
\m غنّْجنْثْ إِ أَربِّي،  
\m زهّْذنْثْ إِ سِيذِي إِنُو. سِيلَاهْ.   
\m
\v 34 نتَّا ذ ونِّي إِندّْهنْ  
\m ذڭْ ؤُجنَّا خْ \add مَارَّا\add* إِجنْوَانْ  
\m زڭْ وشْحَاڒْ ؤُيَا.  
\m خْزَارْ، أَقَا نتَّا إِڭَّا  
\m إِجّْ ن ڒْحسّْ إِجهْذنْ س ثْمِيجَّا نّسْ.   
\m
\v 35 وْشمْ جّهْذْ إِ أَربِّي!  
\b  
\m لْعَاضَامَا نّسْ أَقَا-ت ثِيوَا إِ إِسْرَائِيل  
\m ؤُ جّهْذْ نّسْ أَقَا-ث ذڭْ إِسيْنُوثنْ.   
\m
\v 36 \add أَ،\add* أَربِّي، مَامّشْ ثسِّيڭّْوذذْ  
\m زِي ثِيزَاوِييِّينْ نّشْ إِقدّْسنْ،  
\m \add أَ\add* أَربِّي ن إِسْرَائِيل، \add شكْ\add* ذ ونِّي إِتِّيشنْ  
\m جّهْذْ ذ ثْزمَّارْ إِ ڒْڭنْسْ.  
\m أَذْ إِتّْوَابَاركْ أَربِّي. *   
\b  
\b  
\m  
\c 69
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. س ثغْنِينْثْ ن ’ثْلِيلِّيشِينْ‘. ن ذَاوُوذْ.\add*\f ◼ \fr 69:‏1 \ft \+bd ’ثِيلِيلِّيشِينْ‘\+bd* - إِشْثْ ن مَارْكَا ن إِنُّووَّارنْ ذَايْسنْ أَژْرِي أَطَّاسْ.\f*   
\b  
\m
\v 2 سنْجمْ أَيِي، \add أَ\add* أَربِّي،  
\m مَاغَارْ أَمَانْ إِوْضنْ أَيِي  
\m غَارْ ڒعْمَارْ \add إِنُو\add*.   
\m
\v 3 نشّْغبِّيغْ ذڭْ ؤُبَارْيُوضْ يُودْجغْ،  
\m وَارْ \add ذِينْ\add* مَانِي غَا بدّغْ.  
\m أَقَا-يِي ذڭْ وَامَانْ يُودْجْغنْ  
\m ؤُ ڒْحمْڒثْ ثتَّازّڒْ خَافِي.   
\b  
\m
\v 4 نشّْ ؤُحْڒغْ س إِغُويَّانْ،  
\m ثْمِيجَّا إِنُو ثبُّويْبحْ،  
\m ثِيطَّاوِينْ إِنُو قْضَانْثْ  
\m زڭْ ؤُرَاجِي خْ أَربِّي إِنُو.   
\m
\v 5 إِنِّي ذ أَيِي إِشَارّْهنْ خْ وَالُو  
\m تّْوسّْعنْ خْ ؤُشُوَّافْ \add إِ إِدْجَانْ\add* خْ ؤُزدْجِيفْ إِنُو.  
\m إِنِّي يَارزُّونْ أَذْ أَيِي أَردّْدْجنْ،  
\m ڒْْعذْيَانْ إِنُو إِ \add خَافِي\add* إِسّْخَارِّيقنْ،  
\m ذوْڒنْ جهّْذنْ.  
\m مِينْ وَارْ ؤُشَارغْ،  
\m إِتّْخصَّا أَيِي أَذْ ت-إِ-د-أَرّغْ \add عَاذْ\add*. \x ◘ \xo 69:‏5 \xt يُوح. 15‏:‏25\x*   
\b  
\m
\v 6 \add أَ\add* أَربِّي، شكْ ثسّْنذْ ثُوبُّوهڒْيَا إِنُو،  
\m إِمرْوُوسَا \add ن دّْنُوبْ\add* إِنُو وَارْ خَاكْ فَّارنْ.   
\m
\v 7 أجّْ إِنِّي خَاكْ إِسِّيثِيمنْ، وَارْ تّْسضْحِينْ،  
\m \add أَ\add* سِيذِي إِنُو، سِيذِي ن ڒْعسْكَارَاثْ،  
\m أجّْ إِنِّي خَاكْ يَارزُّونْ،  
\m وَارْ زَّايِي تّْوَافطّْحنْ،  
\m \add أَ\add* أَربِّي ن إِسْرَائِيل.   
\m
\v 8 مَاغَارْ ذِي طّْوعْ نّشْ إِ كسِّيغْ أَسحْقَارْ،  
\m أَسضْحِي إِڒحّفْ إِ ؤُغمْبُوبْ إِنُو.   
\b  
\m
\v 9 ذوْڒغْ ذ أَغْرِيبْ غَارْ أَيْثْمَا،  
\m إِ إِحنْجِيرنْ ن يمَّا \add ذوْڒغْ\add* ذ أَبَارَّانِي.   
\m
\v 10 مَاغَارْ ثُوسْمِي \add إِقدّْسنْ\add* إِ ثَادَّارْثْ نّشْ  
\m ثشَّا أَيِي،  
\m أَسحْقَارْ ن يِينِّي شكْ إِسّحْقَارَانْ  
\m إِوْضَا-د خَافِي. \x ◘ \xo 69:‏10 \xt يُوح. 2‏:‏17؛ رُوم. 15‏:‏3\x*   
\m
\v 11 نشّْ رُوغْ غَارْ ؤُژُومِّي ن ڒعْمَارْ إِنُو،  
\m \add مَاشَا\add* أَيَا يِيوِي أَيِي-د عْڒَامْ كُوڒْ أَسحْقَارْ.   
\b  
\m
\v 12 نشّْ يَارْضغْ إِشْثْ ن ثْخَانْشثْ \add ن وشْضَانْ\add*،  
\m \add مَاشَا\add* ذوْڒغْ أَسنْ ذ إِجّْ ن لْمَاثَالْ.   
\m
\v 13 إِنِّي إِقِّيمنْ غَارْ ثوَّارْثْ \add ن ثنْذِينْثْ\add*  
\m سَّاوَاڒنْ خَافِي،  
\m ؤُڒَا ذ إِزْڒَانْ ن يِينِّي إِسسّنْ شّْرَابْ.   
\m
\v 14 نشّْ مَاشَا تّتَّارغْ غَاركْ، \add أَ\add* سِيذِي!  
\m \add أَقَا ذِينْ\add* إِجّْ ن ڒْحَاڒْ ن أَرْضَا، \add أَ\add* أَربِّي،  
\m س ڒمْغَارثْ ن ثْمخْسِيوْثْ نّشْ إِشوَّارنْ.  
\m أَرّْ-د خَافِي س ؤُسنْجمْ نّشْ  
\m إِ د-إِفّْغنْ زِي ڒْمَانثْ نّشْ.   
\b  
\m
\v 15 جْبذْ أَيِي-د زڭْ ؤُبَارْيُوضْ،  
\m أجّْ أَيِي وَارْ تّْغبِّيغْ،  
\m \add حِيمَا\add* أَذْ تّْوَافكّغْ  
\m زڭْ إِنِّي ذ أَيِي إِشَارّْهنْ  
\m ؤُ زڭْ وَامَانْ يُودْجْغنْ.   
\m
\v 16 وَارْ تّجِّي أَذْ أَيِي ثَاوِي ڒْحمْڒثْ،  
\m \add وَارْ تّجِّي\add* ڒَادْجَاغْ أَذْ أَيِي إِسَارْضْ،  
\m أَذْ خَافِي إِبلّعْ وَانُو أَقمُّومْ نّسْ.   
\b  
\m
\v 17 أَرّْ خَافِي، \add أَ\add* سِيذِي،  
\m مَاغَارْ ثَامخْسِيوْثْ نّشْ إِشوَّارنْ  
\m ثصْبحْ.  
\m قْڒبْ غَارِي  
\m عْلَاحْصَابْ أَرّحْمثْ نّشْ إِفيّْضنْ.   
\m
\v 18 وَارْ تّفَّارْ شَا ؤُذمْ نّشْ  
\m خْ ؤُمْسخَّارْ نّشْ،  
\m مَاغَارْ تّْوَاحْصَارغْ.  
\m أَرّْ-د خَافِي ذَاوحْذَا.   
\m
\v 19 أَذسْ أَيِي-د غَارْ ڒعْمَارْ إِنُو، فكّْ إِ-ث.  
\m سصْڒحْ أَيِي ذِي سِّيبّثْ ن ڒْعذْيَانْ إِنُو.   
\b  
\m
\v 20 شكْ ثسّْنذْ ڒْعَارْ إِنُو  
\m ذ ؤُسضْحِي إِنُو ذ ڒفْضِيحثْ إِنُو،  
\m أَقَا مَارَّا إِنِّي ذ أَيِي إِحصَّارنْ  
\m \add بدّنْ\add* زَّاثكْ.   
\m
\v 21 أَسحْقَارْ يَارْژْ أَيِي ؤُڒْ  
\m ؤُ نشّْ قنْضغْ أَطَّاسْ.  
\m رَاجِيغْ أَزِيدْجزْ، مَاشَا وَالُو،  
\m نشّْ \add رَاجِيغْ\add* إِنِّي ذ أَيِي غَا إِعزَّانْ،  
\m مَاشَا وَارْ ؤُفِيغْ \add ؤُڒَا ذ إِجّنْ\add*.   
\m
\v 22 نِيثْنِي ڭِّينْ سّمْ ذِي مَاشَّا إِنُو،  
\m إِ ؤُفَاذِي إِنُو ڭِّينْ أَيِي أَذْ سْوغْ ڒْخدْجْ. \x ◘ \xo 69:‏22 \xt مت. 27‏:‏34،48؛ مك. 15‏:‏23؛ يُوح. 19‏:‏28، 29\x*   
\b  
\m
\v 23 أجّْ طَّابْڒَا نْسنْ أَذْ ثذْوڒْ ذ ڒْفخْ،  
\m ؤُڒَا ذ ثَاخْشفْثْ إِ يِينِّي أَكِيذْسنْ إِبدّنْ. \x ◘ \xo 69:‏23 \xt رُوم. 11‏:‏9\x*   
\m
\v 24 سْذَارْغڒْ ثِيطَّاوِينْ نْسنْ،  
\m حِيمَا وَارْ تّْوِيڒِينْ \add عَاذْ\add*،  
\m أَرّْ ثِيجْعِينَّاثِينْ نْسنْ  
\m أَذْ تّنْهزَّانْثْ ڒبْذَا.\x ◘ \xo 69:‏24 \xt إِشا. 6‏:‏9، 10؛ 29‏:‏10؛ 44‏:‏18؛ رُوم. 11‏:‏10\x*   
\m
\v 25 زدْجعْ خَاسنْ أَسْخضْ نّشْ،  
\m أجّْ ڒْحَاذُوقْ ن وغْضَابْ نّشْ  
\m أَذْ ثنْ إِڒْقفْ.   
\b  
\m
\v 26 أجّْ ڒْمَارْڭحْ ن ثْزذِّيغْثْ نْسنْ  
\m أَذْ إِذْوڒْ ذ ڒْخَارْبثْ،  
\m مَاحنْذْ وَارْ \add ذَايسْ\add* إِزدّغْ \add عَاذْ\add*  
\m ؤُڒَا ذ إِجّنْ. \x ◘ \xo 69:‏26 \xt ڒخ. 1‏:‏20\x*   
\m
\v 27 مَاغَارْ نِيثْنِي ذَارَّاشنْ خْ ورْيَازْ  
\m نِّي ثُوغَا ثوْثِيذْ شكْ،  
\m س ڒْهَارْذْ نْسنْ أَرْنِينْ إِ ڒحْرِيقْ  
\m ن يِينِّي زَّايكْ إِتّْوَاڒقّْفنْ.   
\m
\v 28 أَرّْ دّنْبْ خْ دّنْبْ نْسنْ،  
\m وَارْ ثنْ تّجِّي أَذْ د-أَذْفنْ  
\m غَارْ ثْسڭْذَا نّشْ.   
\b  
\m
\v 29 أجّْ إِ-ثنْ أَذْ تّْوَامْحَانْ  
\m زڭْ وذْلِيسْ \add إِتّْوَانْضنْ\add* ن ثُوذَارْثْ،  
\m أَڒَامِي وَارْ تّْوَازمَّامنْ شَا  
\m غَارْ إِمْسڭَّاذنْ. \x ◘ \xo 69:‏29 \xt فِيل. 4‏:‏3؛ أَسَا. 13‏:‏8؛ 17‏:‏8؛ 20‏:‏15\x*   
\m
\v 30 \add مَاشَا\add* نشّْ أَقَا أَيِي  
\m ذِي ڒغْبنْ ؤُ تّْنزْبَارغْ.  
\m إِڒِي أَذْ أَيِي إِسّْڭعّذْ سنّجْ  
\m ؤُسنْجمْ نّشْ، \add أَ\add* أَربِّي.   
\m
\v 31 نشّْ أَذْ صبّْحغْ إِسمْ ن أَربِّي  
\m س يِيجّْ ن يزْڒِي،  
\m س ؤُقَاذِي أَذْ \add أَسْ\add* سّمْغَارغْ.   
\b  
\m
\v 32 أَيَا أَذْ يَارْضَا سِيذِي كْثَارْ  
\m زڭْ إِجّْ ن ؤُفُونَاسْ،  
\m زڭْ إِجّْ ن ؤُفُونَاسْ أَمژْيَانْ  
\m س وَاشَّاونْ ذ ثشْضشْثْ إِمّْسبْضَانْ.   
\m
\v 33 إِمْهِيننْ نِّي ت إِژْرِينْ، أَذْ فَارْحنْ،  
\m \add ؤُ\add* إِنِّي يَارزُّونْ خْ أَربِّي،  
\m أَقَا ؤُڒْ نْومْ أَذْ إِدَّارْ.   
\m
\v 34 مَاغَارْ سِيذِي إِتّسْڒَا غَارْ إِمزْڒَاضْ،  
\m وَارْ إِسّحْقِيرِي شَا إِمحْبَاسْ نّسْ.   
\b  
\m
\v 35 أجّْ إِجنْوَانْ ذ ثمُّورْثْ أَذْ ث سّمْغَارنْ،  
\m ڒبْحُورْ ذ مَارَّا مِينْ ذَايْسنْ إِتّنْهزَّانْ.   
\m
\v 36 مَاغَارْ أَربِّي أَذْ إِسّنْجمْ صِيهْيُونْ،  
\m أَذْ إِبْنَا \add عَاوذْ\add* ثِيندَّامْ ن يَاهُوذَا،  
\m ؤُشَا نِيثْنِي أَذْ ذِينْ زذْغنْ،  
\m أَذْ ت طّْفنْ ذ ڒْوَارْثْ.   
\m
\v 37 زَّارِيعثْ ن إِمْسخَّارنْ نّسْ  
\m أَذْ ت ثطّفْ ذ ثَاسْغَارْثْ،  
\m إِنِّي إِتّخْسنْ إِسمْ نّسْ  
\m أَذْ ذَايسْ زذْغنْ.   
\b  
\b  
\m  
\c 70
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. ن ذَاوُوذْ. إِ ڒِيذَارثْ.\add*   
\b  
\m
\v 2 \add أَ\add* أَربِّي، ذغْيَاثْ حِيمَا أَذْ أَيِي ثْفكّذْ،  
\m حِيمَا أَذْ أَيِي ثْعَاوْنذْ، \add أَ\add* سِيذِي. \x ◘ \xo 70:‏2 \xt إِزهد. 40‏:‏14‏-‏19\x*   
\m
\v 3 أجّْ إِنِّي يَارزُّونْ ڒعْمَارْ إِنُو  
\m أَذْ تّْوَاخَاروْضنْ  
\m ؤُ أَذْ سّْنُوفَّارنْ إِخفْ نْسنْ،  
\m أجّْ إِنِّي يَارطَّانْ خْ ڒْغَارْ إِ ذَايِي إِڒقّْفنْ،  
\m أَذْ ذوْڒنْ غَارْ ضفَّارْ  
\m ؤُ أَذْ تّْوَاسّْبهْذْڒنْ. \x ◘ \xo 70:‏3 \xt إِزهد. 35‏:‏4، 26؛ 71‏:‏13\x*   
\m
\v 4 أجّْ إِ-ثنْ أَذْعقْبنْ  
\m زِي سِّيبّثْ ن ؤُبهْذڒْ،  
\m إِنِّي ذِينْ إِقَّارنْ: ”هَا، هَا!“   
\b  
\m
\v 5 أجّْ مَارَّا إِنِّي خَاكْ يَارزُّونْ،  
\m أَذْ أَرْشْقنْ، أَذْ زَّايكْ فَارْحنْ.  
\m أجّْ إِنِّي إِتّخْسنْ أَسنْجمْ نّشْ،  
\m أَذْ إِنِينْ ڒبْذَا:  
\m ”أَربِّي ذ أَمقّْرَانْ!“   
\m
\v 6 \add مَاشَا\add* نشّْ ذِي ڒغْبنْ ؤُ زڒْضغْ،  
\m \add أَ\add* أَربِّي، ذغْيَاثْ غَارِي.  
\m شكْ ذ ثْوِيزَا إِنُو ذ أَمْسنْجمْ إِنُو،  
\m \add أَ\add* سِيذِي، وَارْ تّْعطَّاڒْ شَا!   
\b  
\b  
\m  
\c 71
\m
\v 1 أَركّْوَاڒغْ غَاركْ، \add أَ\add* سِيذِي،  
\m أجّْ أَيِيعمَّارْصْ  
\m وَارْ تّْسضْحِيغْ إِ ڒبْذَا.\x ◘ \xo 71:‏1 \xt إِزهد. 22‏:‏6؛ 25‏:‏2، 3؛ 31‏:‏2، 3؛ إِشا. 49‏:‏23\x*   
\m
\v 2 فكّْ أَيِي س ثْسڭْذَا نّشْ ؤُ أَرْخُو أَيِي.  
\m أَرّْ-د غَارِي أَمزُّوغْ نّشْ  
\m ؤُ سنْجمْ أَيِي.   
\m
\v 3 إِڒِي ذ إِشْثْ ن ثصْضَارْثْ إِ ثْزذِّيغْثْ إِ نشّْ،  
\m حِيمَا أَذْ غَارسْ د-أَسغْ ڒبْذَا.  
\m شكْ ثْوصِّيذْ حِيمَا أَذْ تّْوَاسّْنجْمغْ،  
\m مَاغَارْ شكْ ذ ثَاسْضَارْثْ إِنُو ذ لْبُورْجْ إِنُو.   
\b  
\m
\v 4 أَربِّي إِنُو، سنْجمْ أَيِي  
\m زڭْ ؤُفُوسْ ن ؤُعفَّانْ،  
\m زڭْ ؤُفُوسْ ن مِّيسْ ن ڒْمُوعْصِييّثْ  
\m ؤُ زِي بُو -غزُّو.   
\m
\v 5 مَاغَارْ شكْ ذ ڒَايَاسْ إِنُو،  
\m سِيذِي إِنُو، سِيذِي،  
\m \add شكْ\add* ذ أَثشْڒِي إِنُو زِي ثمْژِي إِنُو.   
\m
\v 6 زڭْ ؤُعذِّيسْ \add ن يمَّا\add*،  
\m ثُوغَا أَيِيعمّْذغْ خَاكْ.  
\m زڭْ ؤُعذِّيسْ ن يمَّا،  
\m أَقَا شكْ ذ ونِّي ذ أَيِي إِحُوزنْ،  
\m نشّْ صبْحغْ شكْ ڒبْذَا.   
\b  
\m
\v 7 إِ وَاطَّاسْ نشّْ أَمْ يِيشْثْ نْ ڒعْڒَامثْ \add ن ڒعْجبْ\add*،  
\m \add مَاشَا\add* شكْ ذ أَمْشَانْ إِنُو إِجْهذْ إِ ثَاروْڒَا.   
\m
\v 8 أجّْ أَقمُّومْ إِنُو أَذْ إِشُّورْ  
\m س ؤُصبّحْ نّشْ،  
\m أَسّْ إِمُونْ س شَّانْ نّشْ.   
\m
\v 9 وَارْ خَافِي تّْمنْضَارْ  
\m ذڭْ وُوسَّانْ ن ثوْسَارْ إِنُو،  
\m وَارْ ذ أَيِي سمّحْ  
\m مَاڒَا جّهْذْ إِنُو إِرُوحْ. \f ◼ \fr 71:‏9 \ft \+bd ’ذڭْ وُوسَّانْ‘\+bd* - س ثِيعْبْرَانِيثْ ’ذِي ڒْوقْثْ‘.\f*   
\b  
\m
\v 10 مَاغَارْ ڒْعذْيَانْ إِنُو سَّاوَاڒنْ خَافِي،  
\m إِنِّي يَارزُّونْ ڒعْمَارْ إِنُو،  
\m مْشَاوَارنْ خَافِي جْمِيعْ.   
\m
\v 11 نِيثْنِي قَّارنْ: ”أَربِّي إِسْمحْ ذَايسْ.  
\m ضْفَارمْ ث ؤُ منْعمْ ث،  
\m مَاغَارْ وَارْ ذِينْ ونِّي إِ غَا إِفكّنْ.   
\m
\v 12 \add أَ\add* أَربِّي، وَارْ تّْغِيمِي ثِيڭّْوجذْ خَافِي،  
\m \add أَ\add* أَربِّي إِنُو، أوْشْ أَيِي ذغْيَا أَفُوسْ.   
\b  
\m
\v 13 أجّْ إِغْرِيمنْ ن ثُوذَارْثْ إِنُو  
\m أَذْ تّْوَاسضْحَانْ ؤُ أَذْ تّْوَاشّنْ،  
\m أجّْ إِنِّي يَارزُّونْ أَذْ أَيِي ڭّنْ ڒْغَارْ  
\m أَذْ تّْوَاذْڒنْ س ؤُسحْقَارْ ذ ڒفْضِيحثْ. \x ◘ \xo 71:‏13 \xt إِزهد. 34‏:‏4، 26؛ 40‏:‏15؛ 70‏:‏3\x*   
\m
\v 14 \bd نشّْ\bd* مَاشَا أَذْ قِّيمغْ تّْرَاجِيغْ \add شكْ\add* ڒبْذَا،  
\m ؤُ أَذْ أَرْنِيغْ \add عَاذْ\add* غَارْ ؤُصبّحْ نّشْ.   
\m
\v 15 أَقمُّومْ إِنُو أَذْ إِبَارّحْ  
\m س ثْسڭْذَا نّشْ،  
\m أَسنْجمْ نّشْ، أَسّْ إِمُونْ،  
\m مَاغَارْ وَارْ سِّينغْ ڒْقدّْ نّسْ.   
\b  
\m
\v 16 نشّْ أَذْ د-أَسغْ س ثْمڭَّا ثِيمقّْرَانِينْ  
\m ن سِيذِي إِنُو، سِيذِي،  
\m أَذْ إِذَارغْ ثَاسڭْذَا نّشْ،  
\m مْغِيرْ ثنِّي نّشْ وَاهَا.   
\m
\v 17 \add أَ\add* أَربِّي، شكْ ثُوغَا ثسّڒْمَاذذْ أَيِي  
\m زِي ثمْژِي إِنُو،  
\m ؤُ نشّْ أَڒْ أَسّْ-أَ تّْبَارّْحغْ  
\m س لْمُوعْجِيزَاثْ نّشْ.   
\m
\v 18 \add أَ\add* أَربِّي، وَارْ ذ أَيِي سمّحْ شَا،  
\m وَاخَّا وْسَارغْ شَابغْ،  
\m أَڒْ غَا حَاجِيغْ إِ جِّيڒْ-أَ  
\m خْ \add ثْمڭَّا ن\add* ؤُفُوسْ نّشْ  
\m ؤُڒَا خْ ثْمڭَّا نّشْ ثِيمقّْرَانِينْ،  
\m إِ مَارَّا مِينْ إِ د غَا يَاسنْ.   
\b  
\m
\v 19 \add أَ\add* أَربِّي، ثَاسڭْذَا نّشْ  
\m ثِيوضْ أَڒْ سنّجْ \add قَاعْ\add*،  
\m مَاغَارْ شكْ ثڭِّيذْ ثِيمڭَّا ثِيمقّْرَانِينْ،  
\m \add أَ\add* أَربِّي، مَانْ ونْ إِدْجَانْ أَمْ شكْ!   
\m
\v 20 أَقَا شكْ ثجِّيذْ ثكَّا خَافِي  
\m أَطَّاسْ ن ڒحْصَارَاثْ ذ ڒْغَارْ،  
\m \add مَاشَا وَاخَّا أَمنِّي\add*  
\m شكْ أَذْ أَيِي ثسّدَّارذْ عَاوذْ،  
\m شكْ أَذْ أَيِي ثسُّوفّْغذْ  
\m زڭْ \add وَامَانْ\add* إِهوْڒنْ ن ثمُّورْثْ.   
\m
\v 21 شكْ أَذْ ثَارِّيذْ ڒمْغَارثْ إِنُو أَذْ ثمْغَارْ،  
\m أَذْ أَيِي د-ثنّْضذْ س ؤُفوّجْ نّشْ.   
\b  
\m
\v 22 أَذْ شكْ قَاذِيغْ \add عَاوذْ\add* س لهَارْپَا،  
\m \add خْ\add* ڒَامَانْ نّشْ، \add أَ\add* أَربِّي،  
\m أَذْ شكْ زهّْذغْ س ڒْڭَامْبْرِي،  
\m \add أَ\add* أَمْقدَّاسْ ن إِسْرَائِيل.   
\m
\v 23 إِينْشِيشنْ إِنُو أَذْ سْڒِيوْڒونْ،  
\m أَقَا أَذْ زهّْذغْ إِ شكْ،  
\m ؤُڒَا ذ ڒعْمَارْ إِنُو نِّي ثفْذِيذْ شكْ.   
\m
\v 24 ؤُڒَا ذ إِڒسْ إِنُو أَذْ إِحَاجَا  
\m خْ ثْسڭْذَا نّشْ أَسّْ مَارَّا،  
\m مَاغَارْ إِنِّي يَارزُّونْ  
\m أَذْ أَيِي ڭّنْ ڒْغَارْ،  
\m سضْحَانْ، إِوَا، تّْوَافضْحنْ.   
\b  
\b  
\m  
\c 72
\m
\v 1 \add ن سُولِيمَانْ.\add*  
\b  
\m \add أَ\add* أَربِّي، أوْشْ إِ ؤُجدْجِيذْ  
\m \add مَاحنْذْ\add* أَذْ إِحْكمْ عْلَاحْسَابْ ڒْحقّْ نّشْ،  
\m ؤُ \add أوْشْ\add* ثَاسڭْذَا نّشْ إِ مِّيسْ ن ؤُجدْجِيذْ.   
\m
\v 2 \add خنِّي\add* نتَّا أَذْ إِحَاكمْ  
\m ڒْڭنْسْ نّشْ س ثْسڭْذَا،  
\m ڒْمُوسَاكِينْ نّشْ س ڒْحقّْ.   
\m
\v 3 إِذُورَارْ أَذْ إِوْينْ ڒهْنَا إِ ڒْڭنْسْ،  
\m \add ؤُڒَا ذ\add* ثِيوْرِيرِينْ ثَاسڭْذَا.   
\m
\v 4 نتَّا أَذْ يَاغْ ثسْغَارْثْ  
\m ن ڒْمُوسَاكِينْ ن ڒْڭنْسْ،  
\m أَذْ إِسّنْجمْ ثَارْوَا ن إِمزْڒَاضْ،  
\m ؤُشَا أَذْ إِڒْبزْ ونِّي \add ثنْ\add* إِحصَّارنْ.   
\b  
\m
\v 5 نِيثْنِي أَذْ زَّايكْ ڭّْوذنْ  
\m مِينْ غَا ثكّْ ثْفُوشْثْ \add \+add ثدْجَا\+add*، \add* 
\m ؤُ ثَازِيرِي \add أَذْ ثسّْشنْ\add* ؤُذمْ \add نّسْ\add*،  
\m زِي جِّيڒْ أَڒْ جِّيڒْ. \x ◘ \xo 72:‏5 \xt إِزهد. 89‏:‏37، 38\x*   
\m
\v 6 نتَّا أَذْ د-إِهْوَا خْ إِيَّارْ  
\m أَوَارْنِي إِ وحْثَاشْ،  
\m أَمْ ثِينشْنَاشِينْ إِ إِسَّارْضَابنْ ثَامُّورْثْ. \x ◘ \xo 72:‏6 \xt 2 صم. 23‏:‏4\x*   
\m
\v 7 ذڭْ وُوسَّانْ نّسْ  
\m أَذْ إِنُّووَارْ ؤُمْسڭّذْ،  
\m أَذْ ذِينْ يِيڒِي ڒهْنَا إِفيّْضنْ  
\m أَڒْ غَا ثَافذْ ثَازِيرِي وَارْ ثدْجِي عَاذْ.   
\m
\v 8 نتَّا أَذْ إِحْكمْ زِي ڒبْحَارْ أَڒْ ڒبْحَارْ،  
\m زڭْ إِغْزَارْ \add ن لْفُورَاطْ\add*  
\m أَڒْ ثِينڭُّورَا ن ثمُّورْثْ.   
\b  
\m
\v 9 إِمزْذَاغْ نْ ڒخْڒَا  
\m أَذْ قُّونْجڒنْ زَّاثسْ،  
\m \add مَاشَا\add* ڒْعذْيَانْ نّسْ أَذْ ڒسْحنْ ؤُشَاڒْ.   
\m
\v 10 إِجدْجِيذنْ ن ثَارْشِيشْ  
\m أَذْ د-إِوْينْ إِشْثْ ن ثوْهِيبْثْ،  
\m إِجدْجِيذنْ ن شَابَا ذ سبَا  
\m أَذْ د-قَارّْبنْ ثَارْزفِينْ.   
\m
\v 11 مَارَّا إِجدْجِيذنْ أَذْ أَسْ أَضَارنْ،  
\m مَارَّا ڒڭْنُوسْ أَذْ أَسْعبْذنْ.   
\b  
\m
\v 12 مَاغَارْ نتَّا أَذْ إِفكّْ أَمزْڒُوضْ،  
\m ونِّي \add غَارسْ\add* إِتّْڒَاغَانْ،  
\m ؤُڒَا ذ ڒْمسْكِينْ  
\m ذ ونِّي وَارْ غَارسْ أَمْعَاونْ. \x ◘ \xo 72:‏12 \xt أَيُوبْ 29‏:‏12\x*   
\m
\v 13 نتَّا أَذْ إِعْثقْ أَمَارْخُو ذ ؤُمزْڒُوضْ،  
\m نتَّا أَذْ إِسّنْجمْ ڒعْمَارْ ن إِمزْڒَاضْ. \f ◼ \fr 72:‏13 \ft \+bd ’ڒعْمَارْ‘\+bd* - إِخْسْ أَذْ يِينِي ’ثُوذَارْثْ‘.\f*   
\m
\v 14 نتَّا أَذْ إِفكّْ ڒعْمَارْ نْسنْ  
\m زِي دّدْجْ ذ لْعُونْفْ،  
\m إِذَامّنْ نْسنْ أَذْ سكّْوَانْ أَطَّاسْ  
\m ذِي ثِيطَّاوِينْ نّسْ.   
\m
\v 15 نتَّا أَذْ إِدَّارْ!  
\m ؤُ أَذْ أَسْ إِمّوْشْ وُورغْ زِي شَابَا.  
\m ؤُ \add نِيثْنِي\add* أَذْ ژَّادْجنْ ڒبْذَا  
\m ذِي طّْوعْ نّسْ،  
\m أَسّْ مَارَّا أَذْ ث بَارْكنْ.   
\b  
\m
\v 16 أَذْ يِيڒِي إِجّْ ن ؤُفيّضْ ن إِمنْذِي  
\m ذِي ثمُّورْثْ  
\m خْ ثْقِيشَّاثْ ن إِذُورَارْ،  
\m ڒْْغِيدْجثْ نّسْ أَذْ ثنْهزّْ  
\m أَمْ \add ثْشجُّورَا ن\add* لُوبْنَانْ،  
\m ؤُ إِنِّي زِي ثنْذِينْثْ أَذْ نُّووَارنْ  
\m أَمْ أَغمُّويْ \add أَزِيزَا\add* ذِي ثمُّورْثْ.   
\m
\v 17 إِسمْ نّسْ أَذْ إِقِّيمْ إِ ڒبْذَا،  
\m إِڒِي أَذْ إِنُّووَارْ إِسمْ نّسْ  
\m زَّاثْ إِ وُوذمْ ن ثْفُوشْثْ.  
\m أَذْ ذَايسْ تّْوَابَارْكنْ نِيثْنِي،  
\m مَارَّا ڒڭْنُوسْ أَذْ ث سّمْغَارنْ.   
\m
\v 18 أَذْ إِتّْوَابَاركْ سِيذِي أَربِّي،  
\m أَربِّي ن إِسْرَائِيل.  
\m نتَّا إِتّڭّْ لْمُوعْجِيزَاثْ، نتَّا وَاهَا.   
\m
\v 19 أَذْ إِتّْوَابَاركْ  
\m إِسمْ ن ؤُعُودْجِي نّسْ إِ ڒبْذَا.  
\m أَذْ ثتّْوَاشُّورْ مَارَّا ثَامُّورْثْ  
\m س ؤُعُودْجِي نّسْ. أَمِينْ، \add وَاهْ،\add* أَمِينْ.   
\b  
\m
\v 20 ثِيژِيدْجَاثِينْ ن ذَاوُوذْ، مِّيسْ ن يَاسَّا، أَقَا كمّْڒنْثْ.   
\b  
\b  
\m  
\c 73
\s1 أَذْلِيسْ وِيسّْ ثْڒَاثَا: إِزهِّيذنْ 73-89  
\m
\v 1 \add أَزهّذْ ن أَسَافْ.\add*  
\b  
\m وَاهْ، أَربِّي ذ أَصبْحَانْ إِ إِسْرَائِيل،  
\m إِ يِينِّي س وُوڒْ إِصْفَانْ.   
\b  
\m
\v 2 نشّْ مَاشَا، عْڒَاحَاڒْ ثُوغَا إِضَارنْ إِنُو  
\m فّْغنْ \add زڭْ وبْرِيذْ\add*،  
\m وَارْ إِقِّيمْ وَالُو أَذْ حْڒُودْجْضنْ إِصُورَافْ إِنُو.   
\b  
\m
\v 3 مَاغَارْ ثُوغَا ؤُسْمغْ زڭْ إِبُوهَاڒِييّنْ،  
\m \add ڒَْامِي\add* ژْرِيغْ أَقَا إِعفَّاننْ مْلِيحْ إِ دْجَانْ. \x ◘ \xo 73:‏3 \xt أَيُوبْ 21‏:‏7‏-‏15؛ إِزهد. 37‏:‏1؛ إِرْم. 12‏:‏1، 2\x*   
\m
\v 4 مَاغَارْ وَارْ ذِينْ بُو إِسغْوَانْ  
\m غَارْ ڒْموْثْ نْسنْ،  
\m صُّولْطَا نْسنْ أَقَا إِبدّْ نِيشَانْ.   
\m
\v 5 نِيثْنِي وَارْ شَارّْشنْ ذِي ثَامَارَا ن إِوْذَانْ،  
\m وَارْ تّْوَاڒقّْفنْ \add س ڒْمُوصِيبَاثْ\add*  
\m أَمْ \add وزْينْ نّغْنِي ن\add* بْنَاذمْ.   
\m
\v 6 س ؤُيَا ثتَّايڒْ أَسنْ-د نّْفَاخثْ  
\m أَمْ ثْسدّشْثْ غَارْ يِيرِي نْسنْ  
\m ؤُشَا إِڒحّفْ أَسنْ لْعُونْفْ  
\m أَمْ يِيجّْ ن وَارُّوضْ.   
\b  
\m
\v 7 ثِيطَّاوِينْ نْسنْ تّْوَافّْغنْثْ زِي ثَاذُونْثْ،  
\m نِيثْنِيعدُّونْ ڒخْيَاڒَاثْ ن وُوڒْ \add نْسنْ\add*.   
\m
\v 8 نِيثْنِي سْثهْزَانْ \add س بْطَايْطَايْ\add*  
\m سَّاوَاڒنْ خْ ڒْغَارْ، خْ دّدْجْ،  
\m أَقَا سَّاوَاڒنْ زِي سنّجْ.   
\m
\v 9 نِيثْنِي أَرزّْمنْ ؤُقمُّومْ نْسنْ  
\m خْ ؤُجنَّا،  
\m ڒْْهَارْذْ نْسنْ إِڭُّورْ خْ ثمُّورْثْ.   
\m
\v 10 س ؤُيَا إِنّقْڒبْ  
\m \add دَّابْ\add* نْسنْ ن ڒْڭنْسْ غَارْ ذَا،  
\m أَمَانْ إِفيّْضنْ تّْسكَّافنْ ثنْ نِيثْنِي.   
\b  
\m
\v 11 قَّارنْ:  
\m ”مَامّشْ إِ غَا إِسّنْ أَربِّي؟“  
\m ”مَامّشْ إِ غَا إِڭّْ ؤُمْعُودْجِي خْ كُوڒْشِي  
\m أَذْ إِسّنْ؟“   
\m
\v 12 خْزَارْ، أَقَا أَثنْ ذ إِعفَّاننْ!  
\m \add عَاذْ\add* دَّارنْ ڒبْذَا ذِي ڒْهُوذْنثْ،  
\m سّوْسِيعنْ أَڭْڒَا نْسنْ.   
\m
\v 13 س ثِيذتّْ، أَمنِّي وَاهَا  
\m سِّيزذْڭغْ ؤُڒْ إِنُو  
\m ؤُ سِّيرْذغْ إِفَاسّنْ إِنُو ذِي ثَازْذُوڭِي.   
\m
\v 14 أَسّْ أَمْ إِمُونْ نشّْ ثِييِّيثَا ذَايِي،  
\m كُوڒْ صّْبحْ ثتّْوَاربِّيغْ.   
\b  
\m
\v 15 مَاڒَا نِّيغْ: ”ؤُڒَا ذ نشّْ أَذْ سِّيوْڒغْ أَمُّو!“،  
\m خْزَارْ، إِڒِي غْذَارغْ  
\m جِّيڒْ ن إِحنْجِيرنْ نّشْ.   
\m
\v 16 إِتّْڒِيغْ أَيِي \add زمَّارغْ\add* أَذْ فهْمغْ أَيَا،  
\m \add مَاشَا\add* ذِي ثِيطَّاوِينْ إِنُو  
\m إِتَّاوِي-د \add مْغِيرْ\add* ثَامَارَا إِبطّْڒنْ،   
\m
\v 17 أَڒَامِي ؤُذْفغْ  
\m غَارْ ثْزَاوِييِّينْ إِقدّْسنْ ن أَربِّي،  
\m ؤُشَا حكَّارغْ إِ ثْنڭَّارُوثْ نْسنْ.   
\m
\v 18 وَاهْ، شكْ ثسّْرُوسِيذْ ثنْ  
\m خْ إِمُوشَانْ إِتّحْرُودْجُوضنْ،  
\m شكْ ثْغطّْڒذْ ثنْ ذ ڒْخِيرْبَاثْ.   
\b  
\m
\v 19 مَامّشْ ذوْڒنْ  
\m ذ \add إِشْثْ ن ڒْقشْعثْ ن\add* ؤُنخْڒِيعْ  
\m ذڭْ إِشْثْ ن ثشْثِي،  
\m تّْوَامْحَانْ ؤُ تّْوَاقْضَانْ  
\m س إِشڒْوَاونْ إِسَّاڭّْوَاذنْ.   
\m
\v 20 أَمْ ثَارْجِيثْ غَارْ ؤُفَاقِي، \add أَ\add* سِيذِي إِنُو،  
\m \add أَمُّو\add* إِ غَا ثسّحْقَارذْ  
\m \add أَبيّنْ ن\add* ڒخْيَاڒْ نْسنْ  
\m خْمِي د غَا ثْفَاقذْ.   
\m
\v 21 ڒَامِي إِتّْوَاسَّارْزڭْ ؤُڒْ إِنُو  
\m \add ذِي ڒْوقْثْ نِّي\add*،  
\m إِتّجِّي أَيِي \add ڒحْرِيقْ\add* ذِي ثِيژَّاڒْ إِنُو. \f ◼ \fr 73:‏21 \ft \+bd ’ثِيژَّاڒْ‘\+bd* - نِيغْ ’ثِيڭژْڒِينْ‘.\f*   
\m
\v 22 نشّْ ثُوغَا أَيِي ذ أَقفُّوحْ،  
\m ثُوغَا أَيِي غَاركْ أَمْ يِيجّْ ن ڒْوحْشْ  
\m بْڒَا ڒعْقڒْ.   
\b  
\m
\v 23 \add عَاذْ مَاشَا\add* ڒبْذَا أَقَا أَيِي غَاركْ،  
\m شكْ ثطّْفذْ أَيِي زڭْ ؤُفُوسْ أَفُوسِي إِنُو.   
\m
\v 24 شكْ أَذْ أَيِي ثْڭوّْذذْ س شّْوَارْ نّشْ  
\m ؤُ أَوَارْنِي مَانْ أَيَا  
\m أَذْ أَيِي ثكْسِيذْ غَارْ ؤُعُودْجِي نّشْ.   
\m
\v 25 مَانْ ونْ إِ غَارِي ذڭْ ؤُجنَّا  
\m حَاشَا شكْ؟  
\m أَكِيذكْ وَارْ ثْزمَّارْ أَذْ أَيِي ثَارْضَا  
\m ؤُڒَا ذ إِشْثْ ن ثْمسْڒَاشْثْ ذِي ثمُّورْثْ.   
\m
\v 26 مَاڒَا أَرِّيمثْ ذ وُوڒْ إِنُو  
\m سمّْحنْ ذَايِي،  
\m \add خنِّي\add* أَربِّي ذ ثَاصْضَارْثْ ن وُوڒْ إِنُو  
\m ذ ثَاسْغَارْثْ إِنُو إِ ڒبْذَا.   
\b  
\m
\v 27 مَاغَارْ خْزَارْ،  
\m إِنِّي زَّايكْ إِتّڭّْوجنْ أَذْ فْنَانْ.  
\m شكْ أَذْ ثْكحّضذْ كُوڒْ إِجّْ  
\m ونِّي خَاكْ إِتّْحيَّاذنْ  
\m ؤُمِي إِ غَا إِسّفْسذْ إِخفْ نّسْ،   
\m
\v 28 نشّْ مَاشَا، ڒْذَاسثْ إِ أَربِّي ذ مْلِيحْ إِ نشّْ.  
\m نشّْ ڭِّيغْ سِيذِي إِنُو، سِيذِي،  
\m ذ أَمْشَانْ إِنُو ن ثَاروْڒَا،  
\m حِيمَا أَذْ بَارّْحغْ مَارَّا ثِيمڭَّا نّشْ.   
\b  
\b  
\m  
\c 74
\m
\v 1 \add أَخمِّي ن أَسَافْ.\add*  
\b  
\m مَايمِّي، \add أَ\add* أَربِّي، ثنْضَارذْ إِ ڒبْذَا؟  
\m مَايمِّي غَا يَارْغْ وغْضَابْ نّشْ  
\m خْ وُودْجِي ن دّْمَانِي ن ثَاروْسَا نّشْ؟   
\m
\v 2 خمّمْ ذِي ثْمسْمُونْثْ نّشْ  
\m نِّي ثُوغَا ثْكسْبذْ زڭْ وشْحَاڒْ ؤُيَا،  
\m ثَاقْبِيتْشْ ن ثسْغَارْثْ ن ڒْوَارْثْ نّشْ ثنِّي ثفْذِيذْ،  
\m أَذْرَارْ ن صِيهْيُونْ ونِّي خْ ثُوغَا ثْزدّْغذْ.   
\m
\v 3 سْڭعّذْ إِصُورَافْ نّشْ  
\m غَارْ مِينْ يَاردّْدْجنْ إِ ڒبْذَا.  
\m ڒعْذُو يَارَّا مَارَّا ذ ڒْخَارْبثْ  
\m ذِي زَّاوشْثْ إِقدّْسنْ.   
\b  
\m
\v 4 إِنِّي ثُوغَا شكْ إِحصَّارنْ سّْبُوعْرُوثنْ  
\m ذِي ڒْوسْثْ ن ومْشَانْ نّشْ ن ؤُمْسَاڭَارْ،  
\m سّْبدَّانْ ڒعْڒَامَاثْ نْسنْ ذ ڒعْڒَامَاثْ.   
\m
\v 5 أَقَا نتَّا إِذْوڒْ إِتّْوَاسّنْ أَمْ \add يِيجّنْ\add*  
\m إِسّْڭعَّاذْ شّْوَاقَارْ ذِي شْبَارْقْ إِقّْننْ،   
\m
\v 6 ؤُ خنِّي أَرْژِينْ  
\m \add مَارَّا\add* إِنْقَاشنْ نّسْ جْمِيعْ،  
\m س شَّاقُورْ ذ إِفْضِيسنْ.   
\m
\v 7 نِيثْنِي قّذنْ ثِيمسِّي  
\m إِ ثْزَاوِييِّينْ نّشْ إِقدّْسنْ،  
\m أَقَا عَارَّانْ ثَازذِّيغْثْ ن يِيسمْ نّشْ  
\m أَڒْ ثَامُّورْثْ. \x ◘ \xo 74:‏7 \xt 2 إِج. 25‏:‏9\x*   
\m
\v 8 نِيثْنِي نَّانْ ذڭْ وُوڒْ نْسنْ:  
\m ”أجّْ أَنغْ أَذْ ثنْثْ نَاردّدْجْ مَارَّا!“  
\m \add أَمُّو إِ\add* سَّارْغنْ نِيثْنِي  
\m مَارَّا إِمُوشَانْ ن ؤُمْسَاڭَارْ ن أَربِّي  
\m ذِي ثمُّورْثْ.   
\b  
\m
\v 9 ڒعْڒَامَاثْ نّغْ وَارْ ثنْثْ نتّْوِيڒِي \add عَاذْ\add*،  
\m وَارْ ذِينْ ؤُڒَا ذ إِجّْ ن ؤُنَابِي \add عَاذْ\add*،  
\m ؤُشَا ؤُڒَا ذ إِجّْ جَارْ أَنغْ إِسّنْ  
\m أَڒْ مڒْمِي \add عَاذْ\add*.   
\m
\v 10 أَڒْ مڒْمِي، \add أَ\add* أَربِّي،  
\m أَذْ \add زَّايكْ\add* إِسْثهْزَا ونِّي إِحصَّارنْ؟  
\m مَا أَذْ إِشقّفْ ڒعْذُو إِ ڒبْذَا  
\m ذڭْ يِيسمْ نّشْ؟   
\m
\v 11 مَايمِّي إِ ثتّڭّذْ  
\m أَذْ ذَايْنغْ إِسْمحْ أَفُوسْ نّشْ،  
\m أَفُوسْ نّشْ أَفُوسِي؟  
\m \add سُوفُّوغْ إِ-ث\add* زڭْ وحْسِينْ  
\m \add ن ؤُپَارْثسُّو\add* نّشْ،  
\m قْضَا \add خَاسنْ\add*. \f ◼ \fr 74:‏11 \ft \+bd ’أَحْسِينْ‘\+bd* - نِيغْ ’أَبحْرُورْ‘.\f*   
\b  
\m
\v 12 زڭْ وشْحَاڒْ ؤُيَا  
\m أَقَا أَربِّي ذ أَجدْجِيذْ إِنُو.  
\m نتَّا ذ ونِّي إِ د-إِتَّاوْينْ  
\m إِسنْجَامنْ ذِي ڒْوسْثْ ن ثمُّورْثْ.   
\m
\v 13 س ثْزمَّارْ نّشْ ثْفثْقذْ ڒبْحَارْ،  
\m إِزدْجِيفنْ ن ڒْهَايْشَاثْ  
\m ثدّْزذْ إِ-ثنْ خْ وَامَانْ. \x ◘ \xo 74:‏13 \xt ؤُف. 14‏:‏21‏-‏31\x*   
\m
\v 14 شكْ ثْڒبْزذْ إِزدْجِيفنْ ن ’لِيبِييَاثَانْ‘،  
\m ثوْشِيذْ إِ-ث ذ مَاشَّا إِ ڒوْحُوشْ ن ڒخْڒَا. \f ◼ \fr 74:‏14 \ft \+bd ’ڒوْحُوشْ ن ڒخْڒَا‘\+bd* - إِتّْخصَّا أَنغْ أَذْ نْفكَّارْ ذڭْ إِسڒْمَانْ إِمقّْرَاننْ ن ڒبْحَارْ إِنِّي إِشِّينْ ڒْخشْبَاثْ ن إِمِيصْرِييّنْ ثِينِّي إِوْضنْثْ غَارْ ثْمَا ن ڒبْحَارْ ن ؤُغَانِيمْ (خْزَارْ ؤُف. 14‏:30).\f*   
\b  
\m
\v 15 شكْ ثْفدْجْقذْ ڒْعُونْصَارْ ذ ثغْزَارْثْ،  
\m شكْ ثسِّيژْغذْ إِغزْرَانْ إِتَّازّْڒنْ  
\m بْڒَا قطُّو. \x ◘ \xo 74:‏15 \xt ؤُف. 17‏:‏5، 6؛ ڒخْڒ. 20‏:‏11؛ ياش. 3‏:‏13؛ إِزهد. 105‏:‏41؛ إِشا. 48‏:‏21\x*   
\m
\v 16 أَسّْ نّشْ، نّشْ ؤُڒَا ذ دْجِيڒثْ،  
\m شكْ ثڭِّيذْ ذِينْ ثَافَاوْثْ ذ ثْفُوشْثْ. \x ◘ \xo 74:‏16 \xt أَمز. 1‏:‏14‏-‏19\x*   
\m
\v 17 شكْ ثسّْمثْنذْ  
\m مَارَّا إِيْمِيرنْ ن ثمُّورْثْ،  
\m أَنبْذُو ذ ثْڭرْسْثْ  
\m أَقَا ثڭِّيذْ أَسنْ ثِيفْرَاسْ \add نْسنْ\add*.   
\b  
\m
\v 18 عْقڒْ خْ مَانْ أَيَا:  
\m ڒعْذُو إِسّحْقَارْ سِيذِي،  
\m إِجّْ ن ڒْڭنْسْ أَبُوهَاڒِي إِشقّفْ  
\m ذڭْ يِيسمْ نّشْ.   
\m
\v 19 وَارْ تِّيشْ ڒعْمَارْ ن ثجْلِيلّحْثْ نّشْ  
\m إِ ڒوْحُوشْ،  
\m وَارْ ثتُّو إِ ڒبْذَا  
\m ثُوذَارْثْ ن ڒْمُوسَاكِينْ نّشْ.   
\m
\v 20 خْزَارْ غَارْ ڒْعَاهْذْ،  
\m مَاغَارْ \add ذڭْ\add* إِمُوشَانْ ن طّْڒَامْ ذِي ثمُّورْثْ  
\m أَقَا ذَايْسنْ ثُوذْرِينْعمَّارنْثْ س لْعُونْفْ.   
\b  
\m
\v 21 وَارْ تّجِّي ونِّي إِتّْوَاحصَّارنْ  
\m أَذْ د-إِعْقبْ س ؤُسضْحِي،  
\m أجّْ ڒْمسْكِينْ ذ ؤُمزْڒَاضْ  
\m أَذْ صبّْحنْ إِسمْ نّشْ.   
\m
\v 22 كَّارْ بدّْ، \add أَ\add* أَربِّي،  
\m بلّعْ دّعْوثْ نّشْ،  
\m خمّْ مَامّشْ شكْ إِسّحْقَارَانْ  
\m إِبُوهَاڒِييّنْ أَسّْ إِمُونْ.   
\m
\v 23 وَارْ تّتُّو شَا أَغُويِّي ن إِغْرِيمنْ نّشْ،  
\m أَسْبُوعَارْ ن يِينِّي إِ خَاكْ إِغوّْغنْ  
\m إِتّْڭعَّاذْ غَارْ ؤُجنَّا بْڒَا \add أَ\add*قطُّو.   
\b  
\b  
\m  
\c 75
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. ’وَارْ تَّاردّدْجْ!‘ أَزهّذْ ن أَسَافْ. إِزْڒِي.\add*   
\b  
\m
\v 2 نشِّينْ نتّْقَاذَا شكْ،  
\m \add أَ\add* أَربِّي، نتّْقَاذَا!  
\m أَقَا إِسمْ نّشْ يُوذسْ،  
\m أَقَا لْمُوعْجِيزَاثْ نّشْ  
\m سَّاوَاڒنْ \add خْ مَانْ أَيَا\add*.   
\b  
\m
\v 3 مَاغَارْ نشّْ أَذْ خْضَارغْ  
\m ڒْحَاڒْ إِتّْوَاڭّنْ،  
\m أَذْ ڭّغْ شّْرعْ س ڒْحقّْ.   
\m
\v 4 ثَامُّورْثْ أَكْ-ذ مَارَّا إِمزْذَاغْ نّسْ ثفْسِييْ،  
\m مَاشَا نشّْ سّْمتّْنغْ  
\m إِبِيلَارنْ نّسْ. سِيلَاهْ.   
\m
\v 5 نشّْ نِّيغْ إِ إِبُوهَاڒِييّنْ:  
\m ”وَارْ تّڭّْوذمْ شَا!“،  
\m إِ إِعفَّاننْ:  
\m ”وَارْ سّْڭعَّاذمْ إِشّْ \add نْومْ\add*!   
\m
\v 6 وَارْ سّْڭعَّاذمْ إِشّْ نْومْ  
\m \add أَمُّو\add* سنّجْ،  
\m وَارْ سَّاوَاڒمْ س نّْفَاخثْ!“   
\b  
\m
\v 7 مَاغَارْ أَسْڭعّذْ  
\m وَارْ د-إِتَّاسْ زِي شَّارْقْ،  
\m نِيغْ زِي ڒْغَارْبْ ؤُڒَا زِي ڒخْڒَا. \f ◼ \fr 75:‏7 \ft \+bd ’ڒخْڒَا‘\+bd* - أَقَا-ث ذ ڒخْڒَا ن لْجَانُوبْ ونِّي ؤُمِي قَّارنْ ڒخُّو ’نَاقَابْ‘ غَارْ شَّامَالْ ن إِسْرَائِيل.\f*   
\m
\v 8 مَاغَارْ أَربِّي ذ ڒْقَاضِي.  
\m نتَّا إِسّهكّْوَا إِجّنْ  
\m ؤُ إِسّْڭعَّاذْ ونّغْنِي.   
\m
\v 9 مَاغَارْ أَقَا \add ذِينْ\add* إِجّْ ن ڒْكَاسْ  
\m ذڭْ ؤُفُوسْ ن سِيذِي،  
\m بِينُو إِتّڭّْ كُوفُّو، إِتّْوَاخدْجَاضْ مَارَّا.  
\m نتَّا إِتّْكبَّا زَّايسْ.  
\m مَارَّا إِعفَّاننْ ن ثمُّورْثْ  
\m أَذْ ژمّنْ ؤُڒَا ذ ڒخْمِيرَا نّسْ  
\m ؤُمِي \add زَّايسْ\add* إِ غَا سْونْ. \x ◘ \xo 75:‏9 \xt أَسَا. 16‏:‏19\x*   
\b  
\m
\v 10 نشّْ أَذْ \add ث\add* بَارّْحغْ إِ ڒبْذَا قَاعْ،  
\m أَذْ زهّْذغْ إِ أَربِّي ن يَاعْقُوبْ.   
\m
\v 11 نشّْ أَذْ زذْمغْ  
\m مَارَّا أَشَّاونْ ن إِعفَّاننْ،  
\m أَشَّاونْ ن إِمْسڭَّاذنْ  
\m أَذْ تّْوَاسّْڭعّْذنْ.   
\b  
\b  
\m  
\c 76
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. أَكْ-ذ ؤُزنْزُونْ خْ إِفِيڒَانْ.\add* \add أَزهّذْ ن أَسَافْ، إِزْڒِي.\add*   
\b  
\m
\v 2 أَربِّي إِتّْوَاسّنْ ذِي يَاهُوذَا،  
\m إِسمْ نّسْ ذ أَمقّْرَانْ ذِي إِسْرَائِيل.   
\m
\v 3 أَعُوشِّي نّسْ أَقَا-ث ذِي شَالِيمْ،  
\m ثَازذِّيغْثْ نّسْ ذِي صِيهْيُونْ.   
\m
\v 4 ذِينِّي يَارْژَا  
\m فْڒِيثْشَاثْ يَارقّنْ ن ڒْقوْسْ،  
\m ثَاسدَّارْثْ ن ؤُسڒْقِي ذ سِّيفْ  
\m ؤُڒَا ذ أَمنْغِي. سِيلَاهْ.   
\b  
\m
\v 5 ثسَّاڭّْوَاذذْ ؤُ ثْجهْذذْ إِ ثدْجِيذْ  
\m خْ إِذُورَارْ نِّي إِمّژْرنْ ذِي ثْكشَّاضْثْ.   
\m
\v 6 إِنِّي إِزعَّامنْ تّْوَاكشّْضنْ.  
\m نِيثْنِي نُّوذْمنْ، طّْصنْ،  
\m ؤُڒَا ذ إِجّْ زڭْ إِرْيَازنْ إِمحْضنْ  
\m وَارْ إِزمَّارْ أَذْ إِمّْعَاڒَا.   
\m
\v 7 س ؤُودّبْ نّشْ، \add أَ\add* أَربِّي ن يَاعْقُوبْ،  
\m إِغَارْقْ ؤُكَارُّو ذ ؤُيِيسْ ذڭْ يِيضصْ.   
\b  
\m
\v 8 شكْ، \add وَاهْ،\add* شكْ ثسَّاڭّْوَاذذْ،  
\m وِي إِزمَّارنْ أَذْ إِقِّيمْ إِبدّْ  
\m زَّاثْ إِ وُوذمْ نّشْ،  
\m خْمِي د غَا إِكَّارْ وغْضَابْ نّشْ؟   
\m
\v 9 زڭْ ؤُجنَّا ثڭِّيذْ  
\m أَذْ إِتّْوَاسڒْ ڒْحُوكْمْ.  
\m ثطّفْ ثڭّْوُوذِي ثَامُّورْثْ ؤُشَا ثسّغْذْ،   
\m
\v 10 ؤُمِي إِكَّارْ أَربِّي  
\m مَاحنْذْ أَذْ إِشَارّعْ،  
\m حِيمَا أَذْ إِفكّْ  
\m مَارَّا إِمْهِيننْ ن ثمُّورْثْ. سِيلَاهْ.   
\b  
\m
\v 11 مَاغَارْ أَفُوڭمْ ن إِوْذَانْ  
\m أَذْ يَاوِي أَقَاذِي إِ شكْ،  
\m مِينْ إِقِّيمنْ \add عَاذْ\add* ن وسْعَارْ  
\m أَذْ ث ثْمنْعذْ.   
\m
\v 12 وْشمْ لْوُوعُوذْ ؤُ ڭّمْ زَّايْسنْ  
\m زَّاثْ إِ سِيذِي، أَربِّي نْومْ.  
\m أجّْ مَارَّا إِنِّي ذ أَسْ د-إِنّْضنْ  
\m أَذْ أَوْينْ صّْذَاقِي  
\m إِ ونِّي إِتّْخصَّا أَذْ زَّايسْ ڭّْوذنْ،   
\m
\v 13 ونِّي إِمنّْعنْ إِ ڒْحُوكَّامْ  
\m بُوحْبڒَاثْ نْسنْ،  
\m ونِّي زَّايسْ تّڭّْوْذنْ  
\m إِجدْجِيذنْ ن ثمُّورْثْ.   
\b  
\b  
\m  
\c 77
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. سَاذُو ؤُفُوسْ ن يَاذُوثُونْ.\add* \add أَزهّذْ ن أَسَافْ.\add*   
\b  
\m
\v 2 \add نشّْ سّْڭعّْذغْ\add* ثْمِيجَّا إِنُو  
\m غَارْ أَربِّي ؤُشَا ڒَاغِيغْ،  
\m \add سّْڭعّْذغْ\add* ثْمِيجَّا إِنُو غَارْ أَربِّي،  
\m نتَّا أَذْ أَيِي إِسڒْ.   
\m
\v 3 ذڭْ وَاسّْ ن ڒحْصَارثْ إِنُو  
\m أَرْزُوغْ سِيذِي إِنُو.  
\m س دْجِيڒثْ سّْوِيژّْضغْ أَفُوسْ إِنُو  
\m بْڒَا مَا أَذْ أَسْ أَرْخُوغْ،  
\m ڒعْمَارْ إِنُو يُوڭِي أَذْ إِتّْوَاعزَّا.   
\m
\v 4 ؤُمِي ثُوغَا تِّيذَارغْ أَربِّي،  
\m \add خنِّي\add* تّْزهَّارغْ، تّْخمَّامغْ،  
\m \add ؤُشَا\add* يَارْخُو بُوحْبڒْ إِنُو. سِيلَاهْ.   
\b  
\m
\v 5 شكْ ثَارّذْ ثِيطَّاوِينْ إِنُو  
\m أَذْ قِّيمنْثْ فَاقنْثْ،  
\m نّْهوْڒغْ، وَارْ سِّيوْڒغْ.   
\m
\v 6 نشّْ تّْخمَّامغْ  
\m ذڭْ وُوسَّانْ ن وشْحَاڒْ ؤُيَا،  
\m ذڭْ إِسڭّْوُوسَا ن زّْمَانَاثْ \add إِعْذُونْ\add*.   
\m
\v 7 نشّْ تِّيذَارغْ ذڭْ ؤُزنْزُونْ  
\m خْ إِفِيڒَانْ إِنُو س دْجِيڒثْ،  
\m خْمِي تّْخمَّامغْ ذڭْ وُوڒْ إِنُو  
\m ؤُ بُوحْبڒْ إِنُو يَارزُّو:   
\m
\v 8 مَا أَذْ \add أَنغْ\add* إِنْضَارْ سِيذِي إِنُو إِ ڒبْذَا،  
\m وَارْ \add خَافِي\add* إِتّْحِينِّي عَاذْ؟   
\m
\v 9 مَا ثْبدّْ ثْمخْسِيوْثْ نّسْ  
\m إِشوَّارنْ إِ ڒبْذَا؟  
\m مَا إِتّْوَابْضڒْ وَاوَاڒْ  
\m إِ إِدْجَانْ زِي جِّيڒْ إِ جِّيڒْ نّغْنِي  
\m \add أَوَارْنِي أَسْ\add*؟   
\m
\v 10 مَا إِتُّو أَربِّي أَحِينِّي نّسْ؟  
\m مَا ذڭْ وغْضَابْ نّسْ  
\m إِبلّعْ أَرّحْمثْ نّسْ؟“ سِيلَاهْ.   
\b  
\m
\v 11 نِّيغْ: ”وَا ذ ڒعْذَابْ إِنُو،  
\m أَقَا ذ إِسڭّْوُوسَا  
\m زڭْ ؤُفُوسْ ن ؤُمْعُودْجِي خْ كُوڒْشِي.“   
\m
\v 12 نشّْ أَذْ إِذَارغْ ثِيمڭَّا ن سِيذِي،  
\m أَذْعقْڒغْ خْ لْمُوعْجِيزَاثْ نّشْ ن زِيشْ.   
\m
\v 13 نشّْ أَذْ خمَّامغْ  
\m ذِي مَارَّا ڒخْذَايمْ نّشْ،  
\m أَذْ تّْخَارَّاصغْ ذِي مَارَّا مِينْ ثڭِّيذْ.   
\m
\v 14 \add أَ\add* أَربِّي، أَبْرِيذْ نّشْ  
\m أَقَا ذڭْ ؤُقدَّاسْ \add إِ يدْجَا\add*!  
\m مَانْ ونْ \add إِ يدْجَانْ\add*  
\m ذ أَربِّي أَمقّْرَانْ  
\m أَمْ أَربِّي؟   
\m
\v 15 شكْ ذ أَربِّي  
\m نِّي إِتّڭّنْ لْمُوعْجِيزَاثْ،  
\m شكْ ثسّشْنذْ ثِيزمَّارْ نّشْ  
\m جَارْ ڒڭْنُوسْ. \x ◘ \xo 77:‏15 \xt ؤُف. 15‏:‏11\x*   
\m
\v 16 شكْ ثفْذِيذْ ڒْڭنْسْ نّشْ س ؤُغِيڒْ نّشْ،  
\m ثَارْوَا ن يَاعْقُوبْ ذ يُوسُوفْ. سِيلَاهْ.   
\b  
\m
\v 17 أَمَانْ ژْرِينْ شكْ، \add أَ\add* أَربِّي،  
\m أَمَانْ ژْرِينْ شكْ ؤُشَا أَرْجِيجنْ،  
\m \add وَاهْ،\add* \add أَمَانْ\add* إِهوْڒنْ نّْهوْڒنْ. \x ◘ \xo 77:‏17 \xt ؤُف. 14‏:‏21\x*   
\m
\v 18 إِسيْنُوثنْ إِذقّْڒنْ  
\m فَارّْغنْ-د أَمَانْ نْسنْ،  
\m إِبَارُّوثنْ ن إِسيْنُوثنْ  
\m سّْڭعّْذنْ ثْمِيجَّا نْسنْ،  
\m ؤُ فْڒِيثْشَاثْ ن ڒْقوْسْ نّشْ ضْوِينْثْ ذَا ذ ذِيهَا. \f ◼ \fr 77:‏18 \ft \+bd ’سّْڭَاعّْذنْ‘\+bd* - س ثْعِيبْرَانِيثْ ’وْشِينْ‘.\f*  \x ◘ \xo 77:‏18 \xt ؤُف. 14‏:‏24\x*   
\m
\v 19 ثْمِيجَّا نّشْ ثڭَّا  
\m أَمْ وَاجَّاجْ ذِي ثْحَارْيَاضْثْ،  
\m أَسَّامنْ ڭِّينْ ثَافَاوْثْ خْ دُّونشْثْ،  
\m ثَامُّورْثْ ثنْهزّْ ثَارْجِيجْ. `   
\m
\v 20 أَبْرِيذْ نّشْ \add إِشُوقْ\add* ذِي ڒبْحَارْ،  
\m أَمسْرَاقْ نّشْ ذڭْ وَامَانْ إِمقّْرَاننْ،  
\m \add مَاشَا\add* إِصُورَافْ \add ن إِضَارنْ\add* نّشْ  
\m وَارْ بِيننْ \add عَاذْ\add*.   
\b  
\m
\v 21 شكْ ثْنذْهذْ ڒْڭنْسْ نّشْ  
\m أَمْ \add إِشْثْ ن ثْحِيمَارْثْ\add* ن وُودْجِي،  
\m س ؤُفُوسْ ن مُوسَا ذ هَارُونْ. \x ◘ \xo 77:‏21 \xt إِزهد. 78‏:‏52؛ 80‏:‏2\x*   
\b  
\b  
\m  
\c 78
\m
\v 1 \add أَخمِّي ن أَسَافْ.\add*  
\b  
\m \add أَ\add* ڒْڭنْسْ إِنُو، أوْشْ أَمزُّوغْ  
\m إِ شَّارِيعَا إِنُو!  
\m ميّْڒمْ أَمزُّوغْ نْومْ  
\m غَارْ وَاوَاڒنْ ن ؤُقمُّومْ إِنُو.   
\m
\v 2 نشّْ أَذْ أَرْزْمغْ أَقمُّونْ إِنُو  
\m س وَاوَاڒْ إِوزْننْ،  
\m أَذْ بَارّْحغْ ڒمْعَانِي إِنُّوفَّارنْ  
\m زڭْ وشْحَاڒْ ؤُيَا، \x ◘ \xo 78:‏2 \xt إِزهد. 49‏:‏5؛ مت. 13‏:‏35\x*   
\m
\v 3 \add ثِيمسْڒَايِينْ\add* نِّي نسْڒَا ؤُ نسّنْ،  
\m نِّي ذ أَنغْ حَاجَانْ ڒجْذُوذْ نّغْ.   
\m
\v 4 وَارْ ثنْ نتّفَّارْ زڭْ إِحنْجِيرنْ نْسنْ،  
\m زِي جِّيڒْ إِ د غَا يَاسنْ.  
\m أَذْ نْبَارّحْ س ثْمڭَّا إِصبّْحنْ ن سِيذِي،  
\m س ثْمڭَّا نّسْ إِجهْذنْ  
\m ذ لْمُوعْجِيزَاثْ نّسْ نِّي ثُوغَا إِڭَّا.   
\b  
\m
\v 5 مَاغَارْ نتَّا إِڭَّا إِشْثْ ن شّْهَاذثْ  
\m ذِي يَاعْقُوبْ،  
\m إِسَّارْسْ إِشْثْ ن شَّارِيعَا ذِي إِسْرَائِيل،  
\m نِّي ثُوغَا يُومُورْ إِ ڒجْذُوذْ نّغْ،  
\m مَاحنْذْ أَذْ ت سّْغَارنْ إِ إِحنْجِيرنْ نْسنْ، \x ◘ \xo 78:‏5 \xt أَعَوذ. 4‏:‏9؛ 6‏:‏7\x*   
\m
\v 6 مَاحنْذْ جِّيڒْ إِ د غَا يَاسنْ أَذْ إِسّنْ،  
\m إِحنْجِيرنْ نِّي د غَا إِتّْوَاخڒْقنْ  
\m \add أَوَارْنِي أَسنْ\add*،  
\m ؤُ \add خنِّي\add* ؤُڒَا ذ نِيثْنِي أَذْ كَّارنْ  
\m أَذْ ت سّعْذُونْ إِ إِحنْجِيرنْ نْسنْ،   
\m
\v 7 \add مَاحنْذْ\add* نِيثْنِي أَذْ سَّارْسنْ  
\m ڒَْامَانْ نْسنْ خْ أَربِّي،  
\m وَارْ تّتُّونْ شَا ثِيمڭَّا ن أَربِّي،  
\m \add مَاشَا\add* أَذْ حْضَانْ ثِيوصَّا نّسْ،   
\m
\v 8 وَارْ تِّيڒِينْ أَمْ ڒجْذُوذْ نْسنْ،  
\m إِجّْ ن جِّيڒْ أَغنَّانْ ذ إِغوّْغنْ،  
\m إِجّْ ن جِّيڒْ س وُوڒْ وَارْ إِمْثنْ  
\m ؤُ س أَرُّوحْ إِغْذَارنْ أَربِّي. \x ◘ \xo 78:‏8 \xt ؤُف. 32‏:‏9؛ 33‏:‏3، 5؛ 34‏:‏9؛ أَعَوذ. 9‏:‏6، 13؛ 31‏:‏27\x*   
\m
\v 9 أَيْثْ ن إِفْرَايِيمْ، إِمْجبَّاذنْ نْ ڒْقوْسْ،  
\m عقْبنْ ذڭْ وَاسّْ ن ؤُمنْغِي.   
\m
\v 10 وَارْ حْضَانْ ڒْعَاهْذْ أَكْ-ذ أَربِّي،  
\m ؤُڭِينْ أَذْ ؤُيُورنْ ذِي شَّارِيعَا نّسْ.   
\m
\v 11 تُّونْ ثِيمڭَّا نّسْ ذ لْمُوعْجِيزَاثْ،  
\m ثِينِّي إِ ذ أَسنْ إِسّْشنْ.   
\b  
\m
\v 12 زَّاثْ إِ \add ثِيطَّاوِينْ ن\add* ڒجْذُوذْ نْسنْ  
\m إِڭَّا نتَّا إِشْثْ ن لْمُوعْجِيزَا،  
\m ذِي ثمُّورْثْ ن مِيصْرَا،  
\m ذڭْ إِيَّارْ ن صُوعَانْ.   
\m
\v 13 نتَّا إِبْضَا ڒبْحَارْ  
\m ؤُشَا إِسّژْوَا ثنْ زَّايسْ،  
\m إِجَّا أَمَانْ أَذْ بدّنْ أَمْ وغْبَارْ. \x ◘ \xo 78:‏13 \xt ؤُف. 14‏:‏21\x*   
\m
\v 14 نتَّا إِسّْقبّضْ إِ-ثنْ س وَاسّْ  
\m س ؤُسيْنُو،  
\m س دْجِيڒثْ مَارَّا س ثْفَاوْثْ ن ثْمسِّي. \x ◘ \xo 78:‏14 \xt ؤُف. 13‏:‏21؛ إِزهد. 105‏:‏39\x*   
\m
\v 15 نتَّا إِبْضَا ڒجْرُوفْ ذِي ڒخْڒَا،  
\m إِوْشَا إِ ڒْڭنْسْ أَذْ إِسُو س ؤُفيّضْ  
\m أَمشْنَاوْ زڭْ \add وَامَانْ\add* إِهوْڒنْ. \x ◘ \xo 78:‏15 \xt ؤُف. 17‏:‏6؛ ڒخْڒ. 20‏:‏11؛ إِزهد. 105‏:‏41؛ 1 كُور. 10‏:‏4\x*   
\m
\v 16 نتَّا إِجَّا ڒْعُونْصَارَاثْ  
\m أَذْ فيّْضنْثْ زِي سّدْجَاحْ،  
\m نتَّا إِجَّا أَمَانْ  
\m أَذْ هْوَانْ أَمْ يِيغزْرَانْ.   
\b  
\m
\v 17 مَاشَا نِيثْنِي أَرْنِينْ  
\m ذِي دّْنُوبْ نْسنْ خَاسْ،  
\m غوّْغنْ خْ ؤُمْعُودْجِي خْ كُوڒْشِي  
\m \add ؤُمِي ثُوغَا أَثنْ\add* ذِي ثْنزْرُوفْثْ يُوژْغنْ.   
\m
\v 18 نِيثْنِي جَارّْبنْ أَربِّي  
\m ذڭْ وُوڒْ نْسنْ  
\m ؤُمِي تَّارنْ مَاشَّا  
\m غَارْ \add مژْرِي ن\add* ڒعْمَارْ نْسنْ.   
\m
\v 19 سِّيوْڒنْ ضِيدّْ إِ أَربِّي، نَّانْ:  
\m ”مَا إِزمَّارْ أَربِّي  
\m أَذْ إِسّوْجذْ طَّابْڒَا ذِي ڒخْڒَا؟ \x ◘ \xo 78:‏19 \xt ڒخْڒ. 11‏:‏1، 4\x*   
\m
\v 20 خْزَارْ، نتَّا إِوْثَا ذِي ثصْضَارْثْ،  
\m \add أَڒَامِي\add* د-ؤُزّْڒنْ \add زَّايسْ\add*  
\m وَامَانْ ذ إِغزْرَانْ.  
\m مَا إِزمَّارْ نتَّا أَذْ إِوْشْ أَغْرُومْ  
\m نِيغْ إِسّوْجذْ أَيْسُومْ إِ ڒْڭنْسْ نّسْ؟“ \x ◘ \xo 78:‏20 \xt ؤُف. 17‏:‏6؛ ڒخْڒ. 20‏:‏11\x*   
\b  
\m
\v 21 س ؤُيَا إِسْڒَا سِيذِي ؤُشَا إِفُّوڭمْ.  
\m ثِيمسِّي ثَارْغَا ضِيدّْ إِ يَاعْقُوبْ،  
\m إِكَّارْ-د وغْضَابْ نّسْ ضِيدّْ إِ إِسْرَائِيل، \x ◘ \xo 78:‏21 \xt ڒخْڒ. 11\x*   
\m
\v 22 مَاغَارْ وَارْ ؤُمِينمْ شَا ذِي أَربِّي،  
\m وَارْ تّْشِيڒِينْ ذڭْ ؤُسنْجمْ نّسْ.   
\m
\v 23 نتَّا يُومُورْ إِسيْنُوثنْ سنّجْ  
\m ؤُ يَارْزمْ ثِيوُّورَا ن ؤُجنَّا.   
\m
\v 24 إِفَارّغْ-د خَاسنْ ’مَانَّا‘  
\m مَاحنْذْ أَذْ شّنْ،  
\m إِوْشَا أَسنْ إِمنْذِي زڭْ ؤُجنَّا. \x ◘ \xo 78:‏24 \xt ؤُف. 16‏:‏14\x*   
\m
\v 25 مَارَّا شِّينْ أَغْرُومْ  
\m ن يِينِّي ذَايْسنْ ڒْعزّْ.  
\m إِسّكّْ أَسنْ مَاشَّا نْسنْ غَارْ وبْرِيذْ  
\m أَڒَامِي جِّيوْننْ. \f ◼ \fr 78:‏25 \ft \+bd ’أَغْرُومْ ن ينِّي ذَايْسنْ ڒْعزّْ‘\+bd* - تّرْجَامَا ثَايُونَانِيثْ ن ڒْعَاهْذْ أَقْذِيمْ زِي عْڒَاينْ مِيثَايْنْ ؤُ خمْسِينْ إِسڭّْوُوسَا قْبڒْ لْمَاسِيحْ، قَّارنْ أَسْ سِيبْثُووَاخِينْثَا (لْخّْ)، ثقَّارْ ’أَغْرُومْ ن لْمَالَاكَاثْ‘ مِينْزِي ’مَانَّا‘ ثُوغَا-ث زڭْ ؤُجنَّا مَانِي زدّْغنْ لْمَالَاكَاثْ.\f*  \x ◘ \xo 78:‏25 \xt يُوح. 6‏:‏31؛ 1 كُور. 10‏:‏3\x*   
\b  
\m
\v 26 نتَّا إِڭَّا أَسمِّيضْ  
\m ن مَانِيسْ د-ثْنقَّارْ ثْفُوشْثْ  
\m أَذْ إِكَّارْ ذڭْ ؤُجنَّا،  
\m س ثْزمَّارْ نّسْ إِسّكّْ-د  
\m أَسمِّيضْ ن لْجَانُوبْ. \x ◘ \xo 78:‏26 \xt ڒخْڒ. 11‏:‏31\x*   
\m
\v 27 إِجَّا أَيْسُومْ أَذْ خَاسنْ د-إِوْضَا  
\m أَمْ \add ونْژَارْ ن\add* ثْعجَّاجْثْ،  
\m إِجْضَاضْ س وَافْرِيونْ أَمْ يِيجْذِي نْ ڒبْحُورْ.   
\m
\v 28 نتَّا إِجَّا إِ-ثنْ أَذْ وْضَانْ  
\m ذِي ڒْوسْثْ ن ڒْمَارْڭحْ ن ڒْعسْكَارْ،  
\m غَارْ مَارَّا إِغزْذِيسنْ ن ثْزذِّيغِينْ نْسنْ.   
\m
\v 29 نِيثْنِي شِّينْ ؤُ جِّيوْننْ قَاعْ،  
\m كْسِينْ مِينْ ذِي ثُوغَا ضمْعنْ.   
\b  
\m
\v 30 نِيثْنِي ثُوغَا عَاذْ وَارْ تّْوَافكّنْ  
\m زڭْ وضْمَاعْ نْسنْ،  
\m مَاشَّا ثُوغَا عَاذْ ذڭْ ؤُقمُّومْ نْسنْ،   
\m
\v 31 \add ؤُمِي\add* خَاسنْ إِكَّارْ وغْضَابْ ن أَربِّي.  
\m نتَّا إِنْغَا إِنِّي إِدْجَانْ  
\m ذ إِقبُّوزنْ قَاعْ جَارْ أَسنْ،  
\m يَارَّا-د إِحُوذْرِييّنْ ن إِسْرَائِيل  
\m أَذْ أَضَارنْ \add غَارْ ثْعجَّاجْثْ ن ثمُّورْثْ\add*. \x ◘ \xo 78:‏31 \xt ڒخْڒ. 11‏:‏33؛ 1 كُور. 10‏:‏5\x*   
\m
\v 32 \add مَاشَا\add* قَاعْ أَمنِّي أَرْنِينْ ڭِّينْ دّْنُوبْ،  
\m وَارْ ؤُمِيننْ ذِي لْمُوعْجِيزَاثْ نّسْ.   
\m
\v 33 نتَّا إِجَّا ؤُسَّانْ نْسنْ  
\m أَذْ عْذُونْ أَمْ يِيجّْ ن ڒفْوَارْ،  
\m إِسڭّْوُوسَا نْسنْ أَمْ يِيشْثْ ن ڒْعُورّثْ.   
\b  
\m
\v 34 خْمِي ثنْ إِ غَا إِنغْ، أَرْزُونْ خْ أَربِّي،  
\m ذوْڒنْ-د غَارسْ، أَرْزُونْ خَاسْ س شْضَارثْ.   
\m
\v 35 نِيثْنِيعقْڒنْ  
\m أَقَا أَربِّي ذ ثَاصْضَارْثْ نْسنْ،  
\m أَربِّي، أَمْعُودْجِي خْ كُوڒْشِي،  
\m ذ أَمفْذِي نْسنْ. \f ◼ \fr 78:‏35 \ft \+fk أَمفْذِي\ft  - إِجّْ ن بْنَاذمْ نِّي إِفْذِينْ نِيغْ إِفكّنْ إِجّْ ن إِسْمغْ نِيغْ إِشْثْ ن ثسْمغْثْ، نِيغْ إِجّْ ن بْنَاذمْ ذَايسْ أَمَارْوَاسْ، نِيغْ إِشْثْ ن ثمُّورْثْ عْلَاحْسَابْ ڒْقَانُونْ، أَقَا نتَّا أَذْ إِخدْجسْ تَّامَانْ إِ غَا إِڒِيقّنْ إِسْمغْ نِّي، نِيغْ أَذْ إِخدْجصْ أَمَارْوَاسْ إِ إِتّْخصَّا نِيغْ تَّامَانْ ن ثمُّورْثْ نِّي نِيغْ صَّاذَاقْ إِ ثمْغَارْثْ أَمْ مَامّشْ إِ ذ أَسْ إِشُووَّارْ. س ؤُينِّي أَمفْذِي وَارْ إِتّْفكِّي أَمنِّي وَاهَا مَاشَا نتَّا ذ إِجّْ ونِّي إِفكّنْ خْ ڒحْسَابْ ڒْقَانُونْ، وَارْ إِفكّْ بْڒَا مَا أَذْ إِخدْجصْ تَّامَانْ نِيغْ ثَامسْڒَاشْثْ إِ ذ أَسْ إِتّْخصَّا أَذْ ت إِوْشْ. ذ مَانْ أَيَا إِ إِشُووَّارْ أَذْ ث نسّنْ خْ وَاوَاڒْ ’أَمفْذِي‘ ؤُ خْ وَاوَاڒنْ إِ غَارسْ د-إِقّْننْ أَمْ: ’إِفْذِي‘، ’أَذْ إِفْذِي‘، نِيغْ ’أَذْ إِفْذِي كُورْ أَسڭّْوَاسْ إِجّْ ن وزْينْ ن ييَّارْ نّسْ‘، ؤُ مَامّشْ نّغْنِي. سْ ؤُينِّي يشُّو لْمَاسِيحْ ذ أَمفْذِي إِ إِدْجْ إِ مَارَّا إِوْذَانْ مِينْزِي نتَّا إِوْشَا ثُوذَارْثْ نّسْ ذِي طّْوعْ نّغْ أَمُّو إِ خَانغْ إِفْذِي س إِذَامّنْ نّسْ إِزْذِيڭنْ إِقدّْسنْ، ؤُ أَمُّو إِ غَا إِفْذِي إِسْرَائِيل (’مَارَّا ؤُذَاينْ إِنِّي إِ غَا يَامْننْ ذڭْ يِيسمْ نّسْ‘) ذ ثمُّورْثْ أَكِيذسْ خْمِي د غَا يَاسْ إِ ثْوَاڒَا وِيسّْ ثْنَاينْ ذڭْ ؤُنڭَّارْ ن وُوسَّانْ. مَاشَا شِّيطَانْ وَارْ إِدْجِي أَمنِّي. نتَّا إِتّڭّْ أَمْ ؤُشفَّارْ أَمْ ؤُخْشِينْ ؤُ أَمْ ؤُغصَّابْ. وَارْ ذ أَسْ إِتّْهِيمِّي ڒْخَارْ ن بْنَاذمْ مَاشَا مْغِيرْ شَّانْ ن يِيخفْ نّسْ، حِيمَا مَارَّا إِوْذَانْ أَذْ ثعبْذنْ ؤُمِي ثنْ إِسِّيڭّْوجْ خْ أَربِّي إِدَّارنْ س إِخَارِّيقنْ نّسْ ذ ثْسحَّارْثْ نّسْ (خْژَارْ يُوح. 10).\f*   
\m
\v 36 مَاشَا نِيثْنِي سّْنِيعْمِيڒنْ زَّاثسْ  
\m س ؤُقمُّومْ نْسنْ،  
\m س يِيڒسْ نْسنْ سّْخَارِّيقنْ خَاسْ.   
\m
\v 37 وَارْ ثُوغِي ؤُڒْ نْسنْ إِمْثنْ أَكِيذسْ،  
\m وَارْ ؤُيُورنْ س ڒْمَانثْ  
\m أَكْ-ذ ڒْعَاهْذْ نّسْ.   
\b  
\m
\v 38 نتَّا \add مَاشَا\add* ثُوغَا يَارحّمْ \add ذَايْسنْ\add*  
\m ؤُ إِسّصْڒحْ خْ ڒْمُوعْصِييّثْ نّغْ،  
\m وَارْ يَاردّدْجْ، مَاشَا أَطَّاسْ ن ثْوَاڒَاوِينْ  
\m إِجَّا زڭْ وغْضَابْ نّسْ  
\m ؤُ وَارْ إِڭِّي مَارَّا أَسْعَارْ نّسْ أَذْ إِكَّارْ.   
\m
\v 39 نتَّا إِعْقڒْ أَقَا نِيثْنِي  
\m مْغِيرْ ذ أَيْسُومْ وَاهَا،  
\m ذ إِجّْ ن ؤُسمِّيضْ إِعدُّو  
\m وَارْ د-إِتّْعِيقِّيبْ.   
\m
\v 40 مشْحَاڒْ ن ثْوَاڒَاوِينْ  
\m سْعَارنْ ث ذِي ڒخْڒَا،  
\m ڭِّينْ أَسْ ڒحْرِيقْ ذِي ثْنزْرُوفْثْ!   
\b  
\m
\v 41 ثْوَاڒَا أَوَارْنِي ثنّغْنِيثْ  
\m قدْجْبنْ أَربِّي،  
\m ڭِّينْ ڒحْرِيقْ إِ ؤُمْقدَّاسْ ن إِسْرَائِيل.   
\m
\v 42 وَارْ خَارّْصنْ شَا عَاذْ ذڭْ ؤُفُوسْ نّسْ،  
\m ذڭْ وَاسّْ نِّي ڒَامِي ثنْ إِفْذَا  
\m \add زڭْ ؤُفُوسْ\add* ن ونِّي إِ-ثنْ إِحْصَارنْ، \f ◼ \fr 78:‏42 \ft \+bd ’إِفْذَا‘\+bd* - خْزَارْ ’أَمفْذِي‘ - إِزهد. 78‏:35.\f*   
\m
\v 43 أَڒَامِي إِڭَّا ڒعْڒَامَاثْ ذِي مِيصْرَا،  
\m ؤُڒَا ذ لْمُوعْجِيزَاثْ نّسْ ذڭْ إِيَّارْ ن صُوعَانْ،   
\m
\v 44 \add أَڒَامِي\add* إِڭَّا إِغزْرَانْ نْسنْ  
\m أَذْ ذوْڒنْ ذ إِذَامّنْ،  
\m ؤُڒَا ذ مَارَّا ڒْعُونْصَارَاثْ نْسنْ،  
\m حِيمَا نِيثْنِي وَارْ زمَّارنْ  
\m أَذْ \add زَّايْسنْ\add* سْونْ عَاذْ. \x ◘ \xo 78:‏44 \xt ؤُف. 7‏:‏20؛ أَسَا. 16‏:‏4\x*   
\b  
\m
\v 45 إِسّكّْ جَارْ أَسنْ  
\m إِجّْ ن ويْڒَافْ ن إِبعَّاشْ إِ ثنْ إِشّنْ،  
\m ؤُڒَا ذ إِقَارْقْرِيونْ نِّي ثنْ إِثحَّانْ. \x ◘ \xo 78:‏45 \xt ؤُف. 8‏:‏2، 20\x*   
\m
\v 46 نتَّا إِوْشَا ڒْغِيدْجثْ نْسنْ  
\m إِ ثْمُوغْرِي إِصَارّْضنْ،  
\m ؤُڒَا ذ صَّابثْ نْسنْ إِ ثْمُوغْرِي. \x ◘ \xo 78:‏46 \xt ؤُف. 10‏:‏13\x*   
\m
\v 47 إِنْغَا ثَازَايَارْثْ نْسنْ س ثبْرُورِّي،  
\m ؤُڒَا ذ إِزمُّورنْ نْسنْ س ثْكضْفِينْ. \x ◘ \xo 78:‏47 \xt ؤُف. 9‏:‏23\x*   
\m
\v 48 نتَّا إِجَّا ڒْمَاڒْ نْسنْ إِ ؤُبْرُورِي،  
\m ثِيحِيمْرِيوِينْ نْسنْ إِ وَاسَّامنْ.   
\b  
\m
\v 49 نتَّا إِسّكّْ ڒْحَاذُوقْ ن وغْضَابْ نّسْ  
\m جَارْ أَسنْ،  
\m أَمُوزَّارْ ذ ثفْقحْثْ ذ ڒْحصْرَانْ،  
\m ؤُمِي د-إِسّكّْ لْمَالَاكَاثْ س جّْرَايحْ.   
\m
\v 50 نتَّا إِسڭّمْ إِجّْ ن ؤُمسْرَاقْ  
\m إِ وغْضَابْ نّسْ،  
\m وَارْ إِسّْعِيزّْ خْ ڒعْمَارْ نْسنْ زِي ڒْموْثْ،  
\m إِسّعْذُو ڒْمَاڒْ نْسنْ إِ طَّاعُونْ. \x ◘ \xo 78:‏50 \xt ؤُف. 9‏:‏6\x*   
\m
\v 51 نتَّا إِنْغَا مَارَّا إِمنْزَا ذِي مِيصْرَا،  
\m إِمنْزَا ن يرْيَازنْ ذَايْسنْ ثرْيَاسْثْ  
\m ذڭْ إِقِيضَانْ ن حَامْ. \x ◘ \xo 78:‏51 \xt ؤُف. 12‏:‏29؛ إِزهد. 105‏:‏36\x*   
\b  
\m
\v 52 إِڭَّا ڒْڭنْسْ نّسْ أَذْ إِسّْڭعّذْ أَمْ وُودْجِي،  
\m إِسّْقبّضْ إِ-ثنْ  
\m أَمْ يِيشْثْ ن ثْحِيمَارْثْ ذِي ڒخْڒَا.   
\m
\v 53 إِنْذهْ إِ-ثنْ ذِي ڒَامَانْ،  
\m وَارْ ڭّْوِيذنْ وَالُو،  
\m مَاغَارْ ڒبْحَارْ إِذْڒَا ڒْعذْيَانْ نْسنْ. \x ◘ \xo 78:‏53 \xt ؤُف. 14‏:‏27، 28؛ 15‏:‏10\x*   
\m
\v 54 إِوْيِي ثنْ غَارْ ثمُّورْثْ نّسْ إِقدّْسنْ،  
\m غَارْ وذْرَارْ-أَ نِّي ذ إِكْسبْ ؤُفُوسْ أَفُوسِي نّسْ.   
\m
\v 55 إِسُّوفّغْ ڒڭْنُوسْ زَّاثْ إِ وُوذمْ نْسنْ،  
\m إِڭَّا أَذْ أَسنْ د-ثكَّارْ ثسْغَارْثْ نْسنْ  
\m س ؤُفِيڒُو \add ن ڒعْبَارْ\add*،  
\m ؤُشَا إِسّزْذغْ ثِيقبَّاڒْ ن إِسْرَائِيل  
\m ذڭْ إِقِيضَانْ نْسنْ. \x ◘ \xo 78:‏55 \xt ياش. 13‏:‏7؛ إِزهد. 136‏:‏21، 22\x*   
\b  
\m
\v 56 \add مَاشَا\add* نِيثْنِي قدْجْبنْ ث، سْعَارنْ أَربِّي،  
\m أَمْعُودْجِي خْ كُوڒْشِي،  
\m وَارْ هْضِينْ شّْهَاذَاثْ نّسْ.   
\m
\v 57 نِيثْنِي ذوْڒنْ غَارْ ضفَّارْ،  
\m ڭِّينْ س ڒغْذَارْ أَمْ ڒجْذُوذْ نْسنْ.  
\m نِيثْنِي ودَّارنْ  
\m أَمْ يِيشْثْ ن فْڒِيثْشَا ن ڒْقوْسْ  
\m إِ إِثفّْغنْ س ڒخْذعْ.   
\m
\v 58 سْعَارنْ ث س ڒڭْعُوذِي نْسنْ  
\m \add إِ خْ وهّْبنْ ثِيغَارْصَا\add*،  
\m أَرِّينْ ث أَذْ يَاسمْ  
\m س ڒخْيَاڒَاثْ نْسنْ إِنقْشنْ \x ◘ \xo 78:‏58 \xt أَعَوذ. 32‏:‏16، 21\x*   
\m
\v 59 أَربِّي إِسْڒَا مَانْ أَيَا  
\m ؤُشَا إِتّْوَاسَّارْغْ وغْضَابْ نّسْ،  
\m إِذْوڒْ إِعِيفّْ أَطَّاسْ زِي إِسْرَائِيل.   
\b  
\m
\v 60 نتَّا إِجَّا ثَازذِّيغْثْ نّسْ ذِي شِيلُو،  
\m أَقِيضُونْ مَانِي ثُوغَا إِزدّغْ جَارْ إِوْذَانْ. \x ◘ \xo 78:‏60 \xt إِرْم. 7‏:‏14\x*   
\m
\v 61 نتَّا يَارَّا جّهْذْ نّسْ  
\m غَارْ ثْمحْبَاسْثْ،  
\m ؤُڒَا ذ ثَالْوِيزْثْ نّسْ  
\m غَارْ ؤُفُوسْ ن ونِّي ث إِحصَّارنْ. \x ◘ \xo 78:‏61 \xt 1 صم. 4‏:‏10، 11\x*   
\m
\v 62 نتَّا إِسلّمْ ڒْڭنْسْ نّسْ إِ سِّيفْ،  
\m يَارْغَا وغْضَابْ نّسْ خْ ثسْغَارْثْ نّسْ.   
\m
\v 63 ثِيمسِّي ثشَّا إِحُوذْرِييّنْ نْسنْ،  
\m ثِيعْزَارِييِّينْ نْسنْ  
\m وَارْ خَاسنْثْ د-إِوْينْ إِغنِّيجنْ.   
\m
\v 64 إِكهَّاننْ نْسنْ وْضَانْ س سِّيفْ  
\m ؤُ ثِيجَّاڒْ نْسنْ وَارْ رُونْثْ شَا. \x ◘ \xo 78:‏64 \xt 1 صم. 4‏:‏11، 18، 19\x*   
\b  
\m
\v 65 \add خنِّي\add* إِفَاقْ-د سِيذِي إِنُو  
\m أَمْ شَا ن إِجّْ إِ ثُوغَا إِطّْصنْ،  
\m أَمْ يِيجّْ ن بُو-ثغْرُوضْثْ  
\m نِّي إِسْغُويُّو زِي بِينُو.   
\m
\v 66 نتَّا إِوْثَا إِنِّي ث إِحصَّارنْ  
\m غَارْ ضفَّارْ،  
\m إِڭَّا ذَايْسنْ ڒفْضِيحثْ إِ ڒبْذَا. \x ◘ \xo 78:‏66 \xt 1 صم. 5‏:‏6؛ 6‏:‏4\x*   
\m
\v 67 أَقِيضُونْ ن يُوسُوفْ إِنْضَارْ إِ-ث،  
\m ثَاقْبِيتْشْ ن إِفْرَايِيمْ وَارْ ت إِفَارْزْ.   
\m
\v 68 إِفَارْزْ ثَاقْبِيتْشْ ن يَاهُوذَا،  
\m أَذْرَارْ ن صِيهْيُونْ ونِّي ثُوغَا إِتّخْسْ.   
\b  
\m
\v 69 إِبْنَا زَّاوشْثْ نّسْ إِقدّْسنْ  
\m أَمْ \add إِجنْوَانْ\add* يُوعْڒَانْ،  
\m أَمْ ثمُّورْثْ نِّي إِسّمْثنْ إِ ڒبْذَا.   
\m
\v 70 إِفَارْزْ أَمْسخَّارْ نّسْ ذَاوُوذْ،  
\m إِكْسِي ث زِي ڒْكُورِيثْ ن وُودْجِي. \x ◘ \xo 78:‏70 \xt 1 صم. 16‏:‏11؛ 2 صم. 7‏:‏8\x*   
\m
\v 71 إِجَّا إِ-ث أَذْ د-يَاسْ  
\m زِي غَارْ ضفَّارْ ن وُودْجِي،  
\m مَاحنْذْ أَذْ يَارْوسْ يَاعْقُوبْ،  
\m ڒْڭنْسْ نّسْ،  
\m ؤُڒَا ذ إِسْرَائِيل، ڒْوَارْثْ نّسْ. \x ◘ \xo 78:‏71 \xt 2 صم. 5‏:‏2؛ 1 إِم. 11‏:‏2\x*   
\m
\v 72 نتَّا يَارْوسْ إِ-ثنْ  
\m عْلَاحْسَابْ ڒصْفَايثْ ن وُوڒْ نّسْ،  
\m إِڭوّذْ إِ-ثنْ س ؤُفُوسْ إِزمَّارنْ.   
\b  
\b  
\m  
\c 79
\m
\v 1 \add أَزهّذْ ن أَسَافْ.\add*  
\b  
\m \add أَ\add* أَربِّي، ڒڭْنُوسْ ؤُذْفنْ  
\m غَارْ ڒْوَارْثْ نّشْ.  
\m نِيثْنِي سّْخمْجنْ  
\m زَّاوشْثْ نّشْ ثَامقّْرَانْثْ إِقدّْسنْ،  
\m أَرِّينْ ؤُرْشَالِيمْ ذ ڒْخِيرْبَاثْ.   
\m
\v 2 ڒْخشْبَاثْ ن إِمْسخَّارنْ نّشْ  
\m وْشِينْ ثنْثْ ذ مَاشَّا إِ إِجْضَاضْ ن ؤُجنَّا،  
\m أَيْسُومْ ن إِمْثِيقَّانْ نّشْ  
\m إِ ڒوْحُوشْ ن ثمُّورْثْ.   
\m
\v 3 إِذَامّنْ نْسنْ زدْجْعنْ ثنْ  
\m أَمْ وَامَانْ  
\m غَارْ مَارَّا إِغزْذِيسنْ ن ؤُرْشَالِيمْ،  
\m ؤُڒَا ذ إِجّْ وَارْ \add ثنْ\add* إِنْضِيڒْ.   
\m
\v 4 نذْوڒْ ذ ڒفْذِيحثْ إِ جِّيرَانْ نّغْ،  
\m ذ ؤُسْثهْزِي ذ ؤُسحْقَارْ  
\m إِ مَارَّا إِنِّي ذ أَنغْ د-إِنّْضنْ. \x ◘ \xo 79:‏4 \xt إِزهد. 44‏:‏14؛ 80‏:‏7\x*   
\b  
\m
\v 5 أَرْ مڒْمِي، \add أَ\add* سِيذِي؟  
\m مَا \add خنِّي\add* أَذْ ثقِّيمذْ  
\m ثْسعَّارذْ إِ ڒبْذَا؟  
\m \add مَا\add* أَذْ ثَارغْ ثُوسْمِي نّشْ \add إِقدّْسنْ\add*  
\m أَمْ ثْمسِّي \add إِ ڒبْذَا\add*؟ \x ◘ \xo 79:‏5 \xt إِزهد. 89‏:‏47\x*   
\m
\v 6 فَارّغْ أَسْعَارْ نّشْ  
\m خْ ڒڭْنُوسْ إِ وَارْ شكْ إِسِّيننْ،  
\m خْ ثِيڭلْذِيوِينْ نِّي وَارْ إِتّْڒِيغِينْ  
\m خْ يِيسمْ نّشْ. \x ◘ \xo 79:‏6 \xt إِرْم. 10‏:‏25\x*   
\m
\v 7 مَاغَارْ نِيثْنِي شِّينْ يَاعْقُوبْ،  
\m أَردّْدْجنْ ثَازذِّيغْثْ نّسْ.   
\m
\v 8 وَارْ خَانغْعقّڒْ  
\m عْلَاحْسَابْ ڒْمُوعْصِييّثْ نّغْ ن زِيشْ.  
\m قدْجقْ، أجّْ أَرّحْمثْ نّشْ  
\m أَذْ كِيذْنغْ ثمْسَاڭَارْ،  
\m مَاغَارْ نضْعفْ أَطَّاسْ. \x ◘ \xo 79:‏8 \xt إِشا. 64‏:‏8 \x*   
\b  
\m
\v 9 أوْشْ أَنغْ أَفُوسْ نّشْ، \add أَ\add* أَربِّي،  
\m ذِي طّْوعْ ن ؤُعُودْجِي ن يِيسمْ نّشْ،  
\m فكّْ أَنغْ ؤُ سصْڒحْ خْ دّْنُوبْ نّغْ  
\m ذِي طّْوعْ ن يِيسمْ نّشْ.   
\m
\v 10 مَايمِّي غَا إِنِينْ ڒڭْنُوسْ:  
\m ”مَانِي إِدْجَا أَربِّي نْسنْ؟“  
\m أجّْ أَنْثَاقمْ ن إِذَامّنْ  
\m إِتّْوَاسِّيزْڒنْ ن ڒْڭنْسْ نّشْ  
\m أَذْ إِذْوڒْ إِتّْوَاسّنْ  
\m جَارْ ڒڭْنُوسْ جَارْ ثِيطَّاوِينْ نّغْ.   
\m
\v 11 أجّْ أَزهَّارْ ن ؤُمحْبُوسْ أَذْ د-يَاسْ  
\m زَّاثْ إِ وُوذمْ نّشْ،  
\m حْضَا إِحنْجِيرنْ ن ڒْموْثْ  
\m عْلَاحْسَابْ ڒمْغَارثْ ن ؤُغِيڒْ نّشْ.   
\m
\v 12 أَرّْ أَسنْ إِ جِّيرَانْ نّغْ أَبهْذڒْ نْسنْ  
\m سبْعَا ن ثْسقَّارْ غَارْ وحْسِينْ نْسنْ،  
\m \add أَبهْذڒْ نْسنْ\add* إِ زِي شكْ فضْحنْ،  
\m \add أَ\add* سِيذِي إِنُو.   
\b  
\m
\v 13 نشِّينْ ذ ڒْڭنْسْ نّشْ  
\m ذ وُودْجِي ن دّْمَانِي ن ثَاروْسَا نّشْ.  
\m نتّْقَاذَا شكْ إِ ڒبْذَا،  
\m زِي جِّيڒْ أَڒْ جِّيڒْ.  
\m نشِّينْ أَذْ نْبَارّحْ شَّانْ نّشْ.   
\b  
\b  
\m  
\c 80
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ.\add*  
\m \add س ثغْنِينْثْ ن ’ثْلِيلِّيشِينْ‘.\add*  
\m \add شّْهَاذثْ ن أَسَافْ. أَزهّذْ.\add*\f ◼ \fr 80:‏1 \ft \+bd ’ثِيلِيلِّيشِينْ‘\+bd* - إِشْثْ ن مَارْكَا ن إِنُّووَّارنْ ذَايْسنْ أَژْرِي أَطَّاسْ.\f*   
\b  
\m
\v 2 سڒْ، \add أَ\add* أَمكْسَاوْ ن إِسْرَائِيل،  
\m شكْ ذ ونِّي يَاركّْوسنْ يُوسُوفْ  
\m أَمْ وُودْجِي،  
\m شكْ ذ ونِّي إِتّْغِيمَانْ خْ إِكِيرُوبنْ،  
\m بَانْ-د ذِي ثِيسِّيقْثْ! \f ◼ \fr 80:‏2 \ft \+bd ’إِكِيرُوبنْ‘\+bd* - إِشْثْ ن مَارْكَا ن لْمَالَاكَاثْ.\f*   
\m
\v 3 سكَّارْ جّهْذْ أَمقّْرَانْ نّشْ  
\m زَّاثْ إِ وُوذمْ ن إِفْرَايِيمْ  
\m ذ بِينْيَامِينْ ذ مَانَاسَّا،  
\m أَسْ-د حِيمَا أَذْ أَنغْ ثْفكّذْ.   
\m
\v 4 \add أَ\add* أَربِّي، أَرّْ أَنغْ-د،  
\m أجّْ ؤُذمْ نّشْ أَذْ \add خَانغْ\add* يَارْغْ،  
\m \add خنِّي\add* أَذْ نتّْوَافكّْ. \x ◘ \xo 80:‏4 \xt إِزهد. 4‏:‏7؛ 31‏:‏17؛ 67‏:‏2؛ 80‏:‏8؛ دَان. 9‏:‏17\x*   
\b  
\m
\v 5 \add أَ\add* سِيذِي، أَربِّي ن ڒْعسْكَارَاثْ،  
\m مشْحَاڒْ إِ غَا ثكّذْ ثتّْخيَّاقذْ  
\m غَارْ ثْژَادْجِيثْ ن ڒْڭنْسْ نّشْ؟   
\m
\v 6 شكْ ثسّشّذْ ثنْ  
\m س وغْرُومْ ن إِمطَّاونْ،  
\m ثَارِّيذْ ثنْ أَذْ سْونْ إِمطَّاونْ  
\m س إِجّْ ن ڒْمِيجَاڒْ إِتّْوَاڭّنْ.   
\m
\v 7 شكْ ثڭِّيذْ أَنغْ  
\m ذ \add إِشْثْ ن ثْشَامَّا ن\add* إِمْشُوبّشنْ  
\m إِ جِّيرَانْ نّغْ،  
\m ڒْْعذْيَانْ نّغْ  
\m سْثهزَّانْ \add زَّايْنغْ\add* جَارْ أَسنْ. \x ◘ \xo 80:‏7 \xt إِزهد. 44‏:‏14؛ 79‏:‏4\x*   
\m
\v 8 أَرّْ أَنغْ-د، \add أَ\add* أَربِّي ن ڒْعسْكَارَاثْ،  
\m أجّْ ؤُذمْ نّشْ أَذْ \add خَانغْ\add* يَارْغْ،  
\m \add خنِّي\add* أَذْ نتّْوَافكّْ. \x ◘ \xo 80:‏8 \xt إِزهد. 80‏:‏4\x*   
\b  
\m
\v 9 شكْ ثْقڒْعذْ إِشْثْ ن ثْزَايَارْثْ زِي مِيصْرَا،  
\m ثُوژّْڒذْ خْ ڒڭْنُوسْ، ؤُشَا ثژُّوذْ-إِ-ت \add ذِينْ\add*.   
\m
\v 10 شكْ ثسّْوجْذذْ أَسْ \add أَمْشَانْ\add*  
\m ؤُ ثَارِّيذْ ت-إِ-د أَذْ ثوّثْ إِژوْرَانْ،  
\m ثْعمَّارْ \add ثْزَايَارْثْ\add* مَارَّا ثَامُّورْثْ.   
\m
\v 11 تّْوَاسّْذُورْينْ إِذُورَارْ س ثِيڒِي نّسْ،  
\m ثِيشجُّورَا ن ثنْڭلْثْ ن أَربِّي  
\m س ڒفْرُوعْ نّسْ.   
\m
\v 12 ثڭَّا ثِيسضْوِينْ نّسْ  
\m أَذْ أَوْضنْثْ أَڒْ ڒبْحَارْ،  
\m إِفثْوَانْ نّسْ إِزِييْزَاونْ  
\m أَڒْ إِغْزَارْ \add ن لْفُورَاطْ\add*.   
\b  
\m
\v 13 مَايمِّي ثْغضْڒضْ إِغبْرَاونْ نّسْ،  
\m أَڒَامِي مَارَّا إِنِّي د-إِتّكّنْ  
\m خْ وبْرِيذْ ڒقّْضنْ ت؟   
\m
\v 14 إِڒفْ زڭْ وزْغَارْ إِقْڒبْ \add ثَازَايَارْثْ\add*،  
\m \add مَارَّا\add* مِينْ إِنْثنْهزَّانْ ذڭْ إِيَّارْ،  
\m أَقَا إِهْذَا إِ-ت. \f ◼ \fr 80:‏14 \ft \+bd ’أَزْغَارْ‘\+bd* - نِيغْ ’ڒْغَابثْ‘ نِيغْ ’ثَازْڭَانْثْ‘.\f*   
\m
\v 15 \add أَ\add* أَربِّي ن ڒْعسْكَارَاثْ،  
\m ذْوڒْ-د \add غَارْنغْ\add*،  
\m سِيجّْ-د زڭْ ؤُجنَّا،  
\m ؤُ خْزَارْ، أَرْزفْ ثَازَايَارْثْ-أَ،   
\m
\v 16 تّْهِيلَّا ذِي ثْزَايَارْثْ  
\m ثنِّي إِژُّو ؤُفُوسْ نّشْ أَفُوسِي،  
\m ذِي مِّيشْ نِّي ثسّْجهْذذْ إِ يِيخفْ نّشْ.   
\b  
\m
\v 17 أَقَا ثتّْوَاسّشْمضْ س ثْمسِّي، ثتّْوَاقْضعْ.  
\m زڭْ ؤُسڭّْوذْ ن وُوذمْ نّشْ  
\m أَذْ ودَّارنْ.   
\m
\v 18 أجّْ أَفُوسْ نّشْ أَذْ يِيڒِي  
\m أَكْ-ذ ورْيَازْ ن ؤُفُوسْ نّشْ أَفُوسِي،  
\m أَكْ-ذ مِّيسْ ن بْنَاذمْ  
\m ونِّي ثسّْجهْذذْ إِ يِيخفْ نّشْ.   
\m
\v 19 \add خنِّي\add* وَارْ خَاكْ نْحيّذْ شَا.  
\m أجّْ أَنغْ أَذْ ندَّارْ،  
\m \add خنِّي\add* أَذْ نْڒَاغَا خْ يِيسمْ نّشْ.   
\m
\v 20 \add أَ\add* سِيذِي، أَربِّي ن ڒْعسْكَارَاثْ،  
\m أَرّْ أَنغْ-د،  
\m أجّْ ؤُذمْ نّشْ أَذْ \add خَانغْ\add* يَارْغْ،  
\m \add خنِّي\add* أَذْ نتّْوَافكّْ.   
\b  
\b  
\m  
\c 81
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ.\add*  
\m \add س ثغْنِينْثْ ن ؤُجِيتِّي، أَرْيَازْ زِي جَاثْ.\add*  
\m \add ن أَسَافْ.\add*   
\b  
\m
\v 2 سْڒِيوْڒمْ إِ أَربِّي، جّهْذْ نّغْ،  
\m ذُوقّْزمْ س ؤُسْڒِيوْڒوْ  
\m إِ أَربِّي ن يَاعْقُوبْ.   
\m
\v 3 سْڭعّْذمْ إِشْثْ ن يزْڒِي ن ؤُصبّحْ،  
\m أَوِي أَبنْذِيرْ،  
\m ڒْْڭَامْبْرِي مِيژِيذْ ذ لهَارْبَا.   
\m
\v 4 سُوضمْ ذڭْ ؤُيِيشّْ ن إِشَارِّي  
\m غَارْ ؤُبذِّي ن ؤُيُورْ،  
\m غَارْ ثْزِيرِي إِقفْڒنْ،  
\m غَارْ وَاسّْ ن ڒْعِيذْ نّغْ.   
\m
\v 5 مَاغَارْ ثَا ذ ثَاوْصيّثْ إِ إِسْرَائِيل،  
\m إِشْثْ ن لْفَارِيضَا ن أَربِّي ن يَاعْقُوبْ.   
\m
\v 6 إِڭَّا إِ-ت ذ شّْهَاذثْ ذِي يُوسُوفْ،  
\m ڒَْامِي د-إِفّغْ  
\m ضِيدّْ إِ ثمُّورْثْ ن مِيصْرَا.  
\m أَقَا سْڒِيغْ إِجّْ ن يِيڒسْ  
\m وَارْ ذ أَسْ فهْمغْ. \f ◼ \fr 81:‏6 \ft \+bd ’يُوسُوفْ‘\+bd* - س ثِيعْبْرَانِيثْ ’يَاهْ-هُوسفْ‘.\f*   
\b  
\m
\v 7 ثَاغْرُوضْثْ نّسْ فكّغْ ت زِي دّْقڒْ،  
\m إِفَاسّنْ نّسْ أَرْخُونْ  
\m زِي ثْسُودْجثْ \add إِ ثُوغَا يَاربُّو\add*.   
\m
\v 8 شكْ ثْڒَاغِيذْ ذِي ڒحْصَارثْ  
\m ؤُ نشّْ فكّغْ شكْ \add زَّايسْ\add*.  
\m نشّْ أَرِّيغْ-د خَاكْ أَمْ تّْنُوفَّارغْ  
\m ذڭْ وَاجَّاجْ،  
\m غَارْ وَامَانْ ن مَارِيبَا  
\m قدْجْبغْ شكْ. سِيلَاهْ.   
\m
\v 9 سڒْ، ڒْڭنْسْ إِنُو،  
\m \add خنِّي\add* نشّْ أَذْ شهْذغْ  
\m ذِي ڒْوسْطْ نّشْ، \add أَ\add* إِسْرَائِيل،  
\m مَاڒَا \add خنِّي\add* ثُوغَا ثخْسذْ  
\m أَذْ غَارِي د-ثسْڒذْ.   
\m
\v 10 وَارْ غَاركْ إِتِّيڒِي  
\m إِجّْ ن أَربِّي ذ أَغْرِيبْ،  
\m وَارْ سجذْ ؤُڒَا إِ يِيجّْ ن أَربِّي  
\m إِ وَارْ ثسِّينذْ.   
\m
\v 11 نشّْ ذ سِيذِي، أَربِّي نّشْ،  
\m ونِّي شكْ د-إِسُّوفّْغنْ زِي مِيصْرَا.  
\m أَرْزمْ أَقمُّونْ نّشْ  
\m ؤُ نشّْ أَذْ ث شُّورغْ.   
\b  
\m
\v 12 مَاشَا ڒْڭنْسْ إِنُو وَارْ إِسْڒِي شَا  
\m غَارْ ثْمِيجَّا إِنُو،  
\m إِسْرَائِيل وَارْ ذ أَيِي إِخْسْ.   
\m
\v 13 \add س ؤُينِّي\add* جِّيغْ ثنْ إِ وُوڒْ نْسنْ إِقسْحنْ،  
\m \add أَڒَامِي\add* إِ غَا ؤُيُورنْ  
\m ذِي ڒشْوَارْ \add ن ؤُزدْجِيفْ\add* نْسنْ.   
\m
\v 14 مْڒِي د-إِسْڒَا غَارِي ڒْڭنْسْ إِنُو،  
\m مْڒِي إِسْرَائِيل إِخْسْ أَذْ يُويُورْ ذڭْ إِبْرِيذنْ إِنُو!   
\m
\v 15 \add خنِّي\add* مَامّشْ ذغْيَا إِڒِي قْضِيغْ  
\m خْ ڒْعذْيَانْ نْسنْ،  
\m أَرِّيغْ أَفُوسْ إِنُو ضِيدّْ إِ يِينِّي ثنْ إِحصَّارنْ.   
\m
\v 16 إِنِّي إِشَارّْهنْ سِيذِي  
\m أَذْ غَارسْ د-ذوْڒنْ  
\m تّْمُورُوذنْ ذدْجنْ،  
\m ڒْْوقْثْ \add ن ؤُخدْجصْ\add* نْسنْ أَذْ يِيڒِي إِ ڒبْذَا.   
\b  
\m
\v 17 إِڒِي أَقَا إِوْشَا أَسْ مَاشَّا  
\m زِي لمْلِيحْ ن يِيرْذنْ،  
\m \add وَاهْ\add*، إِڒِي س ثَامّنْثْ زِي جَّارْفْ  
\m أَقَا نشّْ سّْجِّيوْنغْ شكْ.   
\b  
\b  
\m  
\c 82
\m
\v 1 \add أَزهّذْ ن أَسَافْ.\add*  
\b  
\m أَربِّي إِبدّْ ذِي ثْمسْمُونْثْ ن أَربِّي.  
\m نتَّا إِحكّمْ س ڒْحقّْ  
\m ذِي ڒْوسْثْ ن إِربِّيثنْ.   
\m
\v 2 مشْحَاڒْ إِ غَا ثكّمْ  
\m ثْحكّْممْ س ڒْغشّْ،  
\m أَذْ ثسّْڭعّْذمْ ؤُذمْ ن إِعفَّاننْ؟  
\m سِيلَاهْ.   
\b  
\m
\v 3 حكْممْ س ڒْحقّْ خْ ؤُمَارْخُو  
\m ؤُ خْ ؤُيُوجِيڒْ،  
\m أَغمْ ثَاسْغَارْثْ إِ ونِّي إِتّْوَاحصَّارنْ  
\m ؤُ إِ ؤُمزْڒُوضْ.   
\m
\v 4 فكّمْ أَمَارْخُو ذ ؤُمزْڒُوضْ،  
\m فكّْ إِ-ث زڭْ ؤُفُوسْ ن إِعفَّاننْ. \x ◘ \xo 82:‏4 \xt أَوڒن. 24‏:‏11\x*   
\b  
\m
\v 5 نِيثْنِي وَارْ تّسّْننْ ؤُ وَارْ فهّْمنْ،  
\m ڭُّورنْ تّنّْضنْ ذِي ثَادْجسْثْ،  
\m مَارَّا ذْسُوسَا ن ثمُّورْثْ تّنْهزَّانْ.   
\b  
\m
\v 6 نشّْ نِّيغْ: ”كنِّيوْ ذ إِربِّيثنْ،  
\m كنِّيوْ مَارَّا ذ إِحنْجِيرنْ  
\m ن ؤُمْعُودْجِي خْ كُوڒْشِي!“ \x ◘ \xo 82:‏6 \xt يُوح. 10‏:‏34‏-‏36\x*   
\m
\v 7 عَاذْ أَذْ ثمْثمْ أَمْ \add كُوڒْ\add* بْنَاذمْ،  
\m أَذْ ثوْضَامْ أَمْ كُوڒْ إِجّنْ زِي ڒْحُوكَّامْ.   
\b  
\m
\v 8 كَّارْ، \add أَ\add* أَربِّي، حْكمْ خْ ثمُّورْثْ،  
\m مِينْزِي شكْ أَذْ ثطّْفذْ ثَاسْغَارْثْ نّشْ  
\m زِي مَارَّا ڒڭْنُوسْ. \x ◘ \xo 82:‏8 \xt إِزهد. 2‏:‏8؛ عبر. 1‏:‏2\x*   
\b  
\b  
\m  
\c 83
\m
\v 1 \add إِزْڒِي. أَزهّذْ ن أَسَافْ.\add*   
\b  
\m
\v 2 \add أَ\add* أَربِّي، وَارْ سّغْذْ،  
\m وَارْ تّڭّْ إِخفْ نّشْ ذ أَذهْشُورْ،  
\m وَارْ سقَّارْ شَا، \add أَ\add* أَربِّي.   
\m
\v 3 مَاغَارْ خْزَارْ،  
\m ڒْْعذْيَانْ نّشْ تَّارُّودْجُوذنْ،  
\m إِنِّي شكْ إِشَارّْهنْ سّْڭعّْذنْ أَزدْجِيفْ.   
\m
\v 4 تّْخَارّْصنْ ذڭْ إِشْثْ ن ثْمعْمُوتْشْ  
\m ذِي ثْنُوفَّارْ  
\m ضِيدّْ إِ ڒْڭنْسْ نّشْ،  
\m تّمْشَاوَارنْ  
\m خْ يِينِّي إِتّْوَاحْضَانْ زَّايكْ.   
\m
\v 5 قَّارنْ: ”أَسمْ-د، أجّْ أَنغْ  
\m أَذْ ثنْ نْثحَّا أَمْ ڒْڭنْسْ،  
\m \add أَڒَامِي\add* وَارْ إِتِّيذَارْ عَاذْ  
\m ذڭْ يِيسمْ ن إِسْرَائِيل.“   
\b  
\m
\v 6 مَاغَارْ تّمْشَاوَارنْ س وُوڒْ ذ إِجّْ،  
\m أَقَا تّڭّنْ إِجّْ ن ڒْعَاهْذْ ضِيدّْ إِ شكْ: \x ◘ \xo 83:‏6 \xt Ps 2‏:‏2\x*   
\m
\v 7 إِقِيضَانْ ن إِذُومْ ذ أَيْثْ ن إِسْمَاعِيلْ،  
\m مُوآبَ ذ أَيْثْ ن هَاجَارْ،   
\m
\v 8 جَابَالْ ذ عَامُّونْ ذ عَامَالِيقْ،  
\m فِيلِيشِيثْ ذ إِمزْذَاغْ ن صُورْ.   
\m
\v 9 ؤُڒَا ذ أَشُّورْ إِمَّارْنِي غَارْسنْ.  
\m نِيثْنِي ثُوغَا أَثنْ ذ أَفُوسْ إِجْهذْ  
\m إِ أَيْثْ ن لُوطْ. سِيلَاهْ.   
\b  
\m
\v 10 أڭّْ أَسنْ أَمْ مِيذْيَانْ ذ سِيسَارَا،  
\m أَمْ يَابِينْ غَارْ يغْزَارْ ن قِيشُونْ.   
\m
\v 11 نِيثْنِي تّْوَاثحَّانْ غَارْ عَايْنْ-ذُورْ،  
\m ذوْڒنْ ذ ڒغْبَارْ خْ ثمُّورْثْ.   
\m
\v 12 أڭّْ إِ-ثنْ أَكْ-ذ ثَارْوَا ن ثَاصِيڒثْ نْسنْ  
\m أَمْ غُورَابْ ذ ذِي‘بْ،  
\m مَارَّا أَيْثْ ن جّهْذْ نْسنْ  
\m أَمْ زَابَاحْ ذ صَالْمُونَّاعْ، \x ◘ \xo 83:‏12 \xt ڒقض. 7‏:‏25؛ 8‏:‏5؛ إِزهد. 83‏:‏12\x*   
\m
\v 13 إِنِّي إِقَّارنْ:  
\m ”أجّْ أَنغْ أَذْ نطّفْ  
\m ثِيزذِّيغِينْ ن أَربِّي  
\m إِ يِيخفْ نّغْ ذ ڒْوَارْثْ.“   
\b  
\m
\v 14 \add أَ\add* أَربِّي إِنُو، أڭّْ إِ-ثنْ  
\m أَمْ يِيجّْ ن ؤُقلِّيجْ  
\m إِتّنّْضنْ \add ذِي ڒعْوِينْ\add*،  
\m أَمْ ؤُڒُومْ زَّاثْ إِ وُوذمْ ن ؤُسمِّيضْ.   
\m
\v 15 أَمْ ثْمسِّي ثسّْرقَّا أَزْغَارْ،  
\m أَمْ ؤُشعَّاڒْ إِتّتّْ إِذُورَارْ، \f ◼ \fr 83:‏15 \ft \+bd ’أَزْغَارْ‘\+bd* - نِيغْ ’ڒْغَابثْ‘ نِيغْ ’ثَازْڭَانْثْ‘.\f*   
\m
\v 16 أَژّڒْ أَمُّو خَاسنْ س ؤُسمِّيضْ نّشْ،  
\m سْنخْڒعْ إِ-ثنْ س ثْحَارْيَاضْثْ نّشْ.   
\m
\v 17 ڒحّفْ ؤُذمْ نْسنْ س ڒحْيَا،  
\m مَاحنْذْ نِيثْنِي، \add أَ\add* سِيذِي،  
\m أَذْ أَرْزُونْ خْ يِيسمْ نّشْ.   
\b  
\m
\v 18 أجّْ إِ-ثنْ أَذْ بَارّْقنْ  
\m ؤُ أَذْ أَرجْفنْ إِ ڒبْذَا،  
\m أجّْ إِ-ثنْ أَذْ سضْحَانْ  
\m ؤُشَا أَذْ تّْوَاهلّْكنْ،   
\m
\v 19 حِيمَا أَذْ سّْننْ، أَقَا شكْ وَاهَا  
\m إِ غَارْ إِدْجَا يِيسمْ ’سِيذِي‘،  
\m أَمْعُودْجِي خْ مَارَّا ثَامُّورْثْ.   
\b  
\b  
\m  
\c 84
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ.\add*  
\m \add س ثغْنِينْثْ ن ؤُجِيتِّي، أَرْيَازْ زِي جَاثْ.\add*  
\m \add زڭْ أَيْثْ ن قُورَاحْ. أَزهّذْ.\add*   
\b  
\m
\v 2 مَامّشْ تّْعِيزّنْثْ ثْزذِّيغِينْ نّشْ،  
\m \add أَ\add* سِيذِي ن ڒْعسْكَارَاثْ!   
\m
\v 3 ڒعْمَارْ إِنُو ذَايسْ مژْرِي،  
\m \add وَاهْ،\add* إِفنَّا \add س ؤُوحّشْ\add*  
\m خْ ڒمْرَاحَاثْ ن سِيذِي،  
\m ؤُڒْ إِنُو ذ دَّاثْ إِنُو  
\m سْڒِيوْڒِيونْ إِ أَربِّي إِدَّارنْ. \x ◘ \xo 84:‏3 \xt إِزهد. 42‏:‏2؛ 63‏:‏2\x*   
\b  
\m
\v 4 ؤُڒَا ذ ژَّاوشْ إِتَّافْ عَاذْ إِشْثْ ن ثَادَّارْثْ،  
\m ؤُ ثَافَارْدْجسْثْ ثُوفَا إِجّْ ن ڒْعُوشّْ إِ يِيخفْ نّسْ  
\m إِ ذِي ثسّْرُوسَّا إِسّْضَاونْ نّسْ،  
\m \add غَارْ\add* إِعَالْطَارنْ نّشْ، \add أَ\add* سِيذِي ن ڒْعسْكَارَاثْ،  
\m أَجدْجِيذْ إِنُو ذ أَربِّي إِنُو!   
\b  
\m
\v 5 سّعْذْ نْسنْ ن يِينِّي إِزدّْغنْ  
\m ذِي ثَادَّارْثْ نّشْ،  
\m أَقَا أَثنْ تّْصبَّاحنْ إِ شكْ  
\m بْڒَا قطُّو. سِيلَاهْ.   
\b  
\m
\v 6 سّعْذْ ن إِوْذَانْ  
\m إِنِّي \add إِتَّافنْ\add* جّهْذْ نْسنْ ذَايكْ،  
\m \add إِنِّي إِحطَّانْ\add* إِبْرِيذنْ إِڭعّْذنْ  
\m \add غَارْ زَّاوشْثْ نّشْ ثَامقّْرَانْثْ\add*  
\m ذڭْ وُوڒْ نْسنْ.   
\m
\v 7 خْمِي تّْشُوقَانْ ذڭْ إِجّْ ن ڒوْضَا ن ثغْزُورْثْ  
\m ن ثْشجُّورَا ن ؤُمتِّينْ،  
\m أَرِّينْ ث ذ ڒْعُونْصَارْ.  
\m ؤُڒَا ذ أَنْژَارْ أَمزْوَارُو  
\m أَذْ \add ثنْ\add* إِسّْذُورِييْ س لْبَارَاكَاثْ.   
\b  
\m
\v 8 نِيثْنِي ڭُّورنْ زِي جّهْذْ أَڒْ جّهْذْ،  
\m أَذْ د-بَاننْ غَارْ أَربِّي ذِي صِيهْيُونْ.   
\m
\v 9 \add أَ\add* سِيذِي، أَربِّي ن ڒْعسْكَارَاثْ،  
\m سڒْ إِ ثْژَادْجِيثْ إِنُو،  
\m سْحسّْ، \add أَ\add* أَربِّي ن يَاعْقُوبْ! سِيلَاهْ.   
\b  
\m
\v 10 \add أَ\add* أَربِّي،  
\m \add شكْ ذ\add* ثَاسدَّارْثْ نّغْ ن ؤُسڒْقِي،  
\m أَقَا خْزَارْ غَارْ وُوذمْ ن ؤُمذْهُونْ نّشْ!   
\m
\v 11 مَاغَارْ إِجّْ ن وَاسّْ ذِي ڒمْرَاحَاثْ نّشْ  
\m إِحْڒَا خْ وَاڒفْ \add ن وُوسَّانْ نّغْنِي\add*.  
\m معْلِيكْ ؤُفِيغْ أَذْ بدّغْ  
\m خْ ثْنبْذَاثْ ن ثَادَّارْثْ ن أَربِّي إِنُو،  
\m ؤُڒَا ذ أَثْلَاعْ ذڭْ إِقِيضَانْ ن ثُوعفّْنَا.   
\b  
\m
\v 12 مَاغَارْ سِيذِي أَربِّي ذ ثَافُوشْثْ  
\m ذ ثْسدَّارْثْ إِ ؤُسڒْقِي،  
\m سِيذِي أَذْ إِوْشْ أَحِينِّي ذ ؤُعُودْجِي.  
\m نتَّا وَارْ إِسّْعِيزِّي ڒْخَارْ  
\m ذڭْ إِنِّي إِڭُّورنْ س ڒكْمَارثْ.   
\b  
\m
\v 13 \add أَ\add* سِيذِي ن ڒْعسْكَارَاثْ،  
\m سّعْذْ ن بْنَاذمْ نِّي ذَايكْ إِتِّيقَّانْ. \x ◘ \xo 84:‏13 \xt إِزهد. 2‏:‏12؛ 34‏:‏9\x*   
\b  
\b  
\m  
\c 85
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ.\add*  
\m \add زڭْ أَيْثْ ن قُورَاحْ. أَزهّذْ.\add*   
\b  
\m
\v 2 شكْ ثَارْضِيذْ خْ ثمُّورْثْ، \add أَ\add* سِيذِي،  
\m ثسّنْقڒْبذْ ثَامحْبَاسْثْ ن يَاعْقُوبْ.   
\m
\v 3 ثكّْسذْ ڒْمُوعْصِييّثْ خْ ڒْڭنْسْ نّشْ،  
\m ثذْڒِيذْ مَارَّا دّْنُوبْ نّسْ. سِيلَاهْ.   
\m
\v 4 شكْ ثْمنْعذْ مَارَّا أَفُوڭمْ،  
\m ثسّْثوّْجذْ ڒْحَاذُوقْ ن وغْضَابْ نّشْ.   
\b  
\m
\v 5 أَرّْ أَنغْ، \add أَ\add* أَربِّي ن ؤُسنْجمْ نّغْ،  
\m تُّو أَغْضَابْ نّشْ خَانغْ.   
\m
\v 6 مَا ثخْسذْ أَذْ خَانغْ ثسْعَارذْ إِ ڒبْذَا؟  
\m مَا أَذْ ثڭّذْ أَغْضَابْ نّشْ  
\m أَذْ إِقِّيمْ زِي جِّيڒْ أَڒْ جِّيڒْ؟   
\m
\v 7 مَا وَارْ ذ أَنغْ ثجِّيذْ أَذْ ندَّارْ عَاوذْ،  
\m حِيمَا أَذْ أَشْ إِفَارْحْ ڒْڭنْسْ نّشْ؟ \x ◘ \xo 85:‏7 \xt إِزهد. 71‏:‏20\x*   
\m
\v 8 سْشنْ أَنغْ-د  
\m ثَامخْسِيوْثْ نّشْ إِشوَّارنْ، \add أَ\add* سِيذِي،  
\m أوْشْ أَنغْ أَسنْجمْ نّشْ.   
\b  
\m
\v 9 نشّْ خْسغْ أَذْ سْڒغْ  
\m مِينْ غَا إِسِّيوڒْ أَربِّي، سِيذِي،  
\m مَاغَارْ نتَّا أَذْ إِسِّيوڒْ أَكْ-ذ ڒْڭنْسْ نّسْ  
\m ؤُ أَكْ-ذ إِمْثِيقَّانْ نّسْ خْ ڒهْنَا.  
\m غَارْومْ، مَاڒَا نِيثْنِي أَذْ د-ذوْڒنْ  
\m تّْشَاڒَانْ \add خْ يِيخفْ نْسنْ\add*.   
\m
\v 10 نِيشَانْ، أَقَا يُوذسْ-د ؤُسنْجمْ نّسْ  
\m إِ يِينِّي زَّايسْ إِتّڭّْوذنْ،  
\m حِيمَا أَعُودْجِي \add نّسْ\add*  
\m أَذْ إِزْذغْ ذِي ثمُّورْثْ نّغْ.   
\m
\v 11 ثَامخْسِيوْثْ إِشوَّارنْ ذ ڒَامَانْ  
\m أَذْ مّْسَاڭَارنْ،  
\m ثَاسڭْذَا ذ ڒهْنَا أَذْ مّْسُوذُومنْ. \x ◘ \xo 85:‏11 \xt عبر. 7‏:‏2\x*   
\b  
\m
\v 12 ثِيذتّْ أَذْ ثغْمِي زِي ثمُّورْثْ،  
\m ثَاسڭْذَا أَذْ ثسِّيجّْ غَارْ سْوَادَّايْ  
\m زڭْ ؤُجنَّا.   
\m
\v 13 سِيذِي أَذْ إِوْشْ ؤُڒَا ذ مِينْ إِصبْحنْ،  
\m ثَامُّورْثْ نّغْ أَذْ ثوْشْ ڒْغِيدْجثْ نّسْ. \x ◘ \xo 85:‏13 \xt إِزهد. 67‏:‏7\x*   
\m
\v 14 ثَاسڭْذَا أَذْ أَسْ ثِيزْوَارْ  
\m زَّاثْ إِ وُوذمْ نّسْ،  
\m أَذْ ثحْضَا جُّورّثْ ن إِصُورَافْ نّسْ.   
\b  
\b  
\m  
\c 86
\m
\v 1 \add ثَاژَادْجِيثْ ن ذَاوُوذْ.\add*  
\b  
\m \add أَ\add* سِيذِي، أَرّْ أَمزُّوغْ نّشْ \add غَارِي\add*،  
\m سڒْ أَيِي،  
\m مَاغَارْ نشّْ ذِي ڒغْبنْ ؤُ زڒْضغْ.   
\m
\v 2 حْضَا خْ ڒعْمَارْ إِنُو،  
\m مَاغَارْ نشّْ ذ أَمْثِيقِّي،  
\m \add أَ\add* أَربِّي إِنُو،  
\m سنْجمْ أَمْسخَّارْ نّشْ،  
\m ونِّي خَاكْ إِتّْشَاڒَانْ.   
\m
\v 3 حِينّْ خَافِي، \add أَ\add* سِيذِي إِنُو،  
\m مَاغَارْ تّْڒَاغِيغْ خَاكْ أَسّْ أَمْ إِمُونْ.   
\m
\v 4 سْفَارْحْ ڒعْمَارْ ن ؤُمْسخَّارْ نّشْ،  
\m مَاغَارْ إِ شكْ، \add أَ\add* سِيذِي إِنُو،  
\m سّْڭعَّاذغْ ڒعْمَارْ إِنُو.   
\m
\v 5 مَاغَارْ شكْ، \add أَ\add* سِيذِي إِنُو،  
\m ذ أَصبْحَانْ ؤُ ذ أَمْسَامحْ،  
\m غَاركْ ثَامخْسِيوْثْ إِشوَّارنْ  
\m إِ مَارَّا إِنِّي غَاركْ إِتّْڒَاغَانْ.   
\b  
\m
\v 6 \add أَ\add* سِيذِي، سڒْ إِ ثْژَادْجِيثْ إِنُو،  
\m حكَّارْ إِ ثْمِيجَّا ن ثُوثْرَا إِنُو.   
\m
\v 7 ذڭْ وَاسّْ ن ڒحْصَارثْ إِنُو  
\m تّْڒَاغِيغْ-د غَاركْ،  
\m مَاغَارْ شكْ أَذْ خَافِي د-ثَارّذْ. \x ◘ \xo 86:‏7 \xt إِزهد. 50‏:‏15\x*   
\m
\v 8 جَارْ إِربِّيثنْ وَارْ إِدْجِي ؤُڒَا ذ إِجّنْ  
\m أَمْ شكْ، \add أَ\add* سِيذِي إِنُو،  
\m وَارْ ذِينْ مِينْ يَارْوسنْ  
\m ذِي ثْمڭَّا نِّي ثڭِّيذْ. \x ◘ \xo 86:‏8 \xt أَعَوذ. 3‏:‏24؛ إِزهد. 136‏:‏4\x*   
\m
\v 9 مَارَّا ڒڭْنُوسْ إِ ثڭِّيذْ، أَذْ د-أَسنْ،  
\m أَذْ سجْذنْ زَّاثْ إِ وُوذمْ نّشْ،  
\m \add أَ\add* سِيذِي إِنُو،  
\m أَذْ سّْعُودْجنْ إِسمْ نّشْ.   
\m
\v 10 مَاغَارْ شكْ ذ أَمقّْرَانْ  
\m ؤُ شكْ ذ ونِّي إِتّڭّنْ لْمُوعْجِيزَاثْ،  
\m شكْ وحّْذكْ ذ أَربِّي \add إِ ثدْجِيذْ\add*.   
\m
\v 11 سْشنْ أَيِي أَبْرِيذْ نّشْ، \add أَ\add* سِيذِي،  
\m \add حِيمَا\add* أَذْ ؤُيُورغْ ذِي ثِيذتّْ نّشْ،  
\m سْمُونْ ؤُڒْ  إِنُو  
\m مَاحنْذْ أَذْ ڭّْوذغْ إِسمْ نّشْ. \x ◘ \xo 86:‏11 \xt إِزهد. 25‏:‏4؛ 27‏:‏11؛ 119‏:‏33\x*   
\m
\v 12 \add أَ\add* سِيذِي إِنُو، أَربِّي إِنُو،  
\m خْسغْ أَذْ شكْ قَاذِيغْ س مَارَّا وُوڒْ إِنُو،  
\m أَذْ شنّْعغْ إِسمْ نّشْ إِ ڒبْذَا قَاعْ.   
\m
\v 13 مَاغَارْ ثَامخْسِيوْثْ نّشْ إِشوَّارنْ  
\m ثمْغَارْ خَافِي،  
\m شكْ ثْفكّذْ ڒعْمَارْ إِنُو  
\m زِي ڒَادْجَاغْ ن ڒَاخَارْثْ.   
\b  
\m
\v 14 \add أَ\add* أَربِّي،  
\m إِمْعفَّارنْ كَّارنْ-د أَكِيذِي،  
\m إِشْثْ ن بَانْذِييَّا ن أَيْثْ ن بُو-ڒخْشُونثْ  
\m أَرزُّونْ أَذْ \add نْغنْ\add* ڒعْمَارْ إِنُو.  
\m شكْ وَارْ غَارْسنْ ثدْجِيذْ  
\m قِيبَاتْشْ إِ ثِيطَّاوِينْ نْسنْ. \x ◘ \xo 86:‏14 \xt إِزهد. 54‏:‏5\x*   
\m
\v 15 \add مَاشَا\add* شكْ، \add أَ\add* سِيذِي إِنُو،  
\m ذ أَربِّي ذ أَرْحِيمْ ذ ؤُحْنِينْ،  
\m غَاركْ تَّاسِيعْ ن ڒْخَاضَارْ  
\m ؤُڒَا ذ ثَامخْسِيوْثْ إِشوَّارنْ  
\m ذ ڒَامَانْ مْغَارنْ. \x ◘ \xo 86:‏15 \xt ؤُف. 34‏:‏6؛ ڒخْڒ. 14‏:‏18؛ نَاح. 9‏:‏17؛ إِزهد. 103‏:‏8؛ 145‏:‏8؛ يُووِ. 2‏:‏13\x*   
\m
\v 16 خْزَارْ-د غَارِي ؤُ حِينّْ خَافِي،  
\m أڭّْ جّهْذْ نّشْ ذڭْ ؤُمْسخَّارْ نّشْ،  
\m ؤُشَا سنْجمْ مِّيسْ ن ثَايَّا نّشْ.   
\m
\v 17 أڭّْ إِشْثْ ن ڒعْڒَامثْ ذِي طّْوعْ إِنُو،  
\m حِيمَا إِنِّي ذ أَيِي إِشَارّْهنْ  
\m أَذْ ث ژَترنْ أَذْ سضْحَانْ،  
\m مَاغَارْ شكْ، \add أَ\add* سِيذِي، ثوْشِيذْ أَيِي أَفُوسْ  
\m ؤُ ثسّْفوّْجذْ خَافِي.   
\b  
\b  
\m  
\c 87
\m
\v 1 \add أَزهّذْ، إِزْڒِي ن أَيْثْ ن قُورَاحْ.\add*  
\b  
\m ذْسَاسْ نّسْ \add أَقَا-ث\add* خْ إِذُورَارْ إِقدّْسنْ.   
\m
\v 2 سِيذِي إِتّخْسْ ثِيوُّورَا ن صِيهْيُونْ  
\m أَطَّاسْ خْ مَارَّا ثِيزدّْغِينْ ن يَاعْقُوبْ.   
\m
\v 3 ثِيمسْڒَايِينْ يُوعْڒَانْ قَّارنْ خَامْ،  
\m \add أَ\add* ثَانْذِينْثْ ن أَربِّي. سِيلَاهْ.   
\m
\v 4 نشّْ أَذْ بَارّْحغْ رَاهَابْ ذ بَابِيلْ  
\m غَارْ يِينِّي إِ ذ أَيِي إِسّْننْ.  
\m خْزَارْ، فِيلِيشِيثْ ذ ونِّي زِي صُورِي  
\m أَكْ-ذ ؤُكُوشِي ...  
\m ’وَانِيثَا إِتّْوَاخڒْقذْ-د ذِينْ!‘   
\b  
\m
\v 5 مَاشَا خْ صِيهْيُونْ أَذْ إِنِينْ:  
\m ’\add إِنَا\add* مَارَّا تّْوَاخڒْقنْ-د ذَايسْ!‘،  
\m أَمْعُودْجِي خْ كُوڒْشِي أَذْ ت إِسّمْثنْ.   
\m
\v 6 سِيذِي أَذْ إِزمّمْ ذِي لِيسْثَا ن ڒڭْنُوسْ:  
\m ’وَانِيثَا إِخْڒقْ-د ذِينْ‘. سِيلَاهْ.   
\m
\v 7 نِيثْنِي تّْغنَّاجنْ أَمْ شطّْحنْ:  
\m ’ثَاڒَاوِينْ إِنُو مَارَّا ذَايمْ!‘   
\b  
\b  
\m  
\c 88
\m
\v 1 \add إِزْڒِي، أَزهّذْ ن أَيْثْ ن قُورَاحْ.\add*  
\m \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ،\add* \add س ثغْنِينْثْ ن ’إِزْڒِي ن وشْضَانْ‘ غَارْ ڒحْصَارَاثْ.\add*  
\m \add أَخمِّي ن هَايْمَانْ، أَزْرَاحِي.\add*   
\b  
\m
\v 2 \add أَ\add* سِيذِي، أَربِّي ن ؤُسنْجمْ إِنُو،  
\m ذڭْ وَاسّْ إِ ذِي د غَا سْغُويغْ غَاركْ  
\m س دْجِيڒثْ،   
\m
\v 3 أجّْ \add خنِّي\add* أَذْ د-ثَاسْ ثْژَادْجِيثْ إِنُو زَّاثكْ،  
\m أوْشْ أَمزُّوغْ نّشْ إِ ؤُڒَاغِي إِنُو.   
\m
\v 4 مَاغَارْ ڒعْمَارْ إِنُو إِجِّيونْ س ڒْمُوصِيبَاثْ،  
\m ثُوذَارْثْ إِنُو ثُوذسْ-د ڒَاخَارْثْ.   
\m
\v 5 نشّْ تّْوَاحسَّابغْ أَمْ يِينِّي د-إِهكّْوَانْ  
\m ذڭْ وحْفُورْ \add ن ونْضڒْ\add*،  
\m أَمْ إِجّْ ن ورْيَازْ  
\m ؤُمِي وَارْ ذَايسْ جّْهذْ \add عَاذْ\add*.   
\b  
\m
\v 6 أَقَا تّْوَاحُوزغْ جَارْ إِمتَّانْ،  
\m أَمْ يِينِّي إِتّْوَانْغنْ  
\m إِنِّي إِزّْڒنْ ذڭْ ونْضڒْ،  
\m إِنِّي وَارْ ثنْ ثتِّيذَارذْ \add عَاذْ\add*،  
\m تّْوَاقضْعنْ نِيثْنِي زڭْ ؤُفُوسْ نّشْ.   
\m
\v 7 شكْ ثڭِّيذْ أَيِي  
\m ذڭْ ونْضڒْ يُودْجْغنْ قَاعْ،  
\m ذِي ثَادْجسْثْ، ذِي ڒَادْجَاغْ.   
\m
\v 8 أَسْعَارْ نّشْ إِذْقڒْ خَافِي أَطَّاسْ،  
\m س مَارَّا ڒمْوَاجْ \add ن وسْعَارْ\add* نّشْ  
\m ثسّْذدْجذْ أَيِي. سِيلَاهْ.   
\b  
\m
\v 9 إِمْقَارَّابنْ إِنُو  
\m ثسِّيڭّْوجذْ إِ-ثنْ خَافِي،  
\m ثَارِّيذْ أَيِي ذ نّْعِي إِ نِيثْنِي.  
\m إِتّْوَابلّعْ خَافِي،  
\m وَارْ زمَّارغْ أَذْ د-فّْغغْ.   
\m
\v 10 ثِيطّْ إِنُو ثعْمشْ س ڒغْبنْ.  
\m \add أَ\add* سِيذِي، أَسّْ مَارَّا تّْڒَاغِيغْ غَاركْ،  
\m نشّْ سّْوِيژّْضغْ إِفَاسّنْ إِنُو غَاركْ.   
\b  
\m
\v 11 مَا أَذْ ثڭّذْ إِشْثْ ن لْمُوعْجِيزَا  
\m ذڭْ إِمتَّانْ؟  
\m نِيغْ أَذْ د-كَّارنْ ڒخْيَاڒَاثْ \add ن إِمتَّانْ\add*،  
\m مَا أَذْ شكْ قَاذَانْ؟ سِيلَاهْ.   
\m
\v 12 مَا أَذْ بَارّْحنْ  
\m س ثْمخْسِيوْثْ نّشْ إِشوَّارنْ  
\m ذڭْ ونْضڒْ، س ڒَامَانْ نّشْ  
\m ذِي \add ثسْرَافْثْ ن\add* ؤُهلّكْ؟   
\m
\v 13 مَا أَذْ تّْوَاسّْننْثْ لْمُوعْجِيزَاثْ نّشْ  
\m ذِي ثَادْجسْثْ،  
\m ثَاسڭْذَا نّشْ ذِي ثمُّورْثْ ن ثَاتُّوثْ؟   
\b  
\m
\v 14 \add أَ\add* سِيذِي، نشّْ تّْڒَاغِيغْ شكْ،  
\m ثَاژَادْجِيثْ إِنُو ثتَّاسْ-د زَّاثكْ غَارْ ؤُثفُّو.   
\m
\v 15 مَايمِّي، \add أَ\add* سِيذِي،  
\m ثْنطَّارذْ ڒعْمَارْ إِنُو،  
\m \add مَايمِّي\add* ثسّْنُوفَّارذْ  
\m ؤُذمْ نّشْ زَّايِي؟   
\m
\v 16 زِي ثمْژِي إِنُو نشّْ ذِي ڒغْبنْ  
\m ؤُ ڭُّورغْ غَارْ ؤُنُورِي،  
\m كْسِيغْ إِسْنخْرِيعنْ نّشْ \add ضِيدّْ إِنُو\add*،  
\m تّْوَاحْصَارغْ \add زَّايْسنْ\add*.   
\b  
\m
\v 17 ثتّكّْ خَافِي ڒْحَاذُوقْ ن وغْضَابْ نّشْ،  
\m إِتّحَّا أَيِي ؤُسڭّْوِيذْ نّشْ.   
\m
\v 18 أَسّْ مَارَّا إِتّنّضْ أَيِي-د أَمْ وَامَانْ،  
\m إِتّْقُووَّارْ أَيِي-د مَارَّا.   
\m
\v 19 أَمْعِيزّْ إِنُو ذ ؤُمدُّوكّڒْ إِنُو  
\m ثسِّيڭّْوجذْ إِ-ثنْ خَافِي،  
\m إِنِّي ذ أَيِي إِسّْننْ إِنُو  
\m \add أَقَا أَثنْ تّْوَاڒحّْفنْ\add* س ثَادْجسْثْ.   
\b  
\b  
\m  
\c 89
\m
\v 1 \add أَخمِّي ن إِثَانْ، أَزْرَاحِي.\add*   
\b  
\m
\v 2 أَذْغنّْجغْ خْ \bd ثْمڭَّا\bd*  
\m \bd ن ثْمخْسِيوْثْ إِشوَّارنْ ن سِيذِي\bd* إِ ڒبْذَا،  
\m أَذْ بَارّْحغْ \bd ڒَْامَانْ نّشْ\bd*  
\m س ؤُقمُّومْ إِنُو زِي جِّيڒْ أَڒْ جِّيڒْ.   
\m
\v 3 مَاغَارْ نِّيغْ: ”\bd ثَامخْسِيوْثْ إِشوَّارنْ\bd*  
\m ثتّْوَابْنَا إِ ڒبْذَا،  
\m أَقَا ثْضمْنذْ \bd ڒَْامَانْ نّشْ\bd*  
\m ذڭْ إِجنْوَانْ.“   
\b  
\m
\v 4 ”نشّْ ڭِّيغْ إِجّْ ن ڒْعَاهْذْ  
\m أَكْ-ذ ونِّي زَّايِي إِتّْوَافَارْزنْ،  
\m جُّودْجغْ إِ ؤُمْسخَّارْ إِنُو ذَاوُوذْ:   
\m
\v 5 ’نشّْ أَذْ ضمْنغْ زَّارِيعثْ نّشْ إِ ڒبْذَا  
\m ؤُ أَذْ بْنِيغْ ڒْعَارْشْ نّشْ زِي جِّيڒْ أَڒْ جِّيڒْ.‘ “ سِيلَاهْ.   
\b  
\m
\v 6 إِجنْوَانْ تّْقَاذَانْ \add شكْ\add*  
\m خْ لْمُوعْجِيزَا\add ث\add* نّشْ، \add أَ\add* سِيذِي،  
\m ذڭْ وڭْرَاوْ ن إِمْقدَّاسنْ  
\m \add تّْقَاذَانْ شكْ\add* خْ \bd ڒَْامَانْ نّشْ\bd*. \x ◘ \xo 89:‏6 \xt إِزهد. 19‏:‏2\x*   
\m
\v 7 مَاغَارْ مَانْ ونْ ذڭْ إِسيْنُوثنْ  
\m \add إِزمَّارْ\add* أَذْ إِتّْوَاقدّْ أَكْ-ذ سِيذِي،  
\m \add مَانْ ونْ إِ إِدْجَانْ\add*  
\m جَارْ وَارَّاونْ ن إِربِّيثنْ  
\m \add إِزمَّارْ\add* أَذْ إِمْقُودَّا أَكْ-ذ سِيذِي؟   
\b  
\m
\v 8 أَربِّي إِوْعَارْ أَطَّاسْ  
\m ذڭْ وڭْرَاوْ ن إِمْقدَّاسنْ،  
\m مَارَّا إِنِّي ذ أَسْ د-إِنّْضنْ  
\m تّڭّْوذنْ زَّايسْ.   
\m
\v 9 \add أَ\add* سِيذِي، أَربِّي ن ڒْعسْكَارَاثْ،  
\m مَانْ ونْ غَارْ إِدْجَا ثِيزمَّارْ  
\m أَمْ شكْ، \add أَ\add* سِيذِي!  
\m \bd ڒَْامَانْ نّشْ\bd* إِتّنّضْ إِ شكْ.   
\b  
\m
\v 10 شكْ ثْحكّْمذْ خْ نّْفَاخثْ ن ڒبْحَارْ.  
\m خْمِي د-تّْنكَّارنْ ڒمْوَاجْ نّسْ،  
\m أَقَا شكْ ثَارسِّيذْ إِ-ثنْ.   
\m
\v 11 أَقَا ثْڒبْزذْ رَاهَابْ  
\m أَمْ يِيجّنْ ونِّي إِسّْنُوقّْبنْ،  
\m ثْزدْجْعذْ ڒْعذْيَانْ نّشْ  
\m س ؤُغِيڒْ نّشْ إِجهْذنْ.   
\b  
\m
\v 12 نّشْ ذ إِجنْوَانْ،  
\m نّشْ ؤُڒَا ذ ثَامُّورْثْ.  
\m دُّونِيثْ ذ ؤُعمَّارْ نّسْ  
\m ثڭِّيذْ أَسنْ ذْسَاسْ. \x ◘ \xo 89:‏12 \xt إِزهد. 24‏:‏1، 2\x*   
\m
\v 13 شكْ ثْخڒْقذْ-د شَّامَالْ ذ لْجَانُوبْ،  
\m ثابُورْ ذ هِيرْمُونْ سْڒِيوْڒِيونْ  
\m س يِيسمْ نّشْ.   
\b  
\m
\v 14 أَقَا غَاركْ أَغِيڒْ إِ ذِي \add ثڭِّيذْ\add* ثَارْيَاسْثْ،  
\m أَفُوسْ نّشْ إِجْهذْ،  
\m أَفُوسْ أَفُوسِي نّشْ إِتّْوَاسّْڭعَّاذْ.   
\m
\v 15 ثَاسڭْذَا ذ ڒْحقّْ  
\m أَقَا أَثنْ ذ ذْسَاسْ ن ڒْعَارْشْ نّشْ،  
\m \bd ثَامخْسِيوْثْ إِشوَّارنْ\bd* ذ \bd ڒَْامَانْ\bd*  
\m إِتِّيزْوَارنْ زَّاثْ إِ وُوذمْ نّشْ. \x ◘ \xo 89:‏15 \xt أَعَوذ. 32‏:‏4؛ إِزهد. 85‏:‏14؛ 97‏:‏2؛ 99‏:‏4؛ 145‏:‏17؛ أَسَا. 15‏:‏3\x*   
\b  
\m
\v 16 سّعْذْ ن ڒْڭنْسْ إِ إِسّْننْ \add أَذْ ميّْزنْ\add*  
\m أَسُوضِي س وسْرُودّحْ \add ن ڒْبُوقْ\add*، \add أَ\add* سِيذِي،  
\m نِيثْنِي أَذْ ؤُيُورنْ ذِي ثْفَاوْثْ ن وُوذمْ نّشْ.   
\m
\v 17 نِيثْنِي أَذْ فَارْحنْ أَسّْ مَارَّا  
\m س يِيسمْ نّشْ  
\m ؤُشَا أَذْ د-تّْوَاسّْڭعّْذنْ  
\m س ثْسڭْذَا نّشْ،   
\b  
\m
\v 18 مَاغَارْ شكْ ذ ڒمْڒَاحثْ ن جّهْذْ نْسنْ،  
\m إِشّْ نّغْ أَذْ إِتّْوَاسّْڭعّذْ  
\m س ڒْخَاضَارْ نّشْ.   
\m
\v 19 ثَاسدَّارْثْ نّغْ ن ؤُسڒْقِي ن سِيذِي،  
\m أَجدْجِيذْ نّغْ أَقَا-ث ن ؤُمْقدَّاسْ ن إِسْرَائِيل.   
\b  
\m
\v 20 إِشْثْ ن ثْوَاڒَا ثُوغَا ثسِّيوْڒذْ ذِي ڒوْحِييْ  
\m خْ ؤُمْثِيقِّي نّشْ، ثنِّيذْ:  
\m ”س \add ؤُفُوسْ ن\add* إِجّْ ن بُو-ثغْرُوضْثْ ڭِّيغْ ثْوِيزَا،  
\m إِجّْ ونِّي إِتّْوَافَارْزنْ زِي ڒْڭنْسْ  
\m سّْڭعّْذغْ-ث.   
\m
\v 21 نشّْ ؤُفِيغْ ذَاوُوذْ، أَمْسخَّارْ إِنُو،  
\m ذهْنغْ ث س زّشْثْ إِقدّْسنْ، \x ◘ \xo 89:‏21 \xt 1 صم. 16‏:‏1، 13\x*   
\b  
\m
\v 22 مَاحنْذْ أَفُوسْ إِنُو أَذْ يِيڒِي إِمْثنْ أَكِيذسْ،  
\m \add وَاهْ\add* أَغِيڒْ إِنُو أَذْ ث إِسّمْحذْ.   
\m
\v 23 ڒعْذُو وَارْ ث إِسَّاڭّْوَاذْ،  
\m مِّيسْ ن ڒْمُوعْصِييّثْ وَارْ ث إِحصَّارْ. \x ◘ \xo 89:‏23 \xt 2 صم. 7‏:‏10؛ 2 Th. 2‏:‏3. \x*   
\b  
\m
\v 24 إِنِّي ث إِحصَّارنْ أَذْ ثنْ ڒبْزغْ  
\m زَّاثْ إِ وُوذمْ نّسْ،  
\m إِنِّي ث إِشَارّْهنْ أَذْ ثنْ وْثغْ.   
\m
\v 25 \bd ڒَْامَانْ إِنُو\bd* ذ \bd ثْمخْسِيوْثْ إِنُو إِشوَّارنْ\bd*،  
\m أَقَا أَثنْ أَكِيذسْ \add إِ غَا يِيڒِينْ\add*،  
\m أَذْ إِتّْوَاسّْڭعّذْ يِيشّْ نّسْ س يِيسمْ إِنُو.   
\m
\v 26 أَذْ سَّارْسغْ أَفُوسْ نّسْ خْ ڒبْحَارْ،  
\m أَفُوسْ نّسْ أَفُوسِي خْ إِغزْرَانْ.   
\b  
\m
\v 27 نتَّا أَذْ خَافِي د-إِڒَاغَا:  
\m ’أَقَا شكْ ذ بَابَا إِنُو، أَربِّي إِنُو،  
\m ذ ثَاصْضَارْثْ ن ؤُسنْجمْ إِنُو!‘ \x ◘ \xo 89:‏27 \xt 2 صم. 7‏:‏14؛ عبر. 1‏:‏4، 5\x*   
\m
\v 28 نشّْ أَذْ ث ڭّغْ ذ أَمنْزُو \add إِنُو\add*،  
\m أَمْعُودْجِي خْ إِجدْجِيذنْ ن ثمُّورْثْ. \x ◘ \xo 89:‏28 \xt كُول. 1‏:‏15، 18؛ عبر. 1‏:‏6؛ أَسَا. 1‏:‏5\x*   
\b  
\m
\v 29 إِ ڒبْذَا أَذْ حْضِيغْ  
\m \bd ثَامخْسِيوْثْ إِنُو إِشوَّارنْ\bd* زَّاثسْ،  
\m ؤُ ڒْعَاهْذْ إِنُو أَذْ غَارسْ إِقِّيمْ س ڒْمَانثْ.   
\m
\v 30 أَذْ ژُّوغْ زَّارِيعثْ نّسْ إِ ڒبْذَا،  
\m ڒْْعَارْشْ نّسْ مِينْ غَا كّنْ  
\m ؤُسَّانْ ن ؤُجنَّا دْجَانْ.   
\b  
\m
\v 31 مَاڒَا إِحنْجِيرنْ نّسْ حيّْذنْ  
\m خْ شَّارِيعَا إِنُو،  
\m وَارْ ڭُّورنْ أَكْ-ذ لْفَارَايِيضْ إِنُو، \x ◘ \xo 89:‏31 \xt 2 صم. 7‏:‏14\x*   
\m
\v 32 مَاڒَا سّْفسْذنْ ثِيوصَّا إِنُو،  
\m وَارْ حطِّينْ ڒُومُورَاثْ إِنُو،   
\b  
\m
\v 33 \add خنِّي\add* أَذْ خدْجْصغْ  
\m أَعدُّو نْسنْ س وعْمُوذْ،  
\m ڒْْمُوعْصِييّثْ نْسنْ س ثيِّيثَا.   
\m
\v 34 \add مَاشَا\add* وَارْ خَاسنْ تّكّْسغْ  
\m \bd ثَامخْسِيوْثْ إِنُو إِشوَّارنْ\bd*،  
\m وَارْ نكَّارغْ \bd ڒْْمَانثْ إِنُو\bd*.   
\b  
\m
\v 35 وَارْ تّْغصَّابغْ ڒْعَاهْذْ إِنُو،  
\m مِينْ د-إِفّْغنْ زڭْ إِينْشِيشنْ إِنُو،  
\m وَارْ ث تّْبذِّيڒغْ.   
\m
\v 36 نشّْ جُّودْجغْ إِشْثْ ن ثْوَاڒَا  
\m غَارْ ثْقدَّاسْثْ إِنُو:  
\m ‘وَارْ سّْخَارِّيقغْعمَّارْصْ خْ ذَاوُوذْ!‘ \x ◘ \xo 89:‏36 \xt عبر. 6‏:‏13، 17، 18\x*   
\b  
\m
\v 37 زَّارِيعثْ نّسْ أَذْ ثقِّيمْ إِ ڒبْذَا،  
\m ؤُ ڒْعَارْشْ نّسْ \add أَذْ ذِينْ إِبدّْ\add* زَّاثِي  
\m أَمْ ثْفُوشْثْ.   
\m
\v 38 نتَّا أَذْ إِقِّيمْ إِبدّْ إِ ڒبْذَا أَمْ ثْزِيرِي  
\m ؤُ أَشهَّاذْ ذڭْ إِسيْنُو\add ثنْ\add*  
\m أَقَا-ث ذ أَمْثِيقِّي.“ سِيلَاهْ. \x ◘ \xo 89:‏38 \xt أَيُوبْ 16‏:‏19‏-‏21، دَان. 7‏:‏13، أَسَا. 1‏:‏5، 7؛ أَسَا. 14‏:‏14\x*   
\b  
\m
\v 39 \add مَاشَا\add* شكْ ثْعَارّْنذْ ث غَارْ ؤُغزْذِيسْ،  
\m ثنْضَارذْ ث،  
\m شكْ ثْفُوڭّْمذْ خْ ؤُمذْهُونْ نّشْ.   
\m
\v 40 شكْ ثنْضَارذْ ڒْعَاهْذْ  
\m أَكْ-ذ ؤُمْسخَّارْ نّشْ،  
\m ثْفسْذذْ تَّاجْ \add ن وعْزَاڒْ\add* نّسْ  
\m \add س ؤُبدْجَاعْ\add* ن ثمُّورْثْ.   
\b  
\m
\v 41 ثْغضْڒذْ مَارَّا ڒحْيُوذْ نّسْ،  
\m ثْهذْمذْ ثِيندَّامْ نْسنْ إِفَارْينْ.   
\m
\v 42 مَارَّا إِنِّي د-إِكِّينْ أَبْرِيذْ كشّْضنْ ث،  
\m نتَّا إِذْوڒْ ذ أَسحْقَارْ إِ جِّيرَانْ نّسْ. \x ◘ \xo 89:‏42 \xt إِزهد. 80‏:‏13\x*   
\b  
\m
\v 43 شكْ ثسّْڭعّْذذْ أَفُوسْ أَفُوسِي  
\m ن يِينِّي ث إِحصَّارنْ،  
\m ثسّْفَارّْحذْ مَارَّا ڒْعذْيَانْ نّسْ.   
\m
\v 44 شكْ ثسّنْقڒْبذْ ڒقْضعْ ن سِّيفْ نّسْ،  
\m شكْ ثجِّيذْ ث وَارْ إِتّْغِيمِي إِبدّْ ذڭْ ؤُمنْغِي.   
\b  
\m
\v 45 شكْ ثسّْبدّذْ أَژْرِي نّسْ،  
\m ڒْْكُورْسِي نّسْ إِڭلّْذنْ  
\m ثنْضَارذْ ث غَارْ ثمُّورْثْ.   
\m
\v 46 شكْ ثسّمْژِيذْ أَسْ ؤُسَّانْ ن ثمْژِي نّسْ،  
\m ثذْڒِيذْ ث س ڒفْضِيحثْ. سِيلَاهْ.   
\b  
\m
\v 47 أَڒْ مڒْمِي عَاذْ، \add أَ\add* سِيذِي،  
\m أَذْ ثسّْنُوفَّارذْ إِخفْ نّشْ بْڒَا قطُّو،  
\m أَذْ يَارْغْ وسْعَارْ نّشْ أَمْ ثْمسِّي؟   
\m
\v 48 عْقڒْ خْ ڒْمِيجَاڒْ ن ثُوذَارْثْ إِنُو!  
\m مَايمِّي د-ثْخڒْقذْ  
\m مَارَّا أَرَّاوْ ن بْنَاذمْ أَمنِّي بَاطڒْ؟   
\m
\v 49 مَانْ أَرْيَازْ إِجهْذنْ وَارْ إِتّْوِيڒِي ڒْموْثْ،  
\m \add مَانْ أَرْيَازْ\add* إِ غَا إِفكّنْ ڒعْمَارْ نّسْ  
\m زڭْ ؤُفُوسْ ن ڒَاخَارْثْ؟ سِيلَاهْ. \x ◘ \xo 89:‏49 \xt إِزهد. 49‏:‏10، 16\x*   
\b  
\m
\v 50 \add أَ\add* سِيذِي إِنُو، مَانِي دْجَانْثْ  
\m \bd ثْمڭَّا ن ثْمخْسِيوْثْ نّشْ\bd* ن زِيشْ،  
\m ثِينِّي خْ ثُوغَا ثجُّودْجذْ إِ ذَاوُوذْ  
\m س \bd ڒْْمَانثْ نّشْ\bd*؟ \x ◘ \xo 89:‏50 \xt 2 صم. 7‏:‏15\x*   
\m
\v 51 \add أَ\add* سِيذِي إِنُو، عْقڒْ  
\m خْ ؤُسحْقَارْ ن إِمْسخَّارنْ نّشْ،  
\m نِّي أَربُّوغْ ذڭْ وحْسِينْ إِنُو  
\m زڭْ ؤُبَارُّو ن مَارَّا ڒڭْنُوسْ، \f ◼ \fr 89:‏51 \ft \+bd ’أَحْسِينْ‘\+bd* - نِيغْ ’أَبحْرُورْ‘.\f*   
\m
\v 52 إِ زِي ذ أَيِي سّحْقَارَانْ  
\m ڒْْعذْيَانْ نّشْ، \add أَ\add* سِيذِي،  
\m إِ زِي سّحْقَارَانْ إِصُورَافْ ن ؤُمذْهُونْ نّشْ.   
\b  
\m
\v 53 أَذْ إِتّْوَابَاركْ سِيذِي إِ ڒبْذَا قَاعْ!  
\m أَمِينْ، \add وَاهْ،\add* أَمِينْ!   
\b  
\b  
\m  
\c 90
\s1 أَذْلِيسْ وِيسّْ أَربْعَا: إِزهِّيذنْ 90-106  
\m
\v 1 \add ثَاژَادْجِيثْ ن مُوسَا، أَرْيَازْ ن أَربِّي.\add*  
\b  
\m \add أَ\add* سِيذِي إِنُو،  
\m شكْ ثُوغَا ذ ثَازذِّيغْثْ نّغْ  
\m زِي جِّيڒْ أَڒْ جِّيڒْ. \x ◘ \xo 90:‏1 \xt أَعَوذ. 33‏:‏1، 27\x*   
\m
\v 2 قْبڒْ مَا أَذْ إِڒِينْ إِذُورَارْ،  
\m قْبڒْ مَا أَذْ د-ثسُّوفّْغذْ  
\m ثَامُّورْثْ ذ دُّونشْثْ،  
\m \add وَاهْ\add* أَقَا شكْ ذ أَربِّي  
\m زِي ڒبْذَا أَڒْ ڒبْذَا.   
\m
\v 3 شكْ ثجِّيذْ بْنَاذمْ  
\m أَذْ إِعْقبْ غَارْ ثْعجَّاجْثْ.  
\m ثقَّارذْ:  
\m ”عقْبتِّيوْ-د ثَارْوَا ن بْنَاذمْ!“   
\m
\v 4 مَاغَارْ أَڒفْ ن إِسڭّْوُوسَا  
\m ذِي ثِيطَّاوِينْ نّشْ  
\m أَمْ وَاسّْ ن إِضنَّاضْ نِّي إِعْذُونْ،  
\m ؤُڒَا أَمْ يِيشْثْ ن \add نُّوبثْ ن\add* ثْعسَّاسْثْ ذِي دْجِيڒثْ. \x ◘ \xo 90:‏4 \xt 2 بُط. 3‏:‏8\x*   
\b  
\m
\v 5 شكْ ثْفَارْضذْ ثنْ، أَقَا أَثنْ أَمْ يِيضصْ.  
\m غَارْ ثُوفُّوثْ ڭِّينْ أَمْ أَرْبِيعْ إِيمَّانْ.   
\m
\v 6 غَارْ ثُوفُّوثْ إِتّْزيْزِيوْ \add أَرّْبِيعْ\add*  
\m ؤُشَا إِيمَّا،  
\m غَارْ ثْمذِّيثْ إِتّْوَامْجَارْ، إِتَّاژغْ.   
\m
\v 7 مَاغَارْ نشِّينْ نفْنَا س وغْضَابْ نّشْ،  
\m ننّخْڒعْ زڭْ وسْعَارْ نّشْ.   
\m
\v 8 شكْ ثڭِّيذْ ڒْمُوعْصِييّثْ نّغْ  
\m قِيبَاتْشْ نّشْ،  
\m دّْنُوبْ نّغْ إِنُّوفَّارنْ  
\m ذِي ثْفَاوْثْ ن وُوذمْ نّشْ.   
\b  
\m
\v 9 مَاغَارْ مَارَّا ؤُسَّانْ نّغْ أَذْ عْذُونْ  
\m ذڭْ ؤُفُوڭمْ نّشْ إِسّڭّْوَاذنْ،  
\m نسّعْذُو إِسڭّْوُوسَا نّغْ  
\m أَمْ يِيجّْ ن ؤُسُوضِي.   
\m
\v 10 ؤُسَّانْ ن ثُوذَارْثْ نّغْ  
\m تّكّنْ سبْعِينْ ن إِسڭّْوُوسَا،  
\m نِيغْ، مڒْمِي إِ غَا نِيڒِي نجْهذْ،  
\m أَقَا ثْمَانْيِينْ ن إِسڭّْوُوسَا.  
\m مِينْ ذَايسْ ذ أَعُودْجِي،  
\m \add إِتَّارُو-د\add* ثَامَارَا ذ ڒْوحْرَانْ،  
\m ذغْيَا ثتّكّْ ثْعدُّو ؤُ نطَّاوْ غَارْ ذِينْ.   
\m
\v 11 مَانْ ونْ إِسّْننْ  
\m ڒْْقسْحَانْ ن وغْضَابْ نّشْ،  
\m \add ؤُ مَانْ ونْ إِسّْننْ\add* ثِيڭّْوُوذِي زَّايكْ  
\m \add أَمْ د-إِتّْڒِيقْ\add*  
\m أَكْ-ذ أَذُوقّزْ نّشْ \add ن ؤُفُوڭمْ\add*؟   
\m
\v 12 سڒْمذْ أَنغْ أَذْ نْحسّبْ ؤُسَّانْ نّغْ،  
\m حِيمَا أَذْ د-نَاوِي ؤُڒْ \add إِشُّورنْ س\add* ثِيغِيثْ.   
\b  
\m
\v 13 ذْوڒْ-د، \add أَ\add* سِيذِي، أَڒْ مڒْمِي؟  
\m حِينّْ خْ إِمْسخَّارنْ نّشْ. \x ◘ \xo 90:‏13 \xt أَعَوذ. 32‏:‏36؛ إِزهد. 135‏:‏14\x*   
\m
\v 14 سْجِّيونْ أَنغْ غَارْ \add ؤُ\add*ثفُّو  
\m س ثْمخْسِيوْثْ نّشْ إِشوَّارنْ،  
\m \add خنِّي\add* أَذْ نسْڒِيوْڒوْ،  
\m أَذْ نْفَارْحْ مَارَّا ؤُسَّانْ نّغْ.   
\m
\v 15 سْفَارْحْ أَنغْ أَنشْثْ ن وُوسَّانْ  
\m إِ ذ أَنغْ ثحْصَارذْ،  
\m \add أَنشْثْ ن\add* إِسڭّْوُوسَا إِ ذِي نژْرَا ڒْغَارْ.   
\m
\v 16 سْشنْ ڒْخذْمثْ نّشْ إِ إِمْسخَّارنْ نّشْ،  
\m ڒْعزّْ نّشْ خْ إِحنْجِيرنْ نْسنْ.   
\m
\v 17 أَذْ خَانغْ ثهْوَا  
\m ڒضْرَافثْ ن سِيذِي، أَربِّي نّغْ،  
\m ضْمنْ شكْ ڒْخذْمثْ ن إِفَاسّنْ نّغْ،  
\m \add وَاهْ\add*، ڒْخذْمثْ ن إِفَاسّنْ نّغْ ضْمنْ إِ-ت.   
\b  
\b  
\m  
\c 91
\m
\v 1 \add ثْمِيجَّا ثَامزْوَارُوثْ:\add*  
\m ونِّي إِزدّْغنْ  
\m ذڭْ ؤُذُورِّي ن ؤُمْعُودْجِي خْ كُوڒْشِي،  
\m أَقَا نتَّا أَذْ إِسّنْسْ  
\m ذِي ثِيڒِي ن ؤُمْزمَّارْ خْ كُوڒْشِي.   
\b  
\m
\v 2 \add ثْمِيجَّا وِيسّْ ثْنَاينْ:\add*  
\m أَذْ إِنِيغْ إِ سِيذِي:  
\m \add شكْ\add* ذ أَمْشَانْ إِنُو ن ثَاروْڒَا ذ لْبُورْجْ إِنُو،  
\m أَربِّي إِنُو، ونِّي خْ تّشْڒغْ!   
\b  
\m
\v 3 \add ثْمِيجَّا ثَامزْوَارُوثْ:\add*  
\m مَاغَارْ نتَّا أَذْ شكْ إِفكّْ  
\m زِي ڒْفخْ ن إِنيْمَارنْ ن إِجْضَاضْ،  
\m زِي طَّاعُونْ يَاردّْدْجنْ. \x ◘ \xo 91:‏3 \xt إِزهد. 124‏:‏7\x*   
\m
\v 4 س أَرِّيشْ نّسْ أَذْ شكْ إِذڒْ،  
\m سَاذُو وَافْرِيونْ نّسْ أَذْ ثَافذْ أَذُورِّي.  
\m ڒْْمَانثْ نّسْ ذ ثَاسدَّارْثْ ثَامقّْرَانْثْ  
\m ذ أَرُّوضْ ن وُوزَّاڒْ. \x ◘ \xo 91:‏4 \xt إِزهد. 57‏:‏2\x*   
\m
\v 5 وَارْ ثتّڭّْوذذْ شَا  
\m زڭْ ؤُنخْڒِيعْ ن دْجِيڒثْ،  
\m زِي فْڒِيثْشَا ن ڒْقوْسْ إِ \add ذِينْ\add* إِطَّاونْ س وَاسّْ، \x ◘ \xo 91:‏5 \xt أَيُوبْ 5‏:‏19، 20؛ أَوڒن. 3‏:‏25؛ إِزْڒِي 3‏:‏8\x*   
\m
\v 6 ؤُڒَا زِي طَّاعُونْ إِ د-إِتّنّْضنْ ذِي ثَادْجسْثْ،  
\m زِي لْهَالَاكْ إِ يَاردّْدْجنْ س ؤُزِيڒْ.   
\m
\v 7 وَاخَّا أَذْ وْضَانْ أَڒفْ غَارْ ؤُغزْذِيسْ نّشْ  
\m ؤُعشْرَا أَڒفْ غَارْ أَفُوسْ أَفُوسِي نّشْ،  
\m \add عَاذْ\add* وَارْ شكْ د-إِتِّيكّْوِيضْ.   
\m
\v 8 أَذْ ثْوَاڒِيذْ أَيَا س ثِيطَّاوِينْ نّشْ وَاهَا،  
\m أَذْ ثْژَارذْ مَامّشْ غَا إِتّْوَاخْڒفْ  
\m زڭْ إِعفَّاننْ.   
\b  
\m
\v 9 \add ثْمِيجَّا وِيسّْ ثْنَاينْ:\add*  
\m مَاغَارْ \add خَاكْ\add*:  
\m ’شكْ \add أَ\add* سِيذِي، أَقَا شكْ  
\m ذ أَمْشَانْ إِنُو ن ثَاروْڒَا!‘  
\b  
\m \add ثْمِيجَّا ثَامزْوَارُوثْ\add*  
\m أَقَا شكْ ثڭِّيذْ أَمْعُودْجِي خْ كُوڒْشِي  
\m ذ ثَازذِّيغْثْ إِ يِيخفْ نّشْ،   
\m
\v 10 وَارْ ذَايكْ ثْنطّحْ ثُوعفّْنَا،  
\m ؤُڒَا ذ إِشْثْ ن جّْرِيحشْثْ  
\m وَارْ د-ثْقَارَّابْ شَا غَارْ ؤُقِيضُونْ نّشْ،   
\m
\v 11 مَاغَارْ نتَّا أَذْ خَاكْ يُومُورْ  
\m لْمَالَاكَاثْ نّسْ،  
\m مَاحنْذْ أَذْ شكْ حْضَانْثْ  
\m ذِي مَارَّا إِبْرِيذنْ نّشْ. \x ◘ \xo 91:‏11 \xt إِزهد. 34‏:‏8؛ مت. 4‏:‏6؛ لك. 4‏:‏10\x*   
\m
\v 12 أَذْ شكْ كْسِينْ خْ إِفَاسّنْ نْسنْثْ،  
\m حِيمَا أَضَارْ نّشْ وَارْ إِنڭّحْ أَژْرُو. \x ◘ \xo 91:‏12 \xt لك. 4‏:‏11\x*   
\m
\v 13 أَذْ ثْعفْسذْ خْ ويْرَاذْ إِزهَّارنْ  
\m ؤُ خْ ثْڒفْسَا،  
\m أَذْ ثْعجْنذْ خْ ويْرَاذْ أَمژْيَانْ  
\m ذ ڒْهَايْشثْ \add ن ڒبْحَارْ\add*. \x ◘ \xo 91:‏13 \xt أَيُوبْ 5‏:‏22، 23\x*   
\b  
\m
\v 14 \add ثْمِيجَّا وِيسّْ ثْڒَاثَا زِي أَربِّي:\add*  
\m ؤُمِي د-إِقّنْ نتَّا غَارِي،  
\m نشّْ أَذْ ث سّْنجْمغْ.  
\m نشّْ أَذْ ث سّْڭعّْذغْ،  
\m مَاغَارْ نتَّا إِسّنْ إِسمْ إِنُو.   
\m
\v 15 نتَّا أَذْ أَيِي إِڒَاغَا  
\m ؤُ نشّْ أَذْ خَاسْ د-أَرّغْ.  
\m ذِي ڒحْصَارثْ أَقَا أَيِي غَارسْ.  
\m نشّْ أَذْ ث فكّغْ، أَذْ أَسْ سّْعُودْجغْ.   
\m
\v 16 نشّْ أَذْ ث سّْجِّيوْنغْ  
\m أَكْ-ذ ثُوزّڭَّارْثْ ن وُوسَّانْ،  
\m نشّْ أَذْ أَسْ سّشْنغْ أَسنْجمْ إِنُو.   
\b  
\b  
\m  
\c 92
\m
\v 1 \add أَزهِّيذْ. إِجّْ ن إِزْڒِي إِ وَاسّْ ن سّبْثْ.\add*   
\b  
\m
\v 2 مَامّشْ إِصْبحْ  
\m مَاحنْذْ أَذْ نْقَاذَا سِيذِي،  
\m أَذْ نْزهّذْ إِ يِيسمْ نّشْ،  
\m \add أَ\add* أَمْعُودْجِي خْ كُوڒْشِي،   
\m
\v 3 مَاحنْذْ أَذْ نْبَارّحْ  
\m س ثْمخْسِيوْثْ نّشْ إِشوَّارنْ  
\m غَارْ ثُوفُّوثْ،  
\m ڒَْامَانْ نّشْ ذِي دْجْيَاڒِي،   
\m
\v 4 \add ذِي لهَارْبَا\add* سعشْرَا ن إِفِيڒَانْ ؤُ ذِي لهَارْبَا،  
\m س \add ثِيرَارْثْ خْ\add* إِفِيڒَانْ ن ڒْڭَامْبْرِي.   
\b  
\m
\v 5 مَاغَارْ شكْ ثسّْفَارْحذْ أَيِي،  
\m \add أَ\add* سِيذِي، س ثْمڭَّا نّشْ،  
\m نشّْ أَذْ سْڒِيوڒْوغْ  
\m خْ ڒفْعَايڒْ ن إِفَاسّنْ نّشْ.   
\m
\v 6 مَامّشْ مْغَارنْثْ ثْمڭَّا نّشْ، \add أَ\add* سِيذِي،  
\m مَامّشْ ؤُدْجْغنْ إِخَارِّيصنْ نّشْ!   
\m
\v 7 إِجّْ ن ؤُقفُّوحْ وَارْ غَارسْ مِينْ غَا إِعَاوذْ،  
\m إِجّْ ن ؤُبُوهَاڒِي وَارْ إِفهّمْ مَانْ أَيَا.   
\b  
\m
\v 8 مَاڒَا إِعفَّاننْغمّْينْ أَمْ أَرْبِيعْ،  
\m ؤُ مَارَّا إِنِّي إِتّڭّنْ ڒْمُوعْصِييّثْ  
\m تّْنوَّارنْ،  
\m \add أَقَا أَيَا أَذْ إِسِّيوضْ\add* أَثحِّي نْسنْ  
\m إِ ڒبْذَا قَاعْ.   
\m
\v 9 شكْ ذ أَمْعُودْجِي خْ كُوڒْشِي إِ ڒبْذَا، \add أَ\add* سِيذِي!   
\m
\v 10 مَاغَارْ خْزَارْ، ڒْعذْيَانْ نّشْ، سِيذِي،  
\m ڒْعذْيَانْ نّشْ أَذْ فْنَانْ،  
\m مَارَّا إِنِّي إِتّڭّنْ ڒْغشّْ  
\m أَذْ تّْوَازدْجْعنْ.   
\b  
\m
\v 11 شكْ أَذْ ثسّْڭعّْذذْ أَشَّاوْ إِنُو  
\m أَمْ ونِّي ن إِغَايْضْ ن ڒخْڒَا  
\m أَكْ-ذ وَاشَّاونْ ذ إِزِيرَارنْ،  
\m تّْوَاذهْنغْ س زّشْثْ ن طْرِي.   
\m
\v 12 ثِيطّْ إِنُو أَذْ ثْژَارْ إِنِّي خَافِي إِتّْشكّْمنْ،  
\m إِمزُّوغنْ إِنُو أَذْ سْڒنْ إِ إِغْرِيمنْ إِنُو  
\m إِنِّي خَافِي د-إِكَّارنْ.   
\m
\v 13 أَمْسڭّذْ أَذْ إِنوَّارْ  
\m أَمْ ثْشجَّارْثْ ن ثِينِي،  
\m أَذْ إِغْمِي أَمْ ثْشجَّارْثْ ن ثنْڭلْثْ  
\m خْ \add إِذُورَارْ ن\add* لُوبْنَانْ، \x ◘ \xo 92:‏13 \xt ڒقض. 9‏:‏15؛ حُوش. 14‏:‏6\x*   
\b  
\m
\v 14 إِنِّي إِتّْوَاژُّونْ ذِي ثَادَّارْثْ ن سِيذِي،  
\m أَذْ نُّووَارنْ  
\m ذِي ڒمْرَاحَاثْ ن أَربِّي نّغْ.   
\m
\v 15 نِيثْنِي أَذْ وْشنْ ڒْغِيدْجثْ ذِي ثوْسَارْ،  
\m أَذْ قِّيمنْ صحّنْ ذ طْرِي.   
\m
\v 16 مَاحنْذْ أَذْ بَارّْحنْ،  
\m بلِّي سِيذِي أَقَا-ث نِيشَانْ.  
\m نتَّا ذ ثَاصْضَارْثْ إِنُو  
\m ؤُ وَارْ ذَايسْ بُو ڒْغشّْ.   
\b  
\b  
\m  
\c 93
\m
\v 1 سِيذِي إِحكّمْ،  
\m نتَّا يَارْضْ س لْعَاضَامَا،  
\m سِيذِي يَارْضْ س جّهْذْ أَمْ س يِيجّْ ن ؤُحزَّامْ.  
\m وَاهْ، دُّونشْثْ ثْبدّْ ثمْثنْ،  
\m وَارْ ثتّنْهزِّي شَا. \x ◘ \xo 93:‏1 \xt إِزهد. 2‏:‏6؛ 24‏:‏8، 10\x*   
\b  
\m
\v 2 ڒْكُورْسِي إِڭلّْذنْ نّشْ إِمْثنْ  
\m زِي مشْحَاڒْ ؤُيَا،  
\m شكْ ثدْجِيذْ زِي ڒبْذَا.   
\b  
\m
\v 3 إِغزْرَانْ سّْڭعّْذنْ، \add أَ\add* سِيذِي،  
\m إِغزْرَانْ سّْڭعّْذنْ ثْمِيجَّا نْسنْ.  
\m إِغزْرَانْ أَذْ سّْڭعّْذنْ  
\m \add ڒْْحسّْ ن\add* زّْهِيرْ نْسنْ.   
\b  
\m
\v 4 سِيذِي ذِي ڒُوعْڒَا إِجْهذْ خْ زّْهِيرْ  
\m ن وَاطَّاسْ ن وَامَانْ إِجهْذنْ  
\m ؤُ خْ ؤُهَاجِي ن ڒبْحَارْ.   
\b  
\m
\v 5 شّْهَاذَاثْ نّشْ أَقَا ذَايْسنْثْ ڒَامَانْ.  
\m ثَاقدَّاسْثْ ثْزهّجْ إِ ثَادَّارْثْ نّشْ،  
\m \add أَ\add* سِيذِي، أَڒْ مَارَّا ؤُسَّانْ.   
\b  
\b  
\m  
\c 94
\m
\v 1 \add أَ\add* أَربِّي ن ؤُنْثَاقمْ، \add أَ\add* سِيذِي،  
\m أَربِّي ن ؤُنْثَاقمْ،  
\m بَانْ-د ذِي ثِيسِّيقْثْ!   
\m
\v 2 \add أَ،\add* ڒْقَاضِي ن ثمُّورْثْ، سْڭعّذْ إِخفْ نّشْ،  
\m أَرّْ ثَاسْغَارْثْ إِ إِمْعفَّارنْ  
\m أَمْ مِينْ سّْذَاحدْجنْ نِيثْنِي.   
\m
\v 3 مشْحَاڒْ إِ غَا كّنْ عَاذْ إِعفَّاننْ، \add أَ\add* سِيذِي،  
\m مشْحَاڒْ إِ غَا كّنْ نڭّْزنْ  
\m إِعفَّاننْ س ڒفْرَاحثْ،   
\b  
\m
\v 4 أَذْ قِّيمنْ سَّاوَاڒنْ أَوَاڒنْ إِقسْحنْ،  
\m \add مشْحَاڒْ\add* إِ غَا قِّيمنْ مَارَّا  
\m إِنِّي إِتّڭّنْ ڒْمُوعْصِييّثْ  
\m أَذْ سّمْغَارنْ إِخفْ نْسنْ؟   
\m
\v 5 \add أَ\add* سِيذِي، نِيثْنِي ڒبّْزنْ ڒْڭنْسْ نّشْ،  
\m حصَّارنْ ثَاسْغَارْثْ ن ڒْوَارْثْ نّشْ.   
\m
\v 6 نِيثْنِي نقّنْ ثَاجَّاتْشْ ذ ؤُبَارَّانِي،  
\m غَارّْصنْ إِ إِيُوجِيڒنْ.   
\m
\v 7 نِيثْنِي قَّارنْ: ”سِيذِي وَارْ ت إِتّْوِيڒِي،  
\m أَربِّي ن يَاعْقُوبْ وَارْ ذ أَسْ إِتّْحكَّارْ.“ \x ◘ \xo 94:‏7 \xt إِزهد. 10‏:‏11، 13؛ 59‏:‏8\x*   
\b  
\m
\v 8 فثْنمْ كنِّيوْ إِقفُّوحنْ ذِي ڒْڭنْسْ،  
\m \add جْمِيعْ\add* أَكْ-ذ إِبُوهَاڒِييّنْ،  
\m مڒْمِي إِ غَا ثْذوْڒمْ ثْفهّْممْ؟ \x ◘ \xo 94:‏8 \xt إِزهد. 92‏:‏7\x*   
\m
\v 9 مَا وَارْ إِتّسْڒِي ونِّي إِژُّونْ أَمزُّوغْ؟  
\m مَا وَارْ إِژَارّْ ونِّي إِڭِّينْ ثِيطّْ؟ \x ◘ \xo 94:‏9 \xt ؤُف. 4‏:‏11\x*   
\m
\v 10 مَا وَارْ إِتّْعَاقبْ  
\m ونِّي إِتّْوبّْخنْ ڒڭْنُوسْ،  
\m ونِّي إِسّڒْمَاذنْ ثُوسّْنَا إِ بْنَاذمْ؟   
\m
\v 11 سِيذِي يَارڭّبْ خْ إِخَارِّيصنْ ن إِوْذَانْ،  
\m أَقَا أَثنْ أَمْ يِيجّْ ن ؤُسُوضِي وَاهَا. \x ◘ \xo 94:‏11 \xt 1 كُور. 3‏:‏20\x*   
\b  
\m
\v 12 سّعْذْ ن ورْيَازْ نِّي ثتّْوبّْخذْ، \add أَ\add* سِيذِي،  
\m ونِّي ثسّڒْمَاذذْ زِي شَّارِيعَا نّشْ،   
\m
\v 13 حِيمَا أَذْ ث ثسَّاريّحذْ  
\m زڭْ وُوسَّانْ إِعفّْننْ،  
\m أَڒْ غَا حْفَارنْ أَحْفُورْ ن ثُورْصُوضِي إِ ؤُعفَّانْ.   
\m
\v 14 مَاغَارْ سِيذِي وَارْ إِنطَّارْ ڒْڭنْسْ نّسْ،  
\m وَارْ إِسمّحْ ذِي ثسْغَارْثْ نّسْ. \x ◘ \xo 94:‏14 \xt 1 صم. 12‏:‏22؛ رُوم. 11‏:‏1، 2\x*   
\m
\v 15 مَاغَارْ ڒْحُوكْمْ أَذْ د-إِذْوڒْ غَارْ ثْسڭْذَا،  
\m مَارَّا إِنِّي غَارْسنْ ؤُڒْ إِسڭّْمنْ  
\m أَذْ ت-إِ-د-ضفَّارنْ.   
\b  
\m
\v 16 مَانْ ونْ كِيذِي إِ غَا إِبدّنْ  
\m ضِيدّْ إِ إِعفَّاننْ؟  
\m مَانْ ونْ خَافِي إِ غَا إِوْثنْ  
\m ضِيدّْ إِ يِينِّي إِتّڭّنْ ڒْغشّْ؟   
\m
\v 17 مْڒِي وَارْ إِدْجِي سِيذِي ذ ثْوِيزَا إِنُو،  
\m إِڒِي إِزْذغْ ڒعْمَارْ إِنُو عْڒَاحَاڒْ  
\m ذڭْ وسْغَاضْ. \f ◼ \fr 94:‏17 \ft \+bd أَسْغَاضْ\+bd* - ذ مَانْ أَيَا إِخْسْ أَذْ يِينِي ’ذڭْ ؤُنُورِي‘.\f*   
\m
\v 18 مَاڒَا نِّيغْ: ’أَضَارْ إِنُو إِتّفْرِيغْ!‘،  
\m \add خنِّي\add* ثطّفْ أَيِي  
\m ثْمخْسِيوْثْ نّشْ إِشوَّارنْ، \add أَ\add* سِيذِي!   
\m
\v 19 مَاڒَا مَّارْنِينْ ذَايِي إِخَارِّيصنْ  
\m أَڒْ طَّارْفْ،  
\m ثُوغَا ڒعْمَارْ إِنُو إِتَّارّْ مژْرِي  
\m ذڭْ ؤُسْفوّجْ نّشْ.   
\b  
\m
\v 20 مَا \add ثخْسذْ\add* أَذْ كِيذكْ إِسّْمُونْ  
\m ڒْْكُورْسِي ن ؤُهلّكْ،  
\m ونِّي إِسِّيوْضنْ ڒغْبنْ  
\m خْ \add ذْسَاسْ\add* ن ثوْصيّثْ؟   
\m
\v 21 نِيثْنِي حصَّارنْ ڒعْمَارْ ن ؤُمْسڭَّاذْ،  
\m شهّْذنْ خْ إِذَامّنْ إِمزْذَاڭنْ س ڒْغَارْ.   
\m
\v 22 سِيذِي ثُوغَا أَيِي ذ إِجّْ ن لْبُورْجْ يُوعْڒَانْ،  
\m أَربِّي إِنُو ذ ثَاصْضَارْثْ ن ثَاروْڒَا إِنُو.   
\m
\v 23 نتَّا أَذْ خَاسنْ إِسّعْقبْ  
\m ڒْمُوعْصِييّثْ نْسنْ،  
\m أَمْ تّڭّنْ ڒْغَارْ نْسنْ أَذْ ثنْ إِثحَّا.  
\m سِيذِي، أَربِّي نّغْ، أَذْ ثنْ إِثحَّا.   
\b  
\b  
\m  
\c 95
\m
\v 1 أَسمْ-د، أجّْ أَنغْ أَذْ نسْڒِيوْڒوْ زَّاثْ إِ سِيذِي،  
\m أجّْ أَنغْ أَذْ نْذُوقّزْ س ؤُسْڒِيوْڒوْ  
\m إِ ثصْضَارْثْ ن ؤُسنْجمْ نّغْ.   
\m
\v 2 أجّْ أَنغْ أَذْ نَاذسْ  
\m غَارْ وُوذمْ نّسْ س ؤُقَاذِي،  
\m أجّْ أَنغْ أَذْ أَسْ نسْڒِيوْڒوْ س إِزهِّيذنْ.   
\b  
\m
\v 3 مَاغَارْ سِيذِي \add ذ\add* إِجّْ أَربِّي ذ أَمقّْرَانْ،  
\m إِجّْ ن ؤُجدْجِيذْ ذ أَمقّْرَانْ  
\m سنّجْ إِ مَارَّا إِربِّيثنْ.   
\m
\v 4 ذڭْ ؤُفُوسْ نّسْ \add دْجَانْ\add*  
\m إِمُوشَانْ يُودْجْغنْ قَاعْ ن ثمُّورْثْ،  
\m ؤُڒَا ذ ثِيقِيشَّاثِينْ ن إِذُورَارْ  
\m \add أَقَا أَثنْثْ\add* نّسْ.   
\m
\v 5 نّسْ ڒبْحَارْ، مَاغَارْ إِخْڒقْ إِ-ث-إِ-د،  
\m ؤُ إِفَاسّنْ نّسْ ڭِّينْ ؤُڒَا ذ ڒْبَارْ.   
\m
\v 6 أَسمْ-د، أجّْ أَنغْ  
\m أَذْ \add أَسْ\add* نْبنْذقْ، أَذْ نسْجذْ،  
\m أجّْ أَنغْ أَذْ نسْجذْ خْ إِفَادّنْ زَّاثْ إِ سِيذِي،  
\m ونِّي ذ أَنغْ إِڭِّينْ،   
\m
\v 7 مَاغَارْ نتَّا ذ أَربِّي نّغْ  
\m ؤُ نشِّينْ ذ ڒْڭنْسْ ن ثَاروْسَا نّسْ،  
\m ؤُڒَا ذ ؤُدْجِي ن ؤُفُوسْ نّسْ.  
\m مَاڒَا أَسّْ-أَ ثْسدْجمْ غَارْ ثْمِيجَّا نّسْ، \x ◘ \xo 95:‏7 \xt إِزهد. 100‏:‏3؛ عبر. 3‏:‏7، 13، 15؛ 4‏:‏7\x*   
\m
\v 8 وَارْ سّقْسِيحمْ شَا ؤُڒْ نْومْ،  
\m أَمْ ذِي مَارِيبَا،  
\m أَمْ ذڭْ وَاسّْ ن مَاسَّا ذِي ڒخْڒَا، \x ◘ \xo 95:‏8 \xt ؤُف. 17‏:‏7؛ ڒخْڒ. 20‏:‏1، 3، 13؛ أَعَوذ. 6‏:‏16\x*   
\m
\v 9 مَانِي ثُوغَا ذ أَيِي تّْجَارّْبنْ  
\m ڒجْذُوذْ نْومْ،  
\m قدْجْبنْ أَيِي،  
\m وَاخَّا ثُوغَا ژْرِينْ ڒْخذْمثْ إِنُو. \x ◘ \xo 95:‏9 \xt عبر. 3‏:‏9\x*   
\m
\v 10 أَربْعِينْ ن إِسڭّْوُوسَا  
\m ثُوغَا تّْعِيفّغْ جِّيڒْ-أَ، نِّيغْ:  
\m ”أَقَا-ثنْ ذ إِجّْ ن ڒْڭنْسْ  
\m س وُوڒْ إِودَّارنْ،  
\m وَارْ سِّيننْ إِبْرِيذنْ إِنُو.“\x ◘ \xo 95:‏10 \xt عبر. 3‏:‏9، 10، 17\x*   
\m
\v 11 س ؤُينِّي نشّْ جُّودْجغْ  
\m ذڭْ وغْضَابْ إِنُو:  
\m ”نِيثْنِي وَارْ د-تِّيذْفنْعمَّارْصْ  
\m ذِي أَرَّاحثْ إِنُو!“ \x ◘ \xo 95:‏11 \xt عبر. 3‏:‏11، 18؛ 4‏:‏3، 5\x*   
\b  
\b  
\m  
\c 96
\m
\v 1 غنّْجمْ إِ سِيذِي إِجّْ ن يزْڒِي أَمَايْنُو،  
\m غنّْجمْ إِ سِيذِي، مَارَّا ثَامُّورْثْ! \x ◘ \xo 96:‏1 \xt 1 إِم. 16‏:‏23‏-‏33\x*   
\m
\v 2 غنّْجمْ إِ سِيذِي، بَارْكمْ إِسمْ نّسْ،  
\m بشَّارمْ إِ ؤُسنْجمْ نّسْ أَسّْ خْ وَاسّْ.   
\m
\v 3 بَارّْحمْ أَعُودْجِي نّسْ جَارْ ڒڭْنُوسْ،  
\m ڒعْجَايبْ نّسْ جَارْ مَارَّا ڒڭْنُوسْ.   
\b  
\m
\v 4 مَاغَارْ سِيذِي ذ أَمقّْرَانْ،  
\m إِسّْذَاحدْجْ أَسمْغَارْ أَطَّاسْ،  
\m نتَّا ذ أَمْسَاڭّْوذْ  
\m مَاهُو مَارَّا إِربِّيثنْ.   
\m
\v 5 مِينْزِي مَارَّا إِربِّيثنْ ن ڒڭْنُوسْ  
\m أَقَا أَثنْ ذ لْ-أَصْنَامْ،  
\m \add مَاشَا\add* سِيذِي إِڭَّا إِجنْوَانْ.   
\m
\v 6 ثِيسِّيقْثْ ذ ڒْعزّْ \add دْجَانْ\add* زَّاثْ إِ وُوذمْ نّسْ،  
\m جّهْذْ ذ وَاژْرِي أَقَا أَثنْ  
\m ذِي زَّاوشْثْ نّسْ إِقدّْسنْ.   
\b  
\m
\v 7 وْشمْ إِ سِيذِي، \add أَ،\add* ثِيقبَّاڒْ ن ڒڭْنُوسْ،  
\m وْشمْ إِ سِيذِي أَعُودْجِي ذ جّهْذْ.   
\m
\v 8 وْشمْ إِ سِيذِي أَعُودْجِي ن يِيسمْ نّسْ،  
\m أَوْيمْ-د ثَاوْهِيبْثْ،  
\m أَسمْ-د غَارْ ڒمْرَاحَاثْ نّسْ،   
\m
\v 9 بنْذقْ زَّاثْ إِ سِيذِي  
\m س ؤُشوَّارْ إِقدّْسنْ،  
\m أَرْجِيجمْ زَّاثْ إِ وُوذمْ نّسْ،  
\m \add أَ\add* مَارَّا ثَامُّورْثْ! \x ◘ \xo 96:‏9 \xt إِزهد. 29‏:‏2\x*   
\b  
\m
\v 10 إِنِيمْ جَارْ ڒڭْنُوسْ: ”سِيذِي إِحكّمْ!“  
\m نِيشَانْ، \add ڒخُّو\add* دُّونشْثْ ثْبدّْ ثمْثنْ،  
\m وَارْ تّنْهزِّي \add عَاذْ\add*.  
\m نتَّا أَذْ إِحْكمْ ڒڭْنُوسْ س ڒْحقّْ.   
\m
\v 11 أجّْ إِجنْوَانْ أَذْ فَارْحنْ  
\m ؤُ ثَامُّورْثْ أَذْ ثَارْشقْ،  
\m أجّْ أَذْ إِزْهَارْ ڒبْحَارْ ذ ؤُعمَّارْ نّسْ،   
\b  
\m
\v 12 أجّْ أَذْ إِسْڒِيوْڒِيوْ ييَّارْ س ڒفْرَاحثْ  
\m س مَارَّا مِينْ ذَايسْ،  
\m خنِّي أَذْ سْڒِيوْڒِيونْثْ  
\m مَارَّا ثْشجُّورَا ن وزْغَارْ \f ◼ \fr 96:‏12 \ft \+bd ’أَزْغَارْ‘\+bd* - نِيغْ ’ڒْغَابثْ‘ نِيغْ ’ثَازْڭَانْثْ‘.\f*   
\m
\v 13 زَّاثْ إِ وُوذمْ ن سِيذِي،  
\m مَاغَارْ نتَّا أَذْ د-يَاسْ،  
\m مَاغَارْ نتَّا أَذْ د-يَاسْ  
\m حِيمَا أَذْ إِشَارّعْ ثَامُّورْثْ.  
\m نتَّا أَذْ إِشَارّعْ دُّونشْثْ س ثْسڭْذَا  
\m ؤُ ڒڭْنُوسْ س ڒْحقّْ نّسْ. \x ◘ \xo 96:‏13 \xt إِزهد. 98‏:‏9؛ أَسَا. 19‏:‏11\x*   
\b  
\b  
\m  
\c 97
\m
\v 1 سِيذِي إِحكّمْ،  
\m أجّْ ثَامُّورْثْ أَذْ ثْفَارْحْ،  
\m أَذْ أَرشْقنْثْ مَارَّا ثڭْزِيرِينْ. \x ◘ \xo 97:‏1 \xt إِزهد. 93‏:‏1؛ 96‏:‏10\x*   
\m
\v 2 قُووَّارنْ أَسْ إِسيْنُوثنْ  
\m ذ يِيجّْ ن ؤُسيْنُو إِبُّومْبسْ،  
\m ثَاسڭْذَا ذ ڒْحقّْ  
\m أَقَا أَثنْ ذ ذْسَاسْ ن ڒْعَارْشْ نّسْ.   
\m
\v 3 ثِيمسِّي ثڭُّورْ أَسْ  
\m زَّاثْ ن وُوذمْ نّسْ،  
\m ثْقدّْ إِغْرِيمنْ نّسْ  
\m إِ ذ أَسْ د-إِتّنّْضنْ.   
\b  
\m
\v 4 أَسَّامنْ نّسْ سّْڒَاقَّانْ دُّونشْثْ،  
\m ثَامُّورْثْ ثْژَارّْ إِ-ت، ثنْهزَّا. \x ◘ \xo 97:‏4 \xt إِزهد. 77‏:‏17؛ أَسَا. 4‏:‏5\x*   
\m
\v 5 إِذُورَارْ فسّْينْ أَمْ شّْمعْ  
\m زَّاثْ إِ وُوذمْ ن سِيذِي،  
\m زَّاثْ إِ وُوذمْ ن سِيذِي ن مَارَّا ثَامُّورْثْ.   
\m
\v 6 إِجنْوَانْ تّْبَارّْحنْ ثَاسڭْذَا نّسْ،  
\m مَارَّا ڒڭْنُوسْ تّْوَاڒَانْ أَعُودْجِي نّسْ. \x ◘ \xo 97:‏6 \xt إِزهد. 19‏:‏2؛ 50‏:‏6\x*   
\b  
\m
\v 7 أجّْ أَذْ سضْحَانْ مَارَّا إِنِّيعبّْذنْ  
\m إِ \add ڒخْيَاڒَاثْ\add* إِنقْشنْ ن ؤُكشُّوضْ،  
\m مَارَّا إِنِّي إِتّْشنّْعنْ ذِي لْ-أَصْنَامْ.  
\m بنْذْقمْ زَّاثسْ، كنِّيوْ،  
\m مَارَّا إِربِّيثنْ!   
\m
\v 8 صِيهْيُونْ إِسْڒَا، إِفَارْحْ،  
\m يسِّيسْ ن يَاهُوذَا أَرشْقنْثْ،  
\m زِي سِّيبّثْ ن ڒحْكَامَاثْ نّشْ، \add أَ\add* سِيذِي.   
\b  
\m
\v 9 مَاغَارْ شكْ، \add أَ\add* سِيذِي،  
\m ذ أَمْعُودْجِي خْ مَارَّا ثَامُّورْثْ،  
\m شكْ ذ ونِّي يُوعْڒَانْ قَاعْ  
\m خْ مَارَّا إِربِّيثنْ.   
\b  
\m
\v 10 كنِّيوْ إِ إِتّخْسنْ سِيذِي، شَارْهمْ ڒْغَارْ.  
\m نتَّا إِحطَّا خْ ڒعْمُورْ ن إِمْثِيقَّانْ نّسْ،  
\m نتَّا إِتّْفكَّا إِ-ثنْ زڭْ ؤُفُوسْ ن إِعفَّاننْ. \x ◘ \xo 97:‏10 \xt عَام. 5‏:‏15؛ رُوم. 12‏:‏9\x*   
\m
\v 11 ثَافَاوْثْ ثتّْوَازَارْعْ إِ ؤُمْسڭّذْ،  
\m ڒفْرَاحثْ إِ يِينِّي غَارْ إِدْجَا ؤُڒْ إِسڭّْمنْ.   
\m
\v 12 \add كنِّيوْ\add* إِمْسڭَّاذنْ، فَارْحمْ زِي سِيذِي،  
\m قَاذَامْ خْمِي ثتِّيذَارمْ ثَاقدَّاسْثْ نّسْ.   
\b  
\b  
\m  
\c 98
\m
\v 1 \add أَزهِّيذْ.\add*  
\m  
\m غنّْجمْ إِ سِيذِي إِجّْ ن يزْڒِي ن جْذِيذْ،  
\m مَاغَارْ نتَّا إِڭَّا لْمُوعْجِيزَاثْ.  
\m أَفُوسْ نّسْ أَفُوسِي ذ ؤُغِيڒْ نّسْ إِقدّْسنْ  
\m سّْنجْمنْ ث.   
\b  
\m
\v 2 سِيذِي إِسّْشنْ أَسنْجمْ نّسْ،  
\m إِسَّارْڭبْ ثَاسڭْذَا نّسْ  
\m زَّاثْ إِ ثِيطَّاوِينْ ن ڒڭْنُوسْ.   
\m
\v 3 نتَّا إِعْقڒْ خْ ثْمخْسِيوْثْ نّسْ إِشوَّارنْ،  
\m خْ ڒَامَانْ نّسْ إِ ثَادَّارْثْ ن إِسْرَائِيل.  
\m مَارَّا ثِينڭُّورَا ن ثمُّورْثْ ژْرِينْثْ أَسنْجمْ  
\m س \add ؤُفُوسْ ن\add* ن أَربِّي نّغْ.   
\b  
\m
\v 4 ذُوقّْزمْ س ؤُسْڒِيوْڒوْ إِ سِيذِي،  
\m مَارَّا ثَامُّورْثْ،  
\m سْغُويّمْ، سْڒِيوڒْومْ، زهّْذمْ.   
\m
\v 5 زهّْذمْ إِ سِيذِي س ڒْڭَامْبْرِي،  
\m س ڒْڭَامْبْرِي ؤُ س ثْمِيجَّا ن يزْڒِي،   
\m
\v 6 س ڒبْوَاقْ ذ ڒْحسّْ ن ؤُسُوضِي  
\m ذڭْ ؤُيِيشّْ ن إِشَارِّي.  
\m ذُوقّْزمْ س ؤُسْڒِيوْڒوْ  
\m زَّاثْ إِ وُوذمْ ن ؤُجدْجِيذْ، سِيذِي.   
\b  
\m
\v 7 أجّْ أَذْ إِزْهَارْ ڒبْحَارْ  
\m ذ مَارَّا أَعمَّارْ نّسْ،  
\m دُّونشْثْ ذ يِينِّي ذَايسْ إِزدّْغنْ.   
\m
\v 8 أجّْ إِغزْرَانْ أَذْ وْثنْ شَامْخَا س إِفَاسّنْ،  
\m إِذُورَارْ أَذْ سّْڒِيوْڒونْ \add جْمِيعْ\add*   
\m
\v 9 زَّاثْ إِ وُوذمْ ن سِيذِي،  
\m مَاغَارْ نتَّا أَذْ د-يَاسْ  
\m حِيمَا أَذْ إِحْكمْ ثَامُّورْثْ.  
\m نتَّا أَذْ إِحْكمْ ثَامُّورْثْ س ثْسڭْذَا،  
\m ڒڭْنُوسْ س ڒْحقّْ.   
\b  
\b  
\m  
\c 99
\m
\v 1 سِيذِي إِحكّمْ، أجّْ أَذْ أَرْجِيجنْ ڒڭْنُوسْ.  
\m نتَّا إِقِّيمْ \add خْ\add* إِكِيرُوبنْ،  
\m ثَامُّورْثْ ثبْذَا أَذْ ثنْهزّْ. \f ◼ \fr 99:‏1 \ft \+bd ’إِكِيرُوبنْ‘\+bd* - إِشْثْ ن مَارْكَا ن لْمَالَاكَاثْ.\f*   
\m
\v 2 سِيذِي ذ أَمقّْرَانْ ذِي صِيهْيُونْ،  
\m نتَّا يُوعْڒَا أَطَّاسْ خْ مَارَّا ڒڭْنُوسْ.   
\m
\v 3 أجّْ إِ-ثنْ أَذْ قَاذَانْ  
\m إِسمْ نّشْ أَمقّْرَانْ إِسَّاڭّْوَاذنْ،  
\m \add أَذْ إِنِينْ\add*: ”أَقَا نتَّا ذ أَمْقدَّاسْ!“   
\b  
\m
\v 4 جّهْذْ ن ؤُجدْجِيذْ أَقَا نتَّا إِتّخْسْ ڒْحقّْ.  
\m شكْ ثڭِّيذْ أَمْشَانْ إِمْثنْ إِ ثْسڭْذَا،  
\m ثڭِّيذْ ڒْحقّْ ذ ثْسڭْذَا ذِي يَاعْقُوبْ.   
\m
\v 5 سْعُودْجمْ سِيذِي، أَربِّي نّغْ،  
\m بنْذْقمْ زَّاثْ إِ ثْنبْذَاثْ  
\m ن إِضَارنْ نّسْ.  
\m أَقَا نتَّا ذ أَمْقدّسْ!   
\b  
\m
\v 6 مُوسَا ذ هَارُونْ \add ثُوغَا أَثنْ\add*  
\m زڭْ إِكهَّاننْ نّسْ،  
\m شَامْوِيلْ \add ثُوغَا\add* زڭْ إِنِّي إِڒَاغَانْ إِسمْ نّسْ.  
\m نِيثْنِي ڒَاغَانْ غَارْ سِيذِي  
\m ؤُشَا نتَّا إِسْڒَا أَسنْ.   
\m
\v 7 إِسِّيوڒْ أَكِيذْسنْ زڭْ ؤُقلِّيجْ ن ؤُسيْنُو.  
\m نِيثْنِي حْضَانْ شّْهَاذَاثْ نّسْ،  
\m ؤُڒَا ذ ثِيوصَّا نّسْ نِّي ذ أَسنْ إِوْشَا.   
\m
\v 8 \add أَ\add* سِيذِي، أَربِّي نّغْ، شكْ ثسْڒِيذْ أَسنْ.  
\m شكْ ذ إِجّْ ن أَربِّي إِغفَّارنْ،  
\m \add مَاشَا\add* ؤُڒَا ذ ؤُمْثَاقمْ خْ ثْمڭَّا نْسنْ.   
\m
\v 9 سْعُودْجمْ سِيذِي، أَربِّي نّغْ،  
\m بنْذْقمْ \add أَسْ\add* زَّاثْ إِ وذْرَارْ نّسْ إِقدّْسنْ،  
\m مَاغَارْ سِيذِي، أَربِّي نّغْ،  
\m ذ أَمْقدّسْ \add إِ إِدْجَا\add*.   
\b  
\b  
\m  
\c 100
\m
\v 1 \add إِزْڒِي ن ؤُقَاذِي.\add*  
\b  
\m أجّْ أَذْ ثدُّوقّزْ مَارَّا ثَامُّورْثْ  
\m س ؤُسْڒِيوْڒوْ إِ سِيذِي.   
\m
\v 2 سخَّارمْ إِ سِيذِي س ڒفْرَاحثْ،  
\m أَسمْ-د زَّاثْ إِ وُوذمْ نّسْ س ؤُسْڒِيوْڒوْ.   
\m
\v 3 سْنمْ، أَقَا سِيذِي ذ أَربِّي \add إِ يدْجَا\add*.  
\m نتَّا إِخْڒقْ أَنغْ-د  
\m ؤُ نشِّينْ نّسْ \add إِ ندْجْ\add*،  
\m ڒْْڭنْسْ نّسْ ذ وُودْجِي ن ثَاروْسَا نّسْ. \x ◘ \xo 100:‏3 \xt إِزهد. 95‏:‏7؛ حِز. 34‏:‏30، 31\x*   
\b  
\m
\v 4 أَذْفمْ ثِيوُّورَا نّسْ س ؤُقَاذِي،  
\m ڒمْرَاحَاثْ نّسْ س إِزْڒَانْ ن ؤُصبّحْ،  
\m قَاذَامْ ث، بَارْكمْ إِسمْ نّسْ.   
\m
\v 5 مَاغَارْ سِيذِي ذ أَصبْحَانْ،  
\m ثَامخْسِيوْثْ نّسْ إِشوَّارنْ  
\m \add ثتّْغِيمَا\add* إِ ڒبْذَا،  
\m ڒَْامَانْ نّسْ زِي جِّيڒْ أَڒْ جِّيڒْ.   
\b  
\b  
\m  
\c 101
\m
\v 1 \add أَزهّذْ ن ذَاوُوذْ.\add*  
\b  
\m نشّْ أَذْغنّْجغْ  
\m خْ ثْمخْسِيوْثْ إِشوَّارنْ ذ ڒْحقّْ،  
\m أَذْ زهّْذغْ إِ شكْ، \add أَ\add* سِيذِي!   
\m
\v 2 نشّْ أَذْ ڭّغْ س ڒعْقڒْ  
\m عْلَاحْسَابْ إِجّْ ن وبْرِيذْ إِكمّْڒنْ.  
\m مڒْمِي غَارِي إِ د غَا ثَاسذْ؟  
\m نشّْ أَذْ ؤُيُورغْ س وُوڒْ نِيشَانْ  
\m ذِي ڒْوسْطْ ن ثَادَّارْثْ إِنُو،   
\m
\v 3 نشّْ وَارْ نطَّارغْ ثِيطَّاوِينْ إِنُو  
\m ذِي مِينْ إِفضْحنْ.  
\m نشّْ شَارّْهغْ مِينْ تّڭّنْ  
\m إِنِّي خَاكْ إِحيّْذنْ  
\m \add مَانْ أَيَا\add* وَارْ ذ أَيِي إِڒصّقْ.   
\m
\v 4 ؤُڒْ إِتّفْرِيغنْ إِتّْخصَّا  
\m أَذْ خَافِي يَاڭّْوجْ،  
\m وَارْ خْسغْ أَذْ سّْنغْ مِينْ وَارْ إِحْڒِينْ.   
\m
\v 5 ونِّي إِشقّْفنْ  
\m ذڭْ جَّارْ نّسْ س ثْنُوفّْرَا،  
\m أَذْ ث ثحِّيغْ.  
\m ونِّي إِتّْكبَّارنْ س ثِيطَّاوِينْ نّسْ  
\m ذ ونِّي إِتّْعفَّارنْ س وُوڒْ نّسْ،  
\m وَارْ ث كسِّيغْ.   
\m
\v 6 ثِيطَّاوِينْ إِنُو \add أَرزُّونْثْ\add*  
\m خْ إِمْثِيقَّانْ ذِي ثمُّورْثْ،  
\m حِيمَا نِيثْنِي أَذْ غَارِي قِّيمنْ.  
\m ونِّي إِڭُّورنْ  
\m ذڭْ إِجّْ ن وبْرِيذْ إِكمّْڒنْ،  
\m أَذْ أَيِي إِسخَّارْ.   
\m
\v 7 ونِّي إِتّڭّنْ ڒْغشّْ،  
\m وَارْ إِتّْغِيمِي ذِي ثَادَّارْثْ إِنُو،  
\m ؤُڒَا ذ بُو-إِخَارِّيقنْ وَارْ إِتّْوَاضْمنْ  
\m زَّاثْ إِ ثِيطَّاوِينْ إِنُو.   
\m
\v 8 كُوڒْ صّْبحْ أَذْ ثحِّيغْ  
\m مَارَّا إِعفَّاننْ زِي ثمُّورْثْ،  
\m حِيمَا \add أَمُّو إِ\add* غَا مْحِيغْ مَارَّا  
\m إِنِّي إِتّڭّنْ ڒْمُوعْصِييّثْ  
\m زِي ثنْذِينْثْ ن سِيذِي.   
\b  
\b  
\m  
\c 102
\m
\v 1 \add ثَاژَادْجِيثْ ن إِجّْ ن ڒْمسْكْسِينْ مَاڒَا مَانَاينِّي ذ أَطَّاسْ خَاسْ،\add* \add ؤُشَا خنِّي إِتّْفَارّغْ إِمُونَاسْ نّسْ زَّاثْ إِ سِيذِي.\add*   
\b  
\m
\v 2 \add أَ\add* سِيذِي، سڒْ غَارْ ثْژَادْجِيثْ إِنُو،  
\m أجّْ أَغُويِّي إِنُو أَذْ غَاركْ د-يَاوضْ.   
\m
\v 3 وَارْ تّفَّارْ ؤُذمْ نّشْ خَافِي  
\m ذڭْ وَاسّْ إِ ذِي تّْوَاحْصَارغْ.  
\m أَرّْ-د غَارِي أَمزُّوغْ نّشْ  
\m ذڭْ وَاسّْ إِ ذِي ڒَاغِيغْ،  
\m سڒْ-د \add خنِّي\add* غَارِي ذغْيَا.   
\b  
\m
\v 4 مِينْزِي ؤُسَّانْ إِنُو عْذُونْ أَمْ دّخَّانْ،  
\m إِخْسَانْ إِنُو أَمْ ثفْقُونْثْ إِشمْضنْ. \x ◘ \xo 102:‏4 \xt إِزهد. 37‏:‏20\x*   
\m
\v 5 ؤُڒْ إِنُو إِتِّيسْڒَاوْ ؤُ يُوژغْ أَمْ أَرْبِيعْ،  
\m أَڒَامِي تُّوغْ أَذْ شّغْ أَغْرُومْ إِنُو.   
\m
\v 6 زِي سِّيبّثْ ن ؤُزهَّارْ يُودْجْغنْ إِنُو،  
\m ڒصْقنْ إِغْسَانْ إِنُو غَارْ ثڒْمشْثْ إِنُو.   
\b  
\m
\v 7 نشّْ أَمْ يِيجّْ بُو-ؤُعُوقِّي ن ؤُجْضِيضْ  
\m ذِي ڒخْڒَا،  
\m ذوْڒغْ أَمْ يِيجّْ ن مُوكَا جَارْ ڒْخِيرْبَاثْ.   
\m
\v 8 تّْغِيمغْ فَاقغْ س ڒفْثَانثْ،  
\m ذوْڒغْ أَمْ يِيجّْ ن وجْضِيضْ  
\m إِ إِقِّيمنْ وحّْذسْ خْ ثْزقَّا.   
\m
\v 9 ڒْعذْيَانْ إِنُو تّكّْوَارنْ أَيِي أَسّْ مَارَّا.  
\m إِنِّي خَافِي إِتّْعدَّانْ،  
\m نعّْڒنْ أَمْ قَّارنْ إِسمْ إِنُو.   
\b  
\m
\v 10 مَاغَارْ تّتّغْ إِغّضْ أَمْ وغْرُومْ  
\m ؤُ خدْجْضغْ ثِيسسِّيثْ إِنُو س إِمطَّاونْ \add إِنُو\add*   
\m
\v 11 زِي سِّيبّثْ ن وسْخضْ نّشْ  
\m ذ ؤُذُوقّزْ ن وغْضَابْ نّشْ،  
\m مَاغَارْ شكْ ثسّْڭعّْذذْ أَيِي  
\m ؤُ ثنْضَارذْ أَيِي \add عَاوذْ\add* غَارْ ثمُّورْثْ.   
\m
\v 12 ؤُسَّانْ إِنُو أَمْ يِيشْثْ ن ثِيڒِي إِزُّوڭَّارْثنْ،  
\m ؤُ نشّْ ثَاژْغغْ أَمْ ثُوڭَا.   
\b  
\m
\v 13 \add مَاشَا\add* شكْ، \add أَ\add* سِيذِي،  
\m أَذْ ثقِّيمذْ \add خْ ڒْكُورْسِي نّكْ\add* إِ ڒبْذَا،  
\m زِي جِّيڒْ أَڒْ جِّيڒْ أَذْ ذَايكْ خَارّْصنْ.   
\m
\v 14 شكْ أَذْ ثكَّارذْ أَذْ ثَارْحْمذْ خْ صِيهْيُونْ،  
\m مَاغَارْ أَقَا ذ ڒْوقْثْ  
\m مَاحنْذْ أَذْ خَاسْ ثْحِينّذْ،  
\m مِينْزِي ڒْوقْثْ إِتّْوَاڭّنْ  
\m أَقَا ثِيوضْ-د.   
\m
\v 15 مَاغَارْ إِژْرَا نّسْ ؤُسِينْ-د  
\m خْ ڒْخَاضَارْ ن إِمْسخَّارنْ نّشْ  
\m ؤُ نِيثْنِي كْسِينْ س وسْحِيسّفْ ذِي ثْعجَّاجْثْ نْسنْ.   
\b  
\m
\v 16 ڒڭْنُوسْ أَذْ ڭّْوذنْ إِسمْ ن سِيذِي،  
\m مَارَّا إِجدْجِيذنْ ن ثمُّورْثْ  
\m \add أَذْ ڭّْوذنْ\add* أَعُودْجِي نّشْ.   
\m
\v 17 خْمِي غَا إِبْنَا سِيذِي صِيهْيُونْ  
\m \add ثْوَاڒَاثْ نّغْنِيثْ\add*،  
\m أَذْ د-إِبَانْ ذڭْ ؤُعُودْجِي نّسْ.   
\m
\v 18 أَذْ إِڒْهَا أَكْ-ذ ثْژَادْجِيثْ ن ؤُمزْڒُوضْ،  
\m وَارْ إِسّحْقَارَا شَا ثَاژَادْجِيثْ نْسنْ.   
\b  
\m
\v 19 مَانْ أَيَا إِتّْوَارِي إِ جِّيڒْ إِ د غَا يَاسنْ،  
\m ڒْْڭنْسْ نِّي د غَا إِتّْوَاخڒْقنْ،  
\m أَذْ إِصبّحْ إِ سِيذِي،   
\m
\v 20 مَاغَارْ نتَّا أَقَا إِسِّيجّْ-د  
\m زِي زَّاوشْثْ نّسْ إِقدّْسنْ يُوعْڒَانْ،  
\m زڭْ ؤُجنَّا إِخْزَارْ-د سِيذِي  
\m غَارْ ثمُّورْثْ سْوَادَّايْ   
\m
\v 21 حِيمَا أَذْ إِسڒْ أَوعّضْ ن ؤُمحْبُوسْ،  
\m حِيمَا أَذْ يَارْخُو  
\m إِ يِينِّي \add إِدْجَانْ ذ\add* ثَارْوَا ن ڒْموْثْ،   
\m
\v 22 مَاحنْذْ أَذْ بَارّْحنْ  
\m س يِيسمْ ن سِيذِي ذِي صِيهْيُونْ،  
\m ذ شّنْعثْ نّسْ ذِي ؤُرْشَالِيمْ،   
\m
\v 23 خْمِي ذِينِّي إِ غَا تّْوَاسّْمُوننْ ڒڭْنُوسْ،  
\m \add جْمِيعْ\add* أَكْ-ذ ثْڭلْذِيوِينْ،  
\m حِيمَا أَذْ سخَّارنْ إِ سِيذِي.   
\b  
\m
\v 24 نتَّا إِسَّارْخُو جّهْذْ إِنُو أَكْ-ذ وبْرِيذْ،  
\m نتَّا إِسّمْژِي ذڭْ وُوسَّانْ إِنُو.   
\m
\v 25 نشّْ نِّيغْ: ’وَارْ ذ أَيِي كسِّي  
\m ذڭْ وزْينْ ن وُوسَّانْ \add ن ثُوذَارْثْ\add* إِنُو، \add أَ\add* أَربِّي،  
\m أَقَا إِسڭّْوُوسَا نّشْ \add تّْغِيمَانْ\add* زِي جِّيڒْ أَڒْ جِّيڒْ.   
\m
\v 26 زڭْ وشْحَاڒْ ؤُيَا ثڭِّيذْ ذْسَاسْ إِ ثمُّورْثْ،  
\m إِجنْوَانْ ذ ڒْخذْمثْ ن إِفَاسّنْ نّشْ. \x ◘ \xo 102:‏26 \xt عبر. 1‏:‏10\x*   
\m
\v 27 إِنَا أَذْ فْنَانْ، مَاشَا شكْ أَذْ ثْذُومذْ.  
\m نِيثْنِي مَارَّا أَذْ أَرْشَانْ أَمْ وَارُّوضْ،  
\m شكْ أَذْ ثنْ ثْبدّْڒذْ  
\m أَمْ يِيشْثْ ن ڒعْبَايثْ،  
\m \add أَمُّو إِ\add* غَا تّْوَابدّْڒنْ. \x ◘ \xo 102:‏27 \xt عبر. 1‏:‏10‏-‏12 \x*   
\m
\v 28 شكْ \add مَاشَا\add* ذ شكْ،  
\m إِسڭّْوُوسَا نّشْ وَارْ قطِّينْعمَّارْصْ.‘ \x ◘ \xo 102:‏28 \xt عبر. 1‏:‏12b\x*   
\m
\v 29 إِحنْجِيرنْ ن إِمْسخَّارنْ نّشْ  
\m أَذْ \add ذِينْ\add* زذْغنْ  
\m ؤُ ثَارْوَا نْسنْ أَذْ تّْوَاسّْمثْننْ  
\m زَّاثْ إِ وُوذمْ نّشْ.   
\b  
\b  
\m  
\c 103
\m
\v 1 \add ن ذَاوُوذْ.\add*  
\b  
\m بَاركْ سِيذِي، \add أَ\add* ڒعْمَارْ إِنُو،  
\m ذ مَارَّا مِينْ ذَايِي إِسمْ نّسْ إِقدّْسنْ.   
\m
\v 2 بَاركْ سِيذِي، \add أَ\add* ڒعْمَارْ إِنُو،  
\m وَارْ تّتُّوعمَّارْصْ  
\m مَارَّا ثِيمڭَّا نّسْ إِصبْحنْ.   
\m
\v 3 \add نتَّا\add* ذ ونِّي ذ أَشْ إِغفَّارنْ  
\m مَارَّا دّْنُوبْ نّشْ،  
\m ونِّي إِسّْڭنْفَانْ مَارَّا ڒهْڒَاشَاثْ نّشْ، \x ◘ \xo 103:‏3 \xt عبر. 6‏:‏5\x*   
\m
\v 4 ونِّي إِفْذِينْ ثُوذَارْثْ نّشْ زِي ثُورْصُوضِي،  
\m ونِّي خَاكْ إِڭِّينْ تَّاجْ  
\m ن ثْمخْسِيوْثْ إِشوَّارنْ ذ أَرّحْمثْ،   
\m
\v 5 ونِّي إِسّْجَّاوَاننْ أَقمُّومْ نّشْ  
\m س مِينْ إِصبْحنْ،  
\m ونِّي إِتَّارَّانْ ثمْژِي نّشْ أَمْ ؤُڭِيذرْ.   
\b  
\m
\v 6 سِيذِي إِتّڭّْ ثَاسڭْذَا ذ ڒْحقّْ  
\m إِ مَارَّا إِنِّي إِتّْوَاحصَّارنْ.   
\m
\v 7 نتَّا إِسّْشنْ إِ مُوسَا إِبْرِيذنْ نّسْ،  
\m إِ أَيْثْ ن إِسْرَائِيل ثِيمڭَّا نّسْ.   
\m
\v 8 سِيذِي ذ أَرْحِيمْ ذ أَحْنِينْ،  
\m غَارسْ تَّاسِيعْ ن ڒْخَاضَارْ،  
\m إِشُّورْ س ثْمخْسِيوْثْ إِشوَّارنْ. \x ◘ \xo 103:‏8 \xt ؤُف. 34‏:‏6؛ ڒخْڒ. 14‏:‏18؛ أَعَوذ. 5‏:‏10؛ نَاح. 9‏:‏17؛ إِزهد. 86‏:‏15؛ 145‏:‏8؛ إِرْم. 32‏:‏18\x*   
\m
\v 9 نتَّا وَارْ إِتّمْشُوبُّوشْ إِ ڒبْذَا،  
\m وَارْ إِتّْغِيمِي \add إِتّْخيِّيقْ\add* إِ ڒبْذَا. \x ◘ \xo 103:‏9 \xt إِشا. 57‏:‏16؛ إِشا. 3‏:‏5\x*   
\m
\v 10 نتَّا وَارْ ذ أَنغْ إِتّڭّْ  
\m عْلَاحْسَابْ دّْنُوبْ نّغْ  
\m ؤُ وَارْ زَّايْنغْ إِخدْجفْ  
\m عْلَاحْسَابْ ڒْمُوعْصِييّثْ نّغْ،   
\b  
\m
\v 11 مَاغَارْ أَمْ ؤُجنَّا يُوعْڒَانْ خْ ثمُّورْثْ،  
\m أَمُّو إِ ثمْغَارْ  
\m ثْمخْسِيوْثْ نّسْ إِشوَّارنْ  
\m ثِيوَا مَارَّا إِنِّي ث إِتّڭّْوذنْ.   
\m
\v 12 أَمْ إِڭّْوجْ شَّارْقْ خْ ڒْغَارْبْ،  
\m أَمُّو إِ إِسِّيڭّْوجْ نتَّا  
\m إِخطَّانْ نّغْ خَانغْ.   
\m
\v 13 أَمْ مَامّشْ إِحِينّْ بَابَاثْسنْ  
\m خْ إِحنْجِيرنْ نّسْ،  
\m أَمُّو إِ إِتّْحِينّْ سِيذِي خْ يِينِّي ث إِتّڭّْوذنْ.   
\m
\v 14 مَاغَارْ نتَّا إِسّنْ مَامّشْ نتّْوَاڭّْ،  
\m إِعْقڒْ أَقَا نشِّينْ ذ أَشَاڒْ.   
\b  
\m
\v 15 ؤُسَّانْ ن بْنَاذمْ أَمشْنَاوْ ثُوڭَا،  
\m نتَّا إِتّْنُووَارْ أَمْ ثْنُووَّاشْثْ ن ييَّارْ. \x ◘ \xo 103:‏15 \xt أَيُوبْ 14‏:‏1، 2؛ إِزهد. 90‏:‏5، 6؛ يَاع. 1‏:‏10، 11؛ 1 بُط. 1‏:‏24\x*   
\m
\v 16 مَاڒَا إِكَّا-د خَاسْ ؤُسمِّيضْ، وَارْ ثقِّيمْ  
\m ؤُ أَمْشَانْ مَانِي ثُوغَا ثْبدّْ،  
\m وَارْ خَاسْ إِسِّينْ عَاذْ.   
\m
\v 17 \add مَاشَا\add* ثَامخْسِيوْثْ إِشوَّارنْ ن سِيذِي  
\m ثتّْغِيمَا زِي ڒبْذَا أَڒْ ڒبْذَا  
\m ثِيوَا يِينِّي ث إِتّڭّْوذنْ،  
\m ؤُ ثَاسڭْذَا نّسْ \add ثتّْغِيمَا\add*  
\m إِ وَارَّاوْ ن وَارَّاوْ،   
\m
\v 18 إِ مَارَّا إِنِّي إِحطَّانْ ڒْعَاهْذْ نّسْ  
\m ؤُ إِعقّْڒنْ خْ ڒُومُورَاثْ نّسْ،  
\m مَاحنْذْ أَذْ زَّايْسنْ تّڭّنْ. \x ◘ \xo 103:‏18 \xt أَعَوذ. 7‏:‏9\x*   
\b  
\m
\v 19 سِيذِي إِسّْبدّْ ڒْعَارْشْ نّسْ ذڭْ ؤُجنَّا،  
\m ثَاڭلْذَا نّسْ ثْحكّمْ خْ مَارَّا \add مِينْ إِدْجَانْ\add*.   
\m
\v 20 بَارْكنْثْ سِيذِي، \add كنِّينْثْ\add*، لْمَالَاكَاثْ نّسْ،  
\m أَيْثْ ن بُو-ثغْرُوضْثْ إِمحْضنْ  
\m إِنِّي إِتّڭّنْ أَوَاڒْ نّسْ،  
\m إِنِّي إِتّسْڒَانْ إِ ثْمِيجَّا ن وَاوَاڒْ نّسْ.   
\m
\v 21 بَارْكنْثْ سِيذِي، مَارَّا ڒْعسْكَارَاثْ نّسْ،  
\m \add كنِّيوْ،\add* إِمْسخَّارنْ نّسْ،  
\m إِنِّي إِتّڭّنْ مِينْ ذ أَسْ يَارشْقنْ! \x ◘ \xo 103:‏21 \xt أَمز. 32‏:‏1؛ 1 إِج. 22‏:‏19؛ أَفا. 3‏:‏10؛ كُول. 1‏:‏16\x*   
\m
\v 22 بَارْكمْ سِيذِي،  
\m \add أَ\add* مَارَّا مِينْ إِتّْوَاڭّنْ \add س ؤُفُوسْ نّسْ\add*،  
\m ذِي مَانِي مَا إِ ثدْجَا ڒحْكَامثْ نّسْ.  
\m بَاركْ سِيذِي، \add أَ\add* ڒعْمَارْ إِنُو.   
\b  
\b  
\m  
\c 104
\m
\v 1 بَاركْ سِيذِي، \add أَ\add* ڒعْمَارْ إِنُو!  
\m \add أَ\add* سِيذِي، أَربِّي إِنُو،  
\m مَامّشْ ذ أَمقّْرَانْ شكْ!  
\m شكْ ثْيَارْضذْ س لْعَاضَامَا ذ ڒْعزّْ.   
\m
\v 2 نتَّا إِڒحّفْ إِخفْ نّسْ س ثْفَاوْثْ  
\m أَمْ س إِجّْ ن ؤُپَارْثسُّو،  
\m نتَّا إِتّْبزّعْ أَجنَّا  
\m أَمْ ثْجَارْثِيڒْثْ ن ؤُقِيضُونْ. \x ◘ \xo 104:‏2 \xt أَمز. 1‏:‏6؛ أَيُوبْ 26‏:‏7\x*   
\m
\v 3 \add أَقَا نتَّا\add* ذ ونِّي إِسَّارْسنْ  
\m ثِيحنْيَا ن وسْقفْ  
\m سَاذُو إِخَّامنْ نّسْ خْ وَامَانْ،  
\m ذ ونِّي إِڭِّينْ إِسيْنُوثنْ  
\m ذ أَكَارُّو نّسْ،  
\m ذ ونِّي إِڭُّورنْ  
\m خْ وَافْرِيونْ ن ؤُسمِّيضْ، \x ◘ \xo 104:‏3 \xt إِزهد. 18‏:‏11؛ إِشا. 19‏:‏1؛ أَسَا. 14‏:‏14\x*   
\m
\v 4 ذ ونِّي إِڭِّينْ لْمَالَاكَاثْ نّسْ  
\m أَمْ يِيسمِّيضنْ  
\m ؤُ إِمْسخَّارنْ نّسْ  
\m ذ إِشْثْ ن ثْمسِّي إِتّحْذُوذُوقنْ. \x ◘ \xo 104:‏4 \xt عبر. 1‏:‏7\x*   
\b  
\m
\v 5 نتَّا إِسّْبدّْ ثَامُّورْثْ خْ ذْسُوسَا نّسْ،  
\m وَارْ ثتّنْهزِّيعمَّارْصْ إِ ڒبْذَا. \x ◘ \xo 104:‏5 \xt أَيُوبْ 26‏:‏7؛ 38‏:‏4، 5، 6؛ إِزهد. 24‏:‏2؛ 78‏:‏69\x*   
\m
\v 6 شكْ ثْڒحّْفذْ أَسْ س \add وَامَانْ\add* إِهوْڒنْ  
\m أَمْ س يِيجّْ ن وَارُّوضْ،  
\m أَمَانْ بدّنْ ثِيوَا إِ إِذُورَارْ.   
\m
\v 7 نِيثْنِي أَروْڒنْ زڭْ ؤُسِيڭّْوذْ نّشْ،  
\m قدْجْقنْ أَذْ فّْغنْ زِي ثْمِيجَّا ن وَاجَّاجْ نّشْ.   
\m
\v 8 تّْوَاسّْڭعّْذنْ إِذُورَارْ،  
\m هكّْوَانْثْ ثيْسَارِينْ  
\m ذڭْ ومْشَانْ إِ ذ أَسنْ ثڭِّيذْ.   
\m
\v 9 شكْ ثڭِّيذْ أَيْمِيرْ إِ وَامَانْ  
\m نِّي وَارْعدُّونْ،  
\m وَارْ د-ذكّْوِيڒنْ  
\m مَاحنْذْ أَذْ ذْڒنْ ثَامُّورْثْ.   
\b  
\m
\v 10 \add شكْ\add* ذ ونِّي إِندّْهنْ  
\m ثَاڒَاوِينْ ذِي ثغْزُورِينْ،  
\m أَقَا تَّازّْڒنْثْ ذِينْ جَارْ إِذُورَارْ.   
\m
\v 11 أَقَا وَارّْذنْثْ مَارَّا ڒْمَاڒْ ن ييَّارْ،  
\m إِغْيَاڒْ ن ڒخْڒَا تّكّْسنْ أَفَاذِي نْسنْ زَّايْسنْثْ.   
\m
\v 12 إِجْضَاضْ ن ؤُجنَّا زدّْغنْ  
\m غَارْ ثمَّاوِينْ نْسنْ،  
\m زِي جَارْ ڒفْرُوعْ ثتّكّْ-د ثْمِيجَّا نْسنْ.   
\m
\v 13 \add نتَّا أَقَا\add* ذ ونِّي إِتّسُّونْ إِذُورَارْ  
\m زڭْ إِخَّامنْ نّسْ ذڭْ ؤُجنَّا،  
\m ثَامُّورْثْ ثتّْيَاوَانْ  
\m زِي ڒْغِيدْجثْ \add إِ د-إِفّْغنْ\add* زِي مِينْ ثڭِّيذْ شكْ. \f ◼ \fr 104:‏13 \ft \+bd ’إِخَامّنْ نّسْ ذڭْ ؤُجنَّا‘\+bd* - س ثْعِيبْرَانِيثْ ’إِخَامّنْ نّسْ ن نّجْ‘.\f*   
\m
\v 14 نتَّا إِڭَّا أَرْبِيعْ إِغمِّي إِ ڒْمَارْ،  
\m ؤُڒَا ذ أَغمُّويْ ذِي طّْوعْ ن بْنَاذمْ.  
\m \add إِڭَّا إِ-ت\add* مَاحنْذْ أَذْ د-يَاوِي  
\m أَغْرُومْ زِي ثمُّورْثْ   
\m
\v 15 ؤُ بِينُو نِّي إِسّْفَارَّاحنْ ؤُڒْ ن بْنَاذمْ.،  
\m أَڒَامِي إِغمْبَابْ أَذْ \add زَّايسْ\add* وسّْڭنْ  
\m مَاهُو زِي زّشْثْ،  
\m ؤُڒَا ذ أَغْرُومْ نِّي إِسّجْهذْ ؤُڒْ ن بْنَاذمْ.   
\m
\v 16 ثِيشجُّورَا ن سِيذِي تّْيَاوَاننْثْ،  
\m ثِيشجُّورَا ن ثنْڭلْثْ ن لُوبْنَانْ  
\m نِّي إِژُّو نتَّا،   
\m
\v 17 مَانِي تّڭّنْ إِجْضَاضْ ڒْعُوشّْ نْسنْ،  
\m \add مَانِي\add* إِ ثدْجَا ثَادَّارْثْ ن ؤُبلَّارْجْ  
\m ذِي ثْشجُّورَا ن ؤُمرْزِي. \f ◼ \fr 104:‏17 \ft \+bd ’أَمرْزِي‘\+bd* - نِيغْ ’أَمضْزِي‘.\f*   
\m
\v 18 إِذُورَارْ يُوعْڒَانْ أَقَا أَثنْ  
\m إِ إِغَايْضنْ ن ثْصُوضَارْ،  
\m ڒجْرُوفْ ذ أَمْشَانْ ن ثَاروْڒَا  
\m إِ إِكَاوْكَاونْ ن ثصْضَارْثْ.   
\b  
\m
\v 19 نتَّا إِڭَّا ثَازِيرِي ذ ڒعْبَارْ  
\m إِ ڒوْقَاثْ إِتّْوَاڭّنْ،  
\m ثَافُوشْثْ ثسّنْ مڒْمِي إِ غَا ثغْڒِي.   
\m
\v 20 شكْ ثسّكِّيذْ-د ثَادْجسْثْ  
\m ؤُ ثوْضَا-د دْجِيڒثْ  
\m \add إِ ذِي\add* تّخْثُوثْينْ  
\m مَارَّا ڒوْحُوشْ ن وزْغَارْ. \f ◼ \fr 104:‏20 \ft \+bd ’أَزْغَارْ‘\+bd* - نِيغْ ’ڒْغَابثْ‘ نِيغْ ’ثَازْڭَانْثْ‘.\f*   
\m
\v 21 أَيْرَاذنْ إِمژْيَاننْ  
\m زهَّارنْ خْ زَّارْذثْ،  
\m أَرزُّونْ خْ مَاشَّا نْسنْ زِي أَربِّي. \x ◘ \xo 104:‏21 \xt أَيُوبْ 38‏:‏39،40؛ إِشا. 31‏:‏4\x*   
\m
\v 22 مَاڒَا ثفّغْ-د \add خنِّي\add* ثْفُوشْثْ،  
\m تّشْرُورُوذنْ غَارْ ڒْمَارْڭحْ،  
\m تّْغمَّارنْ ذڭْ إِفْرَانْ نْسنْ.   
\m
\v 23 \add خنِّي\add* إِتّفّغْ بْنَاذمْ  
\m غَارْ ڒْخذْمثْ نّسْ،  
\m غَارْ ثوُّورِي نّسْ أَڒْ ثَامذِّيثْ.   
\b  
\m
\v 24 مَامّشْ أَطَّاسْ إِ ثڭِّيذْ، \add أَ\add* سِيذِي،  
\m س ثِيغِيثْ إِ ثڭِّيذْ مَارَّا ثِيمسْڒَايِينْ،  
\m ثَامُّورْثْ ثتّْوَاشُّورْ س وَاڭْڒَا نّشْ.   
\m
\v 25 أَقَا ذِينْ ڒبْحَارْ إِمْغَارْ،  
\m يِيرِيوْ غَارْ مَارَّا إِغزْذِيسنْ نّسْ،  
\m مَانِي إِسّْفُوفّيْ مَارَّا س إِمُودَّارنْ  
\m إِمقّْرَاننْ ذ إِمژْيَاننْ،  
\m بْڒَا ڒحْسَابْ،   
\m
\v 26 مَانِي ڭُّورنْ إِغَارُّوبَا،  
\m \add ؤُڒَا ذ\add* ’لِيبِييَاثَانْ‘ نِّي ثڭِّيذْ  
\m حِيمَا أَذْ ذَايسْ إِتِّيرَارْ.   
\b  
\m
\v 27 نِيثْنِي مَارَّا تّْرَاجَانْ شكْ،  
\m أَذْ أَسنْ ثوْشذْ مَاشَّا نْسنْ  
\m ذِي ڒْوقْثْ نّسْ. \x ◘ \xo 104:‏27 \xt إِزهد. 145‏:‏15\x*   
\m
\v 28 \add مَاڒَا\add* ثوْشِيذْ أَسنْ، يَارّْونْ نِيثْنِي،  
\m \add مَاڒَا\add* ثَارْزْمذْ أَفُوسْ نّشْ،  
\m دَّاكّْوَاڒنْ جِّيوْننْ س ڒْخَارْ.   
\m
\v 29 \add مَاڒَا\add* ثفَّارذْ ؤُذمْ نّشْ،  
\m أَقَا تّْنخْڒَاعنْ،  
\m \add مَاڒَا\add* ثْكسِّيذْ أَسنْ نّفْسْ،  
\m أَذْ سُّوفّْغنْ بُوحْبڒْ  
\m ؤُشَا أَذْ د-ذوْڒنْ غَارْ ؤُشَاڒْ نْسنْ. \x ◘ \xo 104:‏29 \xt إِزهد. 30‏:‏8\x*   
\m
\v 30 \add مَاڒَا\add* ثسّكّذْ-د أَرُّوحْ نّشْ،  
\m \add خنِّي\add* تّْوَاخڒْقنْ-د نِيثْنِي،  
\m أَذْ ثَارِّيذْ أَغمْبُوبْ ن ثمُّورْثْ ذ أَمَايْنُو.   
\b  
\m
\v 31 أَعُودْجِي ن سِيذِي أَذْ يِيڒِي إِ ڒبْذَا،  
\m سِيذِي أَذْ إِفَارْحْ إِ مَارَّا مِينْ إِڭَّا.   
\m
\v 32 \add مَاڒَا\add* نتَّا إِخزَّارْ  
\m ذِي ثمُّورْثْ، ثتَّارْجِيجِي،  
\m \add مَاڒَا\add* إِحَاذَا إِذُورَارْ، أَذْ ذُوخّْننْ.   
\m
\v 33 نشّْ خْسغْ أَذْغنّْجغْ إِ سِيذِي  
\m مِينْ غَا كّغْ دَّارغْ،  
\m أَذْ زهّْذغْ إِ أَربِّي إِنُو  
\m مِينْ \add ذَا\add* إِ غَا كّغْ دْجِيغْ. \x ◘ \xo 104:‏33 \xt إِزهد. 63‏:‏5؛ 146‏:‏2\x*   
\m
\v 34 أَخمّمْ إِنُو أَذْ د-يَاسْ  
\m خْ ڒْخَاضَارْ نّسْ،  
\m أَذْ فَارْحغْ ذِي سِيذِي.   
\m
\v 35 إِمذْنَابْ أَذْ تّْوَاثحَّانْ قَاعْ  
\m زِي ثمُّورْثْ،  
\m إِعفَّاننْ وَارْ تِّيڒِينْ عَاذْ.  
\m بَاركْ سِيذِي، \add أَ\add* ڒعْمَارْ إِنُو. هَالِّيلُو-يَاهْ!   
\b  
\b  
\m  
\c 105
\m
\v 1 قَاذَامْ سِيذِي،  
\m ڒَْاغَامْ خْ يِيسمْ نّسْ،  
\m بَارّْحمْ س ثْمڭَّا نّسْ جَارْ ڒڭْنُوسْ. \x ◘ \xo 105:‏1 \xt 1 إِم. 16‏:‏8‏-‏22\x*   
\m
\v 2 غنّْجمْ أَسْ، زهّْذمْ إِ نتَّا،  
\m سِيوْڒمْ خْ مَارَّا لْمُوعْجِيزَاثْ نّسْ.   
\m
\v 3 شنّْعمْ إِخفْ نّشْ  
\m س يِيسمْ نّسْ إِقدّْسنْ،  
\m حِيمَا ؤُڒْ ن يِينِّي يَارزُّونْ سِيذِي، أَذْ إِفَارْحْ. \x ◘ \xo 105:‏3 \xt إِزهد. 34‏:‏3\x*   
\m
\v 4 سقْسَامْ خْ سِيذِي ذ جّهْذْ نّسْ،  
\m أَرْزُومْ ؤُذمْ نّسْ ڒبْذَا.   
\m
\v 5 عقْڒمْ خْ لْمُوعْجِيزَاثْ نّسْ إِ إِڭَّا،  
\m خْ ڒعْڒَامثْ نّسْ  
\m ؤُ خْ ڒحْكَامَاثْ ن ؤُقمُّومْ نّسْ.   
\m
\v 6 زَّارِيعثْ ن إِبْرَاهِيمْ، أَمْسخَّارْ نّسْ،  
\m أَيْثْ ن يَاعْقُوبْ، إِنِّي زَّايسْ إِتّْوَافَارْزنْ!   
\b  
\m
\v 7 نتَّا ذ سِيذِي، أَربِّي نّغْ.  
\m ڒحْكَامَاثْ نّسْ \add إِ د-إِتَّاسنْ\add*  
\m خْ ثمُّورْثْ مَارَّا.   
\m
\v 8 عقْڒمْ خْ ڒْعَاهْذْ نّسْ إِ ڒبْذَا،  
\m أَوَاڒْ نِّي إِوصَّا إِ وَاڒفْ ن جِّيڒَاثْ،   
\m
\v 9 إِ إِڭَّا أَكْ-ذ إِبْرَاهِيمْ،  
\m ؤُ \add إِسّمْثنْ إِ-ث س\add* ثْجَادْجِيثْ نّسْ إِ إِسْحَاقْ.   
\m
\v 10 نتَّا إِڭَّا إِ-ث ذ ثَاوْصيّثْ إِ يَاعْقُوبْ،  
\m إِ إِسْرَائِيل \add إِڭَّا إِ-ث\add* ذ ڒْعَاهْذْ إِ ڒبْذَا، \x ◘ \xo 105:‏10 \xt أَمز. 28‏:‏13؛ 35‏:‏11؛ 1 إِم. 16‏:‏17\x*   
\m
\v 11 ؤُمِي إِنَّا:  
\m ”أَذْ أَشْ وْشغْ ثَامُّورْثْ ن كنْعَانْ،  
\m أَفِيڒُو \add ن ڒعْبَارْ\add* ن ثسْغَارْثْ نْومْ!“ \x ◘ \xo 105:‏11 \xt أَمز. 13‏:‏15؛ 15‏:‏18\x*   
\b  
\m
\v 12 ؤُمِي ثُوغَا كنِّيوْ ذڭْ إِجّْ ن وُورُو ن يرْيَازنْ،  
\m س ذْرُوسْ \add وَاهَا\add*،  
\m ؤُ أَمْ يِيبَارَّانِييّنْ \add إِ ثدْجِيمْ\add* ذَايسْ. \x ◘ \xo 105:‏12 \xt 1 إِم. 16‏:‏19\x*   
\m
\v 13 نِيثْنِي ثلْعنْ زِي ڒْڭنْسْ غَارْ ڒْڭنْسْ \add نّغْنِي\add*،  
\m زڭْ إِشْثْ ن ثْڭلْذِيثْ غَارْ إِجّْ ن ڒْڭنْسْ نّغْنِي.   
\m
\v 14 وَارْ إِجِّي ؤُڒَا ذ إِجّْ ن بْنَاذمْ  
\m أَذْ ثنْ إِسّحْصَارْ،  
\m إِعَاقبْ إِجدْجِيذنْ ذِي طّْوعْ نْسنْ. \x ◘ \xo 105:‏14 \xt أَمز. 35‏:‏5\x*   
\m
\v 15 وَارْ تّْحَاذَامْ شَا إِمذْهُوننْ إِنُو،  
\m وَارْ تّڭّمْ ڒْغَارْ ذڭْ إِنَابِييّنْ إِنُو.   
\b  
\m
\v 16 \add خنِّي\add* إِڒَاغَا-د إِ ڒَاژْ غَارْ ثمُّورْثْ.  
\m يَارْژَا أَسنْ مَارَّا ڒعْوتْشْ ن وغْرُومْ. \f ◼ \fr 105:‏16 \ft \+bd ’ڒعْوتْشْ ن وغْرُومْ‘\+bd* - لتّرْلِيجّْكْ ’أَزدْجَاضْ ن وغْرُومْ‘.\f*   
\m
\v 17 إِسّكّْ-د إِجّْ ن ورْيَازْ غَارْ زَّاثْ،  
\m يُوسُوفْ إِمّنْزْ ذ إِسْمغْ. \x ◘ \xo 105:‏17 \xt أَمز. 37‏:‏27، 35؛ 45‏:‏5\x*   
\m
\v 18 شَارْفنْ إِضَارنْ نّسْ ذڭْ إِشذِّييّنْ،  
\m ڒعْمَارْ نّسْ إِتّْوَاحْصَارْ ذڭْ وُوزَّاڒْ. \f ◼ \fr 105:‏18 \ft \+bd ’إِتّْوَاحْصَارْ ذڭْ وُوزَّاڒْ‘\+bd* - س ثْعِيبْرَانِيثْ ’يُوسَا-د وُوزَّاڒْ‘.\f*   
\m
\v 19 أَڒْ ڒْوقْثْ نِّي ذِي إِتّْوَاسّقْفڒْ  
\m وَاوَاڒْ نّسْ  
\m إِصفَّا أَسْ ڒْهَارْذْ ن سِيذِي.   
\m
\v 20 إِسّكّْ ؤُجدْجِيذْ \add إِجّْ\add* حِيمَا أَذْ أَسْ إِسَّارْخُو،  
\m ڒْْحَاكمْ نْ ڒڭْنُوسْ إِضْڒقْ إِ-ث.   
\m
\v 21 نتَّا إِڭَّا إِ-ث ذ بَابْ خْ ثَادَّارْثْ نّسْ،  
\m ؤُڒَا ذ ڒْحَاكمْ خْ مَارَّا مِينْ غَارسْ. \x ◘ \xo 105:‏21 \xt أَمز. 41‏:‏40\x*   
\m
\v 22 حِيمَا أَذْ غَارسْ إِشدّْ ڒْحُوكَّامْ  
\m ؤُ \add حِيمَا\add* أَذْ إِسّڒْمذْ ثِيغِيثْ إِ إِمْغَارنْ نّسْ.   
\m
\v 23 \add أَوَارْنِي أَيَا\add* يُوسَا-د إِسْرَائِيل غَارْ مِيصْرَا،  
\m إِقِّيمْ يَاعْقُوبْ أَمْ ؤُبَارَّانِي  
\m ذِي ثمُّورْثْ ن حَامْ.   
\m
\v 24 نتَّا إِڭَّا ڒْغِيدْجثْ ذِي ڒْڭنْسْ نّسْ أَطَّاسْ،  
\m يَارَّا إِ-ث إِجْهذْ خْ يِينِّي ث إِحصَّارنْ. \x ◘ \xo 105:‏24 \xt ؤُف. 1‏:‏7، 9\x*   
\b  
\m
\v 25 نتَّا يَارَّا ؤُڒْ نْسنْ إِنّقْڒبْ،  
\m أَڒَامِي ذوْڒنْ شَارّْهنْ ڒْڭنْسْ نّسْ،  
\m ذوْڒنْغدَّارنْ إِمْسخَّارنْ نّسْ. \x ◘ \xo 105:‏25 \xt ؤُف. 1‏:‏9، 10، 12\x*   
\m
\v 26 \add خنِّي\add* إِسّكّْ-د مُوسَا، أَمْسخَّارْ نّسْ،  
\m ذ هَارُونْ ونِّي إِفَارْزْ إِ-ث نتَّا. \x ◘ \xo 105:‏26 \xt ؤُف. 3‏:‏10؛ 4‏:‏12\x*   
\m
\v 27 نِيثْنِي ڭِّينْ ڒعْڒَامَاثْ نْسنْ إِفَارْزنْ جَارْ أَسنْ،  
\m ؤُ \add ڭِّينْ\add* لْمُوعْجِيزَاثْ ذِي ثمُّورْثْ ن حَامْ. \x ◘ \xo 105:‏27 \xt ؤُف. 7‏:‏9\x*   
\m
\v 28 نتَّا إِسّكّْ-د ثَادْجسْثْ  
\m ؤُشَا ثذْوڒْ مَارَّا ذ ثَادْجسْثْ.  
\m نِيثْنِي وَارْغوّْغنْ شَا خْ وَاوَاڒنْ نّسْ.   
\m
\v 29 نتَّا يَارَّا أَمَانْ نْسنْ ذ إِذَامّنْ  
\m ؤُ إِنْغَا إِسڒْمَانْ نْسنْ. \x ◘ \xo 105:‏29 \xt ؤُف. 7‏:‏17، 18، 20؛ أَسَا. 16‏:‏3، 4\x*   
\m
\v 30 نتَّا يَارَّا ثَامُّورْثْ نْسنْ  
\m ثْسفَّايْ س إِقَارْقْرِيونْ،  
\m أَڒْ ذَاخڒْ ذڭْ إِخَّامنْ ن إِجدْجِيذنْ نْسنْ.   
\m
\v 31 نتَّا إِسِّيوڒْ ؤُشَا يُوسَا-د  
\m ويْڒَافْ ن إِبعَّاشْ،  
\m نَّامُوسْ \add وْضَانْ-د\add*  
\m خْ ثمُّورْثْ نْسنْ مَارَّا.   
\m
\v 32 نتَّا يَارَّا أَنْژَارْ نْسنْ ذ أَبْرُورِّي،  
\m \add إِسّكّْ-د\add* ثِيمسِّي ذ إِشعَّاڒنْ  
\m خْ ثمُّورْثْ نْسنْ.   
\m
\v 33 نتَّا إِوْثَا ثَازَايَارْثْ نْسنْ ذ وَارْثُو نْسنْ،  
\m يَارْژَا ثِيشجُّورَا ذِي ثمُّورْثْ نْسنْ.   
\m
\v 34 نتَّا إِسِّيوڒْ، \add خنِّي\add* ثُوسَا-د ثْمُوغْرِي،  
\m ؤُڒَا ذ بُو-وڒْسَاحْ، أَقَا أَثنْ بْڒَا ڒحْسَابْ.   
\m
\v 35 نِيثْنِي شِّينْ مَارَّا أَفْسُو ذِي ثمُّورْثْ نْسنْ،  
\m شِّينْ ڒْغِيدْجثْ ن ثمُّورْثْ نْسنْ.   
\m
\v 36 نتَّا إِنْغَا مَارَّا إِمنْزَا  
\m ذِي ثمُّورْثْ نْسنْ،  
\m إِمنْزَا ن مَارَّا ثَارْيَاسْثْ نْسنْ. \x ◘ \xo 105:‏36 \xt إِزهد.78‏:‏51\x*   
\m
\v 37 نتَّا إِسُّوفّغْ إِ-ثنْ-د  
\m س نُّوقَارْثْ ذ وُورغْ،  
\m وَارْ ذِينْ ثُوغِي ؤُڒَا ذ إِجّْ  
\m ذِي ثْقبَّاڒْ نْسنْ إِ إِنْذرْفنْ.   
\m
\v 38 مِيصْرَا ثْفَارْحْ س وُوفُّوغْ نْسنْ،  
\m مَاغَارْ ثوْضَا خَاسنْ ثِيڭّْوُوذِي ثمْغَارْ. \x ◘ \xo 105:‏38 \xt ؤُف. 12‏:‏33\x*   
\b  
\m
\v 39 نتَّا إِبزّعْ أَسيْنُو أَمْ يِيجّْ ن أَرْوَاقْ  
\m ؤُ ثْمسِّي حِيمَا أَذْ ثوْشْ ثَافَاوْثْ س دْجِيڒثْ.   
\m
\v 40 نِيثْنِي ژُّودْجنْ ؤُ نتَّا يَارَّا  
\m أَذْ د-أَسنْ إِجْضَاضْ، قَّارنْ أَسْ ’ثْسَالْوَا‘،  
\m إِسّْجِّيونْ إِ-ثنْ س وغْرُومْ ن ؤُجنَّا.   
\m
\v 41 نتَّا يَارْزمْ ثَاصْضَارْثْ،  
\m أَمَانْ ذُوقّْزنْ-د زَّايسْ،  
\m ؤُزّْڒنْ خْ ڒَاژَاغْ \add ؤُ ذوْڒنْ\add* أَمْ يغْزَارْ.   
\m
\v 42 مَاغَارْ نتَّا إِعْقڒْ  
\m خْ وَاوَاڒْ نّسْ إِقدّْسنْ،  
\m خْ ؤُمْسخَّارْ نّسْ إِبْرَاهِيمْ. \x ◘ \xo 105:‏42 \xt أَمز. 15‏:‏14\x*   
\m
\v 43 نتَّا إِسُّوفّغْ-د ڒْڭنْسْ نّسْ  
\m س ڒفْرَاحثْ،  
\m إِنِّي زَّايسْ إِتّْوَافَارْزنْ س ؤُسْڒِيوْڒوْ. \x ◘ \xo 105:‏43 \xt ؤُف. 14‏:‏8؛ ڒخْڒ. 33‏:‏3\x*   
\m
\v 44 نتَّا إِوْشَا أَسنْ ثِيمُّورَا ن ڒڭْنُوسْ،  
\m نِيثْنِي وَارْثنْ ثَامَارَا ن شُّوعُوبْ،   
\m
\v 45 حِيمَا أَذْ طّْفنْ ذِي ثْوصَّا نّسْ،  
\m أَذْ حْضَانْ إِزرْفَانْ نّسْ. هَالِّيلُو-يَاه. \x ◘ \xo 105:‏45 \xt ؤُف. 19‏:‏4، 5، 6؛ أَعَوذ. 4‏:‏1، 40؛ 6‏:‏21، 22، 23، 24، 25\x*   
\b  
\b  
\m  
\c 106
\m
\v 1 هَالِّيلُو-يَاهْ، قَاذَامْ سِيذِي،  
\m مَاغَارْ نتَّا إِصْبحْ،  
\m مَاغَارْ ثَامخْسِيوْثْ نّسْ إِشوَّارنْ  
\m ثتّْغِيمَا إِ ڒبْذَا. \x ◘ \xo 106:‏1 \xt 1 إِم. 16‏:‏34‏-‏36؛ إِزهد. 107‏:‏1؛ 118‏:‏1؛ 136‏:‏1\x*   
\m
\v 2 وِي إِزمَّارنْ أَذْ إِحَاجَا  
\m ثِيمڭَّا ثِيمقّْرَانِينْ ن سِيذِي،  
\m أَذْ إِبَارّحْ مَارَّا شَّانْ نّسْ؟   
\m
\v 3 سّعْذْ نْسنْ إِ يِينِّي إِحْضَانْ ڒْحقّْ،  
\m \add سّعْذْ نّسْ\add* إِ ونِّي إِتّڭّنْ  
\m ڒبْذَا ثَاسڭْذَا.   
\m
\v 4 عْقڒْ خَافِي، \add أَ\add* سِيذِي،  
\m س أَرْضَا غَارْ ڒْڭنْسْ نّشْ،  
\m عَاهذْ أَيِي س ؤُسنْجمْ نّشْ،   
\m
\v 5 مَاحنْذْ أَذْ ژَترغْ ڒْخَارْ  
\m إِ يِينِّي زَّايكْ إِتّْوَافَارْزنْ،  
\m مَاحنْذْ أَذْ فَارْحغْ  
\m س ڒفْرَاحثْ ن ڒْڭنْسْ نّشْ،  
\m مَاحنْذْ أَذْ فَارْحغْ س يِيخفْ إِنُو  
\m \add جْمِيعْ\add* أَكْ-ذ ثسْغَارْثْ نّشْ.   
\b  
\m
\v 6 نشِّينْ نخْضَا، \add جْمِيعْ\add*  
\m أَكْ-ذ ڒجْذُوذْ نّغْ،  
\m نڭَّا ڒْغشّْ،  
\m نڭَّا ثُوعفّْنَا. \x ◘ \xo 106:‏6 \xt لَاوِي 26‏:‏40؛ إِرْم. 3‏:‏25؛ دَان. 9‏:‏5\x*   
\m
\v 7 ڒجْذُوذْ نّغْ ذِي مِيصْرَا وَارْ فْهِيمنْ  
\m إِ لْمُوعْجِيزَاثْ نّشْ،  
\m وَارْ خَارّْصنْ ذڭْ ؤُفيّضْ ن ثْمڭَّا  
\m ن ثْمخْسِيوْثْ نّشْ إِشوَّارنْ،  
\m مَاشَاغوّْغنْ غَارْ ڒبْحَارْ،  
\m غَارْ ڒبْحَارْ ن ثلْڭَا. \x ◘ \xo 106:‏7 \xt ؤُف. 14‏:‏11، 12\x*   
\m
\v 8 \add مَاشَا\add* نتَّا إِسّنْجمْ إِ-ثنْ  
\m ذِي طّْوعْ ن يِيسمْ نّسْ،  
\m حِيمَا أَذْ ثتّْوَاسّنْ ڒمْغَارثْ نّسْ. \x ◘ \xo 106:‏8 \xt ؤُف. 9‏:‏16\x*   
\m
\v 9 نتَّا إِوبّخْ ڒبْحَارْ ن ثلْڭَا  
\m أَڒَامِي إِذْوڒْ يُوژغْ،  
\m ؤُشَا إِجَّا إِ-ثنْ أَذْ كّنْ  
\m خْ \add وُوذمْ ن ثمُّورْثْ\add*  
\m \add جَارْ\add* \add وَامَانْ\add* إِهوْڒنْ أَخْمِي \add ذِي\add* ڒخْڒَا. \x ◘ \xo 106:‏9 \xt ؤُف. 14‏:‏21، 22، 29\x*   
\m
\v 10 نتَّا إِفكّْ إِ-ثنْ زڭْ ؤُفُوسْ  
\m ن يِينِّي \add إِ-ثنْ\add* إِشَارّْهنْ،  
\m إِفكّْ إِ-ثنْ زڭْ ؤُفُوسْ ن ڒعْذُو.   
\m
\v 11 أَمَانْ ذْڒِينْ إِنِّي ثنْ إِحصَّارنْ،  
\m وَارْ إِقِّيمْ ؤُڒَا ذ إِجّنْ زَّايْسنْ. \x ◘ \xo 106:‏11 \xt ؤُف. 14‏:‏27؛ 15‏:‏5\x*   
\m
\v 12 نِيثْنِي تّشْڒنْ خْ وَاوَاڒنْ نّسْ،  
\m صبّْحنْ أَسْ س يِيجّْ ن يزْڒِي ن ؤُصبّحْ. \x ◘ \xo 106:‏12 \xt ؤُف. 14‏:‏31؛ 15‏:‏1\x*   
\b  
\m
\v 13 \add مَاشَا\add* تُّونْ ذغْيَا ثِيمڭَّا نّسْ،  
\m وَارْ خْسنْ أَذْ رَاجَانْ \add عَاذْ\add* شّْوَارْ نّسْ.   
\m
\v 14 نِيثْنِي ذوْڒنْ تّْمغّْڒنْ أَطَّاسْ ذِي ڒخْڒَا،  
\m قدْجْبنْ أَربِّي ذِي ثْنزْرُوفْثْ. \x ◘ \xo 106:‏14 \xt ؤُف. 16‏:‏3؛ ڒخْڒ. 11‏:‏4، 6، 33؛ إِزهد. 78‏:‏18؛ 1 كُور. 10‏:‏6\x*   
\m
\v 15 \add خنِّي\add* إِوْشَا أَسنْ مِينْ تَّارنْ،  
\m \add مَاشَا\add* إِسّمْژِي \add ڒْْقدّْ ن\add* ڒعْمُورْ نْسنْ. \x ◘ \xo 106:‏15 \xt ڒخْڒ. 11‏:‏20، 33؛ إِزهد. 78‏:‏30، 31؛ إِشا. 10‏:‏16\x*   
\m
\v 16 نِيثْنِي ذوْڒنْ ؤُسْمنْ زِي مُوسَا  
\m ذِي ڒْمَارْڭحْ ن ڒْعسْكَارْ،  
\m ؤُڒَا زِي هَارُونْ، أَمْقدّسْ ن سِيذِي. \x ◘ \xo 106:‏16 \xt ڒخْڒ. 16\x*   
\m
\v 17 ثَامُّورْثْ ثنُّورْزمْ، ثْصَارْضْ ذَاثَانْ،  
\m ؤُشَا ثنْثِييْ أَبَارُّو ن أَبِيرَامْ. \x ◘ \xo 106:‏17 \xt ڒخْڒ. 16‏:‏31، 32، 33؛ أَعَوذ. 11‏:‏6\x*   
\m
\v 18 ثِيمسِّي ثبْذَا ثشْمضْ جَارْ ؤُبَارُّو نْسنْ،  
\m إِجّْ ن ؤُشعَّاڒْ ن ثْمسِّي  
\m إِقّذْ إِعفَّاننْ \add نِّي\add*. \x ◘ \xo 106:‏18 \xt ڒخْڒ. 16‏:‏35،46\x*   
\m
\v 19 نِيثْنِي ڭِّينْ إِجّْ ن ؤُعجْمِي غَارْ حُورِيبْ،  
\m بنْذْقنْ إِ يِيجّْ ن ڒخْيَاڒْ إِفسْينْ. \x ◘ \xo 106:‏19 \xt ؤُف. 32‏:‏4\x*   
\m
\v 20 نِيثْنِي بدّْڒنْ أَعُودْجِي ن سِيذِي  
\m أَكْ-ذ ڒخْيَاڒْ ن إِجّْ ن ؤُفُونَاسْ  
\m إِ إِتّتّنْ أَرْبِيعْ. \x ◘ \xo 106:‏20 \xt إِرْم. 2‏:‏11؛ رُوم. 1‏:‏22‏-‏23\x*   
\m
\v 21 تُّونْ أَربِّي، أَمْسنْجمْ نْسنْ،  
\m ونِّي ثُوغَا إِڭِّينْ  
\m ثِيمڭَّا ثِيمقّْرَانِينْ ذِي مِيصْرَا،   
\m
\v 22 لْمُوعْجِيزَاثْ ذِي ثمُّورْثْ ن حَامْ،  
\m ثِيمڭَّا سَّاڭّْوَاذنْثْ  
\m غَارْ ڒبْحَارْ ن ثلْڭَا.   
\m
\v 23 إِنَّا أَقَا أَذْ ثنْ إِكحّضْ،  
\m مْڒِي وَارْ إِدْجِي ذ مُوسَا،  
\m ونِّي زَّايسْ إِتّْوَافَارْزنْ،  
\m إِكَّارْ-د ذِي ثْخنْذُوقْثْ زَّاثْ إِ وُوذمْ نّسْ  
\m ذِي طّْوعْ نْسنْ،  
\m مَاحنْذْ أَذْ إِسّْبعّذْ أَسْعَارْ نّسْ  
\m إِ زِي إِخْسْ أَذْ ثنْ يَاردّدْجْ. \x ◘ \xo 106:‏23 \xt ؤُف. 32‏:‏11، 32؛ أَعَوذ. 9‏:‏13، 14؛ 10‏:‏10\x*   
\b  
\m
\v 24 نِيثْنِي كّْسنْ ثَاقْشُورْثْ  
\m خْ ثمُّورْثْ إِعِيزّنْ،  
\m وَارْ ثشْڒنْ شَا خْ وَاوَاڒْ نّسْ. \x ◘ \xo 106:‏24 \xt ڒخْڒ. 14‏:‏1، 2\x*   
\m
\v 25 نِيثْنِي نْذقْمنْ ذڭْ إِقِيضَانْ نْسنْ،  
\m وَارْ سْڒِينْ غَارْ ثْمِيجَّا ن سِيذِي.   
\m
\v 26 نتَّا إِسّْڭعّذْ أَفُوسْ نّسْ خَاسنْ،  
\m \add إِجِّيدْجْ\add* أَذْ ثنْ إِسّغْضڒْ ذِي ڒخْڒَا، \x ◘ \xo 106:‏26 \xt ڒخْڒ. 14‏:‏28\x*   
\m
\v 27 مَاحنْذْ أَذْ إِسّغْضڒْ ثَارْوَا نْسنْ  
\m جَارْ ڒڭْنُوسْ،  
\m مَاحنْذْ أَذْ ثنْ إِزدْجعْ ذِي ثمُّورَا. \x ◘ \xo 106:‏27 \xt إِزهد. 44‏:‏12؛ حِز. 20‏:‏23\x*   
\m
\v 28 نِيثْنِي سّْڒحْمنْ إِخفْ نْسنْ  
\m غَارْ بَاعَالْ-فَاغُورْ،  
\m شِّينْ ثِيغَارْصَا إِ إِمتَّانْ. \x ◘ \xo 106:‏28 \xt ڒخْڒ. 25‏:‏3؛ 31‏:‏16؛ أَسَا. 2‏:‏14\x*   
\m
\v 29 سْعَارنْ ث س ثْمڭَّا نْسنْ،  
\m أَڒَامِي د خَاسنْ ثوْضَا جّْرِيحشْثْ.   
\m
\v 30 \add خنِّي\add* إِكَّارْ-د فِينَاحَاسْ،  
\m يُوسَا-د جَارْ أَسنْ،  
\m ؤُ أَمُّو إِ ثتّْوَاسّْبدّْ جّْرِيحشْثْ.   
\m
\v 31 أَيَا إِتّْوَاحْسبْ أَسْ-د ذ ثَاسڭْذَا،  
\m زِي جِّيڒْ أَڒْ جِّيڒْ إِ ڒبْذَا.   
\m
\v 32 نِيثْنِي سْعَارنْ أَفُوڭمْ نّسْ  
\m غَارْ وَامَانْ ن مَارِيبَا،  
\m أَڒَامِي إِڭَّا مُوسَا ڒْغَارْ ذِي سِّيبّثْ نْسنْ، \x ◘ \xo 106:‏32 \xt ڒخْڒ. 20‏:‏12؛ إِزهد. 95‏:‏8\x*   
\m
\v 33 مَاغَارْ سَّارزْڭنْ ڒعْمَارْ نّسْ،  
\m غَارسْ أَڒَامِي إِفّغْ وَاوَاڒْ وَارْ إِضْبِيعنْ  
\m زڭْ إِينْشِيشنْ نّسْ.   
\b  
\m
\v 34 نِيثْنِي وَارْ ثحَّانْ ڒڭْنُوسْ  
\m عْلَاحْسَابْ مِينْ ذ أَسنْ يُومُورْ سِيذِي.   
\m
\v 35 \add مَاشَا\add* صُّورنْ إِخفْ نْسنْ أَكْ-ذ ڒڭْنُوسْ  
\m ڒمْذنْ \add أَذْ ڭّنْ\add* مِينْ ڭِّينْ نِيثْنِي. \x ◘ \xo 106:‏35 \xt ڒقض. 2‏:‏2؛ 3‏:‏5، 6\x*   
\m
\v 36 نِيثْنِي ثُوغَا تّْسخَّارنْ  
\m إِ ڒخْيَاڒَاثْ ن لْ-أَصْنَامْ نْسنْ،  
\m إِنِّي ذ أَسنْ إِذوْڒنْ ذ ڒْفخْ.   
\m
\v 37 نِيثْنِي إِوْينْ إِحنْجِيرنْ نْسنْ  
\m ذ ثْحنْجِيرِينْ نْسنْ ذ ثَاغَارْصْثْ إِ شّْوَاطنْ. \x ◘ \xo 106:‏37 \xt لَاوِي 18‏:‏21؛ أَعَوذ. 12‏:‏31؛ 2 إِج. 16‏:‏3؛ 17‏:‏17؛ 21‏:‏6؛ 2 إِم. 28‏:‏3؛ 33‏:‏6\x*   
\m
\v 38 نِيثْنِي سِّيزّْڒنْ إِذَامّنْ إِمزْذَاڭنْ،  
\m إِذَامّنْ ن إِحنْجِيرنْ نْسنْ  
\m ذ ثْحنْجِيرِينْ نْسنْ،  
\m نِّي إِوْينْ ذ ثَاغَارْصْثْ  
\m إِ ڒخْيَاڒَاثْ ن لْ-أَصْنَامْ ن كنْعَانْ،  
\m أَڒَامِي ثذْوڒْ ثمُّورْثْ ثفْسذْ  
\m س إِذَامّنْ. \x ◘ \xo 106:‏38 \xt ڒخْڒ. 35‏:‏33\x*   
\m
\v 39 نِيثْنِي ذوْڒنْ خمْجنْ زِي ثْمڭَّا نْسنْ،  
\m سّْفسْذنْ إِخفْ نْسنْ س ڒخْذَايمْ نْسنْ.   
\m
\v 40 يَارْغَا وغْضَابْ ن سِيذِي خْ ڒْڭنْسْ نّسْ  
\m ؤُ نتَّا إِعِيفّْ ثَاسْغَارْثْ نّسْ.   
\m
\v 41 نتَّا إِسلّمْ إِ-ثنْ  
\m غَارْ إِفَاسّنْ ن ڒڭْنُوسْ  
\m ؤُ إِنِّي ثنْ إِشَارّْهنْ ذوْڒنْ تّْسدْجَاضنْ خَاسنْ.   
\m
\v 42 حْصَارنْ ثنْ ڒْعذْيَانْ نْسنْ،  
\m نِيثْنِي تّْوَاسّْوَاضْعنْ سَاذُو أَفُوسْ نْسنْ.   
\m
\v 43 أَطَّاسْ ن ثْوَاڒَاوِينْ ثُوغَا إِتّْفكَّا إِ-ثنْ،  
\m \add مَاشَا\add* نِيثْنِي سَّارزْڭنْ خَاسْ  
\m س ثْغنَّانْثْ نْسنْ،  
\m تّْوَاسّْمژْينْ س ڒْمُوعْصِييّثْ نْسنْ.   
\m
\v 44 \add وَاخَّا أَمنِّي\add* نتَّا إِخْزَارْ \add عَاذْ\add* غَارْسنْ  
\m ؤُمِي ثنْ ثُوغَا ذِي ڒحْصَارثْ،  
\m ؤُمِي إِسْڒَا ثْغُويِّيثْ نْسنْ.   
\m
\v 45 يِيذَارْ ڒْعَاهْذْ نّسْ ذِي طّْوعْ نْسنْ  
\m ؤُ إِنْذمْ زِي سِّيبّثْ  
\m ن ثْمخْسِيوْثْ نّسْ إِشوَّارنْ.   
\m
\v 46 إِسّْشنْ أَسنْ أَرّحْمثْ \add نّسْ\add*  
\m زَّاثْ إِ وُوذمْ ن مَارَّا  
\m إِنِّي ثنْ إِحبّْسنْ.   
\m
\v 47 سنْجمْ أَنغْ، \add أَ\add* سِيذِي، أَربِّي،  
\m نْذهْ أَنغْ نْمُونْ زِي ڒڭْنُوسْ،  
\m حِيمَا أَذْ نْقَاذَا إِسمْ أَمْقدَّاسْ نّشْ،  
\m أَذْ شكْ نْصبّحْ س يزْڒَانْ ن ؤُسمْغَارْ. \x ◘ \xo 106:‏47 \xt 1 إِم. 16‏:‏35\x*   
\b  
\m
\v 48 أَذْ إِتّْوَابَاركْ سِيذِي، أَربِّي ن إِسْرَائِيل،  
\m زِي ڒبْذَا أَڒْ ڒبْذَا!“  
\b  
\m أجّْ مَارَّا ڒْڭنْسْ أَذْ يِينِي:  
\m ’أَمِينْ! هَالِّيلُو-يَاهْ!‘ \x ◘ \xo 106:‏48 \xt 1 إِم. 16‏:‏36\x*   
\b  
\b  
\m  
\c 107
\s1 أَذْلِيسْ وِيسّْ خمْسَا: إِزهِّيذنْ 107-150  
\m
\v 1 قَاذَامْ سِيذِي،  
\m مَاغَارْ نتَّا إِصْبحْ،  
\m مَاغَارْ ثَامخْسِيوْثْ نّسْ إِشوَّارنْ  
\m \add ثتّْغِيمَا\add* إِ ڒبْذَا.   
\m
\v 2 أجّْ إِنِّي إِتّْوَافكّنْ ن سِيذِي  
\m أَذْ سِّيوْڒنْ أَمُّو،  
\m إِنِّي إِفكّْ زڭْ ؤُفُوسْ  
\m ن يِينِّي \add ثنْ\add* إِحصَّارنْ، \f ◼ \fr 107:‏2 \ft \+bd ’إِتّْوَافْذِينْ ... إِفْذِي‘\+bd* - خْزَارْ إِزهد. 78‏:35.\f*  \x ◘ \xo 107:‏2 \xt إِزهد. 35‏:‏9؛ إِزهد. 63‏:‏2، 3؛ إِشا. 49‏:‏12؛ 56‏:‏18؛ 62‏:‏12؛ \x*   
\m
\v 3 إِنِّي إِسّْمُونْ زِي ثمُّورَا،  
\m زِي شَّارْقْ، زِي ڒْغَارْبْ، زِي شَّامَالْ  
\m ؤُ زِي ڒبْحَارْ. \x ◘ \xo 107:‏3 \xt إِزهد. 106‏:‏47؛ أَعَوذ. 30‏:‏4، 5 \x*   
\b  
\m
\v 4 \add ثُوغَا ذِينْ\add* إِنِّي إِودَّارنْ ذِي ڒخْڒَا،  
\m أَبْرِيذْ \add نْسنْ\add* إِكَّا خْ ثْنزْرُوفْثْ،  
\m وَارْ ؤُفِينْ ثَانْذِينْثْ  
\m مَاحنْذْ أَذْ ذَايسْ زذْغنْ.   
\m
\v 5 ذَايْسنْ ڒَاژْ ذ ؤُفَاذِي،  
\m ڒعْمَارْ نْسنْ إِفْشڒْ ذَايْسنْ.   
\m
\v 6 \add خنِّي\add* سْغُوينْ غَارْ سِيذِي ذِي ڒحْصَارثْ نْسنْ،  
\m \add ؤُ\add* نتَّا إِفكّْ إِ-ثنْ زِي ثِيڭّْوُوذِي نْسنْ.   
\m
\v 7 نتَّا إِنْذهْ إِ-ثنْ  
\m ذڭْ إِجّْ ن وبْرِيذْ إِسڭّذْ،  
\m مَاحنْذْ أَذْ ؤُيُورنْ غَارْ إِشْثْ ن ثنْذِينْثْ  
\m حِيمَا أَذْ \add ذَايسْ\add* زذْغنْ.   
\m
\v 8 أجّْ إِ-ثنْ أَذْ قَاذَانْ سِيذِي  
\m خْ ثْمخْسِيوْثْ نّسْ إِشوَّارنْ،  
\m خْ لْمُوعْجِيزَاثْ نّسْ إِ ثَارْوَا ن بْنَاذمْ.   
\m
\v 9 مَاغَارْ نتَّا إِسّْجِّيونْ ڒعْمَارْ إِفُّوذنْ،  
\m ڒعْمَارْ إِدْجُوژنْ إِشُّورْ إِ-ث س ڒْخَارْ.   
\b  
\m
\v 10 \add ثُوغَا ذِينْ\add* إِنِّي إِقِّيمنْ  
\m ذِي ثَادْجسْثْ ذ ثِيڒِي ن ڒْموْثْ،  
\m س إِشذِّيينْ ن دّدْجْ ذ وُوزَّاڒْ،   
\m
\v 11 مَاغَارْغوّْغنْ  
\m أَكْ-ذ وَاوَاڒنْ ن أَربِّي،  
\m وَارْ سْڒِينْ غَارْ شّْوَارْ  
\m ن ؤُمْعُودْجِي خْ كُوڒْشِي.   
\m
\v 12 نتَّا إِسّقْنعْ ؤُڒْ نْسنْ س ثَامَارَا،  
\m نّْذرْفنْ، وَارْ ؤُفِينْ وِي غَا إِوْشنْ أَفُوسْ.   
\m
\v 13 \add خنِّي\add* ڒَاغَانْ إِ سِيذِي ذِي ڒحْصَارثْ نْسنْ  
\m ؤُ نتَّا إِسّنْجمْ إِ-ثنْ  
\m زِي ثِيڭّْوُوذِي نْسنْ،   
\m
\v 14 نتَّا إِسُّوفّغْ إِ-ثنْ زِي ثَادْجسْثْ  
\m ؤُ زِي ثِيڒِي ن ڒْموْثْ،  
\m يَارْژَا إِشذِّيينْ نْسنْ.   
\m
\v 15 أجّْ إِ-ثنْ أَذْ قَاذَانْ سِيذِي  
\m خْ ثْمخْسِيوْثْ نّسْ إِشوَّارنْ،  
\m خْ لْمُوعْجِيزَاثْ نّسْ إِ ثَارْوَا ن بْنَاذمْ.   
\m
\v 16 مَاغَارْ نتَّا يَارْژَا ثِيوُّورَا ن نّْحَاسْ،  
\m إِشَارّڭْ زّكْرُونَاثْ ن وُوزَّاڒْ.   
\b  
\m
\v 17 \add ثُوغَا ذِينْ\add* إِبُوهَاڒِييّنْ إِنِّي إِتّْوَاغزَّانْ  
\m زِي سِّيبّثْ ن ؤُخطُّو نْسنْ ذ ڒْمُوعْصِييّثْ نْسنْ.   
\m
\v 18 إِعِيفّْ ڒعْمَارْ نْسنْ زِي مَارَّا مَاشَّا،  
\m إِوْضنْ أَڒْ ثوُّورَا ن ڒْموْثْ.   
\m
\v 19 \add خنِّي\add* ڒَاغَانْ إِ سِيذِي ذِي ڒحْصَارثْ نْسنْ  
\m ؤُ نتَّا إِسّنْجمْ إِ-ثنْ زِي ثِيڭّْوُوذِي نْسنْ.   
\m
\v 20 نتَّا إِسّكّْ أَوَاڒْ نّسْ،  
\m إِسّْڭنْفَا إِ-ثنْ ؤُ إِسّنْجمْ إِ-ثنْ  
\m زڭْ إِحُوفَارْ نْسنْ.   
\m
\v 21 أجّْ إِ-ثنْ أَذْ قَاذَانْ سِيذِي  
\m خْ ثْمخْسِيوْثْ نّسْ إِشوَّارنْ،  
\m خْ لْمُوعْجِيزَاثْ نّسْ إِ ثَارْوَا ن بْنَاذمْ.   
\m
\v 22 أجّْ إِ-ثنْ أَذْ أَوْينْ ثِيوْهِيبِينْ ن ؤُقَاذِي،  
\m أَذْ بَارّْحنْ ثِيمڭَّا نّسْ س ؤُسْڒِيوْڒوْ. \x ◘ \xo 107:‏22 \xt لَاوِي 7‏:‏12؛ إِزهد. 50‏:‏14\x*   
\b  
\m
\v 23 \add ثُوغَا ذِينْ\add* إِنِّي إِهكّْوَانْ  
\m غَارْ ڒبْحَارْ س إِغَارُّوبَا،  
\m إِنِّي إِخدّْمنْ خْ وَامَانْ إِوسْعنْ. \x ◘ \xo 107:‏23 \xt أَسَا. 18‏:‏17\x*   
\m
\v 24 ژْرِينْ مِينْ إِڭَّا سِيذِي،  
\m ؤُڒَا ذ لْمُوعْجِيزَاثْ نّسْ ذِي ڒَادْجَاغْ \add ن ڒبْحَارْ\add*.   
\m
\v 25 مَاڒَا نتَّا إِسِّيوڒْ،  
\m إِكَّارْ-د إِجّْ ن ؤُسمِّيضْ  
\m نِّي إِسّْڭعّْذنْ ڒمْوَاجْ نّسْ.   
\m
\v 26 ڭعّْذنْ غَارْ ؤُجنَّا  
\m ؤُشَا هْوَانْ غَارْ ثِيسِي ن \add وَامَانْ\add* إِهوْڒنْ.  
\m إِفْسِي ڒعْمَارْ نْسنْ زِي ثِيڭّْوُوذِي.   
\m
\v 27 ميّْڒنْ، ميّْڒمْ  
\m زِي سَّا غَارْ ذَا أَمْ ؤُمسْشَارْ،  
\m إِودَّارْ أَسنْ مَارَّا ڒعْقڒْ نْسنْ.   
\m
\v 28 \add خنِّي\add* ڒَاغَانْ إِ سِيذِي ذِي ڒحْصَارثْ نْسنْ  
\m \add ؤُ\add* نتَّا إِسُّوفّغْ إِ-ثنْ-د  
\m زِي ثِيڭّْوُوذِي نْسنْ.   
\m
\v 29 نتَّا يَارَّا أَسمِّيضْ أَذْ يَارْسَا،  
\m أَڒَامِي ذوْڒنْ ڒمْوَاجْ سّغْضنْ.   
\m
\v 30 نِيثْنِي فَارْحنْ ؤُمِي أَرْسِينْ \add ڒمْوَاجْ\add*  
\m ؤُ \add ؤُمِي\add* نتَّا إِنْذهْ إِ-ثنْ  
\m غَارْ ڒْمُويِّي إِ غَارسْ ثُوغَا تّْمژْرِيينْ.   
\m
\v 31 أجّْ إِ-ثنْ أَذْ قَاذَانْ سِيذِي  
\m خْ ثْمخْسِيوْثْ نّسْ إِشوَّارنْ،  
\m خْ لْمُوعْجِيزَاثْ نّسْ إِ ثَارْوَا ن بْنَاذمْ،   
\m
\v 32 أجّْ إِ-ثنْ أَذْ ث سّْعُودْجنْ  
\m ذڭْ وڭْرَاوْ ن ڒْڭنْسْ،  
\m أَذْ ث شنّْعنْ ذِي ڒْحڒْقثْ ن إِمْغَارنْ.   
\b  
\m
\v 33 نتَّا يَارَّا إِغزْرَانْ ذ ڒخْڒَا،  
\m ڒْْعُونْصَارَاثْ \add يَارَّا إِ-ثنْثْ\add*  
\m ذ ثَامُّورْثْ إِفُّوذنْ،   
\m
\v 34 ثَامُّورْثْ إِ إِتِّيشنْ ڒْغِيدْجثْ  
\m \add يَارَّا إِ-ت\add* ذ ثَامدْجَاحْثْ،  
\m زِي سِّيبّثْ ن ثُوعفّْنَا  
\m ن يِينِّي ذَايسْ إِزدّْغنْ.   
\m
\v 35 نتَّا يَارَّا ڒخْڒَا  
\m ذ أَيڒْمَامْ ن وَامَانْ،  
\m ثَامُّورْثْ يُوژْغنْ ذ ڒْعُونْصَارَاثْ.\x ◘ \xo 107:‏35 \xt إِشا. 41‏:‏18\x*   
\m
\v 36 ذِينِّي إِ إِسّزْذغْ إِنِّي إِدْجُوژنْ  
\m ؤُشَا \add ذِينْ\add* سّْبدّنْ \add نِيثْنِي\add* إِشْثْ ن ثنْذِينْثْ  
\m مَاحنْذْ أَذْ \add ذَايسْ\add* زذْغنْ.   
\m
\v 37 نِيثْنِي زَارّْعنْ ذڭْ إِيَّارنْ،  
\m تّژُّونْ ثِيزَايَارِينْ ذڭْ إِمَارْجَاعنْ،  
\m ثِينِّي د-إِتَّاوْينْ إِڭُومَّا  
\m ذ ڒْغِيدْجثْ \add نْسنْ\add*.   
\m
\v 38 نتَّا إِبَاركْ إِ-ثنْ،  
\m \add أَڒَامِي\add* ذوْڒنْ ذڭْ وَاطَّاسْ،  
\m أَڭْڒَا ن ڒْمَاڒْ نْسنْ وَارْ إِتّْوَاسّمْژِي.   
\b  
\m
\v 39 \add خنِّي\add* مَاشَا ذَاكّْوَاڒنْ ذِي ذْرُوسْ \add عَاوذْ\add*،  
\m هكّْوَانْ غَارْ ڒَادْجَاغْ  
\m زِي سِّيبّثْ ن ڒحْصَارثْ  
\m ذ ڒغْبنْ ذ وشْضَانْ.   
\m
\v 40 نتَّا إِتّْكبَّا أَسحْقَارْ  
\m خْ ثَارْوَا ن ثَاصِيڒثْ،  
\m إِجَّا إِ-ثنْ تّثْلِيعنْ ذِي ڒخْڒَا  
\m مَانِي وَارْ \add دْجِينْ\add* إِبْرِيذنْ. \x ◘ \xo 107:‏40 \xt أَيُوبْ. 12‏:‏24\x*   
\m
\v 41 إِسّْڭعّذْ-د أَمزْڒُوضْ زِي ڒغْبنْ  
\m ؤُشَا يَارَّا ڒَادْجَاثْ أَمْ ثْحِيمَارِينْ ن وُودْجِي. \x ◘ \xo 107:‏41 \xt 1 صم. 2‏:‏8؛ إِزهد. 113‏:‏7، 8\x*   
\m
\v 42 إِنِّي إِڭُّورنْ نِيشَانْ تّْوَاڒَانْ  
\m ؤُشَا فَارّْحنْ،  
\m \add مَاشَا\add* مَارَّا \add أَيْثْ ن\add* ڒْمُوعْصِييّثْ  
\m تّقّْننْ أَقمُّومْ \add نْسنْ\add*. \x ◘ \xo 107:‏42 \xt أَيُوبْ 5‏:‏16؛ 22‏:‏19\x*   
\b  
\m
\v 43 ونِّي ذ أَمِيغِيسْ، أجّْ إِ-ث أَذْ إِحْضَا،  
\m أجّْ إِ-ثنْ أَذْ سّْننْ نِيشَانْ  
\m ثِيمڭَّا ن ثْمخْسِيوْثْ ن سِيذِي.   
\b  
\b  
\m  
\c 108
\m
\v 1 \add إِزْڒِي. أَزهّذْ ن ذَاوُوذْ.\add*   
\b  
\m
\v 2 \add أَ\add* أَربِّي، ؤُڒْ إِنُو إِعوّڒْ،  
\m أَذْغنّْجغْ أَذْ زهّْذغْ،  
\m \add وَاهْ\add* ؤُڒَا ذ أَعُودْجِي إِنُو.   
\m
\v 3 فَاقْ، لهَارْبَا ذ ڒْڭَامْبْرِي!  
\m نشّْ خْسغْ أَذْ سّْفَاقغْ ثَافَاوْثْ ن ڒفْجَارْ.   
\b  
\m
\v 4 نشّْ أَذْ شكْ قَاذِيغْ جَارْ ڒڭْنُوسْ، \add أَ\add* سِيذِي،  
\m أَذْ أَكْ زهّْذغْ جَارْ شُّوعُوبْ.   
\m
\v 5 مَاغَارْ ثَامخْسِيوْثْ نّشْ إِشوَّارنْ  
\m \add ثتَّاكّْوَاضْ\add* ثِيوَا إِ إِجنْوَانْ،  
\m ڒَْامَانْ نّشْ أَڒْ إِسيْنُوثنْ. \x ◘ \xo 108:‏5 \xt إِزهد. 36‏:‏6؛ 57‏:‏11\x*   
\m
\v 6 \add أَ\add* أَربِّي، سْڭعّذْ إِخفْ نّشْ  
\m ثِيوَا إِ إِجنْوَانْ،  
\m \add أَرّْ\add* أَعُودْجِي نّشْ خْ مَارَّا ثَامُّورْثْ،   
\b  
\m
\v 7 حِيمَا إِمْعِيزّنْ نّشْ أَذْ تّْوَانجْمنْ،  
\m أَوِي أَسنْجمْ س ؤُفُوسْ أَفُوسِي نّشْ  
\m ؤُ أَرّْ-د خَانغْ \add أَوَاڒْ\add*.   
\b  
\m
\v 8 أَربِّي ثُوغَا إِسَّاوَاڒْ  
\m ذِي زَّاوشْثْ نّسْ إِقدّْسنْ،  
\m س ؤُينِّي إِ غَا نڭْزغْ س ڒفْرَاحثْ.  
\m نشّْ أَذْ بْضِيغْ شَاكِيمْ،  
\m أَذْعبَّارغْ ثَايْسَارْثْ ن سُوكُّوثْ.   
\m
\v 9 جِيلْعَاذْ إِنُو، مَانَاسَّا إِنُو،  
\m إِفْرَايِيمْ ذ أَسڒْقِي إِجهْذنْ ن ؤُزدْجِيفْ إِنُو،  
\m يَاهُوذَا ذ أَمْڭوّذْ إِنُو.   
\m
\v 10 مَاشَا مُوآبَ ذ سَّارِيجْ إِنُو ن ؤُسِيرْذْ،  
\m خْ إِذُومْ أَذْ نْضَارغْ سَانْذَالِييَاثْ إِنُو،  
\m خْ \add ثمُّورْثْ ن\add* فِيلِيشِيثْ  
\m أَذْ ذُوقّْزغْ س ؤُسْڒِيوْڒوْ.   
\b  
\m
\v 11 وِي ذ أَيِي غَا إِنذْهنْ  
\m \add غَارْ\add* ثنْذِينْثْ إِفَارْينْ؟  
\m وِي ذ أَيِي غَا إِڭوّْذنْ غَارْ إِذُومْ؟   
\m
\v 12 مَا وَارْ ذ أَنغْ ثنْضَارذْ، \add أَ\add* أَربِّي،  
\m ؤُ أَكْ-ذ ڒْعسْكَارَاثْ نّغْ مَا \add زعْمَا\add*  
\m وَارْ د-ثفِّيغذْ \add عَاذْ\add* أَكِيذْسنْ،  
\m \add أَ\add* أَربِّي؟ \x ◘ \xo 108:‏12 \xt إِزهد. 60‏:‏3\x*   
\m
\v 13 أوْشْ أَنغْ أَفُوسْ  
\m \add حِيمَا أَذْ أَنغْ ثسّْنجْمذْ\add* زِي ڒحْصَارثْ،  
\m \add مَاغَارْ\add* أَسنْجمْ \add س ؤُفُوسْ ن\add* يِيجّْ ن بْنَاذمْ  
\m أَقَا إِبْضڒْ.   
\m
\v 14 أَكْ-ذ أَربِّي أَذْ نڭّْ س ومْحَاضْ  
\m ؤُ نتَّا أَذْ إِعْفسْ خْ يِينِّي ذ أَنغْ إِحصَّارنْ.   
\b  
\b  
\m  
\c 109
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. أَزهّذْ ن ذَاوُوذْ.\add*  
\b  
\m \add أَ\add* أَربِّي ن ؤُصبّحْ إِنُو، وَارْ سْغِيذِي!   
\m
\v 2 مَاغَارْ أَقمُّومْ ن إِجّْ ن ؤُعفَّانْ،  
\m أَقَا أَقمُّومْ \add إِشُّورْ س\add* إِخَارِّيقنْ  
\m إِنُّورْزمْ خَافِي.  
\m نِيثْنِي سَّاوَاڒنْ أَكِيذِي  
\m س يِيجّْ ن يِيڒسْ إِسّْخَارِّيقنْ.   
\m
\v 3 نّْضنْ أَيِي-د  
\m س وَاوَاڒنْ إِشُّورنْ س وشْرَاهْ،  
\m تّْمنْغَانْ أَكِيذِي خْ وَالُو. \x ◘ \xo 109:‏3 \xt إِزهد. 69‏:‏5\x*   
\m
\v 4 إِ ثْوَارِّيثْ خْ ثْمخْسِيوْثْ إِنُو،  
\m شّثْشَانْ نِيثْنِي زَّايِي  
\m ؤُ نشّْ كسِّيغْ س ڒْمعْرُوفْ.   
\m
\v 5 نِيثْنِي خدْجْصنْ أَيِي ڒْخَارْ س ڒْغَارْ،  
\m ثَامخْسِيوْثْ إِنُو س وشْرَاهْ.   
\b  
\m
\v 6 أڭّْ خَاسْ إِجّْ ن ؤُعفَّانْ،  
\m أجّْ إِجّْ ن شِّيطَانْ أَذْ إِبدّْ  
\m غَارْ ؤُغزْذِيسْ نّسْ. \x ◘ \xo 109:‏6 \xt زَاك. 3‏:‏1، 2\x*   
\m
\v 7 مَاڒَا خَاسْ شَارّْعنْ،  
\m أَذْ إِفّغْ أَمْ ؤُقْطَاطْعِي  
\m ؤُشَا أجّْ ثَاژَادْجِيثْ نّسْ أَذْ ثِيڒِي ذ دّنْبْ. \x ◘ \xo 109:‏7 \xt أَوڒن. 15‏:‏8؛ 28‏:‏9\x*   
\m
\v 8 أَذْ ذوْڒنْ ؤُسَّانْ نّسْ ؤُذْرُوسنْ،  
\m أجّْ ونّغْنِي أَذْ إِطّفْ ڒْفُوسِينَا نّسْ. \x ◘ \xo 109:‏8 \xt ڒخ. 1‏:‏20\x*   
\m
\v 9 أَذْ ذوْڒنْ إِحنْجِيرنْ نّسْ ذ إِيُوجِيڒنْ،  
\m ثَامْغَارْثْ نّسْ ذ ثَاجَّاتْشْ.   
\m
\v 10 أَذْ ثلّْعنْ إِحنْجِيرنْ نّسْ ذَا ذ ذِيهَا،  
\m أَذْ تَّارنْ، أَذْ أَرْزُونْ خْ مَاشَّا  
\m غَارْ ڒَاڭّْوَاجْ ن ڒْخِيرْبَاثْ \add ن ثْزذِّيغِينْ\add* نْسنْ.   
\b  
\m
\v 11 أَذْ إِتَّارْ بُو-ؤُمَارْوَاسْ مَارَّا مِينْ غَارسْ،  
\m أَذْ كشّْضنْ إِبَارَّانِييّنْ  
\m \add ڒْْغِيدْجثْ ن\add* وَارْبرْ نّسْ.   
\m
\v 12 وَارْ غَارسْ إِتِّيڒِي ؤُڒَا ذ إِجّنْ  
\m ونِّي ذ أَسْ إِ غَا إِڭِّينْ  
\m س ثْمخْسِيوْثْ إِشوَّارنْ،  
\m أجّْ ؤُڒَا ذ إِجّْ أَذْ إِحِينّْ  
\m خْ إِيُوجِيڒنْ نّسْ.   
\m
\v 13 أَذْ تّْوَاثحَّانْ ثَارْوَا نّسْ أَوَارْنِي أَسْ،  
\m أَذْ إِتّْوَامْحَا إِسمْ نْسنْ  
\m ذِي جِّيڒْ إِ د غَا يَاسنْ.   
\m
\v 14 أَذْ يِيذَارْ سِيذِي ڒْمُوعْصِييّثْ ن ڒجْذُوذْ نّسْ،  
\m عمَّارْصْ وَارْ إِمحِّي دّنْبْ ن يمَّاسْ.   
\m
\v 15 إِڒِي أَذْ بدّنْ ڒبْذَا قِيبَاتْشْ إِ سِيذِي،  
\m أجّْ إِ-ث أَذْ إِكّسْ ڒِيذَارثْ نْسنْ خْ ثمُّورْثْ. \x ◘ \xo 109:‏15 \xt أَيُوبْ 18‏:‏17؛ إِزهد. 34‏:‏17\x*   
\b  
\m
\v 16 مَاغَارْ نتَّا وَارْ إِعْقِيڒْ  
\m حِيمَا أَذْ يڭّْ س ثْمخْسِيوْثْ إِشوَّارنْ،  
\m \add مَاشَا\add* إِمَارّثْ ڒْمسْكِينْ ذ ؤُمزْڒُوضْ،  
\m ؤُڒَا ذ ونِّي ؤُمِي إِتّْوَارْژْ وُوڒْ،  
\m حِيمَا أَذْ ث إِنغْ.   
\m
\v 17 نتَّا ثُوغَا إِتّخْسْ نّعْڒثْ،  
\m \add خنِّي\add* أجّْ إِ-ت أَذْ خَاسْ ثوْضَا،  
\m ؤُ ؤُمِي وَارْ إِفَارْحْ س لْبَارَاكَا،  
\m أجّْ إِ-ت أَذْ خَاسْ ثِيڭّْوجْ.   
\m
\v 18 ؤُمِي يَارْضْ نّعْڒثْ أَمْ وَارُّوضْ نّسْ،  
\m أجّْ إِ-ت أَذْ ثَاذفْ \add خنِّي\add*  
\m أَمْ وَامَانْ غَارْ ذَاخڒْ نّسْ،  
\m أَمْ زّشْثْ ذڭْ إِغْسَانْ نّسْ.   
\m
\v 19 أجّْ أَذْ ثِيڒِي \add نّعْڒثْ نِّي\add*  
\m أَمْ وَارُّوضْ إِ ذِي إِتّْڒحّفْ،  
\m أَمْ وبْيَاسْ إِ إِبكّسْ ڒبْذَا.   
\m
\v 20 ثَا ذ ڒْمُونثْ ن سِيذِي إِ إِغْرِيمنْ إِنُو،  
\m إِ يِينِّي إِسَّاوَاڒنْ ڒْغَارْ خْ ڒعْمَارْ إِنُو.   
\b  
\m
\v 21 \add مَاشَا\add* شكْ، \add أَ\add* سِيذِي، سِيذِي إِنُو،  
\m أڭّْ ذَايِي \add أَمْ مَامّشْ ثخْسذْ\add*  
\m ذِي طّْوعْ ن يِيسمْ نّشْ،  
\m مَاغَارْ ثَامخْسِيوْثْ نّشْ إِشوَّارنْ  
\m ذ ثَاصبْحَانْثْ،  
\m فكّْ أَيِي.   
\m
\v 22 مَاغَارْ نشّْ ذِي ڒغْبنْ ؤُ زڒْضغْ،  
\m ؤُڒْ إِنُو إِتّْوَاسّْنُوقّبْ  
\m غَارْ ذَاخڒْ \add ذڭْ إِذْمَارنْ إِنُو\add*.   
\m
\v 23 أَمْ إِشْثْ ن ثِيڒِي إِزُّوڭَّارْثنْ قطِّيغْ،  
\m زّْرُوزَانْ أَيِي أَمْ يِيشْثْ ن ثْمُورْغِي.   
\m
\v 24 إِفَادّنْ إِنُو تَّارْجِيجِينْ س ؤُژُومِّي،  
\m أَرِّيمثْ إِنُو ذ ثَامُوسْرِيوْثْ،  
\m إِتّْخصَّا إِ-ت ثَاذُونْثْ.   
\m
\v 25 نشّْ ذوْڒغْ أَسنْ  
\m ذ \add إِشْثْ ن ڒْقشْعثْ ن\add* ؤُسحْقَارْ.  
\m مَاڒَا ژْرِينْ أَيِي،  
\m سّنْهزَّانْ أَزدْجِيفْ نْسنْ.   
\b  
\m
\v 26 أوْشْ أَيِي أَفُوسْ، \add أَ\add* سِيذِي، أَربِّي إِنُو،  
\m سنْجمْ أَيِي  
\m عْلَاحْصَابْ ثَامخْسِيوْثْ نّشْ إِشوَّارنْ،   
\m
\v 27 حِيمَا أَذْ سّْننْ  
\m أَقَا ذ مَانْ أَيَا ذ أَفُوسْ نّشْ،  
\m أَقَا شكْ إِ إِڭِّينْ مَانْ أَيَا، \add أَ\add* سِيذِي.   
\m
\v 28 نِيثْنِي ذ يِينِّي إِنعّْڒنْ،  
\m مَاشَا شكْ أَذْ ثْبَارْكذْ،  
\m مَاڒَا تّْغوّْغنْ،  
\m أَذْ ذوْڒنْ تّْسضْحَانْ  
\m \add مَاشَا\add* أَمْسخَّارْ نّشْ أَذْ إِفَارْحْ.   
\m
\v 29 أجّْ إِغْرِيمنْ إِنُو أَذْ يَارْضنْ س ڒفْضِيحثْ،  
\m أَذْ ڒحّْفنْ ذڭْ ؤُسضْحِي  
\m أَمْ ذڭْ إِجّْ ن ؤُسڒْهَامْ.   
\m
\v 30 زڭْ وُوڒْ إِنُو أَذْ قَاذِيغْ سِيذِي  
\m س ؤُقمُّومْ إِنُو،  
\m أَذْ ث سّمْغَارغْ جَارْ وَاطَّاسْ.   
\m
\v 31 مَاغَارْ نتَّا أَذْ إِبدّْ  
\m أَكْ-ذ ؤُمزْڒُوضْ غَارْ ؤُفُوسْ نّسْ أَفُوسِي،  
\m حِيمَا أَذْ \add ث\add* إِسّنْجمْ  
\m زڭْ إِنِّي إِحكّْمنْ خْ ڒعْمَارْ نّسْ.   
\b  
\b  
\m  
\c 110
\m
\v 1 \add أَزهّذْ ن ذَاوُوذْ.\add*  
\b  
\m سِيذِي إِسَّاوَاڒْ أَكْ-ذ سِيذِي إِنُو:  
\m قِيمْ غَارْ ؤُفُوسْ أَفُوسِي إِنُو،  
\m أَڒْ د-سَّارْسغْ ڒْعذْيَانْ نّشْ  
\m ذ ثَانبْذَاثْ سَاذُو إِضَارنْ نّشْ. \x ◘ \xo 110:‏1 \xt مت. 22‏:‏42‏-‏45؛ مك. 12‏:‏36؛ لك. 20‏:‏41‏-‏44؛ ڒخ. 2‏:‏34‏-‏36؛ عبر. 1‏:‏13، 6‏:‏20؛ 10‏:‏13؛ 1 كُور. 15‏:‏25‏-‏28؛ أَفا. 1‏:‏22\x*   
\b  
\m
\v 2 سِيذِي أَذْ إِسّكّْ أَزدْجَاضْ ن صُّولْطَا نّشْ  
\m زِي صِيهْيُونْ،  
\m شكْ أَذْ ثْصلّْطذْ ذِي ڒْوسْطْ ن ڒْعذْيَانْ نّشْ.   
\b  
\m
\v 3 ڒْڭنْسْ نّشْ أَذْ يِيڒِي ذ أَمْسعَّافْ  
\m ذڭْ وَاسّْ ن صُّولْطَا نّشْ،  
\m أَذْ د-يَاسْ ذِي ثِيسِّيقْثْ إِقدّْسنْ  
\m زِي ڒمْڒَاوْڒثْ ن ثُوفُّوثْ،  
\m \add أَمُّو إِ غَا يِيڒِي\add* إِ شكْ نّْذَا  
\m ن يِينِّي عَاذْ مَامّشْ  
\m ذ أَشْ د-إِتّْوَاخڒْقنْ.   
\b  
\m
\v 4 سِيذِي إِجِّيدْجْ،عمَّارْصْ أَذْ خَاسْ إِنْذمْ:  
\m ”شكْ ذ أَكهَّانْ إِ ڒبْذَا،  
\m عْلَاحْسَابْ صِّيفثْ ن مَالْكِيصَاذِيقْ!“،  
\m \add إِخْسْ أَذْ يِينِي ’أَجدْجِيذْ ذ أَمْسڭّذْ‘\add*. \x ◘ \xo 110:‏4 \xt عبر. 4‏:‏14‏-‏15؛ 5‏:‏6، 9‏-‏10؛ 6‏:‏20؛ 7‏:‏15‏-‏26؛ 8‏:‏1؛ 10‏:‏21\x*   
\b  
\m
\v 5 سِيذِي أَقَا-ث غَارْ ؤُفُوسْ أَفُوسِي نّشْ.  
\m نتَّا أَذْ إِڒْبزْ إِجدْجِيذنْ  
\m ذڭْ وَاسّْ ن وغْضَابْ نّسْ.   
\m
\v 6 نتَّا أَذْ إِحَاكمْ خْ ڒڭْنُوسْ،  
\m أَقَا ذَا \add ثَامُّورْثْ\add* ثشُّورْ س ڒْخشْبَاثْ،  
\m أَذْ إِڒْبزْ أَزدْجِيفْ  
\m خْ إِشْثْ ن ثمُّورْثْ ثَامقّْرَانْثْ. \x ◘ \xo 110:‏6 \xt أَسَا. 14‏:‏14‏-‏20؛ 16‏:‏14‏-‏16؛ 20‏:‏8‏-‏10\x*   
\m
\v 7 أَكْ-ذ وبْرِيذْ أَذْ إِسُو زِي ثغْزَارْثْ،  
\m خْ ؤُيَا أَذْ إِسّْڭعّذْ أَزدْجِيفْ نّسْ.   
\b  
\b  
\m  
\c 111
\m
\v 1 هَالِّيلُو-يَاهْ!  
\b  
\m \bd أَلِيفْ.\bd* أَذْ قَاذغْ سِيذِي  
\m س مَارَّا ؤُڒْ إِنُو،  
\m \bd بِيثْ.\bd* ذِي ڒَامَانْ ن وڭْرَاوْ  
\m ن يِينِّي إِڭُّورنْ نِيشَانْ، \add ذِي\add* ثْمسْمُونْثْ.   
\m
\v 2 \bd ڭِيملْ.\bd* ڒفْعَايڒْ ن سِيذِي ذ إِمقّْرَاننْ،  
\m \bd ذَالِيثْ.\bd* أَقَا ثْوَارزُّونْ  
\m زِي مَارَّا إِنِّي زَّايْسنْ إِفَارّْحنْ.   
\m
\v 3 \bd هِي.\bd* نتَّا إِڭَّا س لْعَاضَامَا ذ ڒْعزّْ،  
\m \bd وَاوْ.\bd* ثَاسڭْذَا نّسْ ثتّْغِيمَا إِ ڒبْذَا.   
\m
\v 4 \bd زَايِينْ.\bd* نتَّا إِڭَّا إِجّْ ن \add ڒْْعِيذْ\add*  
\m \add إِ\add* ڒِيذَارثْ ن لْمُوعْجِيزَاثْ نّسْ.  
\m \bd خِيثْ.\bd* سِيذِي ذ أَحْنِينْ ذ أَرْحِيمْ.   
\m
\v 5 \bd ثِيث.\bd* نتَّا إِوْشَا مَاشَّا  
\m إِ يِينِّي ث إِتّڭّْوذنْ،  
\m \bd يُوذْ.\bd* إِتِّيذَارْ ڒْعَاهْذْ نّسْ إِ ڒبْذَا.   
\m
\v 6 \bd كَافْ.\bd* نتَّا إِسّْشنْ إِ ڒْڭنْسْ نّسْ  
\m ثِيمڭَّا نّسْ إِجهْذنْ،  
\m \bd لَامِيذْ.\bd* حِيمَا أَذْ أَسنْ إِوْشْ  
\m ثَاسْغَارْثْ ن ڒڭْنُوسْ.   
\m
\v 7 \bd مِيمْ.\bd* ڒفْعَايڒْ ن إِفَاسّنْ نّسْ  
\m ذ ثِيذتّْ ذ ڒْحقّْ،  
\m \bd نُونْ.\bd* مَارَّا ثِيوصَّا نّسْ  
\m ذَايْسنْثْ ڒَامَانْ،   
\m
\v 8 \bd سَامِيخْ.\bd* أَقَا أَثنْ بدّنْ إِ ڒبْذَا،  
\m \bd عَايِينْ.\bd* تّْوَاڭّنْ ذِي ثِيذتّْ ؤُ س ڒصْفَايثْ.   
\m
\v 9 \bd بِي.\bd* نتَّا إِسّوْجذْ تَّامَانْ ن وصْڒَاحْ  
\m إِ ڒْڭنْسْ نّسْ،  
\m \bd ثْسَاذِي.\bd* إِڭَّا ڒْعَاهْذْ نّسْ إِ ڒبْذَا.  
\m \bd قُوفْ.\bd* إِسمْ نّسْ  
\m ذ أَمْقدَّاسْ ذ إِسّڭّْوَاذنْ.   
\m
\v 10 \bd رِيخْ.\bd* ثِيڭّْوُوذِي ن سِيذِي ذ بدُّو ن ثِيغِيثْ.  
\m \bd شِينْ.\bd* مَارَّا إِنِّي إِتّڭّنْ أَمنِّي،  
\m أَقَا غَارْسنْ ڒعْقڒْ ذ لمْلِيحْ.  
\m \bd ثَافْ.\bd* شَّانْ نّسْ إِتّْغِيمَا إِ ڒبْذَا.   
\b  
\b  
\m  
\c 112
\m
\v 1 هَالِّيلُو-يَاهْ!  
\b  
\m \bd أَلِيفْ.\bd* سّعْذْ ن ورْيَازْ  
\m نِّي إِتّڭّْوذنْ سِيذِي،  
\m \bd بِيثْ.\bd* ونِّي إِفَارّْحنْ أَطَّاسْ  
\m خْ ثْوصَّا نّسْ. \x ◘ \xo 112:‏1 \xt إِزهد. 1‏:‏1، 2\x*   
\m
\v 2 \bd ڭِيملْ.\bd* ثَارْوَا نّسْ  
\m أَذْ إِڒِينْ جهّْذنْ ذِي ثمُّورْثْ،  
\m \bd ذَالِيثْ.\bd* جِّيڒْ ن يِينِّي إِڭُّورنْ نِيشَانْ  
\m أَذْ إِتّْوَابَاركْ.   
\m
\v 3 \bd هِي.\bd* ڒْخِيرْ ذ وَاڭْڒَا  
\m أَذْ شُّورنْ ثَادَّارْثْ نّسْ،  
\m \bd وَاوْ.\bd* ثَاسڭْذَا نّسْ ثتّْغِيمَا إِ ڒبْذَا.   
\m
\v 4 \bd زَايِينْ.\bd* إِ يِينِّي إِڭُّورنْ نِيشَانْ  
\m \add أَذْ أَسنْ\add* ثغْڒِي ثْفَاوْثْ ذِي ثَادْجسْثْ.  
\m \bd خِيثْ.\bd* \add نتَّا\add* ذ أَحْنِينْ ذ أَرْحِيمْ ذ ؤُمْسڭّذْ.   
\m
\v 5 \bd ثِيث.\bd* أَرْيَازْ نِّي إِتّْحِينَّا ؤُ يَارطّڒْ،  
\m \add أَذْ يِيڒِي\add* مْلِيحْ،  
\m \bd يُوذْ.\bd* أَقَا إِعدّڒْ ثِيمسْڒَايِينْ نّسْ نِيشَانْ.   
\m
\v 6 \bd كَافْ.\bd* مَاغَارْ نتَّا وَارْ إِتّْغِيمِي  
\m إِتّنْهزَّا إِ ڒبْذَا.  
\m \bd لَامِيذْ.\bd* أَذْ \add ذِينْ\add* ثِيڒِي ڒِيذَارثْ  
\m ذڭْ ؤُمْسڭّذْ إِ ڒبْذَا.   
\m
\v 7 \bd مِيمْ.\bd* نتَّا وَارْ إِتّڭّْوذْ  
\m زِي نَّابْ إِ وَارْ إِحْڒِينْ،  
\m \bd نُونْ.\bd* ؤُڒْ نّسْ إِمْثنْ، إِتّْشَاڒْ خْ سِيذِي.   
\m
\v 8 \bd سَامِيخْ.\bd* ؤُڒْ نّسْ إِمْثنْ، وَارْ إِتّڭّْوذْ،  
\m \bd عَايِينْ.\bd* أَڒْ غَا إِخْزَارْ  
\m غَارْ يِينِّي ث-إِ-د إِحصَّارنْ.   
\m
\v 9 \bd بِي.\bd* إِزُوزَّارْ، إِتِّيشْ إِ إِمزْڒَاضْ.  
\m \bd ثْسَاذِي.\bd* ثَاسڭْذَا نّسْ  
\m ثتّْغِيمَا إِ ڒبْذَا،  
\m \bd قُوفْ.\bd* إِشّْ نّسْ أَذْ إِتّْوَاسُّوعْڒَا س شَّانْ.   
\m
\v 10 \bd رِيخْ.\bd* أَذْ ث إِژَارْ ؤُعفَّانْ، أَذْ إِفُّوڭمْ.  
\m \bd شِينْ.\bd* نتَّا أَذْ إِغزّْ س ثغْمَاسْ،  
\m \add خنِّي\add* أَذْ إِفْسِي.  
\m \bd ثَافْ.\bd* مژْرِي ن إِعفَّاننْ أَذْ إِبْضڒْ.   
\b  
\b  
\m  
\c 113
\m
\v 1 هَالِّيلُو-يَاهْ، سْعُودْجمْ،  
\m \add كنِّيوْ\add* إِمْسخَّارنْ ن سِيذِي،  
\m سْعُودْجمْ إِسمْ ن سِيذِي!   
\m
\v 2 أَذْ إِتّْوَابَاركْ إِسمْ ن سِيذِي،  
\m زِي ڒخُّو أَڒْ ڒبْذَا. \x ◘ \xo 113:‏2 \xt دَان. 2‏:‏20\x*   
\m
\v 3 زِي مَانِيسْ د-ثْنقَّارْ ثْفُوشْثْ  
\m أَڒْ مَانِيسْ ثْغدْجِي ثْفُوشْثْ،  
\m أَذْ إِتّْوَاسّْعُودْجْ إِسمْ ن سِيذِي.\x ◘ \xo 113:‏3 \xt مـَال. 1‏:‏11\x*   
\b  
\m
\v 4 سِيذِي يُوعْڒَا خْ مَارَّا ڒڭْنُوسْ،  
\m ثِيوَا إِ إِجنْوَانْ ذ أَعُودْجِي نّسْ.   
\m
\v 5 مَانْ ونْ إِدْجَانْ  
\m أَمْ سِيذِي، أَربِّي نّغْ،  
\m ونِّي إِزدّْغنْ ذِي ڒُوعْڒَا قَاعْ،   
\m
\v 6 ونِّي يُوضَارنْ  
\m مَاحنْذْ أَذْ إِژَارْ ذڭْ إِجنْوَانْ  
\m ؤُ خْ ثمُّورْثْ!   
\b  
\m
\v 7 ونِّي د-إِسّْنكَّارَانْ  
\m أَمُوقْڒِيڒْ زِي ثْعجَّاجْثْ،  
\m إِسّْڭعّذْ أَمزْڒُوضْ زڭْ وفْرَاضْ \x ◘ \xo 113:‏7 \xt 1 صم. 2‏:‏8؛ إِزهد. 107‏:‏41\x*   
\m
\v 8 مَاحنْذْ أَذْ \add ث\add* إِسّْغِيمْ أَكْ-ذ ثَارْوَا ن ثَاصِيڒثْ،  
\m أَكْ-ذ ثَارْوَا ن ثَاصِيڒثْ نْ ڒْڭنْسْ نّسْ.   
\m
\v 9 ونِّي إِسّزْذَاغنْ  
\m ثنِّي وَارْ إِتِّيرْونْ ذِي ثَادَّارْثْ،  
\m \add أَمْ\add* إِشْثْ ن يمَّاثْسنْ ن إِحنْجِيرنْ ثْفَارْحْ.  
\m هَالِّيلُو-يَاه.   
\b  
\b  
\m  
\c 114
\m
\v 1 أَڒَامِي إِفّغْ إِسْرَائِيل زِي مِيصْرَا،  
\m ثَادَّارْثْ ن يَاعْقُوبْ  
\m زڭْ إِجّْ ن ڒْڭنْسْ  
\m س يِيڒسْ ن مِيدّنْ، \f ◼ \fr 114:‏1 \ft \+bd ’إِڒسْ‘\+bd* - نِيغْ ’ثُوثْلَايْثْ‘.\f*  \x ◘ \xo 114:‏1 \xt ؤُف. 13‏:‏3\x*   
\m
\v 2 إِذْوڒْ يَاهُوذَا ذ زَّاوشْثْ نّسْ إِقدّْسنْ،  
\m إِسْرَائِيل ذ \add ثَامُّورْثْ ن\add* ڒحْكَامثْ نّسْ.   
\b  
\m
\v 3 ڒبْحَارْ إِژْرَا إِ-ث ؤُشَا يَارْوڒْ،  
\m لْ-ؤُرْذُونْ إِنّقْڒبْ غَارْ ضفَّارْ.   
\m
\v 4 إِذُورَارْ نڭْزنْ أَمْ يِيشَارِّييّنْ،  
\m ثِيوْرِيرِينْ أَمْ يِيزْمَارنْ.   
\b  
\m
\v 5 مِينْ شكْ يُوغِينْ، \add أَ\add* ڒبْحَارْ،  
\m أَڒَامِي ثْركّْوَاڒذْ،  
\m \add أَ شكْ\add* لْ-ؤُرْذُونْ، أَڒَامِي ثنْقڒْبذْ غَارْ ضفَّارْ؟ \f ◼ \fr 114:‏5 \ft \+bd ’ڒبْحَارْ‘\+bd* - نِيغْ ’إِلْ‘.\f*   
\m
\v 6 \add أَ\add* إِذُورَارْ، \add مِينْ كنِّيوْ يُوغِينْ\add*  
\m أَڒَامِي ثْنڭّْزمْ أَمْ يِيشَارِّييّنْ،  
\m ثِيوْرِيرِينْ أَمْ يِيزْمَارنْ؟   
\b  
\m
\v 7 \add أَ\add* ثَامُّورْثْ أَرْجِيجِي زَّاثْ إِ وُوذمْ ن سِيذِي،  
\m زَّاثْ إِ وُوذمْ ن أَربِّي ن يَاعْقُوبْ،   
\m
\v 8 ونِّي يَارِّينْ ثَاصْضَارْثْ  
\m ذ ڒْحمْڒثْ ن وَامَانْ،  
\m سّدْجَاحْ ذ ڒْعُونْصَارَاثْ ن وَامَانْ. \x ◘ \xo 114:‏8 \xt ؤُف. 17‏:‏6؛ ڒخْڒ. 20‏:‏11\x*   
\b  
\b  
\m  
\c 115
\m
\v 1 وَارْ إِدْجِي إِ نشِّينْ، \add أَ\add* سِيذِي،  
\m وَارْ إِدْجِي إِ نشِّينْ،  
\m مَاغَارْ إِ يِيسمْ نّشْ أَذْ يِيڒِي ؤُعُودْجِي،  
\m ذِي سِّيبّثْ ن ثْمخْسِيوْثْ نّشْ إِشوَّارنْ  
\m ذ ڒَامَانْ نّشْ.   
\m
\v 2 مَايمِّي غَا قَّارنْ ڒڭْنُوسْ:  
\m ’مَانِي إِدْجَا خنِّي أَربِّي نْسنْ؟‘   
\b  
\m
\v 3 أَربِّي نّغْ أَقَا-ث ذڭْ ؤُجنَّا،  
\m إِڭَّا مَارَّا مِينْ ذ أَسْ يَارْضَانْ.   
\m
\v 4 ڒخْيَاڒَاثْ نْسنْ ن لْ-أَصْنَامْ  
\m أَقَا أَثنْثْ س نُّوقَارْثْ ذ وُورغْ،  
\m ڒْْخذْمثْ ن إِفَاسّنْ ن إِوْذَانْ. \f ◼ \fr 115:‏4 \ft \+bd ’إِفَاسّنْ ن إِوْذَانْ‘\+bd* - س ثْعِيبْرَانِيثْ ’إِفَاسّنْ ن أَذَامْ‘.\f*   
\m
\v 5 غَارْسنْ أَقمُّومْ،  
\m \add مَاشَا\add* وَارْ سِّيوِيڒنْثْ،  
\m غَارْسنْثْ ثِيطَّاوِينْ،  
\m \add مَاشَا\add* وَارْ تّْوِيڒِينْثْ، \x ◘ \xo 115:‏5 \xt أَعَوذ. 4‏:‏28؛ إِرْم. 10‏:‏3، 4، 5، 9‏-‏16\x*   
\m
\v 6 غَارْسنْثْ إِمزُّوغنْ،  
\m \add مَاشَا\add* وَارْ تّسْڒِينْثْ،  
\m غَارْسنْثْ وَانْزَارنْ،  
\m \add مَاشَا\add* وَارْ تّْشمِّينْثْ.   
\m
\v 7 إِفَاسّنْ نْسنْ  
\m وَارْ زمَّارنْ أَذْ شبَّارنْ،  
\m إِضَارنْ نْسنْ  
\m وَارْ زمَّارنْ أَذْ ؤُيُورنْ.  
\m نِيثْنِي وَارْ سُّوفُّوغنْ ڒْحسّْ زِي ثْمِيجَّا نْسنْ.   
\m
\v 8 أجّْ إِنِّي ثنْثْ إِڭِّينْ  
\m أَذْ ذَايْسنْثْ أَروْسنْ،  
\m كُوڒْ  إِجّْ زڭْ إِنِّي خَاسنْثْ إِتّشْڒنْ.   
\b  
\m
\v 9 إِسْرَائِيل، ثْشڒْ خْ سِيذِي.  
\m نتَّا ذ ثْوِيزَا نْسنْ  
\m ذ ثَاسدَّارْثْ نْسنْ إِ ؤُسڒْقِي.   
\m
\v 10 ثَادَّارْثْ ن هَارُونْ، ثْشڒْ خْ سِيذِي.  
\m نتَّا ذ ثْوِيزَا نْسنْ  
\m ذ ثَاسدَّارْثْ نْسنْ إِ ؤُسڒْقِي.   
\m
\v 11 \add مَارَّا كنِّيوْ\add* إِنِّي إِتّڭّْوذنْ سِيذِي،  
\m ثشْڒمْ خْ سِيذِي.  
\m نتَّا ذ ثْوِيزَا نْسنْ  
\m ذ ثَاسدَّارْثْ نْسنْ إِ ؤُسڒْقِي.   
\m
\v 12 سِيذِي إِعْقڒْ خَانغْ، نتَّا أَذْ إِبَاركْ.  
\m أَذْ إِبَاركْ ثَادَّارْثْ ن إِسْرَائِيل،  
\m أَذْ إِبَاركْ ثَادَّارْثْ ن هَارُونْ.   
\m
\v 13 نتَّا أَذْ إِبَاركْ  
\m إِنِّي إِتّڭّْوذنْ زِي سِيذِي،  
\m إِمژْيَاننْ \add جْمِيعْ\add* أَكْ-ذ إِمقّْرَاننْ.   
\m
\v 14 سِيذِي أَذْ أَومْ إِسّْمَارْنِي \add ثَارْوَا\add*،  
\m إِ كنِّيوْ ؤُڒَا إِ إِحنْجِيرنْ نْومْ.   
\b  
\m
\v 15 كنِّيوْ ثتّْوَابَارْكمْ زِي سِيذِي،  
\m ونِّي إِڭِّينْ إِجنْوَانْ ذ ثمُّورْثْ.   
\m
\v 16 إِجنْوَانْ، \add وَاهْ،\add* إِجنْوَانْ ن سِيذِي،  
\m \add مَاشَا\add* ثَامُّورْثْ إِوْشَا إِ-ت  
\m إِ ثَارْوَا ن بْنَاذمْ.   
\m
\v 17 إِمتَّانْ وَارْ زمَّارنْ  
\m أَذْ سّمْغَارنْ سِيذِي،  
\m ؤُڒَا ذ إِنِّي د-إِهْوَانْ ذڭْ ؤُسُوسمْ.   
\m
\v 18 نشِّينْ أَذْ نْبَاركْ سِيذِي،  
\m زِي ڒخُّو أَڒْ إِ ڒبْذَا. هَالِّيلُو-يَاهْ!   
\b  
\b  
\m  
\c 116
\m
\v 1 نشّْ تّخْسغْ،  
\m مَاغَارْ سِيذِي إِسْڒَا  
\m إِ ثْمِيجَّا إِنُو، إِ ثُوثْرَا إِنُو،   
\m
\v 2 مَاغَارْ نتَّا إِوْشَا أَيِي أَمژُّوغْ نّسْ.  
\m أَذْ أَسْ ڒَاغِيغْ مَارَّا ؤُسَّانْ \add ن ثُوذَارْثْ إِنُو\add*.   
\m
\v 3 إِسغْوَانْ ن ڒْموْثْ نّْضنْ أَيِي-د،  
\m ثوْضَا-د خَافِي ثِيڭّْوُوذَا ن ڒَاخَارْثْ.  
\m نشّْ ؤُفِيغْ أَقَا أَيِي تّْوَاحْصَارغْ ؤُ شضْنغْ. \x ◘ \xo 116:‏3 \xt 2 صم. 22‏:‏5، 6\x*   
\m
\v 4 ڒَاغِيغْ خْ يِيسمْ ن سِيذِي، نِّيغْ:  
\m ”\add أَ\add* سِيذِي، فكّْ ڒعْمَارْ إِنُو!“   
\b  
\m
\v 5 سِيذِي ذ أَحْنِينْ ذ أَمْسڭّذْ،  
\m أَربِّي نّغْ ذَايسْ ڒحْنُونشْثْ.   
\m
\v 6 سِيذِي إِحطَّا ؤُڒَاونْ ن إِحَافِييّنْ.  
\m نشّْ ثُوغَا أَيِي \add أَمْ\add* ؤُنعْضَابْ،  
\m \add مَاشَا\add* نتَّا إِسّنْجمْ أَيِي.   
\m
\v 7 هْنَا عَاوذْ، \add أَ\add* ڒعْمَارْ إِنُو،  
\m مَاغَارْ سِيذِي إِڭَّا أَشْ مِينْ إِصبْحنْ. \x ◘ \xo 116:‏7 \xt إِزهد. 13‏:‏6\x*   
\m
\v 8 مَاغَارْ شكْ ثحْضِيذْ ڒعْمَارْ إِنُو  
\m زِي ڒْموْثْ،  
\m ثِيطَّاوِينْ إِنُو زڭْ إِمطَّاونْ،  
\m أَضَارْ إِنُو زڭْ ؤُنقْرَاضْ.   
\m
\v 9 أَذْ ؤُيُورغْ زَّاثْ إِ وُوذمْ ن سِيذِي،  
\m ذِي ثمُّورَا ن يِينِّي إِدَّارنْ.   
\b  
\m
\v 10 نشّْ ؤُمْنغْ، س ؤُينِّي نِّيغْ:  
\m ”نشّْ تّْوَاحْصَارغْ أَطَّاسْ!“ \x ◘ \xo 116:‏10 \xt 2 كُور. 4‏:‏13\x*   
\m
\v 11 ذِي ثِيڭّْوُوذِي إِنُو نِّيغْ:  
\m ”مَارَّا إِوْذَانْ ذ أَيْثْ ن بُو-إِخَارِّيقنْ!“ \x ◘ \xo 116:‏11 \xt رُوم. 3‏:‏4\x*   
\m
\v 12 مَامّشْ إِ غَا خدْجْصغْ سِيذِي  
\m خْ مَارَّا ڒْخَارْ إِ ذ أَيِي إِڭَّا؟   
\m
\v 13 أَذْ سّْڭعّْذغْ  
\m ڒْْكَاسْ ن ؤُسنْجمْ أَمقّْرَانْ،  
\m أَذْ ڒَاغِيغْ خْ يِيسمْ ن سِيذِي.   
\m
\v 14 نشّْ أَذْ كمّْڒغْ  
\m لْوُوعُوذْ إِنُو إِ سِيذِي،  
\m قِيبَاتْشْ إِ مَارَّا ڒْڭنْسْ نّسْ.   
\b  
\m
\v 15 أَقَا إِغْڒَا ذِي ثِيطَّاوِينْ ن سِيذِي  
\m ڒْْموْثْ ن إِمْثِيقَّانْ نّسْ.   
\m
\v 16 أَ سِيذِي، أَقَا نشّْ ذ أَمْسخَّارْ نّشْ،  
\m نّشْ ذ أَمْسخَّارْ نّشْ،  
\m مِّيسْ ن ثَايَّا نّشْ.  
\m شكْ ثسَّارْخُوذْ خَافِي إِشذِّيينْ إِنُو.   
\m
\v 17 نشّْ أَذْ شكْ د-أَوْيغْ  
\m ثَاوْهِيبْثْ ن ؤُقَاذِي،  
\m أَذْ ڒَاغِيغْ خْ يِيسمْ ن سِيذِي.   
\m
\v 18 نشّْ أَذْ سّْقفْڒغْ لْوُوعُوذْ إِنُو إِ سِيذِي،  
\m قِيبَاتْشْ إِ مَارَّا ڒْڭنْسْ نّسْ.   
\m
\v 19 ذِي ڒمْرَاحَاثْ ن ثَادَّارْثْ ن سِيذِي،  
\m ذِي ڒْوسْطْ نّمْ، \add أَ\add* ؤُرْشَالِيمْ!  
\m هَالِّيلُو-يَاه.   
\b  
\b  
\m  
\c 117
\m
\v 1 سْعُودْجمْ سِيذِي، مَارَّا ڒڭْنُوسْ،  
\m صبْحمْ ث، مَارَّا شُّوعُوبْ! \x ◘ \xo 117:‏1 \xt رُوم. 15‏:‏11\x*   
\m
\v 2 مَاغَارْ ثَامخْسِيوْثْ نّسْ إِشوَّارنْ  
\m ذ ثَامقّْرَانْثْ ثِيوَا نّغْ،  
\m ڒَْامَانْ ن سِيذِي إِتّْغِيمَا إِ ڒبْذَا،  
\m هَالِّيلُو-يَاهْ!   
\b  
\b  
\m  
\c 118
\m
\v 1 \add غَارْ بدُّو ...\add*  
\m قَاذَامْ سِيذِي،  
\m مَاغَارْ نتَّا ذ أَصبْحَانْ،  
\m مَاغَارْ ثَامخْسِيوْثْ نّسْ إِشوَّارنْ  
\m ثتّْغِيمَا إِ ڒبْذَا.   
\m
\v 2 أجّْ إِسْرَائِيل أَذْ يِينِي:  
\m ”ثَامخْسِيوْثْ نّسْ إِشوَّارنْ  
\m ثتّْغِيمَا إِ ڒبْذَا.“   
\m
\v 3 أجّْ ثَادَّارْثْ ن هَارُونْ أَذْ ثِينِي  
\m ”ثَامخْسِيوْثْ نّسْ إِشوَّارنْ  
\m ثتّْغِيمَا إِ ڒبْذَا.“   
\m
\v 4 أجّْ إِنِّي إِتّڭّْوذنْ سِيذِي أَذْ إِنِينْ:  
\m ”ثَامخْسِيوْثْ نّسْ إِشوَّارنْ  
\m ثتّْغِيمَا إِ ڒبْذَا.“   
\b  
\m
\v 5 \add ذڭْ وبْرِيذْ ...\add*  
\m ذِي ڒحْصَارثْ ڒَاغِيغْ غَارْ سِيذِي.  
\m سِيذِي يَارَّا-د خَافِي، \add إِوْشَا أَيِي\add* تَّاسِيعْ.   
\m
\v 6 سِيذِي أَقَا-ث أَكِيذِي، وَارْ تّڭّْوذغْ شَا،  
\m \add مَاغَارْ\add* مِينْ إِزمَّارْ بْنَاذمْ  
\m أَذْ أَيِي إِڭّْ؟ \x ◘ \xo 118:‏6 \xt رُوم. 8‏:‏31؛ عبر. 13‏:‏6\x*   
\m
\v 7 سِيذِي أَقَا-ث أَكِيذِي  
\m جَارْ يِينِّي ذ أَيِي إِوْشِينْ أَفُوسْ.  
\m نشّْ أَذْ خزَّارغْ \add غَارْ سْوَادَّايْ\add*  
\m خْ يِينِّي ذ أَيِي إِشَارّْهنْ.   
\m
\v 8 إِحْڒَا أَذْ أَروْڒغْ غَارْ سِيذِي  
\m خْ ؤُثشْڒِي خْ بْنَاذمْ. \x ◘ \xo 118:‏8 \xt إِزهد. 62‏:‏9، 10؛ 146‏:‏3؛ إِرْم. 17‏:‏5، 7\x*   
\m
\v 9 إِحْڒَا أَذْ أَروْڒغْ غَارْ سِيذِي  
\m خْ ؤُثشْڒِي خْ ثَارْوَا ن ثَاصِيڒثْ.   
\m
\v 10 مَارَّا ڒڭْنُوسْ نّْضنْ أَيِي-د،  
\m نشّْغضْڒغْ ثنْ س يِيسمْ ن سِيذِي.   
\m
\v 11 نّْضنْ أَيِي-د، \add وَاهْ،\add* قُووَّارنْ أَيِي.  
\m نشّْغضْڒغْ ثنْ س يِيسمْ ن سِيذِي.   
\m
\v 12 نِيثْنِي نّْضنْ أَيِي أَمْ ثْزِيزْوَا،  
\m أَقَا أَمْ ثْمسِّي ن إِسنَّاننْ خسْينْ.  
\m نشّْغضْڒغْ ثنْ س يِيسمْ ن سِيذِي.   
\m
\v 13 شكْ ثْعَارْنذْ أَيِي س ڒقْسَاحثْ  
\m أَڒَامِي عْڒَاحَاڒْ وْضِيغْ،  
\m مَاشَا سِيذِي إِوْشَا أَيِي أَفُوسْ.   
\m
\v 14 سِيذِي ذ جّهْذْ إِنُو ذ أَزهّذْ \add إِنُو\add*،  
\m نتَّا إِذْوڒْ أَيِي ذ أَسنْجمْ.   
\m
\v 15 ذڭْ إِقِيضَانْ ن إِمْسڭَّاذنْ \add إِتّْوَاسڒْ\add*  
\m ڒْْحسّْ ن ؤُسْڒِيوْڒوْ ذ ؤُسنْجمْ.  
\m أَفُوسْ أَفُوسِي ن سِيذِي إِڭَّا س جّهْذْ.   
\m
\v 16 أَفُوسْ أَفُوسِي ن سِيذِي إِتّْوَاسّْڭعّذْ،  
\m أَفُوسْ أَفُوسِي ن سِيذِي إِڭَّا س ومْحَاضْ. \x ◘ \xo 118:‏16 \xt لك. 1‏:‏51\x*   
\m
\v 17 نشّْ وَارْ تّْمتِّيغْ شَا، أَذْ دَّارغْ،  
\m أَذْ بَارّْحغْ ثِيمڭَّا ن سِيذِي.   
\m
\v 18 سِيذِي إِوبّخْ أَيِي أَطَّاسْ،  
\m \add مَاشَا\add* وَارْ ذ أَيِي إِوْشِي إِ ڒْموْثْ.   
\b  
\m
\v 19 \add غَارْ وَاذَافْ ...\add*  
\m أَرْزْممْ أَيِي ثِيوُّورَا ن ثْسڭْذَا،  
\m أَذْ زَّايْسنْثْ أَذْفغْ، أَذْ قَاذِيغْ سِيذِي. \x ◘ \xo 118:‏19 \xt إِشا. 26‏:‏2\x*   
\b  
\m
\v 20 \add إِنِّي يَارحّْبنْ زڭْ يِينِّي إِتَّاذْفنْ قَّارنْ ...\add*  
\m ثَا ذ ثَاوَّارْثْ ن سِيذِي،  
\m إِمْسڭَّاذنْ أَذْ زَّايسْ أَذْفنْ.   
\m
\v 21 نشّْ أَذْ أَشْ قَاذِيغْ ؤُمِي ذ أَيِي ثسْڒِيذْ،  
\m ثْذوْڒذْ أَيِي ذ أَسنْجمْ.   
\m
\v 22 أَژْرُو إِ وَارْ خْسنْ إِبنَّاينْ،  
\m إِذْوڒْ ذ إِخفْ ن ثغْمَارْثْ. \x ◘ \xo 118:‏22 \xt إِشا. 8‏:‏14؛ 28‏:‏16؛ مت. 21‏:‏42؛ مك. 12‏:‏10؛ لك. 20‏:‏17؛ ڒخ. 4‏:‏11؛ رُوم. 9‏:‏33؛ أَفا. 2‏:‏20؛ 1 بُط. 2‏:‏4، 7\x*   
\m
\v 23 وَا يُوسَا-د زِي سِيذِي  
\m ؤُ مَانْ أَيَا ذ ڒعْجبْ ذِي ثِيطَّاوِينْ نّغْ.   
\m
\v 24 وَا ذ أَسّْ إِ إِڭَّا سِيذِي،  
\m أجّْ أَنغْ أَذْ نَارْشقْ ؤُ أَذْ ذَايسْ نْفَارْحْ.   
\m
\v 25 أَ سِيذِي، أَوِي-د أَسنْجمْ،  
\m أَ سِيذِي، أَوِي-د أَفْڒَاحْ.   
\m
\v 26 لْبَارَاكَا إِ ونِّي د غَا يَاسنْ  
\m س يِيسمْ ن سِيذِي!  
\m نشِّينْ أَذْ كنِّيوْ نْبَاركْ  
\m زِي ثَادَّارْثْ ن سِيذِي. \x ◘ \xo 118:‏26 \xt مت. 21‏:‏9؛ مت. 23‏:‏39؛ مك. 11‏:‏9، 10؛ لك. 19‏:‏38؛ يُوح. 12‏:‏13\x*   
\m
\v 27 أَربِّي ذ سِيذِي نِّي ذ أَنغْ إِڭِّينْ ثَافَاوْثْ.  
\m قْنمْ \add ثَاغَارْصْثْ ن\add* ڒْعِيذْ س إِسغْوَانْ  
\m غَارْ وَاشَّاونْ ن ؤُعَالْطَارْ،  
\m \add ڒْمذْبحْ ن وشْمَاضْ\add*.   
\b  
\m
\v 28 \add إِنِّي إِتَّاذْفنْ قَّارنْ ...\add*  
\m شكْ ذ أَربِّي إِنُو، س ؤُيَا أَذْ شكْ قَاذِيغْ،  
\m \add أَ\add* أَربِّي إِنُو، أَذْ شكْ سّْعُودْجغْ.   
\b  
\m
\v 29 \add مَارَّا جْمِيعْ ...\add*  
\m قَاذَامْ سِيذِي، مَاغَارْ نتَّا إِصْبحْ،  
\m مَاغَارْ ثَامخْسِيوْثْ نّسْ إِشوَّارنْ  
\m ثتّْغِيمَا إِ ڒبْذَا.   
\b  
\b  
\m  
\c 119
\m
\v 1 \bd أَلِيفْ.\bd* سّعْذْ نْسنْ إِ يِينِّي إِكمّْڒنْ  
\m أَبْرِيذْ \add ن ثُوذَارْثْ\add* نْسنْ بْڒَا ڒْعِيبْ،  
\m إِنِّي إِڭُّورنْ خْ وبْرِيذْ ن شَّارِيعَا ن سِيذِي. \x ◘ \xo 119:‏1 \xt إِزهد. 1‏:‏1\x*   
\m
\v 2 سّعْذْ نْسنْ إِ يِينِّي إِحطَّانْ  
\m شّْهَاذَاثْ نّسْ،  
\m إِنِّي خَاسْ يَارزُّونْ س مَارَّا ؤُڒْ نْسنْ.   
\m
\v 3 نِيثْنِي وَارْ تّڭّنْ ڒْغشّْ،  
\m مَاشَا ڭُّورنْ ذڭْ إِبْرِيذنْ نّسْ.   
\m
\v 4 \add أَ\add* سِيذِي، شكْ ثُومَارذْ  
\m مَاحنْذْ بْنَاذمْ  
\m أَذْ إِحْضَا ثِيوصَّا نّشْ نِيشَانْ.   
\m
\v 5 مْڒِي قَاعْ إِبْرِيذنْ إِنُو تّْوَاسڭّْذنْ،  
\m مَاحنْذْ أَذْ حْضِيغْ ثِيوصَّا نّشْ،   
\m
\v 6 \add خنِّي\add*عمَّارْصْ أَذْ سضْحِيغْ  
\m مَاڒَا خزَّارغْ غَارْ مَارَّا ثِيوصَّا نّشْ.   
\m
\v 7 س وُوڒْ إِقُّورْ أَذْ شكْ قَاذِيغْ،  
\m مَاڒَا نشّْ ڒمْذغْ  
\m ڒحْكَامَاثْ نّشْ إِسڭّْذنْ.   
\m
\v 8 أَذْ حْضِيغْ ثِيوصَّا نّشْ!  
\m وَارْ ذَايِي سمّحْ \add مَارَّا\add*!   
\b  
\m
\v 9 \bd بِيثْ.\bd* مَامّشْ إِ غَا إِسِّيزْذڭْ  
\m إِجّْ ن ؤُحُوذْرِي أَبْرِيذْ نّسْ؟  
\m س ومْنَاعْ نّسْ ذڭْ وَاوَاڒْ نّشْ.   
\m
\v 10 نشّْ أَرزُّوغْ خَاكْ س وُوڒْ إِنُو مَارَّا،  
\m وَارْ ذ أَيِي تّجِّي  
\m أَذْ فّْغغْ خْ ڒُومُورَاثْ نّشْ.   
\m
\v 11 مِينْ ثقَّارذْ شكْ،  
\m خمّْڒغْ ث ذڭْ وُوڒْ إِنُو،  
\m مَاحنْذْ وَارْ كِيذكْ خطِّيغْ.   
\m
\v 12 ثتّْوَابَارْكذْ شكْ، \add أَ\add* سِيذِي،  
\m سڒْمذْ أَيِي ثِيوصَّا نّشْ.   
\m
\v 13 س إِينْشِيشنْ إِنُو بَارّْحغْ  
\m مَارَّا لْفَارَايِيضْ ن ؤُقمُّومْ نّشْ.   
\m
\v 14 أَقَا فَارْحغْ س وبْرِيذْ ن شّْهَاذَاثْ نّشْ،  
\m أَمْ س مَارَّا مِينْ إِدْجَانْ إِغْڒَا.   
\m
\v 15 أَذْ خَارّْصغْ ذِي ڒُومُورَاثْ نّشْ،  
\m أَذْ خزَّارغْ غَارْ إِمسْرَاقْ نّشْ.   
\m
\v 16 نشّْ تَّارّغْ مژْڒِي ذِي ثِيوصَّا نّشْ،  
\m أَوَاڒْ نّشْ وَارْ ث تّتُّوغْ.   
\b  
\m
\v 17 \bd ڭِيملْ.\bd* أڭّْ ثْشُونِي إِ ؤُمْسخَّارْ نّشْ،  
\m مَاحنْذْ أَذْ دَّارغْ ؤُ أَذْ حْضِيغْ أَوَاڒْ نّشْ. \x ◘ \xo 119:‏17 \xt إِزهد. 103‏:‏2؛ 116‏:‏7\x*   
\m
\v 18 أَرْزمْ أَيِي ثِيطَّاوِينْ إِنُو،  
\m حِيمَا أَذْ ژَترغْ لْمُوعْجِيزَاثْ ن شَّارِيعَا نّشْ.   
\m
\v 19 نشّْ أَقَا أَيِي ذ أَبَارَّانِي خْ ثمُّورْثْ،  
\m وَارْ خَافِي ثفَّارْ ڒُومُورَاثْ نّشْ. \x ◘ \xo 119:‏19 \xt أَمز. 47‏:‏9؛ 1 إِم. 29‏:‏15؛ إِزهد. 39‏:‏13؛ عبر. 11‏:‏13\x*   
\m
\v 20 ڒعْمَارْ إِنُو إِتّْوَافْنَا  
\m س ؤُوحّشْ غَارْ لْفَارَايِيضْ نّشْ، ڒبْذَا.   
\m
\v 21 شكْ ثْعَاقْبذْ إِمْعفَّارنْ إِتّْوَانعْڒنْ،  
\m إِنِّي إِتّفّْغنْ خْ ڒُومُورَاثْ نّشْ.   
\m
\v 22 كْسِي خَافِي ڒفْضِيحثْ ذ ؤُسحْقَارْ،  
\m مَاغَارْ حْضِيغْ شّْهَاذَاثْ نّشْ.   
\m
\v 23 ؤُڒَا ذ ڒْحُوكَّامْ قِّيمنْ،  
\m سَّاوَاڒنْ أَكْ-ذ وَايَاوْيَا خَافِي،  
\m \add مَاشَا\add* أَمْسخَّارْ نّشْ  
\m إِتّْخَارّصْ ذِي ثْوصَّا نّشْ.   
\m
\v 24 شّْهَاذَاثْ نّشْ ذ مژْرِي إِنُو،  
\m أَقَا أَثنْثْ ذ إِمْشَاوَارنْ إِنُو. \x ◘ \xo 119:‏24 \xt إِزهد. 43‏:‏4\x*   
\b  
\m
\v 25 \bd ذَالِيثْ.\bd* ڒعْمَارْ إِنُو إِڒْصقْ غَارْ ثْعجَّاجْثْ،  
\m أَرّْ-د ذَايِي ثُوذَارْثْ عْلَاحْسَابْ أَوَاڒْ نّشْ.   
\m
\v 26 نشّْ نعْمغْ إِ شكْ خْ إِبْرِيذنْ إِنُو  
\m ؤُ شكْ ثسْثَاجْبذْ أَيِي.  
\m سڒْمذْ أَيِي ثِيوصَّا نّشْ. \x ◘ \xo 119:‏26 \xt إِزهد. 25‏:‏4؛ 27‏:‏11؛ 86‏:‏11\x*   
\m
\v 27 أَرّْ أَيِي أَذْ فهْمغْ  
\m أَبْرِيذْ ن ڒُومُورَاثْ نّشْ،  
\m أَذْ خَارّْصغْ ذِي لْمُوعْجِيزَاثْ نّشْ.   
\m
\v 28 ڒعْمَارْ إِنُو إِفْسِي س وشْضَانْ،  
\m سڭّمْ أَيِي غَارْ \add وبْرِيذْ ن\add* وَاوَاڒْ نّشْ.   
\m
\v 29 سِيڭّْوجْ أَيِي خْ وبْرِيذْ ن إِخَارِّيقنْ،  
\m حِينّْ خَافِي س شَّارِيعَا نّشْ.   
\m
\v 30 نشّْ إِخْضَارغْ أَبْرِيذْ ن ثِيذتّْ،  
\m سَّارْسغْ لْفَارَايِيضْ نّشْ \add زَّاثِي\add*.   
\m
\v 31 نشّْ شبَّارغْ  
\m ذِي شّْهَاذَاثْ نّشْ، \add أَ\add* سِيذِي،  
\m وَارْ ذ أَيِي تّجِّي أَذْ سضْحِيغْ.   
\m
\v 32 نشّْ أَذْ أَزّْڒغْ  
\m أَبْرِيذْ ن ڒُومُورَاثْ نّشْ،  
\m مَاغَارْ شكْ ثڭِّيذْ تَّاسِيعْ إِ وُوڒْ إِنُو.   
\b  
\m
\v 33 \bd هِي.\bd* \add أَ\add* سِيذِي! سڒْمذْ أَيِي  
\m أَبْرِيذْ ن ثْوصَّا نّشْ،  
\m \add خنِّي\add* نشّْ أَذْ ذَايسْ طّْفغْ أَڒْ أَنڭَّارْ.   
\m
\v 34 أوْشْ أَيِي ڒفْهَامثْ،  
\m \add خنِّي\add* أَذْ حْضِيغْ شَّارِيعَا نّشْ  
\m ؤُ أَذْ ذَايسْ طّْفغْ س وُوڒْ إِنُو مَارَّا.   
\m
\v 35 نْذهْ أَيِي خْ وبْرِيذْ ن ڒُومُورَاثْ نّشْ،  
\m مِينْزِي فَارّْحغْ زَّايسْ.   
\m
\v 36 أَرّْ ؤُڒْ إِنُو غَارْ شّْهَاذَاثْ نّشْ،  
\m وَارْ إِدْجِي غَارْ طّْمعْ ن أَرْبحْ.   
\m
\v 37 سْهيّضْ ثِيطَّاوِينْ إِنُو خْ ڒْبَاطڒْ،  
\m أَرّْ-د ذَايِي ثُوذَارْثْ س إِبْرِيذنْ نّشْ.   
\m
\v 38 ضْمنْ مِينْ ثنِّيذْ إِ ؤُمْسخَّارْ نّشْ،  
\m ونِّي شكْ إِتّڭّْوْذنْ.   
\m
\v 39 سْحيّذْ خَافِي ڒفْضِيحثْ إِ زِي تّڭّْوذغْ،  
\m مَاغَارْ لْفَارَايِيضْ نّشْ شْنَانْثْ.   
\m
\v 40 خْزَارْ، تّْوحّْشغْ ڒُومُورَاثْ نّشْ،  
\m أَرّْ أَيِي دَّارغْ س ثْسڭْذَا نّشْ.   
\b  
\m
\v 41 \bd وَاوْ.\bd* أجّْ أَذْ غَارِي د-ثَاسْ  
\m ثْمخْسِيوْثْ نّشْ إِشوَّارنْ، \add أَ\add* سِيذِي،  
\m أَسنْجمْ نّشْ  
\m \add أَقَا-ث\add* أَمْ مَامّشْ إِ ثنِّيذْ شكْ.   
\m
\v 42 حِيمَا زمَّارغْ أَذْ أَرّغْ  
\m خْ ونِّي زَّايِي إِسّْبهْذَاڒنْ،  
\m مَاغَارْ تّشْڒغْ خْ وَاوَاڒْ نّشْ.   
\m
\v 43 وَارْ تّكّسْ أَوَاڒْ ن ثِيذتّْ قَاعْ  
\m زڭْ ؤُقمُّومْ إِنُو،  
\m مَاغَارْ تّْرَاجِيغْ لْفَارَايِيضْ نّشْ.   
\m
\v 44 نشّْ أَذْ حْضِيغْ شَّارِيعَا نّشْ بْڒَا قطُّو،  
\m إِ ڒبْذَا قَاعْ.   
\m
\v 45 نشّْ ڭُّورغْ ذِي تَّاسِيعْ،  
\m مَاغَارْ أَرْزُوغْ خْ ڒُومُورَاثْ نّشْ.   
\m
\v 46 أَذْ سِّيوْڒغْ خْ شّْهَاذَاثْ نّشْ  
\m زَّاثْ إِ إِجدْجِيذنْ،  
\m وَارْ \add زَّاثْسنْ\add* تّْسضْحِيغْ شَا.   
\m
\v 47 أَذْ أَرّغْ مژْرِي ذِي ڒُومُورَاثْ نّشْ،  
\m ثِينِّي إِ تّخْسغْ.   
\m
\v 48 أَذْ سْڭعّْذغْ إِفَاسّنْ إِنُو  
\m قِيبَاڒْ إِ ڒُومُورَاثْ نّشْ، ثِينِّي إِ تّخْسغْ،  
\m أَذْ خَارّْصغْ ذِي ثْوصَّا نّشْ.   
\b  
\m
\v 49 \bd زَايِينْ.\bd* عْقڒْ خْ وَاوَاڒْ  
\m \add إِ ثنِّيذْ\add* إِ ؤُمْسخَّارْ نّشْ،  
\m مِينْ خفْ ثُويْڒذْ أَسِيثمْ إِنُو.   
\m
\v 50 ذ وَا ذ أَفوّجْ إِنُو ذِي ڒغْبنْ إِنُو،  
\m مَاغَارْ لْوَاعْذْ نّشْ  
\m يَارَّا-د ذَايِي ثُوذَارْثْ.   
\m
\v 51 إِمْعفَّارنْ سْثهْزَانْ زَّايِي أَڒْ طَّارْفْ،  
\m \add مَاشَا\add* نشّْ وَارْ حيِّيذغْ شَا  
\m خْ شَّارِيعَا نّشْ.   
\m
\v 52 نشّْ خَارّْصغْ  
\m ذِي لْفَارَايِيضْ نّشْ ن ڒبْذَا، \add أَ\add* سِيذِي،  
\m \add خنِّي\add* أَقَا تّْوَافوّْجغْ.   
\m
\v 53 ثَافْقحْثْ ثطّفْ أَيِي  
\m ذِي سِّيبّثْ ن إِعفَّاننْ،  
\m إِنِّي إِسمّْحنْ ذِي شَّارِيعَا نّشْ.   
\m
\v 54 ثِيوصَّا نّشْ ثُوغَا أَثنْثْ ذ إِزْڒَانْ إِنُو  
\m ذِي ثَادَّارْثْ ن ثْبَارَّانشْثْ إِنُو.   
\m
\v 55 ذِي دْجِيڒثْ ثُوغَا تّْخَارّْصغْ  
\m ذڭْ يِيسمْ نّشْ،  
\m \add أَ\add* سِيذِي، ؤُ حْضِيغْ شَّارِيعَا نّشْ. \x ◘ \xo 119:‏55 \xt إِزهد. 16‏:‏7؛ 42‏:‏9\x*   
\m
\v 56 أَمُّو إِ ذ أَيِي إِمْسَارْ،  
\m مَاغَارْ حْضِيغْ ڒُومُورَاثْ نّشْ.   
\b  
\m
\v 57 \bd خِيثْ.\bd* سِيذِي ذ ثَاسْغَارْثْ إِنُو،  
\m نشّْ نِّيغْ أَذْ حْضِيغْ أَوَاڒنْ نّشْ.   
\m
\v 58 حشّْمغْ \add زَّاثْ\add* إِ وُوذمْ نّشْ  
\m س مَارَّا وُوڒْ  إِنُو،  
\m حِينّْ خَافِي أَمْ مَامّشْ إِ \add ذ أَيِي\add* ثنِّيذْ.   
\m
\v 59 نشّْ خَارّْصغْ ذڭْ إِبْرِيذنْ إِنُو،  
\m أَذْ سّْعقْبغْ \add إِصُورَافْ ن\add* إِضَارنْ إِنُو  
\m غَارْ شّْهَاذَاثْ نّشْ.   
\m
\v 60 نشّْ قدْجْقغْ، وَارْعطَّاڒغْ شَا،  
\m حِيمَا أَذْ حْضِيغْ ڒُومُورَاثْ نّشْ.   
\m
\v 61 إِسغْوَانْ ن إِعفَّاننْ شَارّْفنْ أَيِي،  
\m \add مَاشَا\add* وَارْ تّتُّوغْ شَّارِيعَا نّشْ.   
\m
\v 62 غَارْ وزْينْ ن دْجِيڒثْ تّْنكَّارغْ،  
\m حِيمَا أَذْ شكْ قَاذِيغْ  
\m خْ لْفَارَايِيضْ نّشْ إِسڭّْذنْ.   
\m
\v 63 نشّْ ذ أَعْشِيرْ ن مَارَّا  
\m إِنِّي شكْ إِتّڭّْوذنْ،  
\m ن يِينِّي إِحطَّانْ ڒُومُورَاثْ نّشْ.   
\m
\v 64 زِي ثْمخْسِيوْثْ نّشْ إِشوَّارنْ  
\m ثشُّورْ ثمُّورْثْ مَارَّا، \add أَ\add* سِيذِي،  
\m سڒْمذْ أَيِي ثِيوصَّا نّشْ.   
\b  
\m
\v 65 \bd ثِيث.\bd* شكْ ثڭِّيذْ س ثْشُونِي إِ ؤُمْسخَّارْ نّشْ،  
\m \add أَ\add* سِيذِي، عْلَاحْسَابْ أَوَاڒْ نّشْ.   
\m
\v 66 سڒْمذْ أَيِي مَاحنْذْ أَذْ ميّْزغْ  
\m ؤُ أَذْ سّْنغْ مْلِيحْ،  
\m مِينْزِي تّشْڒغْ خْ ڒُومُورَاثْ نّشْ.   
\m
\v 67 قْبڒْ مَا تّْوَاحْصَارغْ، ودَّارغْ،  
\m \add مَاشَا\add* ڒخُّو حطِّيغْ مِينْ ثقَّارذْ شكْ.   
\m
\v 68 شكْ ذ أَصبْحَانْ، ثتّڭّذْ مِينْ إِصبْحنْ،  
\m سڒْمذْ أَيِي ثِيوصَّا نّشْ.   
\m
\v 69 إِمْعفَّارنْ أَرخُّونْ-د خَافِي إِخَارِّيقنْ،  
\m \add مَاشَا\add* نشّْ حطِّيغْ ڒُومُورَاثْ نّشْ  
\m س مَارَّا ؤُڒْ إِنُو.   
\m
\v 70 ؤُڒْ نْسنْ وَارْ إِتَّاشَانْ أَمْ ثَاذُونْثْ،  
\m \add مَاشَا\add* نشّْ، أَقَا شَّارِيعَا نّشْ  
\m تَّافغْ ذَايسْ مژْرِي.   
\m
\v 71 ثُوغَا إِ نشّْ مْلِيحْ ؤُمِي تّْوَاحْصَارغْ،  
\m مَاغَارْ أَمُّو إِ ڒمْذغْ ثِيوصَّا نّشْ.   
\m
\v 72 شَّارِيعَا زڭْ ؤُقمُّومْ نّشْ  
\m غَارِي إِحْڒَا أَطَّاسْ  
\m خْ وَاڒَافْ ن \add ؤُقِييَّاثْ\add* ن وُورغْ  
\m نِيغْ ن نُّوقَارْثْ. \x ◘ \xo 119:‏72 \xt إِزهد. 19‏:‏11\x*   
\b  
\m
\v 73 \bd يُوذْ.\bd* إِفَاسّنْ نّشْ ڭِّينْ أَيِي،  
\m كوّْننْ أَيِي.  
\m أوْشْ أَيِي ڒعْقڒْ،  
\m مَاحنْذْ أَذْ ڒمْذغْ ڒُومُورَاثْ نّشْ. \x ◘ \xo 119:‏73 \xt أَيُوبْ 10‏:‏9؛ إِزهد. 139‏:‏13\x*   
\m
\v 74 إِنِّي شكْ إِتّڭّْوذنْ أَذْ أَيِي ژَترنْ  
\m ؤُشَا أَذْ فَارْحنْ،  
\m مَاغَارْ تّْرَاجِيغْ أَوَاڒْ نّشْ.   
\m
\v 75 نشّْ سّْنغْ، \add أَ\add* سِيذِي،  
\m أَقَا سڭّْذنْثْ ڒحْكَامَاثْ نّشْ،  
\m ؤُ أَقَا شكْ ثحْصَارذْ أَيِي س ڒَامَانْ.   
\m
\v 76 أجّْ أَذْ ثِيڒِي ثْمخْسِيوْثْ نّشْ إِشوَّارنْ  
\m ذ أَفوّجْ إِ نشّْ،  
\m أَمْ مَامّشْ إِ ثنِّيذْ إِ ؤُمْسخَّارْ نّشْ.   
\m
\v 77 أَذْ خَافِي د-ثَاسْ أَرّحْمثْ نّشْ،  
\m مَاحنْذْ أَذْ دَّارغْ،  
\m مَاغَارْ شَّارِيعَا نّشْ ذَايسْ مژْرِي إِنُو.   
\m
\v 78 أجّْ أَذْ سضْحَانْ إِمْعفَّارنْ،  
\m مَاغَارْ س إِخَارِّيقنْ  
\m سّْفَارّْغنْ أَيِي \add صِّيفثْ إِنُو\add*،  
\m \add مَاشَا\add* نشّْ ثْخمَّامغْ  
\m ذِي ڒُومُورَاثْ نّشْ.   
\m
\v 79 أجّْ أَذْ غَارِي د-ذوْڒنْ  
\m إِنِّي شكْ إِتّڭّْوذنْ،  
\m إِنِّي إِسّْننْ شّْهَاذَاثْ نّشْ.   
\m
\v 80 أجّْ أَذْ يِيڒِي ؤُڒْ إِنُو إِمُونْ  
\m غَارْ ثْوصَّا نّشْ،  
\m حِيمَا وَارْ تّْسضْحِيغْ شَا.   
\b  
\m
\v 81 \bd كَافْ.\bd* ڒعْمَارْ إِنُو إِسْخفْ  
\m \add زِي مژْرِي\add* غَارْ ؤُسنْجمْ نّشْ،  
\m أَقَا تّْرَاجِيغْ أَوَاڒْ نّشْ.   
\m
\v 82 ثِيطَّاوِينْ إِنُو ذقّْڒنْثْ \add زِي مژْرِي\add*  
\m غَارْ مِينْ ثقَّارذْ شكْ، ؤُمِي نِّيغْ:  
\m ’مڒْمِي إِ خَافِي إِ غَا ثسّْفوّْجذْ؟‘   
\m
\v 83 مَاغَارْ ذوْڒغْ  
\m أَمْ يِيشْثْ ن ثْخَانْشثْ ن يِيڒمْ  
\m \add ثُويڒْ\add* ذِي دّخَّانْ،  
\m \add مَاشَا\add* ثِيوصَّا نّشْ  
\m وَارْ ثنْثْ تُّوغْ.   
\m
\v 84 مشْحَاڒْ ن وُوسَّانْ \add عَاذْ\add*  
\m \add إِ إِقِّيمنْ\add* إِ ؤُمْسخَّارْ نّشْ؟  
\m مڒْمِي إِ غَا ثْشَارّْعذْ  
\m إِنِّي ذ أَيِي إِضفَّارنْ؟   
\m
\v 85 إِمْعفَّارنْ غْزَانْ أَيِي إِحُوفَارْ،  
\m مِينْ وَارْ د-يُوسِينْ أَكْ-ذ شَّارِيعَا نّشْ.   
\m
\v 86 مَارَّا ڒُومُورَاثْ نّشْ ذ ثِيذتّْ.  
\m نِيثْنِي تّْذَارَّاشنْ أَيِي س إِخَارِّيقنْ،  
\m أوْشْ أَيِي أَفُوسْ!   
\m
\v 87 عْڒَاحَاڒْ إِڒِي أَقَا ثحَّانْ أَيِي  
\m زِي ثمُّورْثْ،  
\m \add مَاشَا\add* نشّْ وَارْ حيّْذغْ  
\m خْ ڒُومُورَاثْ نّشْ.   
\m
\v 88 أَرّْ-د ذَايِي ثُوذَارْثْ  
\m عْلَاحْسَابْ ثَامخْسِيوْثْ نّشْ إِشوَّارنْ،  
\m \add خنِّي\add* أَذْ حْضِيغْ شّْهَاذثْ \add إِ د-إِفّْغنْ\add*  
\m زڭْ ؤُقمُّومْ نّشْ.   
\b  
\m
\v 89 \bd لَامِيذْ.\bd* \add أَ\add* سِيذِي، أَوَاڒْ نّشْ  
\m إِتّْغِيمَا إِ ڒبْذَا إِمْثنْ ذڭْ ؤُجنَّا.   
\m
\v 90 ثَامخْسِيوْثْ نّشْ إِشوَّارنْ  
\m \add ثِيوضْ\add* زِي جِّيڒْ أَڒْ جِّيڒْ.  
\m شكْ ثڭِّيذْ ثَامُّورْثْ أَذْ ثْبدّْ ثمْثنْ  
\m ؤُ \add أَمُّو إِ\add* غَا ثقِّيمْ ثْبدّْ. \x ◘ \xo 119:‏90 \xt أَمب. 1‏:‏4\x*   
\m
\v 91 عْلَاحْسَابْ لْفَارَايِيضْ نّشْ أَذْ قِّيمنْ بدّنْ،  
\m مَاغَارْ مَارَّا نِيثْنِي ذ إِمْسخَّارنْ نّشْ.   
\m
\v 92 معْلِيكْ وَارْ ثدْجِي شَّارِيعَا نّشْ  
\m ذ مژْرِي إِنُو،  
\m إِڒِي تّْوَاهلّْكغْ ذِي ڒحْصَارثْ إِنُو.   
\m
\v 93 عمَّارْصْ أَذْ تُّوغْ ڒُومُورَاثْ نّشْ إِ ڒبْذَا،  
\m مَاغَارْ زَّايْسنْثْ ثَارِّيذْ أَيِي-د ثُوذَارْثْ.   
\m
\v 94 نشّْ أَقَا أَيِي إِ شكْ، سنْجمْ أَيِي،  
\m مِينْزِي أَرْزُوغْ خْ ڒُومُورَاثْ نّشْ.   
\m
\v 95 إِعفَّاننْ رَاجَانْ أَيِي حِيمَا أَذْ أَيِي ثحَّانْ،  
\m \add مَاشَا\add* نشّْ خزَّارغْ غَارْ شّْهَاذَاثْ نّشْ.   
\m
\v 96 نشّْ ژْرِيغْ أَقَا مَارَّا مِينْ ثدْجَا ڒكْمَارثْ  
\m غَارسْ أَنڭَّارْ،  
\m \add مَاشَا\add* ڒُومُورْ نّشْ غَارسْ تَّاسِيعْ أَطَّاسْ.   
\b  
\m
\v 97 \bd مِيمْ.\bd* مَامّشْ إِ خَافِي ثْعِيزّْ شَّارِيعَا نّشْ،  
\m أَسّْ إِكْمڒْ تّْخَارّْصغْ ذَايسْ.   
\m
\v 98 س ڒُومُورَاثْ نّشْ ثَارِّيذْ أَيِي ذ أَمِيغِيسْ  
\m خْ ڒْعذْيَانْ إِنُو، مَاغَارْ أَقَا أَثنْ غَارِي إِ ڒبْذَا.   
\m
\v 99 نشّْ غَارِي ڒعْقڒْ كْثَارْ  
\m خْ مَارَّا إِمْسڒْمَاذنْ إِنُو،  
\m مَاغَارْ تّْخَارّْصغْ ذڭْ إِبْرِيذنْ نّشْ.   
\m
\v 100 نشّْ غَارِي ڒفْهَامثْ كْثَارْ خْ إِوسُّورَا،  
\m مَاغَارْ حْضِيغْ ڒُومُورَاثْ نّشْ.   
\m
\v 101 منْعغْ إِضَارنْ إِنُو  
\m زِي قَاعْ إِبْرِيذنْ إِعفَّاننْ،  
\m حِيمَا أَذْ حْضِيغْ أَوَاڒْ نّشْ.   
\m
\v 102 نشّْ وَارْ حيّْذغْ شَا خْ لْفَارَايِيضْ نّشْ،  
\m مَاغَارْ شكْ ذ ونِّي ذ أَيِي إِسّْغَارنْ.   
\m
\v 103 مَامّشْ إِ غَا يِيڒِي ذ مِيژِيذْ  
\m مِينْ ثقَّارذْ شكْ  
\m إِ وَانغْ إِنُو، خْ ثَامّنْثْ إِ ؤُقمُّومْ إِنُو! \x ◘ \xo 119:‏103 \xt إِزهد. 19‏:‏11؛ أَوڒن. 8‏:‏11\x*   
\m
\v 104 زِي ڒُومُورَاثْ نّشْ تَّارِّيغْ-د ڒعْقڒْ،  
\m خْ ؤُيَا شَارّْهغْ كُوڒْ أَمسْرُوقْ ن إِخَارِّيقنْ.   
\b  
\m
\v 105 \bd نُونْ.\bd* أَوَاڒْ نّشْ ذ ڒفْنَارْ إِ ؤُضَارْ إِنُو  
\m ذ ثَافَاوْثْ إِ ؤُمسْرُوقْ إِنُو.   
\m
\v 106 نشّْ جُّودْجغْ ؤُ أَذْ \add ث\add* ڭّغْ،  
\m أَقَا أَذْ حْضِيغْ  
\m مَارَّا لْفَارَايِيضْ نّشْ إِسڭّْذنْ. \x ◘ \xo 119:‏106 \xt نَاح. 10‏:‏30\x*   
\m
\v 107 نشّْ تّْوَاحْصَارغْ أَطَّاسْ، \add أَ\add* سِيذِي،  
\m أَرّْ-د ذَايِي ثُوذَارْثْ عْلَاحْسَابْ أَوَاڒْ نّشْ.   
\m
\v 108 تّْزَاوْڭغْ، كْسِي س أَرْضَا  
\m ثِيوْهِيبِينْ ن ڒْخَاضَارْ  
\m زڭْ ؤُقمُّومْ إِنُو، \add أَ\add* سِيذِي،  
\m ؤُ سڒْمذْ أَيِي لْفَارَايِيضْ نّشْ.   
\m
\v 109 ثُوذَارْثْ إِنُو أَقَا-ث ڒبْذَا ذِي لْخَاطرْ،  
\m \add مَاشَا\add*عمَّارْصْ أَذْ تُّوغْ شَّارِيعَا نّشْ.   
\m
\v 110 إِعفَّاننْ ڭِّينْ أَيِي إِجّْ ن ڒْفخْ،  
\m \add مَاشَا\add* نشّْ وَارْ فّْغغْ شَا  
\m خْ ڒُومُورَاثْ نّشْ.   
\m
\v 111 شّْهَاذَاثْ نّشْ ذ ثَاسْغَارْثْ إِنُو إِ ڒبْذَا،  
\m مَاغَارْ نِيثنْثِي سّْفَارّْحنْثْ ؤُڒْ إِنُو.   
\m
\v 112 حزّْمغْ ؤُڒْ إِنُو  
\m مَاحنْذْ أَذْ ڭّغْ عْلَاحْسَابْ ثِيوصَّا نّشْ،  
\m إِ ڒبْذَا، أَڒْ أَنڭَّارْ.   
\b  
\m
\v 113 \bd سَامِيخْ.\bd* أَيْثْ ن ثْنَاينْ ن إِغمْبَابْ  
\m شَارّْهغْ ثنْ،  
\m \add مَاشَا\add* تّخْسغْ شَّارِيعَا نّشْ.   
\m
\v 114 شكْ ذ أَذُورِّي إِنُو  
\m ذ ثَاسدَّارْثْ ن ؤُسڒْقِي إِنُو،  
\m نشّْ تّْرَاجِيغْ أَوَاڒْ نّشْ.   
\m
\v 115 بعّْذمْ خَافِي، \add أَ\add* إِعفَّاننْ،  
\m حِيمَا أَذْ حْضِيغْ ڒُومُورَاثْ ن أَربِّي إِنُو.   
\m
\v 116 سنّذْ أَيِي عْلَاحْسَابْ لْوَاعْذْ نّشْ،  
\m مَاحنْذْ أَذْ دَّارغْ  
\m ؤُ وَارْ تّْسضْحِيغْ ذِي ڒَايَاسْ إِنُو.   
\m
\v 117 عمّذْ أَيِي،  
\m \add خنِّي\add* أَذْ تّْوَاسّْنجْمغْ،  
\m ؤُ أَذْ أَرّغْ مژْرِي  
\m ذِي ثْوصَّا نّشْ ڒبْذَا.   
\m
\v 118 مَارَّا إِنِّي إِتَّاڭّْوجنْ  
\m خْ ثْوصَّا نّشْ، سّحْقَارغْ ثنْ،  
\m مَاغَارْ ڒْغشّْ نْسنْ \add مْغِيرْ\add* ذ إِخَارِّيقنْ.   
\m
\v 119 أَمْ كُوفُّو ثْمحِّيذْ  
\m مَارَّا إِعفَّاننْ زِي ثمُّورْثْ،  
\m س ؤُيَا تّخْسغْ شّْهَاذَاثْ نّشْ.   
\m
\v 120 زِي ثِيڭّْوُوذِي زَّايكْ  
\m ثشِّيرُّووْ أَرِّيمثْ إِنُو،  
\m \add أَمُّو إِ\add* ڭّْوذغْ زِي ڒحْكَامَاثْ نّشْ.   
\b  
\m
\v 121 \bd عَايِينْ.\bd* نشّْ ڭِّيغْ ڒْحقّْ ذ ثْسڭْذَا،  
\m وَارْ ذ أَيِي تّْسلّمْ إِ \add ڒْمَارْڭحْ ن\add*  
\m يِينِّي ذ أَيِي إِحصَّارنْ.   
\m
\v 122 أڭّْ ڒْعَارْبُونْ ذِي طّْوعْ ن ؤُمْسخَّارْ نّشْ،  
\m وَارْ تّجِّي إِمْعفَّارنْ أَذْ أَيِي حْصَارنْ.   
\m
\v 123 ثِيطَّاوِينْ إِنُو ذقّْڒنْثْ  
\m \add زِي مژْرِي\add* غَارْ ؤُسنْجمْ نّشْ،  
\m غَارْ لْوَاعْذْ ن ثْسڭْذَا نّشْ.   
\m
\v 124 أڭّْ س ثْمخْسِيوْثْ نّشْ إِشوَّارنْ  
\m أَكْ-ذ ؤُمْسخَّارْ نّشْ،  
\m سڒْمذْ أَيِي ثِيوصَّا نّشْ.   
\m
\v 125 نشّْ ذ أَمْسخَّارْ نّشْ، أوْشْ أَيِي ڒعْقڒْ،  
\m مَاحنْذْ أَذْ سّْنغْ شّْهَاذَاثْ نّشْ.   
\m
\v 126 أَقَا يِيوضْ أَسْ-د ڒْحَاڒْ إِ سِيذِي،  
\m حِيمَا أَذْ إِبدّْ خْ إِضَارنْ نّسْ،  
\m \add مَاغَارْ\add* نِيثْنِي أَرْژِينْ شَّارِيعَا نّشْ.   
\m
\v 127 مِينْزِي تّخْسغْ ثِيوصَّا نّشْ خْ وُورغْ،  
\m \add وَاهْ\add* أَطَّاسْ خْ وُورغْ إِتّْوَاصفَّانْ،   
\m
\v 128 خْ ؤُيَا حسْبغْ مَارَّا ڒُومُورَاثْ \add نّشْ\add*  
\m ذِي كُوڒْ \add ثَامسْڒَاشْثْ\add* نِيشَانْ،  
\m \add مَاشَا\add* شَارْهغْ كُوڒْ أَمسْرُوقْ ن إِخَارِّيقنْ.   
\b  
\m
\v 129 \bd بِي.\bd* شّْهَاذَاثْ نّشْ ذ لْمُوعْجِيزَاثْ،  
\m خْ ؤُيَا إِحطَّا ثنْثْ وُوڒْ إِنُو.   
\m
\v 130 أَنُورْزمْ ن وَاوَاڒنْ نّشْ  
\m إِسّْشَانْ ثَافَاوْثْ،  
\m إِ إِحَافِييّنْ إِتِّيشْ أَسنْ ڒعْقڒْ. \x ◘ \xo 119:‏130 \xt إِزهد. 19‏:‏9\x*   
\m
\v 131 أَرْزْمغْ أَقمُّومْ إِنُو أَطَّاسْ  
\m ؤُ سَّاحْرَاثغْ زِي مژْرِي غَارْ ڒُومُورَاثْ نّشْ.   
\m
\v 132 أَرّْ ؤُذمْ \add نّشْ\add* غَارِي ؤُ حِينّْ خَافِي،  
\m أَمْ مَامّشْ د-ثكَّارْ  
\m إِ يِينِّي إِتّخْسنْ إِسمْ نّشْ.   
\m
\v 133 سمْثنْ إِصُورَافْ إِنُو  
\m أَمْ مَامّشْ إِ ذ أَيِي ثنِّيذْ،  
\m وَارْ تّجِّي أَذْ خَافِي إِحْكمْ ڒْغشّْ وَالُو.   
\m
\v 134 فكّْ أَيِي زِي ڒحْصَارثْ ن إِوْذَانْ،  
\m مَاحنْذْ أَذْ حْضِيغْ ڒُومُورَاثْ نّشْ.   
\m
\v 135 أجّْ ؤُذمْ نّشْ  
\m أَذْ يَارْغْ خْ ؤُمْسخَّارْ نّشْ،  
\m سڒْمذْ أَيِي ثِيوصَّا نّشْ. \x ◘ \xo 119:‏135 \xt إِزهد. 4‏:‏7\x*   
\m
\v 136 ثِيغزْرَاثِينْ ن وَامَانْ هْوَانْثْ-إِ-د  
\m زِي ثِيطَّاوِينْ إِنُو،  
\m مَاغَارْ نِيثْنِي وَارْ حطَّانْ شَّارِيعَا نّشْ.   
\b  
\m
\v 137 \bd ثْسَاذِي.\bd* أَقَا شكْ ذ أَمْسڭّذْ، \add أَ\add* سِيذِي،  
\m ؤُڒَا ذ لْفَارَايِيضْ نّشْ سڭّْذنْثْ.   
\m
\v 138 شكْ ثُومُورذْ ثَاسڭْذَا ن شّْهَاذَاثْ نّشْ،  
\m ڒْْمَانثْ \add نْسنْ\add* ذ ثَامقّْرَانْثْ أَطَّاسْ.   
\m
\v 139 ثُوسْمِي إِنُو \add إِقدّْسنْ\add* إِنُو ثشَّا أَيِي،  
\m مَاغَارْ إِنِّي ذ أَيِي إِحصَّارنْ  
\m تُّونْ أَوَاڒنْ نّشْ.   
\m
\v 140 لْوَاعْذْ نّشْ إِقُّورْ أَطَّاسْ،  
\m أَمْسخَّارْ نّشْ إِتّخْسْ إِ-ث. \x ◘ \xo 119:‏140 \xt 2 صم. 22‏:‏31؛ إِزهد. 12‏:‏7؛ 18‏:‏31؛ أَوڒن. 30‏:‏5\x*   
\m
\v 141 نشّْ ذ أَمُوقْڒِيڒْ ؤُ تّْوَاسّحْقَارغْ،  
\m \add مَاشَا\add* وَارْ تّتُّوغْ ڒُومُورَاثْ نّشْ.   
\m
\v 142 ثَاسڭْذَا نّشْ ذ ثَاسڭْذَا إِ ڒبْذَا،  
\m شَّارِيعَا نّشْ ذ ثِيذتّْ.   
\m
\v 143 دِّيقثْ ذ ثڭّْوُوذِي ڒقّْفنْثْ أَيِي،  
\m \add مَاشَا\add* ڒُومُورَاثْ نّشْ  
\m ذَايْسنْثْ مژْرِي إِنُو.   
\m
\v 144 ثَاسڭْذَا ن شّْهَاذَاثْ نّشْ  
\m إِ ڒبْذَا إِ ثدْجَا.  
\m سفْهمْ أَيِي \add ثنْثْ\add*، \add خنِّي\add* أَذْ دَّارغْ.   
\b  
\m
\v 145 \bd قُوفْ.\bd* ڒَاغِيغْ س مَارَّا ؤُڒْ  إِنُو،  
\m أَرّْ-د خَافِي، \add أَ\add* سِيذِي،  
\m \add خنِّي\add* أَذْ حْضِيغْ ثِيوصَّا نّشْ.   
\m
\v 146 نشّْ ڒَاغِيغْ-د خَاكْ، فكّْ أَيِي،  
\m \add خنِّي\add* أَذْ حْضِيغْ مَارَّا شّْهَاذَاثْ نّشْ.   
\m
\v 147 قْبڒْ ثُوفُّوثْ ثُوغَا تّْڒَاغِيغْ  
\m حِيمَا أَذْ أَيِي د-ثوْشذْ أَفُوسْ،  
\m رَاجِيغْ أَوَاڒْ نّشْ. \x ◘ \xo 119:‏147 \xt إِزهد. 5‏:‏4؛ 88‏:‏14؛ 130‏:‏6\x*   
\m
\v 148 ثِيطَّاوِينْ إِنُو فَاقنْثْ  
\m قْبڒْ ڒْوقْثْ ن وُوضُوفْ ن وشْبَارْ،  
\m حِيمَا أَذْ خَارّْصغْ  
\m ذڭْ وَاوَاڒنْ نّسْ. \x ◘ \xo 119:‏148 \xt إِزهد. 63‏:‏2، 7؛ 90‏:‏4\x*   
\m
\v 149 سڒْ-د غَارْ ثْمِيجَّا إِنُو  
\m عْلَاحْسَابْ ثَامخْسِيوْثْ نّشْ إِشوَّارنْ،  
\m \add أَ\add* سِيذِي، أَرّْ-د ذَايِي ثُوذَارْثْ  
\m عْلَاحْسَابْ لْفَارَايِيضْ نّشْ.   
\m
\v 150 إِنِّي يَارزُّونْ أَذْ ڭّنْ ڒفْضَايحْ،  
\m ؤُذْسنْ أَيِي،  
\m أَقَا نِيثْنِي تَّاڭّْوجنْ أَطَّاسْ  
\m خْ شَّارِيعَا نّشْ.   
\m
\v 151 شكْ ثُوذْسذْ، \add أَ\add* سِيذِي،  
\m مَارَّا ڒُومُورَاثْ نّشْ ذ ثِيذتّْ إِ دْجَانْ.   
\m
\v 152 \add ؤُڒَا\add* ذ أَطَّاسْ زڭْ وَامِي  
\m ثُوغَا سّْنغْ شّْهَاذَاثْ نّشْ،  
\m مَاغَارْ شكْ ثڭِّيذْ ثنْثْ إِ ڒبْذَا.   
\b  
\m
\v 153 \bd رِيخْ.\bd* خْزَارْ غَارْ ڒغْبنْ إِنُو  
\m ؤُ ثسّْنجْمذْ أَيِي،  
\m مَاغَارْ وَارْ تُّوغْ شَّارِيعَا نّشْ.   
\m
\v 154 أَغْ أَيِي ثَاسْغَارْثْ ؤُشَا فكّْ أَيِي،  
\m أَرّْ-د ذَايِي ثُوذَارْثْ  
\m أَمْ مَامّشْ إِ ذ أَيِي ثنِّيذْ.   
\m
\v 155 إِڭّْوجْ ؤُسنْجمْ خْ إِعفَّاننْ،  
\m مَاغَارْ وَارْ أَرزُّونْ ثِيوصَّا نّشْ.   
\m
\v 156 \add أَ\add* سِيذِي، أَرّحْمثْ نّشْ ذ أَطَّاسْ،  
\m أَرّْ-د ذَايِي ثُوذَارْثْ  
\m عْلَاحْسَابْ لْفَارَايِيضْ ن نّشْ.   
\m
\v 157 إِنِّي ذ أَيِي إِتّْذَارَّاشنْ  
\m ذ يِينِّي ذ أَيِي إِحصَّارنْ  
\m أَقَا أَثنْ \add س\add* وَاطَّاسْ،  
\m \add مَاشَا\add* نشّْ وَارْ حيّْذغْ شَا  
\m خْ شّْهَاذَاثْ نّشْ.   
\m
\v 158 ژْرِيغْ إِنِّي ذ أَيِي إِغْذَارنْ ؤُشَا عِيفّغْ \add ثنْ\add*،  
\m مَاغَارْ نِيثْنِي وَارْ طِّيفنْ  
\m ذڭْ وَاوَاڒْ نّشْ.   
\m
\v 159 خْزَارْ، مَامّشْ تّخْسغْ ڒُومُورَاثْ نّشْ،  
\m \add أَ\add* سِيذِي، أَرّْ-د ذَايِي ثُوذَارْثْ  
\m عْلَاحْسَابْ ثَامخْسِيوْثْ نّشْ إِشوَّارنْ.   
\m
\v 160 بدُّو ن وَاوَاڒْ نّشْ أَقَا-ث ذ ثِيذتّْ،  
\m كُوڒْ ڒحْكَامْ إِسڭّْذنْ زَّايكْ  
\m أَقَا-ث إِ ڒبْذَا.   
\b  
\m
\v 161 \bd شِينْ.\bd* ڒْحُوكَّامْ ذَارّْشنْ خَافِي خْ وَالُو،  
\m \add مَاشَا\add* ؤُڒْ إِنُو ثُوغَا إِتّڭّْوذْ  
\m زڭْ وَاوَاڒْ نّشْ.   
\m
\v 162 نشّْ فَارْحغْ خْ لْوَاعْذْ نّشْ،  
\m أَمشْنَاوْ إِجّنْ إِ إِتَّافْ  
\m إِشْثْ ن ثْكشَّاضْثْ ثَامقّْرَانْثْ.   
\m
\v 163 نشّْ شَارّْهغْ أَخَارِّيقْ ؤُ عِيفّغْ ث،  
\m \add مَاشَا\add* تّخْسغْ شَّارِيعَا نّشْ.   
\m
\v 164 سبْعَا ن ثْوَاڒَاوِينْ ذڭْ وَاسّْ  
\m صبْحغْ شكْ  
\m خْ ڒحْكَامَاثْ ن ثْسڭْذَا نّشْ.   
\m
\v 165 إِنِّي إِتّخْسنْ شَّارِيعَا نّشْ،  
\m أَقَا غَارْسنْ ڒهْنَا ثَامقّْرَانْثْ،  
\m وَارْ ذِينْ أَژْرُو ن ؤُنقْرَاضْ زَّاثْسنْ.   
\m
\v 166 \add أَ\add* سِيذِي، تّْرَاجِيغْ أَسنْجمْ نّشْ،  
\m ؤُ تّڭّغْ عْلَاحْصَابْ ثِيوصَّا نّشْ.   
\m
\v 167 ڒعْمَارْ إِنُو إِحطَّا شّْهَاذَاثْ نّشْ،  
\m تّخْسغْ ثنْثْ أَطَّاسْ.   
\m
\v 168 نشّْ حطِّيغْ ڒُومُورَاثْ نّشْ  
\m ذ شّْهَاذَاثْ نّشْ،  
\m مَاغَارْ مَارَّا إِبْرِيذنْ إِنُو  
\m \add أَرْزْمنْ\add* زَّاثكْ.   
\b  
\m
\v 169 \bd ثَافْ.\bd* \add أَ\add* سِيذِي، أجّْ أَذْ غَاركْ د-يَاوضْ  
\m ؤُڒَاغِي إِنُو زَّاثْ إِ وُوذمْ نّشْ،  
\m أوْشْ أَيِي ڒعْقڒْ عْلَاحْسَابْ أَوَاڒْ نّشْ.   
\m
\v 170 أجّْ أَذْ د-ثَاسْ ثُوثْرَا إِنُو  
\m غَارْ وُوذمْ نّشْ،  
\m فكّْ أَيِي أَمْ مَامّشْ إِ ذ أَيِي ثنِّيذْ.   
\m
\v 171 إِينْشِيشنْ إِنُو أَذْ ؤُشْرُورنْ أَصبّحْ  
\m أَمْ يِيجّْ ن ڒْعُونْصَارْ،  
\m مَاغَارْ شكْ ثسّڒْمَاذذْ أَيِي  
\m ثِيوصَّا نّشْ.   
\m
\v 172 إِڒسْ إِنُو أَذْ يَارّْ مِينْ ثنِّيذْ شكْ،  
\m مَاغَارْ مَارَّا ڒُومُورَاثْ نّشْ سڭّْذنْ.   
\m
\v 173 أجّْ أَفُوسْ نّشْ أَذْ أَيِي إِڭّْ ثْوِيزَا،  
\m مَاغَارْ إِخْضَارغْ ڒُومُورَاثْ نّشْ.   
\m
\v 174 \add أَ\add* سِيذِي، تّْمژْرغْ غَارْ ؤُسنْجمْ نّشْ،  
\m شَّارِيعَا نّشْ أَقَا ذَايسْ مژْرِي إِنُو.   
\m
\v 175 أجّْ ڒعْمَارْ إِنُو أَذْ إِدَّارْ،  
\m أَذْ شكْ إِصبّحْ،  
\m أَذْ أَيِي عَاوْننْثْ لْفَارَايِيضْ نّشْ.   
\m
\v 176 نشّْ ودَّارغْ  
\m أَمْ يِيجّْ ن ؤُهُوڒِي إِودَّارنْ.  
\m أَرْزُو خْ ؤُمْسخَّارْ نّشْ،  
\m مَاغَارْ وَارْ تُّوغْ ڒُومُورَاثْ نّشْ. \x ◘ \xo 119:‏176 \xt إِشا. 53‏:‏6؛ لك. 15‏:‏4‏-‏7\x*   
\b  
\b  
\m  
\c 120
\m
\v 1 \add إِزْڒِي ن ؤُڭعّذْ.\add*  
\b  
\m نشّْ ڒَاغِيغْ غَارْ سِيذِي ذِي ڒحْصَارثْ إِنُو  
\m ؤُ نتَّا إِسْڒَا أَيِي.   
\m
\v 2 \add أَ\add* سِيذِي، فكّْ ڒعْمَارْ إِنُو  
\m زڭْ إِينْشِيشنْ إِسّْخَارِّيقنْ،  
\m زڭْ إِڒسْ إِشمّْثنْ. \x ◘ \xo 120:‏2 \xt 1 صم. 24‏:‏10؛ 26‏:‏19\x*   
\b  
\m
\v 3 مِينْ ذ أَشْ إِ غَا يوْشْ،  
\m مِينْ ذ أَشْ إِ غَا يَارْنِي إِڒسْ  
\m نِّي إِشمّْثنْ؟   
\m
\v 4 فْڒِيثْشَاثْ ن ڒْقوْسْ قضْعنْثْ  
\m \add زڭْ ؤُفُوسْ\add* ن إِجّْ ن ؤُمْجَاهذْ،  
\m أَكْ-ذ ڒفْحمْ ن ثْشجَّارْثْ ن ثَاڭَّا. \x ◘ \xo 120:‏4 \xt إِزهد. 11‏:‏2؛ 59‏:‏8\x*   
\b  
\m
\v 5 ؤُشْثْ إِنُو، أَقَا نشّْ ذ أَبَارَّانِي ذِي مَاشِيكْ،  
\m أَقَا زدّْغغْ غَارْ إِقِيضَانْ ن قِيذَارْ!   
\m
\v 6 أَطَّاسْ إِ إِزْذغْ ڒعْمَارْ إِنُو  
\m غَارْ يِينِّي إِشَارّْهنْ ڒهْنَا.   
\m
\v 7 نشّْ ذ أَهدَّانْ،  
\m مَاشَا خْمِي غَا سِّيوْڒغْ،  
\m خنِّي أَرزُّونْ أَمنْغِي.   
\b  
\b  
\m  
\c 121
\m
\v 1 \add إِزْڒِي ن ؤُڭعّذْ.\add*  
\b  
\m نشّْ سّْڭعّْذغْ ثِيطَّاوِينْ إِنُو غَارْ إِذُورَارْ،  
\m مَانِيسْ د غَا ثَاسْ ثْوِيزَا إِنُو؟   
\m
\v 2 ثْوِيزَا إِنُو زِي سِيذِي،  
\m ونِّي إِڭِّينْ إِجنْوَانْ ذ ثمُّورْثْ.   
\b  
\m
\v 3 نتَّا وَارْ إِتّجِّي أَضَارْ نّشْ أَذْ إِفَارْغْ،  
\m ونِّي شكْ إِحطَّانْ وَارْ إِتّْنُوذُومْ.   
\m
\v 4 خْزَارْ، ونِّي إِحطَّانْ إِسْرَائِيل  
\m وَارْ إِتّْنُوذُومْ ؤُ وَارْ إِتّطّصْ.   
\b  
\m
\v 5 سِيذِي ذ أَمحْضَايْ نّشْ،  
\m سِيذِي ذ ثِيڒِي نّشْ غَارْ ؤُفُوسْ أَفُوسِي نّشْ.   
\m
\v 6 ذڭْ وَاسّْ ثَافُوشْثْ وَارْ شكْ ثشِّيثْ شَا،  
\m ؤُڒَا ذ ثَازِيرِي س دْجِيڒثْ.   
\b  
\m
\v 7 سِيذِي أَذْ شكْ إِحْضَا زِي مَارَّا ڒْغَارْ،  
\m نتَّا أَذْ إِحْضَا ڒعْمَارْ نّشْ. \f ◼ \fr 121:‏7 \ft \+bd ’ڒعْمَارْ نّكْ‘\+bd* - إِخْسْ أَذْ يِينِي ’ثُوذَارْثْ نّكْ‘.\f*   
\m
\v 8 سِيذِي أَذْ إِحْضَا ؤُفُّوغْ نّشْ ذ وَاذَافْ نّشْ،  
\m زِي ڒخُّو أَڒْ إِ ڒبْذَا.   
\b  
\b  
\m  
\c 122
\m
\v 1 \add إِزْڒِي ن ؤُڭعّذْ. ن ذَاوُوذْ.\add*  
\b  
\m نشّْ فَارّْحغْ ؤُمِي ذ أَيِي نَّانْ:  
\m ”نشِّينْ أَذْ نُويُورْ  
\m غَارْ ثَادَّارْثْ ن سِيذِي.   
\m
\v 2 إِضَارنْ نّغْ بدّنْ-د  
\m غَارْ ثوُّورَا نّشْ،  
\m \add أَ\add* ؤُرْشَالِيمْ!“   
\m
\v 3 ؤُرْشَالِيمْ ثتّْوَابْنَا أَمْ يِيشْثْ ن ثنْذِينْثْ  
\m نِّي إِتّْوَاشبَّارنْ مْلِيحْ  
\m أَكْ-ذ يِيخفْ نّسْ.   
\b  
\m
\v 4 غَارْ ذِينِّي تّْڭعَّاذنْثْ ثْقبَّاڒْ،  
\m ثِيقبَّاڒْ ن سِيذِي،  
\m \add عْلَاحْسَابْ\add* لْفَارِيضَا إِ إِسْرَائِيل،  
\m حِيمَا أَذْ قَاذَانْ إِسمْ ن سِيذِي.   
\m
\v 5 مَاغَارْ ذِينِّي بدّنْ ڒكْرَاسِي ن شّْرعْ  
\m ڒكْرَاسِي ن ثَادَّارْثْ ن ذَاوُوذْ.   
\b  
\m
\v 6 تَّارمْ إِ ڒهْنَا ن ؤُرْشَالِيمْ:  
\m ”أَقَا أَذْ فڒْحنْ إِنِّي شمْ إِتّخْسنْ،   
\m
\v 7 حِيمَا أَذْ ذِينْ يِيڒِي ڒهْنَا  
\m غَارْ ڒْحِيضْ ن زَّاثْ نّمْ،  
\m ؤُڒَا ذ ڒْهُوذْنثْ ذِي ڒقْصُورْ نّمْ.“   
\m
\v 8 ذِي طّْوعْ ن أَيْثْمَا  
\m ذ إِمدُّوكَّاڒْ إِنُو أَذْ إِنِيغْ:  
\m ”أَذْ ذَايمْ يِيڒِي ڒهْنَا!“   
\m
\v 9 ذِي طّْوعْ ن ثَادَّارْثْ ن سِيذِي،  
\m أَربِّي نّغْ،  
\m أَذْ أَشْ أَرْزُوغْ خْ مِينْ إِشْنَانْ.   
\b  
\b  
\m  
\c 123
\m
\v 1 \add إِزْڒِي ن ؤُڭعّذْ.\add*  
\b  
\m نشّْ سّْڭعّْذغْ ثِيطَّاوِينْ إِنُو غَاركْ،  
\m شكْ إِ إِقِّيمنْ \add خْ ڒْكُورْسِي نّسْ\add*  
\m ذڭْ ؤُجنَّا. \x ◘ \xo 123:‏1 \xt إِزهد. 2‏:‏4؛ إِزهد. 113‏:‏5، 6؛ إِزهد. 115‏:‏3\x*   
\m
\v 2 خْزَارْ، أَمْ ثِيطَّاوِينْ ن إِسمْغَانْ  
\m غَارْ ؤُفُوسْ ن بَابْ نْسنْ،  
\m أَمْ ثِيطَّاوِينْ ن ثَايَّا  
\m غَارْ ؤُفُوسْ ن لَالَّاسْ،  
\m أَمُّو إِ \add خزَّارنْثْ\add* ثِيطَّاوِينْ نّغْ  
\m غَارْ سِيذِي، أَربِّي نّغْ،  
\m أَڒْ خَانغْ إِ غَا إِحِينّْ.   
\b  
\m
\v 3 حِينّْ خَانغْ، \add أَ\add* سِيذِي، حِينّْ خَانغْ،  
\m مَاغَارْ يُوزَا غَارْنغْ ؤُسحْقَارْ.   
\m
\v 4 ڒعْمَارْ نّغْ يُوزَا غَارسْ أَطَّاسْ  
\m زڭْ ؤُسْثهْزِي ن أَيْثْ ن بُو-نّْفَاخثْ،  
\m ؤُڒَا زڭْ ؤُسحْقَارْ ن إِغبَّاننْ.   
\b  
\b  
\m  
\c 124
\m
\v 1 \add إِزْڒِي ن ؤُڭعّذْ. ن ذَاوُوذْ.\add*  
\b  
\m مْڒِي سِيذِي وَارْ كِيذْنغْ إِبدّْ!  
\m إِنِي \add ث خنِّي أَمُّو\add*، \add أَ\add* إِسْرَائِيل،   
\m
\v 2 مْڒِي سِيذِي وَارْ كِيذْنغْ إِبدّْ،  
\m ؤُمِي أَكِيذْنغْ د-كَّارنْ إِوْذَانْ،   
\b  
\m
\v 3 إِڒِي سَارْضنْ أَنغْ أَمْ ندَّارْ،  
\m ؤُمِي يَارْغَا ؤُخيّقْ نْسنْ خَانغْ،   
\m
\v 4 إِڒِي أَمَانْ فيّْضنْ خَانغْ،  
\m إِڒِي إِشْثْ ن ڒْحمْڒثْ ثكَّا خْ ڒعْمَارْ نّغْ،   
\m
\v 5 إِڒِي أَمَانْ إِحَاجنْ كِّينْ خْ ڒعْمَارْ نّغْ.   
\b  
\m
\v 6 أَذْ إِتّْوَابَاركْ سِيذِي،  
\m ونِّي وَارْ د أَنغْ إِتّجِّينْ  
\m ذ ثَاكشَّاضْثْ إِ ثغْمَاسْ نْسنْ.   
\m
\v 7 ڒعْمَارْ نّغْ يَارْوڒْ  
\m أَمْ وجْضِيضْ زِي ڒْفخْ ن ؤُنڭْمَارْ.  
\m ڒْفخْ يَارژْ ؤُ نشِّينْ ننْفكّْ. \x ◘ \xo 124:‏7 \xt أَوڒن. 6‏:‏5\x*   
\b  
\m
\v 8 ثْوِيزَا نّغْ ثْبدّْ ذڭْ يِيسمْ ن سِيذِي،  
\m ونِّي إِڭِّينْ إِجنْوَانْ ذ ثمُّورْثْ. \x ◘ \xo 124:‏8 \xt إِزهد. 121‏:‏2\x*   
\b  
\b  
\m  
\c 125
\m
\v 1 \add إِزْڒِي ن ؤُڭعّذْ.\add*  
\b  
\m إِنِّي إِتّشْڒنْ خْ سِيذِي،  
\m أَقَا أَثنْ أَمْ وذْرَارْ ن صِيهْيُونْ،  
\m ونِّي وَارْ إِتّنْهزِّينْ،  
\m \add مَاشَا\add* إِتّْغِيمَا إِ ڒبْذَا. \x ◘ \xo 125:‏1 \xt إِزهد. 9‏:‏5، 8، 12؛ إِزهد.123‏:‏1 \x*   
\m
\v 2 أَمْ مَامّشْ إِذُورَارْ  
\m قُووَّارنْ إِ ؤُرْشَالِيمْ،  
\m أَمُّو إِقُووَّارْ سِيذِي إِ ڒْڭنْسْ نّسْ،  
\m زِي ڒخُّو أَڒْ ڒبْذَا.   
\b  
\m
\v 3 مَاغَارْ أَزدْجَاضْ ن ڒْغَارْ  
\m وَارْ إِتّْغِيمِي إِتَّاريّحْ  
\m خْ ثمُّورْثْ ن إِمْسڭَّاذنْ،  
\m حِيمَا إِمْسڭَّاذنْ  
\m وَارْ سّْوِيژِّيضنْ إِفَاسّنْ نْسنْ غَارْ ڒْغَارْ.   
\b  
\m
\v 4 إِڒِي أَذْ يڭّْ سِيذِي ثَاشُونِي  
\m ذڭْ إِصبْحَاننْ،  
\m ذڭْ إِنِّي إِسڭّْذنْ س وُوڒْ، \f ◼ \fr 125:‏4 \ft \+bd ’س وُوڒْ‘\+bd* - س ثْعِيبْرَانِيثْ ’س وُوڒَاونْ‘.\f*   
\m
\v 5 \add مَاشَا\add* إِنِّي إِ غَا إِحيّْذنْ \add زڭْ وبْرِيذْ\add*  
\m غَارْ إِبْرِيذنْ إِفَارْغنْ،  
\m أَذْ ثنْ إِسِّيڭّْوجْ سِيذِي \add جْمِيعْ\add*  
\m أَكْ-ذ يِينِّي إِتّڭّنْ ڒْغشّْ.  
\m \add أَذْ ذِينْ يِيڒِي\add* ڒهْنَا خْ إِسْرَائِيل.   
\b  
\b  
\m  
\c 126
\m
\v 1 \add إِزْڒِي ن ؤُڭعّذْ.\add*  
\b  
\m ؤُمِي إِسّعْقبْ سِيذِي  
\m إِنِّي د-إِذوْڒنْ غَارْ صِيهْيُونْ،  
\m ثُوغَا أَنغْ أَخْمِي يِينِّي إِتُّورْجَانْ.   
\m
\v 2 ثُوغَا أَقمُّونْ نّغْ إِشُّورْ  
\m س ثْضحَّاشْثْ،  
\m إِڒسْ نّغْ إِشُّورْ س ؤُسْڒِيوْڒوْ.  
\m نَّانْ جَارْ ڒڭْنُوسْ:  
\m ’سِيذِي إِڭَّا ذَايْسنْ  
\m ثِيمسْڒَايِينْ ثِيمقّْرَانِينْ!‘ \x ◘ \xo 126:‏2 \xt أَيُوبْ 8‏:‏21\x*   
\m
\v 3 سِيذِي إِڭَّا ذَايْنغْ  
\m ثِيمسْڒَايِينْ ثِيمقّْرَانِينْ،  
\m أَقَا نشِّينْ نْفَارْحْ \add زَّايسْ\add*.   
\m
\v 4 \add أَ\add* سِيذِي، قدْجبْ ثَامحْبَاسْثْ نّغْ،  
\m أَمْ مَامّشْ \add تّْقدْجْبنْثْ\add* ثِيغزْرَاثِينْ  
\m \add ثَامُّورْثْ\add* ن لْجَانُوبْ.   
\m
\v 5 إِنِّي إِزَارّْعنْ س إِمطَّاونْ،  
\m أَذْ مْجَارنْ س ؤُسْڒِيوْڒوْ.   
\m
\v 6 ونِّي يَاربُّونْ  
\m ثَاخَانْشثْ ن زَّارِيعثْ،  
\m إِتّْرُو خْمِي د-إِڭُّورْ،  
\m \add مَاشَا\add* خْمِي د غَا يَاسْ،  
\m أَذْ د-يَاسْ س ؤُسْڒِيوْڒوْ،  
\m أَذْ يَارْبُو ثِيقبِّيضِينْ \add ن إِمنْذِي\add* نّسْ.   
\b  
\b  
\m  
\c 127
\m
\v 1 \add إِزْڒِي ن ؤُڭعّذْ. ن سُولِيمَانْ.\add*  
\b  
\m مْڒِي وَارْ إِبنِّي سِيذِي ثَادَّارْثْ،  
\m أَذْ سِّيحْڒنْ إِبنَّاينْ إِخفْ نْسنْ بَاطڒْ.  
\m مْڒِي وَارْ إِحطِّي سِيذِي خْ ثنْذِينْثْ،  
\m أَعسَّاسْ أَذْ إِعسّْ بَاطڒْ.   
\b  
\m
\v 2 بَاطڒْ أَقَا كنِّيوْ أَذْ ثكَّارمْ زِيشْ،  
\m أَذْ ثطّْصمْ ثْعضْڒمْ،  
\m أَذْ ثشّمْ أَغْرُومْ ن ڒمْحَاينْ،  
\m مَاغَارْ نتَّا إِتِّيشْ إِ-ث  
\m إِ إِمْعِيزّنْ نّسْ ذڭْ يِيضصْ.   
\b  
\m
\v 3 خْزَارْ، أَرَّاونْ ذ ثَاسْغَارْثْ  
\m \add إِ إِمّوْشنْ\add* زِي سِيذِي،  
\m ڒْغِيدْجثْ ن ؤُعذِّيسْ أَقَا-ت ذ ڒْمُونثْ.   
\m
\v 4 أَمْ مَامّشْ \add جهْذنْثْ\add* فْڒِيثْشَاثْ ن ڒْقوْسْ  
\m ذڭْ ؤُفُوسْ ن ورْيَازْ،  
\m أَمُّو إِ دْجَانْ أَرَّاونْ  
\m \add زڭْ إِسڭّْوُوسَا\add* ن ثمْژِي.   
\b  
\m
\v 5 سّعْذْ ن ورْيَازْ إِجهْذنْ  
\m نِّي زَّايْسنْ إِشُّورْ  
\m أَقْرَابْ نّسْ ن فْڒِيثْشَاثْ ن ڒْقوْسْ.  
\m نِيثْنِي وَارْ تّْسضْحِينْ شَا  
\m ؤُمِي سَّاوَاڒنْ أَكْ-ذ ڒْعذْيَانْ  
\m غَارْ ثوَّارْثْ \add ن ثنْذِينْثْ\add*.   
\b  
\b  
\m  
\c 128
\m
\v 1 \add إِزْڒِي ن ؤُڭعّذْ.\add*  
\b  
\m سّعْذْ ن كُوڒْ إِجّْ  
\m ونِّي إِتّڭّْوذنْ سِيذِي،  
\m ونِّي إِڭُّورنْ ذڭْ إِبْرِيذنْ نّسْ.   
\m
\v 2 أَقَا أَذْ ثشّذْ  
\m زڭْ وَارْبرْ ن إِفَاسّنْ نّشْ،  
\m أَذْ ثِيڒِيذْ ذ أَمِيمُونْ ذ لمْلِيحْ.   
\b  
\m
\v 3 ثَامْغَارْثْ نّشْ أَذْ ثِيڒِي  
\m أَمْ إِشْثْ ن ثْزَايَارْثْ إِ د-إِتَّاوْينْ ڒْغِيدْجثْ  
\m ذِي ثَادَّارْثْ نّشْ،  
\m أَرَّاونْ نّشْ أَذْ إِڒِينْ  
\m أَمْ إِغمُّوينْ ن زِّيثُونْ  
\m قُووَّارنْ إِ طَّابْڒَا نّشْ.   
\b  
\m
\v 4 أَمُّو إِ غَا إِتّْوَابَاركْ ورْيَازْ إِجهْذنْ  
\m نِّي إِتّڭّْوذنْ سِيذِي.   
\m
\v 5 سِيذِي أَذْ شكْ إِبَاركْ زِي صِيهْيُونْ،  
\m ؤُ أَذْ ثْژَارذْ أَقَا ؤُرْشَالِيمْ أَذْ ثِيڒِي مْلِيحْ،  
\m مَارَّا ؤُسَّانْ ن ثُوذَارْثْ نّشْ،   
\m
\v 6 \add وَاهْ،\add* أَذْ ثْژَارذْ  
\m إِحنْجِيرنْ ن إِحنْجِيرنْ نّشْ.  
\m ڒهْنَا \add أَذْ يِيڒِي\add* خْ إِسْرَائِيل.   
\b  
\b  
\m  
\c 129
\m
\v 1 \add إِزْڒِي ن ؤُڭعّذْ.\add*  
\b  
\m ”زِي ثمْژِي إِنُو  
\m حْصَارنْ أَيِي أَطَّاسْ ن ثْوَاڒَاوِينْ!“  
\m إِنِي \add ث خنِّي أَمُّو\add*، \add أَ\add* إِسْرَائِيل،   
\m
\v 2 زِي ثمْژِي إِنُو حْصَارنْ أَيِي  
\m أَطَّاسْ ن ثْوَاڒَاوِينْ،  
\m مَاشَا وَارْ ذ أَيِي زمَّارنْ.   
\b  
\m
\v 3 إِمْشَارّْزنْ شَارْزنْ خْ وعْرُورْ إِنُو،  
\m ڭِّينْ ڒَاثَارَاثْ ن وشْرَازْ نْسنْ ذ إِزِيرَارنْ.   
\m
\v 4 سِيذِي ذ أَمْسڭّذْ.  
\m نتَّا إِقْضعْ إِسغْوَانْ ن إِعفَّاننْ.   
\m
\v 5 أجّْ مَارَّا إِنِّي إِشَارّْهنْ صِيهْيُونْ،  
\m أَذْ سضْحَانْ ؤُ أَذْ تّْوَاعَارْننْ غَارْ ضفَّارْ.   
\b  
\m
\v 6 أجّْ إِ-ثنْ أَذْ ذوْڒنْ  
\m أَمْ أَرْبِيعْ خْ ثْزغْوِينْ  
\m إِ إِتِّيسْڒَاوْ قْبڒْ إِ-ث غَا قڒْعنْ، \x ◘ \xo 129:‏6 \xt أَيُوبْ 8‏:‏12؛ 40‏:‏10\x*   
\m
\v 7 وَارْ زَّايسْ إِتّْعمَّارْ  
\m ونِّي إِمجَّارنْ  
\m أَفُوسْ نّسْ،  
\m ؤُڒَا ذ ونِّي إِتّْشدَّانْ  
\m إِشوَّافنْ \add ن إِمنْذِي\add*  
\m أَحْسِينْ نّسْ،   
\m
\v 8 ؤُ حِيمَا إِمْسبْرِيذنْ وَارْ قَّارنْ:  
\m ”لْبَارَاكَا ن سِيذِي أَقَا-ت أَكِيذْومْ!“  
\m ”نشِّينْ نْبَاركْ كنِّيوْ س يِيسمْ ن سِيذِي.“   
\b  
\b  
\m  
\c 130
\m
\v 1 \add إِزْڒِي ن ؤُڭعّذْ.\add*  
\b  
\m زِي ڒَادْجَاغْ ڒَاغِيغْ-د خَاكْ، \add أَ\add* سِيذِي!   
\m
\v 2 \add أَ\add* سِيذِي إِنُو، سڒْ إِ ثْمِيجَّا إِنُو،  
\m أجّْ إِمزُّوغنْ نّشْ أَذْ فثْننْ  
\m خْ ثْمِيجَّا ن ثُوثْرَا إِنُو!   
\b  
\m
\v 3 \add أَ\add* سِيذِي، مَاڒَا ثحْضِيضْ  
\m ڒْْمُوعْصِييَّاثْ مْلِيحْ،  
\m \add أَ\add* سِيذِي إِنُو، مَانْ ونْ إِزمَّارنْ  
\m أَذْ إِقِّيمْ إِبدّْ. \x ◘ \xo 130:‏3 \xt إِزهد. 143‏:‏2\x*   
\m
\v 4 مَاشَا غَاركْ أَسَامحْ،  
\m مَاحنْذْ أَذْ زَّايكْ ڭّْوذنْ. \x ◘ \xo 130:‏4 \xt 2 صم. 24‏:‏14\x*   
\b  
\m
\v 5 نشّْ سِيثِيمغْ ذِي سِيذِي،  
\m ڒعْمَارْ إِنُو \add إِشُّورْ س\add* ؤُسِيثمْ،  
\m تّْرَاجِيغْ أَوَاڒْ نّسْ، \x ◘ \xo 130:‏5 \xt إِزهد. 27‏:‏14؛ 40‏:‏2؛ حَاب. 2‏:‏3\x*   
\m
\v 6 ڒعْمَارْ إِنُو \add إِتّْرَاجَا\add* سِيذِي إِنُو،  
\m أَطَّاسْ زڭْ إِعسَّاسنْ \add تّْرَاجَانْ\add*  
\m غَارْ \add ؤُ\add*ثفُّو. \x ◘ \xo 130:‏6 \xt إِزهد. 5‏:‏4؛ 119‏:‏147؛ 123‏:‏1، 2\x*   
\b  
\m
\v 7 أجّْ إِسْرَائِيل أَذْ إِرَاجَا سِيذِي،  
\m مَاغَارْ ثَامخْسِيوْثْ إِشوَّارنْ  
\m أَقَا-ت غَارْ سِيذِي،  
\m غَارسْ أَفكِّي إِشطّْ.   
\m
\v 8 نتَّا أَذْ إِسّنْجمْ إِسْرَائِيل  
\m زِي مَارَّا ڒْمُوعْصِييَّاثْ نّسْ.   
\b  
\b  
\m  
\c 131
\m
\v 1 \add إِزْڒِي ن ؤُڭعّذْ. ن ذَاوُوذْ.\add*  
\b  
\m \add أَ\add* سِيذِي، ؤُڒْ إِنُو  
\m وَارْ ذَايسْ بُو نّْفَاخثْ،  
\m ثِيطَّاوِينْ إِنُو وَارْ ذَايْسنْثْ بُو ؤُنعْفَارْ،  
\m وَارْ تّڭّغْ شَا ثِيمسْڒَايِينْ ؤُجَارنْثْ أَيِي  
\m نِيغْ ذ ثِينِّي ذ ڒعْجبْ إِ نشّْ. \x ◘ \xo 131:‏1 \xt 2 إِم. 32‏:‏25؛ إِزهد. 101‏:‏5؛ أَوڒن. 6‏:‏17؛ 16‏:‏5\x*   
\b  
\m
\v 2 س ثِيذتّْ، سَّاريّْحغْ ڒعْمَارْ إِنُو  
\m ؤُ سّسْقَارغْ ث،  
\m أَمْ إِجّْ ن ؤُنِييْبُو  
\m ؤُمِي إِتّْوَاسّْبدّْ وُوطُّوضْ  
\m أَكْ-ذ يمَّاسْ،  
\m أَمْ إِجّْ ن ؤُنِييْبُو  
\m ؤُمِي إِتّْوَاسّْبدّْ وُوتُّوضْ  
\m أَمُّو إِ إِدْجَا ڒعْمَارْ إِنُو ذَايِي.   
\b  
\m
\v 3 أجّْ إِسْرَائِيل أَذْ إِرَاجَا سِيذِي،  
\m زِي ڒخُّو أَڒْ ڒبْذَا.   
\b  
\b  
\m  
\c 132
\m
\v 1 \add إِزْڒِي ن ؤُڭعّذْ.\add*  
\b  
\m \add أَ\add* سِيذِي، إِذَارْ ذَاوُوذْ،  
\m \add إِذَارْ\add* مَارَّا أَودّبْ نّسْ،   
\m
\v 2 مَامّشْ إِجُّودْجْ إِ سِيذِي،  
\m إِوَاعْذْ إِ ؤُمْزمَّارْ ن يَاعْقُوبْ:   
\m
\v 3 ”\add ؤُشْثْ\add*، مَاڒَا أَذْ أَذْفغْ  
\m غَارْ ثَاقِيذُونْثْ ن ثَادَّارْثْ إِنُو،  
\m أَذْ حبْشغْ خْ قَامَا ن ڒشْثُو إِنُو، \x ◘ \xo 132:‏3 \xt 1 إِم. 15‏:‏1\x*   
\m
\v 4 أَذْ سمّْحغْ يِيضصْ إِ ثِيطَّاوِينْ إِنُو،  
\m ؤُڒَا ذ أَنُوذمْ إِ وَابْڒِيونْ إِنُو،   
\m
\v 5 قْبڒْ إِ غَا أَفغْ أَمْشَانْ إِ سِيذِي،  
\m إِشْثْ ن ثْزذِّيغْثْ إِ سِيذِي،  
\m أَمْزمَّارْ ن يَاعْقُوبْ!“   
\b  
\m
\v 6 خْزَارْ، نسْڒَا خْ \add تَّابُوثْ\add* ذِي إِفْرَاثَا،  
\m نُوفَا إِ-ت ذڭْ إِيَّارنْ ن يَاعَارْ. \f ◼ \fr 132:‏6 \ft \+bd ’يَاعَارْ‘\+bd* - إِخْسْ أَذْ يِينِي ’قَارْيَاثْ-يَاعَارِيمْ‘ مَانِي إِدْجَانْ تَّاپُوثْ أَوَارْنِي د-إِذْوڒْ زِي ثمُّورْثْ ن إِفِيلِيسْطِينِييّنْ (1 صم. 6‏:21-7‏:2؛ 1 إِم. 13‏:6)\f*   
\m
\v 7 أَذْ نَاذفْ غَارْ ثْزذِّيغِينْ نّسْ،  
\m أَذْ نسْجذْ إِ ثْنبْذَاثْ ن إِضَارنْ نّسْ.   
\m
\v 8 كَّارْ، سِيذِي، \add ؤُيُورْ\add* غَارْ أَرَّاحثْ نّشْ،  
\m شكْ ذ تَّابُوثْ ن جّهْذْ نّشْ.   
\m
\v 9 أجّْ إِكهَّاننْ نّشْ  
\m أَذْ يَارْضنْ س ثْسڭْذَا،  
\m إِمْثِيقَّانْ نّشْ أَذْ سْڒِيوڒْونْ.   
\m
\v 10 وَارْ د-ثَارِّي ؤُذمْ ن ؤُمذْهُونْ نّشْ  
\m ذِي طّْوعْ ن ؤُمْسخَّارْ نّشْ ذَاوُوذْ.   
\b  
\m
\v 11 سِيذِي إِجُّودْجْ إِ ذَاوُوذْ س ڒَامَانْ،  
\m عمَّارْصْ أَذْ إِحيّذْ نتَّا  
\m خْ ثْجَادْجِيثْ نّسْ:  
\m ”زِي ڒْغِيدْجثْ ن ؤُعذِّيسْ نّشْ  
\m أَذْ سّْغِيمغْ \add إِجّْ\add* خْ ڒْعَارْشْ نّشْ. \x ◘ \xo 132:‏11 \xt 2 صم. 7‏:‏12؛ 1 إِج. 8‏:‏25؛ 2 إِم. 6‏:‏16؛ لك. 1‏:‏69 \x*   
\m
\v 12 مَاڒَا إِحنْجِيرنْ نّشْ  
\m أَذْ حْضَانْ ڒْعَاهْذْ إِنُو ذ شّْهَاذَاثْ إِنُو،  
\m ثِينِّي ذ أَسنْ إِ غَا سّْڒمْذغْ،  
\m خنِّي ؤُڒَا ذ إِحنْجِيرنْ نْسنْ  
\m أَذْ قِّيمنْ خْ ڒْكُورْسِي نّشْ إِ ڒبْذَا.“   
\m
\v 13 مَاغَارْ سِيذِي إِفَارْزْ صِيهْيُونْ،  
\m إِمژْرِي ت ذ ثَازذِّيغْثْ إِ يِيخفْ نّسْ.   
\b  
\m
\v 14 ”وَا ذ \add أَمْشَانْ ن\add* أَرَّاهثْ إِنُو إِ ڒبْذَا،  
\m ذَا إِ خْسغْ أَذْ زذْغغْ، نشّْ خْسغْ ث. \x ◘ \xo 132:‏14 \xt إِزهد. 68‏:‏17؛ 132‏:‏8 \x*   
\m
\v 15 أَذْ بَارْكغْ نِّيعْمثْ ن صِيهْيُونْ،  
\m أَذْ سّْجِيوْنغْ إِمزْڒَاضْ نّسْ س وغْرُومْ.   
\m
\v 16 أَذْ سّْيَارْضغْ إِكهَّاننْ نّسْ  
\m س ؤُسنْجمْ،  
\m إِمْثِيقَّانْ نّسْ أَذْ سْڒِيوڒْونْ س جّهْذْ. \x ◘ \xo 132:‏16 \xt 2 إِم. 6‏:‏41\x*   
\m
\v 17 ذِينِّي أَذْ سّْغمّْيغْ  
\m إِجّْ ن ؤُيِيشّْ إِ ذَاوُوذْ،  
\m إِجّْ نْ ڒفْنَارْ إِ ؤُمذْهُونْ إِنُو  
\m سّْوجْذغْ \add ث ذِينْ\add*.\x ◘ \xo 132:‏17 \xt لك. 1‏:‏69\x*   
\m
\v 18 أَذْ سّْيَارْضغْ ڒْعذْيَانْ نّسْ  
\m س ؤُسضْحِي،  
\m مَاشَا أَذْ خَاسْ إِنُّووَارْ  
\m تَّاجْ \add ن وعْزَاڒْ\add* نّسْ.“   
\b  
\b  
\m  
\c 133
\m
\v 1 \add إِزْڒِي ن ؤُڭعّذْ. ن ذَاوُوذْ.\add*  
\b  
\m خْزَارْ، مَامّشْ إِصْبحْ  
\m ذ مَامّشْ إِشْنَا،  
\m مَاڒَا ثَاوْمَاثْ زدّْغنْ مُوننْ!   
\m
\v 2 أَيَا أَمْ زّشْثْ إِشْنَانْ خْ ؤُزدْجِيفْ،  
\m ثنِّي د-إِهكّْوَانْ خْ ثْمَارْثْ،  
\m خْ ثْمَارْثْ ن هَارُونْ،  
\m ثْهكّْوَا-د  
\m خْ ثْمَا ن ؤُفُورِّي ن وَارُّوضْ نّسْ.   
\m
\v 3 أَيَا أَمْ نّْذَا ن \add وذْرَارْ ن\add* هِيرْمُونْ،  
\m ونِّي د-إِهكّْوَانْ خْ إِذُورَارْ ن صِيهْيُونْ،  
\m مَاغَارْ ذِينِّي يُومُورْ سِيذِي لْبَارَاكَا \add نّسْ\add*،  
\m ثُوذَارْثْ إِ ڒبْذَا.   
\b  
\b  
\m  
\c 134
\m
\v 1 \add إِزْڒِي ن ؤُڭعّذْ.\add*  
\b  
\m خْزَارْ، بَارْكمْ سِيذِي،  
\m \add أَ\add* كنِّيوْ إِمْسخَّارنْ ن سِيذِي،  
\m إِنِّي إِبدّنْ ذِي ثَادَّارْثْ ن سِيذِي ذِي دْجِيڒثْ.   
\m
\v 2 سْڭعّْذمْ إِفَاسّنْ نْومْ  
\m غَارْ زَّاوشْثْ إِقدّْسنْ  
\m ؤُ بَارْكمْ سِيذِي.   
\b  
\m
\v 3 أَذْ شكْ إِبَاركْ سِيذِي زِي صِيهْيُونْ،  
\m نتَّا ذ ونِّي إِڭِّينْ إِجنْوَانْ ذ ثمُّورْثْ.   
\b  
\b  
\m  
\c 135
\m
\v 1 هَالِّيلُو-يَاهْ!  
\m صبّْحمْ إِسمْ ن سِيذِي،  
\m صبّْحمْ \add خَاسْ\add*، \add أَ\add* إِمْسخَّارنْ ن سِيذِي،   
\m
\v 2 \add كنِّيوْ\add* إِنِّي إِبدّنْ ذِي ثَادَّارْثْ ن سِيذِي،  
\m ذِي ڒمْرَاحَاثْ ن ثَادَّارْثْ ن أَربِّي نّغْ.   
\m
\v 3 هَالِّيلُو-يَاهْ، مَاغَارْ سِيذِي إِصْبحْ،  
\m زهّْذمْ إِ يِيسمْ نّسْ،  
\m مَاغَارْ نتَّا ذ ڒضْرَافثْ.   
\m
\v 4 مَاغَارْ سِيذِي إِفَارْزْ يَاعْقُوبْ إِ يِيخفْ نّسْ،  
\m إِسْرَائِيل ذ أَڭْڒَا نّسْ. \x ◘ \xo 135:‏4 \xt ؤُف. 19‏:‏5؛ أَعَوذ. 7‏:‏6؛ ثِيث. 2‏:‏14؛ 1 بُط. 2‏:‏9\x*   
\b  
\m
\v 5 مَاغَارْ \bd نشّْ\bd* سّْنغْ أَقَا سِيذِي ذ أَمقّْرَانْ،  
\m سِيذِيثْنغْ \add ذ أَمقّْرَانْ\add* خْ مَارَّا إِربِّيثنْ.   
\m
\v 6 مَارَّا مِينْ ذ أَسْ إِتّعْجِيبنْ إِ سِيذِي، إِڭَّا إِ-ث،  
\m ذڭْ إِجنْوَانْ ؤُ خْ ثمُّورْثْ،  
\m ذِي ڒبْحُورْ ؤُ ذڭْ \add وَامَانْ\add* إِهوْڒنْ مَارَّا.   
\m
\v 7 نتَّا إِسّْڭعّذْ إِسيْنُوثنْ  
\m زِي طّْرُوفَا ن ثمُّورْثْ،  
\m نتَّا إِتّڭّْ أَسَّامنْ أَكْ-ذ ونْژَارْ،  
\m إِتّْڭوَّاذْ أَسمِّيضْ  
\m زِي ڒهْرِيثْ نّسْ غَارْ بَارَّا. \x ◘ \xo 135:‏7 \xt إِرْم. 10‏:‏13؛ 51‏:‏16\x*   
\b  
\m
\v 8 نتَّا إِوْثَا إِمنْزَا ن مِيصْرَا،  
\m زڭْ إِوْذَانْ أَڒْ ڒْمَارْ. \x ◘ \xo 135:‏8 \xt ؤُف. 12‏:‏12، 29؛ إِزهد. 78‏:‏51\x*   
\m
\v 9 نتَّا إِسّكّْ ڒعْڒَامَاثْ ذ لْمُوعْجِيزَاثْ  
\m ذِي ڒْوسْطْ نّشْ، \add أَ\add* مِيصْرَا،  
\m غَارْ فِيرْعُونْ  
\m ؤُ غَارْ مَارَّا إِمْسخَّارنْ نّسْ. \x ◘ \xo 135:‏9 \xt ؤُف. 7، 8، 9، 10، 14\x*   
\b  
\m
\v 10 نتَّا إِوْثَا أَطَّاسْ ن ڒڭْنُوسْ  
\m ؤُ إِنْغَا إِجدْجِيذنْ إِجهْذنْ. \x ◘ \xo 135:‏10 \xt ياش. 12\x*   
\m
\v 11 سِيحُونْ، أَجدْجِيذْ ن إِمُورِييّنْ،  
\m ؤُ عُوجْ، أَجدْجِيذْ ن بَاشَانْ،  
\m ؤُ مَارَّا ثِيڭلْذِيوِينْ ن كنْعَانْ.   
\m
\v 12 إِوْشَا أَسنْ ثَامُّورْثْ ذ ثَاسْغَارْثْ،  
\m ذ ثَاسْغَارْثْ إِ إِسْرَائِيل، ڒْڭنْسْ نّسْ. \x ◘ \xo 135:‏12 \xt إِزهد. 78‏:‏55\x*   
\b  
\m
\v 13 \add أَ\add* سِيذِي، إِسمْ نّشْ إِتّْغِيمَا إِ ڒبْذَا،  
\m أَخَارّصْ ذَايكْ \add أَذْ يِيڒِي\add* زِي جِّيڒْ أَڒْ جِّيڒْ. \x ◘ \xo 135:‏13 \xt ؤُف. 3‏:‏15، إِزهد. 102‏:‏13 \x*   
\m
\v 14 مَاغَارْ سِيذِي أَذْ يَارّْ ثَاسْغَارْثْ  
\m غَارْ ڒْڭنْسْ نّسْ،  
\m نتَّا أَذْ إِحِينّْ خْ إِمْسخَّارنْ نّسْ. \x ◘ \xo 135:‏14 \xt أَعَوذ. 32‏:‏36، إِزهد. 90‏:‏13\x*   
\b  
\m
\v 15 ڒخْيَاڒَاثْ نْ لْ-أَصْنَامْ ن ڒڭْنُوسْ  
\m أَقَا أَثنْثْ س نُّوقَارْثْ ذ وُورغْ،  
\m تّْوَاڭّنْثْ س إِفَاسّنْ ن إِوْذَانْ.\x ◘ \xo 135:‏15 \xt إِزهد. 115‏:‏4\x*   
\m
\v 16 نِيثنْثِي غَارْسنْثْ إِجّْ ن ؤُقمُّومْ،  
\m \add مَاشَا\add* وَارْ سِّيوِيڒنْثْ،  
\m غَارْسنْ ثِيطَّاوِينْ،  
\m \add مَاشَا\add* وَارْ تّْوِيڒِينْثْ،   
\m
\v 17 نِيثنْثِي غَارْسنْ ثِيمزُّوغنْ،  
\m \add مَاشَا\add* وَارْ تّسْڒِينْثْ،  
\m وَالُو أَسُوضِي \add ن نّفْسْ\add*  
\m ذڭْ ؤُقمُّونْ نْسنْ.   
\m
\v 18 أَذْ ذوْڒنْ إِنِّي ثنْثْ إِڭِّينْ  
\m أَمْ نِيثنْثِي،  
\m مَارَّا وِي خَاسنْثْ إِتّْشَاڒْ.   
\b  
\m
\v 19 \add أَ\add* ثَادَّارْثْ ن إِسْرَائِيل، بَارْكمْ سِيذِي،  
\m \add أَ\add* ثَادَّارْثْ ن هَارُونْ، بَارْكمْ سِيذِي.   
\m
\v 20 \add أَ\add* ثَادَّارْثْ ن لَاوِي، بَارْكمْ سِيذِي!  
\m أجّْ مَارَّا إِنِّي إِتّڭّْوذنْ سِيذِي،  
\m أَذْ بَارْكنْ سِيذِي.   
\m
\v 21 أَذْ إِتّْوَابَاركْ سِيذِي زِي صِيهْيُونْ،  
\m نتَّا ذ ونِّي إِزدّْغنْ ذِي ؤُرْشَالِيمْ.  
\m هَالِّيلُو-يَاهْ!   
\b  
\b  
\m  
\c 136
\m
\v 1 قَاذَامْ سِيذِي، مَاغَارْ نتَّا إِصْبحْ،  
\m مَاغَارْ ثَامخْسِيوْثْ نّسْ إِشوَّارنْ  
\m ثتّْغِيمَا إِ ڒبْذَا. \x ◘ \xo 136:‏1 \xt عِز.3‏:‏11؛ إِرْم. 33‏:‏11\x*   
\m
\v 2 قَاذَامْ ونِّي ذ أَربِّي خْ \add مَارَّا\add* إِربِّيثنْ،  
\m مَاغَارْ ثَامخْسِيوْثْ نّسْ إِشوَّارنْ  
\m ثتّْغِيمَا إِ ڒبْذَا.   
\m
\v 3 قَاذَامْ ونِّي ذ سِيذِي خْ \add مَارَّا\add* إِسِيذِيثنْ،  
\m مَاغَارْ ثَامخْسِيوْثْ نّسْ إِشوَّارنْ  
\m ثتّْغِيمَا إِ ڒبْذَا،   
\b  
\m
\v 4 ... ونِّي إِتّڭّنْ لْمُوعْجِيزَاثْ ثِيمقّْرَانِينْ،  
\m نتَّا وَاهَا،  
\m مَاغَارْ ثَامخْسِيوْثْ نّسْ إِشوَّارنْ  
\m ثتّْغِيمَا إِ ڒبْذَا،   
\m
\v 5 ... ونِّي إِڭِّينْ إِجنْوَانْ س ڒفْهَامثْ،  
\m مَاغَارْ ثَامخْسِيوْثْ نّسْ إِشوَّارنْ  
\m ثتّْغِيمَا إِ ڒبْذَا، \x ◘ \xo 136:‏5 \xt أَمز. 1‏:‏1\x*   
\m
\v 6 ... ونِّي إِڭِّينْ ثَامُّورْثْ خْ وَامَانْ،  
\m مَاغَارْ ثَامخْسِيوْثْ نّسْ إِشوَّارنْ  
\m ثتّْغِيمَا إِ ڒبْذَا. \x ◘ \xo 136:‏6 \xt إِزهد. 24‏:‏2\x*   
\b  
\m
\v 7 ... ونِّي إِڭِّينْ ثِيفَاوِينْ ثِيمقّْرَانِينْ،  
\m مَاغَارْ ثَامخْسِيوْثْ نّسْ إِشوَّارنْ  
\m ثتّْغِيمَا إِ ڒبْذَا، \x ◘ \xo 136:‏7 \xt أَمز. 1‏:‏14\x*   
\m
\v 8 ثَافُوشْثْ حِيمَا أَذْ ثحْكمْ خْ وَاسّْ،  
\m مَاغَارْ ثَامخْسِيوْثْ نّسْ إِشوَّارنْ  
\m ثتّْغِيمَا إِ ڒبْذَا، \x ◘ \xo 136:‏8 \xt أَمز. 1‏:‏16\x*   
\m
\v 9 ثَازِيرِي ذ إِثْرَانْ حِيمَا أَذْ حكْمنْ خْ دْجِيڒثْ،  
\m مَاغَارْ ثَامخْسِيوْثْ نّسْ إِشوَّارنْ  
\m ثتّْغِيمَا إِ ڒبْذَا،   
\b  
\m
\v 10 ... ونِّي إِوْثِينْ إِمِيصْرِييّنْ  
\m ذڭْ إِمنْزَا نْسنْ،  
\m مَاغَارْ ثَامخْسِيوْثْ نّسْ إِشوَّارنْ  
\m ثتّْغِيمَا إِ ڒبْذَا، \x ◘ \xo 136:‏10 \xt ؤُف. 12‏:‏29؛ إِزهد. 78‏:‏43، 51\x*   
\m
\v 11 ... ونِّي د-إِسُّوفّْغنْ إِسْرَائِيل  
\m زِي ڒْوسْثْ نْسنْ،  
\m مَاغَارْ ثَامخْسِيوْثْ نّسْ إِشوَّارنْ  
\m ثتّْغِيمَا إِ ڒبْذَا، \x ◘ \xo 136:‏11 \xt ؤُف. 12‏:‏31، 51؛ 13‏:‏3، 17\x*   
\m
\v 12 س ؤُفُوسْ إِجهْذنْ ذ ؤُغِيڒْ إِتّْوَاسّْڭعّْذنْ،  
\m مَاغَارْ ثَامخْسِيوْثْ نّسْ إِشوَّارنْ  
\m ثتّْغِيمَا إِ ڒبْذَا. \x ◘ \xo 136:‏12 \xt ؤُف. 6‏:‏6\x*   
\b  
\m
\v 13 ... ونِّي إِبْضَانْ ڒبْحَارْ ن ثلْڭَا خْ ثْنَاينْ،  
\m مَاغَارْ ثَامخْسِيوْثْ نّسْ إِشوَّارنْ  
\m ثتّْغِيمَا إِ ڒبْذَا، \x ◘ \xo 136:‏13 \xt ؤُف. 14‏:‏21، 22؛ إِزهد. 78‏:‏13\x*   
\m
\v 14 ؤُشَا إِسّژْوَا إِسْرَائِيل ذِي ڒْوسْثْ نّسْ،  
\m مَاغَارْ ثَامخْسِيوْثْ نّسْ إِشوَّارنْ  
\m ثتّْغِيمَا إِ ڒبْذَا.   
\m
\v 15 ؤُشَا إِنْضَارْ فِيرْعُونْ ذِي ڒبْحَارْ ن ثلْڭَا  
\m أَكْ-ذ ڒْعسْكَارْ نّسْ،  
\m مَاغَارْ ثَامخْسِيوْثْ نّسْ إِشوَّارنْ  
\m ثتّْغِيمَا إِ ڒبْذَا. \x ◘ \xo 136:‏15 \xt ؤُف. 14‏:‏24\x*   
\b  
\m
\v 16 ... ونِّي إِنذْهنْ ڒْڭنْسْ نّسْ  
\m \add ذڭْ وبْرِيذْ\add* ذِي ڒخْڒَا،  
\m مَاغَارْ ثَامخْسِيوْثْ نّسْ إِشوَّارنْ  
\m ثتّْغِيمَا إِ ڒبْذَا. \x ◘ \xo 136:‏16 \xt ؤُف. 15، 16، 17، 19؛ إِزهد. 78‏:‏53\x*   
\m
\v 17 ... ونِّي إِوْثِينْ إِجدْجِيذنْ إِمقّْرَاننْ،  
\m مَاغَارْ ثَامخْسِيوْثْ نّسْ إِشوَّارنْ  
\m ثتّْغِيمَا إِ ڒبْذَا، \x ◘ \xo 136:‏17 \xt ڒخْڒ. 21‏:‏24، 25، 34، 35؛ ياش. 12‏:‏1؛ إِزهد. 135‏:‏10، 11\x*   
\m
\v 18 ؤُشَا إِنْغَا إِجدْجِيذنْ إِجهْذنْ،  
\m مَاغَارْ ثَامخْسِيوْثْ نّسْ إِشوَّارنْ  
\m ثتّْغِيمَا إِ ڒبْذَا.   
\b  
\m
\v 19 \add عْقڒْ خْ\add* سِيحُونْ، أَجدْجِيذْ ن إِمُورِييّنْ،  
\m مَاغَارْ ثَامخْسِيوْثْ نّسْ إِشوَّارنْ  
\m ثتّْغِيمَا إِ ڒبْذَا،   
\m
\v 20 خْ عُوجْ، أَجدْجِيذْ ن بَاشَانْ،  
\m مَاغَارْ ثَامخْسِيوْثْ نّسْ إِشوَّارنْ  
\m ثتّْغِيمَا إِ ڒبْذَا. \x ◘ \xo 136:‏20 \xt أَعَوذ. 3‏:‏1‏-‏7\x*   
\m
\v 21 ثَامُّورْثْ نْسنْ إِوْشَا إِ-ت ذ ثَاسْغَارْثْ،  
\m مَاغَارْ ثَامخْسِيوْثْ نّسْ إِشوَّارنْ  
\m ثتّْغِيمَا إِ ڒبْذَا، \x ◘ \xo 136:‏21 \xt ياش. 12‏:‏6\x*   
\m
\v 22 ذ ثَاسْغَارْثْ إِ ؤُمْسخَّارْ نّسْ إِسْرَائِيل،  
\m مَاغَارْ ثَامخْسِيوْثْ نّسْ إِشوَّارنْ  
\m ثتّْغِيمَا إِ ڒبْذَا.   
\b  
\m
\v 23 إِذَارْ أَنغْ ذِي دّدْجْ نّغْ،  
\m مَاغَارْ ثَامخْسِيوْثْ نّسْ إِشوَّارنْ  
\m ثتّْغِيمَا إِ ڒبْذَا.   
\m
\v 24 نتَّا إِكّسْ أَنغْ-د زڭْ \add إِفَاسّنْ\add*  
\m \add ن\add* يِينِّي ذ أَنغْ إِحْصَارنْ،  
\m مَاغَارْ ثَامخْسِيوْثْ نّسْ إِشوَّارنْ  
\m ثتّْغِيمَا إِ ڒبْذَا.   
\m
\v 25 نتَّا ذ ونِّي إِتِّيشنْ مَاشَّا  
\m إِ مَارَّا إِمُودَّارنْ،  
\m مَاغَارْ ثَامخْسِيوْثْ نّسْ إِشوَّارنْ  
\m ثتّْغِيمَا إِ ڒبْذَا. \f ◼ \fr 136:‏25 \ft \+bd ’مَارَّا إِنِّي إِدَّارنْ‘\+bd* - س ثْعِيبْرَانِيثْ ’إِ مَارَّا أَيْسُومْ‘، إِخْسْ أَذْ يِينِي إِ مَارَّا إِوْذَانْ ؤُ إِ مَارَّا إِمُودَّارنْ (لْحَايَاوَانَاثْ).\f*   
\m
\v 26 قَاذَامْ أَربِّي ن إِجنْوَانْ،  
\m مَاغَارْ ثَامخْسِيوْثْ نّسْ إِشوَّارنْ  
\m ثتّْغِيمَا إِ ڒبْذَا.   
\b  
\b  
\m  
\c 137
\m
\v 1 غَارْ إِغزْرَانْ ن بَابِيلْ،  
\m ذِينِّي إِ ثُوغَا نتّْغِيمَا،  
\m نْرُو عَاوذْ خْمِي ثُوغَا نتِّيذَارْ صِيهْيُونْ.   
\m
\v 2 نُويڒْ ڒْڭَامْبْرِييَاثْ نّغْ  
\m غَارْ إِصفْصَافنْ \add إِ إِدْجَانْ\add* ذِي ڒْوسْثْ نّسْ.   
\b  
\m
\v 3 مَاغَارْ إِنِّي ذ أَنغْ إِحبّْسنْ  
\m تَّارنْ زَّايْنغْ ذِينِّي  
\m \add أَذْ نْغنّجْ\add* أَوَاڒنْ ن إِجّْ ن يزْڒِي،  
\m إِنِّي ذ أَنغْ إِحصَّارنْ  
\m تَّارنْ شَا ن ڒْحَاجّثْ إِسّفْرَاحنْ.  
\m \add نِيثْنِي نَّانْ\add*: ”غنّْجمْ زعْمَا  
\m \add إِجّْ زڭْ\add* إِزْڒَانْ ن صِيهْيُونْ إِ نشِّينْ!“ \x ◘ \xo 137:‏3 \xt إِزهد. 79‏:‏1 \x*   
\b  
\m
\v 4 مَامّشْ نْزمَّارْ أَذْ نْغنّجْ  
\m إِجّْ ن يزْڒِي ن سِيذِي ذِي ثمُّورْثْ ن مِيدّنْ؟   
\m
\v 5 مَاڒَا نشّْ تُّوغْ شمْ، \add أَ\add* ؤُرْشَالِيمْ،  
\m أجّْ \add خنِّي\add* أَذْ إِتُّو ؤُفُوسْ أَفُوسِي إِخفْ نّسْ.   
\b  
\m
\v 6 أجّْ أَذْ أَيِي إِڒْصقْ إِڒسْ إِنُو خْ وَانغْ إِنُو،  
\m مَاڒَا وَارْ شمْ تِّيذَارغْ،  
\m مَاڒَا وَارْ سّْعُودْجِيغْ ؤُرْشَالِيمْ  
\m خْ ڒفْرَاحثْ إِنُو ثَامقّْرَانْثْ قَاعْ.   
\b  
\m
\v 7 \add أَ\add* سِيذِي، عْقڒْ خْ أَيْثْ ن إِذُومْ،  
\m \add ذڭْ\add* وَاسّْ ن ؤُرْشَالِيمْ،  
\m إِنِّي إِقَّارنْ: ”عَارَّامْ \add ت\add*، عَارَّامْ \add ت\add*،  
\m أَڒْ ذْسَاسْ نّسْ!“ \x ◘ \xo 137:‏7 \xt إِرْم. 49‏:‏7؛ حِز. 25‏:‏12\x*   
\b  
\m
\v 8 \add أَ\add* يدْجِيسْ ن بَابِيلْ،  
\m \add شمْ\add* ثنِّي إِتّْوَاسّْحُوزنْ إِ وَاردّدْجْ،  
\m سّعْذْ ن يِينِّي ذ أَمْ  
\m إِ غَا إِخدْجْصنْ ثَامڭِّيثْ \add إِعفّْننْ\add*  
\m إِ ذَايْنغْ ثڭِّيذْ. \x ◘ \xo 137:‏8 \xt إِرْم. 50‏:‏15، 29؛ أَسَا. 18‏:‏6\x*   
\m
\v 9 سّعْذْ ن ونِّي إِ غَا إِطّْفنْ  
\m إِحنْجِيرنْ نْومْ إِمژْيَاننْ،  
\m أَذْ ثنْ إِڒْبزْ خْ ثصْضَارْثْ. \x ◘ \xo 137:‏9 \xt إِشا. 13‏:‏16\x*   
\b  
\b  
\m  
\c 138
\m
\v 1 \add ن ذَاوُوذْ.\add*  
\b  
\m أَذْ شكْ قَاذِيغْ س مَارَّا ؤُڒْ إِنُو،  
\m أَذْ شكْ زهّْذغْ زَّاثْ إِ إِربِّيثنْ.   
\m
\v 2 أَذْ بنْذْقغْ غَارْ زَّاوشْثْ نّشْ  
\m ثَامقّْرَانْثْ إِقدّْسنْ،  
\m أَذْ قَاذِيغْ إِسمْ نّشْ  
\m خْ ثْمخْسِيوْثْ نّشْ إِشوَّارنْ  
\m ؤُ خْ ڒَامَانْ نّشْ،  
\m مَاغَارْ شكْ ثسّمْغَارذْ  
\m أَوَاڒْ نّشْ خْ مَارَّا  
\m \add مِينْ إِتّْوَافنْ عَاذْ\add*  
\m \add ذڭْ\add* يِيسمْ نّشْ.   
\b  
\m
\v 3 ذڭْ وَاسّْ ڒَامِي خَاكْ د-ڒَاغِيغْ،  
\m ثَارِّيذْ-د خَافِي،  
\m شكْ ثوْشِيذْ جّهْذْ إِ ڒعْمَارْ إِنُو.   
\m
\v 4 مَارَّا إِجدْجِيذنْ ن ثمُّورْثْ  
\m أَذْ شكْ قَاذَانْ، \add أَ\add* سِيذِي،  
\m خْمِي تّسْڒَانْ أَوَاڒنْ  
\m زڭْ ؤُقمُّومْ نّشْ.   
\m
\v 5 أَذْغنّْجنْ خْ إِبْرِيذنْ ن سِيذِي،  
\m مَاغَارْ أَعُودْجِي ن سِيذِي ذ أَمقّْرَانْ.   
\m
\v 6 مَاغَارْ وَاخَّا إِتّْوَاسُّوعْڒَا سِيذِي أَطَّاسْ،  
\m \add عَاذْ\add* إِخزَّارْ-د غَارْ ؤُمْوَاضعْ،  
\m \add مَاشَا\add* بُو-نّْفَاخثْ إِسّنْ إِ-ث زِي ڒَاڭّْوَاجْ. \x ◘ \xo 138:‏6 \xt إِزهد. 113‏:‏6، 7\x*   
\b  
\m
\v 7 مَاڒَا ؤُيُورغْ ذِي ڒْوسْطْ ن ڒحْصَارثْ،  
\m أَذْ أَيِي د-ثتَّارّذْ غَارْ ثُوذَارْثْ.  
\m شكْ ثسّْوِيژّْضذْ أَفُوسْ نّشْ  
\m ضِيدّْ إِ وغْضَابْ ن ڒْعذْيَانْ إِنُو،  
\m أَفُوسْ نّشْ أَفُوسِي إِسّنْجمْ أَيِي.   
\m
\v 8 سِيذِي أَذْ ث إِكمّڒْ إِ نشّْ.  
\m \add أَ\add* سِيذِي، ثَامخْسِيوْثْ نّشْ إِشوَّارنْ  
\m ثتّْغِيمَا إِ ڒبْذَا،  
\m ڒفْعَايڒْ ن إِفَاسّنْ نّشْ  
\m وَارْ ثنْ ثَارخُّوذْ.   
\b  
\b  
\m  
\c 139
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. ن ذَاوُوذْ. أَزهّذْ.\add*  
\b  
\m \add أَ\add* سِيذِي، شكْ ثْبقّْشذْ أَيِي ؤُ ثسّْنذْ أَيِي.   
\m
\v 2 شكْ ثسّْنذْ أَغِيمِي إِنُو ذ ؤُبذِّي إِنُو،  
\m زِي ڒَاڭّْوَاجْ ثْفهّْمذْ إِخَارِّيصنْ إِنُو.   
\m
\v 3 خْمِي ڭُّورغْ ؤُ خْمِي طّْصغْ ثَارزُّوذْ ذَايِي،  
\m أَقَا شكْ ثسّْنذْ مَارَّا إِبْرِيذنْ إِنُو.   
\m
\v 4 مِينْزِي وَارْ ذِينْ ؤُڒَا ذ إِجّْ ن وَاوَاڒْ  
\m خْ يِيڒسْ إِنُو، ؤُ خْزَارْ،  
\m شكْ أَ سِيذِي، ثسّْنذْ ث كُوڒْشِي.   
\m
\v 5 شكْ ثْحصَّارذْ أَيِي زِي ضفَّارْ ؤُ زِي زَّاثْ،  
\m ثسَّارْسذْ خَافِي ثَاڒقَّا ن ؤُفُوسْ نّشْ.   
\m
\v 6 ثُوسّْنَا-يَا ذ أَثبْهثْ إِ نشّْ،  
\m ثُوعْڒَا خَافِي، وَارْ زمَّارغْ أَذْ ت أَوْضغْ.   
\m
\v 7 غَارْ مَانِي \add زمَّارغْ\add*  
\m أَذْ رَاحغْ زِي أَرُّوحْ نّشْ،  
\m غَارْ مَانِي غَا أَروْڒغْ زڭْ وُوذمْ نّشْ؟   
\m
\v 8 مَاڒَا ڭعّْذغْ غَارْ ؤُجنَّا،  
\m أَقَا شكْ ذِينِّي،  
\m \add مَاڒَا\add* ڭِّيغْ ڒَاخَارْثْ ذ ثَاسُّوثْ إِنُو، خْزَارْ،  
\m أَقَا شكْ ؤُڒَا ذِينِّي، \x ◘ \xo 139:‏8 \xt أَيُوبْ 26‏:‏6؛ عَام. 9‏:‏2، 3، 4؛ عبر. 4‏:‏13\x*   
\m
\v 9 \add مَاڒَا\add* كْسِيغْ أَفْرِيونْ \add أَمْ ثْفَاوْثْ ن\add* ڒفْجَارْ،  
\m أَذْ زذْغغْ غَارْ ؤُنڭَّارْ قَاعْ ن ڒبْحَارْ، \f ◼ \fr 139:‏9 \ft \+bd ’ڒبْحَارْ‘\+bd* - نِيغْ ’إِلْ‘.\f*   
\m
\v 10 \add خنِّي\add* ؤُڒَا ذِينِّي أَذْ أَيِي إِنْذهْ ؤُفُوسْ نّشْ،  
\m \add أَفُوسْ نّشْ\add* أَفُوسِي أَذْ أَيِي إِطّفْ.   
\m
\v 11 مَاڒَا نِّيغْ: ”إِوَا ثَادْجسْثْ، وْضَا-د خَافِي،  
\m \add خنِّي\add* دْجِيڒثْ ذ ثْفَاوْثْ إِ ذ أَيِي إِقُووَّارنْ.   
\m
\v 12 إِ شكْ ثَادْجسْثْ وَارْ ثدْجِي ذ طّْڒَامْ،  
\m \add إِ شكْ\add* دْجِيڒثْ ثتّڭّْ ثْفَاوْثْ أَمْ ؤُزِيڒْ،  
\m \add إِ شكْ\add* ثَادْجسْثْ \add أَقَا-ت\add* أَمْ ثْفَاوْثْ.   
\b  
\m
\v 13 \add وَاهْ،\add* شكْ ثْخڒْقذْ-د ثِيژَّاڒْ إِنُو،  
\m ثْمُوذذْ أَيِي ذڭْ ؤُعذِّيسْ ن يمَّا.   
\m
\v 14 قَاذِيغْ شكْ ؤُمِي د-تّْوَاخڒْقغْ  
\m زڭْ إِشْثْ ن ثبْرِيذْثْ ن ڒعْجبْ ذ ثَامقّْرَانْثْ.  
\m ثِيمڭَّا نّشْ ذ لْمُوعْجِيزَاثْ،  
\m ڒعْمَارْ إِنُو ثسّنْ ث \add مْلِيحْ\add* قَاعْ.   
\m
\v 15 إِخْسَانْ إِنُو ثُوغَا وَارْ خَاكْ نُّوفَّارنْ،  
\m ؤُمِي تّْوَاڭّغْ س ثْنُوفّْرَا،  
\m تّْوَامُوذغْ \add أَمْ إِجّْ ن ؤُبُورْضَا\add*  
\m ذِي ڒَادْجَاغْ ن ثمُّورْثْ. \x ◘ \xo 139:‏15 \xt أَيُوبْ 10‏:‏8، 10؛ أَمب. 11‏:‏5 \x*   
\m
\v 16 ثِيطَّاوِينْ نّشْ ژْرِينْثْ  
\m أَبدُّو إِنُو إِضفْصنْ.  
\m ذڭْ وذْلِيسْ نّشْ إِتّْوَانّْضنْ  
\m أَقَا مَارَّا يُورَانْ،  
\m أَقَا ؤُسَّانْ إِ ثُوغَا تّْوَاڭّنْ،  
\m جَارْ أَسنْ \add ؤُڒَا ذ أَسّْ\add* أَمزْوَارُو  
\m \add ن ؤُبدُّو إِنُو\add*.   
\m
\v 17 مَامّشْ غَارِي تّْعِيزَّانْ  
\m إِخَارِّيصنْ نّشْ، \add أَ\add* أَربِّي،  
\m مَامّشْ إِمْغَارْ ؤُبَارُّو نْسنْ!   
\m
\v 18 مَاڒَا خْسغْ أَذْ ثنْ حسْبغْ،  
\m أَقَا أَثنْ كْثَارْ أَطَّاسْ زڭْ يجْذِي،  
\m \add ؤُ\add* خْمِي فَاقغْ، أَقَا أَيِي عَاذْ أَكِيذكْ.   
\b  
\m
\v 19 \add أَ\add* أَربِّي، معْلِيكْ إِ غَا ثنْغذْ أَعفَّانْ،  
\m \add معْلِيكْ\add* إِ غَا ثجّذْ إِرْيَازنْ  
\m إِ إِسَّازَّاڒنْ إِذَامّنْ  
\m أَذْ خَافِي أَڭّْوجّنْ،   
\m
\v 20 إِنِّي خَاكْ إِسَّاوَاڒنْ س ثْحْرَايْمشْثْ،  
\m ڒْعذْيَانْ نّشْ  
\m إِنِّي إِنطّْقنْ \add إِسمْ نّشْ\add* ذِي ڒْبَاطڒْ. \x ◘ \xo 139:‏20 \xt ؤُف.20‏:‏7\x*   
\m
\v 21 \add أَ\add* سِيذِي، مَا وَارْ شَارّْهغْ  
\m إِنِّي شكْ إِشَارّْهنْ،  
\m ؤُ مَا وَارْ تّْعِيفّغْ  
\m إِنِّي أَكِيذكْ إِتّمْعَاڒَانْ؟   
\m
\v 22 نشّْ شَارّْهغْ ثنْ  
\m س إِجّْ ن وشْرَاهْ إِكْمڒْ،  
\m أَقَا نِيثْنِي ذوْڒنْ أَيِي ذ ڒْعذْيَانْ.   
\m
\v 23 أَرْزُو خَافِي، \add أَ\add* أَربِّي، سّنْ ؤُڒْ إِنُو،  
\m قدْجبْ أَيِي ؤُ سّنْ إِخَارِّيصنْ إِنُو. \x ◘ \xo 139:‏23 \xt أَيُوبْ 31‏:‏6؛ إِزهد. 26‏:‏2\x*   
\m
\v 24 خْزَارْ-د، مَا أَقَا أَيِي  
\m ذِي شَا ن وبْرِيذْ ن ڒقْجَاحثْ  
\m ؤُ نْذهْ أَيِي غَارْ وبْرِيذْ ن ڒبْذَا.   
\b  
\b  
\m  
\c 140
\m
\v 1 \add إِ ؤُمقّْرَانْ ن إِمغْنَاجنْ. أَزهّذْ ن ذَاوُوذْ.\add*   
\b  
\m
\v 2 فكّْ أَيِي زِي بْنَاذمْ ذ أَعفَّانْ، \add أَ\add* سِيذِي،  
\m حْضَا أَيِي زڭْ ورْيَازْ ن لْعُونْفْ،   
\m
\v 3 زڭْ يِينِّي إِتّْخَارَّاصنْ  
\m ذڭْ وُوڒْ \add نْسنْ\add* ذِي ڒْغَارْ،  
\m \add ؤُ\add* سّكَّارنْ إِمنْغَانْ ذِي مَارَّا ؤُسَّانْ.   
\m
\v 4 نِيثْنِي سّْقضْعنْ إِڒْسَاونْ نْسنْ  
\m أَمْ يِيجّْ ن ؤُفِيغَارْ،  
\m سّمْ إِحْمَا أَقَا-ث سَاذُو إِينْشِيشنْ نْسنْ.  
\m سِيلَاهْ. \x ◘ \xo 140:‏4 \xt إِزهد. 58‏:‏5؛ رُوم. 3‏:‏13\x*   
\b  
\m
\v 5 حْضَا خَافِي، \add أَ\add* سِيذِي، زڭْ إِفَاسّنْ ن إِعفَّاننْ،  
\m حْضَا أَيِي زڭْ إِرْيَازنْ ن لْعُونْفْ،  
\m إِنِّي يَارزُّونْ أَذْ أَيِيغضْڒنْ  
\m غَارْ ثمُّورْثْ. \f ◼ \fr 140:‏5 \ft \+bd ’إِنِّي يَارزُّونْ أَذْ أَيِي غضْڒنْ غَارْ ثمُّورْثْ‘\+bd* - س ثْعِيبْرَانِيثْ ’إِنِّي يَارزُّونْ أَذْ سّْنقْرَاذنْ إِضَارنْ إِنُو‘.\f*   
\m
\v 6 أَيْثْ ن بُو-نّْفَاخثْ  
\m سّْنُوفَّارنْ خَافِي إِجّْ ن ڒْفخْ،  
\m تّْبزَّاعنْ ثِيسغْوِينْ  
\m أَمْ يِيشْثْ ن ثْرَاشَّا  
\m غَارْ ؤُغزْذِيسْ ن ؤُمسْرَاقْ،  
\m أَقَا تّڭّنْ أَيِي ثِيخفْشِينْ. سِيلَاهْ. \x ◘ \xo 140:‏6 \xt إِرْم. 18‏:‏22\x*   
\b  
\m
\v 7 نشّْ نِّيغْ إِ سِيذِي: ”شكْ ذ أَربِّي إِنُو!“  
\m سڒْ، \add أَ\add* سِيذِي، غَارْ ثْمِيجَّا ن ثُوثْرَا إِنُو.   
\m
\v 8 \add أَ\add* سِيذِي، سِيذِي إِنُو، جّهْذْ ن ؤُسنْجمْ إِنُو،  
\m ذڒْ أَزدْجِيفْ إِنُو ذڭْ وَاسّْ ن \add ڒْْحسّْ\add* ن ڒسْنَاحْ.   
\m
\v 9 \add أَ\add* سِيذِي، وَارْ تّجِّي أَعفَّانْ أَذْ يَارّْ مژْرِي.  
\m وَارْ تّڭّْ تَّاسِيعْ إِ ونْوَايْ نّسْ إِعفّْننْ،  
\m أَڒَامِي غَا سّْعُودْجنْ إِخفْ نْسنْ. سِيلَاهْ.   
\b  
\m
\v 10 \add خْ\add* ؤُزدْجِيفْ ن \add مَارَّا\add* إِنِّي ذ أَيِي د-إِنّْضنْ،  
\m إِڒِي أَذْ ثنْ إِذڒْ ؤُشقّفْ ن إِينْشِيشنْ نْسنْ،   
\m
\v 11 أجّْ أَذْ خَاسنْ كبّنْ ڒفْحمْ،  
\m \add إِڒِي\add* نتَّا أَذْ ثنْ إِغْضرْ ذِي ثْمسِّي،  
\m ذِي ڒْحمْڒَاثْ يُودْجْغنْ،  
\m حِيمَا وَارْ تّكَّارنْ عَاذْ.   
\m
\v 12 أجّْ أَرْيَازْ \add إِ إِشقّْفنْ\add* س يِيڒسْ  
\m وَارْ إِتّْغِيمِي إِبدّْ خْ ثمُّورْثْ،  
\m أجّْ أَذْ إِعَارْنْ ڒْغَارْ ذغْيَا  
\m أَرْيَازْ بُو-ڒخْشُونثْ.   
\b  
\m
\v 13 نشّْ سّْنغْ، أَقَا سِيذِي أَذْ إِسّقْفڒْ  
\m دّعْوثْ ن ڒْمُوسَاكِينْ، ڒْحقّْ ن إِمزْڒَاضْ.   
\m
\v 14 س ثِيذتّْ، إِمْسڭَّاذنْ  
\m أَذْ قَاذَانْ إِسمْ نّشْ،  
\m إِنِّي إِڭُّورنْ نِيشَانْ أَذْ قِّيمنْ  
\m زَّاثْ إِ وُوذمْ نّشْ.   
\b  
\b  
\m  
\c 141
\m
\v 1 \add أَزهّذْ ن ذَاوُوذْ.\add*  
\b  
\m \add أَ\add* سِيذِي، نشّْ تّْڒَاغِيغْ غَاركْ،  
\m ذغْيَاثْ غَارِي،  
\m سڒْ غَارْ ثْمِيجَّا إِنُو  
\m خْمِي د خَاكْ إِ غَا تّْڒَاغِيغْ.   
\m
\v 2 إِڒِي أَذْ ثْبدّْ ثْژَادْجِيثْ إِنُو  
\m أَمْ ڒبْخُورْ \add إِتّْفُوحنْ\add* زَّاثْ إِ وُوذمْ نّشْ،  
\m ؤُڒَا ذ أَسْڭعّذْ ن إِفَاسّنْ إِنُو  
\m أَمْ ثوْهِيبْثْ ن ثْمذِّيثْ. \x ◘ \xo 141:‏2 \xt ؤُف. 29‏:‏30؛ ڒخْڒ. 28‏:‏1‏-‏8؛ أَسَا. 5‏:‏8؛ 8‏:‏3\x*   
\b  
\m
\v 3 \add أَ\add* سِيذِي، أڭّْ إِجّْ ن ؤُعسَّاسْ  
\m غَارْ ؤُقمُّومْ إِنُو،  
\m حْضَا ثَاوَّارْثْ ن إِينْشِيشنْ إِنُو.   
\m
\v 4 أڭّْ أَقَا ؤُڒْ إِنُو وَارْ إِتّْنجْبِيذْ  
\m غَارْ إِشْثْ ن ثْمسْڒَاشْثْ ذ ثَاعفَّانْثْ،  
\m مَاحنْذْ أَذْ ڭّغْ ثِيمڭَّا س ڒْغشّْ  
\m أَكْ-ذ إِرْيَازنْ نِّي إِتّڭّنْ ڒْمُوعْصِييّثْ،  
\m أڭّْ أَقَا نشّْ وَارْ تّتّغْ  
\m زِي ثَازْيُوضِي نْسنْ.   
\b  
\m
\v 5 أجّْ أَمْسڭّذْ أَذْ أَيِي إِوّثْ،  
\m \add مَاغَارْ أَيَا\add* ذ ثَامخْسِيوْثْ إِشوَّارنْ،  
\m مَاڒَا نتَّا إِتّْسڭّذْ أَيِي،  
\m أَيَا ذ زّشْثْ خْ ؤُزدْجِيفْ إِنُو،  
\m أَذْ ت إِقْبڒْ ؤُزدْجِيفْ إِنُو.  
\m \add وَاهْ\add*، ؤُڒَا أَمُّو أَذْ ثِيڒِي ثْژَادْجِيثْ إِنُو عَاذْ  
\m ضِيدّْ إِ ثْمڭَّا نْسنْ إِعفّْننْ. \f ◼ \fr 141:‏5 \ft \+bd ’ضِيدّْ إِ ثْمڭَّا نْسنْ‘\+bd* - إِخْسْ أَذْ يِينِي: ضِيدّْ إِ ثْمڭَّا إِعفّْننْ ن يرْيَازنْ نِّي إِتّڭّنْ ڒْمُوعْصِييّثْ (نُّومْرَا 4).\f*   
\m
\v 6 ڒْقُوضَاثْ نْسنْ مّنْضَارنْ سْوَادَّايْ  
\m خْ ؤُغزْذِيسْ ن جَّارْفْ،  
\m أَقَا سْڒِينْ بلِّي أَوَاڒنْ إِنُو ضَارْفنْ.   
\m
\v 7 أَخْمِي ثتّْوَاشَارْزْ  
\m ؤُ ثنُّورْزمْ ثمُّورْثْ،  
\m أَمُّو إِ تّْوَازدْجْعنْ إِغْسَانْ نّغْ  
\m غَارْ ؤُقمُّومْ ن ڒَاخَارْثْ. \x ◘ \xo 141:‏7 \xt حِز. 37‏:‏1، 11، 12\x*   
\b  
\m
\v 8 مَاشَا ثِيطَّاوِينْ إِنُو  
\m خزَّارنْثْ-إِ-د غَاركْ،  
\m \add أَ\add* سِيذِي، سِيذِي إِنُو،  
\m نشّْ أَركّْوَاڒغْ غَاركْ،  
\m وَارْ تّجِّي ڒعْمَارْ إِنُو يَارْخفْ.   
\m
\v 9 سِيڭّْوجْ أَيِي إِ ومْنَاعْ ن ڒْفخْ  
\m إِ ذ أَيِي مذْينْ،  
\m زِي ثخْشِيفِينْ ن يِينِّي إِتّڭّنْ ڒْمُوعْصِييّثْ.   
\m
\v 10 إِڒِي إِعفَّاننْ أَذْ وْضَانْ مَارَّا  
\m ذِي ثْرَاشَّاوِينْ نْسنْ،  
\m مِينْ غَا كّغْعدُّوغْ.   
\b  
\b  
\m  
\c 142
\m
\v 1 \add أَخمِّي ن ذَاوُوذْ.\add*  
\m ثَاژَادْجِيثْ ؤُمِي ث ثُوغَا ذڭْ يفْرِي.   
\b  
\m
\v 2 س ثْمِيجَّا إِنُو سْغُويغْ غَارْ سِيذِي،  
\m س ثْمِيجَّا إِنُو حشّْمغْ سِيذِي.   
\m
\v 3 نشّْ تّْزدْجَاعغْ إِفقُّوصنْ إِنُو  
\m زَّاثْ إِ وُوذمْ نّسْ،  
\m سَّارْڭْبغْ \add أَسْ\add* ڒحْصَارثْ إِنُو  
\m زَّاثْ إِ وُوذمْ نّسْ.   
\m
\v 4 مَاڒَا بُوحْبڒْ إِنُو إِذْقڒْ خَافِي أَطَّاسْ،  
\m شكْ ثسّْنذْ أَمسْرُوقْ إِنُو.  
\b  
\m نِيثْنِي سّْنُوفَّارنْ أَيِي إِجّْ ن ڒْفخْ  
\m ذڭْ وبْرِيذْ نِّي ذِي غَا ؤُيُورغْ. \x ◘ \xo 142:‏4 \xt إِزهد. 77‏:‏4\x*   
\m
\v 5 سْوضْ غَارْ ؤُفُوسِي، ؤُ خْزَارْ،  
\m وَارْ ذِينْ ثُوغِي حذْ  
\m إِ ذ أَيِي غَا إِوْشنْ ثَايْنِيثْ،  
\m إِتّْوَاكّسْ أَيِي قَاعْ مَانِي غَا أَروْڒغْ،  
\m وَارْ ذِينْ ثُوغِي ؤُڒَا ذ إِجّْ  
\m إِ غَا إِسّقْسَانْ خْ ڒعْمَارْ إِنُو.   
\m
\v 6 نشّْ سْغُويُّوغْ-د غَاركْ، \add أَ\add* سِيذِي. قَّارغْ:  
\m ”شكْ ذ أَمْشَانْ إِنُو ن ثَاروْڒَا،  
\m ثَاسْغَارْثْ إِنُو ذِي ثمُّورْثْ ن يِينِّي إِدَّارنْ.\x ◘ \xo 142:‏6 \xt إِزهد. 16‏:‏5\x*   
\b  
\m
\v 7 حْضَا خْ ؤُغُويِّي إِنُو، مَاغَارْ فْنِيغْ قَاعْ.  
\m فكّْ أَيِي زڭْ إِنِّي ذ أَيِي إِضفَّارنْ،  
\m مَاغَارْ نِيثْنِي جهْذنْ خَافِي. \x ◘ \xo 142:‏7 \xt إِزهد. 41‏:‏2؛ 79‏:‏8؛ 116‏:‏6\x*   
\m
\v 8 سُوفّغْ ڒعْمَارْ إِنُو زِي ڒحْبسْ  
\m مَاحنْذْ أَذْ قَاذِيغْ إِسمْ نّشْ.  
\m إِمْسڭَّاذنْ أَذْ أَيِي د-نّْضنْ،  
\m مَاغَارْ شكْ ثتّڭّذْ ذَايِي س ثْشُونِي.“   
\b  
\b  
\m  
\c 143
\m
\v 1 \add أَزهّذْ ن ذَاوُوذْ.\add*  
\b  
\m \add أَ\add* سِيذِي، سڒْ إِ ثْژَادْجِيثْ إِنُو،  
\m سْحسّْ إِ ثُوثْرَا إِنُو.  
\m أَرّْ-د خَافِي عْلَاحْسَابْ ثِيذتّْ نّشْ،  
\m عْلَاحْسَابْ ثَاسڭْذَا نّشْ.   
\m
\v 2 وَارْ تّڭّْ شّْرعْ أَكْ-ذ ؤُمْسخَّارْ نّشْ،  
\m مَاغَارْ ؤُڒَا ذ إِجّْ زڭْ إِنِّي إِدَّارنْ  
\m أَذْ يِيڒِي ذ أَمْسڭّذْ زَّاثْ إِ وُوذمْ نّشْ. \x ◘ \xo 143:‏2 \xt رُوم. 3، 4؛ ڭال. 3، 4 \x*   
\m
\v 3 مِينْزِي ڒعْذُو إِتّْذَارَّاشْ ڒعْمَارْ إِنُو،  
\m إِعفّسْ خْ ثُوذَارْثْ إِنُو غَارْ ثمُّورْثْ،  
\m إِسّْزدّغْ أَيِي ذڭْ إِمُوشَانْ ن طّْڒَامْ،  
\m أَمْ يِينِّي إِمُّوثنْ زِي مشْحَاڒْ ؤُيَا.   
\b  
\m
\v 4 بُوحْبڒْ إِنُو إِتّفْشِيڒْ خَافِي،  
\m ؤُڒْ إِنُو يَاروّعْ ذِي ذَاخڒْ إِنُو.   
\m
\v 5 نشّْ تّْعقْڒغْ خْ وُوسَّانْ إِعْذُونْ،  
\m تّْخمَّامغْ ذِي مَارَّا ثِيمڭَّا نّشْ،  
\m تّْخَارّْصغْ ذِي ڒفْعَايڒْ ن إِفَاسّنْ نّشْ. \x ◘ \xo 143:‏5 \xt إِزهد. 77‏:‏6، 11\x*   
\m
\v 6 نشّْ تّْبزّْعغْ إِفَاسّنْ إِنُو غَاركْ،  
\m ڒعْمَارْ إِنُو أَقَا-ث زَّاثكْ  
\m أَمْ إِشْثْ ن ثمُّورْثْ إِفُّوذنْ. سِيلَاهْ.   
\b  
\m
\v 7 أَرّْ-د خَافِي ذغْيَا، \add أَ\add* سِيذِي،  
\m بُوحْبڒْ إِنُو إِتّفْشِيڒْ،  
\m وَارْ سّْنُوفَّارَا ؤُذمْ نّشْ زَّايِي،  
\m مَاحنْذْ وَارْ دِّيكّْوِيڒغْ  
\m أَمْ يِينِّي د-إِهكّْوَانْ  
\m ذڭْ وحْفُورْ \add ن ونْضڒْ\add*.   
\m
\v 8 أجّْ أَيِي أَذْ سْڒغْ  
\m إِ ثْمخْسِيوْثْ نّشْ إِشوَّارنْ  
\m غَارْ ثفُّوثْ،  
\m مَاغَارْ تّشْڒغْ خَاكْ.  
\m سْشنْ أَيِي أَبْرِيذْ إِ غَا ؤُيُورغْ،  
\m مَاغَارْ سّْڭعّْذغْ ڒعْمَارْ إِنُو غَاركْ. \x ◘ \xo 143:‏8 \xt إِزهد. 25‏:‏1\x*   
\b  
\m
\v 9 \add أَ\add* سِيذِي، كّسْ أَيِي إِ ڒْعذْيَانْ إِنُو،  
\m غَاركْ إِ غَا أَروْڒغْ.   
\m
\v 10 سڒْمذْ أَيِي أَذْ ڭّغْ  
\m \add مِينْ إِدْجَانْ\add* إِ أَرْضَا نّشْ،  
\m مَاغَارْ شكْ ذ أَربِّي إِنُو.  
\m أجّْ أَرُّوحْ نّشْ إِصبْحنْ أَذْ أَيِي إِنْذهْ  
\m ذڭْ إِشْثْ ن ثمُّورْثْ إِوَاطَانْ.   
\m
\v 11 \add أَ\add* سِيذِي، أَرّْ-د ذَايِي ثُوذَارْثْ  
\m ذِي طّْوعْ ن يِيسمْ نّشْ.  
\m س ثْسڭْذَا نّشْ،  
\m سُوفّغْ ڒعْمَارْ إِنُو زِي ڒحْصَارثْ،   
\m
\v 12 أَردّدْجْ ڒْعذْيَانْ إِنُو  
\m ذِي ثْمخْسِيوْثْ نّشْ إِشوَّارنْ،  
\m قْضَا خْ مَارَّا إِنِّي ذ أَيِي إِحصَّارنْ،  
\m مَاغَارْ نشّْ ذ ؤُمْسخَّارْ نّشْ. \x ◘ \xo 143:‏12 \xt إِزهد. 86‏:‏16؛ 116‏:‏16\x*   
\b  
\b  
\m  
\c 144
\m
\v 1 \add ن ذَاوُوذْ.\add*  
\b  
\m أَذْ إِتّْوَابَاركْ سِيذِي، ثَاصْضَارْثْ إِنُو،  
\m ونِّي إِسّڒْمَاذنْ إِفَاسّنْ إِنُو إِ ؤُمنْغِي،  
\m إِضوْضَانْ إِنُو إِ ڒْحَارْبْ. \x ◘ \xo 144:‏1 \xt 2 صم. 22‏:‏35؛ إِزهد. 18‏:‏35\x*   
\m
\v 2 \add شكْ إِ ذ أَيِي ثدْجِيذْ\add* ذ أَمدُّوكّڒْ إِنُو  
\m إِ ذَايسْ ثَامخْسِيوْثْ إِشوَّارنْ،  
\m ؤُڒَا ذ لْبُورْجْ إِنُو، لْبُورْجْ إِنُو يُوعْڒَانْ  
\m ذ أَمْسنْجمْ إِنُو،  
\m ثَاسدَّارْثْ إِنُو إِ ؤُسڒْقِي،  
\m ذ ونِّي غَارْ أَركّْوَاڒغْ،  
\m ذ ونِّي ذ أَيِي إِسّْوَاضْضْعنْ ڒْڭنْسْ إِنُو. \x ◘ \xo 144:‏2 \xt 2 صم. 22‏:‏48؛ إِزهد. 18‏:‏48\x*   
\b  
\m
\v 3 \add أَ\add* سِيذِي، مِينْ إِعْنَا بْنَاذمْ،  
\m أَقَا شكْ ثخْسذْ أَذْ ث ثسّْنذْ؟  
\m مِّيسْ ن بْنَاذمْ،  
\m أَقَا شكْ ثتّْخَارِّيصذْ ذَايسْ؟ \x ◘ \xo 144:‏3 \xt أَيُوبْ 7‏:‏17؛ إِزهد. 8‏:‏5؛ 31‏:‏8؛ عبر. 2‏:‏6\x*   
\m
\v 4 بْنَاذمْ أَمشْنَاوْ ڒفْوَارْ،  
\m ؤُسَّانْ نّسْ أَذْ عْذُونْ أَمْ ثِيڒِي. \x ◘ \xo 144:‏4 \xt أَيُوبْ 8‏:‏9؛ 14‏:‏2، 3؛ إِزهد. 39‏:‏6؛ 62‏:‏10؛ 102‏:‏12؛ يَاع. 4‏:‏14\x*   
\b  
\m
\v 5 ميّڒْ إِجنْوَانْ نّشْ، \add أَ\add* سِيذِي، هْوَا-د.  
\m حَاذَا إِذُورَارْ، \add خنِّي\add* أَذْ ڭّنْ دّخَّانْ. \x ◘ \xo 144:‏5 \xt إِزهد. 18‏:‏8، 10؛ 104‏:‏32\x*   
\m
\v 6 ژَترْيضْ أَسَّامنْ ؤُ زدْجعْ إِ-ثنْ،  
\m سكّْ فْڒِيثْشَاثْ نّشْ ؤُ سْخَارْوضْ إِ-ثنْ. \x ◘ \xo 144:‏6 \xt 1 صم. 7‏:‏10؛ 2 صم. 22‏:‏8؛ إِزهد. 18‏:‏15\x*   
\m
\v 7 سْوِيژّضْ إِفَاسّنْ نّشْ زِي سنّجْ،  
\m سُوفّغْ أَيِي-د ؤُ فكّْ أَيِي  
\m زِي \add ڒْْحمْڒَاثْ ن\add* وَامَانْ ثِيمقّْرَانِينْ،  
\m زڭْ ؤُفُوسْ ن إِبَارَّانِييّنْ،   
\m
\v 8 مَاغَارْ أَقمُّومْ نْسنْ إِقَّارْ إِخَارِّيقنْ،  
\m أَفُوسْ نْسنْ أَفُوسِي  
\m ذ إِجّْ ن ؤُفُوسْ \add إِشُّورْ\add* س ڒْغشّْ.   
\b  
\m
\v 9 \add أَ\add* أَربِّي، أَذْ أَشْغنّْجغْ  
\m إِجّْ ن يزْڒِي ذ ن جْذِيذْ إِ شكْ،  
\m س لهَارْپَا ؤُ \add س لْعُوذْ\add* سعشْرَا ن إِفِيڒَانْ  
\m أَذْ أَشْ زهّْذغْ.   
\m
\v 10 شكْ ذ ونِّي إِسَّاوَاضنْ  
\m أَسنْجمْ إِ إِججْدْجِيذنْ،  
\m ذ ونِّي إِفكّنْ أَمْسخَّارْ نّسْ ذَاوُوذْ  
\m زِي سِّيفْ أَعفَّانْ،   
\m
\v 11 سُوفّغْ أَيِي-د ؤُ فكّْ أَيِي  
\m زڭْ ؤُفُوسْ ن ثَارْوَا ن ؤُبَارَّانِي،  
\m زڭْ ونِّي غَارْ إِدْجَا ؤُقمُّومْ  
\m إِ إِقَّارنْ مْغِيرْ إِخَارِّيقنْ،  
\m ؤُ زڭْ ونِّي غَارْ إِدْجَا ؤُفُوسْ أَفُوسِي  
\m \add إِشُّورْ\add* س ڒْغشّْ.   
\b  
\m
\v 12 معْلِيكْ إِحنْجِيرنْ نّغْ  
\m أَذْ إِڒِينْ أَمْ يِيغذِّيونْ،  
\m إِنِّي إِمْغَارنْ \add عَاذْ\add* ذِي ثمْژِي نْسنْ،  
\m يسِّيثْنغْ أَمْ ثْغمَّارْ  
\m إِ ڭِّينْ س ؤُكشُّوضْ  
\m \add س عْڒَامْ كُوڒْ أَرْشَامنْ\add*،  
\m ڭِّينْ ثنْثْ إِ يِيشْثْ ن زَّاوشْثْ إِقدّْسنْ.   
\m
\v 13 \add أَذْ شُّورنْ\add* ڒهْرِيثْ نّغْ،  
\m أَذْ وْشنْ زَّاذْ أَوَارْنِي زَّاذْ،  
\m أَذْ يَارْنِي وُودْجِي نّغْ س ڒُوڒُوفْ ن ثْسقَّارْ،  
\m سعشْرَا ن ڒُوڒُوفْ ن ثْسقَّارْ  
\m ذِي دّْمَانِي ن ثَاروْسَا نّغْ.   
\m
\v 14 أَذْ حمْڒنْ إِمْوَانْ نّغْ مْلِيحْ،  
\m وَارْ إِتِّيڒِي عَاذْ ؤُهْجَامْ  
\m نِيغْ ذ ؤُفُّوغْ \add إِ ؤُمنْغِي\add*  
\m ؤُڒَا ذ إِغُويَّانْ ذڭْ وَازَّاينْ نّغْ.   
\m
\v 15 سّعْذْ ن ڒْڭنْسْ نِّي إِدْجَانْ أَمْيَا.  
\m سّعْذْ ن ڒْڭنْسْ نِّي زِي أَربِّي نْسنْ ذ سِيذِي.   
\b  
\b  
\m  
\c 145
\m
\v 1 \add إِزْڒِي ن ؤُصبّحْ ن ذَاوُوذْ.\add*  
\b  
\m \bd أَلِيفْ.\bd* \add أَ\add*، أَربِّي إِنُو، أَجدْجِيذْ،  
\m نشّْ أَذْ شكْ سّْعُودْجغْ،  
\m أَذْ بَارْكغْ إِسمْ نّشْ إِ ڒبْذَا قَاعْ.   
\m
\v 2 \bd بِيثْ.\bd* كُوڒْ أَسّْ أَذْ شكْ بَارْكغْ،  
\m أَذْ سّمْغَارغْ إِسمْ نّشْ إِ ڒبْذَا قَاعْ.   
\m
\v 3 \bd ڭِيملْ.\bd* سِيذِي ذ أَمقّْرَانْ،  
\m إِسّْذِيهدْجْ أَسمْغَارْ أَطَّاسْ،  
\m ڒمْغَارثْ نّسْ وَارْ ذَايسْ بُو ثَارزُّوثْ. \x ◘ \xo 145:‏3 \xt أَيُوبْ 5‏:‏9؛ إِزهد. 18‏:‏4؛ 150‏:‏2\x*   
\m
\v 4 \bd ذَالِيثْ.\bd* جِّيڒْ أَوَارْنِي جِّيڒْ  
\m أَذْ إِسّمْغَارْ ڒخْذَايمْ نّشْ،  
\m أَذْ بَارّْحنْ س ثْمڭَّا نّشْ ثِيمقّْرَانِينْ. \x ◘ \xo 145:‏4 \xt أَعَوذ. 4‏:‏9؛ 6‏:‏7\x*   
\m
\v 5 \bd هِي.\bd* نشّْ أَذْ سِّيوْڒغْ  
\m خْ ثِيسِّيقْثْ ن ؤُعُودْجِي ن لْعَاضَامَا نّشْ،  
\m خْ ڒخْبَارْ ن لْمُوعْجِيزَاثْ نّشْ. \f ◼ \fr 145:‏5 \ft \+bd ’خْ ڒخْبَارْ‘\+bd* - س ثْعِيبْرَانِيثْ ’ن وَاوَاڒنْ‘.\f*   
\m
\v 6 \bd وَاوْ.\bd* نِيثْنِي أَذْ سِّيوْڒنْ  
\m خْ جّْهذْ ن ثْمڭَّا نّشْ إِسَّاڭّْوَاذنْ،  
\m نشّْ أَذْ بَارّْحغْ س ڒمْغَارثْ نّشْ.   
\m
\v 7 \bd زَايِينْ.\bd* ڒِيذَارثْ ن ثْشُونِي نّشْ إِفيّْضنْ  
\m أَذْ ت ڭّنْ \add ذ إِجّْ ن ڒْعُونْصَارْ إِتّْشُورْشُورْ\add*،  
\m أَذْ سْڒِيوْڒِيونْ إِ ثْسڭْذَا نّشْ. \x ◘ \xo 145:‏7 \xt إِزهد. 119‏:‏171\x*   
\m
\v 8 \bd خِيثْ.\bd* سِيذِي ذ أَرْحِيمْ ذ أَحْنِينْ،  
\m غَارسْ تَّاسِيعْ ن ڒْخَاضَارْ  
\m ذ وَاطَّاسْ ن ثْمخْسِيوْثْ إِشوَّارنْ. \x ◘ \xo 145:‏8 \xt ؤُف. 34‏:‏6، 7؛ ڒخْڒ. 14‏:‏18؛ إِزهد. 86‏:‏15؛ 103‏:‏8\x*   
\m
\v 9 \bd ثِيث.\bd* سِيذِي ذ أَصبْحَانْ إِ مَارَّا،  
\m أَرّحْمثْ نّسْ أَقَا-ت ثِيوَا  
\m مَارَّا ثِيمڭَّا نّسْ.   
\m
\v 10 \bd يُوذْ.\bd* مَارَّا ثِيمڭَّا نّشْ،  
\m \add أَ\add* سِيذِي، أَذْ شكْ قَاذِينْثْ،  
\m إِمْثِيقَّانْ نّشْ أَذْ شكْ بَارْكنْ.   
\m
\v 11 \bd كَافْ.\bd* نِيثْنِي أَذْ سِّيوْڒنْ  
\m خْ ؤُعُودْجِي ن ثْڭلْذِيثْ نّشْ، أَذْ سِّيوْڒنْ  
\m خْ ثِيمڭَّا نّشْ ثِيمقّْرَانِينْ،   
\m
\v 12 \bd لَامِيذْ.\bd* حِيمَا أَذْ بَارّْحنْ  
\m س ثْمڭَّا نّسْ ثِيمقّْرَانِينْ  
\m إِ ثَارْوَا ن بْنَاذمْ،  
\m س ؤُعُودْجِي ن لْعَاضَامَا ن ثْڭلْذِيثْ نّسْ.   
\m
\v 13 \bd مِيمْ.\bd* ثَاڭلْذِيثْ نّشْ  
\m ذ إِشْثْ ن ثْڭلْذِيثْ إِ ڒبْذَا،  
\m ڒحْكَامثْ نّشْ \add أَذْ ثِيڒِي\add* خْ كُوڒْ جِّيڒْ.   
\m
\v 14 \bd سَامِيخْ.\bd* سِيذِي إِتّْسنّذْ  
\m مَارَّا إِنِّي إِوْضَانْ،  
\m إِتّْسڭّمْ مَارَّا إِنِّي إِقْوِيسنْ.   
\m
\v 15 \bd عَايِينْ.\bd* مَارَّا ثِيطَّاوِينْ تّْرَاجَانْثْ شكْ،  
\m شكْ ثتِّيشذْ أَسنْ مَاشَّا  
\m ذِي ڒْوقْثْ نّسْ \add إِتّْوَاڭّنْ\add*. \x ◘ \xo 145:‏15 \xt إِزهد. 104‏:‏27\x*   
\m
\v 16 \bd بِي.\bd* شكْ ثَارزّْمذْ أَفُوسْ نّشْ،  
\m ثسّْيَاوَانذْ مَارَّا مِينْ إِدَّارنْ  
\m \add أَكْ-ذ\add* مِينْ إِخْسْ ڒْخَاضَارْ \add نْسنْ\add*.   
\m
\v 17 \bd ثْسَاذِي.\bd* سِيذِي أَقَا-ث نِيشَانْ  
\m ذِي مَارَّا إِبْرِيذنْ نّسْ،  
\m إِتّڭّْ س ثْمخْسِيوْثْ إِشوَّارنْ  
\m ذِي مَارَّا ثِيمڭَّا نّسْ.   
\m
\v 18 \bd قُوفْ.\bd* سِيذِي يُوذسْ إِ مَارَّا  
\m إِنِّي خَاسْ إِتّْڒَاغَانْ،  
\m مَارَّا إِنِّي خَاسْ إِتّْڒَاغَانْ ذِي ثِيذتّْ.   
\m
\v 19 \bd رِيخْ.\bd* نتَّا إِڭَّا س ڒْخَاضَارْ  
\m إِ مَارَّا إِنِّي ث إِتّڭّْوْذنْ،  
\m إِتّسْڒَا إِغُويَّانْ نْسنْ ؤُ إِسّنْجَامْ إِ-ثنْ.   
\m
\v 20 \bd شِينْ.\bd* سِيذِي إِحطَّا خْ مَارَّا إِنِّي ث إِتّخْسنْ،  
\m \add مَاشَا\add* مَارَّا إِعفَّاننْ إِتّحَّا إِ-ثنْ.   
\m
\v 21 \bd ثَافْ.\bd* أَقمُّومْ إِنُو أَذْ إِسِّيوڒْ  
\m خْ ؤُصبّحْ ن سِيذِي،  
\m مَارَّا دَّاثْ أَذْ إِبَاركْ  
\m إِسمْ نّسْ إِقدّْسنْ، إِ ڒبْذَا قَاعْ.   
\b  
\b  
\m  
\c 146
\m
\v 1 هَالِّيلُو-يَاه.  
\m \add أَ\add* ڒعْمَارْ إِنُو، صبّحْ إِ سِيذِي.   
\m
\v 2 نشّْ أَذْ صبّْحغْ إِ سِيذِي  
\m مِينْ غَا كّغْ دَّارغْ،  
\m أَذْ زهّْذغْ إِ أَربِّي إِنُو  
\m مِينْ \add ذَا\add* غَا كّغْ عَاذْ. \f ◼ \fr 146:‏2 \ft \+bd ’مِينْ غَا كّغْ دَّارغْ‘\+bd* - س ثْعِيبْرَانِيثْ ’ذِي ثُوذَارْثْ إِنُو‘.\f*   
\m
\v 3 وَارْ ثْشڒْ خْ ثَارْوَا ن ثَاصِيڒثْ،  
\m خْ مِّيسْ ن بْنَاذمْ،  
\m ونِّي ؤُمِي وَارْ غَارْ إِدْجِي بُو ؤُسنْجمْ. \x ◘ \xo 146:‏3 \xt إِزهد. 118‏:‏8، 9\x*   
\m
\v 4 إِفّغْ بُوحْبڒْ نّسْ،  
\m إِذْوڒْ غَارْ ثمُّورْثْ.  
\m ذڭْ وَاسّْ نِّي سِيمَانْثْ نّسْ  
\m أَذْ قْضَانْ إِنْوَاينْ نّسْ.   
\b  
\m
\v 5 سّعْذْ ن ونِّي غَارْ إِدْجَا  
\m أَربِّي ن يَاعْقُوبْ ذ أَمْعَاونْ،  
\m ونِّي إِتّْرَاجَانْ سِيذِي، أَربِّي نّسْ،   
\m
\v 6 ونِّي إِڭِّينْ إِجنْوَانْ ذ ثمُّورْثْ،  
\m ڒبْحَارْ ذ مَارَّا مِينْ ذَايسْ،  
\m ونِّي ذَايسْ ڒَامَانْ إِ ڒبْذَا، \f ◼ \fr 146:‏6 \ft \+bd ’ونِّي ذَايسْ ڒَامَانْ‘\+bd* - س ثْعِيبْرَانِيثْ ’ونِّي إِحطَّانْ ڒَامَانْ‘.\f*   
\m
\v 7 ونِّي إِتَّاغنْ ثَاسْغَارْثْ  
\m إِ يِينِّي إِتّْوَاحصَّارنْ،  
\m ونِّي إِتِّيشنْ أَغْرُومْ إِ يِينِّي إِدْجُوژنْ.  
\m سِيذِي يَارخُّو إِ إِمحْبَاسْ.   
\b  
\m
\v 8 سِيذِي يَارزّمْ إِ إِذَارْغَاڒنْ ثِيطَّاوِينْ،  
\m إِسّْبدَّا إِنِّي إِڭُّورنْ إِتّقْوِيسنْ،  
\m سِيذِي إِتّخْسْ إِمْسڭَّاذنْ. \x ◘ \xo 146:‏8 \xt إِزهد. 145‏:‏14؛ 147‏:‏3؛ مت. 9‏:‏30؛ لك. 13‏:‏13؛ يُوح. 9‏:‏7، 32\x*   
\m
\v 9 سِيذِي إِحطَّا إِبَارَّانِييّنْ،  
\m إِتِّيشْ أَفُوسْ إِ ؤُيُوجِيڒْ ذْ ثِيجَّاڒْ،  
\m \add مَاشَا\add* أَبْرِيذْ ن إِعفَّاننْ أَذْ ث إِسّْفَارْغْ.   
\m
\v 10 سِيذِي أَذْ إِحْكمْ إِ ڒبْذَا،  
\m أَربِّي نّشْ، \add أَ\add* صِيهْيُونْ،  
\m \add إِحكّمْ\add* زِي جِّيڒْ أَڒْ جِّيڒْ.  
\m هَالِّيلُو-يَاه. \x ◘ \xo 146:‏10 \xt ؤُف. 15‏:‏18؛ إِزهد. 145‏:‏13\x*   
\b  
\b  
\m  
\c 147
\m
\v 1 هَالِّيلُو-يَاهْ،  
\m مَاغَارْ أَزهّذْ إِ أَربِّي نّغْ  
\m ذ أَصبْحَانْ، مِينْزِي إِتَّاسْ-د أَكِيذسْ  
\m أَذْ أَسْ نْصبّحْ. \x ◘ \xo 147:‏1 \xt إِزهد. 33‏:‏1\x*   
\m
\v 2 سِيذِي إِبنَّا ؤُرْشَالِيمْ،  
\m إِسّْمُونْ إِمّنعْرَاقْ ن إِسْرَائِيل.   
\m
\v 3 نتَّا إِسّْڭنْفَا إِنِّي غَارْسنْ ؤُڒْ يَارْژنْ،  
\m إِتّْشدَّا إِيزِّيمنْ نْسنْ إِتّقْسنْ. \x ◘ \xo 147:‏3 \xt ؤُف. 15‏:‏26؛ أَيُوبْ 5‏:‏18\x*   
\m
\v 4 إِحسّبْ قدَّا ن إِثْرَانْ،  
\m إِتّْڒَاغَا ثنْ مَارَّا س يِيسمْ. \x ◘ \xo 147:‏4 \xt إِشا. 40‏:‏26\x*   
\m
\v 5 سِيذِيثْنغْ ذ أَمقّْرَانْ ؤُ جّهْذْ نّسْ إِمْغَارْ.  
\m ڒعْقڒْ نّسْ وَارْ غَارسْ بُو ڒعْبَارْ.   
\m
\v 6 سِيذِي إِتّْسنّذْ إِمْوَاضْعنْ،  
\m إِسّْهكّْوَا إِعفَّاننْ أَڒْ ثَامُّورْثْ.   
\b  
\m
\v 7 قَاذَامْ سِيذِي س ؤُغنّجْ،  
\m زهّْذمْ إِ أَربِّي نّغْ س ڒْڭَامْبْرِي.   
\m
\v 8 \add نتَّا\add* ذ ونِّي إِدَّاڒنْ أَجنَّا  
\m س إِسيْنُوثنْ،  
\m ذ ونِّي إِسّوْجَاذنْ أَنْژَارْ إِ ثمُّورْثْ،  
\m ذ ونِّي إِسّْغمَّاينْ أَرْبِيعْ خْ إِذُورَارْ. \x ◘ \xo 147:‏8 \xt أَيُوبْ 38‏:‏26، 27؛ إِزهد. 104‏:‏14؛ حُوش. 2‏:‏23، 24\x*   
\m
\v 9 ذ ونِّي إِتِّيشنْ إِ ڒْمَاڒْ مَاشَّا نّسْ،  
\m ؤُڒَا إِ ثَارْوَا ن إِبَاغْڒِيونْ خْمِي غَا سْغُوينْ.   
\m
\v 10 نتَّا وَارْ يَارطِّي س جّهْذْ ن ؤُيِيسْ،  
\m إِضَارنْ ن ورْيَازْ وَارْ ذ أَسْ تّعْجِيبنْ.   
\m
\v 11 يَارطَّا أَسْ إِ سِيذِي إِنِّي ث إِتّڭّْوذنْ،  
\m إِنِّي إِسِّيثْمنْ  
\m ذِي ثْمخْسِيوْثْ نّسْ إِشوَّارنْ.   
\b  
\m
\v 12 \add أَ\add* ؤُرْشَالِيمْ، صبّحْ إِ سِيذِي،  
\m \add أَ\add* صِيهْيُونْ، صبّحْ إِ أَربِّي نّمْ.   
\m
\v 13 مَاغَارْ نتَّا إِسّمْحذْ  
\m زّكْرُونَاثْ ن ثوُّورَا نّشْ،  
\m إِبَاركْ إِحنْجِيرنْ نّشْ ذِي ڒْوسْثْ نّشْ،   
\m
\v 14 نتَّا إِوْشَا ڒهْنَا إِ إِيْمِيرنْ نّشْ،  
\m إِسّْجِيونْ إِ شكْ س مِينْ إِصبْحنْ قَاعْ ن يِيرْذنْ.   
\m
\v 15 نتَّا إِسّكَّا ثِيوَاڒِينْ نّسْ غَارْ ثمُّورْثْ،  
\m أَوَاڒْ نّسْ إِتَّازّڒْ أَطَّاسْ. \x ◘ \xo 147:‏15 \xt إِزهد. 33‏:‏9\x*   
\m
\v 16 إِتِّيشْ أَذْفڒْ أَمْ ثْضُوفْثْ،  
\m إِزُّوزَارَا نّْذَا إِڭرْسنْ أَمْ يِيغّضْ.   
\m
\v 17 إِسّكَّا أَذْفڒْ نّسْ ذ إِبْقُوقنْ،  
\m وِي إِزمَّارنْ أَذْ إِقِّيمْ إِبدّْ  
\m زَّاثْ إِ ثسْمُوضِي نّسْ؟   
\m
\v 18 إِسّكَّا أَوَاڒْ نّسْ  
\m ؤُشَا إِتَّارَّا إِ-ثنْ أَذْ فسْينْ،  
\m نتَّا إِتّجَّا أَسمِّيضْ نّسْ إِتّْسُوضْ،  
\m خنِّي تُّوشْرُورنْ وَامَانْ.   
\m
\v 19 نتَّا إِبَارّحْ إِ يَاعْقُوبْ أَوَاڒنْ نّسْ،  
\m إِ إِسْرَائِيل ثِيوصَّا نّسْ ذ لْفَارَايِيضْ نّسْ.   
\m
\v 20 ؤُڒَا إِ يِيجّْ ن ڒْڭنْسْ نّغْنِي  
\m وَارْ ذ أَسْ إِڭِّي أَمُّو،  
\m نِيثْنِي وَارْ سِّيننْ شَا لْفَارَايِيضْ نّسْ.  
\m هَالِّيلُو-يَاهْ! \x ◘ \xo 147:‏20 \xt ڒخ. 14‏:‏16\x*   
\b  
\b  
\m  
\c 148
\m
\v 1 هَالِّيلُو-يَاهْ!  
\m صبّْحمْ إِ سِيذِي زڭْ إِجنْوَانْ،  
\m صبّْحمْ ث ذِي ڒُوعْڒَا. \x ◘ \xo 148:‏1 \xt لك. 2‏:‏14؛ أَسَا. 5‏:‏13\x*   
\m
\v 2 صبّْحمْ ث، مَارَّا لْمَالَاكَاثْ نّسْ!  
\m صبّْحمْ ث، مَارَّا ڒْعسْكَارَاثْ نّسْ!   
\m
\v 3 صبّْحنْثْ ث، ثَافُوشْثْ ذ ثْزِيرِي!  
\m صبّْحمْ ث، مَارَّا إِثْرَانْ يَارقّنْ!   
\m
\v 4 صبّْحثْ، أَجنَّا خْ إِجنْوَانْ،  
\m ؤُڒَا ذ أَمَانْ نِّي \add إِدْجَانْ\add* ثِيوَا إِ ؤُجنَّا.   
\m
\v 5 أجّْ إِ-ثنْ أَذْ صبّْحنْ إِسمْ ن سِيذِي،  
\m مَاغَارْ نتَّا يُومُورْ  
\m ؤُ \add أَمُّو\add* تّْوَاخڒْقنْ-د. \x ◘ \xo 148:‏5 \xt أَمز. 1‏:‏6‏-‏31؛ إِزهد. 33‏:‏6، 9\x*   
\m
\v 6 نتَّا إِذكّنْ إِ-ثنْ \add ذِينْ\add* إِ ڒبْذَا،  
\m إِوْشَا \add أَسنْ\add* إِشْثْ ن ثوْصيّثْ  
\m إِ وَارْ زمَّارنْ أَذْ تعدَّانْ \add عمَّارْصْ\add*. \x ◘ \xo 148:‏6 \xt أَيُوبْ 14‏:‏5، 13؛ 26‏:‏10؛ 38‏:‏33؛ إِزهد. 104‏:‏5؛ 119‏:‏91؛ إِرْم. 31‏:‏35؛ 33‏:‏25\x*   
\b  
\m
\v 7 صبّْحمْ إِ سِيذِي، زِي ثمُّورْثْ،  
\m \add كنِّيوْ\add* ڒْهَايْشَاثْ نْ ڒبْحَارْ  
\m ذ مَارَّا \add أَمَانْ\add* إِهوْڒنْ،   
\m
\v 8 ثِيمسِّي ذ ثبْرُورِّي  
\m ذ وذْفڒْ ذ دّخَّانْ،  
\m أَسمِّيضْ ن ثْحَارْيَاضْثْ  
\m نِّي إِتّڭّنْ أَوَاڒْ نّسْ،   
\m
\v 9 إِذُورَارْ ذ مَارَّا ثِيوْرِيرِيرِينْ،  
\m ثِيشجُّورَا ن فْرُوثَا  
\m ذ مَارَّا ثِيشجُّورَا ن ثنْڭلْثْ،   
\m
\v 10 ڒوْحُوشْ ن ڒخْڒَا ذ مَارَّا ڒْمَارْ،  
\m إِمُودَّارنْ إِتّْبُوعنْ ذ إِجْضَاضْ  
\m س وَافْرِيونْ \add نْسنْ\add*،   
\m
\v 11 \add كنِّيوْ\add* إِجدْجِيذنْ ن ثمُّورْثْ  
\m ذ مَارَّا شُّوعُوبْ،  
\m \add كنِّيوْ\add* ڒْحُوكَّامْ  
\m ذ مَارَّا ڒْقُوضَاثْ خْ ثمُّورْثْ، \f ◼ \fr 148:‏11 \ft \+bd ’ڒْقُوضَاثْ‘\+bd* - نِيغْ ’إِمزُورْفَا‘.\f*   
\m
\v 12 إِبْڒِيغنْ ؤُڒَا ذ ثِيعْزَارِييِّينْ،  
\m إِوسُّورَا \add جْمِيعْ\add* أَكْ-ذ إِمژْيَاننْ!   
\m
\v 13 أجّْ إِ-ثنْ أَذْ صبّْحنْ إِسمْ ن سِيذِي،  
\m مَاغَارْ إِسمْ نّسْ وَاهَا يُوعْڒَانْ قَاعْ،  
\m ثِيسِّيقْثْ نّسْ \add ثَاڒقّْ\add*  
\m خْ ثمُّورْثْ ذ إِجنْوَانْ. \x ◘ \xo 148:‏13 \xt أَوڒن. 18‏:‏10؛ إِشا. 12‏:‏4\x*   
\m
\v 14 نتَّا إِسّْڭعّذْ إِشّْ ن ڒْڭنْسْ نّسْ،  
\m أَصبّحْ ن مَارَّا إِمْثِيقَّانْ نّسْ،  
\m ن أَيْثْ ن إِسْرَائِيل،  
\m ن ڒْڭنْسْ إِ د أَسْ يُوذْسنْ.  
\m هَالِّيلُو-يَاهْ! \x ◘ \xo 148:‏14 \xt إِزهد. 132‏:‏17\x*   
\b  
\b  
\m  
\c 149
\m
\v 1 هَالِّيلُو-يَاهْ!  
\m غنّْجمْ إِجّْ ن يزْڒِي ن جْذِيذْ إِ سِيذِي،  
\m سْعُودْجمْ ث ذڭْ وڭْرَاوْ ن إِمْثِيقَّانْ نّسْ.   
\m
\v 2 أَذْ إِفَارْحْ إِسْرَائِيل زڭْ ونِّي ث إِڭِّينْ،  
\m أَذْ أَرْشْقنْ إِحنْجِيرنْ ن صِيهْيُونْ  
\m س ؤُجدْجِيذْ نْسنْ. \x ◘ \xo 149:‏2 \xt إِزهد. 100‏:‏3\x*   
\m
\v 3 أَذْ صبّْحنْ نِيثْنِي إِسمْ نّسْ  
\m س شّْضِيحْ س نُّوبْثَاثْ،  
\m أَذْ أَسْ زهّْذنْ س ؤُبنْذِيرْ ذ ڒْڭَامْبْرِي، \x ◘ \xo 149:‏3 \xt إِزهد. 81‏:‏3، 4\x*   
\m
\v 4 مَاغَارْ سِيذِي يَارْضَا خْ ڒْڭنْسْ نّسْ،  
\m أَذْ يَاوِي شَّانْ إِ إِمْوَاضْعنْ س ونْجَامْ.   
\m
\v 5 أَذْ سْڒِيوڒْونْ إِمْثِيقَّانْ  
\m س ؤُوقَّارْ يُودْجْغنْ،  
\m أجّْ إِ-ثنْ أَذْ سْغُوينْ س ڒفْرَاحثْ  
\m زڭْ إِمُوشَانْ نْسنْ ن أَرَّاحثْ.   
\b  
\m
\v 6 إِزْڒَانْ ن ؤُعُودْجِي إِ أَربِّي  
\m ذڭْ ؤُقمُّومْ نْسنْ  
\m إِجّْ ن سِّيفْ إِقْضعْ س ثْنَاينْ ن وُوذْمَاونْ  
\m ذڭْ ؤُفُوسْ نْسنْ، \x ◘ \xo 149:‏6 \xt 2 تس. 2‏:‏8؛ عبر. 4‏:‏12؛ أَسَا. 1‏:‏16\x*   
\m
\v 7 حِيمَا أَذْ نْثَاقْمنْ زِي ڒڭْنُوسْ،  
\m \add حِيمَا\add* أَذْ عَاقْبنْ شُّوعُوبْ،   
\m
\v 8 حِيمَا أَذْ شَارْفنْ إِجدْجِيذنْ نْسنْ س سّْنَاسڒْ،  
\m أَيْثْ ن ثَاصِيڒثْ نْسنْ س سّْنَاسڒْ ن وُوزَّاڒْ، \x ◘ \xo 149:‏8 \xt مت. 18‏:‏18\x*   
\m
\v 9 حِيمَا أَذْ خَاسنْ ڭّنْ ڒْحُوكْمْ يُورَانْ.  
\m ذ مَانْ أَيَا أَذْ ثِيڒِي ذ لْعَاضَامَا  
\m ن مَارَّا إِمْثِيقَّانْ نّسْ.  
\m هَالِّيلُو-يَاه. \x ◘ \xo 149:‏9 \xt أَعَوذ. 4‏:‏6\x*   
\b  
\b  
\m  
\c 150
\m
\v 1 هَالِّيلُو-يَاهْ،  
\m صبّْحمْ أَربِّي  
\m ذِي زَّاوشْثْ نّسْ إِقدّْسنْ،  
\m صبّْحمْ ث ذِي ڒْكُوبّثْ ن جّهْذْ نّسْ! \x ◘ \xo 150:‏1 \xt إِشا. 6‏:‏3\x*   
\m
\v 2 صبّْحمْ ث خْ ثْمڭَّا نّسْ ثِيمقّْرَانِينْ،  
\m صبّْحمْ ث خْ ڒمْغَارثْ نّسْ ثَامقّْرَانْثْ!   
\m
\v 3 صبّْحمْ س ثْمِيجَّا ن ؤُسُوضِي  
\m ذڭْ ؤُيِيشّْ ن إِشَارِّي،  
\m صبّْحمْ س لهَارْپَا ذ ڒْڭَامْبْرِي!   
\m
\v 4 صبّْحمْ ث س ؤُبنْذِيرْ ذ شّْضِيحْ س نُّوبْثَاثْ،  
\m صبّْحمْ ث س \add ثِيرَارْثْ\add* ن إِفِيڒَانْ ذ ثمْجَا!   
\m
\v 5 صبّْحمْ أَسْ س ڒْحسّْ إِفْسُوسنْ  
\m ن ثدْجُونِينْ ن وُوزَّاڒْ،  
\m صبّْحمْ أَسْ س ڒْحسّْ يُوعْڒَانْ  
\m ن ثدْجُونِينْ ن وُوزَّاڒْ!   
\b  
\m
\v 6 مَارَّا مِينْ إِتَّارَّانْ نّفْسْ،  
\m صبّحْ إِ سِيذِي.  
\m هَالِّيلُو-يَاهْ!   