\id HAB
\h Ḥabaqquq
\toc1 Ḥabaqquq
\toc2 Ḥabaqquq
\toc3 Ḥab.
\mt1 Ḥabaqquq
\c 1
\s1 Acetci n Ḥabaqquq
\m 
\v 1 Řḥukm issaggʷaden nni iẓra unabi Ḥabaqquq.
\b
\m 
\v 2 “\add A\add* SIDI, ař meřmi i ɣa qqimeɣ ttřaɣiɣ
\m u Cek war d ayi tᵉttesřid,
\m ař meřmi i ɣa qqimeɣ ttřaɣiɣ ‘Lɛunf!’,
\m u Cek war d ayi tessenjamed!
\m 
\v 3 Mayemmi d ayi tessecned řmuɛṣiyyet,
\m u tᵉttɣimid txezzared ɣar řeɣben?
\m Maɣar areddeǧ d lɛunf
\m aqa aten arendad inu,
\m u imsar umcubbec, ikkar-dd uruddez.
\m 
\v 4 X uya tedweř ccariɛa břa jjehd,
\m u war dd-itteffeɣ ɛemmarṣ řḥeqq,
\m maɣar aɛeffan ittenneḍ i umsegged.
\m X uya i dd-itteffeɣ řḥeqq ifarɣ.
\b
\s1 Tamwarrit n SIDI x tẓaǧit
\m 
\v 5 Xzarem jar řegnus, xzarem,
\m innurzem uqemmum s utebhet,
\m maɣar Necc ad ggeɣ
\m ict n řxedmet deg wussan nwem
\m i war tᵉttimnem mařa tt ḥajan. \x ◘ \xo 1:5 \xt Řex. 13:41\x*
\m 
\v 6 Maɣar xzarem,
\m Necc ssekkareɣ Ikaldaniyyen,
\m řgens iqesḥen u imqeǧqen,
\m wenni igguren di řewseɛ n temmurt,
\m ḥima ad iṭṭef tizeddiɣin
\m nni war iǧin nnes.
\m 
\v 7 Issaggʷaden u issnexřaɛen iǧan!
\m Řḥeqq nnes d uɛuǧi nnes
\m tteffɣen-dd zzayes.
\m 
\v 8 Iysan nnes fsusen x uɣiřas,
\m nitni mmuzzaren
\m mahu uccanen n ǧiřet,
\m imnayen nnes ttrabaɛen.
\m Imnayen nnes ttasen-dd zi řaggʷaj,
\m nitni ṭṭawen am ugider
\m nni ittqeǧqen maḥend ad yecc.
\m 
\v 9 Aqa netta ittas-dd, amen ikmeř, i lɛunf,
\m iɣembab nsen \add xezzaren\add* ɣar zzat,
\m u netta issmuna imeḥbas am yejdi.
\m 
\v 10 Netta ittqeṣṣar x ijeǧiden
\m u inni i ɣar teǧa ṣṣulṭa
\m ittegg i-ten d taḍeḥḥact.
\m \add Wah,\add* netta iḍeḥḥec x kuř lqelɛa,
\m minzi netta ittɛurrec ucař
\m uca ad tent iṭṭef.
\m 
\v 11 Xenni ad inneɛtar \add am\add* usemmiḍ,
\m ad iɛdu, ad idweř d amednub,
\m \add maɣar\add* jjehd nnes wanita d arebbi nnes.
\b
\s1 Acetci wiss tnayen n Ḥabaqquq
\m 
\v 12 Zi mecḥař uya
\m ma Cek war teǧid d SIDI,
\m AREBBI inu, Amqeddas inu?
\m Neccin war nettmetti ca!
\m \add A\add* SIDI, Cek tarrid i-t i řḥukm,
\m \add a\add* Taṣḍart, Cek tfarzed t
\m maḥend ad yiři i lɛiqab.
\m 
\v 13 Cek d amezdag aṭṭas n tiṭṭawin
\m ḥima ad twařant řɣar.
\m Cek war tzemmared
\m ad tṣewḍed di řmuɛṣiyyet.
\m Mayemmi tṣewḍed \add waha\add*
\m deg yinni itteggen s řeɣdaret?
\m \add Mayemmi\add* i tesseɣḍed
\m xmi iṣarreḍ uɛeffan
\m i wenni i xas iseggden?
\m 
\v 14 Cek teggid iwdan
\m am yiseřman n řebḥar,
\m am \add immudar\add* nni ittbuɛen
\m \add x temmurt\add* i war ɣar iǧi řḥakem!
\b
\m 
\v 15 S tsennart issgeɛɛad i-ten-dd marra,
\m iyarru i-ten s tracca nnes,
\m uca issmun i-ten di tracca nnes n udellaɛ.
\m X uya ifarreḥ u ittfaja.
\m 
\v 16 X uya iwehheb tiɣarṣa i tracca nnes,
\m uca ibexxar tiwhibin n řebxur
\m i tracca n udellaɛ nnes.
\m minzi zzaysent i tedweř
\m tesɣart nnes temɣar,
\m uřa d macca nnes aqa tředd.
\m 
\v 17 Ma iɛeddeř ad iqqim issexwa
\m tracca nnes x man aya,
\m uca ad iqqim řebda ineqq řegnus
\m břa ma ad yejj \add ḥed\add*?
\b
\b
\c 2
\s1 SIDI ad dd-yarr x Ḥabaqquq i twařa wiss tnayen
\m 
\v 1 Necc ad beddeɣ
\m deg wemcan n tɛessast inu
\m u ad ssbeddeɣ ixef inu
\m x ṣṣumɛet n tɛessast,
\m ad ṣewḍeɣ maḥend ad ẓareɣ
\m min i d ayi ɣa yini Netta,
\m u min i dd ɣa yarreɣ x ucetci inu. \x ◘ \xo 2:1 \xt Ica. 21:8\x*
\b
\m 
\v 2 Yarra-dd xafi SIDI, inna:
\m Ari řewḥiy
\m ari t ifarz x teřwiḥin,
\m maḥend wenni iɛeddun
\m am dd-ittazzeř, izemmar ad t iɣar. \x ◘ \xo 2:2 \xt Ica. 30:8\x*
\m 
\v 3 Maɣar řewḥiy \add ittraja\add* ɛad
\m ař řweqt nni yuran.
\m Ittemḥizwar ɣar uqeṭṭu
\m u war issxarriq ca.
\m Mařa iqqim war dd-ittis, qqim raja t,
\m maɣar ad dd-yas s tidett,
\m war iɛeṭṭař.
\b
\m 
\v 4 Xzar, aqa ittuff, \add wah,\add*
\m řeɛmar nnes war iseggem dayes,
\m maca amsegged s l’iman nnes ad iddar. \f ◼ \fr 2:4 \fk s l’iman nnes\ft - man aya ixs ad yini s l’iman nnes di Sidi Arebbi (Rum. 1:17)\f*
\b
\m 
\v 5 S tidett, binu aqa icemmet!
\m \add Binu aqa-t am\add* yijj n bu-nnfaxet
\m wenni war ittareyyḥen,
\m wenni issemɣaran řeɛmar nnes
\m \add ameřhaf\add* am řaxart.
\m Netta war ittjjiwin am řmewt
\m u iyru ɣares marra řegnus
\m u issmun ɣares marra iyduden. \f ◼ \fr 2:5 \ft \bd afessar\bd* - nessen aqa Ikaldaniyyen d řḥukkam n Babil swin aṭṭas n binu (xzar Daniyal 5). S uyenni yarwesen nitni s yixef nsen di binu, minzi am mammec arzmen nitni aqemmum nsen ḥima ad swen binu, ammu i yarezzmen nitni aqemmum nsen am ijj n bu-nnfaxet wenni war ittareyyiḥen ...’\f*
\m 
\v 6 Ma war dd xas ttiwyen
\m ijj n wawař iweznen
\m uřa d ijj n yeẓri
\m iccur s řemɛani innufaren, ad inin:
\m \bdit Uct\bdit* x wenni ijarrwen
\m min war iǧin nnes!
\m Ař meřmi \add ɛad\add*?
\m \bdit Uct\bdit* x wenni issdeqqařen
\m ixef nnes s werhan!
\m 
\v 7 Ma war dd-ttekkaren s řɣefřet
\m inni i cek ɣa izeɛfen,
\m u ma war dd-ttfaqan ca
\m inni cek ɣa yarren tᵉttarjijed,
\m u ma war d asen tᵉttiřid
\m d takeccaḍt nsen?
\m 
\v 8 Maɣar cek tkeccḍed aṭṭas n řegnus,
\m ad cek keccḍen marra řegnus iqqimen
\m di ssibbet n idammen n iwdan
\m d lɛunf \add x\add* temmurt,
\m u \add x\add* tendint u \add x\add* marra
\m inni dayes izeddɣen.
\b
\m 
\v 9 \bdit Uct\bdit* x wenni ikessben s řɣecc
\m takeccaḍt i taddart nnes,
\m maḥend ad ibna řɛucc nnes di řuɛřa,
\m ḥima ad injem \add ammu\add* zeg ufus n řɣar.
\m 
\v 10 Cek tcawared řefḍiḥet i taddart nnec,
\m ḥima ad teqḍid x řegnus,
\m uca \add ammu\add* i teggid ddenb
\m di řeɛmar nnec.
\m 
\v 11 Minzi aẓru isɣuyyu-dd zi řḥiḍ,
\m u taḥnact tᵉttarra-dd \add xas\add*
\m zi jar tefřawt.
\b
\m 
\v 12 \bdit Uct\bdit* x wenni ibennan
\m \add ict n\add* tendint s idammen
\m uřa x wenni issrusan dsas
\m \add n yict n\add* tendint s řɣecc!
\m 
\v 13 Xzar, ma war iǧi zi SIDI n řɛeskarat,
\m aqa řegnus arebbren ixef nsen i tmessi,
\m u ccuɛub ttaḥřen i walu?
\m 
\v 14 Maɣar tammurt ad tᵉttwaccur
\m s tussna n uɛuǧi n SIDI,
\m am mammec ttdařen waman řebḥar.
\b
\m 
\v 15 \bdit Uct\bdit* x wenni i ɣa isseswen jjar nnes,
\m wenni ixeǧḍen \add binu\add* s ssem nnec
\m u \add xenni\add* issᵉscar i-t,
\m maḥend ad iẓar tuɛɛaryant nsen.
\m 
\v 16 Ad tessjjiwned ixef nnec s řefḍiḥet
\m deg wemcan n ccan.
\m Su cek \add řexxu\add* ɛawed,
\m uca ejj axtan nnec war iǧin ittban.
\m Řkas zeg ufus afusi n SIDI
\m ad ɣarek dd-yas,
\m uřa d řefdiḥet x uɛuǧi nnec.
\m 
\v 17 Maɣar řɛunf i teggid ḍidd i Lubnan
\m ad cek ideř
\m uřa d areddeǧ n řmař i zi \add ten\add* tessiggʷded,
\m di ssibbet n idammen n iwdan
\m d lɛunf \add x\add* temmurt,
\m u \add x\add* tendint u \add x\add* marra inni dayes izeddɣen.
\b
\m 
\v 18 Ma tizi n ijj n řexyař ineqcen,
\m umi t inqec uneqqac \add s yixef nnes\add*,
\m \add man tizi n\add* yijj n řexyař ifesyen
\m \add umi aneqqac nnes\add*
\m d ijj n umseřmed n ixarriqen,
\m řami wenni t iggin ittceř x min igga,
\m umi ittegg l’aṣnam ignawen?
\m 
\v 19 \bdit Uct\bdit* x wenni iqqaren i ukeccuḍ ‘Faq!’
\m u i weẓru ignawen: ‘Kkar!’.
\m Ma \add izemmar\add* ad isseřmed?
\m Xzar, aqa řeḥḥfen t s wureɣ d nnuqart
\m u war dayes qaɛ buḥbeř.
\m 
\v 20 SIDI aqa-t di Zzawect nnes iqeddsen.
\m Susem zzat i wudem nnes,
\m marra tammurt!
\b
\b
\c 3
\s1 Taẓaǧit n Ḥabaqquq
\m 
\v 1 Taẓaǧit n Ḥabaqquq, anabi, deg waṭṭas n tmijjiwin.
\b
\m 
\v 2 \add A\add* SIDI, \add umi\add* sřiɣ řexbar nnec,
\m tuɣa tteggʷedeɣ.
\m \add A\add* SIDI, sneddar řxedmet nnec ɛawed
\m di řwesṭ n iseggʷusa,
\m seccen i-tt di řwesṭ n iseggʷusa,
\m deg weɣḍab ɛqeř x řeḥnunect nnec.
\m 
\v 3 Arebbi yusa-dd zi Tayman u Amqeddas
\m zeg wedrar n Faran. Silah.
\m Lɛaḍama nnes tedřa ijenwan
\m u aṣebbeḥ nnes iccur tammurt.
\m 
\v 4 Tuɣa din ict n tessiqt am tfawt,
\m \add ffɣent-i-dd\add* fřitcat n wassam
\m zeg ufus nnes,
\m aqa-tent ɣares,
\m u daysent tnuffar tzemmar nnes.
\m 
\v 5 Ṭṭaɛun ittizwar i wudem nnes,
\m řḥaduq n tmessi iffeɣ-dd
\m zeg iḍaren nnes.
\m 
\v 6 Netta ikkar uca yarra tammurt tᵉttenhezza,
\m Netta iẓra u igga ad arjijen řegnus!
\m Idurar n zic ttwařebzen
\m ařami dewřen d taɛejjajt,
\m tiwririn zi mecḥař uya ɣensent!
\m Ibriden ittduman i řebda aqa aten nnes.
\m 
\v 7 Necc ẓriɣ iqiḍan n Kucan ttwaḥṣaren,
\m tijartiřin n iqiḍan n temmurt n Midyan
\m ittawi tent usemmiḍ s jjehd.
\m 
\v 8 Ma yarɣa \add weɣḍab\add* n SIDI x iɣezran?
\m Ma tuɣa aɣḍab nnec ḍidd i iɣezran?
\m Ma tuɣa aduqqez nnec \add n ufugem\add*
\m ḍidd i řebḥar,
\m řami tnedhed x yeysan nnec,
\m x ikarruten nnec n usenjem?
\m 
\v 9 Řqews nnec ittwaɛarra marra,
\m tijaǧitin i tessiwřed \add tuɣa atent\add*
\m d iɛumad necc \add i useqsaḥ\add*. Silah.
\m Tfeǧqed tammurt s iɣezran.
\m 
\v 10 Řami Cek ẓrin idurar, iřqef i-ten řewjeɛ,
\m řḥemřet n waman tuɣa tɛeddu,
\m \add aman\add* ihewřen arrin
\m tmijja nsen tᵉttwaseř,
\m geɛɛden ifassen nsen \add ɣar ujenna\add*.
\m 
\v 11 Tafuct, \add uřa\add* d uyur,
\m qqimen bedden di tzeddiɣt nsen.
\m Aqa ruḥen zi ssibbet n tfawt
\m n fřitcat n řqews nnec,
\m zi ssibbet n tissiqt
\m n lansa nnec itteḥduduqen.
\m 
\v 12 S wesxeḍ teṣṣurufed tiwa i temmurt,
\m s weɣḍab nnec tɛefsed x řegnus.
\m 
\v 13 Cek teffɣed i usenjem n řgens nnec,
\m i usenjem n umedhun nnec.
\m Aqa cek tqeǧɛed
\m tazeqqa n taddart n uɛeffan,
\m tɛarrid dsas ař iri. Silah.
\b
\m 
\v 14 Azeǧif n iɛeskariyyen nnes imezwura,
\m aqa tessnuqqbed i-t s lansat nsen.
\m Nitni usin-dd ɛeřfen-dd
\m maḥend ad ayi zeǧɛen.
\m Aqa d meẓri nsen
\m mařa \add zemmaren\add*
\m ad ccen řmeskin s tnuffra.
\m 
\v 15 Ak-d iysan nnec tᵉṭṭfed abrid di řebḥar,
\m akuffu n waman imeqqranen.
\m 
\v 16 \add Řami\add* sřiɣ, yarjij uɛeddis inu.
\m Umi \add sřiɣ\add* řḥess \add nni\add*, arjijen iyencicen inu,
\m axessar yudef ɣar iɣsan inu,
\m u necc arjijeɣ deg wemcan inu.
\m \add Waxxa amenni\add* ad rajiɣ di řxaḍar
\m x wass n řeḥṣaret,
\m xmi ɣa issgeɛɛed x řgens,
\m \add u\add* ad aneɣ iḥṣar ak-d bandiyyat \add nnes\add*.
\b
\s1 Řefraḥet n Ḥabaqquq
\m 
\v 17 Waxxa war ittnuwwar wartu,
\m u war din tᵉttiři \add ɛad\add* řɣiǧet ɣar tzayart,
\m \add waxxa\add* řɣiǧet n zzitun ad tefceř
\m uřa d iyyaren war ttɣimin tticen řmacuř,
\m u ad ttwaqeḍɛen wuǧi zi řkuři
\m u war ttiřin \add ɛad\add* ifunasen
\m d tfunasin di řkurit,
\m 
\v 18 \add ɛad amenni\add* necc ad sřiweřweɣ i SIDI,
\m ad farḥeɣ zi AREBBI n usenjem inu.
\m 
\v 19 SIDI, Sidi inu, \add Netta\add* d jjhed inu.
\m Netta ittegg iḍaren inu \add fsusen\add*
\m am yiḍaren n tudadin,
\m Netta ittejja ayi ṣṣurufeɣ x řegɛudi.
\b
\m I umeqqran n imeɣnajen.
\m Ak-d uzenzun inu x ifiřan. \x ◘ \xo 3:19 \xt Izhd. 18:34\x* 
