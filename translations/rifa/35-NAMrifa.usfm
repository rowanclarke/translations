\id NAM
\h نَاحُومْ
\toc1 نَاحُومْ
\toc2 نَاحُومْ
\toc3 نَحُم.
\mt1 نَاحُومْ
\c 1
\s1 أَوَاڒْ ن نَاحُومْ خْ نِينْوَا
\m 
\v 1 ڒْحُوكْمْ إِسَّاڭّْوَاذنْ خْ نِينْوَا.
\m أَذْلِيسْ ن ڒوْحِييْ ن نَاحُومْ، أَلْقُوشِي.\f ◼ \fr 1:‏1 \ft \bd ’نَاحُومْ‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَفوّجْ‘ نِيغْ ’أَمْفوّجْ‘.\f*
\b
\m 
\v 2 \bd أَلِيفْ.\bd* - أَربِّي إِتَّاسْمنْ ؤُ سِيذِي إِنْثَاقَامْ،
\m سِيذِي ذ أَنقَّامْ ؤُ نتَّا ذ بَابْ ن وسْعَارْ.
\m سِيذِي ذ أَنقَّامْ إِ ڒْعذْيَانْ نّسْ،
\m نتَّا إِڭَّا ڒْعذْيَانْ جَارْ ثِيطَّاوِينْ نّسْ. \f ◼ \fr 1:‏2 \ft \bd أَفسَّارْ\bd* - أَذْلِيسْ ن نَاحُومْ ذَايسْ إِجّْ ن ؤُصتّفْ ’أَلِيفْبَاثْ‘. مَانْ أَيَا إِخْسْ أَذْ يِينِي أَقَا عْڒَاينْ مَارَّا إِسكِّيلنْ (لْحُورُوفْ) ن ثْعِيبْرَانِيثْ تّْوَاسّْخدّْمنْ ذِي ثِيرَا-يَا، إِجّْ أَوَارْنِي إِ ونّغْنِي، كُوڒْ إِجّْ ذِي نُّوبثْ نّسْ. نْثَافْ غَارْ ؤُمزْوَارُو ن كُوڒْ ثَاسْغَارْثْ إِجّْ ن ؤُسكِّيلْ (إِجّْ ن لْحَارْفْ) ن لْحُورُوفْ ن أَلِيفْبَاثْ ن ثْمَازِيغْثْ غَارْ ؤُزدْجِيفْ ن وَاوَاڒْ أَمزْوَارُو ن ثْوِينْسْثْ. إِتّْوَافْ ؤُستّفْ-أَ وَاهَا ذڭْ وذْلِيسْ إِقدّْسنْ ن سِيذِي أَربِّي، وَارْ إِدْجِي ذڭْ ؤُڒَا ذ إِجّْ ن وذْلِيسْ نّغْنِي ذِي شَّارْقْ أَمرْوَاسُو.\f*  \x ◘ \xo 1:‏2 \xt ؤُف. 20‏:‏5\x*
\m 
\v 3 سِيذِي غَارسْ تَّاسِيعْ ن ڒْخَاضَارْ
\m ؤُ جّهْذْ نّسْ إِمْغَارْ
\m ؤُ نتَّا وَارْ إِتّْبَارِّيعمَّارْصْ
\m \add ونِّي إِتّڭّنْ دّنْبْ\add*.
\m \bd بِيثْ.\bd* أَبْرِيذْ ن سِيذِي ذِي ثْحَارْيَاضْثْ
\m ؤُ ذڭْ ؤُسمِّيضْ،
\m إِسيْنُوثنْ أَقَا أَثنْ
\m ذ ثَاعجَّاجْثْ ن إِضَارنْ نّسْ. \f ◼ \fr 1:‏3 \ft \bd ’إِسيْنُوثنْ ...‘\bd* - أَمْ مَامّشْ إِڭُّورْ بْنَاذمْ ذِي ثْعجَّاشْثْ، أَمُّو إِڭُّورْ سِيذِي أَربِّي خْ إِسيْنُوثنْ ن إِجنْوَانْ.\f*
\b
\m 
\v 4 \bd ڭِيملْ.\bd* - نتَّا إِوبّخْ ڒبْحَارْ،
\m إِتَّارَّا إِ-ث يُوژغْ،
\m مَارَّا إِغزْرَانْ إِتّجَّا إِ-ثنْ تَّاژْغنْ.
\m \bd ذَالِيثْ.\bd* بَاشَانْ ذ كَارْمَالْ سْڒَاونْ،
\m ؤُڒَا ذ نُّووَارْ ن لُوبْنَانْ إِسْڒَاوْ. \f ◼ \fr 1:‏4 \ft \bd ’بَاشَانْ ذ كَارْمَالْ ... لُوبْنَانْ‘\bd* - أَقَا-ثنْ ذ جّْوَايهْ س ڒْغِيدْجثْ أَطَّاسْ ذڭْ وُوسَّانْ ن زِيشْ.\f*
\m 
\v 5 \bd هِي.\bd* - إِذُورَارْ تَّارْجِيجِينْ زَّايسْ،
\m ؤُ ثِيوْرِيرِينْ فسّْينْثْ،
\m \bd وَاوْ.\bd* ؤُ ثَامُّورْثْ ثتّْوَاسّْڭعّذْ-د
\m زَّاثْ إِ وُوذمْ نّسْ،
\m ؤُڒَا ذ مَارَّا وِي خَاسْ إِزدّْغنْ! \x ◘ \xo 1:‏5 \xt ؤُف. 19‏:‏18؛ إِزهد. 18‏:‏8؛ 29‏:‏5، 6؛ 97‏:‏4، 5؛ 114‏:‏4\x*
\m 
\v 6 \bd زَايِينْ.\bd* - وِي إِزمَّارنْ أَذْ إِقِّيمْ إِبدّْ
\m زَّاثْ إِ وسْخضْ نّسْ،
\m ؤُ وِي إِزمَّارنْ أَذْ إِكَّارْ
\m زَّاثْ إِ ڒْحَاذُوقْ ن وغْضَابْ نّسْ؟
\m \bd خِيثْ.\bd* أَسْعَارْ نّسْ إِتّْوَاكبّْ-د أَمْ ثْمسِّي
\m ؤُ ثِيصُوضَارْ تّْوَاقدْجْعنْثْ-إِ-د زَّايسْ.
\b
\m 
\v 7 \bd ثِيث.\bd* - إِشْنَا سِيذِي
\m إِ دُّورِّي ذڭْ وَاسّْ ن ڒحْصَارثْ.
\m \bd يُوذْ.\bd* نتَّا إِسّنْ مَارَّا
\m إِنِّي غَارسْ يَاركّْوَاڒنْ. \x ◘ \xo 1:‏7 \xt يُووِ. 4‏:‏16\x*
\b
\m 
\v 8 \bd كَافْ.\bd* - \add س\add* يِيشْثْ ن ڒْحمْڒثْ إِفيّْضنْ
\m أَذْ يُوقَا أَمْشَانْ نّسْ
\m ؤُ ڒْعذْيَانْ نّسْ أَذْ ثنْ إِضْفَارْ،
\m \add أَڒْ غَا يَاذْفنْ غَارْ\add* ثَادْجسْثْ.
\b
\m 
\v 9 \bd مِيمْ.\bd* - مِينْ ثْخَارّْصمْ \add خنِّي\add* خْ سِيذِي؟
\m نتَّا أَذْ \add ث\add* إِقْضَا قَاعْ.
\m أَغُوفِي وَارْ د-إِتِّيسْ مَارْثَاينْ.
\m 
\v 10 أَقَا نِيثْنِي تّْوَامُوذنْ عَاذْ
\m أَمْ شْبَارْقْ أَكْ-ذ إِسنَّاننْ،
\m ؤُغلَّانْ أَمْ يِيمسْشَارنْ،
\m \add أَمُّو\add* إِ غَا تّْوَاشّنْ نِيثْنِي
\m قَاعْ أَمْ ؤُڒُومْ يُوژْغنْ.
\m 
\v 11 زَّايكْ إِ د-إِفّغْ
\m ونِّي إِتّْخَارّْصنْ
\m ذِي مِينْ وَارْ إِحْڒِينْ خْ سِيذِي،
\m أَمْشَاوَارْ إِ وَارْ إِسكّْوِينْ وَالُو.
\b
\m 
\v 12 أَمُّو إِسَّاوَاڒْ سِيذِي:
\m وَاخَّا نِيثْنِي تّْفڒْحنْ
\m ؤُ \add دْجَانْ\add* ذڭْ وَاطَّاسْ،
\m وَاخَّا أَمنِّي نِيثْنِي أَذْ تّْوَاقسّنْ
\m ؤُ نتَّا أَذْ إِعْذُو.
\m وَاخَّا نشّْ ڭِّيغْ خَاكْ أَغِيڒْ،
\m \add مَاشَا\add* نشّْ وَارْ خَاكْ تّڭّغْ أَغِيڒْ عَاذْ.
\m 
\v 13 ڒخُّو أَذْ أَرْژغْ أَزَايْڒُو نّسْ
\m \add إِ\add* خَاكْ \add إِمَّارْسنْ\add*،
\m ؤُ نشّْ أَذْ شَارّْڭغْ ثِيسْغُونِينْ نّشْ.
\b
\m 
\v 14 سِيذِي إِوصَّا خَاكْ،
\m أَقَا وَارْ زَّايكْ
\m إِتِّيڒِي عَاذْ حذْ س يِيسمْ نّشْ.
\m نشّْ أَذْ قضْعغْ ڒخْيَاڒَاثْ إِنقْشنْ
\m ذ \add ڒخْيَاڒَاثْ\add* إِفسْينْ زِي ثَادَّارْثْ نّشْ.
\m نشّْ أَذْ ڭّغْ أَنْضڒْ نّشْ،
\m مَاغَارْ ؤُفِيغْ شكْ ثفْسُوسذْ.
\b
\b
\c 2
\s1 أَوطُّو ن نِينْوَا
\m 
\v 1 خْزَارْ، خْ إِذُورَارْ \add تَّازّْڒنْ\add* إِضَارنْ
\m ن ونِّي د-يِيوْينْ ڒخْبَارْ أَصبْحَانْ،
\m ونِّي إِخبَّارنْ س ڒهْنَا.
\m عيّذْ ڒعْيُوذَاثْ نّشْ، \add أَ\add* يَاهُوذَا،
\m سقْفڒْ لْوُوعُوذْ نّشْ،
\m مَاغَارْ ونِّي يَاردّْدْجنْ
\m وَارْ إِتّْغِيمِي إِژكّْوِي خَاكْ عَاذْ،
\m نتَّا إِنّقْضعْ مَارَّا. \x ◘ \xo 2:‏1 \xt إِشا. 52‏:‏7؛ رُوم. 10‏:‏15\x*
\m 
\v 2 إِجّنْ ونِّي يُوژّْڒنْ \add خْ إِوْذَانْ\add* س لْعُونْفْ
\m إِ د-إِڭعّذْ خَاكْ!
\m عسّْ خْ لْبُورْجْ، حْضَا أَبْرِيذْ،
\m سمْحضْ ثِيجْعِينَّا نّشْ،
\m أَرْنِي ذِي جّْهذْ نّشْ!
\b
\m 
\v 3 س مِينْزِي سِيذِي أَذْ د-يَارّْ
\m ڒْعزّْ ن يَاعْقُوبْ،
\m \add أَقَا-ث ذ\add* ڒْعزّْ ن إِسْرَائِيل.
\m مَاغَارْ إِكشَّاضنْ كشّْضنْ ثنْ،
\m ؤُ نِيثْنِيغضْڒنْ ثِيزرْمِينْ نْسنْ. \x ◘ \xo 2:‏3 \xt إِزهد. 80‏:‏13؛ إِشا. 10‏:‏12\x*
\m 
\v 4 ثْشَابَّاثْ \add ن ؤُسڒْقِي\add*
\m ن أَيْثْ ن بُو-ثغْرُوضْثْ زوْغنْثْ،
\m إِرْيَازنْ إِمحْضنْ \add بدّنْ\add*
\m سّْوجْذنْ إِ ؤُمنْغِي
\m \add س وَارُّوضْ\add* أَزڭّْوَاغْ إِحذْقنْ،
\m غَارْ \add ثسِّيقْثْ ن\add* ثْمسِّي ن وُوزَّاڒْ
\m ن إِكَارُّوثنْ \add ن ؤُمنْغِي\add*،
\m ذڭْ وَاسّْ إِ ذِي إِ غَا إِسّوْجذْ إِخفْ نّسْ
\m ؤُ \add ثِيشجُّورَا ن\add* ؤُمرْزِي أَذْ نّْهزّنْ. \f ◼ \fr 2:‏4 \ft \bd ’أَمرْزِي‘\bd* - نِيغْ ’أَمضْزِي‘.\f*
\m 
\v 5 إِكَارُّوثنْ ن ؤُمنْغِي هَاجنْ ذڭْ إِبْرِيذنْ،
\m أَقَا ژّعْوَاضنْ زِي سَّا غَارْ ذَا
\m ذڭْ وَازَّاينْ،
\m تّْوَاضْهَارنْ أَمْ يِيصفْضَاونْ،
\m نِيثْنِي ڭمَّارنْ ذَا ذ ذِيهَا أَمْ وَاسَّامنْ.
\m 
\v 6 نتَّا إِتّْخَارّصْ ذڭْ أَيْثْ ن جّهْذْ،
\m نِيثْنِي \add مَاشَا\add* تّْنقْرَاضنْ أَمْ ڭُّورنْ
\m نِيثْنِي تَّازّْڒنْ غَارْ ڒْحِيضْ نْسنْ،
\m \add مَانِي\add* إِبدّْ سّْقفْ \add ن ؤُهْجَامْ\add* إِوْجذْ.
\b
\m 
\v 7 ثِيوُّورَا ن إِغزْرَانْ نُّورزْمنْثْ،
\m ؤُ ڒقْصَارْ أَذْ إِفْسِي.
\m 
\v 8 أَقَا ثَامسْڒَاشْثْ ثْبدّْ نِيشَانْ!
\m نتَّاثْ أَذْ ثتّْوَاعَارَّا،
\m أَذْ ثتّْوَاسّْڭعّذْ،
\m ؤُ ثِييَّا نّسْ سْغُويُّونْثْ
\m أَمشْنَاوْ أَبَارِّي ن ثذْبِيرِينْ،
\m \add أَمْ\add* شَّاثنْثْ ذڭْ إِذْمَارنْ نْسنْثْ. \f ◼ \fr 2:‏8 \ft \bd ’ذڭْ إِذْمَارنْ نْسنْثْ‘\bd* - س ثْعِيبْرَانِيثْ ’ذڭْ وُوڒَاونْ نْسنْثْ‘.\f*
\m 
\v 9 نِينْوَا أَمْ يِيجّْ ن ؤُيڒْمَامْ ن وَامَانْ
\m زڭْ وَاسّْ إِ ذِي إِدْجَا.
\m \add ڒخُّو مَاشَا\add* أَركّْوڒنْ نِيثْنِي.
\m بدّمْ! بدّمْ!، \add تّْڒَاغَانْ نِيثْنِي\add*،
\m \add مَاشَا\add* ؤُڒَا ذ إِجّْ وَارْ د-إِتّْنقْڒِيبْ.
\m 
\v 10 كشّْضمْ نُّوقَارْثْ، كشّْضمْ ؤُرغْ!
\m وَارْ ذِينْ قطُّو إِ ڒكْنُوزْ،
\m غَارْ ؤُشوَّارْ ن عْڒَامْ كُوڒْ ڒقْشُوعْ.
\m 
\v 11 ثخْوَا، ثتّْوَاكشّضْ
\m ؤُ ثتّْوَاردّدْجْ نتَّاثْ،
\m ؤُڒْ إِفْسِي ؤُشَا إِفَادّنْ فشْڒنْ،
\m تّكّْسنْثْ أَسْ ثِيجْعِينَّا مَارَّا
\m ؤُ إِغمْبَابْ نْسنْ وَارْغنْ مَارَّا. \x ◘ \xo 2:‏11 \xt أَعَوذ. 1‏:‏28؛ 20‏:‏8؛ ياش. 2‏:‏11؛ 5‏:‏1؛ 7‏:‏5؛ إِشا. 13‏:‏8، 7؛ 21‏:‏3؛ حِز. 21‏:‏12\x*
\m 
\v 12 مَانِي إِدْجَا ڒخُّو ڒْمَارْڭحْ ن وَايْرَاذنْ،
\m ذ ڒْمذْوڒْ ن وَايْرَاذنْ إِمژْيَاننْ،
\m مَانِي يُويُورْ ويْرَاذْ،
\m أَقَا-ت ذ ثَايْرَاذْثْ أَكْ-ذ ويْرَاذْ أَمژْيَانْ
\m \add أَمْ\add* ؤُڒَا ذ إِجّْ إِسّْنخْڒعْ إِ-ثنْ؟
\m 
\v 13 \add مَانِي إِدْجَا ڒخُّو\add* وَايْرَاذْ نِّي إِمزّْقنْ
\m مِينْ حْذَاجنْ ثَارْوَا نّسْ
\m ؤُ إِجيّفْ إِ ثَايْرَاذِينْ نّسْ،
\m ذ ونِّي إِشُّورنْ إِفْرَانْ نّسْ س ؤُكشّضْ،
\m ذ إِمُوشَانْ نّسْ ن ؤُذُورِّي
\m زِي مِينْ إِتّْوَاشَارّْڭنْ؟
\b
\m 
\v 14 خْزَارْ، \add نشّْ أَذْ إِڒِيغْ\add* خَاكْ،
\m \add أَمُّو إِ\add* إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ،
\m نشّْ أَذْ أَرّغْ إِكَارُّوثنْ نّشْ ذ دّخَّانْ.
\m أَذْ شّغْ سِّيفْ إِيْرَاذنْ نّشْ إِمژْيَاننْ،
\m ؤُ نشّْ أَذْ قضْعغْ ثَاكشَّاضْثْ نّشْ
\m زِي ثمُّورْثْ
\m ؤُعمَّارْصْ عَاذْ أَذْ ثتّْوَاسڒْ
\m ثْمِيجَّا ن إِرقَّاسنْ نّشْ. \f ◼ \fr 2:‏14 \ft \bd ’ثْمِيجَّا ن إِرقَّاسنْ نّكْ‘\bd* - خْزَارْ إِشا. 36‏:13، 37‏:9.\f*
\b
\b
\c 3
\m 
\v 1 \bd ؤُشْثْ خْ ثنْذِينْثْ ن إِذَامّنْ!\bd*
\m أَقَا-ت ذ أَخَارِّيقْ ذ لْعُونْفْ مَارَّا،
\m ثُوكَّارْضَا وَارْ ثتّْبذِّي شَا. \f ◼ \fr 3:‏1 \ft \bd ’ثَانْذِينْثْ ن إِذَامّنْ‘\bd* - إِخْسْ أَذْ يِينِي أَقَا ثَانْذِينْثْ-أَ ثشُّورْ س ؤُسِيزّڒْ ن إِذَامّنْ.\f*
\m 
\v 2 ڒْحسّْ ن ؤُركُّوضْ،
\m ڒْحسّْ ن ؤُقَارْقبْ ن ثْجَارَّارِينْ،
\m إِيْسَانْ إِتَّازّْڒنْ ذڭْ ونّضْ
\m ذ إِكَارُّوثنْ إِنطّْونْ.
\m 
\v 3 أَمنَّايْ إِنْيَا،
\m سِّيفْ إِتّْوسّڭْ،
\m فْڒِيثْشَا \add أَقَا-ت\add* أَمْ وَاسَّامْ.
\m أَطَّاسْ ذ إِنِّي إِتّْوَانْغنْ
\m ؤُ \add أَقَا ذِينْ\add* أَعُورِّيشْ ن إِمتَّانْ،
\m ڒْخشْبَاثْ وَارْ غَارْسنْثْ ڒْحذْ،
\m \add وَاهْ\add*، تّنْقْرَاضنْ ذِي ڒْخشْبَاثْ نْسنْ.
\m 
\v 4 زِي سِّيبّثْ ن وَاطَّاسْ ن فَارْقْ-شّْغڒْ
\m ن ثمْغَارْثْ ڒْمُوحسْنَا،
\m ن لَالَّا ن ثْسحَّارْثْ،
\m ثنِّي إِزّْنُوزَانْ ڒڭْنُوسْ س فَارْقْ-شّْغڒْ نّسْ
\m ؤُڒَا ذ \add مَارَّا\add* ڒَادْجَاثْ س ؤُسحَّارْ نّسْ،
\m 
\v 5 خْزَارْ، \add س ؤُيَا أَذْ خَامْ إِڒِيغْ\add*،
\m \add أَمُّو\add* إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ،
\m ؤُ نشّْ أَذْ سّْڭعّْذغْ
\m ثِيمُووَّا \add ن وَارُّوضْ نّمْ\add*
\m ثِيوَّا إِ ؤُغمْبُوبْ نّمْ،
\m ؤُ نشّْ أَذْ سّشْنغْ إِ ڒڭْنُوسْ ثُوعَّارْينْثْ نّمْ،
\m ؤُ ڒفْضِيحثْ نّمْ إِ ثْڭلْذِيوِينْ.
\m 
\v 6 نشّْ أَذْ شمْ ڒقْفغْ س نّْعَاوَاثْ،
\m ؤُ أَذْ شمْ سّْفضْحغْ
\m ؤُ أَذْ شمْ أَرّغْ إِ ؤُسْفُورّجْ.
\m 
\v 7 خنِّي أَذْ إِمْسَارْ
\m أَقَا مَانْ ونْ شمْ إِ غَا إِژَارنْ،
\m أَذْ زَّايمْ يَارْوڒْ، أَذْ يِينِي
\m ”\add ثَانْذِينْثْ ن\add* نِينْوَا ثْخَارّبْ!
\m وِي زَّايسْ إِ غَا إِشضْننْ؟“
\m مَانِي ذ أَمْ إِ غَا يَارْزُوغْ
\m إِنِّي شمْ إِ غَا إِسّْفوّْجنْ؟
\b
\m 
\v 8 مَا شمْ حْسنْ زِي نُو-أَمُونْ
\m نِّي إِتّْغِيمَانْ غَارْ إِغزْرَانْ،
\m أَمْ ذ أَسْ قوَّارنْ وَامَانْ،
\m \add أَڒَامِي\add* ڒبْحَارْ ذ أَشْبَارْ نّسْ ن زَّاثْ،
\m \add أَقَا\add* ڒْحِيضْ نّسْ إِڭعّذْ زِي ڒبْحَارْ.
\m 
\v 9 كُوشْ ثُوغَا ذ صُّولْطَا نّسْ، ؤُڒَا ذ مِيسْڒَا،
\m وَارْ ثُوغِي غَارسْ أَنڭَّارْ.
\m فُوطْ ذ أَيْثْ ن لِيبِييَا
\m ثُوغَا أَثنْ زڭْ إِمْعَاوْننْ نّشْ.
\m 
\v 10 ؤُڒَا ذ نتَّاثْ ثُويُورْ ذِي لْمنْفَا،
\m ذِي ثْمحْبَاسْثْ.
\m ؤُڒَا ذ إِحنْجِيرنْ نّسْ تّْوَاڒبْزنْ
\m ذِي ثْغمُّورَا ن مَارَّا ن ثبْرِيذِينْ،
\m ؤُ خْ إِمْشنّْعنْ نّسْ
\m نْضَارنْ خَاسنْ ثَاقدُّوحْثْ
\m ؤُ مَارَّا إِمْغَارنْ نّسْ
\m تّْوَاشَارْفنْ س سّْنَاسڒْ.
\b
\m 
\v 11 ؤُڒَا ذ شمْ أَذْ ثسْشَارذْ
\m أَذْ ثسّْنُوفَّارذْ إِخفْ نّمْ.
\m عَاوذْ شمْ أَذْ ثَارْزُوذْ إِجّْ ن لْبُورْجْ
\m \add إِ ؤُذُورِّي\add* زِي ڒعْذُو نّمْ.
\m 
\v 12 مَارَّا لْقلْعَاثْ نّمْ أَمْ وُورْثَانْ
\m أَكْ-ذ ڒْبَاشُورْ.
\m مَاڒَا تّْوَانْهزّنْ،
\m أَذْ وْضَانْ ذڭْ ؤُقمُّومْ
\m ن ونِّي إِخْسنْ أَذْ ثنْ يشّْ.
\m 
\v 13 خْزَارْ، أَقَا ذ وَا ذ ڒْڭنْسْ نّمْ،
\m \add أَقَا-ث ذ\add* ثِيمْغَارِينْ.
\m تّْنُورْزْمنْثْ ثوُّورَا ن ثمُّورْثْ نّمْ
\m قَاعْ إِ ڒعْذُو،
\m ثِيمسِّي أَذْ ثشّْ إِعُومَاذْ نّمْ ن وفْرَايْ.
\b
\m 
\v 14 أَيمْ أَمَانْ إِ يِيخفْ نّمْ إِ ڒحْصَارثْ،
\m سمْثنْ لْقلْعَاثْ نّمْ،
\m بدّْ ذِي ثْڒَاخْثْ،
\m عفْسْ ذِي ثَارِّيسْثْ،
\m سقْسحْ إِژْرَا إِتّْوَاسُّويْذَانْ!
\m 
\v 15 ثِيمسِّي أَذْ شمْ ثشّْ ذِينْ،
\m سِّيفْ أَذْ شمْ إِنغْ،
\m أَذْ شمْ ثشّْ أَمْ بُو-وڒْسَاحْ!
\m أَرْنِي ذڭْ إِخفْ نّمْ أَمْ بُو-وڒْسَاحْ،
\m أَرْنِي ذڭْ يِيخفْ نّمْ أَمْ ثْمُورْغِي.
\m 
\v 16 شكْ ثسّْمَارْنِيذْ ذڭْ إِسبَّابنْ نّمْ
\m كْثَارْ زڭْ إِثْرَانْ ن ؤُجنَّا.
\m بُو-وڒْسَاحْ أَذْ إِسَّارْسْ ثِيڒْمشْثْ نّسْ
\m ؤُشَا أَذْ إِضْوَا.
\m 
\v 17 ثَارْوَا ن ثَاصِيڒثْ نّمْ
\m أَمْ يِيجّْ ن ويْڒَافْ ن ثْمُورْغِي
\m ؤُ ڒْعسْكَارَاثْ نّمْ
\m أَمْ يِيخنْفُوسنْ إِمقّْرَاننْ،
\m إِنِّي يَارْسَانْ ذِي ڒحْيُوضْ
\m ذڭْ يِيجّْ ن وَاسّْ ذ أَصمَّاضْ.
\m ڒَْامِي د-ثنْقَارْ ثْفُوشْثْ،
\m طَّاونْ سّنِّي ذغْيَا.
\m وَارْ إِسِّينْ حذْ أَمْشَانْ نْسنْ.
\m مَانِي رُوحنْ نِيثْنِي؟
\m 
\v 18 إِمكْسَاونْ نّشْ تّْنُوذُومنْ،
\m \add أَيَا،\add* أَجدْجِيذْ ن أَشُّورْ،
\m أَيْثْ ن جّهْذْ نّشْ تّطّْصنْ،
\m ڒْْڭنْسْ نّشْ أَذْ ث زدْجْعنْ خْ إِذُورَارْ،
\m ؤُشَا ؤُڒَا ذ إِجّنْ وَارْ \add ثنْ\add* إِسّْمُونْ شَا.
\m 
\v 19 وَارْ ذِينْ أَسْڭنْفِي إِ ثَارژِّيثْ نّشْ،
\m إِتّكّسْ أَشْ ؤُيزِّيمْ!
\m مَارَّا إِنِّي إِ خَاكْ إِسْڒِينْ ڒخْبَارْ،
\m أَذْ شَّاثنْ ذڭْ إِفَاسّنْ زِي سِّيبّثْ نّشْ،
\m مَاغَارْ خْ مَانْ ونْ
\m وَارْ إِعدُّو شَا ڒبْذَا ڒْغَارْ نّشْ؟ 
