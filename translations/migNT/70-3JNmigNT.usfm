\id 3JN  
\h 3 Juan 
\toc1 YA'A KUU CARTA UNI JA NI CHAA SAN JUAN APOSTOL NUU TAKA ÑAYƗVƗ KAKANDIJA 
\toc2 3 Juan 
\toc3 3 Jn. 
\mt2 LA TERCERA EPISTOLA DE SAN JUAN APOSTOL 
\mt1 YA'A KUU CARTA UNI JA NI CHAA SAN JUAN APOSTOL NUU TAKA ÑAYƗVƗ KAKANDIJA 
\c 1  
\s1 Cha̱a kájika jíín tú'un ndaa̱ 
\p  
\v 1 Máá‑rí kúu máá cháa ñá'nu‑ga̱. Te cháa‑ri̱ tutu̱ yá'a nuu̱‑ro̱ Gayo máni̱, chi̱ kúndá'ú ndija ini̱‑ri̱ róó.  
\v 2 Ñáni̱ máni̱, kuní‑ri̱ ja̱ bueno ná kí'i̱n ta̱ká tiñu sá'a‑ró, jíín já ná kéndo̱o ndéé ndánu‑ro, nátu̱'un ni̱ kendo̱o va̱'a añú‑ro̱.  
\v 3 Ja̱ndáa̱ ni̱ kusɨɨ̱ xáa̱n iní‑ri̱ kɨvɨ̱ ní cha̱koyo ñani̱‑yo̱, chi ni̱ ka̱nakani‑de tu̱'un‑ró núu̱‑rí, ndasa bueno íó ndaa̱ tu̱'un ñú'un ini̱‑ro̱, nátu̱'un jíka ndaa̱‑ro̱.  
\v 4 Tuká ɨnga̱ tu̱'un kúsɨɨ̱ iní‑ri̱ sá'a ná nuu̱ yá'á, ja̱ kúni tu̱'un‑ri̱ ja̱ kájika ndaa̱ se̱'e‑ri̱ jíná'an‑i.  
\v 5 Ñáni̱ máni̱, bueno sá'a‑ró táká tiñu jíku‑ró jián jíín táká ñani̱‑yo̱, va̱sa cha̱a jíká kákuu‑de.  
\v 6 Chi cha̱a‑ún, ni̱ ka̱jani‑de tu̱'un‑ró núu̱ tɨ́ku'ni̱, ja̱ vá'a kúndá'ú ini̱‑ro̱. Te va̱'a sá'a‑ró te nú chindéé chítuu‑ró‑de chu'un íchí‑ró‑de, nátu̱'un kuní Dios.  
\v 7 Chi cha̱a‑ún, mani̱‑dé jíín‑yá, te ja̱ yúán ní ka̱ki'in‑de ichi kája'a̱n‑de, te tú káki'in‑de ni ɨɨn ndatíñu nuu̱ ñáyɨvɨ sɨ́ɨn nación.  
\v 8 Núsáá te yóó, nɨ́nɨ ná kuátá'ú‑yó cháa‑ún, náva̱'a chindéé tá'an‑yó jíín‑de sɨkɨ̱ tú'un ndaa̱. 
\s1 Ja̱ kájasu̱ nuu̱ tú'un va̱'a 
\p  
\v 9 A ni̱ chaa‑ri̱ tutu̱ nuu̱ máá tɨ́ku'ni̱. Ko Diótrefes, tú játá'ú‑de tu̱'un ká'a̱n‑ri̱, kua̱chi ja̱ kúñá'nu máá‑de nuu̱‑í kuní‑de.  
\v 10 Núsáá te nú jaa̱‑ri̱ te naxndáku‑ri̱ nuu̱‑ro̱ tíñu sá'a‑de ja̱ kátɨ́lakuá yu'u‑dé, ndasa sátú'ún‑de sɨkɨ̱‑rí. Te va̱sa a ká'a̱n‑de súan, ko tú kúva̱'a ini̱‑de. Chi̱ tú játá'ú‑de ñani̱‑yo̱ kátájí‑yó núu̱‑dé, te jasú‑de nuu̱ ñáyɨvɨ kákuni̱‑i kuatá'ú‑i‑de. Te skúnu‑de‑i ini̱ tɨku'ni̱.  
\v 11 Ñáni̱ máni̱, ma̱ sá'a‑ró nátu̱'un kásá'a cha̱a ñáá, chi̱ sua nátu̱'un kásá'a cha̱a va̱'a. Cha̱a sá'a tiñu va̱'a, se̱'e Dios kúu‑de. Ko cha̱a sá'a tiñu ñáá, tú jiní kutɨ‑dé nuu̱ Dios.  
\v 12 Ta̱ká ña̱yɨvɨ kájani ndaa̱‑i tu̱'un sɨkɨ̱ Demetrio, te suni máá tú'un ndaa̱ ká'a̱n sɨkɨ̱‑dé, te suni súan ká'a̱n máá‑rí. Te a kájini̱‑ro̱ já tú'un ká'a̱n‑ri̱ íó ndaa̱.  
\v 13 Ió kua'a̱ tú'un chaa‑ri̱ nuu̱‑ro̱ kuní‑ri̱, ko tú kuní‑ri̱ chaa‑ri̱ jíín tinta jíín pluma.  
\v 14 Chi̱ ñúkuu ini̱‑ri̱ ja̱ yakú‑na̱ kɨvɨ̱ te jaa̱‑ri̱ nuu̱‑ro̱. Yúan‑na te ndatu̱'ún jíín yú'u‑yo.  
\v 15 Ná kóo tu̱'un vindáa̱ vinené jíín‑ró. Sándéé iní‑ro̱, áchí ta̱ká amigo yá'a. Te suni ka'a̱n‑ro̱ jíín táká amigo jia̱n, ná sándéé iní‑i.