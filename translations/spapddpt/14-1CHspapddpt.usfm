\v 24 \w Todos|strong="H3605"\w* \w los|strong="H1121"\w* \w jefes|strong="H8269"\w*, \w los|strong="H1121"\w* \w valientes|strong="H1368"\w* \w y|strong="H1571"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* del \w rey|strong="H4428"\w* \w David|strong="H1732"\w* rindieron \w homenaje|strong="H3027"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w* \w Salomón|strong="H8010"\w*.   
\p
