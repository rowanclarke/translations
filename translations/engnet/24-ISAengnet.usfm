\c 7  
\p
\v 1  \w During|strong="H3117"\w* \w the|strong="H5921"\w* \w reign|strong="H3117"\w* \w of|strong="H1121"\w* Ahaz \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Jotham|strong="H3147"\w*, \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Uzziah|strong="H5818"\w*, \w king|strong="H4428"\w* \w of|strong="H1121"\w* \w Judah|strong="H3063"\w*, \w King|strong="H4428"\w* \w Rezin|strong="H7526"\w* \w of|strong="H1121"\w* Syria \w and|strong="H1121"\w* \w King|strong="H4428"\w* \w Pekah|strong="H6492"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Remaliah|strong="H7425"\w* \w of|strong="H1121"\w* \w Israel|strong="H3478"\w* \w marched|strong="H5927"\w* \w up|strong="H5927"\w* \w to|strong="H3478"\w* \w Jerusalem|strong="H3389"\w* \w to|strong="H3478"\w* \w do|strong="H3201"\w* \w battle|strong="H4421"\w*, \w but|strong="H3808"\w* \w they|strong="H3117"\w* \w were|strong="H3478"\w* \w unable|strong="H3808"\w* \w to|strong="H3478"\w* \w prevail|strong="H3201"\w* \w against|strong="H5921"\w* \w it|strong="H5921"\w*.   
\p
\v 2  \w It|strong="H5921"\w* \w was|strong="H1732"\w* \w reported|strong="H5046"\w* \w to|strong="H5921"\w* \w the|strong="H6440"\w* \w family|strong="H1004"\w* \w of|strong="H1004"\w* \w David|strong="H1732"\w*, “Syria \w has|strong="H7307"\w* allied \w with|strong="H1004"\w* Ephraim.” \w They|strong="H5921"\w* \w and|strong="H1004"\w* \w their|strong="H6440"\w* \w people|strong="H5971"\w* \w were|strong="H5971"\w* emotionally \w shaken|strong="H5128"\w*, just \w as|strong="H3824"\w* \w the|strong="H6440"\w* \w trees|strong="H6086"\w* \w of|strong="H1004"\w* \w the|strong="H6440"\w* \w forest|strong="H3293"\w* \w shake|strong="H5128"\w* \w before|strong="H6440"\w* \w the|strong="H6440"\w* \w wind|strong="H7307"\w*.  
\v 3  \w So|strong="H3318"\w* \w the|strong="H3068"\w* \nd \+w Lord|strong="H3068"\+w*\nd* told \w Isaiah|strong="H3470"\w*, “\w Go|strong="H3318"\w* \w out|strong="H3318"\w* \w with|strong="H3068"\w* \w your|strong="H3068"\w* \w son|strong="H1121"\w* \w Shear-jashub|strong="H7610"\w* \w and|strong="H1121"\w* \w meet|strong="H7125"\w* Ahaz \w at|strong="H3068"\w* \w the|strong="H3068"\w* \w end|strong="H7097"\w* \w of|strong="H1121"\w* \w the|strong="H3068"\w* \w conduit|strong="H8585"\w* \w of|strong="H1121"\w* \w the|strong="H3068"\w* \w upper|strong="H5945"\w* \w pool|strong="H1295"\w* \w which|strong="H3068"\w* \w is|strong="H3068"\w* located \w on|strong="H3068"\w* \w the|strong="H3068"\w* road \w to|strong="H3318"\w* \w the|strong="H3068"\w* \w field|strong="H7704"\w* where \w they|strong="H3068"\w* \w wash|strong="H3526"\w* \w and|strong="H1121"\w* dry cloth.  
\v 4  Tell \w him|strong="H1121"\w*, ‘Make \w sure|strong="H8104"\w* \w you|strong="H3372"\w* stay \w calm|strong="H8252"\w*! Don’t \w be|strong="H1121"\w* \w afraid|strong="H3372"\w*! Don’t \w be|strong="H1121"\w* intimidated \w by|strong="H8147"\w* \w these|strong="H8147"\w* \w two|strong="H8147"\w* \w stubs|strong="H2180"\w* \w of|strong="H1121"\w* \w smoking|strong="H6226"\w* logs, \w or|strong="H1121"\w* \w by|strong="H8147"\w* \w the|strong="H8104"\w* raging \w anger|strong="H3824"\w* \w of|strong="H1121"\w* \w Rezin|strong="H7526"\w*, Syria, \w and|strong="H1121"\w* \w the|strong="H8104"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Remaliah|strong="H7425"\w*.  
\v 5  Syria \w has|strong="H3588"\w* \w plotted|strong="H7451"\w* \w with|strong="H5921"\w* Ephraim \w and|strong="H1121"\w* \w the|strong="H5921"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Remaliah|strong="H7425"\w* \w to|strong="H5921"\w* \w bring|strong="H7451"\w* \w about|strong="H5921"\w* \w your|strong="H5921"\w* demise.  
