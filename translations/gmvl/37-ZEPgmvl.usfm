\id ZEP - Gamo Full Bible final version
\h Sofonaasa Tinbite
\toc1 Sofonaasa Tinbite
\toc2 Sofonaasa Tinbite
\toc3 Sofo
\mt1 Sofonaasa Tinbite
\imt1 Giddo Qofa
\ip Nabe Sofonaasi ba kiitaa Kirstoosi yelettanaappe sinththan laappunththa xeeta layththay baggafe aadhdhishin aaththides; he wode kawo Yosyaasi Kirstoosi yelettanaappe kase usuppun xeetanne nam7u tammanne issi layththan caaqo qaalay ooraxanaappe tammu layththafe sinththan gidontta aggenna. Ha maxaafazi hara nabeti yootida tinbitera gayttiza tinbite oykkides. Heytikka Yuhuday eeqa xoossatas goynnida gaason qixaatey izi bolla gakkiza wode iza mulera dhayanayssa besseettes. Hessaththoka GODAY he wode hara kawoteththata qaxxayanayssaka yootees. Yerusalaamey laalettikokka daro layththatappe guye katamaya kase ba diza mala hanana; ashketinne xilloteth kaalliza asay izin de7ana.
\iot Ha Maxaafay Oykkida Kumeththa Qofa
\io1 Yuhuda bolla yaana pirda \ior 1:1-18\ior*
\io1 Maaroteththan gelo \ior 2:1-3\ior*
\io1 Isra7eele shoorota bolla yaana pirda \ior 2:4-15\ior*
\io1 Yuhudaynne hara kawoteththati GODAAKKO simmana \ior 3:1-20\ior*
\c 1
\p 
\v 1 Amoxe naa Iyosiyaasi Yuhudan kawotida wode Hizqiyaasa naa, Amaariya naa, Godoliyaasa naa, Kuushe naa Sofonaasakko yida GODAA qaalay hayssafe kaallizayssa.\x - \xo 1:1 \xt 2Kawo 22:1—23:30; 2Taari 34:1—35:27\x*
\s1 Godaappe Yaana Pirda
\p 
\v 2 GODAY, «Tani biitta bolla
\q2 dizaaz ubbaa dhayssana» gees.
\p 
\v 3 GODAY, «Asenne medosata dhayssana;
\q2 salo kafotanne abba giddon diza
\q2 moleta ta dhayssana;
\q2 ta asa zereth biitta bollafe
\q2 dhayssiza wode
\q2 iitati laalettida buura doore mala
\q2 gidana» gees.
\p 
\v 4 GODAY, «Tani Yuhudaninne
\q2 Yerusalaamen diza
\q2 as ubbaa qaxxayana;
\q2 qasseka Ba7aale,
\q2 istta eeqa xoossatanne
\q2 laymatiza qeeseta hayssafe ta
\q2 milxi histta dhayssana.\x - \xo 1:4-7 \xt Isa 14:29-31; Er 47:1-7; Hizi 25:15-17; Iyu 3:4-8; Amo 1:6-8; Zaka 9:5-7\x*
\q1 
\v 5 Fooqe bolla kezidi
\q2 salo medheteththatas
\q2 goynnizayta,
\q2 GODAAS goynnishenne
\q2 iza sunththan caaqqishe
\q2 simmi wodhidi qasse
\q2 Milkkoome sunththan
\q2 caaqqizayta,
\q1 
\v 6 GODAA kaallanaappe guye
\q2 simmizayta,
\q2 GODAA koyonttayta,
\q2 izi istta maaddana mala
\q2 oychchonttayta
\q2 ta dhayssana» gees.
\q1 
\v 7 GODAA gallassay matida gishshas
\q2 Ubbaa haariza GODAA sinththan
\q2 co7u giite;
\q2 GODAY yarsho giigsides;
\q2 ba xeygidayta baas dummasides.
\q1 
\v 8 «GODAA yarsho gallas
\q2 daannatanne kawoza nayta,
\q2 imaththa may7o may7izayta
\q2 ubbaa ta qaxxayana.
\q1 
\v 9 He wode allaga xoossata
\q2 pengen guppizayta,
\q2 bantta godata keeththaa
\q2 makkallateththaninne
\q2 baleththon kunththizayta
\q2 ta qaxxayana» gees GODAY.
\p 
\v 10 GODAY, «He wode
\q2 mole penge baggara waasoy,
\q2 katamaas nam7anththo
\q2 dubbushan yeehoy,
\q2 zumbullata bolla
\q2 gita shiroy siyettana.
\q1 
\v 11 Intteno Makitesha giyan
\q2 dizaytoo! Waassite;
\q2 gaasoykka izan zal7iza
\q2 zal7anchchati
\q2 ubbay wurana;
\q2 biran zal7izaytikka
\q2 ubbay hayqqana.
\q1 
\v 12 He wode ta Yerusalaame giddoza
\q2 xomppera koyana;
\q2 aykko hirgay baynda
\q2 badhdhi gi uttidayta,
\q2 woyne ushshu gacci ekkichchiin
\q2 orcco bolla attida
\q2 woyne ushsha mala gididayta,
\q2 ‹Iita gidiin woykko lo7o gidiin
\q2 GODAY aykkoka ooththenna›
\q2 gizayta ta qaxxayana.
\q1 
\v 13 Istti haarida haaroy bonqqettana;
\q2 istta keeththay laalettana;
\q2 istti keeth keexxanashin
\q2 ba keexxida keeththan deettenna;
\q2 woyne mith tokkanashin
\q2 ba tokkida woynezappe oosettida
\q2 ushshaa uyettenna» gees.
\s1 Wolqqama Godaa Gallassa
\b
\q1 
\v 14 «GODAAPPE yaana
\q2 gita gallassay matides;
\q2 hessika eeson yaana;
\q2 GODAA gallassan siyettana
\q2 yeehoy camo;
\q2 heen olanchchati
\q2 camo waaso waassana.
\q1 
\v 15 He gallassay bashsha gallas,
\q2 metonne ceece gallas,
\q2 shironne dhayssa gallas,
\q2 dhuma gallassinne tulala gallas,
\q2 Shaaranne girdi gida dhuma
\q2 gallas gidana.
\q1 
\v 16 He gallassay
\q2 gimbettida katamata bollanne
\q2 adussa gimbeta bolla
\q2 ola zayeynne
\q2 ola waasoy
\q2 siyettiza gallas gidana.
\q1 
\v 17 Asay qooqeththo hemettana mala
\q2 asaa bolla tani ceece yeddana;
\q2 asay GODAA bolla nagara
\q2 ooththida gishshas
\q2 istta suuththi di7o mala gukkana;
\q2 istta ahaykka
\q2 buura mala olettana.
\q1 
\v 18 GODAA bashsha gallas
\q2 istta biraynne worqqay
\q2 istta ashshanaas dandayenna.
\q2 Biittay kumeth
\q2 iza hanqon dhayana;
\q2 iza zil7eteththa suulen
\q2 biitta ubbay xuugettana;
\q2 biitta bolla diza ubbaa bolla
\q2 qoppontta dishin wurseth ehana»
\q2 gees GODAY.
\c 2
\p 
\v 1 Intteno yeellay baynda deretoo!
\q2 Ane issi bolla shiiqite!
\q1 
\v 2 Bashsha gallassay
\q2 gakkanaappe kasetidi,
\q2 he gallassay suulla mala denththi
\q2 dhayssontta dishin,
\q2 GODAAPPE mino hanqoy
\q2 intte bolla yontta dishin
\q2 GODAAPPE bashsha gallassi
\q2 intte bolla gakkontta
\q2 dishin shiiqite.
\q1 
\v 3 Intteno biitta bolla diza ashketoo;
\q2 iza azazokka polizaytoo!
\q2 GODAA koyite;
\q2 Xilloteththinne ashketeth koyite;
\q1 GODAA hanqo gallassafe
\q2 intte attanaakko
\q2 oonee erizay!
\s1 Filisxeeme Dere Bolla Yootettida Pirda
\p 
\v 4 Gaazay bula biitta gidana;
\q2 Asqeloonaykka laaletta attana.
\q2 Azaxooney seeta gallas kayzana.
\q2 Aqarooney shodettana.
\q1 
\v 5 Intteno abba achchan dizaytoo!
\q2 Kelite dere asatoo,
\q2 inttes aayye ana!\f + \fr 2:5 \fqa Kaalite dere asata: \ft Kaalite dere asata guussi Filisxeeme asata guussa.\f*
\q2 Filisxeeme dere asay diza
\q2 Kanaane biittayee!
\q2 ne bolla yootettida
\q2 GODAA qaalay
\q2 hayssafe kaallizayssa;
\q2 «Ta nena mulera dhayssana;
\q2 nenan diza asappe
\q2 attana asi deenna.
\q1 
\v 6 Kaalite asay diza
\q2 abba achcha biittay
\q2 heenththanchchata duussasonne
\q2 dorsa yire gidana.
\q1 
\v 7 Hessika Yuhudappe casha
\q2 attidaytas gidana;
\q2 isttika heen baas
\q2 aqota demmana;
\q1 Gadey qammishin
\q2 Asqeloona kataman diza
\q2 keeththatan aqana;
\q2 GODAY istta Xoossay
\q2 istta naagana;
\q2 isttafe di7ettidayssaka
\q2 isttas zaarana.»
\s1 Mo7aabe Bollanne Amoone Bolla Yootettida Pirda.
\p 
\v 8 GODAY,
\q1 «Mo7aabe asay cayizayssanne
\q2 Amoone asay qidhizayssa
\q2 ta siyadis.
\q2 Ta deraa cayida;
\q2 istti ta deraa bollaka
\q2 mandida» gees.\x - \xo 2:8-11 \xt Isa 15:1—16:14; 25:10-12; Er 48:1—49:6; Hizi 21:28-32; 25:1-11\x*
\q1 
\v 9 Hessa gishshas GODAY Ubbaafe
\q2 Wolqqama Isra7eele Xoossay,
\q2 «Tani ta de7o
\q2 Xoossateththan caaqqays;
\q2 Mo7aabey Sodoome mala
\q2 Amooney Gamoora mala,
\q2 sharafay may7idaso malanne
\q2 maxine bookki ekkida olla mala
\q2 mernaas bula gidana.
\q2 Ta asaappe casha attidayti
\q2 istta haaro bonqqananne
\q2 istta biittaa laattana» gees.\x - \xo 2:9 \xt Medhe 19:24\x*
\q1 
\v 10 Bantta otoroteththafe dendidayssan
\q2 istti Ubbaafe Wolqqama
\q2 Xoossa deraa cayida
\q2 gishshassinne
\q2 qidhida gishshas
\q2 hessi istta bolla gakkana.
\q1 
\v 11 GODAY he biitta eeqa xoossata
\q2 ubbaa dhayssiza wode
\q2 izi istta yashissizayssa gidana;
\q2 Abba achchan diza dereti ubbay
\q2 issoy issoy ba dizason dishe
\q2 izas goynnana.
\s1 Tophphiya Bollanne Asoore Bolla Yootettida Pirda
\b
\q1 
\v 12 «Intteno Tophphiya asatoo!
\q2 Intte ta mashshan siifettana.»\x - \xo 2:12 \xt Isa 18:1-7\x*
\q1 
\v 13 Izi ba kushe pudeha baggan diza
\q2 dereta bolla denththana;
\q2 Asoore dhayssana.
\q2 Nannawekka bulasana;
\q2 bazzo biitta mala melissana.
\q1 
\v 14 Dorsa wudeynne mehe wudey,
\q2 medheteththaafe ubbaa qommoy
\q2 heen shempana.
\q2 Guttoynne Quxarsi
\q2 izi gimbetan aqana.
\q2 Istta waasoy maskootetara
\q2 seetettana.
\q2 Gimbeza laaleththi issaa
\q2 issaa pengen doorettana;
\q2 keeththata tookki eqqida
\q2 ziga godati kallottana.
\q1 
\v 15 Kase ufayssan diza
\q2 katamaya hanno;
\q2 izakka ba wozinan,
\q2 «Ta xalla days;
\q2 taappe haray
\q2 oonikka deenna» gidaara
\q2 histtiin ha7i waanada
\q2 wora do7ati guurizaso
\q2 bazzo biitta gida attadee?
\q2 Izi achchara aadhdhi biza ubbay
\q2 izo qidhishe ba kushe wuxxees.\x - \xo 2:13-15 \xt Isa 10:5-34; 14:24-27; Naho 1:1—3:19\x*
\c 3
\s1 Yerusalaames Sinththafe Yaana Qaada
\q1 
\v 1 Makkallanchchayssinne tunidaaris,
\q2 as un7eththizayta katamays
\q2 aayye ana!
\q1 
\v 2 Iza oonaska azazettuku;
\q2 ooni zoriinkka ekkuku;
\q2 GODAANKKA ammanettuku;
\q2 ba Xoossakokka shiiqukku.
\q1 
\v 3 Izo kaaleththizayti
\q2 xaaggiza gaammo mala.
\q2 Izo ayssizaytikka
\q2 wontos ashshontta
\q2 miza kana suyte mala.
\q1 
\v 4 Izin diza nabeti otoranchchatanne
\q2 as baleththizayta.
\q2 Qeeseti Xoossa Keeththa
\q2 tuniseettes;
\q2 woga bollaka makkalleettes.
\q1 
\v 5 Izin diza GODAY izi xillo.
\q2 Mulekka baletti erenna;
\q2 maalado maalado suure pirdees;
\q2 ubbaa gallassika daaburi erenna;
\q2 gido attiin makkallanchchatas
\q2 yeellay deenna.
\q1 
\v 6 GODAY, «Tani dereta dhayssadis;
\q2 istta miixay mulera dhaydes;
\q2 oonikka izara aadhdhontta mala
\q2 istta oge kayzisadis;
\q2 istta katamati mulera dhayda;
\q2 issi asikka deenna;
\q2 isttan de7anaykka deenna.
\q1 
\v 7 Ta he katamayo,
\q2 Tumappe neni taas yayyana;
\q2 ta seerishin ne ekkana gadis shin;
\q2 hessa gishshas
\q2 izi duussasoy dhayenna;
\q2 izi bolla qixaatey gakkenna.
\q2 Gido attiin ta derey iita ooson,
\q2 kaseppe gede
\q2 minni minni bides» gees.
\b
\q1 
\v 8 GODAY,
\q1 «Hessa gishshas ta pirdana
\q2 gallassay gakkanaas diishshite;
\q2 tani dere asanne
\q2 kawota shiishshanaas qachchadis.
\q2 Tani ta mino hanqoza istta bolla
\q2 gussanaas qachchadis.
\q2 Ta hanqo taman
\q2 kumeththa biittay eexxana.
\m 
\v 9 He wode asay ubbay
\q2 GODAA sunth xeygana malanne
\q2 sigan izas haggazana mala
\q2 ta istta doona geeshshana.
\q1 
\v 10 Tophphiya shaafatappe
\q2 he pinththan laaletti dishe
\q2 taas goynniza ta derey
\q2 taas yarsho ehana.
\q1 
\v 11 Intte ta bolla polida qoho
\q2 ubbaafe dendidayssan;
\q2 he gallas yeellatekketa;
\q2 ba otoreteththan ufayettizayta,
\q2 hanno ha katamayppe ta diggana.
\q2 Hessafe guye ta geeshsha zuman,
\q2 intte ta bolla otoretteketa.
\q1 
\v 12 GODAA sunththan ammanettiza;
\q2 ashketanne banttana
\q2 kawushshizayta;
\q2 ta intte giddon ashshana.
\q1 
\v 13 Isra7eeleppe casha attidayti
\q2 nagara oosettenna.
\q2 Wordo haasayettenna;
\q2 Istta doonankka
\q2 gene haasayay deenna.
\q2 Hessa gishshas istti miidi
\q2 saron de7ana;
\q2 istta babisana miishshika deenna.\x - \xo 3:13 \xt Ajju 14:5\x*
\q1 
\v 14 Hanne Xiyoone nayee ane yexxa!
\q2 Isra7eele asawu ane ililite!
\q2 Hanne Yerusalaame nayee!
\q2 Kumeththa wozinappe ufayetta!
\q2 Ufayettashe hashshu ga!
\q1 
\v 15 GODAY ne bolla
\q2 yiza qixaateza diggides;
\q2 ne morkketakka neeppe zaarides.
\q2 GODAY Isra7eele kawoy
\q2 nenara dees;
\q2 hayssafe guye
\q2 ay iitasikka babbaka.
\q1 
\v 16 He wode asay Yerusalaames,
\q2 ‹Xiyoone ne babbofa;
\q2 ne qesey daaburoppo.
\q1 
\v 17 GODAA ne Xoossay nenara dees;
\q2 izi ashshiza mino olanchcha.
\q2 Izi nenan daro ufayettees;
\q2 izi ba siiqon nena woppisana;
\q2 ne yeththan izi bonchchettidi
\q2 ufayettana› gaana.
\b
\q1 
\v 18 «Bonchcho ba7aale gallassati
\q2 attida gishshas
\q2 neni muuzottidayssanne,
\q2 nees tooho gidida yeellaa
\q2 ta neeppe diggana.
\q1 
\v 19 He wode nena un7eththidayta
\q2 ta qaxxayana.
\q2 Wobbeta ta ashshana;
\q2 laalettidaytakka
\q2 ta shiishshana.
\q2 Istti kawuyida dere ubbaan
\q2 ta istta bonchchosinne
\q2 sabas gaththana.
\q1 
\v 20 He wode ta inttena shiishshana;
\q2 intte dere ta inttena zaarana.
\q2 Intte intte ayfera beyishin,
\q2 inttefe di7ettida miishshaa
\q2 ta inttes zaariza wode
\q2 biitta bolla diza
\q2 dere ubbaa sinththan
\q2 ta inttes sabanne
\q2 bonchcho immana» gees.
