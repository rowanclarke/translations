\id 3JN stc-653JN-Nat.sfm, 3 John, Natqgu (Santa Cruz) STC, Daniel Boerger, 11/07/2007
\ide UTF-8
\h 3 Jon
\toc3 3 Jon
\toc1 Nzryrkr Jon Kratq
\toc2 3 Jon
\mt1 Nzryrkr Jon Kratq
\imt1 Natq Ngr Nzaplxtqngr Mz Nzryrkr Jon Kratq
\ip Mc ‘Natq Ngr Nzaplxtqngr Mz Nrpakxmrlz Kx Yr Jon.’ Mwx yrle letz lc mz yiz 90 o 91 AD mz nibr nzrmcngr mz Jiszs. Jon yrbzle letz kratq lc mz kzdq ncblo drtqde Gaizs. Ycmnetr-ngrde kxnamu lrmakxtr nzokatr-krdr krkcng tzvzpxng mz nzyapwxtipx-krdr Nrpakxmrlz. Rpile kx nqmq kr Gaizs mrlz murde okatrle nidr, a' nqmq kr Diotrifes trka, murde atrkatile nidr. X rpi-kzpzle mz Gaizs kx narlr-ngrbzle mz Demitrizs nzalvztr-krde mz makxtr nyzdr. Mwx Jon kabzle letz lc mz Demitrizs mz nztwz-krbzlele mz Gaizs.
\c 1
\p 
\v 1 Nim la, Gaizs. Ninge Jon, kxaclvele lrmakxtr. Mrlzti-angidr-zlwzx nim.
\v 2 Mrlxnge mz Kraes, krka'-ngrne kx da amrlx namrlzbz bam, x naxplrq mz nrkrdrtq, da kc tqwai nzxplr-krm mz nzrlxngiti-krm.
\v 3 Eu, abrtztx-zlwz-ngrne nzxlr-krnge nrpa kx nzrlwa-ngrmqng kzdung kztegung kx nzvzmqng mrka. Nzrpilr kx vz-nqblq-zvzpeq nzmncngr angidr mz nzlolvz-amqngi-krm Nrpakxmrlz.
\v 4 Nzabrtz-krnge myapx-esz'ngr nzxlr-krnge nzvz-zvzkr doa nengeng mz nzvz-nqblq-krdr nzmncngr angidr.
\s1 Nzmrlzkr Nqmq Kr Gaizs
\p 
\v 5-6 Mrlxnge, mzlegung kcng tzvzpxng mz nzalvztr-krdr Nrpakxmrlz, nzyapwxtipxpebzlr mz lrmakxtr mrka nzmrlz-krbz nivz lrm badr. X nzrpi-kzlr kx nzokatr-krm nidr vz zvz, kxmule-esz' trkrlzwq nidr. X abrtztx-ngrne nzokatr-krm nidr mz nzmncngr kx takitrde nzaxvctr-krbzme mz Gct. X da kx mrlzm bange nzxlr-krngele, mzli kc narkalz-ngrmlr mztea nyzm, kabzme da kcng amrlx naokatrle nidr, mz nzlepx-krdr Nrpakxmrlz.
\v 7 Murde nzvzneng mz nzwztr-krbzlr mz Kraes, a' trnzrtwzpwzung dalr nzwz-krdr mz leplz kxnzmnc-mrbrng kcng tzryapwxne badr.
\v 8 Mz nzmu-krde lcde, takitrde nigu lrmakxtr nzokatr-krgu nidr, mz nzngi-kzte-krgu badr mz nzwzkr Kraes.
\s1 Bzkq Vz-nqblqq Nqmq Kr Diotrifes
\p 
\v 9 Yrbo da lc mz lrmakxtr mz mztea nyzmu. X pipxpebo nzmncngr angidr mz nzokatr-krmu leplz kcng tzvzneng mz nzalvztr-krdr Nrpakxmrlz. A' Diotrifes kc tqrtulrtr-lzbq mz nzngini-krde kxrmailz, trlxngitileu nike pibo bamu.
\v 10 X mzli kc navz-ngrbo, sa nayapwxtipxbo nqmq krde mz lrmakxtr nyzmung, mz nzpiti-krde ninge mz natq kxtrka x nzpokia-krde. X da kx trka zlwz, pxtxpx-ngrde nzadwatr-krde leplz lcng mz ma nyzde. X da kxtrkatx-esz'ngr kz, rpwa'-ngrbzle mz leplz kcng tzrpilr na-adwatrng mz ma nyzdr, x aprtxpxle nidr mz makxtr.
\v 11 Mrlxnge, bzkq vz-nqblqq nqmq krde lcng tqtrka. A' vz-nqblqpwz nzmncngr kxtubq, murde krkc tqalele da kxtubq, nide doa ne Gct. A' krkc tqalele da kxtrka, trtxpnzngr nzkrlz-krde Gct.
\s1 Nzokatrngr Demitrizs
\p 
\v 12 Mzli kc navz-ngrm Demitrizs mz nzalvztr-krde mz makxtr nyzmu, naokatramu nide. X nim, kx Gaizs, na-adwatrq nide ma nyzm. Murde trtxpnzngr da kx trkatrpz bade, x leplz amrlx nzrpilr kx nide ncblo kxmrlz. Krlzq kx trkrlzwxu nzpokiangr, x napi-zpwxbo bamu kx nzalvztr-krdeng tubq.
\s1 Natq Ngr Nzarlr-lzbqngr
\p 
\v 13 Da kqlu kx suti drtwrnge napibo bam, a' trpengr nzyro-krboleng mz letz lc.
\v 14 Murde rpix kx navzbo bam mz nzycmnetr-krgi mz da kxkqlu.
\v 15 Kztem kcng mrka nzrpibzlr bam kx, “Nim la.” X pibz mz kztenge kcng mrla amrlx kx rpibo badr kx, “Nimu la.” Eu, nim lape. Krka'-ngrne kx nakabz Gct nzmnc-zpwxngr bam.
\cls Delape. Mrlztix nim. Ninge \sig Jon. \sig* 
