\id HOS
\h Hosea
\toc1 Hosea
\toc2 Hosea
\toc3 Hosea
\mt1 Hosea
\c 1
\s1 HOSEA.
\q1 
\v 1 K A OLELO a Iehova ia Hosea, ke keiki a Beeri, i na la o Uria, o Iotama, o Ahaza, a o Hezekia, na'lii o ka Iuda; a i na la o leroboama ke keiki a Ioasa, ke alii o ka Iseraela.
\b
\q1 
\v 2 O ka mua o ka olelo a Iehova ma Hosea. Olelo mai la o Iehova ia Hosea, e hele oe, a e lawe i wahine moe kolohe nau, a i na keiki moe kolohe hoi: no ka mea, ua moe kolohe nui ko ka aina, i ka haalele ana ia Iehova.
\q1 
\v 3 A hele aku la ia, a lawe ia Gomera, ke kaikamahine a Dibelaima; a hapai ae la oia, a hanau mai la he keikikane nana.
\q1 
\v 4 A olelo mai la o Iehova ia ia, e kapa aku i kona inoa, o Iezereela; no ka mea, aole liuliu aku, a e hoopai aku au i ke koko o Iezereela maluna o ko ka hale o Iehu; a e hoopau auanei au i ke aupuni o ko ka hale o ka Iseraela.
\q1 
\v 5 A i kela manawa e haki no ia'u ke kikoo o ka Iseraela ma ka papu o Iezereela.
\b
\q1 
\v 6 Hapai hou ae la oia, a hanau mai la, he kaikamahine. Olelo mai ke Akua ia ia, e kapa aku i kona inoa, o Loruhama, no ka mea, aole au e aloha hou aku i ko. ka hale o ka Iseraela; aka, e lawe loa aku au ia lakou.
\q1 
\v 7 Aka, e aloha aku au i ko ka hale o ka Iuda, a e hoola aku au ia lakou ma o Iehova la ko lakou Akua; aole au e hoola ia lakou ma ke kikoo, a me ka pahikaua; aole ma ke kaua, aole hoi ma na lio, a ma na hoohololio.
\b
\q1 
\v 8 A i ka wa i ukuhi aku ai oia ia Loruhama, hapai ae la oia, a hanau mai he keikikane.
\q1 
\v 9 I mai la ke Akua, E kapa aku i kona inoa, o Loami; no ka mea, aole oukou he poe kanaka no'u, aole auanei hoi au he Akua no oukou.
\b
\q1 
\v 10 Aka, e like auanei ka lehulehu o na mamo a Iseraela, me ke one o ke kai, aole e hiki ke anaia, aole hoi ke heluia; a ma kahi i oleloia'i lakou, Aole o ko'u poe kanaka oukou, malaila e oleloia'i lakou, He poe keiki oukou na ke Akua ola.
\q1 
\v 11 A e hoakoakoaia mai na mamo a Iuda, a me na mamo a Iseraela, ma kahi hookahi, a e hoonoho lakou i hookahi alii no lakou; a e pii ae la lakou mai ka aina mai; no ka mea, nani ka manawa o Iezereela.
\c 2
\b
\q1 
\v 1 O Ami, a i ko oukou mau hoahanau wahine, O Ruhama.
\q1 
\v 2 E hakaka oukou me ko oukou makuwahine, e hakaka oukou; No ka mea, aole oia o ka'u wahine; Aole hoi wau o kana kane: I haalele ai oia i kona hookamakama ana mai kona maka aku, A me kona moe kolohe hoi mai waena aku o kona mau u:
\q1 
\v 3 O wehe aku au ia ia a olohelohe, A e hooku ia ia e like me ia i ka la ana i hanau ai, A e hoolilo ia ia e like me ka waoakua, A e hooku hoi ia ia e like me ka aina maloo, A e pepehi ia ia i ka makewai.
\q1 
\v 4 Aole au e aloha aku i kana poe keiki, No ka mea, he poe keiki lakou na ka moe kolohe.
\q1 
\v 5 No ka mea, ua moe kolohe ko lakou makuwahine, Ua hana hilahila ka mea nana lakou i hapai: No ka mea, i iho la ia, E hele aku au mamuli o kuu mau ipo, Ka poe i haawi mai i ka'u ai, a me ko'u wai, i ko'u hulu hipa, a me kuu olona, o ko'u aila, a me ko'u mea inu.
\b
\q1 
\v 6 No ia mea, aia hoi, e hoopuni au i kou ala i na laau kuku, A e hana au i papohaku nona, I mea e loaa ole ai ia ia kona mau alanui.
\q1 
\v 7 A hahai aku no ia i kona mau hoaaloha, aole e loaa lakou ia ia; A imi aku hoi ia ia lakou, aole e loaa; Alaila, e i iho ia, E hele au, a e hoi hou i kuu kane mamua; No ka mea, ua oi aku ko'u pono i kela wa mamua o keia.
\b
\q1 
\v 8 Aole oia i noonoo, ua haawi aku au ia ia i ka mea ai, a me ka waina hou. a me ka aila, A hoomahuahua aku hoi i ke kala, a me ke gula nona, Na mea a lakou i hoomakaukau ai no Baala.
\q1 
\v 9 No ia mea, e hoi hou mai au, a e lawe aku i ka'u palaoa i kona manawa, A me ka'u wain a hou i kona manawa iho, E lawe aku hoi au i ko'u hulu hipa, a me ko'u olona, na mea i uhi ai i kona olohelohe.
\q1 
\v 10 Ano e hoike aku au i kona mea hilahila imua o na maka o kona mau hoaaloha, Aohe mea e hoopakele ia ia mai ko'u lima aku.
\q1 
\v 11 A e hoopau aku au i kona lealea a pau, I kana mau ahaaina, i kona mau mahina hou, i kona mau la Sabati. a me kona mau ahaaina a pau.
\q1 
\v 12 A e luku aku au i kona mau kumuwaina, a me kona mau laau fiku, i na mea ana i i mai ai, Oia ka'u uku, o ko'u mau ipo i haawi mai ai ia'u; A e hoolilo au ia mau mea i ululaau, A e ai iho na holoholona ia mau mea.
\q1 
\v 13 A e hoopai aku au maluna ona i na la o na Baala, I na la ana i kuni ai i ka mea ala no lakou; A i kahiko ai ia ia iho i kona mau apo-ihu, a me kona mau lei-a-i, A hahai no ia mamuli o kona mau ipo, A hoopoina ia ia'u, wahi a Iehova.
\b
\q1 
\v 14 Nolaila, aia hoi, e hoowalewale au ia ia, a e alakai aku ia ia i ka waonahele, A e olelo oluolu aku ia ia.
\q1 
\v 15 A e haawi aku au nona i kona mau malawaina mailaila mai, A i ke awawa o Akora, i puka o ka manaolana; A e mele no ia malaila, e like me ia i kona wa opio, A e like me ia i ka wa ana i puka mai ai mai ka aina o Aigupita mai.
\q1 
\v 16 A i kela manawa, wahi a Iehova, e kapa mai oe ia'u o Isi; Aole e kapa hou ia'u, o Baali.
\q1 
\v 17 A e lawe ae au i ka inoa o na Baala mai kona waha aku, Aole e hoomanao hou ia lakou ma ko lakou inoa.
\q1 
\v 18 A i kela manawa e hana aku au no lakou i berita Me na holoholona o ke kula, a me na manu o ka lewa, A me na mea kolo o ka honua: A e haki ia'u ke kakaka, a me ka pahikaua, a me ka mea kaua mai ka honua aku, A e hoomoe iho au ia lakou me ka maluhia.
\q1 
\v 19 E hoopalau aku au ia oe na'u a mau loa aku; A e hoopalau aku au ia oe na'u ma ka pono, a ma ka hoopono, a ma ka lokomaikai, a ma ke aloha.
\q1 
\v 20 A e hoopalau aku no hoi au ia oe na'u ma ka oiaio: A e ike aku oe ia Iehova.
\b
\q1 
\v 21 A i kela manawa, e hoolohe no au, wahi a Iehova, E hoolohe no au i na lani, a e hoolohe lakou i ka honua;
\q1 
\v 22 A e hoolohe ka honua i ka ai, a me ka waina, a me ka aila; A e hoolohe no lakou ia Iezereela.
\q1 
\v 23 A e kanu iho au ia ia ma ka honua; A e aloha aku au i ka mea i aloha ole ia; A e olelo aku au i ka poe kanaka aole no'u, O oe ko'u poe kanaka; A e olelo mai hoi lakou, O oe ko makou Akua.
\c 3
\b
\q1 
\v 1 A LAILA olelo mai la o Iehova ia'u, E hele hoi, e aloha aku i ka wahine i alohaia e ka hoalauna, aka, ke moe kolohe nae: E like me ke aloha o Iehova i na mamo a Iseraela, I ka poe e huli ana i na akua e, A e makemake hoi i na pai huawaina.
\q1 
\v 2 A kuai aku la au ia ia na'u i na kala he umikumamalua a me ka homera a me ka hapalua o ka homera bale:
\q1 
\v 3 A i aku la au ia ia, E kali oe ia'u i na la he nui, Aole oe e hele i ka moe kolohe, Aole oe e lilo i ke kanaka e ae: Pela hoi e lilo ai au nau.
\q1 
\v 4 No ka mea, he nui na la e noho ai na mamo a Iseraela, aohe alii, aohe haku, aohe mohai, aohe kii, aohe epoda, aohe terapima:
\q1 
\v 5 Mahope iho e huli mai na mamo a Iseraela, a imi ia Iehova ko lakou Akua, a me Davida ko lakou alii; A e makau lakou ia Iehova, a me kona lokomaikai i na la mahope.
\c 4
\b
\q1 
\v 1 E HOOLOHE oukou, e na mamo a Iseraela, i ka olelo a Iehova: no ka mea, he hakaka ko Iehova me na kanaka o ka aina; No ka mea, aohe oiaio, aohe aloha, aohe ike i ke Akua ma ka aina.
\q1 
\v 2 O ka hoohiki ino, ka hoopunipuni, ka pepehi kanaka, ka aihue, a me ka moe kolohe, ka lakou i hoomahuahua ae ai, a pili aku no ke koko i ke koko.
\q1 
\v 3 No ia mea, e kanikau auanei ka aina, A e nawaliwali na mea a pau e noho ana maluna ona, Me na holoholona o ke kula, a me na manu o ka lewa; Oia, e laweia'ku hoi na ia o ke kai.
\b
\q1 
\v 4 Aka, mai hakaka kekahi kanaka, aole hoi e papa aku ia hai: No ka mea, o kou poe kanaka, ua like lakou me ka poe e hakaka ana me ke kahuna.
\q1 
\v 5 Nolaila e hina oe i ke ao, O ke kaula hoi, e hina pu ia me oe i ka po; A e luku aku au i kou makuwahine.
\b
\q1 
\v 6 Ua lukuia ko'u poe kanaka no ka ike ole: No ka mea, ua hoowahawaha oe i ka ike, E hoowahawaha aku hoi au ia oe, Aole oe e malama i ka oihanakahuna na'u: A no kou hoopoina ana i ke kanawai o kou Akua, Owau hoi kekahi e hoopoina i kau poe keiki.
\b
\q1 
\v 7 E like me ko lakou nui ana, pela lakou i hana hewa mai ai ia'u: A e hoololi au i ko lakou nani i mea hilahila.
\q1 
\v 8 Ua ai lakou i ka hewa o kuu poe kanaka, A ua kau i ko lakou mau naau ma ko lakou la hala.
\q1 
\v 9 A e like auanei me na kanaka, pela no me ke kahuna: A e hoopai aku au ia lakou e like me ko lakou mau aoao, A e hoouku aku au ia lakou e like me ka lakou hana ana.
\q1 
\v 10 A e ai lakou, aole nae e maona, A e moe kolohe lakou, aole nae e mahuahua ae; No ka mea, ua hooki lakou i ka malama ia Iehova.
\b
\q1 
\v 11 O ka moe kolohe, o ka waina, a me ka waina hou, oia ke lawe aku i ka naau.
\b
\q1 
\v 12 Ke ninau nei kuu poe kanaka i ko lakou kii laau, A ua hoike mai ko lakou kookoo ia lakou; No ka mea, ua hooauwana ka naau moe kolohe ia lakou; Ua hele moe kolohe lakou mai lalo ae o ko lakou Akua.
\q1 
\v 13 Kaumaha aku la lakou ma kahi kiekie o na mauna, A kuni i ka mea ala maluna o na puu, Malalo o ka laau oka, a me ka laau popela, a me ka laau kaa, No ka mea, ua oluolu kona malumalu: No ia mea, e moe kolohe ka oukou poe kaikamahine, A e moe kolohe ka oukou poe hunona wahine.
\q1 
\v 14 Aole au e hoopai aku i ka oukou poe kaikamahine no ko lakou moe kolohe ana, A i ka oukou poe hunona wahine no ko lakou moe kolohe ana: No ka mea, ua hookaawale pu lakou ia lakou iho me na wahine hookamakama, A ua mohai pu lakou me na wahine moe kolohe: A o ka poe kanaka ike ole, e make no lakou.
\b
\q1 
\v 15 Ina o oe, e ka Iseraela, i moe kolohe, mai hana hewa o ka luda: A mai hele oukou i Gilegala, Mai pii ae oukou i Betavena, Mai hoohiki, E ola o Iehova.
\q1 
\v 16 No ka mea, ua paakiki o ka Iseraela, e like me ka paakiki o ka bipiwahine hou: Ano e hanai o Iehova ia lakou, e like me ke keikihipa ma kahi akea.
\q1 
\v 17 Ua hui pu o Eperaima me na kii, e waiho aku ia ia.
\q1 
\v 18 Ua hewa ka lakou ahainu, Ua mau ko lakou moe kolohe ana; A ake kona poe alii i ka hilahila.
\q1 
\v 19 Ua hoopaa ka makani ia ia iloko o kona mau eheu, A e hilahila auanei lakou i ka lakou mau mohai.
\c 5
\b
\q1 
\v 1 E HOOLOHE oukou i keia, o na kahuna, E haliu mai oukou, e ko ka hale o ka Iseraela, A e lohe na pepeiao, e ko ka hale o ke alii; No ka mea, no oukou ka hoohewa. No ka mea, ua lilo oukou i pahele ma Mizepa, A i upena hohola hoi maluna o Tabora.
\q1 
\v 2 Ke pepehi nui nei ka poe haalele hewa, A e hahau au ia lakou a pau.
\q1 
\v 3 Ua ike au ia Eperaima, Aole hoi i hunaia ka Iseraela mai o'u aku la: No ka mea, ano, e Eperaima, ua moe kolohe no oe, A ua haumia o ka Iseraela.
\q1 
\v 4 Aole lakou i hoolilo i ko lakou manao e huli hou i ko lakou Akua: No ka mea, he naau moe kolohe iwaena o lakou, Aole lakou i ike ia Iehova.
\q1 
\v 5 Ke hoike mai nei ka haakei o ka Iseraela ma kona maka: Nolaila o ka Iseraela a me Eperaima, e haule pu iloko o ko lakou hewa; A o Iuda hoi kekahi e haule pu me lakou.
\q1 
\v 6 A e hele lakou me ka lakou poe hipa, a me ka lakou poe bipi e imi ia Iehova, Aka, aole e loaa ia lakou; Ua hele ia mai o lakou aku.
\q1 
\v 7 Ua hana hoopunipuni aku la lakou ia Iehova: No ka mea, ua hoohanau lakou i na keiki e: Ano e hoopauia auanei lakou i ka malama hookahi, a me ko lakou waiwai.
\b
\q1 
\v 8 E puhi oukou i ka pukani ma Gibea, I ka pu hoi ma Rama: E kahea nui aku ma Betavena mahope on, e Beniamina.
\q1 
\v 9 A e neoneo auanei o Eperaima i ka la e hoopaiia'i: Mawaena o na ohana o ka Iseraela ua hoike aku au i ka oiaio o ka mea e hiki mai ana.
\q1 
\v 10 Ua like na'lii o ka Iuda me ka poe hoonee i ka palena aina: Nolaila e ninini aku au i ko'u huhu maluna o lakou me he wai la.
\q1 
\v 11 Ua hooluhiia o Eperaima, ua hookaumahaia ma ka hoohewa, No ka mea, ua lealea oia i ka hele ana mamuli o ke kauoha.
\q1 
\v 12 Nolaila, e like auanei au me ka mu no Eperaima, A me he mea popopo la no ko ka hale o Iuda.
\q1 
\v 13 A ike iho la o Eperaima i kona mai, a o Iuda hoi i kona. eha, Alaila, hele aku la o Eperaima i Asuria, A hoouna aku la i ke alii ku e: Aole nae e hiki ia ia ke hoola ia oukou, Aole hoi e hoola i ko oukou eha.
\q1 
\v 14 No ka mea, e like auanei au me he liona la ia Eperaima, A e like me he liona hou la i ko ka hale o Iuda: Owau, owau ke haehae, a hele aku, E lawe pio aku au, aohe mea nana e hoopakele.
\b
\q1 
\v 15 E hele au a e hoi aku i ko'u wahi, A e hoopaiia lakou, a e imi mai i kuu maka: I ko lakou wa pilikia e imi koke mai lakou ia'u.
\c 6
\b
\q1 
\v 1 I NA kakou e hoi hou aku ia Iehova, No ka mea, ua haehae mai kela, a e hoola mai ia ia kakou; Ua hahau mai ia, a e hoola mai no oia ia kakou.
\q1 
\v 2 Mahope o na la elua e hoola mai ia ia kakou: I ke kolu o ka la e hooku mai ia ia kakou iluna, A e ola kakou imua ona.
\q1 
\v 3 Alaila e ike kakou, ke hahai kakou e ike ia Iehova; Ua makaukau kona hele ana'ku, e like me ka wanaao: A e hele mai ia ia kakou e like me ka ua; E like me ke kuaua mua, a me ke kuaua hope maluna o ka honua.
\b
\q1 
\v 4 E Eperaima, heaha ka'u e hana aku ai ia oe? E Iuda, heaha ka'u e hana aku ai ia oe? No ka mea, o ka oukou pono, na like me ke ao kakahiaka, A ua like me ka hau e nalo koke ana.
\q1 
\v 5 No ia mea, ua kalai aku au ia lakou ma na kaula; Ua pepehi aku au ia lakou ma na olelo a kuu waha: A e puka aku kou hoohewaia e like me ka malamalama.
\q1 
\v 6 No ka mea, o ke aloha ko'u makemake, aole ka mohai; A o ka ike i ke Akua mamua o na mohaikuni.
\q1 
\v 7 Aka, e like me kanaka, ua hai ia lakou ka berita: Ilaila ua hana hoopunipuni mai lakou ia'u.
\q1 
\v 8 O Gileada ke kulanakauhale o ka poe hana hewa, i hahiia i na kapuwai koko.
\q1 
\v 9 E like me ka poe hao wale e hoohalua ana i ke kanaka; Pela no ka poe kahuna i pepehi wale ma ke ala o Sekema; No ka mea, ke hana nei lakou i ka mea ino.
\q1 
\v 10 Maloko o ka ohana a Iseraela ua ike au i ka mea weliweli; Malaila ka moe kolohe o Eperaima, Ua haumia ka Iseraela:
\q1 
\v 11 Nou hoi, e ka Iuda, ua makaukau ka ohi ai ana.
\c 7
\b
\q1 
\v 1 I KA wa a'u e hoihoi aku ai i ke pio ana o kuu poe kanaka, I kuu hoola ana i ka Iseraela, alaila hoikeia mai ka hewa o Eperaima, A me na mea ino o ko Samaria: No ka mea, ua hana lakou i ka wahahee; A komo mai ka aihue maloko, A hao wale ka poe powa mawaho.
\q1 
\v 2 Aole noonoo ko lakou naau i kuu hoomanao ana i ko lakou hewa a pau: Ano, ua hoopuni ka lakou mau hana ia lakou; Eia no lakou imua o ko'u maka.
\q1 
\v 3 Ma ko lakou hewa hoolealea aku lakou i ke alii, A i na haku hoi ma ko lakou mau hoopunipuni.
\q1 
\v 4 He poe moe kolohe lakou a pau, e like me ka umu i hoenaenaia e ka mea pulehu palaoa, Hoopanee oia i ka pulehu ana, mahope o ke kawili ana i ka palaoa a hiki i ka wa e hu ai.
\q1 
\v 5 A i ka la o ko kakou alii loohia iho na haku e ka mai i ka wela o ka waina, A o aku la oia i kona lima me ka poe haakei.
\q1 
\v 6 No ka mea, ua hoomakaukau lakou i ko lakou naau, e like me ka umu ma ko lakou hoohalua ana: Ua hiamoe ko lakou mau mea peluhu palaoa, a ao ka po: A i kakahiaka, ua wela ia mea e like me ke ahi lapalapa.
\q1 
\v 7 Ua wela lakou a pau e like me ka umu, Ua ai lakou i ko lakou mau lunakanawai; Ua haule ko lakou poe alii a pau: Aohe mea e kahea mai ia'u iwaena o lakou.
\b
\q1 
\v 8 O Eperaima, ua hui pu ia me na kanaka e: O Eperaima, he popo palaoa no ia, aole i huliia.
\q1 
\v 9 Ua ai na malihini i kona ikaika, aole nae ia i ike: Ua kau mai no hoi ke oho hina maluna ona, aole nae ia i ike.
\q1 
\v 10 Ke hoike mai nei ka haaheo o ka Iseraela ma kona maka: Aole lakou e hoi hou ia Iehova i ko lakou Akua, Aole imi aku ia ia no keia mea a pau.
\b
\q1 
\v 11 Ua like hoi o Eperaima me he manu nunu la i hawawa aohe ona manao: Kahea aku lakou i ko Aigupita, A hele lakou i ko Asuria.
\q1 
\v 12 A i ka wa e hele ai lakou, e hohola aku au i ka'u upena maluna o lakou; A e lawe mai au ia lakou ilalo, e like me na manu o ka lewa; A e hahau aku au ia lakou, e like me ka mea a ko lakou ahakanaka i lohe ai.
\q1 
\v 13 E auwe lakou! no ka mea, ua auwana lakou mai o'u aku la: O ka make ko lakou! no ka mea, ua kipi mai lakou ia'u: Owau ka i hoola ia lakou, A o lakou ka i olelo wahahee mai ia'u.
\q1 
\v 14 Aole lakou i auwe mai ia'u me ko lakou naau, i ka wa a lakou i auwe ai maluna o ko lakou wahi moe: Ua hoakoakoa lakou ia lakou iho no ka ai, a no ka waina hou, a ua kipi mai lakou ia'u.
\q1 
\v 15 Ia'u i ao ai ia lakou, a hooikaika aku ai i ko lakou mau lima, Aka, ke manao hewa mai nei lakou ia'u.
\q1 
\v 16 Ua hoi hou lakou, aole nae i ka Mea kiekie loa; Ua like lakou me he kakaka hewa la: E haule na'lii o lakou me ka pahikaua, no ka hookano o ko lakou alelo: O keia ko lakou hoino ma ka aina o Aigupita.
\c 8
\b
\q1 
\v 1 E KAU i ka pu ma kou waha, Me he aeto la e hele ku e mai i ka hale o Iehova; No ka mea, ua hai ia lakou kuu berita, A ua ae lakou maluna o ko'u kanawai.
\q1 
\v 2 E kahea mai auanei ka Iseraela ia'u, E kuu Akua, ua ike makou ia oe.
\q1 
\v 3 Ua haalele ka Iseraela i ka mea maikai: E hahai auanei ka enemi ia ia.
\q1 
\v 4 Ua hoalii lakou i na alii, aole ma o'u nei; Ua hoonoho lakou i na haku a'u i ike ole ai; Ua hana lakou i ko lakou kala, a me ko lakou gula i kii no lakou, i mea e okiia'ku ai lakou.
\b
\q1 
\v 5 He mea hoopailua kou keikibipi, e Samaria. Ua hoaaia kuu inaina ia lakou: Pehea la ka loihi a loaa ia lakou ka maemae?
\q1 
\v 6 No ka mea, na ka Iseraela keia mea; Na ka paahana no ia i hana; Aole ia he akua: No ka mea, e haki liilii ia ke keikibipi o Samaria.
\q1 
\v 7 No ka mea, ua lulu lakou i ka makani, A e ohi auanei lakou i ka puahiohio: Aohe kino o ka ai e ku ana; Aole hoi e hua mai ka opuu i ka hua palaoa: Ina paha e hua mai, na ka poe malihini e hoopau ia mea.
\b
\q1 
\v 8 Ua hoopauia ka Iseraela: A e like auanei lakou iwaena o ko na aina e, me he ipu la I makemake ole ia.
\q1 
\v 9 No ka mea, ua pii ae la lakou i Asuria, me he hoki hihiu, oia wale no! Ua hoolimalima o Eperaima i na mea aloha.
\q1 
\v 10 Ua hoolimalima hoi lakou iwaena o na lahuikanaka e, ano e hoakoakoa nae au ia lakou; A e anwe iki lakou no ke kaumaha o ke alii o na haku.
\b
\q1 
\v 11 No ka mea, ua hoomahuahua o Eperaima i na kuahu no ka hewa, A e lilo na kuahu nona e hewa ai.
\q1 
\v 12 Ua kakau aku au nona i na mea nui o kuu kanawai, Aka, ua manaoia ua mau mea la, me he mea e la.
\q1 
\v 13 I ke kaumaha ana i kuu mau mohai, ua kaumaha aku lakou i ka io, a ai iho la; Aole i oluolu o Iehova ia lakou; Ano e ho manao oia i ko lakou hala; A e hoopai hoi i ko lakou hewa: A e hoi hou lakou i Aigupita.
\q1 
\v 14 No ka mea, ua hoopoina o ka Iseraela i ka Mea nana ia I hana, a ua hana aku i na hale hoomana; A ua hoomahuahua o ka Iuda i na kulanakauhale i paa i ka papohaku: A e hoouna aku au i ke ahi iloko o kona mau kulanakauhale; A e ai aku ia i kona mau halealii.
\c 9
\b
\q1 
\v 1 MAI hauoli, e ka Iseraela, me ka olioli, e like me na lahuikanaka; No ka mea, ua hele moe kolohe aku oe mai kou Akua aku, Ua makemake aku oe i na makana ma na kahua hehi palaoa a pau.
\q1 
\v 2 O ke kahua, a me kahi kaomi waina, aole e hanai laua ia lakou, A e pau auanei ka waina hou iloko ona.
\q1 
\v 3 Aole lakou e noho ma ka aina o Iehova; Aka, e hoi hou o Eperaima i Aigupita; A e ai lakou i na mea haumia ma Asuria.
\q1 
\v 4 Aole lakou e kaumaha aku i ka waina ia Iehova, Aole ia e oluolu mai ia mau mea. O ka lakou mau mohai, e like auanei ia lakou me ka berena o ka poe e kanikau ana: O ka poe a pau e ai iho ia mea e haumia lakou; No ka mea, o ka lakou berena no ko lakou ola, aole e laweia oia iloko o ka hale o Iehova.
\q1 
\v 5 Heaha la uanei ka oukou e hana'i i ka la ahaaina, A i ka la ahaaina a Iehova?
\q1 
\v 6 No ka mea, aia hoi, ua hele aku lakou mai ka luku aku: E hoakoakoa o Aigupita ia lakou, E kanu aku no o Memepi ia lakou. A o na wahi maikai i kuaiia no ko lakou kala e paapu ia i ka puakala; A maloko o ko lakou mau halelewa e kupu ka laau ooi.
\b
\q1 
\v 7 Ua hiki mai na la o ka hoopai ana, Ua hiki mai na la o ka uku ana; E ike auanei ka Iseraela: Ua naaupo ke kaula, a ua hehena ke kanaka kilokilo uhane, no ka hoonuiia o kou hewa, a me ka nui o ka inaina.
\q1 
\v 8 E kali ana o Eperaima i ke kokua, mai ko'u Akua mai: O ke kaula, he punihei ia o ka mea punihei manu ma kona aoao a pau, A he mea inaina ma ka hale o ke Akua.
\q1 
\v 9 Ua hana hewa nui lakou e like me na la o Gibea: Nolaila, e hoomanao mai ia i ko lakou hala, A e hoopai mai hoi i ko lakou mau hewa.
\b
\q1 
\v 10 Ua loaa ia'u ka Iseraela e like me na hua waina ma ka waonahele; Ua ike au i ko oukou poe kupuna, e like me ka hua mua ma ka laau fiku i kona hua mua ana; Aka, hele aku la lakou ia Baala-peora, a hookaawale ia lakou iho no ka mea hilahila: A o na mea hoowahawahaia, ua like me ko lakou makemake.
\q1 
\v 11 A no ka Eperaima, e lele aku auanei ko lakou nani me he manu la, mai ka hanau ana mai, mai ka opu mai, a mai ka hapai ana mai.
\q1 
\v 12 Ina paha e hanai lakou i na keiki a lakou, E hoonele aku au ia lakou mawaena aku o kanaka: A he poino ko lakou i ka wa a'u e haalele ai ia lakou!
\q1 
\v 13 O Eperaima, e like me ko'u ike ana ma Turo, ua kanuia oia ma kahi maikai: Aka, e alakai aku o Eperaima i kaua poe keiki no ka mea pepehi.
\q1 
\v 14 E Iehova, e haawi aku oe ia lakou i ka mea au e haawi aku ai; E haawi aku ia lakou i ka opu hanau hapa wale, a me na u maloo.
\b
\q1 
\v 15 O ko lakou hewa a pau, aia ma Gilegala; No ka mea, malaila au i inaina aku ai ia lakou: No ka hewa o ka lakou hana ana e kipaku aku ai au ia lakou mai ko'u hale aku, Aole au e aloha hou aku ia lakou, A o ko lakou mau alii, he poe kipi lakou!
\q1 
\v 16 Ua hahauia o Eperaima, Ua maloo ko lakou aa; Aole lakou e hua mai ka hua; A ina e hanau mai lakou, E pepehi no au i na mea aloha o ko lakou opu.
\q1 
\v 17 E kipaku auanei kuu Akua ia lakou, No ka mea, aole lakou i hoolohe ia ia; A e lilo lakou i poe aea mawaena o na lahuikanaka.
\c 10
\b
\q1 
\v 1 O KA Iseraela, he kumu waina, i ulu palahalaha, e hua ana i ka hua nona iho; E like me ka nui o kona hua, pela no ia i hoomahuahua ai i na kuahu; E like me ka maikai o kona aina, pela no ia i hoonani ai i na kii.
\q1 
\v 2 Ua kanalua ko lakou naau; Ano e hoopaiia lakou; E hoohiolo no ia i ko lakou kuahu, E hoopau no ia i ko lakou mau kii.
\b
\q1 
\v 3 Ano hoi, e olelo auanei lakou, Aohe o kakou alii, No ka mea, aole o kakou i makau aku ia Iehova; Heaha ka mea a ke alii e hana mai ai no kakou?
\q1 
\v 4 Ua olelo lakou i na olelo hoohiki wahahee i ka hana ana i ka berita; A ua ulu mai ka hoahewa e like me ka laau make ma na auwaha o ke kula.
\q1 
\v 5 E makau auanei na kanaka o Samaria no na keikibipi o Betavena: No ka mea, e auwe auanei kona poe kanaka no ia mea; A e haalulu na kahuna no kona nani, No ka mea, ua nalowale ia.
\q1 
\v 6 A e laweia'ku hoi ia i Asuria i makana no ke alii no ka enemi: A e kau mai ka hilahila ia Eperaima, A e hilahila hoi ka Iseraela no kona manao iho.
\q1 
\v 7 A o Samaria, ua okiia'ku kona alii, e like me ka hua maluna o ka wai.
\q1 
\v 8 A e hoopauia na heiau o Avena, ka hewa o ka Iseraela: E kupu mai auanei ka laau kuku a me ka puakala maluna o ko lakou mau kuahu; A e olelo aku lakou i na mauna, E uhi mai ia makou; A i na puu, E hiolo mai maluna o makou.
\q1 
\v 9 E ka Iseraela, ua hana hewa oe mai na la o Gibea mai; Ilaila lakou i ku ai: A o ke kaua ana ma Gibea i na keiki hewa, aole anei ia e hiki aku io lakou la?
\q1 
\v 10 Eia ko'u manao, e hahau aku ia lakou; A e akoakoa mai na kanaka e ku e ia lakou, I kuu hoopaa ana ia lakou, no ko lakou mau hewa elua.
\b
\q1 
\v 11 A o Eperaima, ua like ia me ka bipi wahine opiopio i laka, a makemake hoi e hehi i ka palaoa: Aka, e hele aku no au maluna o kona a-i maikai: E hooholo au ia Eperaima; A e hana o Iuda me ka oopalau, A na Iakoba e kuikui i puupuu lepo nona.
\q1 
\v 12 E lulu oukou no oukou iho, ma ka pono, E ohi oukou ma ka lokomaikai; E waele i ko oukou mahinaai; No ka mea, he manawa keia e imi ia Iehova, A hiki mai ia, a ao aku i ka pono ia oukou.
\q1 
\v 13 Ua mahi oukou ma ka pono ole, a ua ohi oukou i ka hewa; A e ai oukou i ka hua o ka wahahee: No ka mea, ua hilinai oe ma kou aoao iho, A i ka lehulehu o kou poe ikaika.
\q1 
\v 14 Nolaila, e kupu mai auanei ka haunaele iwaena o kou poe kanaka, A e hoohioloia kou mau wahi paa a pau loa, E like me Salemana i hoohiolo ai ia Betarebela i ka la o ke kaua; I ulupaia'i ka makuwahine me kana mau keiki.
\q1 
\v 15 Pela oia e hana mai ai ia oukou, ma Betela, no ko oukou hewa nui: I kakahiaka e oki loa ia'ku ke alii o ka Iseraela.
\c 11
\b
\q1 
\v 1 I KO Iseraela wa kamalii, alaila, ua aloha aku au ia ia, A kahea aku au i kuu keiki e hele mai Aigupita mai.
\q1 
\v 2 Like me lakou i kahea aku ai ia lakou, pela no lakou i hele ae ai mai o lakou aku; Kaumaha aku la lakou i na Baala, a kuni i ka mea ala i na kii kalaiia.
\q1 
\v 3 Ua ao aku au ia Eperaima i ka hele, e alakai ana ia lakou ma ko lakou lima; Aka, aole lakou i ike, owau ka i hoola ia lakou.
\q1 
\v 4 Ua alako aku au ia lakou me na kaula o ke kanaka a me na apo o ke aloha: A ua lilo au no lakou i mea like me na mea e lawe aku ana I ka auamo mai luna aku o ko lakou a-i, A ua waiho iho la au i ka ai imua o lakou.
\b
\q1 
\v 5 Aole ia e hoi hou i ka aina o Aigupita, Aka, o ka Asuria, oia kona alii; No ka mea, ua hoole no ia i ka hoi hou ana,
\q1 
\v 6 A e haule mai ka pahikaua maluna o kona mau kulanakauhale, A e ai iho i kona mau lala, a e hoopau, no ko lakou manao.
\q1 
\v 7 A ua manao kuu poe kanaka e hoi ihope mai o'u aku la; A ua kahea aku lakou ia lakou la i ka Mea kiekie, Aole kekahi i hookiekie aku ia ia.
\b
\q1 
\v 8 Pehea la wau e hookuu aku ai ia oe, e Eperaima? Pehea la wau e hoolilo ai ia oe, e ka Iseraela? Pehea la wau e hana aku ai ia oe e like me Adema? Pehea hoi wau e hooku ai ia oe e like me Zeboima? Ua huliia ko'u naau iloko o'u, Ua hoala pu ia hoi kuu minamina.
\q1 
\v 9 Aole au e hoopai aku me kuu inaina nui, Aole au e huli ae e luku aku ia Eperaima; No ka mea, owau no ke Akua, aole he kanaka, Maloko ou ka Mea Hemolele; Aole au e hele mai me ka huhu.
\q1 
\v 10 Mamuli o Iehova lakou e hele ai; E uwo ana no ia e like me ka liona: A i ka wa e uwo ai oia, alaila e haalulu na keiki mai ke komohana mai.
\q1 
\v 11 E haalulu lakou me he manu la mai Aigupita mai, Me he manu nunu la mai ka aina o Asuria mai: A e hoonoho au ia lakou maloko o ko lakou mau hale iho, wahi a Iehova.
\b
\q1 
\v 12 Ke hoopuni nei o Eperaima ia'u me ka hoopunipuni, A o ka hale o ka Iseraela me ka wahahee: Aka, o ka Iuda, ke hooalii nei oia me ke Akua, A ke kupaa nei oia me ka poe pono.
\c 12
\b
\q1 
\v 1 KE ai nei ka Eperaima i ka makani, A ke hahai nei hoi ia i ka makani hikina: Hoomahuahua no ia i na la a pau i ka hoopunipuni a me ka luku ana; A hana lakou i ka berita me ko Asuria, A ua laweia'ku ka aila i Aigupita.
\q1 
\v 2 He paio hoi ko Iehova me ka Iuda, A e hoopai aku oia ia Iakoba e like me kona mau aoao; E hoouku aku kela ia ia e like me kana hana.
\b
\q1 
\v 3 Iloko o ka opu hoopaa aku oia i ke kuekuewawae o kona kaikuaana, A ma kona ikaika hakaka pu ia me ke Akua.
\q1 
\v 4 A hakaka pu ia me ka anela, a lanakila: Uwe iho la ia, a nonoi aku la ia ia: Loaa oia ia ia ma Betela, a olelo pu oia me kakou;
\q1 
\v 5 Oia hoi, o Iehova ke Akua o na kaua; O Iehova, oia kona inoa ponoi.
\q1 
\v 6 Nolaila, e huli oe i kou Akua: E malama i ke aloha, a me ka olelo hoopono, A e hilinai mau maluna o kou Akua.
\b
\q1 
\v 7 He kalepa no ia, ma kona lima ka mea kaupaona hoopunipuni: A makemake no ia i ka alunu.
\b
\q1 
\v 8 A i iho la o Eperaima, Ua lako no nae wau, Ua loaa ia'u ka waiwai; Ma ka'u mau hana a pau aole i loaa kuu hewa, ka mea i hewa'i au.
\q1 
\v 9 A owau, o Iehova kou Akua, mai ka aina o Aigupita mai, E hoonoho hou aku au ia oe i na halelewa, e like me na la o ka ahaaina.
\q1 
\v 10 A ua olelo aku au ma na kaula, A ua hoomahuahua i na hihio, A ua olelo aku au i na olelo nane ma ka lima o na kaula.
\q1 
\v 11 Ua hewa anei ko Gileada? Oia, ua hewa lakou; Ke kaumaha nei lakou i na bipi ma Gilegala; A o ko lakou mau kuahu, ua like me na ahu ma na auwaha o ka mahinaai.
\b
\q1 
\v 12 A holo aku la o Iakoba i ka aina o Suria; A hooluhi aku la o Iseraela no ka wahine, A no ka wahine malama aku la ia i na holoholona.
\q1 
\v 13 A ma ke kaula i lawe mai ai o Iehova i ka Iseraela mai Aigupita mai, A ma ke kaula i malama mai ai oia ia ia.
\q1 
\v 14 Hoonaukiuki loa aku la o Eperaima ia ia; Nolaila e waiho aku ai ia i kona koko maluna ona, A e hoihoi aku kona Haku i kona hoowahawaha maluna ona.
\c 13
\b
\q1 
\v 1 I KA wa i olelo ai o Eperaima, he haalulu, Ua hookiekieia oia iloko o ka Iseraela; Aka, i kana hana hewa ana ma Baala, make iho la ia.
\q1 
\v 2 Ano, hoomahuahua lakou i ka hewa, A hana lakou no lakou i kii hooheheeia no ko lakou kala, I kii ma ko lakou manao, o na hana a na paahana wale no; Ke olelo nei ka poe e kaumaha ana, E honi lakou i na keiki bipi.
\q1 
\v 3 No ia mea, e like auanei lakou me ke ao kakahiaka, A me ka hau hou e nalo koke ana, E like me ka opala i puehuia i ka puahiohio mai kahi hehipalaoa aku, A me ka uahi mai ka puka-uahi aku.
\b
\q1 
\v 4 Aka, owau o Iehova ke Akua ou, mai ka aina o Aigupita mai, Mai ike oe i akua e ae, ia'u wale no; No ka mea, aohe Hoola, owau walo no.
\b
\q1 
\v 5 Owau ka i ike ia oe ma ka waonahele, Ma ka aina panoa,
\q1 
\v 6 E like me ka lakou mea ai, pela i maona ai lakou; Ua maona lakou. a hookiekieia ko lakou naau; No ia mea, ua hoopoina lakou ia'u.
\q1 
\v 7 Nolaila, e like auanei au ia lakou me he liona la; Me he leopadi la ma ke ala, e hoohalua ai au ia lakou.
\q1 
\v 8 E halawai au me lakou me he bea la i hooneleia, A e haehae au i ka wahi o ko lakou naau, A e hoopau aku au ia lakou malaila e like me ka liona: A e haehae ka holoholona o ka waonahele ia lakou.
\b
\q1 
\v 9 Nau iho kou make, e ka Iseraela; Aka, iloko o'u kou kokua.
\q1 
\v 10 Auhea hoi kou alii, nana e hoola mai ia oe ma kou mau kulanakauhale a pau? Auhea hoi kou mau lunakanawai, na mea au i olelo ai, E haawi mai i alii no'u, a me na luna?
\q1 
\v 11 Haawi aku au i alii nou, no kuu inaina, A lawe aku au ia ia ma kuu huhu.
\b
\q1 
\v 12 Ua nakiiia ka hala o ka Eperaima, Ua ahuia kona hewa.
\q1 
\v 13 O na ehaeha o ka wahine hanau, e hiki mai ia maluna ona: He keiki naaupo ia; No ka mea, aohe ona pono e ku loihi ma kahi e hanau ai na keiki.
\q1 
\v 14 E hoola aku au ia lakou mai ka mana o ka po; E hoola panai au ia lakou mai ka make mai; Owau no kou luku, e ka make; Owau no kou pepehi, e ka po; Ua hunaia ka mihi, mai ko'u maka aku.
\b
\q1 
\v 15 Ina ua mahuahua oia mawaena o kona mau hoahanau, E hele mai auanei ka makani hikina, Ka makani o Iehova e hiki mai, mai ka waonahele mai: A e hoomalooia kona punawai, A e maloo kona waipuna; A e hoopau aku ia i ka waiwai o na ipu a pau i makemakeia.
\q1 
\v 16 E hoopaiia auanei ko Samaria; No ka mea, ua kipi aku ia i kona Akua; E haule auanei lakou ma ka pahikaua; E ulupaia ka lakou mau keiki liilii, A o ka lakou poe wahine hapai e kahaia'ku.
\c 14
\b
\q1 
\v 1 E KA Iseraela, e huli mai oe ia Iehova kou Akua; No ka mea, ua haule oe ma kou hewa iho.
\q1 
\v 2 E lawe me oukou i na olelo, a e huli oukou ia Iehova: E i aku ia ia, E lawe aku oe i na hewa a pau, A e ae lokomaikai mai, A e hoihoi aku makou i na mohai o ko makou lehelehe.
\q1 
\v 3 Aole e hoola ko Asuria ia makou; Aole makou e holo maluna o ka lio; Aole hoi makou e olelo hou aku i ka hana a ko makou mau lima. O oe ko makou Akua: No ka mea, ma ou la e loaa'i i ka poe makua ole ka lokomaikai.
\b
\q1 
\v 4 A e kala aku au i ko lakou kipi ana, E aloha wale aku hoi au ia lakou: No ka mea, ua huli ae kuu inaina mai ona aku la.
\q1 
\v 5 E like auanei au me ka hau i ka Iseraela; E pua auanei oia e like me ka lilia, A e kolo lea kona mau aa e like me Lebanona.
\q1 
\v 6 A e palahalaha aku kona mau lala, A e like auanei kona nani me ka laau oliva, E like hoi kona ala me Lebanona.
\q1 
\v 7 E hoi mai ka poe e noho ana malalo o kona malu; E kupu mai lakou me ka ai, A e ulu lakou me ke kumuwaina: A o kona inoa ua like me ka waina o Lebanona.
\b
\q1 
\v 8 E olelo iho o Eperaima, Heaha ka'u e hana hou aku ai i na kii? Ua lohe au a ua nana hou au ia ia; Ua like au me ka laau kaa uliuli; Mai o'u aku ua loaa ia oe ka hua.
\b
\q1 
\v 9 Owai ka mea naauao, i noonoo ai oia i keia mau mea? A akamai hoi, i ike ai oia i keia mau mea? No ka mea, o na aoao o Iehova, ua pololei, A e hele ka poe pono iloko olaila; Aka, o ka poe lawehala, e haule lakou iloko olaila. 
