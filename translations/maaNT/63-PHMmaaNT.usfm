\id PHM
\h Filemón
\toc1 Xo̱jo̱n carta‑la̱ San Pablo xi kiskiì‑la̱ Filemón
\toc2 Filemón
\toc3 Flm.
\mt1 Xo̱jo̱n carta‑la̱ San Pablo xi kiskiì‑la̱ Filemón
\c 1
\s1 Kó tsò Pablo nga síhixat'aà Filemón
\p 
\v 1 Ji̱ Filemón xi ndaà matsjake̱‑lè xi ngásòn xá‑la̱ Na̱'èn‑ná titsa̱'né, 'a̱n Pablo nga nda̱yá tìjna̱a'ya k'oi̱í kjoa̱‑la̱ nga xá‑la̱ Cristo tìs'iaàn, tisìhixat'aà‑lè ko̱ 'ndsè Timoteo.
\v 2 Ti̱koa̱á tisìhixat'aà xi̱ta̱ na̱xa̱ndá‑la̱ Cristo xi ya̱ bixoña ni'ya‑lè ko̱ tichjaá Apia ko̱ 'ndseé Arquipo xi ti̱koa̱ xá‑la̱ Nainá nchikjaán‑tji koni 'a̱n.
\v 3 Nainá xi Na̱'èn‑ná, ko̱ jè Jesucristo xi otíxoma‑ná kàtatsjá‑nò kjo̱ndaà ko̱ kjoa̱'nchán ya̱ i̱jiìn ini̱ma̱‑nò.
\s1 Kjoa̱tjòcha xi tjín‑la̱ Filemón
\p 
\v 4 K'e̱ nga chjàt'aà‑la̱ Nainá, kjit'aà na̱chrjein sìkítsjeèn i̱t'aà tsi̱ji, k'oa̱á ma‑ne nga tsjaà‑la̱ kjo̱ndaà Na̱'èn‑ná,
\v 5 Koií kjoa̱‑la̱ nga jyeé ki'nchrè nga ndaà mokjeiín‑lè i̱t'aà ts'e̱ Na̱'èn‑ná Jesucristo ti̱koa̱ ndaà matsjachi ngats'iì xi̱ta̱‑la̱ Nainá.
\v 6 K'oa̱á s'ín sìjét'aà‑la̱ Nainá nga ndaà ki̱tasòn koni s'ín nokjoàkoi̱i xi̱ta̱ xi i'nga i̱t'aà ts'e̱ kjoa̱ xi mokjeiín‑lè mé‑ne nga ìsa̱ ndaà jcha̱xkoin ngats'iì kjo̱ndaà xi ko̱ma si̱kitasoán i̱t'aà ts'e̱ Cristo.
\v 7 Ji̱ ndí 'ndsè, 'ñó tsja ma‑na ko̱ ma'ñó takoàn i̱t'aà ts'e̱ kjoa̱tjòcha xi tjín‑lè, nga i̱t'aà tsi̱ji‑né, nga jye ndaà tìnìjetakoìn ini̱ma̱‑la̱ jñà xi̱ta̱‑la̱ Nainá.
\s1 Kó tsò Pablo nga chja̱tjì Onésimo
\p 
\v 8 K'oa̱á ma‑ne na̱s'ín i̱t'aà ts'e̱ Cristo tjí'nde‑na̱ nga kìnè‑lè mé kjoa̱ xi s'i̱in, ta̱nga mìtsà ko̱s'ín tìbìt'in‑lè.
\v 9 Ta jngoò kjo̱ndaà tísíjé‑lè, nga̱ tíjiìn‑ná nga tjòcha 'yaá xinguia̱á. Ko̱ jyeé tíjiìn‑lè, 'a̱n Pablo, jyeé xi̱ta̱ jchínga‑ná, ti̱koa̱ nda̱yá tìjna̱a'ya xi jè nga̱tjì‑la̱ Cristo Jesús.
\v 10 K'oa̱á ma‑ne nga tísíjé jngoò‑lè kjo̱ndaà nga ndaà chjoétjoì jè Onésimo xi koni ki'ndí‑na̱ komà nga kòkjeiín‑la̱ 'én ndaà‑la̱ Nainá xi 'a̱n tsibeno̱jmí‑la̱ nga i̱ tìjna̱a'ya nda̱yá.
\p 
\v 11 Nga sa̱ kjòtseé, jè Onésimo, jngoò xi̱ta̱ chi̱'nda xi mìkiì ndaà kjòchjeén‑lè, ta̱nga i̱'ndei̱ jyeé ndaà ko̱chjeén‑ná ingajoá.
\v 12 Tìsìkasén ìjngoò k'a‑lè, 'a̱n nga 'ñó matsjake̱.
\v 13 Ndaá‑la s'e̱ tsà i̱ kíjnako̱‑na mé‑ne nga si̱ìchját'aà‑na koni tsà ji̱ tìnìchját'aà‑ná, k'e̱ nga ta̱kó nda̱yá tìjna̱a'ya nga jè nga̱tjì‑la̱ 'én ndaà‑la̱ Nainá xi kjoa̱ ts'e̱ Cristo.
\v 14 Ta̱nga majìn‑na nga kjo̱'ñó siìkíjna tsà ngaji̱ mìkiì tíjngoò takoìn, mé‑ne jè kjo̱ndaà xi tìsìjé‑lè mì kjo̱'ñó ko̱ma‑lè; ini̱ma̱‑lè kji̱nchrobàjiìn.
\v 15 Tsà koi na̱chrjein, jè Onésimo, koií kjoa̱‑la̱ tsasìt'aà xìn chiba na̱chrjein‑lè mé‑ne i̱'ndei̱ ko̱ma chjoétjò ìjngoò k'a‑ne nga ya̱ kíjnako̱ kjit'aà‑lè.
\v 16 Ta̱nga kì k'oa̱á s'ín 'ya takoìn koni tsà jngoò xi ta̱xki̱ chi̱'nda; ìsa̱á 'ñó ndaà jcha̱takoìn koni tsà jngoò 'ndsì xi 'ñó ndaà matsjachi. 'A̱n, 'ñó matsjake̱; ta̱nga ngaji̱ ìsa̱á 'ñó ti̱tsjachi mìtsà ta koi kjoa̱‑la̱ nga chi̱'nda tsi̱ji ko̱ma, koi‑né nga jyeé 'ndsè chibà i̱t'aà ts'e̱ Cristo.
\p 
\v 17 Tsà kixi̱í kjoa̱ nga k'oa̱s'ín 'yatakòn‑ná nga 'ndseé chibá i̱t'aà ts'e̱ Cristo, chjoétjoì Onésimo koni tsà 'a̱n xi tichjoétjò‑ná.
\v 18 Tsà tjín mé kjoa̱ xi ch'o kisìko̱‑lè, koa̱ tsà mé xi kitje̱n‑t'in‑lè, 'a̱án ti̱kichjí‑ná.
\v 19 'A̱n, Pablo, 'a̱n sobá tìkjiì‑lè xo̱jo̱n jè. 'A̱n kíchjiá yije xi tje̱n‑la̱. Mìkiì mochjeén nga 'a̱n ko̱xán‑lè, jyeé tíjiìn‑lè nga 'a̱án kitje̱n‑t'in‑ná kjoa̱binachon‑lè.
\v 20 Ndí 'ndsè, k'oa̱á s'ín tìsìjé‑lè nga kàtasakó jngoò‑na̱ kjo̱ndaà i̱t'aà tsi̱ji, koni s'ín ok'ìn‑la̱ nga 'ndseé chibá i̱t'aà ts'e̱ Na̱'èn‑ná; ti̱je takoìn ini̱ma̱‑na̱ i̱t'aà ts'e̱ Cristo.
\v 21 Be‑ná nga sìkitasòn‑né; k'oa̱á ma‑ne nga tìsìkasén‑lè xo̱jo̱n jè; skanda 'beé‑la̱ takoàn, nga ìsa̱á tsatoó s'i̱in koni s'ín tìxan‑lè.
\v 22 K'oa̱á ti̱s'ín tìxan‑lè nga ti̱kíjnandaà jngoò‑ná i̱'nde ñánda ma síkjáya. K'oa̱á s'ín tìkoña nga jè Nainá kji̱'nchré‑né koni s'ín titsa̱nokjoàt'aà‑là, nga tsjá'nde‑na nga ko̱ma kjíkon‑nò.
\s1 'Én‑la̱ Pablo xi fehet'aà‑ne
\p 
\v 23 Tísíhixat'aà‑lè Epafras, xinguia̱á xi ngásòn nda̱yá titsa̱jna‑je̱n nga jè nga̱tjì‑la̱ Cristo Jesús.
\v 24 Ti̱koa̱á tísíhixat'aà‑lè Marcos, Aristarco, Demas ko̱ Lucas, xi síchját'aà‑na kjoa̱ ts'e̱ xá xi tìs'iaàn.
\p 
\v 25 Jè kàtìjnajiìn ini̱ma̱‑nò kjo̱ndaà‑la̱ Jesucristo xi otíxoma‑ná.
