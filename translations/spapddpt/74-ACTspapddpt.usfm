\v 18 \w Pablo|strong="G3972"\w* permaneció \w aún|strong="G2532"\w* \w muchos|strong="G2425"\w* \w días|strong="G2250"\w* \add en Corinto\add*. \w Se|strong="G2532"\w* despidió \w de|strong="G1722"\w* \w los|strong="G3588"\w* hermanos \w y|strong="G2532"\w* \w navegó|strong="G1602"\w* \w hacia|strong="G1519"\w* \w Siria|strong="G4947"\w* \w con|strong="G1722"\w* \w Priscila|strong="G4252"\w* \w y|strong="G2532"\w* Aquila. \w En|strong="G1722"\w* \w Cencreas|strong="G2747"\w* \w se|strong="G2532"\w* rapó \w la|strong="G3588"\w* \w cabeza|strong="G2776"\w*, \w porque|strong="G1063"\w* \w tenía|strong="G2192"\w* \w un|strong="G3588"\w* \w voto|strong="G2171"\w*.   
\p
\v 19 Llegaron \w a|strong="G1519"\w* Éfeso \w y|strong="G1161"\w* \w los|strong="G3588"\w* \w dejó|strong="G2641"\w* allí. \w Él|strong="G3588"\w* \w entró|strong="G1525"\w* \w en|strong="G1519"\w* \w la|strong="G3588"\w* \w congregación|strong="G4864"\w* \w y|strong="G1161"\w* discutía \w con|strong="G1519"\w* \w los|strong="G3588"\w* \w judíos|strong="G2453"\w*.  
\v 20 \w Cuando|strong="G1909"\w* ellos \w le|strong="G1909"\w* \w rogaron|strong="G2065"\w* \w que|strong="G1161"\w* permaneciera \w más|strong="G1161"\w* \w tiempo|strong="G5550"\w*, \w no|strong="G3756"\w* quiso.  
\v 21 \w Se|strong="G4314"\w* despidió \w de|strong="G4314"\w* \w ellos|strong="G3588"\w* \w y|strong="G2532"\w* \w dijo|strong="G3004"\w*: \w Si|strong="G2532"\w* \w Dios|strong="G2316"\w* \w quiere|strong="G2309"\w*, volveré \w a|strong="G4314"\w* ustedes. \w Y|strong="G2532"\w* zarpó \w de|strong="G4314"\w* Éfeso.   
\p
\v 22 Arribó \w a|strong="G1519"\w* \w Cesarea|strong="G2542"\w* \w y|strong="G2532"\w* saludó \w a|strong="G1519"\w* \w la|strong="G3588"\w* asamblea. Subió \w a|strong="G1519"\w* Antioquía  
\v 23 donde permaneció \w un|strong="G5100"\w* \w tiempo|strong="G5550"\w*.  
\s1 Tercer viaje misionero  
\p \w Salió|strong="G1831"\w* \w y|strong="G2532"\w* atravesó \w una|strong="G5100"\w* tras \w otra|strong="G5100"\w* \w las|strong="G3588"\w* regiones \w de|strong="G3588"\w* Galacia \w y|strong="G2532"\w* Frigia, \w y|strong="G2532"\w* fortalecía a \w todos|strong="G3956"\w* \w los|strong="G3588"\w* \w discípulos|strong="G3101"\w*.   
\s1 Ministerio de Apolos  
\p
\v 24 \w Entonces|strong="G1161"\w* \w llegó|strong="G2658"\w* \w a|strong="G1519"\w* Éfeso \w un|strong="G5100"\w* \w judío|strong="G2453"\w* \w llamado|strong="G3686"\w* Apolos, \w de|strong="G1722"\w* origen alejandrino, varón \w elocuente|strong="G3052"\w* \w y|strong="G1161"\w* \w poderoso|strong="G1415"\w* \w en|strong="G1722"\w* \w las|strong="G3588"\w* \w Escrituras|strong="G1124"\w*.  
\v 25 \w Éste|strong="G3778"\w* \w era|strong="G1510"\w* \w instruido|strong="G2727"\w* \w en|strong="G4012"\w* \w el|strong="G3588"\w* \w camino|strong="G3598"\w* \w del|strong="G3588"\w* \w Señor|strong="G2962"\w*. \w Era|strong="G1510"\w* \w ferviente|strong="G2204"\w* \w de|strong="G4012"\w* \w espíritu|strong="G4151"\w*. \w Hablaba|strong="G2980"\w* \w y|strong="G2532"\w* \w enseñaba|strong="G1321"\w* \w con|strong="G2532"\w* diligencia \w con|strong="G2532"\w* \w respecto|strong="G4012"\w* a \w Jesús|strong="G2424"\w*, \w aunque|strong="G2532"\w* \w solo|strong="G3441"\w* conocía \w el|strong="G3588"\w* bautismo \w de|strong="G4012"\w* \w Juan|strong="G2491"\w*.  
\v 26 \w Éste|strong="G3778"\w* \w comenzó|strong="G3778"\w* \w a|strong="G1722"\w* hablar \w con|strong="G1722"\w* osadía \w en|strong="G1722"\w* \w la|strong="G3588"\w* \w congregación|strong="G4864"\w* judía, \w pero|strong="G1161"\w* \w cuando|strong="G1722"\w* \w Priscila|strong="G4252"\w* \w y|strong="G2532"\w* Aquila \w lo|strong="G3588"\w* oyeron, \w lo|strong="G3588"\w* \w tomaron|strong="G4355"\w* \w aparte|strong="G4355"\w* \w y|strong="G2532"\w* \w le|strong="G1722"\w* expusieron \w más|strong="G1161"\w* exactamente \w el|strong="G3588"\w* \w Camino|strong="G3598"\w*.   
\p
\v 27 Cuando \w él|strong="G3588"\w* \w quiso|strong="G1014"\w* viajar \w a|strong="G1519"\w* Acaya \w para|strong="G1519"\w* animar \w a|strong="G1519"\w* \w los|strong="G3588"\w* hermanos, \add Priscila y Aquila\add* \w escribieron|strong="G1125"\w* \w a|strong="G1519"\w* \w los|strong="G3588"\w* \w discípulos|strong="G3101"\w* \w para|strong="G1519"\w* \w que|strong="G3588"\w* \w lo|strong="G3588"\w* recibieran. Cuando llegó, ayudó \w mucho|strong="G4183"\w* \w a|strong="G1519"\w* \w los|strong="G3588"\w* \w que|strong="G3588"\w* \w por|strong="G1223"\w* \w gracia|strong="G5485"\w* habían \w creído|strong="G4100"\w*.  
\v 28 Refutaba \w con|strong="G1223"\w* ímpetu \w a|strong="G1223"\w* \w los|strong="G3588"\w* \w judíos|strong="G2453"\w* \w en|strong="G1223"\w* público \w y|strong="G1063"\w* demostraba \w por|strong="G1223"\w* \w medio|strong="G1223"\w* \w de|strong="G1223"\w* \w las|strong="G3588"\w* \w Escrituras|strong="G1124"\w* \w que|strong="G3588"\w* \w Jesús|strong="G2424"\w* es \w el|strong="G3588"\w* \w Cristo|strong="G5547"\w*.   
\c 19  
\s1 Las Buenas Noticias a Éfeso  
\p
\v 1 Mientras Apolos \w estaba|strong="G1096"\w* \w en|strong="G1722"\w* \w Corinto|strong="G2882"\w*, \w Pablo|strong="G3972"\w* recorrió \w las|strong="G3588"\w* costas \w del|strong="G3588"\w* norte \w y|strong="G2532"\w* \w llegó|strong="G2064"\w* \w a|strong="G1519"\w* Éfeso. \w Halló|strong="G2147"\w* \w a|strong="G1519"\w* \w unos|strong="G5100"\w* \w discípulos|strong="G3101"\w*  
\v 2 \w y|strong="G1161"\w* \w les|strong="G4314"\w* preguntó: ¿\w Después|strong="G1161"\w* \w que|strong="G3588"\w* \w creyeron|strong="G4100"\w*, \w recibieron|strong="G2983"\w* \w el|strong="G3588"\w* \w Espíritu|strong="G4151"\w* Santo?  
\p \w Y|strong="G1161"\w* contestaron: ¡\w Ni|strong="G3761"\w* siquiera oímos \w que|strong="G3588"\w* \w hay|strong="G3588"\w* \w Espíritu|strong="G4151"\w* Santo!   
\p
\v 3 \w Y|strong="G1161"\w* \w les|strong="G1519"\w* volvió \w a|strong="G1519"\w* preguntar: ¿\w En|strong="G1519"\w* \w qué|strong="G3588"\w* \add nombre\add* fueron bautizados?  
\p \w Y|strong="G1161"\w* \w ellos|strong="G3588"\w* respondieron: \w En|strong="G1519"\w* \w el|strong="G3588"\w* bautismo \w de|strong="G1519"\w* \w Juan|strong="G2491"\w*.   
\p
\v 4 \w Entonces|strong="G1161"\w* \w Pablo|strong="G3972"\w* \w dijo|strong="G3004"\w*: \w Juan|strong="G2491"\w* bautizó \w con|strong="G3326"\w* \w un|strong="G3588"\w* bautismo \w de|strong="G1519"\w* cambio \w de|strong="G1519"\w* mente, \w y|strong="G1161"\w* anunció \w al|strong="G3588"\w* \w pueblo|strong="G2992"\w* \w que|strong="G3588"\w* creyeran \w en|strong="G1519"\w* \w el|strong="G3588"\w* \w que|strong="G3588"\w* \w vendría|strong="G2064"\w*, \w es|strong="G3778"\w* \w decir|strong="G3004"\w*, \w en|strong="G1519"\w* \w Jesús|strong="G2424"\w*.  
\v 5 Cuando oyeron \w esto|strong="G3588"\w*, fueron bautizados \w en|strong="G1519"\w* \w el|strong="G3588"\w* \w Nombre|strong="G3686"\w* \w del|strong="G3588"\w* \w Señor|strong="G2962"\w* \w Jesús|strong="G2424"\w*.  
\v 6 \w Cuando|strong="G1909"\w* \w Pablo|strong="G3972"\w* \w les|strong="G1909"\w* impuso \add las\add* \w manos|strong="G5495"\w*, \w el|strong="G3588"\w* \w Espíritu|strong="G4151"\w* Santo \w vino|strong="G2064"\w* \w sobre|strong="G1909"\w* \w ellos|strong="G3588"\w*. \w Hablaban|strong="G2980"\w* \w en|strong="G1909"\w* \w lenguas|strong="G1100"\w* \w y|strong="G2532"\w* \w profetizaban|strong="G4395"\w*.  
\v 7 \w En|strong="G3588"\w* total eran \w unos|strong="G3588"\w* 12 hombres.   
\p
\v 8 \w Entró|strong="G1525"\w* \w en|strong="G1519"\w* \w la|strong="G3588"\w* \w congregación|strong="G4864"\w* \w de|strong="G4012"\w* \w los|strong="G3588"\w* judíos \w y|strong="G2532"\w* hablaba osadamente durante \w tres|strong="G5140"\w* \w meses|strong="G3376"\w*. Discutía \w y|strong="G2532"\w* \w persuadía|strong="G3982"\w* \w con|strong="G1909"\w* \w respecto|strong="G1519"\w* \w al|strong="G3588"\w* reino \w de|strong="G4012"\w* \w Dios|strong="G2316"\w*.   
\p
\v 9 \w Pero|strong="G1161"\w* \w como|strong="G5613"\w* \w algunos|strong="G5100"\w* \w se|strong="G2532"\w* endurecieron \w y|strong="G2532"\w* no creyeron, maldijeron \w el|strong="G3588"\w* \w Camino|strong="G3598"\w* \w delante|strong="G1799"\w* \w de|strong="G1722"\w* \w la|strong="G3588"\w* \w multitud|strong="G4128"\w*.  
\p Pablo \w se|strong="G2532"\w* apartó \w de|strong="G1722"\w* \w ellos|strong="G3588"\w* \w y|strong="G2532"\w* \w se|strong="G2532"\w* llevó \w a|strong="G1722"\w* \w los|strong="G3588"\w* \w discípulos|strong="G3101"\w*. Discutía \w cada|strong="G2596"\w* \w día|strong="G2250"\w* \w en|strong="G1722"\w* \w la|strong="G3588"\w* \w escuela|strong="G4981"\w* \w de|strong="G1722"\w* Tirano  
\v 10 durante \w dos|strong="G1417"\w* \w años|strong="G2094"\w*, \w de|strong="G1909"\w* \w manera|strong="G1096"\w* \w que|strong="G3588"\w* \w todos|strong="G3956"\w* \w los|strong="G3588"\w* \w que|strong="G3588"\w* vivían \w en|strong="G1909"\w* Asia, \w judíos|strong="G2453"\w* \w y|strong="G2532"\w* \w griegos|strong="G1672"\w*, oyeron \w la|strong="G3588"\w* \w Palabra|strong="G3056"\w* \w del|strong="G3588"\w* \w Señor|strong="G2962"\w*.   
\p
\v 11 \w Dios|strong="G2316"\w* \w hacía|strong="G4160"\w* milagros extraordinarios \w por|strong="G1223"\w* \w medio|strong="G1223"\w* \w de|strong="G1223"\w* \w Pablo|strong="G3972"\w*.  
\v 12 Incluso \w les|strong="G1909"\w* llevaban \w a|strong="G1909"\w* \w los|strong="G3588"\w* enfermos pañuelos \w o|strong="G2228"\w* delantales \w de|strong="G1909"\w* \w su|strong="G3588"\w* \w cuerpo|strong="G5559"\w*, \w y|strong="G2532"\w* eran sanados \w de|strong="G1909"\w* \w sus|strong="G3588"\w* \w dolencias|strong="G3554"\w* \w y|strong="G2532"\w* \w salían|strong="G1607"\w* \w los|strong="G3588"\w* \w espíritus|strong="G4151"\w* \w malos|strong="G4190"\w*.   
\p
\v 13 \w Entonces|strong="G1161"\w* \w algunos|strong="G5100"\w* \w judíos|strong="G2453"\w* \w exorcistas|strong="G1845"\w* ambulantes \w también|strong="G2532"\w* intentaron invocar \w el|strong="G3588"\w* \w Nombre|strong="G3686"\w* \w del|strong="G3588"\w* \w Señor|strong="G2962"\w* \w Jesús|strong="G2424"\w* \w sobre|strong="G1909"\w* \w los|strong="G3588"\w* \w que|strong="G3588"\w* \w tenían|strong="G2192"\w* \w espíritus|strong="G4151"\w* malignos, \w y|strong="G2532"\w* \w decían|strong="G3004"\w*: ¡\w Los|strong="G3588"\w* \w conjuro|strong="G3726"\w* \w por|strong="G1909"\w* \w Jesús|strong="G2424"\w*, \w el|strong="G3588"\w* \w que|strong="G3588"\w* \w predica|strong="G2784"\w* \w Pablo|strong="G3972"\w*!  
\v 14 \w Esto|strong="G3778"\w* lo \w hacían|strong="G4160"\w* \w siete|strong="G2033"\w* \w hijos|strong="G5207"\w* \w de|strong="G1161"\w* \w un|strong="G5100"\w* tal Esceva, sumo sacerdote \w judío|strong="G2453"\w*.   
\p
\v 15 \w Pero|strong="G1161"\w* \w el|strong="G3588"\w* \w espíritu|strong="G4151"\w* \w maligno|strong="G4190"\w* les respondió: \w Conozco|strong="G1097"\w* \w a|strong="G1161"\w* \w Jesús|strong="G2424"\w* \w y|strong="G2532"\w* entiendo \w a|strong="G1161"\w* \w Pablo|strong="G3972"\w*, \w pero|strong="G1161"\w* ustedes, ¿\w quiénes|strong="G5101"\w* \w son|strong="G1510"\w*?   
\p
\v 16 \w El|strong="G3588"\w* hombre \w en|strong="G1722"\w* \w quien|strong="G3739"\w* estaba \w el|strong="G3588"\w* \w espíritu|strong="G4151"\w* \w maligno|strong="G4190"\w* \w se|strong="G1438"\w* abalanzó \w sobre|strong="G1909"\w* \w ellos|strong="G3588"\w* \w y|strong="G2532"\w* dominó \w a|strong="G1909"\w* dos. Prevaleció \w contra|strong="G2596"\w* \w ellos|strong="G3588"\w* \w de|strong="G1537"\w* \w tal|strong="G5620"\w* \w modo|strong="G5620"\w* \w que|strong="G3588"\w* \w huyeron|strong="G1628"\w* \w de|strong="G1537"\w* \w aquella|strong="G1565"\w* \w casa|strong="G3624"\w* \w desnudos|strong="G1131"\w* \w y|strong="G2532"\w* \w heridos|strong="G5135"\w*.   
\p
\v 17 \w Todos|strong="G3956"\w* \w los|strong="G3588"\w* habitantes \w de|strong="G1909"\w* Éfeso, \w judíos|strong="G2453"\w* \w y|strong="G2532"\w* \w griegos|strong="G1672"\w*, supieron \w esto|strong="G3778"\w*. \w El|strong="G3588"\w* \w temor|strong="G5401"\w* \w se|strong="G1438"\w* apoderó \w de|strong="G1909"\w* \w todos|strong="G3956"\w* \w ellos|strong="G3588"\w*, \w y|strong="G2532"\w* \w el|strong="G3588"\w* \w Nombre|strong="G3686"\w* \w del|strong="G3588"\w* \w Señor|strong="G2962"\w* \w Jesús|strong="G2424"\w* \w era|strong="G1096"\w* engrandecido.   
\p
\v 18 \w Muchos|strong="G4183"\w* \w creyentes|strong="G4100"\w* llegaban, confesaban \w y|strong="G2532"\w* declaraban \w sus|strong="G3588"\w* malas prácticas.  
\v 19 \w Entonces|strong="G1161"\w* \w muchos|strong="G2425"\w* \w de|strong="G3588"\w* \w los|strong="G3588"\w* \w que|strong="G3588"\w* practicaban \w las|strong="G3588"\w* magias, recogieron \w los|strong="G3588"\w* rollos \w y|strong="G2532"\w* \add los\add* \w quemaron|strong="G2618"\w* públicamente. Calcularon \w su|strong="G3588"\w* costo: 50.000 piezas \w de|strong="G3588"\w* plata.  
\v 20 \w Así|strong="G3779"\w* crecía \w poderosamente|strong="G2596"\w* \w y|strong="G2532"\w* \w prevalecía|strong="G2480"\w* \w la|strong="G3588"\w* \w Palabra|strong="G3056"\w* \w del|strong="G3588"\w* \w Señor|strong="G2962"\w*.   
\p
\v 21 \w Después|strong="G3326"\w* \w que|strong="G3754"\w* ocurrió \w esto|strong="G3778"\w*, \w Pablo|strong="G3972"\w* \w pasó|strong="G1330"\w* \w por|strong="G1722"\w* \w Macedonia|strong="G3109"\w* \w y|strong="G2532"\w* Acaya. \w Luego|strong="G1722"\w* decidió \w en|strong="G1722"\w* \w su|strong="G3588"\w* \w espíritu|strong="G4151"\w* \w ir|strong="G4198"\w* \w a|strong="G1519"\w* Jerusalén. \w Y|strong="G2532"\w* \w dijo|strong="G3004"\w*: \w Después|strong="G3326"\w* \w que|strong="G3754"\w* \w vaya|strong="G4198"\w* \w allí|strong="G1563"\w*, \w también|strong="G2532"\w* necesito \w ir|strong="G4198"\w* \w a|strong="G1519"\w* \w Roma|strong="G4516"\w*.  
\v 22 Luego envió \w a|strong="G1519"\w* \w sus|strong="G3588"\w* ayudantes \w Timoteo|strong="G5095"\w* \w y|strong="G2532"\w* \w Erasto|strong="G2037"\w* \w a|strong="G1519"\w* \w Macedonia|strong="G3109"\w* \w y|strong="G2532"\w* \w él|strong="G3588"\w* permaneció \w un|strong="G3588"\w* \w tiempo|strong="G5550"\w* \w en|strong="G1519"\w* Asia.   
\s1 Alboroto en Éfeso  
\p
\v 23 \w En|strong="G2596"\w* \w aquel|strong="G3588"\w* \w tiempo|strong="G2540"\w* \w hubo|strong="G1096"\w* \w un|strong="G3588"\w* gran \w alboroto|strong="G5017"\w* \w con|strong="G2596"\w* \w respecto|strong="G4012"\w* \w al|strong="G3588"\w* \w Camino|strong="G3598"\w*.   
\p
\v 24 \w Demetrio|strong="G1216"\w*, \w un|strong="G5100"\w* platero \w que|strong="G3588"\w* \w hacía|strong="G4160"\w* \w templos|strong="G3485"\w* \w de|strong="G3588"\w* plata \w de|strong="G3588"\w* Artemisa, conseguía mucha \w ganancia|strong="G2039"\w* para \w los|strong="G3588"\w* diseñadores.  
\v 25 \w Los|strong="G3588"\w* reunió juntamente \w con|strong="G1537"\w* \w sus|strong="G3588"\w* artesanos. Les \w dijo|strong="G3004"\w*: Varones, sabemos \w que|strong="G3754"\w* \w nuestra|strong="G3588"\w* prosperidad \w se|strong="G1987"\w* basa \w en|strong="G1537"\w* \w este|strong="G3778"\w* negocio.  
\v 26 \w Pero|strong="G2532"\w* ustedes \w ven|strong="G2334"\w* \w y|strong="G2532"\w* oyen \w que|strong="G3754"\w* \w este|strong="G3778"\w* \w Pablo|strong="G3972"\w* persuadió \w a|strong="G1223"\w* \w una|strong="G3588"\w* considerable \w multitud|strong="G3793"\w* \w en|strong="G1223"\w* Éfeso \w y|strong="G2532"\w* \w en|strong="G1223"\w* \w casi|strong="G4975"\w* \w toda|strong="G3956"\w* Asia, \w y|strong="G2532"\w* \w la|strong="G3588"\w* desvió cuando \w dijo|strong="G3004"\w* \w que|strong="G3754"\w* \w no|strong="G3756"\w* \w son|strong="G1510"\w* \w dioses|strong="G2316"\w* \w los|strong="G3588"\w* \w que|strong="G3754"\w* \w se|strong="G1096"\w* \w hacen|strong="G1096"\w* \w con|strong="G1223"\w* \w las|strong="G3588"\w* \w manos|strong="G5495"\w*.  
\v 27 \w Con|strong="G2532"\w* \w esto|strong="G3778"\w* \w se|strong="G2532"\w* corren riesgos: \w nuestro|strong="G2249"\w* \w negocio|strong="G3313"\w* sería desacreditado. \w También|strong="G2532"\w* \w el|strong="G3588"\w* \w templo|strong="G2411"\w* \w de|strong="G1519"\w* \w la|strong="G3588"\w* \w gran|strong="G3173"\w* \w diosa|strong="G2299"\w* Artemisa sería estimado \w como|strong="G2532"\w* \w nada|strong="G3762"\w*, \w y|strong="G2532"\w* \w aquella|strong="G3588"\w* \w diosa|strong="G2299"\w*, \w a|strong="G1519"\w* \w quien|strong="G3739"\w* \w toda|strong="G3650"\w* Asia \w y|strong="G2532"\w* \w la|strong="G3588"\w* humanidad adoran, sería despojada \w de|strong="G1519"\w* \w su|strong="G3588"\w* \w grandeza|strong="G3168"\w*.   
