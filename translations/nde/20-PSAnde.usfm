\d Ingoma yemiqanso.
\q1 
\v 1 Kwathi lapho \nd uThixo\nd* ebuyisa izithunjwa eZiyoni,
\q2 sasinjengabantu abaphuphayo.
\q1 
\v 2 Imilomo yethu yayigcwele ngohleko,
\q2 lezindimi zethu zicula izingoma zentokozo.
\q1 Basebesithi abezizwe,
\q2 “\nd UThixo\nd* ubenzele izinto ezimangalisayo.”
\q1 
\v 3 \nd UThixo\nd* usenzele izinto ezimangalisayo,
\q2 ngakho siyathokoza kakhulu.
\b
\q1 
\v 4 Buyisa ukuphumelela kwethu, Oh \nd Thixo\nd*,
\q2 njengemifula eseNegebi.
\q1 
\v 5 Labo abahlanyela ngezinyembezi
\q2 bazavuna ngezingoma zentokozo.
\q1 
\v 6 Lowo ophuma ekhala,
\q2 ethwele inhlanyelo ukuba ayehlanyela
\q1 uzabuya ngezingoma zentokozo,
\q2 ethwele izinyanda.
\c 127
\cl Ihubo 127
\d Ingoma yemiqanso. ElikaSolomoni.
\q1 
\v 1 Ngaphandle kokuba \nd uThixo\nd* ayakhe indlu,
\q2 abakhi bayo basebenzela ize.
\q1 Ngaphandle kokuba \nd uThixo\nd* awulinde umuzi,
\q2 abalindi bawo balinda ize.
\q1 
\v 2 Kuyize ukuvuka
\q2 kwenu ngovivi liphinde libambe kuze kuhlwe,
\q1 lisebenzela ukudla kokufaka emlonyeni
\q2 ngoba upha ubuthongo kulabo abathandayo.
\b
\q1 
\v 3 Amadodana ayilifa elivela \nd kuThixo\nd*,
\q2 abantwana bangumvuzo ovela kuye.
\q1 
\v 4 Njengemitshoko esandleni sebutho
\q2 anjalo amadodana azelwe ngumuntu esesemutsha.
\q1 
\v 5 Ubusisiwe umuntu
\q2 omxhaka wakhe ugcwele wona.
\q1 Kayikuyangeka nxa sebedibana
\q2 lezitha entubeni.
\c 128
\cl Ihubo 128
\d Ingoma yemiqanso.
\q1 
\v 1 Babusisiwe bonke abamesabayo \nd uThixo\nd*,
\q2 abahamba ngezindlela zakhe.
\q1 
\v 2 Lizakudla izithelo zomsebenzi wenu;
\q2 izibusiso lokuphumelela kuzakuba ngokwenu.
\q1 
\v 3 Umkakho wesifazane uzakuba njengevini elithela
\q2 kakhulu phakathi kwendlu yakho;
\q1 amadodana akho azakuba njengamahlumela e-oliva
\q2 esetafuleni yakho.
\q1 
\v 4 Ibusisiwe kanjalo
\q2 indoda eyesaba \nd uThixo\nd*.
\b
\q1 
\v 5 Sengathi \nd uThixo\nd* angakubusisa eseZiyoni
\q2 insuku zonke zokuphila kwakho;
\q2 sengathi ungakubona ukuphumelela kweJerusalema,
\q1 
\v 6 njalo sengathi ungaphila uze ubone isizukulwane sakho.
\q2 Ukuthula kakube ku-Israyeli.
\c 129
\cl Ihubo 129
\d Ingoma yemiqanso.
\q1 
\v 1 Sebengihluphe kakhulu kusukela ebutsheni bami
\q2 katsho njalo u-Israyeli,
\q1 
\v 2 sebengihluphe kakhulu kusukela ebutsheni bami,
\q2 kodwa kabangehlulanga.
\q1 
\v 3 Abalimi bawulimile umhlane wami
\q2 benza imifolo emide.
\q1 
\v 4 Kodwa \nd uThixo\nd* ulungile;
\q2 ungikhulule ezintanjeni zababi.
\b
\q1 
\v 5 Akuthi bonke abayizondayo iZiyoni
\q2 babuyiselwe emuva beyangekile.
\q1 
\v 6 Sengathi bangaba njengotshani obukhula ephahleni
\q2 obubuna bungakakhuli;
\q1 
\v 7 umvuni angeke agcwalisa isandla sakhe ngabo,
\q2 loba lowo obuthayo agcwalise izingalo zakhe.
\q1 
\v 8 Sengathi labo abadlulayo bangabokuthi,
\q2 “Izibusiso \nd zikaThixo\nd* mazibe kuwe;
\q2 siyakubusisa ngegama \nd likaThixo\nd*.”
\c 130
\cl Ihubo 130
\d Ingoma yemiqanso.
\q1 
\v 1 Ngingaphansi ekujuleni ngiyakhala kuwe, \nd Thixo\nd*;
\q2 
\v 2 Thixo, zwana ilizwi lami.
\q1 Indlebe zakho kazilalele ukukhala kwami
\q2 ngicela umusa.
\b
\q1 
\v 3 Aluba wena, \nd Thixo\nd* ububhala phansi zonke izono,
\q2 ngubani ongema na Nkosi?
\q1 
\v 4 Kodwa kuwe kulentethelelo;
\q2 ngalokho uyesatshwa.
\b
\q1 
\v 5 Ngiyamlindela \nd uThixo\nd*, umphefumulo wami uyalinda,
\q2 ngibeka ithemba lami elizwini lakho.
\q1 
\v 6 Umphefumulo wami ulindela uThixo
\q2 okudlula abalindi bemelele ukusa,
\q2 okudlula abalindi bemelele ukusa.
\b
\q1 
\v 7 We Israyeli, beka ithemba lakho \nd kuThixo\nd*,
\q2 ngoba kuye \nd uThixo\nd* kulothando olungaphuthiyo
\q2 njalo kuye kulensindiso epheleleyo.
\q1 
\v 8 Yena ngokwakhe uzahlenga u-Israyeli
\q2 kuzozonke izono zabo.
\c 131
\cl Ihubo 131
\d Ingoma yemiqanso. ElikaDavida.
\q1 
\v 1 Inhliziyo yami kayizikhukhumezi, Oh \nd Thixo\nd*,
\q2 amehlo ami kawaziphakamisi;
\q1 kangizihluphi ngezindaba ezinkulu
\q2 loba ngezinto ezimangalisayo kimi.
\q1 
\v 2 Kodwa ngiwupholisile ngawuthulisa umphefumulo wami;
\q2 njengomntwana okhutshwe ebeleni likanina,
\q2 njengomntwana okhutshwe ebeleni
\q2 unjalo umphefumulo wami uthule ngaphakathi kwami.
\b
\q1 
\v 3 Oh, Israyeli, beka ithemba lakho \nd kuThixo\nd*
\q2 manje kuze kube phakade.
\c 132
\cl Ihubo 132
\d Ingoma yemiqanso.
\q1 
\v 1 Oh \nd Thixo\nd*, khumbula uDavida
\q2 ngezinhlupheko zonke azibhenselayo.
\b
\q1 
\v 2 Wafunga isifungo \nd kuThixo\nd*
\q2 wenza isithembiso kuMninimandla kaJakhobe:
\q1 
\v 3 “Angizukungena endlini yami
\q2 loba ngiye embhedeni wami,
\q1 
\v 4 angiyikuwavumela amehlo ami ubuthongo,
\q2 akukuba lakuwozela enkopheni zami,
\q1 
\v 5 ngize ngifumane indawo \nd kaThixo\nd*,
\q2 indawo yokuhlala uMninimandla kaJakhobe.”
\b
\q1 
\v 6 Sakuzwa lokhu e-Efrathi,
\q2 sakubona emangweni waseJayari:
\q1 
\v 7 “Kasiye lapho ahlala khona;
\q2 kasikhonze phansi kwesihlalo sakhe.
\q1 
\v 8 Phakama, Oh \nd Thixo\nd*, ubuye endaweni yakho yokuphumula,
\q2 wena umtshokotsho wesivumelwano elitshengisa amandla akho.
\q1 
\v 9 Sengathi abaphristi bakho bangembeswa ngokulunga;
\q2 sengathi labathembekileyo bakho bangahlabelela ngentokozo.”
\b
\q1 
\v 10 Ngenxa yenceku yakho uDavida,
\q2 ungamfulatheli ogcotshiweyo wakho.
\b
\q1 
\v 11 \nd UThixo\nd* wenza isifungo kuDavida,
\q2 isifungo esiqinileyo angakusaphula wathi:
\q1 “Omunye wezizukulwane zakho
\q2 ngizambeka esihlalweni sakho sobukhosi
\q1 
\v 12 aluba amadodana akho egcina isivumelwano sami
\q2 lezimiso engibafundisa zona,
\q1 lapho-ke amadodana abo azahlala esihlalweni sakho
\q2 sobukhosi kuze kube nini lanini.”
\b
\q1 
\v 13 Ngoba \nd uThixo\nd* uyikhethile iZiyoni,
\q2 uyithandile ukuba yindawo yakhe yokuhlala:
\q1 
\v 14 “Le yindawo yami yokuphumula lanini;
\q2 lapha ngizahlala ngisebukhosini, ngoba ngiyithandile
\q1 
\v 15 ngizayibusisa ngokudla okunengi;
\q2 abayanga bayo ngizabasuthisa ngokudla.
\q1 
\v 16 Ngizavunulisa abaphristi bayo ngensindiso,
\q2 labathembekileyo bakhe bazahlabelela ngentokozo nini lanini.
\b
\q1 
\v 17 Lapha ngizakhulisa uphondo lukaDavida
\q2 ngilungisele ogcotshiweyo wami isibane.
\q1 
\v 18 Ngizakwembathisa izitha ngehlazo,
\q2 kodwa umqhele osekhanda lakhe uzakhazimula.”
\c 133
\cl Ihubo 133
\d Ingoma yemiqanso. ElikaDavida.
\q1 
\v 1 Bheka kuhle, kuyabukeka kangakanani
\q2 nxa abazalwane behlezi ndawonye ngokuzwana!
\b
\q1 
\v 2 Kunjengamafutha aligugu athelwe ekhanda,
\q2 ejuluka endevini,
\q1 ejuluka endevini zika-Aroni,
\q2 ehlele emabheqeni ezigqoko zakhe.
\q1 
\v 3 Kufana lokuthi amazolo aseHemoni
\q2 akhithikela eNtabeni iZiyoni.
\q1 Ngoba lapho \nd uThixo\nd* wehlisela isibusiso sakhe,
\q2 esiyikuphila okwaphakade.
\c 134
\cl Ihubo 134
\d Ingoma yemiqanso.
\q1 
\v 1 Dumisani \nd uThixo\nd*, lonke lina zinceku \nd zikaThixo\nd*
\q2 eliqhuba inkonzo endlini \nd kaThixo\nd* ebusuku.
\q1 
\v 2 Phakamisani izandla zenu endlini engcwele
\q2 lidumise \nd uThixo\nd*.
\b
\q1 
\v 3 Sengathi \nd uThixo\nd*,
\q2 uMenzi wezulu lomhlaba,
\q2 angalibusisa eseZiyoni.
\c 135
\cl Ihubo 135
\q1 
\v 1 Dumisani \nd uThixo\nd*.
\b
\q1 Dumisani ibizo \nd likaThixo\nd*;
\q2 mdumiseni lina zinceku \nd zikaThixo\nd*,
\q1 
\v 2 lina eliqhuba inkonzo endlini \nd kaThixo\nd*,
\q2 emagumeni endlu kaNkulunkulu.
\b
\q1 
\v 3 Dumisani \nd uThixo\nd* ngoba \nd uThixo\nd* ulungile;
\q2 hlabelani indumiso ebizweni lakhe ngoba lokho kuhle.
\q1 
\v 4 Ngoba \nd uThixo\nd* usemkhethile uJakhobe ukuba ngowakhe,
\q2 u-Israyeli ukuba yinotho yakhe eligugu.
\b
\q1 
\v 5 Ngiyazi ukuthi \nd uThixo\nd* mkhulu,
\q2 lokuthi iNkosi yethu inkulu kulabonkulunkulu bonke.
\q1 
\v 6 \nd UThixo\nd* wenza loba yini ayifunayo,
\q2 emazulwini lasemhlabeni,
\q2 enlwandle lasezinzikini zazo.
\q1 
\v 7 Wenza amayezi aqubuka emikhawulweni yomhlaba;
\q2 uthuma umbane kanye lezulu,
\q2 avulele umoya oseziphaleni zakhe.
\b
\q1 
\v 8 Wawalahla phansi amazibulo aseGibhithe,
\q2 amazibulo abantu lawezinyamazana.
\q1 
\v 9 Wathumela izibonakaliso lezimangaliso zakhe
\q2 phakathi kwakho, wena Gibhithe,
\q2 phezu kukaFaro lezinceku zakhe zonke.
\q1 
\v 10 Wazilahla phansi izizwe ezinengi
\q2 wabulala amakhosi alamandla,
\q1 
\v 11 uSihoni inkosi yama-Amori,
\q2 u-Ogi inkosi yaseBhashani
\q2 lawo wonke amakhosi aseKhenani
\q1 
\v 12 wanika ilizwe labo laba yilifa,
\q2 ilifa labantu bakhe, u-Israyeli.
\b
\q1 
\v 13 Ibizo lakho, Oh \nd Thixo\nd*, limi kuze kube nininini,
\q2 udumo lwakho, Oh \nd Thixo\nd*, ezizukulwaneni zonke.
\q1 
\v 14 Ngoba \nd uThixo\nd* uzabalamulela abantu bakhe
\q2 abe lesihawu ezincekwini zakhe.
\b
\q1 
\v 15 Izithombe zezizwe ziyisiliva legolide,
\q2 zenziwe ngezandla zabantu.
\q1 
\v 16 Zilemilomo, kodwa kazikhulumi,
\q2 amehlo, kodwa kaziboni;
\q1 
\v 17 zilezindlebe, kodwa kazizwa,
\q2 njalo kazilamphefumulo emilonyeni yazo.
\q1 
\v 18 Labo abazenzayo bazakuba njengazo,
\q2 kube njalo lakulabo abathemba kuzo.
\b
\q1 
\v 19 Wena ndlu ka-Israyeli, dumisa \nd uThixo\nd*;
\q2 wena ndlu ka-Aroni, dumisa \nd uThixo\nd*;
\q1 
\v 20 wena ndlu kaLevi, dumisa \nd uThixo\nd*
\q2 lina elimesabayo, dumisani \nd uThixo\nd*.
\q1 
\v 21 Udumo alube \nd uThixo\nd* lusuka eZiyoni,
\q2 kuye ohlala eJerusalema.
\b
\q1 Dumisani \nd uThixo\nd*.
\c 136
\cl Ihubo 136
\q1 
\v 1 Bongani \nd uThixo\nd*, ngoba ulungile.
\qr Uthando lwakhe lumi laphakade.
\q1 
\v 2 Bongani uNkulunkulu wabonkulunkulu.
\qr Uthando lwakhe lumi laphakade.
\q1 
\v 3 Bongani uMbusi wababusi:
\qr Uthando lwakhe lumi kuze kube laphakade.
\b
\q1 
\v 4 Kuye yedwa owenza izimanga ezinkulu,
\qr uthando lwakhe lumi laphakade.
\q1 
\v 5 Owathi ngokuzwisisa kwakhe wenza amazulu,
\qr uthando lwakhe lumi laphakade.
\q1 
\v 6 Owendlala umhlaba phezu kwamanzi,
\qr uthando lwakhe lumi laphakade.
\q1 
\v 7 Owenza izibane ezinkulu,
\qr uthando lwakhe lumi laphakade.
\q1 
\v 8 Ilanga ukubusa emini,
\qr uthando lwakhe lumi laphakade.
\q1 
\v 9 Inyanga lezinkanyezi ukubusa ebusuku,
\qr uthando lwakhe lumi laphakade.
\b
\q1 
\v 10 Kuye owatshaya walalisa amazibulo aseGibhithe,
\qr uthando lwakhe lumi laphakade.
\q1 
\v 11 Wakhupha u-Israyeli phakathi kwabo,
\qr uthando lwakhe lumi laphakade.
\q1 
\v 12 Ngesandla esilamandla lengalo eyeluliweyo,
\qr uthando lwakhe lumi laphakade.
\b
\q1 
\v 13 Kuye owadabula uLwandle oluBomvu lwehlukana,
\qr uthando lwakhe lumi laphakade.
\q1 
\v 14 Wakhuphula u-Israyeli phakathi kwalo,
\qr uthando lwakhe lumi laphakade.
\q1 
\v 15 Kodwa wakhukhulela uFaro lempi yakhe eLwandle oluBomvu,
\qr uthando lwakhe lumi laphakade.
\b
\q1 
\v 16 Wahola abantu bakhe enkangala,
\qr uthando lwakhe lumi laphakade.
\b
\q1 
\v 17 Owalahla phansi amakhosi amakhulu,
\qr uthando lwakhe lumi laphakade.
\q1 
\v 18 Wabulala amakhosi esabekayo,
\qr uthando lwakhe lumi laphakade,
\q1 
\v 19 uSihoni inkosi yama-Amori,
\qr uthando lwakhe lumi laphakade,
\q1 
\v 20 lo-Ogi inkosi yaseBhashani,
\qr uthando lwakhe lumi laphakade.
\q1 
\v 21 Wanikela amazwe abo njengelifa,
\qr uthando lwakhe lumi laphakade.
\q1 
\v 22 Abayilifa encekwini yakhe u-Israyeli,
\qr uthando lwakhe lumi laphakade.
\b
\q1 
\v 23 Kuye Yedwa owasikhumbula singesibantu balutho,
\qr uthando lwakhe lumi laphakade.
\q1 
\v 24 Wasikhulula ezitheni zethu,
\qr uthando lwakhe lumi laphakade.
\q1 
\v 25 Njalo onika ukudla izidalwa zonke,
\qr uthando lwakhe lumi laphakade.
\b
\q1 
\v 26 Bongani uNkulunkulu wasezulwini,
\qr uthando lwakhe lumi laphakade.
\c 137
\cl Ihubo 137
\q1 
\v 1 Ngasemifuleni yaseBhabhiloni sahlala phansi sakhala
\q2 lapho sasikhumbula iZiyoni.
\q1 
\v 2 Khona lapho ezihlahleni zemidubu
\q2 saphanyeka amachacho ethu,
\q1 
\v 3 ngoba khonapho abathumbi bethu bacela izingoma kithi,
\q2 labahlukuluzi bethu bafuna izingoma zentokozo;
\q2 bathi, “Sihlabeleleni enye yezingoma zaseZiyoni!”
\b
\q1 
\v 4 Singazihlabela kanjani izingoma \nd zikaThixo\nd*
\q2 siselizweni lemzini na?
\q1 
\v 5 Aluba ngikukhohlwa, Oh Jerusalema,
\q2 isandla sami sokunene kasilahlekelwe yibungcitshi baso.
\q1 
\v 6 Sengathi ulimi lwami lunganamathela elwangeni lomlomo wami
\q2 uba ngingakukhumbuli wena,
\q1 uba ngingathathi iJerusalema
\q2 njengentokozo yami ephezu konke.
\b
\q1 
\v 7 Khumbula, Oh \nd Thixo\nd*, ama-Edomi akwenzayo
\q2 mhla iJerusalema ithunjwa.
\q1 “Lidilizeni,” baklabalala,
\q2 “lidilizeni kanye lezisekelo zalo!”
\q1 
\v 8 Wena Ndodakazi yaseBhabhiloni,
\q2 oqunyelwe ukubhubha,
\q2 ubusisiwe lowo okuphindiselayo ngalokho okwenzileyo kithi.
\q1 
\v 9 Ubusisiwe lowo othatha insane zakho,
\q2 azisakazele ematsheni.
\c 138
\cl Ihubo 138
\d ElikaDavida.
\q1 
\v 1 Ngizakudumisa, \nd Thixo\nd*, ngenhliziyo yami yonke;
\q2 phambi kwabo “nkulunkulu” ngizahlabelela udumo lwakho.
\q1 
\v 2 Ngizakhothama ngikhangele ethempelini lakho elingcwele
\q2 ngidumise ibizo lakho,
\q2 ngenxa yothando lwakho lokuthembeka kwakho,
\q1 ngoba uphakamise ngaphezu kwezinto zonke
\q2 ibizo lakho lelizwi lakho.
\q1 
\v 3 Ngabiza wena wangiphendula;
\q2 wangenza ngaba lesibindi lenhliziyo eqinileyo.
\b
\q1 
\v 4 Sengathi wonke amakhosi omhlaba angakudumisa, Oh \nd Thixo\nd*,
\q2 lapho esizwa amazwi omlomo wakho.
\q1 
\v 5 Sengathi bangahlabela ngezindlela \nd zikaThixo\nd*
\q2 ngoba inkazimulo \nd kaThixo\nd* inkulu.
\b
\q1 
\v 6 Loba \nd uThixo\nd* ephakeme, uyabananza abathobekileyo,
\q2 kodwa abazigqajayo ubazi ekhatshana labo.
\q1 
\v 7 Loba ngihamba phakathi kohlupho
\q2 uyayilondoloza impilo yami;
\q1 uyaselula isandla sakho ukungivikela elakeni lwezitha zami,
\q2 ngesandla sakho sokunene uyangisindisa.
\q1 
\v 8 \nd UThixo\nd* uzagcwalisa icebo lakhe ngami;
\q2 uthando lwakho, Oh \nd Thixo\nd*, lumi laphakade
\q2 ungawutshiyi umsebenzi wezandla zakho.
\c 139
\cl Ihubo 139
\d Kumqondisi wokuhlabela. ElikaDavida. Ihubo.
\q1 
\v 1 Oh \nd Thixo\nd*, usungihlolile
\q2 usungazi.
\q1 
\v 2 Uyakwazi lapho ngihlala lalapho ngiphakama;
\q2 uyayibona imicabango yami lanxa ukhatshana.
\q1 
\v 3 Uyananzelela ukuphuma kwami lokulala phansi kwami;
\q2 uzazi kuhle zonke izindlela zami.
\q1 
\v 4 Ilizwi lingakabi khona elimini lwami
\q2 usulazi lonke, wena \nd Thixo\nd*.
\q1 
\v 5 Uyangihonqolozela emuva laphambili;
\q2 ubekile isandla sakho phezu kwami.
\q1 
\v 6 Ukwazi okunje kungumangaliso kimi,
\q2 kuphakeme kakhulu ngeke ngikufinyelele.
\b
\q1 
\v 7 Ngingaya ngaphi ngisuke eMoyeni wakho na?
\q2 Ngingabalekela ngaphi ngisuke kuwe na?
\q1 
\v 8 Ngingakhuphukela emazulwini, ukhona lapho;
\q2 nxa ngilala ezinzikini, ukhona lapho.
\q1 
\v 9 Aluba ngindiza ngamaphiko okusa,
\q2 aluba ngisehlela ngaphetsheya kolwandle,
\q1 
\v 10 lalapho isandla sakho sizangikhokhela,
\q2 isandla sakho sokunene sizangibamba singiqinise.
\q1 
\v 11 Nxa ngisithi, “Ngempela ubumnyama buzangifihla
\q2 ukukhanya kube yibusuku eduze kwami,”
\q1 
\v 12 lalobo bumnyama kabukuba mnyama kuwe;
\q2 ubusuku buzakhanya njengemini,
\q2 ngoba ubumnyama buyikukhanya kuwe.
\b
\q1 
\v 13 Ngoba wadala ingaphakathi yobuyimi;
\q2 wangiphetha kuhle ndawonye esiswini sikamama.
\q1 
\v 14 Ngiyakudumisa ngokuthi ngabunjwa ngesimanga esesabekayo;
\q2 iyamangalisa imisebenzi yakho,
\q2 lokho ngikwazi kamhlophe.
\q1 
\v 15 Isimo samathambo ami sasingafihlekanga kuwe
\q2 lapho ngangisenziwa endaweni esithekileyo.
\q2 Lapho ngangiselukelwa ndawonye ezinzikini zomhlaba,
\q1 
\v 16 amehlo akho awubona umzimba wami ungakabi lesimo.
\q2 Zonke insuku ezamiselwa mina zabhalwa encwadini yakho
\q2 lalunye lwazo lungakabi khona.
\q1 
\v 17 Iligugu elinganani kimi imicabango yakho, Oh Nkulunkulu!
\q2 Bukhulu kanganani ubunengi bayo!
\q1 
\v 18 Aluba ngingayibala
\q2 ingedlula ubunengi bezinhlamvu zetshebetshebe.
\q2 Ngithi nxa ngivuka ngibe ngilokhu ngilawe.
\b
\q1 
\v 19 Ungasake ubabulale ababi, awu Nkulunkulu!
\q2 Sukani kimi lina bachithi begazi!
\q1 
\v 20 Bakhuluma ngawe beqonde ububi;
\q2 abakuphikisayo badlala ngebizo lakho.
\q1 
\v 21 Kangibazondi yini abakuzondayo na Oh, \nd Thixo\nd*,
\q2 ngibenyanye labo abakuvukelayo na?
\q1 
\v 22 Ngiyabazonda ngenzondo yonke;
\q2 ngithi bayizitha zami.
\q1 
\v 23 Ngihlola, Oh Nkulunkulu, uyazi inhliziyo yami;
\q2 ngizama ukuze wazi ukunqineka kwemicabango yami.
\q1 
\v 24 Ake ubone ingabe kulendledlana embi kimi,
\q2 ungihole ngendlela yaphakade.
\c 140
\cl Ihubo 140
\d Kumqondisi wokuhlabela. Ihubo LikaDavida.
\q1 
\v 1 Ngilamulela, Oh \nd Thixo\nd*, ebantwini ababi;
\q2 ngivikela ebantwini bodlakela,
\q1 
\v 2 abakha amacebo amabi ezinhliziyweni zabo
\q2 bahlokomise impi ukusa kwamalanga.
\q1 
\v 3 Benza izindimi zabo zicije njengezenyoka;
\q2 ubuhlungu benhlangwana busezindebeni zabo.
\b
\q1 
\v 4 Ngivikela, Oh \nd Thixo\nd*, ezandleni zababi;
\q2 ngiphephisa ebantwini bodlakela
\q2 abaceba ukungigwenxa.
\q1 
\v 5 Abantu abazigqajayo bangifihlele isifu;
\q2 sebewanwebile amambule abo
\q2 bangithiya lapha lalapha endleleni yami.
\b
\q1 
\v 6 Oh \nd Thixo\nd*, ngithi kuwe, “UnguNkulunkulu wami.”
\q2 Zwana, ukukhala kwami ngicela umusa.
\q1 
\v 7 Oh \nd Thixo\nd* wobukhosi, mhlengi wami olamandla,
\q2 ovikela ikhanda lami ngelanga lempi
\q1 
\v 8 ungavumeli ababi izifiso zabo Oh \nd Thixo\nd*;
\q2 ungayekeli amacebo abo ukuthi aphumelele, funa bazigqaje.
\b
\q1 
\v 9 Akuthi ingqondo zalabo abangihanqileyo
\q2 zandelwe luhlupho oludalwe yizindebe zabo.
\q1 
\v 10 Akuthi amalahle avuthayo abakhithikele;
\q2 sengathi bangaphoselwa emlilweni,
\q2 emigodini ebhixa udaka, bangavuki futhi.
\q1 
\v 11 Akuthi abahlebayo bangatholi indawo elizweni;
\q2 akuthi umnyama ubahlale izithende abantu bochuku.
\b
\q1 
\v 12 Ngiyazi ukuthi \nd uThixo\nd* ubenzela okulungileyo abayanga,
\q2 ubamele abaswelayo.
\q1 
\v 13 Ngempela abalungileyo bazalidumisa ibizo lakho
\q2 labaqotho bazahlala phambi kwakho.
\c 141
\cl Ihubo 141
\d Ihubo likaDavida
\q1 
\v 1 Oh \nd Thixo\nd*, ngiyakubiza; woza masinyane kimi.
\q2 Zwana ilizwi lami nxa ngikubiza.
\q1 
\v 2 Sengathi umkhuleko wami ungema phambi kwakho njengempepha;
\q2 kuthi ukuphakama kwezandla zami kube njengomhlatshelo wakusihlwa.
\b
\q1 
\v 3 Ngibekela umlindi womlomo wami, Oh \nd Thixo\nd*,
\q2 qaphela umnyango wezindebe zami.
\q1 
\v 4 Ungayekeli inhliziyo yami ihugwe ngokubi,
\q2 ngingene ezenzweni ezimbi
\q1 labantu abayizigangi;
\q2 mangingadli izibiliboco zabo.
\b
\q1 
\v 5 Ake ngitshaywe ngumuntu olungileyo, kungumusa;
\q2 kake angikhuze, kungamafutha ekhanda lami.
\q1 Ikhanda lami kaliyikukwala.
\q2 Ikanti umkhuleko wami uhlezi umelana lezenzo zezigangi.
\b
\q1 
\v 6 Ababusi bazo bazaphoselwa phansi emaweni,
\q2 lababi bazafunda ukuthi amazwi ami ayekhulunywe kuhle.
\q1 
\v 7 Bazakuthi, “Njengalowo olimayo eqeqebula umhlabathi,
\q2 kanjalo amathambo ethu achithiziwe emlonyeni weliba.”
\b
\q1 
\v 8 Kodwa amehlo ami agxile kuwe, Oh \nd Thixo\nd* woBukhosi;
\q2 kuwe ngiyaphephela unganginikeli ekufeni.
\q1 
\v 9 Ngivikela emijibileni asebeyithiyele mina,
\q2 ezifini ezithiywe yizigangi.
\q1 
\v 10 Akuthi ababi bawele emambuleni abo,
\q2 mina ngidlule kuhle ngiphephile.
\c 142
\cl Ihubo 142
\d \tl Ihubo\tl* likaDavida. Lapho esebhalwini. Umkhuleko.
\q1 
\v 1 Ngiyamemeza kakhulu \nd kuThixo\nd*;
\q2 ngiphakamisela ilizwi lami \nd kuThixo\nd* ngicela umusa.
\q1 
\v 2 Ngithululela ukusola kwami phambi kwakhe;
\q2 phambi kwakhe ngichaza ukuhlupheka kwami.
\b
\q1 
\v 3 Lapho umphefumulo wami uncipha ngaphakathi kwami,
\q2 nguwe oyaziyo indlela yami.
\q1 Endleleni engihamba ngayo
\q2 abantu bangithiyile khona.
\q1 
\v 4 Khangela kwesokunene sami ubone;
\q2 kakho lobani onginanzayo.
\q1 Angilaso isiphephelo;
\q2 kakho onakekela impilo yami.
\b
\q1 
\v 5 Ngikhala kuwe, Oh \nd Thixo\nd*;
\q2 ngithi, “Uyisiphephelo sami,
\q2 uyisabelo sami elizweni labaphilayo.”
\b
\q1 
\v 6 Lalela ukukhala kwami,
\q2 ngoba ngileziswelo ezizikileyo,
\q1 ngikhulula kulabo abaxotshana lami,
\q2 ngoba balamandla kakhulu kulami.
\q1 
\v 7 Ngikhulula entolongweni yami,
\q2 ukuze ngidumise ibizo lakho.
\q1 Lapho-ke abalungileyo bazangibuthanela
\q2 ngenxa yokulunga kwakho kimi.
\c 143
\cl Ihubo 143
\d Ihubo likaDavida
\q1 
\v 1 Oh \nd Thixo\nd*, zwana umkhuleko wami,
\q2 zwana ukukhala kwami ngicela umusa;
\q1 ngokuthembeka kwakho langokulunga kwakho
\q2 woza uzongiphumuza.
\q1 
\v 2 Ungangenisi inceku yakho ekwahlulelweni,
\q2 ngoba kakho ophilayo ongabe ulungile kuwe.
\q1 
\v 3 Isitha siyangizingela,
\q2 singincindezela phansi emhlabathini;
\q1 singenza ngihlale emnyameni
\q2 njengalabo abafa kudala.
\q1 
\v 4 Kanjalo umphefumulo wami uyaphela ngaphakathi kwami;
\q2 inhliziyo yami ngaphakathi kwami idanile.
\q1 
\v 5 Ngiyazikhumbula insuku zekadeni;
\q2 ngidla ingqondo ngayo yonke imisebenzi yakho
\q2 nginakane ngalokho okwenziwe yizandla zakho.
\q1 
\v 6 Ngiyelula izandla zami kuwe;
\q2 umphefumulo wami uyakomela njengomhlabathi owomileyo.
\b
\q1 
\v 7 Ngiphendula masinyane, awu \nd Thixo\nd*;
\q2 umoya wami uyaphela.
\q1 Ungangifihleli ubuso bakho
\q2 funa ngibe njengalabo abaya egodini.
\q1 
\v 8 Akuthi ukusa kungilethele ilizwi lothando lwakho olungaphuthiyo,
\q2 ngoba sengibeke ithemba lami kuwe.
\q1 Ngitshengisa indlela okumele ngihambe ngayo,
\q2 ngoba ngiphakamisela umphefumulo wami kuwe.
\q1 
\v 9 Ngikhulula ezitheni zami, Oh \nd Thixo\nd*,
\q2 ngoba ngizifihla kuwe.
\q1 
\v 10 Ngifundisa ukwenza intando yakho,
\q2 ngoba unguNkulunkulu wami;
\q1 sengathi uMoya wakho omuhle kakhulu
\q2 ungangikhokhela emhlabathini ochayileyo.
\b
\q1 
\v 11 Ngenxa yebizo lakho, Oh \nd Thixo\nd*, londoloza impilo yami;
\q2 ngokulunga kwakho ngikhupha ekuhluphekeni.
\q1 
\v 12 Ethandweni lwakho olungaphuthiyo, thulisa izitha zami;
\q2 bhubhisa bonke abangizondayo,
\q2 ngoba ngiyinceku yakho.
\c 144
\cl Ihubo 144
\d ElikaDavida.
\q1 
\v 1 Udumo kalube \nd kuThixo\nd* iDwala lami,
\q2 yena ofundisa izandla zami ukulwa impi,
\q2 leminwe yami ukuhlasela.
\q1 
\v 2 UnguNkulunkulu wami othandekayo lenqaba yami,
\q2 inqaba yami lomkhululi wami,
\q1 isihlangu sami engiphephela kuso,
\q2 othobisa abantu bami ngaphansi kwami.
\b
\q1 
\v 3 Kambe \nd Thixo\nd*, umuntu uyini ungaze umnanze,
\q2 indodana yomuntu ukuthi uyikhumbule na?
\q1 
\v 4 Umuntu unjengomphefumulo;
\q2 insuku zakhe zinjengesithunzi esidlulayo masinyane.
\b
\q1 
\v 5 Yahlukanisa izulu lakho, Oh \nd Thixo\nd*, wehlele phansi;
\q2 thinta izintaba, ukuze zithunqe intuthu.
\q1 
\v 6 Thumela umbane uzihlakaze izitha;
\q2 phosa imitshoko yakho zichitheke.
\q1 
\v 7 Yelula isandla sakho sisuka phezulu;
\q2 ngihlenga ungikhulule
\q2 emanzini alamandla abezizweni
\q1 
\v 8 omilomo yabo igcwele amanga,
\q2 ozandla zabo zokunene zilenkohliso.
\b
\q1 
\v 9 Ngizakuhlabelela ingoma entsha, Oh Nkulunkulu;
\q2 ngechacho lezintambo ezilitshumi ngizakutshayela ingoma,
\q1 
\v 10 kuye yedwa onika amakhosi ukunqoba,
\q2 ohlenga inceku yakhe uDavida enkembeni ebulalayo.
\b
\q1 
\v 11 Ngihlenge, ungikhulule
\q2 ezandleni zabezizwe
\q1 omilomo yabo igcwele amanga,
\q2 ozandla zabo zokunene zilenkohliso.
\b
\q1 
\v 12 Kuzakuthi amadodana ethu ebutsheni bawo
\q2 azakuba njengezihlahla ezikhuliswa kuhle,
\q1 kuthi amadodakazi ethu
\q2 abe njengezinsika ezibazelwe ukucecisa isigodlo.
\q1 
\v 13 Iziphala zethu zizagcwala
\q2 ngemihlobo yonke yokudla.
\q1 Izimvu zethu zizakwanda ngezinkulungwane,
\q2 ngamatshumi ezinkulungwane emadlelweni ethu;
\q2 
\v 14 inkabi zethu zizadonsa imithwalo enzima.
\q1 Akusayikuba khona ukubhidlizwa kwemiduli,
\q2 ukuya ebugqilini,
\q2 lokukhala kosizi emigwaqweni yakithi.
\q1 
\v 15 Babusisiwe labobantu lokhu okuzakwenzakala kubo;
\q2 babusisiwe abantu oNkulunkulu wabo ngu \nd Thixo\nd*.
\c 145
\cl Ihubo 145
\d Ihubo lokudumisa. ElikaDavida.
\q1 
\v 1 Ngizaphakamisa wena, Nkulunkulu wami oyiNkosi;
\q2 ngizalidumisa ibizo lakho kuze kube phakade.
\q1 
\v 2 Zonke insuku ngizakudumisa
\q2 ngibabaze ibizo lakho kuze kube phakade.
\b
\q1 
\v 3 Umkhulu \nd uThixo\nd* njalo ufanele kakhulu ukudunyiswa;
\q2 ubukhulu bakhe kakho ongabulinganisa.
\q1 
\v 4 Yileso laleso isizukulwane sizababaza imisebenzi yakho kwesinye;
\q2 sizatshelana ngezenzo zakho ezinkulu.
\q1 
\v 5 Sizakhuluma ngenkazimulo yakho ebenyezelayo ubukhosi bakho,
\q2 lami ngizazidla ingqondo ngemisebenzi yakho emangalisayo.
\q1 
\v 6 Zizalandisa ngamandla emisebenzi yakho emangalisayo,
\q2 lami ngizafakaza ngemisebenzi yakho emikhulu.
\q1 
\v 7 Bazakwenza umkhosi ngokulunga kwakho okukhulu
\q2 bahlabele ngentokozo ngokulunga kwakho.
\b
\q1 
\v 8 \nd UThixo\nd* ulomusa njalo ulesihawu,
\q2 uyaphuza ukuthukuthela, kodwa uyanda ngothando.
\b
\q1 
\v 9 \nd UThixo\nd* ulungile kubo bonke;
\q2 ulesihawu kukho konke akwenzayo.
\q1 
\v 10 Konke owakwenzayo kuzakudumisa, wena \nd Thixo\nd*;
\q2 abathembekileyo bakho bazakubabaza.
\q1 
\v 11 Bazalandisa ngenkazimulo yombuso wakho
\q2 bakhulume ngamandla akho,
\q1 
\v 12 kuze kuthi bonke abantu bazi ngezenzo zakho ezinkulu
\q2 lokubenyezela kwenkazimulo yombuso wakho.
\q1 
\v 13 Umbuso wakho ungumbuso ongapheliyo,
\q2 lobukhosi bakho bumi kuzozonke izizukulwane.
\b
\q1 \nd UThixo\nd* uthembekile kuzozonke izithembiso zakhe
\q2 njalo ulothando kukho konke akwenzayo.
\q1 
\v 14 \nd UThixo\nd* uyabaxhasa bonke labo abawayo
\q2 abaphakamise bonke abacubayo.
\q1 
\v 15 Amehlo abo bonke akhangela kuwe,
\q2 wena ubaphe ukudla kwabo ngesikhathi esifaneleyo.
\q1 
\v 16 Uyavula isandla sakho
\q2 usuthise izidingo zakho konke okuphilayo.
\b
\q1 
\v 17 \nd UThixo\nd* ulungile kuzozonke izindlela zakhe
\q2 njalo uthembekile kukho konke akwenzayo.
\q1 
\v 18 \nd UThixo\nd* useduze kulabo abacela kuye,
\q2 kubo bonke abacela kuye ngeqiniso.
\q1 
\v 19 Uyagcwalisa izidingo zalabo abamesabayo;
\q2 uyezwa ukukhala kwabo abasindise.
\q1 
\v 20 \nd UThixo\nd* uyabalinda bonke abamthandayo,
\q2 kodwa bonke ababi uzababhubhisa.
\b
\q1 
\v 21 Umlomo wami uzakhuluma ngokudumisa \nd uThixo\nd*.
\q2 Akuthi izidalwa zonke zidumise ibizo lakhe elingcwele
\q2 kuze kube nini lanini.
\c 146
\cl Ihubo 146
\q1 
\v 1 Dumisani \nd uThixo\nd*.
\b
\q1 Dumisa \nd uThixo\nd* mphefumulo wami.
\b
\q2 
\v 2 Ngizamdumisa \nd uThixo\nd* impilo yami yonke;
\q2 ngizahlabela indumiso kuNkulunkulu wami nxa ngisaphila.
\q1 
\v 3 Lingabeki ithemba lenu emakhosini,
\q2 ebantwini benyama, abangeke basindise.
\q1 
\v 4 Kuthi umoya wabo ungaphuma, babuyele emhlabathini;
\q2 mhlalokho nje amacebo ahle abhidlike.
\b
\q1 
\v 5 Ubusisiwe lowo osizo lwakhe lunguNkulunkulu kaJakhobe,
\q2 othemba lakhe \nd likuThixo\nd* uNkulunkulu wakhe.
\b
\q1 
\v 6 UnguMenzi wamazulu lomhlaba,
\q2 ulwandle lakho konke okulapho:
\q2 \nd uThixo\nd* owala elokhu ethembekile laphakade.
\q1 
\v 7 Uyabalwela abancindezelwayo
\q2 anike abalambileyo ukudla.
\q1 \nd UThixo\nd* ukhulula izibotshwa,
\q2 
\v 8 \nd uThixo\nd* wenza iziphofu zibone,
\q1 \nd uThixo\nd* uyabaphakamisa labo asebebhazalele,
\q2 \nd uThixo\nd* uthanda abalungileyo.
\q1 
\v 9 \nd UThixo\nd* uyabalinda abezizweni
\q2 asekele izintandane labafelokazi,
\q2 kodwa anyampise izindlela zababi.
\b
\q1 
\v 10 \nd UThixo\nd* uyabusa nini lanini,
\q2 uNkulunkulu wakho, wena Ziyoni, ezizukulwaneni zonke.
\b
\q1 Dumisani \nd uThixo\nd*.
\c 147
\cl Ihubo 147
\q1 
\v 1 Dumisani \nd uThixo\nd*.
\b
\q1 Kuhle kangakanani ukuhlabela indumiso kuNkulunkulu wethu,
\q2 kumnandi njalo kufanele ukumbonga!
\b
\q1 
\v 2 \nd UThixo\nd* uyalakha iJerusalema;
\q2 aqoqe labo abahlakazekileyo baka-Israyeli.
\q1 
\v 3 Uyabathoba abadabukileyo enhliziyweni
\q2 abophe amanxeba abo.
\q1 
\v 4 Umisile ubunengi bezinkanyezi
\q2 aziqambe leyo laleyo ngamabizo.
\q1 
\v 5 INkosi yethu inkulu, njalo makhulu amandla ayo;
\q2 ukuzwisisa kwayo kakulamkhawulo.
\q1 
\v 6 \nd UThixo\nd* uyabasekela abathobekileyo kodwa
\q2 abaphosele phansi ababi.
\b
\q1 
\v 7 Hlabelani \nd kuThixo\nd* ngokubonga;
\q2 litshaye amachacho kuNkulunkulu wethu.
\b
\q1 
\v 8 Uyembesa umkhathi ngamayezi;
\q2 awuphe umhlaba izulu
\q2 njalo akhulise utshani ezintabeni.
\q1 
\v 9 Unika inkomo utshani
\q2 aphe lamatsiyane amawabayi nxa esekhala.
\b
\q1 
\v 10 Ukuthokoza kwakhe kakukho emandleni ebhiza,
\q2 loba injabulo yakhe ekuqineni kwemilenze yomuntu;
\q1 
\v 11 \nd UThixo\nd* uthokoza ngalabo abamesabayo,
\q2 ababeka ithemba labo ethandweni lwakhe olungaphuthiyo.
\b
\q1 
\v 12 Umbabaze \nd uThixo\nd*, Oh Jerusalema;
\q2 dumisa uNkulunkulu wakho, Oh Ziyoni.
\b
\q1 
\v 13 Ngoba uyaqinisa imigoqo yamasango akho,
\q2 abusise labantu bakho ngaphakathi kwakho.
\q1 
\v 14 Wenza ukuthula emikhawulweni yelizwe lakho.
\q2 Njalo ukusuthisa ngamabele amahle kakhulu.
\b
\q1 
\v 15 Uthumela umlayo wakhe emhlabeni;
\q2 ilizwi lakhe ligijima masinyane.
\q1 
\v 16 Wendlala ungqwaqwane njengoboya bezimvu
\q2 ahaze iliqhwa njengomlotha.
\q1 
\v 17 Uphosela phansi isiqhotho sakhe njengamatshe.
\q2 Ngubani ongamelana lomfutho wakhe olomqando na?
\q1 
\v 18 Uthumela ilizwi lakhe konke kuncibilike;
\q2 aphephethise umoya wakhe amanzi ageleze.
\b
\q1 
\v 19 Ulivezile ilizwi lakhe kuJakhobe,
\q2 imithetho yakhe lezahlulelo ku-Israyeli.
\q1 
\v 20 Lokhu kazange akwenzele esinye isizwe;
\q2 kaziyazi imithetho yakhe.
\b
\q1 Dumisani \nd uThixo\nd*.
\c 148
\cl Ihubo 148
\q1 
\v 1 Dumisani \nd uThixo\nd*.
\b
\q1 Dumisani \nd uThixo\nd* emazulwini,
\q2 mdumiseni eziqongweni ngaphezulu.
\q1 
\v 2 Mdumiseni zingilosi zakhe zonke,
\q2 mdumiseni lonke mabutho asezulwini.
\q1 
\v 3 Mdumiseni, langa lenyanga,
\q2 mdumiseni lonke zinkanyezi ezikhazimulayo.
\q1 
\v 4 Mdumiseni lina ziqongo zamazulu
\q2 lani manzi ngaphezulu komkhathi.
\b
\q1 
\v 5 Konke kakudumise ibizo \nd likaThixo\nd*
\q2 ngoba yena watsho ilizwi kwadaleka.
\q1 
\v 6 Wazibeka ezindaweni zazo okwanini lanini;
\q2 wanika isahlulelo esingela kuguquka.
\b
\q1 
\v 7 Dumisani \nd uThixo\nd* emhlabeni,
\q2 lina zidalwa zasolwandle lezinziki zalo zonke,
\q1 
\v 8 umbane lesiqhotho, ungqwaqwane lamayezi,
\q2 umoya wesiphepho owenza intando yakhe,
\q1 
\v 9 lina zintaba lamaqaqa wonke,
\q2 zihlahla zezithelo lemisedari yonke,
\q1 
\v 10 zinyamazana zeganga lenkomo zonke,
\q2 zinanakazana lezinyoni eziphaphayo,
\q1 
\v 11 makhosi omhlaba lezizwe zonke,
\q2 lina makhosana lababusi bonke emhlabeni,
\q1 
\v 12 majaha lezintombi,
\q2 maxhegu labantwana.
\b
\q1 
\v 13 Kabalidumise ibizo \nd likaThixo\nd*,
\q2 ngoba ibizo lakhe lodwa liphakeme;
\q2 inkazimulo yakhe ingaphezulu komhlaba lamazulu.
\q1 
\v 14 Ubaphakamisele abantu bakhe uphondo,
\q2 indumiso yabo bonke abathembekileyo bakhe,
\q2 eka-Israyeli, abantu abasesifubeni sakhe.
\b
\q1 Dumisani \nd uThixo\nd*.
\c 149
\cl Ihubo 149
\q1 
\v 1 Dumisani \nd uThixo\nd*.
\b
\q1 Hlabelelani \nd uThixo\nd* ingoma entsha,
\q2 indumiso yakhe ebandleni labathembekileyo.
\b
\q1 
\v 2 Akuthi u-Israyeli athokoze ngoMenzi wakhe;
\q2 akuthi abantu baseZiyoni bajabule ngeNkosi yabo.
\q1 
\v 3 Kabadumise ibizo lakhe ngokusina,
\q2 batshaye amagedla lamachacho.
\q1 
\v 4 Ngoba \nd uThixo\nd* uyathokoza ngabantu bakhe;
\q2 abathobekileyo ubapha umqhele wensindiso.
\q1 
\v 5 Akuthi abathembekileyo bathokoze ngale inhlonipho,
\q2 bahlabele ngentokozo besemibhedeni yabo.
\b
\q1 
\v 6 Sengathi indumiso kaNkulunkulu ingaba semilonyeni yabo
\q2 lenkemba esika nxazonke ibe sezandleni zabo,
\q1 
\v 7 ukuthi benze impindiselo phezu kwezizwe
\q2 lesijeziso phezu kwabantu,
\q1 
\v 8 babophe amakhosi azo ngentambo
\q2 lezikhulu zabo ngezibopho zensimbi,
\q1 
\v 9 ukugcwalisa kubo isigwebo abasibhalelwayo.
\q2 Lokhu kuyinkazimulo yabathembekileyo bakhe bonke.
\b
\q1 Dumisani \nd uThixo\nd*.
\c 150
\cl Ihubo 150
\q1 
\v 1 Dumisani \nd uThixo\nd*.
\b
\q2 Dumisani uNkulunkulu endlini yakhe engcwele;
\q1 mdumiseni emazulwini Akhe amakhulu.
\q1 
\v 2 Mdumiseni ngenxa yezenzo zakhe zamandla;
\q2 mdumiseni ngenxa yobukhulu bakhe obudlula konke.
\q1 
\v 3 Mdumiseni ngokutshaya icilongo,
\q2 mdumiseni ngechacho langomhubhe,
\q1 
\v 4 mdumiseni ngegedla langokusina,
\q2 mdumiseni ngeziginci langomqangala,
\q1 
\v 5 mdumiseni ngamazenge akhencezayo;
\q2 mdumiseni ngomsindo wamazenge ancencethayo!
\b
\q1 
\v 6 Akuthi konke okuphefumulayo kumdumise \nd uThixo\nd*.
\b
\q1 Dumisani \nd uThixo\nd*.
