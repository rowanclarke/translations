\id JOL - Biblica® Open Igbo Contemporary Bible 2020
\h Juel
\toc1 Juel
\toc2 Juel
\toc3 Jul
\mt1 Juel
\c 1
\p 
\v 1 Okwu \nd Onyenwe anyị\nd* nke bịakwutere Juel nwa Petuel.
\b
\s1 Mbibi nke igurube ga-eweta
\q1 
\v 2 Nụrụnụ nke a, unu ndị okenye;
\q2 geenụ ntị, unu ndị niile bi nʼala a.
\q1 Ihe dị otu a o meela na ndụ unu,
\q2 ka o mere na ndụ nna nna unu ha?
\q1 
\v 3 Gwanụ ya ụmụ unu,
\q2 ka ụmụ unu gwakwa ụmụ ha, ka ụmụ ha gwakwa ụmụ ụmụ ha,
\q2 ka ụmụ ụmụ ha gwakwa ọgbọ nke na-eso ha.
\q1 
\v 4 Ihe igurube rifọrọ
\q2 ka igurube ukwu richara,
\q1 ihe igurube ukwu rifọrọ,
\q2 ka ụmụ igurube richara,
\q1 ihe ụmụ igurube rifọrọ
\q2 ka igurube ndị ọzọ richapụrụ.
\b
\q1 
\v 5 Tetanụ, unu ndị na-aṅụbiga mmanya oke. Kwaanụ akwa.
\q2 Kwaanụ akwa unu ndị na-aṅụ mmanya;
\q1 kwaanụ akwa nʼihi mmanya ọhụrụ,
\q2 nʼihi na e sitela nʼọnụ unu napụ unu mmanya unu na-aṅụ.
\q1 
\v 6 O nwere mba bịakwasịrị ala m,
\q2 usuu ndị agha nke na-enweghị ịgụta ọnụ;
\q1 nke nwere eze dịka ọdụm,
\q2 nweekwa ikiri eze dịka ka nne ọdụm.
\q1 
\v 7 Ọ laala mkpụrụ vaịnị m nʼiyi
\q2 mee ka osisi fiig m niile mebie kpamkpam.
\q1 O kpechapụsịala agbụgbọ osisi fiig m,
\q2 kpofuo ha,
\q2 hapụ alaka osisi ya ka ọ na-acha ọcha.
\b
\q1 
\v 8 Kwaa akwa mwute dịka nwaagbọghọ na-amaghị nwoke,
\q2 nke di na-aga ịlụ ya nwụrụ.
\q1 
\v 9 Akwụsịla iwebata onyinye ọka na onyinye mmanya
\q2 nʼụlọ \nd Onyenwe anyị\nd*.
\q1 Ndị nchụaja na-eru ụjụ,
\q2 bụ ndị ahụ na-eje ozi nʼihu \nd Onyenwe anyị\nd*.
\q1 
\v 10 Emebiela ala ubi niile,
\q2 ala nọ na-eru ụjụ.
\q1 Ebibiela ọka niile,
\q2 mmanya adịghịkwa,
\q2 otu a kwa, mmanụ oliv adịghịkwa.
\b
\q1 
\v 11 Daanụ mba nʼobi unu, unu ndị ọrụ ubi,
\q2 tienụ mkpu akwa, unu ndị ọrụ ubi vaịnị.
\q1 Tienụ aka nʼobi nʼihi ọka wiiti na ọka balị,
\q2 nʼihi na a laala owuwe ihe ubi nʼiyi.
\q1 
\v 12 Osisi vaịnị anwụọla.
\q2 Osisi fiig akpọnwụọla.
\q1 Osisi pomegranet na osisi nkwụ, na osisi apụl akpọnwụọla.
\q2 Nʼezie, osisi niile akpọnwụọla.
\q1 Nʼebe ndị mmadụ nọ,
\q2 ọṅụ alala.
\s1 Ọkpụkpọ oku maka nchegharị
\q1 
\v 13 Yikwasịnụ onwe unu akwa mkpe, unu ndị nchụaja; ruonụ ụjụ,
\q2 kwaanụ akwa, unu ndị na-eje ozi nʼebe ịchụ aja.
\q1 Bịanụ, yiri akwa mkpe nọ ọnọdụ abalị
\q2 unu ndị na-ejere Chineke m ozi
\q1 nʼihi na egbochiela onyinye ọka na onyinye ihe ọṅụṅụ
\q2 ịbata nʼụlọ Chineke unu.
\q1 
\v 14 Kpọsaanụ obubu ọnụ dị nsọ.
\q2 Kpọọnụ nzukọta dị nsọ.
\q1 Chịkọtaanụ ndị okenye
\q2 na ndị niile bi nʼala a,
\q1 ka ha bịa nʼụlọnsọ \nd Onyenwe anyị\nd* Chineke unu;
\q2 ka ha tikuo \nd Onyenwe anyị\nd* mkpu akwa.
\b
\q1 
\v 15 Ụbọchị dị oke egwu ka ụbọchị ahụ bụ!
\q2 Nʼihi na ụbọchị \nd Onyenwe anyị\nd* abịala nso.
\q2 Ọ ga-ewetakwa mbibi site nʼaka Onye pụrụ ime ihe niile.
\b
\q1 
\v 16 Ọ bụ na e sitebeghị nʼihu anyị
\q2 wezuga ihe oriri niile,
\q1 Ọ bụ na ọṅụ na obi ụtọ e sitebeghị
\q2 nʼụlọnsọ Chineke anyị pụọ?
\q1 
\v 17 Mkpụrụ ubi
\q2 akpọnwụọla nʼọkpụrụkpụ aja ala.
\q1 Ụlọ a na-edebe ihe oriri atọgbọrọla nʼefu,
\q2 a kwatuola ọba niile,
\q2 nʼihi na mkpụrụ ọka niile akpọọla nku.
\q1 
\v 18 Lee otu anụ ụlọ niile si eze ume!
\q2 Igwe ehi na-awagharị
\q1 nʼihi na ha enweghị ebe ịta nri;
\q2 ọ bụladị igwe atụrụ nọkwa nʼọnọdụ ịta ahụhụ.
\b
\q1 
\v 19 Gị \nd Onyenwe anyị\nd*, ka m na-akpọku,
\q2 nʼihi na ọkụ erepịala ebe ịta nri nke ụmụ anụ ụlọ.
\q2 Ọkụ erechapụkwala osisi niile dị nʼọhịa.
\q1 
\v 20 Ọ bụladị ụmụ anụ ọhịa na-ebeku gị akwa,
\q2 nʼihi na iyi niile ataala,
\q2 ọkụ erechapụkwala ebe ịta nri nke anụmanụ niile nke dị nʼọzara.
\c 2
\s1 Igwe igurube
\q1 
\v 1 Fụọ opi ịdọ aka na ntị na Zayọn.
\q2 Ka a nụ ụda opi ịdọ aka na ntị site nʼelu ugwu nsọ m.
\b
\q1 Ka ndị niile bi nʼala ahụ maa jijiji,
\q2 nʼihi na ụbọchị ikpe nke \nd Onyenwe anyị\nd* na-abịa,
\q1 ọ na-abịaru nso.
\q2 
\v 2 Ọ bụ ụbọchị ọchịchịrị na nke mgbarụ ihu.
\q2 Ọ bụ ụbọchị itiri ojii nke oke ọchịchịrị.
\q1 Usuu ndị agha dị ike nke ga-ekpuchi elu ugwu niile dịka chi ọbụbọ.
\q2 Ha hiri nne, nweekwa ike dị ukwuu.
\q1 Ahụbeghị ụdị dịka ha na mbụ,
\q2 a gaghị ahụkwa ụdị ha ọzọ ruo ọgbọ niile nke na-abịa.
\b
\q1 
\v 3 Ọkụ na-ere na-aga ha nʼihu,
\q2 ire ọkụ na-enwu oke onwunwu dị ha nʼazụ.
\q1 Tupu ha abịaruo, ala ahụ na-ama mma dịka ogige nke Iden,
\q2 ma nʼazụ ha, ala ubi niile dịka ọzara nke tọgbọrọ nʼefu,
\q2 o nweghị ihe ga-agbanarị ịla nʼiyi ha.
\q1 
\v 4 Nʼile anya, ha dịka ịnyịnya,
\q2 ha na-ekwogharị dịka ịnyịnya agha.
\q1 
\v 5 Ha ji ụzụ dịka ụzụ ụgbọala
\q2 na-arịgo elu ugwu.
\q1 Ụzụ ha dịkwa ka ụzụ ọkụ nke na-erepịa ahịhịa kpọrọ nkụ.
\q2 Ha dịkwa ka ụzụ nke usuu ndị agha dị ike, ndị na-aga ịlụ agha.
\b
\q1 
\v 6 Egwu na-ejide ndị niile ha chere ihu.
\q2 Ihu ha na-agbarụkwa.
\q1 
\v 7 Ha na-ekwogharị dịka ndị agha;
\q2 ha na-arịgo mgbidi dịka ezi ndị agha.
\q1 Ha na-aga nʼahịrị nʼahịrị,
\q2 na-ahapụghị onye ọbụla nʼije ha.
\q1 
\v 8 Ọ dịghị onye na-anọchiri ibe ya ụzọ.
\q2 Onye ọbụla na-aga nʼihu nʼahịrị nʼahịrị.
\q1 Ọ dịghị ngwa agha ọbụla pụrụ ịkwụsị ha,
\q2 ka ha na-aga nʼahịrị nʼahịrị.
\q1 
\v 9 Ha na-enukwasị obodo,
\q2 na-agbagharị nʼelu mgbidi,
\q1 na-arịgo, na-abakwa nʼime ụlọ;
\q2 na-abanye dịka ndị ohi site na oghereikuku niile.
\b
\q1 
\v 10 Ala na-ama jijiji nʼihu ha,
\q2 eluigwe na-emekwa mkpọtụ.
\q1 Ihu anyanwụ na ihu ọnwa na-agbakwa ọchịchịrị,
\q2 kpakpando adịghịkwa enye ìhè.
\q1 
\v 11 Olu \nd Onyenwe anyị\nd* dara
\q2 nʼihu ndị agha,
\q1 ndị agha ya dị agụtaghị ọnụ,
\q2 ha dịkwa ọtụtụ bụ ndị na-edebe iwu ya.
\q1 Ụbọchị ikpe nke \nd Onyenwe anyị\nd* dị ukwu
\q2 bụrụkwa ihe dị egwu.
\q2 Onye pụrụ ịnagide ya?
\s1 Lọghachikwute m
\q1 
\v 12 “Ọ bụladị ugbu a,” otu a ka \nd Onyenwe anyị\nd* kwubiri ya,
\q2 “Jirinụ obi unu niile lọghachikwute m.
\q2 Werekwanụ obubu ọnụ, na ịkwa akwa, na iru ụjụ, lọghachikwutenụ m.”
\b
\q1 
\v 13 Dọwakwaanụ obi unu,
\q2 ọ bụghị uwe unu.
\q1 Lọghachikwutenụ \nd Onyenwe anyị\nd* bụ Chineke unu,
\q2 nʼihi na ọ bụ onye na-eme amara, na onye obi ebere.
\q1 Ọ bụ onye na-adịghị ewe iwe ọsịịsọ. O jupụtara nʼịhụnanya.
\q2 Ọ naghị eme ọsịịsọ nʼinye ntaramahụhụ.
\q1 
\v 14 Onye maara? Ma eleghị anya ọ ga-alọghachite azụ tụgharịa obi ya,
\q2 hapụrụ anyị ngọzị ya,
\q1 kwe ka eweta onyinye mkpụrụ ubi na onyinye ihe ọṅụṅụ
\q2 maka \nd Onyenwe anyị\nd* bụ, Chineke unu.
\b
\q1 
\v 15 Fụọ opi ike nʼime Zayọn.
\q2 Kpọsaa obubu ọnụ dị nsọ.
\q2 Kpọkọta nzukọ dị nsọ.
\q1 
\v 16 Chịkọtaa onye ọbụla,
\q2 doo nzukọ ahụ nsọ,
\q1 ma ndị okenye,
\q2 ma ụmụntakịrị,
\q2 ma ụmụ na-aṅụ ara.
\q1 Kpọpụta nwoke lụrụ nwunye ọhụrụ site nʼụlọ ya,
\q2 ya na nwaagbọghọ lụrụ dị ọhụrụ site nʼebe nzuzo ya.
\q1 
\v 17 Ka ndị nchụaja, bụ ndị na-ejere \nd Onyenwe anyị\nd* ozi,
\q2 nọọ nʼetiti ebe ịchụ aja, na mpụta ọnụ ụlọ kwaa akwa.
\q1 Ha kpeekwa ekpere sị, “Zọpụta ndị gị, \nd Onyenwe anyị\nd*.
\q2 Ekwela ka ihe nketa gị bụrụ ihe ịta ụta,
\q2 nʼetiti mba dị iche iche.
\q1 Ekwela ka ha sị,
\q2 ‘Olee ebe Chineke ha nọ?’ ”
\s1 Ọsịsa \nd Onyenwe anyị\nd*
\q1 
\v 18 Mgbe ahụ, \nd Onyenwe anyị\nd* kworo ekworo nʼihi ala ya,
\q2 nwee ọmịiko nʼebe ndị ya nọ.
\p 
\v 19 \nd Onyenwe anyị\nd* zaghachiri ha sị,
\q1 “Ana m ezitere unu ọka na mmanya ọhụrụ, na mmanụ,
\q2 nke ga-ezuru unu, jukwa unu afọ.
\q1 Agaghị m emekwa
\q2 ka unu bụrụ ihe ịkwa emo nʼetiti ndị mba ọzọ.
\b
\q1 
\v 20 “Aga m ewezuga ndị agha ahụ si nʼugwu, zipụ ha nʼebe tere anya,
\q2 m ga-achụba ha nʼala kpọrọ nkụ, na ebe tọgbọrọ nʼefu.
\q1 Ndị nọ nʼihu ga-erugbu nʼosimiri Nnu dị nʼọwụwa anyanwụ;
\q2 ndị nọ nʼazụ ka m ga-erugbu nʼosimiri Mediterenịa dị nʼọdịda anyanwụ.
\q1 Isisi ọjọọ ya ga-esipụta,
\q2 isisi nke ure ya ga-arịgokwa.”
\b
\q1 Nʼezie, ọ meela ihe ndị dị ukwuu dị iche iche.
\q2 
\v 21 Atụkwala egwu, gị ala Juda,
\q2 kama ṅụrịa ọṅụ, nweekwa obi ụtọ,
\q1 nʼezie, \nd Onyenwe anyị\nd* arụọla ọrụ dị ịtụnanya.
\q2 
\v 22 Atụla egwu, unu anụ ọhịa niile,
\q2 nʼihi na ebe ịta nri unu ga-ejupụtakwa nʼahịhịa ndụ.
\q1 Osisi na-amị mkpụrụ ha,
\q2 osisi fiig, na osisi vaịnị na-amịkwa mkpụrụ nʼuju.
\q1 
\v 23 Ụmụ Zayọn, ka obi tọọ unu ụtọ,
\q2 ṅụrịanụ ọṅụ nʼime ịdị mma \nd Onyenwe anyị\nd*, bụ Chineke unu.
\q1 Nʼihi na o nyela unu mmiri ozuzo mbụ nke ọkọchị,
\q2 nʼihi ịdị mma ya.
\q1 Ọ na-ezite ọtụtụ mmiri ozuzo,
\q2 nke ọkọchị, na nke udu mmiri, dịka ọ dị na mbụ.
\q1 
\v 24 Ebe ịzọcha ọka gị niile ga-ejupụtakwa na mkpụrụ ọka,
\q2 ebe ịnara mmanya gị niile ga-ejubiga oke na mmanya na mmanụ ọhụrụ.
\b
\q1 
\v 25 “Aga m enyeghachi afọ niile nke igurube riri,
\q2 ndị ahụ nke igurube ukwu na igurube nta,
\q2 na ụkpana, na ndị mbibi ọzọ riri,
\q1 bụ usuu ndị agha ahụ m zitere nʼetiti unu.
\q1 
\v 26 Unu ga-eri ka unu siri chọọ, rijuchaa afọ,
\q2 unu ga-etokwa \nd Onyenwe anyị\nd* bụ Chineke unu,
\q2 onye rụrụ ọrụ ebube ndị a nʼihi unu.
\q1 Ọ dịkwaghị mgbe ọzọ ihere ga-eme ndị m.
\q1 
\v 27 Mgbe ahụ unu ga-amata na m nọ nʼebe a nʼetiti ndị m Izrel.
\q2 Unu ga-amatakwa na naanị m bụ \nd Onyenwe anyị\nd* bụ Chineke unu,
\q2 na ọ dịkwaghị onye ọzọ.
\q1 Ihere agaghị emekwa ndị m ọzọ.
\s1 Ụbọchị \nd Onyenwe anyị\nd*
\q1 
\v 28 “Ma emesịa,
\q2 aga m awụkwasị mmadụ niile Mmụọ m.
\q1 Ụmụ unu ndị ikom, na ụmụ unu ndị inyom ga-ebu amụma.
\q2 Ndị okenye nwoke unu ga-arọ nrọ.
\q2 Ụmụ okorobịa unu ga-ahụkwa ọhụ.
\q1 
\v 29 Nʼụbọchị ahụ, aga m awụsa mmụọ m
\q2 ọbụladị nʼahụ ndị ohu m ndị nwoke na ndị nwanyị.
\q1 
\v 30 Aga m egosi ihe ebube dị iche iche na mbara eluigwe,
\q2 na nʼelu ụwa;
\q2 a ga-ahụ ọbara, na ire ọkụ, na ogidi anwụrụ ọkụ.
\q1 
\v 31 Anyanwụ ga-agbanwe ghọọ ọchịchịrị,
\q2 ọnwa ga-aghọkwa ọbara,
\q2 tupu ụbọchị \nd Onyenwe anyị\nd* abịa, bụ ụbọchị ahụ dị ukwu dịkwa oke egwu.
\q1 
\v 32 Ọ ga-erukwa na onye ọbụla nke na-akpọku aha \nd Onyenwe anyị\nd*
\q2 ka a ga-azọpụta.
\q1 Nʼihi na ọ bụ nʼelu ugwu Zayọn, na nʼime Jerusalem
\q2 ka mgbapụta ga-adị,
\q2 dịka \nd Onyenwe anyị\nd* kwuru ya.
\q1 Mgbapụta a ga-adịkwara ndị fọdụrụ ndụ,
\q2 bụ ndị ahụ \nd Onyenwe anyị\nd* na-akpọ.
\c 3
\s1 Ikpe nke mba niile
\q1 
\v 1 “Nʼihi na, lee, nʼụbọchị ahụ, nʼoge ahụ,
\q2 mgbe m ga-eweghachi akụnụba nke Juda na Jerusalem,
\q1 
\v 2 na m ga-achịkọta mba niile nke ụwa,
\q2 mee ka ha zukọọ na Ndagwurugwu Jehoshafat.\f + \fr 3:2 \ft Ihe aha a pụtara bụ, \nd onyenwe anyị\nd* na-ekpe ikpe\f*
\q1 Nʼebe ahụ, ka mụ onwe m ga-ama ha ikpe,
\q2 nʼihi ihe ha mere ihe nketa m, na ndị nke m Izrel.
\q1 Nʼihi na ha chụsasịrị ndị m nʼetiti mba niile,
\q2 kee ala m nʼetiti onwe ha.
\q1 
\v 3 Ha fere nza nʼihi ndị m,
\q2 were ụmụ m ndị nwoke gbanwere ụmụ akwụna.
\q2 Ha rere ụmụ m ndị nwanyị nʼihi mmanya, nʼihi inweta mmanya ha ga-aṅụ.
\p 
\v 4 “Ọ bụ gịnị ka unu nwere megide m, unu Taịa na Saịdọn, na unu obodo ahụ niile dị gburugburu ala ndị Filistia? O nwere ihe m mere nke unu na-akwụghachi m ụgwọ ya? Ọ bụrụ nʼezie na unu na-akwụghachi m ụgwọ, mụ onwe m ga-eji ọsọ kwụghachi unu ihe ọjọọ niile unu mere.
\v 5 Nʼihi na unu weere ọlaọcha m na ọlaedo m, burukwa ihe dị oke ọnụahịa niile m nwere, bulaa ha nʼụlọnsọ chi\f + \fr 3:5 \ft Maọbụ, \fqa ụlọ ukwu unu\f* unu.
\v 6 Unu refuru ndị Juda na ndị Jerusalem, resi ha ndị Griik, si otu a wega ha nʼebe dị anya site nʼala ha.
\p 
\v 7 “Lee, aga m esi nʼebe ahụ unu refuru ha kpọlite ha. Aga m emekwa ka ihe ndị ahụ niile unu mere bịaghachi unu nʼisi.
\v 8 Aga m ewere ụmụ unu ndị nwoke na ndị nwanyị resi ha ndị Juda, ndị ga-eresi ha ndị Sheba, bụ mba tere anya.” \nd Onyenwe anyị\nd* ekwuola ya.
\q1 
\v 9 Kwupụtanụ nke a nʼetiti mba niile:
\q2 Jikerenụ agha!
\q1 Kpọteenụ ndị dike nʼagha.
\q2 Ka ndị agha niile a zụziri azụzi bịaruo nso ibu agha.
\q1 
\v 10 Kpụgharịanụ mma oge unu ka ha bụrụkwa mma agha,
\q2 kpụgharịakwanụ mma ịkwa osisi unu ka ha ghọọ ùbe.
\q1 Ka onye na-adịghị ike kwuo sị,
\q2 “Adị m ike!”
\q1 
\v 11 Chịkọta onwe unu ọsịịsọ, bịa, unu mba niile, nọ nʼebe niile.
\q2 Zukọtaanụ nʼebe ahụ.
\b
\q1 Kpọdata ndị agha gị dị ike \nd Onyenwe anyị\nd*!
\b
\q1 
\v 12 “Ka akpọlitekwa mba niile,
\q2 mee ka ha niile bịaruo na Ndagwurugwu Jehoshafat,
\q1 nʼihi na ọ bụ nʼebe ahụ
\q2 ka m ga-anọ kpee mba nọ nʼakụkụ niile ikpe.
\q1 
\v 13 Tinye mma iwe ihe ubi,
\q2 nʼihi na mkpụrụ ubi achaala.
\q1 Bịa zọchaa mkpụrụ vaịnị,
\q2 nʼihi nʼebe ịzọcha mmanya ejula,
\q2 ebe ịnara mmanya gị niile ejubigakwala oke,
\q1 nʼihi na ajọ omume ha dị ukwuu.”
\b
\q1 
\v 14 Ọtụtụ igwe mmadụ, ọtụtụ igwe mmadụ!
\q2 Ha jupụtara na ndagwurugwu mkpebi ikpe ahụ!
\q1 Nʼihi na ụbọchị \nd Onyenwe anyị\nd* dị nso,
\q2 na ndagwurugwu mkpebi nhọrọ ahụ.
\q1 
\v 15 Anyanwụ na ọnwa ga-agbaji oji,
\q2 kpakpando agakwaghị enye ìhè.
\q1 
\v 16 \nd Onyenwe anyị\nd* ga-ebigbọ na Zayọn,
\q2 olu ya ga-ada nʼime Jerusalem.
\q2 Elu ụwa na mbara eluigwe ga-amakwa jijiji.
\q1 \nd Onyenwe anyị\nd* ga-abụrụ ndị ya ebe mgbaba.
\q2 Ọ ga-abụrụ ndị Izrel ebe e wusiri ike.
\s1 Ngọzị dịrị ndị nke Chineke
\q1 
\v 17 “Mgbe ahụ, unu ga-amata na mụ onwe m bụ \nd Onyenwe anyị\nd* Chineke unu
\q2 bi na Zayọn, nʼugwu m dị nsọ.
\q1 Jerusalem ga-abụ ebe dị nsọ.
\q2 Ndị mba ọzọ agakwaghị esite nʼime ya gabiga ọzọ.
\b
\q1 
\v 18 “Nʼụbọchị ahụ, mmanya ọhụrụ ga-esi nʼugwu ukwu niile na-atapụtasị,
\q2 mmiri ara ehi ga na-erupụtakwa site nʼugwu nta niile;
\q2 mmiri ga na-asọkwa na ndagwurugwu niile nke Juda ebe mmiri si eru.
\q1 Isi iyi ga-esitekwa nʼụlọnsọ ukwu \nd Onyenwe anyị\nd* sọpụta
\q2 dee Ndagwurugwu Shitim.
\q1 
\v 19 Ma Ijipt ga-atọgbọrọ nʼefu,
\q2 Edọm ga-aghọkwa mkpọmkpọ ebe,
\q1 nʼihi ihe ike ha mere ndị Juda,
\q2 bụ ndị ha kwafuru ọbara ndị aka ha dị ọcha nʼala ha.
\q1 
\v 20 Ma Juda ga-abụ ebe mmadụ ga-ebi ruo mgbe ebighị ebi.
\q2 A ga-ebikwa na Jerusalem nʼọgbọ niile.
\q1 
\v 21 Aga m ahapụ ịbọ ọbọ ọbara ha?
\q2 Mba, agaghị m agụnye onye ikpe maara dịka onye ikpe na-amaghị.
\b
\qc Nʼihi na \nd Onyenwe anyị\nd* bi na Zayọn.”
