\id PHM - Quechua, North Bolivia NT -Bolivia 2012 (DBL -2013) 
\h FILEMÓN 
\toc1 Filemón - Apóstol Pablopaj Escribiskan Carta 
\toc2 Filemón 
\toc3 Flm 
\mt1 FILEMÓN 
\mt2 Apóstol Pablopaj Escribiskan Carta 
\c 1  
\s1 Saludo 
\p  
\v 1 Noka, Pablo, preso cani Cristo Jesusraycu. Hermano Timoteopiwan cay cartata escribimuyqui kanman, Filemón, munaska llanc'ajmasiycu,  
\v 2 wasiyquipi culto ruwaj hermanocunaman, hermananchis Apiaman, Señorpaj obranpi ñac'arejmasinchis Arquipomanpas.  
\v 3 Dios Tatanchis Señor Jesucristopiwan kancunata bendicichun favorninwan sonko tiyaycuyninwan. 
\s1 Filemonpaj munacuynin creeyninpiwan 
\p  
\v 4 Oracionniycunapi kanmanta yuyaricuspa, Diosman graciasta konipuni,  
\v 5 imaraycuchus willawancu Diospi tucuy creyentecunata munacuskayquimanta, Señor Jesuspi creeyniyquimantawan.  
\v 6 Kan creejmasiypaj Diosmanta mañacuni, Cristo Jesuspi tucuy bendicioncuna capuwaskanchismanta allinta entendinayquipaj.  
\v 7 Munacuyniyquiraycu animaska sinchi cusiska cachcani; kanraycu, hermano, creyentecunapas cusichiska cancu. 
\s1 Pablo Onesimopaj favorta mañan 
\p  
\v 8 Cristopaj apostolnin caskayraycu, derechoyoj cani ima ruwanayquita mandanaypaj.  
\v 9 Chaywanpas rogayta munayqui munacuyniyoj caskayquiraycu. Noka, Pablo, ña machuña cani, Cristo Jesusraycu cunanka preso cani.  
\v 10 Uj favorta mañacuyqui Onesimopaj; payka cay carcelpi Diosman cutiricuspa waway jina cachcan. 
\p  
\v 11 Ñaupajka Onésimo mana sirvej carkan kanpajka, cunantaj sirvej capun kanpaj nokapajpas.  
\v 12 Ujtawan cachampuyqui; payta jap'ekay noka quiquiyta jina.  
\v 13 Nokaka munayman nokawan caypi cananta, cuentayquimanta sirvinawanpaj, evangelioraycu preso cachcajtiy.  
\v 14 Mana permisoyquiwan mana imatapas ruwayta munanichu, favor ruwawaskayqui mana mat'iska cananpaj, manachayri kanpaj munayniyquimanta.  
\v 15 Ichapas Onesimoka kanmanta ithiricorkan uj tiempota, cunan astaquipaj kanwan capunanpaj,  
\v 16 manaña esclavo jinachu, astawan allinpajraj esclavomanta nejtenka, uj munaska hermano jina. Nokaka payta sinchita munacuni; kanka astawanraj munacunayqui, mana mayken runata jinallachu, manachayri Señorpi hermanota jina. 
\p  
\v 17 Ajina ari, sichus creyentemasiyquita jina jap'ekawanqui chayka, payta jap'ekay noka quiquiyta jina.  
\v 18 Sichus mana allincunata ruwarkasunqui chayka, chayri manuyqui cajtinpas, nokata cobraway.  
\v 19 Noka, Pablo, quiquin maquiywan cayta escribimuni. Noka pagapuskayqui, ¡yuyachiyta atiyman noka willajtiy creeskayquimanta manuy jina caskayquita chaywanpas!  
\v 20 Arí, hermanóy, cay favorta ruwaway Señorpi creyente jina. Cusichiway Cristopi hermano jina. 
\p  
\v 21 Escribimuyqui, seguro caspa casucunayquimanta. Yachani ruwanayquita astawanraj mañaskaymanta nejtinpas.  
\v 22 Wasiyquipi alojacunaypaj waquichipuway. Oracionniyquichista Dios uyariskanraycu, jamuyta suyachcani kancunawan tupanaypaj Diospaj favorninman jina. 
\s1 Saludocuna 
\p  
\v 23 Cristoraycu presomasiy Epafras saludamusunqui.  
\v 24 Llanc'ajmasiycuna, Marcos, Aristarco, Demas, Lucaspiwan saludamusunquichis.  
\v 25 Señor Jesucristo favorninwan kancunata bendicichun. Ajina cachun.