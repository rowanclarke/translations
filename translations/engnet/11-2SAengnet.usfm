\v 7  \w Hushai|strong="H2365"\w* replied \w to|strong="H2896"\w* Absalom, “Ahithophel’s \w advice|strong="H6098"\w* \w is|strong="H2896"\w* \w not|strong="H3808"\w* \w sound|strong="H2896"\w* \w this|strong="H2063"\w* \w time|strong="H6471"\w*.”  
\v 8  \w Hushai|strong="H2365"\w* \w went|strong="H5971"\w* \w on|strong="H5971"\w* \w to|strong="H5971"\w* say, “\w You|strong="H3588"\w* \w know|strong="H3045"\w* \w your|strong="H3045"\w* father \w and|strong="H5971"\w* \w his|strong="H3045"\w* \w men|strong="H1368"\w* – \w they|strong="H1992"\w* \w are|strong="H1992"\w* \w soldiers|strong="H4421"\w* \w and|strong="H5971"\w* \w are|strong="H1992"\w* \w as|strong="H5315"\w* dangerous \w as|strong="H5315"\w* \w a|strong="H3068"\w* \w bear|strong="H1677"\w* \w out|strong="H3045"\w* \w in|strong="H5315"\w* \w the|strong="H3588"\w* \w wild|strong="H7704"\w* \w that|strong="H3588"\w* \w has|strong="H3588"\w* \w been|strong="H5971"\w* \w robbed|strong="H7909"\w* \w of|strong="H7704"\w* \w her|strong="H3045"\w* \w cubs|strong="H7909"\w*. \w Your|strong="H3045"\w* father \w is|strong="H5315"\w* \w an|strong="H3588"\w* \w experienced|strong="H3045"\w* \w soldier|strong="H4421"\w*; \w he|strong="H3588"\w* \w will|strong="H5971"\w* \w not|strong="H3808"\w* \w stay|strong="H3885"\w* \w overnight|strong="H3885"\w* \w with|strong="H3045"\w* \w the|strong="H3588"\w* \w army|strong="H5971"\w*.  
\v 9  \w At|strong="H1961"\w* \w this|strong="H1931"\w* \w very|strong="H6258"\w* moment \w he|strong="H1931"\w* \w is|strong="H1931"\w* \w hiding|strong="H2244"\w* \w out|strong="H5307"\w* \w in|strong="H8085"\w* \w one|strong="H1931"\w* \w of|strong="H5971"\w* \w the|strong="H8085"\w* \w caves|strong="H6354"\w* \w or|strong="H8085"\w* \w in|strong="H8085"\w* \w some|strong="H5971"\w* other \w similar|strong="H5307"\w* \w place|strong="H4725"\w*. \w If|strong="H2009"\w* \w it|strong="H1931"\w* \w should|strong="H4725"\w* \w turn|strong="H1961"\w* \w out|strong="H5307"\w* \w that|strong="H5971"\w* \w he|strong="H1931"\w* attacks \w our|strong="H8085"\w* \w troops|strong="H5971"\w* \w first|strong="H8462"\w*, whoever \w hears|strong="H8085"\w* \w about|strong="H1961"\w* \w it|strong="H1931"\w* \w will|strong="H1961"\w* say, ‘Absalom’s \w army|strong="H5971"\w* \w has|strong="H1961"\w* \w been|strong="H1961"\w* \w slaughtered|strong="H4046"\w*!’  
\v 10  \w If|strong="H3588"\w* \w that|strong="H3588"\w* happens \w even|strong="H1571"\w* \w the|strong="H3605"\w* bravest soldier – \w one|strong="H3605"\w* \w who|strong="H3605"\w* \w is|strong="H1931"\w* lion-hearted – \w will|strong="H3478"\w* virtually \w melt|strong="H4549"\w* \w away|strong="H4549"\w*. \w For|strong="H3588"\w* \w all|strong="H3605"\w* \w Israel|strong="H3478"\w* \w knows|strong="H3045"\w* \w that|strong="H3588"\w* \w your|strong="H3605"\w* \w father|strong="H1121"\w* \w is|strong="H1931"\w* \w a|strong="H3068"\w* \w warrior|strong="H1368"\w* \w and|strong="H1121"\w* \w that|strong="H3588"\w* \w those|strong="H3605"\w* \w who|strong="H3605"\w* \w are|strong="H1121"\w* \w with|strong="H3045"\w* \w him|strong="H3605"\w* \w are|strong="H1121"\w* \w brave|strong="H2428"\w*.  
