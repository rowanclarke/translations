\mt1 Hosea  
\c 1  
\p
\v 1 \w The|strong="H3068"\w* \w Lord|strong="H3068"\w* \w sent|strong="H3068"\w* \w a|strong="H3068"\w* \w message|strong="H1697"\w* \w to|strong="H3478"\w* \w Hosea|strong="H1954"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Beeri \w at|strong="H3478"\w* \w the|strong="H3068"\w* \w time|strong="H3117"\w* \w when|strong="H1961"\w* \w Uzziah|strong="H5818"\w*, \w Jotham|strong="H3147"\w*, \w and|strong="H1121"\w* Ahaz \w were|strong="H3478"\w* \w the|strong="H3068"\w* \w kings|strong="H4428"\w* \w of|strong="H1121"\w* \w Judah|strong="H3063"\w*, \w and|strong="H1121"\w* \w Jeroboam|strong="H3379"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* Jehoash\f + \fr 1:1 \ft Spelled here “Joash.”\f* \w was|strong="H3068"\w* \w the|strong="H3068"\w* \w king|strong="H4428"\w* \w of|strong="H1121"\w* \w Israel|strong="H3478"\w*.  
\v 2 \w The|strong="H3588"\w* \w Lord|strong="H3068"\w* \w began|strong="H8462"\w* \w speaking|strong="H1696"\w* \w through|strong="H3212"\w* \w Hosea|strong="H1954"\w* \w by|strong="H3068"\w* \w telling|strong="H1696"\w* \w him|strong="H3947"\w*, “\w Go|strong="H3212"\w* \w and|strong="H3068"\w* \w take|strong="H3947"\w* \w a|strong="H3068"\w* \w wife|strong="H1696"\w* \w who|strong="H3068"\w* \w is|strong="H3068"\w* \w a|strong="H3068"\w* \w prostitute|strong="H2181"\w* \w and|strong="H3068"\w* \w have|strong="H3068"\w* \w children|strong="H3206"\w* born \w to|strong="H1696"\w* \w a|strong="H3068"\w* \w prostitute|strong="H2181"\w*,\f + \fr 1:2 \ft Literally “children of prostitution.” There is much debate over this phrase. Some believe this indicates that Gomer had children as a result of her prostitution before marrying Hosea. Others believe this could have happened later as she returned to her former ways (note that only the first child, Jezreel, is clearly identified as being Hosea's). Still others believe that this means any children Hosea had with Gomer would be tainted by her reputation as a prostitute. \f* \w because|strong="H3588"\w* \w those|strong="H1696"\w* living \w in|strong="H3068"\w* \w this|strong="H1696"\w* land \w have|strong="H3068"\w* committed terrible prostitution \w by|strong="H3068"\w* turning \w away|strong="H3947"\w* \w from|strong="H3947"\w* \w the|strong="H3588"\w* \w Lord|strong="H3068"\w*.”   
\p
\v 3 \w So|strong="H3947"\w* Hosea \w went|strong="H3212"\w* \w and|strong="H1121"\w* \w married|strong="H3947"\w* \w Gomer|strong="H1586"\w*, \w the|strong="H3947"\w* \w daughter|strong="H1323"\w* \w of|strong="H1121"\w* \w Diblaim|strong="H1691"\w*. She \w became|strong="H3205"\w* \w pregnant|strong="H2029"\w* \w and|strong="H1121"\w* \w bore|strong="H3205"\w* Hosea \w a|strong="H3068"\w* \w son|strong="H1121"\w*.  
\v 4 \w The|strong="H5921"\w* \w Lord|strong="H3068"\w* told \w Hosea|strong="H7121"\w*, “\w Call|strong="H7121"\w* \w him|strong="H7121"\w* \w Jezreel|strong="H3157"\w*,\f + \fr 1:4 \ft Jezreel means “the Lord will sow” (or scatter, since that was the way in which seed was sown). Jezreel was historically a place of much violence and bloodshed.\f* \w because|strong="H3588"\w* \w I|strong="H3588"\w* \w am|strong="H3068"\w* going \w to|strong="H3478"\w* \w punish|strong="H6485"\w* \w the|strong="H5921"\w* \w house|strong="H1004"\w* \w of|strong="H1004"\w* \w Jehu|strong="H3058"\w* \w for|strong="H3588"\w* \w the|strong="H5921"\w* \w blood|strong="H1818"\w* \w he|strong="H3588"\w* \w shed|strong="H1818"\w* \w at|strong="H5921"\w* \w Jezreel|strong="H3157"\w*, \w and|strong="H3478"\w* \w I|strong="H3588"\w* \w will|strong="H3068"\w* \w put|strong="H7673"\w* \w an|strong="H7673"\w* \w end|strong="H7673"\w* \w to|strong="H3478"\w* \w the|strong="H5921"\w* \w kingdom|strong="H4468"\w* \w of|strong="H1004"\w* \w Israel|strong="H3478"\w*.  
\v 5 \w On|strong="H3117"\w* \w that|strong="H3117"\w* \w day|strong="H3117"\w* \w I|strong="H3117"\w* \w will|strong="H1961"\w* \w break|strong="H7665"\w* \w Israel|strong="H3478"\w*'s military \w power|strong="H3478"\w* \w in|strong="H3478"\w* \w the|strong="H3117"\w* \w valley|strong="H6010"\w* \w of|strong="H3117"\w* \w Jezreel|strong="H3157"\w*.”   
\p
\v 6 Gomer \w became|strong="H3205"\w* \w pregnant|strong="H2029"\w* \w again|strong="H5750"\w* \w and|strong="H3478"\w* \w gave|strong="H3205"\w* \w birth|strong="H3205"\w* \w to|strong="H3478"\w* \w a|strong="H3068"\w* \w daughter|strong="H1323"\w*. \w The|strong="H3588"\w* Lord told \w Hosea|strong="H7121"\w*, “\w Call|strong="H7121"\w* \w her|strong="H5375"\w* \w Lo-ruhamah|strong="H3819"\w*,\f + \fr 1:6 \ft The name means “unloved.”\f* \w because|strong="H3588"\w* \w I|strong="H3588"\w* \w will|strong="H3478"\w* \w no|strong="H3808"\w* \w longer|strong="H5750"\w* \w love|strong="H7355"\w* \w the|strong="H3588"\w* \w house|strong="H1004"\w* \w of|strong="H1004"\w* \w Israel|strong="H3478"\w* \w and|strong="H3478"\w* \w certainly|strong="H3588"\w* \w not|strong="H3808"\w* \w forgive|strong="H5375"\w* \w them|strong="H7121"\w*.  
\v 7 \w But|strong="H3808"\w* \w I|strong="H3808"\w* \w will|strong="H3068"\w* \w have|strong="H7355"\w* \w pity|strong="H7355"\w* \w on|strong="H3068"\w* \w the|strong="H3068"\w* \w house|strong="H1004"\w* \w of|strong="H1004"\w* \w Judah|strong="H3063"\w*, \w and|strong="H3063"\w* \w I|strong="H3808"\w* \w will|strong="H3068"\w* \w save|strong="H3467"\w* \w them|strong="H7355"\w*—\w but|strong="H3808"\w* \w I|strong="H3808"\w* \w will|strong="H3068"\w* \w not|strong="H3808"\w* \w save|strong="H3467"\w* \w them|strong="H7355"\w* \w by|strong="H3068"\w* \w bow|strong="H7198"\w* \w or|strong="H3808"\w* \w sword|strong="H2719"\w* \w or|strong="H3808"\w* \w war|strong="H4421"\w* \w or|strong="H3808"\w* \w horses|strong="H5483"\w* \w and|strong="H3063"\w* riders.”   
\p
\v 8 After Gomer \w had|strong="H3205"\w* \w weaned|strong="H1580"\w* \w Lo-ruhamah|strong="H3819"\w* she \w became|strong="H3205"\w* \w pregnant|strong="H2029"\w* \w again|strong="H2029"\w* \w and|strong="H1121"\w* \w gave|strong="H3205"\w* \w birth|strong="H3205"\w* \w to|strong="H3205"\w* \w a|strong="H3068"\w* \w son|strong="H1121"\w*.  
\v 9 \w The|strong="H3588"\w* Lord told \w Hosea|strong="H7121"\w*, “\w Call|strong="H7121"\w* \w him|strong="H7121"\w* \w Lo-ammi|strong="H3818"\w*,\f + \fr 1:9 \ft The name means “not my people.”\f* \w because|strong="H3588"\w* \w you|strong="H3588"\w* \w are|strong="H5971"\w* \w not|strong="H3808"\w* \w my|strong="H1961"\w* \w people|strong="H5971"\w* \w and|strong="H5971"\w* \w I|strong="H3588"\w* \w am|strong="H1961"\w* \w not|strong="H3808"\w* \w your|strong="H3588"\w* \w God|strong="H3808"\w*.\f + \fr 1:9 \ft Literally, “I am not yours.”\f*  
\v 10 Even so\f + \fr 1:10 \ft “Even so”—transition supplied. The Hebrew simply says “and.”\f* the number of the people of Israel will be like the sand on the seashore that cannot be measured or counted. Then right there at the place where they were told ‘you are not my people’ they will be called ‘the children of the living God.’  
\v 11 The people of Israel and the people of Judah will be gathered together and they will choose one leader for themselves and they will take possession of the land, and the day of Jezreel will be great.”   
\b  
\c 2  
\p
\v 1 “\w On|strong="H1961"\w* \w that|strong="H5971"\w* day \w you|strong="H3808"\w* \w will|strong="H1961"\w* call \w your|strong="H3808"\w* \w brothers|strong="H1121"\w* \w Ammi|strong="H5971"\w*, \w and|strong="H1121"\w* \w you|strong="H3808"\w* \w will|strong="H1961"\w* call \w your|strong="H3808"\w* sisters Ruhamah.\f + \fr 2:1 \ft Ammi means “my people,” and Ruhamah means “pitied” or “loved.”\f*  
\v 2 Condemn \w your|strong="H7760"\w* mother, condemn \w her|strong="H7760"\w* \w because|strong="H3588"\w* \w she|strong="H3588"\w* \w is|strong="H3117"\w* \w not|strong="H3588"\w* \w my|strong="H7760"\w* wife \w and|strong="H1121"\w* \w I|strong="H3588"\w* am \w not|strong="H3588"\w* \w her|strong="H7760"\w* husband. Tell \w her|strong="H7760"\w* \w to|strong="H3478"\w* stop looking \w like|strong="H3478"\w* \w a|strong="H3068"\w* prostitute—\w get|strong="H5927"\w* rid \w of|strong="H1121"\w* \w the|strong="H3588"\w* makeup \w and|strong="H1121"\w* \w the|strong="H3588"\w* provocative clothing.\f + \fr 2:2 \ft Literally, “Let her remove her fornication from her face and her adultery from between her breasts.” The exact meaning is unclear. Possibilities include: the suggestive looks of a prostitute; the prostitute's makeup and jewelry; revealing clothing; or a prostitute's actions with her lovers. In any case the main sense is clear: Israel is to stop prostituting herself with other gods.\f*   
\p
\v 3 Otherwise \w I|strong="H5971"\w* \w will|strong="H5971"\w* strip her naked \w as|strong="H5971"\w* \w the|strong="H5971"\w* day she \w was|strong="H5971"\w* born, \w and|strong="H5971"\w* make her \w like|strong="H5971"\w* \w a|strong="H3068"\w* desert, \w a|strong="H3068"\w* barren land, \w and|strong="H5971"\w* let her die \w of|strong="H5971"\w* thirst.  
\v 4 \w I|strong="H3588"\w* \w will|strong="H3808"\w* \w have|strong="H3808"\w* \w no|strong="H3808"\w* pity \w on|strong="H6440"\w* \w her|strong="H5493"\w* children, \w because|strong="H3588"\w* \w they|strong="H3588"\w* \w are|strong="H6440"\w* children \w of|strong="H6440"\w* prostitution.  
\v 5 \w For|strong="H3117"\w* \w their|strong="H7760"\w* mother \w was|strong="H3117"\w* \w a|strong="H3068"\w* prostitute \w who|strong="H3205"\w* conceived \w them|strong="H7760"\w* \w in|strong="H4191"\w* \w a|strong="H3068"\w* shameful way. She said, ‘\w I|strong="H3117"\w*'ll run \w after|strong="H3117"\w* \w my|strong="H7760"\w* lovers \w who|strong="H3205"\w* \w give|strong="H3205"\w* \w me|strong="H7760"\w* \w my|strong="H7760"\w* food \w and|strong="H3117"\w* water, \w my|strong="H7760"\w* wool \w and|strong="H3117"\w* flax \w and|strong="H3117"\w* olive oil, \w and|strong="H3117"\w* \w my|strong="H7760"\w* drink.’   
\p
\v 6 \w That|strong="H3588"\w* \w is|strong="H1121"\w* \w why|strong="H3808"\w* \w I|strong="H3588"\w* am going \w to|strong="H1121"\w* block \w her|strong="H3588"\w* path \w with|strong="H1121"\w* thorn bushes, \w and|strong="H1121"\w* build \w a|strong="H3068"\w* stone wall \w to|strong="H1121"\w* \w stop|strong="H3808"\w* \w her|strong="H3588"\w* \w so|strong="H3808"\w* \w she|strong="H3588"\w* won't \w find|strong="H7355"\w* \w her|strong="H3588"\w* way.  
\v 7 \w When|strong="H3588"\w* \w she|strong="H3588"\w* runs \w after|strong="H3588"\w* \w her|strong="H5414"\w* lovers \w she|strong="H3588"\w* won't catch \w up|strong="H3001"\w* \w with|strong="H3212"\w* \w them|strong="H5414"\w*; \w she|strong="H3588"\w*'ll look \w for|strong="H3588"\w* \w them|strong="H5414"\w* \w but|strong="H3588"\w* \w she|strong="H3588"\w* won't \w find|strong="H5414"\w* \w them|strong="H5414"\w*. \w Then|strong="H5414"\w* \w she|strong="H3588"\w*'ll say, ‘\w Let|strong="H5414"\w* \w me|strong="H5414"\w* \w go|strong="H3212"\w* \w back|strong="H3212"\w* \w to|strong="H3212"\w* \w my|strong="H5414"\w* former husband, \w because|strong="H3588"\w* \w it|strong="H5414"\w* \w was|strong="H4325"\w* better \w for|strong="H3588"\w* \w me|strong="H5414"\w* \w then|strong="H5414"\w* \w than|strong="H3588"\w* \w now|strong="H3588"\w*.’   
\p
\v 8 \w She|strong="H3651"\w* doesn't consider \w that|strong="H3651"\w* \w it|strong="H3651"\w* \w was|strong="H1870"\w* \w me|strong="H4672"\w* \w who|strong="H4672"\w* gave \w her|strong="H4672"\w* grain, new wine, \w and|strong="H1870"\w* olive oil, \w nor|strong="H3808"\w* \w the|strong="H1870"\w* silver \w and|strong="H1870"\w* \w the|strong="H1870"\w* gold which \w I|strong="H2005"\w* gave \w her|strong="H4672"\w* abundantly \w that|strong="H3651"\w* \w they|strong="H3651"\w* \w made|strong="H7753"\w* into \w an|strong="H4672"\w* idol \w of|strong="H1870"\w* Baal.  
\v 9 \w So|strong="H3808"\w* \w I|strong="H3588"\w* \w will|strong="H3808"\w* \w take|strong="H7725"\w* \w back|strong="H7725"\w* \w my|strong="H1245"\w* ripened grain \w and|strong="H7725"\w* \w my|strong="H1245"\w* new wine \w I|strong="H3588"\w* \w gave|strong="H7725"\w* \w at|strong="H7725"\w* harvest-time. \w I|strong="H3588"\w* \w will|strong="H3808"\w* \w take|strong="H7725"\w* \w back|strong="H7725"\w* \w my|strong="H1245"\w* wool \w and|strong="H7725"\w* \w my|strong="H1245"\w* flax \w I|strong="H3588"\w* provided \w to|strong="H7725"\w* cover \w her|strong="H4672"\w* nakedness.  
\v 10 \w I|strong="H3588"\w* \w will|strong="H5414"\w* strip \w her|strong="H5414"\w* naked \w while|strong="H1931"\w* \w her|strong="H5414"\w* lovers \w watch|strong="H3045"\w*; \w no|strong="H3808"\w* \w one|strong="H3808"\w* \w will|strong="H5414"\w* \w be|strong="H3808"\w* able \w to|strong="H6213"\w* rescue \w her|strong="H5414"\w* \w from|strong="H2091"\w* \w me|strong="H5414"\w*.  
\v 11 \w I|strong="H3651"\w* \w will|strong="H7725"\w* \w put|strong="H7725"\w* \w a|strong="H3068"\w* stop \w to|strong="H7725"\w* \w all|strong="H5337"\w* \w her|strong="H3947"\w* festivities: \w her|strong="H3947"\w* \w feasts|strong="H4150"\w*, \w new|strong="H8492"\w* moon celebrations, special Sabbaths—\w all|strong="H5337"\w* \w her|strong="H3947"\w* \w festivals|strong="H4150"\w*.\f + \fr 2:11 \ft While the celebrations mentioned are all part of the religious calendar, it seems that they had become an excuse for partying rather than true observance.\f*  
\v 12 \w I|strong="H6258"\w* \w will|strong="H5869"\w* destroy \w her|strong="H1540"\w* vines \w and|strong="H3027"\w* fig trees \w that|strong="H3027"\w* \w she|strong="H3808"\w* said \w were|strong="H5869"\w* \w given|strong="H3027"\w* \w to|strong="H3027"\w* \w her|strong="H1540"\w* \w as|strong="H5869"\w* payment \w for|strong="H3027"\w* being \w a|strong="H3068"\w* prostitute. \w I|strong="H6258"\w* \w will|strong="H5869"\w* turn \w them|strong="H3027"\w* \w into|strong="H1540"\w* scrub-land; \w only|strong="H5337"\w* wild animals \w will|strong="H5869"\w* eat \w the|strong="H3027"\w* remaining fruit.  
\v 13 \w I|strong="H3605"\w* \w will|strong="H7673"\w* punish \w her|strong="H3605"\w* \w for|strong="H3605"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w times|strong="H4150"\w* \w she|strong="H2320"\w* offered incense \w to|strong="H4150"\w* Baal, dressing herself \w up|strong="H3605"\w*, putting \w on|strong="H3605"\w* rings \w and|strong="H4150"\w* jewelry, going after \w her|strong="H3605"\w* lovers, \w but|strong="H3605"\w* forgetting \w about|strong="H3605"\w* \w me|strong="H3605"\w*, declares \w the|strong="H3605"\w* Lord.   
\p
\v 14 See what \w I|strong="H5414"\w*'m going \w to|strong="H5414"\w* \w do|strong="H1612"\w*! \w I|strong="H5414"\w* \w will|strong="H5414"\w* win \w her|strong="H5414"\w* back, \w taking|strong="H7760"\w* \w her|strong="H5414"\w* \w into|strong="H5414"\w* \w the|strong="H5414"\w* desert \w where|strong="H1992"\w* \w I|strong="H5414"\w* \w will|strong="H5414"\w* speak \w to|strong="H5414"\w* \w her|strong="H5414"\w* heart-to-heart.  
\v 15 \w There|strong="H1992"\w* \w I|strong="H3117"\w* \w will|strong="H3068"\w* return \w her|strong="H5921"\w* vineyards \w to|strong="H3212"\w* \w her|strong="H5921"\w* \w and|strong="H3068"\w* \w make|strong="H6485"\w* \w the|strong="H5002"\w* Valley \w of|strong="H3068"\w* Achor\f + \fr 2:15 \ft “Achor” means “trouble.” See \xt Joshua 7:26\ft . \f* \w a|strong="H3068"\w* door \w of|strong="H3068"\w* hope. \w There|strong="H1992"\w* \w she|strong="H5921"\w* \w will|strong="H3068"\w* respond \w to|strong="H3212"\w* \w me|strong="H5921"\w* \w as|strong="H3117"\w* \w she|strong="H5921"\w* \w did|strong="H3068"\w* \w when|strong="H3117"\w* \w she|strong="H5921"\w* \w was|strong="H3068"\w* \w young|strong="H3117"\w*, \w as|strong="H3117"\w* \w in|strong="H5921"\w* \w the|strong="H5002"\w* \w time|strong="H3117"\w* \w when|strong="H3117"\w* \w she|strong="H5921"\w* left \w the|strong="H5002"\w* land \w of|strong="H3068"\w* Egypt.  
\v 16 \w Then|strong="H1696"\w* \w on|strong="H5921"\w* \w that|strong="H3651"\w* day, \w says|strong="H1696"\w* \w the|strong="H5921"\w* Lord, \w you|strong="H5921"\w* \w will|strong="H3820"\w* call \w me|strong="H5921"\w* ‘\w my|strong="H5921"\w* husband’ \w and|strong="H3212"\w* \w not|strong="H1696"\w* ‘\w my|strong="H5921"\w* Baal.’\f + \fr 2:16 \ft “My Baal” would normally be translated as “my lord,” but since the context is that of Israel following pagan religions who called their various gods “Baal” then this is more appropriate here. In addition, God wants the close relationship of being Israel's husband rather than simply her Lord.\f*  
\v 17 \w I|strong="H3117"\w* \w will|strong="H4714"\w* stop \w her|strong="H5414"\w* appealing \w to|strong="H5927"\w* \w the|strong="H5414"\w* Baals—\w their|strong="H5414"\w* names won't \w be|strong="H3117"\w* \w mentioned|strong="H5927"\w* \w ever|strong="H3117"\w* \w again|strong="H6030"\w*.   
\p
\v 18 \w At|strong="H3068"\w* \w that|strong="H3117"\w* \w time|strong="H3117"\w* \w I|strong="H3117"\w* \w will|strong="H3068"\w* \w make|strong="H7121"\w* \w a|strong="H3068"\w* solemn agreement\f + \fr 2:18 \ft Or “covenant.” Here it implies that these creatures will not hurt the people of Israel.\f* \w with|strong="H3068"\w* \w the|strong="H5002"\w* wild \w animals|strong="H1961"\w* \w and|strong="H3068"\w* \w the|strong="H5002"\w* birds \w of|strong="H3068"\w* \w the|strong="H5002"\w* sky \w and|strong="H3068"\w* \w the|strong="H5002"\w* creeping \w things|strong="H1961"\w* \w of|strong="H3068"\w* \w the|strong="H5002"\w* ground. \w I|strong="H3117"\w* \w will|strong="H3068"\w* \w do|strong="H3068"\w* \w away|strong="H5750"\w* \w with|strong="H3068"\w* \w the|strong="H5002"\w* bow \w and|strong="H3068"\w* \w the|strong="H5002"\w* sword; \w I|strong="H3117"\w* \w will|strong="H3068"\w* abolish war \w from|strong="H3117"\w* \w the|strong="H5002"\w* land \w so|strong="H1961"\w* \w you|strong="H3117"\w* \w can|strong="H3808"\w* \w lie|strong="H1961"\w* \w down|strong="H7121"\w* \w in|strong="H3068"\w* safety.  
\v 19 \w I|strong="H3808"\w* \w will|strong="H3808"\w* \w make|strong="H2142"\w* \w you|strong="H3808"\w* \w my|strong="H2142"\w* wife forever; \w I|strong="H3808"\w* \w will|strong="H3808"\w* \w make|strong="H2142"\w* \w you|strong="H3808"\w* \w my|strong="H2142"\w* wife \w in|strong="H5493"\w* goodness \w and|strong="H6310"\w* justice \w and|strong="H6310"\w* love \w and|strong="H6310"\w* mercy.  
\v 20 \w I|strong="H3117"\w* \w will|strong="H2719"\w* \w be|strong="H3117"\w* faithful \w to|strong="H3117"\w* \w you|strong="H3117"\w*, \w my|strong="H4480"\w* \w wife|strong="H2416"\w*, \w and|strong="H3117"\w* \w you|strong="H3117"\w* \w will|strong="H2719"\w* know \w me|strong="H4480"\w* \w as|strong="H3117"\w* \w the|strong="H4480"\w* Lord.  
