\id XXC - Paama NT + [pma] -Vanuatu 2015 (DBL 2015)
\h Tables
\toc1 Tables
\toc2 Tables
\mt1 Tables
\tr 
\th1 \bd Sua teni\bd*
\th2 \bd Oda\bd*
\th3 \bd Histri ten Sios - sua 0 rokol 100\bd*
\tr 
\tc1 37 BC–4 AD
\tc2 A
\tc3 Rom ling Mari Herod vi asuv houlu en out Isrel.
\tr 
\tc1 27 BC -14 AD
\tc2 B
\tc3 Sisa Ogastas vi mari asuv houlu ten out Rom mul losil kat out kantri houlu
\tr 
\tc1 0
\tc2 C
\tc3 \bd Iesu avasi\bd*
\tr 
\tc1 26-30
\tc2 E
\tc3 Sion Baptis mul vit luvat selusien onen Ahi.
\tr 
\tc1 26-36
\tc2 D
\tc3 Pontias Paelet mai vi avat ten kavmen en out Sudea.
\tr 
\tc1 30-33
\tc2 F
\tc3 Iesu mul mumon umen onen Ahi en out netan.
\tr 
\tc1 33
\tc2 G
\tc3 Iesu mat en aiveave.
\tr 
\tc1 33
\tc2 H
\tc3 Pentekos koa meatin taosen etel along demkatien one en Iesu.
\tr 
\tc1 34
\tc2 I
\tc3 Siu keil akov vini Stivin ka asak purun Kristin keil.
\tr 
\tc1 36
\tc2 J
\tc3 Ahi viles Pol mai vi Kristin.
\tr 
\tc1 44
\tc2 K
\tc3 Herod Antipas mu vini \bd eiloheh Tiemes\bd* ven demkatien onen en out Serusalem.
\tr 
\tc1 45-49
\tc2 L
\tc3 Ualien rohtoh onen Pol (keilu Banabas) (Umen 13—14)
\tr 
\tc1 48
\tc2 20
\tc3 \bdit Tiemes\bdit* - Tiemes mutisi navong mul en out Serusalem.
\tr 
\tc1 49
\tc2 6
\tc3 \bdit Kalesia\bdit* - Pol mutisi
\tr 
\tc1 50-53
\tc2 M
\tc3 Ualien koa vi elu onen Pol (keilu Saelas) (Umen 15—18)
\tr 
\tc1 51
\tc2 13
\tc3 \bdit 1 Tesalonaeka\bdit* - Pol mutisi navong mul en out Korin.
\tr 
\tc1 52
\tc2 14
\tc3 \bdit 2 Tesalonaeka\bdit* - Pol mutisi navong mul en out Korin.
\tr 
\tc1 53-57
\tc2 N
\tc3 Ualien koa vi etel onen Pol (Umen 18:23–21:17)
\tr 
\tc1 54
\tc2 O
\tc3 Navong \bd eiloheh Pilip\bd* mul vitehiten more longlongien min meatin keil ten out Esia, en out Frikea amuti kati en aiveave.
\tr 
\tc1 55
\tc2 9
\tc3 \bdit 1 Korin\bdit* - Pol mutisi navong mul en out Efeses.
\tr 
\tc1 55
\tc2 10
\tc3 \bdit 2 Korin\bdit* - Pol mutisi navong mul en out Masedonia.
\tr 
\tc1 56
\tc2 2
\tc3 \bdit Mak\bdit* - Sion Mak, meteilau onen Banabas mutisi
\tr 
\tc1 57
\tc2 8
\tc3 \bdit Rom\bdit* - Pol mutisi navong mul en out Korin.
\tr 
\tc1 60
\tc2 1
\tc3 \bdit Matiu\bdit* - Eiloheh Matiu Livae mutisi
\tr 
\tc1 60
\tc2 12
\tc3 \bdit Kolosi\bdit* - Pol mutisi navong mul en out Rom.
\tr 
\tc1 60
\tc2 18
\tc3 \bdit Filimon\bdit* - Pol mutisi navong mul en out Kolosi.
\tr 
\tc1 60
\tc2 3
\tc3 \bdit Luk\bdit* - Dokta Luk koa rovitei Siu mutisi
\tr 
\tc1 60
\tc2 7
\tc3 \bdit Efeses\bdit* - Pol mutisi navong mul en out Rom.
\tr 
\tc1 60
\tc2 P
\tc3 Pol va en out Rom (Umen 27:18–28:16)
\tr 
\tc1 61
\tc2 11
\tc3 \bdit Pilipae\bdit* - Pol mutisi navong mul en out Rom.
\tr 
\tc1 63
\tc2 21
\tc3 \bdit 1 Pita\bdit* - Pita mutisi navong mul en out Serusalem.
\tr 
\tc1 63
\tc2 5
\tc3 \bdit Umen\bdit* - Dokta Luk mutisi
\tr 
\tc1 63
\tc2 Q
\tc3 \bd Eiloheh Tiemes\bd* (natin Alveas) avuli kati en out Serusalem ka akuri en out nesa en Eim Votut. Navong seseini keke valokovein demkatien onen en Iesu en meten meatin keil, avat keil onen Siu keil asoni vita ka bon atan en aven. Evus, amu vini en ai keil.
\tr 
\tc1 64
\tc2 15
\tc3 \bdit 1 Timoti\bdit* - Pol mutisi navong mul en out Pilipae.
\tr 
\tc1 64
\tc2 17
\tc3 \bdit Taetas\bdit* - Pol mutisi navong mul en out Pilipae.
\tr 
\tc1 64
\tc2 R
\tc3 Mari ahang tai kan lein mari taon ten out Rom ka mari asuv houlu Nero luvos vit Kristin keil amumoni. Sakini mari sakpurunien kur out.
\tr 
\tc1 64
\tc2 26
\tc3 \bdit Siud\bdit* - Siud, tua tai onen Iesu, mutisi.
\tr 
\tc1 65
\tc2 S
\tc3 \bd Eiloheh Matiu\bd* va mum en kantri ten out Partia ka Itiopia ka asali en metas tai ka ara koteh hiren.
\tr 
\tc1 67
\tc2 16
\tc3 \bdit 2 Timoti\bdit* - Pol mutisi en eim takeih en out Rom.
\tr 
\tc1 67
\tc2 22
\tc3 \bdit 2 Pita\bdit* - Pita mutisi navong mul en out \bd Serusalem\bd*.
\tr 
\tc1 67
\tc2 T
\tc3 Aling \bd eiloheh Pita\bd* en aiveave, ka ven Pita longe suval rovinvintei keke hemat en vati sakien koa Iesu mat eni, vis keil iti kati vatin hehita netan ka alen hina nesa. Sakini, amuti kati mukonek. (Sion 21:19)
\tr 
\tc1 67
\tc2 U
\tc3 Ara koteh vatin \bd Pol\bd* ran teiai onen. Armuti kattei en aiveave suval Kristin sav keil veni kei vi horetan ten Rom.
\tr 
\tc1 68
\tc2 19
\tc3 \bdit Hibru\bdit* - Roreingeingen isei mutisi.
\tr 
\tc1 68
\tc2 V
\tc3 Mari asuv houlu Nero ten out Rom mat.
\tr 
\tc1 69-79
\tc2 W
\tc3 Vespasian mai vi mari asuv houlu ten out Rom.
\tr 
\tc1 70
\tc2 X
\tc3 Siu keil en out Serusalem amumon rea tai va kat kavmen ten out Rom. Sakini, asan meatin tavaeen keil one keke avatali mal en Siu keil. Ka koakeil ten out Rom apurun taon ten out Serusalem, amu lein Eim Votut onen Ahi, ka amumuas Siu keil houlu.
\tr 
\tc1 70
\tc2 Y
\tc3 \bd Eiloheh Andru\bd* va viteni more longlongien min koakeil amul soutin. Ka en out Akea apar koteh hiren.
\tr 
\tc1 70
\tc2 Z
\tc3 \bd Eiloheh Tomas\bd* mul vit usil Iesu en out vasi. Ka en avong tai, avuli kati, asali en metas keil, ka amuniti.
\tr 
\tc1 70
\tc2 ZA
\tc3 \bd Eiloheh Nataniel\bd*, koa avise mun en Batolomiu, amutah puruni ka amuti kati en aiveave.
\tr 
\tc1 70
\tc2 ZB
\tc3 \bd Eiloheh Matias\bd*, koa kekes Sudas, va san selusien onen Ahi en out Itiopia, ka akov vini navong mul murur en aiveave.
\tr 
\tc1 72
\tc2 ZC
\tc3 \bd Eiloheh Siud\bd*, koa avise en Tatios, va ven meatin keil en out ist, vesesal en out Turkey, ka amuasi en ai keil.
\tr 
\tc1 74
\tc2 ZD
\tc3 \bd Eiloheh Saemon\bd* va soutin en out Afrika, ka va soutin en out koa avise en Britain. Ka en out enek, amuti kati en aiveave.
\tr 
\tc1 81-96
\tc2 ZE
\tc3 Domisian mai vi mari asuv houlu ten out Rom.
\tr 
