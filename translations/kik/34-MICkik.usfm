\id MIC - Biblica® Open Kikuyu Holy Word of God 
\h Mika 
\toc1 Mika 
\toc2 Mika 
\toc3 Mik 
\mt1 MIKA 
\c 1  
\p  
\v 1 Ĩno nĩyo ndũmĩrĩri ya Jehova ĩrĩa yakinyĩrĩire Mika\f + \fr 1:1 \ft Rĩĩtwa Mika rĩgĩtaũrwo nĩ kuuga “Nũũ ũhaana ta Jehova”.\f* ũrĩa warĩ wa itũũra rĩa Moreshethu, ĩkoniĩ Samaria na Jerusalemu, hĩndĩ ya ũthamaki wa Jothamu, na wa Ahazu, na wa Hezekia, athamaki a Juda. 
\q1  
\v 2 Atĩrĩrĩ, ta thikĩrĩriai inyuĩ andũ aya inyuothe; 
\q2 o nawe thĩ ta igua, na arĩa othe matũũraga kuo, 
\q1 nĩgeetha Mwathani Jehova arute ũira wa kũmũũkĩrĩra, 
\q2 o we Mwathani arĩ thĩinĩ wa hekarũ yake theru. 
\s1 Ituĩro rĩa Gũũkĩrĩra Samaria na Jerusalemu 
\q1  
\v 3 Atĩrĩrĩ! Jehova nĩarooka oimĩte gĩikaro gĩake; 
\q2 araikũrũka arangĩrĩrie kũrĩa gũtũũgĩru gũkũ thĩ. 
\q1  
\v 4 Irĩma itwekaga irĩ rungu rwake, 
\q2 nayo mĩkuru ĩgaatũkana; 
\q1 itwekaga ta mũhũra ũrĩ mwaki-inĩ, 
\q2 igaikũrũka ta maaĩ maikũrũkĩte na ihenya kĩgaragaro-inĩ. 
\q1  
\v 5 Ũndũ ũyũ wonekete nĩ ũndũ wa ũremi wa Jakubu, 
\q2 na nĩ ũndũ wa mehia ma nyũmba ya Isiraeli. 
\q1 Ũremi wa Jakubu-rĩ, nĩ ũrĩkũ? 
\q2 Githĩ ti Samaria? 
\q1 Kũndũ kũrĩa gũtũũgĩru kwa Juda-rĩ, nĩ kũ? 
\q2 Githĩ ti Jerusalemu? 
\b  
\q1  
\v 6 “Nĩ ũndũ ũcio, ngaatua Samaria hĩba ya mahiga, 
\q2 gũtuĩke kũndũ gwa kũhaandagwo mĩthabibũ. 
\q1 Nĩngaita mahiga marĩo mũkuru-inĩ 
\q2 na thikũrie mĩthingi yarĩo. 
\q1  
\v 7 Mĩhianano yarĩo yothe nĩĩkoinangwo icunjĩ; 
\q2 nacio iheo ciothe cia hekarũ yarĩo icinwo na mwaki. 
\q1 Nĩngananga mĩhianano yothe yarĩo. 
\q2 Tondũ rĩonganirie iheo ciarĩo kuuma mũcaara wa ũmaraya, 
\q1 na igaatũmĩrwo rĩngĩ irĩ mũcaara wa kũrĩha maraya.” 
\s1 Maithori na Kĩrĩro 
\q1  
\v 8 Tondũ ũcio-rĩ, ngũrĩra na ngirĩke, 
\q2 na thiĩ ndĩ magũrũ matheri na ndĩ njaga. 
\q1 Ngũgirĩka o ta mbwe, 
\q2 na ndĩre ta ndundu. 
\q1  
\v 9 Nĩgũkorwo kĩronda kĩarĩo gĩtingĩhona; 
\q2 gĩũkĩte gĩgakinya Juda. 
\q1 Nĩgĩkinyĩte o kĩhingo‑inĩ kĩa andũ akwa, 
\q2 gĩgakinya Jerusalemu kuo kwene. 
\q1  
\v 10 Mũtikaheane ũhoro ũcio kũu Gathu, 
\q2 mũtikarĩre o na hanini. 
\q1 Ningĩ kũu Bethi-Ofara 
\q2 mwĩgaragariei rũkũngũ‑inĩ. 
\q1  
\v 11 Inyuĩ andũ arĩa mũtũũraga Shafiri, 
\q2 thiĩi mũrĩ njaga na mũconokete. 
\q1 Andũ arĩa matũũraga Zaanani 
\q2 matingiuma itũũra rĩao. 
\q1 Narĩo itũũra rĩa Bethi-Ezeli no gũcaaya rĩracaaya, 
\q2 itũũra rĩu rĩtingĩhota gũkũgitĩra. 
\q1  
\v 12 Andũ arĩa matũũraga Marothu-rĩ, 
\q2 menyogondaga nĩ ruo, o metereire ũteithio, 
\q1 nĩ ũndũ mwanangĩko ũikũrũkĩte kuuma kũrĩ Jehova, 
\q2 ũgakinya o kĩhingo-inĩ kĩa Jerusalemu. 
\q1  
\v 13 Inyuĩ mũtũũraga Lakishi,\f + \fr 1:13 \ft Lakishi rĩarĩ itũũra rĩmwe rĩa marĩa manene mũno ma Juda.\f* 
\q2 ngaari cianyu cia ita ciohererei mbarathi. 
\q1 Nĩ inyuĩ mwatoonyirie Mwarĩ wa Zayuni mehia-inĩ, 
\q2 nĩgũkorwo ũremi wa Isiraeli woimanire na inyuĩ. 
\q1  
\v 14 Nĩ ũndũ ũcio nĩmũkahe Moreshethu-Gathu 
\q2 iheo cia kuuganĩra ũhoro. 
\q1 Itũũra rĩa Akizibu no rĩa kũheenereria 
\q2 athamaki a Isiraeli. 
\q1  
\v 15 Inyuĩ mũtũũraga Maresha 
\q2 nĩngamũrehithĩria mũndũ wa kũmũũkĩrĩra, amũtoorie. 
\q1 Ũrĩa we ũrĩ Riiri wa Isiraeli 
\q2 nĩagooka Adulamu. 
\q1  
\v 16 Enjwoi mĩtwe mũcakaĩre 
\q2 ciana cianyu iria mũkenagĩra; 
\q1 mwĩenjei kĩhara mũhaane ta nderi, 
\q2 nĩgũkorwo ciana icio cianyu nĩigatahwo. 
\c 2  
\s1 Mĩbango ya Mũndũ na Mĩbango ya Ngai 
\q1  
\v 1 Kaĩ andũ arĩa mathugundaga waganu, 
\q2 o acio meciiragia maũndũ mooru marĩ ũrĩrĩ, marĩ na haaro-ĩ! 
\q1 Rũciinĩ gwakĩa mekaga o ũguo, 
\q2 tondũ hinya wa gwĩka ũguo marĩ naguo. 
\q1  
\v 2 Macumĩkagĩra mĩgũnda makamĩtunyana, 
\q2 na makeerirĩria nyũmba magacioya na hinya. 
\q1 Maheenagia mũndũ makamũtunya mũciĩ wake, 
\q2 makaheenia mũndũ wao, makamũtunya igai rĩake. 
\p  
\v 3 Nĩ ũndũ ũcio, Jehova ekuuga atĩrĩ: 
\q1 “Nĩndĩrathugunda mwanangĩko wa gũũkĩrĩra andũ aya, 
\q2 ũrĩa mũtakahota kwĩhonokia. 
\q1 Mũtigacooka gũthiiaga na mwĩtĩĩo, 
\q2 nĩgũkorwo ihinda rĩu nĩ rĩa mũtino. 
\q1  
\v 4 Mũthenya ũcio andũ nĩmakamũthekerera; 
\q2 na mamũnyũrũrie na rwĩmbo rũrũ rwa kĩrĩro, maine atĩrĩ, 
\q1 ‘Tũrĩ anange biũ; 
\q2 indo cia andũ akwa nĩngayane. 
\q1 Nĩacieheretie kuuma kũrĩ niĩ! 
\q2 Aragaya mĩgũnda iitũ kũrĩ andũ arĩa matũkunyanagĩra.’ ” 
\b  
\q1  
\v 5 Nĩ ũndũ mũtigakorwo na mũndũ o na ũmwe kĩũngano-inĩ kĩa Jehova 
\q2 wa kũgaya ithaka na ũndũ wa gũcicuukĩra mĩtĩ. 
\s1 Anabii a Maheeni 
\q1  
\v 6 Anabii ao moigaga atĩrĩ, “Mũtikarathe ũhoro. 
\q2 Tigagai kũratha ũhoro ũkoniĩ maũndũ maya; 
\q2 gĩconoko gĩtigatũkinyĩrĩra.” 
\q1  
\v 7 Ningĩ nĩ kwagĩrĩire kũũranagio atĩrĩ, 
\q2 wee nyũmba ya Jakubu: 
\q1 “Kaĩ Roho wa Jehova arĩ mũrakaru? 
\q2 We no eke maũndũ ta macio?” 
\b  
\q1 “Githĩ ciugo ciakwa itigunaga 
\q2 mũndũ ũrĩa ũthiiaga na mĩthiĩre mĩrũngĩrĩru? 
\q1  
\v 8 Ica‑ikuhĩ‑rĩ, andũ akwa maarahũkĩte magatuĩka ta thũ. 
\q2 Mũtunyaga andũ arĩa mahooreire nguo ciao cia goro, 
\q1 mũgatunya ehĩtũkĩri arĩa marahĩtũka matekũmaka, 
\q2 o acio matakoragwo na meciiria ma mbaara na inyuĩ. 
\q1  
\v 9 Mũingataga andũ‑a‑nja a andũ akwa 
\q2 kuuma mĩciĩ yao ĩrĩa mĩega. 
\q1 Mũgatunya ciana ciao 
\q2 kĩrathimo gĩakwa nginya tene. 
\q1  
\v 10 Ũkĩrai mũthiĩ, mwehere! 
\q2 Nĩgũkorwo gĩikaro gĩkĩ ti kĩo kĩhurũko kĩanyu, 
\q1 tondũ nĩgĩthaahie, 
\q2 kĩanangĩtwo ũndũ gĩtangĩcookererio. 
\q1  
\v 11 Mũndũ wa maheeni na ũtaaragia ma angĩũka oige atĩrĩ, 
\q2 ‘Ndaamũrathĩra gũkorwo na ndibei na njoohi nyingĩ,’ 
\q2 ũcio nĩwe ũngĩtĩkĩrĩka nĩ andũ aya! 
\s1 Ũhonokio Kwĩranĩrwo 
\q1  
\v 12 “Atĩrĩrĩ, inyuĩ andũ a Jakubu, 
\q2 ti‑itherũ nĩngamũcookanĩrĩria, inyuothe, 
\q1 o na inyuĩ matigari ma Isiraeli nĩngamũrehe hamwe. 
\q2 Ngamarehe hamwe ta ngʼondu irĩ kiugũ, 
\q1 matuĩke ta rũũru rwa mbũri rũrĩ ũrĩithio-inĩ waruo; 
\q2 nakĩo kĩrĩndĩ kĩa andũ kĩiyũre kuo. 
\q1  
\v 13 Mũhingũri njĩra, nĩakambata arĩ mbere yao; 
\q2 nao nĩmakamomora kĩhingo moime nja. 
\q1 Mũthamaki wao nĩakoimagara arĩ mbere yao, 
\q2 Jehova amatongoretie.” 
\c 3  
\s1 Atongoria na Anabii Gũkũũmwo 
\p  
\v 1 Ningĩ ngiuga atĩrĩ, 
\q1 “Ta iguai, inyuĩ atongoria a Jakubu, 
\q2 o inyuĩ aathani a nyũmba ya Isiraeli. 
\q1 Githĩ mũtiagĩrĩirwo nĩkũmenya ũhoro wa gũtuanĩra ciira na kĩhooto. 
\q2  
\v 2 No inyuĩ mũthũire maũndũ mega no mũkenda marĩa mooru; 
\q1 inyuĩ mũnũraga andũ akwa ikonde, 
\q2 na mũgathoora nyama mahĩndĩ-inĩ mao. 
\q1  
\v 3 Inyuĩ mũrĩĩaga nyama cia mĩĩrĩ ya andũ akwa, 
\q2 mũkamonũra ikonde 
\q2 na mũkoinanga mahĩndĩ mao tũcunjĩ; 
\q1 O inyuĩ mũmatinangagia ta nyama cia gũkarangwo na rũgĩo, 
\q2 o na ta nyama cia gũtherũkio na nyũngũ.” 
\q1  
\v 4 Hĩndĩ ĩyo magaakaĩra Jehova, 
\q2 nowe ndakamacookeria. 
\q1 Hĩndĩ ĩyo nĩakahitha ũthiũ wake kuuma kũrĩ o, 
\q2 tondũ wa ũũru ũrĩa mekĩte. 
\p  
\v 5 Jehova ekuuga atĩrĩ, 
\q1 “Ha ũhoro wa anabii acio 
\q2 mahĩtithagia andũ akwa, 
\q1 mũndũ aamahe irio, 
\q2 maanagĩrĩra makiugaga ‘thayũ,’ 
\q1 no angĩmaima irio, 
\q2 makahaarĩria mbaara ya kũmũũkĩrĩra. 
\q1  
\v 6 Tondũ ũcio, ũtukũ nĩũkamũhubanĩria, 
\q2 mwage kuona cioneki, 
\q1 mũhubanĩrio nĩ nduma mwage ũguũrio. 
\q2 Riũa nĩrĩgathũĩra anabii, 
\q1 naguo mũthenya ũmatuĩkĩre nduma. 
\q1  
\v 7 Ooni-maũndũ nĩmagaconoka, 
\q2 nao aragũri maconorithio. 
\q1 Othe nĩmakahumbĩra mothiũ mao, 
\q2 tondũ gũtirĩ ũhoro magaacookerio nĩ Ngai.” 
\b  
\q1  
\v 8 No hakwa-rĩ, niĩ njiyũrĩtwo nĩ hinya, 
\q2 na ngaiyũrwo nĩ Roho wa Jehova, 
\q2 o na ngaiyũrwo nĩ kĩhooto na ũhoti, 
\q1 nĩguo nyumbũrĩre Jakubu ũremi wake, 
\q2 na nyumbũrĩre Isiraeli mehia make. 
\q1  
\v 9 Ta thikĩrĩriai, inyuĩ atongoria a nyũmba ya Jakubu, 
\q2 o inyuĩ aathani a nyũmba ya Isiraeli, 
\q1 inyuĩ mũmenaga kĩhooto, 
\q2 na mũkoogomia maũndũ marĩa ma ma; 
\q1  
\v 10 inyuĩ mwakaga Zayuni na ũiti wa thakame, 
\q2 na mũgaaka Jerusalemu na waganu. 
\q1  
\v 11 Atongoria akuo matuaga ciira maahakwo, 
\q2 athĩnjĩri-Ngai akuo marutanaga maarĩhwo, 
\q1 na anabii akuo marathaga mohoro maheo mbeeca. 
\q2 No rĩrĩ, megiritanagia na Jehova makoiga atĩrĩ, 
\q1 “Githĩ Jehova ndakĩrĩ gatagatĩ-inĩ gaitũ? 
\q2 Gũtirĩ ũũru ũngĩtũkora.” 
\q1  
\v 12 Nĩ tondũ wanyu-rĩ, 
\q2 Zayuni gũgaaciimbwo ta mũgũnda, 
\q1 Jerusalemu gũtuĩke hĩba ya mahiga, 
\q2 nakĩo kĩrĩma kĩrĩa gĩakĩtwo hekarũ 
\q2 gĩtuĩke kĩhumbu kĩmereirwo nĩ ihinga. 
\c 4  
\s1 Kĩrĩma kĩa Jehova 
\p  
\v 1 Matukũ-inĩ ma kũrigĩrĩria, 
\q1 kĩrĩma kĩrĩa kĩa hekarũ ya Jehova nĩgĩkahaandwo 
\q2 kĩrĩ kĩo kĩnene gatagatĩ ka irĩma iria ingĩ; 
\q1 nĩgĩkambarario igũrũ rĩa tũrĩma tũrĩa tũngĩ, 
\q2 nao andũ a ndũrĩrĩ nĩkuo magaathiiaga. 
\p  
\v 2 Ndũrĩrĩ nyingĩ igaathiĩ kuo, ikiugaga atĩrĩ, 
\q1 “Ũkai twambate tũthiĩ kĩrĩma‑inĩ kĩa Jehova, 
\q2 tũthiĩ nyũmba ya Ngai wa Jakubu. 
\q1 Nĩagatũruta ũhoro wa mĩthiĩre yake, 
\q2 nĩgeetha tũgeragĩre njĩra ciake.” 
\q1 Nĩgũkorwo Zayuni nĩgũkoima ũtaarani, 
\q2 nakuo Jerusalemu kuume ndũmĩrĩri ya Jehova. 
\q1  
\v 3 Nĩagatuithania ndũrĩrĩ nyingĩ ciira, 
\q2 nacio ndũrĩrĩ iria irĩ hinya cia kuuma kũraya aciiguithanie. 
\q1 Magaatura hiũ ciao cia njora ituĩke hiũ cia mĩraũ, 
\q2 namo matimũ mao maturwo hiũ cia gũceeha mĩtĩ. 
\q1 Gũtirĩ rũrĩrĩ rũgaacooka kũrũa na rũrĩa rũngĩ na hiũ cia njora, 
\q2 kana rũcooke kwĩruta ũhoro wa mbaara rĩngĩ. 
\q1  
\v 4 O mũndũ agaikaraga gĩtina-inĩ kĩa mũthabibũ wake 
\q2 na aikarage gĩtina-inĩ kĩa mũkũyũ wake, 
\q1 na gũtirĩ mũndũ ũkaamamakia, 
\q2 nĩgũkorwo ũguo nĩguo Jehova Mwene-Hinya-Wothe oigĩte. 
\q1  
\v 5 Andũ a ndũrĩrĩ ciothe no marũmĩrĩre 
\q2 kĩrĩra kĩa ngai ciao; 
\q1 no ithuĩ tũrĩrũmagĩrĩra kĩrĩra kĩa Jehova Ngai witũ 
\q2 nginya tene na tene. 
\s1 Mũbango wa Jehova 
\p  
\v 6 Jehova ekuuga atĩrĩ: 
\q1 “Mũthenya ũcio-rĩ, 
\q2 nĩngacookanĩrĩria ithua; 
\q1 na nĩngacookanĩrĩria arĩa matahĩtwo, 
\q2 o na arĩa nyariirithĩtie. 
\q1  
\v 7 Ithua nĩngacitua matigari, 
\q2 na arĩa maingatĩtwo ndĩmatue rũrĩrĩ rũrĩ hinya. 
\q1 Jehova nĩwe ũkamaathaga arĩ Kĩrĩma-inĩ gĩa Zayuni, 
\q2 kuuma mũthenya ũcio nginya tene. 
\q1  
\v 8 Ha ũhoro waku, wee mũthiringo ũyũ mũraihu na igũrũ 
\q2 wa kũrangĩra rũũru rwa mbũri, 
\q2 o wee kĩĩhitho kĩrũmu kĩa Mwarĩ wa Zayuni-rĩ, 
\q1 wathani ũrĩa warĩ naguo mbere nĩũgagũcookerera; 
\q2 naguo ũthamaki wa Mwarĩ wa Jerusalemu ũmũcookerere.” 
\b  
\q1  
\v 9 Atĩrĩrĩ, nĩkĩ kĩratũma ũrĩre wanĩrĩire, 
\q2 kaĩ ũtarĩ na mũthamaki? 
\q1 Kaĩ ũkuĩrĩirwo nĩ mũkũhei kĩrĩra, 
\q2 tondũ wanyiitwo nĩ ruo rũhaana ta rwa mũndũ-wa-nja akĩrũmwo? 
\q1  
\v 10 Wĩnyogonde nĩ ruo, wee Mwarĩ wa Zayuni, 
\q2 o ta mũndũ-wa-nja akĩrũmwo, 
\q1 nĩgũkorwo rĩu no nginya uume itũũra inene 
\q2 ũgaikare nja werũ-inĩ. 
\q1 Nĩũgathiĩ Babuloni; 
\q2 kũu nĩkuo ũkaahonokerio. 
\q1 Kũu nĩkuo Jehova agaagũkũũra 
\q2 kuuma guoko-inĩ gwa thũ ciaku. 
\b  
\q1  
\v 11 No rĩrĩ, ndũrĩrĩ nyingĩ 
\q2 nĩicookanĩrĩire, igũũkĩrĩre. 
\q1 Iroiga atĩrĩ, “Rekei anyiitwo nĩ thaahu, 
\q2 rekei maitho maitũ mathekerere Zayuni!” 
\q1  
\v 12 No cio itingĩmenya meciiria ma Jehova; 
\q2 o na itiũĩ mũbango wake, 
\q1 o we ũrĩa ũcicookanagĩrĩria 
\q2 ta itĩĩa cia ngano kĩhũrĩro-inĩ. 
\b  
\q1  
\v 13 “Arahũka, wee Mwarĩ wa Zayuni, ũhũũre ngano ĩyo, 
\q2 nĩgũkorwo nĩngakũhe hĩa cia kĩgera; 
\q1 nĩngakũhe mahũngũ ma gĩcango 
\q2 nawe nĩũkahehenja ndũrĩrĩ nyingĩ.” 
\q1 Uumithio ũcio meyoeire na njĩra ĩtarĩ ya kĩhooto nĩũkawamũrĩra Jehova, 
\q2 ũtonga wao ũwamũrĩre Mwathani wa thĩ yothe. 
\c 5  
\s1 Mũthamaki kuuma Bethilehemu 
\q1  
\v 1 Thagathaga mbũtũ ciaku cia mbaara, 
\q2 wee itũũra inene rĩa mbũtũ cia mbaara, 
\q2 nĩgũkorwo matũrigiicĩirie matũũkĩrĩre. 
\q1 Nĩmakaringa mwathi wa Isiraeli 
\q2 rũthĩa-inĩ na rũthanju. 
\b  
\q1  
\v 2 “No rĩrĩ, wee Bethilehemu Efiratha, 
\q2 o na harĩa arĩ we mũnini mũno mĩhĩrĩga-inĩ ya Juda, 
\q1 thĩinĩ waku nĩkuo gũkoima 
\q2 ũrĩa ũgaatuĩka mwathi wa Isiraeli, 
\q1 ũrĩa kĩhumo gĩake nĩ gĩa kuuma tene, 
\q2 kuuma mĩndĩ na mĩndĩ.” 
\b  
\q1  
\v 3 Tondũ ũcio, Isiraeli nĩagatiganĩrio 
\q2 nginya ihinda rĩkinye, 
\q2 rĩrĩa ũrĩa ũraarũmwo agaaciara, 
\q1 nao ariũ-a-ithe arĩa angĩ 
\q2 magaacookerera andũ a Isiraeli. 
\b  
\q1  
\v 4 Nĩagookĩra arĩithie rũũru rwa mbũri ciake 
\q2 arĩ na hinya wa Jehova, 
\q2 na ũnene wa rĩĩtwa rĩa Jehova Ngai wake. 
\q1 Nao nĩmagatũũra marĩ agitĩre, nĩgũkorwo hĩndĩ ĩyo 
\q2 ũnene wake ũgaakinya o nginya ituri ciothe cia thĩ. 
\q2  
\v 5 Nake nĩagatuĩka thayũ wao. 
\s1 Ũhonokania na Mwanangĩko 
\q1 Hĩndĩ ĩrĩa Ashuri makaahithũkĩra bũrũri witũ, 
\q2 na matuĩkanĩrie ciĩhitho ciitũ nũmu, 
\q1 nĩtũkamaarahũrĩra arĩithi mũgwanja, 
\q2 o na anene anana mamokĩrĩre. 
\q1  
\v 6 Nĩmagaatha bũrũri wa Ashuri na rũhiũ rwa njora; 
\q2 maathe bũrũri wa Nimurodi na hiũ cia njora icomoretwo. 
\q1 Nĩagatũhonokia kuuma kũrĩ Aashuri 
\q2 hĩndĩ ĩrĩa magaatharĩkĩra bũrũri witũ 
\q2 na matuĩkanĩirie mĩhaka-inĩ iitũ. 
\b  
\q1  
\v 7 Matigari ma Jakubu magaatuĩka 
\q2 ta ime riumĩte harĩ Jehova 
\q2 gatagatĩ-inĩ ka ndũrĩrĩ nyingĩ, 
\q1 o na ta mbura ya rũthuthuũ yurĩte nyeki-inĩ, 
\q2 ĩrĩa ĩtarehagwo nĩ mũndũ kana ĩkoirio nĩ andũ. 
\q1  
\v 8 Matigari ma Jakubu magaakoragwo gatagatĩ ka ndũrĩrĩ, 
\q2 o gatagatĩ ka ndũrĩrĩ nyingĩ, 
\q1 ta mũrũũthi ũrĩ thĩinĩ wa nyamũ cia mũtitũ, 
\q2 na ta kĩana kĩa mũrũũthi kĩrĩ thĩinĩ wa ndũũru cia ngʼondu, 
\q1 kĩrĩa gĩthiiaga gĩgĩcitihangagia na gĩgĩcitambuuraga 
\q2 na gũtirĩ mũndũ ũngĩcihonokia. 
\q1  
\v 9 Guoko gwaku nĩgũkambarario na igũrũ kuonanie ũhootani harĩ thũ ciaku, 
\q2 na amuku aku othe nĩmakaniinwo. 
\p  
\v 10 Jehova ekuuga atĩrĩ, “Mũthenya ũcio-rĩ, 
\q1 “nĩngananga mbarathi ciaku ikweherere biũ, 
\q2 nacio ngaari ciaku cia ita ndĩcitharie. 
\q1  
\v 11 Nĩngananga matũũra marĩa manene ma bũrũri wanyu, 
\q2 na tharũrie ciĩhitho iria nũmu cianyu ciothe. 
\q1  
\v 12 Nĩngananga ũgo wanyu, 
\q2 na mũtigacooka kũragũra rĩngĩ. 
\q1  
\v 13 Nĩngananga mĩhianano yanyu ya gwacũhio, 
\q2 na nyanange mahiga manyu marĩa maamũre mũrĩ namo; 
\q1 mũtigacooka kũinamĩrĩra 
\q2 wĩra wa moko manyu rĩngĩ. 
\q1  
\v 14 Itugĩ cia Ashera iria mũrĩ nacio nĩngacimunya 
\q2 na momore matũũra manyu manene. 
\q1  
\v 15 Nĩngerĩhĩria ndĩ na marakara na mangʼũrĩ 
\q2 kũrĩ ndũrĩrĩ iria itanjathĩkagĩra.” 
\c 6  
\s1 Ciira wa Jehova harĩ Isiraeli 
\p  
\v 1 Ta thikĩrĩriai ũrĩa Jehova ekuuga: 
\q1 “Ũkĩrai mwĩciirĩrĩre mbere ya irĩma; 
\q2 mũreke tũrĩma tũigue ũrĩa mũkuuga. 
\q1  
\v 2 Inyuĩ irĩma ici, iguai thitango ya Jehova; 
\q2 thikĩrĩriai inyuĩ mĩthingi ya thĩ ĩrĩa ĩtũũraga tene na tene. 
\q1 Nĩgũkorwo Jehova arĩ na ciira na andũ ake, 
\q2 nĩarathitanga andũ a Isiraeli. 
\b  
\q1  
\v 3 “Andũ akwa, kaĩ ndĩmwĩkĩte atĩa? 
\q2 Ndĩmũnogetie na kĩ? Njookeriai. 
\q1  
\v 4 Ndaamũrutire bũrũri wa Misiri, 
\q2 ngĩmũkũũra kuuma bũrũri wa ũkombo. 
\q1 Ngĩtũma Musa amũtongorie, 
\q2 marĩ na Harũni na Miriamu. 
\q1  
\v 5 Andũ akwa, ririkanai 
\q2 ũrĩa Balaki mũthamaki wa Moabi aamũciirĩire, 
\q2 na ũrĩa Balamu mũrũ wa Beori aamũcookeirie. 
\q1 Ririkanai rũgendo rwanyu kuuma Shitimu nginya Giligali, 
\q2 nĩgeetha mũmenye ciĩko cia ũthingu iria Jehova aaneka.” 
\b  
\q1  
\v 6 Nĩ kĩĩ ingĩtwara mbere ya Jehova, 
\q2 ngĩinamĩrĩre mbere ya Ngai ũcio ũrĩ igũrũ mũno? 
\q1 Hihi no ngĩthiĩ mbere yake na maruta ma njino, 
\q2 kana thiĩ na tũcaũ twa ũkũrũ wa mwaka ũmwe? 
\q1  
\v 7 Anga Jehova no akenio nĩ ndũrũme ngiri nyingĩ, 
\q2 kana akenio nĩ maguta maingĩ ta ma njũũĩ ngiri ikũmi? 
\q1 Hihi no ndute mwana wakwa wa irigithathi nĩ ũndũ wa ũremi wakwa, 
\q2 kana ndute maciaro ma mwĩrĩ wakwa nĩ ũndũ wa mehia ma ngoro yakwa? 
\q1  
\v 8 Atĩrĩrĩ, wee mũndũ ũyũ, githĩ Jehova ndakuonetie maũndũ marĩa mega. 
\q2 Na nĩ ũndũ ũrĩkũ Jehova agwathaga wĩke? 
\q1 Githĩ to wĩkage maũndũ ma kĩhooto, 
\q2 na wendage ũhoro wa kũiguanĩra tha, 
\q2 na ũtwaranage na Ngai waku wĩnyiihĩtie. 
\s1 Andũ a Isiraeli Kũherithio nĩ ũndũ wa Mahĩtia Mao 
\q1  
\v 9 Ta thikĩrĩriai! Jehova nĩaretana kũu itũũra inene, 
\q2 mũndũ ũrĩa mũũgĩ nĩetigĩre rĩĩtwa rĩaku. 
\q2 “Rũmbũiya rũthanju, o na ũrĩa ũrũnyitĩte. 
\q1  
\v 10 Wee nyũmba ya waganu-rĩ, 
\q2 no ndiganĩrwo nĩ igĩĩna iria mwĩigĩire na njĩra ĩtarĩ ya kĩhooto, 
\q2 kana ndiganĩrwo nĩ eba ya gũthima ĩrĩa ĩtarĩ ya kĩhooto, ĩrĩa nume? 
\q1  
\v 11 No njuge mũndũ ndehĩtie akĩhũthagĩra ratiri itarĩ cia ma, 
\q2 arĩ na mondo ya mahiga ma gũthima ma maheeni? 
\q1  
\v 12 Itonga ciakuo nĩ cia ngũĩ; 
\q2 andũ akuo nĩ a maheeni, 
\q2 na nĩmĩ ciao nĩkũheenania iheenanagia. 
\q1  
\v 13 Tondũ ũcio, nĩnyambĩrĩirie gũkũniina, 
\q2 na ngambĩrĩria gũkwananga nĩ ũndũ wa mehia manyu. 
\q1  
\v 14 Mũrĩrĩĩaga irio na mũtihũũne, 
\q2 nda cianyu irĩkoragwo o ihũtiĩ. 
\q1 Mũrĩigaga mĩthiithũ, no mũtikahonokia kĩndũ, 
\q2 tondũ kĩrĩa gĩothe mwahonokia nĩngakĩniinithia na rũhiũ rwa njora. 
\q1  
\v 15 Mũrĩhaandaga no mũtikaagetha; 
\q2 mũrĩĩhihaga ndamaiyũ no mũtikehaka maguta ma cio; 
\q2 mũrĩĩhihaga thabibũ no mũtikanyua ndibei yacio. 
\q1  
\v 16 Nĩmũrũmĩrĩire irĩra cia watho wa Omuri 
\q2 na mĩtugo yothe ya nyũmba ya Ahabu, 
\q2 mũkarũmĩrĩra irĩra ciao cia ndũire. 
\q1 Tondũ ũcio nĩngamũrekereria mwanangwo, 
\q2 na ndekererie andũ anyu matuĩke a gũthekererwo; 
\q2 mũgaatũũra mũnyararĩtwo nĩ ndũrĩrĩ icio.” 
\c 7  
\s1 Mĩnyamaro ya Isiraeli 
\q1  
\v 1 Hĩ, kaĩ ndĩ mũnyamarĩku-ĩ! 
\q2 Ndariĩ ta mũndũ ũrongania maciaro maarĩkia kũgethwo hĩndĩ ya riũa, 
\q2 o ta mũndũ ũrahaara thabibũ thuutha wa magetha; 
\q1 gũtirĩ kĩmanjĩka gĩa thabibũ kĩngĩrĩĩo, 
\q2 o na kana ngũyũ iria ciambaga kwĩrua iria ngoro yakwa ĩĩriragĩria. 
\q1  
\v 2 Andũ arĩa eetigĩri Ngai nĩmathirĩte bũrũri‑inĩ, 
\q2 gũtirĩ mũndũ o na ũmwe mũrũngĩrĩru ũtigarĩte. 
\q1 Andũ othe maikarĩte metereire gũita thakame; 
\q2 o mũndũ araguĩma mũrũ wa nyina na wabu. 
\q1  
\v 3 Mahũthagĩra moko mao meerĩ gwĩka ũũru; 
\q2 mũtongoria etagia iheo na hinya, 
\q1 nake mũciirithania aamũkagĩra mahaki; 
\q2 arĩa marĩ hinya nĩo moigaga kĩrĩa mekwenda: 
\q2 othe makagĩa ndundu ya gwĩka ũũru. 
\q1  
\v 4 Ũrĩa mwega mũno wao ahaana ta congʼe, 
\q2 ũrĩa mũrũngĩrĩru mũno nĩ mũũru gũkĩra rũgiri rwa mĩigua. 
\q1 Mũthenya ũrĩa arangĩri aku matũire makwĩraga ũhoro waguo nĩmũkinyu, 
\q2 mũthenya ũrĩa Ngai agaagũceerera. 
\q2 Rĩĩrĩ nĩrĩo ihinda rĩa kĩrigiicano kĩao. 
\q1  
\v 5 Ndũkanehoke mũndũ wa itũũra; 
\q2 ndũkanehoke o na mũrataguo. 
\q1 Menyerera ciugo cia kanua gaku, 
\q2 ndũkaanahe mũtumia waku ũcio ũkomaga gĩthũri‑inĩ gĩaku ũhoro. 
\q1  
\v 6 Nĩgũkorwo mũriũ nĩagĩte gũtĩĩa ithe, 
\q2 nake mũirĩtu akaremera nyina, 
\q1 o nake mũtumia wa mũriũ akaremera nyaciarawe, 
\q2 thũ cia mũndũ igaatuĩka andũ a nyũmba yake mwene. 
\b  
\q1  
\v 7 No rĩrĩ, niĩ hakwa‑rĩ, ndĩcũthagĩrĩria Jehova 
\q2 ndĩ na kĩĩrĩgĩrĩro, 
\q1 njetereire Ngai Mũhonokia wakwa; 
\q2 Ngai wakwa-rĩ, nĩakanjigua. 
\s1 Isiraeli Kwĩhaanda Rĩngĩ 
\q1  
\v 8 Atĩrĩrĩ, wee thũ yakwa-rĩ, tiga kũngenerera! 
\q2 O na ingĩgũa gũtirĩ hĩndĩ itagookĩra! 
\q1 O na ingĩikara nduma-inĩ-rĩ, 
\q2 Jehova nĩwe ũrĩtuĩkaga ũtheri wakwa. 
\q1  
\v 9 Tondũ nĩ niĩ ndĩmwĩhĩirie, 
\q2 nĩngũkirĩrĩria mangʼũrĩ ma Jehova 
\q1 nginya rĩrĩa we akaanjiirĩrĩra, 
\q2 na onanie kĩhooto gĩakwa. 
\q1 Nĩakanduta nduma-inĩ, andehe ũtheri-inĩ, 
\q2 na niĩ nĩngeyonera ũthingu wake. 
\q1  
\v 10 Hĩndĩ ĩyo thũ yakwa nĩĩkeyonera ũguo, 
\q2 na ĩhumbwo thoni, 
\q1 o ĩyo yanjũũragia atĩrĩ, 
\q2 “Jehova Ngai waku akĩrĩ ha?” 
\q1 Rĩu nĩ hĩndĩ maitho makwa mekwĩonera kũgũa kwayo, 
\q2 o na ĩkarangĩrĩrio thĩ ta ndooro ya njĩra-inĩ. 
\b  
\q1  
\v 11 Mũthenya wa gwaka thingo ciaku nĩũgakinya, 
\q2 o guo mũthenya wa kwaramia mĩhaka yaku. 
\q1  
\v 12 Mũthenya ũcio, andũ nĩmagooka kũrĩ we 
\q2 moimĩte Ashuri na matũũra manene ma Misiri, 
\q1 na bũrũri ũrĩa ũrĩ gatagatĩ ka bũrũri wa Misiri 
\q2 na Rũũĩ rwa Farati, 
\q1 na kuuma iria rĩmwe nginya rĩrĩa rĩngĩ, 
\q2 na kuuma kĩrĩma kĩmwe nginya kĩrĩa kĩngĩ. 
\q1  
\v 13 Thĩ nĩĩkanangĩka ĩkire ihooru nĩ ũndũ wa andũ arĩa matũũraga kuo, 
\q2 marĩ maciaro ma ciĩko ciao. 
\s1 Mahooya na Kĩgooco 
\q1  
\v 14 Rĩithia andũ aku na mũthĩgi waku, 
\q2 nĩo rũũru rwa igai rĩaku, 
\q1 rũrĩa rwĩrĩithagia rũrĩ rwiki mũtitũ-inĩ, 
\q2 kũrĩa kũrĩ ũrĩithio mũnoru. 
\q1 Reke irĩe o kũu Bashani na Gileadi, 
\q2 o ta ũrĩa ciarĩĩaga matukũ ma tene. 
\b  
\q1  
\v 15 “Ta ũrĩa gwatariĩ matukũ marĩa mwoimire bũrũri wa Misiri, 
\q2 nĩngamoonia morirũ makwa.” 
\b  
\q1  
\v 16 Ndũrĩrĩ nĩikoona na iconoke, 
\q2 itunyĩtwo hinya wacio wothe. 
\q1 Nĩikenyiita tũnua twacio, 
\q2 na ihingare matũ ciage kũigua. 
\q1  
\v 17 Igaacũnaga rũkũngũ ta nyoka, 
\q2 ta ciũmbe iria ikurumaga thĩ. 
\q1 Nĩikoimĩra kuuma imamo-inĩ ciacio ikĩinainaga; 
\q2 nĩigacookerere Jehova Ngai witũ na guoya, 
\q2 na nĩigagwĩtigĩra. 
\q1  
\v 18 Nĩ Ngai ũrĩkũ ũhaana tawe, 
\q2 ũrĩa ũrekagĩra matigari ma igai rĩake mehia na ũremi wao? 
\q1 Ndũtũũraga ũrakarĩte nginya tene, 
\q2 no nĩũkenagio nĩ kũiguanĩra tha. 
\q1  
\v 19 Nĩũgatũiguĩra tha rĩngĩ, 
\q2 mehia maitũ nĩũkamarangĩrĩria na makinya, 
\q2 na waganu witũ wothe ũũnyugute iria-inĩ kũrĩa kũriku. 
\q1  
\v 20 Nĩũgatũũria kĩrĩkanĩro gĩaku kũrĩ Jakubu, 
\q2 na ũiguĩre Iburahĩmu tha, 
\q1 o ta ũrĩa werĩire maithe maitũ na mwĩhĩtwa 
\q2 matukũ-inĩ macio ma tene.