\v 43 \w Moisés|strong="H4872"\w* \w vio|strong="H7200"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w obra|strong="H4399"\w*, y \w ciertamente|strong="H2009"\w* \w la|strong="H3605"\w* \w hicieron|strong="H6213"\w* \w tal|strong="H3651"\w* \w como|strong="H3651"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w ordenó|strong="H6680"\w*. \w Así|strong="H3651"\w* \w la|strong="H3605"\w* \w hicieron|strong="H6213"\w*, y \w Moisés|strong="H4872"\w* \w los|strong="H3605"\w* \w bendijo|strong="H1288"\w*.   
\c 40  
\s1 Establecimiento del Tabernáculo  
\p
\v 1 Entonces \nd \+w Yavé|strong="H3068"\+w*\nd* \w habló|strong="H1696"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*:  
\v 2 \wj El \+w primer|strong="H7223"\+w* \+w día|strong="H3117"\+w* del \+w mes|strong="H2320"\+w* \+w primero|strong="H7223"\+w* ordenarás \+w levantar|strong="H6965"\+w* el \+w Tabernáculo|strong="H4908"\+w* de Reunión.\wj*  
\v 3 \wj \+w Pondrás|strong="H7760"\+w* \+w allí|strong="H8033"\+w* \+w el|strong="H5921"\+w* Arca \+w del|strong="H5921"\+w* \+w Testimonio|strong="H5715"\+w* \+w y|strong="H5921"\+w* \+w la|strong="H5921"\+w* ocultarás \+w con|strong="H5921"\+w* \+w el|strong="H5921"\+w* velo.\wj*  
\v 4 \wj Introducirás la \+w mesa|strong="H7979"\+w*, arreglarás sus utensilios, pondrás el candelabro y mandarás encender sus \+w lámparas|strong="H5216"\+w*.\wj*   
\p
\v 5 \wj Luego \+w pondrás|strong="H5414"\+w* el \+w altar|strong="H4196"\+w* \+w de|strong="H6440"\+w* \+w oro|strong="H2091"\+w* \+w para|strong="H5414"\+w* el incienso frente al Arca \+w del|strong="H4196"\+w* \+w Testimonio|strong="H5715"\+w*, y \+w pondrás|strong="H5414"\+w* la cortina en la entrada \+w del|strong="H4196"\+w* \+w Tabernáculo|strong="H4908"\+w*.\wj*   
\p
\v 6 \wj \+w Pondrás|strong="H5414"\+w* el \+w altar|strong="H4196"\+w* \+w del|strong="H4196"\+w* \+w holocausto|strong="H5930"\+w* después \+w de|strong="H6440"\+w* la entrada \+w al|strong="H5930"\+w* \+w Tabernáculo|strong="H4908"\+w* \+w de|strong="H6440"\+w* Reunión.\wj*  
\v 7 \wj \+w Pondrás|strong="H5414"\+w* la \+w fuente|strong="H3595"\+w* \+w entre|strong="H8033"\+w* la entrada al Tabernáculo \+w de|strong="H5414"\+w* Reunión y el \+w altar|strong="H4196"\+w*, y echarás \+w agua|strong="H4325"\+w* en \+w ella|strong="H8033"\+w*.\wj*  
\v 8 \wj Arreglarás el \+w patio|strong="H2691"\+w* \+w alrededor|strong="H5439"\+w*, y colgarás la cortina \+w de|strong="H5414"\+w* la entrada al \+w patio|strong="H2691"\+w*.\wj*   
\p
\v 9 \wj \+w Tomarás|strong="H3947"\+w* \+w el|strong="H3605"\+w* \+w aceite|strong="H8081"\+w* de \+w la|strong="H3605"\+w* \+w unción|strong="H4888"\+w* y \+w ungirás|strong="H4886"\+w* \+w el|strong="H3605"\+w* \+w Tabernáculo|strong="H4908"\+w* y \+w todo|strong="H3605"\+w* \+w lo|strong="H3605"\+w* \+w que|strong="H1961"\+w* \+w hay|strong="H1961"\+w* en \+w él|strong="H3605"\+w*. Así \+w lo|strong="H3605"\+w* consagrarás junto con \+w todos|strong="H3605"\+w* sus utensilios, y \+w será|strong="H1961"\+w* \+w sagrado|strong="H6944"\+w*.\wj*  
\v 10 \wj \+w Ungirás|strong="H4886"\+w* también \+w el|strong="H3605"\+w* \+w altar|strong="H4196"\+w* \+w del|strong="H4196"\+w* \+w holocausto|strong="H5930"\+w* y \+w todos|strong="H3605"\+w* sus utensilios, y \+w santificarás|strong="H6942"\+w* \+w el|strong="H3605"\+w* \+w altar|strong="H4196"\+w*. \+w El|strong="H3605"\+w* \+w altar|strong="H4196"\+w* \+w será|strong="H1961"\+w* \+w santísimo|strong="H6944"\+w*.\wj*  
\v 11 \wj También \+w ungirás|strong="H4886"\+w* la \+w fuente|strong="H3595"\+w* y su basa y la consagrarás.\wj*   
