\id JHN - IKWERRE
\h Jọni
\toc1 Izi ọma lele kpa Jọni gbarụ a n'ọkwukwo
\toc2 Jọni
\toc3 Jọn
\mt2 Izi ọma lele kpa
\mt1 Jọni
\mt2 gbarụ a n'ọkwukwo
\imt1 Nhne gbasịri ọkwukwo ka
\im \bk Izi ọma lele kpa Jọni gbarụ a n'ọkwukwo\bk* gwehịaru Jizọsi iwhne lele Ikwu-Ọnu Chiokike, nye “ghọru badnụ, va wuru n'esilawụru aị” (1:14). Lele kpa ọkwukwo wam kwuru, be gbarụ izi ọma ka ma ele badnụ kweru nụ Jizọsi bụ Nye Ọznohia wam, Nnwọ Chiokike, hite n'ọkwnata mkpọma nụ rẹwhna a, be nwehịa bụdnu (20:31).
\ip Jọni mernu a mahịa nụ Jizọsi bụ Ikwu-Ọnu Chiokike. Ẹrnu ndu-ẹhni Jizọsi gesiri nụ ọ bụ Nye Ọznohia wam Chiokike kweru mkwna. Ọkwukwo ka gesiri nụ agwna ele badnụ kweru nụ Jizọsi ghọ ele sno apna a, kọvu ele berere kwéle nụ a, be bụru ele neemegidne Jizọsi dụ n'ẹnwu a.
\ip Jọni kwusiri nhne gbasịri nkesi bụdnu kwó okwo rikne hite nụ Karaịsi, nookwu nụ Jizọsi bụ apna, ezi ọka nụ bụdnu. Nụ ọkwukwo Jọni, a whnụrnu nụ nhne a nọowhnu anya kpakara ọbochi lele mini, brẹdi, iwhne, nye znụ atnụrnu nụ atnụrnu a, isisi nụ mkpụru a, neegesi nhne ke Enine.
\iot Nhne zị n'ọkwukwo ka
\io1 Ọpanizo \ior (1:1-18) \ior*
\io1 Jọni Nye Wụ Mini nụ ele sno apna Jizọsi mbọm \ior (1:19-51) \ior*
\io1 Ẹrnu Jizọsi nụ ọhna \ior (2:1---12:50) \ior*
\io1 Ọbochi ipne-aznụ nụ rime Jerusẹlem \ior (13:1---19:42) \ior*
\io1 Olizọ n'ẹnwu nụ ọwhuya iwhne Nyenwe aị \ior (20:1-31) \ior*
\io1 Ọ whụyaru iwhne nụ Galili \ior (21:1-25) \ior*
\ili1 \it Nye gbarụ ọkwukwo ka:\it* Jọni
\ili1 \it Risi nhne o kwno gba a:\it* Ma ele badnụ kweru nụ Jizọsi bụ Karaịsi wam, ma hite n'ọkwnata mkpọma nụ rẹwhna a, be nwehịa bụdnu.
\c 1
\s1 Ikwu-ọnu ke ghọru badnụ
\p 
\v 1 Nụ mbọm hne Ikwu-ọnu wam zị, Ikwu-ọnu wam nụ Chiokike zị nụ mbọm, Ikwu-ọnu wam bụ Chiokike.
\v 2 Ya nụ Chiokike zị nụ mbọm.
\p 
\v 3 Be keru kpakara nhne hite n'aka a, ọ zá nhne ke be keru hne ọ zị́la.
\v 4 Ikwu-ọnu wam bụ risi bụdnu, bụdnu wam bụ masị iwhne ke badnụ.
\v 5 Iwhne wam nọomu nụ rime ọchichiri, ọchichiri nwée rikne nwegidne a.\f + \fr 1:5 \fq nwée rikne nwegidne a: \ft mọbu \fq nwée rikne ghọhia a.\f*
\p 
\v 6 Chiokike ziyaru otu nyerukna rẹwhna a bụ Jọni.
\v 7 Jọni varụ lele nye akebne ke iwhne wam, ma kpakara ele nụrnu izi a kweru n'iwhne wam.
\v 8 Jọni bụ́o iwhne wam, kọvu ọ bụ nye akebne iwhne wam.
\v 9 Ka bụ iwhne wam n'ezi bụ ke varụ n'ọwa, ke neenye kpakara ele badnụ iwhne.
\p 
\v 10 Ikwu-ọnu wam zị n'ọwa, ọ bụ n'ezi nụ Chiokike keru ọwa hite nụ rime a, kọvu ọwa máa nye ọ bụ.
\v 11 Ọ vakwnusiri ele ke a, kọvu ele ke a nábnanyana a.
\v 12 Kọvu kpakara ele nabnanyarnụ a, kwerumakọ nụ rẹwhna a, o nyernu be rikne be bụru rụmu Chiokike.
\v 13 Be mụ́ge ele ka lele kpa be mụrnu ele badnụ. Be mụ́ge be hite n'echiche ke badnụ, mọbu hite nụ nda k'ọwa, kọvu Chiokike bụ Nda be.
\p 
\v 14 Ikwu-ọnu wam ghọru badnụ, va wuru n'esilawụru aị. A whnụrnu igwugwu a, bụ igwugwu ke Nnwọ Nda a mụrnu kpọi, oru nụ ezi ọka jihịaru nụ rime a.
\p 
\v 15 Jọni gbarụ akebne gbasịri a, siwama, kaa, “Ka bụ nye me nookwu ọka a nụ o snogwu m n'aznụ, kọvu ọ kakwo m, kwnornu nụ ọ zị sụ be mụrnu m.”
\p 
\v 16 Hite n'oru a zị agịda, a nwernu ngọzi tụkwasi nụ ngọzi.
\v 17 Chiokike hiri n'aka Mozizi nyee iwu, Chiokike nyee masịri oru nụ ezi ọka hite n'aka Jizọsi Karaịsi.
\v 18 Ọ zá nye whnụleru Chiokike anya. Nnwọ Nda a mụrnu kpọi, nye bụ Chiokike, nye zị n'akwankọ ke Nda a, mernu ele badnụ mahịa Nda a.
\s1 Jọni karụ nụ ọ bụ́o // Karaịsi
\r (Mat 3:1-12; Mak 1:1-8; Luk 3:1-18)
\p 
\v 19 Ka bụ akebne Jọni gbarụ nga ele risi ele Ju zị nụ Jerusẹlem ziznernu ele arịohna nụ ele Livaị be sịkwa a, “Ị bụ nyele?”
\p 
\v 20 Jọni sarụ be, ọ gọ́la ẹgo, kọvu o kwusiri a rikne, kaa, “M bụ́la m Karaịsi.”
\p 
\v 21 Be sịkwa a, “Ị bụ kọ nyele? Ị bụ Ẹlaija sa?”
\p Jọni kaa, “Ọ́za.”
\p Be sịkwa a, “Ị bụ Nye Ọwhnurninya wam?”\f + \fr 1:21 \fq Nye Ọwhnurninya wam: \ft Gwnụ Ditaronomi 18:15; Ẹrnu Ele Izi 3:22\f*
\p Ọ sarụ be, “Ọ́za.”
\p 
\v 22 Be kaa, “Kanụ aị nye ị bụ, ma a mahịa nhne a jaakanụ ele dusiri aị. Kịni bụ nhne i kwuru gbasịri ẹhni i?”
\p 
\v 23 Jọni sarụ be,
\q1 “M bụ m akpịri nye nọokpo okwo n'ẹli-ịkpa,
\q2 ‘Anụ mekwata apna Nyenwe aị ma ọ snịrni asnị,’
\m lele kpa Azaya nye ọwhnurninya kwuru.”
\p 
\v 24 Ele izi ele Farisi ziyaru,
\v 25 sịkwaru Jọni, “Ị bụ́o Karaịsi, mọbu Ẹlaija, mọbu Nye Ọwhnurninya wam, kịni mernu ị nọowu ele badnụ mini?”
\p 
\v 26 Jọni sarụ be, “M ji m mini nọowu ele badnụ mini, kọvu otu nyenum gwuzo n'esilawụru anụ, nye anụ máa.
\v 27 O snogwu m n'aznụ, kọvu m kwésile m ọ tọma eriri okoro-ọchi a.”
\p 
\v 28 Kpakara nhne ka mernu nụ Bẹtani n'ọbosi ẹhnam ke aznụ Osimini Jọdani kịyari, hne Jọni nọowu ele badnụ mini.
\s1 Jizọsi, Nnwọ // Atnụrnu Chiokike
\p 
\v 29 N'ekile a, Jọni whnụrnu Jizọsi hne o naavakwnusi a, ọ kaa, “Anụ le, ka bụ Nnwọ Atnụrnu ke Chiokike, nye noovume mmehie k'ọwa.
\v 30 Ka bụ nye wam me nookwu ọka nga me karụ, ‘Otu nyenum sno m n'aznụ, kọvu ọ kakwo m, kwnornu nụ ọ zị sụ be mụrnu m.’
\v 31 M máam nye ọ bụ, kọvu m nọowu ele badnụ mini ma ele Izirẹli mahịa nye ọ bụ.”
\p 
\v 32 Ka bụ akebne Jọni gbarụ, “M whnụrnu m Enine Nsọ hi n'oligwe lele nduru dnakwasị a, dazịri n'olu a.
\v 33 Kọvu nụ m máam nye ọ bụ. Chiokike nye ziyaru m me wụ ele badnụ mini kannụ m, ‘Ị jọowhnu Enine Nsọ hi n'oligwe dnakwasị otu badnụ dazịgidne nụ ya, nye wam bụ nye jeeji Enine Nsọ nọowu ele badnụ mini.’
\v 34 Me nụ iwhuru m whnụrnu a, gba akebne nụ nye ka bụ Nnwọ Chiokike.”
\s1 Ele mbọm sno // apna Jizọsi
\p 
\v 35 N'ekile a, Jọni nụ ele sno apna a lawụru gwuzo.
\v 36 Nga ọ whnụrnu Jizọsi hne o neewhe, ọ kaa, “Anụ le Nnwọ Atnụrnu ke Chiokike.”
\p 
\v 37 Ele sno apna a lawụru wam nụrnu a, be snornu Jizọsi.
\v 38 Jizọsi tụhnasnarnu whnụ nụ be noosno a n'aznụ, ọ sịkwa be, “Kịni bụ nhne anụ noopio?”
\p Be kaa, “Rabaị” (ke bụ, Nye-zni-nhne), “Ndaa hne i wu?”
\p 
\v 39 Jizọsi sarụ be, “Anụ va whnụrnu.” Ọ bụ nhne nụ lele ọtnu-ige ke ẹno n'iwhnehnie,\f + \fr 1:39 \fq Ọtnu-ige ke ẹno n'iwhnehnie: \ft ọkwukwo ke mbọm kwuru \fq ige nri awa\f* be snornu a zne whnụrnu hne o wu, be nụ a dazịri kpakara ọbochi wam.
\p 
\v 40 Otu nụ rime ele nụrnu nhne Jọni kwuru ke snornu Jizọsi bụ Anduru nwene rukna Saịmoni Pita.
\v 41 Ngangam, o piohịaru nwene a rukna, Saịmoni, ọ kanụ a, “A whnụna m Mezaya” (ke bụ Karaịsi).
\v 42 O kwuznenu Jizọsi Saịmoni.
\p Jizọsi legidne Pita anya kaa, “Ị bụ Saịmoni nnwọ Jọni, be jookwu i Kifasi,” be tụhnasna a, Pita, ke bụ rugwu.
\s1 Jizọsi sukwuru Filipu // nụ Natanẹli
\p 
\v 43 N'ekile a, Jizọsi kpebi o zne Galili, o piohịa Filipu, ọ kanụ a, “Snornu m zne.”
\p 
\v 44 Filipu, Anduru nụ Pita hi nụ ẹli Bẹtesaida.
\v 45 Filipu pohịa Natanẹli, ọ kanụ a, “A whnụrnu nye wam Mozizi nụ ele ọwhnurninya gbarụ nhne gbasịri a n'ọkwukwo nsọ, Jizọsi nye Nazarẹti, nnwọ Josefu.”
\p 
\v 46 Natanẹli sịkwa a, “Ẹli Nazarẹti, o nwernu nhne ọma ọbula ke jeehi n'ẹli Nazarẹti whụya?”
\p Filipu sarụ a, “Vaa, whnụrnu.”
\p 
\v 47 Nga Jizọsi whnụrnu Natanẹli naavakwnusi a, o kwu nhne gbasịri a, “Ka bụ nye Izirẹli n'ezi, nye aghịgho zị́la nụ rime a.”
\p 
\v 48 Natanẹli sịkwa a, “Nda kpa i jiri mahịa m?”
\p Jizọsi sarụ a, “M whnụrnu m jị nụ mkpururu isisi figi sụ Filipu sukwuru i.”
\p 
\v 49 Natanẹli sarụ a, “Nye-zni-nhne, ị bụ Nnwọ Chiokike. Ị bụ eze Izirẹli.”
\p 
\v 50 Jizọsi sịkwa a, “Ị kweruru kpọi kwnornu nụ m karụ m nụ m whnụrnu m jị nga ị zị mkpururu isisi be kwu figi? Ị jọowhnu nhne ke kakwo ka.”
\v 51 Ọ kanụ be, “Me kanụ anụ ezi ọka, anụ jọowhnu hne oligwe kpumernu, nụ ele enine izi Chiokike neepnezne, neehidna n'olu Nnwọ ke Badnụ.”
\c 2
\s1 Jizọsi mernu mini // ghọ manya
\p 
\v 1 N'ọbochi ke ẹto, ọlulu nnwerne zị n'ẹli Kana n'ẹli Galili, nne Jizọsi zị masị pịi.
\v 2 Be sukwuru Jizọsi nụ ele sno apna a n'ọlulu nnwerne wam.
\v 3 Nga manya be nọonwo kworu, nne Jizọsi kanụ a, “Be nwéma manya.”
\p 
\v 4 Jizọsi sarụ a, “Ọ gbásịla m, sị nwerinya. Ige m yóoduge.”
\p 
\v 5 Nne a kanụ ele neezne izi, “Anụ mee nhne ọbula ọ karụ anụ mee.”
\p 
\v 6 Idudu mini isunu gwuzo ndụndu be jiri rugwu kpụ, ke ele Ju ji nọosnu nhne lele kpa omen'ẹli be jiri zịri, ke otu jeeri nri lawụru mọbu nri ẹto galọni mini.
\v 7 Jizọsi kanụ ele neezne izi, “Anụ gbajite be nụ mini.” Be gbaji be mini dụ n'ọnu be.
\p 
\v 8 Ọ kanụ be, “Anụ kwuhịa agwna mini wam gweznenu nye risi ngadna iriri.”
\p Be gweznenu a.
\v 9 O detụ mini wam ke ghọru manya riro. Ọ máa hne manya wam hi, kọvu ele neezne izi ele gbarụ mini wam magwụ. O sukwu nye nọolu nnwerne,
\v 10 ọ kanụ a, “Nye ọbula neekesi manya kakpa mma n'ọziri, nga ele izne nwọkparu manya, o ke manya ọjo. Kọvu ị bịtaru manya kakpa mma dụ kịtna.”
\v 11 Ka bụ ẹrnu ndu-ẹhni mbọm Jizọsi rnụrnu. Ọ rnụrnu a nụ Kana n'ẹli Galili, o gesi igwugwu a, ele sno apna a kwnata a mkpọma.
\p 
\v 12 Nga ka whemernu, Jizọsi nụ nne a, nụ rụmu nne a, nụ ele sno apna a zne Kapanọm, be dazịri pịi ọbochi ele nụ ele.
\s1 Nhne Jizọsi mernu // n'Ọro Nsọ Chiokike
\r (Mat 21:12,13; Mak 11:15-17; Luk 19:45,46)
\p 
\v 13 Iriri Ọgawhe ele Ju zị ndụndu, Jizọsi zne Jerusẹlem.
\v 14 Ọ whnụrnu ele neere atnụrnu nụ ehni nụ nduru nụ ele naagbanwo ịwai dazịgwu n'ikpechi n'Ọro Nsọ Chiokike.
\v 15 O gweru eriri mee mbịnibini, chịhala kpakara be, ma ehni ma atnụrnu. O kpute ikpechi kpakara ele naagbanwo ịwai ruwhnu n'ẹli, chịsakwo ịwai be.
\v 16 Ọ kanụ ele neere nduru, “Anụ whọga hna, anụ méma ọro Nda m ọro ahịa.”
\p 
\v 17 Ele sno apna a chenwanya nhne be gbarụ n'ọkwukwo nsọ, “Nhne gbasịri Ọro Nsọ Chiokike neerne lele bẹkwnu nụ rime m.”
\p 
\v 18 Ele Ju sịkwa a, “Ndaa ẹrnu ndu-ẹhni ke ị jọornu ke neegesi nụ ị nwernu rikne mee nhne i neeme?”
\p 
\v 19 Jizọsi sarụ be, “Anụ kwnadna Ọro Nsọ ka, m joowulizọ a n'ọbochi ẹto daị.”
\p 
\v 20 Ele Ju sarụ a, “Be jiri nri awha ẹno nụ isunu wu Ọro Nsọ ka, i joowu a n'ọbochi ẹto?”
\v 21 Kọvu Jizọsi kwuru ọka gbasịri ẹhni a lele Ọro Nsọ Chiokike.
\v 22 Nga Jizọsi hiri n'ẹnwu lizọ, ele sno apna a chenwanya nụ o kwuru ọka ka, be kweru nhne ọkwukwo nsọ kwuru nụ nhne Jizọsi kwuru.
\p 
\v 23 Kpa Jizọsi zị nụ Jerusẹlem nụ Iriri Ọgawhe, agịda ele badnụ kweru nụ ya kpa be whnụrnu agịda ẹrnu ndu-ẹhni ọ nọornu.
\v 24 Kọvu Jizọsi kwéle o nyee be ẹhni a, kwnornu nụ ọ magwụ kpakara badnụ nkarị nkarị.
\v 25 Ọ zị́la mkpa nụ be kanụ a nhne gbasịri nye ọbula, kwnornu nụ o magwụ nhne zị nụ mkpọma be.
\c 3
\s1 Jizọsi nụ Nikodimọsi
\p 
\v 1 Otu nwerukna be kwu Nikodimọsi, otu nụ rime ele Farisi, nye risi ele Ju,
\v 2 vakwnusiri Jizọsi n'abalị. Ọ kaa, “Rabaị, a magwụ nụ ị bụ Nye-zni-nhne ke Chiokike ziyaru, kwnornu nụ ọ zá nye jọornuli ẹrnu ndu-ẹhni ị nọornu okwolem ma Chiokike dagwụnu a.”
\p 
\v 3 Jizọsi sarụ, “Me kanụ ị ezi ọka, ọ zá nye jọowhnu n'ẹli-eze Chiokike anya, ọ bụru nụ be mụ́gele a berere.”\f + \fr 3:3 \fq be mụ́gele a berere: \ft mọbu \fq be mụ́gele a hite n'oligwe.\f*
\p 
\v 4 Nikodimọsi sịkwa a, “Ndaa kpa be jọomu badnụ berere nga o mernu okno badnụ? Ọ jaabna nụ rụwho nne a berere, be mụ a?”
\p 
\v 5 Jizọsi sarụ a, “Me kanụ ị ezi ọka, ọ zá nye jaabna n'ẹli-eze Chiokike ọ bụru nụ be mụ́gele a hite nụ mini nụ Enine.
\v 6 Nye ke badnụ etekne mụrnu bụ anọ-ẹhni, nye Enine mụrnu bụ enine.
\v 7 Ọ gbágwoji ị anya nụ m karụ m nụ be jọomuriri anụ berere.
\v 8 Ruwhere neewhe hne ọ masịgwu a, ị nọonu imerne a, kọvu ị máa hne o hi mọbu hne o neezne. Nye ọbula ke be mụrnu hite n'Enine nụ kpam.”
\p 
\v 9 Nikodimọsi sịkwa a, “Ndaa kpa be jeeme nhne nụ kpa?”
\p 
\v 10 Jizọsi sarụ a, “Ị bụ nye-zni-nhne n'ẹli Izirẹli, kọvu ị máa nhne ka.
\v 11 Me kanụ ị ezi ọka, a nookwu nhne a magwụ, a naagba akebne nhne ke a whnụrnu, kọvu anụ kwé ọ nahọru akebne aị.
\v 12 Anụ kwé nhne me kwuru gbasịri nhne k'ọwa. Ndaa kpa anụ jeekweru ọ bụru me kanụ anụ nhne k'oligwe?
\v 13 Ọ zá badnụ ọbula ke znernu oligwe nụ mbọm, okwolem Nnwọ ke Badnụ nye hiri n'oligwe hiedna.
\v 14 Lele kpa Mozizi gwelizọru agwọ n'olu isisi n'ẹli chna chna chna, ọ bụ kpa be jeegwelizọ Nnwọ ke Badnụ olu,
\v 15 ma nye ọbula ke kweru nụ ya jeenwe bụdnu kwó okwo.
\v 16 Kwnornu nụ Chiokike whnụrnu ọwa n'anya kpa, o gweru Nnwọ ọ mụrnu ya nụ nsnụnu a kpọi nyega, ma nye ọbula ke kweru nụ ya jọ́onwu ẹnwu, kọvu o jeenwe bụdnu kwó okwo.
\v 17 Kwnornu nụ Chiokike zíyage Nnwọ a n'ọwa ọ bụru nye kpe k'ọwa, kọvu ma ọ bụru Nye Ọznohia k'ọwa.
\v 18 Be jéekpe nye ọbula ke kweru nụ Nnwọ wam ikpe, kọvu nye ọbula ke kwége bụ nye be kperu ikpe, kwnornu nụ o kwége nụ Nnwọ Chiokike mụrnu ya nụ nsnụnu a.
\v 19 Ka bụ ikpe wam be kperu ọwa, iwhne varụ n'ọwa, ele badnụ whnụrnu ọchichiri n'anya karụ iwhne, kwnornu nụ be nọornu ẹrnu ọjo.
\v 20 Nye ọbula ke nọornu ẹrnu ọjo bụ nye irno ke iwhne, ọ jáava nụ rime iwhne ọ zị iwhne kpume ẹrnu ọjo a.
\v 21 Kọvu nye ọbula ke nọornu ẹrnu ọma jaava nụ rime iwhne ma iwhne gesi nụ ẹrnu a bụ nhne ọ rnụrnu hite nụ Chiokike.”
\s1 Jizọsi nụ Jọni // Nye Wụ Mini
\p 
\v 22 Nga ka mekworu, Jizọsi nụ ele sno apna a znernu n'ẹli Judiya, ya nụ be dazịri ige matị, ọ wụ ele badnụ mini.
\v 23 Jọni masị zị nọowu mini n'Enọni ke zị Salịm ndụndu, kwnornu nụ agịda mini zị pịi. Ele badnụ neeznekwnusi a, ọ nọowu be mini.
\v 24 (Be yéeyisige Jọni n'ọro ikelu n'ige ka.)
\v 25 Agwna ele sno apna Jọni nụ otu nye Ju nọodogbuta nhne gbasịri ọsnusnu nhne lele kpa omen'ẹli ele Ju jiri zịri.
\v 26 Be vakwnusi Jọni kanụ a, “Nye-zni-nhne, nwerukna wam jị nụ a zị n'aznụ Osimini Jọdani kịyari, nye ị gbarụ akebne gbasịri a, ọ nọowu ele badnụ mini, agịda ele badnụ neeznekwnusi a.”
\p 
\v 27 Jọni sarụ be, “Ọ zá nye ọbula ke jeenwe nhne ke Chiokike késile a.
\v 28 Anụ bụ ele akebne m nụ m karụ m, ‘M bụ́o m Karaịsi, kọvu be beru ọsno ziya m nụ ruwhnu a.’
\v 29 Nye nọolu nnwerne ikne bụ nye nwe nnwerne ikne, kọvu enyi nye noolu nnwerne ikne, nye noogwuzo noobno nsnị, mkpọma nọoso a n'ọnu nụ ọ nụrnu nkọli nye wam nọolu nnwerne ikne. Ọ bụ kpa snarnịma m jiri zu ozu kịtna.
\v 30 Ọ jaazị naaba aba, kpa me jaazị naaya ẹli ẹli.”
\s1 Nye ke hiri n'oligwe va
\p 
\v 31 Nye wam ke hiri n'oligwe va kakwo kpakara badnụ, nye hi n'ọwa bụ nye ke ọwa, o nookwu nhne ke ọwa. Nye hiri n'oligwe kakwo kpakara badnụ.
\v 32 O nookwu nhne ọ whnụrnu nụ nhne ọ nụrnu, kọvu ọ zá nye neekweru izi a.
\v 33 Nye ọbula ke jeegweru izi a naakahịa nụ Chiokike bụ nye ezi ọka.
\v 34 Nye Chiokike ziyaru nookwu ikwu-ọnu Chiokike, kwnornu nụ Chiokike nyéne a Enine a n'apna zị matị.
\v 35 Nda whnụrnu Nnwọ a n'anya, gweru kpakara nhne yisi n'aka a.
\v 36 Nye ọbula ke kweru nụ Nnwọ wam nwernu bụdnu kwó okwo, nye ọbula ke zá noobnonu Nnwọ wam nsnị, jéenwe bụdnu, kọvu ovu owe ẹhni Chiokike jaazị nụ risi a ọkwnukokwnu.
\c 4
\s1 Jizọsi nụ nwerinya // Sameria
\p 
\v 1 Ele Farisi nụrnu nụ Jizọsi neewehịa ele sno apna a, nọowu be mini karụ Jọni,
\v 2 ọ bụ n'ezi nụ Jizọsi wụ́ge ele badnụ mini, kwolem ele sno apna a.
\v 3 Nga Jizọsi nụrnu a, ọ whụya nụ Judiya naalahna Galili.
\p 
\v 4 Ọ zị mkpa nụ ọ jaagawhe n'esilawụru ẹli Sameria.
\v 5 Ọ vadu n'otu ẹli-ọhna Sameria be kwu Saịka, ke zị ndụndu otu ẹli Jekọpu nyernu nnwọ a rukna Josefu.
\v 6 Ọmi Jekọpu zị pịi. Inwe gwụru Jizọsi kwnornu nụ izne wam, ọ dazịri ẹli nụ ngeri ọmi wam n'iwhnehnie.\f + \fr 4:6 \fq n'iwhnehnie: \ft ọkwukwo ke mbọm kwuru \fq ọtnu-ige ke isunu\f*
\p 
\v 7 Otu nwerinya Sameria varụ ọ tụru mini n'ọmi, Jizọsi kanụ a, “Kesi m mini.”
\v 8 (Ele sno apna a znernu nụ rime ẹli-ọhna ọ zụ wiri.)
\p 
\v 9 Nwerinya Sameria wam kanụ a, “Ị bụ nye Ju, m bụ m nye Sameria, ndaa kpa ị nọorio m mini?” (Ele Ju nụ ele Sameria mékọta nhne.)
\p 
\v 10 Jizọsi sarụ a, “Ọ bụru nụ ị magwụ nkesi Chiokike, nụ nye ke nọorio ị mini, ị jọorio a ma o kesi i mini ke bụdnu.”
\p 
\v 11 Nwerinya wam kaa, “Nda-aị-kwu, i nwée nhne i jeeji nọotu mini, ọmi ka miri emi k'agịda, ndaa hne i jeegwehịa mini bụdnu ka.
\v 12 Ị kakwo nda aị Jekọpu nye nyernu aị ọmi ka, ọ nwọrnu mini hi nụ rime a, ma rụmu a, ma rụmu anọhia a?”
\p 
\v 13 Jizọsi sarụ a, “Nye ọbula ke jọonwo mini ke hi n'ọmi ka, akpịri jọokpo a bẹkwnu berere,
\v 14 kọvu nye ọbula ke jọonwo mini ke me jeenye a, akpịri jọ́okpo a bẹkwnu berere. Mini ke me jeenye a jọogho risi mini ke jaagba dụ bụdnu kwó okwo.”
\p 
\v 15 Nwerinya wam kaa, “Nda-aị-kwu, kesi m mini ka ma akpịri gharụ ọ kpọ m bẹkwnu, ma m gharụ m ọ va ọ tụ mini n'ọmi ka.”
\p 
\v 16 Jizọsi kanụ a, “Zne, sukwu nzi i, va hna.”
\p 
\v 17 Nwerinya wam kaa, “M nwée m nzi.”
\p Jizọsi kanụ a, “I kwukwaru nkarị nụ i nwée nzi,
\v 18 kwnornu nụ ị gbọlam nzi isne, nye ke jị nụ a wu kịtna bụ́o nzi ị. I kwuru ezi ọka nụ i nwée nzi.”
\p 
\v 19 Nwerinya wam kaa, “Nda aị-kwu, m whnụrnu nụ ị bụ nye ọwhnurninya.
\v 20 Ele nda aị kpọru risi ẹli n'olu rugwu ka, kọvu anụ ele Ju karụ nụ hne be kwesiri ọ kpọ risi ẹli bụ nụ Jerusẹlem.”
\p 
\v 21 Jizọsi kanụ a, “Nwerinya, kweru nhne me naakanụ ị, ige vawa nga ele badnụ jọ́okponu Nda risi ẹli n'olu rugwu ka mọbu nụ Jerusẹlem.
\v 22 Anụ ele Sameria máa nye anụ nọokponu risi ẹli, aị ele Ju magwụ nye a nọokponu risi ẹli, kwnornu nụ ọznohia hi n'aka ele Ju va.
\v 23 Kọvu ige vawa, owe, ige wam valẹm masị, nga ele nọokponu Nda risi n'ẹli n'ezi jọokponu a risi ẹli n'enine nụ n'ezi ọka. Ka bụ ele Nda pioru kpọnu a risi ẹli.
\v 24 Chiokike bụ enine, ele nọokponu a risi ẹli jọokporirinu a risi ẹli n'enine nụ n'ezi ọka.”
\p 
\v 25 Nwerinya wam kanụ a, “M maam nụ Mezaya, nye be kwu Karaịsi, jaava. Nga ọ varụ, ọ jaakanụ aị kpakara nhne.”
\p 
\v 26 Jizọsi kanụ a, “Me nye nookwunu ị ọka, bụ ya.”
\v 27 Ige wam ele sno apna Jizọsi hiehna, o jiri be anya nụ ya nụ nyerinya nookwurita ọka. Kọvu ọ zá nye sịkwaru, “Kịni bụ nhne i noopio?” mọbu, “Kịni mernu i nookwunu nwerinya ka ọka?”
\p 
\v 28 Nwerinya wam sịgbasi idudu mini a, lahna nụ rime ẹli-ọhna, kanụ ele badnụ,
\v 29 “Anụ va whnụrnu nwerukna ke kannụ m kpakara nhne me mernu. Nye ka ọ jọoburu Karaịsi sa?”
\v 30 Be gbahala nụ rime ẹli-ọhna znekwnusi Jizọsi.
\p 
\v 31 Kọvu ele sno apna a zị naarịasno Jizọsi, kaa, “Nye-zni-nhne, ri wiri.”
\p 
\v 32 Jizọsi kanụ be, “M nwernu m wiri ke anụ máa.”
\p 
\v 33 Ele sno apna a nẹesikwarita ẹhni be, “O nwernu nye gweyannụ a wiri sa?”
\p 
\v 34 Jizọsi kanụ be, “Wiri m bụ ọ bịta echiche nye ziyaru m nụ ọ rnụkpa ẹrnu o nyernu m.
\v 35 Anụ naakaa, ‘Ọ gwnarnụ ẹnwa ẹno, anụ gwe nhne n'ẹkwu.’ Kọvu me kanụ anụ, anụ le anya n'ẹkwu, mkpụru chnanam ma be ghọru nhne n'ẹkwu.
\v 36 Nye neegwe nhne n'ẹkwu nwernu ọgwo ẹrnu, ọ chịbna ele badnụ lele mkpụru ma be nwehịa bụdnu kwó okwo. Kpam, nye ke kparụ mkpụru nụ nye ke gweru nhne n'ẹkwu jeenwekọta snarnịma.
\v 37 Nhne be kwuru bụ ezi ọka, ‘Otu badnụ kpasịri mkpụru, nye berere ghọru mkpụru.’
\v 38 M ziznernu m anụ ghọru mkpụru n'ẹkwu ke anụ rnụ́ge ẹrnu nụ rime a. Ele berere rnụrnu ẹrnu, anụ nwehịa mbnarna n'ẹrnu be.”
\p 
\v 39 Agịda ele Sameria ele wu nụ rime ẹli-ọhna wam kweru nụ Jizọsi kwnornu nụ nhne nwerinya wam kwuru, “Ọ kanụ m kpakara nhne me mernu.”
\v 40 Nga ele Sameria vakwnusiri a, be rịasno a ma ya nụ be dazịri, Jizọsi dazịri pịi ọbochi lawụru.
\v 41 Agịda ele berere kweru kwnornu nụ izi ọma o znirni be.
\p 
\v 42 Be kanụ nwerinya wam, “A kweru kịtna, ọ bụ́o nụ nhne i kannụ aị, kọvu kwnornu nụ a nụrnu nhne o kwuru, a magwụ nụ nye ka bụ Nye Ọznohia ke ọwa n'ezi.”
\s1 Jizọsi gwọru nnwọ // rukna nye risi
\p 
\v 43 Nga ọbochi lawụru wam whemernu, ọ whọga pịi zne Galili.
\v 44 Jizọsi n'iwhuru a karụ, “Nye ọwhnurninya nwée igwugwu n'ẹli a.”
\v 45 Nga ọ vaduru ẹli Galili, ele zị nụ Galili naakweru a kwnornu nụ be znernu Iriri Ọgawhe nụ Jerusẹlem, be whnụrnu kpakara nhne o mernu n'Iriri Ọgawhe wam.
\p 
\v 46 Jizọsi lahna nụ Kana ke Galili hne o mernu mini ghọ manya. Otu nye risi ọchichi ke nnwọ a rukna zị n'ẹhni igbugbu nụ Kapanọm.
\v 47 Nga ọ nụrnu nụ Jizọsi hiri nụ Judiya va Galili, o znekwnusi a, kanụ a, ọ va gwọ nnwọ a rukna ẹhni igbugbu, nye zị n'ọnu ẹnwu.
\p 
\v 48 Jizọsi kanụ a, “Anụ jéekweru kwekọlam ma anụ whnụrnu ẹrnu ndu-ẹhni nụ ẹrnu rikne.”
\p 
\v 49 Nwerukna wam kaa, “Nda-aị-kwu, snornu m zne, ọ zị nnwọ m nwụ.”
\p 
\v 50 Jizọsi kanụ a, “La, nnwọ ị rukna zị bụdnu.”
\p Nwerukna wam kweru nhne Jizọsi kanụ a, la.
\v 51 Nga ọ zị n'apna, ele izi a kwnusi a, kanụ a, “Nnwọ ị rukna zị bụdnu.”
\v 52 Ọ sịkwa be ige ẹhni bụru nnwọ a rukna ọma, be kanụ a, “N'ọtnu-ige ke mbọm n'iwhnehnie\f + \fr 4:52 \fq Ọtnu-ige ke mbọm n'iwhnehnie: \ft ọkwukwo ke mbọm kwuru \fq ige awa ke ẹsau\f* n'ekile wheru ewhe, ẹhni orne bẹkwnu wam sịgbasiri a.”
\p 
\v 53 Nda nnwọ wam chenwanya nụ ọ bụ ige wam Jizọsi kannụ a, “Nnwọ ị rukna zị bụdnu.” Kam kpayarụ, ya nụ kpakara ele ọro a kweru.
\p 
\v 54 Ka bụ ẹrnu ndu-ẹhni ke ẹbo Jizọsi rnụrnu nga o hiri nụ Judiya va Galili.
\c 5
\s1 Ọgwugwo n'Olulu Mini // Bẹtisaida
\p 
\v 1 Nga ka whemernu, Jizọsi znernu iriri ele Ju nụ Jerusẹlem.
\v 2 Otu olulu mini zị ngeri Ọnu-Mgbo Atnụrnu nụ Jerusẹlem ke nwernu mgbemgbe ọro isne, ke ele Hiburu nookwu Bẹtizata.
\v 3 Agịda ele nrịria naadnanyị nụ ngeri a, ele isni, nụ ele mgwọro, nụ ele ngeri ẹhni be dọnwurnu ọdonwu. [Be zị neese ma be gbarụ mini wam.
\v 4 Kwnornu nụ enine izi Nyenwe aị neehiedna hite n'ige dụ n'ige gbarụ mini wam. Nye nrịria ọbula ke beru ọsno dnabna nụ rime mini wam nga enine izi gbarụkparu a, ẹhni a jọoburu ọma hite nụ nrịria ọbula ọ naarịa.]
\v 5 Otu nwerukna ke naarịa nrịria nri awha ẹto nụ ẹsato zị pịi.
\v 6 Nga Jizọsi whnụrnu a hne ọ dnanyị, ọ mahịaru nụ ọ zị nụ nrịria gbu ọkwnu, ọ sịkwa a, “Ị pioru be gwọ ị nrịria ị?”
\p 
\v 7 Nye nrịria wam sarụ a, “Nda-aị-kwu, m nwée m nye jeeyisi m nụ rime olulu mini nga be gbarụru mini, kpa me neezne, nye berere beru m ọsno dnabna.”
\p 
\v 8 Jizọsi kanụ a, “Lizọ, chịri etere i, zne izne.”
\v 9 Ngangam, be gwọru nwerukna wam. Ọ chịri etere a, zne izne.
\p Nhne ka mernu n'Ọbochi Ozukwa Inwe.
\v 10 Ka mernu ele Ju kanụ nwerukna wam Jizọsi gwọru nrịria, “Tna bụ Ọbochi Ozukwa Inwe, o megidnernu n'iwu nụ ị nẹechiri etere ị.”
\p 
\v 11 Nwerukna wam sarụ be, “Nwerukna ke gwọru m nrịria kannụ m, ‘Chịri etere i, zne izne.’ ”
\p 
\v 12 Be sịkwa a, “Nyele bụ nye ke karụ jị chịri etere i zne izne?”
\p 
\v 13 Kọvu nụ nwerukna wam be gwọru máa nye Jizọsi bụ, kwnornu nụ Jizọsi bnanam n'esilawụru igbudu badnụ wam whọga.
\p 
\v 14 Omekwo, Jizọsi piohịaru a n'Ọro Nsọ Chiokike, ọ kanụ a, “Le, be gwọru ị nrịria ị, i méma mmehie, ọ zị nhne ọjo ke kakwo ka dnakwasị ị.”
\v 15 Nwerukna wam whọga kanụ ele risi ele Ju nụ ọ bụ Jizọsi gwọru a nrịria a.
\s1 Bụdnu hi nụ Nnwọ // Chiokike
\p 
\v 16 Ele Ju bete o mekpa Jizọsi ẹhni kwnornu nụ ọ gwọru nrịria n'Ọbochi Ozukwa Inwe.
\v 17 Jizọsi kanụ be, “Nda m nọornu ẹrnu kpakara ige, ọ bụ masị kpa me nọornu.”
\v 18 Ikwu-ọnu ka mernu ele risi ele Ju ovu owe ẹhni k'agịda, be noopiosi rikne o gbu Jizọsi, ọ bụ́o nụ o luluru Ọbochi Ozukwa Inwe be kpọi, kọvu nụ ọ karụ nụ Chiokike bụ Nda a, naakaa nụ ya nụ Chiokike hna n'otu.
\p 
\v 19 Jizọsi kanụ be, “Me kanụ ezi ọka, ọ zá nhne ke Nnwọ nwernu rikne o mee n'ẹhni a, kọvu o neeme nhne ọ whnụrnu Nda a neeme. Kwnornu nụ Nnwọ nọornu nhne Nda a nọornu.
\v 20 Nda whnụrnu Nnwọ a n'anya, neegesi a kpakara nhne o neeme. O jeegesi a nhne ke kakwo ka ke jaagbagwoji anụ anya.
\v 21 Lele kpa Nda neeme ele nwụrnu ọnwu hi n'ẹnwu lizọ, nyee be bụdnu, ọ bụ masị kpa Nnwọ neenye ele masịri a bụdnu.
\v 22 Nda zá neekpe nye ọbula ikpe, kọvu o yisiri kpakara ikpe n'aka Nnwọ a,
\v 23 ma kpakara ele badnụ sọbisinu Nnwọ a lele kpa be nọosobisinu Nda. Nye ọbula ke zá nọosobisinu Nnwọ, zá nọosobisinu Nda nye ziyaru a.
\p 
\v 24 “Me kanụ anụ ezi ọka, nye ọbula ke nọonu ikwu-ọnu m kweru nụ nye wam ke ziyaru m, nwernu bụdnu kwó okwo. Be jáama a ikpe, kọvu o hilem n'ẹnwu whe nụ bụdnu.
\v 25 Me kanụ anụ ezi ọka, ige vawa, ige wam valẹm masị, nga ele nwụrnu ọnwu jọonu nkọli ke Nnwọ Chiokike, ele nụrnu a jaazị bụdnu.
\v 26 Kwnornu lele kpa Nda nwernu bụdnu nụ rime a, ọ bụ masị kpa o mernu Nnwọ nwernu bụdnu nụ rime a.
\v 27 O nyernu Nnwọ rikne o kpe ikpe, kwnornu nụ ọ bụ Nnwọ ke Badnụ.
\p 
\v 28 “Ọ gbágwoji anụ anya nụ ige vawa, nga ele zị n'ilili jọonu nkọli a,
\v 29 be jeehi n'ilili lizọ, ele mernu mma jeelizọ n'ẹnwu zịri bụdnu, ele mmehie jeelizọ n'ẹnwu bụru ele be jaama ikpe.
\p 
\v 30 “M nwée m rikne mee nhne ọbula nụ rikne ke aka m. M neekpe ikpe kpa Nda m kannụ m me kpe. Ka neegesi nụ ikpe m zị snam, kwnornu nụ m zá neeme nhne me pioru, kọvu kwekọlam nhne nye ziyaru m pioru.
\s1 Akebne gbasịri Jizọsi
\p 
\v 31 “Ọ bụru nụ me naagbanụ ẹhni m akebne, akebne m bụ́o ezi.
\v 32 Kọvu ọ zị nye naagbanụ m akebne, m magwụ m nụ akebne a zị kwem.
\v 33 Anụ ziznernu ele izi znekwnusi Jọni, o kwuru nhne gbasịri ezi ọka.
\v 34 Ka zá neegesi nụ m neegweru akebne ke badnụ, m nookwu nhne ka ma anụ nwehịa ọznohia.
\v 35 Jọni nụ lele tọnji ke noonwu, nọomuke, anụ kpebiri ọ nwụdna ige matị n'iwhne a.
\p 
\v 36 “M nwernu m nhne akebne ke kakwo akebne Jọni gbarụ. M nọornu ẹrnu ke Nda m nyernu m, ẹrnu wam naagbanụ m akebne, neegesi nụ Nda m ziyaru m.
\v 37 Nda m nye ziyaru m naagbanụ m akebne. Anụ nụ́lele nkọli a mọbu whnụ ruwhnu a.
\v 38 Anụ zá naabịta ikwu-ọnu a nụ mkpọma anụ, kwnornu nụ anụ kwéle nụ nye wam o ziyaru.
\v 39 Anụ tụsa ẹhni nyosna nhne be gbarụ n'ọkwukwo nsọ anụ, anụ neeche nụ anụ jeenwe bụdnu kwó okwo hite nụ nhne be gbarụ nụ rime a, be naagbanụ m akebne.
\v 40 Kọvu anụ kwé ọ vakwnusi m, ma anụ nwehịa bụdnu kwó okwo.
\p 
\v 41 “M zá m nanarnụ ọznarni hite n'aka badnụ.
\v 42 M magwụ m anụ, anụ nwée ọwhnun'anya Chiokike nụ mkpọma anụ.
\v 43 M ji m rẹwhna Nda m va, anụ kwége m, kọvu ọ bụru nụ nye berere jiri rẹwhna a va, anụ jeegweru a.
\v 44 Ndaa kpa anụ jeekwe, hne anụ noopio ọznarni ke badnụ, kọvu anụ nwée rikne pio ọznarni ke hi n'aka nye ke bụ Chiokike kpọi va.
\p 
\v 45 “Anụ chékọ nụ m joobno anụ nhne nụ ruwhnu Nda m. Kọvu ọ bụ Mozizi nye anụ kwnatarụ mkpọma, joobno anụ nhne.
\v 46 Ọ bụru nụ anụ kweruru Mozizi n'ezi, anụ jeekweru m, kwnornu nụ ọ gbarụ nhne gbasịri m.
\v 47 Kọvu hne anụ kwége nhne Mozizi gbarụ n'ọkwukwo nsọ, ndaa kpa anụ jeekweru nhne me nookwu?”
\c 6
\s1 Jizọsi nyernu pokwu // badnụ isne wiri
\r (Mat 14:13-21; Mak 6:30-44; Luk 9:10-17)
\p 
\v 1 Nga ka mekworu, Jizọsi whe aznụ Osimini Galili (ka bụ Osimini Taberasị).
\v 2 Agịda ele badnụ snornu a, kwnornu nụ be whnụrnu ẹrnu ndu-ẹhni ọ rnụrnu, nga ọ gwọru ele nrịria.
\v 3 Jizọsi pnezne n'olu rugwu dazịri ẹli, ya nụ ele sno apna a.
\v 4 Ige Iriri Ọgawhe ele Ju zị ndụndu.
\p 
\v 5 Nga Jizọsi lehnatarụ anya whnụ agịda ele badnụ naavakwnusi a, ọ kanụ Filipu, “Ndaa hne a jọozuya wiri a jeenye igbudu ele ka?”
\v 6 Ka bụ ma ọ kpa Filipu iru, kwnornu nụ ọ magwụ nhne o jeeme.
\p 
\v 7 Filipu sarụ a, “Ọ bụru nụ a zụ brẹdi riwhu mkpụru ịwai lawụru, o jéezu ma nye ọbula ri matị matị.”
\v 8 Otu nụ rime ele sno apna a, Anduru, nwene rukna Saịmoni Pita, kaa,
\v 9 “Otu wikoro matị zị hna nye ji ike brẹdi balị\f + \fr 6:9 \fq balị \ft Ka bụ ịkpa be ji neeme brẹdi.\f* isne nụ aznụ matị matị lawụru. Ọ zá nhne kam bụ n'esilawụru igbudu ele badnụ ka.”
\p 
\v 10 Jizọsi kanụ be, “Anụ kanụ be dazịri ẹli.” Agịda achara zị pịi. Kpakara ele badnụ wam dazịri ẹli, be hna lele pokwu ele rukna isne.
\v 11 Jizọsi gweru brẹdi wam, tụ mmamma, nyee kpakara ele wam dazịgwu ẹli. O gweru aznụ wam mee kwno kpam. Be ri, riji rụwho be.
\p 
\v 12 Nga be rikworu, Jizọsi kanụ ele sno apna a, “Anụ tụtukota kpakara rụvnuruvnu ke gwnarnụ, ọ zá ke whu.”
\v 13 Be tụtukota kpakara rụvnuruvnu a, ke jiri nri nụ nkịta lawụru hite n'ike brẹdi balị isne wam ke ele badnụ riri.
\p 
\v 14 Ele zị nga Jizọsi rnụrnu ẹrnu ndu-ẹhni ka karụ, “N'ezi ọka, ka bụ nye ọwhnurninya wam ke jaava n'ọwa.”
\v 15 Nga Jizọsi whnụru nụ be noopio o chni a eze nụ rikne, o hi n'esilawụru be whọga, ya nụ nsnụnu a zne n'olu rugwu.
\s1 Jizọsi znernu izne // n'olu mini
\r (Mat 14:22,33; Mak 6:45-52)
\p 
\v 16 N'ogbednachi, ele sno apna a zne osimini.
\v 17 Be bna n'ọgbo neewhe aznụ osimini kịyari neezne Kapanọm. Jizọsi yáavage hne be zị tem dụ n'abalị.
\v 18 Okne ruwhere nụ abaka-mini neewhe n'olu mini.
\v 19 Ele sno apna a kwọ ọgbo nhne nụ lele maịli ẹto mọbu ẹno nga be whnụrnu Jizọsi naavakwnusi be, neezne izne n'olu mini. Be tụ ogwnu k'agịda.
\v 20 Kọvu Jizọsi kanụ be, “Anụ tụ́ko ogwnu, ọ bụ mawa.”
\v 21 Be kweru a, ọ bnakwnusi be nụ rime ọgbo, ngangam ọgbo be dụ n'ẹli wam be neezne.
\s1 Ele badnụ noopio Jizọsi
\p 
\v 22 N'ekile a, agịda ele badnụ ele zị n'aznụ osimini kịyari mahịaru nụ otu ọgbo matị zị pịi whọgalam vuru ele sno apna Jizọsi kpọi. Jizọsi snóge be.
\v 23 Ọgbo ele ke berere hiri nụ Taberasị va nụ ngeri hne ele badnụ wam riri brẹdi, nga Nyenwe aị tụkparu mmamma.
\v 24 Nga ele badnụ wam whnụrnu nụ Jizọsi zị́la pịi, ma ele sno apna a, be bna n'ọgbo wam zne Kapanọm noopio Jizọsi.
\s1 Jizọsi bụ Wiri ke Bụdnu
\p 
\v 25 Nga ele badnụ wam whnụrnu a n'aznụ osimini kịyari, be sịkwa a, “Nye-zni-nhne, ndaa nga ị varụ hna?”
\p 
\v 26 Jizọsi sarụ be, “Me kanụ anụ ezi ọka, anụ noopio m kwnornu nụ anụ rijiri rụwho nụ brẹdi me nyernu anụ, ọ bụ́o kwnornu nụ anụ whnụrnu ẹrnu ndu-ẹhni.
\v 27 Anụ dọ́gbu ẹhni anụ n'ẹrnu kwnornu nụ wiri ke nooro oro, tnụnuma, anụ dọgbu ẹhni anụ n'ẹrnu kwnornu nụ wiri ke jaazị tem dụ bụdnu kwó okwo, ke Nnwọ ke Badnụ neenye anụ. Ya bụ nye Chiokike nyernu rikne o mee kpam.”
\p 
\v 28 Be sịkwa Jizọsi, “Kịni bụ nhne a jeeme ma a rnụ ẹrnu Chiokike?”
\p 
\v 29 Jizọsi sarụ be, “Ka bụ ẹrnu Chiokike, anụ kweru nụ nye wam o ziyaru.”
\p 
\v 30 Be sịkwa a, “Kịni bụ ẹrnu ndu-ẹhni i jeeji gesi ma a whnụrnu, kweru? Kịni bụ nhne i jeeme?
\v 31 Ele nda aị ọknani riri mana n'ẹli chna chna chna, lele kpa ọkwukwo nsọ kwuru, ‘O nyernu be brẹdi ke hi n'oligwe va, be ri.’ ”
\p 
\v 32 Jizọsi kanụ be, “Me kanụ anụ ezi ọka, ọ bụ́o Mozizi nyernu anụ brẹdi ke hi n'oligwe va, kọvu Nda m neenye anụ ezi brẹdi ke hi n'oligwe va.
\v 33 Kwnornu nụ brẹdi ke Chiokike neenye bụ nye wam ke hi n'oligwe va, bụ nye neenye ele ọwa bụdnu.”
\p 
\v 34 Be kaa, “Nda-aị-kwu, neenye aị brẹdi ka kpakara ige.”
\p 
\v 35 Jizọsi kanụ be, “Mawa bụ brẹdi ke neenye bụdnu, nye vakwnusiri m, wiri jọ́ogwnu a rịa rịa, nye kweru nụ me, akpịri jọ́okpo a bẹkwnu rịa rịa.
\v 36 M karụ m, anụ whnụrnu m, kọvu anụ kwége.
\v 37 Nye ọbula ke Nda m nyernu m jaavakwnusi m, m jáachịhala a rịa rịa.
\v 38 Kwnornu nụ m hiri m n'oligwe hiedna mee echiche nye ziyaru m, ọ bụ́o o mee echiche m.
\v 39 Ka bụ echiche nye ziyaru m, me túwhu nye ọbula ke o nyernu m, kọvu me mee ma be hi n'ẹnwu lizọ n'ọbochi ipne-aznụ.
\v 40 Kwnornu nụ ka bụ nhne Nda m noopio, nye ọbula ke jọowhnu Nnwọ wam, kweru nụ a, jeenwe bụdnu kwó okwo, m jeeme nye wam hi n'ẹnwu lizọ n'ọbochi ipne-aznụ.”
\p 
\v 41 Ele Ju bete ọ takpo megidne a, kwnornu nụ ọ karụ, “Mawa bụ Brẹdi ke hiednarnụ n'oligwe.”
\v 42 Be kaa, “Nye ka ọ bụ́o Jizọsi nnwọ Josefu? A magwụ nda a nụ nne a, ndaa kpa ọ naakaa nụ o hi n'oligwe hiedna?”
\p 
\v 43 Jizọsi kanụ be, “Anụ tákpoma n'esilawụru ẹhni anụ.
\v 44 Ọ zá nye jaavakwnusi m okwolem ma Nda m nye ziyaru m jọodoru a vakwnusi m, m jeeme o lizọ n'ẹnwu n'ọbochi ipne-aznụ.
\v 45 Ele ọwhnurninya gbarụ a n'ọkwukwo nsọ, ‘Chiokike jeezni kpakara ele badnụ nhne.’ Nye ọbula ke bnoteru Nda nsnị mụhia nhne n'aka a, jaavakwnusi m.
\v 46 Ọ zá nye ọbula ke whnụleru Nda anya nụ mbọm, kwekọlam nye wam ke hi hne Chiokike zị whnụrnu Nda anya.
\v 47 Me kanụ anụ ezi ọka, nye ọbula ke kweru nwernu bụdnu kwó okwo.
\v 48 Mawa bụ wiri ke bụdnu.
\v 49 Ele nda anụ ọknani riri mana n'ẹli chna chna chna, be nwụ.
\v 50 Kọvu wiri ke hi n'oligwe hiedna, nye ọbula ke riri a, jọ́onwu ẹnwu.
\v 51 Mawa bụ wiri ke zị bụdnu ke hi n'oligwe hiedna. Ọ bụru nụ badnụ ọbula ri wiri ka, o jaazị bụdnu tim tọm. Anọ-ẹhni m bụ wiri ke me jeenye ọwa ma be zịri bụdnu.”
\p 
\v 52 Ka kpayarụ ọdogbuta whụyaru n'esilawụru ele Ju. Be kaa, “Nwerukna ka, o jeenye aị anọ-ẹhni a ma a ri?”
\p 
\v 53 Jizọsi kanụ be, “Me kanụ anụ ezi ọka, okwolem ma anụ riri anọ-ẹhni ke Nnwọ ke Badnụ, nwọ ọvnarna a, anụ jéenwe bụdnu nụ rime anụ.
\v 54 Nye ọbula ke jeeri anọ-ẹhni m, nwọ masị ọvnarna m nwernu bụdnu kwó okwo.
\v 55 Kwnornu nụ anọ-ẹhni m bụ wiri n'ezi, ọvnarna m bụ masị nhne be nwọ ọnwo n'ezi.
\v 56 Nye ọbula ke jeeri anọ-ẹhni m, nwọ ọvnarna m, wu nụ rime m, m wu masị m nụ rime a.
\v 57 Lele kpa Nda ke zị bụdnu ziyaru m, m zị m bụdnu kwnornu nụ Nda m, kpam masị, nye ọbula ke jeeri anọ-ẹhni m jaazị bụdnu kwnornu me.
\v 58 Ka bụ wiri wam ke hi n'oligwe hiedna, ọ bụ́o kpa nda anụ ọknani riri mana be nwụ. Nye ọbula ke jeeri wiri ka jaazị bụdnu tim tọm.”
\v 59 Ka bụ nhne Jizọsi kwuru nga o neezni nhne nụ ọro ọgbako ele Ju zị nụ Kapanọm.
\s1 Ikwu-ọnu ke bụdnu // kwó okwo
\p 
\v 60 Nga agịda ele sno apna a nụrnu ọka a, be kaa, “Ikwu-ọnu ka siri rikne, nyele jeemeli a?”
\p 
\v 61 Nga Jizọsi mahịaru nụ ele sno apna a naatakpo gbasịri ọka ka, ọ kanụ be, “Ka o mernu ovu we anụ ẹhni sa?
\v 62 Ndaa kpa ọ jọonu nga anụ jọowhnu Nnwọ ke Badnụ lahna hne ọ zị nụ mbọm?
\v 63 Enine neenye bụdnu, badnụ etekne nwée rikne mee nhne ọbula. Ọka me nookwunu anụ bụ enine bụ masị bụdnu.
\v 64 Kọvu agwna anụ kwége.” Jizọsi magwụ hite n'ọziri ele kwé ekwe nụ nye jeere a.
\v 65 Ọ kanụ be, “Ka kpayarụ me jiri kanụ anụ nụ ọ zá nye jaavakwnusi m, okwolem ma Nda m nyernu a rikne o mee kpam.”
\p 
\v 66 Hite nụ nhne Jizọsi kwuru, agịda ele sno apna a lahna aznụ kwnornu nụ ikwu-ọnu ka, be snóge a berere.
\v 67 Jizọsi sịkwa nri nụ badnụ lawụru wam ele sno apna a, “Anụ jaalahna masị?”
\p 
\v 68 Saịmoni Pita, kaa, “Nyenwe aị, a jaalakwnusi nyele? I nwernu ikwu-ọnu ke neenye bụdnu kwó okwo.
\v 69 Kịtna, a kweru, mahịa masị nụ ị bụ nye nsọ ke Chiokike.”
\p 
\v 70 Jizọsi kanụ be, “Me họhiaru anụ nri nụ ẹbo, kọvu otu nyenum nụ rime anụ bụ ekwensu.”
\v 71 O nookwu gbasịri Judasị, nnwọ Saịmoni Isikarịoti, kwnornu nụ Judasị jeere a, ọ bụ n'ezi nụ ọ bụ otu nụ rime nri nụ badnụ lawụru wam ele sno apna Jizọsi.
\c 7
\s1 Jizọsi nụ rụmu nne a
\p 
\v 1 Nga ka mekworu, Jizọsi neeznegharị nụ rime Galili. Ọ chọ́la o zne Judiya kwnornu nụ ele Ju noopio o gbu a.
\v 2 Ige Iriri Ọro Igwugwu ele Ju zị ndụndu.
\v 3 Rụmu nne Jizọsi kanụ a, “Whọga hna zne Judiya ma ele sno apna ị whnụrnu ẹrnu ị nọornu.
\v 4 Nye pioru ma ele badnụ mahịa nye ọ bụ rnụ́ ẹrnu tugwaru otugwa. Mee ma ọwa whnụrnu ẹrnu ị nọornu.”
\v 5 Rụmu nne a kwuru ka kwnornu nụ be kwéle nụ ya.
\p 
\v 6 Jizọsi kanụ be, “Ige m yóoduge, kọvu ige anụ zị n'aka anụ.
\v 7 Ele ọwa jéenwe rikne sno anụ iro, kọvu be snornu m irno, kwnornu nụ m naakaa nụ ẹrnu be bụ́o ọma.
\v 8 Anụ zne n'Iriri ka, m jáava n'Iriri ka kịtna, kwnornu nụ ige m yóoduge.”
\v 9 Nga Jizọsi kwukworu kpa, ọ dazịgidne nụ Galili.
\s1 Jizọsi znernu Iriri // Ọro Igwugwu
\p 
\v 10 Nga rụmu nne a znernu Iriri wam, Jizọsi snornu be zne Iriri wam nụ mgwụgwa, ọ bụ́o nụ ruwhnu ọhna.
\v 11 Ele Ju zị noopio a n'Iriri wam, be nẹesikwa, “Ndaa hne ọ zị?”
\p 
\v 12 Agịda ele badnụ nọotnurita n'esilawụru be, be naakaa, “Ọ bụ nye ọma.” Ele berere naakaa, “Ọ́za, o nooduwhu ele badnụ.”
\v 13 Kọvu ọ zá nye nookwuhịa nhne gbasịri a nụ ruwhnu ọhna, kwnornu nụ be nọotu ogwnu ele risi ele Ju.
\p 
\v 14 N'esilawụru Iriri wam, Jizọsi znernu n'Ọro Nsọ Chiokike bete neezni nhne.
\v 15 Nhne o neezni jiri ele risi ele Ju anya, be kaa, “Nwerukna ka mụ́lele nhne, ndaa kpa o jiri mahịa nhne?”
\p 
\v 16 Jizọsi sarụ be, “Nhne me neezni bụ́o ikwu-ọnu ke m, kọvu ke nye ziyaru m.
\v 17 Nye ọbula ke jeeme echiche nye ziyaru m, nye wam jaamahịa ma nhne me neezni ma o hi n'aka Chiokike mọbu o hi n'aka ke m.
\v 18 Nye nookwu nhne aka ke a, noopio igwugwu ke ẹhni a, kọvu nye noopio igwugwu nye ziyaru a bụ nye ezi ọka, aghịgho zị́la nụ rime a.
\v 19 Ọ bụ́o Mozizi nyernu anụ iwu? Kọvu ọ zá otu nụ rime anụ ke naabịta iwu. Kịni mernu anụ noopio o gbu m?”
\p 
\v 20 Ele badnụ wam kaa, “Ị bụ nye rẹnwu ọjo nwụgwu. Nyele noopio o gbu i?”
\p 
\v 21 Jizọsi kanụ be, “M rnụrnu m otu ẹrnu ndu-ẹhni, o ji anụ anya.
\v 22 Mozizi nyernu anụ iwu ọ kpa rụmu anụ nka (ọ bụ n'ezi nụ ọkpa nka híge n'aka Mozizi, kọvu o hi n'aka ele gbaka), anụ naakpa rụmu anụ nka n'Ọbochi Ozukwa Inwe.
\v 23 Ọ bụru nụ anụ naakpa rụmu anụ nka n'Ọbochi Ozukwa Inwe, ma anụ bịta Iwu Mozizi, ndaa kpa ovu ji neewe anụ ẹhni kwnornu nụ m gwọru m nye nrịria n'Ọbochi Ozukwa Inwe?
\v 24 Anụ kpé ikpe hite nụ nhne anya nọowhnu, kọvu anụ kpe ikpe bụru ọma.”
\s1 Jizọsi, ọ bụ ya bụ Mezaya?
\p 
\v 25 Agwna ele zị nụ Jerusẹlem kaa, “Ka ọ bụ́o nye be noopio o gbu?
\v 26 Le, o nookwu ọka n'ọhna, ọ zá nye nookwu nhne ọbula megidne a. Ele risi aị be magwụ nụ nye ka bụ Karaịsi n'ezi?”
\p 
\v 27 Kọvu nga Karaịsi jaava, ọ zá nye jaamahịa hne o jeehi va. Kọvu kpakara aị magwụ hne nwerukna ka hi va.
\p 
\v 28 Kpa Jizọsi neezni nhne n'Ọro Nsọ Chiokike, o gweru okne nkọli siwama lụlo, kaa, “Anụ magwụ nye me bụ, anụ magwụ masị hne me hi va, kọvu m váge m nụ rikne aka m, nye ziyaru m bụ ezi ọka. Anụ máa nye ọ bụ.
\v 29 Kọvu m maam nye ọ bụ, kwnornu m hi m hne ọ zị va, ya ziyaru m.”
\p 
\v 30 Be pio kpa be jọonwugwu a, kọvu ọ zá nye tụkwasiri a aka, kwnornu nụ ige a yóoduge.
\v 31 Kọvu agịda ele badnụ n'esilawụru igbudu badnụ wam kweru nụ ya, be kaa, “Nga Karaịsi jaava, ọ jọornu ẹrnu ndu-ẹhni kakwo ke nwerukna ka nọornu?”
\s1 Be ziznernu ele nse // be nwudne Jizọsi
\p 
\v 32 Ele Farisi nụrnu nhne igbudu ele badnụ wam nookwu gbasịri a, be nụ ele risi arịohna zizne ele neese Ọro Nsọ Chiokike ma be nwụgwu Jizọsi.
\v 33 Jizọsi kaa, “Me nụ anụ jaazị ige matị, omekwo, m lakwnusi nye ziyaru m.
\v 34 Anụ joopio m, anụ jọ́owhnu m, kwnornu nụ anụ jéenwe rikne va nhne me naala.”
\p 
\v 35 Ele risi ele Ju sịkwa ẹhni be kaa, “Ndaa hne o jeezne hne a jóopiohịali a? O jeezne hne ele Ju wu n'esilawụru ele Giriki, zni ele Giriki nhne?
\v 36 Kịni bụ risi nhne o nookwu? Ọ karụ, ‘Anụ joopio m, kọvu anụ jọ́owhnu m, hne me neezne anụ jéenwe rikne va.’ ”
\s1 Osimini ke neenye bụdnu
\p 
\v 37 N'okne ọbochi ipne-aznụ ke Iriri wam, Jizọsi gwuzoru, gweru okne nkọli siwama, kaa, “Nye ọbula ke akpịri nọokpo bẹkwnu, ọ vakwnusi m, nwọrnu mini.
\v 38 Lele kpa ọkwukwo nsọ kwuru, ‘Nye ọbula ke kweru nụ me, osimini ke mini bụdnu jeehi nụ rime rụwho a naagbahịa.’ ”
\v 39 Jizọsi kwuru ka kwnornu nụ Enine Nsọ ke ele kweru nụ ya jaanahịa. N'ige wam be ényene Enine Nsọ, kwnornu nụ be ényene Jizọsi igwugwu.
\s1 Okewa n'esilawụru // ele badnụ
\p 
\v 40 Agwna ele zị n'igbudu ele badnụ wam, nga be nụrnu ikwu-ọnu ka, be kaa, “N'ezi, nwerukna ka bụ nye ọwhnurninya wam.”
\p 
\v 41 Ele berere kaa, “Ọ bụ Karaịsi.”
\p Kọvu ele berere kaa, “Karaịsi o jeehi nụ Galili va?
\v 42 Ọkwukwo nsọ kwuru nụ Karaịsi jeehi nụ avnụrnu Devidi va, nụ be jọomu a nụ Bẹtilehem, ẹli-ọhna hne Devidi wuru.”
\v 43 Ka kpayarụ okewa n'esilawụru igbudu ele badnụ wam kwnornu nụ Jizọsi.
\v 44 Agwna be pioru ọ nwudne a, kọvu ọ zá nye tụkwasiri a aka.
\s1 Ókwe ekwe ke ele risi // ele Ju
\p 
\v 45 Omekwo, ele neese Ọro Nsọ Chiokike lahnakwnusi ele risi arịohna nụ ele Farisi, be sịkwa be, “Kịni mernu anụ nwụ́yagele a?”
\p 
\v 46 Ele nse wam sarụ be, “Ọ zá nye kwuleru ọka lele kpa nwerukna ka kwuru.”
\p 
\v 47 Ele Farisi sịkwa be, “O duhie masịla anụ sa?
\v 48 O nwernu otu nye Farisi mọbu ele risi ele Ju ke kweru nụ ya sa?
\v 49 Ele ka máa nhne ọbula gbasịri iwu, ọvu ọnu Chiokike zị nụ risi be.”
\p 
\v 50 Otu nye Farisi rẹwhna a bụ Nikodimọsi, nye znekwnusiri Jizọsi n'abalị, kanụ be,
\v 51 “Iwu aị zá naama badnụ ikpe sị ọ nụ́na nhne hi n'ọnu a, nụ nhne o mernu.”
\p 
\v 52 Be sarụ a, “Ị bụ masị nye Galili sa? Lekasi nụ nhne be gbarụ n'ọkwukwo nsọ, ọ zá nye ọwhnurninya ke hi nụ Galili whụya.”
\p [
\v 53 Be gbasa, nye ọbula la n'ọro a.
\c 8
\s1 Nwerinya be nwụgwuru // n'ọyi
\p 
\v 1 Jizọsi znernu nụ Rugwu Olivu.
\v 2 N'ọnu ọsisi, ọ lahna n'Ọro Nsọ Chiokike, kpakara ele badnụ gba a gburugburu, ọ dazịri ẹli bete neezni be nhne.
\v 3 Ele zni iwu ele Ju nụ ele Farisi kwuyanụ a otu nwerinya be nwụgwuru n'ọyi, be gwuzote a n'esilawụru be.
\v 4 Be kaa, “Nye-zni-nhne, a nwụgwuru nwerinya ka hne ya nụ nyerukna dnanyị.
\v 5 N'iwu aị, Mozizi karụ be gweru akaworugwu tụgbu a. Kịni bụ nhne i kwuru?”
\v 6 Be kwuru ka naakpa a iru ma be bno Jizọsi nhne.
\p Kọvu Jizọsi whudnahie ẹli gweru mkpaka a gba nhne nụ rịzna.
\v 7 Be zị kọriri nẹesikwa a, o lizọ, kanụ be, “Nye ọbula n'esilawụru anụ ke mékọlele mmehie beru ọsno tụ a akaworugwu.”
\v 8 O whudnahie ẹli berere naagba nhne nụ rịzna.
\p 
\v 9 Nga be nụrnu a, be hite nụ nye okno badnụ dụ nụ nye matị, otu otu be whọga kwo. Ọ gwnata Jizọsi nụ nwerinya wam.
\v 10 Jizọsi lizọ, sịkwa a, “Nwerinya, ndaa ele noobno i nhne? Ọ zá nye gwnarnụ ke jaama ị ikpe?”
\p 
\v 11 Nwerinya wam kaa, “Ọ zá, sụ Nda-aị-kwu.”
\p Jizọsi kanụ a, “M máge m masị m jị ikpe, kọvu la, i méma mmehie berere.”]
\s1 Jizọsi, iwhne ke ọwa
\p 
\v 12 Jizọsi kakwnonu be, “Mawa bụ iwhne ke ọwa. Nye ọbula ke joosno m jeenwe iwhne ke bụdnu, o jéezne izne n'ọchichiri.”
\p 
\v 13 Ele Farisi kaa, “Ị naagbanụ ẹhni ị akebne kịtna, nhne i nookwu bụ́o ezi ọka.”
\p 
\v 14 Jizọsi sarụ be, “Ọ bụbedi nụ m naagbanụ ẹhni m akebne, nhne me nookwu bụ ezi ọka, kwnornu nụ m magwụ m hne me hi nụ hne me neezne.
\v 15 Anụ neekpe ikpe lele badnụ. M zá m neekpe nye ọbula ikpe.
\v 16 Ọ bụru nụ me kpe ikpe, ikpe m ziri ezi kwnornu nụ me nụ nsnụnu m zá n'ikpe, me nụ Nda m nye ziyaru m zị.
\v 17 Be gbarụ a n'iwu anụ, nụ akebne badnụ lawụru gbarụ bụ ezi ọka.
\v 18 M gbanụ m ẹhni m akebne, Nda m nye ziyaru m gbakwnonu m akebne.”
\p 
\v 19 Be sịkwa a, “Ndaa hne Nda ị zị?”
\p Jizọsi sarụ be, “Anụ máa m, anụ máa masị Nda m. Ọ bụru nụ anụ magwụ nye me bụ, anụ znernu amahịa Nda m.”
\v 20 Jizọsi kwuru kpakara nhne ka nga o neezni nhne n'Ọro Nsọ Chiokike, nụ rime hne be naabịta igbe ịwai. Ọ zá nye tụkwasiri a aka megidne a kwnornu nụ ige a yáavage.
\s1 Anụ jéezneli hne me // neezne
\p 
\v 21 Jizọsi kanụ be berere, “M jaala, anụ joopio m, anụ jọonwu nụ rime mmehie anụ. Anụ jéenwe rikne va hne me jaala.”
\p 
\v 22 Ele risi ele Ju kaa, “Ọ kaa nụ a jáavali hne ọ naala. O joogbu ẹhni a sa?”
\p 
\v 23 Jizọsi kanụ be, “Anụ hi hna, kọvu m hi m n'olu va. Anụ bụ ele ọwa ka, kọvu m bụ́o m nye ọwa ka.
\v 24 Ọ bụ nhne me jiri kanụ anụ nụ anụ jọonwu nụ rime mmehie anụ. Ọ bụru nụ anụ kwége nụ m bụ m nye me bụ, anụ jọonwu nụ rime mmehie anụ.”
\p 
\v 25 Be sịkwa a, “Ị bụ nyele?”
\p Jizọsi kanụ be, “M bụ m nye me karụ nụ m bụ m n'ọziri.
\v 26 M nwernu m agịda nhne me jookwu n'ikpe megidne anụ. Kọvu nye ziyaru m bụ ezi ọka, m jaakanụ ọwa nhne me nụrnu hite n'ọnu a.”
\p 
\v 27 Be ghọ́yage nhne o nookwu gbasịri Nda.
\v 28 Ka kpayarụ, Jizọsi kannụ be, “Nga anụ jeegwelizọ Nnwọ ke Badnụ olu, ige wam anụ jaamahịa nụ m bụ m nye me bụ. Ọ zá nhne ke me neeme nụ rikne aka ke m, kọvu m neezni kpakara nhne Nda m znirni m.
\v 29 Nye wam ziyaru m dagwụnu m, ọ ghárụla me nụ nsnụnu m rịa rịa, kwnornu nụ m neeme nhne naamasị a kpakara ige.”
\v 30 Agịda ele nụrnu nhne Jizọsi kwuru kweru nụ ya.
\s1 Badnụ nwernu ẹhni a n'ezi
\p 
\v 31 Jizọsi kanụ ele Ju ele ke kweru nụ ya, “Ọ bụru nụ anụ dazịgidne n'ikwu-ọnu m, anụ jọoburu ele sno apna m n'ezi.
\v 32 Anụ jaamahịa ezi ọka, ezi ọka wam jeeme anụ nwernu ẹhni anụ.”
\p 
\v 33 Be sarụ Jizọsi, “A bụ rụmu Ebereham, a bụ́kolele ọhi n'aka badnụ ọbula. Ndaa kpa ị naakaa nụ a jeenwernu ẹhni aị?”
\p 
\v 34 Jizọsi sarụ be, “Me kanụ anụ ezi ọka, nye ọbula ke neeme mmehie bụ ọhi ke mmehie.
\v 35 Ọhi zá naadazịgidne n'ọro tim tọm, kọvu nnwọ nwe ọro ọkwnukokwnu.
\v 36 Ọ bụru nụ Nnwọ jeeme anụ nwernu ẹhni anụ, anụ jeenwernu ẹhni anụ n'ezi.
\v 37 M magwụ m nụ anụ bụ rụmu Ebereham, kọvu anụ noopio o gbu m, kwnornu nụ anụ kwége ikwu-ọnu m.
\v 38 M naakanụ anụ nhne Nda m gesiri m, kọvu anụ neeme nhne nda anụ kannụ anụ.”
\p 
\v 39 Be sarụ a, “Ebereham bụ nda aị.”
\p Jizọsi kanụ be, “Ọ bụru nụ Ebereham bụ nda anụ n'ezi, anụ jọornu ẹrnu Ebereham rnụrnu.
\v 40 Nhne me mernu bụ ọ kanụ anụ ezi ọka me nụrnu n'ọnu Chiokike, anụ noopio o gbu m. Ebereham méne kpam.
\v 41 Anụ neeme nhne anụ nda anụ mernu.”
\p Be kaa, “Chiokike bụ Nda a nwernu kpọi. A bụ́o rụmu ọyi.”
\s1 Rụmu ke Ekwensu
\p 
\v 42 Jizọsi kanụ be, “Ọ bụru nụ Chiokike bụ Nda anụ n'ezi, anụ znernu ọwhnu m n'anya, kwnornu nụ m hi m hne Chiokike zị whụya, va hna. M váge m nụ rikne aka ke m, kọvu ya ziyaru m.
\v 43 Nhne mernu anụ ghọ́yage nhne me nookwu, ọ bụ nụ anụ bnóge nsnị n'ikwu-ọnu m.
\v 44 Anụ bụ rụmu nda anụ Ekwensu, anụ jọornu ẹrnu nda anụ noopio. Ọ bụ nye noogbu badnụ hite n'ọpanizo. Ọ zị́la n'ezi ọka, kwnornu nụ ezi ọka zá nụ rime a. Omen'ẹli a bụ ọ gha aghalaghala, kwnornu nụ o bụ nye aghalaghala nụ nda kpakara aghalaghala.
\v 45 Me nookwunu anụ ezi ọka, kọvu anụ zá neekweru m.
\v 46 Nyele n'esilawụru anụ jaama m ikpe mmehie? Ọ bụru nụ me kanụ anụ ezi ọka, kịni mernu anụ kwége m?
\v 47 Nye ọbula bụ ke Chiokike joobno nsnị ikwu-ọnu Chiokike. Kọvu anụ jóobno nsnị kwnornu nụ anụ bụ́o ele ke Chiokike.”
\s1 Jizọsi nụ Ebereham
\p 
\v 48 Ele Ju sarụ Jizọsi, “A kwukwaru nkarị nga a kwuru nụ ị bụ nye Sameria ke rẹnwu ọjo nwụgwu.”
\p 
\v 49 Jizọsi kanụ be, “Ọ zá rẹnwu ọjo nwụgwu m, kọvu m neenye Nda m igwugwu, kọvu anụ zá neenye m igwugwu.
\v 50 M zá m noopio igwugwu ke m. O nwernu nye ke noopio igwugwu m, nye wam bụ nye ikpe.
\v 51 Me kanụ anụ ezi ọka, ọ bụru nụ nye ọbula bịta ikwu-ọnu m, ọ jọ́owhnu ẹnwu anya rịa rịa.”
\p 
\v 52 Ele Ju kanụ a, “Kịtna hne a mahịaru nụ rẹnwu ọjo nwụgwu ị. Ebereham nụ kpakara ele ọwhnurninya nwụrnu ẹnwu. Ị zị hna naakaa nụ nye ọbula ke jaabịta ikwu-ọnu ị jọ́onwu ọnwu rịa rịa.
\v 53 Nda aị Ebereham nwụrnu ẹnwu. Ị kákwole Ebereham nụ ele ọwhnurninya ele nwụrnu ẹnwu. I che nụ ị bụ dị nyele?”
\p 
\v 54 Jizọsi sarụ, “Ọ bụru nụ me nyee ẹhni m igwugwu, ọ zá nhne ọ bụ. Nda m nye anụ naakaa nụ ọ bụ Chiokike anụ neenye m igwugwu.
\v 55 Ọ bụ n'ezi nụ anụ máa nye ọ bụ rịa rịa. Kọvu m maam nye ọ bụ. Ọ bụru me kaa nụ m máam nye ọ bụ, m jọoburu nye aghalaghala lele anụ, kọvu m magwụ m nye ọ bụ, m naabịta ikwu-ọnu a.
\v 56 Nda anụ Ebereham nwernu ovu ọso n'ọnu nụ ọ jọowhnu ọbochi m, ọ whnụ masị a, ọ nwụdnarnu.”
\p 
\v 57 Ele Ju kanụ a, “Ị yóoduge nri awha isne, ị whnụrnu Ebereham n'ezi?”
\p 
\v 58 Jizọsi kanụ be, “Me kanụ anụ ezi ọka, m zị m sụ be mụrnu Ebereham.”
\v 59 Be chịri akaworugwu be jọotugbu a, kọvu Jizọsi tugwa ẹhni a, hi n'Ọro Nsọ Chiokike whọga.
\c 9
\s1 Jizọsi gwọru nye // be mụrnu n'isni
\p 
\v 1 Kpa Jizọsi neewhe, ọ whnụ otu nyerukna be mụrnu n'isni.
\v 2 Ele sno apna a sịkwa a, “Nye-zni-nhne, ọ bụ mmehie nyele mernu be mụrnu nwerukna ka n'isni? Mmehie ke a sọbu ke ele mụrnu a?”
\p 
\v 3 Jizọsi kaa, “Isni kpuru a bụ́o kwnornu nụ mmehie ke a mọbu ke ele mụrnu a. Kọvu o kpuru isni ma ẹrnu Chiokike whụya iwhne n'ẹhni a.
\v 4 A jaazị nọornu ẹrnu nye wam ziyaru m kpa ọbochi gwnarnụ, kwnornu nụ abalị vawa, nga ọ zá nye jeenwe rikne rnụ ẹrnu.
\v 5 Kpa me zịko n'ọwa, mawa bụ iwhne ke ọwa.”
\p 
\v 6 Nga o kwukworu ka, ọ gbụsa ọnu-mini n'ẹli, gweru ọnu-mini wam me ọrura, o te ọrura wam n'anya nwerukna wam.
\v 7 Ọ kanụ a, “Zne snụ ruwhnu i n'Olulu Mini Saịlom” (ke bụ nye be ziznernu). Nwerukna wam zne, snụ ruwhnu a, hiehna nọowhnu ọsno.
\p 
\v 8 Ele agbatibi a nụ ele whnụrnu hne ọ nọorio nhne nụ mbọm sịkwa, “Ka ọ bụ́o nwerukna wam dazị ẹli nọorio nhne?”
\p 
\v 9 Agwna be kaa, “Ọ bụ ya.”
\p Ele berere kaa, “Ọ́za, o yiri ya.”
\p Kọvu nwerukna wam karụ, “Ọ bụ mawa.”
\p 
\v 10 Be sịkwa a, “Ndaa kpa anya ị jiri kpume?”
\p 
\v 11 Ọ sarụ, “Otu nwerukna be kwu Jizọsi mernu ọrura tesi n'anya m, kanụ m, ‘Zne n'Olulu Mini Saịlom snụ ruwhnu,’ kpa me snụrnu, m whnụrnu m ọsno.”
\p 
\v 12 Be sịkwa a, “Nda hne ọ zị?”
\p Ọ kaa, “M máam.”
\s1 Ele Farisi nọotule // ọgwugwo wam
\p 
\v 13 Be kwuznenu ele Farisi nwerukna wam kpuru isni nụ mbọm.
\v 14 Jizọsi mernu ọrura kpume anya nwerukna wam n'Ọbochi Ozukwa Inwe.
\v 15 Ele Farisi sịkwa nwerukna wam berere kpa o jiri nọowhnu ọsno. Ọ kanụ be, “O yisiri ọrura n'anya, m snụ ruwhnu m, kịtna, m nọowhnu ọsno.”
\p 
\v 16 Agwna ele Farisi kaa, “Nwerukna ka híge nụ hne Chiokike zị va, kwnornu nụ ọ zá naabịta iwu ke Ọbochi Ozukwa Inwe.”
\p Ele berere kaa, “Ndaa kpa nye mmehie jeenwe rikne rnụ ẹrnu ndu-ẹhni ele ka?” Ka vuyarụ okewa n'esilawụru be.
\v 17 Ele Farisi sịkwa kwno nwerukna wam berere, “Ndaa nhne ị kwuru gbasịri nye wam kpumernu anya ị?”
\p Ọ sarụ be, “Ọ bụ nye ọwhnurninya.”
\p 
\v 18 Kọvu ele risi ele Ju kwége nụ o kpuru isni nụ mbọm kọvu nọowhnu ọsno kịtna tem be sukwu ele mụrnu nwerukna wam.
\v 19 Be sịkwa be, “Ka ọ bụ nnwọ anụ, nye anụ karụ nụ o kpuru isni nga anụ mụrnu a? Ndaa kpa o jiri nọowhnu ọsno kịtna?”
\p 
\v 20 Ele mụrnu a sarụ be, “Ọ bụ n'ezi nụ ọ bụ nnwọ aị, nye a mụrnu n'isni.
\v 21 Kọvu a máa kpa o jiri nọowhnu ọsno kịtna mọbu nye kpumernu anya a. Anụ sịkwahia a, ọ bụ okno badnụ, o jookwulinu ẹhni a.”
\v 22 Ele mụrnu a kwuru ka kwnornu nụ be nọotu ogwnu ele risi ele Ju. Kwnornu nụ ele risi ele Ju kwekọtaru nụ nye ọbula ke jookwuhịa nụ Jizọsi bụ Karaịsi, be jaachịhala a n'ọro ọgbako ele Ju.
\v 23 Ka kpahịaru ele mụrnu a karụ, “Ọ bụ okno badnụ, anụ sịkwa a.”
\p 
\v 24 Be sukwu kwno nwerukna wam be mụrnu n'isni, be kanụ a, “Nyee Chiokike ọznarni, a magwụ nụ nwerukna ka bụ nye mmehie.”
\p 
\v 25 Nwerukna wam kaa, “M máam ma ọ bụ nye mmehie, ma ọ bụ́o nye mmehie. Kọvu otu nhne bụ ke me mahịaru, m kpuru m isni nụ mbọm, kịtna m nọowhnu ọsno.”
\p 
\v 26 Be sịkwa kwno a, “Kịni bụ nhne o mernu ị? Ndaa kpa o jiri kpume anya ị?”
\p 
\v 27 Ọ sarụ be, “M kannụ m anụ nụ mbọm, anụ kwéle o bno nsnị. Anụ pioru ọ nụ a berere? Anụ noopio ọ bụru ele sno apna a sa?”
\p 
\v 28 Be kpasị a iwhnerne, kaa, “I bụ nye sno apna nye ka, a bụ ele sno apna Mozizi.
\v 29 A magwụ nụ Chiokike kwunnu Mozizi ọka, kọvu nye ka, a máa hne o hi va.”
\p 
\v 30 Nwerukna wam sarụ be, “Ka bụ nhne tụ n'anya, anụ máa hne o hi va, kọvu o kpumernu anya m.
\v 31 A magwụ nụ Chiokike zá noobnonu ele mmehie nsnị, kọvu o noobnonu ele nọosobisinu a nsnị bụ ele neeme nhne naamasị a.
\v 32 Ke ọwa panịzoru, ọ zá nye nụleru nụ o nwernu nye kpumernu anya nye be mụrnu n'isni.
\v 33 Ọ bụru nụ nwerukna ka híge n'aka Chiokike, o jéenwe rikne mee nhne ọbula.”
\p 
\v 34 Be sarụ a, “Be mụrnu ị, znụlizo ị nụ rime mmehie. Ị jọobu nye jeezni aị nhne sa?” Be chịhala a nụ rime ọro ọgbako ele Ju.
\s1 Isni ke Enine
\p 
\v 35 Nga Jizọsi nụrnu nụ be chịhalaru a, o pohịa a, kaa, “I kweru nụ Nnwọ ke Badnụ?”
\p 
\v 36 Nwerukna wam sịkwa Jizọsi, “Nda-aị-kwu, kanụ m nye ọ bụ ma m kweru m nụ ya.”
\p 
\v 37 Jizọsi kanụ a, “Ị whnụnam a, ọ bụ nye nookwunu i ọka kịtna.”
\p 
\v 38 Nwerukna wam kaa, “Nyenwe aị, m kweru m.” Ọ kpọnu a risi n'ẹli.
\p 
\v 39 Jizọsi kaa, “M varụ m n'ọwa o kpe ikpe, ma ele kpuru isni whnụrnu ọsno, ma ele nọowhnu ọsno kpu isni.”
\p 
\v 40 Agwna ele Farisi zị hne ọ zị nụrnu nhne o kwuru, be sịkwa a, “A bụ ele isni masị?”
\p 
\v 41 Jizọsi kaa, “Ọ bụru nụ anụ kpuru isni, ikpe mmehie ba mána anụ, kọvu anụ karụ nụ anụ nọowhnu ọsno, anụ bụ ele ikpe mmehie marnụ.”
\c 10
\s1 Jizọsi ọmamarna nye // znụ atnụrnu
\p 
\v 1 Jizọsi kaa, “Me kanụ anụ ezi ọka, nye ọbula ke gála nụ ọnu-mgbo bna n'ọro atnụrnu, kọvu garụ apna berere bna, bụ nye buznu n'ezi.
\v 2 Nye ke garụ n'ọnu-mgbo bna n'ọro atnụrnu bụ nye nọoznu atnụrnu.
\v 3 Nye neese ọnu-mgbo jaagbanụ a ọro, rụmu atnụrnu a nụrnu nkọli a, o sukwu rụmu atnụrnu a nụ rẹwhna be, duru be whọga.
\v 4 Nga ọ chịhiaru be, o beru be ọsno, rụmu atnụrnu a snornu a n'aznụ, kwnornu nụ be magwụ nkọli a.
\v 5 Be jóosno nye berere, kọvu be jaagbawhu, kwnornu nụ be máa nkọli nye izne.”
\v 6 Ka bụ elulu Jizọsi tnụnnu be, kọvu be ghọ́yage nhne ọ naakanụ be.
\p 
\v 7 Jizọsi kanụ be berere, “Me kanụ anụ ezi ọka, mawa bụ ọnu-mgbo ke atnụrnu.
\v 8 Kpakara ele beru m ọsno va bụ ele buznu n'ezi. Atnụrnu wam bnóne be nsnị.
\v 9 Mawa bụ ọnu-mgbo. Be jọoznohia nye ọbula ke jeehi nụ rime m bna, ọ jaabna nụ rime, whọga kwno n'ederezi, whnụ ọri ọ jaata.
\v 10 Nye buznu varụ ma o znu buznu, gbu ogbu, lulu nhne, kọvu m varụ m ma be nwehịa bụdnu, bụ bụdnu ke zuru ozu.
\p 
\v 11 “Mawa bụ ọmamarna nye znụ atnụrnu. Ọmamarna nye znụ atnụrnu jiknernu ọ nwụnu atnụrnu a ẹnwu.
\v 12 Nye be gnornu ẹrnu, nye atnụrnu wam bụ́o ke a, jẹesigbasi atnụrnu gbawhu nga ọ whnụrnu edu naava. Edu tagbu atnụrnu, chikeme kwo be.
\v 13 Ọ gbarụ ẹso kwnornu nụ atnụrnu bụ́o ke a, ọ bụ nye be gnornu ẹrnu, bụdnu rụmu atnụrnu wam zị́la a mkpa.
\p 
\v 14 “Mawa bụ ọmamarna nye znụ atnụrnu. M maam atnụrnu m, atnụrnu m magwụ m masị.
\v 15 Lele kpa Nda m magwụ m, bụ kpa me magwụ Nda m. M nọotusanu rụmu atnụrnu m bụdnu m.
\v 16 M nwernu m rụmu atnụrnu berere ke zá n'ogbori atnụrnu ka, m jeegweya be. Be masị jọonu nkọli m, kpakara be jọoburu otu ogbori atnụrnu. Be jeenwe otu nye znụ atnụrnu.
\v 17 Ka bụ nhne kpayarụ Nda m jiri whnụ m n'anya kwnornu nụ m kweru m ọ tụbita bụdnu m, ma m gwelizọ a berere.
\v 18 Ọ zá nye nanahịa m bụdnu m. Mawa bịtaru a hite nụ mkpọma m. M nwernu rikne ọ bịta a, m nwe masịri m rikne o gwelizọ a. Ka bụ nhne Nda m nyernu m n'iwu.”
\p 
\v 19 Ka kpayarụ okewa kwno n'esilawụru ele Ju.
\v 20 Agịda be naakaa, “Rẹnwu ọjo nwụgwu a, ọ bụ nye ẹra. Kịni mernu anụ noobno a nsnị?”
\p 
\v 21 Kọvu ele berere kaa, “Nye rẹnwu ọjo nwụgwu, o jookwu ọka kpa? Ndaa kpa rẹnwu ọjo jookpumeli anya nye isni?”
\s1 Ókwe ekwe ke ele Ju
\p 
\v 22 N'ige Iriri Onyewhete Ọro Nsọ Chiokike dụru nụ Jerusẹlem, n'ige okirika,
\v 23 Jizọsi zị n'Ọro Nsọ Chiokike neezne izne nụ mgbemgbe ọro Solomọni.
\v 24 Ele Ju gba a gburugburu, znekwnusi a, kaa, “Ị bịtaru a n'ọchichiri ogologo ige, kawamanụ aị ọ bụru nụ jịwa bụ Karaịsi.”
\p 
\v 25 Jizọsi sarụ be, “M kannụ m anụ, kọvu anụ kwége. Ẹrnu ndu-ẹhni me nọornu nụ rẹwhna Nda m naagbanụ m akebne.
\v 26 Kọvu anụ kwége kwnornu nụ anụ bụ́o atnụrnu ke m.
\v 27 Atnụrnu ke m nọonu nkọli m, m maam be, be noosno m n'aznụ.
\v 28 M neenye be bụdnu kwó okwo, be jọ́onwu rịa rịa. Ọ zá nye nwernu rikne dọhala be n'aka m.
\v 29 Nda m nye nyernu m be kakwo kpakara nhne berere. Ọ zá nye nwernu rikne dọhala be n'aka Nda m.
\v 30 Me nụ Nda m bụ otu.”
\p 
\v 31 Ele risi ele Ju tụturu kwno akaworugwu be jọotu a.
\v 32 Jizọsi kanụ be, “M rnụrnu m agịda ẹrnu ndu-ẹhni nụ ruwhnu anụ ke Nda m nyernu m, ndaa ẹrnu ke anụ kwnornu nụ a nọotu m akaworugwu?”
\p 
\v 33 Ele Ju sarụ a, “A jọ́otu ị akaworugwu kwnornu nụ ẹrnu ọma, kọvu kwnornu nụ ị kwuluru Chiokike hne ị bụ badnụ etekne, ị neeme ẹhni ị Chiokike.”
\p 
\v 34 Jizọsi sarụ be, “Ọkwukwo nsọ anụ kwuru nụ Chiokike sukwuru be chi.
\v 35 O sukwuru be chi bụ ele nụrnu ikwu-ọnu Chiokike, aghalaghala zị́la nụ nhne be gbarụ n'ọkwukwo nsọ.
\v 36 Nda m họhiaru m, bịta m nsọ, ziya m n'ọwa. Ndaa kpa me nookwulu Chiokike kwnornu nụ m karụ m nụ m bụ m Nnwọ Chiokike?
\v 37 Anụ kwé, ọ bụru nụ m zá m nọornu ẹrnu Nda m.
\v 38 Kọvu ọ bụru nụ m nọornu ẹrnu Nda m, ọ bụbedi nụ anụ kwéle nụ me, anụ kweru n'ẹrnu m, ma anụ mahịa nụ Nda m zị nụ rime m, me nụ rime Nda m.”
\v 39 Be pio ọ nwudne a berere, kọvu o hi n'aka be whọgaru.
\p 
\v 40 Jizọsi lahna n'aznụ Osimini Jọdani kịyari, hne Jọni wụru mini nụ mbọm. Ọ dazịri pịi.
\v 41 Agịda ele badnụ vakwnusi a, kaa, “Jọni rnụ́ge ẹrnu ndu-ẹhni, kọvu kpakara nhne Jọni kwuru gbasịri nwerukna ka bụ ezi ọka.”
\v 42 Agịda be kweru nụ ya pịi.
\c 11
\s1 Ẹnwu Lazarọsi
\p 
\v 1 Otu nwerukna rẹwhna bụ Lazarọsi, nye wu nụ Bẹtani, dnarnụ ẹhni igbugbu. Bẹtani bụ hne Meri nụ nwene a rinya Mata wu.
\v 2 Ka bụ Meri wam ke wụsiri Jizọsi mọno otute, gweru rukeri-ize a kwnosnama ọchi a, bụ nye nwene a rukna Lazarọsi dnarnụ ẹhni igbugbu.
\v 3 Rụmu nne a rinya ziznenu Jizọsi izi kaa, “Nyenwe aị, enyi i ke ị whnụrnu n'anya naarịa arịa.”
\p 
\v 4 Nga Jizọsi nụrnu a, ọ kaa, “Ẹhni igbugbu ka jọ́obu ẹnwu Lazarọsi, kọvu o jeenye Chiokike igwugwu ma be hite nụ a nyee Nnwọ Chiokike igwugwu.”
\v 5 Jizọsi whnụrnu Mata nụ nwene a rinya nụ Lazarọsi n'anya.
\v 6 Kọvu nga ọ nụrnu nụ Lazarọsi naarịa ẹhni igbugbu, ọ dazịri nụ hne ọ zị ọbochi lawụru berere.
\p 
\v 7 Omekwo, ọ kanụ ele sno apna a, “Anụ va ma a lahna Judiya.”
\p 
\v 8 Ele sno apna a kanụ a, “Nye-zni-nhne, o gbúle ọkwnu ele Ju pioru ọ tụ akaworugwu, ị naalahna kọriri pịi?”
\p 
\v 9 Jizọsi sarụ be, “Otu ọbochi nwernu nri nụ awa lawụru, nye ọbula ke znernu izne n'iwhnehnie jọ́okpobi ọchi, kwnornu nụ ọ nọowhnu iwhne k'ọwa.
\v 10 Kọvu ọ bụru nụ o zne izne n'abalị, ọ jọokpobi ọchi, kwnornu nụ ọ zị́ iwhne zị nụ rime a.”
\p 
\v 11 Nga Jizọsi kwukworu kpa, ọ kaa, “Lazarọsi enyi aị neezni anyarna, kọvu m jeezne ma m kpatne a.”
\p 
\v 12 Ele sno apna a kaa, “Nyenwe aị, ọ bụru nụ o neezni anyarna, ẹhni jọoburu a ọma.”
\v 13 Kọvu nhne Jizọsi nookwu bụ nụ Lazarọsi nwụnam. Kọvu be neeche nụ ọ bụ ozni anyarna etekne.
\p 
\v 14 Jizọsi kawhnomenu be, “Lazarọsi nwụnam.
\v 15 Mkpọma nọoso m n'ọnu kwnornu anụ, nụ m zị́la m hne ọ nwụrnu, ma anụ kweru. Anụ lizọ ma a znekwnusi a.”
\p 
\v 16 Tọmosi, nye be kwu Didimọsi (ke bụ ejima) kanụ ele sno apna a ibne a, “Anụ lizọ ma a snornu a zne, ma a snornu a nwụ ẹnwu.”
\s1 Jizọsi, olizọ n'ẹnwu // nụ bụdnu
\p 
\v 17 Nga Jizọsi vaduru, ọ whnụrnu nụ be lilem Lazarọsi ọbochi ẹno wheru ewhe.
\v 18 Bẹtani dụ́la maịli lawụru hite nụ Jerusẹlem.
\v 19 Agịda ele Ju varụ ọ kasi Mata nụ Meri mkpọma kwnornu ẹnwu nwene be rukna.
\v 20 Nga Mata nụrnu nụ Jizọsi vawa, ọ whọga znekwnusi a, kọvu Meri dazịri n'ọro.
\p 
\v 21 Mata kanụ Jizọsi, “Nyenwe aị, ọ bụru nụ ị zị hna, nwene m rukna bọ́ ọ nwụna.
\v 22 Kọvu m maam nụ nhne ọbula ị rịoru n'aka Chiokike, o jeenye i ya.”
\p 
\v 23 Jizọsi kanụ a, “Nwene i rukna jeelizọ berere.”
\p 
\v 24 Mata sa a, “M maam nụ o jeelizọ berere n'ọbochi ipne-aznụ.”
\p 
\v 25 Jizọsi kanụ a, “Mawa bụ olizọ n'ẹnwu nụ bụdnu. Nye ọbula ke kweru nụ me, ọ bụrubedi nụ ọ nwụrnu ọnwu, ọ jaazị bụdnu.
\v 26 Berere kwno, nye ọbula ke zị bụdnu kweru nụ me jọ́onwu ẹnwu tim tọm. Mata, i kweru nhne me nookwu?”
\p 
\v 27 Mata sarụ, “Owe! Nyenwe aị, m kweru m nụ jị bụ Karaịsi, Nnwọ Chiokike ke varụ n'ọwa.”
\s1 Jizọsi kwnarnụ ẹkwna
\p 
\v 28 Nga Mata kwukworu ka, ọ lahna, sukwu Meri nwene a rinya ichne kanụ a, “Nye-zni-nhne zị hna, o noosukwu i.”
\v 29 Nga Meri nụrnu ka, o lizọ wara wara ma o kwnusi Jizọsi.
\v 30 Jizọsi yáavaduge nụ rime ẹli-ọhna, ọ zị kọriri nụ hne Mata kwnusiri a.
\v 31 Ele Ju be nụ Meri zị n'ọro naakasi a mkpọma, snornu a nga be whnụrnu nụ o lizọru wara wara whọga. Be neeche nụ o neezne akwna ẹkwna n'ilili.
\p 
\v 32 Nga Meri dụru hne Jizọsi zị, whnụ a, ọ dna n'ẹli n'ọchi a, kaa, “Nyenwe aị, ọ bụru nụ ị zị hna, nwene m rukna bọ́ ọ nwuna.”
\p 
\v 33 O metụru Jizọsi nụ mkpọma nga ọ whnụrnu Meri nụ ele Ju sno a naakwna ẹkwna, o gbu a igbugbu nụ mkpọma.
\v 34 Ọ sịkwa be, “Ndaa hne anụ vubiri a?”
\p Be kaa, “Nyenwe aị, va whnụrnu.”
\p 
\v 35 Jizọsi kwnarnụ ẹkwna.
\p 
\v 36 Ele Ju kaa, “Le, ọ whnụrnu a n'anya k'agịda.”
\p 
\v 37 Kọvu agwna be kaa, “O kpumernu anya nwerukna kpuru isni, ọ bụ nụ o jéenwe rikne mee Lazarọsi gharụ ọ nwụ ẹnwu?”
\s1 Jizọsi mernu Lazarọsi hi // n'ẹnwu lizọ
\p 
\v 38 O gbu kwno Jizọsi igbugbu nụ mkpọma, o zne n'ilili be gwuru nụ rime rugwu, be jiri rugwu kpusni ọnu a.
\v 39 Jizọsi kaa, “Anụ gweme rugwu ka.”
\p Mata, nwene rinya nwerukna wam nwụrnu ọnwu kaa, “Nyenwe aị, ọ jeenwe ẹknarna ọjo, kwnornu nụ tna bụ ọbochi ẹno be liri a.”
\p 
\v 40 Jizọsi kaa, “Me kannụ ị nụ i jọowhnu igwugwu Chiokike ọ bụru nụ i jeekweru kpọi?”
\p 
\v 41 Be vume rugwu wam. Jizọsi lelizọ anya n'olu, kaa, “Nda m, meka, kwnornu nụ i bnonem me nsnị.
\v 42 M magwụ m nụ i noobnonu m nsnị ige ọbula, kọvu kwnornu nụ ele ka zị hna m nookwu a ma be kweru nụ jị ziyaru m.”
\p 
\v 43 Nga o kwukworu ka, o gweru okne nkọli siwama, “Lazarọsi, whụya.”
\v 44 Nwerukna wam nwụrnu ọnwu whụya, nye be ji ikpe iznu whụ a aka lawụru nụ ọchi lawụru, nụ ikpe be jiri whụ ruwhnu a. Jizọsi kanụ be, “Anụ tọma a, ma ọ la.”
\s1 Be gbarụ iznuznu // o gbu Jizọsi
\r (Mat 25:1-5; Mak 14:1,2; Luk 22:1,2)
\p 
\v 45 Agịda ele Ju ele varụ elekwa Meri whnụrnu nhne Jizọsi mernu, kweru nụ ya.
\v 46 Kọvu agwna be lahna kanụ ele Farisi nhne Jizọsi mernu.
\v 47 Ele Farisi nụ ele risi arịohna kwu ikwu kaa, “Ndaa nhne a neeme? Nwerukna ka nọornu agịda ẹrnu ndu-ẹhni.
\v 48 Ọ bụru nụ a gharụ a, o neezne nụ ruwhnu, kpakara ele badnụ jeekweru nụ ya. Ele Rom jaava lulu ẹli aị ma Ọro Nsọ aị.”
\p 
\v 49 Otu nyenum n'esilawụru be, rẹwhna a bụ Kayafasị, nye bụ nye risi arịohna n'awha wam, kaa, “Anụ máa nhne rịa rịa.
\v 50 Ọ bụru ọma nụ otu badnụ nwụhianu kpakara badnụ ẹnwu, ma kpakara mba gharụ o whu etekne.”
\p 
\v 51 N'ezi ọka, o kwúge nhne ka hite nụ mkpọma a, kọvu lele nye risi arịohna n'awha wam, ọ whnụrnu ọwhnurninya nụ Jizọsi jọonwuhianu ele Ju ẹnwu.
\v 52 Ọ bụ́o ele Ju kpọi, kọvu kwnornu kpakara rụmu Chiokike be chịsaru nụ kpakara ọwa, chịkota be ma be bụru otu.
\v 53 Hite n'ọbochi wam ele risi ele Ju bete ọ gba iznuznu kpa be joogbu Jizọsi.
\p 
\v 54 Kam kpayarụ, Jizọsi zị́ma neezne izne nụ ruwhnu ọhna n'esilawụru ele Ju, kọvu ọ whọga zne hne zị ndụndu n'ẹli-ịkpa, bna n'otu ẹli be kwu Ifirem, ya nụ ele sno apna a dazịri pịi.
\p 
\v 55 Ige Iriri Ọgawhe ele Ju zị ndụndu, agịda ele Ju zne Jerusẹlem, zne ọ bịta ẹhni be nsọ sụ ọ dụ Iriri Ọgawhe be.
\v 56 Be noopio Jizọsi, be gbakọ n'Ọro Nsọ Chiokike, be nẹesikwa ibne be, “Ndaa nhne bụ echiche anụ? Ọ bụ nụ ọ jáava Iriri ka sa?”
\v 57 Ele risi arịohna nụ ele Farisi nyernu iwu, kaa, nye ọbula ke magwụ hne Jizọsi zị kanụ be ma be nwudne a.
\c 12
\s1 Be teru Jizọsi mọno // nụ Bẹtani
\r (Mat 26:6-13; Mak 14:3-9)
\p 
\v 1 Ọ gwnarnụ ọbochi isunu Iriri Ọgawhe ele Ju dụ. Jizọsi znernu Bẹtani hne Lazarọsi nwerukna wam o mernu o hi n'ẹnwu lizọ.
\v 2 Be sinu Jizọsi wiri anyasnu, Mata neezne izi, Lazarọsi bụ otu nụ ele Jizọsi dazị neeri wiri.
\v 3 Meri gweru otu olori mọno otute zị gburu ọnu be jiri nadi zị snam mee, ke nwernu ẹknarna ọma wụsi n'ọchi Jizọsi, gweru rukeri-ize a kwnosnama a. Ẹknarna mọno wam jihịa rime ọro.
\p 
\v 4 Otu nụ rime ele sno apna Jizọsi be kwu Judasị Isikarịoti, nye jeere Jizọsi, kaa,
\v 5 “Kịni mernu be réle mọno otute ka riwhu mkpụru ịwai ẹto, kesi ele mboni?”
\p 
\v 6 Ọ bụ́o nụ nhne gbasịri ele mboni neemetụ a nụ mkpọma mernu o jiri kwu kpa. Kọvu kwnornu nụ ọ bụ nye buznu, ya neeji rẹkpa ịwai be, neeri nhne zị a nụ rime.
\p 
\v 7 Jizọsi sarụ a, “Gharụ nwerinya ka, ọ bịtaru ka kwnornu ọbochi be jeeli m.
\v 8 Jị nụ ele mboni zị kpakara ige, me nụ jị jáazị kpakara ige.”
\s1 Be gbarụ iznuznu // o gbu Lazarọsi
\p 
\v 9 Agịda ele Ju nụrnu nụ Jizọsi zị nụ Bẹtani, be va, ọ bụ́o kwnornu Jizọsi kpọi, kọvu ma be whnụrnu Lazarọsi nye Jizọsi mernu o hi n'ẹnwu lizọ.
\v 10 Ele risi arịohna ma mmụma kpa be joogbu Lazarọsi masị.
\v 11 Agịda ele Ju gharụru ele risi ele Ju kweru nụ Jizọsi kwnornu Lazarọsi.
\s1 Jizọsi bnaznernu // Jerusẹlem
\r (Mat 21:1-11; Mak 11:1-11; Luk 19:28-40)
\p 
\v 12 N'ọbochi ke sno a, agịda ele badnụ ele varụ Iriri Ọgawhe nụrnu nụ Jizọsi vawa Jerusẹlem.
\v 13 Be gburu igwugwu bụkwu whọga zne kwnusi a, neesi lụlo,
\q1 “Ozana! \f + \fr 12:13 \fq Ozana \ft n'ikwu-ọnu ele Hiburu, ke bụ “Znọhia!”\f* Chiokike gọzi nye naava nụ rẹwhna Nyenwe aị,
\q2 Chiokike gọzi eze Izirẹli.”
\p 
\v 14 Jizọsi pohịa otu nnwọ ịyinya dazịri n'olu a, lele kpa ọkwukwo nsọ kwuru,
\q1 
\v 15 “Ị tụ́ko ogwnu, jị adna Zayọni,
\q2 Le, eze i gba nnwọ ịyinya naava.”
\p 
\v 16 Ele sno apna a ghọ́yage n'ige wam, kọvu nga Jizọsi hiri n'ẹnwu lizọ n'igwugwu, be chenwanya nhne ọkwukwo nsọ kwuru gbasịri a nụ be mernu a nhne ka.
\p 
\v 17 Agịda ele badnụ wam whnụrnu nga Jizọsi sukwuhịaru Lazarọsi n'ilili, mee ma o hi n'ẹnwu lizọ. Be kahịaru nhne mernu.
\v 18 Ka kpayarụ agịda ele badnụ znekwnusi a, kwnornu nụ be nụrnu nụ ọ rnụrnu ẹrnu ndu-ẹhni ka.
\v 19 Ele Farisi kanụ ibne be, “Le, ọ zá nhne a neemeli, kpakara ọwa sno a n'aznụ.”
\s1 Agwna ele Giriki noopio // Jizọsi
\p 
\v 20 Agwna ele Giriki znernu Jerusẹlem n'ige Iriri wam zne kpọnu Chiokike risi ẹli.
\v 21 Be vakwnusi Filipu nye Bẹtesaida nụ ẹli Galili, kaa, “Nda-aị-kwu, a noopio ọ whnụ Jizọsi.”
\v 22 Filipu zne kanụ Anduru, be lawụru zne kanụ Jizọsi.
\p 
\v 23 Jizọsi sarụ be, “Ige wam valẹm ma be nyee Nnwọ ke Badnụ igwugwu.
\v 24 M kanụ anụ ezi ọka, otu mkpụru ịkpa zị etekne nga be kpásịla a nụ rime n'ẹli. Nga be kpasịri a, ọ nwụma, fuhịa, mịi agịda ike ịkpa berere.
\v 25 Nye ọbula ke nọowhnu bụdnu a n'anya jootuwhu a, kọvu nye sno bụdnu a irno n'ọwa ka jaabịta a dụ bụdnu kwó okwo.
\v 26 Nye ọbula ke nọornunu m ẹrnu joosno m n'aznụ. Hne me zị nnwọ izi m jaazị pịi. Nda m jọosobisinu nnwọ izi m.
\s1 Jizọsi kwuru ọka // gbasịri ẹnwu a
\p 
\v 27 “Kịtna mkpọma m naala mini. Ndaa nhne me jaakaa? M jaakaa, ‘Nda m, i kwékọ ige ka va’? Kọvu ka bụ risi nhne me kwnornu va.
\v 28 Nda m, nyee rẹwhna ị igwugwu.”
\p Otu nkọli hiri n'oligwe dna, kaa, “M nyene m a igwugwu, m jeenye kwno a igwugwu berere.”
\p 
\v 29 Igbudu ele badnụ wam gwuzo pịi kaa, “Egbe oligwe gbarụ.” Ele berere kaa, “Enine izi kwunnu a ọka.”
\p 
\v 30 Kọvu Jizọsi karụ, “Ọ bụ́o kwnornu me nhne nkọli ka kwuru ọka, ọ bụ kwnornu anụ.
\v 31 Kịtna bụ ige be jeekpe ọwa ka ikpe, kịtna be jẹechihala nye risi ke ọwa ka.
\v 32 Kọvu me, ọ bụru nụ be gwelizọ m olu n'ọwa, m jọodoru kpakara badnụ nyee ẹhni m.”
\v 33 O kwuru ka ma o gesi ọkpa ẹnwu ọ jọonwu.
\p 
\v 34 Igbudu ele badnụ wam kaa, “A nụrnu hite n'iwu aị nụ Karaịsi jaazị tim tọm. Ndaa kpa ị naakaa nụ be gwelizọ Nnwọ ke Badnụ olu? Nyele bụ Nnwọ ke badnụ?”
\p 
\v 35 Jizọsi kanụ be, “Anụ jeenwe iwhne ige matị, anụ zne izne nụ rime a, ọ zị ọchichiri vakwnusi anụ. Kwnornu nụ nye neezne izne n'ọchichiri máa nhne o neezne.
\v 36 Anụ tụkwasi ovu n'iwhne kịtna anụ nwernu a, ma anụ bụru rụmu ke iwhne.” Nga Jizọsi kwukworu ọka ka, ọ whọga, tugwa ẹhni a.
\s1 Ókwe ekwe ke ele Ju
\p 
\v 37 Ọ bụ n'ezi nụ Jizọsi rnụrnu kpakara ẹrnu ndu-ẹhni ka n'anya be, be kwéruge nụ ya.
\v 38 Ka bụ ma nhne Azaya nye ọwhnurninya kwuru mezu,
\q1 “Nyenwe aị, nyele kweru izi a ziri,
\q2 ndaa nye Nyenwe aị kpumennu aka dikne a?”
\p 
\v 39 Kwnornu nụ be kwéle, Azaya kwuru nụ hne berere,
\q1 
\v 40 “Chiokike mernu be kpu isni,
\q2 mee mkpọma be bụru nhne nwụrnu ọnwu,
\q1 ma be gharụ o ji anya be whnụ ọsno,
\q2 gweru mkpọma be ghọhia, ma be tụhnasna,
\q2 ma m gwọ m be.”
\p 
\v 41 Ka bụ nhne Azaya kwuru kwnornu nụ ọ whnụrnu igwugwu Jizọsi, o kwu ọka gbasịri a.
\p 
\v 42 N'ige wam agịda ele risi ele Ju kweru nụ Jizọsi, kọvu kwnornu nụ ele Farisi, be nwée rikne kwuhịa nhne gbasịri a, ọ zị be chịhala be n'ọro ọgbako ele Ju.
\v 43 Be mernu kpa, kwnornu nụ be whnụrnu ọznarni ke badnụ n'anya kakwo ọznarni ke Chiokike.
\s1 Ikwu-ọnu Jizọsi // jeekpe ikpe
\p 
\v 44 Jizọsi gweru okne nkọli siwama, kaa, “Nye ọbula ke kweru nụ me, o kwéruge nụ me kpọi, kọvu ma nụ nye ziyaru m.
\v 45 Nye ọbula ke neele m anya jọowhnu nye ziyaru m.
\v 46 M varụ m n'ọwa lele iwhne, ma nye ọbula ke jeekweru nụ me jáadazịgidne n'ọchichiri.
\p 
\v 47 “Nye ọbula ke jọonu ikwu-ọnu m, kọvu zá naabịta be, m jéekpe a ikpe, kwnornu nụ m váge m o kpe ọwa ikpe, kọvu ọ znọhia ọwa.
\v 48 Nye ke zụsaru m, zá naabịta ikwu-ọnu m nwernu nye jeekpe a ikpe. Ikwu-ọnu me kwuru jeekpe a ikpe n'ọbochi ipne-aznụ.
\v 49 Kwnornu nụ m kwúge m ọka ke m, kọvu Nda m nye ziyaru m nyernu m iwu nhne me jaakaa, nụ nhne me jookwu.
\v 50 M magwụ m nhne o nyernu n'iwu bụ bụdnu kwó okwo. Nhne me kwuru bụ nhne Nda m karụ me kwu.”
\c 13
\s1 Jizọsi snụrnu ọchi // ele sno apna a
\p 
\v 1 N'ọbochi ke bọru ọbochi Iriri Ọgawhe, Jizọsi magwụ nụ ige ọ jaaghasa ọwa ka lakwnusi Nda a dụlam. Ọ whnụrnu ele ka ele zị n'ọwa n'anya. Ọ whnụrnu be n'anya dụ ipne-aznụ.
\p 
\v 2 Kpa be neeri wiri anyasnu, Ekwensu yisiri a nụ mkpọma Judasị Isikarịoti nnwọ Saịmoni o re Jizọsi.
\v 3 Jizọsi magwụ nụ Nda a yisilem kpakara nhne n'aka a, nụ o hi hne Chiokike zị va, ọ naalahnakwnusi Chiokike.
\v 4 O lizọ n'olu wiri, wopu iwo olu a, gweru akata kne n'ikwnu a.
\v 5 Ọ wụsi mini nụ rime agbụgba, bete nọosnu ọchi ele sno apna a, gweru akata o kne n'ikwnu nookwnosna be.
\p 
\v 6 O va hne Saịmoni Pita zị, Pita sịkwa a, “Nyenwe aị, ị jọosnu ọchi m?”
\p 
\v 7 Jizọsi sarụ a, “Ị máa nhne me neeme kịtna, kọvu omekwo, ị jaamahịa.”
\p 
\v 8 Pita kaa, “Ị jọ́osnu ọchi m rịa rịa.”
\p Jizọsi sarụ a, “Ọ bụru nụ m snụ́ge m ọchi ị, me nụ jị nwékọ nhne ọbula.”
\p 
\v 9 Pita sarụ a, “Ọ bụru kpam, ị snụ́ ọchi m kpọi, kọvu snụ ma aka m lawụru ma risi m.”
\p 
\v 10 Jizọsi sarụ a, “Nye hnịarnu ẹhni zị rịchna kpam kpam, o kwésile ọ snụ ẹhni a berere, okwolem ọ snụ ọchi a. Kpakara anụ zị rịchna, kọvu ọ bụ́o kpakara anụ.”
\v 11 Kwnornu nụ Jizọsi magwụ nye jeere a, bụ nhne o kwno kaa nụ kpakara be zị rịchna, okwolem otu badnụ kpọi nye zị́la rịchna.
\p 
\v 12 Nga ọ snụkparu be ọchi, o woru iwo olu a berere dazịri ẹli nụ hne ọ zị nụ mbọm. Ọ sịkwa be, “Anụ ghọhiaru nhne me mennu anụ?
\v 13 Anụ noosukwu m Nye-zni-nhne, nụ Nyenwe anụ, ọ bụ ezi ọka, kwnornu nụ ọ nhne me bụ.
\v 14 Kịtna, me bụ Nyenwe anụ nụ Nye-zni-nhne snụrnu ọchi anụ, anụ kwesiri ọ snụrita ọchi ibne anụ.
\v 15 M gesiri m anụ nhne atụ ma anụ mee kpa me mernu.
\v 16 Me kanụ anụ ezi ọka, ọ zá ọhi ke kakwo nyenwe a, ọ zá nnwọ izi ke kakwo nye dusiri a izi.
\v 17 Mkpọma jọoso anụ n'ọnu, ọ bụru nụ anụ mahịaru nhne ka, neeme be.
\p 
\v 18 “M zá m nookwu kwnornu kpakara anụ. M magwụ m ele me họhiaru, kọvu nhne ọkwukwo nsọ kwuru jeemezurịri, ‘Nye riri wiri m lizọru megidne m.’
\v 19 M naakanụ anụ ezi ọka kịtna sị o mee, ma nga o jeeme anụ kweru nụ m bụ m ya.
\v 20 Me kanụ anụ ezi ọka, nye ọbula ke jaanabnanya nye me ziznernu, nabnanyarnụ m, nye nabnanyarnụ m, nabnanyarnụ nye ziyaru m.”
\s1 Jizọsi kwuru ọka // gbasịri o rure a
\r (Mat 26:20-25; Mak 14:17-21; Luk 22:21-23)
\p 
\v 21 Nga Jizọsi kwuru ka, o gbu a igbugbu nụ mkpọma k'agịda, ọ kaa, “Me kanụ anụ ezi ọka, otu badnụ n'esilawụru anụ jeere m.”
\p 
\v 22 Ele sno apna a lehnata ẹhni be anya. Be máa nye ọ naakaa.
\v 23 Otu nye sno apna a Jizọsi whnụrnu n'anya ke dazị Jizọsi ndụndu n'ẹhni.
\v 24 Saịmoni Pita kanụ a, “Sịkwahia a nye ọ bụ.”
\p 
\v 25 Nye sno apna wam dnabnernu nụ mkpọma Jizọsi sịkwa a, “Nyenwe aị, ọ bụ nyele?”
\p 
\v 26 Jizọsi sarụ a, “Ọ bụ nye me jeerusi brẹdi ka nụ rime wiri nyee.” O gweru otu ibekala brẹdi, rusi a nụ wiri nyee Judasị, nnwọ Saịmoni Isikarịoti.
\v 27 Ngangam Judasị gweruru brẹdi wam, Ekwensu bna nụ rime a. Jizọsi kanụ a, “Ọ zị nhne i neeme, mee a wara wara.”
\v 28 Ọ zá nye zị pịi neeri wiri mahịaru nhne Jizọsi nookwu.
\v 29 Hne ọ bụ Judasị vugwu rẹkpa ịwai, agwna ele sno apna Jizọsi neeche nụ Jizọsi kannụ a o zne zụya nhne be jeeri n'Iriri wam, mọbu o kesi ele mboni ịwai.
\v 30 Judasị narnụ brẹdi wam, ọ whọga ngangam. Ka neeme n'abalị.
\s1 Iwu ikne
\p 
\v 31 Nga Judasị whọgaru, Jizọsi kaa, “Kịtna, be jeenye Nnwọ ke Badnụ igwugwu, be jeenye masị Chiokike igwugwu nụ rime a.
\v 32 Ọ bụru nụ be nyee Chiokike igwugwu nụ rime a, Chiokike jeenye Nnwọ a igwugwu n'iwhuru a. O jeeme a kịtna.
\p 
\v 33 “Rụmu m, me nụ anụ jáazị gbu ọkwnu. Anụ joopio m, kọvu me kanụ anụ nhne me kannụ ele risi ele Ju, anụ jéenwe rikne va hne me neezne.
\p 
\v 34 “M neenye anụ iwu ikne, anụ whnụ ibne anụ n'anya. Lele kpa me whnụrnu anụ n'anya, anụ ji ọgwo ọ whnụ ibne anụ n'anya.
\v 35 Kpakara ele badnụ jaamahịa nụ anụ bụ ele sno apna m, ọ bụru nụ anụ whnụ ibne anụ n'anya.”
\s1 Jizọsi kwuru nụ Pita // jọogonahoru a
\r (Mat 26:31-35; Mak 14:27-31; Luk 22:31-34)
\p 
\v 36 Saịmoni Pita sịkwa a, “Nyenwe aị, i zne hnele?”
\p Jizọsi sarụ a, “Anụ jéenwe rikne sno m hne me neezne kịtna, kọvu omekwo, anụ joosno m.”
\p 
\v 37 Pita sịkwa a, “Kịni mernu me jéenwe rikne sno i kịtna? M jọonwunu ị ẹnwu.”
\p 
\v 38 Jizọsi sarụ a, “Ị jọonwu kwnornu m n'ezi? Me kanụ i ezi ọka, sụ okne ọchichi kwna ẹkwna, ị jọogonahoru m mgba ẹto.”
\c 14
\s1 Jizọsi bụ apna
\p 
\v 1 “Mkpọma lákwadia anụ mini. Anụ kweru nụ Chiokike, anụ kweru masị nụ me.
\v 2 Agịda ọro jiri n'ọro Nda m, m naala zne mekwatanụ anụ ọnodi. Ọ bụru ọ bụ́o kpam, m znernu m ọkanu anụ.
\v 3 Me zne mekwatanụ anụ ọnodi, m jeehiehna, kwuru anụ yisi n'ẹhni m, ma me nụ anụ dazịri n'otu hnanụm.
\v 4 Anụ magwụ apna hne me neezne.”
\p 
\v 5 Tọmosi kanụ a, “Nyenwe aị, a máa hne i neezne, ndaa kpa a jaamahịa apna a?”
\p 
\v 6 Jizọsi sarụ a, “Mawa bụ apna nụ ezi ọka nụ bụdnu. Ọ zá nye jeezne hne Nda m zị okwokọlam ma o hiri nụ me.
\v 7 Ọ bụru nụ ị magwụ m n'ezi, ị jaamahịa Nda m masị. Hite kịtna anụ magwụ Nda m, anụ whnụna a anya.”
\p 
\v 8 Filipu kaa, “Nyenwe aị, gesi aị Nda ị, o joozunu aị.”
\p 
\v 9 Jizọsi sarụ a, “Filipu, me nụ anụ zị ogologo ige ka, ị máa nye me bụ? Nye ọbula ke whnụrnu m, whnụnam Nda m. Ndaa kpa ị naakaa, ‘Gesi aị Nda.’
\v 10 Ọ bụru nụ ị kwége sa nụ m zị m nụ rime Nda m, Nda m zị nụ rime m? Ikwu-ọnu me nookwu bụ́o ke m. Nda m ke zị nụ rime m nọornu ẹrnu a.
\v 11 Anụ kweru nga me karụ nụ m zị m nụ rime Nda m, Nda m zị nụ rime m. Ọ bụru nụ ọ zá nhne berere, anụ kweru kwnornu nụ ẹrnu ele ka.
\v 12 Me kanụ anụ ezi ọka, nye ọbula ke kweru nụ me jọornu ẹrnu me nọornu. Owe! Ọ jọornu ẹrnu ke kakwo ka kwnornu nụ m naalakwnusi Nda m.
\v 13 Kpakara nhne anụ jọorio nụ rẹwhna m, m jeeme a, ma be nyee Nda igwugwu hite nụ Nnwọ a.
\v 14 Nhne ọbula anụ rịoru nụ rẹwhna m, m jeeme a.
\s1 Jizọsi kweru mkwna // Enine Nsọ
\p 
\v 15 “Ọ bụru nụ anụ whnụrnu m n'anya, anụ jaabịta nhne me nyernu n'iwu.
\v 16 M jaarịasno Nda m, o jeenye anụ Nye Ọkasi Mkpọma berere, nye jaadazịnu anụ tim tọm.
\v 17 Ọ bụ Enine ezi ọka, ke ọwa jáanahịali, kwnornu nụ ele zị n'ọwa nwée rikne whnụ a mọbu mahịa a. Kọvu anụ magwụ a, kwnornu nụ o wu nụ rime anụ, ọ jaadazịgidnenu anụ.
\v 18 M jáagharụ anụ etekne, m jeehiehnakwnusi anụ.
\v 19 Ige matị ọwa jọ́owhnu m, kọvu anụ jọowhnu m. M zị m bụdnu, kam kpayarụ anụ jaazị masị bụdnu.
\v 20 N'ọbochi wam, anụ jaamahịa nụ m zị m nụ rime Nda m, anụ nụ rime m, lele kpa me zị nụ rime anụ.
\p 
\v 21 “Nye ọbula ke jaabịta nhne me nyernu n'iwu, bụ nye whnụrnu m n'anya. Nye whnụrnu m n'anya bụ nye Nda m jọowhnu n'anya, m jọowhnu masị a n'anya, gweru ẹhni m gesi a.”
\p 
\v 22 Judasị (ọ bụ́o Isikarịoti) kaa, “Nyenwe aị, ndaa kpa i jeegesi aị ẹhni ị, ọ bụ́o ele ọwa?”
\p 
\v 23 Jizọsi sarụ a, “Nye ọbula ke whnụrnu m n'anya, jaabịta ikwu-ọnu m. Nda m jọowhnu a n'anya, me nụ Nda m jaavakwnusi a, aị nụ ya joowu.
\v 24 Nye ọbula ke whnụ́ge m n'anya, jáabịta ikwu-ọnu m. Ikwu-ọnu ke anụ nụrnu bụ́o ke m. Be hi n'aka Nda m, nye ziyaru m.
\p 
\v 25 “M naakanụ anụ ka kpa me nụ anụ zị.
\v 26 Kọvu Nye Ọkasi Mkpọma wam, Enine Nsọ, nye Nda m jeeziyanu anụ nụ rẹwhna m, jeezni anụ kpakara nhne. O jeeme anụ chenwanya kpakara nhne me znirni anụ.
\v 27 M nẹesigbasinu anụ udno, m neenye anụ udno m, ọ bụ́o lele kpa ọwa neenye bụ kpa me neenye anụ. Mkpọma lákwadia anụ mini. Anụ tụ́ko ogwnu.
\p 
\v 28 “Anụ nụrnu kpa me karụ nụ m jaala, kọvu m jeehiehnakwnusi anụ. Ọ bụru nụ anụ whnụrnu m n'anya, anụ znernu ọnwudna, kwnornu nụ m naalakwnusi Nda m, kwnornu nụ Nda m kakwo m.
\v 29 M kannụ m anụ kịtna hne o yéemege, ma nga o jeeme anụ kweru.
\v 30 M jáakanụ anụ agịda ọka berere, kwnornu nụ nye nẹechi ọwa ka vawa. Kọvu o nwée rikne hne me zị.
\v 31 Kọvu ọwa jaamahịa nụ m whnụrnu Nda m n'anya, bụ nhne kpayarụ me neeme kpakara nhne lele kpa o nyernu m iwu. Anụ va ma a whọga hna.
\c 15
\s1 Isisi vaịni nụ nkala a
\p 
\v 1 “Mawa bụ isisi vaịni n'ezi, Nda m bụ nye ẹrnu ẹkwu.
\v 2 Nkala ọbula ke mị́ge mkpụru nụ rime m, o gbukwama a. Ọ kwnasna nkala ọbula ke naamị mkpụru ma ọ mịnya agịda mkpụru, ma ọ zịri rịchna.
\v 3 Anụ zị rịchna hite n'ikwu-ọnu me kwuru.
\v 4 Anụ dazịgidne nụ rime m, me nụ rime anụ. Ọ zá nkala ke nwernu rikne mịi mkpụru n'ẹhni a, okwolem ma ọ zị n'isisi, otu aka wam, anụ nwée rikne mịi mkpụru, okwolem ma anụ dazịgidnernu nụ rime m.
\p 
\v 5 “Mawa bụ isisi vaịni, anụwa bụ nkala a. Nye ọbula ke jaadazịgidne nụ rime m, me nụ rime a, jaamị agịda mkpụru, kwnornu nụ anụ nwée rikne meli nhne ọbula hne me zị́la.
\v 6 Nye ọbula ke dázịgidnene nụ rime m, be jootuwhu a lele nkala ke mị́ge mkpụru. Ọ kpọnwu, ele badnụ chịkota kpọrne a nụ bẹkwnu.
\v 7 Ọ bụru nụ anụ dazịgidne nụ rime m, ikwu-ọnu m dazịgidne nụ rime anụ, anụ jọorio nhne ọbula zị anụ mkpa, ọ jọoburu ke anụ.
\v 8 Ka bụ nhne neenye Nda m igwugwu, anụ mịnya agịda mkpụru, ke jeegesi nụ anụ bụ ele sno apna m.
\p 
\v 9 “Lele kpa Nda m whnụrnu m n'anya, bụ kpa me whnụrnu anụ n'anya. Anụ dazịgidne n'ọwhnun'anya m.
\v 10 Ọ bụru anụ bịta nhne me nyernu n'iwu, anụ jaadazịgidne n'ọwhnun'anya m, lele kpa me bịtaru nhne Nda m nyernu n'iwu, m dazịgidne n'ọwhnun'anya a.
\v 11 M naakanụ anụ nhne ka ma ovu ọso n'ọnu m zịri nụ rime anụ, ma ovu ọso n'ọnu anụ zu ozu.
\v 12 Ka bụ nhne me nyernu n'iwu, anụ whnụrita ibne anụ n'anya lele kpa me whnụrnu anụ n'anya.
\v 13 Ọ zá ọwhnun'anya ke kakwo ka, nụ badnụ tuwhuru bụdnu a kwnornu ele enyi a.
\v 14 Anụ bụ ele enyi m, ọ bụru nụ anụ mee nhne me nyernu n'iwu.
\v 15 M zá m noosukwu anụ ele izi berere, kwnornu nụ nnwọ izi máa nhne nyenwe a neeme. Kọvu m sukwuru m anụ ele enyi m, kwnornu nụ kpakara nhne me nụrnu n'ọnu Nda m bụ nhne me kannụ anụ.
\v 16 Ọ bụ́o anụ họhiaru m, kọvu me họhiaru anụ, bịta anụ ichne, ma anụ zne mịnya mkpụru, ma mkpụru anụ dazịgidne. Ka jeeme, nhne ọbula anụ jọorio Nda m nụ rẹwhna m, o jeenye anụ.
\v 17 Ka bụ nhne me nyernu n'iwu, anụ whnụrita ibne anụ n'anya.
\s1 Ọwa snornu ele sno apna // Jizọsi irno
\p 
\v 18 “Ọ bụru n'ọwa sno anụ irno, anụ chenwanya nụ o beru ọsno sno m irno.
\v 19 Ọ bụru nụ anụ bụ ke ọwa, ọwa jọowhnu anụ n'anya lele nhne ke a. Kọvu m họhiaru m anụ hite n'ọwa, anụ bụ́o ke ọwa, ka kpayarụ ọwa snornu anụ irno.
\v 20 Anụ chenwanya nhne me kannụ anụ, Ọ zá ọhi ke kakwo nyenwe a. Ọ bụru nụ be kpaknarnụ m ẹhni, be jaakpakna anụ ẹhni masị. Ọ bụru nụ be bịtaru ikwu-ọnu m, be jaabịta ke anụ.
\v 21 Be jeeme anụ kpakara nhne ka kwnornu nụ anụ kweru nụ rẹwhna m, be máa nye ziyaru m.
\v 22 Ọ bụru nụ m váge m kwunu be ọka, ikpe mmehie báamana be. Kịtna be jeeji kịni gọhoru ẹhni be hite nụ mmehie?
\v 23 Nye ọbula ke snornu m irno, snornu Nda m irno.
\v 24 Ọ bụru nụ m rnụ́ge m ẹrnu n'esilawụru be ke ọ zá nye berere rnụrnu, ikpe mmehie báamana be. Kịtna be whnụrnu nhne me rnụrnu, be sno me nụ Nda m irno.
\v 25 Ka bụ ma nhne be gbarụ n'ọkwukwo nsọ mezu, ‘Be snornu m irno hne ọ zá nhne me mernu be.’
\p 
\v 26 “Nga Nye Ọkasi Mkpọma wam varụ, Enine ke ezi ọka, Nye me jeeziya hite nụ hne Nda m zị, nye hi hne Nda m zị va, ọ jaagbanụ m akebne.
\v 27 Anụ jọobu masị ele akebne m kwnornu nụ me nụ anụ zị hite n'ọpanizo.
\c 16
\p 
\v 1 “M kannụ m anụ kpakara nhne ka ọ zị anụ dnahnala hite n'ọkwnata ovu anụ.
\v 2 Be jaachịhala anụ n'ọro ọgbako ele Ju, ige vawa nga nye ọbula ke gburu anụ jeeche nụ ọ nọornu ẹrnu Chiokike.
\v 3 Be jeeme anụ nhne nụ kpa kwnornu nụ be máa Nda m mọbu me.
\v 4 M kannụ m anụ nhne ele ka, ma nga be jeeme anụ chenwanya nụ m kannụ m anụ nhne gbasịri be. M káge m be nụ mbọm kwnornu nụ me nụ anụ zị.
\s1 Ẹrnu ke Enine Nsọ
\p 
\v 5 “Kịtna, m naalahna hne nye ziyaru m zị. Kọvu ọ zá nye n'esilawụru anụ nẹesikwa m, ‘Ndaa hne i neezne?’
\v 6 Kịtna me kannụ anụ, o noogbu anụ igbugbu nụ mkpọma.
\v 7 Kọvu me kanụ anụ ezi ọka, ọ kanụ anụ mma me lahna, kwnornu nụ ọ bụru m láge m, Nye Ọkasi Mkpọma wam jáavakwnusi anụ. Kọvu me la, m jeeziyanu anụ ya.
\v 8 Nga ọ varụ, ọ jaabanụ ọwa mbna kwnornu mmehie, nụ ome mma nụ ikpe.
\v 9 Ọ jaabanụ ọwa mbna gbasịri mmehie, kwnornu nụ be kwége nụ me,
\v 10 gbasịri ome mma, kwnornu nụ m naalakwnusi Nda m, anụ jọ́owhnuma m anya berere,
\v 11 gbasịri ikpe, kwnornu nụ ikpe hieru nye risi nẹechi ọwa ka.
\p 
\v 12 “Agịda nhne zị ke me jaakanụ anụ, kọvu anụ jéenwe rikne vuru be kịtna.
\v 13 Kọvu nga Enine ezi ọka wam varụ, o jooduru anụ bna nụ kpakara ezi ọka. O jóokwu nhne aka ke a, kọvu kpakara nhne ọ jọonu bụ nhne ọ jaakanụ anụ. Ọ jaakanụ anụ nhne ke jaava nụ ruwhnu.
\v 14 O jeenye m igwugwu kwnornu o jeegweru nhne me kwuru kanụ anụ.
\v 15 Kpakara nhne Nda m nwernu bụ ke m. Ọ bụ nhne me jiri kaa nụ Enine Nsọ jeegweru nhne ke m kanụ anụ.
\s1 Nhne igbugbu nụ snarnịma
\p 
\v 16 “Ige matị anụ jọ́owhnu m berere, omekwo, ige matị anụ jọowhnu m.”
\p 
\v 17 Agwna ele sno apna a nẹesikwarita ibne be, “Kịni bụ risi nhne ka? Ọ karụ, ‘Ige matị anụ jọ́owhnu m, ige matị anụ jọowhnu m,’ berere, ‘M naalakwnusi Nda m.’ ”
\v 18 Be nẹesikwarita ibne be, “Kịni bụ ige matị? A máa nhne o nookwu ọka a.”
\p 
\v 19 Jizọsi whnụrnu nụ be noopio ọ sịkwa a, ọ kanụ be, “M karụ m ige matị anụ jọ́owhnu m, omekwo, ige matị anụ jọowhnu m. Ọ bụ nhne anụ nẹesikwarita n'esilawụru anụ?
\v 20 Me kanụ anụ ezi ọka, anụ jaakwna ẹkwna, gba mkpe, kọvu ọwa jọonwudna. Anụ jeenwe nhne igbugbu, kọvu nhne igbugbu anụ jọogho ovu ọso n'ọnu.
\v 21 Nga nyerinya nọomu nnwọ, ọ zị nụ nhne igbugbu kwnornu nụ rime neeme a, kọvu nga ọ mụdnarnu nnwọ, o chezu kpakara nhne igbugbu a, kwnornu snarnịma nụ ọ mụrnu nnwọ ikne n'ọwa.
\v 22 Kpam masị, anụ nwernu nhne igbugbu kịtna, kọvu m jọowhnu anụ anya berere, anụ jeenwe snarnịma, ọ zá nye jeenwe rikne nahọru anụ ovu ọso n'ọnu anụ.
\v 23 N'ọbochi wam, anụ jọ́orio m nhne ọbula, me kanụ anụ ezi ọka, Nda m jeenye anụ nhne ọbula anụ jọorio a nụ rẹwhna m.
\v 24 Tem dụ kịtna, ọ zá nhne ọbula anụ rịoru nụ rẹwhna m. Anụ rịo, anụ jenwehịa, ma ovu ọso n'ọnu anụ zu ozu.
\s1 Mmeri megidne ọwa
\p 
\v 25 “M ji m elulu kwunu anụ ọka, ige vawa nga me jóokwunu anụ ọka n'elulu berere. M jookwunu anụ ọka zị snam nhne gbasịri Nda m.
\v 26 N'ọbochi wam, anụ jọorio nhne nụ rẹwhna m, m jáakaa nụ m jọorio Nda m nụ risi anụ.
\v 27 Kwnornu nụ Nda m n'iwhuru a whnụrnu anụ n'anya, kwnornu nụ anụ whnụrnu m n'anya, anụ kweru nụ m hi m hne Chiokike zị va.
\v 28 M hi m hne Nda m zị va bna n'ọwa, kịtna, m nẹesigbasi ọwa naalahna hne Nda m zị.”
\p 
\v 29 Ele sno apna a kaa, “Kịtna, ị nookwunu aị ọka dnornu aị anya, ị zá nookwu n'elulu.
\v 30 Kịtna a magwụ nụ i magwụ kpakara nhne. Ọ zá mkpa nụ nye ọbula sịkwa ị ajịji. Ka mernu a kweru nụ ị hi hne Chiokike zị va.”
\p 
\v 31 Jizọsi sarụ be, “Anụ kweru kịtna?
\v 32 Ige vawa, ige wam valẹm, nga be jẹechisa kpakara anụ, nye ọbula n'ọro ke a. Anụ jẹesigbasi me nụ nsnụnu m, kọvu m zá m nụ nsnụnu m, kwnornu nụ me nụ Nda m zị.
\p 
\v 33 “M kannụ m anụ nhne ka ma anụ nwe udno nụ rime m. N'ọwa anụ jeenwe mmekpẹhni, kọvu mkpọma si anụ rikne, m megbulem ọwa.”
\c 17
\s1 Jizọsi kpennu ele sno apna a // okpukpe
\p 
\v 1 Nga Jizọsi kwukworu ọka ele ka, o lelizọ anya n'oligwe, kaa,
\p “Nda m, ige wam valẹm, nyee Nnwọ ị igwugwu, ma Nnwọ ị nyee i igwugwu.
\v 2 I nyernu a iknernema nụ hne kpakara ele badnụ zị, ma o kesi kpakara ele ke i nyernu a bụdnu kwó okwo.
\v 3 Ka bụ bụdnu kwó okwo, ma ele badnụ mahịa ị, ị bụ otu Chiokike ke bụ ezi, nụ Jizọsi Karaịsi nye i ziyaru.
\v 4 M nyernu m ị igwugwu n'ọwa hite n'ọrnukpa ẹrnu i nyernu m me rnụ.
\v 5 Kịtna Nda m, nyee m igwugwu nụ ruwhnu ị, bụ igwugwu ke me nwernu sụ ị kpụru ọwa.
\p 
\v 6 “M mernu ele badnụ mahịa rẹwhna ị bụ ele i nyernu m hite n'ọwa. Be bụ ele ke i. Jị nyernu m be. Be bịtaru ikwu-ọnu ị.
\v 7 Kịtna, be magwụ nụ kpakara nhne i nyernu m hi n'aka ị va.
\v 8 M nyernu m be ikwu-ọnu ke i nyernu m. Be gweru a, be magwụ n'ezi nụ m hi m hne ị zị whụya, be kweru nụ jị ziyaru m.
\v 9 M neekpenu be okpukpe. M zá m neekpenu ọwa okpukpe, kọvu ele wam i nyernu m, kwnornu nụ be bụ ke i.
\v 10 Kpakara nhne me nwernu bụ ke i, kpakara nhne i nwernu bụ ke m masị, be bụ igwugwu m.
\v 11 M zị́ma m n'ọwa berere, kọvu be zị n'ọwa, m naavakwnusi ị, Nda zị nsọ, bịkwata be hite nụ rikne ke rẹwhna ị, rẹwhna ke i nyernu m, ma be zịri n'otu lele kpa a zị n'otu.
\v 12 Nga me nụ be zị, m bịtaru m be nụ rẹwhna ị, bụ rẹwhna ke i nyernu m, m segidnernu m be. Ọ zá nye whuru owhu nụ rime be, okwokọlam nye wam whuzne owhuzne, ma nhne be gbarụ n'ọkwukwo nsọ mezu.
\p 
\v 13 “M naavakwnusi ị kịtna, m nookwu nhne ka n'ọwa ma be nwernu ovu ọso n'ọnu m, ma ovu ọso n'ọnu be zu ozu.
\v 14 M nyernu m be ikwu-ọnu ị, ọwa snornu be irno kwnornu nụ be bụ́o ke ọwa, lele kpa me bụ́o ke ọwa.
\v 15 M zá m naakaa jị gweme be n'ọwa. Kọvu m nọorio ị ma ị bịta be zọma n'aka nye ọjo wam.
\v 16 Be bụ́o ke ọwa, lele kpa me bụ́o ke ọwa.
\v 17 Bịta be nsọ hite n'ezi ọka ị, ikwu-ọnu ị bụ ezi ọka.
\v 18 Lele kpa i ziyaru m n'ọwa, bụ kpa me neezizne be n'ọwa.
\v 19 M kwnornu be bịta ẹhni m nsọ, ma be bịta be nsọ n'ezi ọka.
\p 
\v 20 “M zá m neekpenu be okpukpe kpọi, kọvu m neekpekọtanu ele jeekweru nụ me hite n'ikwu-ọnu be.
\v 21 M neekpe ma kpakara be zịri n'otu, Nda m, lele kpa ị zị nụ rime m, me nụ rime i. Kpakara be zịri n'otu ma ọwa kweru nụ jị ziyaru m.
\v 22 M nyernu m be igwugwu ke i nyernu m, ma be zịri n'otu lele kpa a zị n'otu.
\v 23 Me zịri nụ rime be, jị nụ rime m, ma be zu ozu n'ọzi n'otu, ma ọwa mahịa nụ jị ziyaru m, nụ ị whnụrnu be n'anya lele kpa ị whnụrnu m n'anya.
\p 
\v 24 “Nda m, jị nyernu m be, m noopio be dazịri hne me zị, ma be whnụ igwugwu m, ka bụ igwugwu ke i nyernu m kwnornu nụ ị whnụrnu m n'anya sị ị kpụru ọwa.
\p 
\v 25 “Nda ke mee mma, ọwa máa nye ị bụ, kọvu m magwụ m nye ị bụ, ele ka magwụ masị nụ jị ziyaru m.
\v 26 M mernu m be mahịa ị, m jaazị neeme kpam ma ọwhnun'anya ke ị whnụrnu m zịri nụ rime be, ma me nụ be bụru otu.”
\c 18
\s1 Be nwudnernu Jizọsi
\r (Mat 26:47-56; Mak 14:43-50; Luk 22:47-53)
\p 
\v 1 Nga Jizọsi kpekworu okpukpe ka, ya nụ ele sno apna a whọga whe mini Kidirọni. Be bna n'otu ẹkwu ke zị pịi.
\p 
\v 2 Judasị nye reru a magwụ pịi, kwnornu nụ Jizọsi nụ ele sno apna a neezne pịi ige ọbula.
\v 3 Judasị chịri ele ọgwnu nụ ele neese Ọro Nsọ Chiokike, ele ele risi arịohna nụ ele Farisi ziznernu, be vu tọnji nụ ọwa, nụ mgwna ọgwnu.
\p 
\v 4 Kpa Jizọsi magwụ kpakara nhne jaadnakwasị a, o znekwnusi be, sịkwa be, “Anụ noopio nyele?”
\p 
\v 5 Be kaa, “Jizọsi, nye Nazarẹti.”
\p Jizọsi kaa, “Ọ bụ mawa.” Judasị nye reru a nụ be gwuzo.
\v 6 Nga Jizọsi karụ, “Ọ bụ mawa,” Be lahna aznụ, dna n'ẹli.
\p 
\v 7 Jizọsi sịkwa kwno be, “Ndaa nye anụ noopio?”
\p Be kaa, “Jizọsi, nye Nazarẹti.”
\p 
\v 8 Jizọsi kanụ be, “M kannụ m anụ nụ me bụ ya. Ọ bụru nụ anụ noopio m, anụ gharụ ele ka ma be la.”
\v 9 Ka bụ ma nhne o kwuru mezu, “Kpakara ele i nyernu m, ọ zá otu ke me tuwhuru.”
\p 
\v 10 Saịmoni Pita ji ama-ọgwnu, ọ mnịohia a, gbu nye izi nye risi arịohna, bihala a nsnị akarikwnunga. Rẹwhna nye izi wam bụ Makọsi.
\p 
\v 11 Jizọsi kanụ Pita, “Mnịohnasi ama-ọgwnu ị n'ọbo a. Ọ bụ nụ m jọ́onwo okiko awhnụwhnu Nda m nyernu m me nwọ?”
\s1 Jizọsi gwuzo nụ // ruwhnu Anasị
\r (Mat 26:57,58; Mak 14:53,54; Luk 22:54)
\p 
\v 12 Ele ọgwnu nụ nye risi be, nụ ele neese Ọro Nsọ Chiokike nwudne Jizọsi, be kne a eriri.
\v 13 Be beru ọsno gwezne a nụ ruwhnu Anasị, nda nnwerne Kayafasị, nye risi arịohna n'awha wam.
\v 14 Ọ bụ Kayafasị nye kannụ ele Ju nụ ọ bụru ọma otu badnụ nwụhianu kpakara be ẹnwu.
\s1 Pita gọnahoru Jizọsi
\r (Mat 26:69,70; Mak 14:66-68; Luk 22:55-57)
\p 
\v 15 Saịmoni Pita nụ nye sno apna Jizọsi ke berere snornu Jizọsi. Nye risi arịohna magwụ nye sno apna a ka, o snornu Jizọsi bna n'ederezi nye risi arịohna.
\v 16 Kọvu Pita dazịri nụ ngeri mgbo n'ederezi, nye sno apna wam ke nye risi arịohna magwụ zne kanụ nnwọ rinya zị n'ọnu-mgbo, o kwubnanya Pita.
\p 
\v 17 Nnwọ rinya zị n'ọnu-mgbo kanụ Pita, “Ị bụ otu nụ rime ele sno apna nwerukna ka.”
\p Pita sarụ, “M bụ́la m.”
\p 
\v 18 Iyi nọotu, ele izi nụ ele neese nhne kpawhụsi bẹkwnu, be gwuzoru gburugburu bẹkwnu wam naakwna iyi. Pita gwuzo masị n'esilawụru be, naakwna iyi.
\s1 Nye risi arịohna // nẹesikwa Jizọsi ajịji
\r (Mat 26:59-66; Mak 14:55-64; Luk 22:66-71)
\p 
\v 19 Nye risi arịohna sịkwa Jizọsi ajịji gbasịri ele sno apna a, nụ nhne o neezni.
\p 
\v 20 Jizọsi sarụ a, “M kwuru m ọka nụ ogbo ọhna, kpakara nhne me znirni bụ n'ọro ọgbako ele Ju nụ n'Ọro Nsọ Chiokike hne kpakara ele Ju naagbakọ. Ọ zá nhne me kwuru nụ mgwụgwa.
\v 21 Ị sị́kwa m ajịji, sịkwa ele nụrnu nhne me kwuru. Be magwụ masị nhne me kwuru.”
\p 
\v 22 Nga Jizọsi kwuru ka, otu nye neese nhne gbọ a aka, kaa, “Kịni mernu i nookwunu nye risi arịohna ọka kpa?”
\p 
\v 23 Jizọsi sarụ a, “Ọ bụru nụ m kwuru m nhne bụ́o ọma, gba akebne nhne ọjo me kwuru. Kọvu ọ bụru nụ m kwuru m ezi ọka, kịni mernu ị gbọru m aka?”
\v 24 Anasị zizne a ke Kayafasị nye risi arịohna, hne o kne kọriri eriri.
\s1 Pita gọnahoru Jizọsi // berere
\r (Mat 26:71-75; Mak 14:69-72; Luk 22:58-62)
\p 
\v 25 Kpa Saịmoni Pita gwuzo naakwna iyi, be sịkwa a, “Ị bụ́o otu nụ rime ele sno apna a sa?”
\p Pita gọ, kaa, “M bụ́la m.”
\p 
\v 26 Otu nụ rime ele izi nye risi arịohna nwene nwerukna wam Pita bihalaru nsnị a, gwelizọ ọnu, sịkwa a, “Ọ bụ́o jị nye me whnụrnu n'ẹkwu wam?”
\v 27 Berere kwno, Pita gọ, ngangam, okne ọchichi kwna ẹkwna.
\s1 Jizọsi gwuzo nụ // ruwhnu Paịleti
\r (Mat 27:1,2,11-14; Mak 15:1-5; Luk 23:1-5)
\p 
\v 28 Be hi n'ọro Kayafasị kwuru Jizọsi zne n'ọbna nye ọchichi, n'ọnu ọsisi. Ele Ju bnána nụ rime n'ọbna kwnornu nụ be noopio ọ bịta ẹhni be rịchna ma be nwe rikne ri Iriri Ọgawhe.
\v 29 Paịleti whọkwnusi be n'ederezi sịkwa be, “Ndaa nhne anụ noobno nwerukna ka?”
\p 
\v 30 Be sarụ a, “Ọ bụru nụ ọ bụ́o nye aghorome, a znéne okwuyanụ ị ya.”
\p 
\v 31 Paịleti kaa, “Anụ kwuru a kpe a ikpe lele kpa iwu anụ kwuru.”
\p Be kaa, “A nwée rikne gbu nye ọbula.”
\v 32 Ka bụ ma nhne Jizọsi kwuru mezu ke gbasịri ọkpa ẹnwu ọ jọonwu.
\v 33 Paịleti lahna n'ọbna, sịkwa Jizọsi, “Ị bụ eze ele Ju?”
\p 
\v 34 Jizọsi sịkwa a, “Kị ọ bụ echiche i, sọbu ele berere kannụ nhne gbasịri m?”
\p 
\v 35 Paịleti sa a, “M bụ nye Ju? Ọ bụ ele ke i nụ ele risi arịohna be kwuyannụ m jị. I mernu kịni?”
\p 
\v 36 Jizọsi kaa, “Ẹli-eze m bụ́o ke ọwa ka. Ọ bụru nụ ọ bụ ke ọwa ka, ele izi m znernu ọlu ọgwnu ma ele risi ele Ju gharụ o gweru m nyee n'aka be. Ọ zá, ẹli-eze m bụ́o ke ọwa ka.”
\p 
\v 37 Paịleti sịkwa a, “Ke bụ nụ ị bụ eze?”
\p Jizọsi sarụ a, “Jịwa karụ nụ m bụ m eze. Ka bụ risi nhne be kwnornu mụ m nụ nhne me kwnornu va nụ rime ọwa, ma m gbanụ m ezi ọka akebne. Nye ọbula ke zị n'ezi ọka noobnonu m nsnị.”
\p 
\v 38 Paịleti sịkwa a, “Kịni bụ ezi ọka?”
\s1 Be marnụ Jizọsi ikpe ẹnwu
\r (Mat 27:15-31; Mak 15:6-20; Luk 23:13-25)
\p Paịleti whọkwnusi kwno ele risi ele Ju n'ederezi kanụ be, “Ọ zá nhne ọjo me whnụrnu nụ rime nwerukna ka rịa rịa.
\v 39 Ọ bụ omen'ẹli anụ me sịgbasinu anụ otu nye ikelu n'ige Iriri Ọgawhe. Anụ pioru me sịgbasinu anụ eze ele Ju?”
\p 
\v 40 Kpakara be siwama, “Ọ́za, ọ bụ́o nwerukna ka, sịgbasinu aị Barabasị.” (Barabasị bụ nye buznu.)
\c 19
\p 
\v 1 Paịleti kwuru Jizọsi pnịa nhne.
\v 2 Ele ọgwnu kpa okpu igwnu kpusi a nụ risi, be wosi a iwo odno odno.
\v 3 Be znekwnusi a, kaa, “A bekwulem jị, Eze ele Ju.” Be gbọ aka nụ ruwhnu.
\p 
\v 4 Paịleti lahna kwno hne ele risi ele Ju zị, ọ kanụ be, “Anụ le, m jookwuyanu anụ ya, ma anụ marnụ nụ ọ zá nhne ọjo me whnụrnu nụ rime a.”
\v 5 Jizọsi woru iwo odno odno nụ okpu igwnu whụya ederezi, Paịleti kanụ be, “Anụ le nwerukna wam.”
\p 
\v 6 Nga ele risi arịohna nụ ele neese Ọro Nsọ Chiokike whnụrnu a, be siwama, “Kpọgidne a n'ọgba, kpọgidne n'ọgba.”
\p Paịleti kanụ be, “Anụ kwuru a kpọgidne a n'ọgba n'aka anụ. Kọvu me kanụ anụ, ọ zá nhne ọjo me whnụrnu nụ rime a.”
\p 
\v 7 Ele risi ele Ju kwusi rikne, “A nwernu iwu, iwu aị kwuru nụ o kwesiri ẹnwu kwnornu nụ ọ kanụ nụ ọ bụ Nnwọ Chiokike.”
\p 
\v 8 Nga Paịleti nụrnu ka, ọ tụ ogwnu k'agịda.
\v 9 Ọ lahna kwno n'ọbna, ọ sịkwa Jizọsi, “Ndaa hne i hi va?” Kọvu Jizọsi sála a ọka ọbula.
\v 10 Paịleti kanụ a, “Ị zá naasa m ọka, ọ bụ nụ ị máa nụ m nwernu m rikne ọ sịgbasi ị mọbu ọ kpọgidne i n'ọgba?”
\p 
\v 11 Jizọsi kaa, “Ị béenwene rikne megidne m ọ bụru nụ be nyéne i rikne hite n'oligwe, nye kwuru m nyee n'aka i nwe mmehie ke kakwo.”
\p 
\v 12 Nga Paịleti nụrnu ka, ọ gbalị ọ sịgbasi Jizọsi. Kọvu ele risi ele Ju si ọlo, “Ọ bụru nụ ị sịgbasi a, ị bụ́o enyi Siza. Nye ọbula ke neeme ẹhni a eze neemegidne Siza.”
\p 
\v 13 Nga Paịleti nụrnu nhne ka, o kwuhala Jizọsi ederezi, dazịri ẹli nụ ngadna nụ hne be jiri akaworugwu mee, be kwu n'ọnu Hiburu Gabata.
\v 14 Nhne ka mernu n'iwhnehnie, n'ọtnu-ige ke nri nụ ẹbo\f + \fr 19:14 \fq Ọtnu-ige ke nri nụ ẹbo: \ft ọkwukwo ke mbọm kwuru \fq ige awa ke isunu\f* n'ọbochi ojiknernu Ọgawhe.
\p Paịleti kanụ be “Anụ le eze anụ.”
\p 
\v 15 Be siwama, “Gwepu a, gwepu a, kpọgidne a n'ọgba.”
\p Paịleti sịkwa be, “Me kpọgidne eze anụ n'ọgba?”
\p Ele risi arịohna sarụ a, “A nwée eze berere kwolem Siza.”
\p 
\v 16 Paịleti nyewhete be Jizọsi, ma be kpọgidne a n'ọgba.
\s1 Be kpọgidnernu Jizọsi n'ọgba
\r (Mat 27:32-44; Mak 15:21-32; Luk 23:26-43)
\p Ele ọgwnu kwuru Jizọsi.
\v 17 Jizọsi vuru ọgba a, ọ whọga zne hne be kwu Hne Okpokoro Risi (ke bụ n'ọnu Hiburu Gọlugota.)
\v 18 Be kpọgidne a n'ọgba pịi, ya nụ ele rukna lawụru berere, otu badnụ n'akarikwnunga a, nye ke berere n'akarita a. Jizọsi zịri n'esilawụru be.
\p 
\v 19 Paịleti gbasịri nhne be jọogwnu tụkwasi a n'olu ọgba a, “Jizọsi, nye Nazarẹti, Eze ele Ju.”
\v 20 Agịda ele Ju gwnụrnu a, kwnornu nụ hne be kpọgidnernu Jizọsi n'ọgba zị́la ikere nụ rime ẹli-ọhna. Be gbarụ nhne ọgwnugwnu wam n'ọnu Hiburu, Latịni nụ Giriki.
\v 21 Ele risi arịohna ele Ju kanụ Paịleti, “Ị gbásị ‘Eze ele Ju,’ kọvu gbasị, ‘Nwerukna ka karụ nụ ọ bụ eze ele Ju.’ ”
\p 
\v 22 Paịleti sarụ be, “Nhne me gbarụ dazịm kpa me gbarụ a.”
\p 
\v 23 Nga ele ọgwnu kpọgidnernu Jizọsi n'ọgba, be gweru kpakara iwo a keri n'esilawụru be, keme be nga ẹno, be gweru a otu otu. Be chịri iwo olu a ke be dọ́wala ọdowa be dụru hi n'olu dụ n'ẹli.
\p 
\v 24 Be kaa, “A jọ́odowa iwo ka, kọvu a joovu ọgbanuchi ma a mahịa nye jeenwe a.” Ka bụ ma nhne be gbarụ n'ọkwukwo nsọ mezu, ke kwuru,
\q1 “Be keriri kpakara iwo m n'esilawụru be,
\q2 be ji iwo m vu ọgbanuchi.”
\q1 Ka bụ nhne ele ọgwnu wam mernu.
\p 
\v 25 Ele gwuzo ndụndu nụ hne ọgba wam zị bụ nne Jizọsi nụ nwene rinya nne a, nụ Meri nnwerne Kilopasi, nụ Meri Magịdalini.
\v 26 Nga Jizọsi whnụrnu nne a nụ nye sno apna a wam ọ whnụrnu n'anya, ọ kanụ nne a, “Nwerinya, le nnwọ ị.”
\v 27 Ọ kanụ nye sno apna a wam, “Le nne i.” Hite n'ige wam, nye sno apna a wam kwuru a la n'ọro a.
\s1 Ẹnwu Jizọsi
\r (Mat 27:45-56; Mak 15:33-41; Luk 23:44-49)
\p 
\v 28 Kpa Jizọsi magwụ nụ be mezulem kpakara nhne, o mee ma nhne be gbarụ n'ọkwukwo nsọ mezu, ọ kaa, “Akpịri nọokpo m bẹkwnu.”
\v 29 Otu idudu manya gbarụ ọka zị pịi, be rusi spọnji nụ rime a, knesi a nụ nkala hisopu, gwelizọ nụ mgbele-ọnu Jizọsi.
\v 30 Kpa Jizọsi nwọrnu manya wam, ọ kaa, “Okwolem.” Ọ pịaya risi a nwụma.
\s1 Be dụru Jizọsi ara // nụ ikpurutu
\p 
\v 31 Nhne ka mernu n'ọbochi ojiknernu, ke bụ ọbochi ke sno Ọbochi Ozukwa Inwe. Ọ másila ele risi ele Ju ọ sịgbasi iznu be n'olu ọgba n'Ọbochi Ozukwa Inwe kwnornu nụ ọ bụ okne ọbochi. Be rịasno Paịleti ma be gbaji kpakara be ọchi ma be vudna iznu be n'olu ọgba.
\v 32 Ele ọgwnu wam zne gbaji ọchi nye ke mbọm nụ nye ke berere ele be kpọgidnernu be nụ Jizọsi n'ọgba.
\v 33 Kọvu nga be vaduru hne Jizọsi zị, be whnụrnu nụ ọ nwụnam, be gbájile ọchi a.
\v 34 Otu nye ọgwnu gweru ara dụ Jizọsi nụ ikpurutu, ngangam, ọvnarna nụ mini gbahịa.
\v 35 Nye wam ke whnụrnu nhne ka gbarụ akebne, akebne a bụ ezi ọka. Ọ magwụ nụ o nookwu ezi ọka ma anụ kweru.
\v 36 Kpakara nhne ka mernu ma nhne be gbarụ n'ọkwukwo nsọ mezu, “Be jáagbaji otu ọkpukpu a.”
\v 37 Nhne be gbarụ n'ọkwukwo nsọ ke berere kwuru, “Ele badnụ jeele anya nye wam be dụru ara.”
\s1 Be liri Jizọsi
\r (Mat 27:57-61; Mak 15:42-47; Luk 23:50-56)
\p 
\v 38 Omekwo, Josefu nye Arimatiya, zne rịo Paịleti ma o vuru iznu Jizọsi. Josefu bụ nye sno apna Jizọsi nụ mgwụgwa, kwnornu nụ ọ nọotu ogwnu ele Ju. Paịleti kweru, ọ va vuru iznu a whọga.
\v 39 Nikodimọsi nye znekwnusiri Jizọsi n'abalị, snornu Josefu, o gweya mọno nwernu ẹknarna ọma be gwarụ nhne be kwu maa nụ alọsi, zị agịda.
\v 40 Ele rukna lawụru ka vuru iznu Jizọsi, whụ a n'ikpe marnụ mma nụ mọno wam, kwnornu nụ kpam bụ kpa ele Ju neeme iznu sị be li.
\v 41 Otu ẹkwu zị ndụndu hne be kpọgburu Jizọsi, otu ilili be gwuru ikne zị nụ rime ẹkwu wam, ọ zá nye be liru nụ rime a nụ mbọm.
\v 42 Kwnornu nụ ọ bụ ọbochi ojiknernu Ọbochi Ozukwa Inwe ele Ju, ilili wam zị masị ndụndu, be lite Jizọsi nụ rime a.
\c 20
\s1 Ilili ke ọ zá nye zị a
\r (Mat 28:1-8; Mak 16:1-8; Luk 24:1-12)
\p 
\v 1 N'ọnu ọsisi n'ọbochi mbọm n'ikwezu, ọ gba kọriri ọchichiri, Meri Magịdalini znernu ilili wam whnụ nụ be vumenem rugwu be jiri kpusni ọnu ilili wam.
\v 2 Ọ gba ẹso znekwnusi Saịmoni Pita nụ nye sno apna a wam Jizọsi whnụrnu n'anya. Ọ kanụ be, “Be vumenem iznu Nyenwe aị n'ilili, a máa hne be bịtaru a.”
\p 
\v 3 Pita nụ nye sno apna a wam whọga, neezne n'ilili.
\v 4 Be lawụru bete agba ẹso, kọvu nye sno apna a kịyari gbawhe Pita, beru Pita ọsno gbadu ilili.
\v 5 O whudnahie ẹli whnụ ikpe marnụ mma wam, kọvu ọ bnáge nụ rime.
\v 6 Saịmoni Pita va, bna nụ rime ilili. Ọ whnụrnu ikpe marnụ mma wam dazị etekne,
\v 7 n'ikpe be jiri whụ risi Jizọsi, ya nụ ikpe be pịakotaru be n'otu ichne.
\v 8 Nye sno apna a wam ke beru ọsno va, bna nụ rime ilili, ọ whnụrnu, kweru masị.
\v 9 (Be ghọ́yage nhne be gbarụ n'ọkwukwo nsọ, nụ o jeehi n'ẹnwu lizọ.)
\v 10 Ele sno apna a wam lahna.
\s1 Jizọsi gesiri Meri Magịdalini // ẹhni a
\r (Mat 28:9,10; Mak 16:9-11)
\p 
\v 11 Kọvu Meri gwuzoru n'ederezi ilili wam naakwna ẹkwna. Kpa ọ naakwa ẹkwna, o whudnahie le anya nụ rime ilili wam.
\v 12 Ọ whnụ ele enine izi lawụru wogwu iwo abọchna dazị ẹli nụ hne iznu Jizọsi zị nụ mbọm, otu nụ risi a, otu n'ọchi a.
\p 
\v 13 Be sịkwa a, “Nwerinya, kịni neeme i ẹkwna?”
\p Ọ kaa, “Be vumenem Nyenwe m, m máam hne be vubiri a.”
\v 14 Nga o kwuru ka, ọ tụhnasna whnụ Jizọsi, kọvu ọ máa nụ ọ bụ Jizọsi.
\p 
\v 15 Jizọsi sịkwa a, “Nwerinya, kịni neeme i ẹkwna? Ndaa nye i noopio?”
\p Meri che nụ ọ bụ nye ẹrnu ẹkwnu, ọ kaa, “Nda-aị-kwu, ọ bụru nụ ọ bụ jị vumernu a, kanụ hne ị vubiri a, m jeezne vuru a.”
\p 
\v 16 Jizọsi sukwu a, “Meri.”
\p Meri tụhnasna, kete a ruwhnu, siwama n'ọnu Hiburu, “Raboni!” (ke bụ Nye-zni-nhne).
\p 
\v 17 Jizọsi kanụ a, “Ị kpákwadia m aka, kwnornu nụ m yáalakwnuznege m Nda m. Kọvu znekwnusi rụmu nda m, kanụ be m naalakwnusi Nda m nụ Nda anụ, nụ Chiokike m nụ Chiokike anụ.”
\p 
\v 18 Meri Magịdalini zne kanụ ele sno apna a nụ ọ whnụrnu Nyenwe aị, nụ ka bụ nhne ọ kanụ a.
\s1 Jizọsi gesiri ele sno apna a // ẹhni a
\r (Mat 28:16-20; Mak 16:14-18; Luk 24:36-49)
\p 
\v 19 N'ogbednachi, n'ọbochi mbọm wam n'ikwezu, ele sno apna a gbakọru n'otu ọro tụgidne ẹhni be ọnuhna, kwnornu be nọotu ogwnu ele risi ele Ju. Jizọsi varụ gwuzoru n'esilawụru be, kaa, “Udno zịnu anụ.”
\v 20 Nga o kwuru ka, o gesi be aka a lawụru nụ ikpurutu a. Mkpọma sọ ele sno apna a n'ọnu kpa be whnụrnu Nyenwe aị.
\p 
\v 21 Jizọsi kaa kwno berere, “Udno zịnu anụ, lele kpa Nda m ziyaru m, ọ bụ kpa me neezni anụ.”
\v 22 Nga o kwuru ka, o nwesi be inwe, kaa, “Anụ nahọru Enine Nsọ.
\v 23 Ọ bụru nụ anụ gbarụnu ele badnụ mmehie be, be jaagbarụnu be mmehie be, kọvu ọ bụru nụ anụ jáagbarụnu be, be jáagbarụnu be.”
\s1 Jizọsi nụ Tọmosi
\p 
\v 24 Otu nụ nri nụ badnụ lawụru wam sno apna Jizọsi, nye rẹwhna a bụ Tọmosi, nye be kwu Didimọsi nụ be zị́la nga Jizọsi varụ.
\v 25 Ele sno apna a ele berere kanụ a, “A whnụrnu Nyenwe aị.”
\p Tọmosi kanụ be, “Okwolem ma m whnụrnu m anụnu ituru nụ aka a lawụru, m yisi mkpaka aka m nụ rime be, yisi aka m n'ikpurutu a, m jéekweru.”
\p 
\v 26 N'ikwezu a, ele sno apna Jizọsi gbakọgwu kwno n'otu ọro, tụgidne ẹhni ọnuhna, Tọmosi nụ be zị masị. Be tụsnirni ọro, kọvu Jizọsi varụ gwuzoru n'esilawụru be, kaa, “Udno zịnu anụ.”
\v 27 Ọ kanụ Tọmosi, “Yisi aka ị hna, le aka m lawụru, dnọsnima aka ị yisi n'ikpurutu m, i nwéma mkpọma lawụru, kweru.”
\p 
\v 28 Tọmosi sarụ a, “Nyenwe m nụ Chiokike m.”
\p 
\v 29 Jizọsi kanụ a, “I kweruru kwnornu nụ ị whnụrnu m, ngọzi zịnu ele whnụ́ge, kọvu be kweru.”
\s1 Risi ọkwukwo ka
\p 
\v 30 Jizọsi rnụrnu agịda ẹrnu ndu-ẹhni berere nụ ruwhnu ele sno apna a ke be gbáge n'ọkwukwo ka.
\v 31 Kọvu be gbarụ ka ma anụ kweru nụ Jizọsi bụ Karaịsi wam, Nnwọ Chiokike, ma hite n'ọkwnata mkpọma nụ rẹwhna a, anụ jeenwe bụdnu.
\c 21
\s1 Jizọsi gesiri ele sno apna a // ẹsau ẹhni a
\p 
\v 1 Omekwo, Jizọsi gesiri ele sno apna a ẹhni a n'apna berere, nụ ngeri Osimini Taberasị.
\v 2 Saịmoni Pita, Tọmosi nye be kwu Didimọsi, nụ Natanẹli nye Kana ke Galili, nụ rụmu rukna Zebidi, nụ ele sno apna a lawụru berere zị.
\v 3 Saịmoni Pita kaa, “M neezne o gbu aznụ.”
\p Be kanụ a, “A joosno i zne.” Kpakara be zne bna n'otu ọgbo, kọvu ọ zá nhne be gburu kpakara abalị wam.
\p 
\v 4 N'ọnu ọsisi, Jizọsi gwuzoru n'ọnu mini, kọvu ele sno apna a máa nụ ọ bụ Jizọsi.
\p 
\v 5 Ọ sịkwa be, “Rụmu takịri, ọ zị aznụ anụ gbuhịaru?”
\p Be sa a, “Ọ́za.”
\p 
\v 6 Jizọsi kanụ be, “Anụ wụsi ịgbo anụ n'akarikwnunga ọgbo, anụ jọowhnu aznụ.” Be wụsi ịgbo be, be nwée rikne dọli ịgbo wam kwnornu nụ be gburu agịda aznụ.
\p 
\v 7 Nye sno apna wam Jizọsi whnụrnu n'anya kanụ Pita, “Ọ bụ Nyenwe aị.” Kpa Saịmoni Pita nụrnu nụ ọ bụ Nyenwe aị, o jeru ikpe a (kwnornu nụ ọ gba ẹto) dnabna mini.
\v 8 Ele sno apna a ele berere kwọru ọgbo, dọru ịgbo wam aznụ jiri va mkpomkpo ẹli. Be zá ikere nụ mkpomkpo ẹli, nhne hne lele riwhu rula ẹto.
\v 9 Nga be dụru mkpomkpo ẹli, be whnụrnu esekere bẹkwnu nụ aznụ nụ zị n'olu a nụ brẹdi zị pịi.
\p 
\v 10 Jizọsi kanụ be, “Anụ gweya agwna aznụ anụ gburu.”
\p 
\v 11 Saịmoni Pita zne dọru ịgbo wam nụ mkpomkpo ẹli, aznụ okpotokpo jiri a, otu riwhu nụ nri isne nụ ẹto, Ịgbo wam dọ́kala, ọ bụ n'ezi nụ aznụ zị agịda.
\v 12 Jizọsi kanụ be, “Anụ va ri wiri.” Ọ zá nye sno apna a ke nwernu rikne ọ nyipohịa sịkwa a, “Ị bụ nyele?” Be magwụ nụ ọ bụ Nyenwe aị.
\v 13 Jizọsi gweru brẹdi wam nyee be, ya nụ aznụ.
\v 14 Ka mernu mgba ẹto Jizọsi gesiri ele sno apna a ẹhni a kpa o hi n'ẹnwu lizọ.
\s1 Jizọsi nụ Pita
\p 
\v 15 Nga be rikworu wiri, Jizọsi kanụ Saịmoni Pita, “Saịmoni nnwọ Jọni, ị whnụrnu m n'anya kakwo nhne ele ka?”
\p Ọ sa a, “Owe, Nyenwe aị, ị magwụ nụ m whnụrnu m jị n'anya.”
\p Jizọsi kanụ a, “Nyee atnụrnu m wiri.”
\p 
\v 16 Jizọsi kanụ a ke mgba lawụru, “Saịmoni, nnwọ Jọni, ị whnụrnu m n'anya n'ezi ọka?”
\p Ọ sa a, “Owe, Nyenwe aị, ị magwụ nụ m whnụrnu m jị n'anya.”
\p Jizọsi kanụ a, “Nọoznu atnụrnu m.”
\p 
\v 17 Jizọsi kanụ a ke mgba ẹto, “Saịmoni, nnwọ Jọni, ị whnụrnu m n'anya?”
\p O gbu Pita igbugbu nụ Jizọsi kannụ ke mgba ẹto, “Ị whnụrnu m n'anya?” Ọ kaa, Nyenwe aị, ị magwụ kpakara nhne, ị magwụ nụ m whnụrnu m jị n'anya.
\p Jizọsi kanụ a, “Nyee atnụrnu m wiri.
\v 18 Me kanụ ị ezi ọka, nga ị bụ wikoro, ị nọosnu ajnị n'ikwnu i zne hne ọbula ọ masịri ị. Kọvu, nga i jeeme okno badnụ, i jọodosni aka ị, nye berere snụsi ị ajnị, kwuru i zne hne másịla ị.”
\v 19 Jizọsi kwuru ka ma o gesi kpa Pita jọonwu ẹnwu, ma o nyee Chiokike igwugwu. Jizọsi kanụ a, “Sno m.”
\s1 Jizọsi nụ nye sno apna a // ke berere
\p 
\v 20 Pita tụhnasna whnụ nye sno apna a wam, nye Jizọsi whnụrnu n'anya, nye dnabnernu Jizọsi nga be neeri wiri anyasnu wam, sịkwa a, “Nyenwe aị, nyele jeere i?”
\v 21 Nga Pita whnụrnu a, ọ kanụ Jizọsi, “Nyenwe aị, ndaa nhne i kwuru gbasịri nwerukna ka?”
\p 
\v 22 Jizọsi sarụ a, “Ọ bụru nụ m pioru m ọ zịri bụdnu tem m va, ọ gbásịla ị, sno m.”
\v 23 Be tnụsa a n'esilawụru ele sno apna Jizọsi nụ nye sno apna a ka jọ́onwu ẹnwu. Kọvu Jizọsi kála nụ ọ jọ́onwu ẹnwu, kọvu o karụ, “Ọ bụru nụ m pioru m ọ zịri bụdnu tem m va, ọ gbásịla ị.”
\p 
\v 24 Ya bụ nye sno apna a ke kwuru kpakara nhne ka, nye gba masịri a n'ọkwukwo, a magwụ nụ nhne ọ gbarụ bụ ezi ọka.
\s1 Okwukwo
\p 
\v 25 Agịda nhne ele berere ke Jizọsi mernu, ọ bụru nụ be gba kpakara be n'ọkwukwo, m che m nụ kpakara ọwa n'iwhuru a jéenwe rikne vuli kpakara ọkwukwo be jaagba.
