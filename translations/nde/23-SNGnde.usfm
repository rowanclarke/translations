\id SNG - Biblica® Open Ndebele Contemporary Bible 
\h Ingoma 
\toc1 Ingoma Yezingoma 
\toc2 Ingoma 
\toc3 Ing 
\mt1 Ingoma Yezingoma 
\c 1  
\p  
\v 1 Ingoma yezingoma kaSolomoni. 
\b  
\sp Umlobokazi 
\q1  
\v 2 Kangange ngezangiwo zomlomo wakhe 
\q2 ngoba uthando lwakho lumnandi kulewayini. 
\q1  
\v 3 Limnandi iphunga lamagcobo akho; 
\q2 ibizo lakho linjengamakha atheliweyo. 
\q2 Yikho izintombi zikuthanda kangaka! 
\q1  
\v 4 Ngithatha uhambe lami, kasiphangise! 
\q2 Inkosi kayingingenise endlini yayo. 
\sp Abangane 
\q1 Siyathokoza njalo siyajabula ngawe; 
\q2 sizalubabaza uthando lwakho okudlula iwayini. 
\sp Umlobokazi 
\q1 Kabazenzi ukuba bakuthande! 
\b  
\q1  
\v 5 Ngimnyama kodwa ngiyabukeka, 
\q2 lina madodakazi aseJerusalema 
\q1 ngimnyama okwamathente aseKhedari, 
\q2 okwamakhetheni amathente kaSolomoni. 
\q1  
\v 6 Linganginyonkolozi ngoba ngimnyama, 
\q2 ngimnyama ngenxa yokutshiswa lilanga. 
\q1 Abanewethu bangizondela 
\q2 bangenza umlindi wesivini; 
\q2 angabe ngisanaka esami isivini. 
\q1  
\v 7 Akungitshele, wena engikuthandayo, 
\q2 uyelusela ngaphi imihlambi yezimvu zakho 
\q2 lokuthi ziphumula ngaphi izimvu zakho emini? 
\q1 Kungani ngisiba njengomfazi ombozileyo eceleni 
\q2 kwemihlambi yabangane bakho na? 
\sp Abangane 
\q1  
\v 8 Nxa ungazi, wena omuhle okudlula bonke abesifazane, 
\q2 landela umkhondo wezimvu 
\q1 udlisele amazinyane embuzi zakho 
\q2 eduze lamathente abelusi. 
\sp Umyeni 
\q1  
\v 9 Sithandwa sami, ngikufanisa lebhiza elisikazi 
\q2 elibotshwe enqoleni kaFaro. 
\q1  
\v 10 Izihlathi zakho zinhle ngokuceciswa, 
\q2 intamo yakho ngobuhlalu obucazimulayo. 
\q1  
\v 11 Sizakwenzela amacici egolide, 
\q2 ebalazwe ngesiliva. 
\sp Umlobokazi 
\q1  
\v 12 Khonapho inkosi isetafuleni 
\q2 amakha ami enadi alanquza iphunga lawo elimnandi. 
\q1  
\v 13 Kimi isithandwa sami sinjengemfuko yemure 
\q2 ithe khoxo phakathi kwamabele ami. 
\q1  
\v 14 Kimi isithandwa sami sinjengelixha lempoko zehena 
\q2 eliphuma esivinini se-Eni-Gedi. 
\sp Umyeni 
\q1  
\v 15 Bakithi, umuhle njani sithandwa sami! 
\q2 Ngeqiniso umuhle! 
\q2 Amehlo akho angamajuba. 
\sp Umlobokazi 
\q1  
\v 16 Umuhle ngempela, sithandwa sami! 
\q2 Bakithi, uyabukeka! 
\q2 Umbheda wethu butshani obuluhlaza tshoko. 
\sp Umyeni 
\q1  
\v 17 Izinsika zendlu yethu ngezomsedari 
\q2 lezintungo ngezefire. 
\c 2  
\sp Umlobokazi 
\q1  
\v 1 Ngililuba laseSharoni, 
\q2 imbali yasezigodini. 
\sp Umyeni 
\q1  
\v 2 Njengembali phakathi kwameva 
\q2 sinjalo isithandwa sami phakathi kwezintombi. 
\sp Umlobokazi 
\q1  
\v 3 Njengesihlahla se-aphula phakathi kwezihlahla zeganga 
\q2 sinjalo isithandwa sami phakathi kwamajaha. 
\q1 Kumnandi kimi ukuhlala emthunzini waso, 
\q2 lezithelo zakhe ziyahlabusa kimi. 
\q1  
\v 4 Useke wangisa endlini yedili, 
\q2 lophawu lwakhe kimi luthando. 
\q1  
\v 5 Ngiqinisani ngamavini awonyisiweyo, 
\q2 lingivuselele ngama-aphula, 
\q2 ngoba sengiyathiswa luthando. 
\q1  
\v 6 Ingalo yakhe yobunxele ngiyiqamele, 
\q2 kuthi ingalo yakhe yokunene ingigonile. 
\q1  
\v 7 Madodakazi aseJerusalema, 
\q2 ngiyaliqonqosela 
\q2 ngezimpala langezimpalakazi zeganga. 
\q1 Lingalunyakazisi loba liluvuse uthando 
\q2 luze luzifunele lona. 
\b  
\q1  
\v 8 Zwanini! Yisithandwa sami! 
\q2 Khangelani! Nansi siyeza, 
\q1 siseqa ezintabeni 
\q2 siqolotsha emaqaqeni. 
\q1  
\v 9 Isithandwa sami sinjengempala loba ithole lomziki. 
\q2 Khangela! Nansiyana simi ngale komduli wakwethu, 
\q1 sikhangele sibona emawindini, 
\q2 silunguza ngezimbotshana. 
\q1  
\v 10 Isithandwa sami sakhuluma sathi kimi, 
\q2 “Sukuma, sithandwa sami, 
\q2 wena omuhle, woza sihambe. 
\q1  
\v 11 Khangela! Ubusika sebudlulile; 
\q2 isikhathi sezulu sesidlule. 
\q1  
\v 12 Amaluba asebonakala emangweni; 
\q2 isikhathi sokuhlabelela kwezinyoni sesifikile, 
\q1 ukukhala kwamajuba 
\q2 sekuzwakala elizweni lakithi. 
\q1  
\v 13 Umkhiwa usuthela izithelo zawo zakuqala; 
\q2 amavini aqhakazayo aseletha iphunga elimnandi. 
\q1 Sukuma, woza sithandwa sami; 
\q2 wena omuhle wami, woza sihambe.” 
\sp Umyeni 
\q1  
\v 14 Juba lami elisezingoxweni zedwala, 
\q2 ekusithekeni kwamawa entaba, 
\q1 akungitshengise ubuso bakho, 
\q2 akungizwise ilizwi lakho; 
\q1 ngoba limnandi ilizwi lakho, 
\q2 lobuso bakho buyabukeka. 
\q1  
\v 15 Sibambeleni amakhanka, 
\q2 amakhanka amancinyane 
\q1 onayo ezivinini, 
\q2 izivini zethu esezithela. 
\sp Umlobokazi 
\q1  
\v 16 Isithandwa sami ngesami lami ngingowakhe; 
\q2 uzithokozisa ngoba phakathi kwamaluba. 
\q1  
\v 17 Akuze kube emadabukakusa 
\q2 lapho kunyamalala khona izithunzi, 
\q1 phenduka sithandwa sami, 
\q2 ube njengempala 
\q1 loba njengegogo elisengumntwana 
\q2 phezu kwezintaba ezilamakhelekethe. 
\b  
\c 3  
\q1  
\v 1 Ubusuku bonke ngisembhedeni wami 
\q2 ngamdinga lowo othandwa yinhliziyo yami; 
\q2 ngamdinga kodwa kangimfumananga. 
\q1  
\v 2 Sengivuka manje ngizulazule phakathi kwedolobho, 
\q2 emigwaqweni lasemagcekeni alo; 
\q1 ngizalibhudula ngidinga othandwa yinhliziyo yami. 
\q2 Kanjalo ngamdinga kodwa angaze ngamthola. 
\q1  
\v 3 Abalindi bangifica belokhu 
\q2 benquma phakathi kwedolobho. 
\q2 “Like lambona yini lowo othandwa yinhliziyo yami?” 
\q1  
\v 4 Ngathi ngisedlula kubo 
\q2 ngabe ngimbona othandwa yinhliziyo yami. 
\q1 Ngambamba angaze ngamyekela ukuba ahambe 
\q2 ngaze ngamletha endlini kamama, 
\q2 endlini yakhe lowo owangizalayo. 
\q1  
\v 5 Madodakazi aseJerusalema, ngiyaliqonqosela 
\q2 ngezimpala langezimpalakazi zeganga. 
\q1 Lingalunyakazisi loba liluvuse uthando 
\q2 luze luzifunele lona. 
\b  
\q1  
\v 6 Ngubani lo ozayo eqhamuka enkangala 
\q2 kungathi yisikhatha sentuthu, 
\q1 eziqhole ngamakha emure lenhlaka eyenziwe 
\q2 ngemihlobo yonke yezinongo zomthengisi? 
\q1  
\v 7 Khangela! Yinqola kaSolomoni, 
\q2 isekelwe ngamabutho angamatshumi ayisithupha, 
\q2 angabathenjwa abayinqaba ko-Israyeli, 
\q1  
\v 8 bonke begqize izinkemba enqulwini, 
\q2 bonke sebake bazilwa izimpi, 
\q1 ngulowo lalowo inkemba yakhe eceleni kwakhe, 
\q2 elungele ukuhlatshwa komkhosi ebusuku. 
\q1  
\v 9 Inkosi uSolomoni yazenzela inqola leyo; 
\q2 yayenza ngezigodo zeLebhanoni. 
\q1  
\v 10 Imijabo yayo yayenza ngesiliva, 
\q2 isisekelo sayo yasenza ngegolide. 
\q1 Isihlalo sayo yasithungela ilembu eliyibubende 
\q2 ingaphakathi yayo yaceciswa ngothando 
\q2 ngamadodakazi aseJerusalema. 
\q1  
\v 11 Phumani phandle madodakazi aseZiyoni, 
\q2 libone iNkosi uSolomoni ithwele umqhele, 
\q1 umqhele ewetheswa ngunina mhla welanga atshada ngalo, 
\q2 ilanga inhliziyo yakhe yathokoza ngalo. 
\c 4  
\sp Umyeni 
\q1  
\v 1 Kayisibuhle bakho, sithandwa sami! 
\q2 Awu, ayisibuhle, bakithi! 
\q2 Amehlo akho embeswe liveli, angamajuba. 
\q1 Inwele zakho zinjengomhlambi wembuzi 
\q2 zisehla entabeni iGiliyadi. 
\q1  
\v 2 Amazinyo akho anjengomhlambi wezimvu zisanda kugundwa, 
\q2 zivela geziswa yileyo ihamba laleyo efanana layo; 
\q2 kayikho ethe qekele yodwa. 
\q1  
\v 3 Izindebe zakho zinjengozwezwe olubomvu; 
\q2 muhle umlomo wakho. 
\q1 Izihlathi zakho ezembeswe liveli lakho 
\q2 ezinjengephomegranathi elidatshulwe phakathi. 
\q1  
\v 4 Intamo yakho injengomphotshongo wokulinda kaDavida, 
\q2 owakhiwa waba muhle kakhulu; 
\q1 kulengiswe kuwo amahawu ayinkulungwane, 
\q2 wonke angamahawu amaqhawe. 
\q1  
\v 5 Amabele akho omabili anjengamazinyane amabili, 
\q2 njengamaphahla amazinyane empala 
\q2 adla utshani phakathi kwezimbali. 
\q1  
\v 6 Nxa kusesemadabukakusa 
\q2 izithunzi zingakabaleki emuntwini, 
\q1 ngizakuya entabeni yemure 
\q2 laseqaqeni lwamakha amnandi. 
\q1  
\v 7 Umuhle kakhulukazi, ntokazi yami; 
\q2 kakulanto engenhle kuwe. 
\b  
\q1  
\v 8 Woza, mlobokazi wami, sisuke eLebhanoni, 
\q2 woza sisuke eLebhanoni. 
\q1 Yehla emaweni ase-Amana, 
\q2 wehle esiqongweni saseSeniri, isiqongo seHemoni, 
\q1 ezimbalwini zezingonyama 
\q2 lezintabeni okuhlala ingwe kuzo. 
\q1  
\v 9 Uyithumbile inhliziyo yami, dadewethu, mlobokazi wami; 
\q2 uyithumbile inhliziyo yami 
\q1 ngokungithi jeqe ngamehlo akho, 
\q2 langengqongqo elilodwa lobuhlalu bakho. 
\q1  
\v 10 Luthokozisa kanganani uthando lwakho, 
\q2 dadewethu, mlobokazi wami! 
\q1 Lumnandi kakhulu kulewayini, 
\q2 lephunga lamakha akho 
\q2 kulawo wonke amafutha! 
\q1  
\v 11 Izindebe zakho ziconsa ubumnandi njengoluju, mlobokazi wami; 
\q2 uchago loluju kungaphansi kolimi lwakho. 
\q1 Iphunga lezivunulo zakho 
\q2 linjengeleLebhanoni. 
\q1  
\v 12 Uyisivande esibiyelweyo, dadewethu, mlobokazi wami; 
\q2 ungumthombo obiyelweyo, 
\q2 lesiphethu esihuqelweyo sagcikwa. 
\q1  
\v 13 Izilimo zakho ziyisivande samaphomegranathi 
\q2 alezithelo ezinhle zilehena lenadi, 
\q2  
\v 14 inadi lesafuroni, 
\q2 ikhalamu lesinamoni, 
\q2 lemihlobo yonke yezihlahla zempepha, 
\q2 imure lenhlaba lazozonke iziyoliso zekhethelo. 
\q1  
\v 15 Uyisiphethu sesivandeni, 
\q2 umthombo ogeleza amanzi 
\q2 ugeleza usehla eLebhanoni. 
\sp Umlobokazi 
\q1  
\v 16 Vuka moya wenyakatho, 
\q2 woza moya weningizimu! 
\q1 Phephetha esivandeni sami, 
\q2 ukuze amakha aso agcwale indawo yonke. 
\q1 Akuthi isithandwa sami size esivandeni saso 
\q2 sikholise izithelo zaso zekhethelo. 
\c 5  
\sp Umyeni 
\q1  
\v 1 Sengingenile esivandeni sami, dadewethu, mlobokazi wami; 
\q2 sengiyibuthile imure yami lesiyoliso sami. 
\q1 Sengizidlile inhlanga zami loluju lwami; 
\q2 sengiyinathile iwayini yami lochago lwami. 
\sp Abangane 
\q1 Dlanini, bangane, linathe; 
\q2 nathani lizidele, lina zithandani. 
\sp Umlobokazi 
\q1  
\v 2 Ngalala kodwa inhliziyo yami ivukile. 
\q2 Zwana! Isithandwa sami siyaqoqoda: 
\q1 “Ngivulela, dadewethu, sithandwa sami, 
\q2 juba lami, wena ongelasiyinga. 
\q1 Ikhanda lami ligcwele amazolo, 
\q2 inwele zami zilobumanzi bobusuku.” 
\q1  
\v 3 Sengisikhulule isigqoko sami 
\q2 ngisigqoke futhi na? 
\q1 Sengizigezile inyawo zami 
\q2 ngibuye ngizingcolise futhi na? 
\q1  
\v 4 Isithandwa sami sangenisa isandla saso embotsheni yomnyango; 
\q2 inhliziyo yami yagubhazela ifuna sona. 
\q1  
\v 5 Ngavuka ngayasivulela isithandwa sami, 
\q2 izandla zami zijuluka imure, 
\q1 iminwe yami igeleza imure, 
\q2 phezu kwezibambo zekhiye. 
\q1  
\v 6 Ngasivulela isithandwa sami, 
\q2 kodwa isithandwa sami sasesisukile, sasesihambile. 
\q1 Inhliziyo yami yadangala ngoba sesihambile. 
\q2 Ngasithalaza kodwa ngasiswela. 
\q2 Ngasimemeza kodwa kasisabelanga. 
\q1  
\v 7 Abalindi bangibona 
\q2 ngesikhathi bebhodabhoda, behlola idolobho. 
\q1 Bangitshaya bangilimaza; 
\q2 bangihlubula bathatha ibhatshi lami, 
\q2 labobalindi bemiduli! 
\q1  
\v 8 Lina madodakazi aseJerusalema, ngiyaliqonqosela 
\q2 nxa lisithola isithandwa sami lizasitshelani? 
\q2 Sitsheleni ukuthi mina sengiyathiswa luthando. 
\sp Abangane 
\q1  
\v 9 Isithandwa sakho singcono ngani kulezinye izithandwa 
\q2 wena omuhle okudlula bonke abesifazane? 
\q1 Singcono ngani isithandwa sakho kulezinye 
\q2 osungaze usiqonqosele kangaka? 
\sp Umlobokazi 
\q1  
\v 10 Isithandwa sami siyakhazimula sincwaba, 
\q2 siyabonakala laphakathi kwezinkulungwane ezilitshumi. 
\q1  
\v 11 Ikhanda laso liligolide elicengwe kakhulu; 
\q2 inwele zaso ziyibulembu, 
\q2 zimnyama okwewabayi. 
\q1  
\v 12 Amehlo aso anjengamajuba 
\q2 esezifuleni ezilamanzi, 
\q1 agezwe ngochago, 
\q2 amiswa njengamatshe engcebo. 
\q1  
\v 13 Izihlathi zaso zinjengendima yeziyoliso 
\q2 ezilephunga lamakha. 
\q1 Izindebe zaso zinjengezimbali, 
\q2 ziconsa imure. 
\q1  
\v 14 Izingalo zaso yimiqwayi yegolide 
\q2 elixutshwe ngekhrisolithe. 
\q1 Umzimba waso unjengophondo lwendlovu olulolongiweyo 
\q2 lwaceciswa ngamasafire. 
\q1  
\v 15 Imilenze yaso yizinsika zelitshe 
\q2 eliqinileyo elibutshelezi 
\q2 elimiswe ezisekelweni zegolide elicengekileyo. 
\q1 Isithombo saso sinjengeLebhanoni, 
\q2 njengemisedari yakhona eyebanga laphezulu. 
\q1  
\v 16 Umlomo waso uyibumnandi qobo lwabo; 
\q2 siyabukeka ngokupheleleyo. 
\q1 Lesi yiso isithandwa sami, yena umngane wami, 
\q2 we madodakazi aseJerusalema. 
\c 6  
\sp Abangane 
\q1  
\v 1 Sesiye ngaphi isithandwa sakho 
\q2 wena omuhle kulabo bonke abesifazane? 
\q1 Siqonde ngaphi isithandwa sakho 
\q2 ukuze sikudingise sona? 
\sp Umlobokazi 
\q1  
\v 2 Isithandwa sami sehlele ngesivandeni saso, 
\q2 endimeni yamaluba eziyoliso, 
\q1 ukuzulazula ezivandeni 
\q2 lokuqunta izimbali. 
\q1  
\v 3 Ngingowaso isithandwa sami, laso singesami; 
\q2 uzithokozisa ngoba phakathi kwamaluba. 
\sp Umyeni 
\q1  
\v 4 Umuhle, sithandwa sami, njengeThiza, 
\q2 uthandeka njengeJerusalema, 
\q2 ulesithunzi njengamabutho ephethe uphawu lwempi. 
\q1  
\v 5 Susa amehlo akho kimi; 
\q2 angihubula igwebu. 
\q1 Inwele zakho zinjengomhlambi wembuzi 
\q2 zisehla eGiliyadi. 
\q1  
\v 6 Amazinyo akho anjengomhlambi wezimvu 
\q2 zivela geziswa 
\q1 yileyo ihamba laleyo efanana layo; 
\q2 akula ehamba yodwa. 
\q1  
\v 7 Izihlathi zakho ezivalwe liveli lakho 
\q2 zinjengezingxenye zesithelo sephomegranathi. 
\q1  
\v 8 Kungabe kukhona amakhosikazi angamatshumi ayisithupha, 
\q2 labanye abafazi beceleni abangamatshumi ayisificaminwembili, 
\q2 lezintombi ezipheleleyo ezingelakubalwa; 
\q1  
\v 9 kodwa ijuba lami, opheleleyo wami, wehlukene, 
\q2 nguye yedwa kunina, 
\q2 uyintandokazi yalowo owamzalayo. 
\q1 Izintombi zambona zathi ubusisiwe; 
\q2 amakhosikazi labafazi beceleni bambabaza. 
\sp Abangane 
\q1  
\v 10 Ngubani lo oqhamuka njengokusa, 
\q2 omuhle njengenyanga, okhazimula njengelanga, 
\q2 olobukhosi njengezinkanyezi ziludwendwe? 
\sp Umyeni 
\q1  
\v 11 Ngehlela esivandeni esilezithelo ezilenkelo 
\q2 ngisiyabona amahlumela esigodini, 
\q1 ngisiyabona ingabe amavini ayesenunkula yini 
\q2 langabe amaphomegranathi ayeseqhakazile na. 
\q1  
\v 12 Ngisalibele nje 
\q2 isifiso sami sangibeka ezinqoleni zobukhosi ezabantu bakithi. 
\sp Abangane 
\q1  
\v 13 Phenduka, phenduka, wena mShulamithi; 
\q2 phenduka, phenduka, ukuze sikubuke! 
\sp Umyeni 
\q1 Liyabe limbukelani umShulamithi 
\q2 kungathi libuka umgido kaMahanayimi? 
\b  
\c 7  
\q1  
\v 1 Zinhle kakhulu inyawo zakho emanyathelweni, 
\q2 awu ndodakazi yenkosana! 
\q1 Amathebe mahle anjengamatshe aligugu, 
\q2 ingathi abunjwa kuhle yingcitshi. 
\q1  
\v 2 Inkaba yakho yindingilizana yesiphathelo esihle 
\q2 esihlala sigcwele iwayini elixutshiweyo. 
\q1 Ukhalo lwakho luyinqunjana yengqoloyi 
\q2 ezingelezwe yizimbali. 
\q1  
\v 3 Amabele akho anjengamazinyane amabili, 
\q2 njengamaphahla empala. 
\q1  
\v 4 Intamo yakho injengomphotshongo wempondo zendlovu. 
\q1 Amehlo akho ayiziziba zeHeshibhoni 
\q2 eduze lesango laseBhathi Rabhimi. 
\q1 Impumulo yakho injengomphotshongo waseLebhanoni 
\q2 ukhangele eDamaseko. 
\q1  
\v 5 Ikhanda lakho lingumqhele kuwe njengentaba iKhameli. 
\q2 Inwele zakho zingumceciso wobukhosi; 
\q2 inkosi ithunjiwe ngamagoda azo. 
\q1  
\v 6 Wamuhle bantu njalo uyathokozisa, 
\q2 wena sithandwa, ngezintokozo zakho! 
\q1  
\v 7 Uluthi lwakho luthe klwi, njengesihlahla sephamu, 
\q2 lamabele akho anjengelixha lezithelo. 
\q1  
\v 8 Ngathi, “Ngizakhwela esihlahleni sephamu; 
\q2 ngizaziphatha lezozithelo zalo.” 
\q1 Sengathi amabele akho angaba njengamaxha evini, 
\q2 amakha okuphefumula kwakho abe njengama-aphula, 
\q2  
\v 9 lomlomo wakho ube njengewayini elidlula wonke. 
\sp Umlobokazi 
\q1 Sengathi iwayini lelo lingaya kusithandwa sami, 
\q2 ligeleze kakuhle ezindebeni lasemazinyweni. 
\q1  
\v 10 Ngingowaso isithandwa sami, 
\q2 silangathela mina. 
\q1  
\v 11 Woza, sithandwa sami, kasihambe siye emaphandleni, 
\q2 kasiyolala emizini. 
\q1  
\v 12 Kasihambe ekuseni ezivinini 
\q2 ukuyabona ingabe amavini asenunkula na, 
\q1 ingabe amaluba amaphomegranathi awo aseqhakazile 
\q2 lapho ngizakupha uthando lwami. 
\q1  
\v 13 Izihlahla zamamandraki zikhupha iphunga elimnandi, 
\q2 kuthi emnyango wakwethu kube lezibiliboco zonke 
\q1 ezintsha lezindala, 
\q2 engikubekele zona, sithandwa sami. 
\b  
\c 8  
\q1  
\v 1 Aluba nje unjengomfowethu kimi, 
\q2 owondliwa emunya emabeleni kamama! 
\q1 Lapho-ke, nxa ngikufica phandle, 
\q2 ngithi loba ngikwanga, 
\q2 angabikhona ongisolayo. 
\q1  
\v 2 Ngabe ngiyakudonsa 
\q2 ngikuse endlini kamama 
\q2 yena owangikhulisayo. 
\q1 Ngabe ngikupha iwayini elixutshiweyo unathe, 
\q2 uluju lwamaphomegranathi ami. 
\q1  
\v 3 Ingalo yakhe yobunxele ngiyiqamele 
\q2 kuthi ingalo yakhe yokunene ingigonile. 
\q1  
\v 4 Madodakazi aseJerusalema, ngiyaliqonqosela: 
\q2 Lingalunyakazisi loba liluvuse uthando 
\q2 luze luzifunele lona. 
\sp Abangane 
\q1  
\v 5 Ngubani lo oqhamukayo evela enkangala na, 
\q2 eyeme isithandwa sakhe? 
\sp Umlobokazi 
\q1 Ngikuvusile ngaphansi kwesihlahla se-aphula; 
\q2 kulapho unyoko akumithela khona, 
\q2 kulapho ahelelwa wakuzalela khona. 
\q1  
\v 6 Ngibeka ngibe njengesidindo enhliziyweni yakho, 
\q2 njengesidindo engalweni yakho; 
\q1 ngoba uthando lulamandla njengokufa, 
\q2 ubukhwele balo kabuyekethisi njengengcwaba. 
\q1 Luyatshisa njengomlilo obhebha kakhulu, 
\q2 njengelangabi elivuthayo. 
\q1  
\v 7 Impophoma zamanzi ngeke zilucime uthando; 
\q2 imifula ngeke ilukhukhule. 
\q1 Nxa umuntu enganika 
\q2 yonke inotho yomuzi wakhe 
\q2 ngenxa yothando kungaba yinhlekisa. 
\sp Abangane 
\q1  
\v 8 Silentombazana engumnawethu, 
\q2 njalo kayikaphuhli. 
\q1 Sizamenzelani kambe umnawethu 
\q2 mhla sekuthiwa uyacelwa? 
\q1  
\v 9 Uba engumduli, 
\q2 sizakwakha imiphotshongo yesiliva phezu kwakhe. 
\q1 Uba engumnyango, 
\q2 sizamvala ngamapulanka esihlahla somsedari. 
\sp Umlobokazi 
\q1  
\v 10 Ngingumduli, 
\q2 lamabele ami anjengemiphotshongo. 
\q1 Yikho-nje emehlweni akhe 
\q2 sengifana lalowo olethe ukusuthiseka. 
\q1  
\v 11 USolomoni wayelesivini eBhali Hamoni; 
\q2 wasiqhatshisela ebalimini isivini sakhe. 
\q1 Munye ngamunye kwakumele athele umthelo wezithelo zawo 
\q2 ongamashekeli esiliva ayinkulungwane. 
\q1  
\v 12 Kodwa esami isivini ngesami ukupha santando; 
\q2 amashekeli lawo ayinkulungwane ngawakho, bakithi Solomoni, 
\q2 lamakhulu amabili amashekeli ngawalabo abalondoloza izithelo zawo. 
\sp Umyeni 
\q1  
\v 13 Wena ohlala ezivandeni labangane 
\q2 bekususa isizungu, 
\q2 ake ngilizwe ilizwi lakho! 
\sp Umlobokazi 
\q1  
\v 14 Masihambe, sithandwa sami, 
\q2 woba njengembabala 
\q1 kumbe njengejongosana lomziki 
\q2 ezintabeni ezigcwele amakha.