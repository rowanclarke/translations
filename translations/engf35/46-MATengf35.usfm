\v 24 \w A|strong="G1510"\w* \w disciple|strong="G3101"\w* \w is|strong="G1510"\w* \w not|strong="G3756"\w* \w above|strong="G5228"\w* \w his|strong="G3588"\w* \w teacher|strong="G1320"\w*, \w nor|strong="G3761"\w* \w a|strong="G1510"\w* \w slave|strong="G1401"\w* \w above|strong="G5228"\w* \w his|strong="G3588"\w* \w master|strong="G2962"\w*.  
