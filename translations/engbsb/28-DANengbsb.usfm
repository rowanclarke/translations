\m \w The|strong="H3606"\w* \w king|strong="H4430"\w* said \w to|strong="H5922"\w* Daniel, “May \w your|strong="H1768"\w* God, \w whom|strong="H1768"\w* \w you|strong="H1768"\w* serve continually, deliver \w you|strong="H1768"\w*!”
\b
\m 
\v 17 \w A|strong="H3068"\w* stone \w was|strong="H1841"\w* \w brought|strong="H1841"\w* \w and|strong="H6032"\w* placed over \w the|strong="H1768"\w* mouth \w of|strong="H4430"\w* \w the|strong="H1768"\w* \w den|strong="H1358"\w*, \w and|strong="H6032"\w* \w the|strong="H1768"\w* \w king|strong="H4430"\w* sealed \w it|strong="H1932"\w* \w with|strong="H1841"\w* \w his|strong="H7804"\w* own signet ring \w and|strong="H6032"\w* \w with|strong="H1841"\w* \w the|strong="H1768"\w* rings \w of|strong="H4430"\w* \w his|strong="H7804"\w* nobles, \w so|strong="H1768"\w* \w that|strong="H1768"\w* nothing concerning \w Daniel|strong="H1841"\w* \w could|strong="H1768"\w* \w be|strong="H1841"\w* changed.
