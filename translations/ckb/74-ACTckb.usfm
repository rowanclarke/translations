\id ACT - Biblica® Open Kurdi Sorani Standard Version
\h کردار
\toc1 کرداری نێردراوان
\toc2 کردار
\toc3 کردار
\mt1 کرداری نێردراوان
\c 1
\s1 بەرزکردنەوەی عیسا بۆ ئاسمان
\p 
\v 1 بەڕێز ساوفیلۆس، لە پەڕتووکی یەکەممدا دەربارەی هەموو ئەوەی کە عیسا دەستی کرد بە ئەنجامدان و فێرکردنی نووسیومە،
\v 2 هەتا ئەو ڕۆژەی تێیدا بەرزکرایەوە، دوای ئەوەی لە ڕێگەی ڕۆحی پیرۆزەوە ئەو نێردراوانەی ڕاسپارد کە هەڵیبژاردن.
\v 3 دوای ئازارچێژتنی بە چەندین بەڵگە بە زیندوویی خۆی پیشاندان، لە ماوەی چل ڕۆژدا بۆیان دەرکەوت و سەبارەت بە شانشینی خودا بۆیان دوا.
\v 4 کاتێک پێکەوە نانیان دەخوارد، ڕایسپاردن: «ئۆرشەلیم بەجێمەهێڵن، بەڵکو چاوەڕێی بەڵێنەکەی باوک بکەن کە لە منەوە بیستتان.
\v 5 یەحیا خەڵکی لە ئاو هەڵدەکێشا، بەڵام ئێوە پاش چەند ڕۆژێکی کەم لە ڕۆحی پیرۆز هەڵدەکێشرێن\f + \fr 1:5 \ft یۆنانی: \tl باپتیزۆ‏\tl*، بە واتای شوشتن دێت بۆ پاکبوونەوە لە گوناه، وەک (بسمیلکردن).‏\f*.»
\p 
\v 6 ئەوانەی پێکەوە کۆببوونەوە لێیان پرسی: «ئەی خاوەن شکۆ، لەم کاتەدا پاشایەتی بۆ ئیسرائیل دەگەڕێنیتەوە؟»
\p 
\v 7 وەڵامی دانەوە: «بۆتان نییە ئەو کات و سەردەمانە بزانن کە باوک بە دەسەڵاتی خۆی دایناون.
\v 8 بەڵام کاتێک ڕۆحی پیرۆزتان دێتە سەر، هێز وەردەگرن و بۆ من دەبنە شایەت، لە ئۆرشەلیم و هەموو یەهودیا و سامیرە، تاکو ئەوپەڕی زەوی.»
\p 
\v 9 ئەمەی فەرموو و ئەوانیش تەماشایان دەکرد، بەرزکرایەوە، هەورێک لەبەرچاویان شاردییەوە.
\p 
\v 10 کاتێک ئەو دەڕۆیشت، ئەوان سەرنجیان لە ئاسماندا بوو، ئەوە بوو دوو پیاو بە جلی سپییەوە لەلایانەوە ڕاوەستاون.
\v 11 پێیان گوتن: «ئەی جەلیلییەکان، بۆچی ڕاوەستاون سەیری ئاسمان دەکەن؟ ئەم عیسایە، کە لەنێوتاندا بۆ ئاسمان بەرزکرایەوە، چۆن بینیتان دەچووە ئاسمان، ئاواش دێتەوە.»
\s1 هەڵبژاردنی یەکێک لە جێی یەهوزا
\p 
\v 12 ئینجا لەو کێوەی پێی دەگوترا زەیتوون گەڕانەوە ئۆرشەلیم کە بەقەد ڕۆیشتنێکی شەممە لە ئۆرشەلیم نزیک بوو.\f + \fr 1:12 \ft ئەو دووریەیە کە جولەکەیەک بۆی هەیە لە ڕۆژی شەممەدا بیبڕێت. ئەویش تەنها (1100 مەترە)، چونکە وەک نەریتێکی ئایینی ڕۆژی شەممە بۆ پشوودانە.‏\f*
\v 13 کاتێک گەیشتن، چوونە ژوورێک لە نهۆمی سەرەوە، ئەوەی کە تێیدا دەمانەوە، ئەوانیش ئەمانە بوون:
\b
\li1 پەترۆس و یۆحەنا و یاقوب،
\li1 ئەندراوس و فیلیپۆس و تۆماس،
\li1 بەرتۆلماوس و مەتا و یاقوبی کوڕی حەلفی،
\li1 شیمۆنی دڵگەرم\f + \fr 1:13 \ft یۆنانی: \tl زێلۆتێس‏\tl*، پارتێکی ڕادیکالی جولەکە بوو، \xt مەتا 10‏:4‏\xt*\ft ‏.‏\f* و یەهوزای برای یاقوب.
\b
\p 
\v 14 هەموو بە یەک دڵ بەردەوام بوون لەسەر نوێژکردن، لەگەڵ ژنەکان و مریەمی دایکی عیسا و براکانی.
\p 
\v 15 ڕۆژێکیان پەترۆس کە لەنێوان نزیکەی سەد و بیست باوەڕداردا بوو، هەستا و گوتی:
\v 16 «خوشک و برایان، دەبووایە نووسراوە پیرۆزەکە بێتە دی، پێشتر لەبارەی یەهوزاوە ڕۆحی پیرۆز لەسەر زمانی داود فەرموویەتی، کە بوو بە ڕێبەر بۆ ئەوانەی عیسایان گرت.
\v 17 بە یەکێک لە ئێمە دەژمێردرا و لەم خزمەتەدا بەشی هەبوو.»
\p 
\v 18 (یەهوزا بە پاداشتی ناپاکی کێڵگەیەکی دەستکەوت، بەڵام بەدەمدا کەوت و لە ناوەڕاستەوە شەق بوو، هەموو هەناوی هاتە دەرەوە.
\v 19 هەموو دانیشتووانی ئۆرشەلیم بەمەیان زانی، لەبەر ئەوە لە زمانی خۆیان ئەو کێڵگەیان ناو نا حەقل دەمخ، کە بە واتای کێڵگەی خوێن دێت.)
\p 
\v 20 پەترۆس درێژەی پێدا و گوتی: «لە پەڕتووکی زەبووردا نووسراوە:
\q1 «﴿با ماڵەکەی چۆڵ بێت،
\q2 کەس نەبێت تێیدا نیشتەجێ بێت!﴾\f + \fr 1:20 \ft \xt زەبوورەکان 69‏:25.‏\xt*\ft ‏\f*
\m هەروەها:
\q1 ﴿با یەکێکی دیکە ئەرکەکەی ئەو وەربگرێت.﴾\f + \fr 1:20 \ft \xt زەبوورەکان 109‏:8.‏\xt*\ft ‏\f*
\m 
\v 21 کەواتە با یەکێک لەو پیاوانەی کە یاوەرمان بوون بە درێژایی ئەو ماوەیەی عیسای مەسیح لەنێوماندا دەژیا،
\v 22 هەر لە لەئاوهەڵکێشانەکەیەوە لەلایەن یەحیا هەتا ئەو ڕۆژەی بەرزکرایەوە، لەگەڵماندا ببێتە شایەتی هەستانەوەکەی.»
\p 
\v 23 جا دووانیان هێنایە پێشەوە، یوسف کە بە بارساباس ناودەبردرا و نازناوی یوستۆس بوو، لەگەڵ مەتیاس.
\v 24 نوێژیان کرد و گوتیان: «ئەی یەزدان، تۆ بە دڵی هەمووان دەزانیت، بۆمان دەربخە لەم دووانە کامەیانت هەڵبژاردووە،
\v 25 تاکو شوێنی ئەو خزمەت و نێردراویێتییە بگرێتەوە، کە یەهوزا لێی لادا، بۆ ئەوەی بچێتە شوێنی خۆی.»
\v 26 ئینجا تیروپشکیان بۆ کردن و تیروپشکەکە مەتیاسی گرتەوە، لەگەڵ یازدە نێردراوەکە ژمێردرا.
\c 2
\s1 هاتنی ڕۆحی پیرۆز
\p 
\v 1 کە ڕۆژی پەنجایەمین\f + \fr 2:1 \ft پەنجایەمین ڕۆژ لەدوای جەژنی پەسخە، هەروەها ڕۆژی جەژنی دروێنەیە، بڕوانە \xt دەرچوون 23‏:16‏–34‏:22 و دواوتار 16‏:9‏-12.‏\xt*\ft ‏\f* هات، هەموو باوەڕداران پێکەوە لە یەک شوێندا بوون،
\v 2 لەناکاو دەنگێک لە ئاسمانەوە وەک ڕەشەبا هات، ئەو ماڵەی پڕکرد کە تێیدا دانیشتبوون.
\v 3 ئینجا چەند زمانێکی دابەشبوو وەک ئاگر بۆیان دەرکەوت و لەسەر هەریەکەیان نیشتەوە.
\v 4 جا هەموویان پڕبوون لە ڕۆحی پیرۆز و دەستیان پێکرد بە زمانەکانی دیکە بدوێن، وەک ڕۆح پێی بەخشین.
\p 
\v 5 لەو کاتەدا جولەکەی لەخواترسی هەموو نەتەوەکانی ژێر ئاسمان لە ئۆرشەلیم مابوونەوە.
\v 6 کاتێک دەنگەکە هات، خەڵک کۆبوونەوە و بووە پەشێوی، چونکە هەریەکەیان گوێی لە زمانی خۆی دەبوو پێی دەدوان.
\v 7 حەپەسابوون و بە سەرسامییەوە گوتیان: «باشە هەموو ئەوانەی قسە دەکەن جەلیلی نین؟
\v 8 ئەی چۆن هەریەکەمان گوێی لە زمانی دایکیی خۆی دەبێت؟
\v 9 ئێمەی خەڵکی پەرتیا و میدیا و ئیلامی، دانیشتووانی میسۆپۆتامیا، یەهودیا و کەپەدۆکیا، پۆنتۆس و ئاسیا،
\v 10 فریجیا و پامفیلیا، میسر و ناوچەکانی لیبیای ڕووەو کورێن\f + \fr 2:10 \ft گەورەترین شار لە وڵاتی لیبیا لەم سەردەمەدا.‏\f*، هەروەها میوانەکانی ڕۆما،
\v 11 جولەکە و ئەوانەشی ببوون بە جولەکە، کریتی و عەرەب، ئەوەتا گوێمان لێیانە بە زمانی خۆمان باسی کردارە مەزنەکانی خودا دەکەن.»
\v 12 هەموو سەرسام و حەپەسا بوون، بە یەکتریان دەگوت: «دەبێ ئەمە واتای چی بێت؟»
\p 
\v 13 هەندێکی دیکە بە گاڵتە پێکردنەوە دەیانگوت: «شەرابی نوێیان زۆر خواردووەتەوە.»
\s1 یەکەم وتاری پەترۆس
\p 
\v 14 پەترۆس لەگەڵ یازدە نێردراوەکەی دیکەی عیسا ڕاوەستا، بە دەنگی بەرز بە خەڵکی ڕاگەیاند: «ئەی پیاوانی جولەکە و هەموو ئەوانەی لە ئۆرشەلیم دانیشتوون، با ئەمە لەلاتان زانراو بێت و گوێ لە قسەکانم بگرن،
\v 15 چونکە وەک بیردەکەنەوە ئەمانە سەرخۆش نین، لەبەر ئەوەی هێشتا کاتژمێر نۆی\f + \fr 2:15 \ft یۆنانی: کاتژمێری سێیەم.‏\f* بەیانییە!
\v 16 بەڵکو لە ڕێگەی پێغەمبەر یۆئێلەوە گوتراوە:
\q1 
\v 17 «﴿خودا دەفەرموێ، لە ڕۆژانی کۆتاییدا
\q2 ڕۆحم بەسەر هەموو خەڵکدا دەڕێژم.
\q1 کوڕان و کچانتان پەیامی خودا ڕادەگەیەنن،
\q2 گەنجانتان بینینیان بۆ ئاشکرا دەکرێت،
\q2 پیرەمێردەکانتان خەون دەبینن.
\q1 
\v 18 تەنانەت بەسەر بەندە و کەنیزەکانیشم،
\q2 لەو ڕۆژانەدا ڕۆحی خۆم دەبارێنم و
\q2 ئەوانیش پەیامی خودا ڕادەگەیەنن.
\q1 
\v 19 لە سەرەوە لە ئاسمان پەرجوو\f + \fr 2:19 \ft پەرجوو: موعجیزە.‏\f* و
\q2 لە خوارەوە لەسەر زەوی نیشانە دەکەم:
\q2 خوێن و ئاگر و ستوونی دووکەڵ.
\q1 
\v 20 خۆر دەبێتە تاریکی و
\q2 مانگیش دەبێتە خوێن،
\q2 بەر لەوەی ڕۆژی گەورە و شکۆداری یەزدان بێت.
\q1 
\v 21 جا هەرکەسێک بە ناوی یەزدانەوە بپاڕێتەوە،
\q2 ڕزگاری دەبێت.﴾\f + \fr 2:21 \ft \xt یۆئێل 2‏:28‏-32‏\xt*\ft ‏\f*
\p 
\v 22 «پیاوانی ئیسرائیل، گوێ لەم قسانە بگرن: عیسای ناسیرەیی پیاوێکە بۆتان سەلمێنرا، بە پەرجوو و کاری مەزن و نیشانە لەلایەن خوداوە لایەنگری کراوە، کە خودا لە ڕێگەی ئەوەوە لەنێوتان ئەنجامی دا، وەک خۆتان دەزانن.
\v 23 ئەم بەگوێرەی خواستی بڕیارلەسەردراو و زانینی پێشووی خودا داتانە دەست، بە دەستی گوناهباران لە خاچتان دا و کوشتتان.
\v 24 بەڵام خودا هەڵیستاندەوە و لە ئازاری مردن ئازادی کرد، لەبەر ئەوەی نەدەکرا لە چنگیدا بمێنێتەوە.
\v 25 سەبارەت بە ئەو داود گوتوویەتی:
\q1 «﴿هەمیشە یەزدانم لەبەردەمم دەبینی،
\q2 لەبەر ئەوەی لەلای دەستەڕاستمەوەیە، ناهەژێم.
\q1 
\v 26 بۆیە دڵشادم و زارم خۆشی دەردەبڕێت،
\q2 تەنانەت جەستەم لە هیوادا نیشتەجێ دەبێت،
\q1 
\v 27 چونکە تۆ گیانم لە جیهانی مردوواندا\f + \fr 2:27 \ft یۆنانی: \tl هادیس‏\tl*: بڕوانە پەراوێزی \xt مەتا 11‏:23‏\xt*\ft ‏.‏\f* بەجێناهێڵیت،
\q2 هەروەها ڕێگا نادەیت دڵسۆزەکەی تۆ لەناو گۆڕ بۆگەن بێت.
\q1 
\v 28 ڕێگاکانی ژیانت پێ ناساندم،
\q2 تێربوون لە شادی لە ئامادەبوونتدایە.﴾\f + \fr 2:28 \ft \xt زەبوورەکان 16‏:8‏-11‏\xt*\ft ‏\f*
\p 
\v 29 «برایان، با بە ڕاشکاوی پێتان بڵێم کە داودی باوکمان مرد و نێژرا، گۆڕەکەشی تاکو ئەمڕۆ لەلامانە.
\v 30 ئەویش کە پێغەمبەر بوو، دەیزانی خودا سوێندی خواردووە و بەڵێنی پێداوە کە لە بەری پشتی ئەو لەسەر تەختەکەی دادەنیشێت.
\v 31 پێشبینیی کرد و باسی هەستانەوەی مەسیحەکەی\f + \fr 2:31 \ft بە زمانی عیبری پێی دەگوترێ \tl مەشیخ‏\tl* یان \tl مەشیح‏\tl*. بە زمانی یۆنانی دەبێتە \tl کریستۆس‏\tl*، کە بە واتای (دەستنیشانکراو) لەلای خودا دێت کە ڕزگارکەری گەلەکەیەتی. بڕوانە یەکەم ساموئێل 16.‏\f* کرد، کە نە لە جیهانی مردوواندا بەجێهێڵرا و نە جەستەشی بۆگەن بوو.
\v 32 ئەم عیسایە خودا هەڵیستاندەوە، ئێمەش هەموومان شایەتین بۆی.
\v 33 ئینجا بۆ لای دەستەڕاستی خودا بەرزکرایەوە کە بەڵێنی ڕۆحی پیرۆزی لە باوکەوە وەرگرت، ئەمەی ڕژاند کە ئێوە دەیبینن و دەیبیستن.
\v 34 داود بۆ ئاسمان بەرز نەکرایەوە، بەڵکو خۆی دەڵێت:
\q1 «﴿یەزدان بە خاوەن شکۆی منی فەرموو:
\q2 ”لە دەستەڕاستم دابنیشە
\q1 
\v 35 هەتا دوژمنانت دەکەمە تەختەپێ\f + \fr 2:35 \ft تەختەپێ: لەبەر بەرزی ئاستی کورسی مێزێکی بچووکە دەخرێتە ژێر پێ.‏\f* بۆ پێیەکانت.“﴾\f + \fr 2:35 \ft \xt زەبوورەکان 110‏:1‏\xt*\ft ‏\f*
\p 
\v 36 «بۆیە با هەموو ماڵی ئیسرائیل بە دڵنیاییەوە بزانن کە ئەم عیسایەی ئێوە لە خاچتان دا، خودا کردی بە مەسیحی خاوەن شکۆ.»
\p 
\v 37 کاتێک ئامادەبووان گوێیان لەم قسانە بوو، کاری کردە سەر دڵیان، بە پەترۆس و نێردراوانی دیکەیان گوت: «برایان، چی بکەین؟»
\p 
\v 38 پەترۆس وەڵامی دانەوە: «تۆبە بکەن، با هەریەکەتان بە ناوی عیسای مەسیحەوە لە ئاو هەڵبکێشرێت بۆ لێخۆشبوونی گوناهەکانتان و ڕۆحی پیرۆز بە دیاری وەردەگرن.
\v 39 ئەم بەڵێنەش بۆ خۆتان و منداڵەکانتان و بۆ هەموو ئەوانەیە کە دوورن\f + \fr 2:39 \ft ئەوانەی دوورن: مەبەستی لەوانەیە کە لە نەتەوەکانی دیکەن و یەزدان بانگیان دەکات.‏\f* و یەزدانی پەروەردگارمان بانگیان دەکات.»
\p 
\v 40 بە زۆر قسەی دیکەش ئاگاداری کردنەوە و لێیان پاڕایەوە: «خۆتان لەم نەوە لار و چەوتە ڕزگار بکەن.»
\v 41 ئەوانەی کە قسەکەیان وەرگرت لە ئاو هەڵکێشران، لەو ڕۆژەدا نزیکەی سێ هەزار کەس هاتنە ڕیزی باوەڕدارانەوە.
\s1 هاوبەشیی باوەڕداران
\p 
\v 42 ئیتر ئەوان پەیوەستبوون لەسەر فێرکردنی نێردراوان و هاوبەشییەتی\f + \fr 2:42 \ft پێکەوە ژیان و بەشداریکردنی یەکتر لە ڕووی ماددی و مەعنەوییەوە.‏\f*، لەتکردنی نان\f + \fr 2:42 \ft پێکەوە نانخواردن و دواتریش یادکردنەوەی شێوی مەسیح. بڕوانە \xt یەکەم کۆرنسۆس 11‏:23‏\xt*\ft ‏.‏\f* و نوێژکردن.
\v 43 هەموو لە ناخەوە سام دایگرتبوون، چونکە زۆر پەرجوو و نیشانە لەسەر دەستی نێردراوان کران.
\v 44 باوەڕداران هەموو پێکەوە بوون و لە هەرچی هەیانبوو هاوبەش بوون.
\v 45 ماڵوموڵکی خۆیان دەفرۆشت و بەگوێرەی پێویستی هەریەکەیان دابەشیان دەکرد.
\v 46 ڕۆژانە بە یەک دڵ بەردەوام لە حەوشەکانی پەرستگا دەبوون، لە ماڵەکاندا نانیان لەتدەکرد، بە خۆشی و دڵپاکییەوە پێکەوە نانیان دەخوارد،
\v 47 ستایشی خودایان دەکرد و لەلای هەموو خەڵک پەسەند بوون. مەسیحی خاوەن شکۆش ڕۆژانە ئەوانەی دەهێنایە پاڵیان کە ڕزگاریان دەبوو.
\c 3
\s1 چاکبوونەوەی ئیفلیجێک
\p 
\v 1 ڕۆژێکیان کاتژمێر سێی\f + \fr 3:1 \ft یۆنانی: کاتژمێری نۆیەم.‏\f* پاش نیوەڕۆ، کە کاتی نوێژ بوو، پەترۆس و یۆحەنا سەرکەوتن بۆ پەرستگا.
\v 2 لەبەردەم دەرگای پەرستگادا کە پێی دەگوترا دەرگای جوان، پیاوێک بە زگماک ئیفلیج دانیشتبوو، هەموو ڕۆژێک هەڵیاندەگرت‏ و لەوێ دایاندەنا تاکو سواڵ بکات لەوانەی دەهاتنە حەوشەکانی پەرستگاکەوە.
\v 3 کاتێک ئەو پیاوە بینی کە پەترۆس و یۆحەنا بە نیازن بێنە ناو حەوشەکانی پەرستگا، داوای خێری لێکردن.
\v 4 پەترۆس و یۆحەنا بە وردی تێیانڕوانی، ئینجا پەترۆس گوتی: «سەیرمان بکە!»
\v 5 ئەویش چاوی تێبڕین و چاوەڕێی دەکرد شتێکیان لێ وەربگرێت.
\p 
\v 6 پەترۆس گوتی: «زێڕ و زیوم نییە، بەڵام ئەوەی هەمە دەتدەمێ. بە ناوی عیسای مەسیحی ناسیرەییەوە، هەستە و بڕۆ!»
\v 7 ئینجا بە دەستی ڕاستی گرتی و هەڵیستاند، دەستبەجێ هێز کەوتە پێ و پاژنەکانی.
\v 8 ئیتر هەڵبەزییەوە و ڕاوەستا و دەستی بە ڕۆیشتن کرد، لەگەڵیان چووە ناو حەوشەکانی پەرستگا، دەڕۆیشت و هەڵدەبەزییەوە و ستایشی خودای دەکرد.
\v 9 هەموو خەڵک بینییان دەڕوات و ستایشی خودا دەکات.
\v 10 جا کاتێک خەڵکەکە زانییان ئەمە ئەو کەسەیە کە بۆ سواڵکردن لەلای دەرگای پەرستگا دادەنیشت، ئەوەی پێی دەگوترا جوان، سەرسامی و حەپەساوی دایگرتن لەوەی بەسەری هاتووە.
\s1 وتاری پەترۆس لە پەرستگا
\p 
\v 11 کاتێک پیاوەکە خۆی بە پەترۆس و یۆحەناوە هەڵواسیبوو، هەموو خەڵکەکە بە سەرسامییەوە ڕایانکردە لایان بۆ ئەو ڕێڕەوەی کە پێی دەگوترا ڕێڕەوی سلێمان، کە هەردوو لای بە کۆڵەکە گیرابوو.
\v 12 پەترۆس ئەمەی بینی، پێی گوتن: «پیاوانی ئیسرائیل، بۆچی لەمە سەرسامن؟ بۆچی چاوتان تێبڕیوین وەک ئەوەی بە توانا یان بە لەخواترسیمان وامان کردووە بڕوات؟
\v 13 خودای ئیبراهیم و ئیسحاق و یاقوب، خودای باوکانمان، عیسای خزمەتکاری خۆی شکۆدار کرد، ئەوەی بە گرتنتان دا و لەبەردەم پیلاتۆس نکۆڵیتان لێکرد، کە بڕیاری دابوو بەریبدات.
\v 14 ئێوە نکۆڵیتان لە پیرۆز و ڕاستودروستەکە\f + \fr 3:14 \ft مەبەست لە مەسیحە.‏\f* کرد و داوای ئازادکردنی بکوژێکتان کرد.
\v 15 سەرۆکی ژیانتان کوشت، بەڵام خودا لەنێو مردووان هەڵیستاندەوە و ئێمە شایەتین بۆ ئەمە.
\v 16 ئەم پیاوەی ئێوە دەیبینن ‏و دەیناسن،‏ باوەڕی بەناوی عیسا هەبوو، بۆیە هێز و توانای بۆ گەڕایەوە. بە ناوی عیسا و ئەو باوەڕەی بەهۆیەوە دێت، لە‏بەرچاوی هەمووتان ئەم تەندروستییە تەواوەی پێ بەخشی.
\p 
\v 17 «ئێستاش برایان دەزانم بە نەزانی ئەوەتان کرد، هەروەک ڕابەرەکانیشتان.
\v 18 بەڵام خودا ئەوەی هێنایە دی کە پێشتر لەسەر زمانی هەموو پێغەمبەرانەوە ڕایگەیاندبوو، کە مەسیحەکەی خۆی ئازار دەچێژێت.
\v 19 کەواتە تۆبە بکەن و بگەڕێنەوە بۆ لای خودا تاکو گوناهەکانتان بسڕێنەوە، بۆ ئەوەی لەلای یەزدانەوە کاتی حەسانەوەتان بێت و
\v 20 مەسیحتان بۆ بنێرێتەوە، ئەو عیسایەی کە پێشتر بۆتانی دیاری کردبوو.
\v 21 ئەوەی دەبێت لە ئاسمان بیهێڵێتەوە، هەتا کاتی چاککردنەوەی هەموو شتێک\f + \fr 3:21 \ft گەڕانەوەی مەسیح، بڕوانە \xt ئاشکراکردن 21‏\xt*\ft ‏.‏\f*، ئەوەی لە کۆنەوە خودا لەسەر زاری پێغەمبەرە پیرۆزەکانییەوە باسی کردووە.
\v 22 موساش گوتی: ﴿یەزدانی پەروەردگارتان لەنێو برایانتاندا پێغەمبەرێکی وەک منتان بۆ دادەنێت، دەبێت گوێ لە هەموو ئەو شتانە بگرن کە پێتانی دەڵێت.
\v 23 جا هەرکەسێک گوێ لەم پێغەمبەرە نەگرێت لەنێو گەل دادەبڕدرێت.﴾\f + \fr 3:23 \ft \xt دواوتار 18‏:15‏،18‏،19.‏\xt*\ft ‏\f*
\p 
\v 24 «هەموو پێغەمبەرانیش، لە ساموئێل بەدواوە، هەموو ئەوانەی قسەیان کردووە، باسی ئەم ڕۆژانەیان کردووە.
\v 25 ئێوەش کوڕی پێغەمبەران و ئەو پەیمانەن کە خودا لەگەڵ باوکانتاندا بەستی، کاتێک بە ئیبراهیمی فەرموو: ﴿لە ڕێگەی نەوەی تۆوە هەموو نەتەوەکانی سەر زەوی بەرەکەتدار دەبن.﴾\f + \fr 3:25 \ft \xt پەیدابوون 22‏:18؛ 26‏:4.‏\xt*\ft ‏\f*
\v 26 کاتێک خودا خزمەتکاری خۆی هەستاندەوە، یەکەم جار بۆ ئێوەی نارد، بۆ ئەوەی بەرەکەتدارتان بکات بە گەڕانەوەی هەریەکەتان لە خراپەکانی.»
\c 4
\s1 پەترۆس و یۆحەنا لە ئەنجومەنی باڵادا
\p 
\v 1 کاتێک پەترۆس و یۆحەنا قسەیان بۆ خەڵکەکە دەکرد، کاهینان و سەرۆکی پاسەوانی پەرستگا و سەدوقییەکان هاتنە لایان،
\v 2 زۆر لێیان پەست بوون، چونکە خەڵکیان فێردەکرد و دەیانگوت کە مردووان زیندوو دەبنەوە هەروەک چۆن عیسا زیندووبووەوە.
\v 3 بۆیە پەترۆس و یۆحەنایان گرت و لەبەر ئەوەی دەمەو ئێوارە بوو، هەتا بەیانی لە زیندانیان کردن.
\v 4 بەڵام زۆر لەوانەی گوێیان لە قسەکان بوو باوەڕیان هێنا و ژمارەی پیاوان گەیشتە پێنج هەزار.
\p 
\v 5 بۆ بەیانی پێشەوایان و پیران و مامۆستایانی تەورات لە ئۆرشەلیم کۆبوونەوە،
\v 6 لەگەڵ حەنای سەرۆکی کاهینان و قەیافا و یۆحەنا و ئەسکەندەر و هەموو ئەوانەی لە تیرەی سەرۆکی کاهینان بوون.
\v 7 پەترۆس و یۆحەنایان لە ناوەڕاست ڕاگرت و پرسیاریان لێکردن: «بە چ هێزێک و بە چ ناوێک ئەمەتان کرد؟»
\p 
\v 8 لەو کاتەدا پەترۆس پڕبوو لە ڕۆحی پیرۆز، پێی گوتن: «ئەی پێشەوایانی گەل و ئەی پیران،
\v 9 ئەگەر ئەمڕۆ لەسەر چاکەیەک کە بۆ پەککەوتەیەک کراوە، لێکۆڵینەوەمان لەگەڵ دەکەن و لێمان دەپرسن کە بە چی چاک بووەتەوە،
\v 10 ئەوا با لەلای هەمووتان و هەموو گەلی ئیسرائیل زانراو بێت، بە ناوی عیسای مەسیحی ناسیرەیی، ئەم ئیفلیجە کە بەو تەندروستییە لەبەردەمتان ڕاوەستاوە چاک بووەوە، بە ناوی ئەو عیسایەی کە ئێوە لە خاچتان دا و خوداش لەناو مردووان هەڵیستاندەوە.
\v 11 ئەمە
\q1 «﴿ئەو بەردەیە کە ئێوەی وەستا ڕەتتان کردەوە،
\q2 ئەوەی بوو بە گرنگترین بەردی بناغە\f + \fr 4:11 \ft بەردێکی گەورەیە کە لە گۆشەی دیوار دادەنرێت، لەو بەردانە بەهێزترە کە لە دیوارەکە بەکاردێت و دەبێتە هۆی بەهێزکردنی دیوارەکە.‏\f*‏.﴾\f + \fr 4:11 \ft \xt زەبوورەکان 118‏:22‏\xt*\ft ‏\f*
\m 
\v 12 بێجگە لە عیسا ڕزگاربوون بە کەسی دیکە نییە، چونکە لەژێر ئاسماندا ناوێکی دیکە بە مرۆڤەکان نەدراوە کە بە هۆیەوە بتوانین ڕزگار بین.»
\p 
\v 13 کاتێک ئازایەتی پەترۆس و یۆحەنایان بینی و زانییان خەڵکێکی نەخوێندەوار\f + \fr 4:13 \ft دەرچووی قوتابخانەی ئایینی بۆ مامۆستایەتی تەورات نین.‏\f* و سادەن، سەرسام بوون و بۆیان دەرکەوت کە ئەم پیاوانە پێشتر لەگەڵ عیسادا بوون.
\v 14 بەڵام کاتێک ئەو پیاوەشیان بینی لەگەڵیان ڕاوەستابوو، ئەوەی چاک بووەوە، هیچیان نەبوو وەڵامی پێ بدەنەوە.
\v 15 ئەوسا فەرمانیان پێدان لە ئەنجومەنی باڵا\f + \fr 4:15 \ft ئەنجومەنی باڵای جولەکە کە لە یۆنانی پێی گوتراوە \tl سەنهەدرین‏\tl*، باڵاترین دەسەڵاتی جولەکە بووە کە دەسەڵاتی دەرکردنی بڕیاری ئایینی و شارستانی و تاوانبارکردنی هەبووە.‏\f* بچنە دەرەوە و لەناو خۆیاندا کەوتنە گفتوگۆ:
\v 16 «چی لەم پیاوانە بکەین؟ ئاشکرایە بۆ هەموو دانیشتووانی ئۆرشەلیم کە نیشانەیەکی بەرچاو لە ڕێگەی ئەمانەوە کراوە، ناتوانین نکۆڵی لێ بکەین.
\v 17 بەڵام نەوەک زیاتر لەنێو گەل بڵاو بێتەوە، هەڕەشەیان لێ دەکەین ئیتر لەلای کەس باسی ئەم ناوە نەکەن.»
\p 
\v 18 ئینجا بانگیان کردن و فەرمانیان پێدان کە بە هیچ شێوەیەک بە ناوی عیسا دەم نەکەنەوە و کەسیش فێرنەکەن.
\v 19 بەڵام پەترۆس و یۆحەنا وەڵامیان دایەوە: «بەلای خوداوە کامیان دروستترە: گوێ لە ئێوە بگرین یان لە ئەو؟ ئێوە حوکم بدەن!
\v 20 بەڵام ئێمە ئەوەی بینیومانە و بیستوومانە ناتوانین باسی نەکەین.»
\p 
\v 21 دوای هەڕەشەی زیاتر، بەریاندان. نەیانزانی چۆن سزایان بدەن، لەبەر ئەوەی هەموو ستایشی خودایان دەکرد بەهۆی ئەوەی ڕوویدابوو،
\v 22 چونکە ئەو پیاوەی ئەم نیشانەی چاکبوونەوەی بەسەرهاتبوو لە چل ساڵ زیاتر بوو.
\s1 نوێژی باوەڕداران
\p 
\v 23 کە پەترۆس و یۆحەنا بەربوون، هاتنە لای هاوڕێیەکانیان و ئەو شتانەی کاهینانی باڵا و پیران پێیان گوتبوون بۆیان گێڕانەوە.
\v 24 کاتێک هاوڕێیەکانیان ئەمەیان بیست، هەموویان بە یەک دەنگ هاواریان بۆ خودا کرد: «ئەی یەزدانی باڵادەست، تۆی دروستکەری ئاسمان و زەوی و دەریا و هەموو ئەو شتانەی تێیاندایە.
\v 25 لە ڕێگەی ڕۆحی پیرۆز لەسەر زاری داودی باوکمان و بەندەی خۆت فەرمووت:
\q1 «﴿بۆچی نەتەوەکان دەوروژێن و
\q2 گەلان پیلان لە شتی پووچ دەگێڕن؟
\q1 
\v 26 پاشایانی زەوی خۆیان ڕێک دەخەن،
\q2 سەرۆکەکانیان پێکەوە کۆدەبنەوە
\q2 لە دژی یەزدان و مەسیحەکەی\f + \fr 4:26 \ft یۆنانی: \tl کریستۆس‏\tl*. واتا مەسیح، هەروەها (دەستنیشانت کرد) لە ئایەتی 27، ئەوەی بە دەستی پێغەمبەر و بە ڕێگای چەورکردن بە ڕۆن بۆ پاشایەتی دەستنیشان کراوە، بڕوانە \xt یەکەم ساموئێل 9‏:16؛ 16‏:12.‏\xt*\ft ‏\f*‏.﴾\f + \fr 4:26 \ft \xt زەبوورەکان 2‏:1‏-2‏\xt*\ft ‏\f*
\m 
\v 27 لەبەر ئەوەی بە ڕاستی لەم شارەدا، هێرۆدس و پیلاتۆسی پۆنتی و ناجولەکەکان و گەلی ئیسرائیل لە دژی عیسای خزمەتکاری پیرۆزت یەکیانگرت، ئەوەی کە دەستنیشانت کرد.
\v 28 ئەو کارەیان ئەنجام دا کە هێز و خواستی تۆ پێشوەخت نەخشەیان بۆ کێشابوو کە دەبێت ڕووبدەن.
\v 29 ئێستاش ئەی یەزدان، سەیری هەڕەشەکانیان بکە، توانای ئەوە بە خزمەتکارەکانت ببەخشە کە بەوپەڕی ئازایەتییەوە بە وشەکانت بدوێن.
\v 30 دەستت درێژ بکە تاکو چاکبوونەوە و نیشانە و پەرجوو بە ناوی عیسای خزمەتکاری پیرۆزتەوە بکرێت.»
\p 
\v 31 کاتێک لە خودا دەپاڕانەوە، ئەو شوێنەی کە تێدا کۆببوونەوە هاتە لەرزین و هەموویان پڕبوون لە ڕۆحی پیرۆز، بە چاونەترسییەوە پەیامی خودایان ڕادەگەیاند.
\s1 پێکەوە ژیان
\p 
\v 32 کۆمەڵی باوەڕداران یەک دڵ و گیان بوون، کەس نەیدەگوت ئەوەی هەیەتی هی خۆیەتی، بەڵکو لە هەموو شتێکدا هاوبەش بوون.
\v 33 نێردراوان بە هێزێکی گەورەوە شایەتی هەستانەوەی عیسای خاوەن شکۆیان دەدا، نیعمەتێکی\f + \fr 4:33 \ft نیعمەت بەخشینێکی خودایە بە مرۆڤ بەبێ شایستەبوونی پێی دەبەخشێت.\f* گەورەش بەسەر هەموویانەوە بوو.
\v 34 کەسی نەبوونیان تێدا نەبوو، چونکە هەموو ئەوانەی خاوەن کێڵگە و ماڵ بوون دەیانفرۆشت، پارەکەیان دەهێنا و
\v 35 لەبەرپێی نێردراوان دایاندەنا، ئەوانیش بەگوێرەی پێویستی کەسەکان دابەشیان دەکرد.
\p 
\v 36 یەکێک لەوان پیاوێک بوو بە ناوی یوسف کە لێڤییەکی قوبرسی بوو. نێردراوان پێیان دەگوت بەرناباس کە بە واتای «کوڕی هاندەر» دێت.
\v 37 کێڵگەیەکی هەبوو، فرۆشتی و پارەکەی هێنا، خستییە بەرپێی نێردراوان.
\c 5
\s1 حەنانیا و سەفیرە
\p 
\v 1 پیاوێک ناوی حەنانیا بوو، لەگەڵ سەفیرەی ژنی پارچە زەوییەکی فرۆشت.
\v 2 بە ئاگاداری ژنەکەی بەشێک لە پارەکەی بۆ خۆی هەڵگرت، ئەوەی مایەوە هێنای و خستییە بەرپێی نێردراوان.
\p 
\v 3 پەترۆس گوتی: «حەنانیا، بۆچی شەیتان دڵی پڕکردوویت، بۆ ئەوەی درۆ لەگەڵ ڕۆحی پیرۆز بکەیت و لە پارەی زەوییەکە بەشێک بۆ خۆت هەڵبگریت؟
\v 4 ئایا نەتدەتوانی کێڵگەکە بۆ خۆت دابنێیت و نەیفرۆشی کاتێک کە هی خۆت بوو؟ پاش فرۆشتنی ئایا مافی ئەوەت نەبوو نرخەکەی هەڵبگریت؟ ئیتر بۆچی لە دڵی خۆتدا ویستت ناپاکی بکەیت؟ تۆ درۆت لەگەڵ خەڵک نەکرد، بەڵکو لەگەڵ خودا.»
\p 
\v 5 کاتێک حەنانیا گوێی لەم قسەیە بوو، کەوت و مرد. هەموو ئەوانەی ئەمەیان بیست ترسێکی گەورەیان لێ نیشت.
\v 6 ئینجا چەند گەنجێک هەستان و کفنیان کرد، هەڵیانگرت بۆ دەرەوە و ناشتیان.
\p 
\v 7 پاش نزیکەی سێ کاتژمێر، ژنەکەی هاتە ژوورە و نەیدەزانی چی ڕوویداوە.
\v 8 پەترۆس لێی پرسی: «پێم بڵێ، زەوییەکەتان بەم بڕە فرۆشت؟»
\p گوتی: «بەڵێ، بەم بڕە.»
\p 
\v 9 پەترۆسیش پێی گوت: «بۆچی ڕێککەوتن ڕۆحی یەزدان تاقی بکەنەوە؟ ئەوەتا ئەوانەی مێردەکەتیان ناشت لە بەردەرگان، تۆش هەڵدەگرن و دەتبەنە دەرەوە.»
\p 
\v 10 دەستبەجێ ژنەکە لەبەرپێی پەترۆسدا کەوت و مرد. کاتێک گەنجەکان هاتنە ژوورەوە و بینییان مردووە، هەڵیانگرت و لەتەنیشت مێردەکەی ناشتیان.
\v 11 ئیتر ترسێکی گەورە هاتە سەر هەموو کڵێسا و هەموو ئەوانەی ئەمانەیان بیست.
\s1 زۆربوونی باوەڕداران
\p 
\v 12 لەسەر دەستی نێردراوان زۆر نیشانە و پەرجوو لەنێو گەلدا کرا. هەموو باوەڕداران بە یەک دڵ لە ڕێڕەوەکەی سلێمان لە پەرستگادا کۆدەبوونەوە.
\v 13 کەس نەیدەوێرا بچێتە پاڵیان، بەڵام گەل زۆر ڕێزیان دەگرتن.
\v 14 لەگەڵ ئەوەشدا هەتا دەهات ژن و پیاو بە کۆمەڵ باوەڕیان بە مەسیحی خاوەن شکۆ دەهێنا و دەهاتنە پاڵی.
\v 15 لە ئەنجامدا، وای لێهات نەخۆشیان دەهێنایە سەر شەقام و لەسەر جێگا و نوێن دایاندەنان، بەڵکو ئەگەر پەترۆس هات، سێبەرەکەی بکەوێتە سەر هەندێکیان.
\v 16 خەڵکی شارەکانی دەوروپشتی ئۆرشەلیمیش کۆببوونەوە، نەخۆش و ئەوانەیان هەڵگرتبوو کە بە دەست ڕۆحی پیس دەیانناڵاند، جا هەموویان چاکدەبوونەوە.
\p 
\v 17 بەڵام سەرۆکی کاهینان و هەموو ئەوانەی لەگەڵی بوون لە ڕێبازی سەدوقی هەستان و پڕبوون لە ئیرەیی.
\v 18 نێردراوانیان گرت و فڕێیان دانە زیندانی گشتییەوە.
\v 19 بەڵام فریشتەیەکی یەزدان لە شەودا دەرگای زیندانەکەی کردەوە و بردنییە دەرەوە و گوتی:
\v 20 «بڕۆن بۆ حەوشەکانی پەرستگا و ڕاوەستن، تەواوی پەیامی ئەم ژیانە بە خەڵکی بڵێن.»
\p 
\v 21 هەرکە گوێیان لێبوو، بەیانی زوو چوونە حەوشەکانی پەرستگا و دەستیان کرد بە فێرکردنی خەڵک.
\p سەرۆکی کاهینان و ئەوانەی لەگەڵی بوون هاتن، ئەنجومەنی باڵا و هەموو کۆمەڵی پیرانی نەوەی ئیسرائیلیان بانگکرد و ناردیان لە زیندان بیانهێنن.
\v 22 بەڵام کە پاسەوانەکان چوون و لە زیندان نەیاندۆزینەوە، گەڕانەوە و هەواڵیان پێدان و گوتیان:
\v 23 «زیندانەکەمان بینی بە باشی داخرابوو، پاسەوانیش لە بەردەرگاکان ڕاوەستابوون، بەڵام کاتێک کردمانەوە کەسمان تێیدا نەبینی.»
\v 24 کاتێک سەرۆکی پاسەوانی پەرستگا و کاهینانی باڵا ئەمەیان بیست، لێیان سەرسام بوون و گوتیان ئەمە چی بەسەردێت!
\p 
\v 25 ئینجا یەکێک هات و گوتی: «ئەو پیاوانەی فڕێتاندانە زیندانەوە، وا لە حەوشەکانی پەرستگادا ڕاوەستاون و خەڵکی فێر دەکەن.»
\v 26 ئەوسا سەرۆک و پاسەوانان ڕۆیشتن و بێ توندوتیژی نێردراوانیان هێنا، چونکە دەترسان گەل بەردبارانیان بکەن.
\p 
\v 27 کاتێک ئەوانیان هێنا و لەبەردەم ئەنجومەنی باڵادا ڕایانگرتن، سەرۆکی کاهینان لێی پرسین:
\v 28 «بە توندی فەرمانمان پێ کردن خەڵکی بەم ناوە فێر نەکەن، ئەوەتا ئۆرشەلیمتان لە فێرکردنەکانتان پڕکردووە و دەتانەوێ خوێنی ئەم پیاوە بخەنە ئەستۆمان.»
\p 
\v 29 پەترۆس و نێردراوان وەڵامیان دایەوە: «دەبێت گوێڕایەڵی بۆ خودا بێت زیاتر لەوەی بۆ خەڵک!
\v 30 خودای باوباپیرانمان عیسای هەستاندەوە، ئەوەی بە هەڵواسینی لەسەر دار کوشتتان.
\v 31 خودا ئەوی وەک سەرۆک و ڕزگارکەر بۆ دەستەڕاستی خۆی بەرز کردەوە، تاکو تۆبەکردن و لێخۆشبوونی گوناه بە ئیسرائیل ببەخشێت.
\v 32 ئێمە شایەتی ئەم شتانەین، هەروەها ڕۆحی پیرۆزیش، ئەوەی خودا بەخشیویەتییە ئەوانەی گوێڕایەڵن بۆی.»
\p 
\v 33 کاتێک گوێیان لێبوو زۆر تووڕە بوون، ویستیان بیانکوژن.
\v 34 بەڵام فەریسییەک بە ناوی گەمالائیل کە مامۆستای تەورات بوو و هەموو گەل ڕێزیان دەگرت، لە ئەنجومەنی باڵا هەستا و فەرمانی کرد کە نێردراوان بۆ ماوەیەکی کەم ببردرێنە دەرەوە.
\v 35 پێی گوتن: «پیاوانی ئیسرائیل، ئاگاداری خۆتان بن لەوەی دەتانەوێ بەم پیاوانەی بکەن.
\v 36 ماوەیەک لەمەوبەر سوداس دەرکەوت و خۆی بە شت دەزانی، هەروەها نزیکەی چوار سەد پیاوی لێ کۆبوونەوە، بەڵام کوژرا و هەموو ئەوانەی دوای کەوتبوون بڵاو بوونەوە و ئاسەواریان نەما.
\v 37 دوای ئەمەش لە کاتی ناونووسینەکەدا یەهوزای جەلیلی هەستا و خەڵکانێکی بەدوای خۆیدا لەخشتە برد، ئەویش لەناوچوو و ئەوانەی دوای کەوتبوون بڵاوبوونەوە.
\v 38 ئێستاش ئامۆژگاریتان دەکەم، لەم پیاوانە دوور بکەونەوە و وازیان لێ بهێنن، چونکە ئەگەر ئەم بیروباوەڕە و کارە لە خەڵکەوە بێت، تێکدەچێت.
\v 39 بەڵام ئەگەر لە خوداوە بێت، ناتوانن تێکی بدەن، ئەگینا خۆتان دەبیننەوە لە دژی خودا دەجەنگن.»
\p 
\v 40 وتەکانی قایلی کردن، بۆیە نێردراوانیان بانگکرد و فەرمانیان دا کە بدرێنە بەر قامچی. ئینجا فەرمانیان پێکردن ناوی عیسا نەهێنن و ئازادیان کردن.
\p 
\v 41 ئیتر نێردراوان بە دڵشادییەوە لەبەردەم ئەنجومەنی باڵا هاتنە دەرەوە، چونکە بە شیاوی ئەوە دانران کە لە پێناو ناوی عیسادا سووکایەتییان پێ بکرێت.
\v 42 ئیتر هەموو ڕۆژێک لە حەوشەکانی پەرستگا و لە ماڵاندا، بێوچان خەڵکیان فێردەکرد و مزگێنییان دەدا کە عیسا مەسیحەکەیە.
\c 6
\s1 هەڵبژاردنی حەوت خزمەتکار
\p 
\v 1 لەو ڕۆژانەدا کە قوتابییەکان زیادیان دەکرد، جولەکە یۆنانییەکان\f + \fr 6:1 \ft ئەو جولەکانەی لە دەرەوەی فەلەستین بە زمانی یۆنانی قسە دەکەن.‏\f* بۆڵەبۆڵیان لەسەر عیبرانییەکان\f + \fr 6:1 \ft ئەو جولەکانەی لەناو فەلەستین بە زمانی عیبری قسە دەکەن.‏\f* کرد کە لە دابەشکردنی نانی ڕۆژانە بێوەژنەکانیان پشتگوێ دەخرێن.
\v 2 بۆیە دوازدە نێردراوەکە هەموو قوتابییەکانیان بانگکرد و گوتیان: «باش نییە بۆمان ڕاگەیاندنی پەیامی خودا پشتگوێ بخەین و خەریکی ئازووقە دابەشکردن بین.
\v 3 خوشک و برایان، لەنێو خۆتاندا حەوت پیاو هەڵبژێرن کە ناوبانگیان باش بێت و پڕبن لە ڕۆحی پیرۆز و دانایی، تاکو لەسەر ئەم ئەرکە دایانبنێین.
\v 4 ئێمەش خۆمان تەرخان دەکەین بۆ نوێژکردن و بۆ خزمەتی ڕاگەیاندنی پەیامی خودا.»
\p 
\v 5 هەموو کۆمەڵەکە ئەم پێشنیارەیان بەدڵ بوو، جا ستیفانۆسیان هەڵبژارد، کە پیاوێکی پڕ لە باوەڕ و ڕۆحی پیرۆز بوو، لەگەڵ فیلیپۆس و پروخۆرۆس و نیکانۆر و تیمۆن و پەرمیناس و نیکۆلاوسی ئەنتاکی کە ببووە جولەکە.
\v 6 لەپێش نێردراوانیان ڕاگرتن، ئەوانیش نوێژیان کرد و دەستیان لەسەر دانان.
\p 
\v 7 ئیتر پەیامی خودا لە گەشەکردندا بوو، ژمارەی قوتابییەکانیش لە ئۆرشەلیم زۆر زیاتر ببوون، ژمارەیەکی زۆریش لە کاهینان باوەڕیان بە مەسیح هێنا و گوێڕایەڵی بوون.
\s1 گرتنی ستیفانۆس
\p 
\v 8 ستیفانۆس پڕبوو لە نیعمەت و هێزی خودا، پەرجوو و نیشانەی گەورەی لەنێو گەلدا دەکرد.
\v 9 جا هەندێک لەوانەی لەو کەنیشتەن کە پێی دەگوترا کەنیشتی ئازادکراوان، لەگەڵ کورێنییەکان و ئەسکەندەرییەکان و ئەوانەی لە ناوچەکانی کیلیکیا و ئاسیان، هەستان و دەمەقاڵێیان لەگەڵ ستیفانۆس کرد.
\v 10 بەڵام نەیانتوانی بەربەرەکانێی ئەو داناییە بکەن کە ڕۆحی پیرۆز لە قسەکردندا پێیدابوو.
\p 
\v 11 بۆیە بەدزییەوە خەڵکیان هاندا تاکو بڵێن: «گوێمان لێی بوو سەبارەت بە موسا و خودا کفری دەکرد.»
\p 
\v 12 ئینجا گەل و پیران و مامۆستایانی تەوراتیان جۆشدا، هاتنە سەری و گرتییان و بۆ ئەنجومەنی باڵایان هێنا.
\v 13 شایەتی درۆزنیان دانا، دەیانگوت: «ئەم پیاوە وەستانی نییە لە قسەکردن لە دژی ئەم شوێنە پیرۆزە\f + \fr 6:13 \ft پەرستگا‏\f* و تەورات،
\v 14 ئێمەش گوێمان لێی بوو دەیگوت کە عیسای ناسیرەیی ئەم شوێنە تێکدەدات و ئەو نەریتانە دەگۆڕێت کە لە موساوە وەرمانگرتووە.»
\p 
\v 15 جا هەموو ئەوانەی لە ئەنجومەنی باڵا دانیشتبوون چاویان تێبڕی و بینییان ڕووی وەک ڕووی فریشتە وایە.
\c 7
\s1 وتاری ستیفانۆس
\p 
\v 1 سەرۆکی کاهینان لێی پرسی: «ئایا ئەو تۆمەتانە ڕاستن؟»
\p 
\v 2 ئەویش گوتی: «برایان و باوکان گوێ بگرن، خودای شکۆمەندی بۆ ئیبراهیمی باوکمان دەرکەوت کاتێک لە میسۆپۆتامیا بوو، پێش ئەوەی لە حاران نیشتەجێ بێت،
\v 3 پێی فەرموو: ﴿خاک و کەسوکارت بەجێبهێڵە و بڕۆ بۆ ئەو خاکەی پیشانت دەدەم.﴾\f + \fr 7:3 \ft \xt پەیدابوون 12‏:1‏\xt*\ft ‏\f*
\p 
\v 4 «خاکی کلدانییەکانی بەجێهێشت و لە حاران نیشتەجێ بوو. دوای مردنی باوکی، خودا لەوێوە گواستییەوە بۆ ئەم خاکەی ئێوە ئێستا تێیدا نیشتەجێن.
\v 5 لێرەدا هیچ میراتێکی نەدایێ، تەنانەت شوێن پێیەکیش. بەڵام خودا بەڵێنی پێدا کە بە موڵک بیداتە خۆی و وەچەکەی لەدوای خۆی، هەرچەندە هێشتا منداڵی نەبوو.
\v 6 خوداش ئاوای فەرموو: ﴿نەوەکانت لە خاکێک نامۆ دەبن کە هی خۆیان نییە، دەبنە کۆیلەیان و چوار سەد ساڵ دەیانچەوسێننەوە.
\v 7 بەڵام ئەو نەتەوەیەش حوکم دەدەم، کە ئەوان وەک کۆیلە خزمەتیان دەکەن،﴾ خودا فەرموویەتی، ﴿دوای ئەوە دێنە دەرەوە و لەم شوێنە دەمپەرستن.﴾\f + \fr 7:7 \ft \xt پەیدابوون 15‏:13،‏\xt*\ft ‏ 14‏\f*
\v 8 خوداش پەیمانی خەتەنەکردنی لەگەڵ ئیبراهیم بەست. ئاوا ئیسحاقی بوو، لە تەمەنی هەشت ڕۆژیدا خەتەنەی کرد. ئیسحاقیش یاقوبی بوو، یاقوبیش دوازدە باوکانی یەکەمینی\f + \fr 7:8 \ft مەبەستی لە دوازدە سەرۆک هۆزەکەیە، یەهودا و لێڤی و یوسف و هتد.‏\f* بوو.
\p 
\v 9 «باوکانیش چاویان بە یوسف هەڵنەهات، فرۆشتیانە میسر. بەڵام خودای لەگەڵ بوو،
\v 10 لە هەموو ناخۆشییەکانی ڕزگاری کرد، لەبەردەم فیرعەونی پاشای میسردا نیعمەت و دانایی پێدا. ئەویش کردی بە فەرمانڕەوای میسر و سەرپەرشتیاری هەموو ماڵەکەی خۆی.
\p 
\v 11 «ئینجا قاتوقڕی و تەنگانە بەسەر هەموو میسر و کەنعاندا هات، باوباپیرانمان خواردنیان دەست نەدەکەوت.
\v 12 یاقوب بیستی لە میسر دانەوێڵە هەیە، جاری یەکەم باوکانمانی نارد.
\v 13 بۆ جاری دووەم یوسف بە برایانی ناسرا، بنەماڵەی یوسفیش بۆ فیرعەون دەرکەوت.
\v 14 ئیتر یوسف ناردی یاقوبی باوکی بە هەموو کەسوکاریەوە بۆ میسر بانگکرد، کە حەفتا و پێنج کەس بوون.
\v 15 جا یاقوب بۆ میسر دابەزی و مرد، خۆی و باوباپیرانمان.
\v 16 ئینجا بۆ شەخەم گەڕاندیانەوە و لەو گۆڕە ناشتییان کە ئیبراهیم لە شەخەم بە بڕێک زیو لە کوڕەکانی حەمۆری کڕی.
\p 
\v 17 «بەڵام ئەو کاتەی بەڵێنەکە نزیک دەبووەوە کە خودا بە ئیبراهیمی دا، گەل لە میسر پەرەیان دەسەند و زۆردەبوون،
\v 18 تاکو ﴿لە میسر پاشایەکی نوێ هاتە سەر تەخت کە یوسفی نەدەناسی.﴾\f + \fr 7:18 \ft \xt دەرچوون 1‏:7‏-8‏\xt*\ft ‏\f*
\v 19 لەگەڵ گەلەکەمان بە فێڵ دەجوڵایەوە و خراپەی لەگەڵ باوباپیرانمان کرد، ناچاری دەکردن منداڵە ساواکانیان دووربخەنەوە تاکو بمرن.
\p 
\v 20 «لەو کاتەدا موسا لەدایک بوو. لەبەرچاوی خودا جوان بوو، سێ مانگ لە ماڵی باوکی بەخێوکرا،
\v 21 کاتێک دوورخرایەوە\f + \fr 7:21 \ft بۆ پاراستنی لە مردن لەناو سەبەتەیەک خرایە ناو ڕووباری نیل، بڕوانە \xt دەرچوون 2‏:4‏\xt*\ft ‏.‏\f*، کچی فیرعەون هەڵیگرتەوە و کردییە کوڕی خۆی و بەخێوی کرد.
\v 22 موساش لەناو هەموو دانایی میسرییەکاندا پەروەردە کرا، بە توانا لە قسە و کرداردا.
\p 
\v 23 «کاتێک تەمەنی بووە چل ساڵ، بڕیاری دا سەردانی برا ئیسرائیلییەکانی بکات.
\v 24 یەکێکیانی بینی ستەمی لێ دەکرێت، بەرگری لێکرد و دادوەریی بۆ ستەملێکراو کرد، میسرییەکەی کوشت.
\v 25 وایزانی برایانی تێدەگەن کە خودا لەسەر دەستی ئەو ڕزگاریان دەکات. بەڵام تێنەگەیشتن.
\v 26 بۆ بەیانی دوو لە برا عیبرانییەکانی بینی کە شەڕیان دەکرد، هەوڵی دەدا ئاشتیان بکاتەوە، گوتی: ”ئێوە بران، بۆچی دەست بۆ یەکتری درێژ دەکەن؟“
\p 
\v 27 «بەڵام ئەوەی ستەمی لە نزیکەکەی دەکرد، پاڵێکی پێوەنا و گوتی: ﴿کێ تۆی کردووە بە گەورە و دادوەر بەسەرمانەوە؟
\v 28 ئایا دەتەوێ بمکوژیت هەروەک دوێنێ میسرییەکەت کوشت؟﴾\f + \fr 7:28 \ft \xt دەرچوون 2‏:14‏\xt*\ft ‏\f*
\v 29 موساش بەهۆی ئەم قسەیەوە هەڵهات، لە خاکی میدیان بووە بێگانە و لەوێ دوو کوڕی بوو.
\p 
\v 30 «دوای ئەوەی چل ساڵ تەواوبوو، ﴿فریشتەیەک لە بیابانی شاخی سینا لەنێو دەوەنێکی داگیرساودا بۆی دەرکەوت.﴾\f + \fr 7:30 \ft \xt دەرچوون 3‏:2‏\xt*\ft ‏\f*
\v 31 موساش ئەمەی بینی و لە دیمەنەکە سەرسام بوو، دەچووە پێش تاکو لە نزیکەوە سەیر بکات، دەنگی یەزدان هات:
\v 32 ﴿من خودای باوکانت، خودای ئیبراهیم و ئیسحاق و یاقوبم.﴾\f + \fr 7:32 \ft \xt دەرچوون 3‏:6‏\xt*\ft ‏\f* بەڵام موسا لەرز گرتی و نەیوێرا سەیر بکات.
\p 
\v 33 «﴿جا یەزدان پێی فەرموو: پێڵاوەکانت لە پێت دابکەنە، چونکە ئەو شوێنەی تۆ لەسەری وەستاویت خاکێکی پیرۆزە.
\v 34 بەڕاستی من ئەزیەتی گەلەکەی خۆمم لە میسر بینی و گوێم لە ناڵەیان بوو، هاتمە خوارەوە تاکو دەربازیان بکەم. ئێستاش وەرە، دەتنێرمە میسر.﴾\f + \fr 7:34 \ft \xt دەرچوون 3‏:5‏-10.‏\xt*\ft ‏\f*
\p 
\v 35 «ئەو موسایەی ڕەتیان کردەوە و گوتیان: ﴿کێ تۆی کردووە بە گەورە و دادوەر بەسەرمانەوە؟﴾\f + \fr 7:35 \ft \xt دەرچوون 2‏:14‏\xt*\ft ‏\f* هەر ئەو بوو خودا وەک گەورە و ئازادکەر بە دەستی ئەو فریشتەیە ناردی کە لە دەوەنەکەدا بۆی دەرکەوت.
\v 36 جا موسا گەلەکەی لە‏ میسر هێنایە‏ دەرەوە، پەرجوو و نیشانەی کرد لە خاکی میسر، لە دەریای سوور، هەروەها لە ماوەی چل ساڵدا لە چۆڵەوانی.
\p 
\v 37 «ئەمە ئەو موسایەیە کە بە نەوەی ئیسرائیلی گوت: ﴿خودا لەنێو براکانتان پێغەمبەرێکی وەک منتان بۆ دادەنێت.﴾\f + \fr 7:37 \ft \xt دواوتار 18‏:15‏\xt*\ft ‏\f*
\v 38 هەر ئەویش بوو لە چۆڵەوانی لەناو کڵێساکەدا\f + \fr 7:38 \ft یۆنانی: \tl ئێکلێسیا‏\tl*: بانگکراوان بۆ کۆبوونەوە. مەبەستی لەو ڕۆژەیە کە لە سەردەمی موسا لە شاخی سینا خودا گەلی خۆی کۆکردەوە بۆ ئەوەی قسەیان لەگەڵ بکات، بڕوانە \xt دواوتار 4‏:10 و دەرچوون 19‏ و 20‏\xt*\ft .‏\f* بوو، لەگەڵ ئەو فریشتەیەی لە شاخی سینا قسەی لەگەڵی دەکرد، لەگەڵ باوباپیرانیشمان، ئەوەی وشە زیندووەکانی وەرگرت تاکو بمانداتێ.
\p 
\v 39 «بەڵام باوباپیرانمان نەیانویست گوێڕایەڵی بن. ئەویان ڕەتکردەوە و دڵیان بۆ میسر لێی دەدا.
\v 40 بە هارونیان گوت: ﴿چەند خوداوەندێکمان بۆ دروستبکە تاکو پێشڕەویمان بکەن، چونکە ئەم موسایە، ئەو پیاوەی ئێمەی لە خاکی میسرەوە دەرهێنا نازانین چی لێهات.﴾\f + \fr 7:40 \ft \xt دەرچوون 32‏:1‏\xt*\ft ‏\f*
\v 41 لەو ڕۆژانەدا بتێکیان لە شێوەی گۆلک دروستکرد و قوربانییان بۆ کرد، بە دەستکردی خۆیان دڵشاد بوون.
\v 42 بەڵام خودا ڕووی لێ وەرگێڕان و وازی لێ هێنان ئەستێرەکانی ئاسمان\f + \fr 7:42 \ft یۆنانی: سوپای ئاسمان.‏\f* بپەرستن، وەک لە پەڕتووکی پێغەمبەراندا نووسراوە:
\q1 «﴿ئەی بنەماڵەی ئیسرائیل، ئایا بۆ ماوەی چل ساڵ لە چۆڵەوانی
\q2 قوربانی سەربڕاو و پێشکەشکراوتان بۆ هێنام؟
\q1 
\v 43 نەخێر، بەڵکو نزرگەی بتی مۆلەختان\f + \fr 7:43 \ft خوداوەندێکی کەنعانییە بتپەرستەکان بووە، خەڵکی بۆ پەرستنی هەستاون بە تێپەڕاندنی منداڵەکانیان بەناو ئاگردا. بڕوانە دووەم هەواڵی ڕۆژان 28: 3.‏\f*
\q2 لەگەڵ ئەستێرەی خوداوەندەکەتان هەڵگرت، ڕێفان\f + \fr 7:43 \ft خوداوەندێکی میسرییەکان بوو.‏\f*،
\q2 ئەو پەیکەرانەی دروستتان کرد تاکو بیانپەرستن.
\q1 لەبەر ئەوە من بۆ شوێنێک ڕاپێچتان دەکەم کە لە بابل دوورترە.﴾\f + \fr 7:43 \ft \xt ئامۆس 5‏:25‏-27.‏\xt*\ft ‏\f*
\p 
\v 44 «چادری پەرستنی شایەتیش لە چۆڵەوانیدا لەگەڵ باوباپیرانمان بوو، هەروەک ئەوەی خودا فەرمانی بە موسا کرد لەسەر ئەو نموونەیە دروستی بکات کە بینیویەتی.
\v 45 جا باوباپیرانمان چادری پەرستنیان وەرگرت و لەگەڵ یەشوع بردیانە ناو موڵکی ئەو گەلانەی خودا لەبەردەمی باوکانمان دەریکردن هەتا ڕۆژانی داود،
\v 46 ئەوەی لەلای خودا ڕەزامەندی بەدەستهێنا، ئەویش هەوڵی دا نشینگەیەک بۆ خودای یاقوب دروستبکات.
\v 47 کەچی ئەوە سلێمان بوو کە ماڵێکی بۆ دروستکرد.
\p 
\v 48 «بەڵام خودای هەرەبەرز لە ماڵی دەستکرد نیشتەجێ نابێت، هەروەک پێغەمبەر ئیشایا گوتوویەتی:
\q1 
\v 49 «﴿ئاسمان تەختی منە و زەویش تەختەپێمە،
\q2 چ ماڵێکم بۆ بنیاد دەنێن؟
\q4 یەزدان دەفەرموێ،
\q2 لەکوێیە شوێنی حەوانەوەم؟
\q1 
\v 50 ئایا دەستی من هەموو ئەم شتانەی دروستنەکردووە؟﴾\f + \fr 7:50 \ft \xt ئیشایا 66‏:1‏-2.‏\xt*\ft ‏\f*
\p 
\v 51 «ئەی کەللەڕەقان، ئەی دڵ و گوێ خەتەنەنەکراوان! ئێوە وەک باوباپیرانتان هەمیشە بەربەرەکانێی ڕۆحی پیرۆز دەکەن!
\v 52 باوباپیرانتان چ پێغەمبەرێکیان نەچەوساندووەتەوە؟ ئەوانەشیان کوشت کە زوو باسی هاتنی ڕاستودروستەکەیان\f + \fr 7:52 \ft مەبەستی عیسای مەسیحە.‏\f* دەکرد، ئەوەی ئێستا ئێوە بە گرتنتان دا و کوشتتان.
\v 53 ئێوە تەوراتتان بە ڕێنمایی فریشتەکان وەرگرت بەڵام پەیڕەوتان نەکرد.»
\s1 کوشتنی ستیفانۆس
\p 
\v 54 کاتێک ئەندامانی ئەنجومەنی باڵا گوێیان لەم قسانەی ستیفانۆس بوو، دڵیان پڕبوو لە قین و ددانیان لێی جیڕکردەوە.
\v 55 بەڵام ستیفانۆس پڕ ببوو لە ڕۆحی پیرۆز، چاوی بڕییە ئاسمان، شکۆی خودای بینی و عیساش لە دەستەڕاستی خودا وەستابوو.
\v 56 گوتی: «دەبینم ئاسمان کراوەتەوە و کوڕی مرۆڤیش لە دەستەڕاستی خودا ڕاوەستاوە.»
\p 
\v 57 بەمە گوێی خۆیان توند گرت و هەمووان بە دەنگێکی بەرز هاواریان کرد و تێکڕا پەلاماریان دا،
\v 58 بردیانە دەرەوەی شار و بەردبارانیان کرد. شایەتەکانیش جلەکانیان داکەند و خستیانە بەرپێی گەنجێک کە ناوی شاول بوو.
\p 
\v 59 کاتێک ستیفانۆسیان بەردباران دەکرد، نوێژی دەکرد: «عیسای خاوەن شکۆ، ڕۆحم وەربگرە!»
\v 60 ئینجا چۆکی دادا و بە دەنگێکی بەرز هاواری کرد: «ئەی مەسیحی خاوەن شکۆ، ئەم گوناهەیان لەسەر مەنووسە.» ئەمەی گوت و نوست\f + \fr 7:60 \ft مەبەستی لە مردنە. مەسیح بە مردن دەڵێت نوستن. بڕوانە \xt مەتا 9‏:24 و یۆحەنا 11‏:11.‏\xt*\ft ‏‏\f*.
\c 8
\s1 چەوسانەوەی باوەڕداران
\p 
\v 1 شاول بە کوشتنی ستیفانۆس ڕازی بوو.
\p هەر لەو ڕۆژەدا کڵێسا لە ئۆرشەلیم تووشی چەوسانەوەیەکی توند هات. هەموو بە ناوچەکانی یەهودیا و سامیرەدا پەرشوبڵاو بوونەوە، نێردراوان نەبێت.
\v 2 هەندێک پیاوی لەخواترس ستیفانۆسیان ناشت و پرسەیەکی باشیان بۆ دانا.
\v 3 بەڵام شاول دەستی کرد بە لەناوبردنی کڵێسا، ماڵ بە ماڵ ژن و پیاوی ڕادەکێشا و فڕێیدەدانە زیندان.
\s1 مزگێنیدان لە سامیرە
\p 
\v 4 ئەوانەی پەرشوبڵاو ببوونەوە دەگەڕان و مزگێنیی پەیامی خودایان بڵاودەکردەوە.
\v 5 فیلیپۆس بەرەو شاری سامیرە چووە خوارەوە و لەوێ مزگێنیی مەسیحی بە خەڵکەکە ڕاگەیاند.
\v 6 خەڵکەکە بە یەک دڵ گوێیان لەوە دەگرت کە فیلیپۆس دەیگوت، کاتێک ئەو نیشانانەیان دەبیست و دەبینی کە دەیکرد.
\v 7 ڕۆحی پیسیش لە زۆر کەس لەوانەی تێیاندا بوو بە دەنگی بەرز هاواریان دەکرد و دەردەچوون، زۆر گۆج و شەلیش چاکبوونەوە.
\v 8 جا خۆشییەکی گەورە ئەو شارەی گرتەوە.
\p 
\v 9 پێشتر لە شارەکە پیاوێک هەبوو ناوی شیمۆن بوو، جادووی دەکرد و خەڵکی سامیرەی سەرسام کردبوو، دەیگوت: «پیاوێکی پایەبەرزم!»
\v 10 گەورە و بچووک هەموو گوێیان لێ دەگرت و دەیانگوت: «ئەم پیاوە بە هێزی خودای گەورە ناودەبردرێت.»
\v 11 ئەوان گوێیان بۆ دەگرت، چونکە لەمێژ بوو بە جادووەکەی سەرسامی کردبوون.
\v 12 بەڵام کاتێک فیلیپۆس مزگێنیی پاشایەتی خودا و ناوی عیسای مەسیحی پێدان، باوەڕیان کرد و ژن و پیاو لە ئاو هەڵکێشران.
\v 13 شیمۆنیش باوەڕی هێنا و لە ئاو هەڵکێشرا، ئینجا دوای فیلیپۆس کەوت و سەرسام بوو بەو نیشانە و پەرجووە گەورانەی کە دەیبینی.
\p 
\v 14 کاتێک نێردراوان لە ئۆرشەلیم بیستیان سامیرە پەیامی خودای قبوڵ کردووە، پەترۆس و یۆحەنایان بۆ ناردن.
\v 15 کاتێک هاتن، نوێژیان بۆ کردن بۆ ئەوەی ڕۆحی پیرۆز وەربگرن،
\v 16 چونکە هێشتا ڕۆحی پیرۆز نەهاتبووە سەر کەسیان، تەنها بە ناوی عیسای خاوەن شکۆوە لە ئاو هەڵکێشرابوون.
\v 17 جا پەترۆس و یۆحەنا دەستیان لەسەر دانان و ڕۆحی پیرۆزیان وەرگرت.
\p 
\v 18 شیمۆن بینی کە نێردراوان دەستیان لەسەر خەڵک دادەنێن ڕۆحی پیرۆز دەدرێت، پارەی بۆ هێنان و
\v 19 گوتی: «ئەو دەسەڵاتە بە منیش بدەن، تاکو دەست لەسەر هەرکەسێک دابنێم ڕۆحی پیرۆز وەربگرێت.»
\p 
\v 20 پەترۆس پێی گوت: «با زیوەکەت لەگەڵ خۆت لەناوبچێت! چونکە واتزانی بەهرەی خودا بە پارە دەبێت!
\v 21 لەم شتەدا نە بەشت هەیە و نە پشک، چونکە دڵت بەرامبەر خودا ڕاست نییە.
\v 22 لەم خراپەیەت تۆبە بکە و لە مەسیحی خاوەن شکۆ بپاڕێوە بەڵکو لە مەبەستی دڵت خۆش بێت،
\v 23 چونکە دەتبینم کە پڕیت لە تاڵی و گیرۆدەی گوناهیت.»
\p 
\v 24 شیمۆن گوتی: «ئێوە لە پێناوی من داوا لە مەسیحی خاوەن شکۆ بکەن، تاکو هیچ شتێک لەوەی باستان کرد بە سەرمدا نەیەت.»
\p 
\v 25 دوای ئەوەی پەترۆس و یۆحەنا لەبارەی عیساوە شایەتییان دا و پەیامی مەسیحی خاوەن شکۆیان ڕاگەیاند، گەڕانەوە ئۆرشەلیم و مزگێنییان دایە زۆر گوندی سامیرەیی.
\s1 فیلیپۆس و وەزیری حەبەشە
\p 
\v 26 فریشتەیەکی یەزدان بە فیلیپۆسی گوت: «هەستە و بەرەو باشوور بڕۆ، لەسەر ئەو ڕێگایەی لە ئۆرشەلیمەوە بۆ غەزە شۆڕ دەبێتەوە، کە چۆڵەوانییە.»
\v 27 ئەویش هەستا و ڕۆیشت، پیاوێکی خەساوی حەبەشی بینی کە وەزیری کاروباری دارایی کنداکەی\f + \fr 8:27 \ft ئافرەتێکە پاشای حەبەشە بووە.‏\f* شاژنی حەبەشە بوو، بۆ پەرستن هاتبووە ئۆرشەلیم.
\v 28 لە گەڕانەوەدا بوو، لەناو گالیسکەکەی دانیشتبوو، پەڕتووکی ئیشایا پێغەمبەری دەخوێندەوە.
\v 29 ڕۆحی پیرۆز بە فیلیپۆسی فەرموو: «بڕۆ پێش و لەگەڵ ئەو گالیسکەیە بڕۆ.»
\p 
\v 30 ئیتر فیلیپۆس پەلەی کرد و گوێی لێبوو پەڕتووکی ئیشایا پێغەمبەر دەخوێنێتەوە. گوتی: «ئایا ئەوەی دەیخوێنیتەوە تێیدەگەیت؟»
\p 
\v 31 گوتی: «چۆن بتوانم ئەگەر یەکێک ڕێنماییم نەکات؟» جا فیلیپۆسی بانگکرد سەربکەوێت و لەگەڵی دابنیشێت.
\p 
\v 32 ئەو بڕگەیەی نووسراوە پیرۆزەکان کە دەیخوێندەوە ئەمە بوو:
\q1 ﴿ئەو وەک مەڕ بۆ سەربڕین بردرا،
\q2 وەک چۆن بەرخ لەبەردەستی ئەوەی خورییەکەی دەبڕێتەوە بێدەنگە،
\q2 ئەو دەمی نەکردەوە.
\q1 
\v 33 لە کاتی سووکایەتی پێکردنیدا لە دادپەروەری بێبەش کرا.
\q2 ئیتر کێ باسی نەوەکانی دەکات؟
\q2 چونکە ژیانی لەسەر زەوی هەڵگیرا.﴾\f + \fr 8:33 \ft \xt ئیشایا 53‏:7،‏\xt*\ft ‏ 8‏\f*
\p 
\v 34 خەساوەکە پرسیاری لە فیلیپۆس کرد: «پرسیارێکم هەیە: ئەم پێغەمبەرە باسی کێ دەکات؟ باسی خۆی یان یەکێکی دیکە؟»
\v 35 ئینجا فیلیپۆس لەم نووسراوە پیرۆزەوە دەستی کرد بە ڕوونکردنەوەی دەقەکە و مزگێنیی عیسای دایێ.
\p 
\v 36 کاتێک بە ڕێگاوە بوون، گەیشتنە سەر ئاوێک، خەساوەکە گوتی: «ئەوە ئاوە، چی ڕێم لێ دەگرێت لە ئاو هەڵبکێشرێم؟»
\v 37 [فیلیپۆس گوتی: «دەبێت، ئەگەر بە هەموو دڵتەوە باوەڕ بهێنیت.» ئەویش وەڵامی دایەوە: «باوەڕ دەکەم عیسای مەسیح کوڕی خودایە.»]
\v 38 ئینجا فەرمانی دا گالیسکەکە ڕاوەستێ، ئەوسا پێکەوە چوونە ناو ئاوەکە و فیلیپۆس خەساوەکەی لە ئاو هەڵکێشا.
\v 39 کاتێک لە ئاوەکە هاتنە دەرەوە، ڕۆحی یەزدان فیلیپۆسی ڕفاند و ئیتر خەساوەکە نەیبینییەوە، بەڵام بە خۆشییەوە بە ڕێگای خۆیدا ڕۆیشت.
\v 40 فیلیپۆسیش لە ئەشدۆد بینرایەوە، دواتر بە هەموو شارەکاندا دەگەڕا و مزگێنیی دەدا هەتا گەیشتە قەیسەرییە.
\c 9
\s1 مەسیح شاول دەگۆڕێت
\p 
\v 1 شاول هێشتا هەڕەشەی لە قوتابییەکانی عیسای خاوەن شکۆ دەکرد و هەوڵی کوشتنی دەدان. چوو بۆ لای سەرۆکی کاهینان،
\v 2 داوای نامەی لێکرد بۆ کەنیشتەکانی دیمەشق، تاکو ئەگەر یەکێک ببینێت و سەر بە ڕێگاکە\f + \fr 9:2 \ft ڕێگای پاشایەتی عیسا، بڕوانە \xt کردار 24‏:14‏\xt*\ft ‏.‏\f* بێت، چ ژن و چ پیاو، بە بەندکراوی بۆ ئۆرشەلیمیان ببات.
\v 3 کە دەڕۆیشت و لە دیمەشق نزیک بووەوە، لەپڕ ڕووناکییەک لە ئاسمانەوە لە دەوروبەری بریسکەی دایەوە،
\v 4 کەوتە سەر زەوی و گوێی لە دەنگێک بوو، پێی فەرموو: «شاول! شاول! بۆچی دەمچەوسێنیتەوە؟»
\p 
\v 5 شاول پرسیاری کرد: «گەورەم، تۆ کێیت؟»
\p فەرمووی: «من عیسام، ئەوەی تۆ دەیچەوسێنیتەوە. [بۆت زەحمەتە لوشکە لە نەقیزەی من باوێی.]
\v 6 بەڵام هەستە، بڕۆ ناو شار، لەوێ پێت دەگوترێ دەبێ چی بکەیت.»
\p 
\v 7 ئەو پیاوانەی لە گەشتەکەدا لەگەڵی بوون بە بێدەنگی وەستان، دەنگەکەیان بیست بەڵام کەسیان نەبینی.
\v 8 شاول لەسەر زەوییەکە هەستایەوە، بەڵام کاتێک چاوی کردەوە هیچی نەبینی، بۆیە دەستیان گرت و هێنایانە ناو دیمەشق.
\v 9 سێ ڕۆژ هیچی نەبینی، هەروەها هیچی نەخوارد و هیچی نەخواردەوە.
\p 
\v 10 لە دیمەشق قوتابییەک هەبوو ناوی حەنانیا بوو، مەسیحی خاوەن شکۆ لە بینیندا پێی فەرموو: «حەنانیا!»
\p گوتی: «ئەوەتام گەورەم!»
\p 
\v 11 مەسیح پێی فەرموو: «هەستە و بڕۆ ئەو شەقامەی پێی دەگوترێ ڕاست، لە ماڵی یەهوزا پرسیار لە پیاوێکی تەرسۆسی بکە ناوی شاولە، وا نوێژ دەکات.
\v 12 لە بینیندا پیاوێکی بۆ دەرکەوت بە ناوی حەنانیا کە دێتە لای و دەستی لە سەری دادەنێت تاکو بینایی بۆ بگەڕێتەوە.»
\p 
\v 13 حەنانیا وەڵامی دایەوە: «گەورەم، لە زۆر کەس ئەو خراپانەم بیستووەتەوە کە ئەم پیاوە لە ئۆرشەلیم بە گەلە پیرۆزەکەی تۆی کردووە.
\v 14 هەروەها لە کاهینانی باڵاوە دەسەڵاتی پێدراوە و هاتووە بۆ ئەوەی هەموو ئەوانە بگرێت کە بە ناوی تۆوە دەپاڕێنەوە.»
\p 
\v 15 بەڵام مەسیح پێی فەرموو: «بڕۆ! ئەم پیاوە بۆ من ئامێرێکی هەڵبژێردراوە بۆ هەڵگرتنی ناوی من لەبەردەم ناجولەکەکان و پاشایان و نەوەی ئیسرائیل.
\v 16 پیشانی دەدەم دەبێت لەبەر ناوی من چەند ئازار بچێژێت.»
\p 
\v 17 حەنانیاش ڕۆیشت و چووە ماڵەکە، دەستی لەسەری دانا و گوتی: «شاولی برام، عیسای خاوەن شکۆ منی ناردووە، ئەوەی لەو ڕێگایەی پێیدا هاتی بۆت دەرکەوت، تاکو دیسان ببینیت و پڕبیت لە ڕۆحی پیرۆز.»
\v 18 دەستبەجێ شتێکی وەک توێکڵ لە چاوەکانی کەوتە خوارەوە، ئینجا بینی، هەستا و لە ئاو هەڵکێشرا.
\v 19 نانی خوارد، هێزی هاتەوە بەر و چەند ڕۆژێکی لەگەڵ قوتابییەکان لە دیمەشق بەسەر برد.
\s1 مژدەدانی شاول لە دیمەشق
\p 
\v 20 شاول یەکسەر لە کەنیشتەکاندا دەستی کرد بە ڕاگەیاندنی ئەوەی کە عیسا کوڕی خودایە.
\v 21 هەموو ئەوانەی گوێیان دەگرت سەرسام ببوون و دەیانگوت: «ئەمە هەمان ئەو کەسە نییە ئەوانەی لەناودەبرد کە لە ئۆرشەلیم بەم ناوەوە دەپاڕانەوە؟ بۆ ئەمەش نەهاتە ئێرە، تاکو بە بەندکراوی بۆ کاهینانی باڵا بیانبات؟»
\v 22 بەڵام شاول توانادارتر دەبوو، جولەکەی دانیشتووی دیمەشقی دەمکوت دەکرد و دەریدەخست کە عیسا مەسیحەکەیە.
\p 
\v 23 پاش ماوەیەکی زۆر، جولەکە پیلانیان دانا بیکوژن،
\v 24 بەڵام شاول بە پیلانەکەیانی زانی. ئەوان شەو و ڕۆژ چاودێری دەروازەکانیان دەکرد تاکو بیکوژن.
\v 25 بۆیە قوتابییەکان بە شەو بردیان و لەناو سەبەتەیەکدا لە شوورای شارەکەوە شۆڕیان کردەوە.
\s1 شاول لە ئۆرشەلیم
\p 
\v 26 کاتێک شاول گەیشتە ئۆرشەلیم، هەوڵی دا بچێتە پاڵ قوتابییەکان، بەڵام هەموو لێی ترسان و باوەڕیان نەدەکرد کە بووبێتە قوتابی.
\v 27 بەڵام بەرناباس بردی و هێنایە لای نێردراوان، بۆی گێڕانەوە چۆن لە ڕێگادا عیسای خاوەن شکۆی بینیوە و قسەی لەگەڵ کردووە، هەروەها چۆن لە دیمەشق ئازایانە بە ناوی عیساوە مزگێنیی ڕاگەیاندووە.
\v 28 ئیتر لەگەڵیان لە ئۆرشەلیم دەهات و دەچوو، بە چاونەترسییەوە بە ناوی عیسای خاوەن شکۆوە مزگێنیی ڕادەگەیاند.
\v 29 هەروەها قسە و مشتومڕی لەگەڵ جولەکە یۆنانییەکان دەکرد، ئەوانیش هەوڵیان دا بیکوژن.
\v 30 کاتێک باوەڕداران بەمەیان زانی بردیانە قەیسەرییە و بۆ تەرسۆسیان نارد.
\p 
\v 31 کڵێساش لە هەموو یەهودیا و جەلیل و سامیرەدا لە ئارامیدا بوو، بنیاد دەنرا و لە سایەی ترسی مەسیحی خاوەن شکۆ و دڵنەوایی ڕۆحی پیرۆزدا لە زیادبووندا بوو.
\s1 پەترۆس لە شاری لودە و یافا
\p 
\v 32 کاتێک کە پەترۆس بە هەموو ناوچەکاندا تێدەپەڕی، بۆ لای گەلی پیرۆزی خودا لە شاری لودە دابەزی.
\v 33 لەوێ پیاوێکی ئیفلیجی بینی کە ناوی ئینیاس بوو، هەشت ساڵ بوو لەناو جێگادا کەوتبوو.
\v 34 پەترۆس پێی گوت: «ئینیاس، عیسای مەسیح چاکت دەکاتەوە. هەستە و جێگاکەت کۆبکەوە!» دەستبەجێ هەستا.
\v 35 هەموو دانیشتووانی لودە و شارون بینییان، ئیتر بەرەو لای مەسیحی خاوەن شکۆ گەڕانەوە.
\p 
\v 36 قوتابییەک لە یافا هەبوو ناوی تابیسا بوو، واتا ئاسک\f + \fr 9:36 \ft یۆنانی: \tl دۆرکەس‏\tl*: ئاسک‏\f*، کە هەمیشە خەریکی کاری چاکە و یارمەتیدانی هەژاران بوو.
\v 37 ئەوە بوو لەو ڕۆژانەدا نەخۆش کەوت و مرد، جا شوشتیان و لە ژوورێکی سەرەوە دایاننا.
\v 38 لودە لە یافاوە نزیک بوو، ئیتر کە قوتابییەکان بیستیان پەترۆس لەوێیە، دوو پیاویان نارد بۆ لای و تکایان لێکرد و گوتیان: «لە هاتن بۆ لامان دوامەکەوە.»
\p 
\v 39 پەترۆس هەستا و لەگەڵیان ڕۆیشت، کاتێک گەیشت، بردیانە ژووری سەرەوە، هەموو بێوەژنەکان لەلای ڕاوەستان، دەگریان و ئەو کراس و جلانەیان پیشانی دەدا کە ئاسکە کردبووی لەو کاتەی لەگەڵیان بوو.
\p 
\v 40 پەترۆس هەموویانی ناردە دەرەوە، کەوتە سەر چۆک و نوێژی کرد، ئینجا ڕووی کردە تەرمەکە و گوتی: «تابیسا، هەستە!» ئەویش چاوی کردەوە و کاتێک پەترۆسی بینی دانیشت.
\v 41 ئیتر دەستی بۆ ڕاکێشا و هەڵیستاندەوە، ئینجا باوەڕداران و بێوەژنانی بانگکرد و بە زیندوویی ڕادەستی کردنەوە.
\v 42 ئەم هەواڵە بە هەموو یافادا بڵاو بووەوە و زۆر کەس باوەڕیان بە مەسیح هێنا.
\v 43 پەترۆس چەندین ڕۆژ لە یافا لەلای پێستەخۆشکەرێک مایەوە کە ناوی شیمۆن بوو.
\c 10
\s1 پەترۆس و کۆرنیلیۆس
\p 
\v 1 لە شاری قەیسەرییە پیاوێک بە ناوی کۆرنیلیۆس هەبوو، سەرپەل\f + \fr 10:1 \ft وشە یۆنانییەکە مەبەست لە سەرکردەی سەد سەربازە لە سوپای ڕۆم.‏\f* بوو لەو لیوایەی پێی دەگوترا ئیتالی.
\v 2 خۆی و هەموو ماڵەکەی خواپەرست و لەخواترس بوون، زۆر هاوکاری خەڵکی هەژاری دەکرد و هەموو کاتێک نوێژی بۆ خودا دەکرد.
\v 3 نزیکەی کاتژمێر سێی\f + \fr 10:3 \ft یۆنانی: کاتژمێری نۆیەم.‏\f* دوای نیوەڕۆ، بە ڕوونی فریشتەیەکی خودا لە بینینێکدا هاتە لای و پێی گوت: «کۆرنیلیۆس!»
\p 
\v 4 بە ترسەوە سەیری کرد و گوتی: «بەڵێ گەورەم؟»
\p پێی گوت: «نوێژەکانت و چاکەکانت وەک یادەوەری بەرز بوونەتەوە بەردەم خودا.
\v 5 ئێستا چەند پیاوێک بۆ یافا بنێرە و ئەو شیمۆنەی پێی دەگوترێ پەترۆس بیهێنن.
\v 6 لە ماڵی شیمۆنی پێستەخۆشکەرە، ماڵەکەی لەسەر دەریایە.»
\p 
\v 7 کاتێک ئەو فریشتەیەی کە قسەی لەگەڵی کرد ڕۆیشت، دووان لە خزمەتکارەکانی و سەربازێکی خواپەرستی بانگکرد کە یەکێک بوو لە دارودەستە تایبەتەکەی،
\v 8 هەموو شتێکی بۆ گێڕانەوە و ناردیانی بۆ یافا.
\s1 بینینی پەترۆس
\p 
\v 9 بۆ بەیانی، کاتێک بە ڕێگاوە بوون و لە شارەکە نزیک دەبوونەوە، نزیکەی کاتژمێر دوازدە\f + \fr 10:9 \ft یۆنانی: کاتژمێری شەشەم.‏\f*، پەترۆس بۆ نوێژکردن چووە سەربان.
\v 10 ئیتر برسی بوو و دەیویست نان بخوات، بەڵام لە کاتی ئامادەکردنی خواردندا، لەهۆش خۆی چوو.
\v 11 ئاسمانی بە کراوەیی بینی، شتێک لە شێوەی چەرچەفێکی گەورە دەهاتە خوارەوە بۆ سەر زەوی کە لە هەر چوار لاوە گرێدرا بوو.
\v 12 هەموو جۆرە ئاژەڵی چوارپێ و خشۆکی سەر زەوی و باڵندەی ئاسمانی تێدابوو.
\v 13 ئینجا دەنگێک بانگی کرد: «پەترۆس هەستە، سەربڕە و بخۆ!»
\p 
\v 14 پەترۆس گوتی: «نەخێر، ئەی پەروەردگار، چونکە هەرگیز شتی گڵاو یان حەرامم نەخواردووە.»
\p 
\v 15 دیسان دەنگەکە لەگەڵی دوا: «ئەوەی خودا پاکی کردووەتەوە تۆ بە گڵاوی دامەنێ.»
\p 
\v 16 ئەمەش سێبارە بووەوە و دەستبەجێ چەرچەفەکە بۆ ئاسمان بەرزکرایەوە.
\p 
\v 17 کە پەترۆس سەرسام بوو لەوەی کە ئاخۆ دەبێت ئەو بینینە چی بێت، ئەو پیاوانەی کە کۆرنیلیۆس ناردبوونی، بە پرسیار ماڵی شیمۆنیان دۆزییەوە و لە بەردەرگا وەستان.
\v 18 بانگیان کرد و پرسییان، ئاخۆ ئەو شیمۆنەی نازناوی پەترۆسە لێرەیە.
\p 
\v 19 لە کاتێکدا پەترۆس هەر بیری لە بینینەکە دەکردەوە، ڕۆحی پیرۆز پێی فەرموو: «سێ پیاو لە بەردەرگا لێت دەپرسن.
\v 20 هەستە بڕۆ خوارەوە و بێ دوودڵی لەگەڵیان بڕۆ، چونکە من ئەوانم ناردووە.»
\p 
\v 21 پەترۆسیش بۆ لای پیاوەکان هاتە خوارەوە و گوتی: «ئەوەی دەتانەوێ منم. بۆچی هاتوون؟»
\p 
\v 22 گوتیان: «کۆرنیلیۆسی سەرپەل، پیاوێکی ڕاستودروست و لەخواترسە، هەموو گەلی جولەکەش شایەتی بۆ دەدەن. بەهۆی فریشتەیەکی پیرۆز ڕێنمایی کرا کە بۆ ماڵەکەی خۆی بانگت بکات و گوێ لە قسەکانت بگرێت.»
\v 23 جا پەترۆس بۆ ژوورەوە بانگهێشتی کردن و میوانداری کردن.
\s1 پەترۆس لە ماڵی کۆرنیلیۆس
\p بۆ بەیانی پەترۆس هەستا و لەگەڵیان ڕۆیشت، هەروەها هەندێک لە باوەڕدارانی خەڵکی یافاش یاوەری بوون.
\v 24 بۆ ڕۆژی دووەم چوو بۆ قەیسەرییە. کۆرنیلیۆس چاوەڕێی دەکردن، خزم و دۆستانی نزیکی خۆی کۆکردبووەوە.
\v 25 کاتێک پەترۆس هاتە ژوورەوە، کۆرنیلیۆس پێشوازی لێکرد و لەبەرپێی کەوت و کڕنۆشی برد.
\v 26 پەترۆس هەڵیستاندەوە و گوتی: «هەستە! منیش مرۆڤم!»
\p 
\v 27 کاتێک پەترۆس قسەی لەگەڵ دەکرد چووە ژوورەوە و خەڵکێکی زۆری بینی کۆبوونەتەوە،
\v 28 پێی گوتن: «دەزانن بۆ جولەکە ڕێپێنەدراوە تێکەڵاوی ناجولەکە بێت یان بچێتە لای. بەڵام خودا پیشانی دام بە کەس نەڵێم گڵاو یان پیس\f + \fr 10:28 \ft بڕوانە \xt 10‏:14‏\xt*\ft .‏\f*.
\v 29 بۆیە کە بانگکرام بێ ناڕەزایی دەربڕین هاتم. دەکرێت بپرسم بۆچی منتان بانگکردووە؟»
\p 
\v 30 کۆرنیلیۆس گوتی: «چوار ڕۆژ لەمەوبەر، لەم کاتەدا کە کاتژمێر سێی\f + \fr 10:30 \ft یۆنانی: کاتژمێری نۆیەم.‏\f* پاش نیوەڕۆ بوو، لە ماڵی خۆم نوێژم دەکرد. لەپڕ پیاوێک بە جلی بریسکەدارەوە لەبەردەمم ڕاوەستا،
\v 31 گوتی: ”کۆرنیلیۆس نوێژەکانت بیستران و خێرەکانت لەبەردەم خودا یادکرانەوە.
\v 32 بۆیە بۆ یافا بەدوای شیمۆندا بنێرە کە نازناوی پەترۆسە. لە ماڵی شیمۆنی پێستەخۆشکەرە، لەسەر دەریا.“
\v 33 منیش دەستبەجێ بەدوای تۆدا ناردم، تۆش چاکت کرد کە هاتی. ئێستا هەموو لەبەردەم خودا ئامادەین، تاکو گوێ بگرین لە هەموو ئەوەی پەروەردگار فەرمانی پێکردووی.»
\s1 وتاری پەترۆس
\p 
\v 34 پەترۆس دەمی کردەوە و گوتی: «لەڕاستیدا تێگەیشتم خودا لایەنگری کەس ناکات،
\v 35 بەڵکو لە هەر نەتەوەیەک ئەوەی ترسی ئەوی لە دڵدا بێت و کاری ڕاستودروست بکات، لەلای پەسەندە.
\v 36 ئەو پەیامە دەزانن کە خودا بۆ گەلی ئیسرائیلی نارد، مزگێنیی ئاشتی لە ڕێگەی عیسای مەسیحەوە ڕادەگەیەنێت، کە پەروەردگاری هەمووانە.
\v 37 ئەو شتانە دەزانن کە لە هەموو یەهودیا ڕوویدا، بە دەستپێکردن لە جەلیلەوە دوای ئەوەی یەحیا لەئاوهەڵکێشانەکەی ڕاگەیاند،
\v 38 چۆن خودا بە ڕۆحی پیرۆز و هێز عیسای ناسیرەیی دەستنیشان کرد\f + \fr 10:38 \ft لە پەیمانی کۆن داود لەلایەن ساموئێلەوە چەورکرا کە هەڵبژاردەی خودایە، ئەم چەورکردنەش وەکو نەریتێک بەردەوام بوو بۆ ڕزگاریی خودا.‏\f*، ئەوەی دەگەڕا و چاکەی دەکرد و هەموو ئەوانەی ئیبلیس دەستی بەسەریاندا گرتبوو چاکی دەکردنەوە، چونکە خودا لەگەڵی بوو.
\p 
\v 39 «ئێمە شایەتی هەموو ئەو شتانەین کە لە ناوچەی یەهودیا و ئۆرشەلیم کردی. ئەوەی بە هەڵواسینی بە دارەوە کوشتیان،
\v 40 بەڵام خودا لە ڕۆژی سێیەمدا لەنێو مردوواندا هەڵیستاندەوە وای کرد دەربکەوێت،
\v 41 نەک بۆ هەموو گەل، بەڵکو بۆ ئەو شایەتانەی کە خودا پێشتر هەڵیبژاردن، بۆ ئێمە کە پاش هەستانەوەی لەنێو مردووان، لەگەڵیدا خواردمان و خواردمانەوە.
\v 42 ئینجا فەرمانی پێداین جاڕبدەین بۆ گەل و شایەتی بدەین کە خودا ئەوی بە دادوەری زیندووان و مردووان داناوە.
\v 43 هەموو پێغەمبەران شایەتیی بۆ دەدەن کە هەرکەسێک باوەڕی پێ بهێنێت، بە ناوی ئەو گوناهەکانی دەبەخشرێت.»
\s1 وەرگرتنی ڕۆحی پیرۆز
\p 
\v 44 کاتێک پەترۆس باسی ئەم شتانەی دەکرد، ڕۆحی پیرۆز ڕژایە سەر هەموو ئەوانەی گوێیان لە پەیامەکە گرتبوو.
\v 45 ئەو باوەڕدارە خەتەنەکراوانەی کە لەگەڵ پەترۆس بوون سەریان سوڕما کە ڕۆحی پیرۆز وەک دیارییەک بەسەر ناجولەکەکانیشدا ڕژا،
\v 46 چونکە گوێیان لێیان بوو بە زمانە ڕۆحییەکان دەدوێن و ستایشی خودا دەکەن.
\p ئینجا پەترۆس گوتی:
\v 47 «کەس هەیە ڕێگا بگرێت لە لەئاوهەڵکێشانی ئەمانە کە وەک ئێمە ڕۆحی پیرۆزیان وەرگرتووە؟»
\v 48 بۆیە فەرمانی پێدان بە ناوی عیسای مەسیح لە ئاو هەڵبکێشرێن. ئینجا داوایان لە پەترۆس کرد چەند ڕۆژێک لەلایان بمێنێتەوە.
\c 11
\s1 ڕوونکردنەوەی پەترۆس
\p 
\v 1 نێردراوان و باوەڕداران کە لە یەهودیا بوون بیستیان کە ناجولەکەکانیش پەیامی خودایان وەرگرتووە.
\v 2 کاتێک پەترۆس گەڕایەوە ئۆرشەلیم باوەڕدارانی خەتەنەکراو ڕەخنەیان لێ گرت و
\v 3 دەیانگوت: «تۆ چوویتە ماڵی خەڵکێکی خەتەنەنەکراو و نانت لەگەڵیان خواردووە!»
\p 
\v 4 جا پەترۆس یەک لەدوای یەک دەستی کرد بە ڕوونکردنەوەی ئەوانەی کە ڕوویدابوو و گوتی:
\v 5 «لە شاری یافا بووم نوێژم دەکرد، لەهۆش خۆم چووم و بینینێکم بۆ ئاشکرا کرا، شتێک لە ئاسمانەوە وەک چەرچەفێکی گەورە بە هەر چوار لایەوە بۆ لای من شۆڕکرایەوە.
\v 6 سەیرم کرد و لێی وردبوومەوە، چوارپێی زەوی و ئاژەڵی کێوی، خشۆک و باڵندەی ئاسمانم بینی.
\v 7 ئینجا گوێم لە دەنگێک بوو پێی فەرمووم: ”پەترۆس هەستە، سەربڕە و بخۆ!“
\p 
\v 8 «بەڵام گوتم: ”نەخێر، ئەی پەروەردگار، چونکە هەرگیز گڵاو یان حەرام نەچووەتە دەمم.“
\p 
\v 9 «دەنگەکە دووبارە لە ئاسمانەوە فەرمووی: ”ئەوەی خودا پاکی کردووەتەوە تۆ بە گڵاوی دامەنێ.“
\v 10 ئەمە سێبارە بووەوە و هەموو شتەکان بۆ ئاسمان ڕاکێشرانەوە.
\p 
\v 11 «ئەوە بوو یەکسەر سێ پیاو لەپێش ئەو ماڵە ڕاوەستان کە ئێمەی لێبوو، لە قەیسەرییەوە بۆ لام نێردرابوون،
\v 12 ڕۆحی پیرۆز پێی فەرمووم کە بێ دوودڵی لەگەڵیان بڕۆم، ئەم شەش برایەش لەگەڵم هاتن و چووینە ماڵی پیاوەکە.
\v 13 ئەویش بۆی گێڕاینەوە چۆن فریشتەی لە ماڵەکەیدا بینیوە ڕاوەستاوە و گوتوویەتی: ”بنێرە بۆ یافا بەدوای شیمۆندا کە نازناوی پەترۆسە،
\v 14 ئەو پەیامێکتان دەداتێ بەهۆیەوە خۆت و هەموو ماڵەکەت ڕزگارتان دەبێت.“
\p 
\v 15 «کاتێک دەستم بە قسە کرد، ڕۆحی پیرۆزیان بەسەردا ڕژا، وەک لە سەرەتادا هاتە سەر ئێمەش.
\v 16 قسەکەی عیسای خاوەن شکۆم بەبیر هاتەوە کە فەرمووی: ”یەحیا خەڵکی لە ئاو هەڵدەکێشا، بەڵام ئێوە لە ڕۆحی پیرۆز هەڵدەکێشرێن.“
\v 17 جا ئەگەر خودا هەمان دیاریی بەوان دابێت هەروەک بە ئێمەی داوە کە باوەڕمان بە عیسای مەسیحی خاوەن شکۆ هێنا، ئیتر من کێم بتوانم ڕێگا لە خودا بگرم؟»
\p 
\v 18 کاتێک گوێیان لەمە بوو، بێدەنگ بوون و ستایشی خودایان کرد و گوتیان: «کەواتە خودا تۆبەکردنی تەنانەت بە ناجولەکەکانیش بەخشیوە بۆ ئەوەی ژیانی هەتاهەتاییان هەبێت.»
\s1 کڵێسای ئەنتاکیا
\p 
\v 19 ئینجا ئەو کەسانەی بەهۆی ئەو چەوسانەوەیەی بەسەر ستیفانۆسدا هات پەرشوبڵاو ببوونەوە، پەڕینەوە بۆ فینیکیا و قوبرس و ئەنتاکیا، باسی پەیامی خودایان بۆ کەس نەدەکرد، بۆ جولەکە نەبێت.
\v 20 بەڵام هەندێکیان خەڵکی قوبرس و کورێن\f + \fr 11:20 \ft گەورەترین شار لە وڵاتی لیبیا لەو سەردەمە.‏\f* بوون، کاتێک هاتنە ئەنتاکیا، قسەیان بۆ یۆنانییەکان دەکرد و مزگێنیی عیسای خاوەن شکۆیان دەدا.
\v 21 یەزدان پشتگیری کردن، ژمارەیەکی زۆر باوەڕیان هێنا و بۆ عیسای خاوەن شکۆ گەڕانەوە.
\p 
\v 22 ئەم هەواڵە گەیشتە کڵێسای ئۆرشەلیم، ئەوانیش بەرناباسیان بۆ ئەنتاکیا نارد.
\v 23 کاتێک گەیشت و نیعمەتی خودای بینی، دڵشاد بوو، هەمووانی هاندا بە هەموو دڵیانەوە لەگەڵ مەسیحی خاوەن شکۆ بمێننەوە،
\v 24 چونکە پیاوچاک بوو، پڕبوو لە ڕۆحی پیرۆز و باوەڕ. خەڵکێکی زۆریش هاتنە پاڵ مەسیحی خاوەن شکۆ.
\p 
\v 25 ئەوسا چوو بۆ تەرسۆس تاکو بەدوای شاولدا بگەڕێت،
\v 26 کاتێک دۆزییەوە بۆ ئەنتاکیای هێنا. ئیتر ساڵێکی تەواو لە کڵێسا کۆبوونەوە و خەڵکێکی زۆریان فێرکرد. یەکەم جاریش لە ئەنتاکیا قوتابییەکان ناویان لێنرا مەسیحی\f + \fr 11:26 \ft یۆنانی: \tl کریستیانۆی‏\tl*.‏\f*.
\p 
\v 27 لەو ڕۆژانەدا هەندێک پێغەمبەر لە ئۆرشەلیمەوە هاتنە ئەنتاکیا،
\v 28 یەکێک لەوان ناوی ئاگابۆس بوو، هەستا و لە ڕێگەی ڕۆحی پیرۆزەوە پێشبینیی کرد کە قاتوقڕییەکی گەورە هەموو جیهان دەگرێتەوە، ئەوەی لە سەردەمی کلودیۆسیش ڕوویدا.
\v 29 بۆیە قوتابییەکان بڕیاریان دا هەریەکە بەگوێرەی توانای خۆی یارمەتی بنێرێت بۆ ئەو خوشک و برایانەی لە یەهودیا دەژین.
\v 30 ئینجا ئەمەیان کرد و لە ڕێگەی بەرناباس و شاولەوە یارمەتییەکەیان بۆ پیرانی یەهودیا نارد.
\c 12
\s1 دەربازکردنی پەترۆس
\p 
\v 1 لەو کاتەدا هێرۆدسی پاشا\f + \fr 12:1 \ft مەبەستی لە هێرۆدس ئەگریپاسە کە لە 41 بۆ 44 ز. فەرمانڕەوای فەلەستین بوو.‏\f* دەستی کرد بە چەوساندنەوەی چەند کەسێکی کڵێسا.
\v 2 هەروەها یاقوبی برای یۆحەنای بە شمشێر کوشت.
\v 3 کە بینی ئەمە جێی ڕەزامەندی جولەکەیە، پەترۆسیشی گرت، ئەمەش لە ڕۆژانی جەژنی فەتیرەدا بوو.
\v 4 کاتێک هێرۆدس پەترۆسی گرت، خستییە زیندانەوە، بۆ ئەوەی پاسەوانی لێ بکرێت دایە دەست چوار کۆمەڵی چوار سەربازی، دەیویست دوای جەژنی پەسخە بیهێنێتە بەردەم گەل.
\p 
\v 5 بۆیە کاتێک پەترۆس زیندانی کرابوو، کڵێسا بە گوڕ لە پێناوی ئەو نوێژیان بۆ خودا دەکرد.
\p 
\v 6 شەوی پێش ئەو ڕۆژەی کە هێرۆدس بەتەمابوو پەترۆس بهێنێتە دەرەوە و دادگایی بکات، پەترۆس لەنێوان دوو سەربازدا نوستبوو، بە دوو زنجیر بەسترابووەوە، لە بەردەرگاش پاسەوان هەبوو، کە پاسەوانی زیندانەکەیان دەکرد.
\v 7 لەپڕ فریشتەیەکی یەزدان دەرکەوت و ڕووناکییەک لەناو ژوورەکە درەوشایەوە، جا کەلەکەی پەترۆسی جوڵاند و خەبەری کردەوە و گوتی: «خێرا هەستە!» ئیتر زنجیرەکان لە دەستەکانی کەوتن.
\p 
\v 8 فریشتەکە پێی گوت: «پشتێنەکەت ببەستە و پێڵاوەکانت لە پێ بکە!» ئەویش کردی. ئینجا پێی گوت: «سەرکراسەکەت لەبەر بکە و دوام بکەوە.»
\v 9 پەترۆسیش دوای کەوت و لە بەندیخانە چووە دەرەوە، نەیدەزانی ئەوەی لە ڕێگەی فریشتەکەوە ڕوودەدات ڕاستە، بەڵکو وایدەزانی بینینێکی بۆ ئاشکرا کراوە.
\v 10 پاسەوانی یەکەم و دووەمیان بڕی و گەیشتنە دەروازە ئاسنینەکەی بەرەو شار، لە خۆیەوە بۆیان کرایەوە، تێپەڕین و شەقامێکیان بڕی، لەناکاو فریشتەکە بەجێی هێشت.
\p 
\v 11 ئینجا پەترۆس بەخۆیدا هاتەوە و گوتی: «ئێستا بەڕاستی زانیم کە یەزدان فریشتەکەی نارد و لە دەستی هێرۆدس و هەموو ئەوەی گەلی جولەکە چاوەڕێی بوو دەربازی کردم.»
\p 
\v 12 هەرکە بە تەواوی زانی چی ڕوویداوە، ڕۆیشت بۆ ماڵی مریەمی دایکی یۆحەنا کە پێی دەگوترا مەرقۆس، لەوێ خەڵکێکی زۆر کۆببوونەوە و نوێژیان دەکرد.
\v 13 کە پەترۆس لە دەرگای داڵانەکەی دا، کارەکەرێک کە ناوی ڕودا بوو، هات بۆ ئەوەی بزانێت کێیە.
\v 14 کاتێک دەنگی پەترۆسی ناسییەوە، بێ کردنەوەی دەرگاکە لە خۆشییاندا ڕایکردە ژوورەوە و خەبەری دا کە پەترۆس لە بەردەرگا ڕاوەستاوە.
\p 
\v 15 پێیان گوت: «وڕێنە دەکەیت.» بەڵام ئەو لەسەر قسەکەی سووربوو، گوتیان: «ئەوە فریشتەکەیەتی!»
\p 
\v 16 بەڵام پەترۆس لە لێدانەکە بەردەوام بوو، کاتێک لێیان کردەوە و بینییان، سەرسام بوون.
\v 17 بە دەست ئیشارەتی بۆ کردن بێدەنگ بن، ئینجا بۆی گێڕانەوە چۆن یەزدان لە زیندان دەریهێنا، پێی گوتن: «ئەمە بە یاقوب\f + \fr 12:17 \ft برای مەسیح. بڕوانە \xt گەلاتیا 1‏:19.‏\xt*\ft ‏\f* و خوشک و برایان بڵێن.» ئینجا چووە دەرەوە و بۆ شوێنێکی دیکە ڕۆیشت.
\p 
\v 18 کە ڕۆژبووەوە ئاژاوەیەکی گەورە لەنێو سەربازەکاندا دروستبوو لەسەر ئەوەی ئاخۆ پەترۆس چی لێهات.
\v 19 کاتێک هێرۆدس داوای کرد و نەیدۆزییەوە، لێکۆڵینەوەی لەگەڵ سەربازان کرد و فەرمانی دا بکوژرێن.
\s1 مردنی هێرۆدسی ئەگریپاس
\p ئینجا هێرۆدس لە یەهودیاوە چوو بۆ قەیسەرییە و لەوێ مایەوە.
\v 20 هێرۆدس لە خەڵکی سور و سەیدا زۆر تووڕە بوو، ئەوانیش بە یەک دڵ بۆ لای هاتن و بلاستۆسی سەرپەرشتیاری ماڵی پاشایان ڕازی کرد و داوای ئاشتبوونەوەیان کرد، چونکە ناوچەکەیان لە ناوچەی پاشاوە ئازووقەی بۆ دەهات.
\p 
\v 21 لە ڕۆژی دیاریکراودا هێرۆدس جلی پاشایەتیی لەبەرکرد، لەسەر کورسی حوکمدان دانیشت و وتاری بۆیان دا.
\v 22 خەڵکەکەش هاواریان کرد: «ئەمە دەنگی خوداوەندێکە هی مرۆڤ نییە!»
\v 23 دەستبەجێ فریشتەیەکی یەزدان لێیدا، چونکە شکۆی نەدایە خودا، کرمیش لێیدا و مرد.
\p 
\v 24 بەڵام پەیامی خودا بەردەوام لە پەرەسەندن و گەشەکردندا بوو.
\p 
\v 25 بەرناباس و شاولیش دوای تەواوکردنی خزمەتەکە لە ئۆرشەلیم گەڕانەوە، یۆحەناشیان لەگەڵ خۆیان برد، کە بە مەرقۆس ناسراوبوو.
\c 13
\s1 هەڵبژاردنی بەرناباس و شاول
\p 
\v 1 لە کڵێسای ئەنتاکیادا چەند پێغەمبەر و مامۆستایەک هەبوون: بەرناباس، شیمۆنی ناسراو بە ڕەش، لوکیوسی کورێنی، مەناینی شیربرای هێرۆدسی ئەنتیپاس پاشا، لەگەڵ شاول.
\v 2 کاتێک عیسای خاوەن شکۆیان دەپەرست و بەڕۆژوو بوون، ڕۆحی پیرۆز فەرمووی: «بەرناباس و شاولم بۆ تەرخان بکەن، بۆ ئەو کارەی بانگم کردوون بۆی.»
\v 3 ئینجا بەڕۆژوو بوون و نوێژیان کرد، دەستیان لەسەر دانان و بەڕێیانکردن.
\s1 شاول و بەرناباس لە قوبرس
\p 
\v 4 ئەوانیش کە بە ڕۆحی پیرۆز نێردران، بەرەو سولوکیا دابەزین و لەوێشەوە بە دەریادا بۆ قوبرس.
\v 5 کاتێک گەیشتنە سەلامیس، پەیامی خودایان لە کەنیشتەکانی جولەکە ڕاگەیاند، یۆحەناش وەک یاریدەدەر لەگەڵیان بوو.
\p 
\v 6 بە هەموو دوورگەکەدا گەڕان هەتا گەیشتنە پافۆس. لەوێ تووشی جادووگەرێکی جولەکە بوون بە ناوی باریەشوع کە پێغەمبەرێکی درۆزن بوو.
\v 7 باریەشوع لەگەڵ سرگیۆس پۆڵسی فەرمانڕەوا\f + \fr 13:7 \ft فەرمانڕەوای قوبرس.‏\f* بوو، کە پیاوێکی تێگەیشتوو بوو. سرگیۆس بەرناباس و شاولی بانگکرد، چونکە دەیویست گوێی لە پەیامی خودا بێت.
\v 8 بەڵام ئەلیماس کە جادووگەر واتای ناوەکەی بوو، بەربەرەکانێی کردن و هەوڵی دا فەرمانڕەوا لە باوەڕ لابدات.
\v 9 کەچی شاول کە پۆڵسی پێ دەگوترا، پڕبوو لە ڕۆحی پیرۆز و تێیڕوانی و
\v 10 گوتی: «ئەی پڕ لە هەموو جۆرە فرتوفێڵێک! کوڕی شەیتان! دوژمنی هەموو ڕاستودروستییەک! لە خوارکردنی ڕێگای ڕاستی یەزدان ناوەستی؟
\v 11 ئەوەتا دەستی یەزدان لە دژی تۆیە و کوێر دەبیت، بۆ ماوەیەک خۆر نابینی.»
\p دەستبەجێ تەم و تاریکی دایپۆشی و بەدوای یەکێکدا گەڕا تاکو دەستی بگرێت.
\v 12 کاتێک فەرمانڕەواکە بینی چ ڕوویدا، باوەڕی هێنا، لە فێرکردنەکەی مەسیحی خاوەن شکۆ سەرسام بوو.
\s1 لە ئەنتاکیای پیسیدیا
\p 
\v 13 پۆڵس و هاوڕێیانی بە دەریادا لە پافۆسەوە چوونە پەرگە لە پامفیلیا\f + \fr 13:13 \ft شوێنێکە لە باشووری تورکیای ئێستا.‏\f*. بەڵام یۆحەنا لێیان جیا بووەوە و گەڕایەوە ئۆرشەلیم.
\v 14 ئەوانیش بە پەرگەدا هاتنە ئەنتاکیای پیسیدیا، شەممەش چوونە کەنیشت و دانیشتن.
\v 15 پاش خوێندنەوەی تەورات و پەڕتووکی پێغەمبەران، پێشەوایانی کەنیشتەکە پەیامیان نارد و پێیان گوتن: «برایان، ئەگەر شتێکتان هەیە گەلی پێ هانبدەن، بیڵێن.»
\p 
\v 16 پۆڵس هەستا و بە دەست ئاماژەی کرد و گوتی: «پیاوانی ئیسرائیل و ئەو ناجولەکانەی کە لە خودا دەترسن، گوێ بگرن:
\v 17 خودای ئەم گەلەی ئیسرائیل باوباپیرانی ئێمەی هەڵبژارد و لە کاتی ئاوارەبوونیان لە خاکی میسردا کردنی بە گەلێکی مەزن، ئینجا بە بازووێکی بەهێز لەوێ دەریهێنان.
\v 18 نزیکەی چل ساڵیش لە چۆڵەوانی بەرگەی ڕەفتاری ئەوانی گرت،
\v 19 ئینجا حەوت نەتەوەی لە خاکی کەنعان لەناوبرد و خاکەکەیانی بە میرات پێدان.
\v 20 ئەمە هەمووی نزیکەی چوار سەد و پەنجا ساڵی خایاند.
\p «لەدوای ئەمە خودا دادوەری بۆ دانان هەتا سەردەمی ساموئێل پێغەمبەر.
\v 21 ئینجا نەوەی ئیسرائیل داوای پاشایان کرد، خوداش لە تیرەی بنیامین، شاولی کوڕی قیشی پێدان، کە بۆ ماوەی چل ساڵ پاشایەتی کردن.
\v 22 پاشان لایبرد و داودی کردە پاشایان، ئەوەی شایەتی بۆ دا و فەرمووی: ﴿داودی کوڕی یەسام دۆزییەوە، پیاوێکە بە دڵی خۆم، ئەوەی هەموو خواستی من جێبەجێ دەکات.﴾\f + \fr 13:22 \ft \xt یەکەم ساموئێل 13‏:14 و زەبوورەکان 89‏:20.‏\xt*\ft ‏\f*
\p 
\v 23 «خودا بەگوێرەی بەڵێنەکەی، عیسای ڕزگارکەری لە نەوەی ئەوەوە بۆ ئیسرائیل هێنا.
\v 24 پێش هاتنی عیسا، یەحیا لەئاوهەڵکێشانی تۆبەی بۆ هەموو گەلی ئیسرائیل ڕاگەیاند.
\v 25 کاتێک یەحیا خەریک بوو ئەرکەکەی تەواو دەکرد، گوتی: ”وا دەزانن من کێم؟ ئەو نیم. ئەوەتا ئەوەی لەدوای من دێت، ئەوەی من شایانی ئەوە نیم کە قەیتانی پێڵاوەکانی بکەمەوە.“
\p 
\v 26 «خەڵکینە، برایان، کوڕانی پشتی ئیبراهیم و ئەو ناجولەکانەی لەنێوتاندا لە خودا دەترسن، پەیامی ئەم ڕزگارییە بۆ ئێمە نێردراوە.
\v 27 دانیشتووانی ئۆرشەلیم و ڕابەرەکانیان مەسیحیان نەناسی، کەچی کاتێک تاوانباریان کرد وتەی پێغەمبەرانیان هێنایە دی کە هەموو شەممەیەک دەخوێنرێتەوە.
\v 28 جا لەگەڵ ئەوەی هیچ هۆیەکیان بۆ مردن نەدۆزییەوە، داوایان لە پیلاتۆس کرد بیکوژێت.
\v 29 دوای ئەوەی هەموو ئەو شتانەیان تەواو کرد کە لەسەری نووسراوە، لە دار هێنایانە خوارەوە و خستیانە گۆڕ.
\v 30 بەڵام خودا لەنێو مردووان هەڵیستاندەوە،
\v 31 ماوەیەکی درێژیش بۆ ئەوانە دەرکەوت کە لە جەلیلەوە هەتا ئۆرشەلیم لەگەڵیدا هاتبوون. ئێستا ئەوان لەبەردەم گەل شایەتی ئەمە دەدەن.
\p 
\v 32 «ئێمەش مزگێنیی ئەو بەڵێنەتان پێدەدەین کە بۆ باوباپیرانمان هات،
\v 33 ئەوەی خودا بۆ ئێمەی هێنایە دی کە وەچەی ئەوانین، بە هەستانەوەی عیسا. وەک لە زەبووری دووەمدا نووسراوە:
\q1 «﴿تۆ کوڕی منی،
\q2 من ئەمڕۆ بوومە باوکت.﴾\f + \fr 13:33 \ft \xt زەبوورەکان 2‏:7‏\xt*\ft ‏\f*
\m 
\v 34 خودا ئاوا دەفەرموێت سەبارەت بەوەی لەنێو مردووان هەڵیستاندەوە بۆ ئەوەی هەرگیز نەڕزێت:
\q1 ﴿ئەو بەڵێنە پیرۆز و مسۆگەرەتان دەدەمێ کە بە داودم دابوو.﴾\f + \fr 13:34 \ft \xt ئیشایا 55‏:3‏\xt*\ft ‏\f*
\m 
\v 35 بۆیە لە زەبوورێکی دیکە دەفەرموێ:
\q1 ﴿ڕێگا نادەیت دڵسۆزەکەی\f + \fr 13:35 \ft مەبەستی لە مەسیحە.‏\f* تۆ لەناو گۆڕ بۆگەن بێت.﴾\f + \fr 13:35 \ft \xt زەبوورەکان 16‏:10‏\xt*\ft ‏\f*
\p 
\v 36 «چونکە داود دوای ئەوەی بەگوێرەی مەبەستی خودا خزمەتی نەوەی خۆی کرد، نوست و چووە پاڵ باوباپیرانی و تەرمەکەی بۆگەن بوو.
\v 37 بەڵام ئەوەی خودا هەڵیستاندەوە بۆگەنی نەبینی.
\p 
\v 38 «بۆیە برایان، با لەلاتان زانراو بێت کە لە ڕێگەی عیساوە بەخشینی گوناه بە ئێوە ڕاگەیەنرا.
\v 39 بە باوەڕهێنان بە ئەو بێتاوان دەکرێن لە هەموو ئەو شتانەی نەتانتوانی بە تەوراتی موسا لێی بێتاوان بکرێن.
\v 40 جا ئاگاداربن، ئەوەی پێغەمبەران گوتوویانە بەسەرتاندا نەیەت:
\q1 
\v 41 «﴿ئەی گاڵتەجاڕەکان سەیر بکەن،
\q2 سەرسام بن و بمرن،
\q1 چونکە لە سەردەمی ئێوەدا کارێک دەکەم،
\q2 کارێک کە هەرگیز باوەڕ ناکەن ئەگەر بۆتان باس بکرێت.﴾\f + \fr 13:41 \ft \xt حەبەقوق 1‏:5‏\xt*\ft ‏\f*»
\p 
\v 42 کاتێک پۆڵس و بەرناباس لە کەنیشت دەهاتنە دەرەوە، داوایان لێ کرا شەممەی داهاتووش ئەم قسانەیان بۆ بکەن.
\v 43 دوای کۆبوونەوەکە، زۆر لە جولەکە و خواپەرستەکان کە ببوونە جولەکە، بەدوای پۆڵس و بەرناباس کەوتن، ئەمانیش قسەیان بۆ دەکردن و هانیان دەدان لە نیعمەتی خودا بمێنن.
\p 
\v 44 لە ڕۆژی شەممەی داهاتوودا نزیکەی هەموو دانیشتووانی شارەکە کۆبوونەوە، تاکو گوێ لە پەیامی مەسیحی خاوەن شکۆ بگرن.
\v 45 کاتێک جولەکە خەڵکەکەیان بینی، ئیرەیی دایگرتن و بەربەرەکانێی قسەکانی پۆڵسیان دەکرد و جنێویان پێدەدا.
\p 
\v 46 پۆڵس و بەرناباسیش بە چاونەترسییەوە وەڵامیان دانەوە: «پێویست بوو یەکەم جار پەیامی خودا بۆ ئێوە باس بکەین. بەڵام لەبەر ئەوەی ڕەتتان کردەوە و خۆتان بە شیاوی ژیانی هەتاهەتایی نەزانی، ئەوەتا دەچینە لای ناجولەکەکان،
\v 47 چونکە مەسیحی باڵادەست بەم جۆرە ڕایسپاردین:
\q1 «﴿من تۆم کردووەتە ڕووناکی بۆ نەتەوەکان،
\q2 تاکو ڕزگاری بەوپەڕی زەوی بگەیەنیت.﴾\f + \fr 13:47 \ft \xt ئیشایا 49‏:6.‏\xt*\ft ‏\f*»
\p 
\v 48 کاتێک ناجولەکەکان گوێیان لەمە بوو، زۆر دڵشاد بوون و پەیامی مەسیحی خاوەن شکۆیان شکۆدار کرد، هەموو ئەوانەش کە بۆ ژیانی هەتاهەتایی دەستنیشان کرابوون، باوەڕیان هێنا.
\p 
\v 49 پەیامی مەسیحی خاوەن شکۆ لە هەموو ناوچەکەدا بڵاو بووەوە.
\v 50 بەڵام ڕابەرانی جولەکە خانمە ڕێزدارە لەخواترسەکان و پیاوماقوڵانی شاریان جۆشدا، چەوساندنەوەیان لە دژی پۆڵس و بەرناباس بەرپا کرد و لە سنوورەکانی خۆیان دەریانکردن.
\v 51 ئەوانیش تۆزی پێیان تەکاند و بەرەو شاری کۆنیا ڕۆیشتن.
\v 52 قوتابییەکانیش پڕدەبوون لە خۆشی و ڕۆحی پیرۆز.
\c 14
\s1 گەشتێک بۆ کۆنیا
\p 
\v 1 لە کۆنیا پۆڵس‏ و بەرناباس وەک هەمیشە چوونە ناو کەنیشتی جولەکەکان و بە شێوەیەک قسەیان کرد کە ژمارەیەکی زۆر لە جولەکە و یۆنانییەکان باوەڕیان هێنا.
\v 2 بەڵام ئەو جولەکانەی باوەڕیان نەهێنا، ناجولەکەکانیان جۆشدا و لە دژی برایان مێشکیان پڕکردن.
\v 3 بۆیە پۆڵس و بەرناباس ماوەیەکی دوورودرێژ لەوێ مانەوە و ئازایانە سەبارەت بە عیسای خاوەن شکۆ قسەیان دەکرد، ئەویش شایەتی بۆ پەیامی نیعمەتی خۆی دەدا و ڕێی دابوو نیشانە و پەرجوو لەسەر دەستیان بکرێت.
\v 4 ئیتر دانیشتووانی کۆنیا بوونە دوو بەش، هەندێکیان لەگەڵ جولەکە بوون و هەندێکیان لەگەڵ نێردراوان.
\v 5 کاتێک ناجولەکەکان و جولەکە و سەرۆکەکانیان بەتەمابوون سووکایەتی بە نێردراوان بکەن و بەردبارانیان بکەن،
\v 6 نێردراوان زانییان و بۆ شاری لیسترا و دەربەی لیکاونیا\f + \fr 14:6 \ft لیسترا و دەربە دوو شار بوون لە هەرێمی لیکاونیا، دەکەوێتە ناوەڕاستی تورکیای ئێستا.‏\f* و بۆ ناوچەکانی دەوروپشتیان هەڵاتن و
\v 7 لەوێش مزگێنییان دەدا.
\s1 چاکبوونەوەی ئیفلیجێک
\p 
\v 8 لە لیسترا کابرایەک دانیشتبوو، هێز لە پێیەکانیدا نەبوو، بە زگماک ئیفلیج بوو، هەرگیز بە پێی خۆی نەڕۆیشتبوو.
\v 9 گوێی لە پۆڵس بوو کە قسەی دەکرد، پۆڵسیش چاوی تێبڕی، کاتێک بینی باوەڕی هەیە چاک بێتەوە،
\v 10 بە دەنگێکی بەرز گوتی: «هەستە بە پێوە ڕابوەستە!» کابرا دەستبەجێ هەڵبەزییەوە و دەستی بە ڕۆیشتن کرد.
\p 
\v 11 کاتێک خەڵکەکە بینییان پۆڵس چی کرد، بە زمانی لیکاونیا هاواریان کرد: «خوداوەندەکان\f + \fr 14:11 \ft یۆنانییە کۆنەکان بتپەرست بوون و بڕوایان وابوو چەند خوداوەندێک هەیە.‏\f* شێوەی مرۆڤیان وەرگرتووە و هاتوونەتە خوارەوە بۆ ناومان!»
\v 12 جا بەرناباسیان ناو نا زییۆس، پۆڵسیش هەرمەس\f + \fr 14:12 \ft لە ئەندێشەی یۆنانییەکان هەرمەس ئەو خوداوەندە بوو کە پەیامی زییۆسی گەورەی خوداوەندەکانی دەگەیاند.‏\f*، چونکە قسەکەری سەرەکی بوو.
\v 13 ئینجا کاهینی زییۆس، کە پەرستگاکەی لە دەرەوەی شار بوو، لەگەڵ خەڵکەکە گا و تاجەگوڵینەی هێنابووە لای دەروازەکان و دەیویست قوربانی پێشکەش بکات.
\p 
\v 14 بەڵام کاتێک نێردراوەکان، پۆڵس و بەرناباس، ئەمەیان بیست، جلەکانیان دڕاند، خێرا چوونە لای خەڵکەکە، هاواریان کرد:
\v 15 «خەڵکینە، بۆچی ئەمە دەکەن؟ ئێمەش مرۆڤین، لە هەمان سروشتی ئێوە، مزگێنیتان دەدەینێ واز لەم شتە پووچانە بهێنن و بۆ لای خودای زیندوو بگەڕێنەوە، دروستکەری ئاسمان و زەوی و دەریا و هەموو ئەو شتانەی تێیاندایە.
\v 16 ئەوەی لە نەوەکانی ڕابردوودا، هێشتی هەموو نەتەوەکان بە ڕێگای خۆیاندا بڕۆن.
\v 17 لەگەڵ ئەوەی خۆی بە بێ شایەتی نەهێشتەوە، چاکە دەکات، لە ئاسمانەوە باران و وەرزی بەروبوومتان دەداتێ و دڵتان لە خواردن و لە خۆشی تێر دەکات.»
\v 18 بە گوتنی ئەم قسانە و هەوڵدانێکی زۆر توانییان وا لە خەڵکەکە بکەن کە قوربانییان بۆ نەکەن.
\p 
\v 19 هەندێک جولەکە لە ئەنتاکیا و کۆنیاوە هاتن، قەناعەتیان بە خەڵکەکە هێنا، ئەوانیش پۆڵسیان بەردباران کرد و ڕایانکێشایە دەرەوەی شار، وایانزانی مردووە.
\v 20 بەڵام کاتێک قوتابییەکان دەوریان دا، هەستا و گەڕایەوە ناو شار. بۆ ڕۆژی دواتر لەگەڵ بەرناباس بۆ دەربە ڕۆیشت.
\p 
\v 21 مزگێنییان بەو شارە دا و ژمارەیەکی زۆریان کردە قوتابی. ئینجا گەڕانەوە لیسترا و کۆنیا و ئەنتاکیا،
\v 22 ورەی قوتابییەکانیان بەرز دەکردەوە هانیان دەدان لە باوەڕ بچەسپێن: «پێویستە بە تەنگانەی زۆردا بچینە ناو شانشینی خودا.»
\v 23 لە هەر کڵێسایەک پۆڵس و بەرناباس پیرانیان بۆ هەڵبژاردن، ئینجا بە ڕۆژووگرتنەوە نوێژیان کرد و پیرەکانیان دایە دەست مەسیحی باڵادەست کە باوەڕیان پێی هێناوە.
\v 24 ئینجا بە پیسیدیادا تێپەڕین و گەیشتنە پامفیلیا.
\v 25 لە شاری پەرگە پەیامی خودایان ڕاگەیاند و پاشان بۆ بەندەری ئەنتالیا\f + \fr 14:25 \ft یۆنانی: \tl ئەتالیا‏\tl*.‏\f* دابەزین.
\p 
\v 26 لەوێشەوە بە ڕێگای دەریا بۆ ئەنتاکیا گەڕانەوە، ئەو شوێنەی لێوەی درانە دەست نیعمەتی خودا بۆ ئەو کارەی جێبەجێیان کرد.
\v 27 کاتێک گەیشتن و کڵێسایان کۆکردەوە، باسی هەموو ئەو شتانەیان کرد کە خودا لەگەڵیان کردبووی، هەروەها کە دەرگای باوەڕی بۆ ناجولەکەکانیش کردووەتەوە.
\v 28 جا لەوێ ماوەیەکی زۆر لەگەڵ قوتابییەکان مانەوە.
\c 15
\s1 ئەنجومەنی ئۆرشەلیم
\p 
\v 1 هەندێک کەس لە یەهودیاوە بۆ ئەنتاکیا هاتن و برایانیان فێردەکرد و دەیانگوت: «ئەگەر بەپێی ئەو نەریتەی کە موسا فێری کردن خەتەنە نەکرێن، ناتوانن ڕزگاربن.»
\v 2 کاتێک دەمەقاڵە و مشتومڕێکی زۆر لەلایەن پۆڵس و بەرناباس لەگەڵ ئەوان ڕوویدا، پۆڵس و بەرناباس لەگەڵ چەند کەسێکی دیکە دیاری کران، تاکو سەبارەت بەم بابەتە بۆ لای نێردراوان و پیران بەرەو ئۆرشەلیم بەڕێ بکەون.
\v 3 پاش ئەوەی کڵێسا ماڵئاواییان لێکردن، بە ناو فینیکیا و سامیرەدا تێپەڕین، باسی ئەوەیان دەکرد کە ناجولەکەکانیش باوەڕیان بە عیسا هێناوە، جا خۆشییەکی زۆریان لەنێو هەموو باوەڕداراندا بڵاوکردەوە.
\v 4 کاتێک گەیشتنە ئۆرشەلیم، کڵێسا و نێردراوان و پیران پێشوازییان لێکردن، ئەوانیش هەواڵی هەموو ئەو شتانەیان پێدان کە خودا لە ڕێگەی ئەوانەوە کردبووی.
\p 
\v 5 بەڵام هەندێک لەوانەی سەر بە ڕێبازی فەریسییەکان بوون و باوەڕیان هێنابوو، هەستان و گوتیان: «دەبێت ئەو باوەڕدارانەی کە جولەکە نین خەتەنە بکرێن و فەرمانیان پێ بکرێت کە کار بە تەوراتی موسا بکەن.»
\s1 پەترۆس و پیرانی ئۆرشەلیم
\p 
\v 6 جا نێردراوان و پیران بۆ لێکۆڵینەوەی ئەم بابەتە کۆبوونەوە.
\v 7 پاش مشتومڕێکی زۆر، پەترۆس هەستا و پێی گوتن: «ئەی برایان، ئێوە دەزانن پێش ماوەیەک، خودا لەنێو ئێوەدا هەڵیبژارد کە لە دەمی منەوە ناجولەکەکان مزگێنیی مەسیح ببیستن و باوەڕ بهێنن.
\v 8 ئەو خودایەی کە دەزانێت چی لە دڵدایە، شایەتی بۆیان دا بە بەخشینی ڕۆحی پیرۆز بەوانیش هەروەک بە ئێمە.
\v 9 بە هیچ شتێک جیاوازی لەنێوان ئێمە و ئەواندا نەکردووە، بە باوەڕ دڵی ئەوانیشی پاک کردووەتەوە.
\v 10 ئیتر بۆچی ئێوە خودا تاقی دەکەنەوە، نیرێک\f + \fr 15:10 \fq نیر: \ft دارێکە دەخرێتە سەر شانی گا یان ڕەشەوڵاخ بۆ ڕاکێشانی عەرەبانە یان ئامێری جووت.\f* دەخەنە سەر شانی ئەو قوتابییانەی کە جولەکە نین، ئەوەی نە باوباپیرانمان و نە خۆمان توانیمان هەڵیبگرین؟
\v 11 بەڵام باوەڕمان هەیە کە بە نیعمەتی عیسای خاوەن شکۆ ڕزگار دەبین، هەروەک ئەوان.»
\p 
\v 12 ئیتر هەموو ئەندامانی ئەنجومەنەکە بێدەنگ بوون و گوێیان لە بەرناباس و پۆڵس گرت، باسی ئەو نیشانە و پەرجووانەیان دەکرد کە خودا لەسەر دەستی ئەوان لەناو ناجولەکەکان ئەنجامی داوە.
\v 13 دوای ئەوەی تەواوبوون، یاقوب گوتی: «ئەی برایان گوێم لێ بگرن.
\v 14 شیمۆن\f + \fr 15:14 \ft مەبەستی لە پەترۆسە.‏\f* ڕوونی کردەوە چۆن خودا یەکەم جارە بایەخی خۆی بۆ ناجولەکەکان نیشان داوە بۆ ئەوەی لەناو ئەواندا گەلێک ناوی ئەو هەڵبگرن\f + \fr 15:14 \ft مەبەستی ئەوەیە کە گەلێک بە ناوی خودا بناسرێن.‏\f*.
\v 15 وتەی پێغەمبەرانیش لەگەڵ ئەمە ڕێک دەکەوێت، هەروەک نووسراوە:
\q1 
\v 16 «﴿دوای ئەمە دەگەڕێمەوە و
\q2 چادرە ڕووخاوەکەی داود هەڵدەدەمەوە،
\q1 ڕووخاوییەکانی دروستدەکەمەوە،
\q2 سەرلەنوێ بنیادی دەنێمەوە،
\q1 
\v 17 تاکو ئەو خەڵکانەی کە ماونەتەوە ڕوو لە یەزدان بکەن،
\q2 هەموو ئەو ناجولەکانەی ناوی منیان هەڵگرتووە.
\q1 ئەوە فەرمایشتی یەزدانە، ئەوەی ئەم کارانە ئەنجام دەدات
\q2 
\v 18 کە هەر لە سەرەتاوەش زانراون.﴾\f + \fr 15:18 \ft \xt ئامۆس 9‏:11‏-12‏\xt*\ft ‏\f*
\p 
\v 19 «لەبەر ئەوە وای بە باش دەزانم قورسایی نەخەینە سەر شانی ئەو ناجولەکانەی کە بۆ لای خودا گەڕاونەتەوە،
\v 20 بەڵکو بۆیان بنووسین، خۆیان دووربخەنەوە لە گڵاوی بتەکان و لە داوێنپیسی و لە گۆشتی ئاژەڵی خنکێنراو و خوێن،
\v 21 چونکە هەر لە کۆنەوە فێرکردنی موسا لە هەموو شارێک ڕاگەیەنرابوو و هەموو شەممەیەک لە کەنیشتەکان دەخوێنرایەوە.»
\s1 بڕیاری کۆبوونەوەی کڵێسا
\p 
\v 22 ئینجا نێردراوان و پیران و هەموو کڵێسا بە باشیان زانی دوو پیاو لەناو خۆیاندا هەڵبژێرن و لەگەڵ پۆڵس و بەرناباسدا بیاننێرن بۆ ئەنتاکیا. یەهوزای ناسراو بە بەرساباس و سیلایان هەڵبژارد، کە پێشەوای نێو باوەڕداران بوون.
\v 23 بە دەستی خۆیان ئاوایان نووسی\f + \fr 15:23 \ft بە واتای نامەیەکیان نووسی و بەواندا ناردیان.‏\f*:
\pmo لە نێردراوان و پیرانەوە، برایانتان،
\pmo بۆ ئەو باوەڕدارانەی جولەکە نین لە ناوچەکانی ئەنتاکیا و سوریا و کیلیکیا:
\pmo سڵاو.
\pm 
\v 24 بیستمان کە هەندێک کەس بێ ئەوەی ئێمە ڕایانبسپێرین لەلای ئێمەوە هاتوون و بە قسەکانیان بێزار و دڵگرانیان کردوون.
\v 25 بۆیە بە باشمان زانی بە یەک بیروڕاوە چەند پیاوێک هەڵبژێرین و لەگەڵ برایانی خۆشەویستمان بەرناباس و پۆڵس بیاننێرن بۆ لاتان،
\v 26 پیاوانێک گیان لەسەر دەستن لە پێناوی ناوی عیسای مەسیحی خاوەن شکۆمان.
\v 27 جا یەهوزا و سیلامان نارد بۆ لاتان تاکو هەمان شتتان بە دەم پێ ڕابگەیەنن،
\v 28 چونکە ڕۆحی پیرۆز و ئێمەش وامان بە باش زانی هیچ قورساییەک نەخەینە سەر شانتان، جگە لەمانە کە پێویستن:
\v 29 خۆتان دووربخەنەوە لەو قوربانییانەی بۆ بت پێشکەش کراون، هەروەها لە خواردنی ئاژەڵی خنکێنراو و خوێن و لە داوێنپیسی. ئەگەر خۆتان لەمانە پاراست، شتی چاک دەکەن.
\pmc ماڵ ئاوا.
\p 
\v 30 ئەمانیش کە بەڕێکران و بۆ ئەنتاکیا هاتن، هەموو کۆمەڵەی باوەڕدارانیان کۆکردەوە و نامەکەیان پێشکەش کرد.
\v 31 کاتێک خوێندیانەوە بەو هاندانەی تێیدا بوو زۆر دڵشاد بوون.
\v 32 یەهودا و سیلاش کە خۆیان پێغەمبەر بوون، بە زۆر وشە هانی برایانیان دا و ورەیان بەرزکردنەوە.
\v 33 پاش ئەوەی ماوەیەکیان بەسەربرد، لەلایەن برایانەوە بە ئاشتییەوە ڕەوانە کرانەوە بۆ لای ئەوانەی ناردبوویانن، [
\v 34 بەڵام سیلا بەلایەوە باشتر بوو لەوێ بمێنێتەوە.]
\v 35 پۆڵس و بەرناباسیش هەر لە ئەنتاکیا مانەوە و لەگەڵ زۆر کەسی دیکەدا بەشدارییان کرد لە مزگێنیدان و فێرکردنی پەیامی مەسیحی خاوەن شکۆ.
\s1 جیابوونەوەی پۆڵس و بەرناباس
\p 
\v 36 پاش چەند ڕۆژێک پۆڵس بە بەرناباسی گوت: «با بگەڕێینەوە بۆ هەموو ئەو شارانەی کە پەیامی مەسیحی خاوەن شکۆمان تێیدا ڕاگەیاندووە و سەر لە برایان بدەین و هەواڵیان بزانین.»
\v 37 بەرناباسیش پێشنیاری کرد کە یۆحەنا لەگەڵ خۆیاندا بیبەن، ئەوەی بە مەرقۆس ناسراوە.
\v 38 بەڵام پۆڵس پێی باش بوو ئەو کەسە لەگەڵ خۆیاندا نەبەن کە لە پامفیلیادا لێیان جیا بووەوە و لەگەڵیان بۆ کارەکە نەڕۆیشت.
\v 39 لەبەر ئەوە دەمەقاڵە کەوتە نێوانیان، تاکو وای لێهات لە یەکتری جیا بوونەوە. ئەوسا بەرناباس مەرقۆسی لەگەڵ خۆی برد و بە دەریادا بۆ قوبرس چوو.
\v 40 بەڵام پۆڵس سیلای هەڵبژارد و ڕۆیشتن، دوای ئەوەی لەلایەن باوەڕدارانەوە بە نیعمەتی مەسیحی خاوەن شکۆ سپێردران.
\v 41 ئینجا چوونە ناوچەکانی سوریا و کیلیکیا و کڵێساکانیان بەهێز دەکرد.
\c 16
\s1 تیمۆساوس لەگەڵ پۆڵس و سیلا
\p 
\v 1 پۆڵس گەیشتە شاری دەربە و پاشان شاری لیسترا، لەوێ قوتابییەک بە ناوی تیمۆساوس هەبوو، دایکی جولەکەیەکی باوەڕدار بوو، بەڵام باوکی یۆنانی بوو.
\v 2 برایان لە لیسترا و کۆنیا بە باشە باسی تیمۆساوسیان دەکرد.
\v 3 پۆڵس حەزی دەکرد تیمۆساوس یاوەری بێت، جا بردی تاکو خەتەنە بکرێت، لەبەر ئەو جولەکانەی لەو ناوچانە بوون، چونکە هەموو دەیانزانی باوکی یۆنانییە.
\v 4 ئیتر پۆڵس و هاوڕێکانی لە‏ شارێکەوە دەچوون بۆ شارێکی دیکە و ئەو فەرمانانەی لەلایەن نێردراوان و پیرانەوە لە ئۆرشەلیم بڕیاریان لەسەر درابوو، پێیان ڕادەگەیاندن تاکو پەیڕەوی بکەن.
\v 5 جا کڵێساکان لە باوەڕدا بەهێز دەبوون و ڕۆژ لەدوای ڕۆژ ژمارەیان زیادی دەکرد.
\s1 بینینی پۆڵس لە ترۆئاس
\p 
\v 6 پاشان پۆڵس و هاوڕێیەکانی بە ناوچەکانی فریجیا و گەلاتیادا تێپەڕین، لەبەر ئەوەی ڕۆحی پیرۆز ڕێی نەدان لە ناوچەی ئاسیا پەیامی خودا ڕابگەیەنن.
\v 7 کاتێک گەیشتنە نزیک ناوچەی میسیا هەوڵیان دا بەرەو ناوچەی بیسینیا بڕۆن، بەڵام ڕۆحی عیسا ڕێگای نەدان.
\v 8 ئەوسا بە میسیادا تێپەڕین و هاتنە ترۆئاس.
\v 9 لە شەودا پۆڵس بینینێکی بۆ ئاشکرا کرا، کە تێیدا پیاوێکی مەکدۆنی ڕاوەستابوو و لێی دەپاڕایەوە و دەیگوت: «وەرە بۆ مەکدۆنیا و یارمەتیمان بدە.»
\v 10 پاش ئەوەی بینینەکەی بۆ ئاشکرا کرا، هەوڵماندا\f + \fr 16:10 \ft بەڵگەیە بۆ ئامادەبوونی لۆقای پزیشک لەگەڵ پۆڵس.‏\f* دەستبەجێ بەڕێ بکەوین بۆ مەکدۆنیا، دڵنیا بووین کە خودا بانگی کردووین تاکو مزگێنییان بدەینێ.
\p 
\v 11 جا بە دەریادا لە ترۆئاسەوە ڕاست بۆ سامۆسراکی ڕۆیشتین و بۆ ڕۆژی دوایی بۆ نیاپۆلیس.
\v 12 لەوێشەوە بۆ فیلیپی کە گرنگترین شاری ناوچەی مەکدۆنیایە و جێنشینی ڕۆمانییەکانە، لەوێ چەند ڕۆژێک ماینەوە.
\p 
\v 13 لە ڕۆژی شەممەدا چووینە دەرەوەی شار بۆ سەر ڕووبار، لەو بڕوایەدا بووین کە شوێنێک بۆ نوێژکردن بدۆزینەوە. دانیشتین قسەمان لەگەڵ ئەو ژنانە کرد کە لەوێ کۆببوونەوە.
\v 14 یەک لەوان کە گوێی دەگرت ژنێکی خواپەرست بوو بە ناوی لیدیا، خەڵکی شاری سیاتیرا و بازرگانی کوتاڵی گرانبەها بوو. مەسیحی خاوەن شکۆ دڵی کردەوە تاکو سەرنج بداتە قسەکانی پۆڵس.
\v 15 کاتێک خۆی و خاووخێزانی لە ئاو هەڵکێشران، پاڕایەوە و گوتی: «ئەگەر بەڕاستی باوەڕتان وایە کە من باوەڕم بە مەسیحی خاوەن شکۆ هێناوە، ئەوا وەرنە ماڵەکەم و بمێننەوە.» ئیتر ناچاری کردین.
\s1 دەرکردنی ڕۆحی فاڵچیێتی
\p 
\v 16 کاتێک بۆ شوێنی نوێژکردن دەچووین، تووشی کارەکەرێک بووین ڕۆحی فاڵچیێتی تێدابوو، بە کاری فاڵچیێتییەکەی قازانجێکی زۆری بۆ خاوەنەکانی بەدەستدەهێنا.
\v 17 بەدوای پۆڵس و ئێمە کەوت و هاواری دەکرد: «ئەم مرۆڤانە بەندەی خودای هەرەبەرزن، ڕێگای ڕزگاریتان بۆ ڕادەگەیەنن.»
\v 18 چەندین ڕۆژ ئەمەی دەکرد، تاکو پۆڵس بێزار بوو، ئاوڕی دایەوە و بە ڕۆحەکەی گوت: «بە ناوی عیسای مەسیح فەرمانت پێدەدەم، لێی وەرە دەرەوە!» یەکسەر ڕۆحە پیسەکە لێی هاتە دەرەوە.
\s1 پۆڵس و سیلا لە بەندیخانە
\p 
\v 19 کاتێک خاوەنەکانی کچە کارەکەرەکە بینییان سەرچاوەی داهاتیان بڕا، پۆڵس و سیلایان گرت، ڕایانکێشانە بازاڕ بۆ بەردەم دەسەڵاتداران.
\v 20 بردیاننە پێش دادوەران و گوتیان: «ئەم پیاوانە شارەکەمان دەشێوێنن، جولەکەن و
\v 21 نەریتێک بڵاو دەکەنەوە کە دروست نییە ئێمەی ڕۆمانی وەریبگرین یان کاری پێ بکەین.»
\p 
\v 22 ئیتر خەڵکەکە پێکڕا لێیان هەستان و دادوەران فەرمانیان دا کە جلەکانیان بدڕێنرێن و دارکاری بکرێن.
\v 23 جا زۆر دارکارییان کردن و خستیاننە بەندیخانەوە، فەرمانیان بە چاودێری بەندیخانەکە دا بە توندی پاسەوانیان بکات.
\v 24 ئەویش کە ئەم فەرمانەی بۆ هات، فڕێیدانە ناو قووڵایی بەندیخانەکە و پێیانی خستە ناو کۆتەوە.
\p 
\v 25 لە نیوەی شەودا پۆڵس و سیلا نوێژیان دەکرد و گۆرانی ڕۆحییان بۆ خودا دەگوت، بەندکراوانی دیکەش گوێیان لێبوو.
\v 26 لەناکاو بوومەلەرزەیەکی بەهێز ڕوویدا، بناغەی بەندیخانەکەی هەژاند، دەستبەجێ هەموو دەرگاکان کرانەوە و کۆتی هەمووان بووەوە.
\v 27 کە چاودێرەکە خەبەری بووەوە و بینی دەرگاکانی بەندیخانە کراونەتەوە، شمشێری هەڵکێشا بەتەمابوو خۆی بکوژێت، وایزانی بەندکراوان ڕایانکردووە.
\v 28 بەڵام پۆڵس هاواری کرد: «هیچ لە خۆت مەکە، هەموومان لێرەین!»
\p 
\v 29 ئەویش داوای ڕووناکی کرد، چووە ژوورەوە و دەلەرزی، لەبەردەم پۆڵس و سیلا چۆکی دادا.
\v 30 ئەوسا بردنییە دەرەوە و گوتی: «گەورەکانم، پێویستە چی بکەم تاکو ڕزگارم بێت؟»
\p 
\v 31 گوتیان: «باوەڕ بە عیسای خاوەن شکۆ بهێنە، خۆت و خێزانەکەت ڕزگارتان دەبێت.»
\v 32 جا پەیامی مەسیحی خاوەن شکۆیان بۆ خۆی و هەموو ئەوانەی لە ماڵەکەیدا بوون ڕاگەیاند.
\v 33 ئیتر چاودێرەکە لەو کاتەی شەودا بردنی و برینەکانی ساڕێژ کردن و پاشان دەستبەجێ خۆی و خاووخێزانەکەی لە ئاو هەڵکێشران.
\v 34 ئینجا بردنییە ماڵەوە و خواردنی بۆ دانان، خۆی و خاووخێزانەکەی زۆر دڵشاد بوون، کە باوەڕیان بە خودا هێنابوو.
\p 
\v 35 کە ڕۆژبووەوە فەرمانڕەواکان چەند سەربازێکیان نارد و گوتیان: «پیاوەکان ئازاد بکەن.»
\v 36 چاودێری بەندیخانە ئەم هەواڵەی دایە پۆڵس: «فەرمانڕەوایان ناردوویانە کە ئازاد بکرێن، بۆیە ئێستا وەرنە دەرەوە و بڕۆن بە سەلامەت.»
\p 
\v 37 بەڵام پۆڵس پێی گوتن: «بە بێ دادگایی کردن و بە ئاشکرا دارکارییان کردین و فڕێیان داینە بەندیخانە، ئێمەش هاوڵاتی ڕۆمانین، ئایا ئێستا بە نهێنی دەرماندەکەن؟ نەخێر! بەڵکو با خۆیان بێن دەرمانبهێنن.»
\p 
\v 38 پۆلیسەکان ئەم قسانەیان بە فەرمانڕەوایان ڕاگەیاند، ئەوانیش کاتێک زانییان پۆڵس و سیلا هاوڵاتی ڕۆمانین ترسان.
\v 39 ئیتر هاتن و لێیان پاڕانەوە، بردیاننە دەرەوە و داوایان لێکردن شارەکە بەجێبهێڵن.
\v 40 کاتێک پۆڵس و سیلا لە بەندیخانە هاتنە دەرەوە، چوون بۆ ماڵی لیدیا، لەوێ لەگەڵ خوشک و برایانی باوەڕدار کۆبوونەوە و هانیان دان، پاشان ڕۆیشتن.
\c 17
\s1 پۆڵس و سیلا لە سالۆنیکی
\p 
\v 1 پاش ئەوەی پۆڵس و هاوڕێکانی بە شاری ئەمفیپۆلیس و ئەپۆلۆنیادا تێپەڕین، گەیشتنە سالۆنیکی کە کەنیشتی جولەکەی لێبوو.
\v 2 پۆڵس وەک کردبوویە پیشە چووە لایان، سێ ڕۆژی شەممە لەسەر یەک بە نووسراوە پیرۆزەکان گفتوگۆی لەگەڵ دەکردن،
\v 3 ڕوونی دەکردەوە و دەریدەخست کە دەبووایە مەسیح ئازار بچێژێت و لەنێو مردووان هەستێتەوە. پێی گوتن: «ئەم عیسایەی من پێتانی ڕادەگەیەنم، مەسیحەکەیە.»
\v 4 هەندێکیان قایل بوون و چوونە پاڵ پۆڵس و سیلا، هەروەها زۆر لە یۆنانی خواپەرست و لە ژنە خانەدانەکانیش کە ژمارەیان کەم نەبوو.
\p 
\v 5 بەڵام هەندێک لە جولەکەکانی دیکە ئیرەییان پێ هات، چەند پیاوخراپێکی بازاڕیان هێنا و خەڵکیان کۆکردەوە و ئاژاوەیان لە شاردا نایەوە. چوونە سەر ماڵی یاسون و داوایان کرد پۆڵس و سیلا بهێنرێنە لای خەڵک.
\v 6 کاتێک نەیاندۆزینەوە، یاسون و هەندێک برایانیان بۆ لای فەرمانڕەوایانی شار ڕاکێشا، هاواریان دەکرد: «ئەمانە کە جیهانیان هەڵگێڕاوەتەوە، بۆ ئێرەش هاتوون،
\v 7 یاسون میوانداری کردوون. هەموویان لە دژی فەرمانەکانی قەیسەر کار دەکەن، دەڵێن پاشایەکی دیکە هەیە، ناوی عیسایە.»
\v 8 بەم قسانە خەڵکەکە و فەرمانڕەوایانی شاریان وروژاند.
\v 9 ئەوانیش دەستەبەرنامەیان\f + \fr 17:9 \ft دەستەبەرنامە: بڕێک پارەیە کە وەک بارمتە وەردەگیرێت لەگەڵ بەڵێننامەیەکی فەرمی، لە کاتی بوونی هەر کێشەیەکدا دەستدەگیردرێت بەسەر پارەکەدا.‏\f* بۆ یاسون و ئەوانەی دیکە کرد و ئازادیان کردن.
\s1 لە شاری بیریە
\p 
\v 10 کە شەو داهات برایان پۆڵس و سیلایان ناردە بیریە، کە گەیشتن چوونە کەنیشتی جولەکە.
\v 11 خەڵکی بیریە لە سالۆنیکییەکان تێگەیشتووتر بوون، چونکە بەوپەڕی پەرۆشییەوە پەیامەکەیان وەرگرت و بۆ دڵنیابوون لە ڕاستیی قسەکانی پۆڵس، ڕۆژانە لە نووسراوە پیرۆزەکان ورد دەبوونەوە.
\v 12 ئیتر زۆریان باوەڕیان هێنا، هەروەها ژمارەیەک لە ژنە خانەدانە یۆنانییەکان و ژمارەیەکی زۆریش لە پیاوانی یۆنانی.
\p 
\v 13 بەڵام کاتێک جولەکەی سالۆنیکی زانییان پۆڵس لە بیریەش پەیامی خودای ڕاگەیاندووە، هاتن لەوێش خەڵک جۆش بدەن و بیانوروژێنن.
\v 14 دەستبەجێ برایان پۆڵسیان بەرەو کەناری دەریا نارد، بەڵام سیلا و تیمۆساوس لەوێ مانەوە.
\v 15 ئەوانەی یاوەری پۆڵس بوون ئەویان هێنایە ئەسینا، ئینجا گەڕانەوە پاش ئەوەی پۆڵس ڕایسپاردن بە زووترین کات سیلا و تیمۆساوس بێن بۆ لای.
\s1 پۆڵس لە ئەسینا
\p 
\v 16 کاتێک پۆڵس لە ئەسینا چاوەڕێی دەکردن، زۆر پەست و بێزار بوو کە بینی شارەکە پڕە لە بت.
\v 17 بۆیە لە کەنیشت گفتوگۆی لەگەڵ جولەکە و خواپەرستان دەکرد، لە بازاڕیش لەگەڵ ئەوانەی ڕۆژانە تووشیان دەبوو.
\v 18 کۆمەڵێک فەیلەسوفی ئەپیکوری\f + \fr 17:18 \ft ڕێبازێکی فەلسەفەی یۆنانییە؛ بەرزترین بنەمای شادییە، لەو سەردەمەدا زۆر گرنگییان بە ئارەزووی جەستە دەدا.‏\f* و ستۆیکی\f + \fr 17:18 \ft ڕێبازێکی فەلسەفەی یۆنانییە؛ کە دەڵێ پێویستە مرۆڤ لەگەڵ سروشتدا بگونجێت و بەسەر خۆیدا زاڵ بێت.‏\f* گفتوگۆیان لەگەڵی دەکرد. هەندێکیان دەیانگوت: «ئەم چەنەبازە دەیەوێت چی بڵێت؟» هەندێکی دیکەشیان دەیانگوت: «دیارە بانگەواز بۆ چەند خوداوەندێکی نامۆ دەکات،» چونکە باسی عیسا و زیندووبوونەوەی دەکرد.
\v 19 ئینجا بردیانە ئاریۆپاگۆس\f + \fr 17:19 \ft شوێنی کۆبوونەوەی ئەنجومەنی شاری ئەسینا بوو.‏\f* و گوتیان: «دەتوانین بزانین ئەم فێرکردنە نوێیە چییە باسی دەکەیت؟
\v 20 چونکە شتی سەیرت لێ دەبیستین و دەمانەوێت واتاکەی بزانین.»
\v 21 لەبەر ئەوەی هەموو ئەسیناییەکان و ئەو بێگانانەی تێدا دەژیان دەرفەتیان بە هیچ شتێک نەدەدا جگە لە باسکردن و گوێگرتن لە بیروڕا نوێیەکان.
\s1 وتارێک لە ئاریۆپاگۆس
\p 
\v 22 پۆڵس لە ناوەڕاستی ئاریۆپاگۆسدا وەستا و گوتی: «پیاوانی ئەسینا، دەبینم لە هەموو لایەکەوە زۆر دیندارن.
\v 23 کاتێک دەگەڕام و سەیری پەرستراوەکانتانم دەکرد، قوربانگایەکم بینی لەسەری نووسرا بوو:
\pc ”بۆ خودای نەناسراو.“‏
\m جا ئەوەتان بۆ ڕادەگەیەنم کە دەیپەرستن و نایناسن.
\p 
\v 24 «ئەو خودایەی کە جیهان و هەموو شتەکانی ناوی دروستکردووە، پەروەردگاری ئاسمان و زەوییە و لە پەرستگای دەستکرد نیشتەجێ نابێت.
\v 25 بە دەستی مرۆڤ خزمەت ناکرێت وەک ئەوەی پێویستی بە شتێک بێت، چونکە ئەو خۆی ژیان و هەناسە و هەموو شتێک بە هەمووان دەبەخشێت.
\v 26 هەموو نەتەوەکانی لە یەک کەسەوە دروستکردووە، تاکو لەسەر هەموو ڕووی زەوی نیشتەجێ بن، کات و سنوورەکانی نیشتەجێبوونی ئەوانی داناوە و دیاری کردووە،
\v 27 تاکو ڕوو لە خودا بکەن، بەڵکو بیگەنێ و بیدۆزنەوە، هەرچەندە لە هەر یەکێکمان دوور نییە.
\v 28 ”چونکە لە ئەودا دەژین و دەجوڵێین و هەین،“\f + \fr 17:28 \ft لە شیعری (ئەپیمەنیدیس)ی شاعیر وەرگیراوە، کە خەڵکی کریتە و لە ساڵی 600 پ. ز. ژیاوە.‏\f* وەک هەندێک شاعیرانتان گوتیان: ”ئێمەش نەوەی ئەوین.“\f + \fr 17:28 \ft لە شیعری (ئارەتۆس)ی شاعیر وەرگیراوە، کە خەڵکی کیلیکیایە و لە 315‏–240 پ. ز. ژیاوە.‏\f*
\p 
\v 29 «لەبەر ئەوەی کە نەوەی خوداین، پێویستە وا بیرنەکەینەوە کە خودا وەکو پەیکەری زێڕ یان زیو یان بەردینە، کە داهێنان و بیری مرۆڤ شێوەی کێشاوە.
\v 30 لە سەردەمانی نەزانیدا خودا چاوپۆشی کردووە، بەڵام ئێستا فەرمان دەدات بە هەموو کەسێک لە هەموو شوێنێک کە تۆبە بکەن،
\v 31 چونکە ڕۆژێکی دیاری کردووە کە تێیدا لە ڕێگەی ئەو پیاوەی کە دەستنیشانی کردووە، بە دادپەروەری جیهان حوکم بدات. بەڵگەشی بە هەمووان داوە کە لەنێو مردووان هەڵیستاندەوە.»
\p 
\v 32 کاتێک گوێیان لە هەستانەوەی مردووان بوو، هەندێکیان گاڵتەیان پێکرد، بەڵام هەندێکی دیکەیان گوتیان: «جارێکی دیکە لەم بارەیەوە گوێت لێ دەگرین.»
\v 33 ئیتر پۆڵس ئەوێی بەجێهێشت،
\v 34 بەڵام هەندێک کەس لایەنگری پۆڵسیان کرد و باوەڕیان هێنا، لەوانە: دیونیسیۆسی ئەندامی ئاریۆپاگۆس، هەروەها ژنێک بە ناوی داماریس و چەند کەسێکی دیکەش لەگەڵیان.
\c 18
\s1 پۆڵس لە کۆرنسۆس
\p 
\v 1 لەدوای ئەمە پۆڵس ئەسینای بەجێهێشت و هاتە کۆرنسۆس.
\v 2 لەوێ جولەکەیەکی دۆزییەوە بە ناوی ئەکیلا، خەڵکی پۆنتۆس\f + \fr 18:2 \ft شوێنێکە دەکەوێتە کەناری دەریای ڕەش، لە باکووری تورکیای ئێستا. بڕوانە \xt کردار 2‏:9‏\xt*\ft ‏\f* بوو، تازە لەگەڵ پریسکیلای ژنی لە ئیتالیاوە هاتبوون، چونکە کلودیۆس\f + \fr 18:2 \ft ئیمپراتۆری ڕۆمانی لە ساڵانی 41‏–55 ز.‏\f* فەرمانی دابوو هەموو جولەکە ڕۆما بەجێبهێڵن. پۆڵس ئیتر چووە لایان
\v 3 و بەهۆی هاوپیشەییان لەلایان مایەوە و ئیشی دەکرد، چونکە پیشەیان چادر دروستکردن بوو.
\v 4 پۆڵس هەموو شەممەیەک لە کەنیشت گفتوگۆی دەکرد و هەوڵی دەدا قەناعەت بە جولەکە و یۆنانییەکان بهێنێت.
\p 
\v 5 کاتێک سیلا و تیمۆساوس لە مەکدۆنیاوە هاتن، پۆڵس خۆی بۆ خزمەتی پەیامی مەسیح تەرخان کرد و لەنێو جولەکەکاندا شایەتی دەدا کە عیسا مەسیحەکەیە.
\v 6 بەڵام کاتێک دژایەتییان کرد و جنێویان پێدا، کراسەکەی تەکاند و پێی گوتن: «خوێنی خۆتان لەسەر خۆتان! من بێتاوانم. لە ئێستاوە دەچمە لای ناجولەکەکان.»
\p 
\v 7 ئیتر پۆڵس کەنیشتەکەی بەجێهێشت و چووە ماڵی پیاوێکی خواپەرست بە ناوی تیتیۆس یوستۆس، کە ماڵەکەی لەتەنیشت کەنیشتەوە بوو.
\v 8 کریسپۆسی پێشەوای کەنیشتەکە خۆی و خاووخێزانی باوەڕیان بە عیسای خاوەن شکۆ هێنا. هەروەها زۆر لە خەڵکی کۆرنسۆس کە گوێیان لە پۆڵس بوو باوەڕیان هێنا و لە ئاو هەڵکێشران.
\s1 قسە بکە و بێدەنگ مەبە
\p 
\v 9 شەوێک مەسیحی خاوەن شکۆ لە بینینێکدا بە پۆڵسی فەرموو: «مەترسە، بەڵکو قسە بکە و بێدەنگ مەبە،
\v 10 چونکە من لەگەڵتدام، کەس هێرش ناکاتە سەرت بۆ ئەوەی ئازارت بدات، چونکە خەڵکێکی زۆرم هەیە لەم شارە.»
\v 11 ئیتر پۆڵس ساڵێک و شەش مانگ لەگەڵیان مایەوە و پەیامی خودای فێر دەکردن.
\p 
\v 12 لەو سەردەمەی گالیۆن\f + \fr 18:12 \ft فەرمانڕەوای ئەخایا لە ساڵانی 51‏–52 ز، بە دادپەروەری بەناوبانگە.‏\f* فەرمانڕەوای ئەخایا\f + \fr 18:12 \ft باشووری یۆنان‏\f* بوو، جولەکە هەموویان پێکەوە هێرشیان کردە سەر پۆڵس و بردیان بۆ دادگا،
\v 13 گوتیان: «ئەم پیاوە قەناعەتی بە خەڵک دەهێنا کە بە پێچەوانەی تەورات خودا بپەرستن.»
\p 
\v 14 کە پۆڵس خەریک بوو دەمی بکاتەوە، گالیۆن بە جولەکەکانی گوت: «جولەکەکان، ئەگەر بابەتەکە ناڕەوایی یان تاوانێکی خراپ بووایە، وەک هۆیەک گوێم لە سکاڵاتان دەگرت.
\v 15 بەڵام ئەگەر بابەتەکە لەسەر وشە و ناو و تەوراتتانە، خۆتان تەماشای بکەن. نامەوێت لەم بابەتانەدا ببمە دادوەر.»
\v 16 ئیتر لە دادگا دەریکردن.
\v 17 ئیتر هەموو خەڵک سۆستانیسی پێشەوای کەنیشتیان گرت و لەبەردەم دادگا لێیاندا، گالیۆنیش گوێی بەمە نەدا.
\s1 گەڕانەوەی پۆڵس بۆ ئەنتاکیا
\p 
\v 18 پۆڵس ڕۆژانێکی زۆر مایەوە، ئینجا ماڵئاوایی لە برایان کرد و لەگەڵ پریسکیلا و ئەکیلا بە دەریادا بەرەو سوریا ڕۆیشت. پاشان لە کەنخریا سەری تاشی، چونکە نەزری لەسەر بوو.
\v 19 کاتێک گەیشتنە ئەفەسۆس، پۆڵس پریسکیلا و ئەکیلای لەوێ بەجێهێشت و خۆی چووە کەنیشت و لەگەڵ جولەکەکان دەستی بە گفتوگۆ کرد.
\v 20 ئەوانیش داوایان لێکرد ماوەیەکی زیاتر لایان بمێنێتەوە، بەڵام ڕازی نەبوو.
\v 21 ئیتر ماڵئاوایی لێکردن و گوتی: «خودا حەز بکات دەگەڕێمەوە بۆ لاتان.» ئینجا لە ئەفەسۆسەوە بە دەریادا ڕۆیشت.
\v 22 لە بەندەری قەیسەرییە دابەزی، بەرەو ئۆرشەلیم سەرکەوت و سڵاوی لە کڵێسا کرد، ئینجا بەرەو خوار چوو بۆ ئەنتاکیا.
\p 
\v 23 پۆڵس ماوەیەک لە ئەنتاکیا مایەوە و پاشان ڕۆیشت و لە ناوچەکانی گەلاتیا و فریجیا شوێن بە شوێن دەگەڕا، ورەی هەموو قوتابییەکانی بەرز دەکردەوە.
\p 
\v 24 جولەکەیەکی خەڵکی ئەسکەندەریە بە ناوی ئەپۆلۆس هات بۆ ئەفەسۆس، زمان پاراو و لە نووسراوە پیرۆزەکان شارەزا بوو.
\v 25 فێری ڕێگای مەسیحی خاوەن شکۆ کرابوو، بە دڵگەرمی دەدوا و بە دروستی خەڵکی فێری پەیامی عیسا دەکرد، هەرچەندە تەنها لەئاوهەڵکێشانەکەی یەحیای دەزانی.
\v 26 بە چاونەترسییەوە دەستی کرد بە قسەکردن لە کەنیشت. کە پریسکیلا و ئەکیلا گوێیان لێی بوو، بانگهێشتی ماڵی خۆیان کرد و دروستتر ڕێگای خودایان بۆ ڕوونکردەوە.
\p 
\v 27 کاتێک ئەپۆلۆس حەزی کرد بچێت بۆ ناوچەی ئەخایا، برایان هانیان دا و بۆ قوتابییەکانیان نووسی پێشوازیی لێ بکەن. کاتێک هاتە ئەوێ، یارمەتییەکی زۆری ئەوانەی دا کە بەهۆی نیعمەتی خوداوە باوەڕیان هێنابوو،
\v 28 چونکە بە هێزەوە و بە گفتوگۆی ئاشکرا جولەکە بەرهەڵستکارەکانی بێدەنگ دەکرد، لە ڕێگەی نووسراوە پیرۆزەکانەوە دەیسەلماند کە عیسا مەسیحەکەیە.
\c 19
\s1 پۆڵس لە ئەفەسۆس
\p 
\v 1 لە کاتێکدا کە ئەپۆلۆس لە کۆرنسۆس بوو، پۆڵس بە ڕێگاکانی ناوەوە تێپەڕی و هاتە ئەفەسۆس. لەوێ چاوی بە هەندێک قوتابی کەوت،
\v 2 لێی پرسین: «کاتێک باوەڕتان هێنا، ڕۆحی پیرۆزتان وەرگرت؟»
\p کەچی وەڵامیان دایەوە: «نەخێر! تەنانەت نەمانبیستووە کە ڕۆحی پیرۆز هەیە!»
\p 
\v 3 گوتی: «کەواتە چ جۆرە لە ئاو هەڵکێشانێکتان وەرگرتووە؟»
\p گوتیان: «لەئاوهەڵکێشانەکەی یەحیا.»
\p 
\v 4 پۆڵس گوتی: «لەئاوهەڵکێشانەکەی یەحیا لەئاوهەڵکێشانی تۆبەکردن بوو، بە خەڵکی دەگوت باوەڕ بهێنن بەوەی لەدوای دێت، واتا بە عیسا.»
\v 5 کاتێک ئەمەیان بیست بە ناوی عیسای خاوەن شکۆوە لە ئاو هەڵکێشران.
\v 6 جا پۆڵس دەستی لەسەر دانان، ڕۆحی پیرۆز هاتە سەریان، بە زمانی ڕۆحی دوان و پێشبینییان کرد.
\v 7 بە هەموویان نزیکەی دوازدە پیاو دەبوون.
\p 
\v 8 ئینجا پۆڵس چووە کەنیشت و بۆ زیاتر لە سێ مانگ ئازایانە دەدوا، گفتوگۆی دەکرد و سەبارەت بە کاروباری شانشینی خودا قەناعەتی بە خەڵک دەهێنا.
\v 9 بەڵام هەندێک کەللەڕەقییان کرد و باوەڕیان نەهێنا، لەبەردەم خەڵکەکە جنێویان بە ڕێگاکە\f + \fr 19:9 \ft ڕێگای پاشایەتی عیسا، بڕوانە \xt کردار 24‏:14‏\xt*\ft ‏.‏\f* دا. جا پۆڵس لێیان کشایەوە و قوتابییەکانی برد، ڕۆژانە لە قوتابخانەی تیرانۆس گفتوگۆی دەکرد.
\v 10 بۆ ماوەی دوو ساڵ لەسەر ئەمە بەردەوام بوو، هەتا وای لێهات هەموو ئەوانەی لە ئاسیادا دانیشتبوون، جولەکە و یۆنانی، پەیامی مەسیحی خاوەن شکۆیان بیست.
\p 
\v 11 خوداش پەرجووی سەرسوڕهێنەری بە دەستی پۆڵس ئەنجام دەدا،
\v 12 تەنانەت ئەو دەستەسڕ و بەروانکانەش کە بەر لەشی پۆڵس کەوتبوون، دەهێنران و دەخرانە سەر نەخۆش و نەخۆشییەکەیان نەدەما و ڕۆحە پیسەکان لە لەشیان دەردەچوون.
\s1 کوڕانی سکاوا
\p 
\v 13 هەندێک لەو جولەکە گەڕۆکانەی ڕۆحی پیسیان دەردەکرد، هەوڵیان دا ناوی عیسای خاوەن شکۆ بۆ ئەوانە بەکاربهێنن کە ڕۆحی پیسیان تێدایە، دەیانگوت: «بە ناوی عیسا، ئەوەی پۆڵس ڕایدەگەیەنێت، فەرمانت پێ دەکەم، دەربچیت.»
\v 14 سکاوا کە کاهینێکی باڵای جولەکە بوو، حەوت کوڕی ئەم کارەیان دەکرد.
\v 15 ڕۆحە پیسەکەش وەڵامی دانەوە: «عیسا دەناسم و دەربارەی پۆڵسیش دەزانم، بەڵام ئێوە کێن؟»
\v 16 ئینجا ئەو پیاوەی کە ڕۆحە پیسەکەی تێدابوو پەلاماری دان و بەسەر هەموویاندا زاڵبوو، بە جۆرێک لێیدان کە بە ڕووتی و بریندارییەوە لەو ماڵەی کە لێی بوون ڕایانکرد.
\p 
\v 17 کاتێک ئەو جولەکە و یۆنانییانەی کە لە ئەفەسۆس دەژیان بەمەیان زانی، هەموو ترس دایگرتن و ناوی عیسای خاوەن شکۆ بەرزبووەوە.
\v 18 هەروەها زۆر لەوانەی باوەڕیان هێنا، دەهاتن و بە ئاشکرا دانیان بە کردەوەکانیاندا دەنا.
\v 19 ژمارەیەک لەوانەی خەریکی جادووگەریێتی بوون، پەڕتووکەکانیان کۆدەکردەوە و لەبەردەم هەموواندا دەیانسووتاندن. نرخەکانیان هەژمارد کرد، بینییان پەنجا هەزار پارچە زیوە\f + \fr 19:19 \ft هەر پارچە زیوێک نزیکەی ڕۆژانەی کرێکارێک بووە.‏\f*.
\v 20 بەم شێوەیە پەیامی مەسیحی خاوەن شکۆ بە تواناوە گەشەی دەکرد و بەهێز دەبوو.
\s1 شڵەژانێکی ترسناک لە ئەفەسۆس
\p 
\v 21 لەدوای ئەوەی ئەم شتانە ڕوویاندا، پۆڵس بڕیاری دا بە مەکدۆنیا و ئەخایادا تێبپەڕێت و بچێتە ئۆرشەلیم، گوتی: «پاش ئەوەی لەوێ دەبم، دەبێت ڕۆماش ببینم.»
\v 22 جا پۆڵس دووان لە یاریدەدەرەکانی نارد بۆ مەکدۆنیا کە تیمۆساوس‏ و ئەراستۆس بوون، خۆشی ماوەیەک لە‏ هەرێمی ئاسیا مایەوە.
\p 
\v 23 لەو کاتەدا لەبەر ڕێگاکە\f + \fr 19:23 \ft ڕێگای پاشایەتی عیسا، بڕوانە \xt کردار 24‏:14‏\xt*\ft ‏.‏\f* ئاژاوەیەکی گەورە سەریهەڵدا.
\v 24 لەوێ زیوگەرێک بە ناوی دیمیتریۆس هەبوو کە پەرستگای بچووکی زیوینی ئەرتەمیسی دروستدەکرد و قازانجێکی باشی هەبوو بۆ پیشەوەران.
\v 25 ئیتر کرێکارەکانی خۆی و هاوپیشەکانی کۆکردەوە و گوتی: «کوڕینە، هەروەک دەزانن لەم پیشەیەوە داهاتێکی باشمان دەستدەکەوێت،
\v 26 بینیوتانە و بیستووتانە کە نەک تەنها لە ئەفەسۆس، بگرە لە هەموو ئاسیا، ئەم پۆڵسە قەناعەتی بە خەڵکێکی زۆر هێناوە و لەڕێ لایداون، دەڵێت ئەوانەی دەستکردن خودا نین.
\v 27 نەک تەنها ئیشەکەمان دەکەوێتە مەترسییەوە بەڵکو پەرستگاکەی ئەرتەمیسی خواژنی گەورەش هیچ بەهایەکی نامێنێت، ئەوەی هەموو ئاسیا و جیهان دەیپەرستن پایەبەرزییەکەی لەدەست دەدات.»
\p 
\v 28 کاتێک گوێیان لێبوو تووڕە بوون و هاواریان دەکرد: «پایە بەرزە ئەرتەمیسی ئەفەسۆسییەکان!»
\v 29 ئەم شڵەژانە هەموو شارەکەی گرتەوە، خەڵکەکە گایۆس و ئەریستارخۆسی مەکدۆنییان ڕاکێشایە ناو گۆڕەپانی شانۆی شار، کە هاوڕێی پۆڵس بوون لە گەشتەکەیدا.
\v 30 پۆڵس ویستی بچێتە ناو خەڵکەکە، بەڵام قوتابییەکان نەیانهێشت.
\v 31 هەروەها هەندێک گەورە پیاوی ئاسیا کە دۆستی بوون، پەیامیان بۆ نارد و لێی پاڕانەوە کە نەچێتە شانۆکە.
\p 
\v 32 ئیتر هەندێک هاواری شتێکیان دەکرد و هەندێک شتێکی دیکە، چونکە کۆڕەکە\f + \fr 19:32 \ft یۆنانی: \tl ئێکلێسیا‏\tl*: کڵێسا.‏\f* شێوا بوو، زۆربەشیان نەیاندەزانی بۆچی کۆبوونەتەوە.
\v 33 ئینجا جولەکەکان بۆ پێشەوە پاڵیان بە ئەسکەندەرەوە دەنا، هەندێک لەو خەڵکە هۆکاری ئەو ئاژاوەیان بۆ ئەو دەگەڕاندەوە. ئەویش دەستی بەرزکردەوە و دەیویست لەبەردەم خەڵکەکە بەرگری لە خۆی بکات.
\v 34 بەڵام کە زانییان جولەکەیە، نزیکەی دوو کاتژمێر هەموویان بەیەکەوە هاواریان دەکرد: «پایە بەرزە ئەرتەمیسی ئەفەسۆسییەکان!»
\p 
\v 35 ئینجا فەرمانڕەوای شارەکە خەڵکەکەی هێمن کردەوە و گوتی: «پیاوانی ئەفەسۆس، کێ هەیە نەزانێت کە شاری ئەفەسۆسییەکان پاسەوانی پەرستگای ئەرتەمیسی گەورە و ئەو پەیکەرەیە کە لە ئاسمانەوە کەوتە خوارەوە؟
\v 36 بۆیە کە ئەمانە نکۆڵییان لێ ناکرێت، پێویستە هێمن بنەوە و هیچ شتێک بە سەرەڕۆیی نەکەن.
\v 37 ئێوە ئەم دوو پیاوەتان هێناوە، کە نە پەرستگایان بڕیوە نە کفریان سەبارەت بە خواژنەکەمان کردووە.
\v 38 بەڵام ئەگەر دیمیتریۆس و ئەو پیشەوەرانەی کە لەگەڵ ئەون سکاڵایان لە کەسێک هەیە، ئەوا دادگاکان کراونەتەوە و دادوەر هەیە، با سکاڵا لە یەکتری بکەن.
\v 39 ئەگەر داوای شتێکی دیکەش دەکەن، ئەوا لە کۆڕی یاساییدا سەیر دەکرێت.
\v 40 لە ڕاستیدا لە مەترسیداین بەوەی کە تاوانبار بکرێن بە ئاژاوەنانەوە، لەبەر ئەوەی ئەمڕۆ، هیچ پاساوێکمان نییە بۆ پاکانەی ئەم کۆبوونەوەیە.»
\v 41 کە ئەم شتانەی گوت، کۆمەڵەکەی\f + \fr 19:41 \ft یۆنانی: \tl ئێکلێسیا‏\tl*: کڵێسا.‏\f* بڵاوە پێکرد.
\c 20
\s1 پۆڵس لە مەکدۆنیا و یۆنان
\p 
\v 1 دوای نەمانی ئاژاوەکە، پۆڵس قوتابییەکانی بانگکرد و ورەی بەرزکردنەوە، ماڵئاوایی لێکردن و بەرەو مەکدۆنیا بەڕێکەوت.
\v 2 کاتێک بەو ناوچانەدا تێپەڕی، بە زۆر وشە ورەی باوەڕدارانی بەرز کردەوە. لە کۆتاییدا گەیشتە یۆنان
\v 3 و سێ مانگی لەوێ بەسەربرد. کاتێک بەتەمابوو بە دەریادا بچێتە سوریا، جولەکە پیلانیان بۆی گێڕا، بۆیە بڕیاری دا بە مەکدۆنیادا بگەڕێتەوە.
\v 4 ئەم کەسانەی لەگەڵ بوو: لە بیریە سوپاترۆسی کوڕی پیڕۆس، لە سالۆنیکییان ئەریستارخۆس و سەکوندۆس، گایۆس لە دەربە و تیمۆساوس، لە ئاسیاش تیخیکۆس و تروفیمۆس.
\v 5 ئەمانە پێشمان کەوتن و لە ترۆئاس چاوەڕێیان دەکردین.
\v 6 بەڵام ئێمە دوای جەژنی فەتیرە، سواری کەشتی بووین و فیلیپیمان بەجێهێشت، پاش گەشتی پێنج ڕۆژ گەیشتینە بەندەری ترۆئاس، لەوێ بەوانەی دیکە شاد بووینەوە و حەوت ڕۆژ لەوێ ماینەوە.
\s1 پۆڵس لە ترۆئاس
\p 
\v 7 لە یەکەم ڕۆژی هەفتەدا بۆ نانلەتکردن کۆبووینەوە. پۆڵس گفتوگۆی لەگەڵ خەڵک دەکرد، چونکە بەتەمابوو ڕۆژی دواتر بڕوات، بۆیە هەتا نیوە شەو قسەی بۆ کردن.
\v 8 ئەو ژوورەی سەرەوە کە لێی کۆببووینەوە چرای زۆری لێبوو.
\v 9 گەنجێک ناوی یوتیخۆس بوو لەناو پەنجەرەدا دانیشتبوو، خەوەکوتکێیەکی قورس دەیبردەوە، پۆڵس وتارێکی درێژی دەدا، جا خەوی لێ کەوت و لە نهۆمی سێیەمەوە کەوتە خوارەوە، بە مردوویی هەڵگیرایەوە.
\v 10 پۆڵس هاتە خوارەوە خۆی بەسەریدا دا و لە باوەشی گرت و گوتی: «مەشێوێن، ژیانی تێدایە!»
\v 11 دوایی پۆڵس چووە سەرەوە، نانی لەتکرد و خواردی، هەتا بەرەبەیان قسەی کرد، پاشان لەوێ ڕۆیشت.
\v 12 گەنجەکەشیان بە زیندووێتی برد و زۆر دڵنەوایی کران.
\s1 لە تروئاسەوە بۆ میلیتۆس
\p 
\v 13 پۆڵس بە ڕێگای وشکانی چوو بۆ ئەسۆس، ئێمەش بە سواری کەشتی بەرەو ئەوێ بەڕێکەوتین، چونکە بڕیاری دابوو کە لەوێ چاومان پێی بکەوێت.
\v 14 کاتێک لە ئەسۆس تووشمان بوو، هەڵمانگرت و هاتینە میتیلینی.
\v 15 لەوێش بە دەریادا ڕۆیشتین و بۆ بەیانی گەیشتینە بەرامبەر خیۆس، بۆ ڕۆژی دواتر گەیشتینە سامۆس، ڕۆژی دوای ئەوەش هاتینە میلیتۆس.
\v 16 جا پۆڵس بڕیاری دابوو کە ئەفەسۆس بەجێبهێڵێت نەوەک ماوەیەک لە ئاسیادا بمێنێتەوە، چونکە پەلەی دەکرد، بەڵکو بتوانێت لە ڕۆژی پەنجایەمین بگاتە ئۆرشەلیم.
\s1 وتەی پۆڵس بۆ پیرانی ئەفەسۆس
\p 
\v 17 پۆڵس لە میلیتۆسەوە ناردی بۆ ئەفەسۆس، بانگی پیرانی کڵێسای کرد.
\v 18 کاتێک هاتنە لای، پێی گوتن: «ئێوە دەزانن لە یەکەم ڕۆژەوە کە پێم خستە ناو ئاسیا، بە درێژایی ئەو کاتەی کە لەگەڵتان بووم، چۆن ژیام.
\v 19 لە کاتێکدا کە بە پیلانی جولەکە بەرهەڵستکارەکان تووشی تاقیکردنەوەی سەخت بووم، بەوپەڕی بێفیزی و فرمێسکەوە خزمەتی عیسای خاوەن شکۆم دەکرد.
\v 20 هیچم لەو شتانە دوانەخستووە کە سوودبەخشن و بۆم ڕاگەیاندوون، بە ئاشکرا و ماڵەوماڵ فێرم کردوون.
\v 21 شایەتی ئەوەم داوە لای جولەکە و یۆنانییەکان کە دەبێت تۆبە بکەن و بۆ لای خودا بگەڕێنەوە و باوەڕ بە عیسای خاوەن شکۆمان بهێنن.
\p 
\v 22 «ئەوەتا ئێستا وا بە ڕۆحی پیرۆز بەستراوم، دەچمە ئۆرشەلیم و نازانم چیم بەسەردێت.
\v 23 تەنها ڕۆحی پیرۆز لە هەموو شارێک شایەتیم بۆ دەدات کە گرتن و ناخۆشی چاوەڕێم دەکات.
\v 24 بەڵام هیچ بەهایەکم بۆ ژیانی خۆم دانەناوە، تەنها ئامانجم ئەوەیە، ئەو پێشبرکێیە تەواو بکەم و ئەو ئەرکە بەجێبگەیەنم کە عیسای خاوەن شکۆ بە منی سپارد، ئەویش ئەرکی شایەتیدانە بۆ مزگێنیی نیعمەتی خودا.
\p 
\v 25 «ئێستا دەزانم هیچکام لە ئێوە ئیتر ڕووم نابیننەوە کە بە ناوتاندا دەگەڕام و پاشایەتی خودام ڕادەگەیاند.
\v 26 هەر بۆیە ئەمڕۆ شایەتیتان بۆ دەدەم، کە لە خوێنی هەمووان بێتاوانم،
\v 27 چونکە لە ڕاگەیاندنی تەواوی خواستی خودا بۆتان دوانەکەوتم.
\v 28 ئاگاتان لە خۆتان و لە هەموو مێگەلەکە بێت، کە ڕۆحی پیرۆز ئێوەی کردووە بە چاودێر بەسەریانەوە. شوانایەتی کڵێسای خودا بکەن، کە بە خوێنی خۆی\f + \fr 20:28 \ft خوێنی مەسیح.‏\f* کڕیویەتی.
\v 29 دەزانم پاش ڕۆیشتنم گورگی ڕفێنەر دێنە ناوتان، بەزەییان بە مێگەلەکە نایەتەوە.
\v 30 هەروەها لەنێو خۆتاندا خەڵکانێک پەیدا دەبن کە ڕاستیی دەشێوێنن، تاکو قوتابییەکان بەلای خۆیاندا ڕابکێشن.
\v 31 بۆیە ئێشک بگرن، لە بیرتان بێت بۆ ماوەی سێ ساڵ شەو و ڕۆژ بە فرمێسکەوە نەوەستاوم لە ئاگادارکردنەوەی هەر یەکێکتان.
\p 
\v 32 «ئێستاش بە خودا و وشەی نیعمەتەکەیتان دەسپێرم، کە توانای هەیە بنیادتان بنێت و لەگەڵ هەموو ئەوانەی پیرۆزکراون میراتتان پێ ببەخشێت.
\v 33 چاوم لە زێڕ و زیو و جلی کەس نەبوو.
\v 34 خۆتان دەزانن پێویستی خۆم و یاوەرانم، ئەم دەستانە دابینیان کردووە.
\v 35 هەموو شتێکم پیشانتاندا کە پێویستە چۆن ڕەنج بدەن بۆ یارمەتیدانی لاوازان، وشەکانی عیسای خاوەن شکۆتان لەیاد بێت کە خۆی فەرمووی: ”بەخشین لە وەرگرتن بەختەوەریترە.“»
\p 
\v 36 کاتێک پۆڵس قسەکانی تەواو کرد، لەگەڵ هەموویان چۆکی دادا و نوێژی کرد.
\v 37 هەمووان زۆر گریان، باوەشیان کردبوو بە پۆڵسدا و ماچیان دەکرد،
\v 38 بەو قسەی کردی خەمبار بوون کە گوتی جارێکی دیکە ڕووی نابیننەوە. ئینجا تاکو لای کەشتییەکە لەگەڵی ڕۆیشتن.
\c 21
\s1 پێشبینییەکان دەربارەی ئازاری پۆڵس
\p 
\v 1 کاتێک لێیان جیا بووینەوە، بە دەریادا ڕێک بەرەو کووس\f + \fr 21:1 \ft کووس و ڕودس دوو دوورگەن لە دەریای سپی ناوەڕاست.‏\f* ڕۆیشتین. ڕۆژی پاشتر بۆ ڕودس لەوێشەوە بۆ پەتارا.
\v 2 لەوێ کەشتییەکمان بینی دەچووە فینیکیا، سواربووین و ڕۆیشتین.
\v 3 ئینجا قوبرسمان بینی و بەلای چەپدا بەجێمان هێشت، بەرەو سوریا دەچووین و گەیشتینە سور، چونکە کەشتییەکە بارەکەی لەوێ دادەگرت.
\v 4 لەوێ قوتابییەکانمان دۆزییەوە و حەوت ڕۆژ ماینەوە. بە ڕێنمایی ڕۆحی پیرۆز تکایان لە پۆڵس کرد کە نەچێتە ئۆرشەلیم.
\v 5 کاتێک ماوەمان تەواو بوو، بەڕێکەوتین بۆ ئەوەی درێژە بە گەشتەکەمان بدەین، هەموو قوتابییەکان هەتا دەرەوەی شار بە ژن و منداڵیانەوە لەگەڵمان هاتن. لە کەناراوەکە چۆکمان دادا و نوێژمان کرد.
\v 6 پاشان ماڵئاواییمان لە یەکتری کرد و سواری کەشتییەکە بووین، ئەوانیش گەڕانەوە ماڵەکانیان.
\p 
\v 7 لە سورەوە بەردەوام بووین لە گەشتەکەمان و گەیشتینە پتولمایس، لەوێ سڵاومان لە خوشک و برایان کرد و ڕۆژێک لەلایان ماینەوە.
\v 8 بۆ بەیانی هاتینە قەیسەرییە و چووینە ماڵی فیلیپۆسی مزگێنیدەر، کە یەکێکە لە حەوتەکە\f + \fr 21:8 \ft بڕوانە 6‏:1‏-6‏\f*، لەلای ماینەوە.
\v 9 فیلیپۆس چوار کچی پاکیزەی هەبوو پێشبینییان دەکرد.
\p 
\v 10 کە چەندین ڕۆژ ماینەوە، پێغەمبەرێک بە ناوی ئاگابۆس لە یەهودیاوە هات.
\v 11 هاتە لامان و پشتێنەکەی پۆڵسی برد، دەست و پێی خۆی بەستەوە و گوتی: «ڕۆحی پیرۆز ئەمە دەفەرموێ: ”ڕابەرانی جولەکە بەم شێوەیە خاوەنی ئەم پشتێنە لە ئۆرشەلیم دەبەستنەوە و دەیدەنە دەست ناجولەکەکان.“»
\p 
\v 12 کاتێک ئەمەمان بیست، ئێمە و دانیشتووانی ئەوێ، لە پۆڵس پاڕاینەوە نەچێتە ئۆرشەلیم.
\v 13 بەڵام پۆڵس گوتی: «چیتانە، دەگریێن و دڵم دەشکێنن؟ ئامادەم نەک تەنها بەند بکرێم، بەڵکو بۆ ناوی عیسای خاوەن شکۆ لە ئۆرشەلیم بشمرم.»
\v 14 کە پێمان قایل نەکرا، وازمان لێهێنا و گوتمان: «با بە خواستی مەسیحی خاوەن شکۆ بێت.»
\p 
\v 15 دوای ئەو ڕۆژانە ئامادەکاریمان کرد و چووینە ئۆرشەلیم.
\v 16 هەندێک قوتابی قەیسەرییەش لەگەڵمان هاتن و ئێمەیان بردە لای مەناسۆن، کە قوبرسییە و قوتابییەکی کۆنە، تاکو لەلای بمێنینەوە.
\s1 لە ئۆرشەلیم
\p 
\v 17 کاتێک گەیشتینە ئۆرشەلیم، برایان بە خۆشییەوە پێشوازییان لێکردین.
\v 18 ڕۆژێک دواتر پۆڵس لەگەڵمان هاتە لای یاقوب\f + \fr 21:18 \ft برای مەسیح، بڕوانە \xt گەلاتیا 1‏:19‏\xt*\ft ‏\f*، هەموو پیرانیش ئامادەبوون.
\v 19 پۆڵس سڵاوی لێکردن و یەک بە یەکی ئەوەی پێ ڕاگەیاندن کە خودا لەنێو ناجولەکەکاندا لە ڕێگەی خزمەتەکەیەوە کردوویەتی.
\p 
\v 20 کە گوێیان لێبوو، ستایشی خودایان کرد و پێیان گوت: «برا دەبینیت کە هەزاران کەس لەناو جولەکەدا باوەڕیان هێناوە و هەموو دڵگەرمی تەوراتن.
\v 21 ئاگادار کراونەتەوە کە تۆ هەموو جولەکەکانی نێو نەتەوەکان فێری هەڵگەڕانەوە لە تەوراتی موسا دەکەیت و پێیان دەڵێی منداڵەکانیان خەتەنە نەکەن و بەگوێرەی نەریت نەژین.
\v 22 کەواتە چی بکرێت؟ بێگومان دەبیستن کە تۆ هاتوویت،
\v 23 جا ئەوە بکە کە پێت دەڵێین: چوار پیاومان لەلایە نەزریان لەسەرە،
\v 24 بیانبە و لەگەڵیان خۆت پاک بکەرەوە و نرخی سەرتاشینەکەیان بۆ بدە، ئەوسا هەموو دەزانن ئەوەی دەربارەی تۆ پێیان گوتراوە ڕاست نییە و تۆش بەپێی تەورات دەڕۆیت.
\v 25 دەربارەی ناجولەکەکانیش کە باوەڕیان هێناوە، نامەیەکمان ناردووە و فەرمانمان کرد خۆیان لە قوربانی بت و لە خوێن، لە گۆشتی ئاژەڵی خنکێنراو و لە داوێنپیسی بپارێزن.»
\p 
\v 26 بۆ بەیانی پۆڵس پیاوەکانی برد و لەگەڵیان ڕێوڕەسمی پاکبوونەوەی ئەنجام دا، پاشان چووە ناو پەرستگا بۆ ئەوەی کۆتایی هاتنی ڕۆژانی پاکبوونەوە ڕابگەیەنێت و بۆ هەر یەکێکیشیان قوربانیی بکات.
\s1 گرتنی پۆڵس
\p 
\v 27 کاتێک حەوت ڕۆژەکە بەرەو تەواوبوون دەچوو، جولەکەی ئاسیا پۆڵسیان لەناو پەرستگا بینی، جا هەموو خەڵکەکەیان جۆشدا و گرتییان،
\v 28 هاواریان دەکرد: «خەڵکی ئیسرائیل فریابکەون! ئەمە ئەو پیاوەیە کە لە هەموو شوێنێک لە دژی گەل و تەورات و ئەم شوێنە هەموو خەڵک فێردەکات، تەنانەت یۆنانیشی هێناوەتە ناو پەرستگا و ئەم شوێنە پیرۆزەی گڵاو کردووە!»
\v 29 لەبەر ئەوەی تروفیمۆسی خەڵکی ئەفەسۆسییان لە شارەکەدا لەگەڵی بینیبوو، وایاندەزانی پۆڵس لەگەڵ خۆی هێناویەتییە ناو پەرستگا.
\p 
\v 30 ئینجا هەموو شارەکە وروژا، خەڵکەکەش لە هەموو لایەکەوە ڕایانکرد. پۆڵسیان گرت، ڕایانکێشایە دەرەوەی پەرستگا، دەستبەجێ دەرگاکان داخران.
\v 31 کاتێک هەوڵی کوشتنیان دەدا، هەواڵ بە فەرماندەی هێز درا کە هەموو ئۆرشەلیم شڵەژاوە.
\v 32 یەکسەر سەرباز و سەرپەلی برد و ڕایکردە لایان. کاتێک فەرماندە و سەربازەکانیان بینی، لە لێدانی پۆڵس وەستان.
\p 
\v 33 ئیتر فەرماندەکە نزیک بووەوە و گرتی، فەرمانی دا بە دوو زنجیر بیبەستنەوە، ئینجا پرسیاری کرد ئاخۆ کێیە و چی کردووە.
\v 34 بەڵام خەڵکەکە هەندێکیان بە دەنگی بەرز شتێکیان دەگوت و هەندێکی دیکەشیان شتێکی دیکە. ئینجا بەهۆی ئاژاوەکەوە نەیتوانی ڕاستییەکە بزانێت، فەرمانی دا پۆڵس ببردرێتە سەربازگە.
\v 35 کاتێک لەسەر قاڵدرمەکان\f + \fr 21:35 \ft پێپلیکانە‏\f* بوو، لەبەر توندوتیژی خەڵکەکە سەرباز هەڵیانگرت،
\v 36 چونکە ئەو خەڵکەی کە دوای کەوتبوون هاواریان دەکرد: «لە ناوی ببە!»
\p 
\v 37 پێش ئەوەی پۆڵس بگەیەنرێتە ناو سەربازگەکە، بە فەرماندەکەی گوت: «دەتوانم شتێکت پێ بڵێم؟» گوتی: «یۆنانی دەزانیت؟
\v 38 تۆ ئەو پیاوە میسرییە نیت کە ماوەیەک لەمەوبەر ئاژاوەیەکی نایەوە و فەرماندەیی چوار هەزار پیاوکوژی کرد بەرەو بیابان؟»
\p 
\v 39 پۆڵس گوتی: «من جولەکەم، خەڵکی تەرسۆسی کیلیکیا، هاوڵاتی شارێکی بچووک نیم. داوات لێ دەکەم ڕێگام بدەی قسە بۆ خەڵکەکە بکەم.»
\p 
\v 40 دوای ئەوەی کە فەرماندەکە ڕێگای قسەکردنی بە پۆڵس دا، لەسەر قاڵدرمەکان ڕاوەستا و بە دەست ئاماژەی بۆ خەڵکەکە کرد. کاتێک بێدەنگ بوون، بە زمانی عیبری قسەی بۆ کردن و گوتی:
\c 22
\s1 بەرگری پۆڵس
\p 
\v 1 «برایان و باوکان، ئێستا گوێ لەو بەرگرییە بگرن کە لە خۆمی دەکەم.»
\v 2 کاتێک گوێیان لێبوو بە زمانی عیبری قسەیان بۆ دەکات زیاتر بێدەنگ بوون.
\p ئەویش گوتی:
\v 3 «من جولەکەم، لە تەرسۆسی کیلیکیا لەدایک بووم، بەڵام لەم شارە گەورە بووم، لەبەردەستی\f + \fr 22:3 \ft یۆنانی: لەبەرپێی.‏\f* گەمالائیل بە باشی بەگوێرەی تەوراتی باوباپیرانمان فێرکراوم. زۆر دڵگەرم بووم بۆ خودا، وەک ئەمڕۆ هەر یەکێکتان.
\v 4 شوێنکەوتووانی ئەم ڕێگایەم هەتا مردن چەوساندەوە، ژن و پیاوم دەگرت و ڕادەستی زیندانم دەکردن،
\v 5 هەروەک سەرۆکی کاهینان و هەموو ئەنجومەنی پیران شایەتیم بۆ دەدەن. نامەم لەوان وەرگرت بۆ برایانی دیمەشق، چووم تاکو ئەوانەی ئەوێش بە بەندکراوی بهێنمە ئۆرشەلیم تاکو سزا بدرێن.
\p 
\v 6 «ئەوە بوو کاتێک دەڕۆیشتم و لە نیوەڕۆدا لە دیمەشق نزیک دەبوومەوە، لەناکاو لە ئاسمانەوە ڕووناکییەکی گەورە لە دەوروبەرم درەوشایەوە.
\v 7 کەوتمە سەر زەوی و گوێم لە دەنگێک بوو پێی فەرمووم: ”شاول! شاول! بۆچی دەمچەوسێنیتەوە؟“
\p 
\v 8 «وەڵامم دایەوە: ”گەورەم، تۆ کێیت؟“
\p «پێی فەرمووم: ”من عیسای ناسیرەییم، ئەوەی تۆ دەیچەوسێنیتەوە.“
\v 9 ئەوانەی لەگەڵم بوون ڕووناکییەکەیان بینی، بەڵام لەو دەنگە تێنەگەیشتن کە قسەی لەگەڵم دەکرد.
\p 
\v 10 «گوتم: ”ئەی خاوەن شکۆ، چی بکەم؟“»
\p «مەسیحی خاوەن شکۆ پێی فەرمووم: ”هەستە بڕۆ دیمەشق، لەوێ هەموو ئەو شتانەت پێ دەگوترێت کە دەبێت بیکەیت.“
\v 11 جا لەبەر هێزی ڕووناکییەکە نەمدەبینی، ئەوانەی لەگەڵم بوون دەستیان گرتم و هێنامیانە دیمەشق.
\p 
\v 12 «پیاوێک بە ناوی حەنانیا هات بۆ لام. ئەو کەسێکی لەخواترس و گوێڕایەڵی تەورات بوو، هەروەها هەموو جولەکەی ئەوێ بە باشی باسیان دەکرد.
\v 13 لەتەنیشتم وەستا و پێی گوتم: ”شاولی برام، ببینە.“ یەکسەر ئەوم بینی.
\p 
\v 14 «ئینجا گوتی: ”خودای باوباپیرانمان هەڵیبژاردووی تاکو خواستی بزانیت، هەروەها ڕاستودروستەکە\f + \fr 22:14 \ft مەبەست لە مەسیحە‏\f* ببینیت و گوێت لە وشەی دەمی ئەو بێت،
\v 15 چونکە تۆ بۆ هەموو خەڵک دەبیتە شایەتی ئەو، بەوەی بینیت و بیستت.
\v 16 ئێستا بۆ خۆت دوادەخەیت؟ هەستە لە ئاو هەڵبکێشرێ و بە پاڕانەوە بە ناوی ئەو گوناهەکانت بشۆرەوە.“
\p 
\v 17 «کاتێک گەڕابوومەوە بۆ ئۆرشەلیم و لە پەرستگا نوێژم دەکرد، لەهۆشی خۆم چووم،
\v 18 مەسیحم بینی و پێی فەرمووم: ”خێراکە و بە پەلە لە ئۆرشەلیم بڕۆ دەرەوە، چونکە شایەتییەکەت کە سەبارەت بە منە وەریناگرن.“
\p 
\v 19 «منیش گوتم: ”خاوەن شکۆ، خۆیان دەزانن لە هەموو کەنیشتەکان ئەوانەی باوەڕیان بە تۆ هەبوو، دەمگرتن و دارکاریم دەکردن.
\v 20 کاتێک خوێنی ستیفانۆسی شایەتی تۆ ڕژا، من ڕاوەستابووم، ڕازی بووم و پارێزگاریم لە جلوبەرگی بکوژانی دەکرد.“
\p 
\v 21 «بەڵام پێی فەرمووم: ”بڕۆ! بۆ شوێنی دوور دەتنێرم، بۆ لای ناجولەکەکان.“»
\p 
\v 22 هەتا باسی ناجولەکەکان گوێیان لە پۆڵس گرت، ئینجا هاواریان کرد و گوتیان: «لەسەر ڕووی زەوی مەیهێڵە! چونکە ئەمە شایانی ژیان نییە!»
\p 
\v 23 لە کاتێکدا هاواریان دەکرد و جلەکانی خۆیان فڕێدەدا و خۆڵیان بە هەوادا دەکرد،
\v 24 فەرماندەکە فەرمانی دا بۆ سەربازگە ببردرێت و لەژێر قامچیدا لێی بکۆڵنەوە، بۆ ئەوەی بزانێت بۆچی ئاوا هاواریان لێی دەکرد.
\s1 پۆڵس هاوڵاتییەکی ڕۆمانییە
\p 
\v 25 کاتێک بەستیانەوە تاکو بە قامچی لێی بدەن، پۆڵس بە سەرپەلەکەی گوت کە لەوێ وەستا بوو: «ئایا لە ڕووی یاساییەوە ڕێتان پێدراوە کە هاوڵاتیی ڕۆمانی بەر قامچی بدەن کە هێشتا نەسەلمێنراوە تاوانبارە؟»
\p 
\v 26 کاتێک سەرپەلەکە گوێی لەمە بوو، چووە لای فەرماندەکە و هەواڵی پێدا و گوتی: «ئەوە بەتەمای چی بکەیت؟ ئەم پیاوە هاوڵاتیی ڕۆمانییە!»
\p 
\v 27 فەرماندەکەش چوو بۆ لای پۆڵس و پێی گوت: «پێم بڵێ، تۆ هاوڵاتیی ڕۆمانیت؟»
\p گوتی: «بەڵێ.»
\p 
\v 28 فەرماندەکە گوتی: «بە پارەیەکی زۆر ئەم ڕەگەزنامەیەم وەرگرت.»
\p پۆڵس گوتی: «بەڵام من بە زگماک هاوڵاتیم.»
\p 
\v 29 ئەوانەی کە بەتەمابوون لێی بکۆڵنەوە، دەستبەجێ لێی دوور کەوتنەوە، فەرماندەکەش ترسا کە زانی هاوڵاتییەکی ڕۆمانیی کۆت کردووە.
\p 
\v 30 بۆ بەیانی فەرماندەکە ویستی بە تەواوی بزانێت بۆچی جولەکە تۆمەتباری دەکەن، بۆیە ئازادی کرد و فەرمانی دا کاهینانی باڵا و هەموو ئەندامانی ئەنجومەنی باڵای جولەکە\f + \fr 22:30 \ft ئەنجومەنی باڵای جولەکە کە لە یۆنانی پێی گوتراوە \tl سەنهەدرین‏\tl*، باڵاترین دەسەڵاتی جولەکە بووە کە دەسەڵاتی دەرکردنی بڕیاری ئایینی و شارستانی و تاوانبارکردنی هەبووە.‏\f* کۆببنەوە. ئینجا پۆڵسی بانگکرد و لەبەردەمیاندا ڕایگرت.
\c 23
\s1 پۆڵس لە ئەنجومەنی باڵای جولەکەدا
\p 
\v 1 پۆڵس ڕوانییە ئەنجومەنی باڵا و گوتی: «برایان، هەتا ئەمڕۆ بە تەواوی ویژدانێکی پاکەوە بۆ خودا ژیاوم.»
\v 2 لەو کاتەدا حەنانیای سەرۆکی کاهینان فەرمانی بەوانە دا کە لەلای ڕاوەستابوون تاکو بکێشن بە دەمیدا.
\v 3 پۆڵس پێی گوت: «خودا لێت بدات، ئەی دیواری سپیکراو! چۆن دانیشتووی بەپێی تەورات حوکمم دەدەیت، کەچی پێچەوانەی تەورات فەرمانی لێدانم دەدەیت؟»
\p 
\v 4 ئەوانەی لەلای ڕاوەستابوون گوتیان: «ئایا جنێو بە سەرۆکی کاهینانی خودا دەدەیت؟»
\p 
\v 5 پۆڵس گوتی: «برایان، نەمدەزانی سەرۆکی کاهینانە، چونکە نووسراوە: ﴿بە خراپە باسی سەرکردەی گەلەکەت مەکە.﴾\f + \fr 23:5 \ft \xt دەرچوون 22‏:28‏\xt*\ft ‏\f*»
\p 
\v 6 پۆڵس کە دەیزانی بەشێک لە ئەندامانی ئەنجومەنەکە سەدوقین و بەشێکی دیکەش فەریسی، هاواری کرد و گوتی: «برایان، من فەریسی کوڕی فەریسیم. لەبەر هیوام بە هەستانەوەی مردووان وا حوکم دەدرێم.»
\v 7 کە ئەمەی گوت، ناکۆکی کەوتە نێوان فەریسی و سەدوقییەکان و ئەنجومەنەکە بوو بە دوو بەش،
\v 8 چونکە سەدوقییەکان دەڵێن هەستانەوە و فریشتە و ڕۆح نین، بەڵام فەریسییەکان دان بە هەموو ئەمانەدا دەنێن.
\p 
\v 9 ئینجا هاوار بەرزبووەوە و هەندێک لە مامۆستایانی تەورات کە فەریسی بوون، هەستان و بە توندی ناڕەزاییان دەربڕی و گوتیان: «تاوان لەم پیاوەدا نابینین. ئەی ئەگەر ڕۆحێک یان فریشتەیەک لەگەڵیدا دوابێت؟»
\v 10 کاتێک ناکۆکییەکە پەرەی سەند، فەرماندەکە ترسا پۆڵس پارچەپارچە بکەن، بۆیە فەرمانی بە سەربازەکان دا دابەزن، لەنێوانیاندا بیڕفێنن و بیبەنەوە سەربازگە.
\p 
\v 11 بۆ شەوی پاشتر، مەسیحی خاوەن شکۆ لەلای پۆڵس ڕاوەستا و فەرمووی: «ورەت بەرزبێت! وەک لە ئۆرشەلیم شایەتیت بۆ من دا، دەبێ لە ڕۆماش ئاوا شایەتی بدەیت.»
\s1 پیلانی جولەکە بۆ کوشتنی پۆڵس
\p 
\v 12 کاتێک ڕۆژ هەڵات جولەکە پیلانیان کێشا، سوێندیان خوارد و گوتیان کە نە بخۆن و نە بخۆنەوە هەتا پۆڵس دەکوژن.
\v 13 ئەوانەی ئەم پیلانەیان کێشا لە چل پیاو زیاتر بوون.
\v 14 چوونە لای کاهینانی باڵا و پیران و گوتیان: «سوێندمان خواردووە تامی هیچ نەکەین هەتا پۆڵس دەکوژین.
\v 15 ئێستاش ئێوە و ئەنجومەنی باڵا بە فەرماندەکە ڕابگەیەنن، وەک ئەوەی بتانەوێت وردتر لە بابەتەکەی بکۆڵنەوە، پێویستە بیهێنێت بۆ لاتان. ئێمەش ئامادەین بۆ کوشتنی، پێش ئەوەی بگاتە لای ئەنجومەن.»
\p 
\v 16 بەڵام کاتێک خوشکەزاکەی پۆڵس بە پیلانەکەی زانی، هاتە سەربازگە و هەواڵی دایە پۆڵس.
\p 
\v 17 جا پۆڵس سەرپەلێکی بانگکرد و گوتی: «ئەم گەنجە ببە لای فەرماندەکە، چونکە هەواڵێکی پێیە بیداتێ.»
\v 18 ئەویش بردییە لای فەرماندەکە.
\p گوتی: «پۆڵسی بەندکراو بانگی کردم و داوای لێکردم ئەم گەنجە بهێنمە لات، شتێکی هەیە پێتی بڵێت.»
\p 
\v 19 فەرماندەکەش دەستی گرت و بە تەنها بردییە ئەو لاوە و لێی پرسی: «چیت هەیە پێمی بڵێی؟»
\p 
\v 20 گوتی: «جولەکە ڕێککەوتوون داوات لێ بکەن کە بەیانی پۆڵس بنێریتە ئەنجومەنی باڵا، وەک بیانەوێت وردتر لێی بکۆڵنەوە.
\v 21 بۆیە ڕازی مەبە بە داواکارییەکەیان، چونکە زیاتر لە چل پیاویان لە بۆسەدان بۆی، سوێندیان خواردووە نەخۆن و نەخۆنەوە هەتا دەیکوژن. ئێستا ئامادەن و چاوەڕێی بەڵێنن لە تۆوە.»
\p 
\v 22 فەرماندەکە گەنجەکەی بەڕێکرد و فەرمانی پێدا: «بە کەس نەڵێیت کە ئەمەت بە من گوتووە.»
\s1 ناردنی پۆڵس بۆ لای فیلیکس
\p 
\v 23 ئینجا دووان لە سەرپەلەکانی بانگکرد و گوتی: «دوو سەد سەرباز لەگەڵ حەفتا سوار و دوو سەد ڕمهەڵگر ئامادە بکەن، تاکو لە کاتژمێر نۆی\f + \fr 23:23 \ft یۆنانی: کاتژمێری سێیەم.‏\f* شەو بچنە قەیسەرییە.
\v 24 هەروەها وڵاخ ئامادە بکرێ تاکو پۆڵس سواری بێت و بە سەلامەتی بیگەیێننە لای فیلیکسی فەرمانڕەوا.»
\p 
\v 25 نامەیەکی نووسی ئەمەی تێدابوو:
\pmo 
\v 26 لە کلودیۆس لیسیاس،
\pmo بۆ بەڕێز فیلیکسی فەرمانڕەوا،
\pmo سڵاو.
\pm 
\v 27 ئەم پیاوە، جولەکە گرتییان و خەریک بوو بیکوژن، بەڵام لەگەڵ سەربازان چووم و ڕزگارم کرد، چونکە بیستبووم کە هاوڵاتی ڕۆمانییە.
\v 28 دەمویست بزانم بە چی تاوانباری دەکەن، بردمە ئەنجومەنەکەیان.
\v 29 بینیم لەبەر کاروباری تەوراتەکەیان تاوانبار کراوە، بەڵام تاوانێکی لەسەر نەبوو کە شایانی سزای مردن یان بەندکردن بێت.
\v 30 کاتێک ئاگادار کرامەوە کە پیلانێک لەم پیاوە دەگێڕدرێت، دەستبەجێ بۆ لای تۆم نارد، فەرمانم بە سکاڵاکاران کرد چییان لەسەری هەیە لەلای تۆ باسی بکەن.
\p 
\v 31 بۆیە سەربازان وەک فەرمانیان پێ کرابوو، پۆڵسیان برد و بە شەو بۆ ئەنتیپاتریسیان\f + \fr 23:31 \ft شارێک بووە کە ئێستا پێی دەگوترێ ڕەئسلعەین، نزیکەی 40کم لە ئۆرشەلیم دوورە.‏\f* هێنا.
\v 32 بۆ بەیانی سوارەکانیان لەگەڵ نارد و خۆیان بۆ سەربازگە گەڕانەوە.
\v 33 سوارەکانیش چوونە قەیسەرییە و نامەکەیان دایە فەرمانڕەوا و پۆڵسیان بردە بەردەمی.
\v 34 خوێندییەوە و پرسی خەڵکی چ ناوچەیەکە. زانی خەڵکی کیلیکیایە،
\v 35 گوتی: «کەی سکاڵاکاران گەیشتن، گوێت لێ دەگرم.» ئینجا فەرمانی دا لە کۆشکی هێرۆدس پاسەوانی بکرێت.
\c 24
\s1 سکاڵای جولەکەکان لە دژی پۆڵس
\p 
\v 1 پاش پێنج ڕۆژ حەنانیای سەرۆکی کاهینان و هەندێک پیر و پارێزەرێک بە ناوی تەرتولۆس هاتنە قەیسەرییە و لەلای فەرمانڕەوا سکاڵایان لە پۆڵس کرد.
\v 2 کاتێک پۆڵس بانگکرا، تەرتولۆس دەستی بە سکاڵاکە کرد و گوتی: «فیلیکسی پایەبەرز، بەهۆی دووربینیت وا لە ئاشتییەکی زۆرداین و ئەم گەلە چاکسازی بۆ دەکرێت،
\v 3 بە هەموو شێوەیەک و لە هەموو شوێنێک بە سوپاسەوە بەمە دەزانین.
\v 4 بەڵام تاکو زیاتر ماندووت نەکەم، داواکارم بە نەرمونیانی خۆت، بە کورتی گوێمان لێ بگریت.
\p 
\v 5 «بینیمان ئەم پیاوە گێرەشێوێنە و لەناو هەموو جولەکەی جیهاندا ئاژاوە دەنێتەوە. پێشەوای ڕێبازی ناسیرەییەکانە و
\v 6 هەوڵی دا پەرستگا گڵاو بکات، بەڵام ئێمە گرتمان. [ویستمان بەگوێرەی تەوراتی خۆمان حوکمی بدەین.
\v 7 بەڵام لیسیاسی فەرماندە هات و بە زەبری هێز لە دەستی سەندین و
\v 8 فەرمانی بە سکاڵاکارانی کرد بێنە لات.] جا ئەگەر خۆت لێکۆڵینەوەی لەگەڵ بکەیت، ڕاستی سکاڵاکانی ئێمەت بۆ دەردەکەوێت.»
\p 
\v 9 جولەکەکانی دیکە پشتگیری خۆیان نیشان دا و پێداگرییان لەسەر ڕاستیی قسەکانی کردەوە.
\p 
\v 10 کاتێک فەرمانڕەوا ئاماژەی بۆ پۆڵس کرد قسە بکات، ئەویش وەڵامی دایەوە: «دەزانم ساڵانێکی زۆرە تۆ دادوەری ئەم گەلەیت، بۆیە بە خۆشییەوە بەرگری لە خۆم دەکەم.
\v 11 دەتوانیت دڵنیابیت، دوازدە ڕۆژ تێپەڕی نەکردووە کە بۆ پەرستن هاتوومەتە ئۆرشەلیم.
\v 12 نە لە پەرستگا منیان بینیوە مشتومڕ لەگەڵ کەسێک بکەم و نە خەڵکم وروژاندووە، نە لە کەنیشتەکان و نە لە هیچ شوێنێکی ئەم شارە.
\v 13 ناتوانن ئەو شتانە بسەلمێنن کە ئێستا پێی تاوانبارم دەکەن.
\v 14 بەڵام من دان بەوەدا دەنێم کە بەگوێرەی ئەو ڕێگایەی\f + \fr 24:14 \ft ڕێگای پاشایەتی عیسا.‏\f* کە ئەوان پێی دەڵێن ڕێبازی چەوت، خودای باوباپیرانم دەپەرستم. باوەڕم هەیە بە هەموو ئەوەی بەگوێرەی تەوراتە و لە پەڕتووکی پێغەمبەراندا نووسراوە،
\v 15 هەروەها هەمان ئەو هیوایەم بە خودا هەیە کە ئەو پیاوانە هەیانە، کە هەستانەوە بۆ ڕاستودروستان و خراپەکارانیش دەبێت.
\v 16 لەبەر ئەوە تێدەکۆشم تاکو هەمیشە ویژدانێکی پاکم بەرامبەر خودا و خەڵک هەبێت.
\p 
\v 17 «لەدوای ساڵانێکی زۆر گەڕامەوە تاکو پیتاک بۆ گەلەکەم بهێنم و قوربانی بکەم.
\v 18 منیان لە حەوشەکانی پەرستگادا لە کاتی خۆپاککردنەوەدا بینی، بەڵام نە لەناو خەڵک و نە لەناو ئاژاوە.
\v 19 بەڵام هەندێک لەو جولەکانەی ئاسیا، ئەگەر شتێکیان لە دژی من هەبووایە، دەهاتنە لات و سکاڵایان لەسەرم دەکرد.
\v 20 یان با خۆیان بڵێن چ تاوانێکیان دۆزییەوە، کاتێک لەبەردەم ئەنجومەنی باڵادا ڕاوەستام،
\v 21 جگە لەم ڕاگەیاندنە کاتێک لەنێویان ڕاوەستابووم هاوارم کرد: ”سەبارەت بە هەستانەوەی مردووانە ئەمڕۆ ئێوە حوکمم دەدەن!“»
\s1 پۆڵس لە بەندیخانەی قەیسەرییە
\p 
\v 22 فیلیکس کە زانیارییەکی باشی دەربارەی ڕێگاکە\f + \fr 24:22 \ft ڕێگای پاشایەتی عیسا، بڕوانە \xt کردار 24‏:14‏\xt*\ft ‏.‏\f* هەبوو، دادگاییەکەی دواخست و گوتی: «کە لیسیاسی فەرماندە هات، ئەوا بڕیار لە بابەتەکانی ئێوە دەدەم.»
\v 23 ئینجا فەرمانی بە سەرپەلەکە دا کە چاودێری پۆڵس بکرێت، بەڵام هەندێک سەربەستی هەبێت، کەسیش ڕێگا لە هاوڕێیەکانی نەگرێت بۆ خزمەتکردنی.
\p 
\v 24 پاش چەند ڕۆژێک فیلیکس و دروسیلای ژنی هاتن، کە جولەکە بوو، پۆڵسی بانگکرد و لەبارەی باوەڕ بە عیسای مەسیح گوێی لێ گرت.
\v 25 کاتێک پۆڵس لەبارەی ڕاستودروستی و بەسەرخۆدا زاڵبوون و حوکمدانی داهاتوو دەدوا، فیلیکس ترسا و گوتی: «ئێستا بڕۆ. کەی کاتم هەبوو بانگت دەکەمەوە.»
\v 26 بە هیوا بوو پۆڵس بەرتیلی بداتێ، بۆیە بەردەوام بانگی دەکرد و قسەی لەگەڵ دەکرد.
\p 
\v 27 دوو ساڵ تێپەڕی و پورکیۆس فێستۆس شوێنی فیلیکسی گرتەوە. بەڵام لەبەر ئەوەی کە دەیویست ڕەزامەندی جولەکە بەدەستبهێنێت، پۆڵسی لە بەندیخانە هێشتەوە.
\c 25
\s1 بابەتی پۆڵس لەلای قەیسەر
\p 
\v 1 کاتێک فێستۆس گەیشتە هەرێمەکە، لەدوای سێ ڕۆژ لە قەیسەرییەوە چووە ئۆرشەلیم.
\v 2 کاهینانی باڵا و ڕابەرانی جولەکە سکاڵایان لە پۆڵس کرد و لە فێستۆس پاڕانەوە،
\v 3 تکایان لێکرد چاکەیەکیان لەگەڵ بکات بەوەی پۆڵس بنێرێتە ئۆرشەلیم، چونکە لەسەر ڕێگا بۆسەیان بۆ نابووەوە تاکو بیکوژن.
\v 4 فێستۆس وەڵامی دایەوە: «پۆڵس لە قەیسەرییە دەستبەسەرە و خۆشم بە زوویی دەچم بۆ ئەوێ.»
\v 5 ئینجا گوتی: «با گەورە پیاوانتان لەگەڵم بێن، ئەگەر پیاوەکە خراپەیەکی هەیە، با سکاڵای لێ بکەن.»
\p 
\v 6 دوای ئەوەی کە فێستۆس هەشت بۆ دە ڕۆژێک لەگەڵیان مایەوە، چوو بۆ قەیسەرییە. بۆ بەیانی لەسەر کورسی دادوەری دانیشت و فەرمانی دا پۆڵس بهێنن.
\v 7 کاتێک کە هێنایان، ئەو جولەکانەی لە ئۆرشەلیمەوە هاتبوون لێی کۆبوونەوە و تاوانی زۆر و ترسناکیان خستە پاڵی، بەڵام نەیانتوانی بیسەلمێنن.
\p 
\v 8 ئەوسا پۆڵس بەرگری لە خۆی کرد: «هیچ شتێکم لە دژی تەوراتی جولەکە یان پەرستگا یان قەیسەر نەکردووە.»
\p 
\v 9 بەڵام فێستۆس دەیویست چاکە لەگەڵ جولەکەدا بکات، لە پۆڵسی پرسی: «دەتەوێ بچیتە ئۆرشەلیم و لەوێ سەبارەت بەم شتانە دادگاییت بکەم؟»
\p 
\v 10 پۆڵس گوتی: «لەبەردەم کورسی دادوەری قەیسەر وەستاوم، دەبێت لێرەش دادگایی بکرێم. خراپەم لەگەڵ جولەکە نەکردووە، وەک چۆن خۆت باش دەزانیت.
\v 11 ئەگەر تاوانێکم کردبێت شایانی سزای مردن بێت، ئەوا لە مردن ڕامنەدەکرد. بەڵام ئەگەر ئەو شتانەی منی پێ تاوانبار دەکەن ڕاست نەبێت، ئەوا کەس ناتوانێت بمداتە دەستیان. داواکەم دەدەمە قەیسەر!»
\p 
\v 12 دوای ئەوەی کە فێستۆس لەگەڵ ڕاوێژکارانی قسەی کرد، گوتی: «داواکەت دایە قەیسەر، دەچیتە لای قەیسەر!»
\s1 ڕاوێژی فێستۆس بە ئەگریپاس
\p 
\v 13 دوای چەند ڕۆژێک شا ئەگریپاس و بەرنیکی هاتنە قەیسەرییە تاکو سڵاو لە فێستۆس بکەن.
\v 14 کاتێک چەند ڕۆژێکیان لەوێ بەسەربرد، فێستۆس بابەتی پۆڵسی خستە بەردەم پاشا و گوتی: «پیاوێک لێرەیە فیلیکس بە گیراوی بەجێی هێشت.
\v 15 کاتێک چوومە ئۆرشەلیم، کاهینانی باڵا و پیرانی جولەکە داوایان خستە پێشم تاکو تاوانبار بکرێت.
\p 
\v 16 «جا پێم گوتن نەریتی ڕۆمانییەکان نییە پێش ڕووبەڕووکردنەوەی سکاڵا لێکراو و سکاڵاکاران کەسێک بەدەستەوە بدەن، تاکو دەرفەتی بەرگری لە دژی سکاڵاکە هەبێت.
\v 17 کاتێک لێرە کۆبوونەوە، خێرا بۆ بەیانییەکەی لەسەر کورسی دادوەری دانیشتم و فەرمانم دا کە پیاوەکە بهێنن.
\v 18 کاتێک سکاڵاکاران بەرامبەری وەستان، تۆمەتێکی وایان نەدایە پاڵی کە من چاوەڕێم دەکرد،
\v 19 بەڵکو مشتومڕیان لەسەر هەندێک بابەتی تایبەت بە ئایینەکەیان و پیاوێکی مردوو بوو بە ناوی عیسا، کە پۆڵس دەڵێت زیندووە.
\v 20 کاتێک دڵنیا نەبووم چۆن لێکۆڵینەوە لەم شتانە بکەم، گوتم لەوانەیە حەز بکات بچێتە ئۆرشەلیم و لەوێ لەسەر ئەم شتانە دادگایی بکرێت.
\v 21 بەڵام کاتێک پۆڵس داواکارییەکەی بەرزکردەوە کە بۆ بڕیاری ئیمپراتۆر بهێڵدرێتەوە، فەرمانم دا بیهێڵنەوە هەتا بۆ قەیسەری دەنێرم.»
\p 
\v 22 ئەگریپاس بە فێستۆسی گوت: «من حەز دەکەم خۆم گوێ لەم پیاوە بگرم.» گوتی: «بەیانی گوێت لێی دەبێت.»
\p 
\v 23 بۆ بەیانی ئەگریپاس و بەرنیکی بە پێشوازییەکی گەورە و شکۆدارەوە هاتن و لەگەڵ فەرماندە و پیاوماقوڵانی شاردا هاتنە هۆڵی گوێگرتن. فێستۆس فەرمانی دا و پۆڵس هێنرا.
\v 24 فێستۆس گوتی: «شا ئەگریپاس و هەموو ئامادەبووان کە لەگەڵماندان، ئەم پیاوەی دەیبینن، ئەو کەسەیە کە هەموو گەلی جولەکە لە ئۆرشەلیم و لێرە لێم پاڕانەوە و هاواریان دەکرد کە نابێت چیتر بژیێت.
\v 25 بۆم دەرکەوت هیچی نەکردووە شایانی مردن بێت، بەڵام لەبەر ئەوەی کە خۆی داواکارییەکەی دایە ئیمپراتۆر، بڕیارم دا بینێرم بۆ لای.
\v 26 لەبەر ئەوەی لەبارەی ئەمەوە شتێکم نییە کە بە دڵنیاییەوە بۆ قەیسەری خاوەن شکۆی بنووسم، بۆیە هێنامە بەردەمتان، بە تایبەتی بەردەمی تۆ، شا ئەگریپاس، تاکو کە لێکۆڵینەوە کرا، شتێکم هەبێت بینووسم،
\v 27 چونکە بەلای منەوە شیاو نییە گیراوێک بنێرم بێ دیاریکردنی ئەو تاوانەی لە ئەستۆیەتی.»
\c 26
\s1 بەرگری پۆڵس لەلای ئەگریپاس
\p 
\v 1 ئەگریپاس بە پۆڵسی گوت: «ڕێگات دراوەتێ باسی خۆت بکەیت.» ئینجا پۆڵس دەستی درێژکرد و بەرگری کرد:
\v 2 «شا ئەگریپاس، خۆم بە بەختەوەر دەزانم کە ئەمڕۆ لەبەردەم تۆ بەرگری لە خۆم بکەم، سەبارەت بە هەموو ئەو شتانەی جولەکە منیان پێ تۆمەتبار کردووە،
\v 3 بە تایبەتی تۆ لە هەموو نەریت و کێشەی جولەکە شارەزایت، بۆیە لێت دەپاڕێمەوە بە ئارامی گوێم لێ بگریت.
\p 
\v 4 «هەموو جولەکەکان بە باشی دەزانن کە ژیانی لاویەتیم چۆن بووە، هەر لە سەرەتای ژیانمەوە کە لەنێو گەلەکەم\f + \fr 26:4 \ft مەبەستی ئەوەیە کاتێک لە کیلیکیا بووە‏\f* و لە ئۆرشەلیمدا بووم.
\v 5 ئەوان لەمێژە دەمناسن و ئەگەر بیانەوێت دەتوانن شایەتی بدەن کە وەک فەریسی ژیاوم، توندترین ڕێبازی ئایینەکەمان.
\v 6 ئێستاش حوکم دەدرێم لەبەر ئەوەی هیوام بەو بەڵێنە هەیە کە خودا بە باوباپیرانمانی داوە.
\v 7 ئەمە ئەو بەڵێنەیە کە دوازدە هۆزەکەمان شەو و ڕۆژ بە هیوای هاتنەدی، بە پەرۆشەوە خواپەرستی دەکەن. ئەی پاشا، لەبەر ئەم هیوایە جولەکە تۆمەتبارم دەکەن.
\v 8 بۆچی ئێوە باوەڕ ناکەن کە خودا مردووان هەڵدەستێنێتەوە؟
\p 
\v 9 «لە ڕاستیدا خۆم پێم وابوو کە پێویستە زۆر شت لە دژی ناوی عیسای ناسیرەیی بکەم.
\v 10 لە ئۆرشەلیم ئەوەم کرد، دەسەڵاتم لە کاهینانی باڵا وەرگرت و زۆر کەسم لە گەلی پیرۆزی خودا خستە زیندانەوە، بۆ کوشتنیان دەنگم دەدا.
\v 11 لە هەموو کەنیشتەکان زۆر جار سزام دەدان تاکو ناچاریان بکەم کفر بکەن. ئەوەندە ڕقم لێیان بوو تەنانەت لە شارەکانی دەرەوەش دەمچەوساندنەوە.
\p 
\v 12 «جارێکیان بە دەسەڵات و مۆڵەتی کاهینانی باڵا دەچوومە دیمەشق.
\v 13 جا ئەی پاشا، لە نیوەڕۆدا بە ڕێگاوە ڕووناکییەکم لە ئاسمانەوە بینی، درەوشاوەتر لە تیشکدانەوەی ڕۆژ، دەوروبەری من و هاوڕێیانمی ڕووناک کردەوە.
\v 14 هەموومان کەوتینە سەر زەوی. ئینجا گوێم لە دەنگێک بوو بە زمانی عیبری پێی فەرمووم: ”شاول، شاول، بۆچی دەمچەوسێنیتەوە؟ بۆت زەحمەتە لوشکە لە نەقیزەی من باوێی\f + \fr 26:14 \ft پەندێکی یۆنانییە بۆ بەرهەڵستیکردنی بێ سوود بەکاردێت.‏\f*.“
\p 
\v 15 «منیش گوتم: ”تۆ کێیت گەورەم؟“
\p «مەسیحی خاوەن شکۆ فەرمووی: ”من عیسام، ئەوەی تۆ دەیچەوسێنیتەوە.
\v 16 بەڵام هەستە و لەسەر پێیەکانت ڕابوەستە. لەبەر ئەوە بۆت دەرکەوتم، کە وەک خزمەتکار و شایەت هەڵتبژێرم بۆ ئەوەی بینیت و ئەوەی تێیدا بۆت دەردەکەوم.
\v 17 ڕزگارت دەکەم لە گەلەکەت و لەو ناجولەکانەی تۆیان بۆ دەنێرم
\v 18 تاکو چاویان بکەیتەوە، تاکو لە تاریکی بگەڕێنەوە بۆ ڕووناکی، لە دەسەڵاتی شەیتان بۆ خودا، ئەوسا لێخۆشبوونی گوناه وەردەگرن و لەگەڵ ئەوانەی بە باوەڕیان بە من پیرۆزکراون بەشیان دەبێت.“
\p 
\v 19 «ئەی شا ئەگریپاس، لەو کاتە بەلاوە سەرپێچی بینینی ئاسمانیم نەکردووە.
\v 20 یەکەم جار بۆ دانیشتووانی دیمەشق، پاشان ئۆرشەلیم و هەموو ناوچەکانی یەهودیا و دواتر بە ناجولەکەکانم ڕاگەیاند، کە تۆبە بکەن و بۆ لای خودا بگەڕێنەوە و لە ڕێگەی هەڵسوکەوتیانەوە تۆبەکردنەکەیان دەربخەن.
\v 21 لەبەر ئەمە جولەکەکان لە حەوشەکانی پەرستگادا منیان گرت و هەوڵیان دا بمکوژن.
\v 22 بەڵام هەتا ئەمڕۆش خودا یارمەتی داوم، بۆیە وەستاوم و شایەتی بۆ گەورە و بچووک دەدەم. هیچ ناڵێم جگە لەوەی کە پێغەمبەران و موسا لەبارەی ئەوەی خەریکە ڕوودەدات گوتوویانە،
\v 23 کە مەسیحەکە ئازار بچێژێت و یەکەمی هەستانەوەی مردووان بێت و ڕووناکی بۆ گەلەکەی و نەتەوەکان ڕابگەیەنێت.»
\p 
\v 24 کاتێک پۆڵس بەم قسانە بەرگری لە خۆی دەکرد، فێستۆس هاواری کرد: «پۆڵس شێت بوویت! ئەوەندەت خوێندووەتەوە کە شێت بوویت.»
\p 
\v 25 پۆڵس گوتی: «فێستۆسی پایەبەرز، شێت نیم، بەڵام قسەی ڕاست و شیاو دەکەم.
\v 26 ئەم پاشایەی ئازادانە قسەی لەگەڵ دەکەم، ئەم شتانە دەزانێت، دڵنیام هیچ لەمانە لەلای شاراوە نییە، چونکە ئەم کارانە لە سووچێک نەکراون.
\v 27 ئەگریپاسی پاشا، باوەڕت بە پێغەمبەران هەیە؟ دەزانم باوەڕت هەیە.»
\p 
\v 28 ئەگریپاس بە پۆڵسی گوت: «دەتەوێت بەم کاتە کەمە قەناعەتم پێ بهێنی ببمە مەسیحی؟»
\p 
\v 29 پۆڵس گوتی: «کاتی کەم یان زۆر، لە خودا دەپاڕێمەوە نەک تەنها تۆ، بەڵکو هەموو ئەوانەی ئەمڕۆ گوێم لێ دەگرن وەک منتان لێ بێت، بەڵام بێ ئەم زنجیرانە.»
\p 
\v 30 جا پاشا و فەرمانڕەوا و بەرنیکی و ئامادەبووان هەستان،
\v 31 دەڕۆیشتن و بە یەکتریان دەگوت: «ئەم پیاوە شتێکی نەکردووە شایانی سزای مردن یان گرتن بێت.»
\p 
\v 32 ئەگریپاس بە فێستۆسی گوت: «ئەگەر ئەم پیاوە داواکارییەکەی نەدابووایە قەیسەر، دەکرا ئازاد بکرایە.»
\c 27
\s1 گەشتی پۆڵس بەرەو ڕۆما
\p 
\v 1 کاتێک بڕیار درا بە دەریادا بۆ ئیتالیا بڕۆین، پۆڵس و هەندێک بەندکراوی دیکە درانە دەست سەرپەلێک بە ناوی یولیۆس کە لە سوپای ئیمپراتۆر بوو.
\v 2 سواری کەشتییەکی ئەدرامیتی بووین و بەڕێکەوتین، کە دەیویست بۆ چەند بەندەرێکی ئاسیا بڕوات. ئەریستارخۆسی مەکدۆنیمان لەگەڵ بوو، کە خەڵکی سالۆنیکییا بوو.
\p 
\v 3 بۆ بەیانی گەیشتینە سەیدا. یولیۆس لەگەڵ پۆڵس باش بوو، ڕێگای دا بچێتە لای برادەرانی تاکو پێویستییەکانی دابین بکەن.
\v 4 ئینجا لەوێوە بەڕێکەوتین و بە پەنای قوبرسدا ڕۆیشتین، چونکە با پێچەوانە بوو.
\v 5 کە ئەو دەریایەمان بڕی، ئەوەی لەتەنیشت کیلیکیا و پامفیلیایە، لە میرای لیکیە دابەزین.
\v 6 لەوێ سەرپەلەکە کەشتییەکی دۆزییەوە ئەسکەندەری بوو دەچووە ئیتالیا، سواری کردین.
\v 7 کەشتییەکە ماوەیەکی درێژ بە هێواشی دەڕۆیشت و بە زەحمەت لە کنیدۆس نزیک کەوتینەوە، بایەکە نەیهێشت زیاتر بڕۆین، بە پەنای کریتدا و لە بەرامبەر سەلمۆن ڕۆیشتین.
\v 8 بە زەحمەت تێپەڕمان کرد و گەیشتینە شوێنێک پێی دەگوترێ بەندەرە باشەکان، کە لە شاری لەسائیە نزیکە.
\p 
\v 9 لەدوای تێپەڕینی ماوەیەکی زۆر، گەشتی دەریایی ترسناک بوو، چونکە ڕۆژی کەفارەت\f + \fr 27:9 \ft ڕۆژی کەفارەت دەکەوێتە مانگی تشرینی یەکەم (مانگی 10)، پیرۆزترین ڕۆژی جولەکەکانە و لەم ڕۆژەدا بەڕۆژوو دەبن. بڕوانە \xt لێڤییەکان 23‏:27‏-28.‏\xt*\ft ‏\f* بەسەرچووبوو، هەر بۆیە پۆڵس ئاگاداری کردنەوە و
\v 10 پێی گوتن: «کوڕینە، دەبینم گەشتەکە بە تێکشکان و زیانێکی گەورەوە دەبێت، نەک تەنها بۆ کەشتی و بارەکەی، بەڵکو بۆ ژیانیشمان.»
\v 11 بەڵام سەرپەلەکە لایەنگری کەشتیوان و خاوەنەکەی دەکرد، نەک قسەی پۆڵس.
\v 12 لەبەر ئەوەی بەندەرەکە بۆ بەسەربردنی زستان باش نەبوو، بۆیە زۆربەیان بڕیاریان دا ئەوێش بەجێبهێڵن، بە هیوای ئەوەی بگەنە فینکس تاکو زستانی تێدا بەسەرببەن، کە بەندەرێکی کریت بوو ڕووەو باشووری ڕۆژهەڵات و باکووری ڕۆژئاوا.
\s1 گەشتێکی ترسناک
\p 
\v 13 کە شنەبای باشوور هەڵیکرد، وایانزانی بە مرازیان گەیشتن، لەنگەریان بەرزکردەوە و بە نزیک کەناری کریتدا تێدەپەڕین.
\v 14 بەڵام دوای کەمێک تۆفانێک کە بە «باکووری ڕۆژهەڵات» ناسراوە لەلای دوورگەکەوە هەڵیکرد و
\v 15 کەشتییەکەی گرتەوە و نەیتوانی ڕووبەڕووی بێتەوە، خۆمان بەدەستەوە دا و تۆفانەکە ئێمەی لەگەڵ خۆی برد.
\v 16 تۆفانەکە ئێمەی بەرەو پەنای دوورگەیەکی بچووک برد کە ناوی کەودا بوو، بە زەحمەت توانیمان بەلەمی ڕزگاربوون بخەینە ژێر ڕکێفمانەوە.
\v 17 کاتێک بەلەمەکەیان بەرز کردەوە، گوریسیان بۆ بەستنەوەی کەشتییەکە بەکاردەهێنا. دەترسان بکەونە ناو تەنکاوی\f + \fr 27:17 \ft شوێنێک لەنێوان دوو دەریا، قووڵایی کەمە.‏\f* سیرتیس، بۆیە لە کەشتییەکەوە لەنگەری دەریایان\f + \fr 27:17 \ft لەنگەری دەریا: لەنگەرێکی تایبەتە بۆ کەمکردنەوەی خێرایی کەشتی بەکاردەهێنرێت.‏\f* دابەزاند، بەو شێوەیە تۆفانەکە کەشتییەکەی برد.
\v 18 بۆ بەیانی ڕەشەباکە توند بوو، دەستیان بە سووککردنی بارەکە کرد.
\v 19 لە ڕۆژی سێیەم بە دەستی خۆیان کەلوپەلی کەشتییەکەیان فڕێدا.
\v 20 ماوەیەکی درێژ نە خۆرمان بینی و نە ئەستێرە، هەتا دەهات ڕەشەباکە بەهێزتر دەبوو، لە کۆتاییدا هەموو هیوایەکی ڕزگاربوونمان بڕا.
\p 
\v 21 کاتێک ماوەیەکی زۆر بوو نانیان نەخواردبوو، پۆڵس لە ناوەڕاستیان ڕاوەستا و گوتی: «کوڕینە، دەبووایە گوێتان لە من بگرتایە و کریتتان بەجێ نەهێشتایە، ئەوسا لەم تێکشکان و زیانە دوور دەبوون.
\v 22 ئێستاش لێتان دەپاڕێمەوە ورە بەرنەدەن، کەستان ژیانی لەدەست نادات، تەنها کەشتییەکە تێکدەشکێت،
\v 23 چونکە ئەمشەو فریشتەی ئەو خودایەی من هی ئەوم و دەیپەرستم، هاتە لام و
\v 24 گوتی: ”پۆڵس مەترسە! دەبێت تۆ لەبەردەم قەیسەر ڕاوەستیت و خودا ژیانی هەموو ئەوانەت دەداتێ کە لەگەڵت گەشت دەکەن.“
\v 25 کەواتە کوڕینە، ورەبەرز بن، چونکە باوەڕم بە خودا هەیە کە ئاوا دەبێت، وەک ئەوەی پێی فەرمووم.
\v 26 بەڵام دەبێت بکەوینە سەر دوورگەیەک.»
\p 
\v 27 لە شەوی چواردەیەمیندا کە هێشتا تۆفانەکە لە دەریای ئەدریا کەشتییەکەی لەگەڵ خۆی دەبرد، لە نیوەشەودا کەشتیوانان وایانزانی لە وشکانی نزیک دەبنەوە.
\v 28 کە پێوایان بینییان بیست باڵایە\f + \fr 27:28 \ft نزیکەی 37 مەتر.‏\f*. کەمێک ڕۆیشتن و پێوایانەوە بینییان پازدە باڵایە.
\v 29 دەترسان نەوەک بکەونە سەر بەرد، لە پشتەوە چوار لەنگەریان شۆڕکردەوە و دەپاڕانەوە تاکو ڕۆژ هەڵبێت.
\v 30 کەشتیوانان هەوڵیان دا لە کەشتییەکە هەڵبێن، بەلەمی ڕزگاربوونیان بۆ دەریا شۆڕکردەوە بە بیانووی ئەوەی دەیانەوێ چەند لەنگەرێک لە پێشەوە شۆڕبکەنەوە.
\v 31 پۆڵس بە سەرپەل و سەربازەکانی گوت: «ئەگەر ئەمانە لە کەشتییەکەدا نەمێننەوە، ناتوانن ڕزگارتان بێت.»
\v 32 ئەوسا سەربازەکان گوریسی بەلەمی ڕزگاربوونیان بڕی و وازیان لێی هێنا بکەوێت.
\p 
\v 33 کاتێک خەریک بوو ڕۆژ هەڵدەهات، پۆڵس تکای لە هەمووان کرد نان بخۆن و گوتی: «ئەمە ڕۆژی چواردەیەمینە و ئێوە چاوەڕوان و بەردەوامن بێ ئەوەی هیچ بخۆن و هیچ وەربگرن.
\v 34 بۆیە تکاتان لێ دەکەم نان بخۆن، چونکە ئەمە بۆ ڕزگاربوونتانە. کەستان تاڵێک لە قژی سەری نافەوتێت.»
\v 35 کە ئەمەی گوت، نانێکی هەڵگرت و لەبەردەم هەمووان سوپاسی خودای کرد، ئینجا لەتی کرد و دەستی بە خواردن کرد.
\v 36 ئیتر هەموویان ورەیان بەرزبووەوە و نانیان خوارد.
\v 37 ئەوانەی ناو کەشتییەکە هەموومان دوو سەد و حەفتا و شەش کەس بووین.
\v 38 کە تێر نانیان خوارد، بە فڕێدانی دانەوێڵەکە بۆ ناو دەریا کەشتییەکەیان سووککرد.
\s1 تێکشکانی کەشتییەکە
\p 
\v 39 کاتێک ڕۆژبووەوە، کەشتیوانەکان نەیانزانی لە چ شوێنێکدان، بەڵام کەنداوێکیان بینی کەناری هەبوو، دەیانویست ئەگەر بتوانن کەشتییەکە بەرەو ئەوێ ببەن.
\v 40 ئینجا لەنگەرەکانیان پساند و لە دەریادا بەجێیان هێشتن، لە هەمان کاتدا گوریسی سەوڵەکانی ئاراستەکردنیان شلکرد و بایەوانەکەی پێشەوەیان کردەوە بۆ بایە هەڵکردووەکە، بەرەو کەنارەکە ڕۆیشتن.
\v 41 بەڵام کەوتە تەنکاو و کەشتییەکەیان بەرەو وشکانی برد، کە پێشەکەی گیربوو و نەجوڵا، لەبەر توندی شەپۆلەکان پشتەوەی تێکدەشکا.
\p 
\v 42 پلانی سەربازەکان ئەوە بوو کە بەندکراوان بکوژن نەوەک کەسیان مەلە بکات و هەڵبێت.
\v 43 بەڵام سەرپەلەکە دەیویست پۆڵس بپارێزێت، بۆیە پلانەکەی ڕاگرتن و فەرمانی دا ئەوانەی دەتوانن مەلە بکەن با یەکەم جار خۆیان فڕێبدەن و بگەنە وشکانی،
\v 44 ئەوانی دیکەش هەندێکیان بە تەختە و هەندێکیان بە پارچەکانی کەشتییەکە خۆیان بگەیەننە وشکانی. بەو شێوەیە هەموو بە سەلامەتی گەیشتنە وشکانی.
\c 28
\s1 لە دوورگەی ماڵتا
\p 
\v 1 کە ڕزگارمان بوو زانیمان ئەو دوورگەیە پێی دەگوترێ ماڵتا.
\v 2 دانیشتووانەکەی چاکەیەکی لە ڕادەبەدەریان لەگەڵ کردین. ئاگریان بۆ کردینەوە و پێشوازییان لە هەموومان کرد، چونکە باران دەباری و کەشوهەوا سارد بوو.
\v 3 پۆڵس هەندێک چیلکەی کۆکردەوە و خستییە ئاگرەکە، تیرەمارێک لەبەر گەرماییەکە دەرپەڕی و خۆی بە دەستیەوە هەڵواسی.
\v 4 کاتێک خەڵکەکە تیرەمارەکەیان بینی خۆی بە دەستییەوە هەڵواسیوە، بە یەکتریان گوت: «بێگومان ئەم کابرایە بکوژە، هەرچەندە لە دەریا ڕزگاری بوو، بەڵام خوداوەندی دادپەروەری ناهێڵێت بژیێت.»
\v 5 بەڵام پۆڵس تیرەمارەکەی ڕاوەشاندە ناو ئاگرەکە و تووشی هیچ زیانێک نەبوو.
\v 6 ئەوانیش چاوەڕێیان دەکرد بئاوسێت یان لەناکاو بە مردوویی بکەوێت. بەڵام زۆر چاوەڕێیان کرد و بینییان هیچی بەسەرنەهات، ئەوسا بیروڕایان گۆڕی و سەبارەت بە پۆڵس گوتیان: «ئەمە خوداوەندێکە!»
\p 
\v 7 دەوروبەری ئەو شوێنە زەوی و زاری پیاوگەورەی دوورگەکە بوو کە ناوی پۆبلیۆسە. ئەو پێشوازی لێکردین و سێ ڕۆژ بە خۆشییەوە میوانداری کردین.
\v 8 وا ڕێککەوت باوکی پۆبلیۆس لەناو جێگادا کەوتبوو، تا و سکچوونی هەبوو. پۆڵس چووە لای و نوێژی کرد، دەستی لەسەر دانا و چاکیکردەوە.
\v 9 کاتێک ئەمە ڕوویدا، نەخۆشەکانی دیکەی دوورگەکە دەهاتن و چاک دەبوونەوە.
\v 10 ئیتر بە زۆر شێوە ڕێزیان گرتین، کە بەڕێکەوتین هەموو پێداویستییەکانیان بۆ دابین کردین.
\s1 لە ماڵتاوە بۆ ڕۆما
\p 
\v 11 دوای سێ مانگ بە کەشتییەکی ئەسکەندەری بەڕێکەوتین، کە زستانی لە دوورگەکە بەسەربرد بوو؛ کەشتییەکە وێنەی دوو خوداوەندی جمکی بە ناوی کاستۆر و پۆلوکس لەسەر بوو.
\v 12 کاتێک لە سیراکۆسا دابەزین، سێ ڕۆژ لەوێ ماینەوە.
\v 13 ئینجا لەوێ ڕۆیشتین و گەیشتینە ڕیگیۆم. بۆ بەیانی بای خواروو هەڵیکرد، لە ڕۆژی دووەم هاتینە پوتیۆلی.
\v 14 لەوێ برایانمان دۆزییەوە، داوایان لێکردین هەفتەیەک بمێنینەوە. بەم شێوەیە هاتینە ڕۆما.
\v 15 لەوێوە کە برایان هەواڵی ئێمەیان بیست، تاکو گۆڕەپانی ئەپیۆس\f + \fr 28:15 \ft یۆنانی: \tl فۆروم ئەپیۆس‏\tl*.‏\f* و سێ خانەکە\f + \fr 28:15 \ft شوێنێکە، بە نزیکەی 40کم لە باشووری ڕۆمایە.‏\f* هاتنە پیشوازیمان. کاتێک پۆڵس بینییانی سوپاسی خودای کرد و ورەی بەرزبووەوە.
\v 16 کاتێک گەیشتینە ڕۆما، ڕێگا بە پۆڵس درا بە تەنها لەگەڵ ئەو سەربازەی پاسەوانی دەکرد نیشتەجێ بێت.
\p 
\v 17 دوای سێ ڕۆژ پۆڵس ڕابەرانی جولەکەی بانگکرد. کاتێک کۆبوونەوە، پێی گوتن: «برایان، هەرچەندە هیچم لە دژی گەلەکەمان و نەریتی باوباپیرانمان نەکردووە، بەڵام لە ئۆرشەلیم گیرام و درامە دەستی ڕۆمانییەکان.
\v 18 لێکۆڵینەوەیان لەگەڵم کرد ویستیان ئازادم بکەن، چونکە هۆیەکیان بۆ کوشتنم نەدۆزییەوە.
\v 19 بەڵام جولەکە ناڕازی بوون و منیش ناچار بووم داواکارییەکەم بدەمە قەیسەر، مەبەستم ئەوە نەبوو سکاڵا لە گەلی خۆم بکەم.
\v 20 لەبەر ئەوە داوام کرد بتانبینم و قسەتان لەگەڵ بکەم، چونکە لە پێناوی هیوای ئیسرائیل ئەم زنجیرەم پێوەیە.»
\p 
\v 21 وەڵامیان دایەوە: «دەربارەی تۆ نامەمان لە یەهودیاوە وەرنەگرتووە، کەسیش لە برایان نەهاتووە تاکو دەربارەی تۆ هەواڵمان بداتێ یان بە خراپە باست بکات.
\v 22 بەڵام پێمان خۆشە گوێمان لە بۆچوونەکانی تۆ بێت، چونکە دەزانین کە خەڵکی لە هەموو شوێنێکەوە بەربەرەکانێی ئەم ڕێبازە دەکات.»
\p 
\v 23 ڕۆژێکیان بۆ دیتنی پۆڵس دیاری کرد و زۆر کەس هاتنە ماڵەکەی. ئەویش لە بەیانییەوە تاکو ئێوارە بۆیانی ڕوون دەکردەوە و شایەتی بۆ پاشایەتی خودا دەدا، هەوڵی دەدا بە تەوراتی موسا و پەڕتووکی پێغەمبەران دەربارەی عیسا قەناعەتیان پێ بهێنێت.
\v 24 جا هەندێکیان بەو قسانەی قایل بوون، هەندێکیش باوەڕیان نەکرد.
\v 25 ئینجا بە جیاوازی بیروڕاوە ئەوێیان بەجێهێشت کاتێک پۆڵس دوایین قسەی بۆ کردن: «ڕۆحی پیرۆز لە ڕێگەی ئیشایا پێغەمبەرەوە ڕاستی بە باوباپیرانتان فەرمووە:
\q1 
\v 26 «﴿بڕۆ لای ئەم گەلە و پێی بڵێ:
\q1 ”ئێوە هەمیشە دەبیستن بەڵام هەرگیز تێناگەن،
\q2 ئێوە هەمیشە سەیر دەکەن بەڵام هەرگیز نابینن!“
\q1 
\v 27 چونکە دڵی ئەم گەلە ڕەق بووە و
\q2 گوێیان قورس بووە،
\q2 چاویان نوقاندووە،
\q1 نەوەک بە چاویان ببینن و
\q2 بە گوێیان ببیستن و
\q2 بە دڵیان تێبگەن و بگەڕێنەوە،
\q1 منیش چاکیان بکەمەوە.﴾\f + \fr 28:27 \ft \xt ئیشایا 6‏:9،‏\xt*\ft ‏ 10‏\f*
\p 
\v 28 «با لەلاتان زانراو بێت، ڕزگاریی خودا بۆ ناجولەکەکان نێردرا، ئەوانیش گوێ دەگرن.»
\v 29 [کاتێک ئەمەی گوت، جولەکەکان ڕۆیشتن و دەمەقاڵێیەکی زۆریان هەبوو.]
\p 
\v 30 پۆڵس دوو ساڵی تەواو لەو ماڵەی بە کرێی گرتبوو مایەوە، پێشوازی لە هەموو ئەوانە دەکرد کە دەهاتنە لای،
\v 31 بەوپەڕی ئازایی و بێ کۆسپ شانشینی خودای ڕادەگەیاند و سەبارەت بە عیسای مەسیحی خاوەن شکۆ خەڵکی فێردەکرد.
