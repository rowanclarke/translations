\v 3 \w Et|strong="H1004"\w* \w il|strong="H3426"\w* \w y|strong="H1004"\w* \w en|strong="H3947"\w* \w avait|strong="H1004"\w* d'\w autres|strong="H3426"\w* \w qui|strong="H7704"\w* disaient: \w Nous|strong="H3947"\w* \w engageons|strong="H6148"\w* \w nos|strong="H6148"\w* \w champs|strong="H7704"\w*, \w et|strong="H1004"\w* \w nos|strong="H6148"\w* \w vignes|strong="H3754"\w*, \w et|strong="H1004"\w* \w nos|strong="H6148"\w* \w maisons|strong="H1004"\w*, afin d'\w avoir|strong="H3947"\w* \w du|strong="H1004"\w* \w blé|strong="H1715"\w* \w pendant|strong="H1004"\w* \w la|strong="H3947"\w* \w famine|strong="H7458"\w*.  
\v 4 \w Il|strong="H4428"\w* \w y|strong="H4428"\w* \w en|strong="H4428"\w* \w avait|strong="H4428"\w* aussi \w qui|strong="H4428"\w* disaient: \w Nous|strong="H4428"\w* empruntons \w de|strong="H4428"\w* l'\w argent|strong="H3701"\w*, \w pour|strong="H4428"\w* \w le|strong="H4428"\w* \w tribut|strong="H4060"\w* \w du|strong="H4428"\w* \w roi|strong="H4428"\w*, \w sur|strong="H4428"\w* \w nos|strong="H4428"\w* \w champs|strong="H7704"\w* \w et|strong="H4428"\w* \w sur|strong="H4428"\w* \w nos|strong="H4428"\w* \w vignes|strong="H3754"\w*.  
\v 5 \w Et|strong="H1121"\w* \w pourtant|strong="H1121"\w* \w notre|strong="H3027"\w* \w chair|strong="H1320"\w* \w est|strong="H1121"\w* \w comme|strong="H1121"\w* \w la|strong="H1121"\w* \w chair|strong="H1320"\w* \w de|strong="H1121"\w* \w nos|strong="H5650"\w* \w frères|strong="H1121"\w*, \w et|strong="H1121"\w* \w nos|strong="H5650"\w* \w fils|strong="H1121"\w* \w sont|strong="H1121"\w* \w comme|strong="H1121"\w* \w leurs|strong="H1121"\w* \w fils|strong="H1121"\w*. \w Et|strong="H1121"\w* \w voici|strong="H2009"\w*, \w nous|strong="H3027"\w* assujettissons \w nos|strong="H5650"\w* \w fils|strong="H1121"\w* \w et|strong="H1121"\w* \w nos|strong="H5650"\w* \w filles|strong="H1323"\w* \w pour|strong="H3027"\w* \w être|strong="H3027"\w* \w esclaves|strong="H5650"\w*; \w et|strong="H1121"\w* \w déjà|strong="H1121"\w* quelques-unes \w de|strong="H1121"\w* \w nos|strong="H5650"\w* \w filles|strong="H1323"\w* \w sont|strong="H1121"\w* \w assujetties|strong="H5650"\w*; \w et|strong="H1121"\w* \w nous|strong="H3027"\w* n'\w y|strong="H3027"\w* pouvons \w rien|strong="H3426"\w*, car \w nos|strong="H5650"\w* \w champs|strong="H7704"\w* \w et|strong="H1121"\w* \w nos|strong="H5650"\w* \w vignes|strong="H3754"\w* \w sont|strong="H1121"\w* \w à|strong="H1121"\w* d'\w autres|strong="H3027"\w*.  
\v 6 \w Quand|strong="H8085"\w* j'\w entendis|strong="H8085"\w* \w leur|strong="H8085"\w* \w cri|strong="H2201"\w* \w et|strong="H8085"\w* \w ces|strong="H1697"\w* paroles-là, \w je|strong="H1697"\w* fus \w fort|strong="H3966"\w* \w irrité|strong="H2734"\w*.  
\v 7 \w Je|strong="H3068"\w* délibérai \w donc|strong="H5414"\w* \w en|strong="H5414"\w* moi-même, \w et|strong="H1419"\w* \w je|strong="H5414"\w* censurai \w les|strong="H5414"\w* principaux \w et|strong="H1419"\w* \w les|strong="H5414"\w* \w magistrats|strong="H5461"\w*, \w et|strong="H1419"\w* \w je|strong="H5414"\w* \w leur|strong="H5414"\w* \w dis|strong="H5414"\w*: \w Vous|strong="H5414"\w* prêtez \w à|strong="H5414"\w* \w intérêt|strong="H4855"\w* l'\w un|strong="H5414"\w* \w à|strong="H5414"\w* l'\w autre|strong="H5414"\w*? \w Et|strong="H1419"\w* \w je|strong="H5414"\w* convoquai \w contre|strong="H5921"\w* \w eux|strong="H5921"\w* \w une|strong="H5414"\w* \w grande|strong="H1419"\w* \w assemblée|strong="H6952"\w*;  
