\v 4 \w Jésus|strong="G2424"\w* \w lui|strong="G2532"\w* \w répondit|strong="G2532"\w* : « \w Il|strong="G2532"\w* \w est|strong="G3588"\w* \w écrit|strong="G1125"\w* : \qt L’homme ne vit pas seulement de pain, mais de toute parole de Dieu.\qt* »  
\v 5 \w Et|strong="G2532"\w* \w le|strong="G2532"\w* \w diable|strong="G2532"\w* \w l|strong="G2532"\w*’\w ayant|strong="G2532"\w* emmené \w sur|strong="G1722"\w* \w une|strong="G2532"\w* \w haute|strong="G2532"\w* montagne, \w lui|strong="G2532"\w* \w montra|strong="G1166"\w* \w en|strong="G1722"\w* \w un|strong="G2532"\w* \w instant|strong="G4743"\w* \w tous|strong="G3956"\w* \w les|strong="G2532"\w* \w royaumes|strong="G2532"\w* \w de|strong="G2532"\w* \w la|strong="G2532"\w* \w terre|strong="G3625"\w*,  
