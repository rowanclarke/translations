\p
\v 21 \w Con|strong="H5921"\w* respecto \w a|strong="H3068"\w* \w los|strong="H5921"\w* utensilios \w que|strong="H3588"\w* quedan \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w en|strong="H5921"\w* \w el|strong="H5921"\w* palacio \w del|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w* \w y|strong="H3588"\w* \w en|strong="H5921"\w* Jerusalén, \nd \+w Yavé|strong="H3068"\+w*\nd* \w de|strong="H5921"\w* \w las|strong="H5921"\w* huestes, \nd ʼElohim\nd* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, dice:  
\v 22 \wj \+w Serán|strong="H1961"\+w* llevados \+w a|strong="H3068"\+w* Babilonia, \+w y|strong="H5704"\+w* \+w allí|strong="H8033"\+w* \+w estarán|strong="H1961"\+w* \+w hasta|strong="H5704"\+w* el \+w día|strong="H3117"\+w* \+w cuando|strong="H3117"\+w* me acuerde \+w de|strong="H5704"\+w* ellos, \wj*\w dice|strong="H5002"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*. \wj \+w Entonces|strong="H3117"\+w* \+w los|strong="H1961"\+w* traeré \+w y|strong="H5704"\+w* \+w los|strong="H1961"\+w* restituiré \+w a|strong="H3068"\+w* \+w este|strong="H2088"\+w* \+w lugar|strong="H4725"\+w*.\wj*   
\c 28  
\s1 Un falso profeta  
\p
\v 1 En \w aquel|strong="H1931"\w* \w mismo|strong="H1931"\w* \w año|strong="H8141"\w*, \w al|strong="H4428"\w* \w principio|strong="H7225"\w* del \w reinado|strong="H4428"\w* \w de|strong="H1121"\w* Sedequías, en \w el|strong="H1931"\w* \w quinto|strong="H2549"\w* \w mes|strong="H2320"\w* del \w año|strong="H8141"\w* \w cuarto|strong="H7243"\w*, \w aconteció|strong="H1961"\w* \w que|strong="H1931"\w* \w Hananías|strong="H2608"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Azur|strong="H5809"\w*, \w quien|strong="H3605"\w* \w era|strong="H1961"\w* \w profeta|strong="H5030"\w* \w de|strong="H1121"\w* \w Gabaón|strong="H1391"\w*, me habló en \w la|strong="H1931"\w* \w Casa|strong="H1004"\w* \w de|strong="H1121"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* en presencia \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w sacerdotes|strong="H3548"\w* y \w de|strong="H1121"\w* \w todo|strong="H3605"\w* \w el|strong="H1931"\w* \w pueblo|strong="H5971"\w*:  
\v 2 \nd \+w Yavé|strong="H3068"\+w*\nd* de las huestes, \nd ʼElohim\nd* de \w Israel|strong="H3478"\w*, habló: ¡Quiebro el \w yugo|strong="H5923"\w* del \w rey|strong="H4428"\w* de Babilonia!  
\v 3 \w Dentro|strong="H5750"\w* \w de|strong="H4480"\w* \w dos|strong="H8141"\w* \w años|strong="H8141"\w* devolveré \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w lugar|strong="H4725"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* utensilios \w de|strong="H4480"\w* \w la|strong="H3605"\w* \w Casa|strong="H1004"\w* \w de|strong="H4480"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w que|strong="H4480"\w* \w Nabucodonosor|strong="H5019"\w*, \w rey|strong="H4428"\w* \w de|strong="H4480"\w* Babilonia, \w tomó|strong="H3947"\w* \w de|strong="H4480"\w* \w este|strong="H2088"\w* \w lugar|strong="H4725"\w* y \w los|strong="H3605"\w* \w llevó|strong="H3947"\w* \w a|strong="H3068"\w* Babilonia.  
\v 4 Jeconías, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* \w Joacim|strong="H3079"\w*, \w rey|strong="H4428"\w* \w de|strong="H3588"\w* \w Judá|strong="H3063"\w*, regresará \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w lugar|strong="H4725"\w* \w y|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* exiliados \w de|strong="H3588"\w* \w Judá|strong="H3063"\w* \w que|strong="H3588"\w* fueron \w a|strong="H3068"\w* Babilonia, \w dice|strong="H5002"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \w porque|strong="H3588"\w* \w quebraré|strong="H7665"\w* \w el|strong="H3588"\w* \w yugo|strong="H5923"\w* del \w rey|strong="H4428"\w* \w de|strong="H3588"\w* Babilonia.   
\p
\v 5 Entonces \w el|strong="H3605"\w* \w profeta|strong="H5030"\w* \w Jeremías|strong="H3414"\w* respondió al \w profeta|strong="H5030"\w* \w Hananías|strong="H2608"\w* \w en|strong="H5975"\w* presencia \w de|strong="H5971"\w* \w los|strong="H3605"\w* \w sacerdotes|strong="H3548"\w* y \w de|strong="H5971"\w* \w todo|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w que|strong="H5971"\w* \w estaba|strong="H5975"\w* \w en|strong="H5975"\w* \w pie|strong="H5975"\w* \w en|strong="H5975"\w* \w la|strong="H3605"\w* \w Casa|strong="H1004"\w* \w de|strong="H5971"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.  
\v 6 \w Y|strong="H3068"\w* \w el|strong="H3605"\w* \w profeta|strong="H5030"\w* \w Jeremías|strong="H3414"\w* dijo: ¡Amén, \w así|strong="H3651"\w* \w lo|strong="H1697"\w* \w haga|strong="H6213"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*! ¡\w Cumpla|strong="H6965"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w tu|strong="H6213"\w* profecía y devuelva \w los|strong="H3605"\w* utensilios \w de|strong="H1697"\w* \w la|strong="H3605"\w* \w Casa|strong="H1004"\w* \w de|strong="H1697"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* y \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w cautivos|strong="H1473"\w* \w de|strong="H1697"\w* Babilonia \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w lugar|strong="H4725"\w*!  
\v 7 Sin embargo, \w escucha|strong="H8085"\w* \w ahora|strong="H4994"\w* \w esta|strong="H2088"\w* \w palabra|strong="H1697"\w* \w que|strong="H4994"\w* \w yo|strong="H4994"\w* \w hablo|strong="H1696"\w* \w a|strong="H3068"\w* tus \w oídos|strong="H8085"\w* y \w a|strong="H3068"\w* \w oídos|strong="H8085"\w* \w de|strong="H5971"\w* \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w*:  
\v 8 \w Los|strong="H5921"\w* \w profetas|strong="H5030"\w* \w que|strong="H4480"\w* llegaron \w antes|strong="H6440"\w* \w de|strong="H4480"\w* \w ti|strong="H4480"\w* \w y|strong="H5921"\w* \w antes|strong="H6440"\w* \w de|strong="H4480"\w* \w mí|strong="H5921"\w*, \w desde|strong="H4480"\w* antaño \w profetizaron|strong="H5012"\w* \w contra|strong="H5921"\w* \w muchas|strong="H7227"\w* tierras \w y|strong="H5921"\w* \w contra|strong="H5921"\w* \w grandes|strong="H1419"\w* \w reinos|strong="H4467"\w*, \w sobre|strong="H5921"\w* \w guerra|strong="H4421"\w*, calamidad \w y|strong="H5921"\w* \w pestilencia|strong="H1698"\w*.  
\v 9 \w El|strong="H5030"\w* \w profeta|strong="H5030"\w* \w que|strong="H3045"\w* \w profetiza|strong="H5012"\w* \w paz|strong="H7965"\w*, cuando \w se|strong="H3045"\w* cumpla la \w palabra|strong="H1697"\w* \w de|strong="H1697"\w* ese \w profeta|strong="H5030"\w*, será reconocido como uno \w que|strong="H3045"\w* en verdad \w envió|strong="H7971"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.   
\p
\v 10 Entonces \w el|strong="H5921"\w* \w profeta|strong="H5030"\w* \w Hananías|strong="H2608"\w* \w quitó|strong="H3947"\w* \w el|strong="H5921"\w* \w yugo|strong="H5921"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* nuca \w del|strong="H5921"\w* \w profeta|strong="H5030"\w* \w Jeremías|strong="H3414"\w*, \w y|strong="H5921"\w* \w lo|strong="H5921"\w* \w quebró|strong="H7665"\w*.  
\v 11 \w Hananías|strong="H2608"\w* habló \w en|strong="H5921"\w* presencia \w de|strong="H5921"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w*: \nd \+w Yavé|strong="H3068"\+w*\nd* dice: \w Dentro|strong="H5750"\w* \w de|strong="H5921"\w* \w dos|strong="H8141"\w* \w años|strong="H8141"\w* \w quebraré|strong="H7665"\w* \w el|strong="H5921"\w* \w yugo|strong="H5923"\w* \w de|strong="H5921"\w* \w Nabucodonosor|strong="H5019"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Babilonia, \w que|strong="H5921"\w* \w llevan|strong="H3212"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* nuca tantas \w naciones|strong="H1471"\w*. \w Y|strong="H3068"\w* \w Jeremías|strong="H3414"\w* \w siguió|strong="H3212"\w* su \w camino|strong="H1870"\w*.   
\p
\v 12 \w Después|strong="H5921"\w* \w que|strong="H5921"\w* \w el|strong="H5921"\w* \w profeta|strong="H5030"\w* \w Hananías|strong="H2608"\w* rompió \w el|strong="H5921"\w* \w yugo|strong="H5921"\w* \w que|strong="H5921"\w* \w tenía|strong="H1961"\w* \w el|strong="H5921"\w* \w profeta|strong="H5030"\w* \w Jeremías|strong="H3414"\w* \w en|strong="H5921"\w* su nuca, \w la|strong="H5921"\w* \w Palabra|strong="H1697"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w Jeremías|strong="H3414"\w*:  
\v 13 \wj \+w Vé|strong="H1980"\+w*, habla \+w a|strong="H3068"\+w* \+w Hananías|strong="H2608"\+w*: \+nd \+w Yavé|strong="H3068"\+w*\+nd* dice: ¡\+w Yugos|strong="H4133"\+w* \+w de|strong="H8478"\+w* \+w madera|strong="H6086"\+w* \+w quebraste|strong="H7665"\+w*, pero \+w en|strong="H8478"\+w* \+w lugar|strong="H8478"\+w* \+w de|strong="H8478"\+w* ellos \+w harás|strong="H6213"\+w* \+w yugos|strong="H4133"\+w* \+w de|strong="H8478"\+w* \+w hierro|strong="H1270"\+w*!\wj*  
\v 14 \wj \+w Porque|strong="H3588"\+w* \+nd \+w Yavé|strong="H3068"\+w*\+nd* \+w de|strong="H5921"\+w* \+w las|strong="H5921"\+w* huestes, \+nd ʼElohim\+nd* \+w de|strong="H5921"\+w* \+w Israel|strong="H3478"\+w*, dice: \+w Yo|strong="H3588"\+w* \+w puse|strong="H5414"\+w* un \+w yugo|strong="H5923"\+w* \+w de|strong="H5921"\+w* \+w hierro|strong="H1270"\+w* \+w sobre|strong="H5921"\+w* \+w la|strong="H5921"\+w* nuca \+w de|strong="H5921"\+w* \+w todas|strong="H3605"\+w* estas \+w naciones|strong="H1471"\+w* \+w para|strong="H5921"\+w* \+w que|strong="H3588"\+w* sirvan \+w a|strong="H3068"\+w* \+w Nabucodonosor|strong="H5019"\+w*, \+w rey|strong="H4428"\+w* \+w de|strong="H5921"\+w* Babilonia, \+w y|strong="H1571"\+w* \+w ellas|strong="H5921"\+w* \+w le|strong="H5921"\+w* \+w servirán|strong="H5647"\+w*. \+w También|strong="H1571"\+w* \+w le|strong="H5921"\+w* \+w di|strong="H5414"\+w* \+w los|strong="H5921"\+w* \+w animales|strong="H2416"\+w* \+w del|strong="H5921"\+w* \+w campo|strong="H7704"\+w*.\wj*   
\p
