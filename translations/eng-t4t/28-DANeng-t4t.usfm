\mt2 This book contains the account of Daniel foretelling about God controlling all nations of the world and about the coming one. We call this book  
\mt1 Daniel  
\c 1  
\s1 Daniel was taken to Babylon  
\p
\v 1 \w After|strong="H5921"\w* \w King|strong="H4428"\w* \w Jehoiakim|strong="H3079"\w* \w had|strong="H4428"\w* been ruling \w in|strong="H8141"\w* \w Judah|strong="H3063"\w* \w for|strong="H5921"\w* almost \w three|strong="H7969"\w* \w years|strong="H8141"\w*, \w King|strong="H4428"\w* \w Nebuchadnezzar|strong="H5019"\w* \w of|strong="H4428"\w* Babylon \w came|strong="H3063"\w* \w to|strong="H5921"\w* \w Jerusalem|strong="H3389"\w* \add with his army\add* \w and|strong="H3063"\w* surrounded \w the|strong="H5921"\w* city.  
\v 2  \add After two years,\add* \w Yahweh|strong="H3068"\w* \w allowed|strong="H5414"\w* Nebuchadnezzar’s \add soldiers \add* \w to|strong="H5414"\w* capture \w Jehoiakim|strong="H3079"\w*, \add who was the\add* \w King|strong="H4428"\w* \w of|strong="H4428"\w* \w Judah|strong="H3063"\w*. \w They|strong="H3027"\w* \w also|strong="H3027"\w* \w took|strong="H4428"\w* \w some|strong="H3027"\w* \w of|strong="H4428"\w* \w the|strong="H5414"\w* \w things|strong="H3627"\w* \w that|strong="H5414"\w* \w were|strong="H3027"\w* \w in|strong="H1004"\w* \w the|strong="H5414"\w* \w temple|strong="H1004"\w* \w of|strong="H4428"\w* \w God|strong="H5414"\w*, \w and|strong="H3063"\w* \w took|strong="H4428"\w* \w them|strong="H5414"\w* \w to|strong="H5414"\w* Babylonia. There Nebuchadnezzar \w put|strong="H5414"\w* \w them|strong="H5414"\w* \w in|strong="H1004"\w* \w the|strong="H5414"\w* \w temple|strong="H1004"\w* \w of|strong="H4428"\w* \w his|strong="H5414"\w* \w god|strong="H5414"\w*.   
\p
\v 3 \w Then|strong="H4428"\w* Nebuchadnezzar commanded Ashpenaz, \w the|strong="H4480"\w* \w chief|strong="H7227"\w* \w official|strong="H5631"\w* \w in|strong="H3478"\w* \w his|strong="H3478"\w* palace, \w to|strong="H3478"\w* bring \add to him\add* \w some|strong="H4480"\w* \w of|strong="H1121"\w* \w the|strong="H4480"\w* Israeli \w men|strong="H1121"\w* \add whom they had brought to Babylon. He wanted men \add* \w who|strong="H1121"\w* belonged \w to|strong="H3478"\w* important \w families|strong="H1121"\w*, \w including|strong="H4428"\w* \w the|strong="H4480"\w* \w family|strong="H2233"\w* \w of|strong="H1121"\w* \w the|strong="H4480"\w* \w King|strong="H4428"\w* \w of|strong="H1121"\w* Judah.  
\v 4  \add King Nebuchadnezzar wanted only\add* \w men|strong="H3206"\w* \w who|strong="H3605"\w* \w were|strong="H5612"\w* \w very|strong="H3045"\w* healthy, \w handsome|strong="H2896"\w*/\w good-looking|strong="H2896"\w*, \w wise|strong="H7919"\w*, well-educated, \w capable|strong="H3581"\w* \w of|strong="H4428"\w* \w learning|strong="H5612"\w* many \w things|strong="H3605"\w*, \w and|strong="H4428"\w* suitable \w for|strong="H4428"\w* working \w in|strong="H4428"\w* \w the|strong="H3605"\w* \w palace|strong="H1964"\w*. \w He|strong="H3605"\w* \w also|strong="H4428"\w* wanted \w to|strong="H4428"\w* \w teach|strong="H3925"\w* \w them|strong="H5975"\w* \w the|strong="H3605"\w* \w Babylonian|strong="H3778"\w* \w language|strong="H3956"\w* \w and|strong="H4428"\w* \w have|strong="H3045"\w* \w them|strong="H5975"\w* \w read|strong="H5612"\w* \w things|strong="H3605"\w* \w that|strong="H3045"\w* \w had|strong="H4428"\w* \w been|strong="H3605"\w* written \w in|strong="H4428"\w* \w the|strong="H3605"\w* \w Babylonian|strong="H3778"\w* \w language|strong="H3956"\w*.  
\v 5 \w The|strong="H6440"\w* \w king|strong="H4428"\w* commanded \add his servants\add*, “Give \w them|strong="H6440"\w* \w the|strong="H6440"\w* \w same|strong="H1697"\w* kind \w of|strong="H4428"\w* \w food|strong="H6598"\w* \w and|strong="H4428"\w* \w wine|strong="H3196"\w* \w that|strong="H3117"\w* \w is|strong="H3117"\w* given \w to|strong="H6440"\w* \w me|strong="H6440"\w*. Train \w them|strong="H6440"\w* \w for|strong="H6440"\w* \w three|strong="H7969"\w* \w years|strong="H8141"\w*. \w Then|strong="H4428"\w* \w they|strong="H3117"\w* \w will|strong="H4428"\w* \w become|strong="H1431"\w* \w my|strong="H6440"\w* \w servants|strong="H6440"\w*.”   
\p
\v 6 Among \w the|strong="H1961"\w* \w young|strong="H1121"\w* Israeli \w men|strong="H1121"\w* \add who were chosen\add* \w were|strong="H1961"\w* \add me\add*, \w Daniel|strong="H1840"\w*, \w and|strong="H1121"\w* \w Hananiah|strong="H2608"\w*, \w Mishael|strong="H4332"\w*, \w and|strong="H1121"\w* \w Azariah|strong="H5838"\w*, \w who|strong="H1121"\w* all \w came|strong="H1961"\w* \w from|strong="H1121"\w* \w Judah|strong="H3063"\w*.  
\v 7 \w But|strong="H1992"\w* Ashpenaz \w gave|strong="H7760"\w* \w us|strong="H7760"\w* \add Babylonian\add* \w names|strong="H8034"\w*. \w The|strong="H7760"\w* \w name|strong="H8034"\w* \w he|strong="H7760"\w* \w gave|strong="H7760"\w* \w to|strong="H8034"\w* \w me|strong="H7760"\w* \w was|strong="H8034"\w* \w Belteshazzar|strong="H1095"\w*, \w the|strong="H7760"\w* \w name|strong="H8034"\w* \w he|strong="H7760"\w* \w gave|strong="H7760"\w* \w to|strong="H8034"\w* \w Hananiah|strong="H2608"\w* \w was|strong="H8034"\w* \w Shadrach|strong="H7714"\w*, \w the|strong="H7760"\w* \w name|strong="H8034"\w* \w he|strong="H7760"\w* \w gave|strong="H7760"\w* \w to|strong="H8034"\w* \w Mishael|strong="H4332"\w* \w was|strong="H8034"\w* \w Meshach|strong="H4335"\w*, \w and|strong="H8269"\w* \w the|strong="H7760"\w* \w name|strong="H8034"\w* \w he|strong="H7760"\w* \w gave|strong="H7760"\w* \w to|strong="H8034"\w* \w Azariah|strong="H5838"\w* \w was|strong="H8034"\w* Abednego.   
\p
\v 8 \w But|strong="H3808"\w* \w I|strong="H7760"\w* decided \w that|strong="H4428"\w* \w I|strong="H7760"\w* \w would|strong="H4428"\w* \w not|strong="H3808"\w* eat \w the|strong="H5921"\w* kind \w of|strong="H4428"\w* \w food|strong="H6598"\w* \w that|strong="H4428"\w* \w the|strong="H5921"\w* \w king|strong="H4428"\w* ate, \w or|strong="H3808"\w* \w drink|strong="H4960"\w* \w the|strong="H5921"\w* \w wine|strong="H3196"\w* \w that|strong="H4428"\w* \w he|strong="H3808"\w* \w drank|strong="H4960"\w*, \w because|strong="H5921"\w* \w that|strong="H4428"\w* \w would|strong="H4428"\w* \w make|strong="H7760"\w* \w me|strong="H5921"\w* ◄ritually \w defiled|strong="H1351"\w*/unacceptable \w to|strong="H5921"\w* \w God|strong="H3808"\w*►. \w So|strong="H3808"\w* \w I|strong="H7760"\w* \w asked|strong="H1245"\w* Ashpenaz \w to|strong="H5921"\w* allow \w me|strong="H5921"\w* \w to|strong="H5921"\w* eat \w and|strong="H4428"\w* \w drink|strong="H4960"\w* other \w things|strong="H3808"\w*.  
\v 9 \w God|strong="H5414"\w* \w had|strong="H5414"\w* \w caused|strong="H5414"\w* Ashpenaz \w to|strong="H5414"\w* greatly \w respect|strong="H6440"\w* \w me|strong="H6440"\w*,  
\v 10 \w but|strong="H7200"\w* \w he|strong="H4480"\w* \w was|strong="H4428"\w* worried \w about|strong="H4480"\w* \w what|strong="H4100"\w* \w I|strong="H7200"\w* suggested. \w He|strong="H4480"\w* said, “\w My|strong="H7200"\w* \w master|strong="H8269"\w*, \w the|strong="H6440"\w* \w king|strong="H4428"\w*, \w has|strong="H4428"\w* commanded \w that|strong="H7200"\w* \w you|strong="H6440"\w* \w eat|strong="H3978"\w* \w the|strong="H6440"\w* kinds \w of|strong="H4428"\w* \w food|strong="H3978"\w* \w and|strong="H4428"\w* \w drink|strong="H4960"\w* \w that|strong="H7200"\w* \w he|strong="H4480"\w* \w does|strong="H4100"\w*. \w If|strong="H7200"\w* \add you eat other things and as a result\add* \w you|strong="H6440"\w* \w become|strong="H7200"\w* \w more|strong="H4480"\w* thin \w and|strong="H4428"\w* pale \w than|strong="H4480"\w* \w the|strong="H6440"\w* other \w young|strong="H3206"\w* \w men|strong="H7218"\w* \w who|strong="H4428"\w* \w are|strong="H4100"\w* \w your|strong="H6440"\w* \w age|strong="H1524"\w*, \w he|strong="H4480"\w* \w will|strong="H4428"\w* \add order his soldiers to\add* cut \w off|strong="H4480"\w* \w my|strong="H7200"\w* \w head|strong="H7218"\w* \w because|strong="H6440"\w* \w of|strong="H4428"\w* \w what|strong="H4100"\w* \w you|strong="H6440"\w* \w have|strong="H7200"\w* done!”   
\p
\v 11 Ashpenaz \w had|strong="H8269"\w* ordered \w a|strong="H3068"\w* guard \w to|strong="H5921"\w* watch \w me|strong="H5921"\w*, \w Hananiah|strong="H2608"\w*, \w Mishael|strong="H4332"\w*, \w and|strong="H8269"\w* \w Azariah|strong="H5838"\w*.  
\v 12 \w So|strong="H4480"\w* \w I|strong="H3117"\w* said \w to|strong="H5414"\w* \w this|strong="H5414"\w* guard: “\add Please\add* \w test|strong="H5254"\w* \w us|strong="H5414"\w* \w for|strong="H4325"\w* \w ten|strong="H6235"\w* \w days|strong="H3117"\w*. \add During that time\add* \w give|strong="H5414"\w* \w us|strong="H5414"\w* \add only\add* \w vegetables|strong="H2235"\w* \w to|strong="H5414"\w* eat \w and|strong="H3117"\w* \w water|strong="H4325"\w* \w to|strong="H5414"\w* \w drink|strong="H8354"\w*.  
\v 13 \w After|strong="H7200"\w* ten days, \w see|strong="H7200"\w* \w how|strong="H6213"\w* \w we|strong="H3068"\w* \w look|strong="H7200"\w*, \w and|strong="H4428"\w* \w see|strong="H7200"\w* \w how|strong="H6213"\w* \w the|strong="H6440"\w* other \w young|strong="H3206"\w* \w men|strong="H3206"\w* \w look|strong="H7200"\w*, \w the|strong="H6440"\w* \w ones|strong="H3206"\w* \w who|strong="H5650"\w* \w are|strong="H5650"\w* eating \w the|strong="H6440"\w* kind \w of|strong="H4428"\w* \w food|strong="H6598"\w* \w that|strong="H7200"\w* \w the|strong="H6440"\w* \w king|strong="H4428"\w* eats. \w Then|strong="H6213"\w* \w you|strong="H6440"\w* \w can|strong="H6213"\w* \w decide|strong="H7200"\w* \w about|strong="H6213"\w* \add what food you will let us eat\add*.”  
