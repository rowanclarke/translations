\p \k Caak kamoeh:\k*
\li2 Mt 11:19
\p \k Caaknoi:\k*
\li2 Mt 15:27; Lk 16:21
\p \k Cak poe:\k*
\li2 Mt 18:8; 25:46; Lk 16:9; Jn 3:36; 4:14; 5:24; Tk 13:46; Kl 6:8; 1 Ti 1:16
