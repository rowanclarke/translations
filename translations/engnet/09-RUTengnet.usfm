\c 3
\p 
\v 1 \w At|strong="H3808"\w* \w that|strong="H3808"\w* time, \w Naomi|strong="H5281"\w*, \w her|strong="H3190"\w* \w mother-in-law|strong="H2545"\w*, said \w to|strong="H1245"\w* \w her|strong="H3190"\w*, “\w My|strong="H1245"\w* \w daughter|strong="H1323"\w*, \w I|strong="H3808"\w* \w must|strong="H3808"\w* \w find|strong="H1245"\w* \w a|strong="H3068"\w* home \w for|strong="H1245"\w* \w you|strong="H3808"\w* \w so|strong="H3808"\w* \w you|strong="H3808"\w* \w will|strong="H3808"\w* \w be|strong="H3808"\w* secure.
