\v 42 \w Adina|strong="H5721"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Siza \w rubenita|strong="H7206"\w*, \w jefe|strong="H7218"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* rubenitas, \w y|strong="H5921"\w* \w con|strong="H5921"\w* \w él|strong="H5921"\w* 30,  
\v 43 \w Hanán|strong="H2605"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Maaca, Josafat mitnita,  
\v 44 Uzías astarotita, Sama y \w Jehiel|strong="H3273"\w*, \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Hota aroerita,  
\v 45 \w Jediael|strong="H3043"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Simri|strong="H8113"\w*, y su hermano Joha tizita,  
\v 46 Eliel mahavita, Jerebai y Josavía, \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Elnaam, Itma \w moabita|strong="H4125"\w*,  
\v 47 Eliel, \w Obed|strong="H5744"\w*, Haasiel mesobaíta.   
\c 12  
\s1 Los ejércitos de David  
\p
\v 1 \w Éstos|strong="H1992"\w* eran \w los|strong="H1992"\w* \w que|strong="H1121"\w* \w fueron|strong="H1732"\w* \w a|strong="H3068"\w* \w David|strong="H1732"\w* \w en|strong="H5750"\w* \w Siclag|strong="H6860"\w*, cuando \w él|strong="H1121"\w* estaba \w aún|strong="H5750"\w* \w encerrado|strong="H6113"\w* \w por|strong="H6440"\w* \w causa|strong="H6440"\w* \w de|strong="H6440"\w* \w Saúl|strong="H7586"\w*, \w hijo|strong="H1121"\w* \w de|strong="H6440"\w* \w Cis|strong="H7027"\w*, y eran \w de|strong="H6440"\w* \w los|strong="H1992"\w* \w valientes|strong="H1368"\w* \w que|strong="H1121"\w* \w lo|strong="H1992"\w* \w ayudaron|strong="H5826"\w* \w en|strong="H5750"\w* la \w guerra|strong="H4421"\w*.  
\v 2 Estaban \w armados|strong="H5401"\w* con \w arcos|strong="H7198"\w*. Usaban ambas \w manos|strong="H8041"\w* para tirar piedras con honda y flechas con \w arco|strong="H7198"\w*.  
\p De los hermanos de \w Saúl|strong="H7586"\w*, de \w Benjamín|strong="H1144"\w*:  
\v 3 \w el|strong="H1121"\w* \w jefe|strong="H7218"\w* después \w Joás|strong="H3101"\w*, Ahiezer, \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Semaa gabaatita, Jeziel y \w Pelet|strong="H6404"\w*, \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Azmavet, Beraca, \w Jehú|strong="H3058"\w* anatotita,  
\v 4 \w Ismaías|strong="H3460"\w* \w gabaonita|strong="H1393"\w*, \w valiente|strong="H1368"\w* \w entre|strong="H5921"\w* \w los|strong="H5921"\w* 30 \w y|strong="H5921"\w* jefe \w de|strong="H5921"\w* \w los|strong="H5921"\w* 30, Jeremías, Jahaziel, Johanán, Jozabad gederatita,  
\v 5 Eluzai, Jerimot, Bealías, Semarías, Sefatías harufita,  
\v 6 Elcana, Isías, Hazi, Azareel, Joezer,  
\v 7 Joela y Zebadías, hijos de Jeroham de Gedor.   
\p
\v 8 También \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w de|strong="H4480"\w* Gad \w se|strong="H4480"\w* pasaron \w a|strong="H3068"\w* David, \w a|strong="H3068"\w* la fortaleza \w en|strong="H4480"\w* \w el|strong="H1121"\w* desierto, \w hombres|strong="H1121"\w* \w fuertes|strong="H1121"\w* y \w valientes|strong="H1121"\w*, entrenados \w para|strong="H4480"\w* la guerra, diestros \w con|strong="H4480"\w* \w el|strong="H1121"\w* escudo y la lanza, cuyas caras eran como caras \w de|strong="H4480"\w* leones. Eran tan ligeros como las gacelas \w en|strong="H4480"\w* las montañas.  
\v 9 Ezer \w el|strong="H5921"\w* primero, Obadías \w el|strong="H5921"\w* segundo, Eliab \w el|strong="H5921"\w* tercero,  
\v 10 Mismana el cuarto, Jeremías el quinto,  
\v 11 Atai el sexto, Eliel el séptimo,  
\v 12 Johanán el octavo, Elzabad el noveno,  
\v 13 Jeremías el décimo y Macbanai el undécimo.   
\p
\v 14 Éstos fueron jefes del ejército de los hijos de Gad. El menor tenía \w a|strong="H3068"\w* su cargo 100 hombres, y el mayor de ellos, 1.000.  
\v 15 Éstos pasaron \w el|strong="H1121"\w* Jordán \w el|strong="H1121"\w* mes primero cuando estaba desbordado por todas sus riberas. Pusieron en fuga \w a|strong="H3068"\w* todos \w los|strong="H1121"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* valles, tanto al oriente como al occidente.   
\p
\v 16 También algunos \w de|strong="H5921"\w* \w los|strong="H1992"\w* hijos \w de|strong="H5921"\w* Benjamín \w y|strong="H5921"\w* \w de|strong="H5921"\w* Judá fueron \w a|strong="H3068"\w* David \w a|strong="H3068"\w* \w la|strong="H1931"\w* fortaleza.  
\v 17 \w David|strong="H1732"\w* salió \w a|strong="H3068"\w* recibirlos \w y|strong="H5704"\w* les habló: Si vienen \w a|strong="H3068"\w* mí \w en|strong="H4480"\w* paz \w para|strong="H5704"\w* ayudarme, mi corazón \w se|strong="H4480"\w* unirá \w a|strong="H3068"\w* ustedes. Pero si vienen \w para|strong="H5704"\w* entregarme \w a|strong="H3068"\w* mis enemigos, sin haber iniquidad \w en|strong="H4480"\w* mis manos, ¡\w que|strong="H4480"\w* \w el|strong="H1121"\w* \nd ʼElohim\nd* \w de|strong="H4480"\w* nuestros antepasados \w lo|strong="H5704"\w* vea \w y|strong="H5704"\w* \w se|strong="H4480"\w* \w lo|strong="H5704"\w* demande!   
\p
\v 18 Entonces \w el|strong="H5921"\w* Espíritu llegó \w sobre|strong="H5921"\w* Amasai, jefe \w de|strong="H5921"\w* \w los|strong="H5921"\w* 30, \w y|strong="H5921"\w* dijo: ¡\w Somos|strong="H1961"\w* tuyos, oh \w David|strong="H1732"\w*, \w y|strong="H5921"\w* \w contigo|strong="H5921"\w* estamos, hijo \w de|strong="H5921"\w* Isaí! ¡\w Paz|strong="H7965"\w*, \w paz|strong="H7965"\w* \w a|strong="H3068"\w* \w ti|strong="H5921"\w*, \w y|strong="H5921"\w* \w paz|strong="H7965"\w* \w a|strong="H3068"\w* tus ayudantes, \w pues|strong="H7200"\w* \w también|strong="H3162"\w* tu \nd ʼElohim\nd* \w te|strong="H5921"\w* \w ayuda|strong="H5826"\w*!  
\p \w David|strong="H1732"\w* \w los|strong="H5921"\w* recibió \w y|strong="H5921"\w* \w los|strong="H5921"\w* designó \w como|strong="H1961"\w* jefes \w de|strong="H5921"\w* \w la|strong="H5921"\w* tropa.   
\p
\v 19 También algunos \w de|strong="H3588"\w* Manasés se pasaron \w a|strong="H3068"\w* \w David|strong="H1732"\w* \w cuando|strong="H3588"\w* iba \w con|strong="H5973"\w* \w los|strong="H1121"\w* filisteos \w a|strong="H3068"\w* \w la|strong="H3588"\w* batalla \w contra|strong="H5973"\w* Saúl. \w Pero|strong="H3588"\w* \w no|strong="H3588"\w* \w los|strong="H1121"\w* \w ayudó|strong="H5826"\w*, \w porque|strong="H3588"\w* \w los|strong="H1121"\w* \w jefes|strong="H7218"\w* \w de|strong="H3588"\w* \w los|strong="H1121"\w* filisteos tuvieron consejo \w y|strong="H3588"\w* lo despidieron, \w pues|strong="H3588"\w* dijeron: ¡\w Él|strong="H5973"\w* puede pasarse \w a|strong="H3068"\w* \w su|strong="H3588"\w* \tl ʼadón\tl* Saúl \w con|strong="H5973"\w* nuestras \w cabezas|strong="H7218"\w*!  
\v 20 \w Cuando|strong="H3588"\w* \w él|strong="H5921"\w* iba \w a|strong="H3068"\w* Siclag, \add algunos\add* \w de|strong="H4480"\w* \w los|strong="H5921"\w* \w de|strong="H4480"\w* \w Manasés|strong="H4519"\w* \w se|strong="H5921"\w* pasaron \w a|strong="H3068"\w* \w él|strong="H5921"\w*: Adnas, Jozabad, Jediaiel, Micael, Jozabad, Eliú \w y|strong="H3588"\w* Ziletai, \w jefes|strong="H7218"\w* \w de|strong="H4480"\w* millares \w de|strong="H4480"\w* \w los|strong="H5921"\w* \w de|strong="H4480"\w* \w Manasés|strong="H4519"\w*.  
\v 21 Éstos ayudaron \w a|strong="H3068"\w* David \w contra|strong="H5921"\w* \w la|strong="H5921"\w* banda armada, pues todos \w ellos|strong="H5921"\w* eran hombres valientes \w y|strong="H5921"\w* \w fueron|strong="H3212"\w* \w jefes|strong="H7218"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* ejército.  
\v 22 \w En|strong="H5921"\w* \w aquel|strong="H3605"\w* tiempo acudían día \w tras|strong="H5973"\w* día \w a|strong="H3068"\w* \w David|strong="H1732"\w* \w para|strong="H5921"\w* ayudarlo, \w hasta|strong="H5921"\w* \w que|strong="H3588"\w* \w se|strong="H1961"\w* formó un gran \w ejército|strong="H2428"\w*, \w como|strong="H3588"\w* \w el|strong="H5921"\w* \w ejército|strong="H2428"\w* \w de|strong="H5921"\w* \nd ʼElohim\nd*.   
\s1 Guerreros que acudieron a la proclamación de David como rey.  
\p
\v 23 Éste \w es|strong="H3588"\w* \w el|strong="H5921"\w* número \w de|strong="H5921"\w* \w los|strong="H5921"\w* jefes \w que|strong="H3588"\w* estaban listos Kiriath Jearim \w para|strong="H5704"\w* \w la|strong="H5921"\w* guerra, \w que|strong="H3588"\w* \w fueron|strong="H1732"\w* \w a|strong="H3068"\w* \w David|strong="H1732"\w* \w en|strong="H5921"\w* Hebrón \w a|strong="H3068"\w* fin \w de|strong="H5921"\w* traspasarle \w el|strong="H5921"\w* reino \w de|strong="H5921"\w* Saúl \w según|strong="H5921"\w* \w la|strong="H5921"\w* Palabra \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*:  
\v 24 \w De|strong="H5921"\w* \w los|strong="H5921"\w* hijos \w de|strong="H5921"\w* Judá \w que|strong="H5921"\w* portaban escudo \w y|strong="H5921"\w* lanza: 6.800, listos \w para|strong="H5921"\w* \w la|strong="H5921"\w* \w guerra|strong="H6635"\w*.  
\v 25 \w De|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Simeón: 6.100 \w hombres|strong="H1121"\w*, \w valientes|strong="H1121"\w* y esforzados para la \w guerra|strong="H6635"\w*.  
\v 26 \w De|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* Leví: 4.600,  
\v 27 junto \w con|strong="H4480"\w* Joiada, jefe \w de|strong="H4480"\w* \w los|strong="H1121"\w* descendientes \w de|strong="H4480"\w* Aarón, y \w con|strong="H4480"\w* \w él|strong="H1121"\w* 3.700,  
\v 28 y Sadoc, joven valiente y esforzado, \w con|strong="H5973"\w* 22 \w de|strong="H5973"\w* \w los|strong="H5973"\w* jefes \w de|strong="H5973"\w* su casa paterna.  
\v 29 \w De|strong="H8269"\w* los hijos \w de|strong="H8269"\w* Benjamín, parientes \w de|strong="H8269"\w* Saúl, 3.000, pues hasta entonces la mayor parte \w de|strong="H8269"\w* ellos mantenían su lealtad \w a|strong="H3068"\w* la \w casa|strong="H1004"\w* \w de|strong="H8269"\w* Saúl.  
\v 30 \w De|strong="H4480"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* Efraín, 20.800, muy \w valientes|strong="H1121"\w* \w e|strong="H3068"\w* ilustres varones \w en|strong="H4480"\w* sus \w casas|strong="H1004"\w* paternas.  
\v 31 \w De|strong="H4480"\w* la media tribu \w de|strong="H4480"\w* Manasés, 18.000, quienes fueron designados \w por|strong="H4480"\w* \w nombre|strong="H8034"\w* \w para|strong="H4480"\w* ir \w a|strong="H3068"\w* proclamar \w a|strong="H3068"\w* David como rey.  
\v 32 De los hijos de Isacar, 200 jefes, entendidos en distinguir los tiempos, que sabían lo que Israel debía hacer y cuyas órdenes seguían todos sus hermanos.  
\v 33 \w De|strong="H5921"\w* Zabulón, 50.000 \w hombres|strong="H1121"\w* \w que|strong="H4100"\w* salían \w a|strong="H3068"\w* \w la|strong="H5921"\w* batalla, prontos \w para|strong="H5921"\w* \w la|strong="H5921"\w* guerra \w con|strong="H5921"\w* \w toda|strong="H3605"\w* clase \w de|strong="H5921"\w* armas \w de|strong="H5921"\w* guerra, dispuestos \w a|strong="H3068"\w* pelear sin doblez \w de|strong="H5921"\w* corazón.  
\v 34 De Neftalí, 1.000 jefes y 36.000 con escudo y lanza.  
\v 35 \w De|strong="H5973"\w* \w los|strong="H5973"\w* \w de|strong="H5973"\w* Dan, dispuestos \w a|strong="H3068"\w* pelear, 28.600.  
\v 36 \w De|strong="H4480"\w* Aser, 40.000 \w dispuestos|strong="H6186"\w* \w para|strong="H4480"\w* la \w guerra|strong="H4421"\w* y preparados \w para|strong="H4480"\w* pelear.  
\v 37 Del otro lado del Jordán, de los rubenitas, gaditas y de la media tribu de Manasés: 120.000 con toda clase de armas de \w guerra|strong="H4421"\w*.   
\p
\v 38 \w Todos|strong="H3605"\w* \w estos|strong="H3605"\w* hombres \w de|strong="H4480"\w* \w guerra|strong="H4421"\w*, listos \w para|strong="H4480"\w* \w la|strong="H3605"\w* \w batalla|strong="H4421"\w*, fueron \w con|strong="H4480"\w* corazón sincero \w a|strong="H3068"\w* Hebrón \w para|strong="H4480"\w* proclamar \w a|strong="H3068"\w* David como rey \w sobre|strong="H4480"\w* \w todo|strong="H3605"\w* Israel. \w Todos|strong="H3605"\w* \w los|strong="H3605"\w* demás \w de|strong="H4480"\w* Israel eran también \w del|strong="H4480"\w* \w mismo|strong="H3605"\w* sentir \w para|strong="H4480"\w* proclamar rey \w a|strong="H3068"\w* David.   
\p
\v 39 Estuvieron allí \w con|strong="H5921"\w* \w David|strong="H1732"\w* tres días. Comían \w y|strong="H1571"\w* bebían \w porque|strong="H5921"\w* sus hermanos prepararon \w para|strong="H5921"\w* \w ellos|strong="H5921"\w*.  
\v 40 También \w los|strong="H5973"\w* vecinos, \w hasta|strong="H3117"\w* Isacar, Zabulón \w y|strong="H3588"\w* Neftalí, llevaron alimentos \w en|strong="H5973"\w* asnos, camellos, mulas \w y|strong="H3588"\w* bueyes: provisiones \w de|strong="H3588"\w* harina, tortas \w de|strong="H3588"\w* higos, uvas pasas, \w vino|strong="H1961"\w* \w y|strong="H3588"\w* aceite, \w y|strong="H3588"\w* bueyes \w y|strong="H3588"\w* ovejas \w en|strong="H5973"\w* abundancia, \w porque|strong="H3588"\w* \w había|strong="H1961"\w* alegría \w en|strong="H5973"\w* Israel.   
\c 13  
\s1 Traslado del Arca de \nd Yavé\nd*  
\p
\v 1 Entonces \w David|strong="H1732"\w* \w tomó|strong="H3289"\w* \w consejo|strong="H3289"\w* \w con|strong="H5973"\w* \w los|strong="H3605"\w* \w jefes|strong="H8269"\w* \w de|strong="H5973"\w* millares y \w de|strong="H5973"\w* centenas, \w los|strong="H3605"\w* oficiales \w de|strong="H5973"\w* \w la|strong="H3605"\w* casa y \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w jefes|strong="H8269"\w*.  
\v 2 \w Y|strong="H3068"\w* \w David|strong="H1732"\w* dijo \w a|strong="H3068"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* \w congregación|strong="H6951"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*: \w Si|strong="H5921"\w* \w les|strong="H5973"\w* parece \w bien|strong="H2895"\w* \w y|strong="H5921"\w* \w si|strong="H5921"\w* es \w la|strong="H5921"\w* voluntad \w de|strong="H4480"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* nuestro \nd ʼElohim\nd*, \w enviemos|strong="H7971"\w* mensajeros \w a|strong="H3068"\w* \w todas|strong="H3605"\w* \w partes|strong="H6555"\w* \add a llamar a\add* nuestros hermanos \w que|strong="H4480"\w* \w quedaron|strong="H7604"\w* \w en|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* tierras \w de|strong="H4480"\w* \w Israel|strong="H3478"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w sacerdotes|strong="H3548"\w* \w y|strong="H5921"\w* \w levitas|strong="H3881"\w* \w que|strong="H4480"\w* están \w con|strong="H5973"\w* \w ellos|strong="H5921"\w* \w en|strong="H5921"\w* sus \w ciudades|strong="H5892"\w* \w y|strong="H5921"\w* campos \w de|strong="H4480"\w* \w alrededor|strong="H5921"\w*, \w para|strong="H5921"\w* \w que|strong="H4480"\w* \w se|strong="H5921"\w* reúnan \w con|strong="H5973"\w* \w nosotros|strong="H3605"\w*.  
\v 3 Traigamos \w hasta|strong="H3117"\w* nosotros \w el|strong="H3588"\w* Arca \w de|strong="H3588"\w* nuestro \nd ʼElohim\nd*, \w porque|strong="H3588"\w* \w no|strong="H3808"\w* \w la|strong="H3588"\w* buscamos \w en|strong="H3588"\w* \w el|strong="H3588"\w* \w tiempo|strong="H3117"\w* \w de|strong="H3588"\w* \w Saúl|strong="H7586"\w*.  
\v 4 \w Toda|strong="H3605"\w* \w la|strong="H3605"\w* \w congregación|strong="H6951"\w* dijo \w que|strong="H3588"\w* \w se|strong="H3651"\w* hiciera \w así|strong="H3651"\w*, \w porque|strong="H3588"\w* \w el|strong="H3588"\w* \w asunto|strong="H1697"\w* \w pareció|strong="H3474"\w* \w bien|strong="H3588"\w* \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H3588"\w* \w pueblo|strong="H5971"\w*.   
\p
\v 5 Entonces \w David|strong="H1732"\w* reunió \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w*, \w desde|strong="H4480"\w* \w Sihor|strong="H7883"\w* \w de|strong="H4480"\w* \w Egipto|strong="H4714"\w* \w hasta|strong="H5704"\w* \w la|strong="H3605"\w* entrada \w de|strong="H4480"\w* Hamat, \w para|strong="H5704"\w* traer \w el|strong="H3605"\w* Arca \w de|strong="H4480"\w* \nd ʼElohim\nd* \w desde|strong="H4480"\w* Quiriat-jearim.  
\v 6 \w David|strong="H1732"\w* \w subió|strong="H5927"\w* con \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* \w a|strong="H3068"\w* \w Baala|strong="H1173"\w* de Quiriat-jearim, en \w Judá|strong="H3063"\w*, para traer de \w allí|strong="H8033"\w* \w el|strong="H3605"\w* Arca de \nd ʼElohim\nd*, \nd \+w Yavé|strong="H3068"\+w*\nd*, \w Quien|strong="H3605"\w* \w mora|strong="H3427"\w* \w entre|strong="H8033"\w* \w los|strong="H3427"\w* \w querubines|strong="H3742"\w*, sobre \w la|strong="H3605"\w* cual es \w invocado|strong="H7121"\w* su \w Nombre|strong="H8034"\w*.   
\p
\v 7 Trajeron \w el|strong="H5921"\w* Arca \w de|strong="H5921"\w* \nd ʼElohim\nd* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w de|strong="H5921"\w* Abinadab \w en|strong="H5921"\w* una carroza \w nueva|strong="H2319"\w*. Uza \w y|strong="H5921"\w* Ahío \w guiaban|strong="H5090"\w* \w la|strong="H5921"\w* carroza.  
\v 8 \w David|strong="H1732"\w* \w y|strong="H5797"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* se regocijaban \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \nd ʼElohim\nd* con \w todas|strong="H3605"\w* sus fuerzas, con cánticos, \w arpas|strong="H3658"\w*, \w salterios|strong="H5035"\w*, panderos, \w címbalos|strong="H4700"\w* \w y|strong="H5797"\w* \w trompetas|strong="H2689"\w*.   
\p
