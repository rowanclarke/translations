\c 56
\s1 Instrucciones morales
\p 
\v 1 \nd \w Yavé|strong="H3068"\w*\nd* dice: \wj \w Guarden|strong="H8104"\w* \w el|strong="H3588"\w* \w juicio|strong="H4941"\w* recto \w y|strong="H3588"\w* practiquen \w la|strong="H8104"\w* \w justicia|strong="H6666"\w*, \w porque|strong="H3588"\w* mi salvación está \w a|strong="H3068"\w* punto \w de|strong="H3588"\w* venir \w y|strong="H3588"\w* mi \w justicia|strong="H6666"\w* \w a|strong="H3068"\w* punto \w de|strong="H3588"\w* ser revelada.\wj*
