\id PHP - Biblica® Open Finnish Living News New Testament
\h Filippiläisille
\toc1 Paavalin kirje filippiläisille
\toc2 Kirje filippiläisille
\toc3 Fil.
\mt1 Paavalin Kirje Filippiläisille
\c 1
\p 
\v 1 \add Lähettäjät:\add* Paavali ja Timoteus, kaksi Jeesuksen Kristuksen palvelijaa.
\p \add Vastaanottajat:\add* Filippin kaupungin papit, diakonit ja kaikki kristityt.
\p 
\v 2 Jumalan siunausta teille kaikille! Rukoilen, että Jumala, meidän Isämme, ja Herramme Jeesus Kristus antaisi rauhansa sydämeenne ja elämäänne.
\v 3 Kun rukoilen puolestanne, ylistän teistä Jumalaa.
\v 4 Niin iloinen olen muistaessani,
\v 5 kuinka paljon te olette auttaneet minua hyvän uutisen levittämisessä siitä saakka, jolloin itse kuulitte sen, aina tähän päivään asti.
\v 6 Olen varma, että Jumala, joka on alkanut teissä hyvän työnsä, auttaa teitä tuntemaan yhä paremmin hänen rakkauttaan. Hän myös vie tämän työnsä päätökseen siihen päivään mennessä, jona Jeesus Kristus palaa maailmaan.
\s1 Paavalin rakkaus filippiläisiin
\p 
\v 7 On luonnollista, että ajattelen teistä näin, sillä teillä on aivan erityinen sija sydämessäni. Yhdessä olemme puolustaneet totuutta ja vieneet ihmisille hyvän sanoman Kristuksesta. Yhdessä olemme saaneet kokea, että Jumala on kanssamme – sekä nyt, kun olen vankilassa, että silloin, kun olin vapaa.
\v 8 Jumala yksin tietää, kuinka teitä rakastan ja ikävöin. Tämän rakkauden on Jeesus Kristus antanut sydämeeni.
\p 
\v 9 Olen rukoillut, että oppisitte entistä paremmin tuntemaan Kristusta ja saisitte entistä enemmän rakkautta ihmisiä kohtaan. Olen myös rukoillut, että hengellinen arvostelukykynne kasvaisi.
\v 10 Silloin pystytte selvästi erottamaan oikean väärästä ja olette sisäisesti puhtaita – aina Herran tuloon saakka – eikä kukaan pysty moittimaan teitä mistään.
\v 11 Kun Jeesuksen teissä vaikuttamat hyvät teot ja asenteet ilmaisevat, että olette Jumalan lapsia, silloin kunnioitetaan ja ylistetään Herraa.
\p 
\v 12 Rakkaat veljet, haluan teidän myös tietävän, että kaikki, mitä minulle nyt on tapahtunut, on vain edistänyt hyvän uutisen leviämistä.
\v 13 Jokainen täällä – henkivartioston sotilaita myöten – tietää minun olevan kahleissa vain siitä syystä, että olen kristitty.
\v 14 Minun vankilassa oloni ansiosta monet täkäläiset kristityt eivät enää pelkää vankeuteen joutumista. Nähdessään minun kärsivällisyyteni he ovat rohkeasti ruvenneet puhumaan Kristuksesta toisille.
\p 
\v 15 On tietysti sellaisiakin, jotka julistavat hyvää sanomaa kateellisina siitä, että Jumala on käyttänyt minua työssään. He haluaisivat itselleen suuren sananjulistajan maineen! Mutta toisilla on puhtaammat vaikuttimet;
\v 16 he julistavat rakkaudesta minuun, kun tietävät, että Herra on tuonut minut tänne puolustamaan totuutta.
\v 17 Ne, jotka saarnaavat tehdäkseen minut kateelliseksi, kuvittelevat, että heidän menestymisensä saa minut suremaan vankeuttani.
\v 18 Mutta olkootpa heidän vaikuttimensa mitkä tahansa, joka tapauksessa hyvää sanomaa Kristuksesta julistetaan, ja siitä olen iloinen!
\s1 Miksi Paavali haluaa elää
\p 
\v 19 Minulla on muutenkin syytä iloon, sillä tiedän, että teidän rukoustenne ja Pyhän Hengen avulla tämä kaikki kääntyy minun parhaakseni.
\v 20 Hartain toiveeni on, etten koskaan lannistuisi, vaan että olisin näissä koettelemuksissakin valmis puhumaan rohkeasti Kristuksen puolesta – aivan niin kuin olen ennenkin tehnyt – ja että tuottaisin aina kunniaa Kristukselle riippumatta siitä, elänkö vai kuolen.
\p 
\v 21 Elämä merkitsee minulle tilaisuutta todistaa Kristuksesta, ja kuolema – niin, sen mukana tulee jotain vieläkin parempaa!
\v 22 Mutta jos elämä antaa minulle mahdollisuuden voittaa uusia ihmisiä Kristukselle, silloin en todellakaan tiedä, olisiko parempi elää vai kuolla.
\v 23 Olen kahden vaiheilla: joskus tahdon elää, joskus taas haluan mieluummin päästä Kristuksen luo. Minulle kuolema olisi tietysti paljon parempi.
\v 24 Mutta jos jään eloon, voin olla avuksi teille.
\v 25 Kyllä minua tarvitaan yhä täällä maan päällä, ja siksi olen varma, että saan vielä jonkin aikaa elää voidakseni auttaa teitä kasvamaan ja kokemaan uskon iloa.
\v 26 Sitten kun taas pääsen käymään siellä, saatte kiittää Jeesusta Kristusta siitä, että olen elossa ja että hän on minua suojellut.
\p 
\v 27 Mutta pääsinpä tulemaan luoksenne tai en, muistakaa aina elää niin kuin kristityn tulee. Silloin saan jatkuvasti hyviä tietoja siitä, kuinka te levitätte sanomaa Kristuksesta yhteisvoimin
\v 28 ja rohkeasti vihollisista välittämättä. He näkevät tässä merkin omasta tuhostaan. Mutta teille se on selvä merkki siitä, että Jumala on puolellanne ja että olette saaneet häneltä ikuisen elämän.
\p 
\v 29 Teille ei ole annettu etuoikeutta vain uskoa Kristukseen, vaan myös kärsiä hänen tähtensä.
\v 30 Me taistelemme yhdessä tässäkin asiassa. Olette jo aikaisemminkin nähneet minun kärsivän hänen tähtensä, ja olen vieläkin keskellä suurta ja vaikeaa taistelua, niin kuin hyvin tiedätte.
\c 2
\s1 Pitäkää esikuvananne Kristuksen rakkautta
\p 
\v 1 Rohkaisevatko kristityt siellä toinen toistaan? Rakastetaanko minua niin paljon, että minua halutaan auttaa? Tajuatteko, mitä merkitsee, että olemme veljiä Kristuksessa ja että meissä on sama Henki? Oletteko lämminsydämisiä lähimmäisiä?
\v 2 Antakaa minulle se ilo, että rakastatte toisianne, olette sydämenne pohjia myöten yksimielisiä ja teette yhdessä työtä saman päämäärän saavuttamiseksi.
\p 
\v 3 Alkää olko itsekeskeisiä ihmissuosion tavoittelijoita. Olkaa sen sijaan nöyriä ja pitäkää toista itseänne parempana.
\v 4 Älkää huolehtiko vain omista asioistanne, vaan olkaa kiinnostuneita myös toisista.
\p 
\v 5 Teillä tulisi olla samanlainen asenne kuin Jeesuksella Kristuksella.
\v 6 Vaikka hän oli Jumala, hän ei vaatinut omia oikeuksiaan, jotka olisivat hänelle kuuluneet.\f + \fr 2:6 \ft Sananmukaisesti: »Jumalan muotoisena ollessaan ei katsonut saaliikseen olla Jumalan vertainen».\f*
\p 
\v 7 Sen sijaan hän luopui suuresta voimastaan ja kunniastaan ja tuli ihmiseksi\f + \fr 2:7 \ft Sananmukaisesti: »tuli ihmisten kaltaiseksi».\f*, kaikkien palvelijaksi.
\v 8 Vielä enemmänkin hän nöyryytti itseään: hän kuoli ristillä kuin rikollinen.\f + \fr 2:8 \ft Sananmukaisesti: »oli kuuliainen kuolemaan asti, nimittäin kuolemaan ristillä».\f*
\v 9 Sen tähden Jumala nosti hänet taivaan kunniaan ja antoi hänelle nimen, joka on kaikkia muita nimiä suurempi.
\v 10 Jeesuksen edessä on jokaisen sekä taivaassa että maan päällä ja sen alla olevan polvistuttava
\v 11 ja tunnustettava Isän Jumalan kunniaksi, että Jeesus Kristus on Herra.
\p 
\v 12 Rakkaat ystävät, kun olin siellä luonanne, te noudatitte aina tarkasti ohjeitani. Nyt kun olen sieltä poissa, teidän on entistäkin tarkemmin pidettävä huolta siitä, että teette niitä hyviä tekoja, jotka ovat pelastuksen seurauksena. Totelkaa Jumalaa häntä syvästi kunnioittaen ja sanoutukaa irti kaikesta, mikä on hänen tahtonsa vastaista.
\v 13 Jumalahan antaa teille halun totella häntä ja toteuttaa hänen tahtoaan maailmassa.
\p 
\v 14 Toimittakaa kaikki tehtävänne mukisematta ja vastaan panematta,
\v 15 niin ettei teitä voida moittia mistään. Koska olette Jumalan lapsia, eläkää puhtaina ja moitteettomina tässä pimeässä maailmassa, jonka ihmiset ovat kieroja ja kovia. Loistakaa heidän keskellään kuin taivaan tähdet,
\v 16 kun tarjoatte heille elämän sanomaa. Kuinka iloinen saankaan olla sitten Kristuksen saapuessa siitä, että työni teidän keskuudessanne kantoi niin kauniin sadon!
\v 17 Jos minun on uhrattava henkeni pyrkiessäni vahvistamaan teidän uskoanne, olen kuitenkin iloinen.
\v 18 Myös te saatte olla iloisia siitä, että minulla on etuoikeus kuolla teidän tähtenne.
\s1 Paavali haluaa tavata ystäviään
\p 
\v 19 Jos Herra tahtoo, lähetän pian Timoteuksen katsomaan teitä. Palattuaan hän voi sitten tuoda minulle rohkaisuksi teidän kuulumisenne.
\v 20 Kukaan ei kanna teistä vastuuta sillä tavoin kuin Timoteus.
\v 21 Kaikki muut huolehtivat enemmän omista asioistaan kuin Kristuksen työstä.
\v 22 Mutta Timoteuksen te tunnette! Hän on ollut minulle kuin oma poika auttaessaan minua hyvän uutisen eteenpäin viemisessä.
\v 23 Toivon, että voin lähettää hänet luoksenne heti, kun saan tietää miten minun käy.
\v 24 Uskon Herran järjestävän niin, että pian itsekin pääsen katsomaan teitä.
\p 
\v 25 Ennen sitä minun on kuitenkin lähetettävä Epafroditus takaisin teidän luoksenne. Lähetitte hänet tänne, kun minä olin avun tarpeessa, ja hän ja minä olemmekin olleet kuin veljekset. Yhdessä olemme tehneet työtä ja taistelleet rinta rinnan.
\v 26 Lähetän nyt hänet takaisin kotiin, sillä hänen on ollut ikävä teitä kaikkia, ja hän on ollut levoton siksi, että saitte kuulla hänen sairaudestaan.
\v 27 Ja sairas hän todella olikin – kuoleman kielissä. Mutta Jumala armahti häntä ja myös minua, kun ei antanut minulle sellaista surua muiden huolteni lisäksi.
\v 28 Niinpä lähetän hänet erityisen mielelläni takaisin luoksenne, sillä tiedän, kuinka kiitollisia te olette nähdessänne hänet. Se tekee minutkin iloiseksi ja keventää huolteni painoa.
\v 29 Ottakaa lämpimästi vastaan tämä Jumalan lapsi ja osoittakaa hänelle arvonantoa,
\v 30 sillä hän vaaransi henkensä Kristuksen työn tähden ja oli lähellä kuolemaa yrittäessään auttaa minua siinä missä te ette välimatkan takia voineet.
\c 3
\p 
\v 1 Rakkaat ystävät, mitä ikinä tapahtuukin, olkaa iloisia siitä, että tunnette Herran. En kyllästy muistuttamaan teitä samoista asioista, ja teidän on hyvä kuulla tämä yhä uudestaan.
\s1 Varoituksia
\p 
\v 2 Varokaa vääriä työntekijöitä, noita vaarallisia koiria, jotka väittävät, että ihmisen on otettava juutalaisten ympärileikkaus voidakseen pelastua!
\v 3 Ei tuo toimitus tee meistä Jumalan lapsia. Ainoa oikea ympärileikkaus on Jumalan palveleminen Pyhän Hengen voimalla. Me kristityt ylistämme Kristusta siitä, mitä hän on tehnyt puolestamme. Tajuamme, ettemme missään tapauksessa pysty pelastamaan itseämme.
\p 
\v 4 Minulla jos kellään olisi syytä toivoa voivani vaikuttaa omaan pelastumiseeni. Jos ihminen yleensä voisi pelastua sen ansiosta, mikä hän on, niin minä ainakin voisin.
\v 5 Minut ympärileikattiin, kun olin kahdeksan päivän ikäinen. Olin syntynyt puhdasveriseen juutalaiseen perheeseen, joka kuuluu Benjaminin sukuun. Minä jos kukaan olin siis oikea juutalainen. Lisäksi vielä lukeuduin fariseuksiin, jotka vaativat mitä ankarinta juutalaisten lakien ja tapojen noudattamista.
\v 6 Ja mitä vilpittömyyteen tulee, olin niin innokas, että vainosin kristittyjen seurakuntaa ja yritin noudattaa jokaista oman uskontoni sääntöä ja määräystä viimeistä piirtoa myöten.
\p 
\v 7 Nyt olen kääntänyt selkäni kaikelle sille, mitä ennen pidin suuressa arvossa. Olen pannut luottamukseni ja toivoni yksin Kristukseen.
\v 8 Kaikki muu menettää arvonsa, kun vertaan sitä aarteeseen, joka on omani siksi, että tunnen Jeesuksen Kristuksen, Herrani. Olen työntänyt kaiken muun arvottomana syrjään omistaakseni vain Kristuksen
\v 9 ja saadakseni olla yhteydessä häneen. Enää en kuvittele pelastuvani siksi, että olen hyvä ihminen, tai siksi, että noudatan Jumalan lakeja, vaan uskon, että Kristus yksin pelastaa minut. Jumala hyväksyy minut yhteyteensä, koska turvaudun yksin Kristukseen ja siihen, mitä hän teki puolestani.
\v 10 Nyt haluan vain oppia paremmin tuntemaan Kristusta, kokea sitä valtavaa voimaa, joka herätti hänet kuolleista, ja ymmärtää, mitä hänen kanssaan kärsiminen ja kuoleminen merkitsee.
\v 11 Uskon ja toivon hänen kerran herättävän minutkin kuolleista.
\p 
\v 12 En ole vielä perillä saakka enkä tarkoita olevani täydellinen. En ole vielä oppinut kaikkea, mitä minun pitäisi, mutta koska Kristus on voittanut minut, kuljen päämäärääni kohti.
\v 13 Ei, rakkaat veljet, en ole vielä perillä, mutta minun on lupa unohtaa mennyt ja kääntää katseeni tulevaisuuteen.
\v 14 Ponnistan voimani päästäkseni maaliin ja saadakseni palkinnon. Palkintona on ikuinen elämä taivaassa Jumalan yhteydessä – sen perusteella, mitä Kristus teki puolestamme.
\p 
\v 15 Toivon, että kaikki te, jotka olette kasvaneet uskossanne aikuisiksi, näette nämä asiat samassa valossa kuin minä. Mikäli olette eri mieltä jossakin kohden, uskon, että Jumala tekee asian teille selväksi,
\v 16 jos seuraatte elämässänne sitä totuutta, jonka olemme yhdessä oppineet tuntemaan.
\p 
\v 17 Rakkaat veljet, eläkää niin kuin minä. Olen yrittänyt antaa teille esikuvan. Ottakaa oppia myös niistä, jotka noudattavat esimerkkiäni.
\v 18 Usein aikaisemmin olen sanonut teille ja sanon vieläkin aivan silmät kyynelissä: on monia, jotka pitävät itseään kristittyinä, mutta ovat itse asiassa Kristuksen ristin vihollisia.
\v 19 He joutuvat kadotukseen, sillä vatsanpalvojia he ovat. He ylpeilevät sellaisesta, mitä heidän pitäisi hävetä, ja kantavat huolta vain tämän maailman asioista.
\v 20 Mutta meidän kotimaamme on taivas, jossa pelastajamme Herra Jeesus Kristus on ja josta odotamme hänen paluutaan.
\p 
\v 21 Kun hän tulee takaisin, hän muuttaa kuolevaisen ruumiimme samanlaiseksi taivaalliseksi ruumiiksi kuin hänellä itsellään on. Tämän hän tekee sillä voimalla, jolla hän hallitsee koko maailmankaikkeutta.
\c 4
\s1 Loppukehotuksia ja rukous
\p 
\v 1 Rakkaat kristityt veljet, haluaisin kovasti nähdä teidät, sillä te olette minun iloni ja palkinto työstäni. Rakkaat ystävät, pysykää uskollisina Herralle!
\p 
\v 2 Tahdon nyt vedota kahteen naiseen, Euodiaan ja Syntykeen. Lakatkaa riitelemästä! Herran avulla se on mahdollista. Olkaa jälleen ystäviä keskenänne.
\v 3 Sinua taas, uskollinen työtoverini, pyydän auttamaan näitä naisia, sillä he tekivät työtä yhdessä minun kanssani julistaessamme ihmisille hyvää sanomaa Kristuksesta. He uurastivat myös Klemensin ja muiden työtoverieni kanssa, joiden nimet on kirjoitettu ikuisen elämän kirjaan.
\p 
\v 4 Olkaa aina iloisia Herran tuntemisesta! Sanon sen uudestaan: olkaa iloisia.
\v 5 Toivon ihmisten näkevän, että te olette epäitsekkäitä ja huomaavaisia kaikissa tilanteissa. Muistakaa: Herra tulee pian.
\v 6 Älkää kantako huolta mistään, vaan rukoilkaa sen sijaan kaikkea Jumalalta. Kertokaa hänelle hätänne älkääkä unohtako kiittää häntä hänen vastauksestaan.
\v 7 Jos teette näin, saatte kokea Jumalan rauhaa, joka on ihmeellisempää kuin mikään, mitä ihmisjärki voi käsittää. Hänen rauhansa pitää teidän ajatuksenne ja sydämenne sellaisina kuin Kristus tahtoo niiden olevan.
\p 
\v 8 Päättäessäni nyt tätä kirjettä haluaisin sanoa, veljet, vielä yhden asian: kiinnittäkää ajatuksenne siihen, mikä on totta, hyvää ja oikeaa. Ajatelkaa sellaista, mikä on puhdasta ja rakastettavaa ja nähkää ihmisistä heidän hyvät puolensa. Ajatelkaa kaikkea sitä, mistä voitte ylistää Jumalaa ja olla iloisia.
\v 9 Toteuttakaa jatkuvasti käytännössä, mitä olette oppineet minulta ja nähneet minun tekevän. Rauhan Jumala on teidän kanssanne.
\p 
\v 10 Kuinka kiitollisena ylistänkään Herraa siitä, että te autatte minua jälleen. Olettehan te aina olleet innokkaita tukemaan työtäni taloudellisesti, mutta viime aikoina teillä ei ole ollut siihen mahdollisuutta.
\v 11 En tarkoita, että minulta koskaan olisi puuttunut mitään välttämätöntä, sillä olen oppinut olemaan tyytyväinen kaikissa olosuhteissa.
\v 12 Osaan elää köyhyyden, mutta myös rikkauden keskellä. Joka tilanteessa pystyn olemaan tyytyväinen: kylläisenä ja nälkäisenä, vauraudessa ja puutteessa.
\v 13 Kestän mitä tahansa, mihin Jumala minut johdattaa – Kristuksen avulla, joka antaa minulle voimaa.
\p 
\v 14 Olette joka tapauksessa tehneet oikein auttaessanne minua nykyisissä vaikeuksissani.
\v 15 Niin kuin hyvin tiedätte, vain te, filippiläiset, ryhdyitte huolehtimaan työstäni taloudellisesti, kun tuotuani ensi kertaa teille hyvän uutisen jatkoin matkaani Makedoniasta. Yksikään muu seurakunta ei sitä tehnyt.
\v 16 Vielä silloinkin, kun oli Tessalonikassa, te lähetitte minulle kaksi kertaa apua.
\v 17 Mutta vaikka annankin lahjoillenne suuren arvon, minua ilahduttaa kaikkein eniten se, että Jumala palkitsee hyvyytenne moninkertaisesti.
\p 
\v 18 Tällä hetkellä minulla on kaikkea mitä tarvitsen, ja enemmänkin. Tehän lähetitte tänne runsaan lahjoituksen Epafrodituksen mukana. Se on Jumalalle mieluinen, hyvältä tuoksuva uhri.
\v 19 Jumala kyllä täyttää kaikki teidän tarpeenne rikkauksistaan sen tähden, mitä Kristus Jeesus on tehnyt puolestamme.
\p 
\v 20 Jumalalle, Isällemme, kaikesta kunnia!
\p 
\v 21 Sanokaa terveisiä kaikille siellä oleville kristityille. Veljet, jotka ovat nyt kanssani, lähettävät myös terveisiä,
\v 22 samoin kaikki muutkin kristityt täältä, erityisesti ne, jotka ovat työssä keisarin palatsissa.
\v 23 Toivotan teille Herramme Jeesuksen Kristuksen siunausta.
