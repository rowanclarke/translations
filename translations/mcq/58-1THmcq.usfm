\id 1TH - Ese (Managalasi) NT [mcq] -Papua New Guinea 1999 (web version -2014)
\h 1 Tesaronia
\toc1 1 Tesaronia
\toc2 1 Tesaronia
\toc3 1 Te
\mt1 1 Tesaronia
\c 1
\s1 Vuꞌa Anejijihina
\p 
\v 1 Nú Poru ho Sivenasi ho Timoti ho ijano sosia kaꞌene Tesaronia Godi Amoho ꞌee Natohwa Jesu Keriso puni vaji hiju jihipunaꞌe pasikaho veju. ꞌEne maiji vwihaniujine ꞌee matauviꞌinijaho jona.
\s1 Tesaronia Puni Nimairoa ꞌEe Icháꞌina Hijuji Teimani ꞌWavajina
\p 
\v 2 Nú jonijihunaꞌe Godi teimani ꞌwavura. ꞌEne nú naꞌia mapoka siporua ꞌojuri veijaho nú joni iha ꞌurihiꞌi ꞌojura.
\v 3 Naꞌia mapokaꞌe jara nimaa rohuni kaukara ijí vene ꞌee ea oja mihe ꞌee nimairoa kaꞌene núni Natohwa Jesu Keriso oni vaja ꞌee núni Godi ꞌee Omijihuni unaꞌi ija kisina ꞌunama hijuji vwihaniura.
\v 4 Vwehu núne Godi ja oja mihe ꞌee Hura ja iji pijihajaho hena kaꞌavara.
\v 5 ꞌEnajihunaꞌe vuꞌa maa maiuꞌina kaꞌene nú apena roajaho iraru paꞌwaravara kaivo harura ꞌee Godoni ꞌAvena vaji roe raka kaꞌene núra ꞌwaravajaho nimaa hene ja nimaa rojara. ꞌEne nú jonijihunaꞌe icháꞌina kaꞌene hijajaho ja nikúvara.
\v 6 Ja ꞌuꞌo núra vejujaꞌinaꞌe vene ꞌee Natohwijara venajaꞌinaꞌe vejara. Uneunecha sisea ani ani rejara vo ja Godi oni ꞌAvena vajijino teamanaꞌeme ira ikaho apejara.
\v 7 ꞌEnajihunaꞌe ja ꞌunama maa kaꞌene veju kaji Masatonia ꞌee Akaia ora kaꞌene nimaa rojiꞌinaka hijujihija ꞌunama kaji najahara.
\v 8 ꞌEnaꞌomo iviamaa Natohwi jihuni vuꞌijaho joni rene rausahe vaꞌe Masatonia ꞌee Akaiaru pavaꞌara vo kwaaka mapokaki vaꞌana. Jara Godi nimaa nimaa rojujaho pu nihe parajara. Ijihunihahi nú pu areri unenu ꞌahoꞌa paꞌwarahuna.
\v 9 Pu opuipo núra ja kiꞌi roume jara ꞌunama icháꞌina kaꞌene ꞌekuajaho ꞌwaruvara. ꞌEnareja jara godia iraꞌata kaꞌene iji vejuji nimaa rojujaho areꞌi kaivo taꞌarohe Godi nimaa kaꞌene majama hijiꞌiniji oja mahujaho ꞌwaruvara.
\v 10 ꞌEnajihunaꞌe ja iviamaa Huni harihijara kúꞌo akúpa ꞌahi rena rohuniji ꞌajaha hiju. Jesu kaꞌene Hura vejume kúꞌo ꞌurinajara sena kaꞌene roajaho vahanumana.
\c 2
\s1 Porura Kaukara Kaꞌene Tesaronia Venajina
\p 
\v 1 Vwehu núne ja ojono nihena kavu. Nú joni vuꞌajaho nú núni vea panisame vuꞌara.
\v 2 Ja niheja jaꞌinaꞌe nú nimarako Piripai siseꞌi ꞌahúume haha hianumana kaivo nú núni Godijihuni vaji harura apeꞌikaꞌi ja Godoni vuꞌa maiuꞌina ijí ninakaraa renana vajijaho ꞌwaravara.
\v 3 Núra ja ꞌwaravajaho puruvareꞌe ꞌwarahuna pana ꞌee ꞌunama siseijino ꞌwarahuna pana ꞌee pisivisame ꞌwarahuna pana.
\v 4 ꞌEnakaivo Godira nú nimaa vetúarena Huni vuꞌa maa maiuꞌinakaho múhanaꞌomo nú emaa teamanahunaꞌe vehuna pana kaivo Godira núni ojijaho nivena kúmana.
\v 5 Ja niheju jaꞌinaꞌe nú ira toa vene ꞌwarahuna pana ꞌee joni uneunecha ꞌekaꞌirono pisivihuna pana. Ijihuni maijaho Godiho núni vuꞌa nimaa vetúu.
\v 6 ꞌEne emaa ꞌee jaa ꞌee ea ꞌaho puꞌúmo nú taꞌaroruꞌavarono avahuna pana. Nú Keriso oni apasoruaꞌomo nú núni harurijino vehune saꞌina
\v 7 kaivo nú masuani ajuarasahe joni vaji hijara areri oahi huni sesamaaꞌe ꞌajohau jaꞌinaꞌe vejara.
\v 8 Nú ja nihoꞌo oja miha paraja jihunaꞌe nú Godoni vuꞌa maiuꞌinijiru pamihara kaivo nú nihoꞌo ura renua paraꞌeme núni hia ꞌuꞌo ja vajihara.
\v 9 Vwehu núne ja mavwihaha. Nú joni vaji hijari veijaho nú ja ahija mihuna senuvume nú onúno harura vene naꞌia veiriꞌa kaukara vejiꞌi Godoni vuꞌa maa maiuꞌina ja ꞌwaravara.
\v 10 Godiho nú nihena kúme nimaa vejuꞌe ja ꞌuꞌo nimaa veju. Núra icháꞌinaꞌe ja puꞌúmo akume ꞌee arimaaꞌe hine ꞌee unenu ꞌahoꞌa ea ꞌahoꞌa panamuhe ꞌwaruꞌeme nú nimaa rojiꞌina puꞌúmo hami hijura.
\v 11 Ja niheju núra icháꞌina kaꞌene niꞌajihe ꞌee taꞌarorahe ꞌee hine hami nirisame ea kwinu kwino areri omahi sesahwahaꞌe ꞌwaramu jaꞌinaꞌe nú hine ja ꞌwaravara.
\v 12 Ijihunaꞌe Godi kaꞌene ja ꞌumenauꞌe Huni ara ꞌee hanajiꞌinijino vahuna ꞌiamajihuni ꞌunama kaꞌene Hura kive areri rehunijino oꞌavara.
\v 13 Ikehuni hahi nú ꞌuꞌo naꞌia mapokaꞌe Godi teimani ꞌwavura. Ja vea kaꞌene Godoni ira ike núnunaꞌi apejari veijaho ja emaapuni ira punaꞌa paapejara kaivo ja Godoni ira nimaaꞌe apeju jaꞌinaꞌe apejara. Ijihunaꞌe ja ea irara ijí ira kaji nimaa ronujaho joni vaja ꞌuꞌo kaukara venu.
\v 14 ꞌEnajihunaꞌe vwehu núne Godoni sosia kaꞌene Jesu Keriso oni vaji Jutia namijujipo vejajaꞌinaꞌe ja vejara. Ja ehu jopunaꞌi sisea icháꞌina kaꞌene piuniva jaꞌinaꞌe pu ꞌuꞌo Jua punaꞌi sisea ijaꞌinaꞌe piunivara vo kirasahara.
\v 15 Pu Natohwa Jesu ꞌanae ꞌee poropetia ꞌania jaꞌinaꞌe nú ꞌuꞌo ꞌararihúume usevara. ꞌEnajihunaꞌe pu Godira ura renujaꞌina pavene ꞌee emaapuni nanaꞌejiꞌinaꞌe rejara.
\v 16 Jenitarupo Godi nimaa rohuni jihunaꞌe pu tanuꞌuruhuꞌe nú vuꞌa paꞌwaravura. Ijihuni hahi pu puni siseijaho vejuꞌe tiresa hina apena ajimu. ꞌEnakaivo puni eha siseijaho niroe areri rena parana namu.
\s1 Porura Tesaronia Kúꞌo ꞌUnama Vaꞌe Kiꞌiro Vwihanajina
\p 
\v 17 ꞌEnakaivo vwehu núne nú ja hahijino maꞌuako irechamie vaꞌara kaivo núni ojijaho ijí ja puꞌúmo navu. ꞌEne núni ura ijaho roe joni urania kihunaꞌe ura renua paranúu.
\v 18 Ijihuni maijaho nú roe ja kihunaꞌe ura renu ꞌee na Poru naꞌia mapokaꞌe roe ja kihunaꞌe ura reniu kaivo Setanira hine roturúhu.
\v 19 Núni nimaa roijaho irahije ꞌee núni eha maa kaꞌene núaꞌe taꞌaroruhe vajúhunijaho irahije? Núni Natohwa Jesura roꞌamani veijino jara Huni unaꞌi namihunijina.
\v 20 Ijihuni maijaho ja núni pinana mamaijina ꞌee temarijina.
\c 3
\p 
\v 1 Ijihuni hahi vea kaꞌene nú areri pakirasahunaꞌe henareja nú vwihajajaho maijaho areme iki Atenisi hiꞌipisana ronareꞌe hiju.
\v 2 ꞌEne hu Timoti núni vwea kaꞌene nú puꞌúmo Godoni kaukara vejiꞌina kaꞌene Keriso oni vuꞌa maa maiuꞌina ꞌwaraviꞌina ranavuꞌe ja niꞌajihe joni nimairoa kisinaꞌe reꞌamarono vuꞌu.
\v 3 ꞌEjakame jara siseisei hijujara ja patanuꞌurihuna. Ijihuni maijaho ja niheju nú nikaꞌina hihunaꞌe iji pijúhana.
\v 4 Núra ja puꞌúmo hijajino nú ja puꞌúmo siseꞌi ꞌahúhunaka ꞌwaravajaho ja nihejaraꞌomo iviamaa ijaꞌina renu.
\v 5 Ijihunihahi na areri pakairahunaꞌe henarejo joni nimaa roijí heꞌi ꞌahiuꞌe ranavuꞌe vuꞌu. Ijihuni maijaho na oja hianimujaho vejuroꞌi pisivisaviꞌinijara pisimiakame núra kaukara kaꞌene vejajaho maa paꞌanaꞌe rena veꞌamarono ranavuꞌe vuꞌu.
\v 6 Iviamai Timotiho ijí joni rene joni pinana maa apene ꞌunama núni roana. ꞌEne jara Godi nimaa rone oja mahe ija kisi apene joni unaꞌi saname vejujaho ro ꞌwarumana. Jara naꞌia mapoka nú vwihanúe nú ura ja kiꞌi ꞌahúu jaꞌinaꞌe areri ja ꞌuꞌo ura nú kúꞌi ꞌahiu.
\v 7 Vwehu núne nú ijihuni hahi iki hijujaho sisea piuname ahisina apejiꞌi hijura kaivo jara nihoꞌo nimaa rojujihunaꞌe nú oja sonahúu.
\v 8 Jara Natohwi jihuni vaji kirasahe namijujara rejuꞌe nú hami hiju.
\v 9 Nú icháꞌinaꞌe jonijihunaꞌe Godi teimani ꞌwaꞌeja? Ijihuni maijaho núra temara kaꞌene jonunaꞌi ꞌekajihuni hahi nú Godoni unaꞌi jonijihunaꞌe temarasahura.
\v 10 ꞌEne nú naꞌia ꞌee veiriꞌa majaa hine joni niura kihunaꞌe siporua ꞌojuraꞌomo roe kime raka kaꞌene joni nimairoa vaji panavujaho niꞌajihe areri rehuna.
\v 11 Godi kaꞌene núni Omijara Huhusune ꞌee Jesu kaꞌene núni Natohwijiꞌo núni ꞌunama venuhakame nú vuꞌe ja kihuna.
\v 12 Natohwijara venae jara ea kwinu kwino oja ꞌekaravura ꞌee emaa mahoꞌo oja ꞌekaujaho emarene ꞌee ameurahe arihama areri núra jonunaꞌi vejujaꞌinaꞌe renama.
\v 13 ꞌEne Hu ja venaꞌe joni oja Godi kaꞌene núni Omijihuni unaꞌi ariramaa rene panamaꞌeje núni Natohwa Jesuho ꞌee Huni ea ariramaijipo Hu huꞌúmo roavari veijaho matauma namihuna.
\c 4
\s1 Kara Kaꞌene Godi Teamahunijina
\p 
\v 1 Vwehu núne Vuꞌa túchamaa pina ikena. Nú Natohwa Jesuni vaji ja jarirame ꞌwaravu núra vuꞌa kaꞌene ꞌwaravume ja hene oju kajaꞌinaꞌe nijaꞌina oje Godiho teamaꞌamana. ꞌEje ja maranie ajime vaꞌamana.
\v 2 ꞌEjume nú Natohwa Jesuni harura vaji varapa raka kaꞌene vajihajaho ja nihena kivu.
\v 3 Ijihunihahi ikaho Godoni uraijina ja nihoꞌo ea ariramaa rehunaꞌe ura renukúne ꞌuasa paveꞌavara.
\v 4 ꞌEne ja ea kwinu kwino joni hahi jihipuni hura vene hami ꞌajoꞌeje ariraꞌe nava.
\v 5 ꞌEnakúne ja Jenitaru kaꞌene Godi pahene pakavujipo puni hahapo napara itunama parajukame ꞌunama kaꞌene vejujaꞌina paveha.
\v 6 ꞌEjume ja ꞌunama ikehunakino sisea vene vweuna panamaꞌamana. Ijihuni maijaho Natohwijara ike uneunecha ikihipuni eha ijaho venuna. ꞌEne nú nimarako ꞌwaravaji kúꞌo nahama ꞌwaravu.
\v 7 Ijihuni maijaho Godira nú ꞌumenuajaho nú ꞌunama sisea kaꞌene ꞌuasa veꞌavarono ija pijúhuna pana kaivo nú ariramaa rehuni jihunaꞌe iji pijúhana.
\v 8 ꞌEnajihunaꞌe ea irara ike hene pataarohujaho hu emaa papataarohu kaivo Godi kaꞌene Huni ꞌAvena mahaji pataaroha avanu.
\v 9 Jara vwehu jona icháꞌinaꞌe oja mihunijaho ea pina maiꞌo pavene ꞌwarahuna. Ijihuni maijaho ꞌunama kaꞌene vwehu jonaꞌe icháꞌina oja ꞌekarahunijaho Godira ja najahana.
\v 10 Nú niheju. Ja ꞌunama kajaho vwehu jona kaꞌene Masatonia hijujihi puꞌúmo vejura kaivo vwehu núne nú ja jarirame ꞌwaravujaho ja maji vene ihajinanama apene vaha.
\v 11 Nú ja niꞌwaravu jaꞌinaꞌe masuani hine jomaaru vene ꞌee joni iji kaukara vejiꞌi hihunijaho joni ura nimaa renaꞌama.
\v 12 ꞌEjakame ja ea kaꞌene samaa hiju jihipuni unaꞌa hami hine ꞌee uneunecha ꞌahoꞌa papivusahuna.
\s1 Keriso Oni Vaji Kwamasahajihi Aherama Rohunijina
\p 
\v 13 ꞌEnakaivo vwehu núne jara ea kaꞌene kwamasahu jihipuni vuꞌijí paꞌwarave heꞌava jihunaꞌe hine ea kaꞌene panimaa rojujipo vejujaꞌina temuka apehuna nú ura parenu.
\v 14 Nú Jesura kwame kúꞌo ꞌurinaji nimaa roꞌavajaho Godira ijaꞌinaꞌe ea kaꞌene Jesuni vaji kwamasahajija Hu huꞌúmo aherame rohuna.
\v 15 Na ikaho Natohwi jihuni iri vaji rena roaji ja ꞌwaravu. Nú ea kaꞌene maiꞌo hijukija Natohwijara roꞌamajaho nú urasahe pavahuna kaivo nú mahiꞌeje ea kaꞌene kwamasahajipo ꞌurihuna.
\v 16 Ijihuni maijaho Natohwijara Huhusu ꞌona ojiꞌina puni natohwijiꞌi mwasiriviꞌi ariha Godoni vitiꞌinijiꞌi roꞌeje ea kaꞌene Keriso oni vaji kwamasahajipo urasahe ꞌurihuna.
\v 17 ꞌEjakame nú ea kaꞌene maiꞌo hiꞌavajija ꞌurina vaꞌe kahi ꞌimitia vaji pu piunime ahuma ajima vaꞌe ichutoi Natohwijaho piunahuna ꞌee nú Natohwijihi puꞌúmo majama hihuna.
\v 18 ꞌEnakúne ike vuꞌa ikino ea kwinu kwino ꞌwame niꞌajarave oja sonahiꞌeje hiha.
\c 5
\s1 Natohwijara Rohuni Veiji Amairiara Hunijina
\p 
\v 1 ꞌEnakaivo vwehu núne iviamaikino icháꞌina ho vea irakijino ikara rehunijaho na jona pavene ꞌwarahuna.
\v 2 Ja ijaho ni mahoꞌo hejume paꞌarena jaꞌinaꞌe Natohwi jihuni veijara roꞌamajaho areri nesa apejiꞌinijara naꞌi roujaꞌinaꞌe rohuna.
\v 3 ꞌEne pu vea kaꞌene unekajaho pareꞌena ꞌwaviꞌi matauma hiꞌavajino niꞌaha kwino sisea puni haha ꞌahi rehuna. Areri napari hariha naheꞌi ꞌahauꞌe vejiꞌi haha kaꞌene henujaꞌinaꞌe hehuna kaivo pu juhaha usehunijaho areri parehuna.
\v 4 ꞌEnakaivo vwehu núne ja nututa pahiju jihunaꞌe ijí vea kajaho ja nesa apejiꞌina punaꞌi paroe asitahuna.
\v 5 Ijihuni maijaho ja hanajiꞌini jihuni harihija ꞌee veꞌiriꞌijihuni harihija. Nú naꞌiaho nututi jihuni harihija pana.
\v 6 ꞌEnakúne roe ja puꞌúmo ea ꞌahopo vejujaꞌinaꞌe panotui kaivo ꞌurine nia nirie ꞌaiha vejiꞌi hija.
\v 7 Ijihuni maijaho ea kaꞌene notujaho pu puni nia naꞌi notuura ꞌee ea kaꞌene toa sisea ine nanamiujaho pu naꞌi toa sisea ine nanamiura.
\v 8 ꞌEnakaivo nú ea kaꞌene veirihuni jihunaꞌe roe masuani núni túratakaho nimairoa ꞌee oja ꞌekaravujino same ꞌee isúa nimairoa kaꞌene niꞌajúhajino sava.
\v 9 Ijihuni maijaho Godiho nú Huni sena vaji aruhuna iji pijúhuna pana kaivo niꞌajúhajaho núni Natohwa Jesu Keriso oni vaji apehunaꞌe ija pijúhana.
\v 10 Hu núnijihunaꞌe kwama jihunaꞌe nú maiꞌo hiꞌeja ho kwamasahuna kaivo nú pu puꞌúmo ahuma majama hihuna.
\v 11 Ijihuni hahi ojono ꞌwame niꞌajarame ꞌee ojono nasarame ꞌurine emareꞌavara. ꞌEne ja niveju kajaꞌinaꞌe veꞌavara.
\s1 Túchamahuni Kara Icháꞌiniji Ohunijine ꞌEe ꞌAjoramajina
\p 
\v 12 ꞌEnakaivo vwehu núne nú ja jarirame ꞌwaravujaho ea kaꞌene joni vaja kajino kaukara kikisinaꞌe vene ꞌee Natohwi jihuni vaji ja ꞌajohaꞌe ꞌee vuꞌa kaꞌene pu ꞌwaravujaho taꞌaroraꞌavara.
\v 13 ꞌEne oja ꞌekauri vajijino pura kaukara kaꞌene vejujihunaꞌe puni hura vene ira mamaa ijino ꞌwaraꞌavara. ꞌEne ea ꞌaho puꞌúmo matauma hiꞌavara.
\v 14 ꞌEne vwehu núne nú ja jarirame ꞌwaravujaho ja ea kaꞌene vuꞌataa pahejiꞌinijija ꞌuraraꞌavara. ꞌEne ea kaꞌene tea junaviꞌinijija ꞌee ea ajuasina niꞌajiꞌavara. ꞌEe ohura paapeꞌavara kaꞌi ea ꞌaho puꞌúmo masuani hiꞌavara.
\v 15 Ja pakiꞌeje ea ꞌahopo ja siseꞌi ꞌahiakame ja eha vene pununaꞌi sisea veꞌava. ꞌEnakaivo naꞌia mapoka ꞌunama kaꞌene vejakame ea kwinu kwino maranie ꞌee ea mahoꞌo ꞌuꞌo maranihunijiru sarame veꞌavara.
\v 16 ꞌEne naꞌia mapokaꞌe temarasaꞌavara.
\v 17 ꞌEne naꞌia mapokaꞌe siporua maijí ꞌojiꞌi naꞌavara.
\v 18 Uneunecha mapoka kaꞌene rejujija Godi teimani ꞌwaꞌavara. Ijihuni maijaho ijaho Godoni ura kaꞌene jara Jesu Keriso oni vaji vehunaꞌe ura renujina.
\v 19 Ja Godoni ꞌAveni jihuni vena paveje utaꞌamana.
\v 20 Vuꞌa kaꞌene túnaꞌi rehuniji ꞌwarave heꞌavajaho pasenaꞌavara.
\v 21 ꞌEnakaivo uneunecha mapokakija ꞌeke hami piuhihu vaꞌo mamaijija ija kisinaꞌe ꞌeke ꞌuninamiꞌavara.
\v 22 ꞌUnama kaꞌene sisea rehuna saꞌinaꞌe kiꞌavajaho juhaꞌavara.
\v 23 ꞌEne iviꞌa Godia kaꞌene matauviꞌinijara mahoꞌo venae arimaaꞌe rene ꞌee joni ꞌavena ꞌee joni oja ꞌee joni haha mahoꞌo ꞌajohakame vea kaꞌene núni Natohwa Jesu Kerisora roꞌamajaho nihoꞌo panamuꞌamana.
\v 24 Hu nihoꞌo pauchaviꞌinijara a ꞌumenanaꞌomo Hu aneja venajaho ve parahuna.
\v 25 ꞌEne vwehu núne núni siporua ꞌonuꞌavara.
\v 26 ꞌEne vwehu núna ꞌajorame ura mina venaꞌavara.
\v 27 Na Natohwi jihuni ihi ꞌurahiꞌi ꞌwaravukúne ike asurakaho tahe vwehu núna mahoꞌo heꞌavara.
\v 28 Núni Natohwa Jesu Keriso oni maiji vwihanúujaho ja puꞌúmuna. 
