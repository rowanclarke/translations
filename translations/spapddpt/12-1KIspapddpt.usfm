\v 21 \w Roboam|strong="H7346"\w* llegó \w a|strong="H3068"\w* Jerusalén. Mandó congregar \w a|strong="H3068"\w* 180.000 \w guerreros|strong="H6213"\w* escogidos \w de|strong="H5973"\w* \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H5973"\w* \w Judá|strong="H3063"\w* y \w la|strong="H3605"\w* \w tribu|strong="H7626"\w* \w de|strong="H5973"\w* \w Benjamín|strong="H1144"\w* \w para|strong="H5973"\w* \w combatir|strong="H4421"\w* \w contra|strong="H5973"\w* \w la|strong="H3605"\w* \w casa|strong="H1004"\w* \w de|strong="H5973"\w* \w Israel|strong="H3478"\w* y devolver \w el|strong="H5973"\w* \w reino|strong="H4410"\w* \w a|strong="H3068"\w* \w Roboam|strong="H7346"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5973"\w* \w Salomón|strong="H8010"\w*.
