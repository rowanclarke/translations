\v 38 \w Il|strong="H01732"\w* \w y|strong="H08033"\w* \w avait|strong="H03068"\w* \w une|strong="H00259"\w* \w chambre|strong="H03957"\w*, \w avec|strong="H06213"\w* \w sa|strong="H05414"\w* \w porte|strong="H08179"\w*, \w près|strong="H00681"\w* \w des|strong="H08179"\w* pilastres \w des|strong="H08179"\w* portiques ; c’est \w là|strong="H08033"\w* qu’\w on|strong="H08033"\w* \w lavait|strong="H07364"\w* \w les|strong="H03957"\w* \w holocaustes|strong="H05930"\w*\f + \fr 40:38 \ft 38. C’est là qu’on lavait les entrailles et les pieds des victimes offertes en holocauste (Lev 1,9). Les LXX présentent, pour ce vers., des leçons différentes de celles de la Massore. — Le sens demeure assez incertain.\f*.  
\v 39 \w Dans|strong="H08432"\w* \w le|strong="H07819"\w* \w vestibule|strong="H00197"\w* \w du|strong="H08179"\w* \w portique|strong="H00197"\w*\f + \fr 40:39 \ft 39. \ft \+it Du portique\+it* oriental (voir vers. suivant).\f*, \w il|strong="H01732"\w* \w y|strong="H08033"\w* \w avait|strong="H03068"\w* \w deux|strong="H08147"\w* \w tables|strong="H07979"\w* d’\w un|strong="H02403"\w* \w côté|strong="H06311"\w* \w et|strong="H02403"\w* \w deux|strong="H08147"\w* \w tables|strong="H07979"\w* \w de|strong="H08179"\w* l’\w autre|strong="H08147"\w*, \w sur|strong="H02403"\w* \w lesquelles|strong="H02004"\w* \w on|strong="H00376"\w* \w devait|strong="H05414"\w* \w immoler|strong="H02076"\w* \w les|strong="H07819"\w* \w victimes|strong="H05930"\w* \w destinées|strong="H06256"\w* \w à|strong="H08147"\w* l’\w holocauste|strong="H05930"\w*, \w au|strong="H05930"\w* \w sacrifice|strong="H02077"\w* \w pour|strong="H05930"\w* \w le|strong="H07819"\w* \w péché|strong="H02403"\w* \w et|strong="H02403"\w* \w au|strong="H05930"\w* \w sacrifice|strong="H02077"\w* \w pour|strong="H05930"\w* \w le|strong="H07819"\w* délit.  
\v 40 \w Au|strong="H05927"\w* \w côté|strong="H03802"\w* \w extérieur|strong="H02351"\w*\f + \fr 40:40 \ft 40. \ft \+it Au côté extérieur\+it* du même portique oriental. Les quatre tables dont parle ce verset étaient placées en dehors, sur les côtés du vestibule ; elles servaient spécialement aux holocaustes : comp. xlvi, 1-7 avec 13-15.\f*, \w au|strong="H05927"\w* \w septentrion|strong="H06828"\w* \w pour|strong="H05927"\w* \w celui|strong="H00376"\w* \w qui|strong="H08147"\w* \w montait|strong="H05927"\w* \w à|strong="H05927"\w* l’\w entrée|strong="H06607"\w* \w du|strong="H05927"\w* \w portique|strong="H00197"\w*, \w il|strong="H01732"\w* \w y|strong="H08033"\w* \w avait|strong="H05927"\w* \w deux|strong="H08147"\w* \w tables|strong="H07979"\w*, \w et|strong="H05927"\w* \w de|strong="H08179"\w* l’\w autre|strong="H08147"\w* \w côté|strong="H03802"\w*, \w vers|strong="H05927"\w* \w le|strong="H05927"\w* \w vestibule|strong="H00197"\w* \w du|strong="H05927"\w* \w portique|strong="H00197"\w*, \w deux|strong="H08147"\w* \w tables|strong="H07979"\w*.  
\v 41 \w Il|strong="H01732"\w* \w se|strong="H03802"\w* \w trouvait|strong="H04672"\w* \w ainsi|strong="H00559"\w*, \w sur|strong="H04427"\w* \w les|strong="H07819"\w* \w côtés|strong="H03802"\w* \w de|strong="H08179"\w* \w la|strong="H07819"\w* \w porte|strong="H08179"\w*, \w quatre|strong="H00702"\w* \w tables|strong="H07979"\w* d’une \w part|strong="H02506"\w* \w et|strong="H08179"\w* \w quatre|strong="H00702"\w* \w tables|strong="H07979"\w* \w de|strong="H08179"\w* l’\w autre|strong="H08179"\w* ; \w en|strong="H07979"\w* \w tout|strong="H08179"\w* \w huit|strong="H08083"\w* \w tables|strong="H07979"\w*, \w sur|strong="H04427"\w* \w lesquelles|strong="H02004"\w* \w on|strong="H00376"\w* \w devait|strong="H05414"\w* \w immoler|strong="H02076"\w*.  
\v 42 \w Il|strong="H02677"\w* \w y|strong="H08033"\w* \w avait|strong="H03068"\w* \w encore|strong="H03254"\w* \w quatre|strong="H00702"\w* \w tables|strong="H07979"\w*\f + \fr 40:42 \ft 42. \ft \+it Quatre autres tables\+it*, sans doute beaucoup plus petites que les huit autres en bois.\f* servant \w aux|strong="H02077"\w* \w holocaustes|strong="H05930"\w*, \w en|strong="H03240"\w* \w pierre|strong="H00068"\w* \w de|strong="H03627"\w* \w taille|strong="H01496"\w*, \w longues|strong="H00753"\w* d’une \w coudée|strong="H00520"\w* \w et|strong="H07341"\w* \w demie|strong="H02677"\w*, \w larges|strong="H07341"\w* d’une \w coudée|strong="H00520"\w* \w et|strong="H07341"\w* \w demie|strong="H02677"\w* \w et|strong="H07341"\w* \w hautes|strong="H01363"\w* d’une \w coudée|strong="H00520"\w*, \w sur|strong="H04427"\w* \w lesquelles|strong="H02004"\w* \w on|strong="H00376"\w* \w posait|strong="H07896"\w* \w les|strong="H07819"\w* \w instruments|strong="H03627"\w* \w avec|strong="H02677"\w* \w lesquels|strong="H02004"\w* \w on|strong="H00376"\w* immolait \w les|strong="H07819"\w* \w victimes|strong="H02077"\w* \w destinées|strong="H06256"\w* \w à|strong="H03240"\w* l’\w holocauste|strong="H05930"\w* \w et|strong="H07341"\w* \w aux|strong="H02077"\w* \w autres|strong="H00312"\w* \w sacrifices|strong="H02077"\w*.  
\v 43 \w Des|strong="H01004"\w* \w crochets|strong="H02053"\w* d’\w un|strong="H01004"\w* \w palme|strong="H02948"\w* \w étaient|strong="H02948"\w* \w fixés|strong="H06965"\w* \w tout|strong="H05439"\w* \w autour|strong="H05439"\w* \w de|strong="H01004"\w* l’édifice ; \w et|strong="H01004"\w* \w la|strong="H03559"\w* \w chair|strong="H01320"\w* \w des|strong="H01004"\w* \w sacrifices|strong="H07133"\w* \w devait|strong="H05414"\w* \w être|strong="H00194"\w* \w placée|strong="H07760"\w* \w sur|strong="H04427"\w* \w les|strong="H01004"\w* \w tables|strong="H07979"\w*.\f + \fr 40:43 \ft 43. LXX, \ft \+it et elles avaient une bordure de pierre taillée, en dedans tout autour ; et au dessus des tables en haut, des toitures pour les protéger contre la pluie et la chaleur.\+it*\f*   
\p
\v 44 \w En|strong="H06440"\w* \w dehors|strong="H02351"\w* \w du|strong="H06440"\w* \w portique|strong="H00197"\w* \w intérieur|strong="H06442"\w*, \w il|strong="H01732"\w* \w y|strong="H08033"\w* \w avait|strong="H06921"\w* \w les|strong="H06440"\w* \w chambres|strong="H03957"\w* \w des|strong="H06440"\w* \w chantres|strong="H07891"\w*\f + \fr 40:44 \ft 44. \ft \+it Les chambres des chantres\+it*. Les lévites-chantres ne devaient plus remplir cette fonction dans le nouveau temple (xliv, 10-14) ; ces chambres sont donc ainsi appelées, uniquement en souvenir de la place qu’ils y avaient autrefois ; elles seront attribuées aux prêtres. — \+it À côté du portique septentrional\+it*, dans l’angle nord-est du parvis intérieur. — \+it À côté du portique oriental\+it*, dans l’angle sud-est du même parvis. — Dans les LXX, on lit pour ce verset : \+it Et il me conduisit dans le parvis intérieur, et voici deux chambres dans le parvis intérieur : l’une à côté (a tergo) du portique qui regardait vers le nord était tournée vers le midi ; l’autre qui était à côté du portique qui regardait vers le midi, était tournée vers le nord.\+it*\f*, \w dans|strong="H06440"\w* \w le|strong="H06440"\w* \w parvis|strong="H02691"\w* \w intérieur|strong="H06442"\w* ; \w celle|strong="H02459"\w* \w qui|strong="H01870"\w* \w était|strong="H06440"\w* \w à|strong="H06440"\w* \w côté|strong="H03802"\w* \w du|strong="H06440"\w* \w portique|strong="H00197"\w* \w septentrional|strong="H06828"\w*, \w avait|strong="H06921"\w* \w sa|strong="H06440"\w* façade \w dans|strong="H06440"\w* \w la|strong="H06440"\w* \w direction|strong="H01870"\w* \w du|strong="H06440"\w* \w midi|strong="H01864"\w* ; \w l|strong="H06440"\w*’\w autre|strong="H08179"\w* \w à|strong="H06440"\w* \w côté|strong="H03802"\w* \w du|strong="H06440"\w* \w portique|strong="H00197"\w* \w oriental|strong="H06921"\w*, \w avait|strong="H06921"\w* \w sa|strong="H06440"\w* façade \w dans|strong="H06440"\w* \w la|strong="H06440"\w* \w direction|strong="H01870"\w* \w du|strong="H06440"\w* \w nord|strong="H06828"\w*.  
\v 45 \w Il|strong="H03548"\w* \w me|strong="H06440"\w* \w dit|strong="H01696"\w* : « \w Cette|strong="H01696"\w* \w chambre|strong="H03957"\w* \w dont|strong="H06440"\w* \w la|strong="H06440"\w* façade \w est|strong="H01870"\w* \w dans|strong="H06440"\w* \w la|strong="H06440"\w* \w direction|strong="H01870"\w* \w du|strong="H01004"\w* \w midi|strong="H01864"\w* \w est|strong="H01870"\w* \w pour|strong="H06440"\w* \w les|strong="H06440"\w* \w prêtres|strong="H03548"\w* \w qui|strong="H03548"\w* \w sont|strong="H01870"\w* \w chargés|strong="H08104"\w* \w du|strong="H01004"\w* \w service|strong="H04931"\w* \w de|strong="H01004"\w* \w la|strong="H06440"\w* \w maison|strong="H01004"\w*.  
\v 46 \w Et|strong="H01121"\w* \w la|strong="H06440"\w* \w chambre|strong="H03957"\w* \w dont|strong="H06440"\w* \w la|strong="H06440"\w* façade \w est|strong="H03068"\w* \w dans|strong="H06440"\w* \w la|strong="H06440"\w* \w direction|strong="H01870"\w* \w du|strong="H06440"\w* \w nord|strong="H06828"\w* \w est|strong="H03068"\w* \w pour|strong="H06440"\w* \w les|strong="H06440"\w* \w prêtres|strong="H03548"\w* \w chargés|strong="H08104"\w* \w du|strong="H06440"\w* \w service|strong="H08334"\w* \w de|strong="H01121"\w* \w l|strong="H06440"\w*’\w autel|strong="H04196"\w*. » \w Ce|strong="H01992"\w* \w sont|strong="H03068"\w* \w les|strong="H06440"\w* \w fils|strong="H01121"\w*\f + \fr 40:46 \ft 46. \ft \+it Les fils de Sadoc\+it* seulement (xliv, 10-16), et non pas les fils d’Aaron en général.\f* \w de|strong="H01121"\w* Sadoc \w qui|strong="H03548"\w*, \w parmi|strong="H06440"\w* \w les|strong="H06440"\w* \w enfants|strong="H01121"\w* \w de|strong="H01121"\w* \w Lévi|strong="H03878"\w*, \w s|strong="H01870"\w*’\w approchent|strong="H07131"\w* \w de|strong="H01121"\w* \nd \+w Yahweh|strong="H03068"\+w*\nd* \w pour|strong="H06440"\w* \w le|strong="H06440"\w* \w servir|strong="H08334"\w*.   
\p
\v 47 \w Puis|strong="H03201"\w* \w il|strong="H01732"\w* \w mesura|strong="H04058"\w* \w le|strong="H06440"\w* \w parvis|strong="H02691"\w*\f + \fr 40:47 \ft 47. \ft \+it Le parvis\+it*, l’espace de forme carrée réservé au dedans du parvis intérieur devant le temple, et entourant l’autel des holocaustes. — \+it Cent coudées de longueur\+it*, du portique de l’est jusqu’au temple ; cent coudées de largeur, du portique du nord jusqu’au portique du sud.\f*, \w qui|strong="H00376"\w* \w était|strong="H04196"\w* \w carré|strong="H07251"\w*, \w ayant|strong="H03701"\w* \w cent|strong="H03967"\w* \w coudées|strong="H00520"\w* \w de|strong="H01004"\w* \w longueur|strong="H00753"\w* \w et|strong="H06440"\w* \w cent|strong="H03967"\w* \w coudées|strong="H00520"\w* \w de|strong="H01004"\w* \w largeur|strong="H07341"\w*. \w L|strong="H06440"\w*’\w autel|strong="H04196"\w* \w était|strong="H04196"\w* \w devant|strong="H06440"\w* \w la|strong="H06440"\w* \w maison|strong="H01004"\w*.   
\s3 2.\sc Chap. xl, 48-xli, 26 : L’édifice du temple.\sc* — Vestibule (xl, 48, 49). le Saint (xli, 1, 2). Le Saint des saints (xli, 3, 4). L’édifice latéral (xli, 5-11). Le bâtiment à l’occident (xli, 12). Diverses mesures (xli, 13-15a), Ornementation et mobilier (xli, 15b-26).  
\p
\v 48 \w Il|strong="H01732"\w* \w me|strong="H01004"\w* \w conduisit|strong="H00935"\w* \w ensuite|strong="H00310"\w* \w vers|strong="H00935"\w* \w le|strong="H04058"\w* \w vestibule|strong="H00197"\w* \w de|strong="H01004"\w* \w la|strong="H04058"\w* \w maison|strong="H01004"\w*\f + \fr 40:48 \ft 48. \ft \+it Le vestibule de la maison\+it*, du temple proprement dit. — \+it Les piliers\+it*, le mur à droite et à gauche de la porte était épais de 5 coudées. Comp. 41, 5. — \+it La largeur du portique\+it* : peut-être la largeur de ses parois latérales en retour sur l’ouverture et diminuant celle-ci de six coudées ; ce qui donne quatorze coudées pour l’ouverture même du portique (voir vers, suivant). — LXX \+it Et la largeur du portique, quatorze coudées et les parois latérales de la porte (parois latérales en retour sur l’ouverture) du vestibule, trois coudées d’un côté et trois coudées de l’autre\+it*.\f*, \w et|strong="H01004"\w* \w il|strong="H01732"\w* \w mesura|strong="H04058"\w* \w le|strong="H04058"\w* pilier \w du|strong="H01004"\w* \w vestibule|strong="H00197"\w* : \w cinq|strong="H02568"\w* \w coudées|strong="H00520"\w* d’\w un|strong="H01004"\w* \w côté|strong="H06311"\w* \w et|strong="H01004"\w* \w cinq|strong="H02568"\w* \w coudées|strong="H00520"\w* \w de|strong="H01004"\w* l’\w autre|strong="H08179"\w* ; \w et|strong="H01004"\w* \w la|strong="H04058"\w* \w largeur|strong="H07341"\w* \w du|strong="H01004"\w* \w portique|strong="H00197"\w* : \w trois|strong="H07969"\w* \w coudées|strong="H00520"\w* d’\w un|strong="H01004"\w* \w côté|strong="H06311"\w* \w et|strong="H01004"\w* \w trois|strong="H07969"\w* \w coudées|strong="H00520"\w* \w de|strong="H01004"\w* l’\w autre|strong="H08179"\w*.  
\v 49 \w La|strong="H05927"\w* \w longueur|strong="H00753"\w* \w du|strong="H05927"\w* \w vestibule|strong="H00197"\w*\f + \fr 40:49 \ft 49. \ft \+it La longueur du vestibule\+it*, prise du nord au sud. — \+it La largeur\+it*, prise de l’est à l’ouest. LXX, \+it douze coudées et on y montait par dix degrés\+it*. — \+it Des colonnes\+it* : équivalent des colonnes de Booz et de Jakin dans le temple de Salomon. Comp. 1Ro 7,15 sv.\f* \w était|strong="H05892"\w* \w de|strong="H05982"\w* \w vingt|strong="H06242"\w* \w coudées|strong="H00520"\w*, \w et|strong="H06242"\w* \w la|strong="H05927"\w* \w largeur|strong="H07341"\w* \w de|strong="H05982"\w* \w onze|strong="H06249"\w* \w coudées|strong="H00520"\w*, \w aux|strong="H05927"\w* \w degrés|strong="H04609"\w* \w par|strong="H05927"\w* \w lesquels|strong="H02004"\w* \w on|strong="H00376"\w* \w y|strong="H08033"\w* \w montait|strong="H05927"\w* ; \w et|strong="H06242"\w* \w il|strong="H01732"\w* \w y|strong="H08033"\w* \w avait|strong="H05927"\w* \w des|strong="H05927"\w* \w colonnes|strong="H05982"\w* \w près|strong="H00681"\w* \w des|strong="H05927"\w* piliers, l’\w une|strong="H05927"\w* d’\w un|strong="H05927"\w* \w côté|strong="H06311"\w*, l’\w autre|strong="H06311"\w* \w de|strong="H05982"\w* l’\w autre|strong="H06311"\w*.   
\c 41
\p
\v 1 \w Puis|strong="H03201"\w* \w il|strong="H01732"\w* \w me|strong="H03068"\w* \w conduisit|strong="H00935"\w* \w dans|strong="H08432"\w* \w le|strong="H04058"\w* \w temple|strong="H01964"\w*, \w et|strong="H07341"\w* \w il|strong="H01732"\w* \w en|strong="H00935"\w* \w mesura|strong="H04058"\w* \w les|strong="H04058"\w* piliers\f + \fr 41:1 \ft XLI, 1. \ft \+it Les piliers\+it* formés par le retour des murs, qui avaient six coudées d’épaisseur ; l’intervalle d’un pilier à l’autre formait l’ouverture de la porte. — Les mots \+it largeur de la tente\+it* manquent dans les LXX.\f* : \w six|strong="H08337"\w* \w coudées|strong="H00520"\w* \w de|strong="H07341"\w* \w largeur|strong="H07341"\w* d’un \w côté|strong="H06311"\w*, \w et|strong="H07341"\w* \w six|strong="H08337"\w* \w coudées|strong="H00520"\w* \w de|strong="H07341"\w* \w largeur|strong="H07341"\w* \w de|strong="H07341"\w* l’\w autre|strong="H06311"\w* \w côté|strong="H06311"\w*, \w largeur|strong="H07341"\w* \w de|strong="H07341"\w* \w la|strong="H04058"\w* \w tente|strong="H00168"\w*.  
\v 2 \w La|strong="H04058"\w* \w largeur|strong="H07341"\w* \w de|strong="H07341"\w* \w la|strong="H04058"\w* \w porte|strong="H06607"\w* \w était|strong="H05892"\w* \w de|strong="H07341"\w* \w dix|strong="H06235"\w* \w coudées|strong="H00520"\w*\f + \fr 41:2 \ft 2. \ft \+it Dix coudées\+it* : c’était exactement la largeur de l’ancien tabernacle. — \+it Les parois latérales\+it*, les deux murs à droite et à gauche de la porte. — Les dimensions sont les mêmes que celles du temple de Salomon.\f* ; \w les|strong="H04058"\w* \w parois|strong="H07023"\w* \w latérales|strong="H06763"\w* \w de|strong="H07341"\w* \w la|strong="H04058"\w* \w porte|strong="H06607"\w* \w avaient|strong="H03478"\w* \w cinq|strong="H02568"\w* \w coudées|strong="H00520"\w* d’un \w côté|strong="H03802"\w* \w et|strong="H06242"\w* \w cinq|strong="H02568"\w* \w coudées|strong="H00520"\w* \w de|strong="H07341"\w* l’\w autre|strong="H06311"\w*. \w Il|strong="H01732"\w* \w mesura|strong="H04058"\w* \w la|strong="H04058"\w* \w longueur|strong="H00753"\w* \w du|strong="H06607"\w* \w temple|strong="H01964"\w* : \w quarante|strong="H00705"\w* \w coudées|strong="H00520"\w*, \w et|strong="H06242"\w* \w la|strong="H04058"\w* \w largeur|strong="H07341"\w* : \w vingt|strong="H06242"\w* \w coudées|strong="H00520"\w*.   
\p
\v 3 \w Il|strong="H01732"\w* \w entra|strong="H00935"\w*\f + \fr 41:3 \ft 3. \ft \+it Il entra\+it* seul, nul autre que le grand-prêtre n’ayant le droit de pénétrer dans le Saint des saints. — \+it La porte\+it*, pour la largeur de la porte. — Au lieu \+it et la largeur de la porte, sept coudées\+it*, on a dans les LXX : \+it et les parois latérales de la porte avaient sept coudées d’un côté et sept coudées de l’autre\+it*.\f* \w ensuite|strong="H00310"\w* \w à|strong="H08147"\w* l’\w intérieur|strong="H06441"\w* \w et|strong="H07341"\w* \w il|strong="H01732"\w* \w mesura|strong="H04058"\w* \w les|strong="H04058"\w* piliers \w de|strong="H07341"\w* \w la|strong="H04058"\w* \w porte|strong="H06607"\w* : \w deux|strong="H08147"\w* \w coudées|strong="H00520"\w*, \w et|strong="H07341"\w* \w la|strong="H04058"\w* \w porte|strong="H06607"\w* elle-même : \w six|strong="H08337"\w* \w coudées|strong="H00520"\w*, \w et|strong="H07341"\w* \w la|strong="H04058"\w* \w largeur|strong="H07341"\w* \w de|strong="H07341"\w* \w la|strong="H04058"\w* \w porte|strong="H06607"\w* : \w sept|strong="H07651"\w* \w coudées|strong="H00520"\w*.  
\v 4 \w Il|strong="H02088"\w* \w mesura|strong="H04058"\w* \w une|strong="H06440"\w* \w longueur|strong="H00753"\w* \w de|strong="H06440"\w* \w vingt|strong="H06242"\w* \w coudées|strong="H00520"\w*\f + \fr 41:4 \ft 4. \ft \+it Vingt coudées\+it* de long, vingt de large et sans doute aussi vingt coudées de haut, comme dans le temple de Salomon, ce qui donnait an Saint des saints la forme d’un cube, symbole mathématique de la perfection. — \+it Du côté du temple\+it*, le long du Saint.\f* \w et|strong="H06242"\w* \w une|strong="H06440"\w* \w largeur|strong="H07341"\w* \w de|strong="H06440"\w* \w vingt|strong="H06242"\w* \w coudées|strong="H00520"\w* \w du|strong="H06440"\w* \w côté|strong="H06440"\w* \w du|strong="H06440"\w* \w temple|strong="H01964"\w*, \w et|strong="H06242"\w* \w il|strong="H02088"\w* \w me|strong="H06440"\w* \w dit|strong="H00559"\w* : « C’\w est|strong="H06440"\w* \w le|strong="H06440"\w* \w Saint|strong="H06944"\w* \w des|strong="H06440"\w* \w saints|strong="H06944"\w* ».   
\p
\v 5 \w Il|strong="H01732"\w* \w mesura|strong="H04058"\w* \w le|strong="H04058"\w* \w mur|strong="H07023"\w*\f + \fr 41:5 \ft 5. \ft \+it Le mur\+it*, son épaisseur. — \+it La largeur\+it*, l’espace compris entre le mur du temple et le mur de l’édifice latéral ; c’est dans cet intervalle que se trouvaient les cellules qui vont être décrites.\f* \w de|strong="H01004"\w* \w la|strong="H04058"\w* \w maison|strong="H01004"\w* : \w six|strong="H08337"\w* \w coudées|strong="H00520"\w*, \w et|strong="H01004"\w* \w la|strong="H04058"\w* \w largeur|strong="H07341"\w* \w de|strong="H01004"\w* l’édifice latéral, \w quatre|strong="H00702"\w* \w coudées|strong="H00520"\w*, \w tout|strong="H05439"\w* \w autour|strong="H05439"\w* \w de|strong="H01004"\w* \w la|strong="H04058"\w* \w maison|strong="H01004"\w*.  
\v 6 Quant \w aux|strong="H03808"\w* \w cellules|strong="H07064"\w* \w latérales|strong="H06763"\w*, \w il|strong="H01732"\w* \w y|strong="H01004"\w* \w avait|strong="H05439"\w* \w trois|strong="H07969"\w* \w cellules|strong="H07064"\w* superposées\f + \fr 41:6 \ft 6. \ft \+it Il y avait\+it* 3 étages de cellules, et 30 cellules par étage. C’étaient des réduits peu profonds où l’on devait conserver les ustensiles sacrés et le trésor de la maison de Yahweh (I Rois, vii, 51). Ces cellules étaient contre le temple, que les planchers s’appuyassent sur des retraites ménagées à la muraille du temple ou qu’il y eût un mur spécial. Les vers. 6 et 7 sont difficiles et les versions présentent des leçons assez divergentes. C’est surtout grâce à I Rois, vi, 5, 6, qu’on peut se retrouver dans ce texte.\f* , \w et|strong="H01004"\w* \w cela|strong="H01697"\w* \w trente|strong="H07970"\w* \w fois|strong="H06471"\w* ; \w elles|strong="H00310"\w* aboutissaient \w au|strong="H01004"\w* \w mur|strong="H07023"\w* \w construit|strong="H01124"\w* \w pour|strong="H01004"\w* \w ces|strong="H00310"\w* \w cellules|strong="H07064"\w* \w tout|strong="H05439"\w* \w autour|strong="H05439"\w* \w de|strong="H01004"\w* \w la|strong="H05439"\w* \w maison|strong="H01004"\w*, \w en|strong="H01004"\w* \w sorte|strong="H03318"\w* qu’\w elles|strong="H03808"\w* s’appuyaient \w sans|strong="H03808"\w* \w être|strong="H01961"\w* engagées \w dans|strong="H08432"\w* \w le|strong="H05439"\w* \w mur|strong="H07023"\w* \w de|strong="H01004"\w* \w la|strong="H05439"\w* \w maison|strong="H01004"\w*.  
\v 7 \w L|strong="H03068"\w*’\w espace|strong="H01004"\w* s’élargissait \w pour|strong="H05927"\w* \w la|strong="H05927"\w* circulation \w à|strong="H05927"\w* \w chaque|strong="H00259"\w* \w étage|strong="H03326"\w* \w de|strong="H01004"\w* \w cellules|strong="H07064"\w*, \w car|strong="H03588"\w* l’édifice \w avait|strong="H05439"\w* \w un|strong="H05927"\w* couloir circulaire \w à|strong="H05927"\w* \w chaque|strong="H00259"\w* \w étage|strong="H03326"\w* \w tout|strong="H05439"\w* \w autour|strong="H05439"\w* ; c’\w est|strong="H01004"\w* \w pourquoi|strong="H03651"\w* \w cette|strong="H05927"\w* \w partie|strong="H04481"\w* \w de|strong="H01004"\w* l’édifice s’élargissait \w à|strong="H05927"\w* \w chaque|strong="H00259"\w* \w étage|strong="H03326"\w*, \w et|strong="H05927"\w* \w ainsi|strong="H03651"\w* \w le|strong="H05927"\w* couloir d’\w en|strong="H05927"\w* \w bas|strong="H08481"\w* \w était|strong="H01004"\w* \w moins|strong="H04591"\w* \w large|strong="H07341"\w* \w que|strong="H03588"\w* \w celui|strong="H00376"\w* d’\w en|strong="H05927"\w* \w haut|strong="H04605"\w*, \w et|strong="H05927"\w* \w le|strong="H05927"\w* couloir \w du|strong="H01004"\w* \w milieu|strong="H08484"\w* \w en|strong="H05927"\w* \w proportion|strong="H06310"\w* \w des|strong="H01004"\w* \w deux|strong="H08147"\w* \w autres|strong="H05921"\w*\f + \fr 41:7 \ft 7. Il y avait entre les cellules et le mur extérieur un espace libre, un couloir, au moyen duquel on pouvait circuler de l’une à l’autre ; ce couloir devenait plus large à chaque étage de cellules, grâce aux retraites pratiquées dans la muraille à laquelle elles étaient adossées. — \ft \+it Et ainsi le couloir d’en bas\+it* etc. Traduction paraphrastique et hypothétique d’un texte incertain. LXX : \+it Et de l’étage inférieur on montait à celui d’au-dessus, et de celui du milieu au troisième étage\+it*.\f*.   
\p
\v 8 \w Je|strong="H05315"\w* \w vis|strong="H07200"\w* \w que|strong="H07200"\w* \w la|strong="H07200"\w* \w maison|strong="H01004"\w* \w tout|strong="H05439"\w* \w autour|strong="H05439"\w* \w était|strong="H01004"\w* \w sur|strong="H07200"\w* \w une|strong="H07200"\w* \w élévation|strong="H08641"\w* ; \w le|strong="H07200"\w* \w fondement|strong="H04328"\w* \w des|strong="H01004"\w* \w cellules|strong="H07064"\w* \w latérales|strong="H06763"\w* \w était|strong="H01004"\w* d’\w un|strong="H07200"\w* \w roseau|strong="H07070"\w* \w plein|strong="H04393"\w*, \w de|strong="H01004"\w* \w six|strong="H08337"\w* \w coudées|strong="H00520"\w* \w vers|strong="H00935"\w* l’angle.\f + \fr 41:8 \ft 8. Une assise massive, de 6 coudées plus haute que le sol du parvis intérieur, supportait l’édifice du temple, y compris les cellules et le mur extérieur ; elle dépassait même ce mur de 5 coudées (vers. 11), formant une espèce de perron. — \ft \+it Vers l’angle\+it* : la hauteur de l’assise fut mesurée à l’un des angles de la partie qui dépassait le mur.\f*  
\v 9 \w Le|strong="H01004"\w* \w mur|strong="H07023"\w* \w extérieur|strong="H02351"\w* \w de|strong="H01004"\w* l’édifice latéral \w était|strong="H01004"\w* \w large|strong="H07341"\w* \w de|strong="H01004"\w* \w cinq|strong="H02568"\w* \w coudées|strong="H00520"\w* ; \w à|strong="H01004"\w* \w la|strong="H01004"\w* \w suite|strong="H00319"\w*\f + \fr 41:9 \ft 9. \ft \+it À la suite\+it* etc. Traduction très incertaine.\f* \w venait|strong="H00935"\w* l’assise \w de|strong="H01004"\w* l’édifice latéral \w de|strong="H01004"\w* \w la|strong="H01004"\w* \w maison|strong="H01004"\w*.  
\v 10 \w De|strong="H01004"\w* \w là|strong="H05439"\w* jusqu’\w aux|strong="H01004"\w* \w chambres|strong="H03957"\w*\f + \fr 41:10 \ft 10. \ft \+it Aux chambres\+it*, qu’il ne faut pas confondre avec les cellules, et qui étaient situées au nord et au sud du parvis intérieur et servaient de vestiaire aux prêtres (xlii, 1-14).\f*, \w il|strong="H01732"\w* \w y|strong="H01004"\w* \w avait|strong="H05439"\w* \w une|strong="H01004"\w* \w largeur|strong="H07341"\w* \w de|strong="H01004"\w* \w vingt|strong="H06242"\w* \w coudées|strong="H00520"\w* \w tout|strong="H05439"\w* \w autour|strong="H05439"\w* \w de|strong="H01004"\w* \w la|strong="H05439"\w* \w maison|strong="H01004"\w*.  
\v 11 \w L|strong="H03068"\w*’\w entrée|strong="H06607"\w* \w de|strong="H01870"\w* l’édifice latéral \w était|strong="H01870"\w* \w sur|strong="H04427"\w* l’assise, \w une|strong="H04725"\w* \w porte|strong="H06607"\w* \w dans|strong="H08432"\w* \w la|strong="H01870"\w* \w direction|strong="H01870"\w* \w du|strong="H01870"\w* \w nord|strong="H06828"\w* \w et|strong="H07341"\w* \w une|strong="H04725"\w* \w porte|strong="H06607"\w* \w dans|strong="H08432"\w* \w la|strong="H01870"\w* \w direction|strong="H01870"\w* \w du|strong="H01870"\w* \w midi|strong="H01864"\w* ; \w la|strong="H01870"\w* \w largeur|strong="H07341"\w* \w de|strong="H01870"\w* l’assise \w était|strong="H01870"\w* \w de|strong="H01870"\w* \w cinq|strong="H02568"\w* \w coudées|strong="H00520"\w* \w tout|strong="H05439"\w* \w autour|strong="H05439"\w*.   
\p
\v 12 \w Le|strong="H06440"\w* \w bâtiment|strong="H01146"\w*\f + \fr 41:12 \ft 12. \ft \+it Le bâtiment\+it* : d’après II Rois, xxiii, 11 et I Par. xxvi, 18, il devait y avoir derrière le temple de Salomon un édifice servant de magasin. C’est à cette construction que répond le bâtiment dont il est ici question ; il était situé à l’ouest du temple.\f* \w qui|strong="H07023"\w* \w était|strong="H03220"\w* \w en|strong="H06440"\w* \w face|strong="H06440"\w* \w de|strong="H06440"\w* \w l|strong="H06440"\w*’\w espace|strong="H06440"\w* \w vide|strong="H01508"\w* \w du|strong="H06440"\w* \w côté|strong="H06285"\w* \w de|strong="H06440"\w* \w l|strong="H06440"\w*’\w occident|strong="H03220"\w* \w avait|strong="H05439"\w* \w soixante-dix|strong="H06440"\w* \w coudées|strong="H00520"\w* \w de|strong="H06440"\w* \w large|strong="H07341"\w* ; \w la|strong="H06440"\w* \w muraille|strong="H07023"\w* \w du|strong="H06440"\w* \w bâtiment|strong="H01146"\w* \w avait|strong="H05439"\w* \w cinq|strong="H02568"\w* \w coudées|strong="H00520"\w* \w de|strong="H06440"\w* \w large|strong="H07341"\w* \w tout|strong="H05439"\w* \w autour|strong="H05439"\w*, \w et|strong="H06440"\w* \w sa|strong="H06440"\w* \w longueur|strong="H00753"\w* \w était|strong="H03220"\w* \w de|strong="H06440"\w* quatre-vingt-dix \w coudées|strong="H00520"\w*.   
\p
