\v 8 \w and|strong="H1121"\w* \w Koz|strong="H6976"\w*, \w who|strong="H1121"\w* \w was|strong="H1121"\w* \w the|strong="H3205"\w* \w father|strong="H3205"\w* \w of|strong="H1121"\w* \w Anub|strong="H6036"\w* \w and|strong="H1121"\w* \w Hazzobebah|strong="H6637"\w* \w and|strong="H1121"\w* \w of|strong="H1121"\w* \w the|strong="H3205"\w* \w families|strong="H4940"\w* \w of|strong="H1121"\w* Aharhel, \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Harum|strong="H2037"\w*.
\p 
\v 9 \w Jabez|strong="H3258"\w* \w was|strong="H8034"\w* \w more|strong="H3588"\w* faithful \w to|strong="H1961"\w* God\f + \fr 4:9 \ft “More faithful to God”: literally, “more honorable,” but this does not carry the meaning of a better relationship to God.\f* \w than|strong="H3588"\w* \w his|strong="H7121"\w* brothers. \w His|strong="H7121"\w* mother \w had|strong="H1961"\w* \w given|strong="H3205"\w* \w him|strong="H3205"\w* \w the|strong="H3588"\w* \w name|strong="H8034"\w* \w Jabez|strong="H3258"\w*, saying, “\w I|strong="H3588"\w* \w gave|strong="H3205"\w* \w birth|strong="H3205"\w* \w to|strong="H1961"\w* \w him|strong="H3205"\w* \w in|strong="H8034"\w* \w pain|strong="H6090"\w*.”
\v 10 \w Jabez|strong="H3258"\w* \w begged|strong="H7592"\w* \w the|strong="H6213"\w* \w God|strong="H3027"\w* \w of|strong="H3027"\w* \w Israel|strong="H3478"\w*, “\w Please|strong="H7451"\w* \w bless|strong="H1288"\w* \w me|strong="H7121"\w* \w and|strong="H3478"\w* expand \w my|strong="H1961"\w* \w borders|strong="H1366"\w*!\f + \fr 4:10 \ft “Expand my borders”: or, “enlarge my territory.” While this may be seen as simply a request for greater land ownership, it is perhaps better to understand this request that God would expand all that Jabez had, including spiritual aspects.\f* \w Be|strong="H1961"\w* \w with|strong="H5973"\w* \w me|strong="H7121"\w* \w and|strong="H3478"\w* \w keep|strong="H6213"\w* \w me|strong="H7121"\w* safe \w from|strong="H3478"\w* \w harm|strong="H7451"\w* \w so|strong="H6213"\w* \w I|strong="H3027"\w* won't \w have|strong="H1961"\w* \w pain|strong="H7451"\w*.”\f + \fr 4:10 \ft “Pain”: part of the prayer is a desire that despite the name his mother gave him that he would not thereby be cursed to suffer pain.\f* \w And|strong="H3478"\w* \w God|strong="H3027"\w* \w gave|strong="H7121"\w* \w him|strong="H7121"\w* \w what|strong="H7451"\w* \w he|strong="H6213"\w* \w asked|strong="H7592"\w* \w for|strong="H7121"\w*.
