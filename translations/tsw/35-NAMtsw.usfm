\id NAM - Tsishingini (tsw)
\h Nahum
\toc3 Nah
\toc2 Nahum
\toc1 Nahum
\mt2 Aatagada a Nahum
\mt1 Nahum
\is1 Ucuɗuwu wa aatagada a nda
\ip Aatagada a Nahum Ishipa i ɗa na o rocosu ma̱za̱nga̱ mo uriyu wa Niniva, lyuci gbain va Asuriya, za na a yuwusan tsushu'un na̱ Isra'ila. U ta gura wo o'wo a ɗana ta̱ aatagada'a o una̱ wa a'wan Ukpakuta̱li na̱ kupa ne ejere 612 babu na a matsain Yesu. A̱risa̱ a Niniva a̱ ta̱ rocosu uge'etosu wa̱ A̱sula̱ adama aciyogbamu a̱ yi oɓolo na̱ a̱bunda̱ e iwuya i na u ri na̱ yi. Uge'etosu u nda u fara ta̱ o ukosu u mantsa ma̱ cindere babu na a matsain Yesu.
\is1 Ili i na i ri pe:
\io1 1. Uge'etosu wa Niniva 1:1-15
\io1 2. Uriyu wa Niniva 2:1-3:19
\c 1
\p 
\v 1 Adanshi e ikaka ya̱ A̱sula̱ a̱ tyo Niniva. Aatagada a alavu alavu a na Nahum vuma va Elikoshi enei.\x - \xo 1:1 \xt Isha 10:5-34; 14:24-27; Zaf 2:13-15.\x*
\s1 Upan wa̱ A̱sulazuva aci a Niniva
\q1 
\v 2 A̱sulazuva A̱sula̱ a̱ tsushu'un a ɗa,
\q2 waru za va atsupu a ɗa.
\q1 A̱sulazuva za va atsupu a ɗa,
\q2 waru za vu upan wu usuɗuwu.
\q1 U tsu tsupa ta̱
\q2 e ekere a n'yuwatan ma̱ yi.
\q2 A̱ ta̱wusa̱a̱ n'yuwatan ma̱ yi nu upan.
\q1 
\v 3 A̱sulazuva a tsu yuwan upan go'o shi,
\q2 waru za vu ucira u ɗa lon,
\q2 u tsu lyawa za vu unusu ka̱ra̱ fa̱a̱n shi.
\b
\q1 Ure wa̱ yi u ta̱ pe a̱tsuma̱ a̱ lipa̱ na̱ wunla̱,
\q2 eleshe waru ma̱buta̱ ma apata ana a̱ yi.
\q1 
\v 4 U tsu ɓara ta̱ mala hali u 'yewe,
\q2 waru u tsu 'yeweto ta̱ ɗolu suru.
\q1 Bashan na̱ Kame a̱ tsu 'yewe ta̱,
\q2 yipa̱lu ya Lebanon fo a tsu kpanla ta̱.
\q1 
\v 5 Nsasan n tsu jinga̱ɗa̱ ta̱ elime a̱ yi,
\q2 agaɗi waru e jeruwe.
\q1 Uvaɗi u jinga̱ɗa̱ ta̱ elime a̱ yi
\q2 na aza a na a̱ ri pe a̱tsuma̱ a̱ yi.
\q1 
\v 6 Zane ɗa aa gura isawan a̱ ma̱ka̱ka̱n ma̱ yi
\q2 nu u yuwan upan?
\q1 Zane ɗa aa gura isawaan
\q2 usuɗuwu wu upan wa̱ yi?
\q1 Upan wa̱ yi u to ocusho tsa a akina,
\q2 atali a̱ ta̱ ɓosuso a̱ ma̱ka̱ka̱n ma̱ yi.
\q1 
\v 7 A̱sulazuva za vi isa'ani i ɗa,
\q2 uba̱ta̱ wu upa'atan wu ucira
\q2 a mantsa ma addama.
\q1 Waru u ta aɗa aza a na a zuwai ucira u le ya̱'a̱ yi.
\q1 
\v 8 Agba na̱ mini ma gbain ma ɗa
\q2 A̱sulazuva o kototo Niniva,
\q2 u ta̱ lo n'yuwatan ma̱ yi a̱ tyo e irumbu.
\q1 
\v 9 Ili i na o foɓoi aci A̱sulazuva biti
\q2 u ta rawa utyo.
\q2 Addama a̱ da̱shi ta̱wa̱ wa̱ ire shi.
\q1 
\v 10 O to o'wo tsi ili i na awanda a̱ guza̱i
\q2 reve o'wo gashi aza a na ma̱ra̱ ma̱ tsura̱to yi,
\q2 a̱ ta̱ kuloto le tsa anlya o u'yewu.
\q1 
\v 11 A̱tsuma̱ Niniva a ɗa vuma ro uta̱i,
\q2 za na foɓoyi A̱sulazuva iwuya,
\q1 reve u ca a̱sa̱la̱ e pere.
\p 
\v 12 Apa ili i na A̱sulazuva a dammai,
\q1 <<Ko na wo o'woi a̱ ta̱ na aza a na o ɓoloi aci na̱ a̱bunda̱,
\q2 o to koɗo ɗu reve a̱ tsun ɗu a̱ nge'en.
\q1 A̱ɗu aza a Yahuda ko na wo o'woi
\q2 n ca ɗu ta̱ a̱tsuma̱lima̱,
\q2 ma̱a̱ da̱shi yuwan ne shi.
\q1 
\v 13 Gogo n ta kuɗa a̱a̱gba̱la̱ e inan yi iluma i na u zuwaa nɗu a̱ yinlu,
\q2 reve n kakasa akani a na a̱ nla̱ ɗu na̱ yi.>>
\b
\q1 
\v 14 A̱sulazuva a yuwan ta̱ adanshi
\q2 a aci a̱ wu Nineva a na,
\q1 <<Vu buwa a̱ tsura̱ muwun mu ugundo
\q2 n na e ɗe na aala a̱ wu shi.
\q1 Waru n ta̱ kototo musula̱ n na i she'ein
\q2 na̱ a̱ma̱li a na a̱ zuɗa̱i,
\q1 aza musa'a n ɗu.
\q1 N ta̱ foɓoo ɗu aason,
\q2 adama a na i ri nu urana shi.>>
\b
\q1 
\v 15 Ka̱lyuwa̱! Zuva vu nsasan m gbagbain
\q2 ana aza a na a̱ ta̱wusa̱a̱ na alabari asa'ani,
\q2 za na a cuɗuwusa asuvu nden!
\q1 A̱vu Yahuda vu yuwan a̱buki a̱ wu,
\q2 vu shiton akucunu a̱ wu.
\q1 Adama a na n'yuwatan n buwa
\q2 a̱ ka̱nda̱ruwa̱ wu shi
\q2 o to kototo le suru suru.
\c 2
\s1 A̱risa̱ a̱ lyuci va Niniva
\q1 
\v 1 Za vu ulungusu ta̱wa̱ ta̱ aci a̱ wu Niniva,
\q2 vu geshe ba̱ta̱ vu upa'atan
\q2 vi idana re
\q2 vi isawan nu ucira,
\q2 vu ɓoloto a̱za̱ e ipiri ya̱ wu suru!
\b
\q1 
\v 2 Ko na̱ shi a damma a̱za̱ o ulungusu wu utsuru
\q2 a̱ shi a̱ ta̱ a̱ lungusa̱ utsuru wi iɗa i le,
\q2 ko shi gba a damma a̱ lungusa̱ ta̱ eten a ataci a ina̱bi i le,
\q1 A̱sulazuva gba ta̱ ka̱mbuwa̱a̱ Isra'ila na̱ tsugbain tsa a̱ yi suru.
\b
\q1 
\v 3 A̱ra̱ga̱ ali o uvon a Niniva
\q2 a̱za̱ a̱ shili a ɗa,
\q1 a̱soja a̱ yi a̱ ta̱ wotowu
\q2 na̱ a̱tugu a̱ shili a̱ ma̱ɗiya̱.
\q1 Irumu yi ikeke yi ido i le i da̱na̱ ta̱ e ikanasa
\q2 urana u na o foɓo n le
\q2 a fabusa ibata nu ucasu u wovon.
\q1 
\v 4 Ikeke yi ido'o
\q2 a̱ da̱na̱ ta̱ e ilaɗi ujaru a̱tsuma̱ e re,
\q1 reve a sumusa na̱ a̱ 'ya̱wi na̱ a̱ ka̱mbi
\q2 a̱tsuma̱ agalaci a̱ lyuci'i.
\q1 a̱ ta̱ tsi fitila,
\q2 a̱ ka̱ra̱sa̱ tsi imaɗatsu.
\b
\q1 
\v 5 Reve mogono ma Niniva mo ɓoloto ali o uvon a̱ yi,
\q2 a̱vu a̱ ka̱ra̱ a̱ ta̱ɗa̱tsa̱sa̱ a̱ 'ya̱wa̱,
\q1 a̱ jika̱ a̱ tyo o ukari u lyuci,
\q2 a̱ shuwa̱ ili i na a yuwaan aciyele mapari.
\q1 
\v 6 A̱ kpa̱tu'wa̱ ta̱ agula o ɗolu,
\q2 reve ukobu u mogono wo oco.
\q1 
\v 7 Adanshi ma̱ 'ya̱wa̱a̱ ma tsugbashi me e iɗa ya Niniva ma̱ ta̱ lo.
\q2 Agbashi e esheli a̱ ta̱ da̱na̱ e mesun tsa muɗa
\q2 no o korosoyi ekere aci.
\q1 
\v 8 Niniva ta̱ tsa aagula
\q2 a na o ɓosoi,
\q1 Waru a ta yisali a dansa, <<Isawain! Isawain!>>
\q2 Agba babu za na vadalai.
\b
\q1 
\v 9 I pura̱ azurufa!
\q2 I pura̱ zinariya!
\q1 Utsuru wa̱ yi u ri na̱ utyo shi,
\q2 na̱ cu'un vu utsuru va̱ yi biti
\q2 diga uba̱ta̱ wi izuwa ya̱ yi!
\q1 
\v 10 Niniva la̱nga̱ ta̱,
\q2 waru u kuwa̱ ta̱,
\q2 reve wo o'wo okongo!
\q1 Okolo ama a̱ yi a kuɗa ta̱,
\q2 a̱lu e le a̱ ka̱ra̱ ta̱ e meje'en,
\q2 waru rewesu le rakpatsa ta̱.
\b
\q1 
\v 11 Nye ɗa i shi i cinai lyuci ndolo Niniva
\q2 za na shi vadama a̱ba̱nu e ikamu?
\q1 A̱ba̱nu a na a tsu lyuwato muwun mi ikamu,
\q2 uba̱ta̱ u na kamu na̱ ka vu kamu tsu yuwusan alyuna,
\q2 oɓolo na̱ muwun mi ikamu babu wovon?
\q1 
\v 12 Kamu kakara ta̱ ili na̱ a̱bunda̱
\q2 adama a̱ muwun ma̱ yi,
\q1 waru wu una ta̱ fo ka vu kamu va̱ yi nama.
\q2 A̱vu u shiton a̱ba̱nu a̱ yi ni ili i na wu unai,
\q2 a̱ba̱nu a̱ yi fo ni inama'a.
\b
\q1 
\v 13 Reve A̱sulazuva oɓolo a̱ a̱soja a zuva damma,
\q2 <<A̱yi ɗa nda, n ta̱ riya̱a̱ Niniva!
\q1 A̱vu n kuloto ikeke yi ido ya̱ yi na akina.
\q2 Matsun me pe'eni ma ta lyuwa a̱ a̱soja a̱ yi.
\q2 Aza a na a̱ ri tsi ikamu yu ucira.
\q1 N ta putsa yi na woo kototo nɗa mu uvaɗi,
\q2 reve n putsaa nlingata ma̱ yi
\q2 na 'ya̱wa̱a̱ ni ikaka i wovon.>>
\c 3
\s1 Niniva to o'wo okongo
\q1 
\v 1 Woo yo'ono wu shi!
\q1 A̱vu lyuci na ocosu mpasa,
\q2 zana ri tapu ne epen
\q2 za na ri tapu ni itana i na a̱ pura̱i,
\q2 u lamba itana i na a usai shi!
\q1 
\v 2 Uwwa! Mesun ma asuɗu
\q2 na̱ mesun ma̱ a̱ga̱nda̱mu e ikeke,
\q2 na̱ mesun me ilaɗi yi ido kirib kirib
\q2 na̱ cine ikeke'e a̱ jinga̱ɗa̱sa̱ iɗa!
\q1 
\v 3 Ka̱lyuwa̱! Aza a na a kumbusa ido
\q2 a̱ ta̱ a̱tsuma̱ o uvon,
\q1 mutsun m pe'eni n ta a madala
\q2 ɓolo ni ibata,
\q2 waru apa a̱bunda̱ ama a na o unai.
\q1 Apa oɓolo a̱kwa̱kwa̱,
\q2 a na a̱ ri n kece shi,
\q2 ama a̱ ka̱ra̱ ta̱ a̱ ta̱ɗa̱tsa̱sa̱
\q2 zuva va̱ a̱kwa̱kwa̱.
\q1 
\v 4 Ili i nda i fara ta̱ suru
\q2 adama a̱bunda̱ a tsushakala a Niniva,
\q2 aashakala o una̱ wu uyo'o u ndolo,
\q2 mma va̱ a̱za̱ nkunu,
\q1 za na pusa̱yin nɗa
\q2 a̱tsuma̱ o ure u tsu shakala tsa̱ a̱ yi,
\q2 ne elentsu a̱tsuma̱ o ure u tsuboci tsa̱ a̱ yi.
\b
\q1 
\v 5 A̱sulazuva o oɓolo a̱ a̱soja a damma ta̱,
\q2 <<A̱yi ɗa nda, n ri tsushu'un na̱ Niniva,
\q1 n ta̱ 'ya̱sa̱n ma̱kuru ma̱ wu
\q2 n roco nɗa ataɓu a̱ wu,
\q2 reve vo o'wo ili i wono e ekere o tsugono tsu uvaɗi suru.
\q1 
\v 6 N ta kusha'wa wu ili yi idaba,
\q2 a̱vu n ca wu wono
\q2 mo o'woto wu ili i na o goro.
\q1 
\v 7 Aza a na a̱ ka̱lyuwa̱ nuwu suru
\q2 o to rono na̱ a̱ca̱pa̱ a damma,
\q1 <Ili ya asalama!
\q2 Niniva wo o'wo ta̱ okongo,
\q2 zane ɗa a̱ shon
\q2 adama a̱ yi?
\q1 A te ɗa ma̱a̱ tsura̱a̱ wu
\q2 aza a na a ca wu adanshi?> >>
\b
\q1 
\v 8 Niniva, vu la'a ta̱ lyuci va̱ Tebe,
\q2 zana ri o una̱ wu Uɗolu wa̱ Nilu ɗa?
\q1 A̱yi fo mini ma ɗa ma̱ ka̱nda̱ruwa̱ niyi,
\q2 mala ma ɗa uba̱ta̱ wu upa'atan wa̱ a̱ yi,
\q2 mini ma ɗa ukari wa̱ yi.
\q1 
\v 9 Kush na̱ Masar ɗa ucira wa̱ yi,
\q2 waru ucira wa̱ yi u ri nu utyo shi.
\q2 Put na̱ Libiya e le ɗa aza a na o ɓoloso una̱ na̱ yi.
\q1 
\v 10 Nu ucira wa̱ yi suru a̱ pura̱i ta̱
\q2 a̱ 'ya̱wa̱ e iɗa i tsugbashi,
\q2 a̱ ka̱ra̱ ta̱ na̱ yi a̱ tyo e iɗa i ro.
\q1 O ɓuɓosuso ta̱ aci a̱ nreɓu ma̱ yi,
\q2 oboguzu e re suru.
\q1 E ne'eshen ta̱ mbara ma̱ yi
\q2 a̱tsuma̱ o ure u matawa ma agita,
\q2 a̱ nla̱ ta̱ azagbain a̱ yi na akani suru.
\q1 
\v 11 Niniva vu to o'wo usowu tim,
\q2 waru vu to sowo a̱tsuma̱lima̱ lon.
\q1 Vu ta zami uba̱ta̱ wu upa'atan,
\q2 diga e ekere a n'yuwatan ma̱ wu.
\q1 
\v 12 Ba̱ta̱ vu ɓaɓu va̱ wu ri nu ucira shi,
\q2 a ta lyuwa le tsu umatsun wu ubiri na e inai.
\q1 A mantsa ma na a̱ jinga̱ɗa̱i ɗanga'a,
\q2 a̱vu muwu'un a̱ riya̱
\q2 o una̱ wu za va alya.
\q1 
\v 13 Ka̱lyuwa̱ a̱soja o uvon a̱ wu,
\q2 a̱ ta̱ tsa̱ a̱ma̱ci.
\q1 Na̱ntsu lyuci va̱ wu ukpa̱tu'u ɗa a̱ ri
\q2 e ekere a n'yuwatan ma̱ wu.
\q2 Akina a lyuwa ta̱ ɗanga vu ukatsusu vu na̱ntsu va̱ wu.
\q1 
\v 14 Rono mini adama a na a̱ ta̱ ka̱nda̱ruwa̱ wu,
\q2 vu tsura̱ mini ma̱ a̱bunda̱
\q2 kafu uvo'on u teme.
\q1 Vu da̱shi ugbamu wu uɓaɓu wa̱ wu!
\q2 Vu ka̱ra̱ a̱ 'ya̱wa̱ o uɓaa
\q2 vu dadasa ci'in,
\q2 reve vu tara ili i ma̱zuɗa̱ me ikunku!
\q1 
\v 15 Ni ifoɓi i nda suru,
\q2 akina a ta lyuwa wu,
\q1 matsun mepe'eni ma̱ ta̱ kototo wu,
\q2 waru u ta tama wu tsa apapari.
\b
\q1 Vu da̱shi ta̱ a̱bunda̱ tsa apapari,
\q2 reve vu da̱shi a̱bunda̱ tso oɓolo akyun!
\q1 
\v 16 Vu da̱shi ta̱ a̱bunda̱
\q2 aza atsulu na wina a̱ wu
\q2 hali a la'a oɓolo a̱ yitele'o ya zuva.
\q1 A̱ ta̱ tsa akyun
\q2 a na a tsu yuwan ulungusu
\q2 reve a̱ kpa̱tu'wa̱ evelu e le a 'yawan.
\q1 
\v 17 Aza e ipiri ya̱ wu a̱ ta̱ a̱bunda̱
\q2 va damma akyun a na a̱ ri a̱ ma̱ka̱ra̱
\q2 azagbain a̱ wu a̱ ta̱ tso o oɓolo apapari,
\q1 nden zuva va alya
\q2 a mantsa mo uta̱nu.
\q1 Mantsa ma na urana u suɗuwai,
\q2 a̱vu a 'yawan,
\q2 waru babu za na tsu reve
\q2 uba̱ta̱ u na a̱ tyo yi.
\b
\q1 
\v 18 <<A̱vu mogono ma Asuriya
\q2 aza a na e idanasa ama a̱ wu a̱ ta̱ nlavu,
\q2 mbara ma̱ wu fo n ta nlavu.
\q1 Akapi a ama a̱ wu a̱ ta̱ ubetu'wu
\q2 tsi ikyon zuva vu nsasan,
\q2 a̱ ri na̱ za va aguɓa a na oɓoloto le shi.
\q1 
\v 19 Babu ili i na ya inato wuntsu a̱ wu,
\q2 adama a na wuntsu wa̱ wu
\q2 za a na a̱ tsu ta̱wa̱ nu ukwisa̱ u ɗa.
\q1 Zana uwwai adama a ɗa wu
\q2 u ta ɓasa ekere a̱ yi u damma, <Ulobono ta̱!>
\q1 Adama a na za lo
\q2 na kuɗa̱i o sowo a̱tsuma̱lima̱
\q2 diga e ekere a̱ wu shi?>>
