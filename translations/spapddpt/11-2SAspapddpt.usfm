\c 18
\s1 Derrota y muerte de Absalón
\p 
\v 1 Entonces \w David|strong="H1732"\w* pasó revista \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w gente|strong="H5971"\w* \w que|strong="H5921"\w* tenía \w consigo|strong="H5921"\w*, \w y|strong="H5921"\w* designó \w para|strong="H5921"\w* \w ellos|strong="H5921"\w* \w jefes|strong="H8269"\w* \w de|strong="H5921"\w* miles \w y|strong="H5921"\w* \w jefes|strong="H8269"\w* \w de|strong="H5921"\w* cientos.
\v 2 \w Luego|strong="H3318"\w* \w David|strong="H1732"\w* \w envió|strong="H7971"\w* \w al|strong="H4428"\w* \w pueblo|strong="H5971"\w*: una \w tercera|strong="H7992"\w* parte \w al|strong="H4428"\w* \w mando|strong="H7971"\w* \w de|strong="H5973"\w* \w Joab|strong="H3097"\w*, otra \w tercera|strong="H7992"\w* parte \w al|strong="H4428"\w* \w mando|strong="H7971"\w* \w de|strong="H5973"\w* Abisai, \w hijo|strong="H1121"\w* \w de|strong="H5973"\w* Sarvia, hermano \w de|strong="H5973"\w* \w Joab|strong="H3097"\w*, \w y|strong="H1571"\w* \w la|strong="H1571"\w* otra \w tercera|strong="H7992"\w* parte \w al|strong="H4428"\w* \w mando|strong="H7971"\w* \w de|strong="H5973"\w* Itai geteo. \w Y|strong="H3068"\w* \w el|strong="H5973"\w* \w rey|strong="H4428"\w* dijo \w al|strong="H4428"\w* \w pueblo|strong="H5971"\w*: Yo \w mismo|strong="H1571"\w* \w también|strong="H1571"\w* \w saldré|strong="H3318"\w* \w con|strong="H5973"\w* ustedes.
\v 3 \w Pero|strong="H3588"\w* \w el|strong="H3588"\w* \w pueblo|strong="H5971"\w* dijo: \w No|strong="H3808"\w* \w saldrás|strong="H3318"\w*, \w porque|strong="H3588"\w* \w si|strong="H3588"\w* nosotros tenemos \w que|strong="H3588"\w* huir, \w no|strong="H3808"\w* nos \w harán|strong="H7760"\w* \w caso|strong="H3820"\w*. \w Aunque|strong="H3588"\w* \w la|strong="H3588"\w* mitad \w de|strong="H3588"\w* nosotros \w muera|strong="H4191"\w*, \w no|strong="H3808"\w* nos \w harán|strong="H7760"\w* \w caso|strong="H3820"\w*, \w pero|strong="H3588"\w* tú vales hoy \w como|strong="H3588"\w* 10.000 \w de|strong="H3588"\w* nosotros. \w Así|strong="H3588"\w* \w que|strong="H3588"\w* \w será|strong="H1961"\w* \w mejor|strong="H2896"\w* \w que|strong="H3588"\w* nos ayudes desde \w la|strong="H3588"\w* \w ciudad|strong="H5892"\w*.
\v 4 \w El|strong="H3605"\w* \w rey|strong="H4428"\w* les respondió: \w Haré|strong="H6213"\w* \w lo|strong="H6213"\w* \w que|strong="H5971"\w* les parezca \w bien|strong="H3190"\w*. \w Y|strong="H3068"\w* \w el|strong="H3605"\w* \w rey|strong="H4428"\w* \w se|strong="H5971"\w* detuvo \w junto|strong="H3027"\w* \w a|strong="H3068"\w* \w la|strong="H3605"\w* entrada, \w mientras|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* salía \w por|strong="H3027"\w* cientos y \w por|strong="H3027"\w* miles.
\v 5 \w Y|strong="H3068"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* dio \w orden|strong="H6680"\w* \w a|strong="H3068"\w* \w Joab|strong="H3097"\w*, Abisai \w e|strong="H3068"\w* Itai: Traten \w con|strong="H5921"\w* espíritu \w de|strong="H5921"\w* perdón \w al|strong="H5921"\w* joven Absalón \w por|strong="H5921"\w* amor \w a|strong="H3068"\w* \w mí|strong="H5921"\w*. \w Todo|strong="H3605"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* \w oyó|strong="H8085"\w* cuando \w el|strong="H5921"\w* \w rey|strong="H4428"\w* dio \w orden|strong="H6680"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w jefes|strong="H8269"\w* \w acerca|strong="H5921"\w* \w de|strong="H5921"\w* Absalón.
\p 
\v 6 Entonces el \w pueblo|strong="H5971"\w* \w salió|strong="H3318"\w* \w a|strong="H3068"\w* enfrentar \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* \w en|strong="H3318"\w* el \w campo|strong="H7704"\w*. La \w batalla|strong="H4421"\w* \w se|strong="H1961"\w* libró \w en|strong="H3318"\w* el \w bosque|strong="H3293"\w* \w de|strong="H5971"\w* Efraín.
\v 7 \w Allí|strong="H8033"\w* \w el|strong="H1931"\w* \w pueblo|strong="H5971"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w* \w fue|strong="H1961"\w* derrotado \w ante|strong="H6440"\w* \w los|strong="H1931"\w* esclavos \w de|strong="H6440"\w* \w David|strong="H1732"\w*, y en \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w hubo|strong="H1961"\w* una \w matanza|strong="H4046"\w* \w de|strong="H6440"\w* 20.000 hombres.
\v 8 \w La|strong="H1931"\w* \w batalla|strong="H4421"\w* \w se|strong="H1961"\w* extendió \w sobre|strong="H5921"\w* \w la|strong="H1931"\w* superficie \w de|strong="H5921"\w* \w toda|strong="H3605"\w* \w aquella|strong="H1931"\w* tierra, \w y|strong="H5921"\w* \w en|strong="H5921"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w el|strong="H1931"\w* \w bosque|strong="H3293"\w* mató \w más|strong="H5921"\w* \w gente|strong="H5971"\w* \w que|strong="H1931"\w* \w la|strong="H1931"\w* \w que|strong="H1931"\w* devoró \w la|strong="H1931"\w* \w espada|strong="H2719"\w*.
\p 
\v 9 Absalón \w se|strong="H5921"\w* halló \w ante|strong="H6440"\w* \w los|strong="H5921"\w* esclavos \w de|strong="H5921"\w* \w David|strong="H1732"\w* \w e|strong="H3068"\w* \w iba|strong="H7392"\w* \w montado|strong="H7392"\w* \w en|strong="H5921"\w* una mula. \w Al|strong="H5921"\w* \w pasar|strong="H5674"\w* \w la|strong="H5921"\w* mula \w por|strong="H5921"\w* \w debajo|strong="H8478"\w* \w del|strong="H5921"\w* ramaje \w de|strong="H5921"\w* un \w gran|strong="H1419"\w* roble, \w se|strong="H5921"\w* \w le|strong="H5921"\w* enredó fuertemente \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* roble, \w y|strong="H5921"\w* quedó suspendido \w entre|strong="H5921"\w* \w el|strong="H5921"\w* \w cielo|strong="H8064"\w* \w y|strong="H5921"\w* \w la|strong="H5921"\w* tierra. \w Y|strong="H3068"\w* \w la|strong="H5921"\w* mula \w que|strong="H5921"\w* tenía \w debajo|strong="H8478"\w* \w de|strong="H5921"\w* \w él|strong="H5921"\w*, siguió adelante.
\v 10 Lo \w vio|strong="H7200"\w* cierto hombre \w e|strong="H3068"\w* informó \w a|strong="H3068"\w* \w Joab|strong="H3097"\w*: ¡\w Mira|strong="H7200"\w*, acabo de \w ver|strong="H7200"\w* \w a|strong="H3068"\w* Absalón \w colgado|strong="H8518"\w* en un roble!
\p 
\v 11 \w Joab|strong="H3097"\w* \w dijo|strong="H5046"\w* \w al|strong="H5921"\w* hombre \w que|strong="H3808"\w* \w le|strong="H5921"\w* \w dio|strong="H5414"\w* \w la|strong="H5921"\w* noticia: \w Y|strong="H3068"\w* \w al|strong="H5921"\w* verlo tú, ¿\w por|strong="H5921"\w* \w qué|strong="H3808"\w* \w no|strong="H3808"\w* \w lo|strong="H3808"\w* \w heriste|strong="H5221"\w* \w allí|strong="H8033"\w* \w y|strong="H5921"\w* \w lo|strong="H3808"\w* derribaste \w a|strong="H3068"\w* tierra? \w Yo|strong="H2009"\w* \w te|strong="H5921"\w* habría \w dado|strong="H5414"\w* 110 gramos \w de|strong="H5921"\w* \w plata|strong="H3701"\w* \w y|strong="H5921"\w* un cinturón.
\p 
\v 12 \w Pero|strong="H3588"\w* \w el|strong="H5921"\w* \w hombre|strong="H1121"\w* respondió \w a|strong="H3068"\w* \w Joab|strong="H3097"\w*: \w Aunque|strong="H3588"\w* \w se|strong="H5921"\w* pesaran \w en|strong="H5921"\w* mis \w manos|strong="H3027"\w* 11 kilogramos \w de|strong="H5921"\w* \w plata|strong="H3701"\w*, \w yo|strong="H3588"\w* \w no|strong="H3808"\w* extendería \w mi|strong="H5921"\w* \w mano|strong="H3027"\w* \w contra|strong="H5921"\w* \w el|strong="H5921"\w* \w hijo|strong="H1121"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w*, \w porque|strong="H3588"\w* \w nosotros|strong="H5921"\w* oímos \w cuando|strong="H3588"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w les|strong="H5921"\w* dio órdenes \w a|strong="H3068"\w* \w ti|strong="H5921"\w*, Abisai \w e|strong="H3068"\w* Itai: ¡Tengan \w cuidado|strong="H3027"\w* \w que|strong="H3588"\w* \w nadie|strong="H3808"\w* toque \w al|strong="H5921"\w* joven Absalón!
\v 13 \w De|strong="H4480"\w* \w otra|strong="H6213"\w* \w manera|strong="H1697"\w*, \w si|strong="H3808"\w* \w yo|strong="H4480"\w* hubiera actuado \w con|strong="H4480"\w* \w traición|strong="H8267"\w* \w contra|strong="H5048"\w* su \w vida|strong="H5315"\w* (y \w nada|strong="H3808"\w* hay escondido \w del|strong="H4480"\w* \w rey|strong="H4428"\w*), \w tú|strong="H6213"\w* \w mismo|strong="H3605"\w* tomarías posición \w contra|strong="H5048"\w* \w mí|strong="H5315"\w*.
\p 
\v 14 \w Joab|strong="H3097"\w* respondió: \w No|strong="H3808"\w* perderé mi tiempo \w contigo|strong="H6440"\w*. \w Y|strong="H3068"\w* \w tomó|strong="H3947"\w* \w tres|strong="H7969"\w* flechas \w en|strong="H5750"\w* su \w mano|strong="H3709"\w*, \w fue|strong="H3808"\w* y las clavó \w en|strong="H5750"\w* el \w corazón|strong="H3820"\w* \w de|strong="H6440"\w* Absalón, \w mientras|strong="H5750"\w* \w aún|strong="H5750"\w* éste \w estaba|strong="H2416"\w* colgado del roble.
\v 15 Entonces se colocaron \w alrededor|strong="H5437"\w* de él los \w diez|strong="H6235"\w* jóvenes \w escuderos|strong="H5375"\w* de \w Joab|strong="H3097"\w*, \w e|strong="H3068"\w* \w hirieron|strong="H5221"\w* \w a|strong="H3068"\w* Absalón y acabaron de \w matarlo|strong="H4191"\w*.
\p 
\v 16 \w En|strong="H3588"\w* seguida \w Joab|strong="H3097"\w* \w tocó|strong="H8628"\w* \w la|strong="H3588"\w* \w corneta|strong="H7782"\w*, \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w pueblo|strong="H5971"\w* dejó \w de|strong="H3588"\w* perseguir \w a|strong="H3068"\w* \w Israel|strong="H3478"\w*, \w porque|strong="H3588"\w* \w Joab|strong="H3097"\w* \w detuvo|strong="H2820"\w* al \w pueblo|strong="H5971"\w*.
\v 17 Luego, \w tomaron|strong="H3947"\w* \w a|strong="H3068"\w* Absalón, \w lo|strong="H5921"\w* echaron \w a|strong="H3068"\w* un \w gran|strong="H1419"\w* \w hoyo|strong="H6354"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w bosque|strong="H3293"\w* \w y|strong="H5921"\w* \w pusieron|strong="H5324"\w* un \w gran|strong="H1419"\w* \w montón|strong="H1530"\w* \w de|strong="H5921"\w* piedras \w sobre|strong="H5921"\w* \w él|strong="H5921"\w*. \w Y|strong="H3068"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* \w huyó|strong="H5127"\w*, \w cada|strong="H3605"\w* uno \w a|strong="H3068"\w* su tienda.
\p 
\v 18 Durante \w su|strong="H3588"\w* \w vida|strong="H2416"\w*, Absalón \w tomó|strong="H3947"\w* \w y|strong="H3588"\w* \w erigió|strong="H5324"\w* \w para|strong="H5704"\w* \w él|strong="H5921"\w* \w el|strong="H5921"\w* monumento \w que|strong="H3588"\w* \w está|strong="H2088"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w valle|strong="H6010"\w* \w del|strong="H5921"\w* \w Rey|strong="H4428"\w*, \w porque|strong="H3588"\w* decía: \w No|strong="H3588"\w* \w tengo|strong="H5921"\w* algún \w hijo|strong="H1121"\w* \w que|strong="H3588"\w* conserve \w la|strong="H5921"\w* \w memoria|strong="H2142"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w nombre|strong="H8034"\w*. \w Y|strong="H3068"\w* dio \w al|strong="H5921"\w* monumento \w su|strong="H3588"\w* \w nombre|strong="H8034"\w*, \w y|strong="H3588"\w* \w hasta|strong="H5704"\w* \w hoy|strong="H3117"\w* \w se|strong="H5921"\w* \w le|strong="H5921"\w* \w llama|strong="H7121"\w* columna \w de|strong="H5921"\w* Absalón.
\p 
\v 19 \w Entonces|strong="H3588"\w* Ahimaas, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* \w Sadoc|strong="H6659"\w*, dijo: \w Te|strong="H3588"\w* \w ruego|strong="H4994"\w* \w que|strong="H3588"\w* \w me|strong="H3588"\w* permitas correr \w y|strong="H3588"\w* llevar \w al|strong="H4428"\w* \w rey|strong="H4428"\w* \w la|strong="H3588"\w* buena noticia \w de|strong="H3588"\w* \w que|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* lo libró \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w mano|strong="H3027"\w* \w de|strong="H3588"\w* sus enemigos.
\p 
\v 20 \w Pero|strong="H3588"\w* \w Joab|strong="H3097"\w* \w le|strong="H5921"\w* contestó: \w Hoy|strong="H3117"\w* \w no|strong="H3808"\w* serás \w hombre|strong="H1121"\w* \w de|strong="H5921"\w* buenas noticias, \w sino|strong="H3588"\w* \w otro|strong="H2088"\w* \w día|strong="H3117"\w* \w las|strong="H5921"\w* llevarás. \w Hoy|strong="H3117"\w* \w no|strong="H3808"\w* llevarás buenas noticias, \w porque|strong="H3588"\w* \w el|strong="H5921"\w* \w hijo|strong="H1121"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w* \w murió|strong="H4191"\w*.
\p 
\v 21 \w En|strong="H3212"\w* seguida \w Joab|strong="H3097"\w* \w dijo|strong="H5046"\w* \w al|strong="H4428"\w* \w etíope|strong="H3569"\w*: \w Vé|strong="H3212"\w*, dí \w al|strong="H4428"\w* \w rey|strong="H4428"\w* lo que \w viste|strong="H7200"\w*. \w Y|strong="H3068"\w* el \w etíope|strong="H3569"\w* se inclinó ante \w Joab|strong="H3097"\w* y \w corrió|strong="H7323"\w*.
\p 
\v 22 Pero Ahimaas, \w hijo|strong="H1121"\w* \w de|strong="H5750"\w* \w Sadoc|strong="H6659"\w*, \w volvió|strong="H3254"\w* \w a|strong="H3068"\w* decir \w a|strong="H3068"\w* \w Joab|strong="H3097"\w*: \w Sea|strong="H1961"\w* \w como|strong="H4100"\w* \w sea|strong="H1961"\w*, te \w ruego|strong="H4994"\w* \w que|strong="H4100"\w* me permitas \w que|strong="H4100"\w* \w también|strong="H1571"\w* \w yo|strong="H4994"\w* corra tras \w el|strong="H1121"\w* \w etíope|strong="H3569"\w*.
\p \w Y|strong="H3068"\w* \w Joab|strong="H3097"\w* dijo: ¿\w Para|strong="H1961"\w* \w qué|strong="H4100"\w* corres, \w hijo|strong="H1121"\w* mío, \w si|strong="H1571"\w* \w no|strong="H1961"\w* \w habrá|strong="H1961"\w* regalos \w para|strong="H1961"\w* ti?
\p 
\v 23 \w Sea|strong="H1961"\w* \w como|strong="H4100"\w* \w sea|strong="H1961"\w*, déjame correr. \w Y|strong="H3068"\w* \w él|strong="H5674"\w* le dijo: ¡\w Corre|strong="H7323"\w*!
\p Entonces Ahimaas \w corrió|strong="H7323"\w* \w por|strong="H1870"\w* \w el|strong="H5674"\w* \w camino|strong="H1870"\w* de la llanura, y \w pasó|strong="H5674"\w* adelante del \w etíope|strong="H3569"\w*.
\p 
\v 24 \w David|strong="H1732"\w* \w estaba|strong="H3427"\w* \w sentado|strong="H3427"\w* entre las \w dos|strong="H8147"\w* \w puertas|strong="H8179"\w*. \w El|strong="H3427"\w* vigía había \w subido|strong="H5375"\w* \w a|strong="H3068"\w* la azotea \w de|strong="H5869"\w* la \w puerta|strong="H8179"\w* \w en|strong="H3212"\w* \w el|strong="H3427"\w* \w muro|strong="H2346"\w*. Al alzar sus \w ojos|strong="H5869"\w* \w vio|strong="H7200"\w* \w a|strong="H3068"\w* un hombre que corría solo.
\p 
\v 25 El vigía \w gritó|strong="H7121"\w* \w e|strong="H3068"\w* informó \w al|strong="H4428"\w* \w rey|strong="H4428"\w*.
\p \w Y|strong="H3068"\w* el \w rey|strong="H4428"\w* \w dijo|strong="H5046"\w*: Si \w viene|strong="H1980"\w* solo, hay buenas noticias \w en|strong="H3212"\w* su \w boca|strong="H6310"\w*. El hombre continuó y avanzaba. Avanzaba y se acercaba.
\p 
\v 26 \w El|strong="H1571"\w* vigía \w vio|strong="H7200"\w* \w a|strong="H3068"\w* \w otro|strong="H2088"\w* hombre \w que|strong="H1571"\w* corría. \w El|strong="H1571"\w* vigía dio voces \w al|strong="H4428"\w* \w portero|strong="H7778"\w*: \w Aquí|strong="H2009"\w* viene \w otro|strong="H2088"\w* hombre \w que|strong="H1571"\w* \w corre|strong="H7323"\w* solo.
\p \w Y|strong="H3068"\w* \w el|strong="H1571"\w* \w rey|strong="H4428"\w* respondió: \w Ese|strong="H2088"\w* \w también|strong="H1571"\w* trae buenas noticias.
\p 
\v 27 \w Y|strong="H3068"\w* \w el|strong="H1121"\w* vigía dijo: Me parece \w que|strong="H1121"\w* la carrera del \w primero|strong="H7223"\w* \w es|strong="H2088"\w* como la carrera \w de|strong="H1121"\w* Ahimaas, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Sadoc|strong="H6659"\w*. \w Y|strong="H3068"\w* dijo \w el|strong="H1121"\w* \w rey|strong="H4428"\w*: ¡\w Ése|strong="H2088"\w* \w es|strong="H2088"\w* \w buen|strong="H2896"\w* \w hombre|strong="H1121"\w* y trae \w buenas|strong="H2896"\w* noticias!
\p 
\v 28 Entonces Ahimaas \w gritó|strong="H7121"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w*: ¡\w Paz|strong="H7965"\w*! \w Y|strong="H3068"\w* se postró delante del \w rey|strong="H4428"\w* con su rostro en tierra y dijo: ¡\w Bendito|strong="H1288"\w* sea \nd \w Yavé|strong="H3068"\w*\nd* tu \nd ʼElohim\nd*, Quien \w entregó|strong="H5462"\w* \w a|strong="H3068"\w* los hombres \w que|strong="H3027"\w* \w alzaron|strong="H5375"\w* su \w mano|strong="H3027"\w* contra \w mi|strong="H5375"\w* \tl ʼadón\tl* el \w rey|strong="H4428"\w*!
\p 
\v 29 \w Y|strong="H3068"\w* el \w rey|strong="H4428"\w* dijo: ¿Está \w bien|strong="H7965"\w* el joven Absalón?
\p Ahimaas respondió: \w Vi|strong="H7200"\w* un \w gran|strong="H1419"\w* \w alboroto|strong="H1995"\w* \w cuando|strong="H4100"\w* \w Joab|strong="H3097"\w* \w envió|strong="H7971"\w* \w al|strong="H4428"\w* esclavo del \w rey|strong="H4428"\w* y \w a|strong="H3068"\w* tu esclavo, pero \w no|strong="H3808"\w* \w supe|strong="H3045"\w* \w qué|strong="H4100"\w* era.
\p 
\v 30 Entonces el \w rey|strong="H4428"\w* dijo: \w Pasa|strong="H5437"\w* \w y|strong="H3541"\w* colócate \w allí|strong="H3541"\w*. \w Y|strong="H3068"\w* él pasó \w y|strong="H3541"\w* se \w quedó|strong="H5975"\w* \w allí|strong="H3541"\w* \w en|strong="H5975"\w* \w pie|strong="H5975"\w*.
\p 
\v 31 También llegó \w el|strong="H5921"\w* \w etíope|strong="H3569"\w* \w y|strong="H3588"\w* dijo: ¡\w Reciba|strong="H1319"\w* \w mi|strong="H5921"\w* \tl ʼadón\tl* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w la|strong="H5921"\w* noticia, \w pues|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w te|strong="H5921"\w* libró \w hoy|strong="H3117"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w mano|strong="H3027"\w* \w de|strong="H5921"\w* \w todos|strong="H3605"\w* \w aquellos|strong="H3605"\w* \w que|strong="H3588"\w* \w se|strong="H5921"\w* \w levantaron|strong="H6965"\w* \w contra|strong="H5921"\w* \w ti|strong="H5921"\w*!
\p 
\v 32 \w Y|strong="H3068"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* preguntó \w al|strong="H5921"\w* \w etíope|strong="H3569"\w*: ¿\w Está|strong="H1961"\w* \w bien|strong="H7965"\w* \w el|strong="H5921"\w* joven Absalón?
\p \w Y|strong="H3068"\w* \w el|strong="H5921"\w* \w etíope|strong="H3569"\w* contestó: ¡\w Como|strong="H1961"\w* \w aquel|strong="H3605"\w* joven \w sean|strong="H1961"\w* \w los|strong="H5921"\w* enemigos \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \tl ʼadón\tl* \w el|strong="H5921"\w* \w rey|strong="H4428"\w*, \w y|strong="H5921"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w que|strong="H5921"\w* \w se|strong="H1961"\w* \w levantaron|strong="H6965"\w* \w contra|strong="H5921"\w* \w ti|strong="H5921"\w*!
\p 
\v 33 El rey se conmovió profundamente, subió \w a|strong="H3068"\w* la sala que estaba sobre la puerta y lloró. Mientras subía decía: ¡Hijo mío, Absalón! ¡Hijo mío, hijo mío, Absalón! ¡Quién me diera que muriera yo en tu lugar, Absalón, hijo mío, hijo mío!
\c 19
\s1 El regreso a Jerusalén
\p 
\v 1 Informaron \w a|strong="H3068"\w* Joab: ¡Mira, \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w llora|strong="H1058"\w* \w y|strong="H5921"\w* endecha \w a|strong="H3068"\w* causa \w de|strong="H5921"\w* Absalón!
\v 2 Aquel día \w la|strong="H5921"\w* victoria \w se|strong="H5921"\w* convirtió \w en|strong="H5921"\w* duelo \w para|strong="H5921"\w* todo \w el|strong="H5921"\w* pueblo, \w porque|strong="H5921"\w* \w el|strong="H5921"\w* pueblo oyó decir: ¡Cuán acongojado \w está|strong="H5921"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w por|strong="H5921"\w* su hijo!
\v 3 \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w el|strong="H1931"\w* \w pueblo|strong="H5971"\w* entró calladamente \w en|strong="H5921"\w* \w la|strong="H1931"\w* ciudad, \w como|strong="H3588"\w* entra calladamente \w la|strong="H1931"\w* tropa avergonzada \w cuando|strong="H3588"\w* huye \w de|strong="H5921"\w* \w la|strong="H1931"\w* batalla.
\v 4 \w El|strong="H1931"\w* rey cubrió \w su|strong="H1931"\w* rostro y clamaba \w a|strong="H3068"\w* gran voz: ¡Oh, hijo \w mío|strong="H5971"\w*, Absalón! ¡Oh Absalón, hijo \w mío|strong="H5971"\w*, hijo \w mío|strong="H5971"\w*!
\p 
\v 5 Entonces Joab entró en la casa donde estaba \w el|strong="H1121"\w* \w rey|strong="H4428"\w* y le dijo: Hoy cubriste \w de|strong="H6440"\w* vergüenza \w los|strong="H1121"\w* semblantes \w de|strong="H6440"\w* todos tus esclavos \w que|strong="H1121"\w* salvaron tu vida, la \w de|strong="H6440"\w* tus \w hijos|strong="H1121"\w* y tus hijas, tus esposas y tus concubinas,
\v 6 \w al|strong="H4428"\w* amar \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w que|strong="H3117"\w* \w te|strong="H5315"\w* aborrecen y aborrecer \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w que|strong="H3117"\w* \w te|strong="H5315"\w* aman. \w Porque|strong="H6440"\w* \w hoy|strong="H3117"\w* demostraste \w que|strong="H3117"\w* \w nada|strong="H3605"\w* \w te|strong="H5315"\w* importan tus príncipes y esclavos, pues \w hoy|strong="H3117"\w* me demuestras claramente \w que|strong="H3117"\w* \w si|strong="H6440"\w* Absalón estuviera vivo y \w todos|strong="H3605"\w* \w nosotros|strong="H3605"\w* muertos, estarías contento.
\v 7 \w Ahora|strong="H3117"\w* \w pues|strong="H3588"\w*, levántate, sal \w y|strong="H3588"\w* habla bondadosamente \w a|strong="H3068"\w* tus esclavos, \w porque|strong="H3588"\w* juro \w por|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w que|strong="H3588"\w* \w si|strong="H3588"\w* \w no|strong="H3588"\w* sales, \w no|strong="H3588"\w* quedará ni un hombre contigo esta noche. Esto \w te|strong="H5869"\w* será peor \w que|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* males \w que|strong="H3588"\w* llegaron sobre ti desde tu juventud \w hasta|strong="H3117"\w* \w ahora|strong="H3117"\w*.
\p 
\v 8 \w Entonces|strong="H3588"\w* \w el|strong="H5921"\w* rey \w se|strong="H5921"\w* \w levantó|strong="H6965"\w* \w y|strong="H3588"\w* \w se|strong="H5921"\w* sentó \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* puerta. \w E|strong="H3068"\w* informaron \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* pueblo: Miren, \w el|strong="H5921"\w* rey \w está|strong="H2063"\w* sentado \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* puerta, \w y|strong="H3588"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* pueblo compareció ante \w el|strong="H5921"\w* rey. \w Pero|strong="H3588"\w* Israel \w había|strong="H3588"\w* huido, \w cada|strong="H3605"\w* uno \w a|strong="H3068"\w* \w su|strong="H3588"\w* tienda.
\p 
\v 9 En \w todas|strong="H3605"\w* las tribus \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*, \w todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* discutía: \w El|strong="H3605"\w* \w rey|strong="H4428"\w* nos libró \w de|strong="H6440"\w* \w la|strong="H3605"\w* mano \w de|strong="H6440"\w* nuestros enemigos y nos salvó \w de|strong="H6440"\w* \w la|strong="H3605"\w* mano \w de|strong="H6440"\w* \w los|strong="H3427"\w* filisteos, pero \w ahora|strong="H2009"\w* \w huyó|strong="H5127"\w* del país \w por|strong="H6440"\w* \w causa|strong="H6440"\w* \w de|strong="H6440"\w* Absalón.
\v 10 Absalón, \w a|strong="H3068"\w* \w quien|strong="H3605"\w* ungimos \w como|strong="H1961"\w* \w rey|strong="H4428"\w* \w de|strong="H4480"\w* \w nosotros|strong="H3605"\w*, murió \w en|strong="H5921"\w* \w la|strong="H1931"\w* batalla. ¿\w Por|strong="H5921"\w* \w qué|strong="H4480"\w* \w están|strong="H1961"\w* callados \w con|strong="H5921"\w* respecto \w a|strong="H3068"\w* \w que|strong="H4480"\w* vuelva \w el|strong="H1931"\w* \w rey|strong="H4428"\w*?
\p 
\v 11 \w El|strong="H5921"\w* \w rey|strong="H4428"\w* \w David|strong="H4428"\w* envió \w a|strong="H3068"\w* \w los|strong="H5921"\w* sacerdotes Sadoc \w y|strong="H5921"\w* Abiatar: Hablen \w a|strong="H3068"\w* \w los|strong="H5921"\w* ancianos \w de|strong="H5921"\w* Judá: ¿\w Por|strong="H5921"\w* \w qué|strong="H4100"\w* serán ustedes \w los|strong="H5921"\w* últimos \w en|strong="H5921"\w* devolver \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w a|strong="H3068"\w* su casa? \w Porque|strong="H5921"\w* \w la|strong="H5921"\w* palabra \w de|strong="H5921"\w* todo Israel llega \w al|strong="H5921"\w* \w rey|strong="H4428"\w* \w para|strong="H5921"\w* devolverlo \w a|strong="H3068"\w* su casa.
\v 12 Ustedes \w son|strong="H1961"\w* mis hermanos, \w mi|strong="H1961"\w* hueso y \w mi|strong="H1961"\w* carne. \w Entonces|strong="H7725"\w* ¿\w por|strong="H1697"\w* \w qué|strong="H4100"\w* \w son|strong="H1961"\w* ustedes \w los|strong="H3605"\w* últimos en devolver \w al|strong="H4428"\w* \w rey|strong="H4428"\w*?
\v 13 También digan \w a|strong="H3068"\w* Amasa: ¿\w No|strong="H1961"\w* \w eres|strong="H1961"\w* tú \w hueso|strong="H6106"\w* mío y \w carne|strong="H1320"\w* mía? ¡Así \nd ʼElohim\nd* me haga y \w aun|strong="H7725"\w* me añada \w si|strong="H1961"\w* \w no|strong="H1961"\w* \w eres|strong="H1961"\w* comandante del ejército delante de \w mí|strong="H1961"\w* continuamente todos \w los|strong="H1961"\w* días, en lugar de Joab!
\p 
\v 14 \w Así|strong="H3541"\w* inclinó \w el|strong="H3605"\w* corazón \w de|strong="H8478"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* varones \w de|strong="H8478"\w* Judá \w como|strong="H1961"\w* \w el|strong="H3605"\w* \w de|strong="H8478"\w* un solo hombre. \w Entonces|strong="H3117"\w* enviaron \w a|strong="H3068"\w* decir \w al|strong="H8478"\w* \w rey|strong="H6213"\w*: Vuelve \w tú|strong="H6213"\w* con \w todos|strong="H3605"\w* tus esclavos.
\p 
\v 15 \w El|strong="H3605"\w* \w rey|strong="H4428"\w* \w volvió|strong="H7725"\w* y \w fue|strong="H3063"\w* hasta \w el|strong="H3605"\w* Jordán. \w Y|strong="H3068"\w* \w Judá|strong="H3063"\w* \w fue|strong="H3063"\w* \w a|strong="H3068"\w* Gilgal \w a|strong="H3068"\w* recibir \w al|strong="H4428"\w* \w rey|strong="H4428"\w*, \w a|strong="H3068"\w* fin de permitir \w que|strong="H3605"\w* \w el|strong="H3605"\w* \w rey|strong="H4428"\w* cruzara \w el|strong="H3605"\w* Jordán.
\v 16 \w Entonces|strong="H7725"\w* Simei, hijo \w de|strong="H5704"\w* Gera, benjamita, \w que|strong="H5704"\w* era \w de|strong="H5704"\w* Bahurim, se \w dio|strong="H7725"\w* prisa \w y|strong="H5704"\w* bajó \w con|strong="H5704"\w* los hombres \w de|strong="H5704"\w* \w Judá|strong="H3063"\w* \w a|strong="H3068"\w* encontrarse \w con|strong="H5704"\w* \w el|strong="H5674"\w* \w rey|strong="H4428"\w* \w David|strong="H4428"\w*.
\v 17 \w Con|strong="H5973"\w* \w él|strong="H5973"\w* iban 1.000 \w hombres|strong="H1121"\w* \w de|strong="H5973"\w* Benjamín. También Siba, esclavo \w de|strong="H5973"\w* la casa \w de|strong="H5973"\w* Saúl, llegó \w con|strong="H5973"\w* sus 15 \w hijos|strong="H1121"\w* y sus 20 esclavos y se apresuraron \w a|strong="H3068"\w* cruzar \w el|strong="H5973"\w* Jordán \w delante|strong="H5973"\w* \w del|strong="H5973"\w* \w rey|strong="H4428"\w*.
\p 
\v 18 Cruzaron \w el|strong="H5973"\w* vado \w para|strong="H5973"\w* ayudar \w a|strong="H3068"\w* pasar \w a|strong="H3068"\w* la \w familia|strong="H1004"\w* \w del|strong="H5973"\w* \w rey|strong="H4428"\w* y \w para|strong="H5973"\w* hacer lo bueno \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w él|strong="H5973"\w*. Entonces Simei, \w hijo|strong="H1121"\w* \w de|strong="H6440"\w* Gera, se postró \w ante|strong="H6440"\w* \w el|strong="H5973"\w* \w rey|strong="H4428"\w* \w cuando|strong="H5650"\w* éste iba \w a|strong="H3068"\w* pasar \w el|strong="H5973"\w* \w Jordán|strong="H3383"\w*
\v 19 y dijo \w al|strong="H4428"\w* \w rey|strong="H4428"\w*: \w No|strong="H6213"\w* me impute iniquidad, mi \tl ʼadón\tl*, ni recuerde \w el|strong="H5307"\w* mal \w que|strong="H1121"\w* \w hizo|strong="H6213"\w* \w tu|strong="H6213"\w* esclavo \w el|strong="H5307"\w* \w día|strong="H1121"\w* cuando mi \tl ʼadón\tl* \w el|strong="H5307"\w* \w rey|strong="H4428"\w* \w salió|strong="H5674"\w* \w de|strong="H6440"\w* Jerusalén. \w Que|strong="H1121"\w* \w el|strong="H5307"\w* \w rey|strong="H4428"\w* \w no|strong="H6213"\w* guarde \w esto|strong="H6213"\w* en su corazón,
\v 20 \w porque|strong="H4428"\w* tu esclavo sabe \w que|strong="H3117"\w* pecó. \w Por|strong="H4428"\w* eso aquí vengo \w hoy|strong="H3117"\w*, el primero de toda la casa de José \w que|strong="H3117"\w* baja \w al|strong="H4428"\w* encuentro de \w mi|strong="H3389"\w* \tl ʼadón\tl* el \w rey|strong="H4428"\w*.
\p 
\v 21 Abisai, hijo \w de|strong="H3588"\w* Sarvia, intervino: ¿\w No|strong="H3588"\w* debe Simei morir, \w porque|strong="H3588"\w* maldijo \w al|strong="H4428"\w* ungido \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd*?
\p 
\v 22 \w Entonces|strong="H3588"\w* David \w respondió|strong="H6030"\w*: ¿\w Qué|strong="H3588"\w* tengo \w yo|strong="H3588"\w* \w con|strong="H3588"\w* ustedes, \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* Sarvia, \w para|strong="H3588"\w* \w que|strong="H3588"\w* hoy sean mis adversarios? ¿Debe \w morir|strong="H4191"\w* hoy algún \w hombre|strong="H1121"\w* \w en|strong="H3588"\w* Israel? ¿Acaso \w no|strong="H3808"\w* \w sé|strong="H3808"\w* \w que|strong="H3588"\w* hoy soy rey \w en|strong="H3588"\w* Israel?
\p 
\v 23 \w Y|strong="H3068"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* dijo \w a|strong="H3068"\w* Simei: ¡\w No|strong="H3808"\w* \w morirás|strong="H4191"\w*! \w Y|strong="H3068"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w se|strong="H3045"\w* \w lo|strong="H4100"\w* juró.
\p 
\v 24 También Mefi-boset, hijo de Saúl, bajó \w a|strong="H3068"\w* recibir \w al|strong="H4428"\w* \w rey|strong="H4428"\w*. \w No|strong="H3808"\w* \w se|strong="H3808"\w* había lavado los pies, \w ni|strong="H3808"\w* había arreglado su barba, \w ni|strong="H3808"\w* había lavado sus ropas, desde el día cuando el \w rey|strong="H4428"\w* salió hasta el día cuando llegó en paz.
\p 
\v 25 Sucedió \w que|strong="H4480"\w* \w cuando|strong="H3117"\w* \w llegó|strong="H5704"\w* \w con|strong="H4480"\w* \w los|strong="H1121"\w* \w de|strong="H4480"\w* Jerusalén \w para|strong="H5704"\w* recibir \w al|strong="H4480"\w* \w rey|strong="H4428"\w*, éste le dijo: ¿\w Por|strong="H4480"\w* \w qué|strong="H4480"\w* \w no|strong="H3808"\w* \w fuiste|strong="H3212"\w* \w conmigo|strong="H6213"\w*, Mefi-boset?
\p 
\v 26 \w Y|strong="H3068"\w* \w él|strong="H5973"\w* respondió: ¡\w Oh|strong="H4100"\w* \w rey|strong="H4428"\w*, \tl ʼadón\tl* mío! \w Mi|strong="H3389"\w* esclavo \w me|strong="H3588"\w* engañó, \w pues|strong="H3588"\w* tu esclavo \w se|strong="H1961"\w* dijo: Aparejaré un asno \w y|strong="H3588"\w* montaré \w en|strong="H5973"\w* \w él|strong="H5973"\w* \w para|strong="H3588"\w* \w ir|strong="H1980"\w* \w con|strong="H5973"\w* \w el|strong="H5973"\w* \w rey|strong="H4428"\w*, \w porque|strong="H3588"\w* tu esclavo \w es|strong="H1961"\w* cojo.
\v 27 \w Además|strong="H5921"\w*, calumnió \w a|strong="H3068"\w* tu esclavo ante \w mi|strong="H5921"\w* \tl ʼadón\tl* \w el|strong="H5921"\w* \w rey|strong="H4428"\w*. \w Pero|strong="H3588"\w* \w mi|strong="H5921"\w* \tl ʼadón\tl* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w es|strong="H3588"\w* \w como|strong="H3588"\w* \w el|strong="H5921"\w* Ángel \w de|strong="H5921"\w* \nd ʼElohim\nd*. \w Por|strong="H5921"\w* \w tanto|strong="H5921"\w*, haz \w lo|strong="H5921"\w* \w que|strong="H3588"\w* \w te|strong="H5921"\w* parezca \w bien|strong="H3588"\w*,
\v 28 \w porque|strong="H4428"\w* aunque toda la casa \w de|strong="H5869"\w* mi padre era digna \w de|strong="H5869"\w* muerte ante mi \tl ʼadón\tl* \w el|strong="H6213"\w* \w rey|strong="H4428"\w*, pusiste \w a|strong="H3068"\w* \w tu|strong="H6213"\w* esclavo entre los que comen \w a|strong="H3068"\w* \w tu|strong="H6213"\w* mesa, ¿y qué derecho aún tengo \w yo|strong="H6213"\w* para quejarme más ante \w el|strong="H6213"\w* \w rey|strong="H4428"\w*?
\p 
\v 29 \w Y|strong="H3068"\w* \w el|strong="H3588"\w* \w rey|strong="H4428"\w* le dijo: ¿\w Por|strong="H3588"\w* \w qué|strong="H3588"\w* hablas \w más|strong="H5750"\w* \w de|strong="H3588"\w* tus asuntos? \w Ya|strong="H3068"\w* determiné \w que|strong="H3588"\w* \w tú|strong="H3426"\w* \w y|strong="H3588"\w* Siba \w se|strong="H1961"\w* dividirán las tierras.
\p 
\v 30 Mefi-boset \w dijo|strong="H1696"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w*: \w Que|strong="H4100"\w* él las tome todas, \w porque|strong="H4100"\w* mi \tl ʼadón\tl* el \w rey|strong="H4428"\w* regresa \w en|strong="H5750"\w* paz \w a|strong="H3068"\w* su propia casa.
\p 
\v 31 \w Y|strong="H3068"\w* Barzilai galaadita bajo de Rogelim \w y|strong="H1571"\w* cruzó \w el|strong="H3605"\w* Jordán \w con|strong="H1571"\w* \w el|strong="H3605"\w* \w rey|strong="H4428"\w* para despedirlo.
\v 32 Barzilai era muy anciano, de 80 años. \w Él|strong="H5674"\w* dio provisiones \w al|strong="H4428"\w* \w rey|strong="H4428"\w* cuando estaba en Mahanaim, \w porque|strong="H4428"\w* era hombre muy rico.
\v 33 \w El|strong="H1931"\w* \w rey|strong="H4428"\w* dijo \w a|strong="H3068"\w* Barzilai: Pasa conmigo \w y|strong="H3588"\w* \w te|strong="H3588"\w* sustentaré junto \w a|strong="H3068"\w* mí \w en|strong="H3588"\w* Jerusalén.
\p 
\v 34 Pero Barzilai dijo \w al|strong="H4428"\w* \w rey|strong="H4428"\w*: ¿Cuántos años me quedan de vida para que yo suba \w con|strong="H5978"\w* \w el|strong="H5674"\w* \w rey|strong="H4428"\w* \w a|strong="H3068"\w* Jerusalén?
\v 35 \w Ya|strong="H3068"\w* tengo 80 \w años|strong="H3117"\w*. ¿Discerniré \w entre|strong="H3588"\w* \w lo|strong="H4100"\w* bueno \w y|strong="H3588"\w* \w lo|strong="H4100"\w* malo? ¿Puede tu esclavo saborear \w lo|strong="H4100"\w* \w que|strong="H3588"\w* coma \w o|strong="H3068"\w* \w lo|strong="H4100"\w* \w que|strong="H3588"\w* beba? ¿Escuchará \w aún|strong="H3588"\w* \w la|strong="H3588"\w* voz \w de|strong="H3588"\w* cantores \w y|strong="H3588"\w* cantoras? \w Entonces|strong="H3117"\w*, ¿\w por|strong="H3588"\w* \w qué|strong="H3588"\w* debe ser tu esclavo otra carga \w para|strong="H3588"\w* \w mi|strong="H3389"\w* \tl ʼadón\tl* \w el|strong="H3588"\w* \w rey|strong="H4428"\w*?
\v 36 Tu esclavo solo desea cruzar \w el|strong="H1121"\w* Jordán con \w el|strong="H1121"\w* \w rey|strong="H4428"\w*. ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* debe \w el|strong="H1121"\w* \w rey|strong="H4428"\w* darme tal recompensa?
\v 37 Te ruego \w que|strong="H4100"\w* permitas \w que|strong="H4100"\w* tu esclavo regrese para \w que|strong="H4100"\w* muera en mi ciudad, \w al|strong="H4428"\w* lado del sepulcro de mi padre y mi madre. Sin embargo, aquí \w está|strong="H2063"\w* tu esclavo Quimham \w quien|strong="H4100"\w* \w pasará|strong="H5674"\w* con mi \tl ʼadón\tl* \w el|strong="H5674"\w* \w rey|strong="H4428"\w*. Haz con \w él|strong="H5674"\w* \w lo|strong="H4100"\w* \w que|strong="H4100"\w* \w lo|strong="H4100"\w* \w que|strong="H4100"\w* te parezca bien.
\p 
\v 38 \w Entonces|strong="H7725"\w* \w el|strong="H5973"\w* \w rey|strong="H4428"\w* dijo: \w Que|strong="H4994"\w* \w pase|strong="H5674"\w* Quimhan \w conmigo|strong="H5973"\w* y \w yo|strong="H2009"\w* \w haré|strong="H6213"\w* \w por|strong="H4428"\w* \w él|strong="H5973"\w* \w lo|strong="H6213"\w* \w que|strong="H4994"\w* \w te|strong="H5869"\w* parezca \w bien|strong="H2896"\w*. Todo \w lo|strong="H6213"\w* \w que|strong="H4994"\w* \w me|strong="H5973"\w* pidas \w te|strong="H5869"\w* \w lo|strong="H6213"\w* \w haré|strong="H6213"\w*.
\p 
\v 39 \w El|strong="H5921"\w* \w rey|strong="H4428"\w* \w pasó|strong="H5674"\w* cruzó \w el|strong="H5921"\w* Jordán \w y|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* gente \w con|strong="H5921"\w* \w él|strong="H5921"\w*. \w Luego|strong="H5674"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* besó \w a|strong="H3068"\w* Barzilai \w y|strong="H5921"\w* \w lo|strong="H5921"\w* bendijo, \w y|strong="H5921"\w* \w él|strong="H5921"\w* regresó \w a|strong="H3068"\w* su lugar.
\p 
\v 40 \w El|strong="H3605"\w* \w rey|strong="H4428"\w* prosiguió \w a|strong="H3068"\w* Gilgal, y Quimham fue con \w él|strong="H3605"\w*. \w Todo|strong="H3605"\w* \w el|strong="H3605"\w* \w pueblo|strong="H5971"\w* \w de|strong="H5971"\w* Judá y también \w la|strong="H3605"\w* mitad del \w pueblo|strong="H5971"\w* \w de|strong="H5971"\w* Israel acompañaban \w al|strong="H4428"\w* \w rey|strong="H4428"\w*.
\p 
\v 41 \w Ciertamente|strong="H1571"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* hombres \w de|strong="H5973"\w* \w Israel|strong="H3478"\w* fueron \w al|strong="H4428"\w* \w rey|strong="H4428"\w* \w y|strong="H1571"\w* \w le|strong="H5973"\w* dijeron: ¿\w Por|strong="H4428"\w* \w qué|strong="H1571"\w* nuestros hermanos varones \w de|strong="H5973"\w* \w Judá|strong="H3063"\w* \w te|strong="H5973"\w* raptan \w e|strong="H3068"\w* hicieron \w que|strong="H1571"\w* \w el|strong="H5973"\w* \w rey|strong="H4428"\w* \w y|strong="H1571"\w* \w a|strong="H3068"\w* su familia cruzaran \w el|strong="H5973"\w* Jordán, \w y|strong="H1571"\w* \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* hombres \w de|strong="H5973"\w* \w David|strong="H4428"\w* \w con|strong="H5973"\w* \w él|strong="H5973"\w*?
\p 
\v 42 Entonces \w todos|strong="H3605"\w* \w los|strong="H3605"\w* hombres \w de|strong="H5973"\w* \w Judá|strong="H3063"\w* respondieron \w a|strong="H3068"\w* \w los|strong="H3605"\w* hombres \w de|strong="H5973"\w* \w Israel|strong="H3478"\w*: \w Porque|strong="H1732"\w* \w el|strong="H5973"\w* \w rey|strong="H4428"\w* es nuestro pariente cercano. Pero ¿\w por|strong="H4069"\w* \w qué|strong="H3605"\w* se quejan ustedes \w por|strong="H4069"\w* esto? ¿Comimos algo \w a|strong="H3068"\w* costa \w del|strong="H5973"\w* \w rey|strong="H4428"\w* \w o|strong="H3068"\w* se nos dieron regalos?
\p 
\v 43 \w Al|strong="H5921"\w* \w responder|strong="H6030"\w* \w los|strong="H5921"\w* hombres \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*, \w dijeron|strong="H1697"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* hombres \w de|strong="H4480"\w* \w Judá|strong="H3063"\w*: ¡Tenemos diez partes \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w y|strong="H3588"\w* \w más|strong="H3588"\w* derecho \w sobre|strong="H5921"\w* \w David|strong="H4428"\w* \w que|strong="H3588"\w* ustedes! ¿\w Por|strong="H5921"\w* \w qué|strong="H3588"\w* \w nos|strong="H5921"\w* despreciaron? ¿\w No|strong="H3588"\w* dimos nuestra \w palabra|strong="H1697"\w* primero \w para|strong="H5921"\w* devolver \w a|strong="H3068"\w* nuestro \w rey|strong="H4428"\w*?
\p Sin embargo, \w la|strong="H5921"\w* \w palabra|strong="H1697"\w* \w de|strong="H4480"\w* \w los|strong="H5921"\w* hombres \w de|strong="H4480"\w* \w Judá|strong="H3063"\w* prevaleció \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w de|strong="H4480"\w* \w los|strong="H5921"\w* hombres \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*.
\c 20
\s1 Rebelión de Seba
\p 
\v 1 Pero \w Seba|strong="H7652"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Bicri, \w de|strong="H1121"\w* Benjamín, \w hombre|strong="H1121"\w* \w perverso|strong="H1100"\w*, estaba \w allí|strong="H8033"\w*. Éste sopló la \w corneta|strong="H7782"\w* y dijo: ¡\w No|strong="H3808"\w* tenemos \w parte|strong="H2506"\w* en \w David|strong="H1732"\w* \w ni|strong="H3808"\w* \w heredad|strong="H5159"\w* en \w el|strong="H1121"\w* \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Isaí|strong="H3448"\w*! ¡\w Israel|strong="H3478"\w*: \w cada|strong="H8033"\w* uno \w a|strong="H3068"\w* su tienda!
\p 
\v 2 Entonces \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hombres|strong="H1121"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w* dejaron \w de|strong="H4480"\w* seguir \w a|strong="H3068"\w* \w David|strong="H1732"\w* \w y|strong="H5704"\w* \w siguieron|strong="H1692"\w* \w a|strong="H3068"\w* \w Seba|strong="H7652"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* Bicri. Pero \w los|strong="H1121"\w* \w hombres|strong="H1121"\w* \w de|strong="H4480"\w* \w Judá|strong="H3063"\w* \w siguieron|strong="H1692"\w* fielmente \w a|strong="H3068"\w* su \w rey|strong="H4428"\w* \w desde|strong="H4480"\w* \w el|strong="H3605"\w* \w Jordán|strong="H3383"\w* \w hasta|strong="H5704"\w* Jerusalén.
\p 
\v 3 \w Cuando|strong="H3117"\w* \w David|strong="H1732"\w* \w llegó|strong="H5704"\w* \w a|strong="H3068"\w* su palacio \w en|strong="H5704"\w* Jerusalén, \w tomó|strong="H3947"\w* \w a|strong="H3068"\w* las \w diez|strong="H6235"\w* \w concubinas|strong="H6370"\w* \w que|strong="H3808"\w* \w dejó|strong="H5414"\w* \w para|strong="H5704"\w* cuidar el palacio \w y|strong="H5704"\w* las colocó \w en|strong="H5704"\w* reclusión. \w Aunque|strong="H5704"\w* las sustentó, \w nunca|strong="H3808"\w* \w más|strong="H5704"\w* \w se|strong="H1961"\w* unió \w a|strong="H3068"\w* ellas. Ellas \w quedaron|strong="H1961"\w* \w en|strong="H5704"\w* viudez perpetua \w hasta|strong="H5704"\w* \w cuando|strong="H3117"\w* murieron.
\p 
\v 4 Luego el \w rey|strong="H4428"\w* dijo \w a|strong="H3068"\w* \w Amasa|strong="H6021"\w*: Convócame \w a|strong="H3068"\w* los hombres de \w Judá|strong="H3063"\w* dentro de \w tres|strong="H7969"\w* \w días|strong="H3117"\w* y preséntate \w aquí|strong="H6311"\w*.
\v 5 \w Amasa|strong="H6021"\w* \w fue|strong="H3212"\w* \w a|strong="H3068"\w* convocar \w a|strong="H3068"\w* \w Judá|strong="H3063"\w*, pero tardó \w más|strong="H4480"\w* \w del|strong="H4480"\w* \w tiempo|strong="H4150"\w* \w que|strong="H4480"\w* le \w fue|strong="H3212"\w* \w señalado|strong="H4150"\w*.
\p 
\v 6 Entonces \w David|strong="H1732"\w* dijo \w a|strong="H3068"\w* Abisai: \w Seba|strong="H7652"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* Bicri \w nos|strong="H4480"\w* hará \w más|strong="H4480"\w* daño \w ahora|strong="H6258"\w* \w que|strong="H4480"\w* Absalón. \w Toma|strong="H3947"\w* tú \w a|strong="H3068"\w* \w los|strong="H1121"\w* esclavos \w de|strong="H4480"\w* tu \tl ʼadón\tl* y \w vé|strong="H3068"\w* tras \w él|strong="H1121"\w*, \w no|strong="H6435"\w* \w sea|strong="H6435"\w* \w que|strong="H4480"\w* \w halle|strong="H4672"\w* \w ciudades|strong="H5892"\w* \w fortificadas|strong="H1219"\w* \w para|strong="H4480"\w* \w él|strong="H1121"\w* y escape \w de|strong="H4480"\w* nosotros.
\v 7 Entonces \w los|strong="H1121"\w* \w hombres|strong="H1368"\w* \w de|strong="H1121"\w* \w Joab|strong="H3097"\w* con \w los|strong="H1121"\w* cereteos, \w los|strong="H1121"\w* peleteos y \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w valientes|strong="H1368"\w* \w salieron|strong="H3318"\w* tras \w él|strong="H3605"\w*. \w Salieron|strong="H3318"\w* \w de|strong="H1121"\w* Jerusalén para ir tras \w Seba|strong="H7652"\w*.
\p 
\v 8 Cuando estaban \w cerca|strong="H5921"\w* \w de|strong="H5921"\w* \w la|strong="H1931"\w* \w gran|strong="H1419"\w* roca \w que|strong="H1931"\w* \w está|strong="H1931"\w* \w en|strong="H5921"\w* \w Gabaón|strong="H1391"\w*, \w Amasa|strong="H6021"\w* \w fue|strong="H1931"\w* \w a|strong="H3068"\w* \w ellos|strong="H1992"\w*. \w Joab|strong="H3097"\w* vestía \w su|strong="H1931"\w* ropa militar, \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w ella|strong="H1931"\w* una \w espada|strong="H2719"\w* \w con|strong="H5973"\w* \w su|strong="H1931"\w* vaina atada \w a|strong="H3068"\w* \w la|strong="H1931"\w* cintura, \w la|strong="H1931"\w* \w cual|strong="H1931"\w* \w se|strong="H1931"\w* \w le|strong="H1931"\w* \w cayó|strong="H5307"\w* cuando \w avanzó|strong="H3318"\w*.
\p 
\v 9 \w Joab|strong="H3097"\w* preguntó \w a|strong="H3068"\w* \w Amasa|strong="H6021"\w*: ¿Tienes \w paz|strong="H7965"\w*, hermano mío? \w Y|strong="H3068"\w* \w Joab|strong="H3097"\w* tomó \w a|strong="H3068"\w* \w Amasa|strong="H6021"\w* \w por|strong="H3027"\w* la \w barba|strong="H2206"\w* con su \w mano|strong="H3027"\w* \w derecha|strong="H3225"\w* para besarlo.
\v 10 Pero \w Amasa|strong="H6021"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* \w cuidó|strong="H8104"\w* \w de|strong="H8138"\w* \w la|strong="H8104"\w* \w espada|strong="H2719"\w* \w que|strong="H3808"\w* estaba \w en|strong="H5221"\w* \w la|strong="H8104"\w* otra \w mano|strong="H3027"\w* \w de|strong="H8138"\w* \w Joab|strong="H3097"\w*, \w de|strong="H8138"\w* modo \w que|strong="H3808"\w* \w lo|strong="H3808"\w* \w hirió|strong="H5221"\w* con ella \w en|strong="H5221"\w* \w la|strong="H8104"\w* quinta costilla y \w derramó|strong="H8210"\w* sus vísceras \w a|strong="H3068"\w* tierra. Cayó \w muerto|strong="H4191"\w* \w sin|strong="H3808"\w* necesidad \w de|strong="H8138"\w* repetir \w la|strong="H8104"\w* estocada. Después \w Joab|strong="H3097"\w* y su hermano Abisai \w fueron|strong="H7291"\w* \w a|strong="H3068"\w* perseguir \w a|strong="H3068"\w* \w Seba|strong="H7652"\w*, \w hijo|strong="H1121"\w* \w de|strong="H8138"\w* Bicri.
\p 
\v 11 Uno \w de|strong="H5921"\w* \w los|strong="H5921"\w* jóvenes \w de|strong="H5921"\w* \w Joab|strong="H3097"\w* \w se|strong="H5921"\w* colocó \w en|strong="H5921"\w* pie \w junto|strong="H5921"\w* \w a|strong="H3068"\w* \w él|strong="H5921"\w* \w y|strong="H5921"\w* dijo: ¡\w El|strong="H5921"\w* \w que|strong="H4310"\w* favorezca \w a|strong="H3068"\w* \w Joab|strong="H3097"\w* \w y|strong="H5921"\w* esté \w por|strong="H5921"\w* \w David|strong="H1732"\w*, siga \w a|strong="H3068"\w* \w Joab|strong="H3097"\w*!
\v 12 \w Amasa|strong="H6021"\w* \w estaba|strong="H5975"\w* \w tendido|strong="H7993"\w* revolcándose \w en|strong="H5921"\w* \w su|strong="H3588"\w* \w sangre|strong="H1818"\w* \w en|strong="H5921"\w* \w medio|strong="H8432"\w* \w del|strong="H4480"\w* \w camino|strong="H4546"\w*.
\p \w Cuando|strong="H3588"\w* un hombre \w vio|strong="H7200"\w* \w que|strong="H3588"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w que|strong="H3588"\w* pasaba \w se|strong="H5921"\w* detenía, \w apartó|strong="H5437"\w* \w a|strong="H3068"\w* \w Amasa|strong="H6021"\w* \w del|strong="H4480"\w* \w camino|strong="H4546"\w*, \w lo|strong="H5921"\w* llevó \w al|strong="H5921"\w* \w campo|strong="H7704"\w* \w y|strong="H3588"\w* \w lo|strong="H5921"\w* cubrió \w con|strong="H5921"\w* una túnica.
\v 13 Cuando fue apartado \w del|strong="H4480"\w* \w camino|strong="H4546"\w*, \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hombres|strong="H1121"\w* \w siguieron|strong="H7291"\w* tras \w Joab|strong="H3097"\w* \w para|strong="H4480"\w* perseguir \w a|strong="H3068"\w* \w Seba|strong="H7652"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* Bicri.
\p 
\v 14 Seba \w pasó|strong="H5674"\w* por \w todas|strong="H3605"\w* las \w tribus|strong="H7626"\w* de \w Israel|strong="H3478"\w* hasta Abel de Bet-maacá. \w Todos|strong="H3605"\w* \w los|strong="H3605"\w* bicritas se reunieron y también fueron tras \w él|strong="H3605"\w*.
\p 
\v 15 Entonces \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w ejército|strong="H2426"\w* \w que|strong="H5921"\w* \w estaba|strong="H5975"\w* \w con|strong="H5921"\w* \w Joab|strong="H3097"\w* llegó \w y|strong="H5921"\w* \w lo|strong="H5921"\w* sitiaron \w en|strong="H5921"\w* Abel \w de|strong="H5921"\w* Bet-maacá. Levantaron un terraplén \w contra|strong="H5921"\w* \w el|strong="H5921"\w* \w muro|strong="H2346"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w* \w que|strong="H5921"\w* \w estaba|strong="H5975"\w* sostenida \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w muro|strong="H2346"\w*.
\p 
\v 16 Entonces una mujer \w sabia|strong="H2450"\w* dio voces \w desde|strong="H4480"\w* la \w ciudad|strong="H5892"\w*: ¡\w Escuchen|strong="H8085"\w*! ¡\w Escuchen|strong="H8085"\w*! Les \w ruego|strong="H4994"\w* \w que|strong="H4480"\w* digan \w a|strong="H3068"\w* \w Joab|strong="H3097"\w*: ¡Ven \w acá|strong="H2008"\w* \w para|strong="H5704"\w* \w que|strong="H4480"\w* \w yo|strong="H4480"\w* \w hable|strong="H1696"\w* contigo!
\p 
\v 17 Cuando él se acercó \w a|strong="H3068"\w* ella, la mujer le preguntó: ¿Eres tú \w Joab|strong="H3097"\w*?
\p \w Y|strong="H3068"\w* le respondió: Yo soy.
\p \w Y|strong="H3068"\w* ella le dijo: \w Escucha|strong="H8085"\w* las \w palabras|strong="H1697"\w* \w de|strong="H1697"\w* tu esclava.
\p \w Y|strong="H3068"\w* él respondió: \w Escucho|strong="H8085"\w*.
\p 
\v 18 \w Entonces|strong="H3651"\w* ella \w habló|strong="H1696"\w*: \w Antiguamente|strong="H7223"\w* solían decir: El que consulte, que consulte en Abel, y \w así|strong="H3651"\w* \w concluían|strong="H8552"\w* cualquier asunto.
\v 19 Yo soy de las pacíficas y fieles de \w Israel|strong="H3478"\w*, pero tú procuras \w destruir|strong="H1245"\w* una \w ciudad|strong="H5892"\w* \w que|strong="H4100"\w* es madre en \w Israel|strong="H3478"\w*. ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* \w destruyes|strong="H1104"\w* la \w heredad|strong="H5159"\w* de \nd \w Yavé|strong="H3068"\w*\nd*?
\p 
\v 20 \w Joab|strong="H3097"\w* \w respondió|strong="H6030"\w* y dijo: ¡\w Lejos|strong="H2486"\w*, \w lejos|strong="H2486"\w* esté de \w mí|strong="H6030"\w* que yo devore \w o|strong="H3068"\w* \w destruya|strong="H7843"\w*!
\v 21 \w El|strong="H5921"\w* \w asunto|strong="H1697"\w* \w no|strong="H3808"\w* \w es|strong="H3027"\w* \w así|strong="H3651"\w*, \w sino|strong="H3588"\w* \w que|strong="H3588"\w* un \w hombre|strong="H1121"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* región montañosa \w de|strong="H5921"\w* Efraín, \w Seba|strong="H7652"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Bicri, \w levantó|strong="H5375"\w* \w su|strong="H3588"\w* \w mano|strong="H3027"\w* \w contra|strong="H5921"\w* \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w David|strong="H1732"\w*. Entreguen solo \w a|strong="H3068"\w* \w él|strong="H5921"\w* \w y|strong="H3588"\w* \w me|strong="H5921"\w* \w iré|strong="H3212"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w*.
\p \w Entonces|strong="H3588"\w* \w la|strong="H5921"\w* mujer respondió \w a|strong="H3068"\w* \w Joab|strong="H3097"\w*: ¡\w Mira|strong="H2009"\w*, \w su|strong="H3588"\w* \w cabeza|strong="H7218"\w* \w te|strong="H5921"\w* \w será|strong="H3808"\w* lanzada \w desde|strong="H5921"\w* \w el|strong="H5921"\w* \w muro|strong="H2346"\w*!
