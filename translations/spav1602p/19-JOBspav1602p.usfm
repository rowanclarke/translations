\v 5 \w Mas|strong="H5921"\w* \w si|strong="H5921"\w* vosotros \w os|strong="H5921"\w* engrandecie­reis \w contra|strong="H5921"\w* \w mí|strong="H5921"\w*, \w y|strong="H5921"\w* adujereis \w contra|strong="H5921"\w* \w mí|strong="H5921"\w* \w mi|strong="H5921"\w* \w oprobio|strong="H2781"\w*,
