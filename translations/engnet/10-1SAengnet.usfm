\v 1  \w The|strong="H5921"\w* \nd \+w Lord|strong="H3068"\+w*\nd* said \w to|strong="H5704"\w* \w Samuel|strong="H8050"\w*, “\w How|strong="H4970"\w* \w long|strong="H5704"\w* \w do|strong="H3068"\w* \w you|strong="H3588"\w* intend \w to|strong="H5704"\w* \w mourn|strong="H5921"\w* \w for|strong="H3588"\w* \w Saul|strong="H7586"\w*? \w I|strong="H3588"\w* \w have|strong="H3068"\w* \w rejected|strong="H3988"\w* \w him|strong="H5921"\w* \w as|strong="H5704"\w* \w king|strong="H4428"\w* \w over|strong="H5921"\w* \w Israel|strong="H3478"\w*. \w Fill|strong="H4390"\w* \w your|strong="H3068"\w* \w horn|strong="H7161"\w* \w with|strong="H4390"\w* \w olive|strong="H8081"\w* \w oil|strong="H8081"\w* \w and|strong="H1121"\w* \w go|strong="H3212"\w*! \w I|strong="H3588"\w* \w am|strong="H3068"\w* \w sending|strong="H7971"\w* \w you|strong="H3588"\w* \w to|strong="H5704"\w* \w Jesse|strong="H3448"\w* \w in|strong="H5921"\w* Bethlehem, \w for|strong="H3588"\w* \w I|strong="H3588"\w* \w have|strong="H3068"\w* \w selected|strong="H7200"\w* \w a|strong="H3068"\w* \w king|strong="H4428"\w* \w for|strong="H3588"\w* myself \w from|strong="H5921"\w* \w among|strong="H5921"\w* \w his|strong="H3068"\w* \w sons|strong="H1121"\w*.”   
\p
\v 2  \w Samuel|strong="H8050"\w* replied, “\w How|strong="H8085"\w* \w can|strong="H3947"\w* \w I|strong="H8085"\w* \w go|strong="H3212"\w*? \w Saul|strong="H7586"\w* \w will|strong="H3068"\w* \w hear|strong="H8085"\w* \w about|strong="H8085"\w* \w it|strong="H3947"\w* \w and|strong="H3068"\w* \w kill|strong="H2026"\w* \w me|strong="H3947"\w*!” \w But|strong="H8085"\w* \w the|strong="H8085"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w said|strong="H8085"\w*, “\w Take|strong="H3947"\w* \w a|strong="H3068"\w* \w heifer|strong="H5697"\w* \w with|strong="H3068"\w* \w you|strong="H3947"\w* \w and|strong="H3068"\w* say, ‘\w I|strong="H8085"\w* \w have|strong="H3068"\w* \w come|strong="H3212"\w* \w to|strong="H3068"\w* \w sacrifice|strong="H2076"\w* \w to|strong="H3068"\w* \w the|strong="H8085"\w* \nd \+w Lord|strong="H3068"\+w*\nd*.’  
