\v 18 \w When|strong="H3117"\w* those three \w years|strong="H3117"\w* \w that|strong="H3117"\w* \w the|strong="H6440"\w* \w king|strong="H4428"\w* \w had|strong="H4428"\w* set \w for|strong="H6440"\w* training \w us|strong="H6440"\w* \w young|strong="H3117"\w* \w men|strong="H8269"\w* \w from|strong="H6440"\w* Judah \w were|strong="H3117"\w* ended, Ashpenaz \w brought|strong="H4428"\w* \w all|strong="H3117"\w* \w of|strong="H4428"\w* \w us|strong="H6440"\w* \w to|strong="H6440"\w* \w King|strong="H4428"\w* \w Nebuchadnezzar|strong="H5019"\w*.  
