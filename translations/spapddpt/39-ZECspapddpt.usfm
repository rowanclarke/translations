\p
\v 1 Pidan \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* la \w lluvia|strong="H4306"\w* en la estación \w tardía|strong="H4456"\w*. \nd \+w Yavé|strong="H3068"\+w*\nd*, \w Quien|strong="H6213"\w* \w hace|strong="H6213"\w* \w las|strong="H1992"\w* nubes tormentosas, enviará \w relámpagos|strong="H2385"\w* y \w les|strong="H1992"\w* \w dará|strong="H5414"\w* \w lluvias|strong="H4306"\w* abundantes y \w hierba|strong="H6212"\w* verde en \w el|strong="H6213"\w* \w campo|strong="H7704"\w* \w de|strong="H5414"\w* cada uno.  
\v 2 \w Pero|strong="H3588"\w* \w los|strong="H5921"\w* ídolos domésticos prometen \w en|strong="H5921"\w* \w vano|strong="H1892"\w*, \w los|strong="H5921"\w* \w adivinos|strong="H7080"\w* \w ven|strong="H2372"\w* \w mentiras|strong="H8267"\w*, anuncian \w sueños|strong="H2472"\w* \w falsos|strong="H8267"\w*, \w y|strong="H3588"\w* \w su|strong="H3588"\w* \w consuelo|strong="H5162"\w* \w es|strong="H3588"\w* \w vano|strong="H1892"\w*. \w Por|strong="H5921"\w* \w lo|strong="H5921"\w* \w cual|strong="H3588"\w* \w el|strong="H5921"\w* pueblo vaga \w como|strong="H3588"\w* \w ovejas|strong="H6629"\w* afligidas, \w porque|strong="H3588"\w* \w no|strong="H3588"\w* hay \w pastor|strong="H7462"\w*.   
\p
\v 3 \wj \+w Mi|strong="H5921"\+w* ira \+w se|strong="H5921"\+w* encendió \+w contra|strong="H5921"\+w* \+w los|strong="H5921"\+w* \+w pastores|strong="H7462"\+w*, castigaré \+w a|strong="H3068"\+w* \+w los|strong="H5921"\+w* machos cabríos. \+nd \+w Yavé|strong="H3068"\+w*\+nd* \+w de|strong="H5921"\+w* \+w las|strong="H5921"\+w* huestes \+w visitará|strong="H6485"\+w* \+w su|strong="H3588"\+w* rebaño, \+w la|strong="H5921"\+w* \+w Casa|strong="H1004"\+w* \+w de|strong="H5921"\+w* \+w Judá|strong="H3063"\+w*, \+w y|strong="H3588"\+w* \+w hará|strong="H7760"\+w* \+w de|strong="H5921"\+w* \+w ella|strong="H5921"\+w* \+w su|strong="H3588"\+w* corcel real \+w en|strong="H5921"\+w* \+w la|strong="H5921"\+w* \+w batalla|strong="H4421"\+w*.\wj*  
\v 4 \wj \+w De|strong="H4480"\+w* \+w ella|strong="H4480"\+w* \+w saldrá|strong="H3318"\+w* \+w la|strong="H3605"\+w* Piedra \+w Angular|strong="H6438"\+w*, \+w la|strong="H3605"\+w* estaca, \+w el|strong="H3605"\+w* \+w arco|strong="H7198"\+w* \+w de|strong="H4480"\+w* \+w guerra|strong="H4421"\+w* y \+w todo|strong="H3605"\+w* caudillo.\wj*  
\v 5 \wj Juntos \+w serán|strong="H1961"\+w* \+w como|strong="H3588"\+w* \+w valientes|strong="H1368"\+w* \+w que|strong="H3588"\+w* \+w en|strong="H5973"\+w* \+w la|strong="H3588"\+w* \+w batalla|strong="H4421"\+w* pisan \+w el|strong="H5973"\+w* lodo \+w de|strong="H3588"\+w* las \+w calles|strong="H2351"\+w*. Combatirán \+w porque|strong="H3588"\+w* \+nd \+w Yavé|strong="H3068"\+w*\+nd* \+w estará|strong="H1961"\+w* \+w con|strong="H5973"\+w* ellos. \+w Los|strong="H5973"\+w* jinetes \+w serán|strong="H1961"\+w* \+w avergonzados|strong="H3001"\+w*.\wj*  
\v 6 \wj \+w Porque|strong="H3588"\+w* \+w Yo|strong="H3588"\+w* fortaleceré \+w la|strong="H3588"\+w* \+w Casa|strong="H1004"\+w* \+w de|strong="H3588"\+w* \+w Judá|strong="H3063"\+w* \+w y|strong="H3588"\+w* daré \+w la|strong="H3588"\+w* victoria \+w a|strong="H3068"\+w* \+w la|strong="H3588"\+w* \+w casa|strong="H1004"\+w* \+w de|strong="H3588"\+w* \+w José|strong="H3130"\+w*, \+w los|strong="H1961"\+w* haré regresar, \+w pues|strong="H3588"\+w* \+w tendré|strong="H1961"\+w* compasión \+w de|strong="H3588"\+w* ellos. \+w Serán|strong="H1961"\+w* \+w como|strong="H3588"\+w* \+w si|strong="H3588"\+w* \+w no|strong="H3808"\+w* \+w fueron|strong="H1961"\+w* desechados, \+w porque|strong="H3588"\+w* \+w Yo|strong="H3588"\+w* \+w soy|strong="H1961"\+w* \+nd \+w Yavé|strong="H3068"\+w*\+nd* \+w su|strong="H3588"\+w* \+nd ʼElohim\+nd*, \+w y|strong="H3588"\+w* \+w los|strong="H1961"\+w* escucharé.\wj*  
\v 7 \wj Efraín \+w será|strong="H1961"\+w* \+w como|strong="H3644"\+w* un \+w valiente|strong="H1368"\+w*, y su \+w corazón|strong="H3820"\+w* \+w se|strong="H1961"\+w* alegrará \+w como|strong="H3644"\+w* con \+w vino|strong="H3196"\+w*. Sus \+w hijos|strong="H1121"\+w* lo \+w mirarán|strong="H7200"\+w* y \+w se|strong="H1961"\+w* alegrarán. Su \+w corazón|strong="H3820"\+w* \+w se|strong="H1961"\+w* regocijará en \+nd \+w Yavé|strong="H3068"\+w*\+nd*.\wj*   
\p
\v 8 \wj \+w Los|strong="H3588"\+w* reuniré \+w con|strong="H3588"\+w* un silbo, \+w porque|strong="H3588"\+w* \+w los|strong="H3588"\+w* \+w redimí|strong="H6299"\+w*. Serán tan numerosos \+w como|strong="H3588"\+w* \+w antes|strong="H3588"\+w*.\wj*  
\v 9 \wj Yo \+w los|strong="H1121"\+w* sembré entre las naciones. En lejanos países \+w se|strong="H5971"\+w* acordarán \+w de|strong="H1121"\+w* Mí. Criarán allí \+w a|strong="H3068"\+w* sus \+w hijos|strong="H1121"\+w*, pero regresarán.\wj*  
\v 10 \wj Los devolveré de la tierra de \+w Egipto|strong="H4714"\+w*, los reuniré desde Asiria y los traeré \+w a|strong="H3068"\+w* la tierra de \+w Galaad|strong="H1568"\+w* y el \+w Líbano|strong="H3844"\+w*, hasta \+w que|strong="H3808"\+w* \+w no|strong="H3808"\+w* \+w se|strong="H3808"\+w* \+w halle|strong="H4672"\+w* sitio para ellos.\wj*  
\v 11 \wj \+w Pasarán|strong="H5674"\+w* por \+w el|strong="H3605"\+w* \+w mar|strong="H3220"\+w* de \+w la|strong="H3605"\+w* \+w angustia|strong="H6869"\+w*. \+w Él|strong="H3605"\+w* golpeará las ondas del \+w mar|strong="H3220"\+w*, de tal modo \+w que|strong="H3605"\+w* \+w todas|strong="H3605"\+w* las profundidades del Nilo se secarán. \+w La|strong="H3605"\+w* altivez de Asiria será abatida y desaparecerá \+w el|strong="H3605"\+w* \+w cetro|strong="H7626"\+w* de \+w Egipto|strong="H4714"\+w*.\wj*  
\v 12 \wj Yo los fortaleceré en \+nd \+w Yavé|strong="H3068"\+w*\+nd*, Palabra de \+nd \+w Yavé|strong="H3068"\+w*\+nd*, y andarán en su \+w Nombre|strong="H8034"\+w*.\wj*   
\c 11  
\s1 Alegoría sobre la infidelidad de los pastores  
\p
\v 1 ¡\w Abre|strong="H6605"\w* tus \w puertas|strong="H1817"\w*, oh \w Líbano|strong="H3844"\w*, y consuma el fuego tus cedros!  
\v 2 ¡Llora, oh ciprés, \w porque|strong="H3588"\w* \w el|strong="H3588"\w* cedro \w cayó|strong="H5307"\w*, \w y|strong="H3588"\w* \w los|strong="H3588"\w* majestuosos fueron talados! ¡Laméntense, oh robles \w de|strong="H3588"\w* \w Basán|strong="H1316"\w*, \w porque|strong="H3588"\w* \w el|strong="H3588"\w* denso \w bosque|strong="H3293"\w* \w cayó|strong="H5307"\w*!  
\v 3 Hay un gemido \w de|strong="H3588"\w* \w los|strong="H3588"\w* \w pastores|strong="H7462"\w*, \w porque|strong="H3588"\w* \w su|strong="H3588"\w* esplendor quedó arruinado. Hay un rugido \w de|strong="H3588"\w* \w los|strong="H3588"\w* leoncillos, \w porque|strong="H3588"\w* \w el|strong="H3588"\w* esplendor del \w Jordán|strong="H3383"\w* quedó \w destruido|strong="H7703"\w*.   
\s1 Los dos cayados  
\p
\v 4 \nd \+w Yavé|strong="H3068"\+w*\nd* mi \nd ʼElohim\nd* dice: \wj \+w Apacienta|strong="H7462"\+w* las \+w ovejas|strong="H6629"\+w* para la matanza,\wj*  
\v 5 \wj \+w a|strong="H3068"\+w* \+w las|strong="H5921"\+w* cuales sus compradores degüellan \+w sin|strong="H3808"\+w* sentirse culpables. \+w El|strong="H5921"\+w* \+w que|strong="H3808"\+w* \+w las|strong="H5921"\+w* \+w vende|strong="H4376"\+w* piensa: \+w Bendito|strong="H1288"\+w* sea \+nd \+w Yavé|strong="H3068"\+w*\+nd*, \+w porque|strong="H5921"\+w* \+w me|strong="H5921"\+w* \+w enriquecí|strong="H6238"\+w*. Sus propios \+w pastores|strong="H7462"\+w* \+w no|strong="H3808"\+w* tienen compasión \+w de|strong="H5921"\+w* \+w ellas|strong="H5921"\+w*.\wj*  
\v 6 \wj \+w Por|strong="H5921"\+w* \+w tanto|strong="H5921"\+w* ya \+w no|strong="H3808"\+w* tendré compasión \+w de|strong="H5921"\+w* \+w los|strong="H3427"\+w* \+w habitantes|strong="H3427"\+w* \+w de|strong="H5921"\+w* \+w la|strong="H5921"\+w* tierra, \wj*\w dice|strong="H5002"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*. \wj \+w Porque|strong="H3588"\+w*, miren, \+w Yo|strong="H3588"\+w* entrego \+w a|strong="H3068"\+w* \+w los|strong="H3427"\+w* hombres, \+w a|strong="H3068"\+w* cada uno \+w en|strong="H5921"\+w* \+w manos|strong="H3027"\+w* \+w de|strong="H5921"\+w* \+w su|strong="H3588"\+w* \+w prójimo|strong="H7453"\+w* \+w y|strong="H3588"\+w* \+w en|strong="H5921"\+w* \+w manos|strong="H3027"\+w* \+w de|strong="H5921"\+w* \+w su|strong="H3588"\+w* \+w rey|strong="H4428"\+w*. \+w Así|strong="H3588"\+w* desolarán \+w la|strong="H5921"\+w* tierra, \+w y|strong="H3588"\+w* \+w Yo|strong="H3588"\+w* \+w no|strong="H3808"\+w* \+w los|strong="H3427"\+w* \+w libraré|strong="H5337"\+w* \+w de|strong="H5921"\+w* sus \+w manos|strong="H3027"\+w*.\wj*   
\p
\v 7 \w Así|strong="H3651"\w* que \w apacenté|strong="H7462"\w* las \w ovejas|strong="H6629"\w* de matadero, \w esto|strong="H3651"\w* es, las pobres del \w rebaño|strong="H6629"\w*. \w Tomé|strong="H3947"\w* para mí \w dos|strong="H8147"\w* \w cayados|strong="H4731"\w*. \w A|strong="H3068"\w* uno \w llamé|strong="H7121"\w* Gracia y al otro Atadura, y \w apacenté|strong="H7462"\w* las \w ovejas|strong="H6629"\w*.  
\v 8 \w Entonces|strong="H1571"\w* eliminé \w a|strong="H3068"\w* \w tres|strong="H7969"\w* \w pastores|strong="H7462"\w* en un \w mes|strong="H3391"\w*, porque \w yo|strong="H5315"\w* me fastidié de \w ellos|strong="H1571"\w*, \w y|strong="H1571"\w* \w ellos|strong="H1571"\w* \w también|strong="H1571"\w* se disgustaron conmigo.  
\v 9 Les dije: \w No|strong="H3808"\w* los alimentaré \w más|strong="H4191"\w* \w a|strong="H3068"\w* ustedes. \w Si|strong="H3808"\w* alguna muere, \w que|strong="H3808"\w* \w muera|strong="H4191"\w*. \w Si|strong="H3808"\w* alguna \w se|strong="H3808"\w* pierde, \w que|strong="H3808"\w* \w se|strong="H3808"\w* pierda, y las \w que|strong="H3808"\w* queden, \w que|strong="H3808"\w* coman \w carne|strong="H1320"\w* las unas de las otras.   
\p
\v 10 \w Tomé|strong="H3947"\w* mi cayado Gracia y \w lo|strong="H3605"\w* \w quebré|strong="H1438"\w* en señal \w de|strong="H5971"\w* anulación \w de|strong="H5971"\w* mi \w pacto|strong="H1285"\w* con \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w pueblos|strong="H5971"\w*.  
\v 11 \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w fue|strong="H1931"\w* \w anulado|strong="H6565"\w*. \w Los|strong="H1931"\w* \w que|strong="H3588"\w* compraban las \w ovejas|strong="H6629"\w*, quienes \w me|strong="H3588"\w* observaban, reconocieron \w que|strong="H3588"\w* \w era|strong="H1931"\w* \w Palabra|strong="H1697"\w* \w de|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.  
\v 12 \w Y|strong="H3068"\w* les dije: \w Si|strong="H3808"\w* les parece \w bien|strong="H2896"\w*, denme mi \w salario|strong="H7939"\w*, y \w si|strong="H3808"\w* \w no|strong="H3808"\w*, déjenlo. \w Y|strong="H3068"\w* pesaron 30 piezas \w de|strong="H5869"\w* \w plata|strong="H3701"\w* como \w salario|strong="H7939"\w* mío.   
\p
\v 13 \w Y|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w me|strong="H5921"\w* dijo: \wj \+w Échalo|strong="H7993"\+w* \+w al|strong="H5921"\+w* tesoro. \wj*¡Valioso \w precio|strong="H3701"\w* \w con|strong="H5921"\w* \w el|strong="H5921"\w* cual fui valuado \w por|strong="H5921"\w* \w ellos|strong="H5921"\w*!  
\p \w Y|strong="H3068"\w* \w tomé|strong="H3947"\w* \w las|strong="H5921"\w* 30 piezas \w de|strong="H5921"\w* \w plata|strong="H3701"\w* \w y|strong="H5921"\w* \w las|strong="H5921"\w* \w eché|strong="H7993"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* vasija \w de|strong="H5921"\w* arcilla \w del|strong="H5921"\w* tesoro \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w Casa|strong="H1004"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*.  
\v 14 Luego \w quebré|strong="H1438"\w* mi \w otro|strong="H8145"\w* cayado, Atadura, para romper la hermandad entre \w Judá|strong="H3063"\w* \w e|strong="H3068"\w* \w Israel|strong="H3478"\w*.   
\p
\v 15 \w Y|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* me dijo: \wj \+w Toma|strong="H3947"\+w* \+w también|strong="H5750"\+w* la ropa y los objetos \+w de|strong="H5750"\+w* un \+w pastor|strong="H7462"\+w* insensato,\wj*  
\v 16 \wj \+w porque|strong="H3588"\+w*, \+w ciertamente|strong="H3588"\+w*, \+w Yo|strong="H3588"\+w* \+w levanto|strong="H6965"\+w* \+w en|strong="H3588"\+w* \+w la|strong="H3588"\+w* tierra \+w a|strong="H3068"\+w* un \+w pastor|strong="H7462"\+w* \+w que|strong="H3588"\+w* \+w no|strong="H3808"\+w* \+w se|strong="H3808"\+w* ocupará \+w de|strong="H3588"\+w* las perdidas, \+w ni|strong="H3808"\+w* \+w buscará|strong="H1245"\+w* \+w a|strong="H3068"\+w* \+w la|strong="H3588"\+w* descarriada, \+w ni|strong="H3808"\+w* \+w curará|strong="H7495"\+w* \+w a|strong="H3068"\+w* \+w la|strong="H3588"\+w* perniquebrada, \+w ni|strong="H3808"\+w* llevará \+w a|strong="H3068"\+w* cuestas \+w a|strong="H3068"\+w* \+w la|strong="H3588"\+w* cansada, \+w pero|strong="H3588"\+w* \+w se|strong="H3808"\+w* comerá \+w la|strong="H3588"\+w* \+w carne|strong="H1320"\+w* \+w de|strong="H3588"\+w* \+w la|strong="H3588"\+w* robusta \+w y|strong="H3588"\+w* romperá sus pezuñas.\wj*  
\v 17 \wj ¡\+w Ay|strong="H1945"\+w* \+w del|strong="H5921"\+w* pastor inútil, \+w que|strong="H5921"\+w* abandona \+w el|strong="H5921"\+w* \+w rebaño|strong="H6629"\+w*! ¡Caiga una \+w espada|strong="H2719"\+w* \+w contra|strong="H5921"\+w* su mano \+w derecha|strong="H3225"\+w* \+w y|strong="H5921"\+w* su \+w ojo|strong="H5869"\+w* \+w derecho|strong="H3225"\+w* sea completamente \+w oscurecido|strong="H3543"\+w*!\wj*   
\c 12  
\s1 El día del \nd Yavé\nd*  
\p
\v 1 \w La|strong="H5921"\w* \w respuesta|strong="H1697"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w Palabra|strong="H1697"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w en|strong="H5921"\w* \w lo|strong="H1697"\w* relacionado \w con|strong="H5921"\w* \w Israel|strong="H3478"\w*: \wj \+nd \+w Yavé|strong="H3068"\+w*\+nd*, Quien \+w extiende|strong="H5186"\+w* \+w el|strong="H5921"\+w* \+w cielo|strong="H8064"\+w*, pone \+w el|strong="H5921"\+w* \+w cimiento|strong="H3245"\+w* \+w de|strong="H5921"\+w* \+w la|strong="H5921"\+w* tierra \+w y|strong="H5921"\+w* forma \+w el|strong="H5921"\+w* \+w espíritu|strong="H7307"\+w* \+w del|strong="H5921"\+w* hombre \+w dentro|strong="H7130"\+w* \+w de|strong="H5921"\+w* \+w él|strong="H5921"\+w*, \+w dice|strong="H5002"\+w*: \wj*  
\v 2 \wj \+w Ciertamente|strong="H1571"\+w* \+w Yo|strong="H2009"\+w* convierto \+w a|strong="H3068"\+w* Jerusalén \+w en|strong="H5921"\+w* copa \+w que|strong="H5921"\+w* \+w hará|strong="H7760"\+w* temblar \+w a|strong="H3068"\+w* \+w todos|strong="H3605"\+w* \+w los|strong="H5921"\+w* \+w pueblos|strong="H5971"\+w* \+w de|strong="H5921"\+w* \+w alrededor|strong="H5439"\+w*. \+w Cuando|strong="H1571"\+w* \+w esté|strong="H1961"\+w* sitiada Jerusalén, \+w también|strong="H1571"\+w* \+w estará|strong="H1961"\+w* \+w contra|strong="H5921"\+w* \+w Judá|strong="H3063"\+w*.\wj*   
\p
\v 3 \wj \+w Aquel|strong="H1931"\+w* \+w día|strong="H3117"\+w* Yo \+w pondré|strong="H7760"\+w* \+w a|strong="H3068"\+w* Jerusalén \+w como|strong="H1961"\+w* piedra \+w pesada|strong="H4614"\+w* \+w a|strong="H3068"\+w* \+w todos|strong="H3605"\+w* \+w los|strong="H5921"\+w* \+w pueblos|strong="H5971"\+w*. \+w Todos|strong="H3605"\+w* \+w los|strong="H5921"\+w* \+w que|strong="H1931"\+w* \+w se|strong="H1961"\+w* \+w la|strong="H1931"\+w* carguen \+w serán|strong="H1961"\+w* \+w despedazados|strong="H8295"\+w*. \+w Y|strong="H3068"\+w* \+w todas|strong="H3605"\+w* \+w las|strong="H5921"\+w* \+w naciones|strong="H1471"\+w* \+w de|strong="H5921"\+w* \+w la|strong="H1931"\+w* tierra \+w se|strong="H1961"\+w* juntarán \+w contra|strong="H5921"\+w* \+w ella|strong="H1931"\+w*.\wj*  
\v 4 \wj \+w Aquel|strong="H1931"\+w* \+w día|strong="H3117"\+w*, \wj*\w dice|strong="H5002"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*, \wj golpearé \+w con|strong="H5921"\+w* pánico \+w todo|strong="H3605"\+w* \+w caballo|strong="H5483"\+w* \+w y|strong="H5921"\+w* \+w a|strong="H3068"\+w* \+w todo|strong="H3605"\+w* jinete \+w con|strong="H5921"\+w* locura. Pero \+w abriré|strong="H6491"\+w* mis \+w ojos|strong="H5869"\+w* \+w con|strong="H5921"\+w* favor \+w sobre|strong="H5921"\+w* \+w la|strong="H1931"\+w* \+w Casa|strong="H1004"\+w* \+w de|strong="H5921"\+w* \+w Judá|strong="H3063"\+w* \+w y|strong="H5921"\+w* \+w heriré|strong="H5221"\+w* \+w con|strong="H5921"\+w* ceguera \+w todo|strong="H3605"\+w* \+w caballo|strong="H5483"\+w* \+w de|strong="H5921"\+w* \+w las|strong="H5921"\+w* naciones oponentes.\wj*  
\v 5 \wj Entonces \+w los|strong="H3427"\+w* jefes de \+w Judá|strong="H3063"\+w* dirán en su \+w corazón|strong="H3820"\+w*: \+w Los|strong="H3427"\+w* \+w habitantes|strong="H3427"\+w* de Jerusalén son un fuerte apoyo para nosotros por medio de \+nd \+w Yavé|strong="H3068"\+w*\+nd* de las huestes, su \+nd ʼElohim.\+nd* \wj*   
\p
\v 6 \wj \+w Aquel|strong="H1931"\+w* \+w día|strong="H3117"\+w* \+w pondré|strong="H7760"\+w* \+w a|strong="H3068"\+w* \+w los|strong="H3427"\+w* jefes \+w de|strong="H5921"\+w* \+w Judá|strong="H3063"\+w* \+w como|strong="H5921"\+w* brasero encendido \+w entre|strong="H5921"\+w* \+w la|strong="H1931"\+w* \+w leña|strong="H6086"\+w* \+w y|strong="H5921"\+w* \+w como|strong="H5921"\+w* antorcha \+w de|strong="H5921"\+w* fuego \+w entre|strong="H5921"\+w* \+w los|strong="H3427"\+w* conjuntos \+w de|strong="H5921"\+w* espigas, \+w pues|strong="H1931"\+w* devorarán \+w a|strong="H3068"\+w* \+w derecha|strong="H3225"\+w* \+w y|strong="H5921"\+w* \+w a|strong="H3068"\+w* \+w izquierda|strong="H8040"\+w* \+w a|strong="H3068"\+w* \+w todos|strong="H3605"\+w* \+w los|strong="H3427"\+w* \+w pueblos|strong="H5971"\+w* \+w vecinos|strong="H3427"\+w*. \+w Los|strong="H3427"\+w* \+w de|strong="H5921"\+w* Jerusalén vivirán \+w otra|strong="H5750"\+w* vez \+w con|strong="H5921"\+w* seguridad \+w en|strong="H5921"\+w* Jerusalén, \+w su|strong="H1931"\+w* \+w lugar|strong="H8478"\+w*.\wj*   
