\v 34 Aarón lo \w puso|strong="H3240"\w* \w delante|strong="H6440"\w* del \w Testimonio|strong="H5715"\w* para guardarlo, como \nd \+w Yavé|strong="H3068"\+w*\nd* \w ordenó|strong="H6680"\w* \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*.  
\v 35 Así \w los|strong="H3427"\w* \w hijos|strong="H1121"\w* \w de|strong="H5704"\w* \w Israel|strong="H3478"\w* comieron \tl \+w maná|strong="H4478"\+w*\tl* 40 \w años|strong="H8141"\w*, \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* llegaron \w a|strong="H3068"\w* una tierra \w habitada|strong="H3427"\w*. Comieron \tl \+w maná|strong="H4478"\+w*\tl* \w hasta|strong="H5704"\w* \w que|strong="H5704"\w* llegaron \w al|strong="H5704"\w* \w límite|strong="H7097"\w* \w de|strong="H5704"\w* la tierra \w de|strong="H5704"\w* \w Canaán|strong="H3667"\w*.   
\p
\v 36 Un \tl gomer \tl* \w es|strong="H1931"\w* \w la|strong="H1931"\w* décima parte del \tl efa\tl*.\f + \fr 16:36 \ft \+tl Gomer\+tl*: 2,2 litros es la décima parte del \+tl efa\+tl*: 22 litros. \f*   
\c 17  
\s1 La Peña de Horeb  
\p
\v 1 \w Toda|strong="H3605"\w* \w la|strong="H5921"\w* congregación \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* salió \w del|strong="H5921"\w* \w desierto|strong="H4057"\w* \w de|strong="H5921"\w* \w Sin|strong="H5512"\w* \w por|strong="H5921"\w* jornadas, \w conforme|strong="H6310"\w* \w al|strong="H5921"\w* \w Mandamiento|strong="H6310"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*. Acamparon \w en|strong="H5921"\w* Refidim, \w y|strong="H5921"\w* \w no|strong="H5921"\w* había \w agua|strong="H4325"\w* \w para|strong="H5921"\w* \w que|strong="H5921"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* bebiera.  
\v 2 \w El|strong="H5973"\w* \w pueblo|strong="H5971"\w* altercó \w con|strong="H5973"\w* \w Moisés|strong="H4872"\w* y dijeron: \w Danos|strong="H5414"\w* \w agua|strong="H4325"\w* \w para|strong="H5414"\w* \w que|strong="H4100"\w* bebamos.  
\p \w Y|strong="H3068"\w* \w Moisés|strong="H4872"\w* \w les|strong="H5973"\w* dijo: ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* altercan \w conmigo|strong="H5973"\w*? ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* tientan \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*?   
\p
\v 3 \w Así|strong="H2088"\w* \w que|strong="H4100"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* tuvo \w allí|strong="H8033"\w* \w sed|strong="H6772"\w* \w por|strong="H5921"\w* falta \w de|strong="H5921"\w* \w agua|strong="H4325"\w* \w y|strong="H5921"\w* \w murmuró|strong="H3885"\w* \w contra|strong="H5921"\w* \w Moisés|strong="H4872"\w*: ¿\w Por|strong="H5921"\w* \w qué|strong="H4100"\w* \w nos|strong="H5921"\w* \w sacaste|strong="H5927"\w* \w de|strong="H5921"\w* \w Egipto|strong="H4714"\w* \w para|strong="H5921"\w* matarnos \w de|strong="H5921"\w* \w sed|strong="H6772"\w* \w a|strong="H3068"\w* \w nosotros|strong="H5921"\w*, \w a|strong="H3068"\w* nuestros \w hijos|strong="H1121"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* nuestros \w ganados|strong="H4735"\w*?   
\p
\v 4 \w Moisés|strong="H4872"\w* \w clamó|strong="H6817"\w* \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd*: ¿\w Qué|strong="H4100"\w* \w haré|strong="H6213"\w* con \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w*? Un \w poco|strong="H4592"\w* \w más|strong="H5750"\w* y me apedrearán.   
\p
\v 5 \nd \+w Yavé|strong="H3068"\+w*\nd* dijo \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: \wj \+w Pasa|strong="H5674"\+w* al frente del \+w pueblo|strong="H5971"\+w* y \+w toma|strong="H3947"\+w* \+w contigo|strong="H5971"\+w* algunos \+w de|strong="H6440"\+w* los \+w ancianos|strong="H2205"\+w* \+w de|strong="H6440"\+w* \+w Israel|strong="H3478"\+w*. \+w Toma|strong="H3947"\+w* \+w en|strong="H5221"\+w* tu \+w mano|strong="H3027"\+w* la \+w vara|strong="H4294"\+w* con la cual golpeaste \+w el|strong="H2975"\+w* Nilo, y \+w anda|strong="H1980"\+w*.\wj*  
\v 6 \wj \+w Mira|strong="H2005"\+w*, \+w Yo|strong="H4480"\+w* \+w estaré|strong="H5975"\+w* \+w delante|strong="H6440"\+w* \+w de|strong="H4480"\+w* \+w ti|strong="H5921"\+w* \+w allí|strong="H8033"\+w* \+w en|strong="H5921"\+w* \+w la|strong="H5921"\+w* peña \+w de|strong="H4480"\+w* \+w Horeb|strong="H2722"\+w*. Golpearás \+w la|strong="H5921"\+w* peña \+w y|strong="H5921"\+w* \+w saldrá|strong="H3318"\+w* \+w agua|strong="H4325"\+w* \+w de|strong="H4480"\+w* \+w ella|strong="H8033"\+w* \+w para|strong="H5921"\+w* \+w que|strong="H4480"\+w* \+w el|strong="H5921"\+w* \+w pueblo|strong="H5971"\+w* beba.\wj*  
\p \w Así|strong="H3651"\w* \w Moisés|strong="H4872"\w* \w lo|strong="H5921"\w* \w hizo|strong="H6213"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w presencia|strong="H6440"\w* \w de|strong="H4480"\w* \w los|strong="H5921"\w* \w ancianos|strong="H2205"\w* \w de|strong="H4480"\w* \w Israel|strong="H3478"\w*.  
\v 7 \w Llamó|strong="H7121"\w* aquel \w lugar|strong="H4725"\w* Masa \w y|strong="H5921"\w* Meriba \w por|strong="H5921"\w* \w el|strong="H5921"\w* altercado \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w y|strong="H5921"\w* \w porque|strong="H5921"\w* \w tentaron|strong="H5254"\w* \w a|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w al|strong="H5921"\w* \w decir|strong="H7121"\w*: ¿\w Está|strong="H3426"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w entre|strong="H5921"\w* \w nosotros|strong="H5921"\w*, \w o|strong="H3068"\w* \w no|strong="H5921"\w*?   
\p
\v 8 Entonces \w Amalec|strong="H6002"\w* llegó y luchó \w contra|strong="H5973"\w* \w Israel|strong="H3478"\w* \w en|strong="H5973"\w* Refidim.  
\v 9 \w Moisés|strong="H4872"\w* dijo \w a|strong="H3068"\w* \w Josué|strong="H3091"\w*: Escógenos varones \w y|strong="H5921"\w* \w sal|strong="H3318"\w* \w a|strong="H3068"\w* luchar \w contra|strong="H5921"\w* \w Amalec|strong="H6002"\w*. \w Mañana|strong="H4279"\w* yo \w me|strong="H5921"\w* ubicaré \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w cumbre|strong="H7218"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* colina \w con|strong="H5921"\w* \w la|strong="H5921"\w* \w vara|strong="H4294"\w* \w de|strong="H5921"\w* \nd ʼElohim\nd* \w en|strong="H5921"\w* \w mi|strong="H5921"\w* \w mano|strong="H3027"\w*.   
\p
\v 10 \w Josué|strong="H3091"\w* \w hizo|strong="H6213"\w* como \w Moisés|strong="H4872"\w* le dijo y luchó contra \w Amalec|strong="H6002"\w*. \w Moisés|strong="H4872"\w*, Aarón y \w Hur|strong="H2354"\w* \w subieron|strong="H5927"\w* \w a|strong="H3068"\w* la \w cumbre|strong="H7218"\w* \w de|strong="H3898"\w* la colina.  
\v 11 \w Sucedió|strong="H1961"\w* \w que|strong="H1961"\w* \w cuando|strong="H1961"\w* \w Moisés|strong="H4872"\w* \w tenía|strong="H1961"\w* su \w mano|strong="H3027"\w* en \w alto|strong="H7311"\w*, \w Israel|strong="H3478"\w* \w prevalecía|strong="H1396"\w*, pero \w cuando|strong="H1961"\w* él bajaba su \w mano|strong="H3027"\w*, \w Amalec|strong="H6002"\w* \w prevalecía|strong="H1396"\w*.   
\p
\v 12 \w Como|strong="H1961"\w* \w los|strong="H3427"\w* brazos \w de|strong="H5921"\w* \w Moisés|strong="H4872"\w* \w se|strong="H1961"\w* entumecieron, \w tomaron|strong="H3947"\w* una piedra, \w se|strong="H1961"\w* \w la|strong="H5921"\w* \w pusieron|strong="H7760"\w* \w debajo|strong="H8478"\w* \w y|strong="H5921"\w* \w se|strong="H1961"\w* sentó \w sobre|strong="H5921"\w* \w ella|strong="H5921"\w*. Aarón \w y|strong="H5921"\w* \w Hur|strong="H2354"\w* \w le|strong="H5921"\w* sostenían \w las|strong="H5921"\w* \w manos|strong="H3027"\w*, uno \w por|strong="H5921"\w* un \w lado|strong="H3027"\w* \w y|strong="H5921"\w* \w el|strong="H5921"\w* \w otro|strong="H2088"\w* \w por|strong="H5921"\w* \w el|strong="H5921"\w* \w otro|strong="H2088"\w*. \w Así|strong="H2088"\w* \w tuvo|strong="H1961"\w* firmeza \w en|strong="H5921"\w* sus brazos \w hasta|strong="H5704"\w* \w la|strong="H5921"\w* puesta \w del|strong="H5921"\w* \w sol|strong="H8121"\w*.  
\v 13 Así \w Josué|strong="H3091"\w* exterminó \w a|strong="H3068"\w* \w Amalec|strong="H6002"\w* y \w a|strong="H3068"\w* su \w pueblo|strong="H5971"\w* \w a|strong="H3068"\w* filo \w de|strong="H5971"\w* \w espada|strong="H2719"\w*.   
\p
\v 14 \w Entonces|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* dijo \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: \wj \+w Escribe|strong="H3789"\+w* \+w esto|strong="H2063"\+w* \+w como|strong="H3588"\+w* recordatorio \+w en|strong="H3588"\+w* un rollo \+w y|strong="H3588"\+w* recítalo \+w a|strong="H3068"\+w* \+w Josué|strong="H3091"\+w*: \+w Yo|strong="H3588"\+w* borraré absolutamente \+w la|strong="H3588"\+w* \+w memoria|strong="H2143"\+w* \+w de|strong="H3588"\+w* \+w Amalec|strong="H6002"\+w* \+w de|strong="H3588"\+w* \+w debajo|strong="H8478"\+w* del \+w cielo|strong="H8064"\+w*.\wj*   
\p
\v 15 \w Moisés|strong="H4872"\w* \w edificó|strong="H1129"\w* un \w altar|strong="H4196"\w*, lo \w llamó|strong="H7121"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \nd Nissi\nd*  
\v 16 \w y|strong="H3588"\w* dijo: \w Por|strong="H5921"\w* \w cuanto|strong="H3588"\w* \nd \+w YA|strong="H3068"\+w*\nd* juró, \nd \+w Yavé|strong="H3068"\+w*\nd* tendrá \w guerra|strong="H4421"\w* \w contra|strong="H5921"\w* \w Amalec|strong="H6002"\w* \w de|strong="H5921"\w* \w generación|strong="H1755"\w* \w en|strong="H5921"\w* \w generación|strong="H1755"\w*.   
\c 18  
\s1 Visita de Jetro  
\p
\v 1 Jetro, \w sacerdote|strong="H3548"\w* \w de|strong="H3588"\w* \w Madián|strong="H4080"\w*, \w suegro|strong="H2859"\w* \w de|strong="H3588"\w* \w Moisés|strong="H4872"\w*, \w oyó|strong="H8085"\w* \w todo|strong="H3605"\w* \w lo|strong="H6213"\w* \w que|strong="H3588"\w* \nd ʼElohim\nd* \w hizo|strong="H6213"\w* \w por|strong="H3588"\w* \w Moisés|strong="H4872"\w* \w y|strong="H3588"\w* \w por|strong="H3588"\w* \w su|strong="H3588"\w* \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w*, \w y|strong="H3588"\w* \w cómo|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w sacó|strong="H3318"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w*.   
\p
\v 2 Jetro, \w suegro|strong="H2859"\w* de \w Moisés|strong="H4872"\w*, \w tomó|strong="H3947"\w* \w a|strong="H3068"\w* Séfora, esposa de \w Moisés|strong="H4872"\w* (después que éste la envió \add a su casa\add*),  
\v 3 \w y|strong="H3588"\w* \w a|strong="H3068"\w* sus \w dos|strong="H8147"\w* \w hijos|strong="H1121"\w*. \w El|strong="H3588"\w* \w nombre|strong="H8034"\w* \w de|strong="H3588"\w* uno \w de|strong="H3588"\w* ellos \w era|strong="H1961"\w* Gersón, \w porque|strong="H3588"\w* dijo: \w Forastero|strong="H5237"\w* \w soy|strong="H1961"\w* \w en|strong="H3588"\w* tierra extranjera.  
\v 4 \w El|strong="H3588"\w* \w nombre|strong="H8034"\w* del otro era Eliezer, \w porque|strong="H3588"\w* dijo: \w el|strong="H3588"\w* \nd ʼElohim\nd* \w de|strong="H3588"\w* mis antepasados \w es|strong="H3588"\w* mi \w ayuda|strong="H5828"\w* \w y|strong="H3588"\w* \w me|strong="H3588"\w* \w libró|strong="H5337"\w* \w de|strong="H3588"\w* \w la|strong="H3588"\w* \w espada|strong="H2719"\w* \w de|strong="H3588"\w* \w Faraón|strong="H6547"\w*.   
\p
\v 5 Jetro, \w suegro|strong="H2859"\w* \w de|strong="H1121"\w* \w Moisés|strong="H4872"\w*, llegó al \w desierto|strong="H4057"\w* con \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* y \w la|strong="H1931"\w* esposa \w de|strong="H1121"\w* \w Moisés|strong="H4872"\w*. Acampó junto \w a|strong="H3068"\w* \w la|strong="H1931"\w* Montaña \w de|strong="H1121"\w* \nd ʼElohim\nd*  
\v 6 y envió palabra \w a|strong="H3068"\w* \w Moisés|strong="H4872"\w*: Yo, tu \w suegro|strong="H2859"\w* Jetro, vengo \w a|strong="H3068"\w* \w ti|strong="H5973"\w* \w con|strong="H5973"\w* tu esposa y tus \w dos|strong="H8147"\w* \w hijos|strong="H1121"\w*.   
\p
\v 7 Entonces \w Moisés|strong="H4872"\w* \w salió|strong="H3318"\w* \w a|strong="H3068"\w* recibir \w a|strong="H3068"\w* su \w suegro|strong="H2859"\w*, se inclinó y lo \w besó|strong="H5401"\w*. Se \w preguntaron|strong="H7592"\w* el uno al \w otro|strong="H7453"\w* por su salud y entraron \w en|strong="H3318"\w* la tienda.   
\s1 Victoria sobre Amalec  
\p
\v 8 Entonces \w Moisés|strong="H4872"\w* relató \w a|strong="H3068"\w* su \w suegro|strong="H2859"\w* \w todo|strong="H3605"\w* \w lo|strong="H5921"\w* \w que|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w hizo|strong="H6213"\w* \w a|strong="H3068"\w* \w Faraón|strong="H6547"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w los|strong="H5921"\w* \w egipcios|strong="H4714"\w* \w por|strong="H5921"\w* amor \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* \w y|strong="H5921"\w* \w todas|strong="H3605"\w* \w las|strong="H5921"\w* adversidades \w que|strong="H5921"\w* \w tuvieron|strong="H4672"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w camino|strong="H1870"\w*, \w y|strong="H5921"\w* \w cómo|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w los|strong="H5921"\w* \w libró|strong="H5337"\w*.   
\p
\v 9 Jetro \w se|strong="H5921"\w* regocijó \w por|strong="H5921"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w bien|strong="H2896"\w* \w que|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w hizo|strong="H6213"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w*, \w Quien|strong="H3605"\w* \w libró|strong="H5337"\w* \w al|strong="H5921"\w* pueblo \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w mano|strong="H3027"\w* \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w egipcios|strong="H4714"\w*.  
\v 10 Jetro exclamó: ¡\w Bendito|strong="H1288"\w* sea \nd \+w Yavé|strong="H3068"\+w*\nd*, Quien los \w libró|strong="H5337"\w* \w de|strong="H8478"\w* la \w mano|strong="H3027"\w* \w de|strong="H8478"\w* los \w egipcios|strong="H4714"\w* y \w de|strong="H8478"\w* la \w mano|strong="H3027"\w* \w de|strong="H8478"\w* \w Faraón|strong="H6547"\w*! ¡Él \w libró|strong="H5337"\w* \w al|strong="H8478"\w* \w pueblo|strong="H5971"\w* \w de|strong="H8478"\w* la \w mano|strong="H3027"\w* \w de|strong="H8478"\w* \w Egipto|strong="H4714"\w*!  
\v 11 \w Ahora|strong="H6258"\w* \w sé|strong="H3045"\w* \w que|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w es|strong="H3588"\w* \w mayor|strong="H1419"\w* \w que|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \tl ʼelohim\tl*, \w pues|strong="H3588"\w* quedó probado \w que|strong="H3588"\w* \w en|strong="H5921"\w* \w aquello|strong="H1697"\w* \w en|strong="H5921"\w* \w lo|strong="H1697"\w* \w cual|strong="H3588"\w* \w se|strong="H3045"\w* ensoberbecieron, \w Él|strong="H5921"\w* prevaleció \w contra|strong="H5921"\w* \w ellos|strong="H5921"\w*.   
\p
\v 12 Entonces Jetro, \w suegro|strong="H2859"\w* \w de|strong="H6440"\w* \w Moisés|strong="H4872"\w*, ofreció un \w holocausto|strong="H5930"\w* y \w sacrificios|strong="H2077"\w* \w a|strong="H3068"\w* \nd ʼElohim.\nd* \w Y|strong="H3068"\w* Aarón llegó \w con|strong="H5973"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w ancianos|strong="H2205"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w* \w a|strong="H3068"\w* comer \w pan|strong="H3899"\w* \w con|strong="H5973"\w* \w el|strong="H5973"\w* \w suegro|strong="H2859"\w* \w de|strong="H6440"\w* \w Moisés|strong="H4872"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \nd ʼElohim.\nd*   
\p
