\p 
\v 39 \w Then|strong="G2532"\w* \w He|strong="G2532"\w* \w told|strong="G3004"\w* \w them|strong="G3004"\w* \w a|strong="G2532"\w* \w parable|strong="G3850"\w*: “\w Can|strong="G1410"\w* \w a|strong="G2532"\w* \w blind|strong="G5185"\w* \w man|strong="G5185"\w* \w guide|strong="G3594"\w* \w a|strong="G2532"\w* \w blind|strong="G5185"\w* \w man|strong="G5185"\w*? \w Will|strong="G2532"\w* \w they|strong="G2532"\w* \w not|strong="G3780"\w* \w both|strong="G2532"\w* \w fall|strong="G1706"\w* \w into|strong="G1519"\w* \w a|strong="G2532"\w* ditch?
