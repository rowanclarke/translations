\v 4 \w You|strong="H6213"\w* \w have|strong="H1942"\w* loved \w all|strong="H6213"\w* devouring words, || \w O|strong="H3068"\w* \w you|strong="H6213"\w* \w deceitful|strong="H7423"\w* \w tongue|strong="H3956"\w*.
