\v 38 \w Hijo|strong="H1121"\w* \w de|strong="H1121"\w* Izhar, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Coat, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Leví, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Israel.   
\m
\v 39 \w Y|strong="H3068"\w* \w su|strong="H1992"\w* hermano Asaf, \w el|strong="H3588"\w* \w cual|strong="H3588"\w* \w estaba|strong="H1961"\w* \w a|strong="H3068"\w* \w su|strong="H1992"\w* mano derecha: Asaf, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Berequías, \w hijo|strong="H1121"\w* \w de|strong="H3588"\w* Sima;   
\m
\v 40 Hijo \w de|strong="H5414"\w* Micael, hijo \w de|strong="H5414"\w* Baasías, hijo \w de|strong="H5414"\w* Malquías;   
\m
\v 41 \w Hijo|strong="H1121"\w* \w de|strong="H1121"\w* Etni, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Zera, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Adaia;   
\m
\v 42 \w Hijo|strong="H1121"\w* \w de|strong="H1121"\w* Etán, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Zima, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Simi;   
\m
\v 43 Hijo de Jahat, hijo de Gersón, hijo de Leví.   
\m
\v 44 Mas los hijos de Merari sus hermanos estaban \w a|strong="H3068"\w* la mano siniestra, \add es a saber,\add* Etán hijo de Quisi, hijo de Abdi, hijo de Maluc;   
\m
\v 45 Hijo de Hasabías, hijo de Amasías, hijo de Hilquías;   
\m
\v 46 \w Hijo|strong="H1121"\w* \w de|strong="H1121"\w* Amasai, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Bani, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Semer;   
\m
\v 47 \w Hijo|strong="H1121"\w* \w de|strong="H1121"\w* Mahali, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Musi, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Merari, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Leví.   
\m
\v 48 \w Y|strong="H3068"\w* sus hermanos \w los|strong="H1121"\w* levitas fueron puestos sobre todo \w el|strong="H1121"\w* ministerio del tabernáculo \w de|strong="H1121"\w* la casa \w de|strong="H1121"\w* Dios.   
\m
\v 49 Mas Aarón y sus \w hijos|strong="H1121"\w* ofrecí­an perfume sobre \w el|strong="H1121"\w* altar \w de|strong="H1121"\w* la ofrenda quemada, y sobre \w el|strong="H1121"\w* altar del perfume, en toda la obra del lugar santísimo, y \w para|strong="H5414"\w* hacer las expiaciones sobre \w Israel|strong="H3478"\w*, confor­me \w a|strong="H3068"\w* todo lo \w que|strong="H1121"\w* Moisés siervo \w de|strong="H1121"\w* Dios había mandado.   
\m
\v 50 \w Y|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Aarón son estos, Eleazar su \w hijo|strong="H1121"\w*, Finees su \w hijo|strong="H1121"\w*, Abisua su \w hijo|strong="H1121"\w*;   
\m
\v 51 Buqui su \w hijo|strong="H1121"\w*, Uzi su \w hijo|strong="H1121"\w*, Zeraías su \w hijo|strong="H1121"\w*;   
\m
\v 52 Meraiot su hijo, Amarías su hijo, Ahitob su hijo;   
\m
\v 53 Sadoc su hijo, Ahimaas su hijo.   
\m
\v 54 \w Y|strong="H3068"\w* estas son sus habitaciones, conforme \w a|strong="H3068"\w* sus domicilios y sus términos, \add las\add* de los hijos de Aarón por las familias de los coatitas, porque de ellos fue la suerte:   
\m
\v 55 Les dieron pues \w a|strong="H3068"\w* Hebrón en tierra \w de|strong="H1121"\w* Judá, y sus \w ejidos|strong="H4054"\w* alre­dedor \w de|strong="H1121"\w* ella.   
\m
\v 56 Mas \w el|strong="H1121"\w* territorio \w de|strong="H1121"\w* la ciudad y sus aldeas se dieron \w a|strong="H3068"\w* Caleb, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Jefone.   
\m
\v 57 \w Y|strong="H3068"\w* \w a|strong="H3068"\w* los hijos de Aarón dieron las ciudades de Judá de acogi­miento, \add es a saber,\add* \w a|strong="H3068"\w* Hebrón, y \w a|strong="H3068"\w* Libna con sus \w ejidos|strong="H4054"\w*; \w a|strong="H3068"\w* Jatir, y Estemoa con sus \w ejidos|strong="H4054"\w*,   
\m
\v 58 \w Y|strong="H3068"\w* \w a|strong="H3068"\w* Hilem con sus \w ejidos|strong="H4054"\w*, y \w a|strong="H3068"\w* Debir con sus \w ejidos|strong="H4054"\w*:   
\m
\v 59 \w A|strong="H3068"\w* Asán con sus \w ejidos|strong="H4054"\w*, y \w a|strong="H3068"\w* Bet-semes con sus \w ejidos|strong="H4054"\w*:   
\m
\v 60 \w Y|strong="H3068"\w* de la tribu de Benjamín, \w a|strong="H3068"\w* Geba con sus \w ejidos|strong="H4054"\w*, y \w a|strong="H3068"\w* Alemet con sus \w ejidos|strong="H4054"\w*, y \w a|strong="H3068"\w* Anatot con sus \w ejidos|strong="H4054"\w*. Todas sus ciudades fueron trece ciudades, \add repartidas\add* por sus linajes.   
\m
\v 61 \w A|strong="H3068"\w* los hijos de Coat, que que­daron de su parentela, \add dieron\add* diez ciudades de la media \w tribu|strong="H4294"\w* de Manasés por suerte.   
\m
\v 62 \w Y|strong="H3068"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Gersón, por sus linajes, \add dieron\add* \w de|strong="H1121"\w* la \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* Isacar, y \w de|strong="H1121"\w* la \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* Aser, y \w de|strong="H1121"\w* la \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* Neftalí, y \w de|strong="H1121"\w* la \w tribu|strong="H4294"\w* \w de|strong="H1121"\w* Manasés en Basán, trece ciudades.   
\m
\v 63 \w Y|strong="H3068"\w* \w a|strong="H3068"\w* los hijos de Merari, por sus linajes, de la \w tribu|strong="H4294"\w* de \w Rubén|strong="H7205"\w*, y de la \w tribu|strong="H4294"\w* de Gad, y de la \w tribu|strong="H4294"\w* de Zabulón, \add se dieron\add* por suerte doce ciudades.   
\m
\v 64 \w Y|strong="H3068"\w* dieron los hijos de Israel \w a|strong="H3068"\w* los levitas ciudades con sus eji­dos.   
\m
\v 65 \w Y|strong="H3068"\w* dieron por suerte de la \w tribu|strong="H4294"\w* de los hijos de Judá, y de la \w tribu|strong="H4294"\w* de los hijos de Simeón, y de la \w tribu|strong="H4294"\w* de los hijos de Benjamín, las ciudades que nombraron por sus nombres.   
\m
\v 66 \w Y|strong="H3068"\w* \w a|strong="H3068"\w* los linajes de los hijos de Coat \add dieron\add* ciudades con sus términos de la tribu de Efraím.   
\m
\v 67 \w Y|strong="H3068"\w* diéronles las ciudades de acogimiento, \w a|strong="H3068"\w* Siquem con sus ejidos en el monte de Efraím, y \w a|strong="H3068"\w* Gezer con sus ejidos,   
\m
\v 68 \w Y|strong="H3068"\w* \w a|strong="H3068"\w* Jocmeam con sus ejidos, y \w a|strong="H3068"\w* Bet-horón con sus ejidos,   
\m
\v 69 \w Y|strong="H3068"\w* \w a|strong="H3068"\w* Ajalón con sus ejidos, y \w a|strong="H3068"\w* Gat-rimón con sus ejidos.   
\m
\v 70 De la media tribu de Manasés, \w a|strong="H3068"\w* Aner con sus ejidos, y \w a|strong="H3068"\w* Bilam con sus ejidos, para los del linaje de los hijos de Coat que habían quedado.   
\m
\v 71 \w Y|strong="H3068"\w* \w a|strong="H3068"\w* los hijos de Gersón \add dieron\add* de la familia de la media tribu de Manasés, \w a|strong="H3068"\w* Golan en Basán con sus ejidos y \w a|strong="H3068"\w* Astarot con sus ejidos;   
\m
\v 72 \w Y|strong="H3068"\w* de la tribu de Isacar, \w a|strong="H3068"\w* Cedes con sus ejidos, \w a|strong="H3068"\w* Daberat con sus ejidos,   
\m
\v 73 \w Y|strong="H3068"\w* \w a|strong="H3068"\w* Ramot con sus ejidos, y \w a|strong="H3068"\w* Anem con sus ejidos;   
\m
\v 74 \w Y|strong="H3068"\w* de la tribu de Aser, \w a|strong="H3068"\w* Masal con sus ejidos, y \w a|strong="H3068"\w* Abdón con sus ejidos,   
\m
\v 75 \w Y|strong="H3068"\w* \w a|strong="H3068"\w* Ucoc con sus ejidos, y \w a|strong="H3068"\w* Rehob con sus ejidos;   
\m
\v 76 \w Y|strong="H3068"\w* de la tribu de Neftalí, \w a|strong="H3068"\w* Cedes en Galilea con sus ejidos, y \w a|strong="H3068"\w* Amón con sus ejidos, \w a|strong="H3068"\w* Quiriat-jearim con sus ejidos.   
\m
\v 77 \w Y|strong="H3068"\w* \w a|strong="H3068"\w* los hijos de Merari que habían quedado, \add dieron\add* de la tribu de Zabulón \w a|strong="H3068"\w* Rimón con sus ejidos, y \w a|strong="H3068"\w* Tabor con sus ejidos;   
\m
\v 78 \w Y|strong="H3068"\w* de la otra parte del Jordán de Jericó, al oriente del Jordán, \add dieron\add*, de la tribu de Rubén, \w a|strong="H3068"\w* Beser en el desierto con sus eji­dos; y \w a|strong="H3068"\w* Jasa con sus ejidos,   
\m
\v 79 \w Y|strong="H3068"\w* \w a|strong="H3068"\w* Cademot con sus eji­dos, y \w a|strong="H3068"\w* Mefaat con sus eji­dos;   
\m
\v 80 \w Y|strong="H3068"\w* de la tribu de Gad, \w a|strong="H3068"\w* Ramot en Galaad con sus ejidos, y \w a|strong="H3068"\w* Mahanaim con sus ejidos,   
\m
\v 81 \w Y|strong="H3068"\w* \w a|strong="H3068"\w* Hesbón con sus ejidos, y \w a|strong="H3068"\w* Jacer con sus ejidos.   
\c 7
\m
\v 1 \w LOS|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Isacar, cuatro: \w Tola|strong="H8439"\w*, Fúa, \w Jabsub|strong="H3437"\w*, y Simrón.   
\m
\v 2 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Tola|strong="H8439"\w*: Uzi, Refaías, \w Jeriel|strong="H3400"\w*, \w Jamai|strong="H3181"\w*, \w Jibsam|strong="H3005"\w* y \w Samuel|strong="H8050"\w*, \w cabezas|strong="H7218"\w* en las \w familias|strong="H1004"\w* \w de|strong="H1121"\w* sus padres. \w De|strong="H1121"\w* \w Tola|strong="H8439"\w* \w fueron|strong="H1732"\w* \w contados|strong="H4557"\w* por sus linajes en \w el|strong="H1121"\w* \w tiempo|strong="H3117"\w* \w de|strong="H1121"\w* \w David|strong="H1732"\w*, \w veintidós|strong="H6242"\w* \w mil|strong="H3967"\w* \w seiscientos|strong="H8337"\w* \w hombres|strong="H1368"\w* muy valero­sos.   
\m
\v 3 \w Hijo|strong="H1121"\w* \w de|strong="H2568"\w* Uzi fue Izrahías; y \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H2568"\w* Izrahías: Micael, \w Obadías|strong="H5662"\w*, \w Joel|strong="H3100"\w*, \w e|strong="H3068"\w* \w Isías|strong="H3449"\w*: \w todos|strong="H3605"\w*, \w cinco|strong="H2568"\w* \w príncipes|strong="H7218"\w*.   
\m
\v 4 \w Y|strong="H3068"\w* \w había|strong="H3588"\w* \w con|strong="H5921"\w* \w ellos|strong="H5921"\w* \w en|strong="H5921"\w* sus linajes, \w por|strong="H5921"\w* \w las|strong="H5921"\w* \w familias|strong="H1004"\w* \w de|strong="H5921"\w* sus padres, \w treinta|strong="H7970"\w* \w y|strong="H3588"\w* \w seis|strong="H8337"\w* mil \add hombres\add* \w de|strong="H5921"\w* \w guerra|strong="H4421"\w*: \w por|strong="H5921"\w* \w que|strong="H3588"\w* tuvieron \w muchas|strong="H7235"\w* esposas \w e|strong="H3068"\w* \w hijos|strong="H1121"\w*.   
\m
\v 5 \w Y|strong="H3068"\w* sus hermanos por \w todas|strong="H3605"\w* las \w familias|strong="H4940"\w* de Isacar, contados \w todos|strong="H3605"\w* por sus genealogías, eran \w ochenta|strong="H8084"\w* y \w siete|strong="H7651"\w* mil \add hombres\add* \w valientes|strong="H1368"\w* en extremo.   
\m
\v 6 Los \add hijos\add* de \w Benjamín|strong="H1144"\w* fueron \w tres|strong="H7969"\w*: \w Bela|strong="H1106"\w*, Bequer, y \w Jediael|strong="H3043"\w*.   
\m
\v 7 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H2568"\w* \w Bela|strong="H1106"\w*: Esbon, Uzi, Uziel, Jerimot, \w e|strong="H3068"\w* Iri; \w cinco|strong="H2568"\w* \w cabezas|strong="H7218"\w* \w de|strong="H2568"\w* \w casas|strong="H1004"\w* \w de|strong="H2568"\w* linajes, hom­bres \w de|strong="H2568"\w* gran valor, y \w de|strong="H2568"\w* cuya des­cendencia fueron contados vein­tidós mil \w treinta|strong="H7970"\w* y cuatro.   
\m
\v 8 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Bequer: \w Zemira|strong="H2160"\w*, \w Joas|strong="H3135"\w*, Eliezer, Elienai, \w Omri|strong="H6018"\w*, Jerimot, Abías, Anatot y Alemet; \w todos|strong="H3605"\w* \w estos|strong="H3605"\w* fueron \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Bequer.   
\m
\v 9 \w Y|strong="H3068"\w* contados por sus descenden­cias, por sus linajes, los que eran \w cabezas|strong="H7218"\w* de sus \w familias|strong="H1004"\w*, \add resulta­ron\add* \w veinte|strong="H6242"\w* \w mil|strong="H3967"\w* y \w doscientos|strong="H3967"\w* hom­bres de grande \w esfuerzo|strong="H2428"\w*.   
\m
\v 10 \w Hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Jediael|strong="H3043"\w* fue \w Bilhán|strong="H1092"\w*; y \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Bilhán|strong="H1092"\w*: Jebús, \w Benjamín|strong="H1144"\w*, Aod, Quenaana, Zetán, \w Tarsis|strong="H8659"\w*, y Ahisahar.   
\m
\v 11 \w Todos|strong="H3605"\w* \w estos|strong="H3605"\w* fueron \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Jediael|strong="H3043"\w*, \w cabezas|strong="H7218"\w* \w de|strong="H1121"\w* familias, \w hombres|strong="H1368"\w* muy \w valerosos|strong="H1368"\w*, dieci­\w siete|strong="H7651"\w* \w mil|strong="H3967"\w* y \w doscientos|strong="H3967"\w* \w que|strong="H1121"\w* \w salían|strong="H3318"\w* \w a|strong="H3068"\w* \w combatir|strong="H4421"\w* \w en|strong="H3318"\w* \w la|strong="H3605"\w* \w guerra|strong="H4421"\w*.   
\m
\v 12 \w Y|strong="H3068"\w* Suppim y Hupim fueron \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Hir: y \w Husim|strong="H2366"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Aher.   
\m
\v 13 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Neftalí: Jaoel, \w Guni|strong="H3337"\w*, \w Jezer|strong="H7967"\w*, y Salum, \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Bilha|strong="H1090"\w*.   
\m
\v 14 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Manasés|strong="H4519"\w*: Asriel, \w el|strong="H1121"\w* cual le \w parió|strong="H3205"\w* su \w concubina|strong="H6370"\w* la Sira: (la cual también le \w parió|strong="H3205"\w* \w a|strong="H3068"\w* Maquir, padre \w de|strong="H1121"\w* \w Galaad|strong="H1568"\w*:   
\m
\v 15 \w Y|strong="H3068"\w* Maquir \w tomó|strong="H3947"\w* por esposa \add la hermana\add* de Hupim y Suppim, cuya hermana \w tuvo|strong="H1961"\w* por \w nombre|strong="H8034"\w* Maaca:) y el \w nombre|strong="H8034"\w* del segun­do \w fue|strong="H1961"\w* Zelofehad. \w Y|strong="H3068"\w* Zelofehad \w tuvo|strong="H1961"\w* \w hijas|strong="H1323"\w*.   
\m
\v 16 \w Y|strong="H3068"\w* Maaca esposa \w de|strong="H1121"\w* Maquir le \w parió|strong="H3205"\w* un \w hijo|strong="H1121"\w*, y llamóle \w Peres|strong="H6570"\w*; y \w el|strong="H1121"\w* \w nombre|strong="H8034"\w* \w de|strong="H1121"\w* su hermano fue Seres, cuyos \w hijos|strong="H1121"\w* fueron Ulam y \w Recem|strong="H7552"\w*.   
\m
\v 17 \w Hijo|strong="H1121"\w* \w de|strong="H1121"\w* Ulam fue Bedán. Éstos \add fueron\add* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Galaad|strong="H1568"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Maquir, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Manasés|strong="H4519"\w*.   
\m
\v 18 \w Y|strong="H3068"\w* su hermana Hamolequet \w parió|strong="H3205"\w* \w a|strong="H3068"\w* Isod, y \w a|strong="H3068"\w* Abiezer, y Mahala.   
\m
\v 19 \w Y|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Semida \w fueron|strong="H1961"\w* Ahián, Siquem, Likhi, y Aniam.   
\m
\v 20 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* Efraím: Sutela, \w Bered|strong="H1260"\w* su \w hijo|strong="H1121"\w*, su \w hijo|strong="H1121"\w* Tahat, Elada su \w hijo|strong="H1121"\w*, Tahat su \w hijo|strong="H1121"\w*,   
\m
\v 21 \w Y|strong="H3068"\w* \w Zabad|strong="H2066"\w* \w su|strong="H3588"\w* \w hijo|strong="H1121"\w*, \w y|strong="H3588"\w* Sutela \w su|strong="H3588"\w* \w hijo|strong="H1121"\w*, \w y|strong="H3588"\w* \w Ezer|strong="H5827"\w*, \w y|strong="H3588"\w* Elad; \w mas|strong="H3588"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H3588"\w* Gat, \w naturales|strong="H3205"\w* \w de|strong="H3588"\w* \add aquella\add* tierra, \w los|strong="H1121"\w* \w mataron|strong="H2026"\w* \w porque|strong="H3588"\w* \w vinieron|strong="H3381"\w* \w a|strong="H3068"\w* tomarles sus \w ganados|strong="H4735"\w*.   
\m
\v 22 \w Y|strong="H3068"\w* Efraím su padre hizo duelo por \w muchos|strong="H7227"\w* \w días|strong="H3117"\w*, y vinie­ron sus hermanos \w a|strong="H3068"\w* consolarlo.   
\m
\v 23 Entrando \w él|strong="H3588"\w* \w después|strong="H1961"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* esposa, ella \w concibió|strong="H2029"\w*, \w y|strong="H3588"\w* \w parió|strong="H3205"\w* un \w hijo|strong="H1121"\w*, al \w cual|strong="H3588"\w* \w puso|strong="H3205"\w* \w por|strong="H3588"\w* \w nombre|strong="H8034"\w* \w Bería|strong="H1283"\w*; \w por|strong="H3588"\w* \w cuanto|strong="H3588"\w* \w había|strong="H1961"\w* \w estado|strong="H1961"\w* \w en|strong="H3588"\w* aflicción \w en|strong="H3588"\w* \w su|strong="H3588"\w* \w casa|strong="H1004"\w*   
\m
\v 24 \w Y|strong="H3068"\w* su \w hija|strong="H1323"\w* fue Seera, la cual \w edificó|strong="H1129"\w* \w a|strong="H3068"\w* Bet-horón la baja y la alta, y \w a|strong="H3068"\w* Uzen-seera.   
\m
\v 25 \w Hijo|strong="H1121"\w* \w de|strong="H1121"\w* este \add Bería\add* fue Refa, y Resef, y Tela su \w hijo|strong="H1121"\w*, y Taán su \w hijo|strong="H1121"\w*,   
\m
\v 26 \w Laadán|strong="H3936"\w* su \w hijo|strong="H1121"\w*, Amiud su \w hijo|strong="H1121"\w*, Elisama su \w hijo|strong="H1121"\w*,   
\m
