\id JOL .01, Joel 1, Motu, PNG, RTWP 12/92 
\h IOEL 
\toc1 IOEL 
\toc2 IOEL 
\mt1 IOEL  
\c 1  
\s1 Kwadi edia hahevahu  
\p
\v 1 Iehova ena hereva Ioel Petuel enai e kau. Ini e gwau toma:   
\q1
\v 2 Iahu e, ina na a kamonai!  
\q2 Tano inoholaina taumui iboumui ai, taiamui a hakala!  
\q1 Umui emui nega ai eiava tamamui edia nega ai  
\q2 kara inihetomana vada e vara a?   
\q1
\v 3 Natumui ba hamaorolaidia,  
\q2 bena idia ese natudia ma bae hamaorolaidia,  
\q2 gabeai unu natudia ese uru ta ma bae hamaorolaidia.   
\b  
\q1
\v 4 Rau-ani kwadidia ese e rakatani ḡaudia na  
\q2 kwadi tabatabadia ese vada e ani;  
\q1 bona kwadi tabatabadia ese e rakatani ḡaudia na  
\q2 roho kwadidia ese vada e ani;  
\q1 bona roho kwadidia ese e rakatani ḡaudia na  
\q2 hahevahu kwadidia ese vada e ani.   
\b  
\q1
\v 5 Kekero taumui e, a noga, ba taitai;  
\q2 vine ranuna o inumu taumui, ba tai lolololo;  
\q1 vine ranuna gaihona dainai ba tai,  
\q2 badina be udumui amo vada eme heabi oho.   
\q1
\v 6 Badina be bese ta vada e tore isi, lauegu tano ihadikana totona,  
\q2 mai siahudia bona diaḡau;  
\q1 isedia na leona isedia na heheto,  
\q2 gadigadidia na leona hahinena gadigadina na heheto.   
\q1
\v 7 Egu vine audia vada e havahudia,  
\q2 egu suke audia vada e hakwaidudia;  
\q1 kopidia vada e vakadia oho, vada e negedia dobi;  
\q2 rigidia vada e hakurokurodia.   
\b  
\q1
\v 8 Ba taitai, hane-ulato rami-hebouna na heto;  
\q2 puse dabuana e rioamu, maohenina taina e taimu.   
\q1
\v 9 Flaoa boubouna bona inuinu boubouna ḡaudia na  
\q2 Iehova ena dubu amo vada eme heabi oho.  
\q1 Helaḡa taudia, Iehova ena hesiai taudia,  
\q2 na e taitaimu.   
\q1
\v 10 Biru gabudia vada e vahu,  
\q2 tano na e taimu;  
\q1 badina be uit vada e dika vaitani,  
\q2 vine ranuna e oremu, dehoro na e-dodomu.   
\b  
\q1
\v 11 Biru taumui e, daramui bae doko;  
\q2 vine ireḡudia taumui e, ba tai;  
\q1 uit bona bali daidiai,  
\q2 uma anidia vada e dika dainai.   
\q1
\v 12 Vine auna e maraimu,  
\q2 suke auna e kakoromu;  
\q1 rimono, pamu, apolo,  
\q2 bona imea audia iboudiai e maraimu;  
\q1 bona moale e oremu  
\q2 taunimanima natudia ediai.   
\b  
\q1
\v 13 Hahelaḡa taumui e, puse dabuadia ba rio, ba tai;  
\q2 ihaboulaina patadia ireḡudia taumui e, ba tai lolololo.  
\q1 Egu Dirava isiaina ilao-henina taumui e,  
\q2 a raka vareai, mai puse dabuamui, ba noho rani.  
\q1 Badina be flaoa boubouna bona inuinu boubouna ḡaudia na  
\q2 emui Dirava ena dubu amo vada e herumu.   
\b  
\q1
\v 14 Anivaga ta ba hahelagaia;  
\q2 hebou helaḡana ta ba boilaia.  
\q1 Hanua tau-badadia ba haboudia,  
\q2 bona tano inoholaina taudia iboudiai danu;  
\q1 Iehova, emui Dirava, ena dubu ai bae hahebou,  
\q2 Iehova bae tai henia.   
\q1
\v 15 Dina madi ihabaina!  
\q2 badina be Iehova ena dina vada eme kahikahi;  
\q1 hahebua-tari, Siahu-idoinai Diravana ena amo,  
\q2 unu e mai tomamu.   
\q1
\v 16 Aniani na ita vairada amo  
\q2 vada eme heabi oho ani?  
\q1 Moale bona lalo-namo na eda Dirava ena dubu amo  
\q2 vada eme heabi oho ani?   
\b  
\q1
\v 17 Uhe na tano baruadia henudiai e masemu;  
\q2 habou-habou rumadia vada e ḡaḡae;  
\q1 roge vada e dika,  
\q2 badina be uma na asi anidia.   
\q1
\v 18 Ubu-ubu ḡaudia na e ḡanaganamu,  
\q2 boromakau seridia na e daradaramu,  
\q1 badina be asi adia rei;  
\q2 mamoe seridia danu kudoudia e hetahamu.   
\b  
\q1
\v 19 Iehova e, lau oi na tai henimumu;  
\q2 badina be tano ḡaḡaena ena rei gabudia na  
\q2 lahi ese vada e aradia ore;  
\q1 bona tano paka audia iboudiai na  
\q2 lahi hururu-hururuna ese vada e aradia.   
\q1
\v 20 Uda boromadia ese danu oi e tai henimumu,  
\q2 badina be sinavai-sinavai vada e kororo,  
\q1 bona tano ḡaḡaena ena rei gabudia na  
\q2 lahi ese vada e aradia ore.   
\c 2  
\q1
\v 1 Siona ai kibi ba hiriria;  
\q2 egu ororo helaḡana ai ba hone!  
\q1 Tano inoholaina taudia bae heude-heude,  
\q2 badina be Iehova ena dina vada e maimu,  
\q2 vada eme kahira-kahira,   
\q1
\v 2 dibura bona gabola dinana,  
\q2 dagadaga bona dibura masemase dinana!  
\q1 Bese badana mai siahuna ida  
\q2 ororo ai e da'ania, dagadaga na heto;  
\q1 nega gunadia amo idia heḡereḡeredia haida asie hedinarai,  
\q2 bona idia muridiai danu heḡereḡeredia haida basie hedinarai,  
\q2 uru iboudiai lalodiai.   
\b  
\q1
\v 3 Idia vairadiai lahi na e heara oremu,  
\q2 bona muridiai lahi hururu-hururuna na e hearamu.  
\q1 Vairadiai tano ita-itana na Eden imeana na heto,  
\q2 a muridiai tano na e gagaemu, e vahu vaitanimu,  
\q2 ḡau ta idia imadia amo se roho maurimu.   
\b  
\q1
\v 4 Oromadia na hosi oromadia heḡereḡeredia,  
\q2 bona e heaumu, tuari hosidia na heheto.   
\q1
\v 5 Mai reḡedia, kariota reḡedia na heheto,  
\q2 ororo doridia ai e rohomu;  
\q1 lahi hururu-hururuna ese rei e araiamu na heto,  
\q2 tuari oreana mai goadana tuari totona e gini heḡaeḡaemu na heto.   
\q1
\v 6 Idia vairadiai taunimanima na hisihisi ese e gugubadiamu,  
\q2 vaira iboudiai e laboradia gugurumu.   
\q1
\v 7 Tuari taudia na heheto e heaumu,  
\q2 tuari taudia na heheto maḡu e dada daemu.  
\q1 Ta ta ena dala ena dala ai e rakamu,  
\q2 edia dala amo asie raka sirimu.   
\q1
\v 8 Asie raka hesede-hesedemu,  
\q2 ta ta ena dala ena dala ai e rakamu;  
\q1 tuari lalonai e tata vareaimu,  
\q2 ta ese se ginidia ahumu.   
\q1
\v 9 Hanua latanai e roho kaumu,  
\q2 hanua maḡuna e heau heniamu;  
\q1 ruma lalodiai e dada daemu,  
\q2 gaba mauru amo e rau vareaimu, henao tauna na heto.   
\b  
\q1
\v 10 Idia vairadiai tano e lagamu,  
\q2 bona guba e heude-heudemu.  
\q1 Dina bona hua e diburamu,  
\q2 hisiu na asie nakamu.   
\q1
\v 11 Iehova gadona e hadaeamu,  
\q2 ena tuari oreana vairanai,  
\q1 badina be ena tuari oreana na bada herea;  
\q2 ena hereva anina e havaraiamu tauna na mai siahuna.  
\q1 Badina be Iehova ena dina na dina badana mai garina;  
\q2 ia lalonai daika baine haheauka diba?   
\s1 Iehova ena hebogahisi  
\q1
\v 12 Iehova na e tomu: ina harihari  
\q2 lau dekegu ai a lou mai, mai lalomui idoidiai ida,  
\q1 bona mai anivagamui, mai taimui, mai ganaganamui ida;   
\q2
\v 13 Ialomui hari ba daredia, dia dabuamui.  
\q1 Iehova, emui Dirava, ba lou henia,  
\q2 badina be ia na mai ena harihari-bada bona mai ena hebogahisi.  
\q1 ia na badu ai e halahemu, bona ena lalokau na bada herea,  
\q2 bona kara dika amo e helalo kerehaimu.   
\q1
\v 14 Daika dibana, reana ia na baine helalo kerehai lou,  
\q2 bona hahenamo na ia murina kahana ai baine rakatania,  
\q1 flaoa boubouna bona inuinu boubou ḡaudia,  
\q2 Iehova, emui Dirava, ena.   
\b  
\q1
\v 15 Siona ai kibi ba hiriria,  
\q2 anivaga ta ba hahelaḡaia;  
\q1 hebou helaḡana ta ba boilaia,   
\q2
\v 16 taunimanima ba haboudia.  
\q1 Hebou taudia ba hahelagadia,  
\q2 hanua tau-badadia ba haboudia;  
\q1 memero kekeni ba gogodia,  
\q2 rata e inumu memerodia danu.  
\q1 Headava matamata tauna ese ena daiutu baine rakatania,  
\q2 headava matamata hahinena danu ena daiutu amo baine raka lasi.   
\b  
\q1
\v 17 Iduara dehena bona ihaboulaina patana padadiai  
\q2 hahelaḡa taudia, Iehova ena hesiai taudia, na bae tai,  
\q1 baeto: Iehova e, emu orea taudia ba bogadia hisi,  
\q2 dihimu basio hahemaraia,  
\q1 gwaurai-gwaurai herevana ai basio halaoa,  
\q2 bese idau-idau bogaragidiai.  
\q1 Dahaka dainai bese idau-idau bogaragidiai baeto  
\q2 “Edia Dirava be edeseni ai?”   
\b  
\q1
\v 18 Bena Iehova na e vageḡe, ena tano dainai,  
\q2 ia ese ena orea taudia e bogadia hisi.   
\q1
\v 19 Iehova na e haere, ena orea taudia e hamaorodia, eto:  
\q2 A itaia, uit bona vine ranuna bona dehoro na siaidia vasimu,  
\q2 bena bogamui do bae kunu;  
\q1 bona basina hahemaraimui lou,  
\q2 bese idau-idau bogaragidiai.   
\b  
\q1
\v 20 Mirigini kahana tauna na emui amo baina abia oho dauhai,  
\q2 tano kaukauna, tano deḡedeḡena-rahu ai baina lulua lao;  
\q1 ena vaira oreana na laurabada kahana davarana ai,  
\q2 bona ena muri oreana na lahara kahana davarana ai,  
\q2 baina luludia lao.  
\q1 Ia bonana dikana bona bodagana na baine dae,  
\q2 badina be ia ese kara badadia vada e kara.   
\b  
\q1
\v 21 Tano e, basio gari;  
\q2 ba moale, ba hisi dae;  
\q2 badina be Iehova ese kara badadia vada o kara.   
\q1
\v 22 Uda boromadia e, basio gari;  
\q2 badina be tano ḡaḡaena ena rei gabudia ai  
\q2 rei matamata e tubumu;  
\q1 au huahuadia e dobimu,  
\q2 suke auna bona vine auna anidia e vara badabadamu.   
\b  
\q1
\v 23 Siona natuna verina e, ba moale!  
\q2 Iehova, emui Dirava, ba moalelaia!  
\q1 Badina be ia ese medu gunadia vada e heni,  
\q2 umui ihamomokanimui totona;  
\q1 medu barokodia na latamui ai vada e hadiho,  
\q2 medu gunana bona medu gabena, nega gunadaia heḡereḡeredia.   
\b  
\q1
\v 24 Uit ikwadilaina gabudia ai na uit ai bae honu,  
\q2 vine ranuna bona dehoro na hodu amo bae hepurai dobi.   
\q1
\v 25 Kwadi tabatabadia, roho kwadidia,  
\q2 hahevahu kwadidia, rau-ani kwadidia,  
\q1 egu tuari oreana badana,  
\q2 bogaragimui ai na siaia vasi oreana,  
\q1 ese e ani ore laḡanidia na  
\q2 lau ese ma baina henimui lou.   
\b  
\q1
\v 26 Bavani lava dae, bogamui bae kunu,  
\q2 Iehova, emui Dirava, ladana ba imodaia;  
\q2 ia ese hoa karadia vada e karalai henimui.  
\q1 Egu orea taudia na nega ta ai  
\q2 ma basie hahemaraidia lou.   
\q1
\v 27 Ba diba, lau na Israel bogaraginai,  
\q2 lau, Iehova, na emui Dirava,  
\q2 idauna ta na lasi.  
\q1 Egu orea taudia na nega ta ai  
\q2 ma basie hahemaraidia lou.   
\b  
\q1
\v 28 Nega gabena ai ina na baine vara:  
\q2 lau laumagu baina seia dobi taunimanima iboudiai latadiai;  
\q1 bena natumui mamaruanedia bona hahinedia do bae peroveta;  
\q2 emui iahu bae nihi,  
\q2 bona emui eregabe bae mata hanai.   
\q1
\v 29 Unu dinadia ai hesiai taudia bona hesiai hahinedia latadiai danu laumagu do baina seia dobi.   
\b  
\p
\v 30 Toa ḡaudia danu baina hahedinaraidia, guba ai bona tanobada ai, rara bona lahi bona kwalahu tubu-daena.  
\v 31 Dina do baine dibura, hua na rara ai bainela, Iehova ena dina badana mai garina ida do basine kau ai.  
\v 32 Bena Iehova ladana bae hahanea taudia iboudiai na bae mauri, badina be Siona ororona ai bona Ierusalem ai haida na bae roho mauri, Iehova ena hereva heḡereḡerena; bona unu roho-mauri taudia bogaragidiai Iehova ese e vavedia taudia danu bae noho.   
\c 3  
\s1 Iehova ena hahemaoro bese idau-idau latadiai  
\p
\v 1 A itaia, Iuda bona Ierusalem baina hanamodia lou negana ai, unu dinadia ai bona una negana ai  
\v 2 lau ese bese iboudiai baina haboudia, Iehosafat ena koura lalonai baina hakaudia diho. Unuseni ai lau ese baina hahemaoro henidia, egu bese taudia daidiai, bona dihigu Israel dainai; badina be idia na vada e karoho rohoroho bese idau-idau bogaragidiai, bona egu tano vada e haria;  
\v 3 mari vada e kara, egu bese taudia iabidia; mero ta vada e heni, ariara hahinena davana; bona kekeni ta vada e hoia, vine ranuna davana, bena una vine ranuna vada e inua.   
\p
\v 4 Turo bona Sidono bona Filistia kahadia iboudiai, umui be dahaka lauegu ai? Egu kara ta davana egu ai o halouamu a? Bema dava ta o halouamu, lau ese emui kara davana na kwaramui ai ma baina haloua haraga-haraga.  
\v 5 Badina be umui ese egu \it silver\it* bona egu \it gold\it* vada o abi, bona egu kohu namo-hereadia na emui dubu lalodiai vada o huadia vareai.  
\v 6 Iuda bona Ierusalem taudia vada o hoidia, Helene taudia ediai; edia tano amo vada o abidia oho dauhai.  
\v 7 A harihari lau ese o ha hoidia gabudia lalodiai baina haraiva-raivadia, bona emui kara davana na kwaramui ai baina haloudia.  
\v 8 Natumui mamaruanedia bona hahinedia na lau ese baina hoidia Iuda garana imadia ai; bena idia ese Sabea taudia ediai ma bae ha hoidia, dauhai e nohomu besena taudia ediai; badula be Iehova vada e hereva.   
\q1
\v 9 Bese idau-idau bogaragidiai ini ba gwau toma:  
\q2 Tuari ba hegaegaelaia,  
\q2 goada taudia ba haraiva-raivadia.  
\q1 Tuari taudia iboudiai na bae raka kahi mai,  
\q2 bae dae baema.   
\q1
\v 10 Emui ruarua auridia na dare ba karalai,  
\q2 bona emui ilapa na io ba karalai;  
\q2 bena manoka tauna baineto “Lau na tuari taugu”.   
\b  
\q1
\v 11 Aoma haraga-haraga,  
\q2 heḡeḡe-madai besedia iboumui ai;  
\q2 unuseIli ai ba hahebou.  
\q1 Iehova e,  
\q2 emu tuari taudia ba hakaudia diho.   
\q1
\v 12 Bese idau-idau bae tore tore isi,  
\q2 bae dara dae, Iehosafat ena koura baema;  
\q1 badina be unuseni ai baina helai,  
\q2 heḡeḡe-madai besedia iboudiai baina hahemaoro henidia.   
\b  
\q1
\v 13 Ba lapa lapa,  
\q2 badina be uit iutuna negana vada e kau.  
\q1 A raka vareai, ba moi tao moi tao;  
\q2 badina be vine itaolaina gabuna vada eme honu.  
\q1 Uro anidia e hepurai dobimu,  
\q2 badina be edia dika na bada herea.   
\b  
\q1
\v 14 Hutuma, hutuma herea,  
\q2 lalo-davari kourana ai!  
\q1 Badina be Iehova ena dina vada eme kahira-kahira,  
\q2 lalo-davari kourana ai!   
\q1
\v 15 Dina bona hua na e diburamu,  
\q2 bona hisiu na asie nakamu.   
\s1 Iuda ihamaurina  
\q1
\v 16 Iehova na Siona amo e lolomu,  
\q2 Ierusalem amo e herevamu,  
\q2 bena guba bona tanobada e heude-heudemu.  
\q1 A Iehova na ena bese taudia edia roho-mauri gabuna,  
\q2 Israel taudia edia gabu aukana.   
\b  
\q1
\v 17 Taunabunai umui ba diba lau na Iehova, emui Dirava;  
\q2 Siona ai, egu ororo helaḡana ai, na nohomu.  
\q1 Ierusalem do baine helaga,  
\q2 bona idau taudia ese basie rakaia hanai lou.   
\b  
\q1
\v 18 Una dina ai  
\q2 vine ranuna gaihona na ororo amo baine hetuturu dobi,  
\q1 bona ororo komutadia ai rata baine aru,  
\q2 bona Iuda koupadia iboudiai lalodiai ranu baine aru;  
\q1 Iehova ena dubu amo ranu baine lohilohia,  
\q2 Sitim kourana baine haranua.   
\b  
\q1
\v 19 Aigupto baine vahu,  
\q2 bona Edom baine ḡaḡae vaitani,  
\q2 Iuda taudia na e daḡedaḡe henidia dainai;  
\q1 badina be asi edia kerere taudia raradia na  
\q2 edia tano ai e hahebubu.   
\q1
\v 20 A Iuda na bae noholaia hanaihanai,  
\q2 bona Ierusalem danu ela bona uru iboudiai.   
\q1
\v 21 Raradia davadia baina abi,  
\q2 bona kerere taudia na maorodia basina gwaurai;  
\q2 badina be Iehova na Siona ai e nohomu.   