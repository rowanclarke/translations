\id EXO - Mbembe Okohm [MFNOk] 
\h Nnwẹr kw'Orenga 
\toc1 Nnwẹr kw'Orenga 
\toc2 Nnwẹr kw'Orenga 
\mt1 Nnwẹr kw'Orenga 
\c 1  
\s1 Che pa va pa Jekọb kw'obiro okpena Israẹl 
\p  
\v 1 Ma wọ ode che pa va p'ijinọng p'Israẹl, kw'obiro okpena Jekọb, p'iwa achin k'Ijip, ọnọng-ọnọng ttara ẹhọhmmọr chẹ biphyir.  
\v 2 Wa bẹ ade: Reubẹn, ọmaana Simeọn, ọmaana Lẹvi, ọmaana Juda,  
\v 3 ọmaana Isaaka, ọmaana Zẹbulun, ọmaana Bẹnjamin,  
\v 4 ọmaana Dan, ọmaana Naphtali, ọmaana Gad, ttara Ashẹr.  
\v 5 Josẹph kẹ wa okkekkeni oruk k'Ijip. Biphyir-phyir wa efonamma cha Jekọb ede, anọng arọbh attaan obhiri jobh p'iwa otzim ochina k'Ijip. 
\p  
\v 6 Wa Josẹph ọmaana efonamma chẹ biphyir, ọmaana ọgbọ nwa biphyir ape.  
\v 7 Yina, efonamma cha Jekọb ẹn-ẹbhakhi ebhon ayok maa, ch'ẹhaabh, ebire ekwu ẹbar, ẹnyaami maa, efu irek nnuma. 
\s1 Phero ọnang anọng p'Israẹl ihem 
\p  
\v 8 Wa ọvaarnọng ọbhakwẹ kw'oni Josẹph orong on-okwu ọdabh Ijip.  
\v 9 Wa obeni anọng pẹ bi, “Bọng kker o! Anọng mba p'Israẹl akk'ahaabha kpọng, abira akhaama ẹfa ayọhnga man.  
\v 10 Bọng kwu motzima ekkoji ọkwọbha bẹ ọhaabh mva, oni mando ode, egbong etto ma, bẹ attara attattaanga-nọng paman arima man abẹ, ifha bẹ arọbh aji irek nna.” 
\p  
\v 11 Mẹ wọ e, anọng p'Ijip arọbha akker-atzọhmnọng p'afon Ijip, bẹ anang ebhonmọr ch'Israẹl ọtzọhm f'ihem bi, bẹ asi. Anọng p'Israẹl asi ideden-mon sa Pitọm, ọmaana Rameses mach'ọkhaanga-họhm anang Phero.  
\v 12 Yina, odem nwa kw'anọng p'Ijip ado anọng p'Israẹl ihem anang, mando kw'anọng p'Israẹl areng ahaabh, abira ado anyaami maa, ojora ọnwa anọng p'Ijip.  
\v 13 Anọng p'Ijip an-anang anọng p'Israẹl ọtzọhm k'ihem s'ideden.  
\v 14 Bẹ an-asi akpen abenga anọng p'Israẹl, okhuri ọtzọhm gaang-angaang f'idọdọhbh ọbhabhakhi ọmaana f'atza ọbabanga, ttara owoni-tzọhm kpenamkpen. Chibhi da anọng p'Israẹl asi itzọhm gaang-agaang anang bẹ, anọng p'Ijip nkwu-osisi kakhaam ttara bẹ. 
\p  
\v 15 Mẹ wọ, ọvaarnọng kw'Ijip oben panọng p'am-akkeri aHiburu-panọng ọmaan p'akpen Shiphra, ọmaana Pua bi,  
\v 16 “Mada bọng am-akkeri aHiburu-panọng ọmaan, bọng dọkha ogbe akkeri k'ọmaanpa, idikha nnwa ode ojinọng, bọng fhẹ-ẹ. Yina, idikha ode kwanọng, tte kẹ oruk akpen.”  
\v 17 Yina, da panọng p'am-akker-anọng ọmaan akhaam ojora f'Ibinọkpaabyi, bẹ ndọhna s'ọvaarnọng kw'Ijip ọnangi bẹ kahokhi. Bẹ atte va p'ijinọng ọbọhk, aruk akpen.  
\v 18 Mẹ wọ, ọvaarnọng kw'Ijip oyeri akkeri-panọng-ọmaan mba, ọbọbh bẹ bi, “Okhuri yan kwa bọng asi odik dema nwa? Mbọng vọ osi bọng atte va p'ijinọng ọbọhk bẹ aruk akpen?” 
\p  
\v 19 Akkeri-panọng-ọmaan mba abhina Phero bi, “AHiburu-panọng macha panọng p'Ijip kade. Bẹ akhaam ettem ch'ọmaan. Bẹ am-amaan k'ọmọmmọm, yina akkeri-panọng-ọmaan an-apyiri.”  
\v 20 Mẹ wọ, Ibinọpkaabyi on-osi ọphyaam ọnang akkeri-panọng-ọmaan mba, anọng p'Israẹl achina ororo ahaabh, bẹ abira akhaama ẹfa.  
\v 21 Ibinọkpaabyi ọn-ọnang akkeri-panọng-ọmaan mba nhọhmmọr sabẹ ọkhaam, okhuri da bẹ akhaam ojora f'Ibinọkpaabyi. 
\p  
\v 22 Mẹ wọ e, Phero ọnang anọng pẹ biphyir ẹfa bi, “Bọng dọkha nnwa kw'ijinọng kpenamkpen kw'oHiburu-kwanọng ọ́maan, abhari k'ọraanga kwa Nile, yina, bọng tte nnwa kw'ikwanọng ọbọhk oruk akpen.” 
\c 2  
\s1 Ẹmmaana cha Mosẹs 
\p  
\v 1 Wa ojinọng wani kw'efona cha Lẹvi, ọtza ọtzọkha kwanọng kw'efona cha Lẹvi k'ọbada.  
\v 2 Wa kwanọng nwa otzima ibhọr, ọmaan ojinọng. Mada ore bi, nnwa nwa ojibh-ojibh, odubh-ẹ k'aphe attaan.  
\v 3 Mada ọnẹ-ẹ dọk ofha odubha, ọtzọkha nnwa nwa okhe k'ikhiriba s'otzim ettimma osi. Otzima ẹbaanttim ọkpa aphaangi p'ikhiriba nna. Ọtzọkha ikhiriba nna, ttara nnwa k'ẹtzaanga, ọnana k'araraari p'ameni k'asi, p'awobh k'ẹraangakha ch'ọraanga kwa Nile.  
\v 4 Ọgbaanọkka kw'ikwanọng kwa nnwa nwa ọtza ọpaangi obe, ifha ore ọttọhk f'osi nnwa nwa. 
\p  
\v 5 Wa nnwa kwa Phero kw'ikwanọng otzima aminava p'ade atzọhmnọng pẹ ọtza bi, otza ogbobha asi k'ọraanga kwa Nile. Mada aminava mba am-arenga m'ẹraangakha, nnwa kwa Phero on-ore ikhiriba k'ottem kw'araraari p'ameni k'ẹraangakha, ọtzọhm ọtzọhmnọng wani kwẹ bi, ọtza ọtzọkha sẹ otzima okwu.  
\v 6 Mada ogwong sẹ, ore nnwa k'ẹtzaanga kw'om-obhom ẹmọng. Ọkhaama nkwu-osisi ọmaan-ẹ. Oben bi, “Nnwa nwa ofha ode oHiburu-nwa wani.” 
\p  
\v 7 Mẹ wọ, ọgbaanọkka kwa nnwa nwa ọbọbh nnwa kwa Phero kw'ikwanọng bi, “Na mfha nda nyeri oHiburu-kwanọng wani, kw'ọfha ọrọk nnwa nwa ọnang-ọ o?” 
\p  
\v 8 Nnwa kwa Phero oben ọgbaanọkka kwa nnwa nwa bi, “Ojibhi kẹ, rọhng!” Mẹ wọ, otza otzima ọkka kwa nnwa nwa okwu.  
\v 9 Nnwa kwa Phero oben ọkka kwa nnwa nwa bi, “Kọ tzọkha nnwa nwa arọk anang-m. Kaam ńnang-ọ agbukha k'ọtzọhm fọ.” Mẹ wọ, ọkka kwa nnwa nwa ọtzọkh-ẹ ọrọk.  
\v 10 K'ogbe kwa nnwa nwa ọkk'ọn-ọbara, ọtzọkh-ẹ ochena nnwa kwa Phero kw'on-ode ọkka kwa nnwa nwa. Ọkpẹ-ẹ Mosẹs\f + \fr 2.10 \ft K'eHiburu, che cha Mosẹs ekheri ọwọnhg kwa “ẹtzọra atzima ayin k'iyaan.”\f*, oben bi, “Nwong nnwa nwa k'asi.” 
\s1 Mosẹs ọrọbh ochina Midiyan 
\p  
\v 11 Iwa ewu dani, k'ogbe kw'iwa Mosẹs ọkk'ọn-ọbara, wa ofon otza odibh anọng pẹ p'Israẹl. Ore ọtzọhm gaang-agaang f'ihem f'anọng pẹ am-asi, obiro ore da ojinọng wani kw'ofon Ijip om-ottum oHiburu-jinọng, kw'ode obhon-nọng kwa kẹ Mosẹs.  
\v 12 Mada Mosẹs ọbhakhi okkeri, ọnọng kore, ofhu ojinọng nwa kw'ofon Ijip, ọtzọkha obukhi kwẹ ọnọhnga k'oyeyeng.  
\v 13 K'ewu ch'ejem mẹ, Mosẹs on-oyin k'iyaan, otza ore aHiburu-jinọng afa p'am-arima erima, ọbọbh oyok kw'aponga apyibhi bi, “Areng mbọng afẹ am-attum oyokh-oyok o?” 
\p  
\v 14 Ojinọng nwa obhin-ẹ bi, “Anyi wọ ọsọ-ọ oho ọmaana ọttọhn-aponga kwaman o? Am-asi achibhi bi abira afhu-m mach'afhu oJipnọng o?” Mẹ wọ, ojora ọnwa Mosẹs, on-ochibhi bi, “K'odik-ọkka odik nwa ọkk'ọjaakh e.” 
\p  
\v 15 Mada Phero ọbhaang odik nwa, oror nden s'otzima ofhu Mosẹs. Ofona mẹ, Mosẹs ọrọbh ka Phero k'itzitzikha otza oruk ka Midiyan, otza owobha ẹwọr ọbaanga esipe dani.  
\v 16 Wa ọkhaam ọfọhnẹja wani kwa Midiyan, kw'iwa ọkhaam va p'ipanọng azenamfa. Ewu dani, aminava mba azenamfa akwu akhaabha asi k'esipe akhe k'ọgbaakha, ifha bẹ anang etzirakpo py'otte kwabẹ.  
\v 17 Yina, akker-arukhimaan bani akwu akhubh aminava mba, mẹ wọ, Mosẹs obina \it bi bik\it* ọtza ọkkaana bẹ, ọnang etzirakpo pyabẹ asi. 
\p  
\v 18 Mada aminava mba abhan, otte kwabẹ kw'okpen Reuẹl ọbọbh bẹ bi, “Kaambi bọng akk'ẹbhar-ẹbhar akhuna. Ode yan mayina?” 
\p  
\v 19 Bẹ abhin-ẹ bi, “Ọnọng wani kw'ofon Ijip wọ ọkkaan man ka mbọhk s'akker-arukhimaan, obiro ọkkaana ọnang etzirakpo pyaman asi.” 
\p  
\v 20 Reuẹl ọbọbh aminava pẹ bi, “Bọng asi yan afona ajẹ ẹ? Bọng nọhng atza ayer-ẹ okwu ochi ọttọhk.” 
\p  
\v 21 Mẹ wọ, Mosẹs okhera bi, okwu oruk k'ọhọhm kwa Reuẹl. Wa Reuẹl okwu ọtzọkha ominanwa wani kwẹ kw'okpen Zipọra, ọnang Mosẹs k'ọbada.  
\v 22 Zipọra ọmaan Mosẹs nnwa kw'ijinọng, Mosẹs ọkpẹ-ẹ Gẹrshọm, oben bi, “Kaam nkk'okhekhen-nọng nna nda m'okhekhen-mon nwa.” 
\s1 Ibinọkpaabyi ọbhaang ẹmọng ch'anọng p'Israẹl 
\p  
\v 23 M'ogbe-bhirada nwuma, ọvaarnọng kw'Ijip okwu ope. Anọng p'Israẹl abhom ẹmọng ch'ẹkkaana anang Ibinọkpaabyi, okhuri ebira cha bẹ awobh k'Ijip. Ọvaar Ibinọkpaabyi ọbhaanga ẹmọng chabẹ, cha bẹ abhomi k'ihem.  
\v 24 Wa Ibinọkpaabyi ọbhaanga ẹmọng chabẹ, obiro ojima echekhi ch'ọkhaam ttara Abraham mọgbakha Isaak, ọmaana Jekọb.  
\v 25 Wa Ibinọkpaabyi ore bi, anọng p'Israẹl awobh k'ihem, on-obiro ọkpakh-ẹ bi, ọkkaana bẹ. 
\c 3  
\s1 Ibinọkpaabyi oyeri Mosẹs 
\p  
\v 1 Wa ewu dani, Mosẹs om-okkeri arukhimaan p'otte kwa kwanọng kwẹ kw'okpen Jẹtro. Jẹtro wa ode ọfọhnẹja k'ẹkhọma cha Midiyan. Mosẹs otzima arukhimaan mba eden orenga m'ibe s'anọng an-arukhi maa, okwu opyiri k'egbegbeho cha Horẹb ch'ede egbegbeho ch'Ibinọkpaabyi.  
\v 2 Mẹ wọ kw'orenga-eden kw'Ọvaar Ibinọkpaabyi oreng k'akpondaak p'awọm k'echi, oyin Mosẹs abẹ. Wa Mosẹs odo okkeri ore bi chibhi da ekpon ẹm-ẹwọm, echi nda kẹkwọmi.  
\v 3 Mosẹs oben k'ettem chẹ bi, “Kaam ngaambi nnenga mbaanga kẹ, ifha nne ọttọhk f'osi yina ekpon ẹm-ẹwọma m'echi nda, yina, chẹ kẹkwọmi.” 
\p  
\v 4 Mada Ọvaar Ibinọkpaabyi on-ore bi Mosẹs okk'orenga ọbaanga kẹ, on-oyer-ẹ k'ottem kw'echi nda bi, “Mosẹs! Mosẹs!” 
\p Mosẹs oben bi, “Itta, kkeri kaam ma e.” 
\p  
\v 5 Ibinọkpaabyi oben-ẹ bi, “Kọ dọk kàrenga abaanga ka, wọra ekpo pya mmo pyọ, kkeri ibe nna s'abe mẹ ide irerek s'awurada.”  
\v 6 Obiro oben-ẹ bi, “Kaam wọ nde Ibinọkpaabyi kw'abatte Abraham, ọmaana kw'Isaak, ttara kwa Jekọb.” Mẹ wọ, Mosẹs on-ochubha itzitzikha sẹ, okhuri ojora f'on-orori bi, ore Ibinọkpaabyi. 
\p  
\v 7 Mẹ wọ, Ọvaar Ibinọkpaabyi oben bi, “K'odik ọkkakka, kaam nkk'ọmmamma kw'anọng paam awobh k'Ijip nna e. Kaam nkk'ẹmọng ch'ẹkkaana mmaanga, cha bẹ abhomi, okhuri ihem s'akker-atzọhmnọng am-anang bẹ. Kaam nnong ihem sabẹ am-are kẹ.  
\v 8 Mẹ wọ, nkk'nkwa bi, nkwu nkkaana, nnọbha bẹ ka mbọhk s'anọng p'Ijip, mbiri nnọbha bẹ m'irek nnuma, ndima bẹ nchina k'irerek s'ijibh-ojibh ibiri iwoni-owoni. Irerek ọkkakka s'abasi ọmaana akhọkhọnana ahaabh-ọhaabh, obhon kw'abaKenaan, ọmaana abaHet, ọmaana ab'Amọr, ọmaana abaPẹriz, ọmaana abaHiv, ttara abaJẹbus.  
\v 9 K'odik ọkkakka, kaam nkk'ẹmọng ch'anọng p'Israẹl abhomi mmaanga e, kaam nkk'ihem-dem s'anọng p'Ijip am-anang bẹ mbiri nna e.  
\v 10 Mẹ wọ, kọ rọhng, kaam nna ndọhm-ọ ka Phero bi, atza atzima anọng paam p'Israẹl abina k'Ijip.” 
\p  
\v 11 Yina, Mosẹs oben Ibinọkpaabyi bi, “Kaam nde macha bọng ọnọng bi, nyin Phero k'itzitzikha, mbiri ndima anọng p'Israẹl bẹ abina k'Ijip o?” 
\p  
\v 12 Ibinọkpaabyi on-oben bi, “Kaam ńwobha ttar-ọ. Ma wọ óde ẹkhọhkha ọnang-ọ bi, kaam wọ ndọhm-ọ. Akk'anọng p'Israẹl atzima abina k'Ijip, bọng án-akpobha Ibinọkpaabyi m'egbegbekho nda.” 
\p  
\v 13 Mẹ wọ, Mosẹs oben Ibinọkpaabyi bi “Idikha kaam nna nda k'anọng p'Israẹl, mgbaak bẹ bi, ‘Ibinọkpaabyi kw'abatte wọ ọtzọhm-m ka bọng e,’ bẹ an-abọbh-m bi, ‘Ibinọkpaabyi nwa okpen yan?’ Kaam mgbaak bẹ yan o?” 
\p  
\v 14 Ibinọkpaabyi on-oben Mosẹs bi, “KAAM WỌ NDE NWUMA KWA NDE. Kọ gbaak anọng p'Israẹl bi: ‘KAAM WỌ NDE wọ ọtzọhm-m ka bọng.’ ” 
\p  
\v 15 Ibinọkpaabyi obiro oben Mosẹs bi, “Kọ gbaak anọng p'Israẹl bi, Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kw'abatte Abraham, ọmaana Isaak, ọmaana Jekọb akpobh, wọ ọtzọhm-m ka bọng. Ma wọ ode che chaam, che ch'igbọ biphyir k'ororo iyer-m maa ogbe ode. 
\p  
\v 16 “Kọ rọhng atza atzobha adeho p'Israẹl, aben bẹ bi, ‘Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kw'abatte Abraham, ọmaana kw'Isaak, ttara Jekọb akpobh, oyin-m abẹ oben bi, kaam nkk'ogbe ndọkha nkkeri, nne odem kwa bẹ asi bọng k'Ijip.  
\v 17 Kaam nkk'nchekhi bi, ńnọbha bọng k'ihem s'Ijip, ndima bọng nchina k'irerek ọkkakka s'abasi ọmaana akhọkhọnana ahaabh-ọhaabh s'abaKenaan, ọmaana abaHet, ọmaana abAmọr, ọmaana abaPẹriz, ọmaana abaHiv, ttara abaJẹbus.’ 
\p  
\v 18 “Adeho mba p'Israẹl ayong-ọ itzọhng oyonga. Mẹ wọ, kọ ọmaana adeho p'Israẹl akhaambi achina k'ọvaarnọng kw'Ijip atza aben-ẹ bi, Ọvaar Ibinọpkaabyi, kw'ode Ibinọpkaabyi kw'abaHiburu okk'man abẹ ottema. Mẹ wọ, tte man ọbọhk mosi orenga kw'iwu ittaan mochina k'ibe s'anọng an-arukhi, ifha mosi njafọhni ọnang Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kwaman.  
\v 19 Yina, kaam nnong kẹ bi, ọvaarnọng kw'Ijip bọng ọbọhk kótte bọng afona, kw'oyongi bi ẹfa ch'ideden ẹkwẹ-ẹ.  
\v 20 Mẹ wọ, kaam ńdima ẹfa chaam nnang anọng p'Ijip ettuma, kaam ńsi idik kpenamkpen s'ipe anọng for k'ottem kwabẹ. K'ekponga-nnam, kẹ otte bọng ọbọhk otte, bọng afona. 
\p  
\v 21 “Kaam mbiri ńsi anọng p'Ijip asi ọphyaam anang bọng, ifha mada bọng ábina orenga, bọng aningi mbọhk-mbọhk afon.  
\v 22 Kwanọng kpenamkpen ochina k'ojip-kwanọng kw'orukhi ọbaang-ẹ, ọmaana k'ojip-kwanọng kw'orukhi k'ọhọhm kwẹ, ọ́bọbh-ẹ agimma pa gol, ọmaana p'asilva, ttara ọbara fa for fa bọng áfhọra va pa bọng p'ijinọng ọmaana p'ipanọng. M'eden nda dọ cha bọng arenga achi anọng p'Ijip ọgbọm.” 
\c 4  
\s1 Ngọhkha s'Ibinọkpaabyi ọnangi Mosẹs 
\p  
\v 1 Mẹ wọ, Mosẹs obhina bi, “Kaam ńsi yan, idikha bẹ ani kaam k'odik-ọkka atzọk, bẹ itzọhng kabira ayonga anang-m, bẹ an-aben bi, Ọvaar Ibinọkpaabyi kọ abẹ koyini khi?” 
\p  
\v 2 Mẹ wọ, Ọvaar Ibinọkpaabyi ọbọbh-ẹ bi, “Mbọng vọ fa kọ atzim k'ọbọhk kwọ o?” 
\p Mosẹs obhina bi, “Ochikhura e.” 
\p  
\v 3 Ọvaar Ibinọkpaabyi oben-ẹ bi, “Kọ bhari ochikhura nwuma k'irerek.” 
\p Mosẹs ọbhari chẹ k'irek, ochikhura nwa oreng jọhk, Mosẹs ọrọbh oji chẹ.  
\v 4 Mẹ wọ, Ọvaar Ibinọkpaabyi oben-ẹ bi, “Nemi ọbọhk kwọ abọkha jọhk nda k'ẹsara.” Mẹ wọ, Mosẹs onemi ọbọhk ọbọkha jọhk nda k'ẹsara, jọhk en-ebiri ẹbhakhi ochikhura k'ọbọhk kwẹ.  
\v 5 Ọvaar Ibinọkpaabyi oben bi, “Si mando, ifha bẹ akhera bi, Ọvaar Ibinọkpaabyi kw'abatte Abraham, ọmaana Isaak, ttara Jekọb akpobh, ọkk'ọ abẹ oyina.” 
\p  
\v 6 Mẹ wọ e, Ọvaar Ibinọkpaabyi obiro oben bi, “Kọ khe ọbọhk kwọ k'ọphaangi kw'ittemmọma kw'ọnọhma-baba kwọ ẹtzaanga.” Mosẹs osi mando. Mada ọn-ọrọbh ọbọhk, ọbọhk on-ode okkim-okkima kw'owuri \it bi gwaang\it*.  
\v 7 “Kọ biri kpa nnam akhe ọbọhk kwọ k'ọphaangi kw'ittemmọma kw'ọnọhma-baba kwọ ẹtzaanga.” Mosẹs osi mando. Mada ọn-ọrọbh ọbọhk, ọbọhk on-obiro ọkpa nnam ode mach'ira okkekkeni ode. 
\p  
\v 8 Mẹ wọ, Ọvaar Ibinọkpaabyi oben bi, “Idikha anọng ani kọ itzọhng ayong, bẹ k'echeden-kọhkha kabira akhera, bẹ afha akhera k'ẹkhọhkha ch'ettong mfa.  
\v 9 Yina, idikha bẹ ani kọ itzọhng akher ayonga, bẹ ka ngọhkha nna mfa kabira akhera, kọ rọhng atza akhaabha asi k'ọraanga kwa Nile, akwu abyengi k'ogbin. Asi mba p'akhaabha k'ọraanga án-areng izi m'irerek.” 
\p  
\v 10 Mosẹs oben Ọvaar Ibinọkpaabyi bi, “O Ọvaar Ibinọkpaabyi, akk'aronga bi, ttẹwọr k'ittẹwọr maa, apyiri mada am-agbaak ọtzọhmnọng kwọ atzim mba ma, kaam mgbagbaakha kimkpo. Kaam mgbagbaakha igaang-m ọgaangi, mbiri nyek atzim.” 
\p  
\v 11 Ọvaar Ibinọkpaabyi on-oben-ẹ bi, “Anyi wọ ọnangi ọnọngẹya ẹmma ch'otzim ọgbaak atzim o? Anyi wọ osi ọnọngẹya ọkpa itzọhng ttara ẹmma? Anyi wọ osi ọnọngẹya ore iyaan, obiro ọsẹ-ẹ ọkpa chen o? Kaam Ọvaar Ibinọkpaabyi arang na a?  
\v 12 Mẹ wọ, kọ rọhng, kaam ńdaakh-ọ atzim ọtzaakhi, mbiri ḿkpebh-ọ atzim okpebhi p'agbaak.” 
\p  
\v 13 Yina, Mosẹs oben bi, “O Ọvaar Ibinọkpaabyi, tte mphyem-ọ bi, ira atzọhm ọnọng ọdọdọk.” 
\p  
\v 14 Mẹ wọ, ettem ebhem Ọvaar Ibinọkpaabyi, on-oben Mosẹs bi, “Agbaanakka Aarọn kw'ofon k'ẹnọmma cha Lẹvi owobh mẹ. Kaam nnong-ẹ bi ode ọnọng kw'okpo mgbagbaakha k'eden ọkkakka. Kẹ oreng k'eden okwuma bi okwu okhebh-ọ e, sa kẹ obiro owobha k'ottemdaamiji mada ọrọ-ọ.  
\v 15 Kọ gbaakh-ẹ atzim p'ọgbaak. Kaam ńdaakhi bọng anọng afa atzim ọtzaakhi, mbiri mbgaak bọng odem kwa bọng akhaambi asi.  
\v 16 Aarọn wọ ọ́gbaak anọng mba atzim k'eho chọ. Kẹ wọ óde mach'igbaakhi sọ, kọ abira ade mach'Ibinọkpaabyi anaang-ẹ.  
\v 17 Yina, kọ tzọkha ochikhura kwọ atzima k'ọbọhk, ifha kọ afha atzima chẹ asi ngọhkha s'ipe anọng for.” 
\s1 Mosẹs ọkpa nnam k'Ijip 
\p  
\v 18 Mẹ wọ, Mosẹs ọkpa nnam ka Jẹtro kw'ode otte kwa kwanọng kwẹ, oben-ẹ bi, “Tte mkpa nnam k'anọng paam k'Ijip, ifha nda nne s'ọnọng manda wani otzima orukhi kẹ.” 
\p Jẹtro oben bi, “Phyaa, do renga o.” 
\p  
\v 19 Wa Ọvaar Ibinọkpaabyi okk'Mosẹs obena ka Midiyan bi, “Kọ kpa nnam k'Ijip, kkeri anọng mba p'iwa abeni bi, afhọ-ọ, akk'apa e.”  
\v 20 Mando kwa Mosẹs ọtzọk kwanọng kwẹ, ọmaana va pẹ p'ijinọng ọnana bẹ k'ẹnyanyaang, obiro ọtzọkha ochikhura kw'Ibinọkpaabyi oben-ẹ bi, otzima k'ọbọhk, obina orenga ọkpa nnam k'Ijip. 
\p  
\v 21 Ọvaar Ibinọkpaabyi oben Mosẹs bi, “Mada akpa nnam k'Ijip, kọ akhaambi ado for bi, asi ikkokkoni-dik nna biphyir sa nkk'ọ ẹfa nnanga bi, asi k'itzitzikha sa Phero. Yina, kaam ńsi Phero ọbar ettem, oningi anọng mba ọbọhk otte bẹ afona.  
\v 22 Mẹ wọ, ben Phero bi, ‘Ọvaar Ibinọkpaabyi obeni bi, Israẹl wọ ode ocheden-nwa kwaam kw'ijinọng.  
\v 23 Kaam mben-ọ bi, “Tte nnwa kwaam ọbọhk ofona otza okpobh-m.” Yina, kọ abhum bi attẹ-ẹ ọbọhk ofona. Mẹ wọ, kaam ḿfhu ocheden-nwa kwọ kw'ijinọng.’ ” 
\p  
\v 24 Wa Ọvaar Ibinọkpaabyi oyin Mosẹs abẹ k'ibe s'otzim anọng pẹ obhing, ọkham bi, ọfhẹ-ẹ.  
\v 25 Yina, Zipọra kw'ode kwanọng kwa Mosẹs ọtzọkha ọtza kw'ọjaabhi mach'imaana, osi nnwa kwẹ ọkpakkọrikkọ, ọtzọkha ẹkpakpa ch'ọkk'ọkpaara ọttọhmi Mosẹs ka mmokpatzọkhi, oben bi, “K'odik ọkkakka, oreng m'izi nna kọ an-ade odim kwaam.”  
\v 26 Mẹ wọ, Ọvaar Ibinọkpaabyi otte Mosẹs ọbọhk oruk akpen. M'ogbe nwa wọ kwa Zipora obeni bi, “Odim kwaam kw'oreng k'izi, okhuri ọkpakkọrikkọ.” 
\p  
\v 27 Wa Ọvaar Ibinọkpaabyi oben Aarọn bi, “Rọhng atza akhebha Mosẹs k'ibe s'anọng an-arukhi.” Mando kw'Aarọn ofon otza okhebha Mosẹs k'egbegbeho ch'Ibinọkpaabyi owobh, ọbaakh-ẹ.  
\v 28 Mẹ wọ, Mosẹs ọgbaak Aarọn odik kpenamkpen kw'Ọvaar Ibinọkpaabyi ọkk'ẹ ọgbaakha bi, ọgbaakh-ẹ. Wa obiro ọgbaakh-ẹ odik kpenamkpen kw'okhuri ngọhkha sa mpe ọnọng for s'Ọvaar Ibinọkpaabyi ọtzọhn-ẹ bi osi. 
\p  
\v 29 Wa Mosẹs ttara Aarọn atza ayeri adeden-nọng p'anọng p'Israẹl biphyir atzobha.  
\v 30 Wa Aarọn ọgbaak bẹ odik kpenamkpen kw'Ọvaar Ibinọkpaabyi okk'Mosẹs ọgbaakha, obiro osi ngọhkha nna k'itzitzikha s'anọng mba.  
\v 31 Wa anọng mba akhera. Mada anọng mba abhaang bi Ọvaar Ibinọkpaabyi okk'ihem-dema s'anọng p'Israẹl awobh ọra, ọmaana bi, om-ochibhi odik okhuri bẹ, bẹ achunga nho anang-ẹ ikpokpobha. 
\c 5  
\s1 Mosẹs ọmaana Aarọn atza akhebha Phero 
\p  
\v 1 Ayongi mẹ, Mosẹs ọmaana Aarọn atza akhebha Phero, aben bi, “Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kw'Israẹl, obeni bi, ‘Tte anọng paam ọbọhk afona, ifha bẹ atza asi ọdadaami kw'ikpokpobha k'ibe s'anọng an-arukhi, anang-m.’ ” 
\p  
\v 2 Mẹ wọ, Phero oben bi, “Anyi wọ ode Ọvaar Ibinọkpaabyi, kwa kaam nnọbh ka chen maa, ntte anọng p'Israẹl ọbọhk bẹ afona? Kaam Ọvaar Ibinọkpaabyi kinnong! Anọng p'Israẹl ọbọhk kíntte bẹ afona.” 
\p  
\v 3 Iwa Mosẹs ọmaana Aarọn, aben bi, “Ibinọkpaabyi kw'abaHiburu okk'man abẹ ottema. Mẹ wọ, tte mobina orenga kw'iwu ittaan mochina k'ibe s'anọng an-arukhi, ifha mọtza osi njafọhni ọnang Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kwaman. Oni mando ode, kẹ ọfha ọnang man ihem k'adem-k'adem, ayongi mẹ, ofha ofhu man ttara ọkkangkkaang.” 
\p  
\v 4 Yina, ọvaarnọng kw'Ijip ọn-ọbọbh Mosẹs ọmaana Aarọn bi, “Ode yan kwa bọng akwọbh anọng mba ọtzọhm fa bẹ am-asi o? Bọng kpa nnam k'itzọhm sabọng!”  
\v 5 Mẹ wọ, Phero oben bi, “Bọng kker e, anọng p'irek nna akk'an-ahaabha, yina, bọng am-akwọbha bẹ ọtzọhm osisi.” 
\p  
\v 6 M'ewu nduma dani, Phero ọnang akker-atzọhmnọng ọmaana akkeri-itzọhm ẹfa bi:  
\v 7 “Bọng anọng mba araraari-bukhi pa bẹ am-atzima abanga atza dọk kànang. Tte bẹ areng-mmo atza aror araraari-bukhi pa bẹ am-aztima abanga atza.  
\v 8 Yina, bọng si bẹ abanga ọtzabhik kwa bẹ am-akkekkeni abanga, bọng kàjekhi. Bẹ akpọhr-ọkpọhra e, kwẹ gwọ osi bẹ am-abhom bi, ‘Tte mofona, mọtza osi ẹjafọhni ọnang Ibinọkpaabyi kwaman.’  
\v 9 Bọng si ọtzọhm mva fẹ ọgaang-ọgaangi ọnang ajinọng mba, ifha bẹ am-asi ọtzọhm, bẹ aningi ogbe akhaam kwa bẹ ayonga itzọhng k'ibhora manda rani.” 
\p  
\v 10 Mẹ wọ, akker-atzọhmnọng ọmaana akkeri-itzọhm p'Israẹl, afona atza agbaak anọng mba bi, “Ma wọ ode odik kwa Phero ọgbaakhi: ‘Kaam bọng araraaribukhi pa bẹ am-atzima abanga atza dọk kinnang.  
\v 11 Bọng nọhng atza aror araraari-bukhi, pa bẹ am-atzima abanga atza k'ibe sa bọng aroror, yina, ọtzọhm fabọng kòjekhi mebubuni.’ ”  
\v 12 Mẹ wọ, anọng mba an-akpaanga makhọra Ijip, aror araraari-bukhi pa bẹ atzima abanga atza.  
\v 13 Akker-atzọhmnọng mba achina ororo anyuni bẹ k'ẹfa, aben bi, “Bọng kyera ọtzọhm fabọng f'ewu, macha bọng am-akkekkeni asi, k'ogbe kwa bẹ am-anang bọng araraari-bukhi.”  
\v 14 Akker-atzọhmnọng pa Phero otzek, abọkha akkeri-itzọhm p'Israẹl attum ngwur, abira abọbh bẹ bi, “Okhuri yan kw'ọtzabhik kwa bọng abang ikhena ttara mayina, oni obhik kwa bọng am-akkekkeni abanga opyir o?” 
\p  
\v 15 Mẹ wọ, akkem-itzọhm p'Israẹl afona atza abhom akpẹkhi Phero, aben-ẹ bi, “Itta, okhuri yan kwa kọ am-asi atzọhmnọng pọ manda o?  
\v 16 Bẹ atzọhmnọng pọ araraari-bukhi pa bẹ am-atzima abanga atza dọk kanangi. Yina, bẹ am-aben man bi, ‘Bọng banga atza!’ Bẹ am-attum atzọhmnọng pọ, kaambi ode bi ottotto ode kw'anọng pọ.” 
\p  
\v 17 Phero obhina bẹ bi, “Ọkpọra e, bọng akpọr-ọkpọra e! Kwẹ wọ osi bọng am-aben bi, ‘Tte mofona, motza osi ẹjafọhni ọnang Ọvaar Ibinọkpaabyi.’  
\v 18 Bọng kpa nnam k'ọtzọhm. Bẹ bọng araraari-bukhi pa bẹ am-atzima abanga atza kánang, yina, bọng akhaambi abanga ọtzabhik kwa bọng am-akkekkeni abanga.” 
\p  
\v 19 Akkeri-itzọhm p'Israẹl akwu atzin bi, odik wọ om-otto mẹ, da bẹ abeni bi, “Bọng ọtzabhik kwa bọng am-abanga kw'ewu kàkhaambi ajekhi.”  
\v 20 Mada bẹ abin ka Phero, bẹ are Mosẹs ọmaana Aarọn p'am-atzik bẹ,  
\v 21 bẹ aben bi, “Tte Ọvaar Ibinọkpaabyi kw'ore bọng, ọkpaara aponga pabọng! Bọng akk'asa mopyibh k'itzitzikha sa Phero, ọmaana akhaan-nọng pẹ, bọng abira khe bẹ ọkkangkkaang k'ọbọhk bi, bẹ afhu man.” 
\s1 Ibinọkpaabyi ochekhi bi, ọ́rọbha anọng p'Israẹl k'ebira 
\p  
\v 22 Mẹ wọ e, Mosẹs ọkpa nnam k'Ọvaar Ibinọkpaabyi, oben bi, “O Itta, okhuri yan kwa akhe anọng mba ka dama-dama o? Kwẹ wọ osi atzọhm-m o?  
\v 23 Tzọni k'ogbe kwa ndim che chọ nda mgbaak Phero atzim, ọkk'anọng mba ọkha ka dama-dama, kọ bẹ kabira akkaana mebubuni.” 
\c 6  
\p  
\v 1 Mẹ wọ, Ọvaar Ibinọkpaabyi oben Mosẹs bi, “Kọ án-are ọttọhk fa ńsi Phero, okhuri bi, ófona k'ẹfa chaam, kẹ ótte anọng paam ọbọhk, bẹ afona. Ófona k'ẹfa chaam, kẹ ọkhaam ma for sẹ ókhubh bẹ, k'ẹkhọma chẹ.” 
\p  
\v 2 Ibinọkpaabyi oben Mosẹs bi, “Kaam wọ nde Ọvaar Ibinọkpaabyi.  
\v 3 Wa kaam nyini Abraham, ọmaana Isaak, ttara Jekọb abẹ, mach'Ibinọkpaabyi kw'Ẹfa biphyir. Yina, kaam che chaam ch'ede Ọvaar Ibinọkpaabyi, kinjaakhi nnang bẹ.  
\v 4 Wa kaam mbiri nchekhi bi, nnang bẹ irerek sa Kenaan, nnuma s'iwa bẹ arukhi mach'akhekhennọng.  
\v 5 Kaam nkk'ẹmọng ch'anọng p'Israẹl abhomi k'ebira cha bẹ awobh k'Ijip mmaanga, kaam nkk'echekhi chaam mbiri njima. 
\p  
\v 6 “Mẹ wọ, gbaak anọng p'Israẹl bi, ‘Kaam wọ nde Ọvaar Ibinọkpaabyi. Kaam wọ ńnọbha bọng k'ọyak kw'ihem s'anọng p'Ijip. Kaam ḿbiri nnọbha bọng k'ebira cha bẹ akhe bọng. Kaam ndima ẹfa chaam mmek bọng, ḿbiri ndima chẹ ńsi aponga adaam bọng.  
\v 7 Kaam ńdọkha bọng mach'anọng paam, ḿbiri nde Ibinọkpaabyi kwabọng. Órenga mẹ, bọng áronga bi, kaam wọ nde Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kwabọng, kw'ọrọbh bọng k'ọyak kw'ihem s'anọng p'Ijip.  
\v 8 Kaam ḿbiri ndima bọng ma mpyiri k'irerek nnuma, s'iwa nchekhi ttara ọmmakkakkari bi, nnang Abraham, ọmaana Isaak, ttara Jekọb. Kaam ńnang bọng irerek nnuma bi, in-ide sabọng. Kaam wọ nde Ọvaar Ibinọkpaabyi.’ ” 
\p  
\v 9 Wa Mosẹs ọtzọkha idik nna ọgbaak anọng p'Israẹl, yina, bẹ kẹ itzọhng kayong, okhuri akpen p'akk'bẹ abenga ọmaana ihem barambar sa bẹ awobh. 
\p  
\v 10 Mẹ wọ, Ọvaar Ibinọkpaabyi oben Mosẹs bi,  
\v 11 “Rọhng atza agbaak Phero kw'ode ọvaarnọng kw'Ijip bi, tte otte anọng p'Israẹl ọbọhk bẹ abina aji ẹkhọma chẹ.” 
\p  
\v 12 Yina, Mosẹs ọbọbh Ọvaar Ibinọkpaabyi bi, “Idikha anọng p'Israẹl an-itzọhng ayong anang-m, Phero on-osi yan oyong-m itzọhng o, da kaam nyekhi atzim o?” 
\p  
\v 13 Wa Ọvaar Ibinọkpaabyi ọgbaak Mosẹs ọmaana Aarọn odik kw'okhuri anọng p'Israẹl ọmaana ọvaar Phero kw'Ijip, ọnang ẹfa bi, bẹ atzima anọng p'Israẹl abina aji Ijip. 
\s1 Efonamma cha Mosẹs ọmaana Aarọn 
\li1  
\v 14 Ma wọ ode aho pa mfona sabẹ: 
\li1 Va p'ijinọng pa Reubẹn, kw'ode ocheden-nwa kw'ijinọng kwa Israẹl ade: Hanọk, ọmaana Palu, ọmaana Hẹzrọn, ttara Karmi. Ma wọ iwa ode efona cha Reubẹn. 
\li1  
\v 15 Wa Simeọn obhoni va p'ijinọng pa ade: Jemuyẹl, ọmaana Jamin, ọmaana Ọhad, ọmaana Jakin, ọmaana Zoha, ttara Shaul, kw'ode nnwa kw'oKenaan-kwanọng ọmaani ọnang-ẹ, Ma wọ iwa ode efona cha Simeọn. 
\li1  
\v 16 Ma wọ ode che pa va p'ijinọng pa Lẹvi obhoni atzor ka ndori sabẹ; Gẹrshọn, ọmaana Kohat ttara Mẹrari. Biphyir-phyir wa Lẹvi orukhi cho arọbh azadani obhiri chi obhiri afa. 
\li1  
\v 17 Wa va p'ijinọng pa Gẹrshọn obhoni ka nnọmma sabẹ ade: Libni ttara Shimeyi. 
\li1  
\v 18 Wa va p'ijinọng pa Kohat obhoni ade: Amram, ọmaana Izha, ọmaana Hẹbrọn, ttara Uziyẹl. Biphyir-phyir wa Kohat orukhi cho arọbh azadani obhiri jobh obhiri attaan. 
\li1  
\v 19 Wa Mẹrari obhon va p'ijinọng p'ade: Mali ọmaana Mushi. 
\li1 Ma wọ ode nnọmma sa Lẹvi atzor ka ndori sabẹ. 
\li1  
\v 20 Wa Amram ọtzọk Jokẹbẹd kw'ode ọgbaanọkka kw'otte kwẹ, k'ọbada, kw'ọmaan-ẹ Aarọn ọmaana Mosẹs. Biphyir-phyir wa Amram orukhi cho arọbh azadani obhiri chi obhiri afa. 
\li1  
\v 21 Wa Izha obhon va p'ijinọng p'ade: Kọra ọmaana Nẹphẹg, ttara Zikiri. 
\li1  
\v 22 Wa Uziyẹl obhon va p'ijinọng p'ade: Mishayẹl, ọmaana Ẹlzaphan, ttara Sitri. 
\li1  
\v 23 Wa Aarọn ọtzọk Ẹlisheba kw'ode ominanwa kw'Aminadab k'ọbada, kw'obiro ode ọgbaanọkka kwa Nashọn, ọmaan-ẹ Nadab ọmaana Abihu, ọmaana Ẹleyaza, ttara Itamar. 
\li1  
\v 24 Va p'ijinọng pa Kọra ade Asir, ọmaana Ẹlkana, ttara Abiyasaph. Ma wọ iwa ode nnọmma sa Kọra. 
\li1  
\v 25 Wa Ẹleyaza kw'Aarọn obhoni ọtzọk ominanwa kwa Putiyẹl k'ọbada, ọmaan-ẹ Phinẹhas. 
\b  
\li1 Ma wọ iwa ode aho pa nhọhmmọr sa Lẹvi, k'ẹnọmma-k'ẹnọmma. 
\b  
\p  
\v 26 Aarọn nwa ttara Mosẹs bọ p'iwa Ọvaar Ibinọkpaabyi obeni bi, “Bọng dima anọng p'Israẹl abina aji Ijip, ka ngaan sabẹ.”  
\v 27 Bẹ anọng mba afa kw'ode Aarọn ọmaana Mosẹs bọ iwa agbaakhi ọvaar Phero kw'Ijip atzim, okhuri ebina ch'anọng p'Israẹl k'Ijip. 
\s1 Aarọn ọgbaakhi atzim k'eho cha Mosẹs 
\p  
\v 28 Mada Ọvaar Ibinọkpaabyi ọgbaakhi Mosẹs atzim k'Ijip,  
\v 29 oben Mosẹs bi, “Kaam wọ nde Ọvaar Ibinọkpaabyi. Gbaak ọvaar Phero kw'Ijip idik nna biphyir sa mgbaakh-ọ.” 
\p  
\v 30 Yina, Mosẹs oben Ọvaar Ibinọkpaabyi bi, “Mada kaam nde ọnọng kw'oyekhi atzim, Phero on-osi yan oyong-m itzọhng o?” 
\c 7  
\p  
\v 1 Mẹ wọ, Ọvaar Ibinọkpaabyi oben Mosẹs bi, “Kker e, kaam nkk'ọ nsa bi, ade mach'Ibinọkpaabyi k'itzitzikha sa Phero e, agbaanakka Aarọn wọ óde ọsẹjaakhi kwọ.  
\v 2 Kọ gbaak agbaanakka Aarọn odik kpenamkpen kwa kaam mgbaakh-ọ, ifha kẹ ọgbaak Phero otte anọng p'Israẹl ọbọhk, bẹ bina k'ẹkhọma chẹ.  
\v 3 Yina, kaam ńsi Phero ọbar ettem, chibhi da nsi ngọhkha haabhada, ọmaana idik s'ipe anọng for k'Ijip,  
\v 4 Phero kọ itzọhng kóyonga. Mẹ wọ, kaam nsi ijoradik k'Ijip, mbiri ndima ẹfa chaam nnang anọng p'Ijip ettuma ch'ideden, ńdima ngaan s'anọng paam p'Israẹl mbina k'Ijip.  
\v 5 Anọng p'Ijip áronga bi, kaam wọ nde Ọvaar Ibinọkpaabyi, k'ogbe kwa nsi ijoradik k'Ijip, mbiri ndima anọng p'Israẹl mbina.” 
\p  
\v 6 Mosẹs ọmaana Aarọn asi mach'Ọvaar Ibinọkpaabyi ọtzọhni bẹ.  
\v 7 Wa Mosẹs ode cho arọbh anna, Aarọn ode cho arọbh anna obhir attaan, mada bẹ agbaakhi Phero idik nna. 
\s1 Ochikhura kw'Aarọn orengi jọhk 
\p  
\v 8 Wa Ọvaar Ibinọkpaabyi oben Mosẹs ọmaana Aarọn bi,  
\v 9 “Idikha Phero obeni bọng bi, bọng si odik kw'ope ọnọng fọr, ben Aarọn bi, ‘Tzọkha ochikhura kwọ bhari m'irerek, m'itzitzikha sa Phero,’ ochikhura nwuma on-oreng jọhk.” 
\p  
\v 10 Mando kwa Mosẹs ọmaana Aarọn afona atza akhebha Phero, bẹ asi mach'Ọvaar Ibinọkpaabyi ọtzọhni bẹ. Aarọn ọtzọkha ochikhura kwẹ ọbhari k'irerek m'itzitzikha sa Phero ọmaana akhaan-nọng pẹ, ochikhura nwuma on-oreng jọhk.  
\v 11 Mẹ wọ, Phero oyeri ajinọng p'akhaam eronga ọmaana abọhnga-nọng, anọng p'am-asi mbọhng k'Ijip, bẹ akwu asi odem nwuma wani ttara mfhọna sabẹ.  
\v 12 Ọnọng-ọnọng ọbhari ochikhura kwẹ, achikhura mba an-areng jọhk. Yina, ochikhura kw'Aarọn on-omyi pabẹ biphyir.  
\v 13 Kaambi mẹ wọ, Phero odo ettem ọbar, itzọhng koyong ọnang bẹ, mach'Ọvaar Ibinọkpaabyi ọkk'ọgbaakha. 
\s1 Nkwuri s'izi 
\p  
\v 14 Iwa Ọvaar Ibinọkpaabyi oben Mosẹs bi, “Ettem cha Phero k'ebhon e, kẹ otzim obhum-obhum bi, otte anọng paam ọbọhk bẹ afona.  
\v 15 Rọhng atza akhebha Phero mada ọtza asi k'ekpebha. Kọ wobha m'ẹraangakha cha Nile atzikh-ẹ, atzima ochikhura nwuma kw'ira orengi jọhk atzima k'ọbọhk.  
\v 16 Mẹ wọ, gbaakh-ẹ bi, ‘Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kw'aHiburu, wọ ọtzọhm-m bi mgbaakh-ọ bi, atte anọng pẹ ọbọhk bẹ afona, ifha bẹ atza akpobh-ẹ k'ibe s'anọng an-arukhi. Yina, ma apyiri ma kakher bi, ayonga itzọhng.  
\v 17 Ma wọ ode odik kw'Ọvaar Ibinọkpaabyi obeni bi, on-ofona ma kọ aronga bi, kẹ wọ ode Ọvaar Ibinọkpaabyi: Kaam ndima ochikhura nwa kwa ndim m'ọbọhk mbun m'ọraanga kwa Nile, ọ́n-ọbhakhi ode izizi.  
\v 18 Nden sa nwobh ka Nile ḿpe, ọraanga kwa Nile ón-obiro ohom eruk maa, anọng p'Ijip asi pẹ dọk kafha agwo.’ ” 
\p  
\v 19 Mẹ wọ, Ọvaar Ibinọkpaabyi oben Mosẹs bi, “Ben Aarọn bi, tzima ochikhura nwuma kw'atzim k'ọbọhk kwọ atzena k'ọraanga kw'Ijip, ọmaana ka ngekha, ọmaana mmen, ọmaana ka nsipe, ttara k'asi pa bẹ aye-oye, ifha bẹ an-abhakhi ade izizi. Izi in-iwobha k'ibe kpenamkpen k'Ijip, kaambi k'agbere pa bẹ atzim nchi, ttara atza asi bọ.” 
\p  
\v 20 Mosẹs ọmaana Aarọn asi mach'Ọvaar Ibinọkpaabyi okk'bẹ ọtzọhna. M'itzitzikha sa Phero, ọmaana akhaan-nọng pẹ, Aarọn otzini ochikhura kwẹ obun m'ọraanga kwa Nile, asi biphyir an-ade izi-izi.  
\v 21 Nden s'ọraanga kwa Nile mpe, asi an-ahom eruk maa anọng p'Ijip asi pẹ dọk kafha agwo. Ijip biphyir on-ode izi-izi. 
\p  
\v 22 Yina, anọng p'am-asi mbọng k'Ijip asi idik nnuma rani ttara mfhọhna sabẹ. Mẹ wọ, Phero ochina ororo ọbar ettem, itzọhng kokher oyonga ọnang Mosẹs ọmaana Aarọn, mach'Ọvaar Ibinọkpaabyi ọkk'ọgbaakha.  
\v 23 Phero ọkpa nnam ochina k'ọvaar-dimpa kwẹ, idik nna k'ettem kokhe.  
\v 24 Mẹ wọ, anọng p'Ijip biphyir atza atzum ọkhaan-ọkhaan kw'ọraanga kwa Nile, ifha bẹ are asi pa bẹ afha agwo, okhuri da bẹ ani asi p'ọraanga nwa dọk afha agwo. 
\s1 Nkwuri s'awọribọhk 
\p  
\v 25 Wa iwu izenamfa ikwu ikwọbha, mada Ọvaar Ibinọkpaabyi ọbhakhi ọraanga kwa Nile ode izi-izi. 
\c 8  
\p  
\v 1 Mẹ wọ, Ọvaar Ibinọkpaabyi oben Mosẹs bi, “Rọhng atza gbaak Phero bi, ‘Kaam Ọvaar Ibinọkpaabyi mbeni bi, tte otte anọng paam ọbọhk bẹ afona ifha bẹ akwu akpobh-m.  
\v 2 Idikha obhumi bi, otte bẹ ọbọhk bẹ afona, kaam ndọhm awọribọhk k'ọhaabh makhọra ẹkhọma chẹ biphyir.  
\v 3 Ọraanga kwa Nile on-ofu ttara awọribọhk. Awọribọhk mba an-abira anyaami k'ọvaar-dimpa kwẹ maa, apyiri k'ẹmaanggọ chẹ ọmaana k'iyimabe sẹ, ttara k'ihọhm s'akhaan-nọng pẹ, ọmaana k'ihọhm s'anọng pẹ maa, apyiri k'ibe sa bẹ am-asi ọchattọhk fẹ.  
\v 4 Awọribọhk mba ágbe anan-ẹ, ọmaana anọng pẹ, ttara akhaan-nọng pẹ ka for.’ ” 
\p  
\v 5 Mẹ wọ, Ọvaar Ibinọkpaabyi oben Mosẹs bi, “Gbaak Aarọn bi, onemi ọbọhk kwẹ ttara ochikhura kwẹ k'ọraanga, ọmaana ka mmen ttara ka nsipe, ifha awọribọhk ayin makhọra irek s'Ijip.” 
\p  
\v 6 Mando kw'Aarọn onemi ọbọhk kwẹ otzena k'asi p'Ijip biphyir, awọribọhk ayin makhọra Ijip.  
\v 7 Yina, anọng p'am-asi mbọhng k'Ijip abira akwu asi mfhọna sabẹ, awọribọhk ayin makhọra irek s'Ijip. 
\p  
\v 8 Mẹ wọ, Phero oyeri Mosẹs ọmaana Aarọn, oben bi, “Bọng nzi njọhm akhukhi Ọvaar Ibinọkpaabyi, ifha ọrọbha awọribọhk mba k'ọhọhm kwaam, ọmaana k'ihọhm s'anọng paam, kaam ńtte anọng mba ọbọhk otte bẹ afona atza asi ẹjafọhni anang Ọvaar Ibinọkpaabyi kwabẹ.” 
\p  
\v 9 Mosẹs oben Phero bi, “Kaam ntte odik kpenamkpen ọbọhk nnang-ọ bi, akhe ogbe kwa kaam nzi njọhm k'eho chọ, ọmaana ch'akhaan-nọng pọ, ttara anọng pọ bi, ayongi awọribọhk p'an-arik k'ọraanga kwa Nile, awọribọhk atte ẹhọhmmọr chọ, ọmaana nhọhmmọr s'anọng pọ ọbọhk, otte.” 
\p  
\v 10 Mẹ wọ, Phero oben bi, “Ophyin e.” 
\p Mosẹs obhina bi, “Kwẹ óde-ode mach'abeni, ifha aronga bi, ọnọng kode kwa ode mach'Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kwaman.  
\v 11 Awọribọhk átte kọ, ọmaana ebhonmọr chọ ọbọhk otte, ọmaana akhaan-nọng pọ, ttara anọng pọ, k'ọraanga kwa Nile wọ kwa bẹ an-arik.” 
\p  
\v 12 Mada Mosẹs ọmaana Aarọn abin aji Phero, Mosẹs ozi njọhm, ọgbaak Ọvaar Ibinọkpaabyi odik kwa okhuri awọribọhk p'ọkk'ọtzọhma ọnang Phero.  
\v 13 Mẹ wọ, Ọvaar Ibinọkpaabyi ọbhaanga njọhm sa Mosẹs ophyemi, awọribọhk mba ape k'ihọhm, ọmaana ka ntọhmma-ttem, ttara k'iwoni.  
\v 14 Wa bẹ atzobha awọribọhk mba k'akhung-k'akhung maa, ephyok ch'awọribọhk mba ẹtzọkha irek nna biphyir.  
\v 15 Yina, mada Phero ore bi awọribọhk dọk kade, odo ettem ọbar, itzọhng dọk koyong ọnang Mosẹs ọmaana Aarọn, mach'iwa Ọvaar Ibinọkpaabyi okk'obena. 
\s1 Nkwuri s'abubuni 
\p  
\v 16 Mẹ wọ, Ọvaar Ibinọkpaabyi oben Mosẹs bi, “Ben Aarọn bi, onemi ochikhura kwo otzim k'ọbọhk kwẹ obun k'ọkpọm k'irek, ifha irerek s'Ijip biphyir, ín-ide abubuni-abubuni.”  
\v 17 Mosẹs ọmaana Aarọn asi mach'Ọvaar ọtzọhni bẹ. Mada Aarọn onemi ọbọhk ttara ochikhura kwẹ obun k'ọkpọm k'irek, abubuni ayin abẹ anọng ka for ọmaana nden. Mẹ wọ, ọkpọhm kw'irerek s'Ijip biphyir on-ode abubuni-abubuni.  
\v 18 Chibhi da anọng p'am-asi mbọhng k'Ijip, akhong bi asi mfhọna sabẹ, ifha abubuni abira ayin, bẹ kafha asi. Mẹ wọ, abubuni mba achina ororo abubha anọngẹya ọmaana nden. 
\p  
\v 19 Anọng mba p'am-asi mbọhng an-aben Phero bi, “Ọbọhk kw'Ibinọkpaabyi owobh m'odik nwa e.” Yina, Phero ochina ororo ọgaangi eho, itzọhng kokher oyonga m'idik nna, mach'iwa Ọvaar Ibinọkpaabyi okk'obena. 
\s1 Nkwuri s'araraang 
\p  
\v 20 Mẹ wọ, Ọvaar Ibinọkpaabyi oben Mosẹs bi, “Bina k'ekpekpebha, atza akwunga Phero ọmma da ọtza asi k'ọraanga, agbaakh-ẹ bi, ‘Ọvaar Ibinọkpaabyi obeni bi: Tte anọng paam ọbọhk bẹ afona, ifha bẹ atza akpobh-m.  
\v 21 Idikha ani anọng paam ọbọhk atte bẹ afona, kaam ńdọhm araraang k'ọhaabh nchen kọ, ọmaana akhaan-nọng pọ, ọmaana anọng pọ, ttara k'ihọhm sabọng. Araraang áfhu ihọhm s'anọng p'Ijip, bẹ abira abubha k'irerek biphyir. 
\p  
\v 22 “ ‘Yina, m'ewu nduma, kaam ńgọm ẹkhọma cha Goshẹn, ch'anọng paam arukhi nhok, araraang kẹ káde, ifha áronga bi kaam Ọvaar Ibinọkpaabyi nwobh m'irerek nna.  
\v 23 Kaam nsi odengọmi owobha k'anọng paam ọmaana pọ. Ẹkhọhkha nda ch'épe ọnọng for, étto ophyini.’ ” 
\p  
\v 24 Mẹ wọ, Ọvaar Ibinọkpaabyi osi mach'ọgbaakhi, ọtzọhm araraang k'ọhaabh adim k'ọvaar-dimpa kwa Phero, ọmaana k'ihọhm s'akhaan-nọng pẹ. Araraang afhu k'irerek s'Ijip biphyir. 
\p  
\v 25 Mẹ wọ, Phero oyeri Mosẹs ọmaana Aarọn, oben bi, “Bọng nọhng atza asi njafọhni anang Ibinọkpaabyi kwabọng m'irerek nna.” 
\p  
\v 26 Yina, Mosẹs oben bi, “Mma, kwẹ mando kotzor e. Njafọhni s'am-amosi anang Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kwaman, mkpukhi anọng p'Ijip okpukhi. Idikha mon-osi njafọhni sa mkpukhi bẹ, bẹ man atza kátzọbh o?  
\v 27 Mẹ wọ, maman ọkhaambi obina orenga kw'iwu ittaan mochina k'ibe s'anọng an-arukhi, ifha mosi njafọhni ọnang Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kwaman, mach'ọtzọhni man.” 
\p  
\v 28 Mẹ wọ, Phero oben bi, “Kaam ntte bọng ọbọhk otte bọng atza asi njafọhni anang Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kwabọng k'ibe s'anọng an-arukhi. Yina, bọng kakhaambi afona k'ibe s'ibhir-obhir. Bọng ńzi njọhm anang-m.” 
\p  
\v 29 Mosẹs obhina bi, “Kaam mbin ma, ńzi njọhm ozi nnang Ọvaar Ibinọkpaabyi. Ophyini araraang mba atte kọ, ọmaana akhaan-nọng pọ, ttara anọng pọ ọbọhk otte. Kọ re bi, Phero bọng dọk kọbọra bi, ọkpa anọng mba eden bi, bẹ aningi njafọhn atza asi anang Ọvaar Ibinọkpaabyi.” 
\p  
\v 30 Mẹ wọ, Mosẹs obina oji Phero, otza ozi njọhm ọnang Ọvaar Ibinọkpaabyi.  
\v 31 Ọvaar Ibinọkpaabyi ọbhaanga njọhm nna sa Mosẹs ophyemi bi, araraang mba atte Phero ọmaana akhaan-nọng pẹ, ttara anọng pẹ ọbọhk. Ẹraraang mada dani ch'ebire erik kede.  
\v 32 Yina, Phero obiro okhebha mẹ ọgaangi eho, anọng mba ọbọhk kokher otte, bẹ afona. 
\c 9  
\s1 Nkwuri s'etzirakpo 
\p  
\v 1 Wa Ọvaar Ibinọkpaabyi oben Mosẹs bi, “Rọhng ka Phero, atza agbaakh-ẹ bi, Ọvaar Ibinọkpaabyi kw'abaHiburu obeni bi, ‘Tte anọng paam ọbọhk bẹ afona, ifha bẹ atza akpobh-m.  
\v 2 Idikha abhumi bi atte bẹ ọbọhk, achin ororo abọkha bẹ ahok,  
\v 3 kaam Ọvaar Ibinọkpaabyi ńgọhkha bọng nkwuri s'ideden k'etzirakpo py'ewobh k'owoni, py'ede: nnyanyaang, ọmaana abhaam, ọmaana akamẹl, ọmaana andaamogbodo, ọmaana arukhimaan ttara avu.  
\v 4 Yina, kaam Ọvaar Ibinọkpaabyi ńgọmi etzirakpo py'anọng p'Israẹl ewobha, k'etzirakpo py'anọng p'Ijip. Otzirattọhk manda vani f'anọng p'Israẹl kópe.’ ” 
\p  
\v 5 Mando kw'Ọvaar Ibinọkpaabyi okhe ogbe, oben bi, “Ophyini wọ kwa kaam Ọvaar Ibinọkpaabyi ńsi odik nwa m'irek nna.”  
\v 6 Ewu ehobh mẹ, Ọvaar Ibinọkpaabyi osi mach'obeni. Etzirakpo py'anọng p'Ijip epe biphyir, yina, otzirattọhk manda vani f'anọng p'Israẹl f'ope kode.  
\v 7 Mẹ wọ ofon, Phero ọtzọhm ajinọng bani bẹ atza adọhn odik nwa, bẹ are bi, ode odik-ọkka bi, otzirattọhk manda vani f'anọng p'Israẹl f'ọkk'ọpa, kode. Kaambi mẹ wọ, Phero ochina ororo ọgaangi eho, obhum bi, otte anọng p'Israẹl ọbọhk bẹ afona. 
\s1 Nkwuri s'aphyi 
\p  
\v 8 Mẹ wọ, Ọvaar Ibinọkpaabyi oben Mosẹs ọmaana Aarọn bi, “Bọng kpokhi ọtzọtzọhng-khọhma ka nkwukha ka mbọhkpattem sabọng, tte Mosẹs okwuri ọtzọtzọhng-khọhma nwa k'iwokhi, Phero obe mẹ ore.  
\v 9 Itzọtzọhng nna íyaami mach'ọkpọm makhọra irerek s'Ijip, sẹ ín-itzima aphyi p'anwa ibhan ikwu, p'asi anọngeya, ọmaana nden makhọra irek nna.” 
\p  
\v 10 Mẹ wọ, bẹ akpokhi ọtzọtzọhng-khọhma ka nkwukha, akwu abe Phero k'itzitzikha. Mosẹs ọtzọkha sẹ okwuri k'iwokhi, aphyi p'anwa ibhan abhona anọngẹya ọmaana etzirakpo \it bi wooii\it*.  
\v 11 Wa anọng p'am-asi mbọhng, bẹ Mosẹs k'itzitzikha kafha abe, okhuri aphyi p'asi bẹ, ọmaana anọng p'Ijip biphyir. 
\p  
\v 12 Yina, Ọvaar Ibinọkpaabyi osi Phero odo eho ọgaangi, itzọhng koyong ọnang Mosẹs ọmaana Aarọn, mach'Ọvaar Ibinọkpaabyi okk'Mosẹs ọgbaakha. 
\s1 Nkwuri s'arọngda 
\p  
\v 13 Mẹ wọ, Ọvaar Ibinọkpaabyi oben Mosẹs bi, “Bina atza akwunga Phero okpebhamma, aben-ẹ bi, Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kw'abaHiburu obeni bi, ‘Tte anọng paam ọbọhk bẹ afona, ifha bẹ atza akpobh-m.  
\v 14 Oni mando ode, m'ogbe nwa, kaam nna ngọhkha kọ ọmaana akhaan-nọng pọ nkwuri s'ideden, ifha kọ aronga bi, ọnọng kw'ode macha kaam, makhọra ọyagbin, kode.  
\v 15 Ọban bi, nnamanda ira nkk'ettuma ndọhma nnang kọ ọmaana anọng pọ, ttara nkwuri s'ira nkk'bọng ifha, mbiri ndimi bọng m'ọyagbin.  
\v 16 Yina, odik kw'osi nttọ-ọ ọbọhk, awobha akpen ode bi, ifha are ẹfa chaam, ọmaana bi, bẹ afha asi ẹjaakhi cha che chaam makhọra ọyagbin.  
\v 17 Kọ atzima am-age-oge anang anọng paam bi, atte bẹ ọbọhk, bẹ afona.  
\v 18 Mẹ wọ, ophyini k'ogbe-dema nwa, kaam ndebh arọngda p'apyibhi ọtzam ayọhnga arọngda p'akk'atta ttẹwọr kẹ da Ijip ọmaan maa, apyiri ma.  
\v 19 Tzọhm ẹkkaabha bẹ atzima etzirakpo pyọ, ọmaana ọttọhk kpenamkpen fọ f'owobh k'owoni atzima adim k'ikhira, okhuri bi, arọngda mba atzebhi, anọngeya ọmaana etzirakpo py'eni k'ikhira ewobh, épe-ope.’ ” 
\p  
\v 20 Mẹ wọ, akhaan-nọng pa Phero p'akhaam ojora f'atzim p'Ọvaar Ibinọkpaabyi, afona m'ẹbhar-ẹbhar atza atzọkha atzọhmnọng pabẹ, ọmaana etzirakpo pyabẹ, atzima adim k'ẹtzaanga.  
\v 21 Yina, ayok mbuma p'asi itzimabhaang k'atzim p'Ọvaar Ibinọkpaabyi, atte atzọhmnọng pabẹ, ọmaana etzirakpo pyabẹ ọbọhk k'owoni. 
\p  
\v 22 Mẹ wọ e, Ọvaar Ibinọkpaabyi on-oben Mosẹs bi, “Nemi ọbọhk kwọ atzena k'ẹrọng, ifha arọngda atzebh anọngeya ọmaana etzirakpo, ttara ọttọhk kpenamkpen f'omeni k'iwoni s'anọng p'Ijip.” 
\p  
\v 23 Mada Mosẹs onemi ochikhura kwẹ otzena k'ẹrọng, Ọvaar Ibinọkpaabyi ọtzọhm ẹbhaangkpon ọmaana arọngda, ẹbhaangkpon ẹmani k'irek. Mẹ wọ, Ọvaar Ibinọkpaabyi otzebh arọngda k'obhon kw'Ijip.  
\v 24 Arọngda atzebh, ẹbhaangkpon ẹmani edimi, ẹmani edimi, arọngda mba bọ iwa apyibhi ọtzam ayọhnga p'akk'atta ttẹwọr kẹ da Ijip ọmaan maa, okwu ode obhon.  
\v 25 Arọngda mba afhu anọngẹya ọmaana etzirakpo k'Ijip, ọmaana nchi ttara ọttọhk kpenamkpen f'omeni k'iwoni.  
\v 26 Ibẹ ibungisẹ s'iwa arọngda mba an-atzebhi ide ka Goshẹn, kẹ da iwa anọng p'Israẹl arukhi. 
\p  
\v 27 Mando kwa Phero oyeri Mosẹs ọmaana Aarọn ọgbaak bẹ bi, “Kaam nkk'ẹkhọhngkwuri nsa m'ogbe nwa, Ọvaar Ibinọkpaabyi wọ otzor-otzor, kaam ọmaana anọng paam bọ mọkhaam ottotto.  
\v 28 Bọng zi njọhm anang Ọvaar Ibinọkpaabyi bi, ọkwọbha ẹbhaangkpon ttara arọngda, kkeri py'ẹkk'ẹhaabha kpọng. Kaam ńtte bọng ọbọhk otte bọng afona, bọng kakhaambi, abira achina ororo awobha ma.” 
\p  
\v 29 Mosẹs obhin-ẹ bi, “Idikha nkk'obhon ọbọhk ntta mfona, kaam ḿmẹma mbọhk saam ńzi njọhm nang Ọvaar Ibinọkpaabyi, mmaangkpon ńkwọbha ọtta-ọtta, arọngda abira ákwọbha otzetzebh. Mẹ kw'atzima aronga bi, Ọvaar Ibinọkpaabyi wọ ọkhaam ọyagbin.  
\v 30 Yina, kaam nnong kẹ bi, kọ ọmaana akhaan-nọng pọ, ojora f'Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi atzima am-akhaama.” 
\p  
\v 31 (Wa ngwugwuma ọmaana abarli akhibhi, da iwa abarli akk'akhora, ngwugwuma mbiri nwọm.  
\v 32 Yina, awit kàkhibhi okhuri da iwa bẹ ani akhori m'ogbe nwa). 
\p  
\v 33 Mando kwa Mosẹs obin oji Phero, otte obhon ọbọhk, ọtza ọmẹma mbọhk otzena Ọvaar Ibinọkpaabyi ozi njọhm, mmaangkpon nkwọbha ọtta-ọtta, arọngda akwọbha ottotto, ẹrọng ebire ẹkwọbha otzetzebh.  
\v 34 Mada Phero ore bi ẹrọng, ọmaana arọngda, ttara mmaangkpon ikk'ikwọbha, obiro osi ẹkhọngkwuri. Kẹ ttara akhaan-nọng pẹ abira achina ororo agaangi eho.  
\v 35 Mẹ wọ e, Phero ochina ororo ọbar ettem, anọng p'Israẹl ọbọhk kokher otte bẹ afona, mach'Ọvaar Ibinọkpaabyi okk'Mosẹs otzima ọgbaak. 
\c 10  
\s1 Nkwuri s'agwuribhebhe 
\p  
\v 1 Wa Ọvaar Ibinọkpaabyi oben Mosẹs bi, “Kọ rọhng atza akhebha Phero, kkeri kaam nkk'kẹ, ọmaana akhaan-nọng pẹ nsa bi, bẹ agaangi eho, ifha nsi idik s'ipe anọng for kabẹ k'ottem.  
\v 2 Órenga mẹ, ikhina kọ ágbaak va pọ, ọmaana va pa va pọ, eden cha kaam ńneng nnang anọng p'Ijip ihem, ọmaana idik s'ipe anọng for sa kaam nsi kabẹ k'ottem. Bọng biphyir aronga bi, kaam wọ nde Ọvaar Ibinọkpaabyi.” 
\p  
\v 3 Mando kwa Mosẹs ọmaana Aarọn afona atza akhebha Phero, agbaakh-ẹ bi, “Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kw'abaHiburu, obeni bi, ‘Ogbe obhir otzuma yan, yina ahakha for sọ k'itzitzikha saam o? Tte anọng paam ọbọhk bẹ afona, ifha bẹ atza akpobh-m.  
\v 4 Idikha abhumi bi, atte bẹ ọbọhk bẹ afona, ophyini, kaam ńdọhm agwuribhebhe ọtzọhm k'ẹkhọma chọ.  
\v 5 Agwuribhebhe mba abubha irerek biphyir maa ọnọng sẹ dọk ore. Bẹ ábira akhibhi ekpo py'iwa arọngda akk'akhibhi arik, ọmaana echi kpenamkpen ch'emeni k'iwoni sabọng.  
\v 6 Bẹ abira afhu k'ihọhm sọ, ọmaana k'ihọhm s'akhaan-nọng pọ, ttara k'ihọhm s'anọng p'Ijip biphyir. Kwẹ óde odik kw'abatte, ttara abatte p'atte an-atzima amara, ttẹwọr kẹ da obhon kw'Ijip ọmaan maa, apyiri ma.’ ” Mẹ wọ, Mosẹs ọbhakhi nnam, obina oji Phero. 
\p  
\v 7 Iwa akhaan-nọng mba abọbh Phero bi, “Ogbe obhir otzuma yan, yina ojinọng nwa ọkwọbha man k'eyoma okhe-khe o? Tte bẹ ọbọhk bẹ afona, ifha bẹ afha atza akpobha Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kwabẹ. Ode bi, kọ atzima ara bi, Ijip owobh k'ihem o?” 
\p  
\v 8 Mẹ wọ, Phero ọtzọhm bẹ atza ayeri Mosẹs ọmaana Aarọn akpa nnam, oben bẹ bi, “Bọng nọhng atza akpobha Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kwabọng. Yina, bọng anọng bọ ade anọng p'áfon-ofona o?” 
\p  
\v 9 Mosẹs obhina bi, “Maman ófona ttara igbọ, ọmaana adeden-nọng, ọmaana va paman p'ijinọnọng, ọmaana p'ipanọnọng, ttara etzirakpo pyaman, okhuri bi, maman ọkhaam bi, mosi ọdadaami kw'ikpokpobha ọnang Ọvaar Ibinọkpaabyi kwaman.” 
\p  
\v 10 Yina, Phero on-oben bẹ bi, “Bọng achibhi bi, Ọvaar Ibinọkpaabyi owobha kẹ ttara bọng o? K'odik-ọkka, kaam panọng pabọng ọmaana va pabọng ọbọhk kintte bẹ afona. K'odik-ọkka, bọng achibhi itzama.  
\v 11 Mma e! Tte ajinọng bẹ-bẹ afona atza akpobha Ọvaar Ibinọkpaabyi, mada ode odik kw'am-aphyem-m wọ mẹ.” Mẹ wọ, bẹ akhubh Mosẹs ọmaana Aarọn, k'itzitzikha sa Phero. 
\p  
\v 12 Mẹ wọ, Ọvaar Ibinọkpaabyi oben Mosẹs bi, “Nemi ọbọhk kwọ atzena k'Ijip ifha agwuribhebhe k'ọhaabh atzọkha ibe kpenamkpen, bẹ abira akhibhi ọttọhk kpenamkpen f'omeni k'iwoni, ọmaana ọttọhk kpenamkpen f'arọngda akk'akhibhi arik.” 
\p  
\v 13 Mando kwa Mosẹs onemi ochikhura kwẹ otzena k'Ijip. Ọvaar Ibinọkpaabyi osi ọbhabha ọttẹwọr kẹ da ewuchen em-eyin ogwuma makhọra obhon, m'ẹyawu ttara erungiwu nduma biphyir. Yina ewu ehobha, ọphapha nwa okk'agwuribhebhe otzima okwu.  
\v 14 Agwuribhebhe mba anyaami k'ọhaabh makhọra Ijip. Mada ogbe odede itzama-dema nna s'agwuribhebhe itzimi-mitta k'Ijip, sẹ dọk kíbiri itto, kaambi k'ogbe ororo wọ.  
\v 15 Agwuribhebhe mba abubha irerek biphyir maa, sẹ ipyi erungi \it bi kaang \it* Bẹ achi ọttọhk kpenamkpen f'arọngda akhibhi arik, ọmaana ekpo py'emeni k'iwoni, ttara achiduk pa nchi. Wa echi, obiro ode ọraraari manda wani kw'obiro otzen-otzeni k'irerek s'Ijip, dọk kode. 
\p  
\v 16 M'ẹbhar-ẹbhar, Phero oyeri Mosẹs ọmaana Aarọn, oben bi, “Kaam nkk'ẹkhọngkwuri nsa k'itzitzikha s'Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kwọ, ọmaana k'itzitzikha sọ.  
\v 17 Kọ bina anang ẹkhọngkwuri chaam m'ogbe nwa dọk, azi njọhm anang Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kwọ, ifha ọrọbh-m k'itzama-barada nna.” 
\p  
\v 18 Mosẹs obina oji Phero, ọtza ozi njọhm ọnang Ọvaar Ibinọkpaabyi.  
\v 19 Ọvaar Ibinọkpaabyi ọbhakhi ọphapha nwa ọgaangi maa, on-ode mach'ọphapha kw'okhubha kw'ewuchen em-edimi. Wa ọphapha nwa ogwuma agwuribhebhe mba biphyir ọbhari k'Ẹraanga-khora. Ogwuribhebhe manda wani kw'obiro arik k'Ijip kode.  
\v 20 Yina, Ọvaar Ibinọkpaabyi osi Phero ochina ororo ọgaangi eho bi, otte anọng p'Israẹl ọbọhk bẹ afona. 
\s1 Nkwuri s'orungibanga 
\p  
\v 21 Mẹ wọ, Ọvaar Ibinọkpaabyi oben Mosẹs bi, “Yaangi ọbọhk kwọ atzena k'ẹrọng, ifha orungibanga kw'ọttọmi ọnọng, óyin obubha Ijip biphyir.”  
\v 22 Mẹ wọ, Mosẹs ọyangi ọbọhk kwẹ otzena k'ẹrọng, orungibanga kw'opyi \it bi kaang\it* oyin obubha Ijip biphyir, k'iwu manda ittaan.  
\v 23 Ọnọng manda wani kw'ore oyok, yina on-obiro obina oji ibe sẹ k'iwu ittaan kode. Yina, wa anọng p'Israẹl k'ipyerungi k'awobh k'obe fa bẹ arukhi. 
\p  
\v 24 Mẹ wọ, Phero oyeri Mosẹs ọmaana Aarọn oben bẹ bi, “Bọng nọhng atza akpobha Ọvaar Ibinọkpaabyi. Bọng afha tzima panọng pabọng kaambi va pabọng bọ, arọng afona. Bọng kingẹ tte etzirakpo pyabọng ọbọhk ewobha ka.” 
\p  
\v 25 Yina, Mosẹs oben bi, “Kọ akhaambi atte man ọbọhk, mọtza osi njafọhni, mobiro osi nnanga nkwọmisẹ ọnang Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kwaman.  
\v 26 Etzirakpo pyaman ẹkhaambi ẹtzọn man abẹ efona, man manda vani kofona oji. Mọkhaambi otzima byani mẹ okpobha Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi. Koyongi bi, mokk'opyiri kẹ, yina moronga ọttọhk fa motzima okpobha Ọvaar Ibinọkpaabyi e.” 
\p  
\v 27 Yina, Ọvaar Ibinọkpaabyi ochina ororo osi Phero ọgaangi eho, for kobiro odo bi, otte anọng p'Israẹl ọbọhk bẹ afona.  
\v 28 Mando kwa Phero obeni Mosẹs bi, “Bin-m k'itzitzikha! Aningi dọk ayom bi, abe-m k'itzitzikha o! Kkeri ewu ch'abira are itzitzikha saam ápe-ope.” 
\p  
\v 29 Mosẹs obhina bi, “A o, tte kwẹ ode mach'abeni, kaam kọ k'itzitzikha dọk kímbe.” 
\c 11  
\s1 Nkwuri s'obo kw'acheden-va p'ijinọng p'Ijip 
\p  
\v 1 Mẹ wọ, Ọvaar Ibinọkpaabyi oben Mosẹs bi, “Kaam ḿbiri ntte Phero ọmaana anọng p'Ijip ọbọhk bẹ are nkwuri rani. Nsisi mando, kẹ ótte bọng ọbọhk otte bọng afona. Mada otte bọng ọbọhk, okhubh bọng okhubh biphyir-phyir.  
\v 2 Gbaak anọng p'Israẹl, ajinọng ọmaana panọng bi, bẹ atza aben anọng p'Ijip anang bẹ ekpo pya gol ọmaana silva.”  
\v 3 (Ọvaar Ibinọkpaabyi osi bi, anọng p'Ijip asi ọphyaam anang anọng p'Israẹl. Ayongi mẹ, akhaan-nọng pa Phero, ọmaana anọng p'Ijip biphyir anang Mosẹs ikpokpobha s'ideden). 
\p  
\v 4 Mẹ wọ, Mosẹs oben bi, “Ọvaar Ibinọkpaabyi obeni bi, ‘M'orungittem, kaam ńnenga k'obhon kw'Ijip makhọra.  
\v 5 Ocheden-nwa kpenamkpen kw'ijinọng k'Ijip ópe-ope, ttẹwọr k'ocheden-nwa kw'ijinọng kwa Phero maa, apyiri k'ocheden-nwa kw'ijinọng kw'obira-kwanọng kw'om-ohok ekpo, ọmaana acheden-va p'abhaam biphyir.  
\v 6 Obhoma kw'ówobha k'Ijip opyibh ọyọhnga kw'iwa okk'owobha, ttara kw'óbiro owobha.  
\v 7 Yina, ọttọhk manda vani f'ósi anọng p'Israẹl kóde, kaambi ẹpfa dọ, anọngẹya ọmaana nden kẹ́gbọ.’ Mẹ wọ kwa bọng árọnga bi, Ọvaar Ibinọkpaabyi ọkhọmi anọng p'Israẹl ewobha k'anọng p'Ijip.  
\v 8 Akhaan-nọng mba pọ biphyir ákpa nnam ọkpa, akwu ahakha nho anang-m, aben bi, ‘Tzotzokhaan, kọ ọmaana anọng p'atzọn-ọ abẹ biphyir, bọng nọhng!’ Ogbe nwuma ọkk'ọkwọbha, kaam ńttọ-ọ ọbọhk otte.” Mẹ wọ, Mosẹs obina ttara idọdọkhi oji Phero. 
\p  
\v 9 Ọvaar Ibinọkpaabyi okk'Mosẹs obena bi, “Phero kọ itzọhng koyonga, ifha idik saam s'ipe anọng for ihaabh k'Ijip.”  
\v 10 Mosẹs ọmaana Aarọn asi idik nna s'ipe anọng for biphyir m'itzitzikha sa Phero. Yina, Ọvaar Ibinọkpaabyi osi Phero ọgaangi eho, anọng p'Israẹl ọbọhk kokher otte bi, bẹ abina aji ẹkhọma chẹ. 
\c 12  
\s1 Ọdadaami kwa Pasova 
\p  
\v 1 Wa Ọvaar Ibinọkpaabyi oben Mosẹs, ọmaana Aarọn k'Ijip bi,  
\v 2 “Ophe nwa on-ode ochedenphe, ochedenphe kwabọng kwa cho.  
\v 3 Gbaak anọng p'Israẹl biphyir bi, k'iwu jobh s'ophe nwa, ojinọng kpenamkpen, otzima orukhimaan-nwa wani okwu k'eho ch'ẹhọhmmọr chẹ, ẹhọhmmọr kpenamkpen, orukhimaan-nwa wani.  
\v 4 Idikha ẹhọhmmọr ẹn-ẹbari ebenga k'odem kwa bẹ afha achi, orukhimaan-nwa wani akyera, tte ẹhọhmmọr nduma ebhuna ttara ayokh-ẹbaanga, atzor k'ọnọngmik kwa bẹ ade. Bọng dekha orukhimaan-nwa kw'obenga ọnọng-mik, atzor k'ekkema ch'ọnọng-ọnọng óchi.  
\v 5 Nden sa bọng átzima, sẹ ngaambi nde adimpẹ p'ade cho wani, sa nni ekhem mbiri ndima. Bọng afha atzekha k'arukhimaan, ayongi mẹ, bọng dekha k'avu.  
\v 6 Bọng kkeri sẹ maa, opyiri k'ẹchọhkha ch'ewu ch'ettonga ọhawani kwa chi ch'ophe nwa, kw'anọng p'Israẹl biphyir akhaambi ayẹk sẹ ndọngi.  
\v 7 Mẹ wọ, bẹ átzọkha izi rani áphyokha k'akhaan-akhaan, ọmaana k'ebir-ebir kwa mkpọmmachi s'amma p'ihohm sa bẹ áwobha áchi, nden nna.  
\v 8 M'erungiwu nduma dani, bẹ atzima akwọngitzọhng p'ajobh-ojobhi, achi nden nnuma sa bẹ abhaabhi k'ekpon. Tte bẹ achi ttara brẹd kwa bẹ ani yist akhe.  
\v 9 Bọng chẹ ekhekhebhi kàchi, bọng chẹ kàbira awọhn ttara asi. Yina, bọng mabh eho, ọmaana mmo, ttara ettongakpo k'ekpon.  
\v 10 Bọng chi chẹ akyera yina ewu ehobha. Idikha kpenamkpen emung, ewu ewobh, bọng akhaambi akwọmi chẹ ọkwọmi.  
\v 11 Ma wọ ode odem kwa bọng áchi chẹ; bọng kpaama odikpa ka nwura sabọng, bọng akhe ekpo pya mmo, bọng atzima achikhura pa bọng ka mbọhk. Bọng chi chẹ k'ẹbhar-k'ẹbhar. Ma wọ ode ọdadaami kwa Pasova kw'ọnang kaam Ọvaar Ibinọkpaabyi ikpokpobha. 
\p  
\v 12 “M'erungiwu nduma dani, kaam ńnenga k'Ijip mfhu acheden-va p'anọngẹya biphyir, ọmaana acheden pa nden kpenampken. Kaam ḿkpaara aponga p'apyibh akha p'Ijip biphyir. Kaam wọ nde Ọvaar Ibinọkpaabyi.  
\v 13 Izi nna íde ẹkhọhkha ẹnang bọng k'ihọhm sa bọng awobh. Mada nne izi nnuma, kaam ńjekha bọng ojekha. Nkwuri sa ńgebha bọng kíde, mada ńsi anọng p'Ijip itzama. 
\p  
\v 14 “Ma wọ óde ewu ch'ojima, ch'igbọ s'íkwu k'ororo itzima isi ọdadaami inang Ọvaar Ibinọkpaabyi ikpokpobha. Ẹdadaami-wu nda ewohba ka cho kpenamkpen maa ogbe ode.  
\v 15 K'iwu izenamfa, bọng áchi brẹd kwa bẹ ani yist akhe. Bọng nọbha yist kabọng k'ihọhm m'echedenwu, okhuri bi, idikha ọnọng kpenamkpen ochi ọchattọhk fa bẹ akhe yist, ttẹwọr m'ewu dani maa apyiri iwu izenamfa nna, bẹ akhaambi akhubh-ẹ k'ebhonmọr ch'Israẹl.  
\v 16 M'echedenwu, ttara ewu ch'ettong nzenamfa, bọng hok ewobha ch'ikpokpobha s'Ọvaar Ibinọkpaabyi. Bọng ọtzọhm m'iwu nna biphyir kasi, oyongi ọchattọhk fẹ-fẹ, fa bọng afha asi anang ọnọng kpenamkpen bi, ochi. 
\p  
\v 17 “Bọng si ọdadaami nwa kwa brẹd kwa bẹ ani yist akhe, okhuri bi, m'ewu nda dọ cha kaam ndim bọng ka ngaan sabọng mbina k'Ijip. Bọng si ọdadaami nwa mach'ọdadaami kw'owobha ọnang igbọ s'íkwu k'ororo.  
\v 18 Ttẹwọr k'ẹchọhkha ch'iwu ọhawani kwa chi s'ocheden-phe, bọng am-achi brẹd kwa bẹ ani yist akhe maa, apyiri k'ẹchọhkha ch'ewu ch'ettong iwu ẹrọbh obhiri dani.  
\v 19 K'iwu manda izanamfa, bọng yist k'ihọhm sabọng kahok. Ọnọng kw'ochi ọchattọhk fa bẹ akhe yist, ode ọmaana, obiro ode okhekhennọng, bẹ akhaambi, akhubh-ẹ k'ebhonmọr ch'Israẹl.  
\v 20 Bọng ọttọhk fa bẹ akhe yist kàchi. K'ibe kpenamkpen sabọng arukhi, bọng akhaambi achi brẹd kwa bẹ ani yist akhe.” 
\p  
\v 21 Mẹ wọ, Mosẹs oyeri adeden-nọng p'Israẹl biphyir oben bẹ bi, “Bọng nọhng madẹdẹnwa, atza atzekha orukhimaan-nwa wani-wani, anang nhọhmmọr sabọng, bọng fhu arukhimaan-va atzima asi ọdadaami kwa Pasova.  
\v 22 Bọng dọkha ẹraraari-pyi cha hisobh, arana k'izi sa bọng akhe k'ọkwakkama, bọng atzọkha izi rani abọra k'ebir-ebir ọmaana k'akhaan-akhaan pa mkpọmmachi s'amma. Ọnọng manda wani oningi k'iyaan oyini matzẹmaa, ewu ehobha.  
\v 23 Mada isa Ọvaar Ibinọkpaabyi órenga m'irek nna bi, ofhu anọng p'Ijip, óre izi nna k'ebir-ebir ọmaana k'akhaan-akhaan pa mkpọmmachi s'amma. Orenga-eden kw'obo ọbọhk kótte bi, odim k'ihọhm sabọng bi, ofhu bọng. 
\p  
\v 24 “Bọbọng ọmaana va pa va pabọng, akhaambi ahok ndọhna nna mach'ọphaangi kw'owobha maa, ogbe ode.  
\v 25 Bọng apyiri k'irerek nnuma s'Ọvaar Ibinọkpaabyi ochekhi bi, ọ́nang bọng, bọng si ọdadaami nwa.  
\v 26 Ikhina va pabọng abọbhi bọng bi, ‘Ọdadaami nwa oyini yan o?’  
\v 27 Bọng gbaak bẹ bi, ‘Ode ọdadaami kw'ẹjafọhni cha Pasova anang Ọvaar Ibinọkpaabyi, kw'iwa ojek ihọhm s'anọng p'Israẹl k'Ijip, ọkkaana nhọhmmọr saman k'ogbe kw'iwa ofhu anọng p'Ijip.’ ” Mẹ wọ e, anọng mba arakha attima otzitzikha k'irerek, akpobha Ọvaar Ibinọkpaabyi.  
\v 28 Wa anọng p'Israẹl asi mach'Ọvaar Ibinọkpaabyi okk'Mosẹs ọmaana Aarọn ọtzọhna. 
\p  
\v 29 M'orungittem, Ọvaar Ibinọkpaabyi ofhu achedenva biphyir k'Ijip, ttẹwọr k'ocheden-nwa kwa Phero, kw'ọdabhi ẹvaar, maa atza apyiri k'achedenva p'agbakkọbh-kkọhbha p'awobh k'ẹgbakkọhbh-ttọmma, ttara achedenva p'etzirakpo biphyir.  
\v 30 Mada Phero ọmaana akhaan-nọng pẹ, ttara anọng p'Ijip biphyir aphyọbh m'erungi, wa obhoma kw'ideden owobh k'Ijip, da iwa ẹhọhmmọr en-ebekhi ch'ọnọng oni ope. 
\s1 Orenga kw'anọng p'Israẹl 
\p  
\v 31 M'erungi, Phero oyeri Mosẹs ọmaana Aarọn, oben bi, “Bọng bina! Bọng dima anọng p'Israẹl abina aji anọng paam. Bọng nọhng atza akpobha Ọvaar Ibinọkpaabyi macha bọng akk'aphyema.  
\v 32 Bọng dima etzirakpo pyabọng atzima arọhng, macha bọng akk'abena. Bọng biri si-m ittabọhng.” 
\p  
\v 33 Mẹ wọ, anọng p'Ijip aben anọng mba bi, bẹ asi ẹbhar-ẹbhar abina aji ẹkhọma nda, “Oni mando ode, bẹ ápope biphyir.”  
\v 34 Mẹ wọ, anọng mba atzini abubuma pabẹ, yina bẹ an-atzini yist atzọhkha ka mbabaang sabẹ, k'agbanggbang pa bẹ am-atzima asi brẹd, pa bẹ abhọri k'ọbara.  
\v 35 Wa anọng p'Israẹl asi macha Mosẹs okk'bẹ ọtzọhna, bẹ atza abọbh anọng p'Ijip asilva, ọmaana gol, ttara ọbara.  
\v 36 Wa Ọvaar Ibinọkpaabyi ọkk'ọsa bi, anọng p'Ijip asi ọphyaam anang anọng p'Israẹl. Wa bẹ anang anọng p'Israẹl ọttọhk kpenamkpen fa bẹ abọbhi bẹ. Mẹ wọ e, bẹ achi anọng p'Ijip ọgbọm. 
\p  
\v 37 Wa anọng p'Israẹl abina orenga ka Rameses apyiri ka Sukọt. Akhiri panọng ọmaana vava aji, ajinọng p'iwa asi orenga nwa apyiri anọng nnọhna ẹnọhna obhiri arọbh jobh.  
\v 38 Wa anọng adọdọk k'ọhaabh, ọmaana etzirakpo k'ọhaabh, arukhimaan ọmaana avu abira atzọn bẹ abẹ m'orenga nwa.  
\v 39 Wa bẹ atzọkha abubuma pa bẹ akk'atzima bina k'Ijip asi brẹd kwa bẹ ani yist akhe. Wa abubuma mba yist kakhaam, okhuri da iwa bẹ an-akhubhi bẹ okhubh k'Ijip, bẹ ogbe dọk kakhaam kwa bẹ atzim awọhn ọchattọhk fabẹ. 
\p  
\v 40 Biphyir-phyir wa anọng p'Israẹl arukhi cho ẹnọhna obhiri ẹrọbh obhiri jobh k'Ijip.  
\v 41 Mẹ ewu nduma ch'ettong cho ẹnọhna obhiri ẹrọbh obhiri jobh, wa anọng p'Ọvaar Ibinọkpaabyi ka ngaan sabẹ, abina aji Ijip.  
\v 42 Da iwa Ọvaar Ibinọkpaabyi okkeri erungiwu nduma, ifha otzima bẹ obina k'Ijip, erungiwu nda dọ ch'anọng p'Israẹl biphyir ám-akkeri, atzima anang Ọvaar Ibinọkpaabyi ikpokpobha, k'igbọ kpenamkpen s'íkwu k'ororo. 
\s1 Asana p'ọdadaami kwa Pasova 
\p  
\v 43 Ọvaar Ibinọkpaabyi oben Mosẹs ọmaana Aarọn bi, “Ma wọ ode ndọhna s'ikhuri ọchattọhk f'ọdadaami kwa Pasova. 
\p “Tte okhekhennọng manda wani oningi fẹ ochi.  
\v 44 Obira kpenamkpen kwa bọng akk'adebha ofha ochi fẹ ochi, bọng akk'ẹ ọkpakkọrikkọ asa.  
\v 45 Yina, okhekhennọng kw'orukhi mẹ, ọmaana ọtzọhmnọng kwa bẹ abheri ọtzọhm, bẹ kakhaambi ochi fẹ. 
\p  
\v 46 “Bọng akhaambi achi fẹ k'ọhọhm ẹtzaanga, bọng etzen manda dani katzima ayin k'iyaan. Bọng ọkhọbhi manda wani kavọhkhi.  
\v 47 Ebhonmọr ch'Israẹl biphyir ẹkhaambi esi ọdadaami nwa. 
\p  
\v 48 “Okhekhennọng kw'orukhi ttara bọng, kw'ọdaakh-ẹ bi, ira osi Ọdadaami nwa ọnang Ọvaar Ibinọkpaabyi, ọkhaambi osi ajinọng p'ọhọhm kwẹ biphyir ọkpakkọrikkọ. Mẹ wọ, kẹ ofha osi ọdadaami nwa mach'ọnọng wani kw'ode ọmaana kw'irek nna. Tte ọnọng kwa bẹ ani ọkpakkọrikkọ asi oningi ochi.  
\v 49 Aphaangi mba awobh anang ammaana, ttara akhekhennọng p'arukhi ttara bọng.” 
\p  
\v 50 Wa anọng p'Israẹl biphyir asi mach'Ọvaar Ibinọkpaabyi okk'Mosẹs ọmaana Aarọn ọtzọhna.  
\v 51 Mẹ ewu nduma dani, wa Ọvaar Ibinọkpaabyi otzima anọng p'Israẹl ka ngaan sabẹ obina k'Ijip. 
\c 13  
\s1 Acheden-va p'ijinọng odidibha 
\p  
\v 1 Iwa Ọvaar Ibinọkpaabyi oben Mosẹs bi,  
\v 2 “Tte ocheden-nwa kpenamkpen kw'ijinọng ọbọhk anang-m. Ocheden-nwa kw'ẹbhọr kpenamkpen k'ottem kw'anọng p'Israẹl, ode ọnọngẹya o, obiro ode etzen o, ode kwaam.” 
\p  
\v 3 Mẹ wọ, Mosẹs oben anọng mba bi, “Bọng jima ewu nda, ewu ch'iwa bọng abin k'Ijip, k'obhon kw'ebira, okhuri bi, Ọvaar Ibinọkpaabyi ọrọbh bọng kẹ ttara ẹfa. Bọng ọttọhk kpenamkpen fa bẹ akhe yist kàchi.  
\v 4 Mayina, k'ophe kw'Abib wọ kwa bọng abin.  
\v 5 Mada Ọvaar Ibinọkpaabyi ótzima bọng opyiri k'irek s'abaKenaan, ọmaana s'abaHet, ọmaana s'ab'Amọr, ọmaana abaHiv, ttara s'ab'aJẹbus, irerek s'iwa ochekhi ọnang abatte pabọng bi, ọnang bọng irerek ọkkakka s'abasi, ọmaana akhọkhọnana ahaabh-ọhaabh, bọng ám-asi ọdadaami nwa m'ophe nwa.  
\v 6 K'iwu izenamfa, bọng chi brẹd kwa bẹ ani yist akhe. K'ewu ch'ettonga izenamfa, bọng si ọdadaami anang Ọvaar Ibinọkpaabyi.  
\v 7 Bọng chi brẹd kwa bẹ ani yist akhe, k'iwu nnuma izenamfa. Tte ọttọhk kpenamkpen fa bẹ akhe yist, oningi k'ottem kwabọng ode. Tte bẹ iningi yist orere are, ka nnem sabọng.  
\v 8 M'ewu nduma, bọng gbaak va pabọng bi, ‘Nsi mando okhuri odik kw'iwa Ọvaar Ibinọkpaabyi osi ọnang man, mada mobin k'Ijip.’  
\v 9 Ọdadaami nwa óde mach'ẹkhọhkha cha bọng akhe ka mbọhk sabọng, abira akpa k'otzitzikha-ttem fa bọng mach'ojima bi, ọphaangi kw'Ọvaar Ibinọkpaabyi owobha ka mma sabọng, okhuri bi, Ọvaar Ibinọkpaabyi otzim bọng obina k'Ijip, k'ẹfa chẹ ch'ideden.  
\v 10 Cho kpenamkpen, bọng akhaambi ahok ndọhna nna, k'ogbe kwẹ. 
\p  
\v 11 “Mada Ọvaar Ibinọkpaabyi ótzima bọng opyiri k'irek s'abaKenaan, ọtzọkha sẹ ọnang bọng, mach'iwa ochekhi ọnang bọng, ọmaana abatte pabọng.  
\v 12 Bọng dọkha achedenva p'ẹbhọhr kpenamkpen adibha anang Ọvaar Ibinọkpaabyi. Achedenva p'ijinọng p'etzirakpo pyabọng ade p'Ọvaar Ibinọkpaabyi.  
\v 13 Bọng dima arukhimaan-dim abhek ocheden-nwa kw'ẹnyanyaang, yina, idikha bọng ani chẹ abhekhi, phyakh-ẹ ekhokhora. Kẹ wọ osi, bọng akhaambi abhek achedenva pabọng p'ijinọng kpenamkpen. 
\p  
\v 14 “Ikhina va pabọng p'ijinọng abọbhi bọng bi, ‘Ọdadaami nwa oyini yan o?’ Gbaak bẹ bi, ‘Iwa Ọvaar Ibinọkpaabyi otzim man obina k'Ijip, k'irerek s'ebira, k'ẹfa chẹ ch'ideden.  
\v 15 Mada Phero otzim oho-gaangi obhum bi, otte man ọbọhk mofona, wa Ọvaar Ibinọkpaabyi ofhu achedenva p'anọngẹya, ọmaana pa etzirakpo p'Ijip. Odik nwa wọ motzima yina ndima ocheden-nwa kw'ijinọng kw'otzirattọhk kpenamkpen, nsi ẹjafọhni nnang Ọvaar Ibinọkpaabyi, ifha motzima obhek achedenva paman kpenamkpen p'ijinọng.’  
\v 16 Ma wọ óde mach'ẹkhọhkha ọnang bọng bi, wa Ọvaar Ibinọkpaabyi otzim ẹfa chẹ ch'ideden, ọrọbha man k'ebira ch'Ijip.” 
\s1 Ejekha ch'Ẹraanga-khora 
\p  
\v 17 Mada Phero on-otte anọng mba ọbọhk bẹ afona, wa Ibinọkpaabyi bẹ kotzim orenga k'ẹkhọma cha Philistiya, kw'eden ekhum-okhuma, da iwa Ibinọkpaabyi ochibhi bi, “Idikha bẹ attem egbong abẹ k'eden, bẹ afha abhona achibhi pabẹ, akpa nnam k'Ijip.”  
\v 18 Mẹ wọ, wa Ibinọkpaabyi otzima bẹ ọkhọri k'eden ch'ibe s'anọng an-arukhi, s'ikkeri itzitzikha k'Ẹraanga-khora. Wa anọng p'Israẹl ado for s'egbong atzima abina k'Ijip. 
\p  
\v 19 Iwa Mosẹs okpokhi akhọbhi pa Josẹph, okhuri da iwa Josẹph okk'va p'Israẹl ọsa bẹ atzọkha anwọhngi. Kẹ Josẹph okk'obena bi, “K'odik ọkkọkka Ibinọkpaabyi ọ́kkaana bọng ọkkaana e. Bọng akhaambi akpokhi akhọbhi paam m'ibe nna, atzima afona.” 
\p  
\v 20 Mada bẹ abin ka Sukọt, bẹ abhingi k'Ẹtam k'ọkhaan-ọkhaan kw'ibe s'anọng an-arukhi.  
\v 21 Wa Ọvaar Ibinọkpaabyi otzim eboni ch'ebe iduduma ochi bẹ eden k'ẹya, obiro otzima ekpon ch'ebe iduduma ọnang bẹ iyaan k'erungi, ifha bẹ afha asi orenga nwa k'ẹya, ọmaana k'erungi.  
\v 22 Wa eboni nda ch'ebe iduduma k'ẹya, ọmaana ekpon ch'ebe iduduma k'erungi, bẹ k'itzitzikha s'anọng p'Israẹl, kabin. 
\c 14  
\p  
\v 1 Mẹ wọ, Ọvaar Ibinọkpaabyi oben Mosẹs bi,  
\v 2 “Gbaak anọng p'Israẹl bi, bẹ akpa nnam atza abhing abaanga Pi-Hahirọt kw'owobh k'ottem kwa Migdol, ọmaana ọraanga kw'ideden. Tte bẹ abhing k'ọraanga kw'ideden ọkhaan-ọkhaan, akkeri Baal-Zẹphọn itzitzikha.  
\v 3 Phero ón-ochibhi bi, anọng p'Israẹl am-awen akhọri irerek nna k'ikkokkoni, s'ikpori bẹ imaana k'ibe s'anọng an-arukhi.  
\v 4 Kaam ńsi Phero ọgaangi eho, okhubh bẹ ka nnam. Yina, kaam ńnenga ka Phero ọmaana k'agbongnọng pẹ, ńdọkha abarada ka for saam. Anọng mba p'Ijip áronga bi, kaam wọ nde Ọvaar Ibinọkpaabyi.” Mẹ wọ, anọng p'Israẹl asi mando. 
\p  
\v 5 Mada Phero kw'ode ọvaarnọng kw'Ijip ọbhaang bi, anọng p'Israẹl akk'arọbha afona, Phero ọmaana akhaan-nọng pẹ abhona achibhi pabẹ, aben bi, “Bọng odik kw'amosi ma? Mokk'anọng mba ọbọhk ọtta bẹ afona, ọtzọhm fabẹ okk'man obiro odimi.”  
\v 6 Mẹ wọ, odo akpaar pẹ pa nnyanyaang mindọr ewobha, obiro otzima agbongnọng pẹ bi, bẹ atzọn-ẹ abẹ.  
\v 7 Otzima akpaar akkakka pẹ pa nnyanyaang mindọr, ẹnọhna obhiri arọbh jobh, ttara k'akpaar pa nnyanyaang mindọr p'Ijip biphyir, ttara adeho p'atzim bẹ biphyir eden.  
\v 8 Ọvaar Ibinọkpaabyi osi Phero kw'ode ọvaarnọng kw'Ijip ọgaangi ettem, okhubh anọng p'Israẹl ka nnam p'am-arenga ekkengitza, afona.  
\v 9 Anọng p'Ijip, ọmaana nnyanyaang sa Phero, ọmaana akpaar pẹ pa nnyanyaang mindọr, ọmaana ayaari-nnyanyaang, ttara agbongnọng pẹ biphyir, akhubh anọng p'Israẹl ka nnam, agwora bẹ kẹ da bẹ abhingi k'ọraanga kw'ideden, ọbaanga Pi-Hahirọt kw'okkeri Baal-Zẹphọn itzitzikha. 
\p  
\v 10 Mada anọng p'Israẹl atzini chen are bi, Phero ttara anọng p'Ijip areng akwuma ka nnam, ojora osi bẹ. Bẹ abhom amọng ayeri Ọvaar Ibinọkpaabyi.  
\v 11 Bẹ an-aben Mosẹs bi, “Ma da mpekhubh nni k'Ijip nde, kẹ wọ osi atzima man akwu m'ibe s'anọng an-arukhi bi, mope o? Bọng odik wọ kw'asi man ma bi, atzima man abina k'Ijip o?  
\v 12 Wa man kọ kobeni bi, ‘Atte man ọbọhk mowobha, mosi itzọhm ọnang anọng p'Ijip?’ Ira ojibh ọtzam bi mosi itzọhm ọnang anọng p'Ijip, ọyọhnga bi, mokwu ope m'ibe nna s'anọng an-arukhi!” 
\p  
\v 13 Mosẹs obhina bẹ bi, “Tte oningi bọng ojor. Bọng do abe, kkeri mayina, bọng áre ẹnaanga ch'Ọvaar Ibinọkpaabyi ọ́nang bọng. Anọng mba p'Ijip pa bọng are mayina ma, bọng bẹ dọk káre e.  
\v 14 Ọvaar Ibinọkpaabyi wọ ósi erima chabọng, bọbọng kingẹ wobha \it bi sẹẹbh\it*.” 
\p  
\v 15 Mẹ wọ, Ọvaar Ibinọkpaabyi oben Mosẹs bi, “Ode yan kwa kọ am-abhom ayer-m o? Ben anọng p'Israẹl achina ororo k'orenga.  
\v 16 Tzini ochikhura kwọ, anemi ọbọhk atzena k'ọraanga kw'ideden ifha asi abhaangi, anọng p'Israẹl arenga k'irerek ajekha.  
\v 17 Kaam ńsi anọng p'Ijip agaangi nho, ifha bẹ ákhubh bẹ ka nnam. Kaam mbiri ńnenga ka Phero, ọmaana agbongnọng pẹ biphyir, ọmaana akpaar pẹ pa nnyanyaang mindọr, ttara ayaari-nnyanyaang pẹ, ńdọkha abarada.  
\v 18 Anọng p'Ijip árọnga bi, kaam wọ nde Ọvaar Ibinọkpaabyi, mada nnenga ka Phero, ọmaana akpaar pẹ pa nnyanyaang mindọr, ttara k'ayaari nnyanyaang pẹ ndọkha abarada.” 
\p  
\v 19 Mẹ wọ, itzọhmi s'Ibinọkpaabyi s'ikk'arim-egbong p'Israẹl eden im-icha, in-ikpa nnam itza iwobha bẹ ka nnam. Eboni ch'ebe iduduma ebere ebina bẹ k'itzitzikha, ọtza ebe bẹ ka nnam,  
\v 20 kw'ode ottem kw'agbongnọng p'Ijip ọmaana p'Israẹl. M'erungi biphyir eboni nda etzima ipyerungi ekwu k'okhubha wani, ọmaana iyaan k'okhubha nwonggo. Mẹ wọ, ọnọng kw'ofha orenga ọbaanga oyok m'erungiwu nduma biphyir kode. 
\p  
\v 21 Mẹ wọ, Mosẹs onemi ọbọhk kwẹ otzena k'ọraanga kw'ideden, m'erungiwu nduma biphyir Ọvaar Ibinọkpaabyi otzima ọphapha kw'ọgaang-ọgaangi kw'ofon kẹ da ewuchen em-eyin, okpena asi maa ogbin oyin. Asi mba abhaangi.  
\v 22 Wa anọng p'Israẹl arenga k'ogbin m'ẹraangattem, ttara asi p'abe mach'echumi k'odimbọhk, ttara ka kwabọhk kwabẹ. 
\p  
\v 23 Anọng p'Ijip, ọmaana nnyanyaang sa Phero, ọmaana akpaar pa pẹ nnyanyaang mindọr, ttara ayaari-nnyanyaang pẹ biphyir, akhubh bẹ ka nnam adim k'ẹraangattem ch'ọraanga kw'ideden.  
\v 24 Mẹ ekpekpebha, Ọvaar Ibinọkpaabyi orenga k'ekpon ch'ebe iduduma, ọmaana k'eboni ore agbongnọng p'Ijip, mẹ wọ, okhe bẹ ka dama-dama.  
\v 25 Osi ndọkhi s'akpaar pa nnyanyaang mindọr irọbha, maa orenga ọyak bẹ. Mẹ wọ e, anọng p'Ijip an-aben bi, “Tte motte anọng p'Israẹl ọbọhk! Kkeri Ọvaar Ibinọkpaabyi wọ om-orima Ijip abẹ ma, ka eho chabẹ.”  
\v 26 Mẹ wọ, Ọvaar Ibinọkpaabyi oben Mosẹs bi, “Nemi ọbọhk kwọ atzena k'ọraanga kw'ideden, ifha asi akpa nnam anwa akpori anọng p'Ijip, ọmaana akpaar pabẹ pa nnyanyaang mindọr, ttara ayaari nnyanyaang pabẹ.”  
\v 27 Mosẹs e onemi ọbọhk kwẹ otzena k'ọraanga kw'ideden. M'owukhobha ọraanga nwa akpa nnam owobha mach'ira owobh. Anọng p'Ijip am-akhonga ọrọrọbh, Ọvaar Ibinọkpaabyi okpena bẹ biphyir okhe k'ọraanga kw'ideden.  
\v 28 Asi mba abhobh abhori akpaar pa nnyanyaang mindọr, ọmaana ayaari nnyanyaang, ttara agbongnọng pa Phero biphyir p'akk'anọng p'Israẹl akhubha ka nnam, anwa k'ọraanga kw'ideden. Ọnọng manda wani kw'ọnang kode. 
\p  
\v 29 Yina, wa anọng p'Israẹl areng k'ogbin m'ẹraangattem, ch'asi abe mach'echumi k'odimbọhk ttara ka kwabọhk kwabẹ.  
\v 30 M'ewu nduma, Ọvaar Ibinọkpaabyi ọkkaana anọng p'Israẹl ka mbọhk s'anọng p'Ijip. Wa anọng p'Israẹl an-are da anọng p'Ijip an-ayim abukh-abukhi k'ọraanga ọkhaan-ọkhaan.  
\v 31 Mẹ wọ e, mada anọng p'Israẹl are ẹfa ch'ideden ch'Ọvaar Ibinọkpaabyi otzim okhema anọng p'Ijip, bẹ akhaama ojora f'Ọvaar Ibinọkpaabyi, bẹ abira akhaama nnam-ophephe ka kẹ, ọmaana ka ọtzọhmnọng kwẹ Mosẹs. 
\c 15  
\s1 Emọng cha Mosẹs ọmaana Miriyam akkọhni 
\p  
\v 1 Mẹ wọ, Mosẹs ọmaana anọng p'Israẹl akkọhn ẹmọng nda anang Ọvaar Ibinọkpaabyi aben bi, 
\q1 “Kaam ńkkọhn nnang Ọvaar Ibinọkpaabyi 
\q2 okhuri k'ekhema-barada chẹ. 
\q1 Kẹ okk'ẹnyanyaang, ọmaana ọyaar-ẹnyanyaang, 
\q2 otzini otzem k'ọraanga kw'ideden. 
\q1  
\v 2 “Ọvaar Ibinọkpaabyi wọ ode ẹfa chaam, ọmaana ẹmọng cha kaam nkkọhni, 
\q2 Kẹ wọ ode ẹnaanga chaam. 
\q1 Kẹ wọ ode Ibinọkpaabyi kwaam. Kaam ńnang-ẹ ẹtzọhnga, 
\q2 kaam ńdini Ibinọkpaabyi kw'otte kwaam okpobh k'ẹrọng. 
\q1  
\v 3 Ọvaar Ibinọkpaabyi wọ ode okkenggitza, 
\q2 kẹ okpen Ọvaar Ibinọkpaabyi. 
\q1  
\v 4 Kẹ okk'akpaar pa Phero pa nnyanyaang mindọr, ọmaana agbongnọng pẹ, 
\q2 ọtzọkha otzem k'ọraanga kw'ideden. 
\q1 Ọtzọkha akhaan-nọng pa Phero p'abari odik ọtzam, 
\q2 odimi k'Ẹraanga-khora. 
\q1  
\v 5 Asi donga-dong mba akk'bẹ abhọri, 
\q2 bẹ atzem k'esiwọr mach'ọtza. 
\q1  
\v 6 “O Ọvaar Ibinọkpaabyi, odimbọhk kwọ, 
\q2 ode ẹfa ch'ideden. 
\q1 O Ọvaar Ibinọkpaabyi, atzim ẹfa ch'odimbọhk kwọ asi, 
\q2 ọttattaanga-nọng araami. 
\b  
\q1  
\v 7 “K'ededen ch'ẹvaar chọ, 
\q2 akhem anọng p'attaang anang-ọ. 
\q1 Kọ atte ittemdọkhiji sọ ọbọhk, 
\q2 ikwọmi attattaanga-nọng pọ mach'araraari-bukhi. 
\q1  
\v 8 Agwum ọwọhng kwọ, 
\q2 asi atzobha, abe \it bi pyir\it*, 
\q1 asi p'abhobh-obhobh an-arimi agaangi, mach'echumi, 
\q2 k'esittem asi an-abhakhi arim-orimi. 
\q1  
\v 9 “Ọttattaanga-nọng ọsi ẹmma, oben bi, 
\q2 ‘Kaam ńgubh bẹ ka nnam, mbiri ńgọbha bẹ. 
\q1 Kaam ńchi ọgbọm k'ekpo pyabẹ; 
\q2 Kaam ńchi pyẹ ttara agwọriji paam. 
\q2 Ọkkangkkaang kwaam wọ kwa ńdima mfhu bọng, 
\q2 ńdima ọbọhk kwaam ńdimi bẹ.’ 
\q1  
\v 10 Agwum ọwọhng kwọ, 
\q2 asi anwa akpori bẹ, 
\q1 bẹ atzem k'esiwọr, 
\q2 mach'opo otzemi k'esiwọr. 
\b  
\q1  
\v 11 “O Ọvaar Ibinọkpaabyi, k'ottem kw'idik s'anọng akpobh biphyir, mbọng vọ obeng-ọ abẹ? 
\q2 Anyi wọ obeng-ọ abẹ? 
\q3 K'ẹvaar, awurada pọ ayọhng bẹ biphyir, 
\q3 bẹ akhaam ojora fọ, k'ikpokpobha sa bẹ anang-ọ, 
\q3 kọ asi idik s'ipe anọng for. 
\q1  
\v 12 Kọ anemi odimbọhk kwọ kw'ẹfa, 
\q2 irerek imyi attattaanga-nọng pọ. 
\b  
\q1  
\v 13 “K'idadaakha sọ s'ini ottotto ikhaam, 
\q2 átzima anọng pa kọ akk'abhekha eden, 
\q1 átzima bẹ eden k'ẹfa chọ, 
\q2 achina k'irukhabe sọ s'awurada. 
\q1  
\v 14 Idibhon íbhaanga idik nna, opoma osi bẹ, 
\q2 ojora ọ́bọkha anọng pa Philistiya. 
\q1  
\v 15 Ojora ọ́bọkha avaarnọng p'obhon kw'Edom, 
\q2 opoma ọ́nwa adabhi pa Moab. 
\q1 Ẹfa ẹha avaarnọng pa Kenaan; 
\q2  
\v 16 opoma ttara ojora ọ́nwa bẹ. 
\q1 K'ẹfa chọ, 
\q2 bẹ amun k'ibe rani, mach'ẹtzakpa 
\q1 matzẹmaa anọng p'akk'akkaana, akwọbha afona, O Ọvaar Ibinọkpaabyi, 
\q2 matzẹmaa anọng p'akk'abhekha akwọbha afona. 
\q1  
\v 17 Kọ átzima anọng mba adim kẹ, abira attima bẹ aranga k'egbegbeho ch'ede chọ. 
\q1 O Ọvaar Ibinọkpaabyi, ibe sa kọ asi mach'irukhabe sọ, 
\q2 ide owurada-họhm kw'asi ttara mbọhk sọ, o Ọvaar Ibinọkpaabyi. 
\q1  
\v 18 Ẹvaar ch'Ọvaar Ibinọkpaabyi éwobha, 
\q2 matzẹmaa ogbe ode.” 
\p  
\v 19 Mada nnyanyaang sa Phero, ọmaana akpaar pẹ pa nnyanyaang mindọr, ọmaana ayari-nnyanyaang pẹ adimi k'asi, Ọvaar Ibinọkpaabyi osi asi p'ọraanga kw'ideden anwa akpori bẹ. Yina, osi anọng p'Israẹl arenga k'irerek k'ottem kw'ọraanga.  
\v 20 Mẹ wọ, Miriyam, kw'iwa ode ọsẹ-jaakhi kw'Ibinọkpaabyi, obiro ode ọgbaanọkka kw'Aarọn, ọtzọkha ebin ekhirachẹ, otzima panọng p'Israẹl eden bẹ akhir mbin, abira atzubh.  
\v 21 Miriyam ọkkọhn ọnang bẹ, oben bi; 
\q1 “Bọng kkọhn anang Ọvaar Ibinọkpaabyi, 
\q2 okhuri ekhema-barada chẹ, 
\q1 Kẹ okk'ẹnyanyaang, ọmaana ọyaar-ẹnyanyaang, 
\q2 otzini otzem k'ọraanga kw'ideden.” 
\s1 Asi p'ajobh-ojobhi 
\p  
\v 22 Mẹ wọ, Mosẹs otzima anọng p'Israẹl eden bẹ abina aji Ẹraanga-khora, achina k'ibe s'anọng an-arukhi sa Shur. Bẹ arenga k'iwu ittaan k'ibe s'anọng an-arukhi, bẹ asi kare.  
\v 23 Mada bẹ apyiri ka Mara, bẹ asi pa Mara kafha agwo, okhuri da asi mba ajobh-ojobhi. Kẹ wọ iwa osi bẹ ayeri ibe nna Mara.  
\v 24 Mẹ wọ, anọng p'Israẹl anwọhni anang Mosẹs, aben bi, “Mbọng fa mogwo o?” 
\p  
\v 25 Mẹ wọ, Mosẹs obhom ọkpẹkhi Ọvaar Ibinọkpaabyi, Ọvaar Ibinọkpaabyi ọkhọhkh-ẹ ommenkpakpa, kwa Mosẹs odungi ọbhari k'asi, asi p'ajobh-ojobhi an-abhakhi adam-ọdam. 
\p Ma Mara, Ọvaar Ibinọkpaabyi ọnang anọng p'Israẹl aphaangi, ọmaana ndọhna k'odem kwa bẹ aruk, obiro oyoma bẹ, ifha ore s'ode na bẹ afha ahok aphaangi pẹ.  
\v 26 Oben bi, “Idikha bọng afha átzọhkha ogbe áyong-m itzọhng, asi idik s'itzor-otzor ka chen paam, bọng abira ahok aphaangi paam, kaam bọng ikhọmmana sa nnangi anọng p'Ijip kínang. Kaam wọ nde Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kwabọng, kw'obin bọng k'ikhọmmana.” 
\p  
\v 27 Mẹ wọ, anọng p'Israẹl atte Mara ọbọhk achina k'Elim. M'Elim, akhekhaho jobh obhiri afa, ọmaana aji arọbh attaan obhiri jobh awobh mẹ. Wa anọng p'Israẹl akwu abhing abaanga ngekha nnuma. 
\c 16  
\s1 Ọchattọhk fa Mana 
\p  
\v 1 Wa k'iwu chi s'ophe kw'ottong afa, mada anọng p'Israẹl akk'abina k'Ijip, bẹ biphyir abina orenga k'Elim apyiri k'ibe s'anọng an-arukhi sa Sin, s'iwobh k'ottem kw'Ẹlim, ọmaana Sinai.  
\v 2 M'ibe nna s'anọng an-arukhi rọ s'ebhonmọr ch'Israẹl biphyir ẹnwọhni, ẹttaanga anang Mosẹs ọmaana Aarọn.  
\v 3 Anọng p'Israẹl aben bẹ bi, “Ira ojibh ọtzam bi, mope ka mbọhk s'Ọvaar Ibinọkpaabyi k'Ijip, kẹ da mowobh ẹwọr ochi nden, ọmaana ẹchakpo ọdọdọk biphyir mach'ọdaakhi man. Yina, bọng akk'man atzima akwu m'ibe nna s'anọng an-arukhi bi, okwo ofhu anọngeya mba biphyir.” 
\p  
\v 4 Mẹ wọ, Ọvaar Ibinọkpaabyi oben Mosẹs bi, “Kaam ńdọhm brẹd kw'ótzebh mach'ẹrọng ch'efon k'ọrọngkpakpa nnang bọng. K'ewu kpenamkpen anọng mba ám-ayin k'iyaan atza akpokhi f'obenga bẹ. Kaam ńnenga m'eden nda ńyoma bẹ, ifha nne ode na bẹ átzor ka ndọhna saam.”  
\v 5 Ottong iwu izadani, bẹ asi ọchattọhk fa bẹ akpokhi, f'ode igbe ifa ka fa bẹ am-akkekkeni akpokhi, k'iwu ọdọdọk. 
\p  
\v 6 Mẹ wọ, Mosẹs ọmaana Aarọn aben anọng p'Israẹl biphyir bi, “Sa k'ẹchọhkha, bọng árong-oronga bi, Ọvaar Ibinọkpaabyi wọ otzim bọng obina k'Ijip.  
\v 7 Bọng abira áre abarada p'Ọvaar Ibinọkpaabyi ore k'ekpebha, okhuri bi, kẹ ọkk'ẹnwọhni cha bọng attaanga anang-ẹ ọbhaanga. Maman ode macha bọng anọng, pa bọng anwọhni, attaanga anang o?”  
\v 8 Mosẹs obiro oben bi, “Bọng árong-oronga bi, Ọvaar Ibinọkpaabyi wọ, mada ọnang bọng nden sa bọng achi k'ẹchọhkha, ọmaana brẹd kwa bọng aror bi, achi k'ekpebha, okhuri bi, kẹ ọkk'ẹnwọhni cha bọng attaang anang-ẹ ọbhaanga. Maman ode macha bọng anọng, pa bọng anwọhni, attaanga anang o? K'odik ọkkakka, bọng am-anwọhni, attaanga anang Ọvaar Ibinọkpaabyi e, maman arang e.” 
\p  
\v 9 Mẹ wọ, Mosẹs oben Aarọn bi, “Kọ gbaak anọng p'ebhonmọr ch'Israẹl biphyir bi, bẹ arenga ayin Ọvaar Ibinọkpaabyi k'itzitzikha, okhuri bi, kẹ okk'ẹnwọhni chabọng ọbhaanga.” 
\p  
\v 10 Mada Aarọn ọm-ọgbaak anọng p'ebhonmọr ch'Israẹl biphyir atzim, bẹ akkeri k'ibe s'anọng an-arukhi, are abarada p'Ọvaar Ibinọkpaabyi p'ayini k'eboni. 
\p  
\v 11 Ọvaar Ibinọkpaabyi oben Mosẹs bi,  
\v 12 “Kaam nkk'ẹnwọhni ch'anọng p'Israẹl mmaanga e. Kọ gbaak bẹ bi, ‘K'ẹchọhkha bọng áchi etzen, k'ekpebha, bọng áchi brẹd maa bọng adọbh. Mẹ wọ kwa bọng átzima áronga bi, kaam wọ nde Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kwabọng.’ ” 
\p  
\v 13 Mẹ wọ, m'ẹchọhkha nduma, ọnọhn oyin k'ọhaabh maa obubha ibhingabe \it bi waam\it*. K'ekpebha, odiri-bẹrẹbẹrẹ otzebh ọkhọri ibhingabe biphyir.  
\v 14 Mada odiri-bẹrẹbẹrẹ okk'odimi, ekpo mach'abubuma eyin ebubha m'irerek \it bi gbii.\it* k'ibe s'anọng an-arukhi.  
\v 15 Mada anọng p'Israẹl are fẹ, bẹ fẹ karong, mẹ wọ, bẹ an-abọbh ayok bi, “Bọng ọttọhk-dema vọ ma?” 
\p Mosẹs oben bẹ bi, “Brẹd kw'Ọvaar Ibinọkpaabyi ọnangi bọng bi, bọng achi wọ e.  
\v 16 Ma wọ ode ndọhna s'Ọvaar Ibinọkpaabyi ọkk'ọnanga bi, ‘Ọnọng-ọnọng okpokhi fẹ mach'ọdaakh-ẹ e. Ọnọng-ọnọng okpokhi ogbobhimbọhk, atzor k'ọnọngmik kw'ikhira sọ.’ ” 
\p  
\v 17 Wa anọng p'Israẹl asi macha bẹ agbaakhi bẹ. Anọng bani akpokhi k'ọhaabh, bani akpokhi ibebaa.  
\v 18 Mada bẹ an-ayom k'agbobhimbọhk, bẹ an-are bi, ayok p'akpokhi k'ọhaabh bẹ kpọng kakpokhi. Ayok p'abira akpokhi ibebaa, bẹ f'ọkhar kpọng kabira akpokhi. Ọnọng-ọnọng okpokhi macha fẹ obeng-ẹ. 
\p  
\v 19 Mẹ wọ, Mosẹs oben bẹ bi, “Ọnọng manda wani oningi ọchattọhk mva ohokhi maa ewu ehobha o.” 
\p  
\v 20 Yina, bẹ ayok bani Mosẹs itzọhng kayong. Bẹ ahok ọchattọhk mva maa ewu ehobha. K'ekpebha fẹ ochu ọnwa nniri, obiro ọttẹwọr ohom. Mẹ wọ e, ettem ẹkhọm Mosẹs etzima etzor bẹ. 
\p  
\v 21 Ekpebhawu kpenamkpen, ọnọng-ọnọng okpokhi macha fẹ obeng-ẹ. Yina, ekpikhira ẹkhọmi, fa bẹ akpokhi arik oyona biphyir.  
\v 22 Kẹ ewu ch'ettong izadani, bẹ akpokhi f'ode igbe ifa, ọnọng-ọnọng agbobhi-mbọhk afa. Wa adeho p'obhon atzọkha odik nwa atza agbaak Mosẹs.  
\v 23 Mosẹs oben bẹ bi, “Ma wọ ode ndọhna s'Ọvaar Ibinọkpaabyi ọnangi bi, ‘Ophyini ode ẹwọhngkwokhawu, ẹwọhngkwokhawu ch'awurada ẹnang Ọvaar Ibinọkpaabyi. Mẹ wọ, bọng bọm ọchattọhk kpenamkpen fa bọng abọm, bọng awọhn kpenamkpen fa bọng awọhn. Bọng hok kpenamkpen f'orik maa opyiri ekpebha.’ ” 
\p  
\v 24 Mẹ wọ, bẹ asi macha Mosẹs ọtzọhni bẹ, bẹ ahok f'orikhi maa ewu ehobha. Wa fẹ kohomi, nniri kobiro ọnwa.  
\v 25 Mosẹs oben bi, “Bọng chi fẹ mayina, okhuri bi, mayina ode ẹwọhngkwokhawu ọnang Ọvaar Ibinọkpaabyi. Bọng manda vani k'irerek mayina, káre e.  
\v 26 Bọng am-akpokhi fẹ k'iwu izadani, yina, ottong iwu izenamfa, kw'ode ẹwọhngkwokhawu, manda vani kóde.” 
\p  
\v 27 Kaambi mẹ wọ, ottong iwu izenamfa, anọng bani ayin k'iyaan bi bẹ atza akpokhi ọchattọhk, bẹ manda vani kare. 
\p  
\v 28 Mẹ wọ, Ọvaar Ibinọkpaabyi oben Mosẹs bi, “Ogbe obhir otzuma yan, kwa bọng ábhum asana paam, ọmaana aphaangi paam ohohok o?  
\v 29 Bọng jima bi, Ọvaar Ibinọkpaabyi okk'bọng ẹwọhngkwokhawu ọnanga, kẹ wọ osi ottong iwu izadani, ọm-ọnang bọng brẹd kw'iwu ifa. Ottong iwu izenamfa, ọnọng-ọnọng owobha k'ibe s'owobh. Ọnọng oningi k'iyaan oyini.”  
\v 30 Mẹ wọ, anọng mba akwokha ọwọhng k'ewu ch'ettong izenamfa. 
\p  
\v 31 Wa anọng p'Israẹl ayeri brẹd nwa Mana\f + \fr 16.31 \ft Mana oyini bi, bọng ọttọhk vọ ma?\f*. Wa fẹ owuri mach'echimọma cha koriyanda, fẹ ọdaam mach'obubhkpa kwa bẹ atzim akhọkhọnana asi.  
\v 32 Mosẹs oben bi, “Ma wọ ode ndọhna s'Ọvaar Ibinọkpaabyi, ‘Bọng kpokhi ogbobhimbọhk kwa Mana ahok igbọ s'íkwu k'ororo, ifha bẹ are brẹd kw'iwa nnangi bọng achi k'ibe s'anọng an-arukhi, mada ndim bọng mbina k'Ijip.’ ” 
\p  
\v 33 Mosẹs oben Aarọn bi, “Tọkha ogbobhimbọhk kwa mana awọna k'ogbere. Atzọkha ogbere nwa abera k'itzitzikha s'Ọvaar Ibinọkpaabyi, owobha otzik igbọ s'íkwu k'ororo.” 
\p  
\v 34 Aarọn osi macha Ọvaar Ibinọkpaabyi okk'Mosẹs ọtzọhna, ọtzọkha ogbere nwa obera k'itzitzikha s'Ẹkkọhbhi cha Echekhi, ifha owobha mẹ.  
\v 35 Wa anọng p'Israẹl achi Mana ka cho arọbh afa, maa bẹ apyiri k'irerek s'anọng arukhi. Bẹ achi Mana maa bẹ apyiri k'enem cha Kenaan. 
\p  
\v 36 Omer ode ogbobhimbọk wani k'agbobhimbọhk jobh p'asi ẹpha kw'ode ọkwakkama. 
\c 17  
\s1 Asi p'afon k'itzakpa 
\p  
\v 1 Wa anọng p'ebhonmọr ch'Israẹl biphyir abina k'ibe s'anọng an-arukhi sa Sin, arenga k'obe k'obe mach'Ọvaar Ibinọkpaabyi ọtzọhni bẹ. Bẹ asi ibhingabe ka Rẹphidim, yina, wa asi p'anọng mba agwo, kade.  
\v 2 Mẹ wọ, wa bẹ achi Mosẹs akkaam aben bi, “Nang man asi mogwo.” 
\p Mosẹs obhina bi, “Bọng am-achi-m akkaam pa mbọng o? Okhuri yan kwa bọng am-akhe Ọvaar Ibinọkpaabyi k'eyoma o?” 
\p  
\v 3 Yina, wa asi adaak anọng mba maa, bẹ anwọhni attaanga anang Mosẹs, aben bi, “Okhuri yan kw'atzim man, ọmaana va paman, ttara etzirakpo pyaman abina k'Ijip bi, mokwu ope ma k'isi-dadaakha o?” 
\p  
\v 4 Mẹ wọ, Mosẹs obhom ọkpẹkhi Ọvaar Ibinọkpaabyi, oben bi, “Kaam ńsi yan ọmaana anọng mba o? Ma, bẹ an-ado for sa bẹ atzọbh-m atza.” 
\p  
\v 5 Ọvaar Ibinọkpaabyi obhina Mosẹs bi, “Chi anọng mba eden. Kọ tzima adeho bani p'Israẹl, atzọkha ochikhura kw'atzim abun k'ọraanga kwa Nile, arọhng.  
\v 6 Kaam ḿbọ-ọ k'itzitzikha k'itzakpa sa Horẹb. Bun ochikhura kwọ m'itzakpa nna, asi áyin-oyin mẹ p'anọng mba agwo.” Mẹ wọ, wa Mosẹs osi mando, m'itzitzikha s'adeho mba p'Israẹl.  
\v 7 Wa Mosẹs oyeri ibe nna Masa\f + \fr 17.7 \fq Masa \ft K'eHiburu oyini \fqa Eyoma.\f*, ọmaana Mẹriba\f + \fr 17.7 \fq Mẹriba\ft K'eHiburu oyini \fqa Ẹtta, akkaam ochichi.\f*, okhuri bi, mẹ wọ kw'anọng p'Israẹl achẹ-ẹ akkaam, bẹ abira ayoma Ọvaar Ibinọkpaabyi aben bi, “Ma Ọvaar Ibinọkpaabyi owobh ma ttara man ma o?” 
\s1 Israẹl akhem ab'Amalẹk 
\p  
\v 8 Wa ab'Amalẹk akwu arima anọng p'Israẹl abẹ ka Rẹphidim.  
\v 9 Mẹ wọ e, Mosẹs oben Joshua bi, “Tzekha ajinọng bani paman, atza arima ab'Amalẹk abẹ. Ophyini kaam ḿbe k'egbegbeho ebir-ebir, ttara ochikhura kw'Ibinọkpaabyi k'ọbọhk kwaam.” 
\p  
\v 10 Mẹ wọ, Joshua orima ab'Amalẹk abẹ macha Mosẹs ọkk'ẹfa ọnanga. Mosẹs, ọmaana Aarọn, ttara Hur afona achina k'egbegbeho ebir-ebir.  
\v 11 Ogbe kpenamkpen kwa Mosẹs ọyaangi mbọhk sẹ k'ẹrọng, anọng p'Israẹl akhema. Yina ogbe kpenamkpen kw'ọhak mbọhk sẹ, ab'Amalẹk akhema.  
\v 12 K'ogbe kwa mbọhk nkwok Mosẹs, bẹ atzini ọtza ahokh-ẹ owobha ẹwọr. Aarọn, ọmaana Hur, abọkha mbọhk sẹ atzima k'ẹrọng, ọnọng-ọnọng k'ọbọhk kwẹ. Wa mbọhk sẹ nwobh mando maa ẹchọhkha-kpikhira edimi.  
\v 13 Mẹ wọ, wa Joshua otzima ọkkangkkaang okhema agbong-nọng p'Amalẹk. 
\p  
\v 14 Mẹ wọ, Ọvaar Ibinọkpaabyi oben Mosẹs bi, “Kọ kkẹr idik nna ka nnwẹr, mach'odik kw'ejima. Akhaambi asi Joshua ọbhaanga kwẹ, okhuri bi, kaam ńdimi che ch'Amalẹk k'ọyagbin biphyir-phyir.” 
\p  
\v 15 Mẹ wọ e, Mosẹs osi ijafọhnibe, oyeri sẹ, “Ọvaar Ibinọkpaabyi wọ ode Okhem kwaam.”  
\v 16 Oben bi, “Okhuri da bẹ atzini mbọhk k'ẹrọng atzena k'ẹvaarchi ch'Ọvaar Ibinọkpaabyi. Ọvaar Ibinọkpaabyi wọ órima ab'Amalẹk abẹ k'igbọ k'igbọ.” 
\c 18  
\s1 Jẹtro odibh Mosẹs 
\p  
\v 1 Wa Jẹtro kw'ode ọfọhnẹja kwa Midiyan, obiro ode otte kwa kwanọng kwa Mosẹs, ọbhaanga odik kpenamkpen kw'Ibinọkpaabyi ọkk'ọsa ọnang Mosẹs, ttara anọng p'Israẹl, ọmaana eden ch'Ọvaar Ibinọkpaabyi okk'orenga ọrọbha anọng p'Israẹl k'Ijip. 
\p  
\v 2 Mada Mosẹs okk'kwanọng kwẹ Zipọra ọtzọhma bi, otza ebhinga k'otte Jẹtro, wa otte ọtzọkh-ẹ,  
\v 3 ọmaana va pẹ afa. Wa Mosẹs okpe oyok wani Gẹrshọm, oben bi, “Kaam nkk'okhekhenọng nna nda k'irerek s'anọng.”  
\v 4 Okpe oyok nwonggo Eliyeza, oben bi, “Ibinọkpaabyi kw'otte kwaam okpobh, wọ iwa ode ọkkaan kwaam. Kẹ wọ ọkkaan-m, ọrọbh-m ka mbọhk sa Phero.” 
\p  
\v 5 Wa Jẹtro, otte kwa kwanọng kwa Mosẹs otzima va mba afa, ttara kwanọng kwa Mosẹs otza okhebh-ẹ k'ibe s'anọng an-arukhi, kẹ da iwa obhingi, ọbaanga egbegbeho ch'Ibinọkpaabyi.  
\v 6 Wa okk'ẹkkaabha ọtzọhma ọnang Mosẹs bi, “Kaam Jẹtro, otte kwa kwanọng kwọ, ndim kwanọng kwọ, ttara va pẹ p'ijinọng afa, nkwuma nkwu ngebh-ọ e.” 
\p  
\v 7 Mẹ wọ, Mosẹs okhubh bẹ k'eden, ọrakha ọkhọhkha ikpokpobha, ọbaakha otte kwa kwanọng kwẹ. Bẹ arima ayok, bẹ abira adim k'ikhira.  
\v 8 Mosẹs ọgbaak otte kwa kwanọng kwẹ odik kpenamkpen kw'Ọvaar Ibinọkpaabyi okk'Phero, ọmaana anọng p'Ijip ọsa ọnang anọng p'Israẹl. Wa obiro ọgbaakh-ẹ ihem sa bẹ akk'are k'eden biphyir, ttara eden ch'Ọvaar Ibinọkpaabyi okk'bẹ ọkkaana. 
\p  
\v 9 Wa ettem ẹdaam Jẹtro k'idik-jibhada biphyir s'Ọvaar Ibinọkpaabyi ọkk'ọsa, otzima ọrọbha anọng p'Israẹl ka mbọhk s'anọng p'Ijip.  
\v 10 Oben bi, “Ẹtzọhnga ewobha ẹnang Ọvaar Ibinọkpaabyi kw'ọrọbh bọng ka mbọhk s'anọng p'Ijip ọmaana sa Phero, kw'obiro ọrọbha anọng mba ka mbọhk s'anọng p'Ijip.  
\v 11 Kaam nkk'nna nnonga bi, Ọvaar Ibinọkpaabyi ọbaari ọyọhnga idik biphyir s'anọng akpobh, osi odik nwa otzima otzor anọng p'age for asi anọng p'Israẹl ọgbaan.”  
\v 12 Mẹ wọ, Jẹtro, kw'ode otte kwa kwanọng kwa Mosẹs, otzima ẹnanga ẹkwọmichẹ, ọmaana njafọhni ndọdọk ọnang Ibinọkpaabbyi. Wa Aarọn obiro otzima adeden-nọng p'Israẹl biphyir, ọtza ochi ọchattọhk ttara otte kwa kwanọng kwa Mosẹs k'itzitzikha s'Ibinọkpaabyi. 
\p  
\v 13 Mada ewu en-ehobh, Mosẹs otza owobha ẹwọr bi, ọttọhna aponga p'anọng mba. Anọng mba abe akhọri Mosẹs akhe k'ottem, ttẹwọr k'ekpebha maa ẹchọhkha etto.  
\v 14 Mada otte kwa kwanọng ore idik biphyir sa Mosẹs om-osi ọnang anọng mba, ọn-ọbọbh bi, “Mbọng f'am-asi anang anọng mba ma o? Mbọng vọ osi am-attọhna aponga mancheni, anọng mba biphyir am-abir abe akhọr-ọ ttẹwọr k'ekpebha maa ẹchọhkha etto o?” 
\p  
\v 15 Mosẹs obhin-ẹ bi, “Okhuri da anọng am-akwu akhebh-m bi, mphyem ochibhi kw'Ibinọkpaabyi nnang bẹ e.  
\v 16 Ogbe kpenamkpen kwa bẹ akhaam ngọhr, bẹ am-atzima akwu bi, nttọhna nnang bẹ, mbiri mgbaak bẹ akpebhi, ọmaana aphaangi p'Ibinọkpaabyi.” 
\p  
\v 17 Otte kwa kwanọng kwa Mosẹs obhina bi, “Kọbaan bi asi mando.  
\v 18 Ọ́khọn kọ, ọmaana anọng mba p'am-akwu akhebh-ọ ọkhọn e. Ọtzọhm mva ọbari ọyọhng-ọ e, fẹ mancheni kafha asi e.  
\v 19 Kọ yong-m itzọhng, ka ndọhna sa kaam ńnang-ọ, tte Ibinọkpaabyi owobha ttara bọng. Kọ akhaambi atzera eho ch'anọng mba, abira atzima ngọhr sabẹ ayin Ibinọkpaabyi k'itzitzikha.  
\v 20 Kpebhi bẹ akpebhi ọmaana aphaangi mba, abira akhọkha bẹ eden ch'ẹbaan bi bẹ aruk, ọmaana itzọhmbọhk-dema sa bẹ abaan bi asi.  
\v 21 Yina, kọ tzekha ajinọng p'abaan-ọbaana k'ottem kw'anọng mba biphyir, ajinọng p'akhaam ojora f'Ibinọkpaabyi, p'ayok ahokhi k'odik-ọkka, p'attaanga anang ibhora, asi bẹ adeho p'ayok, ka nnọhna nnọhna, ọmaana arọbh azen azen, ọmaana arọbh afa obhiri jobh, ttara ka jobh jobh.  
\v 22 Tte bẹ ade attọhn-aponga p'anọng mba k'ogbe kpenamkpen. Tte bẹ atzima aponga kpenamkpen p'agaangi-ọgaangi achen-ọ, yina, tte bẹ akpara aponga p'ikhakhari ka for sabẹ. Mẹ wọ osi ọtzọhm obhekh-ọ, da bẹ an-atzor-ọ ọtzọhm.  
\v 23 Idikha asi mando, mach'Ibinọkpaabyi obiro ọtzọhn-ọ, kọ ábe ọtzọhm mva abẹ obe, anọng mba biphyir abira abhana ttara ottemdamiji.” 
\p  
\v 24 Mẹ wọ, Mosẹs oyonga itzọhng ọnang otte kwa kwanọng, osi odik kpenamkpen kw'ọtzọhn-ẹ.  
\v 25 Mosẹs ọrọbha ajinọng p'abaan-ọbaana k'ottem kw'anọng p'Israẹl biphyir, osi bẹ aho p'anọng mba ka ngaan sa nnọhna nnọhna, ọmaana s'arọbh azen azen, ọmaana s'arọbh afa obhiri jobh, ttara sa jobh jobh.  
\v 26 Anọng mba an-ade attọhn-aponga p'ayok k'ogbe kpenamkpen. Anọng atzima aponga p'agaang-ọgaangi achena Mosẹs, yina, bẹ am-akpaara p'ikhakhari ka for sabẹ. 
\p  
\v 27 Mẹ wọ e, Mosẹs otza orik otte kwa kwanọng kwẹ k'eden. Jẹtro ọbhana ka kẹ k'ekhọma. 
\c 19  
\s1 K'egbegbeho cha Sinai 
\p  
\v 1 K'ophe kw'ottong attaan, mada anọng p'Israẹl akk'abina k'Ijip, m'ewu nduma dani, bẹ apyiri k'ibe s'anọng an-arukhi sa Sinai.  
\v 2 Mada bẹ abin ka Rẹphidim, bẹ arenga apyiri k'ibe s'anọng an-arukhi sa Sinai. Wa anọng p'Israẹl abhing mẹ, k'itzitzikha s'egbegbeho nda. 
\p  
\v 3 Mẹ wọ, Mosẹs ovura otza okhebha Ibinọkpaabyi, Ọvaar Ibinọkpaabyi oyer-ẹ k'egbegbeho, oben bi, “Ma wọ ode odik kw'ágbaak va pa va pa Jekọb, ọmaana anọng p'Israẹl.  
\v 4 ‘Bọbọng ọkhaam akk'idik ara sa nnsi Ijip, ọmaana eden cha ndini bọng k'ẹrọng mach'ikyenọhn itzini va pẹ ka mbabaang, ndima nkwu ma da kaam nwobh.  
\v 5 Mẹ wọ, idikha bọng akhakha eho k'ettem obungichẹ, bọng abira ahok echekhi chaam, k'ottem kw'idibhon biphyir, bọng áde anọng pa kaam nhokhi ettem, kaambi ode bi oyagbin biphyir ọkhaam kaam.  
\v 6 Bọng áde obhon kwaam kw'afọhni-nja, ọmaana obhon kw'awurada.’ Ma wọ ode atzim p'agbaak anang anọng p'Israẹl.” 
\p  
\v 7 Mẹ wọ, Mosẹs ọkpa nnam okwu otzobha adeden-nọng p'anọng mba, ọtzọkha atzim biphyir p'Ọvaar Ibinọkpaabyi ọkk'ẹ ọtzọhna bi ọgbaak, ọgbaak bẹ.  
\v 8 Anọng mba biphyir an-abhina k'ogbe wani bi, “Ḿosi odik kpenamkpen ósi mach'Ọvaar Ibinọkpaabyi okk'obena.” Mẹ wọ e, Mosẹs ọkpa nnam ọtza ọgbaak Ọvaar Ibinọkpaabyi ebhina chabẹ. 
\p  
\v 9 Ọvaar Ibinọkpaabyi oben Mosẹs bi, “Kaam nhakha ndor-ọ k'eboni ch'epyi \it bi kaang\it*, ifha anọng mba ábhaanga da mgbaak atzim ttar-ọ, bẹ áphennam ka kọ.” Mẹ wọ, Mosẹs ọn-ọgbaak Ọvaar Ibinọkpaabyi ebhina ch'anọng mba akk'ananga. 
\p  
\v 10 Ọvaar Ibinọkpaabyi oben Mosẹs bi, “Kpa nnam atza akhebha anọng mba, hok bẹ awur-owur mayina ttara ophyini. Tte bẹ agbobhi ọbara fabẹ fa for,  
\v 11 bọng ado for k'ewu ch'ettong ittaan, okhuri bi, Ọvaar Ibinọkpaabyi ọ́hakha k'egbegbeho cha Sinai m'ewu nduma k'ibe s'anọng biphyir arẹ-ẹ.  
\v 12 Kọ khe enem akhọri egbegbeho nda, abira agbaak bẹ bi, ‘Bọng tọkha ogbe kwabọng o, ọnọng oningi egbegbeho nda ovur o, yina ira ọn-ọttọhmi chẹ ọttọhmi. K'odik-ọkka, onong kpenamkpen kw'ọttọhmi egbegbeho nda, bẹ áfhẹ-ẹ ofhu.  
\v 13 Kẹ bẹ átzọbh-ẹ atza, asi mẹ bẹ akhum-ẹ akhọhn, bẹ kẹ ọbọhk kabun. Ode ọnọngẹya, obiro ode etzen o, kọbaan bi, bẹ attẹ-ẹ ọbọhk oruk akpen.’ Oyongi bi, bẹ agyi ẹha ch'erukhimaan-dim k'ogbe-bhirada, mẹ kwa bẹ afha arenga abaanga egbegbeho nda.” 
\p  
\v 14 Mẹ wọ, mada Mosẹs okk'm'egbegbekho nda ọhakha, okwu osi anọng mba awur, bẹ abira agbobhi ọbara fabẹ fa for.  
\v 15 On-oben bẹ bi, “Bọng do for atzik ottong iwu nttaan. Bọng ayok abẹ kayima.” 
\p  
\v 16 K'ekpebha ch'ewu ch'ettong ittaan, ẹbhaangkpon ẹtta, ebira ẹmani, eboni ch'epyi \it bi kaang\it* ebubha egbegbeho ebir-ebir, obukpọhng obiro ogyi k'ẹrọng \it bi pooom\it*, opoma osi ọnọng kpenamkpen k'ibhingabe.  
\v 17 Mẹ wọ, Mosẹs otzima anọng mba obina k'ibhingabe, bẹ atza akhebha Ibinọkpaabyi, bẹ abe k'egbegbeho-rin.  
\v 18 Irorong ibubha egbegbeho cha Sinai, okhuri bi, Ọvaar Ibinọkpaabyi ọhak m'egbegbeho nda k'ekpon. Irorong nna ivura k'ẹrọng mach'irorong s'ekpon ch'ẹwọm-ọwọma, egbegbeho nda biphyir enyingi itzama-itzama.  
\v 19 Ẹmọng ch'obukpọhng en-edo ẹtza-ọtza. Mẹ wọ e, Mosẹs ọgbaak atzim, Ibinọkpaabyi otzima ẹbhaangkpon obhin-ẹ. 
\p  
\v 20 Ọvaar Ibinọkpaabyi ọhakha k'egbegbekho cha Sinai ebir-ebir, oyeri Mosẹs bi, ovura okhebh-ẹ kẹ. Mẹ wọ, Mosẹs ovura,  
\v 21 Ọvaar Ibinọkpaabyi oben Mosẹs bi, “Kọ hakha atza atzọr anọng mba itzọhng, ifha bẹ aningi eden arori cha bẹ akwu are Ọvaar Ibinọkpaabyi, ofona mẹ, haabhada ape.  
\v 22 Kaambi afọhnẹja p'areng afora Ọvaar Ibinọkpaabyi bọ, bẹ akhaambi ahok for sabẹ, iwur-owur, oni mando ode, Ọvaar Ibinọkpaabyi ọ́nang bẹ ettuma.” 
\p  
\v 23 Mosẹs oben Ọvaar Ibinọkpaabyi bi, “Anọng mba k'egbegbeho cha Sinai kafha arenga abaanga, okhuri bi, kọ ọkhaam wọ atzọri man itzọhng bi, ‘Kẹ enem akhori egbegbeho nda, ahok chẹ ewur-owur.’ ” 
\p  
\v 24 Ọvaar Ibinọkpaabyi obhina bi, “Kọ hakha atza atzima Aarọn akwu. Yina, afọhnẹja, ọmaana anọng mba kakhaambi atzima ẹkhaari avura akwu k'Ọvaar Ibinọkpaabyi, oni mando ode, kẹ ọnang bẹ ettuma.” 
\p  
\v 25 Mẹ wọ e, Mosẹs ọhakha okwu okhebha anọng mba, ọgbaak bẹ idik s'Ọvaar Ibinọkpaabyi okk'obena. 
\c 20  
\s1 Asana jobh p'Ibinọkpaabyi 
\r (Deutẹrọnọmi 5.1-21) 
\p  
\v 1 Mẹ wọ, Ibinọkpaabyi ọgbaak atzim mba biphyir, oben bi: 
\mi  
\v 2 “Kaam wọ nde Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kwabọng, kw'otzim bọng obina k'Ijip, k'irerek s'ebira. 
\li1  
\v 3 “Bọng idik ọdọdọk kàkpobha, kw'oyongi kaam. 
\li1  
\v 4 “Bọng ọgbatza kàgwa kw'ókher ọttọhk kpenamkpen f'owobh k'ẹrọng, ode bi fẹ owobh k'irerek, fẹ obiro owobha k'asi ẹtzaanga.  
\v 5 Bọng nho kàhakha anang agbatza mba, bọng bẹ kàbira akpobha, okhuri bi, kaam Ọvaar Ibinọkpaabyi, kwa nde Ibinọkpaabyi kwabọng, nde Ibinọkpaabyi kw'ọkhaam ottem-mamma, kw'ọm-ọnang va ọmmọmma k'itzama s'ab'otte, maa apyiri mgbọmma nttaan, ọmaana mgbọmma nna s'anọng p'attaang-m.  
\v 6 Yina, kaam mingọhkha idadaakha nnang mgbọmma nnọhna-nnabhik sa ngaam idadaakha ttar-m, mbiri nhok asana paam. 
\b  
\li1  
\v 7 “Bọng che ch'Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kwabọng k'elulukhiden kàtzima, okhuri bi, Ọvaar Ibinọkpaabyi kóbina ọnang, ọnọng kw'olukhi che chẹ. 
\li1  
\v 8 “Bọng jima Ẹwọhngkwokhawu bi, bọng ahok chẹ mach'ewuradawu anang Ibinọkpaabyi.  
\v 9 Bọng dima iwu izadani asi itzọhm sabọng biphyir,  
\v 10 yina, ottong iwu izenamfa, ode Ẹwọhngkwokhawu ch'ikpokpobha anang Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kwabọng. M'ewu nda, ọnọng manda wani, kaambi kọ wọ, ode nnwa kwọ kw'ijinọng, ode kw'ikwanọng, ode ọtzọhmnọng kwọ kw'ijinọng, ode ọtzọhmnọng kw'ikwanọng, ode etzirakpo pyabọng, obiro ode okhekhennọng kw'orukhi k'ottem kwa bọng, oningi ọtzọhm osi.  
\v 11 Ọvaar Ibinọkpaabyi otzim iwu izadani osi ẹrọng ọmaana irerek, ọmaana ọraanga kw'ideden, ttara ọttọhk kpenamkpen f'owobh k'ẹtzaanga kwabẹ, yina, ottong iwu izenamfa okwokha ọwọhng. Mẹ wọ, Ọvaar Ibinọkpaabyi odo Ẹwọhngkwokhawu nda, ohok chẹ mach'ewuradawu. 
\li1  
\v 12 “Bọng kpobha abatte, ọmaana abakka, ifha bọng aruk akpen p'adum-odum k'irerek s'Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kwabọng ọ́nang bọng. 
\li1  
\v 13 “Bọng ọnọng kàfhu. 
\li1  
\v 14 “Bọng ọtta kàtzam. 
\li1  
\v 15 “Bọng oribh kàfhu. 
\li1  
\v 16 “Bọng nttẹsẹ kw'ibhora kàbe. 
\li1  
\v 17 “Bọng ihọhm s'ayok, ọmaana panọng p'ayok, kaambi ode ọtzọhmnọng kwẹ kw'ijinọng, obiro ode kw'ikwanọng, ode ẹbhaam chẹ, ode ẹnyanyaang, obiro ode ọttọhk kpenamkpen f'oyok, k'ẹfa kàtzọkha.” 
\p  
\v 18 Mada anọng mba are da ẹbhaangkpon ẹmani, ebire ẹtto etzum, bẹ abhaanga da obukpọhng ogyi, bẹ abira are irorong k'egbegbeho ebir-ebir, opoma osi bẹ, bẹ afọni. Mẹ wọ, bẹ an-abe k'odenmir,  
\v 19 aben Mosẹs bi, “Kọ ọkhaam ma for sọ, gbaak atzim anang man, kkeri m'oyong-ọ itzọhng oyonga. Yina, Ibinọkpaabyi ọbọhk kàtte ọgbaak atzim ọnang man, na mókwu ope.” 
\p  
\v 20 Mosẹs oben anọng mba bi, “Ojora oningi bọng osi, kkeri Ibinọkpaabyi ọkk'ọkwa bi okwu oyoma bọng, ifha bọng akhaama ojora fẹ, f'ósi bọng arọbh aji ẹkhọngkwuri osisi.” 
\p  
\v 21 Anọng mba awobha k'odenmir, mada Mosẹs oreng ọbaanga eboni ch'epyi \it bi kaang\it*, kẹ da Ibinọkpaabyi owobh. 
\s1 Asana p'akhuri agbatza ọmaana ijafọhnibe 
\p  
\v 22 Mẹ wọ, Ọvaar Ibinọkpaabyi oben Mosẹs bi, “Kọ gbaak anọng p'Israẹl bi, ‘Bọng akk'ara ka bọng ọkhaam ka for bi, kaam nkk'k'ẹrọng nwobha mgbaak bọng atzim.  
\v 23 Bọng gol, ọmaana silva kàtzima agwa agbatza pa bọng akpobha, ebengambọhk ttara kaam. 
\p  
\v 24 “‘Bọng dima idọdọhbh asi ijafọhnibe, bọng asi ẹjafọhni ẹkwọmichẹ mẹ, ọmaana ẹnanga ch'odidiri, ch'arukhimaan, ọmaana ch'avu, ttara ch'andaamogbodo anang-m. K'ibe kpenamkpen sa kaam ńsi bi ide ikpokpobhabe ka che chaam, kaam ńhakha ńkwu nkebha bọng, ḿbiri ńdo bọng.  
\v 25 Idikha atzim atza asi ijafọhnibe anang-m, atza pa bẹ akk'adokha kàtzima, okhuri bi, atzim atza pa bẹ adokh-odokha, akk'sẹ akhibhi.  
\v 26 Bọng ka mbarimmo kàrenga avura k'ijafọhnibe saam ebir-ebir, ifha bọng aningi sẹ irinikhum sabọng akhọk.’ 
\c 21  
\p  
\v 1 “Ma wọ ode aphaangi p'ánang anọng p'Israẹl. 
\s1 Asana p'akhuri abira p'aHiburu 
\p  
\v 2 “Idikha adebhi obira kw'ode oHiburu-nọng, kẹ ósi ọtzọhm k'irekh-irek kwọ ka cho azadani. Yina, ottong cho azenamfa, kẹ ọ́naanga ebira, ọttọhk kpenamkpen kọ́nang.  
\v 3 Idikha okwu mancheni, ọ́kpa nnam mancheni. Yina, otzim kwanọng kwẹ okwu, kẹ obiro ọ́kpa nnam ttara kwanọng kwẹ.  
\v 4 Idikha itta kwẹ ọnang-ẹ obira wani kwẹ kw'ikwanọng bi, ọtzọkha, ọmmaan-ẹ va p'ijinọng, ttara p'ipanọng, kwanọng nwuma ttara va pẹ án-ade p'itta kwẹ, ojinọng kẹ-khẹ wọ ófona ọbhana. 
\p  
\v 5 “Yina, idikha obira nwuma osi ẹjaakhi bi, ‘Kaam itta kwaam, ọmaana kwanọng kwaam, ttara va paam adaakh-m ọdaak, kokher bi ọnaanga ebira,’  
\v 6 itta kwẹ ọkhaambi otzim-ẹ ọtza ọkhọkha akpaar-aponga. Kẹ ótzim-ẹ ochina k'ẹkpọmmachi ch'ẹhọmma, ọ́ju-ẹ itzọhng ttara ejum. Mẹ wọ, ón-ode kwẹ k'akpen pẹ biphyir. 
\p  
\v 7 “Idikha ọnọng ọtzọk nnwa kwẹ kw'ikwanọng okpe k'ebira, ominanwa nwa mach'obira kw'ijinọng om-ofona k'idukhi, kófona.  
\v 8 Idikha ominanwa nwa oni itta kwẹ idik ọdaakhi, tte kẹ ọttẹ-ẹ ọbọhk, bẹ abhekh-ẹ k'ebira. Itta kwẹ ẹfa kọkhaam bi, ọkpẹ-ẹ ọnang okhekhennọng, okhuri bi, itta nwa kwẹ, echekhi ch'ọnangi obira nwa kohokhi.  
\v 9 Idikha ọtzọhk ominanwa nwa ọnang nnwa kwẹ kw'ijinọng, kẹ ósi macha bẹ am-asi anang va p'ipanọng.  
\v 10 Mẹ wọ, obiro ọtzọkha kwanọng ọdọdọk, kẹ kọ̀khaambi ọrọbha ocheden kwanọng chen, ọnang-ẹ ọchattọhk, ọnang-ẹ ọbara fa for, ttara eyima.  
\v 11 Idikha kẹ oni kwanọng nwa ekpo mbya ẹttaan ọnangi, kwanọng nwa ọbaan bi, ọbhana k'idukhi, ogbukha manda wani kọ̀nang k'ẹnaanga chẹ. 
\s1 Aphaangi p'akhuri ekpo-omumumma 
\p  
\v 12 “Ọnọng kpenamkpen kw'obuni oyok ọttọhk, ọfhẹ-ẹ, kẹ bẹ abira áfhẹ-ẹ ofhu.  
\v 13 Yina, idikha oni k'ọgbaan otzim ọfhẹ-ẹ, da kwẹ ode bi, Ibinọkpaabyi wọ otte kwẹ ọbọhk otto, tte kẹ ọrọbh otza ochubha k'ibe sa kaam ńdekha.  
\v 14 Yina, ọnọng on-obiro ọkham oyok, ọfhẹ-ẹ k'ọgbaan, bọng dim-ẹ abina aji ijafọhnibe saam, atza afhẹ-ẹ. 
\p  
\v 15 “Ọnọng kpenamkpen kw'ofhu otte, oyongi mẹ, obiro ofhu ọkka, bẹ akhaambi afhẹ-ẹ. 
\p  
\v 16 “Ọnọng kpenamkpen kw'ofu ọnọngẹya, ode bi okpẹ-ẹ okpe, obiro ode bi, bẹ akhebh-ẹ ttara ọnọng nwuma ka mbọhk, bẹ akhaambi afhẹ-ẹ. 
\p  
\v 17 “Ọnọng kpenamkpen kw'ọnangi otte ẹmma, obira ode bi ọnangi ọkka ẹmma, bẹ akhaambi afhẹ-ẹ. 
\p  
\v 18 “Idikha anọng afa asi ẹkhọhr, oyok wani ọtzọbh oyok ọtza, oyongi mẹ obun-ẹ ẹbọhkduk, maa oyok oyima ọkhọhmmana,  
\v 19 kẹ kw'obuni oyok ẹbọhkduk ọmmamma kọ̀tzọkha, idikha oyok ọnang ẹbọhkduk nduma, obina orenga ttara ochikhura kwẹ, kẹ ọ́mọnga agbukha ọnang oyok, k'ogbe kw'okk'oyok okhibhi, obiro ókker-ẹ maa, for igaang-ẹ. 
\p  
\v 20 “Idikha ọnọng ottumi obira kwẹ kw'ijinọng, obir ode kw'ikwanọng ttara ochinnwa, maa ope ka mbọhk sẹ, bẹ akhaambi bẹ anang ọnọng-dema nwuma ọmmamma.  
\v 21 Yina, idikha obira nwuma ọnang ngwur nnuma, ode ewu dani o, obiro ode iwu ifa o, ọkhaam-obira nwa ọmmamma kọ̀tzọkha, da obira nwa ode agbukha pẹ. 
\p  
\v 22 “Idikha ajinọng afa arim-erima, bẹ atza abun kwanọng kw'otzim ibhọr ọttọhk, ofona mẹ, ibhọr nna iyin, da ogbe kwẹ on-otzim obenga, yina, ọttọhk f'ọbar-ọbar komum, otzukha kpenamkpen kw'odim kwa kwanọng nwa ọkpaar, esobh ebire ekhera, mando kw'ótzuk.  
\v 23 Yina, idikha kwanọng nwa omum ekpo k'idendama, tzima akpen atzera akpen,  
\v 24 ọju-ẹ chen, bẹ aju-ẹ chen, ọkpaar-ẹ ọbọhk, bẹ akpaar-ẹ ọbọhk, ọrọbh-ẹ ẹha, bẹ arọbh-ẹ ẹha, ọkpaar-ẹ obho, bẹ akpaar-ẹ obho,  
\v 25 ọkwọm-ẹ ekpon, bẹ akwọm-ẹ ekpon, omum-ẹ ọttọhk, bẹ amum-ẹ ọttọhk, owong-ẹ owonga, bẹ atzukha ttara ewonga. 
\p  
\v 26 “Idikha ọnọng ottumi obira kwẹ kw'ijinọng, kaambi obiro ode kw'ikwanọng ka chen, ọju-ẹ chen, kẹ ọkhaambi otte obira nwa ọbọhk ofona k'idukhi, okhuri chen ch'oju-ẹ.  
\v 27 Idikha ọnọng ottumi obira kwẹ, kw'ijinọng, kaambi obiro ode kw'ikwanọng, ọrọbh-ẹ ẹha, kẹ ọkhaambi otte obira nwa ọbọhk ofona k'idukhi, okhuri ẹha chẹ ch'ọkk'ọrọbha. 
\p  
\v 28 “Idikha ọbhaamdim okhumi ọnọng abhik, ode ojinọng, obiro ode kwanọng maa ope, bẹ akhaambi atzọbh ọbhaamdim-dema nwa atza maa ope, etzen chẹ k'ẹchaa kẹ̀baan. Kaambi mẹ wọ, ọkhaam-ọbhaamdim nwa, odik koji.  
\v 29 Yina, idikha ọbhaamdim nwa okk'anọng abhik om-okhuma, bẹ atzọr ọkhaam itzọhng, yina, chẹ kọ̀bọhk okhe k'ikwuri, maa chẹ efhu ọnọng, bẹ atzọbh ọbhaamdim nwa atza maa ope, bẹ abira afhu ọkhaam-ẹbhaamdim.  
\v 30 Mẹ wọ, idikha bẹ akpaar otzukha anang-ẹ, kẹ ọkhaambi da otzuk kpenamkpen fa bẹ akpaar anang-ẹ, ifha otzima obhek akpen pẹ.  
\v 31 Ọphaangi nwa obiro obe ọnang bi, idikha ọbhaamdim okhumi nnwa kw'ijinọng, obiro ode nnwa kw'ikwanọng obhik, ọfhẹ-ẹ.  
\v 32 Idikha ọbhaamdim okhumi obira kw'ijinọng, obiro ode obira kw'ikwanọng obhik, ọkhaam-ọbhaamdim ọkhaambi ọnang ọkhaam-obira, ashẹkẹl ẹrọbh obhiri jobh p'asilva, bẹ akhaambi abira atzọbh ọbhaamdim nwa atza maa ope. 
\p  
\v 33 “Idikha ọnọng otzumi ipekhuma otte eje, ode ẹbhaam, ode bi ẹnyanyaang dọ, etto k'ẹtzaanga,  
\v 34 ọnọng kw'otzumi ipekhuma nna, ọkhaambi ọtzuk ọnang ọkhaam-ẹbhaam, kẹ ọ́tzọkha otzen-bukhi. 
\p  
\v 35 “Idikha ọbhaamdim kw'ọnọng omum ọbhaamdim kw'oyok ọttọhk ọfhẹ-ẹ, bẹ akhaambi akpe ọbhaamdim kw'owobh akpen, akkema agbukha, bẹ abira akkema otzenbukhi ebengambọhk.  
\v 36 Yina, idikha anọng arong bi, ọbhaamdim nnwa okk'anọng abhik om-okhuma, yina, ọkhaam-ẹbhaam chẹ kọ̀bọk okhe k'ikwuri, ọkhaam-ẹbhaam ótzima ẹbhaam otzuk ẹbhaam, ọbhaam-bukhi ón-ode kwẹ. 
\c 22  
\s1 Asana p'akhuri ẹkhakhaama 
\p  
\v 1 “Idikha ọnọng ofhu ẹbhaam, obiro ode orukhimaan, ọfhẹ-ẹ, ode bi okpẹ-ẹ okpe o, kẹ ọkhaambi otzuk abhaam azen k'ẹbhaam dani, arukhimaan anna k'orukhimaan wani. 
\p  
\v 2 “Idikha bọng abọk oriribha da ọm-ọvọkhi ibe k'erungi, attum-ẹ maa ope, ọnọng kw'ottum-ẹ, iponga s'ẹnọngmon kẹ kípyibh.  
\v 3 Yina, idikha ọfhẹ-ẹ da ewu ekk'ekhobha, aponga p'ẹnọngmon akk'ẹ ipyibha e. 
\p “Oriribha ọkhaambi orik ọttọhk kpenamkpen f'ofhu, idikha ọn-ọttọhk ọkhaam, bẹ akhaambi akpẹ-ẹ atzima atzera eho ch'ọttọhk f'ofhu. 
\p  
\v 4 “Idikha bẹ are etzen ch'ofhu da etzim erukhi akpen ka mbọhk sẹ, ode ẹbhaam, ode ẹnyanyaang, obiro ode orukhimaan o, kẹ ọkhaambi otzuk chẹ k'igbe ifa. 
\p  
\v 5 “Idikha ọnọng otzim etzirakpo pyẹ bi, ọtza ọnang ọchattọhk, ettena ẹtza echi owoni, obiro ode owoni kw'ọnọng kwa grep o, kẹ ọkhaambi da otzuk ekpo py'ọnọng nwa, ttara ekpo ọkkakka py'efon k'owoni kwẹ kw'agrep. 
\p  
\v 6 “Idikha ọnọng okhumi owoni kwẹ, kw'ọwọhm maa ojekha k'owoni kw'oyok, ekpon ẹkwọmi ekpo py'oyok ọyaabh, obiro ode py'oyok ọkk'ọpha otzobha, ọnọng kw'okhe ekpon nda, ọkhaambi otzuk oyok ekpo pyẹ py'ẹkwọmi. 
\p  
\v 7 “Idikha ọnọng ọnangi oyok asilva, obiro ode ekpo ẹdọdọk bi, oye, bẹ akhebha pyẹ k'ọhọhm kw'oyok afhu, bẹ abọk oriribha nwuma, oriribha nwuma ọkhaambi bi ótzuk pyẹ k'igbe ifa.  
\v 8 Yina, idikha bẹ ani oriribha nwuma abọk, ọkhaam-ọhọhm ọkhaambi obe k'itzitzikha s'Ibinọkpaabyi, ifha ọgbaak s'okk'ekpo py'oyok ọfha.  
\v 9 K'aponga biphyir p'akhuri oribh f'ẹbhaam, ọmaana f'ẹnyanyaang, ọmaana f'orukhimaan, ttara f'ibara, obiro ode f'ọttọhk kpenamkpen f'ọnọng obeni bi, ‘Faam vọ’, anọng mba afa p'akkaan ọttọhk mva, akhaambi abe k'itzitzikha akpaar-aponga. Ọnọng kw'aponga apyibhi, ọkhaambi otzuk k'igbe ifa ọnang oyok. 
\p  
\v 10 “Idikha ọnọng otziri oyok ẹnyanyaang, ode ẹbhaam, ode orukhimaan, obiro ode otzirattọhk kpenamkpen, fẹ ope, ode bi, bẹ amum fẹ ọttọhk, obiro ode bi, fẹ odim-odimi o, da bẹ ani otzum akhe,  
\v 11 bẹ anọng afa atzọkha ọnwọhngi k'itzitzikha s'Ọvaar Ibinọkpaabyi bi, oyok ọttọhk fẹ ọbọhk kọttọhmi. Ọkhaam-ọttọhk ọkhaambi okhera mando, otzukha ma kode.  
\v 12 Yina, idikha bẹ an-abira afhu otzirattọhk mva ofhu, oyok kw'oyok otziri ọttọhk ọkhaambi otzuk fẹ, ọnang ọkhaam.  
\v 13 Idikha ode bi etzen ch'ẹtzam dọ ẹfhu otzirattọhk mva, ẹjaakhi fẹ k'abir-ibiri, oyok kw'oyok otziri ọttọhk, ọ́tzọkha abiri-biri p'etzen nda p'arikhi mach'ẹkhọhkha, bẹ kẹ kábọkha bi, ótzuk otzirattọhk f'ọkk'ọpa. 
\p  
\v 14 “Idikha ọnọng ọyaami otzirattọhk f'oyok, bẹ amum fẹ ọttọhk, ode bi fẹ opope, k'ogbe kw'ọkhaam on-ode, ọnọng kw'ọyaami fẹ, ọkhaambi otzuk ọnang ọkhaam.  
\v 15 Yina, ọkhaam owobh mẹ ttara otzirattọhk mva, ọnọng kw'ọyaami fẹ kótzuk. Idikha ọyaami otzirattọhk mva k'agbukha, agbukha p'otzim ọyaam fẹ, atzera otzirattọhk mva f'odimi. 
\s1 Asana p'akhuri erukkha ch'anọngẹya 
\p  
\v 16 “Idikha ojinọng ọbọhr ominanwa kw'oni ojinọng otzim oronga, oyim-ẹ abẹ k'ẹfa, ọkhaambi osi imina sẹ, ominanwa nwa ón-ode kwanọng kwẹ.  
\v 17 Idikha otte kw'ominanwa nwa obhumi biphyir-phyir bi, ọnang-ẹ nnwa kwẹ k'ọbada, ojinọng nwa ọkhaambi da osi imina otzor k'ominanwa kw'oni ojinọng otzim oronga. 
\p  
\v 18 “Bọng kwanọng kw'osi mbọng ọbọhk kàtte oruk akpen. 
\p  
\v 19 “Ọnọng kpenamkpen kw'oyim etzen abẹ, ọbaan bi, bẹ afhẹ-ẹ. 
\p  
\v 20 “Ọnọng kpenamkpen kw'ọfọhni ẹja ọnang ọkhak, okhiri Ọvaar Ibinọkpaabyi oji, ọbaan bi, bẹ adim-ẹ mebubuni. 
\p  
\v 21 “Bọng okhekhennọng ọgbaan kàsi, bọng kẹ ihem kabira kanang, okhuri bi, wa bọbọng akk'akhekhennọng ada k'Ijip. 
\p  
\v 22 “Bọng opopa kwanọng, ọmaana opfu-nwa chen kàsi.  
\v 23 Idikha bọng asi bẹ chen, bẹ abhom ayer-m, k'odik-ọkka kaam ḿmaanga ẹmọng chabẹ ọbhaanga.  
\v 24 Mbiri ńgọhkha ittemdọkhiji saam, mbiri ḿfhu bọng ttara ọkkangkkaang. Panọng pabọng án-ade apopa, va pa bọng abira áde apfu-va. 
\p  
\v 25 “Idikha bọng abhori ọnọng kpenamkpen kwaam, kw'owobh k'owora ka bọng kw'ottem agbukha, bọng iru kàkhe mach'ọnọng kw'om-obhor anọng agbukha om-osi.  
\v 26 Idikha atzọk owura-baba kw'oyokh-ẹbaanga kwọ mach'ebhikha, rik chẹ yina ẹchọhkha etto,  
\v 27 okhuri bi, chẹ-chẹ dọ ch'om-otzima obubha for e. Mada oyima, mbọng f'obubha, ani chẹ arikh o? Mada obhom oyer-m, kaam ḿmaang-ẹ ọbhaanga, okhuri da kaam ngaam inọngkwo. 
\p  
\v 28 “Bọng Ibinọkpaabyi kàlukhi. Bọng ọbaabhi kw'anọng pabọng, ẹmma kabira anang. 
\p  
\v 29 “Bọng ẹnanga ch'ọhọhm kw'ọchattọhk fabọng, obiro ode kw'atzuk pabọng kàbọkha atzima. 
\p “Bọng akhaambi anang-m achedenva pabọng p'ijinọng.  
\v 30 Eden nduma dani dọ cha bọng asi ttara abhaam, ọmaana arukhimaan pabọng. Tte bẹ awobha ttara abọkka k'iwu izenamfa, yina, ottong iwu izenanttaan, bọng dọkha bẹ anang-m. 
\p  
\v 31 “Bọng bọ áde anọng paam p'awur-owur. Mẹ wọ, bọng etzen cha nden s'ẹtzam mfhu, njaakhi k'abirbiri kàchi, bọng dọkha abhari anang mpfa. 
\c 23  
\s1 Asana p'eponga-ttọhna ch'etzor-otzor ọmaana nkwu-osisi 
\p  
\v 1 “Bọng ibhora kàkpaanga agbaak. Bọng kakhaambi abe obibyanọng ka nnam bi, an-ade nttẹsẹ kw'ibhora. 
\p  
\v 2 “Bọng ọhaabh abẹ kàtzọn asi odik kw'on-otzori. Ogbe kwa bẹ abe nttẹsẹ k'opongahọhm, bọng ọhaabh abẹ kàtzọn asi ibhora, atzima abhakhi aponga ewobha.  
\v 3 Bọng nkwu-osisi abẹ kàrenga atza abe nttẹsẹ kw'ogbogbora k'esobh, k'ogbe kw'osi odik kw'oni ojibhi. 
\p  
\v 4 “Idikha ọnọng ore ẹbhaam, obiro ode ẹnyanyaang ch'ọttattaanga-nọng kwẹ ch'etten eden, bọkha chẹ achena ọkhaam.  
\v 5 Idikha ọnọng are ẹnyanyaang ch'ọttattaanga-nọng kwẹ, ch'en-etto ttara ẹtzọhkha, chẹ ọbọhk kàtte. Kọ re bi akkaana ẹ, ọmaana ẹnyanyaang chẹ. 
\p  
\v 6 “Aponga p'ajibhi agbogbora kàbọkha abhakhi k'esobh.  
\v 7 Kọ ọnọng odik kàbubha, ọnọng kw'ọgbaakhi odik ọkkakka kàfhu, kkeri kaam ọnọng kw'aponga apyibhi, ọbọhk kíntte. 
\p  
\v 8 “Ọnọng oningi ngwu ochi, okhuri bi, ngwu mkpa ọnọng chen bi, oningi odik ọkkakka ore, mbiri mbọkha ọwọhng kw'ọnọng kw'otzor-otzor mmakhi. 
\p  
\v 9 “Bọng okhekhennọng ihem kànang, okhuri bi, bọbọng arong odem kw'ekhekhen ẹmma epyiri kẹ, da iwa bọng akk'akhekhennọng ada k'Ijip. 
\s1 Asana p'ọwọhngkwokha-gbe 
\p  
\v 10 “Bọng ayaabha iwoni sabọng ka cho azadani, bọng abira apha ekpo pya bọng ayaabh.  
\v 11 Yina, ottong cho azenamfa bọng tte ẹtzam ọbọhk ekhuri, bọng ọttọhk kpenamkpen mẹ kàsi, ifha ekpo py'émen mẹ éde ọchattọhk ẹnang agbogbora p'arukhi ttara bọng. Nden s'ẹtzam mbiri chi ekpo pya bẹ atzọk arik. Bọng ási mando ttara iwoni sabọng s'agrep, ọmaana s'oliv. 
\p  
\v 12 “Bọng si ọtzọhm k'iwu izadani. Yina, ottong iwu izenamfa bọng ọtzọhm kàsi, ifha abhaam pabọng, ọmaana nnyanyaang sabọng, ọmaana abira p'am-asi ọtzọhm anang bọng, ọmaana akhekhennọng p'arukhi ttara bọng afha akwokha for. 
\p  
\v 13 “Bọng dọkha ogbe ahok odik kpenamkpen kwa kaam nkk'bọng mgbaakha. Bọng che p'akha kàyeri, tte ọnọng oningi che p'akha mba k'ẹmma chabọng ọbhabhaanga-ọbhaang. 
\s1 Adadaami attaan pa cho 
\p  
\v 14 “Igbe ittaan ka cho kpenamkpen, bọng ám-asi ẹyaanga ch'ọdadaami, anang-m. 
\p  
\v 15 “Bọng si Ọdadaami kwa Brẹd kwa bẹ ani yist akhe anang-m. K'iwu izenamfa bọng chi brẹd kwa bẹ ani yist akhe, macha ndọhni bọng. Bọng si ọdadaami nwa k'ogbe kw'ọbaan bi bọng asi, k'ophe kw'Abib, kkeri m'ophe nwuma wọ kw'iwa bọng abin k'Ijip. 
\p “Ọnọng manda wani oning-m k'itzitzikha oyini, ttara abọhk-kpakpa. 
\p  
\v 16 “Bọng si Ọdadaami kw'Ipha ttara acheden-chiduk py'ekpo pya bọng ayaabh k'iwoni sabọng. 
\p “Bọng si Ọdadaami nwa kw'Ipha s'ikpong nnam ka cho, mada bọng apha iwoni sabọng. 
\p  
\v 17 “Igbe ittaan ka cho, ajinọng biphyir áyin Itta Ọvaar Ibinọkpaabyi k'itzitzikha. 
\p  
\v 18 “Bọng kaam izi s'ifon k'ẹjafọhni kànang, ttara ọttọhk kpenamkpen fa bẹ akhe yist. 
\p “Iyaak s'ẹnanga ch'ọdadaami kwaam kàhok maa ewu ehobha. 
\p  
\v 19 “Bọng dima acheden-chiduk akkakka pa bọng ayaabh k'iwoni sabọng, atzima akwu k'ọhọhm kw'Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kwabọng. 
\p “Bọng abasi p'evu kàtzima awọhn ovu-nwa. 
\s1 Itzọhmi s'Ibinọkpaabyi ido eden 
\p  
\v 20 “Kkeri e, kaam ndọhm orenga-eden ichi bọng eden, ibaabha bọng, ibiri itzima bọng ikwu m'ibe nna sa nkk'nda.  
\v 21 Bọng yong-ẹ itzọhng e, abira aha eho anang-ẹ. Bọng sẹ oho-gaangi kànang, kkeri bọng kóbina ọnang k'oho-gaangi kwabọng, da che chaam ewobh mẹ ttar-ẹ.  
\v 22 “Idikha bọng atzọk ogbe ayonga itzọhng anang-ẹ k'idik s'ọgbaakhi, bọng abira asi odik kpenamkpen kwa mgbaakhi, kaam ńde ọttattaanga-nọng kw'attattaanga-nọng pabọng, kaam kímbe ttara anọng p'anabe ttara bọng.  
\v 23 Itzọhmi saam íchi bọng eden, itzima bọng idim k'irek s'ab'Amọr, ọmaana abaHet, ọmaana abaPẹriz, ọmaana abaKenaan, ọmaana abaHiv, ttara abaJẹbus. Kaam ḿbiri ńdimi bẹ biphyir.  
\v 24 Bọng eho kàhakha anang akha pabẹ, bọng bẹ kàkpobha, bọng bẹ abẹ kàtzọn asi idik sa bẹ asi. Bọng akhaambi avọhkhi bẹ, bọng atzukhi agbatza pabẹ k'abir-ibiri.  
\v 25 Bọng akpobha kaam Ọvaar Ibinọkpaabyi, kwa nde Ibinọkpaabyi kwabọng, kaam ńdo ọchattọhk fabọng, ọmaana asi pabọng. Kaam mbiri ńnọbha ọkhọhmana ka bọng k'ottem.  
\v 26 Kwanọng manda wani kw'ibhọr íyin, kw'obiro ókpaana k'irek sabọng kóde. Kaam ńnang bọng akpen p'adum-odum. 
\p  
\v 27 “Kaam ńdọhm ojora faam ochi bọng eden, mbiri ńnge ẹkhọma kpenamkpen cha bọng attema abẹ ka dama-dama. Kaam ńsi attattaanga-nọng biphyir akpa nnam arọbh.  
\v 28 Kaam ńdọhm abhingiho achi bọng eden atza akhubh abaHiv, ọmaana abaKenaan, ttara abaHet ka bọng k'itzitzikha.  
\v 29 Kaam anọng mba ka cho wani kínkwubh, oni mando ode, irek nna in-ide idukhi, nden s'ẹtzam nna mbiri nhaabh nyọhnga bọng.  
\v 30 Kaam ńkwubh bẹ ibeba-ibeba, maa opyiri k'ogbe kwa bọng akk'ahaabha k'odem kwa bọng atzọkha irek nnuma. 
\p  
\v 31 “Kaam ńnge nnem sabọng ttẹwọr k'Ẹraanga-khora, maa apyiri k'Ọraanga kw'ideden kw'abaPhilistiya, ọmaana ttẹwọr k'ibe s'anọng an-arukhi, maa apyiri k'ọraanga kwa Euphrates. Kaam ńtte anọng p'arukhi m'irek nna ọbọhk nnang bọng, bọng ákhubh bẹ, bẹ abina bọng k'itzitzikha.  
\v 32 Bọng echekhi kasi ttara anọng mba, ọmaana akha pabẹ.  
\v 33 Bọng bẹ ọbọhk kàtte bẹ aruk k'irerek sabọng, oni mando ode, bẹ ási bọng asi ẹkhọngkwuri k'itzitzikha saam, okhuri bi, k'odik-ọkka ekpobha ch'akha pabẹ ede ọgbagbara ọnang bọng.” 
\c 24  
\s1 Ọvaar Ibinọkpaabyi osi ẹjaakhi ch'echekhi 
\p  
\v 1 Mẹ wọ, Ọvaar Ibinọkpaabyi, oben Mosẹs bi, “Kọ tzima Aarọn, ọmaana Nadab, ọmaana Abihu, ttara adeho arọbh attaan obhiri jobh p'Israẹl, akwu. Bọng awobha k'odenmir akpobh-m.  
\v 2 Yina, kọ Mosẹs mancheni wọ arenga abaanga kaam Ọvaar Ibinọkpaabyi. Ayok mbonggo kàkhaambi abaanga ka. Anọng mba kakhaambi avura ttar-ẹ.” 
\p  
\v 3 Mada Mosẹs ofon ọtza ọgbaak anọng p'Israẹl atzim biphyir p'Ọvaar Ibinọkpaabyi ọgbaakhi, ọmaana aphaangi pẹ, bẹ abhina k'ogbe wani bi, “Mósi odik kpenamkpen osi kw'Ọvaar Ibinọkpaabyi okk'obena.”  
\v 4 Mẹ wọ, Mosẹs ọn-ọkkẹr odik kpenamkpen kw'Ọvaar Ibinọkpaabyi ọkk'ọgbaakha. 
\p Ewu ehobh mẹ, obina k'ekpekpebha, ọtza osi ijafọhnibe k'egbegbeho-rin, obiro ọtzọkha mkpọmmachi s'atza jobh obhiri mfa ofhu iduduma, sa mbe nnang ngọma jobh obhiri mfa s'Israẹl. 
\p  
\v 5 Mẹ wọ, Mosẹs ọtzọhm adikkobh p'Israẹl bi, bẹ atza anang Ọvaar Ibinọkpaabyi ẹnanga ẹkwọmichẹ, bẹ abira atzima abhaamva asi ẹjafọhni ch'ẹnanga ch'odidiri anang Ọvaar Ibinọkpaabyi.  
\v 6 Mosẹs ọtzọkha izi nna rani okhe k'agbanggbang, ọtzọkha s'irikhi opyakhi k'ijafọhnibe.  
\v 7 Mẹ wọ, ọtzọkha Nnwẹr kw'Echekhi oyeri ọnang anọng p'Israẹl. Bẹ abhina bi, “Mọ́si odik kpenamkpen osi kw'Ọvaar Ibinọkpaabyi okk'obena. Móhakha eho ọhakha ọnang-ẹ.” 
\p  
\v 8 Mẹ wọ, Mosẹs ọtzọkha izi nnuma ọpyakhi anọng mba. Oben bi, “Ma wọ ode izi s'echekhi ch'Ọvaar Ibinọkpaabyi ọkk'ọsa ttara bọng, otzor k'atzim mba biphyir.” 
\p  
\v 9 Mẹ wọ, Mosẹs ọmaana Aarọn, ọmaana Nadab, ọmaana Abihu, ttara adeho arọbh attaan obhiri jobh p'Israẹl, afona  
\v 10 atza are Ibinọkpaabyi kw'Israẹl. Ibe s'ọbari mmo ide mach'ibhokhi sa bẹ atzim atza pa saphiya asi, s'ittaani mach'ọrọngkpakpa.  
\v 11 Yina, Ibinọkpaabyi adeho mba p'Israẹl itzama kosi. Bẹ are Ibinọkpaabyi, bẹ achi, abira agwo. 
\p  
\v 12 Ọvaar Ibinọkpaabyi on-oben Mosẹs bi, “Kọ vura akwu k'egbegbeho, awobha ma. Kaam ńnang-ọ atza-gbẹgbẹri pa nkk'aphaangi, ọmaana asana nkkẹra p'ade ndọhna sabẹ.”  
\v 13 Mẹ wọ, Mosẹs ttara Joshua kw'om-otzor-ẹ ọtzọhm, afona. Mosẹs ovura k'egbegbeho ch'Ibinọkpaabyi.  
\v 14 Mosẹs oben adeho mba bi, “Bọng wobha ma, atzik man maa mọkpa nnam. Aarọn ọmaana Hur awobh ma ttara bọng. Ọnọng kpenamkpen kw'ọkhaam ikhakhaanga ttara oyok, ọfha ọtza okhebha bẹ, bẹ attọhna.” 
\p  
\v 15 Mada Mosẹs ovur k'egbegbeho nduma, eboni ẹbhọri chẹ.  
\v 16 Abarada p'Ọvaar Ibinọkpaabyi ahakha m'egbegbeho cha Sinai. Eboni nda ẹbhọri egbegbeho k'iwu izadani. Ottonga iwu izenamfa, Ọvaar Ibinọkpaabyi oyeri Mosẹs m'eboni ẹtzaanga.  
\v 17 Abarada p'Ọvaar Ibinọkpaabyi k'egbegbeho ebir-ebir, an-akher anọng p'Israẹl ekpon ch'ẹkwọmi ọttọhk maa fẹ odimi.  
\v 18 Mẹ wọ e, Mosẹs odim k'eboni nda ẹtzaanga, mada ovur k'egbegbeho ebir-ebir. Wa owobha kẹ iwu arọbh afa, ọmaana nnungiwu arọbh afa. 
\c 25  
\s1 Nnanga s'anọng asi s'irukhabe s'Ibinọkpaabyi osisi 
\p  
\v 1 Ọvaar Ibinọkpaabyi oben Mosẹs bi,  
\v 2 “Kọ gbaak anọng p'Israẹl bi, bẹ achen-m ẹnanga. Kọ wọ atzọkha ẹnanga ch'ọnọng kpenamkpen kw'osi ochibhi bi, ọnang-m ẹnanga.  
\v 3 Ma wọ ode nnanga s'atzọkha k'anọng mba: gol, ọmaana silva, ọmaana brons,  
\v 4 ọmaana ndik sa nde adem blu, ọmaana sa ngor-ihiho, ọmaana sa ngor-izizi, ọmaana ndik-nyokhasẹ nkkakka, ọmaana avu-phyubha,  
\v 5 ọmaana ndenkpa s'erukhimaan-dim sa bẹ aphyok asi-khora, ọmaana ndenkpa nkkakka s'avu, ttara mgbaakha s'akasiya,  
\v 6 ọmaana ana p'oliv p'attwikkaang, ọmaana ekpo pya bẹ am-atzima asi ana pa bẹ am-abyengi anọng k'eho, ttara insẹns,  
\v 7 ọmaana atza pa oniks, atza akkakka adọdọk pa bẹ agbana k'ẹphọd\f + \fr 25.7 \ft ẹphọd ede inọhmakhuma s'ọfọhn-ẹja s'ikhaam abọhk-kwuma p'aren ka mbabaang, ọmaana odikpa, ttara atza ọkkakka pa bẹ atzim adokha mbọhk sẹ ka mbabaang.\f*, ọmaana k'ẹbarakpa ch'ittemmọma. 
\p  
\v 8 “Mẹ wọ, tte bẹ asi irukhabe anang-m, ofona mẹ, kaam ńnuk k'ottem kwabẹ.  
\v 9 Si irukhabe nna, ọmaana effaangin-ẹkpo pyẹ, atzor \it bi hyẹẹr\it* k'odem kwa kaam ńgọhkh-ọ. 
\s1 Ẹkkọhbhi ch'Echekhi 
\p  
\v 10 “Tte bẹ atzima mgbaakha s'akasiya asi ẹkkọhbhi ch'adum pẹ áde ndọkhi nttaan ọmaana akpamma ọhawani, ẹkpa chẹ ede ndọkhi mfa ọmaana akpaama attaan, ebe chẹ ede ndọkhi mfa ọmaana akpamma attaan.  
\v 11 Tzima gol ọkkakka abhọri chẹ k'ẹtzaanga ọmaana k'iyaan, abira atzima gol abaanga ammakpabem pẹ, adokha akhọri.  
\v 12 Tzima gol arabha ariring anna, akhe bẹ ka ndọkhi nna s'ẹkkọhbhi nda. Ariring afa k'okhubha wani, afa k'okhubha nwonggo.  
\v 13 Tzima mgbaakha s'akasiya asi nneremmachi, abhọri sẹ ttara gol.  
\v 14 Kọ khe nneremmachi nna k'ariring mba p'awobh k'ẹbhabhaanga ch'ẹkkọhbhi nda, ifha bẹ atzima atzini chẹ.  
\v 15 Nneremmachi nna ngaambi nwobha m'ariring p'ẹkkọhbhi nda, bẹ kàkhaambi arọbha sẹ.  
\v 16 Kọ khe aphaangi pa kaam ńnang-ọ m'Ẹkkọhbhi nda ch'Echekhi ẹtzaanga. 
\p  
\v 17 “Tzima gol ọkkakka asi ẹkkọhbhikpa ch'ephyokhi. Adum pẹ áde ndọkhi nttaan ọmaana akpamma ọhawani, ẹkpa chẹ éde ndọkhi mfa ọmaana akpamma attaan.  
\v 18 Kọ tzima gol aduk achẹrubim afa, abera k'ikpiho s'ẹkkọhbhi nda.  
\v 19 Si cherub wani ahok k'eho dani, abira asi ọdọdọk ahok k'eho ndonggo. Kọ si achẹrubim mba ọmaana ẹkkọhbhikpa nda agbakha ayok, ka nho mfa s'ẹkkọhbhi nda.  
\v 20 Tte achẹrubim mba akhaama mbabaang sa mmẹma k'ẹrọng mbubha ẹkkọhbhikpa ch'ẹkkọhbhi nda, tte achẹrubim mba akkeri ayok itzitzikha, bẹ akkeri itzitzikha kẹ ẹkkọhbhikpa nda.  
\v 21 Kọ tzọkha ẹkkọhbhikpa nda akhubha k'ebir-ebir kw'Ẹkkọhbhi ch'Echekhi, atzọkha aphaangi pa kaam ńnang-ọ akhe m'ẹtzaanga.  
\v 22 M'ebir-ebir kw'ẹkkọhbhi-kpa nda, ọmaana k'ottem kw'achẹrubim mba p'awobh k'ebir-ebir kw'Ẹkkọhbhi ch'Echekhi nda, wọ kwa kaam ńgebh-ọ, mbiri nnang-ọ asana paam biphyir p'ánang anọng p'Israẹl. 
\s1 Okpokkoro kwa brẹd kw'Ibinọkpaabyi 
\p  
\v 23 “Tzima mgbaakha s'akasiya asi okpokkoro. Adum pẹ áde ndọkhi nttaan, ẹkpa chẹ ede ẹtzọkhi dani ọmaana akpamma azadani, ebe chẹ ede ndọkhi mfa ọmaana akpaama attaan.  
\v 24 Kọ tzima gol ọkkakka abhọri okpokkoro nwa, abira atzima gol abanga ammakpabem adokh-ẹ akhọri.  
\v 25 Kọ biri si ammakpabem p'ẹkpa ebenga mach'ẹbọhkpattem, atzima gol adokha chẹ akhọri.  
\v 26 Tzima gol asi ariring anna p'okpokkoro nwa, adabh bẹ ma nnyọnga nna s'okpokkoro nwa, mẹ da mmo sẹ nna nwobh.  
\v 27 Ariring mba awobha abaanga m'ammakpabem p'ẹkkọhbhi nda, p'abọkha nneremmachi sa bẹ am-atzima atzini okpokkoro nwa.  
\v 28 Tzima mgbaakha s'akasiya asi nneremmachi nna, abhọri sẹ ttara gol, ifha bẹ am-atzima atzini okpokkoro nwa.  
\v 29 Tzima gol ọkkakka asi agbang-gbang, ọmaana nnengakpa, ọmaana akọbh, ttara agbere pa bọng átzima asi nnanga mbyengisẹ.  
\v 30 Nana brẹd kw'awurada m'okpokkoro nwa k'itzitzikha saam, k'ogbe kpenamkpen. 
\s1 Etwikhikkaang-chi 
\p  
\v 31 “Kọ duk gol ọkkakka atzima asi ettwikkaang-chi. Orin kwẹ, ọmaana abọhnga, ọmaana akọbh, ọmaana agbok, ttara adodo pẹ, pyẹ éde echi nda dani.  
\v 32 Abọhnga azadani átzọhnga k'ẹbhabhaanga ch'ettwikkaang-chi, attaan awobha k'okhubha wani, attaan awobha k'okhubha nwonggo.  
\v 33 Akọbh attaan p'ade mach'adodo p'almọn, ttara agbok ọmaana adodo áwobha k'ẹbọhnga dani, attaan k'ẹbọhnga ẹdọdọk, ábira ade odem nwa wani ttara abọhnga mba azadani biphyir, p'ettwikkaang-chi nda.  
\v 34 Etwikhikkaang-chi nda ẹkhaama akọbh anna p'ade mach'adodo p'almọn ttara agbok, ọmaana adodo.  
\v 35 Ogbok wani owobha k'irekh-irek kw'abọhnga-gbakha p'acheden p'atzọhnga m'etwikkaang-chi nda, ogbok kw'ottong afa obiro owobha k'irekh-irek kw'abọhnga-gbakha p'attong afa, ottong agbok attaan, owobha k'irekh-irek kw'abọhnga-gbakha p'attong attaan. Biphyir-phyir bẹ ade abọhnga azadani.  
\v 36 Agbok ọmaana abọhnga mba biphyir áde echi nda dani, ọmaana etwikkaang-chi nda, cha bẹ atzima gol ọkkakka aduk. 
\p  
\v 37 “Mẹ wọ, si atwikkaang azenamfa, anana bẹ k'etwikkaang-chi nda, ifha bẹ amaani k'ottem kw'itzitzikha sẹ.  
\v 38 Tzima gol ọkkakka asi afhẹngbẹ, ọmaana nnengakpa s'ekpon okkikkibha.  
\v 39 Tzima gol ọkkakka asi etwikkaang-chi ch'ẹdọhbh chẹ ede talẹn wani, ọmaana idik kpenamkpen sẹ biphyir.  
\v 40 Kọ re bi asi ọttọhk kpenamkpen atzor k'eden cha kaam ngọhkh-ọ k'egbegbeho. 
\c 26  
\s1 Irukhabe s'Ibinọkpaabyi 
\p  
\v 1 “Tzima mkpekhe jobh sa bẹ atzim ọbara ọkkakka ayok, ọmaana ndik sa nde blu, ọmaana sa ngor-ihiho, ọmaana sa ngor-izizi, ttara achẹrubim p'omengkkakkaa osi, asi irukhabe nna.  
\v 2 Mkpekhe nna biphyir nde mbengabọhk, adum pabẹ ade ndọkhi arọbh afa obhiri mfa, ẹkpa chabẹ ede ndọkhi nzadani.  
\v 3 Kọ khọma mkpekhe nzen atzima si dani, abira akhọma mvonggo ozen atzima si dani.  
\v 4 Si ager p'ade blu akhe k'akhaan-akhaan p'ekpekhe nda dani ch'akhọm, abira asi mando k'ekpekhe ndonggo ch'akhọm.  
\v 5 Si ager arọbh afa obhiri jobh akhe k'ekpekhe dani, abira asi ager arọbh afa obhiri jobh akhe k'ekpekhe ndonggo. Ager mba akkeri ayok itzitzikha.  
\v 6 Mẹ wọ, kọ tzima gol asi agbak arọbh afa obhiri jobh p'abọkha mkpekhe nna atzima k'ibe rani, ifha irukhabe nna ide ibe rani. 
\p  
\v 7 “Kọ tzima avu-phyubha asi mkpekhe jobh obhiri wani, sa nde ikhira sa mbubha irukhabe nna.  
\v 8 Mkpekhe nna jobh obhiri wani biphyir nde mbenga-mbọhk. Adum ade ndọkhi arọbh afa obhiri azen, ẹkpa ede ndọkhi nzadani.  
\v 9 Kọ khọma mkpekhe nzen atzima asi dani, abira akhọma nnonggo nzadani atzima asi dani. Kọni ekpekhe ch'ettong nzadani k'igbe ifa k'ẹhọhmma ch'irukhabe nna.  
\v 10 Si ager arọbh afa obhiri jobh akhe k'ekpekhe dani ch'akhọm, abira akhe ager arọbh afa obhiri jobh k'ekpekhe ndonggo dani ch'akhọm.  
\v 11 Kọ tzima brons asi agbak arọbh afa obhiri jobh, akhe bẹ k'ager mba, atzima atzọhnga mkpekhe nna, ifha ẹbọkha ikhira nna k'ibe rani.  
\v 12 Onode k'adum p'attar-ọttara ka mkpekhe s'ikhira nna, igbokha s'ekpekhe s'irikhi ilẹbhi ibubha k'ẹpannam ch'irukhabe nna.  
\v 13 Adum pa mkpekhe s'ikhira nna áde, ẹtzọkhi dani ọmaana igbokha k'okhubha wani, ẹtzọkhi dani ọmaana igbokha k'okhubha nwonggo. S'irikhi ílẹbhi k'okhubha kpenamkpen, ifha ibhubha irukhabe nna.  
\v 14 Tzima erukhimaandim-kpakpa cha bẹ aphyok asi-khora, abubha ikhira nna. K'ebir-ebir kw'erukhimaandim-kpakpa nda, bubha evu-kpakpa. 
\p  
\v 15 “Tzima mgbaakha s'akasiya asi mkpọmmachi sa mbe-obe k'irukhabe nna.  
\v 16 Adum p'ẹkpọmmachi kpenamkpen áde ndọkhi chi, ẹkpa éde, ndọkhi mfa ọmaana akpamma attaan,  
\v 17 ttara mmo sa njer aho mbenga-mbọhk, nkkeri ayok itzitzikha. Si mkpọmmachi nna biphyir s'irukhabe nna odem nwuma wani.  
\v 18 Si mkpọmmachi ẹrọbh sa nkkeri k'ẹrakha-ẹrakha kw'irukhabe nna,  
\v 19 abira atzima asilva asi nnana arọbh afa, s'akhe k'irekh-irek kwa mkpọmmachi nna, nnana mfa k'ẹkpọmmachi kpenamkpen, ẹnana dani k'eho dani.  
\v 20 K'okhubha kw'ebir-ebira kw'irukhabe nna, si mkpọmmachi ẹrọbh,  
\v 21 ọmaana nnana arọbh afa sa silva, nnana mfa k'ẹkpọmmachi kpenamkpen.  
\v 22 Si mkpọmmachi nzadani k'okhubha k'irukhabe nna kw'ewuchen em-edimi,  
\v 23 abira asi mkpọmmachi mfa ka nyọhnga s'ẹrakha-ẹrakha kw'irukhabe nna.  
\v 24 Kọ akhaambi agbakha mkpọmmachi nna mfa sa nyọhnga s'irukhabe nna, ttẹwọr k'awọr maa apyiri k'aho pabẹ. Akhe bẹ k'oriring wani, bẹ afa áde odem wani.  
\v 25 Mẹ wọ, sẹ ńde mkpọmmachi nzenanttaan, ọmaana nnana s'asilva chi obhiri wani, nnana mfa k'irekh-irek kw'ẹkpọmmachi dani. 
\p  
\v 26 “Kọ biri tzima mgbaakha s'akasiya asi nneremachi, si nzen sa mkpọmmachi s'okhubha wani kw'irukhabe nna,  
\v 27 abira asi nneremachi nzen k'okhubha nwonggo, asi nzen k'okhubha kw'ewuchen em-edimi ka nnam-annam kw'irukhabe nna.  
\v 28 Ereremachi ch'ottem ẹttẹwọr k'eho dani ẹbọkha k'eho ndonggo k'ottem kwa mkpọmmachi.  
\v 29 Tzima gol abhọri mkpọmmachi nna, abira atzima gol asi ariring, p'abọkha nneremachi nna, abira atzima gol abhọri nneremachi nna. 
\p  
\v 30 “Kọ mun irukhabe nna atzor k'odem kwa ngọhkh-ọ k'egbegbeho. 
\p  
\v 31 “Tzima ndik sa nde blu, ọmaana sa ngor-ihiho, ọmaana sa ngor-izizi, ọmaana ndik nkkakka sa bẹ ayokh-oyok asi ekpekhe, ttara achẹrubim p'omengkkakkaa osi.  
\v 32 Rena sẹ k'agbak pa gol ka mkpọmmachi nna nna sa mgbaakha s'akasiya, abhọri sẹ ttara gol, abe sẹ ka nnana nna s'asilva.  
\v 33 Rena ekpekhe nda k'agbak, atzọkha Ẹkkọhbhi ch'Echekhi ahok ka nnam-annam kw'ekpekhe nda. Ekpekhe nda ẹbhaangi Ibe s'Awurada k'ibe s'Awurada p'ayọhng Awurada.  
\v 34 Kọ áhok ẹkkọbhikpa ch'ephyokhi ch'Ẹkkọhbhi ch'Echekhi, k'ibe s'Awurada p'ayọhng Awurada.  
\v 35 Hok okpokkoro k'iyaan s'ekpekhe nda, k'ebir-ebira kw'irukhabe nna, abira ahok etwikkaang-chi ekker-ẹ itzitzikha k'okhubha kw'ẹrakha-ẹrakha. 
\p  
\v 36 “K'ọmma kw'ikhira nna, tzima ndik sa nde blu, ọmaana sa ngor-ihiho, ọmaana sa ngor-izizi ttara ndik nkkakka sa bẹ ayokh-oyok, ọtzọhm f'odokh-ọbara.  
\v 37 Tzima gol asi agbak p'ekpekhe nda, ọmaana mkpọmmachi nzen sa mgbaakha s'akasiya, abhọri ttara gol. Atzima brons aduk nnana nzen sabẹ. 
\c 27  
\s1 Ijafọhnibe s'ẹnanga ẹkwọmichẹ 
\p  
\v 1 “Tzima mgbaakha s'akasiya asi ijafọhnibe s'ikhaama akhubha anna. Ebe chẹ éde ndọkhi nna ọmaana igbokha, adum pẹ áde ndọkhi nzenamfa ọmaana igbokha, ẹkpa chẹ éde ndọkhi nzenamfa ọmaana igbokha.  
\v 2 Gwa obhik ka nyọhnga nna nna, ifha abhik mba ọmaana ijafọhnibe nna ade ọttọhk mvuma vani. Atzima brons abhọri ijafọhnibe nna.  
\v 3 Kọ tzima brons asi ẹtzọhmkpo pyẹ biphyir, atzima si ọrọkha f'itzọtzọhng okpokpokhi, ọmaana asọvẹl, ọmaana agbobhi-mbọhk, ọmaana adaakpa p'akhaam aha, ttara nnengakpa.  
\v 4 Kọ tzima brons asi otzekpa, atzima brons asi ibuni, abira atzima brons asi ariring mba anna biphyir p'otzekpa nwa.  
\v 5 Kẹ otzekpa nwa k'irekh-irek kw'ijafọhnibe, k'odem kw'ibuni nna, ittẹwọr m'ibhaang-ifa s'ijafọhnibe.  
\v 6 Kọ tzima mgbaakha s'akasiya asi mkpọmmachi s'ijafọhnibe nna, abira atzima brons abhọri sẹ.  
\v 7 Kọ ánọhma mkpọmmachi nna k'ariring mba, ifha sẹ ńwobha k'akhubha mba afa p'ijafọhnibe, k'ogbe kwa bẹ atzini.  
\v 8 Tzima agbaakhakpa asi ijafọhnibe nna itte eje. Kọ si sẹ atzor k'odem kw'iwa ngọhkh-ọ k'egbegbeho. 
\s1 Ẹttọmmattem ch'irukhabe s'Ibinọkpaabyi 
\p  
\v 9 “Si ẹttọmmattem ch'irukhabe nna. Tzima ndik nkkakka sa bẹ ayokh-oyok, asi mkpekhe sa ńde ndọkhi arọbh azenamfa obhiri jobh, arena sẹ k'ẹrakha-ẹrakha,  
\v 10 ọmaana mkpọmmachi ẹrọbh, ọmaana nnana sa brons ẹrọbh, ọmaana agbak p'asilva, ttara abarakpa ka mkpọmmachi.  
\v 11 Okhubha kw'ebir-ebira óbiro ode ndọkhi arọbh azenamfa obhiri jobh, ọkhaama mkpọmmachi ẹrọbh, ọmaana nnana sa brons ẹrọbh, ọmaana agbak p'asilva, ttara abarakpa ka mkpọmmachi. 
\p  
\v 12 “Okhubha kw'ewuchen em-edimi kw'ẹttọhmmattem nda, óde ndọkhi arọbh attaan obhiri chi, obiro ọkhaama mkpekhe, ọmaana mkpọmmachi jobh, ttara nnana jobh.  
\v 13 Okhubha kw'okkeri kẹ da ewuchen em-eyin, ẹkpa ch'ẹttọmmattem nda ébire ede ndọkhi arọbh attaan obhiri chi.  
\v 14 Adum pa mkpekhe ade ndọkhi ẹrọbh obhiri mfa ọmaana igbokha, sẹ nwobha k'okhubha wani kw'ọmma, ngaama mkpọmmachi nttaan, ttara nnana nttaan,  
\v 15 mkpekhe sa nde ndọkhi ẹrọbh obhiri mfa ọmaana igbokha k'adum, ngaama mkpọmmachi nttaan, ttara nnana nttaan mbiri nwobha k'okhubha nwonggo. 
\p  
\v 16 “M'ọmma kw'ẹttọhmmattem, si ekpekhe ch'ede ndọkhi ẹrọbh obhiri jobh k'adum, adem pẹ ade blu ọmaana sa ngor-ihiho, ọmaana sa ngor-izizi, ttara ndik nkkakka sa bẹ ayọkh-oyok, kw'óde ọtzọhmbọhk f'odokh-ọbara, obiro ọkhaama mkpọmmachi nna, ttara nnana nna.  
\v 17 Mkpọmmachi biphyir sa mbe ngọri ẹttọmmattem nda, ngaama abarakpa p'asilva, ọmaana agbak, ttara nnana sa brons.  
\v 18 Ẹttọmmattem nda éde, ndọkhi arọbh azenamfa obhiri jobh k'adum, ndọkhi arọbh attaan obhiri chi k'ẹkpa, ẹkhaama mkpekhe sa ndik nkkakka sa bẹ ayokh-oyok sa ngori mpyiri ndọkhi nzenamfa ọmaana igbokha, ttara nnana sa brons.  
\v 19 Ẹtzọhmkpo ẹdọdọk biphyir pya bẹ atzima k'irukhabe nna, ọtzọhm kpenamkpen f'ẹtzọhmkpo mbya, ttara abhing pẹ biphyir p'ikhira, ttara abhing p'ẹttọhmmattem, áde brons. 
\s1 Ana p'ottwikkaang 
\p  
\v 20 “Ben anọng p'Israẹl bi, bẹ atzima ana p'atto \it bi ttaan\it* pa bẹ amyan k'achiduk p'oliv p'anang iyaan, ifha atwikkaang am-ayeni k'ogbe kpenamkpen.  
\v 21 K'irukhabe s'iwobh k'iyaan-iyaan kw'ekpekhe ch'ewobh k'itzitzikha s'Ẹkkọhbhi ch'Echekhi, Aarọn ọmaana va pẹ p'ijinọng am-ohok atwikkaang mba ayeni k'itzitzikha s'Ọvaar Ibinọkpaabyi, ttẹwọr k'ẹchọhkha maa ewu ehobha. Ndọhna nna nde s'anọng p'Israẹl maa opyiri k'igbọ s'íkwu k'ororo. 
\c 28  
\s1 Nnya s'ọfọhnẹja 
\p  
\v 1 “Yeri agbaanakka Aarọn, ọmaana va pẹ p'ijinọng p'ade Nadab, ọmaana Abihu, ọmaana Ẹleyaza, ttara Itamar k'ottem kw'anọng p'Israẹl, ifha bẹ asi ọtzọhm f'afọhnẹja.  
\v 2 Khum nnya s'awurada anang agbaanakka Aarọn, ifha kẹ ọkhaama ikpokpobha ttara abarada.  
\v 3 Ben ajinọng biphyir p'asi emengkka, pa kaam nkk'ekkoji ch'itzọhmbọhk-dema nna nnanga bi, bẹ akhum nnya anang Aarọn, k'ẹbọhk-nana chẹ, ifha osi ọtzọhm f'ọfọhnẹja.  
\v 4 Ma wọ ode nnya sa bẹ ákhum, ẹbarakpa ch'ittemmọma, ọmaana ẹphọd, ọmaana ọnọhma kw'okhum mbọhk, ọmaana ọnọhma-baba, ọmaana ẹbarakpa ch'eho ọdadabh, ttara odikpa kw'erin. Bẹ akhum nnya nna s'awurada anang agbaanakka Aarọn, ọmaana va pẹ p'ijinọng, ifha bẹ asi ọtzọhm f'afọhnẹja.  
\v 5 Tte bẹ atzima ndik sa gol, ọmaana sa nde blu, ọmaana sa ngor-ihiho, ọmaana sa ngor-izizi, ttara ndik nkkakka sa bẹ ayokh-oyok. 
\s1 Ẹphọd 
\p  
\v 6 “Tte amengkkakkaa otzima ndik sa gol, ọmaana sa nde blu, ọmaana sa ngor-ihiho, ọmaana sa ngor-izizi, ttara ndik nkkakka sa bẹ ayokh-oyok, okhum ẹphọd.  
\v 7 Ch'ẹ́khaama mbarakpa mfa ka mbabaang, pa bẹ akhum araakha ka nyọhnga sẹ mfa, ifha ẹbọkha ayok.  
\v 8 Odikpa kwẹ kwa bẹ átzima emengkka ayok, óde odem wani ttara ẹphọd nda, bẹ ayokh-ẹ ttara ndik sa gol, ọmaana sa nde blu, ọmaana sa ngor-ihiho, ọmaana sa ngor-izizi, ttara ndik nkkakka sa bẹ ayokh-oyok. 
\p  
\v 9 “Tzọkha atza afa p'oniks, akkẹr che pa va p'Israẹl p'ijinọng mẹ.  
\v 10 Kkẹr che azadani k'ọtza wani, abira akkẹr che mbonggo azadani k'ọtza nwonggo, kkẹr che mba atzor k'igbọ sabẹ.  
\v 11 Kkẹr che pa va p'Israẹl p'ijinọng m'atza mba afa, mach'ira omengkkakkaa ọkkẹr ọttọhk k'atza. Bẹ gol akhọri ammakpabem p'atza mba afa,  
\v 12 abira akpa bẹ k'abarakpa mba pa mbabaang s'ẹphọd, mach'atza p'ojima anang va p'Israẹl p'ijinọng. Aarọn om-otzima che mba ka mbabaang sẹ mach'ojima k'itzitzikha s'Ọvaar Ibinọkpaabyi.  
\v 13 Bẹ gol akhọri ammakpabem p'atza mba afa,  
\v 14 ọmaana mgbakkọhbh mfa sa gol mach'edik, agbana sẹ k'atza mba. 
\s1 Ẹbarakpa ch'ittemmọma 
\p  
\v 15 “Khum ẹbarakpa ch'ittemmọma ch'ochibhi kw'Ibinọkpaabyi ororor, kw'ode ọtzọhm f'omengkkakkaa. Tzima ndik sa gol, ọmaana sa nde blu, ọmaana sa ngor-ihiho, ọmaana sa ngor-izizi, ttara ndik nkkakka sa bẹ ayokh-oyok, akhum chẹ mach'ẹphọd.  
\v 16 Éde akhubha anna, idikha anyọhng chẹ ọnyọhnga, adum pẹ ọmaana ẹkpa chẹ áde mbenga-mbọhk, ayom ẹbọhkpattem.  
\v 17 Bẹ adik anna p'atza p'ajibh-ojibh mẹ. M'odik kw'ocheden, ábẹ ọtza kwa ruby, ọmaana kwa topaz, ttara kwa bẹryl,  
\v 18 k'odik kw'ottong afa bẹ ọtza kwa tọkwọis, ọmaana kwa saphira, ttara kw'ẹmẹral;  
\v 19 k'odik kw'ottong attaan bẹ ọtza kwa jasin, ọmaana kw'agate, ttara kw'amẹtist,  
\v 20 k'odik kw'ottong anna bẹ ọtza kwa krisolita, ọmaana kw'oniks, ttara kwa jasper. Bẹ gol akhọri ammakpabem p'atza mba.  
\v 21 Bẹ áde atza jobh obhiri afa, kpenamkpen otzera che cha nnwa wani kw'Israẹl kw'ijinọng, kpenamkpen obe mach'ẹkhọhkha, ttara che ch'efonamma dani ch'Israẹl. 
\p  
\v 22 “Tzima gol kwa bẹ ayokh-oyok mach'edik, asi mgbakkọhbh.  
\v 23 Tzima gol asi ariring afa, atzima akpa bẹ ka nyọhnga s'ẹbarakpa nda ch'ittemmọma.  
\v 24 Kpa mgbakkọhbh nna mfa sa gol k'ariring mba pa nyọhnga s'ẹbarakpa nda ch'ittemmọma,  
\v 25 abira akpa aho mbonggo afa pa mgbakkọhbh k'atza mba afa, amaana k'abarakpa pa mbabaang, k'itzitzikha s'ẹphọd.  
\v 26 Si ariring pa gol afa, agbana bẹ ka nyọhnga nnonggo mfa k'ẹtzaanga kw'ẹbarakpa ch'ittemmọma abaanga ẹphọd.  
\v 27 Biri tzima gol asi ariring afa, agbana bẹ k'irekhirek kw'abarakpa pa mbabaang k'itzitzikha s'ẹphọd, ọbaanga ibe sa bẹ atzọhng k'ebir-ebir kwa mkpansin kw'ẹphọd.  
\v 28 Tzima edik blu, akpa ariring p'ẹbarakpa ch'ittemmọma ọmaana ariring p'ẹphọd, agbana ka mkpansin, ifha ẹbarakpa ch'ittemmọma eningi ẹ́wọkhi k'ẹphọd. 
\p  
\v 29 “K'ogbe kpenamkpen kw'Aarọn ọ́nwa k'Ibe s'Awurada, óm-otzima che pa va p'Israẹl p'ijinọng m'ittemmọma sẹ, pa bẹ abẹ k'ẹbarakpa ch'ittemmọma ch'ochibhi kw'Ibinọkpaabyi ororor, mach'ojima kw'ochina ororo k'itzitzikha s'Ọvaar Ibinọkpaabyi.  
\v 30 Biri bẹ ose kw'Urim\f + \fr 28.30 \fq Urim ọmaana Tumim\ft ade mach'ose kw'iwa afọhnẹja am-abhari atzima aronga ochibhi kw'Ibinọkpaabyi.\f* ọmaana Tumim k'ẹbarakpa ch'ittemmọma, ifha bẹ am-afha awobha m'ittemmọma s'Aarọn, k'ogbe kpenamkpen kw'oyini Ọvaar Ibinọkpaabyi k'itzitzikha. Mẹ wọ, Aarọn óm-otzima ekpo mbya k'ittemmọma sẹ, obe k'ọphaangi kw'achibhi osisi, k'eho ch'anọng p'Israẹl, k'itzitzikha s'Ọvaar Ibinọkpaabyi. 
\s1 Nnya nnonggo s'ọfọhnẹja 
\p  
\v 31 “Tzima ibara s'ide blu biphyir akhum ọnọhma-baba kw'ẹphọd,  
\v 32 ahok ọmma k'ottem kw'ókhe eho. Bẹ abhọri ọmma nwa kw'eho ẹmma, mach'ẹnọhma-khokhora, ifha chẹ eningi ẹjaakhi.  
\v 33 Tzima ndik sa nde blu, ọmaana sa ngor-ihiho, ọmaana sa ngor-izizi, ayok aduk pa pomegranet, agbana akkaningkka pa gol k'ottem kwabẹ. Tzima ndik nna abhọri ẹmma ch'inọhmakhuma nna, ttara akkaningkka pa gol k'ottem kwabẹ.  
\v 34 Akkaningkka mba pa gol, ọmaana apomegrenet awobha ayok k'ottem, akhọri ẹbaramma ch'ọnọhma-baba nwa.  
\v 35 Aarọn ọkhaambi ọfọra chẹ k'ogbe kw'ọsi ọtzọhm f'ọfọhnẹja. Bẹ ábhaanga amọng p'akkaningkka mba, k'ogbe kw'odim k'Ibe s'Awurada k'itzitzikha s'Ọvaar Ibinọkpaabyi, ọmaana k'ogbe kw'óyin k'iyaan, ifha oningi ópe. 
\p  
\v 36 “Tzima gol ọkkakka asi ẹchachaangkpa, akkẹr mẹ mach'ẹkhọhkha bi, AWURADA AWOBH ANANG ỌVAAR IBINỌKPAABYI.  
\v 37 Atzima edik blu akpẹ-ẹ amaana k'ibara s'eho ọdadabh; ch'éwobha k'itzitzikha s'ibara nna s'eho ọdadabh.  
\v 38 Chẹ éwobha Aarọn k'itzitzikha-ttem, Aarọn ọ́tzọkha oponga-pyibha kw'owobh ka nnanga s'awurada s'anọng p'Israẹl atte ọbọhk anang-m, odem kpenamkpen kwa nnanga sabẹ nde. Mando kw'echina ororo ewobha Aarọn m'itzitzikha-ttem, ifha Ọvaar Ibinọkpaabyi ókhera ọtzọkha nnanga nna. 
\p  
\v 39 “Tzima ndik nkkakka sa bẹ ayokh-oyok ayok ọnọhma-baba nwa, abira atzima ndik nkkakka sa bẹ ayokh-oyok ayok ibara nna s'eho ọdadabh. Tte odikpa kw'erin óde ọtzọhmbọhk f'odokh-ọbara.  
\v 40 Biri khum ọnọhma-baba, ọmaana ẹbarakpadik, ttara abarakpa p'eho anang va p'Aarọn p'ijinọng, ifha bẹ akhaama ikpokpobha ttara abarada.  
\v 41 Akk'agbaanakka Aarọn ọmaana va pẹ p'ijinọng nnya nna afọra, abyengi bẹ ana k'eho, abira anana bẹ ọbọhk k'eho. Si bẹ awur, ifha bẹ afha asi ọtzọhm f'afọhnẹja anang-m. 
\p  
\v 42 “Tzima ndik sa bẹ ayokh-oyok akhum akpokhuma p'ẹtzaanga, p'afona k'erin apyiri ka ndaak, pa bẹ am-atzima abubha for.  
\v 43 Aarọn ọmaana va pẹ p'ijinọng akhaambi, afọra pyẹ k'ogbe kpenamkpen kwa bẹ adim k'irukhabe, obiro ode bi bẹ areng achina k'ijafọhnibe bi, bẹ asi ọtzọhm k'Ibe s'Awurada, ifha bẹ aningi oponga-pyibha atzọk, abira ape. 
\p “Ma wọ ode ndọhna sa ńwobha nnang Aarọn, ọmaana va pa va pẹ, maa ogbe ode. 
\c 29  
\s1 Odem kwa bẹ asi afọhnẹja p'Ibinọkpaabyi awur 
\p  
\v 1 “Ma wọ ode odik kw'ási, ifha asi bẹ awur, ifha bẹ afha asi ọtzọhm f'afọhnẹja. Tzọkha ọbhaamnwa-dim, ọmaana arukhimaan-dim afa p'ani ekhem atzim.  
\v 2 Biri tzima abubuma akkakka pa wit, asi brẹd kwa bẹ ani yist akhe, ttara ekpo ẹkkaanga-pyẹ pya bẹ akhe ana, ttara brẹd kwa bẹ ani yist akhe, bẹ abira ayaang ana p'oliv.  
\v 3 Yikha pyẹ k'ikhiriba atzima akwu, ọmaana ẹbhaam nduma, ttara arukhimaan-dim mba afa.  
\v 4 An-atzima Aarọn, ọmaana va pẹ p'ijinọng abira akwu k'ẹhọhmma ch'irukhabe nna, atzima asi agbobhi bẹ for.  
\v 5 Tzọkha nnya nna afọra Aarọn, ọmaana ọnọhma-baba, ọmaana ọnọhma kw'okhum mbọhk kw'ẹphọd, ọmaana ẹphọd ọkhaam, ttara ẹbarakpa ch'ittemmọma. Akpẹ-ẹ mkpansin kwa bẹ atzim emengkka ayok, atzima abọkha ẹphọd nda m'erin.  
\v 6 Dabh-ẹ ẹbarakpa ch'eho ọdadabh m'eho, abira afọr-ẹ ikpo s'awuruda amaana m'ẹbarakpa nda ch'eho ọdadabh.  
\v 7 Atzọkha ana pa bẹ am-abyengi ọnọng k'eho, abyeng-ẹ k'eho.  
\v 8 Atzima va pẹ p'ijinọng akwu, afọra bẹ anọhma-baba,  
\v 9 abira adabh bẹ abarakpa p'eho ọdadabh. Akpa Aarọn ọmaana va pẹ p'ijinọng ẹbarakpadik. Ndọhna nna s'ọfọhnẹja ńde sabẹ, maa ogbe ode. M'eden nda dọ ch'ánana Aarọn, ọmaana va pẹ p'ijinọng ọbọhk k'eho. 
\p  
\v 10 “Tzima ọbhaamdim akwu k'itzitzikha s'irukhabe nna, Aarọn ọmaana va pẹ p'ijinọng ánan-ẹ mbọhk k'eho.  
\v 11 Yẹk ọbhaamdim nwa ẹdọhngi m'itzitzikha s'Ọvaar Ibinọkpaabyi, m'ọmma kw'irukhabe.  
\v 12 Tzima ẹnọhna chọ, agberi izi rani s'ọbhaamdim nwa, achọkhi k'abhik p'ijafọhnibe, abira atzọkha izi s'irikhi abyengi m'orin kw'ijafọhnibe nna.  
\v 13 Atzọkha iyaak biphyir s'ibhọri abhọri, ọmaana s'ibubh anaang, ttara iyaak s'ibubh ndọdọri, akwọmi pyẹ m'ijafọhnibe.  
\v 14 Yina, tzima ekpon akwọmi ayara p'ọbhaamdim nwa, ọmaana ẹkpakpa chẹ, ttara afu k'iyaan-iyaan s'ibhingabe. Ma wọ ode ẹnanga ch'ẹkhọngkwuri ogbogbobhi. 
\p  
\v 15 “Kọ tzọkha erukhimaan-dim dani ma mbuma afa, Aarọn, ọmaana va pẹ p'ijinọng ánana chẹ mbọhk k'eho.  
\v 16 Yẹk erukhimaan-dim nda ẹdọhngi, atzọkha izi sẹ apyakhi k'akhaan-akhaan biphyir p'ijafọhnibe nna.  
\v 17 Jọhkhi erukhimaan-dim nda k'abir-ibiri, abira agbobhi abhọri pẹ, ọmaana mmo, atzọkha eho attara, ọmaana abiri-biri mbonggo.  
\v 18 An-akwọmi erukhimaan-dim nda biphyir m'ijafọhnibe nna. Ma wọ ode ẹnanga ẹkwọmichẹ anang Ọvaar Ibinọkpaabyi, ch'ẹdaami eruk, ebere ede ẹnanga cha bẹ areng k'ekpon akwọmi anang Ọvaar Ibinọkpaabyi. 
\p  
\v 19 “Kọ tzọkha erukhimaan-dim ndongo, Aarọn ọmaana va pẹ p'ijinọng ánana chẹ mbọhk k'eho.  
\v 20 Yẹk chẹ ẹdọhngi, atzọkha izi rani sẹ abọra k'atzọhngkpa p'odimbọhk kw'Aarọn, ọmaana pa va pẹ p'ijinọng, ọmaana ka nnọhnadim s'adimbọhk pabẹ, ọmaana ka nnọhnadim s'adimmo pabẹ. An-apyakhi izi k'akhaan-akhaan biphyir p'ijafọhnibe nna.  
\v 21 Biri tzọkha izi rani k'ijafọhnibe, attara k'ana pa bẹ am-abyengi ọnọng k'eho apyakhi Aarọn, ọmaana ka nnya sẹ, abira apyakhi va pẹ p'ijinọng, ọmaana ka nnya sabẹ. Mẹ wọ, kẹ ọmaana va pẹ p'ijinọng, ọmaana nnya sabẹ án-ade anọng pa bẹ akk'asa awur. 
\p  
\v 22 “Kọ tzọkha iyaak s'erukhimaan-dim nda, ọmaana iyaak s'ẹsara, ọmaana iyaak s'ibubh abhọri, ọmaana s'ibubh anaang, ọmaana iyaak sa ndọdọri, ttara ọtzaak kw'odimmo. Ma wọ ode erukhimaan-dim ch'ẹbọhk-nana.  
\v 23 M'ikhiriba nna sa brẹd kwa bẹ ani yist akhe, s'iwobh m'itzitzikha s'Ọvaar Ibinọkpaabyi, kọ tzọkha brẹd wani, wani kw'ọdọhni-ọdọhni kwa bẹ akhe ana, ttara wani kw'oyor-oyori.  
\v 24 Kọ tzọkha pyẹ biphyir akhe Aarọn, ọmaana va pẹ p'ijinọng ka mbọhk, awokhi pyẹ mach'ẹnanga ch'ẹbar-odik k'itzitzikha s'Ọvaar Ibinọkpaabyi.  
\v 25 An-atzọkha pyẹ ka mbọhk sabẹ, akwọmi k'ijafọhnibe, ttara ẹnanga ẹkwọmichẹ, ch'ẹdaami Ọvaar Ibinọkpaabyi eruk, ẹnanga cha bẹ areng k'ekpon akwọmi anang Ọvaar Ibinọkpaabyi.  
\v 26 K'ogbe kw'akk'ẹba ch'erukhumaan-dim nda atzima asi ẹbọhk-nana ch'Aarọn, mach'ẹnanga ch'ẹbar-odik k'itzitzikha s'Ọvaar Ibinọkpaabyi, ch'éde ekkema chọ. 
\p  
\v 27 “Kọ tzọkha nden nna s'erukhimaan-dim ch'ẹbọhk-nana, s'Aarọn ọmaana va pẹ p'ijinọng, aba p'ira bẹ awokhi, ọmaana ọtzaak kw'ira bẹ anangi, asi sẹ nwur.  
\v 28 Ma wọ ode ekkema cha anọng p'Israẹl am-anang Aarọn ọmaana va pẹ p'ijinọng k'ogbe kpenamkpen. Ma wọ ode ọtzabha kw'anọng p'Israẹl am-asi anang Ọvaar Ibinọkpaabyi, kw'ofona k'ẹnanga chabẹ ch'odidiri. 
\p  
\v 29 “Nnya s'awurada s'Aarọn ngaam va pa va pẹ, ifha bẹ afha abyengi bẹ ana k'eho, ọmaana bi bẹ abira anana bẹ mbọhk k'eho.  
\v 30 Nnwa kw'ijinọng kw'ọtzọk ewobha ch'otte mach'ọfọhnẹja, okwu bi okwu osi ọtzọhm k'irukhabe k'Ibe s'Awurada, ọm-ọfọra nnya nna k'iwu izenamfa. 
\p  
\v 31 “Kọ tzọkha erukhimaan-dim ch'ẹbọhk-nana, awọhn chẹ m'ibe s'awurada.  
\v 32 M'ẹhọhmma ch'irukhabe, Aarọn ọmaana va pẹ p'ijinọng awobha mẹ achi nden s'erukhimaan-dim nda, ọmaana brẹd kw'owobh m'ikhiriba nna.  
\v 33 Bẹ áchi nnanga nna s'egbobhi ch'ephyokhi, cha bẹ asi k'ẹbọhk-nana chabẹ, ọmaana owuwur kwabẹ. Yina, ọnọng ọdọdọk oningi pyẹ ochi, okhuri bi, pyẹ ewur-owur.  
\v 34 Kpenamkpen f'ohobh ewu, ode etzen, obiro ode brẹd, bọng kwọmi chẹ k'ekpon, ọnọng kọ̀khaambi ochi fẹ, okhuri bi, fẹ owur-owur. 
\p  
\v 35 “Si odik kpenamkpen kwa nkk'ndọhna anang Aarọn ọmaana va pẹ p'ijinọng, atzima iwu izenamfa anana bẹ ọbọhk k'eho.  
\v 36 Ewu kpenamkpen tzima ọbhaamdim asi ẹjafọhni, ch'ede mach'ẹnanga ch'ẹkhọngkwuri ogbogbobhi. Gbobhi ephyok atzima asi ijafọhnibe iwur, abira abyengi sẹ ana, ifha asi sẹ iwur.  
\v 37 Tzima iwu izenamfa agbobhi ephyok ch'ijafọhnibe, abira asi sẹ iwur. Mẹ wọ, ijafọhnibe nna in-ide ibe s'awurada, ọttọhk kpenamkpen f'ọttọhmi sẹ ón-owur-owur. 
\p  
\v 38 “Ma wọ ode ẹnanga ch'am-anang k'ijafọhnibe k'ewu kpenamkpen, arukhimaanva afa p'ade cho wani.  
\v 39 Nang wani k'ekpebha, abira anang wani k'ẹchọhkha.  
\v 40 K'ocheden-rukhimaan-nwa, yoma ogbobhimbọhk wani k'agbobhimbọhk jobh p'abubuma pa wit, attara ẹna-gbomma dani ch'ana p'olive, ọmaana etzuk-gbomma dani atzima mach'ẹnanga ch'etzuk-byengi.  
\v 41 Kọ tzima orukhimaan-nwa nwonggo asi ẹjafọhni k'ẹchọhkha, ttara ẹnanga ch'abọkpa, ọmaana ẹnanga ch'etzuk-byengi mach'ira asi k'ekpebha, ch'ẹdaami eruk, cha bẹ areng k'ekpon akwọmi anang Ọvaar Ibinọkpaabyi. 
\p  
\v 42 “Igbọ s'ikwu k'ororo im-isi ẹnanga ẹkwọmichẹ nda k'ogbe kpenamkpen, k'ẹhọhmma ch'irukhabe, k'itzitzikha s'Ọvaar Ibinọkpaabyi. Mẹ wọ kwa kaam ńgebh-ọ, mbiri mgbaak atzim nnang-ọ;  
\v 43 mẹ wọ kwa kaam mbiri ńgebha anọng p'Israẹl, ńdima abarada paam nsi ibe nna iwur. 
\p  
\v 44 “Mẹ wọ, kaam ńsi irukhabe nna ọmaana ijafọhnibe nna iwur, mbiri ńsi Aarọn ọmaana va pẹ p'ijinọng awur, ifha bẹ asi ọtzọhm f'afọhnẹja.  
\v 45 Mẹ wọ, kaam ńwobha k'ottem kw'anọng p'Israẹl, mbiri nde Ibinọkpaabyi kwabẹ.  
\v 46 Bẹ áronga bi, kaam wọ nde Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kwabẹ, kw'otzim bẹ obina k'Ijip, ifha nnuk ttara bẹ. Kaam wọ nde Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kwabẹ. 
\c 30  
\s1 Ijafọhnibe s'insẹns 
\p  
\v 1 “Bọng dima mgbaakha s'akasiya asi ijafọhnibe sa bọng am-akwọmi insẹns.  
\v 2 Si sẹ ikhaama akhubha anna. Adum pẹ ọmaana ẹkpa chẹ áde ebenga-mbọhk kw'ode ẹtzọkhi ọmaana igbokha, ebe chẹ éde ndọkhi nttaan, abhik pẹ afona m'ẹgbaakha nduma dani.  
\v 3 Tzima gol ọkkakka abubha ebir-ebir kwẹ, ọmaana akhaan-akhaan pẹ biphyir, ttara abhik. Abira atzima gol abhọri ammakpabem pẹ akhori.  
\v 4 Tzima gol asi ariring afa, akhe bẹ akkeri ayok itzitzikha m'ijafọhnibe nna, k'irekh-irek kw'ammakpabem mba pa gol, ifha bẹ abọkha mkpọmmachi sa bẹ am-atzima atzini ijafọhnibe nna.  
\v 5 Tzima mgbaakha s'akasiya asi mkpọmmachi, atzima gol abhọri sẹ.  
\v 6 Hok ijafọhnibe nna k'itzitzikha s'ekpekhe ch'ewobh k'itzitzikha s'Ẹkkọhbhi ch'Echekhi, k'itzitzikha s'ẹkkọhbhikpa ch'ephyokhi ch'ewobh k'ebir-ebir kw'Ẹkkọhbhi ch'Echekhi, kẹ da kaam ńgebh-ọ. 
\p  
\v 7 “K'ekpebha kpenamkpen, Aarọn ọkhaambi ọkwọmi insẹns kw'ọdaami eruk m'ijafọhnibe nna, k'ogbe kw'ọm-ọtza okkeri attwikkaang.  
\v 8 Kẹ ọkhaambi obiro ọkwọmi insẹns, mada oyeni attwikkaang k'ẹchọhkha, mẹ wọ, insẹns ákwọmi k'ogbe kpenamkpen k'itzitzikha s'Ọvaar Ibinọkpaabyi, maa apyiri k'igbọ s'ikwu k'ororo.  
\v 9 Bọng insẹns adọdọk kàtzima akwu m'ijafọhnibe nna, ode ẹnanga ẹkwọmichẹ kpenamkpen, obiro ode ẹnanga ch'abọkpa o, ode etzuk-byengi o, bọng m'ijafọhnibe nna kàsi.  
\v 10 Aarọn om-osi ẹjafọhni nda ch'ephyokhi ogbe wani ka cho, k'abhik p'ijafọhnibẹ nna. Kẹ ọkhaambi otzima izi s'etzen osi ẹjafọhni nda ch'ephyokhi cha cho, ch'éde ẹnanga ch'ẹkhọngkwuri ogbogbobhi, ch'igbọ s'ikwu k'ororo. Ẹjafọhni nda ede ch'ewur-owur ẹnang Ọvaar Ibinọkpaabyi.” 
\s1 Ọtzabha kw'ẹjafọhni ch'ephyokhi 
\p  
\v 11 Mẹ wọ, Ọvaar Ibinọkpaabyi oben Mosẹs bi,  
\v 12 “Mada atzọkha obhik kw'anọng p'Israẹl, ọnọng kpenamkpen ọkhaambi osi ẹtzabha ch'ebhekha ch'akpen pẹ ọnang Ọvaar Ibinọkpaabyi, mada bẹ abhikh-ẹ. Mẹ wọ, itzama s'ítto ikhebha bẹ kíde, mada abhik bẹ.  
\v 13 Ọnọng kpenamkpen kwa bẹ akk'abhikha, ọnang ishẹkẹl-bhakha otzor ka shẹkẹl kw'ọhọhm kw'awurada, kw'ọdọhbhi opyiri agẹra ẹrọbh. Ishẹkẹl-bhakha nna ide ẹnanga ẹnang Ọvaar Ibinọkpaabyi.  
\v 14 Anọng biphyir pa bẹ akk'abhikha p'ade cho ẹrọbh obhir-obhiri, ánang Ọvaar Ibinọkpaabyi ẹnanga.  
\v 15 Mada bọng ási ẹnanga ch'ephyokhi anang Ọvaar Ibinọkpaabyi, tte akkọkkaa aningi anangi ayongi ishẹkẹl-bhakha, agbogbora aningi abira anang f'ọkhar ọyọhnga ishẹkẹl-bhakha.  
\v 16 Kọ tzọkha ọtzabha kw'ẹjafọhni ch'ephyokhi k'anọng p'Israẹl, atzima asi ọtzọhm f'irukhabe s'Ọvaar Ibinọkpaabyi. Odik nwa ode ojima ọnang anọng p'Israẹl k'itzitzikha s'Ọvaar Ibinọkpaabyi, obiro óde ẹjafọhni ch'ephyokhi ọnang for sabọng ọkhaam.” 
\s1 Ọkwakkama kwa mbọhk ttara mmo ogbogbobhi 
\p  
\v 17 Mẹ wọ, Ọvaar Ibinọkpaabyi oben Mosẹs bi,  
\v 18 “Tzima brons asi ọkwakkama kwa mbọhk ttara mmo ogbogbobhi, abira atzima brons asi ẹnana chẹ. Kẹ asi m'ọkwakkama nwa, aber-ẹ k'ottem kw'irukhabe ttara ijafọhnibe.  
\v 19 Tte Aarọn ọmaana va pẹ p'ijinọng agbobhi mbọhk, ọmaana mmo sabẹ, ttara asi p'ọkwakkama nwa.  
\v 20 K'ogbe kpenamkpen kwa bẹ adim m'irukhabe nna, bẹ ágbobhi mbọhk ọmaana mmo, ifha bẹ aningi ápe. Bẹ abira asi mando k'ogbe kwa bẹ arenga afora ijafọhnibe nna bi, bẹ atza asi ẹnanga ch'ọchattọhk anang Ọvaar Ibinọkpaabyi.  
\v 21 Bẹ ágbobhi mbọhk, ọmaana mmo sabẹ, ifha bẹ aningi ápe. Ọphaangi nwa owobha ọnang Aarọn, ọmaana va pẹ p'ijinọng, ttara va pa va pẹ, maa apyiri k'igbọ s'íkwu k'ororo.” 
\s1 Ana p'ẹbọhk-nana k'eho 
\p  
\v 22 Mẹ wọ, Ọvaar Ibinọkpaabyi oben Mosẹs bi,  
\v 23 “Tzọkha adem mba p'ekpo ọkkakka py'em-esi ọttọhk ọdaam eruk: mach'ashẹkẹl ẹnọhna obhiri arọbh azen pa myrrh kw'ode asi-asi, ọmaana ashẹkẹl arọbh jobh obhiri afa obhiri jobh pa sinamọn, ọmaana ashẹkẹl arọbh jobh obhiri afa obhiri jobh pa kalamus,  
\v 24 ọmaana ashẹkẹl ẹnọhna obhiri arọbh azen pa kasiya. Bẹ biphyir atzor k'ẹnanga ch'ọhọhm kw'awurada, ttara ẹna-gbomma ch'ana p'oliv.  
\v 25 Kọ tzima pyẹ asi ana p'ẹbọhk-nana ch'awurada, p'adaami eruk, ọtzọhmbọhk f'osi-ekpo py'ẹm-ẹdaam eruk, osi. Bẹ áde ana p'ẹbọhk-nana ch'awurada.  
\v 26 Mẹ wọ, byengi bẹ k'irukhabe, ọmaana k'Ẹkkọhbhi ch'Echekhi,  
\v 27 ọmaana k'okpokkoro ttara ekpo py'ẹnan mẹ biphyir, ettwikkaang-chi ttara ekpo pyẹ biphyir, ọmaana k'ijafọhnibe s'insẹns,  
\v 28 ọmaana ijafọhnibe s'ẹnanga ẹkwọmichẹ ttara ekpo pyẹ biphyir, ọmaana ọkwakkama ttara ẹnana chẹ.  
\v 29 Kọ ási pyẹ ewur, ifha pyẹ en-edo ewur-owur, ọttọhk kpenamkpen f'ọtọhmi pyẹ, fẹ on-owur-owur. 
\p  
\v 30 “Kọ si Aarọn ọmaana va pẹ p'ijinọng awur, ifha bẹ afha asi ọtzọhm f'afọhnẹja.  
\v 31 Gbaak anọng p'Israẹl bi, ‘Ana mba ade ana paam p'ẹbọhk-nana ch'awurada, maa apyiri k'igbọ s'íkwu k'ororo.  
\v 32 Ọnọng ana mba ka for kàbyengi, ana adọdọk kabira asi m'eden nda ch'asi mba, okhuri bi, ana mba ade ana p'awurada, bọng abira atzọkha bẹ bi, be ade ana p'awurada.  
\v 33 Ọnọng kpenamkpen kw'on-osi ana p'adaami eruk macha mba, ode bi, ọnọng on-obiro obyengi ọnọng ọdọdọk ana mba kw'oyongi ọfọhnẹja, bẹ akhaambi akhubh-ẹ k'obhon.’ ” 
\s1 Insẹns 
\p  
\v 34 Mẹ wọ, Ọvaar Ibinọkpaabyi oben Mosẹs bi, “Tzọkha ekpo py'em-esi ekpo ẹdaam eruk macha resin, onicha, ọmaana galbanum, ttara insẹns ọkkakka, ayoma pyẹ mbengana,  
\v 35 abhuna pyẹ atzima asi insẹns, ode ọtzọhmbọhk f'osi-ekpo py'ẹdaami eruk. Insẹns nwa ode abubuma, ode ọkkakka kwẹ, obiro ode kw'awurada.  
\v 36 Tzọkha byani akhok k'abubuma, atzọkha abera k'itzitzikha s'Ẹkkọhbhi ch'Echekhi, k'irukhabe, kẹ da kaam ńgebh-ọ. Sẹ íde ibe s'in-ido iwur-owur inang bọng.  
\v 37 Kọ insẹns ọdọdọk manda wani m'eden nda kàsi anang for sọ. Kọ re bẹ mach'ana p'awurada anang Ọvaar Ibinọkpaabyi.  
\v 38 Ọnọng manda wani kw'osi ana p'akheri mba, ifha ọbhaanga eruk-daamada chẹ, bẹ akhaambi akhubh-ẹ k'obhon.” 
\c 31  
\s1 Bẹzalẹl ọmaana Oholiyab 
\p  
\v 1 Iwa Ọvaar Ibinọkpaabyi oben Mosẹs bi,  
\v 2 “Kker e, kaam nkk'Bẹzalẹl nnwa kw'ijinọng kw'Uri, kw'ode nnwa kwa Hur k'efona cha Juda ndekha.  
\v 3 Kaam nkk'ẹ Egwugwuma ch'Ibinọkpaabyi nnanga, ọmaana ekkoji, ọmaana eronga, ttara otzitzin kw'emengkka kpenamkpen osisi,  
\v 4 ifha osi ọtzọhm f'otzetzekha fa gol, ọmaana silva, ttara brons,  
\v 5 f'ọkpaara atza obiro odokha bẹ, ọmaana nchi ọgwagwa, ttara omengkka-tzọhm kpenamkpen osisi.  
\v 6 Ayongi mẹ, kaam nkk'Oholiyab nnwa kw'ijinọng kw'Ahisamak, k'efona cha Dan ndekha bi, ọkhẹ-ẹ ọbọhk. Kaam nkk'amengkkakkaa biphyir emengkka nnanga, cha bẹ atzima asi ọttọhk kpenamkpen fa nkk'ọ ndọhna:  
\v 7 mach'irukhabe, ọmaana Ẹkkọhbhi ch'Echekhi, ọmaana ẹkkọhbhikpa ch'ephyokhi, ttara ekpo py'ẹnya ẹdọdọk biphyir py'ikhira nna,  
\v 8 mach'okpokkoro ttara ekpo py'ẹnana mẹ biphyir, ọmaana ettwikkaang-chi cha gol ọkkakka ọmaana ekpo pyẹ biphyir, ọmaana ijafọhnibe s'insẹns,  
\v 9 ọmaana ijafọhnibe s'ẹnanga ẹkwọmichẹ ọmaana ekpo biphyir py'ẹtzọni chẹ abẹ, ọmaana ọkwakkama ttara ẹnana chẹ,  
\v 10 ọmaana nnya nyokhasẹ, nnya s'awurada s'Aarọn kw'ode ọfọhnẹja, ọmaana nnya sa va pẹ p'ijinọng k'ogbe kwa bẹ asi ọtzọhm f'afọhnẹja,  
\v 11 ọmaana ana pa bẹ am-abyengi ọnọng k'eho, ttara insẹns kw'ọdaami eruk kwa bẹ ahok k'Ibe s'Awurada. Tte bẹ asi idik nna atzor k'eden cha ndọhn-ọ.” 
\s1 Ẹwọhngkwokhawu 
\p  
\v 12 Mẹ wọ, Ọvaar Ibinọkpaabyi oben Mosẹs bi,  
\v 13 “Ben anọng p'Israẹl bi, bọng akhaambi ahok Nwọhngkwokhawu saam. Ma wọ óde ẹkhọhkha k'ottem kwa kaam ọmaana bọbọng, ttara igbọ s'íkwu k'ororo, ifha bọng aronga bi, kaam wọ nde Ọvaar Ibinọkpaabyi, kw'om-osi bọng awur. 
\p  
\v 14 “Bọng hok Ẹwọhngkwokhawu nda, okhuri bi, ch'ede ewu ch'awurada ẹnang bọng. Ọnọng kpenamkpen kw'olukhi ewu nda, bẹ akhaambi afhẹ-ẹ; ọnọng kpenamkpen kw'osi ọtzọhm manda vani m'ewu nda, bẹ akhaambi afhẹ-ẹ.  
\v 15 Iwu izadani rọ sa bọng asi ọtzọhm, yina, ewu nda ch'ettonga izenamfa, ede Ẹwọhngkwokhawu ch'awurada ẹnang Ọvaar Ibinọkpaabyi. Ọnọng kpenamkpen kw'ọsi ọtzọhm m'ewu nda, bẹ akhaambi afhẹ-ẹ.  
\v 16 Mẹ wọ, anọng p'Israẹl ahok Ẹwọhngkwokhawu nda, bẹ ahok ewu nda k'igbọ s'íkwu k'ororo mach'echekhi ch'ewobha maa, ogbe ode.  
\v 17 Ewu nda éde ẹkhọhkha k'ottem kwa kaam ọmaana anọng p'Israẹl maa ipemanitzor, okhuri bi, Ọvaar Ibinọkpaabyi otzim iwu izadani osi ẹrọng ọmaana irerek, yina, k'ewu ch'ettong izenamfa ọn-ọkwọbha ọtzọhm, okwokha ọwọhng.” 
\p  
\v 18 Mada Ọvaar Ibinọkpaabyi okk'Mosẹs idik nna ọgbaakha okyera k'egbegbeho cha Sinai, ọn-ọtzọkha atza-gbẹgbẹri afa p'asana pa kẹ Ibinọkpaabyi otzima ẹnọhna chẹ ọkkẹr, ọnang Mosẹs. 
\c 32  
\s1 Ọbhaamnwa kwa bẹ atzim gol asi 
\p  
\v 1 Mada anọng mba p'Israẹl are bi, Mosẹs okk'ogbe on-okhibhi kpọng k'egbegbeho bi, okhuna, bẹ afona atza akhọri Aarọn, aben bi, “Kwu si akha anang man p'atzima man eden. Onode ayi Mosẹs kw'otzim man obina k'Ijip, modik korong kw'ọkk'ọtta okhebh-ẹ.” 
\p  
\v 2 Mẹ wọ, Aarọn obhina bẹ bi, “Bọng wọra ekpo py'itzọhng pya gol pya panọng pabọng, ọmaana pya va pabọng p'ijinọng ttara p'ipanọng akhe, atzọkha achen-m.”  
\v 3 Mẹ wọ, anọng mba biphyir awọra ekpo pyabẹ p'itzọhng pya gol achena Aarọn.  
\v 4 Ọtzọkha ekpo pya bẹ akk'ẹ achena, otzima oduk ọgbatza kw'okheri ọbhaamnwa, odokh-ẹ ttara ọtzọhm-ttọhk. Mẹ wọ, bẹ aben bi, “O Israẹl, ma wọ ode akha pa bọng, p'atzim bọng abina k'Ijip e.” 
\p  
\v 5 Mada Aarọn ore odik nwa, osi ijafọhnibe m'itzitzikha s'ọbhaam-nwa nwa, ogwon ẹmọng oben bi, “Ophyini, mósi ọdadaami ọnang Ọvaar Ibinọkpaabyi e.”  
\v 6 Mẹ wọ, ewu ehobh mẹ, anọng mba aphyọbha k'ekpekpebha, asi nnanga nkwọmisẹ, bẹ abira atzima nnanga s'odidiri akwu. Mada bẹ akk'mando asa, bẹ an-awobha ẹwọr achi abira agwo, yina bẹ an-abin attubha k'ọdadaami kw'ebyibya. 
\p  
\v 7 Mẹ wọ, Ọvaar Ibinọkpaabyi oben Mosẹs bi, “Kọ hakha, okhuri bi, anọng pọ p'atzim abina k'Ijip akk'an-akhibhi.  
\v 8 Bẹ akk'idudukha atzima akpa nnam abọra asana pa nnangi bẹ, bẹ akk'ọgbatza abira adukha kw'ode mach'ọbhaam-nwa. Bẹ akk'nho ahakha anang-ẹ, bẹ akk'ẹjafọhni abira asa anang-ẹ, bẹ aben bi, ‘Israẹl o, ma wọ ode akha pabọng e, p'atzim bọng abina k'Ijip e.’ 
\p  
\v 9 “Ọvaar Ibinọkpaabyi oben Mosẹs bi, “Kaam nkk'anọng mba nna, bẹ ade anọng p'agaangi eho e.”  
\v 10 Na tte-m ọbọhk ngọhkha bẹ ittemdọkhiji saam, ifha mbiri ndimi bẹ. Mẹ wọ, kaam nna ńsọ-ọ ẹkhọma ch'ideden.” 
\p  
\v 11 Yina, Mosẹs ophyem Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kwẹ ọphyaam, oben bi, “O Ọvaar Ibinọkpaabyi, ode yan kw'an-adọkhi ettem ttara anọng pọ p'atzim abina k'Ijip, ttara ẹfa chọ ch'ideden ọmaana ekhema o?  
\v 12 Okhuri yan kw'anọng p'Ijip an-aben bi, ‘Wa akhaam ochibhi-tzama yina atzima anọng mba abina k'Ijip bi, akwu afhu bẹ ma mgbegbeho nna, abira adimi che chabẹ m'ọyagbin o?’ Mkpa nnam abọra ittemdọkhiji sọ, hakha ettem, anọng pọ itzama kasi.  
\v 13 Kọ jima atzọhmnọng pọ Abraham, ọmaana Isaak, ttara Jekọb, p'achekhi anang for sọ bi, ‘Kaam ńsi va pa va pabọng ahaabh macha ndodori k'ọrọngkpakpa. Kaam mbiri ńnang va pa va pabọng irerek nna biphyir sa kaam nchekhi nnang bẹ. Sẹ ibiri íde ekkema chabẹ maa ogbe ode.’ ”  
\v 14 Mẹ wọ, Ọvaar Ibinọkpaabyi ọhakha ettem chẹ, itzama s'iwa ọkk'ọkhama bi osi anọng pẹ, bẹ dọk kosi. 
\p  
\v 15 Mosẹs ọbhakhi nnam ọhakha k'egbegbeho, otzima atza-gbẹgbẹri afa ka mbọhk sẹ, pa bẹ akkẹri asana ka nnam mfa, k'itzitzikha ttara ka nnam.  
\v 16 Iwa atza-gbẹgbẹri mba ade ọtzọhmbọhk f'Ibinọkpaabyi, ọkkẹra kw'owobh m'atza-gbẹgbẹri mba ode ọkkẹra kw'Ibinọkpaabyi. 
\p  
\v 17 Mada Joshua ọbhaang amọng p'anọng am-awuri, oben Mosẹs bi, “Agbong-mọng awobh k'ibhingabe.” 
\p  
\v 18 Mosẹs obhina bi, 
\q1 “Ẹmọng ch'ekhema arang mẹ, 
\q2 ẹbomọng arang mẹ, 
\q2 ẹmọng ch'ọkkọhna dọ cha kaam mmaang.” 
\p  
\v 19 Mada Mosẹs oreng ọbaanga k'ibhingabe, on-ore ọbhaamnwa, ttara otzubha, ọdọkhi ettem ọbhari atza-gbẹgbẹri p'otzim ka mbọhk, ọvọhkhi bẹ k'abir-ibiri m'orin kw'egbegbeho nda.  
\v 20 On-obiro ọtzọkha ọbhaamnwa nwa kwa bẹ akk'asa ọbhabh k'ekpon, yina ọn-ọtzọkh-ẹ okhok k'abubuma, ọtzọkha abubuma mba ọnyaani k'asi, oben anọng p'Israẹl agwo bẹ. 
\p  
\v 21 Mosẹs oben Aarọn bi, “Anọng mba asọ-ọ yan kw'atzim bẹ asi ẹkhọngkwuri ch'ẹbari manda o?” 
\p  
\v 22 Aarọn obhina bi, “Itta kwaam, tte oning-ọ ọdọkhi, kọ arong odem kw'itzama ikpaang anọng mba osisi khẹ.  
\v 23 Bẹ-bẹ bọ aben-m bi, ‘Si akha anang man p'atzima man eden. Onode ayi Mosẹs kw'otzim man obina k'Ijip, modik korong kw'ọkk'ọtta okhebh-ẹ.’  
\v 24 Mẹ wọ, mben bẹ bi, ‘Ọnọng kpenamkpen kw'ọkhaam gol, tte ọwọra.’ Mẹ wọ, bẹ awọra anang-m, ndini mmari k'ekpon, ofona mẹ, ọbhaamnwa nwa oyin!” 
\p  
\v 25 Mosẹs okwu ore bi, anọng mba an-asi itzimabhaang s'ideden, ttara bi, Aarọn okk'bẹ ọbọhk ọtta bẹ attena akwọbha eden, maa bẹ an-ade ọhamma-dik anang attattaanga-nọng pabẹ.  
\v 26 Mẹ wọ, Mosẹs on-obe k'ẹbaakhamma ch'ibhingabe, oben bi, “Ọnọng kpenamkpen kw'obe ttara Ọvaar Ibinọkpaabyi, tte orenga otzor-m.” Mẹ wọ, abaLẹvi biphyir amun atzor-ẹ khẹ. 
\p  
\v 27 Mẹ wọ, oben bẹ bi, “Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kw'Israẹl obeni bi, ‘Tte ọnọng-ọnọng ọkpa ọkkangkkaang kwẹ k'erin. Bọng nnenga achina itzitzikha akpa nnam, akhọri abobongi p'ibhingabe nna. Tte ọnọng-ọnọng ofhu ọgbaanọkka kwẹ, ọmaana oyokhẹkhaan, ttara oyokh-ẹbaanga kwẹ.’ ”  
\v 28 AbaLẹvi asi macha Mosẹs obeni bẹ, m'ewu nduma, anọng nnọhna nzenamfa obhiri arọbh jobh, ape. 
\p  
\v 29 Mẹ wọ, Mosẹs oben bi, “Ọvaar Ibinọkpaabyi okk'bọng otzekha mayina, da bọng attaang anang osisi kwa va pabọng p'ijinọng, ọmaana votte pabọng, mẹ wọ, kẹ okk'bọng ọda m'ewu cha mayina.” 
\p  
\v 30 Ewu ehobh mẹ, Mosẹs oben anọng mba bi, “Bọng akk'ẹkhọngkwuri ch'ideden asa. Yina, kaam nna ńda k'Ọvaar Ibinọkpaabyi, asi mẹ kaam mfha nsi ephyokhi ch'egbobhi ẹkhọngkwuri chabọng osi.” 
\p  
\v 31 Mẹ wọ, Mosẹs ọkpa nnam k'Ọvaar Ibinọkpaabyi, oben bi, “Anọng mba akk'ẹkhọngkwuri ch'ideden asa! Bẹ akk'gol atzima asi akha anang for sabẹ.  
\v 32 Yina, tzotzokhaan bina anang ngọngkwuri sabẹ, ani bẹ afha bina anang, rọbha che chaam ka nnwẹr kw'akk'akkẹra.” 
\p  
\v 33 Ọvaar Ibinọkpaabyi obhina Mosẹs bi, “Ọnọng kpenamkpen kw'okk'ẹkhọngkwuri ọsa k'itzitzikha saam, che chẹ dọ cha kaam ńnọbha ka nnwẹr kwaam.  
\v 34 Kọ rọhng madẹdẹn, atzima anọng mba eden achina k'ibe sa ira mgbaakh-ọ, itzọhmi saam rọ íchi bọng eden. Yina, ogbe opyipyiri kwa kaam ńnang ettuma, kaam ńnang bẹ ettuma ọnang k'ẹkhọngkwuri chabẹ.” 
\p  
\v 35 Mẹ wọ, Ọvaar Ibinọkpaabyi ọtzọhm itzama ochena anọng mba, okhuri ọttọhk fa bẹ asi ttara ọgbatza nwa kw'okheri ọbhaamnwa, kw'Aarọn ọkk'odukha. 
\c 33  
\p  
\v 1 Mẹ wọ, Ọvaar Ibinọkpaabyi oben Mosẹs bi, “Kọ ọmaana anọng mba p'atzim abina k'Ijip, bọng bina aji irerek nna. Bọng china k'irerek sa kaam nkk'nchekhi k'ọnwọhngi nnang Abraham, ọmaana Isaak, ttara Jekọb, mben bi, ‘Kaam ńnang va pa va pabọng irerek nna.’  
\v 2 Kaam ńdọhm itzọhmi saam ichi bọng eden, bọng akhubh abaKenaan, ọmaana abAmọr, ọmaana abaHet, ọmaana abaPẹriz, ọmaana abaHiv, ttara abaJẹbus.  
\v 3 Bọng nọhng k'irerek nna s'abasi ọmaana akhọkhọnana ahaabh-ọhaabh. Yina, kaam bọng abẹ kíndọn, okhuri bi, bọng ade anọng p'agaangi eho, kaam mfha ndimi bọng odimi k'eden.” 
\p  
\v 4 Mada anọng mba abhaang ẹkkaabha-tzama nda, bẹ an-awobha ka nkkwosisi, ọnọng kw'obiro ọfọra ẹfhanginẹ-kpo manda byani kode. 
\p  
\v 5 Da Ọvaar Ibinọkpaabyi okk'Mosẹs obena bi, “Gbaak anọng p'Israẹl bi, ‘Bọng ade anọng p'agaangi eho. Idikha ira kaam ndọni bọng abẹ mfona k'igbegbaa m'orenga nwa, ira kaam mfha ndimi bọng odimi. Mẹ wọ, bọng wọra ẹfhanginẹ-kpo pyabọng, ifha ńnonga ọttọhk fa kaam ńsi ttara bọng.’ ”  
\v 6 Mẹ wọ e, anọng p'Israẹl awọra ẹfhanginẹ-kpo pyabẹ k'egbegbeho cha Horẹb. 
\s1 Ikhira s'etzobha 
\p  
\v 7 Mẹ wọ, wa Mosẹs ọm-ọtza ottima ikhira k'iyaan-iyaan, s'ororo kw'ibhingabe, oyeri sẹ “Ikhira s'etzobha.” Ọnọng kpenamkpen kw'orori Ọvaar Ibinọkpaabyi, om-ochina k'ikhira s'etzobha s'iwobh k'iyaan-iyaan s'ibhingabe.  
\v 8 Ogbe kpenamkpen kwa Mosẹs ochin k'ikhira nnuma, anọng biphyir abina abe ka nhọhmma s'okhira fabẹ, am-akkeri Mosẹs maa odim k'ikhira nna ẹtzaanga.  
\v 9 Mada Mosẹs odimi k'ikhira ẹtzaanga, eboni ch'ebe iduduma ẹm-ẹhakha, ekwu ewobha m'ehọhmma, da Ọvaar Ibinọkpaabyi ọm-ọgbaak atzim ttara Mosẹs.  
\v 10 K'ogbe kpenamkpen kw'anọng mba are da eboni ebe k'ẹhọhmma ch'ikhira nna, bẹ biphyir abina abe k'ikpokpobha, ọnọng-ọnọng k'ẹhọhmma ch'ikhira sẹ.  
\v 11 Wa Ọvaar Ibinọkpaabyi ọm-ọgbaak atzim ọnang Mosẹs itzitzikha ttara itzitzikha, mach'ọnọng ọgbaakhi oyok-ẹkhaan kwẹ atzim. Mẹ wọ, Mosẹs ọkpa nnam ochina k'ibhingabe. Yina, Joshua, kw'ode odikkobh kw'ọm-ọtzọn-ẹ abẹ, obiro ode nnwa kwa Nun, k'ikhira nna kobin. 
\s1 Mosẹs ore abarada p'Ọvaar Ibinọkpaabyi 
\p  
\v 12 Mosẹs oben Ọvaar Ibinọkpaabyi bi, “Kọ akk'aam am-abena bi, ndima anọng mba eden, yina, kaam ọnọng atzima am-atzibha kw'ọtzọn-m abẹ. Kọ akk'abena bi, ‘Kaam nnọng che chẹ khẹ, kọ ọkk'ọphyaam faam atzọkha.’  
\v 13 Idikha kaam nkk'ọphyaam ndọkha k'itzitzikha sọ, tzibh-m nden sọ, ifha kaam nnong-ọ, mbiri china ororo ndọkha ọphyaam fọ. Jima bi ẹkhọma nda ede anọng pọ o.” 
\p  
\v 14 Ọvaar Ibinọkpaabyi obhina bi, “Kaam ọkhaam ńdọn-ọ bẹ mofona, mbiri nnang-ọ ẹwọhngkwokha ọnang.” 
\p  
\v 15 Mẹ wọ, Mosẹs oben-ẹ bi, “Idikha kọ ọkhaam ani man abẹ atzọn mofona, man ọbọhk katte mobina ma ibe nna.  
\v 16 Yan wọ kw'ọnọng otzima oronga bi, ettem ẹdaam-ọ kẹ ttar-m, ọmaana anọng pọ, idikha ani man abẹ atzọni? Mbọng vọ ode odengọmi kwa kaam ttara anọng pọ, k'itzitzikha s'anọng adọdọk p'arukhi m'ọyagbin o?” 
\p  
\v 17 Ọvaar Ibinọkpaabyi obhina Mosẹs bi, “Kaam nsi osi macha akk'aphyema, okhuri bi ettem ẹkk'aam ẹdaama ttara kọ, kaam mbiri nnong-ọ ka che.” 
\p  
\v 18 Mẹ wọ e, Mosẹs oben bi, “Kọ na khọkh-m abarada pọ.” 
\p  
\v 19 Ọvaar Ibinọkpaabyi oben bi, “Kaam ńsi ajibhada paam biphyir achi bọng eden, m'itzitzikha sabọng, kaam ḿbiri ńsi ẹjaakhi cha che chaam, ch'ede Ọvaar Ibinọkpaabyi. Kaam ńgaama nkwu-osisi ttara ọnọng kw'ọdaakh-m, mbiri ńsi ejibha nnang ọnọng kwa kaam ńsi ejibha.  
\v 20 Yina, kọ itzitzikha saam kafha are, okhuri bi, ọnọng kw'ofha ore kaam oruk akpen kode.” 
\p  
\v 21 Mẹ wọ, Ọvaar Ibinọkpaabyi oben bi, “Ọkhaam ibe rani s'ibaang-m, s'afha abe k'ẹtzakpa.  
\v 22 Mada abarada paam akwọbha, kaam ndọkh-ọ nge k'ọtzakpa-mma, mbubh-ọ ttara ọbọhk kwaam maa nkwọbha.  
\v 23 Mẹ wọ, kaam ńnọbha ọbọhk kwaam, kọ án-are nnam saam, yina, itzitzikha saam kafha are.” 
\c 34  
\s1 Atzagbẹgbẹri abhapẹ p'asana 
\p  
\v 1 Ọvaar Ibinọkpaabyi oben Mosẹs bi, “Kpaara atza afa macha mbonggo p'echeden, kaam mbiri nkkẹr atzim mba p'iwa awobh k'atza-gbẹgbẹri mba p'echeden p'avọhkhi.  
\v 2 Kọ do for k'ekpebha avura akhebh-m k'egbegbeho cha Sinai. Kebh-m k'egbegbeho ebira.  
\v 3 Tte ọnọng manda wani oning-ọ abẹ ọtzọni okwu, ọnọng oningi k'ibe kpenamkpen m'egbegbeho nda ode, kaambi etzirakpo pyọ, tte eningi araraari m'egbegbeho nda echi.” 
\p  
\v 4 Mẹ wọ, Mosẹs ọkpaara atza-gbẹgbẹri afa macha p'echeden, otzima bẹ k'ekpebha ovura egbegbeho cha Sinai, mach'Ọvaar Ibinọkpaabyi ọkk'ẹ ọtzọhna, obiro otzima atza-gbẹgbẹri mba afa ka mbọhk sẹ.  
\v 5 Mẹ wọ, Ọvaar Ibinọkpaabyi ọhakha k'eboni, obe Mosẹs m'ẹbhabhaanga, ọsi ẹjaakhi cha che chẹ, ch'ede Ọvaar Ibinọkpaabyi.  
\v 6 Ọkwọbha Mosẹs k'itzitzikha osi ẹjaakhi bi, “Ọvaar Ibinọkpaabyi, Ọvaar Ibinọkpaabyi nwa, ode Ibinọkpaabyi kw'inọngkwo, ọmaana ọphyaam, kw'ọm-ọtzọkha ogbe yina ọn-ọdọkh-ẹ, kw'ofu ttara idadaakha, ọmaana ekhera,  
\v 7 kw'ọkhọhk idadaakha sẹ ọnang anọng nnọhna nnabhik, obiro obina ọnang itzama, ọmaana oho gaangi, ttara ẹkhọngkwuri. Yina, kẹ ọnọng kw'aponga apyibhi ọbọhk kotte, kẹ obiro ọnang va ọmaana va pa va pabẹ ettuma, ka ngọngkwuri s'ab'otte, maa apyiri mgbọmma nttaan ọmaana nna.” 
\p  
\v 8 M'ẹbaa mẹ, Mosẹs ọrakha eho k'ikpokpobha.  
\v 9 Oben bi, “O Ọvaar Ibinọkpaabyi, idikha kaam nkk'ọphyaam ndọkha k'itzitzikha sọ, tte kọ Ọvaar Ibinọkpaabyi arenga ttara man. Kaambi ode bi anọng mba ade atzimabhaang-nọng, bina anang man k'itzama saman, abira atzọkha man mach'anọng pọ.” 
\p  
\v 10 Mẹ wọ, Ọvaar Ibinọkpaabyi oben bi, “Kaam na ndọkha echekhi ttara kọ. Anọng pọ biphyir atzima chen pabẹ are íkkokkonidik sa kaam ńsi, sa nindimi minsa k'ẹkhọma manda dani k'ọyagbin biphyir. Anọng p'arukhi ọmaana bọng ábira are ijoradik sa kaam Ọvaar Ibinọkpaabyi ńsi nnang bọng.  
\v 11 Hakha eho anang idik sa mben-ọ bi, asi mayina. Kaam ńgwubh abAmọr, ọmaana abaKenaan, ọmaana abaHet, ọmaana abaPẹriz, ọmaana abaHiv, ttara abaJẹbus.  
\v 12 Bọkh-ọ for o, echekhi kpenamkpen kàkhaama ọmaana anọng mba p'arukhi m'irerek nna sa bọng am-achina o, oni mando ode, bẹ áde agbagbara anang bọng.  
\v 13 Bọng vọhkhi ọjafọhnibe fabẹ, ọmaana atza pabẹ p'akha, bọng abira avọhkhi mkpọmmachi s'Ashẹra pabẹ.  
\v 14 Bọng ọttọhk ọdọdọk kàkpobha, kkeri, Ọvaar Ibinọkpaabyi, kwa che chẹ ede ottemmamma, ode Ibinọkpaabyi kw'ottemmamma. 
\p  
\v 15 “Bọng bọkha bọng for o, bọng echekhi kpenamkpen kàkhaama ọmaana anọng mba p'arukhi m'irerek nna, okhuri bi, mada be asi ẹzaza ọmaana akha pabẹ bi, bẹ afọhni ẹja anang bẹ, bẹ ábher bọng obher bi, bọng átza achi ẹchakpo pya njafọhni sabẹ.  
\v 16 Mada bọng atzọkha aminava pabẹ anang adikkobh pabọng k'ọbada, aminava mba ási ẹzaza anang akha pabẹ, bẹ atzima adikkobh mba pabọng eden otzima, bẹ asi idik nnuma rani. 
\p  
\v 17 “Bọng agbatza kàduk. 
\p  
\v 18 “Bọng si ọdadaami kwa brẹd kwa bẹ ani yist akhe. Bọng chi brẹd kwa bẹ ani yist akhe k'iwu izenamfa, macha nkk'bọng mbena. Bọng si mando k'ogbe kw'ọbaan bi bọng asi, k'ophe kw'Abib, okhuri bi, mophe nwa wọ kw'iwa bọng abin k'Ijip. 
\p  
\v 19 “Va kpenamkpen p'ichedenmọr ade paam, ttara acheden-va adimpẹ biphyir p'etzirakpo, ode arukhimaan o, obiro ode abhaam.  
\v 20 Kọ tzima orukhimaan-nwa abhek ocheden nnwa kw'ẹnyanyaang, yina, idikha ani chẹ abhekhi, phyakhi chẹ ekhokhora. Bhek acheden-va pabọng biphyir. 
\p “Ọnọng manda wani oningi mbọhk-mbọhk oreng oyin-m k'itzitzikha. 
\p  
\v 21 “Bọng ási itzọhm k'iwu izadani, yina, bọng akwokha ọwọhng k'ewu ch'ettong izenamfa. Kaambi k'ogbe kw'ekpo ọyayaabha ttara ọphagbe wọ, bọng akhaambi akwokha ọwọhng. 
\p  
\v 22 “Bọng si Ọdadaami kw'Ipha ttara acheden-chiduk py'ekpo pya bọng ayaabh k'iwoni sabọng, ttara acheden-chiduk p'ipha sa wit, ọmaana Ọdadaami kw'Ipha s'ikpong nnam ka cho.  
\v 23 Ajinọng pabọng biphyir, akhaambi ayin k'itzitzikha s'Ọvaar Ibinọkpaabyi kw'Ẹfa, kw'ode Ibinọkpaabyi kw'Israẹl, igbe ittaan ka cho.  
\v 24 Kaam ńgwubh idibhon ka bọng k'itzitzikha, mbiri mmẹma nnem sabọng. Ọnọng manda wani kw'ọ́bọkha bọng irerek sabọng k'ẹfa ọna kode, m'igbe nna ittaan sa cho sa bọng áyin k'itzitzikha s'Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kwabọng. 
\p  
\v 25 “Bọng kaam izi s'ifon k'ẹjafọhni ch'efon k'ọttọhk kpenamkpen f'ọkhaam yist kanang, bọng katte bi etzen manda dani ch'ẹjafọhni ch'Ọdadaami kwa Pasova, ewobha epyiri k'ekpebhawu ẹdọdọk.  
\v 26 Bọng dima acheden-chiduk akkakka k'irerek sabọng, akwu k'ọhọhm kw'Ọvaar Ibinọkpaabyi, kw'ode Ibinọkpaabyi kwabọng. Bọng abasi p'evu kàtzima awọhn ovu-nwa.” 
\p  
\v 27 Mẹ wọ, Ọvaar Ibinọkpaabyi oben Mosẹs bi, “Kkẹr atzim mba, okhuri bi, kaam nkk'echekhi ndọkha ttara kọ ọmaana anọng p'Israẹl ndor m'atzim mba.”  
\v 28 Wa Mosẹs owobh ttara Ọvaar Ibinọkpaabyi ka nyawu arọbh afa, ọmaana nnungiwu arọbh afa ọchattọhk kochi, asi kobiro ogwo. Ọkkẹr atzim p'ade Echekhi ch'Asana Jobh m'atza-gbẹgbẹri mba. 
\s1 Ọnnanna kw'itzitzikha sa Mosẹs 
\p  
\v 29 Mada Mosẹs ọhak k'egbegbeho cha Sinai, ttara atza-gbẹgbẹri mba afa p'Echekhi ch'Asana ka mbọhk sẹ, korong bi itzitzikha sẹ in-innọnna, okhuri da kẹ okk'idik ọgbaakha ttara Ọvaar Ibinọkpaabyi.  
\v 30 K'ogbe kw'Aarọn ọmaana anọng p'Israẹl an-are Mosẹs, itzitzikha sẹ in-innọnna, mẹ wọ, ojora bẹ bi bẹ arenga abaang-ẹ.  
\v 31 Yina, Mosẹs oyeri bẹ, mẹ wọ, Aarọn ọmaana adeho p'obhon akpa nnam atzor-ẹ, ọgbaak bẹ atzim.  
\v 32 Ayongi mẹ, anọng p'Israẹl biphyir arenga abaang-ẹ, Mosẹs ọgbaak bẹ asana biphyir p'Ọvaar Ibinọkpaabyi ọkk'ẹ ọnanga k'egbegbeho cha Sinai. 
\p  
\v 33 Mada Mosẹs okyer atzim ọgbagbaak ttara bẹ, ọtzọkha ẹbarakpa obubha itzitzikha sẹ.  
\v 34 Yina, ogbe kpenamkpen kwa Mosẹs oyini Ọvaar Ibinọkpaabyi k'itzitzikha bi, ọgbaak atzim ttar-ẹ, ogwonga ẹbarakpa nda k'itzitzikha. Mada oyini k'iyaan, okwu ọgbaak anọng p'Israẹl idik s'Ọvaar Ibinọkpaabyi ọkk'ẹ ọgbaakha,  
\v 35 anọng p'Israẹl an-are bi, itzitzikha sẹ innọnna. Mẹ wọ, Mosẹs obiro ọtzọkha ẹbarakpa nda obubha k'itzitzikha sẹ, yina on-odimi kẹ bi, ọgbaak atzim ttara Ọvaar Ibinọkpaabyi. 
\c 35  
\s1 Aphaangi p'Ẹwọhngkwokawu 
\p  
\v 1 Wa Mosẹs ogwon ọkwa k'obhon kw'Israẹl biphyir, oben bẹ bi, “Ma wọ ode idik s'Ọvaar Ibinọkpaabyi, okk'bọng obena bi bọng asi:  
\v 2 Bọng ási ọtzọhm k'iwu izadani, yina, ewu ch'ettong izenamfa éde ewu ch'awurada, ch'éde Ẹwọhngkwokhawu ẹnang Ọvaar Ibinọkpaabyi. Ọnọng kpenamkpen kw'osi ọtzọhm m'ewu nda, bẹ akhaambi afhẹ-ẹ.  
\v 3 Bọng ekpon k'orukhabe fabọng kpenamkpen m'Ẹwọhngkwokhawu nda kàbaanga.” 
\s1 Nnanga s'anọng anangi s'irukhabe s'Ibinọkpaabyi osisi 
\p  
\v 4 Mosẹs ọgbaak anọng p'obhon kw'Israẹl biphyir bi, “Ma wọ ode odik kw'Ọvaar Ibinọkpaabyi okk'obena bi bọng asi:  
\v 5 Bọng nọbha ẹnanga k'ekpo pya bọng akhaam, anang Ọvaar Ibinọkpaabyi ẹnanga. Ọnọng kpenamkpen kw'ọdaakh-ẹ, tte otzima ẹnanga cha gol, ọmaana asilva, ttara cha brons ochena Ọvaar Ibinọkpaabyi,  
\v 6 ọmaana ndik sa nde blu, ọmaana sa ngor-ihiho, ọmaana sa ngor-izizi, ọmaana ndik nkkakka sa bẹ ayoyok, ọmaana avu-phyubha,  
\v 7 ọmaana ndenkpa s'erukhimaan-dim sa bẹ aphyok ademkora, ọmaana ndenkpa s'avu, ttara mgbaakha s'akasiya,  
\v 8 ọmaana ana p'oliv p'ekpon eyenichẹ, ọmaana ekpo py'ẹdaami eruk pya bẹ am-atzima asi ana pa bẹ abyengi ọnọng k'eho, ttara insẹns kw'ọdaami eruk;  
\v 9 ọmaana atza p'oniks, ttara atza adọdọk pa bọng agbana k'ẹphọd, ttara k'ẹbarakpa ch'ittemmọma. 
\p  
\v 10 “Tte amengkkakkaa biphyir p'awobh k'ottem kwabọng ayin ka, akwu asi ọttọhk kpenamkpen f'Ọvaar Ibinọkpaabyi okk'obena bi, mosi:  
\v 11 irukhabe nna ttara ikhira sẹ, ọmaana ittakhọnga sẹ, ọmaana agbak pẹ, ọmaana nchi s'amma, ọmaana nneremachi, ọmaana mkpọmmachi, ttara nnana;  
\v 12 Ẹkkọhbhi nda ch'Echekhi ttara nneremachi sẹ, ọmaana ẹkkọhbhikpa ch'ephyokhi ttara ekpekhe ch'ẹkpa chẹ ẹmmaana k'ẹtzaanga;  
\v 13 ọmaana okpokkoro ttara nneremachi sẹ, ttara ekpo biphyir py'ẹnan mẹ, ọmaana brẹd kw'awurada,  
\v 14 ọmaana etwikkaang-chi ch'ekpon oyeyeni ttara ekpo pyẹ, atwikkaang ttara ana p'ekpon eyenichẹ,  
\v 15 ijafọhnibe s'insẹns ttara nneremachi sẹ, ọmaana ana pa bẹ am-abyengi ọnọng k'eho, ọmaana insẹns p'adaami eruk, ttara ekpekhe ch'ẹhọhmma ch'ọmma kw'irukhabe;  
\v 16 ọmaana ijafọhnibe s'ẹnanga ẹkwọmichẹ, ttara otzekpa kwẹ kwa brons, ọmaana nneremachi sẹ ttara ekpo pyẹ biphyir, ọmaana ọkwakkama kwa brons ttara ẹnana chẹ,  
\v 17 ọmaana mkpekhe s'ẹttọhmmattem ttara mkpọmmachi ọmaana nnana sẹ, ọmaana ekpekhe ch'ọmma kw'ẹttọhmmattem,  
\v 18 ọmaana abhing p'irukhabe ọmaana p'ẹttọhmmattem, ttara ndik sabẹ,  
\v 19 ọmaana nnya nyokhasẹ s'ọtzọhm f'ọhọhm kw'awurada sa nde; nnya s'awurada s'Aarọn kw'ode ọfọhnẹja, ttara nnya sa va pẹ p'ijinọng am-afọra, k'ogbe kwa bẹ asi ọtzọhm mach'afọhnẹja.” 
\p  
\v 20 Mẹ wọ, anọng p'obhon kw'Israẹl biphyir abina aji Mosẹs.  
\v 21 Ọnọng kpenamkpen kw'ọdaakh-ẹ, obiro ogbikh-ẹ k'ettem, otzima ẹnanga ochena Ọvaar Ibinọkpaabyi, k'ọtzọhm f'irukhabe, ọmaana itzọhmbọhk sẹ biphyir, ttara nnya s'awurada.  
\v 22 Anọng biphyir ajinọng ọmaana panọng, p'ọdaakhi bẹ ọdaak, atzima ẹfanginẹkpo pya gol k'adem-k'adem akwu: bẹ atzim ekpo pya hung, ọmaana ekpo py'itzọhng, ọmaana mbaanga sa nnọhna, ọmaana ẹfanginẹkpo, akwu. Bẹ biphyir atzima agol pabẹ akwu, mach'ẹnanga ch'ẹbar-odik achena Ọvaar Ibinọkpaabyi.  
\v 23 Ọnọng kpenamkpen kw'okhaam ndik sa nde blu, ọmaana sa ngor-ihiho, ọmaana sa ngor-izizi, ode ndik sa bẹ ayokh-oyok o, obiro ode avu-phyubha o, ode ndenkpa s'erukhimaan-dim cha bẹ aphyok asi-khora, obiro ode ndenkpa s'avu o, bẹ atzima akwu.  
\v 24 Ayok p'asi ẹnanga ch'asilva, obiro ode brons o, bẹ atzima achena Ọvaar Ibinọkpaabyi. Ọnọng kpenamkpen kw'ọkhaam mgbaakha s'akasiya, sa bẹ afha atzima asi ọtzọhm kpenamkpen, obiro otzima okwu.  
\v 25 Omengkka-kwanọng kpenamkpen otzima mbọhk sẹ oyok ọttọhk, otzima ọttọhk f'okk'oyokha f'ode blu, ọmaana f'ode ihiho, ọmaana f'ode izizi, ttara ndik nkkakka sa bẹ ayoyok, okwu.  
\v 26 Panọng biphyir p'ọdaakhi bẹ ọdaak, abira atzima emengkka chabẹ ch'ekpo oyoyok, ayok avu-phyubha.  
\v 27 Adeho atzima atza p'oniks, ọmaana atza adem adọdọk pa bẹ agbana k'ẹphọd, ttara k'ẹbarakpa ch'ittemmọma.  
\v 28 Bẹ abira atzima ekpo py'em-esi ọttọhk ọdaam eruk, ọmaana ana p'oliv p'ekpon eyenichẹ, ọmaana ana pa bẹ am-abyengi ọnọng k'eho, ttara insẹns kw'ọdaami eruk, akwu.  
\v 29 Anọng p'Israẹl biphyir, ajinọng ọmaana panọng p'ọdaakhi bẹ ọdaak, atzima nnanga s'ifon bẹ ka nttem achena Ọvaar Ibinọkpaabyi, s'okk'orenga ka Mosẹs oben bẹ bi, bẹ asi. 
\s1 Bẹzalẹl ọmaana Oholiyab 
\p  
\v 30 Mẹ wọ, Mosẹs oben anọng p'Israẹl bi, “Bọng kker e, Ọvaar Ibinọkpaabyi okk'Bẹzalẹl nnwa kw'ijinọng kw'Uri, kw'ode nnwa kwa Hur, kw'ofon k'ẹfona cha Juda, otzekha e.  
\v 31 Kẹ Ibinọkpaabyi ọkk'ẹ Egwugwuma chẹ ọnanga, ọmaana emengkka, ọmaana otzitzin, ttara eronga, ch'emengkka kpenamkpen,  
\v 32 ifha osi omengkka-tzọhm fa gol, ọmaana fa silva, ttara fa brons,  
\v 33 ọmaana bi, ọkpaara atza otzobha, ọmaana nchi ọgwagwa, obira osi omengkka-tzọhm kpenamkpen f'omengkkakkaa.  
\v 34 Kẹ okk'Bẹzalẹl ọmaana Oholiyab kw'ode nnwa kw'ijinọng kw'Ahisamak, kw'ofon k'efona cha Dan, etzina ọnanga bi bẹ akpebhi anọng adọdọk mmengkka sabẹ.  
\v 35 Kẹ okk'bẹ emengkka ch'omengkka-tzọhm kpenamkpen ọnanga, mach'amengkkakkaa, ọmaana odokh-ọbara, ọmaana adokh-ọbara f'ode blu, ọmaana f'ode-ihiho, ọmaana f'ode-izizi ọmaana ndik nkkakka sa bẹ ayoyok, ttara ayokh-ekpo biphyir, ade abitta p'emengkka, ttara abitta p'ekpo ododokha. 
\c 36  
\p  
\v 1 “Mẹ wọ, iwa Ọvaar Ibinọkpaabyi okk'Bẹzalẹl ọmaana Oholiyab, ttara omengkkakkaa kpenamkpen, emengkka ọmaana otzitzin kw'eronga ch'ọtzọhm kpenamkpen f'ibe s'awurada osisi ọnanga. Anọng mba bọ asi ọtzọhm mva atzor mach'Ọvaar Ibinọkpaabyi okk'bẹ ọtzọhna.” 
\p  
\v 2 Mẹ wọ, Mosẹs oyeri Bẹzalẹl ọmaana Oholiyab, ttara amengkkakkaa biphyir p'Ọvaar Ibinọkpaabyi okk'etzina ọnanga, ọmaana ayok p'ọdaakh-ọdaak bi, bẹ akwu asi ọtzọhm mva.  
\v 3 Wa bẹ atzọkha nnanga biphyir s'anọng p'Israẹl akk'atzima akwu ka mbọhk sa Mosẹs, ifha bẹ atzima asi ọtzọhm f'ibe s'awurada. Wa k'ekpebhawu kpenamkpen, anọng mba achina ororo atzima nnanga s'ifon bẹ ka nttem, akwu.  
\v 4 Mẹ wọ, amengkkakkaa mba biphyir, p'am-asi ọtzọhm mva f'ọhọhm kw'awurada abina aji ọtzọhm fabẹ,  
\v 5 atza aben Mosẹs bi, “Anọng mba am-atzim ekpo py'ẹhaabhi kpọng, ẹyọhnga ọtzọhm f'Ọvaar Ibinọkpaabyi ọtzọhni man bi, mosi akwu e.” 
\p  
\v 6 Mẹ wọ, Mosẹs ọnang ẹfa, bẹ atzọhm ẹmọng k'ibhingabe \it bi waam\it* aben bi, “Tte ojinọng, obiro ode kwanọng oningi ẹnanga kpenamkpen ch'ọhọhm kw'awurada osisi, dọk otzim okwu.” Mẹ wọ, wa bẹ akwọbha anọng mba ẹnanga nda osisi,  
\v 7 okhuri bi, ekpo pya bẹ akk'atzama akhaama ẹkk'ẹhaabha ẹyọhnga ọtzọhm biphyir fa bẹ asi. 
\s1 Irukhabe s'Ibinọkpaabyi 
\p  
\v 8 Amengkkakkaa biphyir k'ottem kw'atzọhmnọng mba atzima mkpekhe jobh sa bẹ atzim ndik nkkakka sa bẹ ayoyok asi. Iwa ndik sa bẹ atzim nde blu, ọmaana sa ngor-ihiho, ọmaana sa ngor-izizi asi irukhabe nna, bẹ attara achẹrubim mẹ, p'omengkkakkaa osi.  
\v 9 Mkpekhe nna biphyir nde mbenga-mbọhk, adum ade ndọkhi arọbh afa obhiri mfa, ẹkpa ede ndọkhi nzadani.  
\v 10 Bẹ atzọkha mkpekhe nzen atzọhnga ibe rani, bẹ abira atzọkha mkpekhe nnonggo nzen atzọhnga ibe rani.  
\v 11 Mẹ wọ, bẹ aduk ager p'ade blu m'ẹbaramma ch'ekpekhe nda dani cha bẹ akk'atzọhnga, bẹ asi mando k'ekpekhe ndonggo cha bẹ akk'abira atzọhnga.  
\v 12 Bẹ aduk ager arọbh afa obhiri jobh agbana k'ekpekhe nda dani cha bẹ akk'atzọhnga, bẹ abira agbana ager arọbh afa obhiri jobh k'ekpekhe ndonggo cha bẹ akk'atzọhnga.  
\v 13 Mẹ wọ, bẹ atzima gol asi agbak arọbh afa obhiri jobh, bẹ atzima abọkha mkpekhe nna mfa sa bẹ akk'atzọhnga k'ibe rani, ifha irukhabe nna in-ide rani. 
\p  
\v 14 Bẹ atzima avu-phyubha asi mkpekhe jobh obhiri wani, atzima abubha ebir-ebir kw'ikhira s'irukhabe.  
\v 15 Mkpekhe nna jobh obhiri wani biphyir nde ebenga-mbọhk, adum ade ndọkhi arọbh afa obhiri nzen, ẹkpa ede ndọkhi nzadani.  
\v 16 Bẹ atzọkha mkpekhe nzen atzọhnga k'ibe rani, bẹ abira atzọkha nnonggo nzadani atzọhnga k'ibe rani.  
\v 17 Mẹ wọ, bẹ aduk ager arọbh afa obhiri jobh agbana k'ekpekhe nda dani cha bẹ akk'atzọhnga, bẹ abira agbana ager arọbh afa obhiri jobh k'ekpekhe ndonggo cha bẹ akk'atzọhnga.  
\v 18 Mẹ wọ, bẹ atzima brons asi agbak arọbh afa obhiri jobh, bẹ atzima abọkha ikhira nna in-ide rani.  
\v 19 Mẹ wọ, bẹ abira atzima erukhimaan-kpakpa cha bẹ aphyok asi-khora abubha ikhira nna, yina bẹ abira atzima ndenkpa s'avu abubha k'ebir-ebir. 
\p  
\v 20 Bẹ atzima echi ch'akasiya asi nneremachi sa mbe-obe iduduma k'irukhabe nna.  
\v 21 Adum p'ereremachi kpenamkpen ade ndọkhi chi, ẹkpa ede ẹtzọkhi ọmaana igbokha,  
\v 22 bẹ abira asi nho mfa sa nde mbenga-mbọhk, ibiri ikkeri ayok itzitzikha. M'eden nda dani dọ ch'iwa bẹ abira asi nneremachi biphyir s'irukhabe nna.  
\v 23 Bẹ asi nchi s'amma ẹrọbh p'akkeri k'ẹrakha-ẹrakha kw'irukhabe s'Ibinọkpaabyi,  
\v 24 wa bẹ abira atzima silva asi nnana arọbh afa, akhe k'irekh-irek kwabẹ, ereremachi kpenamkpen ẹkhaam nnana mfa, eho kpenamkpen k'ẹnana chẹ.  
\v 25 K'okhubha kw'ebir-ebira kw'irukhabe nna, bẹ asi nneremachi ẹrọbh,  
\v 26 nnana arin arọbh afa, nnana mfa k'irekh-irek kw'ereremachi kpenamkpen.  
\v 27 Ka nnam-annam kw'irukhabe, k'okhubha kw'ewuchen em-edimi, bẹ asi nchi nzadani,  
\v 28 ọmaana nneremachi mfa ka nyọhnga sa nnam-annam kw'irukhabe nna.  
\v 29 Ma nyọhnga nna, bẹ agbak nneremachi sa ngeri ayok ọgbakha, ttẹwọr k'irekh-irek maa apyiri k'ebir-ebir; bẹ akhe sẹ k'oriring wani.  
\v 30 Mẹ wọ, wa ode nneremachi nzenanttaan, ọmaana nnana sa silva chi obhiri wani, nnana mfa k'ereremachi dani. 
\p  
\v 31 Bẹ atzima echi ch'akasiya asi nneremachi, atzima nzen ka nchi nna s'amma k'okhubbha wani, kw'irukhabe nna,  
\v 32 nzen k'okhubha nwonggo, nzen ka mkpọmmachi s'amma k'okhubha kw'ewuchen em-edimi k'irukhabe nna.  
\v 33 Bẹ an-asi ereremachi ch'ottem ẹttẹwọr k'eho dani, maa ẹbọkha k'eho ndonggo k'ottem kwa mkpọmmachi.  
\v 34 Bẹ atzima gol abhọri mkpọmmachi nna, abira atzima gol asi ariring, p'abọk nneremachi nna. 
\p  
\v 35 Bẹ atzima ndik sa nde blu, ọmaana sa ngor-ihiho, ọmaana sa ngor-izizi, ttara ndik ọkkakka sa bẹ ayokh-oyok m'ekpekhe nda, attara ka chẹrubim p'omengkkakkaa osi.  
\v 36 Bẹ atzima echi ch'akasiya asi mkpọmmachi s'ekpekhe nda, abhọri ttara gol. Bẹ atzima gol asi agbak pa mkpọmmachi nna, abhọri ttara gol, abira atzima silva asi nnana sabẹ.  
\v 37 Bẹ atzima ndik sa nde blu, ọmaana sa ngor-ihiho, ọmaana sa ngor-izizi, ttara ndik nkkakka sa bẹ ayokh-oyok, kw'ode ọtzọhmbọhk f'odokh-ọbara, osi ekpekhe ch'ẹhọhmma ch'irukhabe nna.  
\v 38 Wa bẹ abira asi mkpọmmachi nzen ttara agbak pabẹ. Bẹ atzima gol abhọri aho pa mkpọmmachi nna, ọmaana abarakpa pabẹ, bẹ abira atzima brons asi nnana azen sabẹ. 
\c 37  
\s1 Ẹkkọhbhi ch'Echekhi 
\p  
\v 1 Wa Bẹzalẹl otzim agbaakhakpa p'akasiya osi Ẹkkọhbhi ch'Echekhi. Adum pẹ ade ndọkhi nttaan ọmaana akpaama ọhawani, ẹkpa chẹ ede ndọkhi mfa ọmaana akpaama attaan, ebe chẹ ede ndọkhi mfa ọmaana akpaama attaan.  
\v 2 Otzima gol ọkkakka ọbhọri k'ẹtzaanga ttara k'iyaan, obiro ọbanga gol ọbaak chẹ ọkhọri.  
\v 3 Otzima gol ọrabha ariring anna, tzọkha ọdaabh bẹ okhe ka ndọkhi nna s'ẹkkọhbhi nda. Ariring afa k'okhubha wani, afa k'okhubha nwonggo.  
\v 4 Otzima echi ch'akasiya osi nneremmachi, obiro ọbhọri sẹ ttara gol.  
\v 5 Okhe nneremmachi nna k'ariring p'awobh k'akhaan-akhaan p'ẹkkọhbhi nda, ifha bẹ am-abọkha mẹ atzini chẹ.  
\v 6 Otzima gol ọkkakka osi ẹkkọhbhikpa ch'ephyokhi, adum pẹ ade ndọkhi nttaan ọmaana akpaama ọhawani, ẹkpa chẹ ede ndọkhi mfa ọmaana akpaama attaan.  
\v 7 Mẹ wọ, otzima gol oduk achẹrubim ohok k'ikpiho s'ẹkkọhbhi nda.  
\v 8 Wa osi cherub wani obera k'eho dani, obiro osi ọdọdọk obera k'eho ndonggo. Wa osi achẹrubim mba k'ikpiho bẹ ade odem wani ttara ẹkkọhbhikpa ch'ephyokhi.  
\v 9 Wa achẹrubim mba akhaam mbabaang sa mmẹm k'ẹrọng ibubha ẹkkọhbhikpa ch'ephyokhi nda. Achẹrubim mba awobha akkeri ayok itzitzikha, arọn ẹkkọhbhikpa nda. 
\s1 Okpokkoro 
\p  
\v 10 Bẹ atzima mgbaakha s'akasiya asi okpokkoro nwa. Adum pẹ ade ndọkhi nttaan, ẹkpa chẹ ede ndọkhi ọmaana akpaama azadani, ebe chẹ ede ndọkhi mfa ọmaana akpaama attaan.  
\v 11 Mẹ wọ, bẹ atzima gol ọkkakka abhọri okpokkoro nwa, abira abanga gol abhọri ammakpabem pẹ akhọri.  
\v 12 K'ọkhaan-ọkhaan bẹ akhe ammakpabem p'abeng mach'ẹbọhkpattem, bẹ abanga gol atzima akhọr-ẹ.  
\v 13 Bẹ atzima gol arabha ariring anna p'okpokkoro nwa, atzọkha bẹ adabh amaana ma nnyọhnga nna, mẹ da mmo sẹ nna nwobh.  
\v 14 Ariring mba awobha abaanga ammakpabem ifha bẹ abọkha nneremmachi nna, sa bẹ atzima atzini okpokkoro nnwa.  
\v 15 Wa bẹ atzim mgbaakha s'akasiya asi nneremmachi, sa bẹ am-atzima atzini okpokkoro nwa, bẹ abira atzima gol abhọri sẹ. 
\p  
\v 16 Wa bẹ abira atzima gol ọkkakka asi ekpo py'okpokkoro nwa, agbang-gbang ọmaana agbaangari, ọmaana nnengakpa, ttara akọbh, pa bẹ am-atzima asi nnanga mbyengisẹ. 
\s1 Etwikkaang-chi 
\p  
\v 17 Bẹ atzima gol ọkkakka aduk ettwikkaang-chi nda, ọmaana ẹnana chẹ, ọmaana owom kwẹ, ọmaana akọbh p'adodo, ọmaana agbok, ttara adodo. Wa pyẹ biphyir ede odem nwuma wani.  
\v 18 Etwikkaang-chi nda ẹkhaam abọhnga azadani k'akhaan-akhaan pẹ afa, attaan awobh k'okhubha wani, attaan abira awobha k'okhubha nwonggo. 
\p  
\v 19 Akọbh p'ade mach'agbok ọmaana adodo p'almọnd awobh k'ẹbọhnga dani, attaan k'ẹbọhnga ch'ejem mẹ. Wa ode odem nwuma wani k'abọhnga mba azadani biphyir p'ettwikkaang-chi nda.  
\v 20 Etwikkaang-chi nda wa ẹkhaam akọbh anna p'ade mach'agbok ọmaana adodo p'almọnd.  
\v 21 Ogbok wani owobh k'irekh-irek kw'abọhnga afa p'afon k'etwikkaang-chi nda. Ogbok nwonggo owobha k'irekh-irek kw'abọhnga mbonggo afa, ogbok kw'ottong attaan owobha k'abọhnga p'attong attaan, p'asi abọhnga azadani biphyir-phyir.  
\v 22 Wa bẹ atzima gol aduk agbọk, ọmaana abọhnga, bẹ ade odem wani ttara ettwikkaang-chi nda cha bẹ adukhi ttara gol ọkkakka aduk. 
\p  
\v 23 Bẹ atzima gol ọkkakka asi attwikkaang azenamfa, ọmaana afhẹngbẹ p'attwikkaang-dik ọkpa-kpaara, ttara nnengakpa.  
\v 24 Bẹ atzima talẹn wani kwa gol ọkkakka asi ettwikkaang-chi nda, ọmaana ekpo kpenamkpen pyẹ biphyir. 
\s1 Ẹjafọhnibe s'insẹns 
\p  
\v 25 Wa bẹ atzima mgbaakha s'akasiya asi ijafọhnibe s'insẹns, ebe ttara ẹkpa chẹ ade mbenga-mbọhk; adum pẹ ade ẹtzọkhi dani ọmaana igbokha, ẹkpa chẹ ede ẹtzọkhi dani ọmaana igbokha, ebe chẹ ede ndọkhi nttaan. Bẹ atzima echi nda dani asi abhik pẹ.  
\v 26 Atzima gol ọkkakka abhọri ehoho ọmaana k'okhubha kpenamkpen, abira atzima gol abanga ammakpabem adokha akhọri sẹ.  
\v 27 Wa bẹ atzima gol asi ariring afa m'ammakpabem, afa k'okhubha wani, afa k'okhubha nwonggo, ifha bẹ abọkha nneremmachi sa bẹ am-atzima atzini sẹ.  
\v 28 Bẹ atzima echi ch'akasiya asi nneremmachi, atzima gol abhọri sẹ. 
\p  
\v 29 Bẹ abira asi ana p'awurada pa bẹ am-abyengi ọnọng k'eho, ọmaana insẹns ọkkakka kw'ọdaami eruk, kw'ode ọtzọhmbọhk f'osi-ana. 
\c 38  
\s1 Ijafọhnibe s'ẹnanga ẹkwọmichẹ 
\p  
\v 1 Wa bẹ atzima mgbaakha s'akasiya asi ijafọhnibe s'ẹnanga ẹkwọmichẹ. Adum pẹ ade ndọkhi nzenamfa ọmaana akpaama azadani, ẹkpa ede ndọkhi nzenamfa ọmaana akpaama azadani, ebe ede ndọkhi nna ọmaana akpaama azadani. Wa ijafọhnibe nna ikhaam akhubha anna.  
\v 2 Wa bẹ asi abhik ka nnyọhnga nna. Bẹ atzima mgbaakha nna rani asi abhik mba anna ọmaana ijafọhnibe nna. Bẹ atzima brons abhọri ijafọhnibe nna.  
\v 3 Bẹ abira atzima brons asi ekpo ijafọhnibe nna biphyir mach'ọrọhkha, ọmaana asọvẹl, ọmaana agbang-gbang, ọmaana adaakpa p'akhaam aha attaan, ttara nnengakpa.  
\v 4 Bẹ ayok otzekpa kw'ijafọhnibe nna, atzima brons ayok ibuni, ahok k'irekh-irek kw'otzekpa nwa, m'ibhaang-ifa s'ijafọhnibe nna.  
\v 5 Bẹ atzima brons aduk ariring anna, p'abọkha nneremmachi ka nnyọhnga nna nna, s'otzekpa nwa kwa brons.  
\v 6 Bẹ atzima mgbaakha s'akasiya asi nneremmachi, atzima brons abhọri sẹ biphyir.  
\v 7 Wa bẹ anọhma nneremmachi nna m'ariring mba, ifha sẹ nwobha k'akhaan-akhaan p'ijafọhnibe nna, ifha bẹ am-abọkha mẹ atzini. Bẹ asi ijafọhnibe nna itto eje k'ottem mach'ẹkkọhbhi. 
\s1 Ọkwakkama kwa mbọhk ọmaana ndọkhi ogbogbobhi 
\p  
\v 8 Bẹ atzima abazẹkhubh pa panọng p'asi ọtzọhm k'ẹhọhmma ch'irukhabe s'Ibinọkpaabyi, asi ọkwakkama kwa brons, ọmaana ẹnana cha brons ch'ọkwakkama nwa. 
\s1 Ẹttọmmattem 
\p  
\v 9 Wa bẹ abira asi ẹttọmmattem. Adum pẹ k'ẹrakha-ẹrakha ade ndọkhi arọbh azenamfa obhiri jobh, bẹ abira atzima ndik nkkakka sa bẹ ayokh-oyok, ayok mkpekhe sẹ,  
\v 10 ọmaana mkpọmmachi ẹrọbh, ọmaana arin pa brons ẹrọbh, ọmaana agbak pa silva, ttara mbarakpa ka mkpọmmachi.  
\v 11 K'ebir-ebira, adum ade ndọkhi arọbh azenamfa obhiri jobh, obiro ọkhaama mkpọmmachi ẹrọbh, ọmaana arin pa brons ẹrọbh, ọmaana agbak pa silva, ttara mbarakpa ka mkpọmmachi.  
\v 12 Ẹkpa ch'okhubha kw'ewuchen em-edimi, ede ndọkhi arọbh attaan obhiri chi, ẹkhaama mkpekhe ọmaana mkpọmmachi jobh, ọmaana arin pa brons jobh, ọmaana agbak pa silva, ttara mbarakpa ka mkpọmmachi.  
\v 13 K'okhubha kw'ewuchen em-eyin, ẹkpa chẹ ede ndọkhi arọbh attaan obhiri chi.  
\v 14 Wa mkpekhe sa nde ndọkhi ẹrọbh obhiri mfa ọmaana igbokha k'adum, nwobh k'okhubha wani kw'ẹhọhmma, ọmaana mkpọmmachi nttaan, ttara arin attaan,  
\v 15 mkpekhe sa nde ndọkhi ẹrọbh obhiri mfa ọmaana igbokha k'adum, nwobha k'okhubha nwonggo kw'ẹhọhmma ch'ẹttọmmattem, ọmaana mkpọmmachi nttaan, ttara arin attaan.  
\v 16 Wa bẹ atzim ndik nkkakka sa bẹ ayokh-oyok asi mkpekhe nna biphyir akhọri ẹttọmmattem.  
\v 17 Bẹ atzima brons asi arin pa mkpọmmachi nna. Bẹ abira atzima silva asi agbak, ọmaana mbarakpa sa mkpọmmachi. Bẹ atzima silva abhọri aho pabẹ, mẹ wọ, mkpọmmachi nna biphyir s'ẹttọhmmattem ngaama mbarakpa sa silva.  
\v 18 Bẹ atzima ndik sa nde blu, ọmaana sa ngor-ihiho, ọmaana sa ngor-izizi, ttara ndik nkkakka sa bẹ ayokh-oyok, asi ekpekhe ch'ẹhọhmma ch'ẹttọmmattem, f'ode ọtzọhmbọhk f'odokh-ọbara. Wa adum p'ekpekhe nda ade ndọkhi ẹrọbh obhiri jobh, ebe chẹ ede ndọkhi nzenamfa ọmaana igbokha, macha mkpekhe s'ẹttọhmmattem,  
\v 19 ọmaana mkpọmmachi nna, ttara arin anna pa brons. Bẹ atzima silva asi agbak ọmaana mbarakpa pabẹ, bẹ abira abhọri aho pabẹ ttara silva.  
\v 20 Wa bẹ atzima brons asi abhing p'ikhira nna s'irukhabe, ọmaana ẹttọmmattem chẹ biphyir. 
\s1 Ẹtzọhmkpo 
\p  
\v 21 Ma wọ ode obhik kw'ekpo pya bẹ atzim asi irukhabe, kw'ode irukhabe s'Ẹkkọhbhi ch'Asana p'abaLẹvi p'iwa awobh k'irekh-irek kw'ẹfa ch'Itamar, akkẹri atzor k'odem kwa Mosẹs obeni. Itamar wa ode nnwa kw'ijinọng kw'Aarọn, kw'ode ọfọhnẹja.  
\v 22 Bẹzalẹl kw'ode nnwa kw'ijinọng kw'Uri, Uri kw'ode nnwa kw'ijinọng kwa Hur, kw'ofon k'ẹkhọma cha Juda, osi odik kpenamkpen mach'Ọvaar Ibinọkpaabyi ọtzọhni Mosẹs.  
\v 23 Ọnọng ọdọdọk kw'iwa ọttar mẹ, wa ode Oholiyab kw'ode nnwa kw'ijinọng kw'Ahisamak kw'ofon k'ẹkhọma cha Dan. Oholiyab nwa, wa ode omengkkakkaa, ọmaana odokh-ekpo, ttara odokh-ọbara fa blu, ọmaana f'okhor-ihiho, ọmaana f'okhor-izizi, ttara ndik iyokhasẹ nkkakka.  
\v 24 Biphyir-phyir gol kw'ofon k'ẹnanga ch'ẹbar-odik kw'iwa bẹ atzim asi ọtzọhm biphyir f'irukhabe s'awurada ode, atalent ẹrọbh obhiri ohawani kwa jobh, ọmaana ashẹkẹl ẹnọhna obhiri arọbh chi obhiri wani obhiri jobh, atzor ka shẹkẹl kw'irukhabe s'awurada. 
\p  
\v 25 Asilva pa bẹ atzọk k'abhonnọng, p'iwa bẹ abhikhi k'ogbe kw'ẹnọngmikha, ade atalent arọbh azen, ọmaana ashẹkẹl nnọhna nna obhiri arọbh azenanttaan obhiri chi, atzor ka shẹkẹl kw'ọhọhm kw'awurada,  
\v 26 bẹka wani, kw'ode ishẹkẹl-ibhakha k'ọnọng-ọnọng, atzor ka shẹkẹl kw'irukhabe s'awurada. Wa ọnọng kpenamkpen kw'ọttar k'ọnọngmik kwa bẹ akk'abhikha biphyir, ttẹwọr ka cho ẹrọbh ọmaana-ọmaana ode, ajinọng nnọhna-nabhik.  
\v 27 Wa bẹ atzim atalent mba arọbh azen pa silva aduk arin p'irukhabe s'awurada ọmaana ekpekhe. Bẹ atzima atalent arọbh azen asi arin arọbh azen, talẹn wani k'orin wani.  
\v 28 Bẹ atzima ashẹkel nnọhna nna obhiri arọbh azenanttaan obhiri chi, asi agbak pa mkpọmmachi, abira atzima abhọri aho pa mkpọmmachi nna, ttara mbarakpa sabẹ. 
\p  
\v 29 Wa brons kw'ofon k'ẹnanga ch'ẹbar-odik ode atalent arọbh attaan obhiri jobh, ọmaana ashẹkẹl nnọhna nzadani.  
\v 30 Wa bẹ atzima brons nwa asi arin p'ẹhọhmma ch'irukhabe nna, ọmaana ijafọhnibe, ttara otzekpa kwẹ kwa brons, ttara ekpo pyẹ biphyir,  
\v 31 ọmaana arin p'ẹttọhmmattem ttara p'ọmma kwẹ, ọmaana abhing p'ikhira s'irukhabe, ttara p'ettọhmmattem. 
\c 39  
\s1 Nnya s'ọfọhnẹja 
\p  
\v 1 Wa bẹ atzima ndik sa nde blu, ọmaana sa ngor-ihiho, ọmaana sa ngor-izizi, ayok nnya s'ọtzọhm f'ọfọhnẹja k'irukhabe s'awurada. Bẹ abira ayok nnya s'awurada anang Aarọn, mach'Ọvaar Ibinọkpaabyi okk'Mosẹs obena. 
\s1 Ẹphọd 
\p  
\v 2 Wa bẹ atzima ndik sa gol, ọmaana sa nde blu, ọmaana sa ngor-ihiho, ọmaana sa ngor-izizi, ttara ndik nkkakka sa bẹ ayokh-oyok, asi ẹphọd.  
\v 3 Bẹ aduk gol-kpa p'ayor-oyori, abira akpaara bẹ k'anaanga, atzima asi ndik sa nde blu, ọmaana sa ngor-ihiho, ọmaana sa ngor-izizi, ttara ndik nkkakka sa bẹ ayokh-oyok, kw'ode ọtzọhmbọhk f'omengkkakkaa.  
\v 4 Wa bẹ ayok mkpa mfa ma mbabaang sa nwobh k'akhaan-akhaan afa p'ẹphọd, ifha sẹ mbọkha ẹphọd nda.  
\v 5 Odikpa kwa bẹ atzim ndik sa gol, sa nde blu, ọmaana sa ngor-ihiho, ọmaana sa ngor-izizi, ttara ndik nkkakka sa bẹ ayokh-oyok, wa ode ọtzọhm f'emengkka. Iwa obiro ode odem nwuma wani ttara ẹphọd, mach'Ọvaar Ibinọkpaabyi okk'Mosẹs obena. 
\p  
\v 6 Bẹ abẹ atza p'oniks k'ẹnana cha gol, bẹ akkẹr che pa va p'Israẹl p'ijinọng m'atza mba, mach'ẹkhọhkha.  
\v 7 Mẹ wọ, bẹ agbana bẹ ka mkpa nna sa mbabaang s'ẹphọd, mach'atza p'ojima anang anọng p'Israẹl, mach'Ọvaar Ibinọkpaabyi okk'Mosẹs obena. 
\s1 Ẹbarakpa ch'ittemmọma 
\p  
\v 8 Bẹ ayok ẹbarakpa ch'ittemmọma, kw'ode ọtzọhmbọhk f'omengkkakkaa. Bẹ atzima ndik sa gol, sa nde blu, ọmaana sa ngor-ihiho, ọmaana sa ngor-izizi, ttara ndik nkkakka sa bẹ ayokh-oyok, ayok sẹ odem nwuma wani macha bẹ ayokhi ẹphọd.  
\v 9 Ẹkpa chẹ ttara adum pẹ, bẹ ade mbenga-mbọhk, adum ọmaana ẹkpa ade ẹbọhkpattem dani, akhọni igbe ifa.  
\v 10 Mẹ wọ, bẹ abẹ adik anna p'atza p'ajibh-ojibh mẹ. M'odik kw'ocheden, bẹ abẹ ọtza kwa ruby, ọmaana kwa topaz, ttara kwa bẹril.  
\v 11 K'odik kw'ottong afa bẹ abẹ ọtza kwa tọkwọis, ọmaana kwa saphira, ttara ẹmẹral.  
\v 12 K'odik kw'ottong attaan bẹ abẹ ọtza kwa jasint, ọmaana kw'agate, ttara amẹtist.  
\v 13 K'odik kw'ottong anna bẹ abẹ ọtza kwa krisolita, ọmaana kw'oniks, ttara kwa jaspa, atzima gol akhọri abem pabẹ.  
\v 14 Wa atza mba ade jobh obhiri afa, kpenamkpen otzera che cha nnwa wani kw'Israẹl, kpenamkpen obe mach'ẹkhọhkha, ttara che ch'efonamma dani ch'Israẹl.  
\v 15 Bẹ atzima gol asi mgbakkọhbh sa bẹ ayokh-oyok, sa nde mach'edik.  
\v 16 Bẹ abira atzima gol asi abem afa, ọmaana ariring afa. Bẹ agbana ariring mba afa ka nnyọhnga mfa, s'ẹbarakpa nda ch'ittemmọma.  
\v 17 Bẹ agbana mgbakkọhbh nna mfa sa gol k'ariring mba afa ka nnyọhnga s'ẹbarakpa ch'ittemmọma,  
\v 18 abira agbana nho nnonggo mfa sa mgbakkọhbh nna k'abem mba afa, bẹ abẹ sẹ ka mbarakpa sa mbabaang k'itzitzikha s'ẹphọd.  
\v 19 Bẹ atzima gol asi ariring afa, agbana bẹ ka nnyọhnga mfa s'ẹbarakpa nda ch'ittemmọma, k'ẹtzaanga kw'ammakpabem p'abaang ẹphọd.  
\v 20 Bẹ abira asi ariring afa adọdọk pa gol, bẹ agbana bẹ k'irekh-irek kwa mbarakpa sa mbabaang, k'itzitzikha s'ẹphọd, abaanga ebir-ebir kw'ẹtzọhnga cha odikpa kw'erin kw'ẹphọd.  
\v 21 Bẹ atzima edik ch'ede blu agbana ariring mba p'ẹbarakpa ch'ittemmọma ka ariring p'ẹphọd. Bẹ akpa chẹ k'odikpa kw'erin, ifha ẹbarakpa nda ch'ittemmọma eningi ẹchari ẹrọbha k'ẹphọd, mach'Ọvaar Ibinọkpaabyi okk'Mosẹs obena. 
\s1 Nnya ndọdọk s'ọfọhnẹja 
\p  
\v 22 Wa bẹ atzima ibara s'ide blu biphyir, ayok ọnọhma-baba kw'ẹphọd, kw'ode ọtzọhmbọhk f'oyokh-ekpo osi,  
\v 23 ọkhaama ọmma m'ottem mach'ẹnọhma-khokhora, cha bẹ abhọri ẹmma ifha eningi ẹjaakhi.  
\v 24 Bẹ atzima ndik sa nde blu, ọmaana sa ngor-ihiho, ọmaana sa ngor-izizi, ttara ndik nkkakka sa bẹ ayokh-oyok, ayok apomegrenet akhọri ammakpabem p'ọnọhma-baba nwa.  
\v 25 Bẹ abira atzima gol ọkkakka asi akkaningkka, agbana akhọri ammakpabem k'ottem apomegrenet.  
\v 26 Akkaningkka ọmaana apomegrenet mba awobh ayok k'ottem, akhọri ammakpabem p'ọnọhma-baba nwa kw'ọtzọhm, mach'Ọvaar Ibinọkpaabyi okk'Mosẹs obena. 
\p  
\v 27 Bẹ atzima ndik nkkakka ayok ọnọhma-khum-mbọhk kw'odumi opyiri ka ndudungi anang Aarọn, ọmaana va pẹ p'ijinọng kw'ode, ọtzọhmbọhk f'oyokh-ekpo,  
\v 28 abira atzima ndik nkkakka ayok ibara s'eho ọdadabh, ọmaana adikpa p'eho, ttara akpokhuma p'ẹtzaanga pa bẹ atzim ndik nkkakka ayok.  
\v 29 Bẹ atzima ndik sa bẹ ayokh-oyok, ọmaana sa nde blu, ọmaana sa ngor-ihiho, ttara sa ngor-izizi, kw'ode ọtzọhmbọhk f'odokh-ọbara osi, mach'Ọvaar Ibinọkpaabyi okk'Mosẹs obena. 
\p  
\v 30 Bẹ atzima gol ọkkakka asi ẹchachaangkpa, kw'ode ivaar-kpo s'awurada, akkẹr mẹ mach'ẹkhọhkha bi, AWURADA AWOBH ANANG ỌVAAR IBINỌKPAABYI.  
\v 31 Mẹ wọ, bẹ akpa edik ch'ede blu agbana k'ibara s'eho ọdadabh, mach'Ọvaar Ibinọkpaabyi okk'Mosẹs obena. 
\s1 Mosẹs okkeri ọtzọhm f'irukhabe 
\p  
\v 32 Mẹ wọ, wa ọtzọhm kpenamkpen f'irukhabe, kw'ode irukhabe s'Ibinọkpaabyi, ọkwu ọha. Anọng p'Israẹl asi odik kpenamkpen atzor k'odem kw'Ọvaar Ibinọkpaabyi okk'Mosẹs obena.  
\v 33 Mẹ wọ, wa bẹ atzini irukhabe nna achena Mosẹs: ikhira sẹ ttara ekpo pyẹ biphyir, ọmaana agbak pẹ, ọmaana nchi s'ẹhọhmma, ọmaana nneremachi, ọmaana mkpọmmachi, ttara arin,  
\v 34 ẹkpa cha ndenkpa s'erukhimaan-dim cha bẹ aphyok asi-khora, ọmaana ẹkpa cha ndenkpa s'avu, ttara ekpekhe ch'ẹkpa ẹkkọhbhi ẹmmaana k'ẹtzaanga,  
\v 35 ọmaana Ẹkkọhbhi ch'Echekhi ttara nneremachi sẹ, ọmaana ẹkkọhbhikpa ch'ephyokhi,  
\v 36 ọmaana okpokkoro ttara ekpo pyẹ biphyir, ọmaana brẹd kw'awurada,  
\v 37 ọmaana ettwikkaang-chi cha gol ọkkakka ttara attwikkaang pẹ ọmaana ekpo pyẹ biphyir, ttara ana p'ekpon oyeyeni,  
\v 38 ọmaana ijafọhnibe sa gol, ọmaana ana pa bẹ am-abyengi ọnọng k'eho, ọmaana insẹns kw'ọdaami eruk, ttara ekpekhe ch'ẹhọhmma ch'ikhira nna;  
\v 39 ọmaana ijafọhnibe sa brons ttara otzekpa kwa brons, ọmaana nneremachi sẹ ttara ekpo pyẹ biphyir, ọmaana ọkwakkama ttara ẹnana chẹ;  
\v 40 ọmaana mkpekhe s'ẹttọhmmattem ttara mkpọmmachi sẹ, ttara nnana, ọmaana ekpekhe ch'ẹhọhmma ch'ettọmmattem; ndik ọmaana abhing p'ikhira s'ẹttọhmmattem, ọmaana ekpo py'ẹnya py'irukhabe nna, s'ide irukhabe s'Ibinọkpaabyi;  
\v 41 ọmaana nnya nyokhasẹ s'ọtzọhm f'irukhabe s'awurada, ọmaana nnya s'awurada s'Aarọn kw'ode ọfọhnẹja, ọmaana nnya sa va pẹ p'ijinọng, k'ogbe kwa bẹ am-asi ọtzọhm f'afọhnẹja. 
\p  
\v 42 Wa anọng p'Israẹl akk'ọtzọhm kpenamkpen asa, mach'Ọvaar Ibinọkpaabyi okk'Mosẹs obena.  
\v 43 Mosẹs e okkeri ọtzọhm, obiro ore bi bẹ akk'fẹ asa mach'Ọvaar Ibinọkpaabyi okk'bẹ obena. Mẹ wọ, Mosẹs on-odo anọng mba. 
\c 40  
\s1 Ettima ch'irukhabe s'Ibinọkpaabyi 
\p  
\v 1 Mẹ wọ, wa Ọvaar Ibinọkpaabyi oben Mosẹs bi:  
\v 2 “K'echedenwu ch'ocheden-phe, tzima irukhabe, s'ide irukhabe s'ewobha ttara Ibinọkpaabyi.  
\v 3 Hok Ẹkkọhbhi nda ch'Echekhi k'ẹtzaanga, atzima ekpekhe akpa chẹ amaana k'ẹtzaanga.  
\v 4 Tzima okpokkoro nwa adim k'ẹtzaanga, ahok ekpo py'ẹbaan bi, ẹnana mẹ. Atzima ettwikkaang-chi adim k'ẹtzaanga, abira atzọkha ottwikkaang anana mẹ.  
\v 5 Hok ijafọhnibe sa gol s'insẹns, k'itzitzikha s'Ẹkkọhbhi nda ch'Echekhi, abira agbana ekpekhe k'ẹhọhmma ch'irukhabe nna.  
\v 6 Hok ijafọhnibe s'ẹnanga ẹkwọmichẹ k'itzitzikha s'ẹhọhmma ch'irukhabe nna, kw'ode irukhabe s'ewobha ttara Ibinọkpaabyi;  
\v 7 ahok ọkwakkama k'ottem kw'irukhabe nna ọmaana ijafọhnibe, akhe asi m'ọkwakkamma nwa.  
\v 8 Tzima ẹttọmmattem akhori sẹ, abira agbana ekpekhe k'ẹhọhmma ch'ẹttọmmattem nda. 
\p  
\v 9 “Tzọkha ana pa bẹ am-abyengi ọnọng k'eho, abyengi m'irukhabe nna ọmaana k'ọttọhk kpenamkpen f'owobh k'ẹtzaanga; si sẹ ọmaana ekpo pyẹ biphyir ewur, mando kwa sẹ íwur.  
\v 10 Mẹ wọ, biri tzọkha ana pa bẹ am-abyengi ọnọng k'eho, abyengi k'ijafọhnibe s'ẹnanga ẹkwọmichẹ, ọmaana ekpo pyẹ biphyir, sẹ ide ibe s'awurada p'ayọhng awurada.  
\v 11 Biri byengi ana mba k'ọkwakkamma ọmaana k'ẹnana chẹ, asi pyẹ ewur. 
\p  
\v 12 “Tzima Aarọn ọmaana va pẹ p'ijinọng akwu k'ẹhọhmma ch'irukhabe nna, atzima asi agbobhi bẹ for.  
\v 13 Mẹ wọ, fọra Aarọn nnya nna s'awurada, abyeng-ẹ ana k'eho, abira asẹ-ẹ owur, ifha kẹ ofha osi ọtzọhm f'ọfọhnẹja.  
\v 14 Biri tzima va pẹ p'ijinọng akwu, afọra bẹ ọnọhma-khum-mbọhk kw'odumi opyiri ka ndudungi.  
\v 15 Byengi bẹ ana k'eho, mach'iwa abyengi otte kwabẹ, ifha bẹ afha asi ọtzọhm mach'afọhnẹja. M'eden nda dọ cha bẹ achina ororo áde afọhnẹja k'igbọ s'íkwu k'ogbe ororo.  
\v 16 Wa Mosẹs osi odik kpenamkpen mach'Ọvaar Ibinọkpaabyi oben-ẹ. 
\p  
\v 17 Mẹ wọ, wa bẹ attima irukhabe nna k'echedenwu ch'ocheden-phe, ka cho kw'ottong afa.  
\v 18 Mada Mosẹs ottim irukhabe nna, obera arin pẹ \it bi gbuk\it*, obiro okhe nchi s'ọmma, okhe nneremachi sẹ, obiro ottima mkpọmmachi.  
\v 19 Ọn-ọmẹma ekhirakpa nda obubha k'ebir-ebir kw'irukhabe nna, obiro obubha ebir-ebir kw'ikhira nna mach'Ọvaar Ibinọkpaabyi obeni Mosẹs. 
\p  
\v 20 Ọtzọkha atza-gbẹgbẹri p'Asana okhe k'Ẹkkọhbhi ch'Echekhi, ọtzọkha nneremmachi ọnọhma m'Ẹkkọhbhi ch'Echekhi, obiro obubha chẹ ttara ẹkkọhbhikpa ch'ephyokhi.  
\v 21 Mẹ wọ, otzima Ẹkkọhbhi ch'Echekhi odim k'irukhabe ẹtzaanga, ọgbana ekpekhe ọkpa chẹ ọmaana k'ẹtzaanga, obiro ọkpa Ẹkkọhbhi ch'Echekhi ọmaana kẹ, mach'Ọvaar Ibinọkpaabyi obeni Mosẹs. 
\p  
\v 22 Wa Mosẹs obera okpokkoro k'ẹtzaanga kw'irukhabe, k'okhubha kw'okkeri k'ebir-ebira, k'iyaan-iyaan s'ekpekhe nda,  
\v 23 ọtzọkha brẹd ọnana m'okpokkoro nwa ebir-ebir, k'itzitzikha s'Ọvaar Ibinọkpaabyi, mach'Ọvaar Ibinọkpaabyi oben Mosẹs. 
\p  
\v 24 Ohok ettwikkaang-chi k'irukhabe ewobha ekkeri okpokkoro itzitzikha k'ẹrakha-ẹrakha kw'irukhabe nna,  
\v 25 obiro otzini attwikkaang mba obera m'itzitzikha s'Ọvaar Ibinọkpaabyi, mach'Ọvaar Ibinọkpaabyi obeni Mosẹs. 
\p  
\v 26 Mosẹs ottima ijafọhnibe sa gol k'irukhabe ẹtzaanga k'itzitzikha s'ekpekhe,  
\v 27 obiro ọkwọmi insẹns kw'ọdaami eruk mẹ, mach'Ọvaar Ibinọkpaabyi obeni Mosẹs.  
\v 28 Mẹ wọ, ọgbana ekpekhe nda k'ẹhọhmma ch'irukhabe nna. 
\p  
\v 29 Ottima ijafọhnibe s'ẹnanga ẹkwọmichẹ ọbaanga ẹhọhmma ch'irukhabe, s'ide irukhabe s'ewobha ttara Ibinọkpaabyi. Osi ẹnanga ẹkwọmichẹ, ttara ẹnanga ch'abọkpa mẹ, mach'Ọvaar Ibinọkpaabyi, oben Mosẹs. 
\p  
\v 30 Obera ọkwakkama nwa k'ottem kw'irukhabe s'ewobha ttara Ibinọkpaabyi, ọmaana ijafọhnibe nna, okhe asi m'ọkwakkamma nwa pa mbọhk ọmaana mmopatzọkhi ogbogbobhi,  
\v 31 mẹ kwa Mosẹs ọmaana Aarọn, ttara va p'Aarọn p'ijinọng, am-agbobhi mbọhk, ọmaana mmopatzọkhi sabẹ.  
\v 32 Ogbe kpenamkpen kwa bẹ adimi k'irukhabe nna, obiro ode bi bẹ areng atzuma k'ijafọhnibe, bẹ am-agbobhi mbọhk ọmaana mmopatzọkhi sabẹ, mach'Ọvaar Ibinọkpaabyi obeni Mosẹs. 
\p  
\v 33 Mẹ wọ e, Mosẹs ottima ẹttọmmattem ọkhọri irukhabe nna, ọmaana ijafọhnibe nna, ọgbana ekpekhe k'ẹhọhmma ch'ẹttọmmattem. Wa Mosẹs okyera ọtzọhm osisi. 
\s1 Abarada p'Ọvaar Ibinọkpaabyi 
\p  
\v 34 Mẹ wọ, eboni ebubha irukhabe nna, abarada p'Ọvaar Ibinọkpaabyi abira ahakha afu irukhabe nna \it bi pyẹẹr\it*.  
\v 35 Wa Mosẹs k'irukhabe nna ẹtzaanga dọk kofha odim, okhuri da eboni nda ẹkk'ẹhakha ewobha mẹ, abarada p'Ọvaar Ibinọkpaabyi abira afu m'irukhabe nna. 
\p  
\v 36 K'orenga kw'anọng p'Israẹl asi biphyir, ogbe kpenamkpen kwa bẹ are da eboni eyebhi k'irukhabe, bẹ abina orenga;  
\v 37 yina, idikha eboni en-eyebhi, bẹ orenga kabin, maa opyiri k'ewu cha ch'eyebh.  
\v 38 Mẹ wọ, wa eboni nda ch'Ọvaar Ibinọkpaabyi em-ebubha irukhabe nna k'ẹya, ekpon ẹm-ẹwọma mẹ k'erungi. Wa anọng p'Israẹl biphyir am-are odik nwa k'orenga kwabẹ biphyir.