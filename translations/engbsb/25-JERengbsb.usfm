\m
\v 7 ‘\w But|strong="H3808"\w* \w to|strong="H3068"\w* \w your|strong="H3068"\w* \w own|strong="H3027"\w* \w harm|strong="H7451"\w*, \w you|strong="H3808"\w* \w have|strong="H3068"\w* \w not|strong="H3808"\w* \w listened|strong="H8085"\w* \w to|strong="H3068"\w* \w Me|strong="H3027"\w*,’ \w declares|strong="H5002"\w* \w the|strong="H5002"\w* \w LORD|strong="H3068"\w*, ‘\w so|strong="H4616"\w* \w you|strong="H3808"\w* \w have|strong="H3068"\w* \w provoked|strong="H3707"\w* \w Me|strong="H3027"\w* \w to|strong="H3068"\w* \w anger|strong="H3707"\w* \w with|strong="H3068"\w* \w the|strong="H5002"\w* \w works|strong="H4639"\w* \w of|strong="H3068"\w* \w your|strong="H3068"\w* \w hands|strong="H3027"\w*.’   
\b  
