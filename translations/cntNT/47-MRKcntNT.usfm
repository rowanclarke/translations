\id MRK  
\h SAN MARCOS 
\toc1 Jág₁ Dse₃ quió'₅ Diú₄ a₂ca₂tó'₂ San Marcos ne₄ Si₂ 
\toc2 SAN MARCOS 
\toc3 Mr. 
\mt1 Jág₁ Dse₃ quió'₅ Diú₄ a₂ca₂tó'₂ San Marcos ne₄ Si₂ 
\c 1  
\s1 'Ë́₂ Juan₅₄ jág₁ quió'₅ Diú₄ caun₂ 'uë₃ co₂'ŋiog₅ 
\r (Mateo 3:1-12; Lucas 3:1-9, 15―17; Juan 1:19-28) 
\p  
\v 1 Le₂la₂ bá₄ ca₂rë₃lióg₃ jág₁ dse₃ quió'₅ Jesucristo, Ja₁ŋi'₅₄ Diú₄. \f + \fr 1:1 \ft A₂lɨn₅₄ chog₅₄ si₂ tsá₃ chi₁ton₅ “Ja₁ŋi'₅₄ Diú₄.” \f* 
\p  
\v 2 Juɨ₁lia'₂ lë́₅ tio'₅₄ ne₄ si₂ quió'₅ dsa₂ i₂jme₁'ë́₂ jág₁ quián₂ Diú₄ ma₂lɨ́g'₂, ja₁juá'₂ le₂la₂: 
\q1 Tsɨng₅₄ jan₂ dsa₂ quiáng₃ 
\q2 ne₄ juɨ₅ quiáng'₂, jón₃, 
\q1 a₂dsɨ₃can₅ jág₁ dse₃ jɨn₄ dsa₂ mɨ₂güɨ́g₃, 
\q2 jaun₂ jmo₃ co₂jŋia₅₄ juɨ₅ quiáng'₂.\f + \fr 1:2 \ft Malaquías 3:1.\f* 
\q1  
\v 3 Jaun₂ né'₂ 'ë́₂ dsa₂ 'éi₂ jág₁ co₂mɨ'₅₄ 
\q2 caun₂ 'uë₃ quein₂ co₂'ŋiog₅, jaun₂ i₂'éi₂ juá'₂: 
\q1 “Jmo₄ 'nia'₂ co₂jŋia₅₄ 
\q2 juɨ₅ quió'₅ Te₁gui'₅₄ i₂jiá₃. 
\q1 Nia₄ 'nia'₂ caun₂ juɨ₅ co₂dsau₅.”\f + \fr 1:3 \ft Isaías 40:3.\f* 
\p  
\v 4 Jaun₂ le₂la₂ ca₂rë₃ti₃ jág₁ në₅: Ca₂guan₃ Juan₅₄ caun₂ ja₁lë́₄ 'uë₃ co₂'ŋiog₅ ca₂choin₃ jmɨg₂ dsa₂, qui₂ca₂'ë́₂ jág₁ a₂tsón₃ dsa₂ jmɨg₂, jë₁ma₂ca₂dsi₃quén'₅ dsɨ́₅ ia₁jaun₂ le₃'én₂ dsáu₁.  
\v 5 Jaun₂ ca₂le₃jɨ́n₃ dsa₂ chan₂ juɨg₂ Judea quian'₅₄ dsa₂ i₂chan₂ Jerusalén në́₃, ca₂i₁lein₅₄ ja₁jme₁'en₅₄ Juan₅₄. Qui₂ca₂jmo₃ dsa₂ qui₂ŋí₃ quió'₅ ca₂le₃jë́₃ dsáu₁. Jaun₂ guë́₄ ca₂cho₃ Juan₅₄ jmɨg₂\f + \fr 1:5 \ft lit. “ca₂tióg₃ Juan₅₄ jmɨg₂” \f* Cuá₃ Jordán. 
\p  
\v 6 Nɨ₁tsɨn'₅₄ Juan₅₄ 'éi₂ jme₁lë́₄ quian'₅₄ nɨ₁jŋí₁ já'₂ camello. A₂jme₁jén'₅ tú'₅ guë'₂ në́₃, lo₄ já'₂. Má₃ a₂jme₁guë́'₅ guë'₂, jmá'₃ i₁nɨ'₂ tia₄ quian'₅₄ jmɨ₁tá'₄ cha₂ ja₁nau₂.  
\v 7 Caun₂ ca₂ŋɨ₃ bá₄ 'ë́₂ jág₁ dse₃, juá'₂: 
\p ―I₂jiá₃ chi₁co'₅₄ quió₃, i₂'éi₂ bá₄ i₂'uan'₂ i₂tɨn₂ guë́₄ lia'₂ con'₂ guë́₄ jniá₂, ca₂lia'₂ jŋia'₅₄ lau₂ ton₅ tag₅₄ tsá₃ ca₂tɨ́ng₂ tsɨ'₅₄.  
\v 8 Jniá₂ në₂tiáng₃ 'nia'₂ jmɨg₂; la₁ 'éi₂ guë'₂ në́₃ tióg₂ Jme₂dsí₂ Jŋió₅. 
\s1 Ca₂chon₃ Juan₅₄ jmɨg₂ Jesús 
\r (Mateo 3:13-17; Lucas 3:21-22) 
\p  
\v 9 Jmɨg₄ jaun₂ o₂'ɨ́n₃ Jesús juɨg₂ Nazaret, ja₁tén₄ Galilea. Ŋó₃ ja₁'en₅₄ Juan₅₄. Ja₁jaun₂ ca₂cho₃ Juan₅₄ jmɨg₂ ca₂choin₃ Jesús\f + \fr 1:9 \ft lit. “ca₂tióg₃ Juan₅₄ ca₂tiáin₂ jmɨg₂ Jesús.” \f* Cuá₃ Jordán.  
\v 10 Jaun₂ dsɨ₂juɨ₅ jme₁ca₂'ŋio₂ Jesús ne₄ jmɨg₂, ca₂jág₃ ca₂niá₃ dsɨ₄ mɨ₂güɨ́g₃. Jaun₂ ca₂sión₃ Jme₂dsí₂ quián₅ Diú₄ i₂lɨ́n₅ lia'₂ lɨ́n₅ jan₂ i₁ju₂, ne₄ quió'₅.  
\v 11 Jaun₂ ca₂né'₂ jág₁ a₂já₅ guei'₅₄ i₂juɨ́g₃ a₂juá'₂: 
\p ―'Ne₂ bá₄ lɨ́ng'₅ jón₃ quiáng₃, i₂ŋɨ́₄ lë₃ 'nióg₃ guë́₄ lɨn₃; 'E₂ bá₄ 'ŋio₂ dsɨ₃ quian'₅₄ 'ne₂. 
\s1 Ca₂caun₃ i₂së₃dsen₃ táu₂ quió'₅ Jesús 
\r (Mateo 4:1-11; Lucas 4:1-13) 
\p  
\v 12 Dsɨ₂juɨ₅ jaun₂ ca₂jiog₃ Jme₂dsí₂ quián₅ Diú₄ caun₂ juɨ₅ 'uë₃ co₂'ŋiog₅.  
\v 13 Jaun₂ ja₁jaun₂ ca₂'í₃ të₂láu₃ jmɨg₄ ia₁jaun₂ cáun₂ táu₂ i₂së₃dsen₃. Ja₁jaun₂ jme₁tion'₅₄ já'₂ tsau₂ dsɨ́₅. La₁ ca₂o₃lén₂ ángeles ca₂jme₃'o₅₄. 
\s1 Ca₂jme₃lióg₃ Jesús jme₂tɨin₂₃ dsa₂ jág₁ dse₃ 
\r (Mateo 4:12-17; Lucas 4:14-15) 
\p  
\v 14 Jme₁ma₂ca₂ton'₂ dsa₂ Juan₅₄ né'₃ 'má₃, Jesús në́₃ ca₂ŋei₅₄ juɨ₅ Galilea i₁'ë́₄ jág₁ dse₃ quió'₅ Diú₄,  
\v 15 juá'₂ ŋɨ₂₃: 
\p ―Ca₂dsɨn₃ jmɨg₄ a₂ja₂quián₃ a₂jme₃gón₃ Diú₄. Jaun₂ lë₃ juɨ₁dsi₂quén'₅ 'au'₂, juɨ₁le₂'én'₂ 'nia'₂ jág₁ dse₃. 
\s1 Ca₂të́'₃ Jesús quén₂ dsa₂ i₂jme₁tion'₅₄ tsán'₂ ju₄ 
\r (Mateo 4:18-22; Lucas 5:1-11) 
\p  
\v 16 Co₂ráun₂ ca₂ŋɨ₅ Jesús chei'₅₄ jmɨ₁ŋí'₄ Galilea. Ja₁jaun₂ ca₂jɨ́in₂ Si₂mu₅₄ quiain'₅₄ Drë́₄ rɨin'₅₄. Jme₁tioin'₅₄ táun₂ 'má₅ dsi₂jmɨg₂, ia₁ jme₁lɨ́in₄ dsa₂ i₂jmo₅ ta₁ tsán'₂ ju₄.  
\v 17 Jaun₂ ca₂juá'₂ Jesús: 
\p ―I₂nó'₅ 'nia'₂, jme₁quiong'₅₄ jniá₂, jaun₂ cuë₅₄ ta₁ a₂chi₁liang'₂ dsa₂ mɨ₂güɨ́g₃, juɨ₁lia'₂ chi₂lián'₁ 'nia'₂ ju₄. 
\p  
\v 18 Jaun₂ dsɨ₂juɨ₅ bá₄ i₃léin₂ quiong'₅₄; ja₁jaun₂ ca₂dsia₃ bá₄ tsɨ₁'má₅ quió'₅. 
\p  
\v 19 Me'₂ bá₄ ja₁i₃léin₂ guë́₄ jme₁ca₂jɨ́in₂ i₂chen₂ Jacobo quiain'₅₄ Juan₅₄ rɨin'₅₄, ja₁ŋi'₅₄ Zebedeo. Jme₁tioin'₅₄ 'ŋió'₃ tsɨ₁mu₅ jmóg'₅ 'má₅ quió'₅.  
\v 20 Dsɨ₂juɨ₅ ca₂të́'₃ i₂'éi₂ ján₃; ca₂tén₂ bá₄ guë'₂ 'éi₂ në́₃ Zebedeo jmei₂ 'ŋió'₃ tsɨ₁mu₅ quian'₅₄ mozo quiáin₅. 
\s1 Jan₂ dsa₂ i₂jme₁'en₅₄ jme₂dsí₂ 'lɨn'₅₄ të₂dsɨ́₅ 
\r (Lucas 4:31-37) 
\p  
\v 21 Jaun₂ dsi₃léin₂ juɨg₂ Capernaum. Caun₂ jmɨg₄ sa₅₄, ca₂'í₃ Jesús guá'₅ sinagoga. Jaun₂ ca₂jme₃lióg₃ ca₂jme₃tɨin₂₃ dsa₂ jág₁ dse₃.  
\v 22 Ca₂le₃jɨ́n₃ i₂ca₂nág₂ në́₃ ca₂i₃gó'₃ dsɨ́₅ jág₁ quió'₅, ia₁ ca₂jme₃tag₂₃ juɨ₁lia'₂ jë₁jme₂tag₅ jan₂ i₂'io₅ 'éi'₃, on₃jua'₅₄ rë'₂ juɨ₁lia'₂ jme₂tag₅ të₅juá'₅.  
\v 23 Jë₄ jaun₂ ca₂dsióg₃ jan₂ dsa₂ i₂'en₅₄ jme₂dsí₂ 'lɨn'₅₄, ca₂juá'₂ guió'₅ tiá₂: 
\p  
\v 24 ―¿'E₂ lë₃ tián'₅ 'ne₂ Jesús Nazareno\f + \fr 1:24 \ft o₃, “i₂chan₂ Nazaret.” \f* jë₄ quián₂ jnia'₅₄? A₂jŋia'₅₄ 'niog'₂ 'éng'₄ jnia'₅₄ bá₄ 'ne₂ ŋe'₃. Guion₄ jniá₂ 'ein₂ lɨ́ng'₅. 'Ne₂ lɨ́ng'₅ dsa₂ jŋió₅ quián₅ Diú₄. 
\p  
\v 25 Jaun₂ ca₂jén₂ Jesús i₂'lɨn'₅₄ i₂'en₅₄ të₂dsɨ́₅ dsa₂ 'éi₂, ca₂juá'₂: 
\p ―Tei₄ jmo₄. Jú₅ quió'₅ dsa₂ në₅. 
\p  
\v 26 Jaun₂ ca₂jmo₃ i₂'lɨn'₅₄ ca₂ba₂ca₂lɨ́n'₂ dsa₂ 'éi₂ 'uë₃, ca₂guió'₃ tiá₂. Jaun₂ guë́₄ o₂'ɨ́in₃ jaun₂ në́₃.  
\v 27 Jaun₂ ca₂le₃jɨ́n₃ dsa₂ i₂ca₂të́₂ ne₄ ca₂i₃gó'₃ dsɨ́₅, qui₂ca₂ŋɨ́i'₃ rɨin'₅₄, ca₂juá'₂: 
\p ―¿'E₂ bá₄ në₅? ¿'An₁ a₂në₅ bá₄ juá'₅ 'mɨ́₂? ¡'Io₅ 'éi'₃ i₂në₅ ca₂të₂ ne₄ quió'₅ i₂'lɨn'₅₄, jaun₂ 'éi₂ në́₃ nag₂₃ gau₂ jág₁ quió'₅! 
\p  
\v 28 Jaun₂ dsɨ₂juɨ₅ bá₄ ca₂i₃'ág₃ jág₁ quió'₅ ca₂le₂con₂ ja₁tén₄ Galilea. 
\s1 Ca₂jme₃'lión₂ Jesús ma₂chog₅₄ Si₂mu₅₄ 
\r (Mateo 8:14-15; Lucas 4:38-39) 
\p  
\v 29 Jaun₂ dsɨ₂juɨ₅ jme₁ca₂'uɨin₂ guá'₅, ca₂ŋó₃ quiain'₅₄ Jacobo, Juan₅₄ në́₃, ja₁quió'₄ Si₂mu₅₄ quian'₅₄ Drë́₄.  
\v 30 Ma₂chog₅₄ Si₂mu₅₄ në́₃ jme₁roin₂₃ dso'₅₄, 'i₄ dséi₂. Jaun₂ dsɨ₂juɨ₅ ca₂'ɨn₃ dsa₂ dsa₂ dso'₅₄ 'éi₂ ca₂tsɨ́'₃ Jesús.  
\v 31 Jaun₂ në́₃ ca₂jme₃quiáin₃ con₂ dsa₂ dso'₅₄, ca₂jŋa'₃ gu₂, ca₂chó'₂ jaun₂ në́₃. Jaun₂ dsɨ₂juɨ₅ bá₄ ca₂o₃'ág₃ dséi₂ dsa₂. Jaun₂ 'io₅₄ 'éi₂ në₃ ca₂jme₃lióg₃ ca₂jme₃ti₃ ta₁ ne₄ 'éi₂ tioin'₅₄. 
\s1 Ca₂jme₃'lión₂ Jesús juɨn₅ dsa₂ dso'₅₄ 
\r (Mateo 8:16-17; Lucas 4:40-41) 
\p  
\v 32 Jme₁ma₂rɨn₂ 'iog₂ jmɨg₄ jaun₂, ca₂o₃jŋia₃ dsa₂ ne₅₄ ca₂le₃jɨ́n₃ dsa₂ dso'₅₄, dsa₂ i₂tion'₅₄ jme₂dsí₂ je₂na'₅₄ në́₃.  
\v 33 Ca₂le₃jɨ́n₃ dsa₂ juɨg₂ bá₄ ca₂ŋɨ'₂ o₄'né₄.  
\v 34 Jaun₂ Jesús në́₃ ca₂jme₃'lióin₂ dsa₂ ca₂le₃jë́₃ ne₅₄ dso₄ a₂jme₁lɨ́in₄. Qui₂ca₂'uɨ́in'₂ rë'₂ juɨn₅ je₂na'₅₄ në́₃. La₁ tsá₃ ma₃ca₂cuë₃ Jesús jmɨg₄ jua'₅₄ a₂juá'₂ guë́₄ je₂na'₅₄ jág₁, ia₁ ŋi₅ bá₄ je₂na'₅₄ 'ein₂ 'éi₂. 
\s1 Ca₂'ë́₂ Jesús jág₁ dse₃ dsi₂néi₂ guá'₅ sinagogas le₂tan₅₄ juɨg₂ ja₁tén₄ Galilea 
\r (Lucas 4:42-44) 
\p  
\v 35 Le₁né₃ guë́₄ jme₁jnia₃ jaun₂, ca₂nau₂ Jesús o₂'ɨ́in₃ 'nɨ'₂ juɨg₂, caun₂ ja₁lë́₄ co₂'ŋiog₅, i₁chi'₄ Diú₄.  
\v 36 Jaun₂ ŋó₃ Si₂mu₅₄ quiain'₅₄ rɨin'₅₄ i₁'niong'₂.  
\v 37 Jme₁ca₂dsáu'₂ në́₃, ca₂juá'₂: 
\p ―Ca₂le₃jɨ́n₃ dsa₂ i₂nioi₅₄ 'nai'₂ 'ne₂. 
\p  
\v 38 La₁ Jesús në́₃ ca₂ŋag₃: 
\p ―Ma₃dsau₅₄ dsɨ₂i₁nio₁ le₂tan₅₄ juɨg₂ ma₂quián₅ në₅, dsɨ₁'ë́₄ jág₁ dse₃, ia₁ ta₁ jaun₂ bá₄ guio₃ jniá₂. 
\p  
\v 39 Jaun₂ le₂në₅ ca₂i₁ŋɨ₂ Jesús le₂tan₅₄ juɨg₂ tio'₅₄ ja₁tén₄ 'uë₃ Galilea, qui₂i₁'ë́₄ jág₁ dse₃ dsi₂néi₂ guá'₅ sinagogas le₂caun₂ juɨg₂. Qui₂ca₂'uɨ́in'₂ je₂na'₅₄ të₂dsɨ́₅ dsa₂ në́₃. 
\s1 Ca₂jme₃'lión₂ Jesús dsa₂ i₂lɨ́n₅ 'mé'₅ 'iog₅ 
\r (Mateo 8:1-4; Lucas 5:12-16) 
\p  
\v 40 Ca₂guan₃ jan₂ dsa₂ dso'₅₄ i₂lɨ́n₅ 'mé'₅ 'iog₅ coin₂. Jaun₂ ca₂chi₃jné₃ ne₅₄, ca₂juá'₂: 
\p ―Chi₂jua'₂ 'ŋio₂ 'au'₂, jŋia'₅₄ lia'₂ 'ne₂ bá₄ quɨ'₅₄ jmɨg₄ jmó'₂ le₁jë́₃ quió₃. 
\p  
\v 41 Jaun₂ ca₂dsia₃ Jesús ŋéi₂ dsɨ́₅ dsa₂ 'éi₂, ca₂néi'₃ gu₂ ca₂nɨ́i'₂ quió'₅, jaun₂ ca₂juá'₂: 
\p ―'Ŋio₂ bá₄ dsɨ₃. Juɨ₁le₅₄ le₁jë́₃ quiáng'₂. 
\p  
\v 42 Dsɨ₂juɨ₅ le₂jaun₂ ca₂jŋia'₃ 'mé'₅ 'iog₅, ca₂'lón₂ dsa₂ 'éi₂.  
\v 43 Jaun₂ ca₂dsióg'₂, ca₂juá'₂: 
\p  
\v 44 ―La₁ të₃ŋi'₅₄ tsá₃ 'ein₂ i₂juɨg'₂ 'i₁jan₂. Jŋia'₅₄ gua₂ o₂jme₁jnia₅ ne₄ jme₂dsa₂, o₂jen'₅₄ ne₄ Diú₄ o₂jmo₄ con'₂ lë́₅ 'Éi'₃ quió'₅ Moisés,\f + \fr 1:44 \ft 'Éi'₃ quió'₅ Moisés: 'Í₂ Levítico 14.\f* o₂jang'₅₄ jág₁ dsau₅ jɨn₄ dsa₂ juɨg₂ a₂ma₂'lóng'₂. 
\p  
\v 45 La₁ dsa₂ 'éi₂ në́₃ të₂le₃ i₂juɨ'₂ guë́₄ ca₂dsia₃ bá₄ jme₁o₂'ɨ́in₃, qui₂ca₂'ë́₂ jág₁ ca₂le₂con₂. 'Uɨg₅₄ jaun₂ tsá₃ ma₃lé₂ 'í₂ Jesús jë₄ juɨg₂ të₃ jág₅ dsa₂; jmá'₃ lia'₂ ja₁co₂'ŋiog₅ bá₄ jme₁jŋia₂₃. La₁ tion₅₄ bá₄ jme₁dsɨ₂lén₂ dsa₂ coin₂ i₂ja₂lén₂ ca₂le₂con₂ jaun₂. 
\c 2  
\s1 Ca₂jme₃'lión₂ Jesús jan₂ dsa₂ i₂rë₂já'₃ quió'₅ 
\r (Mateo 9:1-8; Lucas 5:17-26) 
\p  
\v 1 Cang₂ jaun₂ ca₂'í₃ táng₃ Jesús jë₄ juɨg₂ Capernaum. Jaun₂ ca₂rë₃ŋi₅ dsa₂ a₂ma₂dsiáin'₃.  
\v 2 Jaun₂ dsɨ₂juɨ₅ bá₄ ca₂ŋɨ'₂ dsa₂ juɨn₅ lɨn₃, ca₂lia'₂ jŋia'₅₄ tsá₃ ma₃të₂ ja₁'éin'₄ dsi₂néi₂, le₂tan₅₄ o₄'né₄ në́₃. Jaun₂ ca₂ton₃ jág₁ dse₃ ca₂tsɨ́'₃ dsa₂.  
\v 3 Jaun₂ ca₂dsi₃lén₂ co₂nió'₃; jë₄ jaun₂ i₃lén₂ quén₂ le₁jŋiai₂₃ jan₂ dsa₂ i₂rë₂já'₃ quió'₅.  
\v 4 Ia₁ tsá₃ lé₂ ŋɨ́i₃ të₂ dsi₂néi₂ ja₁'en₅₄ Jesús, ia₁ juɨn₅ dsa₂ tion'₅₄, jaun₂ juɨ₅ co'₅₄ tsɨ₁'né₅ bá₄ ca₂niá₃ caun₂ tau₂ pa₁, co₂dsau₅ ja₁chén'₄ Jesús. Juɨ₅ jaun₂ ca₂sióin₂ dsa₂ 'lian'₂ 'éi₂, dsɨ́in₂ caun₂ tsɨ₁jein₁.  
\v 5 Jme₁ca₂rë₃lí'₄ Jesús 'a₂ lia'₂ 'én₂ dsa₂ 'éi₂, jaun₂ ca₂tsɨ́'₃ dsa₂ 'lian'₂: 
\p ―Jón₃, ma₂rë₂'én₄ bá₄ dsáu'₂. 
\p  
\v 6 Jaun₂ i₂lɨn₅₄ të₅juá'₅ i₂jme₁tián'₄ jë₄ jaun₂, ca₂i₃jiog₅ dsɨ́₅:  
\v 7 “¿'E₂ lë₃ juá'₂ i₂në₅ le₂në₅? A₂'ɨn₅ 'lɨg'₅₄ Diú₄ bá₄ i₂në₅. 'I₁jan₂ tsá₃ 'ein₂ lé₂ le₃'én₂ dsáu₁ dsa₂, jŋia'₅₄ lia'₂ jan₂ Diú₄ bá₄.”  
\v 8 La₁ ma₂ŋi₅ bá₄ Jesús dsɨ₂juɨ₅ a₂dsɨ₂jiog₅ dsɨ́₅ dsa₂ 'éi₂ tiáin'₅, jaun₂ ca₂juá'₂: 
\p ―¿'E₂ lë₃ dsɨ₂jiog₅ 'au'₂ 'nia'₂ le₂në₅?  
\v 9 ¿'E₂ a₂quian₅ guë́₄ ta₁, a₂juɨg₅₄ jniá₂ dsa₂ 'lian'₂ në₅: “Ma₂rë₂'én₄ dsáu'₂”, o₃ a₂juɨg₅₄ 'e₂ jniá₂: “Nau₂ guan'₂ ŋɨ₄ quion₂ tsɨ₁jein₁ quiáng'₂?”  
\v 10 La₁, ia₁jaun₂ le₃ŋi'₅₄ 'nia'₂ a₂'io₅ bí₂ 'éi'₃ Jaun₅ dsa₂ mɨ₂güɨ́g₃ ne₄ gua'₅₄ 'uë₃ a₂lé₂ le₃'éin₂ dsáu₁ dsa₂ ―jaun₂ ca₂tsɨ́'₃ dsa₂ 'lian'₂ 'éi₂: 
\p  
\v 11 ―'Ne₂ juɨ́g₂ jniá₂, nau₂ quion₂ tsɨ₁jein₁ quiáng'₂, guan'₂. 
\p  
\v 12 Jaun₂ ca₂nau₂ 'éi₂, ca₂cáun₃ tsɨ₁jein₁ quió'₅, të₃ jág₅ dsa₂. Jaun₂ ca₂i₃gó'₃ dsɨ́₅ ca₂le₃jɨ́in₃, qui₂jme₂juɨin'₂ Diú₄, tsɨ́'₅ rɨin'₅₄: 
\p ―'I₁co₂ráun₂ tsá₃ 'ein₂ ma₂jág₃ jniog₄ le₂në₅. 
\s1 Ca₂të́'₃ Jesús Leví 
\r (Mateo 9:9-13; Lucas 5:27-32) 
\p  
\v 13 Con'₂ siá'₂ táng₃ ca₂ŋó₃ Jesús chei'₅₄ jmɨ₁ŋí'₄. Jaun₂ dsi₃lén₂ dsa₂ juɨn₅ ca₂ŋɨi'₂. Jaun₂ qui₂ca₂jme₃tag₅ Jesús jág₁ dse₃.  
\v 14 Jme₁ca₂ŋɨi₅ ja₁jaun₂, ca₂jɨ́in₂ Leví\f + \fr 2:14 \ft Leví i₂të́'₂ Mateo ján₃.\f* ja₁ŋi'₅₄ Alfeo, guá₅ 'éi₂ gue₂₃ 'lia'₅₄ a₂ca₂tɨ́n₂ dsɨ₂tan₅₄ romano. Jaun₂ ca₂juá'₂ Jesús: 
\p ―Jme₁quiong'₅₄ jniá₂. 
\p Jaun₂ ca₂nau₂ 'éi₂, ca₂ŋó₃ quiong'₅₄. 
\p  
\v 15 Jme₁ma₂'en₅₄ Jesús guë́'₅ ja₁quió'₄ Leví; ja₁jaun₂ jme₁le₁ŋɨ'₂ juɨn₅ dsa₂ i₂cán₂ 'lia'₅₄ quián₅ dsɨ₂tan₅₄ ján₃, quian'₅₄ dsa₂ sián'₂ “i₂le₁cán'₄ dso₄” në́₃, tiáin'₅ co₂lë₅ guë́'₅ quian'₅₄ Jesús quian'₅₄ dsa₂ quiáin₅, ia₁ i₂juɨn₅ lɨn₃ i₂le₂'éi₂ ma₂quiain'₅₄ ŋɨ₂₃.  
\v 16 Jaun₂ jme₁ca₂jág₃ të₅juá'₅ quián₅ dsa₂ fariseos a₂guë́'₅ Jesús co₂lë₅ quian'₅₄ dsa₂ le₂'éi₂, jaun₂ ca₂tsɨ́'₃ dsa₂ quián₅ Jesús: 
\p ―¿'A₂ bá₄ lia'₂ guë́'₅ të₅ quián'₂ 'nia'₂ quian'₅₄ dsa₂ 'lɨn'₅₄ i₂le₁cán'₄ dso₄, quian'₅₄ i₂cán₂ 'lia'₅₄ quián₅ dsɨ₂tan₅₄ në́₃?  
\v 17 Jaun₂ jme₁ca₂nág₂ Jesús jág₁ në₅, jaun₂ ca₂ŋag₃: 
\p ―Tsá₃ të₅mɨ́₅ 'nió'₅ quió'₅ dsa₂ dsen₃ i₂tsá₃ le₁dso'₅₄, jŋia'₅₄ lia'₂ dsa₂ i₂le₁dso'₅₄ bá₄ 'nió'₅ të₅mɨ́₅ quió'₅. Ia₁ tsá₃ ta₁ jaun₂ guio₃ jniá₂ a₂të́₄ dsa₂ dsen₃, a₂të́₄ dsa₂ i₂qui₂le₁cán'₄ dso₄ bá₄ jniá₂ guio₃. 
\s1 Ca₂ŋɨ́'₃ dsa₂ Jesús juɨ₁lia'₂ jág₁ a₂jme₂'ɨn₅₄ dsa₂ 
\r (Mateo 9:14-17; Lucas 5:33-39) 
\p  
\v 18 Co₂ráun₂ dsa₂ i₂jme₁i₂nio₄ quian'₅₄ Juan₅₄, quian'₅₄ dsa₂ i₂tén₅ le₃quió'₅ dsa₂ fariseos në́₃, jme₁jme₂'ɨin₅₄. Jaun₂ dsi₃lén₂ i₂lɨn₅₄ ca₂ŋɨ́i'₃ Jesús: 
\p ―¿'E₂ 'uɨg₅₄ jme₂'ɨn₅₄ dsa₂ i₂i₂nio₄ quian'₅₄ Juan₅₄, dsa₂ quián₅ fariseos në́₃, ton'₂ tsá₃ jme₂'ɨn₅₄ guë'₂ dsa₂ quián'₂ 'ne₂? 
\p  
\v 19 Jaun₂ ca₂ŋag₃ Jesús: 
\p ―¿Lé₂ le₃jme₃'ɨn₅₄ juɨ₁lia'₂ dsa₂ i₂té₄ ja₁niog₅ jmɨg₄ ja₁jen'₂ gu₂ dsa₂, të₁lia'₂ quiong'₅₄ dsa₂ ŋe'₂ i₂jén'₂ gu₂? Ma₁ tsá₃ le₂jaun₂ jmo₅ dsa₂, të₁lia'₂ quiong'₅₄ 'éi₂.  
\v 20 La₁ jiá₃ caun₂ jmɨg₄ a₂jŋia'₃ dsa₂ i₂jén'₂ gu₂ 'éi₂. Jaun₂ guë́₄ lé₂ le₃jme₃'ɨin₅₄. 
\p  
\v 21 ’Ma₁ tsá₃ jmo₅ dsa₂ jua'₅₄ a₂tióng₅ quian'₅₄ 'nau₅₄ 'mɨ'₂ 'mɨ́₂ tsɨ₁'mɨ'₂ gui'₅₄, ia₁ dsáu'₅ tsɨ₁'mɨ'₂ 'mɨ́₂ jë₁ma₂jŋɨ₂. Jaun₂ juë'₂ guë́₄ jë₁gag₂ lë́₂ tsɨ₁'mɨ'₂ gui'₅₄.  
\v 22 On₃ guë́₄ jmo₅ dsa₂ jua'₅₄ a₂tia'₂ vino 'mɨ́₂ 'ŋió'₃ nɨ₁lau₂ gui'₅₄. Ia₁ guéi₃ nɨ₁lau₂ gui'₅₄ quian'₅₄ dsió'₁ vino 'mɨ́₂. Dsɨ₂'én₂ bá₄ vino, lia'₂ nɨ₁lau₂ në́₃. Jaun₂ 'ŋió'₃ nɨ₁lau₂ 'mɨ́₂ bá₄ 'nió'₅ tia'₃ dsa₂ vino 'mɨ́₂ ia₁jaun₂ tsá₃ dsɨ₃'én₂. 
\s1 Ca₂gág₃ dsa₂ quián₅ Jesús mɨ́'₂ trigo jmɨg₄ sa₅₄ 
\r (Mateo 12:1-8; Lucas 6:1-5) 
\p  
\v 23 Caun₂ jmɨg₄ sa₅₄ ca₂ŋɨ₅ Jesús quiain'₅₄ dsa₂ quiáin₅ caun₂ ja₁nau₂ ja₁jnia₄ trigo. Dsa₂ i₂jme₁quiain'₅₄ në́₃ ca₂jme₃lióg₃ qui₂ca₂gág₃ mɨ́'₂ trigo jme₁ca₂ŋɨi₅ ja₁jaun₂.  
\v 24 Jaun₂ në́₃, ca₂juá'₂ dsa₂ fariseos: 
\p ―¿'E₂ lë₃ jmo₅ dsa₂ i₂quiang'₅₄ ta₁ a₂tsá₃ 'i₄ 'éi'₃ jmo₃ jmɨg₄ sa₅₄? 
\p  
\v 25 Jaun₂ ca₂ŋag₃ Jesús: 
\p ―¿Tsa₁ ma₂'í'₂ 'nia'₂ 'i₁cón'₂ a₂ca₂jmo₃ David ma₂lɨ́g'₂ quian'₅₄ rɨin'₅₄ lia'₂ con'₂ jme₁ca₂rë₃'ɨ́n₂ quió'₅, a₂ca₂lë₃ i₁cón'₅?\f + \fr 2:25 \ft 'Nio'₂ ja₁ton₅ 1 Samuel 21:6.\f* 
\v 26 Ca₂'í₃ David dsi₂néi₂ quió'₅ Diú₄, lia'₂ con'₂ jme₁lɨ́n₄ Abiatar juɨg₅₄ jme₂dsa₂. Ca₂guë́'₃ i₁ŋí'₄ jŋió₅ a₂'i₄ 'éi'₃ a₂guë́'₅ jmá'₃ jme₂dsa₂. Jaun₂ ca₂cuë́'₃ dsa₂ i₂jme₁quiain'₅₄ në́₃. 
\p  
\v 27 Ján₃ bá₄ ca₂juá'₂ Jesús ca₂tsɨ́'₃ dsa₂: 
\p ―O₄quió'₄ dsa₂ mɨ₂güɨ́g₃ bá₄ ca₂lë₃ jmɨg₄ sa₅₄, on₃jua'₅₄ rë'₂ o₄quió'₄ jmɨg₄ sa₅₄ ca₂jmó'₂ Diú₄ dsa₂ mɨ₂güɨ́g₃.  
\v 28 Jaun₂ lë₃, Jaun₅ dsa₂ mɨ₂güɨ́g₃ bá₄ i₂'io₅ 'éi'₃ ne₄ quió'₅ jmɨg₄ sa₅₄. 
\c 3  
\s1 Jan₂ dsa₂ i₂'lia'₂ caun₂ mɨ₂gu₂ 
\r (Mateo 12:9-14; Lucas 6:6-11) 
\p  
\v 1 Con'₂ siá'₂ táng₃ ca₂'í₃ Jesús guá'₅ sinagoga. Ja₁jaun₂ jme₁'en₅₄ jan₂ dsa₂ i₂'lia'₂ caun₂ mɨ₂gu₂.  
\v 2 Jaun₂ ca₂tiog₃ dsa₂ ca₂tiain₃ Jesús, o₁ne₄ chi₂jua'₂ jme₃'lióin₂ dsa₂ 'éi₂, të₃ jmɨg₄ sa₅₄, ia₁jaun₂ chain₂ bí₂ a₂bóin'₂ dso₄ Jesús.  
\v 3 Jaun₂ ca₂tsɨ́'₃ Jesús dsa₂ i₂'lia'₂ mɨ₂gu₂: 
\p ―Ŋia₅, dsi₂jo₂ la₂ nau₂. 
\p  
\v 4 Jaun₂ ca₂ŋag₃ Jesús ca₂ŋɨ́i'₃ dsa₂ i₂tion'₅₄ jág₅: 
\p ―Juɨ₁lia'₂ jmɨg₄ sa₅₄, ¿'e₂ 'i₄ 'éi'₃ jmo₃ dsa₂? ¿A₁dse₃, o₃ a₂'lɨg'₅₄ 'e₂? ¿A₂lión₂ dsa₂ jme₂dsí₂ rɨin'₅₄, o₃ a₂jŋɨ'₃ dsa₂ rɨin'₅₄ 'e₂? 
\p Jaun₂ jŋia'₅₄ lë₁tión₂ tei₄ le₂jaun₂ bá₄ dsa₂.  
\v 5 Jaun₂ 'ne₂ Jesús ca₂jɨ́in₂ dsa₂ i₂tion'₅₄, co₂'na₂ guë'₂ quɨ'₂ dsɨ́₅, ia₁ a₂ŋɨ́₄ lë₃ tsá₃ ŋɨ́'₂ dsɨ́₅ dsa₂. Jaun₂ ca₂tsɨ́'₃ dsa₂ dso'₅₄: 
\p ―Nei'₅₄ gog'₂. 
\p Jaun₂ ca₂néi'₃ 'éi₂ gu₂; ca₂lág₃ bá₄ jaun₂ në́₃.  
\v 6 Dsɨ₂juɨ₅ le₂jaun₂ ca₂'uɨn₂ dsa₂ fariseos ca₂i₁jmo₅₄ jág₁ quian'₅₄ dsa₂ quián₅ Herodes a₂jŋɨi'₃ Jesús. 
\s1 Juɨn₅ dsa₂ tion'₅₄ chei'₅₄ jmɨg₂ 
\p  
\v 7 Jaun₂ ca₂ŋó₃ táng₃ Jesús juɨ₅ chei'₅₄ jmɨ₁ŋí'₄ quian'₅₄ dsa₂ i₂quiain'₅₄. Jaun₂ juɨn₅ lɨn₃ dsa₂ chan₂ Galilea ca₂jme₃quiong'₅₄ në́₃.  
\v 8 Jme₁ca₂rë₃ŋi₅ dsa₂ ca₂le₃jë́₃ 'e₂ a₂niog₅ lë́₂ a₂jmo₅ Jesús, ca₂o₃lén₂ juɨn₅ lɨn₃ dsa₂ chan₂ Judea, dsa₂ chan₂ Jerusalén, dsa₂ chan₂ Idumea, dsa₂ chan₂ le₂'ŋo'₅₄ Cuá₃ Jordán, dsa₂ chan₂ Tiro, dsa₂ chan₂ Sidón në́₃, a₂ca₂o₃jɨin₅₄ Jesús.  
\v 9 Jaun₂ ca₂tsɨ́'₃ Jesús dsa₂ quiáin₅, a₂jmo₃ co₂jŋia₅₄ caun₂ tsɨ₁mu₅, ia₁ con'₂ tsá₃ ŋó₅ në₁jua'₂ ca₂quɨ́in'₃ jɨn₄ dsa₂.  
\v 10 Ia₁ juɨn₅ lɨn₃ dsa₂ dso'₅₄ ma₂ca₂jme₃'lióin₂ le₂jŋiá₅. Jaun₂ në́₃, ca₂le₃jɨ́n₃ dsa₂ dso'₅₄ tioin'₅₄ co₂'liain'₂ rɨin'₅₄ ca₂lia'₂ qui₂co₂dsɨin₅₄ Jesús, ia₁ a₂'nio₃ qui₃nɨ́i'₃ quió'₅.  
\v 11 Jme₁ca₂jág₂ jme₂dsí₂ 'lɨn'₅₄ i₂tion'₅₄ të₂dsɨ́₅ dsa₂, jaun₂ ca₂chi₃jné₃, tioin'₅₄ co₂mɨ'₅₄, juá'₂: 
\p ―¡'Ne₂ lɨ́ng'₅ Ja₁ŋi'₅₄ Diú₄! 
\p  
\v 12 Jaun₂ lë₃ ca₂jmo₃ Jesús 'éi'₃ a₂tsá₃ jme₃jniog₂₃. 
\s1 Ca₂quión'₂ Jesús chi'₂ dsɨ₂guia₃-tɨ́n₂ 
\r (Mateo 10:1-4; Lucas 6:12-16) 
\p  
\v 13 Cang₂ jaun₂ ca₂i₃léin₂ caun₂ ja₁lë́₄ dsɨ₂con'₂. Ja₁jaun₂ ca₂quión'₂ Jesús dsa₂ i₂'nioi₃ jme₃quiong'₅₄. Jaun₂ ca₂o₃lén₂ 'éi₂ ja₁chéin'₄.  
\v 14 Jaun₂ ca₂'ɨin₃ guia₃-tɨ́n₂ dsa₂ 'éi₂, ia₁jaun₂ jme₃quiong'₅₄ ton'₂ ia₁jaun₂ chei₃ a₂dsɨ₃lén₂ 'éi₂ a₂qui₂dsɨ₃'ë́₃ jág₁,  
\v 15 ia₁jaun₂ 'io₃ 'éi₂ bí₂ ján₃\f + \fr 3:15 \ft A₂lɨn₅₄ chog₅₄ si₂ juá'₂ ján₃: “a₂jme₃'lióin₂ dsa₂ dso'₅₄.” \f* a₂le₃'uɨ́in'₂ je₂na'₅₄ dsɨ́₅ dsa₂.  
\v 16 I₂la₂ bá₄ dsa₂ i₂guia₃-tɨ́n₂ i₂ca₂'ɨn₃ Jesús: Si₂mu₅₄ i₂të́'₂ Jesús Pe₄;  
\v 17 Le₂on₃ ja₁ŋi'₅₄ Zebedeo: Jacobo quian'₅₄ Juan₅₄, i₂ca₂të́'₃ Jesús Boanerges, co₂'nió'₄ a₂juá'₂, jaun₅ ŋí'₃;  
\v 18 Drë́₄, Fe₂li₄, Bartolomé, Të₅₄, To₁má₄ në́₃; Jacobo ja₁ŋi'₅₄ Alfeo. Tadeo, Si₂mu₅₄ i₂lɨ́n₅ cananista;\f + \fr 3:18 \ft cananista: partido quió'₅ dsa₂ i₂'nio₃ táun₂ 'uë₃ 'éi'₃ quió'₅ Roma. Jma₃quén₅ ca₂quioin₃ le₃on₃ Si₂mu₅₄ 'éi₂, ia₁ ŋɨ́₄ lë₃ mei'₂ tsá₃ ca₂ne₅₄ a₂chein₂.\f* 
\v 19 Judas Iscariote në́₃, dsa₂ i₂ca₂jɨ́n'₂ Jesús. 
\s1 Juá'₂ dsa₂ a₂'io₅ Jesús juɨ₅bí₂ quió'₅ Be'elzebú 
\r (Mateo 12:22-32; Lucas 11:14-23; 12:10) 
\p Jaun₂ ca₂dsián'₃ Jesús jme₁ca₂dsiáin'₃ caun₂ dsi₂néi₂.  
\v 20 Con'₂ guë'₂ siá'₂, ca₂ŋɨ'₂ táng₃ dsa₂ juɨn₅ lɨn₃, jŋia'₅₄ tsá₃ jɨin₅₄ guë́'₃ quiain'₅₄ chi'₂ dsɨ₂guia₃-tɨ́n₂.  
\v 21 Jme₁ca₂rë₃ŋi₅ o₁rɨin'₅₄, jaun₂ ca₂o₃léin₂ a₂jme₁tsáun'₂ të₂, ia₁ 'ei₅ jág₁ a₂lë₁ma₂të₂'ɨ₂₃ ŋɨ₂₃. 
\p  
\v 22 Ján₃ bá₄ le₂jaun₂ të₅juá'₅ i₂ja₂lén₂ Jerusalén, ca₂juá'₂: 
\p ―Quian₅ dsa₂ në₅ Be'elzebú, i₂lɨ́n₅ juɨg₅₄ je₂na'₅₄. A₂jaun₂ bá₄ quɨ'₅₄ jmɨg₄ 'uɨ́in'₂ je₂na'₅₄ tion'₅₄ dsɨ́₅ dsa₂. 
\p  
\v 23 Jaun₂ lë₃ ca₂të́'₃ Jesús të₅juá'₅ 'éi₂, jaun₂ ca₂juá'₂ të₂le₃ quian'₅₄ jág₁ a₂jáng'₅ léi₄: 
\p ―¿'A₂ lia'₂ le₃lé₂ jua'₅₄ jmo₃ Satanás a₂dsein₂₃ 'ŋiog₅ quió'₅ dsa₂?  
\v 24 Në₁jua'₂ co₂nió'₃ dsɨ₂tan₅₄ ca₂niói'₃ mɨ'₅₄ quiain'₅₄ rɨin'₅₄, dsɨ₂tan₅₄ 'éi₂ tsá₃ uë́₂ lé₂ le₃tóin'₃.  
\v 25 Në₁jua'₂ dsa₂ dsi₂néi₂ tioin'₅₄ mɨ'₅₄ quɨ́in'₂, ján₃ bá₄ le₂jaun₂ tsá₃ uë́₂ tió'₅.  
\v 26 Në₁jua'₂ ca₂dsia₃ Satanás 'nei₂ a₂jmo₃ le₁dsoin'₅₄ 'ŋiog₅, ján₃ bá₄ le₂jaun₂ tsá₃ uë́₂ 'oin₅₄ bí₂ quió'₅; ja₁jaun₂ ca₂dsan₃ bá₄ quió'₅ në₁jua'₂ le₂jaun₂. 
\p  
\v 27 ’'I₁jan₂ tsá₃ 'ein₂ lé₂ le₃'í₂ tion₅₄ dsi₂néi₂ quió'₅ juɨ₁lia'₂ jan₂ dsa₂ 'uan'₂, jua'₅₄ a₂jŋiá'₂ dsa₂ a₂te₁'i₁ quió'₅, jŋia'₅₄ lia'₂ a₂'nei'₂ bá₄ de'₂ jŋiá₅ dsa₂. Jaun₂ bá₄ lé₂ le₃jŋia'₃ a₂cha₂ quió'₅. 
\p  
\v 28 ’A₂dsɨ₂jó'₃ juá'₅ jniá₂, a₂lé₂ le₃'én₂ ca₂le₃jë́₃ bá₄ dsáu₁ dsa₂, ca₂le₃jë́₃ 'e₂ a₂'lɨg'₅₄ juá'₂ në́₃.  
\v 29 La₁ në₁jua'₂ ca₂juá'₂ 'lɨg'₅₄ 'ɨin₂₃ Jme₂dsí₂ Jŋió₅, tsá₃ ma₃a₁jaun₂ lé₂ le₃'én₂ dsáu₁. A₂rë₂cáin'₄ ca₂le₃jë́₃ jmɨg₄ chain₂ bá₄ jaun₂. 
\p  
\v 30 Le₂në₅ ca₂juá'₂ ia₁ dsia₅ dsa₂ 'ag₂₃ 'ein₅₄ jme₂dsí₂ 'lɨn'₅₄. 
\s1 Chi'₂ rɨn'₅₄ Jesús quian'₅₄ chog₅₄ 
\r (Mateo 12:46-50; Lucas 8:19-21) 
\p  
\v 31 Jaun₂ ca₂dsi₃lén₂ chi'₂ rɨn'₅₄ Jesús, quian'₅₄ chog₅₄ në́₃. La₁ ca₁'né₄ bá₄ ca₂tóin'₂. Jaun₂ ca₂chein₃ jág₁ a₂të́'₂ Jesús.  
\v 32 Jaun₂ ca₂juá'₂ dsa₂ i₂jme₁tián'₄ cau₅ quió'₅ Jesús: 
\p ―Chog'₂ quian'₅₄ chi'₂ rɨ́ng'₂, në₅ tiáin'₅ ca₁'né₄, a₂'nai'₂ 'ne₂. 
\p  
\v 33 Jaun₂ ca₂ŋag₃: 
\p ―¿'Ein₂ 'éi₂ lɨ́n₅ cha₃ jniá₂, rɨ́n'₃ jniá₂ në́₃? 
\p  
\v 34 Jaun₂ ca₂jɨ́in₂ dsa₂ i₂tián'₅ cau₅ quió'₅, jaun₂ ca₂juá'₂: 
\p ―¡Jag₄! I₂la₂ bá₄ lɨ́n₅ cha₃, rɨ́ng'₃ në́₃.  
\v 35 Ia₁ juɨ₁'ein₂ guë́₃ i₂jmo₅ a₂'ŋio₂ dsɨ́₅ Diú₄, i₂'éi₂ bá₄ lɨ́n₅ juɨ₁lia'₂ rɨ́ng'₃, cha₃ në́₃. 
\c 4  
\s1 Jág₁ jáng'₅ léi₄ juɨ₁lia'₂ dsa₂ i₂séi₂ mɨ́g₂ jon₂ 
\r (Mateo 13:1-9; Lucas 8:4-8) 
\p  
\v 1 Con'₂ siá'₂ táng₃, co₂ráun₂ ca₂jme₃lióg₃ Jesús ca₂jme₃tɨin₂₃ dsa₂ chei'₅₄ jmɨ₁ŋí'₄. Ia₁ juɨn₅ lɨn₃ dsa₂ ca₂lë₃ në́₃ ca₂ŋɨ'₂ ja₁chéin'₄, jaun₂ ca₂'í₃ 'ŋió'₃ tsɨ₁mu₅ 'ei₅ chei'₅₄ jmɨg₂; jaun₂ ja₁jaun₂ ca₂guá₂. Dsa₂ guë'₂ në́₃ ca₂tóin'₂ chei'₅₄ jmɨg₂.  
\v 2 'Lióng₂ jág₁ dse₃ ca₂jme₃tag₂₃ të₂le₃ quian'₅₄ jág₁ a₂jáng'₅ léi₄. Jë₄ juá'₅ quió'₅ a₂jme₂tag₂₃, ca₂juá'₂: 
\p  
\v 3 ―Nei₂ 'nia'₂: Jan₂ dsa₂ ca₂ŋe₄ ja₁nau₂ ca₂i₁séi₄ mɨ́g₂ jon₂.  
\v 4 Jme₁ma₂'ein₅₄ séi₂ në́₃, a₂lɨn₅₄ mɨ́g₂ jon₂ i₂ga'₅₄ le₂'i₄ juɨ₅. I₁tan₅ bá₄ ca₂dsi₃lén₂ ca₂cág'₃ a₂jaun₂.  
\v 5 A₂lɨn₅₄ guë'₂ mɨ́g₂ jon₂ táng₃, ca₂i₃to'₅₄ jë₄ nɨ₁cang₁, ja₁tsá₃ gua'₅₄ lɨn₄ cha₂. A₂jaun₂ në́₃ tsá₃ uë́₂ ca₂rë₃'ag₄, ca₂'ia₂, ia₁ tsá₃ jɨ'₂ gua'₅₄ ja₁i₃to'₅₄.  
\v 6 La₁ jme₁ca₂jnióg₃ 'iog₂ në́₃, ca₂rë₃juɨng₅ ca₂rë₃quéin₃ bá₄, ia₁ tsá₃ jmú₄ 'lióng₂ jme₁cha₂.  
\v 7 A₂lɨn₅₄ guë'₂ ca₂séi'₂ ja₁lë́₄ nɨ₁taun₅. Jme₁ca₂i₃cón₃ nɨ₁taun₅ në́₃, ca₂jlë₃ bá₄ a₂jaun₂, tsá₃ 'e₂ ca₂rau₂.  
\v 8 La₁ a₂lɨn₅₄ guë'₂ në́₃ ca₂tɨ́n₂ ja₁dse₃ 'uë₃. A₂jaun₂ ca₂rau₂ bá₄ dse₃. A₂lɨn₅₄ ca₂'ág₂ jma₃guióg₂-guiá₂ mɨ́g₂, lia'₂ ca₂mɨ́g₂ jon₂. A₂lɨn₅₄ guë'₂ jma₃'nag'₂ ne₂guióg₂ mɨ́g₂; a₂lɨn₅₄ guë'₂ jma₃caun₂ 'ŋiá₂-láu₂ mɨ́g₂. 
\p  
\v 9 Jaun₂ në́₃, ca₂juá'₂ Jesús: 
\p ―Ca₂le₃jɨ́n'₃ 'nia'₂ i₂le₁dsɨ₅₄ rë₂gua₄, rë₂ nei₂ 'nia'₂. 
\s1 Ta₁ quí'₅ jág₁ a₂jáng'₅ léi₄ 
\r (Mateo 13:10-17; Lucas 8:9-10) 
\p  
\v 10 Jme₁ma₂i₂len₃ dsa₂, jme₁ma₂të₁'ŋiái₄ quiain'₅₄ chi'₂ dsɨ₂guia₃-tɨ́n₂, quiain'₅₄ i₂lɨn₅₄ guë́₄ dsa₂ sián'₂, jaun₂ ca₂ŋag₃ 'éi₂ 'e₂ jág₁ dsau₅ jáng'₅ jág₁ jaun₂.  
\v 11 Jaun₂ ca₂juá'₂ Jesús: 
\p ―Diú₄ bá₄ jmo₅ a₂rë₂ŋɨ́'₂ 'au'₂ 'nia'₂ jág₁ a₂rë₂'ma₄ 'a₂ lia'₂ lë́₅ ja₁goin₂, la₁ dsa₂ i₂tsá₃ i₂nio₄ quian'₅₄ jniá₂ në́₃, 'nió'₅ juá'₂ dsa₂ të₂le₃ quian'₅₄ jág₁ a₂jáng'₅ léi₄: 
\q1  
\v 12 ia₁jaun₂ i₂në₂jág₃, 
\q2 la₁ tsá₃ ca₂rë₃lí'₄ 'e₂ në₂jág₃. 
\q1 I₂në₂néi₂ në́₃, 
\q2 la₁ tsá₃ ca₂rë₃lí'₄ 'e₂ në₂néi₂, 
\q2 on₃ guë'₂ ca₂ŋɨ́i'₂; 
\q1 con'₂ tsá₃ ŋó₅ në₁ca₂jéin'₃ dsɨ́₅, 
\q2 ia₁jaun₂ jme₁'lioin₁₂ jniá₂.\f + \fr 4:12 \ft Isaías 6:9-10.\f* 
\s1 Juá'₂ Jesús 'e₂ jág₁ dsau₅ jein₅ jág₁ juɨ₁lia'₂ dsa₂ i₂séi₂ mɨ́g₂ jon₂ 
\r (Mateo 13:18-23; Lucas 8:11-15) 
\p  
\v 13 Ca₂juá'₂ ján₃: 
\p ―¿Tsa₁ ŋɨ́'₂ 'nia'₂ jág₁ a₂jáng'₅ léi₄ në₅? ¿'A₂ bá₄ guë'₂ lé₂ le₃ŋɨ́'₂ 'nia'₂ juɨ₁lia'₂ jág₁ a₂jáng'₅ léi₄ siá'₂?  
\v 14 Juɨ₁lia'₂ lɨ́n₅ dsa₂ i₂séi₂ mɨ́g₂ jon₂, le₂jaun₂ bá₄ lɨ́n₅ juɨ₁lia'₂ dsa₂ i₂'ë́₂ jág₁ dse₃ quió'₅ Diú₄.  
\v 15 I₂lɨn₅₄ dsa₂ lɨ́in₅ juɨ₁lia'₂ mɨ́g₂ jon₂ a₂i₃ga'₅₄ le₂'i₄ juɨ₅. Nag₂₃ jág₁ dse₃, la₁ dsɨ₂juɨ₅ jaun₂ ja₂ Satanás jŋiá'₂ jág₁ a₂ma₂jnia₄ të₂dsɨ́₅ dsa₂.  
\v 16 I₂lɨn₅₄ guë'₂ dsa₂ lɨ́in₅ juɨ₁lia'₂ lë́₅ mɨ́g₂ jon₂ a₂i₃ga'₅₄ jë₄ nɨ₁cang₁. Nag₂₃, gue₂₃ jág₁ a₂'ŋio₂ dsɨ́₅.  
\v 17 La₁ia₁ tsá₃ uë́₂ tió'₅, ia₁ tsá₃ lɨn₄ jmú₄ cha₂ jua'₅₄ a₂chan'₂ tiá₂ jág₁. Jaun₂ jë₁ma₂ca₂can₃ o₂i₁ dsɨ₅, a₂co₂'ein₅ dsa₂ 'uɨg₅₄ jág₁ dse₃, dsɨ₂juɨ₅ bá₄ tí₂ táng₃ jág₁.  
\v 18 I₂sián'₂ guë'₂ në́₃ lɨ́n₅ co₂'nió'₄ mɨ́g₂ jon₂ a₂i₃ga'₅₄ jë₄ nɨ₁taun₅. Nag₂₃ jág₁ dse₃,  
\v 19 la₁ 'ŋio₅ guë́₄ 'ɨ₅ dsɨ́₅ o₂me'₅₄ dsɨ₅ a₂cha₂ mɨ₂güɨ́g₃ la₂; ne₄ 'uɨg₅₄ ia₁ a₂'ɨ́n₅ dsɨ́₅ juɨ₅ ja₁le₃cha₂ cu₄, ja₁në₅ bá₄ ja₁rë₂gain₂ táng₃; tsá₃ caun₂ a₂'ɨ́n₅ dsɨ́₅. Ca₂le₃jë́₃ a₂jaun₂ në́₃ jmo₅ jlë₅ jág₁ dse₃, tsá₃ ma₃cuë₂₃ jmɨg₄ a₂ráu₃.  
\v 20 La₁ i₂lɨn₅₄ guë́₄ në́₃ nag₂₃, gue₂₃ bá₄ jág₁, chan'₂ tiá₂. Lɨ́in₅ juɨ₁lia'₂ lë́₅ mɨ́g₂ jon₂ a₂i₃ga'₅₄ ja₁dse₃ gua'₅₄. 'Lióng₂ rau₂. I₂lɨn₅₄ guë'₂ lɨ́n₅ co₂'nió'₄ mɨ́g₂ a₂qui₂ca₂'ág₂ guióg₂-guiá₂; i₂lɨn₅₄ guë'₂ co₂'nió'₄ a₂qui₂ca₂'ág₂ 'nag'₂ ne₂guióg₂, o₃ caun₂ 'ŋiá₂-láu₂ mɨ́g₂ lia'₂ ca₂mɨ́g₂ mɨ́g₂ jon₂ a₂i₃jnia₄. 
\s1 Jág₁ jáng'₅ léi₄ juɨ₁lia'₂ nɨ₁tsɨ́₅ chi₁guí'₂ si₂ 
\r (Lucas 8:16-18) 
\p  
\v 21 Jaun₂ ca₂juá'₂ táng₃ Jesús: 
\p ―Në₁jua'₂ quian₅ dsa₂ caun₂ nɨ₁tsɨ́₅ a₂guí'₂ si₂, ¿'a₂ chi'₃? ¿né'₃ tsɨ₁mɨ'₂, o₃ né'₃ tsɨ₁cama? Jan₂'ón₄. A₂'ag₅ guei'₅₄ bá₄ dsa₂ si₂.  
\v 22 Ia₁ 'i₁caun₂ cosa tsá₃ cha₂ jua'₅₄ a₂lɨ́n₂ dsa₂ rë₂'ma₄, a₂tsá₃ le₃jniá₂; tion₅₄ bá₄ rë₂jniá₂. Ján₃ guë'₂ 'i₁caun₂ jág₁ tsá₃ cha₂ jua'₅₄ lɨ́n₂ dsa₂ a₂tsá₃ 'ein₂ le₃ŋi₅; tion₅₄ bá₄ rë₂ŋi₅ dsa₂.  
\v 23 Chi₂jua'₂ 'ein₂ dsi₅₄ rë₂gua₄, juɨ₁nei₅₄ rë₂. 
\p  
\v 24 Con'₂ siá'₂ táng₃ ca₂juá'₂ Jesús: 
\p ―Tion'₂ 'nia'₂ juɨ₅ 'e₂ a₂nag'₂. Quian'₅₄ 'éi'₃ a₂cau'₂ 'nia'₂ guiong'₅₄, 'éi'₃ jaun₂ bá₄ quióg₃ Diú₄ quián'₂ 'nia'₂ ján₃, jŋia'₅₄ të₂le₃ lë́₅ guë́₄.  
\v 25 Ia₁ juɨ₁lia'₂ dsa₂ i₂'ŋio₂ dsɨ́₅ le₃ŋɨ́i'₂, Diú₄ bá₄ jmo₃ le₃ŋɨ́i'₂ guë́₄ dse₃. La₁ i₂tsá₃ 'nio₃ le₃ŋɨ́'₂ në́₃, Diú₄ bá₄ jmo₃ a₂tsá₃ ma₃le₃ŋɨ́i'₂ co₂ŋei'₅₄.\f + \fr 4:25 \ft lit. “Ia₁ juɨ₁lia'₂ dsa₂ i₂cha₂ quió'₅, ŋei₂; la₁ i₂tsá₃ cha₂ quió'₅ në́₃, le₂jiog₅ a₂cha₂ quió'₅, jŋia'₃.” \f* 
\s1 Jág₁ jáng'₅ léi₄ juɨ₁lia'₂ 'a₂ lia'₂ 'ia₂ mɨ́g₂ jon₂ 
\p  
\v 26 Jaun₂ ca₂juá'₂ Jesús: 
\p ―Le₂jaun₂ bá₄ lë́₅ ja₁gon₂ Diú₄, juɨ₁lia'₂ lë́₅ quian'₅₄ dsa₂ i₂jne₅ 'e₂ jne₂₃.  
\v 27 Jë₁ma₂ca₂'ia₂, qui₂dsɨ₂cón₃ a₂jaun₂. La₁ juɨ₁lia'₂ dsa₂ i₂jne₅ 'éi₂ në́₃, o₁jŋia'₅₄ a₂'uë₂-jmɨ₂ güɨin₂, nau₂ në́₃, la₁ tsá₃ jaun₂ ŋi₅ 'a₂ lia'₂ lë́₂ a₂dsɨ₂cón₃.  
\v 28 'Uë₃ bá₄ lia'₂ lë́₅, jaun₂ bá₄ rau₂. Le₂'uɨg₅₄, tag₄ de'₂ jŋiá₅ 'ia₂; ŋó₅ jaun₂ 'ia₂ nɨ₁la₁, lë́₂ nɨ₁guein₂. Ŋó₅ jaun₂ lë́₂ nɨ₁cuɨg₂ lá₅ në́₃.  
\v 29 Jë₁ma₂ca₂ron₂, jaun₂ guë́₄ dsɨ₂'áun₂ dsa₂; ia₁ ca₂të́₂ jmɨg₄ a₂ca₂rau₂.\f + \fr 4:29 \ft lit. “'Uë₃ bá₄ lia'₂ lë́₅, jaun₂ bá₄ rau₂. Le₂'uɨg₅₄, tag₄ de'₂ jŋiá₅ 'ia₂; ŋó₅ jaun₂ 'ia₂ mɨ́'₂. Ŋó₅ jaun₂ tó'₅ mɨ́g₂ mɨ́'₂ trigo. Jë₁ma₂ca₂ron₂, jaun₂ guë́₄ dsɨ₂cag'₅₄ dsa₂ quian'₅₄ ŋí₁ hoz; ca₂të́₂ jmɨg₄ a₂ca₂rau₂.” \f* 
\s1 Jág₁ jáng'₅ léi₄ juɨ₁lia'₂ mɨ́g₂ jon₂ quió'₅ nɨ₁'ma₂ mostaza 
\r (Mateo 13:31-32; Lucas 13:18-19) 
\p  
\v 30 Con'₂ siá'₂ táng₃ ca₂juá'₂ Jesús. 
\p ―¿'A₂ lia'₂ lë́₅ ja₁gon₂ Diú₄, o₃ 'e₂ quian'₅₄ lé₂ le₃quɨn₃?  
\v 31 Lë́₅ juɨ₁lia'₂ lë́₅ mɨ́g₂ nɨ₁'ma₂ mostaza.\f + \fr 4:31 \ft mostaza: On₃jua'₅₄ mɨ₂jáng'₅ a₂cuɨ́'₅ dsa₂ go₄ jniog₄; caun₂ nɨ₁'ma₂ dsón'₂ jaun₂ a₂të́'₂ të₅sí₃ Brassica nigra.\f* Mɨ́g₂ jon₂ jaun₂ lë́₅ a₂pí'₁ guë́₄ 'ŋio₅ lɨn₃, lia'₂ con'₂ guë́₄ ca₂le₃jë́₃ jon₂ a₂jne₅ dsa₂.  
\v 32 Jë₁ma₂ca₂i₃jnia₄ në́₃, dsɨ₂cón₃ dsiog₅ lë́₂ caun₂ nɨ₁'ma₂ pa₁, ca₂lia'₂ qui₂rë₂já₂ nɨ₁gu'₂ quió'₅. Jaun₂ tian'₅ i₁tan₅ ja₁lë́₄ 'en'₂ quió'₅. 
\s1 Ta₁ a₂quí'₅ jág₁ a₂jáng'₅ léi₄ a₂ca₂jme₃tag₅ Jesús 
\r (Mateo 13:34-35) 
\p  
\v 33 Ca₂jme₃tɨn₅ Jesús dsa₂ jág₁ dse₃ të₂le₃ quian'₅₄ 'lióng₂ jág₁ a₂jáng'₅ léi₄ le₂në₅.  
\v 34 'I₁caun₂ jág₁ tsá₃ jme₁cuë₂₃ jua'₅₄ tsá₃ të₂le₃ quian'₅₄ jág₁ a₂jáng'₅ léi₄. La₁ jë₁ma₂të₁'ŋiái₄ con'₂ guioin₅₄ quiain'₅₄ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅, jme₁juá'₂ lia'₂ rë₂jiá₃ jág₁. 
\s1 Ca₂jmo₃ Jesús ca₂'ág₂ tei₄ jmɨ₁ŋí'₄, ca₂jŋia'₃ dsí₂ në́₃ 
\r (Mateo 8:23-27; Lucas 8:22-25) 
\p  
\v 35 Le₃ca₂nei₂ jmɨg₄ jaun₂ ca₂tsɨ́'₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅: 
\p ―Ma₃ le₃'ŋo'₅₄ jmɨ₁ŋí'₄ le₃ó₃. 
\p  
\v 36 Tion'₅₄ jaun₂ dsa₂ chei'₅₄ jmɨ₁ŋí'₄, ca₂ŋó₃ Jesús ca₂jiog₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ 'ŋió'₃ tsɨ₁mu₅ ja₁jme₁'ein₅₄ táun₂ jág₁. Ján₃ bá₄ i₂lé₂ guë́₄ tsɨ₁mu₅ siá'₂ quiong'₅₄, tion'₅₄ dsa₂.  
\v 37 Jme₁co₂lág₂ jaun₂ ca₂'ág₂ dsí₂ tiá₂ lɨn₃, jaun₂ qui₂ca₂jná'₃ jmɨg₂ 'ŋio₅ lɨn₃ ca₂lia'₂ ca₂i₃'a₄ jmɨg₂ 'ŋió'₃ tsɨ₁mu₅, jŋia'₅₄ mei'₂ tsá₃ ca₂can'₂.  
\v 38 Jme₁rë₂güɨ́n₃ bá₄ Jesús ŋó₃ le₃chi₁co'₅₄ rë₂dsɨn₅ 'mɨ'₂ dsi₅₄. Jaun₂ ca₂ŋei₃ dsa₂, ca₂juá'₂: 
\p ―¡Të₅! ¿Tsa₁ dsan₂ 'au'₂ jua'₂ dsɨ₃'éin₂ jnia'₅₄ ja₁lá₃? 
\p  
\v 39 Ca₂nau₂ Jesús jaun₂ në́₃, ca₂jéin₂ dsí₂, ca₂jéin₂ jmɨ₁ŋí'₄ në́₃, ca₂juá'₂: 
\p ―¡Jme₁'ua₅₄! ¡Tei₄ jmo₄! 
\p Jaun₂ dsɨ₂juɨ₅ jaun₂ bá₄ ca₂'ág₂ táng₃ tei₄ jmɨ₁ŋí'₄, dsí₂ në́₃ ca₂jŋia'₃.  
\v 40 Jaun₂ ca₂juá'₂ Jesús ca₂tsɨ́'₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅: 
\p ―¿'E₂ lë₃ ŋɨ́₄ 'ŋio₅ gan'₃ 'nia'₂? ¿'A₂ bá₄ lia'₂ ŋɨ́₄ tsá₃ rë₂'én'₂ 'nia'₂? 
\p  
\v 41 Jaun₂ i₃gó'₃ dsɨ́₅ 'ŋio₅ lɨn₃, qui₂ca₂tsɨ́'₃ rɨin'₅₄: 
\p ―¿'Ein₂ bá₄ lɨ́n₅ i₂në₅ ca₂të₂ jmɨ₁ŋí'₄, ca₂të₂ dsí₂ në́₃ qui₂nag₅ gau₂ jág₁ quió'₅? 
\c 5  
\s1 Jan₂ dsa₂ i₂'en₅₄ jme₂dsí₂ 'lɨn'₅₄ 
\r (Mateo 8:28-34; Lucas 8:26-39) 
\p  
\v 1 Jaun₂ dsi₃léin₂ jme₁dsi₃léin₂ 'ŋo'₅₄ jmɨ₁ŋí'₄, go₄ dsa₂ Gadarenos.\f + \fr 5:1 \ft A₂lɨn₅₄ chog₅₄ si₂ juá'₂: “'uë₃ Gerasa.” \f* 
\v 2 Jaun₂ dsɨ₂juɨ₅ jme₁ca₂o₃'ɨ́n₃ Jesús 'ŋió'₃ tsɨ₁mu₅, dsióg₃ jan₂ dsa₂ i₂o₂'ɨ́n₃ ja₁le₁'on₅ 'lag₄, dsa₂ i₂'en₅₄ jme₂dsí₂ 'lɨn'₅₄ dsɨ́₅.  
\v 3 Jme₁guá₄ dsa₂ 'éi₂ jë₄ tau₂ 'ŋio₅; jaun₂ tsá₃ ma₃'ein₂ jme₁quɨ'₅₄ jmɨg₄ tió'₅ 'nei'₂ quian'₅₄ ŋí₁ cadena,  
\v 4 ia₁ 'lióng₂ ráun₂ jme₁ma₂'nei'₂ dsa₂ le₂jŋiá₅, jme₁ma₂tó'₂ dsa₂ cadena mɨ₂tag₅₄, mɨ₂gu₂ në́₃. La₁ jë₂ bá₄ jŋia'₅₄ ma₂gág₃; ma₂juɨin₃ nɨ₁ŋí₁ jme₁chi₁quɨ́'₅ mɨ₂tag₅₄ në́₃. Jaun₂ 'i₁jan₂ tsá₃ ma₃'ein₂ jme₁tio₃.  
\v 5 Jaun₂ në́₃, jme₁i₂ŋɨ₅₄ lia'₂ 'uë₂-jmɨ₂ dsɨ₂guio'₂ ja₁le₁'on₅ 'lag₄ lia'₂ juɨ₅ má'₂ në́₃, qui₂jmái'₂ uɨg₅ 'ŋiog₅ qui₂uɨng₂ quió'₅ quian'₅₄ nɨ₁cang₁.  
\v 6 La₁ jme₁ca₂jɨ́in₂ Jesús já₅ uɨ́ng₂, ŋó₃ jaun₂ në́₃ co₂chi'₅₄ le₃ne₄ ja₁ŋó₄ Jesús, jaun₂ ca₂chi₃jné₃.  
\v 7 Jaun₂ ca₂'í₃ co₂mɨ'₅₄ ca₂juá'₂: 
\p ―¿'E₂ lë₃ tián'₅ 'ne₂ jë₄ quió₃ jniá₂, 'ne₂ Jesús Ja₁ŋi'₅₄ Diú₄ juɨn'₂? Ca₂Diú₄, jnag₅₄, mɨ₅ jniá₂ ne'₅₄ tsá₃ lë₁'ë́₅ uɨg₅. 
\p  
\v 8 Ca₂juá'₂ le₂në₅, ia₁ jme₁ma₂në₂chí'₃ Jesús jme₂dsí₂ 'lɨn'₅₄, ca₂juá'₂: “¡Jú₅ quió'₅ dsa₂ në₅, 'ne₂ jme₂dsí₂ 'lɨn'₅₄!” 
\p  
\v 9 Jaun₂ ca₂ŋag₃ Jesús: 
\p ―¿'A₂ lia'₂ cheng'₂? 
\p Jaun₂ ca₂ŋag₃: 
\p ―Juɨn₅\f + \fr 5:9 \ft griego: legión\f* bá₄ cheng₂, ia₁ a₂juag₅ jnia'₅₄ lë́₂. 
\p  
\v 10 Jaun₂ ca₂mɨ₃ tion₅₄-jan₃ ne₄ Jesús a₂tsá₃ chein₂ jme₂dsí₂ 'lɨn'₅₄ ja₁siá'₂.  
\v 11 Ia₁ jme₁tion'₅₄ juɨn₅ i₁ŋí₅, guë́'₅ quián₅ 'uɨg₅₄ má'₂,  
\v 12 jaun₂ qui₂ca₂mɨ₃ i₂'lɨn'₅₄ ne₄ Jesús, ca₂juá'₂: 
\p ―Chei₅ jnia'₅₄ ja₁tion'₅₄ i₁ŋí₅, jaun₂ dsɨ₁tió'₄ jnia'₅₄ quió'₅ 'éi₂. 
\p  
\v 13 Jaun₂ ca₂cuë₃ bá₄ Jesús jmɨg₄. Jaun₂ ca₂'uɨin₂ ca₂i₃léin₂ i₃toin'₅₄ quió'₅ i₁ŋí₅. Jme₁lë́₂ con'₂ tɨn₃ mei₅ i₁ŋí₅ jme₁tion'₅₄. Ca₂le₃jɨ́n₃ 'éi₂ ca₂i₁nioi₁₂ co₂chi'₅₄ cuɨng₂₃ ca₂sein₃ siá₅ i₃toin'₅₄ jmɨ₁ŋí'₄, ca₂dsain₃. 
\p  
\v 14 Jaun₂ ca₂i₃len₃ dsa₂ i₂jme₁jmo₅ 'í₁ cuɨng₂₃ ca₂i₁chi'₄ dsa₂ jë₄ juɨg₂, quian'₅₄ i₂tion'₅₄ ja₁nau₂ në́₃. Jaun₂ i₃lén₂ dsa₂ i₁jag₅₄ 'e₂ ca₂lë₃ ja₁jaun₂.  
\v 15 Jme₁ca₂o₃léin₂ ja₁'en₅₄ Jesús, ca₂jɨ́in₂ dsa₂ i₂jme₁tion'₅₄ juɨn₅ jme₂dsí₂ je₂na'₅₄ quió'₅. Jaun₂ ma₂guá₅ ma₂qui'₂ tsɨn'₅₄, ma₂'en₅₄ bá₄ dsɨ́₅. Tioin'₅₄ ca₂jág₂ dsɨ₂gó'₃ dsɨ́₅.  
\v 16 Jaun₂ dsa₂ i₂ca₂jág₃ ca₂dsia₃ 'e₂ ca₂lë₃ quian'₅₄ dsa₂ i₂jme₁tion'₅₄ je₂na'₅₄ quió'₅, 'e₂ ca₂lë₃ quian'₅₄ i₁ŋí₅ në́₃.  
\v 17 Jaun₂ ca₂jme₃lióg₃ qui₂ca₂mɨ₃ tion₅₄ ne₄ Jesús a₂o₃'ɨin₅ 'uë₃ go₅₄. 
\p  
\v 18 Jme₁ma₂ŋó₅ Jesús 'í₂ tsɨ₁mu₅, jaun₂ jme₁mɨ₅ dsa₂ i₂jme₁tion'₅₄ je₂na'₅₄ quió'₅, jme₁mɨ₂₃ jág₁ ne₄ Jesús a₂dsó₃ quiong'₅₄.  
\v 19 La₁ tsá₃ ca₂cuë₃ 'éi₂ jmɨg₄. Jaun₂ ca₂tsɨ́'₃ dsa₂ 'éi₂: 
\p ―Guan'₂ ja₁quiáng'₂, ja₁tián'₄ rɨ́ng'₂, o₂dsia₄ ca₂le₃jë́₃ 'e₂ në₂jmo₃ Te₁gui'₅₄ o₄quiáng'₂, 'a₂ lia'₂ në₂dsia₃ ŋéi₂ dsɨ́₅. 
\p  
\v 20 Jaun₂ ŋá'₃ bá₄ dsa₂ 'éi₂ dsi₂néi₂ quió'₅, jaun₂ ca₂jme₃lióg₃ ca₂i₁dsia₂ jë₄ juɨg₂ tén₅ Decápolis ca₂le₃jë́₃ 'e₂ ca₂jmo₃ Jesús o₄quió'₄. Ca₂le₃jɨ́n₃ dsa₂ i₂ca₂nág₂ ca₂i₃gó'₃ dsɨ́₅. 
\s1 Ja₁mɨ́g₄ Jairo, quian'₅₄ 'io₅₄ i₂ca₂nɨ́'₃ tsɨn'₅₄ Jesús 
\r (Mateo 9:18-26; Lucas 8:40-56) 
\p  
\v 21 Jme₁ca₂dsián'₃ táng₃ Jesús le₃'ŋo'₅₄ jmɨ₁ŋí'₄ quian'₅₄ tsɨ₁mu₅, juɨn₅ lɨn₃ dsa₂ i₂ca₂dsi₃lén₂ táng₃ jme₁dsiáin'₃. Të₁lia'₂ 'ŋɨ₂₃ chei'₅₄ jmɨg₂,  
\v 22 jaun₂ ca₂dsióg₃ jan₂ dsa₂ i₂niog₅ gu₂ guá'₅ sinagoga, i₂chen₂ Jairo. Jme₁ca₂jɨ́in₂ Jesús, jaun₂ ca₂chi₃jné₃ ne₄ 'éi₂.  
\v 23 Ca₂mɨ₃ ca₂juá'₂: 
\p ―Ma₂i₁jón₂ jan₂ chi'₂ quiáng₃. ¿Tsa₁ gog'₅₄ o₁jɨin'₁ o₁quiog'₂ gog'₂ ne₄ quió'₅, jaun₂ 'lióin₂, le₃chain₂? 
\p  
\v 24 Jaun₂ në́₃ ca₂ŋó₃ Jesús quiong'₅₄; juɨn₅ lɨn₃ guë́₄ dsa₂ sián'₂ i₃lén₂ ca₂lia'₂ co₂'liain'₂ bá₄ Jesús.  
\v 25 Jë₄ jaun₂, ŋó₃ jan₂ 'io₅₄ i₂ma₂të́₂ guia₃-tɨ́n₂ ŋi₂ a₂dso'₅₄ a₂tɨin₂.  
\v 26 'Lióng₂ a₂ma₂i₃ŋɨ́i₂ o₄gú₃ juɨn₅ të₅mɨ́₅; jme₁ma₂'éin₂ ca₂le₃jë́₃ cu₄ a₂jme₁cha₂ quió'₅. La₁ tsá₃ 'e₂ ta₁ jmo₃, ia₁ të₂le₃ ca₂i₃ja₃ bá₄ quió'₅.  
\v 27 La₁ jme₁ca₂nág₂ a₂'ɨn₅ dsa₂ Jesús, jaun₂ ŋó₃ ca₂jme₃quiáin₃ le₃ja₁ŋó₄ 'éi₂, jɨn₄ dsa₂. Jme₁ca₂dsióg₃ cau₅ quió'₅ Jesús në́₃, jaun₂ ca₂nɨ́i'₃ nɨ₁tsɨn'₅₄ 'éi₂.  
\v 28 Ia₁ lɨ́in₂: “Tsá₃ a₂nag₅₄ a₂jŋia'₅₄ nɨ́g'₄ ca₂juɨg₄ tsɨn'₅₄, jŋia₃ quió₃.”  
\v 29 Co₂tan₅₄ dsɨ₂juɨ₅ le₂jaun₂ bá₄ ca₂'ná₂ tein₂₃ jmɨ₂, ca₂rë₃lí'₄ ca₂'lóin₂ dso₄ quió'₅.  
\v 30 Jaun₂ dsɨ₂juɨ₅ bá₄ ca₂rë₃lí'₄ Jesús a₂o₃'ág₃ bí₂ quió'₅. Jaun₂ ca₂jéin'₃ jɨn₄ dsa₂, ca₂ŋag₃: 
\p ―¿'Ein₂ bá₄ në₂nɨ́'₃ tsɨ́n'₅? 
\p  
\v 31 Jaun₂ ca₂ŋag₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅: 
\p ―Jua'₂ jág'₂ bá₄ 'ne₂ 'a₂ lia'₂ co₂'liog'₂ dsa₂ ja₂léin₂. ¿'E₂ lë₃ juá'₂ “'ein₂ në₂nɨ́'₃ quió₃?” 
\p  
\v 32 La₁ qui₂ja₂né₂ Jesús jɨn₄ dsa₂ a₂'nai'₂ 'ein₂ në₂nɨ́'₃ quió'₅.  
\v 33 'Io₅₄ 'éi₂ në́₃ ma₂jlein₂₃ bá₄ chéin'₅ gó'₅, ia₁ ŋi₅ bá₄ 'e₂ ma₂i₂ŋɨ́i₂. Ca₂ŋó₃ co₂ŋei'₅₄ ne₄ Jesús, ca₂chi₃jné₃, ca₂juá'₂ ca₂le₃jë́₃ lia'₂ tí₅ jág₁ dsón'₂.  
\v 34 Jesús në́₃ ca₂juá'₂: 
\p ―Jón₃, ia₁ 'éng'₂, ca₂'lóng'₂ bá₄. Guan'₂ tei₄ quiáng'₂. Co₂në₅ ca₂jŋia₃ dso₄ quiáng'₂. 
\p  
\v 35 Të₃ dsia₅ bá₄ guë́₄ Jesús jág₁ jaun₂ jme₁ca₂dsi₃lén₂ dsa₂ i₂tion'₅₄ ja₁quió'₄ Jairo i₂lɨ́n₅ ta₁ quió'₅ guá'₅ 'éi₂. Jaun₂ ca₂juá'₂ tsɨ́₅ Jairo: 
\p ―Ma₂ca₂jon₃ bá₄ ja₁mɨ́g'₄. ¿'E₂ ta₁ ma₂cuë'₂ o₂me'₅₄ dsɨ₅ të₅? 
\p  
\v 36 La₁ tsá₃ ca₂tón'₃ Jesús juɨ₅ jág₁ quió'₅ dsa₂ 'éi₂, jaun₂ ca₂tsɨ́'₃ Jairo: 
\p ―Tsá₃ lë₁jmo₂ gang'₃; jŋia'₅₄ lia'₂ 'én₃ bá₄. 
\p  
\v 37 Tsá₃ ca₂cuë₃ jmɨg₄ Jesús a₂dsɨ₃lén₂ juɨn₅ dsa₂ quiong'₅₄. Jŋia'₅₄ lia'₂ Pe₄, Jacobo, quian'₅₄ Juan₅₄ rɨin'₅₄ bá₄ i₃lén₂.  
\v 38 Jme₁ca₂dsi₃léin₂ ja₁quió'₄ Jairo, ca₂jág₃ tion'₅₄ dsa₂ go₂'i₃ quɨ'₂-'o₂₃ co₂mɨ'₅₄, 'lia'₂ dsɨ́₅.  
\v 39 Ca₂'í₃ Jesús dsi₂néi₂, ca₂juá'₂: 
\p ―¿'E₂ lë₃ ŋɨ́₄ lë₃ tó'₂ 'nia'₂ mɨ'₅₄, 'au'₂ 'nia'₂ le₂në₅? Tsá₃ rë₂jon₅₄ guein₂ në₅. Jŋia'₅₄ lia'₂ a₂rë₂güɨ́in₃ bá₄. 
\p  
\v 40 La₁ jŋia'₅₄ ca₂ŋɨ́₂ bá₄ dsa₂ Jesús tioin'₅₄. Jaun₂ në́₃ ca₂'uɨ́n'₂ Jesús ca₂le₃jɨ́n₃ dsa₂ 'éi₂ ca₁'né₄. Jaun₂ ca₂jŋiai₃ chog₅₄-jmei₂ 'lag₄, dsa₂ ún₂ i₂jme₁quiain'₅₄ në́₃. Ca₂i₃toin'₅₄ ja₁rë₂quian₅ guein₂ 'lag₄.  
\v 41 Jaun₂ ca₂jŋa'₃ gu₂ i₂bë'₅₄, jaun₂ ca₂juá'₂: 
\p ―Talita, cumi ―co₂'nió'₄ a₂juá'₂: 'Io₅₄ bë'₅₄, 'ne₂ juɨ́g₂ jniá₂, nau₂. 
\p  
\v 42 Dsɨ₂juɨ₅ le₂jaun₂ bá₄ ca₂nau₂, ca₂ŋɨ₃. Jme₁ma₂'ein₅₄ guia₃-tɨ́n₂ ŋi₂. Jaun₂ ca₂i₃gó'₃ dsɨ́₅ tioin'₅₄.  
\v 43 La₁ Jesús në́₃ ca₂jmo₃ 'éi'₃ a₂tsá₃ 'ein₂ tsɨ́'₃ 'i₁jan₂. Jaun₂ ca₂juá'₂ a₂cuë₃ dsa₂ a₂guë́'₃ i₂bë'₅₄ 'éi₂. 
\c 6  
\s1 Ca₂dsián'₃ Jesús juɨg₂ Nazaret go₅₄ ja₁tsá₃ ca₂guei₃ dsa₂ 
\r (Mateo 13:53-58; Lucas 4:16-30) 
\p  
\v 1 Jaun₂ ca₂o₃'ɨ́n₃ bá₄ Jesús ja₁jaun₂. Jaun₂ ca₂dsiáin'₃ táng₃ juɨg₂ go₅₄ quiain'₅₄ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅.  
\v 2 Jme₁ca₂të́₂ jmɨg₄ sa₅₄, jaun₂ ca₂jme₃lióg₃ ca₂jme₃tɨin₂₃ dsa₂ dsi₂néi₂ guá'₅ sinagoga. Juɨn₅ bá₄ dsa₂ i₂ca₂nág₂ dsɨ₂gó'₃ dsɨ́₅, jaun₂ ca₂tsɨ́'₃ rɨin'₅₄: 
\p ―¿A₂já'₄ ca₂i₁jme₁tɨn₅ i₂në₅ jág₁ ca'₅₄ a₂juá'₂ në₅? ¿I₂'e₂ bá₄ jág₁ a₂ŋɨ́'₂ dsɨ́₅ a₂ma₂ŋɨi₂ në₅, ca₂të₂ léi₄ juë'₂ në́₃ tɨin₂ jmo₃?  
\v 3 ¿On₁jua'₅₄ i₂në₅ të₅'má₃ ja₁ŋi'₅₄ María, dsó₂ rɨn'₅₄ Jacobo, quian'₅₄ José, quian'₅₄ Judas, quian'₅₄ Si₂mu₅₄ në́₃? Në₅ bá₄ tián'₅ 'io₅₄ rɨin'₅₄ ja₁lá₃ ján₃. 
\p Jaun₂ tsá₃ ca₂rë₃jei₅₄ dsa₂ ja₁jaun₂.  
\v 4 Jaun₂ ca₂juá'₂ Jesús: 
\p ―Ca₂le₂con₂ bá₄ ja₁siá'₂ guen₅ dsa₂ dsa₂ i₂'ë́₂ jág₁ quián₅ Diú₄. Jŋia'₅₄ lia'₂ dsa₂ go₅₄ bá₄ tsá₃ guei₅, on₃ guë'₂ o₁rɨin'₅₄, on₃ guë'₂ rɨin'₅₄ dsi₂néi₂ në́₃. 
\p  
\v 5 Jaun₂ tsá₃ 'lióng₂ léi₄ juë'₂ lé₂ le₃jmo₃ juɨg₂ go₅₄. Jŋia'₅₄ lia'₂ i₂lɨn₅₄ bá₄ dsa₂ dso'₅₄ ca₂dsia₃ gu₂, jaun₂ ca₂jme₃'lió₂.  
\v 6 Jaun₂ i₃gó'₃ dsɨ́₅ ia₁ a₂ŋɨ́₄ lë₃ tsá₃ 'e₂ 'én₂ dsa₂. 
\s1 Ca₂chen₃ Jesús dsa₂ guia₃-tɨ́n₂ quiáin₅ ca₂i₁'ë́₄ jág₁ dse₃ juɨg₂ siá'₂ 
\r (Mateo 10:5-15; Lucas 9:1-6) 
\p  
\v 7 Jaun₂ ca₂të́'₃ chi'₂ dsɨ₂guia₃-tɨ́n₂, jaun₂ ca₂chei₃ jma₃on₃ jma₃on₃. Ca₂cuë₃ bí₂ 'éi'₃ a₂'uɨ́n'₂ 'éi₂ jme₂dsí₂ 'lɨn'₅₄ quió'₅ dsa₂.  
\v 8 Jaun₂ ca₂tsɨ́'₃ 'éi₂ a₂tsá₃ 'e₂ cán₂ 'i₁caun₂ le₁'i₄ juɨ₅, jŋia'₅₄ lia'₂ jma₃cáun₃ 'ma₂'ɨ₅₄ bá₄. 'I₁caun₂ a₂siá'₂ tsá₃ cán₂, on₃ guë'₂ të₂'mɨ'₂, on₃ guë'₂ i₁ŋí'₄, on₃ guë'₂ cu₄ 'ŋió'₃ nɨ₁lau₂ le₁jén'₅ tú'₅ në́₃.  
\v 9 Jŋia'₅₄ lia'₂ jma₃co₂dsán'₃ nɨ₁lau₂ con'₂ a₂ma₂le₁ton₅ tag₅₄ bá₄ cán₂, ton'₂ tsá₃ cán₂ tɨn₃ dsán'₃ tsɨn'₅₄ në́₃.  
\v 10 Jaun₂ ca₂juá'₂ në́₃: 
\p ―Jë₁ma₂të́₂ rë₁tón'₄ 'nia'₂ lia'₂ caun₂ dsi₂néi₂ quió'₅ dsa₂ ja₁o₁nóg'₅, ja₁jaun₂ jŋia₄ 'nia'₂ ca₂lia'₂ ca₂të́₂ jmɨg₄ i₁'uɨ́n'₃ 'nia'₂ táng₃ juɨg₂ jaun₂.  
\v 11 Në₁jua'₂ cha₂ ja₁lɨn₅₄ tsá₃ guei₅ dsa₂, on₃ guë'₂ 'nio₃ dsa₂ nag₃ jág₁ quián'₂ 'nia'₂, 'uɨn'₂ 'nia'₂ ja₁jaun₂, séi'₄ 'nia'₂ 'liog₂ tag'₅₄ co₂'nió'₄ jmó'₂ 'nia'₂ léi₄ co₂jaun₂ ma₂le₁cán'₄ dsa₂ 'éi₂ guioin₅₄.\f + \fr 6:11 \ft A₂lɨn₅₄ chog₅₄ si₂ juá'₂ le₂la₂ ján₃: “A₂dsɨ₂jó'₃ juá'₅ jniá₂, jë₁ma₂të́₂ jmɨg₄ i₁qui₃dsɨ₅ Diú₄ 'éi'₃, tsá₃ jua'₅₄ ŋɨ́₄ uɨg₅ gue₃ dsa₂ jme₁chan₂ Sodoma quian'₅₄ Gomorra, con'₂ guë́₄ dsa₂ i₂tsá₃ guen₅ 'nia'₂.” \f* 
\p  
\v 12 Jaun₂ ca₂'uɨn₂ bá₄ chi'₂ dsɨ₂guia₃-tɨ́n₂ në́₃, ca₂i₃léin₂ ca₂i₁'ë́₄ jág₁ a₂dsɨ₃quén'₅ dsɨ́₅ dsa₂.  
\v 13 Jaun₂ qui₂ca₂'uɨ́in'₂ juɨn₅ je₂na'₅₄, qui₂ca₂tsɨ́in₂ no'₅₄ juɨn₅ dsa₂ dso'₅₄, qui₂ca₂jme₃'lóin₂ dsa₂ në́₃. 
\s1 Ca₂jon₃ Juan₅₄ i₂chon₅ dsa₂ jmɨg₂ 
\r (Mateo 14:1-12; Lucas 9:7-9) 
\p  
\v 14 Ca₂rë₃ŋi₅ Rag₅₄ Herodes jág₁ a₂'ei₅ quió'₅ Jesús, ia₁ ca₂le₂con₂ bá₄ ma₂le₁ŋi₅ dsa₂ 'e₂ a₂jmo₅ Jesús ŋɨ₂₃. Jaun₂ juá'₂ Rag₅₄ Herodes: 
\p ―Ma₂ca₂jen'₅₄ Juan₅₄, dsa₂ i₂jme₁chon₅ dsa₂ jmɨg₂; 'uɨg₅₄ jaun₂ quɨ'₅₄ jmɨg₄ jmo₂₃ 'e₂ a₂jmo₂₃. 
\p  
\v 15 I₂lɨn₅₄ guë'₂ dsia₅ táng₃: 
\p ―Elías bá₄ 'éi₂ ŋɨ₅. 
\p La₁ i₂sián'₂ guë'₂ juá'₂: 
\p ―Jan₂ i₂chen₄ quián₅ Diú₄ bá₄ 'éi₂, juɨ₁lia'₂ dsa₂ i₂jme₁'ë́₂ jág₁ quián₅ Diú₄ ma₂lɨ́g'₂. 
\p  
\v 16 Jme₁ca₂nág₂ Rag₅₄ Herodes, jaun₂ ca₂juá'₂: 
\p ―Juan₅₄ bá₄ në₅ ŋɨ₅, i₂ca₂'nia₃ dsa₂ dsɨ₂lag₄, 'éi'₃ quió₃ jniá₂. Ma₂ca₂jein'₅₄ táng₃. 
\p  
\v 17 Ia₁ 'ŋiog₅ bá₄ Herodes ma₂jmo₅ 'éi'₃ le₂jŋiá₅ a₂ca₂i₁chan'₅₄ dsa₂ Juan₅₄ ca₂i₁tio'₂ né'₃ 'má₃ rë₂'ŋei'₅₄ 'uɨg₅₄ quió'₅ 'io₅₄ Herodías i₂lɨ́n₅ dsɨ₂i₂gu₂ Fe₂li₄ rɨin'₅₄. La₁ Herodes në́₃ ma₂jmo₂₃ quiáin₅.  
\v 18 Ia₁ jme₁ma₂qui₂ma₂juá'₂ Juan₅₄ tsɨ́'₅ Herodes: 
\p ―Tsá₃ 'i₄ 'éi'₃ jmó'₂ quiáng'₂, 'io₅₄ quián₅ dsó₂ rɨ́ng'₂. 
\p  
\v 19 'Uɨg₅₄ jaun₂ jme₁'i₄ 'nei₂ dsɨ́₅ 'io₅₄ Herodías jɨ́in₂ Juan₅₄. Jaun₂ jme₁'nio₃ jŋag'₃, la₁ tsá₃ ca₂dsó'₂ juɨ₅ 'a₂ lia'₂ jmo₃.  
\v 20 Ia₁ jme₁ŋi₅ bá₄ Rag₅₄ Herodes a₂lɨ́n₅ Juan₅₄ dsa₂ dsen₃, jaun₂ jme₁jme₂go₃ bá₄; jaun₂ jme₁jmo₂₃ 'í₁. Lia'₂ con'₂ jme₁nag₂₃ jág₁ quió'₅ Juan₅₄, jme₁të₂tsɨin'₅₄ tsá₃ 'e₂ ŋi₅ jmo₃, la₁ 'ŋio₂ bá₄ dsɨ́₅ jme₁nag₂₃.  
\v 21 La₁ ca₂cuɨn₃ jmɨg₄ në́₃ jme₁ca₂jmo₃ Herodes jmɨg₄ a₂ca₂dsɨ́'₃ ŋi₂: ca₂jmo₃ má₃, ca₂të́'₃ dsa₂ can'₅₄ con'₂ dsa₂ i₂jmo₅ 'éi'₃ juɨg₂, i₂lɨ́n₅ juɨg₅₄ 'lióg₂ quiáin₅ në́₃, ca₂le₃jɨ́n₃ guë́₄ con'₂ dsa₂ dsen₅₄ quián₅ juɨg₂ ja₁tén₄ Galilea.  
\v 22 Jaun₂ ca₂guan₃ ja₁mɨ́g₄ Herodías ja₁niog₅ jmɨg₄, jaun₂ ca₂dsáin₂. A₂jaun₂ ca₂të́₂ dsɨ́₅ Rag₅₄ Herodes, ca₂le₃jɨ́n₃ dsa₂ i₂té₄ i₂tion'₅₄ guë́'₅ quiain'₅₄ në́₃. Jaun₂ ca₂juá'₂ rag₅₄ ca₂tsɨ́'₃ 'io₅₄ bë'₅₄ 'éi₂: 
\p ―Mɨ₄ ca₂le₃jë́₃ 'e₂ 'niog'₂, jaun₂ cuë₅₄ jniá₂. 
\p  
\v 23 Jaun₂ ca₂cuë₃ jág₁ quió'₅ ca₂le₃jë́₃ ca₂'ɨin₃ Diú₄, ca₂juá'₂: 
\p ―Chi₂jua'₂ 'e₂ caun₂ a₂mɨ́'₁ 'ne₂, cuë₅₄ bá₄ jniá₂, jŋia'₅₄ ca₂dsio₄ 'uë₃ ja₁gong₂. 
\p  
\v 24 Jaun₂ ca₂o₃'ɨ́n₃ 'io₅₄ bë'₅₄ 'éi₂ ca₂i₁ŋag₁₂ chog₅₄, ca₂i₁jua'₄: 
\p ―¿'E₂ mɨ₅₄ jniá₂, mag₅₄? 
\p Jaun₂ ca₂juá'₂ chog₅₄: 
\p ―Mɨ₄ mɨ₂dsi₄ Juan₅₄ i₂chon₅ dsa₂ jmɨg₂. 
\p  
\v 25 Jaun₂ ca₂'í₃ táng₃ 'éi₂ dsɨ₂juɨ₅ ja₁guá₄ rag₅₄, jaun₂ ca₂juá'₂: 
\p ―'Nio₃ cuë́'₁ të₂në₃ mɨ₂dsi₄ Juan₅₄ i₂chon₅ dsa₂ jmɨg₂, a₂'i₄ 'ŋió'₃ uɨng₅.\f + \fr 6:25 \ft lit. “rë₂dsɨ́₂ ne₄ caun₂ nɨ₁ŋí₁ charola.” \f* 
\p  
\v 26 Jme₁ca₂nág₂ rag₅₄ jág₁ në₅, ca₂jén₂ dsɨ́₅. La₁ tsá₃ a₂ŋi₅ jmo₃, ia₁ ma₂në₂cuë₃ jág₁ quió'₅ le₂jŋiá₅ a₂cuë₃ chi₂jua'₂ 'e₂ 'nio₃ 'io₅₄ 'éi₂, ton'₂ ia₁ ma₂në₂néi₂ a₂mei₅₄ quiáin₅ i₂tián'₅.  
\v 27 Jaun₂ dsɨ₂juɨ₅ jaun₂ ca₂chein₃ jan₂ 'lióg₂ a₂dsɨ₃quián₂ mɨ₂dsi₄ Juan₅₄.  
\v 28 Jaun₂ ca₂ŋó₃ 'lióg₂ juɨ₅ 'ŋió'₃ 'né₅ 'má₃, jaun₂ ca₂i₁qui'₂ dsɨ₂lag₄ Juan₅₄, jaun₂ quian₅ rë₂'i₄ 'ŋió'₃ uɨng₅, ca₂cuë́'₃ 'io₅₄ 'éi₂. Jaun₂ 'io₅₄ në́₃ ca₂gue₃, jaun₂ ca₂i₁cuë'₂ táng₃ chog₅₄. 
\p  
\v 29 Jme₁ca₂rë₃ŋi₅ dsa₂ i₂jme₁quian'₅₄ Juan₅₄, jaun₂ ca₂o₃léin₂, ca₂tág₃ 'lag₄, jaun₂ ca₂i₁'ó₄. 
\s1 Ca₂jme₃tan₅₄ Jesús 'ŋiá₂ mei₅ dsa₂ 
\r (Mateo 14:13-21; Lucas 9:10-17; Juan 6:1-14) 
\p  
\v 30 Cang₂ jaun₂ ca₂o₃len₃ dsa₂ i₂chen₄\f + \fr 6:30 \ft griego: apóstolous.\f* 'éi₂, ca₂ŋɨi'₂ táng₃ quiain'₅₄ Jesús, jaun₂ ca₂dsia₃ 'e₂ niog₅ ca₂jmo₃ ja₁i₁lein₅₄, 'a₂ lia'₂ i₂ca₂jme₁tɨin₂₃ dsa₂.  
\v 31 Jaun₂ ca₂juá'₂ Jesús: 
\p ―I₂nó'₅ 'nia'₂ con'₂ guiong'₅₄ caun₂ ja₁co₂'ŋiog₅, i₂jŋia₄ ca₂tiá₂. 
\p Ia₁ juɨn₅ lɨn₃ dsa₂ i₂o₂lén₂, lia'₂ i₂dsɨ₂len₃ në́₃, ca₂lia'₂ jŋia'₅₄ tsá₃ cuɨn₅ jmɨg₄ guë́'₃.  
\v 32 Jaun₂ në́₃ ca₂tóin'₂ tsɨ₁mu₅ ca₂i₃léin₂ caun₂ ja₁lë́₄ co₂'ŋiog₅ con'₂ guioin₅₄.  
\v 33 Jaun₂ qui₂ca₂'uɨn₂ dsa₂ le₂caun₂ le₂caun₂ juɨg₂, i₃léin₂ co₂chi'₅₄ juɨ₅ tag₅₄ a₂'ein₂₃ Jesús. Jaun₂ jŋiái₅ bá₄ dsi₃léin₂ lia'₂ con'₂ guë́₄ 'éi₂.  
\v 34 Jme₁ca₂sión₃ Jesús 'ŋió'₃ tsɨ₁mu₅, ca₂jɨ́in₂ juɨn₅ lɨn₃ dsa₂, ma₂tion'₅₄ le₁jŋiog₅, ca₂tá'₂ ŋéi₂ dsɨ́₅ dsa₂ 'éi₂, ia₁ i₂nio₄ dsa₂ lia'₂ jë₁i₂nio₄ já'₂ cha'₂ i₂tsá₃ juɨg₅₄ chan₂, jiog₃, jmo₃ 'í₁. Jaun₂ ca₂jme₃lióg₃ ca₂jme₃tɨin₂₃ dsa₂ 'lióng₂ lɨn₃ jág₁.  
\v 35 Jme₁ca₂'láu₂ jaun₂ ca₂o₃lén₂ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅, jaun₂ ca₂juá'₂: 
\p ―Caun₂ ja₁co₂'ŋiog₅ bá₄ la₂, ton'₂ ca₂'láu₂ guë́₄ má'₃.  
\v 36 'Ei'₂ jág₁ dsa₂, ia₁jaun₂ dsɨ₃lein₅ dsɨ₃'nióg₂ a₂guë́'₃ lia'₂ con'₂ juɨg₂ ja₁nau₂ ma₂quián₅ në₅. 
\p  
\v 37 Jaun₂ ca₂ŋag₃ Jesús: 
\p ―Cuë'₅₄ 'nia'₂ dsa₂ a₂guë́'₃. 
\p Jaun₂ ca₂ŋag₃ táng₃ 'éi₂: 
\p ―¿Lé₂ le₃dsɨ₁liá₄ tɨn₃ 'ŋiá₂-láu₂ 'éi'₃ denario i₁ŋí'₄ ia₁jaun₂ dsio'₂ a₂guë́'₃ dsa₂? 
\p  
\v 38 Jaun₂ ca₂juá'₂ táng₃ Jesús: 
\p ―O₂jag₄ 'nia'₂ je₂liá'₂ i₁ŋí'₄ 'i₄ quián'₂ 'nia'₂. 
\p Jaun₂ ca₂i₁jag₅₄ 'éi₂ jaun₂ në́₃, jaun₂ ca₂o₃léin₂ táng₃, ca₂juá'₂: 
\p ―'Ŋiá₂ i₁ŋí'₄ bá₄ 'i₄, on₃ guë'₂ i₁ju₁. 
\p  
\v 39 Jaun₂ ca₂chein₃ jág₁ a₂tian'₃ dsa₂ jma₃co₂niói'₃ ne₄ ŋi₂ma'₂ rë'₂,  
\v 40 jaun₂ ca₂tián'₂ dsa₂ jma₃co₂niói'₃ ja₁lë́₂ caun₂ 'ŋiá₂-lón₂, i₂ca₂tián'₂ jma₃co₂nió'₃ jma₃të₂lón₃-guián₂ në́₃.  
\v 41 Jaun₂ në́₃ ca₂jŋa'₃ Jesús le₃'ŋiá₂ i₁ŋí'₄, le₃on₃ guë'₂ i₁ju₁ në́₃, ca₂jág₃ guei'₅₄ i₂juɨ́g₃, ca₂cuë́'₃ ti₁'mag'₄ Diú₄. Jaun₂ ca₂jmo₃ le₁'nau₅₄ i₁ŋí'₄, jaun₂ guë́₄ ca₂cuë́'₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅, ia₁jaun₂ dsia₃ 'éi₂ ne₄ dsa₂. Ján₃ guë'₂ ca₂jmo₃ dsióg₁ quió'₅ i₁ju₁ on₃ 'éi₂, ca₂cuë́'₃ ca₂le₃jɨ́n₃.  
\v 42 Jaun₂ le₃jɨ́n₃ dsa₂ ca₂guë́'₃ ca₂lia'₂ ca₂rë₃tain₅₄.  
\v 43 Jaun₂ ca₂cág'₃ bá₄ guë́₄ dsa₂ guia₃-tɨ́n₂ tsɨ₁mɨ'₂ 'nau₅₄ i₁ŋí'₄, a₂ca₂chóng₃ quió'₅ i₁ju₁ në́₃.  
\v 44 'Ŋiá₂ mei₅ jme₁lë́₂ ca₂le₃jɨ́n₃ dsa₂ ŋe'₂ i₂ca₂guë́'₃ 'éi₂. 
\s1 Ca₂ŋɨ₃ Jesús ne₄ jmɨ₁ŋí'₄ 
\r (Mateo 14:22-27; Juan 6:16-21) 
\p  
\v 45 Jaun₂ dsɨ₂juɨ₅ le₂jaun₂ ca₂jmo₃ Jesús 'éi'₃ a₂i₃ton'₅₄ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅ 'ŋió'₃ tsɨ₁mu₅, jaun₂ jŋiá₅ de'₂ 'éi₂ ŋɨ́₃ jmɨg₂ con'₂ guë́₄ 'ŋiog₅, a₂dsi₁léin₂ Betsaida, të₁lia'₂ 'í₁ guë́₄ 'ŋiog₅ 'ág'₃ jág₁ dsa₂.  
\v 46 Jme₁ma₂ca₂lë₃ 'ág'₅ jág₁ dsa₂, ca₂ŋó₃ jaun₂ në́₃ juɨ₅ má'₂ i₁chi₂i₁lein'₁ Diú₄.  
\v 47 Jaun₂ con'₂ ca₂tó'₂ nei₂ dé₄, ma₂ŋó₅ tsɨ₁mu₅ dsi₂jo₂ jmɨ₁ŋí'₄, 'ŋiog₅ guë'₂ Jesús jaun₂ bá₄ 'ein₅₄ 'uë₃.  
\v 48 Jaun₂ ca₂jág₃ Jesús 'ŋio₅ cán₂ ta₁ tioin'₅₄ a₂jein₂₃ nɨ₁'ma₂ a₂gag₂ jmɨg₂, ia₁ 'liog'₂ dsí₂ le₂ca'₃. Jaun₂ con'₂ le₁né₃ të₂le₃ ca₂jnia₃, ca₂jme₃quián₃ Jesús ŋɨ₂₃ ne₄ jmɨg₂ ja₁ŋó₄ tsɨ₁mu₅. Jaun₂ ca₂jmo₃ në₂jag₄ bá₄ i₂jme₁ma₂ŋɨ́₃ co₂dsau₅ ja₁tion'₅₄ 'éi₂.  
\v 49 Jme₁ca₂jág₂ jóin'₅ ŋɨ₂₃ ne₄ jmɨ₁ŋí'₄, dsa₂ 'lɨn'₅₄\f + \fr 6:49 \ft griego: fantasma.\f* bá₄ 'éi₂ lɨ́in₂, jaun₂ ca₂tóin'₂ co₂mɨ'₅₄ ca₂guió'₃,  
\v 50 ia₁ ca₂le₃jɨ́in₃ bá₄ ca₂rë₃gó'₅ 'ŋio₅ lɨn₃ jme₁ca₂jág₂. La₁ dsɨ₂juɨ₅ bá₄ ca₂juá'₂ Jesús: 
\p ―¡Tiá₂ dsia₄ 'nia'₂ 'au'₂; jniá₂ bá₄ la₂, tsá₃ lë₁jmo₂ 'nia'₂ gang'₃! 
\p  
\v 51 Jaun₂ ca₂uɨ́g₂ 'ŋió'₃ tsɨ₁mu₅ ja₁tion'₅₄ 'éi₂. Jaun₂ ca₂'ág₂ táng₃ tei₄ ca₂jŋia'₃ dsí₂, jaun₂ i₃gó'₃ dsɨ́₅ 'éi₂ 'ŋio₅ lɨn₃.  
\v 52 Ia₁ tsá₃ 'e₂ ca₂ŋɨ́'₂ dsɨ́₅ dsa₂ 'éi₂ juɨ₁lia'₂ léi₄ juë'₂ a₂ma₂në₂jág₃ jmo₅ Jesús quian'₅₄ i₁ŋí'₄, në₂jag₄ bá₄ cha₂ a₂jmo₅ jnág₅ a₂tsá₃ rë₂ŋɨ́i'₂. 
\s1 Ca₂jme₃'lión₂ Jesús dsa₂ dso'₅₄ 'uë₃ Genesaret 
\r (Mateo 14:34-36) 
\p  
\v 53 Jme₁ca₂'ain₂ jmɨg₂, ca₂dsi₃léin₂ 'uë₃ Genesaret. Ja₁jaun₂ ca₂'néi₂ tsɨ₁mu₅ chei'₅₄ jmɨg₂.  
\v 54 Dsɨ₂juɨ₅ jme₁ca₂'uɨin₂ tsɨ₁mu₅, co₂tan₅₄ lia'₂ ca₂rë₃cuɨn₅ bá₄ dsa₂ Jesús.  
\v 55 Jaun₂ ca₂i₁nioi₁₂ co₂chi'₅₄ le₂tan₅₄ juɨg₂ te₁'i₁ ma₂quián₅ jaun₂. Jaun₂ ca₂i₁quian₅₄ dsa₂ dsa₂ i₂le₁dso'₅₄ quian'₅₄ tsɨ₁jein₁ 'a₂ guë́₃ já'₄ 'en₅₄ Jesús.  
\v 56 Ca₂le₂con₂ ja₁jme₁ŋɨ₅ Jesús, jë₁ma₂'í₅ jë₄ juɨg₂, jë₄ ciudad, o₃ le₂'i₄ juɨ₅ ja₁ŋó₄ 'e₂, jme₁qui₂dsɨ₂jŋia₃ dsa₂ dsa₂ dso'₅₄, qui₂ca₂dsiog₃ ja₁niog₅ 'ma'₅₄. Qui₂ca₂mɨ₃ dsa₂ tsá₃ a₂nag₅₄ o₁jŋia'₅₄ a₃tag₄ tsɨn'₅₄ bá₄ cuë₃ jmɨg₄ a₂nɨ́i'₃. Jaun₂ ca₂le₃jɨ́n₃ dsa₂ dso'₅₄ i₂qui₂ca₂nɨ́'₃ tsɨn'₅₄ Jesús, qui₂ca₂'lóin₂. 
\c 7  
\s1 Jme₂tag₅ Jesús juɨ₁lia'₂ 'e₂ jaun₂ a₂jmo₅ a₂rë₂'ŋio₅ dsa₂ 
\r (Mateo 15:1-20) 
\p  
\v 1 Jaun₂ në́₃ dsa₂ fariseos quian'₅₄ i₂lɨn₅₄ të₅juá'₅ i₂ja₂lén₂ Jerusalén, ca₂o₃léin₂ ca₂ŋɨi'₂ ja₁'en₅₄ Jesús.  
\v 2 Ca₂jág₃ dsa₂ 'éi₂ ca₂jɨ́in₂ i₂lɨn₅₄ chi'₂ dsɨ₂guia₃-tɨ́n₂ a₂guë́'₅ të₃ tsá₃ “le₁jë́₃” gu₂, tsá₃ jme₂ti₃ jua'₅₄ a₂rang₂₃ lia'₂ con'₂ lë́₅ 'éi'₃.\f + \fr 7:2 \ft A₂lɨn₅₄ chog₅₄ si₂ juá'₂ le₂la₂ ján₃: “jaun₂ lë₃ ca₂chi₂ca₂'ag₃.” \f* 
\v 3 (Ia₁ ca₂le₃jɨ́n₃ dsa₂ fariseos, quian'₅₄ ca₂le₃jɨ́n₃ dsa₂ chan₂ Judea në́₃, jme₂ti₃ lia'₂ con'₂ lë́₅ tag₄ chí'₅ quió'₅ dsa₂ can'₅₄, a₂tsá₃ guë́'₃ në₁jua'₂ tsá₃ ma₂në₂rang₃ 'lióng₂ ráun₂ gu₂.  
\v 4 Jë₁ma₂o₃lein₃ 'ma'₅₄, tsá₃ guë́'₃ në₁jua'₂ tsá₃ ma₂në₂jme₃ti₃ con'₂ tag₄ chí'₅ a₂rang₃ quió'₅. Jaun₂ 'lióng₂ bá₄ guë́₄ tag₄ siá'₂ a₂jme₂ti₃ dsa₂ juɨ₁lia'₂ a₂rang₅ dsa₂ nɨ₁vaso, juɨ₁lia'₂ a₂rang₅ dsa₂ nɨ₁taza, nɨ₁dsɨg₁, tsɨ₁cama në́₃.)\f + \fr 7:4 \ft A₂lɨn₅₄ chog₅₄ si₂ juá'₂: “nɨ₁taza, nɨ₁dsɨg₁, nɨ₁ŋí₁ në́₃.” \f* 
\v 5 Jaun₂ në́₃ ca₂ŋag₃ dsa₂ fariseos quian'₅₄ të₅juá'₅, ca₂ŋɨ́i'₃ Jesús: 
\p ―¿'E₂ lë₃ tsá₃ jme₂ti₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáng'₂ tag₄ chí'₅ quió'₅ dsa₂ can'₅₄? Guë́'₅ bá₄ të₃ tsá₃ ma₂në₂rang₃ gu₂. 
\p  
\v 6 Jaun₂ ca₂ŋag₃ 'éi₂: 
\p ―Dsón'₂ bá₄ dsau₅ ca₂juá'₂ Isaías ca₂'ɨin₃ 'nia'₂ dsa₂ i₂lë₁jmo₅-dsáu₅ o₁ne₁, juɨ₁lia'₂ tio'₅₄ ne₄ Si₂: 
\q1 Dsa₂ juɨg₂ la₂ jme₂juag'₂ jniá₂ 
\q2 jmá'₃ lia'₂ quian'₅₄ mɨ₂'o₅₄ bá₄, 
\q1 la₁ia₁ uɨ́ng₂ bá₄ 'i₄ dsɨ́₅ ja₁con₂ jniá₂. 
\q1  
\v 7 La₁ tsá₃ 'e₂ ta₁ tí₄ a₂jme₂juag'₂, 
\q2 ia₁ jág₁ a₂jme₂tag₂₃, 
\q2 'éi'₃ a₂lë₁lë́₅ quió'₅ dsa₂ mɨ₂güɨ́g₃ bá₄.\f + \fr 7:7 \ft Isaías 29:13.\f* 
\p  
\v 8 Ia₁ co₂dsia₅ ma₂ca₂tí'₃ bá₄ 'nia'₂ 'éi'₃ quió'₅ Diú₄, a₂ma₂ja₂nóg'₅ chan'₅₄ tiá₂ 'éi'₃ tag₄ quió'₅ dsa₂ mɨ₂güɨ́g₃.\f + \fr 7:8 \ft A₂lɨn₅₄ chog₅₄ si₂ juá'₂ ján₃: “juɨ₁lia'₂ a₂qui₂rang'₂ 'nia'₂ nɨ₁dsɨg₁, nɨ₁vaso a₂'ág'₂ jmɨg₂, ca₂le₃jë́₃ guë́₄ 'e₂ cosa a₂qui₂jmo'₂ 'nia'₂ në́₃.” \f* 
\p  
\v 9 Ca₂juá'₂ ján₃: 
\p ―'Ŋio₅ tɨn'₂ 'nia'₂ jmo'₂ cau₅ 'éi'₃ quió'₅ Diú₄, a₂jme₂tí'₁ 'nia'₂ tag₄ quián'₂ 'nia'₂ guiong'₅₄.  
\v 10 Ia₁ ca₂juá'₂ Moisés a₂jme₃gan₃ dsa₂ chog₅₄-jmei₂.\f + \fr 7:10 \ft Éxodo 20:12; Deuteronomio 5:56.\f* Jaun₂ juá'₂, chi₂jua'₂ 'ein₂ ca₂juá'₂ uɨg₅ ne₄ chog₅₄-jmei₂, juɨ₁join₅₄.\f + \fr 7:10 \ft Éxodo 21:17; Levítico 20:9.\f* 
\v 11 La₁ 'nia'₂ në́₃ juá'₂ a₂lé₂ le₃juá'₂ dsa₂ tsɨ́'₃ chog₅₄-jmei₂: “Tsá₃ 'nia'₂ lé₂ le₃jme₁'ong₁₂, ia₁ ca₂le₃jë́₃ a₂cha₂ quió₃ a₂lë́₅ Corbán”, (co₂'nió'₄ a₂juá'₂, a₂ma₂lë́₅ quió'₅ Diú₄ bá₄).  
\v 12 Në₁jua'₂ le₂në₅ jaun₂ tsá₃ ma₃cuë'₂ 'nia'₂ jmɨg₄ a₂jme₃'on₅₄ guë́₄ dsa₂ chog₅₄-jmei₂.  
\v 13 Jaun₂ le₂në₅ bá₄ tsá₃ ma₃'e₂ quen₅ jág₁ quió'₅ Diú₄, jmo'₂ 'nia'₂, të₂le₃ quian'₅₄ tag₄ a₂chí'₅, a₂ca₂ŋag₃ dsa₂ can'₅₄ quiáng'₂. 'Lióng₂ bá₄ guë́₄ a₂siá'₂ jmo'₂ 'nia'₂. 
\p  
\v 14 Jaun₂ ca₂të́'₃ Jesús dsa₂, ca₂juá'₂: 
\p ―Nei₂ 'nia'₂ dse₃ ca₂le₃jɨ́ng'₃ a₂juá'₄ jniá₂ la₂.  
\v 15 'I₁caun₂ a₂dsɨ₂to'₅₄ quió'₅ dsa₂, on₃jua'₅₄ a₂jaun₂ jmo₅ a₂rë₂'iog₅ jme₂dsí₂ quió'₅. Cosa a₂'uë₂ dsɨ́₅ dsa₂ guioin₅₄, a₂jaun₂ bá₄ jmo₅ a₂rë₂'iog₅ jme₂dsí₂.\f + \fr 7:15 \ft A₂lɨn₅₄ chog₅₄ si₂ chi₁ton₅ versículo 16 bá₄ ján₃, a₂juá'₂: “Ca₂le₃jɨ́n'₃ 'nia'₂ i₂le₁dsɨ₅₄ rë₂gua₄, nei₂ 'nia'₂.” \f* 
\p  
\v 17 Jme₁o₂'ɨ́in₃ jɨn₄ dsa₂, ŋái'₃ dsi₂néi₂, jaun₂ ca₂ŋag₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅ 'e₂ jág₁ dsau₅ jáng'₅ jág₁ ca₂cuë́'₃ dsa₂ jaun₂.  
\v 18 Jaun₂ ca₂juá'₂: 
\p ―¿Ján₃ bá₄ tsá₃ ŋɨ́'₂ 'nia'₂ a₂juá'₅ jniá₂? Ca₂le₃jë́₃ 'e₂ a₂guë́'₅ dsa₂, on₃jua'₅₄ a₂jaun₂ jmo₅ a₂rë₂'iog₅ jme₂dsí₂.  
\v 19 Ia₁ on₃jua'₅₄ dsɨ́₅ dsa₂ dsɨ₂to'₅₄ a₂guë́'₅. Rë₂tú'₅ bá₄ dsa₂ dsɨ₂to'₅₄ a₂jaun₂. Cang₂ jaun₂ dsɨ₂'uë'₅₄ táng₃ dsa₂ ca₁'né₄. 
\p (Ca₂'ë₃ co₂'nió'₄ a₂le₁jë́₃ ca₂le₃jë́₃ bá₄ má₃, jme₁ca₂juá'₂ le₂në₅).  
\v 20 Ca₂juá'₂ ján₃: 
\p ―Ca₂le₃jë́₃ a₂'uë₂ dsɨ́₅ dsa₂, a₂jaun₂ bá₄ a₂jmo₅ a₂rë₂'iog₅ jme₂dsí₂.  
\v 21 Të₂dsɨ́₅ bá₄ dsa₂ 'uë₂ ca₂le₃jë́₃ ne₅₄ a₂'lɨg'₅₄: juɨ₁lia'₂ a₂lë́₅ dsɨ́₅ dsa₂ niói'₃ jág₁ quian'₅₄ dsa₂ i₂tsá₃ lɨ́n₅ dsɨ₂i₂gu₂; a₂'ang₅ dsa₂; a₂jme₂dsian₅ dsa₂ rɨin'₅₄;  
\v 22 a₂'ɨ́n₅ dsɨ́₅ dsa₂ jmo₃ quió'₅ a₂cha₂ quió'₅ rɨin'₅₄; 'e₂ caun₂ a₂tsá₃ dsi₂ten₅₄ jmái'₂ rɨin'₅₄; a₂qui₂jme₂gain₂₃ rɨin'₅₄; a₂jmo₂₃ o₂guí'₃ 'lɨg'₅₄, a₂jmo₂₃ uɨg₅ dsɨ́₅, a₂qui₂chi₂'ɨn₅ dsa₂ rɨin'₅₄; a₂jme₂róin₂ jmái'₂ dsa₂; ca₂le₃jë́₃ guë́₄ 'e₂ a₂tsá₃ 'en₅₄ dsɨ́₅ dsa₂ lɨ́in₅.  
\v 23 Ca₂le₃jë́₃ a₂në₅, të₂dsɨ́₅ bá₄ dsa₂ lë́₂, a₂në₅ bá₄ a₂jmo₅ a₂rë₂'iog₅ jme₂dsí₂ quió'₅ dsa₂. 
\s1 Jan₂ i₁náu₃ i₂ca₂rë₃'én₂ të₂le₃ quió'₅ Jesús 
\r (Mateo 15:21-28) 
\p  
\v 24 A₂'ein₅₄ ja₁jaun₂, ca₂o₃'ɨ́in₃ ŋó₃ 'uë₃ ma₂quián₅ juɨg₂ Tiro.\f + \fr 7:24 \ft A₂lɨn₅₄ chog₅₄ si₂ juá'₂ ján₃: “quian'₅₄ Sidón.” \f* Jaun₂ ca₂'í₃ con'₂ të₃co'₅₄ bá₄ dsi₂néi₂ quió'₅ dsa₂ ja₁jaun₂. La₁ tion₅₄ bá₄ ca₂rë₃lí'₄ dsa₂, tsá₃ ma₃ca₂cuɨn₃ jmɨg₄ a₂'mai₃.  
\v 25 Dsɨ₂juɨ₅ jaun₂ ca₂nág₂ chog₅₄ jan₂ 'io₅₄ bë'₅₄ i₂'en₅₄ jme₂dsí₂ 'lɨn'₅₄. Ca₂dsióg₃, jaun₂ ca₂chi₃jné₃ ne₄ Jesús.  
\v 26 'Éi₂ jme₁lɨ́n₄ jan₂ 'io₅₄ griega, i₂chan₂ Sirofenicia. Jaun₂ ca₂mɨ₃ ca₂tsɨ́'₃ 'éi₂ a₂dsɨ₃dsein₂₃ je₂na'₅₄ quió'₅ chi'₂ quiáin₅.  
\v 27 Jaun₂ ca₂ŋag₃ Jesús: 
\p ―Juɨ₁le₂tan₅₄ de'₂ jŋiá₅ chi'₂ quiáng₃; ia₁ tsá₃ dsi₂ten₅₄ jua'₅₄ a₂jŋiá'₄ jniá₂ i₁ŋí'₄ quió'₅ chi'₂, a₂ton₅₄ ne₄ dsɨ₂jɨ'₅₄. 
\p  
\v 28 Jaun₂ ca₂ŋag₃ táng₃ 'io₅₄ 'éi₂: 
\p ―Dsón'₂ bá₄ dsau₅, Te₁gui'₅₄, la₁ia₁ le₂jiog₅ dsɨ₂jɨ'₅₄ bá₄ guë́'₅ né'₃ nɨ₁mesa 'nau₅₄ a₂tsɨ₂séi'₂ guein₂. 
\p  
\v 29 Jaun₂ ca₂ŋag₃ táng₃: 
\p ―Dse₃ në₂ŋag'₅₄. Ma₂lé₂ guang'₅₄. Ma₂o₂'ɨ́n₃ bá₄ je₂na'₅₄ i₂jme₁'en₅₄ të₂dsɨ́₅ chi'₂ quiáng'₂. 
\p  
\v 30 Jaun₂ ca₂ŋái'₃ bá₄; jme₁dsiáin'₃, ca₂jɨ́in₂ ja₁mɨ́g₄ roin₂₃ tei₄ ne₄ tsɨ₁cama, ma₂o₂'ɨ́n₃ bá₄ je₂na'₅₄ të₂dsɨ́₅. 
\s1 Ca₂jme₃'lión₂ Jesús jan₂ dsa₂ güɨn₄ i₂tsá₃ lɨn₄ lé₂ dsia₃ jág₁ 
\p  
\v 31 Ca₂o₃'ɨ́n₃ táng₃ Jesús juɨg₂ Tiro, ca₂ŋɨ́i₃ juɨ₅ juɨg₂ Sidón, jaun₂ ca₂dsióg₃ chei'₅₄ jmɨ₁ŋí'₄ Galilea, jaun₂ ca₂'í₃ 'uë₃ Decápolis.  
\v 32 Ja₁jaun₂ ca₂o₃jŋia₃ dsa₂ jan₂ dsa₂ i₂tsá₃ lɨn₄ lé₂ dsia₃ jág₁. Jaun₂ ca₂mɨ₃ dsa₂ a₂quióg₃ Jesús gu₂ ne₄ quió'₅ dsa₂ 'éi₂.  
\v 33 Jaun₂ ca₂jiog₃ Jesús ca₂jŋiai₃ dsa₂ 'éi₂ caun₂ ja₁co₂'ŋiog₅, jaun₂ ja₁jaun₂ ca₂tiá₂ chi₁gú₃ rë₂gua₄ dsa₂ 'éi₂, jaun₂ ca₂'ŋéi₃ chi₁gú₃, jaun₂ ca₂nɨ́i'₂ le₁tsɨ'₂ dsa₂ 'éi₂.  
\v 34 Jaun₂ ca₂chóg'₃ ne₅₄ guei'₅₄ i₂juɨ́g₃, ca₂choin₃ dsɨ́₅, jaun₂ ca₂juá'₂: 
\p ―¡Efata! ―co₂'nió'₄ a₂juá'₂: ¡Nia₄! 
\p  
\v 35 Jme₁ma₂në₂juá'₂ le₂në₅, ca₂niá₃ rë₂gua₄ mɨ₂'o₄ dsa₂ 'éi₂ në́₃, ca₂'lóin₂, ca₂dsia₃ dse₃ jág₁.  
\v 36 Jaun₂ ca₂juá'₂ Jesús ca₂tsɨ́'₃ ca₂le₃jɨ́n₃ dsa₂ i₂jme₁tion'₅₄ a₂tsá₃ 'ein₂ tsɨ́'₃. La₁ të₂le₃ i₂juɨ'₂ guë́₄ ca₂dsia₃ bá₄ dsa₂.  
\v 37 Jaun₂ 'ŋio₅ lɨn₃ ca₂i₃gó'₃ dsɨ́₅ dsa₂ jme₁ca₂rë₃ŋi₅. Jaun₂ qui₂ca₂dsia₃ dsa₂: 
\p ―Dse₃ bá₄ ca₂le₃jë́₃ a₂jmo₂₃. Jmo₂₃ a₂nag₅ dsa₂ i₂güɨn₄, lia'₂ dsa₂ i₂con₄ në́₃, lé₂ le₃dsia₃ jág₁. 
\c 8  
\s1 Ca₂jme₃tan₅₄ Jesús quén₂ mei₅ dsa₂ 
\r (Mateo 15:32-39) 
\p  
\v 1 Jmɨg₄ jaun₂ ca₂ŋɨ'₂ juɨn₅ lɨn₃ dsa₂. Ia₁ tsá₃ ma₃'e₂ cha₂ guë́'₃, jaun₂ ca₂të́'₃ Jesús chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅, jaun₂ ca₂juá'₂: 
\p  
\v 2 ―Ŋéi₂ dsɨ₃ jɨng₅₄ dsa₂ në₅, ia₁ ma₂'nɨ₅ jmɨg₄ tioin'₅₄ ja₁lá₃ quiong'₅₄, tsá₃ ma₃'e₂ cha₂ guë́'₃.  
\v 3 Në₁jua'₂ dsiain'₅₄ guë'₂ jniá₂ quió'₅ të₃ tsá₃ ma₂në₂guë́'₃, 'uáin₂ bá₄ le₂'i₄ juɨ₅, ia₁ uɨ́ng₂ bá₄ ja₂lén₂ i₂lɨn₅₄ në₅. 
\p  
\v 4 Jaun₂ ca₂ŋag₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅: 
\p ―¿A₂já'₄ bá₄ lé₂ le₃dsɨ₁'nióg₂ ca₂le₃jë́₃ i₁ŋí'₄ a₂'nió'₅ le₂tan₅₄ dsa₂ në₅ ja₁co₂'ŋiog₅ la₂? 
\p  
\v 5 Jaun₂ ca₂ŋag₃ táng₃ Jesús: 
\p ―¿Je₂liá'₂ i₁ŋí'₄ 'i₄ quián'₂ 'nia'₂? 
\p ―Guio₃ bá₄ ―ca₂ŋag₃. 
\p  
\v 6 Jaun₂ ca₂jmo₃ Jesús 'éi'₃ a₂tian'₃ dsa₂ ca₂le₃jɨ́in₃ 'uë₃. Jme₁ma₂chan'₂ le₂guio₃ i₁ŋí'₄, ca₂cuë́'₃ ti₁'mag'₄ Diú₄, jaun₂ ca₂jmo₃ le₁'nau₅₄, jaun₂ guë́₄ ca₂cuë́'₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅, ia₁jaun₂ 'éi₂ dsia₃ ne₄ dsa₂. Jaun₂ le₂jaun₂ bá₄ ca₂jmo₃.  
\v 7 Jme₁tion'₅₄ on₃-ún₂ i₁ju₁ pí'₁, jaun₂ ca₂jme₃jŋiói₃ quió'₅ 'éi₂ ján₃, jaun₂ ca₂jmo₃ 'éi'₃ a₂dsión'₂ 'éi₂.  
\v 8 Jaun₂ qui₂ca₂guë́'₃ ca₂le₃jɨ́n₃ dsa₂ ca₂lia'₂ ca₂rë₃tain₅₄. Jme₁ca₂lë₃ jaun₂, ca₂cág'₃ dsa₂ guio₃ tsɨ₁mɨ'₂ 'nau₅₄ a₂ca₂chóng₃.  
\v 9 Ca₂le₃jɨ́n₃ dsa₂ 'éi₂ jme₁lë́₂ con'₂ quén₂ mei₅. Jaun₂ guë́₄ qui₂ca₂'ág'₃ jág₁ dsa₂.  
\v 10 Dsɨ₂juɨ₅ le₂jaun₂ ca₂'í₃ táng₃ 'ŋió'₃ tsɨ₁mu₅ quiain'₅₄ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅, ca₂dsi₃léin₂ 'uë₃ Dalmanuta. 
\s1 Mɨ₅ dsa₂ fariseos a₂jmo₃ Jesús caun₂ léi₄ juë'₂ 
\r (Mateo 16:1-4; Lucas 12:54-56) 
\p  
\v 11 Jaun₂ ca₂o₃lén₂ dsa₂ fariseos ca₂jme₃lióg₃ ca₂tsɨ́in₂ quiong'₅₄, a₂mɨ₂₃ jmo₃ 'éi₂ caun₂ léi₄ juë'₂ a₂já₅ guei'₅₄ i₂juɨ́g₃.  
\v 12 Jaun₂ ca₂chon₃ Jesús dsɨ́₅ 'ŋio₅ lɨn₃, jaun₂ ca₂juá'₂: 
\p ―¿'E₂ bá₄ lë₃ 'nio₃ dsa₂ chan₂ jmɨg₄ në₃ a₂jmo₅₄ jniá₂ léi₄? A₂dsɨ₂jó'₃ juɨ́g₂ jniá₂ 'nia'₂, tsá₃ léi₄ jaun₂ le₃guéi'₁ 'nia'₂. 
\p  
\v 13 Tión₂ jaun₂ bá₄ dsa₂ 'éi₂, ca₂'í₃ táng₃ 'ŋió'₃ tsɨ₁mu₅ ca₂ŋó₃ le₃'ŋo'₅₄ jmɨ₁ŋí'₄ le₃ó₃. 
\s1 Levadura quió'₅ dsa₂ fariseos 
\r (Mateo 16:5-12) 
\p  
\v 14 Ca₂'en₃ dsɨ́₅ chi'₂ dsɨ₂guia₃-tɨ́n₂ cán₂ a₂guë́'₃, jŋia'₅₄ lia'₂ caun₂ i₁ŋí'₄ bá₄ quian₅ i₃léin₂ 'ŋió'₃ tsɨ₁mu₅.  
\v 15 Jaun₂ ti₁ca₂néi'₂ Jesús jág₁, ca₂juá'₂: 
\p ―Të₃ŋi'₅₄ quián'₂ 'nia'₂ quian'₅₄ juá'₅ quió'₅ dsa₂ fariseos, quian'₅₄ jág₁ quió'₅ Herodes në́₃. Ia₁ lë́₅ lia'₂ lë́₅ juɨ₁ levadura. 
\p  
\v 16 Jaun₂ ca₂dsia₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ quian'₅₄ rɨin'₅₄: 
\p ―'An₁ juá'₂ le₂në₅ ia₁ tsá₃ i₁ŋí'₄ cha₂ quián₂ jniog₄. 
\p  
\v 17 Ca₂rë₃lí'₄ bá₄ Jesús jág₁ a₂dsia₅ 'éi₂ i₃léin₂, jaun₂ ca₂juá'₂: 
\p ―¿'E₂ lë₃ juá'₂ 'nia'₂ a₂tsá₃ i₁ŋí'₄ cha₂ quián'₂ 'nia'₂? ¿'E₂ lë₃ ŋɨ́₄ tsá₃ rë₂ŋɨ́'₂ 'nia'₂? ¿O₃ a₂tsá₃ len'₅₄ 'e₂ 'nia'₂, o₃ a₂cang₄ dsei'₂ 'e₂ 'nia'₂?  
\v 18 ¿O₃ bá₄ a₂lë₁tio'₅₄ mɨ₂ne'₅₄ 'e₂ 'nia'₂, la₁ tsá₃ jniag'₃? ¿O₃ bá₄ a₂lë₁le₁dsɨ₅₄ bá₄ rë₂guá'₂ 'nia'₂, la₁ tsá₃ nag'₂ guë'₂ 'nia'₂? ¿O₃ bá₄ tsá₃ ma₃dsá₂ 'e₂ 'au'₂ 'nia'₂?  
\v 19 Lia'₂ con'₂ jme₁ca₂dsio'₄ jniá₂ quian'₅₄ 'ŋiá₂ i₁ŋí'₄ bá₄ ca₂lɨn₅ ca₂guë́'₃ con'₂ 'ŋiá₂ mei₅ dsa₂, ¿je₂liá'₂ mɨ'₂ ca₂lë₃ nɨ₁'nau₅₄ a₂ca₂chóng₃ guë́₄ ca₂cag'₅₄ 'nia'₂? 
\p Jaun₂ ca₂ŋag₃ 'éi₂: 
\p ―Guia₃-tɨ́n₂. 
\p  
\v 20 Con'₂ siá'₂ táng₃, lia'₂ con'₂ jme₁ca₂dsio'₄ jniá₂ guio₃ i₁ŋí'₄ ca₂lɨn₅ ca₂guë́'₃ quén₂ mei₅ dsa₂, ¿je₂liá'₂ mɨ'₂ 'nau₅₄ a₂ca₂chóng₃ ca₂cag'₅₄ guë́₄ táng₃ 'nia'₂? 
\p Jaun₂ ca₂ŋag₃ táng₃ 'éi₂: 
\p ―Guio₃. 
\p  
\v 21 Jaun₂ ca₂juá'₂ táng₃: 
\p ―¿Tsa₁ rë₂len'₅₄ bá₄ guë́₄ 'nia'₂ jaun₂? 
\s1 Ca₂jme₃'lión₂ Jesús jan₂ dsa₂ ten₄ juɨg₂ Betsaida 
\p  
\v 22 Jaun₂ dsi₃léin₂ juɨg₂ Betsaida. Jaun₂ ca₂o₃jŋia₃ dsa₂ jan₂ dsa₂ ten₄, jaun₂ ca₂mɨ₃ dsa₂ a₂téi₂ gu₂.  
\v 23 Jaun₂ në́₃ ca₂jŋa'₃ gu₂ dsa₂ ten₄ 'éi₂, ca₂jiog₃ juɨ₅ 'nɨ'₂ juɨg₂. Jaun₂ ja₁jaun₂ ca₂tsáng₂ jmɨ₁'ë́'₅ quió'₅, jme₁ne₁ dsa₂ 'éi₂, ca₂téi₂ gu₂, jaun₂ ca₂ŋag₃ chi₂jua'₂ ma₂lé₂ jág₃.  
\v 24 Jaun₂ ca₂chóg'₃ ne₅₄ ca₂jág₃, jaun₂ ca₂juá'₂: 
\p ―Jɨn₄ jniá₂ dsa₂ i₂nio₄, i₂jniá₂ lia'₂ jniá₂ nɨ₁'ma₂. 
\p  
\v 25 Con'₂ siá'₂ ca₂tí₂ táng₃ Jesús gu₂ jme₁ne₁ dsa₂ 'éi₂, jaun₂ guë́₄ ca₂jág₃ i₁ca'₅₄ mɨ₂ne₅₄, jaun₂ guë́₄ ca₂rë₃jniá₂ dse₃ jme₁ne₁₂, ca₂'lóin₂.  
\v 26 Jaun₂ ca₂dsióg'₂ Jesús co₂dsau₅ ja₁quió'₄, ca₂juá'₂: 
\p ―Tsá₃ 'ú₅ jë₄ juɨg₂ të₃ jág₅ dsa₂. 
\s1 Ca₂cuë₃ Pe₄ jág₁ dsau₅ a₂lɨ́n₅ Jesús I₂rë₂'ɨ́n₁ quián₅ Diú₄ 
\r (Mateo 16:13-20; Lucas 9:18-21) 
\p  
\v 27 Cang₂ jaun₂ ca₂ŋó₃ Jesús quiain'₅₄ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅ le₂tan₅₄ juɨg₂ Cesarea ja₁tén₄ Filipo. Jaun₂ le₂'i₄ juɨ₅ ja₁i₃léin₂, ca₂ŋag₃ Jesús ca₂ŋɨ́i'₃ chi'₂ dsɨ₂guia₃-tɨ́n₂: 
\p ―¿'Ein₂ lɨ́n₅ jniá₂, juá'₂ dsa₂? 
\p  
\v 28 Jaun₂ ca₂ŋag₃ chi'₂ dsɨ₂guia₃-tɨ́n₂: 
\p ―I₂lɨn₅₄ dsa₂ juá'₂ a₂lɨ́ng'₅ Juan₅₄ i₂jme₁chon₅ dsa₂ jmɨg₂. I₂lɨn₅₄ guë'₂ juá'₂ a₂lɨ́ng'₅ Elías. I₂lɨn₅₄ guë'₂ juá'₂ táng₃ a₂lɨ́ng'₅ jan₂ i₂sián'₂ i₂chen₄ quián₅ Diú₄. 
\p  
\v 29 Jaun₂ ca₂ŋag₃ táng₃: 
\p ―¿'Nia'₂ guë'₂ në́₃? ¿'E₂ juá'₂ 'nia'₂ 'ein₂ lɨ́n₅ jniá₂? 
\p Jaun₂ ca₂ŋag₃ Pe₄: 
\p ―'Ne₂ lɨ́ng'₅ I₂rë₂'ɨ́n₁ quián₅ Diú₄. 
\p  
\v 30 Jaun₂ ca₂jmo₃ Jesús 'éi'₃ a₂tsá₃ dsia₃ tsɨ́'₃ 'i₁jan₂ jua'₅₄ a₂'ag₃. 
\s1 Ca₂'ë́₂ Jesús jág₁ a₂jóin₂ 
\r (Mateo 16:21-38; Lucas 9:22-27) 
\p  
\v 31 Jaun₂ në́₃ ca₂jme₃lióg₃ Jesús ca₂'ë́₂ jág₁ ca₂tsɨ́'₃ chi'₂ dsɨ₂guia₃-tɨ́n₂, a₂ca₂tɨ́n₂ Jaun₅ dsa₂ mɨ₂güɨ́g₃ dsɨ₃ŋɨ́i₂ 'lióng₂ uɨg₅, a₂tsá₃ le₃jei₅₄ dsa₂ can'₅₄ quián₅ guá'₅, juɨg₅₄ jme₂dsa₂, të₅juá'₅ në́₃. Ca₂le₃jɨ́n₃ quɨin'₃ jág₁ a₂jŋag'₃. La₁ jein'₅₄ bá₄ táng₃ a₂'nɨ₅ jmɨg₄ jaun₂.  
\v 32 Ca₂juá'₂ lia'₂ rë₂jiá₃ jág₁. Jaun₂ Pe₄ në́₃ ca₂jiog₃ le₂cau₅, jaun₂ ca₂jme₃lióg₃ ca₂ti₂ca₂néi'₂ a₂jme₁jnéi₂ juɨ₅. 
\p  
\v 33 Jaun₂ ca₂jén'₃ Jesús ca₂jɨ́in₂ ca₂le₃jɨ́n₃ chi'₂ dsɨ₂guia₃-tɨ́n₂, jaun₂ ca₂jéin₂ Pe₄ ca₂juá'₂: 
\p ―¡Jŋiag'₃ cau₅ quió₃, 'ne₂ Satanás! Ia₁ tsá₃ dsɨ₂jiog₅ 'au'₂ juɨ₁lia'₂ dsɨ₂jiog₅ dsɨ́₅ Diú₄; lia'₂ dsɨ₂jiog₅ dsɨ́₅ dsa₂ mɨ₂güɨ́g₃ bá₄ dsɨ₂jiog₅ 'au'₂. 
\p  
\v 34 Jaun₂ ca₂të́'₃ Jesús chi'₂ dsɨ₂guia₃-tɨ́n₂, ca₂le₃jɨ́n₃ guë́₄ dsa₂ i₂jme₁tion'₅₄ në́₃. Jaun₂ ca₂juá'₂: 
\p ―Chi₂jua'₂ 'ein₂ 'nio₃ 'ein₃ jniá₂, co₂dsia₅ juɨ₁dsi₂'én₂ dsɨ́₅ guioin₅₄, juɨ₁jmo₁₂ co₂jŋiai₅₄ a₂jóin₂,\f + \fr 8:34 \ft lit. “juɨ₁quian₅₄ cróg₄ quió'₅.” \f* juɨ₁'ein₁₂.  
\v 35 Ia₁ juɨ₁'ein₂ guë́₃ i₂tsá₃ 'nio₃ jón₂ ia₁ 'ɨ́n₅ dsɨ́₅ le₃chain₂ dse₃ mɨ₂güɨ́g₃ la₂, dsɨ₃'én₂ quió'₅. La₁ juɨ₁'ein₂ guë́₄ i₂tén'₂ dsɨ́₅ gue₃ 'mú₃ 'uɨg₅₄ quió₃ jniá₂, 'uɨg₅₄ quió'₄ jág₁ dse₃ në́₃, tɨ́in'₄, le₃chain₂ dse₃ mɨ₂güɨ́g₃ caun₂.  
\v 36 ¿'E₂ bá₄ ta₁ jmo₃ a₂lí'₂ dsa₂ 'ŋio₅ lɨn₃ ne₄ gua'₅₄ 'uë₃ la₂, në₁jua'₂ dsɨ₃'én₂ bá₄ guë'₂ jme₂dsí₂ quió'₅ mɨ₂güɨ́g₃ caun₂?  
\v 37 ¿O₃ je₂liá'₂ lé₂ le₃quí₃ dsa₂ 'lia'₅₄ ia₁jaun₂ tɨ́n'₄ jme₂dsí₂ quió'₅?  
\v 38 Ia₁ juɨ₁'ein₂ guë́₃ i₂gui'₅₄ jmóg'₂ jniá₂, quian'₅₄ jág₁ dse₃ quió₃, të₃jɨn₄ dsa₂ i₂qui₂rë₂cán'₄ dso₄ i₂tsá₃ ne'₅₄ chan₂ jmɨg₄ në₃, ján₃ bá₄ le₂jaun₂ Jaun₅ dsa₂ mɨ₂güɨ́g₃ gui'₅₄ jmóg'₂ jë₁ma₂të́₂ rë₁guain'₂ quian'₅₄ ángeles jŋió₅ quian'₅₄ ca₂le₃jë́₃ bí₂ jlá'₁ quió'₅ jmei₂. 
\c 9  
\p  
\v 1 Jaun₂ ca₂tsɨ́'₃ dsa₂ le₂la₂ ján₃: 
\p ―A₂dsɨ₂jó'₃ juá'₅ jniá₂, ia₁ chan₂ i₂lɨn₅₄ 'nia'₂ i₂tión₂ ja₁lá₃ i₂tsá₃ tɨn₅₄ dsián₃ né'₃ a₂të₅₄ ne₅₄ a₂guá₂ jmɨg₄ a₂jme₃gón₃ Diú₄ quian'₅₄ juɨ₅bí₂ quió'₅. 
\s1 Ca₂rë₃tsɨ́n₃ Jesús lia'₂ jniái₂ 
\r (Mateo 17:1-13; Lucas 9:28-36) 
\p  
\v 2 Jŋéi₂ jmɨg₄ cang₂ jaun₂ ca₂jŋia₃ Jesús Pe₄, Jacobo, Juan₅₄ në́₃, jaun₂ ca₂i₃léin₂ con'₂ guioin₅₄ juɨ₅ caun₂ má'₂ ŋei₅. Ja₁jaun₂ ca₂jme₃tsɨ́n₃ Jesús lia'₂ jniái₂ të₃ jág₅ rɨin'₅₄.  
\v 3 Jaun₂ nɨ₁tsɨn'₅₄ ca₂jnia₃ tág₅ co₂'né'₅ tiog₂ jau₂ ca₂lia'₂ 'i₁jan₂ dsa₂ chan₂ mɨ₂güɨ́g₃ tsá₃ tɨin₂ rang₃ 'mɨ'₂ a₂jnia₅₄ tiog₂ le₂jaun₂.  
\v 4 Jaun₂ ca₂jág₃ ca₂jnia₃ coin₂, Elías quian'₅₄ Moisés, tióin₂ dsia₂₃ jág₁ quiain'₅₄ Jesús.  
\v 5 Jaun₂ në́₃ ca₂juá'₂ Pe₄ ca₂tsɨ́'₃ Jesús: 
\p ―Të₅, ¡'e₂ guë́₄ dse₃ lia'₂ tio'₅₄ jniog₄ ja₁lá₃! Në₃ o₁jmog'₅₄ 'nɨ₅ tsɨ₁'io₅ láu₃: caun₂ quiáng'₂, caun₂ quió'₅ Moisés, caun₂ guë'₂ quió'₅ Elías në́₃. 
\p  
\v 6 (On₃jua'₅₄ jaun₂ ca₂rë₃lí'₄ rë'₂ Pe₄ 'e₂ a₂ca₂'ŋiai₂, të₂'ɨ₂₃ le₂jaun₂, ia₁ a₂gó'₅ 'ŋio₅ lɨn₃ tioin'₅₄).  
\v 7 Të₃jë₄ jaun₂ në́₃ ca₂'ág₂ jnei₅ ja₁tioin'₅₄, ca₂lioin₂. Jaun₂ jë₄ jnei₅ jaun₂ ca₂né'₂ jág₁ a₂ca₂juá'₂: 
\p ―I₂la₂ bá₄ jón₃ quiáng₃, i₂'nióg₃ guë́₄ lɨn₃. Nei₂ 'nia'₂ jág₁ quió'₅. 
\p  
\v 8 Dsɨ₂juɨ₅ le₂jaun₂ jme₁ca₂jág₃ táng₃, tsá₃ ma₃'ein₂ chan₂, jŋia'₅₄ lia'₂ jan₂ 'ŋiog₅ bá₄ Jesús quiong'₅₄ guë́₄. 
\p  
\v 9 Jme₁ma₂tioin'₅₄ juɨ₅ ja₂lein₃ sióin₅ má'₂, jaun₂ ca₂jmo₃ Jesús 'éi'₃ a₂tsá₃ 'ein₂ tsɨ́'₃ 'i₁jan₂ 'e₂ a₂ca₂jág₃ jaun₂, a₂jmo₃ tei₄ ca₂lia'₂ ca₂jen'₅₄ táng₃ Jaun₅ dsa₂ mɨ₂güɨ́g₃ ne₄ 'mú₃. 
\p  
\v 10 Jaun₂ në́₃ tei₄ bá₄ ca₂jmo₃, tsá₃ 'ein₂ ca₂tsɨ́'₃, jŋia'₅₄ lia'₂ qui₂ca₂ŋɨ́i'₃ rɨin'₅₄ 'e₂ jein₅ jág₁ jaun₂ a₂jein'₅₄ ne₄ 'mú₃.  
\v 11 Jaun₂ ca₂ŋɨ́i'₃ Jesús: 
\p ―¿'E₂ lë₃ juá'₂ të₅juá'₅, Elías bá₄ i₂ca₂tɨ́n₂ jiá₃ le₂'uɨg₅₄? 
\p  
\v 12 Jaun₂ ca₂ŋag₃: 
\p ―Dsón'₂ bá₄ jaun₂ Elías bá₄ i₂jiá₃ le₂'uɨg₅₄, a₂jmóg'₃ ca₂le₃jë́₃. ¿'E₂ guë'₂ lë₃ jaun₂ chi₁ton₅ ne₄ Si₂ a₂ca₂tɨ́n₂ Jaun₅ dsa₂ mɨ₂güɨ́g₃ a₂tsá₃ caun₂ dsɨ₃ŋɨ́i₂, tsá₃ guei₃ dsa₂, 'liog'₃ dsa₂ 'uë₃ co₂ŋɨ́₂?  
\v 13 La₁ jniá₂ juá'₅, i₂ma₂guan₅ bá₄ Elías, qui₂ca₂jmóg'₂ dsa₂ ca₂lia'₂ lë́₂ dsɨ́₅, lia'₂ con'₂ lë́₅ chi₁ton₅ ne₄ Si₂. 
\s1 Ca₂jme₃'lión₂ Jesús jan₂ chi'₂ i₂jme₁'en₅₄ i₂'lɨn'₅₄ të₂dsɨ́₅ 
\r (Mateo 17:14-21; Lucas 9:37-43) 
\p  
\v 14 Jme₁co₂lág₂ jaun₂, ca₂dsi₃lein₃ ja₁tion'₅₄ rɨin'₅₄. Jaun₂ ca₂jɨ́in₂ juɨn₅ dsa₂ sián'₂ tion'₅₄ le₃lág'₃ jaun₂. Tion'₅₄ të₅juá'₅ në́₃, tsɨin₂₃ quian'₅₄ 'éi₂.  
\v 15 Jaun₂ dsɨ₂juɨ₅ jme₁ca₂jág₃ dsa₂ ca₂le₃jɨ́in₃ ca₂jɨ́in₂ Jesús, ca₂i₃gó'₃ dsɨ́₅ 'ŋio₅ lɨn₃, jaun₂ i₃léin₂ i₁cuag₃ Diú₄.  
\v 16 Jaun₂ ca₂ŋag₃ Jesús: 
\p ―¿'E₂ jág₁ tsɨ₂jɨ́n'₂ 'nia'₂ quian'₅₄ dsa₂ në₅? 
\p  
\v 17 Jaun₂ ca₂ŋag₃ jan₂ dsa₂ i₂'en₅₄ jë₄ jaun₂: 
\p ―Të₅, la₂ jŋiag₅₄ chi'₂ quiáng₃ a₂'ein₅₄ jme₂dsí₂ 'lɨn'₅₄ i₂tsá₃ cuë₅ jmɨg₄ dsia₃ chi'₂ jág₁.  
\v 18 Chi₂jua'₂ 'a₂ guë'₂ já'₄ jmóg'₂, jmo₂₃ tón₂ 'uë₃. Qui₂'uë́'₅ chi'₂ jan₅ mɨ₂'o₅₄, qui₂quɨg'₂ mɨ₂jan₅₄ në́₃. Jmo₂₃ a₂rë₂'uá'₃ rë₂juɨ́₂ quió'₅ në́₃. Jaun₂ jme₁ma₂në₂juɨ́g₂ jniá₂ dsa₂ i₂quiang'₅₄ a₂jme₁dsein₂₃ i₂'lɨn'₅₄, la₁ tsá₃ tió'₅, juá'₂. 
\p  
\v 19 Jaun₂ ca₂ŋag₃ Jesús: 
\p ―¡'En₁ jmá'₃ tsá₃ 'e₂ 'én'₂ 'nia'₂ dsa₂ chan₂ jmɨg₄ në₃! ¿Je₂liá'₂ jmɨg₄ jmá'₃ 'nió'₅ jmo₅₄ jniá₂ tió₅ dsɨ₃ ŋɨ₅₄ quian'₅₄ 'nia'₂? O₂quiain₅ 'nia'₂. 
\p  
\v 20 Jaun₂ ca₂i₁quian₅₄ dsa₂ chi'₂ ca₂o₃jiog₃ ne₅₄. Jaun₂ dsɨ₂juɨ₅ jme₁ca₂jág₃ i₂'lɨn'₅₄ ca₂jɨ́in₂ Jesús, ca₂jmo₃ táng₃ i₃'ɨ́n₃ i₂bë'₅₄ qui₂ca₂ba₂ca₂lɨ́in'₂ 'uë₃, 'uë́'₅ jan₅ mɨ₂'o₅₄.  
\v 21 Jaun₂ ca₂ŋɨ́i'₃ jmei₂ chi'₂: 
\p ―¿Jma₂je₂liá'₂ jmɨg₄ jén'₅ le₂në₅? 
\p Jaun₂ ca₂ŋag₃: 
\p ―Lia'₂ con'₂ bɨn'₅₄ bá₄ i₂në₅.  
\v 22 'Lióng₂ ráun₂ ma₂jmo₃ a₂'nio₃ 'í₂ né'₃ si₂, 'nio₃ 'í₂ né'₃ jmɨ́g₃ në́₃, a₂jmóg'₂ i₂'lɨn'₅₄ a₂'nio₃ jŋag'₃. La₁ në₁jua'₂ cha₂ a₂lé₂ le₃jmó'₂, dsia₄ ŋéi₂ 'au'₂ jnia'₅₄. 
\p  
\v 23 Jaun₂ ca₂juá'₂ Jesús: 
\p ―¿'A₂ bá₄ lia'₂ jaun₂ “chi₂jua'₂ cha₂ a₂lé₂?” Lé₂ bá₄, quió'₅ ca₂le₃jɨ́n₃ i₂'én₂. 
\p  
\v 24 Dsɨ₂juɨ₅ le₂jaun₂ ca₂ŋag₃ jmei₂ i₂bë'₅₄ ca₂juá'₂ tiá₂: 
\p ―¡'Én₂ bá₄ jniá₂! ¡Jme₁'o₁ jaun₂ le₃'éng₂ guë́₄! 
\p  
\v 25 Jme₁ca₂jág₃ Jesús caun₂ qui₂ca₂ŋɨ'₂ juɨn₅ lɨn₃ guë́₄ dsa₂, jaun₂ guë́₄ ca₂jéin₂ i₂'lɨn'₅₄, ca₂juá'₂: 
\p ―Jú₅ ja₁në₅, 'ne₂ jme₂dsí₂ i₂jmo'₂ con₄ güɨn₄ chi'₂. Ca₂lia'₂ o₁lɨ́g'₂ jmɨg₄ tsá₃ ma₃'ú'₄ ja₁në₅, ia₁ jniá₂ juá'₅. 
\p  
\v 26 Jaun₂ jme₁ca₂o₃'ɨ́n₃ i₂'lɨn'₅₄, ca₂jmo₃ guë́₄ cón'₂ ca₂guió'₃ chi'₂ 'éi₂, ca₂i₃'ɨ́in₃, ca₂ba₂ca₂lɨ́in'₂ 'uë₃, ca₂quiog₂ tsá₃ lí'₄. “Ca₂join₃ bá₄”, ca₂juá'₂ mei'₂ tsá₃ ca₂le₃jɨ́n₃ dsa₂ i₂ca₂jág₂.  
\v 27 Jaun₂ ca₂'ɨ́n₃ Jesús mɨ₂gu₂, ca₂chó'₂, jaun₂ ca₂nau₂ chi'₂. 
\p  
\v 28 Jaun₂ jme₁ma₂'í₅ Jesús caun₂ dsi₂néi₂, ja₁jaun₂ ca₂ŋag₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ con'₂ guioin₅₄: 
\p ―¿'E₂ 'uɨg₅₄ tsá₃ ca₂tián₃ jnia'₅₄ a₂dsén₄ i₂'lɨn'₅₄? 
\p  
\v 29 Jaun₂ ca₂ŋag₃ Jesús: 
\p ―Jme₂dsí₂ 'lɨn'₅₄ i₂le₂në₅ lé₂ le₃'uɨ́in₃ jmá'₃ lia'₂ quian'₅₄ a₂chi₂lén'₂ dsa₂ Diú₄.\f + \fr 9:29 \ft A₂lɨn₅₄ chog₅₄ si₂ juá'₂: “a₂chi₂len'₂ dsa₂ Diú₄, a₂jme₂'ɨin₅₄ në́₃.” \f* 
\s1 Ca₂'ë́₂ táng₃ Jesús jág₁ a₂jóin₂ 
\r (Mateo 17:22-23; Lucas 9:43-45) 
\p  
\v 30 Jme₁ca₂'uɨin₂ juɨg₂ jaun₂, ca₂i₃lein₃ táng₃, ca₂ŋɨi₅ juɨ₅ 'uë₃ Galilea, tsá₃ jme₁'nio₃ Jesús le₃ŋi₅ dsa₂,  
\v 31 ia₁ jme₁jme₂tɨin₂₃ chi'₂ dsɨ₂guia₃-tɨ́n₂, ca₂juá'₂: 
\p ―Ja₂quián₃ jmɨg₄ a₂jáng'₂ dsa₂ jɨ́in'₂ Jaun₅ dsa₂ mɨ₂güɨ́g₃ o₄gú₃ dsa₂ i₂'iog₅₄ jaun₂ jŋag'₃ dsa₂. La₁ a₂'nɨ₅ jmɨg₄, jein'₅₄ bá₄ táng₃. 
\p  
\v 32 La₁ chi'₂ dsɨ₂guia₃-tɨ́n₂ në́₃, tsá₃ ca₂ŋɨ́i'₂ 'e₂ jein₅ jág₁ a₂juá'₂ le₂jaun₂, ton'₂ tsá₃ ma₃ca₂tiá₃ dsɨ́₅ jua'₅₄ a₂ŋag₃ guë́₄ 'e₂ ŋag₃. 
\s1 Tsɨn₅ chi'₂ dsɨ₂guia₃-tɨ́n₂ 'ein₂ bá₄ i₂lɨ́n₅ i₂dsen₅₄ guë́₄ con'₂ quiain'₅₄ rɨin'₅₄ 
\r (Mateo 18:1-5; Lucas 9:46-48) 
\p  
\v 33 Jaun₂ ca₂dsi₃léin₂ juɨg₂ Capernaum. Jme₁ma₂tiáin'₅ dsi₂néi₂, jaun₂ ca₂ŋɨ́'₃ Jesús chi'₂ dsɨ₂guia₃-tɨ́n₂, ca₂juá'₂: 
\p ―¿'E₂ jág₁ tsɨ́n'₂ 'nia'₂ ja₂nóg'₅ le₂'i₄ juɨ₅? 
\p  
\v 34 La₁ tei₄ bá₄ ca₂tiáin'₂, tsá₃ 'e₂ ca₂ŋag₃, ia₁ le₂'i₄ juɨ₅ ja₂lein₃ tsɨin₂₃ 'ein₂ dsón'₂ i₂lén₂ i₂dsen₅₄ guë́₄ jë₄ quió'₅ rɨin'₅₄.  
\v 35 Jaun₂ ca₂guá₂ Jesús, jaun₂ ca₂të́'₃ ta₁guia₃-tɨ́n₂ 'éi₂, jaun₂ ca₂juá'₂: 
\p ―Chi₂jua'₂ 'ein₂ 'nia'₂ 'nio₃ lén₂ i₂le₂'uɨg₅₄, cán₂ ne₄ juɨ₅, 'nió'₅ léin₂ i₂jë₁ca₂tó'₂ quió'₅ ca₂le₃jɨ́n₃, jme₂ti₃ ta₁ ne₄ ca₂le₃jɨ́n₃ rɨin'₅₄. 
\p  
\v 36 Jaun₂ në́₃ ca₂cain₃ jan₂ guein₂ quián₅ dsa₂, jaun₂ ca₂dsiain₃ 'éi₂ jë₄ quió'₅, jaun₂ ca₂jŋau'₃, ca₂juá'₂: 
\p  
\v 37 ―Juɨ₁'ein₂ guë́₃ i₂guen₅ jan₂ guein₂ bë'₅₄ le₂la₂ o₄quió₃ jniá₂, jniá₂ bá₄ guei₂₃. I₂guei₅ jniá₂, on₃jua'₅₄ jmá'₃ jniá₂ guei₂₃. Guein₂₃ le₂jiog₅ i₂ca₂chei₃ jniá₂. 
\s1 “I₂tsá₃ 'iog₅₄ jniog₄, të₂le₃ quián₂ jniog₄ bá₄ chéin'₅” 
\r (Mateo 10:42; Lucas 9:49-50) 
\p  
\v 38 Jaun₂ ca₂juá'₂ Juan₅₄: 
\p ―Të₅, në₂jɨn₄ jnia'₅₄ jan₂ dsa₂ i₂në₂'uɨ́n'₂ je₂na'₅₄ quian'₅₄ bí₂ 'éi'₃ quiáng'₂. Tsá₃ ma₃në₂cuë́₁ jnia'₅₄ jmɨg₄ jua'₅₄ a₂jmo₃ guë́₄ le₂jaun₂, ia₁ tsá₃ ŋɨ₂₃ guë'₂ quian'₅₄ jniog₄. 
\p  
\v 39 Jaun₂ ca₂juá'₂ Jesús: 
\p ―Tsá₃ jmó'₂ 'nia'₂ le₂jaun₂, jua'₅₄ a₂jnɨg'₅₄. Ia₁ 'i₁jan₂ tsá₃ jmo₅ caun₂ ta₁ juë'₂ lia'₂ con'₂ lë́₅ 'éi'₃ quió₃ jniá₂, jua'₅₄ a₂lé₂ le₃dsia₃ 'ag₃ 'lɨg'₅₄ dsɨ₂juɨ₅ le₂jaun₂.  
\v 40 Ia₁ juɨ₁'ein₂ guë́₃ juɨ₁lia'₂ i₂tsá₃ 'iog₅₄ jniog₄, i₂tión₂ të₂le₃ quián₂ jniog₄ bá₄ 'éi₂.  
\v 41 Ia₁ në₁jua'₂ 'ein₂ ca₂cuë́'₃ 'nia'₂ tsá₃ a₂léi'₂ o₁jŋia'₅₄ caun₂ vaso jmɨg₂ bá₄, ia₁ a₂tén'₅ 'nia'₂ të₂le₃ quió'₅ I₂rë₂'ɨ́n₁ quián₅ Diú₄, a₂dsɨ₂jó'₃ juá'₅ jniá₂, lí'₂ bá₄ 'liain'₅₄. 
\s1 A₂go'₂ tsɨ₃sén'₂ dsa₂ dso₄ 
\r (Mateo 18:6-9; Lucas 17:1-2) 
\p  
\v 42 ’Juɨ₁'ein₂ guë́₃ i₂jmo₅ tsɨ₂sén'₂ dso₄ juɨ₁lia'₂ i₂me'₂ le₂la₂ i₂'én₂ të₂le₃ quió₃ jniá₂, ja₂lɨn₃ guë́₄ dse₃ co₂ŋei'₅₄ jua'₅₄ a₂tón₂ dsa₂ ne₄ jmɨ₁ŋí'₄ rë₂quein₅ ca₂mɨ́g₂ nɨ₁to₂ dsɨ₂lag₅₄.  
\v 43 Në₁jua'₂ mɨ₂gog'₂ jmo₅ a₂tang'₂ dso₄, co₂ŋei'₅₄ guë́₄ dse₃ 'nia₄, ia₁ ja₂lɨn₃ guë́₄ dse₃ dsiáng'₄ 'nau₅₄ caun₂ gog'₂ ja₁le₃chang'₂ co₂tan₅₄, con'₂ guë́₄ a₂jme₁dsiáng'₄ guio₃-juɨ́g₃ a₂rë₂'ŋia₅ ta₁tɨn₃ gog'₂ ja₁tsá₃ lɨ́g'₂ jmɨg₄ éi₃ si₂.\f + \fr 9:43 \ft A₂lɨn₅₄ chog₅₄ si₂ chi₁ton₅ versículo 44, ja₁juá'₂ co₂rë₂ quian'₅₄ versículo 48.\f* 
\v 45 Në₁jua'₂ mɨ₂tag'₅₄ jmo₅ a₂tang'₂ dso₄, 'nia₄ ján₃, ia₁ ja₂lɨn₃ guë́₄ dse₃ dsiáng'₄ guiang'₅₄ ja₁le₃chang'₂ co₂tan₅₄, lia'₂ con'₂ guë́₄ a₂jme₁dsiáng'₄ a₂rë₂'ŋia₅ le₃tɨn₃ tag'₅₄ guio₃-juɨ́g₃, ja₁tsá₃ lɨ́g'₂ jmɨg₄ éi₃ si₂.\f + \fr 9:45 \ft A₂lɨn₅₄ chog₅₄ si₂ chi₁ton₅ versículo 46, ja₁juá'₂ co₂rë₂ quian'₅₄ versículo 48.\f* 
\v 47 Chi₂jua'₂ mɨ₂ne'₅₄ jmo₅ a₂tang'₂ dso₄, co₂ŋei'₅₄ guë́₄ dse₃ dsi₄ ján₃, ia₁ ja₂lɨn₃ guë́₄ dse₃ a₂dsiáng'₄ a₂teng'₅₄ ca₂mɨ́g₂ mɨ₂ne'₅₄ ja₁gon₂ Diú₄, lia'₂ con'₂ guë́₄ a₂jme₁dsiáng'₄ a₂rë₂'ŋia₅ ta₁tɨn₃ mɨ₂ne'₅₄ guio₃-juɨ́g₃: 
\q1  
\v 48 ja₁tsá₃ lɨ́g'₂ jmɨg₄ dsián₃ i₁ja'₅₄, 
\q2 on₃ guë'₂ si₂ éi₃ në́₃.\f + \fr 9:48 \ft Isaías 66:24.\f* 
\p  
\v 49 ’Ia₁ ca₂le₃jɨ́n₃ bá₄ 'nió'₅ lé₂ 'í₁ të₂le₃ quian'₅₄ uɨg₅ a₂lë́₅ lia'₂ lë́₅ si₂.\f + \fr 9:49 \ft lit. “Ia₁ ca₂le₃jɨ́n₃ 'nió'₅ le₃ŋi'₅₄ quió'₅ quian'₅₄ si₂.” 'Nio'₂ ja₁ton₅ 1 Pedro 1:7; 4:12.\f* 
\v 50 Dse₃ bá₄ tsɨ₁ŋi₁ të₁lia'₂ ŋi'₅₄, la₁ në₁jua'₂ ca₂'en₃ ŋi'₅₄ tsɨ₁ŋi₁ në́₃, ¿'A₂ bá₄ lia'₂ lé₂ le₃lei₂ táng₃? Jaun₂ juɨ₁len'₅₄ bá₄ 'nia'₂ juɨ₁lia'₂ lë́₅ tsɨ₁ŋi₁. Juɨ₁le₂chan'₂ bá₄ 'nia'₂ 'ei₅ tei₄ quian'₅₄ rɨ́ng'₂ le₂jang'₂ le₂jang'₂. 
\c 10  
\s1 Jme₂tag₅ Jesús juɨ₁lia'₂ 'a₂ lia'₂ lë́₅ a₂tén₂ dsa₂ dsɨ₂i₂gu₂ 
\r (Mateo 19:1-12; Lucas 16:18) 
\p  
\v 1 Jaun₂ ca₂o₃'ɨ́n₃ Jesús juɨg₂ Capernaum ja₁jme₁'ein₅₄, ca₂ŋó₃ táng₃ ja₁tén₄ Judea quian'₅₄ juɨ₅ 'uë₃ të₂le₃ 'ŋo'₅₄ Cuá₃ Jordán. Ja₁jaun₂ ca₂o₃lén₂ táng₃ dsa₂ juɨn₅ ja₁'ein₅₄. Con'₂ siá'₂ táng₃ ca₂jmo₃ juɨ₁lia'₂ jmo₂₃ tián₂, ca₂jme₃tɨin₂₃ dsa₂.  
\v 2 Jaun₂ ca₂dsi₃lén₂ i₂lɨn₅₄ dsa₂ fariseos, ca₂ŋɨ́i'₃ Jesús a₂jŋia'₅₄ con'₂ 'nio₃ cáun₂ táu₂ chi₂jua'₂ 'i₄ 'éi'₃ a₂tén₂ dsa₂ dsa₂ mɨ́₂ quiáin₅.  
\v 3 Jaun₂ ca₂ŋag₃ 'éi₂: 
\p ―¿'E₂ 'éi'₃ ca₂cuë₃ Moisés guë'₂? 
\p  
\v 4 Jaun₂ ca₂ŋag₃ táng₃ dsa₂ 'éi₂: 
\p ―Ca₂cuë₃ Moisés jág₁ a₂lé₂ le₃jmo₃ dsa₂ ŋe'₂ caun₂ si₂ të₃ron₅₄, jaun₂ guë́₄ ma₂lé₂ dsei₂₃. 
\p  
\v 5 Jaun₂ ca₂ŋag₃ Jesús: 
\p ―'Uɨg₅₄ ia₁ a₂ŋɨ́₄ tsá₃ nág'₁ 'nia'₂ guiong'₅₄ bá₄ ca₂cuë₃ Moisés 'éi'₃ jaun₂,  
\v 6 La₁ le₂'uɨg₅₄ lia'₂ con'₂ jme₁ca₂dsia₃ Diú₄ mɨ₂güɨ́g₃, “ca₂jmói'₂ dsa₂ ŋe'₂, dsa₂ mɨ́₂”.  
\v 7 “'Uɨg₅₄ jaun₂ në́₃ dsa₂ ŋe'₂, ca₂tɨ́in₂ téin₂ chog₅₄-jmei₂, con'₂ tiain'₃ quiain'₅₄ dsa₂ mɨ́₂ quiáin₅.  
\v 8 Jaun₂ jë₁le₃oin₃ léin₂ caun₂ bá₄ nɨ₁ŋɨ́₅.”\f + \fr 10:8 \ft Génesis 2:24.\f* Jaun₂ dsióg₄ lé₂ co₂'nió'₄ jan₂ dsa₂ bá₄, tsá₃ ma₂lë́₂ oin₃.  
\v 9 Jaun₂ tsá₃ 'i₄ 'éi'₃ jua'₅₄ dsa₂ mɨ₂güɨ́g₃ a₂jmo₃ jma₃quén₅ a₂ma₂dsia₃ Diú₄ rë₂. 
\p  
\v 10 Jme₁ma₂tioin'₅₄ táng₃ dsi₂néi₂, ca₂ŋag₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ ca₂ŋɨ́i'₃ Jesús jág₁ në₅.  
\v 11 Jaun₂ ca₂juá'₂ Jesús: 
\p ―Dsa₂ i₂tén₂ 'io₅₄ quián₅, a₂guá₃ táng₃ quiain'₅₄ i₂sián'₂, 'no₂₃ dso₄ ja₁con₂ 'io₅₄ quiáin₅ i₂le₂'uɨg₅₄.  
\v 12 Con'₂ guë'₂ siá'₂ táng₃ në₁jua'₂ tén₂ 'io₅₄ dsɨ₂i₂gu₂ a₂guá₃ táng₃ quiain'₅₄ dsa₂ ŋe'₂ sián'₂, ján₃ bá₄ le₂jaun₂ 'no₂₃ dso₄ ja₁con₂ dsɨ₂i₂gu₂. 
\s1 Ca₂jme₃gon'₅₄ Jesús chi'₂-guein₂ 
\r (Mateo 19:13-15; Lucas 18:15-17) 
\p  
\v 13 Jaun₂ ca₂dsi₃lén₂ dsa₂ le₁jŋiai₂₃ chi'₂ quiáin₅ ja₁guá₄ Jesús, ia₁jaun₂ qui₃téi₂ Jesús gu₂. La₁ chi'₂ dsɨ₂guia₃-tɨ́n₂ në́₃ ca₂jí₂.  
\v 14 Jme₁ca₂jág₃ Jesús, jaun₂ ca₂i₃méi'₂ dsɨ́₅ quian'₅₄ chi'₂ dsɨ₂guia₃-tɨ́n₂, jaun₂ ca₂juá'₂: 
\p ―Cuë₄ 'nia'₂ jmɨg₄ juɨ₁ja₂lén₂ chi'₂-guein₂ cong₂. Tsá₃ jmó₁ 'nia'₂ le₂në₅ jua'₅₄ a₂jnɨg'₅₄, ia₁ juɨ₁lia'₂ i₂le₂la₂ bá₄ guë'₂ i₂dsɨ₂len₅ ja₁gon₂ Diú₄.  
\v 15 A₂dsɨ₂jó'₃ juɨ́g₂ jniá₂ 'nia'₂, ia₁ juɨ₁'ein₂ guë́₃ i₂tsá₃ gue₅ 'éi'₃ quió'₅ Diú₄, juɨ₁lia'₂ gue₅ jan₂ i₂bë'₅₄, o₁lɨ́g'₂ tsá₃ dsi₁lein₅ ja₁gon₂ Diú₄. 
\p  
\v 16 Jaun₂ qui₂ca₂jŋai'₃ guein₂ 'ein₅₄, ca₂quiog₂ gu₂ ne₄ quió'₅, ca₂jme₃jŋió₃. 
\s1 Jan₂ dsó₂ chi'₂ cha₂ cu₄ ca₂dsia₃ jág₁ quiain'₅₄ Jesús 
\r (Mateo 19:16-30; Lucas 18:18-30) 
\p  
\v 17 Jme₁ma₂'en₅₄ Jesús juɨ₅ ŋó₅ táng₃, jaun₂ já₃ jan₂ dsó₂ co₂chi'₅₄ ca₂jme₃jein'₂ ca₂chi₃jné₃ ne₅₄. Jaun₂ ca₂ŋag₃: 
\p ―Të₅ dsen₃, ¿'e₂ 'nió'₅ jmo₅₄ jniá₂ ia₁jaun₂ tɨng₅₄ ja₁le₃chang₂ co₂tan₅₄? 
\p  
\v 18 Jaun₂ ca₂ŋag₃ Jesús: 
\p ―¿'E₂ lë₃ quiong'₅₄ jniá₂ a₂dseng₃? 'I₁jan₂ i₂dsen₃ tsá₃ chan₂, jŋia'₅₄ lia'₂ jan₂ Diú₄ bá₄.  
\v 19 Cuɨng'₂ bá₄ 'Éi'₃ Juá'₅ quió'₅ Diú₄, ja₁juá'₂ tsá₃ jme₁dsiang'₂ dsa₂ mɨ₂güɨ́g₃ rɨ́ng'₂; on₃ guë'₂ nióg'₄ jág₁ quian'₅₄ dsa₂ i₂tsá₃ lɨ́n₅ dsɨ₂i₂gog'₂; on₃ guë'₂ 'áng'₁. Tsá₃ jmó₁ jua'₅₄ jang'₅₄ jág₁ të₂jág₁; tsá₃ jme₁gan₅ dsa₂ jua'₅₄ a₂jŋiá'₄ a₂cha₂ quió'₅; a₂jme₁gang'₃ chog'₂-ŋéi'₅ në́₃.\f + \fr 10:19 \ft Éxodo 20:12-6; Deuteronomio 5:16-20.\f* 
\p  
\v 20 Ca₂ŋag₃ táng₃ dsa₂ 'éi₂: 
\p ―Të₅, ca₂le₃jë́₃ a₂në₅, lia'₂ con'₂ bɨn'₅₄ bá₄ jniá₂ jme₂tí₁. 
\p  
\v 21 Jaun₂ ca₂jág₂ Jesús ŋéi₂ dsɨ́₅, ca₂juá'₂: 
\p ―Caun₂ guë́₄ a₂'nió'₅ quiáng'₂. Guan'₂ o₂'nag₄ ca₂le₃jë́₃ a₂cha₂ quiáng'₂, o₂dsio'₅₄ cu₄ jaun₂ o₂cuë'₅₄ dsa₂ te₂ŋé₂. Jaun₂ guë́₄ le₃cha₂ a₂jlá'₁ quiáng'₂ guei'₅₄ i₂juɨ́g₃. Jaun₂ guë́₄ ŋia₅, 'éin₃.\f + \fr 10:21 \ft A₂lɨn₅₄ chog₅₄ si₂ juá'₂: “Jmo₄ co₂jŋiag'₅₄ a₂jóng'₂,” (lit. quian₂ cróg₄ quiáng'₂), “'éin₃ jniá₂.” \f* 
\p  
\v 22 Jaun₂ ca₂tá'₂ jén₂ dsɨ́₅ dsa₂ 'éi₂ jme₁ca₂nág₂ le₂në₅; ŋái'₅ bá₄ jaun₂ 'lia'₂ dsɨ́₅, ia₁ 'ŋio₅ lɨn₃ jme₁cha₂ cu₄. 
\p  
\v 23 Jaun₂ ca₂jén'₃ Jesús qui₂ca₂jɨ́in₂ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅. Jaun₂ ca₂juá'₂: 
\p ―¡'E₂ guë́₄ 'ŋio₅ quian₅ ta₁ quió'₅ dsa₂ cha₂ cu₄ a₂tɨ́in'₄ ja₁gon₂ Diú₄! 
\p  
\v 24 Jaun₂ i₃gó'₃ dsɨ́₅ chi'₂ dsɨ₂guia₃-tɨ́n₂ jág₁ jaun₂, la₁ ca₂juá'₂ táng₃ Jesús: 
\p ―'Nia'₂ jón₃, ¡'e₂ bá₄ 'ŋio₅ quian₅ ta₁ a₂dsi₁len₅ dsa₂ ja₁gon₂ Diú₄!\f + \fr 10:24 \ft Cha₂ a₂lɨn₅₄ chog₅₄ si₂ a₂juá'₂ le₂la₂: “a₂dsi₁len₅ dsa₂ cha₂ cu₄ ja₁gon₂ Diú₄.” \f* 
\v 25 Tsá₃ guë́₄ 'e₂ ta₁ quian₅ a₂lé₂ le₃ŋɨ₅ jan₂ já'₂ camello juɨ₅ tau₂ mɨ₂cu₄, con'₂ guë́₄ dsa₂ cha₂ cu₄ a₂'í₂ ja₁gon₂ Diú₄. 
\p  
\v 26 Jme₁ca₂nág₂ chi'₂ dsɨ₂guia₃-tɨ́n₂ a₂në₅, i₃gó'₃ dsɨ́₅ 'ŋio₅ lɨn₃. Qui₂ca₂ŋɨ́i'₃ rɨin'₅₄: 
\p ―¿I₂'ein₂ bá₄ guë'₂ jaun₂ në́₃ i₂lé₂ le₃tɨ́n'₄? 
\p  
\v 27 Jaun₂ ca₂jág₂ Jesús, jaun₂ ca₂juá'₂: 
\p ―Dsón'₂ bá₄ jaun₂, të₂le₃ quió'₅ dsa₂ mɨ₂güɨ́g₃, o₁lɨ́g'₂ tsá₃ lé₂ le₃lé₂. La₁ të₂le₃ quió'₅ Diú₄, ca₂le₃jë́₃ bá₄ lé₂ le₃lé₂. 
\p  
\v 28 Pe₄ në́₃ ca₂jme₃lióg₃ ca₂juá'₂: 
\p ―Te₁gui'₅₄, ca₂le₃jë́₃ 'e₂ a₂jme₁cha₂ quián₂ jnia'₅₄, ma₂ca₂tén'₂ dsɨ₅ jnia'₅₄ ma₂qui₂ma₂tí₄, ia₁ a₂'én₅ jnia'₅₄ 'ne₂. 
\p  
\v 29 Jaun₂ ca₂ŋag₃ Jesús: 
\p ―A₂dsɨ₂jó'₃ juá'₅ jniá₂ juɨ́g₂ 'nia'₂, ca₂le₃jɨ́n₃ i₂táun₂ 'ne₄, i₂tén₂ rɨn'₅₄, chog₅₄-jmei₂, chi'₂ quiáin₅, i₂tí₂ ja₁nau₂ quió'₅, 'uɨg₅₄ quió₃ jniá₂, quian'₅₄ 'uɨg₅₄ quió'₄ jág₁ dse₃ në́₃,  
\v 30 gue₃ mɨ₂güɨ́g₃ la₂ 'lióng₂ guë́₄ 'né₅, juɨn₅ guë́₄ rɨin'₅₄, juɨn₅ guë́₄ chog₅₄, juɨn₅ guë́₄ chi'₂-guein₂ quiáin₅ në́₃ le₃chan₂; ton'₂ 'lióng₂ guë́₄ ja₁nau₂ quió'₅ le₃cha₂, o₁jŋia'₅₄ la₂ chain₂ mɨ'₅₄ co₂'ein₅ dsa₂. La₁ia₁ gue₃ ja₁le₃chain₂ co₂tan₅₄ mɨ₂güɨ́g₃ caun₂.  
\v 31 La₁ rë₂në́₃, juɨn₅ i₂lɨ́n₅ i₂quen₅, la₁ jmɨg₄ jaun₂ léin₂ dsa₂ të₂le₃ jë₁ca₂tó'₂; le₂jaun₂ bá₄ ján₃, juɨ₁lia'₂ i₂tsá₃ 'e₂ quen₅ rë₂në́₃ lia'₂ con'₂ niog₅ lɨ́n₂ dsa₂ mɨ₂güɨ́g₃, léin₂ i₂le₂'uɨg₅₄. 
\s1 Con'₂ siá'₂ táng₃ ca₂'ë́₂ Jesús jág₁ a₂jóin₂ 
\r (Mateo 20:17-19; Lucas 18:31-34) 
\p  
\v 32 Tioin'₅₄ juɨ₅ uɨ́g₂ tso₄ a₂dsi₁léin₂ Jerusalén. Jesús në́₃ ŋó₃ dsɨ₂jŋiái₄ ne₄ juɨ₅. Chi'₂ dsɨ₂guia₃-tɨ́n₂ guë'₂ i₂léin₂ dsɨ₂gó'₃ dsɨ́₅. Ca₂le₃jɨ́n₃ guë́₄ dsa₂ i₂jme₁quiain'₅₄ në́₃ i₂léin₂ gó'₅. Jaun₂ në́₃ ca₂të́'₃ Jesús le₃cau₅ juɨ₅ jmá'₃ dsɨ₂guia₃-tɨ́n₂, jaun₂ ja₁jaun₂ ca₂juá'₂ 'e₂ niog₅ dsɨ₃ŋɨ́i₂,  
\v 33 ca₂juá'₂: 
\p ―Ŋí₂ 'nia'₂ jaun₂, tio'₅₄ jniog₄ juɨ₅ uɨg₂ tso₄ a₂dsi₁náu₅ Jerusalén. Ja₁jaun₂ jɨ́n'₂ dsa₂ Jaun₅ dsa₂ mɨ₂güɨ́g₃ o₄gú₃ juɨg₅₄ jme₂dsa₂, ne₄ të₅juá'₅ në́₃. I₂'éi₂ dsí₃ 'éi'₃ a₂jŋag'₃ dsa₂, jaun₂ jáng'₂ dsa₂ o₄gú₃ dsɨ₂nau₂ në́₃.  
\v 34 'Éi₂ në́₃ a₂lë₁qui₃jmóg'₂, qui₃cuë₃, qui₃'ŋéi₂ dsa₂ në́₃. Jaun₂ guë́₄ jŋag'₃. La₁ a₂'nɨ₅ jmɨg₄, jein'₅₄ bá₄ táng₃. 
\s1 A₂ca₂mɨ₃ Jacobo quian'₅₄ Juan₅₄ 
\r (Mateo 20:20-28) 
\p  
\v 35 Jaun₂ në́₃, Jacobo quian'₅₄ Juan₅₄, le₃on₃ ja₁ŋi'₅₄ Zebedeo, ca₂jme₃quiáin₃ ja₁chén'₄ Jesús, jaun₂ ca₂juá'₂: 
\p ―Të₅, 'niog₂ jnia'₅₄ jmó'₂ 'ne₂ dse₃ 'au'₂ a₂jmó'₂ juɨ₁'e₂ caun₂ a₂mɨ́₁ jnia'₅₄. 
\p  
\v 36 Jaun₂ ca₂juá'₂ Jesús: 
\p ―¿'E₂ 'niog'₂ 'nia'₂ jmo₅₄ jniá₂ guë'₂? 
\p  
\v 37 Jaun₂ ca₂juá'₂ táng₃ 'éi₂: 
\p ―Jmó'₂ 'io₄ jnia'₅₄ jma₃jáu₃ lia'₂ ca₂ton₂ cau₅ quiáng'₂ jë₁ma₂të́₂ rë₁ne'₅₄ jláng'₁ ne₄ta₁ quiáng'₂. 
\p  
\v 38 Jaun₂ ca₂ŋag₃ Jesús: 
\p ―Tsá₃ a₂jaun₂ ŋi'₅₄ 'nia'₂ a₂mɨ'₂. ¿Tián'₃ 'nia'₂ dsɨ₃ŋɨ́g'₂ ca₂le₃jë́₃ juɨ₁lia'₂ a₂dsɨ₃ŋɨ́₂ jniá₂ guë'₂? ¿Tián'₃ 'nia'₂ cán'₁ o₂i₁ dsɨ₅ juɨ₁lia'₂ o₂i₁ dsɨ₅ can₅₄ jniá₂? 
\p  
\v 39 Jaun₂ ca₂ŋag₃ táng₃ 'éi₂: 
\p ―Tián₂ bá₄ jnia'₅₄. 
\p Ca₂juá'₂ táng₃ Jesús: 
\p ―Dsón'₂ bá₄ jaun₂ dsɨ₃ŋɨ́'₂ 'nia'₂ 'e₂ niog₅ dsɨ₃ŋɨ́₂ jniá₂. Ján₃ bá₄ cán'₁ 'nia'₂ o₂i₁ dsɨ₅ juɨ₁lia'₂ o₂i₁ dsɨ₅ can₅₄ jniá₂.  
\v 40 La₁ juɨ₁lia'₂ a₂juá'₂ 'nia'₂ a₂tiáng'₄ jma₃ca₂ton₂ cau₅ quió₃, on₃jua'₅₄ jniá₂ ca₂tɨ́ng₂ cuë₅₄ a₂jaun₂. Ja₁jaun₂ lë́₅ co₂jŋia₅₄ a₂tian'₃ con'₂ i₂ca₂tɨ́n₂ bá₄. 
\p  
\v 41 Rɨin'₅₄ i₂guian₃ guë́₄ 'éi₂ në́₃, ca₂rë₃'néi₃ quian'₅₄ Jacobo quian'₅₄ Juan₅₄, jme₁ca₂nág₂ juá'₂ 'éi₂ le₂në₅.  
\v 42 Jaun₂ ca₂të₃ Jesús cau₅ quió'₅ ca₂të́'₃ 'éi₂ ca₂le₃jɨ́n₃. Jaun₂ ca₂juá'₂: 
\p ―Ŋi'₅₄ bá₄ 'nia'₂ juɨ₁lia'₂ dsa₂ can'₅₄ i₂tián'₅ gon₂ juɨg₂ go₄ dsɨ₂nau₂, i₂jɨ́n₂ dsa₂ co₂'nió'₄ dsɨ₂tan₅₄ quiáin₅, qui₂toin'₂ dsa₂ 'éi'₃ bén₂. Le₂jaun₂ bá₄, juɨ₁lia'₂ dsɨ₂tan₅₄ i₂sion₅ guë́₄ quiáin₅ në́₃, tiáin'₅ goin₂ jmo₂₃ 'éi'₃.  
\v 43 La₁ jɨn'₄ 'nia'₂, tsá₃ le₂jaun₂ lé₂. Chi₂jua'₂ 'ein₂ 'nio₃ jmo₃ juɨn'₂, ca₂tɨ́in₂ jme₃ti₃ ta₁ ne₄ rɨin'₅₄;  
\v 44 chi₂jua'₂ 'ein₂ 'nia'₂ 'nio₃ cán₂ ne₄ juɨ₅, 'nió'₅ jme₃ti₃ ne₄ ca₂le₃jɨ́n₃ dsa₂.  
\v 45 Ia₁ le₂në₅ bá₄ Jaun₅ dsa₂ mɨ₂güɨ́g₃, tsá₃ ta₁ jaun₂ já₅ jua'₅₄ a₂jme₃ti₃ dsa₂ ne₅₄; a₂jme₃ti₃ ta₁ ne₄ dsa₂ bá₄ já₅, a₂quí₃ quian'₅₄ 'mú₃ 'lia'₅₄ ia₁jaun₂ tɨ́n'₄ juɨn₅. 
\s1 Ca₂jme₃'lión₂ Jesús jan₂ dsa₂ ten₄ i₂chen₂ Bartimeo 
\r (Mateo 20:29-34; Lucas 18:35-43) 
\p  
\v 46 Dsi₃léin₂ juɨg₂ Jericó. Jme₁o₂'ɨ́in₃ juɨg₂ jaun₂ quiain'₅₄ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅, juɨn₅ guë́₄ dsa₂ sián'₂ në́₃ quiong'₅₄, jaun₂ jan₂ dsa₂ ten₄ i₂chen₂ Bartimeo, (co₂'nió'₄ le₃jua'₅₄ ja₁ŋi'₅₄ Timeo), guá₅ 'éi₂ cau₅ juɨ₅ mɨ₂₃ a₂jme₃'o₅₄ dsa₂ cu₄.  
\v 47 Jme₁ca₂nág₂ juá'₂ dsa₂ ŋó₅ Jesús i₂chan₂ Nazaret cau₅ jaun₂, jaun₂ ca₂'í₃ co₂mɨ'₅₄ të́'₂ Jesús: 
\p ―¡Jesús, tsɨ₁jon₂ David, dsia₄ ŋéi₂ 'au'₂ jniá₂! 
\p  
\v 48 Jaun₂ ca₂jí₂ bá₄ dsa₂ ia₁jaun₂ dsó₃ tei₄. La₁ të₂le₃ i₂juɨ'₂ guë́₄ co₂mɨ'₅₄ ca₂'í₃ bá₄, ca₂juá'₂: 
\p ―¡Tsɨ₁jon₂ David, dsia₄ ŋéi₂ 'au'₂ jniá₂! 
\p  
\v 49 Jaun₂ ca₂nau₂ Jesús jme₁ca₂nág₂, jaun₂ ca₂tsɨ́'₃ dsa₂ i₂quiain'₅₄: 
\p ―Te'₂ 'nia'₂ o₁jia₂ ja₁lá₃. 
\p Jaun₂ ca₂të₃ dsa₂, ca₂juá'₂: 
\p ―Jmo₄ 'io'₂. Nau₂, ia₁ ó₃ të́₂. 
\p  
\v 50 Jaun₂ ca₂ton₃ cau₅ 'mɨ'₂ dsióg₂ jme₁chi₁bóin'₅, jaun₂ con'₂ ca₂nau₂ jaun₂ bá₄ co₂chi'₅₄, ca₂ŋó₃ ja₁chén'₄ Jesús. 
\p  
\v 51 Jaun₂ ca₂ŋag₃ 'éi₂: 
\p ―¿'E₂ 'niog'₂ jmo₅₄ jniá₂ o₄quiáng'₂? 
\p Jaun₂ ca₂ŋag₃ táng₃ dsa₂ ten₄: 
\p ―Të₅, a₂jnia₅₄ jme₁ne₃ bá₄ jniá₂ 'nio₃. 
\p  
\v 52 Jaun₂ ca₂juá'₂ Jesús: 
\p ―Ma₂lé₂ guang'₅₄. Ma₂'lóng'₂ ia₁ 'éng'₂ bá₄. 
\p Dsɨ₂juɨ₅ jaun₂ bá₄ ca₂jnia₃ mɨ₂ne₄ dsa₂ 'éi₂. Jaun₂ ca₂ŋó₃ quiain'₅₄ Jesús. 
\c 11  
\s1 Ca₂'í₃ Jesús jë₄ juɨg₂ Jerusalén 
\r (Mateo 21:1-11; Lucas 19:28-40; Juan 12:12-19) 
\p  
\v 1 Jme₁ma₂quián₅ dsi₁léin₂ Jerusalén, dsi₃léin₂ quián₅ juɨg₂ Betfagé quian'₅₄ juɨg₂ Betania në́₃, a₂niog₅ cau₅ Má'₂ Olivos. Ja₁jaun₂ ca₂chen₃ Jesús on₃ dsa₂ i₂guia₃-tɨ́n₂ quiáin₅,  
\v 2 ca₂juá'₂: 
\p ―O₂nó'₅ 'nia'₂ juɨg₂ pí'₁ niog₅ të₂le₃ ne₄ juɨ₅ ja₁dsau₅₄ në₅. Jë₁ma₂ca₂dsi₃nó'₅ 'nia'₂ ja₁jaun₂, dsian'₂ 'nia'₂ jan₂ bú'₄ 'mɨ́₂ i₂rë₂'ŋe'₅₄ i₂tsá₃ 'ein₂ ma₂co₁dsag₅₄. O₂chein'₅₄ 'nia'₂ jaun₂ të'₅₄ ja₁lá₃.  
\v 3 Në₁jua'₂ 'ein₂ ca₂juá'₂: “¿'E₂ lë₃ jmo'₂ 'nia'₂ le₂në₅?” jaun₂ juɨg'₅₄ 'nia'₂: “Te₁gui'₅₄ bá₄ 'nio₃ ca₂tiá₂, la₁ në₃ cón'₅ bá₄ jáng'₂ táng₃.” 
\p  
\v 4 Jaun₂ i₃lén₂ dsa₂ 'éi₂. Jme₁ca₂dsi₃léin₂ ja₁chén'₄ bú'₄ rë₂'ŋe'₅₄ jë₄ calle cau₅ o₄'né₄ quió'₅ dsa₂, jaun₂ ca₂chéi'₂ jaun₂ në́₃.  
\v 5 Jaun₂ ca₂juá'₂ i₂lɨn₅₄ dsa₂ i₂ca₂jág₃, i₂tión₂ cau₅ jaun₂: 
\p ―¿'E₂ jmo'₂ 'nia'₂ ja₁në₅? ¿'E₂ lë₃ tsɨng'₅₄ bú'₄? 
\p  
\v 6 Jaun₂ ca₂jéin'₃ bá₄ guë'₂ 'éi₂ jág₁ lia'₂ lë́₅ jág₁ ca₂cuë₃ Jesús. Jaun₂ ca₂cuë₃ bá₄ dsa₂ jmɨg₄ të₂ já'₂.  
\v 7 Jaun₂ jme₁o₃lein₃ te₂ bú'₄, ca₂i₁jiog₃ ja₁'en₅₄ Jesús, jaun₂ ca₂jmo₃ dse₃ qui₂ca₂jlág₂ 'mɨ'₂ mɨ₂ca'₄ já'₂. Jaun₂ guë́₄ ca₂co₃dsag₅₄ Jesús.  
\v 8 Juɨn₅ dsa₂ qui₂ca₂néi'₃ 'mɨ'₂ le₂'i₄ juɨ₅ ja₁ŋɨ́₃ Jesús. I₂lɨn₅₄ guë'₂ ca₂dsia₃ gu'₂-nei'₅₄ 'ma₂ a₂ca₂i₁'niai₁₂ ja₁nau₂. 
\p  
\v 9 Jaun₂ dsa₂ i₂i₂lén₂ le₃ne₄ juɨ₅ quian'₅₄ i₂ja₂lén₂ le₃chi₁co'₅₄ në́₃, qui₂ca₂tóin'₂ co₂mɨ'₅₄, ca₂juá'₂: 
\p ―¡Juɨ₁le₂juɨn'₂ bá₄ i₂në₅!\f + \fr 11:9 \ft lit. “Hosana”, a₂jein₅ jág₁ quian'₅₄ jág₁ jmei₅ arameo: “Lio₄ jnia'₅₄”, co₂'nió'₄ a₂qui₂mɨ₅ dsa₂ ne₄ Diú₄ a₂jiá₃ I₂rë₂'ɨ́n₁ quiáin₅; la₁ cang₂ jaun₂ táng₃ ca₂jein₃ jág₁ a₂jme₂juɨn'₂ dsa₂ jan₂ dsa₂.\f* ¡Juɨ₁le₂jŋió₃ bá₄ i₂në₅ i₂já₅ o₄quió'₄ Te₁gui'₅₄!\f + \fr 11:9 \ft Salmo 118:25-26.\f* 
\v 10 ¡Juɨ₁le₂jŋió₃ bá₄ 'éi'₃ a₂já₅ quió'₅ jmei₂ jniog₄ David në́₃! ¡Juɨ₁le₂juɨn'₂ bá₄ i₂guá₅ guei'₅₄ i₂juɨ́g₃! 
\p  
\v 11 Jme₁ca₂'í₃ Jesús juɨg₂ Jerusalén, jaun₂ ca₂'í₃ i₁dsi₅ guá'₅ templo. Jme₁ma₂në₂jág₃ 'a₂ lia'₂ lë́₅ ja₁jaun₂, ca₂o₃'ɨ́in₃, ca₂ŋái'₃ táng₃ juɨ₅ Betania quiain'₅₄ ca₂le₃jɨ́n₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅, ia₁ ma₂ca₂'láu₂. 
\s1 Ca₂juá'₂ Jesús jág₁ uɨg₅ ca₂tsɨ́'₃ nɨ₁'ma₂ higuera a₂tsá₃ mɨ́g₂ cha₂ 
\r (Mateo 21:18-19) 
\p  
\v 12 Jme₁jnia₃ jaun₂, con'₂ ma₂'uɨin₂ táng₃ juɨg₂ Betania, ca₂tá'₂ i₁cón'₅ Jesús.  
\v 13 Jaun₂ ca₂jág₃ të₂ uɨ́ng₂ caun₂ nɨ₁'ma₂ higuera, lia'₂ rë₂can'₂ mog'₅₄ jniá₂ chí'₅. Jaun₂ ŋó₃ 'uɨg₅₄ ja₁dsi₅₄, ia₁ lɨ́in₂ jme₁dsio'₂ mɨ́g₂. La₁ jme₁dsióg₃ në́₃, jmá'₃ mog'₅₄ bá₄ cha₂, ia₁ on₃jua'₅₄ jein₂ a₂'ag₅ mɨ́g₂ higos jaun₂.  
\v 14 Jaun₂ në́₃ ca₂juá'₂ Jesús ca₂tsɨ́'₃ nɨ₁'ma₂: 
\p ―Juɨ₁le₅₄ ca₂lia'₂ o₁lɨ́g'₂ jmɨg₄ tsá₃ ma₃'ein₂ guë́'₃ co₂ŋei'₅₄ mɨ́g₂ quiáng'₂. 
\p Ca₂nág₂ bá₄ chi'₂ dsɨ₂guia₃-tɨ́n₂ jme₁ca₂juá'₂ le₂në₅. 
\s1 Ca₂'uɨ́n'₂ Jesús dsa₂ i₂jme₁tion'₅₄ dsia₅ 'ma'₅₄ i₁dsi₅ guá'₅ 
\r (Mateo 21:12-17; Lucas 19:45-48; Juan 2:13-22) 
\p  
\v 15 Jme₁ca₂dsi₃léin₂ táng₃ juɨg₂ Jerusalén, ca₂'í₃ Jesús i₁dsi₅ guá'₅ templo, ca₂jme₃lióg₃ ca₂'uɨ́in'₂ ca₂le₃jɨ́n₃ dsa₂ i₂jme₁tion'₅₄ 'nag₅, i₂lá₅ në́₃. Jaun₂ qui₂ca₂jéin'₃ nɨ₁mesa jme₁jmó'₂ dsa₂ ta₁ ja₁jme₂tsɨ́in₃ cu₄, qui₂ca₂quɨ́'₂ 'ma₂sɨ₅₄ ja₁jme₁tián'₄ dsa₂ i₂'nɨ₅ i₁ju₂;  
\v 16 tsá₃ ma₃ca₂cuë₃ jmɨg₄ jua'₅₄ a₂dsɨ₃can₅ guë́₄ dsa₂ lio₄ quió'₅ i₁dsi₅ guá'₅. 
\p  
\v 17 Jaun₂ ca₂jme₃tɨin₂₃ dsa₂ 'éi₂, ca₂juá'₂: 
\p ―Ne₄ Si₂ juá'₂: “'Né₅ quió₃ lë́₅ ca₂ne₅₄ 'né₅ ja₁chi₂lén'₂ dsa₂ Diú₄, dsa₂ chan₂ ca₂le₃jë́₃ juɨg₂.”\f + \fr 11:17 \ft Isaías 56:7.\f* La₁ 'nia'₂ në́₃ ma₂jmo'₅₄ në₂jag₄ bá₄ të₂'lau₂ quió'₅ dsa₂ 'ang₂.\f + \fr 11:17 \ft Jeremías 7:11.\f* 
\p  
\v 18 Jaun₂ juɨg₅₄ jme₂dsa₂ quian'₅₄ të₅juá'₅ në́₃ ca₂nág₂ jág₁ në₅. Jaun₂ ca₂jme₃lióg₃ ca₂'náu'₃ juɨ₅ 'a₂ lia'₂ jŋag'₃, ia₁ gó'₅ con'₂ tsá₃ ŋó₅ në₁jua'₂ 'éi₂ bá₄ jme₃gón₃ lé₂, ia₁ juɨn₅ lɨn₃ dsa₂ nag₅ dsɨ₂gó'₃ dsɨ́₅ jág₁ a₂jme₂tag₅ Jesús.  
\v 19 Të₂le₃ ca₂nei₂ jmɨg₄ jaun₂, ca₂'uɨin₂\f + \fr 11:19 \ft A₂lɨn₅₄ chog₅₄ si₂ juá'₂: “ca₂o₃'ɨ́in₃.” \f* juɨg₂ jaun₂. 
\s1 Ca₂rë₃quéin₃ nɨ₁'ma₂ higuera 
\r (Mateo 21:20-22) 
\p  
\v 20 Jme₁jnia₃ jaun₂, ca₂ŋɨi₅ táng₃ juɨ₅ ja₁dsi₅₄ nɨ₁'ma₂ higuera. Jaun₂ ca₂jág₃ co₂dsia₅ ma₂quein₂ ca₂të₂ cho'₅₄.  
\v 21 Jaun₂ ca₂dsáu'₃ dsɨ́₅ Pe₄, jaun₂ ca₂tsɨ́'₃ Jesús: 
\p ―Të₅, jag₄ nɨ₁'ma₂ a₂ca₂chei'₅₄ uɨg₅. Co₂dsia₅ ma₂ca₂rë₃quéin₃. 
\p  
\v 22 Jaun₂ ca₂ŋag₃ Jesús ca₂tsɨ́'₃ dsa₂: 
\p ―'Én₃ 'nia'₂ të₂le₃ quió'₅ Diú₄.  
\v 23 A₂dsɨ₂jó'₃ juɨ́g₂ jniá₂ 'nia'₂, juɨ₁'ein₂ guë́₃ juá'₂ tsɨ́'₃ nɨ₁má'₂ në₅: “Jŋiag'₃ ja₁në₅, o₂'ú₅ jmɨ₁ŋí'₄”, le₂jaun₂ dsón'₂ le₃ti₃ bá₄, në₁jua'₂ tsá₃ ca₂'ág₂ caun₂-tɨn₃ dsɨ́₅.  
\v 24 Jaun₂ lë₃, juá'₅ jniá₂, juɨ₁'e₂ guë́₃ a₂mɨ'₂ 'nia'₂ jme₁chi₂leng'₅₄ Diú₄, në₁jua'₂ jmo'₂ 'nia'₂ 'au'₂ në₂jag₄ bá₄ a₂ma₂në₂gue'₅₄ 'e₂ a₂mɨ'₂, le₂jaun₂ dsón'₂ le₃ti₃ bá₄ ja₁con'₂ 'nia'₂.  
\v 25 Jë₁ma₂të́₂ rë₁náu'₁ 'nia'₂ chi₁léng'₄ Diú₄, në₁jua'₂ cha₂ 'nei₂ 'au'₂ 'nia'₂ ja₁con₂ rɨ́ng'₂, 'én₃ 'nia'₂ dsáu₁ rɨ́ng'₂, ia₁jaun₂ bá₄ Ŋéi'₅ 'nia'₂ i₂guá₅ guei'₅₄ i₂juɨ́g₃ 'éin₂ dsáu'₂ 'nia'₂ guiong'₅₄.\f + \fr 11:25 \ft A₂lɨn₅₄ chog₅₄ si₂ chi₁ton₅ versículo 26 ján₃, a₂juá'₂ le₂la₂: “Ia₁ në₁jua'₂ tsá₃ 'én'₅ 'nia'₂ dsáu₁ rɨ́ng'₂, ján₃ bá₄ le₂jaun₂ tsá₃ 'én₂ Ŋéi'₅ 'nia'₂ i₂guá₅ guei'₅₄ i₂juɨ́g₃ dsáu'₂ 'nia'₂ guiong'₅₄”.\f* 
\s1 Jesús bá₄ i₂'io₅ 'éi'₃ 
\r (Mateo 21:23-27; Lucas 20:1-8) 
\p  
\v 27 Ca₂dsi₃léin₂ táng₃ juɨg₂ Jerusalén. Jaun₂ jme₁ma₂ŋɨ₅ Jesús i₁dsi₅ guá'₅ templo, jaun₂ ca₂jme₃quián₃ juɨg₅₄ jme₂dsa₂, të₅juá'₅, dsɨ₂gui'₅₄ can'₅₄ në́₃.  
\v 28 Jaun₂ ca₂ŋag₃ dsa₂ 'éi₂ ca₂ŋɨ́i'₃ Jesús: 
\p ―¿'E₂ ta₁ lɨ́n'₅ 'ne₂ a₂jmo'₂ ca₂le₃jë́₃ 'e₂ a₂jmo'₂ ŋɨ'₂? ¿'Ein₂ cuë₅ bí₂ 'éi'₃ a₂jmo'₂ le₂në₅? 
\p  
\v 29 Jaun₂ ca₂ŋag₃ Jesús: 
\p ―Ján₃ bá₄ ŋag₄ jniá₂ caun₂ 'nia'₂. Në₁jua'₂ ca₂ŋag'₅₄ 'nia'₂ lia'₂ tí₅, jaun₂ guë́₄ juá'₄ jniá₂ 'ein₂ cuë₅ bí₂ a₂jmo₂₃ ca₂le₃jë́₃ a₂jmo₂₃.  
\v 30 Juɨ₁lia'₂ a₂ca₂chon₃ Juan₅₄ jmɨg₂ dsa₂, ¿'ein₂ quió'₅ 'éi'₃ jaun₂? ¿Quió'₅ Diú₄, o₃ quió'₅ dsa₂ mɨ₂güɨ́g₃ 'e₂? Ŋag₄ 'nia'₂. 
\p  
\v 31 Jaun₂ ca₂dsia₃ dsa₂ can'₅₄ jág₁ con'₂ guioin₅₄, ca₂juá'₂: 
\p ―Në₁jua'₂ ca₂chei₅₄ jniog₄ 'éi'₃ quió'₅ Diú₄ bá₄, në₃ cón'₅ bá₄ ŋag₃: “¿'E₂ lë₃ tsá₃ ca₂rë₃'én'₂ 'nia'₂ jág₁ quió'₅ 'éi₂?”  
\v 32 ¿La₁ në₁jua'₂ ca₂chei₅₄ jniog₄ 'éi'₃ quió'₅ dsa₂ mɨ₂güɨ́g₃ bá₄...? 
\p La₁ ca₂rë₃gain₃ ca₂le₃jɨ́n₃ dsa₂ i₂quian'₅₄ Jesús. Ia₁ ca₂le₃jɨ́n₃ dsa₂ jme₁'éin₂ a₂jme₁lɨ́n₄ Juan₅₄ të₃dsón'₂ jan₂ dsa₂ i₂'ë́₂ jág₁ quián₅ Diú₄.  
\v 33 Jaun₂ ca₂ŋag₃ dsa₂ can'₅₄ ca₂tsɨ́'₃ Jesús: 
\p ―Tsá₃ a₂jaun₂ ne₄ jnia'₅₄. 
\p Jaun₂ ca₂ŋag₃ táng₃ Jesús: 
\p ―Ján₃ bá₄ tsá₃ juá'₄ jniá₂ 'ein₂ cuë₅ bí₂ 'éi'₃ a₂jmo₂₃ ca₂le₃jë́₃ 'e₂ a₂jmo₂₃ ŋɨ₂₃. 
\c 12  
\s1 Jág₁ jáng'₅ léi₄ juɨ₁lia'₂ co₂nió'₃ dsa₂ 'lɨn'₅₄ i₂jmó'₂ ta₁ ja₁nau₂ 
\r (Mateo 21:33-46; Lucas 20:9-19) 
\p  
\v 1 Jaun₂ ca₂jme₃lióg₃ Jesús ca₂juá'₂ quian'₅₄ jág₁ a₂jáng'₅ léi₄. Ca₂juá'₂: 
\p ―Jme₁chan₂ jan₂ dsa₂ ca₂chéin'₃ uɨng₂ a₂'ag₅ mɨ́g₂ uvas ja₁nau₂ quió'₅. Jaun₂ ca₂jmo₃ jnɨ́₁ le₃lág'₃. Jaun₂ ca₂jmo₃ co₂jŋia₅₄ ja₁jlein'₃ mɨ́g₂. Jaun₂ ca₂chi'₃ caun₂ tsɨ₁'né₅ ŋei₅ ja₁guá₃ jmo₃ 'í₁. 
\p Jaun₂ ca₂lɨ́'₃ jág₁ quian'₅₄ dsa₂ sián'₂ i₂nio₃ ne₄ ja₁nau₂, Jaun₂ ca₂ŋó₃ bá₄ 'ŋiog₅ i₂ŋɨ́₃ juɨg₂ siá'₂.  
\v 2 Jme₁ca₂të́₂ jein₂ a₂ca₂rau₂ mɨ́g₂, jaun₂ ca₂chen₃ dsa₂ juɨg₅₄ ja₁nau₂ jan₂ dsa₂ mozo quiáin₅ a₂jme₁i₂mɨ́₃ a₂jáng'₃ dsa₂ ca₂dsio₄ mɨ́g₂ con'₂ a₂ca₂tɨ́n₂ dsa₂ juɨg₅₄.  
\v 3 Dsa₂ jmó'₂ ta₁ ja₁nau₂ në́₃, 'nió'₄ a₂jme₁cuë₃ a₂mɨ₅ dsa₂ 'éi₂, ca₂jŋau'₃, ca₂cuë́'₃ dsa₂ 'éi₂ tioin'₅₄, ca₂dsióg'₂ bá₄, tsá₃ 'e₂ ca₂jáng'₃ a₂jme₁mɨ₅ 'éi₂.  
\v 4 Dsa₂ juɨg₅₄ ja₁nau₂ në́₃ ca₂chein₃ táng₃ jan₂ dsa₂ mozo sián'₂. I₂'éi₂ në́₃, ca₂cuɨ́'₂ mɨ₂dsi₅₄, ca₂jmóg'₂ dsa₂ 'éi₂, jë₂ bá₄ ca₂të₂ca₂'o'₂.  
\v 5 Jaun₂ dsa₂ juɨg₅₄ ja₁nau₂ në́₃ ca₂chein₃ bá₄ guë́₄ jan₂ dsa₂ sián'₂ táng₃, la₁ i₂'éi₂ guë́₄ në́₃ ca₂jŋɨi'₃. Juɨn₅ guë́₄ i₂sián'₂ ca₂i₁len₅₄ ján₃. I₂lɨn₅₄ 'éi₂ qui₂ca₂cuë́'₃, i₂lɨn₅₄ guë'₂ ca₂jme₃dsiain₂₃ tioin'₅₄. 
\p  
\v 6 ’Dsa₂ juɨg₅₄ ja₁nau₂ në́₃ jme₁chan₂ guë́₄ jan₂ ja₁ŋi'₅₄ i₂jme₁'nioi₃ guë́₄ lɨn₃. Jaun₂ ca₂chein₃ 'éi₂, ia₁ lɨ́in₂: “Jme₃gan₃ dsa₂ chi'₂ quiáng₃.”  
\v 7 La₁ dsa₂ tion'₅₄ ja₁nau₂ në́₃, ca₂dsia₃: “I₂në₅ bá₄ tɨn₃ ja₁nau₂ la₂ cang₂; në₃ o₁jŋɨ́i'₄ jniog₄, ia₁jaun₂ jniog₄ bá₄ lé₂ quián₂”.  
\v 8 Jaun₂ le₂jaun₂ bá₄ ca₂jmo₃. Ca₂jŋɨi'₃ bá₄ 'éi₂ tioin'₅₄. Jaun₂ ca₂dsei₂₃ le₃co'₅₄ jnɨ́₁. 
\p  
\v 9 'Jaun₂, ¿'e₂ jmo₃ dsa₂ juɨg₅₄ ja₁nau₂? Jŋiói'₂ jme₃dsiain₂₃ ca₂le₃jɨ́n₃ dsa₂ i₂tion'₅₄ jmó'₂ ta₁ ja₁nau₂ quió'₅, jaun₂ dsia₃ gu₂ dsa₂ sián'₂ táng₃. 
\p  
\v 10 ’¿Tsa₁ ma₂'í'₂ 'nia'₂ Si₂ ja₁juá'₂: 
\q1 Nɨ₁cang₁ a₂tsá₃ ca₂rë₃ji'₅₄ të₅'ia'₂, 
\q2 ca₂dsióg₃ ca₂lë₃ nɨ₁cang₁ a₂dsen₅₄ guë́₄ 
\q2 a₂të₁ron₅₄ qui'₅₄ 'ia'₂; 
\q1  
\v 11 con'₂ në₅ lë́₅ ca₂jmo₃ Te₁gui'₅₄, 
\q2 jaun₂ 'ŋio₅ lɨn₃ bá₄ jlá'₁, lág₂ jniog₄?\f + \fr 12:11 \ft Salmo 118:22-23.\f* 
\p  
\v 12 Jaun₂ jme₁'no'₂ dsa₂ juɨ₅ a₂jme₁tsáun'₂, ia₁ ca₂rë₃lí'₄ bá₄ guioin₅₄ a₂juá'₂ Jesús jág₁ jáng'₅ léi₄ në₅ a₂'ɨin₂₃ 'éi₂ bá₄. La₁ ca₂rë₃gain₃ bá₄ dsa₂ juɨn₅ i₂quian'₅₄ Jesús. Jaun₂ i₂lein₃ bá₄, tsá₃ ma₃ca₂jŋau'₃. 
\s1 Jág₁ juɨ₁lia'₂ 'lia'₅₄ a₂ca₂tɨ́n₂ dsɨ₂tan₅₄ 
\r (Mateo 22:15-22; Lucas 20:20-26) 
\p  
\v 13 Jaun₂ ca₂chen₃ dsa₂ can'₅₄ i₂lɨn₅₄ dsa₂ fariseos, quian'₅₄ i₂lɨn₅₄ dsa₂ quián₅ Rag₅₄ Herodes a₂dsɨ₃chi'₅₄ 'e₂ dsɨ₃chi'₅₄ Jesús, ia₁jaun₂ cuɨn₅ jmɨg₄ jo₅₄ juɨ₁lia'₂ bá₄ 'ŋiái₃ ca₂jon₄ jág₁ 'lia'₂.  
\v 14 Jaun₂ ca₂o₃léin₂ ca₂juá'₂: 
\p ―Të₅, ne₄ bá₄ jnia'₅₄ a₂dsón'₂ bá₄ juá'₂ 'ne₂ lia'₂ tí₅ jág₁. Jaun₂ tsá₃ can'₂ 'ne₂ jág₁ jua'₅₄ a₂quian'₅₄ o₂i₁ dsɨ₅ 'e₂ 'ag₅ dsa₂, ia₁ tsá₃ gang'₃ jmag'₅₄ juɨ₁lia'₂ dsa₂ dsen₅₄ në́₃. Caun₂ qui₂jme₂tɨ́ng'₁ bá₄ dsa₂ juɨ₅ quió'₅ Diú₄. ¿'I₄ 'éi'₃ qui₅₄ 'lia'₅₄ a₂ca₂tɨ́n₂ dsɨ₂tan₅₄ César? ¿'Nió'₅ qui₅₄ o₃ tsá₃ qui₅₄ 'e₂? 
\p  
\v 15 La₁ ŋi₅ rë₂ bá₄ Jesús a₂lë₁i₂nio₄ juá'₂ o₁ne₁ bá₄ dsa₂ 'éi₂. Jaun₂ ca₂juá'₂: 
\p ―¿'E₂ lë₃ cáun'₂ 'nia'₂ táu₂ jniá₂? O₂quian₂ de'₂ 'nia'₂ caun₂ cu₄ denario jaun₂ jág₄ jniá₂. 
\p  
\v 16 Jaun₂ ca₂i₁quian₅₄ dsa₂. Jaun₂ jme₁ca₂jág₃ Jesús, jaun₂ ca₂ŋag₃: 
\p ―¿'Ein₂ dsɨ₂ne₄ chi₁ton₅ ja₁lá₃? ¿'Ein₂ quió'₅ letra në́₃? 
\p Jaun₂ ca₂ŋag₃: 
\p ―Quió'₅ gui'₅₄ emperador César bá₄. 
\p  
\v 17 Jaun₂ ca₂juá'₂ táng₃ Jesús: 
\p ―Jang'₅₄ 'nia'₂ ne₄ César con'₂ a₂ca₂tɨ́n₂ César; ne₄ Diú₄ në́₃ jang'₅₄ 'nia'₂ con'₂ a₂ca₂tɨ́n₂ Diú₄. 
\p Jaun₂ ca₂i₃gó'₃ dsɨ́₅ jɨ́in₂ 'éi₂. 
\s1 Ca₂ŋag₃ dsa₂ saduceos juɨ₁lia'₂ a₂jen'₅₄ 'lag₄ 
\r (Mateo 22:23-33; Lucas 20:27-40) 
\p  
\v 18 Jaun₂ ca₂o₃lén₂ i₂lɨn₅₄ dsa₂ saduceos ca₂o₃jɨin₅₄ Jesús. Ia₁ tsá₃ 'én₂ dsa₂ 'éi₂ a₂jen'₅₄ táng₃ dsa₂ jë₁ma₂dsain₃. Jaun₂ ca₂tsɨ́'₃ Jesús: 
\p  
\v 19 ―Të₅, ca₂quiog₂ Moisés si₂ a₂juá'₂, në₁jua'₂ ca₂jon₃ jan₂ dsa₂ ŋe'₂ të₃ tsá₃ ca₂can₃ 'io₅₄ quiáin₅ guein₂, tion'₅₄ 'nió'₅ jén'₂ gu₂ dsó₂ rɨn'₅₄ dsa₂ ŋe'₂ i₂ca₂jon₃ quiain'₅₄ 'io₅₄ 'nág₂ 'éi₂, ia₁jaun₂ guein₂ i₂le₃chan₂ quiáin₅, lé₂ co₂'nió'₄ tsɨ₁jon₂ 'lag₄ rɨin'₅₄.\f + \fr 12:19 \ft 'Nio'₂ ja₁ton₅ Deuteronomio 25:5-6.\f* 
\p  
\v 20 'Ia₁ jme₁chan₂ guion₃ dsa₂ ŋe'₂ i₂lɨ́n₅ jmá'₃ lia'₂ rɨn'₅₄. Ca₂jen'₂ gu₂ i₂le₂'uɨg₅₄, la₁ ca₂join₃ bá₄ të₃ tsá₃ guein₂ ca₂can₃ 'io₅₄ quiáin₅.  
\v 21 Jaun₂ ca₂jen'₂ táng₃ gu₂ 'io₅₄ 'nág₂ 'éi₂ quiain'₅₄ jë₁ca₂të́₂ on₃. Ján₃ bá₄ le₂jaun₂ ca₂jon₃ táng₃ dsó₂ 'éi₂, tsá₃ guein₂ ca₂can₃ 'io₅₄. Ján₃ bá₄ le₂jaun₂ ca₂lë₃ quian'₅₄ jë₁ca₂të́₂ ún₂.  
\v 22 Le₂jaun₂ bá₄ ca₂lë₃ quian'₅₄ ta₁guion₃ dsa₂ ŋe'₂ con'₂ i₂jme₁lë́₄ rɨn'₅₄: ca₂dsain₃ bá₄ të₃ tsá₃ guein₂ ca₂can₃ 'io₅₄ 'i₁jan₂ quiain'₅₄ 'i₁jan₂ dsó₂ 'éi₂. Jaun₂ ca₂jon₃ 'io₅₄ jme₁ca₂join₃ në́₃.  
\v 23 Jaun₂ në́₃, jmɨg₄ jë₁ma₂të́₂ rë₁jen'₅₄ 'lag₄, ¿'ein₂ bá₄ quián₅ lé₂ 'io₅₄ 'éi₂? Ia₁ ta₁guion₃ bá₄ guë'₂ dsa₂ ŋe'₂ ca₂guá₂ quiain'₅₄. 
\p  
\v 24 Jaun₂ ca₂ŋag₃ Jesús: 
\p ―'E₂ guë́₄ tsá₃ rë₂ ŋɨ́'₂ 'au'₂ 'nia'₂, ia₁ a₂tsá₃ cuɨn'₂ 'nia'₂ 'a₂ lia'₂ juá'₂ Si₂, on₃ guë'₂ cuɨn'₂ 'nia'₂ 'a₂ lia'₂ lë́₅ juɨ₅bí₂ quió'₅ Diú₄.  
\v 25 Jë₁ma₂të́₂ jmɨg₄ a₂jen'₅₄ 'lag₄, on₃jua'₅₄ a₂le₃chain₂ jua'₅₄ a₂qui₃jéin'₂ guë́₄ gu₂, on₃ guë'₂ në₅ tóin'₃ guë́₄ jua'₅₄ a₂qui₃cuɨin₃ chi'₂ quiáin₅ a₂jéin'₂ gu₂, ia₁ i₂lén₂ juɨ₁lia'₂ lɨ́n₅ ángeles i₂tion'₅₄ guei'₅₄ i₂juɨ́g₃ bá₄ 'éi₂ jmɨg₄ jaun₂.  
\v 26 La₁ juɨ₁lia'₂ a₂jen'₅₄ táng₃ 'lag₄, ¿tsa₁ ma₂'í'₂ 'nia'₂ Si₂ quió'₅ Moisés juɨ₁lia'₂ ja₁juá'₂ 'ë₂₃ nɨ₁'ma₂ taun₅, ja₁ca₂juá'₂ Diú₄ ca₂tsɨ́'₃ Moisés: “Jniá₂ bá₄ lɨ́ng₅ Diú₄ quián₅ Abraham, quián₅ Isaac, quián₅ Jacob në́₃?”\f + \fr 12:26 \ft Éxodo 3:6.\f* 
\v 27 A₂lɨ́in₅ Diú₄ quian₅ dsa₂ jén'₃ bá₄, on₃jua'₅₄ rë'₂ Diú₄ quián₅ 'lag₄. Jaun₂ 'ŋio₅ lɨn₃ tsá₃ rë₂ ŋɨ́'₂ 'au'₂ 'nia'₂. 
\s1 'Éi'₃ Juá'₅ a₂dsen₅₄ guë́₄ quió'₅ Diú₄ 
\r (Mateo 22:34-40) 
\p  
\v 28 Jaun₂ ca₂guan₃ jan₂ të₅juá'₅, ca₂nág₂ jág₁ a₂tsɨn₅ Jesús quian'₅₄ dsa₂, ca₂rë₃lí'₄ bá₄ a₂ca₂ŋag₃ Jesús lia'₂ tí₅ jág₁. Jaun₂ ca₂ŋag₃: 
\p ―¿'E₂ 'Éi'₃ Juá'₅ a₂le₂'uɨg₅₄ a₂lë́₅ a₂dsen₅₄ guë́₄ con'₂ guë́₄ ca₂le₃jë́₃ juá'₅? 
\p  
\v 29 Jaun₂ ca₂ŋag₃ Jesús: 
\p ―'Éi'₃ Juá'₅ le₂'uɨg₅₄ con'₂ guë́₄ ca₂le₃jë́₃, juá'₂: “Nei₂ 'nia'₂ dsa₂ chan₂ juɨg₂ Israel. Jan₂ Te₁gui'₅₄ bá₄ lɨ́n₅ Diú₄ quián₂ jniog₄.  
\v 30 Jme₁'nió₄ 'nia'₂ Te₁gui'₅₄ Diú₄ quiáng'₂ ca₂le₃jë́₃ 'au'₂, ca₂le₃jë́₃ jme₂dsí₂ quiáng'₂, ca₂le₃jë́₃ 'a₂ lia'₂ ŋɨ́'₂ dsei'₂, ca₂le₃jë́₃ bí₂ quiáng'₂.”\f + \fr 12:30 \ft Deuteronomio 6:4-5.\f* 
\v 31 Jë₁ca₂të́₂ tɨn₃ juá'₅ në́₃ juá'₂: “A₂jme₁'nióg'₄ dsa₂ mɨ₂güɨ́g₃ rɨ́ng'₂ juɨ₁lia'₂ 'niog'₂ 'ŋiag'₂.”\f + \fr 12:31 \ft Levítico 19:18.\f* Jŋia'₅₄ lia'₂ a₂tɨn₃ në₅ bá₄ juá'₅ a₂lë́₅ a₂dsen₅₄ guë́₄ con'₂ guë́₄ ca₂le₃jë́₃ 'Éi'₃ Juá'₅ quió'₅ Diú₄. 
\p  
\v 32 Jaun₂ ca₂ŋag₃ të₅juá'₅ 'éi₂: 
\p ―Të₅, 'ŋio₅ dse₃ lia'₂ në₂ŋag'₅₄; a₂dsón'₂ bá₄ dsau₅ jan₂ bá₄ Diú₄ i₂chan₂, tsá₃ ma₃'ein₂ diú₄ sián'₂ chan₂.  
\v 33 A₂jaun₂ bá₄ a₂dsen₅₄ guë́₄ a₂jme₃'nio₃ dsa₂ Diú₄ ca₂le₃jë́₃ dsɨ́₅, ca₂le₃jë́₃ jme₂dsí₂, ca₂le₃jë́₃ bí₂ quió'₅; a₂jme₃'nio₃ dsa₂ rɨin'₅₄ juɨ₁lia'₂ 'nioi₃ 'ŋiog₅. A₂jaun₂ bá₄ a₂quen₅ guë́₄ con'₂ guë́₄ ca₂le₃jë́₃ 'e₂ niog₅ jén'₅ dsa₂ ne₄ Diú₄, o₃ 'e₂ a₂qui₂dsɨ́'₂ dsa₂ ne₄chei₂ në́₃. 
\p  
\v 34 Jaun₂ jme₁ca₂nág₂ Jesús ca₂ŋag₃ bá₄ dsa₂ 'éi₂ a₂ŋɨ́'₂ dse₃ dsɨ́₅, jaun₂ ca₂juá'₂: 
\p ―Tsá₃ uɨ́ng₂ ŋɨ'₂ ja₁gon₂ Diú₄. 
\p Jaun₂ të₂le₃ ne₄ juɨ₅ guë́₄ jaun₂, tsá₃ ma₃'ein₂ ca₂tiá₂ dsɨ́₅ jua'₅₄ a₂ŋág₃ guë́₄ 'e₂ ŋag₃. 
\s1 ¿'Ein₂ tsɨ₁jon₂ quián₅ lɨ́n₅ I₂rë₂'ɨ́n₁ quián₅ Diú₄? 
\r (Mateo 22:41-46; Lucas 20:41-44) 
\p  
\v 35 Jaun₂ ca₂jéin'₃ Jesús jág₁ jë₄ jme₂tɨin₂₃ dsa₂ i₁dsi₅ guá'₅ templo, jaun₂ ca₂juá'₂: 
\p ―¿'A₂ lia'₂ lë́₅ juá'₂ të₅juá'₅ a₂lɨ́n₅ tsɨ₁jon₂ David I₂rë₂'ɨ́n₁ quián₅ Diú₄,  
\v 36 ton'₂ 'ŋiog₅ bá₄ guë'₂ David ca₂juá'₂ lia'₂ con'₂ jme₁ca₂'í₃ Jme₂dsí₂ Jŋió₅ të₂dsɨ́₅: 
\q1 Ca₂juá'₂ Diú₄ ca₂tsɨ́'₃ Te₁gui'₅₄ quiáng₃: 
\q1 “Né₂ con₂ jniá₂ të₂le₃ gu₃ ne₁, 
\q2 ca₂lia'₂ ca₂të́₂ jmɨg₄ 
\q2 a₂tón'₁ jniá₂ dsa₂ i₂'iog₅₄ o₄tag'₄”?\f + \fr 12:36 \ft Salmo 110:1.\f* 
\p  
\v 37 ¿'A₂ bá₄ lia'₂ lë́₅ jaun₂ a₂lɨ́in₅ tsɨ₁jon₂ David, ton'₂ 'ŋiog₅ bá₄ guë'₂ David ca₂të₃ “Te₁gui'₅₄ quiáng₃?” 
\p Ca₂le₃jɨ́n₃ dsa₂ juɨn₅ 'éi₂ jme₁nag₂₃ 'ŋio₂ dsɨ́₅ jág₁ quió'₅. 
\s1 Chóg'₅ Jesús dso₄ juá'₂ 'a₂ lia'₂ niog₅ lɨ́n₅ të₅juá'₅ 
\r (Mateo 23:1-36; Lucas 11:37-54; 20:45-47) 
\p  
\v 38 Të₃jë₄ jme₂tɨin₂₃ dsa₂, ca₂juá'₂: 
\p ―Ŋí₂ 'nia'₂, jmo₄ 'nia'₂ 'í₁ tsá₃ i₂can₂ 'nia'₂ juɨ₅ juɨ₁lia'₂ niog₅ lɨ́n₅ të₅juá'₅. Ia₁ të₅ dsɨ́₅ i₂nioi₅₄ le₁qui'₂ 'mɨ'₂ chen'₅₄ jang₄, ton'₂ të₅ dsɨ́₅ qui₂cuag₃ dsa₂ Diú₄ jë₄ 'ma'₅₄,  
\v 39 ton'₂ jmá'₃ lia'₂ ja₁dsen₅₄ bá₄ qui₂dsɨ₂tiain'₂ juɨ₁lia'₂ dsi₂néi₂ guá'₅ sinagoga, ton'₂ jmá'₃ lia'₂ ja₁dsen₅₄ bá₄ dsɨ₂toin'₅₄ ja₁dsɨ₂guë́'₃ juɨ₁lia'₂ ja₁niog₅ jmɨg₄.  
\v 40 Qui₂jŋiá'₂ 'ne₄ 'io₅₄ 'nág₂ në́₃, jaun₂ a₂jŋia'₅₄ con'₂ 'ma₂₃ jlë₅ a₂jmo₂₃ jaun₂, chi₂léin'₂ Diú₄ uë́₂ lɨn₃ të₃jɨn₄ dsa₂. La₁ 'e₂ guë́₄ uɨg₅ cuë₃ Diú₄ quió'₅ i₂le₂'éi₂. 
\s1 Ca₂tó'₂ 'io₅₄ 'nág₂ te₂ŋé₂ cu₄ quió'₅ 
\r (Lucas 21:1-4) 
\p  
\v 41 Co₂ráun₂ guá₅ Jesús i₁dsi₅ guá'₅ cau₅ tsɨ₁gu₅ ja₁tó'₅ dsa₂ cu₄ ofrenda. Jaun₂ guá₅ jɨ́in₂ dsa₂ i₂dsɨ₂lén₂ dsɨ₂tio'₂ cu₄ 'ŋió'₃ tsɨ₁gu₅. Jaun₂ në́₃, juɨn₅ dsa₂ cha₂ cu₄ dsɨ₂lén₂ dsɨ₂tio'₂ 'lióng₂ cu₄.  
\v 42 La₁ të₃jë₄ jaun₂ ca₂dsióg₃ jan₂ 'io₅₄ 'nág₂ te₂ŋé₂. Jaun₂ ca₂tó'₂ tɨn₃ ŋí₁ guéin₂.\f + \fr 12:42 \ft lit. “tɨn₃ ŋí₁ lepta.” \f* 
\v 43 Jaun₂ ca₂të́'₃ Jesús chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅, jaun₂ ca₂juá'₂: 
\p ―A₂dsɨ₂jó'₃ juɨ́g₂ jniá₂ 'nia'₂, 'lióng₂ guë́₄ në₂tió'₂ 'io₅₄ 'nág₂ te₂ŋé₂ në₅, lia'₂ con'₂ guë́₄ ca₂le₃jɨ́n₃ i₂ma₂në₂tió'₂ 'ŋió'₃ tsɨ₁gu₅.  
\v 44 Ia₁ 'éi₂ në́₃ cu₄ a₂ma₂qui₂rë₂tsón₂ bá₄ jaun₂ quió'₅ cuë₂₃. 'Io₅₄ 'nág₂ në₅ në́₃, ca₂le₃jë́₃ bá₄ në₂cuë₃, con'₂ a₂jme₁ron₅ quió'₅, 'nió'₄ a₂jme₁lá₃ a₂guë́'₃. 
\c 13  
\s1 Ca₂'ë́₂ Jesús jág₁ a₂dsɨ₃'én₂ bá₄ guá'₅ templo 
\r (Mateo 24:1-2; Lucas 21:5-6) 
\p  
\v 1 Con'₂ jme₁ma₂'ein₅₄ juɨ₅ o₂'ɨin₅ i₁dsi₅ guá'₅, jaun₂ ca₂juá'₂ jan₂ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅: 
\p ―¡Të₅, jag₄ 'e₂ guë́₄ jlá'₁ nɨ₁cang₁ a₂le₁juɨ́₄ a₂lë́₅ guá'₅! 
\p  
\v 2 Jaun₂ ca₂ŋag₃ Jesús: 
\p ―¿Jág'₂ 'né₅ ca'₅₄ a₂te₁'i₁ në₅? Já₅ caun₂ jmɨg₄, 'i₁ca₂mɨ́g₂ nɨ₁cang₁ tsá₃ ma₃'e₂ le₁juɨ́₄ lé₂. 
\s1 Léi₄ a₂lé₂ jmɨg₄ jë₁ca₂tó'₂ 
\r (Mateo 24:3-28; Lucas 21:7-24; 17:22-24) 
\p  
\v 3 Jme₁ca₂dsióg₃ Jesús má'₂ Olivos a₂chí'₅ quióng₄ guá'₅, ja₁jaun₂ ca₂guá₂. Jaun₂ ca₂guan₃ Pe₄, Jacobo, quiain'₅₄ Juan₅₄, Drë́₄ në́₃, ca₂tsɨ́'₃ Jesús con'₂ jë₄ të₃co'₅₄: 
\p  
\v 4 ―Jua'₅₄ lɨ́g'₂ bá₄ le₃ti₃ a₂juá'₂ 'ne₂ në₅. 'Niog₂ jnia'₅₄ le₃ne₄. ¿'E₂ léi₄ a₂lé₂ né'₃ a₂të₅₄ jmɨg₄ jaun₂? 
\p  
\v 5 Jaun₂ ca₂ŋag₃ Jesús: 
\p ―Jmo₄ 'nia'₂ 'í₁ ia₁jaun₂ tsá₃ 'ein₂ jme₃gau₅.  
\v 6 Ia₁ juɨn₅ i₂të₁i₃nio₄ a₂juá'₂ i₂nioi₅₄ o₄quió₃ jniá₂, juá'₂: “Jniá₂ bá₄ lɨ́ng₅ 'éi₂,” jaun₂ juɨn₅ dsa₂ i₂qui₂jme₃gain₂₃. 
\p  
\v 7 ’Jë₁ma₂nei'₂ 'nia'₂ 'ei₅ jág₁ a₂nio₃ 'nei₂ a₂quɨ́n'₂ dsa₂ ja₁lá₃ ja₁ó₃, la₁ tsá₃ jmó₁ 'nia'₂ gang'₃, ia₁ le₂jaun₂ dsón'₂ lé₂ bá₄. La₁ on₃jua'₅₄ jmɨg₄ jë₁ca₂tó'₂ jaun₂.  
\v 8 Ia₁ nio₃ 'nei₂, qui₃quɨ́n'₂ dsa₂ le₂caun₂ le₂caun₂ juɨg₂ nación; dsɨ₂tan₅₄ guë'₂ në́₃ qui₃tóin'₃ mɨ'₅₄ quɨ́in'₂ quian'₅₄ dsɨ₂tan₅₄ rɨin'₅₄ i₂chan₂ juɨg₂ siá'₂. 'Lióng₂ ja₁qui₂dsɨ₃bi₅₄ 'uë₃ lé₂, ton'₂ le₃cha₂ 'lióng₂ ja₁qui₂i₂nio₄ dsa₂ 'oin₅₄. A₂le₂'uɨg₅₄ jmɨ₁uɨg₅ bá₄ guë́₄ në₅, juɨ₁lia'₂ jan₂ 'io₅₄ i₂rë₂chan₂ guein₂ quián₅. 
\p  
\v 9 ’Rë₂ján'₁ 'nia'₂ chang'₂, ia₁ qui₃jɨ́n'₂ dsa₂ 'nia'₂ ne₄ dsɨ₂tan₅₄ quián₅ guá'₅ ia₁jaun₂ bóg₂ dsa₂ dsi₂néi₂ guá'₅ sinagogas. Jaun₂ dsi₁nó'₅ 'nia'₂ të₃ne₄ dsi₄má'₂, ne₄ rag₅₄ në́₃, 'uɨg₅₄ quió₃ jniá₂; ja₁jaun₂ o₁jang'₄ 'nia'₂ jág₁ dsau₅.  
\v 10 Jág₁ quió'₅ Diú₄ de'₂ jŋiá₅ 'nió'₅ dsɨ₃'ag₅ le₂con₂ mɨ₂güɨ́g₃.  
\v 11 Jë₁ma₂të́₂ rë₁qui₃të₂ dsa₂ 'nia'₂ a₂dsi₁jó₂ ne₄ dsɨ₂tan₅₄, tsá₃ jmó'₂ 'nia'₂ 'ɨ₅ 'au'₂ të₃jŋiá₅ 'e₂ ŋag'₅₄. La₁ ŋag₄ bá₄ 'nia'₂ con'₂ jág₁ a₂ma₂ca₂ŋɨ'₂ 'nia'₂ hora jaun₂, ia₁ on₃jua'₅₄ guion'₅₄ 'nia'₂ a₂ŋag'₅₄ jág₁ jaun₂; Jme₂dsí₂ Jŋió₅ bá₄ i₂jmo₃.  
\v 12 Ia₁ tón'₃ dsa₂ qui₃jɨ́in'₂ rɨin'₅₄ jmɨg₄ jaun₂, jaun₂ jŋag'₃ dsa₂; juɨ₁lia'₂ jmei₂ qui₃jɨ́in'₂ chi'₂ quiáin₅. Chi'₂ guë'₂ në́₃, jme₃'ŋiai₅₄ chog₅₄-jmei₂; chan₂ guë'₂ i₂qui₂jme₃dsian₅ chog₅₄-jmei₂ në́₃.  
\v 13 Ca₂le₃jɨ́n₃ dsa₂ jme₃'ŋia₅₄ 'nia'₂ 'uɨg₅₄ quió₃ jniá₂, la₁ juɨ₁lia'₂ i₂tió'₃ náu₃ tiá₂ të₂ jë₁ca₂tó'₂, tɨ́in'₄ bá₄. 
\p  
\v 14 ’Jaun₂ në́₃, já₅ jmɨg₄ a₂të₅₄ ne'₅₄ 'nia'₂ a₂náu₃ jan₂ dsa₂ i₂juɨ₁si 'lɨn'₅₄ ja₁tsá₃ 'i₄ 'éi'₃ náu₃,\f + \fr 13:14 \ft 'Nio'₂ ja₁ton₅ Daniel 9:27; 11:31; 12:11.\f* ―jaun₂ juɨ₁le₂ŋɨ́'₂ bá₄ i₂'ɨ₅ si₂ la₂―; jaun₂ në́₃, dsa₂ i₂tián'₅ le₂tan₅₄ 'uë₃ Judea, juɨ₁cuɨng₁₂ juɨ₅ má'₂.  
\v 15 Juɨ₁lia'₂ i₂'en₅₄ guei'₅₄ 'ne₄, tsá₃ juɨ₁sióin₄ jua'₅₄ a₂'uë́'₃ 'e₂ 'uë́'₃ dsi₂néi₂ quió'₅;  
\v 16 juɨ₁lia'₂ i₂'en₅₄ ja₁nau₂ quió'₅ táng₃, tsá₃ ma₃juɨ₁jŋioi'₅₄ jua'₅₄ a₂ja₃quián₂ tsɨ₁'mɨ'₂ dsióg₂ quió'₅.  
\v 17 ¡Juɨ́g₂ bá₄ juɨ₁lia'₂ dsa₂ mɨ́₂ i₂le₁quian₅ guein₂, juɨ₁lia'₂ i₂chan₂ guein₂ bë'₅₄ i₂'ɨ́n'₂ dsi'₅₄ quió'₅ në́₃, jmɨg₄ jaun₂!  
\v 18 Mɨ₄ 'nia'₂ ne₄ Diú₄ tsá₃ juɨ₁dsi₂ŋɨ́'₂ 'nia'₂ a₂jaun₂ juɨ₁lia'₂ jein₂ güɨ́g₂.  
\v 19 Ia₁ juá'₅ jniá₂, caun₂ o₂i₁ dsɨ₅ lɨn₃ a₂le₃chan₂ dsa₂ jmɨg₄ jaun₂, caun₂ jmɨ₁uɨg₅ a₂tsá₃ ma₂ca₂rë₃chá₃ ca₂le₃ ca₂nio₃ mɨ₂güɨ́g₃, on₃ guë'₂ ma₃niog₅ jmɨg₄ jua'₅₄ a₂le₃cha₂ guë́₄ cang₂.  
\v 20 Jua'₅₄ mei'₂ guë́₃ Te₁gui'₅₄ tsá₃ ma₂ca₂jme₃të́₃ jmɨg₄ jaun₂, 'i₁jan₂ tsá₃ 'ein₂ jme₁lión₂ jua'₅₄ mei'₂ guë́₃ tsá₃ le₂jaun₂. La₁ ma₂ca₂jme₃të́₃ bá₄ jmɨg₄ jaun₂ o₄quió'₄ i₂quion'₅₄ quiáin₅. 
\p  
\v 21 ’Në₁jua'₂ chan₂ i₂ca₂juá'₂ tsɨ́'₅ 'nia'₂ jmɨg₄ jaun₂: “¡Jag₄ 'nia'₂! La₂ bá₄ chén'₅ I₂rë₂'ɨ́n₁ quián₅ Diú₄”, o₃ në₁jua'₂ 'ein₂ ca₂juá'₂: “Jó₄ 'ein₅₄”, tsá₃ o₁'en'₅₄ 'nia'₂ jág₁ jaun₂.  
\v 22 Ia₁ juɨn₅ dsa₂ i₂jme₃gau₅ ja₃lén₂ a₂juá'₂ lɨ́in₅ I₂rë₂'ɨ́n₁ quián₅ Diú₄, a₂juá'₂ në́₃ a₂lɨ́in₅ dsa₂ i₂'ë́₂ jág₁ quián₅ Diú₄; 'lióng₂ léi₄ juë'₂ a₂o₂dsain₂ jmo₃ a₂jme₃gain₂₃ dsa₂. Jua'₅₄ mei'₂ guë́₃ lé₂, ca₂të₂ dsa₂ i₂quion'₅₄ quián₅ Diú₄ jme₃gain₂₃.  
\v 23 La₁ chan'₂ 'nia'₂ rë₂jáng'₁,\f + \fr 13:23 \ft o₃, “ŋí₂ 'nia'₂”.\f* jaun₂ le₂në₅ ma₂në₂juɨ́g₂ jniá₂ 'nia'₂ ca₂le₃jë́₃ të₃jŋiá₅. 
\s1 'A₂ lia'₂ guan'₂ Jaun₅ dsa₂ mɨ₂güɨ́g₃ 
\r (Mateo 24:29-35, 42―44; Lucas 21:25-36) 
\p  
\v 24 Jë₁ma₂ca₂ŋag₅ jmɨg₄ o₂i₁ dsɨ₅ jaun₂, 
\q1 'iog₂ në́₃ co₂dsia₅ le₃lia'₂, 
\q2 tsɨ'₂ në́₃ tsá₃ ma₃tág₅ jnia₅₄; 
\q1  
\v 25 Nei₅ guë'₂ në́₃ qui₂tsɨ₃séi'₂;\f + \fr 13:25 \ft Co₂'nió'₄ le₃jua'₅₄, caun₂ cosa a₂tsá₃ 'i₄ jme₂dsí₂, a₂ca₂jmo₃ Diú₄. 'Nio'₂ ja₁ton₅ Salmo 8:3; Romanos 1:25.\f* 
\q2 ca₂le₃jë́₃ guë́₄ 'e₂ bí₂ cha₂ guei'₅₄ mɨ₂güɨ́g₃ 
\q2 qui₃guian'₃.\f + \fr 13:25 \ft Isaías 13:10; 34:4.\f* 
\p  
\v 26 ’Të₃jë₄ jaun₂ guë́₄ në́₃, jɨ́n₂ dsa₂ Jaun₅ dsa₂ mɨ₂güɨ́g₃, jŋiói'₂ guei'₅₄ jë₄ jnei₅ quian'₅₄ ca₂le₃jë́₃ juɨ₅bí₂ a₂'io₂₃ jláin'₁.  
\v 27 Jaun₂ qui₃chein₃ ángeles quiáin₅, a₂të₂ dsa₂ i₂quion'₅₄ quiáin₅ i₂chan₂ ca₂le₃jë́₃ juɨg₂ te₁'i₁ ca₂taun₂ ca₂taun₂ mɨ₂güɨ́g₃. 
\p  
\v 28 ’Jme₁tɨn₅ 'nia'₂, juɨ₁le₂ŋɨ́'₂ 'au'₂ jág₁ a₂jáng'₅ léi₄ juɨ₁lia'₂ nɨ₁'ma₂ a₂'ag₅ mɨ́g₂ higos; jme₁chéi'₂ gu'₂-nei'₅₄, qui₂ja₂'iá₃ mog'₅₄ në́₃, ŋi'₅₄ bá₄ 'nia'₂ a₂ma₂ja₂quián₃ jein₂ 'iog₂ bá₄ jaun₂.  
\v 29 Le₂në₅ bá₄ 'nia'₂ jaun₂ në́₃, jë₁ma₂të₅ ne'₅₄ a₂lë́₂ ca₂le₃jë́₃ a₂në₅, juɨ₁le₂ŋi'₅₄ bá₄ 'nia'₂ a₂ma₂ja₂quiáin₃, në₂jag₄ bá₄ i₂ma₂chén'₅ o₄'né₄ bá₄ 'éi₂.  
\v 30 A₂dsɨ₂jó'₃ juá'₅ jniá₂ juɨ́g₂ 'nia'₂, tsá₃ dsɨ₃ŋɨ́₂ tsɨ₁jon₂ la₂,\f + \fr 13:30 \ft o₃, “né'₃ a₂dsián₃ dsa₂ i₂lɨ́n₅ raza la₂.” \f* ca₂lia'₂ ca₂lë₃ ca₂le₃jë́₃ a₂në₅.  
\v 31 Jaun₂ já₅ jmɨg₄, guei'₅₄ dsi₂güɨg₂ quian'₅₄ mɨ₂güɨ́g₃ la₂ ŋag₅, la₁ jág₁ quió₃, o₁lɨ́g'₂ jmɨg₄ tsá₃ ŋag₅ jua'₅₄ a₂tsá₃ le₃ti₃. 
\p  
\v 32 ’La₁ 'i₁jan₂ tsá₃ 'ein₂ ŋi₅ 'e₂ 'ió'₄, 'e₂ hora lé₂ a₂jaun₂, on₃ guë'₂ ángeles i₂tion'₅₄ guei'₅₄ i₂juɨ́g₃, on₃ guë'₂ 'ŋiog₅ Ja₁ŋi'₅₄ Diú₄. Jŋia'₅₄ lia'₂ 'ŋiog₅ bá₄ Diú₄ Jmei₂ ŋi₅. 
\p  
\v 33 ’Chan'₂ 'nia'₂ rë₂jáng'₁, jme₁jnio₂ 'nia'₂ ne'₅₄, ia₁ tsá₃ ŋi'₅₄ 'nia'₂ 'e₂ jmɨg₄ lé₂.  
\v 34 Lé₂ juɨ₁lia'₂ jan₂ dsa₂ i₂o₂'ɨn₅ dsi₂néi₂ quió'₅, dsó₅ dsɨ₂ŋɨ́₃ uɨ́ng₂; dsia₂₃ gu₂ dsa₂ i₂jme₂ti₃ ne₅₄ dsi₂néi₂ quió'₅, le₂jan₂ le₂jan₂ 'éi₂ jma₃quén₅ ta₁ cuë́'₅ con'₂ ca₂tɨ́in₂, tsɨ́'₅ mozo i₂jmo₅ 'í₁ o₄'né₄ a₂chain₂ rë₂jáin₁.  
\v 35 Jaun₂ le₂në₅ bá₄ 'nia'₂ ján₃, rë₂jáng'₁ 'nia'₂ chang'₂, ia₁ tsá₃ ŋi'₅₄ 'nia'₂ 'e₂ 'ió'₄ guan'₂ dsa₂ i₂quió'₅ dsi₂néi₂, të₂le₃ ca₂nei₂, o₃ dsi₃nei₅, o₃ jë₁ma₂ca₂'o₃ i₁tú₃, o₃ të₂le₃ ca₂jnia₃ 'e₂,  
\v 36 ia₁ con'₂ tsá₃ ŋó₅ në₁jua'₂ ca₂guáin'₃ co₂tiá₂, jo₅₄ rë₂güɨ́n'₃ 'nia'₂.  
\v 37 Jaun₂ jág₁ a₂juɨ́g₂ jniá₂ 'nia'₂ la₂, juɨ́g₂ ca₂le₃jɨ́n₃: “¡Chan'₂ 'nia'₂ rë₂jáng'₁!” 
\c 14  
\s1 Ca₂quɨn'₃ dsa₂ jág₁ a₂tsáin'₂ Jesús 
\r (Mateo 26:1-5; Lucas 22:1-2; Juan 11:45-53) 
\p  
\v 1 Tɨn₃ jmɨg₄ né'₃ a₂të₅₄ Jmɨg₄ Të₂'ɨn₅₄, a₂guë́'₅ dsa₂ i₁ŋí'₄ 'ua'₂ a₂tsá₃ juɨ₁ levadura quian'₅₄, jaun₂ juɨg₅₄ jme₂dsa₂, të₅juá'₅ në́₃ ca₂'náu'₃ juɨ₅ 'a₂ lia'₂ tsáin'₂ Jesús quian'₅₄ caun₂ mai₅₄, jaun₂ jŋag'₃.  
\v 2 Jaun₂ ca₂dsia₃ jág₁, juá'₂: 
\p ―La₁ tsá₃ 'nió'₅ jmó₁ jniog₄ të₃ niog₅ jmɨg₄, jme₁né₄, ia₁ con'₂ tsá₃ ŋó₅ në₁jua'₂ ca₂tó'₂ dsa₂ juɨg₂ mɨ'₅₄. 
\s1 Jan₂ 'io₅₄ ca₂tsɨ́in₂ no'₅₄ mɨ₂juɨg₂ Jesús 
\r (Mateo 26:6-13; Juan 12:1-8) 
\p  
\v 3 Lia'₂ con'₂ 'ein₅₄ guë́₄ juɨg₂ Betania ja₁quió'₄ i₂të́'₂ dsa₂ Si₂mu₅₄ 'Mé'₅ 'Iog₅, jaun₂ ca₂dsióg₃ jan₂ 'io₅₄ quian₅ caun₂ tsɨ́₅ no'₅₄ mɨ₂juɨg₂ a₂'mu'₅₄, a₂lë́₅ jmá'₃ no'₅₄ quió'₅ mɨ₁'au₂ nardo. Jaun₂ ca₂niá₃ nɨ₁tsɨ́₅, jaun₂ ca₂'ág₂ no'₅₄ mɨ₂dsi₄ Jesús.  
\v 4 Jaun₂ i₂lɨn₅₄ dsa₂ i₂tion'₅₄ ja₁jaun₂, dséin₂ ca₂tɨ́in₂, jaun₂ ca₂dsia₃: 
\p ―Tsá₃ ne₄ 'e₂ lë₃ në₂'éin₂ no'₅₄ mɨ₂juɨg₂ quió'₅.  
\v 5 Jua'₅₄ co₂ŋei'₅₄ bá₄ në₂'nag₃ quian'₅₄ 'nɨ₅ 'ŋiá₂-láu₂ 'éi'₃ cu₄ denario, jaun₂ jme₁jme₂'oin₅₄ dsa₂ te₂ŋé₂. 
\p Jaun₂ ca₂dséin₃ quiain'₅₄ 'io₅₄ 'éi₂. 
\p  
\v 6 Jaun₂ ca₂juá'₂ Jesús: 
\p ―Tsá₃ lë₁lein'₅₄. ¿'E₂ lë₃ cuë'₂ 'nia'₂ o₂me'₅₄ dsɨ₅? A₂në₂jmóg'₂ në₅, caun₂ a₂dse₃ bá₄ në₅.  
\v 7 Ca₂le₃jë́₃ jmɨg₄ bá₄ i₂nio₄ dsa₂ te₂ŋé₂ jɨn'₄ 'nia'₂; lé₂ bá₄ jme₁'oin'₁, chi₂jua'₂ lɨ́g'₂ 'niog'₂ 'nia'₂ jme₁'oin'₁. La₁ jniá₂ në́₃ tsá₃ ma₃uë́₂ 'en₅₄ jniá₂ quian'₅₄ 'nia'₂.  
\v 8 'Io₅₄ në₅, në₂jmo₃ 'a₂ con'₂ jŋia'₅₄ le₃quɨ'₅₄ jmɨg₄ jmo₃. Ma₂në₂tsáng₂ të₂jŋiá₅ no'₅₄ mɨ₂juɨg₂ quió₃, ma₂në₂jmóg'₂ co₂jŋia₅₄ jë₁ma₂të́₂ rë₁'ong₃.  
\v 9 A₂dsɨ₂jó'₃ juɨ́g₂ jniá₂ 'nia'₂, ca₂le₂con₂ mɨ₂güɨ́g₃ ja₁'ë́₂ dsa₂ jág₁ dse₃ quió₃, ján₃ bá₄ le₂jaun₂ dsiog'₂ dsɨ́₅ dsa₂ 'ɨin₃ 'io₅₄ në₅. 
\s1 Jmo₅ Judas caun₂ jág₁ a₂'nɨi₂₃ Jesús 
\r (Mateo 26:14-16; Lucas 22:3-6) 
\p  
\v 10 Jaun₂ në́₃ Judas Iscariote i₂jme₁lɨ́n₄ jan₂ chi'₂ dsɨ₂guia₃-tɨ́n₂ quián₅ Jesús, ŋei₅₄ i₁dsia₂ jág₁ quian'₅₄ juɨg₅₄ jme₂dsa₂ a₂jáng'₂.  
\v 11 Jaun₂ 'io'₂ jmo₅ dsa₂ can'₅₄ jme₁ca₂nág₂, jaun₂ ca₂jén'₃ cu₄. Jaun₂ guë́₄ në́₃ ca₂'náu'₃ Judas dsɨ́₅ 'a₂ lia'₂ cuɨn₅ jmɨg₄ a₂jɨ́in'₂ Jesús, jaun₂ tsáun'₂ dsa₂. 
\s1 Má₃ jë₁ca₂tó'₂ quió'₅ Te₁gui'₅₄ 
\r 1 Corintios 11:23-26) 
\p  
\v 12 Jmɨg₄ le₂'uɨg₅₄ a₂niog₅ Jmɨg₄ Të₂'ɨn₅₄ a₂guë́'₅ dsa₂ i₁ŋí'₄ a₂tsá₃ quian'₅₄ levadura, jmɨg₄ a₂jme₁jme₂dsian₅ dsa₂ já'₂ cha'₂ quián₅ jmɨg₄, jaun₂ ca₂ŋag₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ ca₂ŋɨ́i'₃ Jesús: 
\p ―¿A₂já'₄ 'niog'₂ dsɨ₁jmó₁ jnia'₅₄ co₂jŋia₅₄ má₃ Jmɨg₄ Të₂'ɨn₅₄ quiáng'₂? 
\p  
\v 13 Jaun₂ ca₂chein₃ on₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅, ca₂juá'₂: 
\p ―O₂nó'₅ 'nia'₂ jë₄ juɨg₂. Ja₁jaun₂ jen'₂ 'nia'₂ jan₂ dsa₂ ŋe'₂ i₂quion₂ jmɨg₂ quian'₅₄ nɨ₁dsɨg₁. Jaun₂ o₁'én'₃ 'nia'₂ dsa₂ 'éi₂.  
\v 14 Dsi₂néi₂ ja₁'í₂ 'éi₂, juɨg'₅₄ dsa₂ juɨg₅₄ dsi₂néi₂: “Le₂la₂ juá'₂ të₅, ¿Na₂ dsi₂néi₂ ja₁guë'₄ Jmɨg₄ Të₂'ɨn₅₄ co₂lë₅ quian'₅₄ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáng₃?”  
\v 15 Jaun₂ 'éi₂ në́₃, 'ë₃ caun₂ dsi₂néi₂ juë'₂ ja₁lë́₄ guei'₅₄ a₂ma₂lë́₅ co₂jŋia₅₄. Ja₁jaun₂ o₂jmo₄ 'nia'₂ co₂jŋia₅₄ má₃ que₅₄ jniog₄. 
\p  
\v 16 Jaun₂ ca₂i₃lén₂ bá₄ dsa₂ on₃ 'éi₂. Jme₁ca₂dsi₃léin₂ jë₄ juɨg₂ në́₃, ca₂dsó'₂ lia'₂ con'₂ lë́₅ jág₁ ca₂juá'₂ Jesús. Jaun₂ ja₁jaun₂ ca₂jmo₃ co₂jŋia₅₄ má₃ a₂guë́'₃ Jmɨg₄ Të₂'ɨn₅₄. 
\p  
\v 17 Jme₁ca₂nei₂ jaun₂, ca₂dsióg₃ Jesús quiain'₅₄ ta₁guia₃-tɨ́n₂ chi'₂ dsɨ₂guia₃-tɨ́n₂.  
\v 18 Jme₁ma₂tiáin'₅ guë́'₅, jaun₂ ca₂juá'₂ Jesús: 
\p ―A₂dsɨ₂jó'₃ juá'₅ jniá₂ la₂, jan'₂ 'nia'₂ i₂guë'₅ jniá₂ co₂lë₅ quiang'₅₄ bá₄ i₂jang'₂ jniá₂. 
\p  
\v 19 Jaun₂ në́₃ ca₂tá'₂ 'lia'₂ dsɨ́₅ 'ŋio₅ lɨn₃ tiáin'₅, jaun₂ ca₂jme₃lióg₃ ca₂ŋɨ́i'₃ Jesús le₂jain₂ le₂jain₂, ca₂juá'₂: 
\p ―¿On₁jua'₅₄ jniá₂ 'ág'₅? 
\p  
\v 20 Jaun₂ ca₂ŋag₃ Jesús: 
\p ―Jan'₂ 'nia'₂ i₂lë́₂ guia₃-tɨ́ng'₂ i₂tiá₂ mɨ₂gu₂ co₂lë₅ 'ŋió'₃ uɨng₅ quian'₅₄ jniá₂.  
\v 21 Dsón'₂ bá₄ dsau₅ Jaun₅ dsa₂ mɨ₂güɨ́g₃ 'ein₅₄ juɨ₅ dsó₃ lia'₂ con'₂ lë́₅ juá'₂ ne₄ Si₂; la₁ ¡'e₂ guë́₄ juɨ́g₂ dsa₂ i₂jáng'₂! Jme₁dse₃ quió'₅ jua'₅₄ co₂ŋei'₅₄ bá₄ tsá₃ ca₂rë₃cháin₃. 
\p  
\v 22 Të₁lia'₂ tiáin'₅ guë́'₅, ca₂jŋa'₃ Jesús i₁ŋí'₄, ca₂cuë́'₃ ti₁'mag'₄ Diú₄, jaun₂ guë́₄ në́₃ ca₂dsioin₃, ca₂cuë́'₃ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅. Jaun₂ ca₂juá'₂: 
\p ―Qué'₂ 'nia'₂, ia₁ ŋɨ₃ bá₄ jniá₂ i₁ŋí'₄ la₂. 
\p  
\v 23 Jaun₂ ca₂can₃ táng₃ copa 'a₄ vino, ján₃ bá₄ le₂jaun₂ ca₂cuë́'₃ ti₁'mag'₄ Diú₄, jaun₂ guë́₄ ca₂cuë́'₃ chi'₂ dsɨ₂guia₃-tɨ́n₂. Jaun₂ ca₂le₃jɨ́in₃ bá₄ ca₂'ɨn'₃.  
\v 24 Ca₂juá'₂ Jesús: 
\p ―Jmɨ₃ bá₄ jniá₂ la₂, a₂lɨ'₅₄ jág₁ 'mɨ́₂ a₂të₃ron₅₄,\f + \fr 14:24 \ft 'Nio'₂ ja₁ton₅ Éxodo 24:8; Jeremías 31:31-34; Hebreos 10:29; 13:20.\f* a₂niog₅ dsɨ₃'o₅₄ o₄quió'₄ juɨn₅ dsa₂.  
\v 25 Dsón'₂ juá'₅ jniá₂, tsá₃ ma₃lɨ́g'₂ jmɨg₄ jua'₅₄ a₂guɨ'₅₄ guë́₄ táng₃ vino ca₂lia'₂ ca₂të́₂ jmɨg₄ i₁guɨ'₄ táng₃ caun₂ vino 'mɨ́₂ co₂lë₅ quiang'₅₄ 'nia'₂ ja₁gon₂ Diú₄. 
\s1 Ca₂juá'₂ Jesús a₂tsá₃ tion₃ Pe₄ a₂cuɨg₂₃ 
\r (Mateo 26:30-35; Lucas 22:31-34; Juan 13:36-38) 
\p  
\v 26 Jme₁ca₂lë₃ 'ë₂₃ jme₂juɨin'₂ Diú₄, jaun₂ guë́₄ i₃léin₂ juɨ₅ Má'₂ Olivos.  
\v 27 Jaun₂ ca₂juá'₂ Jesús ca₂tsɨ́'₃ chi'₂ dsɨ₂guia₃-tɨ́n₂: 
\p ―Ca₂le₃jɨ́n'₃ bá₄ 'nia'₂ tiá'₃ jén₂ 'au'₂, 'ág'₁ 'nia'₂ caun₂-tɨn₃ 'au'₂; ia₁ rë₂ton₅ ne₄ Si₂ ja₁juá'₂: “Jŋɨ́'₄ jniá₂ dsa₂ i₂jŋia₅ já'₂ cha'₂, jaun₂ já'₂ cha'₂ në́₃ dsɨ₃léin₂ tsɨ₁rë₂jain₅₄.”\f + \fr 14:27 \ft Zacarías 13:7.\f* 
\v 28 La₁ cang₂ jë₁ma₂ca₂jeng'₅₄ táng₃, nei₅₄ jniá₂ jŋiág₅ juɨ₅ Galilea lia'₂ con'₂ guë́₄ 'nia'₂. 
\p  
\v 29 Jaun₂ në́₃ ca₂ŋag₃ Pe₄: 
\p ―O₁jŋia'₅₄ la₂ ca₂'ág₂ caun₂-tɨn₃ dsɨ́₅ ca₂le₃jɨ́n₃ rɨ́ng'₃, la₁ jniá₂, o₁lɨ́g'₂ jmɨg₄ tsá₃ 'ag₅₄ caun₂-tɨn₃ dsɨ₃. 
\p  
\v 30 Jaun₂ ca₂juá'₂ Jesús: 
\p ―A₂dsɨ₂jó'₃ juá'₅ jniá₂, a₂'uë₂ në₃, né'₃ a₂'ó₃ jë₁ca₂të́₂ tɨn₃ ráun₂\f + \fr 14:30 \ft A₂lɨn₅₄ chog₅₄ si₂ tsá₃ chi₁ton₅ “jë₁ca₂të́₂ tɨn₃ ráun₂.” \f* të₁guí₄ dsó₂, hora jaun₂ dé₄ dsón'₂ chéng'₅ tsá₃ tóng'₄ ta₁'nɨ₅ ráun₂ a₂cuɨg'₂ jniá₂. 
\p  
\v 31 Jaun₂ ca₂ŋag₃ táng₃ Pe₄: 
\p ―O₁jŋia'₅₄ la₂ ca₂dsau₃ jniog₄ co₂lë₅, o₁lɨ́g'₂ jmɨg₄ jua'₅₄ a₂tsá₃ 'ɨ́n₄ jniá₂ 'ne₂. 
\p Le₂jaun₂ bá₄ ca₂juá'₂ ca₂le₃jɨ́n₃ rɨin'₅₄ ján₃. 
\s1 Ca₂chi₃lén'₂ Jesús Diú₄ caun₂ ja₁chei₂ Getsemaní 
\r (Mateo 26:36-46; Lucas 22:39-46) 
\p  
\v 32 Jaun₂ ca₂dsi₃léin₂ caun₂ ja₁chei₂ Getsemaní. Jaun₂ ca₂juá'₂ ca₂tsɨ́'₃ chi'₂ dsɨ₂guia₃-tɨ́n₂: 
\p ―Ja₁lá₃ tián'₂ 'nia'₂, të₁lia'₂ i₁chi₁leng'₄ Diú₄. 
\p  
\v 33 Jaun₂ ca₂jŋiai₃ Pe₄, Jacobo, Juan₅₄ në́₃. Jaun₂ ca₂rë₃lióg₃ ca₂tá'₂ quian₅ o₂i₁ dsɨ₅ 'ŋio₅ lɨn₃.  
\v 34 Jaun₂ ca₂juá'₂ ca₂tsɨ́'₃ i₂ún₂ i₂quiain'₅₄: 
\p ―'Ŋio₅ lɨn₃ quian₅₄ o₂i₁ dsɨ₅, ca₂lia'₂ jmá'₃ le₃jóng₂ të₂në₃. Ja₁lá₃ tián'₂ 'nia'₂ jme₁jnio₂ 'nia'₂ ne'₅₄. 
\p  
\v 35 Ca₂juɨg₄ bá₄ ca₂ŋó₃ guë́₄ ne₄ juɨ₅. Ja₁jaun₂ ca₂tóin₂ të₂ 'uë₃, ca₂mɨ₃ ca₂tsɨ́'₃ Diú₄, jua'₅₄ lé₂ bá₄ le₃lé₂ a₂tsá₃ dsɨ₃ŋɨ́i₂ uɨg₅ 'e₂ niog₅ dsɨ₃ŋɨ́i₂ hora jaun₂.  
\v 36 Të₃jë₄ chi₂léin'₂ Diú₄, ca₂juá'₂: 
\p ―Abba,\f + \fr 14:36 \ft Abba: co₂'nió'₄ le₃jua'₅₄: “Tia₅₄” quian'₅₄ jág₁ jmei₅ arameo.\f* Tia₅₄ quiáng₃, ca₂le₃jë́₃ bá₄ lé₂ le₃jmó'₂ 'ne₂. Lio₄ jniá₂ 'e₂ a₂dsɨ₃ŋɨ́g₂ në₃. La₁ tsá₃ juɨ₁le₅₄ con'₂ 'nio₃ jniá₂; juɨ₁le₅₄ bá₄ a₂'ŋio₂ 'au'₂ 'ne₂. 
\p  
\v 37 Jaun₂ ca₂dsiáin'₃ táng₃ ja₁tián'₄ 'éi₂, la₁ le₁güɨ́n₃ bá₄ 'éi₂ tiáin'₅ në́₃. Jaun₂ ca₂të́'₃ Pe₄, ca₂juá'₂: 
\p ―¿Rë₁güɨ́n'₃ bá₄ 'ne₂, Si₂mu₅₄? ¿Tsa₁ tiang'₃ jua'₅₄ caun₂ hora bá₄ jme₁jniog'₂ guë́₄ ne'₅₄?  
\v 38 Jme₁jnio₂ 'nia'₂ ne'₅₄, chi₁len'₄ 'nia'₂ Diú₄, ia₁jaun₂ tsá₃ tsɨ₃sén'₂ 'nia'₂ dso₄. Dsón'₂ bá₄ 'ŋio₂ dsɨ́₅ jme₂dsí₂ quián'₂ 'nia'₂, la₁ nɨ₁ŋɨ'₁ guion'₅₄ bá₄ 'nia'₂ 'uan₅₄. 
\p  
\v 39 Jaun₂ ŋó₃ bá₄ táng₃ i₁chi₂i₁lein'₄ Diú₄. Ján₃ bá₄ jág₁ le₂jaun₂ ca₂juá'₂ táng₃.  
\v 40 Jaun₂ guáin'₃ táng₃ ja₁tián'₄ chi'₂ dsɨ₂guia₃-tɨ́n₂, la₁ le₁güɨ́n₃ bá₄ táng₃ 'éi₂ tiáin'₅, ia₁ a₂ŋɨ́₄ lë₃ 'ŋio₅ lɨn₃ ma₂i₁güɨ́in₃. Jaun₂ tsá₃ 'e₂ ŋi₅ ŋag₃.  
\v 41 Jaun₂ jme₁dsiáin'₃ táng₃ ja₁tián'₄ 'éi₂ jë₁ca₂të́₂ 'nag'₂ ráun₂, jaun₂ ca₂juá'₂: 
\p ―¿'E₂? ¿Lia'₂ ma₂tián'₅ jaun₂ bá₄ 'nia'₂ le₁güɨ́ng'₃? Co₂në₅ bá₄ në́₃. Ca₂të́₂ bá₄ hora në́₃. Ŋí₂ 'nia'₂. Ma₂rë₂jɨn'₅₄ bá₄ Jaun₅ dsa₂ mɨ₂güɨ́g₃ o₄gú₃ dsa₂ i₂le₁cán'₄ dso₄.  
\v 42 Nau₂ 'nia'₂ në́₃, ma₃, ia₁ në₅ ma₂já₅ i₂jáng'₂. 
\s1 Ma₂le₁te₂ dsa₂ Jesús 
\r (Mateo 26:47-56; Lucas 22:47-53; Juan 18:2-11) 
\p  
\v 43 Dsɨ₂juɨ₅ të₃jë₄ dsia₂₃ jág₁ jaun₂, ca₂dsióg₃ Judas, i₂lɨ́n₅ jan₂ dsa₂ i₂guia₃-tɨ́n₂. Juɨn₅ lɨn₃ dsa₂ i₂ja₂lén₂ quiong'₅₄ qui₂le₁quian₅ ŋi₁tág₂, i₂le₁quian₅ nɨ₁'ma₂ në́₃, i₂chen₄ quián₅ juɨg₅₄ jme₂dsa₂, quian'₅₄ të₅juá'₅, ca₂le₃jɨ́n₃ guë́₄ dsɨ₂gui'₅₄ can'₅₄ në́₃.  
\v 44 Jaun₂ Judas në́₃, ia₁ ma₂ca₂jmo₃ bá₄ jág₁ le₂jŋiá₅ 'e₂ léi₄ jmo₃ jë₁ma₂të́₂ rë₁jáng'₂, jme₁ma₂juá'₂: “I₂chen'₄ jniá₂ quió'₅, i₂'éi₂ bá₄ jma'₅₄ 'nia'₂, jaun₂ të'₅₄ 'nia'₂, lë́₅ 'í₁.” 
\p  
\v 45 Jaun₂ dsɨ₂juɨ₅ jme₁dsióg₃ Judas, ca₂jme₃quiáin₃ con₂ Jesús, jaun₂ ca₂juá'₂: 
\p ―¡Të₅! ―Jaun₂ ca₂chen'₃ quió'₅.  
\v 46 Jaun₂ dsɨ₂juɨ₅ le₂jaun₂ ca₂jŋau'₃ dsa₂, ca₂tág₃. 
\p  
\v 47 La₁ jan₂ i₂jme₁chén'₄ cau₅ në́₃, ca₂dsi₂ ŋi₁tág₂, ca₂ti₃ caun₂ rë₂gua₄ dsa₂ i₂jme₂ti₃ quián₅ jme₂dsa₂ dsen₅₄.  
\v 48 Jaun₂ ca₂juá'₂ Jesús ca₂tsɨ́'₃ dsa₂: 
\p ―¿Dsa₂ 'ang₂ lɨ́ng₅, 'e₂ ja₂nó'₅ 'nia'₂ le₁quian'₄ ŋi₁tág₂, 'ma₂ në́₃, a₂të'₅₄ jniá₂?  
\v 49 Jua'₂ ca₂le₃jë́₃ jmɨg₄ bá₄ 'eng₅₄ jɨn'₄ 'nia'₂, jme₂tɨ́ng₁ dsa₂ i₁dsi₅ guá'₅, tsá₃ ma₂ca₂chong'₂ guë'₂ 'nia'₂ ja₁jaun₂. La₁ lë́₂ le₂në₅, ia₁jaun₂ le₃ti₃ con'₂ lë́₅ juá'₂ ne₄ Si₂. 
\p  
\v 50 Jaun₂ qui₂ca₂cuɨng₃ bá₄ ca₂le₃jɨ́n₃ chi'₂ dsɨ₂guia₃-tɨ́n₂, ca₂téin₂ bá₄ Jesús. 
\s1 Dsó₂ i₂ca₂cuɨng₃ të₃rë₂ŋɨ́₅ 
\p  
\v 51 Të₃jë₄ jaun₂, ŋó₃ jan₂ dsó₂ rë₂bóin'₅ caun₂ tsɨ₁'mɨ'₂ tióg₃, 'ein₂₃ Jesús.  
\v 52 Jaun₂ jme₁ca₂jŋau'₃ dsa₂, la₁ ca₂lóin₂ bá₄, jmá'₃ tsɨ₁'mɨ'₂ bá₄ ca₂lɨ́'₃ dsa₂. Jaun₂ ŋái'₃ bá₄ të₃ rë₂ŋɨ́i₅. 
\s1 Ma₂chén'₅ Jesús ne₄ dsɨ₂tan₅₄ quián₅ guá'₅ 
\r (Mateo 26:57-68; Lucas 22:54-55, 63―71; Juan 18:12-14, 19―24) 
\p  
\v 53 Jaun₂ ca₂tág₃ dsa₂ Jesús i₁jo₅₄ ne₄ jme₂dsa₂ dsen₅₄, jaun₂ ca₂ŋɨ'₂ ca₂le₃jɨ́n₃ juɨg₅₄ jme₂dsa₂, quian'₅₄ dsɨ₂gui'₅₄ can'₅₄, të₅juá'₅ në́₃.  
\v 54 Pe₄ në́₃ ca₂ŋó₃ uɨ́ng₂ të₂quɨ́in₃ 'ein₂₃ Jesús ca₂të₂ i₁dsi₅ quió'₅ jme₂dsa₂ dsen₅₄. Ja₁jaun₂ ca₂guá₂ cau₅ si₂ quiain'₅₄ 'lióg₂, ca₂jme₃dsioin'₂. 
\p  
\v 55 Jaun₂ juɨg₅₄ jme₂dsa₂, quian'₅₄ ca₂le₃jɨ́n₃ dsɨ₂tan₅₄ quián₅ guá'₅ në́₃, qui₂ca₂'náu'₃ juɨ₅ 'a₂ lia'₂ bóin'₂ dso₄ Jesús ia₁jaun₂ jŋag'₃. La₁ tsá₃ dso'₂ guë'₂ juɨ₅ 'e₂ dso₄ jme₃cáu'₂,  
\v 56 ia₁ juɨn₅ i₂qui₂ca₂jmo₃ jág₁ të₂jág₁ a₂bóin'₂ dso₄ Jesús, la₁ tsá₃ të₃tsɨ'₅₄ guë'₂ jág₁ quió'₅ tioin'₅₄.  
\v 57 Jaun₂ i₂lɨn₅₄ në́₃ qui₂ca₂nau₂ ca₂jmo₃ jág₁ të₂jág₁ a₂'nɨi₂₃ Jesús, ca₂juá'₂: 
\p  
\v 58 ―Ma₂néi₁ jnia'₅₄ juá'₂ i₂në₅: “A₂'éng₄ guá'₅ templo a₂ca₂jmo₃ dsa₂ mɨ₂güɨ́g₃, jaun₂ quian'₅₄ 'nɨ₅ jmɨg₄ jmóg'₄ táng₃ 'ŋió₃ caun₂ guá'₅ siá'₂, on₃jua'₅₄ lia'₂ lë́₅ guá'₅ në₅ a₂ca₂jmo₃ dsa₂ mɨ₂güɨ́g₃.” 
\p  
\v 59 On₃ guë'₂ quian'₅₄ jág₁ jaun₂ ca₂lɨ́'₃ jág₁ rë₂. 
\p  
\v 60 Jaun₂ ca₂nau₂ jme₂dsa₂ dsen₅₄ të₃jë₄ tioin'₅₄ jaun₂, jaun₂ ca₂ŋɨ́i'₃ Jesús ca₂juá'₂: 
\p ―¿Tsa₁ 'e₂ ŋag'₅₄ 'i₁caun₂? ¿I₂'e₂ bá₄ jág₁ në₅ jme₂cáu'₂ dsa₂ quiang'₂? 
\p  
\v 61 La₁ tei₄ bá₄ ca₂nau₂ Jesús, tsá₃ ma₃'e₂ ca₂ŋag₃. Con'₂ siá'₂ ca₂ŋag₃ táng₃ jme₂dsa₂ dsen₅₄, ca₂juá'₂: 
\p ―¿Dsón'₂ 'ne₂ lɨ́ng'₅ dsa₂ I₂rë₂'ɨ́n₁, Ja₁ŋi'₅₄ I₂jŋió₅? 
\p  
\v 62 Jaun₂ guë́₄ ca₂ŋag₃ Jesús: 
\p ―Ján₅, jniá₂ bá₄ lɨ́ng₅. Ján₃ bá₄ të₃ ne'₅₄ 'nia'₂ jë₁ma₂të́₂ rë₁guá₃ Jaun₅ dsa₂ mɨ₂güɨ́g₃ të₂le₃ gu₂ ne₁ quió'₅ i₂'uan'₂, jaun₂ ján₃ bá₄ jag'₅₄ 'nia'₂ jë₁ma₂të́₂ rë₁jŋiói'₂ táng₃ jë₄ jnei₅ guei'₅₄. 
\p  
\v 63 Jaun₂ jme₂dsa₂ dsen₅₄ në́₃, jme₁ca₂nág₂ jág₁ jaun₂, ca₂chein₃ nɨ₁tsɨn'₅₄ 'ŋiog₅,\f + \fr 14:63 \ft Jme₁chí'₄ tag₄ quió'₅ dsa₂ judíos jmɨg₄ jaun₂ a₂gág₅ dsa₂ nɨ₁tsɨn'₅₄ cuë₂₃ léi₄ jë₁ma₂'í₅ 'nei₂ dsɨ́₅, o₃ jme₁'i₄ quɨ'₂ dsɨ́₅.\f* jaun₂ ca₂juá'₂: 
\p ―¿'E₂ guë́₄ jmá'₃ jág₁ 'lióng₂ 'niog₂ jniog₄ jua'₅₄ a₂jáng'₃ guë́₄ dsa₂ sián'₂ jág₁ dsau₅?  
\v 64 Ma₂në₂nei'₂ bá₄ 'nia'₂ guiong'₅₄ a₂ma₂në₂juá'₂ i₂në₅ 'ɨin₂₃ Diú₄. ¿'A₂ lia'₂ juá'₂ 'nia'₂? 
\p Jaun₂ ca₂le₃jɨ́n₃ dsa₂ ca₂juá'₂ tioin'₅₄, ca₂tɨ́in₂ jóin₂ bá₄. 
\p  
\v 65 Jaun₂ ca₂jme₃lióg₃ i₂lɨn₅₄ qui₂ca₂'ŋéi₃ quió'₅ Jesús, qui₂ca₂lio₃ dsa₂ dsɨ₂ne₅₄, jaun₂ qui₂ca₂jnó₂ në́₃ tioin'₅₄, jaun₂ juá'₂: 
\p ―¡Dsi₄ jág₁ jua'₅₄ 'ein₂ në₂quein₃ quiáng'₂! 
\p Chi'₂ 'ɨ'₅₄ quián₅ guá'₅ në́₃, ján₃ bá₄ qui₂ca₂cuë₃ ja'₂ tioin'₅₄. 
\s1 Tsá₃ ca₂tion₃ Pe₄ a₂cuɨin₂₃ Jesús 
\r (Mateo 26:69-75; Lucas 22:56-62; Juan 18:15-18, 25―29) 
\p  
\v 66 I₁dsi₅ ca₁'né₄ 'uë₃ bá₄ jme₁guá₄ Pe₄. Jaun₂ ca₂dsióg₃ jan₂ 'io₅₄ i₂jme₂ti₃ ta₁ ne₄ jme₂dsa₂ dsen₅₄,  
\v 67 jaun₂ ca₂jɨ́in₂ Pe₄ guá₅ jme₂dsioin'₂, jaun₂ ca₂jág₂ 'io₅₄ tiá₂, ca₂juá'₂: 
\p ―¿Ján₃ guë'₂ jme₁quian'₄ 'ne₂ Jesús Nazareno ó₃? 
\p  
\v 68 La₁ tsá₃ ca₂tion₃ Pe₄. 
\p ―Tsá₃ guion₅₄, on₃ guë́₄ ŋɨ́g'₂ 'e₂ a₂juá'₂ 'ne₂. 
\p Jaun₂ ca₂nau₂ Pe₄ ca₂o₃'ɨ́in₃ ca₂i₁nau₂ të₂le₃ ca₁'né₄ ja₁lë́₄ corredor. Të₃jë₄ jaun₂ ca₂'o₃ të₁guí₄ dsó₂.  
\v 69 Con'₂ siá'₂ ca₂jág₃ táng₃ 'io₅₄ ca₂jɨ́in₂ Pe₄, jaun₂ ca₂juá'₂ ca₂tsɨ́'₃ dsa₂: 
\p ―Jan₂ rɨn'₅₄ 'éi₂ bá₄ në₅. 
\p  
\v 70 La₁ ján₃ bá₄ le₂jaun₂ tsá₃ ca₂tion₃ Pe₄. Jme₁co₂lág₂ jaun₂, dsa₂ i₂tián'₅ quian'₅₄ Pe₄ ca₂juá'₂: 
\p ―Dsón'₂ rɨn'₅₄ 'éi₂ bá₄ lɨ́ng'₅, ia₁ ján₃ bá₄ Galilea chang'₂. 
\p  
\v 71 Jaun₂ në́₃, Pe₄ ca₂'ɨin₃ Diú₄ ca₂mɨ₃ a₂dsɨ₃ŋɨ́i₂ 'e₂ dsɨ₃ŋɨ́i₂, ca₂juá'₂: 
\p ―¡Tsá₃ cuɨ́ng₅ dsa₂ i₂'ɨ́n'₅ 'nia'₂! 
\p  
\v 72 Dsɨ₂juɨ₅ jaun₂ ca₂'o₃ táng₃ të₁guí₄ dsó₂ a₂ca₂të́₂ tɨn₃ ráun₂. Jaun₂ guë́₄ në́₃ ca₂dsáu'₃ dsɨ́₅ Pe₄ a₂ca₂juá'₂ Jesús le₂jŋiá₅: “Né'₃ a₂'o₃ jë₁ca₂të́₂ tɨn₃ ráun₂ të₁guí₄ dsó₂, hora jaun₂ dé₄ dsón'₂ chéng'₅ tsá₃ tóng'₄ ta₁'nɨ₅ ráun₂ a₂cuɨg'₂ jniá₂.” Jme₁ca₂dsáu'₃ dsɨ́₅ jág₁ në₅, jaun₂ guë́₄ ca₂'o₃ 'ŋio₅ lɨn₃. 
\c 15  
\s1 Chén'₅ Jesús ne₄ Pilato 
\r (Mateo 27:1-2, 11―14; Lucas 23:1-5; Juan 18:28-38) 
\p  
\v 1 Dsɨ₂juɨ₅ jme₁jnia₃ táng₃ jaun₂, ca₂ŋɨ'₂ juɨg₅₄ jme₂dsa₂ quian'₅₄ dsɨ₂gui'₅₄ can'₅₄, quian'₅₄ ca₂le₃jɨ́n₃ të₅juá'₅, ca₂le₃jɨ́n₃ guë́₄ i₂lɨ́n₅ dsɨ₂tan₅₄ quián₅ guá'₅ në́₃. Qui₂ca₂ŋɨ́i'₃ rɨin'₅₄ ca₂jmo₃ caun₂ jág₁. Ca₂'néi'₂ Jesús tioin'₅₄, jaun₂ ca₂i₁jiog₃ ne₄ Pilato.  
\v 2 Jaun₂ ca₂ŋag₃ Pilato: 
\p ―¿Dsón'₂ lɨ́ng'₅ Rag₅₄ quián₅ dsa₂ judíos? 
\p Jaun₂ ca₂ŋag₃ Jesús: 
\p ―Le₂në₅ bá₄, juɨ₁lia'₂ juá'₂ 'ne₂ në₅. 
\p  
\v 3 Jaun₂ caun₂ qui₂ca₂'nag₃ guë́₄ juɨg₅₄ jme₂dsa₂ 'lióng₂ ne₅₄ dso₄ ca₂bóin'₂ Jesús.  
\v 4 Jaun₂ con'₂ siá'₂ táng₃ ca₂ŋag₃ Pilato ca₂ŋɨ́i'₃ Jesús, ca₂juá'₂: 
\p ―¿Tsa₁ a₂ŋag'₅₄? Në₅ bá₄ nag'₂ 'ŋiag'₂ 'lióng₂ dso₄ a₂bóg'₂ dsa₂. 
\p  
\v 5 La₁ tsá₃ ma₃'e₂ ca₂ŋag₃ Jesús 'i₁caun₂. Jaun₂ jë́₃ ca₂i₃gó'₃ dsɨ́₅ Pilato. 
\s1 Ca₂o₃'ág₃ 'éi'₃ a₂jón₂ Jesús 
\r (Mateo 27:15-31; Lucas 23:13-25; Juan 18:38--19:16) 
\p  
\v 6 Jmɨg₄ jaun₂ jme₁chí'₄ tag₄ a₂lióin₂ ca₂le₃jë́₃ ŋi₂ jan₂ dsa₂ i₂'en₅₄ né'₃ 'má₃, jme₁të₅ Jmɨg₄ Të₂'ɨn₅₄, 'ein₂ ca₂'ɨn₃ dsa₂ juɨg₂ i₂lión₂.  
\v 7 Jaun₂ jme₁'en₅₄ né'₃ 'má₃ jan₂ dsa₂ i₂chen₂ Barrabás, quian'₅₄ dsa₂ i₂ma₂ca₂jme₃dsian₅ dsa₂ jme₁ca₂nau₂ 'nei₂.  
\v 8 Jaun₂ ca₂mɨ₃ dsa₂ juɨg₂ ca₂tsɨ́'₃ Pilato a₂jmo₃ con'₂ lë́₅ tag₄ chí'₅.  
\v 9 Jaun₂ ca₂ŋag₃ Pilato ca₂tsɨ́'₃ dsa₂ juɨg₂: 
\p ―¿'Niog'₂ 'nia'₂ lon₄ jniá₂ Rag₅₄ quián₅ dsa₂ judíos? 
\p  
\v 10 Ia₁ ca₂rë₃lí'₄ bá₄ Pilato 'ŋiog₅ a₂'iog₅₄ uɨg₅ dsɨ́₅ bá₄ juɨg₅₄ jme₂dsa₂ ca₂jɨ́in'₂ Jesús ne₅₄.  
\v 11 La₁ juɨg₅₄ jme₂dsa₂ në́₃ ca₂toin'₂ jág₁ dsa₂, jaun₂ tóin'₃ co₂mɨ'₅₄ a₂mɨ₃ lión₂ Barrabás bá₄.  
\v 12 Jaun₂ ca₂ŋag₃ táng₃ Pilato ca₂tsɨ́'₃ dsa₂ juɨg₂: 
\p ―¿'E₂ guë'₂ 'niog'₂ 'nia'₂ jmo₅₄ jniá₂ quian'₅₄ i₂të'₂ 'nia'₂ rag₅₄ quiáng'₂? 
\p  
\v 13 Jaun₂ ca₂ŋag₃ dsa₂ juɨg₂ co₂mɨ'₅₄ tioin'₅₄, ca₂juá'₂: 
\p ―¡Tióin₃ cróg₄! 
\p  
\v 14 Jaun₂ ca₂juá'₂ táng₃ Pilato: 
\p ―¿'E₂ 'uɨg₅₄? ¿'E₂ guë'₂ dso₄ ma₂'náu₂? 
\p La₁ të₂le₃ i₂juɨ'₂ guë́₄ co₂mɨ'₅₄ ca₂tóin'₂, ca₂juá'₂: 
\p ―¡Tióin₃ cróg₄! 
\p  
\v 15 La₁ Pilato në́₃, ia₁jaun₂ dsɨ₃lén₂ dsa₂ tei₄, ca₂lióin₂ bá₄ Barrabás i₂mɨ₅ dsa₂ lión₂. Jme₁ma₂në₂dsí₃ Pilato 'éi'₃ a₂bán₂ dsa₂ Jesús, jaun₂ ca₂jáng'₂ o₄gú₃ dsa₂ juɨg₂ jaun₂ tion₃ cróg₄. 
\p  
\v 16 Jaun₂ ca₂tág₃ 'lióg₂ Jesús të₂le₃ i₁dsi₅ ne₄ta₁, (co₂'nió'₄ caun₂ ja₁chei₂ Praetorio), jaun₂ ca₂ŋɨ́'₂ 'lióg₂ ca₂le₃jɨ́n₃ rɨin'₅₄.  
\v 17 Jaun₂ ca₂quei'₃ dsa₂ caun₂ capa 'uɨ'₃,\f + \fr 15:17 \ft Color 'uɨ'₃ juɨ₁lia'₂ 'mɨ'₂ a₂quɨ'₅₄ rag₅₄.\f* jaun₂ ca₂jmo₃ caun₂ corona quian'₅₄ chi₁uɨ́ng₃ taun₅, ca₂tó'₂ mɨ₂dsi₄ Jesús.  
\v 18 Jaun₂ ca₂jme₃lióg₃ qui₂ca₂cuag₃ Diú₄ tioin'₅₄, ca₂juá'₂: 
\p ―¡Sian'₃ 'ne₂ Rag₅₄ quián₅ dsa₂ judíos! 
\p  
\v 19 Jaun₂ qui₂ca₂bá₂ mɨ₂dsi₄ Jesús quian'₅₄ nɨ₁'ma₂ ta₅, qui₂ca₂'ŋéi₂ në́₃ tioin'₅₄, qui₂ca₂chi₃jné₃ në́₃, a₂jme₂juag'₂.  
\v 20 Jme₁ca₂lë₃ a₂lë₁co₂jmóg'₂ jaun₂, ca₂dsein₂₃ táng₃ Jesús tsɨ₁'mɨ'₂ 'uɨ'₃ a₂jme₁ca₂quei'₃. Jaun₂ ca₂quei'₃ táng₃ nɨ₁tsɨn'₅₄ a₂jme₁qui'₂. Jaun₂ guë́₄ ca₂jŋiai₃ Jesús a₂dsɨ₃tion₃ cróg₄. 
\s1 Ca₂tion₃ dsa₂ cróg₄ Jesús 
\r (Mateo 27:32-44; Lucas 23:26-43; Juan 19:17-27) 
\p  
\v 21 Jaun₂ ca₂chi₃quiáin₂ jmɨg₄ jan₂ dsa₂ i₂'en₅₄ juɨ₅ jón'₅ ja₁nau₂, i₂chen₂ Si₂mu₅₄ i₂chan₂ juɨg₂ Cirene, i₂lɨ́n₅ jmei₂ Alejandro quian'₅₄ Rufo, a₂cán₂ 'éi₂ cróg₄ quió'₅ Jesús. 
\p  
\v 22 Jaun₂ ca₂jŋia₃ dsa₂ Jesús caun₂ ja₁chei₂ Gólgota, (co₂'nió'₄ jein₅ jág₁ chei₂ Dsɨ₂con'₂ Nɨ₁mu₅ Mɨ₂dsi₄ 'Lag₄.)  
\v 23 Jaun₂ ca₂jén'₃ ne₄ Jesús vino a₂rë₂cón'₅ quian'₅₄ mirra, la₁ tsá₃ ca₂gue₃ 'éi₂.  
\v 24 Jaun₂ guë́₄ ca₂tion₃ cróg₄. Dsɨ₂'lióg₂ guë'₂ në́₃ ca₂jmo₃ dsióg₁ tsɨn'₅₄ Jesús, ca₂co₃ o₁ne₄ 'ein₂ lí'₂. 
\p  
\v 25 Con'₂ hora ŋí₁ ŋi₃ të₂ o₃'iog₂,\f + \fr 15:25 \ft lit. “hora 'nɨ₅.” \f* ca₂tion₃ dsa₂ cróg₄.  
\v 26 Jaun₂ ca₂tióng₃ letra dsi₄ cróg₄ co₂'nió'₄ a₂juá'₂ 'e₂ dso₄ a₂bóin'₂ Jesús, a₂juá'₂: “RAG₅₄ QUIÁN₅ DSA₂ JUDÍOS.”  
\v 27 Ján₃ bá₄ ca₂tioin₃ guë́₄ on₃ dsa₂ 'ang₂ co₂lë₅ quiong'₅₄, jan₂ të₂le₃ gu₂ ne₁, jan₂ guë'₂ të₂le₃ gu₂ jen₅.\f + \fr 15:27 \ft A₂lɨn₅₄ chog₅₄ si₂ chi₁ton₅ versículo 28, a₂juá'₂ le₂la₂: “Jaun₂ le₂jaun₂ ca₂rë₃ti₃ con'₂ lë́₅ juá'₂ Si₂ quió'₅ Diú₄: ‘A₂jmá'₂ dsa₂ 'éi₂ juɨ₁lia'₂ jë₁jmái'₂ dsa₂ i₂rɨn₂ dso₄”’.” Isaías 53:12.\f* 
\p  
\v 29 Jaun₂ ca₂le₃jɨ́n₃ dsa₂ i₂qui₂ca₂ŋɨ́₃ juɨ₅ jaun₂ qui₂ca₂jnáu'₂ jág₁ uɨg₅, qui₂bí₂ dsi₅₄, ca₂juá'₂: 
\p ―Ia₁, ¿on₁ 'ne₂ i₂juá'₂ a₂'éng'₄ guá'₅ con'₂ siá'₂ tɨng'₂ jmog'₅₄ táng₃ quian'₅₄ 'nɨ₅ jmɨg₄?  
\v 30 Në₃ në́₃, lion₄ 'ŋiag'₂, ja₁tong'₂ në₅. 
\p  
\v 31 Ján₃ bá₄ le₂jaun₂ a₂lë₁qui₂co₂jmóg'₂ juɨg₅₄ jme₂dsa₂, quian'₅₄ të₅juá'₅, dsia₂₃ jág₁ qui₂tsɨ́'₅ rɨin'₅₄, juá'₂: 
\p ―Ca₂lióin₂ bá₄ i₂sián'₂, la₁ 'ŋiog₅ bá₄ tsá₃ lé₂ le₃lióin₃.  
\v 32 Juɨ₁sión₄ cróg₄ I₂rë₂'ɨ́n₁ quián₅ Diú₄ në₅, i₂juá'₂ lɨ́n₅ Rag₅₄ quián₅ dsa₂ juɨg₂ Israel, ia₁jaun₂ të₅₄ ne₄ jniog₄, ia₁jaun₂ le₃'éin₂. 
\p Le₂jiog₅ dsa₂ i₂le₁ton₅ quian'₅₄ Jesús qui₂ca₂juá'₂ uɨg₅. 
\s1 Ca₂jon₃ Jesús 
\r (Mateo 27:45-56; Lucas 23:44-49; Juan 19:28-30) 
\p  
\v 33 Jme₁ca₂të́₂ dsi₃ŋí'₃,\f + \fr 15:33 \ft lit. “hora jŋéi₂.” \f* ca₂'ág₂ nei₂ le₂con₂ 'uë₃ jaun₂, ca₂lia'₂ ca₂të́₂ hora ŋí₁ 'nɨ₅ të₂le₃ ca₂'láu₂.\f + \fr 15:33 \ft lit. “hora ŋi₃.” \f* 
\v 34 Hora jaun₂, ca₂'ŋia₂ guë́₄ Jesús jág₁, ca₂juá'₂ tiá₂: 
\p ―Eloi, Eloi, ¿lama sabactani? ―co₂'nió'₄ a₂juá'₂: Diú₄ quiáng₃, Diú₄ quiáng₃, ¿'e₂ lë₃ ma₂në₂téi'₃ jniá₂?.\f + \fr 15:34 \ft Salmo 22:1.\f* 
\p  
\v 35 I₂lɨn₅₄ dsa₂ i₂jme₁tión₂ cau₅ jaun₂ ca₂nág₂, jaun₂ ca₂dsia₃ jág₁ tsɨ́'₅ rɨin'₅₄: 
\p ―¡Nei₂! Elías i₂jme₁'ë́₂ jág₁ quián₅ Diú₄ ma₂lɨ́g'₂ të́'₂. 
\p  
\v 36 Jaun₂ në́₃ ŋó₃ jan₂ co₂chi'₅₄ i₁quian₅₄ caun₂ nɨ₁jau₂ guion₅ jmɨg₂. Jaun₂ ca₂guioin₃ vino dsi'₃. Jaun₂ ca₂chi₃dsí₂ nei'₅₄ caun₂ nɨ₁'ma₂ ta₅, jaun₂ ca₂jén'₃ ne₄ Jesús ia₁jaun₂ jme₁'ɨ́n'₂. Jaun₂ juá'₂: 
\p ―O₁ne₄ chi₂jua'₂ jiá₃ Elías jaun₂ sió₂ quió'₅. 
\p  
\v 37 Cón'₂ bá₄ ca₂'ŋióg₂ guë́₄ Jesús tiá₂ lɨn₃, co₂tan₅₄ ca₂join₃.  
\v 38 Hora jaun₂ dé₄ dsón'₂ co₂dsia₅ ca₂chen₃ ca₂të₂ guei'₅₄ ca₂të₂ 'uë₃ ca₂lë₃ tɨn₃ tsɨ́n'₅ tsɨ₁'mɨ'₂ pa₁ a₂jme₁'ei₅ dsi₂néi₂ guá'₅ templo.  
\v 39 Jaun₂ juɨg₅₄ 'lióg₂ i₂jme₁chén'₄ cau₅ cróg₄, jme₁ca₂jág₃ 'a₂ lia'₂ ca₂jon₃ Jesús, jaun₂ ca₂juá'₂: 
\p ―Të₃dsón'₂ bá₄ jme₁lɨ́n₄ dsa₂ në₅ Ja₁ŋi'₅₄ Diú₄. 
\p  
\v 40 Jaun₂ bá₄ jme₁tión₂ i₂lɨn₅₄ 'io₅₄, jág₅ uɨ́ng₂ ján₃. Jë₄ jaun₂ jme₁chén'₄ María chan₂ Magdala, quian'₅₄ María chog₅₄ i₂chen₂ José, quian'₅₄ i₂chen₂ Jacobo\f + \fr 15:40 \ft o₃, Santiago.\f* i₂lɨ́n₅ i₂me'₂ guë́₄, quian'₅₄ guë́₄ jan₂ i₂chen₂ Salomé.  
\v 41 'Io₅₄ 'éi₂ ma₂ja₂léin₂ le₂tan₅₄ 'uë₃ Galilea jme₂ti₃ ne₄ Jesús. Juɨn₅ bá₄ guë́₄ 'io₅₄ sián'₂ i₂ma₂ja₂lén₂ 'ein₂₃ Jesús të₂ Jerusalén. 
\s1 Ca₂'on₃ Jesús 
\r (Mateo 27:57-61; Lucas 23:50-56; Juan 19:38-42) 
\p  
\v 42 Jme₁ca₂tó'₂ nei₂ jmɨg₄ jaun₂, tion'₅₄ dsa₂ jmo₂₃ co₂jŋia₅₄ juɨ₁lia'₂ 'ióg₃ jmɨg₄ jŋió₅.  
\v 43 Jaun₂ ca₂dsióg₃ José i₂chan₂ Arimatea, i₂lɨ́n₅ jan₂ dsa₂ dsen₅₄ i₂quian'₅₄ dsɨ₂tan₅₄ quián₅ guá'₅. Ia₁ 'éi₂ ján₃ jme₁chi₁jŋia₂₃ a₂'ɨ́n₂ dsɨ́₅ a₂guá₂ 'éi'₃ quió'₅ Diú₄. Jaun₂ ca₂dsia₃ tiá₂ dsɨ́₅ në́₃, ŋó₃ ja₁con₂ Pilato, ca₂i₁mɨi₁₂ 'lag₄ Jesús.  
\v 44 Jaun₂ ca₂i₃gó'₃ dsɨ́₅ Pilato jme₁ca₂nág₂ a₂ma₂jon₅ Jesús, jaun₂ ca₂të́'₃ juɨg₅₄ 'lióg₂ ca₂ŋag₃ chi₂jua'₂ dsón'₂ ma₂join₂₃.  
\v 45 Jme₁ca₂rë₃ŋi₅ ca₂juá'₂ 'lióg₂, “Dsón'₂ bá₄ le₂jaun₂ ma₂ca₂lë₃”, jaun₂ ca₂jɨ́in'₂ 'lag₄ o₄gú₃ Së́₄ 'éi₂.  
\v 46 Jaun₂ Së́₄ në́₃ ca₂i₁lia₅ 'mɨ'₂ tióg₃; quian'₅₄ a₂jaun₂ ca₂lioin₃ 'lag₄ Jesús jme₁ca₂sió₂ cróg₄. Jaun₂ ca₂to'₂ 'ŋió'₃ tau₂ 'ŋio₅ a₂jme₁ma₂lë́₅ dso'₂ nɨ₁'lau₂. Jaun₂ ca₂mói₂ ca₂mɨ́g₂ nɨ₁cang₁ 'ɨ́₂ pa₁, ca₂jne₃ 'o₄ tau₂ 'ŋio₅.  
\v 47 Jaun₂ María i₂chan₂ Magdala quian'₅₄ María chog₅₄ José, ca₂të́₂ ne₅₄ ja₁ca₂'on₃ Jesús. 
\c 16  
\s1 Ca₂jen'₅₄ Jesús 
\r (Mateo 28:1-10; Lucas 24:1-12; Juan 20:1-10) 
\p  
\v 1 Le₃ca₂gú'₃ jmɨg₄ jŋió₅, jaun₂ María i₂chan₂ Magdala quian'₅₄ María chog₅₄ Jacobo,\f + \fr 16:1 \ft o₃, Santiago.\f* quian'₅₄ guë́₄ jan₂ i₂chen₂ Salomé, ca₂i₁lia₅ no'₅₄ mɨ₂juɨg₂ a₂jme₁dsɨ₃tsáng₃ nɨ₁ŋɨ₁ 'lag₄ Jesús.  
\v 2 Jaun₂ le₁né₃ guë́₄ jme₁jnia₃ jmɨg₄ le₂'uɨg₅₄ semana, ca₂i₃léin₂ ja₁chi₁'on₅ Jesús, ca₂dsi₃léin₂ con'₂ ma₂'en₅ ca₂la₂ 'iog₂.  
\v 3 Jaun₂ dsia₂₃ jág₁: 
\p ―¿'Ein₂ jme₃'o₅₄ jniog₄ mói₂ cau₅ nɨ₁cang₁ a₂chi₁jnɨ₅ 'o₄ tau₂ 'ŋio₅? 
\p  
\v 4 La₁ jme₁ca₂jág₃ në́₃, jua'₂ ma₂rë₂mu₅, cau₅ bá₄ ma₂chí'₅. Ia₁ a₂jme₁pa₁ lɨn₃ bá₄ nɨ₁cang₁.  
\v 5 Jaun₂ ca₂i₃toin'₅₄ 'ŋió'₃, jaun₂ ca₂jɨ́in₂ jan₂ dsa₂ chi'₂ i₂qui'₂ 'mɨ'₂ chen'₅₄ tiog₂, guá₅ të₂le₃ gu₂ ne₁ ja₁i₃léin₂ jaun₂. Jaun₂ ca₂i₃gó'₃ dsɨ́₅ 'io₅₄ në́₃.  
\v 6 La₁ ca₂juá'₂ dsa₂ 'éi₂: 
\p ―Tsá₃ juɨ₁dsi₂gó'₃ 'au'₂ 'nia'₂. A₂'na'₂ Jesús bá₄ 'nia'₂ i₂niog'₅₄ i₂ca₂jon₃ ca₂tion₃ dsa₂ cróg₄. La₁ ma₂ca₂jein'₅₄ bá₄. Tsá₃ 'éi₂ chan₂ ja₁lá₃. Në₅ jag₄ 'nia'₂ ja₁ca₂quio₅ dsa₂.  
\v 7 Jaun₂ o₂nó'₅ 'nia'₂ o₂chei'₅₄ chi'₂ dsɨ₂guia₃-tɨ́n₂ quiáin₅, Pe₄ në́₃, a₂ma₂'ein₅₄ juɨ₅ ŋó₅ jŋiái₅ lia'₂ con'₂ guë́₄ 'nia'₂ juɨ₅ Galilea. Ja₁jaun₂ o₁jɨin'₄ 'nia'₂ con'₂ lë́₅ jág₁ quió'₅ ma₂ca₂juá'₂. 
\p  
\v 8 Jaun₂ ca₂'uɨin₂ tau₂ 'ŋio₅ i₃lein₃ cuɨng₂₃, dsɨ₂gó'₃ dsɨ́₅ jlein₂₃. Tsá₃ 'ein₂ ca₂tsɨ́'₃ le₂'i₄ juɨ₅, ia₁ a₂gó'₅ bá₄ i₃lein₃. 
\s1 Ca₂jme₃jnia₅ Jesús ne₄ dsa₂ quiáin₅.\f + \fr 16:8 \ft Chog₅₄ si₂ a₂lë́₅ gui'₅₄ guë́₄ tsá₃ le₁ton₅ versículos 9-20.\f* 
\r (Juan 20:11-18) 
\p  
\v 9 Jaun₂ të₂le₃ o₂'iog₂ jmɨg₄ le₂'uɨg₅₄ a₂ca₂rë₃lióg₃ semana a₂ca₂jein'₅₄ jaun₂, ca₂jme₃jniai₂₃ le₂'uɨg₅₄ ne₄ María chan₂ Magdala, i₂ca₂'uɨ́n'₂ Jesús guion₃ je₂na'₅₄ quió'₅ le₂jŋiá₅.  
\v 10 Jaun₂ 'éi₂ në́₃ ca₂i₁chi'₄ dsa₂ i₂jme₁quian'₅₄ Jesús. 'Éi₂ në́₃, tioin'₅₄ 'lia'₂ dsɨ́₅, quɨ'₂-'o₂₃ bá₄.  
\v 11 Jme₁ca₂nág₂ juá'₂ 'io₅₄ a₂ma₂chan₂ táng₃ Jesús, ia₁ ma₂në₂jág₂ 'io₅₄, la₁ tsá₃ 'ein₂ ca₂rë₃'én₂ guë'₂ jág₁ jaun₂. 
\s1 Ca₂jme₃jnia₅ Jesús ne₄ on₃ dsa₂ quiáin₅ 
\r (Lucas 24:13-35) 
\p  
\v 12 Cang₂ jaun₂ táng₃ ca₂jme₃jnia₅ Jesús le₂siá'₂ ne₄ on₃ dsa₂ 'éi₂ quiáin₅, ja₁jme₁i₂nioi₅₄ ja₁nau₂.  
\v 13 Jaun₂ ca₂i₃lein₃ táng₃ ca₂i₁chi'₄ rɨin'₅₄. Ján₃ bá₄ le₂jaun₂ tsá₃ 'ein₂ rɨin'₅₄ ca₂rë₃'én₂ jág₁ a₂dsia₅ 'éi₂. 
\s1 Ca₂chen₃ Jesús chi'₂ dsɨ₂guia₃-tɨ́n₂ i₂lë́₂ guë́₄ 
\r (Mateo 28:16-20; Lucas 24:36-49; Juan 20:19:23) 
\p  
\v 14 Cang₂ guë́₄ jaun₂ ca₂jme₃jnia₅ Jesús jɨn₄ ta₁guia₃-ján₃ con'₂ i₂jme₁tén₄ guë́'₅. Jaun₂ ca₂jí₂ ia₁ 'e₂ lë₃ ŋɨ́₄ lë₃ cang₄ dsi₅₄, tsá₃ 'éin₂ a₂juá'₂ rɨin'₅₄ i₂ma₂ca₂të́₂ ne₄ a₂ma₂ca₂jein'₅₄ táng₃. 
\p  
\v 15 Jaun₂ ca₂juá'₂ ca₂tsɨ́'₃ dsa₂ 'éi₂: 
\p ―O₂nó'₅ 'nia'₂ le₂con₂ mɨ₂güɨ́g₃, o₂'ë́₃ jɨn₄ ca₂le₃jɨ́n₃ dsa₂ jág₁ dse₃.  
\v 16 I₂'én₂, i₂jŋó₂ jmɨg₂ në́₃, lióin₂, tɨ́in'₄ bá₄. I₂tsá₃ 'én₂ në́₃, le₃chain₂ tioin'₅₄ 'éi'₃ a₂dsɨ₃'éin₂.  
\v 17 Jaun₂ léi₄ la₂ jme₃quian'₅₄ dsa₂ 'én₂. Të₂le₃ quian'₅₄ bí₂ 'éi'₃ quió₃ jniá₂, 'uɨ́in'₂ je₂na'₅₄, ton'₂ dsia₃ dsa₂ jág₁ jmei₅ 'mɨ́₂ në́₃.  
\v 18 Në₁jua'₂ 'ein₂ ca₂jŋa'₃ dsɨ₂mɨ'₂, o₃ 'ein₂ ca₂'ɨn'₃ mɨ́₅ 'lɨg'₅₄, la₁ tsá₃ 'e₂ jén'₄. Qui₂quiog₃ gu₂ ne₄ quió'₅ dsa₂ dso'₅₄, jaun₂ 'lión₂ bá₄ dsa₂. 
\s1 Ca₂uɨ́g₂ Jesús guei'₅₄ i₂juɨg₃ 
\r (Lucas 24:50-53; Hechos 1:6-11) 
\p  
\v 19 Jme₁ma₂lë₅ juá₂ Te₁gui'₅₄ Jesús le₂në₅, jaun₂ guë́₄ ca₂roin'₂ ŋái'₃ guei'₅₄ i₂juɨ́g₃, jaun₂ ca₂guá₂ të₂le₃ gu₂ ne₁ quió'₅ Diú₄.  
\v 20 Cang₂ jaun₂, dsa₂ i₂jme₁quiain'₅₄ në́₃, ca₂'uɨin₂ i₁lein₅₄ ca₂le₂con₂ juɨg₂ i₁'ë́₄ jág₁. Jaun₂ 'ŋiog₅ bá₄ Te₁gui'₅₄ Jesús ca₂cuë₃ bí₂, ca₂jmo₃ léi₄ a₂dsón'₂ dsau₅ jág₁ quió'₅, të₂le₃ quian'₅₄ ca₂le₃jë́₃ léi₄ juë'₂ a₂qui₂ca₂jmo₃ dsa₂ quiáin₅. 
\p Co₂në₅.