\id 1PE
\h 1 بُوطْرُوسْ
\toc1 1 بُوطْرُوسْ
\toc2 1 بُوطْرُوسْ
\toc3 1 بُط.
\mt1 1 بُوطْرُوسْ
\c 1
\s1 أَرّحْمثْ ن أَربِّي ذ ثُويُورْثْ نّغْ س ثْقدَّاسْثْ
\m 
\v 1 بُوطْرُوسْ، رَّاسُولْ ن يَاسُوع لْمَاسِيحْ، إِ يِينِّي إِتّْوَافَارْزنْ ذ إِمعْزَابْ، إِنِّي إِتّْوَاژدْجْعنْ ذِي بُونْطُوسْ، ڭَالَاطِييَا، كَابَّاذُوكِييَا، أَسِييَا ذ بِيثِينِييَا، \f ◼ \fr 1:‏1 \ft \bd ’رَّاسُولْ‘\bd* - نِيغْ ’أَمَازَانْ‘.\f*  \x ◘ \xo 1:‏1 \xt يَاع. 1‏:‏1. \x*
\v 2 إِنِّي إِتّْوَافَارْزنْ عْلَاحْسَابْ ثُوسّْنَا إِ إِدْجَانْ غَارْ أَربِّي، بَابَاثْنغْ، قْبڒْ، س ثُوقدّْسِي ن أَرُّوحْ، إِ طَّاعثْ ؤُ إِ ؤُرُوشِّي س إِذَامّنْ ن يَاسُوع لْمَاسِيحْ: أَرْضَا ذ ڒهْنَا أَذْ ذَايْومْ إِمَّارْنِي. \x ◘ \xo 1:‏2 \xt رُوم. 1‏:‏7؛ 1 كُور. 1‏:‏3؛ ڭال. 1‏:‏3؛ أَفا. 1‏:‏2؛ 2 بُط. 1‏:‏2؛ يَاه. 2. \x*
\b
\m 
\v 3 لْبَارَاكَا إِ أَربِّي، بَابَاسْ ن سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ، ونِّي ذ أَنغْ د-يجِّينْ زِي جْذِيذْ س أَرّحْمثْ نّسْ ثَامقّْرَانْثْ س ثْنُوكْرَا ن يَاسُوع لْمَاسِيحْ، مَاحنْذْ \add أَذْ ثِيڒِيمْ\add* ذ أَسِيثمْ إِدَّارنْ، \x ◘ \xo 1:‏3 \xt رُوم. 6‏:‏23؛ 1 كُور. 15‏:‏20؛ 2 كُور. 1‏:‏3؛ أَفا. 1‏:‏3؛ يَاع. 1‏:‏18. \x*
\v 4 مَاحنْذْ \add أَذْ غَارْومْ ثِيڒِي\add* إِشْثْ ن ڒْوَارْثْ وَارْ ثْفنِّي، وَارْ ثتّْوَابقّضْ، وَارْ ثتّسْڒِيوْ، ونِّي إِ ذ أَومْ إِتّْوَاسّْوجْذنْ ذڭْ إِجنْوَانْ، \x ◘ \xo 1:‏4 \xt كُول. 1‏:‏5؛ 2 تِيم. 1‏:‏12. \x*
\v 5 أَمْ ثتّْوَاحْضَامْ كنِّيوْ س جّهْذْ ن أَربِّي ؤُ س لْ-إِيمَانْ إِ ثُوذَارْثْ إِ إِوجْذنْ حِيمَا أَذْ ثتّْوَاسّضْهَارْ ذِي ڒْوقْثْ ثَانڭَّارُوثْ.
\v 6 ذَايسْ إِ غَا ثْفَارْحمْ إِ ڒبْذَا، وَاخَّا ثْحزْنمْ ذِي ڒْوقْثْ-أَ ذْرُوسْ زِي سِّيبّثْ ن عْڒَامْ كُوڒْ إِجَارِّيبنْ إِ خَاومْ د-إِتّكّنْ، \x ◘ \xo 1:‏6 \xt رُوم. 5‏:‏3؛ عبر. 10‏:‏37؛ 1 بُط. 5‏:‏10؛ يَاع. 1‏:‏2. \x*
\v 7 حِيمَا ثَاقدْجبْثْ ن لْ-إِيمَانْ نْومْ، ثنِّي ثِيغْڒَا خْ وُورغْ إِقُّورنْ ونِّي إِتّْوَاسِّيصْفنْ زِي ثْمسِّي، أَذْ ثِيڒِي إِ ؤُسمْغَارْ ذ شَّانْ ذ ؤُعُودْجِي خْ مِينِّي د-غَا إِضْهَارْ يَاسُوع لْمَاسِيحْ، \x ◘ \xo 1:‏7 \xt إِشا. 48‏:‏10؛ 1 كُور. 3‏:‏13؛ يَاع. 1‏:‏3؛ 1 بُط. 4‏:‏12. \x*
\v 8 ونِّي وَارْ ث ثژْرِيمْ، وَاخَّا ثتّخْسمْ ث. س لْ-إِيمَانْ زَّايسْ ثْفَارّْحمْ كنِّيوْ س إِشْثْ ن ڒفْرَاحثْ إِعُودْجنْ وَارْ إِزمَّارْ أَذْ زَّايسْ إِنْطقْ إِڒسْ، \x ◘ \xo 1:‏8 \xt يُوح. 20‏:‏29. \x*
\v 9 مَاغَارْ أَذْ ثطّْفمْ ڒْمُونثْ ن لْ-إِيمَانْ نْومْ، أَقَا-ت ذ ثُوذَارْثْ ن بُوحْبڒْ نْومْ.
\v 10 ثُوذَارْثْ-أَ ثُوغَا أَرزُّونْ خَاسْ إِنَابِييّنْ، إِنِّي ثُوغَا إِتّْنَابّنْ خْ أَرْضَا إِ ذ أَومْ د-إِكَّارنْ، \x ◘ \xo 1:‏10 \xt أَمز. 49‏:‏10؛ دَان. 2‏:‏44؛ Ḥag. 2‏:‏8؛ زَاك. 6‏:‏12. \x*
\v 11 ؤُمِي ثُوغَا أَرزُّونْ مَانْ ڒْوقْثْ \add إِ ذ أَسنْ\add* إِسّْشنْ أَرُّوحْ ن لْمَاسِيحْ إِ ذَايْسنْ إِزدّْغنْ، \add ؤُ مَانْ ڒْوقْثْ إِ خفْ\add* ثُوغَا إِشهّذْ، أَقَا أَذْ د-يَاسْ ؤُودّبْ إِ غَا إِكّنْ خْ لْمَاسِيحْ ؤُڒَا ذ أَعُودْجِي نّسْ أَوَارْنِي مَانْ أَيَا. \x ◘ \xo 1:‏11 \xt إِزهد. 22‏:‏7؛ إِشا. 53‏:‏3؛ دَان. 9‏:‏24. \x*
\v 12 أَقَا إِتّْوَاسَّارْڭبْ أَسنْ، أَقَا مَارَّا مِينْ خفْ ثُوغَا أَرزُّونْ، أَقَا وَارْ ث أَرْزُونْ ذِي ثِيزِي نْسنْ، مَاشَا ثُوغَا تّْنَابّنْ ذِي ثِيزِي نّغْ ؤُ زِي سِّيبّثْ نّغْ خْ ثْمسْڒَايِينْ إِ ذ أَومْ إِتّْوَاسْسَّارْڭْبنْ ڒخُّو زڭْ يِينِّي إِ ذ أَومْ إِبشَّارنْ س ڒخْبَارْ أَصبْحَانْ س أَرُّوحْ إِقدّْسنْ نِّي د-إِتّْوَاسْسّكّنْ زڭْ ؤُجنَّا، \add ثِيمسْڒَايِينْ\add* إِ ذِي تّْمژّْرنْثْ ؤُڒَا ذ لْمَالَاكَاثْ أَذْ ذَايْسنْثْ خْزَارنْثْ. \x ◘ \xo 1:‏12 \xt ڒخ. 2‏:‏4؛ أَفا. 3‏:‏10. \x*
\b
\m 
\v 13 س ؤُينِّي حزْممْ ڒْخَانْسْرَا ن ڒعْقڒْ نْومْ، إِڒِيمْ ثتّْفَاقمْ نِيشَانْ، ؤُشَا سْمُونمْ \add مَارَّا\add* أَسِيثمْ نْومْ ذِي ڒفْرَاحثْ إِ ذ أَومْ غَا يَاوْضنْ خْمِي د غَا إِضْهَارْ سِيذِيثْنغْ يَاسُوع لْمَاسِيحْ. \x ◘ \xo 1:‏13 \xt لك. 12‏:‏35؛ أَفا. 6‏:‏14. \x*
\v 14 إِڒِيمْ أَمْ ثَارْوَا إِتّطَّاعنْ، وَارْ د-ثْذكّْوِيڒمْ ثْشَارّْشمْ ذِي نّشْوَاثْ نْومْ ثِينِّي ثُوغَا ثضْفَارمْ قْبڒْ س نّشْوثْ، ؤُمِي ثُوغَا كنِّيوْ \add عَاذْ\add* ذ إِقُوبَّانِييّنْ.
\v 15 مَاشَا \add ڒخُّو\add* إِڒِيمْ ذ إِمْقدَّاسنْ ذِي مَارَّا مِينْ ثتّڭّمْ، أَمْ مَامّشْ نتَّا ونِّي خَاومْ د-إِڒَاغَانْ، أَقَا-ث ذ أَمْقدَّاسْ، \x ◘ \xo 1:‏15 \xt لك. 1‏:‏75. \x*
\v 16 مِينْزِي ثُورَا:
\b
\m \qt ”إِڒِيمْ ذ إِمْقدَّاسنْ، مِينْزِي ؤُڒَا ذ نشّْ ذ أَمْقدَّاسْ!“\qt* \x ◘ \xo 1:‏16 \xt لَاوِي 11‏:‏44،45؛ 19‏:‏2؛ 20‏:‏7. \x*
\b
\m 
\v 17 ؤُ مَاڒَا ثتّْڒَاغَامْ إِ ثَابَابَاثْ، ونِّي وَارْ إِتّڭّنْ س وُوذْمَاونْ، ذ ونِّي إِحكّْمنْ كُوڒْ إِجّنْ عْلَاحْسَابْ ڒخْذَايمْ نّسْ، خنِّي ؤُيُورمْ س ثِيڭّْوُوذِي ذِي ڒْوقْثْ-أَ ؤُمِي كنِّيوْ عَاذْ ذ إِمعْزَابْ \add ذِي دُّونشْثْ-أَ\add*. \x ◘ \xo 1:‏17 \xt أَعَوذ. 10‏:‏17؛ 2 إِم. 19‏:‏7؛ أَيُوبْ 34‏:‏19؛ ڒخ. 10‏:‏34؛ رُوم. 2‏:‏11؛ ڭال. 2‏:‏6؛ أَفا. 6‏:‏9؛ كُول. 3‏:‏25. \x*
\v 18 مَاغَارْ ثسّْنمْ بلِّي كنِّيوْ وَارْ ثتّْوَافْذِيمْ س نُّوقَارْثْ ذ وُورغْ إِفنَّانْ زِي ڒخْذَايمْ نْومْ إِبضْڒنْ ثِينِّي ثطّْفمْ كنِّيوْ زِي ڒجْذُوذْ نْومْ، \x ◘ \xo 1:‏18 \xt 1 كُور. 6‏:‏20؛ 7‏:‏23. \x*
\v 19 مَاشَا س إِذَامّنْ إِغْڒَانْ ن إِزْمَارْ وَارْ ذَايسْ بُو ڒْعِيبْ، وَارْ إِبقّْضنْ، أَقَا-ث ذ لْمَاسِيحْ. \x ◘ \xo 1:‏19 \xt ڒخ. 20‏:‏28؛ عبر. 9‏:‏12؛ أَسَا. 1‏:‏5. \x*
\v 20 نتَّا ثُوغَا إِتّْوَافَارْزْ إِ مَانْ أَيَا قْبڒْ مَا أَذْ إِتّْوَاڭّْ ذْسَاسْ ن دُّونشْثْ، ؤُشَا إِتّْوَاسّضْهَارْ أَومْ-د ڒخُّو ذِي زّْمَانَاثْ إِنڭُّورَا ن ڒْوقْثْ ذِي طّْوعْ نْومْ، \x ◘ \xo 1:‏20 \xt رُوم. 16‏:‏25؛ أَفا. 1‏:‏9؛ 3‏:‏9؛ كُول. 1‏:‏26؛ 2 تِيم. 1‏:‏9؛ ثِيث. 1‏:‏2. \x*
\v 21 \add إِ كنِّيوْ\add* إِنِّي زَّايسْ إِتَّامْننْ ذِي أَربِّي، ونِّي ث-إِ-د-إِسّْنكَّارنْ زِي ثَادَّارْثْ ن إِمتِّيننْ ؤُشَا إِوْشَا أَسْ أَعُودْجِي، حِيمَا لْ-إِيمَانْ ذ ؤُسِيثمْ نْومْ أَذْ إِڒِينْ خْ أَربِّي. \x ◘ \xo 1:‏21 \xt ڒخ. 2‏:‏33؛ فِيل. 2‏:‏9. \x*
\v 22 \add ذ مَانْ أَيَا\add* حِيمَا أَذْ تّْوَاقدّْسنْ ڒعْمُورْ نْومْ س طَّاعثْ إِ ثِيذتّْ، أَذْ تّْوَاعمَّارنْ س ثَايْرِي بْڒَا ڒْفَارْزْ ن بْنَاذمْ، \add ؤُشَا\add* أَذْ ثخْسمْ أَيَاوْيَا س وُوڒْ إِزْذِيڭْ إِكْمڒْ، \x ◘ \xo 1:‏22 \xt رُوم. 12‏:‏10؛ أَفا. 4‏:‏3؛ عبر. 13‏:‏1؛ 1 بُط. 2‏:‏17. \x*
\v 23 أَمْ إِوْذَانْ إِ د-إِتّْوَاخڒْقنْ ذ جْذِيذْ، وَارْ إِدْجِي زِي زَّارِيعثْ إِفنَّانْ، مَاشَا زِي ثنِّي وَارْ إِفنِّينْ، أَقَا زڭْ وَاوَاڒْ إِدَّارنْ ن أَربِّي إِ إِتّْذُومَانْ إِ ڒبْذَا. \x ◘ \xo 1:‏23 \xt يَاع. 1‏:‏18؛ 1 يُوح. 3‏:‏9. \x*
\b
\m 
\v 24 \qt ”مِينْزِي مَارَّا دَّاثْ أَمْ أَرْبِيعْ\qt*
\m \qt ؤُشَا مَارَّا أَژْرِي نّسْ\qt*
\m \qt أَمْ ثَاوَارْذشْثْ ذڭْ ييَّارْ س أَرْبِيعْ،\qt*
\m \qt أَرْبِيعْ أَذْ إِسْڒَاوْ، ثَاوَارْذشْثْ أَذْ ثوْضَا،\qt* \x ◘ \xo 1:‏24 \xt إِشا. 40‏:‏6‏-‏8؛ 1 كُور. 7‏:‏31؛ يَاع. 1‏:‏10؛ 4‏:‏14؛ 1 يُوح. 2‏:‏17. \x*
\m 
\v 25 \qt مَاشَا أَوَاڒْ ن أَربِّي نّغْ\qt*
\m \qt إِتّْغِيمَا إِ ڒبْذَا قَاعْ.“\qt*
\b
\m أَوَاڒْ-أَ نتَّا ذ ڒخْبَارْ أَصبْحَانْ ونِّي ذ أَومْ د-إِتّْوَابَارّْحنْ.
\b
\b
\c 2
\s1 إِژْرَا إِدَّارنْ
\m 
\v 1 س ؤُينِّي بعّْذمْ خْ مَارَّا مِينْ إِدْجَانْ ذ أَعفَّانْ، خْ عْڒَامْ كُوڒْ ثَاحْرَايْمشْثْ ذ نِّيفَاقْ ذ ڒحْسذْ ؤُ خْ ؤُشقّفْ. \x ◘ \xo 2:‏1 \xt مت. 18‏:‏3؛ رُوم. 6‏:‏4؛ 1 كُور. 14‏:‏20؛ أَفا. 4‏:‏23؛ كُول. 3‏:‏8؛ عبر. 12‏:‏1. \x*
\v 2 إِڒِيمْ أَمْ إِسيْمَانْ \add إِتّطّْضنْ\add*، وحّْشمْ أَوَاڒْ أَمْ ؤُغِي إِزْذِيڭنْ ذ أَرُّوحَانِي، حِيمَا أَذْ زَّايسْ ثڭْمَامْ إِ ثُوذَارْثْ،
\v 3 مَاڒَا أَقَا كنِّيوْ ثقَّاسمْ ؤُ ثتّْوَاڒَامْ أَقَا سِيذِي إِصْبحْ. \x ◘ \xo 2:‏3 \xt إِزهد. 34‏:‏9. \x*
\v 4 نتَّا ذ ونِّي غَارْ د-ثتَّاكّْوَاضمْ، أَژْرُو إِدَّارنْ، ونِّي مّنْضَارنْ إِوْذَانْ، \add مَاشَا\add* غَارْ أَربِّي أَقَا-ث إِتّْوَافَارْزْ إِغْڒَا. \x ◘ \xo 2:‏4 \xt أَفا. 2‏:‏20. \x*
\v 5 أَمُّو كنِّيوْ عَاوذْ، أَمْ يِيژْرَا إِدَّارنْ، جّمْ أَذْ \add زَّايْومْ\add* ثتّْوَابْنَانْثْ ثِيزَاوِييِّينْ ن أَرُّوحْ، أَذْ ثِيڒِيمْ ذ إِكهَّاننْ إِقدّْسنْ، حِيمَا أَذْ ثوْشمْ ثِيغَارْصِينْ ن أَرُّوحْ إِ أَرْضَا ن أَربِّي س يَاسُوع لْمَاسِيحْ. \x ◘ \xo 2:‏5 \xt رُوم. 12‏:‏1؛ عبر. 3‏:‏6؛ 12‏:‏28؛ أَسَا. 1‏:‏6؛ 5‏:‏10. \x*
\v 6 س ؤُينِّي إِتّْوَانَّا ذِي ثِيرَا \add إِقدّْسنْ\add*:
\b
\m \qt ”أَقَا ذَا، أَذْ سَّارْسغْ ذِي صِيهْيُونْ\qt*
\m \qt إِجّْ ن وژْرُو إِغْڒَا أَمْ ؤُزدْجِيفْ ن ثغْمَارْثْ،\qt*
\m \qt ؤُشَا ونِّي إِ زَّايسْ غَا يَامْننْ،\qt*
\m \qt وَارْ ذَايسْ إِتِّيذفْ ؤُسضْحِيعمَّارْصْ.“\qt* \x ◘ \xo 2:‏6 \xt إِشا. 28‏:‏16. \x*
\b
\m 
\v 7 إِ كنِّيوْ، إِنِّي إِتَّامْننْ، أَقَا ثمّوْشْ شّنْعثْ-أَ، مَاشَا إِ يِينِّي وَارْ يُومِيننْ، أَقَا-ت ذ ثَاصْضَارْثْ ن ؤُنقْرَاضْ ذ أَژْرُو ن ؤُنذْرفْ. \x ◘ \xo 2:‏7 \xt إِزهد. 118‏:‏22؛ إِشا. 8‏:‏14؛ مت. 21‏:‏42؛ ڒخ. 4‏:‏11؛ رُوم. 9‏:‏33. \x*
\v 8 ؤُشَا نِيثْنِي تّْنقْرَاضنْ ذَايسْ، مِينْزِي وَارْ تِّيمْننْ ذڭْ وَاوَاڒْ، أَمْ مَامّشْ ذ أَسنْ يُورَا. \x ◘ \xo 2:‏8 \xt إِشا. 8‏:‏14. \x*
\m 
\v 9 مَاشَا كنِّيوْ ثدْجَامْ ذ إِجّْ ن جِّيڒْ إِتّْوَافَارْزنْ، ثتّْسخَّارمْ أَمْ إِكهَّاننْ إِ ثْڭلْذِيثْ، كنِّيوْ ذ إِجّْ نْ ڒْڭنْسْ إِقدّْسنْ، إِجّْ ن ؤُمُونِي إِتّْوَافْذِينْ، مَاحنْذْ أَذْ ثْبَارّْحمْ أَسمْغَارْ ن ونِّي ذ أَنغْ د-إِڒَاغَانْ زِي ثَادْجسْثْ غَارْ ؤُفيّضْ ن ثْفَاوْثْ نّسْ. \x ◘ \xo 2:‏9 \xt ؤُف. 19‏:‏5؛ أَعَوذ. 7‏:‏6؛ 14‏:‏2؛ 26‏:‏18؛ أَفا. 1‏:‏14؛ أَسَا. 1‏:‏6؛ 5‏:‏10. \x*
\v 10 كنِّيوْ وَارْ ثتّْوِيحْسِيبمْ أَمْ ڒْڭنْسْ، مَاشَا ڒخُّو أَقَا كنِّيوْ ذ ڒْڭنْسْ ن أَربِّي. عَاوذْ ثُوغَا أَرّحْمثْ وَارْ كنِّيوْ ثْڒحّفْ، مَاشَا ڒخُّو ثتّْوَافَارّغْ-د خَاومْ أَرّحْمثْ نّسْ. \x ◘ \xo 2:‏10 \xt حُوش. 2‏:‏1؛ 2‏:‏25؛ رُوم. 9‏:‏26. \x*
\m 
\v 11 \add أَ\add* إِمْعِيزّنْ إِنُو، أَقَا كنِّيوْ ذ إِبَارَّانِييّنْ ذ إِمعْزَابْ، خْ ؤُينِّي زِييَّارغْ خَاومْ، وَارْ ضفَّارمْ شَا نّشْوَاثْ ن أَرِّيمثْ نِّي إِتّْمنْغَانْ أَكْ-ذ ڒعْمَارْ \add نْومْ\add*. \x ◘ \xo 2:‏11 \xt رُوم. 13‏:‏14؛ ڭال. 5‏:‏16. \x*
\v 12 ؤُيُورمْ نِيشَانْ زَّاثْ إِ مَارَّا ثَارْوَا ن بْنَاذمْ إِنِّي خَاومْ إِتّْعَاوَاذنْ ڒخْبُورَاثْ ثِيعفَّانِينْ، أَڒَامِي غَا ژَترنْ ڒخْذَايمْ نْومْ ثِيصبْحَانِينْ، أَذْ سّمْغَارنْ ذِي أَربِّي ذڭْ وَاسّْ ن ؤُقدْجبْ. \x ◘ \xo 2:‏12 \xt مت. 5‏:‏16؛ لك. 1‏:‏68؛ 19‏:‏44؛ رُوم. 12‏:‏17؛ 2 كُور. 8‏:‏21؛ فِيل. 2‏:‏15؛ ثِيث. 2‏:‏8؛ 1 بُط. 3‏:‏16. \x*
\b
\m 
\v 13 طَّاعمْ إِ مَارَّا بْنَاذمْ ذِي طّْوعْ ن أَربِّي: إِ إِجدْجِيذنْ زِي سِّيبّثْ ن صُّولْطَا إِ غَارْسنْ ثدْجَا، \x ◘ \xo 2:‏13 \xt رُوم. 13‏:‏1؛ ثِيث. 3‏:‏1. \x*
\v 14 ؤُ إِ ڒْقُوضَاثْ، مِينْزِي نِيثْنِي تّْوَاسّكّنْ زَّايسْ، حِيمَا أَذْ عَاقْبنْ إِعفَّاننْ، ؤُ حِيمَا أَذْ سّمْغَارنْ إِنِّي إِتّڭّنْ ثَاصبْحَانْثْ.
\v 15 مِينْزِي مَانْ أَيَا إِتّخْسْ إِ-ث أَربِّي، حِيمَا، خْمِي غَا ثڭّمْ مِينْ إِصبْحنْ، أَذْ ثسّغْذمْ أَقمُّومْ ن إِوْذَانْ إِفْغَاڒْ إِ وَارْ إِسِّيننْ أَربِّي، \x ◘ \xo 2:‏15 \xt ثِيث. 2‏:‏8. \x*
\v 16 أَمْ ثَارْوَا ن بْنَاذمْ نِّي إِدَّارنْ \add نِيشَانْ\add* ذِي ثِيڒلِّي، وَارْ إِدْجِي أَمْ يِينِّي إِڭِّينْ ثِيڒلِّي نْسنْ أَمْ يِيجّْ ن ؤُڒحَّافْ خْ ثُوعفّْنَا نْسنْ، مَاشَا أَمْ إِمْسخَّارنْ ن أَربِّي. \x ◘ \xo 2:‏16 \xt يُوح. 8‏:‏32؛ رُوم. 6‏:‏18؛ ڭال. 5‏:‏1. \x*
\v 17 وقَّارمْ مَارَّا إِوْذَانْ، سْعِيزّمْ ثَاوْمَاثْ، ڭّْوذمْ أَربِّي، شنّْعمْ إِجدْجِيذنْ. \x ◘ \xo 2:‏17 \xt مت. 22‏:‏21؛ رُوم. 12‏:‏10؛ أَفا. 4‏:‏3؛ عبر. 13‏:‏1؛ 1 بُط. 1‏:‏22؛ 5‏:‏5. \x*
\m 
\v 18 جّمْ إِنِّي ذ إِمْسخَّارنْ جَارْ أَومْ أَذْ طَّاعنْ إِ أَيْثْبَابْ نْسنْ س ثِيڭّْوُوذِي، وَارْ إِدْجِي إِ يِينِّي إِصبْحنْ إِضَارْفنْ \add وَاهَا\add*، مَاشَا عَاوذْ إِ يِينِّي إِقسْحنْ ذ يوْعَارنْ. \x ◘ \xo 2:‏18 \xt أَفا. 6‏:‏5؛ كُول. 3‏:‏22؛ 1 تِيم. 6‏:‏1؛ ثِيث. 2‏:‏9. \x*
\v 19 مِينْزِي \add إِمْسخَّارنْ أَمْ\add* إِنَا أَذْ د-أَسنْ إِ أَربِّي غَارْ ڒْخَاضَارْ نّسْ، مِينْزِي نِيثْنِي كْسِينْ ثَامَارَا نِّي وَارْ ت إِسْذِيهِيدْجنْ، ذِي طّْوعْ ن ثْنفْسشْثْ ثشْنَا. \x ◘ \xo 2:‏19 \xt مت. 5‏:‏10. \x*
\v 20 مَانْ شَّانْ إِ ذِينْ إِ يِينِّي إِكْسِينْ ثَامَارَا زِي سِّيبّثْ ن إِعذِّيينْ نْسنْ؟ مَاشَا مَاڒَا كنِّيوْ ثڭِّيمْ ثْشُونِي، \add أَمْ\add* ذَايْومْ تّڭّنْ ثُوعفّْنَا، أَقَا مَانْ أَيَا إِسّمْغَارْ شَّانْ نْومْ غَارْ أَربِّي. \x ◘ \xo 2:‏20 \xt 1 بُط. 3‏:‏14؛ 4‏:‏14. \x*
\v 21 مِينْزِي كنِّيوْ ثتّْوَاڒَاغَامْ-د إِ مَانْ أَيَا ؤُمِي إِمُّوثْ لْمَاسِيحْ ذِي طّْوعْ نّغْ ؤُشَا إِجَّا أَنغْ-د لْمِيثَالْ-أَ، حِيمَا أَذْ نُويُورْ ذِي جُّورّثْ ن إِضَارنْ نّسْ: \x ◘ \xo 2:‏21 \xt يُوح. 13‏:‏15؛ فِيل. 2‏:‏5؛ 1 يُوح. 2‏:‏6. \x*
\v 22 نتَّا وَارْ إِڭِّي شَا دّْنُوبْ ؤُ وَارْ إِتّْوِيفْ ذڭْ ؤُقمُّومْ نّسْ شَا ن ڒْغشّْ، \x ◘ \xo 2:‏22 \xt إِشا. 53‏:‏9؛ 2 كُور. 5‏:‏21؛ 1 يُوح. 3‏:‏5. \x*
\v 23 ونِّي، مَاڒَا زَاوَارنْ ث، وَارْ د-إِتَّارِّي أَوَاڒْ، ؤُ مَاڒَا إِودّبْ، وَارْ د-إِتَّارِّي شَا دّنْفْ، مَاشَا إِتَّارَّا دّعْوثْ نّسْ غَارْ ڒْقَاضِي ن ثْسڭْذَا، \x ◘ \xo 2:‏23 \xt مت. 27‏:‏39؛ يُوح. 8‏:‏48،49. \x*
\v 24 ونِّي إِكْسِينْ دّْنُوبْ نّغْ س يِيخفْ نّسْ ؤُشَا إِسّْڭعّذْ إِ-ثنْ ذِي أَرِّيمثْ نّسْ خْ صَّالِيبْ. مَاغَارْ مَاڒَا نمُّوثْ إِ دّْنُوبْ، أَذْ ندَّارْ ذِي ثْسڭْذَا نّسْ، مِينْزِي كنِّيوْ أَقَا ثتّْوَاسّْڭنْفَامْ س إِيزِّيمنْ نّسْ. \x ◘ \xo 2:‏24 \xt إِشا. 53‏:‏4؛ مت. 8‏:‏17؛ رُوم. 6‏:‏11. \x*
\v 25 مِينْزِي كنِّيوْ ثُوغَا ثْودَّارمْ أَمْ يِيحُوڒِييّنْ، ڒخُّو مَاشَا ثْذوْڒمْ-د غَارْ ؤُمكْسَاوْ ذ ؤُمحْضَايْ ن ڒعْمُورْ نْومْ. \x ◘ \xo 2:‏25 \xt إِشا. 53‏:‏6؛ حِز. 34‏:‏6؛ لك. 15‏:‏4. \x*
\b
\b
\c 3
\s1 ثَاسْغُونْثْ جَارْ ورْيَازْ ذ ثمْغَارْثْ ذِي ڒمْڒَاشْ
\m 
\v 1 أَمُّو عَاوذْ كنِّينْثْ، \bd \bdit أَ\bdit* ثِيمْغَارِينْ\bd*، مَارْسنْثْ إِخفْ نْكنْثْ إِ يرْيَازنْ نْكنْثْ نِّي وَارْ إِطِّيعنْ إِ وَاوَاڒْ، حِيمَا أَذْ ثنْ ثَاربْحنْثْ بْڒَا أَرْبَارْ س ثِيشْڒِي نْكنْثْ إِشْنَانْ، \x ◘ \xo 3:‏1 \xt أَمز. 3‏:‏16؛ 1 كُور. 14‏:‏34؛ أَفا. 5‏:‏22؛ كُول. 3‏:‏18؛ ثِيث. 2‏:‏5. \x*
\v 2 خْ مِينِّي إِ غَا ژَترنْ مَامّشْ ثتّڭُّورنْثْ س ثِيڭّْوُوذِي ذ ڒهْيَا.
\v 3 وَارْ تّْزهّْجنْثْ س مِينْ إِتّْبَاننْ غَارْ بَارَّا: أَمُوذِي ن ؤُشُووَّافْ، ثِيمڭَّا ن وُورغْ نِيغْ ثْيَارْضِي ن وَارُّوضْ إِصبْحنْ، \x ◘ \xo 3:‏3 \xt 1 تِيم. 2‏:‏9؛ ثِيث. 2‏:‏3. \x*
\v 4 مَاشَا زهّْجنْثْ س بْنَاذمْ إِنُّوفَارنْ ذڭْ وُوڒْ، س أَرُّوحْ ن ثمْهِينْثْ إِ وَارْ إِتّْوَاغشّنْ، أَقَا-ث ذ إِجّْ ن ؤُزهّجْ إِصبْحنْ زَّاثْ إِ أَربِّي.
\v 5 أَقَا أَمُّو ثُوغَا زهّْجنْثْ زِيشْ ثمْغَارِينْ ثِيمْقدَّاسِينْ، إِنِّي ثُوغَا إِسِّيثِيمنْ خْ أَربِّي، ڒعْمُورْ نْسنْثْ، ؤُشَا ثُوغَا طَّاعنْثْ إِ يرْيَازنْ نْسنْثْ.
\v 6 أَمُّو ثُوغَا سَارَا ثمَّارْسْ إِخفْ نّسْ إِ إِبْرَاهِيمْ، ثْڒَاغَا أَسْ: ”سِيذِي!“، ؤُشَا كنِّينْثْ ثْذوْڒنْثْ ذ يسِّيسْ أَمْ ثتّڭّنْثْ مِينْ إِصبْحنْ، مَاڒَا وَارْ ثتّڭّْوذنْثْ. \x ◘ \xo 3:‏6 \xt أَمز. 18‏:‏12. \x*
\m 
\v 7 كنِّيوْ، \bd \bdit أَ\bdit* إِرْيَازنْ\bd*، زذْغمْ أَكْ-ذ ثمْغَارِينْ نْومْ س ڒعْقڒْ ؤُ وقَّارمْ ثنْثْ أَمْ إِغَارَّافنْ يَارخْفنْ، حِيمَا وَارْ ثتّْوَامنْعنْثْ شَا ثْژَادْجِيثِينْ نْومْ، مِينْزِي نِيثنْثِي أَذْ وَارْثنْثْ ثِيموْشَا ن ثُوذَارْثْ إِتّْذُومَانْ أَكِيذْومْ. \x ◘ \xo 3:‏7 \xt أَفا. 5‏:‏25‏-‏33؛ كُول. 3‏:‏19. \x*
\b
\s1 أَودّبْ ذڭْ إِصُورَافْ ن لْمَاسِيحْ
\m 
\v 8 غَارْ ؤُنڭَّارْ، مُونمْ مَارَّا غَارْ أَرَّايْ ذ إِجّنْ، ودّْبمْ أَكْ-ذ يِينِّي إِودّْبنْ، خْسمْ إِجّنْ ونّغْنِي س ثَايْرِي، أَرحْممْ، إِڒِيمْ ثْضَارْفمْ. \x ◘ \xo 3:‏8 \xt رُوم. 12‏:‏16؛ 15‏:‏5؛ 1 كُور. 1‏:‏10؛ فِيل. 2‏:‏2؛ 3‏:‏16. \x*
\v 9 وَارْ د-تَّارِّيمْ خْ ڒْغَارْ س ڒْغَارْ، نِيغْ ثِيكّْوُورَا س ثِيكّْوُورَا، مَاشَا س ڒْعكْسْ بَارْكمْ، مِينْزِي كنِّيوْ أَقَا ثتّْوَاڒَاغَامْ-د حِيمَا أَذْ ثْوَارْثمْ لْبَارَاكَا. \x ◘ \xo 3:‏9 \xt لَاوِي 19‏:‏18؛ أَوڒن. 20‏:‏22؛ 24‏:‏29؛ مت. 5‏:‏39؛ 25‏:‏34؛ رُوم. 12‏:‏17؛ 1 كُور. 6‏:‏7؛ 1 تس. 5‏:‏15؛ 1 تِيم. 4‏:‏8. \x*
\v 10 س ؤُيَا، أجّْ ونِّي إِخْسنْ ثُوذَارْثْ ذ وُوسَّانْ إِشْنَانْ، أَذْ إِحْضَا إِڒسْ نّسْ زِي مِينْ وَارْ إِحْڒِينْ ؤُڒَا ذ إِينْشِيشنْ نّسْ زڭْ وَاوَاڒْ إِشمّْثنْ. \x ◘ \xo 3:‏10 \xt إِزهد. 34‏:‏13‏-‏15؛ يَاع. 1‏:‏26. \x*
\v 11 أجّْ إِ-ث أَذْ إِڭّْوجْ خْ مِينْ إِدْجَانْ ذ أَعفَّانْ، أَذْ إِڭّْ مِينْ إِصبْحنْ، أَذْ يَارْزُو خْ ڒهْنَا ؤُشَا أَذْ ث إِضْفَارْ س شْضَارثْ. \x ◘ \xo 3:‏11 \xt إِزهد. 37‏:‏27؛ إِشا. 1‏:‏16؛ 3 يُوح. 11. \x*
\m 
\v 12 مِينْزِي ثِيطَّاوِينْ ن سِيذِي خْ إِمْسڭَّاذنْ، ؤُ إِمزُّوغنْ نّسْ أَقَا أَثنْ مَاحنْذْ أَذْ \add أَسنْ\add* سْڒنْ، \add مَاشَا\add* ؤُذمْ ن سِيذِي أَقَا-ث ضِيدّْ إِ ؤُمْعفَّانْ. \x ◘ \xo 3:‏12 \xt إِزهد. 34‏:‏13‏-‏17. \x*
\m 
\v 13 وِي إِزمَّارنْ أَذْ ذَايْومْ إِڭّْ ڒْغَارْ، مَاڒَا كنِّيوْ ثضْفَارمْ مِينْ إِصبْحنْ؟
\v 14 \add مَاڒَا\add* ثْودّْبمْ ذِي طّْوعْ ن ثْسڭْذَا، أَقَا سّعْذْ نْومْ. وَارْ تّڭّْوذمْ زڭْ يِينِّي كنِّيوْ إِسِّيڭّْوذنْ، وَارْ تّْنخْڒِيعمْ شَا، \x ◘ \xo 3:‏14 \xt إِشا. 8‏:‏12‏-‏13؛ إِرْم. 1‏:‏8؛ مت. 5‏:‏10؛ 1 بُط. 2‏:‏20؛ 4‏:‏14. \x*
\v 15 مَاشَا قدّْسمْ سِيذِي، لْمَاسِيحْ، ذڭْ وُوڒَاونْ نْومْ، ؤُ إِڒِيمْ ڒبْذَا ثْوجْذمْ مَاحنْذْ أَذْ ثَارّمْ س ثمْهِينْثْ ذ ؤُوقَّارْ خْ يِينِّي كنِّيوْ إِ غَا إِسّقْسَانْ خْ ؤُسِيثمْ ن لْ-إِيمَانْ نْومْ، \x ◘ \xo 3:‏15 \xt أَيُوبْ 1‏:‏21؛ إِزهد. 119‏:‏46؛ ڒخ. 4‏:‏8. \x*
\v 16 زِي ثْنفْسشْثْ إِشْنَانْ، حِيمَا إِنِّي خَاومْ إِعَاوْذنْ أَخْمِي خْ إِوْذَانْ إِعفَّاننْ، أَذْ سضْحَانْ ؤُمِي تّْشقَّافنْ ذِي ثشْرِي ن ثُوذَارْثْ نْومْ إِشْنَانْ ذِي لْمَاسِيحْ. \x ◘ \xo 3:‏16 \xt ثِيث. 2‏:‏8؛ 1 بُط. 2‏:‏12، 15. \x*
\v 17 أَقَا إِنفّعْ أَذْ ثْودّْبمْ، مَاڒَا إِخْسْ أَربِّي، أَمْ ثتّڭّمْ مِينْ إِصبْحنْ، مَاشَا وَارْ إِدْجِي مَاڒَا كنِّيوْ ثتّڭّمْ مِينْ إِدْجَانْ ذ أَعفَّانْ.
\m 
\v 18 مِينْزِي ؤُڒَا ذ لْمَاسِيحْ ثُوغَا إِمُّوثْ إِشْثْ ن ثْوَاڒَا إِ دّْنُوبْ، أَقَا أَمْسڭَّاذْ ذِي طّْوعْ ن إِمذْنَابْ، حِيمَا أَذْ كنِّيوْ إِسِّيوضْ غَارْ أَربِّي، \add نتَّا\add* ذ ونِّي إِمُّوثنْ ذِي أَرِّيمثْ، مَاشَا أَقَا إِدَّارْ ذِي أَرُّوحْ، \x ◘ \xo 3:‏18 \xt رُوم. 5‏:‏6؛ عبر. 9‏:‏15، 28. \x*
\v 19 \add ذ ونِّي\add* إِبَارّْحنْ إِ ڒعْمُورْ نِّي إِتّْوَاطّْفنْ ذِي ڒَاخَارْثْ، \x ◘ \xo 3:‏19 \xt 1 بُط. 4‏:‏6. \x*
\v 20 إِنِّي ثُوغَا وَارْ إِتّْوَاسّْقنْعنْ ذڭْ وُوسَّانْ ن نُوحْ، ؤُمِي ثُومُورْ تَّاسِيعْ ن ڒْخَاضَارْ ن أَربِّي، أَقَا أَذْ ذِينْ يِيڒِي ؤُغَارَّابُو أَمْ ثُوغَا إِتّْرَاجَا نتَّا أَذْ ثُوبنْ نِيثْنِي. ؤُذْفنْ \add غَارْ ؤُغَارَّابُو\add* مْغِيرْ ثْمنْيَا ن ڒعْمُورْ نِّي إِتّْوَاحْضَانْ دَّارنْ ذڭْ وَامَانْ. \x ◘ \xo 3:‏20 \xt أَمز. 6‏:‏3، 14؛ 8‏:‏18؛ مت. 24‏:‏37؛ لك. 17‏:‏26؛ رُوم. 2‏:‏4؛ 2 بُط. 2‏:‏5. \x*
\m 
\v 21 عْلَاحْسَابْ أَمذْيَا نِّي، أَقَا ؤُڒَا ذ كنِّيوْ ثتّْوَاسّْنجْممْ س ؤُسغْضصْ - ونِّي وَارْ إِدْجِينْ أَسِيرْذْ ن ڒخْمجْ ن أَرِّيمثْ، مَاشَا \add أَذْ يِيڒِي\add* مَاڒَا ثْشهّْذمْ خْ أَربِّي س ثْنفْسشْثْ إِشْنَانْ - ؤُ س ثْنُوكْرَا ن يَاسُوع لْمَاسِيحْ، \x ◘ \xo 3:‏21 \xt أَفا. 5‏:‏26؛ رُوم. 10‏:‏9، 10.\x*
\v 22 ونِّي إِتّْوَاسُّوعْڒَانْ غَارْ ؤُجنَّا، إِقِّيمْ غَارْ ؤُفُوسِي ن أَربِّي، أَمْ ذ أَسْ تّْوَامَّارْسنْثْ لْمَالَاكَاثْ ذ صُّولَاطَاثْ ذ جّهْذْ سَاذُو نتَّا. \x ◘ \xo 3:‏22 \xt أَفا. 1‏:‏20. \x*
\b
\b
\c 4
\m 
\v 1 ڒَامِي خَاومْ إِكْسِي لْمَاسِيحْ أَرْمحْ ذِي دَّاثْ، إِتّْخصَّا كنِّيوْ عَاوذْ أَذْ ثطّْفمْ ذڭْ ؤُخَارَّاصْ-أَ: أَقَا ونِّي إِمُّوثنْ ذِي أَرِّيمثْ، وَانِيثَا أَقَا إِسّْبدّْ دّنْبْ. \x ◘ \xo 4:‏1 \xt رُوم. 6‏:‏7؛ عبر. 12‏:‏1. \x*
\v 2 س ؤُينِّي وَانِيثَا وَارْ إِدَّارْ \add عَاذْ\add* عْلَاحْصَابْ نّشْوَاثْ ن بْنَاذمْ أَمْ ث إِڭَّا قْبڒْ ذِي أَرِّيمثْ، مَاشَا عْلَاحْسَابْ مِينْ إِخْسْ أَربِّي. \x ◘ \xo 4:‏2 \xt رُوم. 14‏:‏7؛ 2 كُور. 5‏:‏15؛ ڭال. 2‏:‏20؛ أَفا. 4‏:‏24؛ 1 تس. 5‏:‏10؛ عبر. 9‏:‏14. \x*
\v 3 مِينْزِي أَقَا إِشْفَا أَومْ ڒْوقْثْ ڒَامِي ثُوغَا كنِّيوْ ثْعبّْذمْ إِ مِينْ خْسنْ لْكُوفَّارْ، ؤُمِي كنِّيوْ ثُوغَا ثڭُّورمْ ذڭْ ؤُفُوشّحْ، سّكْرَانْ، ڒفْسَاذْ ذ فِيشْثَاثْ ن ؤُغلِّي ؤُ ذِي ڒْخذْمثْ \add ن سْوَادَّايْ سْوَادَّايْ\add* ن شّْوَاطنْ. \x ◘ \xo 4:‏3 \xt أَفا. 4‏:‏17. \x*
\v 4 ؤُ خْزَارْ، ڒخُّو تّْبهْثنْ نِيثْنِي ؤُمِي وَارْ ثتِّيزّْڒمْ \add عَاذْ\add* أَكِيذْسنْ ذڭْ وزْقَاقْ ن ڒقْجَاحثْ ذ إِجّنْ، ؤُشَا نِيثْنِي تّْشقَّافنْ ذَايْومْ.
\v 5 \add مَاشَا\add* نِيثْنِي أَذْ أَرّنْ ڒحْسَابْ إِ أَربِّي، ونِّي إِ غَا إِحكْمنْ خْ يِينِّي إِدَّارنْ ؤُ خْ يِينِّي إِمُّوثنْ.
\v 6 س ؤُينِّي إِتّْوَابَارّحْ عَاوذْ س ڒخْبَارْ أَصبْحَانْ إِ إِمتِّيننْ، حِيمَا نِيثْنِي أَذْ تّْوَاحَاسْبنْ أَمْ ثَارْوَا ن بْنَاذمْ زِي جِّيهثْ ن دَّاثْ، مَاشَا أَذْ دَّارنْ ذِي أَربِّي س أَرُّوحْ. \x ◘ \xo 4:‏6 \xt يُوح. 5‏:‏25؛ 1 بُط. 3‏:‏19. \x*
\v 7 أَنڭَّارْ ن مَارَّا أَقَا يُوذسْ-د. س ؤُينِّي إِڒِيمْ س ڒعْقڒْ، ركّْزمْ إِخفْ نْومْ خْمِي ثژَّادْجَامْ. \x ◘ \xo 4:‏7 \xt لك. 21‏:‏34؛ 1 يُوح. 2‏:‏18. \x*
\v 8 سنّجْ إِ مَارَّا، خْسمْ أَيَاوْيَا بْڒَا قطُّو، مِينْزِي ثَايْرِي ثسّْذُورُّويْ خْ ؤُبَارُّو ن دّْنُوبْ. \x ◘ \xo 4:‏8 \xt أَوڒن. 10‏:‏12. \x*
\v 9 أَرحّْبمْ إِ إِبَارَّانِييّنْ بْڒَا ڒعْكَاسثْ. \x ◘ \xo 4:‏9 \xt رُوم. 12‏:‏13؛ فِيل. 2‏:‏14؛ عبر. 13‏:‏2. \x*
\v 10 أجّْ كُوڒْ إِجّنْ أَذْ إِسخَّارْ إِنِّي ذ أَسْ يُوذْسنْ عْلَاحْسَابْ مِينْ ذ أَسْ إِمّوْشنْ زِي أَربِّي، أَمْ يِينِّي إِوكّْڒنْ مْلِيحْ خْ عْڒَامْ كُوڒْ أَرْضَا ن أَربِّي. \x ◘ \xo 4:‏10 \xt أَوڒن. 3‏:‏28؛ رُوم. 12‏:‏6؛ 2 كُور. 8‏:‏11. \x*
\v 11 أجّْ مَارَّا وِي إِسَّاوَاڒنْ، أَذْ إِسِّيوڒْ عْلَاحْسَابْ أَوَاڒْ ن أَربِّي، ؤُ أجّْ كُوڒْ إِجّْ ونِّي إِتّْسخَّارنْ، إِتّْسخَّارْ عْلَاحْسَابْ جّهْذْ إِ ذ أَسْ إِوْشَا أَربِّي، حِيمَا ذِي مَارَّا مِينْ ثتّڭّمْ أَذْ إِذْوڒْ ؤُسمْغَارْ غَارْ أَربِّي س يَاسُوع لْمَاسِيحْ ونِّي غَارْ إِدْجَا ؤُعُودْجِي ذ شَّانْ إِ ڒبْذَا قَاعْ. أَمِينْ. \x ◘ \xo 4:‏11 \xt إِرْم. 23‏:‏22. \x*
\m 
\v 12 \add أَ\add* إِمْعِيزّنْ، وَارْ ذهّْشمْ شَا زڭْ وَاطَّاسْ ن إِجَارِّيبنْ إِ خَاومْ إِ د غَا إِكِّينْ، أَخْمِي كنِّيوْ ثڒْقفْ شَا ن ثْمسْڒَاشْثْ ذ ثَاغْرِيبْثْ، مَاغَارْ مَانْ أَيَا مَاحنْذْ أَذْ ثتّْوَاقدْجْبمْ. \x ◘ \xo 4:‏12 \xt إِرْم. 48‏:‏10؛ 1 كُور. 3‏:‏13؛ 1 بُط. 1‏:‏7. \x*
\v 13 مَاشَا فَارْحمْ ؤُمِي ثْشَارْشمْ ذڭْ ؤُودّبْ إِ إِكِّينْ خْ لْمَاسِيحْ، حِيمَا أَذْ ثْفَارْحمْ س ڒفْرَاحثْ عَاوذْ خْمِي د غَا إِضْهَارْ ؤُعُودْجِي نّسْ.
\v 14 مَاڒَاعيّْبنْ كنِّيوْ خْ سِّيبّثْ ن يِيسمْ ن لْمَاسِيحْ، سّعْذْ نْومْ مِينْزِي أَعُودْجِي ن أَرُّوحْ ن أَربِّي أَذْ خَاومْ يَارْسَا. \x ◘ \xo 4:‏14 \xt مت. 5‏:‏10؛ 1 بُط. 2‏:‏20؛ 3‏:‏14. \x*
\m 
\v 15 وَارْ تّجِّيمْ حذْ زَّايْومْ أَذْ إِودّبْ أَمْ ؤُقتَّاڒْ نِيغْ أَمْ ؤُشفَّارْ نِيغْ أَمْ ؤُعفَّانْ.
\v 16 مَاشَا مَاڒَا إِودّبْ حذْ أَمْ ؤُمَاسِيحِي، وَارْ إِتّْسضْحِي شَا، مَاشَا أَذْ إِكَّارْ أَذْ إِسُّوعْڒَا أَربِّي زِي سِّيبّثْ ن يِيسمْ-أَ.
\v 17 مَاغَارْ ثِيوضْ-د ڒْوقْثْ مَاحنْذْ أَذْ إِبْذَا ڒْحُوكْمْ غَارْ ثَادَّارْثْ ن أَربِّي. مَاشَا مَاڒَا ڒْحُوكْمْ زَّايْنغْ إِ غَا إِسِّيزْوَارْ، مَامّشْ غَا يِيڒِي ؤُنڭَّارُو ن يِينِّي وَارْ إِطِّيعنْ شَا ڒخْبَارْ أَصبْحَانْ ن أَربِّي؟ \x ◘ \xo 4:‏17 \xt إِرْم. 25‏:‏29؛ لك. 10‏:‏12؛ 23‏:‏31؛ أَفا. 2‏:‏19؛ 1 تِيم. 3‏:‏1؛ عبر. 10‏:‏21\x*
\v 18 ؤُشَا مَاڒَا أَمْسڭَّاذْ يِيوضْ أَذْ إِطّفْ ثُوذَارْثْ س ڒْوحْڒَانْ، مَانِي عَاذْ إِ د غَا إِضْهَارْ ؤُكَافْرِيوْ ذ ؤُمذْنُوبْ؟ \x ◘ \xo 4:‏18 \xt أَوڒن. 11‏:‏31. \x*
\v 19 س ؤُينِّي مَارَّا إِنِّي إِتّْودَّابنْ عْلَاحْسَابْ مِينْ إِخْسْ أَربِّي، أجّْ إِ-ثنْ أَذْ أَسْ سلّْمنْ ڒعْمُورْ نْسنْ أَمْ إِ ونِّي د-إِخڒْقنْ كُوڒْشِي، ونِّي ذِي إِدْجَا ڒَامَانْ، مَاحنْذْ أَذْ ڭّنْ مِينْ إِصبْحنْ.
\b
\b
\c 5
\s1 ثَاروْسَا ن ثْحِيمَارْثْ ن أَربِّي
\m 
\v 1 تّْزَاوْڭغْ إِنِّي ذ \bd إِمْغَارنْ\bd* جَارْ أَونْ، نشّْ ذ ونِّي ذ أَمْغَارْ أَكِيذْومْ ذ أَشهَّاذْ ن ؤُودّبْ إِ إِكِّينْ خْ لْمَاسِيحْ ؤُڒَا ذ أَمْعَاشَارْ ذڭْ ؤُعُودْجِي نّسْ إِ د غَا إِتّْوَاسّضْهَارْ:
\v 2 أَروْسمْ ثَاحِيمَارْثْ ن أَربِّي ثنِّي ثْحطَّامْ، وَارْ إِدْجِي س ؤُغِيڒْ مَاشَا س ڒْخَاضَارْ، وَارْ إِدْجِي ذِي طّْمعْ ن أَرْبحْ وَارْ إِحْڒِينْ، مَاشَا س مَارَّا وُوڒْ نْومْ، \x ◘ \xo 5:‏2 \xt ڒخ. 20‏:‏28؛ 1 تِيم. 3‏:‏3؛ ثِيث. 1‏:‏7. \x*
\v 3 وَارْ إِدْجِي أَمْ يِينِّي إِدْجَانْ خْ ثْحِيمَارْثْ، مَاشَا ؤُمِي ثدْجَامْ ذ إِجّْ ن ؤُمذْيَا إِشْنَا إِ نِيثْنِي. \x ◘ \xo 5:‏3 \xt 2 كُور. 1‏:‏24؛ فِيل. 3‏:‏17؛ 1 تِيم. 4‏:‏12؛ ثِيث. 2‏:‏7. \x*
\v 4 ؤُشَا خْمِي د غَا إِضْهَارْ ؤُمكْسَا أَمقّْرَانْ أَذْ زَّايسْ ثطّْفمْ تَّاجْ ن ؤُعُودْجِي إِ وَارْ إِفنِّينْ. \x ◘ \xo 5:‏4 \xt إِشا. 40‏:‏11؛ حِز. 34‏:‏23؛ يُوح. 10‏:‏11؛ 1 كُور. 9‏:‏25؛ عبر. 13‏:‏20؛ 2 تِيم. 4‏:‏8؛ يَاع. 1‏:‏12؛ 1 بُط. 1‏:‏4؛ 2‏:‏25. \x*
\m 
\v 5 ؤُ كنِّيوْ، \bd إِبْڒِيغنْ\bd*، سَارْسمْ إِخفْ نْومْ سَاذُو إِمْغَارنْ نْومْ، بيْسمْ إِخفْ نْومْ س ؤُوَاضعْ ن أَرُّوحْ إِجّْ إِ ونّغْنِي، مِينْزِي أَربِّي إِتّْعكَّاسْ إِمْعفَّارنْ، \add مَاشَا\add* إِمْوَاضْعنْ إِوْشَا أَسنْ أَرْضَا. \x ◘ \xo 5:‏5 \xt أَوڒن. 3‏:‏34؛ رُوم. 12‏:‏10؛ فِيل. 2‏:‏3؛ يَاع. 4‏:‏6. \x*
\v 6 سمْژَايمْ إِخفْ نْومْ سَاذُو أَفُوسْ إِجهْذنْ ن أَربِّي، حِيمَا أَذْ كنِّيوْ إِسُّوعْڒَا ذِي ڒْوقْثْ نّسْ نِيشَانْ. \x ◘ \xo 5:‏6 \xt أَيُوبْ 22‏:‏29؛ أَوڒن. 29‏:‏23؛ مت. 23‏:‏12؛ لك. 14‏:‏11؛ يَاع. 4‏:‏10. \x*
\v 7 مَارَّا إِمْنُوسنْ نْومْ أَرّمْ ثنْ غَارْ أَربِّي، أَقَا نتَّا إِتّْهِيلَّا ذَايْومْ. \x ◘ \xo 5:‏7 \xt إِزهد. 55‏:‏23؛ مت. 6‏:‏25؛ لك. 12‏:‏22؛ 1 كُور. 9‏:‏9؛ فِيل. 4‏:‏6؛ عبر. 13‏:‏5؛ 1 تِيم. 6‏:‏8. \x*
\m 
\v 8 أَرّمْ-د ڒْبَاڒْ، حْضَامْ، مِينْزِي ڒعْذُو نْومْ، شِّيطَانْ أَمقّْرَانْ، إِتّْزهَّارْ أَمْ وَايْرَاذْ ؤُ إِتّْحَامَا، يَارزُّو مِينْ إِزمَّارْ أَذْ إِسَارْضْ. \x ◘ \xo 5:‏8 \xt أَيُوبْ 1‏:‏7؛ لك. 22‏:‏31؛ 1 تس. 5‏:‏6؛ 1 بُط. 1‏:‏13؛ 4‏:‏7. \x*
\v 9 مْعَاڒَامْ ث، ثْبدّمْ نِيشَانْ ذِي لْ-إِيمَانْ، أَقَا ثسّْنمْ بلِّي أَيْثْمَاثْومْ ذِي دُّونشْثْ ؤُڒَا ذ نِيثْنِي كسِّينْ أَودّبْ-أَ. \x ◘ \xo 5:‏9 \xt أَفا. 4‏:‏27؛ يَاع. 4‏:‏7. \x*
\m 
\v 10 مَاشَا أَربِّي ن أَرْضَا ونِّي ذ أَنغْ د-إِڒَاغَانْ غَارْ ؤُعُودْجِي نّسْ إِتّْذُومَانْ إِ ڒبْذَا س يَاسُوع لْمَاسِيحْ، أَقَا نتَّا، أَوَارْنِي ڒَامِي نْودّبْ ڒحْصَارَاثْ-أَ ثِيمُوقْڒِيڒِينْ، أَذْ أَنغْ إِسّجْهذْ، أَذْ أَنغْ إِضْمنْ ؤُ أَذْ أَنغْ إِسدّْ إِ ڒبْذَا. \x ◘ \xo 5:‏10 \xt عبر. 10‏:‏37؛ 1 بُط. 1‏:‏6. \x*
\v 11 غَارسْ نتَّا أَعُودْجِي ذ صُّولْطَا ذ ڒْعزّْ إِ ڒبْذَا قَاعْ. أَمِينْ.
\b
\m 
\v 12 ؤُرِيغْ أَومْ-د شَا ن ثْمسْڒَايِينْ ذِي ثِيرَا ثَاقُوضَاضْثْ س ؤُفُوسْ ن سِيلْوَانُوسْ، ؤُمَا ذ أَمْثِيقِّي، ؤُ نشّْ قنْعغْ ؤُ شهّْذغْ، أَقَا مَانْ أَيَا ذِي مِينْ ذِي ثْبدّمْ \add نِيشَانْ\add*، أَقَا-ث ذ أَرْضَا ن أَربِّي ذ ثِيذتّْ.
\m 
\v 13 ثَامسْمُونْثْ إِتّْوَافَارْزنْ إِ إِدْجَانْ ذِي بَابِيلْ، ثْسدْجَامْ خَاومْ س ڒهْنَا، ؤُڒَا ذ مِّي مَارْكُوسْ.
\m 
\v 14 سدْجْممْ خْ وَايَاوْيَا س ڒهْنَا ؤُ س ؤُسُوذمْ إِقدّْسنْ. ڒهْنَا أَذْ كِيومْ يِيڒِي مَارَّا إِذْومْ إِ إِدْجَانْ ذِي لْمَاسِيحْ. أَمِينْ. \x ◘ \xo 5:‏14 \xt رُوم. 16‏:‏16؛ 1 كُور. 16‏:‏20؛ 2 كُور. 13‏:‏12؛ 1 تس. 5‏:‏26. \x* 
