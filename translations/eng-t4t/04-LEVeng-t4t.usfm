\v 9 “Tell \w this|strong="H1121"\w* \w to|strong="H1121"\w* Aaron \w and|strong="H1121"\w* \w his|strong="H4480"\w* \w sons|strong="H1121"\w*: These \w are|strong="H1121"\w* \w the|strong="H4480"\w* regulations \w concerning|strong="H4480"\w* \w the|strong="H4480"\w* \w offerings|strong="H4480"\w* \w that|strong="H4480"\w* \w will|strong="H1121"\w* \w be|strong="H1121"\w* completely burned \add on the altar\add*: \w The|strong="H4480"\w* \w offering|strong="H4480"\w* \w must|strong="H1121"\w* \w remain|strong="H3498"\w* \w on|strong="H4725"\w* \w the|strong="H4480"\w* altar \w all|strong="H4480"\w* during \w the|strong="H4480"\w* \w night|strong="H1121"\w*, \w and|strong="H1121"\w* \w the|strong="H4480"\w* fire \w on|strong="H4725"\w* \w the|strong="H4480"\w* altar \w must|strong="H1121"\w* always \w be|strong="H1121"\w* kept burning.
\v 10 \add The next morning\add* \w the|strong="H5414"\w* priest \w must|strong="H3808"\w* \w put|strong="H5414"\w* \w on|strong="H5414"\w* \w his|strong="H5414"\w* linen under-clothes \w and|strong="H2403"\w* linen outer clothes. \w Then|strong="H5414"\w* \w he|strong="H1931"\w* \w must|strong="H3808"\w* remove \w the|strong="H5414"\w* ashes \w of|strong="H2403"\w* \w the|strong="H5414"\w* \w offering|strong="H2403"\w* \w from|strong="H5414"\w* \w the|strong="H5414"\w* fire \w and|strong="H2403"\w* \w put|strong="H5414"\w* \w them|strong="H5414"\w* beside \w the|strong="H5414"\w* altar.
\v 11 \w Then|strong="H3068"\w* \w he|strong="H3068"\w* \w must|strong="H1121"\w* \w take|strong="H1121"\w* off \w those|strong="H3605"\w* clothes \w and|strong="H1121"\w* \w put|strong="H3068"\w* \w on|strong="H3068"\w* \w other|strong="H3605"\w* clothes, \w and|strong="H1121"\w* \w take|strong="H1121"\w* \w the|strong="H3605"\w* ashes outside \w the|strong="H3605"\w* camp, \w to|strong="H3068"\w* \w a|strong="H3068"\w* \w place|strong="H3605"\w* \w that|strong="H3605"\w* \w is|strong="H3068"\w* acceptable \w to|strong="H3068"\w* \w me|strong="H5060"\w*.
\v 12 \w The|strong="H3068"\w* fire \w on|strong="H3068"\w* \w the|strong="H3068"\w* altar must always \w be|strong="H3068"\w* kept burning; \w the|strong="H3068"\w* priest must \w not|strong="H1696"\w* allow \w it|strong="H1696"\w* \w to|strong="H1696"\w* ◄\w go|strong="H3068"\w* \w out|strong="H1696"\w*/quit burning►. Each morning \w the|strong="H3068"\w* priest must \w put|strong="H3068"\w* more firewood \w on|strong="H3068"\w* \w the|strong="H3068"\w* fire. \w Then|strong="H1696"\w* \w he|strong="H3068"\w* must arrange more \w offerings|strong="H3068"\w* \w on|strong="H3068"\w* \w the|strong="H3068"\w* fire, \w and|strong="H4872"\w* burn \w on|strong="H3068"\w* \w the|strong="H3068"\w* altar \w the|strong="H3068"\w* fat \w of|strong="H3068"\w* \w the|strong="H3068"\w* \w offerings|strong="H3068"\w* \w to|strong="H1696"\w* \w be|strong="H3068"\w* burned \w to|strong="H1696"\w* maintain fellowship \add with me\add*.
\v 13 \w The|strong="H3068"\w* fire \w on|strong="H3117"\w* \w the|strong="H3068"\w* altar \w must|strong="H1121"\w* \w be|strong="H3068"\w* kept burning \w continually|strong="H8548"\w*; \w the|strong="H3068"\w* priest \w must|strong="H1121"\w* \w not|strong="H2088"\w* allow \w it|strong="H7126"\w* \w to|strong="H3068"\w* \w go|strong="H7126"\w* out.”
\s1 Other instructions concerning the grain offerings
\p 
\v 14 “\w These|strong="H6213"\w* \w are|strong="H3068"\w* \w the|strong="H5921"\w* regulations \w concerning|strong="H5921"\w* \w the|strong="H5921"\w* \w offerings|strong="H4503"\w* \w made|strong="H6213"\w* \w from|strong="H5921"\w* grain: Aaron’s sons must \w bring|strong="H7126"\w* \w them|strong="H5921"\w* \w to|strong="H3068"\w* \w me|strong="H5921"\w* \w in|strong="H5921"\w* front \w of|strong="H3068"\w* \w the|strong="H5921"\w* altar.
\v 15 \w The|strong="H6213"\w* \w priest|strong="H3548"\w* \w must|strong="H1121"\w* \w take|strong="H6213"\w* \w a|strong="H3068"\w* handful \w of|strong="H1121"\w* \w fine|strong="H6213"\w* flour mixed \w with|strong="H3068"\w* olive oil \w and|strong="H1121"\w* \w incense|strong="H6999"\w* \w and|strong="H1121"\w* \w burn|strong="H6999"\w* \w that|strong="H3068"\w* \w on|strong="H3068"\w* \w the|strong="H6213"\w* altar. \w That|strong="H3068"\w* handful \w will|strong="H3068"\w* signify \w that|strong="H3068"\w* \w the|strong="H6213"\w* \w whole|strong="H3632"\w* \w offering|strong="H6999"\w* \w truly|strong="H6213"\w* belongs \w to|strong="H3068"\w* \w me|strong="H6213"\w*. \w And|strong="H1121"\w* \w the|strong="H6213"\w* aroma \w while|strong="H8478"\w* \w it|strong="H6213"\w* \w burns|strong="H6999"\w* \w will|strong="H3068"\w* \w be|strong="H3068"\w* pleasing \w to|strong="H3068"\w* \w me|strong="H6213"\w*.
\v 16 Aaron \w and|strong="H3548"\w* \w his|strong="H3605"\w* sons \w may|strong="H1961"\w* eat \w the|strong="H3605"\w* remaining part \w of|strong="H3605"\w* \w the|strong="H3605"\w* \w grain|strong="H3605"\w* \w offering|strong="H4503"\w*. \w But|strong="H3808"\w* \w they|strong="H3808"\w* \w must|strong="H3808"\w* eat \w it|strong="H1961"\w* \w in|strong="H3808"\w* \w a|strong="H3068"\w* holy \w place|strong="H1961"\w*, \w in|strong="H3808"\w* \w the|strong="H3605"\w* courtyard \w of|strong="H3605"\w* \w the|strong="H3605"\w* Sacred Tent.
\v 17 \w It|strong="H1696"\w* must \w not|strong="H1696"\w* \w have|strong="H3068"\w* yeast mixed \w with|strong="H3068"\w* \w it|strong="H1696"\w*. \w Like|strong="H3068"\w* \w the|strong="H3068"\w* \w offerings|strong="H3068"\w* \w for|strong="H3068"\w* sin \w and|strong="H4872"\w* \w the|strong="H3068"\w* \w offerings|strong="H3068"\w* \w to|strong="H1696"\w* cause \w people|strong="H1696"\w* \w to|strong="H1696"\w* \w no|strong="H1696"\w* longer \w be|strong="H3068"\w* guilty \w of|strong="H3068"\w* sin, \w that|strong="H3068"\w* \w offering|strong="H3068"\w* \w is|strong="H3068"\w* very holy.
\v 18 \w Any|strong="H6440"\w* \w male|strong="H1121"\w* \w descendants|strong="H1121"\w* \w of|strong="H1121"\w* Aaron \w are|strong="H1121"\w* permitted \w to|strong="H1696"\w* eat \w it|strong="H1931"\w*, \w because|strong="H6440"\w* \w it|strong="H1931"\w* \w is|strong="H3068"\w* forever \w their|strong="H3068"\w* regular share \w of|strong="H1121"\w* \w the|strong="H6440"\w* \w offerings|strong="H5930"\w* given \w to|strong="H1696"\w* \w me|strong="H6440"\w* \w and|strong="H1121"\w* burned \w in|strong="H3068"\w* \w the|strong="H6440"\w* fire \add on the altar\add*. \w Anyone|strong="H1931"\w* else \w who|strong="H1931"\w* touches \w those|strong="H1121"\w* \w offerings|strong="H5930"\w* \w made|strong="H1696"\w* \w from|strong="H6440"\w* grain \w will|strong="H3068"\w* \w be|strong="H3068"\w* punished \w by|strong="H3068"\w* \w God|strong="H3068"\w*.”
\p 
\v 19 \w Yahweh|strong="H3068"\w* also said \w to|strong="H4725"\w* Moses/\w me|strong="H2398"\w*,
\v 20 “\w Tell|strong="H3605"\w* Aaron \w and|strong="H1818"\w* \w his|strong="H3605"\w* sons \w that|strong="H3605"\w* \w this|strong="H6942"\w* \w is|strong="H3605"\w* \w the|strong="H3605"\w* offering \w that|strong="H3605"\w* \w they|strong="H5921"\w* \w must|strong="H1818"\w* \w bring|strong="H5060"\w* \w to|strong="H5921"\w* \w Yahweh|strong="H3068"\w* \w on|strong="H5921"\w* \w the|strong="H3605"\w* day \w that|strong="H3605"\w* \w any|strong="H3605"\w* \w of|strong="H6918"\w* \w them|strong="H5921"\w* ◄\w is|strong="H3605"\w* ordained/becomes \w a|strong="H3068"\w* priest►: \w That|strong="H3605"\w* \w person|strong="H1320"\w* \w must|strong="H1818"\w* \w bring|strong="H5060"\w* two quarts/liters \w of|strong="H6918"\w* fine flour \w as|strong="H3605"\w* \w an|strong="H5921"\w* offering \w made|strong="H3605"\w* \w from|strong="H5921"\w* \w grain|strong="H3605"\w*. \w He|strong="H3605"\w* \w must|strong="H1818"\w* \w bring|strong="H5060"\w* half \w of|strong="H6918"\w* \w it|strong="H5921"\w* \w in|strong="H5921"\w* \w the|strong="H3605"\w* morning \w and|strong="H1818"\w* half \w of|strong="H6918"\w* \w it|strong="H5921"\w* \w in|strong="H5921"\w* \w the|strong="H3605"\w* evening.
\v 21 \w He|strong="H4325"\w* must mix \w it|strong="H7665"\w* well \w with|strong="H3627"\w* olive oil \w and|strong="H4325"\w* \w bake|strong="H1310"\w* \w it|strong="H7665"\w* \w in|strong="H7665"\w* \w a|strong="H3068"\w* shallow pan. \w He|strong="H4325"\w* must then \w break|strong="H7665"\w* \w it|strong="H7665"\w* \w into|strong="H4325"\w* small \w pieces|strong="H7665"\w* \w to|strong="H4325"\w* \w be|strong="H4325"\w* burned \add on the altar\add*. \w And|strong="H4325"\w* \w the|strong="H7665"\w* aroma while \w it|strong="H7665"\w* burns \w will|strong="H4325"\w* \w be|strong="H4325"\w* pleasing \w to|strong="H4325"\w* \w Yahweh|strong="H3068"\w*.
\v 22 \w I|strong="H3605"\w* \w have|strong="H3548"\w* commanded \w that|strong="H3605"\w* \w the|strong="H3605"\w* descendants \w of|strong="H3605"\w* Aaron \w who|strong="H3605"\w* \w are|strong="H3548"\w* appointed \w in|strong="H2145"\w* turn \w to|strong="H3605"\w* become \w the|strong="H3605"\w* Supreme \w Priests|strong="H3548"\w* after Aaron dies \w are|strong="H3548"\w* \w the|strong="H3605"\w* \w ones|strong="H6944"\w* \w who|strong="H3605"\w* must prepare \w those|strong="H3605"\w* \w things|strong="H6944"\w*. \w These|strong="H1931"\w* offerings must \w be|strong="H2145"\w* \w completely|strong="H3605"\w* burned \add on the altar\add* \w to|strong="H3605"\w* \w be|strong="H2145"\w* \w sacrifices|strong="H6944"\w* \w to|strong="H3605"\w* \w me|strong="H3605"\w*, \w Yahweh|strong="H3068"\w*.
\v 23 \w Every|strong="H3605"\w* \w offering|strong="H2403"\w* \w that|strong="H3605"\w* \w a|strong="H3068"\w* priest gives \w that|strong="H3605"\w* \w is|strong="H3605"\w* \w made|strong="H3722"\w* \w from|strong="H1818"\w* \w grain|strong="H3605"\w* \w must|strong="H1818"\w* \w be|strong="H3808"\w* \w completely|strong="H3605"\w* \w burned|strong="H8313"\w*; \w none|strong="H3808"\w* \w of|strong="H1818"\w* \w it|strong="H3808"\w* \w is|strong="H3605"\w* \w to|strong="H4150"\w* \w be|strong="H3808"\w* eaten.”
\s1 Other instructions concerning the sin offering
\p 
\v 24 \w Yahweh|strong="H3068"\w* also said to Moses/me,
\v 25 “Tell Aaron and his sons: These are the regulations concerning the offerings that people must bring to me so that I will forgive the people for the sins they have committed:
\v 26 The animals must be slaughtered in my presence in the same place that the animals that are to be completely burned \add on the altar\add* are slaughtered, in the courtyard in front of the Sacred Tent.
\v 27 Any other person who touches any of its meat will be punished by God. And if its blood is splattered on your clothes, you must wash the clothes in \w a|strong="H3068"\w* holy place.
\v 28 If the meat is cooked in \w a|strong="H3068"\w* clay pot, the pot must be broken \add afterwards\add*. But if it is cooked in \w a|strong="H3068"\w* bronze pot, the pot must be scoured \add afterwards\add* and rinsed with water.
\v 29 Any male in \w a|strong="H3068"\w* priest’s family may eat some of the cooked meat; that meat is very holy.
\v 30 But if the blood of those sin offerings is brought into the Sacred Tent to enable the people to be forgiven for having sinned, the meat of those animals must not be eaten. The meat must be completely burned.”
\c 7
\s1 The guilt offering
\p 
\v 1 “\w These|strong="H2063"\w* \w are|strong="H6944"\w* \w the|strong="H1931"\w* regulations concerning \w the|strong="H1931"\w* offerings \w to|strong="H6944"\w* \w be|strong="H1931"\w* made \w by|strong="H8451"\w* \w people|strong="H1931"\w* \w who|strong="H1931"\w* \w are|strong="H6944"\w* guilty \w of|strong="H8451"\w* not giving \w to|strong="H6944"\w* me \w the|strong="H1931"\w* \w things|strong="H6944"\w* \w that|strong="H1931"\w* \w are|strong="H6944"\w* required \w to|strong="H6944"\w* \w be|strong="H1931"\w* given \w to|strong="H6944"\w* me. \w Those|strong="H1931"\w* \w are|strong="H6944"\w* very \w sacred|strong="H6944"\w* offerings.
\v 2 \w Each|strong="H5439"\w* animal \w that|strong="H4196"\w* \w is|strong="H4725"\w* \w to|strong="H5921"\w* \w be|strong="H1818"\w* offered \w by|strong="H5921"\w* such \w people|strong="H1818"\w* \w must|strong="H1818"\w* \w be|strong="H1818"\w* \w slaughtered|strong="H7819"\w* \w in|strong="H5921"\w* \w the|strong="H5921"\w* same \w place|strong="H4725"\w* \w where|strong="H4725"\w* \w the|strong="H5921"\w* animals \w that|strong="H4196"\w* \w will|strong="H1818"\w* \w be|strong="H1818"\w* \w completely|strong="H5439"\w* burned \add on the altar\add* \w are|strong="H1818"\w* \w slaughtered|strong="H7819"\w*, \w and|strong="H4196"\w* \w their|strong="H5921"\w* \w blood|strong="H1818"\w* \w must|strong="H1818"\w* \w be|strong="H1818"\w* \w sprinkled|strong="H2236"\w* \w against|strong="H5921"\w* \w all|strong="H5439"\w* \w sides|strong="H5439"\w* \w of|strong="H4196"\w* \w the|strong="H5921"\w* \w altar|strong="H4196"\w*.
\v 3 \w All|strong="H3605"\w* \w their|strong="H3605"\w* \w fat|strong="H2459"\w*, \w the|strong="H3605"\w* \w fat|strong="H2459"\w* tails \w that|strong="H3605"\w* \w are|strong="H4480"\w* cut \w close|strong="H7126"\w* \w to|strong="H7126"\w* \w the|strong="H3605"\w* backbone, \w and|strong="H7126"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w fat|strong="H2459"\w* \w that|strong="H3605"\w* \w covers|strong="H3680"\w* \w the|strong="H3605"\w* \w inner|strong="H7130"\w* \w parts|strong="H7130"\w* \w of|strong="H4480"\w* \w the|strong="H3605"\w* animals \w or|strong="H4480"\w* \w which|strong="H3605"\w* \w is|strong="H3605"\w* attached \w to|strong="H7126"\w* \w them|strong="H7126"\w*, must \w be|strong="H4480"\w* burned \add on the altar\add*.
\v 4 \w That|strong="H2459"\w* includes \w the|strong="H5921"\w* \w kidneys|strong="H3629"\w* \w with|strong="H5921"\w* \w their|strong="H5921"\w* \w fat|strong="H2459"\w* \w near|strong="H5921"\w* \w the|strong="H5921"\w* lower \w back|strong="H5493"\w* muscle, \w and|strong="H8147"\w* \w the|strong="H5921"\w* protruding \w lobe|strong="H3508"\w* \w that|strong="H2459"\w* \w is|strong="H3516"\w* attached \w to|strong="H5921"\w* \w the|strong="H5921"\w* \w liver|strong="H3516"\w*.
\v 5 \w The|strong="H3068"\w* \w priest|strong="H3548"\w* must \w burn|strong="H6999"\w* \w them|strong="H4196"\w* \w on|strong="H3068"\w* \w the|strong="H3068"\w* \w altar|strong="H4196"\w* \w to|strong="H3068"\w* \w be|strong="H3068"\w* \w offerings|strong="H3068"\w* \w to|strong="H3068"\w* \w me|strong="H6999"\w*, \w Yahweh|strong="H3068"\w*. \w They|strong="H3068"\w* \w are|strong="H3068"\w* \w an|strong="H3068"\w* \w offering|strong="H6999"\w* \w for|strong="H3068"\w* \w the|strong="H3068"\w* \w people|strong="H1931"\w* \w to|strong="H3068"\w* \w be|strong="H3068"\w* forgiven \w for|strong="H3068"\w* not doing what \w they|strong="H3068"\w* \w were|strong="H3068"\w* required \w to|strong="H3068"\w* \w do|strong="H3068"\w*.
\v 6 \w All|strong="H3605"\w* \w the|strong="H3605"\w* \w males|strong="H2145"\w* \w in|strong="H4725"\w* \w the|strong="H3605"\w* \w priest|strong="H3548"\w*’s family \w are|strong="H3548"\w* permitted \w to|strong="H4725"\w* eat \w its|strong="H3605"\w* meat, \w but|strong="H3605"\w* \w it|strong="H1931"\w* must \w be|strong="H2145"\w* eaten \w in|strong="H4725"\w* \w a|strong="H3068"\w* \w sacred|strong="H6944"\w* \w place|strong="H4725"\w*, \w because|strong="H3605"\w* \w it|strong="H1931"\w* \w is|strong="H1931"\w* very \w sacred|strong="H6944"\w*.
\p 
\v 7 “\w The|strong="H1961"\w* regulation \w is|strong="H1961"\w* \w the|strong="H1961"\w* same \w for|strong="H3722"\w* \w the|strong="H1961"\w* \w offerings|strong="H2403"\w* \add to enable people to be forgiven for the sins they have committed \add* \w and|strong="H3548"\w* \w the|strong="H1961"\w* \w offerings|strong="H2403"\w* \w for|strong="H3722"\w* \w when|strong="H1961"\w* \w they|strong="H3548"\w* \w are|strong="H2403"\w* guilty \w of|strong="H8451"\w* \w not|strong="H1961"\w* giving \w to|strong="H1961"\w* \w me|strong="H1961"\w* \w the|strong="H1961"\w* \w things|strong="H1961"\w* \w that|strong="H3548"\w* \w are|strong="H2403"\w* \w required|strong="H1961"\w* \w to|strong="H1961"\w* \w be|strong="H1961"\w* given \w to|strong="H1961"\w* \w me|strong="H1961"\w*. \w The|strong="H1961"\w* meat \w of|strong="H8451"\w* \w those|strong="H1961"\w* \w offerings|strong="H2403"\w* \w belongs|strong="H1961"\w* \w to|strong="H1961"\w* \w the|strong="H1961"\w* \w priest|strong="H3548"\w* \w who|strong="H3548"\w* offers \w them|strong="H1961"\w* \w in|strong="H1961"\w* order \w that|strong="H3548"\w* \w the|strong="H1961"\w* people \w will|strong="H1961"\w* \w be|strong="H1961"\w* \w forgiven|strong="H3722"\w*.
\v 8 \w The|strong="H7126"\w* \w priest|strong="H3548"\w* \w who|strong="H3548"\w* slaughters \w an|strong="H7126"\w* \w animal|strong="H1961"\w* \w that|strong="H3548"\w* \w will|strong="H1961"\w* \w be|strong="H1961"\w* completely burned \w on|strong="H1961"\w* \w the|strong="H7126"\w* altar \w is|strong="H1961"\w* permitted \w to|strong="H1961"\w* \w keep|strong="H7126"\w* \w the|strong="H7126"\w* \w animal|strong="H1961"\w*’s \w hide|strong="H5785"\w* \w for|strong="H1961"\w* himself.
\v 9 \w Offerings|strong="H4503"\w* \w of|strong="H5921"\w* \w things|strong="H3605"\w* \w made|strong="H6213"\w* \w from|strong="H5921"\w* \w grain|strong="H3605"\w* \w that|strong="H3605"\w* \w are|strong="H6213"\w* baked \w in|strong="H5921"\w* \w an|strong="H6213"\w* \w oven|strong="H8574"\w* \w or|strong="H4503"\w* cooked \w in|strong="H5921"\w* \w a|strong="H3068"\w* \w pan|strong="H4227"\w* \w or|strong="H4503"\w* ◄\w in|strong="H5921"\w* \w a|strong="H3068"\w* shallow \w pan|strong="H4227"\w*/\w on|strong="H5921"\w* \w a|strong="H3068"\w* \w griddle|strong="H4227"\w*► \w belong|strong="H1961"\w* \w to|strong="H1961"\w* \w the|strong="H3605"\w* \w priest|strong="H3548"\w* \w who|strong="H3605"\w* \w makes|strong="H6213"\w* \w those|strong="H3605"\w* \w offerings|strong="H4503"\w* \add for another person\add*.
\v 10 \w And|strong="H1121"\w* \w offerings|strong="H4503"\w* \w of|strong="H1121"\w* \w things|strong="H3605"\w* \w made|strong="H1961"\w* \w from|strong="H1121"\w* \w grain|strong="H3605"\w*, whether \w they|strong="H3605"\w* \w were|strong="H1961"\w* \w mixed|strong="H1101"\w* \w with|strong="H1101"\w* \w olive|strong="H8081"\w* \w oil|strong="H8081"\w* \w or|strong="H1121"\w* \w not|strong="H1961"\w*, \w also|strong="H1121"\w* \w belong|strong="H1961"\w* \w to|strong="H1961"\w* \w the|strong="H3605"\w* \w sons|strong="H1121"\w* \w of|strong="H1121"\w* Aaron.”
