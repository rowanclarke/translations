\id JDG
\h ڒْقُوضَاثْ 
\toc1 ڒْقُوضَاثْ 
\toc2 ڒْقُوضَاثْ 
\toc3 ڒقض. 
\mt1 ڒْقُوضَاثْ  
\c 1
\s1 يَاهُوذَا إِذْوڒْ ذ أَزدْجِيفْ أَوَارْنِي إِ ڒْموْثْ ن يَاشُووَا  
\m
\v 1 أَوَارْنِي إِ ڒْموْثْ ن يَاشُووَا، إِمْسَارْ أَقَا أَيْثْ ن إِسْرَائِيل سّقْسَانْ سِيذِي، نَّانْ: ”مَانْ ونْ زَّايْنغْ إِ غَا إِكَّارنْ ذ أَمزْوَارُو أَذْ إِڭعّذْ أَذْ إِمّْنغْ أَكْ-ذ أَيْثْ ن كنْعَانْ؟“ \x ◘ \xo 1:‏1 \xt ڒقض. 20‏:‏18\x*  
\v 2 يَارَّا-د سِيذِي: ”يَاهُوذَا أَذْ إِڭعّذْ \add ذ أَمزْوَارُو\add*. خْزَارْ، نشّْ وْشِيغْ أَسْ ثَامُّورْثْ ذڭْ ؤُفُوسْ نّسْ.“  
\v 3 ؤُشَا إِنَّا يَاهُوذَا إِ ؤُمَاسْ شِيمْعُونْ: ”ڭعّذْ أَكِيذِي ذِي \add ثمُّورْثْ ن\add* ثْقدُّوحْثْ \add ن ڒعْبَارْ\add* إِنُو ؤُشَا أجّْ أَنغْ أَذْ نمّْنغْ أَكْ-ذ أَيْثْ ن كنْعَانْ، \add خنِّي\add* نشّْ أَذْ كِيكْ ڭعّْذغْ ذِي \add ثمُّورْثْ ن\add* ثْقدُّوحْثْ نّشْ.“ ؤُشَا يُويُورْ أَكِيذسْ شِيمْعُونْ.   
\m
\v 4 إِڭعّذْ يَاهُوذَا ؤُشَا سِيذِي إِعَارْنْ أَيْثْ ن كنْعَانْ ذ إِفِيرِيزِييْ\add ينْ\add* ذڭْ ؤُفُوسْ نْسنْ ؤُشَاغڒْبنْ خَاسنْ غَارْ بَازَاقْ،عشْرَا-أَڒَافْ ن يِيرْيَازنْ. \f ◼ \fr 1:‏4 \ft \+bd ’بَازَاقْ‘\+bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَسَّامْ‘.\f*  
\v 5 نِيثْنِي ؤُفِينْ أَذُونِي-بَازَاقْ ذِي بَازَاقْ ؤُشَا مّنْغنْ أَكِيذسْ ؤُ نِيثْنِيغڒْبنْ خْ أَيْثْ ن كنْعَانْ ؤُ خْ إِفِيرِيزِييْ\add ينْ\add*.  
\v 6 \add مَاشَا\add* أَذُونِي-بَازَاقْ يَارْوڒْ ؤُشَا نِيثْنِي ضْفَارنْ ث ؤُشَا طّْفنْ ث ؤُشَا قسّنْ أَسْ إِمْزَاونْ \add ذ ثْفذْنِينْ ثِيمقّْرَانِينْ\add* زڭْ إِفَاسّنْ نّسْ ؤُ زڭْ إِضَارنْ نّسْ.  
\v 7 \add خنِّي\add* إِنَّا أَذُونِي-بَازَاقْ: ”سبْعِينْ ن إِجدْجِيذنْ، تّْوَاقسّنْ أَسنْ إِمْزَاونْ \add ذ ثْفذْنِينْ\add*، ثُوغَا ڒقّْضنْ \add إِڒقّْوَازْ\add* سَاذُو طَّابْڒَا إِنُو. مَامّشْ إِ كِيذْسنْ ڭِّيغْ، أَمُّو إِ ذ أَيِي إِخدْجصْ أَربِّي!“ إِوْينْ ث غَارْ ؤُرْشَالِيمْ ؤُشَا نتَّا إِمُّوثْ ذِينِّي.   
\m
\v 8 أَيْثْ ن يَاهُوذَا مّنْغنْ أَكْ-ذ ؤُرْشَالِيمْ ؤُشَا طّْفنْ ت، وْثِينْ ت س ڒقْضعْ ن سِّيفْ ؤُشَا قّذنْ ثَانْذِينْثْ س ثْمسِّي.   
\m
\v 9 أَوَارْنِي أَسْ هْوَانْ أَيْثْ ن يَاهُوذَا حِيمَا أَذْ مّنْغنْ أَكْ-ذ أَيْثْ ن كنْعَانْ، إِنِّي إِزدّْغنْ ذِي ثمُّورْثْ ن إِذُورَارْ، ذِي \add ثمُّورْثْ ن\add* لْجَانُوبْ ؤُ ذِي ثمُّورْثْ إِوَاطَانْ. \x ◘ \xo 1:‏9 \xt ياش. 10‏:‏36؛ 11‏:‏21؛ 15‏:‏13\x*   
\m
\v 10 إِفّغْ يَاهُوذَا غَارْ أَيْثْ ن كنْعَانْ إِ ثُوغَا إِزدّْغنْ ذِي حَابْرُونْ. إِسمْ ن حَابْرُونْ \add ثُوغَا\add* زِيشْ قَّارنْ أَسْ قَارْيَاثْ-أَرْبَاعْ. نِيثْنِيغڒْبنْ خْ شِيشَايْ ذ أَخِيمَانْ ذ ثَالْمَايْ. \x ◘ \xo 1:‏10 \xt ياش. 15‏:‏14\x*  
\v 11 سّنِّي إِفّغْ غَارْ إِمزْذَاغْ ن ذَابِيرْ. إِسمْ ن ذَابِيرْ \add ثُوغَا\add* زِيشْ قَّارنْ أَسْ قَارْيَاثْ-سَافَارْ. \x ◘ \xo 1:‏11 \xt ياش. 15‏:‏15‏-‏19.\x*  
\v 12 إِنَّا كَالِيبْ: ”ونِّي إِ غَا إِوْثنْ قَارْيَاثْ-سَافَارْ أَذْ ت إِطّفْ، أَذْ أَسْ وْشغْ يدْجِي أَخْسَا ذ ثَامْغَارْثْ.“  
\v 13 عُوثْنِييِيلْ، مِّيسْ ن قِينَازْ، ؤُمَاسْ أَمژْيَانْ ن كَالِيبْ، إِطّفْ إِ-ت. ؤُشَا كَالِيبْ إِوْشَا أَسْ يدْجِيسْ أَخْسَا ذ ثَامْغَارْثْ. \f ◼ \fr 1:‏13 \ft \+bd ’عُوثْنِييِيلْ‘\+bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَيْرَاذْ ن أَربِّي‘.\f*  
\v 14 إِمْسَارْ ؤُمِي \add غَارسْ\add* د-ثُوسَا نتَّاثْ، ثْعَارْنْ إِ-ث س ثُوثْرَا خْ ييَّارْ ن بَابَاسْ. ؤُشَا ثضْرَا خْ وغْيُوڒْ. إِسّقْسَا ت كَالِيبْ: ”مِينْ شمْ يُوغِينْ؟“ \x ◘ \xo 1:‏14 \xt ياش. 15‏:‏18\x*  
\v 15 نتَّاثْ ثَارَّا-د خَاسْ: ”أوْشْ أَيِي إِشْثْ ن لْبَارَاكَا، مِينْزِي ثوْشِيذْ أَيِي إِشْثْ ن ثْرقِّيعْثْ ن ثمُّورْثْ \add غَارْ\add* لْجَانُوبْ. تّْزَاوْڭغْ، أوْشْ أَيِي ؤُڒَا ذ ڒْعُونْصَارَاثْ!“ ؤُشَا إِوْشَا أَسْ كَالِيبْ ڒْعُونْصَارَاثْ ن نجْ ذ ڒْعُونْصَارَاثْ ن وَادَّايْ.   
\m
\v 16 ڭعّْذنْ أَرَّاوْ ن ؤُقِينِي، ونِّي ذ أَضڭْوَاڒْ ن مُوسَا، أَكْ-ذ أَيْثْ ن يَاهُوذَا زِي ثنْذِينْثْ ن ثْشجِّيرَا ن ثِينِي غَارْ ڒخْڒَا ن يَاهُوذَا نِّي \add إِدْجَانْ\add* ذِي \add ثمُّورْثْ ن\add* لْجَانُوبْ غَارْ عَارَاذْ. فّْغنْ نِيثْنِي، زدّْغنْ أَكْ-ذ ڒْڭنْسْ. \f ◼ \fr 1:‏16 \ft \+bd ’ثَانْذِينْثْ ن ثْشجِّيرَا ن ثِينِي‘\+bd* - أَقَا-ت ذ ثَانْذِينْثْ ن أَرِيحَا.\f*  
\v 17 إِرُوحْ يَاهُوذَا أَكْ-ذ ؤُمَاسْ شِيمْعُونْ ؤُشَاغڒْبنْ نِيثْنِي خْ أَيْثْ ن كنْعَانْ إِنِّي إِ ثُوغَا إِزدّْغنْ ذِي صَافَاثْ، حَارّْمنْ ثنْ قَاعْ ؤُشَا ثحَّانْ ثنْ ؤُشَا ڭِّينْ أَسْ إِ ثنْذِينْثْ \add نِّي\add* حُورْمَا.  
\v 18 إِطّفْ يَاهُوذَا ؤُڒَا ذ غَازَّا أَكْ-ذ ثمُّورْثْ نّسْ ذ أَشْقَالُونْ أَكْ-ذ ثمُّورْثْ نّسْ ذ عَاقْرُونْ أَكْ-ذ ثمُّورْثْ نّسْ.  
\v 19 سِيذِي ثُوغَا-ث أَكْ-ذ يَاهُوذَا أَڒَامِي يُوژّڒْ خْ \add إِمزْذَاغْ ن\add* ثمُّورْثْ ن إِذُورَارْ، مَاشَا \add إِمزْذَاغْ\add* ن ڒوْذَا ن ثغْزُورْثْ وَارْ إِزمَّارْ أَذْ خَاسنْ يَاژّڒْ \add زِي ثسْغَارْثْ نْسنْ\add*، مِينْزِي نِيثْنِي ثُوغَا غَارْسنْ إِكَارُّوثنْ ن ؤُمنْغِي ن وُوزَّاڒْ.  
\v 20 إِ كَالِيبْ وْشِينْ أَسْ حَابْرُونْ، أَمْ مَامّشْ ثُوغَا إِنَّا مُوسَا، ؤُشَا نتَّا يُوژّڒْ سّنِّي خْ ثْڒَاثَا ن إِحنْجِيرنْ ن عَانَاقْ.\x ◘ \xo 1:‏20 \xt ڒخْڒ. 14‏:‏24؛ ياش. 14‏:‏13\x*   
\b  
\m
\v 21 أَيْثْ ن بِينْيَامِينْ وَارْ زمَّارنْ أَذْ أَژّْڒنْ خْ إِيابُوسِييّنْ، إِنِّي إِزدّْغنْ ذِي ؤُرْشَالِيمْ. أَمُّو إِ قِّيمنْ إِيابُوسِييّنْ زدّْغنْ غَارْ أَيْثْ ن بِينْيَامِينْ ذِي ؤُرْشَالِيمْ، أَڒْ أَسّْ-أَ.   
\m
\v 22 ثَادَّارْثْ ن يُوسُوفْ ثْڭعّذْ غَارْ بَايْثْ-إِلْ ؤُشَا سِيذِي \add ثُوغَا-ث\add* أَكِيذْسنْ.  
\v 23 ثُويُورْ ثَادَّارْثْ ن يُوسُوفْ حِيمَا أَذْ ثْبرْڭَاڭْ غَارْ بَايْثْ-إِلْ. إِسمْ ن ثنْذِينْثْ \add ثُوغَا\add* زِيشْ قَّارنْ أَسْ لُوزْ. \x ◘ \xo 1:‏23 \xt أَمز. 28‏:‏19\x*  
\v 24 إِنِّي ثُوغَا إِڒبْثنْ \add إِ ثنْذِينْثْ\add*، ژْرِينْ إِجّْ ن ورْيَازْ إِفّغْ-د زِي ثنْذِينْثْ، نَّانْ أَسْ: ”سْشنْ أَنغْ مَانِيسْ نْزمَّارْ أَذْ نَاذفْ غَارْ ثنْذِينْثْ، خنِّي نشِّينْ أَذْ كِيكْ نڭّْ ثَامخْسِيوْثْ إِشوَّارنْ.“  
\v 25 \add خنِّي\add* إِسّْشنْ أَسنْ ثَاوَّارْثْ ن وَاذَافْ غَارْ ثنْذِينْثْ ؤُشَا نِيثْنِي وْثِينْ ثَانْذِينْثْ س إِشْثْ ن ثشْثِي س ڒقْضعْ ن سِّيفْ، \add مَاشَا\add* نِيثْنِي جِّينْ أَرْيَازْ نِّي أَذْ يُويُورْ أَكْ-ذ مَارَّا رَادْجْ نّسْ.  
\v 26 ؤُشَا يُويُورْ ورْيَازْ غَارْ ثمُّورْثْ ن إِحِيتِّييّنْ ؤُشَا إِبْنَا إِشْثْ ن ثنْذِينْثْ، إِڭَّا أَسْ إِسمْ لُوزْ. وَا ذ إِسمْ نّسْ أَڒْ أَسّْ-أَ.   
\m
\v 27 مَانَاسَّا وَارْ إِزمَّارْ أَذْ يَاژّڒْ خْ \add إِمزْذَاغْ\add* ن بَايْثْ-شَانْ ذ ثْندَّامْ إِ غَارسْ د-إِقّْننْ، ڒَا \add خْ إِمزْذَاغْ ن\add* ثَاعْنَاكْ أَكْ-ذ ثْندَّامْ نّسْ ڒَا خْ إِمزْذَاغْ ن ذُورْ ذ ثْندَّامْ نّسْ ڒَا خْ إِمزْذَاغْ ن يِيبْلَاعَامْ ذ ثْندَّامْ نّسْ ؤُڒَا خْ إِمزْذَاغْ ن مَاجِيدُّو ذ ثْندَّامْ نّسْ. ثُوغَا أَيْثْ ن كنْعَانْعوّْڒنْ أَذْ قِّيمنْ زدّْغنْ ذِي ثمُّورْثْ \add نِّي\add*. \x ◘ \xo 1:‏27 \xt ياش. 17‏:‏11، 12\x*  
\v 28 ثُوغَا إِسْرَائِيل إِذْوڒْ إِجْهذْ أَڒَامِي إِڭَّا لْجِيزْيَا خْ أَيْثْ ن كنْعَانْ، \add مَاشَا\add* وَارْ زمَّارنْ أَذْ خَاسنْ أَژّْڒنْ مَارَّا.   
\m
\v 29 \add ؤُڒَا ذ\add* إِفْرَايِيمْ وَارْ إِزمَّارْ أَذْ يَاژّڒْ خْ أَيْثْ ن كنْعَانْ إِ ثُوغَا إِزدّْغنْ ذِي جَازَارْ ؤُ قِّيمنْ أَيْثْ ن كنْعَانْ زدّْغنْ ذِي ڒْوسْطْ نْسنْ ذِي جَازَارْ. \x ◘ \xo 1:‏29 \xt ياش. 16‏:‏10\x*   
\m
\v 30 زابُولُونْ وَارْ إِزمَّارْ أَذْ يَاژّڒْ خْ إِمزْذَاغْ ن قِيطْرُونْ ذ إِمزْذَاغْ ن نَاهَالُولْ ؤُ قِّيمنْ أَيْثْ ن كنْعَانْ زدّْغنْ ذِي ڒْوسْطْ نْسنْ ؤُ ثتّْوَاڭّْ خَاسنْ لْجِيزْيَا.   
\m
\v 31 أَشِيرْ وَارْ إِزمَّارْ أَذْ يَاژّڒْ خْ إِمزْذَاغْ ن عَاكُّو ؤُڒَا خْ \add إِمزْذَاغْ\add* ن صِيذُونْ ذ أَحْلَابْ ذ أَكْزِيبْ ذ هَالْبَا ذ أَفِيقْ ذ رَاحُوبْ.  
\v 32 إِشِيرِييّنْ زدّْغنْ ذِي ڒْوسْطْ ن أَيْثْ ن كنْعَانْ، إِنِّي ذ إِمزْذَاغْ ن ثمُّورْثْ، مِينْزِي نِيثْنِي وَارْ زمَّارنْ أَذْ خَاسنْ أَژّْڒنْ. \f ◼ \fr 1:‏32 \ft \+bd ’إِشِيرِييّنْ‘\+bd* - إِخْسْ أَذْ يِينِي ’أَيْثْ ن أَشِيرْ‘.\f*   
\m
\v 33 نَافْثَالِي وَارْ إِزمَّارْ أَذْ يَاژّڒْ خْ إِمزْذَاغْ ن بَايْثْ-شَامْسْ ذ إِمزْذَاغْ ن بَايْثْ-عَانَاثْ. \add أَمُّو\add* إِ ثُوغَا إِزْذغْ ذِي ڒْوسْطْ ن أَيْثْ ن كنْعَانْ، إِنِّي ذ إِمزْذَاغْ ن ثمُّورْثْ. ثتّْوَاڭّْ خَاسنْ لْجِيزْيَا خْ إِمزْذَاغْ ن بَايْثْ-شَامْسْ ذ بَايْثْ-عَانَاثْ.   
\m
\v 34 إِمُورِييْ\add ينْ\add* حْصَارنْ أَيْثْ ن ذَانْ غَارْ إِذُورَارْ، مِينْزِي وَارْ ثنْ جِّينْ أَذْ هْوَانْ غَارْ ڒوْضَا ن ثغْزُورْثْ.  
\v 35 ثُوغَا إِمُورِييْ\add ينْ\add*عوّْڒنْ أَذْ قِّيمنْ زدّْغنْ ذڭْ إِذُورَارْ ن حَارَاسْ، ذِي أَيَالُونْ ؤُ ذِي شَاعَالْبِيمْ، \add مَاشَا\add* أَفُوسْ ن ثَادَّارْثْ ن يُوسُوفْ ثُوغَا إِزيَّارْ \add خَاسنْ\add* أَطَّاسْ \add أَڒَامِي خَاسنْ\add* ثتّْوَاڭّْ لْجِيزْيَا.  
\v 36 ثُوغَا أَيْمِيرْ ن إِمُورِييْ\add ينْ\add* زِي ثْسُونْثَا ن ثْغَارْضْمِيوِينْ، زِي جَّارْفْ ؤُشَا سّنِّي غَارْ سنّجْ.   
\b  
\b  
\m  
\c 2
\s1 لْمَالَاكْ ن سِيذِي ذِي بُوكِيمْ  
\m
\v 1 لْمَالَاكْ ن سِيذِي إِڭعّذْ زِي جِيلْجَالْ غَارْ بُوكِيمْ، إِنَّا: ”نشّْ سُّوفّْغغْ-د كنِّيوْ زِي مِيصْرَا ؤُشَا إِوْيغْ-د كنِّيوْ غَارْ ثمُّورْثْ نِّي خْ جُّودْجغْ إِ ڒجْذُوذْ نْومْ، نِّيغْ: ’نشّْعمَّارْصْ وَارْ تَّارژِّيغْ ڒْعَاهْذْ إِنُو أَكِيذْومْ إِ ڒبْذَا. \x ◘ \xo 2:‏1 \xt أَمز. 17‏:‏7؛ أَعَوذ. 29‏:‏13، 14\x*  
\v 2 ؤُشَا كنِّيوْ، وَارْ ذ أَومْ إِعدّڒْ أَذْ ثڭّمْ ؤُڒَا ذ إِجّْ ن ڒْعَاهْذْ أَكْ-ذ إِمزْذَاغْ ن ثمُّورْثْ-أَ، ؤُ إِتّْخصَّا أَومْ أَذْ ثْغضْڒمْ إِعَالْطَارنْ نْسنْ!‘ مَاشَا كنِّيوْ وَارْ ثسْڒِيمْ شَا إِ ثْمِيجَّا إِنُو. مَايمِّي ثڭِّيمْ أَيَا؟ \x ◘ \xo 2:‏2 \xt أَعَوذ. 7‏:‏2؛ 12‏:‏3\x*  
\v 3 ؤُ نشّْ نِّيغْ أَومْ عَاوذْ: ’أَقَا وَارْ خَاسنْ ثَاژّْڒغْ زَّاثْ إِ وُوذمْ نْومْ، مَاشَا نِيثْنِي أَذْ إِڒِينْ \add أَمْ إِسنَّاننْ\add* ذڭْ إِغزْذِيسنْ نْومْ ؤُشَا إِربِّيثنْ نْسنْ أَذْ أَومْ ذوْڒنْ ذ ڒْفخْ.‘ “ \x ◘ \xo 2:‏3 \xt ؤُف. 23‏:‏33؛ 34‏:‏12؛ أَعَوذ. 7‏:‏16؛ ياش. 23‏:‏13\x*  
\v 4 ؤُمِي لْمَالَاكْ ن سِيذِي ثُوغَا إِسِّيوڒْ أَوَاڒنْ-أَ غَارْ مَارَّا أَيْثْ ن إِسْرَائِيل، إِمْسَارْ، أَقَا ڒْڭنْسْ إِسّْڭعّذْ ثْمِيجَّا نّسْ ؤُشَا رُونْ نِيثْنِي.  
\v 5 نِيثْنِي قَّارنْ أَسْ إِ ومْشَانْ نِّي ’بُوكِيمْ‘ ؤُشَا نِيثْنِي قدّْمنْ ذِينْ ثَاغَارْصْثْ إِ سِيذِي. \f ◼ \fr 2:‏5 \ft \+bd ’بُوكِيمْ‘\+bd* - إِخْسْ أَذْ يِينِي ’إِنِّي إِتّْرُونْ‘.\f*   
\b  
\m  
\s1 أَوَارْنِي إِ ڒْموْثْ ن يَاشُووَا إِفّغْ أَيْثْ ن إِسْرَائِيل زڭْ وبْرِيذْ ن سِيذِي  
\m
\v 6 \add ؤُمِي\add* إِسّكّْ يَاشُووَا ڒْڭنْسْ، فّْغنْ أَيْثْ ن إِسْرَائِيل، \add كُوڒْ\add* أَرْيَازْ غَارْ ثسْغَارْثْ نّسْ، مَاحنْذْ أَذْ طّْفنْ ثَامُّورْثْ ذ ڒْوَارْثْ. \x ◘ \xo 2:‏6 \xt ياش. 24‏:‏28\x*  
\v 7 ثُوغَا ڒْڭنْسْ إِسخَّارْ إِ سِيذِي مَارَّا ؤُسَّانْ ن يَاشُووَا ذ مَارَّا ؤُسَّانْ ن إِمْغَارنْ، إِنِّي \add عَاذْ\add* إِقِّيمنْ دَّارنْ أَطَّاسْ أَوَارْنِي إِ يَاشُووَا ؤُ إِنِّي إِژْرِينْ مَارَّا ڒْخذْمثْ ثَامقّْرَانْثْ ن سِيذِي ثنِّي إِڭَّا إِ إِسْرَائِيل.  
\v 8 يَاشُووَا، مِّيسْ ن نُونْ، أَمْسخَّارْ ن سِيذِي، إِمُّوثْ \add أَمْ\add* إِجّْ ن بْنَاذمْ \add ذ بَابْ\add* ن مْيَا ؤُ -عشْرَا ن إِسڭّْوُوسَا.  
\v 9 نضْڒنْ ث ذَاخڒْ إِ ويْمِيرْ ن ثسْغَارْثْ نّسْ ذِي ثِيمْنَاثْ-حَارَاسْ، ذِي ثمُّورْثْ ن إِذُورَارْ ن إِفْرَايِيمْ، غَارْ ؤُغزْذِيسْ ن شَّامَالْ ن وذْرَارْ ن جَاعَاشْ.   
\m
\v 10 ؤُ عَاوذْ مَارَّا جِّيڒْ نِّي، أَقَا إِتّْوَاسّْمُونْ غَارْ ڒجْذُوذْ نْسنْ. أَوَارْنِي أَسنْ إِكَّارْ-د إِجّْ ن جِّيڒْ نّغْنِي، جِّيڒْ نِّي وَارْ إِسِّينْ شَا سِيذِي ؤُ وَارْ إِسِّينْ شَا ڒْخذْمثْ إِ إِڭَّا أَكْ-ذ إِسْرَائِيل.  
\v 11 \add خنِّي\add* ڭِّينْ أَيْثْ ن إِسْرَائِيل مِينْ ثُوغَا إِدْجَانْ ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي ؤُشَا سخَّارنْ إِ ’إِبَاعْلنْ‘  
\v 12 نِيثْنِي جِّينْ سِيذِي، أَربِّي ن ڒجْذُوذْ نْسنْ، ونِّي ثنْ د-إِسُّوفّْغنْ زِي مِيصْرَا ؤُشَا نِيثْنِي ضْفَارنْ إِربِّيثنْ نّغْنِي، إِربِّيثنْ ن ڒڭْنُوسْ إِ ذ أَسنْ-د إِنّْضنْ، ؤُشَا ؤُضَارنْ أَسنْ ؤُ \add أَمُّو إِ\add* سْعَارنْ سِيذِي.  
\v 13 مَاغَارْ نِيثْنِي جِّينْ سِيذِي ؤُشَا \add ذوْڒنْ\add* سخَّارنْ إِ بَاعَالْ ؤُ إِ ’عَاشْثَارُوثِينْ‘.  
\v 14 \add خْ ؤُيَا\add* يَارْغَا وغْضَابْ ن سِيذِي خْ إِسْرَائِيل. نتَّا إِڭَّا إِ-ثنْ ذڭْ ؤُفُوسْ ن إِشفَّارنْ إِ ثنْ إِكشّْضنْ ؤُ إِڭَّا إِ-ثنْ ذڭْ ؤُفُوسْ ن ڒْعذْيَانْ نْسنْ إِ ذ أَسنْ د-إِنّْضنْ ؤُشَا ذوْڒنْ وَارْ زمَّارنْ أَذْ \add قِّيمنْ\add* بدّنْ زَّاثْ إِ وُوذمْ ن ڒْعذْيَانْ نْسنْ. \x ◘ \xo 2:‏14 \xt إِزهد. 44‏:‏13؛ إِشا. 50‏:‏1\x*  
\v 15 مَانِي مَا فّْغنْ نِيثْنِي، ثُوغَا أَفُوسْ ن سِيذِي ضِيدّْ نْسنْ إِ ڒْغَارْ، أَمْ مَامّشْ ثُوغَا إِسِّيوڒْ سِيذِي ؤُ أَمْ مَامّشْ ثُوغَا إِ ذ أَسنْ إِجُّودْجْ سِيذِي. أَقَا تّْوَاحْصَارنْ أَڒْ أَنڭَّارْ. \x ◘ \xo 2:‏15 \xt لَاوِي 26؛ أَعَوذ. 28\x*   
\m
\v 16 \add مَاشَا\add* سِيذِي إِسّكَّارْ ڒْقُوضَاثْ، إِنِّي ثنْ إِسّْنجْمنْ زڭْ ؤُفُوسْ ن يِينِّي ثنْ إِكشّْضنْ.  
\v 17 نِيثْنِي وَارْ سْڒِينْ شَا ؤُڒَا غَارْ ڒْقُوضَاثْ نْسنْ، مَاشَا سّْفسْذنْ إِخفْ نْسنْ ؤُمِي ؤُيُورنْ أَوَارْنِي إِربِّيثنْ نّغْنِي ؤُشَا ؤُضَارنْ أَسنْ. ذغْيَا حيّْذنْ خْ وبْرِيذْ نِّي إِ ذِي ؤُيُورنْ ڒجْذُوذْ نْسنْ، إِنِّي ثُوغَا إِسْڒِينْ إِ ثْوصَّا ن سِيذِي. نِيثْنِي \add مَاشَا\add* وَارْ ڭِّينْ أَمنِّي!  
\v 18 ؤُمِي ذ أَسنْ د-إِسّكَّارْ سِيذِي ڒْقُوضَاثْ، ثُوغَا سِيذِي أَكْ-ذ ڒْقَاضِي ؤُشَا إِسّنْجمْ إِ-ثنْ زڭْ ؤُفُوسْ ن ڒْعذْيَانْ نْسنْ، مَارَّا ؤُسَّانْ ن ڒْقَاضِي نِّي، مَاغَارْ سِيذِي ثُوغَا إِنْذمْ زِي سِّيبّثْ ن إِغُويَّانْ نْسنْ زَّاثْ إِ وُوذمْ ن يِينِّي ثنْ إِحْصَارنْ ذ يِينِّي إِ خَاسنْ إِتَّاژّْڒنْ.  
\v 19 ؤُشَا إِمْسَارْ ؤُمِي إِمُّوثْ ڒْقَاضِي، \add أَقَا\add* نِيثْنِي ذوْڒنْ غَارْ ضفَّارْ ؤُشَا ذوْڒنْعفّْننْ كْثَارْ زڭْ ڒجْذُوذْ نْسنْ ؤُمِي ؤُيُورنْ أَوَارْنِي إِربِّيثنْ نّغْنِي، سخَّارنْ أَسنْ ؤُشَا بنْذْقنْ أَسنْ. نِيثْنِي وَارْ جِّينْ زِي ثْمڭَّا نْسنْ \add ثِيعفَّانِينْ\add* ؤُ زِي وبْرِيذْ نْسنْ \add إِ ثُوغَا ضفَّارنْ\add* س ثْغنَّانْثْ. \x ◘ \xo 2:‏19 \xt ڒقض. 3‏:‏12\x*  
\v 20 \add خنِّي\add* يَارْغَا وغْضَابْ ن سِيذِي خْ إِسْرَائِيل ؤُشَا نتَّا إِنَّا: ”مِينْزِي ڒْڭنْسْ-أَ إِعدَّا ڒْعَاهْذْ إِنُو مِينْ خفْ وصِّيغْ ڒجْذُوذْ نْسنْ ؤُ وَارْ سْڒِينْ إِ ثْمِيجَّا إِنُو،  
\v 21 ؤُڒَا ذ نشّْ وَارْ قِّيمغْ عَاذْ أَذْ أَژّْڒغْ زَّاثْ إِ وُوذمْ نْسنْ خْ ڒڭْنُوسْ نِّي إِجَّا يَاشُووَا، ؤُمِي إِمُّوثْ، \x ◘ \xo 2:‏21 \xt ياش. 23‏:‏13\x*  
\v 22 أَڒَامِي نشّْ أَذْ زَّايْسنْ قدْجْبغْ إِسْرَائِيل، مَا أَذْ حْضَانْ نِيثْنِي أَبْرِيذْ ن سِيذِي مَاحنْذْ أَذْ ذَايسْ ؤُيُورنْ أَمْ مَامّشْ ث حْضَانْ ڒجْذُوذْ نْسنْ، نِيغْ لَّا.“  
\v 23 ؤُشَا إِجَّا سِيذِي ڒڭْنُوسْ-أَ \add أَذْ أَريّْحنْ\add* ؤُشَا وَارْ خَاسنْ يُوژِّيڒْ ذغْيَا ؤُ \add عَاوذْ\add* نتَّا وَارْ ثنْ إِڭِّي ذڭْ ؤُفُوسْ ن يَاشُووَا.   
\b  
\b  
\m  
\c 3
\s1 إِسْرَائِيل جَارْ ڒڭْنُوسْ - ڒْقُوضَاثْ  
\m
\v 1 إِنَا ذ ڒڭْنُوسْ إِ إِجَّا سِيذِي \add أَذْ أَريّْحنْ\add*، حِيمَا أَذْ زَّايْسنْ إِقدْجبْ إِسْرَائِيل، \add إِخْسْ أَذْ يِينِي\add* مَارَّا إِنِّي وَارْ إِسِّيننْ شَا عَاذْ خْ مَارَّا ڭَارَّاثْ أَكْ-ذ كنْعَانْ،  
\v 2 مْغِيرْ حِيمَا أَذْ ذوْڒنْ جِّيڒَاثْ ن أَيْثْ ن إِسْرَائِيل أَذْ سّْننْ أَمنْغِي، حِيمَا أَذْ ڒمْذنْ أَذْ مّنْغنْ، مْغِيرْ إِنِّي وَارْ إِسِّيننْ شَا أَمنْغِي:  
\v 3 خمْسَا ن ڒْبَاشَاثْ \add ن ثْندَّامْ\add* ن أَيْثْ ن إِفِيلِيسْطِينِييّنْ ذ مَارَّا أَيْثْ ن كنْعَانْ ذ إِصِيذُونِييْ\add ينْ\add* ذ إِحِيوِييْ\add ينْ\add* إِ إِزدّْغنْ خْ إِذُورَارْ ن لُوبْنَانْ، زڭْ وذْرَارْ ن بَاعْلْ-هِيرْمُونْ أَڒْ مَانِي غَا ثِيوْضذْ غَارْ حَامَاثْ.  
\v 4 نِيثْنِي ثُوغَا أَثنْ \add ذِينْ\add* حِيمَا أَذْ زَّايْسنْ إِتّْوَاقدْجبْ إِسْرَائِيل، حِيمَا أَذْ يِيڒِي إِتّْوَاسّْننْ مَا نِيثْنِي أَذْ سْڒنْ إِ ثْوصَّا ن سِيذِي، ثِينِّي يُومُورْ نتَّا إِ ڒجْذُوذْ نْسنْ س ثْسخَّارْثْ ن مُوسَا.   
\m
\v 5 أَيْثْ ن إِسْرَائِيل ثُوغَا زدّْغنْ ذِي ڒْوسْطْ ن أَيْثْ ن كنْعَانْ: إِحِيتِّييْ\add ينْ\add* ذ إِمُورِييْ\add ينْ\add* ذ إِفِيرِيزِييْ\add ينْ\add* ذ إِحِيوِييْ\add ينْ\add* ذ إِيابُوسِييْ\add ينْ\add*.  
\v 6 نِيثْنِي إِوْينْ يسِّيثْسنْ ذ ثمْغَارِينْ نْسنْ إِ يِيخفْ نْسنْ ؤُ ثِيحنْجِيرِينْ نْسنْ وْشِينْ ثنْثْ إِ إِحنْجِيرنْ نْسنْ ؤُشَا نِيثْنِي \add بْذَانْ أَذْ\add* سخَّارنْ إِ إِربِّيثنْ نْسنْ. *   
\b  
\m
\v 7 ؤُشَا ڭِّينْ أَيْثْ ن إِسْرَائِيل مِينْ \add إِدْجَانْ\add* ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي، تُّونْ سِيذِي، أَربِّي نْسنْ، ؤُشَا ؤُيُورنْ أَذْ سخَّارنْ إِ ’إِبَاعْلنْ‘ ذ ثِيربِّينْ نْسنْ ن شْوَارْثِي.  
\v 8 \add خنِّي\add* يَارْغَا وغْضَابْ ن سِيذِي خْ إِسْرَائِيل ؤُ نتَّا إِوْشَا إِ-ثنْ ذڭْ ؤُفُوسْ ن كُوشَانْ-رِيشَاعْثَايِيمْ، أَجدْجِيذْ ن أَرَامْ-نَاهْرَايْنْ، \add أَقَا-ت ذ مِيسُوپُوثَامْيَا\add*. \add خنِّي\add* سخَّارنْ أَيْثْ ن إِسْرَائِيل ثْمنْيَا ن إِسڭّْوُوسَا إِ كُوشَانْ-رِيشَاعْثَايِيمْ.  
\v 9 سْغُويّنْ أَيْثْ ن إِسْرَائِيل غَارْ سِيذِي ؤُشَا سِيذِي إِڭَّا أَذْ إِكَّارْ إِجّْ ن ؤُمْسنْجمْ إِ أَيْثْ ن إِسْرَائِيل، ونِّي إِ ثنْ إِفكّنْ، \bd عُوثْنِييِيلْ\bd*، مِّيسْ ن قَانَازْ، ؤُمَاسْ ن كَالِيبْ، ونِّي ذ أَمژْيَانْ خَاسْ.  
\v 10 ثُوغَا خَاسْ أَرُّوحْ ن سِيذِي ؤُ ثُوغَا ذ ڒْقَاضِي خْ إِسْرَائِيل ؤُشَا إِفّغْ غَارْ ؤُمنْغِي. إِوْشَا أَسْ سِيذِي كُوشَانْ-رِيشَاعْثَايِيمْ، أَجدْجِيذْ ن أَرَامْ، ذڭْ ؤُفُوسْ نّسْ ؤُشَا إِغْڒبْ نتَّا خْ كُوشَانْ-رِيشَاعْثَايِيمْ.  
\v 11 ثَاريّحْ ثمُّورْثْ أَربْعِينْ ن إِسڭّْوُوسَا. \add خنِّي\add* إِمُّوثْ عُوثْنِييِيلْ، مِّيسْ ن قَانَازْ.   
\b  
\m
\v 12 أَيْثْ ن إِسْرَائِيل أَرْنِينْ أَذْ ڭّنْ مِينْ \add إِدْجَانْ\add* ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي. ؤُشَا سِيذِي إِڭَّا جّهْذْ ذِي عِيجْلُونْ، أَجدْجِيذْ ن مُوآبَ، ضِيدّْ إِ إِسْرَائِيل، مِينْزِي نِيثْنِي ڭِّينْ \add مِينْ إِدْجَانْ\add* ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي.  
\v 13 نتَّا إِسّْمُونْ غَارسْ أَيْثْ ن عَامُّونْ ؤُ ن عَامَالِيقْ ؤُشَا إِفّغْ، إِغْڒبْ خْ إِسْرَائِيل ؤُشَا نِيثْنِي طّْفنْ ثَانْذِينْثْ ن ثْشجِّيرَا ن ثِينِي. \f ◼ \fr 3:‏13 \ft \+bd ’ثَانْذِينْثْ ن ثْشجِّيرَا ن ثِينِي‘\+bd* - إِخْسْ أَذْ يِينِي ’أَرِيحَا‘.\f*  
\v 14 ثْمنْطَاشْ ن إِسڭّْوُوسَا ثُوغَا أَيْثْ ن إِسْرَائِيل تّْسخَّارنْ إِ عِيجْلُونْ، أَجدْجِيذْ ن مُوآبَ.   
\m
\v 15 \add خنِّي\add* سْغُوينْ أَيْثْ ن إِسْرَائِيل غَارْ سِيذِي ؤُشَا سِيذِي إِڭَّا أَذْ د-إِكَّارْ إِجّْ ن ؤُمْسنْجمْ، \bd إِهُوذْ\bd*، مِّيسْ ن جِيرَا، \add زِي ثقْبِيتْشْ\add* ن بِينْيَامِينْ، إِجّْ ن ورْيَازْ إِ وَارْ إِتّْوَاذَارّبْ مْلِيحْ س ؤُفُوسِي نّسْ أَفُوسِي. ؤُشَا أَيْثْ ن إِسْرَائِيل سّكّنْ ث حِيمَا أَذْ وْشنْ إِشْثْ ن ثرْزفْثْ إِ عِيجْلُونْ، أَجدْجِيذْ ن مُوآبَ، س ؤُفُوسْ نّسْ.  
\v 16 إِهُوذْ إِڭَّا إِ يِيخفْ نّسْ إِجّْ ن سِّيفْ غَارسْ ثْنَاينْ ن ڒقْذُوعْ، ثُوزّڭَّارْثْ نّسْ أَنشْثْ ن إِجّْ ن ؤُغِيڒْ، إِقّنْ إِ-ث سَاذُو وَارُّوضْ نّسْ غَارْ ثْمصَّاضْثْ نّسْ ثَافُوسشْثْ.  
\v 17 أَمُّو إِ د-إِقَارّبْ س ثرْزفْثْ غَارْ عِيجْلُونْ، أَجدْجِيذْ ن أَيْثْ ن مُوآبَ، عِيجْلُونْ ثُوغَا ذ أَرْيَازْ إِصحّْ أَطَّاسْ.  
\v 18 ؤُمِي ثُوغَا إِهُوذْ إِكمّڒْ ثِيموْشَا ن ثَارْزفْثْ، إِمْسَارْ، أَقَا إِسّْقبّضْ إِوْذَانْ إِ ثُوغَا يَاربُّونْ ثَارْزفْثْ \add غَارْ ڒَاڭّْوَاجْ\add*،  
\v 19 مَاشَا نتَّا سِيمَانْثْ نّسْ إِعْقبْ \add أَوَارْنِي مَانْ أَيَا\add* زِي ڒخْيَاڒْ إِنقْشنْ \add إِ ذِينْ إِدْجَانْ\add* ذِي جِيلْجَالْ، إِنَّا: ”نشّْ غَارِي إِجّْ ن سِّيرْ خَاكْ، أَجدْجِيذْ!“ ؤُشَا وَا إِنَّا: ”سْقَارمْ!“ مَارَّا وِي ثُوغَا إِبدّنْ غَارسْ، فّْغنْ زِي غَارسْ \add غَارْ بَارَّا\add*.   
\m
\v 20 يُوسَا-د غَارسْ إِهُوذْ ؤُمِي عِيجْلُونْ إِقِّيمْ ذڭْ وخَّامْ ن نّجْ أَسمَّاضْ، ونِّي ثُوغَا إِ نتَّا وَاهَا. \add خنِّي\add* إِنَّا إِهُوذْ: ”نشّْ غَارِي إِجّْ ن وَاوَاڒْ ن أَربِّي إِ شكْ.“ ؤُشَا إِكَّارْ \add ؤُجدْجِيذْ\add* زِي ڒْكُورْسِي نّسْ إِڭلّْذنْ.  
\v 21 \add خنِّي\add* إِسّْوِيژّضْ إِهُوذْ س ؤُفُوسْ نّسْ أَزڒْمَاضْ، إِجْبذْ-د سِّيفْ نِّي خْ ثْمصَّاضْثْ نّسْ ثَافُوسشْثْ، إِشُوكّْ إِ-ث ذڭْ ؤُعذِّيسْ نّسْ،  
\v 22 أَڒَامِي يُوذفْ س ؤُفُوسْ نِّي أَوَارْنِي إِ ڒْمُوسْ ن سِّيفْ ؤُشَا ثَاذُونْثْ ثْبلّعْ-د خْ ڒْمُوسْ، مَاغَارْ نتَّا وَارْ إِكِّيسْ سِّيفْ زڭْ ؤُعذِّيسْ نّسْ. \add خَاسْ ؤُشَا\add* إِفّغْ س وبْرِيذْ ن وخَّامْ ن يِيضصْ.  
\v 23 \add خنِّي\add* إِفّغْ إِهُوذْ زڭْ وُوفُّوغْ \add ن وخَّامْ ن وسْقِيفْ\add*. إِبلّعْ ثِيوُّورَا ن وخَّامْ ن نّجْ أَوَارْنِي أَسْ ؤُ يَارَّا زّكْرُونْ.   
\m
\v 24 \add ؤُمِي\add* يُويُورْ نتَّا، ؤُسِينْ-د إِمْسخَّارنْ نّسْ ؤُشَا ؤُمِي ژْرِينْ أَقَا ثِيوُّورَا ن وخَّامْ ن نّجْ تّْوَابلّْعنْثْ س زّكْرُونْ، نَّانْ: ”نتَّا أَقَا إِذْڒَا \add وَاهَا\add* إِضَارنْ نّسْ ذڭْ وخَّامْ أَسمَّاضْ ن ذَاخڒْ.“  
\v 25 نِيثْنِي قِّيمنْ تّْرَاجَانْ أَڒَامِي ذوْڒنْ سّصْحَانْ، ؤُ خْزَارْ، نتَّا وَارْ يَارْزِيمْ شَا ثِيوُّورَا ن وخَّامْ ن نّجْ. نِيثْنِي كْسِينْ سَّارُوثْ، أَرْزْمنْ ثَاوَّارْثْ، ؤُشَا خْزَارْ، إِمّنْضَارْ سِيذِيثْسنْ غَارْ ثمُّورْثْ إِمُّوثْ.   
\m
\v 26 إِهُوذْ \add مَاشَا\add* ثُوغَا يَارْوڒْ، أَمْ ثُوغَا تّْرَاجَانْ نِيثْنِي. نتَّا ثُوغَا إِكَّا خْ ڒخْيَاڒْ إِنقْشنْ ؤُشَا يَارْوڒْ غَارْ سِيعِيرَاثْ.  
\v 27 ڒَامِي د-يِيوضْ نتَّا \add ذِينِّي\add*، إِسُوضْ ذڭْ ؤُيِيشّْ ن إِشَارِّي خْ إِذُورَارْ ن إِفْرَايِيمْ. \add خنِّي\add* هْوَانْ أَيْثْ ن إِسْرَائِيل أَكِيذسْ زڭْ وذْرَارْ ؤُ نتَّا سِيمَانْثْ نّسْ \add يُويُورْ\add* زَّاثْ إِ وُوذمْ نْسنْ.  
\v 28 نتَّا إِنَّا أَسنْ: ”ضْفَارمْ أَيِي-د، مِينْزِي سِيذِي إِوْشَا أَومْ ڒْعذْيَانْ نْومْ، أَيْثْ ن مُوآبَ، ذڭْ ؤُفُوسْ نْومْ.“ ؤُشَا نِيثْنِي ضْفَارنْ ث ؤُشَا طّْفنْ إِمُوشَانْ ن ؤُژكّْوُو ن لْ-ؤُرْذُونْ غَارْ مُوآبَ ؤُشَا وَارْ جِّينْ ؤُڒَا ذ إِجّْ أَذْ إِژْوَا.  
\v 29 ذِي ڒْوقْثْ نِّي وْثِينْ نِيثْنِي أَيْثْ ن مُوآبَ، عْڒَاحَاڒْ ثنْعَاشْ-أَڒفْ ن يرْيَازنْ، مَارَّا نِيثْنِي جهْذنْ، إِعسْكَارِييّنْ، ؤُڒَا ذ إِجّْ ن ورْيَازْ وَارْ إِنْجِيمْ.  
\v 30 \add أَمُّو\add* إِتّْوَاسّْذدْجْ مُوآبَ ذڭْ وَاسّْ نِّي سَاذُو ؤُفُوسْ ن إِسْرَائِيل ؤُشَا ثَاريّحْ ثمُّورْثْ ثْمنْيِينْ ن إِسڭّْوُوسَا.   
\b  
\m
\v 31 أَوَارْنِي أَسْ يُوسَا-د \bd شَامْجَارْ\bd*، مِّيسْ ن عَانَاثْ، ونِّي إِنْغِينْ ستَّا-مْيَا ن يرْيَازنْ زڭْ إِفِيلِيسْطِينِييّنْ س يِيجّْ ن ڒْمَاشَامْ ن إِفُونَاسنْ. \add أَمُّو\add* إِسّنْجمْ ؤُڒَا ذ \bd نتَّا\bd* إِسْرَائِيل.   
\b  
\b  
\m  
\c 4
\s1 أَغلّبْ ن بَارَاقْ ذ ذَاپُورَا  
\m
\v 1 ؤُمِي ثُوغَا إِهُوذْ إِمُّوثْ، أَرْنِينْ أَيْثْ ن إِسْرَائِيل أَذْ ڭّنْ مِينْ \add إِدْجَانْ\add* ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي.  
\v 2 سِيذِي إِڭَّا إِ-ثنْ سِيذِي ذڭْ ؤُفُوسْ ن يَابِينْ، أَجدْجِيذْ ن أَيْثْ ن كنْعَانْ، ونِّي ثُوغَا إِحكّمْ ذِي حَاصُورْ. ثُوغَا سِيسَارَا ذ أَكُومَانْذَارْ ن ڒْعسْكَارْ نّسْ. وَا ثُوغَا إِزدّْغنْ ذِي هَارُوشِيثْ-هَا-خُويِيمْ. \x ◘ \xo 4:‏2 \xt 1 صم. 12‏:‏9\x*  
\v 3 \add خنِّي\add* سْغُوينْ أَيْثْ ن إِسْرَائِيل إِ سِيذِي، مَاغَارْ سِيسَارَا غَارسْ ثسْعَا-مْيَا ن إِكَارُّوثنْ ن ؤُزَّاڒْ إِ ؤُمنْغِي ؤُ نتَّا ثُوغَا إِسّْذدْجْ أَيْثْ ن إِسْرَائِيل س لْعُونْفْ \add ڒْْمِيجَاڒْ ن\add* عِيشْرِينْ ن إِسڭّْوُوسَا.  
\v 4 ثُوغَا \bd ذابُورَا\bd*، ثَانَابِيثْ، إِشْثْ ن ثمْغَارْثْ س أَرُّوحْ أَمْ ثْمسِّي، ثحْكمْ إِسْرَائِيل ذِي ڒْوقْثْ نِّي.  
\v 5 \bd نتَّاثْ\bd* ثُوغَا ثقِّيمْ \add خْ ڒْكُورْسِي ن ڒْحُوكْمْ\add* سْوَادَّايْ إِ ثْشجَّارْثْ ن ثِينِي ن ذابُورَا، جَارْ رَامَا ذ بَايْثْ-إِلْ، خْ إِذُورَارْ ن إِفْرَايِيمْ، ؤُشَا أَيْثْ ن إِسْرَائِيل ڭعّْذنْ غَارسْ مَاحنْذْ أَذْ أَسْ أَوْينْ دّعْوَاثْ \add نْسنْ\add*.  
\v 6 نتَّاثْ ثسّكّْ، ثْڒَاغَا إِ \bd بَارَاقْ\bd*، مِّيسْ ن أَبِينُوعَامْ زِي قَاذَاشْ ذِي نَافْثَالِي، ثنَّا أَسْ: ”مَا وَارْ يُومُورْ سِيذِي، أَربِّي ن إِسْرَائِيل: ’ؤُيُورْ، فّغْ غَارْ وذْرَارْ ن ثابُورْ ؤُ ثَاوْيذْ أَكِيذكْعشْرَا أَڒفْ ن يرْيَازنْ زڭْ أَيْثْ ن نَافْثَالِي ؤُ زڭْ أَيْثْ ن زابُولُونْ! \x ◘ \xo 4:‏6 \xt عبر. 11‏:‏32\x*  
\v 7 غَارْ ثغْزَارْثْ ن قِيشُونْ نشّْ أَذْ غَاركْ نذْهغْ سِيسَارَا، أَكُومَانْذَارْ ن ڒْعسْكَارْ ن يَابِينْ، أَكْ-ذ إِكَارُّوثنْ نّسْ ذ ؤُبَارُّو نّسْ \add ن يرْيَازنْ\add* ؤُشَا أَذْ أَشْ ث-إِ-د-وْشغْ ذڭْ إِفَاسّنْ نّشْ!‘ “ \x ◘ \xo 4:‏7 \xt إِزهد. 83‏:‏10\x*  
\v 8 بَارَاقْ إِنَّا أَسْ: ”مَاڒَا شمْ ثُويُورذْ أَكِيذِي، أَذْ ؤُيُورغْ، \add مَاشَا\add* مَاڒَا شمْ وَارْ كِيذِي ثُويُورذْ، وَارْ ڭُّورغْ.“  
\v 9 نتَّاثْ ثنَّا: ”نشّْ أَذْ كِيكْ ؤُيُورغْ نِيشَانْ، مْغِيرْ وَارْ ذ أَشْ إِتِّيڒِي شَّانْ ذڭْ وبْرِيذْ إِ غَا ثُويُورذْ، مِينْزِي سِيذِي أَذْ إِزّنْزْ سِيسَارَا غَارْ ؤُفُوسْ ن إِشْثْ ثمْغَارْثْ.“ \add خنِّي\add* ثكَّارْ ذابُورَا ؤُشَا ثُويُورْ أَكْ-ذ بَارَاقْ غَارْ قَاذَاشْ.  
\v 10 \add خنِّي\add* بَارَاقْ إِڒَاغَا-د إِ زابُولُونْ ذ نَافْثَالِي غَارْ قَاذَاشْ ؤُشَا إِڭعّذْ خْ إِضَارنْ أَكْ-ذعشْرَا-أَڒَافْ ن يرْيَازنْ ؤُشَا ؤُڒَا ذ ذابُورَا ثُويُورْ أَكِيذسْ.   
\m
\v 11 حَابِيرْ، أَقِينِي، ونِّي ثُوغَا إِتّْنجْڒَا خْ قَايِينْ، نتَّا \add ذ إِجّْ ن\add* زڭْ أَيْثْ ن حُوبَابْ، أَضڭّْوَاڒْ ن مُوسَا. أَقَا إِوْثَا إِقِيضَانْ نّسْ غَارْ ثْشجَّارْثْ ن يِيڭّْ ذِي صَاعَانَايِيمْ نِّي \add إِدْجَانْ\add* غَارْ قَاذَاشْ. \x ◘ \xo 4:‏11 \xt ڒخْڒ. 10‏:‏29\x*  *   
\b  
\m
\v 12 خبَّارنْ إِ سِيسَارَا، أَقَا بَارَاقْ، مِّيسْ ن أَبِينُوعَامْ، إِڭعّذْ غَارْ وذْرَارْ ن ثابُورْ.  
\v 13 \add خنِّي\add* إِسّْمُونْ-د سِيسَارَا مَارَّا إِكَارُّوثنْ نّسْ، ثسْعَا-مْيَا ن إِكَارُّوثنْ ن وُوزَّاڒْ، ذ مَارَّا ڒْڭنْسْ إِ ثُوغَا غَارسْ إِدْجَانْ، زِي حَارُوشَاثْ-هَا-خُويِيمْ أَڒْ ثغْزَارْثْ ن قِيشُونْ.   
\m
\v 14 ؤُشَا ثنَّا ذابُورَا إِ بَارَاقْ: ”كَّارْ، مِينْزِي وَا ذ أَسّْ إِ ذِي إِوْشَا سِيذِي سِيسَارَا ذڭْ ؤُفُوسْ نّشْ. مَا وَارْ د-إِتّفّغْ سِيذِي \add سِيمَانْثْ نّسْ\add* غَارْ زَّاثْ إِ شكْ!“ \add خنِّي\add* إِهْوَا-د بَارَاقْ زڭْ وذْرَارْ ن ثابُورْ ؤُعشْرَا-أَڒَافْ ن يرْيَازنْ ضْفَارنْ ث.  
\v 15 سِيذِي يَاژّڒْ خْ سِيسَارَا ؤُ خْ مَارَّا إِكَارُّوثنْ نّسْ ؤُ خْ مَارَّا ڒْعسْكَارْ نّسْ س ڒقْضعْ ن سِّيفْ زَّاثْ إِ وُوذمْ ن بَارَاقْ، \add أَڒَامِي\add* إِضْرَا خْ ؤُكَارُّو، يَارْوڒْ خْ إِضَارنْ. \x ◘ \xo 4:‏15 \xt إِزهد. 83‏:‏10\x*  
\v 16 ؤُشَا بَارَاقْ إِضْفَارْ إِكَارُّوثنْ ذ ڒْعسْكَارْ أَڒْ حَارُوشَاثْ-هَا-خُويِيمْ. مَارَّا ڒْعسْكَارْ ن سِيسَارَا إِوْضَا س ڒقْضعْ ن سِّيفْ، أَڒَامِي وَارْ إِقِّيمْ ؤُڒَا ذ إِجّْ.   
\m
\v 17 سِيسَارَا يَارْوڒْ خْ إِضَارنْ غَارْ ؤُقِيضُونْ ن يَاعِيلْ، ثَامْغَارْثْ ن حَابِيرْ، أَقِينِي، مَاغَارْ ثُوغَا ڒهْنَا جَارْ يَابِينْ، أَجدْجِيذْ ن حَاصُورْ ذ ثَادَّارْثْ ن حَابِيرْ، أَقِينِي.  
\v 18 يَاعِيلْ ثفّغْ غَارْ سِيسَارَا، ثنَّا أَسْ: ”أجّْ أَبْرِيذْ، \add أَ\add* سِيذِي إِنُو، أجّْ أَبْرِيذْ غَارِي، وَارْ تّڭّْوذْ!“ ؤُشَا نتَّا إِفّغْ \add زڭْ وبْرِيذْ\add*، \add يُويُورْ\add* غَارسْ غَارْ ؤُقِيضُونْ ؤُشَا نتَّاثْ ثذْڒَا إِ-ث س إِشْثْ ن ثْمَالْثَاثْ.  
\v 19 نتَّا إِنَّا أَسْ: ”أوْشْ أَيِي أَمَانْ أَذْ سْوغْ، نشّْ ذَايِي أَفَاذِي!“ نتَّاثْ ثَارْزمْ إِشْثْ ن ثْخَانْشثْ ن ؤُغِي ؤُ ثوْشَا أَسْ أَذْ إِسُو، خنِّي ثذْڒَا إِ-ث \add ثْوَاڒَاثْ نّغْنِيثْ\add*. \x ◘ \xo 4:‏19 \xt ڒقض. 5‏:‏25\x*  
\v 20 \add خنِّي\add* إِنَّا أَسْ عَاوذْ: ”بدّْ غَارْ ثوَّارْثْ ن ؤُقِيضُونْ ؤُشَا مَاڒَا يُوسَا-د إِجّنْ إِسّقْسَا \add شمْ\add*، إِقَّارْ: ’مَا ذَا شَا ن إِجّْ؟‘، خنِّي أَرّْ خَاسْ: ’ؤُڒَا ذ إِجّْ!‘ “  
\v 21 ثطّفْ يَاعِيلْ، ثَامْغَارْثْ ن حَابِيرْ، إِجّْ ن ڒوْثذْ ن ؤُقِيضُونْ ؤُشَا ثكْسِي إِجّْ ن وفْضِيسْ ذڭْ ؤُفُوسْ نّسْ ؤُشَا ثُوذفْ غَارسْ نْهْڒَا ڒْحسّْ ؤُشَا ثوْثَا أَسْ ڒوْثذْ ذڭْ ؤُغزْذِيسْ \add ن ؤُزدْجِيفْ\add* نّسْ أَڒَامِي يِيوضْ \add ڒوْثذْ\add* غَارْ ثمُّورْثْ. ثُوغَا نتَّا يُودْجغْ ذڭْ يِيضصْ س ڒْوحْڒَانْ، ؤُشَا \add أَمُّو إِ\add* إِمُّوثْ.   
\m
\v 22 ؤُ خْزَارْ، بَارَاقْ ثُوغَا إِضفَّارْ سِيسَارَا ؤُشَا ثفّغْ يَاعِيلْ، ثْرُوحْ أَذْ كِيسْ ثمّڒْقَا، ثنَّا أَسْ: ”أَسْ-د، أَذْ أَشْ سّشْنغْ أَرْيَازْ ونِّي خْ ثَارزُّوذْ!“ نتَّا يُوذفْ أَكِيذسْ ؤُشَا أَقَا سِيسَارَا إِتَّازّڒْ \add خْ ثمُّورْثْ\add* ؤُ ڒوْثذْ ذِي لْحنْكْ \add ن ؤُزدْجِيفْ\add* نّسْ.  
\v 23 أَمُّو إِ إِذدْجْ سِيذِي يَابِينْ، أَجدْجِيذْ ن كنْعَانْ، زَّاثْ إِ وُوذمْ ن أَيْثْ ن إِسْرَائِيل ذڭْ وَاسّْ نِّي.  
\v 24 أَفُوسْ ن أَيْثْ ن إِسْرَائِيل يَارنِّي أَذْ إِطّفْ ؤُشَا إِذْقڒْ أَطَّاسْ خْ يَابِينْ، أَجدْجِيذْ ن كنْعَانْ، أَڒَامِي ثُوغَا ثحَّانْ يَابِينْ، أَجدْجِيذْ ن كنْعَانْ.   
\b  
\b  
\m  
\c 5
\s1 إِزْڒِي ن ؤُغلّبْ ن ذَاپُورَا ذ بَارَاقْ  
\m
\v 1 ذڭْ وَاسّْ نِّيغنّْجنْ ذابُورَا ذ بَارَاقْ، مِّيسْ ن أَبِينُوعَامْ، نَّانْ:   
\b  
\m
\v 2 \qt ”بَارْكمْ سِيذِي إِ إِجطَّاينْ\qt*  
\m \qt ن ؤُشُوَّافْ إِتّْوَافسّْينْ ذِي إِسْرَائِيل\qt*،  
\m \qt س ؤُطوّعْ ن ڒْڭنْسْ س ڒْخَاضَارْ!\qt*   
\m
\v 3 \qt سْڒمْ، \+tl كنِّيوْ،\+tl* إِجدْجِيذنْ،\qt*  
\m \qt سْحسّمْ، \+tl كنِّيوْ،\+tl* أَيْثْ ن جّهْذْ!\qt*  
\m \qt نشّْ أَذْغنّْجغْ إِزْڒَانْ إِ سِيذِي،\qt*  
\m \qt نشّْ أَذْ زهّْذغْ إِ سِيذِي، أَربِّي ن إِسْرَائِيل.\qt*   
\b  
\m
\v 4 \qt \+tl أَ\+tl* سِيذِي، ؤُمِي شكْ د-ثفّْغذْ زِي سَاعِيرْ،\qt*  
\m \qt ؤُمِي شكْ ثُوغَا ثڭُّورذْ زڭْ إِيَّارْ ن إِذُومْ،\qt*  
\m \qt ثنْهزّْ ثمُّورْثْ، يَارْجِيجْ ؤُجنَّا،\qt*  
\m \qt \+tl وَاهْ،\+tl* ؤُڒَا ذ إِسيْنُوثنْ فَارّْغنْ-د س وَامَانْ.\qt* \x ◘ \xo 5:‏4 \xt إِزهد. 68‏:‏8، 9\x*   
\m
\v 5 \qt إِذُورَارْ فسْينْ زَّاثْ إِ وُوذمْ ن سِيذِي،\qt*  
\m \qt أَذْرَارْ نِّي ن سِينَا، \+tl إِفْسِي\+tl*\qt*  
\m \qt زَّاثْ إِ وُوذمْ ن سِيذِي، أَربِّي ن إِسْرَائِيل.\qt* \x ◘ \xo 5:‏5 \xt ؤُف. 19‏:‏18؛ إِزهد. 68‏:‏15، 16، 17؛ 97‏:‏5\x*   
\m
\v 6 \qt ذڭْ وُوسَّانْ ن شَامْجَارْ، مِّيسْ ن عَانَاثْ،\qt*  
\m \qt ذڭْ وُوسَّانْ ن يَاعِيلْ، قِّيمنْ إِبْرِيذنْ خْڒَانْ،\qt*  
\m \qt ؤُ إِنِّي ثُوغَا إِڭُّورنْ خْ ثبْرِيذِينْ،\qt*  
\m \qt تّكّنْ إِمسْرَاقْ إِعَارّْقنْ.\qt*   
\m
\v 7 \qt إِمْجَاهذنْ وَارْ قِّيمنْ،\qt*  
\m \qt وَارْ قِّيمنْ ذِي إِسْرَائِيل،\qt*  
\m \qt أَڒَامِي كَّارغْ نشّْ، ذابُورَا،\qt*  
\m \qt أَڒَامِي كَّارغْ نشّْ، يمَّاسْ ن إِسْرَائِيل.\qt*   
\m
\v 8 \qt ؤُمِي إِفَارْزْ \+tl ڒْْڭنْسْ\+tl* إِربِّيثنْ نّغْنِي،\qt*  
\m \qt \+tl خنِّي\+tl* ثُوغَا ذِينْ إِجّْ ن ؤُمنْغِي إِنقّنْ\qt*  
\m \qt غَارْ ثوُّورَا.\qt*  
\m \qt ثَاسدَّارْثْ ن ؤُعسْكَارْ ذ ؤُحْرِيشْ،\qt*  
\m \qt وَارْ إِتّْوَاژْرِي عَاذْ جَارْ أَربْعَا-أَڒَافْ\qt*  
\m \qt ذِي إِسْرَائِيل!\qt*   
\m
\v 9 \qt ؤُڒْ إِنُو أَكْ-ذ إِمْڭوَّاذنْ ن إِسْرَائِيل،\qt*  
\m \qt إِنِّي إِطوّْعنْ إِخفْ نْسنْ جَارْ ڒْڭنْسْ س ڒْخَاضَارْ،\qt*  
\m \qt لْبَارَاكَا إِ سِيذِي!\qt*   
\m
\v 10 \qt \+tl أَ كنِّيوْ\+tl*، إِنِّي إِنَّاينْ\qt*  
\m \qt خْ ثغْيَاڒْ ذ ثِيشمْڒَاڒِينْ،\qt*  
\m \qt \+tl كنِّيوْ\+tl* إِنِّي إِتّْغِيمَانْ خْ ثْزَارْبِييِّينْ\qt*  
\m \qt ذ \+tl كنِّيوْ\+tl* إِنِّي إِڭُّورنْ ذڭْ وبْرِيذْ،\qt*  
\m \qt سِيوْڒمْ \+tl خْ مَانْ أَيَا\+tl*!\qt*   
\m
\v 11 \qt س ثْمِيجَّا ن إِمْجبَّاذنْ نْ ڒْقوْسْ\qt*  
\m \qt إِ ذِينْ جَارْ وَانُوثنْ،\qt*  
\m \qt أَقَا إِتّْوَاسڒْ وَاوَاڒْ\qt*  
\m \qt خْ ثْمڭَّا إِسڭّْذنْ ن سِيذِي،\qt*  
\m \qt ثِيمڭَّا إِسڭّْذنْ ن ؤُمْجَاهَاذْ ن إِسْرَائِيل.\qt*  
\m \qt \+tl خنِّي\+tl* إِهْوَا-د ڒْڭنْسْ ن سِيذِي\qt*  
\m \qt غَارْ ثوُّورَا \+tl ن ثنْذِينْثْ\+tl*.\qt*   
\b  
\m
\v 12 \qt حْضَاثْ، حْضَاثْ، ذابُورَا،\qt*  
\m \qt حْضَاثْ، حْضَاثْ، سِيوڒْ س يِيجّْ ن إِزْڒِي!\qt*  
\m \qt كَّارْ، بَارَاقْ، أَوِي إِمحْبَاسْ نّشْ،\qt*  
\m \qt أَ شكْ، مِّيسْ ن أَبِينُوعَامْ!\qt*   
\m
\v 13 \qt خنِّي إِهْوَا \+tl كُوڒْ\+tl* وِي يَاروْڒنْ\qt*  
\m \qt غَارْ أَيْثْ ن جّهْذْ ن ڒْڭنْسْ،\qt*  
\m \qt سِيذِي إِهْوَا-د غَارِي أَكْ-ذ أَيْثْ ن بُو-ثغْرُوضْثْ.\qt*   
\m
\v 14 \qt زڭْ إِفْرَايِيمْ ؤُسِينْ-د\qt*  
\m \qt \+tl إِنِّي\+tl* أَژْوَارْ نْسنْ ذِي عَامَالِيقْ\qt*  
\m \qt ؤُ أَوَارْنِي أَشْ يُويُورْ بِينْيَامِينْ\qt*  
\m \qt جَارْ \+tl ڒْْعسْكَارَاثْ ن\+tl* يوْذَانْ نّشْ.\qt*  
\m \qt زِي مَاخِيرْ هْوَانْ إِمْڭوَّاذنْ،\qt*  
\m \qt ؤُ زِي زابُولُونْ إِنِّي إِطّْفنْ\qt*  
\m \qt أَعكَّازْ ن ونِّي إِحسّْبنْ.\qt*   
\m
\v 15 \qt ڒْْحُوكَّامْ ن إِسَّاكَارْ \+tl هْوَانْ-د\+tl* أَكْ-ذ ذابُورَا،\qt*  
\m \qt ؤُشَا أَمْ مَامّشْ \+tl إِتّْوَاسّكّْ\+tl* إِسَّاخَارْ،\qt*  
\m \qt أَمُّو إِ إِتّْوَاسّكّْ ؤُڒَا ذ بَارَاقْ\qt*  
\m \qt ذِي ڒوْضَا ن ثغْزُورْثْ.\qt*  
\m \qt ذِي ڒصْفُوفْ ن رُوبِينْ\qt*  
\m \qt ثُوغَا إِخَارِّيصنْ ن وُوڒْ ذ أَطَّاسْ.\qt*   
\m
\v 16 \qt مَايمِّي ثقِّيمذْ جَارْ إِغنْذِيفنْ،\qt*  
\m \qt ثسّْحسّذْ غَارْ وسْبُوعْرِييْ ن ثْحِيمْرِيوِينْ؟\qt*  
\m \qt ذِي ڒصْفُوفْ ن رُوبِينْ\qt*  
\m \qt ڭِّينْ أَذْ بقّْشنْذڭْ وُوڒْ أَطَّاسْ.\qt*   
\m
\v 17 \qt جِيلْعَاذْ إِقِّيمْ إِزدّغْ\qt*  
\m \qt خْ ؤُجمَّاضْ ن لْ-ؤُرْذُونْ\qt*  
\m \qt ؤُ مَايمِّي إِقِّيمْ ذَانْ غَارْ ثْغَارُّوبَا؟\qt*  
\m \qt أَشِيرْ إِقِّيمْ غَارْ ثْمَا ن ڒبْحَارْ\qt*  
\m \qt ؤُشَا \+tl إِقِّيمْ\+tl* إِزْذغْ غَارْ إِفْثَاسنْ نّسْ.\qt*   
\m
\v 18 \qt زابُولُونْ ذ إِجّْ ن ڒْڭنْسْ\qt*  
\m \qt إِسبّڒْ ثُوذَارْثْ نّسْ أَڒْ ڒْموْثْ،\qt*  
\m \qt أَمْ \+tl ث إِڭَّا\+tl* ؤُڒَا ذ نَافْثَالِي\qt*  
\m \qt خْ ڒڭْعُوذِي ن وَازَّايْ \+tl ن ؤُمنْغِي\+tl*.\qt*   
\b  
\m
\v 19 \qt إِجدْجِيذنْ ؤُسِينْ-د، مّنْغنْ.\qt*  
\m \qt ڒخْذنِّي مّنْغنْ إِجدْجِيذنْ ن كنْعَانْ\qt*  
\m \qt ذِي ثَاعْنَاكْ غَارْ وَامَانْ ن مَاجِيدُّو،\qt*  
\m \qt \+tl مَاشَا\+tl* وَارْ كْسِينْ ثَاكشَّاضْثْ ن نُّوقَارْثْ.\qt*   
\m
\v 20 \qt \+tl مِينْزِي\+tl* إِثْرَانْ مّنْغنْ زڭْ ؤُجنَّا،\qt*  
\m \qt مّنْغنْ أَكْ-ذ سِيسَارَا زِي ثبْرِيذِينْ نْسنْ.\qt*   
\m
\v 21 \qt إِغْزَارْ ن قِيشُونْ إِوْيِي إِ-ثنْ،\qt*  
\m \qt ثِيغْزَارْثْ ن مشْحَاڒْ ؤُيَا، ثِيغْزَارْثْ ن قِيشُونْ!\qt*  
\m \qt ؤُيُورْ س جّهْذْ، \+tl أَ\+tl* ڒعْمَارْ إِنُو.\qt*   
\m
\v 22 \qt ڒخْذنِّي نّْخُوخْڒنْثْ ثِيشضْيِينْ ن إِيْسَانْ\qt*  
\m \qt زڭْ ؤُرَابعْ بْڒَا ؤُقطُّو\qt*  
\m \qt زڭْ أَيْثْ ن بُو-صُّولْطَا نّسْ.\qt*   
\b  
\m
\v 23 \qt نعْڒمْ مِيرُوزْ، إِنَّا لْمَالَاكْ ن سِيذِي،\qt*  
\m \qt نعْڒمْ إِمزْذَاغْ نّسْ س \+tl إِشْثْ ن\+tl* نّعْڒثْ،\qt*  
\m \qt مِينْزِي وَارْ د-ؤُسِينْ\qt*  
\m \qt حِيمَا أَذْ وْشنْ أَفُوسْ إِ سِيذِي،\qt*  
\m \qt \+tl حِيمَا\+tl* أَذْ وْشنْ أَفُوسْ إِ سِيذِي\qt*  
\m \qt س أَيْثْ ن بُو-ثغْرُوضْثْ \+tl نْسنْ\+tl*.\qt*   
\m
\v 24 \qt ثتّْوَابَاركْ يَاعِيلْ، ثَامْغَارْثْ ن حَابِيرْ، أَقِينِي،\qt*  
\m \qt سنّجْ إِ \+tl مَارَّا\+tl* ثِيمْغَارِينْ.\qt*  
\m \qt ثتّْوَابَاركْ نتَّاثْ سنّجْ\qt*  
\m \qt إِ مَارَّا ثِيمْغَارِينْ \+tl إِزدّْغنْ\+tl* ذڭْ إِقِيضَانْ.\qt*   
\m
\v 25 \qt نتَّا إِتَّارْ أَمَانْ، نتَّاثْ ثوْشَا أَسْ أَغِي،\qt*  
\m \qt ثِيوِي \+tl أَسْ-د\+tl* ثْرُوسِّي\qt*  
\m \qt ذڭْ إِشْثْ ن طّبْصِي ذ أَمقّْرَانْ أَطَّاسْ.\qt*   
\m
\v 26 \qt س ؤُفُوسْ نّسْ ثسّْوِيژّضْ غَارْ ڒوْثذْ،\qt*  
\m \qt أَفُوسْ أَفُوسِي نّسْ غَارْ وفْضِيسْ ن إِخدَّامنْ.\qt*  
\m \qt نتَّاثْ ثوْثَا سِيسَارَا،\qt*  
\m \qt ثخْبضْ أَسْ خْ ؤُزدْجِيفْ نّسْ،\qt*  
\m \qt ثڒْبزْ ؤُشَا ثسّْنُوقّبْ أَسْ\qt*  
\m \qt أَغزْذِيسْ \+tl ن ؤُزدْجِيفْ\+tl* نّسْ.\qt*   
\m
\v 27 \qt إِكْمُومّشْ جَارْ إِضَارنْ نّسْ،\qt*  
\m \qt إِبُّوزّڒْ، أَقَا إِزّڒْ \+tl ذِينْ\+tl*.\qt*  
\m \qt أَقَا إِكْمُومّشْ جَارْ إِضَارنْ نّسْ، إِبُّوزّڒْ.\qt*  
\m \qt ؤُمِي ثُوغَا إِتّكْمُومُّوشْ،\qt*  
\m \qt إِوْضَا ذِينْ، ؤُشَا إِوْضَا-د إِڒقّفْ!\qt*   
\b  
\m
\v 28 \qt زِي ڒْكَازِي \+tl نّسْ\+tl* ثخْزَارْ-د يمَّاسْ ن سِيسَارَا\qt*  
\m \qt ؤُشَا ثسْغُويْ جَارْ إِقْضِيبنْ ن وُوزَّاڒْ\qt*  
\m \qt ’مَايمِّي إِعطَّاڒْ ؤُكَارُّو نّسْ ن ؤُمنْغِي\qt*  
\m \qt أَمُّو أَطَّاسْ؟\qt*  
\m \qt مَايمِّي إِعطَّاڒْ دّْرِيزْ ن إِكَارُّوثنْ نّسْ‘\qt*   
\m
\v 29 \qt إِنِّي ذ ثِيغْمِيسِينْ أَطَّاسْ جَارْ ثْجدْجِيذِينْ نّسْ\qt*  
\m \qt أَرِّينْثْ-إِ-د،\qt*  
\m \qt \+tl ؤُشَا\+tl* ؤُڒَا ذ نتَّاثْ سِيمَانْثْ نّسْ\qt*  
\m \qt ثَارَّا-د خْ مِينْ ثنَّا:\qt*   
\m
\v 30 \qt ’مَا \+tl خنِّي نِيثْنِي\+tl* وَارْ ؤُفِينْ وَالُو\qt*  
\m \qt ؤُشَا أَقَا أَثنْ وَارْ بطِّينْ ثَاكشَّاضْثْ؟\qt*  
\m \qt إِ كُوڒْ أَرْيَازْ إِجهْذنْ إِشْثْ \+tl ن ثعْزَارشْثْ\+tl*\qt*  
\m \qt نِيغْ ثْنَاينْ \+tl ن ثعْزَارِييِّينْ\+tl*؟\qt*  
\m \qt ثَاكشَّاضْثْ ن \+tl إِكتَّاننْ\+tl* إِتّْوَاسّْقَارقْشنْ\qt*  
\m \qt إِ سِيسَارَا،\qt*  
\m \qt ثَاكشَّاضْثْ ن \+tl إِكتَّاننْ\+tl* إِتّْوَاسّْقَارقْشنْ،\qt*  
\m \qt أَبُورْضَا، ڒْخذْمثْ ن ؤُمُوذِي\qt*  
\m \qt غَارْ ثْنَاينْ ن إِغزْذِيسنْ\qt*  
\m \qt زڭْ ؤُكتَّانْ إِتّْوَاسّْقَارقْشنْ إِ إِرَاونْ،\qt*  
\m \qt أَمْ ثْكشَّاضْثْ؟‘\qt*   
\b  
\m
\v 31 \qt أَمُّو إِ غَا هلّْكنْ ڒْعذْيَانْ نّشْ، \+tl أَ\+tl* سِيذِي،\qt*  
\m \qt \+tl مَاشَا\+tl* إِنِّي شكْ إِتّخْسنْ أَذْ إِڒِينْ أَمْ ثْفُوشْثْ\qt*  
\m \qt إِ د-إِنقَّارنْ ذِي جّهْذْ نّسْ.“\qt*  
\b  
\m \add أَوَارْنِي أَيَا\add* ثَاريّحْ ثمُّورْثْ أَربْعِينْ ن إِسڭّْوُوسَا. \x ◘ \xo 5:‏31 \xt إِزهد. 19‏:‏6\x*   
\b  
\b  
\m  
\c 6
\s1 جِيذْعُونْ ذ لْمَالَاكْ ن سِيذِي  
\m
\v 1 \add مَاشَا\add* أَيْثْ ن إِسْرَائِيل ڭِّينْ مِينْ \add إِدْجَانْ\add* ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي ؤُشَا إِسلّمْ إِ-ثنْ سِيذِي ذڭْ ؤُفُوسْ ن مِيذْيَانْ، \add إِجّْ ن ڒْمِيجَاڒْ ن\add* سبْعَا ن إِسڭّْوُوسَا.  
\v 2 \add ؤُمِي\add* ثُوغَا أَفُوسْ ن مِيذْيَانْ إِجْهذْ خْ إِسْرَائِيل، ڭِّينْ أَيْثْ ن إِسْرَائِيل إِ يِيخفْ نْسنْ إِفْرَانْ ذڭْ إِذُورَارْ ذ إِخرْذُوسنْ ذ لْقلْعَاثْ ضِيدّْ إِ مِيذْيَانْ.  
\v 3 \add أَوَارْنِي ڒَامِي\add* ثُوغَا زَارّْعنْ أَيْثْ ن إِسْرَائِيل، تّْڭعّذْ مِيذْيَانْ ؤُشَا ؤُڒَا ذ أَيْثْ ن عَامَالِيقْ ذ أَيْثْ ن شَّارْقْ تّْڭعّْذنْ ضِيدّْ نْسنْ.  
\v 4 نِيثْنِي وْثِينْ إِقِيضَانْ نْسنْ ضِيدّْ نْسنْ ؤُشَا أَردّْدْجنْ ڒْغِيدْجثْ ن ثمُّورْثْ أَڒْ \add جّْوَايهْ\add* ن غَازَّا. نِيثْنِي وَارْ جِّينْ ذِي إِسْرَائِيل إِ زِي غَا إِدَّارْ \add بْنَاذمْ\add*، ڒَا ذ ؤُدْجِي، ڒَا ذ أَفُونَاسْ ؤُڒَا ذ أَغْيُوڒْ.  
\v 5 مَاغَارْ نِيثْنِي ڭعّْذنْ س ثْحِيمْرِيوِينْ نْسنْ ذ إِقِيضَانْ نْسنْ ؤُشَا ؤُسِينْ-د أَمْ يِيجّْ ن ويْڒَافْ ن ثْمُورْغِي. وَارْ إِزمَّارْ أَذْ تّْوَاحسْبنْ أَكْ-ذ إِڒغْمَانْ نْسنْ ؤُشَا نِيثْنِي ؤُذْفنْ غَارْ ثَامُّورْثْ، حِيمَا أَذْ ت أَردّْدْجنْ.  
\v 6 \add أَمُّو\add* إِژْڒضْ إِسْرَائِيل أَطَّاسْ زِي سِّيبّثْ ن مِيذْيَانْ. ؤُشَا \add خنِّي\add* سْغُوينْ أَيْثْ ن إِسْرَائِيل غَارْ سِيذِي.   
\m
\v 7 خْمِي سْغُوينْ أَيْثْ ن إِسْرَائِيل غَارْ سِيذِي ذِي سِّيبّثْ ن مِيذْيَانْ، إِمْسَارْ،  
\v 8 أَقَا سِيذِي إِسّكّْ-د إِجّْ ن ورْيَازْ، إِجّْ ن ؤُنَابِي، غَارْ أَيْثْ ن إِسْرَائِيل. نتَّا إِنَّا أَسنْ: ”أَمُّو إِ إِقَّارْ سِيذِي، أَربِّي ن إِسْرَائِيل: ’\bd نشّْ\bd* سّْڭعّْذغْ كنِّيوْ زِي مِيصْرَا ؤُ سُّوفّْغغْ-د كنِّيوْ زِي ثَادَّارْثْ ن ثسْمُوغِي.  
\v 9 نشّْ فكّغْ-د كنِّيوْ زڭْ ؤُفُوسْ ن إِمِيصْرِييّنْ ؤُ زڭْ ؤُفُوسْ ن مَارَّا إِنِّي كنِّيوْ إِحْصَارنْ. نشّْ ؤُژّْڒغْ خَاسنْ زَّاثْ إِ وُوذمْ نْومْ ؤُ وْشِيغْ أَومْ ثَامُّورْثْ نْسنْ.  
\v 10 نشّْ نِّيغْ أَومْ: نشّْ ذ سِيذِي، أَربِّي نْومْ، وَارْ تّْعبّْذمْ إِربِّيثنْ ن إِمُورِييّنْ، إِنِّي ذِي ثمُّورْثْ نْسنْ ثْزدّْغمْ!‘ \add مَاشَا\add* كنِّيوْ وَارْ ثسْڒِيمْ غَارْ ثْمِيجَّا إِنُو.“ \x ◘ \xo 6:‏10 \xt 2 إِج. 17‏:‏35، 38\x*   
\m
\v 11 \add خنِّي\add* يُوسَا-د لْمَالَاكْ ن سِيذِي ؤُشَا إِقِّيمْ سَاذُو ن ثْشجُّورَا ن يِيڭّْ نِّي إِدْجَانْ غَارْ عَافْرَا، ثنِّي ن يُووَاشْ، أَبِيعَازَارِي. مِّيسْ \bd جِيذْعُونْ\bd* ثُوغَا-ث \add ذِينْ\add* إِسَّارْوَاثْ إِرْذنْ ذِي ثْسِيرْثْ ن ؤُضِيڒْ حِيمَا أَذْ ث إِسَّارْوڒْ أَمُّو زَّاثْ إِ وُوذمْ ن مِيذْيَانْ. \f ◼ \fr 6:‏11 \ft \+bd ’يُووَاشْ‘\+bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’ونِّي إِمّوْشنْ س ؤُفُوسْ ن أَربِّي‘.\f*   
\m
\v 12 \add ڒخْذنِّي\add* إِبَانْ أَسْ-د لْمَالَاكْ ن سِيذِي، إِنَّا أَسْ: ”سِيذِي أَكِيذكْ، أَ شكْ، بُو-ثغْرُوضْثْ إِمحْضنْ!“  
\v 13 جِيذْعُونْ إِنَّا أَسْ: ”أَ، سِيذِي إِنُو، مَاڒَا سِيذِي أَقَا-ث أَكِيذْنغْ، مَايمِّي إِ ذ أَنغْ إِڒْقفْ \add خنِّي\add* مَارَّا ؤُيَا ؤُ مَانِي دْجَانْ مَارَّا ڒعْجَايبْ إِ خْ ذ أَنغْ سِّيوْڒنْ ڒجْذُوذْ نّغْ، ؤُمِي نِيثْنِي نَّانْ: ’مَا وَارْ ذ أَنغْ-د إِسُّوفّغْ سِيذِي زِي مِيصْرَا؟‘ مَاشَا ڒخُّو إِنْضَارْ أَنغْ سِيذِي، إِسلّمْ أَنغْ ذڭْ إِفَاسّنْ ن مِيذْيَانْ.“  
\v 14 \add رخْذنِّي\add* إِذْوڒْ-د غَارسْ سِيذِي، إِنَّا: ”ؤُيُورْ ذِي جّهْذْ نّشْ وَانِيثَا ؤُشَا أَذْ ثْفكّذْ إِسْرَائِيل زڭْ ؤُفُوسْ ن مِيذْيَانْ. مَا نشّْ وَارْ شكْ-د سّكّغْ؟“ \x ◘ \xo 6:‏14 \xt 1 صم. 12‏:‏11؛ عبر. 11‏:‏32\x*  
\v 15 \add مَاشَا\add* نتَّا يَارَّا-د خَاسْ: ”أَ سِيذِي إِنُو، س مِينْزِي إِ غَا فكّغْ إِسْرَائِيل؟ خْزَارْ ڒْوَاشُونْ إِنُو ذ ثَامزْڒُوضْثْ قَاعْ ذِي مَانَاسَّا ؤُ نشّْ ذ أَمُوذْرُوسْ قَاعْ ذِي ثَادَّارْثْ ن بَابَا.“  
\v 16 إِنَّا أَسْ سِيذِي: ”مِينْزِي نشّْ أَذْ إِڒِيغْ أَكِيذكْ، أَذْ ثْغڒْبذْ مِيذْيَانْ، أَخْمِي ذ إِجّْ ن ورْيَازْ وَاهَا.“  
\v 17 \add خنِّي\add* إِنَّا أَسْ نتَّا: ”مَاڒَا \add خنِّي\add* ؤُفِيغْ أَرْضَا ذِي ثِيطَّاوِينْ نّشْ، \add خنِّي\add* إِوْشَا أَيِي إِشْثْ ن ڒعْڒَامثْ، أَقَا ذ شكْ سِيمَانْثْ نّشْ إِ كِيذِي إِسَّاوَاڒنْ.  
\v 18 وَارْ سَّا تّْرَاحْ شَا، أَڒْ غَاركْ د غَاعقْبغْ أَذْ ثِيڒِي إِوْيغْ-د ثوْهِيبْثْ إِنُو ؤُ أَذْ ت-إِ-د-سَّارْسغْ زَّاثكْ.“ نتَّا إِنَّا: ”أَذْ قِّيمغْ أَڒْ د غَا ثْعقْبذْ.“   
\m
\v 19 ؤُشَا يُوذفْ جِيذْعُونْ، إِسّوْجذْ إِجّْ ن إِغَايْضْ ذ أَمژْيَانْ زڭْ إِغَايْضنْ ذ إِغْرُومنْ بْڒَا أَغْرُومْ زڭْ يِيجّْ ن إِفَا ن وَارنْ. نتَّا إِسَّارْسْ أَيْسُومْ ذِي ثْصُودْجثْ، إِڭَّا أَرّْوَا ذڭْ إِشْثْ ن ثيْذُورْثْ ؤُشَا يِيوِي \add مَانْ أَيَا\add* غَارسْ غَارْ بَارَّا سَاذُو ثْشجَّارْثْ ن يِيڭّْ ؤُشَا إِسَّارْسْ أَسْ \add مَانْ أَيَا\add*.  
\v 20 \add مَاشَا\add* إِنَّا أَسْ لْمَالَاكْ ن أَربِّي: ”كْسِي أَيْسُومْ ذ إِغْرُومنْ بْڒَا أَنْثُونْ ؤُ ثسَّارْسذْ ثنْ \add ذَا\add* خْ ثصْضَارْثْ ؤُشَا زدْجعْ خَاسْ أَرّْوَا!“ ؤُشَا أَمُّو إِ ث إِڭَّا.  
\v 21 \add خَاسْ\add* ؤُشَا إِسَارّحْ لْمَالَاكْ ن سِيذِي ثِيخفْثْ ن ثغَّارْشْثْ إِ ثُوغَا غَارسْ ذڭْ ؤُفُوسْ، إِحَاذَا زَّايسْ أَيْسُومْ ذ إِغْرُومنْ بْڒَا أَنْثُونْ. \add ڒخْذنِّي\add* ثْڭعّذْ ثْمسِّي زِي ثصْضَارْثْ، ثشَّا أَيْسُومْ ذ إِغْرُومنْ. \add خنِّي\add* إِنُّوفْسڒْ لْمَالَاكْ ن سِيذِي خْ ثِيطَّاوِينْ ن جِيذْعُونْ.   
\m
\v 22 \add ؤُمِي\add* جِيذْعُونْ إِژْرَا، أَقَا ثُوغَا-ث ذ لْمَالَاكْ ن سِيذِي، إِنَّا جِيذْعُونْ: ”أَ، سِيذِي إِنُو، سِيذِي، أَقَا نشّْ ژْرِيغْ لْمَالَاكْ ن سِيذِي أَغمْبُوبْ ذڭْ ؤُغمْبُوبْ.“  
\v 23 \add مَاشَا\add* سِيذِي يَارَّا-د خَاسْ: ”\add أَذْ\add* كِيذكْ \add يِيڒِي\add* ڒهْنَا، وَارْ تّڭّْوذْ شَا، شكْ وَارْ تّْمتِّيذْ.“  
\v 24 ؤُشَا جِيذْعُونْ إِبْنَا ذِينِّي إِجّْ ن ؤُعَالْطَارْ إِ سِيذِي، إِڭَّا أَسْ: ”سِيذِي ذ ڒهْنَا!“ أَقَا-ث ذِي عَافْرَا ن \add أَيْثْ ن\add* أَبِيعَازَارِي أَڒْ أَسّْ-أَ.   
\b  
\m
\v 25 ذِي دْجِيڒثْ نِّي سِيمَانْثْ نّسْ، إِمْسَارْ أَقَا سِيذِي إِنَّا أَسْ: ”كْسِي إِجّْ ن ؤُفُونَاسْ أَمژْيَانْ زڭْ إِفُونَاسنْ \add إِ إِدْجَانْ\add* ن بَابَاشْ، أَقَا أَفُونَاسْ أَمژْيَانْ وِيسّْ ثْنَاينْ ن سبْعَا ن إِسڭّْوُوسَا ؤُشَا غْضڒْ أَعَالْطَارْ ن بَاعْلْ \add إِ إِدْجَانْ\add* ن بَابَاشْ ؤُ زْذمْ ثَاربِّيثْ ن شْوَارْثِي نِّي زَّاثسْ!  
\v 26 بْنَا \add خنِّي\add* إِجّْ ن ؤُعَالْطَارْ إِ سِيذِي، أَربِّي نّشْ، خْ ثْقِيشَّاثْ ن لْقلْعَا-يَا، سوْجذْ إِ-ث، ؤُشَا كْسِي أَفُونَاسْ أَمژْيَانْ وِيسّْ ثْنَاينْ ؤُشَا أَوْيِي ث-إِ-د ذ ثْغَارْصْثْ ن وشْمَاضْ س ؤُكشُّوضْ ن ثْربِّيثْ ن شْوَارْثِي نِّي إِتّْخصَّا أَذْ ثْزذْمذْ.“   
\m
\v 27 \add خنِّي\add* إِكْسِي جِيذْعُونْعشْرَا ن يرْيَازنْ زڭْ إِمْسخَّارنْ نّسْ ؤُشَا إِڭَّا أَمْ مَامّشْ ذ أَسْ إِنَّا سِيذِي. \add مَاشَا\add* ؤُمِي نتَّا إِڭّْوذْ زِي \add ڒْْوَاشُونْ\add* ن ثَادَّارْثْ ن بَابَاسْ ؤُ زڭْ يرْيَازنْ ن ثنْذِينْثْ أَذْ ث إِڭّْ س وَاسّْ، إِڭَّا إِ-ث ذِي دْجِيڒثْ.  
\v 28 ؤُمِي د-كَّارنْ يرْيَازنْ ن ثنْذِينْثْ ثِيوشَّا زِيشْ، ژْرِينْ نِيثْنِي أَقَا أَعَالْطَارْ ن بَاعْلْ إِتّْوَاهْذمْ ؤُشَا ثتّْوَازْذمْ ثْربِّيثْ ن شْوَارْثِي نِّي زَّاثسْ ؤُ أَفُونَاسْ أَمژْيَانْ وِيسّْ ثْنَاينْ إِتّْوَابخَّارْ خْ ؤُعَالْطَارْ إِ \add ذِينْ\add* إِتّْوَابْنَانْ.  
\v 29 ؤُشَا نَّانْ إِ وَايَاوْيَا: ”مَانْ ونْ إِڭِّينْ أَيَا؟“ نِيثْنِي سّقْسَانْ، أَرْزُونْ ؤُشَا نَّانْ: ”جِيذْعُونْ، مِّيسْ ن يُووَاشْ، إِ-ث إِڭِّينْ.“  
\v 30 \add خنِّي\add* نَّانْ يرْيَازنْ ن ثنْذِينْثْ إِ يُووَاشْ: ”سُوفغْ-د مِّيشْ \add حِيمَا\add* أَذْ إِمّثْ، مِينْزِي نتَّا إِغْضرْ أَعَالْطَارْ ن بَاعْلْ ؤُ مِينْزِي نتَّا إِزْذمْ ثَاربِّيثْ ن شْوَارْثِي إِ زَّاثسْ \add إِدْجَانْ\add*.“  
\v 31 يُووَاشْ يَارَّا-د خْ مَارَّا إِنِّي إِ د غَارسْ إِبدّنْ: ”مَا ثخْسمْ أَذْ ثْمنْغمْ إِ بَاعْلْ؟ مَا ثخْسمْ أَذْ ث ثسّْنجْممْ؟ ونِّي أَكِيذسْ إِ غَا إِبدّنْ، أَذْ إِتّْوَانغْ ذِي ضّْبحْ-أَ وَانِيثَا. مَاڒَا نتَّا ذ إِجّْ ن أَربِّي، أجّْ إِ-ث أَذْ إِمّْنغْ إِ يِيخفْ نّسْ نِّيثْ، مِينْزِيغضْڒنْ أَعَالْطَارْ نّسْ.“  
\v 32 ذڭْ وَاسّْ نِّي إِڒَاغَا أَسْ-د \add إِ جِيذْعُونْ\add* يَارُوبَّاعْلْ، مِينْ إِخْسْ أَذْ يِينِي: ”بَاعْلْ إِمّْنغْ أَكِيذسْ، مَاغَارْ نتَّا إِغْضڒْ أَعَالْطَارْ نّسْ.“   
\b  
\m
\v 33 مَارَّا مِيذْيَانْ ذ عَامَالِيقْ ذ أَيْثْ ن شَّارْقْ مُوننْ ؤُشَا ژْوَانْ-د \add لْ-ؤُرْذُونْ\add* ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِي ڒوْضَا ن ثغْزُورْثْ ن يَازْرَاعِيلْ.  
\v 34 أَرُّوحْ ن سِيذِي إِسّْيَارْضْ إِ جِيذْعُونْ ؤُشَا نتَّا إِسُوضْ ذڭْ ؤُيِيشّْ ن إِشَارِّي ؤُشَا إِڒَاغَا-د خْ أَيْثْ ن أَبِيعَازَارْ مَاحنْذْ \add أَذْ بدّنْ\add* أَوَارْنِي أَسْ.  
\v 35 إِسّكّْ إِرقَّاسنْ ذِي مَارَّا مَانَاسَّا ؤُشَا إِتّْوَاڒَاغَا مَانَاسَّا \add مَاحنْذْ أَذْ بدّنْ نِيثْنِي\add* أَوَارْنِي أَسْ. خنِّي إِسّكّْ إِرقَّاسنْ غَارْ أَشِيرْ ؤُ غَارْ زابُولُونْ ؤُ غَارْ نَافْثَالِي ؤُشَا نِيثْنِي ڭعّْذنْ مَاحنْذْ أَذْ ثنْ مّڒْقَانْ.   
\m
\v 36 \add خَاسْ\add* ؤُشَا إِنَّا جِيذْعُونْ إِ أَربِّي: ”مَاڒَا شكْ ثخْسذْ \add س ثِيذتّْ\add* أَذْ ثْفكّذْ إِسْرَائِيل س ؤُفُوسْ إِنُو أَمْ مَامّشْ إِ ذ أَيِي ثنِّيذْ،  
\v 37 خْزَارْ، \add خنِّي\add* نشّْ أَذْ سَّارْسغْ \bd ثَاهِيضُورْثْ ن ثَاضُوفْثْ خْ ؤُنذْرَارْ\bd*. مَاڒَا إِوْضَا نّْذَا مْغِيرْ خْ ثَاضُوفْثْ وَاهَا، \add مَاشَا\add* ثَامُّورْثْ مَارَّا \add ثقِّيمْ\add* ثُوژغْ، \add خنِّي\add* سّْنغْ نشّْ، أَقَا شكْ أَذْ ثسّْنجْمذْ إِسْرَائِيل س ؤُفُوسْ إِنُو، أَمْ مَامّشْ إِ ذ أَيِي ثنِّيذْ.“  
\v 38 ؤُ أَمُّو إِ ثمْسَارْ. ثِيوشَّا نّسْ إِكَّارْ زِيشْ ؤُشَا إِزْڒِي ثَاهِيضُورْثْ ؤُشَا إِژمّْ-د نّْذَا زِي ثْهِيضُورْثْ، إِشْثْ ن طَّاوْيَا ثشُّورْ س وَامَانْ.   
\m
\v 39 \add خَاسْ ؤُشَا\add* إِنَّا جِيذْعُونْ إِ أَربِّي: ”تّْزَاوْڭغْ وَارْ خَافِي يَارقّْ وغْضَابْ نّشْ مَاڒَا نشّْ سِّيوْڒغْ إِشْثْ ن ثْوَاڒَا نّغْنِيثْ. أجّْ أَيِي أَذْ قدْجْبغْ س ثْهِيضُورْثْ \add عَاذْ\add* إِشْثْ ن ثْوَاڒَا نّغْنِي وَاهَا، ؤُشَا أَذْ ثقِّيمْ ثْهِيضُورْثْ ثُوژغْ ؤُ خْ مَارَّا ثَامُّورْثْ \add أَذْ ذِينْ يِيڒِي\add* نّْذَا.“ \x ◘ \xo 6:‏39 \xt أَمز. 18‏:‏32\x*  
\v 40 ؤُشَا ذِي دْجِيڒثْ نِّي إِڭَّا \add إِ-ث\add* سِيذِي أَمُّو: ثَاهِيضُورْثْ وَاهَا إِ إِقِّيمنْ ثُوژغْ ؤُ ثُوغَا نّْذَا خْ مَارَّا ثَامُّورْثْ.   
\b  
\b  
\m  
\c 7
\s1 جِيذْعُونْ يَاژّڒْ خْ أَيْثْ ن مِيذْيَانْ  
\m
\v 1 يَارُوبَّاعْلْ، وَا ذ جِيذْعُونْ، إِكَّارْ زِيشْ ؤُڒَا ذ مَارَّا ڒْڭنْسْ إِ غَارسْ إِدْجَانْ ؤُشَا وْثِينْ نِيثْنِي ڒْمَارْڭحْ ن ڒْعسْكَارْ نْسنْ غَارْ ثَاڒَا ن حَارُوذْ. ڒْمَارْڭحْ ن مِيذْيَانْ ثُوغَا إِدْجَانْ زَّاثسْ غَارْ شَّامَالْ، زِي ثوْرِيرْثْ ن مُورَا ذِي ڒوْضَا ن ثغْزُورْثْ.  
\v 2 سِيذِي إِنَّا إِ جِيذْعُونْ: ”ڒْْڭنْسْ إِ غَاركْ \add إِدْجَانْ\add* أَقَا-ث ذڭْ وَاطَّاسْ. أَمُّو وَارْ زمَّارغْ أَذْ أَسنْ ڭّغْ مِيذْيَانْ ذڭْ ؤُفُوسْ نْسنْ، نِيغْ إِزمَّارْ إِسْرَائِيل أَذْ خَافِي إِفيّشْ أَذْ يِينِي: ’أَفُوسْ إِنُو إِسّنْجمْ أَيِي.‘  
\v 3 س ؤُيَا، ڒَاغَا ذڭْ إِمزُّوغنْ ن ڒْڭنْسْ، إِنِي: ’ونِّي إِتّڭّْوذنْ ذ ونِّي إِتَّارْجِيجنْ أَذْ إِعْقبْ ؤُشَا أَذْ إِفّغْ ذغْيَا زڭْ إِذُورَارْ ن جِيلْعَاذْ!‘ “ \add خنِّي\add*عقْبنْ ثْنَاينْ ؤُ-عِيشْرِينْ-أَڒفْ \add ن يرْيَازنْ\add* زِي ڒْڭنْسْ ؤُشَا قِّيمنْ \add غَارسْ\add*عشْرَا-أَڒَافْ. \x ◘ \xo 7:‏3 \xt أَعَوذ. 20‏:‏8\x*  
\v 4 \add مَاشَا\add* سِيذِي إِنَّا إِ جِيذْعُونْ: ”ڒْْڭنْسْ أَقَا-ث عَاذْ ذڭْ وَاطَّاسْ. سهْوَا ثنْ غَارْ وَامَانْ، ذِينِّي أَذْ ثنْ دّْزغْ إِ شكْ. أَذْ إِمْسَارْ خْ ونِّي إِ ذ أَشْ غَا إِنِيغْ: ’وَا أَذْ كِيكْ إِرَاحْ!‘، وِينْ أَذْ كِيكْ إِرَاحْ، مَاشَا كُوڒْ إِجّْ إِ خْ ذ أَشْ غَا إِنِيغْ: ’وَانِيثَا وَارْ كِيكْ إِتّْرِيحْ!‘، وِينْ وَارْ كِيكْ إِتّْرِيحْ.“  
\v 5 إِسّهْوَا ڒْڭنْسْ غَارْ وَامَانْ. \add خنِّي\add* إِنَّا أَسْ سِيذِي: ”كُوڒْ إِجّْ ونِّي إِ غَا إِڒسْحنْ أَمَانْ س يِيڒسْ نّسْ، أَمْ مَامّشْ إِ \add ثنْ\add* إِڒسّحْ وقْزِينْ، أَذْ ث ثڭّذْ غَارْ إِجّْ ن طَّارْفْ. أَمُّو ؤُڒَا ذ مَارَّا إِنِّي إِ غَا يَاضَارنْ خْ إِفَادّنْ مَاحنْذْ أَذْ سْونْ.“  
\v 6 ڒْقدّْ ن يِينِّي إِوْينْ \add أَمَانْ\add* س ؤُفُوسْ نْسنْ غَارْ ؤُقمُّومْ نْسنْ مَاحنْذْ أَذْ ڒسْحنْ \add أَمَانْ\add* س يِيڒسْ نْسنْ، ثُوغَا أَثنْ ذِي ثڒْثْ-مْيَا ن يرْيَازنْ، مَاشَا مَارَّا إِنّغْنِي ؤُضَارنْ خْ إِفَادّنْ حِيمَا أَذْ سْونْ أَمَانْ.  
\v 7 \add خَاسْ\add* ؤُشَا إِنَّا سِيذِي إِ جِيذْعُونْ: ”س \add ؤُفُوسْ ن\add* ثڒْثْ-مْيَا ن يرْيَازنْ-أَ، إِنِّي إِڒسْحنْ \add أَمَانْ\add* س يِيڒسْ نْسنْ، أَذْ كنِّيوْ سّْنجْمغْ ؤُ نشّْ أَذْ ڭّغْ مِيذْيَانْ ذڭْ ؤُفُوسْ نّشْ. مَارَّا ڒْڭنْسْ \add نّغْنِي إِ إِقِّيمنْ\add* أَذْ ؤُيُورنْ، كُوڒْ إِجّْ غَارْ ومْشَانْ نّسْ.  
\v 8 نِيثْنِي كْسِينْ ڒعْوتْشْ نْ ڒْڭنْسْ ذ وَاشَّاونْ نْسنْ ن إِشَارِّي ذڭْ ؤُفُوسْ، \add ؤُمِي\add* نتَّا إِسّكّْ مَارَّا إِرْيَازنْ ن إِسْرَائِيل، كُوڒْ  إِجّْ غَارْ ؤُقِيضُونْ نّسْ. \add مَاشَا\add* ثڒْثْ-مْيَا ن يرْيَازنْ نِّي إِجَّا إِ-ثنْ \add غَارسْ\add*. ثُوغَا ڒْمَارْڭحْ ن ڒْعسْكَارْ ن مِيذْيَانْ سْوَادَّايْ نّسْ ذِي ڒوْضَا ن ثغْزُورْثْ.  
\v 9 ذِي دْجِيڒثْ نِّي ثمْسَارْ، أَقَا سِيذِي إِنَّا أَسْ: ”كَّارْ بدّْ، هْوَا غَارْ ڒْمَارْڭحْ ن ڒْعسْكَارْ، مَاغَارْ نشّْ ڭِّيغْ أَشْ ثنْ ذڭْ ؤُفُوسْ نّشْ.  
\v 10 مَاڒَا شكْ أَقَا ثڭّْوْذذْ \add عَاذْ\add* مَاحنْذْ أَذْ د-ثهْوِيذْ، هْوَا-د \add خنِّي\add* غَارْ ڒْمَارْڭحْ ن ڒْعسْكَارْ أَكْ-ذ فُورَا، أَمْسخَّارْ نّشْ.  
\v 11 أَذْ ثسْڒذْ مِينْ خفْ سَّاوَاڒنْ، ؤُشَا خنِّي أَذْ أَشْ إِمّوْشْ جّهْذْ ذڭْ إِفَاسّنْ نّشْ أَڒَامِي غَا ثْزمْعذْ أَذْ ثهْوِيذْ غَارْ ڒْمَارْڭحْ نْ ڒْعسْكَارْ.“ \add خنِّي\add* إِهْوَا نتَّا أَكْ-ذ فُورَا، أَمْسخَّارْ نّسْ، أَڒَامِي \add إِوْضنْ\add* أَڒْ زَّاثْ إِ ثرْبِيعِينْ إِسّْوجْذنْ إِ ؤُمنْغِي غَارْ طَّارْفْ ن ڒْمَارْڭحْ.  
\v 12 ؤُشَا مِيذْيَانْ ذ عَامَالِيقْ ذ مَارَّا أَيْثْ ن شَّارْقْ ثُوغَا سُّونْ ذِي ڒوْضَا ن ثغْزُورْثْ أَمْ يِيجّْ ن ويْڒَافْ ن ثْمُورْغِي ؤُ إِڒغْمَانْ نْسنْ وَارْ زمَّارنْ أَذْ تّْوَاحسْبنْ، ثُوغَا أَثنْ ذڭْ وَاطَّاسْ أَمْ يِيجْذِي غَارْ ثْمَا ن ڒبْحَارْ. \x ◘ \xo 7:‏12 \xt  ڒقض. 6‏:‏3، 5، 33\x*  
\v 13 \add ؤُمِي\add* يِيوضْ جِيذْعُونْ \add ذِينْ\add*، خْزَارْ، إِجّْ ن ورْيَازْ، ثُوغَا إِتّْحَاجَا إِ ؤُمدُّوكّڒْ نّسْ إِشْثْ ن ثَارْجِيثْ، إِنَّا: ”خْزَارْ، نشّْ غَارِي إِشْثْ ن ثَارْجِيثْ ؤُشَا ژْرِيغْ مَامّشْ إِجّْ ن وغْرُومْ ن إِمنْذِي إِ إِوْضَانْ غَارْ سْوَادَّايْ إِقْنُونِّي-د غَارْ ذَاخڒْ ن ڒْمَارْڭحْ ن ڒْعسْكَارْ ن مِيذْيَانْ ؤُشَا يِيوضْ أَڒْ أَقِيضُونْ ؤُشَا إِڒْقفْ إِ-ث أَڒَامِي إِوْضَا ؤُ إِذْوڒْ خْ ؤُزدْجِيفْ. أَقَا \add أَمُّو إِ\add* إِوْضَا ؤُقِيضُونْ.“  
\v 14 يَارَّا-د \add خَاسْ\add* ؤُمدُّوكّڒْ نّسْ، إِنَّا: ”أَيَا وَارْ إِخْسْ أَذْ يِينِي مْغِيرْ سِّيفْ ن جِيذْعُونْ، مِّيسْ ن يُووَاشْ، أَرْيَازْ زِي إِسْرَائِيل. أَربِّي إِوْشَا مِيذْيَانْ ذ مَارَّا ڒْمَارْڭحْ ن ڒْعسْكَارْ ذڭْ ؤُفُوسْ نّسْ.“  
\v 15 \add ؤُمِي\add* إِسْڒَا جِيذْعُونْ ثَارْجِيثْ-أَ ذ مِينْ ثخْسْ أَذْ ثِينِي، يُوضَارْ ؤُشَا \add خنِّي\add* إِعْقبْ غَارْ ڒْمَارْڭحْ ن ڒْعسْكَارْ ن إِسْرَائِيل، إِنَّا: ”كَّارمْ، سِيذِي إِڭَّا ڒْمَارْڭحْ ن ڒْعسْكَارْ ن مِيذْيَانْ ذڭْ ؤُفُوسْ نْومْ.“  
\v 16 جِيذْعُونْ إِبْضَا ثڒْثْ-مْيَا ن يرْيَازنْ خْ ثْڒَاثَا ن إِبَاطَايُوننْ ؤُشَا إِوْشَا كُوڒْ إِجّْ \add زَّايْسنْ\add* إِجّْ ن ؤُيِيشّْ ن إِشَارِّي ذڭْ ؤُفُوسْ نّسْ ذ إِجّْ ن وقْضُوحْ إِخْوَانْ ذ إِجّْ ن ؤُصفْضَاوْ ذڭْ وقْضُوحْ.  
\v 17 نتَّا إِنَّا أَسنْ: ”خْزَارمْ-د غَارِي ؤُشَا ڭّمْ أَمنِّي. خْزَارْ، مَاڒَا إِوْضغْ غَارْ طَّارْفْ ن ڒْمَارْڭحْ، خنِّي أَذْ ثڭّمْ ؤُڒَا ذ كنِّيوْ أَمْ مَامّشْ إِ غَا ڭّغْ نشّْ.  
\v 18 خْمِي غَا سُوضغْ نشّْ ذڭْ ؤُيِيشّْ ن إِشَارِّي ؤُڒَا ذ مَارَّا إِنِّي غَارِي إِدْجَانْ، خنِّي أَذْ ثْسُوضمْ ؤُڒَا ذ كنِّيوْ ذڭْ وَاشَّاونْ ن إِشَارِّي غَارْ مَارَّا إِغزْذِيسنْ ن ڒْمَارْڭحْ، أَذْ ثِينِيمْ: ’إِ سِيذِي ؤُ إِ جِيذْعُونْ!‘ “  
\v 19 ؤُشَا جِيذْعُونْ ذ مْيَا ن يرْيَازنْ نِّي ثُوغَا غَارسْ، إِوْضنْ-د غَارْ طَّارْفْ ن ڒْمَارْڭحْ ن ڒْعسْكَارْ غَارْ ؤُمزْوَارُو ن ثْعسَّاسْثْ ن وزْينْ \add ن دْجِيڒثْ\add*، ؤُمِي ثنْ ثُوغَا \add عَاذْ\add* ڭُّورْ أَذْ سّْبدّنْ إِعسَّاسنْ، ؤُشَا سُوضنْ ذڭْ وَاشَّاونْ ن إِشَارِّي، ؤُشَا نِيثْنِي وْثِينْ، أَرْژِينْ إِقْضُوحنْ نِّي غَارْسنْ ذڭْ ؤُفُوسْ نْسنْ.  
\v 20 ثْڒَاثَا ن إِبَاطَايُوننْ سُوضنْ ذڭْ وَاشَّاونْ ن إِشَارِّي ؤُشَا أَرْژِينْ إِقْضُوحنْ ؤُ س ؤُفُوسْ أَژڒْمَاضْ طّْفنْ إِصفْضَاونْ ؤُ س ؤُفُوسْ أَفُوسِي أَشَّاونْ ن إِشَارِّي حِيمَا أَذْ \add ذَايْسنْ\add* سُوضنْ ؤُشَا سْغُوينْ: ”سِّيفْ ن سِيذِي ذ جِيذْعُونْ!“  
\v 21 قِّيمنْ بدّنْ غَارْ مَارَّا إِغزْذِيسنْ ن ڒْمَارْڭحْ كُوڒْ إِجّْ ذڭْ ومْشَانْ نّسْ. \add خنِّي\add* بْذَانْ أَذْ أَژّْڒنْ \add مَارَّا إِنِّي إِدْجَانْ ذِي\add* ڒْمَارْڭحْ، سْغُوينْ ؤُشَا أَروْڒنْ.  
\v 22 \add ؤُمِي\add* سُوضنْ ثڒْثْ-مْيَا ن يرْيَازنْ ذڭْ وَاشَّاونْ ن إِشَارِّي، إِسّكَّارْ سِيذِي سِّيفْ ن إِجّنْ ضِيدّْ إِ ونّغْنِي ذِي مَارَّا ڒْمَارْڭحْ ؤُشَا يَارْوڒْ ڒْعسْكَارْ أَڒْ بَايْثْ-شِيطَّا، جِّيهثْ ن زَارَارَا أَڒْ ثْمَا ن \add يغْزَارْ إِ إِدْجَانْ غَارْ\add* أَبِيلْ-مَاحُولَا غَارْ طَابَّاثْ. \x ◘ \xo 7:‏22 \xt  إِزهد. 83‏:‏10\x*  
\v 23 \add خنِّي\add* ڒَاغَانْ-د خْ يرْيَازنْ ن إِسْرَائِيل، زِي نَافْثَالِي ؤُ زِي أَشِيرْ ؤُ زِي مَارَّا مَانَاسَّا ؤُشَا ضْفَارنْ نِيثْنِي \add أَيْثْ ن\add* مِيذْيَانْ.  
\v 24 \add عَاوذْ\add* إِسّكّْ جِيذْعُونْ إِرقَّاسنْ غَارْ مَارَّا إِذُورَارْ ن إِفْرَايِيمْ، إِنَّا: ”هْوَامْ، ؤُيُورمْ غَارْ ؤُمْسَاڭَارْ أَكْ-ذ أَيْثْ ن مِيذْيَانْ ؤُ ثكّْسمْ أَسْ إِغزْرَانْ أَڒْ بَايْثْ-بَارَا ؤُڒَا ذ لْ-ؤُرْذُونْ.“ تّْوَاڒَاغَانْ مَارَّا إِرْيَازنْ ن إِفْرَايِيمْ ؤُشَا نِيثْنِي طّْفنْ إِغزْرَانْ أَڒْ بَايْثْ-بَارَا ذ لْ-ؤُرْذُونْ.  
\v 25 نِيثْنِي حبّْسنْ ثْنَاينْ ن ڒْحُوكَّامْ ن مِيذْيَانْ، غُورَابْ ذ ذِيئَابْ، ؤُشَا نْغِينْ غُورَابْ خْ ثصْضَارْثْ ن غُورَابْ ؤُ ذِيئَابْ نْغِينْ ث خْ ثْسِيرْثْ \add ن ؤُضِيڒْ\add* ن ذِيئَابْ ؤُشَا نِيثْنِيعرْفنْ خْ إِمِيذْيَانِييّنْ. إِزدْجِيفنْ ن غُورَابْ ذ ذِيئَابْ إِوْينْ ثنْ غَارْ جِيذْعُونْ خْ ؤُجمَّاضْ ن لْ-ؤُرْذُونْ. \x ◘ \xo 7:‏25 \xt إِزهد. 83‏:‏12؛ إِشا. 10‏:‏26\x*   
\b  
\b  
\m  
\c 8
\s1 أَغلّبْ ن جِيذْعُونْ خْ مِيذْيَانْ  
\m
\v 1 \add خنِّي\add* نَّانْ أَسْ يرْيَازنْ ن إِفْرَايِيمْ: ”مَانَاوْيَا إِ ذ أَنغْ ذَا ثڭِّيذْ، أَقَا شكْ وَارْ إِ ذ خَانغْ ثْڒِيغِيذْ ؤُمِي ثفّْغذْ، حِيمَا أَذْ ثمّنْغذْ أَكْ-ذ مِيذْيَانْ؟“ ؤُشَا نِيثْنِي مّْشُوبّشنْ أَكِيذسْ أَطَّاسْ. \x ◘ \xo 8:‏1 \xt ڒقض. 12‏:‏1\x*  
\v 2 \add جِيذْعُونْ\add* يَارَّا-د خَاسنْ: ”مَانِي إِ د غَا يَاسْ مِينْ ڭِّيغْ أَكْ-ذ مِينْ ثڭِّيمْ؟ مَا وَارْ إِدْجِي أَڒْقَاضْ ن مِينْ إِيُورَانْ ن ؤُضِيڒْ ن أَيْثْ ن إِفْرَايِيمْ خَارْ زِي ڒْغِيدْجثْ ن بِينُو ن أَيْثْ ن أَبِيعَازَارْ؟ \f ◼ \fr 8:‏2 \ft \+bd ’جِيذْعُونْ‘\+bd* - س ثْعِيبْرَانِيثْ ’نتَّا‘.\f*  
\v 3 سِيذِي إِڭَّا غُورَابْ ذ ذِيئَابْ، ڒْحُوكَّامْ ن مِيذْيَانْ، ذڭْ ؤُفُوسْ نْومْ. مِينْ زمَّارغْ أَذْ ڭّغْ أَذْ ث سّمْقُودّغْ أَكِيذْومْ؟“ ؤُمِي نتَّا إِنَّا أَوَاڒْ-أَ يَارْسَا ؤُخيّقْ نْسنْ.   
\b  
\m
\v 4 \add ؤُمِي\add* د-يُوسَا جِيذْعُونْ غَارْ لْ-ؤُرْذُونْ، إِژْوَا نتَّا أَكْ-ذ ثڒْثْ-مْيَا ن يرْيَازنْ نِّي ثُوغَا غَارسْ إِدْجَانْ. نِيثْنِي فْنَانْ ڒَامِي ثنْ قِّيمنْ ضفَّارنْ \add أَيْثْ ن مِيذْيَانْ\add*.  
\v 5 إِنَّا نتَّا إِ يرْيَازنْ ن سُوكُّوثْ: ”تّْزَاوْڭغْ، وْشمْ إِ ڒْڭنْسْ إِ د أَيِي إِضْفَارنْ خْ إِضَارنْ ثِيشْنِيفِينْ ن وغْرُومْ، مَاغَارْ نِيثْنِي فْنَانْ ؤُ نشّْ أَقَا ضفَّارغْ زَابَاحْ ذ صَالْمُونَّاعْ، إِجدْجِيذنْ ن مِيذْيَانْ.“  
\v 6 \add مَاشَا\add* ڒْحُوكَّامْ ن سُوكُّوثْ نَّانْ: ”زَابَاحْ ذ صَالْمُونَّاعْ، مَا أَقَا أَثنْ ذڭْ ؤُفُوسْ نّشْ، مَاحنْذْ أَذْ نوْشْ أَغْرُومْ إِ ڒْعسْكَارْ نّشْ؟“  
\v 7 س ؤُيَا إِنَّا جِيذْعُونْ: ”خنِّي ڒخُّو، خْمِي ذ أَيِي غَا إِڭّْ سِيذِي زَابَاحْ ذ صَالْمُونَّاعْ ذڭْ ؤُفُوسْ إِنُو، \add خنِّي\add* أَذْ أَومْ سَّاروْثغْ أَيْسُومْ ن أَرِّيمثْ نْومْ أَكْ-ذ إِسنَّاننْ ذ يژْرَا ن ثْمسِّي زِي ڒخْڒَا.“  
\v 8 ؤُشَا إِڭعّذْ سّنِّي غَارْ فَانُووِيلْ ؤُشَا إِسِّيوڒْ أَمنِّي أَكِيذْسنْ. أَرِّينْ-د خَاسْ يرْيَازنْ ن فَانُووِيلْ أَمْ مَامّشْ إِ د-أَرِّينْ يرْيَازنْ ن سُوكُّوثْ.  
\v 9 س ؤُينِّي إِسِّيوڒْ عَاوذْ أَكْ-ذ يرْيَازنْ ن فَانُووِيلْ، إِنَّا: ”مَاڒَا نشّْعقْبغْ-د ذِي ڒهْنَا، أَذْ هذْمغْ صُّومْعثْ-أَ ثَا.“   
\m
\v 10 \add ثُوغَا\add* زَابَاحْ ذ صَالْمُونَّاعْ أَكْ-ذ ڒْعسْكَارْ نْسنْ ذِي كَارْكُورْ، ثُوغَا أَثنْ عْڒَاحَاڒْ ذِي خمّسْطَاشْ-أَڒفْ ن يرْيَازنْ، مَارَّا إِنِّي ثُوغَا إِقِّيمنْ زِي مَارَّا ڒْعسْكَارْ ن أَيْثْ ن شَّارْقْ. أَقَا مْيَا ؤُ-عِيشْرِينْ-أَڒفْ ن يرْيَازنْ إِنِّي إِزمَّارنْ خْ سِّيفْ ثُوغَا تّْوَانْغنْ \add عَاذْ\add*.  
\v 11 ؤُشَا إِڭعّذْ جِيذْعُونْ أَكْ-ذ وبْرِيذْ ن يِينِّي إِزدّْغنْ ذڭْ إِقِيضَانْ، غَارْ شَّارْقْ ن نُوبَاحْ ذ يُوجْبَاهَا ؤُ نتَّا إِغْڒبْ خْ ڒْعسْكَارْ نِّي، ؤُمِي \add إِعسْكَارِييّنْ ذِي\add* ڒْمَارْڭحْ \add إِتّْغِيڒْ أَسنْ\add* أَقَا أَثنْ ذِي ڒَامَانْ.  
\v 12 زَابَاحْ ذ صَالْمُونَّاعْ أَروْڒنْ ؤُشَا نتَّا إِضْفَارْ إِ-ثنْ. إِطّفْ ثْنَاينْ ن إِجدْجِيذنْ ن مِيذْيَانْ، زَابَاحْ ذ صَالْمُونَّاعْ، ذ إِمحْبَاسْ ؤُشَا إِسِّيڭّْوذْ مَارَّا ڒْعسْكَارْ. \x ◘ \xo 8:‏12 \xt إِزهد.83‏:‏12\x*   
\m
\v 13 \add ؤُمِي\add* د-إِعْقبْ جِيذْعُونْ، مِّيسْ ن يُووَاشْ، زڭْ ؤُمنْغِي، إِكَّا خْ ثْسُونْثَا ن حَارَاسْ،  
\v 14 إِطّفْ إِجّْ ن وبْڒِيغْ زڭْ يرْيَازنْ ن سُوكُّوثْ ذ أَمحْبُوسْ ؤُشَا إِسّقْسَا ث. وَانِيثَا يُورَا أَسْ \add مَارَّا إِسْمَاونْ ن\add* ڒْحُوكَّامْ ن سُوكُّوثْ ذ إِمْغَارنْ نْسنْ، سبْعَا ؤُ-سبْعِينْ ن يرْيَازنْ.  
\v 15 \add ؤُمِي\add* د-يِيوضْ نتَّا غَارْ يرْيَازنْ ن سُوكُّوثْ، إِنَّا: ”إِنَا ذ زَابَاحْ ذ صَالْمُونَّاعْ، إِنِّي زِي إِ ذ أَيِي ثسّْبَارّْقمْ ؤُمِي ثنَّامْ: ’مَا زَابَاحْ ذ صَالْمُونَّاعْ أَقَا أَثنْ ذڭْ ؤُفُوسْ نّشْ أَڒْ غَا نوْشْ أَغْرُومْ إِ يرْيَازنْ نّشْ نِّي يُوحْڒنْ؟‘ “  
\v 16 \add خنِّي\add* إِطّفْ إِمْغَارنْ ن ثنْذِينْثْ ذ إِسنَّاننْ ذ إِژْرَا ن ثْمسِّي زِي ڒخْڒَا ؤُشَا إِڭَّا إِرْيَازنْ ن سُوكُّوثْ أَذْ زَّايسْ أَشَانْ.  
\v 17 لْبُورْجْ ن فَانُووِيلْ إِهْذمْ إِ-ث ؤُ إِنْغَا إِرْيَازنْ ن ثنْذِينْثْ.  
\v 18 \add خنِّي\add* إِنَّا إِ زَابَاحْ ذ صَالْمُونَّاعْ: ”مَامّشْ إِدْجَانْ يرْيَازنْ نِّي ثنْغِيمْ ذِي ثابُورْ؟“ نِيثْنِي أَرِّينْ-د خَاسْ: ”نِيثْنِي ثُوغَا أَثنْ أَمْ شكْ، \add غَارْسنْ\add* أَدُّوذْ ذ إِجّنْ \add أَكْ-ذ\add* إِحنْجِيرنْ ن ؤُجدْجِيذْ.“  
\v 19 \add خنِّي\add* إِنَّا: ”نِيثْنِي ثُوغَا ذ أَيْثْمَا، إِحنْجِيرنْ ن يمَّا. س ثِيذتّْ أَمْ إِدَّارْ سِيذِي، مْڒِي ثنْ ثجِّيمْ أَذْ دَّارنْ، إِڒِي وَارْ كنِّيوْ نقّغْ!“  
\v 20 \add خنِّي\add* إِنَّا إِ يَاثَارْ، أَمنْزُو نّسْ: ”كَّارْ، نغْ إِ-ثنْ!“ \add مَاشَا\add* أَبْڒِيغْ وَارْ د-إِكِّيسْ سِّيفْ نّسْ، مِينْزِي نتَّا إِڭّْوذْ ؤُمِي عَاذْ ذ أَبْڒِيغْ.  
\v 21 \add خنِّي\add* نَّانْ زَابَاحْ ذ صَالْمُونَّاعْ: ”كَّارْ شكْ سِيمَانْثْ نّشْ ؤُشَا نغْ أَنغْ، مَاغَارْ مَامّشْ أَرْيَازْ، أَمُّو ثِيزمَّارْ نّسْ.“ ؤُشَا إِكَّارْ جِيذْعُونْ، إِنْغَا زَابَاحْ ذ صَالْمُونَّاعْ ؤُشَا إِكْسِي ثِيزِيرِيوِينْ ثِيمژْيَانِينْ إِ ذ يُويْڒنْ غَارْ إِرَاونْ ن إِڒغْمَانْ نْسنْ. \x ◘ \xo 8:‏21 \xt إِزهد. 83‏:‏12\x*   
\b  
\m  
\s1 أَعْبذْ ن لْ-أَصْنَامْ زِي جِيذْعُونْ ذ ڒْموْثْ نّسْ  
\m
\v 22 ؤُشَا إِرْيَازنْ ن إِسْرَائِيل نَّانْ إِ جِيذْعُونْ: ”حكْمثْ خَانغْ، شكْ ؤُڒَا ذ مِّيشْ ذ وَايَّاوْ نّشْ، مَاغَارْ شكْ ثْفكّذْ أَنغْ زڭْ ؤُفُوسْ ن مِيذْيَانْ.“  
\v 23 إِنَّا أَسنْ جِيذْعُونْ: ”\bd نشّْ\bd* وَارْ خَاومْ حكّْمغْ ؤُڒَا ذ مِّي وَارْ خَاومْ إِحكّمْ. سِيذِي ذ ونِّي إِ خَاومْ إِ غَا إِحكْمنْ.“  
\v 24 جِيذْعُونْ يَارْنِي إِنَّا أَسنْ: ”نشّْ خْسغْ أَذْ زَّايْومْ تَّارغْ شَا. أَذْ أَيِي إِوْشْ كُوڒْ إِجّْ ن ورْيَازْ إِشْثْ ن ثخْرَازْثْ زِي ثْكشَّاضْثْ نّسْ!“، مِينْزِي \add تّْوَافنْ\add* غَارْسنْ ثخْرَازِينْ ن وُورغْ، مَاغَارْ نِيثْنِي ثُوغَا أَثنْ ذ أَيْثْ ن إِسْمَاعِيلْ.  
\v 25 نِيثْنِي نَّانْ: ”نشِّينْ أَذْ أَشْ ثنْثْ نوْشْ س ڒْخَاضَارْ!“ نِيثْنِي بزّْعنْ إِجّْ ن ورُّوضْ ؤُشَا كُوڒْ أَرْيَازْ إِنْضَارْ خَاسْ إِشْثْ ن ثخْرَازْثْ زِي ثْكشَّاضْثْ نّسْ.  
\v 26 ثِيخْرَازِينْ ن وُورغْ نِّي إِتَّارْ وزْننْثْ سْبعْطَاشْ-مْيَا ن \add شِيقْلُو\add* وُورغْ، نْهْڒَا ثِيزِيرِيوِينْ ثِيمژْيَانِينْ ذ ثخْرَازِينْ ذِي صِّيفثْ ن ثُوذِّيمِينْ ذ ورُّوضْ أَرْجُووَانِي إِ ثُوغَا يَارْضنْ إِجدْجِيذنْ ن مِيذْيَانْ، نْهْڒَا ثِيسدّْيِينْ \add إِ يُويْڒنْ\add* غَارْ إِرَاونْ ن إِڒغْمَانْ نْسنْ.  
\v 27 جِيذْعُونْ إِڭَّا زَّايسْ إِجّْ ن ؤُپَالْطُو \add ن ؤُكهَّانْ\add* ؤُشَا إِڭَّا إِ-ث ذِي ثنْذِينْثْ نّسْ، ذِي عَافْرَا، ؤُ مَارَّا إِسْرَائِيل يُويُورْ أَوَارْنِي أَسْ أَمْ أَوَارْنِي إِ يِيشْثْ نْ ثمْغَارْثْ ن فَارْقْ-شّْغڒْ. أَيَا إِذْوڒْ ذ ڒْفخْ إِ جِيذْعُونْ ذ ثَادَّارْثْ نّسْ.  
\v 28 \add أَمُّو\add* ثُوغَا إِنّْبهْذڒْ مِيذْيَانْ زڭْ أَيْثْ ن إِسْرَائِيل ؤُشَا وَارْ زمَّارنْ أَذْ سّْڭعّْذنْ أَزدْجِيفْ نْسنْ عَاذْ. ثُوغَا ثَامُّورْثْ ثَاريّحْ أَربْعِينْ ن إِسڭّْوُوسَا ذڭْ وُوسَّانْ ن جِيذْعُونْ.   
\m
\v 29 ؤُشَا يَارُوبَّاعْلْ، مِّيسْ ن يُووَاشْ، يُويُورْ ؤُشَا إِزْذغْ \add عَاوذْ\add* ذِي ثَادَّارْثْ نّسْ.  
\v 30 جِيذْعُونْ ثُوغَا غَارسْ سبْعِينْ ن إِحنْجِيرنْ إِنِّي د-إِفّْغنْ زِي ثْمصَّاضْثْ نّسْ، مِينْزِي ثُوغَا غَارسْ أَطَّاسْ ن ثمْغَارِينْ.  
\v 31 ؤُڒَا ذ ثَايَّا نّسْ ثنِّي \add ثُوغَا إِدْجَانْ\add* ذِي شَاكِيمْ، ثجَّا أَسْ-د إِجّْ ن ؤُحنْجِيرْ ؤُ نتَّا إِڭَّا أَسْ أَبِيمَالِيكْ.  
\v 32 جِيذْعُونْ، مِّيسْ ن يُووَاشْ، إِمُّوثْ \add ؤُمِي\add* أَشُوَّافْ نّسْ \add ثُوغَا\add* إِشَابْ أَطَّاسْ ؤُشَا نْضْڒنْ ث ذڭْ ونْضڒْ ن بَابَاسْ يُووَاشْ، ذِي عَافْرَا، \add ثَانْذِينْثْ\add* ن أَبِيعَازَارِي.   
\m
\v 33 \add أَوَارْنِي ڒَامِي\add* إِمُّوثْ جِيذْعُونْ، إِمْسَارْ، أَقَا أَيْثْ ن إِسْرَائِيل ذوْڒنْ-د ؤُشَا سّْفسْذنْ إِخفْ نْسنْ أَمْ ؤُيُورنْ أَوَارْنِي إِ ’إِبَاعْلنْ‘ ؤُشَا ڭِّينْ بَاعْلْ-بَارِيثْ ذ أَربِّي نْسنْ.  
\v 34 أَيْثْ ن إِسْرَائِيل وَارْ فكَّارنْ عَاذْ ذِي سِيذِي، أَربِّي نْسنْ، ونِّي ثنْ إِفكّنْ زڭْ ؤُفُوسْ ن مَارَّا ڒْعذْيَانْ إِ ذ أَسنْ د-إِنّْضنْ  
\v 35 ؤُشَا وَارْ سّشْننْ ثَامخْسِيوْثْ إِشوَّارنْ إِ ثَادَّارْثْ ن يَارُوبَّاعْلْ، ذ ثنِّي ن جِيذْعُونْ، خْ مَارَّا ڒْخَارْ إِ إِڭَّا ذِي طّْوعْ ن إِسْرَائِيل.   
\b  
\b  
\m  
\c 9
\s1 أَبِيمَالِيكْ ذ إِمزْذَاغْ ن شَاكِيمْ  
\m
\v 1 أَبِيمَالِيكْ، مِّيسْ ن يَارُوبَّاعْلْ، يُويُورْ غَارْ شَاكِيمْ، غَارْ أَيْثْمَاسْ ن يمَّاسْ. نتَّا إِسِّيوڒْ أَكِيذْسنْ ؤُ أَكْ-ذ مَارَّا ڒْوَاشُونْ ن ثَادَّارْثْ ن بَابَاسْ ن يمَّاسْ، إِنَّا:  
\v 2 ”سِيوْڒمْ مَاشَا ذڭْ إِمزُّوغنْ ن مَارَّا إِمزْذَاغْ ن شَاكِيمْ: ’مِينْ إِدْجَانْ مْلِيحْ إِ كنِّيوْ: مَاڒَا سبْعِينْ ن يرْيَازنْ أَذْ خَاومْ حكْمنْ، مَارَّا إِحنْجِيرنْ ن يَارُوبَّاعْلْ، نِيغْ مَاڒَا مْغِيرْ إِجّْ ن ورْيَازْ وَاهَا أَذْ خَاومْ إِحْكمْ؟عقْڒمْ عَاوذْ، أَقَا نشّْ ذ إِغُوسَّانْ نْومْ ذ أَيْسُومْ نْومْ.‘ “  
\v 3 \add خنِّي\add* سِّيوْڒنْ أَيْثْمَاسْ ن يمَّاسْ مَارَّا أَوَاڒنْ-أَ ذڭْ إِمزُّوغنْ ن مَارَّا إِمزْذَاغْ ن شَاكِيمْ أَڒَامِي ؤُڒْ نْسنْ إِميّڒْ أَذْ د-يَاسْ أَكْ-ذ أَبِيمَالِيكْ، مَاغَارْ نِيثْنِي نَّانْ: ”نتَّا ذ ؤُمَاثْنغْ.“  
\v 4 نِيثْنِي وْشِينْ أَسْ سبْعِينْ ن \add ؤُقِييَّاثْ ن\add* نُّوقَارْثْ زِي زَّاوشْثْ ن بَاعْلْ-بَارِيثْ. زَّايْسنْثْ إِشْرَا أَبِيمَالِيكْ إِرْيَازنْ إِخْوَانْ ذ يِينِّي إِطَارّْشنْ، ؤُشَا نِيثْنِي ضفَّارنْ ث-إِ-د.  
\v 5 يُوذفْ غَارْ ثَادَّارْثْ ن بَابَاسْ ذِي عَافْرَا ؤُ إِنْغَا خْ إِجّْ ن وژْرُو أَيْثْمَاسْ، إِحنْجِيرنْ ن يَارُوبَّاعْلْ، سبْعِينْ ن يرْيَازنْ. مْغِيرْ يُوثَامْ، أَحنْجِيرْ أَمَاژُوژْ ن يَارُوبَّاعْلْ إِقِّيمْ وحّْذسْ، مِينْزِي نتَّا ثُوغَا إِنُّوفَّارْ. \f ◼ \fr 9:‏5 \ft \+bd ’يُوثَامْ‘\+bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَربِّي ذ ونِّي إِكمْڒنْ‘ نِيغْ ’أَربِّي بْڒَا ڒْعِيبْ‘.\f*  
\v 6 ؤُشَا مُوننْ مَارَّا إِمزْذَاغْ ن شَاكِيمْ ذ مَارَّا إِنِّي ذِي لْقلْعَا ؤُشَا فّْغنْ، ڭِّينْ أَبِيمَالِيكْ ذ أَجدْجِيذْ غَارْ ثْشجَّارْثْ ن يِيڭّْ نِّي \add إِدْجَانْ\add* ذڭْ ومْشَانْ \add إِقدّْسنْ\add* غَارْ شَاكِيمْ. \x ◘ \xo 9:‏6 \xt ياش. 24‏:‏26\x*  
\v 7 نِيثْنِي خبَّارنْ أَيَا إِ يُوثَامْ، إِكَّارْ إِبدّْ خْ ثْقِيشَّاثْ ن وذْرَارْ ن جَارِيزِيمْ. إِسّْڭعّذْ ثْمِيجَّا نّسْ، إِنَّا أَسنْ: ”سْڒمْ غَارِي، \add أَ كنِّيوْ\add* إِمزْذَاغْ ن شَاكِيمْ، ؤُشَا أَربِّي أَذْ غَارْومْ إِسڒْ!“   
\b  
\m
\v 8 ”أَشْحَاڒْ ؤُيَا كَّارنْثْ ثْشجُّورَا، فّْغنْثْ حِيمَا أَذْ ذهْننْثْ إِجّْ ن ؤُجدْجِيذْ خْ يِيخفْ نْسنْثْ ؤُشَا نَّانْثْ إِ ؤُزمُّورْ: ’إِڒِي شكْ ذ أَجدْجِيذْ نّغْ!‘  
\v 9 أَزمُّورْ إِنَّا أَسنْ: ’مَا أَذْ سمْحغْ ذِي ثَاذُونْثْ \add ن زّشْثْ\add* إِنُو نِّي إِ ذ أَيِي إِسّمْغَارْ أَربِّي ذ إِوْذَانْ؟ مَا أَذْ ضْوغْ سنّجْ إِ ثْشجُّورَا نّغْنِي؟‘   
\m
\v 10 ؤُشَا نَّانْثْ ثْشجُّورَا إِ وَارْثُو: ’أَسْ-د، إِڒِي شكْ ذ أَجدْجِيذْ نّغْ!‘  
\v 11 ؤُرْثُو إِنَّا أَسنْ: ’مَا أَذْ سمْحغْ ذِي ثَاژْيُوذِي إِنُو ذ ڒْغِيدْجثْ إِصبْحنْ إِنُو؟ مَا أَذْ ضْوغْ سنّجْ إِ ثْشجُّورَا نّغْنِي؟‘   
\m
\v 12 ؤُشَا نَّانْثْ ثْشجُّورَا إِ ثْزَايَارْثْ: ’أَسْ-د، إِڒِي شمْ ذ أَجدْجِيذْ نّغْ!‘  
\v 13 \add مَاشَا\add* ثنَّا أَسنْ ثْزَايَارْثْ: ’مَا أَذْ سمْحغْ ذِي بِينُو ن جْذِيذْ إِنُو نِّي إِسّفْرَاحنْ أَربِّي ذ إِوْذَانْ؟ مَا أَذْ ضْوغْ سنّجْ إِ ثْشجُّورَا نّغْنِي؟‘   
\m
\v 14 \add خنِّي\add* نَّانْ مَارَّا ثِيشجُّورَا إِ شْبَارْقْ أَكْ-ذ إِسنَّاننْ: ’أَسْ-د، إِڒِي شكْ ذ أَجدْجِيذْ نّغْ!‘  
\v 15 ؤُشَا شْبَارْقْ أَكْ-ذ إِسنَّاننْ إِنَّا إِ ثْشجُّورَا: ’مَاڒَا ثخْسنْثْ كنِّينْثْ س ثِيذتّْ أَذْ أَيِي ثْذهْننْثْ ذ أَجدْجِيذْ خَاكنْثْ، أَسنْثْ-د خنِّي، أَفنْثْ أَذُورِّي ذِي ثِيڒِي إِنُو، مَاشَا مَاڒَا لَّا، \add خنِّي\add* أَذْ ثكَّارْ ثْمسِّي زِي شْبَارْقْ أَكْ-ذ إِسنَّاننْ، أَذْ ثشّْ \add ثِيشجُّورَا ن\add* ثنْڭلْثْ ن لُوبْنَانْ.‘ “   
\b  
\m
\v 16 ڒخُّو خنِّي، كنِّيوْ، \add إِمزْذَاغْ ن شَاكِيمْ\add*، مَاڒَا ثڭِّيمْ س ثِيذتّْ ذ ڒصْفَايثْ \add ؤُمِي\add* ثڭِّيمْ أَبِيمَالِيكْ ذ أَجدْجِيذْ، ؤُ مَاڒَا كنِّيوْ ثڭِّيمْ مْلِيحْ ذِي يَارُوبَّاعْلْ ذ ثَادَّارْثْ نّسْ، ؤُ مَاڒَا كنِّيوْ ثڭِّيمْ ذَايسْ أَمْ مَامّشْ إِسّْذَاهدْجْ،  
\v 17 - أَقَا بَابَا إِمّْنغْ ذِي طّْوعْ نْومْ ؤُشَا إِسبّڒْ ثُوذَارْثْ نّسْ ؤُشَا إِفكّْ كنِّيوْ زڭْ ؤُفُوسْ ن مِيذْيَانْ،  
\v 18 \add مَاشَا\add* كنِّيوْ ثْغوّْغمْ أَسّْ-أَ خْ ثَادَّارْثْ ن بَابَا ؤُ خْ إِجّْ ن وژْرُو أَقَا ثنْغِيمْ أَرَّاوْ نّسْ، سبْعِينْ ن يرْيَازنْ، ؤُ ثڭِّيمْ أَبِيمَالِيكْ، مِّيسْ ن ثَايَّا، ذ أَجدْجِيذْ خْ إِمزْذَاغْ ن شَاكِيمْ، مِينْزِي نتَّا ذ ؤُمَاثْومْ -  
\v 19 مَاڒَا كنِّيوْ ثڭِّيمْ أَسّْ-أَ س ثِيذتّْ ذ ڒصْفَايثْ ذِي يَارُوبَّاعْلْ ذ ثَادَّارْثْ نّسْ، خنِّي أَذْ ثْفَارْحمْ ذِي أَبِيمَالِيكْ ؤُ نتَّا أَذْ إِفَارْحْ ذَايْومْ.  
\v 20 مَاشَا مَاڒَا وَارْ إِدْجِي أَمنِّي، \add خنِّي\add* أَذْ ثكَّارْ ثْمسِّي زِي أَبِيمَالِيكْ أَذْ ثشّْ إِرْيَازنْ ن شَاكِيمْ ذ إِمزْذَاغْ ن لْقلْعَا ؤُشَا أَذْ ثكَّارْ ثْمسِّي زڭْ إِمزْذَاغْ ن شَاكِيمْ ؤُ زِي مَارَّا إِنِّي ذِي لْقلْعَا، أَذْ ثشّْ أَبِيمَالِيكْ!‘ “   
\m
\v 21 \add خنِّي\add* يُويُورْ يُوثَامْ، يَارْوڒْ، إِرُوحْ غَارْ بِي‘رْ. ثُوغَا إِزدّغْ ذِينْ، \add إِڭّْوجْ\add* خْ ؤُمَاسْ أَبِيمَالِيكْ. \f ◼ \fr 9:‏21 \ft \+bd ’خْ ؤُمَاسْ‘\+bd* - س ثْعِيبْرَانِيثْ ’خْ وُوذمْ ن ؤُمَاسْ‘.\f*   
\b  
\m
\v 22 \add ڒَْامِي\add* ثُوغَا إِحكّمْ أَبِيمَالِيكْ خْ إِسْرَائِيل ثْڒَاثَا ن إِسڭّْوُوسَا،  
\v 23 إِسّكّْ أَربِّي إِجّْ ن ڒَارْيَاحْ ذ أَعفَّانْ جَارْ أَبِيمَالِيكْ ذ إِمزْذَاغْ ن شَاكِيمْ. إِمزْذَاغْ ن شَاكِيمْ غْذَارنْ زِي أَبِيمَالِيكْ،  
\v 24 حِيمَا أَغصّبْ، \add نِّي إِتّْوَاڭّنْ إِ\add* سبْعِينْ ن إِحنْجِيرنْ ن يَارُوبَّاعْلْ، ذ إِذَامّنْ نْسنْ أَذْ د-أَسنْ خْ ؤُمَاثْسنْ أَبِيمَالِيكْ، ونِّي ثنْ إِنْغِينْ، ؤُ خْ إِمزْذَاغْ ن شَاكِيمْ، إِنِّي ثُوغَا إِسّْجهْذنْ إِفَاسّنْ نّسْ مَاحنْذْ أَذْ نْغنْ أَيْثْمَاسْ.  
\v 25 إِمزْذَاغْ ن شَاكِيمْ وجْذنْ أَسْ ڒفْخُوخْ خْ ثْقِيشَّاثْ ن إِذُورَارْ ؤُ نِيثْنِي كشّْضنْ مَارَّا ونِّي ذِينْ خَاسنْ إِ غَا إِكّنْ ذ أَبْرِيذْ. أَيَا إِتّْوَانَّا إِ أَبِيمَالِيكْ.  
\v 26 جَاعَالْ، مِّيسْ ن عَابِيذْ، يُوسَا-د أَكْ-ذ أَيْثْمَاسْ ؤُشَا نِيثْنِي ؤُيُورنْ غَارْ شَاكِيمْ ؤُ إِمزْذَاغْ ن شَاكِيمْ تِّيقّنْ ذَايسْ.  
\v 27 نِيثْنِي فّْغنْ غَارْ إِيَّارنْ، ڒقْضنْ ؤُضِيڒْ ذڭْ إِمَارْجَاعنْ نْسنْ،عفّْسنْ خْ ؤُضِيڒْ ؤُشَاغنّْجنْ إِزْڒَانْ ن ڒفْرَاحثْ، ؤُذْفنْ غَارْ ثَادَّارْثْ ن أَربِّي نْسنْ، شِّينْ سْوِينْ ؤُشَا نعْڒنْ أَبِيمَالِيكْ.  
\v 28 ؤُشَا جَاعَالْ، مِّيسْ ن عَابِيذْ، إِنَّا: ”مِينْ \add إِعْنَا نتَّا\add* أَبِيمَالِيكْ ذ مَانْ ونْ \add إِ إِدْجَانْ\add* ذ شَاكِيمْ، أَقَا نشِّينْ أَذْ أَسْ نَاضَارْ؟ مَا وَارْ إِدْجِي نتَّا ذ مِّيسْ ن يَارُوبَّاعْلْ؟ ؤُ مَا وَارْ إِدْجِي زابُولْ ذ لْوَالِي نّسْ؟ سخَّارمْ \add خنِّي\add* إِ يرْيَازنْ ن حَامُورْ، بَابَاسْ ن شَاكِيمْ، مِينْزِي مَايمِّي إِ ذ أَسْ غَا نْسخَّارْ؟  
\v 29 مْڒِي مَاشَا ڒْڭنْسْ-أَ ذڭْ ؤُفُوسْ إِنُو، \add خنِّي\add* نشّْ ثُوغَا خْسغْ أَذْ أَژّْڒغْ خْ أَبِيمَالِيكْ.“ ؤُشَا إِنَّا إِ أَبِيمَالِيكْ: ”أَرْنِي إِ ڒْعسْكَارْ نّشْ ؤُشَا فّغْ \add غَارْ ؤُمنْغِي\add*!“   
\m
\v 30 \add ؤُمِي\add* زابُولْ، ڒْحَاكمْ ن ثنْذِينْثْ، إِسْڒَا أَوَاڒنْ ن جَاعَالْ، مِّيسْ ن عَابِيذْ، يَارْغَا ؤُخيّقْ نّسْ.  
\v 31 نتَّا إِسّكّْ إِرقَّاسنْ غَارْ أَبِيمَالِيكْ ذِي ثْنُوفّْرَا، نَّانْ: ”خْزَارْ، جَاعَالْ، مِّيسْ ن عَابِيذْ، ذ أَيْثْمَاسْ ؤُسِينْ-د غَارْ شَاكِيمْ، ؤُ خْزَارْ، أَقَا سّْغوّْغنْ خَاكْ ثَانْذِينْثْ.  
\v 32 \add خنِّي\add* ڒخُّو، كَّارْ ذِي دْجِيڒثْ-أَ، شكْ ذ ڒْڭنْسْ نِّي غَاركْ إِدْجَانْ، ؤُشَا أڭّْ إِجّْ ن ڒْفخْ ذڭْ إِيَّارْ.  
\v 33 ؤُ غَارْ ثُوفُّوثْ، غَارْ ونْقَارْ ن ثْفُوشْثْ، إِتّْخصَّا أَذْ ثكَّارذْ زِيشْ ؤُشَا عْرفْ خْ ثنْذِينْثْ. ؤُ خْزَارْ، مَاڒَا نتَّا ذ ڒْڭنْسْ إِ غَارسْ أَذْ غَاركْ د-إِفّغْ، أڭّْ خنِّي أَكِيذسْ مِينْ خفْ إِزمَّارْ ؤُفُوسْ نّشْ أَذْ إِڭّْ.“  
\v 34 أَبِيمَالِيكْ ذ مَارَّا ڒْڭنْسْ إِ غَارسْ، إِكَّارْ-د ذِي دْجِيڒثْ ؤُ نِيثْنِي ڭِّينْ إِجّْ ن ڒْفخْ خْ شَاكِيمْ س أَربْعَا ن إِبَاطَايُوننْ.   
\m
\v 35 ؤُ جَاعَالْ، مِّيسْ ن عَابِيذْ، إِفّغْ-د، يُويُورْ غَارْ ثوَّارْثْ ن ثنْذِينْثْ ؤُ أَبِيمَالِيكْ، ذ مَارَّا ڒْڭنْسْ إِ غَارسْ، إِكَّارْ زڭْ ومْشَانْ إِنُّوفَّارنْ.  
\v 36 \add ؤُمِي\add* جَاعَالْ إِژْرَا ڒْڭنْسْ، إِنَّا إِ زابُولْ: ”خْزَارْ، أَقَا إِوْذَانْ هكّْوَانْ-د زِي ثْقِيشَّاثْ ن إِذُورَارْ.“ زابُولْ إِنَّا أَسْ: ”شكْ ثْوَاڒِيذْ ثِيڒِي ن إِذُورَارْ ذ إِوْذَانْ.“  
\v 37 جَاعَالْ يَارْنِي إِسَّاوَاڒْ، إِنَّا: ”خْزَارْ، أَقَا \add إِجّْ ن ؤُبَارُّو\add* ن ڒْڭنْسْ إِهكّْوَا-د زِي ثْعبُّوضْثْ ن ثمُّورْثْ ؤُ إِشْثْ ن ڒْكُومْبَانِييّثْ ثُوسَا-د زڭْ وبْرِيذْ ن ثْشجَّارْثْ ن يِيڭّْ ن إِبزْڭَاونْ.“  
\v 38 خنِّي إِنَّا أَسْ زابُولْ: ”مَانِي إِ دْجَانْ ڒخُّو وَاوَاڒنْ نّشْ إِ زِي ثنِّيذْ: ’مِينْ \add إِعْنَا\add* أَبِيمَالِيكْ، أَقَا نشِّينْ أَذْ أَسْ نْسخَّارْ؟ مَا وَارْ دْجِينْ إِنَا ذ ڒْڭنْسْ إِ ثسّحْقَارذْ شكْ؟ فّغْ \add خنِّي\add* ڒخُّو ؤُ ثمّنْغذْ أَكِيذسْ!“  
\v 39 ؤُشَا إِفّغْ جَاعَالْ زَّاثْ إِ وُوذمْ ن إِمزْذَاغْ ن شَاكِيمْ ؤُشَا إِمّْنغْ أَكْ-ذ أَبِيمَالِيكْ.  
\v 40 إِضْفَارْ إِ-ث أَبِيمَالِيكْ، مِينْزِي نتَّا يَارْوڒْ زَّاثْ إِ وُوذمْ نّسْ ؤُشَا أَطَّاسْ ن يِينِّي إِتّْوَاسّْنُوقّْبنْ \add س سِّيفْ\add* وْضَانْ أَڒْ أَذَافْ ن ثوَّارْثْ ن ثنْذِينْثْ.  
\v 41 إِقِّيمْ أَبِيمَالِيكْ ذِي أَرُومَا ؤُ زابُولْ يُوژّڒْ خْ جَاعَالْ ذ أَيْثْمَاسْ أَڒَامِي وَارْ زمَّارنْ أَذْ قِّيمنْ عَاذْ ذِي شَاكِيمْ.   
\m
\v 42 ثِيوشَّا نّسْ، إِمْسَارْ، ڒْڭنْسْ إِفّغْ غَارْ إِيَّارْ. أَيَا عَاوْذنْ ث إِ أَبِيمَالِيكْ.  
\v 43 \add خنِّي\add* إِكْسِي نتَّا ڒْڭنْسْ، إِبْضَا ث خْ ثْڒَاثَا ن إِبَاطَايُوننْ ؤُشَا إِڭَّا إِجّْ ن ڒْفخْ ذڭْ إِيَّارْ ؤُشَا نتَّا إِخزَّارْ، أَقَا ڒْڭنْسْ إِفّغْ زِي ثنْذِينْثْ. \add خنِّي\add* إِكَّارْ ضِيدّْ نْسنْ ؤُشَا إِغْڒبْ خَاسنْ.  
\v 44 \add مِينْزِي\add* أَبِيمَالِيكْ ذ إِبَاطَايُوننْ إِ غَارسْ، فّْغنْ ؤُشَا ؤُيُورنْ أَذْ بدّنْ غَارْ ثوَّارْثْ ن ثنْذِينْثْ، ؤُ ثْنَاينْ ن إِبَاطَايُوننْ نّغْنِيثْ ؤُذْفنْ خْ يِينِّي \add ثُوغَا\add* ذڭْ إِيَّارْ ؤُشَا قْضَانْ خَاسنْ.  
\v 45 أَسّْ نِّي مَارَّا إِمّْنغْ أَبِيمَالِيكْ أَكْ-ذ ثنْذِينْثْ. نتَّا إِطّفْ إِ-ت، إِنْغَا ڒْڭنْسْ إِ ذَايسْ \add إِدْجَانْ\add*. \add خنِّي\add* إِهْذمْ ثَانْذِينْثْ ؤُشَا إِسُّويسْ خَاسْ ثَامدْجَاحْثْ.   
\m
\v 46 \add ؤُمِي\add* ث سْڒِينْ مَارَّا إِمزْذَاغْ ن لْبُورْجْ، ؤُذْفنْ غَارْ أَمْشَانْ ن وَارْوَاڒْ ن ثَادَّارْثْ ن أَربِّي \add نْسنْ\add* بَارِيثْ. \f ◼ \fr 9:‏46 \ft \+bd ’بَارِيثْ‘\+bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’ڒْعَاهْذْ‘. س ؤُينِّي ’أَربِّي ن ڒْعَاهْذْ‘.\f*  
\v 47 إِتّْوَانَّا إِ أَبِيمَالِيكْ، أَقَا مَارَّا إِمزْذَاغْ ن لْبُورْجْ ن شَاكِيمْ ڭِّينْ أَذْ مُوننْ \add ذِينْ\add*.  
\v 48 \add خَاسْ\add* ؤُشَا إِڭعّذْ أَبِيمَالِيكْ أَذْرَارْ ن صَالْمُونْ، نتَّا أَكْ-ذ مَارَّا ڒْڭنْسْ إِ غَارسْ \add إِدْجَانْ\add*، ؤُ أَبِيمَالِيكْ إِطّفْ شَّاقُورْ نّسْ ذڭْ ؤُفُوسْ ؤُشَا إِقْڒعْ إِشْثْ ن ثْصطَّا ن ثْشجَّارْثْ، إِكْسِي ت ؤُ إِسَّارْسْ إِ-ت خْ ثغْرُوضْثْ نّسْ، إِنَّا إِ ڒْڭنْسْ نّسْ: ”مِينْ ثژْرِيمْ ڭِّيغْ نشّْ، قدْجْقمْ، ڭّمْ \add ث\add* ؤُڒَا ذ كنِّيوْ أَمْ نشّْ!“  
\v 49 ؤُ مَارَّا ڒْڭنْسْ، كُوڒْ أَرْيَازْ، إِقْڒعْ ثَاصطَّا نّسْ ؤُشَا ضْفَارنْ أَبِيمَالِيكْ ؤُ سَّارْسنْ ثنْثْ غَارْ ومْشَانْ ن وَارْوَاڒْ ؤُشَا قّذْمنْ أَسنْ ثِيمسِّي خْ ومْشَانْ ن وَارْوَاڒْ أَڒَامِي مُّوثنْ ؤُڒَا ذ مَارَّا إِرْيَازنْ ن لْبُورْجْ ن شَاكِيمْ، عْڒَاحَاڒْ أَڒفْ ن يرْيَازنْ ذ ثمْغَارِينْ.   
\m
\v 50 إِرُوحْ أَبِيمَالِيكْ \add عَاوذْ\add* غَارْ ثَابَاصْ، إِوْثَا إِقِيضَانْ نّسْ غَارْ ثَابَاصْ ؤُشَا إِطّفْ إِ-ت.  
\v 51 ثُوغَا ذِي ڒْوسْطْ ن ثنْذِينْثْ إِجّْ ن لْبُورْجْ إِمتّْننْ ؤُ أَروْڒنْ غَارسْ مَارَّا إِرْيَازنْ ذ ثمْغَارِينْ ذ مَارَّا إِمزْذَاغْ ن ثنْذِينْثْ ؤُشَا نِيثْنِي بلّْعنْ خَاسنْ، نْيِينْ خْ ثْزقَّا ن لْبُورْجْ.  
\v 52 يِيوضْ أَبِيمَالِيكْ غَارْ لْبُورْجْ ؤُ إِمّْنغْ أَكِيذسْ، \add مَاشَا\add* خْمِي نتَّا د-إِقَارّبْ غَارْ ثوَّارْثْ ن لْبُورْجْ حِيمَا أَذْ أَسْ إِقّذْ ثِيمسِّي،  
\v 53 ثنْضَارْ إِشْثْ ن ثمْغَارْثْ إِشْثْ ن ثَاصْضَارْثْ ن ثْسِيرْثْ يُوعْڒَانْ خْ ؤُزدْجِيفْ ن أَبِيمَالِيكْ ؤُشَا ثڒْبزْ أَسْ أَشقُّوفْ \add ن ؤُزدْجِيفْ\add*. \x ◘ \xo 9:‏53 \xt 2 صم. 11‏:‏21\x*  
\v 54 ذغْيَا إِڒَاغَا نتَّا إِ ؤُمْسخَّارْ \add نّسْ\add* ونِّي ذ أَسْ يَاربُّونْ ڒسْنَاحْ، إِنَّا أَسْ: ”جْبدّْ سِّيفْ نّشْ ؤُشَا نغْ أَيِي، حِيمَا وَارْ خَافِي قَّارنْ: ’إِشْثْ ثمْغَارْثْ ثنْغَا إِ-ث‘.“ ؤُشَا أَحُوذْرِي نّسْ إِسّْنُوقّبْ إِ-ث ؤُشَا إِمُّوثْ.  
\v 55 \add ؤُمِي\add* ژْرِينْ إِرْيَازنْ ن إِسْرَائِيل، أَقَا أَبِيمَالِيكْ إِمُّوثْ، فّْغنْ-د، \add كُوڒْ إِجّْ ن\add* ورْيَازْ غَارْ ومْشَانْ \add ن ثْزذِّيغْثْ\add* نّسْ.   
\m
\v 56 \add أَمُّو\add* إِ إِخدْجصْ أَربِّي ثُوعفّْنَا ن أَبِيمَالِيكْ نِّي إِڭَّا إِ بَابَاسْ ؤُمِي إِنْغَا سبْعِينْ ن أَيْثْمَاسْ.  
\v 57 مَارَّا ثُوعفّْنَا إِ إِڭِّينْ إِرْيَازنْ ن شَاكِيمْ يَارّْ إِ-ت أَربِّي خْ ؤُزدْجِيفْ نْسنْ ؤُ نّعْڒثْ ن يُوثَامْ، مِّيسْ ن يَارُوبَّاعْلْ، ثوْضَا-د خَاسنْ.   
\b  
\b  
\m  
\c 10
\s1 ثُولَاعْ، يَا‘إِرْ ذ يَافْثَاحْ  
\m
\v 1 أَوَارْنِي أَبِيمَالِيكْ إِكَّارْ \bd ثُولَاعْ\bd*، مِّيسْ ن فُووَا، مِّيسْ ن ذُوذُو، إِجّْ ن ورْيَازْ زِي \add ثقْبِيتْشْ ن\add* إِسَّاكَارْ، حِيمَا أَذْ إِسّنْجمْ إِسْرَائِيل. نتَّا ثُوغَا إِزدّغْ ذِي شَامِيرْ خْ إِذُورَارْ ن إِفْرَايِيمْ.  
\v 2 نتَّا ثُوغَا ذ ڒْقَاضِي خْ إِسْرَائِيل ثْڒَاثَا ؤُ-عِيشْرِينْ ن إِسڭّْوُوسَا. \add خنِّي\add* إِمُّوثْ، إِتّْوَانْضڒْ ذِي شَامِيرْ.   
\m
\v 3 أَوَارْنِي أَسْ إِكَّارْ \bd يَا‘إِرْ\bd*، أَجِيلْعَاذِي. نتَّا ثُوغَا ذ ڒْقَاضِي خْ إِسْرَائِيل ثْنَاينْ ؤُ-عِيشْرِينْ ن إِسڭّْوُوسَا.  
\v 4 نتَّا ثُوغَا غَارسْ ثْڒَاثِينْ ن إِحنْجِيرنْ، إِنِّي إِنَّاينْ خْ ثْڒَاثِينْ ن إِغْيَاڒْ ؤُ غَارْسنْ ثْڒَاثِينْ ن ثْندَّامْ، تّْڒَاغَانْ أَسنْثْ ’ذْشُورَاثْ ن يَا‘إِرْ‘ أَڒْ أَسّْ-أَ. أَقَا أَثنْثْ ذِي ثمُّورْثْ ن جِيلْعَاذْ.  
\v 5 ؤُشَا إِمُّوثْ يَا‘إِرْ، نضْڒنْ ث ذِي قَامُونْ.   
\b  
\m
\v 6 أَيْثْ ن إِسْرَائِيل أَرْنِينْ أَذْ ڭّنْ مِينْ \add إِدْجَانْ\add* ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي. نِيثْنِي سخَّارنْ إِ ’إِبَاعْلنْ‘ ذ ’عَاشْثَارُوثِينْ‘ ؤُڒَا ذ إِربِّيثنْ ن أَرَامْ ذ إِربِّيثنْ ن صِيذُونْ ذ إِربِّيثنْ ن مُوآبَ ذ إِربِّيثنْ ن عَامُّونْ ذ إِربِّيثنْ ن إِفِيلِيسْطِينِييّنْ. نِيثْنِي جِّينْ سِيذِي ؤُ وَارْ ذ أَسْ سخَّارنْ \add عَاذْ\add*. \x ◘ \xo 10:‏6 \xt ڒقض. 2‏:‏11؛ 3‏:‏7؛ 4‏:‏1؛ 6‏:‏1\x*  
\v 7 يَارْغَا وغْضَابْ ن سِيذِي خْ إِ إِسْرَائِيل ؤُ نتَّا إِڭَّا إِ-ثنْ ذڭْ ؤُفُوسْ ن إِفِيلِيسْطِينِييّنْ ؤُ ذڭْ ؤُفُوسْ ن أَيْثْ ن عَامُّونْ.  
\v 8 ذڭْ ؤُسڭّْوَاسْ نِّي ڒبْزنْ ؤُ أَرْژِينْ نِيثْنِي أَيْثْ ن إِسْرَائِيل. \add أَمُّو إِ إِڭِّينْ نِيثْنِي\add* ثْمنْطَاشْ ن إِسڭّْوُوسَا أَكْ-ذ أَيْثْ ن إِسْرَائِيل إِنِّي \add إِدْجَانْ\add* خْ ؤُجمَّاضْ ن لْ-ؤُرْذُونْ، ذِي ثمُّورْثْ ن إِمُورِييْ\add ينْ\add*، ثنِّي ذِي جِيلْعَاذْ.  
\v 9 ؤُشَا \add عَاوذْ\add* ژْوَانْ أَيْثْ ن عَامُّونْ لْ-ؤُرْذُونْ حِيمَا أَذْ مّنْغنْ ؤُڒَا أَكْ-ذ يَاهُوذَا ذ بِينْيَامِينْ ذ ثَادَّارْثْ ن إِفْرَايِيمْ \add أَڒَامِي\add* إِتّْوَاحْسَارْ إِسْرَائِيل أَطَّاسْ.  
\v 10 \add خنِّي\add* سْغُوينْ أَيْثْ ن إِسْرَائِيل غَارْ سِيذِي، نَّانْ: ”نشِّينْ نخْضَا أَكِيذكْ، مِينْزِي نشِّينْ نسْمحْ ذِي أَربِّي نّغْ، نْسخَّارْ ’إِبَاعْلنْ‘.“  
\v 11 \add خنِّي\add* إِنَّا سِيذِي إِ أَيْثْ ن إِسْرَائِيل: ”مَا وَارْ \add كنِّيوْ سّْنجْمغْ\add* زڭْ \add ؤُفُوسْ ن\add* إِمِيصْرِييّنْ ذ إِمُورِييّنْ ؤُ زڭْ \add ؤُفُوسْ ن\add* أَيْثْ ن عَامُّونْ ذ إِفِيلِيسْطِينِييّنْ  
\v 12 ؤُ زڭْ \add ؤُفُوسْ ن أَيْثْ ن\add* صِيذُونْ ؤُ زڭْ \add ؤُفُوسْ ن\add* أَيْثْ ن عَامَالِيقْ ذ إِمَاعُونِييّنْ، إِنِّي ثُوغَا كنِّيوْ إِحْصَارنْ ؤُمِي كنِّيوْ إِ ذ غَارِي ثسْغُويمْ، مَا \add خنِّي\add* نشّْ وَارْ سّْنجْمغْ كنِّيوْ زڭْ ؤُفُوسْ نْسنْ؟  
\v 13 \add وَاخَّا أَمنِّي\add* كنِّيوْ ثْسمْحمْ ذَايِي ؤُ ثْسخَّارمْ إِ إِربِّيثنْ نّغْنِي. س ؤُيَا وَارْ كنِّيوْ سّنْجِيمغْ عَاذْ. \x ◘ \xo 10:‏13 \xt أَعَوذ. 32‏:‏15؛ إِرْم. 2‏:‏13\x*  
\v 14 ؤُيُورمْ، ثسْغُويمْ غَارْ إِربِّيثنْ نِّي ثَارشّْحمْ إِ يِيخفْ نْومْ. جّمْ ثنْ أَذْ كنِّيوْ سّْنجْمنْ ذِي ڒْوقْثْ ن ڒحْصَارثْ نْومْ.“  
\v 15 \add مَاشَا\add* أَيْثْ ن إِسْرَائِيل نَّانْ إِ سِيذِي: ”نشِّينْ أَقَا نخْضَا. أڭّْ \bd شكْ\bd* أَكِيذْنغْ مَارَّا مِينْ إِ ذ أَشْ إِعجْبنْ ذِي ثِيطَّاوِينْ نّشْ، مْغِيرْ فكّْ أَنغْ أَسّْ-أَ وَاهَا!“  
\v 16 ؤُ نِيثْنِي سِّيڭّْوجنْ إِربِّيثنْ إِغْرِيبنْ زِي ڒْوسْطْ نْسنْ ؤُشَا سخَّارنْ إِ سِيذِي. \add خنِّي\add* وَارْ إِزمَّارْ ڒعْمَارْ نّسْ أَذْ ثَارْبُو \add عَاذْ\add* ڒغْبنْ ن إِسْرَائِيل.  
\v 17 تّْوَاسْمُوننْ أَيْثْ ن عَامُّونْ ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِي جِيلْعَاذْ. ؤُڒَا ذ أَيْثْ ن إِسْرَائِيل مُوننْ ؤُ نِيثْنِي وْثِينْ إِقِيضَانْ نْسنْ ذِي مِيصْفَا.  
\v 18 \add خنِّي\add* إِنَّا ڒْڭنْسْ، ڒْحُوكَّامْ ن جِيلْعَاذْ، إِ وَايَاوْيَا: ”مَانْ أَرْيَازْ إِ غَا إِمّنْغنْ ذ أَمزْوَارُو أَكْ-ذ أَيْثْ ن عَامُّونْ؟ نتَّا أَذْ إِذْوڒْ ذ أَزدْجِيفْ خْ مَارَّا إِمزْذَاغْ ن جِيلْعَاذْ.“ \x ◘ \xo 10:‏18 \xt ڒقض. 11‏:‏6، 9، 10، 11\x*   
\b  
\b  
\m  
\c 11
\s1 يَافْثَاحْ ذ أَيْثْ ن عَامُّونْ  
\m
\v 1 \bd يَافْثَاحْ\bd*، زِي \add ثمُّورْثْ ن\add* جِيلْعَاذْ، ثُوغَا-ث ذ إِجّْ ن بُو-ثغْرُوضْثْ إِمحْضنْ، \add مَاشَا\add* نتَّا \add ثُوغَا\add* ذ مِّيسْ ن إِشْثْ ن ثمْغَارْثْ ن فَارْقْ-شّْغڒْ. جِيلْعَاذْ أَقَا إِجَّا-د يَافْثَاحْ \add غَارسْ\add*. \x ◘ \xo 11:‏1 \xt عبر. 11‏:‏32\x*  
\v 2 ؤُڒَا ذ ثَامْغَارْثْ ن جِيلْعَاذْ ثُورُووْ أَسْ-د إِحنْجِيرنْ. \add ؤُمِي\add* إِحنْجِيرنْ ن ثمْغَارْثْ-أَ مْغَارنْ، ؤُژّْڒنْ خْ يَافْثَاحْ، نَّانْ أَسْ: ”شكْ وَارْ ثتّطِّيفذْ شَا ثَاسْغَارْثْ ذِي ثَادَّارْثْ ن بَابَاثْنغْ، مَاغَارْ شكْ ذ مِّيسْ ن إِشْثْ ن ثمْغَارْثْ نّغْنِيثْ.“  
\v 3 ؤُشَا يَارْوڒْ يَافْثَاحْ زڭْ وُوذمْ ن أَيْثْمَاسْ ؤُ نتَّا إِقِّيمْ إِزْذغْ ذِي ثمُّورْثْ ن طُوبْ. ؤُشَا إِشْثْ ن ثوْرَاوْثْ ن يرْيَازنْ خْوَانْ ؤُسِينْ-د غَارْ يَافْثَاحْ، فّْغنْ-د أَكِيذسْ.  
\v 4 أَوَارْنِي \add أَطَّاسْ ن\add* وُوسَّانْ إِمْسَارْ، كَّارنْ أَيْثْ ن عَامُّونْ مّنْغنْ أَكْ-ذ إِسْرَائِيل.  
\v 5 ؤُشَا إِمْسَارْ، ؤُمِي أَيْثْ ن عَامُّونْ مّنْغنْ أَكْ-ذ إِسْرَائِيل، أَقَا إِمْغَارنْ ن جِيلْعَاذْ طّْفنْ أَبْرِيذْ حِيمَا أَذْ أَوْينْ يَافْثَاحْ زِي ثمُّورْثْ ن طُوبْ.  
\v 6 نِيثْنِي نَّانْ إِ يَافْثَاحْ: ”أَسْ-د، إِڒِي ذ أَكُومَانْذَارْ نّغْ ؤُ أجّْ أَنغْ أَذْ نمّْنغْ أَكْ-ذ أَيْثْ ن عَامُّونْ.“  
\v 7 يَافْثَاحْ إِنَّا إِ إِمْغَارنْ ن جِيلْعَاذْ: ”مَا وَارْ ذ أَيِي ثْعِيفّمْ ؤُ ثُوژّْڒمْ خَافِي زِي ثَادَّارْثْ ن بَابَا؟ مَايمِّي إِ د غَارِي ثُوسِيمْ ڒخُّو، \add ڒخُّو\add* ؤُمِي ثدْجَامْ ذِي ڒحْصَارثْ؟“  
\v 8 أَرِّينْ-د إِمْغَارنْ ن جِيلْعَاذْ خْ يَافْثَاحْ: ”س ؤُيَا إِ د غَاركْ نُوسَا ڒخُّو، \add حِيمَا\add* شكْ أَكِيذْنغْ ثُويُورذْ أَذْ ثمّنْغذْ أَكْ-ذ أَيْثْ ن عَامُّونْ. شكْ أَذْ غَارْنغْ ثِيڒِيذْ ذ أَزدْجِيفْ خْ مَارَّا إِمزْذَاغْ ن جِيلْعَاذْ.“  
\v 9 \add خنِّي\add* إِنَّا يَافْثَاحْ إِ إِمْغَارنْ ن جِيلْعَاذْ: ”مَاڒَا كنِّيوْ ثَارِّيمْ أَيِي غَارْ ؤُمنْغِي أَكْ-ذ أَيْثْ ن عَامُّونْ ؤُ سِيذِي إِسلّمْ إِ-ثنْ زَّاثْ إِ وُوذمْ إِنُو، أَذْ ذوْڒغْ ذ أَزدْجِيفْ نْومْ!“  
\v 10 إِمْغَارنْ ن جِيلْعَاذْ نَّانْ إِ يَافْثَاحْ: ”أَذْ يِيڒِي سِيذِي ذ ونِّي إِتّسْڒَانْ جَارْ أَنغْ. \add ؤُشْثْ خَانغْ\add* مَاڒَا وَارْ نتّڭّْ عْلَاحْسَابْ أَوَاڒنْ نّشْ.“  
\v 11 خَاسْ ؤُشَا يُويُورْ يَافْثَاحْ أَكْ-ذ إِمْغَارنْ ن جِيلْعَاذْ ؤُ ڒْڭنْسْ إِڭَّا إِ-ث ذ أَزدْجِيفْ ذ أَكُومَانْذَارْ خْ يِيخفْ نّسْ. ؤُشَا إِسِّيوڒْ يَافْثَاحْ مَارَّا أَوَاڒنْ نّسْ زَّاثْ إِ وُوذمْ ن سِيذِي ذِي مِيصْفَا.  
\v 12 ؤُشَا إِسّكّْ يَافْثَاحْ إِرقَّاسنْ غَارْ ؤُجدْجِيذْ ن أَيْثْ ن عَامُّونْ، إِنَّا: ”مِينْ ذِينْ جَارْ أَيِي ذ شكْ، أَقَا شكْ ثفّْغذْ، حِيمَا أَذْ ثمّنْغذْ ضِيدّْ إِ ثمُّورْثْ إِنُو؟“  
\v 13 إِنَّا ؤُجدْجِيذْ ن أَيْثْ ن عَامُّونْ إِ إِرقَّاسنْ ن يَافْثَاحْ: ”مِينْزِي إِسْرَائِيل ثُوغَا إِطّفْ ثَامُّورْثْ إِنُو زڭْ أَرْنُونْ أَڒْ يَابُّوقْ ؤُ أَڒْ لْ-ؤُرْذُونْ، ؤُمِي د-إِفّغْ زِي مِيصْرَا. أَرّْ أَيِي-ت ڒخُّو س ڒهْنَا!“  
\v 14 إِسّكّْ يَافْثَاحْ عَاوذْ إِرقَّاسنْ غَارْ ؤُجدْجِيذْ ن أَيْثْ ن عَامُّونْ.  
\v 15 إِنَّا أَسْ: ”أَمُّو إِ إِقَّارْ يَافْثَاحْ: ’إِسْرَائِيل وَارْ إِطِّيفْ شَا ثَامُّورْثْ ن مُوآبَ ذ ثمُّورْثْ ن أَيْثْ ن عَامُّونْ، \x ◘ \xo 11:‏15 \xt ڒخْڒ. 21‏:‏13؛ أَعَوذ. 2‏:‏9، 19\x*  
\v 16 مِينْزِي ؤُمِي د-فّْغنْ زِي مِيصْرَا، يُويُورْ إِسْرَائِيل ذِي ڒخْڒَا أَڒْ ڒبْحَارْ ن ثلْڭَا ؤُشَا \add غَارْ ؤُنڭَّارْ\add* يُوسَا-د غَارْ قَاذَاشْ.  
\v 17 \add خنِّي\add* إِسّكّْ إِسْرَائِيل إِرقَّاسنْ غَارْ ؤُجدْجِيذْ ن إِذُومْ، إِنَّا: ’أجّْ أَيِي أَذْ شُوقغْ ذِي ثمُّورْثْ نّشْ!‘ مَاشَا أَجدْجِيذْ ن إِذُومْ وَارْ إِسْڒِي شَا. إِسّكّْ عَاوذْ \add إِرقَّاسنْ\add* غَارْ ؤُجدْجِيذْ ن مُوآبَ ؤُشَا ؤُڒَا ذ نتَّا وَارْ إِوْشْ تّسْرِيحْ. \add أَمُّو\add* إِقِّيمْ إِسْرَائِيل ذِي قَاذَاشْ. \x ◘ \xo 11:‏17 \xt ڒخْڒ. 20‏:‏17\x*  
\v 18 ؤُشَا يُويُورْ \add ڒْْڭنْسْ\add* ذِي ڒخْڒَا، إِنّضْ إِ ثمُّورْثْ ن إِذُومْ ذ ثمُّورْثْ ن مُوآبَ ؤُشَا يُوسَا-د \add أَمُّو\add* غَارْ ؤُغزْذِيسْ ن ثمُّورْثْ ن مُوآبَ \add إِ إِدْجَانْ\add* غَارْ مَانِي ثْنقَّارْ ثْفُوشْثْ ؤُشَا نِيثْنِي وْثِينْ إِقِيضَانْ نْسنْ أَغِيرِينْ إِ أَرْنُونْ، مَاشَا وَارْ د-ؤُسِينْ ذَاخڒْ إِ ويْمِيرْ \add ن ثمُّورْثْ\add* ن مُوآبَ، مَاغَارْ أَرْنُونْ ذ أَيْمِيرْ ن مُوآبَ.  
\v 19 \add خنِّي\add* إِسّكّْ إِسْرَائِيل إِرقَّاسنْ غَارْ سِيحُونْ، أَجدْجِيذْ ن إِمُورِييّنْ، أَجدْجِيذْ ن حَاشْبُونْ، ؤُشَا إِنَّا أَسْ إِسْرَائِيل: ’أجّْ أَنغْ أَذْ نْشُوقْ ثَامُّورْثْ نّشْ أَڒْ أَمْشَانْ \add إِ غَارْ إِ غَا ؤُيُورغْ\add*.‘ \x ◘ \xo 11:‏19 \xt ڒخْڒ. 21‏:‏22؛ أَعَوذ. 2‏:‏26\x*  
\v 20 \add مَاشَا\add* سِيحُونْ وَارْ إِتِّيقّْ إِسْرَائِيل أَڒْ إِ غَا إِشُوقْ ثَامُّورْثْ نّسْ \add وَاهَا\add*. ؤُ سِيحُونْ إِسّْمُونْ مَارَّا ڒْڭنْسْ نّسْ ؤُشَا نِيثْنِي وْثِينْ إِقِيضَانْ نْسنْ ذِي جَاهَاصْ. ؤُشَا \add خنِّي\add* إِمّْنغْ نتَّا أَكْ-ذ إِسْرَائِيل.  
\v 21 سِيذِي، أَربِّي ن إِسْرَائِيل، إِڭَّا \add خنِّي\add* سِيحُونْ ذ مَارَّا ڒْڭنْسْ نّسْ ذڭْ ؤُفُوسْ ن إِسْرَائِيل ؤُشَاغڒْبنْ خَاسنْ. مَارَّا ثَامُّورْثْ ن إِمُورِييْ\add ينْ\add*، إِنِّي ثُوغَا إِزدّْغنْ ذِي ثمُّورْثْ نِّي، إِطّفْ إِ-ت إِسْرَائِيل ذ ڒْوَارْثْ.  
\v 22 نِيثْنِي طّْفنْ مَارَّا ثَامُّورْثْ ن إِمُورِييْ\add ينْ\add* ذ ثَاسْغَارْثْ، زڭْ أَرْنُونْ أَڒْ يَابُّوقْ ؤُ زِي ڒخْڒَا أَڒْ لْ-ؤُرْذُونْ. \x ◘ \xo 11:‏22 \xt أَعَوذ. 2‏:‏36\x*  
\v 23 \add خنِّي\add* ڒخُّو، أَقَا يُوژّڒْ سِيذِي، أَربِّي ن إِسْرَائِيل، خْ إِمُورِييْ\add ينْ\add* زَّاثْ إِ وُوذمْ ن ڒْڭنْسْ ن إِسْرَائِيل زِي ڒْوَارْثْ نْسنْ ؤُ مَا شكْ \add خنِّي\add* أَذْ ت ثطّْفذْ ذ ثَاسْغَارْثْ؟  
\v 24 مَا وَارْ ثطِّيفذْ شَا ذ ثَاسْغَارْثْ مِينْ ذ أَشْ غَا إِوْشْ أَربِّي نّشْ كَامُوشْ ذ ڒْوَارْثْ؟ \add أَمُّو\add* إِ غَا نطّفْ مَارَّا ذ ڒْوَارْثْ مِينْ ذ أَنغْ غَا إِوْشْ سِيذِي، أَربِّي نّغْ، ذ ڒْوَارْثْ.  
\v 25 خنِّي ڒخُّو، مَا شكْ خَارْ س وَاطَّاسْ خْ بَالَاكْ، مِّيسْ ن صِيفُّورْ، أَجدْجِيذْ ن مُوآبَ؟ مَا نتَّا \add عمَّارْصْ مَا\add* إِمْشُوبّشْ أَكْ-ذ إِسْرَائِيل؟ مَا \add عمَّارْصْ مَا\add* إِمّْنغْ أَكِيذْسنْ؟ \x ◘ \xo 11:‏25 \xt ڒخْڒ. 22‏:‏2\x*  
\v 26 إِسْرَائِيل ثُوغَا إِزْذغْ عَاذْ ثڒْثْ-مْيَا ن إِسڭّْوُوسَا ذِي حَاشْبُونْ ؤُ ذِي ثْندَّامْ إِ غَارسْ د-إِقّْننْ ؤُ ذِي عَارُوعِيرْ ذ ثْندَّامْ إِ غَارسْ د-إِقّْننْ ؤُ ذِي مَارَّا ثِيندَّامْ نِّي \add إِدْجَانْ\add* غَارْ ثْمُووَّا ن أَرْنُونْ. مَايمِّي وَارْ ثنْثْ ثْفكّمْ \add خنِّي\add* ذِي مَارَّا ڒْوقْثْ نِّي؟  
\v 27 \bd نشّْ\bd* وَارْ كِيكْ خْضِيغْ، \add مَاشَا\add* شكْ ثڭّذْ أَيِي ڒْغَارْ ؤُمِي أَكِيذِي ثمّنْغذْ. سِيذِي، ونِّي ذ ڒْقَاضِي، أَذْ إِحْكمْ أَسّْ-أَ جَارْ أَيْثْ ن إِسْرَائِيل ؤُ جَارْ أَيْثْ ن عَامُّونْ!“  
\v 28 \add مَاشَا\add* أَجدْجِيذْ ن أَيْثْ ن عَامُّونْ وَارْ إِسْڒِي غَارْ وَاوَاڒنْ نِّي ذ أَسْ د-إِسّكّْ يَافْثَاحْ \add س ؤُفُوسْ ن إِجّْ ن ؤُرقَّاسْ\add*.  
\v 29 ؤُشَا إِهْوَا-د أَرُّوحْ ن سِيذِي خْ يَافْثَاحْ ؤُ نتَّا إِژْوَا جِيلْعَاذْ ذ مَانَاسَّا. نتَّا إِژْوَا \add عَاوذْ\add* خْ مِيصْفَا ذِي جِيلْعَاذْ ؤُشَا إِژْوَا \add خنِّي\add* غَارْ أَيْثْ ن عَامُّونْ.  
\v 30 ؤُشَا إِوَاعْذْ يَافْثَاحْ إِجّْ ن لْوَاعْذْ إِ سِيذِي، إِنَّا: ”مَاڒَا شكْ أَذْ ثڭّذْ أَيْثْ ن عَامُّونْ قَاعْ ذڭْ ؤُفُوسْ إِنُو،  
\v 31 \add خنِّي\add*، مَاڒَاعقْبغْ-د ذِي ڒهْنَا زڭْ أَيْثْ ن عَامُّونْ، مِينْ إِ د غَا إِفّْغنْ زِي ثوُّورَا ن ثَادَّارْثْ إِنُو حِيمَا أَذْ كِيذِي إِمّڒْقَا، أَذْ يِيڒِي إِ سِيذِي ؤُ نشّْ أَذْ أَسْ ث قدّْمغْ ذ ثَاسْغَارْثْ ن وشْمَاضْ.“   
\m
\v 32 \add خَاسْ ؤُشَا\add* إِژْوَا يَافْثَاحْ غَارْ أَيْثْ ن عَامُّونْ حِيمَا أَذْ كِيسنْ إِمّْنغْ ؤُشَا سِيذِي إِڭَّا إِ-ثنْ ذڭْ ؤُفُوسْ نّسْ.  
\v 33 نتَّا إِغْڒبْ خَاسنْ زِي عَارُوعِيرْ أَڒْ مَانِي ثِيوْضذْ غَارْ مِينِّيثْ، عِيشْرِينْ ن ثْندَّامْ، أَڒْ أَبَالْ-كُورُومْ، أَقَا-ت ذ إِشْثْ ن ثشْثِي ذ ثَامقّْرَانْثْ أَطَّاسْ. \add أَمُّو\add* إِ د-تّْوَاسّهْوَانْ أَيْثْ ن عَامُّونْ زَّاثْ إِ وُوذمْ ن أَيْثْ ن إِسْرَائِيل. \f ◼ \fr 11:‏33 \ft \+bd ’أَبَالْ-كُورُومْ‘\+bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’ڒوْضَا ن (إِحْوِيشنْ ن) ثْزَايَارِينْ‘.\f*   
\m
\v 34 ؤُمِي د-يُوسَا يَافْثَاحْ غَارْ مِيصْفَا غَارْ ثَادَّارْثْ نّسْ، خْزَارْ، ثفّغْ-د غَارسْ يدْجِيسْ حِيمَا أَذْ ث-إِ-د ثڒْقَا بَارَّا س إِبنْذِيرنْ ذ شّْضِيحْ \add س نُّوبْثَاثْ\add*. نتَّاثْ ثُوغَا ذ أَينِّي غَارسْ \add ن يدْجِيسْ\add*، نتَّا ثُوغَا وَارْ غَارسْ أَحنْجِيرْ ؤُڒَا ذ ثَاحنْجِيرْثْ نّغْنِيثْ.  
\v 35 \add ؤُمِي\add* ت إِژْرَا، إِشَارّڭْ أَرُّوضْ نّسْ، إِنَّا: ”أَ وَايَّاوْ، يدْجِي، شمْ ثسّهْوِيذْ أَيِي-د أَطَّاسْ ؤُ ثْذوْڒذْ غَارْ يِينِّي إِ ذ أَيِي إِتّڭّنْ ڒحْڒِيقْ مِينْزِي نشّْ أَرْزْمغْ أَقمُّومْ إِنُو إِ سِيذِي، وَارْ زمَّارغْ أَذْ د-ذوْڒغْ \add عَاذْ\add*.“  
\v 36 نتَّاثْ ثنَّا أَسْ: ”بَابَا إِنُو! \add مَاڒَا\add* شكْ ثَارْزْمذْ أَقمُّومْ نّشْ إِ سِيذِي، \add خنِّي\add* أڭّْ كِيذِي عْلَاحْسَابْ \add أَوَاڒْ\add* إِ د-إِفّْغنْ زڭْ ؤُقمُّومْ نّشْ، مَاغَارْ إِنْثَاقمْ سِيذِي قَاعْ ذِي طّْوعْ نّشْ خْ ڒْعذْيَانْ نّشْ، خْ أَيْثْ ن عَامُّونْ.“  
\v 37 ؤُ نتَّاثْ ثنَّا \add عَاوذْ\add* إِ بَابَاسْ: ”إِڒِي أَذْ كِيذِي إِتّْوَاڭّْ \add عْلَاحْسَابْ\add* أَوَاڒْ-أَ. أجّْ أَيِي ثْنَاينْ ن إِيُورنْ، \add مَاحنْذْ\add* نشّْ أَذْ ؤُيُورغْ، أَذْ د-هْوِيغْ \add مَاحنْذْ\add* أَذْ رُوغْ خْ إِذُورَارْ خْ ثُوعزْرِييَا إِنُو، نشّْ أَكْ-ذ ثْمدُّوكَاڒْ إِنُو.“  
\v 38 نتَّا يَارَّا-د خَاسْ: ”ؤُيُورْ!“ ؤُشَا إِجَّا إِ-ت أَذْ ثْرَاحْ ثْنَاينْ ن إِيُورنْ. نتَّاثْ \add مَاشَا\add* ثطّفْ أَبْرِيذْ أَكْ-ذ ثْمدُّوكَاڒْ نّسْ ؤُشَا ثْرُو خْ ثُوعزْرِييَا نّسْ ذڭْ إِذُورَارْ.  
\v 39 إِمْسَارْ، ؤُمِي قفْڒنْ ثْنَاينْ ن إِيُورنْ، ثَارڭّْوّحْ-د غَارْ بَابَاسْ ؤُ نتَّا إِقْفڒْ لْوَاعْذْ إِ إِوَاعْذْ. نتَّاثْ ثُوغَا \add عمَّارْصْ\add* وَارْ ثسِّينْ ؤُڒَا ذ إِجّْ ن ورْيَازْ. أَمُّو إِذْوڒْ ذ لْعَاذَا ذِي إِسْرَائِيل، \f ◼ \fr 11:‏39 \ft \+bd ’وَارْ ثسِّينْ‘\+bd* - ڒْمعْنَا ن وَاوَاڒْ-أَ، أَقَا نتَّاثْ وَارْ ثطِّيسْ شَا أَكْ-ذ ورْيَازْ، مَاشَا ثقِّيمْ أَمُّو ذ ثَاعْزَارشْثْ.\f*  
\v 40 أَقَا أَسڭّْوَاسْ أَوَارْنِي إِ ؤُسڭّْوَاسْ يسِّيسْ ن إِسْرَائِيل أَذْ طّْفنْثْ أَبْرِيذْ، حِيمَا أَذْ إِذَارنْثْ إِ يدْجِيسْ ن يَافْثَاحْ، أَجِيلْعَاذِي، أَربْعَا ن وُوسَّانْ ذڭْ ؤُسڭّْوَاسْ.   
\b  
\b  
\m  
\c 12
\s1 يَافْثَاحْ ذ إِفْرَايِيمْ  
\m
\v 1 \add خنِّي\add* تّْوَاسّْمُوننْ إِرْيَازنْ ن إِفْرَايِيمْ \add إِ ؤُمنْغِي\add* ؤُ نِيثْنِي ژْوَانْ غَارْ زَافُونْ. نَّانْ إِ يَافْثَاحْ: ”مَايمِّي ثژْوِيذْ حِيمَا أَذْ ثمّنْغذْ أَكْ-ذ أَيْثْ ن عَامُّونْ ؤُ وَارْ ذ أَنغْ ثْڒِيغِيذْ حِيمَا أَذْ نُويُورْ أَكِيذكْ؟ نشِّينْ أَذْ أَشْ نقّذْ ثِيمسِّي إِ ثَادَّارْثْ نّشْ ثِيوَا إِ ؤُزدْجِيفْ نّشْ ذ شكْ أَكِيذسْ.“ \x ◘ \xo 12:‏1 \xt ڒقض. 8‏:‏1\x*  
\v 2 يَافْثَاحْ إِنَّا أَسنْ: ”نشّْ ذ ڒْڭنْسْ إِنُو ثُوغَا أَنغْ ذڭْ إِجّْ ن ؤُمْشُوبّشْ ذ أَمقّْرَانْ أَكْ-ذ أَيْثْ ن عَامُّونْ. ڒَاغِيغْ-د خَاومْ، \add مَاشَا\add* كنِّيوْ وَارْ د-ثُوسِيمْ حِيمَا أَذْ أَيِي ثْفكّمْ زڭْ ؤُفُوسْ نْسنْ.  
\v 3 \add ؤُمِي\add* ژْرِيغْ، بلِّي كنِّيوْ وَارْ د-ثُوسِيمْ إِ ؤُسنْجمْ، سبّْڒغْ ثُوذَارْثْ إِنُو ؤُشَا ژْوِيغْ \add لْ-ؤُرْذُونْ\add* غَارْ أَيْثْ ن عَامُّونْ ؤُ سِيذِي إِڭَّا أَيِي ثنْ ذڭْ ؤُفُوسْ. مَايمِّي إِ د غَارِي ثْڭعّْذمْ أَسّْ-أَ حِيمَا أَكِيذِي ثمّنْغمْ؟“  
\v 4 \add خَاسْ ؤُشَا\add* إِسّْمُونْ يَافْثَاحْ مَارَّا إِرْيَازنْ زِي جِيلْعَاذْ ؤُشَا إِمّْنغْ أَكْ-ذ إِفْرَايِيمْ ؤُ إِرْيَازنْ ن جِيلْعَاذْغڒْبنْ خْ إِفْرَايِيمْ، مِينْزِي \add إِرْيَازنْ ن إِفْرَايِيمْ\add* نَّانْ: ”كنِّيوْ ذ إِنِّي يَاروْڒنْ زڭْ إِفْرَايِيمْ!“، \add أَقَا\add* جِيلْعَاذْ يُوسَا-د جَارْ إِفْرَايِيمْ ذ مَانَاسَّا.  
\v 5 جِيلْعَاذْ إِحوّسْ إِمُوشَانْ ن ؤُژكّْوُو ن لْ-ؤُرْذُونْ \add إِنِّي إِدْجَانْ\add* ن إِفْرَايِيمْ. ذ مَارَّا إِنِّي يَاروْڒنْ ن إِفْرَايِيمْ نَّانْ: ”أجّْ أَيِي أَذْ ژْوِيغْ“، خنِّي سّقْسَانْ ث إِرْيَازنْ زِي جِيلْعَاذْ: ”مَا شكْ زِي إِفْرَايِيمْ؟“ مَاڒَا نتَّا إِنَّا: ”لَّ!“،  
\v 6 \add خنِّي\add* نَّانْ أَسْ: ”إِنِي ’شِيبُّولِيثْ!‘ “ إِنَّا نتَّا \add خنِّي\add*: ’سِيبُّولِيثْ!‘ ؤُ \add إِبَانْ-د\add* نتَّا وَارْ إِزْمِيرْ أَذْ ث إِنْطقْ مْلِيحْ، خنِّي طّْفنْ ث ؤُشَا نْغِينْ ث غَارْ إِمُوشَانْ ن ؤُژكّْوُو ن لْ-ؤُرْذُونْ. \add أَمُّو\add* إِ وْضَانْ ثْنَاينْ ؤُ-ربْعِينْ-أَڒفْ ن يرْيَازنْ ن إِفْرَايِيمْ ذِي ڒْوقْثْ نِّي.  
\v 7 ثُوغَا يَافْثَاحْ إِحكّمْ إِسْرَائِيل ستَّا ن إِسڭّْوُوسَا. \add خنِّي\add* إِمُّوثْ يَافْثَاحْ، أَجِيلْعَاذِي، ؤُ نتَّا إِتّْوَانْضڒْ ذڭْ \add إِشْثْ زِي\add* ثْندَّامْ ن جِيلْعَاذْ.   
\b  
\m  
\s1 إِبْصَانْ، إِلُونْ ذ عَابْذُونْ  
\m
\v 8 أَوَارْنِي أَسْ ثُوغَا \bd إِبْصَانْ\bd* زِي بَايْثْ-لَاحْمْ ذ ڒْقَاضِي خْ إِسْرَائِيل.  
\v 9 نتَّا ثُوغَا غَارسْ ثْڒَاثِينْ ن إِحنْجِيرنْ ؤُ إِسّْمدْجشْ ثْڒَاثِينْ ن يسِّيسْ غَارْ بَارَّا ؤُ إِ ثْڒَاثِينْ ن أَرَّاونْ نّسْ إِجَّا إِ-ثنْ أَذْ أَوْينْ ثْڒَاثِينْ ن يسِّيسْ زِي بَارَّا. ثُوغَا نتَّا إِحكّمْ خْ إِسْرَائِيل سبْعَا ن إِسڭّْوُوسَا.  
\v 10 \add خنِّي\add* إِمُّوثْ إِبْصَانْ ؤُشَا إِتّْوَانْضڒْ ذِي بَايْثْ-لَاحْمْ.   
\m
\v 11 أَوَارْنِي أَسْ ثُوغَا \bd إِلُونْ\bd*، أَزابُولُونِي، ذ ڒْقَاضِي خْ إِسْرَائِيل. نتَّا إِحْكمْ خْ إِسْرَائِيلعشْرَا ن إِسڭّْوُوسَا. \f ◼ \fr 12:‏11 \ft \+bd ’أَزَاپُولُونِي‘\+bd* - إِجّنْ زِي ثقْبِيتْشْ ن زَاپُولُونْ.\f*  
\v 12 \add خنِّي\add* إِمُّوثْ إِلُونْ، أَزابُولُونِي، ؤُشَا إِتّْوَانْضڒْ ذِي أَيَالُونْ ذِي ثمُّورْثْ ن زابُولُونْ.   
\m
\v 13 أَوَارْنِي أَسْ ثُوغَا \bd عَابْذُونْ\bd*، مِّيسْ ن هِيلَّالْ، زِي فِيرْعَاثُونْ، ذ ڒْقَاضِي خْ إِسْرَائِيل.  
\v 14 نتَّا ثُوغَا غَارسْ أَربْعِينْ ن إِحنْجِيرنْ ذ ثْڒَاثِينْ ن وَايَّاونْ، إِنِّي إِنَّاينْ خْ سبْعِينْ ن إِغْيَاڒْ. نتَّا ثُوغَا ذ ڒْقَاضِي خْ إِسْرَائِيل ثْمنْيَا ن إِسڭّْوُوسَا. \x ◘ \xo 12:‏14 \xt ڒقض. 10‏:‏4\x*  
\v 15 \add خنِّي\add* إِمُّوثْ عَابْذُونْ، مِّيسْ ن هِيلّلْ، زِي فِيرْعَاثُونْ، ؤُشَا إِتّْوَانْضڒْ ذِي فِيرْعَاثُونْ، ذِي ثمُّورْثْ ن إِفْرَايِيمْ، خْ إِذُورَارْ ن عَامَالِيقْ.   
\b  
\b  
\m  
\c 13
\s1 أَخْڒَاقْ ن شَامْشُونْ  
\m
\v 1 \add خنِّي\add* أَرْنِينْ أَيْثْ ن إِسْرَائِيل مَاحنْذْ أَذْ ڭّنْ مِينْ \add إِدْجَانْ\add* ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي. \add خنِّي\add* إِنْضَارْ إِ-ثنْ سِيذِي ذڭْ ؤُفُوسْ ن إِفِيلِيسْطِينِييّنْ، \add إِجّْ ن ڒْمِيجَاڒْ ن\add* أَربْعِينْ ن إِسڭّْوُوسَا. \x ◘ \xo 13:‏1 \xt  ڒقض. 2‏:‏11؛ 3‏:‏7؛ 4‏:‏1؛ 6‏:‏1؛ 10‏:‏6\x*  
\v 2 ثُوغَا ذِينْ إِجّْ ن ورْيَازْ زِي صُورْعَا، زِي ڒْوَاشُونْ ن دَان. ثُوغَا قَّارنْ أَسْ مَانُوحْ. ثَامْغَارْثْ نّسْ ثُوغَا وَارْ غَارسْ بُو ثَارْوَا ؤُ وَارْ د-ثِيرُووْ شَا.  
\v 3 إِبَانْ-د لْمَالَاكْ ن سِيذِي إِ ثمْغَارْثْ-أَ ؤُشَا نتَّا إِنَّا أَسْ: ”خْزَارْ، وَارْ غَارمْ بُو ثَارْوَا ؤُ وَارْ د-ثِيرْوُوذْ شَا، مَاشَا أَذْ ثكْسِيذْ دّيْسثْ، أَذْ ثَارْوذْ إِجّْ ن ؤُحنْجِيرْ.  
\v 4 \add خنِّي\add* ڒخُّو، حْضَا إِخفْ نّمْ! وَارْ سسّْ بِينُو ؤُڒَا ذ شّْرَابْ ؤُ وَارْ تّتّْ وَالُو زِي مَارَّا مِينْ إِنڭْسنْ! \x ◘ \xo 13:‏4 \xt ڒخْڒ. 6‏:‏2، 3\x*  
\v 5 مَاغَارْ خْزَارْ، شمْ أَذْ ثكْسِيذْ س دّيْسثْ، أَذْ ثَارْوذْ إِجّْ ن ؤُحنْجِيرْ. وَارْ ذ أَسْ إِتّكّْ ڒْمُوسْ خْ ؤُزدْجِيفْ نّسْ، مَاغَارْ أَحنْجِيرْ أَذْ يَارْبُو تَّاجْ \add ن وعْزَاڒْ\add* ن أَربِّي زڭْ ؤُعذِّيسْ ن يمَّاسْ ؤُ نتَّا أَذْ إِبْذَا حِيمَا أَذْ إِفكّْ إِسْرَائِيل زڭْ ؤُفُوسْ ن إِفِيلِيسْطِينِييّنْ.“ \x ◘ \xo 13:‏5 \xt ڒخْڒ. 6‏:‏5؛ 1 صم. 1‏:‏11\x*   
\m
\v 6 ثَامْغَارْثْ ثُوذفْ ؤُ ثسِّيوڒْ أَكْ-ذ ورْيَازْ نّسْ، ثنَّا أَسْ: ”إِجّْ ن ورْيَازْ ن أَربِّي يُوسَا-د غَارِي. أَغمْبُوبْ نّسْ إِڭَّا أَمْ لْمَالَاكْ ن أَربِّي، إِسَّاڭّْوَاذْ أَطَّاسْ، ؤُشَا نشّْ وَارْ ث سّقْسِيغْ مَانِيسْ د-يُوسَا، ؤُ نتَّا وَارْ ذ أَيِي إِنِّي مَامّشْ ذ أَسْ قَّارنْ.  
\v 7 نتَّا إِنَّا أَيِي: ’خْزَارْ، شمْ أَذْ ثكْسِيذْ س دّيْسثْ، أَذْ ثَارْوذْ إِجّْ ن ؤُحنْجِيرْ. وَارْ سسّْ بِينُو ؤُڒَا ذ شّْرَابْ ؤُ وَارْ تّتّْ وَالُو مِينْ إِخمْجنْ، مِينْزِي أَحنْجِيرْ أَذْ يَارْبُو تَّاجْ \add ن وعْزَاڒْ\add* ن أَربِّي زڭْ ؤُعذِّيسْ ن يمَّاسْ أَڒْ أَسّْ ن ڒْموْثْ نّسْ.‘  
\v 8 ؤُشَا إِژُّودْجْ مَانُوحْ غَارْ سِيذِي، إِنَّا: ”أَ، سِيذِي إِنُو، تّْزَاوَاڭغْ شكْ، أجّْ أَرْيَازْ ن أَربِّي ونِّي د ثسّكّذْ، أَذْ غَارْنغْ د-يَاسْ ثْوَاڒَا نّغْنِيثْ، مَاحنْذْ أَذْ أَنغْ إِسّْشنْ مِينْ غَا نڭّْ أَكْ-ذ ؤُحنْجِيرْ ونِّي د غَا إِخڒْقنْ.“   
\m
\v 9 ؤُشَا سِيذِي إِسْڒَا غَارْ مَانُوحْ ؤُ لْمَالَاكْ ن أَربِّي يُوسَا-د إِشْثْ ن ثْوَاڒَا نّغْنِيثْ غَارْ ثمْغَارْثْ. نتَّاثْ ثقِّيمْ ذڭْ إِيَّارْ ؤُشَا أَرْيَازْ نّسْ مَانُوحْ ثُوغَا وَارْ كِيذسْ إِدْجِي. \f ◼ \fr 13:‏9 \ft \+bd ’إِسْڒَا غَارْ مَانُوحْ‘\+bd* - س ثْعِيبْرَانِيثْ ’إِسْڒَا غَارْ ثْمِيجَّا ن مَانُوحْ‘.\f*  
\v 10 نتَّاثْ ثْقدْجقْ ؤُ ثعْڒفْ، ثْعَاوذْ أَيَا إِ ورْيَازْ نّسْ، ثنَّا أَسْ: ”خْزَارْ، أَرْيَازْ نِّي د غَارِي يُوسِينْ، إِبَانْ أَيِي-د \add عَاوذْ\add*.“  
\v 11 إِكَّارْ مَانُوحْ، إِضْفَارْ ثَامْغَارْثْ نّسْ. ؤُمِي د-يُوسَا غَارْ ورْيَازْ، إِنَّا أَسْ: ”مَا شكْ ذ أَرْيَازْ نِّي إِسِّيوْڒنْ أَكْ-ذ ثمْغَارْثْ إِنُو؟“ نتَّا يَارَّا-د خَاسْ: ”\add وَاهْ،\add* ذ نشّْ.“  
\v 12 \add خنِّي\add* إِنَّا مَانُوحْ: ”مَاڒَا تّْوَاكمّْڒنْ خنِّي وَاوَاڒنْ نّشْ ڒخُّو، مِينْ \add إِ غَا ثِيڒِي\add* ڒْقَاعِيذَا \add إِ زِي غَا نُويُورْ\add* أَكْ-ذ ؤُحنْجِيرْ ؤُ مِينْ \add إِ غَا ثِيڒِي\add* ڒْخذْمثْ نّسْ؟“  
\v 13 إِنَّا لْمَالَاكْ ن سِيذِي إِ مَانُوحْ: ”ثَامْغَارْثْ أَذْ ثحْضَا إِخفْ نّسْ زِي مَارَّا مِينْ ذ أَسْ نِّيغْ.  
\v 14 نتَّاثْ وَارْ تّتّْ مِينْ د-إِتَّاسنْ زِي ثْزَايَارْثْ ؤُشَا وَارْ ثْسسّْ بِينُو ؤُڒَا ذ شّْرَابْ ؤُ وَارْ تّتّْ وَالُو زِي مَارَّا مِينْ إِنڭْسنْ. أَذْ ثحْضَا مَارَّا مِينْ ذ أَسْ ؤُمُورغْ.“   
\m
\v 15 \add خنِّي\add* إِنَّا مَانُوحْ إِ لْمَالَاكْ ن سِيذِي: ”أجّْ أَنغْ أَذْ شكْ نمْنعْ غَارْنغْ \add شْوَايْثْ ذَانِيثَا\add* ؤُ أَذْ أَشْ نسّوْجذْ إِجّْ ن إِغَايْضْ ذ أَمژْيَانْ زڭْ إِغَايْضنْ زَّاثْ إِ وُوذمْ نّشْ.“  
\v 16 \add مَاشَا\add* لْمَالَاكْ ن سِيذِي إِنَّا إِ مَانُوحْ: ”مَاڒَا ثخْسذْ أَذْ أَيِي ثْمنْعذْ، وَارْ تّتّغْ زڭْ وغْرُومْ نّشْ ؤُ مَاڒَا ثخْسذْ أَذْ ثسّْوجْذذْ إِشْثْ ن ثْغَارْصْثْ ن وشْمَاضْ، إِتّْخصَّا أَذْ ت ثْقذْمذْ إِ سِيذِي.“ مِينْزِي مَانُوحْ وَارْ إِسِّينْ، أَقَا-ث ذ لْمَالَاكْ ن سِيذِي.  
\v 17 ؤُشَا إِنَّا مَانُوحْ إِ لْمَالَاكْ ن سِيذِي: ”مَامّشْ إِ ذ أَشْ قَّارنْ، حِيمَا أَذْ أَشْ نڭّْ شَّانْ، خْمِي غَا إِتّْوَاكمّڒْ وَاوَاڒْ نّشْ.“  
\v 18 إِنَّا أَسْ \add مَاشَا\add* لْمَالَاكْ ن سِيذِي ”مَايمِّي ذ أَيِي ثسّقْسِيذْ خْ يِيسمْ إِنُو؟ أَقَا وَانِيثَا ذ ڒعْجبْ.“  
\v 19 \add خنِّي\add* إِكْسِي مَانُوحْ إِجّْ ن إِغَايْضْ ذ أَمژْيَانْ زڭْ إِغَايْضنْ أَكْ-ذ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* ؤُشَا إِقدّمْ \add أَيَا\add* خْ ثصْضَارْثْ إِ سِيذِي. \add خَاسْ ؤُشَا\add* إِڭَّا نتَّا إِجّْ ن ڒعْجبْ ؤُمِي مَانُوحْ ذ ثمْغَارْثْ نّسْ ثُوغَا خزَّارنْ.  
\v 20 ڒَامِي ثُوغَا أَشعَّاڒْ ن ؤُعَالْطَارْ إِڭعّذْ ذڭْ ؤُجنَّا، إِمْسَارْ أَقَا ؤُڒَا لْمَالَاكْ ن سِيذِي إِڭعّذْ ذڭْ ؤُشعَّاڒْ ن ؤُعَالْطَارْ. مَانُوحْ ذ ثمْغَارْثْ نّسْ ژْرِينْ أَيَا، وْضَانْ غَارْ ثمُّورْثْ خْ إِغمْبَابْ نْسنْ.   
\m
\v 21 سّنِّي \add مَاشَا\add* وَارْ د-إِبِينْ لْمَالَاكْ ن سِيذِي عَاذْ غَارْ مَانُوحْ ذ ثمْغَارْثْ نّسْ. خنِّي إِسّنْ مَانُوحْ، بلِّي ثُوغَا ذ لْمَالَاكْ ن سِيذِي.  
\v 22 إِنَّا مَانُوحْ إِ ثمْغَارْثْ نّسْ: ”س ثِيذتّْ نشِّينْ أَذْ نمّثْ، مِينْزِي نشِّينْ نژْرَا أَربِّي.“ \x ◘ \xo 13:‏22 \xt ؤُف. 33‏:‏20؛ أَعَوذ. 5‏:‏26؛ ڒقض. 6‏:‏22، 23\x*  
\v 23 ثنَّا أَسْ ثمْغَارْثْ نّسْ: ”مَاڒَا سِيذِي إِخْسْ أَذْ أَنغْ إِنغْ، إِڒِي نتَّا وَارْ إِكْسِي زڭْ ؤُفُوسْ نّغْ ثَاغَارْصْثْ ن وشْمَاضْ ذ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* ؤُ أَذْ ثِيڒِي وَارْ د أَنغْ إِتّجِّي أَذْ نْژَارْ أَذْ نْسڒْ قَاعْ مَانْ أَيَا ذِي ڒْوقْثْ-أَ.“   
\m
\v 24 ثَامْغَارْثْ ثُورُووْ-د إِجّْ ن ؤُحنْجِيرْ، ثڭَّا أَسْ \bd شَامْشُونْ\bd*. أَحنْجِيرْ إِمْغَارْ ؤُ سِيذِي إِبَاركْ إِ-ث. \f ◼ \fr 13:‏24 \ft \+bd ’شَامْشُونْ‘\+bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَمْ ثْفُوشْثْ‘.\f*  \x ◘ \xo 13:‏24 \xt عبر. 11‏:‏32\x*  
\v 25 ؤُشَا أَرُّوحْ ن سِيذِي إِبْذَا أَذْ ث إِنْذهْ ذِي ڒْمَارْڭحْ ن ڒْعسْكَارْ ن ذَانْ جَارْ صُورْعَا ذ إِشْثَاؤُولْ.   
\b  
\b  
\m  
\c 14
\s1 ڒمْڒَاشْ ن شَامْشُونْ  
\m
\v 1 شَامْشُونْ إِهْوَا غَارْ ثِيمْنَاثَا. ذِي ثِيمْنَاثَا إِژْرَا إِشْثْ ن ثمْغَارْثْ جَارْ يسِّيسْ ن إِفِيلِيسْطِينِييّنْ.  
\v 2 ؤُمِي د-إِڭعّذْ \add عَاوذْ\add*، إِحَاجَا ث إِ بَابَاسْ ذ يمَّاسْ، إِنَّا: ”نشّْ ژْرِيغْ ذِي ثِيمْنَاثَا إِشْثْ ن ثمْغَارْثْ جَارْ يسِّيسْ ن إِفِيلِيسْطِينِييّنْ. خنِّي ڒخُّو، أَوْيمْ أَيِي ت ذ ثَامْغَارْثْ إِ نشّْ!“  
\v 3 إِنَّا أَسْ بَابَاسْ ؤُڒَا ذ يمَّاسْ: ”مَا وَارْ \add ذِينْ\add* ثدْجِي إِشْثْ ن ثمْغَارْثْ جَارْ يسِّيسْ ن أَيْثْمَاشْ ؤُ جَارْ مَارَّا ڒْڭنْسْ إِنُو ؤُمِي ثخْسذْ أَذْ ثَاوْيذْ إِشْثْ ن ثمْغَارْثْ زڭْ إِفِيلِيسْطِينِييّنْ إِ وَارْ إِتّْوَاخثْننْ؟“ ؤُشَا إِنَّا شَامْشُونْ إِ بَابَاسْ: ”أَوِي أَيِي إِ-ت إِ نشّْ، مِينْزِي نتَّاثْ \add ذ ثَامْغَارْثْ\add* ثشْنَا ذِي ثِيطَّاوِينْ إِنُو.“  
\v 4 بَابَاسْ ذ يمَّاسْ وَارْ سِّيننْ، أَقَا مَانْ أَيَا \add ثُوغَا-ث\add* زِي سِيذِي، أَقَا نتَّا يَارزُّو سِّيبّثْ ضِيدّْ إِ إِفِيلِيسْطِينِييّنْ، \add مِينْزِي\add* ذِي ڒْوقْثْ نِّي ثُوغَا إِفِيلِيسْطِينِييّنْ حكّْمنْ خْ إِسْرَائِيل.   
\m
\v 5 إِهْوَا-د شَامْشُونْ غَارْ ثِيمْنَاثَا أَكْ-ذ بَابَاسْ ذ يمَّاسْ. \add ؤُمِي\add* إِوْضنْ غَارْ إِمَارْجَاعنْ ن ؤُضِيڒْ ن ثِيمْنَاثَا، خْزَارْ، إِفّغْ-د غَارسْ إِجّْ ن ويْرَاذْ ذ أَمژْيَانْ إِزهَّارْ.  
\v 6 أَرُّوحْ ن سِيذِي إِطّفْ إِ-ث \add أَڒَامِي\add* ث إِمزّقْ أَخْمِي إِتّْوَامزّقْ إِجّْ ن إِغَايْضْ ذ أَمژْيَانْ ؤُشَا \add ذ مَانْ أَيَا إِمْسَارْ أَمْ\add* وَارْ غَارسْ ؤُڒَا ذ إِشْثْ ن ڒْحَاجّثْ ذڭْ ؤُفُوسْ نّسْ. نتَّا وَارْ إِعَاوذْ إِ بَابَاسْ ذ يمَّاسْ مِينْ إِڭَّا.   
\m
\v 7 خنِّي إِهْوَا، إِسِّيوڒْ أَكْ-ذ ثْمطُّوثْ. ؤُ نتَّاثْ ثُوغَا ذ \add ثَامْغَارْثْ\add* ثشْنَا ذِي ثِيطَّاوِينْ ن شَامْشُونْ.  
\v 8 أَوَارْنِي شَا ن وُوسَّانْ إِذْوڒْ غَارْ ذِينْ عَاوذْ، حِيمَا أَذْ ت يَاوِي \add ذ ثَامْغَارْثْ\add*. إِفّغْ \add زڭْ وبْرِيذْ\add* حِيمَا أَذْ إِخْزَارْ ڒْخشْبثْ ن ويْرَاذْ، ؤُ خْزَارْ، ثُوغَا \add ذِينْ\add* إِجّْ ن ويْڒَافْ ن ثْزِيزْوَا ذِي ڒْخشْبثْ ن ويْرَاذْ، أَكْ-ذ ثَامّنْثْ.  
\v 9 نتَّا إِيْرُو ثَامّنْثْ ذڭْ إِفَاسّنْ، إِرُوحْ ؤُشَا إِتّتّْ زَّايسْ أَمْ إِڭُّورْ. \add ؤُمِي\add* د-يُوسَا غَارْ بَابَاسْ ذ يمَّاسْ، إِوْشَا أَسنْ زَّايسْ ؤُشَا ؤُڒَا ذ نِيثْنِي شِّينْ. مَاشَا نتَّا وَارْ ذ أَسنْ إِنِي، أَقَا نتَّا ثُوغَا إِكّسْ-د ثَامّنْثْ زِي ڒْخشْبثْ ن ويْرَاذْ.   
\m
\v 10 \add خنِّي\add* إِهْوَا بَابَاسْ غَارْ ثمْغَارْثْ ؤُ شَامْشُونْ إِڭَّا ذِينِّي إِجّْ ن وُورَارْ أَمْ مَامّشْ \add نُّومنْ\add* أَذْ ث تّڭّنْ إِحُوذْرِييّنْ.  
\v 11 \add ؤُمِي\add* ث ژْرِينْ نِيثْنِي، إِمْسَارْ، بلِّي إِوْينْ ثْڒَاثِينْ ن إِمْعَاشَارنْ حِيمَا أَكِيذسْ إِڒِينْ.  
\v 12 إِنَّا أَسنْ شَامْشُونْ: ”أجّْ أَيِي أَذْ أَومْ إِنِيغْ إِشْثْ ن ثْحَاجِيثْ ن ثْوَافِيثْ. مَاڒَا كنِّيوْ ثْزمَّارنْ أَذْ أَيِي ت ثْشَارّْحمْ ؤُ أَذْ خَاسْ ثفّْغمْ ذِي سبْعَا ن وُوسَّانْ ن وُورَارْ-أَ، \add خنِّي\add* أَذْ أَومْ وْشغْ ثْڒَاثِينْ ن ثِيكَّاسْ ذ ثْڒَاثِينْ ن وَارُّوضْ إِشْنَانْ.  
\v 13 \add مَاشَا\add* مَاڒَا وَارْ ثْزمَّارمْ أَذْ أَيِي ت ثْشَارّْحمْ، خنِّي كنِّيوْ أَذْ أَيِي ثوْشمْ ثْڒَاثِينْ ن ثِيكَّاسْ ذ ثْڒَاثِينْ ن وَارُّوضْ إِشْنَانْ.“ نِيثْنِي نَّانْ أَسْ: ”إِنِي أَنغْ ثْحَاجِيثْ ن ثْوَافِيثْ نّشْ، نشِّينْ نخْسْ أَذْ \add ت\add* نْسڒْ!“  
\v 14 نتَّا إِنَّا أَسنْ: ”مَاشَّا إِفّغْ-د زڭْ ونِّي إِتّتّنْ ؤُ ثَاژْيُوذِي ثفّغْ-د زڭْ ونِّي إِجهْذنْ.“ ثْڒَاثَا ن وُوسَّانْ وَارْ زمَّارنْ أَذْ شَارّْحنْ ثْحَاجِيثْ ن ثْوَافِيثْ \add إِ ذ أَسنْ إِنَّا\add*.  
\v 15 ذڭْ وَاسّْ وِيسّْ سبْعَا إِمْسَارْ، أَقَا نَّانْ إِ ثمْغَارْثْ ن شَامْشُونْ: ”غْوَا أَرْيَازْ نّمْ مَاحنْذْ أَذْ أَنغْ إِفسَّارْ ثْحَاجِيثْ ن ثْوَافِيثْ نِيغْ أَذْ أَمْ نقّذْ ثِيمسِّي أَكْ-ذ ثَادَّارْثْ ن بَابَامْ. مَا ثْعَارْضمْ أَنغْ \add ذَا\add*، حِيمَا أَذْ أَنغْ ثكّْسمْ أَڭْڒَا نّغْ نِيغْ لَّا؟“   
\m
\v 16 ؤُشَا ثْرُو ثمْغَارْثْ ن شَامْشُونْ زَّاثسْ، ثنَّا: ”شكْ أَقَا ثْشَارّْهذْ أَيِي وَاهَا، وَارْ ذ أَيِي ثتّخْسذْ. شكْ ثنِّيذْ إِ ثَارْوَا ن ڒْڭنْسْ إِنُو إِشْثْ ن ثْحَاجِيثْ ن ثْوَافِيثْ ؤُ وَارْ ذ أَيِي ت ثْفسَّارذْ.“ نتَّا يَارَّا-د خَاسْ: ”خْزَارْ، وَارْ ت نِّيغْ عَاذْ ؤُڒَا إِ بَابَا ؤُڒَا إِ يمَّا. مَامّشْ إِ ذ أَمْ ت إِ غَا إِنِيغْ إِ شمْ؟“  
\v 17 نتَّاثْ مَاشَا ثْرُو زَّاثسْ \add مَارَّا\add* سبْعَا ن وُوسَّانْ نِّي ذِي ڭِّينْ ؤُرَارْ ؤُ ذڭْ وَاسّْ وِيسّْ سبْعَا إِمْسَارْ أَڒَامِي إِ ذ أَسْ ت إِنَّا، مِينْزِي نتَّاثْ ثهْوڒْ إِ-ث ؤُشَا نتَّاثْ ثْشَارّحْ ثْحَاجِيثْ ن ثْوَافِيثْ إِ ثَارْوَا ن ڒْڭنْسْ نّسْ.  
\v 18 \add خنِّي\add* نَّانْ أَسْ يرْيَازنْ ن ثنْذِينْثْ ذڭْ وَاسّْ وِيسّْ سبْعَا قْبڒْ مَا أَذْ ثغْڒِي ثْفُوشْثْ: ”مِينْ إِدْجَانْ ذ أَمِيژِيذْ خْ ثَامّنْثْ ذ مِينْ إِجهْذنْ خْ ويْرَاذْ؟“ \add خْ ؤُيَا\add* نتَّا إِنَّا أَسنْ: ”مَاڒَا وَارْ ثشْرِيزمْ كنِّيوْ س ثْعجْمِيثْ إِنُو، إِڒِي كنِّيوْ وَارْ ثفِّيغمْ ثْحَاجِيثْ ن ثْوَافِيثْ إِنُو.“   
\m
\v 19 \add خنِّي\add* إِطّفْ إِ-ث أَرُّوحْ ن سِيذِي ؤُشَا إِهْوَا غَارْ أَشْقَالُونْ ؤُشَا إِنْغَا ثْڒَاثِينْ ن يرْيَازنْ ؤُ إِكْسِي ثَاكشَّاذْطْ زَّايْسنْ ؤُشَا إِوْشَا أَرُّوضْ إِشْنَانْ إِ يِينِّي إِسّْفهْمنْ ثْحَاجِيثْ ن ثْوَافِيثْ. أَخيّقْ نّسْ \add مَاشَا\add* ثُوغَا يَارقّْ ؤُشَا إِڭعّذْ \add عَاوذْ\add* غَارْ ثَادَّارْثْ ن بَابَاسْ.  
\v 20 \add س ؤُيَا\add* ثمّوْشْ ثمْغَارْثْ نّسْ إِ ؤُمْعَاشَارْ نّسْ، ونِّي ثُوغَا إِ-ث إِعَاشَارنْ.   
\b  
\b  
\m  
\c 15
\s1 أَخْڒفْ ن شَامْشُونْ ذِي طّْوعْ ن ثمْغَارْثْ ثَافِيلِيصْثِينشْثْ نّسْ زِي ثِيمْنَا  
\m
\v 1 أَوَارْنِي شَا ن وُوسَّانْ، ذڭْ وُوسَّانْ ن ثْميْرَا ن إِرْذنْ، إِمْسَارْ، إِسِّيجِّي شَامْشُونْ خْ ثمْغَارْثْ نّسْ، يِيوِي أَكِيذسْ إِجّْ ن إِغَايْضْ ذ أَمژْيَانْ زڭْ إِغَايْضنْ، إِنَّا \add إِ بَابَاسْ\add*: ”أجّْ أَيِي أَذْ أَذْفغْ غَارْ ثمْغَارْثْ إِنُو ذڭْ وخَّامْ!“ \add مَاشَا\add* بَابَاسْ وَارْ ث إِجِّي أَذْ يَاذفْ.  
\v 2 إِنَّا بَابَاسْ: ”س ثِيذتّْ نشّْ نِّيغْ \add ذڭْ يِيخفْ إِنُو\add*، شكْ ثْعِيفّذْ ت، س ؤُينِّي وْشِيغْ ت إِ ؤُمْعَاشَارْ نّشْ. مَا وَارْ ثدْجِي ؤُتْشْمَاسْ ثَامَاژُوژْثْ عَاذْ ثشْنَا خَاسْ؟ أجّْ إِ-ت أَذْ غَاركْ ثِيڒِي ذڭْ ومْشَانْ نّسْ.“  
\v 3 \add مَاشَا\add* شَامْشُونْ إِنَّا أَسنْ: ”ثْوَاڒَاثْ-أَ أَذْ إِڒِيغْ ذ أَشمْرَاڒْ زِي جِّيهثْ ن إِفِيلِيسْطِينِييّنْ، مَاڒَا ڭِّيغْ ذَايْسنْ مِينْ \add إِدْجَانْ\add* ذ أَعفَّانْ.“   
\m
\v 4 ؤُ شَامْشُومْ يُويُورْ، إِيْمَارْ-د ثڒْثْ-مْيَا ن إِشعْبَاونْ. إِكْسِي إِصفْضَاونْ ؤُشَا إِسّْنقْڒبْ إِ-ثنْ إِجّْ خْ ونّغْنِي س إِكنَّاسنْ \add نْسنْ\add* ؤُشَا ذِي ڒْوسْطْ، جَارْ ثْنَاينْ ن إِكنَّاسنْ، إِشدّْ إِجّْ ن ؤُصفْضَاوْ.  
\v 5 نتَّا إِسَّارْغْ إِصفْضَاونْ ؤُشَا إِجَّا \add إِشعْبَاونْ\add* أَذْ ؤُيُورنْ ذڭْ إِمنْذِي إِبدّنْ ن إِفِيلِيسْطِينِييّنْ. أَمُّو إِسَّارْغْ إِشوَّافنْ \add ن إِمنْذِي\add* ذ إِمنْذِي إِبدّنْ، ؤُڒَا ذ إِيَّارنْ ن ؤُزمُّورْ.   
\m
\v 6 \add خنِّي\add* نَّانْ إِفِيلِيسْطِينِييّنْ: ”وِي إِڭِّينْ أَيَا؟“ نَّانْ؛ ”أَقَا ذ شَامْشُونْ، أَضڭّْوَاڒْ ن ورْيَازْ. زِي ثِيمْنَاثَا، مِينْزِي وَانِيثَا يِيوِي أَسْ ثَامْغَارْثْ نّسْ، إِوْشَا إِ-ت إِ ؤُمْعَاشَارْ نّسْ.“ \add خنِّي\add* ڭعّْذنْ إِفِيلِيسْطِينِييّنْ ؤُشَا قّْذنْ ثِيمسِّي إِ ثمْغَارْثْ ذ بَابَاسْ.  
\v 7 \add خَاسْ ؤُشَا\add* إِنَّا أَسنْ شَامْشُونْ: ”مَاڒَا كنِّيوْ ثڭِّيمْ أَمُّو، خنِّي حْسنْ أَذْ زَّايْومْ نْثَاقْمغْ \add ذ أَمزْوَارُو\add* ؤُشَا أَوَارْنِي أَيَا وَاهَا أَذْ سّْبدّغْ أَمنْغِي.“  
\v 8 نتَّا يَارْژَا أَسنْ إِغْسَانْ خْ ثْنَاينْ، أَقَا إِوْثَا إِ-ثنْ س إِشْثْ ن ثشْثِي ذ ثَامقّْرَانْثْ. \add خنِّي\add* إِهْوَا، يُويُورْ إِزْذغْ ذڭْ إِفْرِي ن ثصْضَارْثْ ن عِيطَامْ. \f ◼ \fr 15:‏8 \ft \+bd ’يَارْژَا أَسنْ إِخْسَانْ خْ ثْنَاينْ‘\+bd* - س ثْعِيبْرَانِيثْ ’أَضَارْ خْ ثْمصَّاضْثْ‘.\f*   
\m
\v 9 \add خنِّي\add* ڭعّْذنْ إِفِيلِيسْطِينِييّنْ ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ ذِي يَاهُوذَا ؤُشَا أَريّْشنْ إِخفْ نْسنْ أَڒْ لَاحِي.  
\v 10 إِرْيَازنْ ن يَاهُوذَا نَّانْ: ”مَايمِّي إِ د خَانغْ ثْڭعّْذمْ؟“ نِيثْنِي أَرِّينْ-د نَّانْ: ”نشِّينْ نْڭعّذْ، حِيمَا أَذْ نْشَارْفْ شَامْشُونْ مَاحنْذْ أَذْ كِيذسْ نڭّْ أَمْ مَامّشْ إِ كِيذْنغْ إِڭَّا نتَّا.“   
\m
\v 11 ؤُشَا هْوَانْ ثڒْثْ-أَڒَافْ ن يرْيَازنْ زِي يَاهُوذَا غَارْ إِفْرِي ن ثصْضَارْثْ ن عِيطَامْ، نَّانْ إِ شَامْشُونْ: ”مَا وَارْ ثسِّينذْ شكْ، أَقَا إِفِيلِيسْطِينِييّنْ حكّْمنْ خَانغْ؟ مَايمِّي ذ أَنغْ ثڭِّيذْ أَيَا؟“ نتَّا يَارَّا-د خَاسنْ: ”أَمْ مَامّشْ أَكِيذِي ڭِّينْ، أَمُّو أَكِيذْسنْ إِ غَا ڭّغْ.“  
\v 12 نِيثْنِي نَّانْ أَسْ: ”نشِّينْ نهْوَا-د حِيمَا أَذْ شكْ نْشَارْفْ ؤُ أَذْ شكْ نڭّْ ذڭْ إِفَاسّنْ ن إِفِيلِيسْطِينِييّنْ.“ \add خنِّي\add* إِنَّا شَامْشُونْ: ”جَادْجمْ أَيِي، أَقَا كنِّيوْ وَارْ خَافِي ثْهجّْممْ.“  
\v 13 نِيثْنِي سِّيوْڒنْ أَكِيذسْ، نَّانْ أَسْ: ”\add مَانْ أَيَا\add* وَارْ إِتِّيڒِي، مَاشَا نشِّينْ أَذْ شكْ نْشَارْفْ ؤُ أَذْ شكْ نڭّْ ذڭْ ؤُفُوسْ نْسنْ، مَاشَا س ثِيذتّْ وَارْ شكْ ننقّْ.“ ؤُشَا شَارْفنْ ث نِيثْنِي س ثْنَاينْ ن ثْسغْوِينْ ذ ثِيمَايْنُوثِينْ ؤُشَا نذْهنْ ث زڭْ إِفْرِي غَارْ سنّجْ.  
\v 14 \add ڒَْامِي\add* يِيوضْ غَارْ لَاحِي، فّْغنْ-د غَارسْ إِفِيلِيسْطِينِييّنْ س إِغُويَّانْ \add ن ؤُمنْغِي\add*. \add ڒخْذنِّي\add* إِطّفْ إِ-ت أَرُّوحْ ن سِيذِي ؤُشَا ثِيسغْوِينْ نِّي غَارْ إِغَادْجنْ نّسْ ذوْڒنْثْ أَمْ ثِيفّسْثْ إِ إِتّْوَاسّْشمْضنْ س ثْمسِّي ذ إِشذِّييّنْ نّسْ فسْينْ زڭْ إِغَادْجنْ نّسْ.  
\v 15 نتَّا يُوفَا إِجّْ ن يِيغسْ ن ؤُقَابْسِي ذ طّْرِي ن إِجّْ ن وغْيُوڒْ. \add خنِّي\add* إِسّْوِيژّضْ أَفُوسْ نّسْ، إِحَارْثْ خَاسْ ؤُشَا إِنْغَا زَّايسْ أَڒفْ ن يرْيَازنْ.  
\v 16 إِنَّا شَامْشُونْ: ”س يِيجّْ ن يِيغسْ ن ؤُقَابْسِي ن وغْيُوڒْ، إِجّْ ن ؤُعُورِّيشْ، ثْنَاينْ ن إِعُورِّيشنْ، أَقَا س يِيجّْ ن إِغسْ ن ؤُقَابْسِي ن ثغْيُوتْشْ نْغِيغْ أَڒفْ ن يرْيَازنْ.“  
\v 17 إِمْسَارْ، ؤُمِي إِكمّڒْ أَوَاڒْ نّسْ، إِنْضَارْ إِغسْ ن ؤُقَابْسِي زڭْ ؤُفُوسْ نّسْ ؤُشَا إِڭَّا أَسْ إِ ومْشَانْ نِّي رَامَاثْ-لَاحِي، \add ’ڒْْڭعّْذثْ ن يِيغسْ ن ؤُقَابْسِي‘\add*.\f ◼ \fr 15:‏17 \ft \+bd ’رَامَاثْ-لَاحِي‘\+bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’ڒْْڭَاعّْذثْ ن يِيغسْ ن ؤُقَابْسِي‘.\f*   
\m
\v 18 \add ڒخْذنِّي\add* ثُوغَا ذَايسْ أَفَاذِي أَطَّاسْ ؤُشَا إِڒَاغَا غَارْ سِيذِي إِنَّا: ”شكْ ثوْشِيذْ إِ ؤُمْسخَّارْ نّشْ أَسنْجمْ-أَ أَمقّْرَانْ. مَا \add خنِّي\add* إِتّْخصَّا أَذْ مّْثغْ س ؤُفَاذِي، أَذْ وْضِيغْ ذڭْ إِفَاسّنْ ن إِنَا إِنِّي وَارْ إِخثْننْ؟“ \x ◘ \xo 15:‏18 \xt 1 صم. 17‏:‏26، 36؛ 2 صم. 1‏:‏2\x*  
\v 19 \add خَاسْ ؤُشَا\add* إِسّْفدْجقْ أَربِّي أَحْفُورْ ن لَاحِي، فّْغنْ-د زَّايسْ وَامَانْ. نتَّا إِسُو ؤُشَا بُوحْبڒْ نّسْ إِذْوڒْ-د ؤُشَا إِذْوڒْ-د غَارْ ثُوذَارْثْ. خْ ؤُيَا إِڭَّا أَسْ \add إِ ثَاڒَا نِّي\add* ’عَايْنْ-هَاقُوريْ‘، \add إِخْسْ أَذْ يِينِي ’ثَاڒَا ن ونِّي إِتّْڒَاغَانْ‘\add*. ثَانِيثَا أَقَا-ت ذِي لَاحِي أَڒْ أَسّْ-أَ.  
\v 20 ثُوغَا نتَّا ذ ڒْقَاضِي خْ إِسْرَائِيل ذڭْ وُوسَّانْ ن إِفِيلِيسْطِينِييّنْ، عِيشْرِينْ ن إِسڭّْوُوسَا.   
\b  
\b  
\m  
\c 16
\s1 شَامْشُونْ ذِي غَازَّا  
\m
\v 1 ؤُمِي إِطّفْ شَامْشُونْ \add أَبْرِيذْ\add* غَارْ غَازَّا، إِژْرَا ذِينِّي إِشْثْ ن ثمْغَارْثْ ن فَارْقْ-شّْغڒْ، ؤُشَا يُوذفْ غَارسْ.  
\v 2 \add خنِّي\add* إِتّْوَانَّا إِ أَيْثْ ن غَازَّا: ”شَامْشُونْ أَقَا-ث ذَا!“ إِنّْضنْ أَسْ-د ؤُشَا حْضَانْ دْجِيڒثْ ثْمُونْ غَارْ ثوَّارْثْ ن ثنْذِينْثْ. دْجِيڒثْ ثْمُونْ سّْقَارنْ، نَّانْ: ”غَارْ ثُوفُّوثْ ن وَاسّْ أَذْ ث ننغْ.“  
\v 3 شَامْشُونْ \add مَاشَا\add* إِقِّيمْ إِزّڒْ \add إِطّصْ\add* أَڒْ أَزْينْ ن دْجِيڒثْ. \add خنِّي\add* إِكَّارْ-د ذڭْ وزْينْ ن دْجِيڒثْ، إِطّفْ ثِيوُّورَا ن ثنْذِينْثْ أَكْ-ذ ڒضْرُوفْ \add غَارْ ؤُغزْذِيسْ ن ثوَّارْثْ\add*، إِقْڒعْ إِ ثنْثْ إِ-د س زّكْرُونْ، إِڭَّا إِ-ثنْثْ خْ ثْغَارْضِينْ نّسْ ؤُشَا يَارْبُو ثنْثْ غَارْ ثْقِيشّثْ ن وذْرَارْ نِّي \add إِدْجَانْ\add* قِيبَاتْشْ إِ حَابْرُونْ.   
\b  
\m  
\s1 شَامْشُونْ ذ ذَالِيلَا  
\m
\v 4 أَوَارْنِي أَسْ، إِمْسَارْ إِعْشقْ إِشْثْ ن ثمْغَارْثْ غَارْ ثغْزَارْثْ ن سُورَاقْ، قَّارنْ أَسْ ذَالِيلَا.  
\v 5 ؤُشَا ڒْبَاشَاثْ \add ن ثْندَّامْ\add* ن إِفِيلِيسْطِينِييّنْ ؤُسِينْ-د غَارسْ، نَّانْ أَسْ: ”غْوَا إِ-ث، ؤُ خْزَارْ \add أَذْ ثَافذْ\add* زِي مَانِيسْ غَارسْ جّهْذْ-أَ ثَامقّْرَانْثْ ؤُ مَامّشْ خَاسْ إِ غَا نْزمَّارْ. \add خنِّي\add* أَذْ ث نْشَارْفْ، حِيمَا أَذْ ث نطّفْ. \bd نشِّينْ\bd* أَذْ أَمْ نوْشْ كُوڒْ إِجّْ \add زَّايْنغْ\add* أَڒفْ ؤُ-مْيَا ن \add ؤُقِييَّاثْ ن\add* نُّوقَارْثْ.“  
\v 6 خَاسْ ؤُشَا ثنَّا ذَالِيلَا إِ شَامْشُونْ: ”إِنِي أَيِي مَاشَا، زِي مَانِيسْ غَاركْ جّهْذْ-أَ أَمقّْرَانْ ذ مَامّشْ زمَّارنْ أَذْ شكْ شَارْفنْ حِيمَا أَذْ ثتّْوَاطّْفذْ.“  
\v 7 إِنَّا أَسْ شَامْشُونْ: ”مَاڒَا شَارْفنْ أَيِي س سبْعَا ن إِژوْرَانْ طّْرِي \add زڭْ ويْسُومْ\add* نِّي وَارْ يُوژِيغنْ عَاذْ، خنِّي أَذْ ذوْڒغْ أَرْخُوغْ أَمْ \add كُوڒْ\add* إِجّْ ن بْنَاذمْ نّغْنِي.“  
\v 8 ڒْبَاشَاثْ \add ن ثْندَّامْ\add* ن إِفِيلِيسْطِينِييّنْ إِوْينْ أَسْ-د سبْعَا ن إِژوْرَانْ ذ طّْرِي \add زڭْ ويْسُومْ\add* نِّي وَارْ يُوژِيغنْ عَاذْ ؤُ نتَّاثْ ثْشَارْفْ إِ-ث زَّايْسنْثْ.  
\v 9 \add ذڭْ إِجّْ ن ؤُمُورْ\add* ثُوغَا غَارسْ حذْ ذِي ثخَّامْثْ ن ذَاخڒْ إِطّفْ أَحطُّو. ثنَّا أَسْ: ”\add أَ\add* شَامْشُونْ، إِفِيلِيسْطِينِييّنْ \add ؤُسِينْ-د\add* خَاكْ!“ \add خنِّي\add* إِقْضُووْ إِژوْرَانْ أَمْ مَامّشْ إِتّْقطَّاسْ بْنَاذمْ أَفِيڒُو ن ثِيفّسْثْ أَخْمِي ت ثڒْقفْ ثْمسِّي. ؤُشَا \add سِّيرْ ن\add* جّهْذْ نّسْ وَارْ إِذْوِيڒْ إِتّْوَاسّنْ.   
\m
\v 10 \add خَاسْ ؤُشَا\add* ثنَّا ذَالِيلَا إِ شَامْشُونْ: ”خْزَارْ، ثْشمْثذْ أَيِي ؤُ ثسّْخَارّْقذْ خَافِي. إِنِي أَيِي مَاشَا ڒخُّو، س مِينْ زِي زمَّارنْ أَذْ شكْ شَارْفنْ.“  
\v 11 نتَّا إِنَّا أَسْ: ”مَاڒَا شَارْفنْ أَيِي س ثْسغْوِينْ ن جْذِيذْ وَارْ تّْوَاسّْخذْمنْثْ \add عمَّارْصْ\add*، أَذْ ذوْڒغْ أَرْخُوغْ أَمْ \add كُوڒْ\add* إِجّْ ن بْنَاذمْ نّغْنِي.“  
\v 12 ؤُشَا ذَالِيلَا ثكْسِي ثِيسغْوِينْ ثِيمَايْنُوثِينْ ثْشَارْفْ إِ-ث زَّايْسنْثْ ؤُ ثنَّا أَسْ: ”أَ شَامْشُونْ، إِفِيلِيسْطِينِييّنْ \add ؤُسِينْ-د\add* خَاكْ!“، \add ذڭْ ؤُمُورْ ذ إِجّنْ\add* ثُوغَا حذْ ذڭْ إِشْثْ ن ثخَّامْثْ ن ذَاخڒْ إِطّفْ أَحطُّو. \add خنِّي\add* إِقطّسْ ثِيسغْوِينْ زڭْ إِغَادْجنْ نّسْ أَمْ يِيجّْ ن ؤُفِيڒُو.   
\m
\v 13 خَاسْ ؤُشَا ثنَّا ذَالِيلَا إِ شَامْشُونْ: ”خْزَارْ، شكْ ثْشمْثذْ أَيِي ؤُ ثسّْخَارّْقذْ خَافِي. إِنِي أَيِي مَاشَا، س مِينْ زِي زمَّارنْ أَذْ شكْ شَارْفنْ؟“ نتَّا إِنَّا أَسْ: ”مَاڒَا شمْ ثْمُوذذْ سبْعَا ن ثْمُوزَارِينْ خْ ؤُزدْجِيفْ إِنُو أَكْ-ذ وخْمَارْ \add ن دّبُّوزْ ن ثْخيَّاضْثْ\add*!“  
\v 14 \add خنِّي\add* نتَّاثْ ثسّمْثذْ ثنْثْ س يِيجّْ ن ؤُمسْمِيرْ، ثنَّا أَسْ: ”أَ شَامْشُونْ، إِفِيلِيسْطِينِييّنْ \add ؤُسِينْ-د\add* خَاكْ!“ \add خنِّي\add* إِفَاقْ-د زڭْ يِيضصْ نّسْ، إِكّسْ-د دّبُّوزْ ن ثْخيَّاضْثْ ذ ؤُفِيڒُو.   
\m
\v 15 \add خَاسْ ؤُشَا\add* ثنَّا أَسْ: ”مَامّشْ ثْزمَّارذْ أَذْ ثِينِيذْ: ’نشّْ تّخْسغْ شمْ!‘، مَاڒَا ؤُڒْ نّشْ وَارْ غَارِي إِدْجِي؟ ڒخُّو ثْشمْثذْ أَيِي ثْڒَاثَا ن ثْوَاڒَاوِينْ ؤُ وَارْ ذ أَيِي ثنِّيذْ زِي مَانِيسْ غَاركْ جّهْذْ-أَ أَمقّْرَانْ.“  
\v 16 ؤُشَا إِمْسَارْ، ؤُمِي نتَّاثْ ثڭَّا خَاسْ أَغِيڒْ س وَاوَاڒنْ نّسْ ؤُ ثهْوڒْ إِ-ث مَارَّا ؤُسَّانْ، إِذْوڒْ ڒعْمَارْ نّسْ ذِي ڒحْصَارثْ أَڒْ ڒْموْثْ.  
\v 17 نتَّا إِسَّارْڭبْ إِ-ت مَارَّا خْ وُوڒْ نّسْ، إِنَّا أَسْ: ”إِجّْ ن ڒْمُوسْ إِ ؤُحفِّيعمَّارْصْ وَارْ غَارِي د-يُوسِي خْ ؤُزدْجِيفْ إِنُو، مِينْزِي نشّْ أَربُّوغْ تَّاجْ \add ن وعْزَاڒْ\add* زڭْ ؤُعذِّيسْ ن يمَّاسْ. مَاڒَا إِتّْوَاحفّْ ؤُشُوَّافْ إِنُو، خنِّي أَذْ أَيِي إِفّغْ جّهْذْ إِنُو، أَذْ ذوْڒغْ أَرْخُوغْ أَمْ كُوڒْ بْنَاذمْ \add نّغْنِي\add*.“  
\v 18 \add ؤُمِي\add* ثژْرَا ذَالِيلَا، بلِّي أَقَا نتَّا إِسَّارْڭبْ إِ-ت مَارَّا خْ وُوڒْ نّسْ، نتَّاثْ ثسّكّْ غَارْ ڒْبَاشَاثْ ن \add ثْندَّامْ ن\add* إِفِيلِيسْطِينِييّنْ، ثنَّا: ”أَسمْ-د ثْوَاڒَا-يَا ذَا، مِينْزِي إِسَّارْڭبْ أَيِي مَارَّا سِيرّْ ن وُوڒْ نّسْ.“ ڒْبَاشَاثْ ن \add ثْندَّامْ ن\add* إِفِيلِيسْطِينِييّنْ ڭعّْذنْ-د غَارسْ، إِوْينْ-د أَكِيذْسنْ \add ڒْوزْنَاثْ ن\add* نُّوقَارْثْ ذڭْ ؤُفُوسْ نْسنْ.  
\v 19 نتَّاثْ ثجَّا شَامْشُونْ أَذْ إِطّصْ خْ إِفَادّنْ نّسْ، ثْڒَاغَا إِ ورْيَازْ، ثْقسّْ أَسْ سبْعَا ن ثْمُوزَارِينْ خْ ؤُزدْجِيفْ نّسْ ؤُشَا ثبْذَا نتَّاثْ ثطّفْ إِ-ث غَارسْ ؤُشَا جّهْذْ نّسْ إِفّغْ زَّايسْ.  
\v 20 \add خنِّي\add* ثنَّا: ”أَ شَامْشُونْ، إِفِيلِيسْطِينِييّنْ \add ؤُسِينْ-د\add* خَاكْ!“ نتَّا إِفَاقْ-د زڭْ يِيضصْ، إِنَّا: ”ثْوَاڒَا-يَا أَذْ أَرْخُوغْ، أَذْ سّْفكّغْ إِخفْ إِنُو“، \add مِينْزِي\add* نتَّا وَارْ إِسِّينْ، أَقَا سِيذِي ثُوغَا إِسْمحْ ذَايسْ.  
\v 21 \add خنِّي\add* طّْفنْ ث إِفِيلِيسْطِينِييّنْ، قڒْعنْ أَسْ ثِيطَّاوِينْ ؤُشَا نذْهنْ ث غَارْ غَازَّا، شَارْفنْ ث س ثْنَاينْ ن سّْنَاسڒْ ن نّْحَاسْ ؤُ نتَّا إِذْوڒْ إِسُّونُّوضْ ثَاسِيرْثْ ذِي ڒحْبسْ.  
\v 22 \add مَاشَا\add* أَشُوَّافْ ن ؤُزدْجِيفْ نّسْ إِذْوڒْ إِمقَّارْ ذغْيَا أَوَارْنِي ڒَامِي إِ ذ أَسْ حفّنْ.   
\b  
\m  
\s1 ڒْموْثْ ن شَامْشُونْ  
\m
\v 23 ڒْبَاشَاثْ ن \add ثْندَّامْ ن\add* إِفِيلِيسْطِينِييّنْ مُوننْ، حِيمَا أَذْ قدّْمنْ إِشْثْ ن ثْغَارْصْثْ ذ ثَامقّْرَانْثْ إِ ذَاجُونْ، أَربِّي نْسنْ، ؤُڒَا إِ ڒفْرَاحثْ، ؤُشَا نَّانْ: ”أَربِّي نّغْ إِوْشَا أَنغْ شَامْشُونْ، ڒعْذُو نّغْ، ذڭْ إِفَاسّنْ نّغْ.“  
\v 24 \add ؤُمِي\add* ث إِژْرَا ڒْڭنْسْ، سّمْغَارنْ أَربِّي نْسنْ، مَاغَارْ نَّانْ: ”أَربِّي نّغْ إِڭَّا ڒعْذُو نّغْ ذڭْ ؤُفُوسْ نّغْ: نتَّا، ونِّي إِخْڒَانْ ثَامُّورْثْ نّغْ ذ ونِّي إِنْغِينْ زَّايْنغْ أَطَّاسْ!“  
\v 25 ؤُشَا إِمْسَارْ، ؤُمِي ؤُڒْ نْسنْ ثُوغَا إِفَارْحْ، نَّانْ: ”ڒَاغَامْ إِ شَامْشُونْ، حِيمَا أَذْ أَنغْ إِسّْفَارْحْ.“ ؤُشَا ڒَاغَانْ-د خْ شَامْشُونْ زِي ڒحْبسْ ؤُشَا سّْثهْزَانْ زَّايسْ زَّاثْ إِ وُوذمْ نْسنْ ؤُشَا جِّينْ ث أَذْ إِبدّْ جَارْ إِپِيلَارنْ.  
\v 26 \add خنِّي\add* إِنَّا شَامْشُونْ إِ ؤُحنْجِيرْ ونِّي ث إِنذْهنْ زڭْ ؤُفُوسْ: ”أوْشْ أَيِي شْوَايْثْ ن أَرَّاحثْ. خْسغْ أَذْ حَاذِيغْ إِپِيلَارنْ إِ يَاربُّونْ ثَادَّارْثْ، مَاحنْذْ أَذْ خَاسنْ سنّْذغْ.“  
\v 27 ثَادَّارْثْ ثُوغَا ثشُّورْ س يرْيَازنْ ذ ثمْغَارِينْ. ثُوغَا ذِينْ \add عَاوذْ\add* مَارَّا ڒْبَاشَاثْ ن \add ثْندَّامْ ن\add* إِفِيلِيسْطِينِييّنْ. خْ ثْزقَّا \add إِوَاطَانْ\add* ثُوغَا \add قِّيمنْ\add* أَمنِّي ثڒْثْ-أَڒَافْ ن يرْيَازنْ ذ ثمْغَارِينْ نِّي خزَّارنْ ؤُمِي إِتّْغنّنْ شَامْشُونْ.  
\v 28 \add خنِّي\add* إِڒَاغَا شَامْشُونْ غَارْ سِيذِي، إِنَّا: ”سِيذِي إِنُو، سِيذِي، خَارّصْ ذَايِي. أوْشْ أَيِي مْغِيرْ ثْوَاڒَا-يَا وَاهَا جّهْذْ إِنُو، \add أَ\add* أَربِّي، حِيمَا أَذْ نْثَاقْمغْ إِخفْ إِنُو زڭْ إِفِيلِيسْطِينِييّنْ ذِي سِّيبّثْ ن ثِيطَّاوِينْ إِنُو ذڭْ إِشْثْ ن ثْوَاڒَا.“ \x ◘ \xo 16:‏28 \xt عبر. 11‏:‏32\x*  
\v 29 ؤُشَا إِطّفْ شَامْشُونْ ثْنَاينْ ن إِپِيلَارنْ إِ \add إِدْجَانْ\add* ذِي ڒْوسْطْ إِ يَارْبُونْ ؤُ مِينْ خفْ ثْسنّذْ ثَادَّارْثْ، \add إِطّفْ\add* إِجّْ ن ؤُپِيلَارْ س ؤُفُوسْ نّسْ أَفُوسِي ذ ونّغْنِي س ؤُفُوسْ نّسْ أَزڒْمَاضْ.  
\v 30 خَاسْ ؤُشَا شَامْشُونْ إِنَّا: ”أجّْ ڒعْمَارْ إِنُو أَذْ إِمّثْ أَكْ-ذ إِفِيلِيسْطِينِييّنْ!“، ؤُ نتَّا إِغْنسْ إِخفْ نّسْ غَارْ زَّاثْ س \add مَارَّا\add* جّهْذْ نّسْ ؤُشَا ثوْضَا ثَادَّارْثْ خْ ڒْبَاشَاثْ \add ن ثْندَّامْ\add* ؤُ خْ مَارَّا ڒْڭنْسْ إِ ذَايسْ ثُوغَا إِدْجَانْ. ثُوغَا قدَّا ن يِينِّي إِ إِنْغَا س ڒْموْثْ نّسْ ذ أَمقّْرَانْ خْ يِينِّي ثُوغَا إِنْغَا ؤُمِي ثُوغَا إِدَّارْ.  
\v 31 أَيْثْمَاسْ ذ مَارَّا ثَادَّارْثْ ن بَابَاسْ هْوَانْ-د ؤُ سّْڭعّْذنْ ث، إِوْينْ ث ؤُ نضْڒنْ ث جَارْ صُورْعَا ذ إِشْثَاؤُولْ ذڭْ ونْضڒْ ن بَابَاسْ مَانُوحْ. ثُوغَا نتَّا ذ ڒْقَاضِي خْ إِسْرَائِيل عِيشْرِينْ ن إِسڭّْوُوسَا.   
\b  
\b  
\m  
\c 17
\s1 مِيخَا ذ ڒخْيَاڒْ نّسْ ن صَّانَامْ  
\m
\v 1 إِجّْ ن ورْيَازْ ثُوغَا إِزدّغْ خْ إِذُورَارْ ن إِفْرَايِيمْ، قَّارنْ أَسْ مِيخَا-يَاهُو.  
\v 2 نتَّا إِنَّا إِ يمَّاسْ: ”أَڒفْ ؤُ-مْيَا ن \add ؤُقِييَّاثْ ن\add* نُّوقَارْثْ إِ ذ أَمْ إِتّْوَاكّْسنْ، إِ خَاسنْثْ ثنِّيذْ إِشْثْ ن نّعْڒثْ إِ زِي ثْنطْقذْ ذڭْ إِمزُّوغنْ إِنُو، خْزَارْ، نُّوقَارْثْ نِّي أَقَا-ت غَارِي، نشّْ كْسِيغْ ت.“ يمَّاسْ ثنَّا: ”أَذْ إِتّْوَابَاركْ مِّي زِي سِيذِي!“  
\v 3 نتَّا يَارَّا أَڒفْ ؤُ-مْيَا ن \add ؤُقِييَّاثْ ن\add* نُّوقَارْثْ إِ يمَّاسْ ؤُشَا يمَّاسْ ثنَّا أَسْ: ”نُّوقَارْثْ سّْقدّْسغْ ت إِ سِيذِي زڭْ ؤُفُوسْ إِنُو إِ مِّي حِيمَا أَذْ زَّايسْ إِڭّْ إِجّْ ن ڒخْيَاڒْ إِنقْشنْ ذ إِجّْ ن ڒخْيَاڒْ إِفسْينْ. \add خنِّي\add* ڒخُّو أَذْ أَشْ ت أَرّغْ.“  
\v 4 نتَّا \add مَاشَا\add* يَارَّا نُّوقَارْثْ \add عَاوذْ\add* إِ يمَّاسْ. \add خنِّي\add* ثكْسِي يمَّاسْ مِيثَاينْ ن \add ؤُقِييَّاثْ ن\add* نُّوقَارْثْ ؤُ ثوْشَا إِ-ثنْثْ إِ يِيجّْ ن ومْزِيڒْ ن وُورغْ، ونِّي زَّايسْ إِڭِّينْ إِجّْ ن ڒخْيَاڒْ إِنقْشنْ ذ يِيجّْ ن ڒخْيَاڒْ إِفسْينْ ؤُشَا ڭِّينْ ثنْثْ ذِي ثَادَّارْثْ ن مِيخَا-يَاهُو.  
\v 5 ثُوغَا مِيخَا غَارسْ إِشْثْ ن ثَادَّارْثْ ن أَربِّي ؤُ نتَّا إِڭَّا إِجّْ ن ؤُپَالْطُو \add ن ؤُكهَّانْ\add* ذ ڒخْيَاڒَاثْ ثِيمژْيَانِينْ ن لْ-أَصْنَامْ ؤُشَا إِڒقّمْ إِجّنْ زڭْ إِحنْجِيرنْ نّسْ أَذْ غَارسْ يِيڒِي ذ أَكهَّانْ.   
\m
\v 6 ذڭْ وُوسَّانْ نِّي وَارْ ذِينْ ثُوغِي أَجدْجِيذْ ذِي إِسْرَائِيل. كُوڒْ إِجّْ إِتّڭّْ مِينْ \add إِدْجَانْ\add* نِيشَانْ ذِي ثِيطَّاوِينْ نّسْ. \x ◘ \xo 17:‏6 \xt ڒقض. 18‏:‏1؛ 21‏:‏25\x*  
\v 7 ذِي بَايْثْ-لَاحْمْ ذِي يَاهُوذَا ثُوغَا ذِينْ إِجّْ ن وبْڒِيغْ زِي ڒْوَاشُونْ ن يَاهُوذَا. نتَّا ثُوغَا ذ إِجّْ ن ؤُلَاوِي، ثُوغَا إِزدّغْ ذِينِّي ذ أَبَارَّانِي.  
\v 8 أَرْيَازْ-أَ إِفّغْ زِي ثنْذِينْثْ نِّي، زِي بَايْثْ-لَاحْمْ ذِي يَاهُوذَا، حِيمَا أَذْ إِزْذغْ أَمْ ؤُبَارَّانِي مَانِي مَا إِزمَّارْ أَذْ يَافْ \add أَمْشَانْ\add*. خْ وبْرِيذْ نّسْ يِيوضْ غَارْ إِذُورَارْ ن إِفْرَايِيمْ غَارْ ثَادَّارْثْ ن مِيخَا.  
\v 9 مِيخَا إِسّقْسَا ث: ”مَانِيسْ إِ د-ثُوسِيذْ شكْ؟“ نتَّا يَارَّا-د خَاسْ: ”نشّْ ذ أَلَاوِي زِي بَايْثْ-لَاحْمْ ذِي يَاهُوذَا. نشّْ ڭُّورغْ، حِيمَا أَذْ زذْغغْ مَانِي مَا إِ غَا يَافغْ \add أَمْشَانْ\add*.“  
\v 10 \add خنِّي\add* إِنَّا أَسْ مِيخَا: ”قِّيمْ غَارِي ؤُشَا ثِيڒِيذْ أَيِي ذ بَابَا ذ أَكهَّانْ! نشّْ أَذْ أَشْ وْشغْعشْرَا ن \add ؤُقِييَّاثْ ن\add* نُّوقَارْثْ ذ شَا ن ورُّوضْ ذ ڒعْوتْشْ.“ ؤُشَا أَلَاوِي يُويُورْ أَكِيذسْ.  
\v 11 أَلَاوِي يَارْضَا خَاسْ ذڭْ وَاوَاڒْ حِيمَا أَذْ إِقِّيمْ أَكْ-ذ ورْيَازْ ؤُ أَبْڒِيغْ ثُوغَا إِ مِيخَا أَمْ يِيجّنْ زڭْ أَرَّاوْ نّسْ.  
\v 12 مِيخَا إِشُّورْ أَلَاوِي ؤُشَا إِذْوڒْ وبْڒِيغْ ذ أَكهَّانْ إِ نتَّا ؤُشَا إِقِّيمْ ذِي ثَادَّارْثْ ن مِيخَا.  
\v 13 ؤُشَا إِنَّا مِيخَا: ”ڒخُّو سّْنغْ نشّْ، أَقَا سِيذِي أَذْ أَيِي إِڭّْ ڒْخَارْ، مَاغَارْ نشّْ غَارِي أَلَاوِي وَانِيثَا ذ أَكهَّانْ.“   
\b  
\b  
\m  
\c 18
\s1 ثَاقْبِيتْشْ ن ذَانْ ثطّفْ لَايِيشْ ذ ثَاسْغَارْثْ نّسْ  
\m
\v 1 ذڭْ وُوسَّانْ نِّي وَارْ ذِينْ ثُوغِي أَجدْجِيذْ ذِي إِسْرَائِيل ؤُ ذڭْ وُوسَّانْ نِّي ثُوغَا ثَاقْبِيتْشْ ن ذَانْ ثَارزُّو ثَاسْغَارْثْ إِ يِيخفْ نّسْ مَاحنْذْ أَذْ ذَايسْ ثزْذغْ، مِينْزِي وَارْ ذ أَسْ د-ثكَّارْ \add عَاذْ\add* ثسْغَارْثْ جَارْ ثْقبَّاڒْ ن إِسْرَائِيل. \x ◘ \xo 18:‏1 \xt  ڒقض. 17‏:‏6؛ 21‏:‏25\x*  
\v 2 سّكّنْ أَيْثْ ن ذَانْ زِي ڒْوَاشُونْ نْسنْ خمْسَا ن يرْيَازنْ زِي مَارَّا طّْرُوفَا نْسنْ، إِرْيَازنْ \add نِّي\add* ذ أَيْثْ ن ؤُمنْغِي إِنِّي د-يُوسِينْ زِي صُورْعَا ذ إِشْثَاؤُولْ، حِيمَا أَذْ أَرْزُونْ ڒخْبَارْ خْ ثمُّورْثْ، أَذْ ذَايسْ يَارْزُونْ. نِيثْنِي نَّانْ أَسنْ: ”ؤُيُورمْ، أَرْزُومْ ثَامُّورْثْ!“ ؤُسِينْ-د غَارْ إِذُورَارْ ن إِفْرَايِيمْ غَارْ ثَادَّارْثْ ن مِيخَا ؤُشَا سّنْسنْ ذِينِّي.  
\v 3 \add ؤُمِي\add* \add إِوْضنْ\add* نِيثْنِي غَارْ ثَادَّارْثْ ن مِيخَا،عقْڒنْ خْ ثْمِيجَّا ن وبْڒِيغْ زڭْ أَيْثْ ن لَاوِي، ؤُشَا فّْغنْ \add زڭْ وبْرِيذْ\add* غَارسْ، نَّانْ أَسْ: ”مِينْ شكْ إِ ذَا د-يِيوْينْ ؤُ مِينْ إِ ذَا ثتّڭّذْ ؤُ مِينْ إِ ذَا ثَارزُّوذْ شكْ؟“  
\v 4 نتَّا يَارَّا-د خَاسنْ: ”ثَا ذ ثَا إِ إِڭَّا مِيخَا أَكِيذِي. نتَّا إِشْرَا أَيِي ؤُ أَمُّو إِ ذوْڒغْ نشّْ ذ أَكهَّانْ نّسْ.“  
\v 5 نِيثْنِي نَّانْ أَسْ: ”سقْسَا أَنغْ أَربِّي، مَاحنْذْ أَذْ نسّنْ، مَا أَبْرِيذْ إِ غَا نُويُورْ، أَذْ يِيڒِي مْلِيحْ.“  
\v 6 يَارَّا-د خَاسنْ ؤُكهَّانْ: ”ؤُيُورمْ ذِي ڒهْنَا! أَبْرِيذْ إِ ثخْسمْ أَذْ ث ثكّمْ، أَقَا-ث \add يَارزْمنْ\add* زَّاثْ إِ \add ثِيطَّاوِينْ ن\add* سِيذِي.“   
\m
\v 7 \add خنِّي\add* رُوحنْ خمْسَا ن يرْيَازنْ نِّي، إِوْضنْ غَارْ لَايِيشْ. نِيثْنِي ژْرِينْ أَقَا ڒْڭنْسْ إِزْذغْ ذَايسْ ذِي ڒَامَانْ أَمْ مَامّشْ ث ثُوغَا ذ لْقَاعِيذَا غَارْ أَيْثْ نْ صِيذُونْ، س ڒْهُوذْنثْ ؤُ ذِي ڒَامَانْ. ثُوغَا وَارْ ذِينْ ؤُڒَا ذ إِجّْ ذِي ثمُّورْثْ ونِّي إِحْصَارنْ خْ \add يِيجّنْ\add* ذِي شَا ن ڒْحَاجّثْ نِيغْ إِطّفْ شَا س ڒخْشُونثْ. نِيثْنِي ثُوغَا إِڭّْوجنْ أَطَّاسْ خْ أَيْثْ ن صِيذُونْ ؤُ وَارْ غَارْسنْ ثُوغِي وَالُو ؤُڒَا أَكْ-ذ إِجّْ ن بْنَاذمْ.  
\v 8 ؤُشَا ؤُسِينْ-د غَارْ أَيْثْمَاثْسنْ ذِي صُورْعَا ذ إِشْثَاؤُولْ ؤُشَا نَّانْ أَسنْ أَيْثْمَاثْسنْ: ”مَانْ \add أَوَاڒْ إِ\add* غَارْومْ؟“  
\v 9 نِيثْنِي أَرِّينْ-د خَاسنْ: ”كَّارمْ، جّمْ أَذْ نْڭعّذْ، مِينْزِي نژْرَا ثَامُّورْثْ، ؤُ خْزَارْ، أَقَا-ت ثشْنَا أَطَّاسْ. مَا خنِّي \add ثخْسمْ\add* أَذْ ثقِّيممْ ثتَّارْسَامْ أَمُّو؟ وَارْ تّعْڭِيزمْ شَا مَاحنْذْ أَذْ ثَاذْفمْ غَارْ ثمُّورْثْ حِيمَا أَذْ ت ثطّْفمْ ذ ڒْوَارْثْ.  
\v 10 مَاڒَا كنِّيوْ أَذْ ثَاوْضمْ ذِينْ، \add خنِّي\add* أَذْ ثَافمْ إِجّْ ن ڒْڭنْسْ \add إِزدّْغنْ\add* ذِي ڒَامَانْ ؤُشَا ثَامُّورْثْ ثوْسعْ أَطَّاسْ غَارْ ثْنَاينْ ن إِغزْذِيسنْ، مِينْزِي أَربِّي إِڭَّا أَومْ ت ذڭْ ؤُفُوسْ نْومْ، أَقَا-ث ذ إِجّْ ن ومْشَانْ مَانِي وَارْ ذ أَسْ إِتّْخصِّي وَالُو ن مِينْ إِدْجَانْ خْ ثمُّورْثْ.“   
\m
\v 11 \add خَاسْ ؤُشَا\add* كّْسنْ إِقِيضَانْ نْسنْ سّنِّي، زِي ڒَادْجْ ن ذَانْ زِي صُورْعَا ذ إِشْثَاؤُولْ، ستَّا مْيَا ن يرْيَازنْ حزّْمنْ س ڒسْنَاحْ.  
\v 12 نِيثْنِي ڭعّْذنْ ؤُشَا وْثِينْ إِقِيضَانْ نْسنْ غَارْ قَارْيَاثْ-يَاعَارِيمْ ذِي يَاهُوذَا. خْ ؤُيَا قَّارنْ أَسْ إِ ومْشَانْ نِّي ’مَاخَانْ-ذَانْ‘ أَڒْ أَسّْ-أَ. خْزَارْ، أَقَا-ت أَوَارْنِي إِ قَارْيَاثْ-يَاعَارِيمْ. \f ◼ \fr 18:‏12 \ft \+bd ’مَاخَانْ-ذَانْ‘\+bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’ثسْقِيفْثْ ن ذَانْ‘.\f*  \x ◘ \xo 18:‏12 \xt ڒقض. 13‏:‏25\x*  
\v 13 سّنِّي فّْغنْ، عْذُونْ غَارْ إِذُورَارْ ن إِفْرَايِيمْ إِوْضنْ غَارْ ثَادَّارْثْ ن مِيخَا.  
\v 14 \add خنِّي\add* سِّيوْڒنْ خمْسَا ن يرْيَازنْ، إِنِّي ثُوغَا إِڭُّورنْ حِيمَا أَذْ برْڭنْ ثَامُّورْثْ ن لَايِيشْ، نَّانْ إِ أَيْثْمَاثْسنْ: ”مَا ثسّْنمْ، أَقَا ذِي ثُوذْرِينْ نِّي أَقَا ذِينْ إِجّْ ن ؤُپَالْطُو \add ن ؤُكهَّانْ\add* ذ ڒخْيَاڒَاثْ ثِيمژْيَانِينْ ن لْ-أَصْنَامْ ذ إِجّْ نْ ڒخْيَاڒْ إِنقْشنْ ذ إِجّْ ن ڒخْيَاڒْ إِفسْينْ؟ خنِّي ڒخُّو، ثسّْنمْ مِينْ خَاومْ أَذْ ث ثڭّمْ.“   
\m
\v 15 \add ڒخْذنِّي\add* فّْغنْ \add زڭْ وبْرِيذْ نْسنْ\add*، ؤُسِينْ-د غَارْ ثَادَّارْثْ ن وبْڒِيغْ، غَارْ ثَادَّارْثْ ن ورْيَازْ زڭْ أَيْثْ ن لَاوِي، غَارْ ثَادَّارْثْ ن مِيخَا، ؤُشَا سّقْسَانْ خْ مَامّشْ إِدْجَا.  
\v 16 ستَّا-مْيَا ن يرْيَازنْ زڭْ أَيْثْ ن ذَانْ إِ إِحزّْمنْ س ڒسْنَاحْ نْسنْ، قِّيمنْ بدّنْ غَارْ وَاذَافْ ن ثوَّارْثْ.  
\v 17 خمْسَا ن يرْيَازنْ، إِنِّي ثُوغَا إِفّْغنْ حِيمَا أَذْ برْڭَاڭنْ ثَامُّورْثْ، ڭعّْذنْ، ؤُذْفنْ ؤُ إِوْينْ ڒخْيَاڒْ إِنقْشنْ ذ ؤُپَالْطُو \add ن ؤُكهَّانْ\add* ذ ڒخْيَاڒَاثْ ثِيمژْيَانِينْ ن لْ-أَصْنَامْ ذ ڒخْيَاڒْ إِفسْينْ. أَكهَّانْ إِقِّيمْ إِبدّْ غَارْ ؤُقمُّومْ ن ثوَّارْثْ أَكْ-ذ ستَّا-مْيَا ن يرْيَازنْ إِحزّْمنْ س ڒسْنَاحْ.  
\v 18 \add خمْسَا\add* إِنَا ؤُذْفنْ غَارْ ثَادَّارْثْ ن مِيخَا، كّْسنْ ڒخْيَاڒْ إِنقْشنْ ذ ؤُپَالْطُو ن ؤُكهَّانْ ذ ڒخْيَاڒَاثْ ثِيمژْيَانِينْ ن لْ-أَصْنَامْ ذ ڒخْيَاڒْ إِفسْينْ. \add خنِّي\add* إِنَّا أَسنْ ؤُكهَّانْ: ”مِينْ ذِينْ ثتّڭّمْ؟“  
\v 19 نِيثْنِي نَّانْ أَسْ: ”سُوسمْ، سَارْسْ أَفُوسْ نّشْ خْ ؤُقمُّومْ نّشْ، ؤُيُورْ أَكِيذْنغْ ؤُ ذْوڒْ ذ بَابَا ذ أَكهَّانْ نّغْ! مِينْ إِحْڒَانْ، مَاڒَا شكْ ذ أَكهَّانْ ذِي ثَادَّارْثْ ن إِجّْ ن ورْيَازْ وَاهَا نِيغْ مَاڒَا شكْ ذ أَكهَّانْ إِ يِيشْثْ ن ثقْبِيتْشْ ذ يِيجّْ ن ڒَادْجْ ذِي إِسْرَائِيل؟“  
\v 20 \add ڒخْذنِّي\add* إِفَارْحْ وُوڒْ ن ورْيَازْ نِّي ؤُشَا إِكْسِي أَپَالْطُو ن ؤُكهَّانْ ذ ڒخْيَاڒَاثْ ثِيمژْيَانِينْ ن لْ-أَصْنَامْ ذ ڒخْيَاڒْ إِنقْشنْ ؤُشَا يُوذفْ جَارْ ڒْڭنْسْ.  
\v 21 ؤُشَاعقْبنْ نِيثْنِي، فّْغنْ ؤُشَا نذْهنْ إِحنْجِيرنْ ذ ڒْمَاڒْ ذ دّْقُوڒَاثْ أَكِيذْسنْ غَارْ زَّاثْ.   
\m
\v 22 ؤُمِي نِيثْنِي ثُوغَا إِڭّْوجنْ أَطَّاسْ خْ ثَادَّارْثْ ن مِيخَا، ڒَاغَانْ-د إِ يرْيَازنْ ذِي ثُوذْرِينْ يُوذْسنْ خْ ثَادَّارْثْ ن مِيخَا، حِيمَا أَذْ مُوننْ ؤُشَا نِيثْنِي خشّنْ خْ أَيْثْ ن دَان.  
\v 23 نِيثْنِي ڒَاغَانْ أَوَارْنِي إِ أَيْثْ ن ذَانْ، \add مَاشَا\add* إِنَا نّْقڒْبنْ أَزدْجِيفْ نْسنْ، نَّانْ إِ مِيخَا: ”مِينْ شكْ يُوغِينْ؟ مَايمِّي ثْڒَاغِيذْ حِيمَا أَذْ تّْوَاسّْمُوننْ \add مَارَّا\add*؟“  
\v 24 إِنَّا نتَّا: ”كنِّيوْ ثكّْسمْ خَافِي إِربِّيثنْ إِنُو إِ ڭِّيغْ ؤُڒَا ذ أَكهَّانْ ؤُشَا ثُويُورمْ. مِينْ غَارِي ڒخُّو عَاذْ؟ مَامّشْ ثڭِّيمْ عَاذْ ثقَّارمْ أَيِي: ’مِينْ شكْ يُوغِينْ؟‘ “  
\v 25 أَيْثْ ن ذَانْ نَّانْ أَسْ: ”غَاركْ أَذْ نْسڒْ إِ ثْمِيجَّا نّشْ غَارْنغْ نِيغْ \add إِزمَّارْ\add* أَذْ خَاومْ وْضَانْ إِرْيَازنْ يوْعَارنْ ؤُ إِڒِي \add أَذْ ثَاغْ\add* أَذْ إِودَّارْ ڒعْمَارْ نّشْ ؤُڒَا ذ ڒعْمُورْ ن ثَادَّارْثْ نّشْ.“  
\v 26 ؤُشَا ؤُيُورنْ أَيْثْ ن ذَانْ ذڭْ وبْرِيذْ نْسنْ ؤُشَا ؤُمِي إِژْرَا مِيخَا بلِّي نِيثْنِي ثُوغَا جهْذنْ خَاسْ، إِنّقْڒبْ، يَارڭّْوحْ غَارْ ثَادَّارْثْ نّسْ.   
\m
\v 27 نِيثْنِي \add مَاشَا\add* إِوْينْ مِينْ إِڭِّينْ مِيخَا ؤُڒَا ذ أَكهَّانْ ونِّي ثُوغَا غَارسْ \add إِتّْسخَّارنْ\add*. نِيثْنِي إِوْضنْ غَارْ لَايِيشْ، غَارْ إِجّْ ن ڒْڭنْسْ \add إِزدّْغنْ\add* ذِي ڒْهُوذْنثْ ذ ڒَامَانْ ؤُشَا نْغِينْ ثنْ س ڒقْضعْ ن سِّيفْ ؤُ سّْشمْضنْ ثَانْذِينْثْ س ثْمسِّي.  
\v 28 وَارْ ذِينْ ؤُڒَا ذ إِجّنْ \add إِزمَّارْ\add* أَذْ إِفكّْ، مِينْزِي لَايِيشْ ثُوغَا ثِيڭّْوّجْ أَطَّاسْ خْ صِيذُونْ ؤُ وَارْ ثُوغِي غَارْسنْ وَالُو ؤُڒَا أَكْ-ذ إِجّْ ن بْنَاذمْ. ثُوغَا-ت ذِي ڒوْضَا ن ثغْزُورْثْ نِّي غَارْ بَايْثْ-رَاحُوبْ. أَوَارْنِي ؤُيَا بْنَانْ ثَانْذِينْثْ \add عَاوذْ\add* ؤُشَا زدّْغنْ ذَايسْ.  
\v 29 نِيثْنِي قَّارنْ أَسْ إِ ثنْذِينْثْ ’ذَانْ‘، خْ يِيسمْ ن بَابَاثْسنْ ذَانْ، ونِّي د-إِتّْوَارْونْ إِ إِسْرَائِيل. مَاشَا زِيشْ ثَانْذِينْثْ ثُوغَا قَّارنْ أَسْ لَايِيشْ. \x ◘ \xo 18:‏29 \xt ياش. 19‏:‏47\x*   
\m
\v 30 أَيْثْ ن ذَانْ سّْبدّنْ ڒخْيَاڒْ إِنقْشنْ إِ يِيخفْ نْسنْ. ؤُشَا يَاهُونَاثَانْ، مِّيسْ ن جَارْشُومْ، مِّيسْ ن مُوسَا، نتَّا أَكْ-ذ إِحنْجِيرنْ نّسْ، ثُوغَا أَثنْ ذ إِكهَّاننْ ن ثقْبِيتْشْ ن ذَانْ أَڒْ أَسّْ إِ ذِي ثتّْوَانْذهْ ثمُّورْثْ غَارْ لْمنْفَا. \f ◼ \fr 18:‏30 \ft \+bd ’مِّيسْ ن مُوسَا‘\+bd* - أَقَا نشِّينْ نتَّافْ ذِي ڒْمَاخْطُوطَاثْ ن إِمَاسُورِيثِييّنْ، إِنِّي إِدْجَانْ ذ إِمَارِيرنْ ن وُوذَاينْ، إِسمْ ن مَانَاسَّا ذڭْ ومْشَانْ ن يِيسمْ ن مُوسَا. وَاخَّا أَمنِّي أَزْينْ أَمقّْرَانْ ن ينِّي أَرزُّونْ س جّهْذْ ذڭْ وذْلِيسْ إِقدّْسنْ ن سِيذِي أَربِّي قَّارنْ بلِّي إِسمْ ن مَانَاسَّا وَارْ يُورَانْ ذَانِيثَا أَمْ مَامّشْ نّغْنِي ؤُمِي لْحَارْفْ ’نُونْ‘ غَارسْ إِجّْ ن شّكْلْ إِفَارْزنْ، وَارْ إِدْجِي أَمْ مَامّشْ ث يُورَانْ ذڭْ إِمُوشَانْ نّغْنِي. س ؤُينِّي إِتّْغِيڒْ أَسنْ أَقَا إِمَاسُورِيثِييّنْ أَرْنِينْ لْحَارْفْ ’نُونْ‘ مَاغَارْ نِيثْنِي وَارْ خْسنْ أَذْ دّدْجنْ إِسمْ ن مُوسَا س وعْبذْ ن لَاصْنَامْ أَمْ مَامّشْ إِ ث إِڭَّا يَاهُونَاثَانْ ذ ثَارْوَا نّسْ.\f*  
\v 31 نِيثْنِي ثُوغَا سّْبدّنْ ڒخْيَاڒْ إِنقْشنْ ن مِيخَا، ثنِّي إِڭَّا، زَّاثْ إِ يِيخفْ نْسنْ مَارَّا ؤُسَّانْ مِينْ ثكَّا ثَادَّارْثْ ن أَربِّي ثدْجَا ذِي شِيلُو.   
\b  
\b  
\m  
\c 19
\s1 ڒفْضِيحثْ إِ إِڭِّينْ أَيْثْ ن بِينْيَامِينْ  
\m
\v 1 ذڭْ وُوسَّانْ نِّي، ؤُمِي وَارْ ذِينْ ثُوغِي أَجدْجِيذْ ذِي إِسْرَائِيل، ثُوغَا ذِينْ إِجّْ ن ؤُلَاوِي إِزدّغْ ذ أَبَارَّانِي \add ذڭْ إِجّْ ن ومْشَانْ\add* غَارْ إِغزْذِيسنْ ن إِذُورَارْ ن إِفْرَايِيمْ. نتَّا يِيوِي إِشْثْ ن ثمْغَارْثْ ذ ثَايَّا زِي بَايْثْ-لَاحْمْ ذِي يَاهُوذَا. \x ◘ \xo 19:‏1 \xt ڒقض. 17‏:‏6؛ 18‏:‏1؛ 21‏:‏25\x*  
\v 2 \add مَاشَا\add* ثَايَّا نّسْ ثذْوڒْ ثسّفْضحْ إِخفْ نّسْ ؤُمِي غَارسْ ت ثُوغَا ؤُشَا ثسْمحْ ذَايسْ، ثعْقبْ غَارْ ثَادَّارْثْ ن بَابَاسْ ذِي بَايْثْ-لَاحْمْ ذِي يَاهُوذَا. ذِينِّي ثقِّيمْ أَطَّاسْ ن وُوسَّانْ، أَربْعَا ن إِيُورنْ.   
\m
\v 3 \add خنِّي\add* إِكَّارْ ورْيَازْ، إِضْفَارْ إِ-ت حِيمَا أَذْ كِيسْ إِسِّيوڒْ س وُوڒْ نّسْ مَاحنْذْ أَذْ ت-إِ-د-إِسَّارڭّْوحْ. ثُوغَا أَمْسخَّارْ نّسْ أَمژْيَانْ أَكِيذسْ ذ إِشْثْ ن ثْيُويَا ن يغْيَاڒْ. ؤُشَا نتَّاثْ ثِيوْيِي إِ-ث غَارْ ثَادَّارْثْ ن بَابَاسْ. \add ؤُمِي\add* ث إِژْرَا بَابَاسْ ن ثْحنْجِيرْثْ إِفَارْحْ ڒَامِي كِيذسْ إِ غَا إِمّڒْقَا.  
\v 4 أَضڭّْوَاڒْ نّسْ، بَابَاسْ ن ثْحنْجِيرْثْ، إِڭَّا خَاسْ \add أَطَّاسْ\add* أَغِيڒْ مَاحنْذْ أَكِيذسْ إِقِّيمْ ثْڒَاثَا ن وُوسَّانْ. نِيثْنِي شِّينْ، سْوِينْ ؤُ سّنْسنْ ذِينِّي.  
\v 5 إِمْسَارْ ذڭْ وَاسّْ وِيسّْ أَربْعَا، أَقَا نِيثْنِي فَاقنْ زِيشْ غَارْ ثُوفُّوثْ ؤُ نتَّا إِكَّارْ إِخْسْ أَذْ يُويُورْ. \add خنِّي\add* إِنَّا بَابَاسْ ن ثْحنْجِيرْثْ إِ وسْڒِي نّسْ: ”سمْحضْ إِخفْ نّشْ س يِيجّْ ن ؤُڒقُّوزْ ن وغْرُومْ، خنِّي أَذْ ثَافْ ثْزمَّارمْ أَذْ ثُويُورمْ.“  
\v 6 نِيثْنِي قِّيمنْ، شِّينْ، سْوِينْ س ثْنَاينْ إِذْسنْ نْسنْ. \add خنِّي\add* إِنَّا بَابَاسْ ن ثْحنْجِيرْثْ إِ ورْيَازْ: ”تّْزَاوْڭغْ، قِّيمْ ذَا، أَذْ ثسّنْسذْ ؤُشَا أَذْ إِفَارْحْ وُوڒْ نّشْ.“  
\v 7 أَرْيَازْ إِكَّارْ حِيمَا أَذْ يُويُورْ، \add مَاشَا\add* أَضڭّْوَاڒْ نّسْ إِكلّفْ خَاسْ، إِڭَّا خَاسْ أَغِيڒْ حِيمَا أَذْ ذِينِّي إِسّنْسْ عَاوذْ.  
\v 8 ذڭْ وَاسّْ وِيسّْ خمْسَا إِكَّارْ زِيشْ غَارْ ثُوفُّوثْ حِيمَا أَذْ يُويُورْ. إِنَّا بَابَاسْ ن ثْحنْجِيرْثْ: ”أَرْنِي سمْحضْ ؤُڒْ نّشْ!“ ؤُ نِيثْنِي قِّيمنْ تّْرَاجَانْ أَڒْ غَا إِعْذُو وَاسّْ ؤُشَا شِّينْ ثْنَاينْ إِذْسنْ مُوننْ.  
\v 9 \add خنِّي\add* إِكَّارْ ورْيَازْ حِيمَا أَذْ يُويُورْ، نتَّا أَكْ-ذ ثَايَّا نّسْ ذ ؤُمْسخَّارْ نّسْ. أَضڭّْوَاڒْ نّسْ، بَابَاسْ ن ثْحنْجِيرْثْ، إِنَّا: ”خْزَارْ، أَسّْ ڭُّورْ أَذْ إِعْذُو ثِيوضْ-د ثْمذِّيثْ، تّْزَاوْڭغْ سنْسمْ ذَا. خْزَارْ، سْفَارْحْ ؤُڒْ نّشْ ؤُ كَّارمْ ثِيوشَّا زِيشْ مَاحنْذْ أَذْ ثطّْفمْ أَبْرِيذْ غَارْ ثْقِيضُونْثْ نّشْ.“  
\v 10 \add مَاشَا\add* أَرْيَازْ وَارْ إِخْسْ شَا \add عَاذْ\add* أَذْ إِسّنْسْ. إِكَّارْ ؤُشَا يُويُورْ، يِيوضْ أَڒْ قِيبَاتْشْ يابُوسْ، ثنِّي ذ ؤُرْشَالِيمْ، ؤُ ثُوغَا إِشْثْ ن ثْيُويَا ن يغْيَاڒْ بَارْذْعنْ ذ ثَايَّا نّسْ أَقَا-ت أَكِيذسْ.  
\v 11 \add ؤُمِي\add* ثنْ \add ثُوغَا\add* نِيثْنِي غَارْ يابُوسْ، ثُوغَا أَسّْ أَذْ إِعْذُو. \add خنِّي\add* إِنَّا ؤُمْسخَّارْ إِ بَابْ نّسْ: ”ؤُيُورْ، أَذْ ذَا نْضَارْ ذِي ثنْذِينْثْ-أَ ن إِيابُوسِييّنْ، أَذْ ذَايسْ نسّنْسْ.“  
\v 12 \add مَاشَا\add* سِيذِي نّسْ يَارَّا-د خَاسْ: ”نشِّينْ وَارْ نتّْميِّيڒْ غَارْ إِشْثْ ن ثنْذِينْثْ ثَاغْرِيبْثْ، ثنِّي وَارْ إِدْجِينْ ن أَيْثْ ن إِسْرَائِيل، \add مَاشَا\add* أَذْ نَارْنِي أَذْ نُويُورْ غَارْ جِيبْعَا.“  
\v 13 نتَّا إِنَّا \add عَاوذْ\add* إِ ؤُمْسخَّارْ نّسْ: ”أَسْ-د، أجّْ أَنغْ \add أَذْ نَارْزُو\add* أَذْ نَاوضْ غَارْ إِجّْ زڭْ إِمُوشَانْ نِّي، أَذْ نسّنْسْ ذِي جِيبْعَا نِيغْ ذِي رَامَا.“   
\m
\v 14 نِيثْنِي أَرْنِينْ ؤُيُورنْ ؤُ ثغْڒِي خَاسنْ ثْفُوشْثْ ؤُمِي ثنْ-ثُوغَا نِيثْنِي غَارْ جِيبْعَا نِّي \add إِدْجَانْ\add* ن بِينْيَامِينْ.  
\v 15 ؤُشَا سّْفَارْغنْ \add زڭْ وبْرِيذْ\add*، حِيمَا أَذْ أَذْفنْ غَارْ ذِينْ مَاحنْذْ أَذْ سّنْسنْ ذِي جِيبْعَا. \add ؤُمِي\add* غَارْ ذِينْ يُوذفْ، إِقِّيمْ ذڭْ وَازَّايْ ن ثنْذِينْثْ، مِينْزِي وَارْ ثنْ إِسِّيذفْ حذْ غَارْ ثَادَّارْثْ مَاحنْذْ أَذْ سّنْسنْ.  
\v 16 ؤُشَا خْزَارْ، غَارْ ثْمذِّيثْ إِعْقبْ-د يِيجّْ ن ؤُوسَّارْ زِي ڒْخذْمثْ نّسْ زڭْ إِيَّارْ. ثُوغَا أَرْيَازْ نِّي \add عَاوذْ\add* زڭْ إِذُورَارْ ن إِفْرَايِيمْ، \add مَاشَا\add* إِزْذغْ أَمْ أَبَارَّانِي ذِي جِيبْعَا، مَاشَا إِمزْذَاغْ ن ثمُّورْثْ نِّي ثُوغَا أَثنْ ذ أَيْثْ ن بِينْيَامِينْ.  
\v 17 إِسّْڭعّذْ نتَّا ثَامُوغْڒِي نّسْ، إِخْزَارْ أَرْيَازْ نِّي ثُوغَا د-إِكِّينْ ذ أَبْرِيذْ ذڭْ وَازَّايْ ن ثنْذِينْثْ. أَوسَّارْ إِنَّا: ”مَانِي غَا ثُويُورذْ ؤُ مَانِيسْ إِ د-ثُوسِيذْ؟“  
\v 18 إِنَّا أَسْ نتَّا: ”نشِّينْ نفّغْ-د زِي بَايْثْ-لَاحْمْ أَڒْ طَّارْفْ قَاعْ ضفَّارْ خْ إِذُورَارْ ن إِفْرَايِيمْ، سّنِّي إِ د-ؤُسِيغْ. نشّْ ثُوغَا ؤُيُورغْ غَارْ بَايْثْ-لَاحْمْ ذِي يَاهُوذَا، ؤُشَا \add ڒخُّو\add* ڭُّورغْ غَارْ ثَادَّارْثْ ن سِيذِي ؤُشَا وَارْ ذَا ؤُڒَا ذ إِجّْ ونِّي إِخْسنْ أَذْ أَيِي إِسِّيذفْ غَارْ ثَادَّارْثْ نّسْ،  
\v 19 وَاخَّا نشِّينْ غَارْنغْ ڒُومْ ذ ڒعْڒفْ إِ يغْيَاڒْ نّغْ ؤُڒَا ذ أَغْرُومْ ذ بِينُو إِ نشّْ، إِ ثَايَّا نّشْ ؤُ إِ ؤُحُوذْرِي نِّي إِدْجَانْ غَارْ إِمْسخَّارنْ نّشْ. وَارْ ذ أَنغْ إِخصّْ وَالُو.“  
\v 20 \add خنِّي\add* إِنَّا ؤُوسَّارْ: ”أَذْ كِيكْ يِيڒِي ڒهْنَا! مَاشَا مِينْ إِ ذ أَشْ إِقِّيمنْ، أَقَا-ث غَارِي، مْغِيرْ إِتّْخصَّا وَارْ ثتّْنُوسِيذْ ذڭْ وَازَّايْ.“   
\m
\v 21 نتَّا إِسِّيذفْ إِ-ث غَارْ ثَادَّارْثْ نّسْ، إِوْشَا ڒعْڒفْ إِ إِغْيَاڒْ ؤُ نِيثْنِي سِّيرْذنْ إِضَارنْ نْسنْ، شِّينْ سْوِينْ.   
\m
\v 22 ذِي ڒْوقْثْ ذ إِشْثْ ڒَامِي إِفَارْحْ وُوڒْ نْسنْ، خْزَارْ، ذغْيَا نّْضنْ-د يرْيَازنْ ن ثنْذِينْثْ إِ ثَادَّارْثْ - إِرْيَازنْ نِّي ذ أَيْثْ إِ وَارْ إِسكّْوِينْ - ؤُشَا سّْقَارْقْبنْ ذِي ثوَّارْثْ. نِيثْنِي سِّيوْڒنْ أَكْ-ذ ورْيَازْ أَوسَّارْ، بَابْ ن ثَادَّارْثْ، نَّانْ: ”سُوفّغْ-د أَرْيَازْ، ونِّي د-يُوذْفنْ غَارْ ثَادَّارْثْ نّشْ، غَارْ بَارَّا، نشِّينْ نخْسْ أَكِيذسْ نوْضَا.“ \x ◘ \xo 19:‏22 \xt أَمز. 19‏:‏4‏-‏1؛ حُوش. 9‏:‏9؛ 10‏:‏9\x*  
\v 23 أَرْيَازْ، بَابْ ن ثَادَّارْثْ، إِفّغْ-د غَارْسنْ، إِنَّا أَسنْ: ”لَّ، أَ أَيْثْمَا، وَارْ تّڭّمْ شَا ثُوعّفْنَا، أَوَارْنِي ڒَامِي د-يُوذفْ ورْيَازْ-أَ ڒخُّو غَارْ ثَادَّارْثْ إِنُو. غَارْومْ أَذْ ثڭّمْ ڒفْضِيحثْ أَمْ ثَانِيثَا.  
\v 24 خْزَارْ، يدْجِي ذ ثَاعْزَارشْثْ ذ ثَايَّا نّسْ أَذْ غَارْومْ ثنْثْ سُّوفّْغغْ. سهْوَامْ ثنْثْ ؤُ ڭّمْ أَكِيذْسنْثْ مِينْ ثخْسمْ، مَاشَا ذڭْ ورْيَازْ-أَ وَارْ تّڭّمْ ڒفْضِيحثْ أَمْ ثَانِيثَا.“   
\m
\v 25 \add مَاشَا\add* إِرْيَازنْ وَارْ خْسنْ أَذْ غَارْسنْ سْڒَانْ. \add خنِّي\add* إِطّفْ أَرْيَازْ ثَايَّا نّسْ، إِسُّوفّغْ إِ-ت-د غَارْسنْ غَارْ بَارَّا. نِيثْنِي ؤُڒْينْ خَاسْ، جيّْحنْ ت دْجِيڒثْ ثكْمڒْ أَڒْ ثُوفُّوثْ ؤُ نِيثْنِي جِّينْ ت أَذْ ثُويُورْ أَڒَامِي إِسْبحْ ڒْحَاڒْ.   
\m
\v 26 ؤُمِي ذ ثَارّژْ ثُوفُّوثْ، ثُوسَا-د ثمْغَارْثْ-أَ ؤُشَا ثوْضَا غَارْ ثوَّارْثْ ن ثَادَّارْثْ ن ورْيَازْ مَانِي \add ثُوغَا إِدْجَا\add* سِيذِيسْ نّسْ، \add ثقِّيمْ ذِينْ\add* أَڒَامِي \add إِ د-ثفّغْ\add* ثْفَاوْثْ.  
\v 27 \add ؤُمِي\add* د-إِكَّارْ سِيذِيسْ غَارْ ثُوفُّوثْ، يَارْزمْ ثِيوُّورَا ن ثَادَّارْثْ ؤُشَا إِفّغْ غَارْ بَارَّا، حِيمَا أَذْ إِطّفْ أَبْرِيذْ نّسْ، خْزَارْ، ذِينْ إِ ثوْضَا ثمْغَارْثْ، ثَايَّا نّسْ، غَارْ ثوَّارْثْ ن ثَادَّارْثْ س إِفَاسّنْ نّسْ خْ ثْنبْذَاثْ.  
\v 28 نتَّا إِنَّا أَسْ: ”كَّارْ بدّْ، نشِّينْ نخْسْ أَذْ نُويُورْ!“ مَاشَا ؤُڒَا ذ إِجّْ وَارْ خَاسْ د-يَارِّي. \add خنِّي\add* إِسَّارْسْ إِ-ت خْ وغْيُوڒْ ؤُشَا إِطّفْ أَبْرِيذْ غَارْ ومْشَانْ \add ن ثْزذِّيغْثْ\add* نّسْ.  
\v 29 \add ؤُمِي\add* يِيوضْ نتَّا غَارْ ثَادَّارْثْ، إِكْسِي إِجّْ ن ڒْمُوسْ، إِطّفْ ثَايَّا نّسْ، إِقسّْ إِ-ت خْ ثنْعَاشْ ن ثْسقَّارْ ؤُشَا إِسّكّْ إِ-ثنْثْ غَارْ مَارَّا جّْوَايهْ ن إِسْرَائِيل.  
\v 30 ؤُشَا إِمْسَارْ، أَقَا قَاعْ ونِّي إِژْرِينْ أَيَا، إِنَّا: ”مَانْ أَيَاعمَّارْصْ عَاذْ وَارْ إِمْسَارْ ؤُڒَا وَارْ ث نژْرِي زڭْ وَاسّْ إِ ذِي فّْغنْ أَيْثْ ن إِسْرَائِيل زِي مِيصْرَا أَڒْ أَسّْ-أَ. خمّمْ ذَايسْ، مْشَاوَارمْ أَكْ-ذ وَايَاوْيَا ؤُشَا إِنِيمْ ڒحْكَامْ!“   
\b  
\b  
\m  
\c 20
\s1 أَمنْغِي ن أَيْثْ ن إِسْرَائِيل أَكْ-ذ ثقْبِيتْشْ ن بِينْيَامِينْ  
\m
\v 1 \add خنِّي\add* فّْغنْ مَارَّا أَيْثْ ن إِسْرَائِيل، ؤُشَا ثْمُونْ ثْمسْمُونْثْ أَمْ يِيجّْ ن ورْيَازْ غَارْ سِيذِي ذِي مِيصْفَا، زِي ذَانْ أَڒْ بِئرْ-سبْعَا ؤُڒَا ذ ثَامُّورْثْ ن جِيلْعَاذْ.  
\v 2 إِمْذبَّارنْ ن مَارَّا ڒْڭنْسْ، ن مَارَّا ثِيقبَّاڒْ ن إِسْرَائِيل، سّْبدّنْ إِخفْ نْسنْ ذِي ثْمسْمُونْثْ ن أَربِّي، أَربْعَا-مْيَا-أَڒفْ ن يرْيَازنْ خْ إِضَارنْ، \add مَارَّا إِرْيَازنْ\add* إِنِّي إِزمَّارنْ خْ سِّيفْ.  
\v 3 أَيْثْ ن بِينْيَامِينْ سْڒِينْ، أَقَا أَيْثْ ن إِسْرَائِيل ڭعّْذنْ غَارْ مِيصْفَا. أَيْثْ ن إِسْرَائِيل نَّانْ: ”سِيوْڒمْ، مَامّشْ \add ثْزمَّارْ\add* أَذْ ثمْسَارْ ثُوعفّْنَا-يَا؟“  
\v 4 أَرْيَازْ أَلَاوِي، أَرْيَازْ ن ثمْغَارْثْ إِتّْوَانْغنْ، يَارَّا-د خَاسنْ: ”نشّْ ؤُسِيغْ-د أَكْ-ذ ثَايَّا إِنُو زِي جِيبْعَا ثنِّي \add إِدْجَانْ\add* ن بِينْيَامِينْ، حِيمَا أَذْ سّنْسغْ \add ذِينْ\add*.  
\v 5 ؤُشَا إِمزْذَاغْ ن جِيبْعَا نّْقڒْبنْ خَافِي، نّْضنْ أَيِي-د ذِي دْجِيڒثْ إِ ثَادَّارْثْ، نْوَانْ أَذْ أَيِي نْغنْ ؤُغصْبنْ ثَايَّا إِنُو أَڒَامِي ثمُّوثْ.  
\v 6 \add خنِّي\add* كْسِيغْ ثَايَّا إِنُو، بْضِيغْ ت ذ ثِيسقَّارْ، سّكّغْ \add إِجّْ ن وزْينْ\add* زَّايسْ غَارْ مَارَّا جّْوَايهْ ن \add ثمُّورْثْ ن\add* ثسْغَارْثْ ن إِسْرَائِيل، مِينْزِي نِيثْنِي ڭِّينْ ڒفْضِيحثْ ذ ثُوبُّوهڒْيَا ذِي إِسْرَائِيل.  
\v 7 خْزَارْ، كنِّيوْ مَارَّا ذ أَيْثْ ن إِسْرَائِيل. أَرّمْ-د كنِّيوْ خْ مَانْ أَيَا س وَاوَاڒْ ذ شّْوَارْ!“   
\m
\v 8 ؤُشَا إِبدّْ ڒْڭنْسْ إِمُونْ أَمْ يِيجّْ ن ورْيَازْ، إِنَّا: ”ؤُڒَا ذ إِجّنْ زَّايْنغْ وَارْ إِڭُّورْ غَارْ ثْقِيضُونْثْ نّسْ ؤُ ؤُڒَا ذ إِجّنْ زَّايْنغْ وَارْ إِتّْعِيقِّيبْ غَارْ ثَادَّارْثْ نّسْ.  
\v 9 أَمُّو إِ غَا نڭّْ \add خنِّي ڒخُّو\add* أَكْ-ذ جِيبْعَا: ’\add أَذْ\add* خَاسْ \add نفّغْ\add* عْلَاحْسَابْ ثَاقدُّوحْثْ!  
\v 10 أَذْ نَارشّحْ زِي مَارَّا ثِيقبَّاڒْ ن إِسْرَائِيلعشْرَا ن يرْيَازنْ زِي مْيَا ؤُ مْيَا زڭْ وَاڒفْ ؤُ أَڒفْ زِيعشْرَا-أَڒَافْ، حِيمَا أَذْ أَوْينْ ڒعْوتْشْ إِ ڒْڭنْسْ، حِيمَا، خْمِي إِ د غَا يَاسنْ غَارْ جِيبْعَا ثنِّي \add إِدْجَانْ\add* ن بِينْيَامِينْ، أَذْ زمَّارنْ أَذْ ڭّنْ أَكِيذسْ عْلَاحْسَابْ مَارَّا ثُوبُّوهڒْيَا نِّي إِڭَّا ذِي إِسْرَائِيل.“   
\m
\v 11 مُوننْ مَارَّا إِرْيَازنْ ن إِسْرَائِيل ذِي ثنْذِينْثْ-أَ، \add ثُوغَا\add* مُوننْ \add أَكْ-ذ وَايَاوْيَا\add* أَمْ يِيجّْ ن ورْيَازْ.  
\v 12 ؤُشَا سكّنْثْ ثِيقبَّاڒْ ن إِسْرَائِيل إِرْيَازنْ غَارْ مَارَّا ثَاقْبِيتْشْ ن بِينْيَامِينْ، نَّانْ: ”مَانَا ڒفْضِيحثْ-أَ إِ غَارْومْ إِمْسَارنْ؟  
\v 13 خنِّي ڒخُّو، وْشمْ أَنغْ-د إِرْيَازنْ نِّي، أَيْثْ إِ وَارْ إِسكّْوِينْ إِ \add إِدْجَانْ\add* ذِي جِيبْعَا، حِيمَا أَذْ ثنْ ننّغْ ؤُشَا أَذْ إِتّْوَامْحَا مِينْ \add إِدْجَانْ\add* ذ أَعفَّانْ زِي إِسْرَائِيل.“ مَاشَا أَيْثْ ن بِينْيَامِينْ وَارْ خْسنْ أَذْ سْڒنْ غَارْ أَيْثْمَاثْسنْ، أَيْثْ ن إِسْرَائِيل. \f ◼ \fr 20:‏13 \ft \+bd ’وَارْ خْسنْ أَذْ سْڒنْ غَارْ أَيْثْمَاثْسنْ‘\+bd* - س ثْعِيبْرَانِيثْ ’وَارْ خْسنْ أَذْ سْڒنْ غَارْ ثْمِيجَّا ن أَيْثْمَاثْسنْ‘.\f*  \x ◘ \xo 20:‏13 \xt  ڒقض. 19‏:‏22؛ حُوش. 9‏:‏9؛ 10‏:‏9\x*   
\m
\v 14 ؤُسِينْ-د أَيْثْ ن بِينْيَامِينْ زِي ثْندَّامْ نْسنْ غَارْ جِيبْعَا مُوننْ حِيمَا أَذْ فّْغنْ غَارْ ؤُمنْغِي أَكْ-ذ أَيْثْ ن إِسْرَائِيل.  
\v 15 ذڭْ وَاسّْ نِّي سدّنْ نِيثْنِي أَيْثْ ن بِينْيَامِينْ زِي ثْندَّامْ، ستَّا ؤُ-عِيشْرِينْ-أَڒفْ ن يرْيَازنْ إِنِّي إِزمَّارنْ إِ سِّيفْ، بْڒَا إِمزْذَاغْ ن جِيبْعَا إِ زَّايْسنْ تّْوَافَارْزنْ \add عَاذْ\add* سبْعَا-مْيَا ن يرْيَازنْ.  
\v 16 جَارْ مَارَّا ڒْڭنْسْ-أَ أَقَا \add ذِينْ\add* سبْعَا-مْيَا ن يرْيَازنْ تّْوَافَارْزنْ إِ وَارْ تّْوَاذَارّْبنْ مْلِيحْ س ؤُفُوسِي نْسنْ أَفُوسِي. كُوڒْ إِجّْ زَّايْسنْ إِزمَّارْ أَذْ إِحَاكَا مْلِيحْ أَطَّاسْ س يدْجِييْ \add س ؤُفُوسْ ؤُزڒْمَاضْ\add*، وَارْ خطِّينْ. \x ◘ \xo 20:‏16 \xt ڒقض. 3‏:‏15\x*  
\v 17 ؤُڒَا ذ إِرْيَازنْ ن إِسْرَائِيل تّْوَاسدّنْ. نْهْڒَا أَيْثْ ن بِينْيَامِينْ ثُوغَا أَثنْ ذِي أَربْعَا-مْيَا-أَڒفْ ن يرْيَازنْ إِنِّي إِزمَّارنْ خْ سِّيفْ. مَارَّا نِيثْنِي ذ إِعسْكَارِييّنْ.   
\m
\v 18 كَّارنْ أَيْثْ ن إِسْرَائِيل ؤُشَا فّْغنْ غَارْ بَايْثْ-إِلْ. سّقْسَانْ أَربِّي، نَّانْ: ”مَانْ ونْ زَّايْنغْ إِ غَا إِفّْغنْ ذ أَمْزْوَارُو غَارْ ؤُمنْغِي أَكْ-ذ أَيْثْ ن بِينْيَامِينْ؟“ إِنَّا سِيذِي: ”أَمزْوَارُو يَاهُوذَا.“  
\v 19 كَّارنْ أَيْثْ ن إِسْرَائِيل غَارْ ثُوفُّوثْ، وْثِينْ إِقِيضَانْ نْسنْ أَجمَّاضْ إِ جِيبْعَا  
\v 20 فّْغنْ يرْيَازنْ ن إِسْرَائِيل غَارْ ؤُمنْغِي أَكْ-ذ بِينْيَامِينْ ؤُشَا سدّنْ يرْيَازنْ ن إِسْرَائِيل إِخفْ نْسنْ قِيبَاتْشْ نْسنْ إِ ؤُمنْغِي غَارْ جِيبْعَا.  
\v 21 \add خنِّي\add* فّْغنْ-د أَيْثْ ن بِينْيَامِينْ زِي جِيبْعَا ؤُشَاغضْڒنْ زِي إِسْرَائِيل ذڭْ وَاسّْ نِّي ثْنَاينْ ؤُ-عِيشْرِينْ-أَڒفْ ن يرْيَازنْ.   
\m
\v 22 \add مَاشَا\add* ڒْڭنْسْ، إِرْيَازنْ ن إِسْرَائِيل، ڭِّينْ ثَارْيَاسْثْ، سدّنْ إِخفْ نْسنْ إِشْثْ ن ثْوَاڒَا نّغْنِيثْ إِ ؤُمنْغِي غَارْ مَانِي ثُوغَا سدّنْ إِخفْ نْسنْ ذڭْ وَاسّْ أَمزْوَارُو.  
\v 23 ؤُشَا أَيْثْ ن إِسْرَائِيل ڭعّْذنْ، رُونْ زَّاثْ إِ وُوذمْ ن سِيذِي أَڒْ ثَامذِّيثْ، سّقْسَانْ: ”مَا أَذْ فّْغغْ إِشْثْ ن ثْوَاڒَا نّغْنِيثْ غَارْ ؤُمنْغِي أَكْ-ذ إِحنْجِيرنْ ن ؤُمَا بِينْيَامِينْ؟“ سِيذِي يَارَّا-د: ”ڭَاعّْذمْ ضِيدّْ إِ نّسْ \add إِ ؤُمنْغِي\add*!“  
\v 24 ذڭْ وَاسّْ وِيسّْ ثْنَاينْ قَارّْبنْ-د أَيْثْ ن إِسْرَائِيل غَارْ أَيْثْ ن بِينْيَامِينْ،  
\v 25 ؤُشَا إِفّغْ بِينْيَامِينْ ذڭْ وَاسّْ وِيسّْ ثْنَاينْ زِي جِيبْعَا مَاحنْذْ أَذْ كِيذْسنْ إِمّڒْقَا.غضْڒنْ عَاوذْ ثْمنْطَاشْ-أَڒفْ ن يرْيَازنْ غَارْ ثمُّورْثْ، إِنِّي ثُوغَا مَارَّا زمَّارنْ خْ سِّيفْ.   
\m
\v 26 \add خَاسْ ؤُشَا\add* فّْغنْ مَارَّا أَيْثْ إِسْرَائِيل، ڒْڭنْسْ مَارَّا، ؤُشَا إِوْضنْ غَارْ بَايْثْ-إِلْ، رُونْ. قِّيمنْ ذِينِّي زَّاثْ إِ وُوذمْ ن سِيذِي ؤُشَا ژُومّنْ ذڭْ وَاسّْ نِّي أَڒْ ثَامذِّيثْ ؤُشَا قدّْمنْ ثِيغَارْصَا ن وشْمَاضْ ذ ثْغَارْصَا ن ڒهْنَا زَّاثْ إِ وُوذمْ ن سِيذِي.  
\v 27 \add خنِّي\add* سّقْسَانْ أَيْثْ ن إِسْرَائِيل سِيذِي، مِينْزِي \add ذِي بَايْثْ-إِلْ\add* ثُوغَا ذِينْ تَّابُوثْ ن ڒْعَاهْذْ ن أَربِّي ذڭْ وُوسَّانْ نِّي.  
\v 28 ذڭْ وُوسَّانْ نِّي ثُوغَا إِبدّْ فِينَاحَاسْ، مِّيسْ ن أَلِيعَازَارْ، مِّيسْ ن هَارُونْ، زَّاثْ إِ وُوذمْ نّسْ ؤُشَا إِنَّا: ”مَا أَذْ نفّغْ إِشْثْ ن ثْوَاڒَا نّغْنِيثْ غَارْ ؤُمنْغِي أَكْ-ذ أَرَّاونْ ن ؤُمَا بِينْيَامِينْ نِيغْ أَذْ \add ذَايسْ\add* نسْمحْ؟“ سِيذِي يَارَّا-د: ”فّْغمْ، مَاغَارْ ثِيوشَّا أَذْ ثنْ ڭّغْ ذڭْ ؤُفُوسْ نّشْ.“   
\m
\v 29 \add خَاسْ ؤُشَا\add* إِڭَّا إِسْرَائِيل ڒفْخُوخْ غَارْ مَارَّا إِغزْذِيسنْ ن جِيبْعَا. \x ◘ \xo 20:‏29 \xt ياش. 8‏:‏4\x*  
\v 30 ذڭْ وَاسّْ وِيسّْ ثْڒَاثَا ڭعّْذنْ أَيْثْ ن إِسْرَائِيل ضِيدّْ إِ أَيْثْ ن بِينْيَامِينْ. سدّنْ إِخفْ نْسنْ \add إِ ؤُمنْغِي\add* أَكْ-ذ جِيبْعَا، أَمْ مَامّشْ \add ت ڭِّينْ\add* ثْوَاڒَاوِينْ إِعْذُونْ.  
\v 31 \add خنِّي\add* فّْغنْ أَيْثْ ن بِينْيَامِينْ إِ ؤُمْسَاڭَارْ أَكْ-ذ أَيْثْ ن إِسْرَائِيل ؤُ تّْوَاسِّيڭّْوجنْ خْ ثنْذِينْثْ ؤُشَا، أَمْ مَامّشْ ثْوَاڒَاوِينْ إِعْذُونْ، بْذَانْ أَذْ نْغِينْ \add إِرْيَازنْ\add* زِي ڒْڭنْسْ خْ إِبْرِيذنْ إِمقّْرَاننْ إِ زَّايْسنْ إِتّْڭعّذْ إِجّْ ن وبْرِيذْ غَارْ بَايْثْ-إِلْ ؤُ ونّغْنِي غَارْ جِيبْعَا، \add نْغِينْ\add* عْڒَاحَاڒْ ثْڒَاثِينْ ن يرْيَازنْ ن إِسْرَائِيل.  
\v 32 \add خنِّي\add* نَّانْ أَيْثْ ن بِينْيَامِينْ: ”أَقَا نِيثْنِي تّْوَاغڒْبنْ زَّاثْ إِ وُوذمْ نّغْ، أَمْ ثْوَاڒَا ثَامزْوَارُوثْ.“ \add خنِّي\add* نَّانْ أَيْثْ ن إِسْرَائِيل: ”أجّْ أَنغْ أَذْ نَارْوڒْ، أَذْ ثنْ نسِّيڭّْوجْ خْ ثنْذِينْثْ غَارْ إِبْرِيذنْ إِمقّْرَاننْ.“  
\v 33 \add خنِّي\add* كَّارنْ مَارَّا إِرْيَازنْ ن إِسْرَائِيل زڭْ ومْشَانْ نْسنْ \add إِنُّوفَّارنْ\add* ؤُ سدّنْ إِخفْ نْسنْ \add إِ ؤُمنْغِي\add* غَارْ بَاعْلْ-ثَامَارْ. ذِي ڒْوقْثْ ذ إِشْثْ فّْغنْ إِنِّي زِي إِسْرَائِيل إِ ثُوغَا ڭِّينْ إِجّْ ن ڒْفخْ زڭْ ومْشَانْ نْسنْ إِنُّوفَارنْ زڭْ يفْرِي ن جِيبْعَا.  
\v 34 عشْرَا-أَڒَافْ ن يرْيَازنْ إِتّْوَافَارْزنْ زِي مَارَّا إِسْرَائِيل ؤُسِينْ-د زڭْ ؤُرنْذَاذْ ن جِيبْعَا ؤُ أَمنْغِي إِذْوڒْ إِوْعَارْ. \add مَاشَا أَيْثْ ن بِينْيَامِينْ\add* وَارْ سِّيننْ، أَقَا ثِيشْثِي ثْحَارْثْ خَاسنْ.  
\v 35 سِيذِي إِوْثَا أَيْثْ ن بِينْيَامِينْ زَّاثْ إِ وُوذمْ ن إِسْرَائِيل، أَڒَامِي أَيْثْ ن إِسْرَائِيل نْغِينْ ذڭْ وَاسّْ نِّي خمْسَا ؤُ-عِيشْرِينْ-أَڒفْ ؤُ-مْيَا ن يرْيَازنْ، إِنِّي إِزمَّارنْ مَارَّا خْ سِّيفْ.  
\v 36 ژْرِينْ أَيْثْ ن بِينْيَامِينْ أَقَا نِيثْنِي ثُوغَا تّْوَاوْثنْ. \add خنِّي\add* وْشِينْ إِرْيَازنْ ن إِسْرَائِيل تَّاسِيعْ إِ أَيْثْ ن بِينْيَامِينْ، مِينْزِي نِيثْنِي تّشْڒنْ خْ ڒْفخْ نِّي ثُوغَا ڭِّينْ ضِيدّْ إِ جِيبْعَا.  
\v 37 إِنِّي إِ ثُوغَا إِنُّوفَّارنْ، قدْجْقنْ أَذْ حجْمنْ خْ جِيبْعَا. \add أَمُّو\add* إِ حجْمنْ إِنِّي إِ ثُوغَا ذڭْ ومْشَانْ إِنُّوفَّارنْ ؤُشَا وْثِينْ مَارَّا ثَانْذِينْثْ س ڒقْضعْ ن سِّيفْ.  
\v 38 إِرْيَازْ\add أنْ\add* ن إِسْرَائِيل ثُوغَا ڭِّينْ أَوَاڒْ أَكْ-ذ يِينِّي إِڭِّينْ ڒْفخْ ذڭْ ومْشَانْ إِنُّوفَّارنْ، أَقَا نِيثْنِي أَذْ جّنْ أَسيْنُو أَمقّْرَانْ ن دّخَّانْ أَذْ د-إِڭعّذْ زِي ثنْذِينْثْ،  
\v 39 \add ؤُشَا خنِّي\add* أَذْ نّْقڒْبنْ إِرْيَازنْ ن إِسْرَائِيل ذڭْ ؤُمنْغِي. بِينْيَامِينْ ثُوغَا إِبْذَا أَذْ إِنغْ إِنِّي إِتّْوَاسّْنُوقّْبنْ زِي إِسْرَائِيل، عْڒَاحَاڒْ ثْڒَاثِينْ ن يرْيَازنْ. أَقَا نَّانْ: ”نِيثْنِي تّْوَاوْثنْ نِيشَانْ زَّاثْ إِ وُوذمْ نّغْ أَمْ ذڭْ ؤُمنْغِي أَمزْوَارُو.“  
\v 40 \add ذِي ثْسَاعّثْ نِّي\add* إِبْذَا ؤُسيْنُو أَمقّْرَانْ أَذْ د-إِڭعّذْ زِي ثنْذِينْثْ أَمْ يِيجّْ ن ؤُقلِّيجْ ن دّخَّانْ. ؤُمِي إِخْزَارْ بِينْيَامِينْ غَارْ ضفَّارْ، أَقَا ثَانْذِينْثْ مَارَّا ثْڭعّذْ \add أَمْ دّخَّانْ\add* غَارْ ؤُجنَّا.  
\v 41 \add خنِّي\add* نّْقڒْبنْ-د إِرْيَازنْ ن إِسْرَائِيل ؤُشَا إِرْيَازنْ ن بِينْيَامِينْ إِوْثَا إِ-ثنْ ؤُنخْڒِيعْ، مِينْزِي نِيثْنِي ژْرِينْ أَقَا ثِيشْثِي ثَاعفَّانْثْ ثُوغَا ثڒْقفْ إِ-ثنْ.  
\v 42 نِيثْنِي نّْقڒْبنْ غَارْ ڒخْڒَا زَّاثْ إِ وُوذمْ ن أَيْثْ ن إِسْرَائِيل. أَمنْغِي \add مَاشَا\add* إِضْفَارْ إِ-ثنْ، ؤُشَا إِنِّي زِي ثْندَّامْ أَقَا ڭِّينْ إِشْثْ ن ثْغَارْصْثْ ثَامقّْرَانْثْ ذِي ڒْوسْطْ نْسنْ.  
\v 43 نِيثْنِي نّْضنْ إِ أَيْثْ ن بِينْيَامِينْ، ضْفَارنْ ثنْ بْڒَا قطُّو،عفْسنْ خَاسنْ أَڒْ أَمْشَانْ ن أَرَّاحثْ قِيبَاتْشْ ن جِيبْعَا غَارْ ؤُغزْذِيسْ ن \add شَّارْقْ\add* مَانِيسْ د-ثْنقَّارْ ثْفُوشْثْ.  
\v 44 وْضَانْ ثْمنْطَاشْ-أَڒفْ ن يرْيَازنْ، مَارَّا نِيثْنِي ذ إِرْيَازنْ إِمحْضنْ.  
\v 45 \add خنِّي\add* نّْقڒْبنْ، أَروْڒنْ غَارْ ڒخْڒَا، غَارْ ثصْضَارْثْ ن رِيمُّونْ. ؤُ خْ وبْرِيذْ أَمقّْرَانْ قْضَانْ زَّايْسنْ خْ خمْسَا-أَڒَافْ ن يرْيَازنْ. ضْفَارنْ ثنْ أَڒْ جِيذْعُومْ، وْثِينْ زَّايْسنْ أَڒْفَاينْ ن يرْيَازنْ \add س ڒْموْثْ\add*.  
\v 46 ذڭْ وَاسّْ نِّي ثُوغَا مَارَّا إِنِّي إِوْضَانْ زِي بِينْيَامِينْ ذِي خمْسَا ؤُ-عِيشْرِينْ-أَڒفْ ن يرْيَازنْ نِّي زمَّارنْ خْ سِّيفْ، مَارَّا نِيثْنِي ذ إِرْيَازنْ إِمحْضنْ.   
\m
\v 47 ستَّا-مْيَا ن يرْيَازنْ \add مَاشَا\add* نّْقڒْبنْ، أَروْڒنْ غَارْ ڒخْڒَا، غَارْ ثصْضَارْثْ ن رِيمُّونْ، ؤُشَا نِيثْنِي قِّيمنْ أَربْعَا ن إِيُورنْ ذِي ثصْضَارْثْ ن رِيمُّونْ. \x ◘ \xo 20:‏47 \xt ڒقض. 21‏:‏13\x*  
\v 48 عقْبنْ إِرْيَازنْ ن إِسْرَائِيل غَارْ أَيْثْ ن بِينْيَامِينْ ؤُشَا وْثِينْ ثنْ مَارَّا س ڒقْضعْ ن سِّيفْ، زڭْ يرْيَازنْ ن ثنْذِينْثْ أَڒْ ڒْمَاڒْ ذ مَارَّا مِينْ ذِينْ ؤُفِينْ. سنّجْ إِ مَانْ أَيَا سَّارْغنْ مَارَّا ثِيندَّامْ إِ ؤُفِينْ ذڭْ وبْرِيذْ نْسنْ س ثْمسِّي.   
\b  
\b  
\m  
\c 21
\s1 ثِيمْغَارِينْ إِ أَيْثْ ن بِينْيَامِينْ  
\m
\v 1 إِرْيَازْ\add أنْ\add* ن إِسْرَائِيل ثُوغَا جُّودْجنْ ذِي مِيصْفَا ؤُشَا نَّانْ: ”ؤُڒَا ذ إِجّْ زَّايْنغْ وَارْ إِتِّيشْ يدْجِيسْ إِ أَيْثْ ن بِينْيَامِينْ ذ ثَامْغَارْثْ.“  
\v 2 يُوسَا-د ڒْڭنْسْ غَارْ بَايْثْ-إِلْ ؤُشَا قِّيمنْ نِيثْنِي ذِينِّي زَّاثْ إِ وُوذمْ ن أَربِّي أَڒْ ثَامذِّيثْ. نِيثْنِي سّْڭعّْذنْ ثْمِيجَّا نْسنْ ؤُشَا رُونْ س إِمطَّاونْ إِتَّازّْڒنْ.  
\v 3 نَّانْ: ”\add أَ\add* سِيذِي، أَربِّي ن إِسْرَائِيل، مَايمِّي إِمْسَارْ ؤُيَا ذِي إِسْرَائِيل، أَقَا أَسّْ-أَ ثقِّيمْ إِشْثْ ن ثقْبِيتْشْ ن إِسْرَائِيل وَارْ ثْبِينْ؟“   
\m
\v 4 ثِيوشَّا نّسْ، إِمْسَارْ، أَقَا ڒْڭنْسْ إِكَّارْ زِيشْ. نِيثْنِي بْنَانْ إِجّْ ن ؤُعَالْطَارْ، قدّْمنْ خَاسْ ثِيغَارْصَا ن وشْمَاضْ ذ ثْغَارْصَا ن ڒهْنَا.  
\v 5 نَّانْ أَيْثْ ن إِسْرَائِيل: ”وِي إِقِّيمنْ زِي مَارَّا ثِيقبَّاڒْ ن إِسْرَائِيل وَارْ د-إِڭعّْذنْ غَارْ وڭْرَاوْ \add ن ڒْڭنْسْ\add* ن سِيذِي؟“ ثُوغَا ڭِّينْ إِشْثْ ن ثْجَادْجِيثْ زِي جِّيهثْ ن ونِّي وَارْ إِ د-إِڭعّْذنْ غَارْ سِيذِي غَارْ مِيصْفَا، نَّانْ: ”أَذْ إِتّْوَانغْ نِيشَانْ!“  
\v 6 خَاسْ ؤُشَا نذْمنْ أَيْثْ ن إِسْرَائِيل خْ ؤُمَاثْسنْ بِينْيَامِينْ، نَّانْ: ”أَسّْ-أَ ثتّْوَاقسّْ إِشْثْ ن ثقْبِيتْشْ زِي إِسْرَائِيل.  
\v 7 مَامّشْ إِ غَا نڭّْ ذِي ثْمسْڒَاشْثْ ن ثمْغَارِينْ إِ \add يرْيَازنْ ن بِينْيَامِينْ\add* نِّي إِقِّيمنْ؟ \add مِينْزِي\add* نشِّينْ نجُّودْجْ غَارْ سِيذِي وَارْ ذ أَسنْ نتِّيشْ شَا يسِّيثْنغْ ذ ثَامْغَارْثْ.“  
\v 8 نَّانْ: ”مَا وَارْ د-إِڭعّذْ شَا ن يِيجّنْ زِي ثْقبَّاڒْ ن إِسْرَائِيل غَارْ سِيذِي ذِي مِيصْفَا؟“ خْزَارْ، وَارْ د-يُوسِي ؤُڒَا ذ إِجّنْ زِي يَابِيشْ ذِي جِيلْعَاذْ غَارْ ڒْمَارْڭحْ ن ڒْعسْكَارْ، غَارْ وڭْرَاوْ \add ن ڒْڭنْسْ\add*،  
\v 9 \add مِينْزِي\add* ڒْڭنْسْ إِتّْوَاحْسبْ، ؤُ خْزَارْ، زِي يَابِيشْ ذِي جِيلْعَاذْ وَارْ ذِينْ إِدْجِي ؤُڒَا ذ إِجّنْ.   
\m
\v 10 \add خنِّي\add* ثسّكّْ ثْمسْمُونْثْ ثنْعَاشْ-أَڒفْ ن يرْيَازنْ زڭْ إِنِّي ذ أَيْثْ ن ؤُمنْغِي قَاعْ ؤُشَا ؤُمُورنْ ثنْ، نَّانْ: ”ڭَاعّْذمْ، وْثمْ إِمزْذَاغْ ن يَابِيشْ ذِي جِيلْعَاذْ س ڒقْضعْ ن سِّيفْ، ؤُڒَا ذ ثِيمْغَارِينْ ذ إِحنْجِيرنْ إِمژْيَاننْ.  
\v 11 أَمُّو إِ إِتّْخصَّا أَذْ ثڭّمْ: مَارَّا مِينْ إِدْجَانْ ذ أَوْثمْ ذ مَارَّا ثِيمْغَارِينْ ثِينِّي ثُوغَا إِطّْصنْ أَكْ-ذ ورْيَازْ، أَذْ ثنْ ثْحَارّْممْ إِ ؤُثحِّي!“ \x ◘ \xo 21:‏11 \xt ڒخْڒ. 31‏:‏17\x*   
\m
\v 12 ؤُفِينْ جَارْ إِمزْذَاغْ ن يَابِيشْ ذِي جِيلْعَاذْ أَربْعَا-مْيَا ن ثبْڒِيغِينْ ثِينِّي ذ ثِيعْزَارِييِّينْ، ثِينِّي ثُوغَا عَاذْ وَارْ طِّيصنْثْ أَكْ-ذ ورْيَازْ، ؤُشَا إِوْينْ ثنْثْ غَارْ ڒْمَارْڭحْ ن ڒْعسْكَارْ ذِي شِيلُو ذِي ثمُّورْثْ ن كنْعَانْ.  
\v 13 \add خَاسْ ؤُشَا\add* ثسّكّْ ثْمسْمُونْثْ ثْمُونْ \add إِرقَّاسنْ\add* ؤُشَا سِّيوْڒنْ أَكْ-ذ أَيْثْ ن بِينْيَامِينْ إِ \add إِدْجَانْ\add* غَارْ ثصْضَارْثْ ن رِيمُّونْ، بَارّْحنْ أَسنْ س ڒهْنَا. \x ◘ \xo 21:‏13 \xt ڒقض. 20‏:‏47\x*  
\v 14 ذِي ڒْوقْثْ نِّيعقْبنْ أَيْثْ ن بِينْيَامِينْ ؤُشَا وْشِينْ أَسنْ ثِيمْغَارِينْ ثِينِّي ثُوغَا جِّينْ دَّارنْثْ زِي ثمْغَارِينْ ن يَابِيشْ ذِي جِيلْعَاذْ. \add مَاشَا\add* ثُوغَا وَارْ ثنْ تّْقذِّينْثْ \add عَاذْ\add*.   
\m
\v 15 \add خنِّي\add* ثُوغَا ڒْڭنْسْ إِزِّيدْجزْ أَسْ بِينْيَامِينْ، مَاغَارْ سِيذِي ثُوغَا إِڭَّا ثَازِّيثْ ذڭْ إِسذِّييّنْ ن ثْقبَّاڒْ ن إِسْرَائِيل.  
\v 16 ؤُشَا إِمقّْرَاننْ ن ثْمسْمُونْثْ نَّانْ: ”مَامّشْ إِ غَا نڭّْ ذِي ثْمسْڒَاشْثْ ن ثمْغَارِينْ إِ \add يرْيَازنْ ن بِينْيَامِينْ\add* نِّي إِقِّيمنْ، مِينْزِي ثِيمْغَارِينْ تّْوَاثحَّانْثْ زِي بِينْيَامِينْ.“  
\v 17 ؤُ نَّانْ عَاوذْ: ”ثَاسْغَارْثْ ن يِينِّي يَاروْڒنْ أَقَا-ت ن بِينْيَامِينْ. إِتّْخصَّا وَارْ ثْمحِّي ؤُڒَا ذ إِشْثْ ن ثقْبِيتْشْ زِي إِسْرَائِيل.  
\v 18 \add مَاشَا\add* نشِّينْ وَارْ نْزمَّارْ أَذْ أَسنْ نوْشْ ثِيمْغَارِينْ زِي يسِّيثْنغْ، مَاغَارْ أَيْثْ ن إِسْرَائِيل جُّودْجنْ، نَّانْ: ”ونِّي إِوْشِينْ ثَامْغَارْثْ إِ أَيْثْ ن بِينْيَامِينْ أَذْ إِتّْوَانْعڒْ.“  
\v 19 \add خنِّي\add* نَّانْ نِيثْنِي: ”خْزَارْ، زڭْ ؤُسڭّْوَاسْ أَڒْ أَسڭّْوَاسْ أَقَا ذِينْ ڒْعِيذْ ن سِيذِي ذِي شِيلُو. ڒْعِيذْ إِتّْوَاڭّْ سنّجْ إِ بَايْثْ-إِلْ، غَارْ شَّارْقْ ن وبْرِيذْ أَمقّْرَانْ إِ إِندّْهنْ زِي بَايْثْ-إِلْ غَارْ شَاكِيمْ، غَارْ ؤُغزْذِيسْ ن لْجَانُوبْ ن لبُونَا.“  
\v 20 ؤُ نِيثْنِيعڒْمنْ إِ أَيْثْ ن بِينْيَامِينْ، نَّانْ: ”ؤُيُورمْ ذِينْ ؤُشَا وْضَامْ ؤُ حْضَامْ ذڭْ إِمَارْجَاعنْ ن ؤُضِيڒْ.  
\v 21 مَاڒَا \add خنِّي\add* كنِّيوْ ثْخزَّارمْ ؤُ ثژْرِيمْ خْمِي إِ د غَا فّْغنْثْ يسِّيسْ ن شِيلُو، حِيمَا أَذْ شضْحنْثْ، فّْغمْ-د \add خنِّي ڒخْذنِّي\add* زڭْ إِمَارْجَاعنْ ن ؤُضِيڒْ ؤُشَا أجّْ أَذْ إِطّفْ \add كُوڒْ\add* أَرْيَازْ ثَامْغَارْثْ نّسْ زِي يسِّيسْ ن شِيلُو، ؤُ أَوَارْنِي أَسْ ؤُيُورمْ غَارْ ثمُّورْثْ ن بِينْيَامِينْ!  
\v 22 مَاڒَا \add خنِّي\add* بَابَاثْسنْثْ نِيغْ أَيْثْمَاثْسنْثْ ؤُسِينْ-د حِيمَا أَذْ خَانغْ شثْشَانْ، أَذْ أَسنْ نِينِي: ’سَامْحمْ أَنغْ، جّمْ ثنْ، مِينْزِي ذڭْ ؤُمنْغِي \add أَكْ-ذ يَابِيشْ\add* وَارْ نْزمَّارْ أَذْ نَاوِي إِ كُوڒْ أَرْيَازْ ثَامْغَارْثْ، ؤُ عَاوذْ كنِّيوْ وَارْ ذ أَسنْ ثنْثْ ثوْشِيمْ، نِيغْ إِڒِي ڒخُّو أَذْ ذَايْومْ يِيڒِي ذ أَمَارْوَاسْ.‘ “  
\v 23 ؤُشَا أَمُّو إِ ڭِّينْ أَيْثْ ن بِينْيَامِينْ. زِي ثعْزَارْيِينْ إِشطّْحنْ س نُّوبْثَاثْ ثِينِّي إِطّْفنْ، كْسِينْ نِيثْنِي ثِيمْغَارِينْ عْلَاحْسَابْ ڒْقدّْ نْسنْ ؤُشَا فّْغنْ،عقْبنْ غَارْ ثسْغَارْثْ نْسنْ ؤُشَا سّْبدّنْ ثِيندَّامْ نْسنْ، ڭِّينْ زدّْغنْ ذَايْسنْثْ.   
\m
\v 24 ذِي ڒْوقْثْ نِّي فّْغنْ-د سّنِّي ؤُڒَا ذ أَيْثْ ن إِسْرَائِيل، كُوڒْ  إِجّْ \add يُويُورْ\add* غَارْ ثقْبِيتْشْ نّسْ ؤُ غَارْ ڒَادْجْ نّسْ. فّْغنْ سّنِّي، كُوڒْ إِجّنْ \add يُويُورْ\add* غَارْ ثسْغَارْثْ نّسْ.  
\v 25 ذڭْ وُوسَّانْ نِّي وَارْ ثُوغِي ذِينْ أَجدْجِيذْ ذِي إِسْرَائِيل. كُوڒْ إِجّْ إِتّڭّْ مِينْ \add إِدْجَانْ\add* نِيشَانْ ذِي ثِيطَّاوِينْ نّسْ. \x ◘ \xo 21:‏25 \xt ڒقض. 17‏:‏6؛ 18‏:‏1؛ 19‏:‏1\x*   