\p 
\v 8 \w David|strong="H1732"\w* \w subía|strong="H5927"\w* \w con|strong="H3588"\w* sus hombres \w y|strong="H3588"\w* despojaban \w a|strong="H3068"\w* \w los|strong="H3427"\w* gesuritas, gercitas \w y|strong="H3588"\w* amalecitas, \w pues|strong="H3588"\w* hacía tiempo \w que|strong="H3588"\w* éstos \w vivían|strong="H3427"\w* \w en|strong="H5704"\w* aquella tierra, \w en|strong="H5704"\w* dirección \w a|strong="H3068"\w* \w Shur|strong="H7793"\w*, \w hasta|strong="H5704"\w* \w la|strong="H3588"\w* tierra \w de|strong="H3588"\w* \w Egipto|strong="H4714"\w*.
\v 9 \w David|strong="H1732"\w* atacaba aquella tierra \w y|strong="H1241"\w* \w no|strong="H3808"\w* dejaba vivo hombre \w ni|strong="H3808"\w* mujer. \w Se|strong="H3808"\w* llevaba las \w ovejas|strong="H6629"\w*, \w bueyes|strong="H1241"\w*, \w asnos|strong="H2543"\w*, \w camellos|strong="H1581"\w* \w y|strong="H1241"\w* equipos. \w Luego|strong="H7725"\w* \w se|strong="H3808"\w* \w volvía|strong="H7725"\w* \w y|strong="H1241"\w* regresaba \w a|strong="H3068"\w* Aquís.
\p 
\v 10 \w Y|strong="H3068"\w* Aquís preguntaba: ¿\w Dónde|strong="H5921"\w* tomaron \w el|strong="H5921"\w* despojo \w hoy|strong="H3117"\w*? \w David|strong="H1732"\w* respondía: \w Hacia|strong="H5921"\w* \w el|strong="H5921"\w* sur \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, \w hacia|strong="H5921"\w* \w el|strong="H5921"\w* sur \w de|strong="H5921"\w* \w los|strong="H5921"\w* jerameelitas \w o|strong="H3068"\w* \w hacia|strong="H5921"\w* \w el|strong="H5921"\w* sur \w de|strong="H5921"\w* \w los|strong="H5921"\w* ceneos.
\v 11 \w David|strong="H1732"\w* \w no|strong="H3808"\w* dejaba \w con|strong="H5921"\w* \w vida|strong="H3117"\w* hombre \w ni|strong="H3808"\w* mujer \w que|strong="H3808"\w* fuera \w a|strong="H3068"\w* Gat, pues decía: \w No|strong="H3808"\w* \w sea|strong="H6435"\w* \w que|strong="H3808"\w* \w ellos|strong="H5921"\w* declaren \w contra|strong="H5921"\w* \w nosotros|strong="H3605"\w* \w y|strong="H5921"\w* digan: ¡\w Esto|strong="H3541"\w* \w hizo|strong="H6213"\w* \w David|strong="H1732"\w*! \w Y|strong="H3068"\w* esa \w fue|strong="H3808"\w* su \w costumbre|strong="H4941"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w tiempo|strong="H3117"\w* \w que|strong="H3808"\w* \w vivió|strong="H2421"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w los|strong="H3427"\w* \w filisteos|strong="H6430"\w*.
\v 12 Aquís \w tenía|strong="H1961"\w* confianza en \w David|strong="H1732"\w*, \w pues|strong="H1961"\w* \w se|strong="H1961"\w* decía: \w Se|strong="H1961"\w* hizo aborrecible \w a|strong="H3068"\w* su \w pueblo|strong="H5971"\w* \w Israel|strong="H3478"\w*, \w por|strong="H5769"\w* lo cual \w será|strong="H1961"\w* \w siempre|strong="H5769"\w* \w mi|strong="H1961"\w* esclavo.
\c 28
\s1 La bruja de Endor
\p 
\v 1 \w En|strong="H3588"\w* \w aquellos|strong="H1992"\w* \w días|strong="H3117"\w* \w aconteció|strong="H1961"\w* \w que|strong="H3588"\w* \w los|strong="H1992"\w* \w filisteos|strong="H6430"\w* reunieron \w sus|strong="H1992"\w* escuadrones \w de|strong="H3588"\w* \w guerra|strong="H3898"\w* \w para|strong="H3588"\w* combatir \w contra|strong="H3478"\w* \w Israel|strong="H3478"\w*. \w Y|strong="H3068"\w* Aquís dijo \w a|strong="H3068"\w* \w David|strong="H1732"\w*: ¡\w Ten|strong="H3045"\w* \w bien|strong="H3588"\w* \w entendido|strong="H3045"\w* \w que|strong="H3588"\w* tú \w y|strong="H3588"\w* tus hombres \w saldrán|strong="H3318"\w* conmigo \w a|strong="H3068"\w* \w la|strong="H3588"\w* batalla!
\p 
\v 2 \w David|strong="H1732"\w* respondió \w a|strong="H3068"\w* Aquís: Muy \w bien|strong="H3651"\w*. \w Sabrás|strong="H3045"\w* \w lo|strong="H6213"\w* \w que|strong="H3045"\w* \w tu|strong="H6213"\w* esclavo puede \w hacer|strong="H6213"\w*. \w Así|strong="H3651"\w* \w que|strong="H3045"\w* Aquís dijo \w a|strong="H3068"\w* \w David|strong="H1732"\w*: Muy \w bien|strong="H3651"\w*, te designaré mi \w guarda|strong="H8104"\w* espalda \w por|strong="H3651"\w* \w toda|strong="H3605"\w* \w la|strong="H8104"\w* \w vida|strong="H3117"\w*.
\v 3 \w Samuel|strong="H8050"\w* había \w muerto|strong="H4191"\w*. \w Todo|strong="H3605"\w* \w Israel|strong="H3478"\w* hizo lamentación por \w él|strong="H3605"\w* y \w lo|strong="H3605"\w* \w sepultaron|strong="H6912"\w* \w en|strong="H5493"\w* \w Ramá|strong="H7414"\w*, su \w ciudad|strong="H5892"\w*. \w Saúl|strong="H7586"\w* había expulsado de \w la|strong="H3605"\w* tierra \w a|strong="H3068"\w* \w los|strong="H3605"\w* encantadores y \w adivinos|strong="H3049"\w*.
\p 
\v 4 \w Los|strong="H3605"\w* \w filisteos|strong="H6430"\w* se reunieron y acamparon en \w Sunem|strong="H7766"\w*. También \w Saúl|strong="H7586"\w* reunió \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* y acamparon en Gilboa.
\v 5 Cuando \w Saúl|strong="H7586"\w* \w vio|strong="H7200"\w* \w el|strong="H4264"\w* \w campamento|strong="H4264"\w* \w de|strong="H3372"\w* los \w filisteos|strong="H6430"\w* \w tuvo|strong="H3372"\w* \w temor|strong="H3372"\w* y su \w corazón|strong="H3820"\w* \w tembló|strong="H2729"\w* muchísimo.
\v 6 \w Entonces|strong="H1571"\w* \w Saúl|strong="H7586"\w* \w consultó|strong="H7592"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*, pero \nd \w Yavé|strong="H3068"\w*\nd* \w no|strong="H3808"\w* le \w respondió|strong="H6030"\w*, \w ni|strong="H3808"\w* por \w sueños|strong="H2472"\w*, \w ni|strong="H3808"\w* por urim,\f + \fr 28:6 \ft Este urim no era el urim y tumim, que tenía el sacerdote en el \tl efod\tl*, porque el único sacerdote que quedó, Abiatar, estaba con David y tenía el \tl efod\tl*.\f* \w ni|strong="H3808"\w* por \w profetas|strong="H5030"\w*.
\v 7 Entonces \w Saúl|strong="H7586"\w* dijo \w a|strong="H3068"\w* sus esclavos: Búsquenme una mujer que sea bruja para que \w yo|strong="H2009"\w* \w vaya|strong="H3212"\w* \w a|strong="H3068"\w* ella y consulte por medio de ella.
\p \w Y|strong="H3068"\w* sus esclavos le respondieron: \w En|strong="H3212"\w* Endor hay una mujer que es bruja.
\p 
\v 8 Entonces \w Saúl|strong="H7586"\w* \w se|strong="H1931"\w* disfrazó, \w se|strong="H1931"\w* \w vistió|strong="H3847"\w* \w con|strong="H5973"\w* otras ropas y \w salió|strong="H3212"\w* \w con|strong="H5973"\w* \w dos|strong="H8147"\w* \w hombres|strong="H8147"\w*. Llegaron \w a|strong="H3068"\w* \w aquella|strong="H1931"\w* mujer \w de|strong="H5973"\w* \w noche|strong="H3915"\w* y dijo: \w Te|strong="H5973"\w* ruego \w que|strong="H1931"\w* \w me|strong="H5973"\w* hagas una práctica \w de|strong="H5973"\w* brujería y \w me|strong="H5973"\w* \w subas|strong="H5927"\w* al \w que|strong="H1931"\w* yo \w te|strong="H5973"\w* nombre.
\p 
\v 9 \w Y|strong="H3068"\w* la mujer le contestó: \w Mira|strong="H2009"\w*, \w tú|strong="H6213"\w* \w sabes|strong="H3045"\w* \w lo|strong="H4100"\w* \w que|strong="H4100"\w* \w Saúl|strong="H7586"\w* \w hizo|strong="H6213"\w*, \w cómo|strong="H4100"\w* echó \w de|strong="H4480"\w* la tierra \w a|strong="H3068"\w* los evocadores y \w adivinos|strong="H3049"\w*. ¿\w Por|strong="H4480"\w* \w qué|strong="H4100"\w* pones trampa \w a|strong="H3068"\w* \w mi|strong="H2009"\w* \w vida|strong="H5315"\w* \w para|strong="H4480"\w* producirme la \w muerte|strong="H4191"\w*?
\p 
\v 10 Entonces \w Saúl|strong="H7586"\w* le \w juró|strong="H7650"\w* \w por|strong="H1697"\w* \nd \w Yavé|strong="H3068"\w*\nd*: ¡\w Vive|strong="H2416"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w que|strong="H1697"\w* ningún castigo te vendrá \w por|strong="H1697"\w* \w este|strong="H2088"\w* \w asunto|strong="H1697"\w*!
\p 
\v 11 La mujer preguntó: ¿\w A|strong="H3068"\w* \w quién|strong="H4310"\w* te hago \w subir|strong="H5927"\w*?
\p \w Y|strong="H3068"\w* dijo: Hazme \w subir|strong="H5927"\w* \w a|strong="H3068"\w* \w Samuel|strong="H8050"\w*.
\p 
\v 12 Al \w ver|strong="H7200"\w* \w a|strong="H3068"\w* \w Samuel|strong="H8050"\w*, la mujer \w clamó|strong="H2199"\w* \w a|strong="H3068"\w* \w gran|strong="H1419"\w* \w voz|strong="H6963"\w*.
\p La mujer habló \w a|strong="H3068"\w* \w Saúl|strong="H7586"\w* y dijo:
\v 13 ¿\w Por|strong="H3588"\w* \w qué|strong="H3588"\w* \w me|strong="H4480"\w* engañaste? ¡Tú eres \w Saúl|strong="H7586"\w*!
\p \w Y|strong="H3068"\w* \w el|strong="H3588"\w* \w rey|strong="H4428"\w* le dijo: \w No|strong="H3588"\w* \w temas|strong="H3372"\w*. ¿\w Qué|strong="H3588"\w* miras? \w La|strong="H3588"\w* mujer respondió \w a|strong="H3068"\w* \w Saúl|strong="H7586"\w*: \w Miro|strong="H7200"\w* \w a|strong="H3068"\w* un \nd ʼElohim\nd* celestial \w que|strong="H3588"\w* \w sube|strong="H5927"\w* \w a|strong="H3068"\w* \w la|strong="H3588"\w* tierra.
\p 
\v 14 \w Y|strong="H3068"\w* \w le|strong="H1931"\w* preguntó: ¿\w Cuál|strong="H4100"\w* \w es|strong="H1931"\w* \w su|strong="H1931"\w* \w forma|strong="H8389"\w*? \w Ella|strong="H1931"\w* respondió: \w Sube|strong="H5927"\w* un \w anciano|strong="H2205"\w* \w cubierto|strong="H5844"\w* \w con|strong="H3588"\w* un \w manto|strong="H4598"\w*.
\p \w Entonces|strong="H3588"\w* \w Saúl|strong="H7586"\w* \w entendió|strong="H3045"\w* \w que|strong="H3588"\w* \w era|strong="H1931"\w* \w Samuel|strong="H8050"\w*, \w inclinó|strong="H6915"\w* \w el|strong="H1931"\w* rostro \w a|strong="H3068"\w* tierra \w y|strong="H3588"\w* \w se|strong="H3045"\w* postró.
\p 
\v 15 \w Entonces|strong="H5493"\w* \w Samuel|strong="H8050"\w* preguntó \w a|strong="H3068"\w* \w Saúl|strong="H7586"\w*: ¿\w Por|strong="H5921"\w* \w qué|strong="H4100"\w* \w me|strong="H5921"\w* perturbaste \w al|strong="H5921"\w* \w hacerme|strong="H6213"\w* \w subir|strong="H5927"\w*?
\p \w Y|strong="H3068"\w* \w Saúl|strong="H7586"\w* \w respondió|strong="H6030"\w*: Estoy \w muy|strong="H3966"\w* angustiado, \w pues|strong="H4100"\w* \w los|strong="H5921"\w* \w filisteos|strong="H6430"\w* \w pelean|strong="H3898"\w* \w contra|strong="H5921"\w* \w mí|strong="H5921"\w*, \w y|strong="H1571"\w* \nd ʼElohim\nd* \w se|strong="H3045"\w* apartó \w de|strong="H5921"\w* \w mí|strong="H5921"\w*. \w Ya|strong="H3068"\w* \w no|strong="H3808"\w* \w me|strong="H5921"\w* \w responde|strong="H6030"\w*, \w ni|strong="H3808"\w* \w por|strong="H5921"\w* \w profeta|strong="H5030"\w* \w ni|strong="H3808"\w* \w por|strong="H5921"\w* \w sueños|strong="H2472"\w*, \w por|strong="H5921"\w* \w lo|strong="H4100"\w* \w cual|strong="H4100"\w* \w te|strong="H5921"\w* \w llamé|strong="H7121"\w* \w para|strong="H5921"\w* \w que|strong="H4100"\w* \w me|strong="H5921"\w* reveles \w qué|strong="H4100"\w* debo \w hacer|strong="H6213"\w*.
\p 
\v 16 \w Samuel|strong="H8050"\w* dijo: \w Si|strong="H1961"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w se|strong="H1961"\w* apartó \w de|strong="H5921"\w* \w ti|strong="H5921"\w* \w y|strong="H5921"\w* \w es|strong="H1961"\w* tu adversario, ¿\w por|strong="H5921"\w* \w qué|strong="H4100"\w* \w me|strong="H5921"\w* \w preguntas|strong="H7592"\w* \w a|strong="H3068"\w* \w mí|strong="H5921"\w*?
\v 17 \nd \w Yavé|strong="H3068"\w*\nd* \w hizo|strong="H6213"\w* como \w habló|strong="H1696"\w* \w por|strong="H3027"\w* \w medio|strong="H3027"\w* \w de|strong="H5414"\w* mí: \nd \w Yavé|strong="H3068"\w*\nd* quitó \w el|strong="H6213"\w* \w reino|strong="H4467"\w* \w de|strong="H5414"\w* \w tu|strong="H6213"\w* \w mano|strong="H3027"\w* y \w lo|strong="H6213"\w* \w dio|strong="H5414"\w* \w a|strong="H3068"\w* \w tu|strong="H6213"\w* \w compañero|strong="H7453"\w* \w David|strong="H1732"\w*,
\v 18 \w por|strong="H5921"\w* \w cuanto|strong="H3651"\w* \w no|strong="H3808"\w* \w obedeciste|strong="H8085"\w* \w la|strong="H5921"\w* \w voz|strong="H6963"\w* \w de|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w ni|strong="H3808"\w* \w cumpliste|strong="H6213"\w* \w el|strong="H5921"\w* \w furor|strong="H2740"\w* \w de|strong="H5921"\w* su \w ira|strong="H2740"\w* \w contra|strong="H5921"\w* \w Amalec|strong="H6002"\w*. \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w te|strong="H5921"\w* \w hace|strong="H6213"\w* \w esto|strong="H2088"\w* \w hoy|strong="H3117"\w*.
\v 19 \w Además|strong="H1571"\w*, \nd \w Yavé|strong="H3068"\w*\nd* \w te|strong="H5973"\w* \w entregará|strong="H5414"\w* \w junto|strong="H5973"\w* \w con|strong="H5973"\w* \w Israel|strong="H3478"\w* \w en|strong="H5973"\w* \w manos|strong="H3027"\w* \w de|strong="H5973"\w* \w los|strong="H1121"\w* \w filisteos|strong="H6430"\w*, \w y|strong="H1571"\w* \w mañana|strong="H4279"\w* tú \w y|strong="H1571"\w* tus \w hijos|strong="H1121"\w* estarán \w conmigo|strong="H5973"\w*. \w Ciertamente|strong="H1571"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w también|strong="H1571"\w* \w entregará|strong="H5414"\w* al \w ejército|strong="H4264"\w* \w de|strong="H5973"\w* \w Israel|strong="H3478"\w* \w en|strong="H5973"\w* \w manos|strong="H3027"\w* \w de|strong="H5973"\w* \w los|strong="H1121"\w* \w filisteos|strong="H6430"\w*.
\p 
\v 20 Inmediatamente \w Saúl|strong="H7586"\w* \w cayó|strong="H5307"\w* \w en|strong="H3588"\w* tierra, \w tan|strong="H3966"\w* \w grande|strong="H3966"\w* \w como|strong="H3588"\w* \w era|strong="H1961"\w*, \w por|strong="H3588"\w* las \w palabras|strong="H1697"\w* \w de|strong="H3588"\w* \w Samuel|strong="H8050"\w*. \w Quedó|strong="H1961"\w* \w sin|strong="H3808"\w* \w fuerzas|strong="H3581"\w*, \w porque|strong="H3588"\w* \w todo|strong="H3605"\w* \w aquel|strong="H3605"\w* \w día|strong="H3117"\w* \w y|strong="H1571"\w* aquella \w noche|strong="H3915"\w* \w no|strong="H3808"\w* comió.
\p 
\v 21 \w Entonces|strong="H3588"\w* \w la|strong="H3588"\w* mujer fue \w a|strong="H3068"\w* \w Saúl|strong="H7586"\w* \w y|strong="H3588"\w* al \w ver|strong="H7200"\w* \w que|strong="H3588"\w* \w estaba|strong="H2009"\w* \w muy|strong="H3966"\w* turbado, le \w dijo|strong="H1696"\w*: \w Mira|strong="H7200"\w* \w que|strong="H3588"\w* tu esclava \w obedeció|strong="H8085"\w* tu \w voz|strong="H6963"\w*, arriesgué \w mi|strong="H2009"\w* \w vida|strong="H5315"\w* \w y|strong="H3588"\w* \w escuché|strong="H8085"\w* las \w palabras|strong="H1697"\w* \w que|strong="H3588"\w* \w me|strong="H3588"\w* \w dijiste|strong="H1696"\w*.
\v 22 \w Te|strong="H3588"\w* \w ruego|strong="H4994"\w* \w que|strong="H3588"\w* tú \w también|strong="H1571"\w* atiendas \w la|strong="H1571"\w* \w voz|strong="H6963"\w* \w de|strong="H3588"\w* tu esclava. Permíteme servirte un trozo \w de|strong="H3588"\w* \w pan|strong="H3899"\w* \w a|strong="H3068"\w* fin \w de|strong="H3588"\w* \w que|strong="H3588"\w* \w comas|strong="H3899"\w*, recuperes \w fuerzas|strong="H3581"\w* \w y|strong="H1571"\w* \w seguirás|strong="H1961"\w* tu \w camino|strong="H1870"\w*.
\p 
\v 23 Pero \w él|strong="H3427"\w* rehusó \w y|strong="H1571"\w* dijo: \w No|strong="H3808"\w* comeré. \w Entonces|strong="H1571"\w* \w los|strong="H3427"\w* esclavos de \w él|strong="H3427"\w* le insistieron \w juntamente|strong="H1571"\w* \w con|strong="H1571"\w* \w la|strong="H1571"\w* mujer, \w y|strong="H1571"\w* \w él|strong="H3427"\w* \w los|strong="H3427"\w* \w escuchó|strong="H8085"\w*.
\p \w Así|strong="H1571"\w* \w que|strong="H3808"\w* \w se|strong="H3808"\w* \w levantó|strong="H6965"\w* del piso \w y|strong="H1571"\w* \w se|strong="H3808"\w* sentó en \w la|strong="H1571"\w* \w cama|strong="H4296"\w*.
\p 
\v 24 \w Y|strong="H3068"\w* aquella mujer tenía en la \w casa|strong="H1004"\w* un ternero engordado, el cual \w mató|strong="H2076"\w*. \w Tomó|strong="H3947"\w* \w harina|strong="H7058"\w*, la amasó, coció panes sin levadura,
\v 25 y \w los|strong="H1931"\w* sirvió \w a|strong="H3068"\w* \w Saúl|strong="H7586"\w* y \w a|strong="H3068"\w* \w sus|strong="H1931"\w* esclavos. Después \w que|strong="H1931"\w* comieron, \w se|strong="H1931"\w* \w levantaron|strong="H6965"\w* y salieron \w aquella|strong="H1931"\w* \w misma|strong="H1931"\w* \w noche|strong="H3915"\w*.
\c 29
\s1 Desconfianza de los filisteos
\p 
\v 1 \w Los|strong="H3605"\w* \w filisteos|strong="H6430"\w* reunieron \w todos|strong="H3605"\w* sus \w ejércitos|strong="H4264"\w* en Afec, \w mientras|strong="H3605"\w* \w los|strong="H3605"\w* israelitas acamparon \w junto|strong="H6908"\w* \w a|strong="H3068"\w* \w la|strong="H3605"\w* \w fuente|strong="H5869"\w* \w que|strong="H3605"\w* está en \w Jezreel|strong="H3157"\w*.
\v 2 \w Los|strong="H5973"\w* jefes \w de|strong="H5973"\w* \w los|strong="H5973"\w* \w filisteos|strong="H6430"\w* desfilaban por centenas y por miles. \w David|strong="H1732"\w* y sus hombres marchaban \w en|strong="H5973"\w* la retaguardia \w con|strong="H5973"\w* Aquís.
\v 3 \w Entonces|strong="H3117"\w* \w los|strong="H1961"\w* \w jefes|strong="H8269"\w* \w de|strong="H5704"\w* \w los|strong="H1961"\w* \w filisteos|strong="H6430"\w* dijeron: ¿\w Qué|strong="H4100"\w* hacen \w aquí|strong="H2088"\w* \w estos|strong="H2088"\w* \w hebreos|strong="H5680"\w*? Aquís respondió \w a|strong="H3068"\w* \w los|strong="H1961"\w* \w jefes|strong="H8269"\w* \w de|strong="H5704"\w* \w los|strong="H1961"\w* \w filisteos|strong="H6430"\w*: ¿\w No|strong="H3808"\w* \w es|strong="H1961"\w* \w éste|strong="H2088"\w* \w David|strong="H1732"\w*, \w el|strong="H5307"\w* esclavo \w de|strong="H5704"\w* \w Saúl|strong="H7586"\w*, \w rey|strong="H4428"\w* \w de|strong="H5704"\w* \w Israel|strong="H3478"\w*, \w que|strong="H4100"\w* \w estuvo|strong="H1961"\w* conmigo \w estos|strong="H2088"\w* \w días|strong="H3117"\w* \w o|strong="H3068"\w* \w estos|strong="H2088"\w* \w años|strong="H8141"\w*, \w y|strong="H5704"\w* \w nada|strong="H3808"\w* malo \w hallé|strong="H4672"\w* \w en|strong="H5704"\w* \w él|strong="H5307"\w* \w desde|strong="H5704"\w* \w el|strong="H5307"\w* \w día|strong="H3117"\w* \w cuando|strong="H3117"\w* \w se|strong="H1961"\w* pasó \w a|strong="H3068"\w* \w mí|strong="H1961"\w* \w hasta|strong="H5704"\w* \w hoy|strong="H3117"\w*?
\p 
\v 4 Pero \w los|strong="H1992"\w* \w jefes|strong="H8269"\w* \w de|strong="H5921"\w* \w los|strong="H1992"\w* \w filisteos|strong="H6430"\w* \w se|strong="H1961"\w* enojaron \w contra|strong="H5921"\w* \w él|strong="H5921"\w* \w y|strong="H5921"\w* \w le|strong="H5921"\w* dijeron: Haz \w volver|strong="H7725"\w* \w a|strong="H3068"\w* \w ese|strong="H2088"\w* hombre \w para|strong="H5921"\w* \w que|strong="H4100"\w* regrese \w al|strong="H5921"\w* \w lugar|strong="H4725"\w* \w que|strong="H4100"\w* \w le|strong="H5921"\w* asignaste, \w y|strong="H5921"\w* \w no|strong="H3808"\w* vaya \w con|strong="H5973"\w* \w nosotros|strong="H5973"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w guerra|strong="H4421"\w*, \w no|strong="H3808"\w* \w sea|strong="H1961"\w* \w que|strong="H4100"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* \w batalla|strong="H4421"\w* \w se|strong="H1961"\w* \w nos|strong="H5921"\w* \w vuelva|strong="H7725"\w* adversario. \w Pues|strong="H2088"\w*, ¿\w con|strong="H5973"\w* \w qué|strong="H4100"\w* puede ser \w él|strong="H5921"\w* aceptable \w a|strong="H3068"\w* \w su|strong="H1992"\w* \tl ʼadón\tl*? ¿\w No|strong="H3808"\w* \w será|strong="H1961"\w* \w con|strong="H5973"\w* \w las|strong="H1992"\w* \w cabezas|strong="H7218"\w* \w de|strong="H5921"\w* \w estos|strong="H1992"\w* hombres?
\p 
\v 5 ¿\w No|strong="H3808"\w* \w es|strong="H2088"\w* \w este|strong="H2088"\w* \w David|strong="H1732"\w*, de quien \w se|strong="H3808"\w* cantaba con danzas:
\q1 \w Saúl|strong="H7586"\w* \w mató|strong="H5221"\w* \w a|strong="H3068"\w* sus miles,
\q1 \w Y|strong="H3068"\w* \w David|strong="H1732"\w*, \w a|strong="H3068"\w* sus diez miles?
\p 
\v 6 \w Entonces|strong="H3117"\w* Aquís \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* \w David|strong="H1732"\w* \w y|strong="H3588"\w* \w le|strong="H5869"\w* dijo: ¡\w Vive|strong="H2416"\w* \nd \w Yavé|strong="H3068"\w*\nd*, tú eres \w recto|strong="H3477"\w*! \w Me|strong="H3588"\w* \w pareció|strong="H5869"\w* \w bien|strong="H2896"\w* \w que|strong="H3588"\w* \w salgas|strong="H3318"\w* \w y|strong="H3588"\w* entres \w en|strong="H5704"\w* \w el|strong="H3588"\w* \w ejército|strong="H4264"\w* conmigo, \w porque|strong="H3588"\w* \w ninguna|strong="H3808"\w* \w cosa|strong="H2088"\w* \w perversa|strong="H7451"\w* \w hallé|strong="H4672"\w* \w en|strong="H5704"\w* ti \w desde|strong="H5704"\w* \w el|strong="H3588"\w* \w día|strong="H3117"\w* \w cuando|strong="H3588"\w* viniste \w a|strong="H3068"\w* mí \w hasta|strong="H5704"\w* \w hoy|strong="H3117"\w*. \w Pero|strong="H3588"\w* tú \w no|strong="H3808"\w* eres grato ante \w los|strong="H3588"\w* jefes.
\v 7 Regresa, \w pues|strong="H6258"\w*, y \w vete|strong="H3212"\w* \w en|strong="H3212"\w* \w paz|strong="H7965"\w*, \w para|strong="H6258"\w* \w no|strong="H3808"\w* desagradar \w a|strong="H3068"\w* los jefes \w de|strong="H5869"\w* los \w filisteos|strong="H6430"\w*.
\p 
\v 8 \w David|strong="H1732"\w* preguntó \w a|strong="H3068"\w* Aquís: ¿\w Qué|strong="H3588"\w* \w hice|strong="H6213"\w*? ¿\w Qué|strong="H3588"\w* \w hallaste|strong="H4672"\w* \w en|strong="H5704"\w* \w tu|strong="H6213"\w* esclavo \w desde|strong="H5704"\w* \w el|strong="H3588"\w* \w día|strong="H3117"\w* \w cuando|strong="H3588"\w* \w estuve|strong="H1961"\w* \w contigo|strong="H6440"\w* \w hasta|strong="H5704"\w* \w hoy|strong="H3117"\w* \w para|strong="H5704"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* vaya \w y|strong="H3588"\w* combata \w contra|strong="H6440"\w* \w los|strong="H1961"\w* enemigos \w de|strong="H3588"\w* \w mi|strong="H1961"\w* \tl ʼadón\tl* \w el|strong="H3588"\w* \w rey|strong="H4428"\w*?
\p 
\v 9 \w Y|strong="H3068"\w* Aquís \w respondió|strong="H6030"\w* \w a|strong="H3068"\w* \w David|strong="H1732"\w*: \w Yo|strong="H3588"\w* \w sé|strong="H3045"\w* \w que|strong="H3588"\w* tú eres \w bueno|strong="H2896"\w* \w delante|strong="H5869"\w* \w de|strong="H3588"\w* \w mí|strong="H6030"\w*, \w como|strong="H3588"\w* un \w ángel|strong="H4397"\w* \w de|strong="H3588"\w* \nd ʼElohim\nd*. \w Pero|strong="H3588"\w* \w los|strong="H5973"\w* \w jefes|strong="H8269"\w* \w de|strong="H3588"\w* \w los|strong="H5973"\w* \w filisteos|strong="H6430"\w* dijeron: \w No|strong="H3808"\w* \w irá|strong="H5927"\w* \w con|strong="H5973"\w* \w nosotros|strong="H5973"\w* \w a|strong="H3068"\w* \w la|strong="H3588"\w* \w batalla|strong="H4421"\w*.
\v 10 Por tanto \w levántate|strong="H7925"\w* \w mañana|strong="H1242"\w* temprano con los esclavos de tu \tl ʼadón\tl* \w que|strong="H6258"\w* vinieron contigo, y tan pronto como se levanten y tengan claridad, salgan.
\p 
\v 11 \w Entonces|strong="H7725"\w* \w David|strong="H1732"\w* y \w sus|strong="H1931"\w* hombres \w se|strong="H1931"\w* levantaron muy de \w mañana|strong="H1242"\w* para salir y \w volver|strong="H7725"\w* \w a|strong="H3068"\w* \w la|strong="H1931"\w* tierra de \w los|strong="H1931"\w* \w filisteos|strong="H6430"\w*. \w Y|strong="H3068"\w* \w los|strong="H1931"\w* \w filisteos|strong="H6430"\w* marcharon \w a|strong="H3068"\w* \w Jezreel|strong="H3157"\w*.
\c 30
\s1 Contra los amalecitas
\p 
\v 1 Al tercer \w día|strong="H3117"\w*, \w cuando|strong="H3117"\w* \w David|strong="H1732"\w* y sus hombres llegaron \w a|strong="H3068"\w* \w Siclag|strong="H6860"\w*, \w aconteció|strong="H1961"\w* \w que|strong="H3117"\w* \w los|strong="H1961"\w* amalecitas \w habían|strong="H1961"\w* incursionado \w en|strong="H5221"\w* el Neguev \w contra|strong="H1961"\w* \w Siclag|strong="H6860"\w*, y lo asolaron \w e|strong="H3068"\w* incendiaron.
\v 2 También tomaron cautivas \w a|strong="H3068"\w* las \w mujeres|strong="H5704"\w* \w y|strong="H5704"\w* \w a|strong="H3068"\w* todos los \w que|strong="H3808"\w* estaban allí, \w grandes|strong="H1419"\w* \w y|strong="H5704"\w* \w pequeños|strong="H6996"\w*. Pero \w a|strong="H3068"\w* \w nadie|strong="H3808"\w* \w mataron|strong="H4191"\w*, \w sino|strong="H3808"\w* \w se|strong="H3808"\w* los llevaron \w al|strong="H5704"\w* proseguir su \w camino|strong="H1870"\w*.
\p 
\v 3 Cuando \w David|strong="H1732"\w* y sus \w hombres|strong="H1121"\w* llegaron \w a|strong="H3068"\w* la \w ciudad|strong="H5892"\w*, ahí \w estaba|strong="H2009"\w* \w quemada|strong="H8313"\w*, y sus esposas, \w hijos|strong="H1121"\w* \w e|strong="H3068"\w* \w hijas|strong="H1323"\w* \w fueron|strong="H1732"\w* llevados cautivos.
\v 4 Entonces \w David|strong="H1732"\w* \w y|strong="H5704"\w* la \w gente|strong="H5971"\w* \w que|strong="H5704"\w* estaba \w con|strong="H5704"\w* él \w alzaron|strong="H5375"\w* su \w voz|strong="H6963"\w* \w y|strong="H5704"\w* \w lloraron|strong="H1058"\w* \w hasta|strong="H5704"\w* \w cuando|strong="H5704"\w* no les quedaron \w más|strong="H5704"\w* \w fuerzas|strong="H3581"\w* \w para|strong="H5704"\w* llorar.
\v 5 También \w fueron|strong="H1732"\w* tomadas cautivas las \w dos|strong="H8147"\w* esposas de \w David|strong="H1732"\w*: Ahinoam \w jezreelita|strong="H3159"\w* y Abigail, la que fue esposa de \w Nabal|strong="H5037"\w* \w carmelita|strong="H3761"\w*.
\v 6 \w Además|strong="H5921"\w* \w David|strong="H1732"\w* estaba \w muy|strong="H3966"\w* \w angustiado|strong="H3334"\w* \w porque|strong="H3588"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* hablaba \w de|strong="H5921"\w* apedrearlo, \w porque|strong="H3588"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w pueblo|strong="H5971"\w* estaba amargado, \w cada|strong="H3605"\w* uno \w por|strong="H5921"\w* causa \w de|strong="H5921"\w* sus \w hijos|strong="H1121"\w* \w e|strong="H3068"\w* \w hijas|strong="H1323"\w*. \w Pero|strong="H3588"\w* \w David|strong="H1732"\w* \w se|strong="H5921"\w* fortaleció \w en|strong="H5921"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w su|strong="H3588"\w* \nd ʼElohim\nd*.
\p 
\v 7 \w David|strong="H1732"\w* dijo al \w sacerdote|strong="H3548"\w* Abiatar, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Ahimelec: \w Tráeme|strong="H5066"\w* \w el|strong="H1121"\w* \tl efod\tl*. \w Y|strong="H3068"\w* Abiatar llevó \w el|strong="H1121"\w* \tl efod\tl* \w a|strong="H3068"\w* \w David|strong="H1732"\w*.
\v 8 \w David|strong="H1732"\w* \w consultó|strong="H7592"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*: ¿\w Persigo|strong="H7291"\w* \w a|strong="H3068"\w* \w esta|strong="H2088"\w* banda? ¿\w Los|strong="H7291"\w* alcanzaré?
\p \w Y|strong="H3068"\w* \w Él|strong="H3588"\w* le respondió: \wj \w Persíguelos|strong="H7291"\w* \w porque|strong="H3588"\w* \w de|strong="H3588"\w* seguro \w la|strong="H3588"\w* alcanzarás \w y|strong="H3588"\w* sin duda \w los|strong="H7291"\w* rescatarás.\wj*
\p 
\v 9 \w Por|strong="H5704"\w* tanto, \w David|strong="H1732"\w* \w salió|strong="H3212"\w* \w con|strong="H5704"\w* \w los|strong="H1931"\w* 600 hombres \w que|strong="H1931"\w* \w estaban|strong="H5975"\w* \w con|strong="H5704"\w* \w él|strong="H1931"\w*, \w y|strong="H5704"\w* llegaron \w hasta|strong="H5704"\w* \w el|strong="H1931"\w* \w torrente|strong="H5158"\w* Besor, \w donde|strong="H1931"\w* \w se|strong="H1931"\w* \w quedaron|strong="H3498"\w* \w los|strong="H1931"\w* rezagados.
\v 10 Pero \w David|strong="H1732"\w* continuó con 400 hombres, \w porque|strong="H1732"\w* 200 \w se|strong="H1931"\w* detuvieron \w porque|strong="H1732"\w* \w estaban|strong="H5975"\w* demasiado \w cansados|strong="H6296"\w* para cruzar \w el|strong="H1931"\w* \w torrente|strong="H5158"\w* Besor.
\p 
\v 11 \w Hallaron|strong="H4672"\w* en el \w campo|strong="H7704"\w* \w a|strong="H3068"\w* un \w egipcio|strong="H4713"\w*, \w a|strong="H3068"\w* quien \w llevaron|strong="H3947"\w* \w a|strong="H3068"\w* \w David|strong="H1732"\w*. Le \w dieron|strong="H5414"\w* \w pan|strong="H3899"\w*, y comió, y le \w dieron|strong="H5414"\w* \w a|strong="H3068"\w* \w beber|strong="H8248"\w* \w agua|strong="H4325"\w*.
\v 12 Le \w dieron|strong="H5414"\w* un trozo \w de|strong="H3588"\w* torta \w de|strong="H3588"\w* higos secos \w y|strong="H3588"\w* \w dos|strong="H8147"\w* racimos \w de|strong="H3588"\w* uvas pasas. \w Y|strong="H3068"\w* \w cuando|strong="H3588"\w* \w él|strong="H3588"\w* comió le \w volvió|strong="H7725"\w* \w el|strong="H3588"\w* aliento, \w porque|strong="H3588"\w* \w no|strong="H3808"\w* \w había|strong="H3588"\w* comido \w pan|strong="H3899"\w* \w ni|strong="H3808"\w* \w bebido|strong="H8354"\w* \w agua|strong="H4325"\w* \w en|strong="H3588"\w* \w tres|strong="H7969"\w* \w días|strong="H3117"\w* \w y|strong="H3588"\w* \w tres|strong="H7969"\w* \w noches|strong="H3915"\w*.
\p 
\v 13 \w David|strong="H1732"\w* \w le|strong="H4310"\w* preguntó: ¿\w A|strong="H3068"\w* \w quién|strong="H4310"\w* perteneces? ¿\w De|strong="H3588"\w* dónde vienes?
\p \w Y|strong="H3068"\w* \w él|strong="H3588"\w* respondió: Soy un joven \w de|strong="H3588"\w* Egipto, esclavo \w de|strong="H3588"\w* un amalecita, \w y|strong="H3588"\w* mi \tl ʼadón\tl* \w me|strong="H3588"\w* abandonó hace \w tres|strong="H7969"\w* \w días|strong="H3117"\w*, \w porque|strong="H3588"\w* enfermé.
\v 14 \w Nosotros|strong="H5921"\w* hicimos una incursión \w al|strong="H5921"\w* sur \w de|strong="H5921"\w* \w los|strong="H5921"\w* cereteos, \w en|strong="H5921"\w* \w lo|strong="H5921"\w* \w que|strong="H5921"\w* pertenece \w a|strong="H3068"\w* \w Judá|strong="H3063"\w* \w y|strong="H5921"\w* \w por|strong="H5921"\w* \w el|strong="H5921"\w* sur \w de|strong="H5921"\w* \w Caleb|strong="H3612"\w*, \w e|strong="H3068"\w* incendiamos \w a|strong="H3068"\w* \w Siclag|strong="H6860"\w*.
\p 
\v 15 \w David|strong="H1732"\w* le dijo: ¿Puedes llevarme tú \w a|strong="H3068"\w* esa banda?
\p \w Y|strong="H3068"\w* él respondió: \w Júrame|strong="H7650"\w* \w por|strong="H2088"\w* \nd ʼElohim\nd* \w que|strong="H2088"\w* no me matarás ni me \w entregarás|strong="H5462"\w* en \w mano|strong="H3027"\w* de mi \tl ʼadón\tl*, y yo te llevaré \w a|strong="H3068"\w* esa banda.
\p 
\v 16 Entonces \w lo|strong="H5921"\w* \w llevó|strong="H3947"\w*. \w Y|strong="H3068"\w* ahí estaban \w ellos|strong="H5921"\w* esparcidos \w por|strong="H5921"\w* \w toda|strong="H3605"\w* \w aquella|strong="H5921"\w* tierra comiendo, \w bebiendo|strong="H8354"\w* \w y|strong="H5921"\w* festejando \w por|strong="H5921"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w gran|strong="H1419"\w* \w despojo|strong="H7998"\w* \w que|strong="H5921"\w* \w tomaron|strong="H3947"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w filisteos|strong="H6430"\w* \w y|strong="H5921"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* tierra \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*.
\v 17 \w David|strong="H1732"\w* \w los|strong="H1992"\w* atacó \w desde|strong="H5704"\w* \w el|strong="H5921"\w* alba \w hasta|strong="H5704"\w* \w la|strong="H5921"\w* noche \w del|strong="H5921"\w* día \w siguiente|strong="H4283"\w*. \w No|strong="H3808"\w* \w escapó|strong="H4422"\w* \w ninguno|strong="H3808"\w* \w de|strong="H5921"\w* \w ellos|strong="H1992"\w*, excepto 400 jóvenes \w que|strong="H3588"\w* montaron \w en|strong="H5921"\w* \w camellos|strong="H1581"\w* \w y|strong="H3588"\w* \w huyeron|strong="H5127"\w*.
\v 18 \w David|strong="H1732"\w* liberó \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w que|strong="H3605"\w* \w fueron|strong="H1732"\w* tomados por \w los|strong="H3605"\w* amalecitas y rescató \w a|strong="H3068"\w* sus \w dos|strong="H8147"\w* esposas.
\v 19 \w No|strong="H3808"\w* les \w faltó|strong="H5737"\w* \w cosa|strong="H3605"\w* \w pequeña|strong="H6996"\w* \w ni|strong="H3808"\w* \w grande|strong="H1419"\w*, \w ni|strong="H3808"\w* \w hijos|strong="H1121"\w* \w ni|strong="H3808"\w* \w hijas|strong="H1323"\w*, \w ni|strong="H3808"\w* \w del|strong="H4480"\w* \w despojo|strong="H7998"\w* \w de|strong="H4480"\w* \w todo|strong="H3605"\w* \w lo|strong="H3808"\w* \w que|strong="H4480"\w* les \w tomaron|strong="H3947"\w*. \w David|strong="H1732"\w* \w lo|strong="H3808"\w* \w recuperó|strong="H7725"\w* \w todo|strong="H3605"\w*.
\v 20 Además \w David|strong="H1732"\w* \w se|strong="H1931"\w* apoderó \w de|strong="H6440"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* rebaños \w y|strong="H1241"\w* las manadas vacunas, \w los|strong="H3605"\w* cuales \w llevaron|strong="H3947"\w* \w delante|strong="H6440"\w* del \w ganado|strong="H4735"\w* recobrado. \w Y|strong="H3068"\w* decían: ¡\w Este|strong="H2088"\w* \w es|strong="H1931"\w* \w el|strong="H1931"\w* botín \w de|strong="H6440"\w* \w David|strong="H1732"\w*!
\p 
\v 21 \w David|strong="H1732"\w* \w llegó|strong="H5066"\w* \w a|strong="H3068"\w* \w los|strong="H3427"\w* 200 hombres \w que|strong="H5971"\w* por estar muy débiles no pudieron seguirlo, \w a|strong="H3068"\w* quienes dejó \w junto|strong="H5971"\w* al \w torrente|strong="H5158"\w* Besor. Ellos \w salieron|strong="H3318"\w* \w a|strong="H3068"\w* recibir \w a|strong="H3068"\w* \w David|strong="H1732"\w* y \w a|strong="H3068"\w* la \w gente|strong="H5971"\w* \w que|strong="H5971"\w* lo acompañaba. Cuando \w David|strong="H1732"\w* \w se|strong="H5971"\w* \w acercó|strong="H5066"\w* \w a|strong="H3068"\w* ellos, \w los|strong="H3427"\w* saludó con \w paz|strong="H7965"\w*.
\v 22 \w Pero|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hombres|strong="H1121"\w* malvados \w y|strong="H3588"\w* \w perversos|strong="H1121"\w* \w que|strong="H3588"\w* \w fueron|strong="H3212"\w* \w con|strong="H5973"\w* \w David|strong="H1732"\w* dijeron: \w Puesto|strong="H3588"\w* \w que|strong="H3588"\w* \w no|strong="H3808"\w* \w fueron|strong="H3212"\w* \w con|strong="H5973"\w* \w nosotros|strong="H3605"\w*, \w no|strong="H3808"\w* \w les|strong="H5973"\w* \w demos|strong="H5414"\w* \w del|strong="H5973"\w* \w despojo|strong="H7998"\w* recuperado, excepto \w a|strong="H3068"\w* \w cada|strong="H3605"\w* uno \w su|strong="H3588"\w* esposa \w y|strong="H3588"\w* sus \w hijos|strong="H1121"\w*. \w Que|strong="H3588"\w* \w los|strong="H1121"\w* tomen \w y|strong="H3588"\w* \w se|strong="H3808"\w* \w vayan|strong="H3212"\w*.
\p 
\v 23 Pero \w David|strong="H1732"\w* dijo: Hermanos míos, \w no|strong="H3808"\w* \w hagan|strong="H6213"\w* \w eso|strong="H3651"\w* \w con|strong="H5921"\w* \w lo|strong="H3808"\w* \w que|strong="H3808"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w nos|strong="H5921"\w* \w dio|strong="H5414"\w*, \w pues|strong="H3651"\w* \w nos|strong="H5921"\w* protegió \w y|strong="H5921"\w* \w entregó|strong="H5414"\w* \w la|strong="H5921"\w* banda \w que|strong="H3808"\w* vino \w contra|strong="H5921"\w* \w nosotros|strong="H5921"\w* \w en|strong="H5921"\w* nuestra \w mano|strong="H3027"\w*.
\v 24 ¿\w Quién|strong="H4310"\w* \w los|strong="H3427"\w* \w escuchará|strong="H8085"\w* \w en|strong="H5921"\w* \w esto|strong="H2088"\w*? \w Porque|strong="H3588"\w* \w la|strong="H5921"\w* misma \w parte|strong="H2506"\w* debe haber \w para|strong="H5921"\w* \w los|strong="H3427"\w* \w que|strong="H3588"\w* van \w a|strong="H3068"\w* \w la|strong="H5921"\w* \w batalla|strong="H4421"\w* \w y|strong="H3588"\w* \w para|strong="H5921"\w* \w los|strong="H3427"\w* \w que|strong="H3588"\w* \w se|strong="H5921"\w* quedan \w con|strong="H5921"\w* \w el|strong="H5921"\w* equipo. Participarán \w por|strong="H5921"\w* \w igual|strong="H2505"\w*.
\v 25 \w Desde|strong="H5704"\w* \w aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w en|strong="H5704"\w* \w adelante|strong="H5704"\w* \w quedó|strong="H1961"\w* establecido \w esto|strong="H2088"\w* \w como|strong="H1961"\w* \w estatuto|strong="H2706"\w* \w y|strong="H5704"\w* \w ordenanza|strong="H4941"\w* \w en|strong="H5704"\w* \w Israel|strong="H3478"\w* \w hasta|strong="H5704"\w* \w hoy|strong="H3117"\w*.
\p 
\v 26 Al llegar \w a|strong="H3068"\w* \w Siclag|strong="H6860"\w* \w David|strong="H1732"\w* \w envió|strong="H7971"\w* parte del \w despojo|strong="H7998"\w* \w a|strong="H3068"\w* los \w ancianos|strong="H2205"\w* de \w Judá|strong="H3063"\w*, sus \w amigos|strong="H7453"\w*, y dijo: \w Aquí|strong="H2009"\w* está un \w presente|strong="H1293"\w* para ustedes del \w despojo|strong="H7998"\w* de los enemigos de \nd \w Yavé|strong="H3068"\w*\nd*.
\p 
\v 27 También envió \w a|strong="H3068"\w* los que estaban en Bet-ʼEl, en Ramot del sur, en Jatir,
\v 28 en \w Aroer|strong="H6177"\w* y en Sifmot, en Estemoa,
\v 29 en Racal, en las \w ciudades|strong="H5892"\w* de Jerameel, en las \w ciudades|strong="H5892"\w* del ceneo,
\v 30 en \w Horma|strong="H2767"\w*, en Corasán, en Atac,
\v 31 en \w Hebrón|strong="H2275"\w*, y \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w lugares|strong="H4725"\w* \w que|strong="H1931"\w* \w David|strong="H1732"\w* recorrió con \w sus|strong="H1931"\w* hombres.
\c 31
\s1 Muerte de Saúl
\p 
\v 1 Entretanto los \w filisteos|strong="H6430"\w* combatían \w contra|strong="H6440"\w* \w Israel|strong="H3478"\w*. Los israelitas \w huyeron|strong="H5127"\w* \w de|strong="H6440"\w* los \w filisteos|strong="H6430"\w* y \w cayeron|strong="H5307"\w* \w muertos|strong="H2491"\w* en la montaña Gilboa.
\v 2 \w Los|strong="H1121"\w* \w filisteos|strong="H6430"\w* \w siguieron|strong="H5221"\w* \w de|strong="H1121"\w* cerca tras \w Saúl|strong="H7586"\w* y sus \w hijos|strong="H1121"\w*. \w Mataron|strong="H5221"\w* \w a|strong="H3068"\w* Jonatán, \w a|strong="H3068"\w* Abinadab y \w a|strong="H3068"\w* Malquisúa, \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Saúl|strong="H7586"\w*.
\v 3 Arreció la \w batalla|strong="H4421"\w* contra \w Saúl|strong="H7586"\w*. Los hombres que tiran con el \w arco|strong="H7198"\w* lo alcanzaron y fue \w herido|strong="H2342"\w* \w gravemente|strong="H3966"\w* por los arqueros.
\p 
\v 4 \w Entonces|strong="H3588"\w* \w Saúl|strong="H7586"\w* dijo \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w escudero|strong="H5375"\w*: ¡\w Saca|strong="H8025"\w* tu \w espada|strong="H2719"\w* \w y|strong="H3588"\w* traspásame \w con|strong="H5921"\w* \w ella|strong="H5921"\w*! \w No|strong="H3808"\w* \w sea|strong="H6435"\w* \w que|strong="H3588"\w* vengan estos \w incircuncisos|strong="H6189"\w*, \w me|strong="H5921"\w* traspasen \w y|strong="H3588"\w* hagan escarnio \w de|strong="H5921"\w* \w mí|strong="H5921"\w*.
\p \w Pero|strong="H3588"\w* \w su|strong="H3588"\w* \w escudero|strong="H5375"\w* \w no|strong="H3808"\w* quiso, \w pues|strong="H3588"\w* tenía \w gran|strong="H3966"\w* \w temor|strong="H3372"\w*. \w Entonces|strong="H3588"\w* \w Saúl|strong="H7586"\w* \w tomó|strong="H3947"\w* \w la|strong="H5921"\w* \w espada|strong="H2719"\w* \w y|strong="H3588"\w* \w se|strong="H5921"\w* \w echó|strong="H5307"\w* \w sobre|strong="H5921"\w* \w ella|strong="H5921"\w*.
\v 5 \w Al|strong="H5921"\w* \w ver|strong="H7200"\w* \w que|strong="H3588"\w* \w Saúl|strong="H7586"\w* moría, \w su|strong="H1931"\w* \w escudero|strong="H5375"\w* \w también|strong="H1571"\w* \w se|strong="H1931"\w* \w echó|strong="H5307"\w* \w sobre|strong="H5921"\w* \w su|strong="H1931"\w* propia \w espada|strong="H2719"\w* \w para|strong="H5921"\w* \w morir|strong="H4191"\w* \w con|strong="H5973"\w* \w él|strong="H1931"\w*.
\v 6 \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w murió|strong="H4191"\w* \w Saúl|strong="H7586"\w*, \w sus|strong="H1931"\w* \w tres|strong="H7969"\w* \w hijos|strong="H1121"\w*, \w su|strong="H1931"\w* \w escudero|strong="H5375"\w* \w y|strong="H1571"\w* \w todos|strong="H3605"\w* \w sus|strong="H1931"\w* \w hombres|strong="H1121"\w* \w junto|strong="H3162"\w* \w con|strong="H1571"\w* \w él|strong="H1931"\w*.
\p 
\v 7 \w Cuando|strong="H3588"\w* \w los|strong="H3427"\w* \w hombres|strong="H1121"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w que|strong="H3588"\w* \w estaban|strong="H3427"\w* al otro \w lado|strong="H5676"\w* del \w valle|strong="H6010"\w* \w y|strong="H3588"\w* \w los|strong="H3427"\w* del otro \w lado|strong="H5676"\w* del \w Jordán|strong="H3383"\w* \w vieron|strong="H7200"\w* \w que|strong="H3588"\w* \w los|strong="H3427"\w* \w de|strong="H3588"\w* \w Israel|strong="H3478"\w* \w huyeron|strong="H5127"\w* \w y|strong="H3588"\w* \w que|strong="H3588"\w* \w Saúl|strong="H7586"\w* \w y|strong="H3588"\w* sus \w hijos|strong="H1121"\w* \w murieron|strong="H4191"\w*, abandonaron las \w ciudades|strong="H5892"\w* \w y|strong="H3588"\w* \w huyeron|strong="H5127"\w*. \w Entonces|strong="H3588"\w* \w los|strong="H3427"\w* \w filisteos|strong="H6430"\w* fueron \w y|strong="H3588"\w* vivieron \w en|strong="H3588"\w* ellas.
\p 
\v 8 Al \w día|strong="H1121"\w* \w siguiente|strong="H4283"\w* \w aconteció|strong="H1961"\w* \w que|strong="H1121"\w* \w los|strong="H1121"\w* \w filisteos|strong="H6430"\w* \w fueron|strong="H1961"\w* \w a|strong="H3068"\w* despojar \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w muertos|strong="H2491"\w* y \w hallaron|strong="H4672"\w* \w a|strong="H3068"\w* \w Saúl|strong="H7586"\w* y sus \w tres|strong="H7969"\w* \w hijos|strong="H1121"\w* \w tendidos|strong="H5307"\w* en la montaña Gilboa.
\v 9 Le \w cortaron|strong="H3772"\w* la \w cabeza|strong="H7218"\w* y lo despojaron \w de|strong="H5971"\w* sus \w armas|strong="H3627"\w*. \w Enviaron|strong="H7971"\w* \w a|strong="H3068"\w* proclamar la noticia por toda la tierra \w de|strong="H5971"\w* los \w filisteos|strong="H6430"\w*, en el \w templo|strong="H1004"\w* \w de|strong="H5971"\w* sus \w ídolos|strong="H6091"\w* y entre el \w pueblo|strong="H5971"\w*.
\v 10 Colgaron sus \w armas|strong="H3627"\w* en el \w templo|strong="H1004"\w* de Astarot y clavaron su cadáver contra el \w muro|strong="H2346"\w* de Bet-sán.
\p 
\v 11 Cuando \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* de \w Jabes|strong="H3003"\w* de \w Galaad|strong="H1568"\w* \w oyeron|strong="H8085"\w* \w lo|strong="H6213"\w* que \w los|strong="H3427"\w* \w filisteos|strong="H6430"\w* \w hicieron|strong="H6213"\w* \w a|strong="H3068"\w* \w Saúl|strong="H7586"\w*,
\v 12 se \w levantaron|strong="H6965"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w hombres|strong="H1121"\w* \w valientes|strong="H2428"\w* y \w anduvieron|strong="H3212"\w* \w toda|strong="H3605"\w* aquella \w noche|strong="H3915"\w*. Bajaron \w el|strong="H3605"\w* cadáver \w de|strong="H1121"\w* \w Saúl|strong="H7586"\w* y \w los|strong="H1121"\w* cadáveres \w de|strong="H1121"\w* sus \w hijos|strong="H1121"\w* del \w muro|strong="H2346"\w* \w de|strong="H1121"\w* Bet-sán. \w Fueron|strong="H3212"\w* \w a|strong="H3068"\w* \w Jabes|strong="H3003"\w* y \w los|strong="H1121"\w* quemaron \w allí|strong="H8033"\w*.
\v 13 Luego \w tomaron|strong="H3947"\w* sus \w huesos|strong="H6106"\w* y los \w sepultaron|strong="H6912"\w* \w debajo|strong="H8478"\w* del tamarisco \w en|strong="H6912"\w* \w Jabes|strong="H3003"\w*, y ayunaron \w siete|strong="H7651"\w* \w días|strong="H3117"\w*. 
