\v 12 \w Amih|strong="H9908"\w* \w te|strong="H9997"\w* \w Samson|strong="H8123"\w* loh, “\w Nangmih|strong="H9904"\w* \w taengah|strong="H9997"\w* ka \w thui|strong="H2330"\w* \w olkael|strong="H2420"\w* \w he|strong="H9907"\w* \w buhkoknah|strong="H4960"\w* \w hnin|strong="H3117"\w* \w rhih|strong="H7651"\w* khuiah \w kai|strong="H9901"\w* \w taengah|strong="H9997"\w* han \w thui|strong="H5046"\w* rhoela han \w thui|strong="H5046"\w* uh. Na \w puk|strong="H4672"\w* uh \w atah|strong="H9999"\w* \w hni|strong="H5466"\w* \w sawmthum|strong="H7970"\w* \w neh|strong="H9999"\w* \w thovaelnah|strong="H2487"\w* \w himbai|strong="H0899"\w* \w sawmthum|strong="H7970"\w* te \w nangmih|strong="H9904"\w* kam \w pae|strong="H5414"\w* eh.  
