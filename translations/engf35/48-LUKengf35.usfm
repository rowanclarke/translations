\m 
\v 1 \w Now|strong="G2532"\w* \w it|strong="G2532"\w* \w happened|strong="G1096"\w* \w after|strong="G2596"\w* \w this|strong="G3588"\w* \w that|strong="G3588"\w* \w He|strong="G2532"\w* \w started|strong="G1096"\w* \w going|strong="G2532"\w* \w around|strong="G2596"\w* \w town|strong="G4172"\w* \w by|strong="G1722"\w* \w town|strong="G4172"\w*, \w village|strong="G2968"\w* \w by|strong="G1722"\w* \w village|strong="G2968"\w*, \w preaching|strong="G2784"\w* \w and|strong="G2532"\w* \w proclaiming|strong="G2784"\w* \w the|strong="G1722"\w* \w good|strong="G2097"\w* \w news|strong="G2097"\w* \w of|strong="G2316"\w* \w the|strong="G1722"\w* Kingdom \w of|strong="G2316"\w* \w God|strong="G2316"\w*, \w and|strong="G2532"\w* \w the|strong="G1722"\w* \w twelve|strong="G1427"\w* \w were|strong="G3588"\w* \w with|strong="G1722"\w* \w Him|strong="G3588"\w*;
