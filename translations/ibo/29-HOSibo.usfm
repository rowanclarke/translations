\id HOS - Biblica® Open Igbo Contemporary Bible 2020 
\h Hosiya 
\toc1 Hosiya 
\toc2 Hosiya 
\toc3 Hos 
\mt1 Hosiya 
\c 1  
\p  
\v 1 Okwu \nd Onyenwe anyị\nd* nke bịakwutere Hosiya nwa Beiri nʼoge Uzaya, na Jotam, na Ehaz, na Hezekaya, bụ ndị eze Juda, na nʼoge Jeroboam nwa Jehoash bụ eze nʼIzrel. 
\b  
\s1 Nwunye Hosiya na ụmụ ya 
\p  
\v 2 Na mmalite okwu \nd Onyenwe anyị\nd* site nʼọnụ Hosiya, \nd Onyenwe anyị\nd* gwara Hosiya sị, “Gaa lụtara onwe gị nwanyị na-akwa iko na ụmụ amụtara nʼịkwa iko, nʼihi na dịka nwanyị alụrụ alụ nʼakwa iko, ala a na-akwa iko nke ukwu site nʼịgbahapụ \nd Onyenwe anyị\nd*.”  
\v 3 Ya mere, ọ gara lụọ Goma nwa Diblaim, onye tụụrụ ime mụọra ya nwa nwoke. 
\p  
\v 4 \nd Onyenwe anyị\nd* gwara ya, “Aha ị ga-agụ nwantakịrị ahụ bụ Jezril. Nʼihi na tupu nwa oge nta agafee, aga m ata ezinaụlọ Jehu ahụhụ nʼihi ọbara ọ wụsiri na Jezril. Aga m eme ka alaeze nke ụlọ Izrel kwụsị.  
\v 5 Nʼụbọchị ahụ, aga m agbaji ụta Izrel na Ndagwurugwu Jezril.” 
\p  
\v 6 Emesịa, Goma tụụrụ ime ọzọ, mụta nwa nwanyị. Ọ gwara ya, “Aha ị ga-agụ ya bụ Lo-Ruhama,\f + \fr 1:6 \ft Nke a pụtara \fqa onye a na-ahụghị nʼanya \ft maọbụ, \fqa obi ebere adịghịkwa\f* nʼihi na agaghị m enwekwa obi ebere ọzọ nʼahụ ụlọ Izrel, ịgbaghara ha mmehie ha.  
\v 7 Ma aga m enwe obi ebere nʼahụ ụlọ Juda. Mụ onwe m ga-azọpụta ha site na \nd Onyenwe anyị\nd* bụ Chineke ha. Agaghị m eji ngwa agha ọbụla, dịka ụta maọbụ mma agha maọbụ ike ibu agha maọbụ ịnyịnya maọbụ ndị na-agba ịnyịnya zọpụta ha.” 
\p  
\v 8 Mgbe ọ jụrụ Lo-Ruhama ara, ọ tụụrụ ime ọzọ, mụọ nwa nwoke.  
\v 9 \nd Onyenwe anyị\nd* sịrị, “Kpọọ aha ya Lo-ammi,\f + \fr 1:9 \ft Nke pụtara, \fqa ọ bụghị ndị nke m\f* nke pụtara unu abụghị ndị m, nʼihi na unu abụghị ndị nke m, mụ onwe m abụkwaghị Chineke unu. 
\p  
\v 10 “Ma ọnụọgụgụ ụmụ Izrel ga-adị ka aja dị nʼọnụ oke osimiri nke a na-apụghị ịgụta ọnụ maọbụ tụọ nʼihe ọtụtụ. Nʼebe ahụ a nọ sị ha, ‘Unu abụghị ndị m,’ nʼebe ahụ ka a ga-anọ sịkwa ha, ‘Ụmụ Chineke dị ndụ ka unu bụ.’  
\v 11 A ga-achịkọtakwa ndị Juda na ndị Izrel ọnụ. Ha ga-ahọpụtakwara onwe ha otu onyeisi, si nʼala ahụ rigopụta, nʼihi ihe ukwu ka ụbọchị Jezril ga-abụ. 
\c 2  
\p  
\v 1 “Gwa ụmụnne gị ndị nwoke Ami, ‘nke pụtara ndị m,’ gwakwa ụmụnne gị nwanyị Ruhama, nke pụtara, ‘Unu ndị m hụrụ nʼanya.’ 
\s1 Ntaramahụhụ na nlọta 
\q1  
\v 2 “Unu guzogidenụ nne unu, rịọọnụ ya, 
\q2 nʼihi na ọ bụghị nwunye m, 
\q2 mụ onwe m abụkwaghị di ya. 
\q1 Gwanụ ya ka o wezuga ịkwa iko site nʼihu ya, 
\q2 ya wezugakwa ịgba akwụna nke dị nʼetiti ara ya abụọ. 
\q1  
\v 3 Ma ọ bụghị otu a, aga m eyipụ ya uwe ya mee ka ọ gbara ọtọ, 
\q2 aga m eme ka o gbara ọtọ dị ka nʼụbọchị ahụ a mụrụ ya. 
\q1 Aga m eme ya ka ọ dị ka ọzara, 
\q2 ka ọ ghọọ nʼala kpọrọ nkụ, 
\q2 were akpịrị ịkpọ nkụ mee ka ọ nwụọ. 
\q1  
\v 4 Agaghị m egosi ụmụ ya ebere m, 
\q2 nʼihi na ha bụ ụmụ a kwatara nʼiko. 
\q1  
\v 5 Nʼihi na nne ha bụ onye na-akwa iko, 
\q2 ọ tụrụ ime ha nʼọnọdụ ihere. 
\q1 Site nʼikwu sị, ‘Aghaghị m ịgbakwuru ndị enyi nwoke hụrụ m nʼanya, 
\q2 ndị na-enye m nri na mmiri, 
\q2 ajị anụ m na akwa ọcha m, mmanụ oliv m na ihe ọṅụṅụ m.’ 
\q1  
\v 6 Nʼihi nke a, aga m eji ogwu na uke gbachie ya gburugburu; 
\q2 aga m agbachi ụzọ ya, mee ya ka ọ ghara ịma ebe ọ na-eje. 
\q1  
\v 7 Ọ ga-agbaso ndị ahụ hụrụ ya nʼanya ma ọ gaghị achụkwute ha. 
\q2 Ọ ga-achọ ha ma ọ gaghị ahụ ha. 
\q1 Mgbe ahụ, ọ ga-asị, 
\q2 ‘Ka m gaa laghachikwuru di mbụ m, 
\q2 nʼihi na ọ dịrị m mma mgbe ahụ karịa ugbu a.’ 
\q1  
\v 8 Ma ọ kwetaghị na ihe ndị a si nʼaka m, 
\q2 na ọ bụ mụ nyere ya ọka, na mmanya ọhụrụ, na mmanụ oliv, 
\q1 na ọlaọcha, na ọlaedo ndị ahụ niile 
\q2 nke o ji na-efe Baal. 
\b  
\q1  
\v 9 “Ya mere, aga m ewerekwa ọka m mgbe ọ chara, 
\q2 na mmanya ọhụrụ m mgbe oge ya ruru. 
\q1 Aga m anapụkwa ya akwa ajị anụ m na akwa ọcha m, 
\q2 nke ekwesiri iji kpuchie ọtọ ya. 
\q1  
\v 10 Ugbu a, aga m ekpughe ọtọ ya 
\q2 nʼihu ndị ahụ na-ahụ ya nʼanya,\f + \fr 2:10 \ft Ndị ya na ha na-akwa iko\f* 
\q2 ọ dịkwaghị onye nwere ike ịnapụta ya site nʼaka m. 
\q1  
\v 11 Aga m eme ka obi ụtọ ya kwụsị; 
\q2 ọ bụladị mmemme nke afọ niile, mmemme ọnwa ọhụrụ, 
\q2 nke ụbọchị izuike na mmemme ndị ọzọ ahụ niile a kara aka. 
\q1  
\v 12 Aga m ala ubi vaịnị ya na osisi fiig ya niile nʼiyi, 
\q2 nke ọ sịrị bụ ụgwọ ọrụ ya site nʼaka ndị hụrụ ya nʼanya; 
\q1 aga m emekwa ka ha ghọọ oke ọhịa, 
\q2 anụ ọhịa ga-eripịa ha. 
\q1  
\v 13 Aga m enye ya ahụhụ maka ụbọchị niile 
\q2 bụ nke o surere ihe na-esi isi ụtọ nye chi Baal niile, 
\q1 ọ chịrị mgbaaka mkpịsịaka na ihe ịchọ mma niile, jikere onwe ya, 
\q2 pụọ chụso ndị ahụ hụrụ ya nʼanya, 
\q2 ma chezọọ m,” Otu a ka \nd Onyenwe anyị\nd* kwubiri ya. 
\b  
\q1  
\v 14 “Nʼihi nke a, aga m arara ya, 
\q2 duba ya nʼime ọzara, 
\q2 jiri olu dị nro gwa ya okwu nʼebe ahụ. 
\q1  
\v 15 Ebe ahụ ka m ga-enyeghachi ya ubi vaịnị ya, 
\q2 gbanweekwa Ndagwurugwu Akọ, mee ka ọ ghọọ ọnụ ụzọ olileanya. 
\q1 Mgbe ahụ, ọ ga-azakwa m dịka o mere mgbe ọ bụ agbọghọbịa, 
\q2 nʼoge ahụ o si nʼala Ijipt pụta. 
\b  
\q1  
\v 16 “Nʼụbọchị ahụ,” otu a ka \nd Onyenwe anyị\nd* kwubiri, 
\q2 “Ị ga-akpọ m ‘Di m,’ 
\q2 ị gaghị akpọkwa m ‘nna m ukwu,’ ọzọ.\f + \fr 2:16 \ft Maọbụ, \fqa Baal nʼasụsụ Hibru\f* 
\q1  
\v 17 Nʼihi na aga m ewepụkwa aha niile nke arụsị Baal nʼegbugbere ọnụ ya, 
\q2 ha gaghị akpọkwa ha aha ọzọ. 
\q1  
\v 18 Nʼụbọchị ahụ, aga m eme ka gị na ụmụ anụ ọhịa gbaa ndụ, 
\q2 meekwa ka gị na ụmụ nnụnụ, 
\q2 na ihe niile e kere eke nʼakpụgharị nʼala gbaa ndụ. 
\q1 Aga m emebi ngwa agha niile, 
\q2 agha niile ga-akwụsịkwa. 
\q2 Mgbe ahụ, a ga-eme ka ị dịnaa ala nʼudo na-enweghị nsogbu, na ụjọ. 
\q1  
\v 19 Aga m ekwerekwa ịlụ gị dịka nwunye ruo ebighị ebi; 
\q2 aga m ekwerekwa ịlụ gị nʼezi omume na ikpe ziri ezi, 
\q2 nʼịhụnanya nke na-adịgide, nakwa obi ebere. 
\q1  
\v 20 Aga m eji ikwesi ntụkwasị obi kwere ịlụ gị. 
\q2 Ị ga-amatakwa \nd Onyenwe anyị\nd*. 
\b  
\q1  
\v 21 “Nʼụbọchị ahụ m ga-azaghachi,” 
\q2 otu a ka \nd Onyenwe anyị\nd* kwubiri ya. 
\q1 “M ga-azaghachi eluigwe, 
\q2 ha ga-azaghachi ala. 
\q1  
\v 22 Ala ga-azaghachi ọka 
\q2 na mmanya ọhụrụ na mmanụ oliv, 
\q2 mgbe ahụ ha ga-azaghachi Jezril. 
\q1  
\v 23 Aga m akụkwa ya nye onwe m nʼala ahụ dịka mkpụrụ. 
\q2 Aga m egosi ịhụnanya m nʼahụ onye ahụ m kpọrọ, ‘Onye m na-ahụghị nʼanya.’\f + \fr 2:23 \ft Enwekwa obi ebere nʼahụ Lo-Ruhama,\f* 
\q1 M ga-asịkwa ndị ahụ a kpọrọ, ‘Ndị na-abụghị ndị m,\f + \fr 2:23 \ft Ya bụ, Lo-ammi,\f*’ ‘Unu bụ ndị nke m,’ 
\q2 Ha ga-azakwa, ‘Chineke m ka ị bụ.’ ” 
\c 3  
\s1 Hosiya na nwunye ya adịrịkwa na mma 
\p  
\v 1 \nd Onyenwe anyị\nd* gwara m ọzọ, “Gakwuru nwanyị a na-akwa iko, nke na-emekwa enyi na-ezighị ezi, gosi ya ịhụnanya gị dịka \nd Onyenwe anyị\nd* si hụ ndị Izrel nʼanya, nʼagbanyeghị na ha na-eso chi ndị ọzọ na-enwekwa mmasị dị ukwuu nʼachịcha nsọ e ji mkpụrụ osisi a mịkpọrọ amịkpọ mee.” 
\p  
\v 2 Nʼihi ya, eweere m ego ọlaọcha dị iri na ise, na otu ntụju ọka homa, na ọka balị zụta ya.  
\v 3 Mgbe ahụ agwara m ya, “Mụ na gị ga-ebi ọtụtụ ụbọchị, ị gaghị agbakwa akwụna, maọbụ nwee nwoke ọbụla gị na ya ga-enwe mmekọ, otu a ka m ga-emekwa nʼebe ị nọ.” 
\p  
\v 4 Nke a na-egosi na Izrel ga-anọ ogologo mgbe na-enweghị eze maọbụ onye ọchịchị. Ọ gaghị enwe ịchụ aja maọbụ nkume nsọ maọbụ efọọd maọbụ arụsị ezinaụlọ.  
\v 5 Mgbe nke a gasịrị, Izrel ga-alọghachi, chọọ \nd Onyenwe anyị\nd* bụ Chineke ha, na Devid bụ eze ha. Ha ga-ewere ịma jijiji bịakwute \nd Onyenwe anyị\nd*, bịaghachitekwa ngọzị ya nʼoge ikpeazụ a. 
\c 4  
\s1 Okwu Onyenwe anyị megide Izrel 
\q1  
\v 1 Nụrụnụ okwu \nd Onyenwe anyị\nd* unu ndị Izrel, 
\q2 nʼihi na \nd Onyenwe anyị\nd* nwere ebubo\f + \fr 4:1 \ft Maọbụ, \fqa Onyenwe anyị akpọọla unu ikpe\f* 
\q2 megide unu ndị bi nʼala a. 
\q1 “Nʼihi na ọ dịghị ikwesi ntụkwasị obi, ọ dịghị ịhụnanya, 
\q2 ọ dịghịkwa ihe ọmụma banyere Chineke nʼala a niile.\f + \fr 4:1 \ft Ịma ihe banyere Chineke adịghị nʼuche unu\f* 
\q1  
\v 2 Ọ bụ naanị ịbụ ọnụ,\f + \fr 4:2 \ft Maọbụ, \fqa ịṅụ iyi\f* ịgha ụgha na igbu mmadụ, 
\q2 izu ohi na ịkwa iko. 
\q1 Ọgbaaghara dị nʼebe niile, 
\q2 ya na ogbugbu mmadụ na-esepụghị aka. 
\q1  
\v 3 Nke a mere ala jiri nọrọ nʼiru ụjụ, 
\q2 ndị niile nọ na ya na-atakwa ahụ,\f + \fr 4:3 \ft Maọbụ, \fqa na-anwụkwa anwụ\f* 
\q1 ma anụ ọhịa, ma nnụnụ nke igwe, 
\q2 ọ bụladị azụ dị nʼosimiri ka a na-ekpochapụ. 
\b  
\q1  
\v 4 “Ma otu ọ dị, ka onye ọbụla ghara ise okwu, 
\q2 ka onye ọbụla ghara ibo ibe ya ebubo. 
\q1 Nʼihi na ndị gị dịka 
\q2 ndị na-eseso onye nchụaja okwu. 
\q1  
\v 5 Ị na-asọ ngọngọ ehihie na abalị, 
\q2 ndị amụma na-esokwa gị sụọ ngọngọ. 
\q1 Nʼihi ya aga m ala nne gị nʼiyi 
\q2  
\v 6 ndị m ka a na-ala nʼiyi nʼihi na ha amaghị ihe. 
\b  
\q1 “Ebe ọ bụ na ị jụrụ ihe ọmụma, 
\q2 aga m ajụkwa gị dị ka onye nchụaja m; 
\q1 ebe ọ bụ na ị gbakụtara iwu Chineke gị azụ 
\q2 mụ onwe m ga-agbakụtakwa ụmụ gị azụ. 
\q1  
\v 7 Ka ha\f + \fr 4:7 \ft Ya bụ, ndị nchụaja\f* na-abawanye nʼọnụọgụgụ, 
\q2 otu a ka ha si na-aga nʼihu na-emehie megide m, 
\q2 ha gbanwere Chineke ha dị ebube nʼihi ihe na-eweta ihere.\f + \fr 4:7 \ft Akwụkwọ Masori na-ede, nsọpụrụ ha ka m gbanwere ka ọ ghọọ ihere\f* 
\q1  
\v 8 Ha na-eriju afọ site na mmehie ndị m. 
\q2 Ha ji anya ukwu na-achọ ka ha na-emehie na-aga nʼihu. 
\q1  
\v 9 Ọ ga-abụkwa ka ndị nchụaja dị, otu a ka ndị obodo dịkwa. 
\q2 Nʼihi ya, aga m enye ha ntaramahụhụ 
\q2 ma kwụghachi ha ụgwọ nʼihi omume ha niile. 
\b  
\q1  
\v 10 “Ha ga na-eri ihe ma afọ agaghị eju ha. 
\q2 Ha ga-ebi ndụ akwụna ma ha agaghị amụba, 
\q1 nʼihi na ha ajụla \nd Onyenwe anyị,\nd* 
\q2 were onwe ha nyefee  
\v 11 nʼaka ịgba akwụna, 
\q1 na mmanya ochie na mmanya ọhụrụ, 
\q2 nke na-ewepụ mmụọ nghọta. 
\q1  
\v 12 Ndị nke m na-ajụ osisi apịrị apị ase ihe ha ga-eme, 
\q2 na-anata ọsịsa site na mkpara osisi onye ọ na-ajụ ase. 
\q1 Mmụọ nke ịgba akwụna na-eme ka ha kpafuo; 
\q2 ha gbara akwụna ma hapụ Chineke ha. 
\q1  
\v 13 Ha na-achụ aja nʼelu ugwu niile, 
\q2 na-esure onyinye nsure ọkụ nʼelu ugwu nta niile, 
\q1 na nʼokpuru osisi ook, osisi pọpla na osisi terebint, 
\q2 ebe ndo ya dị ezi mma. 
\q1 Nʼihi nke a ka ụmụ unu ndị inyom na-agba akwụna, 
\q2 ndị nwunye ụmụ unu na-akwa iko. 
\b  
\q1  
\v 14 “Agaghị m ata ụmụ unu ndị inyom ahụhụ, 
\q2 mgbe ha na-agba akwụna, 
\q1 maọbụ taa ndị nwunye ụmụ nwoke unu ahụhụ 
\q2 mgbe ha na-akwa iko, 
\q1 nʼihi na ndị ikom unu nʼonwe ha na-ejekwuru ndị akwụna, 
\q2 ha na ndị akwụna ụlọ arụsị na-achụkọkwa aja, 
\q2 ma ndị a na-enweghị nghọta ga-ala nʼiyi. 
\b  
\q1  
\v 15 “Ọ bụ ezie na unu bụ ndị na-akwa iko unu bụ Izrel, 
\q2 ma ka ikpe gharakwa ịma Juda. 
\b  
\q1 “Unu agakwala Gilgal, 
\q2 unu agakwala ruo Bet-Aven, 
\q2 unu aṅụkwala iyi sị, ‘Dịka \nd Onyenwe anyị\nd* na-adị ndụ.’ 
\q1  
\v 16 Ndị Izrel dị isiike 
\q2 dịka nwaagbọghọ ehi dị isiike. 
\q1 \nd Onyenwe anyị\nd* ọ ga-esi aṅaa zụọ ha 
\q2 dịka ụmụ atụrụ nʼebe ịta nri sara mbara? 
\q1  
\v 17 Ifrem na arụsị agbaala ndụ 
\q2 hapụ ya ka ọ nọọrọ onwe ya. 
\q1  
\v 18 Ọ bụladị mgbe mmanya ha gwụrụ, 
\q2 ha na-aga nʼihu na-agba akwụna; 
\q2 ha hụrụ ihere nʼanya nke ukwuu karịa otuto ha. 
\q1  
\v 19 Ifufe ga-ebupụ ha, 
\q2 aja ha na-achụ ga-ewetara ha ihere. 
\c 5  
\s1 Ikpe ọmụma megide Izrel 
\q1  
\v 1 “Nụrụnụ nke a, unu ndị nchụaja! 
\q2 Geenụ ntị, unu ụlọ Izrel! 
\q1 Geenụ ntị, unu ndị ezinaụlọ eze. 
\q2 Nʼihi na ọ bụ unu ka ikpe ahụ gbasara. 
\q1 Nʼihi na unu abụrụla ihe ị maa nʼọnya na Mizpa, 
\q2 na ụgbụ agbasara nʼelu Taboa. 
\q1  
\v 2 Ndị nnupu isi ahụ abamiela ime nʼigbu mmadụ, 
\q2 aga m ata ha niile ahụhụ. 
\q1  
\v 3 Amaara m ihe niile gbasara Ifrem, 
\q2 ọ dịkwaghị ihe zoro ezo banyere Izrel nʼebe m nọ. 
\q1 Gị Ifrem, ugbu a ị gbawala akwụna; 
\q2 gị Izrel, emerụọkwala gị. 
\b  
\q1  
\v 4 “Omume ha agaghị ekwe 
\q2 ka ha laghachikwute Chineke ha, 
\q1 nʼihi na mmụọ nke ịkwa iko ewerela ute biri nʼime ha, 
\q2 ha amaghịkwa \nd Onyenwe anyị\nd*. 
\q1  
\v 5 Mpako niile nke Izrel na-agba ama megide ha, 
\q2 Ọ bụladị Izrel na Ifrem na-asọ ngọngọ nʼime mmehie ha, 
\q2 Juda, nʼonwe ya, soo ha na-asọ ngọngọ. 
\q1  
\v 6 Mgbe ha ga-eji igwe ewu na atụrụ ha na igwe ehi ha, 
\q2 gaa ịchọ \nd Onyenwe anyị\nd*, 
\q1 ha agaghị achọta ya. 
\q2 Nʼihi na o sitela nʼebe ha nọ wezuga onwe ya. 
\q1  
\v 7 Ha bụ ndị na-ekwesighị ntụkwasị obi nye \nd Onyenwe anyị\nd*. 
\q2 Ha mụrụ ụmụ a kwatara nʼiko. 
\q1 Ugbu a, mmemme ọnwa ọhụrụ ha 
\q2 ga-eripịa ha na ala ubi ha. 
\b  
\q1  
\v 8 “Fụọ opi ike na Gibea, 
\q2 fụkwaa mpi anụ na Rema. 
\q1 Tie mkpu agha na Bet-Aven. 
\q2 Lee anya nʼazụ gị, Benjamin. 
\q1  
\v 9 A ga-ebibi Ifrem kpamkpam 
\q2 nʼụbọchị ahụ m ga-ata ha ahụhụ.\f + \fr 5:9 \ft Maọbụ, \fqa nʼụbọchị ntaramahụhụ\f* 
\q1 Nʼetiti ebo nke Izrel niile, 
\q2 ka m na-ekwusa ka amara na ọ bụ okwu kwesiri ntụkwasị obi.\f + \fr 5:9 \ft Ya bụ, okwu nʼaghaghị imezu\f* 
\q1  
\v 10 Ndị ndu Juda adịla ka ndị ahụ 
\q2 na-ewezuga oke ala, 
\q1 aga m awụkwasị ha iwe m 
\q2 dịka uju mmiri ozuzo. 
\q1  
\v 11 Ifrem bụ onye a na-emegbu emegbu, 
\q2 onye e ji ike na-azọpịa, 
\q2 nʼihi na ọ kpacha anya na-achụso ihe efu. 
\q1  
\v 12 Adị m ka nla nye Ifrem, 
\q2 dịkwa ka ihe na-eweta ire ure dịịrị ndị Juda. 
\b  
\q1  
\v 13 “Mgbe Ifrem hụrụ ụdị ọrịa ọ na-arịa, 
\q2 Juda ahụkwa ọnya dị ya nʼahụ, 
\q1 mgbe ahụ Ifrem gakwuru ndị Asịrịa, 
\q2 ma zigakwara eze ukwu ahụ ozi. 
\q1 Ma ọ pụghị ịgwọ gị, 
\q2 maọbụ gwọọ ọnya gị niile. 
\q1  
\v 14 Nʼihi na-aga m adị ka ọdụm nye Ifrem 
\q2 dịkwa ka nwa ọdụm nye Juda. 
\q1 Aga m adọkasị anụ ahụ ha ma hapụ ha pụọ. 
\q2 Aga m ebupụ ha pụọ, na-enweghị onye ga-abịa ịzọpụta ha. 
\q1  
\v 15 Aga m alaghachi azụ nʼọnọdụ m, 
\q2 ruo mgbe ha kweere na ikpe mara ha, 
\q2 ma chọọ ihu m; 
\q1 nʼọnọdụ mmekpa ahụ ha, 
\q2 ha ga-achọsi m ike.” 
\c 6  
\s1 Nnọgide na nnupu isi Izrel 
\q1  
\v 1 “Bịanụ ka anyị laghachikwuru \nd Onyenwe anyị\nd*. 
\q1 Ya onwe ya adọkaala anyị, 
\q2 ọ ga-agwọkwa anyị; 
\q1 o tipụla anyị ọnya, 
\q2 ma ọ ga ekechikwa ọnya anyị. 
\q1  
\v 2 Ọ ga-eme ka anyị dịkwa ndụ ọzọ mgbe ụbọchị abụọ gasịrị. 
\q2 Nʼụbọchị nke atọ, ọ ga-eme ka anyị bilie guzokwa nʼụkwụ anyị, 
\q2 meekwa ka anyị dịrị ndụ nʼihu ya. 
\q1  
\v 3 Ka anyị mara \nd Onyenwe anyị\nd*; 
\q2 ka anyị gbalịsie ike ịmata ya. 
\q1 Ọ bụladị dịka anyanwụ na-awalite, 
\q2 nʼezie, ọ ga-apụta ìhè dịka chi ọbụbọ, 
\q1 ọ ga-abịakwute anyị dịka mmiri ozuzo, 
\q2 dịka mmiri na-ezosa ala nʼoge udu mmiri.” 
\b  
\q1  
\v 4 “Gịnị ka m ga-eji gị mee, O Ifrem? 
\q2 Gịnị ka m ga-eji gị mee, O Juda? 
\q1 Ịhụnanya gị dịka igwe ojii nke ụtụtụ, 
\q2 dịka igirigi na-anọ naanị nwa mgbe nta. 
\q1  
\v 5 Nke mere m ji si nʼọnụ ndị amụma gbukasịa ha. 
\q2 Ejirila m okwu ọnụ m gbuo ha, 
\q2 ikpe ọmụma m na-achawapụta dịka ìhè. 
\q1  
\v 6 Nʼihi na ana m achọ ebere, ọ bụghị aja, 
\q2 ịmata Chineke kama aja nsure ọkụ niile. 
\q1  
\v 7 Ma dịka Adam, ha emebiela ọgbụgba ndụ m; 
\q2 nʼebe ahụ ka ha nọ gosi ekwesighị ntụkwasị obi ha. 
\q1  
\v 8 Gilead bụ obodo nke ndị na-eme ajọ ihe, 
\q2 nke eji nzọ ụkwụ ọbara zọtọsịa. 
\q1  
\v 9 Dịka ndị na-apụnara mmadụ ihe na-ezo na-eche onye ga-agafe, 
\q2 otu a ka ndị nchụaja 
\q1 si egbu ndị mmadụ nʼụzọ Shekem, 
\q2 leenụ oke ajọ omume ihere dị otu a. 
\q1  
\v 10 Nʼezie, ahụla m ihe jọgburu onwe ya nʼime Izrel. 
\q2 Nʼebe ahụ ka Ifrem nọ na-agba akwụna, 
\q2 emerụọkwala Izrel. 
\b  
\q1  
\v 11 “Ma nye gị onwe gị, Juda, 
\q2 owuwe ihe ubi nọ na-eche gị. 
\b  
\q1 “Mgbe ọbụla m ga-eweghachi akụnụba ndị m, 
\c 7  
\q2  
\v 1 mgbe m chọrọ ịgwọ Izrel, 
\q1 mmehie Ifrem na-apụta ihe, 
\q2 a na-ekpughekwa arụ a na-eme na Sameria. 
\q1 Ha na-aghọ aghụghọ, 
\q2 ndị ohi na-akụwakwa ụlọ ndị mmadụ, 
\q2 ndị na-apụnara mmadụ ihe nọ nʼokporoụzọ. 
\q1  
\v 2 Ọ dịghị onye bi nʼime ha maara 
\q2 na m na-echeta mmehie ha niile. 
\q1 Ugbu a, mmehie ha agbaala ha gburugburu. 
\q2 Ana m ahụkwa ha niile. 
\b  
\q1  
\v 3 “Eze ha na-aṅụrị ọṅụ nʼihe ọjọọ ha; 
\q2 ụmụ eze na-achị ọchị nʼihi ụgha ha. 
\q1  
\v 4 Ha niile bụ ndị na-akwa iko; 
\q2 ha dị ka ite ọkụ ighe achịcha e mere ka ọ dị ọkụ, 
\q1 nke onye na-eghe achịcha na-adịghị akwanye nkụ, 
\q2 site na mgbe e bidoro ịgwakọ ụtụ ọka ahụ tutu ruo mgbe o koliri. 
\q1  
\v 5 Nʼụbọchị mmemme nke eze anyị, 
\q2 ụmụ eze bụ ndị akpalịrị site na-ịṅụbiga mmanya oke, 
\q2 ya na ndị na-akwa emo jikọtara aka. 
\q1  
\v 6 Obi ha na-enwu ọkụ dịka ihe ighe achịcha, 
\q2 ha ji izu nzuzo na-abịakwute ya. 
\q1 Nʼabalị niile iwe ha na-ere nwayọọ ka ọkụ na-anyụ anyụ, 
\q2 nʼụtụtụ ihe ha gbatara nʼizu na-enwu dịka ọkụ. 
\q1  
\v 7 Ha niile dị ọkụ dịka ite ighe achịcha dị ọkụ. 
\q2 Ha na-eripịa ndị eze ha. 
\q1 Ndị eze ha niile na-ada, 
\q2 ma o nweghị onye nʼime ha na-akpọku m. 
\b  
\q1  
\v 8 “Ifrem na-agwakọta onwe ya nʼetiti ndị mba ọzọ. 
\q2 Ifrem dịkwa ka mbadamba achịcha a na-atụgharịghị atụgharị. 
\q1  
\v 9 Ndị mba ọzọ na-eripịa ike ha, 
\q2 ma ha adịghị aghọta ya. 
\q1 Isi awọ apụtala ha nʼisi, 
\q2 ma ya onwe ya amaghị na o si otu a dịrị. 
\q1  
\v 10 Ịnya isi Izrel na-agba akaebe megide ya 
\q2 ma nʼagbanyeghị ihe ndị a 
\q1 ọ naghị alọghachikwute \nd Onyenwe anyị\nd* bụ Chineke ya, 
\q2 maọbụ chọọ ya. 
\b  
\q1  
\v 11 “Ifrem dịka nduru 
\q2 nke na-enweghị uche, nke onye ọbụla na-eduhie, 
\q1 ugbu a, ọ na-akpọku Ijipt, 
\q2 ma na-agbakwurukwa Asịrịa. 
\q1  
\v 12 Ma mgbe ha na-agbagharị, aga m ewere ụgbụ m jide ha, 
\q2 dọda ha nʼala dịka nnụnụ e jidere na mbara eluigwe. 
\q1 Aga m enye ha ahụhụ 
\q2 nʼihi njehie ha niile. 
\q1  
\v 13 Ahụhụ na-adịrị ha, 
\q2 nʼihi na ha ajụla m. 
\q1 Ha na-ala nʼiyi 
\q2 nʼihi na ha enupula isi ha megide m. 
\q1 Achọrọ m ka m gbapụta ha, 
\q2 ma ha na-agha ụgha megide m. 
\q1  
\v 14 Ha ejighịkwa obi ha akpọku m, 
\q2 kama ha na-atụrụ onwe ha nʼelu ihe ndina ha, na-eti mkpu akwa. 
\q1 Mgbe ha na-arịọ arịrịọ maka mkpụrụ ubi na mmanya, 
\q2 ha na-egbukasị onwe ha ahụ, 
\q2 na-ewezugakwa onwe ha site nʼebe m nọ. 
\q1  
\v 15 Enyerela m ha aka, mee ka ha dị ike, 
\q2 ma ha atụgharịala gbaa izu imegide m. 
\q1  
\v 16 Ha adịghị ele anya enyemaka nʼaka Onye kachasị ihe niile elu. 
\q2 Ha dịka ụta rọgọrọ arọgọ, nke àkụ ya na-adịghị agbata ihe ọbụla. 
\q1 Ndị ndu ha ga-ada site na mma agha, 
\q2 nʼihi okwu ọjọọ si ha nʼọnụ na-apụta. 
\q1 Nʼihi nke a, a ga-eji ha mee ihe ọchị 
\q2 nʼala Ijipt. 
\c 8  
\s1 Ụgwọ ọrụ mmehie 
\q1  
\v 1 “Tinye opi ike nʼọnụ gị! 
\q2 Nʼihi na ugo nʼefefe nʼelu ụlọ \nd Onyenwe anyị\nd*, 
\q1 nʼihi na ha emebiela ọgbụgba ndụ m, 
\q2 nupu isi megide iwu m. 
\q1  
\v 2 Ugbu a ndị Izrel na-etiku m mkpu akwa, 
\q2 ‘Chineke anyị, anyị bụ Izrel maara gị.’ 
\q1  
\v 3 Ma Izrel ajụla ihe dị mma. 
\q2 Ugbu a, ndị iro ga-achụ ya ọsọ. 
\q1  
\v 4 Ha meere onwe ha ndị eze, ma ha ajụtaghị m ase; 
\q2 ha na-achọrọkwa ndị ọchịchị,\f + \fr 8:4 \ft Ya bụ, ụmụ eze\f* ma ghara ịjụta ase nʼaka m. 
\q1 Ọlaọcha na ọlaedo ha 
\q2 ka ha ji na-akpụrụ onwe ha arụsị, 
\q2 nke ha ji ebibi onwe ha. 
\q1  
\v 5 Ajụla m arụsị nwa ehi a ị kpụrụ, O Sameria. 
\q2 Nʼihi na ọnụma m na-ere ọkụ megide ha. 
\q1 Ruo olee mgbe ka ha ga-anọ bụrụ ndị na-enweghị ike ịdị ọcha? 
\q2  
\v 6 Ọ bụ nʼIzrel ka ha si. 
\q1 Ọ bụ onye na-akpụ ụzụ kpụrụ ya; 
\q2 ọ bụghị Chineke. 
\q1 A ga-akụrisikwa 
\q2 nwa ehi Sameria ahụ. 
\b  
\q1  
\v 7 “Ha akụọla ifufe, 
\q2 ha ga-aghọtakwa oke ifufe. 
\q1 Osisi ọka ha na-eguzo 
\q2 na-enweghị okpo ọka ọbụla. 
\q1 A sịkwarị na ọ mịrị mkpụrụ, 
\q2 ndị mba ọzọ ga-atapịa ya. 
\q1  
\v 8 Elodala Izrel! 
\q2 Lee, ha nọ ugbu a nʼetiti ndị mba ọzọ 
\q2 dịka mkpọkọrọ ite. 
\q1  
\v 9 Nʼihi na ha ejeela Asịrịa 
\q2 dịka ịnyịnya ibu ọhịa na-awagharị naanị ya. 
\q2 Ifrem ewerela onwe ya resi ndị enyi ya. 
\q1  
\v 10 Ọ bụ ezie na ha ewerela onwe ha resi ọtụtụ mba dị iche iche, 
\q2 aga m achịkọta ha. 
\q1 Ha ga-atakwa ahụ 
\q2 nʼihi ọnọdụ mmegbu nke eze na ndịisi ga-achị ha. 
\b  
\q1  
\v 11 “Nʼihi na Ifrem ewuola ọtụtụ ebe nchụaja maka ịchụ aja mmehie, 
\q2 ebe nchụaja ndị a abụrụla ebe a na-eme mmehie. 
\q1  
\v 12 E depụtaara m ha ọtụtụ ihe banyere iwu m, 
\q2 ma ha were ya dịka ihe e si na mba ọzọ webata. 
\q1  
\v 13 Ha na-achụ aja dịka onyinye nye m, 
\q2 ha na-erikwa anụ ndị ahụ ha jiri chụọ aja, 
\q2 ma na \nd Onyenwe anyị\nd* enweghị mmasị nʼebe aja ha dị. 
\q1 Ugbu a, ọ ga-echeta ajọ omume ha, 
\q2 nye ha ntaramahụhụ nʼihi mmehie niile ha, 
\q2 ha ga-alaghachi nʼIjipt. 
\q1  
\v 14 Izrel echezọọla Onye kere ha 
\q2 ma wukwaa obi ndị eze dị iche iche. 
\q2 Juda ewukwaala obodo dị iche iche e wusiri ike. 
\q1 Nʼihi ya, aga m ezite ọkụ nʼobodo ha niile, 
\q2 ọkụ ga-erepịa obodo ha niile e wusiri ike.” 
\c 9  
\s1 Ntaramahụhụ dịrị Izrel 
\q1  
\v 1 Aṅụrịla ọṅụ, gị Izrel, 
\q2 ka obi ghara ịtọkwa gị ụtọ dịka ọ na-atọ ndị mba ọzọ, 
\q1 nʼihi na ị jụla Chineke gị, bido ịgba akwụna 
\q2 i hụrụ ụgwọ ọrụ ịkwa iko nʼanya 
\q2 nʼelu ebe ịzọcha ọka niile. 
\q1  
\v 2 Ebe ịzọcha mkpụrụ ọka na ebe ịzọcha mkpụrụ vaịnị agaghị azụ ha nri, 
\q2 mmanya ọhụrụ ga-agharịpụ ha. 
\q1  
\v 3 Ha agaghị anọgidekwa nʼala \nd Onyenwe anyị\nd*, 
\q2 ma Ifrem ga-alaghachi nʼala Ijipt 
\q2 nọdụ nʼAsịrịa rie nri rụrụ arụ. 
\q1  
\v 4 Ha agaghị awụsa ihe ọṅụṅụ dịka aja nye \nd Onyenwe anyị\nd*, 
\q2 nʼihi na ọdịghị aja ha ga-achụ ga-atọ ya ụtọ. 
\q1 Aja ndị a ga-adị ha ka nri nke ndị na-eru ụjụ si dị. 
\q2 Onye ọbụla riri nri ndị a ga-abụ onye na-adịghị ọcha. 
\q1 Nri ndị a ga-adịrị naanị ha onwe ha, 
\q2 ha agaghị ewebata ya nʼụlọnsọ ukwu \nd Onyenwe anyị\nd*. 
\b  
\q1  
\v 5 Gịnị ọzọ ka unu ga-eme nʼụbọchị mmemme unu ndị ahụ a kara aka, 
\q2 ma nʼụbọchị mmemme nke \nd Onyenwe anyị\nd*? 
\q1  
\v 6 A sịkwa na ha agbanarị mbibi, 
\q2 ndị Ijipt ga-achịkọta ha. 
\q2 Ndị Memfis ga-elikwa ha. 
\q1 Akụnụba nke ọlaọcha ha ka uke ga-ewekọrọ, 
\q2 ogwu na uke ga-etokwa nʼime ebe obibi ha niile, 
\q1  
\v 7 Ụbọchị niile nke ntaramahụhụ\f + \fr 9:7 \ft Maọbụ, \fqa nleta\f* na-abịa, 
\q2 Ụbọchị ngụkọta ihe abịala nso. 
\q2 Ka Izrel mara nke a. 
\q1 Nʼihi na ịba ụba nke mmehie unu adịla ukwuu, 
\q2 nʼihi na ịkpọ asị unu akarịala, 
\q1 unu na-agụ onye amụma dịka onye nzuzu, 
\q2 na-agụkwa onye nwee Mmụọ nke Chineke dịka onye na-ayị ara. 
\q1  
\v 8 Ma onye amụma bụ onye nche Chineke, 
\q2 na-eche Ifrem nche, 
\q1 ma igbudu nke ọnya jupụtara nʼụzọ ya niile, 
\q2 ịkpọ asị dịkwa nʼime nʼụlọnsọ Chineke ya. 
\q1  
\v 9 Ha emerụọla onwe ha ebe ọ dị ukwuu, 
\q2 dịka ọ dị nʼụbọchị Gibea. 
\q1 Ọ ga-echeta njehie ha. 
\q2 Ọ ga-enye ha ntaramahụhụ nʼihi mmehie ha niile. 
\b  
\q1  
\v 10 “Mgbe m chọtara Izrel, 
\q2 ọ dị ka m chọtara mkpụrụ grepu nʼọzara; 
\q1 mgbe m hụrụ nna nna unu ha, 
\q2 ọ dị ka ihu mkpụrụ bụ ụzọ chaa nʼelu osisi fiig. 
\q1 Ma mgbe ha bịaruru na Baal-Peoa, 
\q2 ha doro onwe ha nsọ nyefee nʼaka arụsị ahụ na-eweta ihere, 
\q2 si otu a ghọọ ndị rụrụ arụ, dịka ihe ndị ahụ ha hụrụ nʼanya si bụrụ ihe rụrụ arụ. 
\q1  
\v 11 Nsọpụrụ Ifrem nwere ga-efefu dị ka nnụnụ, 
\q2 nʼihi na ọmụmụ nwa agaghị adị, a gaghị atụkwa ime, agaghị adịkwa ime. 
\q1  
\v 12 A sịkwa na ha azụlite ụmụ ha, 
\q2 aghaghị m ime ka ha nwụọ. 
\q1 Ahụhụ ga-adịrị ha, 
\q2 mgbe m si nʼebe ha nọ wezuga onwe m. 
\q1  
\v 13 Ahụla m na Ifrem yiri Taịa, 
\q2 bụ ihe akụnyere nʼala mara mma. 
\q1 Ma Ifrem ga-eji aka ya 
\q2 kpọpụta ụmụ ya nye ndị ga-egbu ha.” 
\b  
\q1  
\v 14 Biko, \nd Onyenwe anyị\nd* nye ha. 
\q2 Gịnị ka i kwesiri inye ha? 
\q1 Nye ha akpanwa nke nwa na-adịghị anọgide nʼime ya, 
\q2 na ara nke mmiri ara na-adịghị. 
\b  
\q1  
\v 15 “Ihe ọjọọ ha niile bidoro na Gilgal, 
\q2 akpọrọ m ha asị nʼebe ahụ. 
\q1 Nʼihi omume mmehie ha niile, 
\q2 aghaghị m isite nʼụlọ m chụpụ ha. 
\q1 Agaghị m ahụkwa ha nʼanya ọzọ, 
\q2 ndị ndu ha niile bụ ndị nnupu isi. 
\q1  
\v 16 Etigbuola Ifrem, 
\q2 mgbọrọgwụ ha akpọnwụọla, 
\q2 ha agaghị amịkwa mkpụrụ. 
\q1 A sịkwarị na ha amụọ ụmụ, 
\q2 aga m egbu ụmụ ha niile, ndị ha hụrụ nʼanya.” 
\b  
\q1  
\v 17 Chineke m ga-ajụ ha, 
\q2 nʼihi na ha adịghị ege ya ntị maọbụ rube isi. 
\q2 Ha ga-aghọ ndị na-awagharị awagharị na-enweghị ụlọ, nʼetiti mba niile. 
\b  
\c 10  
\q1  
\v 1 Izrel bụ osisi vaịnị dị mma, 
\q2 nke na-amịta mkpụrụ nke ukwuu. 
\q1 Dịka mkpụrụ ya na-aba ụba, 
\q2 otu a ka o si amụba ebe ịchụ aja ya. 
\q1 Dịka ala ya na-abawanyekwa ụba 
\q2 otu a ka o si edoziri onwe ya nkume dị nsọ. 
\q1  
\v 2 Obi ha dị aghụghọ, 
\q2 ma ugbu a, ha ga-ata ahụhụ maka ikpe ọmụma ha. 
\q1 Onyenwe anyị ga-akwatu ebe nchụaja ha, 
\q2 ma mebikwaa ogidi nkume nsọ ha niile. 
\b  
\q1  
\v 3 Ma ugbu a, ha ga-asị, 
\q2 “Anyị enweghị eze, 
\q1 nʼihi na anyị anaghị atụ \nd Onyenwe anyị\nd* egwu, 
\q2 ma olee ihe eze nwere ike ị mere anyị?” 
\q1  
\v 4 Ha na-ekwu okwu na-abaghị uru, 
\q2 were ịṅụ iyi 
\q2 na-agbakwa ndụ, 
\q1 ya mere ikpe ikpe jiri jupụta nʼebe niile, 
\q2 dịka ahịhịa ọjọọ nʼubi. 
\q1  
\v 5 Ndị bi na Sameria ga-atụ ụjọ 
\q2 nʼihi chi nke nwa ehi a kpụrụ akpụ dị na Bet-Aven.\f + \fr 10:5 \fq Bet-Aven \ft pụtara \fqa ụlọ ihe ajọ \ft aha ịkwa emo Betel; Betel nke pụtara \fqa ụlọ Chineke\f* 
\q1 Ndị ya ga-eruru ya ụjụ, 
\q2 otu a kwa ka ndị nchụaja ya 
\q1 rụrụ arụ ga-esi ruoru ya ụjụ, 
\q2 maka ebube nke a napụrụ ya. 
\q1  
\v 6 Ha ga-eburu ha gaa Asịrịa, 
\q2 dịka onyinye ịnata ihuọma a ga-enye eze ukwu ahụ. 
\q1 A ga-emenye Ifrem ihere nʼihu, 
\q2 Izrel ga-ekpudokwa ihu nʼala maka mmekọrịta ya na ndị mba ọzọ. 
\q1  
\v 7 A ga-ala eze Sameria nʼiyi 
\q2 dịka irighiri osisi nʼelu mmiri niile, 
\q1  
\v 8 a ga-ebibicha ebe niile dị elu nke ihe ọjọọ, bụ Aven,\f + \fr 10:8 \fq Aven, \ft na-ekwu banyere Bet-Aven aha ịkwa emo na-akpọ \fqa Betel\f* 
\q2 ọ bụ ya bụ mmehie ndị Izrel, 
\q1 ogwu na uke ga-etolitekwa, 
\q2 nʼebe nchụaja ha. 
\q1 Mgbe ahụ ha ga-asị, ugwu ukwu niile, “Kpuchite anyị!” 
\q2 Sịkwa ugwu nta niile, “Dakwasị anyị!” 
\b  
\q1  
\v 9 “Site nʼụbọchị nke Gibea, gị Izrel nọ na mmehie, 
\q2 i nwebeghị ike site na mmehie ndị a wezuga onwe gị. 
\q1 Ọ bụ na agha agaghị eri ha 
\q2 bụ ndị na-eme ajọọ omume na Gibea? 
\q1  
\v 10 Aga m abịa buso ndị mmehie a agha, nye ya ahụhụ; 
\q2 mba ndị ọzọ ga-ebilite megide ha, 
\q2 taa ha ahụhụ nʼihi ajọ omume abụọ ha. 
\q1  
\v 11 Ifrem bụ nne ehi a zụrụ azụ 
\q2 nke hụrụ ịzọcha ọka nʼanya, 
\q1 nʼihi ya, M ga-ekonye ịyagba nʼolu 
\q2 nʼolu ọma ya ahụ. 
\q1 Aga m agba Ifrem dịka ịnyịnya, 
\q2 Juda aghaghị ịkọ ala ubi 
\q2 Jekọb ga-akọze ala nye onwe ya. 
\q1  
\v 12 Ya mere, ghaanụ mkpụrụ ezi omume maka onwe unu, 
\q2 unu ga-aghọtakwa mkpụrụ ịhụnanya. 
\q1 Kọgharịakwanụ obi unu siri ike, 
\q2 nʼihi na ugbu a bụ oge ịchọ \nd Onyenwe anyị\nd*, 
\q1 tutu ruo mgbe ọ bịara 
\q2 wụkwasị unu mmiri ozuzo dịka ezi omume. 
\q1  
\v 13 Ma unu akụọla mkpụrụ ajọ omume; 
\q2 unu aghọtakwala ihe ọjọọ dịka ihe ubi. 
\q2 Unu eriela mkpụrụ osisi ụgha. 
\q1 Nʼihi na unu atụkwasịla obi unu nʼịdị ike nke onwe unu, 
\q2 na nʼịdị ọtụtụ nke ndị bụ dike nʼagha unu. 
\q1  
\v 14 Nʼihi ya, ụzụ nke ibu agha aghaghị ibili nʼetiti unu, 
\q2 ebe unu niile e wusiri ike ga-ada. 
\q1 Ọ ga-ada dịka Shalman si bibie Bet Abel nʼụbọchị agha, 
\q2 mgbe a tụpịara ndị bụ nne na ụmụ ha. 
\q1  
\v 15 Ọ bụ ihe dị otu a ga-adakwasị gị, Betel, 
\q2 nʼihi na ajọ omume gị dị ukwuu. 
\q1 Mgbe chi ụbọchị ahụ bọrọ, 
\q2 a ga-ala eze Izrel nʼiyi kpamkpam. 
\c 11  
\s1 Ịhụnanya Chineke nye Izrel 
\q1  
\v 1 “Mgbe Izrel bụ nwantakịrị, ahụrụ m ya nʼanya, 
\q2 ọ bụkwa site nʼIjipt ka m kpọpụtara nwa m. 
\q1  
\v 2 Ma dịka m na-akpọ ha, 
\q2 otu a ka ha na-aga nʼebe dị anya site nʼebe m nọ. 
\q1 Ha chụrụ Baal aja, 
\q2 surekwa aja ihe nsure ọkụ na-esi isi ụtọ nye arụsị dị iche iche. 
\q1  
\v 3 Ọ bụ mụ onwe m kuziiri Ifrem otu e si aga ije, 
\q2 ejidere m ha nʼaka m abụọ, 
\q1 ma ha amaghị 
\q2 na ọ bụ mụ onwe m gwọrọ ya. 
\q1  
\v 4 Eji m ụdọ nke mmadụ bụ ebere, 
\q2 na ịhụnanya duo ya. 
\q1 Adịrị m ha dịka onye nʼebuli 
\q2 ibu arọ site nʼolu ha, 
\q2 ehulatakwara m ala, were aka m tinye ha nri nʼọnụ. 
\b  
\q1  
\v 5 “Ọ bụ na ha agaghị alaghachi azụ nʼIjipt, 
\q2 Asịrịa ọ gaghị abụ eze ha, 
\q2 nʼihi na ha ajụla ịlọghachikwute m? 
\q1  
\v 6 Mma agha ga-efegharị nʼobodo ha niile, 
\q2 ọ ga-eripịa ndị nchụaja na-agba afa, 
\q2 ọ ga-eripịakwa nzube ọjọọ ha niile. 
\q1  
\v 7 Ndị m ekpebiela nʼobi ha ịhapụ m. 
\q2 Nʼagbanyeghị na ha na-akpọ m Chineke nke kachasị ihe niile elu, 
\q2 ma mụ onwe m agaghị ebuli ha elu nʼụzọ ọbụla. 
\b  
\q1  
\v 8 “M ga-esi aṅaa rara gị nye, gị Ifrem? 
\q2 M ga-esi aṅaa rara gị nye, gị Izrel? 
\q1 M ga-esi aṅaa mee gị ka ịdị ka Adma? 
\q2 M ga-esi aṅaa meso gị dịka Zeboiim? 
\q1 Obi m na-akwasị akwa ike nʼime m; 
\q2 ọ na-agụsị m agụụ ike inyere unu aka. 
\q1  
\v 9 Agaghị m emezu iwe ọkụ m 
\q2 maọbụ bibiekwa Ifrem ọzọ. 
\q1 Nʼihi na abụ m Chineke, abụghị m mmadụ. 
\q2 Abụ m Onye Nsọ na-ebi nʼetiti unu. 
\q2 Agaghị m emegidekwa obodo ha. 
\q1  
\v 10 Nʼihi na ha ga-agbaso \nd Onyenwe anyị\nd*. 
\q2 Ọ ga-agbọkwa ụja dịka ọdụm. 
\q1 Mgbe ọ gbọrọ ụja, 
\q2 ụmụ ya ga-eji ịma jijiji site nʼakụkụ ọdịda anyanwụ bịakwute ya. 
\q1  
\v 11 Dịka igwe nnụnụ 
\q2 ka ha ga-ama jijiji bịa site nʼIjipt, 
\q2 dịka nduru ka ha ga-efelata site nʼAsịrịa. 
\q1 Aga m eme ka ha biri nʼụlọ ha ọzọ,” 
\q2 otu a ka \nd Onyenwe anyị\nd* kwupụtara. 
\s1 Mmehie Izrel 
\q1  
\v 12 Ifrem e jirila okwu ụgha gbaa m gburugburu, 
\q2 ezinaụlọ Izrel e jirila aghụghọ na-emeso m omume, 
\q1 ma Juda nọsịrị ike nʼekweghị nchịkọta nʼebe Chineke nọ, 
\q2 ọbụladị megide Onye Nsọ ahụ nke kwesiri ntụkwasị obi. 
\c 12  
\q1  
\v 1 Akaọrụ Ifrem bụ naanị ịchụso ikuku, 
\q2 ọ na-achụso ikuku si nʼọwụwa anyanwụ bido nʼụtụtụ ruo nʼabalị. 
\q2 Otu a ka ha si eme ka ịgha ụgha, na ime ihe ike na-abawanye ụba. 
\q1 Ha na Asịrịa na-agbakwa ndụ, 
\q2 ha na-ebugakwa mmanụ nʼIjipt. 
\q1  
\v 2 \nd Onyenwe anyị\nd* na-akpọ Juda ikpe. 
\q2 Ọ ga-ata Jekọb\f + \fr 12:2 \fq Jekọb \ft nʼebe a bụ akpalaokwu nke pụtara \fqa onye aghụghọ \ft Maọbụ, \fqa onye na-aghọrị mmadụ\f* ahụhụ dịka ụzọ ya si dị, 
\q2 kwụghachikwa ya dịka omume ya si dị. 
\q1  
\v 3 Mgbe ọ nọ nʼafọ nne ya ka o jidere nwanne ya nwoke nʼikiri ụkwụ. 
\q2 Mgbe ọ ghọrọ dimkpa, ya na Chineke gbara mgba. 
\q1  
\v 4 E, ya na mmụọ ozi gbara mgba. 
\q2 Nʼoge ahụ, o jidesiri ya aka ike, kwaa akwa, rịọọ ngọzị site nʼaka ya. 
\q1 Ọ hụrụ ya na Betel, 
\q2 gwaakwa ya okwu, 
\q1  
\v 5 \nd Onyenwe anyị\nd* Chineke onye pụrụ ime ihe niile, 
\q2 \nd Onyenwe anyị\nd* bụ aha ya. 
\q1  
\v 6 Ịghaghị ịlọghachikwute Chineke gị, 
\q2 guzosie ike nʼịhụnanya na ikpe ziri ezi, 
\q2 na-elekwa anya Chineke gị mgbe niile. 
\b  
\q1  
\v 7 Onye ahịa na-eji ihe ọtụtụ aghụghọ na-erenye ndị mmadụ ahịa, 
\q2 ọ hụrụ imegbu emegbu nʼanya. 
\q1  
\v 8 Ifrem kwuru, 
\q2 “Abaala m ọgaranya! Abụrụla m onye nwere akụnụba dị ukwuu! 
\q1 Ọ bụ ezie na m bụ onye nwere akụ dị ukwuu, 
\q2 ma agaghị achọta njehie maọbụ mmehie ọbụla nʼime m.” 
\b  
\q1  
\v 9 “Abụ m \nd Onyenwe anyị\nd* na Chineke gị, 
\q2 onye si nʼIjipt kpọpụta unu. 
\q1 Aga m emekwa ka ị biri nʼụlọ ikwu ọzọ, 
\q2 dịka ọ dị nʼoge mmemme ndị ahụ niile a kara aka. 
\q1  
\v 10 A gwara m ndị amụma, 
\q2 ọ bụ m mere ka ha hụ ọhụ dị iche iche, 
\q2 sitekwa nʼọnụ ndị amụma tụọ ilu dị iche iche.” 
\b  
\q1  
\v 11 Gilead ọ na-eme ajọ ihe? 
\q2 Ndị ya bụ ndị efulefu. 
\q1 Ha na-achụ aja oke ehi dị iche iche na Gilgal? 
\q2 Ebe ịchụ aja ha niile ga a dịka ebe a chịkọtara ukwu nkume, 
\q2 nke dị nʼubi a kọrọ akọ. 
\q1  
\v 12 Jekọb gbalagara nʼala Aram; 
\q2 Izrel fere ofufe nʼihi inweta nwunye, 
\q2 nʼihi ịkwụ ụgwọ ya, o lekọtara atụrụ. 
\q1  
\v 13 Ọ bụkwa onye amụma ka \nd Onyenwe anyị\nd* ji site nʼIjipt kpọpụta Izrel, 
\q2 o sitekwara nʼaka onye amụma lekọtazie ya anya. 
\q1  
\v 14 Ma Ifrem akpasuola iwe ilu nke ukwuu. 
\q2 Onyenwe ya ga-awụkwasịkwa ya ikpe ọmụma. 
\q2 Ọ ga-akwụghachi ya dịka nlelị ya si dị. 
\c 13  
\s1 Iwe Chineke megide Izrel 
\q1  
\v 1 Na mbụ, mgbe ọbụla Ifrem kwuru okwu, a na-enwe ọma jijiji, 
\q2 nʼihi na ọ bụ onye e buliri elu nʼIzrel. 
\q2 Ma ikpe maara ya nʼihi ofufe o fere Baal, ọ nwụkwara. 
\q1  
\v 2 Ugbu a, ha na-aga nʼihu nʼime mmehie, 
\q2 ha na-eji ọlaọcha na-akpụrụ onwe ha arụsị dị iche iche, 
\q1 nke ha ji uche kpachara anya kpụzie nke ọma, 
\q2 ha niile bụ akaọrụ ndị ǹka. 
\q1 Ha onwe ha na-ekwu, 
\q2 “Ha na-achụ aja ụmụ mmadụ. 
\q2 Ha na-esusukwa nwa ehi a kpụrụ akpụ ọnụ” 
\q1  
\v 3 Nʼihi ya, ha ga-adị ka igirigi nke ụtụtụ, 
\q2 maọbụ igirigi nke na-agbachapụ ngwangwa, 
\q2 dịka igbugbo nke a fụchapụrụ nʼebe ịzọcha ọka, 
\q2 dịka anwụrụ ọkụ nke si na oghereikuku na-ekupụ. 
\b  
\q1  
\v 4 “Ma mụ onwe m bụ \nd Onyenwe anyị\nd* na Chineke gị, 
\q2 siterịị nʼala Ijipt. 
\q1 Unu agaghị anabatara onwe unu Chineke ọzọ karịa m. 
\q2 Ọ dịghị Onye nzọpụta ọzọ dị karịa m. 
\q1  
\v 5 Elekọtara m unu nʼime ọzara, 
\q2 nʼala ahụ kpọrọ nkụ, nke mmiri na-adịghị. 
\q1  
\v 6 Mgbe m nyere ha nri, ha rijukwara afọ. 
\q2 Mgbe afọ juru ha, ha bidoro ịkpa nganga, 
\q2 chefuo m. 
\q1  
\v 7 Nʼihi ya, aghaghị m ịbịakwasị ha dịka ọdụm; 
\q2 maọbụ dịka agụ nke na-ezo onwe ya nʼakụkụ ụzọ. 
\q1  
\v 8 Aga m adakwasị ha dịka anụ ọhịa bịa nke a gbabara aka ụmụ ya, 
\q2 dọwasịa anụ ahụ kpuchiri obi ha 
\q1 aga m eripịa ha dịka ọdụm, 
\q2 anụ ọhịa ga-adọkasịkwa ha. 
\b  
\q1  
\v 9 “Aga m ala gị nʼiyi, gị Izrel, 
\q2 onye pụrụ inyere gị aka? 
\q1  
\v 10 Ebee ka ndị eze gị nọ, ka ha bịa zọpụta gị? 
\q2 Ebee ka ndịisi ọchịchị nke obodo gị niile nọ, 
\q1 bụ ndị ahụ i ji nʼihi ha na-asị, 
\q2 ‘Nye m eze na ndị ọchịchị’? 
\q1  
\v 11 Esitere m nʼiwe m nye gị eze, 
\q2 sitekwa nʼọnụma m, napụ gị ya. 
\q1  
\v 12 Njehie nke Ifrem ka e kechikọtara debe; 
\q2 a na-edetukwa mmehie ya niile nʼakwụkwọ. 
\q1  
\v 13 Ihe mgbu nke dịka ihe mgbu nwanyị ime na-eme na-abịakwasị ya; 
\q2 maọbụ nwantakịrị na-enweghị uche. 
\q1 Mgbe oge ya zuru, 
\q2 ọ jụrụ ịpụta site nʼọnụ akpanwa ka a mụpụta ya. 
\b  
\q1  
\v 14 “Aga m anapụta ha site nʼike nke Ala mmụọ. 
\q2 Aga m agbapụta ha site nʼọnwụ. 
\q1 Gị ọnwụ, olee ebe ajọọ ọrịa gị niile na-efe efe dị? 
\q2 Gị ala mmụọ, olee ebe ike ịla nʼiyi gị dị? 
\b  
\q1 “Agaghị m enwe ọmịiko ọbụla, 
\q2  
\v 15 ọ bụ ezie na ya onwe ya bụ onye na-amị mkpụrụ nʼetiti ụmụnne ya niile. 
\q1 Ma oke ifufe si nʼọwụwa anyanwụ, nke \nd Onyenwe anyị\nd* zitere, 
\q2 ga-esi nʼọzara fekwasị ya. 
\q1 Isi iyi niile ga-ata, 
\q2 olulu mmiri ya ga-atakọrọkwa. 
\q1 A ga-apụnara ya ihe dị nʼụlọakụ ya niile, 
\q2 na akụ niile o nwere. 
\q1  
\v 16 Sameria aghaghị ịta ahụhụ ikpe ọmụma ya, 
\q2 nʼihi na o nupuru isi megide Chineke ha. 
\q1 A ga-eji mma agha gbuo ndị ya niile, 
\q2 tụpịa ụmụntakịrị ya niile nʼala, 
\q2 jirikwa mma agha bọwaa ndị inyom niile dị ime.” 
\c 14  
\s1 Nchegharị na ngọzị 
\q1  
\v 1 Lọghachikwutenụ \nd Onyenwe anyị\nd* Chineke unu, unu ndị Izrel; 
\q2 nʼihi na ọ bụ mmehie unu wetaara unu ịsọ ngọngọ. 
\q1  
\v 2 Chịrịnụ okwu nʼọnụ unu 
\q2 lọghachikwute \nd Onyenwe anyị\nd*. 
\q1 Gwanụ ya sị, 
\q2 “Gbaghara mmehie anyị niile, 
\q1 jirikwa ihuọma nabata anyị, 
\q2 ka anyị si otu a jiri egbugbere ọnụ anyị chụọrọ gị aja. 
\q1  
\v 3 Ndị Asịrịa enweghị ike ịzọpụta anyị, 
\q2 ọ bụghị nʼelu ịnyịnya agha ka anyị ga-anọkwasị. 
\q1 Anyị agaghị asịkwa ‘Chi anyị ka unu bụ’ 
\q2 nye ihe ndị ahụ anyị jiri aka anyị pịa, 
\q2 nʼihi na nʼime gị, ka ndị na-enweghị nne na nna na-achọta obi ebere.” 
\b  
\q1  
\v 4 “Aga m agwọ ndaghachi azụ ha, 
\q2 jiri obi m niile hụ ha nʼanya, 
\q2 nʼihi na iwe m esitela nʼebe ha nọ chigharịa. 
\q1  
\v 5 Aga m adịrị Izrel dịka igirigi. 
\q2 Ọ ga-amakwa ifuru dịka okoko lili. 
\q1 Dịka osisi sida nke Lebanọn, 
\q2 mgbọrọgwụ ya ga-abami nʼime ala; 
\q2  
\v 6 ome ya ga-awasa, 
\q1 ịma mma ya ga-adịkwa ka osisi oliv, 
\q2 isisi ọma ọ na-esi ga-adị ka isi osisi sida nke Lebanọn. 
\q1  
\v 7 Ha ga-ebi nʼokpuru ndo m. 
\q2 Ha ga-etolite dịka osisi ọka dị ndụ. 
\q1 Ha ga-ama ifuru dịka osisi ubi vaịnị, 
\q2 a ga-amatakwa ha nʼebe niile dịka e si mara mmanya e mere na Lebanọn. 
\q1  
\v 8 Gị Ifrem, gịnị ka mụ na arụsị nwekọrọ? 
\q2 Mụ onwe m ga-aza ya, ma lekọtakwa ya. 
\q1 Mụ onwe m dịkwa ka osisi junipa dị ndụ. 
\q2 Ịmị mkpụrụ gị na-esitekwa nʼebe m nọ abịa.” 
\b  
\q1  
\v 9 Onye bụ onye amamihe? Ha ga-aghọta ihe ndị a. 
\q2 Onye bụ onye nwere uche nghọta? Ha ga-aghọta ihe ọ pụtara. 
\q1 Nʼihi na ụzọ \nd Onyenwe anyị\nd* bụ ezi ụzọ. 
\q2 Ndị ezi omume na-ejekwa ije na ha, 
\q2 ma ndị na-enupu isi na-asọ ngọngọ nʼime ha.