\v 1 \w Pablo|strong="G3972"\w*, \w siervo|strong="G1401"\w* \w de|strong="G2596"\w* \w Dios|strong="G2316"\w* \w y|strong="G2532"\w* apóstol \w de|strong="G2596"\w* \w Jesucristo|strong="G2424"\w*, \w conforme|strong="G2596"\w* \w a|strong="G2596"\w* \w la|strong="G3588"\w* \w fe|strong="G4102"\w* \w de|strong="G2596"\w* \w los|strong="G3588"\w* \w escogidos|strong="G1588"\w* \w de|strong="G2596"\w* \w Dios|strong="G2316"\w* \w y|strong="G2532"\w* \w al|strong="G3588"\w* \w conocimiento|strong="G1922"\w* \w de|strong="G2596"\w* \w la|strong="G3588"\w* \w verdad|strong="G4102"\w* \w que|strong="G3588"\w* lleva \w a|strong="G2596"\w* \w la|strong="G3588"\w* \w piedad|strong="G2150"\w*,   
\p
\v 2 \w en|strong="G1909"\w* \w esperanza|strong="G1680"\w* \w de|strong="G1909"\w* \w la|strong="G3588"\w* \w vida|strong="G2222"\w* eterna, \w la|strong="G3588"\w* \w cual|strong="G3739"\w* \w Dios|strong="G2316"\w*, \w que|strong="G3588"\w* no miente, \w prometió|strong="G1861"\w* \w desde|strong="G1909"\w* \w antes|strong="G4253"\w* \w de|strong="G1909"\w* \w los|strong="G3588"\w* \w tiempos|strong="G5550"\w* eternos.   
\p
\v 3 \w A|strong="G1722"\w* \w su|strong="G3588"\w* debido \w tiempo|strong="G2540"\w*, \w Dios|strong="G2316"\w* \w manifestó|strong="G5319"\w* \w su|strong="G3588"\w* \w palabra|strong="G3056"\w* \w por|strong="G1722"\w* medio \w de|strong="G1722"\w* \w la|strong="G3588"\w* \w predicación|strong="G2782"\w* \w que|strong="G3588"\w* \w me|strong="G1473"\w* fue confiada \w por|strong="G1722"\w* mandato \w de|strong="G1722"\w* \w Dios|strong="G2316"\w* \w nuestro|strong="G2249"\w* \w Salvador|strong="G4990"\w*.   
\p
\v 4 \w A|strong="G2596"\w* \w Tito|strong="G5103"\w*, \w mi|strong="G3588"\w* \w verdadero|strong="G1103"\w* \w hijo|strong="G5043"\w* \w en|strong="G2596"\w* \w la|strong="G3588"\w* \w fe|strong="G4102"\w* \w que|strong="G3588"\w* compartimos: \w Gracia|strong="G5485"\w*, misericordia \w y|strong="G2532"\w* \w paz|strong="G1515"\w* \w de|strong="G2596"\w* parte \w de|strong="G2596"\w* \w Dios|strong="G2316"\w* \w el|strong="G3588"\w* \w Padre|strong="G3962"\w* \w y|strong="G2532"\w* \w de|strong="G2596"\w* \w Cristo|strong="G5547"\w* \w Jesús|strong="G2424"\w* \w nuestro|strong="G2249"\w* \w Salvador|strong="G4990"\w*.   
\p
\v 5 \w Por|strong="G1722"\w* \w esta|strong="G3778"\w* \w causa|strong="G5484"\w* \w te|strong="G4771"\w* dejé \w en|strong="G1722"\w* \w Creta|strong="G2914"\w*: \w para|strong="G2443"\w* \w que|strong="G3588"\w* pusieras \w en|strong="G1722"\w* orden \w lo|strong="G3588"\w* \w que|strong="G3588"\w* faltaba \w y|strong="G2532"\w* nombraras \w ancianos|strong="G4245"\w* \w en|strong="G1722"\w* \w cada|strong="G2596"\w* \w ciudad|strong="G4172"\w*, \w como|strong="G5613"\w* \w yo|strong="G1473"\w* \w te|strong="G4771"\w* \w mandé|strong="G1299"\w*.   
\p
\v 6 \w El|strong="G5100"\w* anciano debe \w ser|strong="G2192"\w* irreprensible, esposo \w de|strong="G1722"\w* \w una|strong="G1520"\w* sola \w mujer|strong="G1135"\w*, \w y|strong="G1510"\w* \w tener|strong="G2192"\w* \w hijos|strong="G5043"\w* creyentes \w que|strong="G5101"\w* \w no|strong="G3361"\w* sean acusados \w de|strong="G1722"\w* mala conducta \w ni|strong="G2228"\w* \w de|strong="G1722"\w* rebeldía.   
\p
\v 7 \w Porque|strong="G1063"\w* \w el|strong="G3588"\w* supervisor, \w como|strong="G5613"\w* administrador \w de|strong="G3588"\w* \w Dios|strong="G2316"\w*, \w debe|strong="G1163"\w* ser irreprensible: \w no|strong="G3361"\w* arrogante, \w no|strong="G3361"\w* \w iracundo|strong="G3711"\w*, \w no|strong="G3361"\w* dado \w al|strong="G3588"\w* vino, \w no|strong="G3361"\w* violento \w ni|strong="G3361"\w* codicioso \w de|strong="G3588"\w* ganancias deshonestas.   
\p
\v 8 Más bien, debe ser hospitalario, amante de lo bueno, prudente, \w justo|strong="G1342"\w*, \w santo|strong="G3741"\w* y con dominio propio.   
\p
\v 9 Debe mantenerse firme \w en|strong="G1722"\w* \w la|strong="G3588"\w* \w palabra|strong="G3056"\w* \w fiel|strong="G4103"\w*, \w conforme|strong="G2596"\w* \w a|strong="G1722"\w* \w la|strong="G3588"\w* \w enseñanza|strong="G1319"\w* recibida, \w para|strong="G2443"\w* poder \w exhortar|strong="G3870"\w* \w con|strong="G1722"\w* \w sana|strong="G5198"\w* \w doctrina|strong="G1322"\w* \w y|strong="G2532"\w* \w convencer|strong="G1651"\w* \w a|strong="G1722"\w* \w los|strong="G3588"\w* \w que|strong="G3588"\w* contradicen.   
\p
\v 10 \w Porque|strong="G1063"\w* \w hay|strong="G3588"\w* \w muchos|strong="G4183"\w* rebeldes, habladores inútiles \w y|strong="G2532"\w* \w engañadores|strong="G5423"\w*, especialmente \w los|strong="G3588"\w* \w de|strong="G1537"\w* \w la|strong="G3588"\w* \w circuncisión|strong="G4061"\w*.   
\p
\v 11 A estos \w es|strong="G3739"\w* \w necesario|strong="G1163"\w* taparles la boca, porque trastornan familias \w enteras|strong="G3650"\w*, \w enseñando|strong="G1321"\w* \w lo|strong="G3739"\w* \w que|strong="G3739"\w* \w no|strong="G3361"\w* \w deben|strong="G1163"\w* \w por|strong="G5484"\w* ganancia deshonesta.   
\p
\v 12 \w Uno|strong="G5100"\w* \w de|strong="G1537"\w* \w ellos|strong="G1537"\w*, \w su|strong="G2398"\w* \w propio|strong="G2398"\w* \w profeta|strong="G4396"\w*, \w dijo|strong="G3004"\w*: \w Los|strong="G5100"\w* \w cretenses|strong="G2912"\w* son siempre \w mentirosos|strong="G5583"\w*, \w malas|strong="G2556"\w* \w bestias|strong="G2342"\w* y glotones perezosos.   
\p
\v 13 \w Este|strong="G3778"\w* \w testimonio|strong="G3141"\w* \w es|strong="G3739"\w* verdadero. \w Por|strong="G1223"\w* \w eso|strong="G1223"\w* \w repréndelos|strong="G1651"\w* \w con|strong="G1722"\w* firmeza, \w para|strong="G2443"\w* \w que|strong="G3588"\w* sean \w sanos|strong="G5198"\w* \w en|strong="G1722"\w* \w la|strong="G3588"\w* \w fe|strong="G4102"\w*,   
\p
\v 14 \w y|strong="G2532"\w* \w no|strong="G3361"\w* presten atención a mitos judíos \w ni|strong="G2532"\w* a \w mandamientos|strong="G1785"\w* \w de|strong="G3588"\w* hombres \w que|strong="G3588"\w* \w se|strong="G2532"\w* apartan \w de|strong="G3588"\w* \w la|strong="G3588"\w* verdad.   
\p
\v 15 Para \w los|strong="G3588"\w* \w limpios|strong="G2513"\w*, \w todas|strong="G3956"\w* \w las|strong="G3588"\w* cosas son limpias; \w pero|strong="G1161"\w* para \w los|strong="G3588"\w* \w contaminados|strong="G3392"\w* \w e|strong="G2532"\w* incrédulos, \w nada|strong="G3762"\w* es \w limpio|strong="G2513"\w*, \w pues|strong="G1161"\w* tienen contaminadas \w la|strong="G3588"\w* \w mente|strong="G3563"\w* \w y|strong="G2532"\w* \w la|strong="G3588"\w* \w conciencia|strong="G4893"\w*.   
\p
\v 16 Dicen \w que|strong="G3588"\w* \w conocen|strong="G1492"\w* \w a|strong="G4314"\w* \w Dios|strong="G2316"\w*, \w pero|strong="G1161"\w* \w con|strong="G4314"\w* \w sus|strong="G3588"\w* \w hechos|strong="G2041"\w* \w lo|strong="G3588"\w* niegan. \w Son|strong="G1510"\w* detestables, desobedientes \w y|strong="G2532"\w* reprobados \w para|strong="G4314"\w* \w toda|strong="G3956"\w* buena \w obra|strong="G2041"\w*.   
\c 2  
\p
\v 1 \w Pero|strong="G1161"\w* \w tú|strong="G4771"\w* \w habla|strong="G2980"\w* \w lo|strong="G3588"\w* \w que|strong="G3588"\w* \w está|strong="G3588"\w* \w de|strong="G3588"\w* acuerdo \w con|strong="G3739"\w* \w la|strong="G3588"\w* \w sana|strong="G5198"\w* \w doctrina|strong="G1319"\w*.   
\p
\v 2 Enseña a \w los|strong="G3588"\w* hombres mayores a ser sobrios, respetables, \w prudentes|strong="G4998"\w*, \w sanos|strong="G5198"\w* \w en|strong="G3588"\w* \w la|strong="G3588"\w* \w fe|strong="G4102"\w*, \w en|strong="G3588"\w* \w el|strong="G3588"\w* amor \w y|strong="G1510"\w* \w en|strong="G3588"\w* \w la|strong="G3588"\w* \w paciencia|strong="G5281"\w*.   
\p
\v 3 \w De|strong="G1722"\w* la misma \w manera|strong="G3361"\w*, enseña \w a|strong="G1722"\w* las mujeres mayores \w a|strong="G1722"\w* vivir \w con|strong="G1722"\w* conducta reverente. \w Que|strong="G3361"\w* \w no|strong="G3361"\w* sean \w calumniadoras|strong="G1228"\w* \w ni|strong="G3366"\w* esclavas \w de|strong="G1722"\w* \w mucho|strong="G4183"\w* \w vino|strong="G3631"\w*, \w sino|strong="G3361"\w* \w maestras|strong="G2567"\w* \w de|strong="G1722"\w* lo bueno.   
\p
\v 4 Así podrán enseñar \w a|strong="G2443"\w* \w las|strong="G3588"\w* mujeres jóvenes \w a|strong="G2443"\w* amar \w a|strong="G2443"\w* \w sus|strong="G3588"\w* esposos \w y|strong="G1510"\w* \w a|strong="G2443"\w* \w sus|strong="G3588"\w* hijos,   
\p
\v 5 \w a|strong="G2443"\w* ser \w prudentes|strong="G4998"\w*, puras, cuidadosas \w de|strong="G3588"\w* \w su|strong="G3588"\w* casa, bondadosas \w y|strong="G2443"\w* \w sujetas|strong="G5293"\w* \w a|strong="G2443"\w* \w sus|strong="G3588"\w* propios esposos, \w para|strong="G2443"\w* \w que|strong="G3588"\w* \w la|strong="G3588"\w* \w palabra|strong="G3056"\w* \w de|strong="G3588"\w* \w Dios|strong="G2316"\w* \w no|strong="G3361"\w* \w sea|strong="G3588"\w* blasfemada.   
\p
\v 6 \w Exhorta|strong="G3870"\w* también a \w los|strong="G3588"\w* jóvenes a ser prudentes.   
\p
\v 7 Preséntate \w tú|strong="G3588"\w* mismo \w en|strong="G1722"\w* \w todo|strong="G3956"\w* \w como|strong="G1722"\w* \w ejemplo|strong="G5179"\w* \w de|strong="G4012"\w* \w buenas|strong="G2570"\w* \w obras|strong="G2041"\w*. \w En|strong="G1722"\w* \w tu|strong="G3588"\w* \w enseñanza|strong="G1319"\w* muestra integridad, seriedad   
\p
\v 8 \w y|strong="G2443"\w* \w palabra|strong="G3056"\w* \w sana|strong="G5199"\w*, \w que|strong="G3588"\w* \w no|strong="G3367"\w* pueda \w ser|strong="G2192"\w* condenada, \w para|strong="G2443"\w* \w que|strong="G3588"\w* \w el|strong="G3588"\w* \w adversario|strong="G1537"\w* se avergüence \w y|strong="G2443"\w* \w no|strong="G3367"\w* \w tenga|strong="G2192"\w* \w nada|strong="G3367"\w* malo \w que|strong="G3588"\w* \w decir|strong="G3004"\w* \w de|strong="G1537"\w* \w nosotros|strong="G2249"\w*.   
\p
\v 9 Exhorta \w a|strong="G1722"\w* los \w siervos|strong="G1401"\w* \w a|strong="G1722"\w* sujetarse \w a|strong="G1722"\w* \w sus|strong="G2398"\w* \w amos|strong="G1203"\w* \w en|strong="G1722"\w* \w todo|strong="G3956"\w*, \w a|strong="G1722"\w* agradarlos, \w a|strong="G1722"\w* \w no|strong="G3361"\w* responder \w con|strong="G1722"\w* rebeldía,   
\p
\v 10 \w a|strong="G1722"\w* \w no|strong="G3361"\w* robar, \w sino|strong="G3361"\w* \w a|strong="G1722"\w* \w mostrar|strong="G1731"\w* completa \w fidelidad|strong="G4102"\w*, \w para|strong="G2443"\w* \w que|strong="G3588"\w* \w en|strong="G1722"\w* \w todo|strong="G3956"\w* \w adornen|strong="G2885"\w* \w la|strong="G3588"\w* \w enseñanza|strong="G1319"\w* \w de|strong="G1722"\w* \w Dios|strong="G2316"\w* \w nuestro|strong="G2249"\w* \w Salvador|strong="G4990"\w*.   
\p
\v 11 \w Porque|strong="G1063"\w* \w la|strong="G3588"\w* \w gracia|strong="G5485"\w* \w de|strong="G3588"\w* \w Dios|strong="G2316"\w* se ha manifestado, trayendo \w salvación|strong="G4992"\w* a \w todos|strong="G3956"\w* \w los|strong="G3588"\w* hombres.   
\p
\v 12 \w Esta|strong="G3588"\w* gracia nos enseña \w a|strong="G1722"\w* rechazar \w la|strong="G3588"\w* impiedad \w y|strong="G2532"\w* \w los|strong="G3588"\w* malos \w deseos|strong="G1939"\w* \w de|strong="G1722"\w* \w este|strong="G3588"\w* mundo, \w y|strong="G2532"\w* \w a|strong="G1722"\w* \w vivir|strong="G2198"\w* \w en|strong="G1722"\w* \w este|strong="G3588"\w* \w tiempo|strong="G3568"\w* \w con|strong="G1722"\w* dominio propio, justicia \w y|strong="G2532"\w* piedad,   
\p
\v 13 mientras esperamos \w la|strong="G3588"\w* \w esperanza|strong="G1680"\w* bendita: \w la|strong="G3588"\w* \w manifestación|strong="G2015"\w* \w gloriosa|strong="G1391"\w* \w de|strong="G3588"\w* \w nuestro|strong="G2249"\w* \w gran|strong="G3173"\w* \w Dios|strong="G2316"\w* \w y|strong="G2532"\w* \w Salvador|strong="G4990"\w* \w Jesucristo|strong="G2424"\w*.   
\p
\v 14 \w Él|strong="G3739"\w* \w se|strong="G1438"\w* entregó \w a|strong="G2443"\w* \w sí|strong="G1438"\w* mismo \w por|strong="G5228"\w* \w nosotros|strong="G2249"\w*, \w para|strong="G2443"\w* \w redimirnos|strong="G3084"\w* \w de|strong="G1325"\w* \w toda|strong="G3956"\w* maldad \w y|strong="G2532"\w* purificar \w para|strong="G2443"\w* \w sí|strong="G1438"\w* un \w pueblo|strong="G2992"\w* \w propio|strong="G4041"\w*, \w celoso|strong="G2207"\w* \w de|strong="G1325"\w* \w buenas|strong="G2570"\w* \w obras|strong="G2041"\w*.   
\p
\v 15 \w Habla|strong="G2980"\w* \w estas|strong="G3778"\w* cosas, \w exhorta|strong="G3870"\w* \w y|strong="G2532"\w* \w reprende|strong="G1651"\w* \w con|strong="G3326"\w* \w toda|strong="G3956"\w* \w autoridad|strong="G2003"\w*. \w Que|strong="G2532"\w* \w nadie|strong="G3367"\w* \w te|strong="G4771"\w* menosprecie.   
\c 3  
\p
\v 1 \w Recuérdales|strong="G5279"\w* que \w se|strong="G1438"\w* sujeten \w a|strong="G4314"\w* los gobernantes \w y|strong="G1510"\w* autoridades, que obedezcan \w y|strong="G1510"\w* estén listos \w para|strong="G4314"\w* \w toda|strong="G3956"\w* buena \w obra|strong="G2041"\w*.   
\p
\v 2 Que \w no|strong="G3367"\w* hablen mal \w de|strong="G4314"\w* \w nadie|strong="G3367"\w*, que \w no|strong="G3367"\w* sean peleadores, sino amables, \w mostrando|strong="G1731"\w* \w toda|strong="G3956"\w* \w mansedumbre|strong="G4240"\w* \w hacia|strong="G4314"\w* \w todos|strong="G3956"\w* los hombres.   
\p
\v 3 \w Porque|strong="G1063"\w* \w nosotros|strong="G2249"\w* \w también|strong="G2532"\w* \w antes|strong="G2532"\w* \w éramos|strong="G1510"\w* necios, desobedientes, \w extraviados|strong="G4105"\w*, esclavos \w de|strong="G1722"\w* \w diversos|strong="G4164"\w* malos \w deseos|strong="G1939"\w* \w y|strong="G2532"\w* placeres. Vivíamos \w en|strong="G1722"\w* \w malicia|strong="G2549"\w* \w y|strong="G2532"\w* \w envidia|strong="G5355"\w*, siendo \w aborrecibles|strong="G4767"\w* \w y|strong="G2532"\w* odiándonos unos \w a|strong="G1722"\w* otros.   
\p
\v 4 \w Pero|strong="G1161"\w* \w cuando|strong="G3753"\w* \w se|strong="G2532"\w* manifestó \w la|strong="G3588"\w* \w bondad|strong="G5544"\w* \w de|strong="G3588"\w* \w Dios|strong="G2316"\w* \w nuestro|strong="G2249"\w* \w Salvador|strong="G4990"\w* \w y|strong="G2532"\w* \w su|strong="G3588"\w* \w amor|strong="G5363"\w* \w por|strong="G3588"\w* \w los|strong="G3588"\w* hombres,   
\p
\v 5 \w él|strong="G3588"\w* nos \w salvó|strong="G4982"\w*, \w no|strong="G3756"\w* \w por|strong="G1223"\w* \w obras|strong="G2041"\w* \w de|strong="G1537"\w* \w justicia|strong="G1343"\w* \w que|strong="G3588"\w* \w nosotros|strong="G2249"\w* hubiéramos \w hecho|strong="G4160"\w*, sino \w por|strong="G1223"\w* \w su|strong="G3588"\w* \w misericordia|strong="G1656"\w*, mediante \w el|strong="G3588"\w* lavamiento \w del|strong="G3588"\w* nuevo nacimiento \w y|strong="G2532"\w* \w la|strong="G3588"\w* renovación \w por|strong="G1223"\w* \w el|strong="G3588"\w* \w Espíritu|strong="G4151"\w* Santo.   
\p
\v 6 Dios \w derramó|strong="G1632"\w* \w abundantemente|strong="G4146"\w* \w el|strong="G3588"\w* Espíritu Santo \w sobre|strong="G1909"\w* \w nosotros|strong="G2249"\w* \w por|strong="G1223"\w* \w medio|strong="G1223"\w* \w de|strong="G1909"\w* \w Jesucristo|strong="G2424"\w* \w nuestro|strong="G2249"\w* \w Salvador|strong="G4990"\w*,   
\p
\v 7 \w para|strong="G2443"\w* \w que|strong="G3588"\w*, \w justificados|strong="G1344"\w* \w por|strong="G2596"\w* \w su|strong="G3588"\w* \w gracia|strong="G5485"\w*, llegáramos \w a|strong="G2596"\w* \w ser|strong="G1096"\w* \w herederos|strong="G2818"\w* \w conforme|strong="G2596"\w* \w a|strong="G2596"\w* \w la|strong="G3588"\w* \w esperanza|strong="G1680"\w* \w de|strong="G2596"\w* \w la|strong="G3588"\w* \w vida|strong="G2222"\w* eterna.   
\p
\v 8 \w Fiel|strong="G4103"\w* \w es|strong="G3778"\w* \w esta|strong="G3778"\w* \w palabra|strong="G3056"\w*. \w Quiero|strong="G1014"\w* \w que|strong="G3588"\w* insistas \w en|strong="G4012"\w* \w estas|strong="G3778"\w* cosas, \w para|strong="G2443"\w* \w que|strong="G3588"\w* \w los|strong="G3588"\w* \w que|strong="G3588"\w* han \w creído|strong="G4100"\w* \w en|strong="G4012"\w* \w Dios|strong="G2316"\w* \w procuren|strong="G5431"\w* ocuparse \w en|strong="G4012"\w* \w buenas|strong="G2570"\w* \w obras|strong="G2041"\w*. \w Estas|strong="G3778"\w* cosas \w son|strong="G1510"\w* \w buenas|strong="G2570"\w* \w y|strong="G2532"\w* \w útiles|strong="G5624"\w* \w para|strong="G2443"\w* \w los|strong="G3588"\w* hombres.   
\p
\v 9 \w Pero|strong="G1161"\w* \w evita|strong="G4026"\w* las discusiones \w necias|strong="G3474"\w*, las \w genealogías|strong="G1076"\w*, las \w contiendas|strong="G2054"\w* \w y|strong="G2532"\w* \w los|strong="G2532"\w* \w pleitos|strong="G2054"\w* acerca \w de|strong="G1161"\w* la Ley, \w porque|strong="G1063"\w* \w son|strong="G1510"\w* inútiles \w y|strong="G2532"\w* no aprovechan.   
\p
\v 10 Al hombre divisivo, \w después|strong="G3326"\w* de \w una|strong="G1520"\w* \w y|strong="G2532"\w* \w otra|strong="G1208"\w* \w amonestación|strong="G3559"\w*, apártalo de ti.   
\p
\v 11 \w Sabiendo|strong="G1492"\w* \w que|strong="G3754"\w* \w tal|strong="G5108"\w* persona \w está|strong="G3588"\w* pervertida \w y|strong="G2532"\w* peca, \w y|strong="G2532"\w* \w se|strong="G1492"\w* condena a \w sí|strong="G2532"\w* misma.   
\p
