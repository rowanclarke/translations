\v 8 Abner \w became|strong="H2734"\w* \w very|strong="H3966"\w* \w angry|strong="H2734"\w* \w about|strong="H5921"\w* \w what|strong="H1697"\w* Ishbosheth \w said|strong="H1697"\w* \w to|strong="H5921"\w* \w him|strong="H5921"\w*. \w He|strong="H3117"\w* \w said|strong="H1697"\w* \w to|strong="H5921"\w* Ishbosheth, “◄\w Do|strong="H6213"\w* \w you|strong="H5921"\w* think \w that|strong="H3117"\w* \w I|strong="H3117"\w* \w am|strong="H6485"\w* \w a|strong="H3068"\w* \add worthless\add* \w dog|strong="H3611"\w* [\w MET|strong="H4672"\w*] \w from|strong="H5921"\w* \w Judah|strong="H3063"\w*?/\w You|strong="H5921"\w* \w are|strong="H3117"\w* treating \w me|strong="H5921"\w* \w as|strong="H1697"\w* though \w I|strong="H3117"\w* \w am|strong="H6485"\w* \w a|strong="H3068"\w* \add worthless\add* \w dog|strong="H3611"\w* [\w MET|strong="H4672"\w*] \w from|strong="H5921"\w* \w Judah|strong="H3063"\w*.► [RHQ] \w From|strong="H5921"\w* \w the|strong="H5921"\w* \w beginning|strong="H7218"\w*, \w I|strong="H3117"\w* \w have|strong="H3063"\w* \w been|strong="H6485"\w* \w loyal|strong="H2617"\w* \w to|strong="H5921"\w* \w Saul|strong="H7586"\w* \w your|strong="H5921"\w* father, \w to|strong="H5921"\w* \w his|strong="H1732"\w* brothers, \w and|strong="H3063"\w* \w to|strong="H5921"\w* \w his|strong="H1732"\w* \w friends|strong="H4828"\w*. \w And|strong="H3063"\w* \w I|strong="H3117"\w* \w have|strong="H3063"\w* prevented \w you|strong="H5921"\w* \w from|strong="H5921"\w* \w being|strong="H1004"\w* defeated \w by|strong="H3027"\w* \w David|strong="H1732"\w*’s army. \w So|strong="H6213"\w* \w now|strong="H3117"\w* ◄\w why|strong="H5921"\w* \w are|strong="H3117"\w* \w you|strong="H5921"\w* criticizing \w me|strong="H5921"\w* \w about|strong="H5921"\w* \add what I have done with\add* \w some|strong="H1697"\w* \w woman|strong="H1004"\w*?/\w you|strong="H5921"\w* \w should|strong="H3117"\w* \w not|strong="H3808"\w* \w be|strong="H3808"\w* criticizing \w me|strong="H5921"\w* \w about|str