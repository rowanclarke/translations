\id JOL - Biblica® Open Kurdi Sorani Standard Version 
\h یۆئێل 
\toc1 یۆئێل 
\toc2 یۆئێل 
\toc3 یۆئێل 
\mt1 یۆئێل 
\c 1  
\p  
\v 1 پەیامی یەزدان کە بۆ یۆئێلی کوڕی پەتوئێل هات: 
\b  
\s1 هێرشی کوللە 
\q1  
\v 2 ئەی پیران، گوێ لەمە بگرن، 
\q2 ئەی هەموو دانیشتووانی خاکەکە، گوێ شل بکەن. 
\q1 ئایا ئەمە لە سەردەمی ئێوە 
\q2 یان لە سەردەمی باوباپیرانتان ڕوویداوە؟ 
\q1  
\v 3 ئەمە بۆ کوڕەکانتان بگێڕنەوە، 
\q2 کوڕەکانیشتان بۆ کوڕەکانیان، 
\q2 کوڕەکانیشیان بۆ نەوەی دوای خۆیان. 
\q1  
\v 4 ئەوەی لەبەر کوللەی قرتێنەر مایەوە 
\q2 کوللەی گەورە لووشیان دا، 
\q1 ئەوەی لەبەر کوللەی گەورە مایەوە 
\q2 پێکوڕە لووشیان دا، 
\q1 ئەوەش کە لەبەر پێکوڕە مایەوە 
\q2 وردە کوللەی لووشیان دا. 
\b  
\q1  
\v 5 ئەی سەرخۆشەکان، بەئاگا بێن و بگریێن! 
\q2 ئەی هەموو ئەوانەی شەراب دەخۆنەوە، 
\q1 واوەیلا بۆ شەرابی شیرین بکەن، 
\q2 چونکە لە دەمتان بڕاوە. 
\q1  
\v 6 نەتەوەیەک پەلاماری خاکەکەمی دا، 
\q2 بەهێز و بێشومارە، 
\q1 ددانەکانی ددانی نەڕە شێرە و 
\q2 کەڵبەی شێرە مێی هەیە. 
\q1  
\v 7 دار مێوەکەمی وێران کردووە و 
\q2 دار هەنجیرەکەمی تێکشکاندووە، 
\q1 توێکڵەکەی داتاشیوە و فڕێیداوە، 
\q2 لقەکانی سپی بوونەوە. 
\b  
\q1  
\v 8 شین بگێڕە وەک پاکیزەیەکی جلوبەرگی گوش\f + \fr 1:8 \ft لە کاتی ماتەمگێڕان و تۆبەکردندا جلوبەرگی لە گوش دروستکراویان لەبەرکردووە کە ئەزیەتی پێستیانی داوە.‏\f* پۆشیو، 
\q2 بۆ مێردی گەنجییەتی کە نەماوە. 
\q1  
\v 9 پێشکەشکراوی دانەوێڵە و شەراب 
\q2 لە ماڵی یەزدان بڕایەوە، 
\q1 کاهینەکان دەلاوێننەوە، 
\q2 ئەوانەی خزمەتکاری یەزدانن. 
\q1  
\v 10 کێڵگەکان وێران بوون، 
\q2 خاک شیوەنی گێڕا، 
\q1 چونکە دانەوێڵە فەوتا، 
\q2 شەرابی نوێ نەما، 
\q2 ڕۆن لە هیزە بڕا. 
\b  
\q1  
\v 11 ئەی جوتیارەکان، نائومێد بن، 
\q2 ڕەزەوانەکان، واوەیلا بکەن، 
\q1 بۆ گەنم و جۆ، 
\q2 چونکە دروێنەی کێڵگە لەناوچوو. 
\q1  
\v 12 دار مێو وشک هەڵگەڕا و 
\q2 دار هەنجیر سیس بوو، 
\q1 دار هەنار و خورما و سێو، 
\q2 هەموو درەختەکانی کێڵگە وشک هەڵگەڕان. 
\q2 بە دڵنیاییەوە شادی و خۆشی بۆ گەل نەما. 
\s1 بانگەوازی تۆبەکردن 
\q1  
\v 13 ئەی کاهینەکان، گوش بپۆشن و بلاوێننەوە، 
\q2 ئەی خزمەتکارانی قوربانگا، واوەیلا بکەن. 
\q1 ئەی خزمەتکارانی خوداکەم، 
\q2 وەرن و شەو بە بەرگی ماتەمەوە بمێننەوە، 
\q1 چونکە پێشکەشکراوی دانەوێڵە و شەراب 
\q2 لە ماڵی خوداتان ڕاگیراوە. 
\q1  
\v 14 ڕۆژووگرتنێک ڕابگەیەنن، 
\q2 بۆ کۆبوونەوەیەکی پیرۆز بانگیان بکەن، 
\q1 پیران کۆبکەنەوە، 
\q2 هەموو دانیشتووانی خاکەکەش 
\q1 بێنە ماڵی یەزدانی پەروەردگارتان، 
\q2 هاوار بکەن بۆ یەزدان. 
\b  
\q1  
\v 15 ئای بۆ ئەو ڕۆژە! 
\q2 چونکە ڕۆژی یەزدان\f + \fr 1:15 \ft لێرەدا مەبەست لە ڕووداوێکە کە دەبێتە سزای ئیسرائیل لەلایەن خوداوە لەسەر ستەمکاری و خراپەکارییان.‏\f* نزیک بووەتەوە، 
\q2 وەک وێرانبوون لەلایەن خودای هەرە بەتواناوە دێت. 
\b  
\q1  
\v 16 ئایا لەبەرچاومان خواردن نەبڕاوە؟ 
\q2 ئایا لە ماڵی خودامان خۆشی و شادی ماوە؟ 
\q1  
\v 17 تۆوی دانەوێڵەکان 
\q2 لەژێر باڕستی خاکدا ڕزین، 
\q1 کۆگاکان چۆڵ کران، 
\q2 ئەمبارەکان وێران کران، 
\q2 چونکە دانەوێڵە وشک بوو. 
\q1  
\v 18 ماڵاتەکان چۆن دەناڵێنن! 
\q2 مێگەلەکان بەڕەڵا بوون، 
\q1 چونکە لەوەڕگایان نییە، 
\q2 تەنانەت ڕانە مەڕەکانیش ماندوون. 
\b  
\q1  
\v 19 ئەی یەزدان، هاوار بۆ تۆ دەکەم، 
\q2 چونکە ئاگر لەوەڕگاکانی دەشتودەری خوارد، 
\q2 گڕێک هەموو درەختەکانی کێڵگەی سووتاند. 
\q1  
\v 20 تەنانەت ئاژەڵە کێوییەکانیش چاویان لە دەستی تۆیە، 
\q2 چونکە جۆگەلە ئاوەکان وشکیان کردووە و 
\q2 ئاگر لەوەڕگاکانی دەشتودەری خواردووە. 
\c 2  
\s1 سوپای کوللە 
\q1  
\v 1 لە سییۆن فوو بە کەڕەنادا بکەن، 
\q2 لەسەر کێوی پیرۆزم هاوار بکەن بۆ ئاگادارکردنەوە. 
\b  
\q1 با هەموو دانیشتووانی خاکەکە بلەرزن، 
\q2 چونکە ڕۆژی یەزدان دێت و نزیکە. 
\q1  
\v 2 ڕۆژی تاریکی و ئەنگوستەچاوە، 
\q2 ڕۆژی هەور و تەمی چڕە. 
\q1 وەک کازێوە باڵی بەسەر چیاکاندا دەکێشێت، 
\q2 سوپایەکی گەورە و بەهێز دێت، 
\q1 لە دێرزەمانەوە هاوشێوەی نەبووە، 
\q2 لە نەوەی داهاتووش شتی وا نابێتەوە. 
\b  
\q1  
\v 3 لەپێشیانەوە ئاگر دەخوات و 
\q2 لەپشتیشیانەوە گڕ دەسووتێنێت. 
\q1 لەپێشیانەوە خاک وەک باخچەی عەدەنە، 
\q2 لەپشتیشیانەوە چۆڵەوانییەکی وێرانە، 
\q2 هیچ لێیان دەرباز نابێت. 
\q1  
\v 4 دیمەنیان وەک دیمەنی ئەسپە، 
\q2 وەک سوار غار دەدەن. 
\q1  
\v 5 وەک دەنگی گالیسکە 
\q2 لەسەر لووتکەی چیاکان باز دەدەن، 
\q1 وەک دەنگی گڕی ئاگرە کە پوشوپەڵاش هەڵدەلووشێت، 
\q2 وەک سوپایەکی بەهێزی ڕیزبەستووە بۆ جەنگ. 
\b  
\q1  
\v 6 لەبەردەم ئەوان، گەلان سڵ دەکەنەوە، 
\q2 هەموو دەموچاوێک ڕەنگی هەڵدەبزڕکێت. 
\q1  
\v 7 وەک پاڵەوان هێرش دەبەن، 
\q2 وەک جەنگاوەر بە شووراکاندا هەڵدەگەڕێن. 
\q1 هەموویان لەسەر یەک هێڵ دەڕۆن و 
\q2 لە ڕێچکەی خۆیان لانادەن. 
\q1  
\v 8 تەنگ بە یەکتری هەڵناچنن و 
\q2 هەریەکەیان بە ڕیزی خۆیدا دەڕوات، 
\q1 بە سەنگەرەکاندا ڕەت دەبن، 
\q2 بەبێ ئەوەی ڕیزەکانیان بشکێنن. 
\q1  
\v 9 بەناو شارەکەدا غار دەدەن، 
\q2 بەسەر شووراکاندا ڕادەکەن، 
\q1 سەردەکەونە سەر ماڵەکان، 
\q2 وەک دز بەناو پەنجەرەکاندا دێنە ژوورەوە. 
\b  
\q1  
\v 10 لەبەردەمیان زەوی دەلەرزێت، 
\q2 ئاسمان دەهەژێت، 
\q1 خۆر و مانگ تاریک دەبن و 
\q2 ئەستێرەکان تروسکایی خۆیان ڕادەگرن. 
\q1  
\v 11 یەزدان دەنگی بەرز دەکاتەوە 
\q2 لەپێش سوپاکەیەوە، 
\q1 سەربازەکانی زۆر زۆرن، 
\q2 ئەوانەی فەرمانەکەی بەجێدەهێنن بە هێزن. 
\q1 ڕۆژی یەزدان گەورەیە، 
\q2 زۆر سامناکە. 
\q2 کێ خۆی لەبەری دەگرێت؟ 
\s1 دڵتان دابدڕن 
\q1  
\v 12 یەزدان دەفەرموێت: «بەڵام ئێستا، 
\q2 بە هەموو دڵتانەوە بگەڕێنەوە لام، 
\q2 بە ڕۆژووگرتن و گریان و شیوەن گێڕانەوە.» 
\b  
\q1  
\v 13 دڵتان دابدڕن نەک جلەکانتان، 
\q2 بگەڕێنەوە لای یەزدانی پەروەردگارتان، 
\q1 چونکە میهرەبان و بە بەزەییە، 
\q2 پشوودرێژە، 
\q1 خۆشەویستییە نەگۆڕەکەی زۆرە، 
\q2 لە خراپە پاشگەز دەبێتەوە. 
\q1  
\v 14 کێ دەزانێت؟ ڕەنگە بگەڕێتەوە و پاشگەز بێتەوە، 
\q2 لەپاش خۆیەوە بەرەکەت بەجێبهێڵێت، 
\q1 بۆ پێشکەشکراوی دانەوێڵە و شەراب 
\q2 بۆ یەزدانی پەروەردگارتان. 
\b  
\q1  
\v 15 لە سییۆن فوو بە کەڕەنادا بکەن، 
\q2 ڕۆژووگرتنێک ڕابگەیەنن، 
\q2 بۆ کۆبوونەوەیەکی پیرۆز بانگیان بکەن. 
\q1  
\v 16 گەل کۆبکەنەوە و 
\q2 کۆمەڵ تەرخان بکەن، 
\q1 پیران خڕبکەنەوە و 
\q2 منداڵان کۆبکەنەوە 
\q2 لەگەڵ شیرەخۆرەکان. 
\q1 با زاوا لە ژوورەکەیەوە بێتە دەرەوە، 
\q2 بووکیش لە کوللەکەی. 
\q1  
\v 17 با کاهینەکان، خزمەتکارانی یەزدان، 
\q2 لەنێوان هەیوانەکە و قوربانگاکەدا بگریێن. 
\q1 با بڵێن: «ئەی یەزدان، دڵت بە گەلەکەت بسووتێت، 
\q2 میراتەکەت مەکە جێگای تانە و تەشەر، 
\q1 هەتا گەلان بیانکەنە پەند. 
\q2 بۆچی لەنێو گەلاندا بڵێن: ”کوا خوداکەیان؟“» 
\s1 وەڵامی یەزدان 
\q1  
\v 18 ئینجا یەزدان خۆشەویستی بۆ خاکەکەی دەردەبڕێت و 
\q2 بەزەیی بە گەلەکەیدا دێتەوە. 
\p  
\v 19 یەزدان وەڵام دەداتەوە و بە گەلەکەی دەفەرموێت: 
\q1 «دانەوێڵە و شەرابی نوێ و زەیتتان بۆ دەنێرم، 
\q1 هەتا ئەوەی لێی تێردەبن، 
\q2 ئیتر ناتانکەمە جێگای تانە و تەشەری نەتەوەکان. 
\b  
\q1  
\v 20 «ئەو سوپایەش کە لە باکوورەوە هاتووە لێتان دوور دەخەمەوە، 
\q2 دەریدەکەم بۆ زەوییەکی وشک و وێران، 
\q1 ڕووی لە دەریای ڕۆژهەڵاتە\f + \fr 2:20 \ft دەریای مردوو.‏\f* و 
\q2 پشتیشی لە دەریای ڕۆژئاوایە\f + \fr 2:20 \ft دەریای ناوەڕاست.‏\f*، 
\q1 بۆگەنییەکەی سەرکەوت و 
\q2 بۆنە پیسەکەی بڵاو دەبێتەوە.» 
\b  
\q1 بێگومان کاری مەزنی ئەنجام داوە. 
\q2  
\v 21 ئەی زەوی مەترسە! 
\q2 شاد و دڵخۆش بە، 
\q1 چونکە یەزدان کاری مەزنی ئەنجام داوە. 
\q2  
\v 22 ئەی ئاژەڵە کێوییەکان مەترسن، 
\q2 چونکە لەوەڕگاکانی دەشتودەر سەوز دەبن، 
\q1 درەختەکان بەر دەگرن، 
\q2 دار هەنجیر و دار مێو بەرێکی زۆر دەردەخەن. 
\q1  
\v 23 ئەی نەوەی سییۆن، 
\q2 شاد و دڵخۆش بن بە یەزدانی پەروەردگارتان، 
\q1 چونکە بۆ دەرکەوتنی ڕاستودروستی پاییزە بارانی پێدان. 
\q2 پاییزە باران و بەهارە باران 
\q2 هەروەک پێشتر بەسەرتاندا دەبارێنێت. 
\q1  
\v 24 ئیتر جۆخینەکان\f + \fr 2:24 \ft جۆخین یان سەرخەرمان ئەو زەوییە تەرخانکراوەیە کە لەلایەن وەرزێر و جوتیارەوە بەکارهێنراوە بۆ کوتانی دانەوێڵە لەسەری لەدوای کۆکردنەوەی لە کێڵگە.‏\f* پڕ دەبن لە دانەوێڵە و 
\q2 قەڕابەکان سەرڕێژ دەبن لە شەراب و زەیت. 
\b  
\q1  
\v 25 «قەرەبووی ئەو ساڵانەتان دەکەمەوە کە کوللەی گەورە خواردیان، 
\q2 پێکوڕە و وردە کوللە و 
\q2 کوللەی قرتێنەر، 
\q1 لەشکرە گەورەکەم کە ناردمە سەرتان. 
\q1  
\v 26 ئینجا زۆر دەخۆن و تێر دەبن، 
\q2 ستایشی ناوی یەزدانی پەروەردگاری خۆتان دەکەن، 
\q1 ئەوەی کاری سەرسوڕهێنەری لەگەڵدا کردن، 
\q2 بۆ هەتاهەتایە گەلەکەم سەرشۆڕ نابێت. 
\q1  
\v 27 ئیتر دەزانن کە من لە ناوەڕاستی ئیسرائیلم، 
\q2 کە من یەزدانی پەروەردگارتانم و 
\q2 بێجگە لە من یەکێکی دیکە نییە. 
\q1 بۆ هەتاهەتایە گەلەکەم سەرشۆڕ نابێت. 
\s1 ڕۆژی یەزدان 
\q1  
\v 28 «پاش ئەمانە، 
\q2 ڕۆحم بەسەر هەموو خەڵکدا دەڕێژم. 
\q1 کوڕان و کچانتان پەیامی خودا ڕادەگەیەنن، 
\q2 پیرەمێردەکانتان خەون دەبینن، 
\q2 گەنجانتان بینینیان بۆ ئاشکرا دەکرێت. 
\q1  
\v 29 تەنانەت بەسەر بەندە و کەنیزەکانیشم، 
\q2 لەو ڕۆژانەدا ڕۆحی خۆم دەبارێنم. 
\q1  
\v 30 پەرجوو\f + \fr 2:30 \ft پەرجوو: موعجیزە.‏\f* لە ئاسمان و 
\q2 زەویدا نیشان دەدەم، 
\q2 خوێن و ئاگر و ستوونی دووکەڵ. 
\q1  
\v 31 خۆر دەبێتە تاریکی و 
\q2 مانگیش دەبێتە خوێن، 
\q2 بەر لەوەی ڕۆژی گەورە و ترسناکی یەزدان بێت. 
\q1  
\v 32 بەڵام هەرکەسێک بە ناوی یەزدانەوە بپاڕێتەوە 
\q2 ڕزگاری دەبێت، 
\q1 چونکە هەروەک یەزدان فەرمووی، 
\q2 ڕزگاربوون لە کێوی سییۆن و 
\q2 لە ئۆرشەلیم دەبێت، 
\q1 بۆ ئەوانەیە کە ماونەتەوە، 
\q2 ئەوانەی یەزدان بانگهێشتی کردوون. 
\c 3  
\s1 حوکمی نەتەوەکان 
\q1  
\v 1 «لەو ڕۆژانەدا و لەو کاتەدا، 
\q2 کاتێک ڕاپێچکراوەکانی یەهودا و ئۆرشەلیم دەگەڕێنمەوە، 
\q1  
\v 2 هەموو نەتەوەکان خڕدەکەمەوە و 
\q2 دەیانبەمە خوارەوە بۆ دۆڵی یەهۆشافات\f + \fr 3:2 \ft لە عیبری بە واتای خودا دادگایی دەکات.‏\f*. 
\q1 لەوێدا دادگاییان دەکەم، 
\q2 لەسەر گەلەکەم و میراتەکەم، ئیسرائیل، 
\q1 کە لەنێو نەتەوەکاندا پەرتوبڵاویان کردنەوە و 
\q2 زەوییەکەی منیان دابەش کرد. 
\q1  
\v 3 لەسەر گەلەکەم تیروپشکیان کرد، 
\q2 منداڵیان بۆ لەشفرۆش فرۆشت، 
\q1 کچیان بۆ شەراب فرۆشت 
\q2 بۆ ئەوەی بیخۆنەوە. 
\p  
\v 4 «ئەی سور و سەیدا و هەموو ناوچەکانی فەلەستیە، ئیتر ئێوە چیتان لە دژی من هەیە؟ ئایا تۆڵەم لێ دەستێننەوە؟ جا ئەگەر تۆڵەم لێ بستێننەوە، بە پەلە و خێرا بەسەر خۆتانیدا دەهێنمەوە،  
\v 5 چونکە ئێوە زێڕ و زیوەکەی منتان برد و گەنجینە باشەکانی منتان بردە ناو پەرستگاکانی خۆتان.  
\v 6 نەوەی یەهودا و نەوەی ئۆرشەلیمتان بە نەوەی یۆنانییەکان فرۆشت، تاکو لە نیشتیمانی خۆیان دووریان بخەنەوە. 
\p  
\v 7 «ببینن، من لەو شوێنەوە کە ئەوانتان پێی فرۆشتبوو هەڵیاندەستێنم، ئەوەی کردبووتان بەسەر خۆتانیدا دەهێنمەوە.  
\v 8 کوڕ و کچەکانتان دەفرۆشمە نەوەی یەهودا، ئەوانیش دەیانفرۆشنە سەبئییەکان، نەتەوەیەکی دوور.» ئەوە فەرمایشتی یەزدانە. 
\q1  
\v 9 ئەمە لەنێو نەتەوەکاندا ڕابگەیەنن: 
\q2 خۆتان بۆ جەنگێک ئامادە بکەن! 
\q1 پاڵەوانەکان هەڵتسێنن! 
\q2 با هەموو جەنگاوەران پێشبکەون و هێرش بکەن. 
\q1  
\v 10 گاسنەکانتان بکوتن و بیکەنە شمشێر، 
\q2 داسەکانیشتان بکەنە ڕم. 
\q1 با لاواز بڵێت، 
\q2 «من پاڵەوانم!» 
\q1  
\v 11 ئەی هەموو نەتەوەکانی دەوروبەر، بە پەلە وەرن، 
\q2 لەوێدا کۆببنەوە. 
\b  
\q1 ئەی یەزدان، پاڵەوانەکانت دابەزێنە! 
\b  
\q1  
\v 12 «نەتەوەکان هەڵدەستن و دێن، 
\q2 بۆ دۆڵی یەهۆشافات، 
\q1 چونکە لەوێدا دادەنیشم بۆ دادگاییکردنی 
\q2 هەموو نەتەوەکانی دەوروبەر. 
\q1  
\v 13 داسەکە ڕاوەشێنن، 
\q2 چونکە دروێنەکە پێگەیشتووە. 
\q1 وەرن ترێ بپڵیشێننەوە، 
\q2 چونکە گوشەرەکە پڕ بووە، 
\q2 قەڕابەکە سەرڕێژ دەبێت، 
\q1 چونکە خراپەیان زۆرە!» 
\b  
\q1  
\v 14 «لە دۆڵی بڕیار 
\q2 کۆمەڵ، کۆمەڵ! 
\q2 چونکە ڕۆژی یەزدان نزیکە 
\q2 لە دۆڵی بڕیار. 
\q1  
\v 15 خۆر و مانگ تاریک دەبن و 
\q2 ئەستێرەکان تروسکایی خۆیان ڕادەگرن. 
\q1  
\v 16 یەزدانیش لە سییۆنەوە دەنەڕێنێت، 
\q2 لە ئۆرشەلیمەوە دەنگی بەرز دەکاتەوە، 
\q2 ئاسمان و زەوی دەهەژێن. 
\q1 بەڵام یەزدان پەناگایە بۆ گەلەکەی خۆی، 
\q2 قەڵایە بۆ نەوەی ئیسرائیل. 
\s1 بەرەکەتی سەر گەلی خودا 
\q1  
\v 17 «ئیتر دەزانن کە من یەزدانی پەروەردگارتانم، 
\q2 لە سییۆن نیشتەجێم، کێوی پیرۆزم. 
\q1 ئۆرشەلیمیش پیرۆز دەبێت؛ 
\q2 لەمەودوا بێگانە بەناویدا تێناپەڕێت. 
\b  
\q1  
\v 18 «لەو ڕۆژەدا چیاکان خۆشاوی ترێیان لێ دەتکێت، 
\q2 گردەکان شیریان لێ دەڕژێت؛ 
\q2 هەموو کەندەکانی یەهودا ئاویان لەسەر دەڕژێت، 
\q1 کانییەک لە ماڵی یەزدانەوە هەڵدەقوڵێت، 
\q2 دۆڵی شەتیم\f + \fr 3:18 \ft یان: دۆڵی داری ئەکاسیا، شوێنێکی وشک و بێ ئاو بووە.‏\f* ئاو دەدات. 
\q1  
\v 19 بەڵام میسر وێران دەبێت، 
\q2 ئەدۆمیش دەبێتە چۆڵەوانییەکی وێران، 
\q1 لەبەر ئەوەی ستەمیان لە نەوەی یەهودا کرد، 
\q2 خوێنی بێتاوانیان لە خاکەکەیاندا ڕشت. 
\q1  
\v 20 یەهوداش هەتاهەتایە ئاوەدان دەبێت، 
\q2 ئۆرشەلیمیش نەوە دوای نەوە. 
\q1  
\v 21 لەو خوێنڕشتنەیان خۆشدەبم 
\q2 کە پێشتر لێی خۆش نەببووم.» 
\b  
\qc یەزدانیش لە سییۆن نیشتەجێ دەبێت!