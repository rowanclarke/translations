\v 10 \w Et|strong="H01004"\w* \w je|strong="H05315"\w* \w répandrai|strong="H08210"\w* \w sur|strong="H05921"\w* \w la|strong="H03427"\w* \w maison|strong="H01004"\w* \w de|strong="H01004"\w* \w David|strong="H01732"\w* \w et|strong="H01004"\w* \w sur|strong="H05921"\w* \w l|strong="H01732"\w*’\w habitant|strong="H03427"\w* \w de|strong="H01004"\w* \w Jérusalem|strong="H03389"\w* \w un|strong="H01732"\w* \w esprit|strong="H07307"\w* \w de|strong="H01004"\w* \w grâce|strong="H02580"\w* \w et|strong="H01004"\w* \w de|strong="H01004"\w* \w supplication|strong="H08469"\w*, \w et|strong="H01004"\w* \w ils|strong="H01992"\w* \w tourneront|strong="H02008"\w* \w les|strong="H01732"\w* \w yeux|strong="H05027"\w* \w vers|strong="H00935"\w* \w moi|strong="H06440"\w* qu’\w ils|strong="H01004"\w* \w ont|strong="H00001"\w* \w transpercé|strong="H01856"\w*\f + \fr 12:10 \ft \it Qu’ils ont transpercé\it*, hébr. \it dâqâru\it*. Les LXX ont lu \it râqâdu\it*, \it qu’ils ont insulté\it*. On pourrait peut-être diviser autrement le texte : \it Et ils tourneront les yeux vers moi. Celui qu’ils ont transpercé, ils feront le deuil sur lui…\it*\f*. \w Et|strong="H01004"\w* \w ils|strong="H01992"\w* \w feront|strong="H01004"\w* \w le|strong="H08210"\w* \w deuil|strong="H05594"\w* \w sur|strong="H05921"\w* \w lui|strong="H01732"\w*, \w comme|strong="H01004"\w* \w on|strong="H00376"\w* \w fait|strong="H06213"\w* \w le|strong="H08210"\w* \w deuil|strong="H05594"\w* \w sur|strong="H05921"\w* \w un|strong="H01732"\w* \w fils|strong="H01121"\w* \w unique|strong="H03173"\w* ; \w ils|strong="H01992"\w* \w pleureront|strong="H01058"\w* \w amèrement|strong="H04843"\w* \w sur|strong="H05921"\w* \w lui|strong="H01732"\w*, \w comme|strong="H01004"\w* \w on|strong="H00376"\w* \w pleure|strong="H05594"\w* \w amèrement|strong="H04843"\w* \w sur|strong="H05921"\w* \w un|strong="H01732"\w* \w premier-né|strong="H01004"\w*\f + \fr 12:10 \ft \it Qu’ils ont transpercé\it*, hébr. \it dâqâru\it*. Les LXX ont lu \it râqâdu\it*, \it qu’ils ont insulté\it*. On pourrait peut-être diviser autrement le texte : \it Et ils tourneront les yeux vers moi. Celui qu’ils ont transpercé, ils feront le deuil sur lui…\it*\f*.
\p 
\v 11 \w En|strong="H03117"\w* \w ce|strong="H01931"\w* \w jour-là|strong="H01931"\w*, \w le|strong="H03117"\w* \w deuil|strong="H04553"\w* \w sera|strong="H03389"\w* \w grand|strong="H01431"\w* \w à|strong="H03117"\w* \w Jérusalem|strong="H03389"\w*, \w comme|strong="H03117"\w* \w le|strong="H03117"\w* \w deuil|strong="H04553"\w* d’Adadremmon \w dans|strong="H03117"\w* \w la|strong="H03117"\w* \w vallée|strong="H01237"\w* \w de|strong="H03117"\w* Mageddo.\f + \fr 12:11 \ft Allusion à la défaite et à la mort du roi Josias dans la bataille qu’il livra au roi d’Égypte Néchao dans la plaine d’Esdrelon. \it Adadremmon\it*, près de Mageddo (2Ro 23,30 ; 2Ch 34,24).\f*
\v 12 \w Le|strong="H05416"\w* \w pays|strong="H00776"\w* \w sera|strong="H01732"\w* \w dans|strong="H01732"\w* \w le|strong="H05416"\w* \w deuil|strong="H05594"\w*, \w chaque|strong="H00259"\w* \w famille|strong="H04940"\w*\f + \fr 12:12 \ft \it Chaque famille\it* : ce ne sera pas seulement un deuil national, mais un deuil de chaque famille. Le prophète mentionne comme exemple deux familles principales, et dans chacune, une branche particulière : la famille royale de David, et la branche de Nathan, fils de David ; la famille de Lévi, et la branche de Séméï. Les femmes sont distinguées à part, parce qu’elles avaient un rôle important dans les cérémonies de deuil.\f* \w à|strong="H01004"\w* \w part|strong="H02506"\w* ; \w la|strong="H01004"\w* \w famille|strong="H04940"\w* \w de|strong="H01004"\w* \w la|strong="H01004"\w* \w maison|strong="H01004"\w* \w de|strong="H01004"\w* \w David|strong="H01732"\w* \w à|strong="H01004"\w* \w part|strong="H02506"\w* \w et|strong="H01004"\w* \w ses|strong="H03526"\w* \w femmes|strong="H00802"\w* \w à|strong="H01004"\w* \w part|strong="H02506"\w* ; \w la|strong="H01004"\w* \w famille|strong="H04940"\w* \w de|strong="H01004"\w* \w la|strong="H01004"\w* \w maison|strong="H01004"\w* \w de|strong="H01004"\w* \w Nathan|strong="H05416"\w* \w à|strong="H01004"\w* \w part|strong="H02506"\w* \w et|strong="H01004"\w* \w ses|strong="H03526"\w* \w femmes|strong="H00802"\w* \w à|strong="H01004"\w* \w part|strong="H02506"\w* ;
\v 13 \w la|strong="H01004"\w* \w famille|strong="H04940"\w* \w de|strong="H01004"\w* \w la|strong="H01004"\w* \w maison|strong="H01004"\w* \w de|strong="H01004"\w* \w Lévi|strong="H03878"\w* \w à|strong="H01004"\w* \w part|strong="H02506"\w* \w et|strong="H01004"\w* \w ses|strong="H03526"\w* \w femmes|strong="H00802"\w* \w à|strong="H01004"\w* \w part|strong="H02506"\w* ; \w la|strong="H01004"\w* \w famille|strong="H04940"\w* \w de|strong="H01004"\w* Séméï \w à|strong="H01004"\w* \w part|strong="H02506"\w* \w et|strong="H01004"\w* \w ses|strong="H03526"\w* \w femmes|strong="H00802"\w* \w à|strong="H01004"\w* \w part|strong="H02506"\w* ;
