\id 1TH
\h 1 סלוניס 
\toc1 1 סלוניס 
\toc2 1 סלוניס 
\toc3 1 סלוניס 
\mt1 אִגֶּרֶת פּוֹלוֹס הָרִאשׁוֹנָה אֶל־הַתַּסְלוֹנִיקִים  
\c 1
\cp  א
\cl פרק א 
\p
\v 1 \vp א\vp* פּוֹלוֹס וְסִלְוָנוֹס וְטִימוֹתִיּוֹס אֶל־עֲדַת הַתַּסְלוֹנִיקִים הַדְּבֵקִים בֵּאלֹהִים אָבִינוּ וּבְיֵשׁוּעַ הַמָּשִׁיחַ אֲדֹנֵינוּ חֶסֶד לָכֶם וְשָׁלוֹם מֵאֵת אֱלֹהִים אָבִינוּ וַאֲדוֹנֵינוּ יֵשׁוּעַ הַמָּשִׁיחַ׃  
\v 2 \vp ב\vp* הִנֵּה אֲנַחְנוּ מְבָרְכִים אֶת־הָאֱלֹהִים בְּכָל־עֵת עַל־כֻּלְּכֶם וְלֹא נֶחְדַּל מֵהַזְכִּיר אֶתְכֶם בִּתְפִלּוֹתֵינוּ׃  
\v 3 \vp ג\vp* בְּזָכְרֵנוּ תָמִיד לִפְנֵי אֱלֹהֵינוּ אָבִינוּ אֶת־מַעֲשֵׂיכֶם בֶּאֱמוּנָה אֶת־עֲבֹדַתְכֶם בְּאַהֲבָה וְאֶת־מִבְטַח עֻזְּכֶם בְּתִקְוָה בַּאֲדֹנֵינוּ יֵשׁוּעַ הַמָּשִׁיחַ׃  
\v 4 \vp ד\vp* כִּי יָדַעְנוּ אַחִים כִּי בְּחִירֵי הָאֱלֹהִים אַתֶּם וִידִידָיו׃  
\v 5 \vp ה\vp* בַּאֲשֶׁר גַּם־בְּשׂרָתֵנוּ לֹא הִשְׁמַעְנוּ אֶתְכֶם בְּקוֹל דְּבָרִים לְבָד כִּי אִם־גַּם־בִּגְבוּרָה וּבְרוּחַ הַקֹּדֶשׁ וּבְבִטְחָה עֲצֻמָה כַּאֲשֶׁר רְאִיתֶם אֵיךְ הָלַכְנוּ בְתוֹכֲכֶם לְטוֹב לָכֶם׃  
\v 6 \vp ו\vp* וְאַתֶּם הֲלַכְתֶּם בְּעִקְּבוֹתֵינוּ וּבְעִקְּבוֹת אֲדֹנֵינוּ וַתְּקַבְּלוּ אֶת־דְּבָרֵינוּ וְלִבְּכֶם עָלַץ בְּרוּחַ הַקֹּדֶשׁ אַף כִּי־צָרָה גְדוֹלָה מְצָאַתְכֶם׃  
\v 7 \vp ז\vp* עַד אֲשֶׁר הֱיִיתֶם לְמוֹפֵת לְכָל־אַנְשֵׁי אֱמוּנָה בְּמַקְדּוֹנְיָא וּבַאֲכַיָּא׃  
\v 8 \vp ח\vp* כִּי מִכֶּם יָצָא קוֹל דְּבַר יְהוָֹה לֹא לְבַד בְּמַקְדּוֹנְיָא וּבַאֲכַיָּא כִּי אִם־גַּם בְּכָל־מָקוֹם יָצָא שֵׁמַע אֱמוּנַתְכֶם בֵּאלֹהִים עַד אֲשֶׁר לֹא נוֹתַר לָנוּ לְדַבֶּר־עוֹד דָּבָר׃  
\v 9 \vp ט\vp* כִּי הַשֹּׁמְעִים הִגִּידוּ בְפִיהֶם אֵיךְ בָּאנוּ אֲלֵיכֶם וְאֵיךְ עֲזַבְתֶּם אֶת־הָאֱלִילִים וַתָּשׁוּבוּ אֶל־הָאֱלֹהִים לַעֲבֹד אֱלֹהִים חַיִּים אֱלֹהֵי אֱמֶת׃  
\v 10 \vp י\vp* וּלְחַכּוֹת לִבְנוֹ מִן־הַשָּׁמַיִם לְיֵשׁוּעַ אֲשֶׁר הֲקִימוֹ מִן־הַמֵּתִים וַאֲשֶׁר הוּא מַצִּילֵנוּ לֶעָתִיד לָבוֹא מֵחָרוֹן אָף׃   
\c 2
\cp  ב
\cl פרק ב 
\p
\v 1 \vp א\vp* הֵן נַפְשְׁכֶם אַחַי יֹדָעַת כִּי בֹאֵנוּ אֲלֵיכֶם לֹא־הָיָה לָרִיק׃  
\v 2 \vp ב\vp* כִּי אַחֲרֵי הַתְּלָאָה אֲשֶׁר מְצָאַתְנוּ וְאַחֲרֵי אֲשֶׁר הִתְעַלְּלוּ בָנוּ בְּפִילִפִּי הֲלֹא יְדַעְתֶּם כִּי אָז מָצָאנוּ עֹז בֵּאלֹהֵינוּ לְהַגִּיד לָכֶם בְּשׂרַת הָאֱלֹהִים נֶגֶד צֹרְרִים רַבִּים׃  
\v 3 \vp ג\vp* כִּי לֹא מִפִּי מַשְׁגֶּה יָצְאָה עֵדוּתֵנוּ וְלֹא מִקֶּרֶב טְמֵא שְׂפָתַיִם וְלֹא מִלָּשׁוֹן רְמִיָּה׃  
\v 4 \vp ד\vp* כִּי כַאֲשֶׁר מָצָא אֱלֹהִים לִבֵּנוּ נָכוֹן לְפָנָיו וַיַּפְקֵד בְּיָדֵינוּ אֶת־הַבְּשׂרָה כֵּן נְדַבֵּרָה לֹא לְהָפִיק רָצוֹן מִבְּנֵי־אָדָם כִּי אִם־מֵאלֹהִים הַבֹּחֵן לֵבָב׃  
\v 5 \vp ה\vp* הֵן יְדַעְתֶּם כִּי מֵעוֹדֵנוּ לֹא בָאנוּ בִשְׂפַת חֲלָקוֹת וְלֹא בְנִכְלֵי בֹצְעֵי בָצַע אֱלֹהִים לָנוּ לְעֵד׃  
\v 6 \vp ו\vp* גַּם לֹא־בִקַּשְׁנוּ כְבוֹד אֲנָשִׁים לֹא מִיֶּדְכֶם וְלֹא מִידֵי אֲחֵרִים אַף כִּי־הָיְתָה לָּנוּ צְדָקָה לְהַעֲמִיס עֲלֵיכֶם לְכַלְכְּלֵנוּ כִּשְׁלִיחֵי הַמָּשִׁיחַ׃  
\v 7 \vp ז\vp* אַךְ בִּנְעִמוֹת הָלַכְנוּ עִמָּכֶם בְּאֹמֶנֶת אֲשֶׁר תִּשָּׂא אֶת־בְּנָהּ בְּחֵיקָהּ׃  
\v 8 \vp ח\vp* וְכֵן זֶה כַמָּה נִכְסֹף נִכְסַפְנוּ לָכֶם עַד אֲשֶׁר־אָמַרְנוּ לָתֵת לָכֶם גַּם־בְּשׂרַת הָאֱלֹהִים וְגַם־נַפְשֵׁנוּ בַּעַדְכֶם כִּי־יְקַרְתֶּם בְּעֵינֵינוּ עַד־מְאֹד׃  
\v 9 \vp ט\vp* הֲלֹא תִזְכְּרוּ אַחַי אֶת־הֶעָמָל וְאֶת־הַיְגִיעָה אֵיךְ עָבַדְנוּ לַיְלָה וְיוֹמָם לְבִלְתִּי הֱיוֹת לְמַשָּׂא עַל־אִישׁ מִכֶּם כַּאֲשֶׁר הִגַּדְנוּ לָכֶם בְּשׂרַת הָאֱלֹהִים׃  
\v 10 \vp י\vp* עֵדִים אַתֶּם וְעֵד אֱלֹהִים כִּי בְקֹדֶשׁ בְּצֶדֶק וּבְתָמִים הָלַכְנוּ לִפְנֵיכֶם שֹׁמְרֵי אֱמֻנִים׃  
\v 11 \vp יא\vp* כַּאֲשֶׁר אַתֶּם יֹדְעִים כִּי־כְאָב אֶל־בָּנָיו כֵּן דִּבַּרְנוּ דִבְרֵי מוּסָר וְתַנְחוּמִים עַל־לֵב כָּל־אִישׁ מִכֶּם׃  
\v 12 \vp יב\vp* וַנָּעִיד בָּכֶם לָלֶכֶת בְּדֶרֶךְ יְשָׁרָה לִפְנֵי אֱלֹהִים אֲשֶׁר קָרָא אֶתְכֶם לִכְבוֹד מַלְכוּתוֹ׃  
\v 13 \vp יג\vp* וּבַעֲבוּר זֹאת גַּם־אֲנַחְנוּ לֹא נֶחְדַּל מֵהוֹדוֹת אֶת־אֱלֹהֵינוּ כִּי הֶאֱזַנְתֶּם לִדְבַר הָאֱלֹהִים אֲשֶׁר הִשְׁמַעְנוּ בְאָזְנֵיכֶם לֹא כִדְבַר אֲנָשִׁים כִּי אִם־קִבַּלְתֶּם אֹתוֹ כִּדְבַר הָאֱלֹהִים לַאֲמִיתּוֹ אֲשֶׁר רַב כֹּחוֹ לְמַאֲמִינִים׃  
\v 14 \vp יד\vp* כִּי נִמְשַׁלְתֶּם אַחַי לִקְהִלוֹת הָאֱלֹהִים בְּיֵשׁוּעַ הַמָּשִׁיחַ אֲשֶׁר־בְּאֶרֶץ יְהוּדָה כִּי עַם הָאָרֶץ הֵצִיקוּ לָכֶם כַּאֲשֶׁר הַיְהוּדִים הֵצִיקוּ לָהֶן׃  
\v 15 \vp טו\vp* הֲלֹא הֵם אֲשֶׁר הֵמִיתוּ אֶת־יֵשׁוּעַ אֲדֹנֵינוּ וְאֶת־הַנְּבִיאִים וְגַם־אֹתָנוּ גֵּרְשׁוּ מִגֵּו וְהֵם לֹא טוֹבִים בְּעֵינֵי אֱלֹהִים וּנְלוֹזִים לִפְנֵי כָל־אָדָם׃  
\v 16 \vp טז\vp* אֲשֶׁר סָגְרוּ עָלֵינוּ מִקְּרֹא אֶל־הַגּוֹיִם לִתְשׁוּעָה וּבָזֹאת מָלְאָה סְאַת עֲוֹנָם כְּדַרְכָּם תָּמִיד וַחֲרוֹן אַף הִשִּׂיגָם עַד־לְכַלֵּה׃  
\v 17 \vp יז\vp* וַאֲנַחְנוּ אַחַי אַחֲרֵי אֲשֶׁר־רָחַקְנוּ מִכֶּם זֶה מְעַט כְּמַסְתִּירֵי פָנִים וְלֹא כְמַרְחִיקֵי לֵב בִּקַּשְׁנוּ מְאֹד לִרְאוֹת אֶת־פְּנֵיכֶם בְּחֵשֶׁק־רָב׃  
\v 18 \vp יח\vp* עַל־כֵּן הוֹאַלְנוּ לָבוֹא אֲלֵיכֶם אֲנִי פוֹלוֹס גַּם־פַּעַם גַּם־פַּעֲמָיִם וְהַשָּׂטָן עֲצָרָנוּ׃  
\v 19 \vp יט\vp* כִּי מַה תִּקְוָתֵנוּ מַה שִּׂמְחָתֵנוּ וּמָה עֲטֶרֶת תִּפְאַרְתֵּנוּ הֲלֹא אַתֶּם הִנְּכֶם לִפְנֵי יֵשׁוּעַ הַמָּשִׁיחַ אֲדֹנֵינוּ בְּבֹאוֹ׃  
\v 20 \vp כ\vp* כִּי הֵן אַתֶּם כְּבוֹדֵנוּ וְשִׂמְחָתֵנוּ׃   
\c 3
\cp  ג
\cl פרק ג 
\p
\v 1 \vp א\vp* עַל־כֵּן כַּלְכֵּל לֹא יָכֹלְנוּ עוֹד וַנֵּאוֹת לְהִוָּתֵר בְּאַתִּינַס לְבַדֵּנוּ׃  
\v 2 \vp ב\vp* וְאֶת־אָחִינוּ טִימוֹתִיּוֹס מְשָׁרֵת־אֵל בִּבְשׂרַת הַמָּשִׁיחַ שָׁלַחְנוּ לְחַזֵּק אֶת־לִבְּכֶם וּלְהַזְהִיר אֶתְכֶם בֶּאֱמוּנַתְכֶם׃  
\v 3 \vp ג\vp* לְבִלְתִּי יִנּוֹעַ לֶב־אִישׁ מִפְּנֵי הַצָּרוֹת הָאֵלֶּה הֲלֹא בְנַפְשְׁכֶם יְדַעְתֶּם כִּי לָזֹאת יֻעָדְנוּ׃  
\v 4 \vp ד\vp* כִּי גַם־הִגַּדְנוּ לָכֶם מֵאָז בִּהְיוֹתֵנוּ אֶצְלְכֶם כִּי־צָרָה תָבוֹא עָלֵינוּ וְכֵן גַּם־בָּאָה כַּאֲשֶׁר יְדַעְתֶּם׃  
\v 5 \vp ה\vp* וְעַל־כֵּן גַּם אֲנִי נִלְאֵיתִי כַּלְכֵּל וָאֶשְׁלַח לָדַעַת עַל־דְּבַר אֱמוּנַתְכֶם אִם לֹא נִסָּה הַמְנַסֶּה אֶתְכֶם לָתֵת אֶת־עֲמָלֵנוּ לָרִיק׃  
\v 6 \vp ו\vp* וְעַתָּה כַּאֲשֶׁר שָׁב אֵלֵינוּ טִימוֹתִיּוֹס מִכֶּם וַיְבַשְּׂרֵנוּ עַל־דְּבַר אֱמוּנַתְכֶם וְאַהֲבַתְכֶם כִּי זְכַרְתֶּם אֹתָנוּ לְטוֹבָה בְּכָל־עֵת וְכִי תִתְאַוּוּ לִרְאוֹת אֶת־פָּנֵינוּ כַּאֲשֶׁר גַּם־אֲנַחְנוּ מִתְאַוִּים לִרְאוֹת אֶת־פְּנֵיכֶם׃  
\v 7 \vp ז\vp* לְזֹאת אֵפוֹא אֶחָי בְּכָל־צָרוֹת וְרָעוֹת מָצָאנוּ תַנְחוּמִים בָּכֶם בִּגְלַל אֱמוּנַתְכֶם׃  
\v 8 \vp ח\vp* כִּי חַיִּים אֲנַחְנוּ הַיּוֹם אִם רַק עֹמְדִים אַתֶּם הָכֵן לִפְנֵי אֲדֹנֵינוּ׃  
\v 9 \vp ט\vp* כִּי בַמֶּה־נּוֹדֶה מַה־נָּשִׁיב לֵאלֹהִים בַּעֲבוּרְכֶם עַל כָּל־הַשִׂמְחָה אֲשֶׁר שָׂמַחְנוּ עֲלֵיכֶם לִפְנֵי אֱלֹהֵינוּ׃  
\v 10 \vp י\vp* לַיְלָה וְיוֹמָם נַעְתִּיר וְנִתְפַּלֵּל כִּי יִנָּתֶן לָנוּ לִרְאוֹת אֶת־פְּנֵיכֶם וּלְהַשְׁלִים אֵת אֲשֶׁר־לָכֵם בֶּאֱמוּנַתְכֶם׃  
\v 11 \vp יא\vp* וֵאלֹהֵינוּ אָבִינוּ וְיֵשׁוּעַ הַמָּשִׁיחַ אֲדֹנֵינוּ יְיַשֵּׁר אֶת־דַּרְכֵּנוּ אֲלֵיכֶם׃  
\v 12 \vp יב\vp* וְאֶתְכֶם יַרְבֶּה וְכֵן יִתֵּן לָכֶם אֲדֹנֵינוּ לְהוֹסִיף בְּאַהֲבַת אִישׁ לְרֵעֵהוּ וּבְאַהֲבַת כָּל־אָדָם כַּאֲשֶׁר גַּם־אֲנַחְנוּ נוֹסִיף לְאַהֲבָה אֶתְכֶם׃  
\v 13 \vp יג\vp* וְכֵן יְכוֹנֵן אֶת־לִבְּכֶם בַּקֹּדֶשׁ וְלֹא יִמָּצֵא בָכֶם שֶׁמֶץ דָּבָר לִפְנֵי אֱלֹהֵינוּ אָבִינוּ בְּיוֹם בּוֹא יֵשׁוּעַ הַמָּשִׁיחַ אֲדֹנֵינוּ עִם־כָּל־קְדֹשָׁיו׃   
\c 4
\cp  ד
\cl פרק ד 
\p
\v 1 \vp א\vp* סוֹף דָּבָר אַחַי נִדְרֹשׁ מִכֶּם וְנַזְהִיר אֶתְכֶם בְּשֵׁם יֵשׁוּעַ אֲדֹנֵינוּ כַּאֲשֶׁר קִבַּלְתֶּם מִפִּינוּ לְהִתְהַלֵּךְ בְּמֵישָׁרִים וְלִמְצֹא חֵן בְּעֵינֵי אֱלֹהִים וְכַאֲשֶׁר גַּם־אַתֶּם הֹלְכִים כֵּן תַּעֲשׂוּ וְכֵן תּוֹסִיפוּ׃  
\v 2 \vp ב\vp* כִּי יְדַעְתֶּם אֶת־הַמִּצְוֹת אֲשֶׁר נָתַנּוּ לָכֶם בְּשֵׁם יֵשׁוּעַ אֲדֹנֵינוּ׃  
\v 3 \vp ג\vp* כִּי זֶה רְצוֹן אֱלֹהִים כִּי קְדשִׁים תִּהְיוּ וְתִנָּזְרוּ מִן־הַזְּנוּת׃  
\v 4 \vp ד\vp* וְכָל־אִישׁ מִכֶּם יָבִין לִשְׁמֹר כִּלְיוֹ בְּקֹדֶשׁ וּבְכָבוֹד׃  
\v 5 \vp ה\vp* לֹא־בְתַאֲוָה וַעֲגָבִים כְּדֶרֶךְ הַגּוֹיִם אֲשֶׁר לֹא יָדְעוּ אֶת־הָאֱלֹהִים׃  
\v 6 \vp ו\vp* וְלֹא־יִפְרֹץ אִישׁ אֶת־אָחִיו וְלֹא יוֹנֶנּוּ בַּדָּבָר הַזֶּה כִּי נֹקֵם יְהוָֹה עַל־כָּל־אֵלֶּה כַּאֲשֶׁר הִגַּדְנוּ וְהַעִידֹנוּ בָכֶם מֵאָז׃  
\v 7 \vp ז\vp* כִּי לֹא־לְתוֹעֵבָה קָרָא אֹתָנוּ אֱלֹהֵינוּ כִּי אִם־לְדֶרֶךְ הַקֹּדֶשׁ׃  
\v 8 \vp ח\vp* וְעַל־כֵּן הַבֹּזֶה לֹא אֶת־אָדָם הוּא בֹזֶה כִּי אִם־אֶת־אֱלֹהִים אֲשֶׁר נָתַן לָכֶם רוּחַ קָדְשׁוֹ׃  
\v 9 \vp ט\vp* וְעַל־דְּבַר אַהֲבַת אַחִים אֵין־לָנוּ לִכְתֹּב דָּבָר אֲלֵיכֶם כִּי הֲלֹא אַתֶּם לִמּוּדֵי אֱלֹהִים לְאַהֲבָה אִישׁ אֶת־אָחִיו׃  
\v 10 \vp י\vp* וְכֵן גַּם־עֲשִׂיתֶם לְכָל־אֲחֵיכֶם אֲשֶׁר בְּמַקְדּוֹנְיָא כֻלָּהּ רַק־נִתְחַנֵּן אֲלֵיכֶם אַחַי כִּי כֵן תַּעֲשׂוּ וְכֵן תּוֹסִיפוּ׃  
\v 11 \vp יא\vp* וְתִתְאַמְּצוּ לָשֶׁבֶת בְּהַשְׁקֵט לַעֲשׂוֹת אִישׁ אֶת־מְלַאכְתּוֹ וְלִחְיוֹת עַל־יְגִיעַ כַּפָּיו כַּאֲשֶׁר צִוִּינוּ אֶתְכֶם׃  
\v 12 \vp יב\vp* וּבְכֵן תִּתְהַלְּכוּ בְמִישׁוֹר אֶת־אֵלֶּה אֲשֶׁר מִחוּץ לַעֲדָתֵנוּ וְלֹא יֶחְסַר לָכֶם כָּל־דָּבָר׃  
\v 13 \vp יג\vp* וְעַל־דְּבַר יְשֵׁנֵי עָפָר חָפַצְנוּ כִּי תֵדְעוּן כִּי לֹא לָכֶם לְהִתְאַבֵּל כַּאֲנָשִׁים אֲשֶׁר אֵין־לָהֶם תִּקְוָה׃  
\v 14 \vp יד\vp* כִּי כַאֲשֶׁר נַאֲמִין כִּי יֵשׁוּעַ מֵת וַיֶּחִי כֵּן גַּם־אֶת־הַיְשֵׁנִים עַל־יְדֵי יֵשׁוּעַ יָקִים אֱלֹהִים לְפָנָיו׃  
\v 15 \vp טו\vp* כִּי כָזֹאת אָנוּ אֹמְרִים לָכֶם בִּדְבַר יְהוָֹה כִּי אֲנַחְנוּ הַנִּשְׁאָרִים פֹּה בַחַיִּים לְמוֹעֵד בּוֹא אֲדֹנֵינוּ לֹא נְקַדֵּם אֶת־הַיְשֵׁנִים׃  
\v 16 \vp טז\vp* כִּי בִתְרוּעָה יֵרֵד אֲדֹנֵינוּ מִן־הַשָּׁמַיִם בְּקוֹל שׁוֹפַר אֱלֹהִים מִפִּי שַׂר־צְבָא הַמָּרוֹם וְהַמֵּתִים בַּמָּשִׁיחַ יָקוּמוּ אָז רִאשׁוֹנָה׃  
\v 17 \vp יז\vp* וְאַחֲרֵי־כֵן אֲנַחְנוּ הַנִּשְׁאָרִים בַּחַיִּים נִלָּקַח וְנַעֲלֶה עִמָּהֶם יַחְדָּו בַּעֲנָנִים לִקְרַאת הָאָדוֹן בִּרְקִיעַ הַשָּׁמָיִם וְכֵן נִהְיֶה עִם־הָאָדוֹן לָנֶצַח׃  
\v 18 \vp יח\vp* לָכֵן אֵפוֹא נַחֲמוּ אִישׁ אֶת־רֵעֵהוּ בִּדְבָרִים כָּאֵלֶּה׃   
\c 5
\cp  ה
\cl פרק ה 
\p
\v 1 \vp א\vp* וְעַל־דְּבַר הָעִתִּים וְהַזְּמַנִּים אֵין־דָּבָר אַחַי לְהִכָּתֵב לָכֶם׃  
\v 2 \vp ב\vp* הֲלֹא יְדַעְתֶּם הֵיטֵב כִּי יוֹם־יְהוָֹה כְּגַנָּב בַּלַּיְלָה יָבוֹא׃  
\v 3 \vp ג\vp* כַּאֲשֶׁר יֹאמְרוּ שָׁלוֹם וְשַׁלְוָה אָז פִּתְאֹם יָבוֹא עֲלֵיהֶם אֵידָם כְּחֶבְלֵי יוֹלֵדָה וְלֹא יִמָּלֵט לָהֶם פָּלִיט׃  
\v 4 \vp ד\vp* אֲבָל אַתֶּם אַחַי אֵינְכֶם בַּחֹשֶׁךְ אֲשֶׁר יָבוֹא עֲלֵיכֶם הַיּוֹם כְּגַנָּב׃  
\v 5 \vp ה\vp* כִּי כֻלְּכֶם בְּנֵי אוֹר וּבְנֵי יוֹם אַתֶּם לֹא בְנֵי לַיְלָה וְלֹא בְנֵי חשֶׁךְ אֲנָחְנוּ׃  
\v 6 \vp ו\vp* עַל־כֵּן אֵין לָנוּ לִישׁוֹן כִּשְׁאָר הָאֲנָשִׁים כִּי אִם־נִשְׁקֹד וְנִשְׁתַּמֵּר מִשִּׁכָּרוֹן׃  
\v 7 \vp ז\vp* כִּי הַיְשֵׁנִים יִישְׁנוּ בַלָּיְלָה וְהַשִּׁכֹּרִים יִשְׁכְּרוּן בַּלָּיְלָה׃  
\v 8 \vp ח\vp* וַאֲנַחְנוּ בְנֵי יוֹם נִשְׁתַּמֵּר מִשְּׁכָּרוֹן וְנִלְבַּשׁ שִׁרְיוֹן אֱמוּנָה וְאַהֲבָה וּלְכוֹבַע לָנוּ תִּקְוַת הַיְשׁוּעָה׃  
\v 9 \vp ט\vp* כִּי לֹא־יָצַר אֹתָנוּ אֱלֹהִים לְכַלֹּתֵנוּ בְאַפּוֹ כִּי אִם־לְהָבִיא לָנוּ יְשׁוּעָה בְּיַד־יֵשׁוּעַ הַמָּשִׁיחַ אֲדֹנֵינוּ׃  
\v 10 \vp י\vp* הוּא אֲשֶׁר מֵת בַּעֲדֵנוּ וְאִם־נָקִיץ אוֹ־נִישַׁן עִמּוֹ נִחְיֶה יַחְדָּו׃  
\v 11 \vp יא\vp* עַל־כֵּן הַזְהִירוּ אִישׁ אֶת־רֵעֵהוּ וְהָשִׁיבוּ אִישׁ אֶת־נֶפֶשׁ אָחִיו כַּאֲשֶׁר עֲשִׂיתֶם עַד־כֹּה׃  
\v 12 \vp יב\vp* וַאֲנַחְנוּ נִפְצַר בָּכֶם אַחִים לָדַעַת בְּשׂוּם לֵב אֶת־הָעֲמֵלִים בָּכֶם וְאֶת־הַנִּצָּבִים עֲלֵיכֶם בְּשֵׁם הָאָדוֹן וְאֶת־הַמּוֹכִיחִים אֶתְכֶם׃  
\v 13 \vp יג\vp* וּלְהַכִּיר יְקַר עֶרְכָּם הַגָּדוֹל לְאַהֲבָה אֹתָם לְמַעַן פָּעֳלָם וְהַחֲזִיקוּ שָׁלוֹם בֵּינֵיכֶם׃  
\v 14 \vp יד\vp* וְאַתֶּם אַחֵינוּ נַזְהִיר אֶתְכֶם הוֹכִיחוּ אֶת־הַמַּמְרִים אַמְּצוּ אֶת־רַכֵּי הַלֵּבָב סַעֲדוּ אֶת־החֹלִים וְהַאֲרִיכוּ אַף לְכָל־אָדָם׃  
\v 15 \vp טו\vp* הִשָּׁמְרוּ פֶּן־יִגְמֹל אִישׁ לְאִישׁ רָעָה תַּחַת רָעָה כִּי אִם־רִדְפוּ לְהֵיטִיב תָּמִיד לְאִישׁ אִישׁ מִכֶּם וְגַם לְכָל־אָדָם׃  
\v 16 \vp טז\vp* וְאַךְ שְׂמֵחִים תִּהְיוּ כָּל־הַיָּמִים׃  
\v 17 \vp יז\vp* וְלֹא תַחְדְּלוּ מֵהִתְפַּלֵּל תָּמִיד׃  
\v 18 \vp יח\vp* הוֹדוּ עַל־כָּל־דָּבָר כִּי־זֶה לָכֶם חֵפֶץ אֱלֹהִים בְּיֵשׁוּעַ הַמָּשִׁיחַ׃  
\v 19 \vp יט\vp* לֹא תְכַבּוּ אֶת־הָרוּחַ׃  
\v 20 \vp כ\vp* וְאֶת־הַנְּבוּאוֹת לֹא תִפְרָעוּ׃  
\v 21 \vp כא\vp* בַּחֲנוּ כָּל־דָּבָר וְהַחֲזִיקוּ בַּטּוֹב׃  
\v 22 \vp כב\vp* וּמִכָּל־שֶׁמֶץ דָּבָר רָע אַף לְמַרְאֵה עָיִן הַרְחִיקוּ רַגְלֵיכֶם׃  
\v 23 \vp כג\vp* וֵאלֹהֵי הַשָּׁלוֹם הוּא יְקַדֵּשׁ אֶתְכֶם מֵחָחֵל וְעַד־כַּלֵּה וְיִשְׁמָרְכֶם מִכָּל־רָע בְּרוּחַ נֶפֶשׁ וּגְוִיָּה לְמוֹעֵד בּוֹא אֲדֹנֵינוּ יֵשׁוּעַ הַמָּשִׁיחַ׃  
\v 24 \vp כד\vp* נֶאֱמָן הוּא הַקֹּרֵא אֶתְכֶם וְהוּא גַּם־יַעֲשֶׂה׃  
\v 25 \vp כה\vp* אָנָּא אֶחָי הִתְפַּלְּלוּ־נָא בַּעֲדֵנוּ׃  
\v 26 \vp כו\vp* שַׁאֲלוּ לִשְׁלוֹם כָּל־הָאַחִים בִּנְשִׁיקַת הַקֹּדֶשׁ׃  
\v 27 \vp כז\vp* הִנְנִי מַשְׁבִּיעֲכֶם בַּאֲדֹנֵינוּ לָתֵת הָאִגֶּרֶת הַזֹּאת לְהִקָּרֵא בְאָזְנֵי כָל־הָאַחִים הַקְּדוֹשִׁים׃  
\v 28 \vp כח\vp* חֶסֶד יֵשׁוּעַ הַמָּשִׁיחַ אֲדֹנֵינוּ עִמָּכֶם אָמֵן׃   