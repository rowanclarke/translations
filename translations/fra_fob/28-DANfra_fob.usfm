\c 4
\p 
\v 1 \w Nébucadnetsar|strong="H5020"\w*, roi, à tous les peuples, aux nations \w et|strong="H1005"\w* langues qui habitent sur toute la terre. Que votre paix \w soit|strong="H1005"\w* multipliée!
\v 2 \w Il|strong="H5922"\w* m'\w a|strong="H3068"\w* semblé bon \w de|strong="H5922"\w* faire connaître \w les|strong="H5922"\w* signes et \w les|strong="H5922"\w* prodiges que \w le|strong="H5922"\w* \w Dieu|strong="H5922"\w* souverain \w a|strong="H3068"\w* faits \w en|strong="H2370"\w* \w ma|strong="H5922"\w* faveur.
\v 3 \w Que|strong="H1768"\w* ses \w signes|strong="H4481"\w* \w sont|strong="H4481"\w* \w grands|strong="H3606"\w*! \w et|strong="H4481"\w* ses prodiges pleins \w de|strong="H4481"\w* force! \w Son|strong="H4481"\w* \w règne|strong="H4481"\w* \w est|strong="H2493"\w* \w un|strong="H4481"\w* \w règne|strong="H4481"\w* éternel, \w et|strong="H4481"\w* \w sa|strong="H4481"\w* domination dure \w de|strong="H4481"\w* \w génération|strong="H4481"\w* \w en|strong="H4481"\w* \w génération|strong="H4481"\w*!
\v 4 \w Moi|strong="H6925"\w*, Nébucadnetsar, j'étais tranquille \w dans|strong="H5954"\w* ma maison, \w et|strong="H3809"\w* florissant \w dans|strong="H5954"\w* mon palais.
\v 5 \w J|strong="H3068"\w*'eus \w un|strong="H5705"\w* \w songe|strong="H2493"\w* \w qui|strong="H1841"\w* m'épouvanta, \w et|strong="H1841"\w* \w mes|strong="H5705"\w* \w pensées|strong="H5954"\w* sur \w ma|strong="H1841"\w* couche \w et|strong="H1841"\w* \w les|strong="H5954"\w* \w visions|strong="H5954"\w* \w de|strong="H5705"\w* \w ma|strong="H1841"\w* tête \w me|strong="H6925"\w* troublèrent.
\v 6 \w Et|strong="H3809"\w* \w de|strong="H3809"\w* ma part \w ordre|strong="H2370"\w* \w fut|strong="H3809"\w* donné \w de|strong="H3809"\w* faire \w venir|strong="H3809"\w* devant moi \w tous|strong="H3606"\w* \w les|strong="H3606"\w* \w sages|strong="H3606"\w* \w de|strong="H3809"\w* Babylone, \w afin|strong="H1768"\w* \w qu|strong="H1768"\w*'ils me \w donnassent|strong="H3046"\w* l'interprétation \w du|strong="H6591"\w* \w songe|strong="H2493"\w*.
\v 7 Alors vinrent \w les|strong="H5922"\w* magiciens, \w les|strong="H5922"\w* astrologues, \w les|strong="H5922"\w* Caldéens \w et|strong="H7690"\w* \w les|strong="H5922"\w* devins, \w et|strong="H7690"\w* \w je|strong="H1934"\w* \w leur|strong="H5922"\w* \w dis|strong="H5922"\w* \w le|strong="H5922"\w* songe, mais ils ne m'\w en|strong="H1934"\w* firent pas connaître l'interprétation.
\v 8 \w Et|strong="H7236"\w* à \w la|strong="H3606"\w* \w fin|strong="H5491"\w*, Daniel, \w qui|strong="H3606"\w* est nommé Beltshatsar, selon \w le|strong="H3606"\w* \w nom|strong="H3606"\w* \w de|strong="H7314"\w* mon \w dieu|strong="H3606"\w*, \w et|strong="H7236"\w* en \w qui|strong="H3606"\w* est l'esprit \w des|strong="H3606"\w* dieux saints, \w se|strong="H8065"\w* présenta devant moi, \w et|strong="H7236"\w* je \w lui|strong="H3606"\w* dis \w le|strong="H3606"\w* \w songe|strong="H3606"\w*.
\v 9 Beltshatsar, chef \w des|strong="H4481"\w* magiciens, \w comme|strong="H4481"\w* je sais \w que|strong="H3606"\w* l'esprit \w des|strong="H4481"\w* \w dieux|strong="H4481"\w* saints est \w en|strong="H4481"\w* toi, \w et|strong="H4481"\w* \w que|strong="H3606"\w* nul secret ne \w t|strong="H4481"\w*'est difficile, dis-moi \w les|strong="H3606"\w* \w visions|strong="H4481"\w* \w que|strong="H3606"\w* \w j|strong="H4481"\w*'ai eues \w en|strong="H4481"\w* \w songe|strong="H3606"\w* \w et|strong="H4481"\w* donne-m'\w en|strong="H4481"\w* l'interprétation.
