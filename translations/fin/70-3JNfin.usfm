\id 3JN - Biblica® Open Finnish Living News New Testament 
\h 3 Johanneksen Kirje 
\toc1 Johanneksen kolmas kirje 
\toc2 3. Johanneksen kirje 
\toc3 3 Joh. 
\mt1 Johanneksen Kolmas Kirje 
\c 1  
\p  
\v 1 \add Lähettäjä:\add* Johannes, seurakunnan johtaja. 
\p \add Vastaanottaja:\add* Gaius, rakas ystäväni. 
\p  
\v 2 Toivon, että voit hyvin ja olet ruumiillisesti yhtä hyvässä kunnossa kuin hengellisesti.  
\v 3 Tulin kovin iloiseksi, kun kuulin täällä käyneiltä uskonveljiltä, että taistelet totuuden puolesta ja elät niin kuin Jumalan sana edellyttää.  
\v 4 Tällaiset uutiset lapsistani ilahduttavat minua enemmän kuin mikään muu. 
\p  
\v 5 Teet hyvää työtä, kun pidät huolta kiertävistä opettajista ja lähetystyöntekijöistä.  
\v 6 He ovat kertoneet meidän seurakunnallemme ystävällisyydestäsi ja avustasi. Olen iloinen, kun autat heitä heidän matkallaan.  
\v 7 Herran asioissahan he matkustavat eivätkä ota vastaan minkäänlaista avustusta niiltä, jotka eivät ole kristittyjä.  
\v 8 Siksi meidän on pidettävä heistä huolta ja toimittava yhdessä heidän kanssaan totuuden puolesta. 
\p  
\v 9 Kirjoitin tästä seurakunnalle, mutta Diotrefes, joka haluaa kovasti esiintyä johtajana, ei tunnusta minun asemaani.  
\v 10 Kerron sitten kun tulen, mitä hän puuhailee ja mitä huhuja hän meistä levittää. Hän ei suostu ottamaan vastaan kiertäviä Jumalan sanan julistajia ja estää muitakin tekemästä niin. Jos joku ei tottele häntä, hän erottaa tämän seurakunnasta. 
\p  
\v 11 Älä vain noudata hänen esimerkkiään! Ota sinä oppia sellaisesta, mikä on hyvää. Muista, että ne, jotka tekevät oikein, osoittavat olevansa Jumalan lapsia. Jos joku jatkuvasti tekee pahaa, hän on kaukana Jumalasta.  
\v 12 Demetriuksesta kaikilla on vain hyvää sanottavana. Totuus itse puhuu hänen puolestaan, samoin minä, ja tiedät, että puhun totta. 
\p  
\v 13 Minulla on paljon asiaa, mutta en halua kertoa kaikkea kirjeessä.  
\v 14 Toivon, että tapaamme pian ja saamme puhua kaikesta.  
\v 15 Siis näkemiin! Ystävät lähettävät sinulle täältä terveisensä. Sanothan sinne jokaiselle erikseen minulta terveisiä.