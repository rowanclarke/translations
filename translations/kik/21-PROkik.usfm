\id PRO - Biblica® Open Kikuyu Holy Word of God
\h Thimo
\toc1 Thimo
\toc2 Thimo
\toc3 Thim
\mt1 THIMO
\c 1
\s1 Ciugo cia Kwambĩrĩria: Gĩtũmi na Muoroto
\q1 
\v 1 Ici nĩ thimo cia Solomoni mũrũ wa Daudi, ũrĩa warĩ mũthamaki wa Isiraeli:
\b
\q1 
\v 2 nĩ thimo cia gũtũma mũndũ agĩe na ũũgĩ, na ataarĩke;
\q2 nĩ cia gũtũma ahote gũtaũkĩrwo nĩ ciugo cia ũũgĩ;
\q1 
\v 3 nĩ cia gũtũma mũndũ ataarĩke ahote kũbarĩrĩra mũtũũrĩre wake,
\q2 ekage maũndũ marĩa magĩrĩire, na ma kĩhooto, na marĩa mega;
\q1 
\v 4 nĩ cia gũtũma ũrĩa ũtarĩ na ũũgĩ agĩe na ũmenyo,
\q2 na cia gũtũma mũndũ mwĩthĩ agĩe na ũmenyo na ũgereri:
\q1 
\v 5 arĩa oogĩ-rĩ, nĩmathikĩrĩrie na mongerere wĩruti wao,
\q2 nao arĩa akũũrani maũndũ metĩkĩre gũtongorio.
\q1 
\v 6 Ningĩ nĩ cia gũtũma mũndũ ataũkĩrwo nĩ thimo na ngerekano,
\q2 na ataũkĩrwo nĩ ciugo cia andũ arĩa oogĩ, na ndaĩ ciao.
\b
\q1 
\v 7 Kĩambĩrĩria kĩa ũmenyo nĩ gwĩtigĩra Jehova,
\q2 no arĩa akĩĩgu nĩ mathũire ũũgĩ na ũtaaro.
\s1 Mwĩmenyererei Kũheenererio
\q1 
\v 8 Mũrũ wakwa, thikĩrĩria mataaro ma thoguo,
\q2 na ndũgatigane na ũrutani wa maitũguo.
\q1 
\v 9 Maũndũ macio magaatuĩka ithaga rĩa kũgemia mũtwe waku,
\q2 na ta mũgathĩ wa kũgemia ngingo yaku.
\q1 
\v 10 Mũrũ wakwa, ehia mangĩgakũheenereria-rĩ,
\q2 ndũkanetĩkanie nao.
\b
\q1 
\v 11 Mangĩgakwĩra atĩrĩ, “Ũka ũthiĩ hamwe na ithuĩ;
\q2 reke tuoherie mũndũ tũite thakame yake,
\q2 reke tũcemaceeme mũndũ o na ũtehĩtie;
\q1 
\v 12 ningĩ reke tũmamerie marĩ muoyo, o ta ũrĩa mbĩrĩra ĩĩkaga,
\q2 na marĩ agima, o ta arĩa maharũrũkaga irima;
\q1 
\v 13 Na ithuĩ-rĩ, tũkĩgĩe na indo cia goro cia mĩthemba yothe,
\q2 na tũiyũrie nyũmba ciitũ na indo cia ndaho;
\q1 
\v 14 rutithania wĩra na ithuĩ,
\q2 tũkorwo na mũhuko ũmwe ithuothe”;
\q1 
\v 15 mũrũ wakwa, tiga gũtwarana nao,
\q2 ndũkagerere njĩra ciao;
\q1 
\v 16 nĩgũkorwo magũrũ mao mahanyũkaga mathiĩ mehia-inĩ,
\q2 nao mahiũhaga magaite thakame.
\q1 
\v 17 Kaĩ nĩ wĩra wa tũhũ kũiga gĩkerenge
\q2 nyoni ciothe igĩkuonaga-ĩ!
\q1 
\v 18 Andũ aya mohagĩria thakame yao ene;
\q2 maceemaga o mĩoyo yao ene!
\q1 
\v 19 Ũcio nĩguo mũthia wa arĩa othe magĩaga na indo na njĩra ya ungumania;
\q2 indo icio iniinaga mĩoyo ya arĩa magĩaga nacio.
\s1 Mwĩmenyererei Mũtikarege Ũũgĩ
\q1 
\v 20 Ũũgĩ nĩ aretana anĩrĩire njĩra-inĩ,
\q2 ningĩ agakayũrũrũka arĩ ihaaro-inĩ cia mũingĩ;
\q1 
\v 21 Aragũthũka na mũgambo mũnene arĩ magomano-inĩ ma njĩra kũu kũrĩ inegene,
\q2 o na itoonyero rĩa itũũra inene akoria atĩrĩ:
\b
\q1 
\v 22 “Inyuĩ mũtarĩ ũũgĩ-rĩ, nĩ nginya rĩ mũgũtũũra mwendete njĩra cianyu itarĩ cia ũũgĩ?
\q2 Nĩ nginya rĩ anyũrũrania megũtũũra makenagĩra kĩnyũrũri,
\q2 na arĩa akĩĩgu mathũire ũmenyo?
\q1 
\v 23 Korwo nĩmwetĩkĩrire kũigua ũtaaro wakwa-rĩ,
\q2 nĩingĩamũhingũrĩire ngoro yakwa,
\q2 ndũme mũmenye meciiria makwa.
\q1 
\v 24 No tondũ nĩmwaregire kũnjigua rĩrĩa ndetanire,
\q2 na gũtirĩ mũndũ werũmbũirie hĩndĩ ĩrĩa ndatambũrũkirie guoko gwakwa,
\q1 
\v 25 na mũkĩagĩra mataaro makwa mothe bata,
\q2 na mũkĩaga gwĩtĩkĩra ikaanania rĩakwa-rĩ,
\q1 
\v 26 niĩ na niĩ nĩngamũthekerera hĩndĩ yanyu ya mwanangĩko,
\q2 na ndĩmũnyũrũrie rĩrĩa mũgaakorererwo nĩ mũtino:
\q1 
\v 27 ĩĩ hĩndĩ ĩrĩa guoya ũkaamũkorerera ta kĩhuhũkanio,
\q2 rĩrĩa mwanangĩko ũkaamũhaata ta rũhuho rwa kĩhuhũkanio,
\q2 rĩrĩa mũgaakinyĩrĩrwo nĩ mĩnyamaro na ruo rwa ngoro.
\b
\q1 
\v 28 “Hĩndĩ ĩyo nĩmakangaĩra, no ndikametĩka;
\q2 nĩmakanjetha na kĩyo, no matikanyona.
\q1 
\v 29 Tondũ nĩmathũũrire ũmenyo,
\q2 na matiigana gũthuura gwĩtigĩra Jehova,
\q1 
\v 30 tondũ matietĩkĩrire mataaro makwa,
\q2 na nĩmamenire ikaanania rĩakwa,
\q1 
\v 31 makaarĩa maciaro ma mĩthiĩre yao,
\q2 na mahũũnio nĩ maciaro ma mathugunda mao.
\q1 
\v 32 Nĩgũkorwo ũgenyũ wa arĩa matarĩ ũũgĩ nĩũkamooraga,
\q2 nakuo kwĩgangara kwa arĩa akĩĩgu nĩgũkamaniina;
\q1 
\v 33 no ũrĩa wothe ũnjiguaga arĩtũũraga na thayũ,
\q2 na atũũre ahooreire, atarĩ ũgwati angĩĩtigĩra.”
\c 2
\s1 Uumithio wa Ũũgĩ Mũtũũrĩre-inĩ
\q1 
\v 1 Mũrũ wakwa, ũngĩtĩkĩra ciugo ciakwa,
\q2 na ũige maathani makwa ta mũthiithũ thĩinĩ waku,
\q1 
\v 2 nakuo gũtũ gwaku ũgũtegere ũũgĩ,
\q2 na werekerie ngoro yaku kũgĩa na ũmenyi,
\q1 
\v 3 na ũngĩgaakayũrũrũka na ũhooe gũkũũrana maũndũ,
\q2 na wĩtane wanĩrĩire ũheo ũtaũku,
\q1 
\v 4 na ũngĩkawetha ta betha,
\q2 na ũũcarie ta kĩgĩĩna kĩhithe-rĩ,
\q1 
\v 5 hĩndĩ ĩyo nĩũgataũkĩrwo nĩ ũhoro wa gwĩtigĩra Jehova,
\q2 na ũgĩe na ũmenyo wa Ngai.
\q1 
\v 6 Nĩgũkorwo Jehova aheanaga ũũgĩ,
\q2 na kanua gake koimaga ũmenyo na ũtaũku.
\q1 
\v 7 Andũ arĩa arũngĩrĩru amaigĩire ũhootani,
\q2 nĩwe ngo ya arĩa matarĩ ũcuuke mĩthiĩre-inĩ yao,
\q1 
\v 8 nĩgũkorwo nĩarangagĩra njĩra cia arĩa marũmagĩrĩra kĩhooto,
\q2 na akagitĩra njĩra ya andũ ake arĩa ehokeku.
\b
\q1 
\v 9 Hĩndĩ ĩyo nĩũgakũũrana maũndũ marĩa magĩrĩire,
\q2 na ma kĩhooto, na marĩa mega: ũgĩkũũrane njĩra o yothe njega.
\q1 
\v 10 Nĩgũkorwo ũũgĩ nĩũgatoonya ngoro yaku,
\q2 naguo ũmenyo ũkenagie muoyo waku.
\q1 
\v 11 ũgereri nĩũrĩkũgitagĩra,
\q2 naguo ũtaũku ũkũrangagĩre.
\b
\q1 
\v 12 Ũũgĩ nĩũgakũhonokia kuuma njĩra-inĩ cia andũ arĩa aaganu,
\q2 ũkũhonokie kuuma kũrĩ andũ arĩa maaragia maũndũ ma waganu,
\q1 
\v 13 o arĩa matigaga njĩra iria nũngĩrĩru,
\q2 magathiĩra njĩra cia nduma,
\q1 
\v 14 arĩa makenaga magĩĩka ũũru,
\q2 na magakenagio nĩ ũũru wa waganu,
\q1 
\v 15 na no-o arĩa njĩra ciao ciogomete,
\q2 na mĩthiĩre yao ĩrĩ ya ungumania.
\b
\q1 
\v 16 Ũũgĩ nĩũgakũhonokia kuuma harĩ mũtumia ũrĩa mũtharia,
\q2 ũkũhonokie harĩ ngʼenyũ ya mũtumia na ciugo ciake cia kũheenereria andũ,
\q1 
\v 17 ũcio ũtigĩte mũratawe wa ũnini wake,
\q2 na agatiganĩria kĩrĩkanĩro kĩrĩa aarĩkanĩire na mũthuuriwe arĩ mbere ya Ngai.
\q1 
\v 18 Nĩgũkorwo nyũmba yake ĩroragia andũ gĩkuũ-inĩ,
\q2 nacio njĩra ciake ikamerekeria kũrĩ maroho ma arĩa akuũ.
\q1 
\v 19 Gũtirĩ mũndũ ũthiiaga harĩ we agacooka,
\q2 kana akegwatĩra njĩra cia muoyo.
\b
\q1 
\v 20 No rĩrĩ, wee nĩũrĩthiiaga na mĩthiĩre ya andũ arĩa ega,
\q2 na ũgeragĩre njĩra cia arĩa athingu.
\q1 
\v 21 Nĩgũkorwo andũ arĩa arũngĩrĩru nĩo magaatũũra bũrũri-inĩ,
\q2 na arĩa matarĩ ũcuuke nĩo magaatigara kuo;
\q1 
\v 22 no rĩrĩ, andũ arĩa aaganu nĩmakeeherio bũrũri-inĩ,
\q2 nao arĩa matarĩ ehokeku nĩmakamunywo maingatwo kuo.
\c 3
\s1 Mauumithio mangĩ ma Ũũgĩ
\q1 
\v 1 Mũrũ wakwa, ndũkariganĩrwo nĩ ũrutani wakwa,
\q2 no ngoro yaku nĩĩrũmagie maathani makwa,
\q1 
\v 2 nĩgũkorwo nĩmagakuongerera matukũ ũtũũre mĩaka mĩingĩ,
\q2 na matũme ũgaacĩre.
\b
\q1 
\v 3 Ndũkanareke wendani na wĩhokeku ikweherere;
\q2 cioherere ngingo yaku,
\q2 ũciandĩke kĩhengere-inĩ kĩa ngoro yaku.
\q1 
\v 4 Weka ũguo nĩũgeetĩkĩrĩka, na ũgĩe na rĩĩtwa rĩega
\q2 maitho-inĩ ma Ngai o na ma andũ.
\b
\q1 
\v 5 Wĩhoke Jehova na ngoro yaku yothe,
\q2 na ndũkanehoke ũmenyo waku mwene;
\q1 
\v 6 mũmenyithagie mĩthiĩre yaku yothe,
\q2 na nĩarĩrũngaga njĩra ciaku.
\b
\q1 
\v 7 Tiga kwĩonaga ũrĩ mũũgĩ maitho-inĩ maku mwene;
\q2 wĩtigĩre Jehova na ũtheemage maũndũ marĩa mooru.
\q1 
\v 8 Ũndũ ũcio nĩũrĩkũrehagĩra ũgima wa mwĩrĩ,
\q2 na mahĩndĩ maku makoragwo marĩ na hinya.
\b
\q1 
\v 9 Tĩĩaga Jehova na ũtonga waku,
\q2 ningĩ ũmũtĩĩage na maciaro mothe ma mbere ma irio ciaku cia mĩgũnda;
\q1 
\v 10 namo makũmbĩ maku nĩmakaiyũrĩrĩra,
\q2 nayo mĩtũngi yaku ĩiyũrĩrĩre ndibei ya mũhihano.
\b
\q1 
\v 11 Mũrũ wakwa, tiga kũnyarara ihũũra rĩa Jehova,
\q2 na ndũgathũũre irũithia rĩake,
\q1 
\v 12 nĩgũkorwo Jehova arũithagia arĩa endete,
\q2 o ta ũrĩa ithe wa mũndũ arũithagia mũriũ ũrĩa akenagĩra.
\b
\q1 
\v 13 Kũrathimwo-rĩ, nĩ mũndũ ũrĩa wonete ũũgĩ,
\q2 mũndũ ũcio wĩgĩĩrĩire na ũmenyo,
\q1 
\v 14 nĩgũkorwo ũũgĩ nĩ wa bata mũno gũkĩra betha,
\q2 na ũciaraga uumithio ũkĩrĩte wa thahabu.
\q1 
\v 15 Ũũgĩ ũrĩ goro gũkĩra ruru iria ndune;
\q2 kĩrĩa gĩothe ũngĩĩrirĩria gũtirĩ kĩngĩringithanio naguo.
\q1 
\v 16 Guoko-inĩ gwake kwa ũrĩo harĩ ũingĩ wa matukũ;
\q2 guoko-inĩ gwake kwa ũmotho harĩ na ũtonga na gĩtĩĩo.
\q1 
\v 17 Mĩthiĩre ya ũũgĩ nĩ mĩthiĩre ya kwendeka,
\q2 na njĩra ciaguo ciothe nĩ cia thayũ.
\q1 
\v 18 Ũũgĩ nĩ mũtĩ wa muoyo kũrĩ arĩa maũhĩmbagĩria;
\q2 arĩa megĩagĩra naguo-rĩ, nĩmarĩrathimagwo.
\b
\q1 
\v 19 Jehova aahandire mĩthingi ya thĩ na ũũgĩ,
\q2 na akĩrũmia igũrũ na ũmenyo wake;
\q1 
\v 20 ũmenyo wake nĩguo wagayanirie kũrĩa kũriku,
\q2 namo matu magatatagia ime.
\b
\q1 
\v 21 Mũrũ wakwa tũũria matua mega na ũkũũrani maũndũ,
\q2 ndũkanareke ciehere maitho-inĩ maku;
\q1 
\v 22 nĩcio igaagũtũũria muoyo, na nĩ ithaga rĩa kũgemagia ngingo yaku.
\q1 
\v 23 Ningĩ ũrĩthiiaga na njĩra yaku ũrĩ na thayũ,
\q2 na kũgũrũ gwaku gũtikahĩngwo;
\q1 
\v 24 Wakoma-rĩ, ndũgetigĩra;
\q2 wakoma-rĩ, ũrĩkomaga toro mwega.
\q1 
\v 25 Ndũgetigĩre mwanangĩko wa narua,
\q2 kana kĩhuhũkanio kĩrĩa gĩkoragĩrĩra andũ arĩa aaganu,
\q1 
\v 26 nĩgũkorwo Jehova nĩwe ũgaatuĩka mwĩhoko waku,
\q2 na amenyagĩrĩre kũgũrũ gwaku gũtikanyiitwo nĩ mũtego.
\b
\q1 
\v 27 Ndũkanagirĩrĩrie ũndũ mwega ũkinyĩre arĩa maagĩrĩirwo nĩgũkinyĩrĩrwo nĩguo,
\q2 rĩrĩa ũrĩ na ũhoti wa kũhingia ũndũ ũcio.
\q1 
\v 28 Ndũkaneere mũndũ wa itũũra rĩaku atĩrĩ,
\q2 “Thiĩ ũgooka rĩngĩ; kĩu ũrenda nĩngakũhe rũciũ,”
\q2 o rĩrĩa ũrĩ na kĩndũ kĩu hakuhĩ.
\b
\q1 
\v 29 Ndũkanaciirĩre gwĩka mũndũ wa itũũra rĩaku ũũru,
\q2 ũcio ũtũũraga hakuhĩ nawe akwĩhokete.
\q1 
\v 30 Ndũkanarũithie mũndũ tũhũ,
\q2 rĩrĩa atarĩ ũndũ mũũru agwĩkĩte.
\b
\q1 
\v 31 Ndũkanacumĩkĩre maũndũ ma mũndũ wa ngũĩ,
\q2 kana ũthuure njĩra o na ĩmwe yake,
\q1 
\v 32 nĩgũkorwo Jehova nĩathũire mũndũ mwaganu,
\q2 no nĩagĩĩaga ndundu na andũ arĩa arũngĩrĩru.
\b
\q1 
\v 33 Nyũmba ya arĩa aaganu ĩtũũraga na kĩrumi kĩa Jehova,
\q1 no mũciĩ wa arĩa athingu nĩaũrathimaga.
\q1 
\v 34 Jehova nĩanyũrũragia andũ arĩa manyũrũranagia na mwĩtĩĩo,
\q2 no arĩa menyiihagia nĩamaheaga wega wake.
\q1 
\v 35 Andũ arĩa oogĩ magayaga gĩtĩĩo,
\q2 no andũ arĩa akĩĩgu magayaga njono.
\c 4
\s1 Ũũgĩ Ũkĩrĩte Indo Ciothe
\q1 
\v 1 Atĩrĩrĩ, inyuĩ ariũ akwa, ta thikĩrĩriai ũrũtani wa thoguo;
\q2 njiguai nĩguo mwĩgĩĩre na kũmenya maũndũ.
\q1 
\v 2 Tondũ ngũmũhe ũrutani mwega,
\q2 nĩ ũndũ ũcio mũtigatirike ũrutani wakwa.
\q1 
\v 3 Rĩrĩa ndaarĩ mwana nyũmba-inĩ ya baba,
\q2 ndĩ o mũndũ mwĩthĩ, na ndĩ mwana wa mũmwe wa maitũ-rĩ,
\q1 
\v 4 baba nĩandutire, akĩnjĩĩra atĩrĩ,
\q2 “Wĩgwatĩre ciugo ciakwa na ngoro yaku yothe;
\q2 rũmia maathani makwa, na nĩũgũtũũra muoyo.
\q1 
\v 5 Gĩa na ũũgĩ, gĩa na kũmenya maũndũ;
\q2 ndũkanariganĩrwo nĩ ciugo ciakwa, kana wahũke kuuma harĩ cio.
\q1 
\v 6 Ndũkanatirike ũũgĩ, naguo nĩũrĩkũgitagĩra;
\q1 
\v 7 Ũũgĩ ũkĩrĩte indo ciothe; nĩ ũndũ ũcio wĩgĩĩre na ũũgĩ.
\q2 Ĩĩ, kaba kũruta indo ciaku ciothe wĩgĩĩre na kũmenya maũndũ.
\q1 
\v 8 Tũũgagĩria ũũgĩ mũno, naguo nĩũrĩkwambararagia;
\q2 ũhĩmbagĩrie, naguo nĩũrĩgũtĩĩithagia.
\q1 
\v 9 Nĩũgagwĩkĩra ithaga rĩa ũtugi mũtwe waku,
\q2 na ũkũhe thũmbĩ thaka mũno.”
\b
\q1 
\v 10 Thikĩrĩria, wee mũrũ wakwa, na wĩtĩkĩre ũrĩa ngũkwĩra,
\q2 nĩgeetha mĩaka ya muoyo waku ĩingĩhe.
\q1 
\v 11 Nguonetie njĩra ya ũũgĩ,
\q2 na ngagũtongoria njĩra-inĩ iria nũngarũ.
\q1 
\v 12 Rĩrĩa ũgũthiĩ, makinya maku matikahĩngĩcwo;
\q2 rĩrĩa ũkũhanyũka-rĩ, ndũkahĩngwo.
\q1 
\v 13 Rũmia ũrutani wakwa, na ndũkanareke ũkweherere;
\q2 ũgitagĩre wega, nĩgũkorwo nĩguo muoyo waku.
\q1 
\v 14 Ndũkanagerere njĩra ya andũ arĩa aaganu,
\q2 kana ũthiĩre njĩra ya andũ arĩa ooru.
\q1 
\v 15 Mĩĩtheemage, na ndũkanamĩgerere;
\q2 mĩhutatĩre, na wĩthiĩre na njĩra yaku.
\q1 
\v 16 Nĩgũkorwo andũ arĩa aaganu matingĩkoma nginya meeke ũũru;
\q2 mooragwo nĩ toro nginya matũme mũndũ ahĩngwo, agwe.
\q1 
\v 17 Marĩĩaga irio iria monete na ũmaramari,
\q2 na makanyua ndibei matunyanĩte na hinya.
\b
\q1 
\v 18 Mĩthiĩre ya andũ arĩa athingu ĩhaana ta ũtheri wa gũgĩkĩa,
\q2 ũrĩa ũthiiaga ũgĩthererũkaga nginya mũthenya barigici.
\q1 
\v 19 No mĩthiĩre ya andũ arĩa aaganu ĩhaana ta nduma ndumanu;
\q2 o matimenyaga kĩrĩa kĩamahĩnga.
\b
\q1 
\v 20 Mũrũ wakwa, ta thikĩrĩria ũrĩa ngũkwĩra;
\q2 tega gũtũ ũigue ciugo ciakwa.
\q1 
\v 21 Ndũkanareke ciehere maitho-inĩ maku,
\q2 ciigage ngoro-inĩ yaku;
\q1 
\v 22 nĩgũkorwo nĩcio itũũragia arĩa maciĩgwatĩire muoyo,
\q2 na igekĩra mwĩrĩ wao wothe ũgima.
\q1 
\v 23 Makĩria ya macio mothe, rangagĩra ngoro yaku,
\q2 nĩgũkorwo nĩyo gĩthima kĩrĩa gĩtherũkaga muoyo.
\q1 
\v 24 Eheria rũnano kanua-inĩ gaku;
\q2 nacio ndeto cia ũmaramari-rĩ, nĩciikare kũraya na iromo ciaku.
\q1 
\v 25 Maitho maku nĩmarorage na mbere,
\q2 ũcũthagĩrĩrie mbere yaku wega.
\q1 
\v 26 Aragania njĩra iria magũrũ maku marĩthiiagĩra,
\q2 na ũthiiagĩre o njĩra iria ngiindĩrĩku.
\q1 
\v 27 Ndũkanaahũke na mwena wa ũrĩo kana wa ũmotho;
\q2 eheria kũgũrũ gwaku kuuma ũũru-inĩ.
\c 5
\s1 Ũtharia Gũkaananio
\q1 
\v 1 Mũrũ wakwa, thikĩrĩria ũũgĩ ũyũ wakwa,
\q2 tega gũtũ wega ũigue ciugo ciakwa cia ũtaũku,
\q1 
\v 2 nĩguo ũtũũrie ũbaarĩrĩri,
\q2 nayo mĩromo yaku ĩtũũrie ũmenyo.
\q1 
\v 3 Nĩgũkorwo mĩromo ya mũtumia mũtharia itaataga ũũkĩ,
\q2 na mĩario yake ĩnyorokete gũkĩra maguta;
\q1 
\v 4 no marigĩrĩrio nĩmũrũrũ ta maaĩ ma nyongo,
\q2 nĩ mũũgĩ ta rũhiũ rwa njora rũrĩa rũũgĩ mbarĩ cierĩ.
\q1 
\v 5 Magũrũ make maikũrũkaga gĩkuũ-inĩ;
\q2 makinya make mathiiaga merekeire o mbĩrĩra.
\q1 
\v 6 Ndeciiragia ũhoro wa njĩra ya muoyo;
\q2 njĩra ciake nĩ njogomu, nowe ndooĩ ũguo.
\b
\q1 
\v 7 Atĩrĩrĩ, ariũ akwa, ta thikĩrĩriai;
\q2 mũtikanatiganĩrie ũrĩa ngũmwĩra.
\q1 
\v 8 Thiiagĩrai njĩra ĩrĩ kũraya nake,
\q2 mũtigakuhĩrĩrie mũrango wa nyũmba yake,
\q1 
\v 9 nĩguo mũtikaheane hinya wanyu mwega kũrĩ andũ angĩ,
\q2 na mĩaka yanyu kũrĩ mũndũ ũtarĩ tha,
\q1 
\v 10 nĩguo ageni matikehũũnie na ũtonga wanyu,
\q2 na kĩrĩa ũnogeire gĩtongie mũciĩ wa mũndũ wa kũngĩ.
\q1 
\v 11 Marigĩrĩrio-inĩ ma muoyo waku nĩũgacaaya,
\q2 hĩndĩ ĩrĩa nyama cia mwĩrĩ waku na mwĩrĩ waku igaakorwo ithirĩte hinya.
\q1 
\v 12 Ũkoiga atĩrĩ, “Hĩ, kaĩ nĩndathũũrire gũtaarwo-ĩ!
\q2 Hĩ, kaĩ ngoro yakwa nĩyamenete kũrũithio-ĩ!
\q1 
\v 13 Ndingĩathĩkĩire arutani akwa,
\q2 kana thikĩrĩrie ataarani akwa.
\q1 
\v 14 Nĩnginyĩte hũgũrũrũ-inĩ cia mwanangĩko,
\q2 ndĩ o gatagatĩ-inĩ ga kĩũngano gĩothe.”
\b
\q1 
\v 15 Atĩrĩrĩ, nyuuaga maaĩ ma itangi rĩaku we mwene,
\q2 maaĩ marĩa mathereraga moimĩte gĩthima-inĩ gĩaku mwene.
\q1 
\v 16 Nĩ kwagĩrĩire ithima ciaku ciunagĩre maaĩ barabara-inĩ,
\q2 kana tũrũũĩ twaku tuunagĩre ihaaro-inĩ cia mũingĩ?
\q1 
\v 17 Nĩmagĩtũũre marĩ maku wiki,
\q2 matigatuĩke maku na mũndũ wa kũngĩ o na rĩ.
\q1 
\v 18 Gĩthima gĩaku kĩrorathimwo,
\q2 nawe ũkenagĩre mũtumia wa ũnini waku.
\q1 
\v 19 Athakarĩte ta thwariga ya mũgoma,
\q2 akaagĩra ta gathiiya ka mũgoma:
\q2 kĩiganagwo nĩ nyondo ciake hĩndĩ ciothe,
\q2 ũkenagio nĩ wendo wake hĩndĩ ciothe.
\q1 
\v 20 Mũrũ wakwa, nĩ kĩĩ kĩngĩtũma ũkenio nĩ mũtumia mũtharia?
\q2 Nĩ kĩĩ kĩngĩtũma ũhĩmbĩrie gĩthũri kĩa mũtumia wa mũndũ ũngĩ?
\b
\q1 
\v 21 Nĩgũkorwo mĩthiĩre ya mũndũ nĩyonagwo nĩ Jehova,
\q2 nake nĩatuĩragia njĩra ciake ciothe.
\q1 
\v 22 Ciĩko njũru cia mũndũ mwaganu nĩcio imũtegaga;
\q2 nga cia mehia make nĩcio imuohaga, ikamũrũmia biũ.
\q1 
\v 23 Mũndũ ũcio nĩagaakua nĩ kwaga ũtaaro,
\q2 akoora nĩ ũndũ wa ũrimũ wake mũnene.
\c 6
\s1 Gũkaania Andũ Kũrũmĩrĩra Ũrimũ
\q1 
\v 1 Mũrũ wakwa, ũngĩkorwo ũigĩte kĩndũ gĩa kũrũgamĩrĩra thiirĩ wa mũndũ wa itũũra rĩaku,
\q2 ũkorwo atĩ nĩwe ũtuĩkĩte wa kũmũrĩhĩra thiirĩ harĩ mũndũ ũngĩ-rĩ,
\q1 
\v 2 ũngĩkorwo ũtegeetwo nĩ ũrĩa uugĩte,
\q2 ũkagwatithio nĩ ciugo cia kanua gaku-rĩ,
\q1 
\v 3 gĩĩke atĩrĩ, mũrũ wakwa, nĩguo wĩteithũre,
\q2 kuona atĩ nĩũgwĩte moko-inĩ ma mũndũ wa itũũra rĩaku:
\q1 Thiĩ wĩnyiihie wee mwene;
\q2 mũthaithe mũno akuohere.
\q1 
\v 4 Ndũkareke maitho maku mone toro,
\q2 kana ũreke imone ciaku icũnge.
\q1 
\v 5 Wĩteithũre o ta ũrĩa thwariga ĩĩteithũraga kuuma moko-inĩ ma mũguĩmi,
\q2 o na kana ta ũrĩa nyoni ĩĩteithũraga kuuma mũtego-inĩ wa mũtegi.
\b
\q1 
\v 6 Thiĩ harĩ thigiriri, wee kĩgũũta gĩkĩ;
\q2 ũcũũranie mĩtugo yayo nĩguo ũũhĩge!
\q1 
\v 7 Ndĩrĩ mũnene,
\q2 kana mũmĩrũgamĩrĩri,
\q2 o na kana mũmĩathi,
\q1 
\v 8 no nĩĩigagĩra mũthiithũ wa irio hĩndĩ ya riũa,
\q2 na ĩgacookanĩrĩria irio ciayo hĩndĩ ya magetha.
\b
\q1 
\v 9 Ũgũkoma hau nginya-rĩ, wee kĩgũũta gĩkĩ?
\q2 Ũrĩũkĩra rĩ, ũtige toro waku?
\q1 
\v 10 Komakoma gatoro kanini, na ũcũngacũnge hanini,
\q2 na ũkũnje moko hanini nĩguo ũhurũke;
\q1 
\v 11 atĩrĩ, ũthĩĩni ũgaagũkorerera ta mũitũ,
\q2 ũkorererwo nĩ wagi ũhaana ta mũndũ wĩohete indo cia mbaara.
\b
\q1 
\v 12 Mũndũ kĩmaramari na mwaganu-rĩ,
\q2 ũrĩa ũthiiaga akĩaragia ndeto itarĩ nũngĩrĩru,
\q2 
\v 13 ũcio uunagĩra andũ riitho,
\q2 na akaheenereria andũ na makinya make,
\q2 o na akaheneria andũ na ciara ciake-rĩ,
\q1 
\v 14 ũcio ũthugundaga ũũru arĩ na maheeni ngoro-inĩ yake:
\q2 ũcio hĩndĩ ciothe ahuraga maũndũ ma nyamũkano.
\q1 
\v 15 Nĩ ũndũ ũcio mũtino ũkaamũhubanĩria o rĩmwe aterĩgĩrĩire;
\q2 mwanangĩko ũtarĩ kĩhonia nĩũkamũniina biũ.
\b
\q1 
\v 16 Kũrĩ maũndũ matandatũ mathũirwo nĩ Jehova,
\q2 ĩĩ, o na nĩ mũgwanja marĩa onaga marĩ magigi, nĩmo:
\li2 
\v 17 maitho ma mwĩtĩĩo,
\li2 na rũrĩmĩ rũrĩa rũheenanagia,
\li2 na moko marĩa maitaga thakame ya andũ matehĩtie,
\li2 
\v 18 na ngoro ĩrĩa ĩthugundaga maũndũ ma waganu,
\li2 na magũrũ marĩa matengʼeraga gũthiĩ gwĩka ũũru,
\li2 
\v 19 na mũira ũtarĩ wa ma ũrĩa ũthothoraga ndeto cia maheeni,
\li2 o na mũndũ ũrĩa ũrehaga nyamũkano gatagatĩ ka andũ a nyina ũmwe.
\s1 Gũkaanio ũtharia
\q1 
\v 20 Mũrũ wakwa, tũũra ũrũmĩtie maathani ma thoguo,
\q2 na ndũgatirike ũrutani wa maitũguo.
\q1 
\v 21 Moherere ngoro-inĩ yaku nginya tene;
\q2 makundĩke marigiicĩrie ngingo yaku.
\q1 
\v 22 Rĩrĩa ũgũthiĩ-rĩ, nĩmarĩgũtongoragia;
\q2 wakoma-rĩ, nĩmarĩkũmenyagĩrĩra;
\q2 na rĩrĩa warahũka-rĩ, nĩmarĩkwaragĩria.
\q1 
\v 23 Nĩgũkorwo maathani maya nĩ tawa,
\q2 na ũrutani ũyũ nĩ ũtheri,
\q2 namo mataaro ma kũrũnga mũndũ-rĩ,
\q2 nĩmo njĩra ya muoyo,
\q1 
\v 24 magakweheragia harĩ mũndũ-wa-nja ũcio mwaganu,
\q2 na magakũhonokia kuuma kũrĩ rũrĩmĩ rũnyoroku rwa mũtumia ũcio ngʼenyũ.
\q1 
\v 25 Ndũkerirĩrie ũthaka wake ngoro-inĩ yaku,
\q2 kana ũreke akũguucĩrĩrie na maitho make,
\q1 
\v 26 nĩgũkorwo mũmaraya atũmaga mũndũ athĩĩne nginya ahooyage kenyũ ka mũgate,
\q2 na mũtumia mũtharia aguĩmaga muoyo waku guo mwene.
\q1 
\v 27 Mũndũ no atahĩre mwaki gĩthũri-inĩ gĩake,
\q2 na nguo ciake itihĩe?
\q1 
\v 28 Mũndũ no agerere igũrũ rĩa makara marĩ na mwaki,
\q2 na makinya make matihĩe?
\q1 
\v 29 Ũguo no taguo mũndũ ũrĩa ũkomaga na mũtumia wa mũndũ ũngĩ atariĩ;
\q2 gũtirĩ mũndũ ũngĩmũhutia na ndaherithio.
\b
\q1 
\v 30 Andũ matimenaga mũici angĩkorwo aiyĩte
\q2 nĩguo eniinĩre ngʼaragu rĩrĩa arĩ mũhũũtu.
\q1 
\v 31 No rĩrĩ, angĩnyiitwo-rĩ, no nginya arĩhe maita mũgwanja,
\q2 o na angĩkorwo ekũrĩha na ũtonga wa nyũmba yake wothe.
\q1 
\v 32 No mũndũ ũrĩa ũtharagia nĩagĩte wĩciirio;
\q2 ũrĩa wothe wĩkaga ũguo nĩwe mwene wĩyanangaga.
\q1 
\v 33 Nguraro na kwĩnyararithia nĩcio igai rĩake,
\q2 na cio thoni icio ciake gũtirĩ hĩndĩ igaathario ithire;
\q1 
\v 34 nĩgũkorwo ũiru nĩguo warahũraga mangʼũrĩ ma mũthuuri,
\q2 na ndakaigua tha akĩĩrĩhĩria.
\q1 
\v 35 Ndagetĩkĩra irĩhi o na rĩrĩkũ;
\q2 nĩakaarega ihaki o na rĩrĩ inene atĩa.
\c 7
\s1 Gũkaanio kũgĩa Ndũgũ na Mũndũ-wa-Nja Mũtharia
\q1 
\v 1 Mũrũ wakwa, tũũra ũrũmĩtie ciugo ciakwa,
\q2 na wĩigĩre maathani makwa thĩinĩ waku.
\q1 
\v 2 Rũmia maathani makwa,
\q2 na nĩũgatũũra muoyo;
\q2 gitagĩra morutani makwa o ta kĩũma kĩa riitho rĩaku.
\q1 
\v 3 Mohagĩrĩre ciara-inĩ ciaku;
\q2 ũmaandĩke kĩhengere-inĩ kĩa ngoro yaku.
\q1 
\v 4 Ĩra ũũgĩ atĩrĩ, “Wee nĩwe mwarĩ wa maitũ,”
\q2 naguo ũtaũku ũwĩtage mũndũ wa nyũmba yanyu;
\q1 
\v 5 nĩcirĩkweheragia harĩ mũndũ-wa-nja ũcio mũtharia,
\q2 o na kuuma kũrĩ mũtumia ũcio ũtarĩ mwĩhokeku,
\q2 hamwe na ciugo ciake cia kũheenanĩrĩria.
\b
\q1 
\v 6 Ndĩ ndirica-inĩ ya nyũmba yakwa-rĩ,
\q2 nĩndacũthĩrĩirie na nja kamwanya-inĩ,
\q1 
\v 7 ngĩona kĩmwana gatagatĩ ka arĩa matarĩ oogĩ,
\q2 na ngĩkũũrana gatagatĩ ka aanake,
\q2 mũndũ mwĩthĩ ũtaarĩ na ũũgĩ wa gũkũũrana maũndũ.
\q1 
\v 8 Aikũrũkaga na njĩra ĩrĩa yarĩ hakuhĩ na koine ya kwa mũndũ-wa-nja ũcio,
\q2 agĩthiĩ na njĩra ĩyo yerekeire na gwake mũciĩ,
\q1 
\v 9 na kwarĩ na mairia o kahwaĩ-inĩ gũgĩtukatuka,
\q2 gũkĩambĩrĩria kũgĩa nduma ya ũtukũ.
\b
\q1 
\v 10 Na rĩrĩ, hagĩũka mũndũ-wa-nja kũmũtũnga,
\q2 wehumbĩte nguo ta mũmaraya, arĩ na wara ngoro-inĩ.
\q1 
\v 11 (Nĩ mũnegeni na mũngʼathia,
\q2 na magũrũ make matikiragĩrĩria mũciĩ;
\q1 
\v 12 rĩmwe arĩ njĩra-inĩ, na rĩrĩa rĩngĩ arĩ ihaaro-inĩ,
\q2 ehithagĩre andũ koine-inĩ ciothe cia njĩra.)
\q1 
\v 13 Nake akĩnyiita mwanake ũcio, akĩmũmumunya,
\q2 na akĩmwĩra atĩrĩ ategũconoka,
\b
\q1 
\v 14 “Ndĩ na maruta ma ngwatanĩro mũciĩ,
\q2 tondũ ũmũthĩ nĩhingirie mĩĩhĩtwa yakwa.
\q1 
\v 15 Nĩ ũndũ ũcio ndoimagara, ndooka gũgũtũnga;
\q2 ngũgũcarĩtie mũno, na rĩu nĩndakuona!
\q1 
\v 16 Nĩnjarĩte ũrĩrĩ wakwa
\q2 na macuka ma gatani ma marangi kuuma Misiri.
\q1 
\v 17 Ũrĩrĩ ũcio wakwa nĩndĩũitĩrĩirie indo nungi wega ta manemane,
\q2 na thubiri, o na mũndarathini.
\q1 
\v 18 Ũka twĩhũũnie wendo nginya rũciinĩ;
\q2 reke twĩkenie na wendo!
\q1 
\v 19 Mũthuuri wakwa ndarĩ mũciĩ;
\q2 nĩathiĩte rũgendo rũraihu.
\q1 
\v 20 Nĩathiire na mũhuko wake ũiyũrĩte mbeeca,
\q2 na akainũka mũciĩ o rĩrĩa mweri ũkaiganana.”
\b
\q1 
\v 21 Agĩkĩmũheenereria na ciugo, akĩmũhĩtithia;
\q2 agĩkĩmuuha na mĩario yake mĩnyoroku.
\q1 
\v 22 O rĩmwe akĩmũrũmĩrĩra ta ndegwa ĩgĩthiĩ gũthĩnjwo,
\q2 kana ta thwariga ĩgĩtoonya kĩana-inĩ kĩa mũtego,
\q1 
\v 23 nginya akaaya gũtheecwo ini nĩ mĩguĩ,
\q2 akahaana ta nyoni ĩguthũkĩte mũtego-inĩ,
\q2 ĩtekũmenya o na hanini atĩ ũndũ ũcio no ũmĩrute muoyo.
\b
\q1 
\v 24 Atĩrĩrĩ, ariũ akwa, ta thikĩrĩriai;
\q2 tegai matũ mũigue ũrĩa ngũmwĩra.
\q1 
\v 25 Mũtikanareke ngoro cianyu ĩrũmĩrĩre mĩthiĩre yake,
\q2 kana mũingĩre njĩra-inĩ ciake.
\q1 
\v 26 Nĩ andũ aingĩ arĩkĩtie kũrũnda;
\q2 arĩa oragĩte nĩ kĩrĩndĩ kĩingĩ mũno.
\q1 
\v 27 Nyũmba yake nĩ njĩra njariĩ ya gũthiĩ mbĩrĩra,
\q2 nayo yerekagĩria andũ nyũmba-inĩ cia gĩkuũ.
\c 8
\s1 Ũũgĩ Gwĩtana
\q1 
\v 1 Githĩ ũũgĩ ndareetana?
\q2 Githĩ ũtaũku ndaranĩrĩra na mũgambo wake?
\q1 
\v 2 Njĩra-inĩ kũrĩa gũtũũgĩru, na magomano-inĩ ma njĩra-rĩ,
\q2 nĩho ũũgĩ arũgamĩte;
\q1 
\v 3 ningĩ hakuhĩ na ihingo iria cierekeire itũũra inene,
\q2 o hau matoonyero-inĩ-rĩ, nĩho araanĩrĩra akoiga atĩrĩ:
\q1 
\v 4 “Inyuĩ andũ nĩ inyuĩ ndĩreeta;
\q2 ndĩraanĩrĩra na mũgambo wakwa kũrĩ andũ othe a thĩ.
\q1 
\v 5 Inyuĩ arĩa mũtarĩ na ũũgĩ, gĩai na ũbaarĩrĩri,
\q2 inyuĩ arĩa akĩĩgu, gĩai na ũtaũku.
\q1 
\v 6 Thikĩrĩriai, nĩgũkorwo ndĩ na maũndũ ma bata ngwaria;
\q2 ngũtumũra mĩromo yakwa njarie maũndũ marĩa magĩrĩire.
\q1 
\v 7 Kanua gakwa kaaragia ũhoro wa ma,
\q2 nĩgũkorwo mĩromo yakwa nĩĩthũire waganu mũno ta kĩndũ kĩrĩ magigi.
\q1 
\v 8 Ciugo ciothe cia kanua gakwa nĩ cia ũthingu;
\q2 gũtirĩ o na kiugo kĩmwe gĩacio kĩogomu kana gĩa kũhĩtithania.
\q1 
\v 9 Kũrĩ arĩa makũũranaga maũndũ ciugo ciothe nĩciagĩrĩire;
\q2 itirĩ mahĩtia kũrĩ arĩa marĩ na ũmenyo.
\q1 
\v 10 Thuurai mataaro makwa handũ ha betha,
\q2 mũthuure ũmenyo handũ ha thahabu ĩrĩa njega mũno,
\q1 
\v 11 nĩgũkorwo ũũgĩ nĩ wa goro gũkĩra ruru iria ndune,
\q2 na gũtirĩ kĩndũ ũngĩĩrirĩria kĩngĩringithanio naguo.
\b
\q1 
\v 12 “Niĩ ũũgĩ-rĩ, ndũũranagia na ũbaarĩrĩri;
\q2 nĩndĩgwatĩire ũmenyo o na gũthugunda maũndũ mega.
\q1 
\v 13 Gwĩtigĩra Jehova nĩgũthũũra ũũru;
\q2 nĩthũire mwĩtĩĩo na mwĩtũũgĩrio,
\q2 na mĩtugo mĩũru na mĩario ya waganu.
\q1 
\v 14 Kĩrĩra na ũũgĩ wa gũkũũrana maũndũ nĩ ciakwa;
\q2 niĩ ndĩ na ũtaũku, na ndĩ na ũhoti.
\q1 
\v 15 Athamaki mathamakaga nĩ ũndũ wa hinya wakwa
\q2 nao aathani magathondeka mawatho ma kĩhooto;
\q1 
\v 16 anene mathamakaga nĩ ũndũ wa hinya wakwa,
\q2 o ũndũ ũmwe na arĩa othe marĩ igweta arĩa maathanaga gũkũ thĩ.
\q1 
\v 17 Nĩnyendete arĩa manyendete,
\q2 nao arĩa manjaragia na kĩyo nĩmanyonaga.
\q1 
\v 18 Ũtonga na gĩtĩĩo cionekaga harĩ niĩ,
\q2 o hamwe na ũtonga wa gũtũũra, na ũgaacĩru.
\q1 
\v 19 Maciaro makwa nĩ mega gũkĩra thahabu ĩrĩa therie;
\q2 uumithio wakwa nĩũkĩrĩte betha ĩrĩa njega.
\q1 
\v 20 Niĩ thiiaga na njĩra ya ũthingu,
\q2 ngathiĩra o njĩra-inĩ cia kĩhooto,
\q1 
\v 21 ngĩheaga andũ arĩa manyendete ũtonga,
\q2 na ngaiyũragia igĩĩna ciao.
\b
\q1 
\v 22 “Jehova aanyũmbire o kĩambĩrĩria-inĩ kĩa wĩra wake,
\q2 mbere ya mawĩra make ma tene;
\q1 
\v 23 ndaathuurirwo kuuma tene wa tene,
\q2 kuuma o kĩambĩrĩria, thĩ ĩtarĩ yagĩa.
\q1 
\v 24 Rĩrĩa gũtaagĩte maria manene-rĩ, nĩguo ndaciarirwo,
\q2 o hĩndĩ ĩrĩa gũtaarĩ matherũkĩro maiyũrĩte maaĩ;
\q1 
\v 25 ndaciarirwo irĩma itanahaandwo harĩa irĩ,
\q2 na tũrĩma tũtanagĩa,
\q1 
\v 26 we atanoomba thĩ kana ithaka ciayo,
\q2 o na kana rũkũngũ o ruothe rwa thĩ.
\q1 
\v 27 Niĩ ndaarĩ o kuo hĩndĩ ĩrĩa aathondekire igũrũ na akĩrĩiga handũ ha rĩo,
\q2 hĩndĩ ĩrĩa eekĩrire rũkiriri rwa kũrĩa kũriku,
\q1 
\v 28 rĩrĩa aahaandire matu kũu igũrũ,
\q2 na akĩrũmia ithima cia kũrĩa kũriku wega,
\q1 
\v 29 rĩrĩa eekĩrire mũhaka wa iria
\q2 nĩguo maaĩ matikanae kwagarara watho wake,
\q1 na rĩrĩa aahandire mĩthingi ya thĩ.
\q2 
\v 30 Hĩndĩ ĩyo ndaarĩ o hakuhĩ nake ndĩ ta mũbundi mũũgĩ.
\q1 Ndaaiyũrĩtwo nĩ gĩkeno mũthenya o mũthenya,
\q2 na ngakenaga hĩndĩ ciothe ndĩ mbere yake,
\q1 
\v 31 ngakenagĩra thĩ yake yothe,
\q2 na ngakenagio nĩ andũ othe a thĩ.
\b
\q1 
\v 32 “Atĩrĩrĩ ariũ akwa, ta thikĩrĩriai;
\q2 kũrathimwo nĩ arĩa marũmagia njĩra ciakwa.
\q1 
\v 33 Ta thikĩrĩriai mataaro makwa nĩguo mũhĩge;
\q2 mũtikamarege.
\q1 
\v 34 Kũrathimwo nĩ mũndũ ũrĩa ũnjiguaga,
\q2 agacũthagĩrĩria mĩrango-inĩ yakwa o mũthenya,
\q2 akanjetagĩrĩra hingĩro-inĩ cia mĩrango yakwa.
\q1 
\v 35 Nĩgũkorwo ũrĩa wothe ũgĩte na niĩ nĩ muoyo agĩte naguo,
\q2 nake akagĩa na agetĩkĩrĩka harĩ Jehova.
\q1 
\v 36 No ũrĩa wothe ũhĩtanĩtie na niĩ nĩ ũũru eĩkaga;
\q2 nao arĩa othe maathũire nĩ gĩkuũ mendete.”
\c 9
\s1 Ũũgĩ na Ũkĩĩgu Gwĩtana
\q1 
\v 1 Ũũgĩ nĩakĩte nyũmba yake;
\q2 nĩaicũhĩtie itugĩ ciayo mũgwanja.
\q1 
\v 2 Nĩahaarĩirie nyama, na akahaarĩria ndibei,\f + \fr 9:2 \ft Ndibei nĩyatukanagio na indo ingĩ ta manemane nĩgeetha ĩcame wega.\f*
\q2 o na akaara metha yake.
\q1 
\v 3 Nĩatũmĩte ndungata ciake cia airĩtu nja,
\q2 na nĩaretana arĩ harĩa hatũũgĩru mũno itũũra-inĩ rĩrĩa inene, akoiga atĩrĩ:
\q1 
\v 4 “Andũ arĩa othe matarĩ na ũũgĩ nĩmoke gũkũ!”
\q2 Ningĩ akeera andũ arĩa maagĩĩte ũtaũku atĩrĩ,
\q1 
\v 5 Ũkai mũrĩe irio ciakwa,
\q2 na mũnyue ndibei ĩrĩa ndĩmũthondekeire.
\q1 
\v 6 Tiganai na mĩthiĩre yanyu ĩtarĩ ya ũũgĩ, na nĩmũgũtũũra muoyo;
\q2 cookai gũthiiaga na njĩra ya ũtaũku.
\b
\q1 
\v 7 “Ũrĩa wothe ũtaaraga mũnyũrũrania eĩtagĩria irumi;
\q2 na ũrĩa wothe ũkaanagia mũndũ mwaganu egĩĩragĩra njono.
\q1 
\v 8 Ndũkanataare mũnyũrũrania, nĩguo ndagagũthũũre;
\q2 kaania mũndũ mũũgĩ, nake nĩegũkwenda.
\q1 
\v 9 Taara mũndũ mũũgĩ na nĩegũkĩrĩrĩria kũũhĩga;
\q2 mũndũ mũthingu mũrute, na nĩekuongerera ũũgĩ wake.
\b
\q1 
\v 10 “Kĩambĩrĩria kĩa ũũgĩ nĩ gwĩtigĩra Jehova,
\q2 na kũmenya Ũrĩa Mũtheru nĩkuo gũtaũkĩrwo.
\q1 
\v 11 Nĩgũkorwo nĩ ũndũ wakwa matukũ maku nĩmakaingĩha,
\q2 na wongererwo mĩaka ya gũtũũra muoyo.
\q1 
\v 12 Ũngĩkorwo ũrĩ mũũgĩ-rĩ, ũũgĩ waku nĩũgakũguna;
\q2 na ũngĩkorwo ũrĩ mũnyũrũrania-rĩ, we nowe ũkaanyariirĩka.”
\b
\q1 
\v 13 Mũndũ-wa-nja ũrĩa wĩtagwo Mũkĩĩgu nĩ wa inegene;
\q2 we ndarĩ mũtugo, na ndarĩ ũmenyo.
\q1 
\v 14 Aikaraga thĩ mũrango-inĩ wa nyũmba yake,
\q2 agaikarĩra gĩtĩ harĩa hatũũgĩru mũno itũũra-inĩ rĩrĩa inene,
\q1 
\v 15 ageetaga arĩa marehĩtũkĩra,
\q2 arĩa marethiĩra na njĩra ciao.
\q1 
\v 16 Ameeraga atĩrĩ, “Andũ arĩa othe matarĩ na ũũgĩ nĩmoke gũkũ!”
\q2 Nao arĩa maagĩĩte ũtaũku akameera atĩrĩ:
\q1 
\v 17 “Maaĩ ma kũiya marĩ mũrĩo;
\q2 o na irio iria irĩĩagĩrwo hitho-inĩ irĩ cama!”
\q1 
\v 18 No andũ acio matikoragwo makĩmenya atĩ arĩa akuũ marĩ kũu,
\q2 na atĩ ageni ake marĩ o kũrĩa kũriku mbĩrĩra-inĩ.
\c 10
\s1 Thimo cia Solomoni
\p Ici nĩ Thimo cia Solomoni:
\q1 
\v 1 Mwana mũũgĩ atũmaga ithe akene,
\q2 no mwana mũkĩĩgu atũũragia nyina na kĩeha.
\b
\q1 
\v 2 Mĩthiithũ yumanĩte na ungumania ndĩrĩ kĩguni,
\q2 no ũthingu ũkũũraga mũndũ kuuma kũrĩ gĩkuũ.
\b
\q1 
\v 3 Jehova ndarekagĩrĩria mũndũ mũthingu ahũte,
\q2 no nĩamarigagĩrĩria merirĩria ma mũndũ mwaganu.
\b
\q1 
\v 4 Moko ma kĩgũũta matũmaga mũndũ athĩĩne,
\q2 no moko ma mũndũ ũrĩ kĩyo marehaga ũtonga.
\b
\q1 
\v 5 Ũrĩa ũcookanagĩrĩria irio hĩndĩ ya riũa nĩ mwana mũũgĩ,
\q2 no ũrĩa ũkomaga hĩndĩ ya magetha nĩ mwana wa kũrehe thoni.
\b
\q1 
\v 6 Mũtwe wa mũndũ mũthingu ũikaraga ũhumbĩrĩtwo nĩ irathimo,
\q2 no kanua ka mũndũ mwaganu kaiyũraga ngũĩ.
\b
\q1 
\v 7 Kĩririkano kĩa mũndũ mũthingu gĩgatuĩka kĩrathimo,
\q2 no rĩĩtwa rĩa mũndũ mwaganu nĩrĩkabutha.
\b
\q1 
\v 8 Mũndũ ũrĩa ũrĩ na ũũgĩ wa ngoro nĩetĩkagĩra mawatho,
\q2 no mũndũ wa kũhũhũtĩka nĩakanangĩka.
\b
\q1 
\v 9 Mũndũ wa mĩthiĩre mĩrũngĩrĩru athiiaga ategwĩtigĩra ũgwati,
\q2 no mũndũ ũrĩa ũrĩ mĩthiĩre mĩogomu nĩakamenyeka.
\b
\q1 
\v 10 Mũndũ ũrĩa uunagĩra ũngĩ riitho na rũnano nĩarehage kĩeha,
\q2 na mwaria mũkĩĩgu nĩakanangĩka.
\b
\q1 
\v 11 Kanua ka mũndũ mũthingu nĩ gĩthima kĩa muoyo,
\q2 no kanua ka mũndũ mwaganu kaiyũraga ngũĩ.
\b
\q1 
\v 12 Rũmena rũrehaga nyamũkano,
\q2 no wendani ũhumbagĩra ũũru wothe.
\b
\q1 
\v 13 Ũũgĩ ũkoragwo mĩromo-inĩ ya mũndũ ũrĩa mũkũũrani maũndũ,
\q2 no mũndũ ũrĩa ũtooĩ gũkũũrana maũndũ aagĩrĩirwo nĩ rũthanju ciande-inĩ ciake.
\b
\q1 
\v 14 Andũ oogĩ meigagĩra ũmenyo,
\q2 no kanua ga kĩrimũ keĩtagĩria mwanangĩko.
\b
\q1 
\v 15 Indo cia itonga nĩ gĩtũũro kĩao kĩirigĩre na hinya,
\q2 no ũkĩa nĩguo mwanangĩko wa andũ arĩa athĩĩni.
\b
\q1 
\v 16 Mũcaara wa andũ arĩa athingu ũmarehagĩra muoyo,
\q2 no indo iria cionagwo nĩ andũ arĩa aaganu imarehagĩra iherithia.
\b
\q1 
\v 17 Mũndũ ũrĩa ũiguaga agĩtaarwo arĩ njĩra-inĩ ya muoyo,
\q2 no mũndũ ũrĩa ũregaga kũrũithio-rĩ, nĩahĩtithagia andũ arĩa angĩ.
\b
\q1 
\v 18 Mũndũ ũrĩa ũhithaga rũmena rwake aaragia na mĩromo ya maheeni,
\q2 na ũrĩa wothe ũcambanagia nĩ mũndũ mũkĩĩgu.
\b
\q1 
\v 19 Rĩrĩa ciugo ciaingĩha mehia matiagaga,
\q2 no mũndũ ũrĩa ũkiraga nĩ mũũgĩ.
\b
\q1 
\v 20 Rũrĩmĩ rwa mũndũ mũthingu nĩ betha njega,
\q2 no ngoro ya mũndũ mwaganu ndĩrĩ bata.
\b
\q1 
\v 21 Mĩromo ya arĩa athingu ĩhũnagia andũ aingĩ,
\q2 no andũ akĩĩgu makuaga nĩ kwaga gũkũũrana maũndũ.
\b
\q1 
\v 22 Kĩrathimo kĩa Jehova nĩkĩo kĩrehaga ũtonga,
\q2 na ndarĩ kĩeha onganagĩrĩria nakĩo.
\b
\q1 
\v 23 Mũndũ mũkĩĩgu akenagĩra mĩtugo mĩũru,
\q2 no mũndũ ũrĩ na ũtaũku akenagĩra ũũgĩ.
\b
\q1 
\v 24 Kĩrĩa mũndũ mwaganu etigagĩra nĩkĩo gĩkaamũkora,
\q2 na kĩrĩa mũndũ mũthingu eriragĩria nĩkĩo akaaheo.
\b
\q1 
\v 25 Kĩhuhũkanio kĩahĩtũka andũ arĩa aaganu maticookaga kuoneka,
\q2 no andũ arĩa athingu mehaandaga wega nginya tene.
\b
\q1 
\v 26 Ta ũrĩa thiki ĩgagatagĩra magego, na ndogo ĩkarũrĩra maitho-rĩ,
\q2 noguo kĩgũũta kĩhaana kũrĩ arĩa magĩtũmaga.
\b
\q1 
\v 27 Gwĩtigĩra Jehova-rĩ, kuongagĩrĩra mũndũ matukũ ma gũtũũra muoyo,
\q2 no mĩaka ya mũndũ mwaganu nĩkũnyiihio ĩnyiihagio.
\b
\q1 
\v 28 Itanya rĩa mũndũ mũthingu nĩ gĩkeno,
\q2 no kĩĩrĩgĩrĩro kĩa mũndũ mwaganu no gĩa tũhũ.
\b
\q1 
\v 29 Njĩra ya Jehova nĩ rĩũrĩro rĩa andũ arĩa athingu,
\q2 no nĩ mwanangĩko harĩ arĩa mekaga ũũru.
\b
\q1 
\v 30 Mũndũ ũrĩa mũthingu ndarĩ hĩndĩ akaamunywo,
\q2 no ũrĩa mwaganu ndagatũũra thĩinĩ wa bũrũri.
\b
\q1 
\v 31 Kanua ka mũndũ ũrĩa mũthingu karehaga ũũgĩ,
\q2 no rũrĩmĩ rwa ũtũrĩka nĩrũkaniinwo.
\b
\q1 
\v 32 Mĩromo ya mũndũ mũthingu nĩyũũĩ kwaria ndeto iria ciagĩrĩire,
\q2 no kanua ka ũrĩa mwaganu kaaragia o rũtũrĩko.
\b
\c 11
\q1 
\v 1 Ratiri itarĩ cia ma nĩ kĩndũ kĩrĩ magigi harĩ Jehova,
\q2 no nĩakenagĩra mahiga ma gũthima marĩa maigananu.
\b
\q1 
\v 2 Rĩrĩa mwĩtĩĩo woka, ũrũmagĩrĩrwo nĩ thoni,
\q2 no kwĩnyiihia kũrehaga ũũgĩ.
\b
\q1 
\v 3 Ũrũngĩrĩru wa arĩa marũgamĩte wega nĩũmonagĩrĩria njĩra,
\q2 no andũ arĩa matarĩ ehokeku, nĩmanangagwo nĩ ũhinga wao.
\b
\q1 
\v 4 Ũtonga ndũrĩ kĩguni mũthenya wa mangʼũrĩ,
\q2 no ũthingu nĩũkũũraga mũndũ kuuma kũrĩ gĩkuũ.
\b
\q1 
\v 5 Ũthingu wa andũ arĩa matarĩ na ũcuuke ũmathondekagĩra njĩra nũngarũ,
\q2 no andũ arĩa aaganu magũithagio nĩ waganu wao ene.
\b
\q1 
\v 6 Ũthingu wa andũ arĩa arũngĩrĩru nĩũmahonokagia,
\q2 no andũ arĩa matarĩ ehokeku nĩmategagwo nĩ merirĩria mao mooru.
\b
\q1 
\v 7 Hĩndĩ ĩrĩa mũndũ mwaganu aakua, kĩĩrĩgĩrĩro gĩake nĩgũthira gĩthiraga;
\q2 kĩrĩa gĩothe eerĩgĩrĩire kuuma kũrĩ ũhoti wake gĩtuĩkaga o tũhũ.
\b
\q1 
\v 8 Mũndũ ũrĩa mũthingu nĩahonokagio kuuma thĩĩna-inĩ,
\q2 naguo ũgaacookerera ũrĩa mwaganu.
\b
\q1 
\v 9 Mũndũ ũtetigĩrĩte Ngai nĩanangaga mũndũ wa itũũra na kanua gake,
\q2 no arĩa athingu nĩmetharaga nĩ ũndũ wa ũmenyo.
\b
\q1 
\v 10 Rĩrĩa andũ arĩa athingu magaacĩra, itũũra nĩgũkena rĩkenaga;
\q2 rĩrĩa andũ arĩa aaganu maathira, nĩkũrũhio kũrũũhagio.
\b
\q1 
\v 11 Itũũra inene nĩrĩtũũgagĩrio nĩ ũndũ wa kĩrathimo kĩa andũ arĩa arũngĩrĩru,
\q2 no nĩrĩanangagwo nĩ kanua ka andũ arĩa aaganu.
\b
\q1 
\v 12 Mũndũ ũtarĩ ũũgĩ wa gũkũũrana maũndũ anyũrũragia mũndũ wa itũũra rĩake,
\q2 no mũndũ ũrĩ na ũtaũku nĩ gwĩkirĩra ekiragĩra.
\b
\q1 
\v 13 Mũndũ wa mũhuhu nĩoimagia ndeto cia ndundu nja,
\q2 no mũndũ mwĩhokeku nĩaigaga hitho.
\b
\q1 
\v 14 Bũrũri ũngĩaga ũtongoria mwega nĩkũgũa ũgũũaga,
\q2 no ataarani aingĩ matũmaga kũgĩe na ũhootani kũna.
\b
\q1 
\v 15 Mũndũ ũrĩa ũrũgamagĩrĩra thiirĩ wa mũndũ ũngĩ ti-itherũ nĩagathĩĩnĩka,
\q2 no mũndũ ũrĩa wothe wagaga kũrũgamĩrĩra mũndũ thiirĩ atũũraga na thayũ.
\b
\q1 
\v 16 Mũndũ-wa-nja mũtaana nĩegĩagĩra gĩtĩĩo,
\q2 no arũme arĩa matarĩ tha no ũtonga magĩaga naguo.
\b
\q1 
\v 17 Mũndũ mũtaana egunaga we mwene,
\q2 no mũndũ ũtarĩ tha erehagĩra thĩĩna we mwene.
\b
\q1 
\v 18 Mũndũ mwaganu athũkũmaga mũcaara wa kũmũheenia,
\q2 no ũrĩa ũhaandaga ũthingu nĩagethaga irĩhi rĩa ma.
\b
\q1 
\v 19 Mũndũ ũrĩa mũthingu kũna nĩagatũũra muoyo,
\q2 no mũndũ ũrĩa ũrũmagĩrĩra waganu nĩ gũkua agaakua.
\b
\q1 
\v 20 Andũ arĩa marĩ ngoro ya rũtũrĩko nĩ kĩndũ kĩrĩ magigi harĩ Jehova,
\q2 no nĩakenagio nĩ andũ arĩa njĩra ciao itarĩ ũcuuke.
\b
\q1 
\v 21 Ti-itherũ mũndũ mwaganu ndakaaga kũherithio,
\q2 no andũ arĩa athingu nĩmakahonokio.
\b
\q1 
\v 22 Mũndũ-wa-nja mũthaka ũtarĩ ũgereri
\q2 ahaana ta gĩcũhĩ gĩa thahabu kĩrĩ iniũrũ-inĩ rĩa ngũrwe.
\b
\q1 
\v 23 Wendi wa mũndũ mũthingu ũrĩkagĩrĩria o wega-inĩ,
\q2 no kĩĩrĩgĩrĩro kĩa mũndũ ũrĩa mwaganu kĩrĩĩkagĩrĩria mangʼũrĩ-inĩ.
\b
\q1 
\v 24 Kũrĩ mũndũ ũheanaga na ũtaana, nake agakĩrĩrĩria kũgĩa na indo;
\q2 ũngĩ atuĩkaga mũkarĩ mũno, no agathiĩ o na mbere gũthĩĩna.
\b
\q1 
\v 25 Mũndũ mũtaana nĩakagaacĩra;
\q2 ũrĩa ũnyootoraga arĩa angĩ o nake mwene nĩakanyootorwo.
\b
\q1 
\v 26 Mũndũ ũrĩa ũregaga kwenderia andũ mbembe iria aigĩte nĩarumagwo nĩ andũ,
\q2 no mũndũ ũrĩa ũciendagia, kĩrathimo kĩrĩkoragwo mũtwe-inĩ wake.
\b
\q1 
\v 27 Mũndũ ũrĩa ũcaragia maũndũ mega arĩonaga o wega,
\q2 no ũrĩa ũcaragia maũndũ mooru no mo marĩmũkoraga.
\b
\q1 
\v 28 Mũndũ ũrĩa wothe wĩhokaga ũtonga wake nĩkũgũa akaagũa,
\q2 no arĩa athingu makaagaacĩra ta ithangũ rĩrĩa iruru.
\b
\q1 
\v 29 Mũndũ ũrĩa ũnyamaragia mũciĩ wake akaagaya o rũhuho,
\q2 nake mũndũ mũkĩĩgu agaatuĩka ndungata ya ũrĩa mũũgĩ.
\b
\q1 
\v 30 Maciaro ma andũ arĩa athingu nĩ mũtĩ wa muoyo,
\q2 nake mũndũ ũrĩa mũũgĩ nĩaguucagĩrĩria ngoro cia andũ.
\b
\q1 
\v 31 Angĩkorwo andũ arĩa athingu nĩmarĩhagwo marĩ gũkũ thĩ-rĩ,
\q2 githĩ arĩa matetigĩrĩte Ngai na arĩa ehia matikarĩhwo makĩria!
\b
\c 12
\q1 
\v 1 Mũndũ ũrĩa wothe wendete ũtaaro nĩendete ũmenyi,
\q2 no ũrĩa ũthũire gũkaanio nĩ mũndũ mũkĩĩgu.
\b
\q1 
\v 2 Mũndũ ũrĩa mwega nĩatugagwo nĩ Jehova,
\q2 no mũndũ mwara Jehova amũtuaga mũndũ mwĩhia.
\b
\q1 
\v 3 Mũndũ ndangĩhota kwĩhaanda na maũndũ ma waganu,
\q2 no ũrĩa mũthingu ndangĩenyenyeka.
\b
\q1 
\v 4 Mũtumia ũrĩa ngatha nĩwe thũmbĩ ya mũthuuri wake,
\q2 no mũtumia ũconorithagia mũthuuri wake atariĩ ta ũbuthu mahĩndĩ-inĩ make.
\b
\q1 
\v 5 Mĩbango ya andũ arĩa athingu nĩ ya kĩhooto,
\q2 no ũtaaro wa andũ arĩa aaganu nĩ wa maheeni.
\b
\q1 
\v 6 Ndeto cia andũ arĩa aaganu nĩ cia kuohia andũ mamaite thakame,
\q2 no mĩario ya andũ arĩa arũngĩrĩru nĩĩmahonokagia.
\b
\q1 
\v 7 Andũ aaganu mangʼaũranagio magathira biũ,
\q2 no nyũmba ya mũndũ ũrĩa mũthingu ĩtũũraga ĩrĩ nũmu.
\b
\q1 
\v 8 Mũndũ agaathagĩrĩrio kũringana na ũũgĩ wake,
\q2 no andũ marĩ meciiria mogomu nĩmamenagwo.
\b
\q1 
\v 9 Kaba mũndũ ũrĩa wonagwo ta atarĩ bata no nĩ arĩ ndungata,
\q2 gũkĩra ũrĩa wĩtuaga atĩ nĩ mũndũ wa bata, na ndarĩ gĩa kũrĩa.
\b
\q1 
\v 10 Mũndũ mũthingu nĩamenyagĩrĩra muoyo wa nyamũ yake,
\q2 no maũndũ marĩa ma tha ma ũrĩa mwaganu nĩ ma kũnyariirana.
\b
\q1 
\v 11 Mũndũ ũrĩa ũrĩmaga mũgũnda wake nĩarĩkoragwo na irio nyingĩ,
\q2 no ũrĩa ũhanyũkanagia na maũndũ ma tũhũ nĩagĩte gũkũũrana maũndũ.
\b
\q1 
\v 12 Arĩa aaganu meriragĩria indo iria itahĩtwo nĩ andũ arĩa ooru,
\q2 no mĩri ya arĩa athingu nĩĩgaacagĩra.
\b
\q1 
\v 13 Mũndũ mũũru ategagwo nĩ mĩario ya wĩhia wake,
\q2 no mũndũ mũthingu nĩahonokaga kuuma thĩĩna-inĩ.
\b
\q1 
\v 14 Mũndũ nĩaiyũragwo nĩ maciaro mega ma kanua gake,
\q2 ti-itherũ, o ta ũrĩa agunagwo nĩ wĩra wa moko make.
\b
\q1 
\v 15 Njĩra ya mũndũ mũkĩĩgu yonekaga yagĩrĩire harĩ we,
\q2 no mũndũ mũũgĩ nĩathikagĩrĩria mataaro.
\b
\q1 
\v 16 Mũndũ mũkĩĩgu onanagia marakara make o rĩmwe,
\q2 no mũndũ mũbaarĩrĩri aarumwo ndatindanagĩrĩra.
\b
\q1 
\v 17 Mũira wa ma arutaga o ũira wa ma,
\q2 no mũira ũtarĩ wa ma aaragia maheeni.
\b
\q1 
\v 18 Ciugo iteciirĩtio itheecaga ta rũhiũ rwa njora,
\q2 no rũrĩmĩ rwa mũndũ ũrĩa mũũgĩ nĩkũhonia rũhonagia.
\b
\q1 
\v 19 Mĩromo ĩrĩa yaragia ma ĩtũũraga nginya tene,
\q2 no rũrĩmĩ rwa maheeni nĩ rwa kahinda o kanini.
\b
\q1 
\v 20 Ngoro cia arĩa mathugundaga gwĩka ũũru ciyũrĩtwo nĩ maheeni,
\q2 no gĩkeno nĩ kĩa andũ arĩa matũmaga thayũ ũgaacĩre.
\b
\q1 
\v 21 Gũtirĩ ũũru ũngĩkora andũ arĩa athingu,
\q2 no arĩa aaganu maiyũrĩtwo nĩ thĩĩna.
\b
\q1 
\v 22 Mĩromo ĩrĩa ĩheenanagia nĩ kĩndũ kĩrĩ magigi harĩ Jehova,
\q2 no nĩakenagio nĩ andũ arĩa maaragia ma.
\b
\q1 
\v 23 Mũndũ mũbaarĩrĩri nĩahithaga ũmenyi wake,
\q2 no ngoro cia andũ arĩa akĩĩgu ĩmemerekagia ũrimũ.
\b
\q1 
\v 24 Moko ma mũndũ ũrĩ kĩyo nĩmo magaathana,
\q2 no kĩgũũta gĩkaarutithio wĩra wa ũkombo.
\b
\q1 
\v 25 Ũritũ wa ngoro nĩũhatagĩrĩria mũndũ,
\q2 no ciugo njega nĩitũmaga akene.
\b
\q1 
\v 26 Mũndũ mũthingu nĩataaraga arata ake,
\q2 no njĩra ya arĩa aaganu nĩ kũmahĩtithia ĩmahĩtithagia.
\b
\q1 
\v 27 Mũndũ kĩgũũta o na ndahĩhagia nyama cia ũguĩmi wake,
\q2 no mũndũ ũrĩ kĩyo onaga indo ciake irĩ cia goro.
\b
\q1 
\v 28 Muoyo wonekaga na njĩra ya ũthingu;
\q2 na njĩra-inĩ ĩyo-rĩ, kũrĩ muoyo ũtagaathira.
\b
\c 13
\q1 
\v 1 Mwana mũũgĩ nĩathikagĩrĩria ũrutani wa ithe,
\q2 no mũnyũrũrania ndathikagĩrĩria agĩkaanio.
\b
\q1 
\v 2 Mũndũ nĩakenagĩra maciaro mega ma kuuma kanua gake,
\q2 no mũndũ ũrĩa ũtarĩ mwĩhokeku eeriragĩria haaro.
\b
\q1 
\v 3 Mũndũ ũrĩa ũmenyagĩrĩra kanua gake nĩ muoyo wake amenyagĩrĩra,
\q2 no ũrĩa ũhiũhaga kwaria nĩakanangĩka.
\b
\q1 
\v 4 Ngoro ya kĩgũũta ĩĩriragĩria na ndĩone kĩndũ,
\q2 no merirĩria ma mũndũ ũrĩ kĩyo nĩmakahingio.
\b
\q1 
\v 5 Mũndũ mũthingu nĩathũire ũhoro ũtarĩ wa ma,
\q2 no mũndũ mwaganu ekaga maũndũ ma thoni na ma njono.
\b
\q1 
\v 6 Ũthingu ũgitagĩra mũndũ ũrĩa mũrũngĩrĩru,
\q2 no waganu nĩũngʼaũranagia mũndũ mwĩhia.
\b
\q1 
\v 7 Kũrĩ mũndũ wĩtuaga gĩtonga, no ndarĩ kĩndũ;
\q2 kũrĩ ũngĩ wĩtuaga mũthĩĩni, no arĩ na ũtonga mũnene.
\b
\q1 
\v 8 Ũtonga wa mũndũ wahota gũkũũra muoyo wake,
\q1 no mũndũ mũthĩĩni ndaiguaga akĩĩhĩtĩrwo.
\b
\q2 
\v 9 Ũtheri wa mũndũ mũthingu waaraga ũgacangarara,
\q2 no tawa wa mũndũ mwaganu nĩkũhorio ũhoragio.
\b
\q1 
\v 10 Mwĩtĩĩo ũciaraga njũgitano,
\q2 no ũũgĩ wonekaga harĩ arĩa metĩkagĩra gũtaarwo.
\b
\q1 
\v 11 Mbeeca itarĩ cia wĩhokeku ithiiaga igĩthiraga,
\q2 no ũrĩa ũcookanagĩrĩria mbeeca tũnini o tũnini nĩatũmaga ciongerereke.
\b
\q1 
\v 12 Ũndũ mũtaanye ũngĩikario mũno nĩũrwaragia mũndũ ngoro,
\q2 no kĩĩrĩgĩrĩro kĩhingĩtio gĩtuĩkaga ta mũtĩ wa muoyo.
\b
\q1 
\v 13 Mũndũ ũrĩa ũthũire ũrutani nĩeyũnũhaga,
\q2 no ũrĩa ũtĩĩaga maathani nĩakaheo kĩheo.
\b
\q1 
\v 14 Ũrutani wa mũndũ ũrĩa mũũgĩ nĩ gĩthima kĩa muoyo,
\q2 ũhũndũraga mũndũ kuuma mĩtego-inĩ ya gĩkuũ.
\b
\q1 
\v 15 Gũtaũkĩrwo wega nĩ maũndũ gũtũmaga mũndũ endeke,
\q2 no njĩra ya arĩa matarĩ ehokeku ti hũthũ.
\b
\q1 
\v 16 Mũndũ o wothe mwĩbaarĩrĩri ekaga maũndũ make na ũmenyi,
\q2 no mũndũ mũkĩĩgu aguũragia ũrimũ wake.
\b
\q1 
\v 17 Mũtũmwo mwaganu atoonyaga thĩĩna-inĩ,
\q2 no mũtũmwo mwĩhokeku nĩarehaga kĩhonia.
\b
\q1 
\v 18 Mũndũ ũrĩa ũregaga gũtaarwo anyiitagwo nĩ thĩĩna na thoni,
\q2 no mũndũ ũrĩa wĩtĩkagĩra gũkaanio atuĩkaga wa gũtĩĩo.
\b
\q1 
\v 19 Ũndũ mwĩrirĩrie wakinyanĩra ũiguithagia ngoro wega,
\q2 no andũ akĩĩgu monaga kũhutatĩra ũũru ta ũndũ ũrĩ magigi.
\b
\q2 
\v 20 Mũndũ ũrĩa ũceeraga na arĩa oogĩ akĩragĩrĩria kũũhĩga,
\q2 no ũrĩa ũtwaranaga na mũndũ mũkĩĩgu onaga o ũũru.
\b
\q1 
\v 21 Mũtino ũthingataga mũndũ ũrĩa mwĩhia,
\q2 no ũgaacĩru nĩ kĩheo kĩa arĩa athingu.
\b
\q1 
\v 22 Mũndũ mwega atigagĩra ciana cia ciana ciake igai,
\q2 no ũtonga wa mũndũ mwĩhia ũigagĩrwo andũ arĩa athingu.
\b
\q1 
\v 23 Mũgũnda wa mũndũ mũthĩĩni no ũciare irio nyingĩ,
\q2 no kwaga kĩhooto gũciniinaga ciothe.
\b
\q1 
\v 24 Mũndũ ũrĩa ũigaga rũthanju thĩ nĩ mwana wake athũire,
\q2 no ũrĩa wendete mwana wake nĩamũherithagia.
\b
\q1 
\v 25 Andũ arĩa athingu marĩĩaga makahũũna,
\q2 no nda ya mũndũ mwaganu ĩikaraga o ĩhũtiĩ.
\b
\c 14
\q1 
\v 1 Mũtumia mũũgĩ nĩ gwaka akaga nyũmba yake,
\q2 no mũtumia mũkĩĩgu nĩgũtharia atharagia nyũmba yake na moko make mwene.
\b
\q1 
\v 2 Mũndũ ũrĩa ũthiiaga na mĩthiĩre mĩrũngĩrĩru nĩwe mwĩtigĩri Jehova,
\q2 no ũrĩa mĩthiĩre yake ĩrĩ mĩhĩtanu nĩamũmenete.
\b
\q1 
\v 3 Mĩario ya mũndũ mũkĩĩgu nĩ rũthanju rwa kũmũhũũra,
\q2 no mĩromo ya arĩa oogĩ nĩĩmagitagĩra.
\b
\q1 
\v 4 Kũrĩa gũtarĩ ndegwa mĩharatĩ ĩkoragwo ĩrĩ mĩtheru,
\q2 no maciaro maingĩ moimanaga na hinya wa ndegwa.
\b
\q1 
\v 5 Mũira mwĩhokeku ndaheenanagia,
\q2 no mũira wa maheeni aaragia o maheeni.
\b
\q1 
\v 6 Mũnyũrũrania acaragia ũũgĩ na ndangĩwona,
\q2 no kũgĩa na ũmenyo nĩ ũhũthũ kũrĩ mũndũ ũrĩa ũkũũranaga maũndũ.
\b
\q1 
\v 7 Ikara kũraya na mũndũ mũkĩĩgu,
\q2 nĩgũkorwo ndũrĩ ũmenyo ũngĩona kuuma mĩromo-inĩ yake.
\b
\q1 
\v 8 Ũũgĩ wa arĩa abaarĩrĩri nĩũtũmaga mamenye ũhoro wa njĩra ciao,
\q2 no ũrimũ wa andũ arĩa akĩĩgu nĩũmahĩtithagia.
\b
\q1 
\v 9 Andũ arĩa akĩĩgu manyũrũragia horohio ya mehia,
\q2 no ũtugi wonekaga harĩ arĩa arũngĩrĩru.
\b
\q1 
\v 10 Ngoro o yothe nĩyũũĩ ũrũrũ wayo,
\q2 o na gĩkeno-inĩ kĩayo gũtirĩ mũndũ ũngĩnyiitanĩra nayo.
\b
\q1 
\v 11 Nyũmba ya mũndũ mwaganu nĩĩkanangwo,
\q2 no hema ya mũndũ mũrũngĩrĩru nĩĩkagaacĩra.
\b
\q1 
\v 12 Kũrĩ njĩra mũndũ onaga ta yagĩrĩire,
\q2 no marigĩrĩrio mayo yerekagĩria mũndũ o gĩkuũ-inĩ.
\b
\q1 
\v 13 O na hĩndĩ ya gũtheka ngoro no ĩkorwo ĩgĩtuura,
\q2 na gĩkeno no kĩrigĩrĩrie na kĩeha.
\b
\q1 
\v 14 Andũ arĩa matarĩ ehokeku nĩmakarĩhwo kũna nĩ ũndũ wa mĩthiĩre yao,
\q2 nake mũndũ mwega aheo kĩheo kũringana na mĩthiĩre yake.
\b
\q1 
\v 15 Mũndũ ũtarĩ ũũgĩ etĩkagia ũndũ o wothe,
\q2 no mũndũ mũbaarĩrĩri nĩacũũranagia ũhoro wa makinya make.
\b
\q1 
\v 16 Mũndũ mũũgĩ nĩetigagĩra Jehova na akeherera ũũru,
\q2 no mũndũ mũkĩĩgu ekaga maũndũ na kwĩgerera atekũmenyerera ũndũ.
\b
\q1 
\v 17 Mũndũ ũhiũhaga kũrakara ekaga maũndũ ma ũrimũ,
\q2 nake mũndũ mwara nĩamenagwo.
\b
\q1 
\v 18 Andũ arĩa matarĩ ũũgĩ magayaga ũrimũ,
\q2 no arĩa abaarĩrĩri mahumbagwo thũmbĩ ya ũmenyo.
\b
\q1 
\v 19 Andũ arĩa ooru nĩmakainamĩrĩra harĩ arĩa ega,
\q2 na arĩa aaganu mainamĩrĩre ihingo-inĩ cia arĩa athingu.
\b
\q1 
\v 20 Andũ arĩa athĩĩni mathũũragwo o na nĩ andũ a itũũra rĩao,
\q2 no itonga irĩ arata aingĩ.
\b
\q1 
\v 21 Mũndũ ũrĩa ũmenaga mũndũ wa itũũra rĩake nĩ kwĩhia ehagia,
\q2 no kũrathimwo nĩ ũrĩa ũiguagĩra athĩĩni tha.
\b
\q1 
\v 22 Andũ arĩa mathugundaga ũũru githĩ ti njĩra mahĩtagia?
\q2 No arĩa mabangaga maũndũ mega monaga ũtugi na wĩhokeku.
\b
\q1 
\v 23 Wĩra wothe wa hinya ũrehaga uumithio,
\q2 no mĩario mĩtheri ĩrehaga o ũthĩĩni.
\b
\q1 
\v 24 Ũtonga wa andũ arĩa oogĩ nĩguo thũmbĩ yao,
\q2 no ũrimũ wa andũ akĩĩgu ũciaraga ũrimũ.
\b
\q1 
\v 25 Mũira mwĩhokeku nĩahonokagia mĩoyo,
\q2 no mũira wa maheeni nĩ mũheenania.
\b
\q1 
\v 26 Mũndũ ũrĩa wĩtigagĩra Jehova arĩ na kĩĩhitho kĩrũmu,
\q2 o na ciana ciake nĩho irĩũragĩra.
\b
\q1 
\v 27 Gwĩtigĩra Jehova nĩ gĩthima kĩa muoyo,
\q2 kũhũndũraga mũndũ kuuma mĩtego-inĩ ya gĩkuũ.
\b
\q1 
\v 28 Ũingĩ wa andũ nĩguo riiri wa mũthamaki,
\q2 no mũnene ũtarĩ andũ a gwatha nĩ mwanangĩku.
\b
\q1 
\v 29 Mũndũ mũkirĩrĩria arĩ ũmenyo mũingĩ,
\q2 no mũndũ ũhiũhaga kũrakara onanagia ũrimũ.
\b
\q1 
\v 30 Ngoro ĩrĩ na thayũ ĩheaga mwĩrĩ muoyo,
\q2 no ũiru ũbuthagia mahĩndĩ.
\b
\q1 
\v 31 Mũndũ ũrĩa ũhinyagĩrĩria athĩĩni nĩkũnyarara anyararaga Ũrĩa wamombire,
\q2 no ũrĩa wothe ũiguagĩra athĩĩni tha, nĩ Ngai atĩĩaga.
\b
\q1 
\v 32 Rĩrĩa mũtino woka, arĩa aaganu matungumanagio thĩ,
\q2 no arĩa athingu, o na gĩkuũ-inĩ makoragwo marĩ na rĩũrĩro.
\b
\q1 
\v 33 Ũũgĩ nĩ ũikaraga ngoro-inĩ ya ũrĩa ũũĩ gũkũũrana maũndũ,
\q2 o na gatagatĩ ka irimũ nĩwĩmenyithanagia.
\b
\q1 
\v 34 Ũthingu nĩgũtũũgĩria ũtũũgagĩria rũrĩrĩ,
\q2 no mehia nĩ gĩconoko harĩ andũ o othe.
\b
\q1 
\v 35 Mũthamaki nĩakenagio nĩ ndungata njũgĩ,
\q2 no nĩangʼũrĩkagio nĩ ndungata ĩrĩa ĩmũconorithagia.
\b
\c 15
\q1 
\v 1 Icookio rĩa ũhooreri nĩrĩeheragia mangʼũrĩ,
\q2 no kiugo kĩa ũũru kĩarahũraga marakara.
\b
\q1 
\v 2 Rũrĩmĩ rwa mũndũ ũrĩa mũũgĩ rũgaathagĩrĩria ũmenyo,
\q2 no kanua ka mũndũ mũkĩĩgu gathothokaga ũrimũ.
\b
\q1 
\v 3 Maitho ma Jehova marĩ kũndũ guothe,
\q2 magacũthagĩrĩria andũ arĩa aaganu o na arĩa eega.
\b
\q1 
\v 4 Rũrĩmĩ rũrĩa rũrehaga kĩhonia nĩ ta mũtĩ wa muoyo,
\q2 no rũrĩmĩ rwa maheeni rũthuthaga ngoro.
\b
\q1 
\v 5 Mũndũ mũkĩĩgu aregaga ũtaaro wa ithe,
\q2 no mũndũ ũrĩa wĩtĩkagĩra kũrũngwo onanagia ũbaarĩrĩri.
\b
\q1 
\v 6 Nyũmba ya mũndũ mũthingu ĩkoragwo na kĩgĩĩna kĩnene,
\q2 no uumithio wa andũ aaganu ũmarehagĩra thĩĩna.
\b
\q1 
\v 7 Mĩromo ya andũ arĩa oogĩ ĩtambagia o ũũgĩ,
\q2 no tiguo ngoro cia andũ arĩa akĩĩgu ciĩkaga.
\b
\q1 
\v 8 Igongona rĩa andũ arĩa aaganu nĩ kĩndũ kĩrĩ magigi harĩ Jehova,
\q2 no mahooya ma mũndũ ũrĩa mũrũngĩrĩru nĩamakenagĩrĩra.
\b
\q1 
\v 9 Njĩra cia andũ arĩa aaganu nĩ kĩndũ kĩrĩ magigi harĩ Jehova,
\q2 no nĩendete andũ arĩa mathingataga ũthingu.
\b
\q1 
\v 10 Iherithia rĩtarĩ rĩa tha rĩetereire mũndũ ũrĩa ũtigĩte njĩra,
\q2 na mũndũ ũrĩa ũthũire kũrũngwo nĩagaakua.
\b
\q1 
\v 11 Gĩkuũ na Mwanangĩko ciikaraga ciĩyanĩkĩte mbere ya Jehova,
\q2 ĩ nacio ngoro cia andũ-rĩ, ikĩĩanĩkĩte atĩa!
\b
\q1 
\v 12 Mũnyũrũrania nĩathũire kũrũngwo;
\q2 ndangĩhooya kĩrĩra kũrĩ ũrĩa mũũgĩ.
\b
\q1 
\v 13 Ngoro ngenu ĩtũmaga gĩthiithi gĩthere,
\q2 no ruo rwa ngoro rũthuthaga roho.
\b
\q1 
\v 14 Ngoro ĩrĩ na gũkũũrana maũndũ nĩĩmaathaga ũmenyo,
\q2 no kanua ka mũndũ mũkĩĩgu kehũũnagia na ũrimũ.
\b
\q1 
\v 15 Matukũ mothe ma andũ arĩa ahatĩrĩrie nĩ ma thĩĩna,
\q2 no ngoro ĩrĩa njanjamũku ĩkoragwo na ndĩa hĩndĩ ciothe.
\b
\q1 
\v 16 Nĩ kaba kĩndũ kĩnini hamwe na gwĩtigĩra Jehova,
\q2 gũkĩra ũtonga mũnene ũrĩ na kĩnyariirĩko.
\b
\q1 
\v 17 Nĩ kaba kũrĩa rwĩga rwa nyeni harĩa harĩ wendo,
\q2 gũkĩra kũrĩa njaũ noru harĩa harĩ na rũthũũro.
\b
\q1 
\v 18 Mũndũ ũhiũhaga kũrakara aarahũraga ngarari,
\q2 no mũndũ mũkirĩrĩria nĩkũhooreria ahooragĩria haaro.
\b
\q1 
\v 19 Njĩra ya kĩgũũta nĩkũhingwo ĩhingĩtwo na mĩigua,
\q2 no njĩra ya mũndũ mũrũngĩrĩru nĩ njĩra njariĩ.
\b
\q1 
\v 20 Mwana mũũgĩ atũmaga ithe akene,
\q2 no mũndũ mũkĩĩgu nĩ nyina anyararaga.
\b
\q1 
\v 21 Ũrimũ ũkenagia mũndũ ũrĩa ũtooĩ gũkũũrana maũndũ,
\q2 no mũndũ ũrĩa mũkuũku nĩarũngagĩrĩria mĩthiĩre yake.
\b
\q1 
\v 22 Mĩbango nĩĩthaataga nĩ kwaga kĩrĩra,
\q2 no kũrĩ na ataarani aingĩ mĩbango nĩĩgaacagĩra.
\b
\q1 
\v 23 Mũndũ nĩaiguaga gĩkeno agĩcookia ũhoro ũrĩa wagĩrĩire,
\q2 nakĩo kiugo kĩarĩtio ihinda rĩrĩa rĩagĩrĩire, kaĩ nĩ kĩega-ĩ!
\b
\q1 
\v 24 Harĩ mũndũ ũrĩa mũũgĩ njĩra ya muoyo ĩrorete na igũrũ,
\q2 ĩmũgirie gũikũrũka mbĩrĩra-inĩ.
\b
\q1 
\v 25 Jehova nĩamomoraga nyũmba ya mũndũ ũrĩa mwĩtĩĩi,
\q2 no nĩamenyagĩrĩra mĩhaka ya mũtumia wa ndigwa.
\b
\q1 
\v 26 Meciiria ma mũndũ mwaganu nĩ kĩndũ kĩrĩ magigi harĩ Jehova,
\q2 no meciiria ma andũ arĩa atheru nĩmamũkenagia.
\b
\q1 
\v 27 Mũndũ mũkoroku arehagĩra nyũmba yake thĩĩna,
\q2 no ũrĩa ũthũire mahaki nĩagatũũra muoyo.
\b
\q1 
\v 28 Ngoro ya mũndũ mũthingu nĩĩthimaga macookio mayo,
\q2 no kanua ka mũndũ mwaganu gathothokaga ũũru.
\b
\q1 
\v 29 Jehova aikaraga haraaya na andũ arĩa aaganu,
\q2 no nĩaiguaga mahooya ma andũ arĩa athingu.
\b
\q1 
\v 30 Gũtheria gĩthiithi nĩkũrehagĩra ngoro gĩkeno,
\q2 naguo ũhoro ũrĩa mwega nĩwĩkĩraga mahĩndĩ hinya.
\b
\q1 
\v 31 Mũndũ ũrĩa ũthikagĩrĩria ikaanania rĩrĩa rĩrehaga muoyo
\q2 nĩagatũũrania na andũ arĩa oogĩ.
\b
\q1 
\v 32 Mũndũ ũrĩa ũregaga kũigua agĩkaanio nĩ kwĩnyarara enyararaga we mwene,
\q2 no mũndũ ũrĩa wothe wĩtĩkagĩra kũrũngwo agĩĩaga na ũtaũku.
\b
\q1 
\v 33 Gwĩtigĩra Jehova nĩkuo kũheaga mũndũ ũũgĩ,
\q2 nakuo kwĩnyiihia gũtongoragia gĩtĩĩo.
\b
\c 16
\q1 
\v 1 Mĩbango ya ngoro nĩ ya mũndũ,
\q2 no icookio rĩa rũrĩmĩ riumaga harĩ Jehova.
\b
\q1 
\v 2 Mũndũ onaga mĩthiĩre yake yothe ĩrĩ mĩega,
\q2 no Jehova nĩwe ũthimaga matanya.
\b
\q1 
\v 3 Rekagĩrĩria Jehova maũndũ mothe marĩa ũrĩĩkaga,
\q2 nayo mĩbango yaku nĩĩrĩgaacagĩra.
\b
\q1 
\v 4 Jehova ombire indo ciothe irĩ na gĩtũmi gĩacio,
\q2 ĩĩ-ni, o na arĩa aaganu aamoombire nĩ ũndũ wa mũthenya wa thĩĩna.
\b
\q1 
\v 5 Mũndũ wothe wa ngoro ya mwĩtĩĩo nĩ kĩndũ kĩrĩ magigi harĩ Jehova.
\q2 Menyai na ma atĩrĩ, ndakaaga kũherithio.
\b
\q1 
\v 6 Mehia nĩmahorohagĩrio nĩ wendo na wĩhokeku,
\q2 na nĩ ũndũ wa gwĩtigĩra Jehova-rĩ, mũndũ nĩeheragĩra ũũru.
\b
\q1 
\v 7 Rĩrĩa mĩthiĩre ya mũndũ yakenia Jehova-rĩ,
\q2 atũmaga o na thũ ciake itũũranie nake na thayũ.
\b
\q1 
\v 8 Kaba indo nini cionekete na njĩra ya ũthingu,
\q2 gũkĩra uumithio mũnene ũtarĩ wa kĩhooto.
\b
\q1 
\v 9 Mũndũ nĩabangaga na ngoro mũthiĩre wake,
\q2 no Jehova nĩwe ũroragia makinya make kũrĩa ekũgerera.
\b
\q1 
\v 10 Mĩromo ya mũthamaki yaragia ũhoro taarĩ ndũmĩrĩri,
\q2 na kanua gake gatiagĩrĩirwo kuogomia kĩhooto.
\b
\q1 
\v 11 Igeri na ratiri cia ma nĩ cia Jehova;
\q2 mahiga mothe ma gũthima marĩa marĩ mũhuko-rĩ, o namo no wĩra wake.
\b
\q1 
\v 12 Kũrĩ athamaki-rĩ, gwĩka ũũru nĩ ũndũ ũrĩ magigi,
\q2 nĩgũkorwo gĩtĩ kĩa ũnene kĩĩhaandaga nĩ ũndũ wa ũthingu.
\b
\q1 
\v 13 Athamaki nĩmakenagĩra mĩromo ĩrĩa yaragia ma;
\q2 nĩ marĩ bata na mũndũ waragia ũhoro wa ma.
\b
\q1 
\v 14 Mangʼũrĩ ma mũthamaki nĩ ta mũtũmwo wa gĩkuũ,
\q2 no mũndũ mũũgĩ nĩakamahooreria.
\b
\q1 
\v 15 Gũthererwo gĩthiithi nĩ mũthamaki nĩ muoyo;
\q2 ũtugi wake ũtariĩ ta itu rĩa mbura ĩrĩa ĩkũragia irio.\f + \fr 16:15 \ft Mbura ĩno ya gũkũria irio nĩĩrehaga kũgaacĩra na gĩkeno.\f*
\b
\q1 
\v 16 Hĩ! Kaĩ kũgĩa ũũgĩ nĩ kwega gũkĩra thahabu-ĩ,
\q2 gũthuura ũtaũku gũgakĩra kũgĩa na betha!
\b
\q1 
\v 17 Njĩra njariĩ ya arĩa arũngĩrĩru yeheragĩra ũũru;
\q2 mũndũ ũrĩa ũmenyagĩrĩra mĩthiĩre yake nĩ muoyo wake mwene agitagĩra.
\b
\q1 
\v 18 Mwĩtĩĩo ũrũmagĩrĩrwo nĩ mwanangĩko,
\q2 roho wa mwĩtũũgĩrio ũkarũmĩrĩrwo nĩ kũgũa.
\b
\q1 
\v 19 Nĩ kaba roho wa kwĩnyiihia na gũkorwo hamwe na arĩa ahinyĩrĩrie,
\q2 gũkĩra kũgayana indo cia ndaho na arĩa etĩĩi.
\b
\q1 
\v 20 Mũndũ ũrĩa ũrũmbũyagia mataaro nĩagaacagĩra,
\q2 na kũrathimwo nĩ mũndũ ũrĩa wĩhokaga Jehova.
\b
\q1 
\v 21 Arĩa oogĩ ngoro-inĩ metagwo akũũrani maũndũ,
\q2 na ciugo njega itũũgagĩria ũtaaro.
\b
\q1 
\v 22 Ũtaũku nĩ gĩthima kĩa muoyo kũrĩ arĩa marĩ naguo,
\q2 no ũrimũ ũrehaga iherithia kũrĩ andũ arĩa akĩĩgu.
\b
\q1 
\v 23 Ngoro ya mũndũ mũũgĩ nĩyo ĩtongoragia kanua gake,
\q2 nayo mĩromo yake ĩtũũgagĩria ũtaaro.
\b
\q1 
\v 24 Ndeto njega nĩ igua rĩa ũũkĩ,
\q2 irĩ mũrĩo ngoro-inĩ, na harĩ mahĩndĩ nĩ ũgima.
\b
\q1 
\v 25 Kũrĩ njĩra mũndũ onaga ta yagĩrĩire,
\q2 no marigĩrĩrio mayo yerekagĩra gĩkuũ-inĩ.
\b
\q1 
\v 26 Kũhũũta kwa mũruti wa wĩra nĩkuo kũmũteithagia,
\q2 ngʼaragu yake nĩyo ĩmũtindĩkaga.
\b
\q1 
\v 27 Kĩmaramari gĩthugundaga ũũru,
\q2 na mĩario yakĩo nĩ ta mwaki wa gũcina.
\b
\q1 
\v 28 Mũndũ mwaganu arehaga ngarari,
\q2 na mũhuhu ũtigithanagia andũ marĩ ũrata mũnene.
\b
\q1 
\v 29 Mũndũ wa haaro aheenagĩrĩria mũndũ wa itũũra rĩake,
\q2 akamũtongoria njĩra-inĩ ĩtarĩ njega.
\b
\q1 
\v 30 Mũndũ ũrĩa uunagĩra andũ riitho akoragwo agĩthugunda waganu,
\q2 ũrĩa ũtembanagia mĩromo akoragwo agĩthugunda ũũru.
\b
\q1 
\v 31 Mbuĩ nĩ thũmbĩ ya riiri;
\q2 cionekaga nĩ ũndũ wa mũtũũrĩre wa ũthingu.
\b
\q1 
\v 32 Nĩ kaba mũndũ mũkirĩrĩria gũkĩra njamba ya ita,
\q2 na nĩ kaba mũndũ ũrĩa ũrigagĩrĩria marakara make gũkĩra ũrĩa wĩnyiitagĩra itũũra inene.
\b
\q1 
\v 33 Mĩtĩ ĩcuukagĩrwo maru-inĩ,
\q2 no itua o rĩothe riumaga kũrĩ Jehova.
\b
\c 17
\q1 
\v 1 Nĩ kaba kĩenyũ kĩũmũ kĩa mũgate kũndũ kũrĩ na thayũ na ũhooreri,
\q2 gũkĩra nyũmba ĩiyũrĩte ndĩa no ĩrĩ na ngũĩ.
\b
\q1 
\v 2 Ndungata ĩrĩ na ũũgĩ ĩgaatuĩka ya gwatha mũriũ wa mwene yo ũrĩa ũrehaga njono,
\q2 na nĩĩkegwatĩra igai ĩrĩ ta ũmwe wa ariũ a mwathi wayo.
\b
\q1 
\v 3 Nyũngũ nĩ ya gũthererio betha, na kĩrugutĩro nĩ gĩa gũthererio thahabu,
\q2 no Jehova nĩwe ũgeragia ngoro cia andũ.
\b
\q1 
\v 4 Mũndũ mwaganu athikagĩrĩria mĩromo ĩrĩa yaragia waganu;
\q2 nake mũndũ wa maheeni athikagĩrĩria rũrĩmĩ rũrĩa rwaragia maũndũ ma gũthũkia.
\b
\q1 
\v 5 Mũndũ ũrĩa ũthekagĩrĩra athĩĩni nĩkũmena amenaga Ũrĩa wamombire;
\q2 mũndũ ũrĩa ũkenagĩra mũtino ndakaaga kũherithio.
\b
\q1 
\v 6 Ciana cia ciana nĩ thũmbĩ harĩ andũ arĩa akũrũ,
\q2 nao aciari nĩo riiri wa ciana ciao.
\b
\q1 
\v 7 Mĩario ya bata ndĩagĩrĩire kanua ka mũndũ mũkĩĩgu,
\q2 na makĩria mĩario ya maheeni ndĩagĩrĩire mũndũ ũrĩa wathanaga!
\b
\q1 
\v 8 Ihaki rĩhaana ta ihiga rĩa kũrehe mũnyaka kũrĩ ũrĩa ũhakanaga;
\q2 kũrĩa guothe athiiaga nĩagaacagĩra.
\b
\q1 
\v 9 Mũndũ ũrĩa ũhumbagĩra ihĩtia nĩ wendo acaragia,
\q2 no ũrĩa ũcookagĩra ũhoro atigithanagia andũ marĩ ũrata mũnene.
\b
\q1 
\v 10 Kũrũithio nĩgũkenagia mũndũ ũrĩa ũkũũranaga maũndũ
\q2 gũkĩra iboko igana harĩ mũndũ mũkĩĩgu.
\b
\q1 
\v 11 Mũndũ mũũru arongooragia o ũremi;
\q2 nĩ ũndũ ũcio nĩagatũmĩrwo mũnene ũtarĩ tha amũũkĩrĩre.
\b
\q1 
\v 12 Nĩ kaba gũcemania na nduba ĩtunyĩtwo ciana ciayo
\q2 gũkĩra gũcemania na mũndũ mũkĩĩgu na ũrimũ wake.
\b
\q1 
\v 13 Mũndũ angĩrĩha wega na ũũru,
\q2 ũũru ndũkeehera nyũmba-inĩ yake.
\b
\q1 
\v 14 Kwambĩrĩria haaro nĩ ta kũhingũrĩra maaĩ mahingĩrĩrie;
\q2 nĩ ũndũ ũcio tiganaga na ũhoro ũcio ngarari itaanagĩa.
\b
\q1 
\v 15 Gũtuĩra mũndũ mwaganu atĩ ndehĩtie na gũtuĩra ũrĩa ũtehĩtie atĩ nĩ mwĩhia,
\q2 maũndũ macio meerĩ nĩ marĩ magigi harĩ Jehova.
\b
\q1 
\v 16 Mbeeca nĩ cia bata ũrĩkũ irĩ guoko-inĩ kwa mũndũ mũkĩĩgu,
\q2 na ndangĩhota kũgũra ũũgĩ, na ndarĩ ngoro ya kwenda gũtaũkĩrwo?
\b
\q1 
\v 17 Mũrata wa mũndũ amwendaga hĩndĩ ciothe,
\q2 nake mũrũ wa nyina na mũndũ aciaragwo nĩ ũndũ wa hĩndĩ ya thĩĩna.
\b
\q1 
\v 18 Mũndũ ũtooĩ gũkũũrana maũndũ atuĩkaga wa kũrĩha thiirĩ wa mũndũ ũngĩ
\q2 o na akaiga kĩndũ gĩa kũrũgamĩrĩra thiirĩ wa mũndũ wa itũũra rĩake.
\b
\q1 
\v 19 Mũndũ ũrĩa wendete haaro nĩ mehia endete;
\q2 na mũndũ ũrĩa wakaga kĩhingo kĩraihu na igũrũ eĩtagĩria wanangĩki.
\b
\q1 
\v 20 Mũndũ ũrĩ ngoro ya ũremi ndagaacagĩra;
\q2 nake mũndũ ũrĩa ũrĩ rũrĩmĩ rwa kũheenania agũũaga thĩĩna-inĩ.
\b
\q1 
\v 21 Kũgĩa na mũriũ mũkĩĩgu kũrehaga ihooru;
\q2 ithe wa mũndũ mũkĩĩgu ndarĩ hĩndĩ akenaga.
\b
\q1 
\v 22 Ngoro ngenu nĩ ndawa njega,
\q2 no roho mũthuthĩku ũngʼaragia mahĩndĩ.
\b
\q1 
\v 23 Mũndũ mwaganu amũkagĩra ihaki na hitho,
\q2 nĩguo ogomie ciira wa kĩhooto.
\b
\q1 
\v 24 Mũndũ ũkũũranaga maũndũ aikaraga arorete o ũũgĩ,
\q2 no maitho ma mũndũ mũkĩĩgu morũũraga nginya ituri cia thĩ.
\b
\q1 
\v 25 Mwana mũkĩĩgu arehagĩra ithe kĩeha,
\q2 na marũrũ kũrĩ nyina ũrĩa wamũciarire.
\b
\q1 
\v 26 Ti wega kũherithia mũndũ ũtekĩte mahĩtia,
\q2 kana kũhũũra anene nĩ ũndũ wa ũrũngĩrĩru wao.
\b
\q1 
\v 27 Mũndũ ũrĩ na ũmenyo aragia ciugo athimĩte,
\q2 nake mũndũ ũrĩ na ũtaũku aikaraga ahooreire.
\b
\q1 
\v 28 O na mũndũ mũkĩĩgu angĩkira nĩonagwo arĩ mũũgĩ,
\q2 na akoneka arĩ mũtaũku angĩtumia kanua.
\b
\c 18
\q1 
\v 1 Mũndũ ũrĩa ũtendaga gũtũũrania na andũ arũmagĩrĩra o merirĩria make;
\q2 ningĩ areganaga na matua mothe ma ũũgĩ ũrĩa mũkinyanĩru.
\b
\q1 
\v 2 Mũndũ mũkĩĩgu ndakenagĩra ũtaũku,
\q2 no akenagĩra kwaria woni wake mwene.
\b
\q1 
\v 3 Rĩrĩa waganu woka, ũrehaga ũirano,
\q2 nacio njono irehaga thoni.
\b
\q1 
\v 4 Ciugo cia kanua ka mũndũ nĩ ta ndia ndiku,
\q2 no gĩthima kĩa ũũgĩ nĩ karũũĩ gatherũkaga.
\b
\q1 
\v 5 Ti wega gũtĩĩra andũ arĩa aaganu maũthĩ,
\q2 kana kuogomia kĩhooto kĩa arĩa matehĩtie.
\b
\q1 
\v 6 Mĩromo ya mũndũ mũkĩĩgu ĩmũrehagĩra ngũĩ,
\q2 nako kanua gake geetagia rũthanju.
\b
\q1 
\v 7 Kanua ka mũndũ mũkĩĩgu nĩko kamũthũkagĩria maũndũ,
\q2 nayo mĩromo yake nĩ mũtego wa ngoro yake.
\b
\q1 
\v 8 Ndeto cia mũndũ wa mũhuhu nĩ ta twenyũ twega twa irio;
\q2 tũmerũkaga nginya tũturi-inĩ twa nda tũrĩa tũrĩ thĩinĩ mũno.
\b
\q1 
\v 9 Mũndũ kĩgũũta wĩra-inĩ wake
\q2 nĩ wa nyina na ũrĩa wanangaga.
\b
\q1 
\v 10 Rĩĩtwa rĩa Jehova nĩ mũthiringo ũrĩ hinya;
\q2 arĩa athingu moragĩra ho, nao magaikara marĩ agitĩre.
\b
\q1 
\v 11 Ũtonga wa andũ arĩa atongu nĩguo itũũra rĩao rĩa hinya;
\q2 meciiragia nĩ rũthingo rũtangĩhaicĩka.
\b
\q1 
\v 12 Mbere ya mwanangĩko, ngoro ya mũndũ ĩkoragwo na mwĩtĩĩo,
\q2 no kwĩnyiihia nĩkuo gũtongoragia gĩtĩĩo.
\b
\q1 
\v 13 Mũndũ ũrĩa ũcookagia ũhoro mbere ya kũũthikĩrĩria,
\q2 ũndũ ũcio nĩ ũrimũ na thoni ciake.
\b
\q1 
\v 14 Roho wa mũndũ nĩguo ũmũũmagĩrĩria rĩrĩa arĩ mũrũaru,
\q2 no roho mũthuthĩku nũũ ũngĩhota kũwĩtiiria?
\b
\q1 
\v 15 Ngoro ya mũndũ mũkũũrani maũndũ nĩĩgĩagĩra ũmenyo;
\q2 matũ ma arĩa oogĩ nĩmaũcaragĩrĩria.
\b
\q1 
\v 16 Kĩheo mũndũ aheanĩte kĩmuonagia njĩra ya kũhĩtũkĩra,
\q2 gĩkamũkinyia harĩ andũ arĩa anene.
\b
\q1 
\v 17 Mũndũ ũrĩa ũrehaga ciira wake mbere onekaga taarĩ we na ma,
\q2 o nginya rĩrĩa mũndũ ũrĩa maraciira nake ooka kũmũũria ciũria.
\b
\q1 
\v 18 Ũcuuki wa mĩtĩ nĩũniinaga ngarari,
\q2 na ũgateithũrana andũ eerĩ njamba.
\b
\q1 
\v 19 Mũndũ mũrakarie nĩ mũrũ wa nyina nĩ hinya kwĩiguithania nake gũkĩra kwĩgwatĩra itũũra inene rĩirigĩre,
\q2 nacio ngarari nĩ ta mĩgĩĩko ĩrĩa ĩhingaga njeera.
\b
\q1 
\v 20 Nda ya mũndũ nĩĩhũũnagio nĩ maciaro ma kanua gake;
\q2 nĩaiganagwo nĩ magetha ma mĩromo yake.
\b
\q1 
\v 21 Rũrĩmĩ rũrĩ na hinya wa gwathĩrĩra mũndũ muoyo kana gĩkuũ,
\q2 no arĩa marwendete no marĩĩage maciaro maaruo.
\b
\q1 
\v 22 Mũndũ ũrĩa wĩgĩĩagĩra na mũtumia nĩegĩagĩra na kĩndũ kĩega,
\q2 na nĩgũtugwo atugĩtwo nĩ Jehova.
\b
\q1 
\v 23 Mũndũ mũthĩĩni athaithanaga aiguĩrwo tha,
\q2 no gĩtonga gĩcookagia ũhoro na ũũru.
\b
\q1 
\v 24 Mũndũ mũceeri na andũ aingĩ aahota kwĩyũnũhithia,
\q2 no nĩ kũrĩ mũrata ũnyiitanaga na mũndũ gũkĩra mũrũ wa nyina na mũndũ.
\b
\c 19
\q1 
\v 1 Nĩ kaba mũndũ mũthĩĩni ũrĩa ũthiiaga na mĩthiĩre ĩtarĩ ũcuuke,
\q2 gũkĩra mũndũ mũkĩĩgu waragia waganu.
\b
\q1 
\v 2 Ti wega kũgĩa na kĩyo hatarĩ na ũmenyo,
\q2 ningĩ kũhĩkĩka mũno gũtũmaga mũndũ ahĩtie njĩra.
\b
\q1 
\v 3 Ũrimũ wa mũndũ nĩguo wanangaga muoyo wake,
\q2 nayo ngoro yake ĩtetagia Jehova.
\b
\q1 
\v 4 Ũtonga nĩwongagĩrĩra mũndũ arata aingĩ,
\q2 no mũndũ mũthĩĩni nĩeheragĩrwo nĩ mũratawe.
\b
\q1 
\v 5 Mũira wa maheeni ndakaaga kũherithio,
\q2 na ũrĩa ũitũrũraga maheeni ndageethara.
\b
\q1 
\v 6 Andũ aingĩ macaragia ũrĩa mangĩendwo nĩ mũnene,
\q2 na mũndũ mũheani iheo-rĩ, nĩ mũrata wa andũ othe.
\b
\q1 
\v 7 Angĩkorwo mũndũ mũthĩĩni nĩatiganagio nĩ andũ ao othe-rĩ,
\q2 ĩ nao arata ake mangĩkĩmwĩtheema atĩa!
\q1 O na angĩmathingata akĩmathaithaga,
\q2 nĩmethiĩrĩire, matirĩ ho.
\b
\q1 
\v 8 Mũndũ ũrĩa wĩgĩĩagĩra na ũũgĩ nĩ ngoro yake mwene endete;
\q2 ũrĩa ũkenagĩra ũtaũku nĩagaacagĩra.
\b
\q1 
\v 9 Mũira wa maheeni ndakaaga kũherithio,
\q2 na ũrĩa ũitũrũraga maheeni nĩakoorwo nĩ muoyo.
\b
\q1 
\v 10 Gũtiagĩrĩire mũndũ mũkĩĩgu gũikaraga egangarĩte;
\q2 gũkĩrĩ ũũru makĩria ngombo gwatha anene!
\b
\q1 
\v 11 Ũũgĩ wa mũndũ nĩũmũheaga ũkirĩrĩria,
\q2 riiri wake nĩkũrekera andũ arĩa angĩ mahĩtia mao.
\b
\q1 
\v 12 Marakara ma mũthamaki nĩ ta mũraramo wa mũrũũthi,
\q2 no ũtugi wake nĩ ta ime rĩrĩ nyeki-inĩ.
\b
\q1 
\v 13 Mwana mũkĩĩgu nĩ mwanangĩko harĩ ithe,
\q2 na mũtumia wa haaro ahaana ta maaĩ maratata mategũtigithĩria.
\b
\q1 
\v 14 Nyũmba na ũtonga igayagwo kuuma kũrĩ aciari,
\q2 no mũtumia mũbaarĩrĩri maũndũ oimaga kũrĩ Jehova.
\b
\q1 
\v 15 Ũgũũta ũrehaga toro mũnene,
\q2 na mũndũ gĩthayo arĩĩagwo nĩ ngʼaragu.
\b
\q1 
\v 16 Mũndũ ũrĩa wathĩkagĩra maathani-rĩ, nĩ muoyo wake amenyagĩrĩra,
\q2 no ũrĩa ũtoonaga bata wa kũmenyerera mĩthiĩre yake nĩagaakua.
\b
\q1 
\v 17 Mũndũ ũrĩa ũiguagĩra athĩĩni tha nĩ Jehova akombagĩra indo,
\q2 nake Jehova nĩakamũrĩha nĩ ũndũ wa ũrĩa ekĩte.
\b
\q1 
\v 18 Rũithagia mũrũguo hĩndĩ ĩrĩa kũrĩ na kĩĩrĩgĩrĩro;
\q2 tiga kwenda gũtũma akooragwo.
\b
\q1 
\v 19 Mũndũ wa marakara mahiũ no nginya aherithio;
\q2 ũngĩmũteithũra rĩmwe no nginya ũkaamũteithũra rĩngĩ.
\b
\q1 
\v 20 Thikĩrĩria mataaro na wĩtĩkĩre ũrutani,
\q2 marigĩrĩrio-inĩ nĩũgaatuĩka mũndũ mũũgĩ.
\b
\q1 
\v 21 Mĩbango ya ngoro ya mũndũ nĩ mĩingĩ,
\q2 no muoroto wa Jehova noguo ũkaahinga.
\b
\q1 
\v 22 Kĩrĩa mũndũ eriragĩria nĩ wendo ũrĩa ũtathiraga,
\q2 nĩ kaba gũthĩĩna gũkĩra mũndũ wa maheeni.
\b
\q1 
\v 23 Gwĩtigĩra Jehova gũkinyagia mũndũ muoyo-inĩ:
\q2 Hĩndĩ ĩyo mũndũ akahurũka aiganĩire, atarĩ na thĩĩna.
\b
\q1 
\v 24 Kĩgũũta kĩrikagia guoko gwakĩo thaani-inĩ;
\q2 gĩgakĩremwo o na nĩgũgũcookia kanua!
\b
\q1 
\v 25 Hũũra mũnyũrũrania, nao arĩa mateciiragia merute kũgĩa na ũbaarĩrĩri;
\q2 kaania mũkũũrani maũndũ, na nĩekuongerera ũmenyo.
\b
\q1 
\v 26 Mũndũ ũrĩa ũtunyaga ithe indo na akaingata nyina,
\q2 nĩ mwana wa kũrehe thoni na gĩconoko.
\b
\q1 
\v 27 Mũrũ wakwa, ũngĩtiga gũthikĩrĩria mataaro-rĩ,
\q2 nĩũkoora njĩra ũtigane na ciugo cia ũmenyo.
\b
\q1 
\v 28 Mũira wa kũhakwo anyũrũragia kĩhooto,
\q2 na kanua ka mũndũ mwaganu kameragia o ũũru.
\b
\q1 
\v 29 Maherithia maigĩirwo anyũrũrania,
\q2 nacio iboko ikaigĩrwo mĩgongo ya andũ arĩa akĩĩgu.
\b
\c 20
\q1 
\v 1 Ndibei nĩ mũnyũrũrania, na njoohi nĩ mũndũ wa ngũĩ;
\q2 mũndũ ũrĩa ũhĩtithagio nĩcio ti mũũgĩ.
\b
\q1 
\v 2 Mangʼũrĩ ma mũthamaki nĩ ta mũraramo wa mũrũũthi;
\q2 ũrĩa ũmũrakaragia nĩ muoyo wake ateaga.
\b
\q1 
\v 3 Gwĩtheema ngũĩ kũrehagĩra mũndũ gĩtĩĩo,
\q2 no mũndũ o wothe mũkĩĩgu ahiũhaga kũũgitana.
\b
\q1 
\v 4 Kĩgũũta gĩticimbaga hĩndĩ ya irĩma;
\q2 nĩ ũndũ ũcio hĩndĩ ya magetha gĩathiĩ kũmaatha gĩtirĩ kĩndũ kĩonaga.
\b
\q1 
\v 5 Muoroto wa ngoro ya mũndũ nĩ ta maaĩ ma ndia ndiku,
\q2 no mũndũ ũrĩ na ũtaũku nĩamatahaga.
\b
\q1 
\v 6 Andũ aingĩ metuaga marĩ na wendo ũtangĩthira,
\q2 no mũndũ mwĩhokeku-rĩ, nũũ ũngĩmuona?
\b
\q1 
\v 7 Mũndũ mũthingu atũũraga mũtũũrĩre ũtarĩ ũcuuke;
\q2 kũrathimwo-rĩ, nĩ ciana ciake iria atigaga.
\b
\q1 
\v 8 Rĩrĩa mũthamaki aikarĩra gĩtĩ gĩake kĩa ũnene atue ciira,
\q2 maitho make mathũngũrũraga ũũru wothe.
\b
\q1 
\v 9 Nũũ ũngiuga atĩrĩ, “Nĩnjigĩte ngoro yakwa ĩrĩ theru;
\q2 ndĩ mũtheru, na ndirĩ na mehia”?
\b
\q1 
\v 10 Mahiga ma ratiri mataiganainie ũritũ, o na ithimi itaiganĩte:
\q2 cierĩ nĩ indo irĩ magigi harĩ Jehova.
\b
\q1 
\v 11 O na kaana kamenyekaga nĩ ũndũ wa ciĩko ciako,
\q2 gakamenyeka kana mĩtugo yako nĩ mĩtheru, na kana nĩ mĩagĩrĩru.
\b
\q1 
\v 12 Matũ marĩa maiguaga na maitho marĩa monaga-rĩ,
\q2 cierĩ nĩ Jehova waciũmbire.
\b
\q1 
\v 13 Tiga kwenda toro, ndũkae gũthĩĩna;
\q2 ikaraga wĩiguĩte, na nĩũrĩrĩĩaga irio ũkahũũna.
\b
\q1 
\v 14 Mũgũri akĩgũra oigaga atĩrĩ, “Kĩndũ gĩkĩ ti kĩega, ti kĩega!”
\q2 Agacooka agathiĩ akĩĩrahaga ũrĩa oĩ kũgũra.
\b
\q1 
\v 15 Thahabu nĩ kũrĩ, o na ruru no nyingĩ,
\q2 no mĩromo ĩrĩa yaragia ũmenyo nĩ ithaga rĩa goro rĩrĩa rĩtonekaga.
\b
\q1 
\v 16 Oya nguo ya mũndũ ũrĩa ũngĩrũgamĩrĩra thiirĩ wa mũndũ wa kũngĩ;
\q2 mĩige ĩrũgamĩrĩre thiirĩ ũcio wa mũndũ wa kũngĩ.
\b
\q1 
\v 17 Irio cionekete na njĩra ya kũheenania irĩ cama harĩ mũndũ,
\q2 no thuutha kanua gake kaiyũraga o mũthanga.
\b
\q1 
\v 18 Mĩbango ĩgaacagĩra nĩ ũndũ wa kũhooya kĩrĩra,
\q2 ũngĩtua gũthiĩ mbaara-inĩ, heo ũtaaro.
\b
\q1 
\v 19 Mũndũ wa mũhuhu nĩoimagia ndeto cia ndundu nja,
\q2 nĩ ũndũ ũcio wĩthemage mũndũ waragia mũno.
\b
\q1 
\v 20 Mũndũ angĩruma ithe kana nyina,
\q2 tawa wake ũkaahorera nduma-inĩ ĩrĩa ndumanu.
\b
\q1 
\v 21 Igai rĩrĩa rĩoneka narua kĩambĩrĩria-inĩ,
\q2 marigĩrĩrio-inĩ rĩtituĩkaga rĩa kĩrathimo.
\b
\q1 
\v 22 Ndũkoige atĩrĩ, “Nĩngerĩhĩria ũũru ũyũ!”
\q2 Eterera Jehova nake nĩegũkũhonokia.
\b
\q1 
\v 23 Mahiga ma ratiri mataiganainie ũritũ nĩ kĩndũ kĩrĩ magigi harĩ Jehova,
\q2 nacio ratiri itarĩ cia ma itimũkenagia.
\b
\q1 
\v 24 Makinya ma mũndũ matongoragio nĩ Jehova.
\q2 Mũndũ-rĩ, angĩkĩhota atĩa kũmenya njĩra yake mwene?
\b
\q1 
\v 25 Nĩ mũtego harĩ mũndũ kwamũrĩra Ngai kĩndũ na ihenya,
\q2 acooke gwĩcũũrania ũhoro wa mĩĩhĩtwa yake thuutha-inĩ.
\b
\q1 
\v 26 Mũthamaki mũũgĩ nĩathũngũrũraga andũ arĩa aaganu;
\q2 ageragĩria kĩgaragari gĩa gũkonyora ngano igũrũ rĩao.
\b
\q1 
\v 27 Roho wa mũndũ nĩ tawa wa Jehova,
\q2 ũthuthuuragia o nginya tũturi tũrĩa tũrĩ thĩinĩ mũno.
\b
\q1 
\v 28 Wendo na wĩhokeku nĩcigitagĩra mũthamaki;
\q2 ũtugi nĩũtũmaga gĩtĩ gĩake kĩa ũnene kĩrũme.
\b
\q1 
\v 29 Hinya wa andũ ethĩ nĩguo riiri wao,
\q2 nacio mbuĩ nĩcio riiri wa arĩa akũrũ.
\b
\q1 
\v 30 Mahũũra na nguraro nĩitheragia ũũru wa mũndũ,
\q2 nacio iboko itheragia o nginya tũturi twa thĩinĩ mũno.
\b
\c 21
\q1 
\v 1 Ngoro ya mũthamaki ĩrĩ moko-inĩ ma Jehova;
\q2 amĩroragia o kũrĩa ekwenda, o ta ũrĩa maaĩ moinithagĩrio mĩtaro-inĩ.
\b
\q1 
\v 2 Mũndũ oonaga mĩthiĩre yake yothe ĩrĩ mĩega,
\q2 no Jehova athimaga ngoro.
\b
\q1 
\v 3 Gwĩka ũrĩa kwagĩrĩire na ũrĩa ũrĩ kĩhooto
\q2 nĩ gwĩtĩkagĩrwo nĩ Jehova gũkĩra kũruta igongona.
\b
\q1 
\v 4 Maitho ma mwĩtũũgĩrio na ngoro ya mwĩtĩĩo,
\q2 o icio tawa wa arĩa aaganu-rĩ, nĩ mehia!
\b
\q1 
\v 5 Mĩbango ya arĩa marĩ kĩyo nĩĩrehaga uumithio,
\q2 o ta ũrĩa ti-itherũ ihenya inene rĩrehaga ũthĩĩni.
\b
\q1 
\v 6 Kũgĩa na ũtonga na njĩra ya rũrĩmĩ rwa maheeni
\q2 nĩ kĩbii gĩa gũthira, na nĩ mũtego wa gĩkuũ.
\b
\q1 
\v 7 Haaro ya andũ arĩa aaganu ĩkaamakururia, ĩmeherie,
\q2 nĩgũkorwo nĩmaregaga gwĩka ũrĩa kwagĩrĩire.
\b
\q1 
\v 8 Njĩra ya mũndũ mũhĩtia nĩ njogomu,
\q2 no mĩthiĩre ya mũndũ ũrĩa ũtarĩ mahĩtia nĩ mĩrũngarũ.
\b
\q1 
\v 9 Nĩ kaba gũtũũra nyũmba-igũrũ, koine-inĩ,
\q2 gũkĩra gũtũũra nyũmba thĩinĩ na mũtumia wa haaro.
\b
\q1 
\v 10 Mũndũ ũrĩa mwaganu eriragĩria gwĩka o ũũru;
\q2 ndaiguuagĩra mũndũ wa itũũra rĩake tha.
\b
\q1 
\v 11 Hĩndĩ ĩrĩa mũnyũrũrania aaherithio, arĩa maagĩte ũũgĩ nĩmohĩgaga;
\q2 hĩndĩ ĩrĩa mũndũ mũũgĩ aataarwo nĩagĩĩaga na ũmenyo.
\b
\q1 
\v 12 Ũrĩa Mũthingu, o we Ngai, nĩonaga nyũmba ya ũrĩa mwaganu,
\q2 na akarehithĩria ũcio mwaganu mwanangĩko.
\b
\q1 
\v 13 Mũndũ angĩhinga matũ ndakaigue kĩrĩro kĩa arĩa athĩĩni-rĩ,
\q2 o nake agaakaya na ndone wa kũmwĩtĩka.
\b
\q1 
\v 14 Kĩheo kĩheanĩtwo na hitho nĩkĩhooreragia marakara,
\q2 na ihaki ihithe nguo-inĩ rĩhooreragia mangʼũrĩ manene.
\b
\q1 
\v 15 Ituĩro rĩa kĩhooto rĩatuuo, rĩrehaga gĩkeno kũrĩ andũ arĩa athingu,
\q2 no rĩrehaga kĩmako kũrĩ arĩa mekaga ũũru.
\b
\q1 
\v 16 Mũndũ ũrĩa ũtiganaga na njĩra ya ũũgĩ,
\q2 akaahurũkĩra kĩũngano-inĩ kĩa arĩa akuũ.
\b
\q1 
\v 17 Mũndũ ũrĩa mwendi ikeno nĩagathĩĩna;
\q2 ũrĩa wothe mwendi ndibei na maguta-rĩ, gũtirĩ hĩndĩ agaatonga.
\b
\q1 
\v 18 Mũndũ ũrĩa mwaganu atuĩkaga irĩhi rĩa gũkũũra ũrĩa mũthingu,
\q2 na ũrĩa ũtarĩ mwĩhokeku agatuĩka irĩhi rĩa gũkũũra ũrĩa mũrũngĩrĩru.
\b
\q1 
\v 19 Nĩ kaba gũtũũra werũ-inĩ,
\q2 gũkĩra gũtũũra na mũtumia wa haaro na kũrakara narua.
\b
\q1 
\v 20 Thĩinĩ wa nyũmba ya mũndũ mũũgĩ nĩ kũrĩ mĩthemba yothe ya irio njega o na maguta,
\q2 no mũndũ mũkĩĩgu arĩĩaga kĩrĩa gĩothe arĩ nakĩo.
\b
\q1 
\v 21 Mũndũ ũrĩa ũthingataga ũthingu na wendani
\q2 nĩagĩĩaga na muoyo, na ũgaacĩru, na gĩtĩĩo.
\b
\q1 
\v 22 Mũndũ mũũgĩ atharĩkagĩra itũũra inene rĩa andũ arĩa njamba,
\q2 na akamomora kĩĩhitho kĩa hinya kĩrĩa mehokete.
\b
\q1 
\v 23 Mũndũ ũrĩa ũmenyagĩrĩra kanua gake na rũrĩmĩ rwake
\q2 nĩeyeheragia mũtino-inĩ.
\b
\q1 
\v 24 Mũndũ mwĩtĩĩi na mwĩgereri, etagwo “Mũnyũrũria”;
\q2 ekaga maũndũ make na mwĩtĩĩo mũnene.
\b
\q1 
\v 25 Merirĩria ma mũndũ kĩgũũta nĩmo makaamũũraga,
\q2 tondũ moko make matiendaga kũruta wĩra.
\q1 
\v 26 Mũthenya wothe eriragĩria o makĩria,
\q2 no arĩa athingu maheanaga mategũtara.
\b
\q1 
\v 27 Igongona rĩa mũndũ mwaganu nĩ kĩndũ kĩrĩ magigi:
\q2 ĩ rĩtikĩrĩ magigi makĩria hĩndĩ ĩrĩa rĩrehetwo na ũhinga ngoro-inĩ!
\b
\q1 
\v 28 Mũira wa maheeni nĩgũthira agaathira,
\q2 nake ũrĩa ũmũthikagĩrĩria akaanangwo nginya tene.
\b
\q1 
\v 29 Mũndũ mwaganu erũagĩrĩra na ũrũme,
\q2 no mũndũ mũrũngĩrĩru nĩeciiragia ũhoro wa mĩthiĩre yake.
\b
\q1 
\v 30 Gũtirĩ ũũgĩ, kana ũmenyi, kana kĩrĩra o na kĩrĩkũ
\q2 kĩngĩhota gũũkĩrĩra Jehova.
\b
\q1 
\v 31 Mbarathi nĩĩharagĩrio nĩ ũndũ wa mũthenya wa mbaara,
\q2 no ũhootani uumaga kũrĩ Jehova.
\b
\c 22
\q1 
\v 1 Rĩĩtwa rĩega nĩrĩakwĩrirĩrio gũkĩra ũtonga mũnene;
\q2 gũtĩĩka nĩ kwega gũkĩra betha kana thahabu.
\b
\q1 
\v 2 Andũ arĩa atongu na arĩa athĩĩni harĩ ũndũ ũmwe ũmanyiitithanĩtie;
\q2 Jehova nĩwe Mũmbi wao othe.
\b
\q1 
\v 3 Mũndũ mũbaarĩrĩri onaga ũgwati akehitha,
\q2 no arĩa matarĩ ũũgĩ mathiiaga o na mbere nao magatoonya thĩĩna-inĩ.
\b
\q1 
\v 4 Kwĩnyiihia na gwĩtigĩra Jehova
\q2 kũrehaga ũtonga, na gĩtĩĩo, na muoyo.
\b
\q1 
\v 5 Njĩra cia andũ arĩa aaganu irĩ mĩigua na mĩtego,
\q2 no ũrĩa ũgitagĩra ngoro yake aikaraga kũraya nacio.
\b
\q1 
\v 6 Menyeria mwana njĩra ĩrĩa agĩrĩirwo nĩkũgera,
\q2 na ndarĩ hĩndĩ akaamiuma o na aakũra.
\b
\q1 
\v 7 Andũ arĩa atongu nĩ mathaga arĩa athĩĩni,
\q2 na ũrĩa ũkombaga nĩ ndungata ya mũmũkoomberi.
\b
\q1 
\v 8 Mũndũ ũrĩa ũhaandaga waganu agethaga thĩĩna,
\q2 naruo rũthanju rwa marakara make nĩrũkanangwo.
\b
\q1 
\v 9 Mũndũ mũtaana we mwene nĩakarathimwo,
\q2 tondũ nĩagayagĩra arĩa athĩĩni irio ciake.
\b
\q1 
\v 10 Ingata mũnyũrũrania, nayo ngũĩ nĩĩgũkweherera;
\q2 inegene na irumi o nacio nĩcigũthira.
\b
\q1 
\v 11 Mũndũ ũrĩa wendaga ngoro theru na akaaragia maũndũ ma ũtugi,
\q2 mũthamaki nĩagatuĩka mũrata wake.
\b
\q1 
\v 12 Maitho ma Jehova nĩmamenyagĩrĩra ũmenyo,
\q2 no nĩathaahagia ciugo cia ũrĩa ũtarĩ mwĩhokeku.
\b
\q1 
\v 13 Kĩgũũta kiugaga, “Nja kũrĩ na mũrũũthi!”
\q2 Kana gĩkoiga atĩrĩ, “Nĩngũũragĩrwo njĩra-inĩ!”
\b
\q1 
\v 14 Kanua ka mũtumia mũtharia nĩ irima iriku,
\q2 nake ũrĩa werekeirio mangʼũrĩ ma Jehova agũũaga thĩinĩ wa rĩo.
\b
\q1 
\v 15 Ngoro ya mwana yohanĩtio na ũrimũ,
\q2 no rũthanju rwa kũmũherithia nĩrũkaũingata kũraya nake.
\b
\q1 
\v 16 Mũndũ ũrĩa ũhinyagĩrĩria arĩa athĩĩni nĩguo eyongerere ũtonga,
\q2 na ũrĩa ũheaga itonga iheo, eerĩ nĩmagathĩĩna.
\s1 Mĩario ya arĩa Oogĩ
\q1 
\v 17 Tega matũ, na ũthikĩrĩrie mĩario ya andũ arĩa oogĩ;
\q2 nyiita na ngoro yaku maũndũ marĩa ngũrutana,
\q1 
\v 18 tondũ nĩ ũndũ mwega hĩndĩ ĩrĩa ũkũmaiga ngoro-inĩ yaku,
\q2 na ũkoragwo namo mothe mĩromo-inĩ yaku.
\q1 
\v 19 Ndaakũmenyithia mo nĩgeetha mwĩhoko waku ũkoragwo harĩ Jehova,
\q2 wee nĩwe ngũruta maũndũ macio ũmũthĩ, ĩĩ wee nĩwe ngũruta.
\q2 
\v 20 Githĩ ndikwandĩkĩire thimo mĩrongo ĩtatũ,
\q2 thimo cia ũtaarani na ũmenyo,
\q1 
\v 21 ngakũruta ciugo cia ma na cia kwĩhokeka,
\q2 nĩgeetha ũkaahota kũhe
\q2 ũrĩa ũgũtũmĩte macookio mega?
\b
\q1 
\v 22 Ndũkanatunye arĩa athĩĩni indo ciao tondũ wa ũthĩĩni wao,
\q2 na ndũkanahinyĩrĩrie arĩa abatari ciira-inĩ,
\q1 
\v 23 nĩgũkorwo Jehova nĩakamaciirĩrĩra,
\q2 na nĩagatunya arĩa mamatunyaga indo ciao.
\b
\q1 
\v 24 Ndũkanagĩe ũrata na mũndũ ũrĩa ũrĩ marakara mahiũ,
\q2 ndũkanagĩe thiritũ na mũndũ ũrĩa ũhiũhaga kũrakara,
\q1 
\v 25 tondũ wahota kwĩruta mĩthiĩre yake,
\q2 na ũnyiitwo nĩ mũtego.
\b
\q1 
\v 26 Ndũgatuĩke mũndũ wa kũiga kĩndũ gĩa kũrũgamĩrĩra thiirĩ,
\q2 kana ũtuĩke wee nĩwe wa kũrũgamagĩrĩra mathiirĩ ma andũ angĩ;
\q1 
\v 27 ũngĩkaaga kĩndũ gĩa kũrĩha nakĩo-rĩ,
\q2 ũgaatunywo ũrĩrĩ waku o ũũkomeire.
\b
\q1 
\v 28 Ndũkaneherie ihiga rĩa tene rĩa mũhaka
\q2 rĩrĩa rĩahaandirwo nĩ maithe manyu ma tene.
\b
\q1 
\v 29 Nĩwonaga mũndũ mũũgĩ na wĩra wake?
\q2 Ũcio agatungata o na mbere ya athamaki;
\q2 ndagatungata mbere ya andũ matooĩkaine.
\c 23
\q1 
\v 1 Rĩrĩa waikara thĩ kũrĩĩanĩra na mwathi wa bũrũri-rĩ,
\q2 wĩmenyerere nũũ ũcio mũrĩ nake;
\q1 
\v 2 wĩigĩrĩre kahiũ mũmero
\q2 ũngĩkorwo ũrĩ mũndũ mũkoroku.
\q1 
\v 3 Ndũkerirĩrie irio ciake irĩ mũrĩo,
\q2 nĩgũkorwo nĩ irio cia gũkũheenereria.
\b
\q1 
\v 4 Tiga kwĩnogia na kwenda gwĩtongia;
\q2 gĩa na ũũgĩ wa kũhota kwĩrigĩrĩria.
\q1 
\v 5 No wone ũtonga, ũcooke ũbuĩrie,
\q2 nĩgũkorwo ti-itherũ ũtonga nĩwĩmeragia mathagu,
\q2 na ũkombũka ta nderi yerekeire matu-inĩ.
\b
\q1 
\v 6 Tiga kũrĩa irio cia mũndũ mũkarĩ,
\q2 ndũkerirĩrie irio ciake cia mũrĩo;
\q1 
\v 7 tondũ nĩ mũndũ wa arĩa meciiragia o ũhoro wa thogora hĩndĩ ciothe.
\q2 Akwĩraga atĩrĩ, “Rĩa na ũnyue,”
\q2 no ngoro yake ndĩrĩ hamwe nawe.
\q1 
\v 8 Nĩũgatahĩka kĩrĩa kĩnini ũgaakorwo ũrĩĩte,
\q2 nacio ngaatho ciaku nĩikoorĩra thĩ.
\b
\q1 
\v 9 Ndũkaarie na mũndũ mũkĩĩgu,
\q2 nĩgũkorwo we no anyararire ũũgĩ wa ciugo ciaku.
\b
\q1 
\v 10 Ndũkaneherie ihiga rĩa tene rĩa mũhaka,
\q2 kana ũhatĩke mĩhaka ya mĩgũnda ya ciana cia ngoriai,
\q1 
\v 11 tondũ Mũgitĩri wacio nĩ arĩ na hinya;
\q2 nĩakamaciirĩrĩra agũũkĩrĩre.
\b
\q1 
\v 12 Ringĩrĩria ngoro yaku gũthikĩrĩria ũrutani,
\q2 na matũ maku kũigua ciugo cia ũmenyo.
\b
\q1 
\v 13 Ndũkanaage kũherithia mwana;
\q2 ũngĩmũhũũra na rũthanju-rĩ, ndangĩkua.
\q1 
\v 14 Mũhũũrage na rũthanju
\q2 nĩguo ũhonokie muoyo wake kuuma kũrĩ gĩkuũ.
\b
\q1 
\v 15 Mũrũ wakwa, ngoro yaku ĩngĩgĩa na ũũgĩ-rĩ,
\q2 hĩndĩ ĩyo ngoro yakwa no ĩkene;
\q1 
\v 16 ngoro yakwa nĩĩgacanjamũka
\q2 rĩrĩa mĩromo yaku ĩkaaria maũndũ marĩa magĩrĩire.
\b
\q1 
\v 17 Ndũkanareke ngoro yaku ĩiguĩre ehia ũiru,
\q2 no hĩndĩ ciothe gĩĩaga na kĩyo gĩa gwĩtigĩra Jehova.
\q1 
\v 18 Tondũ ti-itherũ wee ũrĩ na kĩĩrĩgĩrĩro thuutha-inĩ,
\q2 na kĩĩrĩgĩrĩro gĩaku gĩtigaathira.
\b
\q1 
\v 19 Mũrũ wakwa, thikĩrĩria nĩgeetha ũgĩe na ũũgĩ,
\q2 na ũige ngoro yaku njĩra-inĩ ĩrĩa yagĩrĩire.
\q1 
\v 20 Ndũkegwatanie na andũ arĩa manyuuaga njoohi,
\q2 kana arĩa makorokagĩra nyama,
\q1 
\v 21 nĩgũkorwo arĩĩu na andũ arĩa akoroku matuĩkaga athĩĩni,
\q2 naguo ũgũũta ũtũmaga mũndũ ehumbe matangari.
\b
\q1 
\v 22 Thikagĩrĩria thoguo, we ũrĩa wagũciarire,
\q2 na ndũkanyarare maitũguo, o na aakorwo nĩ mũkũrũ.
\q1 
\v 23 Wĩgũrĩre ũhoro ũrĩa wa ma na ndũkanawendie;
\q2 wĩgĩĩre na ũũgĩ, na ũtaaro, na ũtaũku.
\q1 
\v 24 Ithe wa mwana mũthingu arĩ gĩkeno kĩnene mũno;
\q2 nake ũrĩa ũrĩ na mwana mũũgĩ nĩakenagio nĩwe.
\q1 
\v 25 Thoguo na maitũguo marocanjamũka nĩ ũndũ waku;
\q2 mũtumia ũrĩa wagũciarire arokena!
\b
\q1 
\v 26 Mũrũ wakwa, heaga ngoro yaku,
\q1 na ũreke maitho maku marũmagĩrĩre njĩra ciakwa,
\q1 
\v 27 nĩgũkorwo mũmaraya nĩ irima iriku,
\q2 nake mũtumia mũtharia nĩ gĩthima gĩkunderu.
\q1 
\v 28 Oohagĩria andũ njĩra-inĩ o ta njangiri,
\q2 na nĩatũmaga kuongerereke andũ matarĩ ehokeku kĩrĩndĩ-inĩ.
\b
\q1 
\v 29 Nũũ ũrĩ na haaro? Nũũ ũrĩ na kĩeha?
\q2 Nũũ ũrĩ hatĩka-inĩ? Nũũ ũrĩ na mateta?
\q2 Nũũ ũgurarĩtio hatarĩ gĩtũmi? Nũũ ũtunĩhĩtie maitho?
\q1 
\v 30 Nĩ arĩa matindaga marũmanĩrĩire na ndibei,
\q2 arĩa mathiiaga magĩcamaga mbakũri cia ndibei ĩrĩa ndukanie.
\q1 
\v 31 Tiga kwĩrorera ndibei rĩrĩa ĩtunĩhĩte,
\q2 rĩrĩa ĩgũkenga ĩrĩ gĩkombe-inĩ,
\q2 rĩrĩa ĩkũmerũka wega!
\q1 
\v 32 Mũthia-inĩ ĩrũmanaga ta nyoka,
\q2 ĩgagũtheeca na thumu ta nduĩra.
\q1 
\v 33 Maitho maku makoonaga maũndũ mageni,
\q2 na meciiria maku meciirie maũndũ ma waganu.
\q1 
\v 34 Ũgaatuĩka ta mũndũ ũkomete iria-inĩ rĩrĩa inene gatagatĩ,
\q2 o ta mũndũ ũkomete mũthia wa gĩtugĩ kĩa macua.
\q1 
\v 35 Nĩũkoiga atĩrĩ, “Ngũthĩtwo, no ndinatiihio!
\q2 Nĩmahũũra, no ndinaigua ũndũ!
\q1 Ngokĩra-rĩ,
\q2 nĩguo ngacarie ĩngĩ ya kũnyua?”
\c 24
\q1 
\v 1 Tiga kũiguĩra andũ arĩa aaganu ũiru,
\q2 na ndũkanerirĩrie thiritũ yao,
\q1 
\v 2 nĩgũkorwo ngoro ciao ithugundaga o haaro,
\q2 na mĩromo yao yaragia ũhoro wa kũrehere andũ thĩĩna.
\b
\q1 
\v 3 Nyũmba yakagwo na ũũgĩ,
\q2 naguo ũtaũku nĩguo ũtũmaga ĩĩhaande;
\q1 
\v 4 ũmenyo nĩguo ũiyũragia tũnyũmba twayo,
\q2 ũgatũiyũria na indo cia bata, na ũtonga mwega.
\b
\q1 
\v 5 Mũndũ mũũgĩ arĩ ũhoti mũnene,
\q2 na mũndũ ũrĩ ũmenyo nĩakĩragĩrĩria kũgĩa na hinya;
\q1 
\v 6 ũgĩthiĩ mbaara-inĩ nĩũbatarĩtio nĩgũtaarwo,
\q2 na nĩgeetha ũhootane nĩũbatarĩtio nĩ aheani kĩrĩra aingĩ.
\b
\q1 
\v 7 Ũũgĩ ũrĩ igũrũ mũno, ndũngĩkinyĩrĩka nĩ mũndũ mũkĩĩgu;
\q2 rĩrĩa kwagomanwo kĩhingo-inĩ, ndangĩona wa kuuga.
\b
\q1 
\v 8 Mũndũ ũrĩa ũthugundaga ũũru-rĩ,
\q2 andũ mamwĩtaga mungumania.
\q1 
\v 9 Mathugunda ma ũrimũ nĩ mehia,
\q2 na mũnyũrũrania nĩ kĩndũ kĩrĩ magigi harĩ andũ.
\b
\q1 
\v 10 Ũngĩtuĩka wa kũũrwo nĩ hinya hĩndĩ ya thĩĩna,
\q2 hinya waku kaĩ nĩ mũnini-ĩ!
\b
\q1 
\v 11 Honokia arĩa maratwarĩrĩrio gĩkuũ-inĩ;
\q2 girĩrĩria arĩa maratũgũũga merekeire gĩthĩnjĩro.
\q1 
\v 12 Ũngiuga atĩrĩ, “Ũhoro ũcio tũtiraũmenyete,”
\q2 githĩ ũrĩa ũthimaga ngoro tiwe ũmenyaga?
\q1 Ũrĩa ũrangagĩra muoyo waku-rĩ, githĩ ndooĩ kana nĩguo?
\q2 Githĩ ndakaarĩha o mũndũ kũringana na ũrĩa ekĩte?
\b
\q1 
\v 13 Mũrũ wakwa, rĩa ũũkĩ, nĩgũkorwo nĩ mwega;
\q2 ũũkĩ uumĩte magua-inĩ ũrĩ mũrĩo ũkĩũcama.
\q1 
\v 14 Ningĩ menya atĩ ũũgĩ ũrĩ mũrĩo harĩ ngoro yaku;
\q2 ũngĩgĩa naguo, nĩũkagĩa na kĩĩrĩgĩrĩro,
\q2 na kĩĩrĩgĩrĩro gĩaku gĩtigaathira.
\b
\q1 
\v 15 Ndũkanoohie mũndũ mũthingu njĩra-inĩ ũtharĩkĩre nyũmba yake ta mũitũ,
\q2 ndũkanahithũkĩre gĩikaro gĩake;
\q1 
\v 16 nĩgũkorwo mũndũ mũthingu o na angĩgũa maita mũgwanja, agũũaga o agĩũkagĩra,
\q1 no andũ arĩa aaganu marũndagwo nĩ mũtino.
\b
\q1 
\v 17 Hĩndĩ ĩrĩa thũ yaku yagũa-rĩ, ndũkanamĩkenerere;
\q2 hĩndĩ ĩrĩa yahĩngwo-rĩ, ndũkareke ngoro yaku ĩkene,
\q1 
\v 18 nĩguo Jehova ndakone ũndũ ũcio arakare,
\q2 akĩhũndũre marakara make kuuma kũrĩ thũ ĩyo.
\b
\q1 
\v 19 Ndũkanathĩĩnĩke ngoro nĩ ũndũ wa andũ arĩa ooru,
\q2 kana wĩrirĩrie kũhaanana na arĩa aaganu,
\q1 
\v 20 nĩgũkorwo mũndũ ũrĩa mũũru ndarĩ na mwĩhoko wa thuutha-inĩ,
\q2 na tawa wa ũrĩa mwaganu nĩũkahorio.
\b
\q1 
\v 21 Mũrũ wakwa, wĩtigĩre Jehova na wĩtigĩre mũthamaki,
\q2 na ndũkagĩe na ngwatanĩro na andũ arĩa aremi,
\q1 
\v 22 nĩgũkorwo acio eerĩ no mamũrehithĩrie mwanangĩko wa narua,
\q2 na nũũ ũngĩmenya nĩ mĩtino ĩrĩkũ mangĩrehe?
\s1 Mĩario ĩngĩ ya arĩa Oogĩ
\p 
\v 23 O na ici no thimo cia andũ arĩa oogĩ:
\q1 Kwenda mwena ũmwe gũkĩra ũrĩa ũngĩ ciira-inĩ ti ũndũ mwega:
\q1 
\v 24 Ũrĩa wothe wĩraga mũndũ ũrĩa ũrĩ na mahĩtia atĩrĩ, “Wee ndũrĩ na mahĩtia,”
\q2 kĩrĩndĩ nĩgĩkamũruma, na athũũrwo nĩ ndũrĩrĩ.
\b
\q1 
\v 25 No arĩa matuagĩra andũ arĩa aaganu ciira,
\q2 nĩmakona wega, na magĩe na kĩrathimo kĩega.
\b
\q1 
\v 26 Icookio rĩa wĩhokeku
\q2 nĩ ta kĩmumunyano kĩa mĩromo.
\b
\q1 
\v 27 Rĩĩkia wĩra wa gũtua mwako na nja,
\q2 na ũhaarĩrie mĩgũnda yaku;
\q2 thuutha ũcio cooka wĩakĩre nyũmba.
\b
\q1 
\v 28 Ndũkanarute ũira ũigĩrĩre mũndũ wa itũũra rĩaku kĩgeenyo,
\q2 kana ũheenanie na mĩromo yaku.
\q1 
\v 29 Ndũkanoige atĩrĩ, “Ngũmwĩka o ta ũrĩa anjĩkĩte;
\q2 ngwĩrĩhĩria harĩ mũndũ ũcio kũringana na ũrĩa eekire.”
\b
\q1 
\v 30 Ndaahĩtũkĩire mũgũnda-inĩ wa kĩgũũta,
\q2 ngĩhĩtũkĩra mũgũnda-inĩ wa mĩthabibũ wa mũndũ ũtooĩ gũkũũrana maũndũ;
\q1 
\v 31 na rĩrĩ, mĩigua yamerete kũndũ guothe,
\q2 na mũgũnda ũkaiyũra riya,
\q2 naruo rũthingo rwa mahiga rũkamomoka.
\q1 
\v 32 Nĩndacũũranirie na ngoro yakwa maũndũ macio ndonire,
\q2 na ngĩĩruta ũndũ kuumana na ũrĩa ndonire:
\q1 
\v 33 Mũtugo wa gũkoma hanini,
\q2 gũcooka toro hanini, gũkũnja moko hanini ũhurũke;
\q1 
\v 34 naguo ũthĩĩni ũgaagũkorerera ta mũitũ,
\q2 na wagi ũgũkorerere ta mũndũ wĩohete indo cia mbaara.
\c 25
\s1 Thimo Ingĩ cia Solomoni
\p 
\v 1 Ici nĩ thimo ingĩ cia Solomoni, iria ciacookanĩrĩirio na ikĩandĩkwo nĩ andũ a Hezekia ũrĩa warĩ mũthamaki wa Juda:
\q1 
\v 2 Kũhithĩrĩra ũndũ nĩ ũgooci wa Ngai;
\q2 nakuo gũtuĩria ũndũ nĩkuo kũgoocithagia athamaki.
\b
\q1 
\v 3 O ta ũrĩa igũrũ kũraihĩte na igũrũ, nakuo thĩ gũkarika mũno-rĩ,
\q2 ũguo noguo ngoro cia athamaki itangĩtuĩrĩka.
\b
\q1 
\v 4 Theria betha ĩthire gĩko,
\q2 na nĩhegũtigara kĩndũ kĩa mũturi wa betha;
\q1 
\v 5 eheria andũ arĩa aaganu harĩ mũthamaki,
\q2 na gĩtĩ gĩake kĩa ũnene nĩgĩkũrũmio nĩ ũthingu.
\b
\q1 
\v 6 Ndũgetũũgĩrie harĩ mũthamaki,
\q2 na ndũkerũgamie gatagatĩ ka anene;
\q1 
\v 7 kaba mũthamaki we mwene akwĩre, “Ambata, ũũke haha,”
\q2 gũkĩra agũconorithie mbere ya mũndũ ũrĩ igweta.
\b
\q1 Ũndũ ũrĩa wonete na maitho-rĩ,
\q2 
\v 8 ndũkahiũhe kũũtwara igooti-inĩ,
\q1 tondũ-rĩ, ũgeeka atĩa marigĩrĩrio-inĩ,
\q2 mũndũ wa itũũra rĩaku angĩkaaruta ũira agũconorithie?
\b
\q1 
\v 9 Ciirai na mũndũ wa itũũra rĩaku we mwene,
\q2 nĩguo ndũkoimie ndundu ya mũndũ ũcio ũngĩ nja,
\q1 
\v 10 kana ũiguuo nĩ mũndũ ũngĩ agũconore,
\q2 ũtũũre na ngumo njũru ĩtagagũthira.
\b
\q1 
\v 11 Kiugo kĩarĩtio hĩndĩ ĩrĩa yagĩrĩire
\q2 nĩ ta matunda ma thahabu marĩ thaani-inĩ ya betha.
\b
\q1 
\v 12 Gĩcũhĩ gĩa gũtũ gĩa thahabu, kana ithaga rĩa thahabu ĩrĩa therie,
\q2 nĩ taguo irũithia rĩa mũndũ mũũgĩ rĩtariĩ gũtũ-inĩ kwa mũndũ ũrĩa ũiguaga.
\b
\q1 
\v 13 Ta ũhehu wa tharunji hĩndĩ ya magetha,
\q2 no taguo mũtwari ndũmĩrĩri mwĩhokeku ahaana kũrĩ arĩa mamũtũmaga;
\q2 nĩatũmaga ngoro cia anene ake ikene.
\b
\q1 
\v 14 O ta ũrĩa matu na rũhuho matarĩ mbura ihaana,
\q2 no taguo mũndũ ahaana ũrĩa ũrahaga ũrĩa ekũheana iheo na ndaheane.
\b
\q1 
\v 15 Ũkirĩrĩria no ũguucĩrĩrie ũrĩa waathanaga etĩkĩre ũndũ,
\q2 naruo rũrĩmĩ ruororo no ruune ihĩndĩ.
\b
\q1 
\v 16 Ũngĩona ũũkĩ-rĩ, rĩa o wa gũkũigana,
\q2 ũngĩrĩa mũingĩ mũno nĩũgũtahĩka.
\q1 
\v 17 Nyiihia gũthiiaga kwa mũndũ wa itũũra,
\q2 ũngĩthiĩ kaingĩ no anogio nĩwe agũthũũre.
\b
\q1 
\v 18 Mũndũ ũrĩa ũheanaga ũira wa maheeni agookĩrĩra mũndũ wa itũũra,
\q2 ahaana ta njũgũma, kana rũhiũ rwa njora, kana mũguĩ mũũgĩ.
\b
\q1 
\v 19 Kwĩhoka mũndũ ũtarĩ mwĩhokeku hĩndĩ ya thĩĩna,
\q2 no ta kwĩhoka igego ituĩku, kana kũgũrũ kũrathua.
\b
\q1 
\v 20 Ũrĩa ũinagĩra mũndũ ũrĩ na ngoro nditũ nyĩmbo,
\q2 no ta mũndũ kwĩruta nguo mũthenya wa heho,
\q2 kana gũitĩrĩria thiki igata-inĩ.
\b
\q1 
\v 21 Thũ yaku ĩngĩkorwo ĩhũtiĩ-rĩ, mĩhe irio ĩrĩe;
\q2 ĩngĩkorwo ĩnyootiĩ-rĩ, mĩhe maaĩ ĩnyue.
\q1 
\v 22 Weka ũguo-rĩ, nĩũkũmĩigĩrĩra makara ma mwaki mũtwe,
\q2 nake Jehova nĩagakũrĩha.
\b
\q1 
\v 23 O ta ũrĩa rũhuho rwa gathigathini rũrehaga mbura,
\q2 noguo rũrĩmĩ rwa njuukũ rũrehaga ũhoro wa marakara.
\b
\q1 
\v 24 Nĩ kaba gũtũũra nyũmba-igũrũ koine-inĩ,
\q2 gũkĩra gũtũũrania nyũmba thĩinĩ na mũtumia wa haaro.
\b
\q1 
\v 25 O ta ũrĩa maaĩ mahehu manyootoraga mũndũ mũnyootu,
\q2 no taguo ũhoro mwega uumĩte bũrũri wa kũraya wĩkaga.
\b
\q1 
\v 26 O ta gĩthima kĩiyũrĩte ndaka, kana itherũkĩro rĩa maaĩ riunjuge,
\q2 ũguo nĩguo mũndũ mũthingu ahaanaga angĩĩrekereria harĩ andũ arĩa aaganu.
\b
\q1 
\v 27 Ti wega kũrĩa ũũkĩ mũingĩ mũno,
\q2 o na ti ũndũ wa gũtĩĩka mũndũ gwĩcarĩria gĩtĩĩo we mwene.
\b
\q1 
\v 28 Mũndũ ũtangĩhota gwatha ngoro yake
\q2 atariĩ ta itũũra inene rĩmomoku, na rĩtarĩ na thingo.
\c 26
\q1 
\v 1 O ta ũrĩa tharunji ĩtaagĩrĩire kũgĩa hĩndĩ ya riũa, kana mbura kuura hĩndĩ ya magetha-rĩ,
\q2 noguo gĩtĩĩo gĩtagĩrĩire mũndũ mũkĩĩgu.
\b
\q1 
\v 2 Ta kanyoni-ka-nja gekũbatabata, kana thũngũrũrũ ĩkũhiũka-hiũka,
\q2 noguo kĩrumi gĩtarĩ gĩtũmi gĩtarĩ ha kwĩgwatĩrĩra.
\b
\q1 
\v 3 Kĩboko nĩ kĩa mbarathi, matamu nĩ ma ndigiri,
\q2 na rũthanju nĩ rwa ciande cia andũ arĩa akĩĩgu!
\b
\q1 
\v 4 Ndũkanacookerie mũndũ mũkĩĩgu kũringana na ũrimũ wake,
\q2 ndũkae gũtuĩka take.
\b
\q1 
\v 5 Cookeria mũndũ mũkĩĩgu kũringana na ũrimũ wake,
\q2 nĩguo ndakeyone taarĩ mũndũ mũũgĩ maitho-inĩ make.
\b
\q1 
\v 6 Gũtũma ndũmĩrĩri na guoko kwa mũndũ mũkĩĩgu-rĩ,
\q2 nĩ ta gwĩtinia magũrũ, kana kũnyua haaro.
\b
\q1 
\v 7 O ta magũrũ ma gĩthua ũrĩa mathiiaga maniginĩte,
\q2 noguo thimo ĩhaana ĩkĩario nĩ kanua ka mũndũ mũkĩĩgu.
\b
\q1 
\v 8 Kũhe mũndũ mũkĩĩgu gĩtĩĩo
\q2 no ta kuoherera ihiga kĩgũtha-inĩ.
\b
\q1 
\v 9 Thimo ĩkĩario nĩ kanua ka mũndũ mũkĩĩgu
\q2 nĩ ta mũigua ũrĩ guoko-inĩ kwa mũrĩĩu.
\b
\q1 
\v 10 Mũndũ wandĩkaga mũndũ mũkĩĩgu kana mwĩhĩtũkĩri
\q2 nĩ ta ũrĩa ũikagia mĩguĩ o ro ũguo agatiihia andũ.
\b
\q1 
\v 11 Mũndũ mũkĩĩgu acookagĩra ũrimũ wake
\q2 o ta ũrĩa ngui ĩcookagĩrĩra matahĩko mayo.
\b
\q1 
\v 12 Wanona mũndũ wĩonaga arĩ mũũgĩ maitho-inĩ make?
\q2 Mũndũ mũkĩĩgu arĩ na kĩĩrĩgĩrĩro gũkĩra mũndũ ũcio.
\b
\q1 
\v 13 Kĩgũũta kiugaga atĩrĩ, “Njĩra-inĩ kũrĩ na mũrũũthi,
\q2 mũrũũthi mũrĩĩani ũrorũũra njĩra-inĩ cia itũũra!”
\b
\q1 
\v 14 Ta ũrĩa mũrango ũtindaga ũkĩgarũrũka ihocio-inĩ ciaguo,
\q2 noguo kĩgũũta gĩtindaga gĩkĩĩgarũra gĩkomete ũrĩrĩ-inĩ wakĩo.
\b
\q1 
\v 15 Kĩgũũta gĩikagia guoko gwakĩo o thaani-inĩ;
\q2 kĩnogagio nĩgũcooka gũkuoya gĩgũkinyie kanua-inĩ.
\b
\q1 
\v 16 Kĩgũũta kĩĩonaga kĩrĩ kĩũgĩ maitho-inĩ makĩo,
\q2 gũkĩra andũ mũgwanja arĩa macookagia ũhoro na ũũgĩ.
\b
\q1 
\v 17 Mwĩhĩtũkĩri wĩtoonyagia inegene-inĩ rĩtamũkoniĩ
\q2 no ta mũndũ ũkũnyiita ngui matũ.
\b
\q1 
\v 18 Ta mũgũrũki ũgũikia
\q2 icinga cia mwaki, kana agaikia mĩguĩ ya gĩkuũ,
\q1 
\v 19 no taguo mũndũ ahaana ũrĩa ũheenagia mũndũ wa itũũra rĩake,
\q2 agacooka kũmwĩra atĩrĩ, “Nĩ itherũ nyuma narĩo!”
\b
\q1 
\v 20 Mwaki ũngĩaga ngũ no kũhora ũhoraga;
\q2 ngarari cingĩaga mũhuhu no gũthira ithiraga.
\b
\q1 
\v 21 O ta ũrĩa makara magwatagia marĩa mangĩ mwaki,
\q2 na o ta ũrĩa ngũ ciakanagia mwaki,
\q2 noguo mũndũ mũũgiti aakagĩrĩria haaro.
\b
\q1 
\v 22 Ndeto cia mũndũ wa mũhuhu nĩ ta twenyũ twega twa irio;
\q2 tũmerũkaga tũgathiĩ mwĩrĩ wa mũndũ o thĩinĩ biũ.
\b
\q1 
\v 23 Ta ũrĩa indo cia rĩũmba inyorokagio ikahenia na igũrũ,
\q2 no taguo mĩromo mĩnyoroku ĩhumbagĩra ngoro ĩrĩ na ũũru.
\b
\q1 
\v 24 Mũndũ wa rũmena aaragia ũhinga na mĩromo yake,
\q2 no thĩinĩ wa ngoro yake aiyũrĩtwo no maheeni.
\q1 
\v 25 O na gũtuĩka mĩario yake nĩ ya gũkenania, ndũkanamwĩtĩkie,
\q2 nĩgũkorwo ngoro yake ĩiyũrĩte maũndũ mũgwanja marĩ magigi.
\q1 
\v 26 Rũmena rwake no rũhithwo na maheeni,
\q2 no waganu wake ũkaaguũrio kĩũngano-inĩ.
\b
\q1 
\v 27 Mũndũ angĩenja irima, nĩwe ũkaagũa rĩo;
\q2 mũndũ angĩgaragaria ihiga, rĩkaagaragara rĩmũcookerere.
\b
\q1 
\v 28 Rũrĩmĩ rwa maheeni nĩkũmena rũmenete arĩa rũtuuragia,
\q2 nako kanua ga kwĩyendithĩrĩria karehaga mwanangĩko.
\b
\c 27
\q1 
\v 1 Tiga kwĩraha nĩ ũndũ wa rũciũ,
\q2 nĩgũkorwo ndũũĩ kĩrĩa mũthenya ũngĩrehe.
\b
\q1 
\v 2 Reke mũndũ ũngĩ akũgaathĩrĩrie, no ti kanua gaku mwene;
\q2 mũndũ ũngĩ nĩakũgaathĩrĩrie, no ti mĩromo yaku mwene.
\b
\q1 
\v 3 Ihiga nĩ iritũ na mũthanga nĩ mũrigo,
\q2 no kũrakario nĩ mũndũ mũkĩĩgu nĩ kũritũ gũkĩra icio cierĩ.
\b
\q1 
\v 4 Marakara matirĩ tha, namo marũrũ moinaga ta mũiyũro;
\q2 no ũiru-rĩ, nũũ ũngĩhota kũwĩtiiria?
\b
\q1 
\v 5 Kaba kũrũithio nĩ mũndũ ũtekũhithĩrĩra ũndũ
\q2 gũkĩra wendo mũhithe.
\b
\q1 
\v 6 Nguraro cia gũtihio nĩ mũrata no ciĩhokwo,
\q2 no imumunyano nyingĩ cia mũgũthũũri ti cia kwĩhokwo.
\b
\q1 
\v 7 Mũndũ mũhũũnu athũũraga o na ũũkĩ,
\q2 no mũndũ mũhũũtu, o na kĩndũ kĩrũrũ aiguaga kĩrĩ mũrĩo.
\b
\q1 
\v 8 Mũndũ ũũrĩte gwake mũciĩ
\q2 ahaana ta nyoni ĩtiganĩirie gĩtara kĩayo.
\b
\q1 
\v 9 Maguta manungi wega na ũbumba irehagĩra ngoro ya mũndũ gĩkeno,
\q2 na noguo wega wa mũrata wa mũndũ wĩkaga akĩmũhe ũtaaro wake wa ma.
\b
\q1 
\v 10 Ndũkanateanĩrie mũrata waku kana mũrata wa thoguo,
\q2 na ndũgathiĩ kwa mũrũ wa maitũguo rĩrĩa mũtino wagũkora:
\q2 nĩ kaba mũndũ wa itũũra ũcio ũrĩ hakuhĩ, gũkĩra mũrũ wa nyina na mũndũ ũrĩ kũraya.
\b
\q1 
\v 11 Mũrũ wakwa, tuĩka mũndũ mũũgĩ, ũgĩkenagie ngoro yakwa;
\q2 na niĩ hotage gũcookagĩria mũndũ o wothe ũngĩĩnyarara.
\b
\q1 
\v 12 Mũndũ mũũgĩ oonaga ũgwati ũgĩũka akehitha,
\q2 no arĩa matarĩ ũũgĩ mathiiaga o na mbere, nao magatoonya thĩĩna-inĩ.
\b
\q1 
\v 13 Oya nguo ya mũndũ ũrĩa ũrũgamagĩrĩra thiirĩ wa mũndũ wa kũngĩ;
\q2 mĩige ĩrũgamĩrĩre thiirĩ ũcio wa mũndũ-wa-nja wa kũngĩ.
\b
\q1 
\v 14 Mũndũ angĩrathima mũndũ wa itũũra rĩake rũciinĩ tene anĩrĩire-rĩ,
\q2 ũndũ ũcio ũngĩtuĩka taarĩ kĩrumi.
\b
\q1 
\v 15 Mũtumia wa haaro ahaanaine
\q2 na maaĩ maratata mategũtigithĩria hĩndĩ ya mbura;
\q1 
\v 16 kũgeria kũmũgirĩrĩria nĩ ta kũgeria kũgirĩrĩria rũhuho,
\q2 kana kũgeria gũkumbatĩria maguta na guoko.
\b
\q1 
\v 17 O ta ũrĩa kĩgera kĩnooraga kĩrĩa kĩngĩ,
\q2 no taguo mũndũ ohĩgagia ũrĩa ũngĩ.
\b
\q1 
\v 18 Mũndũ ũrĩa ũrĩmagĩra mũkũyũ nĩakaarĩa maciaro maguo,
\q2 na mũndũ ũrĩa ũtungataga mwathi wake nĩagatĩĩo.
\b
\q1 
\v 19 O ta ũrĩa mũndũ onaga ũthiũ wake maaĩ-inĩ,
\q2 no taguo ngoro ya mũndũ yonanagia ũrĩa mũndũ atariĩ.
\b
\q1 
\v 20 Gĩkuũ na Mwanangĩko itiiganagia,
\q2 na o namo maitho ma mũndũ matiiganagia.
\b
\q1 
\v 21 Nyũngũ nĩ ya gũthererio betha, na kĩrugutĩro nĩ gĩa gũthererio thahabu,
\q2 no mũndũ athimagwo na igweta rĩrĩa agwetagwo narĩo.
\b
\q1 
\v 22 O na ũngĩhũũrĩra mũndũ mũkĩĩgu ndĩrĩ-inĩ,
\q2 ũmũhũũre na mũũthĩ ta ngano-rĩ,
\q2 ndangiumwo nĩ ũrimũ wake.
\b
\q1 
\v 23 Thũũrimaga mahiũ maku na kĩyo,
\q2 ũmenyagĩrĩre wega ndũũru ciaku;
\q1 
\v 24 nĩgũkorwo ũtonga ndũtũũraga nginya tene,
\q2 o nayo thũmbĩ ti ya gũkinyĩra njiarwa na njiarwa.
\q1 
\v 25 Nyeki ĩrĩa nyũmũ rĩrĩa yatũgũtwo na nyeki njerũ ĩkunũke-rĩ,
\q2 nayo ĩrĩa ya irĩma-inĩ yũnganio na ĩinũkio-rĩ,
\q1 
\v 26 hĩndĩ ĩyo tũgondu nĩtũgaatũma ũgĩe na nguo,
\q2 nacio mbũri itũme ũgĩe na gĩa kũgũra mũgũnda.
\q1 
\v 27 Nĩũkagĩa na iria rĩingĩ rĩa mbũri
\q2 rĩa gũkũigana na rĩa kũnyuuo nĩ andũ a nyũmba yaku,
\q2 o na rĩa gũtũũria airĩtu aku a wĩra.
\b
\c 28
\q1 
\v 1 Andũ arĩa aaganu moraga o na gũtarĩ mũndũ ũramathingata,
\q1 no arĩa athingu momagĩrĩria ta mũrũũthi.
\b
\q1 
\v 2 Bũrũri ũngĩĩhia, nĩũgĩaga na aathani aingĩ,
\q2 no mũndũ ũrĩ na ũtaũku na akagĩa na ũmenyo nĩatũmaga bũrũri ũkindĩrie.
\b
\q1 
\v 3 Mwathani ũrĩa ũhatagĩrĩria andũ arĩa athĩĩni
\q2 ahaana ta mbura ya rũhuho ĩrĩa ĩtatigagia irio.
\b
\q1 
\v 4 Andũ arĩa matirikaga watho magaathagĩrĩria andũ arĩa aaganu,
\q2 no arĩa marũmagia watho magianaga nao.
\b
\q1 
\v 5 Andũ arĩa ooru matiiguaga maũndũ ma kĩhooto,
\q2 no arĩa marongoragia Jehova nĩmataũkagĩrwo nĩ mo biũ.
\b
\q1 
\v 6 Nĩ kaba mũndũ mũthĩĩni ũrĩa ũthiiaga na mĩthiĩre ĩtarĩ ũcuuke,
\q2 gũkĩra gĩtonga gĩthiiaga na mĩthiĩre mĩogomu.
\b
\q1 
\v 7 Mũndũ ũrĩa ũrũmagia watho nĩ mwana ũrĩ na gũkũũrana,
\q2 no mwana ũrĩa ũthiiaga na thiritũ ya arĩa akoroku aconorithagia ithe.
\b
\q1 
\v 8 Mũndũ ũrĩa ũingĩhagia ũtonga wake na ũndũ wa gũkombithia mbeeca na gwĩtia uumithio mũkĩru
\q2 aũigagĩra mũndũ ũngĩ, ũrĩa ũkaiguĩra athĩĩni tha.
\b
\q1 
\v 9 Mũndũ ũrĩa ũregaga kũigua watho,
\q2 o na mahooya make nĩ kĩndũ kĩrĩ magigi.
\b
\q1 
\v 10 Mũndũ ũrĩa ũngĩhĩtithia andũ arĩa arũngĩrĩru nĩguo magere njĩra ya ũũru,
\q2 akaagũa mũtego-inĩ wake we mwene,
\q2 no ũrĩa ũtarĩ ũcuuke, wega nĩguo ũgaatuĩka igai rĩake.
\b
\q1 
\v 11 Mũndũ mũtongu no eyone taarĩ mũũgĩ maitho-inĩ make,
\q2 no mũndũ mũthĩĩni ũrĩa ũũĩ gũkũũrana maũndũ amuonaga o ũrĩa atariĩ.
\b
\q1 
\v 12 Hĩndĩ ĩrĩa arĩa athingu maatoorania, nĩkũgĩaga na ndũhiũ nene;
\q2 no rĩrĩa arĩa aaganu maatũũgĩra, andũ nĩ kwĩhitha mehithaga.
\b
\q1 
\v 13 Mũndũ ũrĩa ũhithaga mehia make ndagaacagĩra,
\q2 no ũrĩa ũmoimbũraga na agatigana namo nĩaiguagĩrwo tha.
\b
\q1 
\v 14 Kũrathimwo nĩ mũndũ ũrĩa wĩtigagĩra Jehova hĩndĩ ciothe,
\q2 no ũrĩa ũmagia ngoro yake nĩkũgũa agũũaga thĩĩna-inĩ.
\b
\q1 
\v 15 Mũndũ mwaganu agĩatha andũ matarĩ na ũhoti,
\q2 nĩ ta mũrũũthi ũkũrarama, kana nduba ĩgũticũka.
\b
\q1 
\v 16 Mũnene ũtarĩ na ũtaũku nĩahinyagĩrĩria andũ mũno,
\q2 no mũndũ ũrĩa ũthũire uumithio ũtagĩrĩire
\q2 nĩagakenera matukũ maingĩ ma muoyo wake.
\b
\q1 
\v 17 Mũndũ mũritũhĩre nĩ thakame ya mũndũ ooragĩte,
\q2 egũtũũra ehithaga nginya gũkua gwake;
\q2 mũndũ o na ũrĩkũ ndakanamũteithĩrĩrie.
\b
\q1 
\v 18 Mũndũ ũrĩa mĩthiĩre yake ĩtarĩ ũcuuke aikaraga arĩ mũgitĩre,
\q2 no mũndũ ũrĩa ũthiiaga na njĩra cia waganu akaagũa o rĩmwe, hubu!
\b
\q1 
\v 19 Mũndũ ũrĩa ũrĩmaga mũgũnda wake arĩĩkoragwo na irio nyingĩ,
\q2 no ũrĩa ũhanyũkanagia na maũndũ hatarĩ arĩhũũnaga o thĩĩna.
\b
\q1 
\v 20 Mũndũ mwĩhokeku arĩrathimagwo mũno,
\q2 no ũrĩa wĩriragĩria kũhiũha gũtonga ndakaaga kũherithio.
\b
\q1 
\v 21 Gũtĩĩra mũndũ maũthĩ ti wega:
\q2 no mũndũ no eke ũũru nĩ ũndũ wa kenyũ ka irio.
\b
\q1 
\v 22 Mũndũ mũkarĩ nĩeriragĩria mũno gũtonga,
\q2 na ndooĩ atĩ etereirwo nĩ ũthĩĩni.
\b
\q1 
\v 23 Mũndũ ũrĩa ũrũithagia ũngĩ nĩagatuĩka wa kwendwo nĩwe thuutha-inĩ,
\q2 gũkĩra mũndũ wa rũrĩmĩ rwa kwĩyendithĩrĩria.
\b
\q1 
\v 24 Mũndũ ũrĩa ũtunyaga ithe kana nyina kĩndũ kĩao,
\q2 agacooka akoiga atĩrĩ, “Ti ũũru ndeka,”
\q2 ũcio marĩ rũmwe na ũrĩa wanangaga.
\b
\q1 
\v 25 Mũndũ mũkoroku aarahũraga ngarari,
\q2 no mũndũ wĩhokete Jehova nĩakagaacĩra.
\b
\q1 
\v 26 Mũndũ ũrĩa wĩĩhokaga we mwene nĩ mũndũ mũkĩĩgu,
\q2 no ũrĩa ũthiiaga na njĩra cia ũũgĩ aikaraga arĩ mũgitĩre.
\b
\q1 
\v 27 Mũndũ ũrĩa ũheaga athĩĩni ndarĩ kĩndũ akaaga,
\q2 no mũndũ ũrĩa ũmahingagĩra maitho nĩarĩĩrumagwo kaingĩ.
\b
\q1 
\v 28 Rĩrĩa andũ arĩa aaganu maatuĩka a gwathana, andũ nĩ kwĩhitha mehithaga;
\q2 no rĩrĩa arĩa aaganu mathira, arĩa athingu nĩmatheeremaga.
\b
\c 29
\q1 
\v 1 Mũndũ ũrĩa ũikaraga omĩtie ngingo thuutha wa kũrũithio maita maingĩ,
\q2 akaanangwo o rĩmwe, na aage kĩhonia.
\b
\q1 
\v 2 Rĩrĩa andũ arĩa athingu matheerema, andũ nĩmakenaga;
\q2 no rĩrĩa andũ arĩa aaganu maathana, andũ nĩgũcaaya macaayaga.
\b
\q1 
\v 3 Mũndũ ũrĩa wendete ũũgĩ atũũragia ithe na gĩkeno,
\q2 no mũndũ ũrĩa ũceeraga na maraya nĩgũitanga aitangaga ũtonga wake.
\b
\q1 
\v 4 Mũthamaki ũrĩ matuĩro ma kĩhooto aikaragia bũrũri ũrĩ mwĩkindĩru,
\q2 no ũrĩa ũkorokagĩra mahaki nĩ kwananga awanangaga.
\b
\q1 
\v 5 Mũndũ ũrĩa wĩyendithagĩrĩria harĩ mũndũ wa itũũra rĩake na maheeni,
\q2 nĩ wabu aambagĩra magũrũ make.
\b
\q1 
\v 6 Mũndũ mwaganu ategagwo nĩ mehia make we mwene,
\q2 no mũndũ mũthingu ainaga na agakena.
\b
\q1 
\v 7 Andũ arĩa athingu nĩmamenyagĩrĩra kĩhooto kĩa arĩa athĩĩni,
\q2 no arĩa aaganu matirũmbũyagia kĩhooto kĩao.
\b
\q1 
\v 8 Anyũrũrania matũmaga itũũra inene rĩrĩmbũke ta mwaki,
\q2 no andũ oogĩ nĩkũniina maniinaga marakara.
\b
\q1 
\v 9 Mũndũ mũũgĩ angĩthiĩ igooti-inĩ na mũndũ mũkĩĩgu,
\q2 mũndũ mũkĩĩgu arĩrĩmbũkaga nĩ marakara na akanyũrũrania, naguo thayũ ũkaaga.
\b
\q1 
\v 10 Andũ arĩa maitaga thakame nĩmathũire mũndũ mwĩhokeku,
\q2 no andũ arĩa arũngĩrĩru macaragia ũrĩa mangĩtiirĩrĩra muoyo wake.
\b
\q1 
\v 11 Mũndũ mũkĩĩgu aitũrũraga marakara make mothe,
\q2 no mũndũ mũũgĩ aikaraga amarigĩrĩirie, akahoorera.
\b
\q1 
\v 12 Mũndũ ũrĩa wathanaga angĩthikĩrĩria maheeni-rĩ,
\q2 anene ake othe matuĩkaga andũ aaganu.
\b
\q1 
\v 13 Mũndũ mũthĩĩni na mũndũ mũhinyanĩrĩria harĩ ũndũ ũmwe ũmahaananĩtie:
\q2 Jehova nĩwe ũtũmaga maitho mao eerĩ moone.
\b
\q1 
\v 14 Mũthamaki angĩtuĩra athĩĩni ciira na kĩhooto-rĩ,
\q2 gĩtĩ gĩake kĩa ũnene gĩtũũraga kĩrũmĩte nginya tene.
\b
\q1 
\v 15 Rũthanju na kũrũithio ciĩkagĩra mũndũ ũũgĩ,
\q2 no mwana wa kũrekererio aconorithagia nyina.
\b
\q1 
\v 16 Hĩndĩ ĩrĩa andũ aaganu matheerema, noguo mehia matheeremaga,
\q2 no andũ arĩa athingu nĩmakerorera igwa rĩao.
\b
\q1 
\v 17 Herithagia mũrũguo, na nĩagatũma ũgĩe na thayũ;
\q2 nĩagatũma ũgĩe na gĩkeno ngoro-inĩ.
\b
\q1 
\v 18 Kũrĩa gũtarĩ na ũguũrio, kĩrĩndĩ gĩticookaga kwĩrigĩrĩria;
\q2 no gũkena nĩ mũndũ ũrĩa ũrũmagia watho.
\b
\q1 
\v 19 Ndungata ndĩngĩhera nĩ kwarĩrio gũtheri;
\q2 o na ĩngĩtaũkĩrwo nĩ ũhoro ndĩngĩũrũmbũiya.
\b
\q1 
\v 20 Wanona mũndũ ũhiũhaga kwaria?
\q2 Mũndũ mũkĩĩgu arĩ na kĩĩrĩgĩrĩro kũmũkĩra.
\b
\q1 
\v 21 Mũndũ angĩnania ndungata yake kuuma wĩthĩ wayo,
\q2 marigĩrĩrio-inĩ nĩĩkamũrehera kĩeha.
\b
\q1 
\v 22 Mũndũ wa marakara aarahũraga ngarari,
\q2 nake mũndũ wa marũrũ agĩĩaga na mehia maingĩ.
\b
\q1 
\v 23 Mwĩtĩĩo wa mũndũ nĩũmũnyiihagia,
\q2 no mũndũ ũrĩa wa ngoro ya kwĩnyiihia nĩagatĩĩo.
\b
\q1 
\v 24 Mũndũ wa kũgĩa thiritũ na mũici nĩ muoyo wake mwene athũire;
\q2 ehĩtithagio na ndangĩruta ũira.
\b
\q1 
\v 25 Gwĩtigĩra mũndũ gũtuĩkaga mũtego,
\q2 no ũrĩa wĩhokaga Jehova aikaraga arĩ mũgitĩre.
\b
\q1 
\v 26 Andũ aingĩ nĩmacaragia kũiguuo nĩ mũnene,
\q2 no mũndũ oonaga kĩhooto kuuma kũrĩ Jehova.
\b
\q1 
\v 27 Andũ arĩa athingu monaga andũ arĩa matarĩ ehokeku ta kĩndũ kĩrĩ magigi;
\q2 nao andũ arĩa aaganu moonaga andũ arĩa arũngĩrĩru ta kĩndũ kĩrĩ magigi.
\c 30
\s1 Mĩario ya Aguri
\p 
\v 1 Ĩno nĩyo mĩario ya Aguri mũrũ wa Jake, na nĩ ndũmĩrĩri nditũ:
\q1 Mũndũ ũcio eerire Ithieli,
\q2 akĩĩra Ithieli na Ukali atĩrĩ:
\b
\q1 
\v 2 “Niĩ ndĩ mũndũ mũriitu gũkĩra andũ arĩa angĩ;
\q2 ndirĩ na ũtaũku ta wa mũndũ.
\q1 
\v 3 Ndiĩrutĩte kũgĩa na ũũgĩ,
\q2 o na kana ngamenya Ũrĩa Mũtheru.
\q1 
\v 4 Nũũ wanambata igũrũ na agacooka agaikũrũka gũkũ thĩ?
\q2 Nũũ wanacookereria rũhuho ngundi-inĩ ciake?
\q1 Maaĩ namo-rĩ, nũũ ũrĩ wamoohania na nguo yake ya igũrũ?
\q2 Nũũ wahaandire ituri ciothe cia thĩ?
\q1 Etagwo atĩa, nake mũriũ etagwo atĩa?
\q2 Akorwo nĩũũĩ-rĩ, ndũkĩnjĩĩre!
\b
\q1 
\v 5 “Kiugo gĩothe kĩa Ngai gĩtirĩ mahĩtia;
\q2 nĩwe ngo ya arĩa moragĩra harĩ we.
\q1 
\v 6 Ndũkanongerere ciugo ciake,
\q2 ndakae gũkũrũithia wonekane ũrĩ wa maheeni.
\b
\q1 
\v 7 “Nĩngũkũhooya maũndũ meerĩ, Wee Jehova;
\q2 ndũkanarege kũhe mo mbere ya ngue:
\q1 
\v 8 Atĩrĩrĩ, njehereria maũndũ matarĩ ma ma, na ma maheeni, cindaihĩrĩrie mũno;
\q2 ningĩ ndũkaahe ũthĩĩni kana ũtonga,
\q2 no ũũheage irio cia o mũthenya.
\q1 
\v 9 Ndikaagĩe na indo nyingĩ mũno, ngũkaane,
\q2 njũũrie atĩrĩ, ‘Jehova nũũ?’
\q1 Kana thĩĩne mũno, njiye,
\q2 na nĩ ũndũ ũcio ngĩmenererie rĩĩtwa rĩa Ngai wakwa.
\b
\q1 
\v 10 “Ndũgacambie ndungata kũrĩ mũnene wayo,
\q2 ndĩgagĩkũrume, nawe ũrĩhio ũũru ũcio.
\b
\q1 
\v 11 “Nĩ kũrĩ andũ marumaga maithe mao
\q2 o na matangĩrathima manyina mao;
\q1 
\v 12 kũrĩ andũ arĩa meyonaga marĩ atheru maitho-inĩ mao,
\q2 o rĩrĩa matathambĩtio gĩko kĩao;
\q1 
\v 13 nĩ arĩa marĩ maitho ma mwĩtĩĩo,
\q2 o arĩa maroraga andũ manyiira;
\q1 
\v 14 nĩo arĩa magego mao mahaana ta hiũ cia njora,
\q2 na ngambucu ciao ihaana ta tũhiũ
\q1 twa gũtambuura arĩa athĩĩni, mahuke thĩ,
\q2 na arĩa abatari, mathire andũ-inĩ.
\b
\q1 
\v 15 “Thambara ĩrĩ airĩtu eerĩ.
\q2 Matitigithagĩria kuuga, ‘Tũhei! Tũhei!’
\b
\q1 “Kũrĩ indo ithatũ itarĩ hĩndĩ ihũũnaga,
\q2 o na nĩ inya itarĩ hĩndĩ ingiuga, ‘Nĩndaigania!’
\q1 
\v 16 Nacio nĩ mbĩrĩra, na nda thaata,
\q2 na thĩ tondũ ndĩrĩ hĩndĩ ĩiganagia maaĩ,
\q2 na mwaki tondũ ndũrĩ hĩndĩ uugaga, ‘Nĩndaigania!’
\b
\q1 
\v 17 “Riitho rĩa mũndũ ũrĩa ũnyũrũragia ithe,
\q2 na akarurũka kũiguaga nyina,
\q1 rĩgaakũũrwo nĩ mahuru ma kĩanda-inĩ,
\q2 na rĩkaarĩĩo nĩ nderi.
\b
\q1 
\v 18 “Kũrĩ maũndũ matatũ mangegagia mũno makĩria,
\q2 o na nĩ mana marĩa niĩ itakuũkagĩrwo nĩmo:
\q1 
\v 19 namo nĩ mũthiĩre wa nderi rĩera-inĩ,
\q2 na mũthiĩre wa nyoka rwaro-inĩ rwa ihiga,
\q1 na mũthiĩre wa marikabu ĩrĩ iria-inĩ gatagatĩ,
\q2 na mũthiĩre wa mũndũ makĩendana na mũirĩtu.
\b
\q1 
\v 20 “Ũyũ nĩguo mũthiĩre wa mũndũ-wa-nja mũtharia:
\q2 Arĩĩaga na akehuura mĩromo,
\q2 akoiga atĩrĩ, ‘Ndirĩ ũndũ mũũru njĩkĩte.’
\b
\q1 
\v 21 “Kũrĩ maũndũ matatũ matũmaga thĩ ĩthingithe,
\q2 o na nĩ mana ĩtangĩĩtiiria:
\q1 
\v 22 namo nĩ ndungata ĩtuĩkĩte mũthamaki,
\q2 na mũndũ mũkĩĩgu ahũũnĩte irio,
\q1 
\v 23 na mũndũ-wa-nja ũtangĩendeka ahikĩte,
\q2 na ndungata ya mũirĩtu ĩtuĩkĩte mũtumia wa mũthuuri wa mũmĩathi.
\b
\q1 
\v 24 “Nĩ kũrĩ nyamũ inya nini gũkũ thĩ,
\q2 no nĩ njũgĩ mũno:
\q1 
\v 25 Thigiriri-rĩ, nĩ ciũmbe itarĩ hinya,
\q2 no nĩciĩigagĩra mũthiithũ wa irio hĩndĩ ya riũa;
\q1 
\v 26 ikami nĩ ciũmbe itarĩ ũhoti,
\q2 no nĩciĩthondekagĩra ciikaro ciacio ndwaro-inĩ cia mahiga;\f + \fr 30:26 \ft Ikami nĩ mũthemba wa mbũkũ ciikaraga marima-inĩ ma irĩma irĩ ikundi.\f*
\q1 
\v 27 ngigĩ itirĩ mũthamaki wacio,
\q2 no nĩitwaranaga hamwe irĩ mbũtũ;
\q1 
\v 28 njagathi no inyiitwo na rũhĩ,
\q2 no ĩtũũraga thĩinĩ wa nyũmba cia athamaki.
\b
\q1 
\v 29 “Kũrĩ indo ithatũ irĩ mũkinyũkĩrie mũgaacĩru,
\q2 o na nĩ inya ngaacĩru rĩrĩa igũthiĩ:
\q1 
\v 30 nĩ mũrũũthi, arĩ guo ũrĩ hinya mũno gatagatĩ ka nyamũ iria ingĩ ciothe,
\q2 na ndũngĩeherera nyamũ ĩrĩkũ kana ĩrĩkũ njĩra;
\q1 
\v 31 nĩ njamba ya ngũkũ ĩrĩa ĩkinyũkagia na nguthi, na thenge,
\q2 na mũthamaki mũthiũrũrũkĩrie nĩ mbũtũ ciake cia ita.
\b
\q1 
\v 32 “Angĩkorwo nĩwĩtuĩte mũndũ mũkĩĩgu, na ũgetũũgĩria,
\q2 kana ũkorwo nĩũthugundĩte gwĩka ũũru-rĩ,
\q2 humbĩra kanua gaku na rũhĩ!
\q1 
\v 33 Nĩgũkorwo o ta ũrĩa iria rĩthũcagwo, rĩkoima thiagĩ,
\q2 na o ta ũrĩa iniũrũ rĩthioragwo rĩkoira thakame-rĩ,
\q2 ũguo noguo gũthogotha marakara kũrehaga ngũĩ.”
\c 31
\s1 Mĩario ya Mũthamaki Lemueli
\p 
\v 1 Ĩno nĩyo mĩario ya Mũthamaki Lemueli: nĩ ndũmĩrĩri nditũ ĩrĩa aarutirwo nĩ nyina:
\q1 
\v 2 “Atĩrĩrĩ, wee mũrũ wakwa, ngũkwĩra atĩa, o wee mwana wa nda yakwa,
\q2 ngũkwĩra atĩa o wee mwana wa mĩĩhĩtwa yakwa,
\q1 
\v 3 atĩrĩ, ndũkanaitange hinya waku na andũ-a-nja,
\q2 kana ũhe ũhoti waku acio manangaga athamaki.\f + \fr 31:3 \ft Nyũmba ya ũthamaki nĩyakoragwo na andũ-a-nja aingĩ mũno arĩa rĩmwe na rĩmwe monũhaga athamaki.\f*
\b
\q1 
\v 4 “Atĩrĩrĩ, wee Lemueli, athamaki matiagĩrĩirwo nĩkũnyua ndibei,
\q2 ti mũtugo wa athamaki kũnyua ndibei,
\q2 anene matiagĩrĩirwo nĩ kwĩrirĩria njoohi,
\q1 
\v 5 nĩgeetha matikanyue mariganĩrwo nĩ ũrĩa watho uugaga,
\q2 nao magithie arĩa othe ahinyĩrĩrie kĩhooto kĩao.
\q1 
\v 6 Heaga arĩa marathira njoohi,
\q2 na ndibei kũrĩ arĩa marĩ na ruo rũnene rwa ngoro;
\q1 
\v 7 reke manyue mariganĩrwo nĩ ũthĩĩni wao,
\q2 na matige gũcooka kũririkana kĩeha kĩao.
\b
\q1 
\v 8 “Arĩrĩria arĩa matangĩhota kwĩyarĩrĩria,
\q2 warĩrĩrie kĩhooto kĩa arĩa othe anyamaarĩku.
\q1 
\v 9 Maarĩrĩrie, na ũmatuĩre ciira na kĩhooto;
\q2 rũĩrĩra kĩhooto kĩa arĩa athĩĩni na arĩa abatari.”
\s1 Ciugo cia Kũrigĩrĩria: Mũtumia ũrĩa Ngatha
\q1 
\v 10 Mũtumia ngatha-rĩ, angĩoneka kũ?
\q2 Nĩgũkorwo thogora wake nĩũkĩrĩte mũno ũrĩa wa ruru iria ndune.
\q1 
\v 11 Mũthuuri wake nĩamwĩhokete biũ,
\q2 na ndarĩ kĩndũ kĩa bata angĩaga.
\q1 
\v 12 Mũtumia ũcio, matukũ mothe ma muoyo wake,
\q2 no maũndũ mega ekaga mũthuuriwe,
\q2 na ndangĩmwĩka ũũru.
\q1 
\v 13 Ethaga guoya wa ngʼondu na ndigi cia ũguta,
\q2 agacirutĩra wĩra na kĩyo, na moko make.
\q1 
\v 14 Ahaana ta marikabu cia wonjoria,
\q2 tondũ athũgũraga irio ciake kuuma kũraya.
\q1 
\v 15 Okĩraga rũciinĩ kũrĩ o na nduma;
\q2 akahe andũ a nyũmba yake irio,
\q2 na akagaĩra ndungata ciake cia airĩtu mawĩra mao.
\q1 
\v 16 Ecũũranagia ũhoro wa mũgũnda mũna, akaũgũra;
\q2 kuumana na ũthũkũmi wake, ahaandaga mũgũnda wa mĩthabibũ.
\q1 
\v 17 Ehotoragĩra wĩra wake erutanĩirie;
\q2 moko make marĩ hinya wa kwĩrutĩra wĩra.
\q1 
\v 18 Nĩatigagĩrĩra atĩ wonjoria wake nĩũrĩ na uumithio,
\q2 naguo tawa wake ũraaraga ũgĩakana.
\q1 
\v 19 Anyiitaga mũtĩ wa kuogotha ndigi na guoko,
\q2 nakĩo gĩcũni kĩa ndigi agakĩnyiitĩrĩra na ciara ciake.
\q1 
\v 20 Nĩataanahagĩra andũ arĩa athĩĩni,
\q2 nao arĩa abatari akamatambũrũkĩria moko make.
\q1 
\v 21 Rĩrĩa tharunji yagũa-rĩ, we ndamakaga atĩ nĩĩgũthĩĩnia andũ a nyũmba yake;
\q2 nĩgũkorwo othe nĩahumbe nguo cia rangi mũtune.
\q1 
\v 22 Nĩatumaga indo cia kwara ũrĩrĩ wake;
\q2 nake ehumbaga nguo cia gatani ĩrĩa njega, na cia rangi wa ndathi.\f + \fr 31:22 \ft Gĩtambaya kĩa rangi wa ndathi kĩarĩ kĩa goro mũno, na kĩarĩ kĩonereria kĩa ũnene.\f*
\q1 
\v 23 Mũthuuri wake nĩaheagwo gĩtĩĩo kĩhingo-inĩ gĩa itũũra inene,
\q2 harĩa aikaraga marĩ na athuuri a bũrũri.\f + \fr 31:23 \ft Kĩhingo-inĩ kĩa itũũra nĩho athuuri a itũũra maacemanagia.\f*
\q1 
\v 24 Mũtumia ũcio nĩatumaga nguo cia gatani agaciendia,
\q2 na agatwaragĩra onjoria mĩcibi.
\q1 
\v 25 Hinya na ũtĩĩku nĩcio nguo iria ehumbaga;
\q2 nĩakenaga ategwĩtigĩra matukũ marĩa magooka.
\q1 
\v 26 Aaragia ciugo cia ũũgĩ,
\q2 naruo rũrĩmĩ rwake rũrutanaga maũndũ ma ũtugi.
\q1 
\v 27 Nĩarũmbũyagia maũndũ ma nyũmba yake,
\q2 na ndarĩĩaga irio atanogeire.
\q1 
\v 28 Ciana ciake ciarahũkaga, cikoiga arorathimwo;
\q2 o nake mũthuuri wake nĩamũgaathagĩrĩria, akamwĩra atĩrĩ:
\q1 
\v 29 “Andũ-a-nja aingĩ manatuĩka ngatha,
\q2 no wee nĩũmakĩrĩte othe.”
\q1 
\v 30 Ngoga nĩ cia kũheenania, naguo ũthaka nĩ wa tũhũ;
\q2 no mũtumia ũrĩa mwĩtigĩri Jehova nĩ wa kũgaathĩrĩrio.
\q1 
\v 31 Mũrĩhei mũcaara wa wĩra ũrĩa arutĩte,
\q2 naguo wĩra wake ũrekwo ũmũgaathĩrĩrie kĩhingo-inĩ gĩa itũũra rĩrĩa inene.
