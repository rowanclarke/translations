\id PHM  
\h Filemón 
\toc1 Filemón 
\mt1 Nihánj me ꞌo̱ yanj cartá quiꞌyaj síí cuꞌna̱j Pabló caꞌnéé soꞌ rihaan síí cuꞌna̱j Filemoó a 
\c 1  
\p  
\v 1 ꞌU̱nj roꞌ, me síí cuꞌna̱j Pabló síí ꞌni̱j tagaꞌ cuano̱ cheꞌé se nocóꞌ ꞌu̱nj man Jesucristó, ne̱ nicu̱nꞌ tinúú níꞌ Timoteo ga̱ ꞌu̱nj cuano̱, ne̱ dan me se ꞌyáá ꞌu̱nj yanj nihánj caꞌne̱j ꞌu̱nj rihaan so̱ꞌ si̱j cuꞌna̱j Filemoó a. ꞌE̱e̱ rá ꞌu̱nj mán so̱ꞌ, ne̱ tuviꞌ níꞌ síí ꞌyaj suun ga̱ ꞌu̱nj mé so̱ꞌ,  
\v 2 ne̱ veé da̱nj vaa uún nu̱ꞌ nij síí noco̱ꞌ man Diose̱ nuu chre̱ꞌ tucuá so̱ꞌ do̱ꞌ, raꞌvij níꞌ chana̱ cuꞌna̱j Apia do̱ꞌ, síí cuꞌna̱j Arquipo síí yoꞌo̱ rquee̱ cheꞌé suun ꞌyaj suun níꞌ do̱ꞌ, nu̱ꞌ rihaan nij soꞌ ꞌyáá ꞌu̱nj yanj nihánj caꞌne̱j ꞌu̱nj rihaan nij soj ei. 
\p  
\v 3 Me rá ꞌu̱nj quiꞌya̱j Rej níꞌ Diose̱ quiꞌya̱j Jesucristó si̱j ꞌni̱j raꞌa man níꞌ quiꞌya̱j ndoꞌo se lu̱j cheꞌé nij soj, ne̱ ga̱a̱ xe̱j nimán nij soj, quiꞌya̱j ro̱j soꞌ, raj ei. 
\s1 Nana̱ nihánj taj xnaꞌanj se vaa nagoꞌ Pabló graciá rihaan Diose̱ cheꞌé síí cuꞌna̱j Filemoó cheꞌé se canocoꞌ sa̱ꞌ síí cuꞌna̱j Filemoó man Diose̱ a 
\p  
\v 4 Daj a̱ güii ga̱a tana̱nj na̱nj achíín ni̱ꞌyáá ꞌu̱nj rihaan Diose̱, achíín ni̱ꞌyáá ꞌu̱nj cheꞌé so̱ꞌ, ne̱ nagóꞌ ꞌu̱nj graciá rihaan Diose̱ cheꞌé so̱ꞌ ei.  
\v 5 Da̱nj ꞌyáá ꞌu̱nj, cheꞌé se caꞌnaꞌ nana̱ rihanj se vaa amán ndoꞌo rá so̱ꞌ niꞌya̱j so̱ꞌ man Jesucristó si̱j ꞌni̱j raꞌa man níꞌ, ne̱ ꞌe̱e̱ ndoꞌo rá so̱ꞌ man cunuda̱nj nij síí sa̱ꞌ noco̱ꞌ man soꞌ vaa cunó ꞌu̱nj ei.  
\v 6 Dan me se cheꞌé se a̱j canocóꞌ so̱ꞌ se‑tucua̱nj Jesucristó ga̱ yoꞌó nij tinúú níꞌ, ne̱ cheꞌé dan achíín ni̱ꞌyáá ꞌu̱nj se vaa caꞌve̱e xca̱j yoꞌó nij soꞌ cuentá cheꞌé nu̱ꞌ se sa̱ꞌ nica̱j nij tinu̱j nij soj qui̱ꞌyáá so̱ꞌ, ga̱a ne̱ caꞌve̱e cavi̱i̱ sa̱ꞌ doj Jesucristó quiꞌya̱j taranꞌ nij soj a.  
\v 7 ꞌO̱ se guun niha̱ꞌ uxrá rá ꞌu̱nj, ne̱ nariꞌ nucuaj nimán ꞌu̱nj, cheꞌé se ꞌe̱e̱ rá so̱ꞌ man tinúú so̱ꞌ ne̱ nuu cui̱j rá nij síí sa̱ꞌ noco̱ꞌ man Diose̱ ꞌyáá so̱ꞌ, tinu̱j. 
\s1 Nana̱ nihánj taj xnaꞌanj se vaa me rá Pabló veꞌé naca̱j uún síí cuꞌna̱j Filemoó man síí cuꞌna̱j Onésimo a 
\p  
\v 8 Nda̱ꞌ se uun chij ndoꞌo ꞌu̱nj ne̱ caꞌve̱e caꞌne̱ꞌ ꞌu̱nj suun rihaan so̱ꞌ qui̱ꞌyáá so̱ꞌ nda̱a vaa suun qui̱ꞌyáá so̱ꞌ, tza̱j ne̱ taj maꞌ.  
\v 9 Ma̱a̱n se veꞌé rqueé ꞌu̱nj mán so̱ꞌ qui̱ꞌyáá so̱ꞌ nda̱a vaa no̱ xcúún so̱ꞌ qui̱ꞌyáá so̱ꞌ ei. ꞌU̱nj si̱j cuꞌna̱j Pabló nihánj me se a̱j chii nga̱ mej ne̱ ꞌni̱j ꞌu̱nj tagaꞌ cuano̱ cheꞌé se nocóꞌ ꞌu̱nj man Jesucristó ei. ꞌO̱ se neꞌén ꞌu̱nj se vaa ꞌo̱ ꞌe̱e̱ rá so̱ꞌ tinúú so̱ꞌ, ne̱ cheꞌé dan cachi̱nj ni̱ꞌyáá ꞌu̱nj do̱j rihaan so̱ꞌ  
\v 10 cheꞌé síí cuꞌna̱j Onésimo a. Dan me se ase vaa ꞌo̱ taꞌníj roꞌ, da̱nj vaa soꞌ rihanj cuano̱, cheꞌé se ga̱a ꞌni̱j ꞌu̱nj tagaꞌ, ne̱ cataj xnaꞌanj ꞌu̱nj rihaan soꞌ cheꞌé Jesucristó, ne̱ guun cheꞌe̱ soꞌ canocoꞌ soꞌ man Jesucristó na̱nj ado̱nj.  
\v 11 Dan me se asi̱j rque̱ doj me se taj se gúnꞌ a̱ doj man soꞌ rihaan so̱ꞌ maꞌ. Tza̱j ne̱ cuano̱ nihánj me se cunuu sa̱ꞌ soꞌ, ne̱ vaa se gu̱un soꞌ rihaan níꞌ cuano̱ ei. 
\p  
\v 12 Dan me se a̱j caꞌnéé ꞌu̱nj man soꞌ cuchi̱ꞌ uún soꞌ rihaan so̱ꞌ, ne̱ neꞌén so̱ꞌ se vaa ꞌe̱e̱ uxrá raj man soꞌ ado̱nj.  
\v 13 Ne̱ guun rá ꞌu̱nj nayo̱n soꞌ rihaan so̱ꞌ quina̱j soꞌ nihánj rej ꞌni̱j ꞌu̱nj tagaꞌ nihánj cheꞌé se‑na̱na̱ Jesucristó nana̱ sa̱ꞌ, ne̱ quiꞌya̱j suun soꞌ rihaan ꞌu̱nj nihánj cheꞌé so̱ꞌ, raj ei.  
\v 14 Tza̱j ne̱ ne caꞌve̱j rá ꞌu̱nj quina̱j soꞌ rej nihánj, cheꞌé se nda̱a tuꞌva maꞌa̱n yá so̱ꞌ cavi̱i̱, ga̱a ne̱ quina̱j soꞌ, raj ei. ꞌO̱ se ne gu̱un raj qui̱ꞌyáj fuerzá mán so̱ꞌ qui̱ꞌyáá so̱ꞌ se ndoꞌo cheꞌej maꞌ. Ma̱a̱n se ina̱nj se rii nimán ma̱ꞌán so̱ꞌ qui̱ꞌyáá so̱ꞌ se ndoꞌo yoꞌ cheꞌej, raj ei.  
\v 15 Dan me se ma̱a̱n cheꞌé rej caꞌve̱e ca̱yáán soꞌ ga̱ so̱ꞌ nu̱ꞌ cavii nu̱ꞌ caꞌanj roꞌ, cheꞌé dan caꞌanj yaníj soꞌ do̱j rihaan so̱ꞌ do̱j güii ei.  
\v 16 Tza̱j ne̱ ya̱j me se se̱ guun soꞌ mozó u̱u̱n rihaan so̱ꞌ nu̱ꞌ cavii nu̱ꞌ caꞌanj ya̱j a̱ maꞌ. Tana̱nj a̱ sa̱ꞌ doj ga̱a̱ soꞌ rihaan yoꞌo̱ nij mozó rihaan so̱ꞌ, ne̱ ꞌo̱ tinúú níꞌ síí ꞌe̱e̱ rá níꞌ man gu̱un soꞌ ei. ꞌO̱ se ꞌe̱e̱ uxrá raj man soꞌ, ne̱ táá a̱ so̱ꞌ, ne̱ doj a̱ ga̱a̱ ꞌe̱e̱ rá ma̱ꞌán so̱ꞌ man soꞌ a̱ ei. ꞌO̱ se si̱j ꞌyaj suun rihaan so̱ꞌ me soꞌ rihaan chumii̱ nihánj, ne̱ si̱j noco̱ꞌ man síí ꞌni̱j raꞌa man níꞌ me uún soꞌ, ne̱ doj a̱ ga̱a̱ ya̱ rá so̱ꞌ man soꞌ ei. 
\p  
\v 17 Dan me se sese tinu̱j ya̱ níꞌ, ne̱ veꞌé naꞌmi̱i̱ sa̱ꞌ so̱ꞌ ga̱ soꞌ, ne̱ da̱j se uun rá so̱ꞌ neꞌén so̱ꞌ manj roꞌ, da̱nj gu̱un rá so̱ꞌ que̱neꞌén so̱ꞌ man soꞌ ei.  
\v 18 Ne̱ sese quiꞌyaj chiꞌi̱i̱ soꞌ mán so̱ꞌ do̱ꞌ, sese vaa xcúún quiꞌyaj soꞌ rihaan so̱ꞌ do̱ꞌ, ne̱ ma̱ꞌán ꞌu̱nj na̱ruꞌvee rihaan so̱ꞌ se vaa quiꞌyaj xcúún soꞌ ei.  
\v 19 Ma̱ꞌanj raꞌaj si̱j cuꞌna̱j Pabló cachronj nana̱ nihánj se vaa na̱ruꞌvee ꞌu̱nj cunuda̱nj se vaa quiꞌyaj xcúún soꞌ rihaan so̱ꞌ ei. Veé da̱nj vaa xcúún rihaan soꞌ do̱ꞌ, tza̱j ne̱ taj cheꞌé cata̱j xnaꞌanj ꞌu̱nj rihaan so̱ꞌ se vaa vaa xcúún rihaan ma̱ꞌán so̱ꞌ se vaa quinanii so̱ꞌ rihaan sayuun nu̱ꞌ cavii nu̱ꞌ caꞌanj, quiꞌyaj ma̱ꞌanj ga̱a natáꞌ ꞌu̱nj se‑na̱na̱ Jesucristó rihaan so̱ꞌ maꞌ.  
\v 20 Dan me se me ina̱nj rá ꞌu̱nj qui̱ꞌyáá so̱ꞌ se ndoꞌo cheꞌej, cheꞌé se si̱j noco̱ꞌ man síí ꞌni̱j raꞌa man níꞌ me níꞌ, tinu̱j. ꞌO̱ se nda̱a cunu̱u cui̱j rá ꞌu̱nj, qui̱ꞌyáá so̱ꞌ cheꞌé Jesucristó ei. 
\p  
\v 21 Dan me se ga̱a cachrón ꞌu̱nj nana̱ nihánj, ne̱ nucua̱j rá ꞌu̱nj mán so̱ꞌ se vaa qui̱ꞌyáá so̱ꞌ nu̱ꞌ nihánj, ne̱ nda̱a doj a̱ qui̱ꞌyáá so̱ꞌ rihaan se vaa cataj xnaꞌanj ꞌu̱nj rihaan so̱ꞌ chugua̱nj.  
\v 22 Ne̱ me rá ꞌu̱nj naquiꞌya̱j chu̱vií so̱ꞌ veꞌ ca̱né ꞌu̱nj do̱j ga̱ so̱ꞌ á. ꞌO̱ se guun ya̱ raj se vaa cheꞌé se cachíín niꞌya̱j soj rihaan Diose̱ cheꞌej roꞌ, cheꞌé dan ra̱cuíj Diose̱ manj cuchi̱j rihaan soj, raj ado̱nj. 
\s1 Nana̱ nihánj taj xnaꞌanj se vaa me rá nij tuvi̱ꞌ Pabló se vaa veꞌé ca̱yáán síí cuꞌna̱j Filemoó a 
\p  
\v 23 Me rá síí cuꞌna̱j Epafras se vaa veꞌé ca̱yáán so̱ꞌ á. ꞌNi̱j soꞌ tagaꞌ ga̱ ꞌu̱nj, cheꞌé se si̱j noco̱ꞌ man Jesucristó me soꞌ a.  
\v 24 Ne̱ síí cuꞌna̱j Marcos do̱ꞌ, síí cuꞌna̱j Aristarco do̱ꞌ, síí cuꞌna̱j Demas do̱ꞌ, síí cuꞌna̱j Lucas do̱ꞌ, me rá uún se vaa veꞌé ca̱yáán so̱ꞌ a. Taranꞌ nij soꞌ me síí ꞌyaj suun ga̱ ꞌu̱nj ado̱nj. 
\p  
\v 25 Me rá ꞌu̱nj quiꞌya̱j ndoꞌo Jesucristó si̱j ꞌni̱j raꞌa man níꞌ se lu̱j cheꞌé nimán nij soj ado̱nj.