\id DEU
\h أَعَاوذْ ن شَّارِيعَا 
\toc1 أَعَاوذْ ن شَّارِيعَا 
\toc2 أَعَاوذْ ن شَّارِيعَا 
\toc3 أَعَوذ. 
\mt1 أَعَاوذْ ن شَّارِيعَا  
\c 1
\s1 أَوَاڒْ ن مُوسَا  
\m
\v 1 إِنَا ذ أَوَاڒنْ نِّي إِسِّيوڒْ مُوسَا إِ مَارَّا إِسْرَائِيل خْ ؤُجمَّاضْ ن لْ-ؤُرْذُونْ، ذِي ڒخْڒَا، ذِي ڒوْضَا أَرنْذَاذْ ن صُوفْ، جَارْ فَارَانْ ذ ثُوفَالْ ذ لَابَانْ ذ حَاضَايْرُوثْ ذ ذِي-ذَاهَابْ.  
\v 2 زِي حُورِيبْ خْ وبْرِيذْ ن إِذُورَارْ ن سَاعِيرْ أَڒْ قَاذَاشْ-بَارْنِيعْ أَقَا-ت ذ إِشْثْ ن ثِيشْثِي ن حِيطَاشْ ن وُوسَّانْ.  
\v 3 إِمْسَارْ ذڭْ ؤُسڭّْوَاسْ وِيسّْ أَربْعِينْ، ذڭْ ؤُيُورْ وِيسّْ حِيطَاشْ، ذڭْ \add وَاسّْ\add* أَمزْوَارُو ن ؤُيُورْ، إِسِّيوڒْ مُوسَا أَكْ-ذ أَيْثْ ن إِسْرَائِيل عْلَاحْسَابْ مَارَّا مِينْ ذ أَسْ إِوصَّا سِيذِي زِي جِّيهثْ نْسنْ،  
\v 4 أَوَارْنِي ؤُمِي إِغْڒبْ ذِي إِذْرَاعِي خْ سِيحُونْ، أَجدْجِيذْ ن إِمُورِييّنْ ونِّي ثُوغَا إِزدّْغنْ ذِي حَاشْبُونْ، ؤُ خْ عُوجْ، أَجدْجِيذْ ن بَاشَانْ، ونِّي ثُوغَا إِزدّْغنْ ذِي عَاشْثَارُوثْ. \x ◘ \xo 1:‏4 \xt ڒخْڒ. 21‏:‏24، 33\x*  
\v 5 خْ ؤُجمَّاضْ ن لْ-ؤُرْذُونْ، ذِي ثمُّورْثْ ن مُوآبَ، إِبْذَا مُوسَا أَذْ إِفسَّارْ شَّارِيعَا-يَا، إِنَّا:   
\b  
\m
\v 6 ”سِيذِي، أَربِّي نّغْ، إِسِّيوڒْ أَكِيذْنغْ غَارْ حُورِيبْ، إِنَّا: ’كنِّيوْ ثقِّيمنْ أَطَّاسْ غَارْ وذْرَارْ-أَ، أَقَا ذ أَطَّاسْ.  
\v 7 ذوْڒمْ، كّْسمْ إِقِيضَانْ نْومْ ؤُشَا أَذْفمْ غَارْ إِذُورَارْ ن إِمُورِييّنْ ؤُ غَارْ مَارَّا \add إِمُوشَانْ\add* يُوذْسنْ ذِي ڒوْضَا، ذِي ثمُّورْثْ ن إِذُورَارْ، ذِي ثمُّورْثْ إِوَاطَانْ، ذِي \add ثمُّورْثْ ن\add* لْجَانُوبْ ؤُ غَارْ ثْمَا ن ڒبْحَارْ، ثَامُّورْثْ ن أَيْثْ ن كنْعَانْ، ذ لُوبْنَانْ أَڒْ إِغْزَارْ أَمقّْرَانْ، إِغْزَارْ ن لْفُورَاطْ.  
\v 8 خْزَارْ، نشّْ وْشِيغْ أَومْ ثَامُّورْثْ إِ إِدْجَانْ زَّاثْ إِ وُوذمْ نْومْ. أَذْفمْ غَارسْ، ثطّْفمْ ثَامُّورْثْ نِّي خْ إِجُّودْجْ سِيذِي أَذْ ت إِوْشْ إِ ڒجْذُوذْ نْومْ، إِ إِبْرَاهِيمْ، إِسْحَاقْ ذ يَاعْقُوبْ، ؤُ إِ زَّارِيعثْ نْسنْ أَوَارْنِي أَسنْ.‘ \x ◘ \xo 1:‏8 \xt أَمز. 15‏:‏18؛ 17‏:‏7، 8\x*  
\v 9 ذِي ڒْوقْثْ نِّي سِّيوْڒغْ نشّْ أَكِيذْومْ، نِّيغْ: ’نشّْ وَاهَا وَارْ زمَّارغْ أَذْ أَرْبُوغْ \add أَمْنُوسْ إِ كنِّيوْ\add*. \x ◘ \xo 1:‏9 \xt ؤُف. 18‏:‏18\x*  
\v 10 سِيذِي، أَربِّي نْومْ، إِڭَّا كنِّيوْ ذ أَطَّاسْ، ؤُشَا خْزَارْ، كنِّيوْ ڒخُّو ذ أَطَّاسْ أَمْ يِيثْرَانْ ن ؤُجنَّا.  
\v 11 أَذْ ثَافْ أَذْ ذَايْومْ إِمَّارْنِي سِيذِي، أَربِّي ن ڒجْذُوذْ نْومْ، أَمْ مَامّشْ كنِّيوْ \add ثدْجَامْ ڒخُّو\add* أَڒفْ ن ثْوَاڒَاوِينْ ؤُشَا أَذْ ثَافْ أَذْ كنِّيوْ إِبَاركْ أَمْ مَامّشْ ثُوغَا غَارْومْ د-إِسِّيوڒْ.  
\v 12 مَامّشْ زمَّارغْ نشّْ وحّْذِي وَاهَا أَذْ أَرْبُوغْ إِسْحسِّيفنْ نْومْ ذ دّْقُوڒَاثْ نْومْ ذ إِمْشُوبّشنْ نْومْ؟  
\v 13 كْسِيمْ زِي جَارْ ثقْبِيتْشْ نْومْ إِرْيَازنْ إِمِيغِيسنْ، إِفهّْمنْ، إِنِّي إِتّْوَاسّْننْ \add إِشْنَانْ\add*، حِيمَا أَذْ ثنْ ڭّغْ ذ إِزدْجِيفنْ خَاومْ.‘  
\v 14 \add خنِّي\add* كنِّيوْ ثَارِّيمْ-د خَافِي، ثنَّامْ أَيِي: ’أَوَاڒْ إِ ثسِّيوْڒذْ، أَقَا إِبَانْ-د إِشْنَا، حِيمَا أَذْ \add ث\add* نڭّْ.‘  
\v 15 ؤُشَا كْسِيغْ إِزدْجِيفنْ ن ثقْبِيتْشْ نْومْ، إِرْيَازنْ إِمِيغِيسنْ، إِفهّْمنْ، إِنِّي إِتّْوَاسّْننْ إِشْنَانْ، ؤُشَا ڭِّيغْ ثنْ ذ إِزدْجِيفنْ خَاومْ، \add أَمْ\add* إِمقّْرَاننْ خْ وَاڒفْ، إِمقّْرَاننْ خْ مْيَا، إِمقّْرَاننْ خْ خمْسِينْ ذ إِمقّْرَاننْ خْعشْرَا، ؤُ \add أَمْ\add* إِمحْضَاينْ خْ ثْقبَّاڒْ نْومْ.  
\v 16 ذِي ڒْوقْثْ نِّي ؤُمُورغْ إِ ڒْقُوضَاثْ نْومْ ؤُشَا نِّيغْ: ’سْڒمْ غَارْ أَيْثْمَاثْومْ ؤُشَا حكْممْ س يِيجّْ ن ڒْحُوكْمْ إِسڭّْذنْ جَارْ ورْيَازْ ذ ؤُمَاسْ ذ ؤُبَارَّانِي \add نِّي\add* كِيذسْ \add إِدْجَانْ\add*. \f ◼ \fr 1:‏16 \ft \+bd ’ڒْْقُوضَاثْ‘\+bd* - نِيغْ ’إِمزُورْفَا.\f*  \x ◘ \xo 1:‏16 \xt يُوح. 7‏:‏24\x*  
\v 17 وَارْ تّڭّمْ س وُوذْمَاونْ ذِي ڒحْكَامْ. أَذْ ثسْڒمْ غَارْ ؤُمژْيَانْ ذ ؤُمقّْرَانْ. وَارْ ثڭّْوْذمْ زڭْ وُوذمْ ن شَا ن يِيجّنْ، مِينْزِي ڒحْكَامْ غَارْ أَربِّي. ثَامسْڒَاشْثْ نِّي ثوْعَارْ خَاومْ، أَوْيمْ ت-إِ-د غَارِي ؤُشَا نشّْ أَذْ ت سْڒغْ.‘ \x ◘ \xo 1:‏17 \xt لَاوِي 19‏:‏15؛ 1 صم. 16‏:‏7؛ أَوڒن. 24‏:‏23؛ يَاع. 2‏:‏1\x*  
\v 18 \add أَمُّو\add* إِ كنِّيوْ ؤُمُورغْ ذِي ڒْوقْثْ نِّي مَارَّا ثِيمسْڒَايِينْ نِّي خَاومْ أَذْ ثنْثْ ثڭّمْ.“   
\b  
\m
\v 19 ”\add خنِّي\add* نفْسِي إِقِيضَانْ نّغْ \add ؤُشَا نفّغْ\add* زِي حُورِيبْ ؤُشَا نژْوَا مَارَّا ڒخْڒَا أَمقّْرَانْ إِسَّاڭّْوَاذنْ نِّي ثژْرِيمْ، \add نُويُورْ\add* ذڭْ وبْرِيذْ ن إِذُورَارْ ن إِمُورِييّنْ أَمْ مَامّشْ ذ أَنغْ يُومُورْ سِيذِي، أَربِّي نّغْ، ؤُشَا نِيوضْ غَارْ قَاذَاشْ-بَارْنِيعْ.  
\v 20 \add خنِّي\add* نِّيغْ أَومْ: ’أَقَا ثِيوْضمْ غَارْ إِذُورَارْ ن إِمُورِييّنْ نِّي إِ ذ أَنغْ غَا إِوْشْ سِيذِي، أَربِّي نّغْ.  
\v 21 خْزَارْ، سِيذِي، أَربِّي نّشْ، أَقَا إِوْشَا \add أَسْ\add* ثَامُّورْثْ إِ ذِينْ إِدْجَانْ زَّاثْ إِ وُوذمْ نّشْ. ڭعّذْ، طّفْ إِ-ت، أَمْ مَامّشْ غَاركْ إِسِّيوڒْ سِيذِي، أَربِّي ن ڒجْذُوذْ نْومْ. وَارْ تّڭّْوذْ ؤُ وَارْ تّجِّي أَذْ إِعْڭزْ وُوڒْ نّشْ.‘  
\v 22 ثُوسِيمْ-د غَارِي مَارَّا كنِّيوْ، ثنَّامْ: ’أجّْ أَنغْ أَذْ نسّكّْ إِرْيَازنْ زَّاثْ إِ وُوذمْ نّغْ حِيمَا أَذْ برْڭَاڭنْ ثَامُّورْثْ مَاحنْذْ أَذْ أَنغْ خبَّارنْ خْ مَانْ أَبْرِيذْ إِ زِي غَا نْڭعّذْ ذِي \add ثَامُّورْثْ\add* ؤُ مَامّشْ \add دْجَانْثْ\add* ثْندَّامْ إِ غَارْ د غَا نَاسْ.‘  
\v 23 ثُوغَا أَوَاڒْ-أَ ذ لمْلِيحْ إِ نشّْ ؤُشَا كْسِيغْ ثنْعَاشْ ن يرْيَازنْ زِي \add ڒْْوسْثْ\add* نْومْ، زِي \add كُوڒْ\add* ثَاقْبِيتْشْ إِجّْ ن ورْيَازْ. \x ◘ \xo 1:‏23 \xt ڒخْڒ. 13‏:‏2‏-‏38.\x*  
\v 24 نّْضنْ نِيثْنِي ؤُشَا ؤُيُورنْ خْ وبْرِيذْ غَارْ إِذُورَارْ ؤُشَا ؤُسِينْ-د غَارْ ثغْزُورْثْ ن إِشْكُولْ ؤُشَا برْڭَاڭنْ ثمُّورْثْ. \x ◘ \xo 1:‏24 \xt ڒخْڒ. 13‏:‏23\x*  
\v 25 كْسِينْ س إِفَاسّنْ نْسنْ ڒْغِيدْجثْ ن ثمُّورْثْ ؤُشَا هْوَانْ-د غَارْنغْ. إِوْينْ أَنغْ-د ڒخْبَارْ، نَّانْ: ’ثَامُّورْثْ إِ ذ أَنغْ غَا إِوْشْ سِيذِي، أَربِّي نّغْ، ثصْبحْ.‘ “   
\m
\v 26 ”قَاعْ أَمنِّي، وَارْ ثخْسمْ أَذْ ثْڭعّْذمْ ؤُشَا ثْغوّْغمْ ضِيدّْ إِ ڒُومُورْ ن سِيذِي، أَربِّي نْومْ. \x ◘ \xo 1:‏26 \xt ڒخْڒ. 14‏:‏2\x*  
\v 27 ؤُشَا ثْنذْقمْ-د ذڭْ إِقِيضَانْ نْومْ، ثنَّامْ: ’ذڭْ وقْڒَابْ نّسْ خَانغْ، أَقَا إِسُّوفّغْ أَنغْ سِيذِي زِي ثمُّورْثْ ن مِيصْرَا مَاحنْذْ أَذْ أَنغْ يَارّْ غَارْ إِفَاسّنْ ن إِمُورِييّنْ مَاحنْذْ أَذْ أَنغْ يَاردّدْجْ. \f ◼ \fr 1:‏27 \ft \+bd ’غَارْ إِفَاسّنْ‘\+bd* - س ثْعِيبْرَانِيثْ ’غَارْ ؤُفُوسْ‘.\f*  
\v 28 مَانِي \add خنِّي\add* إِ غَا نْڭعّذْ؟ أَيْثْمَاثْنغْ سّْفسّْينْ ؤُڒَاونْ نّغْ، نَّانْ: ڒْڭنْسْ إِمْغَارْ ؤُشَا زُّوڭَارنْ خَانغْ. ثِيندَّامْ مْغَارنْثْ ؤُشَا تّْوَافَارْينْثْ أَڒْ أَجنَّا ؤُشَا نژْرَا ذِينْ ؤُڒَا ذ أَيْثْ ن عَانَاقْ.‘ \x ◘ \xo 1:‏28 \xt ڒخْڒ. 13‏:‏28\x*  
\v 29 نشّْ نِّيغْ أَومْ: ’وَارْ ثَارْجِيجمْ شَا ؤُ وَارْ زَّايْسنْ تّڭّْوْذمْ.  
\v 30 سِيذِي، أَربِّي نْومْ، ونِّي إِڭُّورنْ زَّاثْومْ، أَذْ إِمّْنغْ ذِي طّْوعْ نْومْ، أَمُّو نِيشَانْ أَمْ مَامّشْ إِڭَّا زَّاثْ إِ ثِيطَّاوِينْ نْومْ ذِي طّْوعْ نْومْ ذِي مِيصْرَا  
\v 31 ؤُڒَا ذِي رخْڒَا، مَانِي ثژْرِيذْ مَامّشْ ثُوغَا شكْ يَاربُّو سِيذِي، أَربِّي نّشْ، مَارَّا أَبْرِيذْ نِّي ثُويُورذْ، أَمْ يِيجّْ ن ورْيَازْ يَاربُّونْ مِّيسْ، أَڒَامِي د-ثِيوْضمْ غَارْ ومْشَانْ-أَ.‘  
\v 32 \add مَاشَا\add* كنِّيوْ عَاذْ وَارْ ثُومِينمْ شَا س وَاوَاڒْ-أَ ذِي سِيذِي، أَربِّي نْومْ،  
\v 33 ونِّي ثُوغَا إِڭُّورنْ زَّاثْ إِ وُوذمْ نْومْ ذڭْ وبْرِيذْ، حِيمَا أَذْ أَومْ يَارْزُو مَانِي غَا ثوْثمْ إِقِيضَانْ نْومْ، \add ؤُ ونِّي ثُوغَا إِڭُّورنْ\add*، س دْجِيڒثْ ذِي ثْمسِّي، مَاحنْذْ أَذْ أَومْ إِسّْشنْ أَبْرِيذْ مَانِي كنِّيوْ إِتّْخصَّا أَذْ ثُويُورمْ، ؤُ س ؤُزِيڒْ ذڭْ إِجّْ ن ؤُسيْنُو. \x ◘ \xo 1:‏33 \xt ؤُف. 13‏:‏21\x*  
\v 34 سِيذِي إِسْڒَا \add ڒْْحسّْ ن\add* وَاوَاڒنْ نْومْ ؤُشَا إِجَّا أَغْضَابْ نّسْ أَذْ إِدُّوقّزْ، إِجِّيدْجْ، إِنَّا:  
\v 35 ’ؤُڒَا ذ إِجّْ زڭْ يرْيَازنْ-أَ ن جِّيڒْ-أَ أَعفَّانْ وَارْ إِژَارّْ ثَامُّورْثْ إِشْنَانْ نِّي خْ جُّودْجغْ مَاحنْذْ أَذْ ت وْشغْ إِ ڒجْذُوذْ نْومْ، \x ◘ \xo 1:‏35 \xt ڒخْڒ. 14‏:‏22، 23؛ إِزهد. 95‏:‏11\x*  
\v 36 مْغِيرْ كَالِيبْ، مِّيسْ ن يَافُونِّي، نتَّا أَذْ ت إِژَارْ ؤُشَا إِ نتَّا ذ إِحنْجِيرنْ نّسْ أَذْ وْشغْ ثَامُّورْثْ نِّي خْ إِڭَّا إِضَارنْ نّسْ، مِينْزِي نتَّا ثُوغَا إِضفَّارْ سِيذِي نِيشَانْ.‘  
\v 37 إِسْعَارْ خَافِي سِيذِي ذِي سِّيبّثْ نْومْ، إِنَّا: ’ؤُڒَا ذ شكْ وَارْ \add غَارسْ\add* تِّيذْفذْ شَا! \x ◘ \xo 1:‏37 \xt ڒخْڒ. 20‏:‏12؛ 27‏:‏14؛ أَعَوذ. 3‏:‏26؛ 4‏:‏21؛ 34‏:‏4\x*  
\v 38 يَاشُووَا، مِّيسْ ن نُونْ، ونِّي إِبدّنْ زَّاثْ إِ وُوذمْ نّشْ، أَذْ غَارسْ يَاذفْ. سْجهْذْ إِ-ث، مِينْزِي نتَّا ذ ونِّي ت غَا إِوْشنْ ذ ڒْوَارْثْ إِ إِسْرَائِيل.  
\v 39 ؤُشَا ثَارْوَا نْومْ إِ خْ ثنَّامْ: أَذْ ذوْڒنْ ذ ثيْمَارْثْ!، إِحنْجِيرنْ نْومْ نِّي وَارْ سِّيننْ \add عَاذْ\add* ڒْخَارْ نِيغْ ڒْغَارْ، نِيثْنِي أَذْ غَارسْ أَذْفنْ ؤُشَا نشّْ أَذْ أَسنْ ت-إِ-د-وْشغْ ؤُشَا نِيثْنِي أَذْ ت وَارْثنْ.  
\v 40 \add مَاشَا\add* كنِّيوْ أَذْ د-ثْذوْڒمْ، أَذْ ثكّْسمْ إِقِيضَانْ نْومْ سَّا \add ؤُشَا أَذْ ثُويُورمْ\add* غَارْ ڒخْڒَا غَارْ ڒبْحَارْ ن ثلْڭَا.‘  
\v 41 كنِّيوْ ثَارِّيمْ-د، ثنَّامْ أَيِي: ’أَقَا نخْضَا أَكْ-ذ سِيذِي. أَذْ نْڭعّذْ ؤُشَا أَذْ نمّْنغْ قَاعْ أَمْ مَامّشْ ذ أَنغْ يُومُورْ سِيذِي، أَربِّي نّغْ.‘ \add خنِّي\add* ثْبيْسمْ، كُوڒْ إِجّْ س ڒسْنَاحْ نّسْ ن ڭَارَّا ؤُ كنِّيوْ س زّْعَامثْ نْومْ ثْبدّمْ أَذْ ثْڭعّْذمْ غَارْ وذْرَارْ.  
\v 42 \add خنِّي\add* إِنَّا أَيِي سِيذِي: ’إِنِي أَسنْ: وَارْ تّْڭعّْذمْ، وَارْ تّْمنْغِيمْ، مِينْزِي نشّْ وَارْ دْجِيغْ ذِي ڒْوسْطْ نْومْ، حِيمَا وَارْ ثْخصَّارمْ زَّاثْ إِ وُوذمْ ن ڒْعذْيَانْ نْومْ.‘  
\v 43 \add أَمُّو\add* إِ كِيومْ سِّيوْڒغْ، \add مَاشَا\add* كنِّيوْ وَارْ تّسْڒِيمْ ؤُشَا ثْغوّْغمْ ضِيدّْ إِ ڒُومُورْ ن سِيذِي ؤُشَا ثڭِّيمْ س ثُوفّثْ، ثْڭعّْذمْ غَارْ إِذُورَارْ.  
\v 44 ؤُشَا فّْغنْ إِمُورِييّنْ نِّي ثُوغَا إِزدّْغنْ ذڭْ إِذُورَارْ ؤُشَا ؤُژّْڒنْ خَاومْ، أَمْ تّڭّنْثْ ثْزِيزْوَا، ؤُشَا ڒبْزنْ كنِّيوْ ذِي صَاعِيرْ أَڒْ حُورْمَا.  
\v 45 ثْذوْڒمْ-د، ثسّْغُويمْ زَّاثْ إِ وُوذمْ ن سِيذِي. سِيذِي وَارْ إِسْڒِي إِ ثْمِيجَّا نْومْ، وَارْ ذ أَومْ إِوْشِي أَمزُّوغْ،  
\v 46 ؤُشَا ثقِّيممْ ذِي قَاذَاشْ إِشْثْ ن ڒْوقْثْ ذ أَزِيرَارْ، ؤُسَّانْ أَطَّاسْ إِ ذِينِّي ثقِّيممْ.“   
\b  
\b  
\m  
\c 2
\m
\v 1 ”\add خنِّي\add* نذْوڒْ-د ؤُشَا نفْسِي إِقِيضَانْ \add ؤُشَا نُويُورْ\add* غَارْ ڒخْڒَا، ذڭْ وبْرِيذْ غَارْ ڒبْحَارْ ن ثلْڭَا، أَمْ مَامّشْ ذ أَيِي إِنَّا سِيذِي ؤُشَا ننّضْ أَطَّاسْ ن وُوسَّانْ إِ إِذُورَارْ ن سَاعِيرْ.  
\v 2 \add خنِّي\add* إِسِّيوڒْ سِيذِي أَكِيذِي، إِنَّا:  
\v 3 ’أَطَّاسْ إِ ثنّْضمْ إِ وذْرَارْ-أَ، أَقَا شْفَا. أَرّمْ \add أَزدْجِيفْ\add* غَارْ شَّامَالْ  
\v 4 ؤُشَا ؤُمُورْ ڒْڭنْسْ، إِنِي: أَذْ ثكّمْ كنِّيوْ خْ ويْمِيرْ ن أَيْثْمَاثْومْ، أَيْثْ ن عِيسُو، إِنِّي إِزدّْغنْ ذِي سَاعِيرْ. نِيثْنِي أَذْ زَّايْومْ ڭّْوذنْ، \add مَاشَا\add* إِتّْخصَّا كنِّيوْ أَذْ ثحْضَامْ إِخفْ نْومْ أَطَّاسْ. \f ◼ \fr 2:‏4 \ft \+bd ’أَذْ ثحْضَامْ إِخفْ نْومْ أَطَّاسْ‘\+bd* - نِيغْ ’أَذْ ثِيڒِيمْ ثْفَاقمْ‘.\f*  
\v 5 وَارْ كِيسنْ تّمْعَاڒَامْ، مِينْزِي وَارْ ذ أَومْ تِّيشغْ ؤُڒَا ذ إِجّْ ن شْبَارْ زِي ثمُّورْثْ نْسنْ، مِينْزِي نشّْ وْشِيغْ إِذُورَارْ ن سَاعِيرْ ذ ڒْوَارْثْ إِ عِيسُو. \f ◼ \fr 2:‏5 \ft \+bd ’إِجّْ ن شْبَارْ‘\+bd* - نِيغْ ’إِجْ ن ؤُصُورْفْ ن ؤُضَارْ‘.\f*  \x ◘ \xo 2:‏5 \xt أَمز. 36‏:‏8\x*  
\v 6 أَذْ خَاسنْ ثسْغمْ ڒعْوتْشْ س نُّوقَارْثْ حِيمَا \add أَذْ ثْزمَّارمْ\add* أَذْ ثشّمْ ؤُ أَذْ خَاسنْ ثسْغمْ عَاوذْ أَمَانْ س نُّوقَارْثْ حِيمَا أَذْ ثسْومْ.  
\v 7 مِينْزِي سِيذِي، أَربِّي نّشْ، ثُوغَا إِبَاركْ إِ شكْ ذِي مَارَّا ڒْخذْمثْ ن إِفَاسّنْ نّشْ. نتَّا إِسّنْ ثِيشْڒِي نّشْ ذِي ڒخْڒَا-يَا أَمقّْرَانْ. \add مَارَّا\add* أَربْعِينْ ن إِسڭّْوُوسَا-يَا ثُوغَا سِيذِي، أَربِّي نّشْ، أَكِيذكْ ؤُشَا وَارْ ذ أَشْ إِخصِّي وَالُو.‘ “   
\m
\v 8 ”\add ؤُمِي\add* نكَّا خْ يَايْثْمَاثْنغْ، أَيْثْ ن عِيسُو نِّي ثُوغَا إِزدّْغنْ ذِي سَاعِيرْ، خْ وبْرِيذْ ن ڒوْضَا ن إِلَاثْ ذ عِيصْيُونْ-جَابِيرْ، نذْوڒْ-د ؤُشَا نكَّا خْ وبْرِيذْ ن ڒخْڒَا ن مُوآبَ.  
\v 9 \add خنِّي\add* إِسِّيوڒْ أَكِيذِي سِيذِي: ’وَارْ سَّاڭّْوَاذْ مُوآبَ ؤُ وَارْ كِيسنْ تّْمنْغَامْ، مِينْزِي نشّْ وَارْ ذ أَومْ تِّيشغْ وَالُو ذ ڒْوَارْثْ زِي ثمُّورْثْ نْسنْ، مِينْزِي نشّْ وْشِيغْ عَارْ ذ ڒْوَارْثْ إِ أَيْثْ ن لُوطْ.‘   
\m
\v 10 \qt ثُوغَا زدّْغنْ ذِينْ إِمِييّنْ، إِجّْ ن ڒْڭنْسْ ذ أَمقّْرَانْ ذ أَطَّاسْ ؤُشَا نِيثْنِي ذ إِزِيرَارنْ أَمْ إِعَانَاقِييّنْ.\qt*  
\v 11 \qt نِيثْنِي تّْوَاحسْبنْ ذ إِرَافَاوِييّنْ أَمْ إِعَانَاقِييّنْ ؤُشَا أَيْثْ ن مُوآبَ قَّارنْ أَسْ إِمِييّنْ.\qt*\f ◼ \fr 2:‏11 \ft \+bd ’إِرَافَاوِييّنْ‘\+bd* - نِيغْ ’جّْوَاهڒْ‘.\f*  
\v 12 \qt \+tl ؤُڒَا ذ\+tl* إِخُورِييّنْ ثُوغَا زدّْغنْ قْبڒْ ذِي سَاعِيرْ، مَاشَا أَيْثْ ن عِيسُو كْسِينْ ڒْوَارْثْ نْسنْ ؤُشَا ثحَّانْ ثنْ زَّاثْ إِ وُوذمْ نْسنْ ؤُشَا ڭِّينْ زدّْغنْ \+tl ذِينْ\+tl* ذڭْ ومْشَانْ نْسنْ، أَمْ مَامّشْ ثُوغَا إِتّڭّْ إِسْرَائِيل س ثمُّورْثْ ن ڒْوَارْثْ نّسْ، ثنِّي إِ ذ أَسنْ إِوْشَا سِيذِي.\qt*   
\m
\v 13 ’كَّارمْ ڒخُّو، ثژْوَامْ ثغْزُورْثْ ن زَارَاذْ!‘ ؤُشَا نژْوَا ثغْزُورْثْ ن زَارَاذْ.  
\v 14 ثْمنْيَا ؤُ-ثْڒَاثِينْ ن إِسڭّْوُوسَا إِ نُويُورْ زِي قَاذَاشْ-بَارْنِيعْ أَڒَامِي نژْوَا ثَاغْزُورْثْ ن زَارَاذْ، أَڒَامِي إِقْضَا جِّيڒْ نِّي ن إِعسْكَارِييّنْ إِنِّي إِسّْننْ أَمنْغِي زِي ڒْوسْطْ ن ڒْمَارْڭحْ ن ڒْعسْكَارْ، أَمْ مَامّشْ ثُوغَا ذ أَسنْ إِجُّودْجْ سِيذِي.  
\v 15 أَمُّو إِ خَاسنْ ثُوغَا أَفُوسْ ن سِيذِي، \add حِيمَا\add* أَذْ ثنْ إِثحَّا زِي ڒْوسْطْ ن ڒْمَارْڭحْ ن ڒْعسْكَارْ أَڒَامِي قْضَانْ مَارَّا.   
\m
\v 16 ؤُمِي قْضَانْ ؤُ مُّوثنْ مَارَّا إِعسْكَارِييّنْ إِنِّي إِسّْننْ أَمنْغِي زِي ڒْوسْطْ ن ڒْڭنْسْ، إِمْسَارْ  
\v 17 أَقَا إِسِّيوڒْ أَكِيذِي سِيذِي، إِنَّا:   
\m
\v 18 ’أَسّْ-أَ أَذْ ثژْوِيذْ أَيْمِيرْ ن \add ثمُّورْثْ ن\add* مُوآبَ، غَارْ \add ثنْذِينْثْ ن\add* عَارْ.  
\v 19 أَذْ د-ثْقَارّْبذْ غَارْ ؤُرنْذَاذْ ن أَيْثْ ن عَامُّونْ. وَارْ ثنْ تّسِّيڭّْوِيذْ شَا، وَارْ خَاسنْ تّْعذِّيذْ شَا، مِينْزِي وَارْ ذ أَومْ تِّيشغْ ڒْوَارْثْ زِي ثمُّورْثْ ن أَيْثْ ن عَامُّونْ، مِينْزِي وْشِيغْ ت ذ ڒْوَارْثْ إِ أَيْثْ ن لُوطْ.‘   
\m
\v 20 \qt ثتّْوَاحْسبْ ؤُڒَا ذ عَامُّونْ ذ إِشْثْ ن ثمُّورْثْ ن إِرَافَاوِييّنْ. ثُوغَا إِرَافَاوِييّنْ زدّْغنْ ذِينْ قْبڒْ ؤُ إِعَامُونِييّنْ قَّارنْ أَسنْ إِزَامْزُومِييّنْ.\qt*  
\v 21 \qt ثُوغَا-ثنْ ذ إِجّْ ن ڒْڭنْسْ إِمْغَارْ أَطَّاسْ، ذ أَزِيرَارْ \+tl ن وَادُّوذْ\+tl* أَمْ إِعَانَاقِييّنْ. ثُوغَا يَاردّدْجْ إِ-ثنْ سِيذِي زَّاثْ إِ وُوذمْ نّسْ ؤُ نِيثْنِي كْسِينْ ڒْوَارْثْ نْسنْ ؤُشَا زدّْغنْ ذڭْ ومْشَانْ نْسنْ.\qt*  
\v 22 \qt ثُوغَا نتَّا إِڭَّا أَمُّو عَاوذْ إِ أَيْثْ ن عِيسُو، إِنِّي ثُوغَا إِزذْغنْ ذِي سَاعِيرْ، مَاغَارْ إِثحَّا إِخُورِييّنْ زَّاثْسنْ ؤُشَا نِيثْنِي كْسِينْ ڒْوَارْثْ نْسنْ ؤُشَا زدّْغنْ ذِينْ أَڒْ أَسّْ-أَ.\qt*  
\v 23 \qt ؤُشَا إِكَافْثُورِييّنْ نِّي ثُوغَا إِفّْغنْ زِي كَافْثُورْ، ثحَّانْ إِعَاوِييّنْ، إِنِّي ثُوغَا إِزدّْغنْ ذِي ذْشُورَاثْ أَڒْ غَازَّا، ؤُشَا نِيثْنِي ڭِّينْ أَذْ \+tl ذِينْ\+tl* زذْغنْ أَڒْ أَسّْ-أَ.\qt*   
\m
\v 24 ’كَّارمْ، فسْيمْ \add إِقِيضَانْ نْومْ\add* ؤُشَا ژْوَامْ ثَاغْزُورْثْ \add ن ثغْزَارْثْ\add* ن أَرْنُونْ. خْزَارْ، وْشِيغْ سِيحُونْ، أَجدْجِيذْ ن حَاشْبُونْ، أَمُورِي، ذ ثمُّورْثْ نّسْ ذڭْ إِفَاسّنْ نْومْ. بْذَا أَذْ ت ثكْسِيذْ ؤُشَا ثَاذْفذْ أَكِيذسْ غَارْ ڭَارَّا.  
\v 25 أَسّْ-أَ أَذْ بْذِيغْ أَذْ أَرّغْ ثِيڭّْوُوذِي ذ ڒْعُورّثْ زَّايكْ خْ \add مَارَّا\add* ڒڭْنُوسْ سَاذُو أَجنَّا مَارَّا، إِنِّي إِ خَاكْ غَا إِسْڒنْ ڒخْبَارْ ؤُشَا أَذْ أَرْجِيجنْ ؤُ أَذْ قْذِيدّْسنْ زَّاثكْ.‘  
\v 26 \add خنِّي\add* سّكّغْ إِرقَّاسنْ زِي ڒخْڒَا ن قَاذِيمُوثْ غَارْ سِيحُونْ، أَجدْجِيذْ ن حَاشْبُونْ س وَاوَاڒنْ ن ڒهْنَا، نِّيغْ: \x ◘ \xo 2:‏26 \xt ڒخْڒ. 21‏:‏21؛ ڒقض. 11‏:‏19\x*  
\v 27 ’أَذْ كّغْ خْ ثمُّورْثْ نّشْ ذ أَبْرِيذْ، خْ وبْرِيذْ أَذْ رَاحغْ. وَارْ هيّْضغْ خْ \add وبْرِيذْ\add* \add غَارْ\add* يفُوسْ ؤُڒَا \add غَارْ\add* ؤُزڒْمَاضْ. \x ◘ \xo 2:‏27 \xt ڒخْڒ. 21‏:‏21، 22\x*  
\v 28 أَذْ أَيِي ثزّنْزذْ مَاشَّا إِ نُّوقَارْثْ حِيمَا أَذْ شّغْ، أَمَانْ أَذْ أَيِي ثنْ ثوْشذْ إِ نُّوقَارْثْ حِيمَا أَذْ سْوغْ. أَذْ ژْوِيغْ خْ إِضَارنْ إِنُو وَاهَا  
\v 29 - أَمْ مَامّشْ ذ أَيِي سَارّْحنْ أَيْثْ ن عِيسُو نِّي إِزدّْغنْ ذِي سَاعِيرْ ذ أَيْثْ ن مُوآبَ نِّي إِزدّْغنْ ذِي عَارْ - أَڒَامِي غَا ژْوِيغْ لْ-ؤُرْذُونْ غَارْ ثمُّورْثْ إِ ذ أَنغْ غَا إِوْشْ سِيذِي، أَربِّي نّغْ.‘   
\m
\v 30 \add مَاشَا\add* سِيحُونْ، أَجدْجِيذْ ن حَاشْبُونْ وَارْ إِخْسْ أَذْ أَنغْ يجّْ أَذْ ت نژْوَا، مِينْزِي سِيذِي، أَربِّي نّشْ، إِسّقْسَاحْ بُوحْبڒْ نّسْ، ؤُ إِسّقْسَاحْ ؤُڒْ نّسْ حِيمَا أَذْ ث إِسلّمْ ذڭْ إِفَاسّنْ نّشْ، أَمْ \add ثدْجَا\add* أَسّْ-أَ.  
\v 31 ؤُشَا إِنَّا أَيِي سِيذِي: ’خْزَارْ، نشّْ بْذِيغْ أَذْ سلّْمغْ سِيحُونْ ذ ثمُّورْثْ نّسْ غَاركْ. بْذَا أَذْ ت ثكْسِيذْ حِيمَا أَذْ ثْوَارْثذْ ثَامُّورْثْ نّسْ.‘  
\v 32 \add خنِّي\add* إِفّغْ-د سِيحُونْ غَارْ ؤُمْسَاڭَارْ أَكِيذْنغْ، نتَّا أَكْ-ذ مَارَّا ڒْڭنْسْ نّسْ، إِ ڭَارَّا ذِي يَاهَاصْ. \x ◘ \xo 2:‏32 \xt ڒخْڒ. 21‏:‏23\x*  
\v 33 سِيذِي، أَربِّي نّغْ، إِسلّمْ أَنغْ ث ؤُشَا نَارْنِي ث، نتَّا ذ إِحنْجِيرنْ نّسْ ذ مَارَّا ڒْڭنْسْ نّسْ. \x ◘ \xo 2:‏33 \xt أَعَوذ. 29‏:‏6\x*  
\v 34 نكْسِي مَارَّا ثِيندَّامْ نّسْ ؤُشَا نْحَارّمْ كُوڒْ ثَانْذِينْثْ \add إِ ؤُثحِّي\add*، إِرْيَازنْ ذ ثمْغَارِينْ ذ إِحنْجِيرنْ، وَارْ نجِّي أَذْ إِقِّيمْ ؤُڒَا ذ إِجّْ ن ؤُمَارْوڒْ.  
\v 35 مْغِيرْ ڒبْهَايمْ ذ مِينْ إِتّْوَاكشّْضنْ زِي ثْندَّامْ أَقَا نكْسِي أَيَا ذ ثْكشَّاضْثْ إِ يِيخفْ نّغْ.  
\v 36 زِي أَرُوعِيرْ نِّي يدْجَانْ غَارْ ثْمَا ن ثغْزَارْثْ ن أَرْنُونْ، ؤُ \add زِي\add* ثنْذِينْثْ نِّي \add يدْجَانْ\add* ذِي ثغْزُورْثْ أَڒْ جِيلْعَاذْ، وَارْ ذِينْ ثُوغِي ؤُڒَا ذ إِشْثْ ن ثنْذِينْثْ ثُوعْڒَا خَانغْ عَاذْ. سِيذِي، أَربِّي نّغْ، إِسلّمْ أَنغْ مَارَّا. \x ◘ \xo 2:‏36 \xt ڒخْڒ. 21‏:‏5؛ ياش. 13‏:‏9، 16؛ 2 صم. 24‏:‏5\x*  
\v 37 مَاشَا شكْ وَارْ د-ثْقَارّْبذْ شَا غَارْ ثمُّورْثْ ن أَيْثْ ن عَامُّونْ، مَارَّا مِينْ ثُوغَا غَارْ ثْمَا ن ثغْزَارْثْ ن يَابُّوقْ ذ ثْندَّامْ خْ إِذُورَارْ، ؤُ وَارْ د-ثْقَارّْبذْ شَا غَارْ ؤُڒَا ذ إِشْثْ ن \add ثمُّورْثْ\add* إِ ذ أَنغْ إِحَارّمْ سِيذِي.“   
\b  
\b  
\m  
\c 3
\m
\v 1 ”\add خنِّي\add* نذْوڒْ-د ؤُشَا نْڭعّذْ أَبْرِيذْ ن بَاشَانْ. إِفّغْ-د عُوجْ، أَجدْجِيذْ ن بَاشَانْ، إِ ؤُمْسَاڭَارْ أَكِيذْنغْ، نتَّا ذ مَارَّا ڒْڭنْسْ نّسْ، إِ ڭَارَّا ذِي إِذْرَاعِي. \x ◘ \xo 3:‏1 \xt ڒخْڒ. 21‏:‏33؛ أَعَوذ. 29‏:‏6\x*  
\v 2 \add خنِّي\add* إِنَّا أَيِي سِيذِي: ’وَارْ زَّايسْ تّڭّْوذْ شَا، مِينْزِي سلّْمغْ ث، نتَّا ذ مَارَّا ڒْڭنْسْ نّسْ ذ ثمُّورْثْ نّسْ، غَارْ إِفَاسّنْ نّشْ ؤُشَا أَذْ زَّايسْ ثڭّذْ أَمْ مَامّشْ ثڭِّيذْ س سِيحُونْ، أَجدْجِيذْ ن إِمُورِييّنْ نِّي ثُوغَا إِزدّْغنْ ذِي حَاشْبُونْ.‘ \x ◘ \xo 3:‏2 \xt ڒخْڒ. 21‏:‏34\x*  
\v 3 ؤُشَا سِيذِي، أَربِّي نّغْ، إِسلّمْ عُوجْ، أَجدْجِيذْ ن بَاشَانْ ذ مَارَّا ڒْڭنْسْ نّسْ غَارْ إِفَاسّنْ نّغْ ؤُشَا نَارْنِييْ ث أَڒْ مَانِي وَارْ نجِّي أَذْ إِقِّيمْ ؤُڒَا ذ إِجّْ ن ؤُمَارْوڒْ.  
\v 4 ذِي ڒْوقْثْ نِّي نطّفْ مَارَّا ثِيندَّامْ. وَارْ ذِينْ ثُوغِي ؤُڒَا ذ إِشْثْ ن ثنْذِينْثْ وَارْ زَّايْسنْ ت نطِّيفْ: ستِّينْ ن ثْندَّامْ ذ مَارَّا جِّيهثْ ن أَرْجُوبْ، ثَاڭلْذِيثْ ن عُوجْ ذِي بَاشَانْ.  
\v 5 مَارَّا ثِيندَّامْ نِّي تّْوَافَارْينْثْ س ڒحْيُوضْ ذ ثِيوُّورَا ذ إِزكْرُوننْ. سنّجْ إِ ؤُيَا \add ثُوغَا ذِينْ\add* أَطَّاسْ ن ثْندَّامْ ذڭْ إِيَّارنْ.  
\v 6 ؤُشَا نْحَارّمْ إِ-ثنْثْ \add إِ ؤُثحِّي\add*، أَمْ مَامّشْ نڭَّا زِي سِيحُونْ، أَجدْجِيذْ ن حَاشْبُونْ. ذِي كُوڒْ ثَانْذِينْثْ أَقَا نْحَارّمْ إِرْيَازنْ ذ ثمْغَارِينْ ذ إِحنْجِيرنْ \add إِ ؤُثحِّي\add*.  
\v 7 \add مَاشَا\add* نكْسِي إِ يِيخفْ نّغْ مَارَّا ڒبْهَايمْ ذ مِينْ إِقِّيمنْ ذ ثَاكشَّاضْثْ زِي ثِيندَّامْ.  
\v 8 أَمُّو إِ نطّفْ ذِي ڒْوقْثْ نِّي ثَامُّورْثْ زِي ثْنَاينْ ن إِجدْجِيذنْ ن إِمُورِييّنْ نِّي إِدْجَانْ خْ ؤُجمَّاضْ ن لْ-ؤُرْذُونْ، زِي ثغْزَارْثْ ن أَرْنُونْ أَڒْ أَذْرَارْ ن حَارْمُونْ  
\v 9 - ثنِّي ؤُمِي قَّارنْ إِصَايْذُونِييّنْ س يِيسمْ ن هِيرْمُونْ سِيرْيُونْ ؤُ إِمُورِييّنْ قَّارنْ أَسْ سِينِيرْ -  
\v 10 مَارَّا ثِيندَّامْ ن ڒْوَاطَا \add يُوعْڒَانْ\add* ذ مَارَّا جِيلْعَاذْ ذ مَارَّا بَاشَانْ أَڒْ سَالْخَا ذ إِذْرَاعِي، \add مَارَّا\add* ثِيندَّامْ ن ثْڭلْذِيثْ ن عُوجْ ذِي بَاشَانْ.  
\v 11 مِينْزِي مْغِيرْ عُوجْ، أَجدْجِيذْ ن بَاشَانْ، ثُوغَا إِقِّيمْ زِي مِينْ إِقِّيمنْ ن إِرَافَاوِييّنْ. خْزَارْ، قَامَا نّسْ ذ إِشْثْ ن قَامَا ن وُوزَّاڒْ، مَا وَارْ إِدْجِي ذِي رَابَّا ن أَيْثْ ن عَامُّونْ؟ ثُوزّڭَّارْثْ نّسْ ثسْعَا ن إِغَادْجنْ ؤُ ثِيرُو نّسْ أَربْعَا ن نْ إِغَادْجنْ، \add عْبَارنْ ت\add* س ؤُغِيڒْ ن إِجّْ ن ورْيَازْ.  
\v 12 ذِي ڒْوقْثْ نِّي نطّفْ ثَامُّورْثْ-أَ ذ ڒْوَارْثْ، زِي \add ثنْذِينْثْ ن\add* عَارُوعِيرْ، نِّي إِدْجَانْ غَارْ ثغْزَارْثْ ن أَرْنُونْ، ؤُڒَا ذ أَزْينْ ن إِذُورَارْ ن جِيلْعَاذْ أَكْ-ذ ثْندَّامْ نّسْ، ؤُشَا وْشِيغْ ت إِ إِرُوبِينِييّنْ ذ إِجَاذِييّنْ. \x ◘ \xo 3:‏12 \xt ڒخْڒ. 32‏:‏33\x*  
\v 13 مِينْ إِقِّيمنْ ن جِيلْعَاذْ ذ مَارَّا بَاشَانْ، ثَاڭلْذِيثْ ن عُوجْ، وْشِيغْ ت إِ وزْينْ ن ثقْبِيتْشْ ن مَانَاسَّا. مَارَّا جِّيهثْ ن أَرْجُوبْ أَكْ-ذ مَارَّا بَاشَانْ قَّارنْ أَسْ ثَامُّورْثْ ن إِرَافَاوِييّنْ.  
\v 14 يَا‘إِرْ، مِّيسْ ن مَانَاسَّا، إِطّفْ مَارَّا ثَامُّورْثْ ن أَرْجُوبْ أَڒْ ويْمِيرْ إِ إِدْجَانْ أَكْ-ذ إِجَاشُورِييّنْ ذ إِمَاعْكِييّنْ ؤُشَا إِڒَاغَا جّْوَايهْ نِّي س يِيسمْ نّسْ: \add جِّيهثْ ن\add* بَاشَانْ، ذْشُورَاثْ ن يَا‘إِرْ. ذ وَا \add ذ إِسمْ نْسنْ أَڒْ\add* أَسّْ-أَ.“   
\m
\v 15 ”إِ مَاكِيرْ وْشِيغْ أَسْ جِيلْعَاذْ.  
\v 16 إِ إِرُوبِينِييّنْ ذ إِجَاذِييّنْ وْشِيغْ أَسنْ \add مِينْ إِقِّيمنْ\add* ن جِيلْعَاذْ أَڒْ ثغْزَارْثْ ن أَرْنُونْ، \add أَڒْ\add* ڒْوسْطْ ن إِغْزَارْ \add نِّي إِدْجَانْ\add* ذ أَيْمِيرْ، أَڒْ ثِيغْزَارْثْ ن يَابُّوقْ \add نِّي إِدْجَانْ\add* ذ أَيْمِيرْ أَكْ-ذ أَيْثْ ن عَامُّونْ.  
\v 17 \add عَاوذْ وْشِيغْ أَسنْ\add* ڒوْضَا ذ لْ-ؤُرْذُونْ \add نِّي إِدْجَانْ\add* ذ أَيْمِيرْ زِي كِينَّارَاثْ أَڒْ ڒبْحَارْ ن ڒوْضَا، ڒبْحَارْ أَمدْجَاهْ، وَادَّايْ ن ثيْسَارِينْ \add ن وذْرَارْ ن\add* فِيسْجَا، غَارْ ؤُغزْذِيسْ ن شَّارْقْ.“ \f ◼ \fr 3:‏17 \ft \+bd ’ڒبْحَارْ أَمدْجَاحْ‘\+bd* - نِيغْ ’إِلّْ أَمدْجَاحْ‘.\f*   
\b  
\m
\v 18 ”ذِي ڒْوقْثْ نِّي وصِّيغْ كنِّيوْ، نِّيغْ: ’سِيذِي، أَربِّي نْومْ، إِوْشَا أَومْ ثَامُّورْثْ-أَ، حِيمَا أَذْ ت ثطّْفمْ ذ ڒْوَارْثْ. إِتّْخصَّا أَذْ ثژْوَامْ ثْوجْذمْ إِ ؤُمنْغِي زَّاثْ إِ أَيْثْمَاثْومْ، أَيْثْ ن إِسْرَائِيل، مَارَّا أَيْثْ ن ؤُمنْغِي. \x ◘ \xo 3:‏18 \xt ڒخْڒ. 32‏:‏20\x*  
\v 19 إِعدّڒْ أَذْ قِّيمنْ ذِي ثْندَّامْ نْومْ، ثنِّي ذ أَومْ وْشِيغْ نشّْ، مْغِيرْ ثمْغَارِينْ نْومْ ذ إِحنْجِيرنْ نْومْ ذ ڒبْهَايمْ نْومْ - أَقَا سّْنغْ بلِّي غَارْومْ أَطَّاسْ ن ڒبْهَايمْ -  
\v 20 أَڒْ غَا إِوْشْ سِيذِي أَرَّاحثْ إِ أَيْثْمَاثْومْ أَمْ مَامّشْ إِ ذ أَومْ إِوْشَا، ؤُشَا ؤُڒَا ذ نِيثْنِي أَذْ كْسِينْ ثَامُّورْثْ نِّي إِ ذ أَسنْ غَا إِوْشْ سِيذِي، أَربِّي نْومْ، ذ ڒْوَارْثْ خْ ؤُجمَّاضْ ن \add يغْزَارْ ن\add* لْ-ؤُرْذُونْ. خنِّي إِعدّڒْ أَذْ د-ثْذوْڒمْ، كُوڒْ إِجّْ غَارْ ثسْغَارْثْ إِ ذ أَومْ وْشِيغْ نشّْ \add إِ كُوڒْ إِجّنْ زَّايْومْ\add*.‘  
\v 21 ذِي ڒْوقْثْ نِّي وصِّيغْ إِ يَاشُووَا، نِّيغْ: ’ثِيطَّاوِينْ نّشْ ژْرِينْثْ مَارَّا مِينْ إِڭَّا سِيذِي، أَربِّي نْومْ، س ثْنَاينْ ن إِجدْجِيذنْ-أَ. أَمُّو إِ غَا يڭّْ سِيذِي س مَارَّا ثِيڭلْذِيوِينْ إِ غَارْ غَا ثژْوِيذْ. \x ◘ \xo 3:‏21 \xt ڒخْڒ. 27‏:‏18\x*  
\v 22 وَارْ زَّايْسنْ ثڭّْوْذمْ، مِينْزِي سِيذِي، أَربِّي نْومْ، أَذْ إِمّْنغْ ذِي طّْوعْ نْومْ.‘   
\m
\v 23 ؤُشَا ژُودْجغْ غَارْ سِيذِي ذِي ڒْوقْثْ نِّي، نِّيغْ:  
\v 24 ’سِيذِي إِنُو، سِيذِي! شكْ ثبْذِيذْ أَذْ ثسّشْنذْ إِ ؤُمْسخَّارْ نّشْ ڒمْغَارثْ نّشْ ذ ؤُفُوسْ نّشْ إِجهْذنْ، مِينْزِي مَانْ أَربِّي إِ ذِينْ ذڭْ ؤُجنَّا نِيغْ ذِي ثمُّورْثْ إِزمَّارْ أَذْ يڭّْ ڒخْذَايمْ ذ جّهْذْ أَمْ مَامّشْ ثنْ ثتّڭّذْ شكْ؟ \x ◘ \xo 3:‏24 \xt 1 صم. 2‏:‏2؛ إِزهد. 89‏:‏7، 8، 9\x*  
\v 25 أجّْ أَيِي أَذْ ژْوِيغْ، زَاوْڭغْ شكْ، ؤُشَا أَذْ ژَترْغْ ثَامُّورْثْ إِشْنَانْ، ثنِّي إِدْجَانْ خْ ؤُجمَّاضْ ن لْ-ؤُرْذُونْ، أَقَا إِذُورَارْ نِّي إِشْنَانْ ذ لُوبْنَانْ!‘  
\v 26 مَاشَا سِيذِي إِصْخضْ خَافِي \add أَفُوڭمْ نّسْ\add* ذِي طّْوعْ نْومْ ؤُشَا وَارْ ذ أَيِي إِسْڒِي. إِنَّا أَيِي سِيذِي: ’شْفَا مِينْ ذ أَيِي ثتَّارذْ، أَقَا ذ أَطَّاسْ. وَارْ كِيذِي سِّيوِيڒْ عَاذْ خْ ثْمسْڒَاشْثْ-أَ. \x ◘ \xo 3:‏26 \xt أَعَوذ. 1‏:‏37؛ 31‏:‏2؛ 34‏:‏4\x*  
\v 27 أَڒِي غَارْ ثْقِيشَّاثْ ن فِيسْجَا ؤُشَا سْڭعّذْ ثَامُوغْڒِي نّشْ غَارْ ڒْغَارْبْ، غَارْ شَّامَالْ، عَارْ لْجَانُوبْ ؤُ غَارْ شَّارْقْ ؤُ خْزَارْ \add إِ ت\add* س إِخفْ ن ثِيطَّاوِينْ نّشْ، مِينْزِي وَارْ ثْژكّْوِّيذْ شَا لْ-ؤُرْذُونْ-أَ.  
\v 28 سلّمْ \add ڒُْومُورْ\add* إِ يَاشُووَا، أڭّْ ذَايسْ ؤُڒْ ؤُ سجْهذْ إِ-ث، مِينْزِي نتَّا أَذْ إِژْوَا زَّاثْ إِ وُوذمْ ن ڒْڭنْسْ-أَ ؤُشَا نتَّا أَذْ ثنْ يَارّْ أَذْ وَارْثنْ ثَامُّورْثْ إِ غَا ثْژَارذْ \add خْ وذْرَارْ فِيسْجَا\add*.‘  
\v 29 ؤُشَا نقِّيمْ ذِي ثغْزُورْثْ زَّاثْ إِ بَايْثْ-فَاغُورْ.“   
\b  
\b  
\m  
\c 4
\s1 ڒْعَاهْذْ أَكْ-ذ سِيذِي أَربِّي  
\m
\v 1 ”خنِّي ڒخُّو، \add أَ\add* إِسْرَائِيل، سڒْ غَارْ ثْوصَّا ذ لْفَارَايِيضْ نِّي ذ أَومْ سّڒْمَاذغْ، مَاحنْذْ أَذْ \add ثنْثْ\add* ثڭّمْ حِيمَا أَذْ ثدَّارمْ ؤُشَا أَذْ ثَاذْفمْ غَارْ ثمُّورْثْ نِّي إِ ذ أَومْ غَا إِوْشْ سِيذِي، أَربِّي ن ڒجْذُوذْ نْومْ، ؤُشَا أَذْ ت ثْوَارْثمْ. \x ◘ \xo 4:‏1 \xt لَاوِي 19‏:‏37؛ 20‏:‏8؛ 22‏:‏31\x*  
\v 2 وَارْ أَرنّْيمْ غَارْ وَاوَاڒْ إِ ذ أَومْ غَا ؤُمُورغْ ؤُ وَارْ زَّايسْ تّكّْسمْ، حِيمَا أَذْ ثِيڒِيمْ ثتّطّْفمْ ذِي ثْوصَّا ن سِيذِي، أَربِّي نْومْ، ثِينِّي زِي ذ أَومْ تُّومُورغْ. \x ◘ \xo 4:‏2 \xt أَعَوذ. 13‏:‏1؛ أَوڒن. 30‏:‏6؛ أَسَا. 22‏:‏18\x*  
\v 3 ثِيطَّاوِينْ نْومْ ژْرِينْثْ مِينْ إِڭَّا سِيذِي أَكْ-ذ بَاعْلْ-فَاغُورْ، مِينْزِي \add مَارَّا\add* أَرْيَازْ نِّي إِضفَّارنْ بَاعْلْ-فَاغُورْ، أَقَا إِثحَّا إِ-ث سِيذِي، أَربِّي نْومْ، زِي ڒْوسْطْ نْومْ. \x ◘ \xo 4:‏3 \xt ڒخْڒ. 25‏:‏4؛ ياش. 22‏:‏17\x*  
\v 4 \add مَاشَا\add* كنِّيوْ، إِنِّي إِڒسّْقنْ غَارْ سِيذِي، أَربِّي نْومْ، أَقَا كنِّيوْ مَارَّا ثدَّارمْ \add عَاذْ\add* أَسّْ-أَ.  
\v 5 خْزَارمْ، نشّْ سّْڒمْذغْ أَومْ ثِيوصَّا ذ لْفَارَايِيضْ أَمْ مَامّشْ ذ أَيِي يُومُورْ سِيذِي، أَربِّي إِنُو، حِيمَا أَذْ \add زَّايْسنْثْ\add* ثڭّمْ ذِي ثمُّورْثْ إِ غَارْ غَا ثَاذْفمْ مَاحنْذْ أَذْ ت ثْوَارْثمْ.  
\v 6 طّْفمْ \add ذَايْسنْثْ\add* ؤُ ڭّمْ \add ثنْثْ\add*، مِينْزِي ثَا أَذْ ثِيڒِي ثِيغِيثْ نْومْ ذ ڒعْقڒْ نْومْ زَّاثْ إِ ثِيطَّاوِينْ ن ڒڭْنُوسْ نِّي إِ غَا إِسْڒنْ مَارَّا ثِيوصَّا-يَا. \add خنِّي\add* أَذْ إِنِينْ نِيثْنِي: ’ڒْڭنْسْ-أَ أَمقّْرَانْ وَانِيثَا ذ ثِيذتّْ ذ إِجّْ ن ڒْڭنْسْ ذ أَمِيغِيسْ ؤُ س ڒعْقڒْ!‘ \f ◼ \fr 4:‏6 \ft \+bd ’طّْفمْ ... ڭّمْ‘\+bd* - س ثْعِيبْرَانِيثْ ’طّفْ ... أڭّْ‘، أَمشْنَاوْ إِسَّاوَاڒْ نتَّا إِ يِيجّْ ورْيَازْ.\f*  
\v 7 مِينْزِي مَانْ ڒْڭنْسْ إِمْغَارنْ إِ ذَا إِدْجَانْ، أَقَا غَارسْ أَربِّي يُوذْسنْ أَمْ سِيذِي، أَربِّي نّغْ، ڒبْذَا خْمِي خَاسْ نتّْڒَاغَا؟ \x ◘ \xo 4:‏7 \xt أَعَوذ. 26‏:‏19\x*  
\v 8 ؤُ مَانْ ڒْڭنْسْ ذَا إِدْجَانْ إِمْغَارْ، أَقَا غَارسْ ثِيوصَّا ذ لْفَارَايِيضْ إِسڭّْمنْ أَمْ مَارَّا شَّارِيعَا-يَا نِّي ذ أَومْ غَا وْشغْ أَسّْ-أَ؟   
\m
\v 9 مَاشَا حْضَا خْ يِيخفْ نّشْ ؤُشَا طّفْ نِيشَانْ أَشْبَارْ خْ ڒعْمُورْ نّشْ حِيمَا وَارْ ثتُّوذْ مِينْ ژْرِينْثْ ثِيطَّاوِينْ نّشْ ؤُ حِيمَا \add ثِيمسْڒَايِينْ-أَ\add* وَارْ د-تّفِّيغنْثْ شَا زڭْ وُوڒَاونْ نّشْ. إِتّْخصَّا أَذْ ثنْثْ ثسَّارْڭْبذْ إِ إِحنْجِيرنْ نّشْ ؤُ إِ إِحنْجِيرنْ ن إِحنْجِيرنْ نّشْ. \x ◘ \xo 4:‏9 \xt أَعَوذ. 6‏:‏7؛ 11‏:‏19\x*   
\m
\v 10 أَسّْ مِينْ ذِي ثُوغَا ثْبدّذْ غَارْ \add وذْرَارْ ن\add* حُورِيبْ زَّاثْ إِ وُوذمْ ن سِيذِي، أَربِّي نّشْ، ڒَامِي ذ أَيِي إِنَّا سِيذِي: ’سْمُونْ غَارِي ڒْڭنْسْ-أَ، \add خنِّي\add* نشّْ أَذْ ثنْ أَرّغْ أَذْ سْڒنْ أَوَاڒنْ إِنُو مَاحنْذْ أَذْ ثنْ سّْڒمْذنْ حِيمَا أَذْ زَّايِي ڭّْوذنْ مَارَّا ؤُسَّانْ نِّي إِدَّارنْ ذِي ثمُّورْثْ ؤُشَا \add حِيمَا\add* أَذْ \add ثنْ\add* سّْڒمْذنْ إِ إِحنْجِيرنْ نْسنْ.‘  
\v 11 \add خنِّي\add* ثْقَارّْبمْ-د كنِّيوْ ؤُشَا ثْبدّمْ غَارْ إِضَارنْ ن وذْرَارْ ؤُشَا أَذْرَارْ يَارْغَا أَڒَامِي ثِيمسِّي نّسْ \add ثِيوضْ\add* غَارْ ڒْوسْطْ ن ؤُجنَّا، \add ؤُشَا أَقَا ذِينْ\add* ثَادْجسْثْ ذ إِسيْنُوثنْ ذ يِيجّْ ن ؤُسيْنُو إِبُّومْبسْ. \f ◼ \fr 4:‏11 \ft \+bd ’غَارْ إِضَارنْ‘\+bd* - س ثْعِيبْرَانِيثْ ’سَاذُو‘. \+bd ’غَارْ ڒْوسْثْ‘\+bd* - س ثْعِيبْرَانِيثْ ’غَارْ وُوڒْ‘.\f*  \x ◘ \xo 4:‏11 \xt ؤُف. 19‏:‏18\x*   
\m
\v 12 \add خنِّي\add* إِسِّيوڒْ أَكِيذْومْ سِيذِي زِي ڒْوسْطْ ن ثْمسِّي. كنِّيوْ ثسْڒِيمْ إِ ڒْحسّْ ن وَاوَاڒنْ، \add مَاشَا\add* وَارْ ثژْرِيمْ شَا أَدُّوذْ \add نّسْ\add*، مْغِيرْ إِشْثْ ن ثْمِيجَّا \add ؤُمِي ثسْڒِيمْ\add* وَاهَا.  
\v 13 نتَّا إِسَّارْڭبْ كنِّيوْ خْ ڒْعَاهْذْ نّسْ، ونِّي يُومُورْ أَذْ ث ثڭّمْ،عشْرَا ن وَاوَاڒنْ. يُورَا ثنْ ذِي ثْنَاينْ ن ثڒْوِيحِينْ ن وژْرُو.  
\v 14 إِ نشّْ \add عَاوذْ\add* يُومُورْ سِيذِي ذِي ڒْوقْثْ نِّي مَاحنْذْ أَذْ كنِّيوْ سّْڒمْذغْ ثِيوصَّا ذ لْفَارَايِيضْ مَاحنْذْ أَذْ زَّايْسنْثْ ثڭّمْ ذِي ثمُّورْثْ إِ غَارْ غَا ثژْوَامْ حِيمَا أَذْ ت ثْوَارْثمْ.“   
\m
\v 15 ”حْضَامْ نِيشَانْ خْ ڒعْمُورْ نْومْ، مِينْزِي كنِّيوْ وَارْ ثژْرِيمْ ؤُڒَا ذ إِجّْ ن وَادُّوذْ ذڭْ وَاسّْ ؤُمِي أَكِيذْومْ إِسِّيوڒْ سِيذِي \add خْ وذْرَارْ ن\add* حُورِيبْ زِي ڒْوسْطْ ن ثْمسِّي!  
\v 16 وَارْ تّسّفْسَاذمْ \add إِخفْ نْومْ\add* ؤُمِي غَا ثڭّمْ إِ يِيخفْ نْومْ إِجّْ ن ڒخْيَاڒْ إِنقْشنْ، أَدُّوذْ ن شَا ن إِجّْ ن صَّانَامْ، أَدُّوذْ ن شَا ن إِجّْ ن ووْثمْ نِيغْ ن إِشْثْ ن ثوْثمْثْ،  
\v 17 إِجّْ ن ڒخْيَاڒْ ن شَا ن إِجّْ ن ؤُمُودَّارْ نِّي \add إِدْجَانْ\add* خْ ثمُّورْثْ، \add نِيغْ\add* إِجّْ ن ڒخْيَاڒْ ن شَا ن إِجّْ ن وجْضِيضْ س وفْرِيونْ إِ إِطَّاونْ ذڭْ ؤُجنَّا،  
\v 18 \add نِيغْ\add* إِجّْ ن ڒخْيَاڒْ ن شَا ن إِجّْ \add ن ؤُمُودَّارْ\add* نِّي إِتّْبُوعنْ خْ ثمُّورْثْ، \add نِيغْ\add* إِجّْ ن ڒخْيَاڒْ ن شَا ن إِجّْ ن وسْڒمْ نِّي إِدْجَانْ ذڭْ وَامَانْ سَاذُو ثمُّورْثْ.  
\v 19 غَاركْ أَذْ ثسّْڭعّْذذْ ثَامُوغْڒِي نّشْ غَارْ ؤُجنَّا ؤُشَا \add خنِّي\add* أَذْ ثْژَارذْ ثَافُوشْثْ ذ ؤُيُورْ ذ إِثْرَانْ، مَارَّا ڒْعسْكَارْ ن ؤُجنَّا، ؤُشَا \add خنِّي\add* أَذْ تّْوَاعَارّْنذْ أَذْ أَسنْ ثْبنْذْقذْ ؤُشَا أَذْ أَسنْ ثْعبْذذْ إِ نِيثْنِي، إِنِّي إِبْضَا سِيذِي، أَربِّي نّشْ، إِ مَارَّا ڒڭْنُوسْ سَاذُو مَارَّا أَجنَّا.  
\v 20 سِيذِي أَقَا إِقْبڒْ إِ كنِّيوْ ؤُشَا إِسُّوفّغْ إِ كنِّيوْ-د زڭْ ؤُفَارَّانْ ن وُوزَّاڒْ، زِي مِيصْرَا، حِيمَا أَذْ أَسْ ثِيڒِيمْ ذ ڒْڭنْسْ نّسْ إِ إِوَارْثْ، أَمْ \add ثدْجَا\add* أَسّْ-أَ. \x ◘ \xo 4:‏20 \xt ؤُف. 19‏:‏5\x*  
\v 21 عَاوذْ إِسْعَارْ خَافِي سِيذِي ذِي سِّيبّثْ ن وَاوَاڒنْ نْومْ ؤُشَا إِجُّودْجْ بلِّي وَارْ ژكّْوِّيغْ شَا لْ-ؤُرْذُونْ ؤُ وَارْ تِّيذْفغْ غَارْ ثمُّورْثْ إِصبْحنْ نِّي إِ ذ أَشْ غَا إِوْشْ سِيذِي، أَربِّي نّشْ، ذ ڒْوَارْثْ، \x ◘ \xo 4:‏21 \xt أَعَوذ. 1‏:‏37؛ 3‏:‏26؛ 31‏:‏2؛ 34‏:‏4\x*  
\v 22 مِينْزِي نشّْ أَذْ مّْثغْ ذِي ثمُّورْثْ-أَ، وَارْ ژكّْوِيغْ شَا لْ-ؤُرْذُونْ. كنِّيوْ أَذْ ثژْوَامْ ؤُشَا أَذْ ثطّْفمْ ثَامُّورْثْ-أَ إِشْنَانْ.  
\v 23 حْضَامْ وَارْ ثتُّومْ ڒْعَاهْذْ ن سِيذِي، أَربِّي نْومْ، ونِّي إِڭَّا أَكِيذْومْ ؤُشَا \add حْضَامْ\add* وَارْ تّڭّمْ إِ يِيخفْ نْومْ إِجّْ ن ڒخْيَاڒْ إِنقْشنْ زِي شَا ن \add ن ڒْحَاجّثْ\add* إِ ذ أَشْ إِحَارّمْ سِيذِي، أَربِّي نّشْ.  
\v 24 مِينْزِي سِيذِي، أَربِّي نّشْ، أَقَا-ث ذ إِشْثْ ن ثْمسِّي إِتّتّنْ، ذ إِجّْ ن أَربِّي إِتَّاسْمنْ. \x ◘ \xo 4:‏24 \xt ؤُف. 20‏:‏5؛ 34‏:‏14؛ أَعَوذ. 5‏:‏9؛ 6‏:‏15؛ 9‏:‏3؛ عبر.12‏:‏29 \x*   
\m
\v 25 خْمِي غَا ثَارْومْ أَرَّاوْ ذ أَيَّاونْ ؤُشَا أَذْ ثوْسَارمْ ذِي ثمُّورْثْ ؤُشَا \add خنِّي\add* أَذْ ثْذدْجْممْ \add إِخفْ نْومْ\add*، أَذْ ثڭّمْ إِجّْ ن ڒخْيَاڒْ إِنقْشنْ، صِّيفّثْ ن شَا ن ڒْحَاجّثْ ؤُشَا أَذْ ثڭّمْ ڒْغَارْ ذِي ثِيطَّاوِينْ ن سِيذِي، أَربِّي نْومْ ؤُمِي ث غَا ثسْعَارمْ \add أَمُّو\add*،  
\v 26 \add خنِّي\add* نشّْ أَسّْ-أَ أَذْ ڒَاغِيغْ خْ ؤُجنَّا ذ ثمُّورْثْ ذ ڒشْهُوذْ خَاومْ، أَقَا كنِّيوْ أَذْ ثتّْوَاهلّْكمْ ذغْيَا س ثِيذتّْ ذِي ثمُّورْثْ إِ غَارْ غَا ثژْوَامْ خْ لْ-ؤُرْذُونْ مَاحنْذْ أَذْ ت ثكْسِيمْ ذ ڒْوَارْثْ. وَارْ ذَايسْ ثتّْغِيمِيمْ كنِّيوْ شَا ن وُوسَّانْ كْثَارْ عَاذْ، مِينْزِي أَذْ ثتّْوَاثحَّامْ قَاعْ.  
\v 27 سِيذِي أَذْ كنِّيوْ إِبزّعْ جَارْ ڒڭْنُوسْ ؤُشَا أَذْ زَّايْومْ إِقِّيمْ إِجّْ ن وُورُو ن يرْيَازنْ \add وَاهَا\add* جَارْ ڒڭْنُوسْ مَانِي كنِّيوْ غَا إِنْذهْ سِيذِي. \x ◘ \xo 4:‏27 \xt أَعَوذ. 28‏:‏62، 64\x*  
\v 28 ذِينْ أَذْ ثْسخَّارمْ إِربِّيثنْ نِّي إِتّْوَاڭّنْ س إِفَاسّنْ ن بْنَاذمْ س ؤُكشُّوضْ ذ وژْرُو، إِنِّي وَارْ إِتّْوَاڒِينْ، وَارْ إِتّسْڒِينْ، وَارْ إِتّتّنْ ؤُ وَارْ إِتّْشمَّانْ.“\x ◘ \xo 4:‏28 \xt إِزهد. 115‏:‏4؛ 135‏:‏15\x*   
\m
\v 29 ”أَذْ ثَارْزُومْ سّنِّي سِيذِي، أَربِّي نّشْ، ؤُ شكْ أَذْ ث ثَافذْ، مَاڒَا ثَارزُّوذْ خَاسْ س مَارَّا ؤُڒْ نّشْ ذ مَارَّا ڒعْمَارْ نّشْ. \f ◼ \fr 4:‏29 \ft \+bd ’سّنِّي‘\+bd* - نِيغْ ’زِي سنِّي‘.\f*  
\v 30 مَاڒَا شكْ ذِي ڒحْصَارثْ ؤُشَا أَذْ غَاركْ د-أَسنْ مَارَّا أَوَاڒنْ-أَ ذڭْ ؤُنڭَّارْ ن وُوسَّانْ، \add خنِّي\add* أَذْ د-ثْذوْڒذْ غَارْ سِيذِي، أَربِّي نّشْ، ؤُ أَذْ ثسْڒذْ إِ ثْمِيجَّا نّسْ،  
\v 31 مِينْزِي سِيذِي، أَربِّي نّشْ، ذ إِجّْ ن أَربِّي يَارحّْمنْ، وَارْ شكْ إِتّجِّي ؤُ وَارْ شكْ إِتَّاردّدْجْ. وَارْ إِتّتُّو ڒْعَاهْذْ ن ڒجْذُوذْ نّشْ، ونِّي ذ أَسنْ إِجِّيدْجْ.  
\v 32 سقْسَا خنِّي خْ وُوسَّانْ إِعْذُونْ، إِنِّي إِدْجَانْ قْبڒْ إِ شكْ، زڭْ وَاسّْ مِينْ ذِي إِڭَّا أَربِّي بْنَاذمْ خْ ثمُّورْثْ، \add سقْسَا\add* زِي طَّارْفْ ن ؤُجنَّا غَارْ طَّارْفْ نّغْنِي ن ؤُجنَّا، مَا \add عمَّارْصْ\add* ثمْسَارْ شَا ن ڒْحَاجّثْ ثمْغَارْ أَنشْثْ ن ثَانِيثَا نِيغْ إِتّْوَاسڒْ \add شَا\add* أَمْ مَانْ أَيَا؟  
\v 33 مَا \add عمَّارْصْ\add* إِسْڒَا شَا ن ڒْڭنْسْ ثْمِيجَّا ن أَربِّي ثسِّيوڒْ زِي ڒْوسْطْ ن ثْمسِّي أَمْ مَامّشْ ت تّسْڒِيذْ شكْ ؤُشَا \add خنِّي إِقِّيمْ\add* إِدَّارْ؟  
\v 34 نِيغْ مَا إِقدْجبْ \add عمَّارْصْ\add* إِجّْ ن أَربِّي أَذْ د-يَاسْ مَاحنْذْ أَذْ إِكْسِي إِ يِيخفْ نّسْ إِجّْ ن ڒْڭنْسْ زِي ڒْوسْطْ ن إِجّْ ن ڒْڭنْسْ \add نّغْنِي\add* س ثْجَارِّيبِينْ، س ڒعْڒَامَاثْ، س لْمُوعْجِيزَاثْ، س ؤُمنْغِي، س ؤُفُوسْ إِجهْذنْ، س ؤُغِيڒْ إِسّْوِيژّْضنْ ؤُ س ثْمڭَّا سِّيڭّْوِيذنْثْ مْغَارنْثْ، أَمْ مَارَّا مِينْ إِڭَّا سِيذِي، أَربِّي نْومْ، زَّاثْ إِ ثِيطَّاوِينْ نْومْ ذِي مِيصْرَا؟  
\v 35 أَقَا إِ شكْ ؤُمِي د-إِتّْوَاسّْبَانْ أَيَا، حِيمَا أَذْ ثسّْنذْ بلِّي سِيذِي ذ أَربِّي \add إِ إِدْجَا\add*. وَارْ ذِينْ شَا نّغْنِي مْغِيرْ نتَّا.\x ◘ \xo 4:‏35 \xt أَعَوذ. 32‏:‏39؛ إِشا. 45‏:‏5، 18، 22؛ مك.12‏:‏29، 32\x*  
\v 36 زڭْ ؤُجنَّا إِڭَّا أَذْ ثسْڒذْ إِ ثْمِيجَّا نّسْ حِيمَا أَذْ شكْ إِنبّهْ ؤُ خْ ثمُّورْثْ أَقَا إِسّْشنْ أَشْ ثِيمسِّي نّسْ إِمْغَارنْ ؤُ أَقَا ثسْڒِيذْ أَوَاڒنْ نّسْ زِي ڒْوسْطْ ن ثْمسِّي.  
\v 37 مِينْزِي نتَّا ثُوغَا إِخْسْ ڒجْذُوذْ نّشْ، ؤُ إِفَارْزْ زَّارِيعثْ نّسْ أَوَارْنِي أَسْ، أَقَا إِسُّوفّغْ إِ شكْ-د س يِيخفْ نّسْ زِي مِيصْرَا س جّهْذْ نّسْ إِمْغَارنْ \x ◘ \xo 4:‏37 \xt ؤُف. 13‏:‏3، 9، 14\x*  
\v 38 حِيمَا أَذْ يَاژّڒْ زَّاثْ إِ وُوذمْ نّشْ خْ ڒڭْنُوسْ إِمْغَارنْ ذ يِينِّي خَاكْ إِجهْذنْ زِي ثصْغَارْثْ نْسنْ، ؤُ \add حِيمَا\add* أَذْ ذَايسْ إِسِّيذفْ شكْ ؤُ أَذْ أَشْ إِوْشْ ثَامُّورْثْ نْسنْ ذ ڒْوَارْثْ، أَمْ مَامّشْ \add إِ ثدْجَا\add* أَسّْ-أَ.  
\v 39 \add خنِّي\add* سّنْ أَسّْ-أَ ؤُشَا خَارّصْ \add خْ مَانْ أَيَا\add* ذڭْ وُوڒْ نّشْ بلِّي سِيذِي ذ أَربِّي إِ يدْجَا، سنّجْ ذڭْ ؤُجنَّا ؤُ سْوَادَّايْ ذِي ثمُّورْثْ، وَارْ ذِينْ حذْ نّغْنِي!  
\v 40 طّفْ ذِي ثْوصَّا نّسْ ؤُ ذِي ڒُومُورَاثْ نّسْ، ثِينِّي ذ أَشْ ؤُمُورغْ أَسّْ-أَ حِيمَا أَذْ إِفّغْ ؤُمدُّورْ مْلِيحْ إِ شكْ ؤُ إِ إِحنْجِيرنْ نّشْ أَوَارْنِي أَشْ ؤُشَا أَذْ زُّوڭَارْثنْ ؤُسَّانْ ذِي ثمُّورْثْ إِ ذ أَشْ غَا إِوْشْ سِيذِي، أَربِّي نّشْ، إِ ڒبْذَا.“   
\m
\v 41 خنِّي إِفَارْزْ مُوسَا \bd ثْڒَاثَا ن ثْندَّامْ \+bdit ن ثَاروْڒَا\+bdit* خْ ؤُجمَّاضْ ن لْ-ؤُرْذُونْ\bd* مَانِيسْ د-ثْنقَّارْ ثْفُوشْثْ، \x ◘ \xo 4:‏41 \xt ڒخْڒ. 35‏:‏6، 14\x*  
\v 42 حِيمَا أَذْ ذِينْ يَاڒْورْ ؤُقتَّاڒْ نِّي إِنْغِينْ، بْڒَا مَا أَذْ أَسْ إِڭّْ ڒحْسَابْ، جَّارْ نّسْ، ونِّي ؤُمِي وَارْ إِشَارّْهنْعمَّارْصْ \add إِضنَّاضْ ؤُڒَا ذ فَارِيضنَّاضْ\add*. وَانِيثَا إِزمَّارْ أَذْ يَارْوڒْ غَارْ إِشْثْ زِي ثْندَّامْ-أَ أَڒَامِي \add إِقِّيمْ\add* إِدَّارْ نتَّا.  
\v 43 بَاصِيرْ ذِي ڒخْڒَا، ذِي ڒْوَاطَا \add يُوعْڒَانْ\add*، إِ رُوبِينِييّنْ، ؤُ رَامُوثْ ذِي جِيلْعَاذْ إِ إِجَاذِييّنْ ؤُ جُولَانْ ذ بَاشَانْ إِ إِمَانَاسِّييّنْ. \x ◘ \xo 4:‏43 \xt ياش. 20‏:‏8\x*   
\m
\v 44 ثَا ذ شَّارِيعَا نِّي إِڭَّا مُوسَا زَّاثْ إِ أَيْثْ ن إِسْرَائِيل.  
\v 45 إِنَا ذ شّْهَاذَاثْ ذ ثِيوصَّا ذ لْفَارَايِيضْ نِّي إِسِّيوڒْ مُوسَا غَارْ أَيْثْ ن إِسْرَائِيل ؤُمِي د-فّْغنْ زِي مِيصْرَا.  
\v 46 \add أَيَا ثُوغَا\add* خْ ؤُجمَّاضْ ن لْ-ؤُرْذُونْ، ذِي ثغْزُورْثْ أَرنْذَاذْ ن بَايْثْ-فَاغُورْ، ذِي ثمُّورْثْ ن سِيحُونْ، أَجدْجِيذْ ن إِمُورِييّنْ، ونِّي ثُوغَا إِزدّْغنْ ذِي حَاشْبُونْ، ونِّي خْ إِغْڒبْ مُوسَا أَكْ-ذ أَيْثْ ن إِسْرَائِيل ؤُمِي د-فّْغنْ زِي مِيصْرَا. \x ◘ \xo 4:‏46 \xt ڒخْڒ. 21‏:‏24؛ أَعَوذ. 1‏:‏4 \x*  
\v 47 \add أَقَا\add* كْسِينْ ثَامُّورْثْ نّسْ أَمْ ڒْوَارْثْ ؤُڒَا ذ ثَامُّورْثْ ن عُوجْ، أَجدْجِيذْ ن بَاشَانْ، \add ثِيمُّورَا ن\add* ثْنَاينْ ن إِجدْجِيذنْ ن إِمُورِييّنْ نِّي \add ثُوغَا زدّْغنْ\add* خْ ؤُجمَّاضْ ن لْ-ؤُرْذُونْ مَانِيسْ د-ثْنقَّارْ ثْفُوشْثْ، \x ◘ \xo 4:‏47 \xt ڒخْڒ. 21‏:‏33؛ أَعَوذ. 3‏:‏3\x*  
\v 48 زِي عَارُوعِيرْ نِّي إِدْجَانْ غَارْ ثْمَا ن ثغْزَارْثْ ن أَرْنُونْ أَڒْ وذْرَارْ ن سِييُونْ نِّي إِدْجَانْ ذ \add وذْرَارْ ن\add* حِيرْمُونْ،  
\v 49 ذ مَارَّا ڒوْضَا خْ ؤُجمَّاضْ ن لْ-ؤُرْذُونْ، غَارْ شَّارْقْ، أَڒْ ڒبْحَارْ ن ڒوْضَا نِّي \add إِدْجَانْ\add* وَادَّايْ ن ثيْسَارِينْ \add ن وذْرَارْ ن\add* فِيسْجَا.   
\b  
\b  
\m  
\c 5
\m
\v 1 إِڒَاغَا مُوسَا إِ مَارَّا إِسْرَائِيل ؤُشَا إِنَّا أَسنْ: ”سْڒمْ، أَ إِسْرَائِيل، إِ ثْوصَّا ذ لْفَارَايِيضْ، ثِينِّي إِ خفْ سِّيوْڒغْ نشّْ أَسّْ-أَ ذڭْ إِمزُّوغنْ نْومْ، حِيمَا أَذْ ثنْثْ ثْڒمْذمْ ؤُ أَذْ ثنْثْ ثحْضَامْ مَاحنْذْ أَذْ زَّايْسنْثْ ثڭّمْ.  
\v 2 سِيذِي، أَربِّي نّغْ، إِڭَّا إِجّْ ن ڒْعَاهْذْ أَكِيذْنغْ ذِي حُورِيبْ. \x ◘ \xo 5:‏2 \xt ؤُف. 19‏:‏5\x*  
\v 3 وَارْ إِدْجِي أَكْ-ذ ڒجْذُوذْ نّغْ إِ إِڭَّا أَربِّي ڒْعَاهْذْ-أَ، مَاشَا أَكِيذْنغْ، نشِّينْ، إِنِّي ذَا \add إِبدّنْ\add* دَّارنْ مَارَّا أَسّْ-أَ.  
\v 4 ؤُذمْ أَكْ-ذ وُوذمْ إِسِّيوڒْ أَكِيذْومْ سِيذِي خْ وذْرَارْ، زِي ڒْوسْطْ ن ثْمسِّي.  
\v 5 ثُوغَا أَيِي ذِي ڒْوقْثْ نِّي بدّغْ جَارْ سِيذِي ذ كنِّيوْ حِيمَا أَذْ كنِّيوْ سَّارڭْبغْ خْ وَاوَاڒْ ن سِيذِي، مِينْزِي ثُوغَا كنِّيوْ ثڭّْوْذمْ زِي ثْمسِّي ؤُ وَارْ ثْڭعَّاذمْ شَا غَارْ وذْرَارْ. \add ؤُشَا\add* نتَّا إِنَّا: \x ◘ \xo 5:‏5 \xt ؤُف. 19‏:‏16؛ 20‏:‏18\x*   
\b  
\m
\v 6 ’نشّْ ذ سِيذِي، أَربِّي نّشْ، ونِّي شكْ-د إِسُّوفّْغنْ زِي ثمُّورْثْ ن مِيصْرَا، زِي ثَادَّارْثْ ن ثسْمُوغِي. \x ◘ \xo 5:‏6 \xt ؤُف. 20‏:‏2‏-‏21؛ إِزهد. 81‏:‏11\x*  
\v 7 \bd وَارْ غَاركْ تِّيڒِينْ شَا إِربِّيثنْ نّغْنِي\bd* زَّاثْ إِ وُوذمْ إِنُو.   
\m
\v 8 وَارْ تّڭّْ إِ يِيخفْ نّشْ إِجّْ ن ڒخْيَاڒْ إِنقْشنْ \add نِيغْ\add* مِينْ مَا ڒخْيَاڒْ ن مِينْ \add ذِينْ إِدْجَانْ\add* سنّجْ ذڭْ ؤُجنَّا نِيغْ سْوَادَّايْ خْ ثمُّورْثْ نِيغْ ذڭْ وَامَانْ سَاذُو ثمُّورْثْ.  
\v 9 وَارْ ذ أَسنْ تّْبنْذقْ ؤُ أَذْ أَسنْ ثْعبْذذْ، مِينْزِي نشّْ، سِيذِي، أَربِّي نّشْ، ذ إِجّْ ن أَربِّي إِتَّاسْمنْ، ونِّي د-يَارزْفنْ ڒْمُوعْصِييّثْ ن إِبَابَاثنْ ذڭْ إِحنْجِيرنْ أَڒْ \add جِّيڒْ\add* وِيسّْ ثْڒَاثَا ؤُ وِيسّْ أَربْعَا ن يِينِّي ذ أَيِي إِشَارّْهنْ، \x ◘ \xo 5:‏9 \xt ؤُف. 20‏:‏5؛ 34‏:‏7، 14؛ إِرْم. 32‏:‏18\x*  
\v 10 \add مَاشَا\add* ونِّي إِسّشْننْ ثَامخْسِيوْثْ إِشوَّارنْ إِ ڒُوڒُوفْ ن يِينِّي ذ أَيِي إِتّخْسنْ ؤُ حطَّانْ ثِيوصَّا إِنُو.   
\m
\v 11 \bd وَارْ نطّقْ س يِيسمْ ن سِيذِي، أَربِّي نّشْ، ذِي ڒْبَاطڒْ،\bd* مِينْزِي سِيذِي وَارْ إِتّْبَارِّي ونِّي إِ غَا إِنطْقنْ س يِيسمْ نّسْ ذِي ڒْبَاطڒْ. \x ◘ \xo 5:‏11 \xt لَاوِي 19‏:‏12؛ مت. 5‏:‏33\x*   
\m
\v 12 \bd حْضَا أَسّْ ن سّبْثْ\bd* حِيمَا أَذْ ث ثسّْقدّْسذْ أَمْ مَامّشْ ذ أَشْ يُومُورْ سِيذِي، أَربِّي نّشْ. \x ◘ \xo 5:‏12 \xt أَمز. 2‏:‏2؛ ؤُف. 23‏:‏12؛ 35‏:‏2؛ لَاوِي 23‏:‏3؛ حِز. 20‏:‏12؛ عبر. 4‏:‏4 \x*  
\v 13 ستَّا ن وُوسَّانْ أَذْ ثْخذْمذْ، أَذْ ثڭّذْ مَارَّا ڒْخذْمثْ نّشْ،  
\v 14 مَاشَا أَسّْ وِيسّْ سبْعَا ذ أَسّْ ن سّبْثْ ن سِيذِي، أَربِّي نّشْ. وَارْ \add ذَايسْ\add* ثتّڭّذْ ؤُڒَا ذ إِشْثْ ن ڒْخذْمثْ، شكْ \add لَّ\add* ؤُڒَا ذ مِّيشْ ذ يدْجِيشْ ذ يِيسْمغْ نّشْ ذ ثَايَّا نّشْ ذ ؤُفُونَاسْ نّشْ ذ وغْيُوڒْ نّشْ ذ ڒبْهَايمْ نّشْ ؤُڒَا ذ أَبَارَّانِي نِّي \add أَكِيكْ\add* إِدْجَانْ ذَاخڒْ إِ ثوُّورَا نّشْ \add لَّ\add*، حِيمَا إِسْمغْ نّشْ ذ ثَايَّا نّشْ أَذْ أَريّْحنْ أَمْ شكْ.  
\v 15 أَذْ ثْعقْڒمْ بلِّي ثُوغَا شكْ ذ إِسْمغْ ذِي ثمُّورْثْ ن مِيصْرَا ؤُ سِيذِي، أَربِّي نّشْ، أَقَا إِسُّوفّغْ إِ شكْ-د سّنِّي س يِيجّْ ن ؤُفُوسْ إِجهْذنْ ذ إِجّْ ن ؤُغِيڒْ إِسّْوِيژّْضنْ. خْ ؤُيَا يُومُورْ شكْ سِيذِي، أَربِّي نّشْ، أَذْ ثحْضِيذْ أَسّْ ن سّبْثْ.   
\m
\v 16 \bd وقَّارْ بَابَاشْ ذ يمَّاشْ\bd*، أَمْ مَامّشْ إِ ذ أَكْ يُومُورْ سِيذِي، أَربِّي نّشْ مَاحنْذْ ؤُسَّانْ \add ن ثُوذَارْثْ\add* نّشْ \add زمَّارنْ\add* أَذْ زُّوڭَّارْثنْ ؤُشَا أَذْ إِفّغْ ؤُمدُّورْ نّشْ مْلِيحْ خْ وُوذمْ \add ن ثمُّورْثْ\add* إِ ذ أَشْ غَا إِوْشْ سِيذِي، أَربِّي نّشْ. \x ◘ \xo 5:‏16 \xt لَاوِي 19‏:‏3؛ مت. 15‏:‏4؛ لك. 18‏:‏20؛ أَفا. 6‏:‏2، 3\x*   
\m
\v 17 \bd وَارْ نقّْ.\bd* \x ◘ \xo 5:‏17 \xt مت. 5‏:‏21؛ لك. 18‏:‏20؛ رُوم. 13‏:‏9 \x*   
\m
\v 18 \bd وَارْ زنَّا.\bd* \x ◘ \xo 5:‏18 \xt لك. 18‏:‏20\x*   
\m
\v 19 \bd وَارْ تَّاشَارْ.\bd*   
\m
\v 20 \bd وَارْ شهّذْ س ژُورْ\bd* ضِيدّْ إِ جَّارْ نّشْ.   
\m
\v 21 \bd وَارْ تّڭّْ مژْرِي ذِي ثمْغَارْثْ ن جَّارْ نّشْ\bd* ؤُ وَارْ ضمّعْ ذِي ثَادَّارْثْ ن جَّارْ نّشْ، نِيغْ ذڭْ إِيَّارْ نّسْ، نِيغْ ذڭْ يِيسْمغْ نّسْ، نِيغْ ذِي ثَايَّا نّسْ، نِيغْ ذڭْ ؤُفُونَاسْ نّسْ، نِيغْ ذڭْ وغْيُوڒْ نّسْ، نِيغْ ذِي شَا زِي مَارَّا مِينْ إِدْجَانْ غَارْ جَّارْ نّشْ.‘ \x ◘ \xo 5:‏21 \xt رُوم. 7‏:‏7\x*   
\b  
\m
\v 22 إِسِّيوڒْ سِيذِي أَوَاڒنْ-أَ أَكْ-ذ مَارَّا أَڭْرَاوْ نْومْ \add ن ڒْڭنْسْ\add* س إِشْثْ ن ثْمِيجَّا إِجهْذنْ خْ وذْرَارْ، زِي ڒْوسْطْ ن ثْمسِّي، زڭْ إِسيْنُوثنْ ؤُ زڭْ ؤُسيْنُو إِبُّومْبسْ ؤُ وَارْ إِمَّارْنِي شَا كْثَارْ. يُورِي ثنْ خْ ثْنَاينْ ن ثڒْوِيحِينْ ن وژْرُو ؤُشَا إِوْشَا إِ-ثنْثْ إِ نشّْ. \x ◘ \xo 5:‏22 \xt أَعَوذ. 9‏:‏10، 11\x*  
\v 23 ؤُشَا إِمْسَارْ، ؤُمِي ثسْڒِيمْ كنِّيوْ إِ ثْمِيجَّا زِي ڒْوسْطْ ن ثَادْجسْثْ ؤُشَا أَذْرَارْ إِشمّضْ س ثْمسِّي، أَقَا ثْقَارّْبمْ-د غَارِي، مَارَّا إِزدْجِيفنْ ن ثْقبَّاڒْ نْومْ ذ إِمْغَارنْ نْومْ،  
\v 24 ثنَّامْ أَيِي: ’خْزَارْ، سِيذِي، أَربِّي نّغْ، إِسّْشنْ أَنغْ-د أَعُودْجِي نّسْ ذ ڒمْغَارثْ نّسْ ؤُشَا نسْڒَا إِ ثْمِيجَّا نّسْ زِي ڒْوسْطْ ن ثْمسِّي. أَسّْ-أَ نژْرَا بلِّي سِيذِي إِسِّيوڒْ أَكْ-ذ بْنَاذمْ ؤُشَا وَا \add إِقِّيمْ\add* إِدَّارْ.  
\v 25 ڒخُّو \add خنِّي\add*، مَايمِّي غَا نمّثْ؟ مِينْزِي ثِيمسِّي-يَا إِمْغَارنْ أَذْ أَنغْ ثشّْ. مَاڒَا نقِّيمْ نتّسْڒَا إِ ثْمِيجَّا ن سِيذِي، أَربِّي نّغْ، أَذْ نمّثْ.  
\v 26 مِينْزِي مَانْ ونْ \add إِ ذِينْ يدْجَانْ\add* جَارْ مَارَّا مِينْ غَارسْ أَرِّيمثْ، ونِّي إِسْڒَانْ إِ ثْمِيجَّا ن أَربِّي إِدَّارنْ ثسِّيوڒْ-د زِي ڒْوسْطْ ن ثْمسِّي أَمْ نشِّينْ، ذ ونِّي إِدَّارنْ \add عَاذْ\add*؟ \x ◘ \xo 5:‏26 \xt أَعَوذ. 4‏:‏33؛ ڒقض. 13‏:‏22\x*  
\v 27 أَذْ د-ثْقَارّْبذْ شكْ ؤُ أَذْ ثسْڒذْ غَارْ مَارَّا مِينْ غَا يِينِي سِيذِي، أَربِّي نّغْ، ؤُشَا \add خنِّي\add* أَذْ ثسِّيوْڒذْ أَكِيذْنغْ خْ مَارَّا مِينْ ذ أَشْ غَا يِينِي سِيذِي، أَربِّي نّغْ، ؤُ نشِّينْ أَذْ \add أَسْ\add* نْسڒْ ؤُشَا أَذْ \add زَّايسْ\add* نڭّْ.‘ \x ◘ \xo 5:‏27 \xt ؤُف. 20‏:‏19؛ عبر. 12‏:‏19\x*   
\m
\v 28 إِسْڒَا سِيذِي إِ ثْمِيجَّا ن وَاوَاڒنْ نْومْ ؤُمِي كِيذِي ثسِّيوْڒمْ ؤُشَا إِنَّا أَيِي سِيذِي: ’سْڒِيغْ إِ ثْمِيجَّا ن وَاوَاڒنْ ن ڒْڭنْسْ-أَ، \add أَوَاڒنْ\add* نِّي كِيكْ سِّيوْڒنْ. أَقَا مْلِيحْ، مَارَّا كِيكْ سِّيوْڒنْ نِيثْنِي.  
\v 29 إِڒِي أَذْ أَسنْ إِمّوْشْ إِجّْ ن وُوڒْ مَاحنْذْ أَذْ أَيِي ڭّْوذنْ ؤُشَا أَذْ حْضَانْ ثِيوصَّا إِنُو مَارَّا ؤُسَّانْ قَاعْ حِيمَا نِيثْنِي ذ ثَارْوَا نْسنْ أَذْ إِڒِينْ مْلِيحْ إِ ڒبْذَا!  
\v 30 رُوحْ، ثِينِيذْ أَسنْ: ذوْڒمْ-د غَارْ إِقِيضَانْ نْومْ!  
\v 31 ؤُشَا شكْ، بدّْ ذَا كِيذِي، حِيمَا أَذْ أَكِيذكْ سِّيوْڒغْ ثِيوصَّا ذ لْفَارَايِيضْ نِّي إِ ذ أَسنْ غَا ثسّْڒمْذذْ حِيمَا أَذْ زَّايْسنْثْ ڭّنْ ذِي ثمُّورْثْ نِّي إِ ذ أَسنْ غَا وْشغْ ذ ڒْوَارْثْ.‘  
\v 32 حْضَامْ حِيمَا أَذْ ثڭّمْ أَمْ مَامّشْ إِ ذ أَومْ يُومُورْ سِيذِي، أَربِّي نْومْ، وَارْ تّْحيّْذمْ \add خْ مَانْ أَيَا\add*، وَارْ إِدْجِي \add غَارْ\add* يفُوسْ ؤُڒَا \add غَارْ\add* ؤُزڒْمَاضْ.  
\v 33 أَذْ ثُويُورمْ مَارَّا أَبْرِيذْ نِّي ذ أَومْ يُومُورْ سِيذِي، أَربِّي نْومْ، حِيمَا أَذْ ثدَّارمْ ؤُشَا أَذْ ثِيڒِيمْ مْلِيحْ ؤُ حِيمَا أَذْ زُّوڭَّارْثنْ ؤُسَّانْ نْومْ ذِي ثمُّورْثْ نِّي إِ غَا ثكْسِيمْ ذ ڒْوَارْثْ.“   
\b  
\b  
\m  
\c 6
\m
\v 1 ”ثِينَا ذ ثِيوصَّا ذ لْفَارَايِيضْ نِّي يُومُورْ سِيذِي، أَربِّي نْومْ، مَاحنْذْ أَذْ أَومْ ثنْثْ سّْڒمْذغْ، حِيمَا أَذْ زَّايْسنْثْ ثڭّمْ ذِي ثمُّورْثْ إِ غَارْ غَا ثژْوَامْ مَاحنْذْ أَذْ ت ثكْسِيمْ ذ ڒْوَارْثْ،  
\v 2 حِيمَا أَذْ ثڭّْوْذذْ سِيذِي، أَربِّي نّشْ، ؤُشَا أَذْ ثحْضِيذْ مَارَّا ثِيوصَّا نّسْ ذ ڒُومُورَاثْ نّسْ نِّي إِ ذ أَشْ ؤُمُورغْ، شكْ ذ مِّيشْ ذ مِّيسْ ن مِّيشْ، مَارَّا ؤُسَّانْ ن ثُوذَارْثْ نّشْ، حِيمَا ؤُسَّانْ \add ن ثُوذَارْثْ\add* نّشْ أَذْ زُّوڭَّارْثنْ.  
\v 3 سڒْ، أَ إِسْرَائِيل، حْضَا أَذْ \add زَّايْسنْثْ\add* ثڭّذْ، حِيمَا أَذْ ثِيڒِيذْ مْلِيحْ ؤُ حِيمَا كنِّيوْ أَذْ ثمَّارْنِيمْ س وَاطَّاسْ ذِي ثمُّورْثْ إِفيّْضنْ س ؤُغِي ذ ثَامّنْثْ، أَمْ مَامّشْ ثُوغَا إِنَّا سِيذِي، أَربِّي ن ڒجْذُوذْ نّشْ.“   
\b  
\m
\v 4 ”سڒْ، أَ إِسْرَائِيل، سِيذِي، أَربِّي نّغْ، سِيذِي ذ إِجّْ. \x ◘ \xo 6:‏4 \xt أَعَوذ. 4‏:‏35؛ مك. 12‏:‏29؛ يُوح. 17‏:‏3؛ 1 كُور. 8‏:‏4، 6\x*  
\v 5 أَذْ ثخْسذْ سِيذِي، أَربِّي نّشْ، س مَارَّا وُوڒْ نّشْ ؤُ س مَارَّا ڒعْمَارْ نّشْ ؤُ س مَارَّا جّهْذْ نّشْ.\x ◘ \xo 6:‏5 \xt أَعَوذ. 10‏:‏12؛ مت. 22‏:‏37؛ مك. 12‏:‏20، 33؛ لك. 10‏:‏27\x*   
\b  
\m
\v 6 أَوَاڒنْ-أَ نِّي إِ ذ أَشْ ؤُمُورغْ أَسّْ-أَ، أَذْ إِڒِينْ ذڭْ وُوڒْ نّشْ.  
\v 7 أَذْ ثنْ ثسِّيڭّْزذْ إِ إِحنْجِيرنْ نّشْ ؤُشَا أَذْ خَاسنْثْ ثسِّيوْڒذْ خْمِي غَا ثقِّيمذْ ذِي ثَادَّارْثْ نّشْ ؤُ خْمِي غَا ثُويُورذْ ذڭْ وبْرِيذْ ؤُ خْمِي غَا ثطّْصذْ ؤُ خْمِي غَا ثكَّارذْ.\x ◘ \xo 6:‏7 \xt أَعَوذ. 4‏:‏9؛ 11‏:‏19\x*  
\v 8 أَذْ ثنْ ثْبيْسذْ أَمْ يِيشْثْ ن ڒعْڒَامثْ ذڭْ ؤُفُوسْ نّشْ، أَذْ إِڒِينْثْ أَمْ يِيجّْ ن ؤُفِيڒُو ن ؤُسڭّمْ جَارْ ثِيطَّاوِينْ نّشْ.  
\v 9 ؤُشَا أَذْ ثنْ ثَارِيذْ خْ ڒضْرُوفْ \add غَارْ ؤُغزْذِيسْ ن ثوَّارْثْ\add* ن ثَادَّارْثْ نّشْ ؤُ ذِي ثوُّورَا نّشْ.“   
\b  
\m
\v 10 ”ؤُشَا أَذْ إِمْسَارْ، خْمِي سِيذِي، أَربِّي نّشْ، أَذْ شكْ يَاوِي ذِي ثمُّورْثْ إِ خْ إِجُّودْجْ إِ ڒجْذُوذْ نْومْ، إِ إِبْرَاهِيمْ ذ إِسْحَاقْ ذ يَاعْقُوبْ، مَاحنْذْ أَذْ أَشْ ت إِوْشْ، \add س\add* ثْندَّامْ إِمْغَارنْ إِشْنَانْ، ثِينِّي وَارْ ثبْنِيذْ شكْ  
\v 11 ؤُ س ثُوذْرِينْ إِشُّورنْ \add س\add* مَارَّا ڒْخَارْ إِ زِي وَارْ \add ثنْثْ\add* ثشُّورذْ شكْ، ؤُ \add س\add* ثغْزِينْ نِّي شكْ وَارْ ثغْزِيذْ، ؤُ \add س\add* ثْزَايَارِينْ ذ ثْزمُّورِينْ نِّي وَارْ ثژُّوذْ شكْ. ؤُشَا خْمِي غَا ثشّذْ ؤُ أَذْ ثجِّيوْنذْ، \x ◘ \xo 6:‏11 \xt أَعَوذ. 8‏:‏9، 10\x*  
\v 12 حْضَا \add خنِّي\add* مَاحنْذْ وَارْ تّتُّوذْ سِيذِي ونِّي شكْ د-إِسُّوفّْغنْ زِي ثمُّورْثْ ن مِيصْرَا، زِي ثَادَّارْثْ ن ثسْمُوغِي.   
\m
\v 13 أَذْ ثڭّْوْذذْ سِيذِي، أَربِّي نّشْ، أَذْ ث ثْعبْذذْ ؤُ س يِيسمْ نّسْ أَذْ ثجَّادْجذْ.\x ◘ \xo 6:‏13 \xt أَعَوذ. 10‏:‏20؛ مت. 4‏:‏10؛ لك. 4‏:‏8\x*  
\v 14 وَارْ ڭُّورمْ أَوَارْنِي إِ إِربِّيثنْ نّغْنِي زِي إِربِّيثنْ ن ڒڭْنُوسْ إِ ذ أَومْ د-إِنّْضنْ  
\v 15 - مِينْزِي سِيذِي، أَربِّي نْومْ ذ إِجّْ ن أَربِّي إِتَّاسْمنْ ذِي ڒْوسْطْ نّشْ - حِيمَا وَارْ خَاكْ يَارقّْ وغْضَابْ ن سِيذِي، أَربِّي نّشْ، ؤُشَا أَذْ شكْ إِثحَّا زڭْ \add وُوذمْ ن\add* ثمُّورْثْ.   
\m
\v 16 وَارْ تّْقدْجَابمْ شَا سِيذِي، أَربِّي نْومْ، أَمْ مَامّشْ \add ث\add* ثْقدْجْبمْ ذِي مَاسَّا. \x ◘ \xo 6:‏16 \xt ؤُف. 17‏:‏2؛ ڒخْڒ. 20‏:‏3؛ مت. 4‏:‏7؛ لك. 4‏:‏12 \x*  
\v 17 أَذْ ثحْضِيذْ نِيشَانْ ڒُومُورَاثْ ن سِيذِي، أَربِّي نْومْ ؤُڒَا ذ شّْهَاذَاثْ نّسْ ذ ثْوصَّا نّسْ نِّي إِ ذ أَشْ يُومُورْ.  
\v 18 أڭّْ مِينْ إِدْجَانْ إِسڭّْذنْ ذ مِينْ إِشْنَانْ ذِي ثِيطَّاوِينْ ن سِيذِي، حِيمَا أَذْ ثِيڒِيذْ مْلِيحْ ؤُ حِيمَا أَذْ ثَاذْفذْ غَارْ ثمُّورْثْ إِشْنَانْ إِ زِي إِجُّودْجْ سِيذِي إِ ڒجْذُوذْ نّشْ، \add حِيمَا أَذْ أَسنْ ت إِوْشْ\add*.  
\v 19 حِيمَا أَذْ ثَاژّْڒذْ خْ مَارَّا ڒْعذْيَانْ زَّاثْ إِ وُوذمْ نّشْ، أَمْ مَامّشْ إِسِّيوڒْ سِيذِي.“   
\b  
\m
\v 20 ”خْمِي شكْ غَا إِسّقْسَا مِّيشْ، أَذْ يِينِي: ’مِينْ ثعْنَا شّْهَاذَاثْ ذ ثْوصَّا ذ لْفَارَايِيضْ نِّي ذ أَومْ يُومُورْ سِيذِي، أَربِّي نّغْ؟‘،  
\v 21 \add خنِّي\add* أَذْ ثِينِيذْ إِ مِّيشْ: ’نشِّينْ ثُوغَا أَنغْ ذ إِسمْغَانْ ن فِيرْعُونْ ذِي مِيصْرَا، \add مَاشَا\add* سِيذِي إِسُّوفّغْ أَنغْ-د زِي مِيصْرَا س ؤُفُوسْ إِجهْذنْ.  
\v 22 سِيذِي إِڭَّا، قِيبَاتْشْ إِ ثِيطَّاوِينْ نّغْ، ڒعْڒَامَاثْ ذ لْمُوعْجِيزَاثْ إِمْغَارنْ ذ إِسِّيڭّْوْذنْ ذِي مِيصْرَا، غَارْ فِيرْعُونْ ؤُ غَارْ مَارَّا ثَادَّارْثْ نّسْ.  
\v 23 ؤُشَا إِسُّوفّغْ أَنغْ-د سّنِّي حِيمَا أَذْ أَنغْ إِسِّيذفْ مَاحنْذْ أَذْ أَنغْ يوْشْ ثَامُّورْثْ نِّي خْ إِجُّودْجْ إِ ڒجْذُوذْ نّغْ،\add حِيمَا أَذْ أَسنْ ت إِوْشْ\add*.  
\v 24 سِيذِي يُومُورْ أَنغْ أَذْ نڭّْ عْلَاحْسَابْ مَارَّا ثِيوصَّا-يَا، أَذْ نڭّْوذْ زِي سِيذِي، أَربِّي نّغْ، إِ ڒبْذَا، ذِي طّْوعْ ن ثِيزِي نّغْ حِيمَا أَذْ ندَّارْ أَمْ \add ثدْجَا\add* أَسّْ-أَ.  
\v 25 مَانْ أَيَا أَذْ يِيڒِي ذ ثَاسڭْذَا نّغْ خْمِي غَا نحْضَا مَاحنْذْ أَذْ نڭّْ مَارَّا ڒُومُورَاثْ-أَ زَّاثْ إِ وُوذمْ ن سِيذِي، أَمْ مَامّشْ ذ أَنغْ يُومُورْ نتَّا.“   
\b  
\b  
\m  
\c 7
\s1 إِسْرَائِيل ذ إِمزْذَاغْ ن كنْعَانْ  
\m
\v 1 ”خْمِي سِيذِي، أَربِّي نّشْ، أَذْ شكْ إِسِّيذفْ ذِي ثمُّورْثْ مَانِي غَا ثْرَاحذْ مَاحنْذْ أَذْ ت ثكْسِيذْ ذ ڒْوَارْثْ، ؤُشَا نتَّا أَذْ يَاژّڒْ زِي زَّاثكْ أَطَّاسْ ن ڒڭْنُوسْ: إِحِيتِّييّنْ ذ إِجِيرْجَاشِييّنْ ذ إِمُورِييّنْ ذ أَيْثْ ن كنْعَانْ ذ إِفِيرِيزِييّنْ ذ إِحِيوِييّنْ ذ إِيابُوسِييّنْ، سبْعَا ن ڒڭْنُوسْ مْغَارنْ ؤُ جهْذنْ خَاكْ أَطَّاسْ، \x ◘ \xo 7:‏1 \xt أَعَوذ. 31‏:‏3\x*  
\v 2 ؤُشَا سِيذِي، أَربِّي نّشْ، أَذْ ثنْ إِسلّمْ زَّاثْ إِ وُوذمْ نّشْ ؤُ شكْ أَذْ ثنْ ثْغڒْبذْ، \add خنِّي\add* إِتّْخصَّا أَذْ ثنْ ثْحَارّْمذْ قَاعْ إِ ؤُثحِّي. وَارْ كِيسنْ تّڭّْ ڒْعَاهْذْ ؤُ وَارْ ذ أَسنْ سّْشنْ ڒحْنُونشْثْ نّشْ. \x ◘ \xo 7:‏2 \xt ؤُف. 23‏:‏32؛ 34‏:‏15؛ ڒخْڒ. 33‏:‏52؛ ياش. 11‏:‏11 \x*  
\v 3 وَارْ ثذِّيكّْوِيڒمْ ذ إِضڭّْوَاڒنْ عَاوذْ أَكِيذْسنْ. وَارْ تِّيشْ يدْجِيشْ إِ مِّيسْ ؤُ وَارْ د-تَّاوِي يدْجِيسْ إِ مِّيشْ، \x ◘ \xo 7:‏3 \xt ؤُف. 34‏:‏16؛ 1 إِج. 11‏:‏2؛ عِز. 9‏:‏12\x*  
\v 4 مِينْزِي أَيَا أَذْ يَارّْ مِّيشْ أَذْ د-إِذْوڒْ زِي ضفَّارْ إِنُو ؤُشَا أَذْ إِسخَّارْ إِ إِربِّيثنْ نّغْنِي ؤُشَا \add أَمُّو\add* أَذْ خَاومْ يَارغْ وغْضَابْ ن سِيذِي ؤُشَا أَذْ كنِّيوْ إِثحَّا ذغْيَا.  
\v 5 أَمُّو \add مَاشَا\add* إِ إِتّْخصَّا أَذْ كِيسنْ ثڭّمْ: أَذْ ثْهذْممْ إِعَالْطَارنْ نْسنْ، أَذْ ثَارْژَامْ إِمَايْضُوثنْ نْسنْ \add إِقدّْسنْ\add* ؤُ أَذْ ثْهذْمنْ ثِيربِّينْ نْسنْ ن شْوَارْثِي ؤُشَا أَذْ ثسّْشمْضمْ ڒخْيَاڒَاثْ نْسنْ إِنقْشنْ ن ؤُكشُّوضْ س ثْمسِّي. \x ◘ \xo 7:‏5 \xt ؤُف. 23‏:‏24؛ 34‏:‏13؛ أَعَوذ. 12‏:‏2، 3\x*  
\v 6 مِينْزِي شكْ ذ إِجّْ ن ڒْڭنْسْ إِقدّسْ إِ سِيذِي، أَربِّي نّشْ. سِيذِي، أَربِّي نّشْ، ونِّي شكْ إِفَارْزنْ حِيمَا أَذْ أَسْ ثِيڒِيذْ ذ إِجّْ ن ڒْڭنْسْ إِغْڒَانْ خْ مَارَّا ڒڭْنُوسْ \add نِّي يدْجَانْ\add* خْ وُوذمْ ن ثمُّورْثْ. \x ◘ \xo 7:‏6 \xt ؤُف. 19‏:‏5؛ أَعَوذ. 4‏:‏20؛ 14‏:‏21؛ 26‏:‏18؛ 28‏:‏9؛ 1 بُط. 2‏:‏9\x*  
\v 7 سِيذِي وَارْ غَارْومْ إِقّنْ ؤُ وَارْ كنِّيوْ إِخْضَارْ ؤُمِي ثُوغَا كنِّيوْ ذ أَطَّاسْ زِي مَارَّا ڒڭْنُوسْ، مِينْزِي ثُوغَا كنِّيوْ ثسْوَامْ قلّْ جَارْ مَارَّا ڒڭْنُوسْ،  
\v 8 مَاشَا ثَايْرِي ن سِيذِي إِ كنِّيوْ ذ ؤُحطُّو نّسْ خْ ثْجَادْجِيثْ نِّي إِجُّودْجْ إِ ڒجْذُوذْ نْومْ، \add ثَاجَادْجِيثْ\add* إِ زِي كنِّيوْ د-إِسُّوفّغْ سِيذِي س ؤُفُوسْ إِجهْذنْ ذ \add إِ زِي\add* شكْ إِسّنْجمْ زِي ثَادَّارْثْ ن ثسْمُوغِي، زڭْ ؤُفُوسْ ن فِيرْعُونْ، أَجدْجِيذْ ن مِيصْرَا. \x ◘ \xo 7:‏8 \xt أَعَوذ. 10‏:‏15\x*  
\v 9 سّنْ خنِّي، بلِّي سِيذِي، أَربِّي نّشْ، ذ أَربِّي، أَقَا نتَّا ذ أَربِّي أَمْثِيقِّي، ونِّي إِحطَّانْ ڒْعَاهْذْ ذ ثْمخْسِيوْثْ إِشوَّارنْ زِي جِّيهثْ ن يِينِّي ث إِتّخْسنْ ؤُشَا حطَّانْ ڒُومُورَاثْ نّسْ، أَڒْ جِّيڒْ وِيسّْ أَڒفْ، \x ◘ \xo 7:‏9 \xt ؤُف. 20‏:‏5؛ أَعَوذ. 5‏:‏9\x*  
\v 10 \add مَاشَا\add* مَارَّا وِي ث إِشَارّْهنْ ذڭْ ؤُغمْبُوبْ نّسْ، أَقَا نتَّا أَذْ زَّايْسنْ ت إِخْڒفْ أَمْ ثنْ إِ غَا يَاردّدْجْ. وَارْ إِتّْرِيجِي، مَاحنْذْ أَذْ إِخدْجصْ ونِّي ث إِشَارّْهنْ ذڭْ ؤُغمْبُوبْ نّسْ. \x ◘ \xo 7:‏10 \xt نَحُم. 1‏:‏2\x*   
\m
\v 11 حْضَا خنِّي ڒُومُورَاثْ ذ ثْوصَّا ذ لْفَارَايِيضْ نِّي ذ أَشْ ؤُمُورغْ نشّْ أَسّْ-أَ مَاحنْذْ أَذْ زَّايْسنْثْ ثڭّذْ.“   
\m
\v 12 ”أَذْ إِمْسَارْ، ؤُمِي ثسْڒِيمْ إِ لْفَارَايِيضْ-أَ ؤُ كنِّيوْ أَذْ ثنْثْ ثحْضَامْ ؤُ أَذْ زَّايْسنْثْ ثڭّمْ، أَقَا سِيذِي، أَربِّي نّشْ، أَذْ أَشْ إِبدّْ خْ ڒْعَاهْذْ ذ ثَامخْسِيوْثْ إِشوَّارنْ إِ ثُوغَا إِجُّودْجْ إِ ڒجْذُوذْ نّشْ. \x ◘ \xo 7:‏12 \xt لَاوِي 26‏:‏3؛ أَعَوذ. 28‏:‏1\x*  
\v 13 نتَّا أَذْ شكْ إِخْسْ، أَذْ شكْ إِبَاركْ ؤُ أَذْ شكْ يَارّْ ذڭْ وَاطَّاسْ. أَذْ إِبَاركْ ڒْغِيدْجثْ ن ؤُعذِّيسْ نّشْ ذ ڒْغِيدْجثْ ن ثمُّورْثْ نّشْ، إِرْذنْ نّشْ، بِينُو نّشْ ن جْذِيذْ، زّشْثْ نّشْ \add ن طّْرِي\add*، ثَارَّاوْثْ ن ثْفُونَاسِينْ نّشْ ذ إِمژْيَاننْ إِعِيزّنْ ن وُودْجِي نّشْ، ذِي ثمُّورْثْ نِّي ثُوغَا إِجُّودْجْ إِ ڒجْذُوذْ نّكْ أَذْ أَشْ ت-إِ-د-إِوْشْ.  
\v 14 أَقَا شكْ ثتّْوَابَارْكذْ جَارْ ڒڭْنُوسْ! وَارْ ذَايكْ إِتّْغِيمِي \add عَاذْ\add* حذْ إِ وَارْ د-إِتّجِّينْ ؤُڒَا ذ ثنِّي وَارْ إِتِّيرِيونْ، ؤُشَا أَمُّو ؤُڒَا ذِي ڒبْهَايمْ نّشْ. \x ◘ \xo 7:‏14 \xt ؤُف. 23‏:‏26\x*  
\v 15 أَذْ زَّايكْ إِكّسْ سِيذِي مَارَّا ڒهْڒَاشْ ؤُ وَارْ شكْ إِڒقّفْ ؤُڒَا س شَا ن ڒهْڒَاشَاثْ ثِيعفَّانِينْثْ إِ غَاركْ إِتّْوَاسّْننْ زِي مِيصْرَا، \add مَاشَا\add* نتَّا أَذْ ثنْثْ إِسِّيوضْ خْ مَارَّا إِنِّي إِ شكْ إِشَارّْهنْ.  
\v 16 أَذْ ثشّذْ مَارَّا ڒڭْنُوسْ نِّي ذ أَشْ غَا إِوْشْ سِيذِي، أَربِّي نّشْ. ثِيطّْ نّشْ وَارْ خَاسنْ ثتّْحِينِّي ؤُ إِربِّيثنْ نْسنْ وَارْ ثنْ ثْسخَّارذْ، مِينْزِي أَيَا أَذْ يِيڒِي ذ ڒْفخْ إِ شكْ.  
\v 17 مَاڒَا ثنِّيذْ ذڭْ وُوڒْ نّشْ: ڒڭْنُوسْ-أَ مْغَارنْ خَافِي، مَامّشْ غَا زمَّارغْ أَذْ زَّايْسنْ كّْسغْ \add عمَّارْصْ\add* ڒْوَارْثْ نْسنْ؟  
\v 18 \add خنِّي\add* وَارْ زَّايْسنْ تّڭّْوذْ. خَارّصْ مْلِيحْ ذِي مِينْ إِڭَّا سِيذِي، أَربِّي نّشْ، أَكْ-ذ فِيرْعُونْ ؤُ أَكْ-ذ مَارَّا إِمِيصْرِييّنْ،  
\v 19 \add خَارّصْ ذِي\add* ثْقدْجَابِينْ إِمْغَارنْ، ثِينِّي ثژْرِيذْ س ثِيطَّاوِينْ نّشْ ؤُ \add ذِي\add* ڒعْڒَامَاثْ ذ لْمُوعْجِيزَاثْ ذ ؤُفُوسْ إِجهْذنْ ذ ؤُغِيڒْ إِسّْوِيژّْضنْ أَكْ-ذ وِي شكْ د-إِسُّوفّغْ سِيذِي، أَربِّي نّشْ. أَمُّو إِ غَا يڭّْ سِيذِي، أَربِّي نّشْ، س مَارَّا ڒڭْنُوسْ إِ زِي تّڭّْوذذْ. \x ◘ \xo 7:‏19 \xt أَعَوذ. 4‏:‏34؛ 29‏:‏3\x*  
\v 20 سِيذِي، أَربِّي نّشْ، أَذْ إِسّكّْ إِرزَّانْ إِضَارْغَاڒنْ جَارْ أَسنْ، أَڒْ غَا تّْوَاهلّْكنْ إِنِّي إِقِّيمنْ، إِنِّي إِتّْوَاسّْنُوفَّارنْ زَّاثكْ. \x ◘ \xo 7:‏20 \xt ؤُف. 23‏:‏28؛ ياش. 24‏:‏12\x*  
\v 21 وَارْ تّڭّْوذْ زَّاثْ إِ وُوذمْ نْسنْ، مِينْزِي سِيذِي، أَربِّي نّشْ، أَقَا-ث ذِي ڒْوسْطْ نّشْ، أَقَا-ث ذ أَربِّي إِمْغَارنْ ؤُ إِسَّاڭّْوَاذنْ.  
\v 22 سِيذِي، أَربِّي نّشْ، أَذْ إِسُّوفّغْ ڒڭْنُوسْ-أَ زَّاثكْ شْوَايْثْ شْوَايْثْ. وَارْ إِزمَّارْ أَذْ خَاسنْ ثقْضِيذْ ذغْيَا، مَاڒَا لَّا أَذْ مَّارنْينْ ڒوْحُوشْ ذڭْ إِيَّارْ أَطَّاسْ خَاكْ.  
\v 23 سِيذِي، أَربِّي نّشْ، أَذْ ثنْ إِسلّمْ زَّاثْ إِ وُوذمْ نّشْ ؤُ أَذْ ثنْ إِسّْخَارْوضْ س يِيجّْ ن ؤُخَارْوضْ إِمْغَارْ أَڒْ غَا تّْوَاثحَّانْ.  
\v 24 أَذْ إِسلّمْ إِجدْجِيذنْ نْسنْ ذڭْ ؤُفُوسْ نّشْ ؤُشَا أَذْ ثمْحِيذْ إِسمْ نْسنْ زِي سَاذُو ؤُجنَّا. ؤُڒَا ذ إِجّْ ن ورْيَازْ وَارْ إِزمَّارْ أَذْ إِبدّْ زَّاثْ إِ وُوذمْ نّشْ أَڒْ ثنْ غَا ثثحِّيذْ.  
\v 25 ڒخْيَاڒَاثْ إِنقْشنْ أَذْ ثنْثْ ثسّْشمْضذْ س ثْمسِّي. نُّوقَارْثْ ذ وُورغْ إِ خَاسنْثْ إِدْجَانْ وَارْ ذَايسْعشّقْ ؤُ وَارْ ث كسِّي إِ يِيخفْ نّشْ، حِيمَا وَارْ زَّايسْ ثتّْخَارْوِيضذْ، مِينْزِي أَيَا ذ إِشْثْ ن جّْعِيفشْثْ إِ سِيذِي، أَربِّي نّشْ.  
\v 26 وَارْ تِّيوِي إِشْثْ ن جّْعِيفشْثْ \add أَمْ ثَا\add* غَارْ ثَادَّارْثْ نّشْ، مَاڒَا لَّا أَذْ ثتّْوَاحَارّْمذْ \add إِ ؤُثحِّي\add* أَمْ نتَّا. أَذْ زَّايسْ ثْعِيفّذْ أَطَّاسْ ؤُ أَذْ أَشْ ثِيڒِي ذ ثَامنّْعِيثْ، مِينْزِي أَقَا-ت ذ إِشْثْ ن ڒْقشْعثْ ن ڒحْرَامْ.“   
\b  
\b  
\m  
\c 8
\s1 سْڒمْ إِ سِيذِي أَربِّي ؤُشَا طّْفمْ ذِي ڒْعَاهْذْ نّسْ  
\m
\v 1 ”أَذْ ثحْضَامْ مَارَّا ڒُومُورَاثْ إِ زِي ذ أَومْ ؤُمُورغْ أَسّْ-أَ، مَاحنْذْ أَذْ ثنْثْ ثڭّمْ، حِيمَا أَذْ ثدَّارمْ ؤُ أَذْ ثمَّارنْيمْ ؤُشَا أَذْ ثَاذْفمْ غَارْ ثمُّورْثْ، ثنِّي إِجُّودْجْ سِيذِي إِ ڒجْذُوذْ نْومْ، ؤُشَا أَذْ ت ثكْسِيمْ ذ ڒْوَارْثْ.  
\v 2 أَذْ ثِيذَارذْ مَارَّا أَبْرِيذْ خْ مَانِي شكْ إِڭوّذْ سِيذِي، أَربِّي نّشْ، أَربْعِينْ ن إِسڭّْوُوسَا ذِي ڒخْڒَا حِيمَا أَذْ شكْ إِسّْوَاضعْ ؤُ أَذْ شكْ إِقدْجبْ مَاحنْذْ أَذْ إِسّنْ مِينْ \add ذِينْ\add* ذڭْ وُوڒْ نّشْ، مَا أَذْ ثحْضِيذْ ڒُومُورَاثْ نّسْ نِيغْ لَّا.  
\v 3 نتَّا إِسّْوَاضعْ إِ شكْ ؤُ إِسّْڒَاژْ إِ شكْ ؤُ إِوْشَا أَشْ ’مَانَّا‘ ذ مَاشَّا، ثنِّي وَارْ ثسِّينذْ شَا شكْ ؤُڒَا ذ ڒجْذُوذْ نّشْ وَارْ ت سِّيننْ شَا، حِيمَا أَذْ أَشْ إِسّْشنْ بلِّي بْنَاذمْ وَارْ إِدَّارْ س وغْرُومْ وَاهَا، مَاشَا أَقَا بْنَاذمْ إِدَّارْ س مَارَّا مِينْ د-إِفّْغنْ زڭْ ؤُقمُّومْ ن سِيذِي. \x ◘ \xo 8:‏3 \xt ؤُف. 16‏:‏14، 15؛ مت. 4‏:‏4؛ لك. 4‏:‏4\x*  
\v 4 أَرُّوضْ نّشْ \add عمَّارْصْ\add* وَارْ خَاكْ إِوْسَارْ ؤُڒَا ذ أَضَارْ نّشْ وَارْ يُوفّْ شَا ذِي \add مَارَّا\add* أَربْعِينْ ن إِسڭّْوُوسَا-يَا.\x ◘ \xo 8:‏4 \xt أَعَوذ. 29‏:‏6؛ نَاح. 9‏:‏21\x*  
\v 5 سنْ ذڭْ وُوڒْ نّشْ، بلِّي سِيذِي، أَربِّي نّشْ، أَقَا يَاربَّا إِ شكْ، أَمْ مَامّشْ يَاربَّا أَرْيَازْ مِّيسْ  
\v 6 ؤُشَا حْضَا ڒُومُورَاثْ ن سِيذِي، أَربِّي نّشْ، أَڒَامِي ثدْجِيذْ ذڭْ إِبْرِيذنْ نّسْ ؤُ أَڒَامِي زَّايسْ تّڭّْوذذْ.“   
\b  
\m
\v 7 ”مِينْزِي سِيذِي، أَربِّي نّشْ،  
\m أَذْ شكْ إِسِّيذفْ  
\m ذڭْ إِشْثْ ن ثمُّورْثْ إِشْنَانْ،  
\m إِشْثْ ن ثمُّورْثْ ن ثْغزْرَاثِينْ  
\m ذ ڒْعُونْصَارَاثْ ذ \add وَامَانْ\add* إِهوْڒنْ،  
\m إِنِّي د-إِفّْغنْ زِي ثيْسَارْثْ ذ وذْرَارْ،   
\m
\v 8 إِشْثْ ن ثمُّورْثْ ن إِرْذنْ  
\m ذ إِمنْذِي ذ ثْزَايَارِينْ  
\m ذ وَارْثَانْ ن ثَازَارْثْ ذ إِرمَّامنْ،  
\m إِشْثْ ن ثمُّورْثْ \add ثشُّورْ\add*  
\m س زّشْثْ ن ثْزِيثُونْثْ ؤُ ن ثَامّنْثْ،   
\m
\v 9 إِشْثْ ن ثمُّورْثْ مَانِي غَا ثشّذْ أَغْرُومْ  
\m ؤُمِي وَارْ ذِينْ ڒخْصصْ  
\m ؤُ وَارْ شكْ إِتّْخصِّي شَا ذَايسْ،  
\m إِشْثْ ن ثمُّورْثْ، إِژْرَا نّسْ  
\m \add شُّورنْ\add* س وُوزَّاڒْ  
\m ؤُ زڭْ إِذُورَارْ نّسْ أَذْ ثْنقْشذْ نّْحَاسْ.   
\m
\v 10 مَاڒَا ثشِّيذْ ؤُ ثجِّيوْنذْ،  
\m أَذْ ثْبَارْكذْ سِيذِي، أَربِّي نّشْ،  
\m خْ ثمُّورْثْ إِشْنَانْ، ثنِّي ذ أَشْ إِوْشَا.“ \x ◘ \xo 8:‏10 \xt أَعَوذ. 6‏:‏11، 12\x*   
\b  
\m
\v 11 ”حْضَا إِخفْ نّشْ، حِيمَا وَارْ ثتُّوذْ سِيذِي، أَربِّي نّشْ، أَڒَامِي وَارْ ثحْضِيذْ ڒُومُورَاثْ نّسْ، لْفَارَايِيضْ نّسْ ذ ثْوصَّا نّسْ، ثِينِّي ذ أَشْ ؤُمُورغْ أَسّْ-أَ،  
\v 12 حِيمَا وَارْ إِتِّيڒِي - مَاڒَا ثشِّيذْ ؤُ ثجِّيوْنذْ ؤُشَا أَقَا ثبْنِيذْ ثُوذْرِينْ إِشْنَانْ، ثِينِّي إِ ذِي ثڭِّيذْ أَذْ \add ذَايْسنْثْ\add* ثْزذْغذْ،  
\v 13 ؤُشَا إِفُونَاسنْ ذ ثْفُونَاسِينْ نّشْ ذ وُودْجِي نّشْ تّْوَامَّارْنِينْ ؤُ نُّوقَارْثْ ذ وُورغْ نِّي غَاركْ أَقَا تّْوَامَّارْنِينْ، ؤُ مَارَّا مِينْ غَاركْ أَقَا إِتّْوَامَّارْنِي -  
\v 14 أَذْ ثسّْڭعّْذذْ ؤُڒْ نّشْ، أَذْ ثتُّوذْ سِيذِي، أَربِّي نّشْ، ونِّي شكْ د-إِسُّوفّْغنْ زِي ثمُّورْثْ ن مِيصْرَا، زِي ثَادَّارْثْ ن ثسْمُوغِي ...   
\b  
\m
\v 15 \bdit ذ ونِّي\bdit* إِ شكْ د-إِنذْهنْ ذِي ڒخْڒَا إِمْغَارنْ ؤُ إِسَّاڭّْوَاذنْ مَانِي ثُوغَا إِفِيغْرَانْ يَارْغِينْ ذ ثْغَارْضْمِيوِينْ ؤُڒَا ذِي ثَامُّورْثْ إِتّْفَاذَانْ بْڒَا أَمَانْ،  
\m \bdit ذ ونِّي\bdit* د-إِسُّوفّْغنْ أَمَانْ زڭْ وژْرُو ن سّدْجَاحْ، \x ◘ \xo 8:‏15 \xt ؤُف. 17‏:‏6؛ ڒخْڒ. 20‏:‏11؛ إِزهد. 78‏:‏15؛ 114‏:‏8\x*   
\m
\v 16 \bdit ذ ونِّي\bdit* ذ أَشْ إِوْشِينْ ’مَانَّا‘ إِ مَاشَّا ذِي ڒخْڒَا، \add مَانَّا\add* نِّي وَارْ سِّيننْ ڒجْذُوذْ نْومْ، حِيمَا أَذْ شكْ إِسّْوَاضعْ ؤُ حِيمَا أَذْ شكْ إِقدْجبْ ؤُ حِيمَا أَذْ أَشْ إِڭّْ ثْشُونِي غَارْ ؤُنڭَّارْ، \x ◘ \xo 8:‏16 \xt ؤُف. 16‏:‏14، 15\x*   
\b  
\m
\v 17 ؤُشَا \add خنِّي\add* أَذْ ثِينِيذْ ذڭْ وُوڒْ نّشْ: ’\add س\add* ثْزمَّارْ إِنُو ذ جّهْذْ ن ؤُفُوسْ إِنُو طّْفغْ مَارَّا ڒكْسِيبثْ-أَ إِ يِيخفْ إِنُو.‘  
\v 18 إِذَارْ سِيذِي، أَربِّي نّشْ أَقَا نتَّا إِ ذ أَشْ إِوْشِينْ جّهْذْ حِيمَا أَذْ ثْكسْبذْ إِشْثْ ن ڒكْسِيبثْ ثمْغَارْ مَاحنْذْ أَذْ إِمْثنْ \add أَمُّو\add* ڒْعَاهْذْ نّسْ نِّي ثُوغَا إِجُّودْجْ إِ ڒجْذُوذْ نّشْ، أَمْ \add ثدْجَا\add* أَسّْ-أَ.  
\v 19 مَاڒَا ثِيوْضذْ أَذْ ثتُّوذْ سِيذِي، أَربِّي نّشْ، ؤُشَا أَذْ ثُويُورذْ أَوَارْنِي إِ إِربِّيثنْ نّغْنِي، أَذْ أَسنْ ثْعبْذذْ ؤُ أَذْ أَسنْ ثْبنْذْقذْ، نشّْ أَسّْ-أَ بَارّْحغْ أَشْ-د، أَقَا أَذْ ثتّْوَاهلّْكمْ س تِّيذثْ.  
\v 20 أَذْ ثتّْوَاهلّْكمْ أَمْ ڒڭْنُوسْ نِّي خْ يُوژّڒْ سِيذِي زَّاثْ إِ وُوذمْ نْومْ، مِينْزِي وَارْ ثسْڒِيمْ إِ ثْمِيجَّا ن سِيذِي، أَربِّي نْومْ.“   
\b  
\b  
\m  
\c 9
\s1 ثْنَاينْ ن ثڒْوِيحِينْ ثِيمزْوُورَا ن وژْرُو  
\m
\v 1 ”سڒْ، إِسْرَائِيل، أَسّْ-أَ أَذْ ثژْوِيذْ لْ-ؤُرْذُونْ، مَاحنْذْ أَذْ ثَاذْفذْ \add غَارْ ثمُّورْثْ\add*، حِيمَا أَذْ ثكّْسذْ ڒْوَارْثْ ن ڒڭْنُوسْ إِمْغَارنْ ؤُ زڭْ إِنِّي خَاكْ إِجهْذنْ، \add إِنِّي غَارْسنْ\add* ثِيندَّامْ ثِيمقّْرَانِينْ نِّي تّْوَافَارْينْثْ أَڒْ أَجنَّا،  
\v 2 إِجّْ ن ڒْڭنْسْ \add ن إِوْذَانْ\add* إِزُّوڭَارْثنْ، أَيْثْ ن إِعَانَاقِييّنْ إِنِّي ثسّْنذْ \add عَاذْ\add* ؤُ خْ يِينِّي ثسْڒِيذْ \add قَّارنْ\add*: ’وِي غَا إِبدّْ زَّاثْ إِ وُوذمْ ن أَيْثْ ن إِعَانَاقِييّنْ؟‘ \x ◘ \xo 9:‏2 \xt ڒخْڒ. 13‏:‏32، 33 \x*  
\v 3 سّنْ خنِّي، أَقَا سِيذِي، أَربِّي نّشْ، ذ ونِّي إِزْوَارنْ زَّاثْ إِ وُوذمْ نّشْ. نتَّا ذ إِشْثْ ن ثْمسِّي إِتّتّنْ، نتَّا أَذْ ثنْ إِثحَّا ؤُ أَذْ ثنْ إِسّْوَاضعْ زَّاثْ إِ وُوذمْ نّشْ ؤُشَا شكْ أَذْ زَّايْسنْ ثكّْسذْ ڒْوَارْثْ نْسنْ ؤُ أَذْ ثنْ ثَارذْدْجذْ ذغْيَا أَمْ مَامّشْ غَاركْ د-إِسِّيوڒْ سِيذِي. \x ◘ \xo 9:‏3 \xt أَعَوذ. 4‏:‏24؛ عبر. 12‏:‏29 \x*  
\v 4 ڒَامِي سِيذِي، أَربِّي نّشْ، خَاسنْ يُوژّڒْ زَّاثكْ، \add خنِّي\add* وَارْ قَّارْ ذڭْ وُوڒْ نّشْ، أَذْ ثِينِيذْ: ’سِيذِي إِسِّيذفْ أَيِي-د ذِي سِّيبّثْ ن ثْسڭْذَا إِنُو مَاحنْذْ أَذْ كْسِيغْ ثَامُّورْثْ-أَ ذ ڒْوَارْثْ‘. \add مِينْزِي\add* ذِي سِّيبّثْ ن ثُوعفّْنَا ن ڒڭْنُوسْ-أَ أَذْ زَّايْسنْ إِكّسْ سِيذِي ڒْوَارْثْ نْسنْ زَّاثْ إِ وُوذمْ نّشْ.  
\v 5 وَارْ إِدْجِي ذِي سِّيبّثْ ن ثْسڭْذَا نّشْ، وَارْ إِدْجِي ذِي سِّيبّثْ ن ڒصْفَايثْ ن وُوڒْ نّشْ، أَذْ ذِينْ ثْرَاحذْ حِيمَا أَذْ ثكْسِيذْ ثَامُّورْثْ نْسنْ ذ ڒْوَارْثْ، مَاشَا ذِي سِّيبّثْ ن ثُوعفّْنَا ن ڒڭْنُوسْ-أَ ؤُ حِيمَا أَذْ إِحْضَا أَوَاڒْ نِّي زِي إِجُّودْجْ سِيذِي، أَربِّي نّشْ، إِ ڒجْذُوذْ نّشْ، إِ إِبْرَاهِيمْ ذ إِسْحَاقْ ذ يَاعْقُوبْ، أَذْ زَّايْسنْ إِكّسْ سِيذِي، أَربِّي نّشْ، ڒْوَارْثْ نْسنْ زَّاثْ إِ وُوذمْ نّشْ.“ \x ◘ \xo 9:‏5 \xt أَمز. 12‏:‏7؛ 13‏:‏15؛ 15‏:‏7؛ 17‏:‏8؛ 26‏:‏4؛ 28‏:‏13 \x*   
\b  
\m
\v 6 ”س ؤُيَا إِ غَا ثسّْنذْ، بلِّي وَارْ إِدْجِي ذِي سِّيبّثْ ن ثْسڭْذَا نّشْ إِ ذ أَشْ إِوْشَا سِيذِي، أَربِّي نّشْ، ثَامُّورْثْ-أَ إِشْنَانْ مَاحنْذْ أَذْ ت ثكْسِيذْ ذ ڒْوَارْثْ، مِينْزِي كنِّيوْ ذ إِجّْ ن ڒْڭنْسْ ذ أَغنَّانْ.  
\v 7 إِذَارْ، وَارْ تّتُّو، بلِّي ثڭِّيذْ أَذْ إِدُّوقّزْ وغْضَابْ ن سِيذِي، أَربِّي نّشْ، ذِي ڒخْڒَا. زڭْ وَاسّْ نِّي ذِي ثفّْغذْ زِي ثمُّورْثْ ن مِيصْرَا أَڒَامِي د-ثُوذْفذْ غَارْ ومْشَانْ-أَ، ثُوغَا ثْغوّْغمْ كنِّيوْ خْ سِيذِي. \x ◘ \xo 9:‏7 \xt ؤُف. 14‏:‏11؛ 16‏:‏2؛ 17‏:‏2؛ ڒخْڒ. 11‏:‏4 \x*  
\v 8 مِينْزِي ذِي هُورِيبْ ثڭِّيمْ أَذْ إِدُّوقّزْ وغْضَابْ ن سِيذِي، أَڒَامِي خَاومْ إِسْعَارْ سِيذِي أَڒَامِي إِخْسْ أَذْ كنِّيوْ إِثحَّا. \x ◘ \xo 9:‏8 \xt ؤُف. 32‏:‏4؛ إِزهد. 106‏:‏19\x*  
\v 9 ڒَامِي ؤُڒْيغْ غَارْ وذْرَارْ حِيمَا أَذْ طّْفغْ ثِيڒْوِيحِينْ ن وژْرُو، ثِيڒْوِيحِينْ ن ڒْعَاهْذْ نِّي أَكِيذْومْ إِڭَّا سِيذِي، قِّيمغْ أَربْعِينْ ن وُوسَّانْ ذ دْجْيَاڒِي ذڭْ وذْرَارْ. أَغْرُومْ وَارْ ث شِّيغْ، أَمَانْ وَارْ ثنْ سْوِيغْ. \x ◘ \xo 9:‏9 \xt ؤُف. 24‏:‏18؛ 34‏:‏28\x*  
\v 10 إِوْشْ أَيِي سِيذِي ثْنَاينْ ن ثڒْوِيحِينْ ن وژْرُو ؤُرِينْثْ س ؤُضَاضْ ن أَربِّي ؤُ ذَايْسنْثْ مَارَّا أَوَاڒنْ نِّي ثُوغَا كِيومْ إِسِّيوڒْ سِيذِي ذڭْ وذْرَارْ زِي ڒْوسْطْ ن ثْمسِّي ذڭْ وَاسّْ ن وڭْرَاوْ \add ن ڒْڭنْسْ\add*. \x ◘ \xo 9:‏10 \xt ؤُف. 31‏:‏18\x*  
\v 11 إِمْسَارْ غَارْ ؤُنڭَّارْ ن أَربْعِينْ ن وُوسَّانْ ذ أَربْعِينْ ن دْجِييَاڒِي، ڒَامِي ذ أَيِي إِوْشَا سِيذِي ثْنَاينْ ن ثڒْوِيحِينْ ن وژْرُو، ثِيڒْوِيحِينْ ن ڒْعَاهْذْ،  
\v 12 إِنَّا أَيِي سِيذِي: ’كَّارْ، هْوَا ذغْيَا سَّا، مِينْزِي ڒْڭنْسْ نّشْ، ونِّي ثْنذْهذْ زِي مِيصْرَا، أَقَا إِضيّعْ إِ-ث. ودَّارنْ ذغْيَا أَبْرِيذْ نِّي إِ خْ ثنْ وصِّيغْ. ڭِّينْ إِ يِيخفْ نْسنْ إِجّْ ن ڒخْيَاڒْ إِفسْينْ.‘  
\v 13 إِسِّيوڒْ أَكِيذِي سِيذِي عَاوذْ، إِنَّا: ’نشّْ ژْرِيغْ ڒْڭنْسْ-أَ، ؤُشَا خْزَارْ، نتَّا ذ إِجّْ ن ڒْڭنْسْ إِقْسحْ. \x ◘ \xo 9:‏13 \xt ؤُف. 32‏:‏9؛ 33‏:‏3؛ 34‏:‏9؛ أَعَوذ. 10‏:‏16؛ 31‏:‏27؛ 2 إِج. 17‏:‏14\x*  
\v 14 أجّْ أَيِي أَذْ ثنْ ثحِّيغْ ؤُ أَذْ مْحِيغْ إِسمْ نْسنْ زِي سْوَادَّايْ ن ؤُجنَّا، أَذْ شكْ ڭّغْ ذ إِجّْ ن ڒْڭنْسْ إِجهْذنْ ؤُ إِمْغَارْ خْ وَانِيثَا.‘ “\x ◘ \xo 9:‏14 \xt ؤُف. 32‏:‏10؛ إِزهد. 106‏:‏23\x*   
\m
\v 15 ”ؤُشَا ذوْڒغْ-د، هْوِيغْ-د زڭْ وذْرَارْ. ثُوغَا أَذْرَارْ يَارقّْ س ثْمسِّي ؤُ ثُوغَا غَارِي ثْنَاينْ ن ثڒْوِيحِينْ ن ڒْعَاهْذْ ذِي ثْنَاينْ ن إِفَاسّنْ إِنُو.  
\v 16 ژْرِيغْ، أَقَا ذَا، كنِّيوْ ثخْضَامْ أَكْ-ذ سِيذِي، أَربِّي نْومْ. ثڭِّيمْ إِ يِيخفْ نْومْ إِجّْ ن ؤُعجْمِي إِفسْينْ. كنِّيوْ ثِيڭّْوجمْ ذغْيَا خْ وبْرِيذْ نِّي خْ ذ أَومْ يُومُورْ سِيذِي. \f ◼ \fr 9:‏16 \ft \+bd ’أَعجْمِي‘\+bd* - نِيغْ ’أَمْوَا‘، ’أَينْذُوزْ‘ نِيغْ ’يُوڭُّو‘. ؤُڒَا ذِي أَيثْ 21.\f*  
\v 17 \add خنِّي\add* طّْفغْ ثْنَاينْ ن ثڒْوِيحِينْ، نْضَارغْ ثنْثْ زِي ثْنَاينْ ن إِفَاسّنْ إِنُو، أَرْژِيغْ ثنْثْ زَّاثْ إِ ثِيطَّاوِينْ نْومْ.  
\v 18 وْضِيغْ \add غَارْ ثمُّورْثْ\add* زَّاثْ إِ وُوذمْ ن سِيذِي أَمْ ؤُمُورْ أَمزْوَارُو، أَربْعِينْ ن وُوسَّانْ ذ أَربْعِينْ ن دْجْيَاڒِي وَارْ شِّيغْ أَغْرُومْ ؤُ وَارْ سْوِيغْ أَمَانْ ذِي سِّيبّثْ ن دّْنُوبْ إِ ثڭِّيمْ ؤُمِي ثڭِّيمْ مِينْ إِدْجَانْ ذ ڒْغَارْ ذِي ثِيطَّاوِينْ ن سِيذِي ؤُ ؤُمِي ث ثسْعَارمْ.  
\v 19 مِينْزِي ڭّْوذغْ زڭْ وغْضَابْ ذ وسْعَارْ إِ زِي خَاومْ ثُوغَا سِيذِي إِفُّوڭمْ ؤُ ثُوغَا إِخْسْ أَذْ كنِّيوْ إِثحَّا. \add مَاشَا\add* سِيذِي إِسْڒَا أَيِي عَاذْ ثْوَاڒَا-يَا.  
\v 20 ثُوغَا سِيذِي عَاوذْ إِسْعَارْ أَطَّاسْ خْ هَارُونْ أَڒَامِي ثُوغَا إِخْسْ أَذْ ث إِثحَّا. ژُّودْجغْ عَاوذْ ذِي طّْوعْ ن هَارُونْ ذِي ڒْوقْثْ نِّي ذ إِجّنْ.  
\v 21 دّنْبْ نْومْ، ونِّي ذ أَعجْمِي نِّي ثڭِّيمْ، كْسِيغْ ث ؤُشَا سّْشمْضغْ ث ذِي ثْمسِّي، شدْجْقغْ ث، هَارْيغْ ث مْلِيحْ، أَڒَامِي إِذْوڒْ ذ إِفْسُوسْ أَمْ ثْعجَّاجْثْ ؤُشَا نْضَارغْ ثَاعجَّاشْثْ نّسْ ذِي ثغْزَارْثْ نِّي د-إِهكّْوَانْ زڭْ وذْرَارْ. \x ◘ \xo 9:‏21 \xt ؤُف. 32‏:‏20\x*  
\v 22 ثَانْيَا ذِي ثَابْعِيرَا، ذِي مَاسَّا ؤُ ذِي قَابَارُوثْ-هَاثَاآوَاثْ ثسّْفُّوڭْممْ سِيذِي. \x ◘ \xo 9:‏22 \xt ؤُف. 17‏:‏7؛ ڒخْڒ. 11‏:‏1،4، 34\x*  
\v 23 ؤُشَا ؤُمِي كنِّيوْ إِسّكّْ سِيذِي زِي قَاذَاشْ-بَارْنِيعْ، إِنَّا: ’أَڒْيمْ ؤُ طّْفمْ ثَامُّورْثْ ذ ڒْوَارْثْ، \add ثَامُّورْثْ\add* نِّي إِ ذ أَومْ وْشِيغْ نشّْ!‘، ثُوغَا كنِّيوْ \add عَاوذْ\add* ثْغوّْغمْ خْ \add ڒُْومُورْ زڭْ\add* ؤُقمُّومْ ن سِيذِي، أَربِّي نْومْ، وَارْ ثُومِينمْ، وَارْ ثسْڒِيمْ إِ ثْمِيجَّا نّسْ. \x ◘ \xo 9:‏23 \xt ڒخْڒ. 13‏:‏3؛ 14‏:‏1\x*  
\v 24 ثُوغَا كنِّيوْ ثْغوّْغمْ خْ سِيذِي زڭْ وَاسّْ نِّي كنِّيوْ سّْنغْ.   
\b  
\m  
\s1 ثَاژَادْجِيثْ ن مُوسَا  
\m
\v 25 غنْسغْ إِخفْ إِنُو زَّاثْ إِ وُوذمْ ن سِيذِي، \add مَارَّا\add* أَربْعِينْ ن وُوسَّانْ ذ أَربْعِينْ ن دْجْيَاڒِي نِّي، ثُوغَا أَيِي \add ذِينْ\add*غنْسغْ زَّاثْ إِ وُوذمْ ن سِيذِي، مِينْزِي سِيذِي إِنَّا، بلِّي نتَّا أَذْ كنِّيوْ إِثحَّا.  
\v 26 ژُودْجغْ إِ سِيذِي ؤُشَا نِّيغْ: ’\add أَ\add* سِيذِي إِنُو، سِيذِي، وَارْ تّْهلَّاكْ ڒْڭنْسْ ذ ڒْوَارْثْ نّشْ، ونِّي ثْفكّذْ س ڒمْغَارثْ نّشْ، أَقَا شكْ ثْنذْهذْ ثنْ زِي مِيصْرَا س ؤُفُوسْ نّشْ إِجهْذنْ.\x ◘ \xo 9:‏26 \xt ؤُف. 32‏:‏11؛ ڒخْڒ. 14‏:‏13\x*  
\v 27 إِذَارْ إِمْسخَّارنْ نّشْ، إِبْرَاهِيمْ، إِسْحَاقْ ذ يَاعْقُوبْ، وَارْ خزَّارْ غَارْ ثْغنَّانْثْ ن ڒْڭنْسْ-أَ ؤُڒَا غَارْ ثُوعفّْنَا نّسْ ذ دّنْبْ نّسْ،  
\v 28 حِيمَا، إِنِّي \add ذِي\add* ثمُّورْثْ إِ زِي ذ أَنغْ د-ثسُّوفّْغذْ، وَارْ قَّارنْ: مِينْزِي سِيذِي وَارْ إِزمَّارْ أَذْ ثنْ إِسِّيذفْ ذِي ثمُّورْثْ إِ خْ ثُوغَا كِيسنْ إِسَّاوَاڒْ، ؤُ مِينْزِي إِشَارْهْ إِ-ثنْ، أَقَا إِسُّوفّغْ إِ-ثنْ-د مَاحنْذْ أَذْ ثنْ إِنغْ ذِي ڒخْڒَا. \x ◘ \xo 9:‏28 \xt ؤُف. 32‏:‏12؛ ڒخْڒ. 14‏:‏16\x*  
\v 29 أَقَا نِيثْنِي ذ ڒْڭنْسْ نّشْ ذ ڒْوَارْثْ نّشْ، ونِّي د-ثسُّوفّْغذْ س ثْزمَّارْ نّشْ ثَامقّْرَانْثْ ؤُ س ؤُغِيڒْ نّشْ إِسّْوِيژّْضنْ!‘ “   
\b  
\b  
\m  
\c 10
\s1 ثْنَاينْ ن ثڒْوِيحِينْ نّغْنِي ن وژْرُو  
\m
\v 1 ”ذِي ڒْوقْثْ نِّي ذ إِجّنْ إِنَّا أَيِي سِيذِي: ’نْقشْ ثْنَاينْ ن ثڒْوِيحِينْ ن وژْرُو أَمْ ثِينِّي ثِيمزْوُورَا ؤُشَا ڭعّذْ-د غَارِي غَارْ وذْرَارْ ؤُشَا أڭّْ إِ شكْ إِشْثْ ن تَّابُوثْ ن ؤُكشُّوضْ. \x ◘ \xo 10:‏1 \xt ؤُف. 34‏:‏1\x*  
\v 2 أَذْ أَرِيغْ ذِي ثڒْوِيحِينْ أَوَاڒنْ نِّي ثُوغَا ذِي ثڒْوِيحِينْ ثِيمزْوُورَا نِّي ثَارْژِيذْ ؤُشَا أَذْ ثنْثْ ثسَّارْسذْ ذِي تَّابُوثْ.  
\v 3 نشّْ ڭِّيغْ إِشْثْ ن تَّابُوثْ ن ؤُكشُّوضْ ن ؤُكَاسِييَا ؤُشَا نقْشغْ ثْنَاينْ ن ثڒْوِيحِينْ ن وژْرُو أَمْ ثْمزْوُورَا. ڭعّْذغْ غَارْ وذْرَارْ س ثْنَاينْ ن ثڒْوِيحِينْ ذڭْ ؤُفُوسْ إِنُو.  
\v 4 يُورَا خْ ثڒْوِيحِينْ، أَنشْثْ ن ثِيرَا ثَامزْوَارُوثْ،عشْرَا ن وَاوَاڒنْ نِّي ثُوغَا إِسِّيوڒْ سِيذِي ذڭْ وَاسّْ ن وڭْرَاوْ \add ن ڒْڭنْسْ\add* خْ وذْرَارْ زِي ڒْوسْطْ ن ثْمسِّي ؤُشَا إِوْشَا إِ-ثنْثْ أَيِي-د سِيذِي.  
\v 5 ذوْڒغْ-د ؤُ هْوِيغْ-د زڭْ وذْرَارْ ؤُشَا سَّارْسغْ ثِيڒْوِيحِينْ ذِي تَّابُوثْ نِّي ڭِّيغْ ؤُشَا ذِيهَا إِ دْجَانْثْ \add عَاذْ\add*، أَمْ مَامّشْ ذ أَيِي يُومُورْ سِيذِي.“   
\b  
\m
\v 6 فسْينْ أَيْثْ ن إِسْرَائِيل إِقِيضَانْ نْسنْ زِي بِيعْرُوثْ-بَانِي-يَاعْقَانْ، فّْغنْ غَارْ مُوسِيرَا. ذِينِّي إِمُّوثْ هَارُونْ ؤُشَا إِتّْوَانْضڒْ ذِينْ. مِّيسْ أَلِيعَازَارْ إِذْوڒْ ذ أَكهَّانْ ذڭْ ومْشَانْ نّسْ. \x ◘ \xo 10:‏6 \xt ڒخْڒ. 20‏:‏28؛ 33‏:‏30، 38\x*  
\v 7 سّنِّي مُّوطِّيينْ غَارْ جُوذْجُوذْ ؤُ زِي جُوذْجُوذْ غَارْ يُوطْبَاثَا، ثَامُّورْثْ ن ثْغزْرَاثِينْ ن وَامَانْ. \x ◘ \xo 10:‏7 \xt ڒخْڒ. 33‏:‏32، 33\x*  
\v 8 ذِي ڒْوقْثْ نِّي ذ إِجّنْ إِحُوزّْ سِيذِي ثَاقْبِيتْشْ ن لَاوِي حِيمَا أَذْ أَرْبُونْ تَّابُوثْ ن ڒْعَاهْذْ ن سِيذِي مَاحنْذْ أَذْ بدّنْ زَّاثْ إِ وُوذمْ ن سِيذِي، أَذْ أَسْ سخَّارنْ ؤُ أَذْ بَارْكنْ ذڭْ يِيسمْ نّسْ، أَڒْ أَسّْ-أَ.  
\v 9 خْ ؤُيَا لَاوِي وَارْ غَارسْ ثُوغِي شَا ن ثسْغَارْثْ، ؤُڒَا ذ شَا ن ڒْوَارْثْ أَكْ-ذ أَيْثْمَاسْ. سِيذِي ذ ڒْوَارْثْ نّسْ، أَمْ مَامّشْ ذ أَسْ إِنَّا سِيذِي، أَربِّي نّشْ. \x ◘ \xo 10:‏9 \xt ڒخْڒ. 18‏:‏20‏-‏32.؛ أَعَوذ. 18‏:‏1؛ حِز. 44‏:‏28 \x*   
\b  
\m
\v 10 ”ؤُشَا نشّْ قِّيمغْ خْ وذْرَارْ، أَمْ وُوسَّانْ إِمزْوُورَا، أَربْعِينْ ن ؤُسَّانْ ذ أَربْعِينْ ن دْجْيَاڒِي ؤُشَا إِسْڒَا أَيِي سِيذِي عَاوذْ ثْوَاڒَا-يَا، أَقَا سِيذِي ثُوغَا وَارْ إِخْسْ أَذْ كنِّيوْ إِسّخْسَارْ. \x ◘ \xo 10:‏10 \xt أَعَوذ. 9‏:‏18، 19\x*  
\v 11 إِنَّا أَيِي سِيذِي: ’كَّارْ، ؤُيُورْ ذڭْ وبْرِيذْ زَّاثْ إِ وُوذمْ ن ڒْڭنْسْ، حِيمَا أَذْ أَذْفنْ غَارْ ثمُّورْثْ، ثنِّي جُّودْجغْ إِ ڒجْذُوذْ نْسنْ أَذْ أَسنْ ت-إِ-د-وْشغْ، أَذْ ت كْسِينْ ذ ڒْوَارْثْ.‘  
\v 12 ڒخُّو خنِّي، \add أَ\add* إِسْرَائِيل! مِينْ زَّايكْ إِتَّارْ سِيذِي، أَربِّي نّشْ، مْغِيرْ أَذْ ثڭّْوذذْ سِيذِي، أَربِّي نّشْ، أَذْ ثُويُورذْ ذڭْ إِبْرِيذنْ نّسْ ؤُ أَذْ ث ثخْسذْ ؤُشَا أَذْ ثْسخَّارذْ إِ سِيذِي، أَربِّي نّشْ س مَارَّا ؤُڒْ نّشْ ؤُ س مَارَّا ڒعْمَارْ نّشْ، \x ◘ \xo 10:‏12 \xt أَعَوذ. 6‏:‏5؛ مت. 22‏:‏37؛ لك. 10‏:‏27\x*  
\v 13 ؤُشَا أَذْ ثحْضِيذْ ڒُومُورَاثْ ن سِيذِي ذ ثْوصَّا نِّي نشّْ خَاكْ شَارْضغْ أَسّْ-أَ إِ ثِيزِي نّشْ.  
\v 14 خْزَارْ، أَجنَّا ذ ؤُجنَّا ن إِجنْوَانْ ذ مَارَّا مِينْ ذَايسْ إِ سِيذِي، أَربِّي نّشْ إِ إِدْجَانْ. \x ◘ \xo 10:‏14 \xt أَمز. 14‏:‏19؛ إِزهد. 24‏:‏1؛ 115‏:‏16\x*  
\v 15 مْغِيرْ غَارْ ڒجْذُوذْ نّشْ وَاهَا إِ إِقّنْ سِيذِي إِخفْ نّسْ حِيمَا أَذْ ثنْ إِخْسْ ؤُ نتَّا إِخْضَارْ زَّارِيعثْ نْسنْ أَوَارْنِي أَسنْ، أَقَا ذ كنِّيوْ، زِي مَارَّا ڒڭْنُوسْ، أَمْ \add ثدْجَا\add* أَسّْ-أَ.  
\v 16 خثْنمْ خنِّي إِ ڒعْذَاڒْيثْ ن وُوڒْ نْومْ، وَارْ سْقسِّيحمْ شَا عَاذْ كْثَارْ ؤُڒَاونْ نْومْ، \x ◘ \xo 10:‏16 \xt ؤُف. 32‏:‏9؛ 33‏:‏3؛ 34‏:‏9؛ أَعَوذ. 9‏:‏13؛ 30‏:‏6؛ إِرْم. 4‏:‏4 \x*  
\v 17 مِينْزِي سِيذِي، أَربِّي نْومْ، ذ أَربِّي خْ \add مَارَّا\add* إِربِّيثنْ ذ سِيذِي خْ \add مَارَّا\add* إِسِيذِيثنْ، إِجّْ ن أَربِّي إِمْغَارْ ذ أَجبَّارْ ذ أَمڭّْوذْ، ونِّي وَارْ إِتّڭّنْ ڒْفَارْزْ ذڭْ إِوْذَانْ نِيغْ إِكسِّي شَّارْضْ، \x ◘ \xo 10:‏17 \xt 2 إِم. 19‏:‏6، 7؛ أَيُوبْ 34‏:‏19؛ ڒخ. 10‏:‏34؛ رُوم. 2‏:‏11؛ ڭال. 2‏:‏6؛ أَفا. 6‏:‏9؛ كُول. 3‏:‏25؛ 1 بُط. 1‏:‏17؛ أَسَا. 17‏:‏14\x*  
\v 18 ونِّي إِتّڭّنْ ثَاسڭْذَا إِ ؤُيُوجِيڒْ ذ ثَاجَّاتْشْ، ونِّي إِتّخْسنْ أَبَارَّانِي ؤُ إِوْشَا أَسْ أَغْرُومْ ذ أَرُّوضْ.  
\v 19 إِتّْخصَّا أَذْ ثخْسمْ أَبَارَّانِي، مِينْزِي ثُوغَا كنِّيوْ ذ إِبَارَّانِييّنْ ذِي ثمُّورْثْ ن مِيصْرَا.  
\v 20 أَذْ ثڭّْوذذْ سِيذِي، أَربِّي نّشْ، أَذْ أَسْ ثْسخَّارذْ ؤُشَا أَذْ أَسْ ثْڒصْقذْ ؤُ س يِيسمْ نّسْ أَذْ ثجَّادْجذْ. \x ◘ \xo 10:‏20 \xt أَعَوذ. 6‏:‏13؛ 13‏:‏4؛ مت. 4‏:‏10؛ لك. 4‏:‏8\x*  
\v 21 أَقَا نتَّا ذ أَسبَّاحْ نّشْ، ؤُشَا نتَّا ذ أَربِّي نّشْ، ونِّي غَاركْ إِڭِّينْ ڒْخذْمثْ-أَ ذ ثَامقّْرَانْثْ ؤُڒَا ذ \add مَارَّا\add* ثِيمسْڒَايِينْ-أَ إِسَّاڭّْوَاذنْ ثِينِّي ژْرِينْثْ ثِيطَّاوِينْ نّشْ.  
\v 22 ڒجْذُوذْ نْومْ هْوَانْ-د س سبْعِينْ ن ڒعْمُورْ غَارْ مِيصْرَا ؤُشَا ڒخُّو إِڭَّا إِ-شْ سِيذِي، أَربِّي نّشْ، أَطَّاسْ أَمْ يِيثْرَانْ ن ؤُجنَّا.“ \x ◘ \xo 10:‏22 \xt أَمز. 15‏:‏5؛ 46‏:‏27؛ ؤُف. 1‏:‏5؛ ڒخ. 7‏:‏14\x*   
\b  
\b  
\m  
\c 11
\s1 ڒْغِيدْجثْ ن طَّاعثْ ذ ڒْغِيدْجثْ ن ڒْمُوعْصِييّثْ  
\m
\v 1 ”أَذْ ثخْسذْ سِيذِي، أَربِّي نّشْ ؤُشَا أَذْ ثحْضِيذْ مِينْ \add ذ أَشْ\add* يُومُورْ نتَّا، ثِيوصَّا نّسْ ذ لْفَارَايِيضْ نّسْ ذ ڒُومُورَاثْ نّسْ، مَارَّا ؤُسَّانْ.  
\v 2 إِتّْخصَّا أَذْ ثسّْنمْ أَسّْ-أَ، نشّْ وَارْ سِّيوْڒغْ أَكْ-ذ إِحنْجِيرنْ نْومْ، إِنِّي وَارْ ت إِسِّيننْ ؤُ وَارْ ژْرِينْ تَّارْبِييّثْ ن سِيذِي، أَربِّي نْومْ، ذ ڒمْغَارثْ نّسْ ذ ؤُفُوسْ نّسْ إِجهْذنْ ذ ؤُغِيڒْ نّسْ إِسّْوِيژّْضنْ  
\v 3 ذ ڒعْڒَامَاثْ نّسْ ذ ثِيمڭَّا نّسْ، ثِينِّي إِڭَّا ذِي ڒْوسْطْ ن مِيصْرَا، زَّاثْ إِ فِيرْعُونْ، أَجدْجِيذْ ن مِيصْرَا، ؤُ زَّاثْ إِ مَارَّا ثَامُّورْثْ نّسْ،   
\b  
\m
\v 4 ... مِينْ إِڭَّا أَكْ-ذ ڒْعسْكَارْ ن إِمِيصْرِييّنْ ذ إِيْسَانْ نْسنْ ذ إِكَارُّوثنْ نْسنْ، مَامّشْ ذ يَارَّا أَمَانْ ن ڒبْحَارْ ن ثلْڭَا أَذْ فيّْضنْ خْ إِزدْجِيفنْ نْسنْ ؤُمِي كنِّيوْ ضْفَارنْ. أَقَا إِهلّكْ إِ-ثنْ سِيذِي، أَڒْ أَسّْ-أَ،   
\m
\v 5 ... ذ مِينْ أَكِيذْومْ إِڭَّا ذِي ڒخْڒَا أَڒَامِي ثِيوْضمْ غَارْ ومْشَانْ-أَ،   
\m
\v 6 ... ذ مِينْ إِڭَّا أَكْ-ذ ذَاثَانْ ذ أَبِيرَامْ، إِحنْجِيرنْ ن إِلِييَابْ، مِّيسْ ن رُوبِينْ، مَامّشْ ثَارْزمْ ثمُّورْثْ أَقمُّومْ نّسْ ؤُشَا ثْسَارْضْ إِ-ثنْ أَكْ-ذ رَادْجْ نْسنْ ذ إِقِيضَانْ نْسنْ ؤُ أَكْ-ذ مَارَّا إِنِّي \add ذِينْ\add* إِبدّنْ، إِنِّي ثنْ د-إِضْفَارنْ ذڭْ إِصُورَافْ نْسنْ، ذِي ڒْوسْطْ ن مَارَّا إِسْرَائِيل. \x ◘ \xo 11:‏6 \xt ڒخْڒ. 16‏:‏31؛ 27‏:‏3؛ إِزهد. 106‏:‏17\x*   
\b  
\m
\v 7 أَقَا ثِيطَّاوِينْ نْومْ ژْرِينْثْ مَارَّا ثِيمڭَّا ثِيمقّْرَانِينْ ن سِيذِي نِّي ثُوغَا إِڭَّا نتَّا.“  
\v 8 \add خنِّي\add* حْضَامْ مَارَّا ثِيوصَّا نِّي إِ ذ أَومْ ؤُمُورغْ أَسّْ-أَ، حِيمَا أَذْ زَّايْسنْثْ ثْجهْذمْ ؤُشَا أَذْ ثَاذْفمْ غَارْ ثمُّورْثْ إِ غَارْ غَا ثژْوَامْ، مَاحنْذْ أَذْ ت ثطّْفمْ ذ ڒْوَارْثْ، ؤُشَا \add خنِّي\add* أَذْ ت ثطّْفمْ ذ ڒْوَارْثْ، \x ◘ \xo 11:‏8 \xt عِز. 9‏:‏12\x*  
\v 9 ؤُ حِيمَا أَذْ زُّوڭَارْثنْ وُوسَّانْ نْومْ خْ وُوذمْ \add ن ثمُّورْثْ\add* نِّي إِجُّودْجْ سِيذِي إِ ڒجْذُوذْ نْومْ أَذْ أَسنْ ت-إِ-د-إِوْشْ ؤُ إِ زَّارِيعثْ نْسنْ، إِشْثْ ن ثمُّورْثْ إِفيّْضنْ س ؤُغِي ذ ثَامّنْثْ.  
\v 10 مِينْزِي ثَامُّورْثْ نِّي مَانِي ثتّْرَاحذْ حِيمَا أَذْ ت ثطّْفذْ ذ ڒْوَارْثْ، وَارْ ثدْجِي أَمْ ثمُّورْثْ ن مِيصْرَا مَانِيسْ د-ثفّْغمْ، مَانِي ثْزَارْعذْ زَّارِيعثْ نّشْ ؤُ ثنِّي ثسّْوذْ س إِضَارنْ نّشْ أَمْ يِيشْثْ ن ثحْوِيشْثْ ثَازِيزَاوْثْ.  
\v 11 ثَامُّورْثْ إِ غَارْ غَا ثژْوَامْ مَاحنْذْ أَذْ ت ثطّْفمْ ذ ڒْوَارْثْ، أَقَا-ت ذ إِشْثْ ن ثمُّورْثْ ن إِذُورَارْ ذ ثيْسَارِينْ، ثنِّي إِسسّنْ أَمَانْ ن ونْژَارْ زڭْ ؤُجنَّا،  
\v 12 إِشْثْ ن ثمُّورْثْ إِ خْ إِحطَّا سِيذِي، أَربِّي نّشْ، إِ خْ دْجَانْثْ ڒبْذَا ثِيطَّاوِينْ ن سِيذِي، أَربِّي نّشْ، زِي بدُّو ن ؤُسڭّْوَاسْ أَڒْ أَنڭَّارْ ن ؤُسڭّْوَاسْ.  
\v 13 مَاڒَا ثسْڒِيمْ نِيشَانْ إِ ثْوصَّا إِنُو، ثِينِّي ذ أَومْ ؤُمُورغْ أَسّْ-أَ، حِيمَا أَذْ ثخْسمْ سِيذِي، أَربِّي نْومْ، ؤُشَا أَذْ أَسْ ثْسخَّارمْ س مَارَّا ؤُڒْ نْومْ ؤُ س مَارَّا ڒعْمَارْ نْومْ، \add خنِّي\add* أَذْ إِمْسَارْ،  
\v 14 أَقَا نشّْ أَذْ وْشغْ أَنْژَارْ ذِي ثمُّورْثْ نْومْ ذِي ڒْوقْثْ نّسْ، \add أَنْژَارْ\add* ن زِيشْ ذ ؤُنڭَّارْ، حِيمَا أَذْ ثسّْمُونذْ إِرْذنْ نّشْ ذ بِينُو نّشْ ن جْذِيذْ ذ زّشْثْ نّشْ \add ن طّْرِي\add*  
\v 15 ؤُشَا نشّْ أَذْ أَشْ وْشغْ أَرْبِيعْ ذڭْ إِيَّارْ نّشْ إِ ڒبْهَايمْ نّشْ ؤُشَا شكْ أَذْ ثشّذْ ؤُ أَذْ ثجِّيوْنذْ.“   
\b  
\m
\v 16 ”حْضَامْ وَارْ إِتّْوَاسّْغكّْوِي وُوڒْ نْومْ ؤُشَا أَذْ ثفّْغمْ \add زڭْ وبْرِيذْ\add*، أَذْ ثْعبْذمْ إِ إِربِّيثنْ نّغْنِي، أَذْ أَسنْ ثْبنْذْقمْ. \x ◘ \xo 11:‏16 \xt أَعَوذ. 8‏:‏19\x*  
\v 17 إِڒِي \add خنِّي\add* أَذْ خَاومْ يَارغْ وغْضَابْ ن سِيذِي ؤُشَا أَذْ إِقّنْ إِجنْوَانْ مَاحنْذْ وَارْ إِشِّيثْ ونْژَارْ \add عَاذْ\add* ؤُ وَارْ ثتِّيشْ ثمُّورْثْ \add عَاذْ\add* صَّابثْ نّسْ ؤُ كنِّيوْ أَذْ تّْوَارذْدْجمْ ذغْيَا زِي ثمُّورْثْ إِشْنَانْ، ثنِّي إِ ذ أَومْ غَا إِوْشْ سِيذِي.  
\v 18 س ؤُيَا حْضَامْ أَوَاڒنْ-أَ إِنُو ذڭْ وُوڒَاونْ نْومْ ؤُ ذِي ڒعْمَارْ نْومْ ؤُ أَذْ ثنْ ثْبيْسمْ أَمْ يِيشْثْ ن ڒعْڒَامثْ خْ ؤُفُوسْ نْومْ، أَذْ إِڒِينْ ذ إِفِيڒَانْ ن ؤُسڭّمْ خْ ثِيطَّاوِينْ نْومْ \x ◘ \xo 11:‏18 \xt أَعَوذ. 6‏:‏6، 8\x*  
\v 19 ؤُشَا سْڒمْذمْ ثنْ إِ إِحنْجِيرنْ نْومْ أَمْ خَاسنْ ثسَّاوَاڒمْ خْمِي غَا ثِيڒِيمْ ذِي ثُوذْرِينْ نْومْ ؤُ خْمِي غَا ثِيڒِيذْ ذڭْ وبْرِيذْ ؤُ ذڭْ يِيضصْ نّشْ ؤُ خْمِي غَا ثِيڒِيذْ ثْفَاقذْ، \x ◘ \xo 11:‏19 \xt أَعَوذ. 4‏:‏9؛ 6‏:‏7\x*  
\v 20 ؤُ أَرِيمْ ثنْ خْ ڒضْرُوفْ \add غَارْ ؤُغزْذِيسْ ن ثوَّارْثْ\add* ن ثَادَّارْثْ نّشْ ؤُ خْ ثوُّورَا نّشْ  
\v 21 حِيمَا أَذْ كْثَارنْ وُوسَّانْ نْومْ ذ وُوسَّانْ ن إِحنْجِيرنْ نْومْ خْ ثمُّورْثْ، ثنِّي مِينْ خفْ إِجُّودْجْ سِيذِي إِ ڒجْذُوذْ نْومْ أَذْ أَسنْ ثنْ-إِ-د-إِوْشْ، أَمْ وُوسَّانْ ن ؤُجنَّا \add قِّيمنْ كْثَارنْ\add* سنّجْ إِ ثمُّورْثْ.  
\v 22 مِينْزِي مَاڒَا ثحْضَامْ نِيشَانْ مَارَّا ثَاوْصيّثْ-أَ نِّي ذ أَومْ ؤُمُورغْ أَسّْ-أَ مَاحنْذْ أَذْ ت ثڭّمْ ؤُ مَاحنْذْ أَذْ ثخْسمْ سِيذِي، أَربِّي نْومْ، أَذْ ثُويُورمْ ذڭْ إِبْرِيذنْ نّسْ مَارَّا ؤُ أَذْ غَارسْ د-ثْڒصْقمْ،  
\v 23 \add خنِّي\add* سِيذِي أَذْ إِسُّوفّغْ مَارَّا ڒڭْنُوسْ-أَ زَّاثْ إِ وُوذمْ نْومْ ؤُشَا \add أَمُّو إِ\add* غَا ثْوَارْثمْ ثَاسْغَارْثْ ن ڒڭْنُوسْ إِمْغَارنْ ذ إِجهْذنْ خَاومْ.  
\v 24 مَارَّا أَمْشَانْ نِّي إِ غَا ثعْجنْ ثْڒقَّا ن ؤُضَارْ نْومْ أَذْ يِيڒِي نْومْ. زِي ڒخْڒَا ؤُ زِي لُوبْنَانْ، ؤُ زڭْ إِغْزَارْ، إِغْزَارْ ن لْفُورَاطْ، أَڒْ ڒبْحَارْ ذِي ڒْغَارْبْ، أَذْ يِيڒِي ويْمِيرْ \add ن ثمُّورْثْ\add* نّشْ. \x ◘ \xo 11:‏24 \xt ياش. 1‏:‏3؛ 14‏:‏9\x*  
\v 25 وَارْ إِزمَّارْ ؤُڒَا ذ إِجّْ أَذْ إِقِّيمْ إِبدّْ زَّاثْ إِ وُوذمْ نْومْ. سِيذِي، أَربِّي نْومْ، أَذْ إِڭّْ ثِيڭّْوُوذِي ذ ڒْعُورّثْ زَّايْومْ خْ مَارَّا ثَامُّورْثْ نِّي إِ خْ غَا ثْعجْنمْ، أَمْ مَامّشْ ثُوغَا أَكِيذْومْ إِسِّيوڒْ.“ \x ◘ \xo 11:‏25 \xt ؤُف. 23‏:‏27\x*   
\b  
\m
\v 26 ”خْزَارْ، نشّْ أَذْ ڭّغْ أَسّْ-أَ \bd لْبَارَاكَا ذ نّعْڒثْ\bd* زَّاثْ إِ وُوذمْ نْومْ:   
\b  
\m
\v 27 ... لْبَارَاكَا، مَاڒَا أَذْ ثسْڒمْ إِ ثْوصَّا ن سِيذِي، أَربِّي نْومْ، ثِينِّي خْ ذ أَومْ ؤُمُورغْ أَسّْ-أَ،   
\m
\v 28 ... ذ نّعْڒثْ، مَاڒَا وَارْ ثسْڒِيمْ إِ ثْوصَّا ن سِيذِي، أَربِّي نْومْ، ؤُشَا أَذْ ثڭّْوجمْ خْ وبْرِيذْ إِ خْ ذ أَومْ ؤُمُورغْ أَسّْ-أَ، خْ مِينِّي إِ غَا ثضْفَارمْ إِربِّيثنْ نّغْنِي إِ وَارْ ثسِّينمْ شَا.   
\b  
\m
\v 29 خْمِي سِيذِي، أَربِّي نّشْ، أَذْ شكْ إِسِّيذفْ ذِي ثمُّورْثْ نِّي إِ غَارْ غَا ثْرَاحذْ حِيمَا أَذْ ت ثطّْفذْ ذ ڒْوَارْثْ، \add خنِّي\add* أَذْ ثڭّذْ لْبَارَاكَا خْ وذْرَارْ ن جِيرِيزِيمْ ذ نّعْڒثْ خْ وذْرَارْ ن عِيبَالْ. \f ◼ \fr 11:‏29 \ft \+bd ’أَذْ ثڭّذْ‘\+bd* - س ثْعِيبْرَانِيثْ ’أَذْ ثوْشِيذْ‘.\f*  \x ◘ \xo 11:‏29 \xt أَعَوذ. 27‏:‏12، 13؛ ياش. 8‏:‏33\x*  
\v 30 مَا وَارْ دْجِينْ \add إِذُورَارْ نِّي\add* خْ ؤُجمَّاضْ ن لْ-ؤُرْذُونْ، أَوَارْنِي إِ وبْرِيذْ، مَانِيسْ د-ثْنقَّارْ ثْفُوشْثْ، ذِي ثمُّورْثْ ن أَيْثْ ن كنْعَانْ نِّي إِزدّْغنْ ذِي ڒوْضَا، أَرنْذَاذْ نْ جِيلْجَالْ، زَّاثْ إِ ثْشجُّورَا ن يِيڭّْ ن مُورَا؟  
\v 31 مِينْزِي كنِّيوْ أَذْ ثژْوَامْ لْ-ؤُرْذُونْ حِيمَا أَذْ \add ذِينْ\add* ثَاذْفمْ ؤُ حِيمَا أَذْ ثطّْفمْ ثَامُّورْثْ، ثنِّي إِ ذ أَومْ غَا إِوْشْ سِيذِي، ذ ڒْوَارْثْ ؤُ كنِّيوْ أَذْ ت ثْوَارْثمْ ؤُ أَذْ ذَايسْ ثْزذْغمْ.  
\v 32 حْضَامْ \add خنِّي\add* مَارَّا ثِيوصَّا ذ لْفَارَايِيضْ نِّي إِ ذ أَومْ سّشْنغْ أَسّْ-أَ.“   
\b  
\b  
\m  
\c 12
\s1 أَمْشَانْ إِقدّْسنْ  
\m
\v 1 ”ذ ثِينَا ذ ثِيوصَّا ذ لْفَارَايِيضْ نِّي إِ غَا ثحْضَامْ مَاحنْذْ أَذْ ثنْثْ ثڭّمْ ذِي ثمُّورْثْ نِّي إِ ذ أَشْ إِوْشَا سِيذِي، أَربِّي ن ڒجْذُوذْ نّشْ، حِيمَا أَذْ ت ثكْسِيذْ ذ ڒْوَارْثْ، مَارَّا ؤُسَّانْ نِّي إِ غَا ثدَّارمْ كنِّيوْ خْ وُوذمْ ن ثمُّورْثْ.   
\m
\v 2 أَذْ ثَاردّْدْجمْ قَاعْ مَارَّا إِمُوشَانْ مَانِي ثُوغَا سخَّارنْ ڒڭْنُوسْ إِ إِربِّيثنْ نْسنْ، \add مَارَّا إِمُوشَانْ\add* نِّي إِ غَا ثطّْفمْ ذ ڒْوَارْثْ: خْ إِذُورَارْ يُوعْڒَانْ، خْ ثوْرِيرِينْ ؤُ سَاذُو كُوڒْ ثَاشجَّارْثْ ثَازِيزَاوْثْ. \f ◼ \fr 12:‏2 \ft \+bd ’ثَاشجَّارْثْ‘\+bd* - نِيغْ ’أَدَّاڭْ‘ (’إِدَّاڭنْ‘).\f*  \x ◘ \xo 12:‏2 \xt ؤُف. 34‏:‏12، 13؛ أَعَوذ. 7‏:‏5\x*  
\v 3 أَذْ ثنْضَارمْ إِعَالْطَارنْ نْسنْ، أَذْ ثَارْژمْ إِمَايْضُوثنْ نْسنْ \add إِقدّْسنْ\add* ؤُ ثِيربِّينْ نْسنْ ن شْوَارْثِي أَذْ ثنْثْ ثسّْشمْضمْ س ثْمسِّي ؤُشَا أَذْ ثْهذْممْ ڒخْيَاڒَاثْ إِنقْشنْ ن إِربِّيثنْ نْسنْ ؤُشَا أَذْ ثمْحَامْ إِسمْ نْسنْ زڭْ ومْشَانْ نِّي. \x ◘ \xo 12:‏3 \xt ڒقض. 2‏:‏2\x*  
\v 4 \add مِينْزِي أَمُّو\add* وَارْ ثْعبّْذمْ إِ سِيذِي، أَربِّي نْومْ أَمْ \add تّڭّنْ نِيثْنِي\add*،  
\v 5 مَاشَا أَذْ ثَارْزُومْ خْ ومْشَانْ نِّي إِ غَا يِيخْضَارْ سِيذِي، أَربِّي نْومْ، زِي جَارْ مَارَّا ثِيقبَّاڒْ نْومْ، حِيمَا أَذْ ذِينْ إِڭّْ إِسمْ نّسْ، \add وَاهْ،\add* غَارْ ثْزذِّيغْثْ نّسْ إِ غَا ثَارْزُومْ ؤُ ذِينْ إِ غَا ثَاوْضمْ \x ◘ \xo 12:‏5 \xt 2 إِم. 7‏:‏12\x*  
\v 6 ؤُشَا ذِينِّي إِ غَا ثَاوْيمْ ثِيغَارْصَا نْومْ ن وشْمَاضْ ذ ثْغَارْصَا نْومْ ذ ڒعْشُورْ نْومْ ذ ثوْهِيبْثْ نِّي إِسّْڭعّذْ ؤُفُوسْ نْومْ ذ ثوْهِيبِينْ نْومْ س ڒْخَاضَارْ ذ إِمنْزَا ن إِفُونَاسنْ ذ ثْفُونَاسِينْ نْومْ ذ \add إِمنْزَا\add* ن وُودْجِي نْومْ،  
\v 7 ؤُشَا ذِينِّي إِ غَا ثشّمْ زَّاثْ إِ وُوذمْ ن سِيذِي، أَربِّي نْومْ، أَذْ ثْفَارْحمْ، كنِّيوْ ذ \add ڒَْادْجْ ن\add* ثُوذْرِينْ نْومْ، زِي مَارَّا مِينْ إِڭَّا ؤُفُوسْ نْومْ ؤُ زِي مِينْ ذِي كنِّيوْ إِبَاركْ سِيذِي، أَربِّي نّشْ.  
\v 8 وَارْ تّڭّمْ أَمْ مَارَّا مِينْ نتّڭّْ نشِّينْ ذَا أَسّْ-أَ: كُوڒْ أَرْيَازْ \add إِتّڭّْ\add* مِينْ ذ أَسْ إِتّْوَاڒَا نِيشَانْ ذِي ثِيطَّاوِينْ نّسْ.  
\v 9 مِينْزِي أَقَا \add عَاذْ\add* ڒخُّو وَارْ ثُوذِيفمْ شَا غَارْ أَرَّاحثْ ؤُ غَارْ ڒْوَارْثْ نِّي ذ أَومْ إِوْشَا سِيذِي، أَربِّي نّشْ.  
\v 10 خْمِي غَا ثژْوَامْ لْ-ؤُرْذُونْ ؤُشَا أَذْ ثْزذْغمْ ذِي ثمُّورْثْ نِّي ذ أَومْ غَا إِوْشْ سِيذِي، أَربِّي نْومْ، ذ ڒْوَارْثْ، نتَّا أَذْ أَومْ إِوْشْ أَرَّاحثْ زِي مَارَّا ڒْعذْيَانْ نْومْ إِ ذ أَومْ د-إِنّْضنْ ؤُشَا أَذْ ثْزذْغمْ ذِي ڒَامَانْ.  
\v 11 ذِينْ إِ غَا يِيڒِي ومْشَانْ نِّي إِ غَا يِيخْضَارْ سِيذِي، أَربِّي نْومْ، حِيمَا أَذْ إِسّزْذغْ ذِينْ إِسمْ نّسْ ؤُشَا ذِينِّي إِ غَا ثَاوْيمْ مَارَّا مِينْ خْ شكْ ؤُمُورغْ: ثِيغَارْصَا ن وشْمَاضْ نْومْ، ثِيغَارْصَا نْومْ، ڒعْشُورْ نْومْ، ثِيوْهِيبِينْ ن ؤُسْڭعّذْ ن ؤُفُوسْ نْومْ ذ مَارَّا \add ثِيوْهِيبِينْ\add* ن لْوَاعْذْ نِّي إِ غَا ثْوعْذمْ إِ سِيذِي. \x ◘ \xo 12:‏11 \xt 1 إِج. 8‏:‏29\x*  
\v 12 أَذْ ثْفَارْحمْ زَّاثْ إِ وُوذمْ ن سِيذِي، أَربِّي نْومْ، كنِّيوْ ذ إِحنْجِيرنْ نْومْ ذ ثْحنْجِيرِينْ نْومْ ذ إِسمْغَانْ نْومْ ذ ثِييَّا نْومْ ذ ؤُلَاوِي نِّي إِزدّْغنْ ذَاخڒْ إِ ثوُّورَا نْومْ، مِينْزِي وَارْ غَارسْ ثَاسْغَارْثْ نِيغْ ڒْوَارْثْ أَكِيذْومْ. \x ◘ \xo 12:‏12 \xt ڒخْڒ. 18‏:‏20؛ أَعَوذ. 10‏:‏9؛ 18‏:‏1\x*  
\v 13 حْضَا وَارْ سّْبخَّارَا ثِيغَارْصَا نّشْ ن وشْمَاضْ ذِي مِينْ مَا أَمْشَانْ نِّي ثْوَاڒِيذْ،  
\v 14 مَاشَا \add وَاهَا\add* ذڭْ ومْشَانْ نِّي إِ غَا يِيخْضَارْ سِيذِي ذڭْ إِشْثنْ زِي ثْقبَّاڒْ نّشْ، ذِينِّي \add وَاهَا\add* إِ غَا ثسّْبخَّارذْ ثِيغَارْصَا ن وشْمَاضْ ؤُشَا ذِينِّي إِ غَا ثڭّذْ مَارَّا مِينْ ذ أَشْ ؤُمُورغْ.   
\b  
\m  
\s1 ثَاوْصيّثْ خْ إِذَامّنْ ؤُ ضِيدّْ إِ وعْبذْ ن لْ-أَصْنَامْ ن ڒڭْنُوسْ  
\m
\v 15 س مَارَّا ثْزمَّارذْ أَذْ ثْغَارْصذْ ذَاخڒْ إِ ثوُّورَا نّشْ مَارَّا مِينْ إِمّژْرِي وُوڒْ نّشْ ؤُشَا أَذْ \add زَّايسْ\add* ثشّذْ عْلَاحْسَابْ لْبَارَاكَا نِّي ذ أَشْ غَا إِوْشْ سِيذِي، أَربِّي نّشْ، ذَاخڒْ إِ ثوُّورَا نّشْ. أَمخْمُوجْ ذ ؤُمزْذَاڭْ زمَّارنْ أَذْ زَّايسْ شّنْ، أَخْمِي \add تّتّنْ زڭْ\add* إِغَايْضْ ن وزْغَارْ ؤُ \add زڭْ\add* ؤُذَاذْ.  
\v 16 مْغِيرْ إِذَامّنْ وَارْ ثنْ ثتّتّذْ. أَذْ ثنْ ثْنغْڒذْ خْ ثمُّورْثْ أَمْ وَامَانْ. \x ◘ \xo 12:‏16 \xt أَمز. 9‏:‏4؛ لَاوِي 7‏:‏26؛ 17‏:‏10؛ أَعَوذ. 15‏:‏23\x*  
\v 17 وَارْ إِعدّڒْ أَذْ ثشّذْ ذَاخڒْ إِ ثوُّورَا نّشْ زِي ڒعْشُورْ ن إِرْذنْ ذ بِينُو نّشْ ن جْذِيذْ ذ زّشْثْ نّشْ \add ن طّْرِي\add* ؤُڒَا زڭْ إِمنْزَا ن إِفُونَاسنْ ذ ثْفُونَاسِينْ ذ وُودْجِي نّشْ نِيغْ زِي ثوْهِيبِينْ ن وَاوَاڒْ إِ ثوْشِيذْ نِيغْ زِي ثوْهِيبِينْ س ڒْخَاضَارْ نِيغْ زِي ثوْهِيبْثْ نِّي إِسّْڭعّذْ ؤُفُوسْ نّشْ.  
\v 18 مِينْزِي أَذْ ثنْ ثشّذْ زَّاثْ إِ وُوذمْ ن سِيذِي، أَربِّي نّشْ، ذڭْ ومْشَانْ نِّي غَا يِيخْضَارْ سِيذِي، أَربِّي نّشْ، شكْ، مِّيشْ، يدْجِيشْ، إِسْمغْ نّشْ، ثَايَّا نّشْ ذ ؤُلَاوِي نِّي إِزدّْغنْ ذَاخڒْ إِ ثوُّورَا نّشْ ؤُشَا أَذْ ثْفَارْحذْ زَّاثْ إِ وُوذمْ ن سِيذِي، أَربِّي نّشْ، ذِي مَارَّا مِينْ غَارْ غَا إِسّْوِيژّذْ ؤُفُوسْ نّشْ.  
\v 19 حْضَا، وَارْ سمّحْ \add غَارْ ؤُزدْجِيفْ نّسْ\add* أَلَاوِي ذِي مَارَّا ؤُسَّانْ نّشْ خْ ثمُّورْثْ نّشْ.“   
\b  
\m
\v 20 ”خْمِي سِيذِي، أَربِّي نّشْ، أَذْ إِسِّييْرُو أَيْمِيرْ \add ن ثمُّورْثْ\add* نّشْ، أَمْ مَامّشْ ذ أَشْ إِنَّا، ؤُشَا أَذْ ثِينِيذْ: ’خْسغْ أَذْ شّغْ أَيْسُومْ‘، مِينْزِي إِمّژْرِي ڒعْمَارْ نّشْ أَذْ يشّْ أَيْسُومْ، \add خنِّي\add* أَذْ ثشّذْ أَيْسُومْ أَنشْثْ ن مَارَّا مِينْ إِمژْرِي ڒعْمَارْ نّشْ. \f ◼ \fr 12:‏20 \ft \+bd ’إِسِّييْرُو‘\+bd* - نِيغْ ’إِوسّعْ‘.\f*  \x ◘ \xo 12:‏20 \xt أَمز. 9‏:‏4؛ لَاوِي 7‏:‏26؛ 17‏:‏10؛ أَعَوذ. 15‏:‏23\x*  
\v 21 مَاڒَا ثُوغَا شكْ ثِيڭّْوجذْ خْ ومْشَانْ نِّي إِ غَا يِيخْضَارْ سِيذِي، أَربِّي نّشْ، حِيمَا أَذْ ذِينْ إِسّمْثنْ إِسمْ نّسْ، \add خنِّي\add* ثْزمَّارذْ أَذْ ثْغَارْصذْ زڭْ إِفُونَاسنْ ذ ثْفُونَاسِينْ نّشْ ؤُ زڭْ وُودْجِي نّشْ نِّي ذ أَشْ إِوْشَا سِيذِي، أَمْ مَامّشْ شكْ ؤُمُورغْ، ؤُشَا أَذْ زَّايسْ ثشّذْ ذَاخڒْ إِ ثوُّورَا نّشْ أَنشْثْ ن مَارَّا مِينْ ذَايسْ إِمّژْرِي ڒعْمَارْ نّشْ.  
\v 22 أَمْ مَامّشْ إِتّْوَاشّْ إِغَايْضْ ن وزْغَارْ ذ ؤُذَاذْ، أَمنِّي إِ زَّايسْ غَا ثشّذْ. أَمخْمُوجْ ذ ؤُمزْذَاڭْ زمَّارنْ أَذْ زَّايسْ شّنْ.  
\v 23 مْغِيرْ وَارْ تّتّْعمَّارْصْ زڭْ إِذَامّنْ، مِينْزِي إِذَامّنْ ذ ڒعْمَارْ. وَارْ تّتّْ ڒعْمَارْ أَكْ-ذ ويْسُومْ.  
\v 24 وَارْ ثنْ ثتّتّذْ، \add مَاشَا\add* أَذْ ثنْ ثْنغْڒذْ خْ ثمُّورْثْ أَمْ وَامَانْ.  
\v 25 وَارْ ثنْ ثتّتّذْ، حِيمَا أَذْ ثِيڒِيذْ شكْ مْلِيحْ ذ إِحنْجِيرنْ نّشْ أَوَارْنِي أَشْ، خْمِي غَا ثڭّذْ مِينْ إِسڭّْذنْ زَّاثْ إِ ثِيطَّاوِينْ ن سِيذِي.  
\v 26 أَذْ ثَاوْيذْ مْغِيرْ ثِيمسْڒَايِينْ نِّي غَاركْ قدّْسنْثْ ذ \add ثْغَارْصَا ن\add* لْوَاعْذْ نّشْ ؤُشَا أَذْ \add كِيذْسنْثْ\add* د-ثَاسذْ غَارْ ومْشَانْ إِ غَا يِيخْضَارْ سِيذِي  
\v 27 ؤُشَا أَذْ ثسّْوجْذذْ ثِيغَارْصَا ن وشْمَاضْ، أَيْسُومْ نّسْ ذ إِذَامّنْ نّسْ، خْ ؤُعَالْطَارْ ن سِيذِي، أَربِّي نّشْ، ؤُشَا إِذَامّنْ ن ثْغَارْصَا أَذْ تّْوَازدْجْعنْ خْ ؤُعَالْطَارْ ن سِيذِي، أَربِّي نّشْ، \add مَاشَا\add* إِعدّڒْ أَذْ ثشّذْ أَيْسُومْ.  
\v 28 حْضَا، ؤُ سڒْ إِ مَارَّا أَوَاڒنْ-أَ نِّي ذ أَشْ ؤُمُورغْ، حِيمَا أَذْ ثِيڒِيذْ مْلِيحْ، شكْ ذ إِحنْجِيرنْ نّشْ أَوَارْنِي أَشْ إِ ڒبْذَا، ؤُمِي غَا ثڭّذْ مِينْ إِشْنَانْ ذ مِينْ إِسڭّْذنْ ذِي ثِيطَّاوِينْ ن سِيذِي، أَربِّي نّشْ.“   
\b  
\m
\v 29 ”خْمِي غَا إِثحَّا سِيذِي، أَربِّي نّشْ، ڒڭْنُوسْ مَانِي غَا ثْرَاحذْ حِيمَا أَذْ ثنْ ثكْسِيذْ ذ ڒْوَارْثْ ؤُشَا \add خنِّي\add* شكْ أَذْ ثنْ ثكْسِيذْ ذ ڒْوَارْثْ ؤُشَا أَذْ ثْزذْغذْ ذِي ثمُّورْثْ نْسنْ،  
\v 30 حْضَا مَاحنْذْ وَارْ ثْضفَّارذْ أَوَارْنِي أَسنْ ذِي ڒْفخْ ذ إِشْثْ، أَوَارْنِي مَا أَذْ تّْوَاثحَّانْ زَّاثْ إِ وُوذمْ نّشْ، ؤُشَا أَذْ ثَارْزُوذْ خْ إِربِّيثنْ نْسنْ، أَذْ ثِينِيذْ: ’أَمْ مَامّشْ سخَّارنْ نِيثْنِي إِ إِربِّيثنْ نْسنْ، أَمُّو إِ غَا ڭّغْ ؤُڒَا ذ نشّْ.‘  
\v 31 وَارْ تّڭّْ أَمنِّي إِ سِيذِي، أَربِّي نّشْ، مِينْزِي مَارَّا مِينْ إِدْجَانْ ذ جّْعِيفشْثْ إِ سِيذِي ذ مِينْ إِشَارّهْ نتَّا، أَقَا ڭِّينْ ث نِيثْنِي إِ إِربِّيثنْ نْسنْ. عَاذْ سّْشمْضنْ إِحنْجِيرنْ نْسنْ ذ يسِّيثْسنْ ذِي ثْمسِّي إِ إِربِّيثنْ نْسنْ.“   
\b  
\b  
\m  
\c 13
\s1 خْ إِنَابِييّنْ إِسّْخَارِّيقنْ ؤُ خْ وعْبذْ ن لْ-أَصْنَامْ  
\m
\v 1 ”مَارَّا أَوَاڒْ نِّي خْ كنِّيوْ وصِّيغْ، أَذْ ث ثحْضَامْ أَذْ زَّايسْ ثڭّمْ. وَارْ غَارسْ أَرنِّي ؤُ وَارْ زَّايسْ تّكّسْ. \x ◘ \xo 13:‏1 \xt أَعَوذ. 4‏:‏2؛ أَوڒن. 30‏:‏6؛ أَسَا. 22‏:‏18\x*   
\m
\v 2 مَاڒَا إِكَّارْ إِجّْ ن ؤُنَابِي نِيغْ إِجّْ ن ؤُمرْجِي ن ثِيرْجَا ذِي ڒْوسْطْ نّشْ ؤُشَا إِڭَّا شَا ن ڒعْڒَامثْ نِيغْ س شَا ن لْمُوعْجِيزَا غَاركْ،  
\v 3 ؤُشَا ڒعْڒَامثْ نِّي نِيغْ لْمُوعْجِيزَا نِّي خْ ذ أَشْ إِسِّيوڒْ ثمْسَارْ ؤُشَا \add خنِّي\add* إِنَّا: ’أجّْ أَذْ نُويُورْ أَوَارْنِي إِ إِربِّيثنْ نّغْنِي!‘، إِنِّي وَارْ ثسِّينذْ، ؤُشَا: ’أجّْ أَنغْ أَذْ أَسنْ نعْبذْ!‘،  
\v 4 \add خنِّي\add* وَارْ تّسْڒِي إِ وَاوَاڒنْ ن ؤُنَابِي نِّي نِيغْ ن ؤُمرْجِي ن ثِيرْجَا نِّي، مِينْزِي سِيذِي، أَربِّي نْومْ، إِتّْقدْجَابْ كنِّيوْ، حِيمَا أَذْ إِسّنْ مَا ثتّخْسمْ سِيذِي، أَربِّي نْومْ س مَارَّا ؤُڒْ نْومْ ؤُ س مَارَّا ڒعْمَارْ نْومْ.  
\v 5 أَذْ ثُويُورمْ أَوَارْنِي إِ سِيذِي، أَربِّي نْومْ، أَذْ زَّايسْ ثڭّْوْذمْ، أَذْ ثطّْفمْ ذِي ثْوصَّا نّسْ، أَذْ ثسْڒمْ إِ ثْمِيجَّا نّسْ، أَذْ أَسْ ثْسخَّارمْ ؤُ أَذْ ذَايسْ ثْڒصْقمْ. \x ◘ \xo 13:‏5 \xt أَعَوذ. 10‏:‏20\x*  
\v 6 إِتّْخصَّا أَذْ إِتّْوَانغْ ؤُنَابِي نِّي نِيغْ ؤُمرْجِي نِّي ن ثِيرْجَا، مِينْزِي إِسِّيوڒْ خْ ڒَاڭّْوَاجثْ خْ وبْرِيذْ ن سِيذِي، أَربِّي نْومْ - ونِّي كنِّيوْ إِسُّوفّْغنْ زِي ثمُّورْثْ ن مِيصْرَا، ذ ونِّي شكْ إِفْذِينْ زِي ثَادَّارْثْ ن ثسْمُوغِي - مَاحنْذْ أَذْ شكْ إِسُّوفّغْ زڭْ وبْرِيذْ نِّي خْ يُومُورْ سِيذِي، أَربِّي نّشْ، أَذْ \add ذَايسْ\add* ثُويُورذْ. إِتّْخصَّا أَذْ ثكّْسذْ ڒْغَارْ زِي ڒْوسْطْ نّشْ. \f ◼ \fr 13:‏6 \ft \+bd ’إِفْذِينْ‘\+bd* - خْزَارْ إِزهد. 78:35.\f*  \x ◘ \xo 13:‏6 \xt أَعَوذ. 18‏:‏20؛ إِرْم. 14‏:‏15\x*   
\m
\v 7 مَاڒَا ؤُمَاشْ، مِّيسْ ن يمَّاشْ، نِيغْ مِّيشْ نِيغْ يدْجِيشْ نِيغْ ثَامْغَارْثْ ن وُوڒْ نّشْ نِيغْ أَمدُّوكّڒْ نّشْ نِّي إِ إِدْجَانْ أَمْ ڒعْمَارْ نّشْ، أَذْ شكْ إِغَارْ س ثْنُوفّْرَا أَذْ يِينِي: ’أجّْ أَنغْ أَذْ نُويُورْ أَذْ نْسخَّارْ إِ إِربِّيثنْ نّغْنِي!‘ إِنِّي وَارْ ثسِّينذْ شَا شكْ ؤُڒَا ذ ڒجْذُوذْ نّشْ، \x ◘ \xo 13:‏7 \xt أَعَوذ. 17‏:‏2\x*  
\v 8 إِنِّي إِدْجَانْ زڭْ إِربِّيثنْ ن ڒڭْنُوسْ إِ ذ أَشْ-د إِنّْضنْ، إِنِّي يُوذْسنْ نِيغْ إِنِّي خَاكْ إِڭّْوجنْ زِي طَّارْفْ ن ثمُّورْثْ أَڒْ طَّارْفْ نّغْنِي،  
\v 9 \add خنِّي\add* وَارْ خَاسْ تّڭّْ شَا، وَارْ غَارسْ تّسْڒِي شَا. وَارْ ث أَرحّمْ شَا، وَارْ ذ أَشْ إِزِّيدْجِيزْ شَا نِيغْ أَذْ ث ثفَّارذْ،  
\v 10 مَاشَا إِتّْخصَّا أَذْ ث ثنْغذْ نِيشَانْ. أَفُوسْ نّشْ أَذْ خَاسْ يِيڒِي ذ أَمزْوَارُو، مَاحنْذْ أَذْ ث ثنْغذْ ؤُ خنِّي \add أَذْ خَاسْ يِيڒِي\add* ؤُفُوسْ ن ڒْڭنْسْ مَارَّا. \x ◘ \xo 13:‏10 \xt أَعَوذ. 17‏:‏7\x*  
\v 11 أَذْ ث ثْحجَّارمْ س يژْرَا أَڒْ غَا إِمّثْ، مِينْزِي ثُوغَا يَارزُّو أَذْ شكْ إِسِّيڭّْوجْ خْ سِيذِي، أَربِّي نّشْ، ونِّي إِ شكْ د-إِسُّوفّْغنْ زِي ثمُّورْثْ ن مِيصْرَا، زِي ثَادَّارْثْ ن ثسْمُوغِي.  
\v 12 مَارَّا إِسْرَائِيل أَذْ سْڒنْ ؤُشَا أَذْ ڭّْوذنْ، \add أَڒَامِي\add* وَارْ د-ذِيكّْوِيڒنْ أَذْ ڭّنْ ڒْغَارْ-أَ ذِي ڒْوسْطْ نّشْ.“ \x ◘ \xo 13:‏12 \xt أَعَوذ. 17‏:‏13\x*   
\b  
\m
\v 13 ”مَاڒَا ثسْڒِيذْ أَقَا قَّارنْ ذڭْ إِشْثنْ زِي ثْندَّامْ نِّي إِ ذ أَومْ غَا إِوْشْ سِيذِي حِيمَا أَذْ ذَايْسنْثْ ثْزذْغذْ:  
\v 14 ’أَقَا فّْغنْ-د زِي ڒْوسْطْ نْومْ يرْيَازنْ، أَيْثْ إِ وَارْ إِسكّْوِينْ، ؤُشَا سّْغكّْوَانْ إِمزْذَاغْ ن ثنْذِينْثْ نْسنْ، قَّارنْ: أجّْ أَذْ نْرَاحْ أَذْ نعْبذْ إِربِّيثنْ نّغْنِي، إِنِّي وَارْ ثسِّينمْ!‘،  
\v 15 \add خنِّي\add* أَذْ ثَارْزُوذْ ؤُ أَذْ ثسّقْسِيذْ مْلِيحْ، ؤُ خْزَارْ، مَاڒَا ثُوفِيذْ ثَامسْڒَاشْثْ نِّي ثْبدّْ خْ ثِيذتّْ، أَقَا جّْعِيفشْثْ نِّي ثتّْوَاڭّْ ذِي ڒْوسْطْ نّشْ،  
\v 16 \add ڒخْذنِّي\add* أَذْ ثڭّذْ إِشْثْ ن ثشْثِي إِ إِمزْذَاغْ ن ثنْذِينْثْ س ڒقْضعْ ن سِّيفْ. أَذْ ت ثْحَارّْمذْ إِ ؤُثحِّي س مَارَّا مِينْ ذَايسْ، ؤُڒَا ذ ڒبْهَايمْ نّسْ، س ڒقْضعْ ن سِّيفْ.  
\v 17 أَذْ ثسّْمُونذْ مَارَّا ثَاكشَّاضْثْ نّسْ غَارْ ڒْوسْطْ ن وَازَّايْ نّسْ، أَذْ ثسّشْمضْ ثَانْذِينْثْ س ثْمسِّي أَكْ-ذ مَارَّا ثَاكشَّاضْثْ إِ ذَايسْ، إِ سِيذِي، أَربِّي نّشْ، ؤُشَا أَذْ ثذْوڒْ \add ثنْذِينْثْ\add* ذ إِشْثْ ن ڒْخَارْبثْ إِ ڒبْذَا،عمَّارْصْ أَذْ ثتّْوَابْنَا عَاوذْ.  
\v 18 وَارْ تّجِّي مِينْ إِتّْوَاحَارّْمنْ \add إِ ؤُثحِّي\add* أَذْ إِقِّيمْ إِڒصّقْ جَارْ إِفَاسّنْ نّشْ، حِيمَا سِيذِي أَذْ \add خَاكْ\add* إِسِّيڭّْوجْ ڒْحَاذُوقْ ن وغْضَابْ نّسْ ؤُشَا أَذْ أَشْ إِوْشْ أَرّحْمثْ، أَذْ شكْ يَارْحمْ أَذْ شكْ يَارْنِي، أَمْ مَامّشْ إِجُّودْجْ إِ ڒجْذُوذْ نّشْ،  
\v 19 خْمِي غَا ثسْڒذْ غَارْ ثْمِيجَّا ن سِيذِي، أَربِّي نّشْ، حِيمَا أَذْ ثحْضِيذْ مَارَّا ثِيوصَّا نّسْ، ثِينِّي إِ خْ ذ أَشْ وصِّيغْ أَسّْ-أَ، ؤُ حِيمَا أَذْ ثڭّذْ مِينْ إِسڭّْذنْ ذِي ثِيطَّاوِينْ ن سِيذِي، أَربِّي نّشْ.“   
\b  
\b  
\m  
\c 14
\m
\v 1 ”كنِّيوْ ذ إِحنْجِيرنْ ن سِيذِي، أَربِّي نْومْ. وَارْ خبّْشمْ شَا خْ \add أَرِّيمثْ\add* نْومْ، وَارْ ثْقشَّارمْ شَا جَارْ ثِيطَّاوِينْ نْومْ ذِي سِّيبّثْ ن إِجّْ ن ؤُمتِّينْ. \x ◘ \xo 14:‏1 \xt لَاوِي 19‏:‏27، 28؛ 21‏:‏5\x*  
\v 2 مِينْزِي أَقَا شكْ ذ إِجّْ ن ڒْڭنْسْ إِقدّسْ غَارْ سِيذِي، أَربِّي نّشْ، ؤُشَا سِيذِي إِفَارْزْ شكْ حِيمَا أَذْ أَسْ ثِيڒِيذْ ذ ڒْڭنْسْ إِغْڒَانْ زِي مَارَّا ڒڭْنُوسْ إِ إِدْجَانْ خْ ثمُّورْثْ. \x ◘ \xo 14:‏2 \xt أَعَوذ. 7‏:‏6؛ 26‏:‏18\x*   
\s1 خْ مَاشَّا ذ وَاڭْڒَا  
\m
\v 3 وَارْ تّتّْ زِي كُوڒْشِي مِينْ إِدْجَانْ ذ جّْعِيفشْثْ.  
\v 4 أَقَا ذ إِنَا ذ \bd إِمُودَّارنْ إِ إِعدّڒْ أَذْ ثنْ ثشّمْ\bd*: أَفُونَاسْ، إِجّنْ زڭْ إِحُوڒِييّنْ، إِجّنْ زڭْ إِغَايْضنْ، \x ◘ \xo 14:‏4 \xt لَاوِي 11‏:‏2\x*  
\v 5 ؤُذَاذْ، إِغَايْضْ ن وزْغَارْ، إِزرْزرْ، إِغَايْضْ أَكْ-ذ وَاشَّاونْ إِمقّْرَاننْ، أَملَّالْ، أَفُونَاسْ ن ڒخْڒَا ذ إِغَايْضْ ن إِذُورَارْ. \f ◼ \fr 14:‏5 \ft \+bd ’إِغَايْضْ ن وزْغَارْ‘\+bd* - نِيغْ ’أَزنْكُوذْ‘. \+bd ’أَملَّالْ‘\+bd* - نِيغْ ’أَمْرُورْ‘ نِيغْ ’أَشَامُولْ‘.\f*   
\m
\v 6 إِعدّڒْ أَذْ ثشّمْ مَارَّا ڒْمَاڒْ إِ غَارْ إِدْجَا ثْڒقَّا ن \bd ثشْضشْثْ إِمّْسبْضَانْ\bd*، ثَاشْضشْثْ إِمّْسبْضَانْ خْ ثْنَاينْ، \bd ؤُ\bd* \add سنّجْ إِ مَانْ أَيَا\add* \bd تَّارَّانْ إِفژْ\bd* جَارْ ڒْمَاڒْ.  
\v 7 مَاشَا زڭْ إِنِّي إِتَّارَّانْ إِفژْ ذ يِينِّي إِ غَارْ ثدْجَا ثشْضشْثْ إِمّْسبْضَانْ قَاعْ خْ ثْنَاينْ، \bd وَارْ إِعدّڒْ أَذْ ثشّمْ إِنَا\bd*: \bd أَڒْغمْ\bd*، ذ \bd ؤُيَارْزِيزْ\bd* ذ \bd ؤُكَاوْكَا ن ثصْضَارْثْ\bd* مِينْزِي تّفّْژنْ، \add مَاشَا\add* وَارْ غَارْسنْ بُو ثشْضشْثْ إِمّْسبْضَانْ، ؤُ \add خنِّي\add* أَذْ غَارْومْ إِڒِينْ خمْجنْ.  
\v 8 \add أَمُّو ؤُڒَا ذ\add* \bd إِڒفْ\bd*، وَاخَّا غَارسْ ثَاشْضشْثْ إِمّْسبْضَانْ، وَارْ إِتَّارِّي إِفژْ، \add س ؤُينِّي\add* أَذْ غَارْومْ يِيڒِي إِخْمجْ. وَارْ تّتّمْ شَا زڭْ ويْسُومْ نّسْ، وَارْ تّْحَاذَامْ شَا ڒْخشْبَاثْ نْسنْ.   
\m
\v 9 إِعدّڒْ أَذْ ثشّمْ إِنَا زِي مَارَّا مِينْ إِدْجَانْ \bd ذڭْ وَامَانْ: مَارَّا وِي غَارْ إِدْجَا وَافْرِيونْ ذ ثقْشُورْثْ\bd* إِعدّڒْ أَذْ ثنْ ثشّمْ.  
\v 10 \add مَاشَا\add* مَارَّا مِينْ وَارْ غَارْ دْجِينْ وَافْرِيونْ نِيغْ ثَاقْشُورْثْ، وَارْ إِعدّڒْ أَذْ ثنْ ثشّمْ، أَذْ غَارْومْ إِڒِينْ خمْجنْ.   
\m
\v 11 \bd مَارَّا إِجْضَاضْ إِزْذِيڭنْ إِعدّڒْ أَذْ ثنْ ثشّمْ\bd*،  
\v 12 \add مَاشَا\add* \bd وَارْ إِعدّڒْ أَذْ زَّايْسنْ ثشّمْ إِنَا\bd*: أَڭِيذرْ، إِسْغِي، أَڭِيذرْ ن ڒبْحَارْ،  
\v 13 بُو-ڒْْخژْرَاثْ ذ أَمسْغُويْ \add أَمُوقْضِيعْ ن ثِيطَّاوِينْ\add* ذ بُو-ؤُمطَّاوْ س ثَازْڒَا أَكْ-ذ مَارَّا مَارْكَاثْ نّسْ، \x ◘ \xo 14:‏13 \xt لَاوِي 11‏:‏14\x*  
\v 14 مَارَّا مَارْكَاثْ ن ؤُبَاغڒْ،  
\v 15 يدْجِيسْ ن بُوهيَّافْ، أَعنَّافْ، أَجْضِيضْ ن ڒبْحَارْ، ڒْبَازْ أَكْ-ذ مَارْكَاثْ نّسْ، \x ◘ \xo 14:‏15 \xt لَاوِي 11‏:‏16\x*  
\v 16 \add أَحمَّاڒْ ن\add* ڒْكَاسْ، بُو-ؤُسُوضِي \add ن ڒْموْثْ\add*، بُو-يُونْثَاحْ،  
\v 17 بُو-ؤُعُوقِّي، بُو-ؤُحَاوَاڒْ، بُو-ثْشَارَارُّوثْ،  
\v 18 أَبلَّارْجْ، بُو-ؤُسُوضِي إِعفّْننْ أَكْ-ذ مَارْكَاثْ نّسْ، ذُونْذُونْ ذ ڒْوضْوَاضْ.   
\m
\v 19 \bd مَارَّا مِينْ غَارْ إِدْجَا وَافْرِيونْ نِّي إِتّْبُوعنْ أَذْ غَارْومْ يِيڒِي إِخْمجْ\bd*. وَارْ إِعدّڒْ أَذْ تّْوَاشّنْ.  
\v 20 مَارَّا إِجْضَاضْ إِزْذِيڭنْ إِعدّڒْ أَذْ ثنْ ثشّمْ.   
\m
\v 21 وَارْ إِعدّڒْ أَذْ ثشّمْ ؤُڒَا زڭْ إِشْثْ ن ڒْخشْبثْ. أَذْ ت ثوْشذْ إِ ؤُبَارَّانِي نِّي \add إِدْجَانْ\add* ذَاخڒْ إِ ثوُّورَا نّشْ، حِيمَا أَذْ زَّايسْ يشّْ، نِيغْ أَذْ ت ثزّنْزذْ إِ ؤُبَارَّانِي، مِينْزِي شكْ ذ إِجّْ ن ڒْڭنْسْ ذ أَمْقدَّاسْ إِ سِيذِي، أَربِّي نّشْ.“  
\b  
\m ”وَارْ سْننِّي إِغَايْضْ ذ أَمژْيَانْ ذڭْ ؤُغِي ن يمَّاسْ.“\x ◘ \xo 14:‏21 \xt ؤُف. 23‏:‏19؛ 34‏:‏26\x*   
\b  
\m
\v 22 \bd أَذْ ثْعشَّارذْ\bd* نِيشَانْ مَارَّا ڒْغِيدْجثْ ن زَّارِيعثْ نِّي إِتّجَّا إِيَّارْ نّشْ زڭْ ؤُسڭّْوَاسْ غَارْ ؤُسڭّْوَاسْ \add نّغْنِي\add*.  
\v 23 أَذْ ثشّذْ ڒعْشُورْ ن إِرْذنْ نّشْ، ن بِينُو نّشْ ن جْذِيذْ، ن زّشْثْ نّشْ \add ن طّْرِي\add*، ؤُڒَا ن إِمنْزَا ن ڒبْهَايمْ نّشْ ؤُ ن وُودْجِي نّشْ زَّاثْ إِ وُوذمْ ن سِيذِي، أَربِّي نّشْ، ذڭْ ومْشَانْ إِ غَا يِيخْضَارْ نتَّا مَاحنْذْ أَذْ ذِينْ إِزمّمْ إِسمْ نّسْ، حِيمَا أَذْ ثْڒمْذذْ أَذْ ثڭّْوذذْ سِيذِي، أَربِّي نّشْ كُوڒْ أَسّْ. \x ◘ \xo 14:‏23 \xt أَعَوذ. 12‏:‏17، 18\x*  
\v 24 مَاڒَا أَبْرِيذْ إِزُّوڭَّارْثْ خَاكْ أَطَّاسْ، أَڒْ غَا ثَافذْ وَارْ ثْزمَّارذْ أَذْ ثَاوْيذْ \add ڒعْشُورْ\add* ذِينْ، مِينْزِي أَمْشَانْ نِّي يِيخْضَارْ سِيذِي، أَربِّي نّشْ، حِيمَا أَذْ ذِينْ إِزمّْ إِسمْ نّسْ، إِدْجَانْ إِڭّْوجْ خَاكْ أَطَّاسْ، \add ؤُشَا\add* مَاڒَا \add خنِّي\add* سِيذِي، أَربِّي نّشْ إِبَاركْ إِ شكْ،  
\v 25 قْڒبْ إِ-ثنْ \add خنِّي\add* ذ \add ثْمنْيَاثْ ن\add* نُّوقَارْثْ ؤُشَا ؤُيُورْ س ثْكمُّوسْثْ ن ثْمنْيَاثْ ذڭْ ؤُفُوسْ نّشْ غَارْ ومْشَانْ نِّي إِ غَا يِيخْضَارْ سِيذِي، أَربِّي نّشْ، \f ◼ \fr 14:‏25 \ft \+bd ’ثَاكمُّوسْثْ‘\+bd* - نِيغْ ’ثَاشمُّوسْثْ‘.\f*  
\v 26 أَذْ ثْصَارْفذْ ثْمنْيَاثْ نِّي خْ مَارَّا مِينْ ذِي إِمّژْرِي وُوڒْ نّشْ، خْ إِفُونَاسنْ ذ ثْفُونَاسِينْ، خْ وُودْجِي، خْ بِينُو، خْ شّْرَابْ نِيغْ خْ مِينْ مَا إِخْسْ وُوڒْ نّشْ ؤُشَا أَذْ ثشّذْ ذِينْ زَّاثْ إِ وُوذمْ ن سِيذِي، أَربِّي، أَذْ ثْفَارْحذْ، شكْ ذ \add ڒَْادْجْ ن\add* ثَادَّارْثْ نّشْ.“ \x ◘ \xo 14:‏26 \xt مت. 21‏:‏12\x*   
\m
\v 27 ”وَارْ سمّحْ شَا ذِي أَلَاوِي نِّي إِزدّْغنْ غَارْ ذَاخڒْ إِ ثوُّورَا نّشْ، مِينْزِي وَارْ غَارسْ بُو ثَاسْغَارْثْ نِيغْ ڒْوَارْثْ أَكِيذكْ. \x ◘ \xo 14:‏27 \xt ڒخْڒ. 18‏:‏20، 24؛ أَعَوذ. 10‏:‏9؛ 12‏:‏12؛ 18‏:‏1، 2؛ 26‏:‏12\x*  
\v 28 غَارْ ؤُنڭَّارْ ن ثْڒَاثَا ن إِسڭّْوُوسَا أَذْ ثسُّوفّْغذْ مَارَّا ڒعْشُورْ ن ڒْغِيدْجثْ ذڭْ ؤُسڭّْوَاسْ نِّي ؤُشَا أَذْ ثنْ ثْخزْنذْ جَارْ ذَاخڒْ ن ثوُّورَا نّشْ.  
\v 29 \add خنِّي\add* أَلَاوِي أَذْ د-يَاسْ، مِينْزِي وَارْ غَارسْ ثدْجِي ثسْغَارْثْ نِيغْ ڒْوَارْثْ أَكِيذكْ، ؤُڒَا ذ أَبَارَّانِي ذ ؤُيُوجِيڒْ ذ ثَاجَّاتْشْ نِّي إِدْجَانْ غَارْ ذَاخڒْ إِ ثوُّورَا نّشْ ؤُشَا أَذْ شّنْ، أَذْ جِّيوْننْ، حِيمَا \add خنِّي\add* سِيذِي، أَربِّي نّشْ، أَذْ أَشْ إِبَاركْ ذِي مَارَّا ڒْخذْمثْ إِ غَا ثڭّذْ س ؤُفُوسْ نّشْ.“   
\b  
\b  
\m  
\c 15
\m
\v 1 ”\bd غَارْ ؤُنڭَّارْ ن سبْعَا ن إِسڭّْوُوسَا أَذْ يِيڒِي إِجّْ ن وسْمَاحْ ن إِمرْوُوسَا.\bd* \x ◘ \xo 15:‏1 \xt ؤُف. 21‏:‏2؛ إِرْم. 34‏:‏14\x*  
\v 2 ثَا ذ ثَامسْڒَاشْثْ ن ؤُفكِّي زڭْ إِمرْوُوسَا: كُوڒْ بَابْ ن ؤُمَارْوَاسْ، ونِّي يَارضْڒنْ زڭْ ؤُفُوسْ نّسْ إِ جَّارْ نّسْ، أَذْ \add أَسْ\add* إِسمْحْ إِ ؤُمَارْوَاسْ. وَارْ إِتّتَّارْ شَا أَمَارْوَاسْ زڭْ جَّارْ نّسْ ؤُڒَا زڭْ ؤُمَاسْ، مِينْزِي إِتّْوَابَارّحْ س ؤُفكِّي ن إِمرْوُوسَا إِ سِيذِي.  
\v 3 إِعدّڒْ أَذْ ثْڒَاغِيذْ أَبَارَّانِي خْ ؤُمَارْوَاسْ، \add مَاشَا\add* مِينْ إِدْجَانْ نّشْ غَارْ ؤُمَاشْ، \add ذ مَانْ أَيَا\add* أَذْ ذَايسْ إِسْمحْ ؤُفُوسْ نّشْ.  
\v 4 أَقَا وَارْ إِتّْخصِّي شَا أَذْ غَاركْ يِيڒِي ؤُڒَا ذ إِجّْ ن ؤُمزْڒُوضْ، مِينْزِي سِيذِي أَذْ شكْ إِبَاركْ أَطَّاسْ ذِي ثمُّورْثْ نِّي إِ ذ أَشْ غَا إِوْشْ، سِيذِي، أَربِّي نّشْ، ذ ثَاسْغَارْثْ إِ غَا ثْوَارْثذْ،  
\v 5 مَاڒَا \add خنِّي\add* ثسْڒِيذْ س ثيْنِيثْ غَارْ ثْمِيجَّا ن سِيذِي، أَربِّي نّشْ، حِيمَا أَذْ ثحْضِيذْ ؤُشَا أَذْ ثڭّذْ مَارَّا ثِيوصَّا-يَا، ثِينِّي خْ ذ أَشْ وصِّيغْ أَسّْ-أَ.  
\v 6 مِينْزِي سِيذِي، أَربِّي نّشْ، أَذْ أَشْ إِبَاركْ أَمْ مَامّشْ ثُوغَا ذ أَشْ إِنَّا، ؤُشَا أَطَّاسْ ن ڒڭْنُوسْ أَذْ خَاكْ أَرْضْڒنْ س وضْمَانْ، مَاشَا شكْ وَارْ ثَارطّْڒذْ وَالُو س وضْمَانْ \add خْ ؤُڒَا ذ يِيجّنْ زَّايْسنْ\add*. شكْ أَذْ ثْحكْمذْ خْ وَاطَّاسْ ن ڒڭْنُوسْ، مَاشَا نِيثْنِي وَارْ خَاكْ حكّْمنْ شَا.“   
\b  
\m
\v 7 ”خْمِي \add ذِينْ\add* غَاركْ غَا يِيڒِي إِجّْ ن ؤُمزْڒُوضْ، إِجّْ زڭْ أَيْثْمَاشْ، غَارْ ذَاخڒْ إِ يِيشْثْ زِي ثوُّورَا ن ثمُّورْثْ نّشْ نِّي إِ ذ أَشْ غَا يوْشْ سِيذِي، أَربِّي نّشْ، \add خنِّي\add* وَارْ سّقْسَاحْ شَا ؤُڒْ نّشْ ؤُ وَارْ تّْزيَّارْ شَا أَفُوسْ نّشْ خْ ؤُمَاشْ نِّي إِزڒْضنْ،  
\v 8 مَاشَا أَذْ أَسْ ثَارْزْمذْ أَفُوسْ نّشْ س وشْرِيمْ ؤُ أَذْ أَسْ ثَارضْڒذْ س وضْمَانْ، عْلَاحْسَابْ مِينْ إِحْوَاجْ ذڭْ ؤُزيَّارْ نّسْ.  
\v 9 حْضَا، وَارْ إِتِّيڒِي ذڭْ وُوڒْ نّشْ ؤُڒَا ذ إِجّْ ن ؤُخَارِّيصْ بَاطڒْ، ثقَّارذْ \add ذڭْ يِيخفْ نّشْ\add*: ’أَقَا يُوذسْ-د ؤُسڭّْوَاسْ وِيسّْ سبْعَا، أَسڭّْوَاسْ ن ؤُفكِّي ن إِمرْوُوسَا!‘، ؤُشَا \add خنِّي\add* أَذْ ثخْزَارذْ س ثِيطَّاوِينْ إِخيّْقنْ خْ ؤُمَاشْ نِّي إِ ذِي إِدْجَا زّڒْضْ ؤُشَا وَارْ ذ أَسْ ثتِّيشذْ وَالُو ؤُ نتَّا أَذْ زَّايكْ إِشثْشَا غَارْ سِيذِي ؤُشَا أَذْ خَاكْ يِيڒِي دّنْبْ.  
\v 10 إِتّْخصَّا أَذْ أَسْ ثوْشذْ ذغْيَا، وَارْ إِتِّيڒِي ؤُخيّقْ ذڭْ وُوڒْ نّشْ خْمِي إِ ذ أَسْ غَا ثوْشذْ، مِينْزِي خْ ؤُيَا أَذْ أَشْ إِبَاركْ سِيذِي، أَربِّي نّشْ، ذِي مَارَّا ڒْخذْمثْ نّشْ ؤُ ذِي مَارَّا مَانِي غَا يَاوضْ ؤُفُوسْ نّشْ. \x ◘ \xo 15:‏10 \xt مت. 5‏:‏42؛ لك. 6‏:‏35\x*  
\v 11 مِينْزِي أَمژْڒُوضْ وَارْ إِتّْوَامحِّي زِي ثمُّورْثْ. خْ ؤُيَا نشّْ ؤُمُورغْ شكْ، قَّارغْ: أَرْزمْ أَفُوسْ نّشْ أَڒْ طَّارْفْ إِ ؤُمَاشْ، إِ ونِّي إِتّْوَاحْصَارنْ ؤُ إِ ؤُمزْڒُوضْ نِّي \add إِدْجَانْ\add* ذِي ثمُّورْثْ نّشْ.“ \x ◘ \xo 15:‏11 \xt مت. 26‏:‏11؛ يُوح. 12‏:‏8\x*   
\b  
\m
\v 12 \bd ”مَاڒَا ؤُمَاشْ\bd*، إِجّْ ن ؤُعِيبْرَانِي نِيغْ إِشْثْ ن ثْعِيبْرَانشْثْ، \bd إِتّْوَازّنْزْ غَاركْ\bd*، \add خنِّي\add* أَذْ أَشْ إِخْذمْ ستَّا ن إِسڭّْوُوسَا، \add مَاشَا\add* ذڭْ ؤُسڭّْوَاسْ وِيسّْ سبْعَا أَذْ أَسْ ثْسَارّْحذْ أَذْ أَسْ ثَارْخُوذْ زِي غَاركْ س ثْڒلِّي. \x ◘ \xo 15:‏12 \xt ؤُف. 21‏:‏2؛ إِرْم. 34‏:‏14\x*  
\v 13 خْمِي إِ ذ أَسْ غَا ثْسَارّْحذْ، \add خنِّي\add* وَارْ ث تّجِّي أَذْ إِرَاحْ س \add إِفَاسّنْ\add* خْوَانْ.  
\v 14 \add أَخْمِي\add* ذ أَسْ غَا ثڭّذْ ثِيسدّشْثْ \add أَمُّو إِ ذ أَسْ غَا ثڭّذْ إِشْثْ ن ثوْهِيبْثْ\add* زڭْ وُودْجِي ؤُ زڭْ ؤُنذْرَارْ ؤُ زِي ثْسِيرْثْ \add ن ؤُضِيڒْ\add*. س مِينْ ذ أَشْ إِبَاركْ سِيذِي، أَربِّي نّشْ، أَذْ أَسْ ثوْشذْ إِ نتَّا.  
\v 15 أَذْ ثِيذَارذْ بلِّي ثُوغَا شكْ ذ إِسْمغْ ذِي ثمُّورْثْ ن مِيصْرَا ؤُشَا سِيذِي، أَربِّي نّشْ، أَقَا إِفْذِي خَاكْ. خْ ؤُيَا، نشّْ ؤُمُورغْ شكْ ثِيوصَّا-يَا أَسّْ-أَ. \f ◼ \fr 15:‏15 \ft \+bd ’إِفْذِي‘\+bd* - خْزَارْ إِزهد. 78:35.\f*  \x ◘ \xo 15:‏15 \xt أَعَوذ. 10‏:‏19؛ 16‏:‏12؛ 24‏:‏18؛ 24‏:‏22؛ ؤُف. 22‏:‏20؛ 23‏:‏9؛ لَاوِي 19‏:‏34. \x*  
\v 16 مَاڒَا نتَّا إِنَّا أَشْ: ’وَارْ خَاكْ تَّاڭّْوْجغْ!‘، مِينْزِي إِتّخْسْ إِ شكْ ذ \add ڒَْادْجْ ن\add* ثَادَّارْثْ نّشْ، مِينْزِي أَقَا نتَّا مْلِيحْ غَاركْ،  
\v 17 خنِّي أَذْ ثكْسِيذْ إِجّْ ن ؤُسِييْنِي ؤُشَا أَذْ ثسّْنُوقّبْ أَمزُّوغْ نّسْ ؤُڒَا ذ ثوَّارْثْ ؤُشَا \add أَمُّو إِ\add* غَا يِيڒِي ذ إِسْمغْ نّشْ إِ ڒبْذَا ؤُ أَمُّو إِ غَا ثڭّذْ \add عَاوذْ\add* س ثَايَّا نّشْ. \x ◘ \xo 15:‏17 \xt ؤُف. 21‏:‏6\x*  
\v 18 وَارْ د-إِتّْبِينْ إِقْسحْ ذِي ثِيطَّاوِينْ نّشْ، خْمِي ث غَا ثسّكّذْ ذِي ثْڒلِّي، مِينْزِي ثُوغَا إِسخَّارْ إِ شكْ ستَّا ن إِسڭّْوُوسَا، يَاربّحْ إِ شكْ ڒخْڒَاصْ ن إِجّْ ن ؤُشوَّاڒْ ثْنَاينْ ن ثْسقَّارْ. \add أَمُّو\add* إِ شكْ غَا إِبَاركْ سِيذِي، أَربِّي نّشْ، ذِي مَارَّا مِينْ غَا ثڭّذْ.“   
\b  
\m
\v 19 \bd ”أَذْ ثسّْقدّْسذْ إِ سِيذِي، أَربِّي نّشْ، مَارَّا إِمنْزَا إِوثْمَانْ\bd* نِّي د-إِتّْوَاخڒْقنْ جَارْ إِفُونَاسنْ ذ ثْفُونَاسِينْ نّشْ ذ وُودْجِي نّشْ. وَارْ إِعدّڒْ أَذْ ثسّْخذْمذْ أَمنْزُو ن إِفُونَاسنْ نّشْ ؤُشَا أَمنْزُو ن وُودْجِي نّشْ وَارْ ث تّدْجَاسْ. \x ◘ \xo 15:‏19 \xt ؤُف. 13‏:‏2؛ 22‏:‏29؛ 34‏:‏19؛ لَاوِي 27‏:‏26؛ ڒخْڒ. 3‏:‏13\x*  
\v 20 أَسڭّْوَاسْ أَوَارْنِي إِ ؤُسڭّْوَاسْ أَذْ ثنْ ثشّذْ، شكْ ذ \add ڒَْادْجْ ن\add* ثَادَّارْثْ نّشْ، زَّاثْ إِ وُوذمْ ن سِيذِي، أَربِّي نّشْ، ذڭْ ومْشَانْ إِ غَا يِيخْضَارْ سِيذِي.  
\v 21 مَاشَا مَاڒَا ثُوغَا ذَايسْ ڒْعِيبْ، ثُوغَا-ث ذ أَقِيذَارْ نِيغْ ذ أَذَارْغَاڒْ نِيغْ مِينْ مَا ڒْعِيبْ أَعفَّانْ \add إِ غَارسْ إِدْجَانْ\add*، وَارْ ذ أَسْ غَارّصْ شَا إِ سِيذِي، أَربِّي نّشْ.\x ◘ \xo 15:‏21 \xt لَاوِي 22‏:‏20؛ أَعَوذ. 17‏:‏1\x*  
\v 22 ذَاخڒْ إِ ثوُّورَا نّشْ أَذْ زَّايسْ ثشّذْ، أَمْ ؤُمخْمُوجْ أَمْ ؤُمزْذَاڭْ، أَمْ مَامّشْ \add إِ غَا ثشّذْ\add* زڭْ إِغَايْضْ ن وزْغَارْ ؤُ زڭْ ؤُذَاذْ.  
\v 23 مْغِيرْ إِذَامّنْ نّسْ، وَارْ ثنْ تّتّْ شَا، أَذْ ثنْ ثْفَارّْغذْ خْ ثمُّورْثْ أَمْ وَامَانْ.“ \x ◘ \xo 15:‏23 \xt أَعَوذ. 12‏:‏16، 23\x*   
\b  
\b  
\m  
\c 16
\s1 ڒعْيُوذَاثْ  
\m
\v 1 ”حْضَا أَيُورْ ن أَبِيبْ، أَذْ ثسّْوجْذذْ \bd \+bdit ثَاغَارْصْثْ\+bdit* ن ؤُسعْذُو\bd* إِ سِيذِي، أَربِّي نّشْ، مِينْزِي ذڭْ ؤُيُورْ ن أَبِيبْ إِسُّوفّغْ إِ شكْ-د سِيذِي، أَربِّي نّشْ، زِي ثمُّورْثْ ن مِيصْرَا س دْجِيڒثْ. \x ◘ \xo 16:‏1 \xt ؤُف. 12‏:‏2؛ لَاوِي 23‏:‏5؛ ڒخْڒ. 9‏:‏1؛ 28‏:‏16\x*  
\v 2 أَذْ ثْغَارْصذْ إِ \add ثَاغَارْصْثْ ن\add* ؤُسعْذُو إِ سِيذِي، أَربِّي نّشْ، ؤُدْجِي ذ إِفُونَاسنْ ذ ثْفُونَاسِينْ ذڭْ ومْشَانْ نِّي إِ غَا يِيخْضَارْ سِيذِي، مَاحنْذْ أَذْ ذِينْ إِسّزْذغْ إِسمْ نّسْ.  
\v 3 وَارْ كِيسْ تّتّْ شَا س ونْثُونْ. سبْعَا ن وُوسَّانْ أَذْ كِيسْ ثشّذْ أَغْرُومْ بْڒَا أَنْثُونْ، أَغْرُومْ ن ثَامَارَا، مِينْزِي ذغْيَا ثفّْغذْ زِي ثمُّورْثْ ن مِيصْرَا، حِيمَا أَذْ ثْعقْڒذْ خْ وَاسّْ إِ د-تّفّْغذْ زِي مِيصْرَا مَارَّا ؤُسَّانْ ن ثُوذَارْثْ نّشْ. \x ◘ \xo 16:‏3 \xt ؤُف. 12‏:‏19؛ 34‏:‏18\x*  
\v 4 وَارْ كِيكْ إِتّمْژَارْ ونْثُونْ ذِي مَارَّا جِّيهثْ نّشْ سبْعَا ن وُوسَّانْ ؤُشَا زڭْ ويْسُومْ نِّي إِ ثْغَارْصذْ غَارْ ؤُعشِّي ن وَاسّْ أَمزْوَارُو، وَارْ إِتّْنُوسِي شَا أَڒْ ثِيوشَّا نّسْ. \x ◘ \xo 16:‏4 \xt ؤُف. 12‏:‏10، 13‏:‏7، 23‏:‏18، 34‏:‏25\x*  
\v 5 وَارْ إِحدْجڒْ أَذْ ثْغَارْصذْ إِ \add ثْغَارْصْطْ ن\add* ؤُسعْذُو غَارْ ذَاخڒْ إِ يِيشْثْ ن ثوُّورَا \add ن ثْندَّامْ\add* إِ ذ أَشْ غَا يوْشْ سِيذِي، أَربِّي نّشْ،  
\v 6 مَاشَا ذڭْ ومْشَانْ نِّي إِ غَا يِيخْضَارْ سِيذِي، أَربِّي نّشْ، حِيمَا أَذْ ذِينْ إِسِّيزْذغْ إِسمْ نّسْ، ذِينْ إِ إِتّْخصَّا أَذْ ثْغَارْصذْ إِ \add ثْغَارْصْثْ ن\add* ؤُسعْذُو غَارْ ؤُعشِّي خْمِي غَا ثغْڒِي ثْفُوشْثْ ذِي ثْسَاعّثْ نِّي ذِي ثفّْغذْ زِي مِيصْرَا.  
\v 7 ؤُشَا أَذْ ت ثسّنْڭْوذْ أَذْ ت ثشّذْ ذڭْ ومْشَانْ نِّي إِ غَا يِيخْضَارْ سِيذِي، أَربِّي نّشْ. غَارْ صّْبحْ \add أَوَارْنِي أَسْ\add* أَذْ ثْعقْبذْ ؤُشَا أَذْ ثْرَاحذْ غَارْ إِقِيضَانْ نّشْ.  
\v 8 \bd ستَّا ن وُوسَّانْ أَذْ ثشّذْ أَغْرُومْ بْڒَا أَنْثُونْ\bd* ؤُشَا ذڭْ وَاسّْ وِيسّْ سبْعَا أَذْ يِيڒِي إِجّْ ن ؤُمُونِي إِفَارْزنْ إِ سِيذِي، أَربِّي نّشْ. \add خنِّي\add* وَارْ إِحدْجڒْ أَذْ ثڭّذْ ؤُڒَا ذ إِشْثْ ن ڒْخذْمثْ \add إِ إِتّْخصَّا أَذْ ثتّْوَاڭّْ\add*.“   
\m
\v 9 ”أَذْ ثْحسْبذْ سبْعَا ن سِّيمَانَاثْ إِ يِيخفْ نّشْ. زڭْ وَامِي \add إِ غَا ثبْذِيذْ أَذْ ثڭّذْ\add* أَمْجَارْ ذڭْ إِمنْذِي إِبدّنْ، أَذْ ثبْذِيذْ أَذْ ثْحسْبذْ سبْعَا ن سِيمَانَاثْ. \x ◘ \xo 16:‏9 \xt ؤُف. 23‏:‏16؛ لَاوِي 23‏:‏15؛ ڒخْڒ. 28‏:‏26\x*  
\v 10 \add خَاسْ ؤُشَا\add* أَذْ ثڭّذْ \bd ڒْعِيذْ ن سِّيمَانَاثْ\bd* إِ سِيذِي، أَربِّي نّشْ. أَذْ ثوْشذْ إِشْثْ ن صّذْقثْ س ڒْخَاضَارْ زڭْ ؤُفُوسْ نّشْ أَمْ مَامّشْ شكْ إِبَاركْ سِيذِي، أَربِّي نّشْ.  
\v 11 أَذْ ثْفَارْحذْ زَّاثْ إِ وُوذمْ ن سِيذِي، أَربِّي نّشْ، شكْ، مِّيشْ، يدْجِيشْ، إِسْمغْ نّشْ، ثَايَّا نّشْ، أَلَاوِي نِّي \add إِتّْغِيمَانْ\add* ذَاخڒْ إِ ثوُّورَا نّشْ، أَبَارَّانِي، أَيُوجِيڒْ ذ ثَاجَّاتْشْ نِّي إِدْجَانْ ذِي ڒْوسْطْ نّشْ، ذڭْ ومْشَانْ نِّي إِ غَا يِيخْضَارْ سِيذِي، أَربِّي نّشْ، حِيمَا أَذْ ذِينْ إِسّزْذغْ إِسمْ نّسْ.  
\v 12 أَذْ ثْعقْڒذْ بلِّي ثُوغَا شكْ ذ إِسْمغْ ذِي مِيصْرَا ؤُشَا إِتّْخصَّا أَذْ ثحْضِيذْ ثِيوصَّا-يَا ؤُ أَذْ ثنْ ثڭّذْ.“   
\b  
\m
\v 13 ”أَذْ ثْعيّْذذْ \bd ڒْْعِيذْ ن إِعُوشُّوثنْ\bd* سبْعَا ن وُوسَّانْ، خْمِي ثْكمّْڒذْ أَسْمُونِي ن صَّابثْ ن ؤُنذْرَارْ نّشْ ذ ؤُژمِّي ن ثْسِيرْثْ نّشْ \add ن ؤُضِيڒْ\add*. \x ◘ \xo 16:‏13 \xt ؤُف. 23‏:‏16؛ لَاوِي 23‏:‏34\x*  
\v 14 ؤُشَا أَذْ ثْفَارْحذْ ذِي ڒْعِيذْ نّشْ، شكْ، مِّيشْ، يدْجِيشْ، إِسْمغْ نّشْ، ثَايَّا نّشْ، أَلَاوِي، أَبَارَّانِي، أَيُوجِيڒْ ذ ثَاجَّاتْشْ نِّي \add إِتّْغِيمَانْ\add* ذَاخڒْ إِ ثوُّورَا نّشْ.  
\v 15 سبْعَا ن وُوسَّانْ أَذْ ثْعيّْذذْ إِ سِيذِي، أَربِّي نّشْ، ذڭْ ومْشَانْ نِّي إِ غَا يِيخْضَارْ سِيذِي، مِينْزِي سِيذِي، أَربِّي نّشْ، أَذْ شكْ إِبَاركْ ذِي مَارَّا ڒْغِيدْجثْ نّشْ ؤُ ذِي مَارَّا ڒْخذْمثْ ن إِفَاسّنْ نّشْ ؤُشَا أَذْ ثْفَارْحذْ س ثِيذتّْ!“   
\b  
\m
\v 16 \bd ”ثْڒَاثَا ن ثْوَاڒَاوِينْ ذڭْ ؤُسڭّْوَاسْ\bd* أَذْ د-بَاننْ مَارَّا إِوثْمَانْ نّشْ زَّاثْ إِ وُوذمْ ن سِيذِي، أَربِّي نّشْ، ذڭْ ومْشَانْ نِّي إِ غَا يِيخْضَارْ نتَّا: ذِي ڒْعِيذْ ن وغْرُومْ بْڒَا أَنْثُونْ، ذِي ڒْعِيذْ ن سِّيمَانَاثْ، ذِي ڒْعِيذْ ن إِعُوشُّوثنْ. وَارْ د-إِتّْبِينْ ؤُڒَا ذ إِجّْ \add س إِفَاسّنْ\add* خْوَانْ زَّاثْ إِ وُوذمْ ن سِيذِي. \x ◘ \xo 16:‏16 \xt ؤُف. 23‏:‏15، 17؛34‏:‏23\x*  
\v 17 كُوڒْ أَرْيَازْ \add أَذْ إِوْشْ\add* أَمْ مَامّشْ ذ أَسْ إِمّوْشنْ ذڭْ ؤُفُوسْ نّسْ، أَنشْثْ ن لْبَارَاكَا إِ ذ أَشْ إِوْشَا سِيذِي، أَربِّي نّشْ.   
\b  
\m  
\s1 خْ ڒحْكَامثْ  
\m
\v 18 أَذْ ثْفَارْنذْ ڒْقُوضَاثْ ذ إِمحْضَاينْ غَارْ ذَاخڒْ إِ ثوُّورَا نِّي ذ أَشْ غَا إِوْشْ سِيذِي، أَربِّي نّشْ، جَارْ \add مَارَّا\add* ثِيقبَّاڒْ نّشْ. نِيثْنِي أَذْ حكْمنْ \add جَارْ\add* ڒْڭنْسْ س إِشْثْ ن ڒحْكَامثْ إِسڭّْذنْ.  
\v 19 وَارْ تّفّغْ شَا خْ وبْرِيذْ ن ثِيذتّْ، وَارْ تّڭّْ س وُوذْمَاونْ \add خْمِي غَا ثْحكْمذْ\add*. وَارْ تّطّفْ شَا أَرّشْوثْ، مِينْزِي أَرّشْوثْ ثسّْذَارْغَاڒْ ثِيطَّاوِينْ ن يِينِّي إِحكّْمنْ ؤُ ثسّْفَارَّاغْ أَوَاڒنْ ن يِينِّي إِقَّارنْ ثِيذتّْ. \x ◘ \xo 16:‏19 \xt ؤُف. 23‏:‏8؛ لَاوِي 19‏:‏15؛ أَعَوذ. 1‏:‏17\x*  
\v 20 ثَاسڭْذَا \add ؤُشَا عَاوذْ\add* ثَاسڭْذَا أَذْ ثضْفَارذْ، حِيمَا أَذْ ثدَّارذْ ؤُشَا أَذْ ثْوَارْثذْ ثَامُّورْثْ نِّي إِ ذ أَشْ غَا إِوْشْ سِيذِي، أَربِّي نّشْ.   
\b  
\m  
\s1 أَعْڒَامْ غَارْ ڒْڭنْسْ خْ وعْبذْ ن لْ-أَصْنَامْ  
\m
\v 21 \bd وَارْ تّڭّْ شَا ثَاربِّيثْ ن شْوَارْثِي\bd* زِي شَا ن ثْشجَّارْثْ زَّاثْ إِ ؤُعَالْطَارْ ن سِيذِي، أَربِّي نّشْ، ونِّي غَا ثڭّذْ. \f ◼ \fr 16:‏21 \ft \+bd ’ثَاشجَّارْثْ‘\+bd* - نِيغْ ’أَدَّاڭْ‘ (’إِدَّاڭنْ‘).\f*  
\v 22 وَارْ سّْڭعَّاذْ أَميْضَا \add إِقدّْسنْ\add* إِ يِيخفْ نّشْ، مِينْزِي ذ مَانْ أَيَا إِشَارّهْ سِيذِي، أَربِّي نّشْ.“   
\b  
\b  
\m  
\c 17
\m
\v 1 ”\bd وَارْ غَارّصْ شَا إِ ؤُفُونَاسْ نِيغْ إِ يِيجّنْ زڭْ وُودْجِي إِ ذِي إِدْجَا شَا ن ڒْعِيبْ\bd*، \add نِيغْ\add* شَا ن ڒْمَاڒْ إِعفّْننْ، إِ سِيذِي، أَربِّي نّشْ، مِينْزِي مَانْ أَيَا ذ جّْعِيفشْثْ إِ سِيذِي، أَربِّي نّشْ. \x ◘ \xo 17:‏1 \xt لَاوِي 22‏:‏20‏-‏25؛ أَعَوذ. 15‏:‏21\x*   
\m
\v 2 ؤُمِي يُوفَا ذِي ڒْوسْطْ نّشْ، غَارْ ذَاخڒْ إِ ثوُّورَا نّشْ، ثِينِّي ذ أَشْ إِوْشَا سِيذِي، أَربِّي نّشْ، شَا ن ورْيَازْ نِيغْ شَا ن ثمْغَارْثْ إِ إِڭِّينْ مِينْ إِدْجَانْ ذ ڒْغَارْ ذِي \add ثِيطَّاوِينْ ن\add* سِيذِي، أَربِّي نّشْ، \add ؤُشَا أَمُّو\add* إِ غَا إِعدُّو خْ ڒْعَاهْذْ نّسْ، \x ◘ \xo 17:‏2 \xt أَعَوذ. 13‏:‏7\x*  
\v 3 ؤُشَا أَذْ يُويُورْ، أَذْ إِعْبذْ إِ إِربِّيثنْ نّغْنِي ؤُشَا أَذْ أَسنْ إِبنْذقْ، إِ ثْفُوشْثْ نِيغْ إِ يُويُورْ نِيغْ إِ مَارَّا إِثْرَانْ ن ؤُجنَّا، مِينْ وَارْ خفْ ؤُمُورغْ نشّْ،  
\v 4 ؤُشَا يِيوضْ إِ شكْ-د ڒخْبَارْ ؤُشَا ثسْڒِيذْ \add ت\add*، \add خنِّي\add* إِتّْخصَّا أَذْ ت ثَارْزُوذْ مْلِيحْ، ؤُ خْزَارْ، مَاڒَا ذ ثِيذتّْ ؤُشَا ثْبَانْ بلِّي ثتّْوَاڭّْ ذِي إِسْرَائِيل جّْعِيفشْثْ ثَانِيثَا،  
\v 5 \add خنِّي\add* أَذْ ثسُّوفّْغذْ أَرْيَازْ نِّي نِيغْ ثَامْغَارْثْ نِّي إِ إِڭِّينْ ڒْغَارْ-أَ غَارْ ثوُّورَا نّشْ، أَرْيَازْ نِّي نِيغْ ثَامْغَارْثْ نِّي، ؤُشَا أَذْ ثنْ ثْحجَّارذْ س إِژْرَا أَڒْ غَا مّْثنْ.“   
\m
\v 6 ”خْ \add وَاوَاڒْ زڭْ\add* ؤُقمُّومْ ن ثْنَاينْ نِيغْ ثْڒَاثَا ن ڒشْهُوذْ أَذْ إِتّْوَانغْ ونِّي إِتّْوَاحْكمْ سْ ڒْموْثْ. خْ \add وَاوَاڒْ زڭْ\add* ؤُقمُّومْ ن إِجّْ ن ؤُشهَّاذْ وَارْ إِحدْجڒْ أَذْ إِتّْوَانغْ. \x ◘ \xo 17:‏6 \xt ڒخْڒ. 35‏:‏30؛ أَعَوذ. 19‏:‏15؛ مت. 18‏:‏16؛ 2 كُور. 13‏:‏1؛ عبر. 10‏:‏28\x*  
\v 7 أَفُوسْ ن ڒشْهُوذْ أَذْ خَاسْ وْضَانْ ذ أَمزْوَارُو مَاحنْذْ أَذْ ث نْغنْ ؤُشَا أَوَارْنِي أَسْ \add أَذْ خَاسْ وْضَانْ إِفَاسّنْ\add* ن مَارَّا ڒْڭنْسْ. أَمُّو إِ غَا ثكّْسذْ ڒْغَارْ زِي ڒْوسْطْ نّشْ.“\x ◘ \xo 17:‏7 \xt أَعَوذ. 13‏:‏10\x*   
\m
\v 8 ”خْمِي خَاكْ غَا ثقْسحْ شَا ن ثْمسْڒَاشْثْ ذِي لْحُوكْمْ جَارْ \add ؤُسِيزّڒْ ن\add* إِذَامّنْ ذ \add ؤُسِيزّڒْ ن\add* إِذَامّنْ \add نّغْنِي\add*، جَارْ دّعْوثْ ذ دّعْوثْ، جَارْ ثِيشْثِي ذ ثشْثِي، \add نِيغْ ذِي لْحُوكْمْ ذڭْ\add* إِمْشُوبَّاشْ غَارْ ذَاخڒْ إِ ثوُّورَا نّشْ، \add خنِّي\add* أَذْ ثكَّارذْ، أَذْ ثْڭعّْذذْ غَارْ ومْشَانْ نِّي غَا يِيخْضَارْ سِيذِي، أَربِّي نّشْ.\x ◘ \xo 17:‏8 \xt 2 إِم. 19‏:‏10؛ مـَال. 2‏:‏7\x*  
\v 9 ؤُشَا أَذْ د-ثَاوْضذْ غَارْ إِكهَّاننْ، غَارْ إِلَاوِييّنْ، ؤُشَا \add خنِّي\add* غَارْ ڒْقَاضِي نِّي ذِينْ إِدْجَانْ ذڭْ وُوسَّانْ نِّي، ؤُشَا أَذْ ثسّقْسِيذْ ؤُ نِيثْنِي أَذْ شكْ خبَّارنْ خْ ڒحْكَامْ.  
\v 10 أَذْ ثڭّذْ أَمْ ثنْفُوتْشْ نِّي إِ شكْ غَا خبَّارنْ ذڭْ ومْشَانْ نِّي إِ غَا يِيخْضَارْ سِيذِي ؤُشَا أَذْ ثحْضِيذْ مَارَّا مِينْ ذ أَشْ غَا سّعْذُونْ.  
\v 11 أَذْ ثڭّذْ عْلَاحْسَابْ أَوَاڒْ ن شَّارِيعَا نِّي ذ أَشْ غَا سشّْننْ ؤُ عْلَاحْسَابْ ڒحْكَامْ نِّي ذ أَشْ غَا إِنِينْ. وَارْ تّْحيِّيذْ خْ وَاوَاڒْ إِ ذ أَشْ غَا إِنِينْ \add غَارْ\add* يفُوسْ ؤُڒَا \add غَارْ\add* ؤُزڒْمَاضْ.  
\v 12 أَرْيَازْ نِّي إِتّڭّنْ س ثُوفّثْ ؤُ وَارْ إِتّسْڒِي غَارْ ؤُكهَّانْ نِّي \add إِ ذِينْ\add* إِبدّنْ، حِيمَا أَذْ ذِينْ إِسخَّارْ سِيذِي، أَربِّي نّشْ، نِيغْ \add وَارْ إِتّسْڒِي\add* غَارْ ڒْقَاضِي، أَقَا أَرْيَازْ نِّي أَذْ إِمّثْ. إِتّْخصَّا أَذْ ثكّْسذْ ڒْغَارْ زِي إِسْرَائِيل.  
\v 13 مَارَّا ڒْڭنْسْ إِتّْخصَّا أَسنْ أَذْ سْڒنْ ؤُ أَذْ ڭّْوذنْ ؤُ وَارْ تُّوفّنْ عَاذْ.“   
\b  
\m  
\s1 خْ ؤُجدْجِيذْ  
\m
\v 14 ”خْمِي غَا ثَاذْفذْ غَارْ ثمُّورْثْ نِّي إِ ذ أَشْ غَا إِوْشْ سِيذِي، أَربِّي نّشْ ؤُشَا أَذْ ت ثطّْفذْ ذ ڒْوَارْثْ ؤُشَا أَذْ ذَايسْ ثْزذْغذْ ؤُ \add خنِّي\add* أَذْ ثِينِيذْ: ’أَذْ خَافِي ڭّغْ \bd إِجّْ ن ؤُجدْجِيذْ\bd* أَمْ مَارَّا ڒڭْنُوسْ إِ ذ أَيِي د-إِنّْضنْ!‘،  
\v 15 \add خنِّي\add* أَذْ خَاكْ ثڭّذْ ذ أَجدْجِيذْ ونِّي إِ غَا يِيخْضَارْ سِيذِي، أَربِّي نّشْ. زِي ڒْوسْطْ ن أَيْثْمَاشْ أَذْ ثڭّذْ ذ إِجّْ ن ؤُجدْجِيذْ خَاكْ، وَارْ خَاكْ تّڭّْ شَا أَبَارَّانِي إِ وَارْ إِدْجِينْ شَا ذ ؤُمَاشْ.  
\v 16 مَاشَا وَارْ إِحدْجڒْ أَذْ يَارْنِي إِيْسَانْ إِ إِخفْ نّسْ ؤُ وَارْ إِتَّارِّي شَا ڒْڭنْسْ غَارْ مِيصْرَا مَاحنْذْ أَذْ يَارْنِي إِيْسَانْ، \add مِينْزِي\add* سِيذِي إِنَّا أَومْ: زِي سَّا ذ ثْسَاونْثْ وَارْ د-ثْعِيقِّيبمْعمَّارْصْ خْ وبْرِيذْ-أَ!  
\v 17 وَارْ إِكسِّي شَا إِ إِخفْ نّسْ أَطَّاسْ ن ثمْغَارِينْ، حِيمَا وَارْ إِتّْغَارِّي وُوڒْ نّسْ. وَارْ يَارنِّي شَا إِ يِيخفْ نّسْ نُّوقَارْثْ نِيغْ ؤُرغْ س وَاطَّاسْ.  
\v 18 خْمِي غَا إِقِّيمْ خْ ڒْعَارْشْ ن ثْڭلْذِيثْ نّسْ، \add خنِّي\add* أَذْ يَارِي إِ يِيخفْ نّسْ إِشْثْ ن ؤُعَاوذْ ن ثِيرَا ن شَّارِيعَا-يَا ذڭْ إِجّْ ن وذْلِيسْ إِتّْوَانّْضنْ زَّاثْ إِ وُوذمْ ن إِكهَّاننْ، إِلَاوِييّنْ.  
\v 19 أَذْ غَارسْ يِيڒِي \add ؤُعَاوذْ ن ثِيرَا-يَا\add*، أَذْ ذَايسْ إِغَارْ مَارَّا ؤُسَّانْ ن ثُوذَارْثْ نّسْ، حِيمَا أَذْ إِڒْمذْ أَذْ إِڭّْوذْ سِيذِي، أَربِّي نّسْ، أَذْ إِحْضَا مَارَّا أَوَاڒنْ ن شَّارِيعَا-يَا ذ ثْوصَّا-يَا ؤُشَا أَذْ زَّايْسنْثْ إِڭّْ،  
\v 20 حِيمَا وَارْ إِسِّيڒِييْ ؤُڒْ نّسْ خْ يَايْثْمَاسْ نِيغْ أَذْ إِحيّذْ خْ وبْرِيذْ ن ثوْصيّثْ، \add وَارْ إِدْجِي\add* \add غَارْ\add* يفُوسْ ؤُڒَا \add غَارْ\add* ؤُزڒْمَاضْ، مَاحنْذْ أَذْ إِزُّوڭَارْثْ ؤُسَّانْ ن ثْڭلْذَا نّسْ، نتَّا ذ وَارَّاوْ نّسْ، ذِي ڒْوسْطْ ن إِسْرَائِيل.“   
\b  
\b  
\m  
\c 18
\s1 ڒْمُونثْ ن إِكهَّاننْ ذ إِلَاوِييّنْ  
\m
\v 1 ”وَارْ ثتِّيڒِي ثسْغَارْثْ نِيغْ ڒْوَارْثْ أَكْ-ذ إِسْرَائِيل إِ إِكهَّاننْ، إِلَاوِييّنْ، إِ مَارَّا ثَاقْبِيتْشْ ن لَاوِي. أَذْ شّنْ ثِيغَارْصَا ن وشْمَاضْ ن سِيذِي ؤُ زِي ثصْغَارْثْ نّسْ. \x ◘ \xo 18:‏1 \xt ڒخْڒ. 18‏:‏20؛ أَعَوذ. 10‏:‏9؛ 1 كُور. 9‏:‏13\x*  
\v 2 وَارْ غَارسْ إِتِّيڒِي ذ ڒْوَارْثْ ذِي ڒْوسْطْ ن أَيْثْمَاسْ. سِيذِي ذ ڒْوَارْثْ نّسْ، أَمْ مَامّشْ ذ أَسْ إِنَّا. \x ◘ \xo 18:‏2 \xt ڒخْڒ. 18‏:‏20‏-‏32.؛ أَعَوذ. 10‏:‏9؛ حِز. 44‏:‏28\x*  
\v 3 مَانْ أَيَا أَذْ يِيڒِي ذ ثَاسْغَارْثْ ن ڒْحقّْ ن إِكهَّاننْ قِيبَاتْشْ إِ ڒْڭنْسْ، قِيبَاتْشْ إِ يِينِّي إِصدّْقنْ إِشْثْ ن ثْغَارْصْثْ، مَا ذ أَفُونَاسْ نِيغْ إِجّنْ زڭْ وُودْجِي: أَذْ وْشنْ إِ ؤُكهَّانْ ثَامصَّاضْثْ ن زَّاثْ، ثْنَاينْ ن إِغسْمِيرنْ ذ ثكْرِيشْثْ.   
\m
\v 4 أَسُوفُّوغْ أَمزْوَارُو \add ن صَّابثْ\add* ن إِرْذنْ نّشْ ؤُ زِي بِينُو ن جْذِيذْ نّشْ ؤُ زِي زّشْثْ نّشْ \add ن طّْرِي\add* ؤُ ثَامزْوَارُوثْ ن وَادْجَاسْ زِي \add ثَاضُوفْثْ ن\add* وُودْجِي نّشْ، أَذْ أَسْ ثوْشذْ.  
\v 5 مِينْزِي يِيخْضَارْ إِ-ث سِيذِي، أَربِّي نّشْ زِي جَارْ مَارَّا ثِيقبَّاڒْ نّشْ، حِيمَا أَذْ إِكَّارْ، أَذْ إِسخَّارْ ذِي طّْوعْ ن يِيسمْ ن سِيذِي، نتَّا ذ أَرَّاوْ نّسْ، مَارَّا ؤُسَّانْ.  
\v 6 خْمِي د غَا يَاسْ ؤُلَاوِي زڭْ إِجّنْ زِي ثوُّورَا نّشْ زِي مَارَّا إِسْرَائِيل، مَانِي إِزدّغْ \add أَمْ ؤُبَارَّانِي\add*، ؤُشَا يُوسَا-د س مَارَّا ڒْخَاضَارْ نّسْ غَارْ ومْشَانْ إِ غَا يِيخْضَارْ سِيذِي  
\v 7 ؤُشَا أَذْ إِسخَّارْ \add ذِينِّي\add* ذڭْ يِيسمْ ن سِيذِي، أَربِّي نّسْ، أَمْ مَارَّا أَيْثْمَاسْ، إِلَاوِييّنْ، إِنِّي ذِينْ إِبدّنْ زَّاثْ إِ وُوذمْ ن سِيذِي،  
\v 8 \add خنِّي\add* أَذْ شّنْ نِيثْنِي ثَاسْغَارْثْ أَنشْثْ ن وَايَاوْيَا، بَارَّا إِ \add تَّامَانْ ن\add* مِينْ إِمّنْزنْ زڭْ \add مِينْ إِدْجَانْ نّسْ\add* عْلَاحْصَابْ \add جَّاذِيرَا نّسْ ن ثَادَّارْثْ ن\add* ڒجْذُوذْ.“   
\b  
\m  
\s1 أَعْڒَامْ غَارْ ڒْڭنْسْ خْ ثْڭزَّانْثْ  
\m
\v 9 ”خْمِي غَا ثَاذْفذْ غَارْ ثمُّورْثْ نِّي إِ ذ أَشْ غَا يوْشْ سِيذِي، أَربِّي نّشْ، وَارْ سّڒْمَاذْ شَا إِ يِيخفْ نّشْ أَذْ ثڭّذْ أَمْ جّْعَايفْ ن ڒڭْنُوسْ-أَ.  
\v 10 وَارْ إِتّْوِيفِّي حذْ جَارْ أَومْ ونِّي إِ غَا إِسّعْذُونْ مِّيسْ نِيغْ يدْجِيسْ خْ ثْمسِّي نِيغْ ونِّي \add إِدْجَانْ\add* ذ أَعزّمْ، \add نِيغْ\add* أَبزْڭَاوْ، \add نِيغْ\add* أَمڭْزُو، \add نِيغْ\add* أَسحَّارْ، \x ◘ \xo 18:‏10 \xt لَاوِي 18‏:‏21؛ 20‏:‏27؛ 1 صم. 28‏:‏7؛ إِشا. 8‏:‏19\x*  
\v 11 \add نِيغْ\add* ونِّي إِتّڭّنْ ثِيرَا، \add نِيغْ\add* ونِّي إِسَّاوَاڒَانْ أَكْ-ذ إِمتَّانْ \add نِيغْ\add* ونِّي إِتّْڭزَّانْ ؤُڒَا ذ ونِّي يَارزُّونْ شّْوَارْ زڭْ إِمتَّانْ.  
\v 12 مِينْزِي مَارَّا ونِّي إِتّڭّنْ ثِيمسْڒَايِينْ-أَ، أَقَا-ث ذ جّْعِيفشْثْ غَارْ سِيذِي ؤُ زِي سِّيبّثْ ن جّْعَايفْ-أَ أَذْ زَّايْسنْ إِكّسْ سِيذِي، أَربِّي نّشْ، ڒْوَارْثْ نْسنْ زَّاثْ إِ وُوذمْ نّشْ.  
\v 13 \add مَاشَا\add* شكْ أَذْ ثِيڒِيذْ ذ أَدُّوذْ زَّاثْ إِ سِيذِي، أَربِّي نّشْ.  
\v 14 مِينْزِي ڒڭْنُوسْ نِّي إِ غَا ثْوَارْثذْ س ؤُغِيڒْ، أَذْ سْڒنْ إِ إِبزْڭَاونْ ذ إِعزَّامنْ، مَاشَا شكْ، وَارْ ذ أَشْ إِسمّحْ سِيذِي، أَربِّي نّشْ، \add أَذْ ثڭّذْ\add* أَيَا.“   
\b  
\m  
\s1 خْ ؤُنَابِي  
\m
\v 15 ”أَذْ أَشْ إِڭّْ سِيذِي، أَربِّي نّشْ، إِجّْ ن ؤُنَابِي زِي ڒْوسْطْ نّشْ، زڭْ أَيْثْمَاشْ، أَمْ نشّْ، إِ نتَّا ؤُمِي غَا ثسْڒمْ، \x ◘ \xo 18:‏15 \xt يُوح. 1‏:‏46؛ ڒخ. 3‏:‏22؛ 7‏:‏37\x*  
\v 16 \add مِينْزِي ذ مَانْ أَيَا\add* أَمْ مَامّشْ مَارَّا مِينْ ثتَّارذْ زِي سِيذِي، أَربِّي نّشْ، ذِي حُورِيبْ ذڭْ وَاسّْ ن وڭْرَاوْ \add ن ڒْڭنْسْ\add*، ؤُمِي ثنِّيذْ: ’وَارْ د-دِّيكّْوِيڒغْ نشّْ أَذْ سْڒغْ إِ ثْمِيجَّا ن سِيذِي، أَربِّي إِنُو، ؤُشَا وَارْ ژَترّغْ نشّْ عَاذْ ثِيمسِّي-يَا إِمْغَارنْ، \add حِيمَا\add* وَارْ تّْمتِّيغْ.‘ \x ◘ \xo 18:‏16 \xt ؤُف. 20‏:‏19؛ أَعَوذ. 5‏:‏25؛ عبر. 12‏:‏19\x*  
\v 17 \add خنِّي\add* إِنَّا أَيِي سِيذِي: ’أَقَا ڭِّينْ مْلِيحْ ؤُمِي كِيكْ سِّيوْڒنْ مَارَّا أَيَا.‘  
\v 18 أَذْ أَسنْ د-سّكّغْ إِجّْ ن ؤُنَابِي زِي ڒْوسْطْ ن أَيْثْمَاثْسنْ، أَمْ شكْ، ؤُشَا نشّْ أَذْ ڭّغْ أَوَاڒنْ إِنُو ذڭْ ؤُقمُّومْ نّسْ ؤُشَا نتَّا أَذْ أَومْ إِسِّيوڒْ خْ مَارَّا مِينْ خفْ ذ أَسْ وصِّيغْ. \x ◘ \xo 18:‏18 \xt يُوح. 4‏:‏25\x*  
\v 19 ؤُشَا أَذْ إِمْسَارْ، أَذْ تَّارغْ ڒحْسَابْ زڭْ ورْيَازْ نِّي وَارْ إِسْڒِينْ إِ وَاوَاڒنْ إِنُو إِ غَا إِسِّيوڒْ س يِيسمْ إِنُو.  
\v 20 مَاشَا أَنَابِي نِّي إِ غَا يُوفّنْ حِيمَا أَذْ إِسِّيوڒْ إِجّْ ن وَاوَاڒْ س يِيسمْ إِنُو، ونِّي نشّْ وَارْ ؤُمُورغْ شَا أَذْ زَّايسْ إِسِّيوڒْ، ذ ونِّي إِ غَا إِسِّيوْڒنْ س يِيسمْ ن إِربِّيثنْ نّغْنِي، أَقَا أَنَابِي نِّي أَذْ إِمّثْ. \x ◘ \xo 18:‏20 \xt أَعَوذ. 13‏:‏6، إِرْم. 14‏:‏14\x*  
\v 21 مَاڒَا ثقَّارذْ ذڭْ وُوڒْ نّشْ: ’مَامّشْ غَا نڭّْ أَذْ نسّنْ أَقَا سِيذِي وَارْ إِسِّيوڒْ أَوَاڒْ نِّي؟‘،  
\v 22 \add خنِّي إِتّْخصَّا أَذْ ثسّْنمْ،\add* خْمِي أَنَابِي نِّي ثُوغَا إِسَّاوَاڒْ س يِيسمْ ن سِيذِي ؤُشَا \add خنِّي\add* أَوَاڒْ نّسْ وَارْ إِمْسَارْ ؤُ وَارْ د-إِفِّيغْ، أَقَا أَوَاڒْ نِّي وَارْ ذ أَسْ إِتّْوَانَّا زِي غَارْ سِيذِي. أَنَابِي نِّي إِسَّاوَاڒْ س ؤُعفَّارْ. وَارْ زَّايسْ تّڭّْوذْ شَا.“   
\b  
\b  
\m  
\c 19
\s1 ثْڒَاثَا ن ثْندَّامْ ن ثَاروْڒَا  
\m
\v 1 ”خْمِي سِيذِي، أَربِّي نّشْ، غَا إِثحَّا ڒڭْنُوسْ إِ زَّايْسنْ ذ أَشْ غَا إِوْشْ، سِيذِي، أَربِّي نّشْ، ثَامُّورْثْ ؤُشَا \add خنِّي\add* أَذْ ثكْسِيذْ ڒْوَارْثْ نْسنْ ؤُشَا أَذْ ثْزذْغذْ ذِي ثْندَّامْ نْسنْ ؤُ ذِي ثُوذْرِينْ نْسنْ،  
\v 2 \add خنِّي\add* إِتّْخصَّا شكْ أَذْ ثْحُوزذْ إِ يِيخفْ نّشْ \bd ثْڒَاثَا ن ثْندَّامْ\bd* ذِي ڒْوسْطْ ن ثمُّورْثْ إِ ذ أَشْ غَا إِوْشْ سِيذِي، أَربِّي نّشْ، مَاحنْذْ أَذْ ت ثكْسِيذْ ذ ڒْوَارْثْ. \x ◘ \xo 19:‏2 \xt ؤُف. 21‏:‏13؛ ڒخْڒ. 35‏:‏9‏-‏34؛ ياش. 20‏:‏2\x*  
\v 3 أَذْ ثْعذْڒذْ إِجّْ ن وبْرِيذْ ؤُشَا ثَامُّورْثْ، ثنِّي ذ أَشْ غَا إِوْشْ سِيذِي، أَربِّي نّشْ، ذ ڒْوَارْثْ، أَذْ ت ثبْضِيذْ خْ ثْڒَاثَا ن ثْسقَّارْ. مَانْ أَيَا حِيمَا كُوڒْ أَقتَّاڒْ إِزمَّارْ أَذْ ذِينْ يَارْوڒْ.   
\m
\v 4 ذ وَا ذ أَمْثَاوِي إِ زِي إِعدّڒْ إِ ؤُقتَّاڒْ مَاحنْذْ أَذْ ذِينْ يَارْوڒْ، حِيمَا أَذْ \add إِقِّيمْ\add* إِدَّارْ: مَاڒَا إِنْغَا جَّارْ نّسْ بْڒَا مَا أَذْ أَسْ إِڭّْ ڒحْسَابْ، ؤُ ثُوغَا وَارْ ث إِشَارّهْ شَا إِضنَّاضْ ذ فَارِيضنَّاضْ.“ \x ◘ \xo 19:‏4 \xt ؤُف. 21‏:‏13؛ أَعَوذ. 4‏:‏41،42\x*   
\m
\v 5 ”ونِّي إِرُوحنْ أَكْ-ذ جَّارْ نّسْ غَارْ وزْغَارْ حِيمَا أَذْ إِقسّْ ثِيشجُّورَا ؤُشَا إِسّْوِيژّضْ أَفُوسْ نّسْ س شَّاقُورْ حِيمَا أَذْ إِحَارْوشْ ثَاشجَّارْثْ ؤُشَا \add خنِّي\add* إِفّغْ أَسْ وُوزَّاڒْ ن شَّاقُورْ ؤُشَا إِڒْقفْ جَّارْ نّسْ ؤُشَا وَانِيثَا إِمُّوثْ، أَقَا وَانِيثَا إِزمَّارْ أَذْ يَارْوڒْ غَارْ إِشْثنْ زِي ن ثْندَّامْ-أَ مَاحنْذْ أَذْ \add إِقِّيمْ\add* إِدَّارْ. \f ◼ \fr 19:‏5 \ft \+bd ’أَزْغَارْ‘\+bd* - نِيغْ ’ڒْْغَابثْ‘ نِيغْ ’ثَازْڭَانْثْ‘.\f*  
\v 6 أَمُّو وَارْ إِزمَّارْ ؤُنقَّامْ ن إِذَامّنْ، خْمِي غَا إِغڒْغڒْ وُوڒْ نّسْ، أَذْ إِضْفَارْ أَقتَّاڒْ ؤُشَا أَذْ خَاسْ إِحَارْثْ، مَاڒَا أَبْرِيذْ ذ أَزِيرَارْ ؤُشَا أَذْ ث إِنغْ أَمْ وَارْ خَاسْ إِدْجِي ڒحْكَامْ س ڒْموْثْ، مِينْزِي ثُوغَا وَارْ ث إِشَارّهْ، \add وَارْ إِدْجِي\add* إِضنَّاضْ \add ؤُڒَا ذ\add* فَارِيضنَّاضْ.  
\v 7 خْ ؤُيَا نشّْ ؤُمُورغْ شكْ، قَّارغْ: ’حُوزْ ثْڒَاثَا ن ثْندَّامْ إِ يِيخفْ نّشْ.‘  
\v 8 ؤُشَا مَاڒَا سِيذِي، أَربِّي نّشْ أَذْ إِوسّعْ ثَامُّورْثْ نّشْ، أَمْ مَامّشْ إِجُّودْجْ إِ ڒجْذُوذْ نّشْ، ؤُ أَذْ أَشْ إِوْشْ مَارَّا ثَامُّورْثْ إِ خْ إِنَّا أَذْ ت إِوْشْ إِ إِبَابَاثنْ نّشْ، \x ◘ \xo 19:‏8 \xt أَمز. 28‏:‏13؛ أَعَوذ. 12‏:‏20\x*  
\v 9 - مَاڒَا أَذْ ثحْضِيذْ مَارَّا ثَاوْصيّثْ-أَ مَاحنْذْ أَذْ ت ثڭّذْ أَمْ مَامّشْ ذ أَشْ ؤُمُورغْ أَسّْ-أَ حِيمَا أَذْ ثخْسذْ سِيذِي، أَربِّي نّشْ، ؤُشَا أَذْ ثُويُورذْ ذڭْ إِبْرِيذنْ نّسْ إِ ڒبْذَا - خنِّي أَذْ ثَارْنِيذْ عَاذْ ثْڒَاثَا ن ثْندَّامْ غَارْ ثْڒَاثَا-يَا، \x ◘ \xo 19:‏9 \xt ياش. 20‏:‏7\x*  
\v 10 حِيمَا وَارْ تّْوَاسِّيزْڒنْ إِذَامّنْ إِمزْذَاڭنْ ذِي ڒْوسْطْ ن ثمُّورْثْ نّشْ، ثنِّي إِ ذ أَشْ غَا إِوْشْ سِيذِي، أَربِّي، ذ ڒْوَارْثْ ؤُشَا أَذْ خَاكْ يِيڒِي دّنْبْ.   
\m
\v 11 \add مَاشَا\add* مَاڒَا شَا ن ورْيَازْ إِشَارْهْ جَّارْ نّسْ ؤُشَا إِقَابڒْ إِ-ث ؤُشَا إِكَّارْ غَارسْ ؤُ \add خنِّي\add* إِڭَّا أَسْ إِشْثْ ن ثشْثِي ؤُشَا إِمُّوثْ، خنِّي يَارْوڒْ غَارْ إِشْثنْ زِي ثْندَّامْ نِّي، \x ◘ \xo 19:‏11 \xt أَمز. 9‏:‏6؛ ؤُف. 21‏:‏12، 14؛ لَاوِي 24‏:‏17؛ ڒخْڒ. 35‏:‏16\x*  
\v 12 \add خنِّي\add* أَذْ سّكّنْ إِمْغَارنْ ن ثنْذِينْثْ نّسْ، أَذْ ث كْسِينْ ث زڭْ ومْشَانْ نِّي، أَذْ ث ڭّنْ ذڭْ إِفَاسّنْ ن ؤُنقَّامْ ن إِذَامّنْ ؤُشَا أَذْ إِمّثْ.  
\v 13 وَارْ ذ أَشْ إِزِّيدْجِيزْ، \add مَاشَا\add* أَذْ ثمْحِيذْ زِي إِسْرَائِيل إِذَامّنْ ن ونِّي وَارْ إِڭِّينْ دّنْبْ حِيمَا أَذْ ثِيڒِيذْ مْلِيحْ.“   
\b  
\m
\v 14 ”وَارْ سْمُوطِّييْ \bd أَيْمِيرْ ن جَّارْ نّشْ،\bd* ونِّي نيّْشنْ ڒجْيُوڒْ \add ن قْبڒْ\add* ذِي ثسْغَارْثْ نّشْ، ثنِّي إِ غَا ثْوَارْثذْ ذِي ثمُّورْثْ إِ ذ أَشْ غَا إِوْشْ سِيذِي، أَربِّي نّشْ، حِيمَا أَذْ ت ثطّْفذْ. \x ◘ \xo 19:‏14 \xt أَوڒن. 22‏:‏28\x*   
\b  
\m  
\s1 خْ ڒشْهُوذْ ذِي ڒْمحْكَامَا  
\m
\v 15 إِجّْ ن ؤُشهَّاذْ \add وَاهَا\add* وَارْ إِزمَّارْ أَذْ إِكَّارْ \add ذ أَشهَّاذْ\add* خْ شَا ن ورْيَازْ ذِي سِّيبّثْ ن شَا ن ڒْمُوعْصِييّثْ نِيغْ ذِي شَا ن دّنْبْ نِّي إِزمَّارْ أَذْ إِتّْوَاڭّْ. خْ \add وَاوَاڒْ زڭْ\add* ؤُقمُّومْ ن \bd ثْنَاينْ\bd* نِيغْ خْ \add وَاوَاڒْ زڭْ\add* ؤُقمُّومْ ن \bd طْرَاثَا ن ڒشْهُوذْ\bd* أَذْ ثتّْوَاضْمنْ ثْمسْڒَاشْثْ. \x ◘ \xo 19:‏15 \xt ڒخْڒ. 35‏:‏30؛ أَعَوذ. 17‏:‏6؛ مت. 18‏:‏16؛ يُوح. 8‏:‏17؛ 2 كُور. 13‏:‏1؛ عبر. 10‏:‏2\x*  
\v 16 خْمِي غَا إِكَّارْ إِجّْ ن ؤُشهَّاذْ أَقْطَاطْعِييْ خْ شَا ن ورْيَازْ حِيمَا أَذْ زَّايسْ إِشثْشَا خْ شَا ن دّنْبْ،  
\v 17 \add خنِّي\add* أَذْ بدّنْ ثْنَاينْ ن يرْيَازنْ، إِنِّي إِتّمّْشُوبُّوشنْ زَّاثْ إِ وُوذمْ ن سِيذِي، زَّاثْ إِ وُوذمْ ن إِكهَّاننْ ذ ڒْقُوضَاثْ نِّي إِ ذِينْ غَا يِيڒِينْ ذڭْ وُوسَّانْ نِّي.  
\v 18 ؤُشَا ڒْقُوضَاثْ أَذْ أَرْزُونْ مْلِيهْ \add ذِي ثْمسْڒَاشْثْ\add*، ؤُ أَقَا، مَاڒَا أَشهَّاذْ ذ إِجّْ ن ؤُشهَّاذْ إِسّْخَارِّيقنْ، أَذْ إِشْهذْ س ڒْبَاطڒْ خْ ؤُمَاسْ،  
\v 19 \add خنِّي\add* أَذْ زَّايسْ ثڭّمْ أَمْ مَامّشْ ثُوغَا إِتّْخَارّصْ أَذْ إِڭّْ نتَّا أَكْ-ذ ؤُمَاسْ. \add أَمُّو\add* إِ غَا ثكّْسذْ ڒْغَارْ زِي ڒْوسْطْ نّشْ، \x ◘ \xo 19:‏19 \xt أَوڒن. 19‏:‏5\x*  
\v 20 حِيمَا إِنِّي إِقِّيمنْ أَذْ سْڒنْ، أَذْ ڭّْوذنْ، وَارْ دِّيكّْوِيرنْ أَذْ ڭّنْ ڒْحَاجّثْ ثَاعفَّانْثْ ذِي ڒْوسْطْ نّشْ.  
\v 21 وَارْ ذ أَشْ إِزِّيدْجِيزْ: ڒعْمَارْ س ڒعْمَارْ، ثِيطّْ س ثِيطّْ، ثِيغْمسْثْ س ثغْمسْثْ، أَفُوسْ س ؤُفُوسْ، أَضَارْ س ؤُضَارْ.“ \x ◘ \xo 19:‏21 \xt ؤُف. 21‏:‏23؛ لَاوِي 24‏:‏20؛ مت. 5‏:‏38\x*   
\b  
\b  
\m  
\c 20
\s1 إِزرْفَانْ إِ ڭَارَّا  
\m
\v 1 ”مَاڒَا ثفّْغذْ غَارْ ؤُمنْغِي أَكْ-ذ ڒْعذْيَانْ نّشْ ؤُشَا ثژْرِيذْ إِيْسَانْ ذ إِكَارُّوثنْ، إِجّْ ن ڒْڭنْسْ كْثَارْ زَّايكْ، وَارْ زَّايْسنْ تّڭّْوذْ شَا، س مِينْزِي سِيذِي، أَربِّي نّشْ، ونِّي شكْ د-إِسُّوفّْغنْ زِي ثمُّورْثْ ن مِيصْرَا، أَقَا-ث أَكِيذكْ.  
\v 2 خْمِي غَا ثَاذْسمْ إِ ؤُمنْغِي، أَذْ د-إِقَارّبْ ؤُكهَّانْ ؤُشَا أَذْ إِسِّيوڒْ غَارْ ڒْڭنْسْ،  
\v 3 أَذْ أَسنْ يِينِي: ’سڒْ، إِسْرَائِيل، كنِّيوْ قَارّْبمْ-د أَسّْ-أَ غَارْ ؤُمنْغِي أَكْ-ذ ڒْعذْيَانْ نْومْ. وَارْ سّمْژَايمْ ؤُڒْ نْومْ، وَارْ تّڭّْوْذمْ نِيغْ أَذْ ثَارْجِيجمْ، نِيغْ \add عَاوذْ\add* أَذْ ثْقفْقِيفمْ زَّاثْ إِ وُوذمْ نْسنْ،  
\v 4 مِينْزِي سِيذِي، أَربِّي نْومْ، نتَّا أَقَا أَذْ كِيومْ يُويُورْ حِيمَا أَذْ خَاومْ إِمّْنغْ زَّاثْ إِ ڒْعذْيَانْ نْومْ مَاحنْذْ أَذْ كنِّيوْ إِسّنْجمْ.‘  
\v 5 ؤُشَا إِمحْضَاينْ أَذْ سِّيوْڒنْ أَكْ-ذْ ڒْڭنْسْ أَذْ إِنِينْ: ’وِي إِبْنَانْ ثَادَّارْثْ ن جْذِيذْ ؤُشَا وَارْ ذَايسْ إِزْذِيغْ عَاذْ؟ أجّْ إِ-ث أَذْ يُويُورْ، أَذْ د-إِذْوڒْ غَارْ ثَادَّارْثْ نّسْ، حِيمَا وَارْ إِتّْمتِّي ذڭْ ؤُمنْغِي ؤُشَا أَذْ د-يَاسْ حذْ نّغْنِي أَذْ ذَايسْ إِزْذغْ.  
\v 6 وِي يژُّونْ ثِيزَايَارِينْ ؤُشَا وَارْ إِغبِّي عَاذْ زِي ڒْغِيدْجثْ نّسْ؟ أجّْ إِ-ث أَذْ يُويُورْ، أَذْ د-إِذْوڒْ غَارْ ثَادَّارْثْ نّسْ، حِيمَا وَارْ إِتّْمتِّي ذڭْ ؤُمنْغِي ؤُشَا أَذْ زَّايسْ إِغبَّا حذْ نّغْنِي. \x ◘ \xo 20:‏6 \xt لَاوِي 19‏:‏23، 24، 25\x*  
\v 7 وِي إِخضْبنْ ثَامْغَارْثْ ؤُ وَارْ ت إِمْڒِيشْ عَاذْ؟ أجّْ إِ-ث أَذْ يُويُورْ، أَذْ د-إِذْوڒْ غَارْ ثَادَّارْثْ نّسْ، حِيمَا وَارْ إِتّْمتِّي ذڭْ ؤُمنْغِي ؤُشَا أَذْ ت يَاوِي ورْيَازْ نّغْنِي. \x ◘ \xo 20:‏7 \xt أَعَوذ. 24‏:‏5\x*  
\v 8 إِمحْضَاينْ أَذْ أَرْنِينْ ذڭْ وَاوَاڒْ أَكْ-ذ ڒْڭنْسْ، أَذْ إِنِينْ: ’وِي إِدْجَانْ ذ أَرْيَازْ ذ أَمَاڭّْوَاذْ نِيغْ إِتّْغَاشَا؟ أجّْ إِ-ث أَذْ يُويُورْ، أَذْ د-إِذْوڒْ غَارْ ثَادَّارْثْ نّسْ، حِيمَا وَارْ تّغْنِيسنْ وُوڒَاونْ ن أَيْثْمَاسْ أَمْ وُوڒْ نّسْ.‘ \x ◘ \xo 20:‏8 \xt ڒقض. 7‏:‏3\x*  
\v 9 خْمِي غَا كمّْڒنْ إِمحْضَاينْ أَوَاڒْ أَكْ-ذ ڒْڭنْسْ، خنِّي أَذْ ڭّنْ إِكُومَانْذَارنْ ن ڒْعسْكَارْ غَارْ ؤُزدْجِيفْ ن ڒْڭنْسْ.“   
\b  
\m
\v 10 ”خْمِي غَا ثَاذْسذْ شَا ن ثنْذِينْثْ حِيمَا أَذْ كِيذسْ ثمّنْغذْ، إِتّْخصَّا أَذْ أَسْ ثْڒَاغِيذْ إِ وصْڒَاحْ.  
\v 11 مَاڒَا ثَارَّا-د خَاكْ س وصْڒَاحْ، \add خنِّي\add* مَارَّا ڒْڭنْسْ نِّي ذَايسْ إِتّْوَافْ، أَذْ شكْ إِسخَّارْ س ؤُغِيڒْ ؤُشَا أَذْ شكْ إِخْذمْ.  
\v 12 مَاڒَا وَارْ كِيكْ ثڭِّي ڒهْنَا، مَاشَا ذ أَمنْغِي إِ ثَارزُّو، \add خنِّي\add* أَذْ أَسْ ثنّْضذْ.  
\v 13 سِيذِي، أَربِّي نّشْ، أَذْ أَشْ ت إِوْشْ إِ شكْ ذڭْ ؤُفُوسْ نّشْ ؤُ مَارَّا \add مِينْ إِدْجَانْ ذ\add* أَوْثمْ ذَايسْ، أَذْ ث ثوْثذْ س ڒقْضعْ ن سِّيفْ.  
\v 14 مْغِيرْ ثِيمطَّا ذ إِحنْجِيرنْ ذ ڒبْهَايمْ ذ مَارَّا مِينْ ذَايسْ ذِي ثنْذِينْثْ، مَارَّا ثَاكشَّاضْثْ نّسْ، أَذْ ت ثكْسِيذْ إِ يِيخفْ نّشْ ذ ثْكشَّاضْثْ ؤُشَا أَذْ ثشّذْ زِي ثْكشَّاضْثْ ن ڒْعذْيَانْ نّشْ، إِنِّي ذ أَشْ إِوْشَا سِيذِي، أَربِّي نّشْ.  
\v 15 أَمنِّي إِ غَا ثڭّذْ ذِي مَارَّا ثِيندَّامْ نِّي خَاكْ إِڭّْوجنْ أَطَّاسْ، ثِينِّي وَارْ إِدْجِينْ زِي ثْندَّامْ ن ڒڭْنُوسْ-أَ.   
\m
\v 16 مَاشَا ثِيندَّامْ ن ڒڭْنُوسْ نِّي ذ أَشْ إِوْشَا سِيذِي، أَربِّي نّشْ، ذ ڒْوَارْثْ، وَارْ زَّايْسنْثْ ثجِّيذْ ؤُڒَا ذ شَا مِينْ غَا يَارّنْ نّفْسْ أَذْ إِقِّيمْ إِدَّارْ. \x ◘ \xo 20:‏16 \xt ڒخْڒ. 33‏:‏52؛ أَعَوذ. 7‏:‏1، 2\x*  
\v 17 أَذْ ثنْثْ ثْحَارّْمذْ إِ ؤُثحِّي: إِحِيتِّييّنْ، إِمُورِييّنْ، أَيْثْ ن كنْعَانْ، إِفِيرِيزِييّنْ، إِحِيوِييّنْ ذ إِيابُوسِييّنْ، أَمْ مَامّشْ إِ ذ أَشْ يُومُورْ سِيذِي، أَربِّي نّشْ،  
\v 18 حِيمَا نِيثْنِي وَارْ ذ أَومْ سّْڒمَّاذنْ أَذْ ثضْفَارمْ مَارَّا جّْعَايفْ نِّي ڭِّينْ نِيثْنِي إِ إِربِّيثنْ نْسنْ ؤُشَا \add خنِّي\add* أَذْ ثخْضَامْ أَكْ-ذ سِيذِي، أَربِّي نْومْ.   
\m
\v 19 مَاڒَا ثنّْضذْ إِ يِيشْثْ ن ثنْذِينْثْ أَطَّاسْ ن وُوسَّانْ ڒَامِي ثمّنْغذْ أَكِيذسْ مَاحنْذْ أَذْ ت ثطّْفذْ، \add خنِّي\add* وَارْ تَّاردَّادْجْ شَا ثِيشجُّورَا س ثيِّيثَا ن شَّاقُورْ، مِينْزِي أَذْ زَّايْسنْثْ ثشّذْ. س ؤُيَا وَارْ ثنْثْ تّْقسِّيذْ، مِينْزِي مَا ثَاشجَّارْثْ ن ييَّارْ أَمْ بْنَاذمْ نِّي د-إِتّْبَاننْ زَّاثْ إِ وُوذمْ نّشْ ؤُمِي ثحْصَارذْ \add ثَانْذِينْثْ\add*؟ \f ◼ \fr 20:‏19 \ft \+bd ’ثَاشجَّارْثْ‘\+bd* - نِيغْ ’أَدَّاڭْ‘ (’إِدَّاڭنْ‘).\f*  
\v 20 مْغِيرْ ثَاشجَّارْثْ نِّي ثسّْنذْ وَارْ ثدْجِي ذ ثَاشجَّارْثْ إِ زِي غَا ثشّذْ، أَقَا ثَانِيثَا أَذْ ت ثَارذْدْجذْ، أَذْ ت ثْقسّذْ، أَذْ \add زَّايسْ\add* ثبْنِيذْ إِجّْ ن سُّورْ خْ ثنْذِينْثْ نِّي أَكِيذكْ إِتّْمنْغَانْ، أَڒْ غَا ثْغضْڒذْ \add ثَانْذِينْثْ نِّي\add*.“   
\b  
\b  
\m  
\c 21
\s1 أَنقِّي زڭْ إِجّنْ إِ وَارْ إِتّْوَاسّْننْ  
\m
\v 1 ”مَاڒَا إِتّْوَافْ حذْ إِتّْوَانغْ ذِي ثمُّورْثْ نِّي ذ أَشْ غَا إِوْشْ سِيذِي، أَربِّي نّشْ، مَاحنْذْ أَذْ ت ثطّْفذْ ذ ڒْوَارْثْ، إِزّڒْ ذڭْ إِيَّارْ ؤُشَا وَارْ إِسِّينْ حذْ وِي ث إِنْغِينْ،  
\v 2 \add خنِّي\add* إِمْغَارنْ نّشْ ذ ڒْقُوضَاثْ نّشْ أَذْ د-فّْغنْ ؤُشَا أَذْ كْسِينْ ڒعْبَارْ أَڒْ ثِيندَّامْ إِ ذ أَسْ د-إِنّْضنْ إِ ونِّي إِتّْوَانْغنْ.  
\v 3 زِي ثنْذِينْثْ نِّي يُوذْسنْ إِ ونِّي إِتّْوَانْغنْ، أَذْ زَّايسْ كْسِينْ يمْغَارنْ إِشْثْ ن ثْعجْمِيثْ ن ثْفُونَاسِينْ نِّيعمَّارْصْ وَارْ زَّايسْ شْرِيزنْ شَا ؤُ ثنِّي وَارْ إِجْبِيذنْ عَاذْ أَزَايْڒُو.  
\v 4 ؤُشَا إِمْغَارنْ ن ثنْذِينْثْ نِّي أَذْ سّهْوَانْ ثَاعجْمِيثْ \add نِّي\add* غَارْ إِشْثْ ن ثغْزُورْثْ \add إِتَّازْڒنْ\add* ڒبْذَا \add س وَامَانْ\add*،عمَّارْصْ وَارْ ثتّْوَاشَارْزْ ؤُ وَارْ ثتّْوَاژُّو ؤُشَا أَذْ أَرْژنْ إِرِي ن ثْعجْمِيثْ ذِينْ ذِي ثغْزُورْثْ.  
\v 5 \add خنِّي\add* أَذْ د-قَارّْبنْ إِكهَّاننْ، أَيْثْ ن لَاوِي، مِينْزِي سِيذِي، أَربِّي نّشْ، إِخْضَارْ إِ-ثنْ مَاحنْذْ أَذْ خَاسْ سخَّارنْ ؤُ مَاحنْذْ أَذْ بَارْكنْ س يِيسمْ ن سِيذِي، ؤُ عْلَاحْسَابْ أَوَاڒْ نْسنْ \add أَذْ إِتّْوَاحْكمْ\add* كُوڒْ أَمْشُوبّشْ ذ كُوڒْ ڒخْشُونثْ.  
\v 6 ؤُشَا مَارَّا إِمْغَارنْ ن ثنْذِينْثْ نِّي يُوذْسنْ خْ ونِّي إِتّْوَانْغنْ، أَذْ سِّيرْذنْ إِفَاسّنْ نْسنْ سنّجْ إِ ثْعجْمِيثْ نِّي ؤُمِي إِتّْوَارْژْ يِيرِي ذِي ثغْزُورْثْ.  
\v 7 أَذْ بَارّْحنْ، أَذْ إِنِينْ: ’إِفَاسّنْ نّغْ وَارْ سِّيزّْڒنْ شَا إِذَامّنْ-أَ ؤُ ثِيطَّاوِينْ نّغْ وَارْ ث ژْرِينْ.  
\v 8 أڭّْ أَصْڒَاحْ إِ ڒْڭنْسْ نّشْ إِسْرَائِيل نِّي ثفْذِيذْ، \add أَ\add* سِيذِي، ؤُشَا وَارْ سّْرُوسَا إِذَامّنْ إِمزْذَاڭنْ ذِي ڒْوسْطْ ن ڒْڭنْسْ نّشْ إِسْرَائِيل!‘ \add خنِّي\add* إِذَامّنْ \add إِتّْوَاسِّيزْڒنْ\add* نِّي أَذْ تّْوَاحسْبنْ ذ ڒفْذِييّثْ إِ نِيثْنِي.  
\v 9 أَمُّو إِ غَا ثكّْسذْ إِذَامّنْ إِمزْذَاڭنْ زِي ڒْوسْطْ نّشْ، مِينْزِي إِتّْخصَّا أَذْ ثڭّذْ مِينْ إِدْجَانْ نِيشَانْ ذِي ثِيطَّاوِينْ ن سِيذِي.“   
\b  
\m  
\s1 ثَامْغَارْثْ إِتّْوَاحبّْسنْ ذِي ڭَارَّا  
\m
\v 10 ”خْمِي غَا ثفّْغذْ غَارْ ؤُمنْغِي أَكْ-ذ ڒْعذْيَانْ نّشْ ؤُشَا سِيذِي، أَربِّي نّشْ، إِڭَّا أَشْ ثنْ ذڭْ إِفَاسّنْ نّشْ ؤُشَا ثِييذْ ثنْ ذ إِمحْبَاسْ،  
\v 11 ؤُشَا ثژْرِيذْ جَارْ إِمحْبَاسْ إِشْثْ ن ثمْغَارْثْ، ثشْنَا ذڭْ وَادُّوذْ، ؤُشَا ثمّژْرذْ أَذْ ت ثكْسِيذْ ذ ثَامْغَارْثْ إِ يِيخفْ نّشْ،  
\v 12 \add خنِّي\add* أَذْ ت ثسِّيذْفذْ غَارْ ثَادَّارْثْ نّشْ ؤُشَا أَذْ ثْحفّْ أَزدْجِيفْ نّسْ، أَذْ ثْقسّذْ إِشَّارنْ نّسْ.  
\v 13 أَذْ ثكّسْ أَرُّوضْ ن ثْمحْبَاسْثْ نّسْ ؤُشَا أَذْ ثقِّيمْ ذِي ثَادَّارْثْ نّشْ ؤُشَا أَذْ ثسْغُويْ إِ بَابَاسْ ذ يمَّاسْ إِجّْ ن ؤُيُورْ إِكْمڒْ ؤُ أَوَارْنِي مَانْ أَيَا ثْزمَّارذْ أَذْ خَاسْ ثَاذْفذْ ؤُشَا أَذْ ثِيڒِيذْ ذ أَرْيَازْ نّسْ ؤُ نتَّاثْ أَذْ ثِيڒِي ذ ثَامْغَارْثْ نّشْ.  
\v 14 ؤُشَا مَاڒَا وَارْ ذ أَشْ ثعْجِيبْ، أَذْ ت ثجّذْ أَذْ ثُويُورْ غَارْ ڒْخَاضَارْ نّسْ، وَارْ ت زْنُوزِي س نُّوقَارْثْ. وَارْ زَّايسْ ثڭّذْ أَخْمِي سّڒْعثْ \add إِ ثدْجَا\add*، مِينْزِي أَقَا ثسّحْقَارذْ ت.“ \f ◼ \fr 21:‏14 \ft \+bd ’غَارْ ڒْخَاضَارْ نّسْ‘\+bd* - س ثْعِيبْرَانِيثْ ’غَارْ ڒعْمَارْ نّسْ‘.\f*   
\b  
\m  
\s1 ڒْحقّْ ن ؤُمنْزُو  
\m
\v 15 ”مَاڒَا أَرْيَازْ غَارسْ ثْنَاينْ ن ثمْغَارِينْ، إِشْثنْ إِتّخْسْ إِ-ت، ثنّغْنِيثْ إِشَارّهْ إِ-ت، ؤُشَا ثنِّي إِشَارّهْ ذ ثنِّي إِتّخْسْ ؤُرْونْثْ أَسْ-د إِحنْجِيرنْ، مَاشَا أَمنْزُو ثُوغَا-ث ن ثنِّي إِشَارّهْ،  
\v 16 \add خنِّي\add* ذڭْ وَاسّْ نِّي إِ ذِي غَا إِبْضَا ڒْوَارْثْ ن مِينْ غَارسْ إِدْجَانْ إِ إِحنْجِيرنْ نّسْ، وَارْ إِزمَّارْ أَذْ إِوْشْ ثَاسْغَارْثْ ن ؤُمنْزُو إِ مِّيسْ ن ثنِّي إِتّخْسْ ذڭْ ومْشَانْ إِ غَا إِوْشْ إِ مِّيسْ ن ثنِّي إِشَارّهْ، \add ونِّي ذ\add* أَمنْزُو \add إِ يدْجَا\add*.  
\v 17 إِتّْخصَّا أَذْ إِنْعمْ س مِّيسْ أَمنْزُو ن ثنِّي إِشَارّهْ ؤُمِي ذ أَسْ غَا إِوْشْ ثْنَاينْ ن ثْسقَّارْ زِي مَارَّا مِينْ ذ أَسْ د-إِكَّارنْ، مِينْزِي نتَّا ذ أَمزْوَارْ ن ثرْيَاسْثْ نّسْ ؤُ ثَاسْغَارْثْ ن ثْمنْزُوثْ نّسْ إِ ثدْجَا.“ \x ◘ \xo 21:‏17 \xt أَمز. 49‏:‏3؛ 1 إِم. 5‏:‏1؛ إِزهد. 78‏:‏51\x*   
\b  
\m  
\s1 مِّيسْ أَغنَّانْ  
\m
\v 18 ”مَاڒَا إِجّْ ن ورْيَازْ غَارسْ مِّيسْ ذ أَغنَّانْ ذ أَمْغوّغْ نِّي وَارْ إِتّسْڒِينْ إِ وَاوَاڒْ ن بَابَاسْ نِيغْ إِ وَاوَاڒْ ن يمَّاسْ، ؤُشَا نِيثْنِي وْثِينْثْ ث، \add مَاشَا\add* نتَّا وَارْ ذ أَسنْ إِتّسْڒِي،  
\v 19 \add خنِّي\add* بَابَاسْ ذ يمَّاسْ أَذْ ث كْسِينْ ؤُشَا أَذْ ث أَوْينْ بَارَّا زَّاثْ إِ إِمْغَارنْ ن ثنْذِينْثْ نّسْ، غَارْ ثوَّارْثْ ن ومْشَانْ \add مَانِي إِزدّغْ\add*.  
\v 20 أَذْ إِنِينْ إِ إِمْغَارنْ ن ثنْذِينْثْ: ’وَا ذ مِّيثْنغْ ذ أَغنَّانْ ذ أَمْغوّغْ، وَارْ إِتّسْڒِي إِ وَاوَاڒْ نّغْ، أَقَا أَفُوسْ نّسْ إِنُّوقّبْ ؤُ نتَّا ذ أَمسْكَارْ.‘  
\v 21 \add خنِّي\add* مَارَّا إِرْيَازنْ ن ثنْذِينْثْ أَذْ ث أَرجْمنْ أَڒْ غَا إِمّثْ. إِتّْخصَّا أَذْ ثكّْسذْ أَعفَّانْ زِي ڒْوسْطْ نْومْ \add حِيمَا\add* مَارَّا إِسْرَائِيل أَذْ ثْسڒْ ؤُشَا أَذْ ثڭّْوذْ.“   
\b  
\m  
\s1 أَنْضڒْ ن ونِّي خَاسْ ڒْحُوكْمْ ن ڒْموْثْ  
\m
\v 22 ”مَاڒَا إِجّْ ن ورْيَازْ إِڭَّا إِجّْ ن دّنْبْ إِ خْ \add إِدْجَا\add* ڒْحُوكْمْ ن ڒْموْثْ ؤُشَا إِتّْوَانغْ، ثُويْڒذْ إِ-ث خْ إِشْثْ ن ثحْنَاشْثْ \add ن ؤُكشُّوضْ\add*،  
\v 23 \add خنِّي\add* وَارْ تّجِّيمْ ڒْخشْبثْ نّسْ أَذْ ثسّنْسْ خْ ثحْنَاشْثْ، مَاشَا أَذْ ث ثْنضْڒذْ ذڭْ وَاسّْ نِّي، مِينْزِي ونِّي إِتّْوَايْڒنْ أَقَا-ث ذ أَمنْعُوڒْ زِي أَربِّي. وَارْ سْخمَّاجْ ثَامُّورْثْ نّشْ، ثنِّي ذ أَشْ غَا إِوْشْ سِيذِي، أَربِّي نّشْ، ذ ڒْوَارْثْ.“ \x ◘ \xo 21:‏23 \xt ڭال. 3‏:‏13\x*   
\b  
\b  
\m  
\c 22
\s1 ثِيوصَّا نّغْنِي  
\m
\v 1 ”وَارْ إِعدّڒْ أَذْ ثْخزَّارذْ \add وَاهَا\add* ذڭْ ؤُودَّارْ ن ؤُفُونَاسْ نِيغْ ن إِجّنْ زڭْ وُودْجِي ن ؤُمَاشْ، نِيغْ أَذْ خَاسنْ ثْقڒْبذْ ثِيطَّاوِينْ، مَاشَا إِتّْخصَّا أَذْ أَشْ ثنْ-إِ-د-ثَارّذْ نِيشَانْ إِ ؤُمَاشْ. \x ◘ \xo 22:‏1 \xt ؤُف. 23‏:‏4\x*  
\v 2 مَاڒَا ؤُمَاشْ وَارْ إِدْجِي شَا يُوذسْ نِيغْ وَارْ ث ثسِّينذْ، أَذْ ث ثسِّيذْفذْ غَارْ ذَاخڒْ إِ ثَادَّارْثْ نّشْ ؤُشَا أَذْ غَاركْ إِقِّيمْ أَڒْ د غَا يَاسْ ؤُمَاشْ أَذْ خَاسْ يَارْزُو ؤُشَا \add خنِّي\add* أَذْ أَسْ \add ث-إِ-\add*د ثَارّذْ.  
\v 3 أَمنِّي إِ غَا ثڭّذْ س وغْيُوڒْ نّسْ، أَمنِّي إِ غَا ثڭّذْ \add عَاوذْ\add* س وَارُّوضْ نّسْ، \add وَاهْ،\add* أَمُّو إِ غَا ثڭّذْ أَكْ-ذ مَارَّا ثَامسْڒَاشْثْ ن ؤُمَاشْ، ثنِّي ذ أَسْ إِودَّارنْ ؤُشَا ثُوفِيذْ ت شكْ. وَارْ إِعدّڒْ أَذْ أَسْ ثنُّوفَارذْ. \f ◼ \fr 22:‏3 \ft \+bd ’وَارْ إِعدّڒْ أَذْ أَسْ ثنُّوفَارذْ‘\+bd* - ذ مَانْ أَيَا إِخْسْ أَذْ يِينِي ’وَارْ إِعدّڒْ أَذْ أَسْ ثنْكَارذْ أَعَاونْ نّشْ‘.\f*  
\v 4 وَارْ \add ثقِّيمذْ\add* أَذْ ثخْزَارذْ ذڭْ وغْيُوڒْ ن ؤُمَاشْ نِيغْ ذڭْ ؤُفُونَاسْ نّسْ أَمْ وْضَانْ ذڭْ وبْرِيذْ، وَارْ خَاسنْ قدْجبْ شَا ثِيطَّاوِينْ. س ثِيذتّْ أَذْ ثنْ ثسّكَّارذْ أَكِيذسْ.“   
\b  
\m
\v 5 ”ثَامْغَارْثْ وَارْ ثْيَارّضْ مِينْ إِتّْڒِيقنْ إِ ورْيَازْ، نِيغْ أَرْيَازْ أَذْ يَارْضْ أَرُّوضْ ن ثمْغَارْثْ، مِينْزِي مَارَّا وِي إِتّڭّنْ أَيَا أَقَا-ت ذ جّْعِيفشْثْ إِ سِيذِي، أَربِّي نّشْ.   
\m
\v 6 مَاڒَا إِبَانْ-د زَّاثْ إِ وُوذمْ نّشْ خْ وبْرِيذْ شَا ن ڒْعُوشّْ ن وجْضِيضْ، ذِي شَا ن ثْشجَّارْثْ نِيغْ خْ ثمُّورْثْ، \add س\add* إِوَارُّوذنْ نِيغْ \add س\add* ثْمدْجَاڒِينْ، ؤُشَا يمَّاثْسنْ ثسّْذڒْ خْ إِوَارُّوذنْ نِيغْ خْ ثْمدْجَاڒِينْ، \add خنِّي\add* وَارْ تّطّفْ يمَّاثْسنْ أَكْ-ذ إِوَارُّوذنْ. \f ◼ \fr 22:‏6 \ft \+bd ’ثَاشجَّارْثْ‘\+bd* - نِيغْ ’أَدَّاڭْ‘ (’إِدَّاڭنْ‘).\f*  
\v 7 أَذْ ثجّذْ أَذْ ثُويُورْ يمَّاثْسنْ، مَاشَا أَذْ ثكْسِيذْ إِوَارُّوذنْ إِ يِيخفْ نّشْ، حِيمَا أَذْ ثِيڒِيذْ مْلِيحْ، ؤُشَا أَذْ أَشْ زُوڭَّارْثنْ وُوسَّانْ \add ن ثُوذَارْثْ\add* نّشْ.   
\m
\v 8 خْمِي غَا ثبْنِيذْ ثَادَّارْثْ ن جْذِيذْ، أَذْ ثڭّذْ ثَاعْمَاذْثْ خْ ثْزقَّا نّشْ، \add حِيمَا\add* وَارْ تِّيكّْوِيضنْ إِذَامّنْ غَارْ ثَادَّارْثْ نّشْ، مَاڒَا إِوْضَا-د زَّايسْ حذْ.   
\m
\v 9 وَارْ زَارّعْ شَا أَمَارْجعْ ن ؤُضِيڒْ نّشْ س ثْنَاينْ ن مَارْكَاثْ ن زَّارِيعثْ، حِيمَا وَارْ ثتّْوَاسّْعِيدْجِيثْ مَارَّا صَّابثْ ن زَّارِيعثْ نِّي ثْزَارْعذْ ؤُڒَا ذ ڒْغِيدْجثْ ن ؤُمَارْجعْ ن ؤُضِيڒْ. \x ◘ \xo 22:‏9 \xt لَاوِي 19‏:‏19\x*  
\v 10 وَارْ شَارّزْ شَا س ؤُفُونَاسْ ذ وغْيُوڒْ جْمِيعْ.  
\v 11 وَارْ يَارّضْ شَا أَرُّوضْ إِتّْوَاڭّنْ زِي ثْخدْجضْثْ ن ثَاضُوفْثْ ذ ڒقْطنْ جْمِيعْ.  
\v 12 أَذْ ثڭّذْ ثْشَارْشِيفَا خْ أَربْعَا ن إِغمُّورَا ن ؤُسڒْهَامْ نّشْ إِ زِي ثْڒحّْفذْ.“ \x ◘ \xo 22:‏12 \xt ڒخْڒ. 15‏:‏38؛ مت. 23‏:‏5\x*   
\b  
\m  
\s1 إِزرْفَانْ زِي جِّيهثْ ن ڒمْڒَاشْ  
\m
\v 13 ”مَاڒَا إِجّْ ن ورْيَازْ يِيوِي إِشْثْ ن ثمْغَارْثْ ؤُشَا يُوذفْ-د خَاسْ، \add خنِّي\add* أَذْ ت إِشَارْهْ،  
\v 14 ؤُشَا إِسّكَّارْ خَاسْ أَوَاڒنْ ؤُشَا يَارَّا إِسمْ نّسْ ذ أَعفَّانْ، إِنَّا: ’أَقَا ثَامْغَارْثْ-أَ إِوْيغْ ت، ؤُشَا \add ؤُمِي\add* غَارسْ-د قَارّْبغْ، إِوْضغْ أَذْ سّْنغْ أَقَا وَارْ ثدْجِي شَا ذ ثَاعْزَارشْثْ!‘،  
\v 15 \add خنِّي\add* أَذْ إِسّْشنْ بَابَاسْ ن ثبْڒِيغْثْ نِّي ذ يمَّاسْ \add لْبُورْهَانَاثْ\add* ن ثْغُونِي ن ثبْڒِيغْثْ إِ يمْغَارنْ غَارْ ثوَّارْثْ ن ثنْذِينْثْ.  
\v 16 أَذْ يِينِي بَابَاسْ ن ثبْڒِيغْثْ نِّي إِ يمْغَارنْ: ’نشّْ وْشِيغْ يدْجِي إِ ورْيَازْ-أَ ذ ثَامْغَارْثْ ؤُشَا نتَّا إِذْوڒْ إِشَارْهْ إِ-ت،  
\v 17 ؤُشَا أَقَا نتَّا إِسّكَّارْ خَاسْ أَوَاڒنْ، إِنَّا: وَارْ ؤُفِيغْ غَارْ يدْجِيشْ \add لْبُورْهَانَاثْ\add* ن ثْغُونِي ن ثبْڒِيغْثْ. أَقَا أَيَا ذ \add لْبُورْهَانَاثْ ن\add* ثْغُونِي ن يدْجِي!‘ ؤُشَا نِيثْنِي أَذْ بزّْعنْ أَڒحَّافْ زَّاثْ إِ وُوذمْ ن إِمْغَارنْ ن ثنْذِينْثْ.  
\v 18 \add خنِّي\add* أَذْ طّْفنْ إِمْغَارنْ ن ثنْذِينْثْ أَرْيَازْ نِّي ؤُشَا أَذْ ث فَارْشنْ  
\v 19 ؤُشَا أَذْ أَسْ ڭّنْ مُولْثَا ن مْيَا \add ن ؤُقِييَّاثْ\add* ن نُّوقَارْثْ ؤُشَا أَذْ ثنْثْ وْشِينْ إِ بَابَاسْ ن ثبْڒِيغْثْ \add نِّي\add*، مِينْزِي نتَّا يَارَّا إِسمْ ذ أَعفَّانْ خْ إِشْثْ ن ثعْزَارشْثْ زِي إِسْرَائِيل. أَذْ ثِيڒِي ذ ثَامْغَارْثْ نّسْ، وَارْ إِحدْجڒْ أَذْ أَسْ إِدْجفْ مَارَّا ؤُسَّانْ \add مِينْ غَا يكّْ إِدَّارْ\add*.  
\v 20 \add مَاشَا\add* مَاڒَا إِفّغْ مَانْ أَيَا ذ ثِيذتّْ ؤُشَا وَارْ ؤُفِينْ \add لْبُورْهَانَاثْ\add* ن ثْغُونِي غَارْ ثبْڒِيغْثْ،  
\v 21 \add خنِّي\add* أَذْ سُّوفّْغنْ ثَابْڒِيغْثْ نِّي غَارْ ثوَّارْثْ ن ثَادَّارْثْ ن بَابَاسْ ؤُشَا أَذْ ت أَرجْمنْ يرْيَازنْ ن ثنْذِينْثْ، \add أَڒْ\add* غَا ثمّثْ، مِينْزِي ثڭَّا ڒفْضِيحثْ ذِي إِسْرَائِيل ؤُمِي ثسّفْضحْ إِخفْ نّسْ ذِي ثَادَّارْثْ ن بَابَاسْ. إِتّْخصَّا أَذْ ثكّْسذْ ڒْغَارْ زِي ڒْوسْطْ نّشْ.“   
\m
\v 22 ”مَاڒَا إِتّْوَاطّفْ إِجّْ ن ورْيَازْ ؤُمِي إِطّصْ أَكْ-ذ شَا ن ثمْغَارْثْ إِ \add إِدْجَانْ\add* أَكْ-ذ ورْيَازْ، \add خنِّي\add* أَذْ مّْثنْ س ثْنَاينْ، أَرْيَازْ نِّي إِطّْصنْ أَكْ-ذ ثمْغَارْثْ ذ ثمْغَارْثْ \add عَاوذْ\add*. إِتّْخصَّا أَذْ ثكّْسذْ ڒْغَارْ زِي إِسْرَائِيل. \x ◘ \xo 22:‏22 \xt لَاوِي 20‏:‏10\x*   
\m
\v 23 مَاڒَا إِشْثْ ن ثبْڒِيغْثْ ذ ثَاعْزَارشْثْ ثتّْوَاخْضبْ زڭْ إِجّْ ن ورْيَازْ، ؤُشَا يُوفَا إِ-ت إِجّْ ن ورْيَازْ ذِي ثنْذِينْثْ ؤُشَا إِطّصْ أَكِيذسْ،  
\v 24 \add خنِّي\add* أَذْ ثنْ ثسُّوفّْغمْ بَارَّا س ثْنَاينْ غَارْ ثوَّارْثْ ن ثنْذِينْثْ، أَذْ تّْوَارجْمنْ أَڒْ غَا مّْثنْ نِيثْنِي: ثَابْڒِيغْثْ مِينْزِي وَارْ ثسّكَّارْ شَا ثْغُويِّيثْ ذِي ثنْذِينْثْ، أَرْيَازْ مِينْزِي إِسّحْقَارْ ثَامْغَارْثْ ن جَّارْ نّسْ. إِتّْخصَّا أَذْ ثكّْسذْ ڒْغَارْ زِي ڒْوسْطْ نّشْ.   
\m
\v 25 مَاڒَا إِجّْ ن ورْيَازْ يُوفَا إِشْثْ ن ثبْڒِيغْثْ إِتّْوَاخضْبنْ ذڭْ إِيَّارْ ؤُشَا إِسّخْسَارْ إِ-ت ورْيَازْ، إِطّصْ أَكِيذسْ، \add خنِّي\add* إِتّْخصَّا أَذْ إِمّثْ ورْيَازْ وَاهَا، ونِّي كِيسْ إِطّْصنْ.  
\v 26 وَارْ تّڭّْ وَالُو إِ ثبْڒِيغْثْ. ثَابْڒِيغْثْ وَارْ ثڭِّي شَا دّنْبْ أَڒْ ڒْموْثْ، مِينْزِي ثَامسْڒَاشْثْ-أَ أَمْ \add ثْمسْڒَاشْثْ\add* ن ورْيَازْ نِّي إِكَّارنْ أَكْ-ذ جَّارْ نّسْ ؤُشَا إِنْغَا إِ-ث،  
\v 27 مِينْزِي نتَّا يُوفِي ت ذڭْ إِيَّارْ، ثسْغُويْ ثبْڒِيغْثْ نِّي إِتّْوَاخضْبنْ، مَاشَا وَارْ ثُوغِي ذِينْ وِي ت غَا إِسّْنجْمنْ.   
\m
\v 28 خْمِي شَا ن ورْيَازْ يُوفَا إِشْثْ ن ثبْڒِيغْثْ ذ ثَاعْزَارشْثْ، وَارْ ت إِخْضِيبْ حذْ، ؤُشَا نتَّا إِطّفْ إِ-ت، إِطّصْ أَكِيذسْ ؤُشَا تّْوَافنْ نِيثْنِي،  
\v 29 \add خنِّي\add* أَرْيَازْ نِّي إِطّْصنْ أَكِيذسْ أَذْ إِوْشْ إِ بَابَاسْ ن ثبْڒِيغْثْ خمْسِينْ ن \add ؤُقِييَّاثْ ن\add* نُّوقَارْثْ ؤُ نتَّاثْ أَذْ ثذْوڒْ ذ ثَامْغَارْثْ نّسْ، ؤُمِي ت إِسّحْقَارْ. وَارْ إِزمَّارْ أَذْ أَسْ إِدْجفْ مَارَّا ؤُسَّانْ \add ن ثُوذَارْثْ\add* نّسْ. \x ◘ \xo 22:‏29 \xt ؤُف. 22‏:‏16\x*   
\m
\v 30 وَارْ إِعدّڒْ إِ ورْيَازْ أَذْ إِكْسِي ثَامْغَارْثْ ن بَابَاسْ ؤُ وَارْ إِعدّڒْ أَذْ إِسّْعَارَّا خْ وَافْرِيوْ \add إِتّْسَارَّانْ\add* ن وَارُّوضْ ن بَابَاسْ.“ \x ◘ \xo 22:‏30 \xt أَعَوذ. 27‏:‏20\x*   
\c 23
\s1 خْ يِينِّي وَارْ إِزمَّارنْ أَذْ أَذْفنْ غَارْ ثْمسْمُونْثْ  
\m
\v 1 ”وَارْ إِعدّڒْ إِ \bd ونِّي ؤُمِي ذقْفنْ\bd*، ؤُمِي تّْوَادّْزنْ \add إِمدْجَاڒنْ\add* نِيغْ تّْوَاكّْسنْ إِمنْيَارنْ أَذْ يَاذفْ غَارْ وڭْرَاوْ \add ن ڒْڭنْسْ\add* ن سِيذِي.   
\m
\v 2 وَارْ إِعدّڒْ إِ \bd مِّيسْ ن ڒحْرَامْ\bd* أَذْ يَاذفْ غَارْ وڭْرَاوْ \add ن ڒْڭنْسْ\add* ن سِيذِي. عَاذْ أَڒْ جِّيڒْ وِيسّْعشْرَا نّسْ \add ؤُڒَا ذ إِجّْ زَّايسْ\add* وَارْ ذ أَسْ إِعدّڒْ أَذْ يَاذفْ غَارْ ثْمسْمُونْثْ ن سِيذِي.   
\m
\v 3 \bd وَارْ إِعدّڒْ إِ يِيجّنْ ن زڭْ أَيْثْ ن عَامُّونْ نِيغْ إِ يِيجّنْ زڭْ أَيْثْ ن مُوآبَ إِ أَذْ يَاذفْ غَارْ وڭْرَاوْ \+bdit ن ڒْڭنْسْ\+bdit* ن سِيذِي.\bd* وَاخَّا أَڒْ جِّيڒْ وِيسّْعشْرَا نّسْ عَاذْ وَارْ إِعدّڒْ إِ \add ؤُڒَا ذ إِجّْ زَّايْسنْ\add* أَذْ يَاذفْ غَارْ وڭْرَاوْ \add ن ڒْڭنْسْ\add* ن سِيذِي إِ ڒبْذَا،\x ◘ \xo 23:‏3 \xt نَاح. 13‏:‏1\x*  
\v 4 مِينْزِي نِيثْنِي وَارْ غَارْومْ د-فِّيغنْ حِيمَا أَذْ كِيذْومْ مْسَاڭَارنْ غَارْ وبْرِيذْ س وغْرُومْ ذ وَامَانْ ؤُمِي د-ثفّْغمْ زِي مِيصْرَا ؤُشَا ؤُمِي نتَّا خَاكْ إِشْرَا بَالْعَامْ، مِّيسْ ن بَاعُورْ، زِي فَاثُورْ زِي \add ثمُّورْثْ ن\add* أَرَامْ-نَاهْرَايْنْ، \add أَقَا-ت ذ مِيسُوپُوثَامْيَا\add*، مَاحنْذْ أَذْ شكْ إِنْعڒْ. \f ◼ \fr 23:‏4 \ft \+bd ’أَرَامْ-نَاهْرَايْنْ‘\+bd* - س ثْعِيبْرَانِيثْ ’مِيسُوپُوثَامِييَا‘.\f*  \x ◘ \xo 23:‏4 \xt ڒخْڒ. 22‏-‏24\x*  
\v 5 \add مَاشَا\add* سِيذِي، أَربِّي نّشْ، ثُوغَا وَارْ إِخْسْ أَذْ إِسڒْ إِ بَالْعَامْ ؤُشَا سِيذِي، أَربِّي نّشْ، يَارَّا نّعْڒثْ ذ لْبَارَاكَا، مِينْزِي سِيذِي، أَربِّي نّشْ، ثُوغَا إِتّخْسْ إِ شكْ.  
\v 6 وَارْ ثَارزُّو خْ ڒهْنَا نْسنْ ذ ڒْخَارْ نْسنْ، مَارَّا ؤُسَّانْ \add ن ثُوذَارْثْ نّشْ\add*، أَڒْ إِ ڒبْذَا. \x ◘ \xo 23:‏6 \xt عِز. 9‏:‏12\x*   
\m
\v 7 \bd وَارْ شَارّهْ أَذُومِي\bd*، مِينْزِي نتَّا ذ ؤُمَاشْ، \bd وَارْ شَارّهْ أَمِيصْرِي\bd*، مِينْزِي ثُوغَا شكْ ذ أَبَارَّانِي ذِي ثمُّورْثْ نّسْ.  
\v 8 إِحنْجِيرنْ إِ ذ أَسنْ إِتّْوَارْونْ إِعدّڒْ أَسنْ أَذْ أَذْفنْ غَارْ وڭْرَاوْ \add ن ڒْڭنْسْ\add* ن سِيذِي زِي جِّيڒْ وِيسّْ ثْڒَاثَا.“   
\b  
\m  
\s1 ثِيوصَّا نّغْنِي  
\m
\v 9 ”ؤُمِي د غَا ثفّْغذْ س ڒْعسْكَارْ ضِيدّْ إِ ڒْعذْيَانْ نّشْ، أَذْ ثحْضِيذْ إِخفْ نّشْ زِي مَارَّا ڒْغَارْ.  
\v 10 مَاڒَا ذِينْ إِجّْ ن ورْيَازْ أَكِيذكْ، وَارْ إِدْجِي شَا ذ أَمزْذَاڭْ أَكْ-ذ مِينْ إِمْسَارنْ س دْجِيڒثْ، أَذْ إِفّغْ بَارَّا إِ ڒْمَارْڭحْ ن ڒْعسْكَارْ. وَارْ ذ أَسْ إِعدّڒْ مَاحنْذْ أَذْ يَاذفْ غَارْ ذَاخڒْ ن ڒْمَارْڭحْ.  
\v 11 غَارْ ؤُوطُّو ن ثْمذِّيثْ، أَذْ إِسِّيرْذْ إِخفْ نّسْ س وَامَانْ ؤُ أَوَارْنِي إِ ؤُغدْجَايْ ن ثْفُوشْثْ إِزمَّارْ أَذْ يَاذفْ \add عَاوذْ\add* غَارْ ڒْمَارْڭحْ.  
\v 12 إِتّْخصَّا أَذْ غَاركْ يِيڒِي ومْشَانْ بَارَّا إِ ڒْمَارْڭحْ ن ڒْعسْكَارْ مَانِي غَا ثفّْغذْ ذِي بَارَّا.  
\v 13 أَذْ غَاركْ يِيڒِي عَاوذْ جَارْ ڒقْشُوعْ نّشْ إِجّْ ن ؤُجِيجْ ؤُشَا خْمِي غَا ثقِّيمذْ بَارَّا، أَذْ زَّايسْ ثْخبْشذْ إِجّْ ن وحْفُورْ، أَذْ ثنْقڒْبذْ ؤُ أَذْ ثْخمّْڒذْ إِسُوفّْغَانْ نّشْ.  
\v 14 مِينْزِي سِيذِي، أَربِّي نّشْ، إِڭُّورْ ذِي ڒْمَارْڭحْ نّشْ ن ڒْعسْكَارْ حِيمَا أَذْ شكْ إِفكّْ ؤُ حِيمَا أَذْ \add أَشْ\add* إِسلّمْ ڒْعذْيَانْ نّشْ زَّاثْ إِ وُوذمْ نّشْ. ثَاسْقِيفْثْ نّشْ أَثْ ثِيڒِي ثْقدّسْ، حِيمَا نتَّا وَارْ ذَايكْ إِتّْوِيڒِي شَا ن ڒفْضِيحثْ ؤُشَا أَذْ خَاكْ إِنّقْڒبْ أَوَارْنِي أَشْ.“   
\b  
\m
\v 15 ”إِسْمغْ إِ غَاركْ د-يَاروْڒنْ زِي بَابْ نّسْ، وَارْ ثْزمَّارذْ أَذْ ث ثْسلّْمذْ \add عَاوذْ\add* إِ بَابْ نّسْ.  
\v 16 أَذْ كِيكْ إِزْذغْ ذِي ڒْوسْطْ نّشْ، ذڭْ ومْشَانْ نِّي غَا يِيخْضَارْ غَارْ ذَاخڒْ إِ يِيشْثْ زِي ثوُّورَا نّشْ، مَانِي غَا يِيڒِي مْلِيحْ. وَارْ إِعدّڒْ أَذْ ث ثْضڒْمذْ.   
\m
\v 17 وَارْ ثتِّيڒِي ؤُڒَا ذ إِشْثْ ن ثمْغَارْثْ ن فَارْقْ-شّْغڒْ ن زَّاوشْثْ جَارْ يسِّيسْ ن إِسْرَائِيل ؤُشَا وَارْ إِتِّيڒِي ؤُڒَا ذ إِجّْ ن ؤُمثْلِي \add ن زَّاوشْثْ\add* جَارْ أَيْثْ ن إِسْرَائِيل.   
\m
\v 18 مَامّشْ مَا يڭَّا وَاوَاڒْ نّشْ، وَارْ إِعدّڒْ أَذْ د-ثَاوْيذْ إِ ؤُيَا ڒْمُونثْ ن فَارْقْ-شّْغڒْ نِيغْ تَّامَانْ ن وقْزِينْ غَارْ ثَادَّارْثْ ن سِيذِي، أَربِّي نّشْ، مِينْزِي أَقَا أَثنْ س ثْنَاينْ ذ إِشْثْ ن جّْعِيفشْثْ غَارْ سِيذِي، أَربِّي نّشْ.   
\m
\v 19 وَارْ تّڭّْ أَرِّيبَا خْ ؤُمَاشْ، وَارْ إِدْجِي أَرِّيبَا خْ نُّوقَارْثْ، وَارْ إِدْجِي أَرِّيبَا خْ مَاشَّا، وَارْ إِدْجِي أَرِّيبَا خْ مَارَّا ثَامسْڒَاشْثْ نِّي إِزمَّارنْ أَذْ د-ثَاوِي أَرِّيبَا. \f ◼ \fr 23:‏19 \ft \+bd ’أَرِّيبَا‘\+bd* - نِيغْ ’ڒْْفَايْذَا‘.\f*  \x ◘ \xo 23:‏19 \xt ؤُف. 22‏:‏25؛ لَاوِي 25‏:‏36؛ نَاح. 5‏:‏2‏-‏13.؛ لك. 6‏:‏34، 35\x*  
\v 20 ثْزمَّارذْ أَذْ ثڭّذْ أَرِّيبَا خْ ؤُبَارَّانِي، مَاشَا وَارْ ثْزمَّارذْ أَذْ ثڭّذْ أَرِّيبَا خْ ؤُمَاشْ، حِيمَا أَذْ أَشْ إِبَاركْ سِيذِي، أَربِّي نّشْ، ذِي مَارَّا ڒْخذْمثْ ن إِفَاسّنْ نّشْ ذِي ثمُّورْثْ مَانِي غَا ثْرَاحذْ حِيمَا أَذْ ت ثكْسِيذْ ذ ڒْوَارْثْ.   
\m
\v 21 خْمِي غَا ثڭّذْ إِجّْ ن لْوَاعْذْ إِ سِيذِي، أَربِّي نّشْ، وَارْ ثذِّيكّْوِيڒذْ شَا غَارْ ضفَّارْ مَاحنْذْ أَذْ ث ثْكمّْڒذْ، مِينْزِي سِيذِي، أَربِّي نّشْ، أَذْ زَّايكْ إِتَّارْ \add أَذْ\add* ث \add ثْكمّْڒذْ\add*، \add مَاڒَا لَّا\add* أَذْ خَاكْ يِيڒِي ذ دّنْبْ. \x ◘ \xo 23:‏21 \xt ڒخْڒ. 30‏:‏3\x*  
\v 22 مَاڒَا وَارْ ثڭِّيذْ إِجّْ ن لْوَاعْذْ، وَارْ خَاكْ إِتِّيڒِي دّنْبْ.  
\v 23 مِينْ د-إِفّْغنْ زِي جَارْ إِينْشِيشنْ نّشْ، أَذْ ث ثْكمّْڒذْ س ثِيذتّْ، أَمْ مَامّشْ إِتّْخصَّا أَذْ ثْكمّْڒذْ لْوَاعْذْ ن ثوْهِيبْثْ س ڒْخَاضَارْ نِّي زِي ثْوَاعْذذْ سِيذِي، أَربِّي نّشْ، ؤُ ونِّي خْ ثسِّيوْڒذْ س ؤُقمُّومْ نّشْ.   
\m
\v 24 خْمِي غَا ثَاذْفذْ غَارْ ؤُمَارْجعْ ن ؤُضِيڒْ ن ؤُمْقَارَّابْ نّشْ، ثْزمَّارذْ أَذْ ثشّذْ أَضِيڒْ عْلَاحْسَابْ مژْرِي ن ڒعْمَارْ نّشْ، مَاشَا إِتّْخصَّا وَارْ ثتّڭّذْ وَالُو ذِي ثْسُودْجثْ نّشْ.   
\m
\v 25 مَاڒَا ثُوذْفذْ غَارْ إِمنْذِي إِبدّنْ ن جَّارْ نّشْ، ثْزمَّارذْ أَذْ ثكْسِيذْ ثِيذْرِينْ س إِفَاسّنْ نّشْ، مَاشَا وَارْ إِعدّڒْ أَذْ ثوْثذْ أَمْجَارْ ذڭْ إِمنْذِي إِبدّنْ ن جَّارْ نّشْ.“ \x ◘ \xo 23:‏25 \xt مت. 12‏:‏1\x*   
\b  
\b  
\m  
\c 24
\s1 إِجّْ ن ڒْحَاڒْ إِفَارْزنْ ن وَادْجَافْ  
\m
\v 1 ”خْمِي غَا يَاوِي إِجّْ ن ورْيَازْ إِشْثْ ن ثمْغَارْثْ ؤُشَا إِمْڒشْ أَكِيذسْ ؤُشَا وَارْ ذ أَسْ ثعْجِيبْ ؤُمِي ذَايسْ يُوفَا شَا ن ڒفْضِيحثْ، ؤُشَا \add خنِّي\add* أَذْ أَسْ يَارِي ثَابْرَاثْ ن ودْجَافْ، أَذْ أَسْ ت إِوْشْ ذڭْ ؤُفُوسْ نّسْ ؤُشَا أَذْ ت إِسُّوفغْ زِي ثَادَّارْثْ نّسْ، \x ◘ \xo 24:‏1 \xt مت. 5‏:‏31؛ 19‏:‏7؛ مك. 10‏:‏4\x*  
\v 2 ؤُشَا \add خنِّي\add* ثفّغْ نتَّاثْ زِي ثَادَّارْثْ نّسْ، ثْرُوحْ ؤُشَا ثذْوڒْ ذ ثَامْغَارْثْ غَارْ إِجّْ ن ورْيَازْ نّغْنِي،  
\v 3 ؤُشَا أَرْيَازْ أَنڭَّارُو إِشَارْهْ إِ-ت، أَذْ أَسْ يَارِي ثَابْرَاثْ ن ودْجَافْ ؤُشَا أَذْ أَسْ ت إِوْشْ ذڭْ ؤُفُوسْ نّسْ ؤُشَا أَذْ ت إِسّكّْ زِي ثَادَّارْثْ نّسْ، نِيغْ أَرْيَازْ أَنڭَّارُو نِّي إِ-ت يِيوْينْ ذ ثَامْغَارْثْ \add نّسْ\add*، إِمُّوثْ،  
\v 4 \add خنِّي\add* وَارْ إِعدّڒْ إِ ورْيَازْ نّسْ أَمزْوَارُو، ونِّي ذ أَسْ إِطلّْقنْ، أَذْ ت يڭّْ \add عَاوذْ\add* ذ ثَامْغَارْثْ إِ يِيخفْ نّسْ، أَوَارْنِي ؤُمِي ثتّْوَاسّخْمجْ نتَّاثْ، مِينْزِي مَانْ أَيَا ذ جّْعِيفشْثْ زَّاثْ إِ وُوذمْ ن سِيذِي. وَارْ إِعدّڒْ أَذْ ثسِّيوِيضْ دّنْبْ خْ ثمُّورْثْ إِ ذ أَشْ إِوْشَا سِيذِي، أَربِّي نّشْ، ذ ڒْوَارْثْ.“   
\b  
\m  
\s1 ثِيوصَّا إِ ؤُحطُّو خْ ؤُمْقَارّبْ  
\m
\v 5 ”خْمِي إِجّْ ن ورْيَازْ ثُوغَا أَمْ إِمْڒشْ، \add خنِّي\add* وَارْ إِتّفّغْ شَا أَكْ-ذ ڒْعسْكَارْ ؤُ وَارْ خَاسْ ثتّْوَاڭّْ ؤُڒَا ذ إِشْثْ ن ثْمسْڒَاشْثْ. أَذْ يِيڒِي إِجّْ ن ؤُسڭّْوَاسْ إِ ثَادَّارْثْ نّسْ وَاهَا ؤُ أَذْ إِسّْفَارْحْ ثَامْغَارْثْ نّسْ إِ يِيوِي \add إِ يِيخفْ نّسْ\add*.“ \x ◘ \xo 24:‏5 \xt أَعَوذ. 20‏:‏7\x*   
\m
\v 6 ”وَارْ إِعدّڒْ أَذْ ثكْسِيذْ إِژْرَا ن ثْسِيرْثْ س ثْنَاينْ ذ أَضْمَانْ، نِيغْ \add أَژْرُو\add* نِّي \add زَّايْسنْ\add* إِتّنْهزَّانْ \add وَاهَا\add*، مِينْزِي أَقَا \add خنِّي\add* أَذْ يِيڒِي ڒعْمَارْ ذ أَضْمَانْ.“   
\m
\v 7 ”مَاڒَا إِتّْوَافْ إِجّْ ن ورْيَازْ يُوشَارْ شَا ن يِيجّْ زڭْ وَاوْمَاثنْ نّسْ، زڭْ أَيْثْ ن إِسْرَائِيل، ؤُشَا نتَّا يَارَّا إِ-ث ذ إِسْمغْ ؤُشَا إِزّنْزْ إِ-ث، \add خنِّي\add* أَذْ إِمّثْ ؤُشفَّارْ \add نِّي\add*. إِتّْخصَّا أَذْ ثكّْسذْ ڒْغَارْ زِي ڒْوسْطْ نّشْ.“ \x ◘ \xo 24:‏7 \xt ؤُف. 21‏:‏16\x*   
\m
\v 8 ”خْمِي \add ذِينْ ثدْجَا\add* جّْرِيحشْثْ ن ڒْبَارْصْ، حْضَا أَذْ ثحْضِيذْ ؤُ أَذْ ثڭّذْ نِيشَانْ عْلَاحْسَابْ مَارَّا مِينْ ذ أَشْ غَا سّْڒمْذنْ إِكهَّاننْ إِلَاوِييّنْ. أَذْ ثحْضَامْ مَاحنْذْ أَذْ ثڭّمْ مَارَّا أَمْ مَامّشْ ثنْ ؤُمُورغْ. \x ◘ \xo 24:‏8 \xt لَاوِي 13‏:‏2\x*  
\v 9 إِذَارْ مِينْ إِڭَّا سِيذِي، أَربِّي نّشْ، أَكْ-ذ مَارْيَامْ ذڭْ وبْرِيذْ ؤُمِي د-ثفّْغمْ زِي مِيصْرَا.“\x ◘ \xo 24:‏9 \xt ڒخْڒ. 12‏:‏10\x*   
\m
\v 10 ”مَاڒَا ثَارْضْڒذْ شَا إِ جَّارْ نّشْ، \add خنِّي\add* وَارْ تِّيذفْ غَارْ ثَادَّارْثْ نّسْ حِيمَا أَذْ زَّايسْ ثكْسِيذْ شَا ذ أَضْمَانْ \add إِ يِيخفْ نّشْ\add*.  
\v 11 أَذْ ثقِّيمذْ بَارَّا ؤُشَا أَرْيَازْ إِ ؤُمِي ثَارْضْڒذْ أَذْ أَشْ د-يَاوِي دِّييّثْ غَارْ بَارَّا.  
\v 12 مَاڒَا ثُوغَا ذ أَرْيَازْ ذ أَمزْڒُوضْ، \add خنِّي\add* وَارْ تّتّْنُوسِي ذڭْ ورْهَانْ نّسْ \add أَمشْنَاوْ إِ يدْجَا ذ ثَاسُّوثْ نّسْ\add*.  
\v 13 أَذْ أَسْ د-ثَارّذْ دِّييّثْ نِّي نِيشَانْ غَارْ ؤُغدْجِي ن ثْفُوشْثْ، حِيمَا أَذْ إِطّصْ ذِي ثَاسُّوثْ نّسْ ؤُشَا أَذْ أَشْ إِبَاركْ. مَانْ أَيَا أَذْ أَشْ ثِيڒِي ذ ثَاسڭْذَا زَّاثْ إِ وُوذمْ ن سِيذِي، أَربِّي نّشْ.“\x ◘ \xo 24:‏13 \xt ؤُف. 22‏:‏26\x*   
\m
\v 14 ”وَارْ سْحِيسّْفمْ أَشوَّاڒْ أَمحْذَاجْ أَمزْڒُوضْ زڭْ أَيْثْمَاشْ نِيغْ زڭْ إِبَارَّانِييّنْ إِ إِزدّْغنْ ذِي ثمُّورْثْ نّشْ ؤُ ذَاخڒْ إِ ثوُّورَا نّشْ. \x ◘ \xo 24:‏14 \xt لَاوِي 19‏:‏13؛ يَاع. 5‏:‏4\x*  
\v 15 أَذْ أَسْ ثوْشذْ ڒْمُونثْ نّسْ كُوڒْ أَسّْ. وَارْ خَاسْ ثْغدْجِي ثْفُوشْثْ خْ مَانْ أَيَا، مِينْزِي نتَّا ذ أَمزْڒُوضْ ؤُشَا إِمّژْرِي ذَايسْ، حِيمَا نتَّا وَارْ إِتّْڒِيغِي إِ سِيذِي ذِي سِّيبّثْ نّشْ ؤُشَا أَذْ ذَايكْ يِيڒِي دّنْبْ.“   
\m
\v 16 ”إِبَابَاثنْ وَارْ تّْوَانقّنْ ذِي سِّيبّثْ ن إِحنْجِيرنْ نْسنْ ؤُ إِحنْجِيرنْ وَارْ تّْوَانقّنْ ذِي سِّيبّثْ ن إِبَابَاثنْ نْسنْ. كُوڒْ إِجّْ أَذْ إِتّْوَانغْ ذِي سِّيبّثْ ن دّنْبْ نّسْ.“\x ◘ \xo 24:‏16 \xt 2 إِج. 14‏:‏6؛ 2 إِم. 25‏:‏4؛ إِرْم. 31‏:‏30؛ حِز. 18‏:‏20\x*   
\m
\v 17 ”وَارْ سْفَارَّاغْ ڒحْكَامْ ن ؤُبَارَّانِي ذ ؤُيُوجِيڒْ نِيغْ أَذْ ثكْسِيذْ أَرُّوضْ ن ثَاجَّاتْشْ ذ أَضْمَانْ.\x ◘ \xo 24:‏17 \xt ؤُف. 22‏:‏21، 22؛ أَوڒن. 22‏:‏22؛ إِشا. 1‏:‏23؛ إِرْم. 5‏:‏28؛ 22‏:‏3؛ حِز. 22‏:‏29؛ زَاك. 7‏:‏10\x*  
\v 18 أَذْ ثْعقْڒذْ بلِّي ثُوغَا شكْ ذ إِسْمغْ ذِي مِيصْرَا ؤُشَا أَقَا سِيذِي، أَربِّي نّشْ، إِفْذِي شكْ سّنِّي. خْ ؤُيَا نشّْ تُّومُورغْ شكْ أَذْ ثڭّذْ مَانْ أَيَا. \f ◼ \fr 24:‏18 \ft \+bd ’إِفْذِي‘\+bd* - خْزَارْ إِزهد. 78:35.\f*  
\v 19 خْمِي ثْمجَّارذْ صَّابثْ نّشْ ذڭْ إِيَّارْ نّشْ ؤُشَا ثتُّوذْ شَا ن ثْقبِّيضْثْ ذڭْ إِيَّارْ، \add خنِّي\add* وَارْ د-ثذِّيكّْوِيڒذْ مَاحنْذْ أَذْ ت ثكْسِيذْ. أَذْ ثِيڒِي \add ذ ثَاسْغَارْثْ\add* إِ ؤُبَارَّانِي، إِ ؤُيُوجِيڒْ ؤُ إِ ثَاجَّاتْشْ، حِيمَا أَذْ شكْ إِبَاركْ سِيذِي، أَربِّي نّشْ، ذِي مَارَّا ڒْخذْمثْ ن إِفَاسّنْ نّشْ.\x ◘ \xo 24:‏19 \xt لَاوِي 19‏:‏9؛ 23‏:‏22\x*  
\v 20 خْمِي غَا ثْژوْضذْ ثَاشجَّارْثْ نّشْ ن زِّيثُونْ، وَارْ تِّيشْ ثَايْنِيثْ \add عَاذْ\add* إِ مِينْ إِقِّيمنْ أَوَارْنِي أَشْ. ذ مَانْ أَيَا إِ غَا يِيڒِينْ إِ ؤُبَارَّانِي، إِ ؤُيُوجِيڒْ ؤُ إِ ثَاجَّاتْشْ.  
\v 21 أَوَارْنِي ڒَامِي ثْڒقْضذْ أَضِيڒْ ن ؤُمَارْجعْ نّشْ ن ؤُضِيڒْ، وَارْ أَرزُّو أَذْ ثْڒقْضذْ مِينْ إِقِّيمنْ أَوَارْنِي أَشْ عَاوذْ. أَقَا مَانْ أَيَا أَذْ يِيڒِي إِ ؤُبَارَّانِي، إِ ؤُيُوجِيڒْ ؤُ إِ ثَاجَّاتْشْ.  
\v 22 أَذْ ثْعقْڒذْ بلِّي ثُوغَا شكْ ذ إِسْمغْ ذِي ثمُّورْثْ ن مِيصْرَا. خْ ؤُيَا نشّْ تُّومُورغْ شكْ أَذْ ثڭّذْ مَانْ أَيَا.“   
\b  
\b  
\m  
\c 25
\s1 ثِيوصَّا نّغْنِي  
\m
\v 1 ”مَاڒَا \add ذِينْ\add* إِجّْ ن ؤُمْشُوبّشْ جَارْ إِرْيَازنْ ؤُشَا إِتّْخصَّا أَسنْ أَذْ ؤُيُورنْ غَارْ ڒْمحْكَامَا، أَذْ \add خَاسنْ\add* حكْمنْ، \add خنِّي\add* أَذْ بَارّْحنْ خْ ونِّي غَارْ إِدْجَا ڒْحقّْ ؤُشَا أَذْ حكْمنْ خْ ؤُمذْنُوبْ. \f ◼ \fr 25:‏1 \ft \+bd ’ونِّي غَارْ إِدْجْ ڒْحقّْ‘\+bd* - س ثْعِيبْرَانِيثْ ’أَمْسڭّذْ‘.\f*  
\v 2 مَاڒَا أَمذْنُوبْ إِسّْذَاهدْجْ ثِييِّيثَا، \add خنِّي\add* ڒْقَاضِي أَذْ يجّْ أَذْ ثغضْڒنْ غَارْ ثمُّورْثْ ؤُشَا أَذْ \add ث\add* فَارْشنْ زَّاثْ إِ وُوذمْ نّسْ أَنشْثْ إِتُّورْسْ \add ذِي ڒحْسَابْ\add* ن ڒْغشّْ نّسْ.  
\v 3 إِعدّڒْ أَذْ أَسْ إِوْشْ أَربْعِينْ ن ثيِّيثَا، وَارْ غَارْسنْثْ يَارنِّي شَا، مِينْزِي مَاڒَا أَذْ ث إِفَارْشْ عَاذْ كْثَارْ سنّجْ إِ ثِييِّيثَا-يَا، أَقَا ؤُمَاشْ أَذْ أَشْ د-إِبَانْ ذ أَمحْڭُورْ جَارْ ثِيطَّاوِينْ نّشْ.“\x ◘ \xo 25:‏3 \xt 2 كُور. 11‏:‏24\x*   
\m
\v 4 ”وَارْ تّڭّْ ثَاشْمَانْثْ إِ ؤُفُونَاسْ خْمِي إِسَّارْوَاثْ.“ \x ◘ \xo 25:‏4 \xt 1 كُور. 9‏:‏9؛ 1 تِيم. 5‏:‏18\x*   
\b  
\m
\v 5 ”خْمِي زدّْغنْ وَاوْمَاثنْ أَكْ-ذ وَايَاوْيَا ؤُشَا إِمُّوثْ إِجّْ زَّايْسنْ، ؤُشَا وَارْ د-يجِّي شَا مِّيسْ، \add خنِّي\add* ثَامْغَارْثْ ن ؤُمتِّينْ وَارْ ثْمدْجشْ شَا أَكْ-ذ شَا ن ورْيَازْ بَارَّا فَامِيلِييَا نّسْ. أَذْ خَاسْ يَاذفْ وَاڒوْسْ ؤُشَا أَذْ ت إِڭّْ ذ ثَامْغَارْثْ نّسْ ؤُشَا أَذْ أَسْ يڭّْ خنِّي \bd لْوَاجِيبْ ن وَاڒوْسْ\bd*. \f ◼ \fr 25:‏5 \ft \+bd ’أَڒْوسْ‘\+bd* - نِيغْ ’ؤُمَاسْ ن ورْيَازْ نّسْ‘.\f*  \x ◘ \xo 25:‏5 \xt مت. 22‏:‏24؛ مك. 12‏:‏19؛ لك. 20‏:‏28\x*  
\v 6 ؤُشَا أَمنْزُو نِّي إِ د غَا ثَارُووْ، أَذْ إِخْڒفْ إِسمْ ن ؤُمَاسْ إِمُّوثنْ، \add حِيمَا\add* إِسمْ ن وَا وَارْ إِمحِّي شَا زِي إِسْرَائِيل.  
\v 7 \add مَاشَا\add* مَاڒَا أَرْيَازْ وَارْ إِخْسْ أَذْ إِكْسِي ثَامْغَارْثْ ن ؤُمَاسْ، أَذْ ثْڒَاهْ \add خنِّي\add* ثمْغَارْثْ ن ؤُمَاسْ غَارْ ثوَّارْثْ، غَارْ إِمْغَارنْ، أَذْ ثِينِي: ’أَڒوْسْ إِنُو يُوڭِي أَذْ إِخْڒفْ إِسمْ ن ؤُمَاسْ ذِي إِسْرَائِيل، وَارْ إِخْسْ أَذْ إِڭّْ لْوَاجِيبْ ن وَاڒوْسْ.‘ \x ◘ \xo 25:‏7 \xt رَاع. 4‏:‏7\x*  
\v 8 \add خنِّي\add* إِمْغَارنْ ن ثنْذِينْثْ نِّي أَذْ أَسْ د-ڒَْاغَانْ ؤُشَا أَذْ أَكِيذسْ سِّيوْڒنْ. مَاڒَا نتَّا إِمْنعْ ذڭْ وَاوَاڒْ نّسْ ؤُشَا إِنَّا: ’وَارْ خْسغْ شَا أَذْ ت أَوْيغْ!‘،  
\v 9 أَذْ غَارسْ د-ثْقَارّبْ \add خنِّي\add* ثَاڒوْسْثْ زَّاثْ إِ ثِيطَّاوِينْ ن إِمْغَارنْ، أَذْ أَسْ ثكّسْ سَانْذَالَا نّسْ زڭْ ؤُضَارْ ؤُشَا أَذْ خَاسْ ثسُّوسفْ خْ ؤُغمْبُوبْ، أَذْ ثْبَارّحْ، أَذْ ثِينِي: ’أَمُّو إِ إِتّْوَاڭّْ ذڭْ ورْيَازْ نِّي وَارْ إِخْسنْ أَذْ إِبْنَا ثَادَّارْثْ ن ؤُمَاسْ!‘ \x ◘ \xo 25:‏9 \xt رَاع. 4‏:‏5\x*  
\v 10 ؤُشَا أَذْ أَسْ ڒَاغَانْ ذِي إِسْرَائِيل س يِيسمْ وَانِيثَا: ’ثَادَّارْثْ ن ونِّي ؤُمِي إِتّْوَاكّسْ سَانْذَالَا نّسْ!‘ “   
\b  
\m
\v 11 ”مَاڒَا \add ذِينْ\add* إِرْيَازنْ مْشُوبُّوشنْ ؤُشَا ثْرحّڭْ-د ثمْغَارْثْ ن شَا ن إِجّْ حِيمَا أَذْ ثْفكّْ أَرْيَازْ نّسْ زڭْ ؤُفُوسْ ن وِي ث إِشَّاثنْ ؤُشَا نتَّاثْ ثسّْوِيژّضْ أَفُوسْ نّسْ ؤُشَا ثطّفْ إِ-ث زِي ثْفُولِينْ ن ؤُسضْحِي نّسْ،  
\v 12 أَذْ أَسْ ثْقسّذْ \add خنِّي\add* أَفُوسْ نّسْ، وَارْ ذ أَمْ تّزِّيدْجِيزْ.“   
\m
\v 13 ”وَارْ غَاركْ إِتِّيڒِي ذِي ثْخَانْشثْ نّشْ إِجّْ ن وژْرُو \add ن ڒوْزنْ\add* ذ إِجّْ ن وژْرُو \add نّغْنِي\add*، إِجّْ ن وژْرُو ذ أَمقّْرَانْ ؤُڒَا ذ إِجّْ ن وژْرُو ذ أَمژْيَانْ.  
\v 14 وَارْ غَاركْ إِتِّيڒِي ذِي ثَادَّارْثْ نّشْ، \add ڒْْمُوذْ\add* ن إِجّْ ن إِفَا ؤُڒَا ذ إِجّْ ن إِفَا \add نّغْنِي\add*، إِجّْ ن إِفَا ذ أَمقّْرَانْ ؤُڒَا ذ إِجّْ ن إِفَا ذ أَمژْيَانْ.  
\v 15 \bd إِجّْ ن وژْرُو \+bdit ن ڒوْزنْ\+bdit* إِوَاطَا، إِسڭّمْ\bd* أَذْ غَاركْ يِيڒِي ؤُڒَا ذ \bd \+bdit إِجْ ن ڒْمُوذْ ن\+bdit* يِيجّْ ن إِفَا نِيشَانْ، إِوَاطَا\bd*، حِيمَا ؤُسَّانْ نّشْ أَذْ زُّوڭَّارْثنْ خْ وُوذمْ \add ن ثمُّورْثْ\add* نِّي إِ ذ أَشْ غَا إِوْشْ، سِيذِي، أَربِّي نّشْ.  
\v 16 مِينْزِي مَارَّا وِي غَا إِڭِّينْ مَانْ أَيَا، مَارَّا وِي غَا إِڭِّينْ ڒْغشّْ، أَقَا نتَّا ذ نّْعِي غَارْ سِيذِي، أَربِّي نّشْ.“ \x ◘ \xo 25:‏16 \xt أَوڒن. 11‏:‏1\x*   
\b  
\m  
\s1 أَثحِّي ن عَامَالِيقْ  
\m
\v 17 ”إِذَارْ مِينْ زَّايكْ إِڭَّا \bd عَامَالِيقْ\bd* ذڭْ وبْرِيذْ، ؤُمِي د-ثفّْغذْ زِي مِيصْرَا، \x ◘ \xo 25:‏17 \xt ؤُف. 17‏:‏8\x*  
\v 18 مَامّشْ د-إِفّغْ غَارْ ؤُمْسَاڭَارْ أَكِيذكْ ذڭْ وبْرِيذْ ؤُشَا إِهْجمْ خَاكْ زِي ضفَّارْ \add مَانِي دْجَانْ\add* مَارَّا إِنِّي إِضعْفنْ، ؤُمِي شكْ ثُوغَا ثُوحْڒذْ، ثفْنِيذْ. نتَّا وَارْ إِڭّْوِيذْ شَا أَربِّي.  
\v 19 أَذْ إِمْسَارْ، خْمِي سِيذِي، أَربِّي نّشْ، أَذْ شكْ إِسَّاريّحْ زِي مَارَّا ڒْعذْيَانْ إِ ذ أَشْ-د إِنّْضنْ ذِي ثمُّورْثْ إِ ذ أَشْ غَا إِوْشْ سِيذِي، أَربِّي نّشْ، ذ ڒْوَارْثْ، حِيمَا أَذْ ت ثكْسِيذْ، أَقَا أَذْ ثمْحِيذْ ڒِيذَارثْ ن عَامَالِيقْ زِي سَاذُو ؤُجنَّا. وَارْ ث تّتُّو!“   
\b  
\b  
\m  
\c 26
\s1 ثَاوْهِيبْثْ ن إِمزْوُورَا  
\m
\v 1 ”خْمِي غَا ثَاذْفذْ غَارْ ثمُّورْثْ نِّي ذ أَشْ غَا إِوْشْ سِيذِي، أَربِّي نّشْ، ذ ڒْوَارْثْ، ؤُشَا أَذْ ت ثطّْفذْ ؤُشَا أَذْ ذَايسْ ثْزذْغذْ،  
\v 2 \add خنِّي\add* أَذْ ثكْسِيذْ زِي ثْمزْوَارُوثْ ن كُوڒْ ڒْغِيدْجثْ إِ غَا ثسّْمُونذْ زِي ثمُّورْثْ نِّي ذ أَشْ غَا إِوْشْ سِيذِي، أَربِّي نّشْ، أَذْ ث ثڭّذْ ذِي ثْسُودْجثْ ؤُشَا أَذْ ثْرَاحذْ غَارْ ومْشَانْ إِ غَا يِيخْضَارْ سِيذِي مَاحنْذْ أَذْ ذِينْ إِسّزْذغْ إِسمْ نّسْ. \x ◘ \xo 26:‏2 \xt ؤُف. 23‏:‏19؛ 34‏:‏26؛ لَاوِي 2‏:‏14؛ 23‏:‏10؛ ڒخْڒ. 15‏:‏17\x*  
\v 3 ؤُشَا أَذْ د-ثَاسذْ غَارْ ؤُكهَّانْ، ونِّي \add ذِينْ\add* غَا يِيڒِينْ ذڭْ وُوسَّانْ نِّي، أَذْ أَسْ ثِينِيذْ: ’أَقَا أَسّْ-أَ أَذْ بَارّْحغْ إِ سِيذِي، أَربِّي نّشْ، بلِّي أَقَا ؤُذْفغْ غَارْ ثمُّورْثْ نِّي خْ إِجُّودْجْ سِيذِي إِ ڒجْذُوذْ نّغْ حِيمَا أَذْ أَنغْ ت إِوْشْ.‘  
\v 4 ؤُشَا أَذْ إِكْسِي ؤُكهَّانْ ثَاسُودْجثْ زڭْ ؤُفُوسْ نّشْ، أَذْ ت إِسَّارْسْ زَّاثْ إِ ؤُعَالْطَارْ ن سِيذِي، أَربِّي نّشْ.  
\v 5 أَذْ ثْبَارّْحذْ زَّاثْ إِ وُوذمْ ن سِيذِي، أَربِّي نّشْ، أَذْ ثِينِيذْ: ’أَرَامِييُو نِّي ثُوغَا إِدْجَانْ عْڒَاحَاڒْ أَذْ إِفْنَا أَقَا ثُوغَا-ث ذ بَابَا. نتَّا إِهْوَا غَارْ مِيصْرَا ؤُشَا إِزْذغْ ذِينْ أَمْ ؤُبَارَّانِي أَكْ-ذ إِجّْ ن وُورُو ن يرْيَازنْ \add وَاهَا\add* ؤُشَا إِيْمَا، إِذْوڒْ ذ إِجّْ ن ڒْڭنْسْ إِمْغَارْ، إِجْهذْ ؤُ ذڭْ وَاطَّاسْ. \x ◘ \xo 26:‏5 \xt أَمز. 46‏:‏1\x*  
\v 6 إِمِيصْرِييّنْ ضڒْمنْ ؤُ حْصَارنْ أَنغْ ؤُ ڭِّينْ خَانغْ ثَاسْمُوغِي ثقْسحْ.  
\v 7 ؤُشَا نسْغُويْ غَارْ سِيذِي، أَربِّي ن ڒجْذُوذْ نّغْ، ؤُشَا إِسْڒَا سِيذِي إِ ثْمِيجَّا نّغْ ؤُ إِژْرَا أَرْژِييّثْ نّغْ ذ ڒغْبنْ نّغْ ذ ڒْمحْنثْ نّغْ.  
\v 8 إِسُّوفّغْ أَنغْ-د سِيذِي زِي مِيصْرَا س ؤُفُوسْ إِجهْذنْ، س ؤُغِيڒْ إِسّْوِيژّْضنْ، س ثِيمڭَّا إِمْغَارنْ إِسِّيڭّْوِيذنْ، س ڒعْڒَامَاثْ ؤُ س لْمُوعْجِيزَاثْ،  
\v 9 ؤُشَا إِسِّيذفْ أَنغْ غَارْ ومْشَانْ-أَ ؤُشَا إِوْشَا أَنغْ ثَامُّورْثْ-أَ، ثَامُّورْثْ إِفيّْضنْ س ؤُغِي ذ ثَامّنْثْ.  
\v 10 ؤُشَا ڒخُّو، خْزَارْ، إِوْيغْ-د ثَامزْوَارُوثْ ن ڒْغِيدْجثْ ن ثمُّورْثْ نِّي ذ أَيِي ثوْشِيذْ، \add أَ\add* سِيذِي!‘ \add خنِّي\add* أَذْ ث ثڭّذْ زَّاثْ إِ وُوذمْ ن سِيذِي، أَربِّي نّشْ، أَذْ ثْبنْذْقذْ زَّاثْ إِ وُوذمْ ن سِيذِي، أَربِّي نّشْ.  
\v 11 أَذْ ثْفَارّْحذْ زِي مَارَّا ڒْخَاڒْ إِ غَا إِوْشْ سِيذِي، أَربِّي نّشْ، إِ شكْ ؤُ إِ \add أَيْثْبَابْ ن\add* ثَادَّارْثْ نّشْ: شكْ ذ ؤُلَاوِي ذ ؤُبَارَّانِي إِ إِدْجَانْ ذِي ڒْوسْطْ نّشْ.“   
\b  
\m  
\s1 ڒعْشُورْ  
\m
\v 12 ”خْمِي غَا ثْكمّْڒذْ زڭْ ؤُعشَّارْ ن مَارَّا ڒعْشُورْ ن ڒْغِيدْجثْ نّشْ ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْڒَاثَا، ونِّي ذ أَسڭّْوَاسْ ن ڒعْشُورْ، خنِّي أَذْ ثنْ ثوْشذْ إِ ؤُلَاوِي، إِ ؤُبَارَّانِي، إِ ؤُيُوجِيڒْ، إِ ثَاجَّاتْشْ، \add حِيمَا\add* أَذْ شّنْ ذَاخڒْ إِ ثوُّورَا نّشْ ؤُ أَذْ جِّيوْننْ. \x ◘ \xo 26:‏12 \xt لَاوِي 27‏:‏30؛ ڒخْڒ. 18‏:‏24، أَعَوذ. 14‏:‏28، 29\x*  
\v 13 ؤُشَا أَذْ ثِينِيذْ زَّاثْ إِ وُوذمْ ن سِيذِي، أَربِّي نّشْ: ’أَقَا كْسِيغْ مِينْ إِدْجَانْ إِقدّْسنْ زِي ثَادَّارْثْ إِنُو ؤُشَا عَاوذْ وْشِيغْ ث إِ ؤُلَاوِي، إِ ؤُبَارَّانِي، إِ ؤُيُوجِيڒْ، إِ ثَاجَّاتْشْ، أَمْ مَامّشْ مَارَّا ثِيوصَّا إِ ذ أَيِي ثْوصِّيذْ. نشّْ وَارْعذِّيغْ ؤُڒَا خْ إِشْثنْ زِي ثْوصَّا نّشْ ؤُ وَارْ تُّوغْ وَالُو. \x ◘ \xo 26:‏13 \xt أَعَوذ. 14‏:‏27\x*  
\v 14 وَارْ زَّايسْ شِّيغْ ذڭْ وشْضَانْ إِنُو ؤُ وَارْ زَّايسْ كْسِيغْ ؤُمِي خمْجغْ ؤُڒَا وَارْ زَّايسْ وْشِيغْ إِ يِيجّْ ن ؤُمتِّينْ. أَقَا سْڒِيغْ إِ ثْمِيجَّا ن سِيذِي، أَربِّي إِنُو، ؤُ ڭِّيغْ مَارَّا مِينْ ذ أَيِي ثُومُورذْ.  
\v 15 خْزَارْ زِي ثْزذِّيغْثْ نّشْ إِقدّْسنْ، زڭْ ؤُجنَّا، غَارْ سْوَادَّايْ ؤُشَا بَاركْ ڒْڭنْسْ نّشْ إِسْرَائِيل ذ ثمُّورْثْ نِّي ذ أَنغْ ثوْشِيذْ، أَمْ مَامّشْ ثجُّودْجذْ إِ ڒجْذُوذْ نّغْ، ثَامُّورْثْ نِّي إِتّْفيّْضنْ س ؤُغِي ذ ثَامّنْثْ.‘ “ \x ◘ \xo 26:‏15 \xt إِشا. 63‏:‏15\x*   
\b  
\m  
\s1 أَوَاڒْ أَنڭَّارُو  
\m
\v 16 ”سِيذِي، أَربِّي نّشْ، أَقَا يُومُورْ إِ شكْ أَسّْ-أَ، أَذْ ثڭّذْ ثِيوصَّا-يَا ذ لْفَارَايِيضْ-أَ. حْضَا ثنْثْ ؤُشَا أڭّْ زَّايْسنْ س مَارَّا ؤُڒْ نّشْ ذ مَارَّا ڒعْمَارْ نّشْ.  
\v 17 أَسّْ-أَ ثنِّيذْ أَقَا سِيذِي أَذْ يِيڒِي ذ أَربِّي نّشْ، أَذْ ثُويُورذْ ذڭْ إِبْرِيذنْ نّسْ، أَذْ ثحْضِيذْ ثِيوصَّا ذ ڒُومُورَاثْ نّسْ ذ لْفَارَايِيضْ نّسْ ؤُشَا أَذْ ثسْڒذْ إِ ثْمِيجَّا نّسْ. \x ◘ \xo 26:‏17 \xt أَمز. 17‏:‏7\x*  
\v 18 ؤُشَا سِيذِي إِنَّا أَشْ أَسّْ-أَ إِ شكْ، أَقَا شكْ أَذْ غَارسْ ثِيڒِيذْ ذ إِجّْ ن ڒْڭنْسْ إِغْڒَا أَطَّاسْ، أَمْ مَامّشْ ذ أَومْ إِنَّا، ؤُ إِتّْخصَّا أَشْ أَذْ ثحْضِيذْ مَارَّا ثِيوصَّا نّسْ، \x ◘ \xo 26:‏18 \xt ؤُف. 19‏:‏5؛ أَعَوذ. 7‏:‏6؛ 14‏:‏2\x*  
\v 19 حِيمَا نتَّا أَذْ شكْ إِسُّوعْڒَا خْ مَارَّا ڒڭْنُوسْ إِ ؤُسمْغَارْ ذ يِيسمْ ذ ڒْعزّْ، حِيمَا أَذْ ثِيڒِيذْ ذ إِجّْ ن ڒْڭنْسْ إِقدّْسنْ إِ سِيذِي، أَربِّي نّشْ، أَمْ مَامّشْ ثُوغَا إِنَّا.“ \x ◘ \xo 26:‏19 \xt أَعَوذ. 4‏:‏7\x*   
\b  
\b  
\m  
\c 27
\s1 أَذْرَارْ ن عِيبَالْ ذ وذْرَارْ ن جِيرِيزِيمْ  
\m
\v 1 مُوسَا، أَكْ-ذ إِمْغَارنْ ن إِسْرَائِيل، يُومُورْ ڒْڭنْسْ، إِنَّا:  
\m ”حْضَامْ مَارَّا ثِيوصَّا-يَا، ثِينِّي ذ أَومْ ؤُمُورغْ نشّْ أَسّْ-أَ.  
\v 2 أَذْ إِمْسَارْ ذڭْ وَاسّْ ؤُمِي غَا ثژْوَامْ إِغْزَارْ ن لْ-ؤُرْذُونْ غَارْ ثمُّورْثْ نِّي ذ أَشْ غَا إِوْشْ سِيذِي، أَربِّي نّشْ، أَقَا أَذْ ثسّْبدّذْ إِژْرَا إِمقّْرَاننْ ؤُشَا أَذْ ثنْ ثْحنّْشذْ س جَّارْ. \x ◘ \xo 27:‏2 \xt ياش. 4‏:‏1\x*  
\v 3 أَذْ ذَايسْ ثَارِيذْ مَارَّا أَوَاڒنْ ن شَّارِيعَا-يَا، خْمِي غَا ثژْوِيذْ حِيمَا أَذْ ثَاذْفذْ غَارْ ثمُّورْثْ نِّي ذ أَشْ غَا إِوْشْ سِيذِي، أَربِّي نّشْ، إِشْثْ ن ثمُّورْثْ إِفيّْضنْ س ؤُغِي ذ ثَامّنْثْ، أَمْ مَامّشْ إِ ذ أَشْ إِنَّا سِيذِي، أَربِّي ن ڒجْذُوذْ نّشْ.  
\v 4 خْمِي غَا ثژْوَامْ إِغْزَارْ ن لْ-ؤُرْذُونْ، أَذْ ثسّْبدّمْ إِژْرَا، إِنِّي خْ ذ أَومْ ؤُمُورغْ أَسّْ-أَ خْ وذْرَارْ ن عِيبَالْ ؤُشَا أَذْ ثنْ ثْحنّْشذْ س جَّارْ.  
\v 5 أَذْ ذِينْ ثبْنِيذْ إِجّْ ن ؤُعَالْطَارْ إِ سِيذِي، أَربِّي نّشْ، إِجّْ ن ؤُعَالْطَارْ ن يژْرَا. وَارْ خَاسْ ثسِّيڒِييذْ \add دُّوزَانْ ن\add* وُوزَّاڒْ زِي سَّا غَارْ ذَا. \x ◘ \xo 27:‏5 \xt ؤُف. 20‏:‏25؛ ياش. 8‏:‏31\x*  
\v 6 إِتّْخصَّا أَذْ ثبْنِيذْ أَعَالْطَارْ ن سِيذِي، أَربِّي نّشْ، س يژْرَا كمْڒنْ \add وَاهَا\add* ؤُشَا أَذْ خَاسْ ثسّْبخَّارذْ ثِيغَارْصَا ن وشْمَاضْ إِ سِيذِي، أَربِّي نّشْ.  
\v 7 \add عَاوذْ\add* أَذْ أَسْ ثْقدّْمذْ ثِيغَارْصِي نّشْ ن ڒهْنَا. أَذْ ذِينْ ثشّذْ ؤُشَا أَذْ ثْفَارْحذْ زَّاثْ إِ وُوذمْ ن سِيذِي، أَربِّي نّشْ.  
\v 8 أَذْ ثَارِيذْ مَارَّا أَوَاڒنْ ن شَّارِيعَا-يَا ذڭْ يژْرَا س إِجّْ ن ونْقَاشْ إِشوَّارنْ إِشْنَانْ.“   
\b  
\m
\v 9 ثُوغَا مُوسَا إِسَّاوَاڒْ أَكْ-ذ إِكهَّاننْ، إِلَاوِييّنْ، غَارْ مَارَّا إِسْرَائِيل، إِنَّا: ”سْقَارْ، سْحسّْ، \add أَ\add* إِسْرَائِيل! أَسّْ-أَ ثِيوْضذْ أَذْ ثِيڒِيذْ ذ إِجّْ ن ڒْڭنْسْ إِ سِيذِي، أَربِّي نّشْ.  
\v 10 أَذْ ثسْڒذْ إِ ثْمِيجَّا ن سِيذِي، أَربِّي نّشْ، ؤُشَا أَذْ ثڭّذْ زِي ڒُومُورَاثْ نّسْ ذ ثْوصَّا نّسْ، ثِينِّي خْ شكْ ؤُمُورغْ أَسّْ-أَ.“   
\b  
\m
\v 11 إِوصَّا مُوسَا ڒْڭنْسْ ذڭْ وَاسّْ نِّي، إِنَّا:   
\b  
\m
\v 12 ”خْمِي غَا ثژْوَامْ لْ-ؤُرْذُونْ أَذْ بدّنْ ثْقبَّاڒْ أَيَا \bd خْ وذْرَارْ ن جِيرِيزِيمْ حِيمَا أَذْ بَارْكنْ ڒْڭنْسْ\bd*: شِيمْعُونْ ذ لَاوِي ذ يَاهُوذَا ذ إِسَّاكَارْ ذ يُوسُوفْ ذ بِينْيَامِينْ.“\x ◘ \xo 27:‏12 \xt أَعَوذ. 11‏:‏29\x*   
\m
\v 13 ”ؤُشَا \add ثِيقبَّاڒْ-أَ\add* أَذْ بدّنْ \bd خْ وذْرَارْ ن عِيبَالْ حِيمَا أَذْ نعْڒنْ\bd*: رُوبِينْ، جَاذْ ذ عَاشِيرْ ذ زابُولُونْ، ذَانْ ذ نَافْثَالِي.“   
\m
\v 14 ”أَذْ بَارّْحنْ إِلَاوِييّنْ ؤُشَا أَذْ إِنِينْ س ثْمِيجَّا إِجهْذنْ إِ مَارَّا أَرَّاوْ ن إِسْرَائِيل:   
\b  
\m
\v 15 ’ذ أَمنْعُوڒْ أَرْيَازْ نِّي إِڭِّنْ إِجّْ ن ڒخْيَاڒْ إِنقْشنْ نِيغْ إِفسْينْ، أَقَا-ث ذ جّْعِيفشْثْ إِ سِيذِي، إِشْثْ نْ ڒْخذْمثْ ن إِفَاسّنْ ن ؤُحْرَايْفِي، ؤُشَا أَذْ ت إِڭّْ ذڭْ ومْشَانْ نّسْ س ثْنُوفّْرَا.‘ ؤُشَا مَارَّا ڒْڭنْسْ أَذْ د-يَارّْ أَذْ يِينِي: ’أَمِينْ!‘   
\m
\v 16 ’ذ أَمنْعُوڒْ وِي غَا إِسّحْقَارنْ بَابَاسْ نِيغْ يمَّاسْ!‘ ؤُشَا مَارَّا ڒْڭنْسْ أَذْ يِينِي: ’أَمِينْ!‘   
\m
\v 17 ’ذ أَمنْعُوڒْ وِي غَا إِسّْمُوطّْينْ أَيْمِيرْ ن جَّارْ نّسْ!‘ ؤُشَا مَارَّا ڒْڭنْسْ أَذْ يِينِي: ’أَمِينْ!‘   
\m
\v 18 ’ذ أَمنْعُوڒْ وِي غَا إِسّْودَّارنْ أَذَارْغَاڒْ ذڭْ وبْرِيذْ!“ ؤُشَا مَارَّا ڒْڭنْسْ أَذْ يِينِي: ’أَمِينْ!‘   
\m
\v 19 ’ذ أَمنْعُوڒْ وِي غَا إِسّْفَارّْغنْ ثَاسْغَارْثْ ن ؤُبَارَّانِي، ن ؤُيُوجِيڒْ ؤُ ن ثَاجَّاتْشْ!‘ ؤُشَا مَارَّا ڒْڭنْسْ أَذْ يِينِي: ’أَمِينْ!‘   
\m
\v 20 ’ذ أَمنْعُوڒْ وِي غَا إِطّْصنْ أَكْ-ذ ثمْغَارْثْ ن بَابَاسْ، مِينْزِي إِتّْعَارَّا بَابَاسْ‘ ؤُشَا مَارَّا ڒْڭنْسْ أَذْ يِينِي: ’أَمِينْ!“ \x ◘ \xo 27:‏20 \xt أَعَوذ. 23‏:‏1\x*   
\m
\v 21 ’ذ أَمنْعُوڒْ وِي غَا إِطّْصنْ أَكْ-ذ شَا ن ؤُمُودَّارْ!‘ ؤُشَا مَارَّا ڒْڭنْسْ أَذْ يِينِي: ’أَمِينْ!‘   
\m
\v 22 ’ذ أَمنْعُوڒْ وِي غَا إِطّْصنْ أَكْ-ذ ؤُتْشْمَاسْ، يدْجِيسْ ن بَابَاسْ نِيغْ يدْجِيسْ ن يمَّاسْ!‘ ؤُشَا مَارَّا ڒْڭنْسْ أَذْ يِينِي: ’أَمِينْ!‘   
\m
\v 23 ’ذ أَمنْعُوڒْ وِي غَا إِطّْصنْ أَكْ-ذ ثَاذڭّْوَاتْشْ نّسْ!‘ ؤُشَا مَارَّا ڒْڭنْسْ أَذْ يِينِي: ’أَمِينْ!‘   
\m
\v 24 ’ذ أَمنْعُوڒْ وِي غَا إِنْغنْ جَّارْ نّسْ س ثْنُوفّْرَا!‘ ؤُشَا مَارَّا ڒْڭنْسْ أَذْ يِينِي: ’أَمِينْ!‘   
\m
\v 25 ’ذ أَمنْعُوڒْ وِي غَا إِطّْفنْ أَرّشْوثْ مَاحنْذْ أَذْ إِنْغَا إِجّْ ن بْنَاذمْ، \add مَاهنْذْ أَذْ إِسِّيزّڒْ\add* إِذَامّنْ إِمزْذَاڭنْ!‘ ؤُشَا مَارَّا ڒْڭنْسْ أَذْ يِينِي: ’أَمِينْ!‘   
\m
\v 26 ’ذ أَمنْعُوڒْ وِي وَارْ إِتّْقَارَّانْ أَوَاڒنْ ن شَّارِيعَا-يَا مَاحنْذْ أَذْ ثنْ يڭّْ!‘ ؤُشَا مَارَّا ڒْڭنْسْ أَذْ يِينِي: ’أَمِينْ!‘ “\x ◘ \xo 27:‏26 \xt ڭال. 3‏:‏10\x*   
\b  
\b  
\m  
\c 28
\s1 لْبَارَاكَاثْ ذ نَّاعْڒِي  
\m
\v 1 ”أَذْ إِمْسَارْ، مَاڒَا ثسْڒِيذْ مْلِيحْ إِ ثْمِيجَّا ن سِيذِي، أَربِّي نّشْ، أَذْ ثحْضِيذْ مَارَّا ثِيوصَّا نّسْ، ثِينِّي ذ أَشْ تُّومُورغْ أَسّْ-أَ حِيمَا أَذْ ثنْثْ ثڭّذْ، \add خنِّي\add* أَذْ شكْ إِسُّوعْڒَا سِيذِي، أَربِّي نّشْ، خْ مَارَّا ڒڭْنُوسْ ن ثمُّورْثْ. \x ◘ \xo 28:‏1 \xt لَاوِي 26‏:‏3\x*  
\v 2 مَارَّا \bd لْبَارَاكَاثْ-أَ\bd* أَذْ خَاكْ د-أَسنْثْ، أَذْ أَشْ د-أَوْضنْثْ، مَاڒَا ثسْڒِيذْ إِ ثْمِيجَّا ن سِيذِي، أَربِّي نّشْ.   
\b  
\m
\v 3 أَذْ ثتّْوَابَارْكذْ ذِي ثنْذِينْثْ ؤُ أَذْ ثتّْوَابَارْكذْ ذڭْ إِيَّارْ.  
\v 4 أَذْ ثتّْوَابَاركْ ڒْغِيدْجثْ ن ؤُعذِّيسْ نّشْ ذ ڒْغِيدْجثْ ن ثمُّورْثْ نّشْ ذ ڒْغِيدْجثْ ن ڒبْهَايمْ نّشْ ذ ثْوَارُورَا ن ثْفُونَاسِينْ نّشْ ذ إِمژْيَاننْ إِعِيزّنْ ن وُودْجِي نّشْ.  
\v 5 أَذْ ثتّْوَابَاركْ ثْسُودْجثْ نّشْ ذ ثبْقشْثْ نّشْ.  
\v 6 أَذْ ثتّْوَابَارْكذْ غَارْ وَاذَافْ نّشْ، أَذْ ثتّْوَابَارْكذْ ذڭْ وُوفُّوغْ نّشْ.“   
\b  
\m
\v 7 ”سِيذِي أَذْ إِسلّمْ ڒْعذْيَانْ نّشْ، إِنِّي خَاكْ غَا إِكَّارنْ ذ إِبَارْحَاضْ زَّاثْ إِ وُوذمْ نّشْ. أَذْ خَاكْ د-فّْغنْ ذڭْ وبْرِيذْ ذ إِجّْ ؤُشَا أَذْ أَروْڒنْ زَّاثْ إِ وُوذمْ نّشْ خْ سبْعَا ن إِبْرِيذنْ.  
\v 8 سِيذِي أَذْ أَشْ يُومُورْ س لْبَارَاكَا ذِي ثسْرَافِينْ نّشْ ؤُ خْ مَارَّا مِينْ إِڭَّا ؤُفُوسْ نّشْ. نتَّا أَذْ شكْ إِبَاركْ ذِي ثمُّورْثْ نِّي إِ ذ أَشْ غَا إِوْشْ سِيذِي، أَربِّي نّشْ.  
\v 9 سِيذِي أَذْ شكْ يَارّْ أَذْ ثكَّارذْ أَمْ يِيجّْ ن ڒْڭنْسْ إِقدّْسنْ إِ يِيخفْ نّسْ أَمْ مَامّشْ إِ ذ أَشْ إِجِّيدْجْ، خْمِي غَا ثحْضِيذْ ثِيوصَّا ن سِيذِي، أَربِّي نّشْ، ؤُشَا أَذْ ثُويُورذْ ذڭْ إِبْرِيذنْ نّسْ.  
\v 10 مَارَّا ڒڭْنُوسْ ن ثمُّورْثْ أَذْ ژَترنْ بلِّي إِسمْ ن سِيذِي إِتّْوَاذنَّا خَاكْ ؤُشَا أَذْ زَّايكْ ڭّْوذنْ.  
\v 11 سِيذِي أَذْ أَشْ إِوْشْ ڒْخَارْ س ؤُفيّضْ ذِي ڒْغِيدْجثْ ن ؤُعذِّيسْ نّشْ ؤُ ذِي ڒْغِيدْجثْ ن ڒبْهَايمْ نّشْ ؤُ ذِي ڒْغِيدْجثْ ن ثمُّورْثْ نّشْ، ذِي ثمُّورْثْ نِّي إِجُّودْجْ سِيذِي إِ ڒجْذُوذْ نّشْ أَذْ أَشْ ت-إِ-د-إِوْشْ. \x ◘ \xo 28:‏11 \xt أَعَوذ. 30‏:‏9\x*  
\v 12 سِيذِي أَذْ أَشْ يَارْزمْ \add ثَاوَّارْثْ ن\add* وخَّامْ نّسْ ن ثْخُوبَايْ إِصڒْحنْ، إِجنْوَانْ، حِيمَا أَذْ إِوْشْ أَنْژَارْ إِ ثمُّورْثْ نّشْ ذِي ڒْوقْثْ نّسْ ؤُ حِيمَا أَذْ إِبَاركْ مَارَّا ڒْخذْمثْ ن ؤُفُوسْ نّشْ. أَذْ ثَارْضْڒذْ إِ وَاطَّاسْ ن ڒڭْنُوسْ، مَاشَا شكْ وَارْ \add خَاسنْ\add* ثَارطّْڒذْ.  
\v 13 سِيذِي أَذْ شكْ يَارّْ ذ أَزدْجِيفْ، وَارْ إِدْجِي ذ ؤُنوَّارْ، ؤُشَا شكْ وَاهَا أَذْ ثِيڒِيذْ سنّجْ، وَارْ ثتِّيڒِيذْ سْوَادَّايْ، مَاڒَا ثسْڒِيذْ إِ ثْوصَّا ن سِيذِي، أَربِّي نّشْ، ونِّي إِ ذ أَشْ تُّومُورغْ أَسّْ-أَ حِيمَا أَذْ ثنْثْ ثحْضِيذْ ؤُشَا أَذْ زَّايْسنْثْ ثڭّذْ.  
\v 14 وَارْ تّْحيِّيذْ شَا \add غَارْ\add* يفُوسْ ؤُڒَا \add غَارْ\add* ؤُزڒْمَاضْ خْ مَارَّا أَوَاڒنْ نِّي ذ أَشْ ؤُمُورغْ أَسّْ-أَ أَڒَامِي غَا ثضْفَارذْ إِربِّيثنْ نّغْنِي، أَذْ خَاسنْ ثْسخَّارذْ.  
\v 15 \add مَاشَا\add* أَذْ إِمْسَارْ، مَاڒَا وَارْ ثسْڒِيذْ إِ وَاوَاڒْ ن سِيذِي، أَربِّي نّشْ، حِيمَا أَذْ ثحْضِيذْ مَارَّا ڒُومُورَاثْ ذ ثْوصَّا نّسْ إِ خْ ذ أَشْ تُّومُورغْ أَسّْ-أَ، حِيمَا أَذْ زَّايْسنْثْ ثڭّذْ، \add خنِّي\add* مَارَّا \bd نّْعَاڒِي\bd*-يَا أَذْ خَاكْ د-هْوَانْثْ ؤُ أَذْ شكْ ڒقْفنْثْ:\x ◘ \xo 28:‏15 \xt لَاوِي 26‏:‏14؛ إِڭجذ. 2‏:‏17؛ دَان. 9‏:‏11، 13؛ مـَال. 2‏:‏2 \x*   
\b  
\m
\v 16 \add أَذْ ثِيڒِيذْ\add* ذ أَمنْعُوڒْ ذِي ثنْذِينْثْ ؤُ \add أَذْ ثِيڒِيذْ\add* ذ أَمنْعُوڒْ ذڭْ إِيَّارْ.  
\v 17 ثَاسُودْجثْ نّشْ ذ ثبْقشْثْ نّشْ \add أَذْ إِڒِينْثْ\add* تّْوَانعْڒنْثْ.  
\v 18 ذ ثَامنْعُوڒْثْ إِ غَا ثِيڒِي ڒْغِيدْجثْ ن ؤُعذِّيسْ نّشْ ذ ڒْغِيدْجثْ ن ثمُّورْثْ نّشْ ؤُ ثْوَارُورَا ن ثْفُونَاسِينْ نّشْ ذ إِمژْيَاننْ إِعِيزّنْ ن وُودْجِي نّشْ.  
\v 19 \add أَذْ ثِيڒِيذْ\add* ذ أَمنْعُوڒْ غَارْ وَاذَافْ نّشْ ؤُ \add أَذْ ثِيڒِيذْ\add* ذ أَمنْعُوڒْ ذڭْ ؤُفُّوغْ نّشْ.“   
\b  
\m
\v 20 ”أَذْ أَشْ د-إِسّكّْ سِيذِي نّعْڒثْ ذ ؤُخَارْوضْ ذ ؤُهذِّي غَارْ مَارَّا مَانِي إِسّْوِيژّذْ ؤُفُوسْ نّشْ، أَڒْ غَا ثتّْوَامْحِيذْ ؤُ أَذْ ثفْنِيذْ ذغْيَا زَّاثْ إِ وُوذمْ إِنُو ذِي سِّيبّثْ ن ڒخْذَايمْ نّشْ ثِيعفَّانِينْ، مِينْزِي ثجِّيذْ أَيِي.  
\v 21 سِيذِي أَذْ ذَايكْ إِسّڒْصقْ طَّاعُونْ أَڒْ شكْ غَا إِقْضَا زِي ثمُّورْثْ نِّي غَارْ غَا ثَاذْفذْ حِيمَا أَذْ ت ثكْسِيذْ ذ ڒْوَارْثْ.  
\v 22 سِيذِي أَذْ شكْ إِوّثْ س بُو-ذدْجِيسْ، س ثْمسِّي \add ن أَرْوَاحْ\add* ذ ؤُڭيّحْ، س ڒحْمُو ذ ڒَاژَاغْ، س \add إِمنْذِي\add* إِتّْوَاسّْشمْضنْ \add زڭْ ؤُسمِّيضْ\add* ؤُڒَا ذ جّْرِيحشْثْ ن وفْسُو. إِنَا أَذْ شكْ ضْفَارنْ أَڒْ غَا ثْهلّْكذْ. \x ◘ \xo 28:‏22 \xt لَاوِي 26‏:‏16\x*  
\v 23 أَجنَّا نِّي \add إِدْجَانْ\add* ثِيوَا إِ ؤُزدْجِيفْ نّشْ أَذْ يِيڒِي ذ نّْحَاسْ ؤُ ثَامُّورْثْ نِّي \add إِدْجَانْ\add* سَاذُو نّشْ ذ ؤُزَّاڒْ. \x ◘ \xo 28:‏23 \xt لَاوِي 26‏:‏19\x*  
\v 24 أَذْ يَارّْ سِيذِي، أَربِّي نّشْ، أَنْژَارْ ن ثمُّورْثْ نّشْ ذ \add إِجّْ ن ؤُسيْنُو ن\add* ڒعْجَاجْ ذ \add إِبْقُوقنْ ن\add* ڒعْجَاجْ. مَانْ أَيَا أَذْ خَاكْ د-إِهْوَا أَڒْ غَا ثتّْوَاثحِّيذْ.  
\v 25 سِيذِي أَذْ شكْ يَارّْ ثتّْوَاغڒْبذْ زَّاثْ إِ وُوذمْ ن ڒْعذْيَانْ نّشْ. ذڭْ إِجّْ ن وبْرِيذْ أَذْ د-ثفّْغذْ ضِيدّْ إِ ڒعْذُو نّشْ ؤُشَا أَذْ ثَاروْڒذْ زَّاثْ إِ وُوذمْ نّسْ خْ سبْعَا ن إِبْرِيذنْ ؤُشَا أَذْ ثِيڒِيذْ ذ \add إِشْثْ ن ڒْقشْعثْ\add* ن ؤُنخْڒِيعْ إِ مَارَّا ثِيڭلْذِيوِينْ ن دُّونشْثْ.  
\v 26 ڒْخشْبثْ نّشْ أَذْ ثِيڒِي ذ مَاشَّا إِ إِجْضَاضْ ن ؤُجنَّا ؤُ إِ مَارَّا ڒْمَاڒْ خْ ثمُّورْثْ ؤُشَا ؤُڒَا ذ إِجّْ وَارْ إِزمَّارْ أَذْ ثنْ إِسِّيڭّْوذْ.  
\v 27 سِيذِي أَذْ شكْ إِوّثْ س ثْحبَّا ن مِيصْرَا، س إِعبُّوزنْ، س جْذَامْ، س وَاجِّيضْ أَڒْ غَا ثَافْ وَارْ ثْزمَّارذْ أَذْ ثڭّنْفِيذْ. \x ◘ \xo 28:‏27 \xt ؤُف. 9‏:‏9\x*  
\v 28 سِيذِي أَذْ شكْ إِوّثْ س ثُوبُّوهڒْيَا، س ثُودَّارْغتْشْ ؤُ س أَرْجفْ ن وُوڒْ.“   
\b  
\m
\v 29 ”ذڭْ وزْينْ ن ؤُزِيڒْ أَذْ ثْحَاذِيذْ أَمْ ؤُحَاذِي ن ؤُذَارْغَاڒْ ذِي ثَادْجسْثْ. إِبْرِيذنْ نّشْ وَارْ تِّيڒِينْ صڒْحنْ، \add وَاهْ،\add* أَذْ ثِيڒِيذْ ثتّْوَاحْصَارذْ ؤُ ثتّْوَاكشّْضذْ مَارَّا ؤُسَّانْ \add ن ثُوذَارْثْ نّشْ\add* ؤُشَا وَارْ إِتِّيڒِي وِي شكْ غَا إِسّنْجْمنْ.  
\v 30 أَذْ ثْخضْبذْ إِشْثْ ن ثمْغَارْثْ ؤُشَا إِجّْ ن ورْيَازْ نّغْنِي أَذْ ت إِسّْنُوقّبْ، أَذْ ثبْنِيذْ ثَادَّارْثْ إِ يِيخفْ نّشْ ؤُشَا وَارْ ذَايسْ ثْزدّْغذْ، أَذْ ثڭِّيذْ إِجّْ ن ؤُمَارْجعْ ن ؤُضِيڒْ أَذْ ذَايسْ ثژُّوذْ ثِيزَايَارِينْ مَاشَا وَارْ زَّايْسنْثْ ثسْثنْفِيعذْ.  
\v 31 أَفُونَاسْ نّشْ أَذْ إِتّْوَاغَارْصْ زَّاثْ إِ ثِيطَّاوِينْ نّشْ ؤُشَا وَارْ زَّايسْ ثتّتّذْ، أَغْيُوڒْ نّشْ أَذْ ث ؤُشَارنْ زَّاثْ إِ وُوذمْ نّشْ ؤُشَا وَارْ ذ أَشْ د-إِتّْعِيقِّيبْ. ؤُدْجِي نّشْ أَذْ ث وْشنْ إِ ڒْعذْيَانْ نّشْ ؤُشَا وَارْ غَاركْ إِتِّيڒِي وِي غَا إِسّنْجْمنْ.  
\v 32 أَذْ مّوْشنْ إِحنْجِيرنْ نّشْ ذ ثْحنْجِيرِينْ نّشْ إِ يِيجّْ ن ڒْڭنْسْ نّغْنِي. ثِيطَّاوِينْ نّشْ أَذْ ثْوَاڒَانْثْ ؤُشَا أَذْ ذَايْسنْ ثمّژْرذْ أَسّْ إِكْمڒْ ؤُشَا وَارْ إِتِّيڒِي جّهْذْ ذڭْ ؤُفُوسْ نّشْ.  
\v 33 ڒْغِيدْجثْ ن ثمُّورْثْ نّشْ ذ مَارَّا ڒْخذْمثْ نّشْ أَذْ ث إِشّْ إِجّْ ن ڒْڭنْسْ إِ وَارْ ثسِّينذْ ؤُشَا أَذْ ثِيڒِيذْ ثحْصَارذْ ؤُ أَذْ ثْڒبْزذْ وَاهَا مَارَّا ؤُسَّانْ \add ن ثُوذَارْثْ نّشْ\add*.  
\v 34 أَذْ ثْذوْڒذْ ذ أَبُوهَاڒِي زِي سِّيبّثْ ن مِينْ غَا ثْژَارذْ س ثِيطَّاوِينْ نّشْ.“   
\b  
\m
\v 35 ”سِيذِي أَذْ شكْ إِوّثْ س ثْحبَّا ثِيعفَّانِينْ غَارْ إِفَادّنْ ؤُ غَارْ إِضَارنْ إِ زِي وَارْ ثْزمَّارذْ أَذْ زَّايْسنْ ثڭّنْفِيذْ، زِي ثْڒقَّا ن ؤُضَارْ نّشْ أَڒْ أَشقُّوفْ \add ن ؤُزدْجِيفْ\add* نّشْ.  
\v 36 سِيذِي أَذْ شكْ يَارّْ \add جْمِيعْ\add* أَكْ-ذ ؤُجدْجِيذْ نّشْ، ونِّي شكْ غَا ثڭّذْ خْ يِيخفْ نّشْ، أَذْ ثْرَاحذْ غَارْ إِجّْ ن ڒْڭنْسْ نِّي وَارْ ثسِّينذْ شَا، ؤُڒَا ذ ڒجْذُوذْ نّشْ، ؤُشَا ذِينْ إِ غَا ثْسخَّارذْ إِ إِربِّيثنْ نّغْنِي ن ؤُكشُّوضْ ذ وژْرُو.  
\v 37 أَذْ ثِيڒِيذْ ذ \add إِشْثْ ن ڒْقشْعثْ ن\add* ؤُنخْڒِيعْ ذ إِجّْ ن ؤُمذْيَا ذ إِشْثْ \add ن سِّيبّثْ إِ\add* ؤُسْثهْزِي إِقسْحنْ جَارْ مَارَّا ڒڭْنُوسْ مَانِي شكْ غَا إِنْذهْ سِيذِي.  
\v 38 أَذْ ثسُّوفّْغذْ أَطَّاسْ ن زَّارِيعثْ غَارْ ييَّارْ ؤُشَا أَذْ ثْڒقْضذْ ذْرُوسْ، مِينْزِي ثَامُورْغِي أَذْ ت ثحْڒُووْ. \x ◘ \xo 28:‏38 \xt مِيخَا 6‏:‏15؛ Ḥag. 1‏:‏6\x*  
\v 39 أَذْ ثڭِّيذْ إِمَارْجَاعنْ ن ؤُضِيڒْ أَذْ ذَايْسنْ ثژُّوذْ ثِيزَايَارِينْ ؤُشَا أَذْ ثنْثْ ثْعَارّْصذْ، \add مَاشَا\add* وَارْ ثْسسّذْ بِينُو ؤُشَا وَارْ ثْڒقّْضذْ وَالُو، مِينْزِي أَذْ ثنْثْ إِشّْ ؤُكشَّا.  
\v 40 أَذْ غَاركْ إِڒِينْ إِزمُّورنْ ذِي مَارَّا ثَامُّورْثْ نّشْ، \add مَاشَا\add* وَارْ ثْذهّْنذْ إِخفْ نّشْ س زّشْثْ، مِينْزِي أَذْ إِوْضَا \add زِّيثُونْ\add* زڭْ ؤُزمُّورْ نّشْ \add قْبڒْ ڒْوقْثْ\add*.  
\v 41 أَذْ د-ثجّذْ إِحنْجِيرنْ ذ ثْحنْجِيرِينْ، \add مَاشَا\add* وَارْ تِّيڒِينْ شَا نّشْ، مِينْزِي أَذْ رُوحنْ ذِي ثْمحْبَاسْثْ.  
\v 42 مَارَّا ثِيشجُّورَا ذ ڒْغِيدْجثْ ن ثمُّورْثْ نّشْ أَذْ ثنْثْ ثطّفْ ثْمُورْغِي ذ ثَاسْغَارْثْ نّسْ.  
\v 43 أَبَارَّانِي نِّي \add إِدْجَانْ\add* ذِي ڒْوسْطْ نّشْ، أَذْ خَاكْ إِسُّوعْڒَا إِخفْ نّسْ، سنّجْ ؤُ سنّجْ عَاذْ، ؤُشَا شكْ أَذْ ثتّْوَاسّهْوِيذْ غَارْ ثمُّورْثْ، سْوَادَّايْ غَارْ وَادَّايْ.  
\v 44 نتَّا أَذْ أَشْ يَارْضڒْ، \add مَاشَا\add* شكْ وَارْ ذ أَسْ ثَارطّْڒذْ. نتَّا أَذْ يِيڒِي ذ أَزدْجِيفْ، شكْ أَذْ ثِيڒِيذْ ذ أَنوَّارْ.  
\v 45 ؤُشَا أَذْ خَاكْ د-هْوَانْثْ مَارَّا نّْعَاڒِي-يَا، أَذْ شكْ ضْفَارنْثْ، أَذْ شكْ ڒقْفنْثْ أَڒْ غَا ثتّْوَامْحِيذْ، ؤُمِي وَارْ ثسْڒِيذْ إِ ثْمِيجَّا ن سِيذِي، أَربِّي نّشْ، حِيمَا أَذْ ثحْضِيذْ ڒُومُورَاثْ نّسْ ذ ثِيوصَّا نّسْ، إِنِّي ذ أَشْ يُومُورْ نتَّا.  
\v 46 أَذْ إِڒِينْثْ ذ إِشْثْ ن ڒعْڒَامثْ ذ إِجّْ ن ؤُسِيڭّْوِيذْ يوْعَارنْ إِ شكْ ؤُ إِ زَّارِيعثْ نّشْ إِ ڒبْذَا.  
\v 47 مِينْزِي وَارْ ثْسخَّارذْ إِ سِيذِي، أَربِّي نّشْ س ڒفْرَاحثْ ذ ثْشُونِي ن وُوڒْ زِي سِّيبّثْ ن ؤُفيّضْ ن مَارَّا مِينْ ذِينْ \add إِدْجَانْ\add*،  
\v 48 أَذْ ثْسخَّارذْ إِ ڒْعذْيَانْ، إِنِّي إِ خَاكْ غَا إِسّكّْ سِيذِي، س ڒَاژْ ذ ؤُفَاذِي، س ثُوعَّارْينْثْ ذ ڒخْصصْ ن مَارَّا ثِيمسْڒَايِينْ، ؤُشَا نتَّا أَذْ إِڭّْ أَزَايْڒُو ن وُوزَّاڒْ خْ يِيرِي نّشْ، أَڒْ شكْ غَا إِمْحَا.  
\v 49 سِيذِي أَذْ خَاكْ د-إِسّْڭعّذْ إِجّْ ن ڒْڭنْسْ إِڭّْوجْ، زڭْ ؤُنڭَّارُو ن ثمُّورْثْ، أَمْ يِيجّْ ن ؤُڭِيذرْ إِطَّاونْ، إِجّْ ن ڒْڭنْسْ إِ ؤُمِي وَارْ ثْزمَّارذْ أَذْ ثْفهْمذْ إِڒسْ نّسْ، \f ◼ \fr 28:‏49 \ft \+bd ’أَڭِيذرْ‘\+bd* - نِيغْ ’أَسِيوَانْ‘.\f*  
\v 50 إِجّْ ن ڒْڭنْسْ غَارسْ ؤُذمْ إِقْضعْ، وَارْ إِتّْوقَّارْ أَوسَّارْ، وَارْ يَارحّمْ خْ ؤُحنْجِيرْ.  
\v 51 أَذْ يشّْ ڒْغِيدْجثْ ن ڒبْهَايمْ نّشْ ذ ڒْغِيدْجثْ ن ثمُّورْثْ نّشْ، أَڒْ غَا ثتّْوَامْحِيذْ، مِينْزِي وَارْ ذ أَشْ إِتّجِّي إِرْذنْ، نِيغْ بِينُو ن جْذِيذْ، نِيغْ زّشْثْ \add ن طّْرِي\add*، نِيغْ ثْوَارُورَا ن ثْفُونَاسِينْ نّشْ نِيغْ إِمژْيَاننْ إِعِيزّنْ ن وُودْجِي نّشْ، أَڒْ شكْ إِ غَا يَاردّدْجْ.  
\v 52 أَذْ شكْ إِحْصَارْ جَارْ مَارَّا ثوُّورَا نّشْ، أَڒْ غَا وْضَانْ ڒحْيُوضْ يُوعْڒَانْ إِمثْننْ، إِنِّي خْ ثُوغَا ثتّشْڒذْ ذِي مَارَّا ثَامُّورْثْ نّشْ. أَذْ شكْ إِحْصَارْ جَارْ مَارَّا ثوُّورَا نّشْ ذِي مَارَّا ثَامُّورْثْ نِّي ذ أَشْ إِوْشَا سِيذِي، أَربِّي نّشْ.  
\v 53 خْمِي ذ أَكْ-د غَا إِنّْضنْ ؤُ ذِي ڒحْصَارثْ إِ زِي شكْ غَا إِحْصَارنْ ڒْعذْيَانْ نّشْ، أَذْ ثشّذْ ڒْغِيدْجثْ ن ؤُعذِّيسْ نّشْ ذ ويْسُومْ ن إِحنْجِيرنْ نّشْ ذ ثْحنْجِيرِينْ نّشْ نِّي ذ أَشْ غَا إِوْشْ سِيذِي، أَربِّي نّشْ. \x ◘ \xo 28:‏53 \xt لَاوِي 26‏:‏29؛ 2 إِج. 6‏:‏29؛ إِڭجذ. 4‏:‏10\x*  
\v 54 أَرْيَازْ نِّي إِ يَارضْبنْ ؤُ ونِّي إِضبْعنْ أَطَّاسْ أَذْ ثِيڒِي ثَامُوغْڒِي نّسْ ذ ثَاعفَّانْثْ غَارْ ؤُمَاسْ ؤُ غَارْ ثمْغَارْثْ ن وُوڒْ نّسْ ؤُ غَارْ مِينْ ذ أَسْ إِقِّيمنْ زڭْ إِحنْجِيرنْ نّسْ،  
\v 55 مَاحنْذْ وَارْ إِتِّيشْ ؤُڒَا إِ يِيجّْ زَّايْسنْ شَا ن ويْسُومْ ن إِحنْجِيرنْ نّسْ، إِنِّي إِ غَا يشّْ ؤُمِي وَارْ ذ أَسْ إِقِّيمْ شَا \add زِي\add* مَارَّا \add مَانْ أَيَا\add* ذِي ڒحْصَارثْ ؤُ ذِي ضِّيقَا إِ زِي خَاكْ غَا إِبزّزْ ڒعْذُو نّشْ ذِي مَارَّا ثِيوُّورَا نّشْ.  
\v 56 ثَامْغَارْثْ إِ يَارضْبنْ ؤُ ثنِّي إِضبْعنْ أَطَّاسْ،عمَّارْصْ وَارْ ثڭِّي ثْڒقَّا ن ؤُضَارْ نّسْ خْ ثمُّورْثْ ذِي سِّيبّثْ ن وَارْضَابْ ؤُ ن وضْبعْ نّسْ، أَذْ ثِيڒِي ثْمُوغْڒِي نّسْ ذ ثَاعفَّانْثْ غَارْ ورْيَازْ ن وُوڒْ نّسْ ؤُ غَارْ مِّيسْ ذ يدْجِيسْ،  
\v 57 ذِي سِّيبّثْ ن لُّوفَانْ نِّي د-إِفّْغنْ جَارْ إِضَارنْ نّسْ ؤُ ذِي سِّيبّثْ ن إِحنْجِيرنْ نِّي ثُورُووْ، مِينْزِي أَذْ ثنْ ثشّْ س ثْنُوفّْرَا ذِي سِّيبّثْ ن ڒخْصصْ ن مَارَّا ذِي ڒحْصَارثْ ؤُ ذِي ضِّيقَا إِ خَاكْ غَا إِبزّزْ ڒعْذُو نّشْ ذِي مَارَّا ثِيوُّورَا نّشْ.“   
\b  
\m
\v 58 ”مَاڒَا وَارْ ثحْضِيذْ مَارَّا أَوَاڒنْ ن شَّارِيعَا-يَا نِّي يُورَانْ ذڭْ وذْلِيسْ-أَ إِتّْوَانّْضنْ مَاحنْذْ أَذْ ثڭّْوذذْ إِسمْ-أَ إِعُودْجَانْ، إِسَّاڭّْوَاذنْ، سِيذِي، أَربِّي نّشْ،  
\v 59 \add خنِّي\add* أَذْ يَارّْ سِيذِي جّْرَايحْ نّشْ ذ جّْرَايحْ جَارْ زَّارِيعثْ نّشْ ذ إِجّْ ن أَرْجفْ أَڒْ طَّارْفْ. أَذْ إِڒِينْثْ ذ جّْرَايحْ مْغَارنْثْ، أَذْ ذُومنْثْ، ؤُشَا أَذْ إِڒِينْ ڒهْڒَاشَاثْ إِعفّْننْ إِ غَا إِقِّيمنْ غَارْ زَّاثْ.  
\v 60 نتَّا أَذْ غَاركْ د-يَارّْ مَارَّا ڒهْڒَاشَاثْ ن مِيصْرَا إِ زِي ثُوغَا ثڭّْوْذذْ ؤُشَا أَذْ ذَايكْ ڒصْقنْثْ.  
\v 61 أَمنِّي أَذْ غَاركْ د-يَارّْ سِيذِي مَارَّا ڒهْڒَاشَاثْ ذ مَارَّا جّْرَايحْ نِّي وَارْ يُورِينْ ذڭْ وذْلِيسْ إِتّْوَانْضنْ ن شَّارِيعَا-يَا، أَڒْ غَا ثتّْوَامْحِيذْ.  
\v 62 أَذْ ثقِّيمذْ أَكْ-ذ إِجّْ ن وُورُو ن يرْيَازنْ ذڭْ ومْشَانْ إِ ذِي غَا ثِيڒِيمْ أَمْ يِيثْرَانْ ن ؤُجنَّا ذڭْ وَاطَّاسْ، ؤُمِي وَارْ ثسْڒِيذْ إِ ثْمِيجَّا ن سِيذِي، أَربِّي نّشْ.  
\v 63 أَمْ مَامّشْ زَّايْومْ إِفَارْحْ سِيذِي حِيمَا أَذْ ذَايْومْ إِڭّْ ثْشُونِي ؤُ أَذْ أَومْ إِتّْمَارْنِي، أَمُّو زَّايْومْ إِ غَا إِفَارْحْ سِيذِي مَاحنْذْ أَذْ كنِّيوْ إِهلّكْ ؤُ مَاحنْذْ أَذْ كنِّيوْ إِثحَّا ؤُشَا كنِّيوْ أَذْ ثتّْوَاقڒْعمْ زِي ثمُّورْثْ نِّي غَارْ غَا ثَاذْفذْ حِيمَا أَذْ ت ثكْسِيذْ ذ ڒْوَارْثْ. \x ◘ \xo 28:‏63 \xt إِشا. 1‏:‏24\x*  
\v 64 سِيذِي أَذْ أَشْ إِبزّعْ خْ مَارَّا ڒڭْنُوسْ، زڭْ ؤُجمَّاضْ ن دُّونشْثْ أَڒْ ؤُجمَّاضْ نّغْنِي ن دُّونشْثْ ؤُشَا ذِينْ أَذْ ثْسخَّارذْ إِ إِربِّيثنْ نّغْنِي \add ن\add* ؤُكشُّوضْ ذ وژْرُو نِّي وَارْ ثسِّينذْ شكْ نِيغْ ڒجْذُوذْ نّشْ. \x ◘ \xo 28:‏64 \xt أَعَوذ. 4‏:‏27؛ نَاح. 1‏:‏8\x*  
\v 65 وَارْ ثتِّيفذْ ڒْهُوذْنثْ جَارْ ڒڭْنُوسْ-أَ ؤُشَا ثَاڒقَّا ن ؤُضَارْ نّشْ وَارْ ثتِّيفْ أَريَّاحْ، \add مِينْزِي\add* سِيذِي أَذْ أَشْ إِوْشْ ذِينْ ؤُڒْ يَارجْفنْ ذ ثْمُوغْڒِي ثْخسِّي ذ إِجّْ ن ڒعْمَارْ إِسْڒَاونْ.  
\v 66 ثُوذَارْثْ نّشْ أَذْ أَشْ ثِيڒِي أَمْ ثُويڒْ زَّاثْ نّشْ، أَذْ ثِيڒِيذْ ثڭّْوذذْ دْجِيڒثْ ذ وَاسّْ ؤُشَا وَارْ إِتِّيڒِي وضْمَانْ خْ ثُوذَارْثْ نّشْ.  
\v 67 غَارْ صّْبحْ أَذْ ثِينِيذْ: ’أَ، إِڒِي أَذْ ثِيڒِي ذ دْجِيڒثْ!‘ ؤُ ذِي دْجِيڒثْ أَذْ ثِينِيذْ: ’أَ، إِڒِي أَذْ يِيڒِي ذْ ضّْبحْ!‘ زِي سِّيبّثْ ن ثِيڭّْوُوذِي ذڭْ وُوڒْ نّشْ إِ ذ أَشْ إِسِّيڭّْوِيذنْ ؤُ زِي سِّيبّثْ ن مِينْ غَا ثْوَاڒِينْثْ ثِيطَّاوِينْ نّشْ.  
\v 68 سِيذِي أَذْ شكْ يَارّْ غَارْ مِيصْرَا ذڭْ إِغُورُّوبَا خْ وبْرِيذْ مِينْ خفْ ذ أَشْ نِّيغْ: ’وَارْ ث ثْژَارّذْعمَّارْصْ!‘، ؤُشَا ذِينْ أَذْ ثزّنْزمْ إِخفْ نْومْ إِ ڒْعذْيَانْ نّشْ ذ إِسمْغَانْ ذ ثِييَّا، \add مَاشَا\add* وَارْ إِتِّيڒِي وِي كنِّيوْ إِ غَا إِسْغنْ.“   
\b  
\m
\v 69 إِنَا ذ أَوَاڒنْ ن ڒْعَاهْذْ نِّي يُومُورْ سِيذِي إِ مُوسَا حِيمَا أَذْ ث إِڭّْ أَكْ-ذ أَيْثْ ن إِسْرَائِيل ذِي ثمُّورْثْ ن مُوآبَ، سنّجْ إِ ڒْعَاهْذْ إِ كِيذْسنْ إِڭَّا غَارْ حُورِيبْ.   
\b  
\b  
\m  
\c 29
\s1 تِّيقّثْ ذ طَّاعثْ  
\m
\v 1 إِڒَاغَا-د مُوسَا خْ مَارَّا إِسْرَائِيل، إِنَّا أَسنْ:  
\m ”كنِّيوْ أَقَا ثژْرِيمْ مَارَّا مِينْ إِڭَّا سِيذِي ذِي ثمُّورْثْ ن مِيصْرَا زَّاثْ إِ ثِيطَّاوِينْ نْومْ ذِي فِيرْعُونْ ذ مَارَّا إِمْسخَّارنْ نّسْ ذ مَارَّا ثَامُّورْثْ نّسْ، \x ◘ \xo 29:‏1 \xt ؤُف. 19‏:‏4\x*  
\v 2 ثِيقدْجُوبَا ثِيمقّْرَانِينْ، ثِينِّي ثژْرِيمْ س ثِيطَّاوِينْ نْومْ، ڒعْڒَامَاثْ ذ لْمُوعْجِيزَاثْ نِّي إِمْغَارنْ. \x ◘ \xo 29:‏2 \xt أَعَوذ. 4‏:‏34؛ 7‏:‏19\x*  
\v 3 أَڒْ أَسّْ-أَ سِيذِي وَارْ ذ أَومْ إِوْشِي ؤُڒْ حِيمَا أَذْ ثْفهْممْ ؤُڒَا ذ ثِيطَّاوِينْ حِيمَا أَذْ ثْژَارمْ ؤُڒَا ذ إِمزُّوغنْ حِيمَا أَذْ ثسْڒمْ.  
\v 4 سّْنذْهغْ كنِّيوْ أَربْعِينْ ن إِسڭّْوُوسَا ذِي ڒخْڒَا. أَرُّوضْ نْومْ وَارْ إِذْوِيڒْ ذ ڒْبَاڒِي ؤُ ثِيسِيڒَا نْومْ وَارْ دُّويْسَارنْثْ خْ إِضَارنْ نْومْ.  
\v 5 وَارْ ثشِّيمْ أَغْرُومْ، وَارْ ثسْوِيمْ بِينُو ؤُڒَا ذ شّْرَابْ، حِيمَا أَذْ ثسّْنمْ بلِّي نشّْ ذ سِيذِي، أَربِّي نْومْ.“   
\m
\v 6 ”\add ڒَْامِي\add* ثْرحّْڭمْ غَارْ ومْشَانْ-أَ، إِفّغْ-د سِيحُونْ، أَجدْجِيذْ ن حَاشْبُونْ، أَكْ-ذ عُوجْ، أَجدْجِيذْ ن بَاشَانْ، حِيمَا أَذْ كِيذْنغْ إِمْسَاڭَارْ إِ ؤُمنْغِي ؤُشَا نغْڒبْ إِ-ثنْ \x ◘ \xo 29:‏6 \xt ڒخْڒ. 21‏:‏24، 33؛ أَعَوذ. 2‏:‏32؛ 3‏:‏1\x*  
\v 7 ؤُشَا نطّفْ ثَامُّورْثْ نْسنْ ؤُشَا نوْشْ إِ-ت ذ ڒْوَارْثْ إِ إِرُوبِينِييّنْ ذ إِجَاذِييّنْ ؤُ إِ وزْينْ ن ثقْبِيتْشْ ن مَانَاسَّا. \x ◘ \xo 29:‏7 \xt ڒخْڒ. 32‏:‏33؛ أَعَوذ. 3‏:‏12؛ ياش. 13‏:‏8\x*   
\m
\v 8 حْضَامْ أَوَاڒنْ ن ڒْعَاهْذْ-أَ، ثڭّمْ ثنْ، حِيمَا أَذْ ثَاوْضمْ س ڒعْقڒْ غَارْ مَارَّا مِينْ غَا ثڭّمْ.  
\v 9 أَسّْ-أَ مَارَّا كنِّيوْ ثْبدّمْ زَّاثْ إِ وُوذمْ ن سِيذِي، أَربِّي نْومْ - إِزدْجِيفنْ ن ثْقبَّاڒْ نْومْ ذ إِمْغَارنْ نْومْ ذ إِمحْضَاينْ نْومْ، مَارَّا إِرْيَازنْ ن إِسْرَائِيل،  
\v 10 إِمژْيَاننْ نْومْ، ذ ثمْغَارِينْ نْومْ، إِبَارَّانِييّنْ نِّي إِزدّْغنْ ذِي ڒْوسْثْ ن ڒْمَارْڭحْ ن ڒْعسْكَارْ نْومْ، زڭْ ونِّي إِتّْقسّنْ أَكشُّوضْ أَڒْ ونِّي د-إِتَّايْمنْ أَمَانْ -  
\v 11 حِيمَا أَذْ يَاذفْ \add كُوڒْ إِجّْ زَّايْومْ\add* غَارْ ڒْعَاهْذْ ن سِيذِي، أَربِّي نّشْ نِّي إِ غَا إِقّنْ سِيذِي، أَربِّي نّشْ أَسّْ-أَ أَكِيذكْ، ؤُ غَارْ نّعْڒثْ \add إِ إِدْجَانْ ذ ؤُغزْذِيسْ نّسْ نّغْنِي\add*،  
\v 12 حِيمَا أَذْ أَشْ يڭّْ أَسّْ-أَ أَذْ ثكَّارذْ أَمْ ڒْڭنْسْ نّسْ ؤُشَا نتَّا أَذْ أَشْ يِيڒِي ذ أَربِّي، أَمْ ذ أَشْ إِنَّا ؤُ أَمْ إِجُّودْجْ إِ ڒجْذُوذْ نّشْ إِبْرَاهِيمْ ذ إِسْحَاقْ ذ يَاعْقُوبْ. \x ◘ \xo 29:‏12 \xt أَمز. 17‏:‏7\x*  
\v 13 وَارْ إِدْجِي أَكِيذْومْ وَاهَا إِ غَا ڭّغْ ڒْعَاهْذْ-أَ ذ نّعْڒثْ-أَ \add إِ إِدْجَانْ ذ ؤُغزْذِيسْ نّسْ نّغْنِي\add*،  
\v 14 أَكْ-ذ يِينِّي ذَا غَارْنغْ إِحْضَارنْ أَسّْ-أَ زَّاثْ إِ وُوذمْ ن سِيذِي، أَربِّي نّغْ، \add مَاشَا عَاوذْ\add* أَكْ-ذ يِينِّي وَارْ ذَا غَارْنغْ إِدْجِينْ أَسّْ-أَ.  
\v 15 مِينْزِي كنِّيوْ ثسّْنمْ مَامّشْ ثُوغَا نْزدّغْ ذِي ثمُّورْثْ ن مِيصْرَا، ؤُ مَامّشْ نژْوَا ذِي ڒْوسْطْ \add ن ثمُّورَا\add* ن ڒڭْنُوسْ نِّي خْ د-ثكّمْ ؤُڒَا ذ كنِّيوْ،  
\v 16 ؤُشَا ثژْرِيمْ نّْعَاوَاثْ نْسنْ ن لْ-أَصْنَامْ ذ إِميْضَا \add ن لْ-أَصْنَامْ نْسنْ\add* نِّي غَارْسنْ ن وژْرُو ذ ؤُكشُّوضْ ذ نُّوقَارْثْ ذ وُورغْ.“   
\m
\v 17 ”وَارْ إِتِّيڒِي جَارْ أَومْ أَرْيَازْ نِيغْ ثَامْغَارْثْ نِيغْ ڒَادْجْ نِيغْ ثَاقْبِيتْشْ أَذْ إِسِّيڭّْوجْ أَسّْ-أَ ؤُڒْ نّسْ خْ سِيذِي، أَربِّي نْومْ، حِيمَا أَذْ إِسخَّارْ إِ إِربِّيثنْ ن ڒڭْنُوسْ نِّي ؤُ وَارْ إِتِّيڒِي جَارْ أَومْ أَژْوَارْ نِّي إِ غَا إِتَّارْونْ أَرّْهَاجْ نِيغْ شِّيحْ، \x ◘ \xo 29:‏17 \xt ڒخ. 8‏:‏23؛ عبر. 12‏:‏15\x*  
\v 18 \add ؤُشَا\add* أَذْ إِمْسَارْ، ؤُمِي غَا إِسڒْ أَوَاڒنْ ن نّعْڒثْ-أَ، أَقَا نتَّا أَذْ إِسڭّمْ إِخفْ نّسْ ذڭْ وُوڒْ نّسْ، أَذْ يِينِي: ’أَذْ غَارِي يِيڒِي ڒهْنَا، وَاخَّا ڭُّورغْ ذِي ڒقْسَاحثْ ن وُوڒْ إِنُو، أَڒْ غَا إِهلّكْ مِينْ إِسُّونْ أَكْ-ذ مِينْ إِفُّوذنْ.‘  
\v 19 سِيذِي وَارْ ذ أَسْ إِسمّحْ، مَاشَا أَغْضَابْ ن سِيذِي ذ ثُوسْمِي نّسْ \add إِقدّْسنْ\add* أَذْ دُّوخّْننْ ذڭْ ورْيَازْ نِّي، ؤُ مَارَّا نّعْڒثْ نِّي يُورِينْ ذڭْ وذْلِيسْ-أَ إِتّْوَانّْضنْ أَذْ خَاسْ ثِيڒِي ؤُشَا سِيذِي أَذْ إِمْحَا إِسمْ نّسْ زِي سَاذُو ؤُجنَّا.  
\v 20 سِيذِي أَذْ ث إِحُوزْ خْ مَارَّا ثِيقبَّاڒْ ن إِسْرَائِيل إِ ڒْغَارْ، عْلَاحْسَابْ مَارَّا نّْعَاڒِي ن ڒْعَاهْذْ نِّي يُورِينْ ذڭْ وذْلِيسْ-أَ إِتّْوَانْضنْ ن شَّارِيعَا-يَا.  
\v 21 \add خنِّي\add* جِّيڒْ إِ د غَا يَاسنْ، إِحنْجِيرنْ نْومْ، إِنِّي غَا إِڭعّْذنْ أَوَارْنِي أَومْ، ؤُڒَا ذ ؤُبَارَّانِي نِّي إِ د غَا يَاسنْ زڭْ إِشْثْ ن ثمُّورْثْ ثِيڭّْوجْ، \add مَارَّا\add* نِيثْنِي أَذْ إِنِينْ \add أَمُّو\add* خْمِي غَا ژَترنْ جّْرَايحْ ن ثمُّورْثْ-أَ ذ ڒهْڒَاشَاثْ إِ زِي إِسّهْڒشْ سِيذِي ثَامُّورْثْ:  
\v 22 ’ڒشْبَارِييّثْ ذ ثْمدْجَاحْثْ، أَقَا ثشْمضْ مَارَّا ثَامُّورْثْ، وَارْ ثتّْوَاژُّو نِيغْ ثسّْغمِّي \add عَاذْ\add* ؤُ وَارْ إِسّْڭعِّيذْ أَفْسُو \add أَزِيزَا\add*، أَمْ مَامّشْ \add إِمْسَارْ\add* ذڭْ ؤُنقْڒبْ ن سَاذُومْ ذ عَامُورَّا ذ أَذْمَا ذ صابُويِيمْ نِّي إِسّْنقْڒبْ سِيذِي ذڭْ وغْضَابْ نّسْ ذ وسْعَارْ نّسْ!‘،  
\v 23 ؤُشَا \add عَاوذْ\add* مَارَّا ڒڭْنُوسْ أَذْ إِنِينْ: ’مَايمِّي إِڭَّا سِيذِي مَانْ أَيَا إِ ثمُّورْثْ-أَ؟ مَانَا ڒْحَاذُوقْ ن وغْضَابْ-أَ إِمْغَارنْ؟‘ \x ◘ \xo 29:‏23 \xt إِرْم. 22‏:‏8\x*  
\v 24 \add خنِّي\add* أَذْ د-أَرّنْ: ’مِينْزِي نِيثْنِي جِّينْ ڒْعَاهْذْ ن سِيذِي، أَربِّي ن ڒجْذُوذْ نْسنْ، \add ڒْعَاهْذْ\add* نِّي إِقّنْ نتَّا أَكِيذْسنْ ؤُمِي ثنْ د-إِسُّوفّغْ زِي ثمُّورْثْ ن مِيصْرَا.  
\v 25 ؤُيُورنْعبْذنْ إِ إِربِّيثنْ نّغْنِي ؤُشَا بنْذْقنْ أَسنْ، \add إِ\add* إِربِّيثنْ نِّي وَارْ سِّيننْ نِيثْنِي، وَارْ ذ أَسنْ ثنْثْ-إِ-د-إِوْشِي نتَّا.  
\v 26 أَغْضَابْ ن سِيذِي يَارْغَا خْ ثمُّورْثْ-أَ مَاحنْذْ أَذْ غَارسْ إِنْذهْ مَارَّا نّعْڒثْ نِّي يُورِينْ ذڭْ وذْلِيسْ-أَ إِتّْوَانّْضنْ.  
\v 27 سِيذِي إِقْڒعْ إِ-ثنْ زِي ثمُّورْثْ ذڭْ وغْضَابْ ذ وسْعَارْ ذ ؤُذُوقّزْ \add ن وغْضَابْ\add* إِمْغَارْ ؤُشَا إِنْضَارْ إِ-ثنْ غَارْ ثمُّورْثْ نّغْنِي، أَمْ \add ثدْجَا\add* أَسّْ-أَ.‘  
\v 28 ثِيمسْڒَايِينْ إِنُّوفَارنْ أَقَا ثنْثْ إِ سِيذِي، أَربِّي نّغْ، مَاشَا \add ثِيمسْڒَايِينْ\add* تّْوَاسَّارڭْبنْثْ أَقَا ثنْثْ إِ نشِّينْ ؤُ إِ إِحنْجِيرنْ نّغْ إِ ڒبْذَا، مَاحنْذْ أَذْ نڭّْ مَارَّا أَوَاڒنْ ن شَّارِيعَا-يَا.“   
\b  
\b  
\m  
\c 30
\s1 أَقَارُّو ن ڒْعَاهْذْ  
\m
\v 1 ”خْمِي خَاكْ د غَا يَاسنْثْ مَارَّا ثْمسْڒَايِينْ-أَ، لْبَارَاكَا ذ نّعْڒثْ نِّي ڭِّيغْ زَّاثكْ، ؤُشَا أَذْ ثنْثْ ثَارّذْ غَارْ وُوڒْ \add نّشْ\add* جَارْ مَارَّا ڒڭْنُوسْ غَارْ مَانِي سِيذِي، أَربِّي نّشْ، خَاكْ يُوژّڒْ،  
\v 2 ؤُشَا أَذْ ثْعقْبذْ غَارْ سِيذِي، أَربِّي نّشْ، أَذْ ثسْڒذْ إِ ثْمِيجَّا نّسْ س مَارَّا ؤُڒْ نّشْ ؤُ س مَارَّا ڒعْمَارْ نّشْ أَنشْثْ ن مَارَّا مِينْ خْ شكْ ؤُمُورغْ أَسّْ-أَ، شكْ \add جْمِيعْ\add* أَكْ-ذ إِحنْجِيرنْ نّشْ،  
\v 3 \add خنِّي\add* سِيذِي، أَربِّي نّشْ، أَذْ إِبْضڒْ أَحبّسْ نّشْ ؤُشَا أَذْ خَاكْ يَارْحمْ ؤُشَا أَذْ شكْ إِسّْمُونْ زِي جَارْ مَارَّا ڒڭْنُوسْ غَارْ مَانِي شكْ إِبزّعْ سِيذِي، أَربِّي نّشْ. \x ◘ \xo 30:‏3 \xt نَاح. 1‏:‏8؛ إِزهد. 106‏:‏45؛ إِرْم. 32‏:‏37\x*  
\v 4 وَاخَّا إِنِّي خْ يُوژّْڒنْ زَّايكْ، أَقَا أَثنْ غَارْ ؤُنڭَّارُو ن ؤُجنَّا، أَقَا سِيذِي، أَربِّي نّشْ، أَذْ شكْ إِسّْمُونْ ؤُشَا أَذْ شكْ د-إِنْذهْ سّنِّي. \x ◘ \xo 30:‏4 \xt نَاح. 1‏:‏9\x*  
\v 5 سِيذِي، أَربِّي نّشْ، أَذْ شكْ إِسِّيذفْ غَارْ ثمُّورْثْ نِّي وَارْثنْ ڒجْذُوذْ نّشْ ؤُشَا أَذْ ت ثكْسِيذْ \add عَاوذْ\add* ذ ڒْوَارْثْ. نتَّا أَذْ ذَايكْ إِڭّْ ثْشُونِي ؤُ أَذْ ذَايكْ يَارْنِي \add عَاذْ\add* كْثَارْ زِي ڒجْذُوذْ نّشْ.  
\v 6 سِيذِي، أَربِّي نّشْ، أَذْ إِخْثنْ ؤُڒْ نّشْ ذ وُوڒْ ن ثَارْوَا نّشْ حِيمَا أَذْ ثخْسذْ سِيذِي، أَربِّي نّشْ، س مَارَّا ؤُڒْ نّشْ ذ مَارَّا ڒعْمَارْ نّشْ، حِيمَا أَذْ ثدَّارذْ.\x ◘ \xo 30:‏6 \xt أَعَوذ. 10‏:‏16؛ إِرْم. 32‏:‏39؛ حِز. 11‏:‏19؛ 36‏:‏26\x*  
\v 7 سِيذِي، أَربِّي نّشْ، أَذْ يَارّْ مَارَّا نّْعَاڒِي نِّي خْ ڒْعذْيَانْ نّشْ ؤُ خْ يِينِّي شكْ إِشَارّْهنْ، إِنِّي خَاكْ د-إِذَارّْشنْ \add عَاوذْ\add*.  
\v 8 أَذْ ثْعقْبذْ، أَذْ ثسْڒذْ إِ ثْمِيجَّا ن سِيذِي ؤُشَا أَذْ ثڭّذْ مَارَّا ڒُومُورَاثْ نِّي خفْ أَشْ تُّومُورغْ أَسّْ-أَ.  
\v 9 سِيذِي، أَربِّي نّشْ، أَذْ أَشْ إِوْشْ أَفيّضْ ذِي مَارَّا ڒْخذْمثْ ن إِفَاسّنْ نّشْ، ذِي ڒْغِيدْجثْ ن ؤُعذِّيسْ نّشْ، ذِي ڒْغِيدْجثْ ن ڒبْهَايمْ نّشْ ؤُ ذِي ڒْغِيدْجثْ ن ثمُّورْثْ نّشْ، \add أَيَا أَذْ يِيڒِي\add* إِ ڒْخَارْ نّشْ، مِينْزِي سِيذِي أَذْ إِعْقبْ حِيمَا أَذْ زَّايكْ إِفَارْحْ إِ ڒْخَارْ نّشْ، أَمْ مَامّشْ ثُوغَا إِفَارْحْ إِ ڒجْذُوذْ نّشْ، \x ◘ \xo 30:‏9 \xt أَعَوذ. 28‏:‏11\x*  
\v 10 خْمِي غَا ثسْڒذْ إِ ثْمِيجَّا ن سِيذِي، أَربِّي نّشْ حِيمَا أَذْ ثحْضِيذْ ڒُومُورَاثْ نّسْ ذ ثْوصَّا نّسْ، ثِينِّي يُورِينْ ذڭْ وذْلِيسْ-أَ إِتّْوَانْضنْ ن شَّارِيعَا ؤُشَا خْمِي د غَا ثْذوْڒذْ غَارْ سِيذِي، أَربِّي نّشْ، س مَارَّا ؤُڒْ نّشْ، س مَارَّا ڒعْمَارْ نّشْ.“   
\m
\v 11 ”مِينْزِي ڒُومُورْ-أَ إِ خْ شكْ تُّومُورغْ نشّْ أَسّْ-أَ، وَارْ إِدْجِي يُوعْڒَا خَاكْ ؤُ وَارْ إِڭّْوِيجْ شَا.  
\v 12 وَارْ إِدْجِي ذڭْ ؤُجنَّا، حِيمَا أَذْ ثِينِيذْ: ’وِي غَا إِڭعّْذنْ غَارْ ؤُجنَّا ذِي طّْوعْ نّغْ حِيمَا أَذْ أَنغْ ث-إِ-د-يَاوِي إِ نشِّينْ ؤُشَا أَذْ أَسْ نْسڒْ، \add حِيمَا\add* \add نْزمَّارْ\add* أَذْ زَّايسْ نڭّْ؟‘ \x ◘ \xo 30:‏12 \xt رُوم. 10‏:‏6‏-‏8\x*  
\v 13 وَارْ إِدْجِي خْ ؤُجمَّاضْ ن ڒبْحَارْ، أَڒَامِي \add غَا ثْزمَّارذْ\add* أَذْ ثِينِيذْ: ’وِي غَا إِژْوَانْ غَارْ ؤُجمَّاضْ ن ڒبْحَارْ حِيمَا أَذْ أَنغْ ث-إِ-د-يَاوِي إِ نشِّينْ ؤُشَا أَذْ أَسْ نْسڒْ، \add حِيمَا\add* نْزمَّارْ أَذْ زَّايسْ نڭّْ؟‘،  
\v 14 مِينْزِي أَوَاڒْ-أَ يُوذسْ إِ شكْ أَطَّاسْ، أَقَا-ث ذڭْ ؤُقمُّومْ نّشْ، أَقَا-ث ذڭْ وُوڒْ نّشْ، حِيمَا أَذْ زَّايسْ ثڭّذْ.“   
\m
\v 15 ”خْزَارْ، نشّْ ڭِّيغْ زَّاثكْ أَسّْ-أَ ثُوذَارْثْ ذ ڒْخَارْ ؤُڒَا ذ ڒْموْثْ ذ ڒْغَارْ،  
\v 16 مِينْزِي نشّْ تُّومُورغْ شكْ أَسّْ-أَ حِيمَا أَذْ ثخْسذْ سِيذِي، أَربِّي نّشْ، أَذْ ثُويُورذْ ذڭْ إِبْرِيذنْ نّسْ ؤُشَا أَذْ ثحْضِيذْ ڒُومُورَاثْ نّسْ ذ ثْوصَّا نّسْ ذ لْفَارَايِيضْ نّسْ مَاحنْذْ أَذْ ثدَّارذْ ؤُ أَذْ ثتّْوَامَّارْنِيذْ، ؤُشَا سِيذِي، أَربِّي نّشْ، أَذْ أَشْ إِبَاركْ ذِي ثمُّورْثْ نِّي غَارْ غَا ثَاذْفذْ حِيمَا أَذْ ت ثطّْفذْ ذ ڒْوَارْثْ.  
\v 17 \add مَاشَا\add* مَاڒَا ؤُڒْ نّشْ إِتَّاڭّْوجْ ؤُ وَارْ ثتّسْڒِيذْ ؤُشَا أَذْ ثتّْوَاسُّوفّْغذْ \add زڭْ وبْرِيذْ\add*، أَذْ ثْبنْذْقذْ زَّاثْ إِ إِربِّيثنْ نّغْنِي ؤُشَا أَذْ أَسنْ ثْعبْذذْ،  
\v 18 \add خنِّي\add* نشّْ تّْبَارّْحغْ أَومْ أَسّْ-أَ بلِّي س ثِيذتّْ أَذْ ثمّْثمْ. وَارْ ثَارنّْيذْ شَا ؤُسَّانْ نّشْ خْ ثمُّورْثْ مَانِي غَا ثَاذْفذْ أَوَارْنِي ڒَامِي ثژْوِيذْ لْ-ؤُرْذُونْ، حِيمَا أَذْ ت ثطّْفذْ ذ ڒْوَارْثْ.  
\v 19 أَسّْ-أَ نشّْ ڒَاغِيغْ خْ ؤُجنَّا ذ ثمُّورْثْ، مَاحنْذْ أَذْ إِڒِينْ ذ ڒشْهُوذْ خَاومْ: ڭِّيغْ زَّاثكْ ثُوذَارْثْ ذ ڒْموْثْ، لْبَارَاكَا ذ نّعْڒثْ! إِخْضَارْ \add خنِّي\add* ثُوذَارْثْ، حِيمَا أَذْ ثدَّارذْ، شكْ ذ زَّارِيعثْ نّشْ، \x ◘ \xo 30:‏19 \xt أَعَوذ. 4‏:‏26\x*  
\v 20 مَاحنْذْ أَذْ ثخْسذْ سِيذِي، أَربِّي نّشْ، ؤُشَا أَذْ ثسْڒذْ إِ ثْمِيجَّا نّسْ، أَذْ أَسْ ثْڒصْقذْ، مِينْزِي نتَّا ذ ثُوذَارْثْ نّشْ ؤُڒَا ذ ثُوزّڭَارْثْ ن وُوسَّانْ نّشْ، حِيمَا ثْزمَّارذْ أَذْ ثْزذْغذْ خْ ثمُّورْثْ نِّي خْ إِجُّودْجْ سِيذِي إِ ڒجْذُوذْ نّشْ أَذْ أَسنْ ت-إِ-د-إِوْشْ، إِ إِبْرَاهِيمْ ذ إِسْحَاقْ ذ يَاعْقُوبْ.“   
\b  
\b  
\m  
\c 31
\s1 يَاشُووَا إِكْسِي أَمْشَانْ ن مُوسَا  
\m
\v 1 إِرُوحْ مُوسَا ؤُشَا إِسِّيوڒْ س وَاوَاڒنْ-أَ أَكْ-ذ مَارَّا إِسْرَائِيل،  
\v 2 إِنَّا أَسنْ: ”أَسّْ-أَ نشّْ غَارِي مْيَا ؤُ-عِيشْرِينْ ن إِسڭّْوُوسَا. وَارْ زمَّارغْ عَاذْ أَذْ فّْغغْ ؤُڒَا أَذْ أَذْفغْ ؤُشَا سِيذِي إِنَّا أَيِي: ’وَارْ ثْژكّْوِيذْ \add إِغْزَارْ-أَ ن\add* لْ-ؤُرْذُونْ!‘ \x ◘ \xo 31:‏2 \xt ڒخْڒ. 27‏:‏12؛ أَعَوذ. 3‏:‏26\x*  
\v 3 سِيذِي، أَربِّي نّشْ، أَذْ إِژْوَا زَّاثْ إِ وُوذمْ نّشْ. نتَّا أَذْ يَاردّدْجْ ڒڭْنُوسْ-أَ زَّاثْ إِ وُوذمْ نّشْ ؤُشَا أَذْ ثطّْفذْ ڒْوَارْثْ نْسنْ. يَاشُووَا أَذْ إِژْوَا زَّاثْ إِ وُوذمْ نّشْ، أَمْ مَامّشْ إِنَّا سِيذِي. \x ◘ \xo 31:‏3 \xt ڒخْڒ. 27‏:‏18\x*  
\v 4 سِيذِي أَذْ كِيسنْ إِڭّْ أَمْ مَامّشْ إِڭَّا أَكْ-ذ سِيحُونْ ذ عُوجْ، إِجدْجِيذنْ ن إِمُورِييّنْ، إِنِّي يَاردّدْجْ نتَّا س ثْنَاينْ، ؤُ أَمْ مَامّشْ إِڭَّا أَكْ-ذ ثمُّورْثْ نْسنْ. \x ◘ \xo 31:‏4 \xt ڒخْڒ. 21‏:‏24، 33\x*  
\v 5 \add خْمِي\add* ثنْ غَا إِسلّمْ سِيذِي زَّاثْ إِ وُوذمْ نْومْ، أَذْ كِيسنْ ثڭّمْ عْلَاحْسَابْ مَارَّا ثَاوْصيّثْ نِّي زِي كنِّيوْ وصِّيغْ\x ◘ \xo 31:‏5 \xt أَعَوذ. 7‏:‏1، 2\x*  
\v 6 إِڒِيمْ ذ إِرْيَازنْ ؤُ إِڒِيمْ ثْمحْضمْ، وَارْ تّڭّْوذمْ، وَارْ تَّارْجِيجمْ شَا زَّاثْ إِ وُوذمْ نْسنْ، مِينْزِي سِيذِي، أَربِّي نّشْ، ذ ونِّي أَكِيذكْ إِڭُّورنْ. نتَّا وَارْ ذَايكْ إِسمّحْ نِيغْ شكْ إِتّجِّي.“ \x ◘ \xo 31:‏6 \xt ياش. 1‏:‏5؛ عبر. 13‏:‏5\x*   
\m
\v 7 إِڒَاغَا مُوسَا إِ يَاشُووَا، إِنَّا أَسْ زَّاثْ إِ ثِيطَّاوِينْ ن مَارَّا إِسْرَائِيل: ”إِڒِي ذ أَرْيَازْ ؤُ إِڒِي ثْمحْضذْ، مِينْزِي أَذْ ثَاذْفذْ أَكْ-ذ ڒْڭنْسْ-أَ غَارْ ثمُّورْثْ نِّي إِجُّودْجْ سِيذِي إِ ڒجْذُوذْ نْسنْ أَذْ أَسنْ ت-إِ-د-إِوْشْ ؤُشَا شكْ أَذْ ثنْ ثجّذْ أَذْ ت طّْفنْ ذ ڒْوَارْثْ.  
\v 8 سِيذِي، ذ ونِّي يُويُورنْ زَّاثْ إِ وُوذمْ نّشْ، ذ نتَّا إِ غَا يِيڒِينْ أَكِيذكْ، وَارْ شكْ إِتّتُّو شَا نِيغْ أَذْ ذَايكْ إِسْمحْ. وَارْ تّڭّْوذْ ؤُ وَارْ تَّارْجِيجِي.“ \x ◘ \xo 31:‏8 \xt ياش. 1‏:‏9\x*   
\b  
\m  
\s1 مُوسَا إِوْشَا شَّارِيعَا إِ أَيْثْ ن لَاوِي  
\m
\v 9 يُورَا مُوسَا شَّارِيعَا-يَا ؤُشَا إِوْشَا إِ-ت إِ إِكهَّاننْ، أَيْثْ ن لَاوِي، إِنِّي يَارْبُونْ تَّابُوثْ ن ڒْعَاهْذْ ن سِيذِي، ؤُ إِ مَارَّا إِمْغَارنْ ن إِسْرَائِيل.  
\v 10 مُوسَا يُومُورْ إِ-ثنْ، إِنَّا: ”أَوَارْنِي سبْعَا ن إِسڭّْوُوسَا، ذِي ڒْوقْثْ إِتّْوَاڭّنْ ن ؤُسڭّْوَاسْ ن ؤُفكِّي ن إِمرْوُوسنْ ذِي ڒْعِيذْ ن إِعُوشُّوثنْ،  
\v 11 خْمِي غَا إِمُونْ مَارَّا إِسْرَائِيل مَاحنْذْ أَذْ إِحْضَارْ زَّاثْ إِ وُوذمْ ن سِيذِي، أَربِّي نّشْ، ذڭْ ومْشَانْ نِّي إِ غَا يِيخْضَارْ نتَّا، أَذْ ثْغَارذْ س جّهْذْ شَّارِيعَا-يَا زَّاثْ إِ مَارَّا إِسْرَائِيل ذڭْ إِمزُّوغنْ نْسنْ. \x ◘ \xo 31:‏11 \xt عِز. 8\x*  
\v 12 أجّْ أَذْ إِمُونْ ڒْڭنْسْ، إِرْيَازنْ ذ ثمْغَارِينْ ذ إِحنْجِيرنْ ذ إِبَارَّانِييّنْ نِّي إِدْجَانْ غَارْ ذَاخڒْ ن ثوُّورَا نّشْ حِيمَا أَذْ سْڒنْ ؤُ حِيمَا أَذْ ڒمْذنْ أَذْ ڭّْوذنْ سِيذِي، أَربِّي نْومْ ؤُشَا أَذْ حْضَانْ مَارَّا أَوَاڒنْ ن شَّارِيعَا-يَا  
\v 13 ؤُ حِيمَا إِحنْجِيرنْ نْسنْ، إِنِّي وَارْ ت إِسِّيننْ، أَذْ سْڒنْ ؤُشَا أَذْ ڒمْذنْ أَذْ ڭّْوذنْ سِيذِي، أَربِّي نْومْ مَارَّا ؤُسَّانْ نِّي إِ غَا ثدَّارمْ خْ وُوذمْ \add ن ثمُّورْثْ\add* نِّي غَارْ غَا ثژْوَامْ خْ لْ-ؤُرْذُونْ مَاحنْذْ أَذْ ت ثطّْفمْ ذ ڒْوَارْثْ.“   
\b  
\m  
\s1 أَبَارّحْ خْ ڒْمُوعْصِييّثْ إِ د غَا يَاسنْ  
\m
\v 14 سِيذِي إِنَّا إِ مُوسَا: ”أَقَا إِوْضنْ-د وُوسَّانْ نّشْ إِ ذِي غَا ثمّْثذْ. ڒَاغَا إِ يَاشُووَا ؤُ سْبدّمْ إِخفْ نْومْ ذڭْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ حِيمَا أَذْ ث ؤُمُورغْ.“ مُوسَا ذ يَاشُووَا رُوحنْ، بدّنْ ذڭْ ؤُقِيضُونْ ن ؤُمْسَاڭَارْ.  
\v 15 \add خنِّي\add* إِبَانْ-د سِيذِي ذڭْ ؤُقِيضُونْ، ذڭْ إِجّْ ن ؤُقلِّيجْ ن ؤُسيْنُو، ؤُشَا إِبدّْ ؤُقلِّيجْ ن ؤُسيْنُو سنّجْ إِ وَاذَافْ ن ؤُقِيضُونْ.  
\v 16 سِيذِي إِنَّا إِ مُوسَا: ”أَقَا شكْ أَذْ ثتّْوَاسّْمُونذْ أَكْ-ذ ڒجْذُوذْ نّشْ ؤُشَا \add خنِّي\add* ڒْڭنْسْ-أَ أَذْ إِكَّارْ أَذْ إِسّفْسذْ إِخفْ نّسْ أَمْ غَا يُويُورْ أَوَارْنِي إِ إِربِّيثنْ ن إِبَارَّانِييّنْ ن ثمُّورْثْ نِّي غَارْ غَا يَاذفْ \add ڒْڭنْسْ\add* أَڒْ ڒْوسْطْ نّسْ ؤُشَا \add ڒْڭنْسْ\add* أَذْ ذَايِي إِسْمحْ، أَذْ يَارْژْ ڒْعَاهْذْ إِنُو ونِّي كِيذْسنْ ڭِّيغْ.  
\v 17 ذڭْ وَاسّْ نِّي أَذْ يَارغْ وغْضَابْ إِنُو خْ \add ڒْْڭنْسْ\add* ؤُشَا أَذْ ثنْ جّغْ، أَذْ زَّايْسنْ فَّارغْ ؤُذمْ إِنُو ؤُشَا أَذْ إِتّْوَاصَارْضْ \add ڒْْڭنْسْ\add* ؤُشَا أَذْ خَاسْ د-أَسنْ وَاطَّاسْ ن إِشڒْوَاونْ ذ ڒحْصَارَاثْ، أَڒْ غَا يِينِي \add ڒْْڭنْسْ\add* ذڭْ وَاسّْ نِّي: ’مَا وَارْ خَافِي د-ؤُسِينْ إِشڒْوَاونْ-أَ، مِينْزِي أَربِّي وَارْ كِيذِي إِدْجِي؟‘ \f ◼ \fr 31:‏17 \ft \+bd ’وَارْ كِيذِي إِدْجِي‘\+bd* - س ثْعِيبْرَانِيثْ ’وَارْ إِدْجِي ذِي ڒْوسْثْ إِنُو‘.\f*  
\v 18 ذڭْ وَاسّْ نِّي أَذْ فَّارغْ ؤُذمْ إِنُو مَارَّا ذِي سِّيبّثْ ن ڒْغَارْ نِّي إِڭَّا ؤُمِي إِذْوڒْ غَارْ إِربِّيثنْ نّغْنِي.  
\v 19 ڒخُّو خنِّي، أَرِي ثِيزْڒِيثْ-أَ إِ يِيخفْ نْومْ ؤُشَا سڒْمذْ إِ-ت إِ أَيْثْ ن إِسْرَائِيل، أڭّْ إِ-ت ذڭْ ؤُقمُّومْ نْسنْ، حِيمَا ثِيزْڒِيثْ-أَ أَذْ ثِيڒِي ذ أَشهَّاذْ ذِي طّْوعْ إِنُو ضِيدّْ إِ إِسْرَائِيل،  
\v 20 مِينْزِي نشّْ أَذْ سِّيذْفغْ ڒْڭنْسْ-أَ غَارْ ثمُّورْثْ نِّي خْ جُّودْجغْ إِ ڒجْذُوذْ نْسنْ \add أَذْ أَسنْ ت وْشغْ\add*، \add إِشْثْ ن ثمُّورْثْ\add* إِفيّْضنْ س ؤُغِي ذ ثَامّنْثْ، ؤُشَا أَذْ شّنْ، أَذْ جِّيوْننْ، أَذْ ذوْڒنْ قْبُوبّْزنْ. \add خنِّي\add* أَذْ ذوْڒنْ غَارْ إِربِّيثنْ نّغْنِي، أَذْ خَاسنْ سخَّارنْ ؤُشَا أَذْ أَيِي سّْذُوقْزنْ، أَذْ أَرْژنْ ڒْعَاهْذْ إِنُو.  
\v 21 ؤُشَا أَذْ إِمْسَارْ ؤُمِي ذ أَسْ د-ؤُسِينْ \add إِ ڒْڭنْسْ-أَ\add* أَطَّاسْ ن إِشڒْوَاونْ ذ ڒحْصَارَاثْ، أَقَا \add خنِّي\add* إِزْڒِي-يَا أَذْ د-ثَارّْ ذڭْ وُوذمْ نّسْ أَمْ يِيجّْ ن ؤُشهَّاذْ، مِينْزِي وَارْ ثتِّيڒِي ثتّْوَاتُّو زڭْ ؤُقمُّومْ ن ثَارْوَا نّسْ، مِينْزِي نشّْ سّْنغْ أَخَارّصْ نِّي إِحطَّا \add عَاذْ\add* أَسّْ-أَ \add ذِي ذَاخڒْ نّسْ\add*، قْبڒْ مَا أَذْ ث سِّيذْفغْ ذِي ثمُّورْثْ نِّي خْ جُّودْجغْ \add أَذْ أَسنْ ت وْشغْ\add*.“ \f ◼ \fr 31:‏21 \ft \+bd ’ثَارْوَا‘\+bd* - س ثْعِيبْرَانِيثْ ’زَاأَذْ‘.\f*   
\m
\v 22 ذڭْ وَاسّْ نِّي يُورَا مُوسَا ثِيزْڒِيثْ-أَ ؤُشَا إِسّڒْمذْ إِ-ت إِ أَيْثْ ن إِسْرَائِيل.  
\v 23 ؤُشَا نتَّا يُومُورْ إِ يَاشُووَا، مِّيسْ ن نُونْ، إِنَّا: ”إِڒِي ذ أَرْيَازْ، إِڒِي ثْمحْضذْ، مِينْزِي أَذْ ثسِّيذْفذْ أَيْثْ ن إِسْرَائِيل ذِي ثمُّورْثْ نِّي خْ ذ أَسنْ جُّودْجغْ \add مَاحنْذْ أَذْ أَسنْ ت وْشغْ\add* ؤُشَا نشّْ أَذْ أَكِيذكْ إِڒِيغْ.“ \x ◘ \xo 31:‏23 \xt ياش. 1‏:‏6\x*   
\m
\v 24 ؤُشَا إِمْسَارْ ؤُمِي إِكمّڒْ مُوسَا ثِيرَا ن وَاوَاڒنْ ن شَّارِيعَا-يَا ذڭْ إِجّْ ن وذْلِيسْ إِتّْوَانّْضنْ، أَڒْ أَنڭَّارْ نْسنْ،  
\v 25 أَقَا مُوسَا يُومُورْ إِلَاوِييّنْ نِّي يَارْبُونْ تَّابُوثْ ن ڒْعَاهْذْ ن سِيذِي، إِنَّا:  
\v 26 ”كْسِيمْ أَذْلِيسْ-أَ إِتّْوَانْضنْ ن شَّارِيعَا ؤُشَا ثڭّمْ ث زَّاثْ إِ تَّابُوثْ ن ڒْعَاهْذْ ن سِيذِي، أَربِّي نْومْ، مَاحنْذْ أَذْ ذِينْ يِيڒِي ذ أَشهَّاذْ ضِيدّْ نْومْ، \x ◘ \xo 31:‏26 \xt 2 إِج. 22‏:‏8\x*  
\v 27 مِينْزِي نشّْ سّْنغْ أَغوّغْ نْومْ ذ ثْغنَّانْثْ نْومْ. خْزَارْ، ؤُمِي نشّْ دَّارغْ عَاذْ أَكِيذْومْ أَسّْ-أَ، كنِّيوْ أَقَا ثْغوّْغمْ خْ سِيذِي، مشْحَاڒْ عَاذْ كْثَارْ إِ غَا ثڭّمْ أَوَارْنِي إِ ڒْموْثْ إِنُو!  
\v 28 سْمُونمْ-د غَارِي مَارَّا إِمْغَارنْ ن ثْقبَّاڒْ نْومْ ذ إِمحْضَاينْ نْومْ، \add خنِّي\add* أَذْ سِّيوْڒغْ أَوَاڒنْ-أَ ذڭْ إِمزُّوغنْ نْسنْ ؤُشَا أَذْ ڭّغْ أَجنَّا ذ ثمُّورْثْ ذ ڒشْهُوذْ ضِيدّْ نْسنْ.  
\v 29 مِينْزِي نشّْ سّْنغْ أَقَا أَوَارْنِي ڒْموْثْ إِنُو أَذْ ثْفسْذمْ أَڒْ طَّارْفْ ؤُشَا أَذْ ثفّْغمْ خْ وبْرِيذْ نِّي خْ كنِّيوْ ؤُمُورغْ. ذڭْ ؤُنڭَّارْ ن وُوسَّانْ، أَذْ ثڭّمْ ڒْغَارْ ذِي ثِيطَّاوِينْ ن سِيذِي أَڒْ غَا ث ثسْعَارمْ س ڒْخذْمثْ إِ ثڭِّيمْ س إِفَاسّنْ نْومْ.“   
\m
\v 30 \add خنِّي\add* إِسِّيوڒْ مُوسَا ذڭْ إِمزُّوغنْ ن مَارَّا أَڭْرَاوْ \add ن ڒْڭنْسْ\add* ن إِسْرَائِيل س وَاوَاڒنْ ن ثِيزْڒِيثْ-أَ أَڒَامِي ثنْ إِكمّڒْ.   
\b  
\b  
\m  
\c 32
\s1 إِزْڒِي ن مُوسَا  
\m
\v 1 ”سْڒمْ، \add أَ\add* إِجنْوَانْ، أَذْ سِّيوْڒغْ!  
\m أجّْ ثَامُّورْثْ أَذْ ثْسڒْ  
\m إِ وَاوَاڒنْ ن ؤُقمُّومْ إِنُو!   
\m
\v 2 أجّْ ثَاغُورِي إِنُو أَذْ ثُوذمْ أَمْ ونْژَارْ،  
\m أَذْ هْوَانْثْ ثِيوَاڒِينْ إِنُو أَمْ نّْذَا،  
\m أَمْ إِشْثْ ن ثْهِيضُورْثْ خْ ؤُغمُّويْ أَزِيزَا  
\m ؤُ أَمْ ثْنشْنَاشِينْ خْ وفْسُو،   
\m
\v 3 مِينْزِي نشّْ أَذْ بَارّْحغْ إِسمْ ن سِيذِي،  
\m أَرّمْ-د ڒمْغَارثْ إِ أَربِّي نّغْ!   
\m
\v 4 \add نتَّا\add* ذ ثَاصْضَارْثْ، ڒْخذْمثْ نّسْ نِيشَانْ،  
\m مِينْزِي مَارَّا إِبْرِيذنْ نّسْ تّْوَاسڭّْذنْ،  
\m إِجّْ ن أَربِّي ذ أَمْثِيقِّي بْڒَا ڒْغشّْ،  
\m أَقَا-ث ذ أَمْسڭّذْ، نِيشَانْ إِ يدْجَا.   
\m
\v 5 \add ڒْْڭنْسْ\add* أَقَا إِسّفْسذْ إِخفْ نّسْ،  
\m نِيثْنِي وَارْ دْجِينْ شَا ذ إِحنْجِيرنْ نّسْ،  
\m \add مَاشَا\add* ذ ڒفْضِيحثْ،  
\m \add أَقَا-ث\add* ذ إِجّْ ن جِّيڒْ إِفَارْغْ، إِخْنُونّسْ.   
\m
\v 6 مَا ثخْسمْ أَذْ ثڭّمْ أَيَا إِ سِيذِي،  
\m \add أَ\add* ڒْڭنْسْ أَبُوهَاڒِي ذ وفْغُورْ!  
\m مَا وَارْ إِدْجِي نتَّا ذ بَابَاشْ نِّي شكْ إِسْغِينْ،  
\m ذ ونِّي شكْ إِڭِّينْ  
\m ؤُ ذ ونِّي شكْ إِكوّْننْ؟   
\m
\v 7 إِذَارمْ ؤُسَّانْ إِعْذُونْ،  
\m خمّمْ إِسڭّْوُوسَا ن جِّيڒْ أَڒْ جِّيڒْ،  
\m سقْسَا بَابَاشْ ؤُ نتَّا أَذْ أَشْ ث إِعَاوذْ  
\m \add سقْسَا\add* إِمْغَارنْ ؤُ نِيثْنِي أَذْ أَشْ ث إِنِينْ.   
\m
\v 8 ؤُمِي إِوْشَا ؤُمْعُودْجِي خْ كُوڒْشِي  
\m ثَاسْغَارْثْ \add نْسنْ\add* إِ مَارَّا ڒڭْنُوسْ،  
\m ؤُمِي إِبْضَا ثَارْوَا ن بْنَاذمْ،  
\m إِسّْڭعّذْ إِيْمِيرنْ ن ڒڭْنُوسْ  
\m عْلَاحْسَابْ ڒْقدّْ ن أَيْثْ ن إِسْرَائِيل.   
\m
\v 9 مِينْزِي ثَاسْغَارْثْ ن سِيذِي ذ ڒْڭنْسْ نّسْ،  
\m يَاعْقُوبْ ذ أَفِيڒُو \add ن ڒعْبَارْ\add* ن ثسْغَارْثْ نّسْ.   
\m
\v 10 يُوفَا إِ-ث ذِي ثمُّورْثْ ن ڒخْڒَا،  
\m ذِي ثْنزْرُوفْثْ إِخْڒَانْ \add أَكْ-ذ ڒوْحُوشْ\add*  
\m إِتّْزُونْ، إِسّْغُويُّونْ.  
\m إِنّضْ أَسْ-د، إِسّڒْمذْ إِ-ث،  
\m إِحْضَا إِ-ث أَمْ مُومُّو ن ثِيطّْ نّسْ.   
\m
\v 11 أَمْ ؤُڭِيذرْ نِّي إِسّْفَاقنْ ڒْعُوشّْ نّسْ،  
\m إِطَّاوْ سنّجْ إِ وَارُّوذْ نّسْ زِي سَّا غَارْ ذَا،  
\m إِتّْبزّعْ أَفْرِيونْ نّسْ،  
\m إِكْسِي إِ-ث ؤُشَا يَاربُّو ث خْ وَافْرِيونْ نّسْ،   
\m
\v 12 \add أَمُّو\add* إِ إِنْذهْ إِ-ث سِيذِي وَاهَا  
\m ؤُشَا وَارْ ثُوغِي ذِينْ أَكِيذسْ  
\m شَا ن أَربِّي ذ أَغْرِيبْ.   
\m
\v 13 إِسّنْيَا إِ-ث خْ ثْعُوڒَاڒْ ن ثمُّورْثْ  
\m ؤُشَا إِشَّا ڒْغِيدْجثْ ن ييَّارْ.  
\m إِجَّا إِ-ث أَذْ إِژمّْ ثَامّنْثْ زِي جَّارْفْ،  
\m ذ زّشْثْ زڭْ وژْرُو ن ثصْضَارْثْ، \x ◘ \xo 32:‏13 \xt أَعَوذ. 33‏:‏26، إِشا. 58‏:‏14\x*   
\m
\v 14 ذ ثْرُوسِّي ن ثْفُونَاسِينْ ذ ؤُغِي ن وُودْجِي  
\m س ثَاذُونْثْ ن إِزْمَارنْ ذ إِشَارِّييّنْ،  
\m \add إِنِّي إِدْجَانْ أَمْ\add* ثَارْوَا ن بَاشَانْ،  
\m \add ؤُ س ثَاذُونْثْ ن\add* إِغَايْضنْ،  
\m س مُومُّو ن وَارنْ ن إِرْذنْ.  
\m \add عَاوذْ\add* شكْ ثسْوِيذْ زڭْ إِذَامّنْ ن ؤُضِيڒْ،  
\m أَكْ-ذ ؤُكُوفُّو نّسْ خَاسْ.   
\b  
\m
\v 15 إِذْوڒْ يَاشُورُونْ إِقْبُوبّزْ  
\m ؤُشَا إِژّعْبضْ  
\m - ’أَقَا ثْمسْڒذْ ؤُ ثقْبُوبّْزذْ،  
\m وَاهْ، س ثَاذُونْثْ ثتّْوَاذْڒذْ!‘ -  
\m ؤُشَا إِسْمحْ ذِي أَربِّي  
\m نِّي إِ-ث د-إِخڒْقنْ  
\m ؤُشَا إِسّحْقَارْ ثَاصْضَارْثْ ن ؤُسنْجمْ نّسْ.   
\m
\v 16 س إِربِّيثنْ إِغْرِيبنْ  
\m سّكَّارنْ نِيثْنِي ثُوسْمِي نّسْ،  
\m س جّْعَايفْ سْعَارنْ ث.   
\m
\v 17 نِيثْنِي قدّْمنْ ثِيغَارْصَا إِ شّْوَاطنْ،  
\m وَارْ إِدْجِي إِ أَربِّي،  
\m إِ إِربِّيثنْ نِّي وَارْ سِّيننْ،  
\m \add إِربِّيثنْ\add* ن جْذِيذْ،  
\m إِنِّي د-يُوسِينْ عَاذْ مَامّشْ،  
\m وَارْ زَّايْسنْ تَّارْجِيجنْ ڒجْذُوذْ نْومْ.   
\m
\v 18 ثَاصْضَارْثْ نِّي إِ شكْ د-يجِّينْ،  
\m ثْسمْحذْ ذَايسْ  
\m ؤُ ثتُّوذْ أَربِّي  
\m نِّي إِ شكْ د-يُورْونْ س ڒوْجعْ.   
\b  
\m
\v 19 إِژْرَا سِيذِي \add مَانْ أَيَا\add* ؤُشَا إِسّهْقَارْ إِ-ثنْ،  
\m زِي سِّيبّثْ ن ؤُسْذُوقّزْ  
\m ن إِحنْجِيرنْ نّسْ ذ يسِّيسْ.   
\m
\v 20 نتَّا إِنَّا:  
\m ’أَذْ زَّايْسنْ فَّارغْ ؤُذمْ إِنُو،  
\m أَذْ ژَترغْ مَامّشْ غَا يِيڒِي  
\m \add زّْمَانْ\add* ؤُنڭَّارُو نْسنْ،  
\m مِينْزِي نِيثْنِي ذ إِجّْ ن جِّيڒْ إِتّْنقْڒَابْ،  
\m ذ ثَارْوَا إِ ذِي وَارْ إِدْجِي ڒْمَانثْ.   
\m
\v 21 نِيثْنِي سّكَّارنْ ثُوسْمِي إِنُو  
\m س مِينْ وَارْ إِدْجِينْ ذ أَربِّي،  
\m سْعَارنْ أَيِي س \add لْ-أَصْنَامْ\add* نْسنْ إِبطّْڒنْ.  
\m نشّْ أَذْ سّكَّارغْ ثُوسْمِي نْسنْ  
\m س \add مِينْ\add* وَارْ إِدْجِينْ ذ ڒْڭنْسْ،  
\m س يِيجّْ ن ڒْڭنْسْ ذ أَبُوهَاڒِي أَذْ ثنْ سْعَارغْ. \x ◘ \xo 32:‏21 \xt رُوم. 10‏:‏19\x*   
\m
\v 22 مِينْزِي س وغْضَابْ إِنُو ثكَّارْ ثْمسِّي،  
\m أَذْ ثشْمضْ أَڒْ ڒَاخَارْثْ \add ذِينْ\add* سْوَادَّايْ،  
\m ؤُشَا أَذْ ثشّْ ثَامُّورْثْ ذ ڒْغِيدْجثْ نّسْ،  
\m ؤُ أَذْ ثسّشْمضْ ثِيسِي ن إِذُورَارْ. \x ◘ \xo 32:‏22 \xt إِرْم. 15‏:‏14\x*   
\m
\v 23 نشّْ أَذْ أَسنْ أَرْنِيغْ إِشڒْوَاونْ،  
\m أَذْ خَاسنْ نيّْشغْ فْڒِيثْشَاثْ إِنُو.   
\m
\v 24 أَذْ تّْوَاهيّْفنْ س ڒَاژْ  
\m ؤُشَا أَذْ تّْوَاصَارْضنْ س طَّاعُونْ  
\m ؤُ س وَاردّدْجْ أَمرْزَاڭْ  
\m ؤُ نشّْ أَذْ ذَايْسنْ سّكّغْ  
\m ثِيغْمَاسْ ن ڒْمَاڒْ  
\m س سّمْ إِنقّنْ ن \add إِفِيغْرَانْ\add*  
\m إِنِّي إِتّْمُودْجُوغنْ ذِي ثْعجَّاجْثْ.   
\m
\v 25 زِي بَارَّا أَذْ إِكّسْ سِّيفْ \add ثَارَّاوْثْ\add*،  
\m ؤُ زڭْ وخَّامْ ن ذَاخڒْ  
\m \add أَذْ ثڒْقفْ\add* ثِيڭّْوُوذِي:  
\m أَمْ ؤُبْڒِيغْ أَمْ ثعْزَارشْثْ،  
\m أَسيْمِي أَكْ-ذ ؤُمشَّايْبُو.   
\b  
\m
\v 26 ثُوغَا خْسغْ أَذْ إِنِيغْ:  
\m ’أَمْ ؤُسمِّيضْ أَذْ ثنْ فَارثْكغْ،  
\m أَذْ سّْبدّغْ ڒِيذَارثْ نْسنْ جَارْ إِوْذَانْ!‘،   
\m
\v 27 مْڒِي وَارْ دْجِيغْ تّڭّْوِيذغْ  
\m زڭْ وسْعَارْ ن ڒعْذُو،  
\m حِيمَا إِغْرِيمنْ نْسنْ وَارْ ث نكَّارنْ  
\m ؤُشَا أَذْ إِنِينْ:  
\m ’إِفَاسّنْ نّغْ،  
\m إِنِّي إِتّْوَاسّْڭعّْذنْ أَمُّو \add س جّهْذْ\add*،  
\m ڭِّينْ أَيَا مَارَّا، \add وَارْ إِدْجِي\add* ذ سِيذِي.‘   
\m
\v 28 مِينْزِي نِيثْنِي ذ إِجّْ ن ڒْڭنْسْ بْڒَا أَرَّايْ  
\m ؤُ وَارْ ذَايْسنْ ڒفْهَامثْ.   
\m
\v 29 مْڒِي ڭِّينْ ثِيغِيثْ،  
\m \add خنِّي\add* إِڭُّورْ أَذْ فهْمنْ أَيَا  
\m ؤُ أَذْ وْشنْ ثَايْنِيثْ إِ ؤُنڭَّارْ نْسنْ.   
\m
\v 30 مَامّشْ إِزمَّارْ أَذْ إِضْفَارْ  
\m إِجّْ \add ن بْنَاذمْ\add* أَڒفْ \add ن إِوْذَانْ\add*  
\m ؤُ \add مَامّشْ زمَّارنْ\add* ثْنَاينْ  
\m أَذْ أَرّنْعشْرَا-أَڒَافْ أَذْ أَروْڒنْ،  
\m مَاڒَا وَارْ ذ أَسنْ ثمّنْزْ ثصْضَارْثْ نْسنْ  
\m ؤُشَا \add وَارْ ذ أَسنْ\add* إِسلّمْ سِيذِي إِ نِيثْنِي؟   
\m
\v 31 مِينْزِي ثَاصْضَارْثْ نْسنْ  
\m وَارْ ثدْجِي أَمْ ثَاصْضَارْثْ نّغْ.  
\m أجّْ أَذْ حكْمنْ ڒْعذْيَانْ نّغْ \add س إِخفْ نْسنْ\add*.   
\b  
\m
\v 32 مِينْزِي ثَازَايَارْثْ نْسنْ  
\m \add ثدْجَا\add* زِي ثْزَايَارْثْ ن سَاذُومْ  
\m ؤُ زڭْ إِيَّارنْ ن عَامُورَّا.  
\m أَضِيڒْ نْسنْ ذ أَضِيڒْ ن سّمْ،  
\m غَارْسنْ إِزكُّوننْ \add شُّورنْ س\add* ثَارْزُوڭِي. \f ◼ \fr 32:‏32 \ft \+bd ’ثَازَايَارْثْ‘\+bd* - نِيغْ ’ضِيڒشْثْ‘.\f*   
\m
\v 33 بِينُو نْسنْ  
\m \add أَمشْنَاوْ أَسُوضِي ن\add* ثْمسِّي ن ڒْهَايْشَاثْ،  
\m \add أَمشْنَاوْ\add* سّمْ إِنقّنْ ن ثْڒفْسِيوِينْ.   
\m
\v 34 مَا \add مَارَّا\add* أَيَا وَارْ غَارِي إِتّْوَاخْزنْ،  
\m إِتّْوَاشمّعْ ذڭْ إِخَّامنْ ن ثْخُوبَايْ إِنُو؟   
\m
\v 35 ذ نشّْ إِ يدْجَانْ خْ نّقْمثْ ذ ڒخْڒَاصْ،  
\m خْمِي غَا إِحْڒُودْجضْ ؤُضَارْ نْسنْ.  
\m أَسّْ ن ؤُضيّعْ نْسنْ أَقَا يُوذسْ،  
\m ؤُشَا مِينْ خَاسنْ إِ غَا يِيڒِي، أَذْ إِمْسَارْ ذغْيَا. \x ◘ \xo 32:‏35 \xt رُوم. 12‏:‏19؛ عبر. 10‏:‏30؛ 1 بُط. 2‏:‏23\x*   
\b  
\m
\v 36 مِينْزِي سِيذِي أَذْ إِڭّْ س ڒْحقّْ  
\m ذِي طّْوعْ ن ڒْڭنْسْ نّسْ،  
\m نتَّا أَذْ إِحنّْ خْ إِمْسخَّارنْ نّسْ  
\m خْمِي غَا إِژَارْ بلِّي جّهْذْ إِمّكْسِي،  
\m ؤُشَا وَارْ ذِينْ إِقِّيمْ \add عَاذْ\add*  
\m ونِّي إِتّْوَاطّْفنْ ذ ونِّي إِجِّينْ. \f ◼ \fr 32:‏36 \ft \+bd ’جّهْذْ‘\+bd* - س ثْعِيبْرَانِيثْ ’أَفُوسْ‘ ونِّي ذ ڒعْڒَامثْ ن جّهْذْ ذ ثْزمَّارْ ن بْنَاذمْ.\f*  \x ◘ \xo 32:‏36 \xt إِزهد. 135‏:‏14؛ إِزهد. 90‏:‏13\x*   
\m
\v 37 \add خنِّي\add* أَذْ يِينِي:  
\m ’مَانِي دْجَانْ إِربِّيثنْ نْسنْ،  
\m \add مَانِي\add* ثَاصْضَارْثْ إِ غَارسْ ؤُفِينْ أَذُورِّي؟   
\m
\v 38 \add مَانِي دْجَانْ إِربِّيثنْ\add* نِّي زِي  
\m شِّينْ ثَاذُونْثْ ن ثْغَارْصَا نْسنْ،  
\m إِنِّي زِي سسّنْ بِينُو  
\m ن ثوْهِيبِينْ ن ؤُسيّبْ نْسنْ؟  
\m أجّْ إِ-ثنْ أَذْ كَّارنْ، أَذْ شكْ عَاوْننْ  
\m ؤُ أجّْ إِ-ث أَذْ خَاومْ إِسّْذُورِي.‘   
\b  
\m
\v 39 خْزَارمْ ڒخُّو،  
\m أَقَا ذ \bd نشّْ، \+bdit وَاهْ\+bdit* ذ نشّْ\bd*،  
\m ؤُ وَارْ \add ذِينْ\add* شَا ؤُڒَا ذ إِجّْ ن أَربِّي أَكِيذِي.  
\m نشّْ نقّغْ ؤُ نشّْ سّدَّارغْ،  
\m نشّْ ڒبّْزغْ ؤُ سّْڭنْفِيغْ  
\m ؤُ وَارْ ذِينْ وِي غَا إِفكّنْ زڭْ ؤُفُوسْ إِنُو. \x ◘ \xo 32:‏39 \xt أَعَوذ. 4‏:‏35؛ 1 صم. 2‏:‏6؛ إِشا. 45‏:‏5، 18، 22\x*   
\m
\v 40 مِينْزِي نشّْ أَذْ سّْوِيژّْضغْ أَفُوسْ إِنُو  
\m غَارْ ؤُجنَّا،  
\m أَذْ إِنِيغْ: ’نشّْ أَقَا دَّارغْ إِ ڒبْذَا!‘   
\m
\v 41 مَاڒَا سّْقضْعغْ سِّيفْ إِنُو إِتّْوسّْڭنْ  
\m ؤُشَا أَفُوسْ إِنُو أَذْ إِطّفْ ذِي ڒْحُوكْمْ،  
\m \add خنِّي\add* نشّْ أَذْ نْثَاقْمغْ زِي إِغْرِيمنْ إِنُو  
\m ؤُ زڭْ إِنِّي ذ أَيِي إِشَارّْهنْ.   
\m
\v 42 أَذْ سّسْشَارغْ فْڒِيثْشَاثْ \add ن ڒْقوْسْ إِنُو\add*  
\m س إِذَامّنْ،  
\m ؤُشَا سِّيفْ إِنُو أَذْ إِسَارْضْ أَيْسُومْ،  
\m إِذَامّنْ ن ونِّي إِتّْوَانْغنْ  
\m ؤُ ن ونِّي إِتّْوَاحبّْسنْ  
\m أَزدْجِيفْ ن ڒعْذُو  
\m أَكْ-ذ \add إِجطَّاينْ ن\add* ؤُشُوَّافْ نّسْ. \x ◘ \xo 32:‏42 \xt إِزهد. 68‏:‏22 \x*   
\m
\v 43 سْڒِيوْڒومْ، \add أَ\add* ڒڭْنُوسْ!، \add أَكْ-ذ\add* ڒْڭنْسْ نّسْ،  
\m مِينْزِي نتَّا أَذْ إِنْثَاقمْ  
\m إِ إِذَامّنْ ن إِمْسخَّارنْ نّسْ،  
\m أَذْ يَارَّا نّقْمثْ خْ إِغْرِيمنْ نّسْ،  
\m ؤُشَا أَذْ إِڭّْ وصْڒَاحْ  
\m إِ ثمُّورْثْ نّسْ ذ ڒْڭنْسْ نّسْ.“ \f ◼ \fr 32:‏43 \ft \+bd ’إِڭّْ وصْرَاحْ‘\+bd* - خْزَارْ إِزهد. 78:35: إِفْذِي، أَمفْذِي.\f*  \x ◘ \xo 32:‏43 \xt رُوم. 15‏:‏10\x*   
\b  
\m
\v 44 يُوسَا-د مُوسَا ؤُشَا إِسِّيوڒْ مَارَّا أَوَاڒنْ ن ثِيزْڒِيثْ-أَ خْ إِمزُّوغنْ ن ڒْڭنْسْ، نتَّا \add جْمِيعْ أَكْ-ذ\add* هُوشِيعَا، مِّيسْ ن نُونْ. \f ◼ \fr 32:‏44 \ft \+bd ’هُوشِيعَا‘\+bd* - إِجّْ ن يِيسمْ نّغْنِي إِ يَاشُووَا.\f*  
\v 45 \add ؤُمِي\add* إِكمّڒْ مُوسَا مَارَّا أَوَاڒنْ-أَ إِ زِي إِسِّيوڒْ غَارْ مَارَّا إِسْرَائِيل،  
\v 46 إِنَّا أَسنْ: ”أَرّمْ مَارَّا أَوَاڒنْ-أَ نِّي خْ ذ أَومْ نِّيغْ أَسّْ-أَ غَارْ وُوڒْ نْومْ، حِيمَا أَذْ ثنْ ثُومُورمْ إِ إِحنْجِيرنْ نْومْ مَاحنْذْ أَذْ حْضَانْ مَارَّا أَوَاڒنْ ن شَّارِيعَا-يَا أَذْ زَّايْسنْ ڭّنْ،  
\v 47 مِينْزِي وَارْ إِدْجِي ذ أَوَاڒْ ن بَاطڒْ إِ كنِّيوْ، مَاشَا ذ ثُوذَارْثْ نْومْ. س وَاوَاڒْ-أَ أَذْ ثزُّوڭَّارْثمْ ؤُسَّانْ نْومْ خْ ثمُّورْثْ إِ غَارْ غَا ثژْوِيمْ خْ لْ-ؤُرْذُونْ، مَاحنْذْ أَذْ ت ثطّْفمْ ذ ڒْوَارْثْ.“   
\b  
\m
\v 48 إِسِّيوڒْ سِيذِي أَكْ-ذ مُوسَا ذڭْ وَاسّْ نِّي، إِنَّا:   
\m
\v 49 ”ڭعّذْ أَذْرَارْ ن أَبَارِيمْ، \add أَقَا-ث\add* ذ أَذْرَارْ ن نابُو نِّي \add إِدْجَانْ\add* ذِي ثمُّورْثْ ن مُوآبَ أَرنْذَاذْ ن أَرِيحَا، ؤُشَا خْزَارْ ثَامُّورْثْ ن كنْعَانْ نِّي إِ غَا وْشغْ ذ ڒْوَارْثْ إِ أَيْثْ ن إِسْرَائِيل، \x ◘ \xo 32:‏49 \xt ڒخْڒ. 27‏:‏12\x*  
\v 50 ؤُشَا مّثْ خْ وذْرَارْ نِّي غَارْ غَا ثْڭعّْذذْ. أَذْ ثْذوْڒذْ أَذْ ثمَّارْنِيذْ غَارْ ڒْڭنْسْ نّشْ، أَمْ مَامّشْ إِمُّوثْ ؤُمَاشْ هَارُونْ خْ وذْرَارْ ن هُورْ ؤُشَا إِمَّارْنِي غَارْ ڒْڭنْسْ نّسْ، \x ◘ \xo 32:‏50 \xt ڒخْڒ. 27‏:‏13؛ 33‏:‏38\x*  
\v 51 مِينْزِي كنِّيوْ ثغْذَاڒمْ زَّايِي ذِي ڒْوسْطْ ن أَيْثْ ن إِسْرَائِيل غَارْ وَامَانْ ن مَارِيبَا-قَاذَاشْ ذِي ڒخْڒَا ن صِينْ، مِينْزِي كنِّيوْ وَارْ ذ أَيِي ثسّْقدّْسمْ ذِي ڒْوسْطْ ن أَيْثْ ن إِسْرَائِيل. \x ◘ \xo 32:‏51 \xt ڒخْڒ. 20‏:‏12\x*  
\v 52 \add خنِّي ڒخُّو\add* أَذْ طْژَارذْ ثَامُّورْثْ زَّاثكْ، مَاشَا وَارْ تِّيذْفذْ شَا غَارْ ثمُّورْثْ نِّي إِ غَا وْشغْ إِ أَيْثْ ن إِسْرَائِيل.“   
\b  
\b  
\m  
\c 33
\s1 لْبَارَاكَا ن مُوسَا  
\m
\v 1 ذ ثَا ذ لْبَارَاكَا نِّي زِي إِبَاركْ، مُوسَا، أَرْيَازْ ن سِيذِي، أَيْثْ ن إِسْرَائِيل قْبڒْ ڒْموْثْ نّسْ.  
\v 2 إِنَّا:  
\m ”سِيذِي يُوسَا-د زڭْ \add وذْرَارْ ن\add* سِينَا، إِڭعّذْ-د إِتّْوسّڭْ أَرنْذَاذْ نْسنْ زِي سَاعِيرْ، ثُوغَا إِتِّيسِّيقْ ؤُمِي د-إِبَانْ زڭْ وذْرَارْ ن فَارَانْ ؤُشَا إِفّغْ-د زِي \add جَارْ\add*عشْرَا-أَڒَافْ ن إِمْقدَّاسنْ. زڭْ ؤُفُوسْ نّسْ أَفُوسِي إِسّْبرْبِيشْ س وَاسَّامنْ أَرنْذَاذْ نْسنْ. \x ◘ \xo 33:‏2 \xt حَاب. 2‏:‏3، 4 \x*  
\v 3 وَاهْ، نتَّا إِتّخْسْ ڒڭْنُوسْ! مَارَّا إِمْقدَّاسنْ \add إِدْجَانْ\add* ذڭْ ؤُفُوسْ نّشْ، أَقَا أَثنْ غَارْ إِضَارنْ نّشْ، \add وَاهْ،\add* أَذْ إِكَّارْ \add كُوڒْ إِجّنْ زَّايْسنْ\add* زڭْ وَاوَاڒنْ نّشْ.  
\v 4 مُوسَا يُومُورْ أَنغْ خْ شَّارِيعَا، أَقَا-ت ذ ڒْوَارْثْ ن ثْمسْمُونْثْ ن يَاعْقُوبْ.  
\v 5 ثُوغَا نتَّا ذ أَجدْجِيذْ ذِي يَاشُورُونْ ؤُمِي نْيَارْونْ إِزدْجِيفنْ ن ڒْڭنْسْ، جْمِيعْ أَكْ-ذ ثْقبَّاڒْ ن إِسْرَائِيل.“   
\b  
\m
\v 6 ”إِڒِي أَذْ إِدَّارْ \bd رُوبِينْ\bd*، وَارْ إِثْمتِّي، ؤُشَا إِڒِي وَارْ تِّيڒِينْ إِرْيَازنْ نّسْ ؤُذْرُوسنْ!“   
\m
\v 7 ذ مَانْ أَيَا إِ إِنَّا خْ \bd يَاهُوذَا\bd*: ”\add أَ\add* سِيذِي، سڒْ غَارْ ثْمِيجَّا ن يَاهُوذَا ؤُشَا يَارّْ إِ-ث غَارْ ڒْڭنْسْ نّسْ. س إِفَاسّنْ نّسْ إِمّْنغْ ذِي طّْوعْ نّسْ ؤُشَا إِڒِي شكْ أَذْ أَسْ إِوْشْ أَفُوسْ ضِيدّْ ن إِغْرِيمنْ نّسْ!“ \f ◼ \fr 33:‏7 \ft \+bd ’ذِي طّْوعْ نّسْ‘\+bd* - إِخْسْ أَذْ يِينِي ’ذِي طّْوعْ ن إِسْرَائِيل‘.\f*   
\m
\v 8 ؤُ خْ \bd لَاوِي\bd* إِنَّا: ”ثُومِّيمْ نّشْ ذ ؤُرِيمْ نّشْ \add أَذْ إِڒِينْ\add* إِ ورْيَازْ نِّي ذ أَمدُّوكّڒْ نّشْ ذ أَمْثِيقِّي، ونِّي ثْقدْجْبذْ ذِي مَاسَّا، أَكْ-ذ وِي ثْقَاشْحذْ غَارْ وَامَانْ ن مَارِيبَا، \x ◘ \xo 33:‏8 \xt ؤُف. 17‏:‏7\x*  
\v 9 ونِّي إِنَّانْ خْ بَابَاسْ ذ يمَّاسْ: ’وَارْ ثنْ تّْوِيڒِيغْ!‘، ذ ونِّي وَارْ إِسّْعِيزّْ خْ يَايْثْمَاسْ نِيغْ وَارْ إِخْسْ أَذْ إِسّنْ إِحنْجِيرنْ نّسْ، مِينْزِي نِيثْنِي طّْفنْ ذِي مِينْ ثنِّيذْ شكْ ؤُشَا حْضَانْ ڒْعَاهْذْ نّشْ.  
\v 10 نِيثْنِي أَذْ سّْڒمْذنْ لْفَارَايِيضْ نّشْ إِ يَاعْقُوبْ ؤُ شَّارِيعَا نّشْ إِ إِسْرَائِيل. أَذْ سُّويُوسنْ ڒبْخُورْ زَّاثْ إِ ونْزَارنْ نّشْ ؤُڒَا ذ ثَاغَارْصْثْ \add ن وشْمَاضْ\add* إِكمّْڒنْ خْ ؤُعَالْطَارْ نّشْ.  
\v 11 بَاركْ ثِيزمَّارْ نّسْ ذِي مِينْ إِڭَّا، \add أَ\add* سِيذِي، ؤُشَا طّفْ أَرْضَا س ڒْخذْمثْ ن إِفَاسّنْ نّسْ، غْضڒْ ثِيمصَّاضِينْ ن يِينِّي أَكِيذسْ إِتّمْعَاڒَانْ ذ ن يِينِّي ث إِشَارّْهنْ حِيمَاعمَّارْصْ وَارْ تّْبذِّينْ عَاذْ!“   
\m
\v 12 ؤُ خْ \bd بِينْيَامِينْ\bd* إِنَّا: ”أَمْعِيزّْ ن سِيذِي، نتَّا أَذْ غَارسْ إِزْذغْ ذِي ڒَامَانْ، أَسّْ مَارَّا أَذْ ث إِذڒْ ؤُشَا أَذْ إِزْذغْ جَارْ ثِيغَارْضِينْ نّسْ!“ \f ◼ \fr 33:‏12 \ft \+bd ’أَذْ إِزْذغْ جَارْ ثِيغَارْضِينْ نّسْ ... ‘\+bd* - مِينْ إِخْسْ أَذْ يِينِي ’بِينْيَامِينْ أَذْ إِزْذغْ س تِّيقّثْ خْ أَربِّي ؤُشَا أَربِّي أَذْ إِذرّْ بِينْيَامِينْ ؤُ بِينْيَامِينْ أَذْ إِزْذغْ جَارْ ثْغَارْضْوِينْ ن سِيذِي‘.\f*   
\m
\v 13 ؤُ خْ \bd يُوسُوفْ\bd* إِنَّا: ”أَذْ إِبَاركْ سِيذِي ثَامُّورْثْ نّسْ س مِينْ إِدْجَانْ إِغْڒَانْ قَاعْ زڭْ ؤُجنَّا، س نّْذَا، ؤُ س \add وَامَانْ\add* إِهوْڒنْ، إِنِّي \add ذِينْ\add* إِدْجَانْ سْوَادَّايْ، \x ◘ \xo 33:‏13 \xt أَمز. 49‏:‏25\x*  
\v 14 ؤُ س ڒْغِيدْجثْ إِغْڒَانْ ن ثْفُوشْثْ ؤُ س مِينْ إِدْجَانْ إِغْڒَانْ إِ إِتِّيشْ ؤُيُورْ،  
\v 15 ؤُ س ڒْقِيمثْ ن إِذُورَارْ ثِيقْذِيمِينْ ؤُ س مِينْ إِغْڒَانْ ن ثوْرِيرِينْ ن ڒبْذَا،  
\v 16 ؤُ س مِينْ إِغْڒَانْ أَطَّاسْ ن ثمُّورْثْ ذ ؤُعمَّارْ نّسْ، ؤُ س ثْشُونِي ن ونِّي ثُوغَا إِزدّْغنْ ذِي شْبَارْقْ أَكْ-ذ إِسنَّاننْ. إِڒِي أَذْ د-يَاسْ خْ ؤُزدْجِيفْ ن يُوسُوفْ ؤُ خْ ثُوشّنْثْ ن ؤُشُوَّافْ ن ونِّي يَاربُّونْ تَّاجْ \add ن وعْزَاڒْ\add* جَارْ أَيْثْمَاسْ. \x ◘ \xo 33:‏16 \xt أَمز. 49‏:‏26؛ ؤُف. 3‏:‏3‏-‏6. \x*  
\v 17 أَمنْزُو ن ؤُفُونَاسْ نّسْ ذ ؤُشوَّارْ نّسْ ؤُ أَشَّاونْ نّسْ أَمْ وَاشَّاونْ \add إِزِيرَارنْ\add* ن إِغَايْضْ ن ڒخْڒَا، أَذْ زَّايْسنْ إِوّثْ ڒڭْنُوسْ مَارَّا جْمِيعْ أَڒْ ثِينڭُّورَا ن دُّونشْثْ. إِنَا ذعشْرَا ن ڒُوڒُوفْ ن إِفْرَايِيمْ ؤُ إِنَا ذ ڒُوڒُوفْ ن مَانَاسَّا!“ \x ◘ \xo 33:‏17 \xt لَاوِي 22‏:‏27؛ ڒخْڒ. 18‏:‏17؛\x*   
\m
\v 18 ؤُ خْ \bd زابُولُونْ\bd* إِنَّا: ”فَارْحْ، أَ زابُولُونْ، س وُوفُّوغْ نّشْ، ؤُ شكْ، \add أَ\add* \bd إِسَّاكَارْ\bd*!، \add فَارْحْ\add* س إِقِيضَانْ نّشْ.  
\v 19 أَذْ ڒَاغَانْ إِ ڒڭْنُوسْ غَارْ وذْرَارْ. ذِينْ إِ غَا غَارْصنْ ثِيغَارْصَا ن ثْسڭْذَا، مِينْزِي أَذْ ژمّنْ أَفيّضْ ن ڒبْحُورْ ذ ثْخُوبَايْ إِنُّوفَارنْ ذڭْ إِجْذِي.“   
\m
\v 20 ؤُ خْ \bd جَاذْ\bd* إِنَّا: ”أَذْ إِتّْوَابَاركْ ونِّي إِڭِّينْ تَّاسِيعْ إِ جَاذْ! نتَّا إِزدّغْ \add ذِينْ\add* أَمْ ثيْرَاذْثْ ؤُشَا إِشَارّڭْ أَغِيڒْ، \add وَاهْ،\add* ؤُڒَا ذ أَشقُّوفْ ن ؤُزدْجِيفْ.  
\v 21 إِكْسِي ثَامُّورْثْ إِشْنَانْ إِ يِيخفْ نّسْ، مِينْزِي أَقَا ذِينْ ثتّْوَاحْضَا ثسْغَارْثْ ن ؤُمْڭوَّاذْ \add س وضْمَانْ\add*. يُوسَا-د أَكْ-ذ إِزدْجِيفنْ ن ڒْڭنْسْ، إِكمّڒْ ثَاسڭْذَا ن سِيذِي ذ ڒحْكَامَاثْ نّسْ، \add جْمِيعْ\add* أَكْ-ذ إِسْرَائِيل.“   
\m
\v 22 ؤُ خْ \bd ذَانْ\bd* إِنَّا: ”ذَانْ ذ إِجّْ ن مِّيسْ ن وَايْرَاذْ نِّي إِ إِنڭّْزنْ غَارْ زَّاثْ زِي بَاشَانْ.“   
\m
\v 23 ؤُ خْ \bd نَافْثَالِي\bd* إِنَّا: ”\add أَ\add* نَافْثَالِي، إِڒِي ثجِّيوْنذْ س ثْشُونِي ؤُ ثشُّورذْ س لْبَارَاكَا ن سِيذِي. كْسِي لْغَارْبْ ذ لْجَانُوبْ ذ ڒْوَارْثْ.“   
\m
\v 24 ؤُ خْ \bd أَشِيرْ\bd* إِنَّا: ”أَقَا إِتّْوَابَاركْ أَشِيرْ أَكْ-ذ إِحنْجِيرنْ نّسْ. إِڒِي أَذْ يَافْ أَرْضَا زڭْ أَيْثْمَاسْ ؤُشَا أَذْ إِسُّورْ أَضَارْ نّسْ ذِي زّشْثْ.  
\v 25 زّكْرُونَاثْ نّشْ \add أَقَا أَثنْ\add* زڭْ وُوزَّاڒْ ذ نّْحَاسْ، أَذْ يِيڒِي جّهْذْ نّشْ أَمْ وُوسَّانْ نّشْ!“   
\b  
\m
\v 26 ”وَارْ \add ذِينْ\add* إِدْجِي أَمْ أَربِّي، \add أَ\add* يَاشُورُونْ، ونِّي إِنَّاينْ خْ ؤُجنَّا حِيمَا أَذْ أَشْ إِوْشْ أَفُوسْ، \add ونِّي إِنَّاينْ\add* خْ إِسيْنُوثنْ س لْعَاضَامَا نّسْ. \x ◘ \xo 33:‏26 \xt أَعَوذ. 32‏:‏13، إِشا. 58‏:‏14\x*  
\v 27 أَربِّي ن ڒبْذَا ذ ثَازذِّيغْثْ \add إِ ؤُذُورِّي\add*، ؤُ سْوَادَّايْ \add تّْعَاوَاننْ\add* إِغَادْجنْ نّسْ ن ڒبْذَا. نتَّا أَذْ يَاژّڒْ خْ ڒعْذُو زَّاثْ إِ وُوذمْ نّشْ، أَذْ يِينِي: ’أَرذدْجْ!‘  
\v 28 إِسْرَائِيل أَذْ إِزْذغْ وحّْضسْ ذِي ڒَامَانْ. أَذْ يِيڒِي وَانُو ن يَاعْقُوبْ ذڭْ إِشْثْ ن ثمُّورْثْ \add إِشُّورنْ\add* ن إِرْذنْ ذ بِينُو ن جْذِيذْ، \add وَاهْ،\add* إِجنْوَانْ نّسْ أَذْ ؤُذْمنْ س نّْذَا. \x ◘ \xo 33:‏28 \xt إِرْم. 23‏:‏6؛ 33‏:‏16؛ إِزهد. 68‏:‏27\x*  
\v 29 سّعْذْ نّشْ، \add أَ\add* إِسْرَائِيل! وِي إِدْجَانْ أَمْ شكْ؟ إِجّْ ن ڒْڭنْسْ إِتّْوَاسّْنجْمنْ زِي سِيذِي. أَقَا نتَّا ذ أَسڒْقِي إِ ؤُعَاونْ ؤُڒَا ذ إِجّْ ن سِّيفْ ن لْعَاضَامَا نّشْ. ڒْعذْيَانْ نّشْ أَذْ سّْنِيعْمِيڒنْ أَذْ سّْوَاضْعنْ إِ شكْ ؤُشَا شكْ أَذْ ثْعفْسذْ خْ إِذمْرَاونْ نْسنْ!“   
\b  
\b  
\m  
\c 34
\s1 ڒْموْثْ ن مُوسَا  
\m
\v 1 \add خنِّي\add* إِڭعّذْ مُوسَا زِي ڒوْضَاثْ ن مُوآبَ غَارْ وذْرَارْ ن نابُو، غَارْ ثْقِيشّثْ ن فِيسْجَا نِّي إِوجّْهنْ أَرِيحَا ؤُشَا إِسّْشنْ أَسْ سِيذِي مَارَّا ثَامُّورْثْ، زِي جِيلْعَاذْ أَڒْ ذَانْ، \x ◘ \xo 34:‏1 \xt أَعَوذ. 3‏:‏27\x*  
\v 2 مَارَّا نَافْثَالِي ذ ثمُّورْثْ ن إِفْرَايِيمْ ذ مَانَاسَّا ذ مَارَّا ثَامُّورْثْ ن يَاهُوذَا أَڒْ ڒبْحَارْ ذ مِينْ ذِينْ أَوَارْنِي أَسْ،  
\v 3 ذ \add ثمُّورْثْ ن\add* لْجَانُوبْ ذ ؤُذوَّارْ ن ڒوْضَا ن أَرِيحَا، ثَانْذِينْثْ ن ثْشجِّيرَا ن ثِينِي أَڒْ صُوغَارْ.  
\v 4 ؤُشَا إِنَّا أَسْ سِيذِي: ”ثَا ذ ثَامُّورْثْ نِّي خْ جُّودْجغْ إِ إِبْرَاهِيمْ، ذ إِسْحَاقْ ذ يَاعْقُوبْ، نِّيغْ: ’إِ زَّارِيعثْ نّشْ، أَذْ ت وْشغْ!“ جِّيغْ شكْ أَذْ ت ثْژَارذْ س ثِيطَّاوِينْ نّشْ، \add مَاشَا\add* وَارْ ثْژكّْوِيذْ شَا ذِيهَا.“ \x ◘ \xo 34:‏4 \xt أَمز. 12‏:‏7؛ 13‏:‏15؛ 15‏:‏18؛ 26‏:‏4؛ 28‏:‏13\x*   
\m
\v 5 \add أَمُّو\add* إِ ذِينِّي إِمُّوثْ مُوسَا، أَمْسخَّارْ ن سِيذِي، ذِي ثمُّورْثْ ن مُوآبَ، أَمْ مَامّشْ \add أَوَاڒْ إِ د-إِفّْغنْ\add* زڭْ ؤُقمُّومْ ن سِيذِي.  
\v 6 ؤُشَا نتَّا إِنْضڒْ إِ-ث ذِي ثغْزُورْثْ ذِي ثمُّورْثْ ن مُوآبَ قِيبَاتْشْ إِ بَايْثْ-فَاغُورْ ؤُشَا ؤُڒَا ذ إِجّْ إِسّنْ أَمْشَانْ ن ونْضڒْ نّسْ أَڒْ أَسّْ-أَ.  
\v 7 ثُوغَا مُوسَا غَارسْ مْيَا ؤُ-عِيشْرِينْ ن إِسڭّْوُوسَا ؤُمِي إِمُّوثْ. ثِيطّْ نّسْ وَارْ ثغْرِي شَا، وَارْ ذ أَسْ إِرُوحْ ڒمْعزّْ.  
\v 8 سْغُويّنْ أَيْثْ ن إِسْرَائِيل خْ مُوسَا ذِي ڒوْضَاثْ ن مُوآبَ ثْڒَاثِينْ ن وُوسَّانْ ؤُشَا \add أَمُّو إِ\add* تّْوَاكمّْڒنْ ؤُسَّانْ ن إِغُويَّانْ ذ وشْضَانْ ن مُوسَا.   
\b  
\m
\v 9 يَاشُووَا، مِّيسْ ن نُونْ، ثُوغَا إِشُّورْ س بُوحْبڒْ ن ثِيغِيثْ، مِينْزِي مُوسَا ثُوغَا إِسَّارْسْ خَاسْ إِفَاسّنْ نّسْ ؤُ أَيْثْ ن إِسْرَائِيل سْڒِينْ غَارسْ ؤُشَا ڭِّينْ أَمْ مَامّشْ \add ث\add* يُومُورْ سِيذِي إِ مُوسَا. \x ◘ \xo 34:‏9 \xt ڒخْڒ. 27‏:‏18\x*  
\v 10 عمَّارْصْ عَاذْ وَارْ د-إِكَّارْ أَنَابِي ذِي إِسْرَائِيل أَمْ مُوسَا، ونِّي ثُوغَا إِسّْننْ سِيذِي ؤُذمْ غَارْ وُوذمْ،  
\v 11 س مَارَّا ڒعْڒَامَاثْ نِّي زِي ث إِسّكّْ سِيذِي، حِيمَا أَذْ ثنْثْ إِڭّْ ذِي ثمُّورْثْ ن مِيصْرَا، زَّاثْ إِ فِيرْعُونْ ذ مَارَّا إِمْسخَّارنْ نّسْ ذ مَارَّا ثَامُّورْثْ نّسْ،  
\v 12 ؤُ س مَارَّا أَفُوسْ نِّي إِجهْذنْ ؤُ س مَارَّا \add ثِيمڭَّا\add* إِمْغَارنْ إِسَّاڭّْوَاذنْ، ثِينِّي إِڭَّا مُوسَا زَّاثْ إِ ثِيطَّاوِينْ ن مَارَّا إِسْرَائِيل.   