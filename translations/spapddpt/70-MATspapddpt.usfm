\s1 Transfiguración de Jesús  
\p
\v 28 \wj \+w En|strong="G1722"\+w* verdad les \+w digo|strong="G3004"\+w* \+w que|strong="G3754"\+w* \+w hay|strong="G3588"\+w* \+w algunos|strong="G5100"\+w* \+w de|strong="G1722"\+w* \+w los|strong="G3588"\+w* \+w que|strong="G3754"\+w* \+w están|strong="G2476"\+w* \+w aquí|strong="G5602"\+w*, ¡\+w que|strong="G3754"\+w* \+w de|strong="G1722"\+w* \+w ningún|strong="G3756"\+w* modo prueben \+w muerte|strong="G2288"\+w* \+w hasta|strong="G2193"\+w* \+w que|strong="G3754"\+w* vean \+w que|strong="G3754"\+w* \+w el|strong="G3588"\+w* \+w Hijo|strong="G5207"\+w* \+w del|strong="G3588"\+w* Hombre \+w viene|strong="G2064"\+w* \+w en|strong="G1722"\+w* \+w su|strong="G3588"\+w* reino!\wj*   
\c 17  
\p
\v 1 \w Seis|strong="G1803"\w* \w días|strong="G2250"\w* \w después|strong="G3326"\w*, \w Jesús|strong="G2424"\w* \w tomó|strong="G3880"\w* \w a|strong="G1519"\w* \w Pedro|strong="G4074"\w*, \w Jacobo|strong="G2385"\w* \w y|strong="G2532"\w* \w Juan|strong="G2491"\w*, \w y|strong="G2532"\w* \w los|strong="G3588"\w* llevó \w aparte|strong="G2596"\w* \w a|strong="G1519"\w* \w una|strong="G3588"\w* montaña alta.  
\v 2 \w Y|strong="G2532"\w* \w se|strong="G1096"\w* transfiguró \w delante|strong="G1715"\w* \w de|strong="G3588"\w* \w ellos|strong="G3588"\w*. \w Su|strong="G3588"\w* \w rostro|strong="G4383"\w* \w resplandeció|strong="G2989"\w* \w como|strong="G5613"\w* \w el|strong="G3588"\w* \w sol|strong="G2246"\w* \w y|strong="G2532"\w* \w sus|strong="G3588"\w* \w vestiduras|strong="G2440"\w* \w se|strong="G1096"\w* transformaron \w como|strong="G5613"\w* \w la|strong="G3588"\w* \w luz|strong="G5457"\w*.  
\v 3 Aparecieron \w Moisés|strong="G3475"\w* \w y|strong="G2532"\w* \w Elías|strong="G2243"\w* quienes \w hablaban|strong="G4814"\w* \w con|strong="G3326"\w* Él.   
\p
\v 4 \w Entonces|strong="G1161"\w* \w Pedro|strong="G4074"\w* \w dijo|strong="G3004"\w* \w a|strong="G1161"\w* \w Jesús|strong="G2424"\w*: ¡\w Señor|strong="G2962"\w*, \w es|strong="G1487"\w* \w bueno|strong="G2570"\w* \w que|strong="G3588"\w* nos quedemos \w aquí|strong="G5602"\w*! \w Si|strong="G1487"\w* \w quieres|strong="G2309"\w*, \w haré|strong="G4160"\w* \w tres|strong="G5140"\w* enramadas: \w una|strong="G1520"\w* para Ti, \w una|strong="G1520"\w* para \w Moisés|strong="G3475"\w* \w y|strong="G2532"\w* \w una|strong="G1520"\w* para \w Elías|strong="G2243"\w*.   
\p
\v 5 Mientras \w hablaba|strong="G2980"\w*, \w una|strong="G3588"\w* \w nube|strong="G3507"\w* radiante \w los|strong="G3588"\w* \w cubrió|strong="G1982"\w*, \w y|strong="G2532"\w* \w de|strong="G1537"\w* \w la|strong="G3588"\w* \w nube|strong="G3507"\w* salió \w una|strong="G3588"\w* \w voz|strong="G5456"\w* \w que|strong="G3588"\w* \w decía|strong="G3004"\w*: \wj \+w Éste|strong="G3778"\+w* \+w es|strong="G3739"\+w* \+w mi|strong="G3588"\+w* \+w Hijo|strong="G5207"\+w* amado, \+w en|strong="G1722"\+w* \+w Quien|strong="G3739"\+w* \+w me|strong="G1473"\+w* complací. Escúchenlo \+w a|strong="G1722"\+w* \+w Él|strong="G3588"\+w*.\wj*   
\p
\v 6 \w Los|strong="G3588"\w* \w discípulos|strong="G3101"\w*, \w al|strong="G3588"\w* oír \add esto\add*, \w cayeron|strong="G4098"\w* \w sobre|strong="G1909"\w* \w sus|strong="G3588"\w* \w rostros|strong="G4383"\w* \w y|strong="G2532"\w* \w se|strong="G2532"\w* atemorizaron muchísimo.   
\p
\v 7 \w Pero|strong="G2532"\w* \w Jesús|strong="G2424"\w* \w se|strong="G2532"\w* acercó, \w los|strong="G3588"\w* tocó \w y|strong="G2532"\w* \w dijo|strong="G3004"\w*: \wj Levántense. \+w No|strong="G3361"\+w* teman.\wj*   
\p
\v 8 \w Al|strong="G3588"\w* levantar \w sus|strong="G3588"\w* \w ojos|strong="G3788"\w*, \w solo|strong="G3441"\w* vieron \w a|strong="G1161"\w* \w Jesús|strong="G2424"\w*.   
\p
\v 9 Mientras \w ellos|strong="G3588"\w* descendían \w de|strong="G1537"\w* \w la|strong="G3588"\w* montaña, \w Jesús|strong="G2424"\w* les ordenó: \wj \+w A|strong="G1537"\+w* \+w nadie|strong="G3367"\+w* digan \+w la|strong="G3588"\+w* \+w visión|strong="G3705"\+w* \+w hasta|strong="G2193"\+w* \+w que|strong="G3588"\+w* \+w el|strong="G3588"\+w* \+w Hijo|strong="G5207"\+w* \+w del|strong="G3588"\+w* Hombre \+w sea|strong="G3588"\+w* levantado \+w de|strong="G1537"\+w* \+w entre|strong="G2193"\+w* \+add los\+add* \+w muertos|strong="G3498"\+w*.\wj*   
\p
\v 10 \w Los|strong="G3588"\w* \w discípulos|strong="G3101"\w* le \w preguntaron|strong="G1905"\w*: ¿\w Por|strong="G3754"\w* \w qué|strong="G3754"\w* \w dicen|strong="G3004"\w* \w los|strong="G3588"\w* \w escribas|strong="G1122"\w* \w que|strong="G3754"\w* \w Elías|strong="G2243"\w* \w debe|strong="G1163"\w* \w venir|strong="G2064"\w* \w primero|strong="G4413"\w*?   
