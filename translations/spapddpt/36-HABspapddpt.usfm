\q1 
\v 3 \nd ʼEloha,\nd* el \w Santo|strong="H6918"\w*, viene de \w Temán|strong="H8487"\w*,
\q1 De las montañas de \w Parán|strong="H6290"\w*. \tl \w Selah|strong="H5542"\w*.\tl*
\b
\q1 Su esplendor \w cubre|strong="H3680"\w* los \w cielos|strong="H8064"\w*
\q1 \w Y|strong="H3068"\w* la tierra se \w llena|strong="H4390"\w* de su \w alabanza|strong="H8416"\w*.
\q1 
\v 4 Su \w resplandor|strong="H5051"\w* \w es|strong="H1961"\w* \w como|strong="H1961"\w* la luz del sol.
\q1 \w Rayos|strong="H7161"\w* de luz proceden de sus \w manos|strong="H3027"\w*.
\q1 \w Allí|strong="H8033"\w* \w se|strong="H1961"\w* oculta su \w poder|strong="H3027"\w*.
\q1 
\v 5 La \w mortandad|strong="H1698"\w* \w va|strong="H3068"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* Él
\q1 \w Y|strong="H3068"\w* \w de|strong="H6440"\w* sus \w pies|strong="H7272"\w* \w salen|strong="H3318"\w* carbones encendidos.
\q1 
\v 6 Se detiene y tiembla la tierra.
\q1 \w Mira|strong="H7200"\w*, y estremece \w a|strong="H3068"\w* las \w naciones|strong="H1471"\w*.
\q1 Se desmoronan las montañas,
\q1 Se hunden las colinas \w antiguas|strong="H5769"\w*,
