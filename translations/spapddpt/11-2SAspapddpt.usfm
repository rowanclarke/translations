\v 23 \w Y|strong="H3068"\w* \w el|strong="H5921"\w* \w mensajero|strong="H4397"\w* dijo \w a|strong="H3068"\w* \w David|strong="H1732"\w*: \w Prevalecieron|strong="H1396"\w* \w contra|strong="H5921"\w* \w nosotros|strong="H5921"\w* \w los|strong="H5921"\w* hombres \w que|strong="H3588"\w* \w salieron|strong="H3318"\w* \w al|strong="H5921"\w* \w campo|strong="H7704"\w*, \w pero|strong="H3588"\w* \w los|strong="H5921"\w* hicimos retroceder \w hasta|strong="H5704"\w* \w la|strong="H5921"\w* entrada \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w puerta|strong="H6607"\w*.
