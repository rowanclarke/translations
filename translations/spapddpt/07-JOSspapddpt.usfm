\v 10 y \w a|strong="H3068"\w* \w los|strong="H3605"\w* \w dos|strong="H8147"\w* \w reyes|strong="H4428"\w* de \w los|strong="H3605"\w* amorreos \w que|strong="H3605"\w* estaban \w al|strong="H4428"\w* otro \w lado|strong="H5676"\w* del \w Jordán|strong="H3383"\w*: \w a|strong="H3068"\w* \w Sehón|strong="H5511"\w*, \w rey|strong="H4428"\w* de \w Hesbón|strong="H2809"\w*, y \w Og|strong="H5747"\w*, \w rey|strong="H4428"\w* de \w Basán|strong="H1316"\w*, \w quien|strong="H3605"\w* vivía en Astarot.  
\v 11 \w Por|strong="H1870"\w* \w lo|strong="H3605"\w* cual nuestros \w ancianos|strong="H2205"\w* y \w todos|strong="H3605"\w* \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* de nuestra tierra nos hablaron: \w Tomen|strong="H3947"\w* \w en|strong="H3212"\w* sus \w manos|strong="H3027"\w* \w provisión|strong="H6720"\w* \w para|strong="H6258"\w* \w el|strong="H3605"\w* \w camino|strong="H1870"\w*, \w vayan|strong="H3212"\w* al encuentro con \w ellos|strong="H3027"\w* y díganles: \w Nosotros|strong="H3605"\w* somos sus esclavos. Hagan \w ahora|strong="H6258"\w* un \w pacto|strong="H1285"\w* con \w nosotros|strong="H3605"\w*.  
\v 12 \w Este|strong="H2088"\w* \w pan|strong="H3899"\w* \w estaba|strong="H1961"\w* caliente \w cuando|strong="H3117"\w* \w lo|strong="H2088"\w* tomamos de nuestras \w casas|strong="H1004"\w* \w como|strong="H1961"\w* provisión \w para|strong="H1961"\w* el camino el \w día|strong="H3117"\w* \w cuando|strong="H3117"\w* \w salimos|strong="H3318"\w* \w a|strong="H3068"\w* fin de llegar \w a|strong="H3068"\w* ustedes, pero \w ahora|strong="H6258"\w*, míralo \w aquí|strong="H2088"\w* \w seco|strong="H3001"\w* y mohoso.  
\v 13 Estos odres de \w vino|strong="H3196"\w* los llenamos \w nuevos|strong="H2319"\w*, y míralos \w aquí|strong="H2009"\w* \w rotos|strong="H1234"\w*, y nuestras ropas y nuestras sandalias desgastadas \w por|strong="H1870"\w* lo \w largo|strong="H7230"\w* del \w camino|strong="H1870"\w*.   
\p
\v 14 Entonces los hombres de Israel \w tomaron|strong="H3947"\w* de sus provisiones \add y les dieron\add*, pero \w no|strong="H3808"\w* \w pidieron|strong="H7592"\w* consejo de \nd \+w Yavé|strong="H3068"\+w*\nd*.  
\v 15 \w Josué|strong="H3091"\w* \w hizo|strong="H6213"\w* \w paz|strong="H7965"\w* con ellos \w e|strong="H3068"\w* \w hizo|strong="H6213"\w* un \w pacto|strong="H1285"\w* con ellos de preservarles la \w vida|strong="H2421"\w*. Los jefes de la congregación también les \w hicieron|strong="H6213"\w* juramento.   
\p
\v 16 \w Sucedió|strong="H1961"\w* \w que|strong="H3588"\w* \w tres|strong="H7969"\w* \w días|strong="H3117"\w* \w después|strong="H3427"\w* \w de|strong="H3588"\w* \w hacer|strong="H3772"\w* \w el|strong="H3588"\w* \w pacto|strong="H1285"\w* \w con|strong="H3588"\w* \w ellos|strong="H1992"\w*, \w oyeron|strong="H8085"\w* \w decir|strong="H8085"\w* \w que|strong="H3588"\w* \w eran|strong="H1961"\w* \w sus|strong="H1992"\w* \w vecinos|strong="H7138"\w* \w y|strong="H3588"\w* \w que|strong="H3588"\w* \w vivían|strong="H3427"\w* \w dentro|strong="H7130"\w* \w de|strong="H3588"\w* \w su|strong="H1992"\w* tierra.  
\v 17 \w Entonces|strong="H3117"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w* \w salieron|strong="H5265"\w*, y al tercer \w día|strong="H3117"\w* llegaron \w a|strong="H3068"\w* las \w ciudades|strong="H5892"\w* \w de|strong="H1121"\w* aquéllos. \w Y|strong="H3068"\w* sus \w ciudades|strong="H5892"\w* eran \w Gabaón|strong="H1391"\w*, Cafira, Beerot, y Quiriat-jearim.  
\v 18 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w* \w no|strong="H3808"\w* \w los|strong="H1121"\w* \w mataron|strong="H5221"\w* \w porque|strong="H3588"\w* \w los|strong="H1121"\w* jefes \w de|strong="H5921"\w* \w la|strong="H5921"\w* congregación \w les|strong="H5921"\w* \w hicieron|strong="H5221"\w* juramento \w por|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*, ʼElohim\nd* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.  
\p \w Y|strong="H3068"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* congregación \w murmuró|strong="H3885"\w* \w contra|strong="H5921"\w* \w los|strong="H1121"\w* jefes.  
