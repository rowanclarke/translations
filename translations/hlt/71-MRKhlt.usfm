\s1 Cangtii Neh Thuituennah  
\p
\v 26 Te \w phoeiah|strong="G2532"\w*, \wj “ \+w Pathen|strong="G2316"\+w* \+w ram|strong="G0932"\+w* \+w tah|strong="G3588"\+w* \+w diklai|strong="G1093"\+w* \+w dongah|strong="G1909"\+w* \+w cangtii|strong="G4703"\+w* aka \+w haeh|strong="G0906"\+w* \+w hlang|strong="G0444"\+w* \+w bangla|strong="G5613"\+w* \+w om|strong="G2076"\+w* \+w tangloeng|strong="G3779"\+w*\wj*.  
\v 27 \wj \+w Tedae|strong="G2532"\+w* \+w khoyin|strong="G3571"\+w* \+w khothaih|strong="G2250"\+w* \+w ip|strong="G2518"\+w* vaeng \+w thoo|strong="G1453"\+w* vaeng \+w cakhaw|strong="G2532"\+w* \+w cangtii|strong="G4703"\+w* \+w daih|strong="G0985"\+w* \+w tih|strong="G2532"\+w* a \+w rhoeng|strong="G3373"\+w* \+w te|strong="G5613"\+w* a \+w ming|strong="G1492"\+w* \+w moenih|strong="G3756"\+w*\wj*.  
