\id JON
\h Jonás
\toc3 Jon
\toc2 Jonás
\toc1 Jonás
\mt1 Jonás
\c 1
\s1 El profeta rebelde
\p 
\v 1 La \w Palabra|strong="H1697"\w* \w de|strong="H1121"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w vino|strong="H1961"\w* \w a|strong="H3068"\w* \w Jonás|strong="H3124"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Amitay:
\v 2 \wj \w Levántate|strong="H6965"\w* \w y|strong="H3588"\w* \w vé|strong="H3068"\w* \w a|strong="H3068"\w* \w Nínive|strong="H5210"\w*, \w la|strong="H5921"\w* \w gran|strong="H1419"\w* \w ciudad|strong="H5892"\w*, \w y|strong="H3588"\w* proclama \w contra|strong="H5921"\w* \w ella|strong="H5921"\w*, \w porque|strong="H3588"\w* \w su|strong="H3588"\w* perversidad \w subió|strong="H5927"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w Mí|strong="H5921"\w*.\wj*
\p 
\v 3 \w Jonás|strong="H3124"\w* se \w levantó|strong="H6965"\w* \w para|strong="H5414"\w* huir \w de|strong="H6440"\w* la \w Presencia|strong="H6440"\w* \w de|strong="H6440"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w a|strong="H3068"\w* \w Tarsis|strong="H8659"\w*. Después \w de|strong="H6440"\w* bajar \w a|strong="H3068"\w* Jope, \w halló|strong="H4672"\w* \w una|strong="H4672"\w* nave que partía \w a|strong="H3068"\w* \w Tarsis|strong="H8659"\w*. \w Pagó|strong="H5414"\w* \w el|strong="H5973"\w* precio y se embarcó \w para|strong="H5414"\w* navegar \w con|strong="H5973"\w* ellos \w a|strong="H3068"\w* \w Tarsis|strong="H8659"\w*, \w lejos|strong="H1272"\w* \w de|strong="H6440"\w* la \w Presencia|strong="H6440"\w* \w de|strong="H6440"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\p 
\v 4 Pero \nd \w Yavé|strong="H3068"\w*\nd* levantó un \w viento|strong="H7307"\w* impetuoso en el \w mar|strong="H3220"\w*, y \w hubo|strong="H1961"\w* una \w tempestad|strong="H5591"\w* tan \w grande|strong="H1419"\w* \w que|strong="H1961"\w* el barco \w estaba|strong="H1961"\w* \w a|strong="H3068"\w* punto de romperse.
\v 5 \w Los|strong="H5921"\w* marineros tuvieron \w miedo|strong="H3372"\w* \w y|strong="H5921"\w* cada uno \w clamaba|strong="H2199"\w* \w a|strong="H3068"\w* su \tl ʼelohim\tl*. Echaron \w la|strong="H5921"\w* carga \w al|strong="H5921"\w* \w mar|strong="H3220"\w* \w para|strong="H5921"\w* aligerar \w la|strong="H5921"\w* nave. Pero \w Jonás|strong="H3124"\w* bajó \w al|strong="H5921"\w* fondo \w del|strong="H5921"\w* barco, \w se|strong="H5921"\w* acostó \w y|strong="H5921"\w* dormía profundamente.
\v 6 \w Y|strong="H3068"\w* el \w capitán|strong="H7227"\w* del barco \w se|strong="H3808"\w* acercó \w a|strong="H3068"\w* él y le dijo: ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* duermes? ¡\w Levántate|strong="H6965"\w* y \w clama|strong="H7121"\w* \w a|strong="H3068"\w* tu \nd ʼElohim\nd*! Tal vez \nd ʼElohim\nd* tenga compasión de nosotros, y \w no|strong="H3808"\w* perezcamos.
\p 
\v 7 Luego cada uno dijo \w a|strong="H3068"\w* su \w compañero|strong="H7453"\w*: ¡Vengan, echemos \w suertes|strong="H1486"\w* \w para|strong="H5921"\w* \w saber|strong="H3045"\w* \w por|strong="H5921"\w* culpa \w de|strong="H5921"\w* \w quién|strong="H4310"\w* \w nos|strong="H5921"\w* \w vino|strong="H3212"\w* \w este|strong="H2063"\w* \w mal|strong="H7451"\w*! \w Echaron|strong="H5307"\w* \w suertes|strong="H1486"\w*, \w y|strong="H5921"\w* \w la|strong="H5921"\w* \w suerte|strong="H1486"\w* \w cayó|strong="H5307"\w* \w sobre|strong="H5921"\w* \w Jonás|strong="H3124"\w*.
\v 8 Entonces \w le|strong="H4310"\w* dijeron: ¡\w Decláranos|strong="H5046"\w* \w por|strong="H2088"\w* \w qué|strong="H4100"\w* \w nos|strong="H4100"\w* \w vino|strong="H4100"\w* \w esta|strong="H2063"\w* calamidad! ¿\w Qué|strong="H4100"\w* \w oficio|strong="H4399"\w* tienes y \w de|strong="H5971"\w* dónde vienes? ¿\w Cuál|strong="H4100"\w* \w es|strong="H2088"\w* tu país? ¿\w De|strong="H5971"\w* \w cuál|strong="H4100"\w* \w pueblo|strong="H5971"\w* eres?
\p 
\v 9 \w Él|strong="H6213"\w* respondió: Soy \w hebreo|strong="H5680"\w* y temo \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w el|strong="H6213"\w* \nd ʼElohim\nd* del \w cielo|strong="H8064"\w*, \w Quien|strong="H6213"\w* \w hizo|strong="H6213"\w* \w el|strong="H6213"\w* \w mar|strong="H3220"\w* y la \w tierra|strong="H3004"\w* seca.
\p 
\v 10 \w Entonces|strong="H3588"\w* \w aquellos|strong="H1992"\w* hombres tuvieron \w gran|strong="H1419"\w* \w temor|strong="H3372"\w* \w y|strong="H3588"\w* \w le|strong="H1931"\w* preguntaron: ¿\w Por|strong="H3588"\w* \w qué|strong="H3588"\w* \w hiciste|strong="H6213"\w* \w esto|strong="H2063"\w*? \w Porque|strong="H3588"\w* \w los|strong="H1992"\w* hombres \w entendieron|strong="H3045"\w* \w que|strong="H3588"\w* \w huía|strong="H1272"\w* \w de|strong="H3588"\w* \w la|strong="H1931"\w* \w Presencia|strong="H6440"\w* \w de|strong="H3588"\w* \nd \w Yavé|strong="H3068"\w*\nd*, \w pues|strong="H3588"\w* \w él|strong="H1931"\w* \w se|strong="H3045"\w* \w lo|strong="H1931"\w* \w declaró|strong="H5046"\w*.
\v 11 \w Y|strong="H3068"\w* \w le|strong="H5921"\w* preguntaron: ¿\w Qué|strong="H3588"\w* \w te|strong="H5921"\w* \w haremos|strong="H6213"\w* \w para|strong="H5921"\w* \w que|strong="H3588"\w* \w se|strong="H5921"\w* \w nos|strong="H5921"\w* calme \w el|strong="H5921"\w* \w mar|strong="H3220"\w*? \w Porque|strong="H3588"\w* \w el|strong="H5921"\w* \w mar|strong="H3220"\w* \w se|strong="H5921"\w* embravecía \w más|strong="H3588"\w* \w y|strong="H3588"\w* \w más|strong="H3588"\w*.
\p 
\v 12 \w Y|strong="H3068"\w* \w él|strong="H5921"\w* respondió: Levántenme \w y|strong="H3588"\w* láncenme \w al|strong="H5921"\w* \w mar|strong="H3220"\w*, \w y|strong="H3588"\w* \w se|strong="H3045"\w* \w les|strong="H5921"\w* calmará, \w pues|strong="H3588"\w* \w yo|strong="H3588"\w* \w sé|strong="H3045"\w* \w que|strong="H3588"\w* \w por|strong="H5921"\w* \w mi|strong="H5921"\w* causa \w les|strong="H5921"\w* vino \w esta|strong="H2088"\w* \w gran|strong="H1419"\w* \w tempestad|strong="H5591"\w*.
\p 
\v 13 \w Sin|strong="H3808"\w* embargo, \w los|strong="H5921"\w* hombres remaron duro \w para|strong="H5921"\w* regresar \w a|strong="H3068"\w* \w tierra|strong="H3004"\w*, \w pero|strong="H3588"\w* \w no|strong="H3808"\w* \w pudieron|strong="H3201"\w* \w porque|strong="H3588"\w* \w el|strong="H5921"\w* \w mar|strong="H3220"\w* \w se|strong="H3808"\w* \w volvía|strong="H7725"\w* \w más|strong="H3588"\w* tormentoso \w contra|strong="H5921"\w* \w ellos|strong="H5921"\w*.
\v 14 \w Entonces|strong="H3588"\w* clamaron \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*: ¡Oh \nd \w Yavé|strong="H3068"\w*\nd*, \w te|strong="H5921"\w* rogamos \w que|strong="H3588"\w* \w nosotros|strong="H5921"\w* \w no|strong="H6213"\w* perezcamos \w por|strong="H5921"\w* \w la|strong="H5921"\w* \w vida|strong="H5315"\w* \w de|strong="H5921"\w* \w este|strong="H2088"\w* hombre, \w ni|strong="H5355"\w* \w nos|strong="H5921"\w* culpes \w de|strong="H5921"\w* \w sangre|strong="H1818"\w* \w inocente|strong="H5355"\w*! ¡\w Porque|strong="H3588"\w* \w tú|strong="H6213"\w*, oh \nd \w Yavé|strong="H3068"\w*\nd*, \w hiciste|strong="H6213"\w* \w lo|strong="H2088"\w* \w que|strong="H3588"\w* \w te|strong="H5921"\w* agradó!
\v 15 Levantaron \w a|strong="H3068"\w* \w Jonás|strong="H3124"\w* y lo lanzaron al \w mar|strong="H3220"\w*. \w Y|strong="H3068"\w* el \w mar|strong="H3220"\w* detuvo su furia.
\v 16 Aquellos hombres \w temieron|strong="H3372"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* con \w gran|strong="H1419"\w* \w temor|strong="H3372"\w*, ofrecieron \w sacrificio|strong="H2077"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w e|strong="H3068"\w* hicieron \w votos|strong="H5087"\w*.
\p 
\v 17 \nd \w Yavé|strong="H3068"\w*\nd* preparó un gran pez que tragara \w a|strong="H3068"\w* Jonás. \w Y|strong="H3068"\w* Jonás estuvo en el estómago del pez tres días y tres noches.
\c 2
\s1 Oración de Jonás
\p 
\v 1 \w Entonces|strong="H3117"\w* \w Jonás|strong="H3124"\w* oró \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd* su \nd ʼElohim\nd* desde el estómago del \w pez|strong="H1709"\w*,
\v 2 y dijo: En mi angustia invoqué \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*, y Él me respondió. Desde el estómago del \tl Seol\tl* pedí socorro, y Tú escuchaste mi voz.
\p 
\v 3 Me lanzaste \w a|strong="H3068"\w* lo profundo en medio de los mares, y me rodeó la corriente. Todas tus ondas y tus olas pasaron sobre \w mí|strong="H6030"\w*.
\v 4 \w Me|strong="H5921"\w* dije: Desechado soy \w de|strong="H5921"\w* tu Presencia, pero aún veré tu santo Templo.
\v 5 Las aguas me rodearon hasta el alma. Me rodeó el abismo. Las algas se enredaron en mi cabeza.
\v 6 Descendí \w a|strong="H3068"\w* los cimientos \w de|strong="H5704"\w* las montañas. La tierra echó sus cerrojos sobre \w mí|strong="H5315"\w* \w para|strong="H5704"\w* siempre.
\p Pero Tú, oh \nd \w Yavé|strong="H3068"\w*, ʼElohim\nd* mío, sacaste \w de|strong="H5704"\w* la fosa \w mi|strong="H5315"\w* \w vida|strong="H5315"\w*.
\v 7 Cuando mi alma desfallecía en mí, me acordé de \nd \w Yavé|strong="H3068"\w*\nd*, y mi oración \w llegó|strong="H5927"\w* hasta Ti en tu santo Templo.
\v 8 \w Los|strong="H5921"\w* \w que|strong="H5921"\w* siguen vanos ídolos olvidan tu misericordia.
\v 9 Pero yo te ofreceré sacrificio de alabanza. Cumpliré lo que prometí. ¡\w La|strong="H8104"\w* salvación es de \nd \w Yavé|strong="H3068"\w*\nd*!
\p 
\v 10 Entonces \nd \w Yavé|strong="H3068"\w*\nd* dio orden al pez, y éste vomitó \w a|strong="H3068"\w* Jonás en tierra seca.
\c 3
\s1 Arrepentimiento de Nínive
\p 
\v 1 La \w Palabra|strong="H1697"\w* \w de|strong="H1697"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w vino|strong="H1961"\w* \w por|strong="H1697"\w* \w segunda|strong="H8145"\w* vez \w a|strong="H3068"\w* \w Jonás|strong="H3124"\w*:
\v 2 \wj \w Levántate|strong="H6965"\w* y \w vé|strong="H3068"\w* \w a|strong="H3068"\w* \w Nínive|strong="H5210"\w*, la \w gran|strong="H1419"\w* \w ciudad|strong="H5892"\w*, y proclama \w en|strong="H3212"\w* ella el mensaje que Yo te daré.\wj*
\p 
\v 3 \w Entonces|strong="H3117"\w* \w Jonás|strong="H3124"\w* \w se|strong="H1961"\w* \w levantó|strong="H6965"\w* y \w fue|strong="H1961"\w* \w a|strong="H3068"\w* \w Nínive|strong="H5210"\w*, conforme \w a|strong="H3068"\w* la \w Palabra|strong="H1697"\w* \w de|strong="H1697"\w* \nd \w Yavé|strong="H3068"\w*\nd*. \w Nínive|strong="H5210"\w* \w era|strong="H1961"\w* una \w ciudad|strong="H5892"\w* muy \w grande|strong="H1419"\w* \w de|strong="H1697"\w* \w tres|strong="H7969"\w* \w días|strong="H3117"\w* \w de|strong="H1697"\w* \w camino|strong="H4109"\w*.
\v 4 \w Jonás|strong="H3124"\w* entró \w en|strong="H5750"\w* la \w ciudad|strong="H5892"\w*. \w Caminó|strong="H4109"\w* un \w día|strong="H3117"\w* y proclamaba: Quedan 40 \w días|strong="H3117"\w* y \w Nínive|strong="H5210"\w* será destruida.
\p 
\v 5 Los hombres \w de|strong="H5704"\w* \w Nínive|strong="H5210"\w* creyeron \w a|strong="H3068"\w* \nd ʼElohim\nd*, proclamaron \w ayuno|strong="H6685"\w* \w y|strong="H5704"\w* se cubrieron \w de|strong="H5704"\w* tela áspera, \w desde|strong="H5704"\w* el \w mayor|strong="H1419"\w* \w hasta|strong="H5704"\w* el \w menor|strong="H6996"\w*.
\p 
\v 6 Cuando \w la|strong="H5921"\w* noticia \w llegó|strong="H5060"\w* \w al|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Nínive|strong="H5210"\w*, éste \w se|strong="H5921"\w* \w levantó|strong="H6965"\w* \w de|strong="H5921"\w* su \w trono|strong="H3678"\w*, \w se|strong="H5921"\w* despojó \w de|strong="H5921"\w* su manto, \w se|strong="H5921"\w* \w cubrió|strong="H3680"\w* \w de|strong="H5921"\w* tela áspera \w y|strong="H5921"\w* \w se|strong="H5921"\w* sentó \w sobre|strong="H5921"\w* ceniza.
\v 7 Proclamó \w y|strong="H1241"\w* anunció en \w Nínive|strong="H5210"\w*, \w por|strong="H4428"\w* mandato \w del|strong="H8354"\w* \w rey|strong="H4428"\w* \w y|strong="H1241"\w* \w de|strong="H4325"\w* sus \w grandes|strong="H1419"\w*: ¡\w Que|strong="H4325"\w* hombres \w y|strong="H1241"\w* animales, \w bueyes|strong="H1241"\w* \w y|strong="H1241"\w* \w ovejas|strong="H6629"\w*, no coman \w alguna|strong="H3972"\w* \w cosa|strong="H3972"\w*! ¡\w Que|strong="H4325"\w* no se \w les|strong="H3972"\w* \w dé|strong="H4325"\w* alimento, ni \w beban|strong="H8354"\w* \w agua|strong="H4325"\w*!
\v 8 ¡Cúbranse \w de|strong="H4480"\w* tela áspera tanto hombres como animales! ¡Clamen \w a|strong="H3068"\w* \nd ʼElohim\nd* fuertemente, y cambien \w de|strong="H4480"\w* mente cada uno \w con|strong="H4480"\w* respecto \w a|strong="H3068"\w* su \w mal|strong="H7451"\w* \w camino|strong="H1870"\w* y \w al|strong="H4480"\w* robo \w que|strong="H4480"\w* hay \w en|strong="H4480"\w* sus \w manos|strong="H3709"\w*!
\v 9 ¿\w Quién|strong="H4310"\w* \w sabe|strong="H3045"\w* \w si|strong="H3808"\w* \nd ʼElohim\nd* desistirá y cambiará de parecer, \w se|strong="H3045"\w* apartará del \w furor|strong="H2740"\w* de su \w ira|strong="H2740"\w* y \w no|strong="H3808"\w* perezcamos?
\p 
\v 10 \nd ʼElohim\nd* \w vio|strong="H7200"\w* \w lo|strong="H3808"\w* \w que|strong="H3588"\w* \w hicieron|strong="H6213"\w*, \w cómo|strong="H3588"\w* regresaron \w de|strong="H5921"\w* \w su|strong="H1992"\w* \w mal|strong="H7451"\w* \w camino|strong="H1870"\w*, \w y|strong="H3588"\w* desistió \w del|strong="H5921"\w* \w mal|strong="H7451"\w* \w que|strong="H3588"\w* \w dijo|strong="H1696"\w* \w que|strong="H3588"\w* \w les|strong="H1992"\w* \w haría|strong="H6213"\w*, \w y|strong="H3588"\w* \w no|strong="H3808"\w* \w lo|strong="H3808"\w* \w hizo|strong="H6213"\w*.
\c 4
\s1 La calabacera
\p 
\v 1 Pero esto desagradó \w a|strong="H3068"\w* \w Jonás|strong="H3124"\w* y lo enojó muchísimo.
\v 2 \w Y|strong="H3068"\w* \w habló|strong="H1697"\w* \w a|strong="H3068"\w* \nd \w Yavé|strong="H3068"\w*\nd*: ¡Oh \nd \w Yavé|strong="H3068"\w*\nd*! ¿\w No|strong="H3808"\w* \w era|strong="H1961"\w* \w esto|strong="H2088"\w* \w lo|strong="H1697"\w* \w que|strong="H3588"\w* \w yo|strong="H3588"\w* decía \w cuando|strong="H3588"\w* \w aún|strong="H5704"\w* \w estaba|strong="H1961"\w* \w en|strong="H5921"\w* \w mi|strong="H5921"\w* tierra? \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* huí \w a|strong="H3068"\w* \w Tarsis|strong="H8659"\w*, \w porque|strong="H3588"\w* \w sabía|strong="H3045"\w* \w que|strong="H3588"\w* Tú \w eres|strong="H1961"\w* un \nd \w ʼEL|strong="H5921"\w*\nd* \w clemente|strong="H2587"\w* \w y|strong="H3588"\w* \w misericordioso|strong="H7349"\w*, lento \w para|strong="H5704"\w* \w la|strong="H5921"\w* ira \w y|strong="H3588"\w* \w grande|strong="H7227"\w* \w en|strong="H5921"\w* \w misericordia|strong="H2617"\w*, \w y|strong="H3588"\w* \w que|strong="H3588"\w* desistes \w del|strong="H5921"\w* \w mal|strong="H7451"\w*.
\v 3 \w Ahora|strong="H6258"\w* \w pues|strong="H3588"\w*, oh \nd \w Yavé|strong="H3068"\w*\nd*, \w te|strong="H4480"\w* \w ruego|strong="H4994"\w* \w que|strong="H3588"\w* \w me|strong="H4480"\w* \w quites|strong="H3947"\w* \w la|strong="H3588"\w* \w vida|strong="H5315"\w*, \w porque|strong="H3588"\w* \w mejor|strong="H2896"\w* \w me|strong="H4480"\w* \w es|strong="H3588"\w* \w la|strong="H3588"\w* \w muerte|strong="H4194"\w* \w que|strong="H3588"\w* \w la|strong="H3588"\w* \w vida|strong="H5315"\w*.
\p 
\v 4 \nd \w Yavé|strong="H3068"\w*\nd* le respondió: \wj ¿Haces \w bien|strong="H3190"\w* en enojarte tanto? \wj*
\p 
\v 5 \w Jonás|strong="H3124"\w* \w salió|strong="H3318"\w* \w de|strong="H4480"\w* la \w ciudad|strong="H5892"\w* \w y|strong="H5704"\w* \w se|strong="H1961"\w* sentó \w al|strong="H4480"\w* \w oriente|strong="H6924"\w* \w de|strong="H4480"\w* \w ella|strong="H8033"\w*. \w Allí|strong="H8033"\w* \w hizo|strong="H6213"\w* una enramada \w y|strong="H5704"\w* \w se|strong="H1961"\w* sentó \w a|strong="H3068"\w* su \w sombra|strong="H6738"\w* \w hasta|strong="H5704"\w* \w ver|strong="H7200"\w* \w qué|strong="H4100"\w* sucedería \w en|strong="H4480"\w* la \w ciudad|strong="H5892"\w*.
\v 6 \nd \w Yavé|strong="H3068"\w* ʼElohim\nd* \w preparó|strong="H4487"\w* una calabacera \w la|strong="H5921"\w* cual creció \w e|strong="H3068"\w* \w hizo|strong="H5927"\w* \w sombra|strong="H6738"\w* \w sobre|strong="H5921"\w* \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w de|strong="H5921"\w* \w Jonás|strong="H3124"\w* \w para|strong="H5921"\w* librarlo \w de|strong="H5921"\w* su malestar. \w Y|strong="H3068"\w* \w Jonás|strong="H3124"\w* \w se|strong="H1961"\w* alegró \w grandemente|strong="H1419"\w* \w por|strong="H5921"\w* \w la|strong="H5921"\w* calabacera.
\p 
\v 7 Pero al amanecer del día \w siguiente|strong="H4283"\w* \nd ʼElohim\nd* \w preparó|strong="H4487"\w* un \w gusano|strong="H8438"\w*, el cual \w hirió|strong="H5221"\w* la calabacera, y se \w secó|strong="H3001"\w*.
\v 8 \w Aconteció|strong="H1961"\w* \w que|strong="H5921"\w* \w al|strong="H5921"\w* salir \w el|strong="H5921"\w* \w sol|strong="H8121"\w*, \nd ʼElohim\nd* envió un sofocante \w viento|strong="H7307"\w* \w oriental|strong="H6921"\w* \w que|strong="H5921"\w* golpeó \w la|strong="H5921"\w* \w cabeza|strong="H7218"\w* \w de|strong="H5921"\w* \w Jonás|strong="H3124"\w*, \w de|strong="H5921"\w* modo \w que|strong="H5921"\w* \w se|strong="H1961"\w* desmayaba \w y|strong="H5921"\w* anhelaba \w la|strong="H5921"\w* \w muerte|strong="H4191"\w*. \w Y|strong="H3068"\w* dijo: \w Mejor|strong="H2896"\w* \w me|strong="H5921"\w* \w es|strong="H1961"\w* \w morir|strong="H4191"\w* \w que|strong="H5921"\w* vivir.
\p 
\v 9 Entonces \nd ʼElohim\nd* respondió \w a|strong="H3068"\w* \w Jonás|strong="H3124"\w*: \wj ¿\w Te|strong="H5921"\w* parece \w bien|strong="H3190"\w* enojarte \w por|strong="H5921"\w* \w la|strong="H5921"\w* calabacera?\wj*
\p \w Y|strong="H3068"\w* \w él|strong="H5921"\w* respondió: Mucho \w me|strong="H5921"\w* enojo, \w hasta|strong="H5704"\w* \w la|strong="H5921"\w* \w muerte|strong="H4194"\w*.
\p 
\v 10 \nd \w Yavé|strong="H3068"\w*\nd* \w le|strong="H5921"\w* dijo: \wj \w Te|strong="H5921"\w* preocupas \w por|strong="H5921"\w* \w la|strong="H5921"\w* calabacera, \w por|strong="H5921"\w* \w la|strong="H5921"\w* cual \w no|strong="H3808"\w* \w trabajaste|strong="H5998"\w* \w ni|strong="H3808"\w* \w la|strong="H5921"\w* hiciste crecer, \w que|strong="H3808"\w* \w en|strong="H5921"\w* una \w noche|strong="H3915"\w* \w nació|strong="H1961"\w* \w y|strong="H5921"\w* \w en|strong="H5921"\w* una \w noche|strong="H3915"\w* pereció.\wj*
\v 11 \wj ¿\w No|strong="H3808"\w* debo Yo preocuparme \w por|strong="H5921"\w* \w Nínive|strong="H5210"\w*, \w esta|strong="H3426"\w* \w gran|strong="H1419"\w* \w ciudad|strong="H5892"\w* \w donde|strong="H5921"\w* \w hay|strong="H3426"\w* \w más|strong="H5921"\w* \w de|strong="H5921"\w* 120.000 personas \w que|strong="H3808"\w* \w no|strong="H3808"\w* distinguen su mano \w derecha|strong="H3225"\w* \w de|strong="H5921"\w* su mano \w izquierda|strong="H8040"\w*, \w y|strong="H5921"\w* \w muchos|strong="H7227"\w* animales?\wj* 
