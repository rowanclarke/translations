\c 1
\cd \it 1 Ko hono К»aonga К»oe ngaahi lea fakatДҒtДҒ. 7 Ko e enginaki ke manavahД“ ki he К»Otua, mo tui ki heК»ene folofola. 10 Ke К»oua naК»a moК»ua К»i he tauvele К»ae kakai angahala. 20 К»Oku lea valoki К»ae poto К»i hono manukiК»i. 24 К»Oku ne fakamanavahД“К»i К»a hono kau manuki.\it*
\p 
\v 1 Ko e ngaahi lea fakatДҒtДҒ К»a Solomone ko e foha К»o Tevita, ko e tuК»i К»o К»Isileli;
\q1 
\v 2 Ke К»ilo ai К»ae poto mo e akonaki;
\q2 pea ongoК»i К»ae ngaahi lea К»oe faК»a К»ilo;
\q1 
\v 3 Ke maК»u К»ae akonaki К»oe poto,
\q2 mo e angatonu, mo e fakamaau, pea mo e fai totonu;
\q1 
\v 4 Ke foaki К»ae К»iloК»ilo ki he taК»epoto,
\q2 pea ki he tangata talavou К»ae К»ilo mo e faК»a fakakaukau.
\q1 
\v 5 вҖҢК»E fie fanongo К»e he tangata poto, pea К»e tupulekina ai a К»ene poto;
\q2 pea К»e maК»u ai К»e he tangata faК»a К»ilo К»ae ngaahi fakakaukau lelei:
\q1 
\v 6 Ke К»iloК»i К»ae lea fakatДҒtДҒ, pea mo hono fakamatala;
\q2 К»ae ngaahi lea К»ae poto, mo К»enau ngaahi tala К»ilongataК»a.
\b
\q1 
\v 7 Ko e manavahД“ kia Sihova ko e kamataК»anga ia К»oe К»ilo:
\q2 ka К»oku fehiК»a К»ae vale ki he poto mo e akonaki.
\q1 
\v 8 вҖҢК»E hoku foha, fanongo ki he akonaki К»a hoК»o tamai,
\q2 pea К»oua naК»a ke liК»aki К»ae fekau К»a hoК»o faК»Д“:
\q1 
\v 9 KoeК»uhi К»e hoko ia ko e teunga lelei ki ho К»ulu,
\q2 mo e kahoa ke tautau ki ho kia.
\q1 
\v 10 вҖҢК»E hoku foha, kapau К»e fakatauveleК»i koe К»e he kau angahala, К»oua naК»a ke loto ki ai.
\q1 
\v 11 Kapau te nau pehД“, вҖңHaК»u ke tau ЕҚ,
\q2 ke tau tatali К»o toitoi ke lilingi К»ae toto,
\q2 ke tau lama fakafufЕ« taК»ehanoК»uhinga ki he taК»ehalaia:
\q1 
\v 12 Ke tau folo moК»ui hifo К»akinautolu К»o hangД“ ko e faК»itoka;
\q2 pea kДҒtoa pe, К»o hangД“ ko kinautolu К»oku К»alu hifo ki he luo:
\q1 
\v 13 Te tau К»ilo ai К»ae koloa kehekehe kotoa pД“,
\q2 te tau fakafonu hotau ngaahi fale К»aki К»ae koloa:
\q1 
\v 14 Ke tau К»inasi fakataha pe mo koe;
\q2 pea te tau kau taha pe К»i he kato paК»anga:вҖқ
\q1 
\v 15 вҖҢК»E hoku foha, К»oua naК»a ke К»alu К»i he hala mo kinautolu;
\q2 taК»ofi ho vaК»e mei honau hala:
\q1 
\v 16 He К»oku lele honau vaК»e ki he kovi,
\q2 К»onau fakatoК»otoК»o ke lilingi К»ae toto.
\q1 
\v 17 Ko e moК»oni К»oku tautau taК»eК»aonga К»ae kupenga К»i he К»ao К»o ha manupuna.
\q1 
\v 18 Pea К»oku nau toitoi ki honau toto К»onautolu pe;
\q2 mo nau lama fakafufЕ« ki heК»enau moК»ui К»anautolu pe.
\q1 
\v 19 He К»oku pehД“ pe К»ae hala К»okinautolu К»oku manumanu ki he koloa;
\q2 К»aia К»oku ne fakaК»osi К»ae moК»ui К»anautolu К»oku nau maК»u ia.
\b
\q1 
\v 20 вҖҢК»Oku kalanga К»ituК»a К»ae poto;
\q2 К»oku ne hiki hake hono leК»o К»i he ngaahi hala.
\q1 
\v 21 вҖҢК»Oku kalanga ia К»i he potu lahi К»oe fakatahaК»anga,
\q2 mo e ava К»oe ngaahi matapДҒ: pea К»i he loto kolo К»oku ne К»ai mai К»ene lea, К»o pehД“,
\q1 
\v 22 вҖңК»Akimoutolu К»ae kau vale, К»e fД“fД“ hono fuoloa К»o hoК»omou manako ki he vale?
\q2 Pea fiefia К»ae kau manuki К»i heК»enau manuki,
\q2 mo e fehiК»a К»ae kau vale ki he poto?
\q1 
\v 23 Mou tafoki К»i heК»eku valoki:
\q1 vakai, te u huaК»i hoku laumДҒlie kiate kimoutolu,
\q2 te u fakahДҒ К»eku ngaahi lea kiate kimoutolu.
\q1 
\v 24 KoeК»uhi kuo u ui, pea naК»e К»ikai te mou tali;
\q1 kuo u mafao atu hoku nima, kae К»ikai tokangaК»i К»e ha taha;
\q1 
\v 25 Pea kuo mou liК»aki К»eku akonaki,
\q2 pea naК»e К»ikai te mou loto ki heК»eku valoki:
\q1 
\v 26 Ko ia te u kata foki au К»i hoК»omou malaК»ia;
\q1 te u manuki К»i he tЕҚ mai К»a hoК»omou manavahД“;
\q1 
\v 27 вҖҢК»Io, К»oka hoko mai hoК»omou manavahД“ К»o hangД“ ko e fakaК»auha,
\q2 mo hoК»omou malaК»ia К»o hangД“ ko e К»ahiohio;
\q1 К»oka hoko mai К»ae mamahi mo e feinga kiate kimoutolu.
\q1 
\v 28 Pea te nau toki ui kiate au, ka К»e К»ikai te u tali;
\q1 te nau kumi toК»otoК»o kiate au, ka К»e К»ikai te nau К»ilo au:
\q1 
\v 29 KoeК»uhi naК»a nau fehiК»a ki he К»ilo,
\q2 pea naК»e К»ikai te nau loto ke manavahД“ kia Sihova:
\q1 
\v 30 NaК»e К»ikai te nau maК»u К»eku ngaahi akonaki,
\q2 pea naК»a nau manukiК»i К»a К»eku valoki kotoa pД“.
\q1 
\v 31 Ko ia te nau kai ai К»i he fua К»o К»enau faianga,
\q2 pea fakamДҒkona К»aki К»enau ngaahi filioК»i pe К»anautolu.
\q1 
\v 32 He ko e tafoki atu К»oe taК»epoto te ne tДҒmateК»i К»akinautolu,
\q2 pea К»e К»auha К»ae vale К»i heК»enau fakafiemДҒlie.
\q1 
\v 33 Ka ko ia kotoa pД“ К»oku fanongo kiate au К»e nofo fiemДҒlie pe ia,
\q2 pea К»e К»ataК»atДҒ ia mei he manavahД“ ki he kovi.вҖқ
\c 2
\cd \it 1 К»Oku fakahДҒ К»e he poto К»e maК»u К»ae mДҒК»oniК»oni К»e heК»ene fДҒnau, 10 Mo e maluК»i mei he kakai angakovi, 20 Mo e fakahinohino ki he ngaahi hala lelei.\it*
\q1 
\v 1 вҖҢК»E hoku foha, kapau te ke maК»u К»a К»eku ngaahi lea,
\q2 mo fakafufЕ« К»iate koe К»a К»eku ngaahi fekau;
\q1 
\v 2 KoeК»uhi ke fakatokangaК»i ho telinga ki he poto,
\q2 pea ke tokanga ai ho loto ki he faК»a fakakaukau;
\q1 
\v 3 вҖҢК»Io, kapau te ke tangi ki he К»ilo,
\q2 pea ke hiki hake ho leК»o ke maК»u К»ae fakakaukau:
\q1 
\v 4 Kapau te ke kumi ki ai К»o hangД“ ko e siliva,
\q2 pea hakule ki ai К»o hangД“ ko e koloa kuo fufЕ«;
\q1 
\v 5 Te ke toki К»ilo ai К»ae manavahД“ kia Sihova,
\q2 pea maК»u К»ae К»iloК»i К»oe К»Otua.
\q1 
\v 6 He К»oku foaki К»e Sihova К»ae poto:
\q2 К»oku haК»u mei hono fofonga К»ae К»ilo mo e fakakaukau.
\q1 
\v 7 вҖҢК»Oku tokonaki К»e ia К»ae poto К»aonga maК»a e kakai mДҒК»oniК»oni:
\q2 ko e fakaЕ« ia kiate kinautolu К»oku К»aК»eva К»i he angatonu.
\q1 
\v 8 вҖҢК»Oku ne tauhi К»ae hala К»oe fakamaau;
\q2 pea К»oku ne maluК»i К»ae hala К»o К»ene kakai mДҒК»oniК»oni.
\q1 
\v 9 Pea te ke toki К»ilo ai К»ae mДҒК»oniК»oni, mo e fakamaau, mo e fai totonu;
\q2 К»io, К»ae hala lelei kotoa pД“.
\q1 
\v 10 вҖҢК»Oka hЕ« К»ae poto ki ho loto,
\q2 pea mДҒlie К»ae К»ilo ki ho laumДҒlie;
\q1 
\v 11 вҖҢК»E fakamoК»ui koe К»e he faК»a fakakaukau,
\q2 pea К»e tauhi koe К»e he poto:
\q1 
\v 12 Ke fakamoК»ui koe mei he hala К»oe tangata kovi,
\q2 mei he tangata К»oku lea К»aki К»ae ngaahi meК»a kovi;
\q1 
\v 13 вҖҢК»Aia К»oku liК»aki К»ae hala К»oe mДҒК»oniК»oni,
\q2 kae К»alu К»i he ngaahi hala К»oe fakapoК»uli;
\q1 
\v 14 вҖҢК»Aia К»oku fiefia ke fai kovi,
\q2 pea К»oku fiemДҒlie К»i he talangataК»a К»ae angahala;
\q1 
\v 15 Pea К»oku pikopiko hono ngaahi hala,
\q2 pea kovi К»a hono ngaahi К»aluК»anga:
\q1 
\v 16 Ke fakamoК»ui koe mei he fefine muli,
\q2 К»io, mei he muli К»oku lea fakaoloolo;
\q1 
\v 17 вҖҢК»Aia kuo ne liК»aki К»ae fakahinohino К»i heК»ene kei siК»i,
\q2 pea kuo ne fakangalongaloК»i К»ae fuakava К»a hono К»Otua.
\q1 
\v 18 He К»oku tahifohifo hono fale ki he mate,
\q2 pea mo hono К»alunga ki he kakai mate.
\q1 
\v 19 вҖҢК»Oku К»ikai toe foki mai ha taha К»oku К»alu atu kiate ia,
\q2 pea К»oku К»ikai ke puke К»ekinautolu ki he ngaahi hala К»oe moК»ui.
\q1 
\v 20 KoeК»uhi ke ke К»eveК»eva koe К»i he hala К»ae kakai angalelei,
\q2 pea ke maК»u К»ae ngaahi К»aluК»anga К»oe mДҒК»oniК»oni.
\q1 
\v 21 KoeК»uhi К»e nofo К»ae angatonu К»i he fonua,
\q2 pea К»e nofomaК»u К»i ai К»ae haohaoa.
\q1 
\v 22 Ka К»e motuhi atu К»ae angahala mei he mДҒmani,
\q2 pea К»e taК»aki fuК»u hake mei ai К»ae fai kovi.
\c 3
\cd \it 1 Ko e enginaki ki he talangofua, 5 Ki he tui, 7 Ki he angavaivai, 9 Ki he faК»a fai lelei, 11 Mo e faК»a kДҒtaki. 13 Ko e koloa lahi К»ae poto. 19 Ko e mДҒlohi, 21 Pea mo e lelei lahi К»oe poto. 27 Ko e enginaki ki he faК»a angaК»ofa, 30 Mo e angalelei, 31 Mo e nofo fiemДҒlie. 33 Ko e malaК»ia К»oku К»i he kakai angakovi.\it*
\q1 
\v 1 вҖҢК»E hoku foha, К»oua naК»a fakangaloК»i К»a К»eku fono;
\q2 ka ke tauhi К»e ho loto К»a К»eku ngaahi fekau:
\q1 
\v 2 He koeК»uhi К»e fakalahi К»aki ia kiate koe К»ae ngaahi К»aho lЕҚloa,
\q2 mo e moК»ui fuoloa, pea mo e melino.
\q1 
\v 3 Ke К»oua naК»a mahuК»i К»iate koe К»ae manavaК»ofa mo e moК»oni:
\q2 nonoК»o ia ki ho kia;
\q2 tohi ia ki he kakano К»o ho loto:
\q1 
\v 4 Ko ia te ke К»ilo ai К»ae lelei,
\q2 pea К»e tДҒpuekina koe К»i he К»ao К»oe К»Otua mo e tangata.
\q1 
\v 5 Falala kia Sihova К»aki ho loto kotoa;
\q2 pea К»oua naК»a ke faК»aki ki ho poto К»oК»ou.
\q1 
\v 6 Ke ke fakaongoongo kiate ia К»i ho hala kotoa pД“,
\q2 pea К»e fakatonutonu К»e ia ho ngaahi К»aluК»anga.
\q1 
\v 7 вҖҢК»Oua naК»a ke pehД“ К»i ho mata К»oК»ou, К»oku ke poto:
\q2 ka ke manavahД“ kia Sihova, pea tafoki mei he kovi.
\q1 
\v 8 вҖҢК»E hoko ia ko e moК»ui ki ho pito,
\q2 mo e uho ki ho ngaahi hui.
\b
\p 
\v 9 В¶ FakaК»apaК»apa kia Sihova К»aki hoК»o koloa,
\q2 pea mo e К»uluaki fua К»o hoК»o meК»a kotoa pД“ kuo tupu:
\q1 
\v 10 Ko ia К»e fonu ai ho ngaahi feleoko К»i he mahu,
\q2 pea К»e hДҒ К»ae uaine foК»ou mei hoК»o ngaahi tataК»oК»anga.
\b
\q1 
\v 11 вҖҢК»E hoku foha, К»oua naК»a ke manukiК»i К»ae tautea meia Sihova;
\q2 pea К»oua naК»a ke fiu К»i heК»ene valoki:
\q1 
\v 12 He ko ia К»oku К»ofa ki ai К»a Sihova К»oku ne tautea;
\q2 К»o hangД“ pe ko e tamai ki he foha К»oku ne fiemДҒlie ai.
\b
\q1 
\v 13 вҖҢК»Oku monЕ«К»ia К»ae tangata ko ia К»oku ne maК»u К»ae poto,
\q2 mo e tangata К»oku ne lavaК»i К»ae К»ilo.
\q1 
\v 14 He К»oku maК»ongoК»onga hake ia К»i he fakatau К»oe siliva,
\q2 mo hono mahuК»inga К»i he koula lelei.
\q1 
\v 15 вҖҢК»Oku mahuК»inga hake ia К»i he ngaahi maka koloa:
\q2 pea К»oku К»ikai tatau mo ia К»ae ngaahi meК»a kotoa pД“ К»oku ke faК»a holi ki ai.
\q1 
\v 16 вҖҢК»Oku К»i hono nima toК»omataК»u К»ae ngaahi К»aho lЕҚloa;
\q2 pea К»oku К»i hono nima toК»ohema К»ae koloa mo e ongoongolelei.
\q1 
\v 17 Ko hono ngaahi hala ko e hala К»oe fiemДҒlie,
\q2 pea К»oku melino К»a hono ngaahi К»aluК»anga kotoa pД“.
\q1 
\v 18 Ko e К»akau ia К»oe moК»ui kiate kinautolu К»oku puke kiate ia:
\q1 pea К»oku monЕ«К»ia К»akinautolu kotoa pД“ К»oku kuku ia ke maК»u.
\q1 
\v 19 Kuo fokotuК»u К»e Sihova К»ae tuК»unga К»o mДҒmani К»i he poto;
\q2 pea К»i he К»ilo kuo ne teuteu ai К»ae ngaahi langi.
\q1 
\v 20 Ko e meК»a К»i heК»ene faК»a К»ilo К»oku mapunopuna hake ai К»ae ngaahi loloto,
\q2 pea К»oku toК»i К»ae hahau mei he ngaahi К»ao.
\q1 
\v 21 E hoku foha, К»oua naК»a ke tuku ke mole atu ia mei ho К»ao:
\q2 tauhi ke maК»u К»ae poto moК»oni mo e К»iloК»ilo.
\q1 
\v 22 Pea К»e hoko ai ia ko e moК»ui ki ho laumДҒlie,
\q2 mo e teunga lelei ki ho kia.
\q1 
\v 23 Pea te ke toki К»alu lelei К»i ho hala,
\q2 pea К»e К»ikai tЕ«kia ho vaК»e.
\q1 
\v 24 вҖҢК»Oka ke ka tokoto ki lalo, К»e К»ikai te ke manavahД“:
\q2 К»io, te ke tokoto hifo, pea К»e melie hoК»o mohe kiate koe.
\q1 
\v 25 вҖҢК»Oua naК»a ke manavahД“ ki ha meК»a fakailifia К»oku fakafokifДҒ mai;
\q2 pe ki he fakaК»auha К»oe angahala, К»oka hoko mai ia.
\q1 
\v 26 He ko ho falalaК»anga К»a Sihova,
\q2 pea К»e fakahaofi К»e ia ho vaК»e ke К»oua naК»a К»efihia.
\b
\q1 
\v 27 вҖҢК»Oua naК»a taК»ofi К»ae lelei meiate kinautolu К»oku totonu ke К»atu ia ki ai,
\q2 К»o kapau К»oku К»i ho nima hono mafai.
\q1 
\v 28 вҖҢК»Oua naК»a ke pehД“ ki ho kaungДҒК»api, вҖңК»Alu, pea ke toe haК»u,
\q2 pea te u foaki ia kiate koe К»apongipongi;вҖқ
\q1 kae К»osi К»oku ke maК»u pe К»ae meК»a К»iate koe.
\q1 
\v 29 вҖҢК»Oua naК»a ke filioК»i kovi ki ho kaungДҒК»api,
\q2 he К»oku ne nofo falala pe kiate koe.
\q1 
\v 30 вҖҢК»Oua naК»a fekuki mo ha taha taК»ehanoК»uhinga,
\q2 К»o kapau kuo К»ikai ke fai К»e ia ha kovi kiate koe.
\q1 
\v 31 вҖҢК»Oua naК»a ke meheka ki he tangata fakamДҒlohi,
\q2 pea К»oua naК»a ke fili ki hono ngaahi hala К»oК»ona.
\q1 
\v 32 He ko e angahala К»oku fakalielia ia kia Sihova:
\q2 ka К»oku К»i he mДҒК»oniК»oni К»a hono finangalo fufЕ«.
\q1 
\v 33 вҖҢК»Oku К»i he fale К»oe angahala К»ae fakamalaК»ia meia Sihova:
\q2 ka К»oku ne tДҒpuakiК»i К»ae nofoК»anga К»oe angatonu.
\q1 
\v 34 Ko e moК»oni К»oku ne manukiК»i К»ae kau manuki:
\q2 ka К»oku foaki К»e ia К»ae lelei ki he angavaivai.
\q1 
\v 35 вҖҢК»E maК»u К»e he poto К»ae ongoongolelei:
\q2 ka ko e hakeakiК»i К»oe vale ko e meК»a fakamДҒ.
\c 4
\cd \it 1 К»Oku fakahДҒ К»e Solomone К»ae ako naК»e fai К»e heК»ene mДҒtuК»a kiate ia, 5 Ke tokanga ki he poto, 14 Pea ke fehiК»a ki he hala К»oe kakai fai kovi. 20 К»Oku ne enginaki ki he tui, 23 Pea mo e mДҒК»oniК»oni.\it*
\q1 
\v 1 вҖҢК»Ae fДҒnau, mou fanongo ki he akonaki К»ae tamai,
\q2 pea tokanga ke К»ilo К»ae poto.
\q1 
\v 2 He К»oku ou foaki К»ae akonaki lelei kiate kimoutolu,
\q2 pea К»oua naК»a mou liК»aki К»a К»eku fono.
\q1 
\v 3 He ko e foha au К»o К»eku tamai,
\q2 ko e pele mo e К»ofeina taha pe au К»i he К»ao К»o К»eku faК»Д“.
\q1 
\v 4 NaК»a ne akonakiК»i foki au, К»o ne pehД“ mai,
\q2 вҖңTuku ke maК»u К»i ho loto К»a К»eku ngaahi lea:
\q1 tauhi К»a К»eku ngaahi fekau, ka ke moК»ui.вҖқ
\q1 
\v 5 Ke ke maК»u К»ae poto,
\q2 pea maК»u mo e К»ilo:
\q1 К»oua naК»a ngalo ia; pea К»oua naК»a ke fakaholomui mei he ngaahi lea К»a hoku ngutu.
\q1 
\v 6 вҖҢК»Oua naК»a liК»aki ia, pea te ne fakamoК»ui koe:
\q2 ke ke К»ofa kiate ia, pea te ne tauhi kiate koe.
\q1 
\v 7 Ko e poto ko e meК»a К»oku fungani hake ia;
\q2 ko ia ke ke maК»u К»ae poto:
\q1 pea К»i he meК»a kotoa pД“ К»oku ke maК»u, ke ke maК»u mo e К»ilo.
\q1 
\v 8 FakahikihikiК»i ia, pea te ne hakeakiК»i koe:
\q2 pea К»i hoК»o fДҒК»ufua kiate ia, te ne fakaongoongolelei koe.
\q1 
\v 9 вҖҢК»E ai К»e К»ia К»ae teunga matamatalelei ki ho К»ulu:
\q2 ko e tatДҒ К»oe nДҒunau te ne foaki kiate koe.вҖқ
\b
\q1 
\v 10 вҖҢК»E hoku foha, fanongo, pea ke maК»u К»a К»eku ngaahi tala,
\q2 pea К»e hoko ai К»o lahi К»ae ngaahi taК»u К»o hoК»o moК»ui.
\q1 
\v 11 Kuo u akonakiК»i koe К»i he hala К»oe poto;
\q2 pea kuo u tataki koe К»i he ngaahi К»aluК»anga totonu.
\q1 
\v 12 вҖҢК»Oka ke ka К»eveК»eva К»e К»ikai К»efihia ho vaК»e;
\q2 pea К»oka ke ka lele К»e К»ikai te ke hinga.
\q1 
\v 13 Puke ke maК»u К»ae akonaki;
\q2 К»oua naК»a tukuange ia:
\q2 kuku maК»u ia; he ko hoК»o moК»ui ia.
\q1 
\v 14 вҖҢК»Oua naК»a ke К»alu atu ki he hala К»oe angahala,
\q2 pea К»oua naК»a К»eveК»eva К»i he К»aluК»anga К»oe kakai angakovi.
\q1 
