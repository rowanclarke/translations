\p
\v 6 \w Por|strong="G1722"\w* tanto, \w de|strong="G1722"\w* \w la|strong="G3588"\w* manera \w que|strong="G3588"\w* \w recibieron|strong="G3880"\w* \w a|strong="G1722"\w* \w Cristo|strong="G5547"\w* \w Jesús|strong="G2424"\w* \w el|strong="G3588"\w* \w Señor|strong="G2962"\w*, vivan \w en|strong="G1722"\w* \w Él|strong="G3588"\w*,  
