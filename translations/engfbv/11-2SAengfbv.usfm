\p 
\v 6 \w David|strong="H1732"\w* \w then|strong="H6258"\w* spoke \w to|strong="H1121"\w* Abishai, saying, “\w Now|strong="H6258"\w* \w Sheba|strong="H7652"\w* \w the|strong="H3947"\w* \w son|strong="H1121"\w* \w of|strong="H1121"\w* \w Bichri|strong="H1075"\w* \w is|strong="H5892"\w* \w going|strong="H4672"\w* \w to|strong="H1121"\w* cause \w us|strong="H6435"\w* \w more|strong="H4480"\w* trouble \w than|strong="H4480"\w* Absalom \w did|strong="H5650"\w*. \w Take|strong="H3947"\w* \w the|strong="H3947"\w* king's \w men|strong="H1121"\w* \w and|strong="H1121"\w* \w chase|strong="H7291"\w* \w him|strong="H4672"\w* down, \w or|strong="H6435"\w* \w he|strong="H1732"\w* \w will|strong="H5650"\w* \w take|strong="H3947"\w* \w over|strong="H4480"\w* \w fortified|strong="H1219"\w* \w towns|strong="H5892"\w* \w and|strong="H1121"\w* \w get|strong="H3947"\w* \w away|strong="H3947"\w* \w from|strong="H4480"\w* \w us|strong="H6435"\w*.”
