\id SNG
\h إِزْڒِي خْ إِزْڒَانْ
\toc1 إِزْڒِي خْ إِزْڒَانْ
\toc2 إِزْڒِي خْ إِزْڒَانْ
\toc3 إِزْڒِي
\mt1 إِزْڒِي خْ إِزْڒَانْ
\c 1
\s1 مّژْرِي ن ثسْڒِيثْ إِ يسْڒِي
\m 
\v 1 إِزْڒِي خْ إِزْڒَانْ نِّي \add إِدْجَانْ\add* ن سُولِيمَانْ.
\b
\m 
\v 2 ”أجّْ إِ-ث أَذْ أَيِي إِسُّوذمْ
\m س إِسُوذِيمنْ ن ؤُقمُّومْ نّسْ،
\m مِينْزِي ؤُسْحِينّبْ نّشْ حْسنْ زِي بِينُو.
\m 
\v 3 ڒفْوَاحثْ ن زّشْثْ نّشْ ثشْنَا،
\m إِسمْ نّشْ أَمْ زّشْثْ إِزدْجْعنْ،
\m خْ ؤُيَا تّخْسنْثْ شكْ ثعْزَارِييِّينْ.
\m 
\v 4 جْبذْ أَيِي أَوَارْنِي أَشْ،
\m نشِّينْ أَذْ نَازّڒْ أَوَارْنِي أَشْ!
\m أَجدْجِيذْ إِنْذهْ أَيِي ذڭْ إِخَامّنْ نّسْ.
\m أجّْ أَنغْ أَذْ نَارْشقْ ؤُ أَذْ زَّايكْ نْفَارْحْ،
\m أَذْ نعْقڒْ خْ ؤُسْحِينّبْ نّشْ
\m كْثَارْ خْ مِينْ غَا نعْقڒْ خْ بِينُو.
\m نِيشَانْ تّخْسنْثْ شكْ.“
\b
\m 
\v 5 ”ذ ثَابَارْشَانْثْ نشّْ، ؤُ صبْحغْ،
\m \add أَ\add* يسِّيسْ ن ؤُرْشَالِيمْ،
\m أَمْ ثْقِيضُونِينْ ن قِيذَارْ،
\m أَمْ ڒِيزَارَاثْ ن سُولِيمَانْ.
\m 
\v 6 وَارْ ذ أَيِي خزَّارنْثْ \add أَمُّو\add*،
\m مِينْزِي نشّْ بَّارْشْنغْ،
\m مِينْزِي ثسّشْمضْ أَيِي ثْفُوشْثْ،
\m إِحنْجِيرنْ ن يمَّا ثُوغَا خيّْقنْ خَافِي،
\m ڭِّينْ أَيِي أَذْ حْضِيغْ إِمَارْجَاعنْ ن ؤُضِيڒْ.
\m أَمَارْجعْ ن يِيخفْ إِنُو وَارْ ث حْضِيغْ شَا.“
\b
\m 
\v 7 ”شكْ، ونِّي إِتّخْسْ بُوحْبڒْ إِنُو،
\m إِنِي أَيِي، مَانِي ثَاركّْوسذْ،
\m مَانِي ثسَّاريَّاحذْ \add ثَاحِيمَارْثْ\add*
\m غَارْ طْحَا ن ؤُزِيڒْ،
\m مِينْزِي إِ ؤُمِي غَا إِڒِيغْ أَمْ ثنِّي إِحجْبنْ
\m غَارْ ثْحِيمْرِيوِينْ ن إِمْعَاشَارنْ نّشْ؟“
\b
\m 
\v 8 ”مَاڒَا شمْ وَارْ ث ثسِّينذْ،
\m \add شمْ\add* ثنِّي إِشْنَانْ قَاعْ جَارْ ثمْغَارِينْ،
\m خنِّي فّغْ، ضْفَارْ ڒَاثَارْ ن وُودْجِي،
\m أَرْوسْ ثِيغَاضْثِينْ نّمْ
\m مَانِي زدّْغنْ إِمكْسَاونْ.“ \f ◼ \fr 1:‏8 \ft \bd ’إِمكْسَاونْ‘\bd* - نِيغْ ’إِنِيتْشَانْ‘.\f*
\b
\s1 ڒغْنُوجْ ن يسْڒِي ذ ثسْڒِيثْ س نُّوبْثَاثْ
\m 
\v 9 ”سّمْقُوذِّيغْ شمْ أَكْ-ذ ڒْعوْذَا إِنُو
\m زَّاثْ إِكَارُّوثنْ ن فِيرْعُونْ،
\m \add أَ\add* ثَامدُّوكّتْشْ إِنُو.
\m 
\v 10 مشْحَاڒْ صبْحنْ إِمڭِّيزنْ نّمْ
\m جَارْ ثْسدّْيِينْ،
\m إِرِي نّمْ جَارْ إِفِيڒَانْ س ثْيَاقُوثِينْ.
\m 
\v 11 أَذْ أَمْ نڭّْ ثِيسدّْيِينْ ن وُورغْ،
\m أَكْ-ذ ثْنقِّيضِينْ ن نُّوقَارْثْ.“
\b
\m 
\v 12 ”مِينْ غَا يكّْ ؤُجدْجِيذْ
\m \add إِقِّيمْ\add* غَارْ طَّابْڒَا نّسْ ثَاقُورَارِيثْ،
\m إِتِّيشّْ صّنْبلْ إِنُو ڒفْوَاحثْ نّسْ.
\m 
\v 13 لِّيفْ إِنُو إِتّڭّْ أَيِي
\m أَمْ ثشْيَارْثْ ن مِيرُّو،
\m ثنِّي إِسّنْسنْ جَارْ إِذْمَارنْ إِنُو.
\m 
\v 14 لِّيفْ إِنُو إِ نشّْ أَمْ
\m ثْقبِّيضْثْ ن نوَّاشْ ن ڒْحنِّي،
\m ذڭْ إِمَارْجَاعنْ ن ؤُضِيڒْ ن عَايْنْ-جَاذِي.“
\b
\m 
\v 15 ”خْزَارْ، ثشْنِيذْ شمْ،
\m ثَامدُّوكّتْشْ إِنُو!
\m خْزَارْ، شمْ ثشْنِيذْ،
\m ثِيطَّاوِينْ نّمْ ذ إِذْبِيرنْ.“
\b
\m 
\v 16 ”خْزَارْ، شكْ ثشْنِيذْ، \add أَ\add* لِّيفْ إِنُو،
\m وَاهْ، ثْضَارْفذْ،
\m ثُوزِّيزوْثْ ذ ثَاسُّوثْ نّغْ،
\m 
\v 17 ثِيحنْيَا ن ثُوذْرِينْ نّغْ ذ ثِينڭْلِينْ،
\m ثِيحنْيَا ن ثْزقَّا
\m أَقَا أَثنْثْ ذ ثِيشجُّورَا ن ؤُمرْزِي.“
\b
\b
\c 2
\s1 أَرْشَامْ ن ثسْڒِيثْ
\m 
\v 1 ”نشّْ ذ ثَانوَّاشْثْ ن شَارُونْ
\m وَارْ زَّايسْ وْضَانْثْ ثِيفْرَايْعمَّارْصْ،
\m ذ ثَالِيلّشْثْ ن ثيْسَارِينْ.“ \f ◼ \fr 2:‏1 \ft \bd ’ثَالِيلّشْثْ‘\bd* - إِجّْ ن مَارْكَا ن إِنُّووَّارنْ ذَايْسنْ أَژْرِي أَطَّاسْ.\f*
\b
\m 
\v 2 ”أَمْ ثْلِيلّشْثْ جَارْ ثْزڭّْوَارْثْ،
\m أَمُّو إِ ثدْجَا ثَامدُّوكّتْشْ إِنُو
\m جَارْ ثْيدْجِيثِينْ.“
\b
\s1 أَرْشَامْ ن يسْڒِي
\m 
\v 3 ”أَمْ ثْشجَّارْثْ ن تّفَّاحْثْ
\m جَارْ ثْشجُّورَا ن وزْغَارْ،
\m أَمُّو إِ يدْجَا لِّيفْ إِنُو جَارْ وَارَّاونْ.
\m نشّْ أَقَا أَيِي مّژْرغْ
\m أَذْ قِّيمغْ ذِي ثِيڒِي نّسْ.
\m ڒْْغِيدْجثْ نّسْ ذ مِيژِيذْ إِ وَانغْ إِنُو. \f ◼ \fr 2:‏3 \ft \bd ’أَزْغَارْ‘\bd* - نِيغْ ’ڒْغَابثْ‘ نِيغْ ’ثَازْڭَانْثْ‘.\f*
\m 
\v 4 نتَّا إِنْذهْ أَيِي ذِي ثَادَّارْثْ ن بِينُو،
\m ؤُ \bd ثَايْرِي\bd* ذ ثَاعدْجَانْثْ نّسْ خَافِي.
\b
\m 
\v 5 سْجهْذمْ أَيِي س ثْغَارْيِيطَاثِينْ ن زّْبِيبْ،
\m سْبَارّْذمْ أَيِي س تّفَّاحِينْ،
\m مَاغَارْ نشّْ هڒْشغْ س \bd ثَايْرِي\bd*.
\b
\m 
\v 6 أَزڒْمَاضْ نّسْ سَاذُو ؤُزدْجِيفْ إِنُو،
\m أَفُوسِي نّسْ إِذَارّعْ أَيِي-د.
\b
\m 
\v 7 نشّْ أَذْ كنِّينْثْ سّْجَادْجَاغْ،
\m \add أَ\add* يسِّيسْ ن ؤُرْشَالِيمْ،
\m غَارْ ثْغَايْضِينْ ن وزْغَارْ
\m ؤُ غَارْ ثُوذَاذِينْ ذڭْ إِيَّارْ\add أنْ\add*،
\m أَقَا كنِّينْثْ وَارْ هكّْوْڒنْثْ \bd ثَايْرِي\bd*،
\m وَارْ ت-إِ-د-سّكَّارَانْثْ
\m أَڒْ ثتّخْسْ سِيمَانْثْ نّسْ.“
\b
\s1 ثَاوَاسِيثْ ن يسْڒِي
\m 
\v 8 ”ثْمِيجَّا ن لِّيفْ إِنُو!
\m أَقَا ذَا، إِتَّاسْ-د،
\m إِنطُّو خْ إِذُورَارْ،
\m إِنڭّزْ خْ ثوْرِيرِينْ!
\b
\m 
\v 9 لِّيفْ إِنُو \add يَارْوسْ\add* ذڭْ إِغَايْضْ ن وزْغَارْ،
\m نِيغْ ذڭْ إِجّْ ن ؤُمژْيَانْ ن وُوذَاذنْ.
\m أَقَا-ث ذَا، إِبدّْ أَوَارْنِي إِ ڒْحِيضْ نّغْ،
\m إِخزَّارْ زِي ڒكْوَازِي،
\m إِتّْشيّعْ زِي شّبَّاشْ.“
\b
\s1 ڒعْرُوضْ ن يسْڒِي
\m 
\v 10 ”لِّيفْ إِنُو إِتَّارَّا-د، إِنَّا أَيِي:
\m ’كَّارْ، بدّْ، \add أَ\add* ثَامدُّوكّتْشْ إِنُو، أَژْرِي إِنُو،
\m أَسْ-د!
\m 
\v 11 مَاغَارْ أَقَا ذَا، ثَاڭرْسْثْ ثعْذُو،
\m إِكْسِي ونْژَارْ، أَقَا إِرُوحْ.
\m 
\v 12 بَاننْ-د إِنُووَّارنْ ذِي ثمُّورْثْ،
\m ڒْْحَاڒْ ن ونْزِيزْ أَقَا-ث ذَا،
\m ؤُ ثْمِيجَّا ن ثْجْلِيلّحْثْ نسْڒَا إِ-ت \add عَاوذْ\add*
\m ذِي ثمُّورْثْ نّغْ.
\m 
\v 13 أَرْثُو ن ثَازَارْثْ إِتّْخمَّاڒْ ڒْبَاشُورْ نّسْ،
\m ثِيزَايَارِينْ إِتّْنوَّارنْ أَرْخُونْ إِ ڒفْوَاحْ.
\m كَّارْ، بدّْ، ثَامدُّوكّتْشْ إِنُو،
\m أَژْرِي إِنُو،
\m أَسْ-د!‘ “
\b
\s1 إِسْڒِي يَارنِّي ذِي ڒعْرُوضْ
\m 
\v 14 ”ثَاذْبِيرْثْ إِنُو
\m ذڭْ إِمُوشَانْ ن ؤُذُورِّي ذِي ڒجْرُوفْ،
\m ثْنُوفَّارْ ذِي ثْسَاونْثْ \add ن وذْرَارْ\add*.
\m أجّْ أَيِي أَذْ ژَترغْ أَغمْبُوبْ نّمْ،
\m أَذْ سْڒغْ إِ ثْمِيجَّا نّمْ،
\m مَاغَارْ ذ ثْمِيژِيذْثْ \add إِ ثدْجَا\add* ثْمِيجَّا نّمْ،
\m إِصْبحْ ؤُغمْبُوبْ نّمْ.“
\b
\s1 ثَاسْڒِيثْ ثخْسْ أَذْ ثِيڒِي إِ يسْڒِي وَاهَا
\m 
\v 15 ”طّْفمْ أَنغْ-د إِشعْبَاونْ،
\m إِشعْبَاونْ إِمژْيَاننْ،
\m إِنِّي إِتَّارْيْثَارنْ \add أَنغْ\add* إِمَارْجَاعنْ ن ؤُضِيڒْ،
\m مَاغَارْ ثِيزَايَارِينْ ذڭْ إِمَارْجَاعنْ نّغْ
\m تّْنوَّارنْثْ \add عَاذْ\add*.
\b
\m 
\v 16 لِّيفْ إِنُو أَقَا-ث إِنُو ؤُ نشّْ نّسْ،
\m نشّْ ن ونِّي يَاركّْوْسنْ جَارْ ثْلِيلِّيشِينْ
\m 
\v 17 أَڒْ إِ غَا إِسْمضْ وَاسّْ
\m ؤُ أَذْ أَروْڒنْثْ ثِيڒِيوِينْ.
\b
\m نّضْ-د، \add أَ\add* لِّيفْ إِنُو،
\m إِڒِي أَمْ يِيجّْ ن إِغَايْضْ ن وزْغَارْ
\m نِيغْ أَمْ يِيجّْ ن ؤُمژْيَانْ ن وُوذَاذنْ
\m خْ إِذُورَارْ \add إِ إِتّْوَاقضْعنْ\add* س ثيْسَارِينْ.“
\b
\b
\c 3
\s1 مّژْڒِي ن ثسْڒِيثْ إِ يسْڒِي
\m 
\v 1 ”أَرْزُوغْ خَاسْ ذِي دْجْيَاڒِي
\m \add أَمْ دْجِيغْ\add* خْ ثَاسُّوثْ إِنُو،
\m \add أَرْزُوغْ خْ\add* ونِّي إِتّخْسْ ڒعْمَارْ إِنُو.
\m نشّْ أَرْزُوغْ خَاسْ،
\m \add مَاشَا نشّْ\add* وَارْ ث ؤُفِيغْ.
\m 
\v 2 \add نشّْ نِّيغْ\add*: ’أَذْ كَّارغْ،
\m أَذْ سُوحغْ ذِي ثنْذِينْثْ،
\m ذڭْ إِبْرِيذنْ ؤُ خْ وَازَّاينْ.
\m نشّْ أَذْ خَاسْ أَرْزُوغْ، \add أَذْ أَرْزُوغْ\add*
\m \add خْ\add* ونِّي إِتّخْسْ ڒعْمَارْ إِنُو.‘
\m نشّْ أَرْزُوغْ خَاسْ، \add مَاشَا\add* وَارْ ث ؤُفِيغْ.
\m 
\v 3 ؤُفِينْ أَيِي إِعسَّاسنْ
\m أَمْ تّنّْضنْ ذِي ثنْذِينْثْ.
\m نشّْ نِّيغْ: ’مَا ثژْرِيمْ كنِّيوْ
\m ونِّي إِتّخْسنْ ڒعْمَارْ إِنُو؟‘
\m 
\v 4 ڒَامِي ثُوغَا عَاذْ وَارْ خَاسنْ عْذُوغْ، ؤُفِيغْ ث،
\m ونِّي إِتّخْسنْ ڒعْمَارْ إِنُو.
\m نشّْ طّْفغْ ث، وَارْ زَّايسْ أَرخُّوغْ
\m أَڒَامِي ث-إِ-د-إِوْيغْ
\m غَارْ ثَادَّارْثْ ن يمَّا،
\m ذڭْ وخَّامْ ن ذَاخڒْ
\m ن ثنِّي إِ د أَيِي يُورْونْ.
\b
\m 
\v 5 نشّْ أَذْ كنِّينْثْ سّْجَادْجَاغْ،
\m \add أَ\add* يسِّيسْ ن ؤُرْشَالِيمْ،
\m غَارْ ثْغَايْضِينْ ن وزْغَارْ
\m ؤُ غَارْ ثُوذَاذِينْ ذڭْ إِيَّارْ\add أنْ\add*،
\m أَقَا كنِّينْثْ وَارْ هكّْوْڒنْثْ \bd ثَايْرِي\bd*،
\m وَارْ ت-إِ-د-سّكَّارَانْثْ
\m أَڒْ ثتّخْسْ سِيمَانْثْ نّسْ.“
\b
\s1 ثَاوَاسِيثْ ن كُولَا أَكْ-ذ يسْڒِي إِ ڒمْڒَاشْ
\m 
\v 6 ”مِينْ ثعْنَا ثنِّي إِ د-إِڭعّْذنْ زِي ڒخْڒَا،
\m أَمْ إِقلِّيجنْ ن دّخَّانْ،
\m ذڭْ إِجّْ ن ؤُسيْنُو ن مِيرُّو ذ جَّاوِي،
\m ن مَارَّا ڒبْزَارْ إِتّْفُوحنْ ن ؤُسبَّابْ؟ \x ◘ \xo 3:‏6 \xt إِزْڒِي 3‏:‏6\x*
\m 
\v 7 خْزَارْ، ڒشْثُو \add ن ثْربُّوثْ\add* ن سُولِيمَانْ،
\m تّنّْضنْ أَسْ-د ستِّينْ ن أَيْثْ ن بُو-ثغْرُوضْثْ،
\m زڭْ أَيْثْ ن بُو-ثغْرُوضْثْ ن إِسْرَائِيل،
\m 
\v 8 مَارَّا إِنِّي إِتّطّْفنْ سِّيفْ،
\m إِنِّي إِڒمّْذنْ أَمنْغِي،
\m كُوڒْ إِجّْ س سِّيفْ نّسْ غَارْ ثْمصَّاضْثْ نّسْ
\m زِي سِّيبّثْ ن مِينْ إِسَّاڭّْوَاذنْ ذِي دْجِيڒثْ.
\m 
\v 9 أَجدْجِيذْ سُولِيمَانْ إِڭَّا إِ يِيخفْ نّسْ
\m إِجّْ ن ڒشْثُو إِ ثْربُّوثْ س ؤُكشُّوضْ ن لُوبْنَانْ.
\m 
\v 10 إِعُومَاذْ \add غَارْ ثغْمَارْثْ\add*
\m إِڭَّا إِ-ثنْ س نُّوقَارْثْ،
\m أَعمّذْ ن وعْرُورْ ن وُورغْ
\m ؤُشَا أَغِيمِي نّسْ ن أَرْجُووَانِي.
\m ذَاخڒْ نّسْ يَارْضنْ ث
\m س \bd ثَايْرِي\bd* ن يسِّيسْ ن ؤُرْشَالِيمْ.“
\b
\m 
\v 11 ”فّْغنْثْ ؤُ خْزَارنْثْ،
\m \add كنِّينْثْ\add* يسِّيسْ ن صِيهْيُونْ،
\m \add أَقَا ذَا\add* أَجدْجِيذْ سُولِيمَانْ
\m أَكْ-ذ تَّاجْ إِ زِي ث ثْڭلّذْ يمَّاسْ
\m ذڭْ وَاسّْ ن وُورَارْ نّسْ،
\m ذڭْ وَاسّْ ن ڒفْرَاحثْ \add يُوژْغنْ\add*
\m ذڭْ وُوڒْ نّسْ.“
\b
\b
\c 4
\s1 إِزْڒِي ن يسْڒِي خْ ثسْڒِيثْ
\m 
\v 1 ”خْزَارْ، ثشْنِيذْ شمْ،
\m ثَامدُّوكّتْشْ إِنُو،
\m شمْ ثشْنِيذْ.
\m أَوَارْنِي لّْثَامْ نّمْ
\m ثِيطَّاوِينْ نّمْ ذ ثِيذْبِيرِينْ.
\m أَشُوَّافْ نّمْ
\m أَمْ ثْحِيمَارْثْ ن إِغَايْضنْ
\m إِ د-إِهكّْوَانْ زڭْ إِذُورَارْ ن جِيلْعَاذْ.
\m 
\v 2 ثِيغْمَاسْ نّمْ ڭِّينْثْ
\m أَمْ ثْحِيمَارْثْ ن وُودْجِي ڒْسِينْ ثنْثْ،
\m إِنِّي د-إِتّْڭعَّاذنْ
\m زڭْ ومْشَانْ ن ؤُصبّنْ،
\m مَارَّا \add ثِيخسْوِينْ\add* ؤُرْونْثْ ثَاشْنِيوِينْ،
\m وَارْ ثقِّيمْ إِشْثْ نْبْڒَا إِحنْجِيرنْ.
\m 
\v 3 إِينْشِيشنْ نّمْ
\m أَمْ ؤُفِيڒُو أَزڭّْوَاغْ إِحذْقنْ،
\m إِصْبحْ ؤُقمُّومْ نّمْ.
\m لْحنْكَاثْ نّمْ أَمْ ثْرمَّانْثْ إِبْضَانْ
\m سَاذُو لّْثَامْ نّمْ.
\m 
\v 4 إِرِي نّمْ أَمْ صُّومْعثْ ن ذَاوُوذْ،
\m بْنَانْ ت أَمْ ثسْفِيفِينْ \add ن ثْسدّْيِينْ\add*.
\m أَڒفْ ن ثْسدَّارِييِينْ \add ن ؤُعسْكَارِي\add* ؤُيْڒنْثْ غَارسْ،
\m مَارَّا أَمْ ثْسدَّارِييِينْ \add إِقسْحنْ إِقُورَارنْ\add*
\m ن أَيْثْ ن بُو-ثغْرُوضْثْ.
\m 
\v 5 إِذْمَارنْ نّمْ ڭِّينْ
\m أَمْ ثْنَاينْ ن إِغَايْضنْ إِمژْيَاننْ،
\m أَمْ وَاشْنِيونْ ن ثْغَايْضثْ ن وزْغَارْ،
\m تّْهدَّانْ ذِي ثْلِيلِّيشِينْ.\f ◼ \fr 4:‏5 \ft \bd ’ثِيلِيلِّيشِينْ‘\bd* - إِجّْ ن مَارْكَا ن إِنُووَّارنْ ذَايْسنْ أَژْرِي أَطَّاسْ.\f*
\b
\m 
\v 6 أَڒْ إِ غَا إِسْمضْ وَاسّْ
\m ؤُ أَذْ أَروْڒنْثْ ثِيڒِيوِينْ،
\m أَذْ ؤُيُورغْ غَارْ وذْرَارْ ن ؤُمِيرُّو،
\m غَارْ ثوْرِيرْثْ ن جَّاوِي.
\m 
\v 7 شمْ مَارَّا ذ أَژْرِي، ثَامدُّوكّتْشْ إِنُو،
\m وَارْ ذَايمْ ؤُڒَا ذ إِجّْ نْ ڒْعِيبْ.
\b
\m 
\v 8 \add أَسْ-د\add* أَكِيذِي زڭْ \add إِذُورَارْ ن\add* لُوبْنَانْ،
\m \add أَ\add* ثَاسْڒِيثْ إِنُو،
\m أَسْ-د أَكِيذِي زڭْ \add إِذُورَارْ ن\add* لُوبْنَانْ،
\m صْوذْ-د زِي ثْقِيشّثْ ن أَمَانَا،
\m زِي ثْقِيشّثْ ن شَانِيرْ ذ هِيرْمُونْ،
\m زِي غَارْ ڒْمَارَاڭحْ ن وَايْرَاذنْ،
\m زڭْ إِذُورَارْ ن إِغِيڒَاسنْ.
\m 
\v 9 ثُوشَارذْ أَيِي ؤُڒْ، \add أَ\add* ؤُتْشْمَا، \add أَ\add* ثَاسْڒِيثْ \add إِنُو\add*،
\m \add وَاهْ\add* ثُوشَارذْ أَيِي ؤُڒْ،
\m س إِشْثْ ن \add ڒْْخزْرَاثْ ن\add* ثِيطَّاوِينْ نّمْ،
\m س إِشْثْ ن ثْسدّشْثْ ن يِيرِي نّمْ.
\m 
\v 10 مَامّشْ ثشْنَا ؤُسْحِينّبْ نّمْ،
\m \add أَ\add* ؤُتْشْمَا، \add أَ\add* ثَاسْڒِيثْ \add إِنُو\add*،
\m مشْحَاڒْ ثصْبحْ ؤُسْحِينّبْ نّمْ خْ بِينُو،
\m ڒفْوَاحثْ ن زّشْثْ نّمْ خْ مَارَّا ڒعْطُورْ.
\m 
\v 11 زڭْ إِينْشِيشنْ نّمْ، \add أَ\add* ثَاسْڒِيثْ \add إِنُو\add*،
\m ثتُّوذُومْ ثَامّنْثْ ن ثغْرَاصْثْ،
\m ثَامّنْثْ ذ ؤُغِي سَاذُو إِڒسْ نّمْ،
\m ؤُ ڒفْوَاحثْ ن وَارُّوضْ نّمْ
\m أَمْ ڒفْوَاحثْ \add ن إِذُورَارْ ن\add* لُوبْنَانْ.
\b
\m 
\v 12 \add أَ\add* ؤُتْشْمَا، \add أَ\add* ثَاسْڒِيثْ \add إِنُو\add*،
\m شمْ ذ ثَاحْوِيشْثْ إِبلّْعنْ،
\m ذ ثَاڒَا إِقّْننْ، ذ ڒْعُونْصَارْ إِشمّْعنْ.
\m 
\v 13 ڒفْرُوعْ إِ زَّايمْ إِسّْنطِّيينْ
\m ذ جنّثْ ن ثْرمَّانِينْ،
\m س ڒْغِيدْجثْ إِصبْحنْ أَطَّاسْ،
\m نّوَّاشْ ن ڒْحنِّي ذ صّنْبلْ،
\m 
\v 14 صّنْبلْ ذ زّْعفْرَانْ،
\m س ؤُغَانِيمْ ؤُحمُّومْ إِتّْفُوحنْ
\m أَكْ-ذ ڒْقَارْفَا،
\m عْڒَامْ كُوڒْ ثِيشجُّورَا ن جَّاوِي،
\m مِيرُّو ذ وشْفِيڒْ،
\m أَكْ-ذ مَارَّا ڒعْطُورْ إِصبْحنْ قَاعْ.
\m 
\v 15 \add أَ\add* ثَاڒَا ن إِحْوِيشنْ،
\m أَنُو ن وَامَانْ إِدَّارنْ،
\m إِنِّي د-إِتَّازّْڒنْ زڭْ \add إِذُورَارْ ن\add* لُوبْنَانْ.“
\b
\s1 ثَاسْڒِيثْ ثسِّيوڒْ، إِسْڒِي يَارَّا-د
\m 
\v 16 ”كَّارْ، \add أَ\add* أَسمِّيضْ ن نّجْ،
\m أَسْ-د، \add أَ\add* أَسمِّيضْ ن سْوَادَّايْ،
\m سُوضْ خْ وحْوِيشْ إِنُو،
\m أجّْ \add ڒفْوَاحثْ ن\add* ڒعْطُورْ نّسْ أَذْ ثُويُورْ.
\m أجّْ لِّيفْ إِنُو أَذْ د-يَاسْ غَارْ وحْوِيشْ نّسْ،
\m أَذْ إِشّْ زِي ڒْغِيدْجثْ نّسْ إِصبْحنْ!“
\b
\b
\c 5
\m 
\v 1 ”نشّْ ؤُسِيغْ-د غَارْ وحْوِيشْ إِنُو،
\m \add أَ\add* ؤُتْشْمَا، \add أَ\add* ثَاسْڒِيثْ إِنُو،
\m ڒقْضغْ مِيرُّو إِنُو أَكْ-ذ بَالْسَامْ. إِنُو،
\m شِّيغْ أَغْرُومْ ن ثْزِيزْوَا أَكْ-ذ ثَامّنْثْ إِنُو،
\m سْوِيغْ بِينُو إِنُو ذ ؤُغِي إِنُو.
\m إِمدُّوكَّاڒْ، أشّمْ، سْومْ،
\m سْشَارمْ، \add أَ\add* إِمْعِيزّنْ!“ \f ◼ \fr 5:‏1 \ft \bd ’أَزْغَارْ‘\bd* - نِيغْ ’ڒْغَابثْ‘ نِيغْ ’ثَازْڭَانْثْ‘.\f*
\b
\s1 ثَاسْڒِيثْ ثْزهْزَا أَذْ ثَارْزمْ إِ يسْڒِي
\m 
\v 2 ”نشّْ طّْسغْ، مَاشَا ؤُڒْ إِنُو إِفَاقْ.
\m \add أَقَا ذَا\add* ثْمِيجَّا ن لِّيفْ إِنُو،
\m ونِّي إِسّْقَارْقْبنْ:
\m ’أَرْزمْ أَيِي، \add أَ\add* ؤُتْشْمَا، ثَامدُّوكّتْشْ إِنُو،
\m ثَاذْبِيرْثْ إِنُو، \add أَ\add* كُوڒْشِي إِنُو،
\m مَاغَارْ أَزدْجِيفْ إِنُو إِشُّورْ س نّْذَا،
\m إِمُوزَارنْ إِنُو \add شُّورنْ\add* س ثُوذِّيمِينْ ن دْجِيڒثْ!‘
\b
\m 
\v 3 أَقَا كّْسغْ أَرُّوضْ إِنُو،
\m مَامّشْ إِ ث غَا يَارْضغْ عَاوذْ؟
\m إِضَارنْ سِّيرْذغْ ثنْ،
\m مَا أَذْ ثنْ سّْخمْجغْ عَاوذْ؟
\b
\m 
\v 4 لِّيفْ إِنُو إِسّكّْ-د أَفُوسْ نّسْ
\m زڭْ ؤُنُوقِّيبْ ن ثوَّارْثْ،
\m ؤُشَا إِنْهزّْ وُوڒْ إِنُو زَّايسْ.
\b
\m 
\v 5 نشّْ بدّغْ حِيمَا أَذْ أَرْزْمغْ إِ لِّيفْ إِنُو،
\m إِفَاسّنْ إِنُو ؤُذُومنْ س مِيرُّو،
\m \add زڭْ\add* إِضوْضَانْ إِنُو إِسِّيزّڒْ مِيرُّو
\m خْ إِفَاسّنْ ن زّكْرُونْ.
\m 
\v 6 نشّْ أَرْزْمغْ إِ لِّيفْ إِنُو،
\m \add مَاشَا\add* لِّيفْ إِنُو ثُوغَا يُويُورْ، إِعْذُو.
\m إِفّغْ ڒعْمَارْ إِنُو ؤُمِي ثُوغَا إِسَّاوَاڒْ!
\m نشّْ أَرْزُوغْ خَاسْ، \add مَاشَا\add* وَارْ ث ؤُفِيغْ.
\m نشّْ ڒَاغِيغْ أَسْ، نتَّا وَارْ خَافِي د-يَارِّي.
\b
\m 
\v 7 ؤُفِينْ أَيِي إِعسَّاسنْ
\m غَارْ ونّضْ نْسنْ ذِي ثنْذِينْثْ،
\m نِيثْنِي وْثِينْ أَيِي، يزْمنْ أَيِي،
\m أَقنْذُورْ إِنُو كّْسنْ أَيِي ث إِعسَّاسنْ ن ڒحْيُوضْ.“
\b
\s1 إِزْڒِي ن ثسْڒِيثْ أَكْ-ذ يسِّيسْ ن ؤُرْشَالِيمْ
\m 
\v 8 ”نشّْ أَذْ كنِّينْثْ سّْجَادْجَاغْ،
\m \add أَ\add* يسِّيسْ ن ؤُرْشَالِيمْ،
\m مَاڒَا كنِّينْثْ ثُوفِينْثْ لِّيفْ إِنُو،
\m مِينْ ذ أَسْ غَا ثِينِينْثْ؟
\m أَقَا ثسّحْڒشْ أَيِي \bd ثَايْرِي\bd*.“
\b
\m 
\v 9 ”مِينْ غَارسْ غَارْ لِّيفْ نّمْ
\m كْثَارْ خْ لِّيفْ \add نّغْنِي\add*،
\m \add أَ\add* شمْ إِ ذِي إِدْجَا وَاژْرِي قَاعْ زِي ثمْغَارِينْ؟
\m مِينْ غَارسْ غَارْ لِّيفْ نّمْ كْثَارْ خْ إِنّغْنِي،
\m أَقَا شمْ أَمُّو إِ ذ أَنغْ ثسّْجَادْجَاذْ؟“
\b
\m 
\v 10 ”لِّيفْ إِنُو ذ أَشمْڒَاڒْ \add إِتِّيسِّيقنْ\add*
\m ذ أَزڭّْوَاغْ \add أَمْ إِذَامّنْ\add*،
\m \add إِتّْبَانْ\add* أَمْ ؤُبَانْذُو سنّجْ خْعشْرَا ن ڒُوڒُوفْ.
\m 
\v 11 أَزدْجِيفْ نّسْ ذ ؤُرغْ إِقُّورْ إِصْفَانْ،
\m إِمُوزَارنْ ن ؤُشُوَّافْ نّسْ ذ ثِيوْرِيرِينْ
\m إِتّڭّنْ أَمْ ڒمْوَاجْ،
\m ذ إِبَارْشَاننْ أَمْ يِيبَاغْڒِيونْ.
\m 
\v 12 ثِيطَّاوِينْ نّسْ ڭِّينْثْ أَمْ ثذْبِيرِينْ
\m غَارْ ثْسدْجْيَاوِينْ ن وَامَانْ،
\m عُومّنْثْ ذڭْ ؤُغِي،
\m قِّيمنْثْ ذِي ثْشُويَارْ نْسنْ
\m \add أَمْ إِژْرَا إِغْڒَانْ\add*.
\m 
\v 13 إِمڭِّيزنْ نّسْ ڭِّينْ
\m أَمْ يِيحْوِيشنْ ن ڒعْطُورْ،
\m \add شُّورنْ س\add* ڒعْشُوبْ إِتّْفُوحنْ،
\m إِينْشِيشنْ نّسْ أَمْ ثْلِيلِّيشِينْ،
\m تُّوذُومنْ س مِيرُّو إِفسْينْ. \f ◼ \fr 5:‏13 \ft \bd ’ثِيلِيلِّيشِينْ‘\bd* - إِجّْ ن مَارْكَا ن إِنُّووَّارنْ ذَايْسنْ أَژْرِي أَطَّاسْ.\f*
\m 
\v 14 إِغَادْجنْ نّسْ أَمْ يِيقضْبَانْ ن وُورغْ،
\m عمَّارنْثْ س \add إِژْرَا ن\add* ثخْرِيسُولِيثْ،
\m أَعذِّيسْ نّسْ إِڭَّا أَمْ ڒْعَاجْ إِتِّيسِّيقنْ،
\m ڒحّْفنْ ث س ثْيَاقُوثِينْ ن صَافِّيرْ.
\m 
\v 15 إِمسْضَانْ نّسْ ذ إِپِيلَارنْ ن ڒْمَارْمُورْ،
\m خْ ذْسُوسَا ن وُورغْ إِتّْوَاصفَّانْ.
\m إِبَانْ-د نتَّا أَمْ لُوبْنَانْ،
\m إِتّْوَافَارْزْ أَمْ \add ثْشجَّارْثْ ن\add* ثنْڭلْثْ.
\m 
\v 16 أَنغْ نّسْ إِشُّورْ س ثَاژْيُوذِي،
\m مَارَّا إِ غَارسْ إِشُووَّارْ.
\m وَا ذ لِّيفْ إِنُو،
\m وَا ذ أَمدُّوكّڒْ إِنُو،
\m \add أَ كنِّينْثْ\add* يسِّيسْ ن ؤُرْشَالِيمْ!“
\b
\b
\c 6
\s1 ثَانڭَّارُوثْ ن إِزْڒِي ن ثسْڒِيثْ
\m 
\v 1 ”مَانِي يُويُورْ لِّيفْ نّمْ،
\m \add أَ\add* شمْ إِشْنَانْ قَاعْ خْ ثمْغَارِينْ؟
\m مَانِي يَارَّا س ؤُزدْجِيفْ لِّيفْ نّمْ؟
\m نشِّينْ نخْسْ أَذْ خَاسْ نَارْزُو أَكِيذمْ!“
\b
\m 
\v 2 ”لِّيفْ إِنُو إِهْوَا غَارْ ؤُحْوِيشْ نّسْ،
\m غَارْ ثْبُوذَا س ڒعْطُورْ،
\m حِيمَا أَذْ يَارْوسْ ذڭْ إِحْوِيشنْ،
\m حِيمَا أَذْ إِسّْمُونْ ثِيلِيلِّيشِينْ. \f ◼ \fr 6:‏2 \ft \bd ’ثِيلِيلِّيشِينْ‘\bd* - إِجّْ ن مَارْكَا ن إِنُّووَّارنْ ذَايْسنْ أَژْرِي أَطَّاسْ.\f*
\m 
\v 3 نشّْ زڭْ لِّيفْ إِنُو،
\m ؤُ لِّيفْ إِنُو أَقَا-ث إِنُو،
\m نتَّا ذ ونِّي يَاركّْوْسنْ جَارْ ثْلِيلِّيشِينْ.“
\b
\s1 أَسْڒِي إِغنّجْ خْ وژْرِي ن ثسْڒِيثْ
\m 
\v 4 ”شمْ ثْصبْحذْ، \add أَ\add* ثَامدُّوكّتْشْ إِنُو،
\m أَمشْنَاوْ ثِيرْصَا،
\m ثشْنِيذْ أَمْ ؤُرْشَالِيمْ،
\m ثسَّاڭّْوَاذذْ أَمْ يِيسذِّييّنْ ن ڒْعسْكَارْ
\m س إِبَانْذُوثنْ \add نْسنْ\add*.
\m 
\v 5 كّسْ ثِيطَّاوِينْ زَّايِي،
\m مَاغَارْ نِيثنْثِيغضْڒنْثْ أَيِي إِفَادّنْ أَطَّاسْ.
\m أَشُوَّافْ نّمْ أَمْ ثْحِيمَارْثْ ن إِغَايْضنْ
\m إِ د-إِهكّْوَانْ زڭْ \add إِذُورَارْ ن\add* جِيلْعَاذْ.
\m 
\v 6 ثِيغْمَاسْ نّمْ ڭِّينْثْ أَمْ ثْحِيمَارْثْ ن وُودْجِي،
\m إِ د-إِتّْڭعَّاذنْ زڭْ ومْشَانْ ن ؤُصبّنْ.
\m مَارَّا \add ثِيخسْوِينْ\add* ؤُرْونْثْ ثَاشْنِيوْثْ،
\m وَارْ ثقِّيمْ إِشْثْ نْبْڒَا إِحنْجِيرنْ.
\m 
\v 7 لْحنْكَاثْ نّمْ أَمْ ثْرمَّانْثْ إِبْضَانْ
\m أَوَارْنِي إِ لّْثَامْ نّمْ.
\m 
\v 8 أَقَا ذِينْ ستِّينْ ن ثْجدْجِيذِينْ
\m ذ ثْمنْيِينْ ن ثِييَّا،
\m ؤُڒَا ذ ثِيعْزَارِييِّينْ بْڒَا ڒحْسَابْ.
\m 
\v 9 وحّْذسْ نتَّاثْ، ثَاذْبِيرْثْ إِنُو،
\m ثنِّي إِكمّْڒنْ إِنُو،
\m أَينِّي ن يسِّيسْ ن يمَّاسْ،
\m نتَّاثْ ذ ثنِّي إِفَارْزنْ
\m غَارْ ثنِّي إِ ذ أَسْ د-يُورْونْ.
\m مَاڒَا زْڒِينْثْ ت ثْيسِّيثْ، أَذْ ت سّْعُودْجَانْثْ،
\m ثِيجدْجِيذِينْ ذ ثِييَّا أَذْ ت سّمْغَارنْثْ.“
\b
\m 
\v 10 ”مِينْ ثعْنَا ثنِّي د-إِسِّيجّنْ
\m أَمْ ثْفَاوْثْ ن ڒفْجَارْ،
\m ثشْنَا أَمْ ثْزِيرِي إِقفْڒنْ،
\m ثصْفَا أَمْ ثْفُوشْثْ يَارقّنْ،
\m ثسَّاڭّْوَاذْ أَمْ يِيسذِّييّنْ ن ڒْعسْكَارْ
\m س إِبَانْذُوثنْ؟“
\b
\s1 ثْسضْحِي ثسْڒِيثْ
\m 
\v 11 ”نشّْ حْوِيغْ غَارْ ثحْوِيشْثْ
\m ن ثْشجُّورَا ن ثغْيَاشْثْ
\m حِيمَا أَذْ ژَترغْ
\m أَغمُّويْ إِبدّنْ ذِي ثغْزُورْثْ،
\m حِيمَا أَذْ ژَترغْ مَا ثَازَايَارْثْ ثسُّوفّغْ-د،
\m مَا ثِيشجُّورَا ن أَرمَّانْ تّْنوَّارنْثْ.
\m 
\v 12 ثُوغَا وَارْ د-أَرِّيغْ ثَايْنِيثْ
\m أَقَا ڭِّيغْ إِخفْ إِنُو
\m ذڭْ إِكَارُّوثنْ ن ڒْڭنْسْ إِنُو إِڭلّْذنْ.“
\b
\b
\c 7
\s1 أَژْرِي ن ثسْڒِيثْ غَارْ شّْذِيحْ
\m 
\v 1 ”عْقبْ-د، عْقبْ-د، \add أَ\add* شُولَامِيثْ!
\m عْقبْ-د، عْقبْ-د،
\m مَاحنْذْ أَذْ ذَايمْ نخْزَارْ.“
\b
\m ”مِينْ ثخْسمْ أَذْ ثْژَارمْ ذِي شُولَامِيثْ؟“
\b
\m ”\add نتَّاثْ\add* أَمْ شّْضِيحْ س نُّوبْثَاثْ
\m ن ثْنَاينْ ن ڒْعسْكَارَاثْ.“
\b
\m 
\v 2 ”مشْحَاڒْ شْنَانْ إِصُورَافْ نّمْ
\m ذِي صَانْذَالِييَّاثْ \add نّمْ\add*،
\m \add أَ، شمْ\add* يسِّيسْ ن إِجّْ ن ؤُمْشنّعْ!
\m أَحْنُونِّي ن ثْمصَّاضْثْ نّمْ
\m أَمْ ثْسدّْيِينْ إِغْڒَانْ
\m \add تّْرَاحنْثْ تَّاسنْثْ-د\add*،
\m صّنْعثْ ن إِفَاسّنْ ن ؤُفنَّانْ.
\m 
\v 3 ثَاعبُّوضْثْ نّمْ
\m أَمْ ثْسَارِيجْثْ ثحْنُونِّي،
\m مَانِي وَارْ إِتّْخصِّي بِينُو إِخدْجْضنْ.
\m أَعذِّيسْ نّمْ ذ أَكمِّيشْ ن إِرْذنْ،
\m نّْضنْثْ أَسْ-د ثْلِيلِّيشِينْ. \f ◼ \fr 7:‏3 \ft \bd ’ثِيلِيلِّيشِينْ‘\bd* - إِجّْ ن مَارْكَا ن إِنُّووَّارنْ ذَايْسنْ أَژْرِي أَطَّاسْ.\f*
\m 
\v 4 إِذْمَارنْ نّمْ \add ڭِّينْ\add*
\m أَمْ ثْنَاينْ ن إِغَايْضنْ إِمژْيَاننْ،
\m أَمْ وَاشْنِيونْ ن ثْغَايْضثْ ن وزْغَارْ.
\m 
\v 5 إِرِي نّمْ إِڭَّا أَمْ صُّومْعثْ ن ڒْعَاجْ،
\m ثِيطَّاوِينْ نّمْ
\m أَمْ يِييڒْمَامنْ ن حَاشْبُونْ،
\m غَارْ ثوَّارْثْ ن بَاثْ-رَابِّيمْ،
\m ثِينْزَارْثْ نّمْ أَمْ صُّومْعثْ ن لُوبْنَانْ
\m إِ إِسَّاجَّانْ غَارْ ذِيمَاشْقْ.
\m 
\v 6 ثِيوَا نّمْ \add إِڭَّا\add* أَزدْجِيفْ نّمْ
\m أَمْ كَارْمِيلْ،
\m أَشُوَّافْ ن ؤُزدْجِيفْ نّمْ ذ أَرْجُووَانِي،
\m أَجدْجِيذْ إِتّْوَاحْبسْ ذڭْ إِمُوزَارنْ نّمْ.“
\b
\m 
\v 7 ”مشْحَاڒْ ثشْنِيذْ شمْ،
\m ؤُ مشْحَاڒْ ثْصبْحذْ، \add أَ\add* \bd ثَايْرِي\bd*،
\m ذِي \add كُوڒْشِي\add* مِينْ إِزمَّارْ بْنَاذمْ
\m أَذْ يَارّْ مژْرِي!“
\b
\s1 أَوَاڒْ ن يسْڒِي ؤُشَا ثَاسْڒِيثْ ثَارْنِي ذَايسْ
\m 
\v 8 ”ثِيذِّي نّمْ ثَارْوسْ ذِي ثْشجَّارْثْ ن ثِينِي،
\m إِذْمَارنْ نّمْ ذڭْ إِزكُّوننْ ن ؤُضِيڒْ.
\m 
\v 9 نشّْ نِّيغْ: ’أَذْ نْيغْ خْ ثْشجَّارْثْ ن ثِينِي،
\m أَذْ طّْفغْ ذِي ڒفْرُوعْ نّسْ.‘
\m إِذْمَارنْ نّمْ \add أَذْ إِڒِينْ\add*
\m أَمْ إِزنْكَاكْ ن ؤُضِيڒْ غَارْ ثْزَايَارْثْ،
\m ڒفْوَاحثْ ن ونْزَارنْ نّمْ
\m أَمْ تّفَّاحِينْ،
\m 
\v 10 أَنغْ نّمْ أَمْ بِينُو إِصبْحنْ أَطَّاسْ ...“،
\b
\m ”... ونِّي إِتّْرَاحنْ نِيشَانْ غَارْ لِّيفْ إِنُو،
\m ونِّي إِتَّارَّانْ إِينْشِيشنْ
\m ن يِينِّي إِطّْصنْ أَذْ نْهزّنْ.“
\b
\m 
\v 11 ”نشّْ ن لِّيفْ إِنُو،
\m غَارِي د-إِتَّاسْ مژْرِي نّسْ.
\m 
\v 12 أَسْ-د، لِّيفْ إِنُو،
\m أجّْ أَنغْ أَذْ نُويُورْ غَارْ ييَّارْ،
\m أَذْ نسّنْسْ ذِي ڒذْشُورْ.
\m 
\v 13 أجّْ أَنغْ أَذْ نكَّارْ زِيشْ
\m حِيمَا أَذْ نُويُورْ غَارْ إِمَارْجَاعنْ ن ؤُضِيڒْ،
\m أجّْ أَنغْ أَذْ نْژَارْ،
\m مَا ثَازَايَارْثْ \add أَقَا\add* ثسُّوفُّوغْ،
\m مَا نُّووَّارْ نّسْ نُّورْزْمنْ،
\m مَا ثِيشجُّورَا ن أَرمَّانْ نوَّارنْثْ.
\m ذِينِّي إِ ذ أَشْ غَا وْشغْ أَسْحِينّبْ إِنُو.
\m 
\v 14 تِّيفَّاحِينْ ن ثَايْرِي أَرْخُونْثْ إِ ڒفْوَاحْ
\m ؤُ ثِيوَا ن ثوُّورَا نّغْ
\m أَقَا ذِينْ فْرُوثَاثْ إِشوَّارنْ،
\m ثِينِّي ن طّْرِي ذ ثِينِّي إِتّْوَاخمّْڒنْ.
\m \add أَ\add* لِّيفْ إِنُو، خمّْڒغْ ثنْثْ إِ شكْ!“
\b
\b
\c 8
\s1 ثَاسْڒِيثْ ثْكمّڒْ أَوَاڒْ نّسْ
\m 
\v 1 ”أَخْ، معْلِيكْ قَاعْ شكْ ذ ؤُمَا،
\m ثطّضذْ ذِي ثْبِيبِّيشِينْ ن يمَّا.
\m مَاڒَا ؤُفِيغْ شكْ ذِي بَارَّا، أَذْ شكْ سُّوذْمغْ،
\m بْڒَا مَا ذ أَيِي سّحْقَارَانْ.
\m 
\v 2 إِڒِي أَذْ شكْ نذْهغْ، أَذْ شكْ أَوْيغْ
\m غَارْ ثَادَّارْثْ ن يمَّا،
\m شكْ أَذْ أَيِي ثسّْڒمْذذْ \add ذِينْ\add*.
\m أَذْ أَشْ وْشغْ بِينُو إِتّْفُوحنْ
\m س ڒعْثُوڒْ أَذْ ثسْوذْ،
\m أَژمِّي ن \add ثْشجَّارْثْ\add* إِنُو \add ن\add* وَارمَّانْ.
\b
\m 
\v 3 أَزڒْمَاضْ نّسْ سَاذُو ؤُزدْجِيفْ إِنُو،
\m أَفُوسِي نّسْ إِذَارّعْ أَيِي-د.
\b
\m 
\v 4 نشّْ أَذْ كنِّينْثْ سّْجَادْجَاغْ،
\m \add أَ\add* يسِّيسْ ن ؤُرْشَالِيمْ:
\m مَايمِّي غَا ثْهوْڒنْثْ \bd ثَايْرِي\bd*
\m نِيغْ أَذْ ت-إِ-د-ثسّكَّارنْثْ،
\m قْبڒْ مَا ثتّخْسْ نتَّاثْ؟“
\b
\s1 ثَاسْڒِيثْ ثفّغْ-د زِي ڒخْڒَا أَكْ-ذ يسْڒِي نّسْ
\m 
\v 5 ”مِينْ ثعْنَا نِّي \add ذِينْ\add* إِتّْڭعَّاذنْ زِي ڒخْڒَا،
\m ثتّْعمّذْ خْ لِّيفْ نّسْ؟“
\b
\m ”سَاذُو \add ثْشجَّارْثْ\add* ن تّفَّاحْثْ
\m أَرّغْ مژْرِي نّمْ،
\m مَانِي شمْ د-ثجَّا يمَّامْ
\m س ڒحْرِيقْ ن ثَارْوَا،
\m مَانِي شمْ د-ثجَّا
\m ثنِّي شمْ د-يُورْونْ.“ \x ◘ \xo 8:‏5 \xt إِزْڒِي 8‏:‏5\x*
\b
\m 
\v 6 ”سَارْسْ أَيِي أَمْ طَّابعْ خْ وُوڒْ نّشْ،
\m أَمْ طَّابعْ خْ ؤُغِيڒْ نّشْ،
\m مَاغَارْ \bd ثَايْرِي\bd* ثجْهذْ أَمْ ڒْموْثْ،
\m ثُوسْمِي ثقْسحْ أَمْ ڒَاخَارْثْ،
\m ثِيفطُّوثِينْ نّسْ ذ ثِيفطُّوثِينْ ن ثْمسِّي،
\m \add أَقَا أَثنْثْ\add* أَمْ ؤُشعَّاڒْ ن سِيذِي.
\m 
\v 7 أَطَّاسْ ن وَامَانْ
\m وَارْ زمَّارنْ أَذْ سّْخسْينْ \bd ثَايْرِي\bd*،
\m ؤُڒَا ذ إِغزْرَانْ وَارْ ت تِّيوْينْ.
\m وَاخَّا إِوْشَا إِجّنْ إِ \bd ثَايْرِي\bd*
\m مَارَّا أَڭْڒَا ن ثَادَّارْثْ نّسْ،
\m أَذْ ث سّحْقَارنْ ذ أَسحْقَارْ.“
\b
\s1 ثَاسْڒِيثْ ذ أَيْثْمَاسْ
\m 
\v 8 ”نشِّينْ غَارْنغْ
\m إِشْثْ ن ؤُتْشْمَاثْنغْ ثَامژْيَانْثْ،
\m عَاذْ وَارْ ذ أَسْ د-فِّيغنْ إِذْمَارنْ.
\m مِينْ غَا نڭّْ إِ ؤُتْشْمَاثْنغْ
\m ذڭْ وَاسّْ إِ ذِي خَاسْ إِ غَا سِّيوْڒنْ؟“
\b
\m 
\v 9 ”مَاڒَا نتَّاثْ ذ ڒْحِيضْ،
\m أَذْ خَاسْ نسّْبدّْ أَشْبَارْ
\m \add أَمْ إِجّْ ن تَّاجْ\add* ن نُّوقَارْثْ.
\m مَاڒَا نتَّاثْ ذ ثَاوَّارْثْ،
\m أَذْ ت نقّنْ س ثْفڒْوِينْ ن ؤُكشُّوضْ ن ثنْڭلْثْ.“
\b
\m 
\v 10 ”نشّْ ذ ڒْحِيضْ ؤُ إِذْمَارنْ إِنُو أَمْ لْبُورْجَاثْ.
\m خنِّي ذوْڒغْ نشّْ ذِي ثِيطَّاوِينْ نّسْ
\m أَمْ ثنِّي يُوفِينْ ڒحْنَا.“
\b
\s1 أَحْوِيشْ ن ثْزَايَارْثْ ن سُولِيمَانْ ذ وحْوِيشْ ن ثْزَايَارْثْ ن ثسْڒِيثْ
\m 
\v 11 ”سُولِيمَانْ ثُوغَا غَارسْ
\m إِجّْ ن ؤُمَارْجعْ ن ؤُضِيڒْ ذِي بَاعْلْ-هَامُونْ.
\m إِوْشَا أَمَارْجعْ نِّي إِ إِعسَّاسنْ.
\m إِ ڒْغِيدْجثْ نّسْ قَاعْ إِجّْ يِيوِي-د
\m أَڒفْ ن ڒوْزنْ ن نُّوقَارْثْ.“ \x ◘ \xo 8:‏11 \xt إِشا. 7‏:‏23\x*
\b
\m 
\v 12 ”أَحْوِيشْ ن ؤُضِيڒْ  إِنُو،
\m أَقَا-ث زَّاثْ إِ ثِيطَّاوِينْ إِنُو.
\m أَڒفْ ن ڒوْزنْ ن نُّوقَارْثْ
\m أَقَا أَثنْ إِ شكْ، \add أَ\add* سُولِيمَانْ،
\m ؤُ أَڒْفَاينْ إِ إِعسَّاسنْ ن ڒْغِيدْجثْ زَّايسْ.“
\b
\s1 أَڒَاغِي ن يسْڒِي ذ ثسْڒِيثْ
\m 
\v 13 ”\add أَ شمْ\add* ثنِّي إِزدّْغنْ ذڭْ إِحْوِيشنْ،
\m إِعْشِيرنْ \add نّمْ\add* تّسْڒَانْ \add س إِمزُّوغنْ نْسنْ\add*
\m إِ ثْمِيجَّا نّمْ،
\m \add قَّارنْ:\add* ’أجّْ أَيِي أَذْ ت سْڒغْ!“
\b
\m 
\v 14 ”ذغْيَا، \add أَ\add* لِّيفْ إِنُو،
\m أڭّْ أَمْ يِيغَايْضْ ن وزْغَارْ
\m نِيغْ أَمْ ؤُمژْيَانْ ن ؤُذَاذنْ،
\m خْ إِذُورَارْ \add إِشُّورنْ\add* س ڒعْشُوبْ إِتّْفُوحنْ.“ 
