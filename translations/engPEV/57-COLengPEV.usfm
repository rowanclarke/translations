\v 20 \w God|strong="G2532"\w* used \w him|strong="G3588"\w* \w to|strong="G1519"\w* \w get|strong="G2532"\w* \w everything|strong="G3956"\w* \w to|strong="G1519"\w* \w come|strong="G2532"\w* \w back|strong="G1519"\w* \w to|strong="G1519"\w* \w himself|strong="G1519"\w*. \w God|strong="G2532"\w*’s son bled \w and|strong="G2532"\w* \w died|strong="G3588"\w* \w on|strong="G1909"\w* \w the|strong="G1722"\w* \w cross|strong="G4716"\w*, \w so|strong="G2532"\w* \w that|strong="G3588"\w* \w now|strong="G2532"\w* \w everything|strong="G3956"\w* can stop \w being|strong="G2532"\w* \w God|strong="G2532"\w*’s enemies, \w and|strong="G2532"\w* become \w God|strong="G2532"\w*’s friends \w again|strong="G1519"\w*. \w Some|strong="G3588"\w* \w of|strong="G1223"\w* \w those|strong="G3588"\w* \w things|strong="G3956"\w* \w are|strong="G3588"\w* \w in|strong="G1722"\w* \w heaven|strong="G3772"\w*, \w and|strong="G2532"\w* \w some|strong="G3588"\w* \w of|strong="G1223"\w* \w them|strong="G3588"\w* \w are|strong="G3588"\w* \w on|strong="G1909"\w* \w the|strong="G1722"\w* \w earth|strong="G1093"\w*, \w but|strong="G2532"\w* \w Jesus|strong="G2532"\w* \w died|strong="G3588"\w* \w on|strong="G1909"\w* \w the|strong="G1722"\w* \w cross|strong="G4716"\w*, \w so|strong="G2532"\w* \w that|strong="G3588"\w* \w they|strong="G2532"\w* can \w all|strong="G3956"\w* \w come|strong="G2532"\w* \w back|strong="G1519"\w* \w to|strong="G1519"\w* \w God|strong="G2532"\w*.\x * \xo 1:20 \xt Ephesians 2:16\x*
\s1 God is a friend of people that trust Jesus
\p 
