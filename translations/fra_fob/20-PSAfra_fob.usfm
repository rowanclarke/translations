\v 13 \w Il|strong="H7725"\w* \w prépare|strong="H3559"\w* \w contre|strong="H3808"\w* \w lui|strong="H3808"\w* \w des|strong="H7725"\w* \w armes|strong="H2719"\w* mortelles, \w il|strong="H7725"\w* \w apprête|strong="H3559"\w* \w des|strong="H7725"\w* flèches ardentes.
\v 14 Voici, \w le|strong="H3559"\w* méchant \w est|strong="H3559"\w* \w en|strong="H3559"\w* travail \w pour|strong="H3559"\w* enfanter \w le|strong="H3559"\w* \w mal|strong="H6466"\w*; il \w a|strong="H3068"\w* conçu \w le|strong="H3559"\w* crime, mais il n'enfante \w que|strong="H3559"\w* mensonge.
\v 15 \w Il|strong="H2009"\w* \w a|strong="H3068"\w* creusé \w un|strong="H3205"\w* trou profond; mais \w il|strong="H2009"\w* tombera \w dans|strong="H3205"\w* \w la|strong="H3205"\w* fosse qu'\w il|strong="H2009"\w* \w a|strong="H3068"\w* faite.
\v 16 \w Sa|strong="H2658"\w* malice retournera \w sur|strong="H5307"\w* \w sa|strong="H2658"\w* tête, \w sa|strong="H2658"\w* violence retombera \w sur|strong="H5307"\w* son front.
\v 17 \w Je|strong="H3068"\w* célébrerai l'Éternel \w à|strong="H7725"\w* \w cause|strong="H5921"\w* \w de|strong="H7218"\w* \w sa|strong="H7725"\w* justice; \w je|strong="H7725"\w* chanterai \w le|strong="H7725"\w* \w nom|strong="H7725"\w* \w de|strong="H7218"\w* l'Éternel, \w le|strong="H7725"\w* Très-Haut.
\c 8
\p 
\v 1 Éternel, \w notre|strong="H5921"\w* Seigneur, \w que|strong="H5921"\w* \w ton|strong="H5921"\w* nom est magnifique \w sur|strong="H5921"\w* toute \w la|strong="H5921"\w* \w terre|strong="H5921"\w*! \w Tu|strong="H5921"\w* as établi \w ta|strong="H5921"\w* majesté \w au-dessus|strong="H5921"\w* \w des|strong="H5921"\w* cieux.
