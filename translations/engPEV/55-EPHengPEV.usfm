\v 20 \w but|strong="G1473"\w* \w now|strong="G5613"\w* \w he|strong="G3739"\w* \w has|strong="G3739"\w* sent \w me|strong="G1473"\w* \w to|strong="G2443"\w* \w tell|strong="G2980"\w* \w this|strong="G3739"\w* good story \w to|strong="G2443"\w* everybody. \w The|strong="G1722"\w* bosses \w here|strong="G1722"\w* didn’t \w like|strong="G5613"\w* \w me|strong="G1473"\w* \w telling|strong="G2980"\w* \w that|strong="G2443"\w* story, \w so|strong="G2443"\w* \w they|strong="G3739"\w* \w put|strong="G1163"\w* \w me|strong="G1473"\w* \w in|strong="G1722"\w* jail. \w I|strong="G1473"\w* want \w you|strong="G3739"\w* \w to|strong="G2443"\w* ask \w God|strong="G2980"\w* \w to|strong="G2443"\w* \w make|strong="G1163"\w* \w me|strong="G1473"\w* brave, \w so|strong="G2443"\w* \w that|strong="G2443"\w* \w I|strong="G1473"\w* keep \w on|strong="G1722"\w* \w telling|strong="G2980"\w* \w his|strong="G1722"\w* good story.   
\s1 The end of Paul’s letter  
\p
\v 21-22 Now I’m sending Tikicus to you to tell you about me and about what I’m doing these days. He is my Christian friend that I love, and he is a good worker for God. He will tell you all the news about me, and the news about the other people that are here with me. And I also want him to help you feel strong and brave.\x * \xo 6:21-22 \xt Acts 20:4; 2 Timothy 4:12; Colossians 4:7-8\x*   
\p
\v 23 \w You|strong="G2532"\w* mob \w are|strong="G3588"\w* \w my|strong="G3326"\w* Christian friends. \w You|strong="G2532"\w* \w believe|strong="G4102"\w* \w in|strong="G2532"\w* \w God|strong="G2316"\w*, \w our|strong="G2316"\w* \w father|strong="G3962"\w*, \w and|strong="G2532"\w* \w you|strong="G2532"\w* \w believe|strong="G4102"\w* \w in|strong="G2532"\w* \w our|strong="G2316"\w* leader \w Jesus|strong="G2424"\w* \w Christ|strong="G5547"\w*. \w So|strong="G2532"\w* \w I|strong="G2532"\w*’m asking \w them|strong="G3588"\w* \w to|strong="G2532"\w* \w be|strong="G2532"\w* really \w good|strong="G3588"\w* \w to|strong="G2532"\w* \w you|strong="G2532"\w*, \w and|strong="G2532"\w* \w to|strong="G2532"\w* help \w you|strong="G2532"\w* \w to|strong="G2532"\w* \w be|strong="G2532"\w* happy \w and|strong="G2532"\w* quiet inside yourselves. \w And|strong="G2532"\w* \w I|strong="G2532"\w*’m asking \w God|strong="G2316"\w* \w to|strong="G2532"\w* help \w you|strong="G2532"\w* \w to|strong="G2532"\w* love \w him|strong="G3588"\w*, \w and|strong="G2532"\w* \w to|strong="G2532"\w* love \w other|strong="G3588"\w* \w people|strong="G3588"\w*, \w and|strong="G2532"\w* \w to|strong="G2532"\w* help \w you|strong="G2532"\w* \w to|strong="G2532"\w* keep \w on|strong="G3326"\w* trusting \w Jesus|strong="G2424"\w*.   
\p
