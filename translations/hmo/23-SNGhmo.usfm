\id SNG SONG OF SONGS, Hiri Motu Bible, PNG, 6/90, 6/92 
\h SOLOMONA ENA ANE 
\toc1 SOLOMONA ENA ANE 
\toc2 SOLOMONA ENA ANE 
\mt1 SOLOMONA ENA ANE  
\c 1  
\q1
\v 1 Inai be ane namo herea, Solomona ena.   
\s1 Ane ginigunana  
\s2 Hahine ia abia  
\q1
\v 2 Oiemu uduna ena bibina ese,  
\q1 kisi momo lau dekenai ia henia noho.  
\q1 Oiemu lalokau ena namo ese,  
\q1 uaina ena namo ia hereaia noho.   
\q1
\v 3 Oiemu kopina oi dahua muramura ena bonana be namo herea,  
\q1 bona oiemu ladana be,  
\q1 dehoro idia bubua ena regena bamona.  
\q1 Unai dainai headava lasi kekeni ibounai ese,  
\q1 oi idia ura henia noho.   
\q1
\v 4 Mani lau be oi danu ita lao,  
\q1 karaharaga do ita lao!  
\q1 Oi be egu king,  
\q1 bona emu ruma lalonai lau do oi hakaua vareai.  
\q1 Ita be do ita moale hebou,  
\q1 oiemu lalokau ena namo ese,  
\q1 uaina ena namo ia hereaia momokani.  
\q1 Hahine ibounai ese oi idia ura henia noho,  
\q1 be mai badina.   
\q1
\v 5 Ierusalema ena hahine e,  
\q1 egu kopina be koremakorema, to egu toana be namo.  
\q1 Egu kopina be koremakorema,  
\q1 Kedara dabua rumadia bamona,  
\q1 Solomona ena ruma koua dabua bamona.   
\q1
\v 6 Egu kopina be koremakorema dainai,  
\q1 lau do oi itaia noho, itaia noho lasi,  
\q1 badina be dina ese lau ia gabua vadaeni.  
\q1 Egu taihuna ese lau dekenai idia badu,  
\q1 bona vain uma naria gaukara lau dekenai idia henia,  
\q1 unai dainai egu kopina lau naria diba lasi.   
\q1
\v 7 Egu lalokau tauna e, lau do oi hadibaia,  
\q1 oiemu mamoe be edeseni oi ubua noho?  
\q1 Bona dina tubua neganai,  
\q1 edeseni oiemu mamoe dekenai,  
\q1 laga-ani oi henidia, idia hekure?  
\q1 Badina oi dekenai do lau mai gwauraia,  
\q1 lau ura lasi mamoe naria taudia haida edia mamoe,  
\q1 edia huana dekenai do lau loaloa kava.   
\s2 Tau ia hereva  
\q1
\v 8 Hahine namona momokani e,  
\q1 bema gabu oi diba lasi neganai,  
\q1 mamoe edia aena gabudia murinai do oi raka.  
\q1 Oiemu nanigosi natudia be mamoe naria taudia,  
\q1 edia palai ruma edia badinai do oi ubudia.   
\q1
\v 9 Egu lalokau e, dahaka dekenai oi be hegeregere?  
\q1 Oi be Farao ena kariota hosi hahine,  
\q1 namona ta hegeregerena.   
\q1
\v 10 Oiemu huina be mai hairaina.  
\q1 Ia ese oiemu vairana kahana kahana dekenai,  
\q1 bona oiemu aiona dekenai ia helai noho,  
\q1 ageva namona bamona.   
\q1
\v 11 Ai ese herahera gaudia do ai karaia,  
\q1 oi dekenai do ai henia totona,  
\q1 golo herahera gaudia, mai siliva danu.   
\s2 Hahine ia hereva  
\q1
\v 12 Egu king be iena mahuta patana,  
\q1 dekenai ia hekure neganai,  
\q1 egu bonana namo muramura ena bonana ia daekau.   
\q1
\v 13 Egu lalokau tauna,  
\q1 be egu ratana edia huanai ia hekure,  
\q1 be lau dekenai bonana namo muramura ena puse bamona.   
\q1
\v 14 Egu lalokau tauna ena toana be namo herea,  
\q1 Ene Gedi ena vain uma dekenai idia vara,  
\q1 hena ava namodia edia toana bamona.   
\s2 Tau ia hereva  
\q1
\v 15 Egu lalokau e,  
\q1 oi be hairai herea momokani.  
\q1 Oiemu lalokau dainai,  
\q1 oiemu matana edia toana be pune manu bamona.   
\s2 Hahine ia hereva  
\q1
\v 16 Egu lalokau tauna e,  
\q1 oi be raho namo momokani.  
\q1 Momokani oi be mai hairaina.  
\q1 Iseda mahuta patana be rei namona bamona.   
\q1
\v 17 Iseda ruma audia be sida,  
\q1 bona ruma guhi au badadia be saipresi audia.   
\c 2  
\q1
\v 1 Lau be Sarona dekenai ia vara rousi palauapalaua,  
\q1 koura dekenai ia vara sosana palauapalaua.   
\s2 Tau ia hereva  
\q1
\v 2 Hahine edia huanai egu lalokau hahine be,  
\q1 sosana palauapalaua,  
\q1 ava ginigini edia huanai bamona.   
\s2 Hahine ia hereva  
\q1
\v 3 Tau edia huanai egu lalokau tauna be,  
\q1 apolo auna, uda audia edia huanai bamona.  
\q1 Iena ikerukeruna lalonai,  
\q1 lau helai mai moale bada danu.  
\q1 Iena au huahua be lau dekenai,  
\q1 idia gaiho namo herea.   
\q1
\v 4 Iena aria ruma dekenai lau ia hakaua lao,  
\q1 iena pepe egu kwarana ena ataiai be lalokau.   
\q1
\v 5 Vain ena huahua kaukaudia,  
\q1 dekena amo lau do oi ubua,  
\q1 bona apolo huahuadia dekena amo,  
\q1 lau do oi hagoadaia.  
\q1 Badina be egu ura henia dikadika ese,  
\q1 egu lalona ia hamasea noho.   
\q1
\v 6 Egu tau ena imana laurina ese,  
\q1 egu kwarana ena henunai ia noho,  
\q1 bona iena imana idibana ese,  
\q1 lau ia rosia noho.   
\q1
\v 7 Ierusalema hahine e,  
\q1 umui lau oda henia inai,  
\q1 uda nanigosi bona uda dia namodia dainai,  
\q1 do umui gwauhamata,  
\q1 aiemai ura henia dekena amo,  
\q1 ai do umui boiboi lasi,  
\q1 ai do umui hanogaia lasi,  
\q1 ela bona ai sibona ai ura do ai noga.   
\s1 Ane iharuana  
\s2 Hahine ia abia  
\q1
\v 8 Egu lalokau tauna ena gadona lau kamonai noho.  
\q1 Itaia, ia be ororo dekena amo ia roho mai noho.  
\q1 Ia heau mai noho lau dekenai.   
\q1
\v 9 Egu lalokau tauna be uda nanigosi,  
\q1 o dia ena natuna bamona.  
\q1 Itaia, ia be aiemai ruma,  
\q1 ena murimurinai ia gini noho,  
\q1 uindo bona uindo hagoadaia audia dekena amo,  
\q1 ia ese ruma ena lalona ia itaia noho.   
\q1
\v 10 Egu lalokau tauna ese lau dekenai ia hereva henia.  
\q1 Inai bamona ia gwau,  
\s2 Tau ia hereva  
\q1 Egu lalokau e, oi toreisi,  
\q1 egu hahine namona e, lau danu ita lao.   
\q1
\v 11 Keru negana be ia ore vadaeni.  
\q1 Medu be ia doko vadaeni.   
\q1
\v 12 Tano ena palauapalaua idia tubu vadaeni.  
\q1 Ane abia negana ia ginidae vadaeni,  
\q1 bona pune manu be,  
\q1 iseda tano dekenai idia tai noho.   
\q1
\v 13 Fig huahuadia be idia mage hamatamaia noho,  
\q1 vain edia palauapalaua,  
\q1 edia bonana danu idia daekau noho.  
\q1 Egu lalokau e, oi toreisi,  
\q1 hahine namona e, lau danu ita lao.   
\q1
\v 14 Oi be egu pune manu,  
\q1 oi be nadi ena matudia lalonai oi hunia noho.  
\q1 Lau ura oiemu vairana do lau itaia,  
\q1 bona lau ura oiemu gadona do lau kamonai.   
\q1
\v 15 Oi mai, tarapu dekenai mariboi do ita abia.  
\q1 Idia be maragi,  
\q1 to idia ese vain umadia idia hadikaia hamatamaia noho.  
\q1 Iseda vain huahua edia palauapalaua,  
\q1 be idia hedinaraia noho.   
\s2 Hahine ia hereva  
\q1
\v 16 Egu tau be egu lalokau,  
\q1 bona lau be iena lalokau.  
\q1 Ia ese iena mamoe ia ubua noho,  
\q1 sosana palauapalaua edia huanai.   
\q1
\v 17  Daba do ia rere lasi neganai,  
\q1 bona hanuaboi do ia ore lasi neganai,  
\q1 egu lalokau tauna e,  
\q1 lau dekenai do oi mai haraga,  
\q1 uda nanigosi o dia natuna,  
\q1 ororo nadi badadia edia huana dekenai  
\q1 idia heau bamona.   
\c 3  
\q1
\v 1 Hanuaboi ta, egu mahuta patana dekenai,  
\q1 egu lalokau tauna lau tahua,  
\q1 lau tahua to lau davaria lasi.  
\q1 Ia dekenai lau boiboi,  
\q1 to ia haere lasi.   
\q1
\v 2 Lau toreisi, hanua dekenai lau loaloa,  
\q1 ariara dekenai bona dala maragidia dekenai,  
\q1 egu lalokau lau tahua.  
\q1 Lau tahua, to lau davaria lasi.   
\q1
\v 3 Hanua gimaia taudia be hanua ena gabu ta ta,  
\q1 dekenai idia raka lao neganai,  
\q1 idia ese lau idia davaria.  
\q1 Lau ese idia dekenai lau tai henia, lau gwau,  
\q1 “Egu lalokau tauna umui itaia lasi, a?”   
\q1
\v 4 Idia lau rakatania,  
\q1 bona nega daudau lasi lalonai,  
\q1 egu lalokau tauna lau davaria.  
\q1 Lau dogoatao auka,  
\q1 bona egu imana dekena amo lau ruhaia lasi,  
\q1 ia mai, bona egu sinana ena ruma dekenai lau hakaua.  
\q1 Lau ia havaraia hahine ena daiutu dekenai,  
\q1 egu lalokau lau abia vareai lao.   
\q1
\v 5 Ierusalema hahine e,  
\q1 umui lau oda henia inai,  
\q1 uda nanigosi bona uda dia namodia dainai,  
\q1 do umui gwauhamata,  
\q1 aiemai ura henia dekena amo,  
\q1 ai do umui boiboi lasi,  
\q1 ai do umui hanogaia lasi,  
\q1 ela bona ai sibona ai ura do ai noga.   
\s1 Ane ihatoina  
\s2 Hahine ia abia  
\q1
\v 6 Unai be dahaka,  
\q1 tano kaukau dekena amo ia mai noho,  
\q1 kwalahu ena ori toana bamona?  
\q1 Ia be mai ena bonana namo herea,  
\q1 muramura pauda ladana muro dainai,  
\q1 hoihoi taudia ese idia hoia muramurana.   
\q1
\v 7 Itaia, inai be Solomona ena terona, helai gauna,  
\q1 Israela ena tuari taudia goadadia ibounai 60 ese,  
\q1 Solomona ena terona idia gimaia noho.   
\q1
\v 8 Unai tau 60 ibounai,  
\q1 be tuari kaia iusilaia diba momo,  
\q1 bona tuari dekenai idia manada vadaeni.  
\q1 Edia tuari kaia be ta ta,  
\q1 edia gaba gaudia dekenai idia atoa hegaegae,  
\q1 hanuaboi ena gari gaudia do idia koua totona.   
\q1
\v 9 King Solomona ena terona, idia huaia helai gauna,  
\q1 be Lebanona audia dekena amo ia karaia.   
\q1
\v 10 Terona ena aena be siliva dekena amo ia koua,  
\q1 bona iena haba be golo dekena amo ia koua.  
\q1 Terona ena pilo bona ena lalona,  
\q1 be dabua, ena kala kakakaka sisina dekena amo ia koua.  
\q1 Inai dabua be Ierusalema hahine ese,  
\q1 mai lalokau danu idia hatua namonamo.   
\q1
\v 11 Siona hahine e, do umui raka mai,  
\q1 King Solomona do umui itaia.  
\q1 Iena korona be iena kwarana dekenai,  
\q1 bona Solomona ena headava dinana dekenai,  
\q1 iena sinana ese unai korona ia henia.  
\q1 Solomona ena moale dinana be unai.   
\c 4  
\s2 Tau ia hereva  
\q1
\v 1 Egu lalokau e, oi be hahine namona.  
\q1 Oiemu matana be pune manu bamona,  
\q1 oiemu vairana koua dabua ena murinai.  
\q1 Oiemu huina be nanigosi orea,  
\q1 Gileada Ororo dekena amo idia diho mai noho bamona.   
\q1
\v 2 Oiemu isena be mamoe orea,  
\q1 edia huina idia utua vadaeni,  
\q1 bona digu gabuna dekena amo,  
\q1 idia daekau mai neganai bamona.  
\q1 Idia ibounai be mai edia natudia, vara hekapa.  
\q1 Ta be sibona ia noho lasi.   
\q1
\v 3 Oiemu uduna bibinadia be varo kakakaka bamona,  
\q1 bona oiemu uduna be mai hairaina.  
\q1 Ma oiemu vairana ena kahana kahana,  
\q1 ena koua dabua murinai,  
\q1 be apolo huahua idia ivaia parara ena toana bamona.   
\q1
\v 4 Oiemu aiona be Davida ena kohoro bamona,  
\q1 mai kuboruna bona manada namo herea.  
\q1 Ia dekenai be ageva, iena toana be,  
\q1 tuari kesi momo herea, kohoro idia taua dae hagegea bamona.   
\q1
\v 5 Oiemu ratana ruaosi,  
\q1 be uda dia hahine ena natuna rua bamona,  
\q1 uda dia hahine ena natuna vara hekapa,  
\q1 sosana palauapalaua edia huanai idia aniani noho gaudia.   
\q1
\v 6 Muro ena ororo dekenai do lau lao,  
\q1 unai bonana namo gabua muramura,  
\q1 ena ororo dekenai do lau noho,  
\q1 ela bona daba do ia rere,  
\q1 bona hanuaboi do ia ore.   
\q1
\v 7 Egu lalokau e, oi be hahine namona.  
\q1 Oi be mai emu dika ta lasi, goeva momokani.   
\q1
\v 8 Egu adavana e,  
\q1 Lebanona Ororo dekena amo do ita raka hebou,  
\q1 Lebanona dekena amo do ita loaloa hebou.  
\q1 Amana bona Seniri bona Heremona Ororo edia ataiai,  
\q1 bona laiona edia kohua,  
\q1 bona taiga edia ororo dekena amo,  
\q1 do ita raka diho mai.   
\q1
\v 9 Egu lalokau e, egu adavana e,  
\q1 oiemu matana ena diari tamona,  
\q1 bona emu aiona ena herahera nadi tamona dekena amo,  
\q1 egu kudouna oi hamakohia vadaeni.   
\q1
\v 10 Egu lalokau e, egu adavana e,  
\q1 oiemu ura henia ese lau ia hamoalea bada noho.  
\q1 Oiemu lalokau ena namo ese,  
\q1 uaina ena namo ia hereaia noho.  
\q1 Oiemu dehoro ena bonana ese,  
\q1 muramura ibounai edia bonana ia hereaia noho.   
\q1
\v 11 Egu adavana e, hani ena mamina namona,  
\q1 be oiemu uduna bibinadia dekenai,  
\q1 oiemu malana be rata bona hani lau dekenai.  
\q1 Oiemu dabua edia bonana,  
\q1 be Lebanona ena bonana namona hegeregerena.   
\q1
\v 12 Egu lalokau, egu adavana e,  
\q1 oi be idia lokaia vadaeni uma gabuna bamona,  
\q1 bona idia koua vadaeni ranu gabuna bamona.   
\q1
\v 13 Oiemu uma dekenai idia vara noho gaudia,  
\q1 be apolo huahuadia,  
\q1 bona au huahua namodia,  
\q1 bona hena bona nada bonana namo muramura danu.   
\q1
\v 14 Io, saparona, kalamusu, kinamono,  
\q1 bona inai bamona bonana namo,  
\q1 gabua muramura idauidau ibounai danu.  
\q1 Muro bona aloe danu unuseni idia vara noho,  
\q1 bonana namo muramura ibounai danu.   
\q1
\v 15 Oi be uma mai ena ranu lohilohi gabuna,  
\q1 ranu guri mai ena mauri ranuna,  
\q1 inai ranu be Lebanona dekena amo ia diho mai noho.   
\s2 Hahine ia hereva  
\q1
\v 16 Lai mirigini e, oi noga!  
\q1 Lai diho e, oi danu do oi toa!  
\q1 Egu uma dekenai do umui toa,  
\q1 vadaeni ena bonana namona gabu idauidau dekenai,  
\q1 do umui hodaia lao.  
\q1 Egu lalokau tauna be ena uma,  
\q1 dekenai do ia raka vareai,  
\q1 bona iena huahua namodia momokani do ia ania.   
\c 5  
\s2 Tau ia hereva  
\q1
\v 1 Egu lalokau, egu adavana e,  
\q1 egu uma lalonai lau raka vareai vadaeni.  
\q1 Egu muro,  
\q1 bona egu bonana namo muramura lau haboua noho.  
\q1 Egu hani,  
\q1 bona bi ena hani haboua ruma lau ania noho,  
\q1 egu uaina bona rata lau inua noho.  
\s2 Ierusalema ena hahine taudia idia hereva  
\q1 Aiemai turadia e, do umui aniani, bona inuinu.  
\q1 Umui lalokau tauna bona hahine e, do umui inua momo.   
\s1 Ane namba 4  
\s2 Hahine ia abia  
\q1
\v 2 Lau mahuta, to egu lalona be ia noga.  
\q1 Lau nihi,  
\q1 egu lalokau tauna be iduara dekenai ia pidipidi.  
\s2 Tau ia hereva  
\q1 Egu lalokau e, egu pune manu e,  
\q1 oi be goevagoeva momokani.  
\q1 Iduara do oi kehoa,  
\q1 badina hanuaboi ena ranu ese,  
\q1 egu kwarana ia hapariparia.  
\q1 Hanuaboi ena medu maragi ese,  
\q1 egu huina ia hapariparia vadaeni.   
\s2 Hahine ia hereva  
\q1
\v 3 Egu dabua lau kokia vadaeni,  
\q1 be do lau kwatua lou, a?  
\q1 Egu aena lau huria vadaeni,  
\q1 be do lau hamirodia lou, a?   
\q1
\v 4 Egu lalokau tauna ese iena imana,  
\q1 be iduara loka dekenai kehoa totona ia atoa,  
\q1 bona ia totona egu kudouna ia toreisi momokani.   
\q1
\v 5 Lau toreisi,  
\q1 egu lalokau tauna totona iduara do lau kehoa gwauraia.  
\q1 Egu imana dekenai muro ia noho,  
\q1 egu ima kwakikwakina dekena amo,  
\q1 muro ena ranu ia diho noho,  
\q1 iduara ena loka dekenai.   
\q1
\v 6 Egu lalokau tauna totona iduara lau kehoa,  
\q1 to egu lalokau ia raka siri vadaeni,  
\q1 ia be ia noho lasi.  
\q1 Lau ura bada momokani iena gadona do lau kamonai,  
\q1 to lau tahua neganai lau davaria lasi,  
\q1 bona ia dekenai lau boiboi neganai,  
\q1 ia be ia haere lasi.   
\q1
\v 7 Hanua gimaia taudia be gabu ta ta dekenai,  
\q1 idia raka lao neganai,  
\q1 idia ese lau idia davaria.  
\q1 Idia ese lau idia dadabaia bona lau idia haberoa,  
\q1 ma egu kouti dabua idia abia lao,  
\q1 magu gimaia taudia ese.   
\q1
\v 8 Ierusalema hahine e,  
\q1 lau dekenai do umui gwauhamata,  
\q1 bema egu lalokau tauna umui davaria neganai,  
\q1 do umui hamaoroa egu ura henia ese,  
\q1 egu lalona ia hamasea noho.   
\s2 Ierusalema ena hahine taudia idia hereva  
\q1
\v 9 Hahine namona e,  
\q1 oiemu lalokau tauna be edena bamona iena namo,  
\q1 ese tau haida edia namo ia hereaia?  
\q1 Edena bamona ia namo herea momokani,  
\q1 bona ai ese unai gwauhamata do ai karaia?   
\s2 Hahine ia hereva  
\q1
\v 10 Egu lalokau tauna ena kopina,  
\q1 be goevagoeva bona kakakaka,  
\q1 tau ibounai 10,000 edia huanai,  
\q1 ia sibona be namo herea.   
\q1
\v 11 Iena kwarana be golo namo herea bamona.  
\q1 Iena huina be koremakorema, galo manu bamona,  
\q1 bona iena huina be davara ena hurehure manokadia bamona.   
\q1
\v 12 Iena matana be pune manu,  
\q1 ranu namona badinai noho gaudia bamona,  
\q1 rata dekenai idia huria gaudia.  
\q1 Edia gabu dekenai idia noho namo herea.   
\q1
\v 13 Iena vairana ena kahana kahana,  
\q1 be muramura avadia ena uma bamona,  
\q1 mai edia bonana namona.  
\q1 Iena uduna bibinadia be sosana palauapalaua,  
\q1 muro ranu be idia dekena amo ia diho noho.   
\q1
\v 14 Iena imana be golo,  
\q1 idia koroa kuboru gaudia bamona,  
\q1 mai herahera nadi haida danu.  
\q1 Iena tauanina be aivori namo herea bamona,  
\q1 mai sapairo nadi haida danu.   
\q1
\v 15 Iena aena be nadi kurokuro du goadadia bamona,  
\q1 bona idia be golo maua edia latanai idia gini noho.  
\q1 Egu lalokau tauna ena toana,  
\q1 be Lebanona Ororo bamona.  
\q1 Iena hairaina be Lebanona sida audia bamona.   
\q1
\v 16 Iena hereva be gaiho namo herea.  
\q1 Lau ese ia lau ura henia noho, bada momokani.  
\q1 Ierusalema hahine taudia e,  
\q1 egu lalokau tauna be unai.  
\q1 Egu turana be unai.   
\c 6  
\s2 Ierusalema ena hahine taudia idia hereva  
\q1
\v 1 Hahine namona e,  
\q1 oiemu lalokau tauna be edeseni ia lao?  
\q1 Ia be edena kahana dekenai ia lao,  
\q1 vadaeni ai ese oi danu do ita tahua?   
\s2 Hahine ia hereva  
\q1
\v 2 Egu lalokau be iena uma dekenai ia lao,  
\q1 iena muramura avadia uma gabuna.  
\q1 Uma dekenai iena mamoe ia ubua noho,  
\q1 bona sosana palauapalaua ia haboua noho danu.   
\q1
\v 3 Egu tau be egu lalokau,  
\q1 bona lau be iena lalokau.  
\q1 Ia ese iena mamoe ia ubua noho,  
\q1 sosana palauapalaua edia huanai.   
\s1 Ane namba 5  
\s2 Tau ese ia abia  
\q1
\v 4 Egu lalokau e, oi be hairai herea,  
\q1 Ierusalema bamona.  
\q1 Oiemu hairaina be bada,  
\q1 Tirisa hanua bamona,  
\q1 oiemu toana be mai garina,  
\q1 tuari orea mai edia pepe edia toana bamona.   
\q1
\v 5 Oiemu matana dekenai lau do oi itaia noho lasi,  
\q1 badina oiemu matana ese,  
\q1 lau idia hamanokaia noho.  
\q1 Oiemu huina be nanigosi orea,  
\q1 Gileada Ororo dekena amo mai mavaru danu,  
\q1 idia diho mai noho bamona.   
\q1
\v 6 Oiemu isena be mamoe orea,  
\q1 edia huina be huria vadaeni,  
\q1 bona digu gabuna dekena amo,  
\q1 idia daekau mai bamona.  
\q1 Idia ibounai be mai edia natudia, vara hekapa,  
\q1 ta be ia sibona ia noho lasi.   
\q1
\v 7 Oiemu vairana ena kahana kahana,  
\q1 ena koua dabua murinai,  
\q1 be apolo huahua namona,  
\q1 idia ivaia parara ena toana bamona.   
\q1
\v 8 King ena hahine be sedira ibounai 60.  
\q1 Iena hesiai hahine danu be sedira 80,  
\q1 bona iena kekeni be momo, duahia diba lasi,   
\q1
\v 9 to lau ese oi,  
\q1 tamona sibona lau ura henia.  
\q1 Oi be egu pune manu,  
\q1 egu hahine goeva momokani.  
\q1 Oi be oiemu sinana ena lalokau,  
\q1 oi ia havaraia hahine ena natuna namona momokani.  
\q1 Hahine ibounai ese oi idia itaia noho,  
\q1 bona oi idia hanamoa noho.  
\q1 Lohia edia hahine,  
\q1 bona hesiai hahine ese oi idia itaia,  
\q1 bona oi idia hanamoa bada noho.   
\q1
\v 10 Inai be daika,  
\q1 iena toana be daba rere bamona?  
\q1 Mai ena hairaina, hua bamona?  
\q1 Mai ena diaridiari, dina bamona?  
\q1 Iena toana be mai garina,  
\q1 tuari orea mai edia pepe edia toana bamona?   
\q1
\v 11 Okari audia edia uma gabuna lalonai lau raka,  
\q1 koura dekenai idia vara avadia do lau itaia.  
\q1 Ma do lau itaia, vain edia raurau,  
\q1 be idia tubu noho o lasi,  
\q1 bona do lau diba, apolo audia dekenai,  
\q1 apolo edia palauapalaua idia hedinaraia o lasi.   
\q1
\v 12 Lau be lau heudeheude noho,  
\q1 oiemu ura henia lau ura dikadika noho,  
\q1 kariota ia guia tauna ese,  
\q1 tuari ia ura dikadika noho bamona.   
\s2 Ierusalema hahine taudia idia hereva  
\q1
\v 13 Sulama hahine e, do oi giroa mai,  
\q1 do oi giroa mai.  
\q1 Ai ura oi mavaru neganai,  
\q1 oi do ai itaia gwauraia.  
\s2 Hahine ia hereva  
\q1 Badina dahaka lau, Sulama hahine umui ura itaia,  
\q1 tuari orea rua edia huanai ena mavaruna,  
\q1 do lau mavaru neganai?   
\c 7  
\s2 Tau ia hereva  
\q1
\v 1 King ena natuna hahine e,  
\q1 oiemu aena mai edia tamaka danu be hairai herea!  
\q1 Oiemu mamuna edia kuboru,  
\q1 be herahera nadi edia kuboru bamona,  
\q1 nadi ia koroa tauna ese ia karaia gauna.   
\q1
\v 2 Oiemu hudona be kapusi kuboruna bamona,  
\q1 uaina dekenai ia honu noho nega ibounai.  
\q1 Oiemu bogana be uiti ena senuna ta,  
\q1 sosana palauapalaua ese idia hagegea noho.   
\q1
\v 3 Oiemu ratana ruaosi,  
\q1 be uda dia hahine ena natuna rua bamona.  
\q1 uda dia hahine ena natuna vara hekapa.   
\q1
\v 4 Oiemu aiona be kohoro bamona,  
\q1 aivori dekena amo idia haginia gauna.  
\q1 Oiemu matana be Hesebona hanua,  
\q1 ena gohu maragidia ruaosi bamona,  
\q1 Batarabimi magu iduara ena badibadinai.  
\q1 Oiemu udu baubauna be namo herea,  
\q1 Lebanona kohoro bamona,  
\q1 Damaseko gimaia totona unai kohoro ia gini noho.   
\q1
\v 5 Oiemu kwarana be mai ena hairaina,  
\q1 Karamele Ororo bamona,  
\q1 bona oiemu huina, idia hatua gauna,  
\q1 be varo kakakaka bamona.  
\q1 Oiemu huina ena hairaina ese,  
\q1 king ta ia abia mauri diba.   
\q1
\v 6 Lalokau e, moale momokani havaraia hahine e,  
\q1 oi be hahine namona,  
\q1 oi be mai hairaina momokani.   
\q1
\v 7 Oiemu gini be namo, pama auna bamona,  
\q1 bona oiemu ratana,  
\q1 be pama ena huahua bamona.   
\q1
\v 8 Lau laloa, pama auna do lau daekau lao,  
\q1 bona pama ena huahua do lau abia.  
\q1 To lau dekenai oiemu ratana ruaosi,  
\q1 be vain huahua namodia bamona.  
\q1 Oiemu uduna ena bonana,  
\q1 be apolo huahua edia bonana hegeregerena.   
\q1
\v 9 Bona oiemu uduna,  
\q1 be uaina namo herea momokani bamona.  
\s2 Hahine ia hereva  
\q1 Unai uaina be egu lalokau tauna dekenai,  
\q1 maoromaoro do ia heau lao be namo,  
\q1 iena bibina bona iena isena,  
\q1 dekenai do ia heau lao.   
\q1
\v 10 Lau be egu lalokau tauna ena,  
\q1 bona ia ese lau ia ura henia noho.   
\q1
\v 11 Egu lalokau e, oi mai!  
\q1 Uma tanodia dekenai do ita raka lao,  
\q1 hanuaboi neganai hanua maragidia dekenai do ita noho.   
\q1
\v 12 Daba neganai vain umadia dekenai do ita lao,  
\q1 do ita itaia vain edia palauapalaua,  
\q1 be idia hedinaraia o lasi.  
\q1 Do ita itaia, vain huahua maragidia,  
\q1 be idia tubu hamatamaia o lasi.  
\q1 Do ita tahua danu,  
\q1 apolo idia tubu noho, o lasi.  
\q1 Unai gabu dekenai, oi do lau ura henia.   
\q1
\v 13 Dudai edia bonana idia daekau noho.  
\q1 Iseda iduara ena ataiai,  
\q1 be huahua namodia idauidau idia noho,  
\q1 matamatadia bona gunadia danu.  
\q1 Lau ese oi totona idia lau haboua vadaeni,  
\q1 egu lalokau e!   
\c 8  
\s2 Hahine ia hereva  
\q1
\v 1 Lau ura oi be lauegu taihuna,  
\q1 egu sinana ena ratana ia inua tauna,  
\q1 vadaeni bema ariara dekenai ita hedavari neganai,  
\q1 lau ese oi do lau kisi henia,  
\q1 bona tau ta ese,  
\q1 lau do ia gwauraia kerere lasi.   
\q1
\v 2 Unai neganai lau ese oi do lau hakaua,  
\q1 bona egu sinana ena ruma do ita raka vareai.  
\q1 Unuseni oi ese lalokau,  
\q1 be lau dekenai do oi hadibaia.  
\q1 Lau ese uaina mai muramura,  
\q1 be oi dekenai do lau henia.  
\q1 Apolo ranuna danu oi dekenai do lau henia.   
\q1
\v 3 Oiemu imana laurina ese,  
\q1 egu kwarana ena henunai do ia noho,  
\q1 bona oiemu imana idibana,  
\q1 ese lau do ia rosia noho.   
\q1
\v 4 Ierusalema hahine e, umui lau oda henia inai,  
\q1 aiemai ura henia dekena amo,  
\q1 ai dekenai do umui boiboi lasi,  
\q1 bona ai do umui hanogaia lasi,  
\q1 ela bona ai sibona ai ura do ai noga.   
\s1 Ane namba 6  
\s2 Ierusalema ena hahine taudia idia abia  
\q1
\v 5 Unai be daika,  
\q1 tano kaukau dekena amo ia mai noho,  
\q1 iena lalokau tauna ena imana ia dogoatao noho?  
\s2 Hahine ia hereva  
\q1 Apolo auna ena henunai oi lau hanogaia.  
\q1 Unuseni oiemu sinana ese oi ia havaraia.  
\q1 Unuseni oiemu sinana ese mara ena hisihisi ia abia.   
\q1
\v 6 Egu lalokau e, oiemu kudouna,  
\q1 ena latanai lau do oi dogoatao,  
\q1 lalokau gwauhamata ena toana ageva oi atoa bamona.  
\q1 Oiemu imana ese hahine ma ta do ia rosia lasi,  
\q1 lau sibona.  
\q1 Lalokau ena goada be mase ena goada hegeregerena,  
\q1 bona mama ena dagedage danu,  
\q1 be mase gabuna ena dagedage danu hegeregerena.  
\q1 Iena siahu be lahi ena siahu bamona,  
\q1 ia hururuhururu bada noho,  
\q1 lahi bada hereana bamona.   
\q1
\v 7 Ranu momo ese lalokau ia habodoa diba lasi.  
\q1 Abata badana ese lalokau ia kokia ore diba lasi.  
\q1 Sedira tau ta ese iena kohu,  
\q1 bona moni ibounai do ia henia,  
\q1 hahine ena lalokau do ia hoia totona,  
\q1 to unai be hegeregere lasi.  
\q1 Iena ura, be unai hahine ese do ia negea momokani.   
\s2 Hahine bona iena tau idia hereva  
\q1
\v 8 Aiemai tadina ta be do mai ratana lasi.  
\q1 Bema tau ta ese ia do ia abia gwauraia neganai,  
\q1 edena bamona aiemai tadina do ai durua?   
\q1
\v 9 Bema ia be magu neganai,  
\q1 ai ese siliva kohoro dekena amo do ai ha-aukaia.  
\q1 Bema ia be iduara neganai,  
\q1 sida reirei audia dekena amo do ai koua.   
\s2 Hahine ia hereva  
\q1
\v 10 Lau be magu,  
\q1 bona egu ratana ruaosi be kohoro bamona.  
\q1 Unai dainai egu lalokau tauna dekenai,  
\q1 lau ese lalo namo bona maino lau henia noho.   
\q1
\v 11 Solomona ena vain uma ta be Bala Hamono dekenai.  
\q1 Ia ese uma naria taudia,  
\q1 be unai uma dekenai ia atoa.  
\q1 Idia ta ta ese siliva moni 1000,  
\q1 be Solomona dekenai idia henia noho,  
\q1 uma ena anina edia davana.   
\q1
\v 12 Solomona e, oiemu siliva moni 1000 do oi abia,  
\q1 vain naria taudia ese edia gaukara davana,  
\q1 siliva moni 200 danu do idia abia.  
\q1 To lauegu vain uma, be lauegu uma korikori,  
\q1 lau sibona egu.   
\s2 Tau ia hereva  
\q1
\v 13 Egu lalokau e, uma lalonai oi noho,  
\q1 mani emu kara lau dekenai do oi hereva.  
\q1 Egu turana taudia danu ese,  
\q1 oiemu gadona do idia kamonai totona idia naria noho.   
\s2 Hahine ia hereva  
\q1
\v 14 Egu lalokau tauna e, lau dekenai oi mai haraga,  
\q1 dia ia heau bamona,  
\q1 uda nanigosi o dia ena natuna,  
\q1 bonana namo muramura idia vara noho ororo,  
\q1 dekena amo idia heau mai bamona.   