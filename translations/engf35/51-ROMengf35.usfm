\s2 Circumcision  
\p
\v 25 \w Now|strong="G1161"\w* \w circumcision|strong="G4061"\w* \w does|strong="G1510"\w* \w have|strong="G1510"\w* \w value|strong="G5623"\w* \w if|strong="G1437"\w* \w you|strong="G4771"\w* \w keep|strong="G4238"\w* \w the|strong="G1161"\w* \w Law|strong="G3551"\w*, \w but|strong="G1161"\w* \w if|strong="G1437"\w* \w you|strong="G4771"\w* \w are|strong="G1510"\w* \w a|strong="G1096"\w* \w transgressor|strong="G3848"\w* \w of|strong="G3551"\w* \w the|strong="G1161"\w* \w Law|strong="G3551"\w*, \w your|strong="G1437"\w* \w circumcision|strong="G4061"\w* \w has|strong="G1096"\w* \w become|strong="G1096"\w* uncircumcision.  
