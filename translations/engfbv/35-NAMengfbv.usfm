\v 13 \w Now|strong="H6258"\w* \w I|strong="H5921"\w* will \w break|strong="H7665"\w* \w their|strong="H5921"\w* \w yoke|strong="H4132"\w* \w from|strong="H5921"\w* \w your|strong="H5921"\w* necks \w and|strong="H7665"\w* \w tear|strong="H5423"\w* \w away|strong="H5423"\w* \w the|strong="H5921"\w* \w chains|strong="H4147"\w* which bind \w you|strong="H5921"\w*.
\p 
