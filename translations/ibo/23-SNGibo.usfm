\id SNG - Biblica® Open Igbo Contemporary Bible 2020
\h Abụ nke Abụ
\toc1 Abụ nke Abụ
\toc2 Abụ nke Abụ
\toc3 Abk
\mt1 Abụ nke Abụ
\c 1
\p 
\v 1 Abụ nke abụ nke Solomọn.
\b
\sp Onye a hụrụ nʼanya
\q1 
\v 2 Ya were nsusu niile nke ọnụ ya susuo m ọnụ,
\q2 nʼihi na ịhụnanya gị dị ụtọ karịa mmanya.
\q1 
\v 3 Mmanụ otite gị niile na-esi isi ọma,
\q2 aha gị dịka mmanụ isi ụtọ awụpụtara awụpụta,
\q2 ọ bụghị ihe ịtụnanya na ụmụ agbọghọ hụrụ gị nʼanya.
\q1 
\v 4 Kpọrọ m, ka mụ na gị soro, ka anyị mee ngwangwa.
\q2 Ka eze kpọbata m nʼime ụlọ ya.
\sp Ndị Enyi
\q1 Anyị ga-aṅụrị ọṅụ nwekwa obi ụtọ nʼime gị.
\q2 Anyị ga-eto ịhụnanya gị karịa mmanya.
\sp Onye a hụrụ nʼanya
\q1 Lee nʼizi ezi ka ha nʼahụ gị nʼanya nke ukwuu.
\b
\q1 
\v 5 Ana m eji nji ma a maara m mma ile anya,
\q2 unu ụmụ agbọghọ Jerusalem.
\q1 Adị m nji dịka ụlọ ikwu nke Keda\f + \fr 1:5 \ft Ndị Keda bụ otu ebo nʼetiti ndị Arab, obodo ha dị na ndịda ọdịda anyanwụ Edọm. Ha na-ebi nʼụlọ ikwu e ji ajị ewu ojii wuo\f*
\q2 dịka akwa mgbochi dị nʼụlọ Solomọn.
\q1 
\v 6 Unu elekwasịla m anya, maka na m na-eji nji.
\q2 Ọ bụ anwụ gbajiri m.
\q1 Ụmụnne m ndị ikom were iwe megide m,
\q2 zipụ m nʼezi ilekọta ubi vaịnị anyị,
\q2 ma ubi vaịnị nke m ka m na-elekọtaghị.
\q1 
\v 7 Gwa m, gị onye m hụrụ nʼanya,
\q2 ebee ka anụ ụlọ gị na-ata nri?
\q2 Ebee ka atụrụ gị na-ezu ike nʼetiti ehihie?
\q1 Nʼihi gị ka m ga-eji dịka nwanyị e kpuchiri ihu
\q2 nʼetiti igwe anụ ụlọ ndị enyi gị.
\sp Ndị Enyi
\q1 
\v 8 Ọ bụrụ na ị maghị, gị nwanyị kachasị mma,
\q2 soro nzọ ụkwụ igwe atụrụ
\q1 meekwa ka ụmụ ewu gị taa ahịhịa
\q2 dị nʼakụkụ ụlọ ikwu ndị na-elekọta atụrụ.
\sp Onye hụrụ ibe ya nʼanya
\q1 
\v 9 Ana m atụnyere gị, gị onye m hụrụ nʼanya dịka nne ịnyịnya
\q2 e kenyere nʼotu ụgbọ agha Fero.
\q1 
\v 10 Agba nti gị ka e jiri ọlantị chọọ mma,
\q2 olu gị kwa ka e jiri nkume dị oke ọnụahịa e doro nʼahịrị chọọ mma.
\q1 
\v 11 Anyị ga-emere gị ọlantị dị iche iche nke ọlaedo,
\q2 nke e ji ọlaọcha chọọ mma.
\sp Onye a hụrụ nʼanya
\q1 
\v 12 Mgbe eze nọ na tebul ya,
\q2 mmanụ isi ọma m tere sijuru ebe niile.
\q1 
\v 13 Onye m hụrụ dị m ka ụda máá\f + \fr 1:13 \ft Ụda máá bụ eso e ji eme ihe otite na-esi isi ụtọ. A na-ewepụta eso ndị a nʼosisi Balsam nke na-eto nʼobodo Kush, nʼetiti ọwụwa anyanwụ nakwa India.\f* e kechiri nʼakpa
\q2 nke dị nʼetiti ara m abụọ.
\q1 
\v 14 Onye m hụrụ nʼanya dịrị m ka ụyọkọ ukwu okoko henna\f + \fr 1:14 \ft Okoko osisi henna bụ ahịhịa isi ọma a na-eji emepụta senti.\f*
\q2 nke sitere nʼogige ubi vaịnị En-Gedi.\f + \fr 1:14 \ft Bụ odo mmiri dị nʼọdịda osimiri nwụrụ anwụ. Ọtụtụ osisi nke a na-esi na ha enweta eso na-esi isi ọma, jupụtara nʼebe ahụ.\f*
\sp Onye hụrụ ibe ya nʼanya
\q1 
\v 15 Nʼezie, ị mara mma, onye m hụrụ nʼanya.
\q2 Leenụ ka ị si maa mma!
\q2 Anya gị dịka nduru.
\sp Onye a hụrụ nʼanya
\q1 
\v 16 Onye m hụrụ nʼanya, ị mara mma nwoke.
\q2 E, ị mara mma.
\q2 Ebe ndina anyị dịka ahịhịa ndụ.
\sp Onye hụrụ ibe ya nʼanya
\q1 
\v 17 Ogidi nke ụlọ anyị bụ osisi sida,
\q2 ntuhie ya bụkwa osisi fịa.
\c 2
\sp Onye a hụrụ nʼanya
\q1 
\v 1 Abụ m okoko osisi ọhịa nke Sharọn,\f + \fr 2:1 \ft Okoko osisi a bụ otu nʼime okoko osisi ndị na-epu nʼọkọchị, na ndịda akụkụ osimiri Kamel \xt Aịz 35:1-2\xt*\f*
\q2 na okoko lili nke na-epu na ndagwurugwu.
\sp Onye hụrụ ibe ya nʼanya
\q1 
\v 2 E, dịka okoko lili nke na-epu nʼetiti ogwu,
\q2 otu a ka ọmasịrị m dị nʼetiti ụmụ agbọghọ ndị ọzọ.
\sp Onye a hụrụ nʼanya
\q1 
\v 3 Onye m hụrụ nʼanya dịka osisi apụl, nʼetiti osisi na-amị mkpụrụ nʼọhịa,
\q2 mgbe e ji ya tụnyere ụmụ okorobịa ndị ọzọ.
\q1 Ọ na-enye m obi ụtọ ịnọ nʼokpuru ndo ya,
\q2 mkpụrụ ya dịkwa ụtọ nʼọnụ.
\q1 
\v 4 Ka ọ kpọrọ m jee nʼụlọ oriri,
\q2 ka ọkọlọtọ ya nʼekpuchi m bụrụ ịhụnanya.
\q1 
\v 5 Were mkpụrụ osisi a mịkpọrọ amịkpọ gbaa m ume;
\q2 werekwa mkpụrụ osisi apụl mee ka ahụ m dị ike,
\q2 nʼihi na abụ m onye ịhụnanya mere ka ike gwụsịa.
\q1 
\v 6 Aka ekpe ya dị nʼokpuru isi m,
\q2 aka nri ya na-ejikụ m.
\q1 
\v 7 Unu ụmụ agbọghọ Jerusalem,
\q2 eji m nne mgbada niile na nne ele ọhịa niile na-agba unu iyi sị:
\q1 Unu akpọtela maọbụ mee ka ịhụnanya teta,
\q2 ruo mgbe ọ masịrị ya.
\b
\q1 
\v 8 Gee ntị! Onye m hụrụ nʼanya!
\q2 Lee ya ka ọ na-abịa,
\q1 na-amali elu nʼelu ugwu niile,
\q2 na-amafekwa nʼelu ugwu nta niile.
\q1 
\v 9 Onye m hụrụ nʼanya yiri mgbada, o yiri nwa ele.
\q2 Lee ya ka ọ na-eguzo nʼazụ mgbidi anyị,
\q1 ọ na-esikwa na oghereikuku
\q2 na nʼoghere dị ya na-elebata anya.
\q1 
\v 10 Onye m hụrụ nʼanya gwara m okwu sị m,
\q2 “Bilie, onye ihe ya na-atọ m ụtọ,
\q2 onye m mara mma, soro m.
\q1 
\v 11 Lee, oge oyi agafeela,
\q2 udu mmiri agabigakwala.
\q1 
\v 12 Okoko osisi epupụtala nʼala;
\q2 oge eji agụ egwu eruokwala,
\q1 a na-anụ abụ nduru
\q2 nʼala anyị niile.
\q1 
\v 13 Mkpụrụ osisi fiig ebidola ịmịpụta mkpụrụ ya nke mbụ,\f + \fr 2:13 \ft Osisi fiig na-amị mkpụrụ ugboro abụọ nʼafọ nʼIzrel. Ọ bụ nʼoge ọkọchị ka ọ kachasị amị mkpụrụ, amaokwu a na-ekwu banyere owuwe ihe ubi nke mkpụrụ fiig mbụ.\f*
\q2 isi osisi vaịnị na-amịpụta okoko na-esiju ebe niile.
\q1 Bilie, ma bịa, ọmasịrị m.
\q2 Onye nke m mara mma! Bịa ka i sooro m.”
\sp Onye hụrụ ibe ya nʼanya
\q1 
\v 14 Nduru m nọ nʼọgba nkume,
\q2 nʼebe nzuzo nke akụkụ ugwu,
\q1 gosi m ihu gị,
\q2 mee ka m nụ olu gị,
\q1 nʼihi na olu gị dị ụtọ,
\q2 ihu gị makwara mma.
\q1 
\v 15 Jidenụ nkịta ọhịa,
\q2 ụmụ nkịta ọhịa niile
\q1 na-emebiri anyị ubi,
\q2 ọ bụladị ubi vaịnị anyị na-agbawa okoko.
\sp Onye a hụrụ nʼanya
\q1 
\v 16 Onye m hụrụ nʼanya bụ nke m, mụ onwe m bụkwa nke ya.
\q2 Ọ na-azụ igwe atụrụ ya nʼetiti okoko urodi,
\q1 
\v 17 tutu chi ụtụtụ abọọ
\q2 mgbe onyinyo niile na-agabigakwa.
\q1 Tụgharịa, onye m hụrụ nʼanya,
\q2 dị ka mgbada
\q1 maọbụ nwa ele
\q2 nke nọ nʼelu ugwu.
\b
\c 3
\q1 
\v 1 Achọrọ m onye m hụrụ nʼanya
\q2 nʼelu ihe ndina m nʼabalị, ma ahụghị m ya.
\q2 Ebiliri m chọọ ya ma ahụghị m ya.
\q1 
\v 2 Ugbu a, aga m ebili pụọ jegharịa nʼama niile
\q2 na nʼokporoụzọ niile nke obodo ịchọ ya,
\q1 m ga-achọgharị onye m hụrụ nʼanya.
\q2 Ya mere, achọrọ m ya ma ahụghị m ya.
\q1 
\v 3 Ndị nche na-eche obodo\f + \fr 3:3 \ft \xt Aịz 21:11-12\xt*\f* hụrụ m,
\q2 mgbe ha na-agagharị nʼobodo,
\q2 ma ajụrụ m ha sị, “Biko, unu hụrụ onye ahụ m hụrụ nʼanya?”
\q1 
\v 4 Ọ dịghị anya mgbe m gafere ha,
\q2 achọtara m onye m hụrụ nʼanya,
\q1 ejidesiri m ya ike, ahapụghị m ya aka
\q2 tutu m duta ya nʼụlọ nne m,
\q2 nʼime ụlọ nwanyị tụrụ ime m.
\q1 
\v 5 Unu ụmụ agbọghọ Jerusalem,
\q2 eji m nne mgbada niile na nne ele ọhịa gbaa unu iyi sị,
\q1 unu akpọtela, maọbụ mee ka ịhụnanya teta
\q2 ruo mgbe o masịrị ya.
\b
\q1 
\v 6 Onye bụ nke a na-esi nʼọzara na-abịa
\q2 dịka anwụrụ ọkụ,
\q1 nke tere mmanụ máá na ụda na-esi isi ụtọ,
\q2 ụda nke ndị ahịa na-ere?
\q1 
\v 7 Lee ọ bụ ụgbọ Solomọn.
\q2 Iri mmadụ isii ndị ọka agha,
\q2 ndị a maara aha ha karịsịa nʼala Izrel sokwa ya.
\q1 
\v 8 Ha niile ji mma agha;
\q2 ha bụ ndị a zụrụ nke ọma ibu agha.
\q1 Mma agha onye ọbụla dịkwa nʼukwu ya,
\q2 ịdị njikere maka ihe egwu abalị.
\q1 
\v 9 Eze Solomọn rụrụ onwe ya ụgbọ a
\q2 nke o ji osisi sitere Lebanọn rụọ.
\q1 
\v 10 Ogidi ya ka o ji ọlaọcha mee;
\q2 ala ya bụkwa ọlaedo.
\q1 Ebe ịnọdụ ọdụ ya ka e ji akwa odo odo kpaa,
\q2 e ji ịhụnanya dozie ebe ime ya.
\q1 Ndị inyom Jerusalem,
\v 11 pụtanụ,
\q2 bịa hụrụ, unu ụmụ agbọghọ Zayọn,
\q1 bịanụ ka unu hụ Solomọn bụ eze;
\q2 lee ụdị okpueze nne ya kpunyere ya nʼisi,
\q1 nʼụbọchị agbamakwụkwọ ya,
\q2 nʼụbọchị obi ụtọ na ịṅụrị ọṅụ ya.
\c 4
\sp Onye hụrụ ibe ya nʼanya
\q1 
\v 1 Leenụ ka i si maa mma, onye m hụrụ nʼanya,
\q2 e, ị mara mma!\f + \fr 4:1 \ft \xt Abk 1:15; 5:12\xt*\f*
\q2 Anya gị abụọ nke dị nʼazụ akwa mkpuchi ihu gị dị ka nduru.
\q1 Agịrị isi gị dị ka igwe ewu\f + \fr 4:1 \ft Igwe ewu ndị a dị ojii.\f*
\q2 nke na-arịda nʼakụkụ ugwu Gilead.
\q1 
\v 2 Eze gị dị ka igwe atụrụ a ka kpachapụrụ ajị ha ọhụrụ,
\q2 nke si nʼebe a sapụrụ ha ahụ na-arịpụta.
\q1 Nke ọbụla chi ụmụ abụọ,
\q2 ọ dịghịkwa nke gba aka nwa nʼetiti ha.
\q1 
\v 3 Egbugbere ọnụ gị abụọ dị ka ogho uhie.
\q2 Ọnụ gị dị mma ile anya.
\q1 Agba nti gị abụọ nke dị nʼime akwa mkpuchi gị
\q2 dị ka pomegranet\f + \fr 4:3 \ft Pomegranet na-acha uhie uhie.\f* e kere abụọ.
\q1 
\v 4 Olu gị dị ka ụlọ elu Devid,
\q2 nke e wuziri nke ọma.
\q1 E konyere puku ọta na ya,
\q2 ha niile bụ ọta nke ndị ọka nʼagha.\f + \fr 4:4 \ft \xt Neh 3:19\xt*\f*
\q1 
\v 5 Ara gị abụọ dị ka ụmụ mgbada abụọ,
\q2 nke otu nne mụrụ nʼotu oge,
\q2 ndị na-ata nri nʼetiti okoko urodi.
\q1 
\v 6 Tutu chi ụtụtụ abọọ,
\q2 tutu onyinyo agbalaga,
\q1 aga m aga nʼugwu ụda máá
\q2 na nʼugwu insensi.
\q1 
\v 7 Ị mara mma nke ukwuu, onye m hụrụ nʼanya,
\q2 ọ dịkwaghị ntụpọ\f + \fr 4:7 \ft \xt Efe 5:27\xt*\f* ọbụla dị gị nʼahụ.
\b
\q1 
\v 8 Si na Lebanọn soro m, nwunye m lụrụ ọhụrụ.
\q2 Si na Lebanọn bịa soro m;
\q1 rịdata site nʼugwu Amana,
\q2 nʼugwu Senia, na nʼugwu Hemon,
\q1 site nʼọgba ọdụm
\q2 nʼugwu niile ebe agụ bi.
\q1 
\v 9 I riela m obi, nwanne m nwanyị, nwunye ọhụrụ m;
\q2 i riela m obi,
\q1 i werela ile anya gị
\q2 na ihe olu i yi rie obi m.
\q1 
\v 10 Lee ka ịhụnanya gị si dị ụtọ, nwanne m nwanyị, nwunye ọhụrụ m.
\q2 Lee ka ịhụnanya gị si dị mma nke ukwuu karịa mmanya,
\q1 isisi ụtọ nke mmanụ otite gị
\q2 na-esi isi ọma karịa mmanụ ụda ọbụla.
\q1 
\v 11 Egbugbere ọnụ gị dị ụtọ dịka mmanụ aṅụ dị, nwunye ọhụrụ m,
\q2 mmiri ara ehi na mmanụ aṅụ dị nʼokpuru ire gị,
\q1 isisi ụtọ nke uwe gị
\q2 na-esi ka Lebanọn
\q1 
\v 12 Ubi a gbara ogige, ma gbachiekwa, ka nwanne m nwanyị, nwunye ọhụrụ bụ.
\q2 Ị bụ isi iyi nke a gbara ogige, rachiekwa.\f + \fr 4:12 \ft I ji debe olulu mmiri ọcha, ka ọ ghara ịgwọtọ, a na-emere ya okwuchi. Ma ọ bụrụ isi iyi, a na-akpa ihe mgbochi ka ndị mmadụ ghara iru nʼebe elu elu ya mgbe ha na-ekute mmiri.\f*
\q1 
\v 13 Ihe ọkụkọ dị nʼime ogige gị bụ pomegranet
\q2 nwere ezi mkpụrụ dị oke ọnụahịa,
\q2 nke nwere henna na naad,
\q2 
\v 14 naad na safron,
\q2 kalamus na sinamọn,
\q2 na osisi nke ihe nsure ọkụ na-esi isi ụtọ,
\q2 na ụda máá, na aloos
\q2 na ụda kachasị mma dị iche iche na-esi isi ụtọ.
\q1 
\v 15 I bụ isi iyi nke ubi a gbara ogige,
\q2 olulu mmiri dị ndụ
\q2 nke si na Lebanọn asọdata.\f + \fr 4:15 \ft Mgbe mkpụrụ mmiri nke kpuchiri ugwu Lebanọn na-agbaze, mmiri ya na-asọdata sọbanye nʼime ọtụtụ isi iyi, mee ka isi iyi ndị ahụ ghara ịta ata.\f*
\sp Onye a hụrụ nʼanya
\q1 
\v 16 Teta nʼụra gị ifufe si nʼugwu;\f + \fr 4:16 \ft Ọ bụ ifufe na-esite na mpaghara ugwu, nke na-efe nwayọọ na-eme ka mkpụrụ dị ọhụrụ, maa mma. Ma nke na-esite na ndịda, na-ebute okpomọkụ na-eme ka mkpụrụ ndị a chaa nke ọma. Ikuku abụọ ndị a bụ ihe na-ekusasi ezi isisi nke okoko ahịhịa dị nʼubi a gbara ogige.\f*
\q2 bịakwa gị ifufe si na ndịda,
\q1 fekwasị ubi m a gbara ogige,
\q2 ka isisi ụda ya dị ụtọ fesaa ebe niile,
\q1 ka onye m hụrụ nʼanya bịa nʼubi ya a gbara ogige,
\q2 ka ọ bịa rie mkpụrụ dị iche iche dị nʼime ya nke dị oke ọnụahịa.
\c 5
\sp Onye hụrụ ibe ya nʼanya
\q1 
\v 1 Abatala m nʼubi m a gbara ogige, nwanne m nwanyị, nwunye ọhụrụ m.
\q2 Achịkọtala m máá ya na ụda m,
\q1 arachakwala m mmanụ aṅụ m na ugbugbo mmanụ aṅụ.
\q2 Aṅụkwala m mmiri ara ehi na mmanya m.
\sp Ndị Enyi
\q1 Rie, ṅụọkwa, unu ndị bụ enyi;
\q2 ṅụjuo afọ, unu ndị hụrụ onwe unu nʼanya.
\sp Onye a hụrụ nʼanya
\q1 
\v 2 A rahụrụ m ụra, ma obi m mụ anya.
\q2 Gee ntị, onye ahụ m hụrụ nʼanya na-akụ aka nʼibo ọnụ ụzọ.\f + \fr 5:2 \ft \xt Mkp 3:20\xt*\f*
\q1 “Megheere m ụzọ, nwanne m nwanyị, onye m hụrụ nʼanya,
\q2 nduru m, onye na-enweghị ntụpọ.
\q1 Igirigi ezokwasịla m nʼisi,
\q2 agịrị isi m jupụtara na mmiri nke abalị.”
\q1 
\v 3 Eyipụlarị m uwe m.
\q2 Ọ bụ m yirikwa ha ọzọ?
\q1 Asaala m ụkwụ m,
\q2 aga m eme ka ha ruo unyi ọzọ?
\q1 
\v 4 Onye m hụrụ nʼanya gbatịrị aka ya imeghe ụzọ,
\q2 mgbe ahụ, obi m chọsikwara ya ike.
\q1 
\v 5 Mụ onwe m biliri imeghere onye m hụrụ nʼanya ụzọ,
\q2 ma aka m abụọ jupụtakwara na mmanụ máá,
\q1 mmanụ máá si na mkpịsịaka m niile na-atapụsi,
\q2 nʼelu ihe mkpọchi nke ibo.
\q1 
\v 6 Mgbe m megheere onye m hụrụ nʼanya ụzọ,
\q2 ma lee, ọ nọkwaghị ya, ọ laala.
\q2 Obi fepụrụ m mgbe ọ pụwara.
\q1 Elegharịrị m anya chọọ ya ma ahụghị m ya ebe ọbụla.
\q2 Akpọrọ m ya oku ma ọ zaghị.
\q1 
\v 7 Ndị nche hụrụ m
\q2 mgbe ha na-agagharị nʼobodo,\f + \fr 5:7 \ft \xt Abk 3:3\xt*\f*
\q1 ha tiri m ihe merụọ m ahụ.
\q2 Ndị nche mgbidi obodo
\q2 napụrụ m akwa mkpuchi m.
\q1 
\v 8 Unu ụmụ agbọghọ Jerusalem, ana m agba unu iyi,
\q2 ọ bụrụ na unu ahụ onye m hụrụ nʼanya,
\q1 gịnị ka unu ga-agwa ya?
\q2 Gwa ya na abụ m onye ịhụnanya mere ka ike gwụchasịa nʼahụ.
\sp Ndị Enyi
\q1 
\v 9 Gị nwanyị kachasị mma,
\q2 olee otu onye ị hụrụ nʼanya si dị mma karịa ndị ọzọ?
\q1 Olee otu onye ị hụrụ nʼanya si dị mma karịa ndị ọzọ
\q2 nke i ji enye anyị iwu dị otu a?
\sp Onye a hụrụ nʼanya
\q1 
\v 10 Onye m hụrụ nʼanya chapụrụ achapụ, dị mma ile anya.
\q2 Ọ pụrụ iche nʼetiti puku ndị nwoke iri.
\q1 
\v 11 Isi ya dịka ọlaedo a nụchara anụcha,
\q2 agịrị isi ya na-eruda dịka igu nkwụ,
\q2 na-ejikwa nji dịka ugolọma.
\q1 
\v 12 Anya ya abụọ dịka nduru\f + \fr 5:12 \ft \xt Abk 1:15; 4:1\xt*\f*
\q2 nọ nʼakụkụ mmiri iyi
\q1 nke e jiri mmiri ara ehi sachaa,
\q2 dịka nkume dị oke ọnụahịa e doro nʼahịrị.
\q1 
\v 13 Nti ya abụọ dị ka ihe ndina ụda\f + \fr 5:13 \ft Ụda nwere isisi ọma nke na-eme mmadụ obi ụtọ.\f*
\q2 nke jupụtara na mmanụ isi ụtọ.
\q1 Egbugbere ọnụ ya dị ka okoko urodi,
\q2 nke na-agbụsị mmanụ máá.
\q1 
\v 14 Aka ya abụọ dị ka mkpara ọlaedo a kpụziri akpụzi,
\q2 nke a hịọnyere nkume oke ọnụahịa beril nʼime ya.
\q1 Ahụ ya na-akwọ mụrụmụrụ dịka ọdụ
\q2 nke e ji nkume dị oke ọnụahịa safaia chọọ mma.
\q1 
\v 15 Ogwe ụkwụ ya abụọ dị ka ogidi e ji nkume mabụl kpụọ,
\q2 nke e ji ọlaedo a ṅụchara anụcha tọọ ntọala ha.
\q1 Ụdịdị ya dị ka Lebanọn,
\q2 dịkwa oke ọnụ dịka osisi sida ya.
\q1 
\v 16 Ọnụ ya bụ ihe tọkarịsịrị ụtọ nʼonwe ya,
\q2 ihe niile banyere ya dị mma nʼile anya.
\q1 Unu ụmụ agbọghọ Jerusalem,
\q2 onye dị otu a bụ onye ahụ m hụrụ nʼanya, ọ bụkwa enyi m.
\c 6
\sp Ndị Enyi
\q1 
\v 1 Gị onye mara mma nʼetiti ndị inyom,
\q2 ebee ka onye ị hụrụ nʼanya jere?
\q1 Olee ụzọ o sitere?
\q2 Ka anyị soro gị chọọ ya.
\sp Onye a hụrụ nʼanya
\q1 
\v 2 Ọ gara nʼubi ya a gbara ogige,
\q2 nʼebe ihe ndina ya nke e fesara ụda na-esi isi ụtọ,
\q1 ijegharị nʼetiti okoko urodi,
\q2 na ịchịkọta okoko lili.
\q1 
\v 3 Abụ m nke onye m hụrụ nʼanya, onye m hụrụ nʼanya bụkwa nke m.
\q2 Ọ na-azụ igwe atụrụ ya nʼetiti okoko urodi.
\sp Onye hụrụ ibe ya nʼanya
\q1 
\v 4 Onye m hụrụ nʼanya, ị mara mma dịka Tịaza, ị mara mma nke ukwu dịka Jerusalem, ị dị ebube ka usuu ndị agha ji ọkọlọtọ.\f + \fr 6:4 \ft Tịaza bụ obodo ochie eze Jeroboam họpụtara ka ọ bụrụ isi obodo ọchịchị nke alaeze ugwu. Ọ bụ na senchuri nke iri (Tupu a mụọ Kraịst). \xt 1Ez 14:17; 1Ez 15:21,33; 16:6,8,15,23\xt*\f*
\q2 Ị dị mma ile anya dịka Jerusalem;
\q2 Ị dị ka ndị agha bu ọkọlọtọ.
\q1 
\v 5 Wepụ anya gị nʼebe m nọ,
\q2 nʼihi na i jirila anya gị dọta m.
\q1 Agịrị isi gị dị ka igwe ewu\f + \fr 6:5 \ft \xt Abk 4:2\xt*\f*
\q2 nke na-arịdata site nʼugwu Gilead.
\q1 
\v 6 Eze gị dị ka igwe atụrụ
\q2 nke si nʼebe a sapụrụ ha ahụ na-arịpụta.
\q1 Nke ọbụla chi ụmụ abụọ,
\q2 ọ dịghịkwa nke nwa ya furu efu nʼetiti ha.
\q1 
\v 7 Agba ntị gị abụọ nke dị nʼime akwa mkpuchi gị
\q2 dị ka pomegranet e kere abụọ.
\q1 
\v 8 E nwere ike nwee iri eze nwanyị isii,
\q2 na iri ndị iko nwanyị asatọ,
\q2 na ọtụtụ ụmụ agbọghọ a na-apụghị ịgụta ọnụ,
\q1 
\v 9 ma gị onwe gị, nduru m, ezigbo m zuruoke, pụrụ iche nʼetiti ha niile.
\q2 Naanị otu nwanyị nne ya nwere,
\q2 ọ masịrị onye mụrụ ya.
\q1 Ụmụ agbọghọ hụrụ ya kpọọ ya onye a gọziri agọzi,
\q2 ndị eze nwanyị na ndị iko nwanyị tooro ya.
\sp Ndị Enyi
\q1 
\v 10 Onye bụ onye a, pụtara ihe dịka chi ọbụbọ,
\q2 nke mara mma dịka ọnwa, na-enwu dịka anyanwụ,
\q2 dị ebube ka dị usuu kpakpando na-aga nʼahịrị nʼahịrị?
\sp Onye hụrụ ibe ya nʼanya
\q1 
\v 11 Agara m nʼubi a gbara ogige ebe a kụrụ mkpụrụ osisi,
\q2 ile ihe na-etopụta ọhụrụ na ndagwurugwu,
\q1 ilekwa akwụkwọ ndụ ọhụrụ ndị na-epupụta nʼosisi vaịnị,
\q2 na ị mata ma nʼosisi pomegranet ọ mara ifuru.
\q1 
\v 12 Tupu m mata ebe m nọ,
\q2 agụ nke mkpụrụobi m adọtala m tinye nʼetiti ụgbọ agha nke ndị eze ala m.
\sp Ndị Enyi
\q1 
\v 13 Laghachi azụ, gị onye Shulam, laghachi azụ;
\q2 laghachi azụ, e, laghachi azụ ka anyị lee gị anya.
\sp Onye hụrụ ibe ya nʼanya
\q1 Maka gịnị ka unu ga-eji lee onye Shulam anya
\q2 dịka ọ bụ ite egwu ndị Mahanaim?
\b
\c 7
\q1 
\v 1 Lee ka ụkwụ gị si dị mma nʼime akpụkpọụkwụ
\q2 gị ada nwa eze.
\q1 Apata ụkwụ gị abụọ dị ezi mma dịka nkume oke ọnụahịa,
\q2 ọrụ aka nke ezigbo onye ọkwa ǹka.
\q1 
\v 2 Otubo gị mara mma
\q2 dịka iko nke a gbajuru mmanya.
\q1 Ukwu gị dị ka ukwu ọka
\q2 e ji okoko urodi gbaa gburugburu.
\q1 
\v 3 Ara gị abụọ dị ka ụmụ mgbada abụọ
\q2 nke otu nne mụrụ nʼotu oge.
\q1 
\v 4 Olu gị guzo kwem dị ka ụlọ elu e ji ọdụ wuo.
\q1 Anya gị abụọ dị ka ọdọ mmiri Heshbọn
\q2 nke dị nʼakụkụ ọnụ ụzọ ama Bat-Rabim.
\q1 Imi gị mara mma dị ka ụlọ elu Lebanọn
\q2 nke chere Damaskọs ihu.
\q1 
\v 5 Isi gị guzo nʼahụ gị ka ugwu Kamel.
\q2 Agịrị isi nke isi gị dịkwa ogho odo odo.\f + \fr 7:5 \ft Ihe akpara akpa nke e jiri mara onye a na-enye nsọpụrụ\f*
\q2 Ịma mma nke agịrị isi gị emela eze onye a dọtara nʼagha.
\q1 
\v 6 Lee ka i si maa mma nke ukwuu, nʼezie, ị mara mma.
\q2 Ị dịkwa ụtọ nke ukwuu, gị onye m hụrụ nʼanya.
\q1 
\v 7 Ị dị ogologo dịka osisi nkwụ;
\q2 ara gị abụọ dịkwa ka ụyọkọ mkpụrụ osisi.
\q1 
\v 8 Ekwuru m sị, “Aga m arịgoro elu osisi nkwụ ahụ,
\q2 jidekwa mkpụrụ ya aka.”
\q1 Ugbu a, ka ara gị abụọ dịkwa ka ụyọkọ mkpụrụ vaịnị,
\q2 ka isisi nke iku ume gị dịkwa ka mkpụrụ osisi apụl,
\q2 
\v 9 ka okpo ọnụ gị dịka mmanya makarịsịrị na mma.
\sp Onye a hụrụ nʼanya
\q1 Ka mmanya ahụ gbadaa nwayọọ nye onye m hụrụ nʼanya,
\q2 na-asọda nwayọọ nʼelu egbugbere ọnụ ya na eze ya.
\q1 
\v 10 Abụ m nke onye ahụ m hụrụ nʼanya,
\q2 ọ bụkwa m ka ọ chọrọ.
\q1 
\v 11 Bịa, onye m hụrụ nʼanya, ka anyị gaa nʼime obodo,
\q2 ka anyị nọọ ọnọdụ abalị nʼobodo nta.
\q1 
\v 12 Ka anyị bilie ngwangwa nʼisi ụtụtụ pụọ jee nʼubi
\q2 lee ma osisi vaịnị ha amaala ifuru,
\q1 ma okoko ya agbawaala,
\q2 ma osisi pomegranet agbawaala okoko.
\q2 Nʼebe ahụ ka m ga-egosi gị ịhụnanya m.
\q1 
\v 13 Nʼebe ahụ ka ị ga-anọ nụ isi nke mandreki\f + \fr 7:13 \ft Dịka ndị mmadụ na-ekwu, mandreki na-eweta mkpali ọchịchọ mmekọrịta nʼahụ mmadụ, na-emekwa ka nwanyị tara ya tụrụ ime. \xt Jen 30:14\xt*\f* na-ewepụta;
\q2 mkpụrụ osisi niile na-atọ ụtọ ga-adịkwa nʼọnụ ụzọ anyị,
\q1 ma ndị ọhụrụ ma ndị ochie,
\q2 nʼihi na edokọtaala m ha maka onye m hụrụ nʼanya.
\b
\c 8
\q1 
\v 1 O, a sịkwarị na ị bụ nwanne m nwoke;
\q2 nke otu nne mụrụ mụ na ya
\q1 m gaara esutu gị ọnụ
\q2 mgbe anyị zutere nʼokporoụzọ
\q2 ma ọ dịkwaghị onye ọbụla ga-eleda m anya.
\q1 
\v 2 Agaara m akpọrọ gị baa nʼụlọ nne m,
\q2 ka ị nọdụ nʼebe ahụ,
\q2 nʼụlọ onye ziri m ihe.
\q1 Agaara m enye gị mmanya e tinyere ihe na-esi isi ụtọ,
\q2 mmanya ụtọ nke pomegranet.
\q1 
\v 3 Aka ekpe ya dị nʼokpuru isi m,
\q2 aka nri ya na-ejikụ m.
\q1 
\v 4 Unu ụmụ agbọghọ Jerusalem, ana m agba unu iyi,
\q2 unu agaghị akpọte maọbụ mee ka ịhụnanya teta
\q2 tupu ruo mgbe ọ masịrị ya.
\sp Ndị Enyi
\q1 
\v 5 Onye bụ onye a si nʼọzara na-abịa,
\q2 onye na-adabere nʼahụ onye ọ hụrụ nʼanya.
\sp Onye a hụrụ nʼanya
\q1 Nʼokpuru osisi apụl ka m kpọtere gị;
\q2 nʼebe ahụ ka nne gị tụrụ ime gị;
\q2 nʼebe ahụ ka ọ nọ mụọ gị.
\q1 
\v 6 Tụkwasị m dịka mgbaaka ihe a kara nʼobi,
\q2 dịka mgbaaka ihe a kara nʼaka gị
\q1 nʼihi na ịhụnanya dị ike dịka ọnwụ,
\q2 ekworo\f + \fr 8:6 \ft \xt Ilu 6:34-35\xt*\f* ya dịkwa ike dịka ala mmụọ.
\q1 Ọ na-enwupụtakwa dịka ọkụ na-ere ere,
\q2 dịka ọkụ nke dị ukwu.
\q1 
\v 7 Ọtụtụ mmiri apụghị imenyụ ịhụnanya,
\q2 osimiri niile enwekwaghị ike iri ya.
\q1 Ọ bụrụ na mmadụ ga-enye
\q2 akụ niile nke ụlọ ya nʼihi ịhụnanya,
\q2 a ga-eleda ya anya nke ukwuu.
\sp Ndị Enyi
\q1 
\v 8 Anyị nwekwara otu nwanne nwanyị nta
\q2 ma ọ kpụbeghị ara.
\q1 Gịnị ka anyị ga-emere nwanne anyị nwanyị,
\q2 nʼụbọchị a ga-abịa ịlụ ya?
\q1 
\v 9 Ọ bụrụ na ọ bụ mgbidi,
\q2 anyị ga-ewukwasị ụlọ elu ọlaọcha nʼelu ya;
\q1 ma ọ bụrụ na ọ bụ ọnụ ụzọ,
\q2 anyị ga-eji ibo e ji osisi sida wuo mechie ya, ichebe ya.
\sp Onye a hụrụ nʼanya
\q1 
\v 10 Abụ m mgbidi,
\q2 ara m abụọ guzokwa dịka ụlọ elu.
\q1 Otu a ka m siri dị nʼanya ya
\q2 dịka onye na-ewetara ya afọ ojuju.
\q1 
\v 11 Solomọn nwere ubi vaịnị na Baal-Hamon,
\q2 o nyefere ubi vaịnị ya nʼaka ndị ọrụ nlekọta.
\q1 Onye ọbụla nʼime ha ga-eweta
\q2 puku shekel ọlaọcha maka mkpụrụ ọ na-amịta.\f + \fr 8:11 \ft \xt Mat 21:33\xt*\f*
\q1 
\v 12 Ma ubi vaịnị m bụ nke aka m. Ana m enye ya onye m chọrọ inye.
\q2 Puku ọlaọcha bụ nke Solomọn,
\q2 ndị ọrụ ubi ga-enwetakwa narị ọlaọcha abụọ.
\sp Onye hụrụ ibe ya nʼanya
\q1 
\v 13 Gị onye bi nʼubi a gbara ogige,
\q2 gị na ndị enyi gị,
\q2 kwere ka m nụ olu gị.
\sp Onye a hụrụ nʼanya
\q1 
\v 14 Soro m ka anyị pụọ, onye m hụrụ nʼanya,
\q2 bịakwute m dịka mgbada,
\q1 maọbụ dịka nwa ele
\q2 na-awụgharị nʼelu ugwu ebe ụda dị iche iche na-esi isi ụtọ jupụtara.
