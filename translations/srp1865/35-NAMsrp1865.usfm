\id NAM  
\h Knjiga proroka Nauma 
\toc1 Knjiga proroka Nauma 
\toc2 Naum 
\toc3 Nm 
\mt1 Knjiga proroka Nauma  
\c 1  
\s1 Božije veličanstvo protiv Asirije.  
\p
\v 1 Breme Nineviji;  
\p knjiga od utvare Nauma Elkošanina.   
\b  
\q1
\v 2 Bog je revnitelj i Gospod je osvetnik;  
\q2 osvetnik je Gospod i gnevi se;  
\q1 Gospod se sveti protivnicima svojim,  
\q2 i drži gnev prema neprijateljima svojim.   
\q1
\v 3 Gospod je spor na gnev i velike je moći;  
\q2 ali nikako ne pravda krivca;  
\q1 put je Gospodnji u vihoru i buri,  
\q2 i oblaci su prah od nogu Njegovih.   
\q1
\v 4 Zaprećuje moru i isušuje ga,  
\q2 i sve reke isušuje,  
\q1 vene Vasan i Karmil,  
\q2 i cvet vasanski vene.   
\q1
\v 5 Gore se tresu od Njega,  
\q2 i humovi se rastapaju,  
\q1 a zemlja gori pred Njim  
\q2 i vasiljena i sve što živi u njoj.   
\b  
\q1
\v 6 Pred gnevom Njegovim ko će se održati?  
\q2 I ko će se opreti jarosti gneva Njegovog?  
\q1 Jarost se Njegova izliva kao oganj,  
\q2 i stene se raspadaju pred Njim.   
\q1
\v 7 Dobar je Gospod,  
\q2 grad je u nevolji,  
\q2 i poznaje one koji se uzdaju u Nj.   
\q1
\v 8 Ali će silnom poplavom učiniti kraj mestu njenom,  
\q2 i tama će goniti neprijatelje Njegove.   
\q1
\v 9 Šta smišljate Gospodu?  
\q2 On će učiniti kraj;  
\q2 neće se dva puta podignuti pogibao.   
\q1
\v 10 Jer kao trnje spleteni  
\q2 i kao od vina pijani  
\q2 proždreće se kao suva slama.   
\q1
\v 11 Iz tebe je izašao koji smišlja zlo Gospodu,  
\q2 savetnik nevaljao.   
\b  
\q1
\v 12 Ovako veli Gospod:  
\q1 Ako i jesu u sili i mnogo ih ima,  
\q2 opet će se iseći i proći.  
\q1 Mučio sam te,  
\q2 neću te više mučiti.   
\q1
\v 13 Nego ću sada slomiti jaram njegov s tebe,  
\q2 i pokidaću tvoje okove.   
\b  
\q1
\v 14 Ali za tebe zapovedi Gospod da se ne seje više ime tvoje;  
\q2 iz doma bogova tvojih istrebiću likove rezane i livene;  
\q2 načiniću ti od njega grob kad budeš prezren.   
\b  
\q1
\v 15 Eto, na gorama noge onog koji nosi dobre glase,  
\q2 koji oglašuje mir.  
\q1 Praznuj, Juda, svoje praznike,  
\q2 ispunjaj zavete svoje,  
\q1 jer zlikovac neće više prolaziti po tebi;  
\q2 sasvim se zatro.   
\c 2  
\s1 Proricanje o razorenju grada Ninevije.  
\q1
\v 1 Izađe zatirač na te,  
\q2 čuvaj grad, pazi na put,  
\q2 utvrdi bedra, ukrepi se dobro.   
\b  
\q1
\v 2 Jer Gospod povrati slavu Jakovljevu  
\q2 kao slavu Izrailjevu,  
\q1 jer ih pustošnici opustošiše  
\q2 i loze im potrše.   
\b  
\q1
\v 3 Štit je junaka njegovih crven,  
\q2 vojnici su u skerletu;  
\q1 kola će mu biti kao zapaljeni lučevi  
\q2 na dan kad se uvrsta,  
\q2 i jele će se ljuljati strašno.   
\q1
\v 4 Kola će praskati po ulicama  
\q2 i udarati jedna o druga po putevima,  
\q1 biće kao lučevi,  
\q2 i trčaće kao munje.   
\q1
\v 5 Pominjaće junake svoje,  
\q2 a oni će padati idući,  
\q1 pohitaće k zidovima njegovim,  
\q2 i zaklon će biti gotov.   
\q1
\v 6 Vrata će se rekama otvoriti,  
\q2 i dvor će se razvaliti.   
\q1
\v 7 I koja stoji, zarobiće se i odvešće se,  
\q2 devojke njene pratiće je  
\q2 uzdišući kao golubice, bijući se u prsi.   
\q1
\v 8 Ninevija beše kao jezero vodeno otkako jeste;  
\q2 ali beže.  
\q1 Stanite, stanite.  
\q2 Ali se niko ne obzire.   
\q1
\v 9 Grabite srebro, grabite zlato;  
\q2 blagu nema kraja,  
\q2 mnoštvo je svakojakih dragih zaklada.   
\b  
\q1
\v 10 Isprazni se, i ogole, i opuste;  
\q2 i srce se rastopi,  
\q2 kolena udaraju jedna o drugo,  
\q1 i bol je u svim bedrima,  
\q2 i lica su svima pocrnela.   
\q1
\v 11 Gde je loža lavovima i pasište lavićima,  
\q2 kuda iđaše lav i lavica i lavić,  
\q2 i nikoga ne beše da plaši.   
\q1
\v 12 Lav lovljaše svojim lavićima dosta,  
\q2 i davljaše lavicama svojim,  
\q1 i punjaše pećine svoje lova  
\q2 i lože svoje grabeža.   
\b  
\p
\v 13 Evo me na te, govori Gospod nad vojskama, i popaliću kola tvoja u dim, i mač će proždreti laviće tvoje, i istrebiću sa zemlje grabež tvoj, i neće se čuti glas poslanika tvojih.   
\c 3  
\s1 Grehovi su grada Ninevije uzrok kazni koja ide na nju.  
\q1
\v 1 Teško gradu krvničkom,  
\q2 sav je pun laži i otimanja,  
\q2 grabež ne izbiva iz njega.   
\q1
\v 2 Pucaju bičevi, i točkovi prašte,  
\q2 i konji topoću, i kola skaču.   
\q1
\v 3 Konjanici poskakuju,  
\q2 i mačevi se sjaju,  
\q2 i koplja sevaju,  
\q1 i mnoštvo je pobijenih  
\q2 i sila mrtvih telesa,  
\q1 nema broja mrtvacima,  
\q2 i pada se preko mrtvaca.   
\q1
\v 4 Za mnoštvo kurvarstva ljupke kurve,  
\q2 vešte bajačice,  
\q1 koja prodaje narode svojim kurvanjem  
\q2 i plemena vračanjem svojim.   
\b  
\q1
\v 5 Evo me na te,  
\q2 govori Gospod nad vojskama,  
\q1 i uzgrnuću ti skute tvoje na lice,  
\q2 i pokazaću narodima golotinju tvoju  
\q2 i carstvima sramotu tvoju.   
\q1
\v 6 I baciću na tebe gadove i naružiću te,  
\q2 i načiniću od tebe ugled.   
\q1
\v 7 I ko te god vidi, bežaće od tebe,  
\q2 i govoriće:  
\q1 Opuste Ninevija;  
\q2 ko će je žaliti?  
\q2 Gde ću tražiti one koji bi te tešili?   
\b  
\q1
\v 8 Jesi li bolja od No-Amona,  
\q2 koji ležaše među rekama,  
\q2 optočen vodom,  
\q1 kome prednja kula beše more  
\q2 i zidovi mu behu more?   
\q1
\v 9 Jačina mu beše huska zemlja i Misir i narodi bez broja;  
\q2 Futeji i Liveji behu ti pomoćnici.   
\b  
\q1
\v 10 I on bi preseljen, otide u ropstvo,  
\q2 i deca njegova biše razmrskana po uglovima svih ulica;  
\q1 i za glavare njegove bacaše žreb,  
\q2 i svi vlastelji njegovi biše okovani u puta.   
\q1
\v 11 I ti ćeš se opiti i krićeš se,  
\q2 i ti ćeš tražiti zaklon od neprijatelja.   
\q1
\v 12 Svi će gradovi tvoji biti kao smokve s ranim rodom;  
\q2 kad se tresnu, padaju u usta onome ko hoće da jede.   
\q1
\v 13 Eto, narod su ti žene usred tebe;  
\q2 neprijateljima će tvojim biti širom otvorena vrata od zemlje tvoje,  
\q2 oganj će proždreti prevornice tvoje.   
\b  
\q1
\v 14 Nahvataj sebi vode za opsadu,  
\q2 utvrdi ograde svoje;  
\q1 uđi u kao i ugazi blato,  
\q2 opravi peć za opeke.   
\q1
\v 15 Onde će te proždreti oganj,  
\q2 mač će te iseći,  
\q2 izješće te kao hrušt;  
\q1 neka vas je mnogo kao hrušteva,  
\q2 neka vas je mnogo kao skakavaca.   
\q1
\v 16 Imaš trgovaca više nego što je zvezda na nebu;  
\q2 hruštevi padoše, pa odleteše.   
\b  
\q1
\v 17 Glavari su tvoji kao skakavci  
\q2 i vojvode tvoje kao veliki skakavci,  
\q1 koji padaju po plotovima kad je studeno,  
\q2 a kad sunce grane, odleću,  
\q2 i mesto im se ne poznaje gde behu.   
\b  
\q1
\v 18 Zadremaše tvoji pastiri, care asirski,  
\q2 polegaše junaci tvoji,  
\q1 narod se tvoj rasprša po gorama,  
\q2 i nema nikoga da ih zbere.   
\q1
\v 19 Nema leka polomu tvom,  
\q2 ljuta je rana tvoja;  
\q1 ko god čuje glas o tebi,  
\q2 pljeskaće rukama nad tobom,  
\q2 jer koga nije stizala zloća tvoja jednako?   