\id OBA
\h Ɛubadya 
\toc1 Ɛubadya 
\toc2 Ɛubadya 
\toc3 Ɛub. 
\mt1 Ɛubadya  
\c 1
\m
\v 1 \bd Řewḥiy n Ɛubadya.\bd*  
\b  
\m “Ammu i iqqar Sidi inu, SIDI, \bd x Idum:\bd*  
\m ’Neccin nesřa ijj n řexbar zi SIDI,  
\m u ijj n umsekki ittwassekk ɣar řegnus:  
\m Kkar, jjem aneɣ ad xas nɣewweɣ,  
\m ad nemmneɣ ak-d \add Idum\add*!’ \x ◘ \xo 1:1 \xt Irm. 49:14\x*   
\m
\v 2 Xzar, Necc ggiɣ cek d ameẓyan jar řegnus,  
\m cek tᵉttwasseḥqarad aṭṭas. \x ◘ \xo 1:2 \xt Irm. 49:15\x*   
\m
\v 3 Nnfaxet n wuř nnec tecmet i cek,  
\m \add cek\add* d wenni din izeddɣen deg imucan n udurri jar řejruf,  
\m di tzeddiɣt nnec yuɛřan,  
\m \add cek\add* d wenni iqqaren deg wuř nnec:  
\m ‘Man wen d ayi ɣa iɣeḍřen ɣar temmurt?’ \x ◘ \xo 1:3 \xt Irm. 49:16\x*   
\m
\v 4 Mařa tessgeɛɛded ixef nnec am ugider,  
\m niɣ teggid řɛucc nnec jar itran,  
\m Necc ad cek dd ssenni ssehwiɣ,  
\m \add ammu i\add* iqqar SIDI.” \x ◘ \xo 1:4 \xt Řxř. 24:21, Ayub 39:27-29, Irm. 49:16\x*   
\b  
\m
\v 5 “Mařa udfen-dd ɣarek iceffaren,  
\m \add niɣ\add* ixewwanen s ǧiřet,  
\m - \add a\add*, mammec i ɣa tᵉttwaředdǧed \add ař ṭṭarf\add* -  
\m Ma war ttacaren ař ɣarsen i ɣa yiři min ikfan?  
\m Mařa usin-dd ɣarek inni i ɣa iřeqḍen aḍiř,  
\m ma ad jjen ca min ittwařeqḍen \add awarni asen\add*? \x ◘ \xo 1:5 \xt Irm. 49:9\x*   
\m
\v 6 \add A\add* mammec i ɣa arzun di Ɛisu,  
\m \add mammec\add* i ɣa beqqcen \add řeknuz\add* nnes nnufaren!   
\m
\v 7 Marra iryazen nni \add iggin\add* ijj n řɛahd akidek,  
\m ɛarnen cek ɣar weymir,  
\m \add iryazen\add* nni tuɣa akidek iddaren di řehna, cemten cek,  
\m nitni zemmaren xak.  
\m Aɣrum zzayek ggin t d tareḥsit swadday nnec.  
\m ‘Aqa netta war dayes bu řefhamet.’ \f ◼ \fr 1:7 \ft \+fk Aqa netta war dayes bu řefhamet\ft  - awař-a issawař x Idum. Waxxa aṭṭas hejmen x Idum maḥend ad zzayes keccḍen am t cemten, waxxa amenni Idum war ɣares bu řefhamet.\f*  \x ◘ \xo 1:7 \xt Izhd. 41:10, Yḥ. 13:18\x*   
\m
\v 8 Ma war ittiři \bd deg wass nni,\bd* iqqar SIDI,  
\m aqa Necc ad areddǧeɣ imiɣisen zi Idum,  
\m u řefhamet zeg idurar n Ɛisu? \x ◘ \xo 1:8 \xt Ica. 29:11, 14; Irm. 49:7\x*   
\m
\v 9 Ayt n bu-teɣruḍt nnec ad ttwaḥṣaren  
\m zi tiggʷudi, \add a\add* Tayman,  
\m ḥima kuř ijjen zeg idurar n Ɛisu  
\m ad ittwaqḍeɛ s wenɣay.” \x ◘ \xo 1:9 \xt Ɛam. 2:14, 16\x*   
\b  
\m
\v 10 “Zi ssibbet n lɛunf \add x\add* umac Yaɛqub,  
\m ad cek tdeř řefḍiḥet,  
\m u ad tᵉttwakksed i řebda. \x ◘ \xo 1:10 \xt Amz. 27:41; Ḥiz. 35:5; Ɛam. 1:11\x*   
\m
\v 11 Deg wass i di tuɣa \add xas\add* tbedded,  
\m deg wass i di ibarraniyyen iwyen-dd agřa nnes  
\m u udfen řbarrani ɣar tewwura nnes,  
\m u nḍaren taqedduḥt x Urcalim,  
\m tuɣa cek am yijjen zzaysen. \x ◘ \xo 1:11 \xt Izhd. 137:7\x*   
\m
\v 12 \add Maca\add* war d ac iɛeddeř ad teqqimed txezzared  
\m deg wass n umac,  
\m deg wass n wectab nnes abarcan,  
\m war d ac iɛeddeř ad tfarḥed x iḥenjiren n Yahuda,  
\m deg wass n wareddeǧ nsen  
\m u war d ac iɛeddeř ad tarezmed aqemmum nnec aṭṭas  
\m deg wass n řeḥṣaret \add nsen\add*.   
\m
\v 13 War iɛeddeř ad tadfed ɣar tewwart n řgens inu  
\m deg wass n uhellek nsen  
\m war d ac iɛeddeř ad teqqimed txezzared ɛawed  
\m deg wass n uḍeyyeɛ nsen  
\m u war d ac iɛeddeř ad teqqimed tesswiẓẓḍed  
\m \add ifassen nnec\add* ɣar wagřa nnes  
\m deg wass n uḍeyyeɛ nnes,   
\m
\v 14 war d ac iɛeddeř ad tbedded  
\m ɣar mani ttmeřqan ibriden,  
\m maḥend ad tᵉtteḥḥid inni inejmen  
\m u war d ac iɛeddeř  
\m ad tsellmed inni tuɣa yarewřen  
\m deg wass n řeḥṣaret.”   
\b  
\m
\v 15 “Maɣar yudes-dd ass n SIDI  
\m x marra řegnus!  
\m Am teggid cek, ad zzayek ittwagg,  
\m axeǧeṣ nnec ad dd-idweř x uzeǧif nnec. \x ◘ \xo 1:15 \xt Ḥiz. 35:15\x*   
\m
\v 16 Maɣar am mammec teswim kenniw  
\m x wedrar inu iqeddsen,  
\m ammu ad swen marra řegnus řebda,  
\m \add wah,\add* ad swen ad sekkfen,  
\m ad dewřen axmi ɛemmarṣ war tuɣa ǧan.   
\m
\v 17 \add Maca\add* x wedrar n Ṣihyun  
\m ad yiři min innejmen,  
\m u wanita ad yiři d amqeddes,  
\m u \add inni n\add* taddart n Yaɛqub  
\m ad ṭṭfen tiseqqař \add n řwart\add* nsen. \x ◘ \xo 1:17 \xt Yuw. 3:5\x*   
\m
\v 18 Taddart n Yaɛqub ad tiři d timessi,  
\m u taddart n Yusuf d aceɛɛař,  
\m uca taddart n Ɛisu ad tiři am yiɣeǧ  
\m u nitni ad asen sscemḍen  
\m u ad ten ccen,  
\m ařami war iqqim  
\m uřa d ijj iddar di taddart n Ɛisu,  
\m maɣar SIDI aqa issiweř.”   
\b  
\m
\v 19 “Inni n \add Temmurt n\add* Ljanub  
\m ad ṭṭfen idurar n Ɛisu d tasɣart,  
\m u yinni n Temmurt Iwaṭan  
\m ad ṭṭfen \add tammurt n\add* Ifilisṭiniyyen d řwart  
\m \add wah,\add* nitni ad ṭṭfen iyyar n Ifrayim  
\m d yeyyar n Samarya d řwart,  
\m u Binyamin \add ad iṭṭef\add* Jilɛad \add d řwart\add*,   
\m
\v 20 u imenfiyyen zi řɛeskar-a  
\m inni iǧan ɣar ayt n Israil  
\m \add ad ṭṭfen tammurt n\add* ayt n Kenɛan  
\m \add d řwart\add* ař Ṣarfat,  
\m u imenfiyyen zi Urcalim  
\m nni \add iǧan\add* di Ṣafarad,  
\m ad ṭṭfen tineddam  
\m n \add Temmurt n\add* Ljanub d řwart. \f ◼ \fr 1:20 \ft \+fk Ṣafarad\ft  - ad taɣ Ṣafarad d ijj n yisem nneɣni i temmurt n Sspanya.\f*   
\m
\v 21 Imsellken ad geɛɛden adrar n Ṣihyun,  
\m ḥima ad ḥakmen adrar n Ɛisu,  
\m uca tagelda ad tiři n SIDI.”   