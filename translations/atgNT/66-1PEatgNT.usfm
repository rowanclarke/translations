\id 1PE - Okphela
\h 1 iPita
\toc1 1 iPita
\toc2 1 iPita
\toc3 1 iPit
\mt2 Ebe onododẹ ni
\mt1 IPita
\mt2 Ọ kẹkẹ
\c 1
\p 
\v 1 Mhẹmhẹ iPita aghiusomhi na kẹẹ ọyi iJesu iKirisiti mhi kẹkẹ ebe ona ghi ẹ ẹgbọ ni Ẹshinẹgba ọ zẹ, ni a khi epfẹse shi elemhi ekẹ agbọ, ni a miatsẹ ku asha khi asha ekẹ iPọntusi, ali iGalesha ali iKapadosha ali Esha, ali iBitinia.
\v 2 Eri Ẹshinẹgba ita ọ zẹ ẹ abi o li ghọle ọli shi, ọ rọte ikanya eyi Ayẹmhẹ-nọ-pfuasẹ khuẹsẹ-a pfuasẹ ni a ke suọ esọ na iJesu iKirisiti ali ni ọ ri ọlia eyi iKirisiti rẹ ẹ khi ẹgbọ ọda shi ugamhi oyọli.
\p Opfọmhẹ ali okhale ni e gbeku ọ, e ka nu ẹ la.
\s1 A kuẹghiẹ Ẹshinẹgba shi Irudushi ni o mhuẹ agbọ
\p 
\v 3 Awa kuẹghiẹ Ẹshinẹgba, ita iJesu iKirisiti Ọnọmhuẹ. Itobọ ilẹlemhi oniẹmhi ni ọ mhọli na awa ọ rọ rọte eghuli guise iJesu iKirisiti le. Onana o ri agbọ onogbọ ali irudushi ni o mhuẹ agbọ na awa.
\v 4 Lọli ọ li ri awa ri ẹloe shi ekẹ ẹ khẹ ugu ni Ẹshinẹgba ọ rọ shi aghọ ọ khẹ ẹgbọ eyọli. Iloghie ọ rẹ wẹ shi nẹ, ni o khi asha ni ẹa la kẹ-a, ni ẹa la pfuẹchẹ, wẹkhi eri e ya taa.
\v 5 Eyẹ ẹ eni ugu ena e khi, ikhi ẹẹ ni a mhọli iregbenga, ni Ẹshinẹgba ọ ri ekpabọ eyọli khukhu shi ẹ khẹ imiepfuese, ikhi imiepfuese ni a ya rọkhasẹ ikpukhokho agbọ.
\v 6 A zẹ ni onana o ri egbe ke mu ẹ ini o tseku khia khi a ya mhọli iyeseudu-a ukuku ẹghẹghẹ irari imhẹsẹ bino ebubu ni a ya mẹ.
\v 7 Eri a ri ena mu ẹ fẹ bino ni a mẹ ini egbegbọ irudunga oyẹ ẹ o khi. Igolu ni ọ li opfu-a, erali a rọ ọ mhẹsẹ ọli bino ni a mẹ ini egbegbọ o khi. Ighọ a ya li mhẹsẹ irudunga oyẹẹ ni o mu ẹloe dọsẹ igolu bino, ni a mẹ asha mie ekpẹ ali ikuẹghiẹ ali ufumhi ẹlẹ ni iJesu ọ ya nyenẹ egbe bhale.
\v 8 A nono ingme oyọli, a gbo mie ọli suọ, aboriẹkhia khi aa mẹ ọli ẹloe ghue. A mhọli oghẹlẹ oniẹmhi ni unu ọa dobẹ ẹ ngme.
\v 9 Itobọ khi u mhọli imiepfuese elemhi ayẹmhẹ oyẹ, o zẹ khi a miesuọ, a regbenga li.
\p 
\v 10 Eri emekẹguele ngme ingme okhale ni ọọ bhale deba ẹ, e kuegbe-a guanọ bie abi Ẹshinẹgba ọ li ya mie ẹgbọ eyọli pfuese, onana o zẹ ni e rọ ngme angme-shi-ekẹ oyi oni imiepfuese ona.
\v 11 Ayẹmhẹ oyi iKirisiti ni o la emekẹguele udu o gueyẹ wẹ abi iJesu ọ li ya mẹ osoli, neni ọ ya mẹ ufumhi oniẹmhi, ẹghẹghẹ ni e rọ ngme ungmemhi amẹguele. E rọshẹka guanọ ni e lẹsẹ ọghuo ọ ya khi ọni iKirisiti ali abi eni ingme e ga li ya de nyaa.
\v 12 Ẹshinẹgba ọ rọkhasẹ eni emekẹguele khi ọa khi itobọ eleli oyẹwẹ a rọ ri emhi ena khasẹ wẹ ama irari oyẹ ẹ. Memena, eni emekẹguele e she gue eni ingme ena nya yẹ ẹ, abi ekpabọ Ayẹmhẹ-nọ-pfuasẹ ni ọ rọte iloghie bhale ọ li gue wẹ yẹ wẹ. Eri igẹni e lili nono ni wẹwẹ e li mẹ eni ingme ena.
\s1 A ke la angeli ipfuasẹ
\p 
\v 13 Irarighọ, a bino angeli bie ke ngeli ni a mu egbe shi ugamhi oyi Ẹshinẹgba, a ke tẹ ẹloe ekẹ, a ri udu oyẹ ẹ shi isomhelemhi ni a ya mẹ ogbẹlẹ ni a ya ri iKirisiti khasẹ.
\v 14 Abi eniyẹ ni ẹẹ suọ esọ na Ẹshinẹgba ni ọ la iloghie, a khi nyenẹ egbe ukhokho je angeli ni u kpẹ ngeli neni a lẹsẹ ungmemhi oyi Ẹshinẹgba.
\v 15 Lẹsẹ khi Ẹshinẹgba ni ọ lu ẹ, ọ ma pfuasẹ ni a li ghọ mhọli ingeli ni e pfuasẹ shi emiemini a riẹlẹ nya.
\v 16 Ebe-no-pfuasẹ ọọ, “Zẹ ni u khi ọni ọ pfuasẹ, itobọ khi mhẹmhẹ mhi pfuasẹ.”\f + \fr 1:16 \ft Li zẹ \fq iLẹv 11.44,45; iLẹv 19.2; iLẹv 20.7\f*
\p 
\v 17 Ini o khia khi Ita wa lu Ẹshinẹgba ini u wa sọ iromhi, ikhi ita ni ọa ya gbe azẹba ini ọọ gue ẹzọ, ri ekpẹ ali ulishi ke ga li aborọkhia khi ọpfẹse ekẹ agbọ u khi eghọ.
\v 18 Irari khi a lẹsẹ khi ọa khi emhi nabi igolu ali ẹlomho ni ẹẹ li opfu-a a rọ pfa ẹ shi ekẹ, lase elemhi imu ali angeli afuẹ le, ni eni e bia ẹ e rọshi ekẹ na ẹ.
\v 19 Ọlia ni e ghalẹ eyi iJesu iKirisiti, ni ọ khi omi osumha ni ọa mhuẹ ichimhi, a rọ luasẹ obọ na awa.
\v 20 Ẹshinẹgba ọ zẹ ọli neni a ma agbọ, ọ gbo ri ọli lasele khasẹ ẹgbọ ikpukhokho agbọ ni awa la ena, irari oyẹ ẹ.
\v 21 Obọ oyi iJesu a te mie Ẹshinẹgba suọ ni ọ te eghuli guise ọni iJesu le, ni ọ gbo ri ufumhi oniẹmhi na li, irarighọ a mhọli irudunga ali irudushi na Ẹshinẹgba.
\p 
\v 22 Aborọkhia khi a she ri udu eyẹ ẹ khi eni e pfuasẹ eghọ, abi a ri ungmemhi igẹsikia a gbe akanya, ni a rọ mhọli inono na egbe ẹ abi a ga miesuọ, a kie lighọ ke nono ingme egbe ẹ.
\v 23 Irari khi ungmemhi oyi Ẹshinẹgba ni o mhuẹ agbọ na agbọagbọ a rọ riẹlẹ ẹ bia, ọa khi emini ẹẹ pfua a rọ riẹlẹ bia.
\v 24 Ebe-no-pfuasẹ o ngme ghọ khi,
\q1 “Eri ẹgbọ nya
\q2 e li abi ebuli.
\q1 Eri isomotse oyẹwẹ
\q2 o li abi udodo.
\q1 Ini ebuli o khakha-a,
\q2 udodo e de ọ kua.
\q2 
\v 25 Ama eri ungmemhi
\q2 oyi Ẹshinẹgba o laọ agbọagbọ.”\f + \fr 1:25 \ft Li zẹ \fq Aza 40.6-9\f*
\m Ona o khi usomhi onete ni a tsẹ abọ ye ẹ.
\c 2
\s1 Ẹchẹ ni o mhọli agbọ ali ushishi no pfuasẹ
\p 
\v 1 A she riẹlẹ ẹ bia, irarighọ, khi kono onobe shi elemhi deba ọgbọ, khi ke lo ẹgbhọli, khi ke ngeli ingeli abamẹmhẹ, khi ke dọ ọgbọkhọghuo ọkọnyọ ali khi ke ngme ungmemhi yese ọgbọ-a.
\v 2 Ochoghọ, zẹ ni angeli oyẹ ẹ e li abi oyi emọfẹ. Okiamhi egbegbi amẹ inyeli eyi ayẹmhẹ ni o khi ungmemhi oyi Ẹshinẹgba, o ke gbe ẹ. Eni a kha da, o rẹẹ fu shi imiepfuese,
\v 3 mena ni a she mu Ọnọmhuẹ fẹ bino ni a mẹ ọli mẹ khi ọọ ti.\f + \fr 2:3 \ft Li zẹ \fq Iwolo 34.8\f*
\p 
\v 4 Abi a li bhale deba Ọnọmhuẹ ni ọ khi ẹchẹ nọ mhuẹ agbọ, ni ẹgbọ e kie, ama Ẹshinẹgba ọ zẹ ọli, ọ mu ọli ẹloe.
\v 5 Ighọ, ẹẹ abi echẹ ni e mhuẹ agbọ, a rọ tọ owa ayẹmhẹ, ni a khi ekpodalo-ugamhi eyi Ẹshinẹgba ni e pfuasẹ, ni a ke luasobo ena ayẹmhẹ eni e ghọle Ẹshinẹgba, rọte obọ oyi iJesu iKirisiti.
\v 6 Irari khi Ebe-no-pfuasẹ ọọ,
\q1 “A bino khi mhi ri
\q1 ẹchẹ gbe ekẹ shi iZayọ,
\q2 ẹchẹli ẹbẹ ni o mu owa mhuẹ,
\q2 ni mhi zẹ ni o mu ẹloe.
\q1 Ọni ọ da ri egbe da li ne,
\q2 ọa ya mẹ omama.”\f + \fr 2:6 \ft Li zẹ \fq Aza 28.16\f*
\m 
\v 7 Irari khi ẹchẹ ona oni o mu ẹloe o khi na ẹẹ ni a mie ọli suọ. Ama eni ẹa mie ọli suọ, o khi,
\q1 “Ẹchẹ ni itsọna e kie,
\q2 ni o tigbe mele oni
\q2 o mu ẹloe nẹ nya-a.”\f + \fr 2:7 \ft Li zẹ \fq Iwolo 118.22\f*
\q1 
\v 8 “Onana o kie gbo khi
\q2 ẹchẹ ni ebubu ẹgbọ
\q1 e ya kholo awẹ shi
\q2 ukpokpomhi ẹchẹ
\q2 ni o ya pfi wẹ gbe.”
\m Itobọ khi ẹa ri ungmemhi oyi Ẹshinẹgba gbe akanya e rọ de. Abi o kha li wẹ o li eghọ.\f + \fr 2:8 \ft Li zẹ \fq Aza 8.14-15\f*
\p 
\v 9 Ama eni Ẹshinẹgba ọ zẹ a khi, ni a khi ekhẹmhuẹ ni ẹẹ ga Ẹshinẹgba, ushishi na ipfuasẹ, ẹgbọ enayi Ẹshinẹgba, ni a rọ mẹ asha ri ikuẹghiẹ na ọni ọ rọte alo ebili lu ẹ lasele bhale ákpá ni o somhotse oyọli.\f + \fr 2:9 \ft Li zẹ \fq Okiali 19.5-6; Aza 43.20,21; iDẹut 4.20; 7.6; 14.2; iTatọ 2.14; Aza 9.2\f*
\v 10 Ẹghẹghẹ ni o dọsẹ aa kpẹ khi ẹgbọ eyi Ẹshinẹgba, ama memena, ẹgbọ eyi Ẹshinẹgba a ke khi, aa kpẹ mhọli ilẹlemhi na ẹ, ama memena Ẹshinẹgba ọ she mhọli ilẹlemhi na ẹ.\f + \fr 2:10 \ft Li zẹ \fq Osia 2.23\f*
\s1 Ighumha eyi Ẹshinẹgba
\p 
\v 11 Emọle mhẹ, mhi lema ẹ, ẹẹ abi epfẹse ni a la elemhi agbọ ona, a lase ọghuẹmhẹ ni e khi eyi olamhẹ le, ni e mu okhọli ẹ vule shi isamhi eyẹ ẹ ọ.
\v 12 A kie ke ngeli ingeli enete elemhi ifuabọ oyi ẹgbọ ni ẹa miesuọ. Ini e tseku ẹ zẹ ẹ unu, e kie ke mẹ ingeli enete ni a ngeli, ni e ke kuẹghiẹ Ẹshinẹgba, ogbẹlẹ ni ọ ya bhale deba awa.
\s1 Iregbe-tiemhie na Enighie ali Ega eyawa
\p 
\v 13 A ri itobọ Ọnọmhuẹ ke ri egbe ẹ tiemhie na eni ẹẹ mhẹsẹ nya ni a mu vule shi iteva ẹgbọ. Okekhi oghie ni ọ funẹ,
\v 14 okekhi igọvunọ ni ọni oghie ọọ ghie ọ ke nasẹ eni e pfidọ, ali e ke kuẹghiẹ eni e riẹlẹ onete.
\v 15 Irari khi eri Ẹshinẹgba ọọ nono ni a pfi ẹgbọ ọkhọlọ okpẹ unu, rọte angeli enete ni a ya ke ngeli.
\v 16 A ke ngeli abi ẹgbọ ni ẹa mhọli ọzuodẹ, ama a khi zudigba umha mhọli ọzuodẹ oyẹẹ ke ngeli ingeli ebe. A ke ngeli abi eni ẹẹ ga Ẹshinẹgba.
\v 17 A ke ri ekpẹ na ọgbọkpa. A nono ingme oyi ẹgbọ ni a ga rọ khi ena irudunga. A ke na ulishi oyi Ẹshinẹgba. A gbo mu ekpẹ ẹ na oghie.
\p 
\v 18 Ẹẹ ni a khi eni ẹẹ ga, a ri egbe ẹ tiemhi ekẹ na eni e khi ega eyẹ ẹ. Ọa khi ega ni eri opfọmhẹ ngeli deba ẹ tsẹ ama li shi eni ẹ ngeli angeli ni o ze deba ẹ.
\v 19 Ẹshinẹgba ọ ya khivọsẹ nẹ ini u ri egbe mie osoli anasẹmhẹ ni u wa kha mẹ, itobọ khi u lẹsẹ ọghuẹmhẹ oyi Ẹshinẹgba.
\v 20 Eleli onoghuo o la ọ ini ọgbọ ọ mẹ osoli shi umha-suesọ ni ọ riẹlẹ? Ama ini u wa mẹ osoli shi onete ni u riẹlẹ, ni u rọ ri egbe mie ọli, Ẹshinẹgba ọ ya khi vọsẹ nẹ shi ọ.
\v 21 Irari onana Ẹshinẹgba ọ rọ lu ẹ, abi iJesu ọ rọ mẹ osoli na ẹ rọ ri angeli irọkhọkhọ shi ekẹ na ẹ ni a ke deba. A rọshẹka ke deba oni angeli.
\v 22 Ọa lamhẹ olamhẹ okhọghuo, wẹkhi eri a mẹ khi ọ ngme ungmemhi ẹgbhọli.\f + \fr 2:22 \ft Li zẹ \fq Aza 53.9\f*
\v 23 Abi ẹgbọ e rọ tseku u tsue ọli, ọa tsue wẹ shi ọ. Abi ọ rọ tseku mẹ osoli ọa tsekha wẹ. Ama eri ọ ri egbọli mhọli Ẹshinẹgba obọ, ọni ọ guẹ sọ ẹzọ shi odẹ igẹsikia.\f + \fr 2:23 \ft Li zẹ \fq Aza 53.7\f*
\v 24 IKirisiti lọlighuo ọ tsua olamhẹ eyawa shi egbe je apfida, ini awa khi ghu eghuli olamhẹ, ama ni awa la agbọ iguẹ-ngeli elemhi ipfuasẹ. Utse ni a kuale ọli o ri awa ze.\f + \fr 2:24 \ft Li zẹ \fq Aza 53.5\f*
\v 25 Eri a kpẹ la agbọ abi osumha ni ọ waa, ama a she mu pfi deba Ọni Ọrisumha-kia ni ọ khi ọni ọ khekhẹ ayẹmhẹ o yẹ.\f + \fr 2:25 \ft Li zẹ \fq Aza 53.6\f*
\c 3
\s1 Angeli oyi ikpotso ni e la ughuẹ ali ọdọ wẹ
\p 
\v 1 Ẹẹ ni a khi ikpotso, a nyẹsẹ ukhomhi na edọ ẹ, isheghọ a khi mẹ ọngẹwẹ ni ọa mie ungmemhi oyi Ẹshinẹgba suọ, ni eni edọ ẹ ri itobọ ekpẹ ni a mhọli a na wẹ ali angeli eyi ẹ mu udu pfi, ini aa ke tseku ngme ungmemhi unu lasele,\f + \fr 3:1 \ft Li zẹ \fq Ẹfi 5.22; iKolo 3.18\f*
\v 2 ini ẹẹ mẹ angeli ipfuasẹ ali angeli ekpẹ ni a ngeli.
\v 3 Khi zẹ ni isomhotse oyẹ o rọte akhuẹ idiegbe ri egbe khasẹ, ni a la do itsu shi ukhomhi dọlọdọlọ, ali ena igolu isọsọ ali igbanọ itsua ni e somhotse.\f + \fr 3:3 \ft Li zẹ \fq 1 iTimo 2.9\f*
\v 4 Ochoghọ, zẹ ni isomotse oyẹ o khi ona ekelemhi udu. Isomhotse ni ọa ya taa, ni o khi ona ikuegbea ali ayẹmhẹ no pfọmhẹ, ni o ghọle Ẹshinẹgba nẹ nya.
\v 5 Ina ikpotso eni ẹlẹlẹ ni e ri egbe da Ẹshinẹgba, e li ri egbe wẹ shi isomotse, irari khi e nyẹsẹ ukhomhi na edọ wẹ.
\v 6 Abi iSera ọ li mu ekpẹ na ọdọli Aburaamu ramhi ni ọ rọ lu ọli, ọnọmhuẹmhẹ. Imi ọni iSera a khi, ini a da ngeli ingeli enete ne, ni aa rọ da zẹ ni ulishi o mu ẹ.\f + \fr 3:6 \ft Li zẹ \fq Igbae 18.12\f*
\p 
\v 7 Ighọ, ẹẹ edọ, a guẹ ke ngeli deba ighuẹ ẹ. A ri iwomhẹloe nu wẹ ke ngeli. A lẹsẹ khi ẹa mhuẹ ekpabọ abi ẹẹ. A gbo lẹsẹ khi eni e nu ẹ mhọli okemhi shi isomhopfa oyi isomhelemhi oyi Ẹshinẹgba ni o mhọli agbọ onogbọ e li khi. A guẹ ri ẹloe ke khu wẹ, ini emhikhọghuo o khi zu iromhi oyẹẹ odẹ.\f + \fr 3:7 \ft Li zẹ \fq Ẹfi 5.25; iKolo 3.19\f*
\s1 Imẹ-osoli shi onete iriẹlẹ
\p 
\v 8 Ọzukhomhi ungmemhi oyẹmhẹ khi, ẹẹ nya a mhọli udu oghuo, a mhọli ilẹlemhi na egbe, a nono ingme egbe abi inyọghuo, a viẹ osoli ke na egbe, a ke ri egbe ẹ tiemhile.
\v 9 Khi ri onobe fata onobe. Ini ọgbọ ọ tsue ẹ, khi tsue ọli shi ọ, ochoghọ sọ iromhi onete na li. Itobọ khi eri Ẹshinẹgba ọ luẹ ni u khi ọgbọ ọyọli, ni u le ikhivọsẹ ugu.
\v 10 Irari khi,
\q1 ọni ọ da a nono
\q2 ni lọli mẹ agbọ li
\q1 ali ni lọli mhọli
\q2 ebubu ogbẹlẹ enete,
\q1 ọ khi ke ri ẹlẹmhi oyọli
\q2 ngme ingmemhi ebe,
\q2 ali ingmemhi ẹgbhọli.
\q1 
\v 11 Ọ mema ya mẹ
\q2 ingmobe na,
\q2 ọọ riẹlẹ onete.
\q1 Ọọ mema ya ke
\q2 nono opfọmhẹ,
\q2 ọ na khu ọli.
\q1 
\v 12 Irari khi eri ukpẹloe
\q2 oyi Ọnọmhuẹ o la
\q2 ẹgbọ eni e guẹ ngeli egbe,
\q2 esọ eyọli e khueghie-a
\q2 shi iromhi ni ẹ sọ,
\q1 ama elemhi e ma bi
\q2 Ọnọmhuẹ deba ẹgbọ ọkhọlọ.\f + \fr 3:12 \ft Li zẹ \fq Iwolo 34.12-16\f*
\p 
\v 13 Ọghuo ọ ya ri emhi obe li ẹ, ini onete iriẹlẹ o mema ghọle ẹ?
\v 14 Ama ini u tseku mẹ osoli shi onete iriẹlẹ, ikhivọsẹ o khi nẹ. “Khi na ulishi ọgbọkhọghuo.”
\v 15 Ama a rọte ekẹ elemhi udu oyẹẹ rue iJesu abi Ọnọmhuẹ ọyẹ ẹ. A ke mu egbe shi ekẹ ẹghẹghẹkpa, ini ọgbọkhọghuo ọ ya mhila ẹ emini irudushi oyẹẹ o migha nga, ni a gue ọli yẹ wẹ. Ama a ri ipfọmhẹ-udu ali ekpẹ ke sọ wẹ ọ.\f + \fr 3:15 \ft Li zẹ \fq iMat 5.10; Aza 8.12-13\f*
\v 16 Zobẹ ni udu oyẹ o pfuasẹ isheghọ ni eni ẹ ngme onobe shi angeli onete oyẹ abi ọni ọ deba iKirisiti, e mẹ omama ingmemhi ipfuẹchẹ ọgbọ-a eyẹwẹ.
\v 17 Ini o ghọle Ẹshinẹgba ni u rọ mẹ osoli shi itobọ khi u riẹlẹ onete, o ti dọsẹ khi u mẹ osoli shi ọkhọlọ ni u riẹlẹ.
\v 18 Irari khi iKirisiti ọ ghu-a shi olamhẹ oyi ọgbọkpa utoghuo kpe, ikhi lọli ni ọ pfuasẹ, ọ mẹ osoli na ena umhapfuasẹ, ni ọ rọ rue awa bhale ghi Ẹshinẹgba. A gbe ọli-a alo gbugbugbu, ama ọ la agbọ elemhi ayẹmhẹ, a ri Ayẹmhẹ guise ọli le bhale agbọ.
\v 19 Elemhi ayẹmhẹ ni ọ la, ọ rọ vu ya tse abọ usomhi onete oyi Ẹshinẹgba yẹ iyẹmhẹ ni e la owa ighumha.
\v 20 Iyẹmhẹ ena e khi eni ẹa suọ esọ, abi Ẹshinẹgba ọ rọ ri abọ mu udu, ni iNoa ọ rọ khali ọkọ-okẹ oniẹmhi se. Ẹgbọ etu-olale kpele a pfuese elemhi oni amẹ.\f + \fr 3:20 \ft Li zẹ \fq Igbae 6.1--7.24\f*
\v 21 Oni amẹ o migha shi ibatizi, ona o mie ẹ pfuese memena. Ọa khi ilẹsẹ khuẹ ichimhi idiegbe-a, ama, imhọli udu ni o pfuasẹ deba Ẹshinẹgba ni ọ tsumhi ẹ rọte irọte eghuli guale oyi iJesu iKirisiti.
\v 22 IJesu iKirisiti ọ she je iloghie, ọ shitọ epfẹ obọ obita oyi Ẹshinẹgba, ọ mhẹsẹ ẹ na igẹni ali afu ali ekpabọ ni e la idane.
\c 4
\s1 Angeli ni o mu pfi
\p 
\v 1 Abi o rọ khia khi iKirisiti ọ she mẹ osoli idiegbe, a li mu egbe ni a li ya mhọli angeli oghọghọ, irari khi ọni ọ da lighọ mẹ osoli idiegbe ne, ọa ke gbo mhọli emini ọ ri olamhẹ ẹ riẹlẹ.
\v 2 Rọte memena je odalo elemhi agbọ oyẹ, khi gbo zẹ ni ọghuẹmhẹ idiegbe oyẹ o mhẹsẹ nẹ, ochoghọ, zẹ ni u ke ngeli abi Ẹshinẹgba ọ li nono ọli shi.
\v 3 A she kpe pfuse ukpokpomhi ẹghẹghẹ-a je ukhokho rọ ọ riẹlẹ emini eni ẹa miesuọ e riẹlẹ. A la agbọ itsẹbọ ilili, idọkọnyọ, idonyọ yesegbe-a, ali idobiẹ, ali ikia-ye-ukue ke da onyọ, ali ilitsa igaga.
\v 4 Ama memena, abọ e sha wẹ khi aa ke nu wẹ a riẹlẹ ikhiakhiamhi emini ẹẹ riẹlẹ, e ri itobọ ighọ ọ tsue ẹ.
\v 5 Ama khi e mema ya gueyẹ Ẹshinẹgba abi e li gbe, ọni ọ ya gue ẹgbọ ẹzọ, shi eni e laọ ali eni e ghua.
\v 6 Onana o zẹ ni a rọ tse abọ usomhi onete yẹ ẹgbọ ni e ghua, ni a rọ gue wẹ ẹzọ abi a li ya gue ẹgbọ na agbọ ẹzọ, ama eri e la elemhi ayẹmhẹ abi Ẹshinẹgba ọ la ọ.
\s1 Guẹ ri ukpẹloe ke khu isomhopfa eyi Ẹshinẹgba
\p 
\v 7 Ẹghẹghẹ ni agbọ o rọ ya pfo o she ti ramhi ana. Irarighọ, a bino angeli bie ke ngeli ni a dobẹ toto obọ iromhi isọsọ.
\v 8 Oni o mema mu egbe nẹ nya khi, a nono ingme egbe ẹ egbegbọ, itobọ khi eri inono ọọ khukhu olamhẹ ebubu.\f + \fr 4:8 \ft Li zẹ \fq Ekpi 10.12\f*
\v 9 A ke mu egbe ẹ epfẹse, ni awọlọ ọa la.
\v 10 Ọgbọgbọ ọ ri isomhopfa ni ọ mhuẹ ke kpaghiẹ ọnuzava ọyọli obọ, ọ ri igẹsikia ke ri ẹloe khu okhale oyi Ẹshinẹgba odẹkhodẹ.
\v 11 Ini ọgbọkhọghuo ọ mhọli ungmemhi ya ngme, ọ ke ngme ungmemhi oyi Ẹshinẹgba. Ọnini ọ ya kpaghiẹ ọgbọ obọ, ọ ri itoto ni Ẹshinẹgba ọ rọ na li riẹlẹ ọli. Ni a rọ bhale ya ẹ khi a rọte obọ oyi iJesu iKirisiti ri ikuẹghiẹ na Ẹshinẹgba odẹkhodẹ. Lọli ọ mhọli ufumhi ali ekpabọ rọte agbọagbọ ya je agbọagbọ. Atsẹ.
\s1 Imẹ-osoli irari khi u miesuọ
\p 
\v 12 Emọle mhẹ abọ e khi sha ẹ shi ọmufẹ ni o toto ni a mẹ, abinẹ khi emini aa kpẹ mẹ ghue a mẹ.
\v 13 A ri ochoghọ ke ghẹlẹ khi a li nu iKirisiti mẹ osoli ni ọ mẹ. Ẹghẹghẹ aghọ ni a mhọli oghẹlẹ oniẹmhi, ini a ri ufumhi oyọli khasẹ.
\v 14 Ini a ri itobọ eva oyi iKirisiti ẹẹ tsue ẹ, ikhivọsẹ o khi nẹ, irari khi Ayẹmhẹ oyi ufumhi ali oyi Ẹshinẹgba o nu ẹ la.
\v 15 Ini u mẹ osoli, khi zẹ ni a bhale ya ẹ khi itobọ khi u gbe ugbeli ali itobọ khi u do ighiatọ, wẹkhi angeli ikpamhika ali itashingme u rọ mẹ osoli.
\v 16 Ama ini u wa mẹ osoli abi ọni ọ miesuọ, khi zẹ ni omama o mu ẹ, ama ke kuẹghiẹ Ẹshinẹgba irari khi u wa yemhẹ eva oyọli.
\v 17 Irari khi ẹghẹghẹ o she ramhi ni iguẹzọ o rọ ya rọte Owa oyi Ẹshinẹgba ya gbaekẹle. Ini o te awa egbe gbaekẹle, sẹ o ke bẹshi ya li eni ẹa mie usomhi onete oyi Ẹshinẹgba suọ egbe?
\v 18 Abi Ebe-no-pfuasẹ o ngme ọ li khi,
\q1 “Ini o ya munu ni a rọ tsumhi
\q2 ọgbọ ni ọ guẹ ẹ ngeli,
\q1 sẹ o ke bie ya li
\q2 ẹgbọ ọkhọlọ ni ẹa mhọli
\q2 Ẹshinẹgba egbe?”\f + \fr 4:18 \ft Li zẹ \fq Ekpi 11.31\f*
\p 
\v 19 Irarighọ, eni ẹẹ mẹ osoli, abi o li ghọle Ẹshinẹgba shi, e ri egbe wẹ mhọli Ẹshinẹgba ni ọ ma wẹ ni ọ zẹ ri egbe ẹ nga obọ. E kie ke gbe ikanya enete.
\c 5
\s1 Ude ni a ye Egbhali ali ozele
\p 
\v 1 Mhi lolo ye ẹ ude, ẹẹ ni a khi egbhali abi mhẹmhẹ mhi li khi ọgbhali, ni mhi ri ẹloe mẹ osoli ni iJesu ọ mẹ, ni mhi gbo li ya mhọli okemhi shi ufumhi oyọli ini ọ nyenẹ egbe bhale.
\v 2 A ri ẹloe ke khu isumha eyi Ẹshinẹgba ni a rọ nga ẹ obọ. O ga pfo ẹ udu ke ri ẹloe khu wẹ. Ọa khi irari eleli ni u ya mẹ ọ tsẹ, ama abi ọgbọ ni ọ mhọli ọghuẹmhẹ ugamhi oyi Ẹshinẹgba.\f + \fr 5:2 \ft Li zẹ \fq iJọn 21.15-17\f*
\v 3 Khi ri itoto mhẹsẹ na ẹgbọ ni Ẹshinẹgba ọ rọ ngẹ obọ, ochoghọ angeli o yẹ o khi irọkhọkhọ ni ẹgbọ ke deba.
\v 4 Ini iJesu iKirisiti ni ọ khi Ọrẹloe-khu isumha ọnọfunẹ ọ bhale, ọ ya ri arula oghie ni ọa tigbe ya taa nẹ.
\p 
\v 5 Ẹẹ ezele, a li lighọ nyẹsẹ ukhomhi ke na egbhali. Ọgbọkpa ọ ke ti egbe ọli tiemhi ekẹ, àá ga egbe ẹ. Irari khi Ebe-no-pfuasẹ o ngme ghọ khi.
\q1 “Ẹshinẹgba ọ ma biselemhi
\q2 ọgbọ ni ọ ti egbọli a nga,
\q1 ama ọ khi ẹ vọsẹ na eni
\q2 e ti egbewẹ ẹ tiemhile.”\f + \fr 5:5 \ft Li zẹ \fq Ekpi 3.34\f*
\m 
\v 6 Irarighọ, a ri egbe ẹ tiemhile na ekpabọ oyi Ẹshinẹgba ni e funẹ, ni ọ ti ẹ nga idane ini o ramhi oni ẹghẹghẹ.\f + \fr 5:6 \ft Li zẹ \fq iMat 23.12; iLuk 14.11; 18.14\f*
\v 7 A zẹ ọtoemhẹ eyẹ ẹ obọ na Ẹshinẹgba, itobọ khi ọ ya rue ẹ ọ le.
\p 
\v 8 A bino angeli bie ke ngeli, àà tọkpẹ, itobọ khi ọbe ẹ ni ọ khi ọkphaghiẹ, ọ kia gasẹ abi ọdumhi ni ọọ khoshẹ, eri ọ nono ọni ọ ya mu nyanọ le.
\v 9 Khi zẹ ọli lo ẹ le! Gbe lighi irudunga oyẹ, itobọ khi u lẹsẹ khi eni e miesuọ nabi yẹyẹ ni e la elemhi agbọ ashakhasha e lili ẹ mẹ osoli enabi enana.
\v 10 Ini u mẹ osoli ukuku ẹghẹghẹ se, Ẹshinẹgba na okhale nya, ni ọ rọte iKirisiti lu ẹ shi ufumhi oyọli na agbọagbọ, ọ ya riẹlẹ ẹ ti dọsẹ abi o kpẹ li ẹ egbe. Ọ rẹ toto, ọ mu ẹ mhọli rẹ gbelighi.
\v 11 Ekpabọ o khi oyọli agbọagbọ. Atsẹ.
\s1 Otsẹ ni o kpukhokho
\p 
\v 12 ISalasi ni mhi rọ shi inyọghuo ni ọ mhọli igẹsikia ọ nu mhẹ kẹkẹ ebe ona. Eri mhi kẹkẹ ebe ona ni ọa nuẹ ghi ẹ, rọ ri udu shi ẹ ọ ali ni a rọ lẹsẹ khi emiemini a riẹ mẹ khi egbegbi okhale oyi Ẹshinẹgba na. A mu ọli mhuẹ gagaga.\f + \fr 5:12 \ft Li zẹ \fq Ika 15.22,40\f*
\p 
\v 13 Ẹgbọ eni e miesuọ ni a zẹ abi ẹẹ na ekẹ iBabilọ, ẹẹ tsẹ ẹ, li shi iMaki ni ọ limhẹ egbe abi omimhẹ.\f + \fr 5:13 \ft Li zẹ \fq Ika 12.12,25; 13.13; 15.37-39; iKolo 4.10; iFilẹ 24\f*
\v 14 A ke tsẹ egbe ẹ a ri inono ghẹlẹ mu egbe. Opfọmhẹ o ka nu ẹẹ nya ni a la elemhi iKirisiti la.
