\v 9 \w Les|strong="H3427"\w* princes \w des|strong="H5921"\w* \w peuples|strong="H1471"\w* \w se|strong="H1471"\w* rassemblent \w avec|strong="H3427"\w* \w le|strong="H3427"\w* \w peuple|strong="H1471"\w* \w du|strong="H3427"\w* \w Dieu|strong="H3427"\w* d'Abraham; car \w à|strong="H3427"\w* \w Dieu|strong="H3427"\w* \w sont|strong="H3427"\w* \w les|strong="H3427"\w* boucliers \w de|strong="H3427"\w* \w la|strong="H5921"\w* \w terre|strong="H5921"\w*; \w il|strong="H3427"\w* \w est|strong="H1471"\w* souverainement élevé.
\c 48
\p 
\v 1 \w L|strong="H3068"\w*'Éternel \w est|strong="H1121"\w* grand \w et|strong="H1121"\w* très digne \w de|strong="H1121"\w* louanges, \w dans|strong="H1121"\w* \w la|strong="H1121"\w* cité \w de|strong="H1121"\w* \w notre|strong="H1121"\w* \w Dieu|strong="H1121"\w*, \w sur|strong="H1121"\w* \w sa|strong="H1121"\w* montagne sainte.
\v 2 \w Elle|strong="H3068"\w* \w s|strong="H5892"\w*'\w élève|strong="H1419"\w* \w avec|strong="H3068"\w* grâce, \w la|strong="H3068"\w* \w montagne|strong="H2022"\w* \w de|strong="H5892"\w* Sion, joie \w de|strong="H5892"\w* \w toute|strong="H3966"\w* \w la|strong="H3068"\w* \w terre|strong="H3068"\w*; \w du|strong="H5892"\w* \w côté|strong="H3068"\w* \w du|strong="H5892"\w* septentrion \w est|strong="H3068"\w* \w la|strong="H3068"\w* \w ville|strong="H5892"\w* \w du|strong="H5892"\w* \w grand|strong="H1419"\w* Roi.
