\p 
\v 19 Pul, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Asiria, llegó \w contra|strong="H5921"\w* \w la|strong="H5921"\w* tierra, \w y|strong="H5921"\w* \w Manahem|strong="H4505"\w* \w dio|strong="H5414"\w* \w a|strong="H3068"\w* Pul 33 toneladas \w de|strong="H5921"\w* \w plata|strong="H3701"\w* \w para|strong="H5921"\w* \w que|strong="H5921"\w* \w la|strong="H5921"\w* \w mano|strong="H3027"\w* \w de|strong="H5921"\w* \w él|strong="H5921"\w* estuviera \w a|strong="H3068"\w* favor \w de|strong="H5921"\w* \w Manahem|strong="H4505"\w*, \w a|strong="H3068"\w* fin \w de|strong="H5921"\w* fortalecer \w el|strong="H5921"\w* \w reino|strong="H4467"\w* bajo su dominio.
\v 20 \w Manahem|strong="H4505"\w* \w impuso|strong="H5414"\w* \w este|strong="H5975"\w* \w dinero|strong="H3701"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w* \w por|strong="H5921"\w* medio \w de|strong="H5921"\w* un tributo \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H5921"\w* \w poderosos|strong="H1368"\w* \w y|strong="H5921"\w* opulentos: 550 gramos \w de|strong="H5921"\w* \w plata|strong="H3701"\w* \w por|strong="H5921"\w* \w cada|strong="H3605"\w* uno, \w para|strong="H5921"\w* entregarlos \w al|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Asiria. \w Con|strong="H5921"\w* eso \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Asiria \w se|strong="H5921"\w* retiró, \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w permaneció|strong="H5975"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra.
\p 
\v 21 \w Todo|strong="H3605"\w* \w lo|strong="H1697"\w* \w que|strong="H3808"\w* \w hizo|strong="H6213"\w* \w Manahem|strong="H4505"\w*, ¿\w no|strong="H3808"\w* \w está|strong="H1992"\w* \w escrito|strong="H3789"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* rollo \w de|strong="H5921"\w* \w las|strong="H1992"\w* Crónicas \w de|strong="H5921"\w* \w los|strong="H1992"\w* \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*?
\v 22 \w Manahem|strong="H4505"\w* reposó \w con|strong="H5973"\w* sus antepasados, y su \w hijo|strong="H1121"\w* Pecaía \w reinó|strong="H4427"\w* \w en|strong="H5973"\w* su \w lugar|strong="H8478"\w*.
\s1 Reinado de Pecaía en Israel
\p 
\v 23 \w El|strong="H5921"\w* \w año|strong="H8141"\w* 50 \w de|strong="H5921"\w* \w Azarías|strong="H5838"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, comenzó \w a|strong="H3068"\w* reinar Pecaía, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* \w Manahem|strong="H4505"\w*, \w en|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w y|strong="H5921"\w* \w reinó|strong="H4427"\w* \w en|strong="H5921"\w* \w Samaria|strong="H8111"\w* \w dos|strong="H8141"\w* \w años|strong="H8141"\w*.
\v 24 \w Hizo|strong="H6213"\w* \w lo|strong="H3808"\w* \w malo|strong="H7451"\w* ante \nd \w Yavé|strong="H3068"\w*\nd*. \w No|strong="H3808"\w* \w se|strong="H3808"\w* apartó \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w pecados|strong="H2403"\w* \w de|strong="H1121"\w* \w Jeroboam|strong="H3379"\w*, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Nabat|strong="H5028"\w*, con \w los|strong="H1121"\w* cuales estimuló \w a|strong="H3068"\w* \w pecar|strong="H2398"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w*.
\p 
\v 25 \w Conspiró|strong="H7194"\w* \w contra|strong="H5921"\w* \w él|strong="H5921"\w* su comandante Peca, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Remalías, \w junto|strong="H5921"\w* \w con|strong="H5973"\w* Argob, Arie \w y|strong="H5921"\w* 50 \w hombres|strong="H1121"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* galaaditas. \w Lo|strong="H5921"\w* \w mató|strong="H5221"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* palacio \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w casa|strong="H1004"\w* \w real|strong="H4428"\w* \w en|strong="H5921"\w* \w Samaria|strong="H8111"\w*, \w y|strong="H5921"\w* \w reinó|strong="H4427"\w* \w en|strong="H5921"\w* su \w lugar|strong="H8478"\w*.
\v 26 \w Todo|strong="H3605"\w* \w lo|strong="H1697"\w* \w que|strong="H5921"\w* \w hizo|strong="H6213"\w* Pecaía, \w ciertamente|strong="H2009"\w* \w está|strong="H5921"\w* \w escrito|strong="H3789"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* rollo \w de|strong="H5921"\w* \w las|strong="H5921"\w* Crónicas \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.
\s1 Reinado de Peca en Israel
\p 
\v 27 \w El|strong="H5921"\w* \w año|strong="H8141"\w* 52 \w de|strong="H5921"\w* \w Azarías|strong="H5838"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*, Peca, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Remalías, comenzó \w a|strong="H3068"\w* reinar \w en|strong="H5921"\w* \w Israel|strong="H3478"\w* \w y|strong="H5921"\w* \w reinó|strong="H4427"\w* 20 \w años|strong="H8141"\w* \w en|strong="H5921"\w* \w Samaria|strong="H8111"\w*.
\v 28 \w Hizo|strong="H6213"\w* \w lo|strong="H3808"\w* \w malo|strong="H7451"\w* ante \nd \w Yavé|strong="H3068"\w*\nd*, \w pues|strong="H4480"\w* \w no|strong="H3808"\w* \w se|strong="H4480"\w* apartó \w de|strong="H4480"\w* \w los|strong="H1121"\w* \w pecados|strong="H2403"\w* \w de|strong="H4480"\w* \w Jeroboam|strong="H3379"\w*, \w hijo|strong="H1121"\w* \w de|strong="H4480"\w* \w Nabat|strong="H5028"\w*, \w con|strong="H4480"\w* \w los|strong="H1121"\w* cuales estimuló \w a|strong="H3068"\w* \w pecar|strong="H2398"\w* \w a|strong="H3068"\w* \w Israel|strong="H3478"\w*.
\s1 Deportación de gran parte de Israel a Asiria
\p 
\v 29 En \w el|strong="H3605"\w* \w tiempo|strong="H3117"\w* de Peca, \w rey|strong="H4428"\w* de \w Israel|strong="H3478"\w*, llegó Tiglat-pileser, \w rey|strong="H4428"\w* de Asiria. \w Tomó|strong="H3947"\w* Ijón, Abel-bet-maaca, Janoa, Cedes, Hazor, \w Galaad|strong="H1568"\w*, Galilea y \w toda|strong="H3605"\w* \w la|strong="H3605"\w* tierra de Neftalí, y \w los|strong="H3605"\w* \w llevó|strong="H3947"\w* \w cautivos|strong="H1540"\w* \w a|strong="H3068"\w* Asiria.
\p 
\v 30 \w El|strong="H5921"\w* \w año|strong="H8141"\w* 20 \w de|strong="H5921"\w* Jotam, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Azarías, \add rey de Judá\add*, \w Oseas|strong="H1954"\w*, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Ela, tramó una conspiración \w contra|strong="H5921"\w* Peca, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Remalías. \w Lo|strong="H5921"\w* \w hirió|strong="H5221"\w*, \w lo|strong="H5921"\w* \w mató|strong="H5221"\w*, \w y|strong="H5921"\w* \w reinó|strong="H4427"\w* \w en|strong="H5921"\w* su \w lugar|strong="H8478"\w*.
\v 31 \w Todo|strong="H3605"\w* \w lo|strong="H1697"\w* \w que|strong="H5921"\w* \w hizo|strong="H6213"\w* Peca \w ciertamente|strong="H2009"\w* \w está|strong="H5921"\w* \w escrito|strong="H3789"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* rollo \w de|strong="H5921"\w* \w las|strong="H5921"\w* Crónicas \w de|strong="H5921"\w* \w los|strong="H5921"\w* \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*.
\s1 Reinado de Jotam en Judá
\p 
\v 32 \w El|strong="H1121"\w* \w segundo|strong="H8147"\w* \w año|strong="H8141"\w* \w de|strong="H1121"\w* Peca, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Remalías, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Israel|strong="H3478"\w*, comenzó \w a|strong="H3068"\w* reinar Jotam, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Uzías, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*.
\v 33 \w Cuando|strong="H1961"\w* comenzó \w a|strong="H3068"\w* reinar \w tenía|strong="H1961"\w* 25 \w años|strong="H8141"\w*, y \w reinó|strong="H4427"\w* 16 \w años|strong="H8141"\w* en Jerusalén. \w El|strong="H1121"\w* \w nombre|strong="H8034"\w* \w de|strong="H2568"\w* su madre \w fue|strong="H1961"\w* Jerusa, \w hija|strong="H1323"\w* \w de|strong="H2568"\w* \w Sadoc|strong="H6659"\w*.
\v 34 \w Hizo|strong="H6213"\w* \w lo|strong="H6213"\w* \w recto|strong="H3477"\w* ante \nd \w Yavé|strong="H3068"\w*\nd*, conforme \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w lo|strong="H6213"\w* \w que|strong="H3605"\w* \w hizo|strong="H6213"\w* su padre Uzías.
\v 35 \w Sin|strong="H3808"\w* embargo, \w no|strong="H3808"\w* \w se|strong="H1931"\w* \w quitaron|strong="H5493"\w* \w los|strong="H1931"\w* lugares \w altos|strong="H1116"\w*, \w porque|strong="H3808"\w* \w el|strong="H1931"\w* \w pueblo|strong="H5971"\w* \w aún|strong="H5750"\w* \w sacrificaba|strong="H2076"\w* y quemaba incienso \w en|strong="H5493"\w* \w los|strong="H1931"\w* lugares \w altos|strong="H1116"\w*. \w Él|strong="H1931"\w* construyó \w la|strong="H1931"\w* \w puerta|strong="H8179"\w* \w más|strong="H5750"\w* alta \w de|strong="H5750"\w* \w la|strong="H1931"\w* \w Casa|strong="H1004"\w* \w de|strong="H5750"\w* \nd \w Yavé|strong="H3068"\w*\nd*.
\p 
\v 36 Todo \w lo|strong="H1697"\w* \w que|strong="H3808"\w* \w hizo|strong="H6213"\w* Jotam, ¿\w no|strong="H3808"\w* \w está|strong="H1992"\w* \w escrito|strong="H3789"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* rollo \w de|strong="H5921"\w* \w las|strong="H1992"\w* Crónicas \w de|strong="H5921"\w* \w los|strong="H1992"\w* \w reyes|strong="H4428"\w* \w de|strong="H5921"\w* \w Judá|strong="H3063"\w*?
\p 
\v 37 En aquel \w tiempo|strong="H3117"\w* \nd \w Yavé|strong="H3068"\w*\nd* \w comenzó|strong="H2490"\w* \w a|strong="H3068"\w* enviar \w a|strong="H3068"\w* \w Rezín|strong="H7526"\w*, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* Siria, y \w a|strong="H3068"\w* Peca, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Remalías, contra \w Judá|strong="H3063"\w*.
\v 38 Azarías descansó Jotam \w con|strong="H5973"\w* sus antepasados, y fue \w sepultado|strong="H6912"\w* \w en|strong="H5973"\w* la \w ciudad|strong="H5892"\w* \w de|strong="H8478"\w* \w David|strong="H1732"\w*. Su \w hijo|strong="H1121"\w* Acaz \w reinó|strong="H4427"\w* \w en|strong="H5973"\w* su \w lugar|strong="H8478"\w*.
\c 16
\s1 Reinado de Acaz en Judá
\p 
\v 1 \w El|strong="H1121"\w* \w año|strong="H8141"\w* 17 \w de|strong="H1121"\w* Peca, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Remalías, \add rey de Israel\add*, comenzó \w a|strong="H3068"\w* reinar Acaz, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* Jotam, \w rey|strong="H4428"\w* \w de|strong="H1121"\w* \w Judá|strong="H3063"\w*.
\v 2 Acaz tenía 19 \w años|strong="H8141"\w* cuando comenzó \w a|strong="H3068"\w* reinar, y \w reinó|strong="H4427"\w* en Jerusalén 16 \w años|strong="H8141"\w*. Pero \w no|strong="H3808"\w* \w hizo|strong="H6213"\w* \w lo|strong="H3808"\w* \w recto|strong="H3477"\w* ante \nd \w Yavé|strong="H3068"\w*\nd* su \nd ʼElohim\nd*, como su antepasado \w David|strong="H1732"\w*,
\v 3 sino \w anduvo|strong="H3212"\w* \w en|strong="H3212"\w* \w el|strong="H1121"\w* \w camino|strong="H1870"\w* \w de|strong="H6440"\w* \w los|strong="H1121"\w* \w reyes|strong="H4428"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*. Incluso hizo \w pasar|strong="H5674"\w* \w a|strong="H3068"\w* su \w hijo|strong="H1121"\w* \w por|strong="H1870"\w* \w el|strong="H1121"\w* fuego, según las repugnancias \w de|strong="H6440"\w* \w los|strong="H1121"\w* \w pueblos|strong="H1471"\w* \w que|strong="H1571"\w* \nd \w Yavé|strong="H3068"\w*\nd* expulsó \w de|strong="H6440"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H6440"\w* \w Israel|strong="H3478"\w*.
\v 4 Asimismo \w sacrificó|strong="H2076"\w* \w y|strong="H5921"\w* quemó incienso \w en|strong="H5921"\w* \w los|strong="H5921"\w* lugares \w altos|strong="H1116"\w*, \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* colinas \w y|strong="H5921"\w* \w debajo|strong="H8478"\w* \w de|strong="H5921"\w* \w todo|strong="H3605"\w* \w árbol|strong="H6086"\w* \w frondoso|strong="H7488"\w*.
\p 
\v 5 Entonces \w Rezín|strong="H7526"\w*, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Siria, \w y|strong="H5921"\w* Peca, \w hijo|strong="H1121"\w* \w de|strong="H5921"\w* Remalías, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w subieron|strong="H5927"\w* \w a|strong="H3068"\w* Jerusalén \w para|strong="H5921"\w* hacer \w la|strong="H5921"\w* \w guerra|strong="H4421"\w*. Sitiaron \w a|strong="H3068"\w* Acaz, pero \w no|strong="H3808"\w* \w prevalecieron|strong="H3201"\w*.
\v 6 \w En|strong="H5704"\w* \w aquel|strong="H1931"\w* \w tiempo|strong="H6256"\w* \w Rezín|strong="H7526"\w*, \w rey|strong="H4428"\w* \w de|strong="H5704"\w* Siria, \w recuperó|strong="H7725"\w* Elat \w para|strong="H5704"\w* Siria, \w y|strong="H5704"\w* expulsó \w a|strong="H3068"\w* \w los|strong="H3427"\w* \w judíos|strong="H3064"\w* \w de|strong="H5704"\w* Elat. \w Los|strong="H3427"\w* sirios fueron \w a|strong="H3068"\w* Elat, \w donde|strong="H8033"\w* viven \w hasta|strong="H5704"\w* \w hoy|strong="H3117"\w*.
\p 
\v 7 Entonces Acaz \w envió|strong="H7971"\w* \w mensajeros|strong="H4397"\w* \w a|strong="H3068"\w* Tiglat-pileser, \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Asiria, \w para|strong="H5921"\w* decirle: Soy tu esclavo \w y|strong="H5921"\w* tu \w hijo|strong="H1121"\w*. \w Sube|strong="H5927"\w* \w y|strong="H5921"\w* \w sálvame|strong="H3467"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w mano|strong="H3709"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* Siria \w y|strong="H5921"\w* \w del|strong="H5921"\w* \w rey|strong="H4428"\w* \w de|strong="H5921"\w* \w Israel|strong="H3478"\w*, \w que|strong="H5921"\w* \w se|strong="H5921"\w* \w levantaron|strong="H6965"\w* \w contra|strong="H5921"\w* \w mí|strong="H5921"\w*.
\v 8 Acaz \w tomó|strong="H3947"\w* la \w plata|strong="H3701"\w* y el \w oro|strong="H2091"\w* que encontró en la \w Casa|strong="H1004"\w* de \nd \w Yavé|strong="H3068"\w*\nd* y en los tesoros de la \w casa|strong="H1004"\w* \w real|strong="H4428"\w*, y \w envió|strong="H7971"\w* un \w presente|strong="H7810"\w* \w al|strong="H4428"\w* \w rey|strong="H4428"\w* de Asiria.
\v 9 El \w rey|strong="H4428"\w* de Asiria lo \w atendió|strong="H8085"\w*, \w subió|strong="H5927"\w* contra \w Damasco|strong="H1834"\w* y la \w tomó|strong="H5927"\w*. Llevó \w cautivos|strong="H1540"\w* \w a|strong="H3068"\w* sus habitantes \w a|strong="H3068"\w* Kir, y \w mató|strong="H4191"\w* \w a|strong="H3068"\w* \w Rezín|strong="H7526"\w*.
\p 
\v 10 Cuando \w el|strong="H3605"\w* \w rey|strong="H4428"\w* Acaz \w fue|strong="H3212"\w* \w a|strong="H3068"\w* \w Damasco|strong="H1834"\w* \w a|strong="H3068"\w* encontrarse con Tiglat-pileser, \w rey|strong="H4428"\w* de Asiria, observó \w el|strong="H3605"\w* \w altar|strong="H4196"\w* \w que|strong="H3605"\w* estaba \w en|strong="H3212"\w* \w Damasco|strong="H1834"\w*. \w El|strong="H3605"\w* \w rey|strong="H4428"\w* Acaz \w envió|strong="H7971"\w* \w al|strong="H4428"\w* \w sacerdote|strong="H3548"\w* Urías \w el|strong="H3605"\w* diseño y \w el|strong="H3605"\w* modelo \w del|strong="H4196"\w* \w altar|strong="H4196"\w*, según \w toda|strong="H3605"\w* su hechura.
\v 11 \w El|strong="H3605"\w* \w sacerdote|strong="H3548"\w* Urías construyó \w el|strong="H3605"\w* \w altar|strong="H4196"\w* según \w todo|strong="H3605"\w* \w lo|strong="H6213"\w* \w que|strong="H5704"\w* \w envió|strong="H7971"\w* \w el|strong="H3605"\w* \w rey|strong="H4428"\w* Acaz \w desde|strong="H5704"\w* \w Damasco|strong="H1834"\w*. \w Así|strong="H3651"\w* \w lo|strong="H6213"\w* \w hizo|strong="H6213"\w* \w el|strong="H3605"\w* \w sacerdote|strong="H3548"\w* Urías \w antes|strong="H5704"\w* \w que|strong="H5704"\w* \w el|strong="H3605"\w* \w rey|strong="H4428"\w* Acaz regresara \w de|strong="H5704"\w* \w Damasco|strong="H1834"\w*.
\p 
\v 12 Cuando \w el|strong="H5921"\w* \w rey|strong="H4428"\w* \w llegó|strong="H5927"\w* \w de|strong="H5921"\w* \w Damasco|strong="H1834"\w* \w y|strong="H5921"\w* \w vio|strong="H7200"\w* \w el|strong="H5921"\w* \w altar|strong="H4196"\w*, \w se|strong="H5921"\w* acercó \w a|strong="H3068"\w* \w él|strong="H5921"\w* \w y|strong="H5921"\w* \w ofreció|strong="H7126"\w* sacrificios \w sobre|strong="H5921"\w* \w él|strong="H5921"\w*.
\v 13 Quemó su \w holocausto|strong="H5930"\w* \w y|strong="H5921"\w* \w ofrenda|strong="H4503"\w*, derramó sus \w libaciones|strong="H5262"\w* \w y|strong="H5921"\w* roció \w la|strong="H5921"\w* \w sangre|strong="H1818"\w* \w de|strong="H5921"\w* sus sacrificios \w de|strong="H5921"\w* paz \w junto|strong="H5921"\w* \w al|strong="H5921"\w* \w altar|strong="H4196"\w*.
