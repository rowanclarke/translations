\v 3 \w Therefore|strong="H3651"\w* \w prophesy|strong="H5012"\w* \w about|strong="H5439"\w* \w those|strong="H5921"\w* mountains \w and|strong="H5971"\w* say, “\w This|strong="H3651"\w* \w is|strong="H3651"\w* \w what|strong="H3541"\w* \w Yahweh|strong="H3068"\w* \w the|strong="H5921"\w* \w Lord|strong="H3069"\w* declares: \add Armies of other nations\add* \w attacked|strong="H5927"\w* \w you|strong="H5921"\w* [DOU] \w from|strong="H5921"\w* \w every|strong="H5439"\w* \w direction|strong="H5439"\w*, \w with|strong="H5921"\w* \w the|strong="H5921"\w* result \w that|strong="H5971"\w* \w your|strong="H5921"\w* land \w became|strong="H1961"\w* abandoned, \w and|strong="H5971"\w* \w people|strong="H5971"\w* \w of|strong="H7611"\w* \w other|strong="H8193"\w* \w nations|strong="H1471"\w* occupied \w you|strong="H5921"\w*, \w and|strong="H5971"\w* \w they|strong="H3651"\w* spoke maliciously \w about|strong="H5439"\w* \w you|strong="H5921"\w* \w and|strong="H5971"\w* slandered \w you|strong="H5921"\w*.  
