\id GEN
\h أَمزْوَارُو
\toc1 أَمزْوَارُو
\toc2 أَمزْوَارُو
\toc3 أَمز.
\mt1 أَمزْوَارُو
\c 1
\s1 ثَاخڒْقِيثْ ن إِجنْوَانْ ذ ثمُّورْثْ
\m 
\v 1 ذڭْ ؤُمزْوَارُو إِخْڒقْ-د أَربِّي إِجنْوَانْ ذ ثمُّورْثْ. \x ◘ \xo 1:‏1 \xt أَيُوبْ 38‏:‏4؛ إِزهد. 33‏:‏6؛ 89‏:‏12؛ 136‏:‏5؛ ڒخ. 14‏:‏15؛ 17‏:‏24؛ عبر. 11‏:‏3؛ \x*
\m 
\v 2 ثُوغَا ثَامُّورْثْ ثخْڒَا، أَمْ مَامّشْ وَارْ ت إِتّْحِيذِي حذْ ؤُ خْ وُوذمْ ن \add وَامَانْ\add* إِهوْڒنْ ثَادْجسْثْ، ؤُ أَرُّوحْ ن أَربِّي ثُوغَا إِتّْرَاحْ إِتَّاسْ-د خْ وُوذمْ ن وَامَانْ.
\m 
\v 3 ؤُشَا إِنَّا أَربِّي: ”أَذْ ثِيڒِي ثْفَاوْثْ“، ؤُشَا ثُوسَا-د ثْفَاوْثْ! \f ◼ \fr 1:‏3 \ft \bd ’ثَافَاوْثْ‘\bd* - أَقَا ذِينْ إِجّْ ن ڒْفَارْقْ جَارْ ثْفَاوْثْ غَارْ إِجّْ ن ؤُغزْذِيسْ ؤُ ثْفُوشْثْ ذ إِثْرَانْ غَارْ إِجّْ ن ؤُغزْذِيسْ نّغْنِي. ثَافُوشْثْ ذ يثْرَانْ أَقَا-ثنْ أَربُّونْ ثَافَاوْثْ، مَاشَا وَارْ ڭِّينْ ثَافَاوْثْ س يِيخفْ نْسنْ.\fp ثِيرَا إِقدّْسنْ قَّارنْثْ أَقَا أَربِّي ذ ثَافَاوْثْ، وَارْ ذَايسْ بُو ثَادْجسْثْ (خْزَارْ 1 يُوحْ. 1:5). س ؤُينِّي ثضْهَارْ-د ثْفَاوْثْ ذَانِيثَا مَاشَا وَارْ نقَّارْ أَقَا أَربِّي إِخْڒقْ-د ثَافَاوْثْ.\f*
\v 4 إِژْرَا أَربِّي بلِّي ثَافَاوْثْ ثصْبحْ ؤُشَا إِبْضَا أَربِّي جَارْ ثْفَاوْثْ ذ ثَادْجسْثْ.
\v 5 إِڒَاغَا أَربِّي ثَافَاوْثْ ’أَزِيڒْ‘ ؤُ ’ثَادْجسْثْ‘ إِڒَاغَا أَسْ ’دْجِيڒثْ‘. ثذْوڒْ ذ ثَامذِّيثْ ؤُ إِذْوڒْ ذ صّْبحْ: \bd ذ أَسّْ أَمزْوَارُو\bd*.
\m 
\v 6 ؤُشَا إِنَّا أَربِّي: ”أَذْ ثِيڒِي إِشْثْ ن ڒْقُوبّثْ ذِي ڒْوسْطْ ن وَامَانْ، أَذْ ثبْضَا أَمَانْ خْ وَامَانْ!“ \x ◘ \xo 1:‏6 \xt إِزهد. 33‏:‏6؛ 104‏:‏2؛ 136‏:‏5؛ أَوڒن. 8‏‏:‏28؛ إِشا. 42‏:‏5؛ إِرْم. 10‏:‏12؛ 51‏:‏15\x*
\v 7 أَربِّي إِڭَّا ڒْقُوبّثْ \add ن ؤُجنَّا\add* ؤُشَا إِبْضَا أَمَانْ إِ إِدْجَانْ سْوَادَّايْ إِ ڒْقُوبّثْ خْ وَامَانْ إِ إِدْجَانْ سنّجْ إِ ڒْقُوبّثْ. ؤُشَا أَمُّو إِ ثمْسَارْ. \x ◘ \xo 1:‏7 \xt إِزهد. 33‏:‏7؛ 136‏:‏6؛ أَوڒن. 8‏:‏24؛ إِزهد. 148‏:‏4. \x*
\v 8 إِڒَاغَا أَربِّي إِ ڒْقُوبّثْ ’أَجنَّا‘. ؤُشَا ثذْوڒْ ذ ثَامذِّيثْ ؤُ إِذْوڒْ ذ صّْبحْ: \bd ذ أَسّْ وِيسّْ ثْنَاينْ\bd*.
\m 
\v 9 ؤُشَا إِنَّا أَربِّي: ”أَذْ مُوننْ وَامَانْ إِ إِدْجَانْ سْوَادَّايْ إِ ؤُجنَّا غَارْ إِجّْ ن ومْشَانْ مَاحنْذْ أَذْ د-إِبَانْ ڒْبَارّْ!“ ؤُشَا أَمُّو إِ ثمْسَارْ. \x ◘ \xo 1:‏9 \xt أَيُوبْ 26‏:‏10؛ 38‏:‏8؛ إِزهد. 24‏:‏2؛ 136‏:‏6. \x*
\v 10 إِڒَاغَا أَربِّي إِ ڒْبَارّْ ’ثَامُّورْثْ‘ ؤُ أَمُونِي ن وَامَانْ إِڒَاغَا أَسْ ’ڒبْحُورْ‘. ؤُشَا إِژْرَا أَربِّي \add بلِّي\add* مَانْ أَيَا إِصْبحْ. \f ◼ \fr 1:‏10 \ft \bd ’ڒبْحُورْ‘\bd* - نِيغْ ’إِلْ‘ ذ ’إِلَاونْ‘.\f*
\m 
\v 11 ؤُشَا إِنَّا أَربِّي: ”أَذْ د-ثسّغْمِي ثمُّورْثْ أَغمُّويْ أَزِيزَا: أَفْسُو \add أَزِيزَا\add* إِ إِزَارّْعنْ زَّارِيعثْ ذ ثْشجُّورَا س فْرُوثَا إِ د إِتِّيشنْ فْرُوثَاثْ عْلَاحْسَابْ مَارْكَا نْسنْثْ س زَّارِيعثْ نْسنْثْ ذَايسْ خْ وُوذمْ ن ثمُّورْثْ!“ ؤُشَا أَمُّو إِ ثمْسَارْ.
\v 12 ثسّغْمِي-د ثمُّورْثْ أَغمُّويْ أَزِيزَا: أَفْسُو \add أَزِيزَا\add* إِ إِزَارّْعنْ زَّارِيعثْ عْلَاحْسَابْ مَارْكَا نّسْ ذ ثْشجُّورَا إِ د إِتِّيشنْ ڒْغِيدْجثْ عْلَاحْسَابْ مَارْكَا نْسنْثْ س زَّارِيعثْ نْسنْثْ ذَايسْ. ؤُشَا إِژْرَا أَربِّي \add بلِّي\add* مَانْ أَيَا إِصْبحْ.
\v 13 ؤُشَا ثذْوڒْ ذ ثَامذِّيثْ ؤُ إِذْوڒْ ذ صّْبحْ: \bd ذ أَسّْ وِيسّْ ثْڒَاثَا\bd*.
\m 
\v 14 ؤُشَا إِنَّا أَربِّي: ”أَذْ \add ذِينْ\add* إِڒِينْثْ ثْفَاوِينْ ذِي ڒْقُوبّثْ \add ن ؤُجنَّا\add* حِيمَا أَذْ بْضَانْثْ جَارْ وَاسّْ ذ دْجِيڒثْ، أَذْ إِڒِينْثْ ذ ڒِْيمَارَاثْ، ذ وُوسَّانْ إِتّْوَاڭّنْ، ذ وُوسَّانْ، ذ إِسڭّْوُوسَا \x ◘ \xo 1:‏14 \xt إِزهد. 136‏:‏7. \x*
\v 15 ؤُشَا أَذْ إِڒِينْثْ ذ ثِيفَاوِينْ ذِي ڒْقُوبّثْ \add ن ؤُجنَّا\add* حِيمَا أَذْ وْشنْثْ ثَافَاوْثْ خْ ثمُّورْثْ!“ ؤُشَا أَمُّو إِ ثمْسَارْ. \x ◘ \xo 1:‏15 \xt أَعَوذ. 4‏:‏19؛ إِرْم. 31‏:‏35\x*
\v 16 إِڭَّا أَربِّي ثْنَاينْ ن ثِيفَاوِينْ مْغَارنْثْ، ثَافَاوْثْ ثَامقّْرَانْثْ، حِيمَا أَذْ ثحْكمْ خْ ؤُزِيڒْ، ؤُ ثَافَاوْثْ ثَامژْيَانْثْ حِيمَا أَذْ ثحْكمْ خْ دْجِيڒثْ، ؤُشَا ؤُڒَا ذ إِثْرَانْ.
\v 17 إِسَّارْسْ إِ-ثنْثْ أَربِّي ذِي ڒْقُوبّثْ \add ن ؤُجنَّا\add* حِيمَا أَذْ وْشنْثْ ثَافَاوْثْ خْ ثمُّورْثْ
\v 18 ؤُ حِيمَا أَذْ حكْمنْثْ خْ وَاسّْ ذ دْجِيڒثْ ؤُ حِيمَا أَذْ بْضَانْثْ جَارْ ثْفَاوْثْ ذ ثَادْجسْثْ. ؤُشَا إِژْرَا أَربِّي \add بلِّي\add* مَانْ أَيَا إِصْبحْ.
\v 19 ؤُشَا ثذْوڒْ ذ ثَامذِّيثْ ؤُ إِذْوڒْ ذ صّْبحْ: \bd ذ أَسّْ وِيسّْ أَربْعَا\bd*.
\m 
\v 20 ؤُشَا إِنَّا أَربِّي: ”أَذْ د-سّفْينْ وَامَانْ س وَاطَّاسْ ن \add مَارَّا مِينْ ذِي إِدْجَا\add* بُوحْبڒْ إِدَّارنْ ؤُشَا أَذْ ضْونْ إِجْضَاضْ سنّجْ إِ ثمُّورْثْ غَارْ مَانِي \add ثدْجَا\add* ڒْقُوبّثْ ن ؤُجنَّا!“ \f ◼ \fr 1:‏20 \ft \bd ’غَارْ مَانِي ثدْجْ ڒْقُوبّثْ ن ؤُجنَّا‘\bd* - س ثْعِيبْرَانِيثْ ’خْ وُوذْمَاونْ ن ڒْقُوبّثْ ن ؤُجنَّا‘.\f*
\v 21 إِخْڒقْ-د أَربِّي إِمُودَّارنْ إِمقّْرَاننْ ذِي ڒبْحَارْ ؤُ مَارَّا بُوحْبڒْ إِدَّارنْ إِتّنْهزَّانْ، إِنِّي زِي د-سّفْينْ وَامَانْ، عْلَاحْسَابْ مَارْكَا نْسنْ ؤُشَا مَارَّا إِجْضَاضْ س وَافْرِيونْ عْلَاحْسَابْ مَارْكَا نْسنْ. ؤُشَا إِژْرَا أَربِّي \add بلِّي\add* مَانْ أَيَا إِصْبحْ.
\m 
\v 22 إِبَارْكْ إِ-ثنْ أَربِّي، إِنَّا: ”جّمْ-د ڒْغِيدْجثْ، كْثَارمْ، عمَّارمْ أَمَانْ ن ڒبْحُورْ ؤُشَا أَذْ كْثَارنْ إِجْضَاضْ ذِي ثمُّورْثْ.“ \x ◘ \xo 1:‏22 \xt أَمز. 8‏:‏17.\x*
\m 
\v 23 ؤُشَا ثذْوڒْ ذ ثَامذِّيثْ ؤُ إِذْوڒْ ذ صّْبحْ: \bd ذ أَسّْ وِيسّْ خمْسَا\bd*.
\m 
\v 24 ؤُشَا إِنَّا أَربِّي: ”أجّْ ثمُّورْثْ أَذْ ثسُّوفّغْ \add مَارَّا مِينْ غَارسْ\add* بُوحْبڒْ إِدَّارنْ عْلَاحْسَابْ مَارْكَا نّسْ: ڒبْهَايمْ ذ \add إِمُودَّارنْ\add* نِّي إِتّْبُوعنْ ذ ڒْمَاڒْ نْ ڒخْڒَا عْلَاحْسَابْ مَارْكَا نْسنْ!“ ؤُشَا أَمُّو إِ ثمْسَارْ. \f ◼ \fr 1:‏24 \ft \bd ’إِمُودَّارنْ‘\bd* - إِخْسْ أَذْ يِينِي ’لْحَايَاوَانَاثْ‘.\f*
\v 25 إِڭَّا أَربِّي ڒْمَاڒْ \add ن ڒخْڒَا\add* ن ثمُّورْثْ عْلَاحْسَابْ مَارْكَا نْسنْ، ؤُ ڒبْهَايمْ عْلَاحْسَابْ مَارْكَا نْسنْثْ ؤُ مَارَّا \add إِمُودَّارنْ\add* نِّي إِتّْبُوعنْ خْ وُوذمْ ن ثمُّورْثْ عْلَاحْسَابْ مَارْكَا نْسنْ. ؤُشَا إِژْرَا أَربِّي \add بلِّي\add* مَانْ أَيَا إِصْبحْ.
\m 
\v 26 ؤُشَا إِنَّا أَربِّي: ”أجّْ أَنغْ أَذْ نڭّْ أَذَامْ، \add بْنَاذمْ\add* ذِي صِّيفثْ نّغْ، ذڭْ وَارْوَاسْ نّغْ، ؤُشَا أَذْ غَارسْ يِيڒِي جّهْذْ خْ إِسڒْمَانْ ن ڒبْحَارْ ؤُ خْ إِجْضَاضْ ن ؤُجنَّا ؤُ خْ ڒبْهَايمْ ؤُ خْ مَارَّا ثَامُّورْثْ ؤُ خْ مَارَّا إِمُودَّارنْ نِّي إِتّْبُوعنْ خْ ثمُّورْثْ!“ \f ◼ \fr 1:‏26 \ft \bd ’أَذْ غَارسْ يِيڒِي‘\bd* - س ثْعِيبْرَانِيثْ ’أَذْ غَارْسنْ يِيڒِي‘، مِينْ إِخْسْ أَذْ يِينِي ’أَذْ يِيڒِي غَارْ إِوْذَانْ ...‘.\f*
\v 27 إِخْڒقْ-د أَربِّي أَذَامْ ذِي صِّيفثْ نّسْ. إِخْڒقْ إِ-ث-إِ-د ذِي صِّيفثْ ن أَربِّي، إِخْڒقْ إِ-ثنْ-د أَوْثمْ ذ ثوْثمْثْ. \x ◘ \xo 1:‏27 \xt أَمز. 5‏:‏1؛ 9‏:‏6؛ 1 كُور. 11‏:‏7؛ أَفا. 4‏:‏24؛ كُول. 3‏:‏10. \x*
\m 
\v 28 إِبَارْكْ إِ-ثنْ أَربِّي ؤُشَا إِنَّا أَسنْ أَربِّي: ”جّمْ-د ڒْغِيدْجثْ، كْثَارمْ، عمَّارمْ ثَامُّورْثْ ؤُشَا أَرّمْ ت سَاذُو ؤُفُوسْ نْومْ، حكْممْ خْ إِسڒْمَانْ ن ڒبْحَارْ ؤُ خْ إِجْضَاضْ ن ؤُجنَّا ؤُ خْ مَارَّا إِمُودَّارنْ نِّي إِتّْبُوعنْ خْ ثمُّورْثْ!“ \x ◘ \xo 1:‏28 \xt أَمز. 8‏:‏17؛ 9‏:‏1، 2، 7. \x*
\m 
\v 29 إِنَّا أَربِّي: ”خْزَارمْ، أَذْ أَومْ وْشغْ مَارَّا أَفْسُو \add أَزِيزَا\add* إِ إِزَارّْعنْ زَّارِيعثْ خْ مَارَّا وُوذمْ ن ثمُّورْثْ ؤُڒَا ذ مَارَّا ثِيشجُّورَا س ڒْغِيدْجثْ نِّي إِزَارّْعنْ زَّارِيعثْ. مَانْ أَيَا أَذْ أَومْ يِيڒِي ذ مَاشَّا. \f ◼ \fr 1:‏29 \ft \bd ’ثَاشجَّارْثْ‘\bd* - نِيغْ ’أَسكْلُو‘ (’إِسكْلَا‘) نِيغْ ’ثَادَّاڭْثْ‘ (’ثِيدَّاڭِينْ‘). \bd أَفسَّارْ\bd* - بْنَاذمْ ثُوغَا إِتّتّْ أَيْسُومْ ذِي ڒْوقْثْ نِّي. أَوَارْنِي إِ طُّوفَانْ إِبْذَا بْنَاذمْ أَذْ يشّْ أَيْسُومْ (خْزَارْ أَمز. 9:2-4).\f*  \x ◘ \xo 1:‏29 \xt أَمز. 9‏:‏3؛ إِزهد. 104‏:‏14، 15. \x*
\v 30 ؤُ إِ مَارَّا ڒْمَاڒْ \add ن ڒخْڒَا\add* ن ثمُّورْثْ، ؤُ إِ مَارَّا إِجْضَاضْ ن ؤُجنَّا ؤُ إِ مَارَّا مِينْ إِتّْبُوعنْ خْ ثمُّورْثْ إِ ذِي إِدْجَا بُوحْبڒْ إِدَّارنْ، أَذْ أَسنْ يِيڒِي مَارَّا أَفْسُو \add أَزِيزَا\add* ذ مَاشَّا إِ نِيثْنِي.“ ؤُشَا أَمُّو إِ ثمْسَارْ. \x ◘ \xo 1:‏30 \xt إِزهد. 104‏:‏14. \x*
\v 31 ؤُشَا إِژْرَا أَربِّي مَارَّا مِينْ إِڭَّا، ؤُ خْزَارْ، ثُوغَا إِصْبحْ أَطَّاسْ. ثذْوڒْ ذ ثَامذِّيثْ ؤُ إِذْوڒْ ذ صّْبحْ: \bd ذ أَسّْ وِيسّْ ستَّا\bd*. \x ◘ \xo 1:‏31 \xt أَعَوذ. 32‏:‏4؛ مك. 7‏:‏37. \x*
\b
\b
\c 2
\m 
\v 1 أَمُّو إِ تّْوَاكمّْڒنْ إِجنْوَانْ ذ ثمُّورْثْ ذ قَاعْ ڒْعسْكَارْ نْسنْ. \f ◼ \fr 2:‏1 \ft \bd ’قَاعْ ڒْعسْكَارْ نْسنْ‘\bd* - نِيغْ ’مَارَّا ڒْعسْكَارْ نْسنْ‘.\f*
\v 2 ذڭْ وَاسّْ وِيسّْ سبْعَا إِكمّڒْ أَربِّي ڒْخذْمثْ نّسْ إِ إِڭَّا ؤُشَا يَاريّحْ ذڭْ وَاسّْ وِيسّْ سبْعَا زِي مَارَّا ڒْخذْمثْ نّسْ إِ إِڭَّا. \x ◘ \xo 2:‏2 \xt ؤُف. 20‏:‏11؛ 31‏:‏17؛ أَعَوذ. 5‏:‏14؛ عبر. 4‏:‏4. \x*
\v 3 إِبَاركْ أَربِّي أَسّْ وِيسّْ سبْعَا ؤُشَا إِسّْقدّسْ إِ-ث، مِينْزِي ذَايسْ إِ يَاريّحْ زِي مَارَّا ڒْخذْمثْ نّسْ، \add ڒْخذْمثْ\add* إِ د-إِخْڒقْ أَربِّي مَاحنْذْ أَذْ ت إِڭّْ \add أَمنِّي\add*.
\m \bd إِنَا ذ إِمزْرُوينْ ن وخْڒَاقْ ن ؤُجنَّا ذ ثمُّورْثْ ڒَامِي د-تّْوَاخڒْقنْ.\bd*
\b
\s1 ثَاخڒْقِيثْ ن أَذَامْ ذ ثمْغَارْثْ نّسْ
\m 
\v 4 ذڭْ وَاسّْ إِ إِڭَّا سِيذِي أَربِّي ثَامُّورْثْ ذ إِجنْوَانْ
\v 5 - قْبڒْ ثُوغِي ذِينْ مَارَّا شْبَارْقْ ذِي ثمُّورْثْ ؤُ قْبڒْ د-إِغْمِي وفْسُو ن ييَّارْ، مِينْزِي سِيذِي أَربِّي وَارْ إِجِّي أَنْژَارْ أَذْ إِوّثْ \add عَاذْ\add* خْ ثمُّورْثْ - ؤُشَا وَارْ ثُوغِي ذِينْ أَذَامْ \add عَاذْ\add* حِيمَا أَذْ إِخْذمْ ثَامُّورْثْ،
\v 6 ثْڭعّذْ-د ثَايُّوثْ زِي ثمُّورْثْ، ثسُّو مَارَّا ؤُذمْ ن ثمُّورْثْ.
\m 
\v 7 ؤُشَا إِكوّنْ سِيذِي أَربِّي أَذَامْ زِي ثْعجَّاجْثْ ن ؤُشَاڒْ ؤُشَا إِسُوضْ ڒعْوِينْ ن ثُوذَارْثْ ذڭْ ونْزَارنْ نّسْ. أَمُّو إِ إِذْوڒْ أَذَامْ ذ إِجّْ ن نّفْسْ إِدَّارْ. \x ◘ \xo 2:‏7 \xt 1 كُور. 15‏:‏45، 47.\x*
\m 
\v 8 خنِّي إِژُّو سِيذِي أَربِّي جّنّثْ ذِي عَاذْنْ، جِّيهثْ ن شَّارْقْ، ؤُشَا إِسَّارْسْ ذِينْ أَذَامْ إِ إِڭَّا. \f ◼ \fr 2:‏8 \ft \bd ’عَاذْنْ‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’مژْرِي‘. س ؤُينِّي ثُوغَا جّنّثْ عَاذْنْ ذ إِجّْ ن ومْشَانْ مَانِي إِزمَّارْ بْنَاذمْ أَذْ يَارّْ مژْرِي عْلَاحْسَابْ مِينْ إِخْسْ أَربِّي، وَارْ إِدْجِي عْلَاحْسَابْ مِينْ إِخْسْ بْنَاذمْ.\f*
\v 9 ؤُشَا إِسّغْمِي-د سِيذِي أَربِّي زِي ثمُّورْثْ كُوڒْ ثَاشجَّارْثْ، ثشْنَا إِ ڒْخژْرَاثْ ؤُ ثْمِيژِيذْثْ إِ مَاشَّا، ؤُشَا \add إِسّغْمِي-د ڒَا ذ\add* ثَاشجَّارْثْ ن ثُوذَارْثْ ذِي ڒْوسْطْ ن جّنّثْ ؤُڒَا ذ ثَاشجَّارْثْ ن ثُوسّْنَا ن ڒْخَارْ ذ ڒْغَارْ. \x ◘ \xo 2:‏9 \xt أَسَا. 2‏:‏7. \x*
\m 
\v 10 إِفّغْ-د إِجّْ ن إِغْزَارْ زِي عَاذْنْ، حِيمَا أَذْ إِسُّووْ جّنّثْ ؤُ سّنِّي إِمّْسبْضَا خْ أَربْعَا ن إِزدْجِيفنْ إِ إِڭِّينْ ثِيسدْجْيَاوِينْ.
\v 11 إِسمْ ن \add يغْزَارْ\add* أَمزْوَارُو ذ فِيشُونْ. نتَّا إِ إِنّْضنْ إِ مَارَّا ثَامُّورْثْ ن حَاوِيلَا مَانِي إِدْجَا وُورغْ.
\v 12 ؤُرغْ ن ثمُّورْثْ نِّي إِصْبحْ. أَقَا ذِينْ \add أَسرْغَاغْ أَشمْڒَاڒْ قَّارنْ أَسْ\add* ’بذُولَا‘، ذ وژْرُو ن ’ؤُنِيكْسْ‘.
\v 13 إِسمْ ن إِغْزَارْ وِيسّْ ثْنَاينْ ذ جِيحُونْ إِ ثُوغَا إِنّْضنْ إِ مَارَّا ثَامُّورْثْ ن كُوشْ.
\v 14 إِسمْ ن إِغْزَارْ وِيسّْ ثْڒَاثَا ذ حِيدَّاقِيلْ. نتَّا إِتَّازّڒْ غَارْ شَّارْقْ ن أَشُّورْ. ؤُ إِغْزَارْ وِيسّْ أَربْعَا ذ لْفُورَاطْ.
\m 
\v 15 إِكْسِي سِيذِي أَربِّي أَذَامْ ؤُشَا إِسَّارْسْ إِ-ث ذِي جّنّثْ ن عَاذْنْ، حِيمَا أَذْ ت إِخْذمْ ؤُ أَذْ ت إِحْضَا.
\v 16 سِيذِي أَربِّي إِوصَّا أَذَامْ، إِنَّا: ”زِي مَارَّا ثِيشجُّورَا ن جّنّثْ أَذْ ثشّذْ مَاشَّا،
\v 17 مَاشَا زِي ثْشجَّارْثْ ن ثُوسّْنَا ن ڒْخَارْ ذ ڒْغَارْ وَارْ تّتّذْ شَا زَّايسْ، مِينْزِي ذڭْ وَاسّْ إِ زَّايسْ غَا ثشّذْ، ڒْموْثْ إِ غَا ثمّْثذْ!“
\m 
\v 18 إِنَّا سِيذِي أَربِّي: ”وَارْ إِعدّڒْ أَذْ يِيڒِي أَذَامْ وحّْذسْ. أَذْ أَسْ ڭّغْ وِي ث غَا إِعَاوْننْ، أَمْ نتَّا قِيبَاتْشْ نّسْ.“
\m 
\v 19 ثُوغَا سِيذِي أَربِّي إِڭَّا زڭْ ؤُشَاڒْ مَارَّا ڒْمَاڒْ ن ڒخْڒَا ؤُ مَارَّا إِجْضَاضْ ن ؤُجنَّا، ؤُشَا إِنْذهْ إِ-ثنْ غَارْ أَذَامْ، حِيمَا أَذْ إِژَارْ مَامّشْ إِ ثنْ غَا إِسمَّا. مَامّشْ إِ غَا إِسمَّا أَذَامْ كُوڒْ نّفْسْ إِدَّارنْ ذ وَا ذ إِسمْ نّسْ.
\v 20 إِڭَّا أَذَامْ إِسْمَاونْ إِ مَارَّا ڒبْهَايمْ ذ يجْضَاضْ ن ؤُجنَّا ؤُ إِ مَارَّا ڒْمَاڒْ ن ڒخْڒَا، \add مَاشَا\add* إِ أَذَامْ وَارْ يُوفِي وِي ث غَا إِعَاوْننْ ذ وِي غَا يِيڒِينْ أَمْ نتَّا قِيبَاتْشْ نّسْ.
\m 
\v 21 إِسّهْوَا-د سِيذِي أَربِّي إِجّْ ن يِيضصْ يُودْجغْ خْ أَذَامْ ؤُشَا إِطّصْ. \add خنِّي\add* إِكْسِي إِشْثنْ زِي ثْغزْذِيسِينْ نّسْ ؤُشَا إِقّنْ \add أَمْشَانْ يَارزْمنْ\add* نِّي س ويْسُومْ.
\v 22 يَارَّا سِيذِي أَربِّي ثَاغزْذِيسْثْ ثنِّي إِ إِكْسِي زِي أَذَامْ ذ ثَامْغَارْثْ ؤُشَا يِيوْيِي ت-إِ-د غَارْ أَذَامْ. \x ◘ \xo 2:‏22 \xt 1 كُور. 11‏:‏8. \x*
\v 23 \add خنِّي\add* إِنَّا أَذَامْ: ”ثْوَاڒَا-يَا ثَانِيثَا أَقَا-ت ذ إِغسْ زڭْ إِغْسَانْ إِنُو ذ أَيْسُومْ زڭْ ويْسُومْ إِنُو. ثَانِيثَا أَذْ ثتّْوَاسمَّا ’ثَارْيَازْثْ‘، \add إِخْسْ أَذْ يِينِي ’ثَامْغَارْثْ‘\add*، مِينْزِي نتَّاثْ ثتّْوَاكْسِي-د زڭْ ورْيَازْ.“ \x ◘ \xo 2:‏23 \xt مـَال. 2‏:‏14؛ أَفا. 5‏:‏30، 31. \x*
\v 24 خْ ؤُيَا أَذْ إِسْمحْ ورْيَازْ ذِي بَابَاسْ ذ يمَّاسْ، أَذْ إِقّنْ غَارْ ثمْغَارْثْ نّسْ ؤُشَا أَذْ إِڒِينْ ذ إِشْثْ ن دَّاثْ. \f ◼ \fr 2:‏24 \ft \bd ’إِشْثْ ن دَّاثْ‘\bd* - س ثْعِيبْرَانِيثْ ’إِجّْ ن ويْسُومْ‘. أَوَاڒنْ خْسنْ أَذْ إِنِينْ بلِّي أَرْيَازْ ذ ثمْغَارْثْ نّسْ أَقَا-ثنْ ذ إِجّْ ن بْنَاذمْ. مَانْ أَيَا ذ تِّيذثْ س مِينْزِي حَاوَّا ثفّغْ زڭْ أَرِّيمثْ ن أَذَامْ س ؤُفُوسْ ن أَربِّي.\f*  \x ◘ \xo 2:‏24 \xt مت. 19‏:‏5، 6؛ مك. 10‏:‏8؛ أَفا. 5‏:‏31؛ 1 كُور. 6‏:‏16. \x*
\v 25 ثُوغَا-ثنْ س ثْنَاينْ إِذْسنْ ذ إِعَارْيَاننْ، أَذَامْ ذ ثمْغَارْثْ نّسْ، \add مَاشَا\add* ثُوغَا وَارْ ذِينْ شَا ن ڒحْيَا جَارْ أَسنْ. \x ◘ \xo 2:‏25 \xt أَمز. 3‏:‏7. \x*
\b
\b
\c 3
\s1 دّنْبْ أَمزْوَارُو
\m 
\v 1 ثُوغَا أَفِيغَارْ ذ أَحْرَايْمِي خْ مَارَّا ڒْمَاڒْ ن ڒخْڒَا إِ إِڭَّا سِيذِي أَربِّي. إِنَّا إِ ثمْغَارْثْ: ”مَا ذ ثِيذتّْ إِنَّا أَربِّي: ’غَارْومْ وَارْ تّتّمْ شَا زِي مَارَّا ثِيشجُّورَا ن جّنّثْ‘؟“
\v 2 ثنَّا ثمْغَارْثْ إِ ؤُفِيغَارْ: ”زِي ڒْغِيدْجثْ ن ثْشجُّورَا ن جّنّثْ نْزمَّارْ أَذْ نشّْ،
\v 3 مَاشَا زِي ڒْغِيدْجثْ ن ثْشجَّارْثْ ذِي ڒْوسْطْ ن جّنّثْ، إِنَّا أَربِّي: ’وَارْ زَّايسْ تّتّمْ، وَارْ ت تّْحَاذَامْ، حِيمَا وَارْ ثتّْمتِّيمْ.‘ “
\v 4 إِنَّا ؤُفِيغَارْ إِ ثمْغَارْثْ: ”كنِّيوْ وَارْ ثتّْمتِّيمْ شَا س ڒْموْثْ قَاعْ، \x ◘ \xo 3:‏4 \xt 2 كُور. 11‏:‏3. \x*
\v 5 \add مَاشَا\add* أَربِّي إِسّنْ بلِّي أَسّْ نِّي ذِي زَّايسْ إِ غَا ثشّمْ، أَذْ أَرْزْمنْثْ ثِيطَّاوِينْ نْومْ ؤُشَا أَذْ ثِيڒِيمْ أَمْ أَربِّي، أَذْ ثسّْنمْ ڒْخَارْ زِي ڒْغَارْ.“ \x ◘ \xo 3:‏5 \xt يُوح. 8‏:‏44. \x*
\m 
\v 6 ثژْرَا ثمْغَارْثْ بلِّي ثَاشجَّارْثْ ثصْبحْ إِ مَاشَّا ؤُشَا ثعْجبْ أَسنْثْ إِ ثِيطَّاوِينْ، أَقَا ثَاشجَّارْثْ ثڭَّا ذَايسْ مژْرِي مَاحنْذْ أَذْ زَّايسْ ثذْوڒْ ذ ثَامِيغِيسْثْ. خنِّي ثكْسِي زِي ڒْغِيدْجثْ نّسْ، ثشَّا ؤُشَا ثوْشَا عَاوذْ إِ ورْيَازْ نّسْ إِ ثُوغَا أَكِيذسْ، ؤُشَا نتَّا إِشَّا. \x ◘ \xo 3:‏6 \xt رُوم. 5‏:‏12، 14‏-‏21؛ 1 تِيم. 2‏:‏14. \x*
\v 7 نَّارْزْمنْثْ ثِيطَّاوِينْ نْسنْ ؤُشَا ؤُفِينْ إِخفْ نْسنْ ذ إِعَارْيَاننْ. خنِّي خيّْضنْ ثِيفْرَايْ ن وَارْثُو، ؤُشَا ڭِّينْ \add زَّايْسنْثْ\add* ثِيبَانْثِيوِينْ إِ يِيخفْ نْسنْ.
\v 8 \add خنِّي\add* سْڒِينْ نِيثْنِي ثْمِيجَّا ن سِيذِي أَربِّي إِڭُّورْ ذِي جّنّثْ غَارْ ؤُوطُّو ن ثْمذِّيثْ، ؤُشَا إِفَّارْ أَذَامْ ذ ثمْغَارْثْ نّسْ زڭْ وُوذمْ ن سِيذِي أَربِّي جَارْ ثْشجُّورَا ن جّنّثْ.
\m 
\v 9 ؤُشَا إِڒَاغَا سِيذِي أَربِّي أَذَامْ، إِنَّا أَسْ: ”مَانِي ثدْجِيذْ؟“
\v 10 نتَّا إِنَّا: ”سْڒِيغْ إِ ثْمِيجَّا نّشْ ذِي جّنّثْ ؤُشَا ڭّْوذغْ مِينْزِي نشّْ ذ أَعَارْيَانْ، خنِّي فَّارغْ.“ \f ◼ \fr 3:‏10 \ft \bd ’أَعَارْيَانْ‘\bd* - نِيغْ ’أَزعْپُوذْ‘.\f*
\v 11 إِنَّا \add أَسْ نتَّا\add*: ”وِي ذ أَشْ إِنَّانْ بلِّي شكْ ذ أَعَارْيَانْ؟ مَا ثشِّيذْ زِي ثْشجَّارْثْ نِّي خْ شكْ وصِّيغْ ’أَقَا أَذْ زَّايسْ ثشّذْ؟“
\v 12 إِنَّا أَذَامْ: ”ثَامْغَارْثْ نِّي ذ أَيِي ثوْشِيذْ، نتَّاثْ ثوْشَا أَيِي زِي ثْشجَّارْثْ ؤُشَا شِّيغْ.“
\v 13 إِنَّا أَسْ سِيذِي أَربِّي إِ ثمْغَارْثْ: ”مَانَاوْيَا إِ ثڭِّيذْ؟“ ثنَّا \add أَسْ\add* ثمْغَارْثْ: ”إِغَارَّا أَيِي ؤُفِيغَارْ ؤُشَا شِّيغْ.“ \x ◘ \xo 3:‏13 \xt أَسَا. 12‏:‏13. \x*
\b
\m 
\v 14 إِنَّا سِيذِي أَربِّي \bd إِ ؤُفِيغَارْ\bd*:
\m \qt ”ڒَْامِي ثڭِّيذْ أَيَا،\qt*
\m \qt أَقَا أَشْ ذ أَمنْعُوڒْ جَارْ مَارَّا ڒبْهَايمْ\qt*
\m \qt ؤُ جَارْ مَارَّا ڒْمَاڒْ ن ڒخْڒَا.\qt*
\m \qt خْ ؤُعذِّيسْ نّشْ أَذْ ثْمُورْذذْ،\qt*
\m \qt ؤُشَا أَذْ ثشّذْ ؤُشَاڒْ\qt*
\m \qt مَارَّا ؤُسَّانْ ن ثُوذَارْثْ نّشْ.\qt* \f ◼ \fr 3:‏14 \ft \bd ’ڒْمَاڒْ نْ ڒخْڒَا‘\bd* - مَارَّا ڒوْحُوشْ إِ إِدْجَانْ ذِي ڒخْڒَا، ذِي ذمْنثْ، ذِي ڒْغَابثْ (نِيغْ ذِي ثَاڭَانْثْ)، ذڭْ وزْغَارْ ؤُ ذِي صّحْرَا.\f*
\m 
\v 15 \qt أَذْ ڭّغْ ڒعْذَاوَاثْ جَارْ أَشْ ذ ثمْغَارْثْ،\qt*
\m \qt جَارْ زَّارِيعثْ نّشْ ذ زَّارِيعثْ نّسْ.\qt*
\m \qt ذ ثنِّي \tl نّسْ\tl* أَذْ ثڒْبزْ أَزدْجِيفْ نّشْ،\qt*
\m \qt ؤُ شكْ أَذْ أَسْ ثْڒبْزذْ أَنِيرْزْ \tl نّسْ\tl*.“\qt* \x ◘ \xo 3:‏15 \xt أَمز. 24‏:‏60؛ مت. 4‏:‏1؛ كُول. 2‏:‏15. \x*
\b
\m 
\v 16 إِنَّا \bd إِ ثمْغَارْثْ\bd*:
\m \qt ”أَطَّاسْ إِ غَا أَرْنِيغْ ڒحْرِيقْ ذ ڒوْجعْ ن ثَارْوَا نّمْ.\qt*
\m \qt س ڒحْرِيقْ أَذْ د-ثَارْوذْ إِحنْجِيرنْ،\qt*
\m \qt ؤُشَا غَارْ ورْيَازْ نّمْ أَذْ ثمّژْرذْ،\qt*
\m \qt \tl مَاشَا\tl* نتَّا أَذْ خَامْ إِحْكمْ.“\qt* \x ◘ \xo 3:‏16 \xt 1 كُور. 14‏:‏34؛ 1 تِيم. 2‏:‏11، 12؛ ثِيث. 2‏:‏5؛ 1 بُط. 3‏:‏6. \x*
\b
\m 
\v 17 ؤُشَا إِنَّا \bd إِ أَذَامْ\bd*:
\m \qt ”مِينْزِي ثسْڒِيذْ غَارْ ثْمِيجَّا ن ثمْغَارْثْ نّشْ\qt*
\m \qt ؤُ ثشِّيذْ زِي ثْشجَّارْثْ ثنِّي خْ شكْ وصِّيغْ:\qt*
\m \qt ’أَقَا أَذْ زَّايسْ ثشّذْ!‘،\qt*
\m \qt أَذْ ثِيڒِي ثمُّورْثْ ذ نّعْڒثْ خْ سِّيبّثْ نّشْ.\qt*
\m \qt س ثَامَارَا أَذْ زَّايسْ ثشّذْ،\qt*
\m \qt مَارَّا ؤُسَّانْ ن ثُوذَارْثْ نّشْ.\qt*
\m 
\v 18 \qt إِسنَّاننْ ذ ثْزڭّْوَارْثْ إِ ذ أَشْ د غَا ثسّغْمِي،\qt*
\m \qt ؤُشَا أَذْ ثشّذْ أَفْسُو ن ييَّارْ\qt*.
\m 
\v 19 \qt س ثِيذِي ن ؤُغمْبُوبْ نّشْ أَذْ ثشّذْ أَغْرُومْ\qt*
\m \qt أَڒْ د غَا ثْذوْڒذْ غَارْ ثمُّورْثْ إِ زِي ثمّكْسِيذْ،\qt*
\m \qt مِينْزِي شكْ ذ \tl أَ\tl*شَاڒْ ؤُشَا غَارْ ؤُشَاڒْ إِ غَا د-ثْذوْڒذْ.“\qt*
\b
\m 
\v 20 إِڒَاغَا أَذَامْ إِسمْ ن ثمْغَارْثْ نّسْ \bd حَاوَّا\bd* مِينْزِي نتَّاثْ ذ يمَّاسْ ن مَارَّا إِنِّي إِدَّارنْ. \f ◼ \fr 3:‏20 \ft \bd ’حَاوَّا‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’ثنِّي إِدَّارنْ‘ نِيغْ ’ثنِّي إِتِّيشنْ ثُوذَارْثْ‘.\f*
\v 21 إِڭَّا سِيذِي أَربِّي إِ أَذَامْ ذ ثمْغَارْثْ نّسْ أَرُّوضْ س يِيڒمْ ؤُشَا يَارْضْ أَسنْ ث. \x ◘ \xo 3:‏21 \xt 2 كُور. 5‏:‏1‏-‏5\x*
\v 22 إِنَّا سِيذِي أَربِّي: ”خْزَارْ، أَذَامْ وَا، أَقَا إِذْوڒْ أَمْ يِيجّنْ زَّايْنغْ، إِسّنْ ڒْخَارْ ذ ڒْغَارْ. ڒخُّو، أجّْ إِ-ث وَارْ إِسّْوَاژَّاضْ أَفُوسْ نّسْ مَاحنْذْ أَذْ إِكْسِي زِي ثْشجَّارْثْ ن ثُوذَارْثْ عَاوذْ، أَذْ يشّْ ؤُ \add خنِّي\add* أَذْ إِدَّارْ إِ ڒبْذَا.“
\v 23 ؤُشَا إِسُّوفُّوغْ إِ-ث سِيذِي أَربِّي زِي جّنّثْ ن عَاذْنْ حِيمَا أَذْ إِخْذمْ ثَامُّورْثْ إِ زِي ثُوغَا إِمّكْسِي.
\v 24 يُوژّڒْ خْ أَذَامْ ؤُشَا إِڭَّا إِكِيرُوبنْ شَّارْقْ إِ جّنّثْ ن عَاذْنْ ذ يِيجّْ ن سِّيفْ إِتّحْذُوذُوقْ، إِتّشْضِيضِيحْ سَّا ذ سَّا إِ ؤُعسِّي خْ وبْرِيذْ ن ثْشجَّارْثْ ن ثُوذَارْثْ. \f ◼ \fr 3:‏24 \ft \bd ’إِكِيرُوبنْ‘\bd* - إِشْثْ ن لْمَارْكَا ن لْمَالَاكَاثْ إِقدّْسنْ.\f*
\b
\b
\c 4
\s1 قَايِينْ ذ هَابِيلْ
\m 
\v 1 إِسّنْ أَذَامْ حَاوَّا، ثَامْغَارْثْ نّسْ، ؤُشَا ثيْسِي س دّيْسثْ ؤُشَا ثُورُووْ-د \bd قَايِينْ\bd*، ثنَّا ”جِّيغْ-د أَرْيَازْ، ذ سِيذِي!“ \f ◼ \fr 4:‏1 \ft \bd ’قَايِينْ‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَڭْڒَا‘ نِيغْ ’مِينْ إِتّْوَاكسّْبنْ‘.\f*
\v 2 \add خنِّي\add* عَاوذْ ثُورُووْ-د ؤُمَاسْ \bd هَابِيلْ\bd*. ثُوغَا هَابِيلْ ذ أَمكْسَاوْ ن وُودْجِي ؤُ قَايِينْ إِرُوحْ إِخدّمْ ثَامُّورْثْ. \f ◼ \fr 4:‏2 \ft \bd ’هَابِيلْ‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’ثَايُّوثْ‘ نِيغْ ’أَمذْلُو‘ نِيغْ ’ڒفْوَارْ‘ نِيغْ ’مِينْ إِعدُّونْ‘ نِيغْ ’مِينْ إِفنَّانْ‘. س ؤُينِّي إِذْوڒْ إِسمْ نّسْ ذ أَشيَّارْ غَارْ مِينْ ذ أَسْ إِ غَا إِمْسَارنْ ؤُمِي إِ ذ أَسْ إِنْغَا ؤُمَاسْ. أَذْ ثفْنَا ثُوذَارْثْ نّسْ ذغْيَا أَمْ إِشْثْ ن ثَايُّوثْ ثْعدُّو. \bd ’أَمكْسَاوْ‘\bd* - نِيغْ ’ذ‘.\f*
\m 
\v 3 ؤُشَا أَوَارْنِي ؤُسَّانْ إِمْسَارْ بلِّي قَايِينْ إِقدّمْ إِشْثْ ن ثوْهِيبْثْ زِي ڒْغِيدْجثْ ن وُوذمْ ن ثمُّورْثْ إِ سِيذِي.
\v 4 إِقدّمْ هَابِيلْ عَاوذْ \add إِشْثْ ن ثوْهِيبْثْ\add* زڭْ إِمنْزَا ن وُودْجِي نّسْ، زڭْ إِنِّي غَارْ إِدْجَا ثَاذُونْثْ أَطَّاسْ. إِخْزَارْ سِيذِي غَارْ هَابِيلْ ذ ثوْهِيبْثْ نّسْ، \x ◘ \xo 4:‏4 \xt عبر. 11‏:‏4. \x*
\v 5 \add مَاشَا\add* غَارْ قَايِينْ ذ ثوْهِيبْثْ نّسْ وَارْ ذ أَسْ يَارِّي شَا ثَايْنِيثْ. ؤُشَا إِخيّقْ قَايِينْ أَطَّاسْ، إِنّقْڒبْ أَسْ ؤُغمْبُوبْ.
\v 6 إِنَّا سِيذِي إِ قَايِينْ: ”مَايمِّي ثْخيّْقذْ؟ مَايمِّي ذ أَشْ إِنّقْڒبْ ؤُغمْبُوبْ؟
\v 7 مَاڒَا ثڭِّيذْ مْلِيحْ، مَا وَارْ \add ذِينْ\add* إِتِّيڒِي ؤُسْڭعّذْ، ؤُ مَاڒَا وَارْ ثڭِّيذْ مْلِيحْ، دّنْبْ أَقَا-ث إِزّڒْ غَارْ ثوَّارْثْ؟ مژْرِي نّسْ غَاركْ، \add مَاشَا\add* إِتّْخصَّا شكْ أَذْ خَاسْ ثْسدْجْضذْ.“
\v 8 إِسِّيوڒْ قَايِينْ أَكْ-ذ هَابِيلْ ؤُمَاسْ. ؤُشَا إِمْسَارْ أَمْ دْجَانْ نِيثْنِي ذڭْ إِيَّارْ، بلِّي قَايِينْ إِكَّارْ غَارْ ؤُمَاسْ هَابِيلْ ؤُشَا إِنْغَا إِ-ث. \x ◘ \xo 4:‏8 \xt مت. 23‏:‏35؛ 1 يُوح. 3‏:‏12؛ يَاه. 11. \x*
\m 
\v 9 \add خنِّي\add* إِنَّا سِيذِي إِ قَايِينْ: ”مَانِي إِدْجَا ؤُمَاشْ هَابِيلْ؟“ إِنَّا: ”وَارْ سِّينغْ. مَا نشّْ ذ أَمحْضَايْ خْ ؤُمَا؟“
\v 10 ؤُشَا إِنَّا نتَّا: ”مِينْ ثڭِّيذْ؟ أَقَا ثْمِيجَّا ن إِذَامّنْ ن ؤُمَاشْ سْغُويُّونْ-د غَارِي زِي ثمُّورْثْ. \x ◘ \xo 4:‏10 \xt عبر. 12‏:‏24. \x*
\v 11 ڒخُّو، أَقَا شكْ ذ منْعُوڒْ زِي ثمُّورْثْ، ثنِّي يَارزْمنْ أَقمُّومْ نّسْ، حِيمَا أَذْ ثقْبڒْ إِذَامّنْ ن ؤُمَاشْ زڭْ إِفَاسّنْ نّشْ.
\v 12 خْمِي غَا ثْخذْمذْ خْ ثمُّورْثْ، وَارْ تّذِيكّْوِيڒْ أَذْ أَشْ ثوْشْ مَارَّا جّهْذْ نّسْ ؤُشَا شكْ أَذْ ثِيڒِيذْ ذ أَمنّجْرُو ذ أَمثْلُوعْ ذِي ثمُّورْثْ.“ \x ◘ \xo 4:‏12 \xt أَوڒن. 28‏:‏17. \x*
\v 13 خنِّي إِنَّا قَايِينْ إِ سِيذِي: ”لْعِيقَابْ إِنُو إِمْغَارْ أَطَّاسْ خْ ثْزمَّارْ إِنُو.
\v 14 أَقَا شكْ أَسّْ\add -أَ\add* ثُوژّْڒذْ خَافِي زڭْ ؤُغمْبُوبْ ن ثمُّورْثْ\add -أَ\add* ؤُشَا زڭْ ؤُغمْبُوبْ نّشْ أَذْ تّْوَافَّار. أَذْ إِڒِيغْ ذ أَمنّجْرُو ذ أَمثْلُوعْ ذِي ثمُّورْثْ ؤُشَا أَذْ يِيڒِي مَارَّا ونِّي ذ أَيِي غَا يَافنْ أَذْ أَيِي إِنغْ.“ \x ◘ \xo 4:‏14 \xt أَيُوبْ 15‏:‏20، 21. \x*
\v 15 خنِّي إِنَّا أَسْ سِيذِي: ”س ؤُيَا مَارَّا ونِّي إِ غَا إِنْغنْ قَايِينْ، أَذْ زَّايسْ خڒْفنْ سبْعَا ن ثْوَاڒَاوِينْ.“ ؤُشَا إِڭَّا سِيذِي ڒعْڒَامثْ إِ قَايِينْ بلِّي مَارَّا ونِّي ث غَا يَافنْ وَارْ ث إِنقّْ.
\b
\s1 ثَارْوَا ن قَاينْ
\m 
\v 16 خنِّي إِفّغْ-د قَايِينْ زڭْ وُوذمْ ن سِيذِي ؤُشَا إِرُوحْ إِزدّغْ ذِي ثمُّورْثْ ن نُوذْ، شَّارْقْ ن عَاذْنْ. \f ◼ \fr 4:‏16 \ft \bd ’نُوذْ‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَثْلَاعْ‘ نِيغْ ’أَودَّارْ‘ نِيغْ ’ثَاروْڒَا‘ (خْزَارْ إِزهد. 56:9).\f*
\v 17 إِسّنْ قَايِينْ ثَامْغَارْثْ نّسْ ؤُشَا ثيْسِي س دّيْسثْ ؤُشَا ثُورُووْ أَسْ-د حَانُوخْ. ثُوغَا \add قَاينْ\add* إِبْنَا إِشْثْ ن ثنْذِينْثْ ؤُشَا إِڒَاغَا أَسْ إِ ثنْذِينْثْ أَمْ يِيسمْ ن مِّيسْ حَانُوخْ. \f ◼ \fr 4:‏17 \ft \bd ’حَانُوخْ‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’ونِّي إِتّْشطَّارنْ‘ نِيغْ ’ونِّي إِكمّْڒنْ‘. ثُوغَا حَانُوخْ ذ إِجّْ ن بْنَاذمْ س وُوڒْ إِكمّْڒنْ غَارْ أَربِّي.\f*
\v 18 حَانُوخْ إِجَّا-د عِيرَاذْ، ؤُ عِيرَاذْ إِجَّا-د محُويَائِيلْ ؤُ محُويَائِيلْ إِجَّا-د مَاتُوشَائِيلْ ؤُ مَاتُوشَائِيلْ إِجَّا-د لَامَاكْ. \f ◼ \fr 4:‏18 \ft \bd ’عِيرَاذْ‘\bd* - إِسمْ وَانِيثَا إِتّْقنَّانْ أَكْ-ذ ’عَارَاذْ‘ (خْزَارْ ڒخْڒ. 21:1). أَذْ ثَاغْ أَذْ يِيڒِي ڒْمعْنَا نّسْ ’عْزڒْ‘ نِيغْ ’أَرْوڒْ‘. إِنّغْنِي قَّارنْ أَقَا ذَايسْ ڒْمعْنَا ’أَمزْذُوغْ ن ثنْذِينْثْ‘. \bd ’محُويَائِيلْ‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’ونِّي إِتّْوَاوْثنْ زِي أَربِّي‘. \bd ’مَاتُوشَائِيلْ‘\bd* - أَذْ ثَاغْ أَذْ يِيڒِي ڒْمعْنَا ن يِيسمْ وَانِيثَا ’أَرْيَازْ ن أَربِّي‘ نِيغْ ’مِينْ إِعْنَا أَربِّي؟‘ إِنّغْنِي قَّارنْ أَقَا-ث ذ ’أَرْيَازْ ن ثَاژَادْجِيثْ‘. \bd ’لَامَاكْ‘\bd* - أَذْ ثَاغْ أَذْ يِيڒِي ڒْمعْنَا ن يِيسمْ-أَ ’ونِّي إِجهْذنْ‘.\f*
\v 19 إِمْڒشْ لَامَاكْ ثْنَاينْ ن ثمْغَارِينْ. إِشْثنْ قَّارنْ أَسْ عَاذَا، ثنّغْنِي قَّارنْ أَسْ صِيلَّا. \f ◼ \fr 4:‏19 \ft \bd ’عَاذَا‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’ثُونْڭرْ‘ نِيغْ ’أَژْرِي‘. ؤُڒَا ذ ثَامْغَارْثْ ن عِيسُو ڒَاغَانْ أَسْ س يِيسمْ-أَ (خْزَارْ أَمز. 36:2، 4 ؤُ أَمز. 26:34، 35). \bd ’صِيلَّا‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’ثِيڒِي‘.\f*
\v 20 ثُورُووْ-د عَاذَا يَابَالْ. نتَّا إِذْوڒْ ذ بَابَاثْسنْ إِ إِمزْذَاغْ ن إِقِيضَانْ ؤُ إِ إِمكْسَاونْ ن ڒبْهَايمْ. \f ◼ \fr 4:‏20 \ft \bd ’يَابَالْ‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’إِغْزَارْ‘ نِيغْ ’أَمَانْ إِتَّازّْڒنْ‘. \bd ’إِمكْسَاونْ‘\bd* - نِيغْ ’إِنِيتْشَانْ‘.\f*
\v 21 إِسمْ ن ؤُمَاسْ ثُوغَا ذ يُوبَالْ ونِّي ثُوغَا ذ بَابَاثْسنْ إِ مَارَّا إِنِّي إِتِّيرَارنْ ڒْڭَامْبْرِي ذ ثمْجَا. \f ◼ \fr 4:‏21 \ft \bd ’يُوبَالْ‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’يغْزَارْ‘ نِيغْ ’ثَامُّورْثْ يُوفّنْ‘.\f*
\v 22 صِيلَّا ثُورُووْ-د عَاوذْ ثُوبَالْ-قَايِينْ، أَمْزِيڒْ ن إِمْزِيڒنْ ن مَارَّا إِنِّي إِخدّْمنْ س نّْحَاسْ ذ وُوزَّاڒْ. ؤُتْشْمَاسْ ن ثُوبَالْ-قَايِينْ \add ثُوغَا\add* ذ نَاعْمَا. \f ◼ \fr 4:‏22 \ft \bd ’ثُوبَالْ-قَايِينْ‘\bd* - أَذْ ثَاغْ إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَمْزِيڒْ، مَاشَا ڒْمعْنَا وَارْ إِدْجِي إِثْوَاسّْننْ نِيشَانْ. \bd ’نَاعْمَا‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’إِعِيزّنْ‘ نِيغْ ’يَارْضَانْ‘.\f*
\m 
\v 23 إِنَّا لَامَاكْ إِ ثمْغَارِينْ نّسْ، عَاذَا ذ صِيلَّا: ”سْڒنْثْ إِ ثْمِيجَّا إِنُو، \add أَ\add* ثِيمْغَارِينْ ن لَامَاكْ! سْڒنْثْ غَارْ مِينْ غَا إِنِيغْ. أَقَا نْغِيغْ أَرْيَازْ إِ ؤُيزِّيمْ إِنُو ذ ؤُحنْجِيرْ إِ ؤُيذِّيمْ إِنُو!
\v 24 أَقَا أَذْ خڒْفنْ زِي قَايِينْ سبْعَا ن ثْوَاڒَاوِينْ، مَاشَا زِي لَامَاكْ سبْعَا ؤُ-سبْعِينْ ن ثْوَاڒَاوِينْ.“ \x ◘ \xo 4:‏24 \xt أَمز. 4‏:‏15. \x*
\b
\s1 أَخْڒَاقْ ن شِيثْ
\m 
\v 25 يُوذفْ أَذَامْ عَاوذْ خْ ثَامْغَارْثْ نّسْ ؤُشَا ثُورُووْ-د نتَّاثْ أَحنْجِيرْ. ثْڒَاغَا أَسْ \bd شِيثْ\bd*، مِينْزِي \add ثنَّا:\add* ”أَربِّي إِوْشَا أَيِي زَّارِيعثْ نّغْنِي ذڭْ ومْشَانْ ن هَابِيلْ، مِينْزِي قَايِينْ إِنْغَا إِ-ث.“ \f ◼ \fr 4:‏25 \ft \bd ’شِيثْ‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’ونِّي إِكسِّينْ أَمْشَانْ ن ونّغْنِي‘ نِيغْ ’ونِّي إِتّْوَاڭّنْ ذڭْ ومْشَانْ ن ونّغْنِي‘. مَانْ أَيَا إِخْسْ أَذْ يِينِي أَقَا أَربِّي إِوْشَا إِ حَاوَّا إِجّْ ن مِّيسْ ذڭْ ومْشَانْ ن هَابِيلْ.\f*
\v 26 ؤُڒَا إِ شِيثْ إِتّْوَاخْڒقْ-د ؤُسيْمِي، ؤُشَا إِڭَّا أَسْ \bd أَنُوشْ\bd*. ڒخْذنِّي إِبْذَا بْنَاذمْ س ؤُڒَاغِي خْ يِيسمْ ن سِيذِي.
\m \bd وَا ذ أَذْلِيسْ إِتّْوَانْضنْ ن إِمزْرُوينْ ن يِينِّي د-إِتّْوَاخڒْقنْ زِي أَذَامْ.\bd* \f ◼ \fr 4:‏26 \ft \bd ’أَنُوشْ‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’بْنَاذمْ‘ نِيغْ ’أَرْيَازْ‘.\f*
\b
\b
\c 5
\s1 ثَارْوَا ن أَذَامْ
\m 
\v 1 أَسّْ مِينْ ذِي إِڭَّا أَربِّي أَذَامْ، إِڭَّا إِ-ث ذِي صِّيفثْ ن أَربِّي. \x ◘ \xo 5:‏1 \xt [1 إِم. 1‏:‏1‏-‏27] — أَمز. 1‏:‏26؛ 9‏:‏6؛ 1 كُور. 11‏:‏7. \x*
\v 2 أَوْثمْ ذ ثوْثمْثْ إِخْڒقْ إِ-ثنْ-د. إِبَارْكْ إِ-ثنْ ؤُشَا إِڒَاغَا أَسنْ س يِيسمْ ’أَذَامْ‘، \add بْنَاذمْ\add*، ذڭْ وَاسّْ إِ ذِي ثنْ د-إِخْڒقْ. \f ◼ \fr 5:‏2 \ft \bd ’ذڭْ وَاسّْ إِ ذِي ثنْ إِخْڒقْ‘\bd* - س ثْعِيبْرَانِيثْ ’ذڭْ وَاسّْ إِ ذِي د-تّْوَاخڒْقنْ‘.\f*  \x ◘ \xo 5:‏2 \xt أَمز. 1‏:‏26؛ مت. 19‏:‏4؛ مك. 10‏:‏6. \x*
\m 
\v 3 أَوَارْنِي ڒَامِي إِدَّارْ \bd أَذَامْ\bd* مْيَا ؤُ-ثْڒَاثِينْ ن إِسڭّْوُوسَا، إِجَّا-د \add أَحنْجِيرْ\add* ذڭْ وَارْوَاسْ نّسْ ؤُ ذِي صِّيفثْ نّسْ ؤُشَا إِڒَاغَا أَسْ شِيثْ.
\v 4 أَوَارْنِي ڒَامِي د-إِجَّا شِيثْ، إِدَّارْ أَذَامْ \add عَاذْ\add* ثمْنْ-مْيَا ن إِسڭّْوُوسَا، إِجَّا-د إِحنْجِيرنْ ذ ثْحنْجِيرِينْ. \x ◘ \xo 5:‏4 \xt 1 إِم. 1‏:‏1. \x*
\v 5 أَمُّو إِ إِدَّارْ أَذَامْ ثسْعَا-مْيَا ؤُ-ثْڒَاثِينْ ن إِسڭّْوُوسَا ؤُشَا إِمُّوثْ.
\m 
\v 6 أَوَارْنِي ڒَامِي إِدَّارْ \bd شِيثْ\bd* مْيَا ؤُ-خمْسَا ن إِسڭّْوُوسَا، إِجَّا-د أَنُوشْ. \x ◘ \xo 5:‏6 \xt أَمز. 4‏:‏26. \x*
\v 7 أَوَارْنِي ڒَامِي د-إِجَّا أَنُوشْ، إِدَّارْ شِيثْ \add عَاذْ\add* ثمْنْ-مْيَا ؤُ-سبْعَا ن إِسڭّْوُوسَا، إِجَّا-د إِحنْجِيرنْ ذ ثْحنْجِيرِينْ.
\v 8 أَمُّو إِ إِدَّارْ شِيثْ ثسْعَا-مْيَا ؤُ-ثنْعَاشْ ن إِسڭّْوُوسَا ؤُشَا إِمُّوثْ.
\m 
\v 9 أَوَارْنِي ڒَامِي إِدَّارْ \bd أَنُوشْ\bd* ثسْعِينْ ن إِسڭّْوُوسَا، إِجَّا-د قِينَانْ. \f ◼ \fr 5:‏9 \ft \bd ’قِينَانْ‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَڭْڒَا‘ نِيغْ ’لْمُولْكْ‘ نِيغْ ’ڒْْعُوشّْ‘ نِيغْ ’ثَازذِّيغْثْ‘.\f*  \x ◘ \xo 5:‏9 \xt 1 إِم. 1‏:‏2. \x*
\v 10 أَوَارْنِي ڒَامِي د-إِجَّا قِينَانْ، إِدَّارْ أَنُوشْ \add عَاذْ\add* ثمْنْ-مْيَا ؤُ-خمّسْطَاشْ ن إِسڭّْوُوسَا، إِجَّا-د إِحنْجِيرنْ ذ ثْحنْجِيرِينْ.
\v 11 أَمُّو إِ إِدَّارْ أَنُوشْ ثسْعَا-مْيَا ؤُ-خمْسَا ن إِسڭّْوُوسَا ؤُشَا إِمُّوثْ.
\m 
\v 12 أَوَارْنِي ڒَامِي إِدَّارْ \bd قِينَانْ\bd* سبْعِينْ ن إِسڭّْوُوسَا، إِجَّا-د مَاهَالَالْ-إِلْ. \f ◼ \fr 5:‏12 \ft \bd ’مَاهَالَالْ-إِلْ‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَسمْغَارْ زِي أَربِّي‘.\f*
\v 13 أَوَارْنِي ڒَامِي د-إِجَّا مَاهَالَالْ-إِلْ، إِدَّارْ قِينَانْ \add عَاذْ\add* ثمْنْ-مْيَا ؤُ-ربْعِينْ ن إِسڭّْوُوسَا، إِجَّا-د إِحنْجِيرنْ ذ ثْحنْجِيرِينْ.
\v 14 أَمُّو إِ إِدَّارْ قِينَانْ ثسْعَا-مْيَا ؤُ -عشْرَا ن إِسڭّْوُوسَا ؤُشَا إِمُّوثْ.
\m 
\v 15 أَوَارْنِي ڒَامِي إِدَّارْ \bd مَاهَالَالْ-إِلْ\bd* خمْسَا ؤُ-ستِّينْ ن إِسڭّْوُوسَا، إِجَّا-د يَارَاذْ. \f ◼ \fr 5:‏15 \ft \bd ’يَارَاذْ‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِّي ’إِجّنْ ونِّي إِ د-إِقَارّْسنْ زِي‘.\f*
\v 16 أَوَارْنِي ڒَامِي د-إِجَّا يَارَاذْ، إِدَّارْ مَاهَالَالْ-إِلْ \add عَاذْ\add* ثمْنْ-مْيَا ؤُ-ثْڒَاثِينْ ن إِسڭّْوُوسَا، إِجَّا-د إِحنْجِيرنْ ذ ثْحنْجِيرِينْ.
\v 17 أَمُّو إِ إِدَّارْ مَاهَالَالْ-إِلْ ثمْنْ-مْيَا ؤُ-خمْسَا ؤُ-ثسْعِينْ ن إِسڭّْوُوسَا ؤُشَا إِمُّوثْ.
\m 
\v 18 أَوَارْنِي ڒَامِي إِدَّارْ \bd يَارَاذْ\bd* مْيَا ؤُ-ثْنَاينْ ؤُ-ستِّينْ ن إِسڭّْوُوسَا، إِجَّا-د حَانُوخْ. \f ◼ \fr 5:‏18 \ft \bd ’حَانُوخْ‘\bd* - خْزَارْ أَمز. 4:17.\f*  \x ◘ \xo 5:‏18 \xt 1 إِم. 1‏:‏3. \x*
\v 19 أَوَارْنِي ڒَامِي د-إِجَّا حَانُوخْ، إِدَّارْ يَارَاذْ \add عَاذْ\add* ثمْنْ-مْيَا ن إِسڭّْوُوسَا، إِجَّا-د إِحنْجِيرنْ ذ ثْحنْجِيرِينْ.
\v 20 أَمُّو إِ إِدَّارْ يَارَاذْ ثسْعَا-مْيَا ؤُ-ثْنَاينْ ؤُ-ستِّينْ ن إِسڭّْوُوسَا ؤُشَا إِمُّوثْ.
\m 
\v 21 أَوَارْنِي ڒَامِي إِدَّارْ \bd حَانُوخْ\bd* خمْسَا ؤُ-ستِّينْ ن إِسڭّْوُوسَا، إِجَّا-د مَاثُوشَالَاحْ. \f ◼ \fr 5:‏21 \ft \bd ’مَاثُوشَالَاحْ‘\bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَرْيَازْ س فْڒِيثْشَا‘ نِيغْ ’ونِّي د-إِتّْوَاسّكّنْ‘ نِيغْ ’أَرْيَازْ ونِّي غَارْ إِدْجْ إِشْثْ ن ؤُرقَّاسْ نِيغْ إِشْثْ ن ثَابْرَاثْ‘.\f*  \x ◘ \xo 5:‏21 \xt يَاه. 14.\x*
\v 22 أَوَارْنِي ڒَامِي د-إِجَّا مَاثُوشَالَاحْ، يُويُورْ حَانُوخْ أَكْ-ذ أَربِّي ثڒْثْ-مْيَا ن إِسڭّْوُوسَا، إِجَّا-د إِحنْجِيرنْ ذ ثْحنْجِيرِينْ. \x ◘ \xo 5:‏22 \xt عبر. 11‏:‏5. \x*
\v 23 أَمُّو إِ إِدَّارْ حَانُوخْ ثڒْثْ-مْيَا ؤُ-خمْسَا ؤُ-ستِّينْ ن إِسڭّْوُوسَا.
\v 24 يُويُورْ حَانُوخْ أَكْ-ذ أَربِّي ؤُشَا وَارْ إِتّْوِيفْ عَاذْ مِينْزِي أَربِّي إِكْسِي إِ-ث. \x ◘ \xo 5:‏24 \xt عبر. 11‏:‏5. \x*
\m 
\v 25 أَوَارْنِي ڒَامِي إِدَّارْ \bd مَاثُوشَالَاحْ\bd* مْيَا ؤُ-سبْعَا ؤُ-ثْمَانْيِينْ ن إِسڭّْوُوسَا، إِجَّا-د لَامَاكْ. \f ◼ \fr 5:‏25 \ft \bd ’لَامَاكْ‘\bd* - أَذْ ثَاغْ إِخْسْ أَذْ يِينِي إِسمْ-أَ ’ونِّي إِجهْذنْ‘ نِيغْ ’أَمْوَاضعْ‘.\f*
\v 26 أَوَارْنِي ڒَامِي د-إِجَّا لَامَاكْ، إِدَّارْ مَاثُوشَالَاحْ \add عَاذْ\add* سبْعَا-مْيَا ؤُ-ثْنَاينْ ؤُ-ثْمَانْيِينْ ن إِسڭّْوُوسَا، إِجَّا-د إِحنْجِيرنْ ذ ثْحنْجِيرِينْ.
\v 27 أَمُّو إِ إِدَّارْ مَاثُوشَالَاحْ ثسْعَا-مْيَا ؤُ-ثسْعَا ؤُ-ستِّينْ ن إِسڭّْوُوسَا ؤُشَا إِمُّوثْ.
\m 
\v 28 أَوَارْنِي ڒَامِي إِدَّارْ \bd لَامَاكْ\bd* مْيَا ؤُ-ثْنَاينْ ؤُ-ثْمَانْيِينْ ن إِسڭّْوُوسَا، إِجَّا-د إِجّْ ن ؤُحنْجِيرْ.
\v 29 إِڒَاغَا إِسمْ نّسْ نُوحْ، إِنَّا: ”وَا أَذْ أَنغْ إِسّْفوّجْ خْ ڒْخذْمثْ نّغْ ذ ثَامَارَا ن إِفَاسّنْ نّغْ، مِينْزِي سِيذِي أَقَا إِنْعڒْ ثَامُّورْثْ!“ \f ◼ \fr 5:‏29 \ft \bd ’نُوحْ‘\bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَفوّجْ‘.\f*
\v 30 أَوَارْنِي ڒَامِي د-إِجَّا نُوحْ، إِدَّارْ لَامَاكْ \add عَاذْ\add* خمْسَا-مْيَا ؤُ-خمْسَا ؤُ-ثسْعِينْ ن إِسڭّْوُوسَا، إِجَّا-د إِحنْجِيرنْ ذ ثْحنْجِيرِينْ.
\v 31 أَمُّو إِ إِدَّارْ لَامَاكْ سبْعَا-مْيَا ؤُ-سبْعَا ؤُ-سبْعِينْ ن إِسڭّْوُوسَا ؤُشَا إِمُّوثْ.
\m 
\v 32 أَوَارْنِي ڒَامِي إِدَّارْ \bd نُوحْ\bd* خمْسَا-مْيَا ن إِسڭّْوُوسَا، نُوحْ إِجَّا-د شَامْ ذ حَامْ ذ يَافَاثْ.
\b
\b
\c 6
\s1 ثُوعفّْنَا ن إِوْذَانْ
\m 
\v 1 ڒَامِي بْذَانْ إِوْذَانْ أَذْ كْثَارنْ ذِي ثمُّورْثْ ؤُشَا ؤُرْونْثْ أَسنْ-د يسِّيثْسنْ، \f ◼ \fr 6:‏1 \ft \bd ’إِوْذَانْ‘\bd* - س ثْعِيبْرَانِيثْ ’بْنَاذمْ‘، ؤُڒَا ذِي أَيثْ وِيسّْ 2.\f*
\v 2 أَقَا ژْرِينْ أَرَّاونْ ن أَربِّي بلِّي يسِّيسْ ن بْنَاذمْ شْنَانْثْ، ؤُشَا كْسِينْ ثِيمْغَارِينْ إِ يِيخفْ نْسنْ زِي مَارَّا ثِينِّي إِخْضَارنْ نِيثْنِي. \f ◼ \fr 6:‏2 \ft \bd ’أَرَّاونْ ن أَربِّي‘\bd* - مَانْ أَيَا إِخْسْ أَذْ يِينِي ’لْمَالَاكَاثْ‘. خْزَارْ أَيُوبْ 1:6؛ 2:1، 38:7. مَاشَا لْمَالَاكَاثْ وَارْ زمَّارنْثْ أَذْ أَذْفنْثْ خْ يسِّيسْ ن بْنَاذمْ، مَاشَا أَذْ ثَاغْ س ثْسحَّارْثْ نْسنْثْ ؤُ ؤُمِي بْذَانْثْ أَذْ زذْغنْ ذڭْ إِرْيَازنْ ذ ثمْغَارِينْ (أَمْ جّْنُونْ) ڭِّينْ زَّايْسنْ أَرَّاونْ نِّي إِڭِّينْ أَخْمِي ’جّْوَاهڒْ‘. جّْوَاهڒْ نِّي سّْفسْذنْ جِّيڒْ ن بْنَاذمْ ؤُڒَا ذ زَّارِيعثْ ن ثمْغَارْثْ إِ زِي إِوَاعْذْ سِيذِي أَربِّي أَمْسنْجمْ نّسْ، لْمَاسِيحْ (خْزَارْ أَمز. 3:15). س ؤُينِّي ثُوغَا إِتّْخصَّا إِ سِيذِي أَربِّي حِيمَا أَذْ إِحْكمْ خْ دُّونشْثْ مَارَّا، أَڒَامِي إِڭَّا طُّوفَانْ أَذْ د-يَاسْ خْ ثمُّورْثْ. مْغِيرْ نُوحْ إِ إِقِّيمنْ إِدَّارْ أَكْ-ذ ثْوَاشُونْثْ نّسْ. سِيذِي أَربِّي إِحبّسْ ؤُڒَا ذ لْمَالَاكَاثْ نِّي إِڭِّينْ أَيَا (خْزَارْ 1 بُط. 3:19، 20، 2 بُط. 2:4 ؤُ يَاه. 6، 7).\f*  \x ◘ \xo 6:‏2 \xt 2 بُط. 2‏:‏4؛ Judas 1‏:‏6، 7\x*
\v 3 \add خنِّي\add* إِنَّا سِيذِي: ”وَارْ إِتّْغِيمِي أَرُّوحْ إِنُو ڒبْذَا ذِي بْنَاذمْ، أَقَا-ث ذ دَّاثْ زِي سِّيبّثْ ن ؤُودَّارْ نّسْ. أَذْ إِڒِينْ وُوسَّانْ \add ن ثُوذَارْثْ\add* نّسْ مْيَا ؤُ-عِيشْرِينْ ن إِسڭّْوُوسَا.“ \f ◼ \fr 6:‏3 \ft \bd ’نّسْ‘\bd* - س ثْعِيبْرَانِيثْ ’نْسنْ‘.\f*
\m 
\v 4 ذڭْ وُوسَّانْ نِّي ثُوغَا ’إِنِيفِيلِيمْ‘، \add إِخْسْ أَذْ يِينِي ’إِنِّي إِوْضَانْ‘\add*، ذِي ثمُّورْثْ ؤُشَا أَوَارْنِي مَانْ أَيَا عَاوذْ، ؤُمِي د-ؤُذْفنْ أَرَّاوْ ن أَربِّي غَارْ يسِّيسْ ن إِوْذَانْ ؤُشَا ؤُرْونْثْ أَسنْ-د. نِيثْنِي ذ ’جّْوَاهڒْ‘ ن زّْمَانْ نِّي، ذ إِرْيَازنْ س يِيسمْ. \f ◼ \fr 6:‏4 \ft \bd ’إِنِيفِيلِيمْ‘\bd* - س ثْعِيبْرَانِيثْ إِنَا ذ ’إِنِّي إِوْضَانْ‘. نسّنْ أَقَا-ثنْ ذ إِوْذَانْ إِمْغَارنْ أَطَّاسْ مَاغَارْ نُوفَا أَوَاڒْ-أَ ؤُڒَا ذڭْ وذْلِيسْ إِقدّْسنْ ذِي ڒشْثَابْ ’ذِي ڒخْڒَا‘ 13:33. س ؤُينِّي نسّنْ أَقَا إِسمْ وَانِيثَا إِشيَّارْ غَارْ ’جّْوَاهڒْ‘.\f*
\v 5 إِژْرَا سِيذِي بلِّي ڒْغَارْ ن بْنَاذمْ ذ أَطَّاسْ خْ ثمُّورْثْ ؤُشَا مَارَّا ڒمْوَايَاڒْ ن ؤُخَارّصْ ن وُوڒْ نّسْ ذ أَعفَّانْ كُوڒْ أَسّْ. \x ◘ \xo 6:‏5 \xt أَمز. 8‏:‏21؛ أَيُوبْ 15‏:‏16؛ أَوڒن. 6‏:‏14؛ إِرْم. 17‏:‏9؛ مت. 15‏:‏19؛ رُوم. 3‏:‏10، 11، 12؛ 8‏:‏6. \x*
\v 6 ؤُشَا إِنْذمْ سِيذِي ؤُمِي إِڭَّا بْنَاذمْ ذِي ثمُّورْثْ ؤُشَا إِقّسْ أَسْ وُوڒْ نّسْ.
\v 7 إِنَّا سِيذِي: ”أَذْ مْحِيغْ خْ وُوذمْ ن ثمُّورْثْ بْنَاذمْ إِ د-خڒْقغْ، بْنَاذمْ أَكْ-ذ ڒبْهَايمْ ذ \add إِمُودَّارنْ\add* إِتّْبُوعنْ ؤُڒَا ذ إِجْضَاضْ ن ؤُجنَّا، مِينْزِي نذْمغْ ؤُمِي ثنْ ڭِّيغْ.“
\v 8 \add مَاشَا\add* نُوحْ يُوفَا أَرْضَا ذِي ثِيطَّاوِينْ ن سِيذِي.
\m \bd إِنَا ذ إِمزْرُوينْ ن يِينِّي د-إِتّْوَاخڒْقنْ زِي نُوحْ.\bd*
\b
\s1 نُوحْ ذ طُّوفَانْ
\m 
\v 9 ثُوغَا نُوحْ ذ أَرْيَازْ ذ أَمْسڭّذْ إِكْمڒْ جَارْ مَارَّا جِّيڒَاثْ نِّي إِدَّارنْ أَكِيذسْ. يُويُورْ نُوحْ أَكْ-ذ أَربِّي. \x ◘ \xo 6:‏9 \xt أَمز. 5‏:‏22. \x*
\v 10 ؤُشَا إِجَّا-د نُوحْ ثْڒَاثَا ن إِحنْجِيرنْ: شَامْ ذ حَامْ ذ يَافَاثْ. \f ◼ \fr 6:‏10 \ft \bd ’شَامْ‘\bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’إِسمْ‘. \bd ’حَامْ‘\bd* - إِخْسْ أَذْ يِينِي ’إِڭْوَا‘ نِيغْ ’إِحْمَا‘. \bd ’يَافَاثْ‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’ونِّي إِتّْوَازدْجعْ أَطَّاسْ‘ نِيغْ ’إِنُّورزْمنْ‘.\f*
\v 11 ثُوغَا ثَامُّورْثْ ذ إِشْثْ ن ڒْخَارْبثْ ذِي ثِيطَّاوِينْ ن أَربِّي ؤُ ثُوغَا ثَامُّورْثْ ثشُّورْ س لْعُونْفْ.
\v 12 إِخْزَارْ أَربِّي غَارْ ثمُّورْثْ، ؤُ خْزَارْ، أَقَا-ت ذ ڒْخَارْبثْ، مَاغَارْ مَارَّا إِمدَّارنْ س أَرِّيمثْ ن ويْسُومْ ثُوغَا خَارّْبنْ أَبْرِيذْ نْسنْ خْ ثمُّورْثْ.
\m 
\v 13 إِنَّا أَربِّي إِ نُوحْ: ”أَنڭَّارْ ن مَارَّا إِمدَّارنْ س أَرِّيمثْ ن ويْسُومْ أَقَا-ث زَّاثْ إِ وُوذمْ إِنُو، مِينْزِي ثَامُّورْثْ ثشُّورْ س لْعُونْفْ زَّايْسنْ. أَقَا أَذْ ثنْ ثحِّيغْ أَكْ-ذ ثمُّورْثْ.
\v 14 أڭّْ إِ يِيخفْ نّشْ إِجّْ ن ؤُغَارَّابُو س ؤُكشُّوضْ ن ؤُمرْزِي ؤُشَا أڭّْ إِخَّامنْ \add إِ مَارَّا ڒْمَاڒْ\add* ذڭْ ؤُغَارَّابُو. غدْجفْ أَغَارَّابُو زِي ذَاخڒْ ؤُ زِي بَارَّا س ثِيزفْثْ. \f ◼ \fr 6:‏14 \ft \bd ’ثِيزفْثْ‘\bd* - أَوَاڒْ ’ثِيزفْثْ‘ ذِي ثْعِيبْرَانِيثْ ذَايسْ ڒمْعَانِي. إِزمَّارْ أَذْ يِينِي ’أَفذِّي‘ نِيغْ ’تَّامَانْ ن ؤُفذِّي‘. خْژَارْ ؤُف. 21:30 ؤُ ڒخْڒ. 35:32. س ؤُينِّي مَاڒَا إِتّْوَافْذِي إِجّْ بْنَاذمْ أَقَا مَانْ أَيَا إِخْسْ أَذْ يِينِي بلِّي ؤُڒَا ذ دّْنُوبْ نّسْ أَذْ إِڒِينْ تّْوَاغمْسنْ.\f*
\v 15 أَمُّو إِتّْخصَّا أَذْ ث ثڭّذْ: ثُوزّڭَّارْثْ ن ؤُغَارَّابُو \add أَذْ ثِيڒِي\add* ثڒْثْ-مْيَا ن إِغَادْجنْ ؤُ ثِيرُو ن ؤُغَارَّابُو \add أَذْ ثِيڒِي\add* خمْسِينْ ن إِغَادْجنْ ؤُ ڒُوعْڒَا نّسْ \add أَذْ يِيڒِي\add* ثْڒَاثِينْ ن إِغَادْجنْ. \f ◼ \fr 6:‏15 \ft \bd ’إِغَادْجنْ‘\bd* - إِجّْ ن ؤُغِيڒْ عْڒَاينْ 50 شْمْ نِيغْ أَزْينْ ن مِيثْرُو.\f*
\v 16 إِتّْخصَّا أَذْ ثڭّذْ إِشْثْ ن ثْبُورْجثْ إِ ثْفَاوْثْ ذڭْ ؤُغَارَّابُو ؤُشَا أَذْ ت ثْكمّْڒذْ أَنشْثْ ن إِجّْ ن ؤُغِيڒْ زِي سنّجْ. أَذْ ثڭّذْ ثَاوَّارْثْ ن ؤُغَارَّابُو ذڭْ ؤُغزْذِيسْ نّسْ. أَذْ ثڭّذْ طّبْقثْ ن وَادَّايْ ذ طّبْقثْ وِيسّْ ثْنَاينْ \add ذِي ڒْوسْطْ\add* ذ طّبْقثْ وِيسّْ ثْڒَاثَا \add سنّجْ\add*.
\v 17 أَقَا نشّْ أَذْ سّكّغْ سّحْڒثْ ن وَامَانْ خْ ثمُّورْثْ، حِيمَا أَذْ ثحِّيغْ سَاذُو ؤُجنَّا مَارَّا إِمدَّارنْ س أَرِّيمثْ ن ويْسُومْ إِ ذِي إِدْجَا أَرُّوحْ ن ثُوذَارْثْ. مَارَّا مِينْ إِدْجَانْ ذِي ثمُّورْثْ أَذْ إِضْڒقْ إِ بُوحْبڒْ.
\v 18 \add مَاشَا\add* أَذْ سّْبدّغْ ڒْعَاهْذْ إِنُو أَكِيذكْ ؤُشَا شكْ أَذْ ثَاذْفذْ غَارْ ؤُغَارَّابُو، شكْ ذ إِحنْجِيرنْ نّشْ ذ ثمْغَارْثْ نّشْ ذ ثمْغَارِينْ ن إِحنْجِيرنْ نّشْ أَكِيذكْ. \x ◘ \xo 6:‏18 \xt 1 بُط. 3‏:‏20؛ 2 بُط. 2‏:‏5. \x*
\v 19 ؤُشَا زِي مَارَّا مِينْ إِدَّارنْ، زِي مَارَّا إِمدَّارنْ س أَرِّيمثْ ن ويْسُومْ أَذْ ثسِّيذْفذْ ثْيُويَا، غَارْ ؤُغَارَّابُو حِيمَا أَذْ دَّارنْ أَكِيذكْ: إِتّْخصَّا أَذْ يِيڒِي ذ أَوْثمْ ذ ثوْثمْثْ.
\v 20 أَذْ غَاركْ د-ثَاسْ ثْيُويَا زِي مَارَّا، حِيمَا أَذْ ثحْضِيذْ ثُوذَارْثْ نْسنْ: زڭْ إِجْضَاضْ عْلَاحْسَابْ مَارْكَاثْ نْسنْ، زِي ڒبْهَايمْ عْلَاحْسَابْ مَارْكَاثْ نْسنْثْ ؤُ زِي مَارَّا \add إِمُودَّارنْ\add* نِّي إِتّْبُوعنْ خْ ثمُّورْثْ عْلَاحْسَابْ مَارْكَاثْ نْسنْ.
\v 21 ؤُشَا شكْ، كْسِي إِ يِيخفْ نّشْ زِي مَارَّا مَاشَّا إِ إِتّْوَاشَّانْ ؤُشَا سْمُونْ إِ-ت غَاركْ، حِيمَا أَذْ أَشْ يِيڒِي ذ مَاشَّا ؤُشَا ؤُڒَا إِ نِيثْنِي.“
\v 22 ؤُشَا إِڭَّا نُوحْ أَمْ مَامّشْ مَارَّا إِ خفْ ث إِوصَّا أَربِّي، أَمُّو إِ \add ث\add* إِڭَّا. \x ◘ \xo 6:‏22 \xt أَمز. 7‏:‏5؛ عبر. 11‏:‏7. \x*
\b
\b
\c 7
\m 
\v 1 إِنَّا سِيذِي إِ نُوحْ: ”أَذفْ شكْ ذ مَارَّا \add ڒَْادْجْ ن\add* ثَادَّارْثْ نّشْ غَارْ ؤُغَارَّابُو، مِينْزِي ژْرِيغْ شكْ ذ أَمْسڭّذْ زَّاثْ إِ وُوذمْ إِنُو ذِي جِّيڒْ-أَ. \x ◘ \xo 7:‏1 \xt أَمز. 6‏:‏9؛ 2 بُط. 2‏:‏5. \x*
\v 2 زِي مَارَّا ڒبْهَايمْ ن ڒحْڒَاڒْ أَذْ غَاركْ ثكْسِيذْ سبْعَا، سبْعَا، أَوْثمْ ذ ثوْثمْثْ نّسْ، ؤُ زِي ڒبْهَايمْ ن ڒحْرَامْ ثْيُويَا، أَوْثمْ ذ ثوْثمْثْ نّسْ. \x ◘ \xo 7:‏2 \xt لَاوِي 11. \x*
\v 3 ؤُڒَا زڭْ إِجْضَاضْ ن ؤُجنَّا إِتّْخصَّا أَذْ ثكْسِيذْ سبْعَا ن ثِييُويَاوِينْ، أَوْثمْ ذ ثوْثمْثْ، حِيمَا أَذْ ثحْضِيذْ زَّارِيعثْ \add نْسنْ\add* إِ ثُوذَارْثْ ذِي مَارَّا ثَامُّورْثْ،
\v 4 مِينْزِي خْمِي غَا عْذُونْ عَاذْ سبْعَا ن وُوسَّانْ نشّْ أَذْ جّغْ أَنْژَارْ أَذْ إِوّثْ خْ ثمُّورْثْ أَربْعِينْ ن وُوسَّانْ ذ أَربْعِينْ ن دْجْيَاڒِي، ؤُشَا أَذْ ثحِّيغْ زڭْ وُوذمْ ن ثمُّورْثْ مَارَّا مِينْ إِدْجَانْ، ذ مِينْ ڭِّيغْ نشّْ.“
\v 5 ؤُشَا إِڭَّا نُوحْ أَمْ مَامّشْ كُوڒْشِي إِ خفْ ث إِوصَّا سِيذِي. \x ◘ \xo 7:‏5 \xt أَمز. 6‏:‏22. \x*
\m 
\v 6 ثُوغَا نُوحْ ذ مِّيسْ ن ستَّا-مْيَا ن إِسڭّْوُوسَا ڒَامِي د-ثُوسَا سّحْڒثْ ن وَامَانْ خْ ثمُّورْثْ.
\v 7 ؤُشَا يُوذفْ نُوحْ غَارْ ؤُغَارَّابُو ذِي سِّيبّثْ ن وَامَانْ ن سّحْڒثْ، \add نتَّا ذ\add* إِحنْجِيرنْ نّسْ ذ ثمْغَارْثْ نّسْ ذ ثمْغَارِينْ ن إِحنْجِيرنْ نّسْ أَكِيذسْ. \x ◘ \xo 7:‏7 \xt مت. 24‏:‏38؛ لك. 17‏:‏27؛ 1 بُط. 3‏:‏20. \x*
\v 8 زِي ڒبْهَايمْ ن ڒحْڒَاڒْ ؤُ زِي ڒبْهَايمْ ن ڒحْرَامْ ؤُ زڭْ إِجْضَاضْ ؤُ زِي مَارَّا مِينْ إِتّْبُوعنْ خْ \add وُوذمْ ن\add* ثمُّورْثْ
\v 9 ثُوذفْ ثْيُويَا س ثْيُويَا غَارْ نُوحْ غَارْ ؤُغَارَّابُو، أَوْثمْ ذ ثوْثمْثْ أَمْ مَامّشْ إِوصَّا أَربِّي إِ نُوحْ.
\m 
\v 10 أَوَارْنِي سبْعَا ن وُوسَّانْ إِمْسَارْ بلِّي أَمَانْ ن سّحْڒثْ ؤُسِينْ-د خْ ثمُّورْثْ.
\v 11 ذڭْ ؤُسڭّْوَاسْ وِيسّْ ستَّا-مْيَا زِي ثُوذَارْثْ ن نُوحْ، ذڭْ ؤُيُورْ وِيسّْ ثْنَاينْ، ذڭْ وَاسّْ وِيسّْ سْبعْطَاشْ ن ؤُيُورْ \add نِّي\add*، ذڭْ وَاسّْ-أَ نِّيثْ، ثُوغَا سّفْينْ-د مَارَّا ڒْعُونْصَارَاثْ ن \add وَامَانْ\add* إِهوْڒنْ ؤُشَا تّْوَارزْمنْثْ ثْبُورْجَاثِينْ ن ؤُجنَّا.
\v 12 ثُوغَا أَنْژَارْ إِقِّيمْ إِشَّاثْ س جّهْذْ خْ ثمُّورْثْ أَربْعِينْ ن وُوسَّانْ ذ أَربْعِينْ ن دْجْيَاڒِي.
\m 
\v 13 ذڭْ وَاسّْ نِّي \add نِّيثْ\add* ثُوغَا نُوحْ يُوذفْ غَارْ ؤُغَارَّابُو أَكْ-ذ شَامْ ذ حَامْ ذ يَافَاثْ، أَيْثْ ن نُوحْ، ؤُڒَا أَكْ-ذ ثَامْغَارْثْ ن نُوحْ ؤُ أَكْ-ذ ثْڒَاثَا ن ثمْغَارِينْ ن إِحنْجِيرنْ نّسْ أَكِيذْسنْ،
\v 14 نِيثْنِي ذ مَارَّا مَارْكَاثْ ن ڒْمَاڒْ \add ن ڒخْڒَا\add* ذ مَارَّا مَارْكَاثْ ن ڒبْهَايمْ ذ مَارَّا مَارْكَاثْ ن \add إِمُودَّارنْ\add* نِّي إِتّْبُوعنْ خْ ثمُّورْثْ ذ مَارَّا مَارْكَاثْ ن إِجْضَاضْ، مَارَّا أَجْضِيضْ، ذ مَارَّا \add مِينْ غَارْ إِدْجَا\add* أَفْرِيونْ.
\v 15 زِي مَارَّا إِمدَّارنْ س أَرِّيمثْ ن ويْسُومْ إِ ذِي إِدْجَا أَرُّوحْ ن ثُوذَارْثْ، ثُوسَا-د ثْيُويَا س ثْيُويَا غَارْ نُوحْ غَارْ ؤُغَارَّابُو.
\v 16 ؤُ زِي مَارَّا إِمدَّارنْ س أَرِّيمثْ ن ويْسُومْ إِ د-يُوسِينْ، يُوذفْ إِجّْ ن ووْثمْ ذ إِشْثْ ن ثوْثمْثْ أَمْ مَامّشْ \add ث\add* يُومُورْ أَربِّي، ؤُشَا إِقّنْ سِيذِي \add ثَاوَّارْثْ\add* أَوَارْنِي أَسْ.
\v 17 ثُوغَا سّحْڒثْ خْ ثمُّورْثْ أَربْعِينْ ن وُوسَّانْ ؤُشَا ڭعّْذنْ وَامَانْ ؤُشَا سّْڭعّْذنْ أَغَارَّابُو أَڒَامِي إِڭعّذْ سنّجْ إِ \add وُوذمْ ن\add* ثمُّورْثْ.
\v 18 ڭعّْذنْ وَامَانْ ؤُشَا مَّارنْينْ-د أَطَّاسْ سنّجْ إِ ثمُّورْثْ ؤُشَا يُويُورْ ؤُغَارَّابُو خْ وُوذمْ ن وَامَانْ.
\v 19 ڭعّْذنْ أَمَانْ أَطَّاسْ س وَاطَّاسْ، أَڒَامِي مَارَّا إِذُورَارْ يُوعْڒَانْ إِ ذِينْ إِدْجَانْ سَاذُو مَارَّا أَجنَّا، ذوْڒنْ ذْڒِينْ.
\v 20 ؤُڒْينْ وَامَانْ خمّسْطَاشْ ن إِغَادْجنْ سنّجْ إِ إِذُورَارْ ؤُشَا ذْڒِينْ إِذُورَارْ.
\v 21 مَارَّا إِمدَّارنْ س أَرِّيمثْ ن ويْسُومْ إِ إِتّنْهزَّانْ خْ ثمُّورْثْ إِضْڒقْ إِ بُوحْبڒْ نّسْ، إِجْضَاضْ ذ ڒبْهَايمْ، ڒْمَاڒْ \add ن ڒخْڒَا\add*، مَارَّا \add إِمُودَّارنْ\add* إِتّْبُوعنْ، إِنِّي إِتّْبُوعنْ خْ وُوذمْ ن ثمُّورْثْ ؤُڒَا ذ مَارَّا إِوْذَانْ. \x ◘ \xo 7:‏21 \xt لك. 17‏:‏27. \x*
\v 22 مَارَّا مِينْ ذِي إِدْجَا ڒعْوِينْ ن أَرُّوحْ ن ثُوذَارْثْ غَارْسنْ ذڭْ ونْزَارنْ نْسنْ زِي مَارَّا مِينْ ذِينْ \add إِدْجَانْ\add* خْ ڒْبَارّْ، إِمُّوثْ.
\v 23 ؤُشَا مَارَّا مِينْ ذِينْ إِدْجَانْ خْ وُوذمْ ن ثمُّورْثْ إِتّْوَامْحَا، زِي بْنَاذمْ أَڒْ ڒْمَاڒْ ذ إِمُودَّارنْ إِنِّي إِتّْبُوعنْ ذ إِجْضَاضْ ن ؤُجنَّا. إِنَا تّْوَاثحَّانْ زِي ثمُّورْثْ. نُوحْ وحّْذسْ إِ إِقِّيمنْ ذ مَارَّا مِينْ كِيذسْ إِ إِدْجَانْ ذڭْ ؤُغَارَّابُو. \x ◘ \xo 7:‏23 \xt 2 بُط. 2‏:‏5. \x*
\v 24 ڭعّْذنْ وَامَانْ خْ ثمُّورْثْ مْيَا ؤُ-خمْسِينْ ن وُوسَّانْ.
\b
\b
\c 8
\m 
\v 1 ؤُشَا إِخَارّصْ أَربِّي ذِي نُوحْ ؤُ ذِي مَارَّا ڒْمَاڒْ \add ن ڒخْڒَا\add* ذ مَارَّا ڒبْهَايمْ إِ ثُوغَا أَكِيذسْ ذڭْ ؤُغَارَّابُو. إِڭَّا أَربِّي أَذْ يكّْ إِجّْ ن ؤُسمِّيضْ خْ ثمُّورْثْ أَڒَامِي أَرْسَانْ وَامَانْ.
\v 2 بلّْعنْثْ ڒْعُونْصَارَاثْ ن \add وَامَانْ\add* إِهوْڒنْ ذ ثْبُورْجَاثِينْ ن ؤُجنَّا ؤُشَا إِبدّْ ونْژَارْ زڭْ ؤُجنَّا.
\v 3 ؤُشَا، أَمْ د-تَّاسنْ تّْرَاحنْ، ذوْڒنْ-د وَامَانْ زِي ثمُّورْثْ. أَوَارْنِي مْيَا ؤُ-خمْسِينْ ن وُوسَّانْ نقْصنْ وَامَانْ.
\v 4 ذڭْ ؤُيُورْ وِيسّْ سبْعَا، ذڭْ وَاسّْ وِيسّْ سْبعْطَاشْ ن ؤُيُورْ \add نِّي\add*، يَارْسَا ؤُغَارَّابُو خْ إِذُورَارْ ن أَرَارَاثْ.
\v 5 قِّيمنْ وَامَانْ نقّْصنْ أَڒْ أَيُورْ وِيسّْعشْرَا. ذڭْ ؤُيُورْ وِيسّْعشْرَا، ذڭْ \add وَاسّْ\add* أَمزْوَارُو ن ؤُيُورْ، ضْهَارنْثْ-إِ-د ثْقِيشَّاثِينْ ن إِذُورَارْ.
\m 
\v 6 أَوَارْنِي ڒَامِي عْذُونْ أَربْعِينْ ن وُوسَّانْ، يَارْزمْ نُوحْ ثابُورْجثْ ن ؤُغَارَّابُو نِّي \add ذَايسْ\add* ثُوغَا إِڭَّا،
\v 7 ؤُشَا إِسّكّْ أَبَاغڒْ. وَانِيثَا إِفّغْ، إِقِّيمْ إِتّْرَاحْ إِتَّاسْ-د أَڒَامِي بْذَانْ وَامَانْ تَّاژْغنْ خْ ثمُّورْثْ.
\v 8 خنِّي إِسّكّْ سّنِّي ثَاذْبِيرْثْ، حِيمَا أَذْ إِژَارْ، مَا أَمَانْ نقْصنْ خْ وُوذمْ ن ثمُّورْثْ.
\v 9 \add مَاشَا\add* وَارْ ثُوفِي ثذْبِيرْثْ مَانِي غَا ثسَّارْسْ ثَاڒقَّا ن ؤُضَارْ نّسْ ؤُشَا ثعْقبْ-د غَارسْ غَارْ ؤُغَارَّابُو، مِينْزِي أَمَانْ ثُوغَا أَثنْ \add عَاذْ\add* خْ وُوذمْ ن مَارَّا ثَامُّورْثْ. إِسّْوِيژّضْ أَفُوسْ نّسْ، إِطّفْ إِ-ت ؤُشَا إِسِّيذفْ إِ-ت-إِ-د غَارسْ ذڭْ ؤُغَارَّابُو.
\v 10 إِرَاجَا عَاذْ سبْعَا ن وُوسَّانْ نّغْنِي، \add خنِّي\add* إِسّكّْ ثَاذْبِيرْثْ عَاوذْ زڭْ ؤُغَارَّابُو.
\v 11 ؤُشَا ثَاذْبِيرْثْ ثعْقبْ-د غَارسْ غَارْ ثْمذِّيثْ، ؤُ خْزَارْ، أَقَا أَفَارْ ن زِّيثُونْ ذڭْ ؤُقمُّومْ نّسْ. \add خنِّي\add* إِفْهمْ نُوحْ بلِّي أَمَانْ نقْصنْ زِي ثمُّورْثْ.
\v 12 إِرَاجَا عَاذْ سبْعَا ن وُوسَّانْ، \add خنِّي\add* إِسّكّْ ثَاذْبِيرْثْ \add عَاوذْ\add* ؤُشَا نتَّاثْ وَارْ غَارسْ د-ثعْقِيبْ عَاذْ.
\v 13 ذڭْ ؤُسڭّْوَاسْ وِيسّْ ستَّا-مْيَا ؤُ-وَاحِيثْ \add ن نُوحْ\add*، ذڭْ \add ؤُيُورْ\add* أَمزْوَارُو، ذڭْ \add وَاسّْ\add* أَمزْوَارُو ن ؤُيُورْ نِّي، ؤُژْغنْ وَامَانْ خْ ثمُّورْثْ. إِكْسِي نُوحْ \add ثَاوَّارْثْ ن\add* ؤُسقَّافْ ن ؤُغَارَّابُو، إِخْزَارْ غَارْ بَارَّا، ؤُشَا خْزَارْ، ؤُذمْ ن ثمُّورْثْ أَقَا يُوژغْ.
\v 14 ذڭْ ؤُيُورْ وِيسّْ ثْنَاينْ، ذڭْ وَاسّْ وِيسّْ سبْعَا ؤُ-عِيشْرِينْ ن ؤُيُورْ \add نِّي\add*، ثُوژغْ ثمُّورْثْ.
\m 
\v 15 خنِّي إِسِّيوڒْ أَربِّي أَكْ-ذ نُوحْ، إِنَّا:
\v 16 ”فّغْ زڭْ ؤُغَارَّابُو، شكْ ذ ثمْغَارْثْ نّشْ ذ إِحنْجِيرنْ نّشْ ذ ثمْغَارِينْ ن إِحنْجِيرنْ نّشْ أَكِيذكْ.
\v 17 مَارَّا مِينْ إِدَّارنْ إِ إِدْجَانْ أَكِيذكْ، زِي مَارَّا مِينْ غَارْسنْ أَرِّيمثْ ن ويْسُومْ، زڭْ إِجْضَاضْ، زِي ڒْمَاڒْ ؤُ زِي مَارَّا \add إِمُودَّارنْ\add* نِّي إِتّْبُوعنْ خْ ثمُّورْثْ، أجّْ إِ-ثنْ أَذْ فّْغنْ أَكِيذكْ، أجّْ إِ-ثنْ أَذْ مْطَارَّاشنْ خْ ثمُّورْثْ، أَذْ أَرّنْ ڒْغِيدْجثْ ؤُشَا أَذْ مَّارنْينْ خْ ثمُّورْثْ.“ \x ◘ \xo 8:‏17 \xt أَمز. 1‏:‏22، 28؛ 9‏:‏1. \x*
\v 18 إِفّغْ نُوحْ ذ إِحنْجِيرنْ نّسْ ذ ثمْغَارْثْ نّسْ ذ ثمْغَارِينْ ن إِحنْجِيرنْ نّسْ أَكِيذسْ.
\v 19 مَارَّا ڒْمَاڒْ \add ن ڒخْڒَا\add*، مَارَّا مِينْ إِتّْبُوعنْ، ذ مَارَّا إِجْضَاضْ، ذ مَارَّا مِينْ إِتّنْهزَّانْ خْ ثمُّورْثْ فّْغنْ زڭْ ؤُغَارَّابُو عْلَاحْصَابْ ڒَادْجَاثْ نْسنْ.
\m 
\v 20 إِبْنَا نُوحْ إِجّْ ن ؤُعَالْطَارْ إِ سِيذِي ؤُشَا إِكْسِي زِي مَارَّا ڒْمَاڒْ ن ڒحْڒَاڒْ ؤُ زِي مَارَّا إِجْضَاضْ ن ڒحْڒَاڒْ ؤُشَا إِقدّمْ ثِيغَارْصَا ن وشْمَاضْ خْ ؤُعَالْطَارْ. \f ◼ \fr 8:‏20 \ft \bd ’أَعَالْطَارْ‘\bd*- نِيغْ ’ڒْْمذْبحْ‘.\f*  \x ◘ \xo 8:‏20 \xt لَاوِي 11. \x*
\v 21 ؤُشَا إِشمّْ سِيذِي ڒفْوَاحثْ إِتّْفُوحنْ ؤُشَا إِنَّا سِيذِي ذڭْ وُوڒْ نّسْ: ”وَارْ تّْعِيقِّيبغْ عَاذْ أَذْ نعْڒغْ ثَامُّورْثْ خْ سِّيبّثْ ن بْنَاذمْ، مِينْزِي مِينْ د-إِتّفّْغنْ زڭْ وُوڒْ ن بْنَاذمْ ذ أَعفَّانْ وَاهَا زِي ثمْژِي نّسْ. وَارْ تّْعِيقِّيبغْ عَاذْ أَذْ وْثغْ مَارَّا مِينْ إِدَّارنْ أَمْ مَامّشْ ڭِّيغْ. \x ◘ \xo 8:‏21 \xt أَمز. 6‏:‏5؛ أَوڒن. 22‏:‏15؛ مت. 15‏:‏19. مك. 7‏:‏21‏-‏23\x*
\v 22 مَارَّا ؤُسَّانْ إِ غَا ثقِّيمْ ثمُّورْثْ ثدْجَا، أَذْ ثِيڒِي ثْيَارْزَا ذ ثْميْرَا، ثصْمضْ ذ ڒحْمُو، أَنبْذُو ذ ڒْمشْثَا ؤُشَا أَسّْ ذ دْجِيڒثْ وَارْ تّْبذِّينْ \add عمَّارْصْ\add*.“ \f ◼ \fr 8:‏22 \ft \bd ’ثَايَارْزَا‘\bd* - نِيغْ ’أَمُوذْ‘. \bd ’ثَاميْرَا‘\bd* - نِيغْ ’ثَافرْسِيثْ‘.\f*  \x ◘ \xo 8:‏22 \xt إِرْم. 33‏:‏20، 25. \x*
\b
\b
\c 9
\s1 ڒْعَاهْذْ ن أَربِّي أَكْ-ذ نُوحْ
\m 
\v 1 خنِّي إِبَاركْ أَربِّي نُوحْ ذ إِحنْجِيرنْ نّسْ ؤُشَا إِنَّا أَسنْ: ”جّمْ-د ڒْغِيدْجثْ، مَارنْيمْ ؤُعمَّارمْ ثَامُّورْثْ! \x ◘ \xo 9:‏1 \xt أَمز. 1‏:‏28؛ 8‏:‏17. \x*
\v 2 ثِيڭّْوُوذِي ذ ڒْعُورّثْ زِي كنِّيوْ أَذْ إِڒِينْثْ خْ مَارَّا ڒْمَاڒْ \add ن ڒخْڒَا\add*، خْ مَارَّا إِجْضَاضْ ن ؤُجنَّا ؤُ خْ مَارَّا مِينْ إِتّْبُوعنْ خْ ثمُّورْثْ ؤُ خْ مَارَّا إِسڒْمَانْ ذِي ڒبْحَارْ: أَقَا مّوْشنْ ذڭْ ؤُفُوسْ نْومْ.
\v 3 مَارَّا مِينْ إِتّْبُوعنْ، مِينْ إِدَّارنْ، أَذْ أَومْ يِيڒِي ذ مَاشَّا. نشّْ أَذْ أَومْ ث وْشغْ مَارَّا، أَمْ ذ أَومْ وْشِيغْ أَفْسُو أَزِيزَا، \x ◘ \xo 9:‏3 \xt أَمز. 1‏:‏29. \x*
\v 4 مَاشَا أَيْسُومْ أَكْ-ذ بُوحْبڒْ نّسْ إِ إِدْجَانْ ذ إِذَامّنْ نّسْ، وَارْ \add ثنْ\add* تّتّمْ. \x ◘ \xo 9:‏4 \xt لَاوِي 3‏:‏17؛ 7‏:‏26؛ 17‏:‏14؛ 19‏:‏26؛ أَعَوذ. 12‏:‏23. \x*
\v 5 ذ ثِيذتّْ أَذْ تَّارغْ إِذَامّنْ نْومْ ن ڒعْمُورْ نْومْ، أَذْ ثنْ تَّارغْ زڭْ إِفَاسّنْ ن مَارَّا إِمُودَّارنْ، ؤُڒَا زڭْ إِفَاسّنْ ن بْنَاذمْ، ؤُ زڭْ إِفَاسّنْ ن ؤُمَاسْ ن كُوڒْ إِجّنْ أَذْ تَّارغْ ڒعْمَارْ ن بْنَاذمْ. \x ◘ \xo 9:‏5 \xt ؤُف. 21‏:‏12، 28. \x*
\v 6 وِي غَا إِسِّيزّْڒنْ إِذَامّنْ ن بْنَاذمْ، إِذَامّنْ نّسْ أَذْ ثنْ سِّيزّْڒنْ س ؤُفُوسْ ن بْنَاذمْ، مِينْزِي أَربِّي إِڭَّا بْنَاذمْ ذِي صِّيفثْ نّسْ. \x ◘ \xo 9:‏6 \xt أَمز. 1‏:‏27؛ إِڭجذ. 4‏:‏13؛ مت. 26‏:‏52؛ أَسَا. 13‏:‏10. \x*
\v 7 ؤُ كنِّيوْ، جّمْ-د ڒْغِيدْجثْ، ذوْڒمْ ذڭْ وَاطَّاسْ، مْطَارّْشمْ ذِي ثمُّورْثْ ؤُشَا ذوْڒمْ ذڭْ وَاطَّاسْ خَاسْ.“ \x ◘ \xo 9:‏7 \xt أَمز. 1‏:‏28؛ 8‏:‏17. \x*
\m 
\v 8 ؤُشَا إِسِّيوڒْ أَربِّي أَكْ-ذ نُوحْ ذ إِحنْجِيرنْ نّسْ نِّي غَارسْ، إِنَّا:
\v 9 ”نشّْ، خْزَارْ، نشّْ تّڭّغْ ڒْعَاهْذْ إِنُو أَكِيذْومْ ؤُ أَكْ-ذ زَّارِيعثْ نْومْ أَوَارْنِي أَومْ، \x ◘ \xo 9:‏9 \xt إِشا. 54‏:‏9. \x*
\v 10 ؤُ أَكْ-ذ مَارَّا بُوحْبڒْ إِدَّارنْ نِّي إِدْجَانْ أَكِيذْومْ، أَكْ-ذ إِجْضَاضْ، أَكْ-ذ ڒْمَاڒْ ؤُ أَكْ-ذ مَارَّا ڒْمَاڒْ \add ن ڒخْڒَا\add* خْ ثمُّورْثْ إِنِّي أَكِيذْومْ، \add وَاهْ، أَكْ-ذ\add* مَارَّا مِينْ د-إِفّْغنْ زڭْ ؤُغَارَّابُو أَڒْ مَارَّا مِينْ إِدَّارنْ خْ ثمُّورْثْ.
\v 11 أَذْ ڭّغْ ڒْعَاهْذْ إِنُو أَكِيذْومْ، أَقَا مَارَّا إِمدَّارنْ س أَرِّيمثْ ن ويْسُومْ وَارْ تّْوَاكسِّينْ عَاذْ س وَامَانْ ن سّحْڒثْ، ؤُ وَارْ ذِينْ ثتِّيڒِي عَاذْ سّحْڒثْ إِ غَا يَاردّْدْجنْ ثَامُّورْثْ.“
\v 12 خنِّي إِنَّا أَربِّي: ”ذ ثَا أَذْ ثِيڒِي ذ ڒعْڒَامثْ ن ڒْعَاهْذْ ثنِّي إِ غَا ڭّغْ جَارْ أَيِي ذ كنِّيوْ ذ مَارَّا ڒعْمَارْ إِدَّارنْ أَكِيذْومْ، إِ \add مَارَّا\add* جِّيڒَاثْ \add إِ\add* ڒبْذَا:
\v 13 أَذْ ڭّغْ ڒْقوْسْ إِنُو ذڭْ إِسيْنُوثنْ ونِّي إِ غَا يِيڒِينْ ذ ڒعْڒَامثْ ن ڒْعَاهْذْ جَارْ أَيِي ذ ثمُّورْثْ.
\v 14 خْمِي غَا بْضِيغْ إِسيْنُوثنْ خْ ثمُّورْثْ، خنِّي أَذْ إِمْسَارْ بلِّي ڒْقوْسْ-أَ أَذْ د-إِضْهَارْ ذڭْ إِسيْنُوثنْ.
\v 15 خنِّي أَذْ إِذَارغْ ڒْعَاهْذْ إِنُو جَارْ أَيِي ذ كنِّيوْ ذ مَارَّا ڒعْمَارْ إِدَّارنْ ن مَارَّا إِمدَّارنْ س أَرِّيمثْ ن ويْسُومْ. وَارْ د-دِّيكّْوِيڒنْ وَامَانْ ذ سّحْڒثْ عَاوذْ، مَاحنْذْ أَذْ سّْغَارْقنْ مَارَّا إِمدَّارنْ س أَرِّيمثْ ن ويْسُومْ.
\v 16 أَذْ د-إِضْهَارْ ڒْقوْسْ ذڭْ إِسيْنُوثنْ، ؤُشَا نشّْ أَذْ ث ژَترغْ حِيمَا أَذْ إِذَارغْ ڒْعَاهْذْ إِ ڒبْذَا جَارْ أَربِّي ذ مَارَّا ڒعْمَارْ إِدَّارنْ ذِي مَارَّا إِمدَّارنْ س أَرِّيمثْ ن ويْسُومْ إِ إِدْجَانْ خْ ثمُّورْثْ.“
\v 17 ؤُشَا إِنَّا أَربِّي إِ نُوحْ: ”ذ ثَا ذ ڒعْڒَامثْ ن ڒْعَاهْذْ إِنُو ونِّي إِ غَا ڭّغْ جَارْ أَيِي ذ مَارَّا إِمدَّارنْ س أَرِّيمثْ ن ويْسُومْ إِ إِدْجَانْ خْ ثمُّورْثْ.“
\b
\s1 ثَارْوَا ن نُوحْ
\m 
\v 18 ثَارْوَا ن نُوحْ إِنِّي د-إِفّْغنْ زڭْ ؤُغَارَّابُو \add ثُوغَا أَثنْ ذ\add* شَامْ ذ حَامْ ذ يَافَاثْ. حَامْ ثُوغَا ذ بَابَاسْ ن كنْعَانْ. \f ◼ \fr 9:‏18 \ft \bd ’كنْعَانْ‘\bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’ثَامُّورْثْ إِوَاطَانْ‘.\f*  \x ◘ \xo 9:‏18 \xt أَمز. 6‏:‏10. \x*
\v 19 إِنَا ذ ثْڒَاثَا ن إِحنْجِيرنْ ن نُوحْ. زَّايْسنْ تّْوَابزّْعنْ \add إِوْذَانْ\add* ذِي مَارَّا ثَامُّورْثْ.
\v 20 إِبْذَا نُوحْ \add إِخدّمْ\add* أَمْ ؤُفدْجَاحْ، إِژُّو ثِيزَايَارِينْ ذڭْ ؤُمَارْجعْ ن ؤُضِيڒْ.
\v 21 \add ؤُمِي\add* إِسْوَا بِينُو، إِسْشَارْ ؤُشَا إِعَارَّا إِخفْ نّسْ ذِي ڒْوسْطْ ن ؤُقِيضُونْ نّسْ.
\v 22 إِژْرَا حَامْ، بَابَاسْ ن كنْعَانْ، ثُوعَّارْينْثْ ن بَابَاسْ ؤُشَا إِنَّا ث إِ ثْنَاينْ ن أَيْثْمَاسْ ذِي بَارَّا.
\v 23 كْسِينْ شَامْ ذ يَافَاثْ شَا ن ورُّوضْ، سَّارْسنْ ث خْ ثْغَارْضِينْ ن ثْنَاينْ إِذْسنْ نْسنْ ؤُشَا ؤُيُورنْ غَارْ ضفَّارْ، ذْڒِينْ ثُوعَّارْينْثْ ن بَابَاثْسنْ. أَرِّينْ أَغمْبُوبْ نْسنْ غَارْ ضفَّارْ، وَارْ ژْرِينْ شَا ثُوعَّارْينْثْ ن بَابَاثْسنْ.
\v 24 إِفَاقْ-د نُوحْ زِي سّكْرَا نّسْ ؤُشَا إِذْوڒْ يَارْڭبْ خْ مِينْ ذ أَسْ إِڭَّا مِّيسْ أَمَاژُوژْ.
\v 25 إِنَّا: ”ذ أَمنْعُوڒْ \add إِ يدْجَا\add* كنْعَانْ! أَذْ يِيڒِي ذ أَمْسخَّارْ \add قَاعْ\add* ن إِمْسخَّارنْ إِ أَيْثْمَاسْ!“
\v 26 ؤُشَا إِنَّا: ”أَذْ إِتّْوَابَاركْ سِيذِي، أَربِّي ن شَامْ. كنْعَانْ أَذْ يِيڒِي ذ أَمْسخَّارْ إِ نِيثْنِي.
\v 27 زعْمَا أَذْ إِوسّعْ أَربِّي ثَازذِّيغْثْ إِ يَافَاثْ، أَذْ إِزْذغْ ذڭْ إِقِيضَانْ ن شَامْ، ؤُ كنْعَانْ أَذْ أَسنْ يِيڒِي ذ أَمْسخَّارْ.“
\v 28 أَوَارْنِي سّحْڒثْ إِدَّارْ نُوحْ \add عَاذْ\add* ثڒْثْ-مْيَا ؤُ-خمْسِينْ ن إِسڭّْوُوسَا.
\v 29 أَمُّو إِ إِدَّارْ نُوحْ ثسْعَا-مْيَا ؤُ-خمْسِينْ ن إِسڭّْوُوسَا، خنِّي إِمُّوثْ.
\m \bd إِنَا ذ إِمزْرُوينْ ن يِينِّي د-إِتّْوَاخڒْقنْ زڭْ أَيْثْ ن نُوحْ:\bd* شَامْ، حَامْ ذ يَافَاثْ.
\b
\b
\c 10
\s1 ثَارْوَا ن شَامْ، خَامْ ذ يَافِيثْ
\m 
\v 1 تّْوَارْونْ أَسنْ-د إِحنْجِيرنْ أَوَارْنِي إِ سّحْڒثْ. \x ◘ \xo 10:‏1 \xt [1 إِم. 1‏:‏1‏-‏27] — 1 إِم. 1‏:‏4\x*  *
\b
\m 
\v 2 \bd أَيْثْ ن يَافَاثْ\bd* \add ثُوغَا أَثنْ ذ\add* جُومَارْ، مَاجُوجْ، مَاذَايْ، يَاوَانْ، ثُوبَالْ، مَاشِيكْ ذ ثِيرَاسْ. \f ◼ \fr 10:‏2 \ft \bd ’جُومَارْ‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’ونِّي بْڒَا ڒْعِيبْ‘ نِيغْ ’ونِّي إِكمْڒنْ‘. \bd ’مَاجُوجْ‘\bd* - نِيغْ ’مَاخُوخْ‘، نِيغْ ’مَاڭُوڭْ‘.\f*  \x ◘ \xo 10:‏2 \xt 1 إِم. 1‏:‏5. \x*
\m 
\v 3 إِحنْجِيرنْ ن جُومَارْ، \add ثُوغَا أَثنْ ذ\add* أَشْكَانَازْ، رِيفَاثْ ذ ثُوجَارْمَا.
\m 
\v 4 إِحنْجِيرنْ ن يَاوَانْ \add ثُوغَا أَثنْ ذ\add* إِلِيشَا، ثَارْشِيشْ ذ إِكِيتِّييّنْ ذ إِذُوذَانِييّنْ. \f ◼ \fr 10:‏4 \ft \bd ’إِكِيتِّييّنْ ذ إِذُوذَانِيينْ‘\bd* - إِخْسْ أَذْ يِينِي ’ثِيقبَّاڒْ ن كِيثْ ذ ذُوذَانْ‘.\f*
\m 
\v 5 زَّايْسنْ إِ تّْوَابْضَانْثْ ثڭْزِيرِينْ ن ڒڭْنُوسْ ذِي ثمُّورَا نْسنْ، كُوڒْ إِجّنْ عْلَاحْسَابْ إِڒسْ نّسْ ؤُشَا \add مَارَّا\add* عْلَاحْسَابْ ڒَادْجْ نْسنْ ؤُ ذِي ڒڭْنُوسْ نْسنْ.
\b
\m 
\v 6 \bd أَيْثْ ن حَامْ\bd* \add ثُوغَا أَثنْ ذ\add* كُوشْ، مِيصْرَايِيمْ، فُوطْ ذ كنْعَانْ. \x ◘ \xo 10:‏6 \xt 1 إِم. 1‏:‏8. \x*
\m 
\v 7 إِحنْجِيرنْ ن كُوشْ \add ثُوغَا أَثنْ ذ\add* سبَا، حَاوِيلَا، سَابْثَا، رَاعَامَا ذ سَابْثَاكَا. إِحنْجِيرنْ ن رَاعَامَا \add ثُوغَا أَثنْ ذ\add* شَابَا ذ ذَاذَانْ.
\m 
\v 8 كُوشْ إِجَّا-د نِيمْرُوذْ. وَانِيثَا إِبْذَا أَذْ يِيڒِي ذ جِّيهڒْ ذِي ثمُّورْثْ. \x ◘ \xo 10:‏8 \xt 1 إِم. 1‏:‏10. \x*
\v 9 وَا ثُوغَا ذ أَنڭْمَارْ ذ أَمقّْرَانْ زَّاثْ إِ وُوذمْ ن سِيذِي. خْ ؤُيَا قَّارنْ: ’أَنڭْمَارْ أَمقّْرَانْ أَمْ نِيمْرُوذْ زَّاثْ إِ وُوذمْ ن سِيذِي.‘
\v 10 أَمزْوَارْ ن ثْڭلْذِيثْ نّسْ ثُوغَا أَثنْثْ \add ذ ثِيندَّامْ ن\add* بَابِيلْ ذ إِرِيخْ ذ أَكَّاذْ ذ كَالْنَا ذِي ثمُّورْثْ ن شِينْعَارْ.
\v 11 زِي ثمُّورْثْ نِّي د-إِفّغْ غَارْ أَشُّورْ ؤُشَا إِبْنَا \add ذِينْ\add* نِينْوَا، رِيحُوبُوثْ-عِيرْ ذ كَالَاحْ
\v 12 ذ رِيسِينْ جَارْ نِينْوَا ذ كَالَاحْ، نتَّاثْ ذ ثَانْذِينْثْ ثَامقّْرَانْثْ.
\m 
\v 13 مِيصْرَايِيمْ إِجَّا-د إِلُوذِييّنْ، إِعَانَامِييّنْ، إِلَاهَابِييّنْ، إِنَافْثُوحِييّنْ،
\m 
\v 14 إِفَاثْرُوسِييّنْ، إِكَاسْلُوحِييّنْ، إِنِّي زِي د-إِقَّارْصنْ إِفِيلِيسْطِينِييّنْ، ؤُڒَا ذ إِكَافْثُورِييّنْ.
\m 
\v 15 كنْعَانْ إِجَّا-د صِيذُونْ، أَمنْزُو نّسْ، ذ حِيثْ
\v 16 ذ ؤُيابُوسِي ذ ؤُمُورِي ذ ؤُجِيرْجَاشِي
\v 17 ذ ؤُحِيوِي ذ ؤُعَارْقِي ذ ؤُسِينِي
\v 18 ذ ؤُرْوَاذِي ذ ؤُصَامَارِي ذ ؤُحَامَاثِي. أَوَارْنِي أَسْ مْبزّْعنْثْ مَارَّا ڒَادْجَاثْ ن كنْعَانْ.
\v 19 ثُوغَا أَيْمِيرْ ن أَيْثْ ن كنْعَانْ زِي صِيذُونْ غَارْ خِيرَارْ أَڒْ غَازَّا \add ؤُ\add* سّنِّي غَارْ سَاذُومْ ذ عَامُورَّا ذ أَذْمَا ذ صابُويِيمْ أَڒْ لَاشَاعْ. \f ◼ \fr 10:‏19 \ft \bd ’خِيرَارْ‘\bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَمْشَانْ إِ إِنوْجِيونْ‘. \bd ’غَازَّا‘\bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’جّهْذْ‘. \bd ’أَذْمَا‘\bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’ثَامُّورْثْ ثَازڭّْوَاغْثْ‘. \bd ’صَاپُويِيمْ‘\bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’إِغَايْضنْ ن وزْغَارْ‘ نِيغْ ’أَژْرِي ن وژْرِي‘ نِيغْ ’إِعبُّوزنْ‘ نِيغْ ’ثَانْذِينْثْ ن ڒْعسْكَارْ‘.\f*
\m 
\v 20 إِنَا ذ أَيْثْ ن حَامْ عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ، عْلَاحْسَابْ إِڒْسَاونْ نْسنْ، ذِي ثِيمُّورَا نْسنْ ؤُ أَكْ-ذ ڒڭْنُوسْ نْسنْ.
\b
\m 
\v 21 إِ \bd شَامْ\bd*، ونِّي ذ جدّْ ن مَارَّا أَيْثْ ن عَابِيرْ، ؤُمَاسْ ن يَافَاثْ، أَمقّْرَانْ، تّْوَارْونْ أَسْ-د عَاوذْ إِحنْجِيرنْ.
\v 22 إِحنْجِيرنْ ن شَامْ \add ثُوغَا أَثنْ ذ\add* عِيلَامْ، أَشُّورْ، أَرْفَاكْشَاذْ، لُوذْ ذ أَرَامْ. \x ◘ \xo 10:‏22 \xt أَمز. 11‏:‏10؛ 1 إِم. 1‏:‏17. \x*
\m 
\v 23 إِحنْجِيرنْ ن أَرَامْ \add ثُوغَا أَثنْ ذ\add* عُوصْ ذ حُولْ ذ جَاثِيرْ ذ مَاشْ.
\m 
\v 24 أَرْفَاكْشَاذْ إِجَّا-د شَالَاحْ ؤُ شَالَاحْ إِجَّا-د عَابِيرْ. \x ◘ \xo 10:‏24 \xt 1 إِم. 1‏:‏18. \x*
\m 
\v 25 تّْوَارْونْ-د إِ عَابِيرْ ثْنَاينْ ن إِحنْجِيرنْ. إِجّنْ قَّارنْ أَسْ فَالَاجْ، مِينْزِي ذڭْ وُوسَّانْ نّسْ ثتّْوَافدْجقْ ثمُّورْثْ، ؤُ قَّارنْ أَسْ إِ ؤُمَاسْ يُوقْطَانْ. \f ◼ \fr 10:‏25 \ft \bd ’فَالَاجْ‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَبطُّو‘ نِيغْ ’أَفدْجقْ‘. \bd ’ثتّْوَافدْجقْ‘\bd* - أَوَاڒْ-أَ إِزمَّارْ أَذْ إِشيَّارْ غَارْ (1) ؤُبطُّو ن إِوْذَانْ ؤُمِي سِيذِي إِبطَّا إِڒسْ نْسنْ ؤُشَا ذوْڒنْ نِيثْنِي أَذْ سِّيوْڒنْ عْڒَامْ كُوڒْ  إِڒْسَاونْ جَارْ أَسنْ (خْزَارْ أَمز. 11:1-9)، نِيغْ غَارْ (2) ؤُبطُّو ن ؤُمَاضَالْ (نِيغْ ’دُّونِّيثْ‘) ذڭْ إِزِييْنَانْ، إِخْسْ أَذْ يِينِي أَمْرِيكَا، إِفْرِيقِييَّا، أَسِييَا، ؤُسْثْرَالِييَا ذ ؤُرُوبَا، مَاغَارْ ذڭْ ؤُمزْوَارُو ثُوغَا ثَامُّورْثْ ذ إِجّْ ن ومْشَانْ (خْزَارْ أَمز. 1:9، 10). \bd ’يُوقْطَانْ‘\bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَمژْيَانْ‘.\f*
\m 
\v 26 يُوقْطَانْ إِجَّا-د أَلْمُوذَاذْ، شَالَافْ، هَاضَارْمَاوْثْ، يَارَاحْ،
\v 27 هَاذُورَامْ، ؤُزَالْ، ذِيقْلَا،
\v 28 عُوبَالْ، أَبِيمَايِيلْ، شَابَا،
\v 29 ؤُفِيرْ، حَاوِيلَا ذ يُوبَابْ. مَارَّا إِنَا \add ثُوغَا أَثنْ ذ\add* إِحنْجِيرنْ ن يُوقْطَانْ.
\v 30 ثَامُّورْثْ مَانِي ثُوغَا زدّْغنْ \add ثُوغَا-ت\add* زِي مِيشَا أَڒْ سَافَارْ، أَذْرَارْ ن شَّارْقْ.
\m 
\v 31 إِنَا ذ أَيْثْ ن شَامْ عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ ؤُ عْلَاحْسَابْ إِڒْسَاونْ نْسنْ، ذِي ثمُّورَا نْسنْ ؤُ أَكْ-ذ ڒڭْنُوسْ نْسنْ.
\b
\m 
\v 32 ثِينَا ذ ڒَادْجَاثْ ن إِحنْجِيرنْ ن نُوحْ، عْلَاحْسَابْ مَامّشْ د-خڒْقنْ، أَكْ-ذ ڒڭْنُوسْ نْسنْ. زَّايْسنْ إِ زِي تّْوَابْضَانْ ڒڭْنُوسْ ذِي ثمُّورْثْ أَوَارْنِي إِ سّحْڒثْ. *
\b
\b
\c 11
\s1 صُّومْعثْ ن بَابِيلْ
\m 
\v 1 ثُوغَا مَارَّا ثَامُّورْثْ س يِيڒسْ ذ إِجّنْ ؤُ س ڒْهَارْذْ ذ إِجّنْ.
\v 2 إِمْسَارْ ڒَامِي فسْينْ إِقِيضَانْ نْسنْ \add ؤُشَا فّْغنْ-د\add* زِي شَّارْقْ، ؤُفِينْ إِجّْ ن ڒوْضَا ذِي ثمُّورْثْ ن شِينْعَارْ، ؤُشَا \add قِّيمنْ\add* زدّْغنْ ذِينِّي. \x ◘ \xo 11:‏2 \xt أَمز. 10‏:‏10. \x*
\v 3 نِيثْنِي نَّانْ، كُوڒْ إِجّْ إِ ونّغْنِي: ”أَرَاحمْ-د، أَذْ نڭّْ إِژْرَا زِي ثْڒَاخْثْ، أَذْ ثنْ نسّحْمَا!“ أَمُّو إِ ذ أَسنْ ثذْوڒْ ثْڒَاخْثْ ذ أَژْرُو ؤُ أَشَارْمُوضْ \add إِذْوڒْ\add* غَارْسنْ ذ ثَارِّيسْثْ.
\v 4 \add خَاسْ\add* ؤُشَا نَّانْ: ”زِيذْ، أَذْ نبْنَا إِشْثْ ن ثنْذِينْثْ ذ إِشْثْ ن صُّومْعثْ، ثَاقِيشَّاثْ نّسْ \add أَذْ د-ثَاوضْ\add* غَارْ ؤُجنَّا، ؤُ جّمْ أَنغْ أَذْ نڭّْ إِجّْ ن يِيسمْ إِ نشِّينْ، حِيمَا وَارْ نتّمْسبْضِي شَا خْ وُوذمْ ن مَارَّا ثَامُّورْثْ.“ \x ◘ \xo 11:‏4 \xt أَعَوذ. 1‏:‏28\x*
\m 
\v 5 \add خنِّي\add* إِهْوَا-د سِيذِي، حِيمَا أَذْ إِژَارْ ثَانْذِينْثْ ذ صُّومْعثْ نِّي بْنَانْ ثَارْوَا ن بْنَاذمْ.
\v 6 إِنَّا سِيذِي: ”خْزَارْ، أَقَا أَثنْ ذ ڒْڭنْسْ ذ إِجّنْ ؤُ مَارَّا إِنَا غَارْسنْ إِجّْ ن يِيڒسْ. وَا ذ بدُّو ن مِينْ غَا ڭّنْ. ڒخُّو وَارْ ذِينْ مِينْ ثنْ إِ غَا إِسّْبدّنْ خْ وبْرِيذْ نْسنْ نِّي نْوَانْ أَذْ ڭّنْ.
\v 7 أَرَاحمْ-د، أَذْ نهْوَا ؤُشَا أَذْ نسّْخَارْوضْ إِڒسْ نْسنْ، حِيمَا كُوڒْ إِجّنْ وَارْ إِفهّمْ \add عَاذْ\add* إِڒسْ ن ونِّي ث يُوذْسنْ.“
\v 8 أَمُّو إِ ثنْ إِزُّوزَارْ سِيذِي سّنِّي خْ وُوذمْ ن مَارَّا ثَامُّورْثْ ؤُشَا سّْبدّنْ ڒبْنِي ن ثنْذِينْثْ. \x ◘ \xo 11:‏8 \xt أَعَوذ. 32‏:‏8؛ ڒخ. 17‏:‏26. \x*
\v 9 خْ ؤُيَا إِ ذ أَسْ ڒَاغَانْ \add إِ ثنْذِينْثْ نِّي\add* س يِيسمْ ن ’بَابِيلْ‘، مِينْزِي ذِينْ إِسّْخَارْوضْ سِيذِي إِڒسْ ن مَارَّا ثَامُّورْثْ ؤُ سّنِّي إِ ثنْ إِزُّوزَارْ سِيذِي خْ وُوذمْ ن مَارَّا ثَامُّورْثْ.
\m \bd إِنَا ذ إِمزْرُوينْ ن يِينِّي د-إِتّْوَاخڒْقنْ \bdit زِي\bdit* شَامْ.\bd* \f ◼ \fr 11:‏9 \ft \bd ’بَابِيلْ‘\bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَخَارْوضْ‘ نِيغْ ’أَربِّي إِسّْخَارْوَاضْ‘.\f*
\b
\s1 ثَارْوَا ن شَامْ
\m 
\v 10 ؤُمِي ثُوغَا غَارْ شَامْ مْيَا ن إِسڭّْوُوسَا، إِجَّا-د \bd أَرْفَاكْشَاذْ\bd*، ثْنَاينْ ن إِسڭّْوُوسَا أَوَارْنِي إِ سّحْڒثْ. \f ◼ \fr 11:‏10 \ft \bd أَفسَّارْ\bd* - ذڭْ وذْلِيسْ أَمزْوَارُو 5:32 نقَّارْ أَقَا شَامْ إِتّْوَاخڒْقذْ-د أَوَارْنِي ڒَامِي ثُوغَا نُوحْ غَارسْ 500 ن إِسڭّْوُوسَا. ذڭْ ؤُسڭّْوَاسْ وِيسّْ ستَّا مْيَا ن ثُوذَارْثْ ن نُوحْ ثبْذَا سّحْرثْ (أَمز. 7:11). ثُوغَا ثُوسَا-د سّحْڒثْ إِجّْ ن ؤُسڭّْوَاسْ خْ ثمُّورْثْ. أَكْ-ذ إِنغْمِيسنْ إِ نُوفَا ذڭْ وَاوَاڒنْ ن أَيَا-يَا نسّنْ أَقَا نُوحْ ثُوغَا غَارسْ 502 ن إِسڭّْوُوسَا ڒَامِي د-إِتّْوَاخڒْقْ شَامْ. \bd ’شَامْ‘\bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’إِسمْ‘.\f*  \x ◘ \xo 11:‏10 \xt [1 إِم. 1‏:‏1‏-‏27] — أَمز. 10‏:‏22‏-‏31؛ 1 إِم. 1‏:‏17. \x*
\v 11 أَوَارْنِي ڒَامِي د-إِجَّا أَرْفَاكْشَاذْ، إِدَّارْ شَامْ \add عَاذْ\add* خمْسَا-مْيَا ن إِسڭّْوُوسَا، ؤُشَا إِجَّا-د إِحنْجِيرنْ ذ ثْحنْجِيرِينْ. \f ◼ \fr 11:‏11 \ft \bd أَفسَّارْ\bd* - أَقَا شَامْ إِذْوڒْ غَارسْ 600 ن إِسڭّْوُوسَا. س ؤُينِّي ثُوغَا عَاذْ إِدَّارْ ڒَامِي ثُوغَا إِبْرَاهِيمْ غَارسْ 50 ن إِسڭّْوُوسَا.\f*
\m 
\v 12 إِدَّارْ أَرْفَاكْشَاذْ خمْسَا ؤُ-ثْڒَاثِينْ ن إِسڭّْوُوسَا، \add خنِّي\add* إِجَّا-د \bd شَالَاحْ\bd*. \f ◼ \fr 11:‏12 \ft \bd ’شَالَاحْ‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’ڒسْنَاحْ‘ نِيغْ ’أَرَّاوْ‘.\f*
\v 13 أَوَارْنِي ڒَامِي د-إِجَّا أَرْفَاكْشَاذْ شَالَاحْ، إِدَّارْ \add عَاذْ\add* أَربْعَا-مْيَا ؤُ-ثْڒَاثَا ن إِسڭّْوُوسَا، ؤُشَا إِجَّا-د إِحنْجِيرنْ ذ ثْحنْجِيرِينْ.
\m 
\v 14 إِدَّارْ شَالَاحْ ثْڒَاثِينْ ن إِسڭّْوُوسَا، \add خنِّي\add* إِجَّا-د \bd عَابِيرْ\bd*. \f ◼ \fr 11:‏14 \ft \bd ’عَابِيرْ‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’ثَامُّورْثْ ن ؤُجمَّاضْ‘.\f*
\v 15 أَوَارْنِي ڒَامِي د-إِجَّا شَالَاحْ عَابِيرْ، إِدَّارْ \add عَاذْ\add* أَربْعَا-مْيَا ؤُ-ثْڒَاثَا ن إِسڭّْوُوسَا، ؤُشَا إِجَّا-د إِحنْجِيرنْ ذ ثْحنْجِيرِينْ.
\m 
\v 16 إِدَّارْ عَابِيرْ أَربْعَا ؤُ-ثْڒَاثِينْ ن إِسڭّْوُوسَا، \add خنِّي\add* إِجَّا-د \bd فَالَاجْ\bd*. \f ◼ \fr 11:‏16 \ft \bd ’فَالَاجْ‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَبطُّو‘ نِيغْ ’أَفدْجقْ‘.\f*
\v 17 أَوَارْنِي ڒَامِي د-إِجَّا فَالَاجْ، إِدَّارْ عَابِيرْ \add عَاذْ\add* أَربْعَا-مْيَا ؤُ-ثْڒَاثِينْ ن إِسڭّْوُوسَا، ؤُشَا إِجَّا-د إِحنْجِيرنْ ذ ثْحنْجِيرِينْ.
\m 
\v 18 إِدَّارْ فَالَاجْ ثْڒَاثِينْ ن إِسڭّْوُوسَا، \add خنِّي\add* إِجَّا-د \bd رَاعُووْ\bd*. \f ◼ \fr 11:‏18 \ft \bd ’رَاعُووْ‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَمدُّوكّڒْ‘.\f*  \x ◘ \xo 11:‏18 \xt 1 إِم. 1‏:‏25 \x*
\v 19 أَوَارْنِي ڒَامِي د-إِجَّا رَاعُووْ، إِدَّارْ فَالَاجْ \add عَاذْ\add* مِيثَاينْ ؤُ-ثسْعَا ن إِسڭّْوُوسَا، ؤُشَا إِجَّا-د إِحنْجِيرنْ ذ ثْحنْجِيرِينْ.
\m 
\v 20 إِدَّارْ رَاعُووْ ثْنَاينْ ؤُ-ثْڒَاثِينْ ن إِسڭّْوُوسَا، \add خنِّي\add* إِجَّا-د \bd سَارُوجْ\bd*.\f ◼ \fr 11:‏20 \ft \bd ’سَارُوجْ‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’ثَاسطَّا‘ نِيغْ ’ڒْْفَارْعْ‘.\f*
\v 21 أَوَارْنِي ڒَامِي د-إِجَّا سَارُوجْ، إِدَّارْ رَاعُووْ \add عَاذْ\add* مِيثَاينْ ؤُ-سبْعَا ن إِسڭّْوُوسَا، ؤُشَا إِجَّا-د إِحنْجِيرنْ ذ ثْحنْجِيرِينْ.
\m 
\v 22 إِدَّارْ سَارُوجْ ثْڒَاثِينْ ن إِسڭّْوُوسَا، \add خنِّي\add* إِجَّا-د \bd نَاحُورْ\bd*.\f ◼ \fr 11:‏22 \ft \bd ’نَاحُورْ‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَنفّحْ يُودْجْغنْ‘.\f*
\v 23 أَوَارْنِي ڒَامِي د-إِجَّا نَاحُورْ، إِدَّارْ سَارُوجْ \add عَاذْ\add* مِيثَاينْ ن إِسڭّْوُوسَا، ؤُشَا إِجَّا-د إِحنْجِيرنْ ذ ثْحنْجِيرِينْ.
\m 
\v 24 إِدَّارْ نَاحُورْ ثسْعَا ؤُ-عِيشْرِينْ ن إِسڭّْوُوسَا، \add خنِّي\add* إِجَّا-د \bd ثَارَاحْ\bd*.\f ◼ \fr 11:‏24 \ft \bd ’ثَارَاحْ‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَمْشَانْ ن وَاريّحْ‘.\f*
\v 25 أَوَارْنِي ڒَامِي د-إِجَّا نَاحُورْ ثَارَاحْ، إِدَّارْ \add عَاذْ\add* مْيَا ؤُ-ثسْعَاطَاشْ ن إِسڭّْوُوسَا، ؤُشَا إِجَّا-د إِحنْجِيرنْ ذ ثْحنْجِيرِينْ.
\m 
\v 26 إِدَّارْ ثَارَاحْ سبْعِينْ ن إِسڭّْوُوسَا، \add خنِّي\add* إِجَّا-د \bd أَبْرَامْ\bd*، نَاحُورْ ذ هَارَانْ.
\m \bd إِنَا ذ إِمزْرُوينْ ن يِينِّي د-إِتّْوَاخڒْقنْ \bdit زِي\bdit* ثَارَاحْ.\bd* \f ◼ \fr 11:‏26 \ft \bd ’أَبْرَامْ‘\bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’ثَابَابَاثْ إِعُودْجنْ‘ نِيغْ ’بَابَاسْ ن أَرَامْ‘.\f*
\b
\m 
\v 27 ثَارَاحْ إِجَّا-د أَبْرَامْ، نَاحُورْ ذ هَارَانْ، ؤُ هَارَانْ إِجَّا-د لُوطْ. \x ◘ \xo 11:‏27 \xt ياش. 24‏:‏2؛ 1 إِم. 1‏:‏26. \x*
\v 28 إِمُّوثْ هَارَانْ زَّاثْ إِ بَابَاسْ ثَارَاحْ ذِي ثمُّورْثْ مَانِي د-إِخْڒقْ نتَّا، ذِي ؤُرْ ن إِكَالْذَانِييّنْ.
\v 29 ؤُشَا كْسِينْ أَبْرَامْ ذ نَاحُورْ إِ يِيخفْ نْسنْ ثِيمْغَارِينْ. إِسمْ ن ثمْغَارْثْ ن أَبْرَامْ ثُوغَا-ث ذ سَارَايْ ؤُ إِسمْ ن ثمْغَارْثْ ن نَاحُورْ ذ مِيلْكَا، يدْجِيسْ ن هَارَانْ، بَابَاسْ ن مِيلْكَا ذ يِيسْكَا. \x ◘ \xo 11:‏29 \xt أَمز. 22‏:‏12؛ 22‏:‏20. \x*
\v 30 سَارَايْ ثُوغَا-ت وَارْ د-ثتِّيرُووْ، ثُوغَا وَارْ غَارسْ بُو ؤُحنْجِيرْ. \x ◘ \xo 11:‏30 \xt أَمز. 16‏:‏1، 2؛ 18‏:‏11، 12. \x*
\v 31 ؤُشَا إِكْسِي ثَارَاحْ أَبْرَامْ، مِّيسْ، ذ لُوطْ مِّيسْ ن هَارَانْ، مِّيسْ ن مِّيسْ، ذ سَارَايْ، ثَاسْڒِيثْ نّسْ، ثَامْغَارْثْ ن مِّيسْ أَبْرَامْ، ؤُشَا نِيثْنِي فّْغنْ جْمِيعْ زِي ؤُرْ ن إِكَالْذَانِييّنْ، حِيمَا أَذْ رَاحنْ غَارْ ثمُّورْثْ ن كنْعَانْ. إِوْضنْ غَارْ حَارَانْ ؤُشَا زدّْغنْ ذِينِّي. \f ◼ \fr 11:‏31 \ft \bd ’إِكَالْذَانِييّنْ‘\bd* - إِكَالْذَانِييّنْ ثُوغَا زدّْغنْ ذِي جّْوَايهْ ن ؤُرْ، إِشْثْ ن ثنْذِينْثْ ذِي ثْڭلْذِيثْ ن مِيسُوپُوثَامِييَا. ذڭْ وُوسَّانْ-أَ نسّنْ بلِّي جّْوَايهْ ن مِيسُوپُوثَامِييَا أَقَا-ثنْثْ ذ شَّامَالْ ن لْعِيرَاقْ. أَڒْ إِ ڒخُّو أَطَّاسْ ن إِوْذَانْ ذِي شَّامَالْ ن لْعِيرَاقْ سَّاوَاڒنْ س ثُوثْلَايْثْ ن ثْكَالْذَانِيثْ.\f*  \x ◘ \xo 11:‏31 \xt ياش. 24‏:‏2؛ نَاح. 9‏:‏7؛ ڒخ. 7‏:‏4. \x*
\v 32 ؤُمِي ثڭَّا ثَارَاحْ مِيثَاينْ ؤُ-خمْسَا ن إِسڭّْوُوسَا، إِمُّوثْ ثَارَاحْ ذِي حَارَانْ.
\b
\b
\c 12
\s1 ثَاڒَاغِيثْ ن أَربِّي خْ أَبْرَامْ
\m 
\v 1 إِنَّا سِيذِي إِ أَبْرَامْ: ”فّغْ زِي ثمُّورْثْ نّشْ، زِي ثمُّورْثْ مَانِي د-ثْخڒْقذْ ؤُ زِي ثَادَّارْثْ ن بَابَاشْ، رُوحْ غَارْ ثمُّورْثْ إِ ذ أَشْ غَا سّشْنغْ. \x ◘ \xo 12:‏1 \xt ڒخ. 7‏:‏3؛ عبر. 11‏:‏8. \x*
\v 2 أَذْ زَّايكْ د-سُّوفّْغغْ إِجّْ ن ڒْڭنْسْ إِمْغَارْ، أَذْ شكْ بَارْكغْ ؤُ أَذْ سّمْغَارغْ إِسمْ نّشْ ؤُشَا إِڒِي ذ شكْ \add عَاوذْ\add* ذ لْبَارَاكَا.
\v 3 أَذْ بَارْكغْ ونِّي شكْ إِ غَا إِبَارْكنْ ذ ونِّي شكْ إِ غَا إِنعْڒنْ، أَذْ ث نعْڒغْ. ذَايكْ إِ غَا تّْوَابَارْكنْثْ مَارَّا ڒَادْجَاثْ ن ثمُّورْثْ.“ \x ◘ \xo 12:‏3 \xt أَمز. 18‏:‏18؛ 22‏:‏18؛ 26‏:‏4؛ ڒخ. 3‏:‏25؛ ڭال. 3‏:‏8. \x*  *
\b
\m 
\v 4 ؤُشَا إِرُوحْ أَبْرَامْ أَمْ مَامّشْ ذ أَسْ إِنَّا سِيذِي، ؤُشَا إِرُوحْ لُوثْ أَكِيذسْ. ثُوغَا أَبْرَامْ غَارسْ خمْسَا ؤُ-سبْعِينْ ن إِسڭّْوُوسَا ؤُمِي د-إِفّغْ زِي حَارَانْ.
\v 5 ؤُشَا إِنْذهْ أَبْرَامْ سَارَايْ ثَامْغَارْثْ نّسْ، ذ لُوطْ مِّيسْ ن ؤُمَاسْ، ذ مَارَّا أَڭْڒَا إِ يَاربْحنْ، ذ إِوْذَانْ ذ ڒْمَاڒْ نِّي د-كسْبنْ ذِي حَارَانْ. فّْغنْ \add زِي حَارَانْ\add* حِيمَا أَذْ رَاحنْ غَارْ ثمُّورْثْ ن كنْعَانْ ؤُشَا إِوْضنْ غَارْ ثمُّورْثْ ن كنْعَانْ. \x ◘ \xo 12:‏5 \xt ڒخ. 7‏:‏4. \x*
\v 6 إِژْوَا أَبْرَامْ زِي ثمُّورْثْ نِّي غَارْ ومْشَانْ ن شَاكِيمْ أَڒْ ثَاشجَّارْثْ ن يِيڭّْ ن مُورَا. ذِي ڒْوقْثْ نِّي ثُوغَا أَيْثْ ن كنْعَانْ \add زدّْغنْ\add* ذِي ثمُّورْثْ. \f ◼ \fr 12:‏6 \ft \bd ’شَاكِيمْ‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’ثَاغْرُوضْثْ‘ نِيغْ ’أَعْرُورْ‘. \bd ’ثَاشجَّارْثْ ن يِيڭّْ‘\bd* - نِيغْ ’إِبجِّي‘. إِسمْ نّسْ س ثْلَاثِينِيثْ ’بِيسْثَاشِيأَ ثربِينْثُوسْ‘، خْزَارْ أَمَاوَالْ أَمشْطُوحْ ن oمَارْ كرْذْجَا (424، 437).\f*  \x ◘ \xo 12:‏6 \xt أَمز. 10‏:‏18، 19؛ 13‏:‏7. \x*
\v 7 إِبَانْ-د سِيذِي إِ أَبْرَامْ، إِنَّا أَسْ: ”إِ زَّارِيعثْ نّشْ ؤُمِي إِ غَا وْشغْ ثَامُّورْثْ-أَ.“ ؤُشَا إِبْنَا ذِينْ إِجّْ ن ؤُعَالْطَارْ \add مِينْ خفْ إِسَّارْسْ ثَاغَارْصْثْ\add* إِ سِيذِي، ونِّي ذ أَسْ د-إِبَاننْ. \f ◼ \fr 12:‏7 \ft \bd ’أَعَالْطَارْ‘\bd*- نِيغْ ’ڒْْمذْبحْ‘.\f*  \x ◘ \xo 12:‏7 \xt أَمز. 13‏:‏15؛ 15‏:‏18؛ 17‏:‏8؛ 24‏:‏7؛ 26‏:‏4؛ أَعَوذ. 34‏:‏4. \x*
\m 
\v 8 خنِّي إِعْذُو سّنِّي غَارْ إِذُورَارْ إِ إِدْجَانْ خْ شَّارْقْ ن بَايْثْ-إِلْ ؤُشَا إِوْثَا ذِينِّي إِقِيضَانْ نّسْ، إِجَّا بَايْثْ-إِلْ خْ جِّيهثْ ن ڒْغَارْبْ ؤُ عَايْ خْ شَّارْقْ. ذِينْ إِبْنَا إِجّْ ن ؤُعَالْطَارْ إِ سِيذِي ؤُشَا إِڒَاغَا إِسمْ ن سِيذِي. \f ◼ \fr 12:‏8 \ft \bd ’بَايْثْ-إِلْ‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’ثَادَّارْثْ ن أَربِّي‘. \bd ’عَايْ‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’ڒْْخَارْبثْ‘.\f*
\m 
\v 9 أَوَارْنِي مَانْ أَيَا إِفْسِي أَبْرَامْ إِقِيضَانْ نّسْ، إِمُّوطِّي \add زڭْ ومْشَانْ غَارْ ومْشَانْ\add*، غَارْ \add ثمُّورْثْ ن\add* لْجَانُوبْ.
\b
\s1 أَبْرَامْ ذِي مِيصْرَا
\m 
\v 10 إِذْوڒْ ڒَاژْ ذِي ثمُّورْثْ ؤُشَا إِكمّڒْ أَبْرَامْ خْ وبْرِيذْ نّسْ، إِهْوَا غَارْ مِيصْرَا، حِيمَا أَذْ إِزْذغْ ذِينْ أَمْ ؤُبَارَّانِي، مِينْزِي \add ثُوغَا\add* ڒَاژْ إِمْغَارْ ذِي ثمُّورْثْ.
\v 11 ڒَامِي د-ثِيوضْ ڒْوقْثْ نِّي ؤُمِي إِ غَا يُوذفْ غَارْ مِيصْرَا، إِنَّا إِ سَارَايْ، ثَامْغَارْثْ نّسْ: ”خْزَارْ، أَقَا سّْنغْ بلِّي شمْ ذ ثَامْغَارْثْ ذَايسْ أَژْرِي.
\v 12 خْمِي شمْ إِ غَا ژَترنْ إِمِيصْرِييّنْ، زمَّارنْ أَذْ إِنِينْ: ’ثَا ذ ثَامْغَارْثْ نّسْ!‘، أَذْ أَيِي نْغنْ ؤُشَا أَذْ شمْ جّنْ ذِي ثُوذَارْثْ.
\v 13 إِنِي، أَقَا شمْ ذ ؤُتْشْمَا، حِيمَا أَذْ أَيِي يِيڒِي ڒْخِيرْ ذِي طّْوعْ نّمْ ؤُشَا أَذْ إِقِّيمْ ڒعْمَارْ إِنُو إِدَّارْ إِ شمْ.“ \x ◘ \xo 12:‏13 \xt أَمز. 20‏:‏12؛ 26‏:‏7. \x*
\m 
\v 14 إِمْسَارْ ؤُمِي يُوذفْ أَبْرَامْ غَارْ مِيصْرَا، ژْرِينْ إِمِيصْرِييّنْ بلِّي ثَامْغَارْثْ ثصْبحْ أَطَّاسْ.
\v 15 ؤُڒَا ذ ڒْحُوكَّامْ ن فِيرْعُونْ، \add أَجدْجِيذْ\add*، ژْرِينْ ت ؤُشَا سّمْغَارنْ ت غَارْ فِيرْعُونْ ؤُشَا إِوْينْ ت غَارْ ثَادَّارْثْ ن فِيرْعُونْ.
\v 16 ؤُشَا إِمْصُورفْ \add فِيرْعُونْ\add* مْلِيهْ أَكْ-ذ أَبْرَامْ ذِي طّْوعْ نّسْ. \add أَمُّو\add* إِ إِكْسِي ؤُدْجِي ذ إِفُونَاسنْ ذ ثْفُونَاسِينْ ذ يغْيَاڒْ ذ إِسمْغَانْ ذ ثِييَّا ذ ثغْيَاڒْ ذ إِڒغْمَانْ. \f ◼ \fr 12:‏16 \ft \bd ’إِڒغْمَانْ‘\bd* - إِڒغْمَانْ ذِي إِسْرَائِيل ؤُ ذِي ثمُّورَا نّغْنِي ذِي شَّارْقْ أَمڒْوَاسُو ذ إِڒغْمَانْ س يِيجّْ ن ثْڭعْرُورْثْ وَاهَا.\f*
\v 17 \add مَاشَا\add* سِيذِي إِوْثَا فِيرْعُونْ ذ \add أَيْثْبَابْ ن\add* ثَادَّارْثْ نّسْ س جّْرَايحْ مْغَارنْثْ ذِي ڒسْبَابْ ن سَارَايْ، ثَامْغَارْثْ ن أَبْرَامْ. \x ◘ \xo 12:‏17 \xt إِزهد. 105‏:‏14. \x*
\v 18 \add خنِّي\add* فِيرْعُونْ إِڒَاغَا-د إِ أَبْرَامْ، إِنَّا أَسْ: ”مَانَاوَايَا إِ ذَايِي ثڭِّيذْ؟ مَاغَارْ وَارْ ذ أَيِي ثنِّيذْ بلِّي نتَّاثْ ذ ثَامْغَارْثْ نّشْ؟
\v 19 مَايمِّي ثنِّيذْ: ’نتَّاثْ ذ ؤُتْشْمَا!‘، أَڒَامِي ت ڭِّيغْ نشّْ ذ ثَامْغَارْثْ إِ يِيخفْ إِنُو؟ ڒخُّو خْزَارْ، أَقَا أَشْ ثَامْغَارْثْ نّشْ، كْسِي \add ت\add*، ثْبعّْذذْ!“
\v 20 يُومُورْ فِيرْعُونْ إِرْيَازنْ نّسْ خَاسْ ؤُشَا سّْقبّْضنْ ث أَكْ-ذ ثمْغَارْثْ نّسْ ؤُ أَكْ-ذ مَارَّا مِينْ ثُوغَا غَارسْ.
\b
\b
\c 13
\s1 أَبْرَامْ ذ لُوطْ فَارْقنْ
\m 
\v 1 أَمُّو إِ يُويُورْ أَبْرَامْ زِي مِيصْرَا غَارْ \add ثمُّورْثْ ن\add* لْجَانُوبْ \add ن كنْعَانْ\add*، نتَّا ذ ثمْغَارْثْ نّسْ، أَكْ-ذ مَارَّا مِينْ غَارسْ، ذ لُوطْ أَكِيذسْ.
\v 2 أَبْرَامْ ثُوغَا غَارسْ أَطَّاسْ ن وَاڭْڒَا ذ ڒبْهَايمْ ذ نُّوقَارْثْ ذ وُورغْ.
\v 3 ؤُشَا إِمُّوطِّي \add زڭْ ومْشَانْ غَارْ ومْشَانْ\add* زِي \add ثمُّورْثْ ن\add* لْجَانُوبْ غَارْ بَايْثْ-إِلْ أَڒْ أَمْشَانْ مَانِي ثُوغَا إِدْجَا ؤُقِيضُونْ نّسْ قْبڒْ، جَارْ بَايْثْ-إِلْ ذ عَايْ، \x ◘ \xo 13:‏3 \xt أَمز. 12‏:‏8. \x*
\v 4 أَڒْ أَمْشَانْ ن ؤُعَالْطَارْ إِ ثُوغَا إِڭَّا قْبڒْ، \add مِينْ خفْ إِسَّارْسْ ثِيغَارْصَا ذ ثوْهِيبِينْ\add*، ؤُشَا ذِينِّي إِڒَاغَا أَبْرَامْ إِسمْ ن سِيذِي. \x ◘ \xo 13:‏4 \xt أَمز. 4‏:‏26؛ 12‏:‏8. \x*
\v 5 ؤُشَا لُوطْ، ونِّي يُويُورنْ أَكْ-ذ أَبْرَامْ، ثُوغَا غَارسْ عَاوذْ ؤُدْجِي ذ إِفُونَاسنْ ذ ثْفُونَاسِينْ ذ إِقِيضَانْ.
\v 6 ثَامُّورْثْ وَارْ ذ أَسنْ ثِيرِيوْ حِيمَا أَذْ قِّيمنْ زدّْغنْ جْمِيعْ، مِينْزِي أَڭْڒَا نْسنْ إِمْغَارْ أَطَّاسْ أَڒْ وَارْ زمَّارنْ أَذْ \add ذِينْ\add* زذْغنْ جْمِيعْ. \x ◘ \xo 13:‏6 \xt أَمز. 36‏:‏7. \x*
\v 7 ؤُشَا إِمْسَارْ ؤُمْشُوبّشْ جَارْ إِمكْسَاونْ ن ڒبْهَايمْ ن أَبْرَامْ ذ إِمكْسَاونْ ن ڒبْهَايمْ ن لُوطْ. ثُوغَا أَيْثْ ن كنْعَانْ ذ إِفِيرِيزِييّنْ زدّْغنْ ڒخْذنِّي ذِي ثمُّورْثْ. \f ◼ \fr 13:‏7 \ft \bd ’إِمكْسَاونْ‘\bd* - نِيغْ ’إِنِيتْشَانْ‘.\f*  \x ◘ \xo 13:‏7 \xt أَمز. 12‏:‏6. \x*
\v 8 إِنَّا أَبْرَامْ إِ لُوطْ: ”وَارْ إِتِّيڒِي عَاذْ ؤُمْشُوبّشْ جَارْ أَيِي ذ شكْ، جَارْ إِمكْسَاونْ إِنُو ذ إِمكْسَاونْ نّشْ، مِينْزِي نشِّينْ ذ إِرْيَازنْ أَوْمَاثنْ.
\v 9 مَا وَارْ ثَارْزمْ ثمُّورْثْ زَّاثشْ؟ تّْزَاوْڭغْ شكْ أَذْ خَافِي ثبْضِيضْ، مَا خْ ؤُزڒْمَاضْ، نِيغْ خْ يفُوسْ! مَاڒَا شكْ ثْرُوحذْ خْ يفُوسْ، نشّْ أَذْ رَاحغْ خْ ؤُزڒْمَاضْ.“ \x ◘ \xo 13:‏9 \xt أَمز. 20‏:‏15؛ 34‏:‏10. \x*
\m 
\v 10 إِسّْڭعّذْ لُوطْ ثَامُوغْڒِي نّسْ ؤُشَا إِژْرَا أَذوَّارْ ن \add يغْزَارْ ن\add* لْ-ؤُرْذُونْ ثُوغَا مَارَّا إِسْوَا. قْبڒْ أَردّدْجْ زِي سِيذِي ثُوغَا سَاذُومْ ذ عَامُورَّا أَمْ جّنّثْ ن سِيذِي، أَمْ ثمُّورْثْ ن مِيصْرَا خْمِي د غَا ثَاسذْ غَارْ صُوغَارْ.
\v 11 ؤُشَا إِخْضَارْ لُوطْ إِ يِيخفْ نّسْ مَارَّا أَذوَّارْ ن \add يغْزَارْ ن\add* لْ-ؤُرْذُونْ ؤُ إِفْسِي لُوطْ إِقِيضَانْ نّسْ \add ؤُشَا يُويُورْ\add* غَارْ شَّارْقْ. \add أَمُّو إِ\add* مّْسبْضَانْ نِيثْنِي إِجّنْ خْ ونّغْنِي.
\m 
\v 12 أَبْرَامْ إِزْذغْ ذِي ثمُّورْثْ ن كنْعَانْ، \add مَاشَا\add* لُوطْ إِزْذغْ ذِي ثْندَّامْ ن ؤُذوَّارْ \add ن لْ-ؤُرْذُونْ\add*، إِوْثَا إِقِيضَانْ نّسْ أَڒْ سَاذُومْ.
\v 13 إِرْيَازنْ ن سَاذُومْ ثُوغَا أَثنْ ذ إِعفَّاننْ ذ إِمذْنَابْ أَكْ-ذ سِيذِي أَڒْ طَّارْفْ. \x ◘ \xo 13:‏13 \xt أَمز. 18‏:‏20؛ حِز. 16‏:‏49. \x*
\v 14 أَوَارْنِي ڒَامِي خَاسْ إِمّْسبْضَا لُوطْ، إِنَّا سِيذِي إِ أَبْرَامْ: ”سَارّحْ ڒخُّو ثِيطَّاوِينْ نّشْ، ثخْزَارذْ زڭْ ومْشَانْ مَانِي ثدْجِيذْ غَارْ شَّامَالْ، غَارْ لْجَانُوبْ، غَارْ شَّارْقْ ؤُ غَارْ ڒْغَارْبْ،
\v 15 مِينْزِي مَارَّا ثَامُّورْثْ إِ ثتّْوَاڒِيذْ، أَذْ أَشْ ت وْشغْ، إِ شكْ ذ زَّارِيعثْ نّشْ إِ ڒبْذَا. \x ◘ \xo 13:‏15 \xt أَمز. 12‏:‏7؛ 15‏:‏7، 18؛ 17‏:‏8؛ 26‏:‏4؛ أَعَوذ. 34‏:‏4؛ ڒخ. 7‏:‏5. \x*
\v 16 أَذْ ڭّغْ زَّارِيعثْ نّشْ أَمْ ثْعجَّاجْثْ ن ثمُّورْثْ، حِيمَا، مَاڒَا إِزمَّارْ حذْ أَذْ إِحْسبْ ثَاعجَّاجْثْ ن ثمُّورْثْ، ؤُڒَا ذ زَّارِيعثْ نّشْ ثْزمَّارْ عَاوذْ أَذْ ثتّْوَاحْسبْ. \x ◘ \xo 13:‏16 \xt أَمز. 15‏:‏5؛ 17‏:‏4؛ أَعَوذ. 10‏:‏22؛ إِرْم. 33‏:‏22؛ رُوم. 4‏:‏17، 18؛ عبر. 11‏:‏12. \x*
\v 17 كَّارْ، شُوقْ ذِي ثمُّورْثْ ذِي ثُوزّڭَّارْثْ نّسْ ذ ثِيرُو نّسْ، مِينْزِي إِ شكْ ؤُمِي ت إِ غَا وْشغْ.“
\v 18 \add خنِّي\add* إِكّسْ أَبْرَامْ إِقِيضَانْ نّسْ ؤُشَا يُويُورْ أَذْ إِزْذغْ غَارْ ثْشجُّورَا ن يِيڭّْ ن مَامْرِي، إِنِّي إِدْجَانْ ذِي حَابْرُونْ. ذِينِّي إِبْنَا إِجّْ ن ؤُعَالْطَارْ إِ سِيذِي. \x ◘ \xo 13:‏18 \xt أَمز. 14‏:‏13. \x*
\b
\b
\c 14
\s1 أَبْرَامْ إِفكّْ لُوطْ ؤُشَا إِمْسَاڭَارْ أَكْ-ذ مَالْكِيصَاذِيقْ
\m 
\v 1 ذڭْ وُوسَّانْ ن أَمْرَافِيلْ، أَجدْجِيذْ ن شِينْعَارْ، ذ أَرِييُوشْ، أَجدْجِيذْ ن إِلَّاسَارْ، ذ كِيذُورْلَاعُومرْ، أَجدْجِيذْ ن عِيلَامْ، ذ ثِيذَالْ، أَجدْجِيذْ ن ڒڭْنُوسْ، إِمْسَارْ بلِّي
\v 2 إِنَا ڭِّينْ ڒْبَارُوضْ أَكْ-ذ بِيرَا، أَجدْجِيذْ ن سَاذُومْ ؤُ أَكْ-ذ بِيرْشَاعْ، أَجدْجِيذْ ن عَامُورَّا، ؤُ \add أَكْ-ذ\add* شِينَابْ، أَجدْجِيذْ ن أَذْمَا، ؤُ \add أَكْ-ذ\add* شِيمْ‘إِبَارْ، أَجدْجِيذْ ن صابُويِيمْ، ؤُ \add أَكْ-ذ\add* ؤُجدْجِيذْ ن بِيلَاعْ، ونِّي إِدْجَانْ ذ صُوغَارْ.
\v 3 مَارَّا إِنَا مُوننْ ذِي ڒوْضَا ن ثغْزُورْثْ ن سِيذِّيمْ، أَقَا ذ ڒبْحَارْ أَمدْجَاحْ. \f ◼ \fr 14:‏3 \ft \bd ’ڒبْحَارْ أَمدْجَاحْ‘\bd* - نِيغْ ’إِلّْ أَمدْجَاحْ‘.\f*
\v 4 ثُوغَا خدّْمنْ ثنْعَاشْ ن إِسڭّْوُوسَا إِ كِيذُورْلَاعُومِيرْ، \add مَاشَا\add* غَارْ ؤُسڭّْوَاسْ وِيسّْ ثْڒطَّاشْغوّْغنْ.
\v 5 ؤُشَا ذڭْ ؤُسڭّْوَاسْ وِيسّْ أَرْبعْطَاشْ يُوسَا-د كِيذُورْلَاعُومِيرْ ذ إِجدْجِيذنْ إِ \add يدْجَانْ\add* أَكِيذسْ ؤُشَاغڒْبنْ خْ إِرَافَاوِييّنْ ذِي أَشْثِيرُوثْ-قَارْنَايْمْ، خْ إِزُوزِييّنْ ذِي هَامْ، خْ إِمِيثِييّنْ ذِي شَاوَا-قَارْيَاثَايِيمْ \f ◼ \fr 14:‏5 \ft \bd ’إِرَافَاوِييّنْ‘\bd* - إِجّْ ن ڒْڭنْسْ ن جّْوَاهڒْ أَمشْنَاوْ إِعَانَاقِييّنْ ذ إِزُوزِييّنْ ذ إِمِييّنْ. إِسمْ وَانِيثَا ؤُڒَا ذ إِسمْ ن مَارَّا ڒڭْنُوسْ-أَ إِنِّي جَارْ أَسنْ جّْوَاهڒْ.\f*  \x ◘ \xo 14:‏5 \xt أَمز. 15‏:‏20؛ أَعَوذ. 2‏:‏10، 11. \x*
\v 6 ؤُ خْ إِخُورِييّنْ ذڭْ إِذُورَارْ نْسنْ ن سَاعِيرْ أَڒْ فَارَانْ، ونِّي \add إِدْجَانْ\add* زَّاثْ إِ ڒخْڒَا.
\v 7 \add أَوَارْنِي أَيَا\add* ذوْڒنْ-د، ؤُسِينْ-د غَارْ عَايْنْ-مِيشْفَاثْ، ونِّي ذ قَاذَاشْ، ؤُشَاغڒْبنْ \add خْ يوْذَانْ نِّي إِزدّْغنْ ذِي\add* مَارَّا ثَامُّورْثْ ن أَيْثْ ن عَامَالِيقْ ؤُ عَاوذْ خْ إِمُورِييّنْ إِنِّي إِزدّْغنْ ذِي هَاصُّونْ-ثَامَارْ. \f ◼ \fr 14:‏7 \ft \bd ’عَايْنْ-مِيشْفَاثْ‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَنُو ن ڒْحُوكْمْ‘. \bd ’كَاذسْ‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَمْقدَّاسْ‘. \bd ’هَاصُّونْ-ثَامَارْ‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَزْبَارْ ن ثِينِي‘.\f*
\m 
\v 8 \add خنِّي\add* إِفّغْ ؤُجدْجِيذْ ن سَاذُومْ ذ ؤُجدْجِيذْ ن عَامُورَّا ذ ؤُجدْجِيذْ ن أَذْمَا ذ ؤُجدْجِيذْ ن صابُويِيمْ ذ ؤُجدْجِيذْ ن بِيلَاعْ، أَقَا-ت ذ صُوغَارْ. رُوحنْ نِيثْنِي غَارْ ڒوْضَا ن ثغْزُورْثْ ن سِيذِّيمْ، مَاحنْذْ أَذْ مّنْغنْ
\v 9 أَكْ-ذ كِيذُورْلَاعُومِيرْ، أَجدْجِيذْ ن عِيلَامْ ذ ثِيذْعَالْ، أَجدْجِيذْ ن ڒڭْنُوسْ، ذ أَمْرَافِيلْ، أَجدْجِيذْ ن شِينْعَارْ، ذ أَرْيُوكْ، أَجدْجِيذْ ن إِلَّاسَارْ: أَربْعَا ن إِجدْجِيذنْ \add ڭِّينْ ڒْبَارُوضْ\add* أَكْ-ذ خمْسَا. \f ◼ \fr 14:‏9 \ft \bd ’أَجدْجِيذْ ن جُويِيمْ‘\bd* - إِخْسْ أَذْ يِينِي ’أَجدْجِيذْ ن ڒڭْنُوسْ‘.\f*
\v 10 ثُوغَا ڒوْضَا ن ثغْزُورْثْ ن سِيذِّيمْ ثشُّورْ س وَانُوثنْ ن ثِيزفْثْ. ؤُشَا أَروْڒنْ إِجدْجِيذنْ ن سَاذُومْ ذ عَامُورَّا ؤُشَا وْضَانْ ذَايْسنْ، ؤُ إِنِّي إِقِّيمنْ أَروْڒنْ غَارْ إِذُورَارْ.
\v 11 كْسِينْ مَارَّا أَڭْڒَا ن سَاذُومْ ذ عَامُورَّا ذ مَارَّا مَاشَّا إِ خزْننْ ؤُشَا ؤُيُورنْ.
\v 12 كْسِينْ عَاوذْ لُوطْ، مِّيسْ ن ؤُمَاسْ ن أَبْرَامْ، ذ وَاڭْڒَا نّسْ ؤُشَا رُوحنْ. نتَّا ثُوغَا إِزدّغْ ذِي سَاذُومْ.
\m 
\v 13 \add خنِّي\add* يُوسَا-د إِجّنْ زڭْ إِنِّي يَاروْڒنْ، إِنَّا مَانْ أَيَا إِ أَبْرَامْ، أَعِيبْرَانِي، ونِّي ثُوغَا إِزدّْغنْ غَارْ ثْشجُّورَا ن يِيڭّْ ن مَامْرِي، أَرْيَازْ ذ أَمُورِييْ، ؤُمَاسْ ن أَشْكُولْ ذ عَانِيرْ. نِيثْنِي ذ أَرْفِيقنْ ذِي ڒْعَاهْذْ ن أَبْرَامْ. \f ◼ \fr 14:‏13 \ft \bd ’أَعِيبْرَانِي‘\bd* - ثَانِيثَا ذ ثْوَاڒَا ثَامزْوَارُوثْ إِ نتَّافْ إِسمْ-أَ ذڭْ وذْلِيسْ إِقدّْسنْ. ذڭْ وذْلِيسْ ’أَمزْوَارُو‘، ؤُذمْ 39، أَيَاثْ 4 ذ 17 ؤُڒَا ذڭْ وُوذمْ 41، أَيثْ 21 نتَّافْ إِسمْ-أَ أَمْ ؤُشيَّارْ غَارْ يُوسُوفْ ؤُ ذڭْ وذْلِيسْ أَمزْوَارُو (أَمز. 43:32) أَمْ إِجّْ ن ؤُشيَّارْ غَارْ مَارَّا إِهنْجِيرنْ ن يَاعْقُوبْ (خْزَارْ عَاوذْ أَمز. 40:15).\f*  \x ◘ \xo 14:‏13 \xt أَمز. 13‏:‏18. \x*
\v 14 \add ڒَْامِي\add* إِسْڒَا أَبْرَامْ بلِّي ؤُمَاسْ طّْفنْ ث ذ أَمحْبُوسْ، يِيوِي \add إِرْيَازنْ\add* إِنِّي إِذَارّْبنْ إِ ؤُمنْغِي، إِنِّي د-إِتّْوَاخڒْقنْ ذِي ثَادَّارْثْ نّسْ، ذِي ثڒْثْ-مْيَا ؤُ-ثْمنْطَاشْ، ؤُشَا إِضْفَارْ إِ-ثنْ أَڒْ دَان.
\v 15 س دْجِيرثْ بْضَانْ خَاسنْ نِيثْنِي، \add ڭِّينْ ثرْفِيقِينْ\add*، نتَّا ذ إِمْسخَّارنْ نّسْ، ؤُشَا إِغْڒبْ خَاسنْ ؤُشَا إِضْفَارْ إِ-ثنْ غَارْ \add ثنْذِينْثْ ن\add* حُوبَا، ثنِّي \add إِدْجَانْ\add* خْ ؤُزڒْمَاضْ ن ذِيمَاشْقْ.
\v 16 يَارَّا-د مَارَّا أَڭْڒَا ؤُڒَا ذ ؤُمَاسْ لُوطْ ذ وَاڭْڒَا نّسْ ؤُڒَا ذ ثِيمْغَارِينْ ذ ڒْڭنْسْ.
\m 
\v 17 ؤُمِي د-إِعْقبْ، أَوَارْنِي ڒَامِي إِغْڒبْ نتَّا خْ كِيذُورْلَاعُومِيرْ ؤُ خْ إِجدْجِيذنْ نِّي ثُوغَا أَكِيذسْ، إِفّغْ ؤُجدْجِيذْ ن سَاذُومْ حِيمَا أَذْ ث إِڒْقَا ذِي ڒوْضَا ن ثغْزُورْثْ ن شَاوَا، ثنِّي إِدْجَانْ ذ ثَاغْزُورْثْ ن ؤُجدْجِيذْ.
\v 18 ؤُ مَالْكِيصَاذِيقْ، أَجدْجِيذْ ن شَالِيمْ، يِيوِي-د أَغْرُومْ ذ بِينُو. نتَّا ثُوغَا ذ أَكهَّانْ ن أَربِّي، أَمْعُودْجِي خْ كُوڒْشِي. \f ◼ \fr 14:‏18 \ft \bd ’مَالْكِيصَاذِيقْ‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَجدْجِيذْ أَمْسڭّذْ‘ نِيغْ ’أَجدْجِيذْ ذ أَمْثِيقِّي‘.\f*  \x ◘ \xo 14:‏18 \xt عبر. 7‏:‏1، 2، 3. \x*
\v 19 إِبَارْكْ إِ-ث، إِنَّا أَسْ: ”أَذْ إِتّْوَابَاركْ أَبْرَامْ زِي أَربِّي، أَمْعُودْجِي خْ كُوڒْشِي، ونِّي إِڭِّينْ إِجنْوَانْ ذ ثمُّورْثْ.
\v 20 أَذْ إِتّْوَابَاركْ أَربِّي، أَمْعُودْجِي خْ كُوڒْشِي، ونِّي إِسلّْمنْ إِغْرِيمنْ نّشْ ذڭْ إِفَاسّنْ نّشْ!“ ؤُشَا \add أَبْرَامْ\add* إِوْشَا أَسْ ڒعْشُورْ ن مَارَّا.
\m 
\v 21 ؤُشَا إِنَّا ؤُجدْجِيذْ ن سَاذُومْ إِ أَبْرَامْ: ”أوْشْ أَيِي مَارَّا مِينْ \add إِدَّارنْ\add*، مَاشَا كْسِي أَڭْڒَا إِ يِيخفْ نّشْ.“
\v 22 \add مَاشَا\add* أَبْرَامْ يَارَّا-د خْ ؤُجدْجِيذْ ن سَاذُومْ: ”أَقَا سّْڭعّْذغْ أَفُوسْ إِنُو غَارْ سِيذِي أَربِّي، أَمْعُودْجِي خْ كُوڒْشِي، ونِّي إِڭِّينْ أَجنَّا ذ ثمُّورْثْ، \add جُّودْجغْ\add*
\v 23 مَاحنْذْ وَارْ كسِّيغْ أَفِيڒُو نِيغْ ثَاحزّمْثْ ن سَانْذَالِييَاثْ ؤُڒَا \add شَا ن ڒْحَاجّثْ\add* زِي مَارَّا مِينْ إِدْجَانْ نّشْ، حِيمَا وَارْ ثقَّارذْ: ’نشّْ سّْثجَّارغْ أَبْرَامْ!‘
\v 24 وَارْ غَارِي ذَايسْ بُو ثَاسْغَارْثْ! مْغِيرْ مِينْ شِّينْ إِمْسخَّارنْ ذ ثسْغَارْثْ ن إِرْيَازنْ نِّي كِيذِي إِرُوحنْ، أَنِيرْ ذ إِشْكُولْ ذ مَامْرِي، أجّْ إِ-ثنْ أَذْ كْسِينْ ثَاسْغَارْثْ نْسنْ!“
\b
\b
\c 15
\s1 ڒْعَاهْذْ ن أَربِّي أَكْ-ذ أَبْرَامْ
\m 
\v 1 أَوَارْنِي مَانْ أَيَا يُوسَا-د وَاوَاڒْ ن سِيذِي غَارْ أَبْرَامْ ذڭْ إِجّْ ن ڒوْحِييْ. إِنَّا أَسْ ”وَارْ تّڭّْوذْ شَا، أَبْرَامْ، نشّْ ذ أَسڒْقِي إِ شكْ، ڒْمُونثْ نّشْ ثمْغَارْ أَطَّاسْ \add ذ نشّْ\add*.“ \x ◘ \xo 15:‏1 \xt إِزهد. 16‏:‏6؛ 18‏:‏3؛ 19‏:‏12. \x*
\v 2 ؤُشَا إِنَّا أَبْرَامْ: ”سِيذِي إِنُو، سِيذِي، مِينْ ذ أَيِي غَا ثوْشذْ، مَاغَارْ نشّْ أَذْ رَاحغْ أَمُّو بْڒَا مِّي ؤُ أَلِيعَازِيرْ زِي ذِيمَاشْقْ أَذْ يِيڒِي \add أَمشْنَاوْ\add* مِّي خْ وَاڭْڒَا ن ثَادَّارْثْ إِنُو؟“ \f ◼ \fr 15:‏2 \ft \bd ’أَلِيعَازِيرْ‘\bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’ونِّي غَارْ إِدْجْ أَربِّي ذ أَمْعَاونْ نّسْ‘ نِيغْ ’ونِّي ؤُمِي إِوْشَا أَربِّي أَفُوسْ‘.\f*
\v 3 إِنَّا أَبْرَامْ عَاوذْ: ”خْزَارْ، وَارْ ذ أَيِي ثوْشِيذْ زَّارِيعثْ، س ؤُينِّي، \add ونِّي إِدْجَانْ أَمْ\add* مِّي ن ثَادَّارْثْ إِنُو، أَذْ يِيڒِي ذ أَوْرِيثْ إِنُو!“ \f ◼ \fr 15:‏3 \ft \bd ’زَّارِيعثْ‘\bd* - إِخْسْ أَذْ يِينِي ’ثَارَّاوْثْ‘.\f*
\v 4 ؤُشَا خْزَارْ، أَوَاڒْ ن سِيذِي يُوسَا-د غَارسْ، إِنَّا: ”وَارْ شكْ إِوَارّثْ شَا وَا، مَاشَا ونِّي إِ غَا إِفّْغنْ زَّايكْ أَذْ يِيڒِي ذ أَوْرِيثْ نّشْ.“
\v 5 إِسُّوفّغْ إِ-ث غَارْ بَارَّا، إِنَّا: ”خْزَارْ غَارْ ؤُجنَّا، ثْحسْبذْ إِثْرَانْ، مَاڒَا ثْزمَّارذْ أَذْ ثنْ ثْحسْبذْ!“ ؤُشَا إِنَّا أَسْ: ”أَمُّو إِ غَا ثِيڒِي زَّارِيعثْ نّشْ!“ \x ◘ \xo 15:‏5 \xt ؤُف. 32‏:‏13؛ أَعَوذ. 10‏:‏22؛ رُوم. 4‏:‏18؛ عبر. 11‏:‏12. \x*
\v 6 ؤُشَا نتَّا يُومنْ ذِي سِيذِي ؤُشَا إِحْسبْ أَسْ ث-إِ-د ذ ثَاسڭْذَا. \f ◼ \fr 15:‏6 \ft \bd ’إِحسْبْ أَسْ ث-إِ-د ذ ثَاسڭْذَا‘\bd* - نِيغْ ’إِڭَّا أَسْ ث إِ نتَّا ذ ثَاسڭْذَا‘.\f*  \x ◘ \xo 15:‏6 \xt رُوم. 4‏:‏3، 9 ،18، 22؛ ڭال. 3‏:‏6؛ يَاع. 2‏:‏23. \x*
\m 
\v 7 إِنَّا أَسْ عَاوذْ: ”نشّْ ذ سِيذِي، ونِّي شكْ د-يِيوْينْ زِي ؤُرْ ن إِكَالْذَانِييّنْ، حِيمَا أَذْ أَشْ وْشغْ ثَامُّورْثْ-أَ ذ ڒْوَارْثْ.“ \x ◘ \xo 15:‏7 \xt إِزهد. 105‏:‏11. \x*
\v 8 \add خنِّي\add* نتَّا إِنَّا: ”\add أَ\add* سِيذِي إِنُو، سِيذِي، س مِينْزِي إِ غَا سّْنغْ، بلِّي أَذْ ت وَارْثغْ؟“
\v 9 إِنَّا أَسْ نتَّا: ”أَوِي أَيِي-د إِشْثْ ن ثْعجْمِيثْ ن ثْڒَاثَا ن إِسڭّْوُوسَا ذ إِجّْ ن إِغَايْضْ ن ثْڒَاثَا إِسڭّْوُوسَا ذ إِجّْ ن إِشَارِّي ن ثْڒَاثَا إِسڭّْوُوسَا ذ إِشْثْ ن ثجْلِيلّحْثْ ذ إِجّْ ن وذْبِيرْ ذ أَمژْيَانْ.“
\v 10 نتَّا يِيوِي-د غَارسْ مَارَّا مَانْ أَيَا، إِبْضَا ثنْ خْ وزْينْ ؤُ إِڭَّا كُوڒْ أَزْينْ قِيبَاتْشْ إِ ونّغْنِي، \add مَاشَا\add* وَارْ إِبْضِي شَا إِجْضَاضْ. \x ◘ \xo 15:‏10 \xt إِرْم. 34‏:‏18، 19\x*
\v 11 هْوَانْ-د إِجْضَاضْ إِتّْكشَّاضنْ خْ إِمُورْضَاسْ، \add مَاشَا\add* أَبْرَامْ يُوژّڒْ خَاسنْ.
\v 12 غَارْ ؤُغدْجَايْ ن ثْفُوشْثْ، إِمْسَارْ أَقَا يُوسَا أَسْ-د إِ أَبْرَامْ إِجّْ ن يِيضصْ يُودْجغْ، ؤُشَا خْزَارْ، ثِيڭّْوُوذِي \add ذ\add* ثَادْجسْثْ إِحذْقنْ وْضَانْ-د خَاسْ.
\v 13 \add خنِّي\add* إِنَّا إِ أَبْرَامْ: ”سّنْ س ثِيذتّْ أَقَا زَّارِيعثْ نّشْ أَذْ ثِيڒِي ذ ثَابَارَّانشْثْ ذڭْ إِشْثْ ن ثمُّورْثْ إِ وَارْ إِدْجِينْ نّسْ ؤُشَا أَذْ أَسنْ خذْمنْ \add أَمْ إِسمْغَانْ\add* ؤُ نِيثْنِي أَذْ خَاسنْ ڭّنْ أَغِيڒْ أَربْعَا-مْيَا ن إِسڭّْوُوسَا. \x ◘ \xo 15:‏13 \xt ؤُف. 12‏:‏40؛ ڒخ. 7‏:‏6؛ ڭال. 3‏:‏17. \x*
\v 14 \add مَاشَا\add* ڒْڭنْسْ ؤُمِي غَا خذْمنْ أَمْ إِسمْغَانْ، أَذْ خَاسنْ حكْمغْ عَاوذْ، ؤُشَا أَوَارْنِي مَانْ أَيَا أَذْ فّْغنْ س وَاڭْڒَا إِمْغَارْ. \x ◘ \xo 15:‏14 \xt ؤُف. 3‏:‏22؛ 11‏:‏2؛ 12‏:‏35،36. \x*
\v 15 أَذْ ثتّْوَاسّْمُونذْ غَارْ ڒجْذُوذْ نّشْ س ڒهْنَا ؤُشَا أَذْ شكْ نضْڒنْ أَمْ ؤُمشَّايْبُو إِوقَّارْ. \x ◘ \xo 15:‏15 \xt أَمز. 25‏:‏7، 8. \x*
\v 16 جِّيڒْ وِيسّْ أَربْعَا أَذْ د-إِعْقبْ ذَانِيثَا، مِينْزِي \add ڒْقدّْ ن\add* ڒْمُوعْصِييّثْ ن إِمُورِييّنْ عَاذْ وَارْ إِكمّڒْ.“ \x ◘ \xo 15:‏16 \xt ؤُف. 12‏:‏40. \x*
\v 17 ڒَامِي ثغْڒِي ثْفُوشْثْ ؤُشَا ثذْوڒْ ذ ثَادْجسْثْ، ثُوغَا ذِينْ أَفَارَّانْ إِدّخّْننْ ؤُ إِعْذُو إِجّْ ن وصْفضْ ن ثْمسِّي جَارْ إِزيْنَانْ نِّي. \f ◼ \fr 15:‏17 \ft \bd أَفسَّارْ\bd* - ڒَامِي ڭِّينْ ثْنَاينْ ن إِجدْجِيذنْ زِيشْ إِجّْ ن ڒْعَاهْذْ ذِي شَّارْقْ-أَمڒْوَاسُو كْسِينْ نِيثْنِي إِجّْ ن ؤُمدَّارْ إِ ثْغَارْصْثْ، بْضَانْ ث ذ إِزيْنَانْ ؤُشَا سَّارْسنْ أَزْينْ غَارْ إِجّْ ن ؤُغزْذِيسْ ؤُ أَزْينْ غَارْ إِجّْ ن ؤُغزْذِيسْ نّغْنِي. خنِّي ثُوغَا خْ ؤُجدْجِيذْ نِّي ثُوغَا ذ أَمُوقْڒِيڒْ زَّايْسنْ أَذْ يُويُورْ ذِي ڒْوسْثْ ن ثْنَاينْ ن إِزِييْنَانْ أَمْ إِقَّارْ أَقَا أَجدْجِيذْ ونِّي ذ أَمقّْرَانْ زَّايْسنْ غَارسْ ڒْحقّْ حِيمَا أَذْ كِيذسْ إِڭّْ أَمشْنَاوْ مِينْ إِڭَّا أَكْ-ذ ؤُمُودَّارْ إِ ؤُمِي غَارْصنْ، مَاڒَا نتَّا وَارْ إِكمّڒْ ڒْعَاهْذْ إِ إِڭَّا أَكِيذسْ (خْزَارْ إِرْم. 34:18-20). ذڭْ وَاوَاڒنْ-أَ نتّْوَاڒَا أَقَا أَربِّي ونِّي ذ أَمقّْرَانْ خْ إِبْرَاهِيمْ، ثُوغَا إِڭُّورْ ذِي ڒْوسْثْ ن إِزيْنَانْ ن ؤُمدَّارْ ذِي صِّيفثْ ن وسْفضْ أَمْ ثُوغَا إِبْرَاهِيمْ إِتّْبدَّا غَارْ ؤُغزْذِيسْ. مَانْ أَيَا إِخْسْ أَذْ يِينِي أَقَا أَربِّي س يِيخفْ نّسْ ذ نتَّا إِ إِقضْعنْ ڒْعَاهْذْ أَكْ-ذ إِبْرَاهِيمْ مِينْزِي أَربِّي إِتّْحِينَّا خْ بْنَاذمْ، إِسّنْ بْنَاذمْ وَارْ إِزمَّارْ أَذْ إِكمّڒْ ؤُڒَا ذ إِجّْ ن ڒْعَاهْذْ أَكِيذسْ. بْنَاذمْ إِزمَّارْ مْغِيرْ أَذْ إِتّْوَاسّنْجمْ خْمِي إِ غَا يَامنْ ذِي ڒْعَاهْذْ إِ إِڭَّا أَربِّي ذِي مِّيسْ، إِخْسْ أَذْ يِينِي ذِي لْمَاسِيحْ ونِّي إِوْشِينْ إِخفْ نّسْ ذ ثْغَارْصْثْ إِ دّْنُوبْ ن إِوْذَانْ.\f*
\v 18 ذڭْ وَاسّْ نِّي نِّيثْ إِڭَّا سِيذِي إِجّْ ن ڒْعَاهْذْ أَكْ-ذ أَبْرَامْ، إِنَّا: ”إِ زَّارِيعثْ نّشْ ؤُمِي وْشِيغْ ثَامُّورْثْ-أَ زڭْ إِغْزَارْ ن مِيصْرَا أَڒْ إِغْزَارْ أَمقّْرَانْ، إِغْزَارْ ن لْفُورَاطْ: \x ◘ \xo 15:‏18 \xt أَمز. 12‏:‏7؛ 13‏:‏15؛ 24‏:‏7؛ 26‏:‏4؛ ؤُف. 32‏:‏13؛ أَعَوذ. 1‏:‏8؛ 34‏:‏4. \x*
\v 19 \add ثَامُّورْثْ ن\add* إِقِينِييْ\add ينْ\add*، إِقنِيزِييْينْ، إِقَاذْمِييْينْ،
\v 20 إِحِيتِّييْ\add ينْ\add*، إِفِيرْزِييْ\add ينْ\add*، إِرَافَاوِييّنْ،
\v 21 إِمُورِييْ\add ينْ\add*، أَيْثْ ن كنْعَانْ، إِڭِيرْڭَاشِييْ\add ينْ\add* ذ إِيِيبُوسِييْ\add ينْ\add*.“
\b
\b
\c 16
\s1 هَاجَارْ ذ إِسْمَاعِيلْ
\m 
\v 1 سَارَايْ، ثَامْغَارْثْ ن أَبْرَامْ، وَارْ ذ أَسْ د-ثِيرُووْ شَا. ثُوغَا غَارسْ إِشْثْ ن ثَايَّا زِي مِيصْرَا قَّارنْثْ أَسْ هَاجَارْ.
\v 2 ثنَّا سَارَايْ إِ أَبْرَامْ: ”أَقَا ثژْرِيذْ بلِّي سِيذِي إِطّفْ خَافِي ثَارْوَا. أَذفْ خْ ثَايَّا إِنُو، بَالَاكْ أَذْ زَّايسْ كْسِيغْ ثَارْوَا.“ أَبْرَامْ ثُوغَا إِسّْحسَّا غَارْ سَارَايْ. \f ◼ \fr 16:‏2 \ft \bd ’غَارْ سَارَايْ‘\bd* - أَمْ إِكْمڒْ ’غَارْ ثْمِيجَّا ن سَارَايْ‘.\f*
\v 3 أَوَارْنِي ڒَامِي إِزْذغْ أَبْرَامْعشْرَا ن إِسڭّْوُوسَا ذِي ثمُّورْثْ ن كنْعَانْ، ثِيوِي-د سَارَايْ، ثَامْغَارْثْ ن أَبْرَامْ، ثَايَّا نّسْ هَاجَارْ، ثنِّي زِي مِيصْرَا، ؤُشَا ثوْشَا أَسْ-د إِ أَبْرَامْ، أَرْيَازْ نّسْ، ذ ثَامْغَارْثْ نّسْ.
\v 4 يُوذفْ خْ هَاجَارْ ؤُشَا نتَّاثْ ثكْسِي دّيْسثْ. ؤُمِي ثژْرَا بلِّي ثكْسِي دّيْسثْ، خنِّي ثذْوڒْ لَالَّاسْ ثتّْوَاسّحْقَارْ ذِي ثِيطَّاوِينْ نّسْ.
\v 5 ثنَّا سَارَايْ إِ أَبْرَامْ: ”زِي سِّيبّثْ نّشْ ڭِّينْ ذَايِي ڒْمُونْكَارْ. نشّْ ڭِّيغْ ثَايَّا إِنُو ذڭْ وحْسِينْ نّشْ. ؤُمِي ثژْرَا بلِّي ثكْسِي دّيْسثْ، ذوْڒغْ ذ ثَامحْڭُورثْ ذِي ثِيطَّاوِينْ نّسْ. أجّْ أَذْ إِحْكمْ سِيذِي جَارْ أَيِي ذ شكْ!“
\v 6 إِنَّا أَبْرَامْ إِ سَارَايْ: ”خْزَارْ، ثَايَّا نّمْ ذڭْ إِفَاسّنْ نّمْ. أڭّْ زَّايسْ مِينْ ثتّْوَاڒِيذْ شمْ مْلِيحْ ذِي ثِيطَّاوِينْ نّمْ.“ ؤُشَا سَارَايْ ثْقمّعْ إِ-ت ؤُ خنِّي نتَّاثْ ثَارْوڒْ زَّايسْ.
\m 
\v 7 ؤُشَا لْمَالَاكْ ن سِيذِي إِڒْقَا إِ-ت غَارْ ثَاڒَا ن وَامَانْ ذِي ڒخْڒَا، غَارْ ثَاڒَا ذڭْ وبْرِيذْ إِتَّاوْينْ غَارْ شُورْ. \f ◼ \fr 16:‏7 \ft \bd ’شُورْ‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’ڒْْحِيضْ‘. ثَانْذِينْثْ-أَ ثُوغَا غَارْ ويْمِيرْ جَارْ كنْعَانْ ذ مِيصْرَا.\f*
\v 8 إِنَّا: ”هَاجَارْ، ثَايَّا ن سَارَايْ، مَانِيسْ د-ثُوسِيذْ ؤُ مَانِي غَا ثْرَاحذْ؟“ نتَّاثْ ثنَّا: ”تّْرَاكّْوَاڒغْ زڭْ وُوذمْ ن لَالَّا سَارَايْ!“
\v 9 خنِّي إِنَّا أَسْ لْمَالَاكْ ن سِيذِي: ”ذْوڒْ غَارْ لَالَّامْ، ؤُضَارْ سَاذُو إِفَاسّنْ نّسْ.“
\v 10 إِنَّا أَسْ عَاوذْ لْمَالَاكْ ن سِيذِي: ”أَذْ كتَّارغْ أَطَّاسْ زَّارِيعثْ نّمْ، أَڒْ وَارْ إِزمَّارْ أَذْ ثتّْوَاحْسبْ ڒَامِي إِ غَا ثِيڒِي ذڭْ وَاطَّاسْ.“
\v 11 إِنَّا أَسْ لْمَالَاكْ ن سِيذِي عَاوذْ: ”أَقَا ڒخُّو، ثكْسِيذْ دّيْسثْ ؤُشَا أَذْ ثَارْوذْ أَسيْمِي. أَذْ أَسْ ثڭّذْ إِسْمَاعِيلْ، مِينْزِي سِيذِي إِسْڒَا أَمْ ذِي ڒمْحَاينْ نّمْ. \f ◼ \fr 16:‏11 \ft \bd ’إِسْمَاعِيلْ‘\bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَربِّي أَذْ إِسڒْ‘ نِيغْ ’ونِّي ؤُمِي إِ غَا إِسڒْ أَربِّي‘ نِيغْ ’ونِّي إِ ذ أَسْ إِتّسْڒَانْ أَربِّي‘.\f*
\v 12 ؤُشَا نتَّا أَذْ يِيڒِي ذ إِجّْ ن بْنَاذمْ أَمشْنَاوْ أَسْنُوسْ ن ڒخْڒَا. أَفُوسْ نّسْ أَذْ يِيڒِي خْ مَارَّا، ؤُ أَفُوسْ ن مَارَّا أَذْ يِيڒِي خَاسْ. أَذْ إِزْذغْ أَرنْذَاذْ ن مَارَّا أَيْثْمَاسْ.“ \x ◘ \xo 16:‏12 \xt أَمز. 25‏:‏18. \x*
\v 13 ؤُ نتَّاثْ ثْڒَاغَا خْ يِيسمْ ن سِيذِي إِ غَارسْ-د إِسِّيوْڒنْ، \add ثنَّا:\add* ”شكْ ذ أَربِّي إِ إِتّْوَاڒَانْ!“، مِينْزِي ثنَّا: ”مَا وَارْ ذَا ژْرِيغْ ونِّي ذ أَيِي إِتّْوَاڒَانْ؟“
\v 14 خْ ؤُيَا سمَّانْ أَنُو نِّي: أَنُو ’لَاحَايْ-رُوئِي‘. خْزَارْ، أَقَا-ث جَارْ قَاذَاشْ ذ بَارَاذْ. \f ◼ \fr 16:‏14 \ft \bd ’أَنُو لَاحَايْ-رُوئِي‘\bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَنُو ن ونِّي إِدَّارنْ ؤُ إِخْزَارْ ذَايِي‘. \bd ’بَارَاذْ‘\bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’ثبْرُورِّي‘.\f*  \x ◘ \xo 16:‏14 \xt أَمز. 24‏:‏62؛ 25‏:‏11. \x*
\v 15 ؤُشَا ثُورُووْ-د هَاجَارْ إِ أَبْرَامْ أَسيْمِي. إِڭَّا أَسْ أَبْرَامْ إِسمْ ن مِّيسْ نِّي \add إِ ذ أَسْ\add* د-ثُورُووْ هَاجَارْ ’إِسْمَاعِيلْ‘. \x ◘ \xo 16:‏15 \xt ڭال. 4‏:‏22. \x*
\v 16 أَبْرَامْ ثُوغَا غَارسْ ستَّا ؤُ-ثْمَانْيِينْ ن إِسڭّْوُوسَا، ؤُمِي د-ثُورُووْ هَاجَارْ إِسْمَاعِيلْ إِ أَبْرَامْ.
\b
\b
\c 17
\s1 ڒْعَاهْذْ ن أَربِّي أَكْ-ذ إِبْرَاهِيمْ
\m 
\v 1 \add ڒَْامِي\add* ثُوغَا غَارسْ غَارْ أَبْرَامْ ثسْعَا ؤُ-ثسْعِينْ ن إِسڭّْوُوسَا، إِبَانْ أَسْ-د سِيذِي إِ أَبْرَامْ، إِنَّا أَسْ: ”نشّْ ذ أَربِّي أَمْزمَّارْ خْ كُوڒْشِي! ؤُيُورْ زَّاثْ إِ وُوذمْ إِنُو ؤُشَا إِڒِي \add ذ بْنَاذمْ\add* إِكمّْڒنْ! \f ◼ \fr 17:‏1 \ft \bd ’أَمْزمَّارْ‘\bd* - ونِّي غَارسْ ثِيزمَّارْ خْ مَارَّا مِينْ إِدْجَانْ.\f*  \x ◘ \xo 17:‏1 \xt أَمز. 5‏:‏22. \x*
\v 2 نشّْ أَذْ ڭّغْ ڒْعَاهْذْ إِنُو جَارْ أَيِي ذ شكْ ؤُشَا أَذْ شكْ سّْكتَّارغْ س يِيجّْ ن شّْكلْ إِمْغَارْ.“ \x ◘ \xo 17:‏2 \xt أَمز. 12‏:‏2؛ 13‏:‏16؛ 15‏:‏5، 18؛ ؤُف. 2‏:‏24؛ 6‏:‏4؛ لَاوِي 26‏:‏42. \x*
\v 3 \add خنِّي\add* إِوْضَا أَبْرَامْ خْ ؤُغمْبُوبْ نّسْ ؤُشَا إِسِّيوڒْ أَربِّي أَكِيذسْ، إِنَّا أَسْ:
\v 4 ”خْزَارْ، نشّْ \add أَذْ ڭّغْ\add* ڒْعَاهْذْ إِنُو أَكِيذكْ ؤُشَا شكْ أَذْ ثِيڒِيذْ ذ بَابَاثْسنْ ن وَاطَّاسْ ن ڒڭْنُوسْ. \x ◘ \xo 17:‏4 \xt رُوم. 4‏:‏17. \x*
\v 5 وَارْ إِتِّيڒِي إِسمْ نّشْ عَاذْ ’أَبْرَامْ‘ مَاشَا \bd ’إِبْرَاهِيمْ‘\bd*، مِينْزِي نشّْ ڭِّيغْ شكْ ذ بَابَاثْسنْ ن وَاطَّاسْ ن ڒڭْنُوسْ.
\v 6 ؤُشَا نشّْ أَذْ شكْ أَرّغْ أَذْ ثڭّذْ ڒْغِيدْجثْ أَطَّاسْ س وَاطَّاسْ ؤُ أَذْ شكْ أَرّغْ ذ ڒڭْنُوسْ، ؤُشَا إِجدْجِيذنْ أَذْ زَّايكْ د-فّْغنْ. \x ◘ \xo 17:‏6 \xt مت. 1‏:‏6. \x*
\v 7 أَذْ ڭّغْ ڒْعَاهْذْ إِنُو جَارْ أَيِي ذ شكْ ذ زَّارِيعثْ نّشْ أَوَارْنِي أَشْ ذِي \add مَارَّا\add* جِّيڒَاثْ نْسنْ، أَمْ يِيجّْ ن ڒْعَاهْذْ إِ ڒبْذَا، حِيمَا أَذْ إِڒِيغْ ذ أَربِّي إِ شكْ ؤُ إِ زَّارِيعثْ نّشْ أَوَارْنِي أَشْ. \x ◘ \xo 17:‏7 \xt أَمز. 13‏:‏15. \x*
\v 8 أَذْ أَشْ وْشغْ، إِ شكْ ؤُ إِ زَّارِيعثْ نّشْ أَوَارْنِي أَشْ، ثَامُّورْثْ مَانِي ثْزدّْغذْ أَمْ ؤُبَارَّانِي، مَارَّا ثَامُّورْثْ ن كنْعَانْ ذ أَڭْڒَا إِ ڒبْذَا. نشّْ أَذْ إِڒِيغْ ذ أَربِّي إِ نِيثْنِي.“ \x ◘ \xo 17:‏8 \xt أَمز. 15‏:‏18؛ أَعَوذ. 1‏:‏8. \x*
\v 9 إِنَّا أَربِّي عَاوذْ إِ إِبْرَاهِيمْ: ”شكْ أَذْ ثحْضِيذْ ڒْعَاهْذْ إِنُو، شكْ ذ زَّارِيعثْ نّشْ أَوَارْنِي أَشْ، ذِي \add مَارَّا\add* جِّيڒَاثْ نْسنْ.
\v 10 ذ وَا ذ ڒْعَاهْذْ إِنُو ونِّي إِ غَا ثحْضَامْ جَارْ أَيِي-د ذ كنِّيوْ ذ زَّارِيعثْ نّشْ أَوَارْنِي أَشْ: إِتّْخصَّا أَذْ إِخْثنْ زَّايْومْ مَارَّا مِينْ إِدْجَانْ ذ أَوْثمْ.
\v 11 كنِّيوْ أَذْ ثْخثْنمْ أَيْسُومْ ن ڒعْذَاڒْيثْ نْومْ ؤُشَا مَانْ أَيَا أَذْ ثِيڒِي ذ ڒعْڒَامثْ ن ڒْعَاهْذْ جَارْ أَيِي-د ذ كنِّيوْ. \x ◘ \xo 17:‏11 \xt ڒخ. 7‏:‏8؛ رُوم. 4‏:‏11. \x*
\v 12 مِّيسْ ن ثْمنْيَا ن وُوسَّانْ أَذْ إِخْثنْ جَارْ أَومْ، مْكُوڒْ أَوْثمْ ذِي \add مَارَّا\add* جِّيڒَاثْ نْومْ، \add أَمْ\add* ونِّي د-إِخڒْقنْ ذِي ثَادَّارْثْ نّشْ \add أَمْ\add* ونِّي إِتّْوَاسْغنْ س نُّوقَارْثْ زِي كُوڒْ أَبَارَّانِي ؤُ وَارْ \add إِدْجِينْ\add* زِي زَّارِيعثْ نّشْ. \x ◘ \xo 17:‏12 \xt لَاوِي 12‏:‏3؛ لك. 2‏:‏21. \x*
\v 13 \add أَمْ\add* ونِّي د-إِخڒْقنْ ذِي ثَادَّارْثْ نّشْ، \add أَمْ\add* ونِّي ثسْغِيذْ س نُّوقَارْثْ، إِتّْخصَّا أَسْ أَذْ إِخْثنْ. \add أَمُّو\add* إِ غَا يِيڒِي ڒْعَاهْذْ إِنُو ذڭْ ويْسُومْ نْومْ ذ ڒْعَاهْذْ إِ ڒبْذَا.
\v 14 أَرْيَازْ وَارْ إِخْثِيننْ، ونِّي ڒعْذَاڒْيثْ نّسْ وَارْ ت خْثِينْ، أَرْيَازْ نِّي إِتّْخصَّا أَذْ ث قسّنْ زِي ڒْڭنْسْ نّسْ، أَقَا يَارْژَا ڒْعَاهْذْ إِنُو.“ \f ◼ \fr 17:‏14 \ft \bd ’أَرْيَازْ نِّي‘\bd* - س ثْعِيبْرَانِيثْ ’ڒعْمَارْ نِّي‘.\f*
\b
\m 
\v 15 إِنَّا أَربِّي عَاوذْ إِ إِبْرَاهِيمْ: ”إِ سَارَايْ ثَامْغَارْثْ نّشْ وَارْ ذ أَسْ ثْڒِيغِيذْ \add عَاذْ\add* ’سَارَايْ‘، مَاشَا ’سَارَا‘ ذ وَا إِ غَا يِيڒِينْ إِسمْ نّسْ. \f ◼ \fr 17:‏15 \ft \bd ’سَارَايْ‘\bd* - أَذْ ثَاغْ إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’يدْجِيسْ ن ؤُجدْجِيذْ‘ (‹‘أَمِيرَا‘›)، مَاشَا عْلَاحْسَابْ إِنّغْنِي ’ثَامْغَارْثْ إِمحْذنْ‘. \bd ’سَارَا‘\bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’ثَاجدْجِيذْثْ‘ نِيغْ ’يمَّاثْسنْ ن ڒڭْنُوسْ‘.\f*
\v 16 \add مِينْزِي\add* أَذْ ت بَارْكغْ ؤُ زَّايسْ أَذْ أَشْ وْشغْ مِّيشْ. \add وَاهْ\add*، أَذْ ت بَارْكغْ ؤُشَا نتَّاثْ أَذْ ثذْوڒْ ذ ڒڭْنُوسْ ؤُ إِجدْجِيذنْ ن ڒڭْنُوسْ أَذْ زَّايسْ د-فّْغنْ!“
\v 17 \add خنِّي\add* إِوْضَا إِبْرَاهِيمْ خْ ؤُغمْبُوبْ نّسْ ؤُشَا إِضْحشْ، إِنَّا ذڭْ وُوڒْ نّسْ: ”أَرْيَازْ ن مْيَا ن إِسڭّْوُوسَا مَا أَذْ أَسْ د-إِتّْوَاخْڒقْ مِّيسْ؟ ؤُ سَارَا، ثنِّي غَارْ إِدْجَا ثسْعِينْ ن إِسڭّْوُوسَا، \add مَا عَاذْ\add* أَذْ د-ثَارُووْ؟“
\v 18 إِنَّا إِبْرَاهِيمْ إِ أَربِّي: ”مْڒِي إِسْمَاعِيلْ إِدَّارْ قِيبَاتْشْ إِ وُوذمْ نّشْ!“
\v 19 \add مَاشَا\add* أَربِّي إِنَّا: ”لَّ، عَاذْ \bd سَارَا، ثَامْغَارْثْ نّشْ، ذ ثنِّي ذ أَشْ د غَا يَارْونْ أَسيْمِي، ؤُشَا شكْ أَذْ أَسْ ثْڒَاغِيذْ إِسْحَاقْ. نشّْ أَذْ ڭّغْ ڒْعَاهْذْ إِنُو أَكِيذسْ ذ ڒْعَاهْذْ إِ ڒبْذَا، إِ زَّارِيعثْ نّسْ أَوَارْنِي أَسْ.\bd*\f ◼ \fr 17:‏19 \ft \bd ’إِسْحَاقْ‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’نتَّا إِضحّشْ‘.\f*  \x ◘ \xo 17:‏19 \xt أَمز. 18‏:‏10؛ 21‏:‏2. \x*
\v 20 زِي جِّيهثْ ن إِسْمَاعِيلْ، أَقَا سدْجغْ أَشْ. خْزَارْ، نشّْ بَارْكغْ ث ؤُشَا أَذْ ث أَرّغْ إِتَّارُووْ ڒْغِيدْجثْ ؤُ أَذْ ث أَرّغْ ذ أَطَّاسْ. ثنْعَاشْ ن ڒْحُوكَّامْ إِ د غَا يجّْ، أَذْ ث ڭّغْ ذ إِجّْ ن ڒْڭنْسْ إِمْغَارْ. \x ◘ \xo 17:‏20 \xt أَمز. 16‏:‏10؛ 25‏:‏12، 16. \x*
\v 21 \add مَاشَا\add* أَذْ ڭّغْ ڒْعَاهْذْ إِنُو أَكْ-ذ إِسْحَاقْ، ونِّي إِ ذ أَشْ د غَا ثَارُووْ سَارَا ذِي ڒْوقْثْ-أَ، ذڭْ ؤُسڭّْوَاسْ إِ د غَا يَاسنْ.“ \x ◘ \xo 17:‏21 \xt أَمز. 21‏:‏2. \x*
\v 22 \add ؤُمِي\add* إِكمّڒْ أَوَاڒْ نّسْ أَكِيذسْ، إِڭعّذْ أَربِّي، \add إِڭّْوجْ\add* خْ إِبْرَاهِيمْ.
\m 
\v 23 إِكْسِي إِبْرَاهِيمْ مِّيسْ إِسْمَاعِيلْ ذ مَارَّا إِسمْغَانْ إِ د-إِتّْوَاخڒْقنْ ذِي ثَادَّارْثْ نّسْ ذ مَارَّا إِنِّي إِمّسْغنْ س نُّوقَارْثْ، مَارَّا \add مِينْ إِدْجَانْ ذ\add* أَوْثمْ جَارْ أَيْثْبَابْ ن ثَادَّارْثْ ن إِبْرَاهِيمْ ؤُشَا إِخْثنْ ڒعْذَاڒْيثْ نْسنْ ذڭْ وَاسّْ نِّي أَمْ مَامّشْ ذ أَسْ إِنَّا أَربِّي.
\v 24 ثُوغَا غَارْ إِبْرَاهِيمْ ثسْعَا ؤُ-ثسْعِينْ ن إِسڭّْوُوسَا ؤُمِي إِخْثنْ ذڭْ ويْسُومْ ن ڒعْذَاڒْيثْ نّسْ. \f ◼ \fr 17:‏24 \ft \bd ’ثسْعَا ؤُ-ثسْعِينْ ن إِسڭّْوُوسَا‘\bd* - مَانْ أَيَا إِخْسْ أَذْ يِينِي بلِّي إِسْحَاقْ إِتّْوَاخڒْقذْ-د ؤُمِي ثُوغَا إِبْرَاهِيمْ عَاذْ إِتّْوَاخْثنْ (أَمز. 18:10-14 ذ 21:5)، أَقَا-ث أَوَارْنِي ڒَامِي إِڭَّا أَربِّي ڒْعَاهْذْ نّسْ أَكِيذسْ (خْزَارْ أَمز. 17:21). مَاشَا إِسْمَاعِيلْ إِتّْوَاخْڒقْ-د قْبڒْ مَّا إِڭَّا أَربِّي ڒْعَاهْذْ نّسْ أَكْ-ذ إِبْرَاهِيمْ.\f*
\v 25 إِڭَّا مِّيسْ إِسْمَاعِيلْ ثْڒطَّاشْ ن إِسڭّْوُوسَا، ؤُمِي ث خثْننْ ذڭْ ويْسُومْ ن ڒعْذَاڒْيثْ نّسْ.
\v 26 إِخْثنْ إِبْرَاهِيمْ ذ مِّيسْ إِسْمَاعِيلْ ذڭْ وَاسّْ ذ إِجّنْ.
\v 27 خثْننْ أَكِيذسْ مَارَّا إِرْيَازنْ ن ثَادَّارْثْ نّسْ، إِنِّي د-إِتّْوَاخڒْقنْ ذِي ثَادَّارْثْ نّسْ ؤُڒَا ذ إِنِّي إِمّسْغنْ س نُّوقَارْثْ زڭْ ؤُبَارَّانِي. \f ◼ \fr 17:‏27 \ft \bd ’زڭْ ؤُبَارَّانِي‘\bd* - س ثْعِيبْرَانِيثْ ’زِي مِّيسْ ن ؤُبَارَّانِي‘.\f*
\b
\b
\c 18
\s1 أَوَاڒْ ن سِيذِي خْ ثْڒَاڒِيثْ ن إِسْحَاقْ
\m 
\v 1 ؤُشَا إِضْهَارْ سِيذِي إِ إِبْرَاهِيمْ غَارْ ثْشجُّورَا ن يِيڭّْ ن مَامْرِي \add ؤُمِي\add* ثُوغَا يَاريّحْ غَارْ وَاذَافْ ن ؤُقِيضُونْ نّسْ ذِي طّْحَا ن ؤُزِيڒْ.
\v 2 إِسّْڭعّذْ ثَامُوغْڒِي نّسْ، إِژْرَا، أَقَا ذِينْ ثْڒَاثَا ن يرْيَازنْ قِيبَاتْشْ نّسْ. \add ؤُمِي\add* ثنْ إِژْرَا، إِكَّارْ إِتَّازّڒْ غَارْسنْ زِي وَاذَافْ ن ؤُقِيضُونْ. ؤُشَا إِبنْذقْ \add س ؤُغمْبُوبْ نّسْ\add* غَارْ ثمُّورْثْ، \f ◼ \fr 18:‏2 \ft \bd ’إِبنْذقْ‘\bd* - نِيغْ ’إِسْجذْ‘.\f*  \x ◘ \xo 18:‏2 \xt عبر. 13‏:‏2. \x*
\v 3 إِنَّا: ”\add أَ\add* سِيذِي إِنُو، مَاڒَا \add ڒخُّو\add* ؤُفِيغْ أَرْضَا ذِي ثِيطَّاوِينْ نّشْ، تّْزَاوَاڭغْ شكْ، وَارْعدُّو خْ ؤُمْسخَّارْ نّشْ.
\v 4 أجّْ \add إِمْسخَّارنْ إِنُو\add* أَذْ د-أَوْينْ شْوَايْثْ ن وَامَانْ ؤُشَا سِيرْذمْ إِضَارنْ نْومْ ؤُشَا زّْڒمْ شْوَايْثْ سَاذُو ثْشجَّارْثْ-أَ. \f ◼ \fr 18:‏4 \ft \bd ’ثَاشجَّارْثْ‘\bd* - نِيغْ ’أَدَّاڭْ‘ (’إِدَّاڭنْ‘).\f*
\v 5 أَذْ د-أَوْيغْ أَڒقُّوزْ ن وغْرُومْ حِيمَا أَذْ تّْوَانعْشنْ وُوڒَاونْ نْومْ، خنِّي أَذْ ثعْذُومْ. أَقَا خْ ؤُيَا إِ د-ثكِّيمْ زَّاثْ إِ ؤُمْسخَّارْ نْومْ!“ نِيثْنِي نَّانْ: ”أڭّْ أَمْ مَامّشْ ثنِّيذْ.“
\m 
\v 6 إِرُوحْ إِبْرَاهِيمْ ذغْيَا غَارْ ؤُقِيضُونْ غَارْ سَارَا، إِنَّا: ”ذغْيَاثْ، \add كْسِي\add* ثْڒَاثَا ن ڒقْيَاسْ ن وَارنْ أَزْذَاذْ، أڭّْوْ \add إِ-ثنْ\add* ؤُشَا أڭّْ \add زَّايسْ\add* ثِيفْضِيرِينْ.“ \f ◼ \fr 18:‏6 \ft \bd ’إِجّْ ن ڒقْيَاسْ‘\bd* - عْڒَاينْ 7-8 لِيثْرُو.\f*
\v 7 \add خَاسْ ؤُشَا\add* يُوزّڒْ إِبْرَاهِيمْ غَارْ إِفُونَاسنْ ؤُشَا إِطّفْ-د إِجّْ ن ؤُمژْيَانْ ن ؤُفُونَاسْ إِڭْمَا ذ لمْلِيحْ، إِوْشَا إِ-ث إِ ؤُبْڒِيغْ، ؤُشَا وَا إِقدْجقْ، حِيمَا أَذْ ث إِسّوْجذْ.
\v 8 نتَّا إِكْسِي عَاوذْ دّْهنْ ذ ؤُغِي ذ ؤُمژْيَانْ ن ؤُفُونَاسْ نِّي إِسّوْجذْ، ؤُشَا إِسَّارْسْ \add إِ-ث\add* زَّاثْسنْ، ؤُ نتَّا ثُوغَا إِبدّْ قِيبَاتْشْ نْسنْ سَاذُو ثْشجَّارْثْ، ؤُشَا شِّينْ.
\v 9 \add خنِّي\add* نَّانْ أَسْ: ”مَانِي ثدْجَا سَارَا ثَامْغَارْثْ نّشْ؟“ يَارَّا-د خَاسنْ: ”\add أَقَا-ت ذِينْ\add* ذڭْ ؤُقِيضُونْ.“
\v 10 ؤُشَا نتَّا إِنَّا: ”ذ ثِيذتّْ أَذْ غَاركْ د-ذوْڒغْ غَارْ ڒْوقْثْ ن ثُوذَارْثْ ؤُ خْزَارْ، أَذْ غَارسْ يِيڒِي ؤُحنْجِيرْ غَارْ سَارَا، ثَامْغَارْثْ نّشْ.“ ؤُ سَارَا ثسْڒَا غَارْ وَاذَافْ ن ؤُقِيضُونْ نِّي \add إِدْجَانْ\add* أَوَارْنِي أَسْ. \x ◘ \xo 18:‏10 \xt أَمز. 17‏:‏19، 21؛ 21‏:‏2. \x*
\v 11 إِبْرَاهِيمْ ذ سَارَا ثُوغَا وْسَارنْ، ؤُيُورنْ ذڭْ وُوسَّانْ، ؤُشَا سَارَا ثُوغَا ثْبدّْ أَسْ ثُوبَّارْثْ ن ثمْغَارِينْ. \x ◘ \xo 18:‏11 \xt أَمز. 17‏:‏17؛ رُوم. 4‏:‏19؛ عبر. 11‏:‏11. \x*
\v 12 ؤُشَا ثضْحشْ سَارَا ذڭْ وُوڒْ نّسْ، ثنَّا: ”أَوَارْنِي ثوْسَارْ إِنُو، مَا أَذْ غَارِي يِيڒِي ڒْخِيرْ\add -أَ\add* ذ لمْلِيحْ قَاعْ، \add أَمْ\add* إِدْجَا سِيذِي إِنُو ؤُڒَا ذ نتَّا إِوْسَارْ؟“ \x ◘ \xo 18:‏12 \xt ڒقض. 19‏:‏26؛ 1 بُط. 3‏:‏6. \x*
\v 13 إِنَّا سِيذِي إِ إِبْرَاهِيمْ: ”مَاغَارْ ثضْحشْ سَارَا، ثنَّا: ’مَا زمَّارغْ أَذْ أَرْوغْ أَمْ وْسَارغْ ڒخُّو؟‘
\v 14 مَا أَقَا ذِينْ شَا ن ڒْحَاجّثْ خْ سِيذِي ثوْعَارْ؟ أَذْ غَاركْ د -عقْبغْ ذِي ڒْوقْثْ إِ نڭَّا، غَارْ ڒْوقْثْ ن ثُوذَارْثْ ؤُشَا \add أَذْ يِيڒِي\add* غَارْ سَارَا مِّيسْ!“ \x ◘ \xo 18:‏14 \xt مت. 19‏:‏26؛ لك. 1‏:‏37. \x*
\v 15 سَارَا ثنْكَارْ، ثنَّا: ”وَارْ ضحْشغْ شَا!“، مِينْزِي ثُوغَا ثڭّْوذْ. نتَّا إِنَّا أَسْ: ”لَّ، أَقَا شمْ ثْضحْشذْ!“
\b
\s1 ثَاژَادْجِيثْ ن إِبْرَاهِيمْ خْ سُوذُومْ
\m 
\v 16 \add خنِّي\add* كَّارنْ إِرْيَازنْ نِّي سّنِّي، سوْضنْ غَارْ سَاذُومْ، ؤُشَا إِرُوحْ إِبْرَاهِيمْ أَكِيذْسنْ، إِسّْقبّضْ إِ-ثنْ.
\v 17 ؤُشَا إِنَّا سِيذِي: ”مَا أَذْ فَّارغْ نشّْ خْ إِبْرَاهِيمْ مِينْ إِ غَا ڭّغْ؟ \x ◘ \xo 18:‏17 \xt عَام. 3‏:‏7. \x*
\v 18 أَذْ يِيڒِي إِبْرَاهِيمْ زعْمَا ذ إِجّْ ن ڒْڭنْسْ إِمْغَارْ إِجْهذْ، أَقَا أَذْ ذَايسْ تّْوَابَارْكنْ مَارَّا ڒڭْنُوسْ ن دُّونشْثْ. \x ◘ \xo 18:‏18 \xt أَمز. 12‏:‏3؛ 22‏:‏18؛ 26‏:‏4؛ ڒخ. 3‏:‏25؛ ڭال. 3‏:‏8. \x*
\v 19 مِينْزِي نشّْ قّْنغْ إِخفْ إِنُو أَكِيذسْ، حِيمَا أَذْ إِسّڒْمذْ إِحنْجِيرنْ نّسْ ؤُڒَا ذ ثَادَّارْثْ نّسْ أَوَارْنِي أَسْ، مَاحنْذْ أَذْ حْضَانْ أَبْرِيذْ ن سِيذِي، أَذْ ڭّنْ ثَاسڭْذَا ذ ڒْحقّْ، حِيمَا سِيذِي أَذْ د-يَاوِي إِ إِبْرَاهِيمْ مِينْ ثُوغَا خَاسْ إِنَّا.“
\v 20 \add خنِّي\add* إِنَّا سِيذِي: ”ثْغُويِّيثْ ن سَاذُومْ ذ عَامُورَّا ثمْغَارْ أَطَّاسْ ؤُ دّْنُوبْ نْسنْ ذقْڒنْ.
\v 21 أَذْ د-هْوِيغْ، أَذْ ژَترغْ مَا ڭِّينْ نِيشَانْ أَمْ ثْغُويِّيثْ نْسنْ إِ غَارِي د-يُوسِينْ نِيغْ لَّا، أَذْ سّْنغْ.“
\v 22 \add خنِّي\add* ذوْڒنْ إِرْيَازنْ سّنِّي ؤُشَا طّْفنْ \add أَبْرِيذْ\add* غَارْ سَاذُومْ. \add مَاشَا\add* إِبْرَاهِيمْ ثُوغَا إِقِّيمْ عَاذْ إِبدّْ زَّاثْ إِ وُوذمْ ن سِيذِي.
\v 23 ؤُشَا إِقَارّبْ-د إِبْرَاهِيمْ، إِنَّا: ”مَا س ثِيذتّْ أَذْ ثَارذْدْجذْ عَاوذْ أَمْسڭّذْ أَكْ-ذ ؤُعفَّانْ؟
\v 24 أَقَا ذِينِّي بَالَاكْ خمْسِينْ ن إِمْسڭَّاذنْ ذَاخڒْ إِ ثنْذِينْثْ. مَا س ثِيذتّْ أَذْ ثنْ ثَارذْدْجذْ، ؤُ وَارْ ثْسمّْحذْ ذڭْ ومْشَانْ نِّي ذِي طّْوعْ ن خمْسِينْ ن إِمْسڭَّاذنْ إِ ذَايسْ إِدْجَانْ؟
\v 25 إِڭّْوجْ خَاكْ أَذْ ثڭّذْ أَيَا، أَذْ ثنْغذْ أَمْسڭّذْ أَكْ-ذ ؤُعفَّانْ، \add وَاهْ،\add* إِڭّْوجْ خَاكْ أَذْ يِيڒِي ؤُمْسڭّذْ محْسُوبْ أَمْ ؤُعفَّانْ. أَقَا ڒْقَاضِي ن دُّونشْثْ مَا وَارْ إِتّڭّْ س ڒْحقّْ؟“ \x ◘ \xo 18:‏25 \xt رُوم. 3‏:‏6. \x*
\v 26 \add ڒخْذنِّي\add* إِنَّا أَسْ سِيذِي: ”مَاڒَا ؤُفِيغْ ذِي سَاذُومْ خمْسِينْ ن إِمْسڭَّاذنْ ذَاخڒْ إِ ثنْذِينْثْ، أَذْ سمْحغْ إِ ومْشَانْ ذِي طّْوعْ نْسنْ.“
\v 27 إِبْرَاهِيمْ يَارَّا-د، إِنَّا: ”خْزَارْ ڒخُّو، بْذِيغْ زعّْمغْ أَذْ سِّيوْڒغْ أَكْ-ذ سِيذِي إِنُو، \add وَاخَّا\add* نشّْ ذ شَاڒْ ذ يِيغّضْ.
\v 28 أَذْ ثَاغْ نقْصنْ زِي خمْسِينْ ن إِمْسڭَّاذنْ خمْسَا، مَا أَذْ ثَارذْدْجذْ خْ خمْسَا نِّي مَارَّا ثَانْذِينْثْ؟“ إِنَّا: ”وَارْ \add ت\add* تَّارذْدْجغْ مَاڒَا ؤُفِيغْ ذِينْ خمْسَا ؤُ-ربْعِينْ.“
\v 29 يَارْنِي ذڭْ وَاوَاڒْ أَكِيذسْ، إِنَّا أَسْ: ”أَذْ ثَاغْ أَذْ يِيڒِي أَذْ إِتّْوَافْ ذِينْ أَربْعِينْ!“ يَارَّا-د نتَّا: ”وَارْ \add ت\add* تّڭّغْ شَا ذِي طّْوعْ ن أَربْعِينْ \add نِّي\add*.“
\v 30 \add خَاسْ ؤُشَا\add* إِنَّا: ”وَارْ تّْخيِّيقْ ڒخُّو سِيذِي إِنُو، خْمِي غَا سِّيوْڒغْ \add عَاوذْ\add*. أَذْ ثَاغْ أَذْ يِيڒِي ذِينْ ثْڒَاثِينْ!“ يَارَّا-د: ”وَارْ \add ت\add* تَّارذْدْجغْ مَاڒَا ؤُفِيغْ ذِينْ ثْڒَاثِينْ.“
\v 31 إِنَّا \add عَاوذْ\add*: ”خْزَارْ ڒخُّو، بْذِيغْ زعْمغْ أَذْ سِّيوْڒغْ أَكْ-ذ سِيذِي إِنُو. أَذْ ثَاغْ أَذْ يِيڒِي ذِينْ \add مْغِيرْ\add* عِيشْرِينْ!“ يَارَّا-د: ”وَارْ \add ت\add* تَّارذْدْجغْ شَا ذِي طّْوعْ ن عِيشْرِينْ \add نِّي\add*.“
\v 32 \add خنِّي\add* إِنَّا: ”وَارْ تّْخيِّيقْ ڒخُّو سِيذِي إِنُو، خْمِي غَا سِّيوْڒغْ \add عَاوذْ\add*. أَذْ ثَاغْ أَذْ يِيڒِي ذِينْ \add مْغِيرْ\add*عشْرَا!“ يَارَّا-د: ”وَارْ \add ت\add* تَّارذْدْجغْ ذِي طّْوعْ نعشْرَا \add نِّي\add*.“
\v 33 \add خنِّي\add* إِرُوحْ سِيذِي أَوَارْنِي ڒَامِي إِكمّڒْ أَوَاڒْ \add نّسْ\add* أَكْ-ذ إِبْرَاهِيمْ ؤُشَا إِبْرَاهِيمْ إِذْوڒْ-د غَارْ ومْشَانْ ن ثْزذِّيغْثْ نّسْ.
\b
\b
\c 19
\s1 ثَاروْڒَا ن لُوطْ زِي سُوذُومْ
\m 
\v 1 ؤُشَا إِوْضنْثْ خنِّي ثْنَاينْ ن لْمَالَاكَاثْ \add نِّي\add* غَارْ سَاذُومْ س دْجِيڒثْ. ثُوغَا لُوطْ إِقِّيمْ غَارْ ثوَّارْثْ ن سَاذُومْ. ؤُمِي \add ثنْ\add* إِژْرَا لُوطْ، إِكَّارْ مَاحنْذْ أَذْ ثنْ إِڒْقَا ؤُشَا إِبنْذقْ \add س ؤُغمْبُوبْ نّسْ\add* غَارْ ثمُّورْثْ. \f ◼ \fr 19:‏1 \ft \bd ’إِبنْذقْ‘\bd* - نِيغْ ’إِسْجذْ‘.\f*
\v 2 إِنَّا: ”خْزَارْ، \add أَ\add* إِسِيذِيثنْ إِنُو، تّْزَاوَاڭغْ كنِّيوْ أَذْ د-ثَاسمْ غَارْ ثَادَّارْثْ ن ؤُمْسخَّارْ نْومْ ؤُشَا أَذْ \add ذَايسْ\add* ثسّنْسمْ، أَذْ ثسِّيرْذمْ إِضَارنْ نْومْ. خنِّي أَذْ ثْفَاقمْ زِيشْ، أَذْ ثْكمّْڒمْ خْ وبْرِيذْ نْومْ.“ \add مَاشَا\add* نِيثْنِي نَّانْ: ”لَّ، أَقَا ذڭْ وَازَّايْ أَذْ نقِّيمْ أَذْ نسّنْسْ.“ \x ◘ \xo 19:‏2 \xt أَمز. 18‏:‏4. \x*
\v 3 \add مَاشَا\add* نتَّا إِكلّفْ خَاسنْ أَطَّاسْ أَڒَامِي أَكِيذسْ رُوحنْ، ؤُذْفنْ غَارْ ثَادَّارْثْ نّسْ ؤُشَا إِڭَّا أَسنْ أَمنْسِي، إِڭّْوَا أَغْرُومْ بْڒَا أَنْثُونْ ؤُشَا شِّينْ. \x ◘ \xo 19:‏3 \xt عبر. 13‏:‏2. \x*
\m 
\v 4 أَقَا قْبڒْ إِ غَا طّْصنْ، قوَّارنْ إِ ثَادَّارْثْ إِرْيَازنْ ن ثنْذِينْثْ، إِرْيَازنْ ن سَاذُومْ، زڭْ ؤُمژْيَانْ أَڒْ أَوسَّارْ، مَارَّا إِوْذَانْ زِي مَارَّا إِمُوشَانْ إِطُّورْفنْ \add ن ثنْذِينْثْ\add*.
\v 5 نِيثْنِي ڒَاغَانْ إِ لُوطْ، نَّانْ أَسْ: ”مَانِي دْجَانْ إِرْيَازنْ إِنِّي غَاركْ د-يُوسِينْ دْجِيرثْ-أَ؟ سُوفّغْ إِ-ثنْ-د، حِيمَا أَذْ ثنْ نسّنْ.“ \f ◼ \fr 19:‏5 \ft \bd ’حِيمَا أَذْ ثنْ نسّنْ‘\bd* - مَانْ أَيَا إِخْسْ أَذْ يِينِي أَقَا إِرْيَازنْ ن سَاذُومْ ثُوغَا خْسنْ أَذْ ثنْغصْبنْ.\f*
\v 6 إِفّغْ-د غَارْسنْ لُوطْ، غَارْ ثوَّارْثْ، ؤُشَا إِقّنْ ثَاوَّارْثْ أَوَارْنِي أَسْ.
\v 7 إِنَّا: ”تّْزَاوْڭغْ، \add أَ\add* أَيْثْمَا إِنُو، وَارْ تّڭّمْ \add قَاعْ\add* ڒْغَارْ!
\v 8 خْزَارْ، غَارِي ثْنَاينْ ن يسِّي، ثِينِّي \add عَاذْ\add* وَارْ إِسِّيننْ أَرْيَازْ. أجّْ أَيِي أَذْ أَومْ ثنْثْ إِ-د-سُّوفّْغغْ بَارَّا ؤُشَا ڭّمْ ذَايْسنْثْ مِينْ ثتّْوَاڒَامْ مْلِيحْ ذِي ثِيطَّاوِينْ نْومْ. مْغِيرْ إِ إِرْيَازنْ-أَ وَارْ ذَايْسنْ تّڭّمْ وَالُو، أَقَا خْ ؤُيَا د-ؤُسِينْ نِيثْنِي سْوَادَّايْ ن ثِيڒِي ن ثْزقَّا إِنُو غَارْ ثْمنْسِيوْثْ.“ \f ◼ \fr 19:‏8 \ft \bd أَفسَّارْ\bd* - أَذْ ثَاغْ إِڭَّا لُوطْ أَمُّو مَاحنْذْ أَذْ يجّْ يسِّيسْ أَذْ ثتّْوَاغصْبنْثْ زڭْ إِرْيَازنْ ن سَاذُومْ، مِينْزِي ثُوغَا إِتّڭّْوذْ ڒْحُوكْمْ ن أَربِّي خْ ثْمڭَّا ن إِرْيَازنْ نِّي إِخْسنْ أَذْ ڭّنْ مِينْ وَارْ إِحدْجْڒنْ، مِينْ إِدْجَانْ ضِيدّْ إِ طّْبِيعثْ ن بْنَاذمْ مَاحنْذْ أَذْ إِتّْوَاڭّْ. إِسّنْ لُوطْ أَقَا أَربِّي ثُوغَا إِحكّمْ خْ دُّونشْثْ س سّحْڒثْ ذڭْ وُوسَّانْ ن نُوحْ مَاغَارْ ’ثَارْوَا ن أَربِّي‘ (أَقَا-ثنْ ذ لْمَالَاكَاثْ ن أَربِّي) ؤُسِينْ-د غَارْ يسِّيسْ ن بْنَاذمْ ؤُ مَانْ أَيَا ذ نّْعِي ذِي ثِيطَّاوِينْ ن أَربِّي (خْزَارْ أَمز. 6:1-4، يَاهُوذَا 6،7). أَمُّو إِخْضَارْ لُوطْ حِيمَا أَذْ إِوْشْ ثِيحنْجِيرِينْ نّسْ مَاحنْذْ أَذْ إِسّنْجمْ ثَانْذِينْثْ ن سَاذُومْ زِي ڒْحُوكْمْ أَمقّْرَانْ ن أَربِّي.\f*
\v 9 نِيثْنِي نَّانْ: ”أَڭّْوجْ ذِيهَا!“ ؤُشَا نَّانْ \add عَاوذْ\add*: ”أَقَا وَانِيثَا يُوسَا-د \add ذَا\add* ذ أَبَارَّانِي ؤُشَا إِخْسْ أَذْ \add خَانغْ\add* إِحْكمْ أَمْ ڒْقَاضِي! ڒخُّو أَذْ شكْ نْضَارّْ كْثَارْ زَّايْسنْ.“ ؤُشَا ڭِّينْ أَطَّاسْ ن ؤُغِيڒْ خْ ورْيَازْ نِّي، خْ لُوطْ، ؤُشَا قَارّْبنْ-د حِيمَا أَذْ أَرْژنْ ثَاوَّارْثْ. \x ◘ \xo 19:‏9 \xt ؤُف. 2‏:‏14؛ ڒخ. 7‏:‏27؛ 2 بُط. 2‏:‏7، 8. \x*
\v 10 \add مَاشَا\add* إِرْيَازنْ نِّي سّْوِيژّْضنْ أَفُوسْ نْسنْ، سِّيذْفنْ لُوطْ غَارْ ثَادَّارْثْ أَكِيذْسنْ ؤُشَا بلّْعنْ ثَاوَّارْثْ.
\v 11 نِيثْنِي وْثِينْ إِرْيَازنْ \add نِّي ثُوغَا إِبدّنْ\add* غَارْ ثوَّارْثْ ن ثَادَّارْثْ س ثُودَّارْغتْشْ، أَمْ ؤُمژْيَانْ أَمْ ؤُمقّْرَانْ، \add أَڒَامِي\add* سِّيهْڒنْ نِيثْنِي إِخفْ نْسنْ ذِي ثَارزُّوثْ خْ ثوَّارْثْ.
\v 12 \add خنِّي\add* نَّانْ إِرْيَازنْ نِّي إِ لُوطْ: ”وِي غَاركْ ذَا عَاذْ؟ مَا أَضڭّْوَاڒْ نِيغْ إِحنْجِيرنْ نِيغْ ثْحنْجِيرِينْ، مَارَّا إِنِّي غَاركْ ذِي ثنْذِينْثْ، أجّْ إِ-ثنْ أَذْ فّْغنْ زڭْ ومْشَانْ-أَ.
\v 13 أَقَا أَذْ نَاردّدْجْ أَمْشَانْ-أَ، مِينْزِي ثْغُويِّيثْ نّسْ ثمْغَارْ زَّاثْ إِ وُوذمْ ن سِيذِي، ؤُ سِيذِي إِسّكّْ أَنغْ-د، حِيمَا أَذْ ت نَاردّدْجْ.“
\m 
\v 14 إِفّغْ لُوطْ ؤُشَا إِسِّيوڒْ أَكْ-ذ إِضڭّْوَاڒنْ نّسْ، إِنِّي إِڭِّينْ أَذْ مڒْشنْ يسِّيسْ، إِنَّا: ”كَّارمْ، فّْغمْ زڭْ ومْشَانْ-أَ، مِينْزِي سِيذِي أَذْ يَاردّدْجْ ثَانْذِينْثْ-أَ.“ \add مَاشَا\add* إِبَانْ-د إِتّْقصَّارْ ذِي ثِيطَّاوِينْ ن إِضڭّْوَاڒنْ نّسْ.
\v 15 ؤُمِي إِصْبحْ ڒْهَاڒْ، سّْقدْجْقنْثْ لْمَالَاكَاثْ لُوطْ، نَّانْثْ: ”كَّارْ، ثكْسِيذْ ثَامْغَارْثْ نّشْ ذ ثْنَاينْ ن يسِّيشْ، \add ثِينِّي أَكِيذكْ\add*، حِيمَا وَارْ ثْهلِّيكذْ شَا ذِي ڒْمُوعْصِييّثْ ن ثنْذِينْثْ-أَ.“
\v 16 \add مَاشَا\add* نتَّا وَارْ إِزْعِيمْ. خنِّي طّْفنْ إِرْيَازنْ نِّي أَفُوسْ نّسْ ذ ؤُفُوسْ ن ثمْغَارْثْ نّسْ ذ إِفَاسّنْ ن ثْنَاينْ ن يسِّيسْ، مِينْزِي سِيذِي ثُوغَا إِخْسْ أَذْ خَاسْ إِحِينّْ. نِيثْنِي سُّوفّْغنْ ث غَارْ بَارَّا، نذْهنْ ث بَارَّا إِ ثنْذِينْثْ.
\v 17 أَڒَامِي ثنْ سُّوفّْغنْ بَارَّا، إِنَّا نتَّا: ”سنْجمْ إِخفْ نّشْ! وَارْ خزَّارْ أَوَارْنِي أَشْ، وَارْ تّْبذِّي ذِي جِّيهثْ-أَ أَمْ ثكْمڒْ. أَرْوڒْ غَارْ إِذُورَارْ، حِيمَا وَارْ ثتّْوَاثحِّيذْ شَا.“ \f ◼ \fr 19:‏17 \ft \bd ’إِخفْ نّشْ‘\bd* - س ثْعِيبْرَانِيثْ ’ڒعْمَارْ نّشْ‘.\f*
\v 18 إِنَّا أَسنْ لُوطْ: ”لَّ، تّْزَاوَاڭغْ، \add أَ\add* سِيذِي إِنُو!
\v 19 خْزَارْ، أَمْسخَّارْ نّشْ يُوفَا أَرْضَا ذِي ثِيطَّاوِينْ نّشْ، \add وَاهْ\add* ثسّمْغَارذْ ثَامخْسِيوْثْ نّشْ إِشوَّارنْ، ثنِّي كِيذِي ثڭِّيذْ ؤُمِي ذ أَيِي ثجِّيذْ دَّارغْ. \add مَاشَا\add* وَارْ زمَّارغْ أَذْ أَروْڒغْ غَارْ إِذُورَارْ قْبڒْ ذ أَيِي غَا إِطّفْ ڒْغَارْ ؤُشَا أَذْ مّْثغْ!
\v 20 خْزَارْ ڒخُّو، ثَانْذِينْثْ-أَ أَقَا ثُوذسْ-د أَطَّاسْ، \add أَقَا\add* زمَّارغْ أَذْ ذِينِّي أَروْڒغْ. نتَّاثْ ذ ثَامعْنَانُوشْثْ. أجّْ أَيِي أَذْ أَروْڒغْ ڒخُّو ذِينِّي. مَا وَارْ ثدْجِي ذ \add إِشْثْ ن ثنْذِينْثْ\add* ذ ثَامعْنَانُوشْثْ؟ \add خنِّي\add* زمَّارغْ أَذْ قِّيمغْ دَّارغْ.“
\v 21 يَارَّا-د خَاسْ: ”خْزَارْ، ثِيوضْ أَيِي-د عَاوذْ ثْزَاوڭْثْ نّشْ خْ ؤُيَا، وَارْ تَّاردّْدْجغْ شَا ثَانْذِينْثْ مِينْ خفْ ثسِّيوْڒذْ.
\v 22 قدْجقْ، أَرْوڒْ ذِينْ، مِينْزِي وَارْ زمَّارغْ أَذْ ڭّغْ وَالُو أَڒْ د غَا ثَاوْضذْ غَارْ ذِينِّي.“ خْ ؤُيَا سمَّانْ إِسمْ ن ثنْذِينْثْ \add نِّي\add* صُوغَارْ. \f ◼ \fr 19:‏22 \ft \bd ’صُوغَارْ‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَمژْيَانْ‘ نِيغْ ’أَمُوقْڒِيڒْ‘.\f*
\v 23 \add أَڒَامِي\add* يِيوضْ لُوطْ غَارْ صُوغَارْ، ثنْقَارْ-د ثْفُوشْثْ خْ ثمُّورْثْ.
\m 
\v 24 إِجَّا سِيذِي أَذْ إِوّثْ ونْژَارْ خْ سَاذُومْ ؤُ خْ عَامُورَّا، ذ ڒشْبَاريّثْ ذ ثْمسِّي زڭْ ؤُجنَّا زِي غَارْ سِيذِي. \f ◼ \fr 19:‏24 \ft \bd أَفسَّارْ\bd* - ذڭْ وُوسَّانْ-أَ ؤُفِينْ إِمُوسْنَاونْ ن ؤُمزْرُويْ مَارَّا مِينْ إِقِّيمنْ ن ثْندَّامْ نِّي ذ إِغّضْ. إِتّْغِيڒْ أَسنْ أَقَا ڒْقدّْ ن ڒحْمُو ذِي غَامُّورَا يِيوضْ غَارْ 3000 سَالْسِييُوسْ. ڒحْيُوضْ ذ ثْخُوذَامْ ن وُورغْ ذوْڒنْ ذ إِغّضْ. ڒشْبَاريّثْ أَذْ ثَافذْ عَاذْ ڒخُّو ذِي جّْوَايهْ ن ڒبْحَارْ إِمُّوثنْ.\f*  \x ◘ \xo 19:‏24 \xt أَعَوذ. 29‏:‏22؛ إِشا. 13‏:‏19؛ إِرْم. 20‏:‏16؛ 50‏:‏40؛ إِڭجذ. 4‏:‏6؛ حِز. 16‏:‏50؛ حُوش. 11‏:‏8؛ عَام. 4‏:‏11؛ صَاف. 2‏:‏9؛ لك. 17‏:‏29؛ 2 بُط. 2‏:‏6؛ يَاه. 7. \x*
\v 25 يَاردّدْجْ نتَّا ثِيندَّامْ نِّي ذ مَارَّا أَذوَّارْ نِّي، أَكْ-ذ مَارَّا إِمزْذَاغْ ن ثْندَّامْ نِّي ؤُڒَا ذ أَغمُّويْ ن ثمُّورْثْ.
\v 26 ثَامْغَارْثْ نّسْ، \add ثنِّي ثُويُورْ\add* غَارْ ضفَّارْ نّسْ، ثخْزَارْ أَوَارْنِي أَسْ ؤُشَا ثذْوڒْ ذ إِجّْ ن ؤُقلِّيجْ ن ثْمدْجَاحْثْ. \x ◘ \xo 19:‏26 \xt لك. 17‏:‏32. \x*
\m 
\v 27 غَارْ صّْبحْ زِيشْ إِكَّارْ إِبْرَاهِيمْ، \add يُويُورْ\add* غَارْ ومْشَانْ مَانِي ثُوغَا إِبدّْ زَّاثْ إِ وُوذمْ ن سِيذِي.
\v 28 إِسْوضْ غَارْ سَاذُومْ ذ عَامُورَّا ؤُ غَارْ مَارَّا ثَامُّورْثْ ن ؤُذوَّارْ نِّي، ؤُشَا إِژْرَا بلِّي دّخَّانْ إِتّْڭعَّاذْ زِي ثمُّورْثْ أَمْ دّخَّانْ ن إِشْثْ ن ثفْقُونْثْ.
\v 29 أَڒَامِي يَاردّدْجْ أَربِّي ثِيندَّامْ ن ؤُذوَّارْ \add نِّي\add*، إِفكَّارْ أَربِّي ذِي إِبْرَاهِيمْ ؤُشَا إِسّكّْ لُوطْ بَارَّا زِي ڒْوسْطْ ن ؤُشڒْوَاوْ، ؤُمِي إِقْڒبْ ثِيندَّامْ إِ ذِي إِزْذغْ لُوطْ. \f ◼ \fr 19:‏29 \ft \bd ’أَشڒْوَاوْ‘\bd* - س لْحَارْفْ ’أَنقْڒبْ‘\f*
\b
\s1 لُوطْ ذ يسِّيسْ
\m 
\v 30 إِڭعّذْ لُوطْ زِي صُوغَارْ ؤُشَا إِرُوحْ إِزْذغْ أَكْ-ذ ثْنَاينْ ن يسِّيسْ ذڭْ إِذُورَارْ، مِينْزِي إِڭّْوذْ \add أَذْ إِقِّيمْ\add* إِزدّغْ ذِي صُوغَارْ. ؤُشَا إِزْذغْ ذڭْ إِفْرِي أَكْ-ذ ثْنَاينْ ن يسِّيسْ.
\v 31 ثنَّا ثْمنْزُوثْ إِ ثْمَاژُوژْثْ: ”بَابَاثْنغْ ذ أَوسَّارْ، وَارْ إِقِّيمْ ؤُعزْرِي ذِي ثمُّورْثْ أَذْ خَانغْ د-يَاذفْ أَمْ مَامّشْ ثڭُّورْ ذِي مَارَّا دُّونشْثْ.
\v 32 زِيذْ، أجّْ أَنغْ أَذْ نوْشْ بِينُو إِ بَابَاثْنغْ أَذْ إِسُّو ؤُشَا أَذْ كِيسْ نزّڒْ، \add مَاحنْذْ\add* أَذْ نوْشْ ثُوذَارْثْ إِ زَّارِيعثْ ن بَابَاثْنغْ.“ \f ◼ \fr 19:‏32 \ft \bd ’زَّارِيعثْ‘\bd* - إِخْسْ أَذْ يِينِي ’ثَارْوَا‘.\f*
\v 33 ذِي دْجِيڒثْ نِّي وْشِينْثْ بِينُو إِ بَابَاثْسنْثْ، إِسْوَا. \add خنِّي\add* ثُوذفْ ثْمنْزُوثْ، ثطّصْ أَكْ-ذ بَابَاسْ، \add مَاشَا\add* نتَّا وَارْ يُوشِي شَا بلِّي ثزّڒْ أَكِيذسْ نِيغْ ثكَّارْ \add عَاوذْ\add*.
\v 34 ثِيوشَّا نّسْ ثنَّا ثْمنْزُوثْ إِ ثْمَاژُوژْثْ: ”أَقَا نشّْ زّْڒغْ دْجِيرثْ إِعْذُونْ أَكْ-ذ بَابَا، أَذْ أَسْ نوْشْ أَذْ إِسُّو بِينُو عَاوذْ دْجِيرثْ-أَ. \add خنِّي\add* أَذْ ثَاذْفذْ شمْ أَذْ كِيذسْ ثزّْڒذْ، مَاحنْذْ أَذْ د-نجّْ جِّيڒْ أَذْ إِقِّيمْ إِدَّارْ زِي ژَّارِيعثْ ن بَابَاثْنغْ.“
\v 35 وْشِينْثْ بِينُو إِ بَابَاثْسنْثْ عَاوذْ ذِي دْجِيرثْ نِّي، إِسْوَا. \add خنِّي\add* ثكَّارْ ثْمَاژُوژْثْ ؤُشَا ثطّصْ أَكْ-ذ بَابَاسْ. \add مَاشَا\add* نتَّا وَارْ يُوشِي شَا بلِّي ثزّڒْ أَكِيذسْ نِيغْ ثكَّارْ \add عَاوذْ\add*.
\v 36 \add أَمُّو\add* كْسِينْثْ ثْنَاينْ ن يسِّيسْ ن لُوطْ س دّيْسثْ زِي بَابَاثْسنْثْ.
\v 37 ؤُشَا ثُورُووْ-د ثْمنْزُوثْ أَسيْمِي، ثْڒَاغَا إِسمْ نّسْ مُوآبَ. وَا ذ بَابَاثْسنْثْ ن أَيْثْ ن مُوآبَ غَارْ أَسّْ\add -أَ\add*. \f ◼ \fr 19:‏37 \ft \bd ’مُوآبَ‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’زِي بَابَا‘.\f*
\v 38 ثَامَاژُوژْثْ عَاوذْ ثُورُووْ-د أَسيْمِي ؤُشَا ثْڒَاغَا إِسمْ نّسْ بنْ-عَامِّي. نتَّا ذ بَابَاثْسنْ ن إِحنْجِيرنْ ن عَامُّونْ غَارْ أَسّْ-أَ. \f ◼ \fr 19:‏38 \ft \bd ’بنْ-عَامِّي‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’مِّيسْ ن ڒْڭنْسْ إِنُو‘.\f*
\b
\b
\c 20
\s1 إِبْرَاهِيمْ أَكْ-ذ أَبِيمَالِيكْ، أَجدْجِيذْ ن جِيرَارْ
\m 
\v 1 سّنِّي إِسّْمُوطِّييْ إِبْرَاهِيمْ إِقِيضَانْ نّسْ، \add يُويُورْ\add* غَارْ ثمُّورْثْ ن لْجَانُوبْ. إِزْذغْ نتَّا جَارْ قَاذَاشْ ذ شُورْ ؤُشَا إِقِّيمْ أَمْ ؤُبَارَّانِي ذِي جِيرَارْ.
\v 2 \add ؤُمِي\add* إِنَّا إِبْرَاهِيمْ خْ سَارَا ثَامْغَارْثْ نّسْ: ”نتَّاثْ ذ ؤُتْشْمَا إِ ثدْجَا!“، إِسّكّْ أَبِيمَالِيكْ، أَجدْجِيذْ ن جِيرَارْ، يِيوِي \add أَكِيسْ\add* سَارَا. \f ◼ \fr 20:‏2 \ft \bd ’أَبِيمَالِيكْ‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’بَابَاسْ ن ؤُجدْجِيذْ‘.\f*  \x ◘ \xo 20:‏2 \xt أَمز. 12‏:‏13؛ 26‏:‏7. \x*
\v 3 \add مَاشَا\add* إِضْهَارْ-د أَربِّي إِ أَبِيمَالِيكْ ذِي ثَارْجِيثْ ن دْجِيرثْ، إِنَّا أَسْ: ”أَقَا ڒخُّو أَذْ ثمّْثذْ ذِي سِّيبّثْ ن ثمْغَارْثْ، ثنِّي د-ثِيوْيذْ أَكِيذكْ، \add مِينْزِي\add* نتَّاثْ ثمْڒشْ أَكْ-ذ ورْيَازْ.“
\v 4 \add مَاشَا\add* أَبِيمَالِيكْ ثُوغَا وَارْ غَارسْ د-إِقَارّبْ، إِنَّا: ”\add أَ\add* سِيذِي إِنُو، مَا \add خنِّي\add* أَذْ ثَاوْضذْ أَذْ ثنْغذْ إِجّْ ن ڒْڭنْسْ إِسڭّْذنْ؟
\v 5 مَا وَارْ ذ أَيِي إِنِّي نتَّا: ’نتَّاثْ ذ ؤُتْشْمَا \add إِ ثدْجَا\add*!‘، ؤُ نتَّاثْ س يِيخفْ نّسْ ثنَّا عَاوذْ: ’نتَّا ذ ؤُمَا \add إِ يدْجَا\add*!‘ س ثِيذتّْ ن وُوڒْ ؤُ س إِفَاسّنْ إِزْذِيڭنْ إِ ڭِّيغْ أَيَا.“
\v 6 إِنَّا أَسْ أَربِّي ذِي ثَارْجِيثْ: ”نشّْ سّْنغْ عَاذْ بلِّي ثڭِّيذْ مَانْ أَيَا س ثِيذتّْ ن وُوڒْ، خْ ؤُيَا حْضِيغْ شكْ حِيمَا وَارْ خَافِي ثْخطِّيضْ ؤُ وَارْ شكْ جِّيغْ أَذْ ت ثْحَاذِيذْ.
\v 7 ڒخُّو، أَرّْ ثَامْغَارْثْ غَارْ ورْيَازْ نّسْ، مِينْزِي نتَّا ذ أَنَابِي ؤُشَا نتَّا أَذْ خَاكْ إِژَّادْجْ، حِيمَا أَذْ ثدَّارذْ. \add مَاشَا\add* مَاڒَا وَارْ ت ثَارِّيذْ شَا، سّنْ بلِّي أَقَا أَذْ ثمّْثذْ، شكْ ذ مَارَّا مِينْ إِدْجَانْ نّشْ!“
\v 8 إِكَّارْ أَبِيمَالِيكْ زِيشْ غَارْ صّْبحْ. إِڒَاغَا إِ مَارَّا إِمْسخَّارنْ نّسْ، إِنَّا مَارَّا أَوَاڒنْ-أَ ذڭْ إِمزُّوغنْ نْسنْ ؤُشَا إِرْيَازنْ نِّي ذوْڒنْ ڭّْوذنْ أَطَّاسْ.
\v 9 \add خنِّي\add* إِڒَاغَا أَبِيمَالِيكْ خْ إِبْرَاهِيمْ ؤُشَا إِنَّا أَسْ: ”مِينْ ذ أَنغْ ثڭِّيذْ ذ مِينْ ذِي خْضِيغْ أَكِيذكْ ؤُمِي ثْغضْرذْ خَافِي ؤُ خْ ثْڭلْذِيثْ إِنُو دّنْبْ أَمقّْرَانْ؟ شكْ ثڭِّيذْ أَكِيذِي مِينْ وَارْ إِشُووَّارنْ أَذْ \add ث\add* ثڭّذْ.“
\v 10 ؤُشَا \add يَارْنِي\add* إِنَّا أَبِيمَالِيكْ إِ إِبْرَاهِيمْ: ”مِينْ شكْ يجِّينْ ڒَامِي ثڭِّيذْ مَانْ أَيَا؟“
\v 11 إِنَّا إِبْرَاهِيمْ: ”مِينْزِي نْوِيغْ: ’نِيشَانْ وَارْ ذِينِّي ثِيڭّْوُوذِي زِي أَربِّي ذڭْ ومْشَانْ-أَ ؤُشَا أَذْ أَيِي نْغنْ ذِي سِّيبّثْ ن ثمْغَارْثْ إِنُو.‘
\v 12 ؤُشَا س ثِيذتّْ نتَّاثْ عَاوذْ ذ ؤُتْشْمَا. نتَّاثْ ذ يدْجِيسْ ن بَابَا، مَاشَا وَارْ ثدْجِي ذ يدْجِيسْ ن يمَّا ؤُشَا ثذْوڒْ ذ ثَامْغَارْثْ إِنُو.
\v 13 ؤُمِي ذ أَيِي إِسّثْلعْ أَربِّي زِي ثَادَّارْثْ ن بَابَا، نِّيغْ أَسْ: ’أَذْ يِيڒِي وَا ذ \add ڒعْڒَامثْ ن\add* ثْمخْسِيوْثْ نّشْ إِشوَّارنْ إِ نشّْ، أَقَا أَذْ ثِينِيذْ ذِي مَارَّا إِمُوشَانْ مَانِي غَا نَاوضْ: نتَّا أَقَا ذ ؤُمَا!‘ “ \x ◘ \xo 20:‏13 \xt أَمز. 12‏:‏13. \x*
\v 14 \add خنِّي\add* إِكْسِي أَبِيمَالِيكِي ؤُدْجِي ذ إِفُونَاسنْ ذ ثْفُونَاسِينْ ذ إِسمْغَانْ ذ ثِييَّا ؤُشَا إِوْشَا إِ-ثنْ إِ إِبْرَاهِيمْ ؤُشَا يَارّْ أَسْ سَارَا، ثَامْغَارْثْ نّسْ.
\v 15 إِنَّا أَبِيمَالِيكْ: ”خْزَارْ، ثَامُّورْثْ إِنُو أَقَا-ت قِيبَاتْشْ نّشْ. زْذغْ مَانِي إِ ذ أَشْ د-\add إِضْهَارْ\add* مْلِيحْ ذِي ثِيطَّاوِينْ نّشْ.“
\v 16 إِ سَارَا إِنَّا: ”خْزَارْ، وْشِيغْ أَڒفْ ن \add ؤُقِييَّاثْ ن\add* نُّوقَارْثْ إِ ؤُمَامْ. أَقَا أَثنْثْ ذ أَڒحَّافْ خْ ثِيطَّاوِينْ إِ كُوڒْشِي إِنِّي كِيذمْ إِدْجَانْ، \add وَاهْ،\add* إِ كُوڒْشِي إِذْوڒْ أَمْ-د ذ تِّيقَارْثْ.“
\v 17 إِژُّودْجْ إِبْرَاهِيمْ إِ أَربِّي ؤُشَا أَربِّي إِسّْڭنْفَا أَبِيمَالِيكْ ذ ثمْغَارْثْ نّسْ ذ ثمْسخَّارِينْ نّسْ ؤُشَا ؤُرْونْثْ.
\v 18 مِينْزِي ثُوغَا سِيذِي إِبلّعْ قَاعْ مَارَّا ڒمْڒَاوَاثْ ن \add ثمْغَارِينْ ذِي\add* ثَادَّارْثْ ن أَبِيمَالِيكْ ذِي سِّيبّثْ ن سَارَا، ثَامْغَارْثْ ن إِبْرَاهِيمْ.
\b
\b
\c 21
\s1 أَخْڒَاقْ ن إِسْحَاقْ
\m 
\v 1 ؤُشَا يَارْزفْ سِيذِي غَارْ سَارَا، أَمْ مَامّشْ ث إِنَّا، ؤُشَا إِكمّڒْ سِيذِي \add أَوَاڒْ\add* إِ إِنَّا إِ سَارَا. \x ◘ \xo 21:‏1 \xt أَمز. 17‏:‏19؛ 18‏:‏10. \x*
\v 2 ثكْسِي سَارَا س دّيْسثْ ؤُشَا ثُورُووْ-د إِجّْ ن ؤُسيْمِي إِ إِبْرَاهِيمْ خْ ثوْسَارْ نّسْ، ذِي ڒْمِيجَارْ نِّي إِ ذ أَسْ إِنَّا أَربِّي. \x ◘ \xo 21:‏2 \xt أَمز. 18‏:‏10، 14؛ ڭال. 4‏:‏23؛ عبر. 11‏:‏11. \x*
\v 3 ؤُشَا إِڒَاغَا إِبْرَاهِيمْ إِ مِّيسْ أَسيْمِي، ونِّي ذ أَسْ د-ثُورُووْ سَارَا، إِسْحَاقْ.
\v 4 إِبْرَاهِيمْ إِخْثنْ إِ مِّيسْ إِسْحَاقْ ؤُمِي ثُوغَا غَارسْ ثْمنْيَا ن وُوسَّانْ، أَمْ مَامّشْ ذ أَسْ يُومُورْ أَربِّي. \x ◘ \xo 21:‏4 \xt أَمز. 17‏:‏10. \x*
\v 5 ثُوغَا غَارْ إِبْرَاهِيمْ مْيَا ن إِسڭّْوُوسَا، أَڒَامِي غَارسْ د-إِخْڒقْ مِّيسْ إِسْحَاقْ.
\v 6 ثنَّا سَارَا: ”إِسّضْحشْ أَيِي أَربِّي ؤُ كُوڒْ إِجّْ ونِّي إِ غَا إِسْڒَانْ \add إِ مَانْ أَيَا\add*، أَذْ إِضْحشْ \add عَاوذْ\add* أَكِيذِي.“
\v 7 ثنَّا \add عَاوذْ\add*: ”مَانْ ونْ \add إِزعْمنْ\add* أَذْ يِينِي إِ إِبْرَاهِيمْ، أَقَا سَارَا أَذْ ثسُّوطّضْ إِسيْمَانْ؟ أَقَا ؤُرْوغْ \add أَسْ-د\add* أَحنْجِيرْ خْ ثوْسَارْ نّسْ!“
\b
\s1 سَارَا ذ هَاجَارْ
\m 
\v 8 إِڭْمَا ؤُسيْمِي ؤُشَا إِتّْوَاكّسْ أَسْ ؤُطُّوضْ. ذڭْ وَاسّْ إِ ذ أَسْ كّْسنْ ؤُطُّوضْ إِ إِسْحَاقْ، إِسّوْجذْ إِبْرَاهِيمْ إِشْثْ ن زَّارْذثْ ثمْغَارْ.
\v 9 \add ؤُمِي\add* ثژْرَا سَارَا مِّيسْ ن ثْمِيصْرشْثْ هَاجَارْ، ونِّي د-ثُورُووْ \add هَاجَارْ\add* إِ إِبْرَاهِيمْ، إِقصَّارْ خَاسْ،
\v 10 ثنَّا إِ إِبْرَاهِيمْ: ”أَژّڒْ خْ ثَايَّا-يَا ذ مِّيسْ، مِينْزِي مِّيسْ ن ثَايَّا-يَا وَارْ إِوَارّثْ شَا أَكْ-ذ مِّي، أَكْ-ذ إِسْحَاقْ.“ \x ◘ \xo 21:‏10 \xt ڭال. 4‏:‏30. \x*
\v 11 أَوَاڒْ-أَ إِبَانْ-د ذ أَعفَّانْ أَطَّاسْ ذِي ثِيطَّاوِينْ ن إِبْرَاهِيمْ ذِي سِّيبّثْ ن مِّيسْ.
\v 12 \add مَاشَا\add* إِنَّا أَربِّي إِ إِبْرَاهِيمْ: ”وَارْ تّجِّي أَحنْجِيرْ ذ ثَايَّا نّشْ أَذْ إِڒِينْ ذ ثِيسِينفْثْ ذِي ثِيطَّاوِينْ نّشْ. سڒْ غَارْ مَارَّا مِينْ إِ ذ أَشْ غَا ثِينِي سَارَا، مِينْزِي ذِي إِسْحَاقْ أَذْ أَشْ ثِيڒِي زَّارِيعثْ. \f ◼ \fr 21:‏12 \ft \bd ’زَّارِيعثْ‘\bd* - إِخْسْ أَذْ يِينِي ’ثَارْوَا‘.\f*  \x ◘ \xo 21:‏12 \xt رُوم. 9‏:‏7؛ عبر. 11‏:‏18. \x*
\v 13 أَذْ ڭّغْ عَاوذْ إِجّْ ن ڒْڭنْسْ زِي مِّيسْ ن ثَايَّا-يَا، مِينْزِي ؤُڒَا ذ نتَّا ذ زَّارِيعثْ نّشْ.“ \x ◘ \xo 21:‏13 \xt أَمز. 16‏:‏10؛ 17‏:‏20. \x*
\v 14 \add خنِّي\add* إِكَّارْ إِبْرَاهِيمْ زِيشْ ؤُشَا إِكْسِي أَغْرُومْ ذ إِشْثْ ن ثشْيَارْثْ ن وَامَانْ، إِوْشَا \add إِ-ثنْ\add* إِ هَاجَارْ، إِسَّارْسْ \add أَسْ ثنْ\add* خْ ثغْرُوضْثْ. \add إِوْشَا أَسْ عَاوذْ\add* أَحنْجِيرْ ؤُشَا إِسّْقبّضْ إِ-ت. ؤُشَا نتَّاثْ ثْرُوحْ، ثنّجْرُو ذِي ڒخْڒَا ن بِئرْ-سبْعَا.
\v 15 \add ڒَْامِي\add* نقْصنْ وَامَانْ زِي ثشْيَارْثْ، ثنْضَارْ أَحنْجِيرْ سَاذُو إِجّْ ن شْبَارْقْ،
\v 16 ؤُشَا ثْرُوحْ ثقِّيمْ قِيبَاتْشْ نّسْ ڒَاڭّْوَاجْ ن ثشْثِي ن ڒْقوْسْ، مِينْزِي ثنَّا: ”وَارْ زمَّارغْ أَذْ ژَترغْ مڒْمِي إِ غَا إِمّثْ ؤُحنْجِيرْ.“ \add أَمُّو\add* إِ ثقِّيمْ قِيبَاتْشْ نّسْ ؤُشَا ثسّْڭعّذْ ثْمِيجَّا نّسْ، ثسْغُويُّو.
\v 17 إِسْڒَا أَربِّي غَارْ ثْمِيجَّا ن ؤُحنْجِيرْ ؤُشَا لْمَالَاكْ ن أَربِّي إِڒَاغَا إِ هَاجَارْ زڭْ ؤُجنَّا، إِنَّا أَسْ: ”مِينْ شمْ يُوغِينْ، هَاجَارْ؟ وَارْ تّڭّْوذْ شَا، مِينْزِي أَربِّي إِسْڒَا ڒْحسّْ ن ؤُحنْجِيرْ، ذِينْ مَانِي إِدْجَا.
\v 18 كَّارْ، سْڭعّذْ أَحنْجِيرْ ؤُشَا طّفْ أَسْ ذڭْ ؤُفُوسْ نّمْ، مِينْزِي أَذْ زَّايسْ ڭّغْ إِجّْ ن ڒْڭنْسْ إِمْغَارْ.“ \x ◘ \xo 21:‏18 \xt أَمز. 16‏:‏10؛ 17‏:‏20. \x*
\v 19 ؤُشَا يَارْزمْ أَربِّي ثِيطَّاوِينْ نّسْ، ثژْرَا ڒْعُونْصَارْ ن وَامَانْ. ثْرُوحْ، ثْعمَّارْ ثَاشْيَارْثْ س وَامَانْ، ثوْشَا أَسْ إِ ؤُحنْجِيرْ، أَذْ إِسُو.
\v 20 ثُوغَا أَربِّي أَكْ-ذ ؤُحنْجِيرْ، إِيْمَا، إِزْذغْ ذِي ڒخْڒَا ؤُ ثُوغَا-ث ذ أَمْجبَّاذْ نْ ڒْقوْسْ.
\v 21 ثُوغَا إِزدّغْ ذِي ڒخْڒَا ن فَارَانْ ؤُشَا ثكْسِي أَسْ-د يمَّاسْ ثَامْغَارْثْ زِي ثمُّورْثْ ن مِيصْرَا.
\b
\s1 ڒْعَاهْذْ جَارْ إِبْرَاهِيمْ ذ أَبِيمَالِيكْ
\m 
\v 22 ذِي ڒْوقْثْ نِّي ذ إِشْثْ إِمْسَارْ، بلِّي أَبِيمَالِيكْ أَكْ-ذ فِيكُولْ، أَكُومَانْذَارْ ن ڒْعسْكَارْ نّسْ، إِسِّيوڒْ أَكْ-ذ إِبْرَاهِيمْ، إِنَّا: ”أَربِّي أَقَا-ث أَكِيذكْ ذِي مَارَّا مِينْ ثتّڭّذْ. \f ◼ \fr 21:‏22 \ft \bd ’فِيكُولْ‘\bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَقمُّونْ ن مَارَّا‘. أَقَا نتَّا خْ مَارَّا إِعسْكَارِييّنْ ؤُ ثُوغَا إِتّْخصَّا أَذْ أَسْ طَّاعنْ ذِي مَارَّا مِينْ يُومُورْ نتَّا.\f*
\v 23 ڒخُّو، جَادْجْ أَيِي غَارْ أَربِّي، أَقَا وَارْ ثتّْغشِّيذْ إِحنْجِيرنْ إِنُو ؤُڒَا ذ أَيَّاونْ إِنُو! \add مَاشَا\add* س مُوخَاسْ ثَامخْسِيوْثْ إِشوَّارنْ إِ كِيكْ ڭِّيغْ قْبڒْ، أَذْ زَّايسْ ثڭّذْ شكْ أَكِيذِي ؤُ أَكْ-ذ ثمُّورْثْ مَانِي ثقِّيمذْ أَمْ ؤُبَارَّانِي.“ \x ◘ \xo 21:‏23 \xt أَمز. 14‏:‏23. \x*
\v 24 إِنَّا إِبْرَاهِيمْ: ”نشّْ أَذْ جَّادْجغْ!“
\v 25 \add خَاسْ ؤُشَا\add* إِعيّبْ إِبْرَاهِيمْ أَبِيمَالِيكْ خْ ڒْعُونْصَارْ ن وَامَانْ نِّي إِطّْفنْ \add زَّايسْ\add* إِمْسخَّارنْ ن أَبِيمَالِيكْ س ؤُغِيڒْ.
\v 26 \add خنِّي\add* إِنَّا أَبِيمَالِيكْ: ”نشّْ وَارْ سِّينغْ وِي إِڭِّينْ مَانْ أَيَا ؤُ شكْ وَارْ ذ أَيِي ث ثنِّيذْ شَا قْبڒْ. أَقَا أَڒْ ڒخُّو إِ زَّايكْ ث سْڒِيغْ.“
\v 27 إِكْسِي إِبْرَاهِيمْ ؤُدْجِي ذ إِفُونَاسنْ ذ ثْفُونَاسِينْ ؤُشَا إِوْشَا أَسْ ثنْ إِ أَبِيمَالِيكْ ؤُشَا نِيثْنِي س ثْنَاينْ إِذْسنْ ڭِّينْ إِجّْ ن ڒْعَاهْذْ \add جَارْ أَسنْ\add*.
\v 28 \add مَاشَا\add* إِسَّارْسْ إِبْرَاهِيمْ سبْعَا ن ثْخسْوِينْ زڭْ وُودْجِي غَارْ ؤُغزْذِيسْ.
\v 29 \add خنِّي\add* إِنَّا أَبِيمَالِيكْ إِ إِبْرَاهِيمْ: ”مِينْ عْنَانْثْ سبْعَا ن ثْخسْوِينْ نِّي ثڭِّيذْ غَارْ ؤُغزْذِيسْ؟“
\v 30 إِنَّا نتَّا: ”كْسِي زعْمَا سبْعَا أَيَا ن ثْخسْوِينْ زڭْ إِفَاسّنْ إِنُو، حِيمَا أَذْ إِڒِينْثْ ذ شّْهَاذثْ ذِي طّْوعْ إِنُو بلِّي نشّْ إِ إِغْزِينْ أَنُو-يَا.“
\v 31 خْ ؤُيَا سمَّانْ أَمْشَانْ نِّي بِئرْ-سبْعَا، مِينْزِي نِيثْنِي س ثْنَاينْ إِذْسنْ ثُوغَا جُّودْجنْ ذِينْ.
\v 32 \add أَمُّو إِ\add* ڭِّينْ ڒْعَاهْذْ ذِي بِئرْ-سبْعَا. \add أَوَارْنِي مَانْ أَيَا\add* إِكَّارْ أَبِيمَالِيكْ أَكْ-ذ فِيكُولْ، أَكُومَانْذَارْ ن ڒْعسْكَارْ نّسْ، إِعْقبْ غَارْ ثمُّورْثْ ن إِفِيلِيسْطِينِييّنْ.
\v 33 إِژُّو إِبْرَاهِيمْ إِشْثْ ن ثْشجَّارْثْ ن ثْمَارِيسْثْ ذِي بِئرْ-سبْعَا ؤُشَا إِڒَاغَا ذِينْ إِسمْ ن سِيذِي، أَربِّي ن ڒبْذَا. \f ◼ \fr 21:‏33 \ft \bd ’ثَاشجَّارْثْ ن ثْمَارِيسْثْ‘\bd* - س ثْلَاثِينِيثْ ’ثَامَارِيخْ‘.\f*  \x ◘ \xo 21:‏33 \xt أَمز. 4‏:‏26. \x*
\v 34 إِزْذغْ إِبْرَاهِيمْ أَمْ ؤُبَارَّانِي ذِي ثمُّورْثْ ن إِفِيلِيسْطِينِييّنْ أَطَّاسْ ن وُوسَّانْ.
\b
\b
\c 22
\s1 إِبْرَاهِيمْ إِقدّمْ مِّيسْ إِسْحَاقْ ذ ثَاغَارْصْثْ إِ أَربِّي
\m 
\v 1 أَوَارْنِي مَانْ أَيَا ثمْسَارْ، أَقَا إِجَارّبْ أَربِّي إِبْرَاهِيمْ، إِنَّا أَسْ: ”إِبْرَاهِيمْ!“ ؤُشَا إِنَّا أَسْ: ”خْزَارْ، نشّْ أَقَا أَيِي ذَا!“
\v 2 إِنَّا أَسْ نتَّا: ”كْسِي أَينِّي ن مِّيشْ، ونِّي ثخْسذْ، إِسْحَاقْ، ؤُشَا رُوحْ غَارْ ثمُّورْثْ ن مُورِييَا ؤُشَا ثْقدّْمذْ ث ذِينْ ذ ثَاغْرَاصْثْ خْ يِيجّْ ن وذْرَارْ جَارْ إِذُورَارْ إِ ذ أَشْ غَا إِنِيغْ.“ \x ◘ \xo 22:‏2 \xt عبر. 11‏:‏17. \x*
\v 3 إِكَّارْ إِبْرَاهِيمْ زِيشْ، إِحزّمْ إِ وغْيُوڒْ نّسْ ؤُشَا إِكْسِي أَكِيذسْ ثْنَاينْ ن إِمْسخَّارنْ نّسْ ذ مِّيسْ إِسْحَاقْ. إِقسّْ أَكشُّوضْ إِ ثوْهِيبْثْ ن ثْغَارْصْثْ، إِكَّارْ، إِرُوحْ ذڭْ وبْرِيذْ غَارْ ومْشَانْ إِ ذ أَسْ إِنَّا أَربِّي.
\v 4 ذڭْ وَاسّْ وِيسّْ ثْڒَاثَا إِسّْڭعّذْ إِبْرَاهِيمْ ثَامُوغْڒِي نّسْ ؤُشَا إِژْرَا أَمْشَانْ زِي ڒَاڭّْوَاجْ.
\v 5 إِنَّا إِبْرَاهِيمْ إِ إِمْسخَّارنْ نّسْ: ”رَاجَامْ ذَا أَكْ-ذ وغْيُوڒْ، نشّْ ذ ؤُحنْجِيرْ أَذْ نْرَاحْ ذِيهَا، أَذْ نسْجذْ. \add أَوَارْنِي أَسْ\add* أَذْ غَارْومْ د-نعْقبْ.“
\v 6 إِكْسِي إِبْرَاهِيمْ أَكشُّوضْ إِ وشْمَاضْ ن ثْغَارْصْثْ، إِسَّارْسْ إِ-ث خْ مِّيسْ إِسْحَاقْ ؤُ نتَّا \add س يِيخفْ نّسْ\add* إِكْسِي س ؤُفُوسْ نّسْ ثِيمسِّي ذ ثْخذْمشْثْ، ؤُشَا \add أَمُّو إِ\add* رُوحنْ نِيثْنِي س ثْنَاينْ إِذْسنْ.
\v 7 \add خنِّي\add* إِسِّيوڒْ إِسْحَاقْ أَكْ-ذ إِبْرَاهِيمْ بَابَاسْ، إِنَّا: ”بَابَا إِنُو!“ إِنَّا نتَّا: ”خْزَارْ، نشّْ أَقَا أَيِي ذَا، مِّي!“ ؤُشَا إِنَّا نتَّا: ”خْزَارْ، \add أَقَا ذَا\add* ثِيمسِّي ذ ؤُكشُّوضْ، مَاشَا مَانِي إِدْجَا إِزْمَارْ إِ ثْغَارْصْثْ؟“ \x ◘ \xo 22:‏7 \xt يُوح. 1‏:‏29، 36\x*
\v 8 إِنَّا إِبْرَاهِيمْ: ”أَربِّي سِيمَانْثْ نّسْ أَذْ إِسَّارْزقْ س يزْمَارْ إِ ثْغَارْصْثْ، \add أَ\add* مِّي!“ ؤُشَا \add أَمُّو إِ\add* رُوحنْ س ثْنَاينْ إِذْسنْ
\v 9 ؤُشَا إِوْضنْ غَارْ ومْشَانْ نِّي إِ ذ أَسْ إِنَّا أَربِّي. ذِينْ إِ إِبْنَا إِبْرَاهِيمْ إِجّْ ن ؤُعَالْطَارْ ؤُشَا إِعْذڒْ أَكشُّوضْ، إِشَارْفْ مِّيسْ إِسْحَاقْ ؤُشَا إِسَّارْسْ إِ-ث خْ ؤُعَالْطَارْ خْ إِكشْوَاضْ. \x ◘ \xo 22:‏9 \xt يَاع. 2‏:‏21. \x*
\v 10 \add خَاسْ ؤُشَا\add* إِسّْوِيژّضْ إِبْرَاهِيمْ أَفُوسْ نّسْ ؤُشَا إِكْسِي-د ثَاخذْمشْثْ، حِيمَا أَذْ إِغَارْصْ إِ مِّيسْ.
\v 11 \add مَاشَا\add* لْمَالَاكْ ن سِيذِي إِڒَاغَا أَسْ-د زڭْ ؤُجنَّا، إِنَّا أَسْ: ”إِبْرَاهِيمْ، إِبْرَاهِيمْ!“ نتَّا إِنَّا: ”نشّْ أَقَا أَيِي ذَا!“
\v 12 \add خنِّي\add* إِنَّا أَسْ: ”وَارْ سْوِيژِّيضْ أَفُوسْ نّشْ غَارْ ؤُحنْجِيرْ. وَارْ ذ تّڭّْ شَا، مِينْزِي ڒخُّو أَقَا سّْنغْ بلِّي ثتّڭّْوذذْ أَربِّي ؤُ وَارْ خَافِي ثسّْعِيزّذْ أَينِّي ن مِّيشْ.“
\v 13 إِسّْڭعّذْ إِبْرَاهِيمْ ثِيطَّاوِينْ نّسْ، ؤُ خْزَارْ، أَقَا أَوَارْنِي أَسْ ثُوغَا إِجّْ ن إِشَارِّي إِقّنْ غَارْ شْبَارْقْ زڭْ وَاشَّاونْ نّسْ. يُويُورْ إِبْرَاهِيمْ ذِينِّي، إِطّفْ إِشَارِّي ؤُشَا إِڭَّا-إِ-ث ذ ثَاغَارْصْثْ ذڭْ ومْشَانْ ن مِّيسْ. \f ◼ \fr 22:‏13 \ft \bd ’أَشَّاونْ‘\bd* - نِيغْ ’إِقِيشَّاونْ‘.\f*
\v 14 إِڒَاغَا إِبْرَاهِيمْ إِسمْ ن ومْشَانْ نِّي: ”سِيذِي أَذْ إِسَّارْزقْ!“ س ؤُينِّي إِقَّارْ بْنَاذمْ أَڒْ أَسّْ-أَ: ”ذڭْ وذْرَارْ ن سِيذِي أَذْ يِيڒِي يَارْزقْ!“ \f ◼ \fr 22:‏14 \ft \bd ’أَذْ إِسَّارْزقْ ... أَذْ إِتّْوَاسَّارْزقْ‘\bd* - س ثْعِيبْرَانِيثْ ’أَذْ إِژَارْ ... أَذْ إِتّْوَاژَارْ‘. \bd أَفسَّارْ\bd* - وَا ذ أَذْرَارْ ’مُورِي-يَاهْ‘، أَمْشَانْ نِّي إِ غَا إِسّْشنْ أَربِّي (أَعَوذ. 12:11) ذ أَمْشَانْ ن زَّاوشْثْ إِقدّْسنْ نِّي ثُوغَا ذِينْ ذڭْ وُوسَّانْ أَوَارْنِي مَانْ أَيَا. أَذْ ثَاغْ ثُوغَا أَمْشَانْ-أَ ؤُڒَا ذ أَمْشَانْ مَانِي ثُوغَا إِزدّغْ مَالْكِيصَاذِيقْ، أَجدْجِيذْ ن سَالِيمْ، إِخْسْ أَذْ يِينِي ثَاسْغَارْثْ ن وذْرَارْ نِّي إِدْجَانْ غَارْ شَّامَالْ، ثنِّي إِذوْڒنْ ذ أَذْرَارْ ن زَّاوشْثْ إِقدّْسنْ. ثَاسْغَارْثْ ن لْجَانُوبْ ن وذْرَارْ ثُوغَا ذ ثَانْذِينْثْ ن ذَاوُوذْ. ذَاوُوذْ إِطّفْ لْپُورْجْ ن أَيْثْ ن يَاپُوسْ نِّي إِدْجَانْ خْ وذْرَارْ-أَ (1 إِج. 8:1، 1 إِم. 11:5، 2 صم. 5:6، 7، 9). أَوَارْنِي أَسْ إِسْغَا ذَاوُوذْ ثَاسْغَارْثْ ن شَّامَالْ ن وذْرَارْ 'مُورِي-يَاهْ' زِي أَرَاوْنَا، ونِّي غَارْ إِدْجْ إِجّْ ن ونْذْرَارْ خْ وذْرَارْ-أَ مَانِي ثُوغَا د-إِسّهْوَا لْمَالَاكْ ن سِيذِي أَفُوسْ نّسْ أَڒَامِي ثْبدّْ جّْرِيحشْثْ نِّي إِسِّيوضْ لْمَالَاكْ ن سِيذِي خْ إِسْرَائِيل نِّي د يُوسِينْ زِي سِّيبّثْ ن ڒحْسَابْ نْ ڒْڭنْسْ نِّي إِڭَّا ذَاوُوذْ س يِيخفْ نّسْ، بْڒَا مَا إِتَّارْ سِيذِي (خْزَارْ 2 صم. 24). خْمِي إِ غَا نْغَارْ 2 صم. 5:7، 1 إِج. 8:1 ؤُ إِزهد. 2:6 نتَّافْ أَقَا نْزمَّارْ أَذْ نحْسبْ أَذْرَارْ-أَ 'مُورِي-يَاهْ' ذ أَذْرَارْ 'سِيحْيُونْ'، أَذْرَارْ إِقدّْسنْ، مَانِي سَّارْسنْ تَّاپُوثْ ذڭْ وُوسَّانْ ن ذَاوُوذْ (2 صم. 6:17). إِذْوڒْ سِيحْيُونْ ذ إِسمْ أَنڭَّارْ ن مَارَّا أَذْرَارْ، ؤُڒَا ذ إِسمْ إِ ثنْذِينْثْ ن ؤُرْشَالِيمْ مَارَّا. خْزَارْ عَاوذْ أَفسَّارْ غَارْ 2 إِج. 19:31.\f*
\v 15 إِڒَاغَا-د لْمَالَاكْ ن سِيذِي وِيسّْ مَارْثَاينْ زڭْ ؤُجنَّا خْ إِبْرَاهِيمْ،
\v 16 إِنَّا: ”مِينْزِي ثڭِّيذْ مَانْ أَيَا ؤُشَا وَارْ خَافِي ثطِّيفذْ أَينِّي ن مِّيشْ، أَذْ جَّادْجغْ خْ سِيمَانْثْ إِنُو، إِقَّارْ سِيذِي، \x ◘ \xo 22:‏16 \xt لك. 1‏:‏73؛ عبر. 6‏:‏13. \x*
\v 17 أَقَا أَذْ شكْ بَارْكغْ أَطَّاسْ ؤُشَا أَذْ كتَّارغْ زَّارِيعثْ نّشْ أَطَّاسْ أَمْ يِيثْرَانْ ن ؤُجنَّا ؤُ أَمْ يِيجْذِي خْ ثْمَا ن ڒبْحَارْ. زَّارِيعثْ نّشْ أَذْ ثطّفْ ثَاوَّارْثْ ن ڒْعذْيَانْ نّسْ ذ ڒْوَارْثْ \x ◘ \xo 22:‏17 \xt أَمز. 24‏:‏60. \x*
\v 18 ؤُ ذِي زَّارِيعثْ نّشْ أَذْ تّْوَابَارْكنْ مَارَّا ڒڭْنُوسْ ن ثمُّورْثْ، مِينْزِي ثسْڒِيذْ إِ ثْمِيجَّا إِنُو.“ \x ◘ \xo 22:‏18 \xt أَمز. 12‏:‏3؛ 18‏:‏18؛ 26‏:‏4؛ ڒخ. 3‏:‏25؛ ڭال. 3‏:‏8. \x*
\v 19 \add خنِّي\add* إِعْقبْ-د إِبْرَاهِيمْ غَارْ إِمْسخَّارنْ نّسْ. نِيثْنِي كَّارنْ ؤُشَا رُوحنْ جْمِيعْ \add ذڭْ وبْرِيذْ\add* غَارْ بِئرْ-سبْعَا، ؤُشَا إِڭَّا إِبْرَاهِيمْ أَذْ إِزْذغْ ذِي بِئرْ-سبْعَا.
\m 
\v 20 أَوَارْنِي مَانْ أَيَا إِمْسَارْ أَقَا خبَّارنْ إِبْرَاهِيمْ، نَّانْ أَسْ: ”خْزَارْ، عَاوذْ مِيلْكَا ثُورُووْ-د إِحنْجِيرنْ إِ نَاحُورْ ؤُمَاشْ:
\v 21 عُوصْ، أَمنْزُو نّسْ، ذ بُوزْ ؤُمَاسْ، ذ قَامُووِيلْ ونِّي ذ بَابَاسْ ن أَرَامْ،
\v 22 ذ كَاسَاذْ ذ حَازُو ذ فِيلْذَاشْ ذ يِيذْلَافْ ذ بِيثُووِيلْ.“
\v 23 بِيثُووِيلْ إِجَّا-د رِيفْقَا. ثْمنْيَا أَيَا إِ د-ثُورُووْ مِيلْكَا إِ نَاحُورْ، ؤُمَاسْ ن إِبْرَاهِيمْ.
\v 24 ؤُ ثَايَّا نّسْ، ثنِّي ؤُمِي قَّارنْ رِيعُومَا، ثُورُووْ \add أَسْ\add*-د عَاوذْ طَابَاحْ ذ جَاحَامْ ذ ثَاحَاشْ ذ مَاعْكَا. \f ◼ \fr 22:‏24 \ft \bd ’ثَايَّا نّسْ‘\bd* - إِخْسْ أَذْ يِينِي ’ثَايَّا ن نَاحُورْ‘.\f*
\b
\b
\c 23
\s1 ڒْموْثْ ذ ونْضڒْ ن سَارَا
\m 
\v 1 ثُوغَا غَارْ سَارَا مْيَا ؤُ-سبْعَا ؤُ-عِيشْرِينْ ن إِسڭّْوُوسَا. \add مَانْ أَيَا ذ ڒْمِيجَاڒْ ن\add* إِسڭّْوُوسَا ن ثُوذَارْثْ ن سَارَا.
\v 2 ؤُشَا ثمُّوثْ سَارَا ذِي قَارْيَاثْ-أَرْبَاعْ، إِخْسْ أَذْ يِينِي حَابْرُونْ، ذِي ثمُّورْثْ ن كنْعَانْ. ؤُشَا يُوذفْ-د إِبْرَاهِيمْ \add غَارْ ؤُقِيضُونْ\add*، إِشْضنْ خْ سَارَا، إِسْغُويْ خَاسْ.
\v 3 \add خَاسْ ؤُشَا\add* إِكَّارْ إِبْرَاهِيمْ طَّارْفْ إِ ؤُمتِّينْ نّسْ، ؤُشَا إِسِّيوڒْ أَكْ-ذ ثَارْوَا ن حِيثْ، إِنَّا:
\v 4 ”نشّْ ذ أَبَارَّانِي ذ أَمْعزّبْ غَارْ أَومْ. وْشمْ أَيِي مْغِيرْ أَنْضڒْ ذ أَڭْڒَا جَارْ أَومْ، حِيمَا أَذْ نضْڒغْ أَمتِّينْ إِنُو زِي زَّاثْ إِنُو.“ \x ◘ \xo 23:‏4 \xt ڒخ. 7‏:‏5. \x*
\v 5 أَرِّينْ-د ثَارْوَا ن حِيثْ خْ إِبْرَاهِيمْ، نَّانْ أَسْ:
\v 6 ”سڒْ غَارْنغْ، \add أَ\add* سِيذِي إِنُو! شكْ ذ ڒْحَاكمْ ن أَربِّي جَارْ أَنغْ. نْضڒْ أَمتِّينْ نّشْ ذڭْ ونْضڒْ نّغْ إِصبْحنْ. ؤُڒَا ذ إِجّْ زَّايْنغْ أَذْ شكْ إِطّفْ خْ ونْضڒْ نّسْ، حِيمَا أَذْ \add ذَايسْ\add* ثْنضْڒذْ أَمتِّينْ نّشْ.“
\v 7 \add خنِّي\add* إِكَّارْ إِبْرَاهِيمْ، إِبنْذقْ زَّاثْ إِ ڒْڭنْسْ ن ثمُّورْثْ، زَّاثْ إِ ثَارْوَا ن حِيثْ
\v 8 ؤُشَا إِسِّيوڒْ أَكِيذْسنْ، إِنَّا: ”مَاڒَا كنِّيوْ س أَرَّايْ نْومْ أَذْ نضْڒغْ أَمتِّينْ إِنُو زِي زَّاثْ إِنُو، سْڒمْ غَارِي ؤُشَا زَاوْڭمْ ذِي طّْوعْ إِنُو غَارْ عِيفْرُونْ، مِّيسْ ن زُوهَارْ،
\v 9 مَاحنْذْ أَذْ أَيِي إِوْشْ إِفْرِي ن مَاكْفِيلَا، ذ ونِّي نّسْ، غَارْ طَّارْفْ ن ييَّارْ نّسْ. أجّْ إِ-ث أَذْ أَيِي ث إِوْشْ س تَّامَانْ نّسْ إِكْمڒْ. أَذْ يِيڒِي ذ أَنْضڒْ إِنُو إِ غَا ملّْكغْ جَارْ أَومْ.“
\v 10 عِيفْرُونْ ثُوغَا إِقِّيمْ جَارْ ثَارْوَا ن حِيثْ ؤُشَا عِيفْرُونْ، أَحِيتِّي، يَارَّا-د خْ إِبْرَاهِيمْ ذڭْ إِمجَّانْ ن ثَارْوَا ن حِيثْ ذ مَارَّا إِنِّي يُوذْفنْ غَارْ ثوَّارْثْ ن ثنْذِينْثْ نّسْ، إِنَّا:
\v 11 ”لَّ، أَ سِيذِي إِنُو، سڒْ-د غَارِي! نشّْ أَذْ أَشْ وْشغْ إِيَّارْ ؤُڒَا ذ إِفْرِي نِّي ذَايسْ إِدْجَانْ. زَّاثْ إِ ثِيطَّاوِينْ ن ثَارْوَا ن ڒْڭنْسْ إِنُو أَذْ أَشْ ث وْشغْ، نْضڒْ أَمتِّينْ نّشْ!“
\v 12 \add خنِّي\add* إِبنْذقْ إِبْرَاهِيمْ س ؤُغمْبُوبْ نّسْ غَارْ ثمُّورْثْ زَّاثْ إِ ڒْڭنْسْ ن ثمُّورْثْ
\v 13 ؤُشَا إِسِّيوڒْ أَكْ-ذ عِيفْرُونْ ذڭْ إِمزُّوغنْ ن ڒْڭنْسْ ن ثمُّورْثْ، إِنَّا: ”تّْزَاوْڭغْ، مَاڒَا ثخْسذْ، سڒْ-د غَارِي. أَذْ أَشْ وْشغْ نُّوقَارْثْ ن ييَّارْ، قْبڒْ إِ-ت زَّايِي، \add خنِّي\add* أَذْ ذَايسْ نضْڒغْ أَمتِّينْ إِنُو.“
\v 14 يَارَّا-د عِيفْرُونْ خْ إِبْرَاهِيمْ، إِنَّا أَسْ:
\v 15 ”سِيذِي إِنُو، سڒْ-د غَارِي! مِينْ إِخْسْ أَذْ يِينِي إِيَّارْ إِسكّْوَانْ أَربْعَا-مْيَا شِيقْلُو ن نُّوقَارْثْ جَارْ أَيِي ذ شكْ؟ نْضڒْ أَمتِّينْ نّشْ!“ \f ◼ \fr 23:‏15 \ft \bd ’أَشِيقْلْ ... إِشِيقْلنْ‘\bd* - إِجّْ ن ڒقْيَاسْ ن وُورغْ ذ نُّوقَارْثْ ؤُ ن ڒْحَاجَاثْ نّغْنِي. أَقَا ذِينْ ؤُڒَا ذ أَشِيقْلْ ن زَّاوشْثْ إِقدّْسنْ (خْزَارْ ؤُف. 38:26).\f*
\v 16 إِسْڒَا إِبْرَاهِيمْ إِ عِيفْرُونْ ؤُشَا إِوْزنْ إِبْرَاهِيمْ إِ عِيفْرُونْ ثْمنْيَاثْ ن نُّوقَارْثْ إِ خفْ إِسِّيوڒْ ذڭْ إِمزُّوغنْ ن ثَارْوَا ن حِيثْ: أَربْعَا-مْيَا شِيقْلُو ن نُّوقَارْثْ، أَمْ ت نُّومنْ إِسبَّابنْ. \x ◘ \xo 23:‏16 \xt أَمز. 50‏:‏13. \x*
\v 17 \add أَمُّو إِ\add* إِذْوڒْ ييَّارْ ن عِيفْرُونْ، ونِّي إِدْجَانْ ذِي مَاكْفِيلَا أَرنْذَاذْ ن مَامْرِي، إِيَّارْ ذ إِفْرِي ونِّي ذَايسْ إِدْجَانْ ذ مَارَّا ثِيشجُّورَا إِنِّي ذڭْ إِيَّارْ غَارْ إِيْمِيرنْ نّسْ إِ ذ أَسْ د-إِنّْضنْ، \f ◼ \fr 23:‏17 \ft \bd ’مَاكْفِيلَا‘\bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’ثْنَاينْ ن ثْسقَّارْ‘ نِيغْ ’ثَاسْغَارْثْ‘ (خْ وبْرِيذْ ن ؤُمذْيَا: ’ثَاسْغَارْثْ ن ثمُّورْثْ‘).\f*  \x ◘ \xo 23:‏17 \xt ڒخ. 7‏:‏16. \x*
\v 18 ذ أَڭْڒَا ن إِبْرَاهِيمْ زَّاثْ إِ ثَارْوَا ن حِيثْ ذ مَارَّا إِنِّي يُوذْفنْ غَارْ ثوَّارْثْ ن ثنْذِينْثْ.
\v 19 أَوَارْنِي أَيَا إِنْضڒْ إِبْرَاهِيمْ سَارَا، ثَامْغَارْثْ نّسْ، ذڭْ إِفْرِي ن ييَّارْ ن مَاكْفِيلَا قِيبَاتْشْ إِ مَامْرِي، ونِّي إِدْجَانْ ذ حَابْرُونْ ذِي ثمُّورْثْ ن كنْعَانْ.
\v 20 \add أَمُّو إِ\add* إِذْوڒْ إِيَّارْ أَكْ-ذ يفْرِي إِ ذَايسْ إِدْجَانْ زِي ثَارْوَا ن حِيثْ غَارْ إِبْرَاهِيمْ أَمْ ونْضڒْ نّسْ.
\b
\b
\c 24
\s1 إِسْحَاقْ ذ رِيفْكَا
\m 
\v 1 إِبْرَاهِيمْ ثُوغَا إِوْسَارْ ؤُ إِمْغَارْ ذڭْ وُوسَّانْ ؤُشَا سِيذِي إِبَاركْ إِبْرَاهِيمْ ذِي كُوڒْشِي.
\v 2 \add خنِّي\add* إِنَّا إِبْرَاهِيمْ إِ ؤُمْسخَّارْ نّسْ أَوسَّارْ نِّي إِدْجَانْ خْ ثَادَّارْثْ نّسْ، أَوْكِيڒْ ن مَارَّا مِينْ غَارسْ: ”أڭّْ ڒخُّو أَفُوسْ نّشْ سَاذُو ثْمصَّاضْثْ إِنُو، \x ◘ \xo 24:‏2 \xt أَمز. 47‏:‏29. \x*
\v 3 أَذْ أَشْ سّْجَّادْجغْ س سِيذِي، أَربِّي ن إِجنْوَانْ ذ أَربِّي ن ثمُّورْثْ، بلِّي وَارْ د-ثتِّيوْيذْ ثَامْغَارْثْ إِ مِّي زِي ثْحنْجِيرِينْ ن أَيْثْ ن كنْعَانْ مَانِي زدّْغغْ نشّْ جَارْ أَسنْ، \x ◘ \xo 24:‏3 \xt أَمز. 28‏:‏1. \x*
\v 4 \add مَاشَا\add* أَذْ ثْرَاحذْ غَارْ ثمُّورْثْ \add إِ زِي د-ؤُسِيغْ\add*، غَارْ رَادْجْ إِنُو، \add مَاحنْذْ\add* أَذْ د-ثَاوْيذْ ثَامْغَارْثْ إِ مِّي إِسْحَاقْ.“
\v 5 إِنَّا أَسْ ؤُمْسخَّارْ: ”بَالَاكْ وَارْ ثتّخْسْ ثمْغَارْثْ أَذْ أَيِي د-ثضْفَارْ غَارْ ثمُّورْثْ-أَ. مَا إِتّْخصَّا أَذْ أَرّغْ مِّيشْ غَارْ ثمُّورْثْ نِّي مَانِيسْ د-ثُوسِيذْ؟“
\v 6 إِنَّا أَسْ إِبْرَاهِيمْ: ”حْضَاثْ، وَارْ د-تَّارِّي شَا مِّي ذِينِّي!
\v 7 سِيذِي، أَربِّي ن إِجنْوَانْ ونِّي ذ أَيِي إِطّْفنْ زِي ثَادَّارْثْ ن بَابَا ؤُ زِي ثمُّورْثْ ن رَادْجْ إِنُو، ونِّي غَارِي إِسِّيوْڒنْ، إِجُّودْجْ أَيِي ؤُمِي ذ أَيِي إِنَّا: ’إِ زَّارِيعثْ نّشْ أَذْ وْشغْ ثَامُّورْثْ-أَ!‘، ذ نتَّا إِ غَا إِسّكّنْ لْمَالَاكْ نّسْ زَّاثْ إِ وُوذمْ نّشْ، مَاحنْذْ أَذْ ثَاوْيذْ سّنِّي ثَامْغَارْثْ إِ مِّي. \x ◘ \xo 24:‏7 \xt أَمز. 12‏:‏1، 7؛ 13‏:‏15؛ 15‏:‏18؛ 26‏:‏4؛ ؤُف. 32‏:‏13؛ أَعَوذ. 34‏:‏4؛ ڒخ. 7‏:‏5. \x*
\v 8 مَاڒَا ثَامْغَارْثْ وَارْ ثتّخْسْ أَذْ شكْ د-ثضْفَارْ، أَذْ ثِيڒِيذْ ثْڒلِّيذْ زِي ثْجَادْجِيثْ-أَ، مْغِيرْ وَارْ د-تَّارِّي ذِينْ مِّي.“
\v 9 إِسَّارْسْ ؤُمْسخَّارْ أَفُوسْ نّسْ سَاذُو ثْمصَّاضْثْ ن سِيذِيسْ إِبْرَاهِيمْ إِجُّودْجْ أَسْ خْ مَانْ أَيَا.
\m 
\v 10 إِكْسِي ؤُمْسخَّارْعشْرَا ن إِڒغْمَانْ زڭْ إِڒغْمَانْ ن سِيذِيسْ، إِرُوحْ. ثُوغَا غَارسْ عْڒَامْ كُوڒْ أَڭْڒَا إِغْڒَانْ ن سِيذِيسْ. إِكَّارْ ؤُشَا إِطّفْ أَبْرِيذْ غَارْ \add ثمُّورْثْ ن\add* أَرَامْ-نَاهْرَايْنْ، \add أَقَا-ت ذ مِيسُوپُوثَامْيَا\add*، غَارْ ثنْذِينْثْ ن نَاحُورْ. \f ◼ \fr 24:‏10 \ft \bd ’أَرَامْ-نَاهْرَايْنْ‘\bd* - س ثْعِيبْرَانِيثْ ’أَرَامْ-نَاهْرَايِيمْ‘، أَوَاڒْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي: أَرَامْ جَارْ ثْنَاينْ ن إِغزْرَانْ.\f*
\v 11 غَارْ ؤُخشِّي ن ثْمذِّيثْ إِجَّا إِڒغْمَانْ أَذْ جّْننْ بَارَّا إِ ثنْذِينْثْ زَّاثْ إِ ڒْعُونْصَارْ ن وَامَانْ، غَارْ ثْسَاعّثْ إِ ذِي د-فّْغنْثْ ثمْغَارِينْ، مَاحنْذْ أَذْ أَيْمنْثْ أَمَانْ.
\v 12 \add خنِّي\add* إِنَّا: ”سِيذِي، أَربِّي ن سِيذِي إِنُو إِبْرَاهِيمْ، تّْزَاوَاڭغْ شكْ أَذْ أَيِي ثْعَاوْنذْ أَسّْ-أَ ؤُشَا سْشنْ ثَامخْسِيوْثْ \add نّشْ\add* إِشوَّارنْ إِ سِيذِي إِنُو إِبْرَاهِيمْ.
\v 13 أَقَا أَيِي غَارْ ڒْعُونْصَارْ ن وَامَانْ ذ ثْحنْجِيرِينْ ن يرْيَازنْ ن ثنْذِينْثْ أَذْ د-فّْغنْثْ مَاحنْذْ أَذْ أَيْمنْثْ أَمَانْ.
\v 14 أجّْ ثَابْڒِيغْثْ نِّي ؤُمِي غَا إِنِيغْ: ’سهْوَا-د أَقْبُوشْ نّمْ، مَاڒَا ثخْسذْ، أَذْ سْوغْ!‘، \add ؤُشَا خنِّي\add* أَذْ ثِينِي: ’سُو، أَذْ وَارْذغْ ؤُڒَا ذ إِڒغْمَانْ نّشْ!‘، أَقَا ذ نتَّاثْ إِ ثڭِّيذْ إِ ؤُمْسخَّارْ نّشْ إِسْحَاقْ، ؤُ س ؤُيَا أَذْ سّْنغْ أَقَا ثسّشْنذْ ثَامخْسِيوْثْ \add نّشْ\add* إِشوَّارنْ إِ سِيذِي إِنُو.“
\m 
\v 15 ؤُشَا عَاذْ قْبڒْ إِ غَا إِكمّرْ أَوَاڒْ، إِژْرَا رِيفْقَا، ثنِّي إِ د-يُورْونْ إِ بِيثُووِيلْ، مِّيسْ ن مِيلْكَا، ثَامْغَارْثْ ن نَاحُورْ ؤُمَاسْ ن إِبْرَاهِيمْ، ثفّغْ-د \add زِي ثنْذِينْثْ\add* س وقْبُوشْ نّسْ خْ ثغْرُوضْثْ. \x ◘ \xo 24:‏15 \xt أَمز. 22‏:‏23\x*
\v 16 ثَابْڒِيغْثْ ثُوغَا ذَايسْ أَژْرِي إِمْغَارْ، ذ ثَاعْزَارشْثْ، وَارْ ت إِسِّينْ ورْيَازْ. نتَّاثْ ثهْوَا-د غَارْ ڒْعُونْصَارْ، ثشُّورْ أَقْبُوشْ نّسْ ؤُشَا ثْڭعّذْ عَاوذْ.
\v 17 يُوزّڒْ غَارسْ ؤُمْسخَّارْ \add نِّي\add*، إِنَّا: ”تّْزَاوْڭغْ شمْ أَذْ أَيِي ثوْشذْ أَذْ سْوغْ شْوَايْثْ ن وَامَانْ زڭْ وقْبُوشْ نّمْ!“
\v 18 نتَّاثْ ثنَّا: ”سُو، أَ سِيذِي إِنُو!“ ثْقدْجقْ ثسّهْوَا أَقْبُوشْ نّسْ خْ ؤُفُوسْ نّسْ، ثوْشَا أَسْ أَذْ إِسُو.
\v 19 \add ڒَْامِي\add* ذ أَسْ ثوْشَا إِسْوَا مْلِيحْ، ثنَّا: ”أَذْ أَيْمغْ أَمَانْ عَاوذْ إِ إِڒغْمَانْ نّشْ، أَڒْ غَارْسنْ إِ غَا يِيڒِي س زّْيَاذَا.“
\v 20 ثْقدْجقْ ثسّخْوَا أَقْبُوشْ ذِي ثَارْيَا، ثُوزّڒْ عَاوذْ غَارْ ڒْعُونْصَارْ، حِيمَا أَذْ ثَايمْ أَمَانْ، ؤُشَا ثُويمْ أَسنْ-د أَمَانْ إِ إِڒغْمَانْ نّسْ مَارَّا.
\v 21 \add وَاخَّا\add* إِثبْهثْ ذَايسْ ورْيَازْ، إِسْقَارْ، حِيمَا أَذْ إِسّنْ مَا سِيذِي إِسّهْونْ خَاسْ أَبْرِيذْ نّسْ نِيغْ لَّا.
\v 22 ؤُمِي جِّيوْننْ إِڒغْمَانْ ثِيسسِّي، إِكْسِي ورْيَازْ ذڭْ إِجّْ ن ؤُمُورْ إِشْثْ ن ثْخَاذنْثْ ن وُورغْ، \add ثنِّي إِوزْننْ\add* أَزْينْ شِيقْلُو، ذ ثْنَاينْ ن ثْمقْيَاسِينْ إِ إِفَاسّنْ نّسْ، \add ثِينِّي إِوزْننْ\add*عشْرَا شِيقْلُو ن وُورغْ،
\v 23 إِنَّا: ”إِنِي أَيِي، ؤُمِي ثڭِّيذْ ذ يدْجِيسْ؟ مَا أَقَا ذِينْ أَمْشَانْ ذِي ثَادَّارْثْ ن بَابَامْ مَانِي نْزمَّارْ أَذْ نسّنْسْ؟“
\v 24 نتَّاثْ ثنَّا أَسْ: ”نشّْ ذ يدْجِيسْ ن بِيثُووِيلْ، مِّيسْ ن مِيلْكَا، ونِّي إِ-ت-إِ-د-يُورْونْ إِ نَاحُورْ.“ \x ◘ \xo 24:‏24 \xt أَمز. 22‏:‏23. \x*
\v 25 ؤُشَا ثَارْنِي ثنَّا أَسْ: ”أَقَا عَاوذْ غَارْنغْ أَطَّاسْ ن ؤُڒُومْ ذ إِغدْجْ، ؤُ غَارْنغْ عَاوذْ أَمْشَانْ إِ ثْمنْسِيوْثْ.“
\v 26 ؤُشَا يُوضَارْ ورْيَازْ ؤُشَا إِبنْذقْ إِ سِيذِي،
\v 27 إِنَّا: ”أَذْ إِتّْوَابَاركْ سِيذِي، أَربِّي ن سِيذِي إِنُو إِبْرَاهِيمْ، ونِّي وَارْ إِكِّيسنْ ثَامخْسِيوْثْ نّسْ إِشوَّارنْ ذ ڒَامَانْ نّسْ زِي سِيذِي إِنُو. إِنْذهْ أَيِي سِيذِي ذڭْ وبْرِيذْ غَارْ ثَادَّارْثْ ن وَاوْمَاثنْ ن سِيذِي إِنُو.“
\m 
\v 28 ثُوزّڒْ ثبْڒِيغْثْ، ثْعَاوذْ ثِيمسْڒَايِينْ-أَ إِ يمَّاسْ ذِي ثَادَّارْثْ.
\v 29 ؤُشَا رِيفْقَا ثُوغَا غَارسْ ؤُمَاسْ، قَّارنْ أَسْ لَابَانْ، ؤُشَا لَابَانْ يُوزّڒْ غَارْ ورْيَازْ نِّي ثُوغَا \add ذِينْ\add* ذِي بَارَّا غَارْ ڒْعُونْصَارْ.
\v 30 ثُوغَا إِژْرَا ثَاخَاذنْثْ ذ ثْنَاينْ ن ثْمقْيَاسِينْ ذڭْ إِفَاسّنْ ن ؤُتْشْمَاسْ ؤُشَا إِسْڒَا إِ وَاوَاڒنْ إِ ثُوغَا ثقَّارْ ؤُتْشْمَاسْ رِيفْقَا، ثنَّا: ”أَمُّو إِ كِيذِي إِسِّيوڒْ ورْيَازْ نِّي.“ ؤُشَا يُويُورْ غَارْ ورْيَازْ. خْزَارْ، إِبدّْ \add ذِيهَا\add* زَّاثْ إِ إِڒغْمَانْ، غَارْ ڒْعُونْصَارْ.
\v 31 إِنَّا: ”أَرَاحْ-د، \add أَ شكْ ذ\add* أَمِيمُونْ ن سِيذِي! مَايمِّي ثقِّيمذْ ذِي بَارَّا، نشّْ أَقَا سّْوجْذغْ ثَادَّارْثْ ذ ومْشَانْ إِ إِڒغْمَانْ.“
\v 32 إِرُوحْ ورْيَازْ أَكِيذسْ غَارْ ثَادَّارْثْ ؤُ نتَّا إِضْڒقْ إِ إِسغْوَانْ ن إِڒغْمَانْ. نتَّا إِوْشَا أَسنْ ڒُومْ ذ مَاشَّا، ؤُشَا إِكْسِي أَمَانْ، حِيمَا أَذْ إِسِّيرْذْ إِضَارنْ نّسْ ؤُڒَا ذ إِضَارنْ ن إِرْيَازنْ نِّي كِيذسْ إِدْجَانْ.
\v 33 إِسَّارْسْ زَّاثسْ مِينْ غَا يشّْ. ؤُشَا نتَّا إِنَّا: ”وَارْ تّتّغْ قْبڒْ إِ غَا إِنِيغْ ثَابْرَاثْ إِنُو.“ نتَّا إِنَّا أَسْ: ”سِيوڒْ!“
\v 34 \add خنِّي\add* إِنَّا: ”نشّْ ذ أَمْسخَّارْ ن إِبْرَاهِيمْ.
\v 35 سِيذِي إِبَارْكْ سِيذِي إِنُو أَطَّاسْ س وَاطَّاسْ ؤُشَا شَّانْ نّسْ إِمْغَارْ أَطَّاسْ. أَقَا إِوْشَا أَسْ ؤُدْجِي ذ إِفُونَاسنْ ذ ثْفُونَاسِينْ، نُّوقَارْثْ ذ وُورغْ، إِسمْغَانْ ذ ثِييَّا، إِڒغْمَانْ ذ يغْيَاڒْ.
\v 36 ذ سَارَا، ثَامْغَارْثْ ن سِيذِي إِنُو، ثُورُووْ-د أَحنْجِيرْ إِ سِيذِي إِنُو أَوَارْنِي ؤُمِي ثوْسَارْ ؤُ نتَّا إِوْشَا أَسْ مَارَّا مِينْ غَارسْ.
\v 37 ؤُشَا سِيذِي إِنُو إِجَّا أَيِي جُّودْجغْ، إِنَّا: ’وَارْ د-تَّاوِي ثَامْغَارْثْ إِ مِّي زِي ثْحنْجِيرِينْ ن أَيْثْ ن كنْعَانْ إِنِّي مَانِي زذْغغْ ذِي ثمُّورْثْ نْسنْ.
\v 38 \add ؤُشْثْ خَاكْ\add* مَاڒَا وَارْ تّْرِيحذْ غَارْ ثَادَّارْثْ ن بَابَا، غَارْ رَادْجْ إِنُو ؤُشَا أَذْ د-ثَاوْيذْ ثَامْغَارْثْ إِ مِّي \add سّنِّي\add*.‘
\v 39 \add خنِّي\add* نشّْ نِّيغْ إِ سِيذِي إِنُو: ’بَالَاكْ ثَامْغَارْثْ وَارْ ذ أَيِي د-ثْضفَّارْ.‘
\v 40 ؤُشَا نتَّا إِنَّا أَيِي: ’سِيذِي إِ ؤُمِي ؤُيُورغْ زَّاثْ إِ وُوذمْ نّسْ، أَقَا نتَّا أَذْ د-إِسّكّْ لْمَالَاكْ نّسْ أَكِيذكْ ؤُشَا أَذْ خَاكْ إِسّهْونْ أَبْرِيذْ نّشْ أَڒْ د غَا ثَاوْيذْ إِ مِّي إِشْثْ ن ثمْغَارْثْ زِي ڒَادْجْ إِنُو ؤُ زِي ثَادَّارْثْ ن بَابَا.
\v 41 أَذْ ثِيڒِيذْ ثْفكّذْ زِي ثْجَادْجِيثْ إِ ذ أَيِي ثجُّودْجذْ، خْمِي غَا ثْرَاحذْ غَارْ ڒَادْجْ إِنُو ؤُ نِيثْنِي وَارْ ذ أَشْ ت تِّيشنْ، \add خنِّي\add* أَذْ شكْ سُّوفّْغغْ زِي ثْجَادْجِيثْ نّشْ إِ ثُوغَا ثجُّودْجذْ.‘
\v 42 أَسّْ-أَ ؤُسِيغْ-د غَارْ ڒْعُونْصَارْ ؤُشَا نِّيغْ: ’\add أَ\add* سِيذِي، أَربِّي ن سِيذِي إِنُو إِبْرَاهِيمْ، تّْزَاوَاڭغْ أَذْ ثسّْهوْنذْ ڒخُّو أَبْرِيذْ إِ ذِي ڭُّورغْ.
\v 43 أَقَا أَيِي ذَا زَّاثْ إِ ڒْعُونْصَارْ ن وَامَانْ. أجّْ أَذْ ثِيڒِي أَمُّو، أَقَا ثَاعْزَارشْثْ، ثنِّي د غَا إِفّْغنْ، مَاحنْذْ أَذْ ثَايمْ أَمَانْ ؤُ إِ ثنِّي ؤُمِي غَا إِنِيغْ: أوْشْ أَيِي أَذْ سْوغْ شْوَايْثْ ن وَامَانْ زڭْ ؤُقْبُوشْ نّمْ!
\v 44 ؤُشَا \add خنِّي\add* نتَّاثْ أَذْ أَيِي ثِينِي: سُو شكْ ؤُ نشّْ أَذْ أَيْمغْ عَاوذْ إِ إِڒغْمَانْ نّشْ!، ذ ثَا أَذْ ثِيڒِي ذ ثَامْغَارْثْ نِّي ذ إِسّوْجذْ سِيذِي إِ مِّيسْ ن سِيذِي إِنُو.‘
\v 45 ؤُشَا قْبڒْ إِ غَا كمّْڒغْ \add ثَاژَادْجِيثْ-أَ\add* ذڭْ وُوڒْ إِنُو، خْزَارْ، رِيفْقَا ثفّغْ-د س ؤُقْبُوشْ نّسْ خْ ثغْرُوضْثْ نّسْ، ثهْوَا غَارْ ڒْعُونْصَارْ ؤُشَا ثُويمْ-د أَمَانْ. نِّيغْ أَسْ: ’تّْزَاوْڭغْ شمْ أَذْ أَيِي ثوْشذْ أَذْ سْوغْ!‘
\v 46 ذغْيَا ثسّهْوَا أَقْبُوشْ نّسْ، ثنَّا: ’سُو ؤُ نشّْ أَذْ سّسْوغْ عَاوذْ إِڒغْمَانْ نّشْ!‘ سْوِيغْ ؤُشَا نتَّاثْ ثوْشَا عَاوذْ إِ إِڒغْمَانْ أَذْ سْونْ.
\v 47 سّقْسِيغْ ت، نِّيغْ: ’ؤُمِي ثڭِّيذْ ذ يدْجِيسْ؟‘ نتَّاثْ ثَارَّا: ’\add نشّْ ذ\add* يدْجِيسْ ن بِيثُووِيلْ، مِّيسْ ن نَاحُورْ ونِّي ذ أَسْ د-يُورْونْ مِيلْكَا.‘ \add خنِّي\add* ڭِّيغْ أَسْ ثَاخَاذنْثْ ذِي ثِينْزَارْثْ نّسْ ذ ثْمقْيَاسِينْ ذڭْ إِفَاسّنْ نّسْ.
\v 48 \add خَاسْ ؤُشَا\add* ؤُضَارغْ، بنْذْقغْ إِ سِيذِي ؤُشَا بَارْكغْ سِيذِي، أَربِّي ن سِيذِي إِنُو إِبْرَاهِيمْ، ونِّي ذ أَيِي إِنذْهنْ نِيشَانْ ذڭْ وبْرِيذْ، حِيمَا أَذْ د-أَوْيغْ إِدْجِيسْ ن ؤُمَاسْ ن سِيذِي إِنُو ذ ثمْغَارْثْ إِ مِّيسْ.
\v 49 \add خنِّي\add* ڒخُّو، مَاڒَا كنِّيوْ ثخْسمْ أَذْ ثسّشْنمْ ثَامخْسِيوْثْ إِشوَّارنْ ذ ڒَامَانْ إِ سِيذِي إِنُو، إِنِي أَيِي ث، مَاڒَا لَّا، إِنِي أَيِي ث \add عَاوذْ\add*، \add خنِّي\add* أَذْ كّغْ يفُوسْ نِيغْ ؤُزڒْمَاضْ.“
\v 50 \add خنِّي\add* لَابَانْ ذ بِيثُووِيلْ أَرِّينْ-د، نَّانْ: ”زِي سِيذِي إِ د-إِفّغْ ؤُيَا، وَارْ نْزمَّارْ أَذْ ذَايكْ نِينِي ڒْغَارْ نِيغْ ڒْخَارْ.
\v 51 خْزَارْ، رِيفْقَا قِيبَاتْشْ نّشْ، كْسِي \add ت\add* ؤُشَا ثْرُوحذْ. أَذْ ثِيڒِي نتَّاثْ ذ ثَامْغَارْثْ ن مِّيسْ ن سِيذِي نّشْ، أَمْ مَامّشْ إِنَّا سِيذِي!“
\m 
\v 52 ؤُمِي إِسْڒَا ؤُمْسخَّارْ ن إِبْرَاهِيمْ أَوَاڒنْ نْسنْ، إِبنْذقْ غَارْ ثمُّورْثْ زَّاثْ إِ سِيذِي.
\v 53 ؤُشَا إِسُّوفّغْ-د ؤُمْسخَّارْ ڒقْشُوعْ ن نُّوقَارْثْ ذ ڒقْشُوعْ ن وُورغْ ذ وَارُّوضنْ، إِوْشَا إِ-ثنْ إِ رِيفْقَا. عَاوذْ إِوْشَا ثِيرْزِيفِينْ إِغْڒَانْ إِ ؤُمَاسْ ذ يمَّاسْ.
\v 54 شِّينْ، سْوِينْ، نتَّا ذ يرْيَازنْ إِنِّي كِيسْ د-يُوسِينْ. سّنْسنْ \add ذِينْ\add* ؤُشَا فَاقنْ غَارْ ضّْبحْ. \add خنِّي\add* إِنَّا: ”سَامْحمْ أَيِي أَذْ رَاحغْ \add ڒخُّو\add* غَارْ سِيذِي إِنُو!“
\v 55 أَرِّينْ-د ؤُمَاسْ ذ يمَّاسْ: ”أجّْ ثَابْڒِيغْثْ أَكِيذْنغْ وَاخَّا مْغِيرْعشْرَا ن وُوسَّانْ، أَوَارْنِي أَسْ أَذْ ثُويُورذْ.“
\v 56 مَاشَا نتَّا إِنَّا أَسنْ: ”وَارْ ذَايِي ثطِّيفمْ عَاذْ ؤُمِي سِيذِي إِسّهْونْ أَبْرِيذْ إِنُو! مْغِيرْ أجّْ أَيِي أَذْ رَاحغْ غَارْ سِيذِي إِنُو.“
\v 57 نِيثْنِي أَرِّينْ-د ڒخْذنِّي: ”أجّْ أَنغْ أَذْ نْڒَاغَا إِ ثبْڒِيغْثْ، أَذْ نْسڒْ \add إِ مِينْ غَا ثِينِي\add* زڭْ ؤُقمُّومْ نّسْ.“
\v 58 ڒَاغَانْ إِ رِيفْقَا ؤُشَا نَّانْ أَسْ: ”مَا أَذْ ثْرَاحذْ شمْ أَكْ-ذ ورْيَازْ-أَ؟“ ؤُشَا نتَّاثْ ثَارَّا-د: ”وَاهْ، أَذْ رَاحغْ.“
\v 59 \add خنِّي\add* سّْقبّْضنْ نِيثْنِي رِيفْقَا، ؤُتْشْمَاثْسنْ، أَكْ-ذ ثْمطَّاضْثْ نّسْ، ؤُشَا \add سّْقبّْضنْ\add* عَاوذْ أَمْسخَّارْ ن إِبْرَاهِيمْ ذ إِرْيَازنْ نّسْ. \x ◘ \xo 24:‏59 \xt أَمز. 35‏:‏8\x*
\v 60 ؤُشَا بَارْكنْ رِيفْقَا، نَّانْ أَسْ: ”\add أَ\add* ؤُتْشْمَاثْنغْ، أَذْ ثَاوْضذْ أَذْ ثمْغَارذْ ذ ڒُوڒُوفْ نعشْرَا ن ڒُوڒُوفْ ؤُشَا زَّارِيعثْ نّمْ أَذْ ثطّفْ ثَاوَّارْثْ ن يِينِّي ت إِشَارّْهنْ!“ \x ◘ \xo 24:‏60 \xt أَمز. 3‏:‏14\x*
\v 61 ثكَّارْ رِيفْقَا ذ ثمْسخَّارِينْ نّسْ ثِيمژْيَانِينْ، نْيِينْثْ خْ إِڒغْمَانْ، ضْفَارنْثْ أَرْيَازْ. \add أَمُّو\add* إِ د-يِيوِي ؤُمْسخَّارْ رِيفْقَا ؤُشَا إِرُوحْ.
\m 
\v 62 أَقَا إِفّغْ-د إِسْحَاقْ زڭْ وَانُو ن لَاحَايْ-رُوئِي. ثُوغَا إِزدّغْ ذِي ثمُّورْثْ ن لْجَانُوبْ. \x ◘ \xo 24:‏62 \xt أَمز. 16‏:‏14؛ 25‏:‏11. \x*
\v 63 إِفّغْ-د إِسْحَاقْ مَاحنْذْ أَذْ إِژَّادْجْ ذڭْ إِيَّارْ. ثُوغَا-ت غَارْ ؤُوطُّو ن ثْمذِّيثْ. نتَّا إِسّْڭعّذْ ثَامُوغْڒِي نّسْ، إِقْشعْ، ؤُ خْزَارْ، إِڒغْمَانْ تّْقَارَّابنْ-د!
\v 64 رِيفْقَا عَاوذْ ثسّْڭعّذْ ثِيطَّاوِينْ نّسْ، ثژْرَا إِسْحَاقْ. نتَّاثْ ثجَّا إِخفْ نّسْ أَذْ ثْضَارْ ذغْيَا خْ وڒْغمْ
\v 65 ؤُشَا ثنَّا إِ ؤُمْسخَّارْ: ”مِينْ إِعْنَا ورْيَازْ نِّي د-يُوسِينْ ذڭْ إِيَّارْ غَارْنغْ؟“ ؤُشَا إِنَّا ؤُمْسخَّارْ: ”وَا ذ سِيذِي إِنُو!“ خنِّي ثكْسِي ثَاكنْبُوشْثْ ؤُشَا ثْڒحّفْ.
\v 66 ؤُشَا إِعَاوذْ ؤُمْسخَّارْ إِ إِسْحَاقْ مَارَّا مِينْ إِڭَّا.
\v 67 إِڭوّذْ إِ-ت إِسْحَاقْ غَارْ ؤُقِيضُونْ ن يمَّاسْ سَارَا، يِيوِي رِيفْقَا ؤُشَا نتَّاثْ ثذْوڒْ ذ ثَامْغَارْثْ نّسْ ؤُ نتَّا ثُوغَا إِتّخْسْ إِ-ت. أَمُّو إِ إِفوّجْ إِسْحَاقْ أَوَارْنِي \add ڒْْموْثْ\add* ن يمَّاسْ.
\b
\b
\c 25
\s1 ثَارْوَا ن إِبْرَاهِيمْ
\m 
\v 1 إِكْسِي إِبْرَاهِيمْ ثَامْغَارْثْ نّغْنِي، قَّارنْ أَسْ قَاثُورَا. \f ◼ \fr 25:‏1 \ft \bd ’قَاثُورَا‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’ڒبْخُورْ‘.\f*  \x ◘ \xo 25:‏1 \xt [1 إِم. 1‏:‏28‏-‏42] \x*
\v 2 نتَّا ثُورُووْ أَسْ-د زِيمْرَانْ، يَاقْشَانْ، مِيذْيَانْ، يِيشْبَاقْ ذ شُوحَا. \x ◘ \xo 25:‏2 \xt 1 إِم. 1‏:‏32. \x*
\v 3 يُوقْشَانْ إِجَّا-د شَابَا ذ ذَاذَانْ. ؤُشَا أَرَّاونْ ن ذَاذَانْ ثُوغَا أَثنْ ذ إِشُّورِييّنْ ذ إِلِيثُوشِييّنْ ذ إِلِييُومِييّنْ.
\v 4 إِحنْجِيرنْ ن مِيذْيَانْ \add ثُوغَا أَثنْ ذ\add* عِييْفَا، عِيفَارْ، حَانُوخْ، أَبِيذَاعْ ذ أَلْذَاعَا. مَارَّا إِنَا \add ثُوغَا أَثنْ ذ\add* إِحنْجِيرنْ ن قَاطُورَا.
\v 5 إِبْرَاهِيمْ إِوْشَا مَارَّا مِينْ غَارسْ إِ إِسْحَاقْ. \x ◘ \xo 25:‏5 \xt أَمز. 24‏:‏36. \x*
\v 6 مَاشَا إِ إِحنْجِيرنْ ن ثِييَّا إِ ثُوغَا غَارْ إِبْرَاهِيمْ، إِوْشَا أَسنْ إِبْرَاهِيمْ أَرِّيغَالُوثْ ؤُشَا، أَمْ ث ثُوغَا \add عَاذْ\add* إِدَّارْ، إِسّكّْ إِ-ثنْ سّنِّي غَارْ شَّارْقْ، غَارْ ثمُّورْثْ ن شَّارْقْ، إِسِّيڭّْوجْ إِ-ثنْ خْ إِسْحَاقْ مِّيسْ.
\v 7 إِبْرَاهِيمْ ثُوغَا إِدَّارْ مْيَا ؤُ-خمْسَا ؤُ-سبْعِينْ ن إِسڭّْوُوسَا، وَا ذ ڒْمِيجَاڒْ ن ثُوذَارْثْ نّسْ.
\v 8 إِضْڒقْ إِبْرَاهِيمْ إِ بُوحْبڒْ نّسْ ؤُشَا إِمُّوثْ ذِي شِّيبْ إِسڭّذْ، ذِي ثوْسَارْ ذ ثْيَاوَانْثْ. ؤُشَا إِمَّارْنِي غَارْ ڒْڭنْسْ نّسْ. \x ◘ \xo 25:‏8 \xt أَمز. 15‏:‏15. \x*
\v 9 إِسْحَاقْ ذ إِسْمَاعِيلْ، إِحنْجِيرنْ نّسْ، نضْڒنْ ث ذڭْ إِفْرِي ن مَاكْفِيلَا ذڭْ إِيَّارْ ن عِيفْرُونْ، مِّيسْ ن صُوحَارْ، أَحِيتِّي، \add إِيَّارْ\add* إِ إِدْجَانْ قِيبَاتْشْ إِ مَامْرِي.
\v 10 إِتّْوَانْضڒْ إِبْرَاهِيمْ ذ ثمْغَارْثْ نّسْ سَارَا ذڭْ إِيَّارْ نِّي إِسْغَا إِبْرَاهِيمْ زِي ثَارْوَا ن حِيثْ.
\m 
\v 11 أَوَارْنِي إِ ڒْموْثْ ن إِبْرَاهِيمْ إِبَاركْ أَربِّي مِّيسْ إِسْحَاقْ. ؤُشَا إِزْذغْ إِسْحَاقْ زَّاثْ إِ وَانُو ن لَاحَايْ-رُوئِي. \f ◼ \fr 25:‏11 \ft \bd ’لَاحَايْ-رُوئِي‘\bd* - خْزَارْ أَمز. 16:14.\f*
\b
\m 
\v 12 \bd إِنَا ذ إِمزْرُوينْ ن يِينِّي د-إِتّْوَاخڒْقنْ \bdit زِي\bdit* إِسْمَاعِيلْ، مِّيسْ ن إِبْرَاهِيمْ،\bd* إِنِّي د-ثجَّا هَاجَارْ، ثَايَّا ن سَارَا زِي مِيصْرَا، إِ إِبْرَاهِيمْ.
\v 13 ذ يِينَا ذ إِسْمَاونْ ن إِحنْجِيرنْ ن إِسْمَاعِيلْ، س إِسْمَاونْ نْسنْ عْلَاحْسَابْ أَخْڒَاقْ نْسنْ. أَمنْزُو ن إِسْمَاعِيلْ \add ثُوغَا-ث ذ\add* نَابَايُوثْ، \add خنِّي\add* قِيذَارْ، أَذْبِييِيلْ، مِيبْسَامْ، \x ◘ \xo 25:‏13 \xt 1 إِم. 1‏:‏29. \x*
\v 14 مِيسْمَا، ذُومَا، مَاسَّا،
\v 15 حَاذَارْ، ثَايْمَا، يَاطُورْ، نَافِيشْ ذ قِيذْمَا.
\v 16 ذ يِينَا ذ إِحنْجِيرنْ ن إِسْمَاعِيلْ س إِسْمَاونْ نْسنْ، س ذْشُورَاثْ نْسنْ ذ ڒْمَارَاڭحْ نْسنْ: ثنْعَاشْ ن ڒْحُوكَّامْ س ڒَادْجَاثْ نْسنْ.
\v 17 ثُوغَا إِدَّارْ إِسْمَاعِيلْ مْيَا ؤُ-سبْعَا ؤُ-ثْڒَاثِينْ ن إِسڭّْوُوسَا. \add خنِّي\add* إِضْڒقْ إِسْمَاعِيلْ إِ بُوحْبڒْ نّسْ، إِمُّوثْ ؤُشَا إِمَّارْنِي غَارْ ڒْڭنْسْ نّسْ.
\v 18 نِيثْنِي زدّْغنْ زِي حَاوِيلَا غَارْ شُورْ، ونِّي إِدْجَانْ أَرنْذَاذْ ن مِيصْرَا، أَمْ ثطّْفذْ أَبْرِيذْ غَارْ أَشُّورْ. نتَّا إِزْذغْ أَرنْذَاذْ ن مَارَّا أَيْثْمَاسْ.
\b
\m \bd إِنَا ذ إِمزْرُوينْ ن يِينِّي د-إِتّْوَاخڒْقنْ \bdit زِي\bdit* إِسْحَاقْ، مِّيسْ ن إِبْرَاهِيمْ.\bd*
\b
\s1 يَاعْقُوبْ ذ عِيسُو
\m 
\v 19 إِبْرَاهِيمْ إِجَّا-د إِسْحَاقْ.
\v 20 ثُوغَا غَارْ إِسْحَاقْ أَربْعِينْ ن إِسڭّْوُوسَا ؤُمِي يِيوِي رِيفْقَا ذ ثَامْغَارْثْ. نتَّاثْ ذ يدْجِيسْ ن بِيثُووِيلْ، أَرَامِييُو زِي فَادَّانْ-أَرَامْ، ؤُتْشْمَاسْ ن لَابَانْ، أَرَامِييُو.
\v 21 إِحشّمْ إِسْحَاقْ سِيذِي ذِي طّْوعْ ن ثمْغَارْثْ نّسْ، ثنِّي ثُوغَا وَارْ إِتِّيرْونْ شَا، ؤُشَا إِسْثَاجبْ أَسْ سِيذِي س ثْژَادْجِيثْ نّسْ يُودْجْغنْ، أَڒَامِي ثكْسِي ثمْغَارْثْ نّسْ، رِيفْقَا، دّيْسثْ. \x ◘ \xo 25:‏21 \xt رُوم. 9‏:‏10. \x*
\v 22 ؤُشَا مّْذحْسنْ إِحنْجِيرنْ ذڭْ ؤُعذِّيسْ نّسْ. \add خنِّي\add* ثنَّا: ”مَانَاوْيَا \add عَاوذْ\add*، مَايمِّي ذ أَيِي إِتّمْسَارْ مَانْ أَيَا؟“، ؤُشَا ثْرُوحْ أَذْ ثسّقْسَا سِيذِي.
\v 23 إِنَّا أَسْ سِيذِي: ”أَقَا ذِينْ ثْنَاينْ ن ڒڭْنُوسْ ذِي دّيْسثْ نّمْ ؤُ ثْنَاينْ ن شُّوعُوبْ أَذْ مّْسبْضَانْ زِي ذْوَاخڒْ نّمْ. إِجّْ ن شّعْبْ أَذْ يِيڒِي إِجْهذْ خْ شّعْبْ نّغْنِي ؤُ ونِّي ذ أَمنْزُو أَذْ إِخْذمْ إِ ؤُمَاژُوژْ.“ \x ◘ \xo 25:‏23 \xt 2 صم. 8‏:‏14؛ رُوم. 9‏:‏12. \x*
\v 24 أَڒَامِي د-إِوْضنْ وُوسَّانْ نّسْ أَذْ ثَارُو، خْزَارْ، أَقَا ذَا ذڭْ ؤُعذِّيسْ نّسْ أَشْنِيونْ.
\v 25 إِفّغْ-د ؤُمزْوَارْ. ثُوغَا-ث ذ أَزڭّْوَاغْ، إِشعَّارْ قَاعْ أَمْ يِيشْثْ ن ثْهِيضُورْثْ. س ؤُينِّي ڭِّينْ أَسْ عِيسُو. \f ◼ \fr 25:‏25 \ft \bd ’عِيسُو‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَزڭّْوَاغْ‘ نِيغْ ’إِحَّارْشُووْ‘.\f*
\v 26 أَوَارْنِي أَسْ إِفّغْ-د ؤُمَاسْ. إِطّفْ أَفُوسْ نّسْ ذڭْ ؤُنِيرْزْ ن عِيسُو. س ؤُيَا سمَّانْ ث س يِيسمْ يَاعْقُوبْ. ثُوغَا غَارْ إِسْحَاقْ ستِّينْ ن إِسڭّْوُوسَا غَارْ وخْڒَاقْ نْسنْ. \x ◘ \xo 25:‏26 \xt حُوش. 12‏:‏4. \x*
\m 
\v 27 \add ڒَْامِي\add* ڭْمَانْ إِحنْجِيرنْ، إِذْوڒْ عِيسُو ذ إِجّْ ن ورْيَازْ إِسّنْ أَنيْمَارْ، إِجّْ ن ورْيَازْ ن بَارَّا، مَاشَا يَاعْقُوبْ إِذْوڒْ ذ إِجّْ ن ورْيَازْ يَارْسَا، ونِّي إِزدّْغنْ ذڭْ إِقِيضَانْ. \f ◼ \fr 25:‏27 \ft \bd ’أَرْيَازْ يَارْسَانْ‘\bd* - أَوَاڒْ أَعِيبْرَانِي إِخْسْ أَذْ يِينِي س لْحَارْفْ ’أَرْيَازْ إِكمْڒنْ‘ نِيغْ ’أَرْيَازْ بْڒَا ڒْعِيبْ‘، مَاشَا ذِي شَا ن ثْوَاڒَاوِينْ أَمْ ڒخُّو نْزمَّارْ أَذْ نِينِي ’أَرْيَازْ أَمْثِيقِّي‘، نِيغْ ’أَرْيَازْ يَارْسَانْ‘.\f*
\v 28 إِسْحَاقْ ثُوغَا إِتّخْسْ عِيسُو، مِينْزِي إِعْجبْ أَسْ أَذْ يشّْ أَيْسُومْ ن ڒْمَاڒْ ن ڒخْڒَا، ؤُ رِيفْقَا ثُوغَا ثتّخْسْ يَاعْقُوبْ.
\v 29 ؤُشَا إِسّْننِّي يَاعْقُوبْ إِشْثْ ن مَاشَّا، ؤُمِي د-إِعْقبْ عِيسُو زِي ڒخْڒَا، يُوحڒْ.
\v 30 إِنَّا عِيسُو إِ يَاعْقُوبْ: ”تّْزَاوْڭغْ شكْ أَذْ أَيِي ثوْشذْ أَذْ شّغْ زڭْ ؤُزڭّْوَاغْ، أَزڭّْوَاغْ نِّي ذِيهَا، مَاغَارْ أَقَا فْنِيغْ \add س ؤُفَاذِي\add*.“ خْ ؤُيَا قَّارنْ أَسْ ’إِذُومْ‘. \f ◼ \fr 25:‏30 \ft \bd ’إِذُومْ‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَزڭّْوَاغْ‘.\f*
\v 31 \add ڒخْذنِّي\add* إِنَّا يَاعْقُوبْ: ”زنْزْ أَيِي أَسّْ-أَ \add ڒْْحقّْ\add* نّشْ \add ن\add* ؤُمنْزُو.“
\v 32 إِنَّا عِيسُو: ”خْزَارْ، أَقَا نشّْ أَذْ مّْثغْ، مِينْ غَا ڭّغْ س \add ڒْْحقّْ ن\add* ؤُمنْزُو؟“ \x ◘ \xo 25:‏32 \xt إِشا. 22‏:‏13؛ 1 كُور. 15‏:‏32. \x*
\v 33 \add خنِّي\add* إِنَّا يَاعْقُوبْ: ”جَادْجْ أَيِي ڒخُّو!“ ؤُشَا إِجُّودْجْ أَسْ، إِزّنْزْ إِ يَاعْقُوبْ \add ڒْْحقّْ ن\add* ؤُمنْزُو نّسْ.
\v 34 \add خَاسْ ؤُشَا\add* إِوْشَا يَاعْقُوبْ إِ عِيسُو أَغْرُومْ ذ ؤُمشْڒِي ن ڒعْذسْ، ؤُ عِيسُو إِشَّا، إِسْوَا، إِكَّارْ، إِرُوحْ. \add أَمُّو\add* إِسّحْقَارْ عِيسُو \add ڒْْحقّْ ن\add* ؤُمنْزُو نّسْ.
\b
\b
\c 26
\s1 ڒْعَاهْذْ جَارْ إِسْحَاقْ ذ أَبِيمَالِيكْ
\m 
\v 1 ثُوغَا إِدْجَا ڒَاژْ ذِي ثمُّورْثْ، إِجّْ ن ڒَاژْ نّغْنِي خْ ؤُمزْوَارْ نِّي ثُوغَا إِدْجَانْ ذڭْ وُوسَّانْ ن إِبْرَاهِيمْ. س ؤُيَا إِرُوحْ إِسْحَاقْ غَارْ أَبِيمَالِيكْ، أَجدْجِيذْ ن إِفِيلِيسْطِينِييّنْ، غَارْ \add جّْوَايهْ ن\add* جِيرَارْ.
\v 2 \add ذِينِّي\add* إِبَانْ أَسْ-د سِيذِي، إِنَّا: ”وَارْ هكّْوِي شَا غَارْ مِيصْرَا. زْذغْ ذِي ثمُّورْثْ إِ ذ أَشْ غَا إِنِيغْ.
\v 3 زْذغْ ذِي ثمُّورْثْ-أَ أَمْ ؤُبَارَّانِي ؤُ نشّْ أَذْ كِيكْ إِڒِيغْ، أَذْ شكْ بَارْكغْ، مِينْزِي إِ شكْ ؤُ إِ زَّارِيعثْ نّشْ ؤُمِي غَا وْشغْ مَارَّا ثِيمُّورَا-يَا ؤُشَا أَذْ كمّْڒغْ ثْجَادْجِيثْ إِ جُّودْجغْ إِ إِبْرَاهِيمْ بَابَاشْ. \x ◘ \xo 26:‏3 \xt أَمز. 13‏:‏15؛ 15‏:‏18. \x*
\v 4 أَذْ كتَّارغْ زَّارِيعثْ نّشْ أَمْ يِيثْرَانْ ن ؤُجنَّا ؤُشَا أَذْ وْشغْ إِ زَّارِيعثْ نّشْ مَارَّا ثِيمُّورَا-يَا. مَارَّا ڒڭْنُوسْ ن دُّونشْثْ أَذْ تّْوَابَارْكنْ ذِي زَّارِيعثْ نّشْ، \x ◘ \xo 26:‏4 \xt أَمز. 12‏:‏3؛ 18‏:‏18؛ 22‏:‏18. \x*
\v 5 مِينْزِي إِسْڒَا إِبْرَاهِيمْ إِ وَاوَاڒْ إِنُو ؤُشَا إِحْضَا مِينْ ذ أَسْ وْشِيغْ مَاحنْذْ أَذْ إِحْضَا: ڒُومُورَاثْ إِنُو، ثِيوصَّا إِنُو ذ إِزرْفَانْ إِنُو.“
\v 6 أَمُّو إِ إِقِّيمْ إِسْحَاقْ إِزدّغْ ذِي جِيرَارْ.
\m 
\v 7 \add ڒَْامِي\add* ث سّقْسَانْ إِرْيَازنْ ن ومْشَانْ نِّي خْ ثمْغَارْثْ نّسْ، إِنَّا أَسنْ: ”نتَّاثْ ذ ؤُتْشْمَا!“، مِينْزِي إِڭّْوذْ أَذْ يِينِي: ”ذ ثَامْغَارْثْ إِنُو!“. \add مَاغَارْ إِنَّا ذڭْ يِيخفْ نّسْ:\add* ”مَاڒَا وَارْ نِّيغْ أَمنِّي أَذْ أَيِي نْغنْ إِرْيَازنْ ن ومْشَانْ-أَ ذِي طّْوعْ ن رِيفْقَا، مِينْزِي أَقَا ذَايسْ أَژْرِي.“
\v 8 ڒَامِي ذِينْ إِزْذغْ أَطَّاسْ ن وُوسَّانْ، إِمْسَارْ بلِّي أَبِيمَالِيكْ، أَجدْجِيذْ ن إِفِيلِيسْطِينِييّنْ، إِخْزَارْ-د زِي ڒْكَازِي، إِژْرَا إِسْحَاقْ إِتّْعَاثَابْ رِيفْقَا، ثَامْغَارْثْ نّسْ.
\v 9 ؤُشَا إِڒَاغَا أَبِيمَالِيكْ خْ إِسْحَاقْ، إِنَّا أَسْ: ”خْزَارْ، ثَا س ثِيذتّْ ذ ثَامْغَارْثْ نّشْ! مَامّشْ ثڭِّيذْ ثنِّيذْ أَنغْ ذ ؤُتْشْمَا؟“ إِسْحَاقْ إِنَّا أَسْ: ”س مِينْزِي نِّيغْ \add إِ يِيخفْ إِنُو\add*: ’أَقَا ثِيڒِي أَذْ أَيِي نْغنْ خْ سِّيبّثْ نّسْ.‘ “
\v 10 أَبِيمَالِيكْ إِنَّا: ”مَاغَارْ ذ أَنغْ ثڭِّيذْ أَيَا؟ خْ ذْرُوسْ أَذْ يِيڒِي إِطّصْ شَا ن إِجّْ زِي ڒْڭنْسْ أَكْ-ذ ثمْغَارْثْ نّشْ ؤُشَا أَذْ ثِيڒِي ثڭِّيذْ دّنْبْ خْ يِيڒِي نّغْ.“
\v 11 يُومُورْ أَبِيمَالِيكْ مَارَّا ڒْڭنْسْ، إِنَّا: ”ونِّي إِ غَا إِحَاذَانْ أَرْيَازْ-أَ نِيغْ ثَامْغَارْثْ نّسْ، أَذْ ث نْغنْ نِيشَانْ!“
\m 
\v 12 إِزَارْعْ إِسْحَاقْ ذِي ثمُّورْثْ نِّي ؤُشَا إِكْسِي أَسڭّْوَاسْ نِّي مْيَا ن إِمُورنْ ن زّْيَاذَا، \add مِينْزِي\add* إِبَارْكْ إِ-ث سِيذِي.
\v 13 ثمَّارْنِي شّنْعثْ ن ورْيَازْ \add نِّي\add* ؤُشَا نتَّا إِقِّيمْ إِمقَّارْ، أَڒَامِي ثذْوڒْ شّنْعثْ نّسْ ذ ثَامقّْرَانْثْ أَطَّاسْ.
\v 14 ثُوغَا غَارسْ ؤُدْجِي ؤُ غَارسْ \add عَاوذْ\add* إِفُونَاسنْ ذ ثْفُونَاسِينْ ذ وَاطَّاسْ ن إِسمْغَانْ، أَڒَامِي زَّايسْ ؤُسْمنْ إِفِيلِيسْطِينِييّنْ.
\v 15 مَارَّا أَنُوثنْ نِّي غْزَانْ إِمْسخَّارنْ ذڭْ وُوسَّانْ ن إِبْرَاهِيمْ بَابَاسْ، نثْينْ ثنْ إِفِيلِيسْطِينِييّنْ ؤُشَا شُّورنْ ثنْ س ؤُشَاڒْ.
\v 16 \add خنِّي\add* إِنَّا أَبِيمَالِيكْ إِ إِسْحَاقْ: ”بعّذْ خَانغْ، مِينْزِي ثْذوْڒذْ ثْجهْذذْ خَانغْ س وَاطَّاسْ.“
\v 17 إِسْحَاقْ إِرُوحْ سّنِّي، إِوْثَا إِقِيضَانْ نّسْ ذِي ثغْزُورْثْ ن جِيرَارْ ؤُشَا إِزْذغْ ذِينِّي.
\v 18 ؤُشَا إِذْوڒْ إِسْحَاقْ إِغْزَا أَنُوثنْ ن وَامَانْ إِنِّي ثُوغَا غْزِينْ ذڭْ وُوسَّانْ ن إِبْرَاهِيمْ بَابَاسْ، إِنِّي نثْينْ إِفِيلِيسْطِينِييّنْ أَوَارْنِي إِ ڒْموْثْ ن إِبْرَاهِيمْ. إِسمَّا ثنْ س إِسْمَاونْ إِنِّي ذ أَسنْ إِڒَاغَا بَابَاسْ.
\v 19 ؤُشَا إِمْسخَّارنْ ن إِسْحَاقْ غْزَانْ ذِي ثغْزُورْثْ نِّي ؤُشَا ؤُفِينْ ذِينْ ڒْعُونْصَارْ ن وَامَانْ دَّارنْ.
\v 20 \add خنِّي\add* قَاشْحنْ إِمكْسَاونْ ن جِيرَارْ أَكْ-ذ إِمكْسَاونْ ن إِسْحَاقْ، نَّانْ: ”أَمَانْ نّغْ!“ \add س ؤُينِّي\add* ڒَاغَانْ إِسمْ ن ڒْعُونْصَارْ نِّي ’عِيسِيقْ‘، مِينْزِي ثُوغَا تّْقَاشَاحنْ خَاسْ. \f ◼ \fr 26:‏20 \ft \bd ’إِمكْسَاونْ‘\bd* - نِيغْ ’إِنِيتْشَانْ‘.\f*
\v 21 \add خنِّي\add* غْزَانْ إِجّْ ن ڒْعُونْصَارْ نّغْنِي ؤُشَا مّنّْغنْ خَاسْ عَاوذْ. \add س ؤُينِّي\add* ذ أَسْ إِڭَّا إِسمْ ن ’سِيثْنَا‘.
\v 22 ؤُشَا إِبعّذْ سّنِّي، إِغْزَا إِجّْ ن ڒْعُونْصَارْ نّغْنِي، وَارْ خَاسْ قِيشْحنْ شَا ؤُشَا ڭِّينْ أَسْ إِسمْ نّسْ ’رِيحُوبُوثْ‘، إِنَّا: ”ڒخُّو سِيذِي إِوْشَا أَنغْ تَّاسِيعْ ؤُشَا أَذْ غَارْنغْ ثِيڒِي ڒْغِيدْجثْ ذِي ثمُّورْثْ.“
\v 23 ؤُشَا إِڭعّذْ سّنِّي غَارْ بِئرْ-سبْعَا.
\m 
\v 24 إِبَانْ أَسْ-د سِيذِي ذِي دْجِيرثْ نِّي، إِنَّا أَسْ: ”نشّْ ذ أَربِّي ن إِبْرَاهِيمْ بَابَاشْ! وَارْ تّڭّْوذْ شَا، أَقَا نشّْ أَكِيذكْ ؤُ نشّْ أَذْ شكْ بَارْكغْ، أَذْ كتَّارغْ زَّارِيعثْ نّشْ ذِي طّْوعْ ن ؤُمْسخَّارْ إِنُو إِبْرَاهِيمْ.“
\v 25 \add خنِّي\add* إِبْنَا ذِينْ إِجّْ ن ؤُعَالْطَارْ \add مِينْ خفْ إِڭَّا ثَاغَارْصْثْ\add*، ؤُشَا إِڒَاغَا إِسمْ ن سِيذِي. إِوْثَا ذِينْ أَقِيضُونْ نّسْ ؤُشَا غْزِينْ ذِينْ إِمْسخَّارنْ ن إِسْحَاقْ إِجّْ ن وَانُو.
\v 26 أَبِيمَالِيكْ يُوسَا-د غَارسْ زِي جِيرَارْ، أَكْ-ذ أَحُوزَّاثْ، أَمدُّوكّڒْ نّسْ، ذ فِيكُولْ، أَكُومَانْذَارْ ن ڒْعسْكَارْ نّسْ.
\v 27 إِنَّا أَسنْ إِسْحَاقْ: ”مَاغَارْ غَارِي د-ثُوسِيمْ، وَاخَّا كنِّيوْ ثْشَارّْهمْ أَيِي ؤُشَا ثسُّوفّْغمْ أَيِي خَاومْ؟“
\v 28 نِيثْنِي نَّانْ: ”أَقَا نژْرَا بلِّي سِيذِي أَكِيذكْ. س ؤُيَا ننَّا، أَذْ ذِينْ ثِيڒِي ڒخُّو إِشْثْ ن ثْجَادْجِيثْ جَارَانغْ، جَارَانغْ ذ شكْ، ؤُشَا أجّْ أَنغْ أَذْ كِيكْ نڭّْ إِجّْ ن ڒْعَاهْذْ،
\v 29 حِيمَا شكْ وَارْ ذ أَنغْ ثتّڭّذْ ڒْغَارْ، أَمْ مَامّشْ ؤُڒَا ذ نشِّينْ وَارْ شكْ نْحِيذِي شَا ؤُشَا أَقَا نمْصُورّفْ أَكِيذكْ مْلِيحْ ؤُشَا نسّكّْ إِ شكْ ذِي ڒَامَانْ. أَقَا شكْ ڒخُّو ذ أَمِيمُونْ ن سِيذِي!“
\v 30 \add خنِّي\add* إِڭَّا أَسنْ إِشْثْ ن زَّارْذثْ ؤُشَا شِّينْ، سْوِينْ.
\v 31 كَّارنْ زِيشْ ؤُشَا جُّودْجنْ إِجّنْ إِ ونّغْنِي. خَاسْ ؤُشَا إِسّْقبّضْ إِ-ثنْ إِسْحَاقْ ؤُشَا رُوحنْ نِيثْنِي زِي غَارسْ ذِي ڒهْنَا.
\m 
\v 32 ذڭْ وَاسّْ نِّي ذ إِجّْ ؤُسِينْ-د إِمْسخَّارنْ ن إِسْحَاقْ، خبَّارنْ ث خْ وَانُو إِ إِغْزَانْ ؤُشَا نَّانْ أَسْ: ”ذ أَمَانْ إِ نُوفَا.“
\v 33 إِسمَّا \add أَنُو-يَا\add* سبْعَا. خْ ؤُيَا إِ إِدْجَا يِيسمْ ن ثنْذِينْثْ نِّي بِئرْ-سبْعَا، أَڒْ أَسّْ-أَ.
\b
\s1 ثِيمْغَارِينْ ن عِيسُو
\m 
\v 34 ؤُمِي ثُوغَا غَارْ عِيسُو أَربْعِينْ ن إِسڭّْوُوسَا، يِيوِي يُوذِيثْ، يدْجِيسْ ن بِيرِي، أَحِيتِّي، ذ ثَامْغَارْثْ، ؤُڒَا ذ بَاسْمَاثْ، يدْجِيسْ ن إِلُونْ، أَحِيتِّي. \f ◼ \fr 26:‏34 \ft \bd ’بِيرِي‘\bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَنُو إِنُو‘. \bd ’بَاسْمَاثْ‘\bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’إِتّْفُوحنْ‘ نِيغْ ’ڒعْطُورْ‘. \bd ’إِلُونْ‘\bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’ثَاشجَّارْثْ ن ڒْبدْجُوضْ‘.\f*
\v 35 ثُوغَا أَثنْثْ ذ ثَارْزُوڭِي ن وُوڒْ إِ إِسْحَاقْ ذ رِيفْقَا. \x ◘ \xo 26:‏35 \xt أَمز. 27‏:‏46. \x*
\b
\b
\c 27
\s1 إِسْحَاقْ إِبَاركْ يَاعْقُوبْ
\m 
\v 1 ڒَامِي إِذْوڒْ إِسْحَاقْ ذ أَوسَّارْ ؤُ ثِيطَّاوِينْ نّسْعمْشنْثْ أَڒَامِي عْڒَاحَاڒْ وَارْ إِتّْوِيڒِي، إِڒَاغَا عِيسُو، مِّيسْ أَمنْزُو، إِنَّا أَسْ: ”مِّي!“ ؤُشَا نتَّا إِنَّا أَسْ: ”أَقَا أَيِي ذَا!“
\v 2 ؤُشَا إِنَّا: ”أَقَا نشّْ وْسَارغْ، وَارْ سِّينغْ أَسّْ إِ ذِي غَا مّْثغْ.
\v 3 ڒخُّو، كْسِي ڒسْنَاحْ نّشْ ذ وقْرَابْ نّشْ ن فْڒِيثْشَاثْ ذ ڒْقوْسْ نّشْ، ثفّْغذْ غَارْ ڒخْڒَا ؤُشَا ڭْمَارْ أَيِي-د ثَايْمَارْثْ إِ مَاشَّا.
\v 4 سوْجذْ أَيِي-د إِشْثْ ن مَاشَّا إِشْنَانْ إِ ذ أَيِي غَا إِعجْبنْ ؤُشَا ثوْشذْ أَيِي ت-إِ-د، أَذْ ت شّغْ، حِيمَا أَذْ شكْ بَارْكغْ قْبڒْ مَا أَذْ مّْثغْ.“
\v 5 رِيفْقَا ثُوغَا ثسْڒَا ؤُمِي إِسِّيوڒْ إِسْحَاقْ أَكْ-ذ مِّيسْ عِيسُو. ؤُشَا إِرُوحْ عِيسُو غَارْ ڒخْڒَا حِيمَا أَذْ إِيْمَارْ ثِيميْرَا، مَاحنْذْ أَذْ ت-إِ-د-يَاوِي.
\v 6 \add خنِّي\add* ثسِّيوڒْ رِيفْقَا أَكْ-ذ يَاعْقُوبْ مِّيسْ، ثنَّا أَسْ: ”خْزَارْ، نشّْ سْڒِيغْ بَابَاشْ إِسَّاوَاڒْ أَكْ-ذ عِيسُو ؤُمَاشْ، إِنَّا \add أَسْ\add*:
\v 7 ’أَوِي أَيِي-د إِشْثْ ن ثيْمَارْثْ ؤُشَا سوْجذْ أَيِي إِشْثْ ن مَاشَّا لمْلِيحْ، مَاحنْذْ أَذْ ت شّغْ، حِيمَا نشّْ أَذْ أَشْ بَارْكغْ قِيبَاتْشْ إِ وُوذمْ ن سِيذِي قْبڒْ إِ غَا مّْثغْ.‘
\v 8 ڒخُّو، مِّي، سڒْ-د غَارِي مِينْ زِي شكْ غَا ؤُمُورغْ.
\v 9 ڒُْوهْ غَارْ ثْحِيمَارْثْ ؤُشَا أَوِي أَيِي-د ثْنَاينْ ن إِغَايْضنْ إِمژْيَاننْ زڭْ إِغَايْضنْ. نشّْ أَذْ زَّايْسنْ سّْوجْذغْ إِشْثْ ن مَاشَّا إِشْنَانْ إِ بَابَاشْ، أَمْ مَامّشْ ذ أَسْ إِتَّاعْجِيبْ
\v 10 ؤُ إِتّْخصَّا شكْ أَذْ ث ثَاوْيذْ إِ بَابَاشْ، أَذْ يشّْ، حِيمَا أَذْ شكْ إِبَاركْ قْبڒْ ڒْموْثْ نّسْ.“
\v 11 \add خنِّي\add* إِنَّا يَاعْقُوبْ إِ رِيفْقَا، يمَّاسْ: ”خْزَارْ، عِيسُو ؤُمَا ذ أَرْيَازْ بُو-شْعَارْ ؤُ نشّْ ذ أَرْيَازْ ذ أَڒقَّاغْ.
\v 12 بَالَاكْ أَذْ أَيِي إِحَاذَا بَابَا ؤُشَا أَذْ إِڒِيغْ أَمشْنَاوْ أَغشَّاشْ ذِي ثِيطَّاوِينْ نّسْ. \add خنِّي\add* أَذْ كْسِيغْ إِشْثْ ن نّعْڒثْ خَافِي، وَارْ كسِّيغْ لْبَارَاكَا.“
\v 13 يمَّاسْ ثنَّا أَسْ: ”نّعْڒثْ نّشْ أَذْ ثِيڒِي خَافِي، أَ مِّي! طَاعْ إِ وَاوَاڒْ إِنُو وَاهَا، أَوْيِي ثنْ-د غَارِي.“
\m 
\v 14 \add خنِّي\add* نتَّا إِرُوحْ، إِكْسِي \add ثنْ\add* ؤُشَا يِيوْيِي \add ثنْ\add* إِ يمَّاسْ. ؤُشَا يمَّاسْ ثڭَّا إِشْثْ ن مَاشَّا إِشْنَانْ أَمْ مَامّشْ ذ أَسْ إِتَّاعْجِيبْ إِ بَابَاسْ.
\v 15 ثكْسِي رِيفْقَا أَرُّوضْ إِفشّْحنْ أَطَّاسْ إِ ثُوغَا غَارسْ ذِي ثَادَّارْثْ زڭْ وَارُّوضْ ن عِيسُو، مِّيسْ أَمنْزُو، ؤُشَا ثَارْضْ \add إِ-ث\add* يَاعْقُوبْ، مِّيسْ أَمَاژُوژْ. \f ◼ \fr 27:‏15 \ft \bd ’ذِي ثَادَّارْثْ‘\bd* - إِخْسْ أَذْ يِينِي ’ذڭْ ؤُقِيضُونْ‘.\f*
\v 16 ثڭَّا أَسْ إِڒمْ ن إِغَايْضنْ إِمژْيَاننْ زڭْ إِغَايْضنْ خْ إِفَاسّنْ نّسْ ؤُ خْ يِيرِي نّسْ أَڒقَّاغْ.
\v 17 ثوْشَا مَاشَّا-يَا إِشْنَانْ أَكْ-ذ وغْرُومْ نِّي ثنْڭّْوَا ذڭْ إِفَاسّنْ ن مِّيسْ يَاعْقُوبْ.
\v 18 نتَّا يُوسَا-د غَارْ بَابَاسْ، إِنَّا: ”\add أَ\add* بَابَا!“ نتَّا إِنَّا: ”أَقَا أَيِي ذَا! مِينْ ثعْنِيذْ شكْ، \add أَ\add* مِّي؟“
\v 19 إِنَّا يَاعْقُوبْ إِ بَابَاسْ: ”نشّْ ذ عِيسُو، أَمنْزُو نّشْ. ڭِّيغْ مِينْ ذ أَيِي ثنِّيذْ. كَّارْ ڒخُّو، قِّيمْ، أشّْ زِي ثْميْرَا إِنُو، حِيمَا أَذْ أَيِي إِبَاركْ ڒعْمَارْ نّشْ.“
\v 20 \add خنِّي\add* إِنَّا إِسْحَاقْ إِ مِّيسْ: ”مَامّشْ ثڭِّيذْ ثُوفِيذْ ت ذغْيَا، \add أَ\add* مِّي؟“ إِنَّا: ”مَاغَارْ سِيذِي، أَربِّي نّشْ، إِڭَّا \add إِ-ت\add* ذڭْ وبْرِيذْ إِنُو.“
\v 21 إِسْحَاقْ إِنَّا إِ يَاعْقُوبْ: ”قَارّبْ-د ڒخُّو، حِيمَا أَذْ شكْ حَاذِيغْ، \add أَ\add* مِّي، مَا شكْ ذ مِّي عِيسُو نِيغْ لَّا.“
\v 22 \add ڒَْامِي\add* د-إِقَارّبْ يَاعْقُوبْ غَارْ بَابَاسْ إِسْحَاقْ، إِحَاذَا ث ؤُشَا إِنَّا: ”ثْمِيجَّا ذ ثْمِيجَّا ن يَاعْقُوبْ، \add مَاشَا\add* إِفَاسّنْ ذ إِفَاسّنْ ن عِيسُو.“
\v 23 نتَّا وَارْ ث إِعْقِيڒْ، مِينْزِي إِفَاسّنْ نّسْ ثُوغَا شعَّارنْ أَمشْنَاوْ إِفَاسّنْ ن عِيسُو ؤُشَا إِبَارْكْ إِ-ث.
\v 24 إِنَّا: ”مَا ذ شكْ ذ مِّي عِيسُو؟“ نتَّا إِنَّا: ”ذ نشّْ!“
\v 25 \add خنِّي\add* إِنَّا: ”سْقَارّبْ أَيِي ت-إِ-د زَّاثِي، حِيمَا أَذْ شّغْ زِي ثْميْرَا ن مِّي، حِيمَا نشّْ أَذْ شكْ بَارْكغْ.“ إِسَّارْسْ إِ-ت-إِ-د زَّاثسْ ؤُشَا إِشَّا. يِيوِي أَسْ-د عَاوذْ بِينُو ؤُشَا إِسْوَا. \f ◼ \fr 27:‏25 \ft \bd ’حِيمَا نشّْ أَذْ شكْ بَارْكغْ‘\bd* - س لْحَارْفْ ’حِيمَا أَذْ شكْ إِبَاركْ ڒعْمَارْ إِنُو‘\f*
\v 26 إِنَّا أَسْ بَابَاسْ إِسْحَاقْ: ”قَارّبْ-د غَارِي ڒخُّو، سُوذمْ أَيِي، \add أَ\add* مِّي!“
\v 27 ؤُشَا إِقَارّبْ-د غَارسْ، إِسُّوذمْ إِ-ث. إِشمّْ إِسْحَاقْ أَرِّيحثْ ن وَارُّوضْ نّسْ ؤُشَا إِبَارْكْ إِ-ث، إِنَّا: ”خْزَارْ، ڒفْوَاحثْ ن مِّي أَمْ ڒفْوَاحثْ ن ييَّارْ إِ إِبَاركْ سِيذِي.
\v 28 أَذْ أَشْ إِوْشْ أَربِّي زِي نّْذَا ن ؤُجنَّا ؤُ زِي ڒيْذَامْ ن ثمُّورْثْ ؤُڒَا ذ وَاطَّاسْ ن إِمنْذِي ذ بِينُو ن جْذِيذْ. \x ◘ \xo 27:‏28 \xt عبر. 11‏:‏20. \x*
\v 29 أَذْ أَشْ خذْمنْ ڒڭْنُوسْ ؤُشَا شُّوعُوبْ أَذْ أَشْ بنْذْقنْ. حْكمْ خْ أَيْثْمَاشْ ؤُ أجّْ إِحنْجِيرنْ ن يمَّاشْ أَذْ أَشْ بنْذْقنْ! إِنِّي شكْ إِ غَا إِنعْڒنْ، أَذْ تّْوَانعْڒنْ، ؤُ إِنِّي شكْ غَا إِبَارْكنْ، أَذْ تّْوَابَارْكنْ.“ \x ◘ \xo 27:‏29 \xt أَمز. 12‏:‏3. \x*
\m 
\v 30 أَوَارْنِي ڒَامِي إِكمّڒْ إِسْحَاقْ لْبَارَاكَا إِ يَاعْقُوبْ ؤُشَا أَمْ د-إِفّغْ يَاعْقُوبْ \add عَاذْ\add* خْ بَابَاسْ إِسْحَاقْ، إِعْقبْ-د عِيسُو، ؤُمَاسْ، زِي ثيْمَارْثْ نّسْ.
\v 31 إِسّوْجذْ خنِّي إِشْثْ ن مَاشَّا إِشْنَانْ ؤُشَا إِكْسِي ت غَارْ بَابَاسْ، إِنَّا أَسْ: ”تّْزَاوْڭغْ، بَابَا، كَّارْ ثشّذْ زِي ثيْمَارْثْ ن مِّيشْ، \add حِيمَا\add* شكْ أَذْ أَيِي ثْبَارْكذْ.“ \f ◼ \fr 27:‏31 \ft \bd ’\bdit حِيمَا\bdit* شكْ أَذْ أَيِي ثْبَارْكذْ‘\bd* - س ثْعِيبْرَانِيثْ ’حِيمَا أَذْ أَيِي إِبَاركْ ڒعْمَارْ نّشْ‘\f*
\v 32 إِنَّا أَسْ إِسْحَاقْ، بَابَاسْ: ”مِينْ ثعْنِيذْ شكْ؟“ نتَّا إِنَّا: ”نشّْ ذ مِّيشْ، أَمنْزُو نّشْ، عِيسُو.“
\v 33 ؤُشَا إِنّخْڒعْ إِسْحَاقْ، إِنَّا: ”مِينْ إِعْنَا وَانِيثَا إِ د-يُوسِينْ ذَا، إِطّفْ ثَايْمَارْثْ ؤُشَا يِيوِي أَيِي ت-إِ-د؟ شِّيغْ زِي مَارَّا \add مَانْ أَيَا\add* قْبڒْ د-ثُوسِيذْ ؤُشَا نشّْ بَارْكغْ ث ؤُ أَذْ إِتّْوَابَاركْ عَاوذْ.“
\v 34 ؤُمِي إِسْڒَا عِيسُو أَوَاڒنْ ن بَابَاسْ، إِسْغُويْ س يِيجّْ ن ڒعْيَاذْ إِجْهذْ يَارْزڭْ، إِنَّا إِ بَابَاسْ: ”بَاركْ أَيِي ؤُڒَا ذ نشّْ، \add أَ\add* بَابَا!“ \x ◘ \xo 27:‏34 \xt عبر. 12‏:‏17. \x*
\v 35 إِنَّا: ”يُوسَا-د ؤُمَاشْ س ثحْرَايْمشْثْ، إِكْسِي لْبَارَاكَا نّشْ.“
\v 36 \add خنِّي\add* إِنَّا: ”مَا وَارْ إِدْجِي إِسمْ نّسْ س ڒْحقّْ يَاعْقُوبْ؟ أَقَا إِشْمثْ أَيِي ثْنَاينْ ن ثْوَاڒَاوِينْ. إِكْسِي \add ڒْحقّْ ن\add* ؤُمنْزُو إِنُو ؤُشَا أَقَا ڒخُّو إِكْسِي \add عَاوذْ\add* لْبَارَاكَا إِنُو.“ \add خنِّي\add* إِنَّا: ”مَا وَارْ غَاركْ ثقِّيمْ شَا ن لْبَارَاكَا إِ نشّْ؟“ \x ◘ \xo 27:‏36 \xt أَمز. 25‏:‏33. \x*
\v 37 \add خنِّي\add* يَارَّا-د إِسْحَاقْ، إِنَّا إِ عِيسُو: ”خْزَارْ، نشّْ ڭِّيغْ ث ذ ڒْحَاكمْ خَاكْ ؤُشَا وْشِيغْ أَسْ أَيْثْمَاسْ ذ إِمْسخَّارنْ، ؤُڒَا س إِمنْذِي ذ بِينُو ن جْذِيذْعوّْڒغْ ث. مِينْ ذِينْ عَاذْ، أَذْ أَشْ وْشغْ ڒخُّو، \add أَ\add* مِّي؟“
\v 38 إِنَّا عِيسُو إِ بَابَاسْ: ”مَا غَاركْ مْغِيرْ لْبَارَاكَا-يَا وَاهَا، \add أَ\add* بَابَا؟ بَاركْ أَيِي عَاوذْ، ؤُڒَا ذ نشّْ، \add أَ\add* بَابَا!“ ؤُشَا إِسّْڭعّذْ عِيسُو ثْمِيجَّا نّسْ، إِسْغُويْ. \x ◘ \xo 27:‏38 \xt عبر. 12‏:‏17. \x*
\v 39 \add خنِّي\add* يَارَّا-د إِسْحَاقْ خْ بَابَاسْ، إِنَّا أَسْ: ”خْزَارْ، أَذْ ثِيڒِي ثْزذِّيغْثْ نّشْ إِڭّْوجّنْ خْ ڒيْذَامْ ن ثمُّورْثْ ؤُ خْ نّْذَا ن ؤُجنَّا سنّجْ.
\v 40 س سِّيفْ نّشْ إِ غَا ثقِّيمذْ ثدَّارذْ ؤُ أَذْ ثْخذْمذْ إِ ؤُمَاشْ. مَاشَا خْمِي غَا ثقِّيمذْ أَذْ ثنْهزّذْ، أَذْ إِمْسَارْ أَذْ ثَاوْضذْ أَذْ ثكّْسذْ زَايْڒُو نّسْ خْ يِيرِي نّشْ.“
\m 
\v 41 ؤُشَا إِشَارْهْ عِيسُو يَاعْقُوبْ ذِي سِّيبّثْ ن لْبَارَاكَا إِ زِي ث إِبَاركْ بَابَاسْ، ؤُشَا إِنَّا عِيسُو ذڭْ وُوڒْ نّسْ: ”أَذْ أَوْضنْ وُوسَّانْ ن ؤُعزِّي ن بَابَا، خنِّي أَذْ نْغغْ ؤُمَا يَاعْقُوبْ.“
\v 42 \add ؤُمِي\add* نَّانْ إِ رِيفْقَا أَوَاڒنْ ن عِيسُو، مِّيسْ أَمنْزُو، ثسّكّْ إِجّنْ أَذْ إِڒَاغَا إِ يَاعْقُوبْ، مِّيسْ أَمَاژُوژْ، ثنَّا أَسْ: ”خْزَارْ، عِيسُو ؤُمَاشْ يَارزُّو مَامّشْ زَّايكْ إِ غَا إِخْڒفْ، نتَّا إِخْسْ أَذْ شكْ إِنغْ.
\v 43 ڒخُّو، \add أَ\add* مِّي، طَاعْ إِ وَاوَاڒْ إِنُو. كَّارْ ؤُشَا ثَاروْڒذْ غَارْ حَارَانْ غَارْ ؤُمَا لَابَانْ.
\v 44 زْذغْ أَكِيذسْ شَا ن وُوسَّانْ أَڒْ غَا يَارْسَا وسْعَارْ ن ؤُمَاشْ.
\v 45 خْمِي غَا إِخْسِي ؤُخيّقْ ن ؤُمَاشْ ؤُشَا أَذْ إِتُّو مِينْ ذ أَسْ ثڭِّيذْ، نشّْ أَذْ سّكّغْ \add إِجّنْ\add*، مَاحنْذْ أَذْ شكْ د-يَاوِي سّنِّي. مَايمِّي إِ زَّايْومْ غَا تّْوَاحَارّْمغْ س ثْنَاينْ إِذْومْ ذڭْ إِجّْ ن وَاسّْ؟“
\m 
\v 46 ثنَّا رِيفْقَا إِ إِسْحَاقْ: ”شَارّْهغْ ثُوذَارْثْ إِنُو ذِي سِّيبّثْ ن يسِّيسْ ن حِيثْ. مَاڒَا يَاعْقُوبْ يِيوِي ثَامْغَارْثْ زِي ثبْڒِيغِينْ ن حِيثْ، أَمْ ثْنَاينْ-أَ، زِي ثْحنْجِيرِينْ ن ثمُّورْثْ-أَ، مَانْ لْقِيمَا إِ غَا يِيڒِينْ غَارْ ثُوذَارْثْ إِنُو؟“ \x ◘ \xo 27:‏46 \xt أَمز. 26‏:‏35. \x*
\b
\b
\c 28
\s1 ثَاروْڒَا ن يَاعْقُوبْ ذ ثَارْجِيثْ نّسْ ذِي بَايْثْ-إِلْ
\m 
\v 1 إِڒَاغَا إِسْحَاقْ إِ يَاعْقُوبْ، إِبَاركْ إِ-ث ؤُشَا إِسّكّْ إِ-ث، إِنَّا أَسْ: ”وَارْ تَّاوِي ثَامْغَارْثْ زِي يسِّيسْ ن كنْعَانْ.
\v 2 كَّارْ، رُوحْ غَارْ فَاذَانْ-أَرَامْ، غَارْ ثَادَّارْثْ ن بِيثُووِيلْ، بَابَاسْ ن يمَّاشْ، ؤُشَا أَوِي-د سّنِّي ثَامْغَارْثْ إِ شكْ زڭْ يسِّيسْ ن لَابَانْ، ؤُمَاسْ ن يمَّاشْ. \x ◘ \xo 28:‏2 \xt حُوش. 12‏:‏13. \x*
\v 3 أَربِّي، أَمْزمَّارْ خْ كُوڒْشِي، أَذْ شكْ إِبَاركْ ؤُ أَذْ أَشْ إِوْشْ ڒْغِيدْجثْ ؤُشَا أَذْ شكْ إِكتَّارْ أَڒْ غَا ثْذوْڒذْ ذ إِجّْ ن وڭْرَاوْ ن ڒڭْنُوسْ.
\v 4 إِڒِي نتَّا أَذْ أَشْ إِوْشْ لْبَارَاكَا ن إِبْرَاهِيمْ، إِ شكْ ؤُ إِ زَّارِيعثْ نّشْ أَكِيذكْ، حِيمَا أَذْ ثْوَارْثذْ ثَامُّورْثْ نِّي ذِي ثْزدّْغذْ أَمْ ؤُبَارَّانِي، ثنِّي إِوْشَا أَربِّي إِ إِبْرَاهِيمْ.“ \x ◘ \xo 28:‏4 \xt أَمز. 12‏:‏7؛ 13‏:‏15؛ 15‏:‏18؛ 24‏:‏7؛ 26‏:‏3؛ أَعَوذ. 34‏:‏4؛ ڒخ. 7‏:‏5. \x*
\v 5 \add خنِّي\add* إِسّكّْ إِسْحَاقْ يَاعْقُوبْ. ؤُشَا نتَّا إِرُوحْ غَارْ فَادَّانْ-أَرَامْ، غَارْ لَابَانْ، مِّيسْ ن بِيثُووِيلْ، أَرَامِييُو، ؤُمَاسْ ن رِيفْقَا، يمَّاسْ ن يَاعْقُوبْ ذ عِيسُو.
\m 
\v 6 \add ؤُمِي\add* إِژْرَا عِيسُو بلِّي إِسْحَاقْ إِبَاركْ يَاعْقُوبْ ؤُشَا إِسّكّْ إِ-ث-إِ-د غَارْ فَادَّانْ-أَرَامْ حِيمَا أَذْ يَاوِي إِ يِيخفْ نّسْ ثَامْغَارْثْ سّنِّي، ؤُ ڒَامِي ث إِبَاركْ، يُومُورْ إِ-ث، إِنَّا أَسْ: ”وَارْ كسِّي ثَامْغَارْثْ زڭْ يسِّيسْ ن كنْعَانْ!“،
\v 7 ؤُشَا \add إِژْرَا عَاوذْ\add* بلِّي يَاعْقُوبْ إِطَاعْ بَابَاسْ ذ يمَّاسْ، إِرُوحْ غَارْ فَادَّانْ-أَرَامْ،
\v 8 \add خنِّي\add* إِثْوَاڒَا عِيسُو بلِّي يسِّيسْ ن كنْعَانْ ذ ثِيعفَّانِينْ ذِي ثِيطَّاوِينْ ن بَابَاسْ إِسْحَاقْ.
\v 9 \add خنِّي\add* إِرُوحْ عِيسُو غَارْ إِسْمَاعِيلْ ؤُشَا يِيوِي مَاحَالَاثْ ذ ثَامْغَارْثْ إِ يِيخفْ نّسْ، يَارْنِي ت-إِ-د غَارْ ثمْغَارِينْ نّغْنِي. نتَّاثْ ثُوغَا-ت ذ يدْجِيسْ ن إِسْمَاعِيلْ، مِّيسْ ن إِبْرَاهِيمْ، ؤُتْشْمَاسْ ن نَابَايُوثْ.
\m 
\v 10 ؤُشَا إِفّغْ يَاعْقُوبْ زِي بِئرْ-سبْعَا، إِرُوحْ غَارْ حَارَانْ.
\v 11 يِيوضْ غَارْ إِجّْ ن ومْشَانْ مَانِي ينْسَا، مِينْزِي ثُوغَا ثَافُوشْثْ ثغْرِي. إِكْسِي زڭْ يژْرَا ن ومْشَانْ نِّي، إِسَّارْسْ إِ-ثنْ سَاذُو ؤُزدْجِيفْ نّسْ ؤُشَا إِوْضَا إِطّصْ ذڭْ ومْشَانْ نِّي.
\v 12 يُورْجَا، أَقَا إِجّْ ن دّْرُوجْ إِبدّْ خْ ثمُّورْثْ ؤُشَا إِتّْحَاذَا إِخفْ ن دّْرُوجْ أَجنَّا، ؤُ خْزَارْ، لْمَالَاكَاثْ ن أَربِّي تَّاڒْينْثْ هكّْوَانْثْ زَّايسْ. \x ◘ \xo 28:‏12 \xt يُوح. 1‏:‏52. \x*
\v 13 ؤُ خْزَارْ، سِيذِي إِبدّْ خَاسْ، إِنَّا: ”نشّْ ذ سِيذِي، أَربِّي ن بَابَاشْ إِبْرَاهِيمْ، ذ أَربِّي ن إِسْحَاقْ. ثَامُّورْثْ إِ خفْ ثطّْصذْ أَذْ أَشْ ت وْشغْ إِ شكْ ؤُ إِ زَّارِيعثْ نّشْ. \x ◘ \xo 28:‏13 \xt أَمز. 35‏:‏1، 3؛ 48‏:‏3؛ أَعَوذ. 12‏:‏20؛ 19‏:‏8. \x*
\v 14 أَذْ ثِيڒِي زَّارِيعثْ نّشْ أَمْ ؤُشَاڒْ ن ثمُّورْثْ ؤُشَا أَذْ ثِيرِيوذْ غَارْ ڒْغَارْبْ ذ شَّارْقْ، غَارْ شَّامَالْ ذ لْجَانُوبْ. ذَايكْ ؤُ ذِي زَّارِيعثْ نّشْ أَذْ تّْوَابَارْكنْثْ مَارَّا ڒَادْجَاثْ ن ثمُّورْثْ. \x ◘ \xo 28:‏14 \xt أَمز. 12‏:‏3؛ 18‏:‏18؛ 22‏:‏18؛ 26‏:‏4. \x*
\v 15 أَقَا أَيِي نشّْ أَكِيذكْ ؤُ نشّْ أَذْ شكْ حْضِيغْ قَاعْ مَانِي إِ غَا ثْرَاحذْ، أَذْ شكْ أَرّغْ غَارْ ثمُّورْثْ-أَ، مِينْزِي نشّْ وَارْ شكْ تّجِّيغْ أَڒْ غَا كمّْڒغْ مِينْ ذ أَشْ نِّيغْ.“
\v 16 ڒَامِي د-إِفَاقْ يَاعْقُوبْ زڭْ يِيضصْ نّسْ، إِنَّا: ”س ثِيذتّْ، سِيذِي أَقَا-ث ذڭْ ومْشَانْ-أَ ؤُ نشّْ وَارْ سِّينغْ!“
\v 17 ثُوغَا إِڭّْوذْ أَطَّاسْ، إِنَّا: ”مشْحَاڒْ إِسَّاڭّْوَاذْ ومْشَانْ-أَ! أَقَا ثَا مْغِيرْ ذ ثَادَّارْثْ ن أَربِّي ؤُ ثَانِيثَا ذ ثَاوَّارْثْ ن ؤُجنَّا!“
\m 
\v 18 إِكَّارْ يَاعْقُوبْ ؤُشَا إِكْسِي أَژْرُو نِّي ثُوغَا إِسَّارْسْ سَاذُو ؤُزدْجِيفْ نّسْ، إِڭَّا إِ-ث أَمْ يِيجّْ ن وژْرُو ن ڒِيذَارثْ ؤُشَا إِفَارّغْ زّشْثْ خْ ؤُزدْجِيفْ ن وژْرُو. \x ◘ \xo 28:‏18 \xt أَمز. 31‏:‏13؛ 35‏:‏14. \x*
\v 19 إِڭَّا أَمْشَانْ نِّي بَايْثْ-إِلْ، مَاشَا زڭْ ؤُمزْوَارُو ثُوغَا إِسمْ ن ومْشَانْ نِّي لُوزْ.
\v 20 ؤُشَا إِوَاعْذْ يَاعْقُوبْ، إِنَّا: ”مَاڒَا أَربِّي أَقَا-ث أَكِيذِي ؤُشَا أَذْ أَيِي إِحْضَا ذڭْ وبْرِيذْ إِ غَا ؤُيُورغْ، أَذْ أَيِي إِوْشْ أَغْرُومْ حِيمَا أَذْ شّغْ، ذ وَارُّوضْ حِيمَا أَذْ أَرْضغْ
\v 21 ؤُ مَاڒَا ذوْڒغْ غَارْ ثَادَّارْثْ ن بَابَا ذِي ڒَامَانْ، خنِّي سِيذِي أَذْ يِيڒِي ذ أَربِّي إِ نشّْ.
\v 22 ؤُشْ أَژْرُو-يَا إِ ڭِّيغْ ذ أَژْرُو ن ڒِيذَارثْ، أَذْ يِيڒِي ذ ثَادَّارْثْ ن أَربِّي ؤُ زِي مَارَّا مِينْ ذ أَيِي غَا ثوْشذْ، أَذْ أَشْ وْشغْ ڒعْشُورْ!“
\b
\b
\c 29
\s1 ڒمْڒَاشْ ن يَاعْقُوبْ أَكْ-ذ لِييَا ذ رَاحِيلْ
\m 
\v 1 إِكْسِي يَاعْقُوبْ ذڭْ إِضَارنْ نّسْ، إِرُوحْ غَارْ ثمُّورْثْ ن أَيْثْ ن شَّارْقْ.
\v 2 إِخْزَارْ ؤُشَا إِژْرَا إِجّْ ن وَانُو ذڭْ إِيَّارْ ؤُ ثُوغَا ذِينْ ثْڒَاثَا ن ثْحِيمْرِيوِينْ ن وُودْجِي جْنِينْثْ زَّاثسْ، مِينْزِي زڭْ وَانُو نِّي وَارّْذنْ نِيثْنِي ثِيحِيمْرِيوِينْ. ثُوغَا ذِينْ إِجّْ ن وژْرُو خْ ؤُقمُّومْ ن وَانُو.
\v 3 سّْمُوننْ ذِينْ مَارَّا ثِيحِيمْرِيوِينْ. \add خَاسْ ؤُشَا\add* كّْسنْ أَژْرُو خْ ؤُقمُّومْ ن وَانُو ؤُشَا وَارْذنْ ؤُدْجِي. \add أَوَارْنِي أَسْ\add* أَرِّينْ أَژْرُو \add عَاوذْ\add* خْ ؤُقمُّومْ ن وَانُو.
\v 4 إِنَّا أَسنْ يَاعْقُوبْ: ”أَيْثْمَا إِنُو، مَانِيسْ كنِّيوْ؟“ نِيثْنِي أَرِّينْ-د: ”زِي حَارَانْ إِ ندْجْ.“
\v 5 نتَّا إِنَّا أَسنْ: ”مَا ثسّْنمْ لَابَانْ، مِّيسْ ن نَاحُورْ؟“ نِيثْنِي أَرِّينْ-د: ”وَاهْ، نسّنْ إِ-ث.“
\v 6 إِنَّا أَسنْ نتَّا: ”مَامّشْ إِدْجَا؟“ أَرِّينْ-د: ”أَقَا-ث مْلِيحْ، أَقَا ذَا يدْجِيسْ رَاحِيلْ ثُوسَا-د أَكْ-ذ وُودْجِي.“
\v 7 إِنَّا أَسْ: ”أَقَا ذَا أَزِيڒْ عَاذْ إِمْغَارْ، وَارْ يدْجِي بُو ڒْوقْثْ حِيمَا أَذْ ننْذهْ ڒبْهَايمْ. وَارْذمْ ؤُدْجِي ؤُشَا رُوحمْ، مَاحنْذْ أَذْ ثنْ ثَاروْسمْ.“
\v 8 نِيثْنِي أَرِّينْ-د: ”وَارْ نْزمَّارْ أَذْ \add ث\add* نڭّْ أَڒْ د غَا مُوننْثْ مَارَّا ثِيحِيمْرِيوِينْ. \add خنِّي\add* أَذْ سّحْڒُودْجْذنْ أَژْرُو خْ ؤُقمُّومْ ن وَانُو، حِيمَا أَذْ نْوَارذْ ؤُدْجِي.“
\m 
\v 9 ڒَامِي ثُوغَا \add عَاذْ\add* إِسَّاوَاڒْ أَكِيذْسنْ، ثُوسَا-د رَاحِيلْ س وُودْجِي ن بَابَاسْ، مِينْزِي نتَّاثْ ثُوغَا-ت ذ ثَامكْسَاوْثْ.
\v 10 ڒَامِي إِژْرَا يَاعْقُوبْ رَاحِيلْ، يدْجِيسْ ن لَابَانْ، ؤُمَاسْ ن يمَّاسْ، أَكْ-ذ وُودْجِي ن لَابَانْ، ؤُمَاسْ ن يمَّاسْ، إِخشّْ-د يَاعْقُوبْ ؤُشَا إِسّحْڒُودْجذْ أَژْرُو خْ ؤُقمُّومْ ن وَانُو، إِوَارْذْ ؤُدْجِي ن لَابَانْ، ؤُمَاسْ ن يمَّاسْ.
\v 11 إِسُّوذمْ يَاعْقُوبْ رَاحِيلْ، إِسّْڭعّذْ ثْمِيجَّا نّسْ ؤُشَا إِسْغُويْ.
\v 12 إِنَّا يَاعْقُوبْ إِ رَاحِيلْ أَقَا نتَّا زِي ڒَادْجْ ن بَابَاسْ إِ إِدْجَا، ؤُڒَا ذ مِّيسْ ن رِيفْقَا. ؤُشَا نتَّاثْ ثُوزّڒْ، ثْخبَّارْ بَابَاسْ.
\m 
\v 13 ؤُمِي إِسْڒَا لَابَانْ ڒخْبَارْ خْ يَاعْقُوبْ، مِّيسْ ن ؤُتْشْمَاسْ، يُوزّڒْ أَذْ ث إِڒْقَا ؤُشَا إِذَارّعْ أَسْ، إِسُّوذمْ إِ-ث، إِنْذهْ إِ-ث غَارْ ثَادَّارْثْ نّسْ. ؤُشَا نتَّا إِعَاوذْ مَارَّا ثِيمسْڒَايِينْ-أَ إِ لَابَانْ.
\v 14 إِنَّا أَسْ لَابَانْ: ”ذ ثِيذتّْ شكْ ذ إِغسْ إِنُو ذ أَيْسُومْ إِنُو إِ ثدْجِيذْ.“ ؤُشَا إِقِّيمْ غَارسْ ڒْقدّْ ن إِجّْ ن ؤُيُورْ إِكْمڒْ.
\v 15 \add ڒخْذنِّي\add* إِنَّا لَابَانْ إِ يَاعْقُوبْ: ”ؤُمِي شكْ ذ ؤُمَا إِ ثدْجِيذْ، مَا أَذْ غَارِي ثْخذْمذْ بَاطڒْ؟ إِنِي أَيِي مِينْ \add إِ غَا ثِيڒِي\add* ڒْمُونثْ نّشْ؟“
\v 16 لَابَانْ غَارسْ ثْنَاينْ ن يسِّيسْ. إِسمْ ن ثْمنْزُوثْ ذ لِييَا ؤُ إِسمْ ن ثْمَاژُوژْثْ، رَاحِيلْ.
\v 17 ثِيطَّاوِينْ ن لِييَا ثُوغَا كشْعنْثْ، \add مَاشَا\add* رَاحِيلْ ثُوغَا ذَايسْ أَژْڒِي ن وَادُّوذْ ؤُ ن ڒْخزْرَاثْ.
\v 18 يَاعْقُوبْ إِخْسْ رَاحِيلْ. إِنَّا: ”نشّْ أَذْ غَاركْ خذْمغْ سبْعَا ن إِسڭّْوُوسَا خْ رَاحِيلْ يدْجِيسْ ثْمَاژُوژْثْ.“ \x ◘ \xo 29:‏18 \xt حُوش. 12‏:‏13. \x*
\v 19 لَابَانْ يَارَّا-د: ”خَارْ أَذْ أَشْ ت وْشغْ إِ شكْ نِيغْ أَذْ ت وْشغْ إِ ورْيَازْ نّغْنِي. قِّيمْ أَكِيذِي.“
\m 
\v 20 \add أَمُّو\add* إِ إِخْذمْ يَاعْقُوبْ خْ رَاحِيلْ سبْعَا ن إِسڭّْوُوسَا مَاشَا ضْهَارنْ أَسْ-د \add إِسڭّْوُوسَا نِّي\add* أَمشْنَاوْ شَا ن وُوسَّانْ، مِينْزِي ثُوغَا إِتّخْسْ إِ-ت.
\v 21 إِنَّا يَاعْقُوبْ إِ لَابَانْ: ”أوْشْ أَيِي \add ڒخُّو\add* ثَامْغَارْثْ إِنُو، مِينْزِي أَقَا كمّْڒنْ وُوسَّانْ \add ن ڒْمِيجَاڒْ\add* إِنُو، \add أَڒَامِي\add* خَاسْ إِ غَا يَاذْفغْ.“
\v 22 \add خنِّي\add* إِسّْمُونْ لَابَانْ مَارَّا إِرْيَازنْ ن ومْشَانْ نِّي، إِڭَّا ؤُرَارْ.
\v 23 غَارْ ثْمذِّيثْ إِكْسِي يدْجِيسْ لِييَا ؤُشَا إِسِّيوضْ إِ-ت غَارسْ ؤُشَا يُوذفْ خَاسْ يَاعْقُوبْ.
\v 24 إِوْشَا لَابَانْ ثَايَّا نّسْ زِيلْپَا إِ يدْجِيسْ لِييَا ذ ثَايَّا.
\v 25 ثِيوشَّا نّسْ إِژْرَا \add يَاعْقُوبْ\add* بلِّي ذ لِييَا. خنِّي إِنَّا إِ لَابَانْ: ”مِينْ ذ أَيِي ثڭِّيذْ؟ مَا وَارْ ذ أَشْ خْذِيمغْ خْ رَاحِيلْ؟ مَاغَارْ ذ أَيِي ثْشمْثذْ؟“
\v 26 لَابَانْ إِنَّا: ”وَارْ إِتِّيڒِي ؤُيَا ذِي ثمُّورْثْ نّغْ أَذْ نسِّيزَّارْ ثَامَاژُوژْثْ خْ ثْمنْزُوثْ.
\v 27 كمّڒْ سِّيمَانَا-يَا \add ن وُورَارْ\add* ن ثَا، خنِّي أَذْ أَشْ نوْشْ \add عَاوذْ\add* ثِينْ خْ ڒْخذْمثْ إِ غَا ثڭّذْ سَّا ثْسَاونْثْ أَكِيذِي عَاذْ سبْعَا ن إِسڭّْوُوسَا نّغْنِي.“
\v 28 إِڭَّا يَاعْقُوبْ \add أَمنِّي\add*، إِكمّڒْ سِّيمَانَا-يَا \add ن وُورَارْ\add*. \add خنِّي\add* إِوْشَا أَسْ يدْجِيسْ رَاحِيلْ ذ ثَامْغَارْثْ
\v 29 ؤُشَا إِوْشَا لَابَانْ ثَايَّا نّسْ بِيلْهَا إِ يدْجِيسْ رَاحِيلْ مَاحنْذْ أَذْ ثِيڒِي ذ ثَايَّا نّسْ.
\v 30 يُوذفْ \add يَاعْقُوبْ\add* عَاوذْ خْ رَاحِيلْ ؤُشَا إِخْسْ رَاحِيلْ عَاذْ كْثَارْ خْ لِييَا. ؤُشَا إِسخَّارْ أَسْ عَاوذْ سبْعَا ن إِسڭّْوُوسَا نّغْنِي.
\b
\s1 إِحنْجِيرنْ ن يَاعْقُوبْ
\m 
\v 31 \add ؤُمِي\add* إِژْرَا سِيذِي بلِّي لِييَا ثُوغَا ثتّْوَاسّحْقَارْ، يَارْزمْ ڒمْڒَاوثْ نّسْ، \add مَاشَا\add* رَاحِيلْ ثُوغَا وَارْ د-ثتِّيرُووْ شَا.
\v 32 ثكْسِي لِييَا س دّيْسثْ ؤُشَا ثُورُووْ-د أَحنْجِيرْ، إِڭَّا أَسْ رُوبِينْ، مِينْزِي ثنَّا: ”أَقَا سِيذِي إِخْزَارْ غَارْ ڒمْحَايمْ إِنُو. ڒخُّو أَذْ أَيِي إِخْسْ ورْيَازْ إِنُو.“ \f ◼ \fr 29:‏32 \ft \bd ’رُوبِينْ‘\bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’خْژَارْ، إِجّْ ن مِّيسْ!‘.\f*
\v 33 ثكْسِي عَاوذْ س دّيْسثْ، ثُورُووْ-د أَحنْجِيرْ، ثنَّا: ”ؤُمِي إِسْڒَا سِيذِي بلِّي نشّْ تّْوَاسّحْقَارغْ، إِوْشَا أَيِي عَاوذْ وَا.“ ؤُشَا ثڭَّا أَسْ شِيمْعُونْ.
\v 34 ثكْسِي عَاوذْ س دّيْسثْ، ثُورُووْ-د أَحنْجِيرْ، ثنَّا: ”ڒخُّو ثْوَاڒَا-يَا أَذْ إِمُونْ ورْيَازْ إِنُو أَكِيذِي، مِينْزِي ؤُرْوغْ أَسْ-د ثْڒَاثَا ن إِحنْجِيرنْ.“ خْ ؤُيَا نتَّا إِڭَّا أَسْ لَاوِي.
\v 35 ثكْسِي ثْوَاڒَا نّغْنِي س دّيْسثْ، ثُورُووْ-د أَحنْجِيرْ ؤُشَا ثنَّا: ”ثْوَاڒَا-يَا أَذْ قَاذِيغْ سِيذِي.“ خْ ؤُيَا ثڭَّا أَسْ يَاهُوذَا. \add أَوَارْنِي مَانْ أَيَا\add* ثسّْبدّْ ثَارْوَا. \f ◼ \fr 29:‏35 \ft \bd ’يَاهُوذَا‘\bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَذْ إِتّْوَاسمْغَارْ أَربِّي‘.\f*
\b
\b
\c 30
\m 
\v 1 \add ؤُمِي\add* ثژْرَا رَاحِيلْ بلِّي وَارْ د-ثِيرُووْ إِ يَاعْقُوبْ، ثُوسمْ زڭْ ؤُتْشْمَاسْ، ثنَّا إِ يَاعْقُوبْ: ”أوْشْ أَيِي ثَارْوَا! مَاڒَا وَارْ ثقْبِيڒذْ، \add خنِّي\add* أَذْ مّْثغْ.“
\v 2 إِخيّقْ يَاعْقُوبْ خْ رَاحِيلْ، إِنَّا: ”مَا أَقَا أَيِي نشّْ ذڭْ ومْشَانْ ن أَربِّي، ونِّي خَامْ إِطّْفنْ ڒْغِيدْجثْ ن ؤُعذِّيسْ نّمْ؟“
\v 3 ثنَّا: ”أَقَا ذَا ثَايَّا إِنُو بِيلْهَا. أَذفْ خَاسْ، حِيمَا أَذْ د-ثَارُووْ خْ إِفَادّنْ إِنُو مَاحنْذْ ؤُڒَا ذ نشّْ أَذْ غَارِي ثِيڒِي ثَارَّاوْثْ زَّايسْ.“
\v 4 ثوْشَا أَسْ بِيلْهَا، ثَايَّا نّسْ، ذ ثَامْغَارْثْ ؤُشَا يُوذفْ خَاسْ يَاعْقُوبْ.
\v 5 ثكْسِي بِيلْهَا س دّيْسثْ ؤُشَا ثُورُووْ-د أَحنْجِيرْ إِ يَاعْقُوبْ.
\v 6 ثنَّا رَاحِيلْ: ”إِوْشَا أَيِي أَربِّي ثَاسْغَارْثْ ؤُشَا إِسْڒَا عَاوذْ غَارِي. إِوْشَا أَيِي مِّي.“ خْ ؤُيَا ثڭَّا أَسْ دَان. \f ◼ \fr 30:‏6 \ft \bd ’إِسْڒَا عَاوذْ غَارِي‘\bd* - س ثْعِيبْرَانِيثْ ’إِسْڒَا عَاوذْ إِ ثْمِيجَّا إِنُو‘.\f*
\v 7 ثكْسِي بِيلْهَا، ثَايَّا ن رَاحِيلْ، ثْوَاڒَا نّغْنِي س دّيْسثْ ؤُشَا ثُورُووْ-د إِ يَاعْقُوبْ أَحنْجِيرْ وِيسّْ ثْنَاينْ.
\v 8 ثنَّا رَاحِيلْ: ”س إِمنْغَانْ ن أَربِّي منْغغْ أَكْ-ذ ؤُتْشْمَا ؤُشَاغڒْبغْ.“ ثڭَّا أَسْ نَافْثَالِي.
\m 
\v 9 \add ؤُمِي\add* ثژْرَا لِييَا ثسّْبدّْ ثَارْوَا، ثكْسِي زِيلْپَا، ثَايَّا نّسْ، ثوْشَا إِ-ت إِ يَاعْقُوبْ ذ ثَامْغَارْثْ،
\v 10 ؤُشَا زِيلْپَا، ثَايَّا ن لِييَا، ثُورُووْ-د أَحنْجِيرْ إِ يَاعْقُوبْ.
\v 11 ثنَّا لِييَا: ”مَانَا ڒْخِيرْ-أَ!“ ؤُشَا ثڭَّا أَسْ جَاذْ.
\v 12 ؤُشَا ثُورُووْ-د زِيلْپَا، ثَايَّا ن لِييَا، أَحنْجِيرْ وِيسّْ ثْنَاينْ إِ يَاعْقُوبْ.
\v 13 ؤُشَا ثنَّا لِييَا: ”أَ سّعْذْ إِنُو!“، مِينْزِي ثِيبْڒِيغِينْ أَذْ أَيِي حسْبنْثْ ذ سّعْذْ!“ ؤُشَا ثڭَّا أَسْ أَشِيرْ.
\v 14 ذڭْ وُوسَّانْ ن ثْميْرَا ن إِرْذنْ إِفّغْ رُوبِينْ ؤُشَا يُوفَا ’ثِيثفَّاحِينْ ن ثَايْرِي‘ ذڭْ إِيَّارْ ؤُشَا نتَّا يِيوْيْ إِ-ثنْثْ إِ لِييَا، يمَّاسْ. \add خنِّي\add* ثنَّا رَاحِيلْ إِ لِييَا: ”تّْزَاوْڭغْ شمْ أَذْ أَيِي ثوْشذْ زِي ’تّفَّاحِينْ ن ثَايْرِي‘ ن مِّيمْ.“
\v 15 \add مَاشَا لِييَا\add* ثنَّا أَسْ: ”مَا وَارْ إِدْجِي ذْرُوسْ أَڒَامِي ثِيوْيذْ أَرْيَازْ إِنُو، ؤُمِي ثخْسذْ عَاوذْ أَذْ د-ثَاوْيذْ ’ثِيثفَّاحِينْ ن ثَايْرِي‘ ن مِّي؟“ ثنَّا رَاحِيلْ: ”س ؤُيَا أَذْ إِطّصْ أَكِيذمْ دْجِيڒثْ-أَ خْ ’تّفَّاحِينْ ن ثَايْرِي‘ ن مِّيمْ.“ \f ◼ \fr 30:‏15 \ft \bd ’ثَاثفَّاحْثْ‘\bd* - نِيغْ ’ثَاذْفُويِّيثْ‘.\f*
\v 16 \add ؤُمِي\add* د-إِعْقبْ يَاعْقُوبْ زڭْ إِيَّارْ س ثْمذِّيثْ، ثفّغْ-د لِييَا غَارسْ ثنَّا أَسْ: ”أَذْ خَافِي ثَاذْفذْ، مِينْزِي نِيشَانْ شْرِيغْ شكْ س ’تّفَّاحِينْ ن ثَايْرِي‘ ن مِّي.“ ؤُشَا \add أَمُّو إِ\add* إِطّصْ أَكِيذسْ دْجِيرثْ نِّي.
\v 17 إِسْڒَا أَربِّي إِ لِييَا ؤُشَا ثكْسِي س دّيْسثْ ؤُشَا ثُورُووْ-د أَحنْجِيرْ وِيسّْ خمْسَا إِ يَاعْقُوبْ.
\v 18 ثنَّا لِييَا: ”أَربِّي إِوْشَا أَيِي ڒْمُونثْ إِنُو خْ ؤُمِي وْشِيغْ ثَايَّا إِنُو إِ ورْيَازْ إِنُو!“ ؤُشَا ثڭَّا أَسْ إِسَّاكَارْ.
\v 19 ثكْسِي لِييَا عَاوذْ س دّيْسثْ ؤُشَا ثُورُووْ-د أَحنْجِيرْ وِيسّْ ستَّا إِ يَاعْقُوبْ.
\v 20 ؤُشَا ثنَّا لِييَا: ”أَربِّي إِوْشَا أَيِي إِشْثْ ن لْبَارَاكَا ثشْنَا. ڒخُّو أَذْ كِيذِي إِزْذغْ ورْيَازْ إِنُو، مِينْزِي ؤُرْوغْ أَسْ-د ستَّا ن إِحنْجِيرنْ.“ ؤُشَا ثڭَّا أَسْ زابُولُونْ.
\v 21 أَوَارْنِي أَسْ ثُورُووْ-د ثَاحنْجِيرْثْ. ثڭَّا أَسْ ذِينَا.
\m 
\v 22 \add خنِّي\add* إِذَارْ أَربِّي رَاحِيلْ ؤُشَا إِسْڒَا أَسْ أَربِّي ؤُشَا يَارْزمْ ڒمْڒَاوْڒثْ نّسْ.
\v 23 ثكْسِي س دّيْسثْ ؤُشَا ثُورُووْ-د أَحنْجِيرْ، ثنَّا: ”إِكّسْ أَربِّي ڒْحڭْرَا إِنُو!“
\v 24 ؤُشَا ثڭَّا أَسْ يُوسُوفْ، ثنَّا: ”أَذْ أَيِي يَارْنِي سِيذِي أَحنْجِيرْ نّغْنِي.“
\b
\s1 ڒْعَاحْذْ جَارْ يَاعْقُوبْ ذ لَابَانْ
\m 
\v 25 ڒَامِي د-ثُورُووْ رَاحِيلْ يُوسُوفْ، إِنَّا يَاعْقُوبْ إِ لَابَانْ: ”سكّْ أَيِي ؤُشَا أَذْ رَاحغْ غَارْ ذْشَارْ إِنُو ذ ثمُّورْثْ إِنُو.
\v 26 أوْشْ أَيِي ثِيمْغَارِينْ إِنُو ذ إِحنْجِيرنْ إِنُو مِينْ زِي غَاركْ خذْمغْ. \add خنِّي\add* أَذْ فّْغغْ. أَقَا شكْ ثسّْنذْ ڒْخذْمثْ إِ زِي ثُوغَا ذ أَشْ تّْسخَّارغْ.“
\v 27 إِنَّا أَسْ لَابَانْ: ”مْڒِي ؤُفِيغْ ڒخُّو أَرْضَا ذِي ثِيطَّاوِينْ نّشْ. أَقَا ژْرِيغْ س إِجّْ ن ڒعْجبْ بلِّي سِيذِي إِبَاركْ أَيِي ذِي طّْوعْ نّشْ.“
\v 28 \add يَارْنِي\add* إِنَّا: ”إِنِي أَيِي \add زعْمَا\add* مَانْ ڒْمُونثْ \add إِ ثخْسذْ\add*، ؤُشَا أَذْ أَشْ ت وْشغْ.“
\v 29 \add خنِّي\add* إِنَّا أَسْ: ”شكْ ثسّْنذْ مَامّشْ ذ أَشْ خذْمغْ ذ مَامّشْ ؤُيُورغْ أَكْ-ذ ڒبْهَايمْ نّشْ زڭْ وَامِي كِيشْ دْجِيغْ.
\v 30 مِينْزِي ذْرُوسْثْ إِ ثُوغَا غَاركْ \add ڒخْذنِّي\add* قْبڒْ إِ د-ؤُسِيغْ، أَقَا إِذْوڒْ ذڭْ وَاطَّاسْ، ؤُشَا إِبَاركْ إِ شكْ سِيذِي ذڭْ إِصُورَافْ إِنُو. \add خنِّي\add* ڒخُّو، مڒْمِي زمَّارغْ أَذْ خذْمغْ إِ ثَادَّارْثْ \add إِنُو\add*؟“
\v 31 إِنَّا أَسْ: ”مِينْ ذ أَشْ إِ غَا وْشغْ؟“ يَارَّا-د يَاعْقُوبْ: ”وَارْ ذ أَيِي تِّيشْ وَالُو، مَاشَا سَامْحْ أَيِي أَيَا \add وَاهَا\add*، \add خنِّي\add* أَذْ د-ذوْڒغْ أَذْ أَروْسغْ ؤُدْجِي نّشْ عَاوذْ ؤُشَا أَذْ ثنْ حْضِيغْ.
\v 32 أَسّْ-أَ أَذْ عْذُوغْ خْ مَارَّا \add ثَاحِيمَارْثْ ن\add* وُودْجِي نّشْ. أڭّْ شكْ خْ ؤُغزْذِيسْ زَّايسْ مَارَّا ؤُدْجِي إِبقّْضنْ ذ إِقَارْقَاشنْ، مَارَّا ؤُدْجِي أَبَارْشَانْ جَارْ إِحُوڒِييّنْ ذ مِينْ إِدْجَانْ ذ أَقَارْقَاشْ نِيغْ س إِبقِّيضنْ جَارْ إِغَايْضنْ. مَانْ أَيَا أَذْ يِيڒِي ذ ڒْمُونثْ إِنُو.
\v 33 خْمِي د غَا ثَاسذْ ذڭْ إِجّْ ن وَاسّْ ن يِيمَاڒْ مَاحنْسْ أَذْ ثْژَارذْ ڒْمُونثْ إِنُو، أَذْ ثْبَانْ ثْسڭْذَا إِنُو زَّاثْ إِ وُوذمْ نّشْ \add أَمُّو نِيشَانْ\add*: مِينْ وَارْ إِدْجِينْ إِبقّضْ نِيغْ مِينْ وَارْ إِدْجِينْ إِقَّارْقشْ جَارْ إِغَايْضنْ ذ مِينْ وَارْ إِدْجِينْ ذ أَبَارْشَانْ جَارْ إِحُوڒِييّنْ، أَقَا \add أَذْ إِتّْوَاحْسبْ\add* إِتّْوَاشَارْ جَارْ مِينْ إِدْجَانْ إِنُو.“
\v 34 \add خنِّي\add* إِنَّا لَابَانْ: ”خْزَارْ، أَقَا أَذْ يِيڒِي أَمْ مَامّشْ \add إِ ذ أَيِي\add* ثنِّيذْ!“
\m 
\v 35 ذڭْ وَاسّْ نِّي إِفَارْقْ إِوثْمَانْ ن إِغَايْضنْ إِشَارْضنْ ذ إِقَارْقَاشنْ ؤُڒَا ذ مَارَّا ثِيغَايْضْثِينْ إِبقّْضنْ ذ إِقَارْقَاشنْ، ذ مَارَّا إِنِّي ذِي ثدْجَا ثمْڒڒْ، ؤُڒَا ذ مَارَّا مِينْ إِدْجَانْ ذ أَبَارْشَانْ جَارْ إِحُوڒِييّنْ، ؤُشَا إِسَّارْسْ إِ-ثنْ ذڭْ ؤُفُوسْ ن إِحنْجِيرنْ نّسْ.
\v 36 \add خنِّي\add* إِڭَّا ثْڒَاثَا ن وُوسَّانْ ن وبْرِيذْ جَارْ إِخفْ نّسْ ذ يَاعْقُوبْ. ؤُشَا يَارْوسْ يَاعْقُوبْ ؤُدْجِي إِقِّيمنْ ن لَابَانْ.
\m 
\v 37 \add خنِّي\add* إِكْسِي يَاعْقُوبْ ثِيسضْوِينْ ن صّفْصَافْ ؤُ زِي ثْشجَّارْثْ ن دْجُوزْ ؤُ زِي ثْشجَّارْثْ ن ذُولْبْ. نتَّا إِقشَّارْ إِ-ثنْثْ ذ إِشطِّيضنْ ذ إِشمْڒَاڒنْ ؤُمِي إِعَارَّا خْ ؤُشمْڒَاڒْ ن ثْسضْوِينْ.
\v 38 إِسَّارْسْ ثِيسضْوِينْ-أَ إِقشَّارنْ قِيبَاتْشْ إِ وُودْجِي ذِي ثَارْيِيوِينْ ذ ڒقْوَاربْ مَانِي د-ؤُسِينْ وُودْجِي مَاحنْذْ أَذْ سْونْثْ ؤُشَا ذوْڒنْثْ تّْوحَّامنْثْ خْمِي د-ثَاسنْثْ أَذْ وَارْذنْثْ.
\v 39 \add خْمِي\add* إِ غَا إِوحّمْ وُودْجِي غَارْ ثْسضْوِينْ، ؤُرْونْثْ-إِ-د ثْغَارْطِينْ مِينْ إِشَارْضنْ ذ مِينْ إِبقّْضنْ ذ مِينْ إِقَارْقَاشنْ.
\v 40 \add خنِّي\add* ثُوغَا إِبطَّا يَاعْقُوبْ إِحُوڒِييّنْ ؤُشَا يَارَّا ؤُدْجِي س ؤُزدْجِيفْ نْسنْ غَارْ مِينْ إِشَارْضنْ ذ مِينْ إِدْجَانْ ذ أَبَارْشَانْ جَارْ وُودْجِي ن لَابَانْ. ؤُشَا إِڭَّا ثِيحِيمْرِيوِينْ نّسْ غَارْ ؤُغزْذِيسْ، وَارْ ثنْثْ إِڭِّي أَكْ-ذ وُودْجِي ن لَابَانْ.
\v 41 كُوڒْ أَمُوڒْ خْمِي تّْوحَّامنْثْ ثِينِّي إِجهْذنْ زڭْ وُودْجِي، إِتّڭّْ يَاعْقُوبْ ثِيسضْوِينْ قِيبَاتْشْ إِ وُودْجِي ذِي ثَارْيِيوِينْ، حِيمَا أَذْ وحّْمنْثْ غَارْ ثْسضْوِينْ. \f ◼ \fr 30:‏41 \ft \bd ’قِيبَاتْشْ إِ وُودْجِي‘\bd* - س ثْعِيبْرَانِيثْ ’قِيبَاتْشْ إِ ثِيطَّاوِينْ ن وُودْجِي‘.\f*
\v 42 \add مَاشَا\add* وَارْ ثنْثْ إِسَّارْسْ شَا أَكْ-ذ ثنِّي إِضعْفنْ جَارْ وُودْجِي. أَمُّو ثُوغَا ثِينِّي إِضعْفنْ إِ لَابَانْ ؤُ ثِينِّي إِجهْذنْ إِ يَاعْقُوبْ.
\v 43 ؤُشَا إِمْغَارْ \add وَاڭْڒَا\add* ن ورْيَازْ-أَ بْڒَا قطُّو. ثُوغَا غَارسْ أَطَّاسْ ن وُودْجِي ذ ثِييَّا ذ إِسمْغَانْ ذ إِڒغْمَانْ ذ يغْيَاڒْ.
\b
\b
\c 31
\s1 ثَاروْڒَا ن يَاعْقُوبْ زِي لَابَانْ
\m 
\v 1 ؤُشَا إِسْڒَا \add يَاعْقُوبْ\add* أَوَاڒنْ ن إِحنْجِيرنْ ن لَابَانْ، نَّانْ: ”يَاعْقُوبْ إِكْسِي مَارَّا مِينْ ثُوغَا ن بَابَاثْنغْ ؤُ س مِينْ ثُوغَا ن بَابَاثْنغْ أَقَا إِكْسبْ مَارَّا أَعُودْجِي-يَا.“ \f ◼ \fr 31:‏1 \ft \bd ’أَعُودْجِي‘\bd* - نِيغْ ’ڒْْعزّْ‘.\f*
\v 2 إِخْزَارْ يَاعْقُوبْ غَارْ ؤُغمْبُوبْ ن لَابَانْ. خْزَارْ، وَارْ كِيذسْ إِدْجِي أَمْ إِضنَّاضْ ذ فَارِيضنَّاضْ.
\v 3 إِنَّا سِيذِي إِ يَاعْقُوبْ: ”ذْوڒْ غَارْ ثمُّورْثْ ن ڒجْذُوذْ نّشْ ؤُ غَارْ ڒَادْجْ نّشْ. أَقَا نشّْ أَذْ إِڒِيغْ أَكِيذكْ.“
\v 4 إِسكّْ يَاعْقُوبْ ؤُشَا إِڒَاغَا-د خْ رَاحِيلْ ذ لِييَا غَارْ ييَّارْ، غَارْ وُودْجِي نّسْ.
\v 5 إِنَّا أَسنْثْ: ”تّْوَاڒِيغْ بلِّي أَغمْبُوبْ ن بَابَاثْكنْثْ وَارْ كِيذِي إِدْجِي أَمْ إِضنَّاضْ ذ فَارِيضنَّاضْ. \add مَاشَا\add* أَربِّي ن ڒجْذُوذْ إِنُو أَقَا-ث أَكِيذِي.
\v 6 كنِّينْثْ ثسّْننْثْ بلِّي أَقَا خذْمغْ إِ بَابَاثْكنْثْ س مَارَّا مِينْ غَارِي ذ جّهْذْ.
\v 7 \add مَاشَا\add* بَابَاثْكنْثْ إِغشّْ أَيِي، إِبدّڒْ ڒْمُونثْ إِنُوعشْرَا ن ثْوَاڒَاوِينْ، \add مَاشَا\add* أَربِّي وَارْ ذ أَسْ إِسمّحْ حِيمَا أَذْ أَيِي إِڭّْ ڒْغَارْ.
\v 8 مَاڒَا نتَّا إِنَّا: ’إِبقِّيضنْ أَذْ إِڒِينْ ذ ڒْمُونثْ نّشْ!‘، ڒخْذنِّي مَارَّا ؤُدْجِي ؤُرْونْثْ-إِ-د \add ؤُدْجِي\add* س إِبقِّيضنْ، مَاڒَا إِنَّا: ’إِنِّي س إِشَارِيضنْ أَذْ إِڒِينْ ذ ڒْمُونثْ نّشْ!‘، ڒخْذنِّي مَارَّا ؤُدْجِي ؤُرْونْثْ-إِ-د \add ؤُدْجِي\add* س إِشَارِيضنْ.
\v 9 \add أَمُّو\add* إِكّسْ أَربِّي ڒبْهَايمْ ن بَابَاثْكنْثْ ؤُشَا إِوْشَا أَيِي \add ثنْثْ\add* إِ نشّْ.
\v 10 إِمْسَارْ غَارْ ڒْوقْثْ ؤُمِي وحّْمنْثْ ؤُدْجِي، سّْڭعّْذغْ ثَامُوغْڒِي إِنُو ؤُشَا ژْرِيغْ ذِي ثَارْجِيثْ، أَقَا ذَا إِغَايْضنْ نِّي إِنڭّْزنْ خْ وُودْجِي، ثُوغَا أَثنْ س إِشَارِيضنْ ذ إِبقِّيضنْ ذ إِقَارْقَاشنْ.
\v 11 إِنَّا أَيِي لْمَالَاكْ ن أَربِّي ذِي ثَارْجِيثْ ’يَاعْقُوبْ!‘ نشّْ نِّيغْ ’أَقَا أَيِي ذَا!‘
\v 12 إِنَّا: ’نْضَارْ ثِيطَّاوِينْ نّشْ، خْزَارْ، مَارَّا إِغَايْضنْ، إِنِّي إِنڭّْزنْ خْ وُودْجِي، أَقَا أَثنْ س إِشَارِيضنْ ذ إِبقِّيضنْ ذ إِقَارْقَاشنْ، مِينْزِي نشّْ ژْرِيغْ مَارَّا مِينْ ذ أَشْ إِتّڭّْ لَابَانْ.
\v 13 نشّْ ذ أَربِّي ن بَايْثْ-إِلْ، مَانِي ثْذهْنذْ أَژْرُو ن ڒِيذَارثْ ؤُ مَانِي ذ أَيِي ثوْشِيذْ أَوَاڒْ. كَّارْ ڒخُّو، فّغْ زِي ثمُّورْثْ-أَ، عْقبْ غَارْ ثمُّورْثْ مَانِي ثْخڒْقذْ.‘ “ \x ◘ \xo 31:‏13 \xt أَمز. 28‏:‏13، 14، 15. \x*
\v 14 \add خنِّي\add* أَرِّينْثْ-إِ-د رَاحِيلْ ذ لِييَا، نَّانْثْ أَسْ: ”مَا ذِينْ عَاذْ شَا ن ثسْغَارْثْ نِيغْ إِشْثْ ن ڒْوَارْثْ إِ نشِّينْ ذِي ثَادَّارْثْ ن بَابَاثْنغْ؟
\v 15 مَا وَارْ نتّْوِيحْسِيبْ أَمْ ثْبَارَّانِييِّينْ؟ أَقَا نتَّا إِزّنْزْ أَنغْ ؤُ نتَّا أَقَا إِقطَّا مَارَّا نُّوقَارْثْ نّغْ.
\v 16 مِينْزِي مَارَّا أَڭْڒَا نِّي إِكّسْ أَربِّي إِ بَابَاثْنغْ، نّغْ إِ إِدْجَا ؤُ ن إِحنْجِيرنْ نّغْ. ڒخُّو \add عَاذْ\add*، أڭّْ مَارَّا مِينْ ذ أَشْ إِنَّا أَربِّي.“
\m 
\v 17 \add خنِّي\add* إِكَّارْ يَاعْقُوبْ ؤُشَا إِسّْڭعّذْ إِحنْجِيرنْ نّسْ ذ ثمْغَارِينْ نّسْ خْ إِڒغْمَانْ.
\v 18 إِڭَّا ذڭْ وبْرِيذْ مَارَّا ڒبْهَايمْ نّسْ ذ مَارَّا أَڭْڒَا نّسْ نِّي د-إِكْسبْ، أَقَا ڒبْهَايمْ نِّي إِطّفْ، إِنِّي د-إِكْسبْ ذِي فَاذَانْ-أَرَامْ، حِيمَا أَذْ د-إِعْقبْ غَارْ إِسْحَاقْ، بَابَاسْ، ذِي ثمُّورْثْ ن كنْعَانْ.
\v 19 ؤُمِي إِرُوحْ لَابَانْ غَارْ ثِيڒْسَا ن وُودْجِي نّسْ، ثُوشَارْ رَاحِيلْ ڒخْيَاڒَاثْ ثِيمژْيَانِينْ ن لْ-أَصْنَامْ ن بَابَاسْ.
\v 20 يَاعْقُوبْ إِخْذعْ لَابَانْ، أَرَامِييُو، ڒَامِي وَارْ ذ أَسْ إِعْڒِيمْ أَقَا أَذْ يَارْوڒْ.
\v 21 يَارْوڒْ س مَارَّا مِينْ غَارسْ. إِكَّارْ، إِژْوَا إِغْزَارْ \add ن لْفُورَاطْ\add* ؤُشَا يَارَّا أَزدْجِيفْ نّسْ غَارْ إِذُورَارْ ن جِيلْعَاذْ. \f ◼ \fr 31:‏21 \ft \bd ’جِيلْعَاذْ‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’ثَاوْرِيرْثْ ن شّْهَاذثْ‘.\f*
\m 
\v 22 ذڭْ وَاسّْ وِيسّْ ثْڒَاثَا خبَّارنْ لَابَانْ، أَقَا يَارْوڒْ يَاعْقُوبْ.
\v 23 \add خنِّي\add* يِيوِي أَيْثْمَاسْ أَكِيذسْ، إِرُوحْ أَوَارْنِي أَسْ ثِيشْڒِي ن سبْعَا ن وُوسَّانْ، إِخشّْ خَاسْ ذڭْ إِذُورَارْ ن جِيلْعَاذْ.
\v 24 ؤُشَا يُوسَا-د أَربِّي غَارْ لَابَانْ، أَرَامِييُو، ذِي ثَارْجِيثْ ذِي دْجِيرثْ، إِنَّا أَسْ: ”غَاركْ أَذْ ثسِّيوْڒذْ س ڒْخَارْ نِيغْ س ڒْغَارْ أَكْ-ذ يَاعْقُوبْ.“
\v 25 إِرحّڭْ خنِّي لَابَانْ خْ يَاعْقُوبْ. يَاعْقُوبْ ثُوغَا إِوْثَا أَقِيضُونْ نّسْ ذڭْ إِذُورَارْ. لَابَانْ عَاوذْ إِوْثَا إِقِيضَانْ نّسْ أَكْ-ذ أَيْثْمَاسْ ذڭْ إِذُورَارْ ن جِيلْعَاذْ.
\v 26 \add خنِّي\add* إِنَّا لَابَانْ إِ يَاعْقُوبْ: ”مِينْ ثڭِّيذْ، ثژْوِيذْ أَيِي ؤُڒْ ؤُشَا ثِيوْيِيذْ-د يسِّي أَمْ ثْمحْبَاسْ ن ڭَارَّا؟
\v 27 مَايمِّي ثَاروْڒذْ س ثْنُوفّْرَا ؤُ ثُوشَارذْ أَيِي ؤُ \add مَايمِّي\add* وَارْ ذ أَيِي ثْخبَّارذْ، حِيمَا أَذْ شكْ سّْقبّْضغْ س ڒفْرَاحثْ، س ڒغْنُوجْ، س ؤُبنْذِيرْ ؤُ س ڒْڭَامْبْرِي؟
\v 28 وَارْ ذ أَيِي ثجِّيذْ أَذْ سُّوذْمغْ إِحنْجِيرنْ إِنُو ذ ثْحنْجِيرِينْ إِنُو. ڒخُّو ذ ثُوبُّوهڒْيَا إِ ثڭِّيذْ.
\v 29 غَارِي ثِيزمَّارْ ذڭْ إِفَاسّنْ إِنُو، حِيمَا أَذْ شكْ ضَارّغْ، \add مَاشَا\add* أَربِّي ن بَابَاثْومْ إِسِّيوڒْ أَكِيذِي دْجِيرثْ-أَ، إِنَّا: ’غَاركْ أَذْ ثسِّيوْڒذْ س ڒْخَارْ نِيغْ س ڒْغَارْ أَكْ-ذ يَاعْقُوبْ.‘
\v 30 ؤُشَا ڒخُّو ثُويُورذْ، ؤُمِي زعْمَا ثْوحّْشذْ ثَادَّارْثْ ن بَابَاشْ. \add مَاشَا\add* مَاغَارْ إِ ذ أَيِي ثُوشَارذْ إِربِّيثنْ إِنُو؟“
\v 31 يَارَّا-د يَاعْقُوبْ، إِنَّا إِ لَابَانْ: ”مِينْزِي ثُوغَا ڭّْوذغْ، نِّيغْ \add أَكْ-ذ يِيخفْ إِنُو\add* أَذْ ثَاغْ أَذْ أَيِي ثكّْسذْ يسِّيشْ س ؤُغِيڒْ!
\v 32 غَارْ ونِّي إِ غَا ثَافذْ لْ-أَصْنَامْ نّشْ، أجّْ إِ-ث وَارْ إِدَّارْ \add عَاذْ\add*! قِيبَاتْشْ إِ وَاوْمَاثنْ نّغْ أَذْ ثْميّْزذْ مِينْ إِدْجَانْ نّشْ جَارْ مِينْ إِدْجَانْ غَارِي ؤُشَا أَوْيِي ث أَكِيذكْ.“ \add مَاغَارْ\add* يَاعْقُوبْ وَارْ إِسِّينْ بلِّي رَاحِيلْ إِ ثنْ يُوشَارنْ.
\m 
\v 33 ؤُشَا يُوذفْ لَابَانْ غَارْ ؤُقِيضُونْ ن يَاعْقُوبْ، غَارْ ؤُقِيضُونْ ن لِييَا، غَارْ ؤُقِيضُونْ ن ثْنَاينْ ن ثِييَّا ؤُشَا وَارْ يُوفِي وَالُو. \add ڒَْامِي\add* د-إِفّغْ زڭْ ؤُقِيضُونْ ن لِييَا، يُوذفْ غَارْ ؤُقِيضُونْ ن رَاحِيلْ.
\v 34 \add مَاشَا\add* ثكْسِي رَاحِيلْ ڒخْيَاڒَاثْ ثِيمژْيَانِينْ ن لْ-أَصْنَامْ، ثڭَّا إِ-ثنْثْ ذڭْ إِغَايْننْ ن وڒْغمْ ؤُشَا ثقِّيمْ خَاسنْ. يَارْزُو لَابَانْ ذڭْ ؤُقِيضُونْ أَمْ إِكْمڒْ، مَاشَا وَارْ يُوفِي وَالُو.
\v 35 ثنَّا إِ بَابَاسْ: ”وَارْ إِتِّيڒِي أَيَا ذ ڒْغَارْ ذِي ثِيطَّاوِينْ ن سِيذِي إِنُو، مِينْزِي وَارْ زمَّارغْ أَذْ كَّارغْ قِيبَاتْشْ نّشْ، مَاغَارْ أَقَا أَيِي س ثْنَامِيثْ ن ثمْغَارِينْ.“ ؤُشَا يَارْزُو، مَاشَا وَارْ يُوفِي ڒخْيَاڒَاثْ ثِيمژْيَانِينْ ن لْ-أَصْنَامْ.
\v 36 \add خنِّي\add* إِخيّقْ يَاعْقُوبْ ؤُشَا إِمْشُوبّشْ أَكْ-ذ لَابَانْ. يَاعْقُوبْ إِطّفْ ذڭْ وَاوَاڒْ، إِنَّا إِ لَابَانْ: ”مَانِي إِدْجَا ؤُخطُّو إِنُو؟ مَانْ ونْ إِدْجَانْ ذ دّنْبْ إِنُو، ؤُمِي ذ أَيِي د-ثضْفَارذْ س زّْعَافْ؟
\v 37 شكْ ثْبقْشذْ مَارَّا ڒْقشّْ إِنُو. مِينْ ثُوفِيذْ زِي مَارَّا ڒحْوَايجْ ن ثَادَّارْثْ نّشْ؟ أڭّْ إِ-ث ذَا زَّاثْ ن يَايْثْمَا ذ أَيْثْمَاشْ ؤُشَا أجّْ إِ-ثنْ أَذْ حكْمنْ جَارْ أَنغْ س ثْنَاينْ.
\v 38 عِيشْرِينْ ن إِسڭّْوُوسَا إِ كِيكْ كِّيغْ. ثِيخسْوِينْ نّشْ ذ ثْغَايْضِينْ نّشْعمَّارْصْ سُّوثْمنْثْ نِيغْعمَّارْصْ شِّيغْ إِشَارِّيينْ ن وُودْجِي نّشْ.
\v 39 وَارْ ذ أَشْ إِوْيغْ مِينْ إِتّْوَامزّْقنْ، \add مَاشَا\add* خطْصغْ ث سِيمَانْثْ إِنُو. مِينْ إِتّْوَاشَارنْ زَّايِي ذڭْ وَاسّْ نِيغْ ذِي دْجِيرثْ، أَقَا زڭْ إِفَاسّنْ إِنُو ثتَّارذْ ث.
\v 40 س ؤُزِيڒْ إِتّتّْ أَيِي ڒحْمُو يُوژْغنْ \add ثِيڒْمشْثْ\add* ؤُ س دْجِيرثْ تّجْمِيذغْ \add زِي سْقِيعْ\add*، \add أَڒَامِي\add* يَارْوڒْ إِضصْ زِي غَارِي.
\v 41 أَمُّو إِ ذ أَيِي ثُوغَا ذِي ثَادَّارْثْ نّشْ عِيشْرِينْ ن إِسڭّْوُوسَا. خذْمغْ غَاركْ أَرْبعْطَاشْ ن إِسڭّْوُوسَا خْ ثْنَاينْ ن يسِّيشْ ذ ستَّا ن إِسڭّْوُوسَا خْ وُودْجِي ؤُشَا ثْبدّْڒذْ ڒْمُونثْ إِنُوعشْرَا ن ثْوَاڒَاوِينْ.
\v 42 مَاڒَا أَربِّي ن بَابَا، أَربِّي ن إِبْرَاهِيمْ ذ ثِيڭّْوُوذِي ن إِسْحَاقْ، إِڒِي وَارْ كِيذِي إِدْجِي، ذ صّحْ إِڒِي أَذْ أَيِي ثسّْقَاذذْ ڒخُّو س إِفَاسّنْ خْوَانْ! إِژْرَا أَربِّي ثَامَارَا ذ ثُومَارْ ن إِفَاسّنْ إِنُو ؤُشَا إِذقْمَارْ إِ شكْ دْجِيڒثْ ن إِضنَّاضْ.“
\m 
\v 43 يَارَّا-د لَابَانْ ؤُشَا إِنَّا إِ يَاعْقُوبْ: ”ثِيحنْجِيرِينْ-أَ ذ يسِّي ؤُ إِحنْجِيرنْ-أَ ذ إِحنْجِيرنْ إِنُو، ؤُ ؤُدْجِي-يَا ذ ؤُدْجِي إِنُو، ؤُ مَارَّا مِينْ ثتّْوَاڒِيذْ أَقَا إِنُو. مِينْ زمَّارغْ خنِّي أَذْ ڭّغْ ڒخُّو س يسِّي نِيغْ س إِحنْجِيرنْ نْسنْثْ نِّي ؤُرْونْثْ؟
\v 44 غَاورْ عَاذْ ڒخُّو، أَذْ نڭّْ إِجّْ ن ڒْعَاهْذْ، نشّْ ذ شكْ، أَذْ يِيڒِي نتَّا ذ شّْهَاذثْ جَارْ أَيِي ذ شكْ!“
\v 45 ؤُشَا إِكْسِي يَاعْقُوبْ أَژْرُو، إِسّْڭعّذْ إِ-ث أَمْ وژْرُو ن ڒِيذَارثْ.
\v 46 ؤُشَا إِنَّا يَاعْقُوبْ إِ يَايْثْمَاسْ: ”سْمُونمْ إِژْرَا!“ كْسِينْ إِژْرَا ؤُشَا ڭِّينْ ثَاعُورِّيشْثْ ؤُشَا شِّينْ ذِينْ خْ ثْعُورِّيشْثْ نِّي.
\v 47 ؤُشَا إِڭَّا لَابَانْ \add إِ ؤُعُورِّيشْ ن إِژْرَا نِّي\add* ’جِيڭَارْ-سَاهَاذُوثَا‘، مَاشَا يَاعْقُوبْ إِڭَّا أَسْ ’جِيلْعَاذْ‘.
\v 48 \add خنِّي\add* إِنَّا لَابَانْ: ”ثَاعُورِّيشْثْ-أَ أَذْ ثِيڒِي ذ شّْهَاذثْ أَسّْ-أَ جَارْ أَيِي ذ شكْ!“ خْ ؤُيَا ثڭَّا أَسْ جِيلْعَاذْ
\v 49 ذ مِيصْفَا، مِينْزِي نتَّا إِنَّا: ”إِڒِي سِيذِي أَذْ إِحْضَا جَارْ أَيِي ذ شكْ، خْمِي غَا نِيڒِي أَمْ ننُوفَّارْ إِجّنْ زڭْ ونّغْنِي. \f ◼ \fr 31:‏49 \ft \bd ’مِيصْفَا‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’لْپُورْجْ إِ ؤُحتُّو‘.\f*
\v 50 مَاڒَا ثسّحْقَارذْ يسِّي نِيغْ أَذْ ثْمڒْشذْ ثِيمْغَارِينْ نّغْنِي خْ يسِّي، \add أَمْ\add* وَارْ ذِينْ إِدْجِي حذْ أَكِيذْنغْ \add حِيمَا أَذْ يِيڒِي ذ أَشهَّاذْ\add*، أَقَا أَربِّي أَذْ يِيڒِي ذ أَشهَّاذْ جَارْ أَيِي ذ شكْ!“
\v 51 إِنَّا عَاوذْ لَابَانْ إِ يَاعْقُوبْ: ”خْزَارْ، ثَاعُورِّيشْثْ-أَ \add ن يژْرَا\add*، خْزَارْ، أَژْرُو ن ڒِيذَارثْ نِّي سّْبدّغْ جَارْ أَيِي ذ شكْ.
\v 52 ثَاعُورِّيشْثْ-أَ \add ن يژْرَا\add* ذ وژْرُو-يَا ن ڒِيذَارثْ أَذْ شهْذنْ بلِّي نشّْ وَارْ غَاركْ د-ژكّْوِيغْ شَا خْ ثْعُورِّيشْثْ-أَ ؤُشَا ؤُڒَا ذ شكْ وَارْ غَارِي د-ثْژكّْوِّيذْ شَا إِ ڒْغَارْ خْ ثْعُورِّيشْثْ-أَ ؤُڒَا خْ وژْرُو-يَا ن ڒِيذَارثْ!
\v 53 أَربِّي ن إِبْرَاهِيمْ ذ أَربِّي ن نَاحُورْ، أَقَا أَربِّي ن بَابَاثْسنْ، أجّْ إِ-ث أَذْ إِحْكمْ جَارْ أَنغْ!“ \add مَاشَا\add* يَاعْقُوبْ إِجُّودْجْ س ’ثِيڭّْوُوذِي ن إِسْحَاقْ بَابَاسْ‘.
\v 54 \add خنِّي\add* إِغَارْصْ يَاعْقُوبْ إِ يِيشْثْ ن ثْغَارْصْثْ ذڭْ إِذُورَارْ ؤُشَا إِڒَاغَا إِ يَايْثْمَاسْ أَذْ شّنْ أَغْرُومْ. ؤُشَا شِّينْ أَغْرُومْ، سنْسّنْ دْجِيرثْ نِّي ذڭْ إِذُورَارْ.
\b
\b
\c 32
\s1 أَسْڒَاحْ جَارْ يَاعْقُوبْ ذ عِيسُو
\m 
\v 1 إِكَّارْ لَابَانْ غَارْ ثُوفُّوثْ ن صّْبحْ، إِسُّوذمْ إِحنْجِيرنْ نّسْ ذ يسِّيسْ، إِبَارْكْ إِ-ثنْ. \add خنِّي\add* إِرُوحْ لَابَانْ، إِعْقبْ غَارْ ومْشَانْ نّسْ.
\v 2 ؤُشَا إِطّفْ يَاعْقُوبْ عَاوذْ أَبْرِيذْ نّسْ ؤُشَا ؤُسِينْثْ-إِ-د لْمَالَاكَاثْ ن أَربِّي، ڒْقَانْثْ ث-إِ-د. \x ◘ \xo 32:‏2 \xt أَمز. 48‏:‏16. \x*
\v 3 إِنَّا يَاعْقُوبْ ؤُمِي ثنْ إِژْرَا: ”ڒْمَارْڭحْ ن ڒْعسْكَارْ ن أَربِّي ذ وَا!“، ؤُشَا إِڒَاغَا إِسمْ ن ومْشَانْ نِّي مَاحَانَايِيمْ.
\v 4 إِسّكّْ يَاعْقُوبْ إِرقَّاسنْ غَارْ زَّاثْ، غَارْ عِيسُو ؤُمَاسْ غَارْ ثمُّورْثْ ن سَاعِيرْ، أَقَا-ت ذ جِّيهثْ ن إِذُومْ.
\v 5 ؤُشَا إِوصَّا إِ-ثنْ، إِنَّا أَسنْ: ”أَمُّو إِ غَا ثِينِيمْ إِ سِيذِي إِنُو عِيسُو: ’أَمُّو إِ إِقَّارْ ؤُمْسخَّارْ نّشْ يَاعْقُوبْ: ثُوغَا زدّْغغْ أَكْ-ذ لَابَانْ أَمْ ؤُبَارَّانِي ؤُشَا قِّيمغْ ذِينْ أَڒْ إِ ڒخُّو.
\v 6 غَارِي إِفُونَاسنْ ذ يغْيَاڒْ ذ وُودْجِي ذ إِسمْغَانْ ذ ثِييَّا ؤُشَا سّكّغْ \add إِرقَّاسنْ\add*، مَاحنْذْ أَذْ \add ث\add* إِنِيغْ إِ سِيذِي إِنُو، مَاحنْذْ أَذْ أَفغْ أَرْضَا ذِي ثِيطَّاوِينْ نّشْ.‘ “
\m 
\v 7 إِرقَّاسنْ ذوْڒنْ-د غَارْ يَاعْقُوبْ، نَّانْ: ”نْرُوحْ غَارْ ؤُمَاشْ عِيسُو، ؤُ نتَّا عَاوذْ يُوسَا-د أَذْ شكْ إِڒْقَا ؤُ أَقَا ذِينْ أَربْعَا-مْيَا ن يرْيَازنْ أَكِيذسْ.“
\v 8 \add خنِّي\add* يَاعْقُوبْ ثُوذفْ إِ-ث ثِيڭّْوُوذِي ثمْغَارْ ؤُشَا إِسّْقنْضْ إِ-ث ڒْحَاڒْ. نتَّا إِبْضَا إِوْذَانْ، إِنِّي أَكِيذسْ ذ وُودْجِي ذ إِفُونَاسنْ ذ ثْفُونَاسِينْ ذ إِڒغْمَانْ خْ ثْنَاينْ ن ڒمْرَاڭحْ ن ڒْعسْكَارْ.
\v 9 إِنَّا: ”مَاڒَا يُوسَا-د عِيسُو غَارْ إِجّْ ن ڒْمَارْڭحْ ن ڒْعسْكَارْ، أَذْ خَاسْ إِغْڒبْ، \add خنِّي\add* أَذْ يَارْوڒْ ڒْمَارْڭحْ ن ڒْعسْكَارْ إِ إِقِّيمنْ.“
\v 10 ؤُشَا إِنَّا يَاعْقُوبْ: ”\add أَ\add* أَربِّي ن بَابَا إِبْرَاهِيمْ ذ أَربِّي ن بَابَا إِسْحَاقْ، \add أَ\add* سِيذِي، \add شكْ\add* ونِّي ذ أَيِي إِنَّانْ: ’ذْوڒْ غَارْ ثمُّورْثْ نّشْ ذ رَادْجْ نّشْ ؤُشَا نشّْ أَذْ أَشْ ڭّغْ مِينْ إِشْنَانْ!‘ \x ◘ \xo 32:‏10 \xt أَمز. 31‏:‏13. \x*
\v 11 أَقَا أَيِي قلّْ خْ مَارَّا ثِيمڭَّا ن ثْمخْسِيوْثْ إِشوَّارنْ ذ مَارَّا ڒَامَانْ إِ ثسّشْنذْ إِ ؤُمْسخَّارْ نّشْ، مِينْزِي ژْوِيغْ لْ-ؤُرْذُونْ س ثغَّارْشْثْ إِنُو \add ڒَامِي د-فّْغغْ\add* ؤُشَا ڒخُّو ذوْڒغْ-د ذ ثْنَاينْ ن ڒمْرَاڭحْ ن ڒْعسْكَارْ.
\v 12 فكّْ أَيِي ڒخُّو زڭْ ؤُفُوسْ ن عِيسُو ؤُمَا، مِينْزِي تّڭّْوذغْ بَالَاكْ أَذْ د-يَاسْ ؤُشَا أَذْ إِنغْ ؤُڒَا ذ ثِييمَّاثِينْ أَكْ-ذ إِحنْجِيرنْ!
\v 13 ؤُشَا شكْ ثنِّيذْ: ’نشّْ أَذْ كِيكْ ڭّغْ مْلِيحْ، أَذْ ڭّغْ زَّارِيعثْ نّشْ أَمْ يِيجْذِي ن ڒبْحَارْ إِ وَارْ إِزمَّارْ أَذْ إِتّْوَاحْسبْ زِي سِّيبّثْ ن ؤُبَارُّو نّسْ!‘ “ \x ◘ \xo 32:‏13 \xt أَمز. 28‏:‏13. \x*
\m 
\v 14 إِسّنْسْ ذِينْ دْجِيڒثْ نِّي ؤُشَا إِكْسِي زِي مِينْ د-يُوسِينْ ذڭْ إِفَاسّنْ نّسْ ذ أَڭْڒَا، مَاحنْذْ أَذْ ث يوْشْ ذ أَرِّيغَالُو إِ ؤُمَاسْ عِيسُو:
\v 15 مِيثَاينْ ن ثْغَايْضِينْ ذ عِيشْرِينْ ن إِمُويَانْ ذ مِيثَاينْ ن ثْخسْوِينْ ذ عِيشْرِينْ ن إِشَارِّييّنْ
\v 16 ذ ثْڒَاثِينْ ن ثْڒغْمِينْ إِسُّوطُّوضنْ أَكْ-ذ ثَارْوَا نْسنْثْ، أَربْعِينْ ن ثْفُونَاسِينْ ثِيمژْيَانِينْ،عشْرَا ن إِفُونَاسنْ إِمژْيَاننْ ذ عِيشْرِينْ ن ثغْيَاڒْ ذعشْرَا ن يغْيَاڒْ إِمژْيَانِينْ.
\v 17 إِسّعْذُو ثنْ غَارْ إِفَاسّنْ ن إِمْسخَّارنْ نّسْ، كُوڒْ ثَاحِيمَارْثْ وحّْذسْ، ؤُشَا إِنَّا إِ إِمْسخَّارنْ نّسْ: ”عْذُومْ كنِّيوْ \add ڒخُّو\add* زَّاثْ إِنُو، ڭّمْ تَّاسِيعْ جَارْ ثْحِيمَارْثْ ذ ثْحِيمَارْثْ.“
\v 18 \add خنِّي\add* يُومُورْ ؤُمزْوَارْ، إِنَّا أَسْ: ”مَاڒَا يُوسَا-د عِيسُو إِ ؤُمْسَاڭَارْ أَكِيذكْ ؤُشَا إِسّقْسَا أَشْ، إِنَّا: ’وِي شكْ يِيڒَانْ ذ مَانِي غَا ثْرَاحذْ؟‘ ؤُ ’ؤُمِي ثِينَا إِ إِدْجَانْ زَّاثكْ؟‘،
\v 19 \add ڒخْذنِّي\add* أَذْ ثِينِيذْ: ’ذ أَرِّيغَالُو إِ يدْجَا ن ؤُمْسخَّارْ نّشْ يَاعْقُوبْ، ونِّي د-إِسّكّْ إِ سِيذِي إِنُو عِيسُو. خْزَارْ، نتَّا عَاوذْ \add يُوسَا-د\add* أَوَارْنِي \add أَنغْ\add*!‘ “
\v 20 يُومُورْ عَاوذْ ونِّي وِيسّْ ثْنَاينْ ذ وِيسّْ ثْڒَاثَا إِنِّي إِڭُّورنْ أَوَارْنِي إِ ثْحِيمْرِيوِينْ، إِنَّا: ”سِيوْڒمْ أَوَاڒنْ-أَ ذ إِجّنْ أَكْ-ذ عِيسُو، خْمِي ث غَا ثڒْقَامْ.
\v 21 كنِّيوْ عَاوذْ أَذْ ثِينِيمْ: ’خْزَارْ، أَمْسخَّارْ نّشْ يَاعْقُوبْ يُوسَا-د أَوَارْنِي أَنغْ!‘ “ مِينْزِي إِنَّا: ”أَذْ ث سَّاريّْحغْ س أَرِّيغَالُو-يَا إِ د-يُوسِينْ زَّاثْ إِنُو. خنِّي أَوَارْنِي مَانْ أَيَا أَذْ ژَترغْ أَغمْبُوبْ نّسْ، بَالَاكْ أَذْ إِقْبڒْ أَغمْبُوبْ إِنُو \add زَّاثسْ\add*.“
\v 22 \add أَمُّو\add* إِ إِسِّيزَّارْ أَرِّيغَالُو زَّاثسْ غَارْ ؤُجمَّاضْ أَمْ إِسّنْسْ نتَّا دْجِيرثْ نِّي ذِي ڒْمَارْڭحْ ن ڒْعسْكَارْ.
\m 
\v 23 إِكَّارْ دْجِيڒثْ نِّي ؤُشَا إِكْسِي ثْنَاينْ ن ثمْغَارِينْ نّسْ ذ ثْنَاينْ ن ثِييَّا نّسْ ذ حِيطَاشْ ن إِحنْجِيرنْ نّسْ، إِژْوَا أَمْشَانْ ن ؤُژكّْوُو ن \add يغْزَارْ ن\add* يَابُّوقْ.
\v 24 يِيوْيِي إِ-ثنْ ؤُشَا إِسّژْوَا ثنْ إِ ثغْزُورْثْ ؤُ \add مَارَّا\add* مِينْ غَارسْ إِسّعْذُو ث غَارْ ؤُجمَّاضْ.
\m 
\v 25 \add مَاشَا\add* إِقِّيمْ يَاعْقُوبْ وحّْذسْ ؤُ نتَّا إِمُّوغْزڒْ أَكْ-ذ إِجّْ ن ورْيَازْ أَڒْمِي ذ ثُوفُّوثْ ن ڒفْجَارْ.
\v 26 \add ؤُمِي\add* إِژْرَا وَانِيثَا أَقَا وَارْ خَاسْ إِقدّْ شَا، إِحَاذَا ث غَارْ ومْشَانْ ن ثمْقِيقّشْثْ ن ثْمصَّاضْثْ نّسْ، مَاحنْذْ أَذْ د-ثنْخُوخرْ ثَامْقِيقّشْثْ ن ثْمصَّاضْثْ ن يَاعْقُوبْ ؤُمِي كِيذسْ ثُوغَا إِتّْمُوغْزُوڒْ.
\v 27 إِنَّا: ”أجّْ أَيِي أَذْ رَاحغْ، أَقَا إِصْبحْ ڒْحَاڒْ.“ مَاشَا نتَّا إِنَّا: ”وَارْ شكْ تّجِّيغْ، مْغِيرْ مَاڒَا ثْبَارْكذْ أَيِي.“ \x ◘ \xo 32:‏27 \xt حُوش. 12‏:‏4. \x*
\v 28 ؤُشَا نتَّا إِنَّا أَسْ: ”مَامّشْ ذ أَشْ قَّارنْ؟“ يَارَّا-د خَاسْ: ”يَاعْقُوبْ.“
\v 29 \add خنِّي\add* إِنَّا أَسْ: ”وَارْ ذ أَشْ قَّارنْ عَاذْ يَاعْقُوبْ، مَاشَا إِسْرَائِيل، مِينْزِي ثمّنْغذْ أَكْ-ذ أَربِّي ذ إِوْذَانْ، ؤُشَا شكْ ثْغڒْبذْ.“ \f ◼ \fr 32:‏29 \ft \bd ’إِسْرَائِيل‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَربِّي إِتّْمنْغَا‘ نِيغْ ’نتَّا إِتّْمنْغَا أَكْ-ذ أَربِّي‘.\f*  \x ◘ \xo 32:‏29 \xt أَمز. 35‏:‏10. \x*
\v 30 إِسّقْسَا يَاعْقُوبْ \add خنِّي\add*، إِنَّا: ”إِنِي أَيِي ڒخُّو إِسمْ نّشْ!“ يَارَّا-د خَاسْ: ”مَاغَارْ ثسّقْسِيذْ خْ يِيسمْ إِنُو؟“ ؤُشَا إِبَارْكْ إِ-ث ذِينْ.
\v 31 ؤُشَا إِسمَّا يَاعْقُوبْ أَمْشَانْ نِّي فَانُووِيلْ، إِنَّا: ”مِينْزِي ژْرِيغْ أَربِّي أَغمْبُوبْ ذڭْ ؤُغمْبُوبْ ؤُشَا إِنْجمْ ڒعْمَارْ إِنُو.“
\v 32 ثنْقَارْ-د خَاسْ ثْفُوشْثْ ؤُمِي ثُوغَا إِعْذُو خْ فَانُووِيلْ، ؤُشَا يُويُورْ إِتّْزحّفْ زِي ثْمصَّاضْثْ نّسْ.
\v 33 خْ ؤُيَا وَارْ تّتّنْ أَيْثْ ن إِسْرَائِيل أَڒْ أَسّْ-أَ زڭْ وژْوَارْ إِڭْذَارنْ إِ إِتّكّنْ خْ ثمْقِيقّشْثْ ن ثْمصَّاضْثْ، مِينْزِي إِحَاذَا ثَامصَّاضْثْ ن يَاعْقُوبْ غَارْ مَانِي إِدْجَا وژْوَارْ إِڭْذَارنْ.
\b
\b
\c 33
\m 
\v 1 إِسّْڭعّذْ يَاعْقُوبْ ثَامُوغْڒِي نّسْ ؤُشَا إِژْرَا عِيسُو ذ أَربْعَا-مْيَا ن يرْيَازنْ أَكِيذسْ خشّنْ-د. إِفَارْقْ \add يَاعْقُوبْ\add* إِحنْجِيرنْ خْ لِييَا ذ رَاحِيلْ ذ ثْنَاينْ ن ثِييَّا.
\v 2 إِڭَّا ثِييَّا ذ ثَارْوَا نْسنْثْ غَارْ زَّاثْ، أَوَارْنِي أَسنْثْ لِييَا ذ ثَارْوَا نّسْ ؤُ رَاحِيلْ ذ يُوسُوفْ ذ إِنڭُّورَا.
\v 3 ؤُمِي إِعْذُو زَّاثْ إِ ثِيطَّاوِينْ نْسنْ، إِبنْذقْ غَارْ ثمُّورْثْ سبْعَا ن ثْوَاڒَاوِينْ أَڒَامِي د-يِيوضْ غَارْ ؤُمَاسْ. \f ◼ \fr 33:‏3 \ft \bd ’زَّاثْ إِ ثِيطَّاوِينْ نْسنْ‘\bd* - س ثْعِيبْرَانِيثْ ’زَّاثْ إِ إِغمْبَابْ نْسنْ‘.\f*
\v 4 عِيسُو يُوزّڒْ-د حِيمَا أَذْ ث إِڒْقَا، إِذَارّعْ أَسْ، إِنْڭزْ أَسْ خْ يِيرِي نّسْ، إِسُّوذمْ إِ-ث ؤُشَا رُونْ س ثْنَاينْ.
\v 5 \add خَاسْ ؤُشَا\add* إِسّْڭعّذْ ثِيطَّاوِينْ نّسْ، إِژْرَا ثِيمْغَارِينْ ذ إِحنْجِيرنْ نِّي ؤُشَا إِنَّا: ”مِينْ عْنَانْ إِنَا إِنِّي أَكِيذكْ؟“ نتَّا يَارَّا-د خَاسْ: ”ذ ثَارْوَا نِّي إِوْشَا أَربِّي زڭْ أَرْضَا \add نّسْ\add* إِ ؤُمْسخَّارْ نّشْ.“
\v 6 ؤُشَا رحّْڭنْثْ-إِ-د ثِييَّا، نِيثنْثِي ذ ثَارْوَا نْسنْثْ، ؤُشَا بنْذْقنْثْ.
\v 7 ثْرحّڭْ-د عَاوذْ لِييَا ذ إِحنْجِيرنْ نّسْ ؤُشَا بنْذْقنْ. ڒخْذنِّي إِقَارّبْ-د يُوسُوفْ ذ رَاحِيلْ ؤُشَا بنْذْقنْ.
\v 8 إِنَّا أَسْ: ”مِينْ ثخْسذْ أَكْ-ذ ؤُبَارُّو-يَا ن ڒْعسْكَارْ نِّي ڒْقِيغْ؟“ نتَّا إِنَّا: ”\add نشّْ سّكّغْ ث،\add* مَاحنْذْ أَذْ أَفغْ أَرْضَا ذِي ثِيطَّاوِينْ ن سِيذِي إِنُو!“
\v 9 إِنَّا عِيسُو: ”أَقَا غَارِي أَطَّاسْ، ؤُمَا إِنُو! أَذْ يِيڒِي إِ شكْ مِينْ إِدْجَانْ نّشْ!“
\v 10 \add خَاسْ ؤُشَا\add* إِنَّا يَاعْقُوبْ: ”لَّ، تّْزَاوَاڭغْ شكْ! مَاڒَا ؤُفِيغْ ڒخُّو أَرْضَا ذِي ثِيطَّاوِينْ نّشْ، كْسِي أَرِّيغَالُو إِنُو زڭْ إِفَاسّنْ إِنُو، مَاغَارْ ژْرِيغْ ؤُذمْ نّشْ أَخْمِي ژْرِيغْ ؤُذمْ ن أَربِّي ؤُشَا ثْقبْڒذْ خَافِي س ڒمْڒَاحثْ.
\v 11 تّْزَاوْڭغْ شكْ، كْسِي لْبَارَاكَا إِنُو إِ ذ أَشْ د-إِوْيغْ، مِينْزِي أَربِّي إِمْصُورُّوفْ أَكِيذِي س أَرْضَا ؤُشَا نشّْ غَارِي كُوڒْشِي.“ إِكلّفْ إِ-ث ؤُشَا إِكْسِي ث.
\m 
\v 12 نتَّا إِنَّا: ”أجّْ أَنغْ أَذْ نفْسِي إِقِيضَانْ نّغْ، أَذْ نْرَاحْ. نشّْ أَذْ رَاحغْ زَّاثشْ.“
\v 13 \add مَاشَا\add* نتَّا إِنَّا أَسْ: ”سِيذِي إِنُو إِسّنْ، أَقَا إِحنْجِيرنْ-أَ أَرهْفنْ ؤُ أَقَا غَارِي ؤُدْجِي ذ ثْفُونَاسِينْ ؤُرْونْثْ سُّوطُّوضنْثْ. مَاڒَا بْنَاذمْ إِزيَّارْ خَاسنْثْ أَطَّاسْ، \add وَاخَّا مْغِيرْ إِ\add* يِيجّْ ن وَاسّْ، أَذْ إِمّثْ وُودْجِي مَارَّا.
\v 14 أَذْ إِعْذُو ڒخُّو سِيذِي إِنُو زَّاثْ إِ ؤُغمْبُوبْ ن ؤُمْسخَّارْ نّسْ ؤُ نشّْ أَذْ د-أَسغْ شْوَايْثْ شْوَايْثْ أَكْ-ذ إِصُورَافْ ن ڒكْسِيبثْ إِ إِدْجَانْ زَّاثِي ؤُڒَا أَكْ-ذ إِصُورَافْ ن إِحنْجِيرنْ، أَڒْ د غَا أَوْضغْ غَارْ سِيذِي إِنُو ذِي سَاعِيرْ.“
\v 15 إِنَّا عِيسُو: ”أَذْ جّغْ ڒخُّو أَكِيذكْ \add شَا ن\add* إِوْذَانْ إِنِّي إِدْجَانْ أَكِيذِي.“ \add مَاشَا\add* نتَّا إِنَّا: ”ؤُمِي دّڭَّا؟ أجّْ أَيِي أَذْ أَفغْ أَرْضَا ذِي ثِيطَّاوِينْ ن سِيذِي إِنُو!“
\v 16 إِعْقبْ-د عِيسُو ذڭْ وَاسّْ نِّي خْ وبْرِيذْ غَارْ سَاعِيرْ.
\m 
\v 17 ؤُشَا إِفْسِي يَاعْقُوبْ إِقِيضَانْ نّسْ، \add يُويُورْ\add* غَارْ سُوكُّوثْ، إِبْنَا ذِينْ ثَادَّارْثْ إِ يِيخفْ نّسْ ؤُشَا إِڭَّا إِعُوشُّوثنْ ن ثْسطَّا إِ ڒبْهَايمْ نّسْ. خْ ؤُيَا إِڒَاغَا إِسمْ ن ومْشَانْ نِّي سُوكُّوثْ، \add إِخْسْ أَذْ يِينِي ’إِعُوشُّوثنْ‘\add*. \f ◼ \fr 33:‏17 \ft \bd ’سُوكُّوثْ‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’إِعُوشُّوثنْ‘.\f*
\v 18 ؤُمِي د-إِعْقبْ يَاعْقُوبْ زِي فَاذَانْ-أَرَامْ، يُوسَا-د غَارْ شَالِيمْ، إِشْثْ ن ثنْذِينْثْ ن شَاكِيمْ، ثنِّي إِدْجَانْ ذِي ثمُّورْثْ ن كنْعَانْ، ؤُشَا إِوْثَا إِقِيضَانْ نّسْ زَّاثْ إِ ثنْذِينْثْ. \x ◘ \xo 33:‏18 \xt ياش. 24‏:‏32؛ ڒخ. 7‏:‏16. \x*
\v 19 إِسْغَا طَّارْفْ ن ييَّارْ مَانِي إِوْثَا إِقِيضَانْ نّسْ، زڭْ إِفَاسّنْ ن إِحنْجِيرنْ ن حَامُورْ، بَابَاسْ ن شَاكِيمْ، س مْيَا ن إِزِييْنَاثْ ن نُّوقَارْثْ إِوزْننْ. \f ◼ \fr 33:‏19 \ft \bd ’حَامُورْ‘\bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَغْيُوڒْ‘.\f*
\v 20 إِسّْڭعّذْ ذِينْ إِجّْ ن ؤُعَالْطَارْ \add مِينْ خفْ ثمَّارْسْ ثْغَارْصْثْ\add* ؤُشَا إِڒَاغَا أَسْ: ’أَربِّي \add ذ\add* أَربِّي ن إِسْرَائِيل!‘ \f ◼ \fr 33:‏20 \ft \bd ’أَربِّي (ذ) أَربِّي ن إِسْرَائِيل!‘\bd* - نِيغْ ’أَربِّي ن إِسْرَائِيل ذ أَربِّي!‘\f*
\b
\b
\c 34
\s1 أَسْنُوقّبْ ن ذِينَا زِي شَاكِيمْ، مِّيسْ ن حَامُورْ
\m 
\v 1 ذِينَا، يدْجِيسْ ن لِييَا، ثنِّي د-ثُورُووْ إِ يَاعْقُوبْ، ثفّغْ، حِيمَا أَذْ ثمّڒْقَا أَكْ-ذ يسِّيسْ ن ثمُّورْثْ. \x ◘ \xo 34:‏1 \xt أَمز. 30‏:‏21. \x*
\v 2 شَاكِيمْ، مِّيسْ ن حَامُورْ أَحِيوِي، ڒْحَاكمْ ن ثمُّورْثْ نِّي، إِژْرَا إِ-ت، إِكْسِي ت ؤُشَا إِطّصْ أَكِيذسْ، إِسّخْسَارْ إِ-ت.
\v 3 إِطَّارْبطْ ذِي ذِينَا، يدْجِيسْ ن يَاعْقُوبْ، ؤُ نتَّا إِخْسْ ثَابْڒِيغْثْ ؤُشَا إِسِّيوڒْ غَارْ وُوڒْ ن ثبْڒِيغْثْ.
\v 4 إِسِّيوڒْ شَاكِيمْ غَارْ حَامُورْ بَابَاسْ، إِنَّا أَسْ: ”أَوْيِي أَيِي-د ثَابْڒِيغْثْ-أَ ذ ثَامْغَارْثْ.“
\m 
\v 5 ڒَامِي إِسْڒَا يَاعْقُوبْ بلِّي شَاكِيمْ إِضيّعْ \add شَّارَافْ ن\add* يدْجِيسْ ذِينَا، ثُوغَا إِحنْجِيرنْ نّسْ أَكْ-ذ ڒبْهَايمْ ذڭْ إِيَّارْ. إِسُّوسمْ يَاعْقُوبْ أَڒَامِي د -عقْبنْ نِيثْنِي.
\v 6 إِرُوحْ حَامُورْ، بَابَاسْ ن شَاكِيمْ غَارْ يَاعْقُوبْ، حِيمَا أَذْ كِيسْ إِسِّيوڒْ.
\v 7 ثَارْوَا ن يَاعْقُوبْ ذوْڒنْ-د زڭْ إِيَّارْ ؤُشَا أَرڭّْبنْ خْ ڒخْبَارْ. خيّْقنْ خْ مَانْ أَيَا \add ذڭْ وُوڒْ\add* ؤُ فُّوڭْمنْ أَطَّاسْ، مِينْزِي إِڭَّا ڒفْضِيحثْ-أَ ذِي إِسْرَائِيل ؤُمِي إِطّصْ أَكْ-ذ يدْجِيسْ ن يَاعْقُوبْ. مَانْ أَيَا وَارْ إِشُووَّارْ أَذْ ث يڭّْ.
\v 8 إِسِّيوڒْ حَامُورْ أَكِيذْسنْ، إِنَّا: ”ڒعْمَارْ ن مِّي شَاكِيمْ إِقّنْ غَارْ يدْجِيثْومْ، تّْزَاوَاڭغْ، أَذْ أَسْ ت ثوْشمْ ذ ثَامْغَارْثْ،
\v 9 ؤُشَا أَذْ نمْضڭّْوَاڒْ. أَذْ أَنغْ ثوْشمْ يدْجِيثْومْ، كنِّيوْ أَذْ ثكْسِيمْ يسِّيثْنغْ إِ يِيخفْ نْومْ.
\v 10 زذْغمْ أَكِيذْنغْ، مِينْزِي ثَامُّورْثْ أَقَا-ت زَّاثْومْ. زذْغمْ ؤُ ؤُيُورمْ ذَايسْ ؤُشَا طّْفمْ ذَايسْ أَڭْڒَا إِ كنِّيوْ.“
\v 11 ؤُشَا إِنَّا شَاكِيمْ \add عَاوذْ\add* إِ بَابَاسْ ذ أَيْثْمَاسْ: ”أجّْ أَيِي أَذْ أَفغْ أَرْضَا ذِي ثِيطَّاوِينْ نْومْ ؤُشَا أَذْ وْشغْ مِينْ ذ أَيِي غَا ثِينِيمْ.
\v 12 \add وَاخَّا\add* أَذْ ثسّْضقْڒمْ خَافِي \add ڒحْمڒْ\add* أَطَّاسْ \add ن\add* صَّاذَاقْ ذ سُّونَانْ، أَقَا نشّْ أَذْ وْشغْ مشْحَاڒْ مَا ذ أَيِي غَا ثِينِيمْ. وْشمْ أَيِي مْغِيرْ ثَابْڒِيغْثْ ذ ثَامْغَارْثْ.“
\v 13 أَرِّينْ-د إِحنْجِيرنْ ن يَاعْقُوبْ خْ شَاكِيمْ ذ حَامُورْ، بَابَاسْ، س إِشْثْ ن ثحْرَايْمشْثْ، مِينْزِي أَقَا إِسّخْسَارْ ذِينَا، ؤُتْشْمَاثْسنْ.
\v 14 نِيثْنِي سِّيوْڒنْ، نَّانْ أَسنْ: ”وَارْ نْزمَّارْ أَذْ نڭّْ أَمُّو، أَذْ نوْشْ ؤُتْشْمَاثْنغْ إِ ورْيَازْ نِّي \add عَاذْ\add* س ڒعْذَاڒْيثْ. ذڭَّا ذ ڒْعَارْ خَانغْ. \x ◘ \xo 34:‏14 \xt أَمز. 17‏:‏12، 13، 14. \x*
\v 15 مْغِيرْ س ؤُمْثَاوِي-يَا وَاهَا أَذْ كنِّيوْ نْسعّفْ، مَاڒَا ثڭِّيمْ أَمْ نشِّينْ، أَذْ ثتّْوَاخثْنمْ مَارَّا إِوثْمَانْ نْومْ.
\v 16 \add خنِّي\add* أَذْ أَومْ نوْشْ يدْجِيثْنغْ ؤُشَا أَذْ نكْسِي يسِّيثْومْ، أَذْ كِيذْونْ نزْذغْ، أَذْ نِيڒِي ذ إِجّْ ن ڒْڭنْسْ.
\v 17 \add مَاشَا\add* مَاڒَا وَارْ ذ أَنغْ ثسْڒِيمْ ذِي ثْمسْڒَاشْثْ ن وخْثَانْ، \add خنِّي\add* أَذْ نكْسِي يدْجِيثْنغْ ؤُشَا أَذْ نُويُورْ.“
\v 18 بَاننْ وَاوَاڒنْ نْسنْ مْلِيحْ ذڭْ إِمزُّوغنْ ن حَامُورْ ؤُ ذڭْ إِمجَّانْ ن شَاكِيمْ، مِّيسْ ن حَامُورْ. \f ◼ \fr 34:‏18 \ft \bd ’إِمزُّوغنْ‘\bd* - نِيغْ ’إِمجَّانْ‘.\f*
\v 19 أَعزْرِي وَارْ ذ أَسْ إِشْقِي أَذْ إِڭّْ مَانْ أَيَا، مِينْزِي نتَّا إِتّخْسْ أَطَّاسْ يدْجِيسْ ن يَاعْقُوبْ ؤُ نتَّا ثُوغَا-ث قَاعْ مْوقَّارْ ذِي مَارَّا ثَادَّارْثْ ن بَابَاسْ.
\m 
\v 20 ؤُشَا ؤُسِينْ-د حَامُورْ ذ مِّيسْ شَاكِيمْ غَارْ ثوَّارْثْ ن ثنْذِينْثْ نّسْ، سِّيوْڒنْ أَكْ-ذ يرْيَازنْ ن ثنْذِينْثْ، نَّانْ:
\v 21 ”إِرْيَازنْ-أَ ذ إِمْهُوذْننْ أَكِيذْنغْ. أجّْ أَنغْ أَذْ ثنْ نجّْ أَذْ زذْغنْ ذِي ثمُّورْثْ-أَ ؤُشَا أَذْ ذَايسْ ؤُيُورنْ. خْزَارْ، ثَامُّورْثْ ثوْسعْ إِ نِيثْنِي غَارْ مَارَّا إِغزْذِيسنْ نّسْ. نشِّينْ أَذْ نكْسِي يسِّيثْسنْ ذ ثِيمْغَارِينْ، أَذْ أَسنْ نوْشْ يسِّيثْنغْ.
\v 22 \add مَاشَا\add* س ؤُمْثَاوِي-يَا وَاهَا أَذْ سعّْفنْ يرْيَازنْ-أَ، حِيمَا أَذْ كِيذْنغْ زذْغنْ ؤُ حِيمَا أَذْ ذوْڒنْ ذ إِجّْ ن ڒْڭنْسْ \add أَكِيذْنغْ\add*، مَاڒَا مَارَّا إِرْيَازنْ إِ إِدْجَانْ جَارْ أَنغْ أَذْ تّْوَاخثْننْ أَمْ مَامّشْ تّْوَاخثْننْ نِيثْنِي.
\v 23 ڒبْهَايمْ نْسنْ ذ أَڭْڒَا نْسنْ ذ مَارَّا ڒْمَاڒْ نْسنْ، مَا وَارْ تِّيڒِينْ نّغْ؟ أجّْ أَنغْ أَذْ ثنْ نْسعّفْ، \add خنِّي\add* أَذْ زذْغنْ أَكِيذْنغْ.“
\v 24 مَارَّا إِنِّي د-يُوسِينْ غَارْ ثوَّارْثْ ن ثنْذِينْثْ نّسْ سْڒِينْ إِ حَامُورْ ذ مِّيسْ شَاكِيمْ ؤُشَا مَارَّا إِرْيَازنْ إِنِّي د-يُوسِينْ غَارْ ثوَّارْثْ ن ثنْذِينْثْ نّسْ، تّْوَاخثْننْ.
\v 25 ؤُمِي ثُوغَا عَاذْ ذَايْسنْ ڒهْرِيقْ ذڭْ وَاسّْ وِيسّْ ثْڒَاثَا، ثمْسَارْ بلِّي إِحنْجِيرنْ ن يَاعْقُوبْ، شِيمْعُونْ ذ لَاوِي، أَيْثْمَاسْ ن ذِينَا، أَقَا كُوڒْ إِجّْ زَّايْسنْ إِكْسِي سِّيفْ نّسْ ؤُشَا رُوحنْ غَارْ ثنْذِينْثْ مَانِي ذ أَسنْ إِتّْغِيڒْ أَقَا ذَايسْ ڒَامَانْ ؤُشَا نْغِينْ مَارَّا إِرْيَازنْ. \x ◘ \xo 34:‏25 \xt أَمز. 49‏:‏6. \x*
\v 26 نْغِينْ حَامُورْ ذ مِّيسْ شَاكِيمْ س ڒقْضعْ ن سِّيفْ ؤُشَا كْسِينْ ذِينَا زِي ثَادَّارْثْ ن شَاكِيمْ، فّْغنْ.
\v 27 ثَارْوَا ن يَاعْقُوبْ ؤُسِينْ-د غَارْ يِينِّي إِتّْوَانْغنْ ؤُشَا كشّْضنْ ثَانْذِينْثْ، مِينْزِي نِيثْنِي سّخْسَارنْ ؤُتْشْمَاثْسنْ.
\v 28 كْسِينْ ؤُدْجِي نْسنْ ذ إِفُونَاسنْ ذ ثْفُونَاسِينْ نْسنْ ذ يغْيَاڒْ نْسنْ ذ مَارَّا مِينْ ثُوغَا ذِي ثنْذِينْثْ ؤُ ذڭْ إِيَّارْ.
\v 29 كْسِينْ مَارَّا أَڭْڒَا نّسْ ؤُشَا إِوْينْ-د مَارَّا إِحنْجِيرنْ ذ ثمْغَارِينْ نْسنْ ذ إِمحْبَاسْ ؤُشَا ؤُشَارنْ مَارَّا مِينْ ثُوغَا ذِي ثُوذْرِينْ.
\v 30 \add خنِّي\add* إِنَّا يَاعْقُوبْ إِ شِيمْعُونْ ذ لَاوِي: ”كنِّيوْ ثسِّيذْفمْ أَيِي ذڭْ إِمْخُومْبَارْ أَڒَامِي ذ أَيِي ثسَّارْزْڭمْ غَارْ إِمزْذَاغْ ن ثمُّورْثْ-أَ، غَارْ أَيْثْ ن كنْعَانْ ذ إِفِيرِيزِييّنْ. ذ نشّْ غَارِي إِجّْ ن وُورُو ن يرْيَازنْ \add وَاهَا\add*. \add مَاڒَا\add* أَذْ مُوننْ خْ ؤُزڒْمَاضْ إِنُو، أَذْ أَيِي قژّْرنْ، أَذْ إِڒِيغْ أَريّْثغْ، نشّْ ذ ثَادَّارْثْ إِنُو.“
\v 31 نِيثْنِي نَّانْ: ”مَا إِعدّڒْ خنِّي أَذْ إِحْسبْ ؤُتْشْمَاثْنغْ أَمشْنَاوْ إِشْثْ ن لْفَاسْذَا؟“
\b
\b
\c 35
\s1 أَعْقَابْ ن يَاعْقُوبْ غَارْ بَايْثْ-إِلْ
\m 
\v 1 ؤُشَا إِنَّا أَربِّي إِ يَاعْقُوبْ: ”كَّارْ، ڭعّذْ غَارْ بَايْثْ-إِلْ ؤُشَا قِّيمْ ذِينْ. أڭّْ ذِينْ إِجّْ ن ؤُعَالْطَارْ \add مِينْ خفْ إِ غَا ثسَّارْسذْ ثَاغَارْصْثْ\add* إِ أَربِّي، ونِّي ذ أَشْ د-إِبَاننْ ؤُمِي د-ثَاروْڒذْ زڭْ ؤُغمْبُوبْ ن ؤُمَاشْ عِيسُو.“ \x ◘ \xo 35:‏1 \xt أَمز. 27‏:‏43؛ 28‏:‏12، 13. \x*
\v 2 \add خنِّي\add* إِنَّا يَاعْقُوبْ إِ ڒْوَاشُونْ \add ن ثَادَّارْثْ\add* نّسْ ؤُ إِ مَارَّا إِنِّي ثُوغَا أَكِيذسْ: ”كّْسمْ إِربِّيثنْ إِغْرِيبنْ نِّي إِدْجَانْ جَارْ أَومْ، سِيزذْڭمْ إِخفْ نْومْ ؤُشَا بدّْڒمْ أَرُّوضْ نْومْ. \f ◼ \fr 35:‏2 \ft \bd ’إِربِّيثنْ إِغْرِيبنْ‘\bd* - مَانْ أَيَا إِخْسْ أَذْ يِينِي ’لَاصْنَامْ‘. ؤُڒَا ذِي أَيثْ 4.\f*
\v 3 أَذْ نكَّارْ، أَذْ نْڭعّذْ غَارْ بَايْثْ-إِلْ. نشّْ أَذْ ڭّغْ ذِينْ إِجّْ ن ؤُعَالْطَارْ إِ أَربِّي نِّي خَافِي د-يَارِّينْ ذڭْ وَاسّْ ن ڒحْصَارثْ إِنُو، ذ ونِّي ثُوغَا أَكِيذِي ذڭْ وبْرِيذْ نِّي ؤُيُورغْ.“
\v 4 ؤُشَا وْشِينْ إِ يَاعْقُوبْ مَارَّا إِربِّيثنْ إِغْرِيبنْ نِّي ثُوغَا غَارْسنْ ؤُڒَا ذ ثِيخْرَازِينْ ذڭْ إِمزُّوغنْ نْسنْ ؤُشَا إِفَّارْ إِ-ثنْ يَاعْقُوبْ سَاذُو ثْشجَّارْثْ ن يِيڭّْ إِ ثُوغَا زَّاثْ إِ شَاكِيمْ. \f ◼ \fr 35:‏4 \ft \bd ’نِّي ثُوغَا غَارْسنْ‘\bd* - س ثْعِيبْرَانِيثْ ’إِنِّي ذڭْ إِفَاسّنْ نْسنْ‘\f*
\v 5 \add ڒَْامِي\add* فسْينْ إِقِيضَانْ، \add ؤُيُورنْ\add* سّنِّي، ثُوغَا ثِيڭّْوُوذِي ن أَربِّي خْ ثْندَّامْ نِّي ثُوغَا ذِي جّْوَايهْ إِ ذ أَسنْ د-إِنّْضنْ، أَڒَامِي نِيثْنِي وَارْ ضفَّارنْ إِحنْجِيرنْ ن يَاعْقُوبْ.
\v 6 أَمُّو إِ يِيوضْ يَاعْقُوبْ غَارْ لُوزْ ذِي ثمُّورْثْ ن كنْعَانْ، أَقَا-ت ذ بَايْثْ-إِلْ، نتَّا ذ مَارَّا ڒْڭنْسْ إِ ثُوغَا أَكِيذسْ.
\v 7 إِبْنَا ذِينْ إِجّْ ن ؤُعَالْطَارْ ؤُشَا إِڒَاغَا إِ ومْشَانْ نِّي إِلْ-بَايْثْ-إِلْ، مِينْزِي ذِينِّي إِ ذ أَسْ د-إِضْهَارْ أَربِّي، ؤُمِي د-يَارْوڒْ زڭْ ؤُغمْبُوبْ ن ؤُمَاسْ. \x ◘ \xo 35:‏7 \xt أَمز. 28‏:‏19. \x*
\m 
\v 8 ثمُّوثْ ذِيبُورَا، ثَامسّطَّاضْثْ ن رِيفْقَا ؤُشَا نضْڒنْ ت سْوَادَّايْ إِ بَايْثْ-إِلْ، سَاذُو ثَابدْجُوضْثْ ؤُشَا إِڒَاغَا إِسمْ نّسْ ’أَلُّونْ-بَاكُوثْ‘، \add أَقَا-ت ذ ’ثَابدْجُوضْثْ ن إِمطَّاونْ‘\add*.
\v 9 إِضْهَارْ أَسْ-د عَاوذْ أَربِّي إِ يَاعْقُوبْ ؤُمِي د-إِذْوڒْ زِي فَاذَانْ-أَرَامْ ؤُشَا إِبَارْكْ إِ-ث. \x ◘ \xo 35:‏9 \xt حُوش. 12‏:‏5. \x*
\v 10 إِنَّا أَسْ أَربِّي: ”إِسمْ نّشْ ذ يَاعْقُوبْ. زِي سَّا ذ ثْسَاونْثْ وَارْ تّڭّنْ عَاذْ إِسمْ نّشْ ’يَاعْقُوبْ‘، مَاشَا ’إِسْرَائِيل‘، ذ وَا إِ غَا يِيڒِينْ ذ إِسمْ نّشْ.“ ؤُشَا إِسمَّا ث إِسْرَائِيل. \x ◘ \xo 35:‏10 \xt أَمز. 32‏:‏27؛ 2 إِج. 17‏:‏34. \x*
\v 11 إِنَّا أَسْ أَربِّي: ”نشّْ ذ أَربِّي، أَمْزمَّارْ خْ كُوڒْشِي! أڭّْ ڒْغِيدْجثْ، مَّارْنِييْ! زَّايكْ إِ غَا إِفّغْ إِجّْ ن ڒْڭنْسْ، وَاهْ، ذ إِجّْ ن وڭْرَاوْ ن ڒڭْنُوسْ أَذْ فّْغنْ زَّايكْ ؤُ إِجدْجِيذنْ أَذْ فّْغنْ زِي ثجْعِينَّا نّشْ. \x ◘ \xo 35:‏11 \xt أَمز. 17‏:‏1، 6؛ 28‏:‏3؛ 48‏:‏3 \x*
\v 12 ؤُشَا ثَامُّورْثْ-أَ إِ وْشِيغْ إِ إِبْرَاهِيمْ ذ إِسْحَاقْ، إِ شكْ ؤُمِي ت إِ غَا وْشغْ ؤُشَا ؤُڒَا إِ زَّارِيعثْ نّشْ أَوَارْنِي أَشْ أَذْ وْشغْ ثَامُّورْثْ.“
\v 13 \add خَاسْ ؤُشَا\add* إِڭعّذْ أَربِّي سنّجْ زڭْ ومْشَانْ مَانِي كِيذسْ إِسِّيوڒْ.
\v 14 يَاعْقُوبْ إِسّْڭعّذْ إِجّْ ن وژْرُو ن ڒِيذَارثْ ذڭْ ومْشَانْ مَانِي كِيسْ إِسِّيوڒْ، إِجّْ ن وژْرُو ن ڒِيذَارثْ. إِسيّبْ خَاسْ إِشْثْ ن ثوْهِيبْثْ ن ؤُسيّبْ ؤُشَا إِفَارّغْ زّشْثْ خْ ؤُزدْجِيفْ نّسْ. \x ◘ \xo 35:‏14 \xt أَمز. 28‏:‏18. \x*
\v 15 إِڭَّا يَاعْقُوبْ إِسمْ ن ومْشَانْ مَانِي كِيذسْ إِسِّيوڒْ أَربِّي ’بَايْثْ-إِلْ!‘
\b
\s1 أَخْڒَاقْ ن بِينْيَامِينْ ذ ڒْموْثْ ن رَاحِيلْ
\m 
\v 16 فسْينْ نِيثْنِي إِقِيضَانْ نْسنْ، \add فّْغنْ\add* زِي بَايْثْ-إِلْ ؤُشَا ؤُمِي ثُوغَا تّڭّْوِيجنْ مْغِيرْ شْوَايْثْ خْ إِفْرَاثَا، خنِّي ثُورُووْ-د رَاحِيلْ ؤُ ثعْذُو خَاسْ ثَارْوَا ثقْسحْ. \f ◼ \fr 35:‏16 \ft \bd ’إِفْرَاثَا‘\bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’مِينْ إِتِّيشنْ ڒْغِيدْجثْ‘ نِيغْ ’ونِّي إِتِّيشّنْ ڒْغِيدْجثْ‘.\f*
\v 17 إِمْسَارْ، ؤُمِي ثغُّوضذْ ذِي ثَارْوَا نّسْ، ثنَّا أَسْ ڒْقَابْڒَا: ”وَارْ تّڭّْوذْ، أَقَا وَا عَاوذْ أَذْ يِيڒِي ذ مِّيمْ!“
\v 18 ڒَامِي ثضْڒقْ إِ بُوحْبڒْ أَمْ ثمُّوثْ \add ذِينْ\add*، أَقَا ثْڒَاغَا أَسْ بِينْ-ؤُنِي، \add إِسمْ-أَ إِخْسْ أَذْ يِينِي ’مِّيسْ ن ڒحْرِيقْ إِنُو‘\add*، \add مَاشَا\add* بَابَاسْ إِڒَاغَا أَسْ بِينْيَامِينْ، \add إِخْسْ أَذْ يِينِي ’مِّيسْ ن زّْهَارْ إِنُو‘\add*. \f ◼ \fr 35:‏18 \ft \bd ’بِينْ-oنِي‘\bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’مِّي ن ڒحْرِيقْ إِنُو‘. \bd ’بِينْيَامِينْ‘\bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’مِّي ن ؤُفُوسْ يفُوسِي‘.\f*
\v 19 \add أَمُّو\add* إِ ثمُّوثْ رَاحِيلْ ؤُشَا نضْڒنْثْ ت ذڭْ وبْرِيذْ غَارْ إِفْرَاثَا، إِخْسْ أَذْ يِينِي بَايْثْ-لَاحْمْ. \x ◘ \xo 35:‏19 \xt أَمز. 48‏:‏7. \x*
\v 20 ؤُشَا إِڭَّا يَاعْقُوبْ إِجّْ ن وژْرُو ن ڒِيذَارثْ خْ ونْضڒْ نّسْ. ذ وَا ذ أَژْرُو ن ڒِيذَارثْ ن رَاحِيلْ خْ ونْضڒْ ن رَاحِيلْ أَڒْ أَسّْ-أَ.
\b
\m 
\v 21 \add خَاسْ ؤُشَا\add* إِفْسِي إِسْرَائِيل إِقِيضَانْ ؤُشَا إِوْثَا أَقِيضُونْ نّسْ خْ ؤُعدُّو ن مَاجْذَالْ-عِيذْرْ.
\v 22 ؤُمِي إِزْذغْ إِسْرَائِيل ذِي ثمُّورْثْ نِّي، إِمْسَارْ بلِّي رُوبِينْ إِرُوحْ إِطّصْ أَكْ-ذ بِيلْهَا، ثَايَّا ن بَابَاسْ، ؤُشَا يِيوضْ أَذْ \add ث\add* إِفْهمْ إِسْرَائِيل.
\b
\m \bd أَقَا \bdit ڒخُّو\bdit* إِوْضنْ أَيْثْ ن يَاعْقُوبْ ثنْعَاشْ\bd*. \x ◘ \xo 35:‏22 \xt أَمز. 49‏:‏4. \x*
\m 
\v 23 \bd ثَارْوَا ن لِييَا\bd* \add ثُوغَا أَثنْ\add*: رُوبِينْ، أَمنْزُو ن يَاعْقُوبْ ذ شِيمْعُونْ ذ لَاوِي ذ يَاهُوذَا ذ إِسَّاكَارْ ذ زابُولُونْ. \x ◘ \xo 35:‏23 \xt أَمز. 46‏:‏8؛ ؤُف. 1‏:‏2. \x*
\v 24 \bd ثَارْوَا ن رَاحِيلْ\bd* \add ثُوغَا أَثنْ\add*: يُوسُوفْ ذ بِينْيَامِينْ.
\v 25 \bd ثَارْوَا ن بِيلْهَا\bd*، ثَايَّا ن رَاحِيلْ، \add ثُوغَا أَثنْ\add*: ذَانْ ذ نَافْثَالِي.
\v 26 \bd ثَارْوَا ن زِيلْپَا\bd*، ثَايَّا ن لِييَا، \add ثُوغَا أَثنْ\add*: جَاذْ ذ أَشِيرْ. إِنَا \add ثُوغَا أَثنْ ذ\add* إِحنْجِيرنْ ن يَاعْقُوبْ إِنِّي ذ أَسْ د-إِتّْوَاخڒْقنْ ذِي فَاذَانْ-أَرَامْ.
\b
\s1 ڒْموْثْ ن إِسْحَاقْ
\m 
\v 27 ؤُشَا يُوسَا-د يَاعْقُوبْ غَارْ بَابَاسْ إِسْحَاقْ ذِي مَامْرِي، ذِي ثنْذِينْثْ ن أَرْبَاعْ، ثنِّي إِدْجَانْ ذ \add ثَانْذِينْثْ ن\add* حَابْرُونْ، مَانِي ثُوغَا إِبْرَاهِيمْ إِزدّغْ أَمْ ؤُبَارَّانِي، ؤُشَا إِسْحَاقْ أَمنِّي \add أَوَارْنِي أَسْ\add*. \f ◼ \fr 35:‏27 \ft \bd ’ثَانْذِينْثْ ن أَرْبَاعْ‘\bd* - نِيغْ ’قَارْيَاثْ-أَرْبَاعْ‘.\f*
\v 28 إِدَّارْ إِسْحَاقْ مْيَا ؤُ-ثْمَانْيِينْ ن إِسڭّْوُوسَا. \f ◼ \fr 35:‏28 \ft \bd ’إِدَّارْ إِسْحَاقْ ...‘\bd* - س ثْعِيبْرَانِيثْ ’ؤُشَا ثُوغَا وُوسَّانْ ن إِسْحَاقْ ...‘\f*
\v 29 إِضْڒقْ إِسْحَاقْ إِ بُوحْبڒْ، إِمُّوثْ ؤُشَا إِمَّارْنِي غَارْ ڒْڭنْسْ نّسْ، إِوْسَارْ، إِجِّيونْ زِي ثُوذَارْثْ، ؤُشَا عِيسُو ذ يَاعْقُوبْ، إِحنْجِيرنْ نّسْ، نضْڒنْ ث. \x ◘ \xo 35:‏29 \xt أَمز. 25‏:‏8. \x*
\b
\b
\c 36
\s1 ثَارْوَا ن عِيسُو
\m 
\v 1 \bd إِنَا ذ إِمزْرُوينْ ن يِينِّي د-إِتّْوَاخڒْقنْ \bdit زِي\bdit* عِيسُو، ونِّي إِدْجَانْ ذ إِذُومْ.\bd* \x ◘ \xo 36:‏1 \xt [1 إِم. 1‏:‏28‏-‏54] — 1 إِم. 1‏:‏35. \x*
\v 2 عِيسُو إِكْسِي ثِيمْغَارِينْ نّسْ زڭْ يسِّيسْ ن كنْعَانْ: عَاذَا، يدْجِيسْ ن إِلُونْ، أَحِيتِّي، ذ أَهُولِيبَامَا، يدْجِيسْ ن عَانَا، يدْجِيسْ ن صَابْعُونْ، أَحِيوِي،
\v 3 ذ بَاسْمَاثْ، يدْجِيسْ ن إِسْمَاعِيلْ، ؤُتْشْمَاسْ ن نَابَايُوثْ.
\v 4 عَاذَا ثُورُووْ-د إِلِيفَازْ إِ عِيسُو ؤُشَا بَاسْمَاثْ ثُورُووْ \add أَسْ-د\add* رَاعُووِيلْ.
\v 5 أَهُولِيبَامَا ثُورُووْ-د يَاعُوسْ ذ يَاعْلَامْ ذ قُورَاحْ. إِنَا \add ثُوغَا أَثنْ ذ\add* إِحنْجِيرنْ ن عِيسُو، إِنِّي ذ أَسْ د-يُورْونْ ذِي ثمُّورْثْ ن كنْعَانْ.
\m 
\v 6 ؤُشَا إِكْسِي عِيسُو ثِيمْغَارِينْ نّسْ ذ إِحنْجِيرنْ نّسْ ذ يسِّيسْ ذ مَارَّا أَيْثْبَابْ ن ثَادَّارْثْ نّسْ ؤُڒَا ذ ڒبْهَايمْ نّسْ ذ مَارَّا ڒْمَاڒْ نّسْ ذ مَارَّا أَڭْڒَا نّسْ نِّي ثُوغَا د-إِكْسبْ زِي ثمُّورْثْ ن كنْعَانْ ؤُشَا إِرُوحْ غَارْ ثمُّورْثْ \add نّغْنِي\add* إِ إِڭّْوجنْ خْ ؤُغمْبُوبْ ن ؤُمَاسْ يَاعْقُوبْ،
\v 7 مِينْزِي أَڭْڒَا نْسنْ ثُوغَا إِمْغَارْ أَڒَامِي وَارْ زمَّارنْ أَذْ زذْغنْ جْمِيعْ، ؤُشَا ثَامُّورْثْ مَانِي ثُوغَا زدّْغنْ أَمْ ڒْبَارَّانِي، وَارْ ثْقدّْ إِ ڒبْهَايمْ نْسنْ. \x ◘ \xo 36:‏7 \xt أَمز. 13‏:‏6. \x*
\v 8 \add خنِّي\add* إِزْذغْ عِيسُو ذڭْ إِذُورَارْ ن سَاعِيرْ. عِيسُو، نتَّا ذ إِذُومْ. \x ◘ \xo 36:‏8 \xt ياش. 24‏:‏4. \x*
\b
\m 
\v 9 \bd إِنَا ذ إِمزْرُوينْ ن يِينِّي د-إِتّْوَاخڒْقنْ \bdit زِي\bdit* عِيسُو\bd*، بَابَاسْ ن إِذُومْ، ذڭْ إِذُورَارْ ن سَاعِيرْ.
\m 
\v 10 \bd إِنَا ثُوغَا أَثنْ ذ إِسْمَاونْ ن إِحنْجِيرنْ ن عِيسُو\bd*: إِلِيفَازْ، مِّيسْ ن عَاذَا ثنِّي ذ ثَامْغَارْثْ ن عِيسُو، رَاعُووِيلْ، مِّيسْ ن بَاسْمَاثْ، ثنِّي ذ ثَامْغَارْثْ ن عِيسُو.
\m 
\v 11 إِحنْجِيرنْ ن إِلِيفَازْ ثُوغَا أَثنْ ذ ثَايْمَانْ، ؤُمَارْ، صَافُو، جَاعْثَامْ ذ قَانَازْ. \f ◼ \fr 36:‏11 \ft \bd ’ثَايْمَانْ‘\bd* - نتَّافْ إِسمْ وَانِيثَا إِ ثْوَاڒَا ثَامزْوَارُوثْ ذَانِيثَا ذڭْ وذْلِيسْ إِقدّْسنْ. إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَفُوسِي‘ نِيغْ ’غَارْ ؤُفُوسْ أَفُوسِي‘ نِيغْ ’لْجَانُوبْ‘ نِيغْ ’غَارْ لْجَانُوبْ‘. أَقَا وَا ذ إِسمْ ن مِّيسْ إِلِيفَازْ ؤُ أَوَارْنِي أَسْ إِذْوڒْ إِسمْ-أَ ذ إِسمْ ن ثمُّورْثْ نّسْ ذِي إِذُومْ.\f*
\m 
\v 12 ثِيمْنَاعْ ثذْوڒْ ذ ثَايَّا ن إِلِيفَازْ، مِّيسْ ن عِيسُو، ؤُ نتَّاثْ ثُورُووْ-د عَامَالِيقْ إِ إِلِيفَازْ. إِنَا ثُوغَا أَثنْ ذ إِحنْجِيرنْ ن عَاذَا، ثَامْغَارْثْ ن عِيسُو.
\m 
\v 13 إِنَا ثُوغَا أَثنْ ذ إِحنْجِيرنْ ن رَاعُووِيلْ: نَاحَاثْ، زَارَاحْ، شَامَّا ذ مِيزَّا. إِنَا ثُوغَا أَثنْ ذ إِحنْجِيرنْ ن بَاسْمَاثْ، ثنِّي ذ ثَامْغَارْثْ ن عِيسُو.
\m 
\v 14 إِنَا ثُوغَا أَثنْ ذ إِحنْجِيرنْ ن أَهُولِيبَامَا، ثنِّي ذ ثَامْغَارْثْ ن عِيسُو، يدْجِيسْ ن عَانَا، ثنِّي ذ يدْجِيسْ ن زِيبْيُونْ. نتَّاثْ ثُورُووْ-د يَاعُوشْ، جَاعْلَامْ ذ قُورَاحْ إِ عِيسُو.
\m 
\v 15 \bd إِنَا ثُوغَا أَثنْ ذ إِمْغَارنْ \bdit ن ثْقبَّاڒْ\bdit* ن أَيْثْ ن عِيسُو.\bd*
\m إِحنْجِيرنْ ن إِلِيفَازْ، أَمنْزُو ن عِيسُو: أَمْغَارْ ثِيمَانْ ذ ؤُمْغَارْ ؤُمَارْ ذ ؤُمْغَارْ صَافُو ذ ؤُمْغَارْ قِينَازْ،
\v 16 ذ ؤُمْغَارْ قُورَاحْ، ذ ؤُمْغَارْ ڭَاثَامْ، ذ ؤُمْغَارْ عَامَالِيقْ. إِنَا ثُوغَا أَثنْ ذ إِمْغَارنْ ن إِلِيفَازْ ذِي ثمُّورْثْ ن إِذُومْ، إِنَا ثُوغَا أَثنْ ذ إِحنْجِيرنْ ن عَاذَا.
\m 
\v 17 إِنَا ثُوغَا أَثنْ ذ إِحنْجِيرنْ ن رَاعُووِيلْ، مِّيسْ ن عِيسُو: أَمْغَارْ نَاحَاثْ ذ ؤُمْغَارْ زَارَاحْ ذ ؤُمْغَارْ سَامَّا ذ ؤُمْغَارْ مِيزَّا. إِنَا ثُوغَا أَثنْ ذ إِمْغَارنْ ن رَاعُووِيلْ ذِي ثمُّورْثْ ن إِذُومْ، ذ إِنَا ثُوغَا أَثنْ ذ إِحنْجِيرنْ ن بَاسْمَاثْ، ثَامْغَارْثْ ن عِيسُو.
\m 
\v 18 إِنَا ثُوغَا أَثنْ ذ أَيْثْ ن أَهُولِيبَامَا، ثَامْغَارْثْ ن عِيسُو: أَمْغَارْ يَاعُوشْ ذ ؤُمْغَارْ يَاعْلَامْ ذ ؤُمْغَارْ قُورَاحْ. إِنَا ثُوغَا أَثنْ ذ إِمْغَارنْ ن أَهُولِيبَامَا، ثَامْغَارْثْ ن عِيسُو، يدْجِيسْ ن عَانَا.
\v 19 إِنَا ثُوغَا أَثنْ ذ إِحنْجِيرنْ ن عِيسُو ذ إِنَا ثُوغَا أَثنْ ذ إِمْغَارنْ \add ن ثْقبَّاڒْ نْسنْ\add*، نِيثْنِي ذ إِذُومْ.
\b
\m 
\v 20 \bd إِنَا ثُوغَا أَثنْ ذ إِحنْجِيرنْ ن سَاعِيرْ، أَخُورِي، إِنِّي ذ إِمزْذَاغْ ن ثمُّورْثْ نِّي\bd*: لُوطَانْ، شُوبَالْ، صَابْعُونْ، عَانَا، \x ◘ \xo 36:‏20 \xt 1 إِم. 1‏:‏38. \x*
\v 21 ذِيشُونْ، إِصَارْ ذ ذِيشَانْ.
\m \bd إِنَا ثُوغَا أَثنْ ذ إِمْغَارنْ \bdit ن ثْقبَّاڒْ\bdit* ن إِخُورِييّنْ\bd*، أَيْثْ ن سَاعِيرْ ذِي ثمُّورْثْ ن إِذُومْ.
\m 
\v 22 إِحنْجِيرنْ ن لُوطَانْ ثُوغَا أَثنْ ذ أَخُورِي ذ هَايْمَامْ ؤُشَا ثُوغَا ثِيمْنَاعْ ذ ؤُتْشْمَاسْ ن لُوطَانْ.
\m 
\v 23 إِنَا ثُوغَا أَثنْ ذ إِحنْجِيرنْ ن شُوبَالْ: عَالْوَانْ، مَانَاحَاثْ، عِيبَالْ، شَافُو ذ ؤُنَامْ.
\m 
\v 24 إِنَا ثُوغَا أَثنْ ذ إِحنْجِيرنْ ن صَابْعُونْ: أَيَا ذ عَانَا. ذ عَانَا وَانِيثَا ذ ونِّي ذ يُوفِينْ ڒْعُونْصَارَاثْ س وَامَانْ إِحْمَانْ ذِي ڒخْڒَا، ؤُمِي يَارْوسْ إِغْيَاڒْ ن زِيبِييُونْ بَابَاسْ. \x ◘ \xo 36:‏24 \xt 1 إِم. 1‏:‏40 \x*
\m 
\v 25 إِنَا ثُوغَا أَثنْ ذ إِحنْجِيرنْ ن عَانَا: \add مْغِيرْ\add* ذِيشُونْ، ذ أَهُولِيبَامَا، يدْجِيسْ ن عَانَا.
\m 
\v 26 إِنَا ثُوغَا أَثنْ ذ إِحنْجِيرنْ ن ذِيشَانْ: حَامْذَانْ ذ أَهْبَانْ ذ يِيثْرَانْ ذ كَارَانْ.
\m 
\v 27 إِنَا ثُوغَا أَثنْ ذ إِحنْجِيرنْ ن إِصَارْ: بِيلْهَانْ، زَاعْوَانْ ذ عَاقَانْ.
\m 
\v 28 إِنَا ثُوغَا أَثنْ ذ إِحنْجِيرنْ ن ذِيشَانْ: عُوصْ ذ أَرَانْ.
\m 
\v 29 إِنَا ثُوغَا أَثنْ ذ إِمْغَارنْ ن ثْقبَّاڒْ ن إِخُورِييّنْ: أَمْغَارْ لُوطَانْ ذ ؤُمْغَارْ شُوبَالْ ذ ؤُمْغَارْ صَابْعُونْ ذ ؤُمْغَارْ عَانَا
\v 30 ذ ؤُمْغَارْ ذِيشُونْ ذ ؤُمْغَارْ إِصَارْ ذ ؤُمْغَارْ ذِيشَانْ. إِنَا ثُوغَا أَثنْ ذ إِمْغَارنْ ن إِخُورِييّنْ عْلَاحْسَابْ إِمْغَارنْ نْسنْ ذِي ثمُّورْثْ ن سَاعِيرْ.
\b
\m 
\v 31 \bd إِنَا ثُوغَا أَثنْ ذ إِجدْجِيذنْ نِّي إِحكْمنْ ذِي ثمُّورْثْ ن إِذُومْ قْبڒْ مَا أَذْ إِحْكمْ ؤُجدْجِيذْ خْ أَيْثْ ن إِسْرَائِيل\bd*: \x ◘ \xo 36:‏31 \xt 1 إِم. 1‏:‏43. \x*
\m 
\v 32 بِيلَاعْ، مِّيسْ ن بَاعُورْ، إِحْكمْ ذِي إِذُومْ ؤُشَا إِسمْ ن ثنْذِينْثْ نّسْ ثُوغَا-ث ذ ذِينْهَابَا.
\m 
\v 33 إِمُّوثْ بِيلَاعْ ؤُشَا يُوبَابْ، مِّيسْ ن زَارَاحْ زِي بُوصْرَا إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ.
\m 
\v 34 يُوبَابْ إِمُّوثْ ؤُشَا حُوشَامْ، زِي ثمُّورْثْ ن إِثَايْمَانِييّنْ، إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ.
\m 
\v 35 إِمُّوثْ حُوشَامْ ؤُشَا هَاذَاذْ، مِّيسْ ن بَاذَاذْ، ونِّي إِغڒْبنْ خْ مِيذْيَانْ ذڭْ إِيَّارْ ن مُوآبَ، إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ. إِسمْ ن ثنْذِينْثْ نّسْ قَّارنْ أَسْ عَاوِيثْ.
\m 
\v 36 إِمُّوثْ هَاذَاذْ ؤُشَا سَامْلَا زِي مَاسْرِيقَا إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ.
\m 
\v 37 إِمُّوثْ سَامْلَا ؤُشَا شَاوُولْ، زِي رِيحُوبُوثْ غَارْ يغْزَارْ \add ن لْفُورَاطْ\add*، إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ.
\m 
\v 38 إِمُّوثْ شَاوُولْ ؤُشَا بَاعْلْ-حَانَانْ، مِّيسْ ن عَاكْبُورْ، إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ.
\m 
\v 39 إِمُّوثْ بَاعْلْ-حَانَانْ، مِّيسْ ن عَاكْبُورْ، ؤُشَا هَاذَارْ إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ. ثَانْذِينْثْ نّسْ قَّارنْ أَسْ فَاعُو ؤُ ثَامْغَارْثْ نّسْ قَّارنْ أَسْ مَاهِيطَابْ‘إِلْ، يدْجِيسْ ن مَاطْرِيذْ، يدْجِيسْ ن مَا-ذَاهَابْ. \f ◼ \fr 36:‏39 \ft \bd ’مَا-ذَاهَابْ‘\bd* - إِسمْ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَمَانْ ن وُورغْ‘.\f*
\b
\m 
\v 40 إِنَا ثُوغَا أَثنْ ذ \bd إِسْمَاونْ ن إِمْغَارنْ \bdit ن ثْقبَّاڒْ\bdit* ن عِيسُو عْلَاحْسَابْ ڒَادْجَاثْ نْسنْ ذ إِمُوشَانْ نْسنْ ذ إِسْمَاونْ نْسنْ\bd*: أَمْغَارْ ثِيمْنَاعْ ذ ؤُمْغَارْ عَالْوَا ذ ؤُمْغَارْ يَاثِيثْ \x ◘ \xo 36:‏40 \xt 1 إِم. 1‏:‏51‏-‏54\x*
\v 41 ذ ؤُمْغَارْ أَهُولِيبَامَا ذ ؤُمْغَارْ إِلَا ذ ؤُمْغَارْ فِينُونْ
\v 42 ذ ؤُمْغَارْ قَانَازْ ذ ؤُمْغَارْ ثَايْمَانْ ذ ؤُمْغَارْ مِيبْصَارْ
\v 43 ذ ؤُمْغَارْ مَاجْذِييِيلْ ذ ؤُمْغَارْ عِيرَامْ. إِنَا ثُوغَا أَثنْ ذ إِمْغَارنْ ن إِذُومْ عْلَاحْسَابْ إِمُوشَانْ نْسنْ، ذِي ثمُّورْثْ ن ڒْملْكْ نْسنْ. وَانِيثَا ذ إِذُومْ، ونِّي ذ بَابَاسْ ن إِذُومِييّنْ.
\b
\m 
\v 44 ؤُشَا إِزْذغْ يَاعْقُوبْ ذِي ثمُّورْثْ ن كنْعَانْ مَانِي ثُوغَا إِزدّغْ بَابَاسْ أَمْ ؤُبَارَّانِي.
\m \bd إِنَا ذ إِمزْرُوينْ ن يِينِّي د-إِتّْوَاخڒْقنْ \bdit زِي\bdit* يَاعْقُوبْ.\bd* \x ◘ \xo 36:‏44 \xt أَمز. 36‏:‏7؛ عبر. 11‏:‏9. \x*
\b
\b
\c 37
\s1 يُوسُوفْ، زّنْزنْ ث أَيْثْمَاسْ
\m 
\v 1 ڒَامِي ثُوغَا غَارْ يُوسُوفْ سْبعْطَاشْ ن إِسڭّْوُوسَا، يَارْوسْ ؤُدْجِي ن بَابَاسْ أَكْ-ذ أَيْثْمَاسْ. ثُوغَا يُوسُوفْ ذ أَمْسخَّارْ غَارْ إِحنْجِيرنْ ن بِيلْهَا ذ إِحنْجِيرنْ ن زِيلْپَا، ثِيمْغَارِينْ ن بَابَاسْ ؤُشَا إِسِّيوضْ يُوسُوفْ أَوَاڒنْ نْسنْ إِعفَّاننْ إِ بَابَاثْسنْ.
\v 2 ؤُشَا إِخْسْ إِسْرَائِيل يُوسُوفْ قَاعْ خْ مَارَّا إِحنْجِيرنْ نّسْ، مِينْزِي ثُوغَا-ث غَارسْ ذ مِّيسْ خْ ثوْسَارْ نّسْ ؤُشَا إِڭَّا أَسْ أَرُّوضْ \add س إِفَاسّنْ ذ إِزِيرَارنْ\add*.
\v 3 \add ڒَْامِي\add* ژْرِينْ أَيْثْمَاسْ بلِّي بَابَاسْ إِتّخْسْ إِ-ث قَاعْ خَاسنْ، شَارْهنْ ث ؤُشَا وَارْ زمَّارنْ أَكِيذسْ سِّيوْڒنْ \add عَاذْ\add* س ڒهْنَا.
\m 
\v 4 ؤُشَا يُورْجَا يُوسُوفْ إِشْثْ ن ثَارْجِيثْ، إِعَاوْذْ إِ-ت إِ يَايْثْمَاسْ. س ؤُيَا نِيثْنِي ذوْڒنْ شَارْهنْ ث عَاذْ كْثَارْ.
\v 5 إِنَّا أَسنْ: ”سْڒمْ ڒخُّو ثَارْجِيثْ-أَ نِّي ؤُرْجِيغْ.
\v 6 خْزَارْ، ثُوغَا نتّْشدَّا ثِيقبِّيضِينْ \add ن إِمنْذِي\add* ذِي ڒْوسْطْ ن ييَّارْ. ؤُ خْزَارْ، ثَاقبِّيضْثْ إِنُو ثْبدّْ، ثقِّيمْ ثْبدّْ ؤُ ثِيقبِّيضِينْ نْومْ نِّي ثُوغَا ذ أَسْ د-إِنّْضنْثْ، بنْذْقنْ إِ ثْقبِّيضْثْ إِنُو.“
\v 7 أَرِّينْ-د خَاسْ أَيْثْمَاسْ: ”مَا أَذْ ثْحكْمذْ \add زعْمَا\add* نِيشَانْ خَانغْ \add أَمْ ؤُجدْجِيذْ\add* نِيغْ أَذْ خَانغْ ثْسدْجْضذْ ذ أَسدْجضْ؟“ ؤُشَا شَارْهنْ ث عَاذْ كْثَارْ ذِي سِّيبّثْ ن ثِيرْجَا نّسْ ذ وَاوَاڒنْ نّسْ.
\v 8 ؤُشَا يُورْجَا عَاذْ ثَارْجِيثْ نّغْنِي، إِعَاوْذْ إِ-ت إِ يَايْثْمَاسْ، إِنَّا: ”خْزَارْ، أَرْجِيغْ عَاذْ ثَارْجِيثْ نّغْنِي. خْزَارْ ثَافُوشْثْ ذ ؤُيُورْ ذ حِيطَاشْ ن إِثْرَانْ بنْذْقنْ أَيِي.“
\v 9 إِعَاوذْ \add إِ-ت\add* إِ بَابَاسْ ذ أَيْثْمَاسْ ؤُشَا إِوبّخْ إِ-ث بَابَاسْ، إِنَّا أَسْ: ”مَانَا ثَارْجِيثْ-أَ إِ ثَارْجِيذْ؟ مَا أَذْ د-نَاسْ \add جْمِيعْ\add*، نشّْ ذ يمَّاشْ ذ أَيْثْمَاشْ، أَذْ أَشْ نْبنْذقْ غَارْ ثمُّورْثْ؟“
\v 10 أَيْثْمَاسْ ؤُسْمنْ زَّايسْ. مَاشَا بَابَاسْ إِعْقڒْ خْ وَاوَاڒنْ\add -أَ\add*. \x ◘ \xo 37:‏10 \xt ڒخ. 7‏:‏9. \x*
\m 
\v 11 ؤُشَا رُوحنْ أَيْثْمَاسْ، حِيمَا أَذْ أَروْسنْ ؤُدْجِي ن بَابَاثْسنْ غَارْ شَاكِيمْ.
\v 12 \add خنِّي\add* إِنَّا إِسْرَائِيل إِ يُوسُوفْ: ”مَا وَارْ أَروْسنْ أَيْثْمَاشْ \add ؤُدْجِي\add* غَارْ شَاكِيمْ؟ زِيذْ، أَذْ شكْ غَارْسنْ سّكّغْ.“ ؤُشَا يَارَّا-د خَاسْ: ”أَقَا أَيِي ذَا!“
\v 13 ؤُشَا إِنَّا أَسْ: ”رُوحْ شكْ، خْزَارْ مُوخَاسْ دْجَانْ أَيْثْمَاشْ ذ مُوخَاسْ دْجَانْ وُودْجِي ؤُشَا أَوِي أَيِي-د ڒخْبَارْ عَاوذْ.“ \add أَمُّو\add* إِ-ث إِسّكّْ زِي ڒوْضَا ن ثغْزُورْثْ ن حَابْرُونْ ؤُشَا نتَّا يِيوضْ-د غَارْ شَاكِيمْ.
\v 14 يُوفَا إِ-ث إِجّْ ن ورْيَازْ ؤُمِي إِودَّارْ ذڭْ إِيَّارْ. إِسّقْسَا ث ورْيَازْ، إِنَّا: ”مِينْ ثَارزُّوذْ؟“
\v 15 إِنَّا: ”أَرزُّوغْ خْ أَيْثْمَا. تّْزَاوْڭغْ شكْ، إِنِي أَيِي مَانِي أَروْسنْ.“
\v 16 أَرْيَازْ يَارَّا-د: ”أَقَا مُوطِّيينْ إِقِيضَانْ نْسنْ سَّا، نشّْ سْڒِيغْ أَسنْ قَّارنْ: ’أجّْ أَنغْ أَذْ نْرَاحْ غَارْ ذُوثَانْ.‘ “ \add ڒخْذنِّي\add* إِرُوحْ يُوسُوفْ أَوَارْنِي أَيْثْمَاسْ ؤُشَا يُوفَا إِ-ثنْ ذِي ذُوثَانْ. \f ◼ \fr 37:‏16 \ft \bd ’ذُوثَانْ‘\bd* - إِسمْ-أَ وَانِيثَا إِفّغْ-د زِي ثُوثْلَايْثْ ن إِكَالْذَانِييّنْ ؤُ إِخْسْ أَذْ يِينِي ’ثْنَاينْ ن وَانُوثنْ‘.\f*
\m 
\v 17 ؤُمِي ث ژْرِينْ زِي ڒَاڭّْوَاجْ، قْبڒْ مَا أَذْ غَارْسنْ د-إِقَارّبْ، مْعَاهَاذنْ ضِيدّْ نّسْ حِيمَا أَذْ ث نْغنْ،
\v 18 نَّانْ إِجّْ إِ ونّغْنِي: ”خْزَارْ، يُوسَا-د بُو-ثِيرْجَا نِّي!
\v 19 زِيذْ ڒخُّو، أجّْ أَنغْ أَذْ ث ننّغْ ؤُشَا أَذْ ث ننْضَارْ ذڭْ وَانُو، أَذْ نِينِي: ’شَا ن ڒْوحْشْ يوْعَارْ إِشَّا إِ-ث!‘، ؤُشَا \add خنِّي\add* أَذْ نْژَارْ مِينْ غَا إِڒِينْثْ ثِيرْجَا نّسْ.“
\v 20 إِسْڒَا رُوبِينْ مَانْ أَيَا ؤُشَا إِفكّْ إِ-ث زڭْ إِفَاسّنْ نْسنْ، إِنَّا: ”وَارْ ث نّقّْ شَا!“ \x ◘ \xo 37:‏20 \xt أَمز. 42‏:‏22. \x*
\v 21 إِنَّا أَسنْ \add عَاوذْ\add* رُوبِينْ: ”وَارْ سِيزِّيڒمْ إِذَامّنْ! نْضَارمْ ث ذڭْ وَانُو-يَا \add ذَا\add* ذِي ڒخْڒَا. وَارْ خَاسْ تّڭّمْ أَفُوسْ!“. إِنَّا أَمُّو حِيمَا أَذْ ث إِفكّْ زڭْ إِفَاسّنْ نْسنْ ؤُشَا أَذْ ث يَارّْ غَارْ بَابَاسْ.
\m 
\v 22 ؤُشَا إِمْسَارْ، ؤُمِي د-يِيوضْ يُوسُوفْ غَارْ أَيْثْمَاسْ، كّْسنْ نِيثْنِي أَرُّوضْ خْ يُوسُوفْ، أَرُّوضْ \add س إِفَاسّنْ ذ إِزِيرَارنْ\add* نِّي خَاسْ ثُوغَا،
\v 23 ؤُشَا طّْفنْ ث، نْضَارنْ ث ذڭْ وَانُو. \add مَاشَا\add* أَنُو ثُوغَا إِخْوَا، وَارْ ذَايسْ ثُوغِي شَا أَمَانْ.
\v 24 أَوَارْنِي مَانْ أَيَا قِّيمنْ مَاحنْذْ أَذْ شّنْ أَغْرُومْ، ؤُشَا ڒَامِي سّْڭعّْذنْ نِيثْنِي ثِيطَّاوِينْ نْسنْ، زْڒِينْ إِجّْ ن ؤُكَارَابَانْ ن إِسْمَاعِيلِييّنْ إِ د-يُوسِينْ زِي جِيلْعَاذْ. إِڒغْمَانْ نْسنْ أَرْبُونْ ڒعْطُورْ ذ ڒفْوَاهْ ن بَالْسَامْ ذ مِيرُّو، ڭُّورنْ أَذْ ث أَوْينْ غَارْ مِيصْرَا.
\v 25 \add خنِّي\add* إِنَّا يَاهُوذَا إِ يَايْثْمَاسْ: ”مَانْ ڒفْضڒْ مَاڒَا ننْغَا ؤُمَاثْنغْ ؤُشَا أَذْ نفَّارْ إِذَامّنْ نّسْ؟
\v 26 غَاوْرمْ، أَذْ ث نزّنْزْ إِ إِسْمَاعِيلِييّنْ، وَارْ إِتِّيڒِي ؤُفُوسْ نّغْ خَاسْ، أَقَا ذ ؤُمَاثْنغْ ذ أَيْسُومْ نّغْ.“ ؤُشَا سْڒِينْ أَيْثْمَاسْ غَارسْ.
\v 27 أَمْ د-عْذُونْ ثُوجَّارْ ن مِيذْيَانْ، سّْڭعّْذنْ-د يُوسُوفْ زڭْ وَانُو ؤُشَا زّنْزنْ ث س عِيشْرِينْ ن \add ؤُقِييَّاثْ ن\add* نُّوقَارْثْ إِ إِسْمَاعِيلِييّنْ، إِنِّي د-يِيوْينْ يُوسُوفْ غَارْ مِيصْرَا. \x ◘ \xo 37:‏27 \xt ڒقض. 8‏:‏24؛ إِزهد. 105‏:‏17؛ ڒخ. 7‏:‏9. \x*
\m 
\v 28 \add ڒَْامِي\add* د-إِذْوڒْ رُوبِينْ غَارْ وَانُو، وَارْ ذِينْ يُوفِي يُوسُوفْ عَاذْ ذڭْ وَانُو. \add خنِّي\add* إِشَارّڭْ أَرُّوضْ نّسْ.
\v 29 إِذْوڒْ غَارْ أَيْثْمَاسْ ؤُشَا إِنَّا: ”أَحنْجِيرْ وَارْ ذِينْ إِدْجِي \add عَاذْ\add*. إِ نشّْ، مَانِي غَا رَاحغْ؟“
\v 30 \add خنِّي\add* كْسِينْ أَرُّوضْ ن يُوسُوفْ ؤُشَا غَارْصنْ إِ يِيجّْ ن ؤُمْيَانْ زڭْ إِغَايْضنْ ؤُشَا مَارْغنْ أَرُّوضْ س إِذَامّنْ.
\v 31 سّكّنْ \add إِجّنْ\add* س أَرُّوضْ ذ لمْلِيحْ \add س إِفَاسّنْ ذ إِزِيرَارنْ\add*، جِّينْ ث أَذْ ث يَاوِي غَارْ بَابَاثْسنْ، نَّانْ: ”ذ وَا إِ نُوفَا. خْزَارْ ڒخُّو، مَا وَاهْ نِيغْ لَّا أَرُّوضْ ن مِّيشْ؟“
\v 32 ؤُشَا نتَّا إِعقْڒْ إِ-ث، إِنَّا: ”أَرُّوضْ ن مِّي إِ يدْجَا! شَا ن ڒْوحْشْ يوْعَارْ إِشَّا إِ-ث. يُوسُوفْ س ثِيذتّْ بتّْقنْ ث!“
\v 33 إِشَارّڭْ يَاعْقُوبْ أَرُّوضْ نّسْ ؤُشَا يَارْضْ إِشْثْ ن ثْخَانْشثْ \add ن وشْضَانْ\add* خْ ثجْعِينَّا نّسْ، إِشْضنْ خْ مِّيسْ أَطَّاسْ ن وُوسَّانْ.
\v 34 كَّارنْ مَارَّا إِحنْجِيرنْ نّسْ ذ مَارَّا ثِيحنْجِيرِينْ نّسْ مَاحنْذْ أَذْ ثعزَّانْ، عَاذْ نتَّا وَارْ إِخْسْ أَذْ إِتّْوَاعزَّا، إِنَّا: ”لَّ، أَذْ د-هْوِيغْ نُّورْيغْ غَارْ ڒَاخَارْثْ.“ ؤُشَا إِسْغُويْ خَاسْ بَابَاسْ. \x ◘ \xo 37:‏34 \xt أَمز. 42‏:‏38؛ 44‏:‏29، 31. \x*
\m 
\v 35 إِمِيذِييَانِييّنْ زّنْزنْ ث ذِي مِيصْرَا إِ بُوثِيفَارْ، أَمْسخَّارْ أَمْشنّعْ ن فِيرْعُونْ، ڒْقبْطَانْ ن إِعسَّاسنْ ن أَرِّيمثْ. \x ◘ \xo 37:‏35 \xt أَمز. 39‏:‏1؛ إِزهد. 105‏:‏17. \x*
\b
\b
\c 38
\s1 يَاهُوذَا ذ ثَامَارْ
\m 
\v 1 ذِي ڒْوقْثْ ذ إِشْثْ إِهْوَا يَاهُوذَا، \add إِفّغْ\add* خْ أَيْثْمَاسْ، ؤُشَا إِوْثَا \add إِقِيضَانْ نّسْ\add* غَارْ يِيجّْ ن ورْيَازْ ذ أَذُولَّامِيثِي ونِّي ؤُمِي قَّارنْ حِيرَا.
\v 2 ؤُشَا إِژْرَا ذِينْ يَاهُوذَا يدْجِيسْ ن يِيجّْ ن ورْيَازْ ذ أَكنْعَانِي ونِّي ؤُمِي قَّارنْ شُوعَا. ؤُشَا \add يَاهُوذَا\add* يِيوِي \add يدْجِيسْ ن شُوعَا\add* \add ذ ثَامْغَارْثْ\add*، ؤُشَا يُوذفْ خَاسْ. \x ◘ \xo 38:‏2 \xt 1 إِم. 2‏:‏3. \x*
\v 3 نتَّاثْ ثكْسِي س دّيْسثْ ؤُشَا ثُورُووْ-د أَحنْجِيرْ ؤُشَا \add يَاهُوذَا\add* إِڒَاغَا أَسْ عِيرْ.
\v 4 ؤُشَا ثكْسِي عَاوذْ س دّيْسثْ، ثُورُووْ-د أَحنْجِيرْ ؤُشَا ثْڒَاغَا أَسْ ؤُنَانْ.
\v 5 ؤُشَا ثُورُووْ-د عَاوذْ أَحنْجِيرْ ؤُشَا ثْڒَاغَا أَسْ شَايْلَا. نتَّا ثُوغَا-ث ذِي كَازِيبْ ؤُمِي ذ أَسْ ث-إِ-د-ثُورُووْ. \x ◘ \xo 38:‏5 \xt ڒخْڒ. 26‏:‏20. \x*
\v 6 يَاهُوذَا إِكْسِي ثَامْغَارْثْ إِ عِيرْ، أَمنْزُو نّسْ. ثَامْغَارْثْ-أَ قَّارنْثْ أَسْ ثَامَارْ.
\v 7 عِيرْ، أَمنْزُو ن يَاهُوذَا، ثُوغَا-ث ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي ؤُشَا إِنْغَا إِ-ث سِيذِي.
\v 8 \add خنِّي\add* إِنَّا يَاهُوذَا إِ ؤُنَانْ: ”أَذفْ خْ ثمْغَارْثْ ن ؤُمَاشْ، مْڒشْ أَكِيذسْ ذڭْ ومْشَانْ ن ؤُمَاشْ، ثجّذْ-د زَّارِيعثْ إِ ؤُمَاشْ.“
\v 9 \add مَاشَا\add* ؤُنَانْ إِسّنْ بلِّي زَّارِيعثْ وَارْ ثتِّيڒِي نّسْ. ؤُشَا أَمُّو إِمْسَارْ، ؤُمِي يُوذفْ خْ ثمْغَارْثْ ن ؤُمَاسْ، إِنْغڒْ \add زَّارِيعثْ نّسْ\add* ذِي ثمُّورْثْ، حِيمَا وَارْ إِتِّيشْ زَّارِيعثْ إِ ؤُمَاسْ.
\v 10 مِينْ إِڭَّا ثُوغَا ذ أَعفَّانْ ذِي ثِيطَّاوِينْ ن سِيذِي ؤُشَا إِنْغَا إِ-ث ؤُڒَا ذ نتَّا.
\m 
\v 11 \add خنِّي\add* إِنَّا يَاهُوذَا إِ ثَامَارْ، ثَاسْڒِيثْ نّسْ: ”قِّيمْ \add أَمْ\add* ثَاجَّاتْشْ ذِي ثَادَّارْثْ ن بَابَامْ، أَڒْ غَا إِمْغَارْ مِّي شَايْلَا!“، مِينْزِي إِنَّا: ”أَقَا وَارْ إِتّْمتِّي ؤُڒَا ذ وَا أَمْ يَايْثْمَاسْ.“ ؤُشَا ثْرُوحْ ثَامَارْ، ثزْذغْ ذِي ثَادَّارْثْ ن بَابَاسْ.
\m 
\v 12 عْذُونْ وُوسَّانْ أَطَّاسْ، خنِّي ثمُّوثْ يدْجِيسْ ن شُوعَا، ثَامْغَارْثْ ن يَاهُوذَا. يَاهُوذَا يَارزُّو أَذْ إِتّْوَاعزَّا ؤُشَا إِڭعّذْ غَارْ ثْحِيمَارْثْ ن وُودْجِي نّسْ غَارْ ثِيمْنَاثَا، نتَّا ذ حِيرَا، أَمدُّوكّڒْ نّسْ زِي أَذُولَّامْ.
\v 13 عڒْمنْ ث إِ ثَامَارْ، نَّانْ: ”خْزَارْ، أَضڭّْوَاڒْ نّمْ إِڭعّذْ غَارْ ثِيمْنَاثَا، أَذْ إِڒْسْ ؤُدْجِي نّسْ.“
\v 14 \add خنِّي\add* ثكّسْ خَاسْ أَرُّوضْ ن ثَاجَّاتْشْ، ثْڒحّفْ س ثْكنْبُوشْثْ، ثسْڒحْهفْ إِخفْ نّسْ زَّايسْ، ؤُشَا ثْرُوحْ أَذْ ثقِّيمْ غَارْ وَاذَافْ ن عَايْنَايِيمْ، ونِّي إِدْجَانْ ذڭْ وبْرِيذْ غَارْ ثِيمْنَاثَا، مِينْزِي ثژْرَا شَايْلَا إِمْغَارْ، ؤُ نتَّاثْ ثُوغَا وَارْ ذ أَسْ ثمّوْشْ ذ ثَامْغَارْثْ.
\v 15 ؤُشَا إِژْرَا إِ-ت يَاهُوذَا، إِحسْبْ إِ-ت ذ لْفَاسْذَا، مِينْزِي ثُوغَا-ت ثْڒحّفْ إِ ؤُغمْبُوبْ نّسْ.
\v 16 ؤُشَا إِميّڒْ غَارسْ غَارْ وبْرِيذْ، إِنَّا أَسْ: ”أجّْ أَيِي أَذْ خَامْ أَذْفغْ!“، مِينْزِي نتَّا ثُوغَا وَارْ إِسِّينْ، بلِّي نتَّاثْ ذ ثَاسْڒِيثْ نّسْ. نتَّاثْ ثنَّا: ”مِينْ ذ أَيِي غَا ثوْشذْ، حِيمَا أَذْ خَافِي ثَاذْفذْ؟“
\v 17 يَارَّا-د: ”نشّْ أَذْ \add أَمْ\add*-د سّكّغْ إِجّْ ن إِغَايْضْ ذ أَمژْيَانْ زڭْ إِغَايْضنْ، زڭْ وُودْجِي.“ ثنَّا أَسْ: ”مْغِيرْ أوْشْ أَيِي إِجّْ ن وَارْهَانْ أَڒْ ذ أَيِي ث-إِ-د ثسّكّذْ.“
\v 18 إِنَّا: ”مَانْ أَضْمَانْ إِ ذ أَمْ إِ غَا وْشغْ؟“ نتَّاثْ ثنَّا: ”ثَاخَاذنْثْ نّشْ ن ؤُشمِّيعْ ذ تّسْبِيحْ نّشْ ذ ثَاغَّارْشْثْ إِ غَاركْ ذڭْ ؤُفُوسْ.“ ؤُشَا إِوْشَا أَسْ ثنْ، يُوذفْ خَاسْ ؤُشَا ثكْسِي زَّايسْ دّيْسثْ.
\v 19 ؤُشَا ثكَّارْ، ثْرُوحْ، ثكّسْ خَاسْ ثَاكنْبُوشْثْ نّسْ ؤُشَا ثْيَارْضْ أَرُّوضْ نّسْ ن ثَاجَّاتْشْ.
\m 
\v 20 ؤُشَا إِسّكّْ يَاهُوذَا إِغَايْضْ ذ أَمژْيَانْ زڭْ إِغَايْضنْ خْ ؤُفُوسْ ن ؤُمدُّوكّڒْ نّسْ أَذُولَّامِي، حِيمَا أَذْ إِطّفْ \add عَاوذْ\add* أَضْمَانْ زڭْ ؤُفُوسْ ن ثمْغَارْثْ، \add مَاشَا\add* وَارْ ت يُوفِي.
\v 21 إِسّقْسَا إِرْيَازنْ خْ ومْشَانْ نّسْ، إِنَّا: ” مَانِي ثدْجَا ثمْغَارْثْ ن فَارْقْ-شّْغڒْ نِّي ثُوغَا إِقِّيمنْ خْ وبْرِيذْ غَارْ عَانَايِيمْ؟“ نِيثْنِي أَرِّينْ-د خَاسْ: ”وَارْ ذَا ثُوغِي قَاعْ شَا ن ثمْغَارْثْ ن فَارْقْ-شّْغڒْ غَارْ زَّاوشْثْ.“
\v 22 \add خنِّي\add* إِعْقبْ-د غَارْ يَاهُوذَا، إِنَّا: ”وَارْ ت ؤُفِيغْ شَا، ؤُڒَا ذ إِرْيَازنْ ن ومْشَانْ \add نِّي\add* نَّانْ: ’وَارْ ذَا ثُوغِي قَاعْ شَا ن ثمْغَارْثْ ن فَارْقْ-شّْغڒْ \add غَارْ زَّاوشْثْ\add*.‘ “
\v 23 ؤُشَا إِنَّا يَاهُوذَا: ”أجّْ إِ-ت أَذْ ثطّفْ \add أَضْمَانْ\add* غَارسْ، حِيمَا وَارْ نتِّيڒِي ذ ڒْعَارْ. خْزَارْ، نشّْ أَقَا سّكّغْ إِغَايْضْ-أَ ذ أَمژْيَانْ، \add مَاشَا\add* شكْ وَارْ ت ثُوفِيذْ.“
\m 
\v 24 عْڒَاحَاڒْ أَوَارْنِي ثْڒَاثَا ن إِيُورنْ ثمْسَارْ، أَقَا خبَّارنْ يَاهُوذَا، نَّانْ: ”ثَامَارْ، ثَاسْڒِيثْ نّشْ، أَقَا ثسّفْسذْ إِخفْ نّسْ ؤُشَا ڒخُّو نتَّاثْ أَقَا-ت س دّيْسثْ س فَارْقْ-شّْغڒْ \add نّسْ\add*.“ \add خنِّي\add* إِنَّا يَاهُوذَا: ”سُوفّْغمْ ت-إِ-د، أَذْ ثشْمضْ!“
\v 25 ؤُمِي ت-إِ-د-يِيوْينْ غَارْ بَارَّا، ثسّكّْ-د \add إِجّنْ\add* غَارْ ؤُضڭّْوَاڒْ نّسْ، مَاحنْذْ أَذْ يِينِي: ”زڭْ ورْيَازْ ن ڒحْوَايجْ-أَ، أَقَا كْسِيغْ س دّيْسثْ.“ ثنَّا عَاذْ: ”أَرْزُو خنِّي وِي إِڒَانْ ثَاخَاذنْثْ-أَ ن ؤُشمِّيعْ ذ تّسْبِيحِينْ-أَ ذ ثَاغَّارْشْثْ-أَ.“
\v 26 يَاهُوذَا إِعقْڒْ \add إِ-ثنْثْ\add*، إِنَّا: ”أَقَا-ت ذ نِيشَانْ خَافِي، مِينْزِي وَارْ ت وْشِيغْ \add ذ ثَامْغَارْثْ\add* إِ شَايْلَا مِّي.“ وَارْ إِقِّيمْ إِسّنْ إِ-ت \add عَاذْ\add*.
\m 
\v 27 ذِي ڒْوقْثْ ؤُمِي د-ثِيوضْ أَذْ د-ثَارُووْ، أَقَا ذَا أَشْنِيونْ ذڭْ ؤُعذِّيسْ نّسْ. \x ◘ \xo 38:‏27 \xt 1 إِم. 2‏:‏4. \x*
\v 28 إِمْسَارْ ؤُمِي د-ثُورُووْ، إِسُّوفّغْ-د إِجّنْ أَفُوسْ ؤُشَا ثكْسِي ث ڒْقَابْڒَا ؤُشَا ثْشدّْ إِ-ث غَارْ ؤُفُوسْ نّسْ س ؤُفِيڒُو ذ أَزڭّْوَاغْ، ثنَّا: ”وَا إِ د-إِفّْغنْ ذ أَمزْوَارْ.“
\v 29 ڒَامِي د يَارَّا أَفُوسْ نّسْ، إِبَانْ-د ؤُمَاسْ، ؤُشَا ثنَّا: ”مَامّشْ ثڭِّيذْ ثَازِّيثْ. \add أَذْ ثِيڒِيذْ\add* ذ بُو-إِتَّارژَّانْ!“ ؤُشَا سمَّانْ ث فَارِيصْ. \f ◼ \fr 38:‏29 \ft \bd ’فَارِيصْ‘\bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَنُوفْسڒْ‘.\f*  \x ◘ \xo 38:‏29 \xt مِيخَا 2‏:‏13؛ مت. 1‏:‏3\x*
\v 30 أَوَارْنِي مَانْ أَيَا إِفّغْ-د ؤُمَاسْ، ونِّي غَارْ إِدْجَا ؤُفِيڒُو أَزڭّْوَاغْ ذڭْ ؤُفُوسْ نّسْ ؤُشَا إِسمَّا ث زَارَاحْ. \f ◼ \fr 38:‏30 \ft \bd ’زَارَاحْ‘\bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَزڭّْوَاغْ‘ نِيغْ ’ونِّي يَارقّنْ‘.\f*
\b
\b
\c 39
\s1 يُوسُوفْ أَمحْضَايْ خْ ثَادَّارْثْ ن بُوثِيفَارْ
\m 
\v 1 نذْهنْ \add خنِّي\add* يُوسُوفْ غَارْ مِيصْرَا. بُوثِيفَارْ، أَمْسخَّارْ أَمْشنّعْ ن فِيرْعُونْ، ڒْقبْطَانْ ن إِعسَّاسنْ ن أَرِّيمثْ، إِجّْ ن ؤُمِيصْرِي، إِسْغَا إِ-ث زڭْ ؤُفُوسْ ن إِسْمَاعِيلِييّنْ، إِنِّي ذِينْ ث يِيوْينْ. \x ◘ \xo 39:‏1 \xt أَمز. 37‏:‏27؛ إِزهد. 105‏:‏17. \x*
\v 2 ثُوغَا سِيذِي أَكْ-ذ يُوسُوفْ. ثُوغَا نتَّا ذ أَرْيَازْ إِفْڒحْ ؤُشَا ثُوغَا-ث ذِي ثَادَّارْثْ ن سِيذِيسْ، أَمِيصْرِي. \x ◘ \xo 39:‏2 \xt ڒخ. 7‏:‏9. \x*
\v 3 إِژْرَا سِيذِيسْ بلِّي سِيذِي ثُوغَا-ث أَكِيذسْ ؤُ بلِّي سِيذِي إِسّكّْوَاضْ س ؤُفُوسْ نّسْ مَارَّا مِينْ ثُوغَا إِتّڭّْ.
\m 
\v 4 \add أَمُّو إِ\add* يُوفَا يُوسُوفْ أَرْضَا ذِي ثِيطَّاوِينْ نّسْ، إِسخَّارْ أَسْ. ؤُشَا إِڭَّا إِ-ث \add بُوثِيفَارْ\add* ذ أَمحْضَايْ خْ ثَادَّارْثْ نّسْ ؤُشَا إِڭَّا أَسْ ذڭْ ؤُفُوسْ نّسْ مَارَّا مِينْ غَارسْ.
\v 5 زڭْ وَاسّْ مِينْ ذِي ث إِڭَّا خْ ثَادَّارْثْ نّسْ ؤُ خْ مَارَّا مِينْ غَارسْ، إِبَارْكْ سِيذِي ثَادَّارْثْ ن ؤُمِيصْرِي ذِي طّْوعْ ن يُوسُوفْ. ثُوغَا لْبَارَاكَا ن سِيذِي خْ مَارَّا مِينْ غَارسْ، \add أَمْ\add* ذَاخڒْ ن ثَادَّارْثْ، \add أَمْ بَارَّا\add* ذڭْ إِيَّارْ.
\v 6 مَارَّا مِينْ غَارسْ، إِجَّا إِ-ث ذڭْ إِفَاسّنْ ن يُوسُوفْ، أَڒْ وَارْ إِسِّينْ نتَّا شَا كْثَارْ مْغِيرْ أَغْرُومْ إِ إِتّتّْ.
\m ثُوغَا يُوسُوفْ إِشْنَا ذڭْ وَادُّوذْ ؤُ ؤُذمْ نّسْ ذَايسْ أَژْرِي.
\v 7 إِمْسَارْ أَوَارْنِي مَانْ أَيَا، أَقَا ثَامْغَارْثْ ن سِيذِيسْ ثنْضَارْ ثِيطَّاوِينْ نّسْ ذِي يُوسُوفْ، ثنَّا: ”زِيذْ، طّصْ أَكِيذِي.“ \x ◘ \xo 39:‏7 \xt أَوڒن. 7‏:‏13. \x*
\v 8 \add مَاشَا\add* نتَّا يُوڭِي، إِنَّا إِ ثمْغَارْثْ ن سِيذسْ: ”خْزَارْ، سِيذِي إِنُو وَارْ إِسِّينْ مِينْ إِدْجَانْ ذِي ثَادَّارْثْ ڒَامِي ذَا أَكِيذسْ دْجِيغْ. مَارَّا مِينْ غَارسْ، إِڭَّا إِ-ث ذڭْ ؤُفُوسْ إِنُو.
\v 9 نتَّا وَارْ إِدْجِي سنّجْ إِنُو ذِي ثَادَّارْثْ-أَ، وَارْ ذ أَيِي إِطِّيفْ س وَالُو مْغِيرْ شمْ، ؤُمِي ثدْجِيذْ ذ ثَامْغَارْثْ نّسْ. مَامّشْ إِ غَا ڭّغْ لْجَارِيمَا-يَا ثَامقّْرَانْثْ أَمْ ثَانِيثَا ؤُشَا أَذْ ڭّغْ دّنْبْ أَكْ-ذ أَربِّي!“
\v 10 ثُوغَا ثسَّاوَاڒْ أَكْ-ذ يُوسُوفْ كُوڒْ أَسّْ، وَارْ غَارسْ إِتّسْڒِي، حِيمَا أَذْ إِطّصْ طَّارْفْ نّسْ ؤُ حِيمَا أَذْ أَكِيذسْ يِيڒِي.
\m 
\v 11 ذڭْ \add إِجّْ ن\add* وَاسّْ ثمْسَارْ، ؤُمِي د-يُوذفْ غَارْ ثَادَّارْثْ، حِيمَا أَذْ إِڭّْ ڒْخذْمثْ نّسْ، وَارْ ثُوغِي \add ذِينْ\add* ؤُڒَا ذ إِجّْ زڭْ يرْيَازنْ ن ثَادَّارْثْ.
\v 12 \add خنِّي\add* ثطّفّْ إِ-ث زڭْ وَارُّوضْ نّسْ، ثنَّا: ”أَرَاحْ-د زّڒْ أَكِيذِي!“ \add ڒخْذنِّي\add* إِجَّا أَسْ نتَّا أَرُّوضْ نّسْ ذڭْ ؤُفُوسْ، يَارْوڒْ، إِفّغْ بَارَّا.
\v 13 ؤُمِي ثژْرَا بلِّي إِجَّا أَسْ أَرُّوضْ نّسْ ذڭْ ؤُفُوسْ نّسْ، يَارْوڒْ غَارْ بَارَّا،
\v 14 ثْڒَاغَا إِ أَيْثْبَابْ ن ثَادَّارْثْ، ثنَّا أَسنْ: ”خْزَارمْ، أَقَا نتَّا يِيوْيْ أَنغْ-د أَرْيَازْ أَعِيبْرَانِي، حِيمَا أَذْ خَانغْ إِضْحشْ. يُوسَا-د غَارِي، حِيمَا أَكِيذِي إِطّصْ ؤُشَا نشّْ سْغُويغْ س جّهْذْ.
\v 15 ؤُمِي إِسْڒَا بلِّي سّْڭعّْذغْ ثْمِيجَّا إِنُو ؤُشَا سْغُويغْ، إِجَّا غَارِي أَرُّوضْ نّسْ، يَارْوڒْ، إِفّغْ بَارَّا.“
\v 16 ؤُشَا نتَّاثْ ثڭَّا أَرُّوضْ نّسْ زَّاثسْ، أَڒْ د غَا يَاسْ سِيذِيسْ غَارْ ثَادَّارْثْ.
\v 17 \add خنِّي\add* ثسِّيوڒْ أَكِيذسْ س وَاوَاڒنْ نِّي ذ إِجّنْ، ثنَّا: ”أَمْسخَّارْ أَعِيبْرَانِي ونِّي د-ثِيوْيذْ غَارْنغْ، يُوسَا-د غَارِي حِيمَا أَذْ أَيِي إِسّْعُورَّا.
\v 18 \add ؤُمِي\add* سّْڭعّْذغْ ثْمِيجَّا إِنُو، سْغُويغْ، إِجَّا أَرُّوضْ نّسْ غَارِي ؤُشَا يَارْوڒْ بَارَّا.“
\v 19 سِيذسْ إِسْڒَا إِ وَاوَاڒنْ إِنِّي ذ أَسْ ثنَّا ثمْغَارْثْ نّسْ، ثنَّا: ”أَمُّو إِ ذ أَيِي إِڭَّا ؤُمْسخَّارْ نّشْ!“، ؤُشَا إِخيّقْ أَطَّاسْ.
\v 20 إِطّفْ إِ-ث سِيذِي ن يُوسُوفْ، إِڭَّا إِ-ث ذِي ڒحْبسْ، مَانِي ثُوغَا إِمحْبَاسْ ن ؤُجدْجِيذْ. أَمُّو إِ إِقِّيمْ ذِي ڒحْبسْ. \x ◘ \xo 39:‏20 \xt إِزهد. 105‏:‏18. \x*
\b
\m 
\v 21 مَاشَا سِيذِي ثُوغَا-ث أَكْ-ذ يُوسُوفْ ؤُشَا إِسّْوِيژّضْ غَارسْ س ثْمخْسِيوْثْ نّسْ إِشوَّارنْ ؤُشَا إِوْشَا أَسْ أَرْضَا نّسْ ذِي ثِيطَّاوِينْ ن ؤُمقّْرَانْ ن ڒحْبسْ.
\v 22 ؤُشَا أَمقّْرَانْ ن ڒحْبسْ يَارَّا مَارَّا إِمحْبَاسْ نِّي ثُوغَا ذِي ڒحْبسْ سَاذُو ؤُفُوسْ ن يُوسُوفْ. مَارَّا مِينْ ثُوغَا تّڭّنْ ذِينْ ثُوغَا إِتّكّْ خْ ؤُفُوسْ نّسْ.
\v 23 أَمقّْرَانْ ن ڒحْبسْ وَارْ ذ أَسْ إِقِّيمْ مِينْ خفْ غَا إِنّهْوڒْ زِي مِينْ ثُوغَا سَاذُو ؤُفُوسْ نّسْ، مِينْزِي سِيذِي ثُوغَا أَكْ-ذ يُوسُوفْ. مِينْ مَا ثُوغَا إِتّڭّْ نتَّا، سِيذِي إِسّكّْوَاضْ إِ-ث.
\b
\b
\c 40
\s1 يُوسُوفْ إِفسَّارْ ثْنَاينْ ن ثِيرْجَا
\m 
\v 1 إِمْسَارْ أَوَارْنِي مَانْ أَيَا بلِّي أَوَارَّاذْ ن ؤُجدْجِيذْ ن مِيصْرَا ذ ؤُخبَّازْ ذنّْبنْ ضِيدّْ إِ سِيذِيثْسنْ، أَجدْجِيذْ ن مِيصْرَا. \f ◼ \fr 40:‏1 \ft \bd ’أَوَارَّاذْ‘\bd* - ونِّي إِقدّْمنْ ڒْكَاسْ إِ ؤُجدْجِيذْ أَوَارْنِي إِقدْجبْ إِ-ث ذ أَمزْوَارُو.\f*
\v 2 إِفُّوڭمْ فِيرْعُونْ خْ ثْنَاينْ ن إِمْسخَّارنْ إِشنّْعنْ نّسْ، خْ ؤُمقّْرَانْ ن إِوَارَّاذنْ ؤُ خْ ؤُمقّْرَانْ ن إِخبَّازنْ.
\v 3 إِڭَّا إِ-ثنْ ذڭْ ؤُحطُّو ذِي ثَادَّارْثْ ن ڒْقبْطَانْ ن إِعسَّاسنْ ن أَرِّيمثْ، ذِي ثَادَّارْثْ ن ثْعسَّاسْثْ، مَانِي إِحبّسْ يُوسُوفْ.
\v 4 ڒْقبْطَانْ ن إِعسَّاسنْ ن أَرِّيمثْ إِڭَّا يُوسُوفْ ذ أَمحْضَايْ نْسنْ، ؤُشَا نتَّا ثُوغَا إِتّْسخَّارْ خَاسنْ. \add أَمُّو\add* ثُوغَا أَثنْ ؤُسَّانْ \add ذ إِزِيرَارنْ\add* ذِي ڒحْبسْ.
\v 5 ؤُرْجِينْ ثَارْجِيثْ س ثْنَاينْ إِذْسنْ نْسنْ، كُوڒْ إِجّنْ زَّايْسنْ يُورْجَا ذِي دْجِيڒثْ نِّي ثَارْجِيثْ نّسْ س ڒْمعْنَا نّسْ، أَمْ ؤُوَارَّاذْ أَمْ ؤُخبَّازْ ن ؤُجدْجِيذْ ن مِيصْرَا، إِنِّي ثُوغَا إِتّْوَاحبّْسنْ ذِي ثَادَّارْثْ ن ثْعسَّاسْثْ.
\m 
\v 6 ؤُشَا يُوسَا-د غَارْسنْ يُوسُوفْ خْ صّْبحْ، إِخْزَارْ ذَايْسنْ ؤُشَا إِژْرَا إِ-ثنْ تّْقلّْقنْ.
\v 7 \add ڒخْذنِّي\add* إِسّقْسَا نتَّا إِمْسخَّارنْ إِشنّْعنْ ن فِيرْعُونْ، إِنِّي ثُوغَا أَكِيذسْ ذِي ڒحْبسْ ذِي ثَادَّارْثْ ن سِيذِيسْ، إِنَّا: ”مَاغَارْ بَارشْننْ ؤُذْمَاونْ نْومْ أَسّْ-أَ قَاعْ أَمُّو؟“
\v 8 نِيثْنِي نَّانْ: ”أَقَا نُورْجَا ثَارْجِيثْ، وَارْ ذَا وِي ت غَا إِفكّنْ.“ إِنَّا أَسنْ يُوسُوفْ: ”مَا وَارْ دْجِينْ شَا إِفسَّارنْ زِي أَربِّي؟ إِوَا، عَاوْذمْ أَيِي ثنْثْ ڒخُّو!“
\m 
\v 9 \add خنِّي\add* إِعَاوذْ ؤُمقّْرَانْ ن إِوَارَّاذنْ ثَارْجِيثْ نّسْ إِ يُوسُوفْ، إِنَّا أَسْ: ”نشّْ ذِي ثَارْجِيثْ إِنُو ژْرِيغْ ثَازَايَارْثْ زَّاثِي ثْبدّْ.
\v 10 ثَازَايَارْثْ \add نِّي\add* غَارسْ ثْڒَاثَا ن ثْسضْوِينْ. \add خْمِي\add* ثسّنْذِييْ، إِتّْڭعَّاذْ نُّووَّارْ نّسْ ؤُ غَارْ إِزكُّوننْ نّسْ إِبَانْ-د ڒْحبّْ ن ؤُضِيڒْ يِيوضْ.
\v 11 ؤُشَا ڒْكَاسْ ن فِيرْعُونْ ثُوغَا-ث غَارِي ذڭْ ؤُفُوسْ إِنُو ؤُشَا كْسِيغْ أَضِيڒْ نِّي ؤُشَاعسَّارغْ ث ذِي ڒْكَاسْ ن فِيرْعُونْ ؤُشَا سّعْذُوغْ ڒْكَاسْ غَارْ ؤُفُوسْ ن فِيرْعُونْ.“
\v 12 إِنَّا أَسْ يُوسُوفْ: ”ذ وَا ذ أَفسَّارْ نّسْ: ثْڒَاثَا ن ثِيسضْوِينْ، أَقَا ذ ثْڒَاثَا ن وُوسَّانْ.
\v 13 عَاذْ ثْڒَاثَا ن وُوسَّانْ \add خنِّي\add* أَذْ أَشْ إِسّْڭعّذْ فِيرْعُونْ أَزدْجِيفْ نّشْ ؤُشَا أَذْ شكْ يَارّْ غَارْ ثْسخَّارْثْ نّشْ، أَذْ ثسّعْذُوذْ ڒْكَاسْ إِ فِيرْعُونْ ذڭْ ؤُفُوسْ نّسْ، أَمْ مَامّشْ ثُوغَا ثَاسْغَارْثْ نّشْ زِيشْ ڒَامِي شكْ ثُوغَا ذ أَوَارَّاذْ نّسْ.
\v 14 مَاشَا عْقڒْ خَافِي خْمِي ذ أَشْ د غَا يَاسْ ڒْخَارْ، تّْزَاوَاڭغْ شكْ أَذْ كِيذِي ثڭّذْ س ثْمخْسِيوْثْ إِشوَّارنْ ؤُشَا أجّْ فِيرْعُونْ أَذْ خَافِي إِعْقڒْ ؤُشَا فكّْ أَيِي-د زِي ثَادَّارْثْ-أَ.
\v 15 مِينْزِي ؤُشَارنْ أَيِي زِي ثمُّورْثْ ن إِعِيبْرَانِييّنْ ؤُ ذَا وَارْ ڭِّيغْ خْ مِينْ خفْ ذَايِي إِ غَا ڭّنْ ذڭْ وحْفُورْ \add ن إِمحْبَاسْ\add*.“
\m 
\v 16 \add ڒَْامِي\add* إِژْرَا ؤُمقّْرَانْ ن إِخبَّازنْ بلِّي إِفسَّارْ أَسْ مْلِيحْ، إِنَّا إِ يُوسُوفْ: ”ؤُڒَا ذ نشّْ ژْرِيغْ ذِي ثَارْجِيثْ إِنُو ثْڒَاثَا ن ثْسُودْجَاثِينْ س وغْرُومْ ذ أَشمْڒَاڒْ خْ ؤُزدْجِيفْ إِنُو.
\v 17 ذِي ثْسُودْجثْ ن سنّجْ ثُوغَا ذَايسْ أَطَّاسْ ن مَاشَّا إِ فِيرْعُونْ إِ إِڭَّا ؤُخبَّازْ ؤُ إِجْضَاضْ تّتّنْ زِي ثْسُودْجثْ إِ إِدْجَانْ خْ ؤُزدْجِيفْ إِنُو.“
\v 18 يَارَّا-د \add خَاسْ\add* يُوسُوفْ، إِنَّا: ”ذ وَا ذ أَفسَّارْ نّسْ. ثْڒَاثَا ن ثْسُودْجَاثِينْ ذ ثْڒَاثَا ن وُوسَّانْ.
\v 19 عَاذْ ثْڒَاثَا ن وُوسَّانْ \add خنِّي\add* أَذْ خَاكْ إِسّْڭعّذْ فِيرْعُونْ أَزدْجِيفْ نّشْ \add جْمِيعْ أَكِيكْ\add* ؤُشَا أَذْ شكْ يَايڒْ خْ إِشْثْ ن ثْشجَّارْثْ ؤُ إِجْضَاضْ أَذْ شّنْ أَيْسُومْ نّشْ.“ \f ◼ \fr 40:‏19 \ft \bd ’ثَاشجَّارْثْ‘\bd* - نِيغْ ’أَدَّاڭْ‘ (’إِدَّاڭنْ‘).\f*
\m 
\v 20 ذڭْ وَاسّْ وِيسّْ ثْڒَاثَا، أَسّْ ن وخْڒَاقْ ن فِيرْعُونْ، إِمْسَارْ بلِّي إِسّوْجذْ إِشْثْ ن زَّارْذثْ إِ مَارَّا إِمْسخَّارنْ نّسْ ؤُشَا إِسّْڭعّذْ أَزدْجِيفْ ن ؤُمقّْرَانْ ن إِوَارَّاذنْ ؤُ أَزدْجِيفْ ن ؤُمقّْرَانْ ن إِخبَّازنْ ثُوغَا-ث جَارْ إِمْسخَّارنْ نّسْ.
\v 21 ؤُشَا نتَّا يَارَّا أَمقّْرَانْ ن إِوَارَّاذنْ غَارْ ڒْخذْمثْ نّسْ ن ؤُوَارَّاذْ، أَڒَامِي وَانِيثَا إِوْشَا \add عَاوذْ\add* أَغَارَّافْ ذڭْ ؤُفُوسْ ن فِيرْعُونْ.
\v 22 \add مَاشَا\add* أَمقّْرَانْ ن إِخبَّازنْ يُويڒْ إِ-ث، أَمْ مَامّشْ ذ أَسْ إِفسَّارْ يُوسُوفْ.
\v 23 مَاشَا أَمقّْرَانْ ن إِوَارَّاذنْ وَارْ إِفكَّارْ شَا \add عَاذْ\add* ذِي يُوسُوفْ، إِتُّو ث.
\b
\b
\c 41
\s1 ثَارْجِيثْ ن فِيرْعُونْ
\m 
\v 1 أَوَارْنِي ڒَامِي عْذُونْ ثْنَاينْ ن إِسڭّْوُوسَا يُورْجَا فِيرْعُونْ أَقَا نتَّا زعْمَا إِبدّْ خْ يغْزَارْ \add ن نِيلْ\add*.
\v 2 خْزَارْ، ڭعّْذنْثْ-إِ-د سبْعَا ن ثْفُونَاسِينْ زڭْ إِغْزَارْ، صبْحنْثْ إِ ڒْخزْرَاثْ ؤُعمَّارنْثْ س ويْسُومْ، هدَّانْثْ جَارْ وحْثِيشْ ن ؤُغَانِيمْ.
\v 3 ؤُ خْزَارْ، سبْعَا ن ثْفُونَاسِينْ نّغْنِي ڭعّْذنْثْ-إِ-د أَوَارْنِي أَسنْثْ زڭْ إِغْزَارْ. نِيثنْثِي وَارْ حْڒِينْثْ إِ ڒْخزْرَاثْ، أَقَا كُّوشّْضنْثْ ؤُشَا بدّنْثْ زَّاثْ إِ ثْفُونَاسِينْ نّغْنِي غَارْ ثْمَا ن إِغْزَارْ.
\v 4 ثِيفُونَاسِينْ إِ وَارْ إِحْڒِينْ إِ ڒْخژْرَاثْ، ثِينِّي إِكُوشّْضنْ، صَارْضنْثْ سبْعَا ن ثْفُونَاسِينْ إِصبْحنْ إِ ڒْخزْرَاثْ، ثِينِّي إِصحّنْ. ؤُشَا إِفَاقْ-د فِيرْعُونْ.
\m 
\v 5 إِطّصْ \add عَاوذْ\add* ؤُشَا يُورْجَا ثْوَاڒَا نّغْنِي، ؤُ خْزَارْ، زڭْ إِشْثْ ن ثْسطَّا ڭعّْذنْثْ سبْعَا ن ثِيذْرِينْ شُّورنْثْ، شْنَانْثْ.
\v 6 ؤُ خْزَارْ،غمْينْثْ-إِ-د سبْعَا ن ثِيذْرِينْ قُّوسْبَارنْ أَوَارْنِي أَسنْثْ، إِسّْشمْضْ إِ-ثنْثْ ؤُسمِّيضْ أَشَارْقِي.
\v 7 سبْعَا ن ثِيذْرِينْ قُّوسْبَارنْثْ صَارْضنْثْ سبْعَا ن ثِيذْرِينْ إِيْمَانْ ذ إِشُّورنْ. ؤُشَا إِفَاقْ-د فِيرْعُونْ، ؤُ خْزَارْ، أَقَا ذ إِشْثْ ن ثرْجِيثْ.
\m 
\v 8 غَارْ صّْبحْ إِبَانْ-د بلِّي بُوحْبڒْ نّسْ إِنّهْوڒْ ؤُشَا إِسّكّْ مَاحنْذْ أَذْ د-ڒَْاغَانْ إِ مَارَّا ثَارْوَا ن ثْسحَّارْثْ ن مِيصْرَا ؤُ إِ مَارَّا إِمِيغِيسنْ. إِعَاوْذْ أَسنْ فِيرْعُونْ ثَارْجِيثْ نّسْ، مَاشَا وَارْ ذِينْ ثُوغِي حذْ إِزمَّارْ أَذْ \add ت\add* إِفسَّارْ إِ فِيرْعُونْ.
\v 9 إِسِّيوڒْ  ؤُمقّْرَانْ ن إِوَارَّاذنْ أَكْ-ذ فِيرْعُونْ، إِنَّا: ”ذڭْ وَاسّْ-أَ أَذْ تّْوَاسْعقْڒغْ خْ دّْنُوبْ إِنُو.
\v 10 \add ؤُمِي\add* إِفُّوڭمْ فِيرْعُونْ خْ إِمْسخَّارنْ نّسْ، إِڭَّا أَيِي ذِي ڒحْبسْ ذِي ثَادَّارْثْ ن ڒْقبْطَانْ ن إِعسَّاسنْ ن أَرِّيمثْ، \add أَمْ\add* نشّْ \add أَمْ\add* ؤُمقّْرَانْ ن إِخبَّازنْ.
\v 11 نشّْ ذ نتَّا نُورْجَا إِشْثْ ن ثَارْجِيثْ ذِي دْجِيرثْ ذ إِشْثْ. كُوڒْ إِجّْ زَّايْنغْ يُورْجَا ثَارْجِيثْ نّسْ س ڒْمعْنَا نّسْ. \x ◘ \xo 41:‏11 \xt دَان. 2‏:‏2. \x*
\v 12 ثُوغَا ذِينْ أَكِيذْنغْ إِجّْ ن ؤُبْڒِيغْ ذ أَعِيبْرَانِي. ثُوغَا-ث ذ أَمْسخَّارْ ن ڒْقبْطَانْ ن إِعسَّاسنْ ن أَرِّيمثْ. نْحَاجَا أَسْ ثِيرْجَا نّغْ ؤُشَا إِفسَّارْ أَنغْ ثنْثْ. إِ كُوڒْ إِجّْ \add زَّايْنغْ\add* إِفسَّارْ أَسْ ثَارْجِيثْ نّسْ.
\v 13 أَمْ مَامّشْ ثنْثْ إِفسَّارْ، أَمنِّي إِ إِمْسَارْ. أَقَا \add فِيرْعُونْ\add* يَارَّا أَيِي نشّْ غَارْ ڒْخذْمثْ إِنُو ؤُ ونّغْنِي يُويڒْ إِ-ث.“
\b
\m 
\v 14 إِسّكّْ فِيرْعُونْ حِيمَا أَذْ د-ڒَْاغَانْ خْ يُوسُوفْ ؤُشَا سُّوفّْغنْ ث-إِ-د ذغْيَا زڭْ وحْفُورْ \add ن إِمحْبَاسْ\add*. إِحفّْ أَشُوَّافْ، إِبدّڒْ أَرُّوضْ ؤُشَا أَمُّو إِ يُوذفْ غَارْ فِيرْعُونْ. \x ◘ \xo 41:‏14 \xt إِزهد. 105‏:‏20؛ دَان. 2‏:‏25. \x*
\v 15 إِنَّا فِيرْعُونْ إِ يُوسُوفْ: ”نشّْ ؤُرْجِيغْ إِشْثْ ن ثَارْجِيثْ، وَارْ إِدْجِي وِي ت غَا إِفسَّارنْ. \add مَاشَا\add* أَقَا سْڒِيغْ خَاكْ بلِّي شكْ، \add خْمِي إِ غَا\add* ثسْڒِيذْ إِ ثَارْجِيثْ، ثْزمَّارذْ أَذْ ت ثْفسَّارذْ.“
\v 16 يَارَّا-د يُوسُوفْ خْ فِيرْعُونْ، إِنَّا: ”وَارْ إِدْجِي شَا زَّايِي، \add مَاشَا\add* أَربِّي أَذْ د-يَارّْ خْ مَامّشْ غَا إِذْوڒْ ؤُمدُّورْ ن فِيرْعُونْ.“
\v 17 إِنَّا فِيرْعُونْ إِ يُوسُوفْ: ”ذِي ثَارْجِيثْ إِنُو ژْرِيغْ إِخفْ إِنُو بدّغْ خْ ثْمَا ن إِغْزَارْ.
\v 18 أَقَا ڭعّْذنْثْ-إِ-د سبْعَا ن ثْفُونَاسِينْ زڭْ إِغْزَارْ، صحّنْثْ ؤُ صبْحنْثْ إِ ڒْخزْرَاثْ، هدَّانْثْ جَارْ وحْثِيشْ ن ؤُغَانِيمْ.
\v 19 أَوَارْنِي أَسنْثْ سبْعَا ن ثْفُونَاسِينْ نّغْنِي ڭعّْذنْثْ-إِ-د. ثُوغَا كُّوشّْضنْثْ ؤُ وَارْ حْڒِينْثْ ذڭْ وُوذمْ، ؤُژْغنْثْ. أَمُّو وَارْ حْڒِينْثْ،عمَّارْصْ وَارْ ثنْثْ ژْرِيغْ ذِي ثمُّورْثْ ن مِيصْرَا أَمْ ثكْمڒْ.
\v 20 ثِيفُونَاسِينْ يُوژْغنْ، وَارْ إِحْڒِينْ، سَارْضنْثْ سبْعَا ن ثْينْذُوزِينْ ثِيمزْوُورَا إِصحّنْ.
\v 21 \add ؤُمِي\add* ؤُذْفنْثْ ثِينَا ذڭْ ؤُعذِّيسْ نْسنْثْ، عَاذْ وَارْ إِسِّينْ حذْ، بلِّي أَقَا ؤُذْفنْثْ ذڭْ ؤُعذِّيسْ نْسنْثْ، أَقَا قِّيمنْثْ وَارْ حْڒِينْثْ إِ ڒْخزْرَاثْ أَمْ قْبڒْ. \add خنِّي\add* فَاقغْ.
\v 22 \add عَاوذْ\add* ژْرِيغْ ذِي ثَارْجِيثْ إِنُو، خْزَارْ، زڭْ إِشْثْ ن ثْسطَّا فّْغنْثْ-إِ-د سبْعَا ن ثِيذْرِينْ شُّورنْثْ ؤُ شْنَانْثْ.
\v 23 خْزَارْ، ژْرِيغْ، ڭعّْذنْثْ-إِ-د سبْعَا ن ثِيذْرِينْ قُّوسْبَارنْثْ، ؤُژْغنْثْ، إِسّْشمْضْ إِ-ثنْثْ ؤُسمِّيضْ أَشَارْقِي.
\v 24 ؤُ سبْعَا ن ثِيذْرِينْ يُوژْغنْ، صَارْضنْثْ سبْعَا ن ثِيذْرِينْ نِّي إِشْنَانْ. نِّيغْ \add ثَارْجِيثْ\add* إِ ثَارْوَا ن ثْسحَّارْثْ، مَاشَا وَارْ ذِينْ ثُوغِي حذْ إِ إِزمَّارنْ أَذْ إِفسَّارْ \add ثَارْجِيثْ-أَ\add*.“
\m 
\v 25 \add خنِّي\add* إِنَّا يُوسُوفْ إِ فِيرْعُونْ: ”ثَارْجِيثْ ن فِيرْعُونْ ذ إِشْثْ. أَربِّي إِبيّنْ إِ فِيرْعُونْ مِينْ إِ غَا يڭّْ نتَّا.
\v 26 سبْعَا ن ثْفُونَاسِينْ شْنَانْثْ أَقَا أَثنْثْ ذ سبْعَا ن إِسڭّْوُوسَا. ؤُشَا ثِيذْرِينْ شْنَانْثْ أَقَا ذ سبْعَا ن إِسڭّْوُوسَا. ذ ثَارْجِيثْ ذ إِشْثْ.
\v 27 سبْعَا ن ثْفُونَاسِينْ ؤُژْغنْثْ وَارْ إِحْڒِينْ ثِينِّي د-يُوڒْينْ أَوَارْنِي أَسنْثْ، أَقَا ذ سبْعَا ن إِسڭّْوُوسَا، ؤُ سبْعَا ن ثِيذْرِينْ قُّوسْبَارنْثْ، ثِينِّي إِسّْشمْضْ ؤُسمِّيضْ أَشَارْقِي، أَقَا أَثنْثْ ذ سبْعَا ن إِسڭّْوُوسَا إِ ذِي غَا يِيڒِي ڒَاژْ.
\v 28 ذ وَا ذ أَوَاڒْ إِ نِّيغْ إِ فِيرْعُونْ. مِينْ غَا يڭّْ أَربِّي، أَقَا إِسّْشنْ إِ-ث إِ فِيرْعُونْ.
\v 29 خْزَارْ، ذِي سبْعَا ن إِسڭّْوُوسَا إِ د-إِڭُّورنْ أَذْ ثِيڒِي ثْيَاوَانْثْ ثَامقّْرَانْثْ خْ مَارَّا ثَامُّورْثْ ن مِيصْرَا.
\v 30 أَوَارْنِي أَسنْ أَذْ د-أَسنْ سبْعَا ن إِسڭّْوُوسَا ن ڒَاژْ. ذِي مَارَّا ثَامُّورْثْ ن مِيصْرَا أَذْ تُّونْ مَارَّا ثْيَاوَانْثْ ؤُشَا ڒَاژْ أَذْ إِثحَّا ثَامُّورْثْ.
\v 31 ؤُشَا ثْيَاوَانْثْ وَارْ ثتِّيڒِي ثتّْوَاسّنْ \add عَاذْ\add* زِي سِّيبّثْ ن ڒَاژْ إِ ت-إِ-د-إِضْفَارنْ، مَاغَارْ ڒْحَاڒْ أَذْ يِيڒِي إِقْسحْ أَطَّاسْ.
\v 32 عْلَاحْسَابْ طّْبِيعثْ ن ثْنَاينْ ن وُوذْمَاونْ ن ثَارْجِيثْ ن فِيرْعُونْ، أَقَا ثْنَاينْ ن ثْسقَّارْ، أَقَا مَانْ أَيَا س مِينْزِي يُورَا ت أَربِّي نِيشَانْ ؤُ أَربِّي أَقَا أَذْ ت يڭّْ ذغْيَا.
\v 33 أجّْ فِيرْعُونْ ڒخُّو أَذْ يَارْزُو خْ إِجّْ ن ورْيَازْ س ڒفْهَامثْ ذ ثِيغِيثْ، مَاحنْذْ أَذْ ث إِڭّْ خْ ثمُّورْثْ ن مِيصْرَا.
\v 34 أجّْ فِيرْعُونْ أَذْ إِڭّْ \add أَمُّو\add*: أجّْ إِ-ث أَذْ إِڭّْ إِوقَّافنْ خْ ثمُّورْثْ، مَاحنْذْ أَذْ كْسِينْ ڒخْمُوسْ \add ن ڒْغِيدْجثْ\add* ن ثمُّورْثْ ن مِيصْرَا ذِي سبْعَا ن إِسڭّْوُوسَا ن ثْيَاوَانْثْ.
\v 35 أجّْ إِ-ثنْ أَذْ سّْمُوننْ مَارَّا ڒعْوتْشْ ذڭْ إِسڭّْوُوسَا إِصبْحنْ إِ د غَا يَاسنْ ؤُشَا أَذْ خمّْڒنْ ڒْحبّْ ن يِيرْذنْ سَاذُو ؤُفُوسْ ن فِيرْعُونْ، مَاحنْذْ أَذْ ث خمّْڒنْ ذ مَاشَّا ذِي ثْندَّامْ.
\v 36 أَذْ يِيڒِي ذ ڒخْزنْ ن مَاشَّا إِ ثمُّورْثْ إِ سبْعَا ن إِسڭّْوُوسَا ن ڒَاژْ نِّي د غَا إِوْضَانْ خْ ثمُّورْثْ ن مِيصْرَا، حِيمَا ثَامُّورْثْ وَارْ ثتّْمتِّي شَا س ڒَاژْ.“
\m 
\v 37 أَوَاڒنْ-أَ بَاننْ-د ذ لمْلِيحْ إِ فِيرْعُونْ ذ مَارَّا إِمْسخَّارنْ نّسْ. \x ◘ \xo 41:‏37 \xt ڒخ. 7‏:‏10. \x*
\b
\s1 يُوسُوفْ إِذْوڒْ ذ ڒْحَاكمْ خْ ثمُّورْثْ ن مِيصْرَا
\m 
\v 38 \add خنِّي\add* إِنَّا فِيرْعُونْ إِ إِمْسخَّارنْ نّسْ: ”مَا إِزمَّارْ أَذْ إِتّْوَافْ شَا ن ورْيَازْ أَمْ وَا إِ ذِي إِزدّغْ أَرُّوحْ ن أَربِّي؟“ \x ◘ \xo 41:‏38 \xt إِزهد. 105‏:‏22. \x*
\v 39 ؤُشَا إِنَّا فِيرْعُونْ إِ يُوسُوفْ: ”ؤُمِي أَربِّي إِمّڒْ أَشْ-د مَارَّا أَيَا، خْ ؤُيَا وَارْ ذِينْ يدْجِي ونِّي غَارْ ثدْجَا ڒفْهَامثْ ذ ثِيغِيثْ أَمْ شكْ.
\v 40 شكْ أَذْ ثِيڒِيذْ خْ ثَادَّارْثْ إِنُو ؤُ إِ وَاوَاڒْ نّشْ أَذْ إِطَاعْ ڒْڭنْسْ إِنُو مَارَّا. مْغِيرْ خْ ڒْعَارْشْ وَاهَا أَذْ إِڒِيغْ نشّْ ذ أَمقّْرَانْ خَاكْ.“ \x ◘ \xo 41:‏40 \xt إِزهد. 105‏:‏21. \x*
\v 41 \add يَارْنِي\add* إِنَّا فِيرْعُونْ إِ يُوسُوفْ: ”خْزَارْ، ڭِّيغْ شكْ خْ مَارَّا ثَامُّورْثْ ن مِيصْرَا.“
\v 42 ؤُشَا إِكّسْ فِيرْعُونْ ثَاخَاذنْثْ نّسْ زڭْ ؤُفُوسْ نّسْ، إِڭَّا إِ-ت ذڭْ ؤُفُوسْ ن يُوسُوفْ ؤُشَا إِسّْيَارْضْ أَسْ أَرُّوضْ ن ڒقْطنْ أَزْذَاذْ ؤُشَا إِڭَّا أَسْ ثَاسدّشْثْ ن وُورغْ ذڭْ يِيرِي نّسْ.
\v 43 إِسّنْيَا إِ-ث ذِي ثْكَارُّوثْ وِيسّْ ثْنَاينْ إِ ثُوغَا غَارسْ ؤُشَا ڒَاغَانْ \add أَمْ ڭُّورنْ\add* زَّاثسْ: ”قوْسْ!“ أَمُّو إِ ث إِڭَّا خْ مَارَّا ثَامُّورْثْ ن مِيصْرَا.
\v 44 إِنَّا فِيرْعُونْ إِ يُوسُوفْ: ”نشّْ ذ فِيرْعُونْ، بْڒَا شكْ ؤُڒَا ذ إِجّْ أَذْ إِڭعّذْ أَفُوسْ نّسْ نِيغْ أَضَارْ نّسْ ذِي مَارَّا ثَامُّورْثْ ن مِيصْرَا.“
\v 45 إِڒَاغَا فِيرْعُونْ إِ يُوسُوفْ س يِيسمْ ن صَافْنَاثْ-فَاعْنِيحْ ؤُشَا إِوْشَا أَسْ أَسْنَاثْ ذ ثَامْغَارْثْ، ثنِّي ذ يدْجِيسْ ن فُوثِي-فَارَاعْ، أَكهَّانْ ن ؤُنْ. ؤُشَا إِجُوڒْ يُوسُوفْ ذِي ثمُّورْثْ ن مِيصْرَا.
\v 46 ثُوغَا يُوسُوفْ ذ مِّيسْ ن ثْڒَاثِينْ ن إِسڭّْوُوسَا ڒَامِي إِبدّْ نتَّا زَّاثْ إِ فِيرْعُونْ، أَجدْجِيذْ ن مِيصْرَا، ؤُشَا إِفّغْ يُوسُوفْ زَّاثْ إِ فِيرْعُونْ ؤُشَا إِجُوڒْ خْ مَارَّا ثَامُّورْثْ ن مِيصْرَا.
\b
\m 
\v 47 ؤُشَا ثسّغْمِي-د ثمُّورْثْ ذِي سبْعَا ن إِسڭّْوُوسَا س ثْيَاوَانْثْ. \f ◼ \fr 41:‏47 \ft \bd ’س ثْيَاوَانْثْ‘\bd* - س ثْعِيبْرَانِيثْ ’س إِفَاسّنْ إِشُّورنْ‘.\f*
\v 48 إِسّْمُونْ مَارَّا مَاشَّا ن سبْعَا ن إِسڭّْوُوسَا \add ن ثْيَاوَانْثْ\add*، إِنِّي ثُوغَا ذِي ثمُّورْثْ ن مِيصْرَا، ؤُشَا إِخمّڒْ مَاشَّا ذِي ثْندَّامْ. مَاشَّا ن إِيَّارنْ إِ ذ أَسْ د-إِنّْضنْ إِ كُوڒْ ثَانْذِينْثْ، إِخمّڒْ إِ-ت ذَايسْ ذَاخڒْ \add ذِي ثنْذِينْثْ\add*.
\v 49 يُوسُوفْ إِخمّڒْ ڒْحبّْ ن إِرْذنْ أَطَّاسْ، أَنشْثْ ن إِجْذِي ن ڒبْحَارْ، أَڒَامِي وَارْ إِزمَّارْ أَذْ إِتّْوَاحْسبْ، مِينْزِي ثُوغَا-ث بْڒَا ڒحْسَابْ.
\b
\m 
\v 50 قْبڒْ إِ د-يُوسَا ؤُسڭّْوَاسْ \add أَمزْوَارُو\add* ن ڒَاژْ، مَّارنْينْ-د غَارْ يُوسُوفْ \bd ثْنَاينْ ن إِحنْجِيرنْ\bd*، إِنِّي ذ أَسْ د-ثُورُووْ أَسْنَاثْ، يدْجِيسْ ن فُوثِي-فَارَاعْ، أَكهَّانْ ن ؤُنْ. \x ◘ \xo 41:‏50 \xt أَمز. 46‏:‏20؛ 48‏:‏5. \x*
\v 51 إِسمَّا يُوسُوفْ \bd أَمنْزُو مَانَاسَّا\bd*، مِينْزِي \add إِنَّا:\add* ”أَربِّي أَقَا إِسّتُّو أَيِي مَارَّا ثَامَارَا إِنُو ذ مَارَّا ثَادَّارْثْ ن بَابَا.“ \f ◼ \fr 41:‏51 \ft \bd ’مَانَاسَّا‘\bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’ونِّي إِتّجَّانْ أَذْ تُّوغْ‘.\f*
\v 52 وِيسّْ ثْنَاينْ إِسمَّا إِ-ث \bd إِفْرَايِيمْ\bd*، مِينْزِي إِنَّا: ”أَربِّي إِڭَّا أَيِي س ڒْغِيدْجثْ ذِي ثمُّورْثْ ن ڒحْصَارثْ إِنُو.“ \f ◼ \fr 41:‏52 \ft \bd ’إِفْرَايِيمْ‘\bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’ونِّي إِتِّيشّنْ ڒْغِيدْجثْ‘.\f*
\b
\m 
\v 53 \add خنِّي\add* كمّْڒنْ سبْعَا ن إِسڭّْوُوسَا ن ؤُفيّضْ \add ن ڒْغِيدْجثْ\add* نِّي إِكِّينْ خْ ثمُّورْثْ ن مِيصْرَا،
\v 54 ؤُشَا بْذَانْ أَذْ د-أَسنْ \bd سبْعَا ن إِسڭّْوُوسَا ن ڒَاژْ\bd*، أَمْ مَامّشْ خَاسْ إِسِّيوڒْ يُوسُوفْ. ثُوغَا ڒَاژْ ذِي مَارَّا ثِيمُّورَا، \add مَاشَا\add* ذِي مَارَّا ثَامُّورْثْ ن مِيصْرَا ثُوغَا ذَايسْ \add عَاذْ\add* أَغْرُومْ. \x ◘ \xo 41:‏54 \xt أَمز. 45‏:‏6؛ إِزهد. 105‏:‏16. \x*
\v 55 \add أَڒَامِي\add* ثُوغَا ڒَاژْ ذِي مَارَّا ثَامُّورْثْ ن مِيصْرَا، إِسْغُويْ ڒْڭنْسْ غَارْ فِيرْعُونْ خْ وغْرُومْ. ؤُشَا إِنَّا فِيرْعُونْ إِ مَارَّا إِمِيصْرِييّنْ: ”رُوحمْ غَارْ يُوسُوفْ، ڭّمْ مِينْ ذ أَومْ غَا يِينِي!“
\v 56 ثُوغَا ڒَاژْ إِزدْجعْ خْ مَارَّا ثَامُّورْثْ ؤُشَا يَارْزمْ يُوسُوفْ خْ مَارَّا مِينْ ثُوغَا إِخمّڒْ، ؤُشَا إِزّنْزْ إِ-ث إِ إِمِيصْرِييّنْ، مِينْزِي ثُوغَا ڒَاژْ إِذْوڒْ إِمْغَارْ أَطَّاسْ ذِي ثمُّورْثْ ن مِيصْرَا.
\v 57 زِي مَارَّا ثِيمُّورَا ؤُسِينْ-د \add إِوْذَانْ\add* غَارْ مِيصْرَا غَارْ يُوسُوفْ حِيمَا أَذْ سْغنْ، مِينْزِي ذِي مَارَّا ثِيمُّورَا ثُوغَا ڒَاژْ إِمْغَارْ أَطَّاسْ.
\b
\b
\c 42
\s1 أَيْثْمَاسْ ن يُوسُوفْ ؤُسِينْ-د غَارْ مِيصْرَا إِ ثْوَاڒَا ثَامزْوَارُوثْ
\m 
\v 1 \add ڒَْامِي\add* إِژْرَا يَاعْقُوبْ بلِّي أَقَا ذِينْ ڒْحبّْ \add ن يِيرْذنْ\add* ذِي مِيصْرَا، \add خنِّي\add* إِنَّا إِ إِحنْجِيرنْ نّسْ ”مَاغَارْ ثقِّيممْ ثْخزَّارمْ إِجّنْ ذڭْ ونّغْنِي؟“
\v 2 إِنَّا: ”أَقَا نشّْ سْڒِيغْ بلِّي ذِينْ إِمنْذِي ذِي مِيصْرَا. رُوحمْ ذِينِّي ؤُشَا سْغمْ أَنغْ-د سّنِّي \add ڒْْحبّْ\add*، حِيمَا أَذْ نقِّيمْ ندَّارْ ؤُشَا وَارْ نتّْمتِّي شَا.“ \x ◘ \xo 42:‏2 \xt ڒخ. 7‏:‏12. \x*
\v 3 هْوَانْعشْرَا ن وَاوْمَاثنْ ن يُوسُوفْ، مَاحنْذْ أَذْ رَاحنْ أَذْ سْغنْ إِمنْذِي زِي مِيصْرَا.
\v 4 \add مَاشَا\add* يَاعْقُوبْ وَارْ إِسّكّْ بِينْيَامِينْ، ؤُمَاسْ ن يُوسُوفْ، أَكْ-ذ أَيْثْمَاسْ، مِينْزِي إِنَّا: ”حِيمَا وَارْ ذ أَسْ إِتّمْسَارْ شَا ن ڒْحَاجّثْ ذ ثَاعفَّانْثْ.“
\m 
\v 5 جَارْ إِنِّي د-يُوسِينْ \add ذِينِّي\add*، ؤُسِينْ-د \add عَاوذْ\add* أَيْثْ ن إِسْرَائِيل، مَاحنْذْ أَذْ سْغنْ \add مَاشَّا\add*، مِينْزِي ثُوغَا ذِينْ ڒَاژْ ذِي ثمُّورْثْ ن كنْعَانْ.
\v 6 ثُوغَا يُوسُوفْ ذ ڒْحَاكمْ خْ ثمُّورْثْ ؤُشَا إِزّنْزْ \add إِمنْذِي\add* إِ مَارَّا ڒْڭنْسْ ن ثمُّورْثْ. ؤُمِي د-إِوْضنْ أَيْثْمَاسْ ن يُوسُوفْ، بنْذْقنْ أَسْ س ؤُغمْبُوبْ نْسنْ غَارْ ثمُّورْثْ. \x ◘ \xo 42:‏6 \xt أَمز. 37‏:‏6. \x*
\v 7 \add ؤُمِي\add* إِژْرَا يُوسُوفْ أَيْثْمَاسْ، إِعْقڒْ إِ-ثنْ، مَاشَا إِڭَّا إِخفْ نّسْ أَخْمِي وَارْ ثنْ إِسِّينْ ؤُشَا إِسِّيوڒْ أَكِيذْسنْ س ڒقْسَاحثْ، إِنَّا أَسنْ: ”مَانِيسْ د-ثُوسِيمْ؟“ نَّانْ: ”زِي ثمُّورْثْ ن كنْعَانْ، مَاحنْذْ أَذْ نْسغْ مَاشَّا.“
\v 8 يُوسُوفْ إِعقْڒْ أَيْثْمَاسْ، مَاشَا نِيثْنِي وَارْ ث عْقِيڒنْ شَا.
\v 9 إِفكَّارْ يُوسُوفْ ذِي ثِيرْجَا نِّي ثُوغَا خَاسنْ يُورْجَا، إِنَّا أَسنْ: ”كنِّيوْ ذ إِبرْڭَاڭنْ إِ ثدْجَامْ، ثُوسِيمْ-د، حِيمَا أَذْ ثْژَارمْ مَانِي وَارْ ثتّْوَاحْضِي ثمُّورْثْ.“ \x ◘ \xo 42:‏9 \xt أَمز. 37‏:‏4. \x*
\v 10 أَرِّينْ-د خَاسْ: ”لَّ، أَ سِيذِي إِنُو، عَاذْ إِمْسخَّارنْ نّشْ ؤُسِينْ-د، مَاحنْذْ أَذْ سْغنْ مَاشَّا.
\v 11 مَارَّا نشِّينْ أَقَا أَنغْ ذ ثَارْوَا ن إِجّْ ن ورْيَازْ. أَقَا أَنغْ ذ \add إِرْيَازنْ\add* ذ إِمْثِيقَّانْ، إِمْسخَّارنْ نّشْ وَارْ دْجِينْ شَا ذ إِبرْڭَاڭنْ.“
\v 12 نتَّا يَارَّا-د خَاسنْ: ”لَّ، كنِّيوْ ثُوسِيمْ-د مَاحنْذْ أَذْ ثْژَارمْ ثُوعَّارْينْثْ ن ثمُّورْثْ.“
\v 13 نَّانْ نِيثْنِي: ”نشِّينْ ذ إِمْسخَّارنْ نّشْ، أَقَا أَنغْ ذِي ثنْعَاشْ ن وَاوْمَاثنْ، ثَارْوَا ن إِجّْ ن ورْيَازْ ذِي ثمُّورْثْ ن كنْعَانْ. أَقَا أَمَاژُوژْ أَقَا-ث أَكْ-ذ بَابَاثْنغْ ؤُ ونّغْنِي وَارْ إِدْجِي \add عَاذْ\add*.“ \x ◘ \xo 42:‏13 \xt أَمز. 43‏:‏29. \x*
\v 14 إِنَّا أَسنْ يُوسُوفْ: ”مَا وَارْ ذ أَومْ ث نِّيغْ ؤُمِي نِّيغْ: ’أَقَا كنِّيوْ ذ إِبرْڭَاڭنْ!‘
\v 15 س ؤُيَا ثتّْوَاقدْجْبمْ. س ثِيذتّْ أَمْ إِدَّارْ فِيرْعُونْ، كنِّيوْ وَارْ د-تّفّْغمْ سَّا، مْغِيرْ خْمِي د غَا يَاسْ ؤُمَاثْومْ أَمَاژُوژْ ذَانِيثَا!
\v 16 سكّمْ إِجّْ ن زَّايْومْ، مَاحنْذْ أَذْ د-يَاوِي ؤُمَاثْومْ. \add خنِّي\add* كنِّيوْ أَذْ ثتّْوَاحبّْسمْ ؤُشَا أَوَاڒنْ نْومْ أَذْ تّْوَاقدْجْبنْ، مَا ذَايْومْ ڒَامَانْ. مَاڒَا لَّا، س ثِيذتّْ أَمْ إِدَّارْ فِيرْعُونْ، أَقَا كنِّيوْ ذ إِبرْڭَاڭنْ!“
\v 17 ؤُشَا إِڭَّا إِ-ثنْ ثْڒَاثَا ن وُوسَّانْ ذِي ڒحْبسْ.
\m 
\v 18 ذڭْ وَاسّْ وِيسّْ ثْڒَاثَا إِنَّا أَسنْ يُوسُوفْ: ”ڭّمْ أَيَا، حِيمَا أَذْ ثقِّيممْ ثدَّارمْ، نشّْ تّڭّْوْذغْ أَربِّي.
\v 19 مَاڒَا كنِّيوْ ذ إِرْيَازنْ ذ إِمْثِيقَّانْ، جّمْ \add خنِّي\add* إِجّْ ن ؤُمَاثْومْ أَذْ إِقِّيمْ إِشَارْفْ ذِي ثَادَّارْثْ مَانِي ثتّْوَاحبّْسمْ كنِّيوْ، \add خنِّي\add* رُوحمْ، كْسِيمْ إِمنْذِي إِ ڒَاژْ ن أَيْثْبَابْ ن ثَادَّارْثْ نْومْ.
\v 20 أَوْيمْ-د \add خنِّي\add* ؤُمَاثْومْ، أَمَاژُوژْ، مَاحنْذْ أَذْ تّْوَاقدْجْبنْ وَاوَاڒنْ نْومْ، وَارْ ثتّْمتِّيمْ شَا.“ ؤُشَا نِيثْنِي ڭِّينْ أَمنِّي. \x ◘ \xo 42:‏20 \xt أَمز. 43‏:‏5؛ 44‏:‏23. \x*
\v 21 نَّانْ إِ وَايَاوْيَا: ”س ثِيذتّْ أَقَا إِتّْخصَّا أَنغْ أَذْ د-نَارّْ دّيّثْ ن ؤُمَاثْنغْ، أَقَا نژْرَا ڒْحصْرَانْ ن ڒعْمَارْ نّسْ ؤُمِي ذ أَنغْ إِتَّارْ أَحِينِّي، مَاشَا وَارْ ذ أَسْ نسْڒِي شَا! خْ ؤُيَا د-يُوسَا ڒْحصْرَانْ-أَ خَانغْ.“
\v 22 يَارَّا-د خَاسنْ رُوبِينْ، إِنَّا: ”مَا وَارْ ذ أَومْ ث نِّيغْ، ؤُمِي نِّيغْ: ’وَارْ خطِّيمْ شَا أَكْ-ذ ؤُحنْجِيرْ!‘، مَاشَا كنِّيوْ وَارْ ثسْڒِيمْ شَا. خْزَارْ، إِذَامّنْ نّسْ تّْوَاتَّارنْ \add ڒخُّو\add*!“ \x ◘ \xo 42:‏22 \xt أَمز. 37‏:‏20، 21. \x*
\v 23 نِيثْنِي وَارْ سِّيننْ بلِّي إِفْهمْ أَسنْ يُوسُوفْ، مِينْزِي ثُوغَا أَثُورْجْمَانْ جَارْ أَسنْ. \x ◘ \xo 42:‏23 \xt أَيُوبْ 33‏:‏23\x*
\v 24 إِنّقْڒبْ خَاسنْ ؤُشَا إِسْغُويْ. \add أَوَارْنِي أَسْ\add* إِنّقْڒبْ-د عَاوذْ غَارْسنْ، إِسِّيوڒْ أَكِيذْسنْ، إِكْسِي زَّايْسنْ شِيمْعُونْ ؤُشَا إِحبّسْ إِ-ث زَّاثْ إِ ثِيطَّاوِينْ نْسنْ.
\v 25 يُومُورْ يُوسُوفْ مَاحنْذْ أَذْ شُّورنْ ثِيخُونْشَايْ نْسنْ س إِمنْذِي ؤُ أَذْ ڭّنْ \add ثْمنْيَاثْ ن\add* نُّوقَارْثْ ذِي كُوڒْ إِشْثْ ن ثْخَانْشثْ نْسنْ ؤُشَا وْشِينْ أَسنْ مَاشَّا إِ وبْرِيذْ. ؤُ أَمُّو إِ كِيذْسنْ ڭِّينْ.
\v 26 سَّارْبُونْ إِمنْذِي نْسنْ خْ يغْيَاڒْ نْسنْ ؤُشَا فّْغنْ سّنِّي.
\m 
\v 27 \add ؤُمِي\add* يَارْزمْ إِجّنْ زَّايْسنْ ثَاخَانْشثْ نّسْ، حِيمَا أَذْ إِسّشّْ أَغْيُوڒْ نّسْ غَارْ مَانِي غَا سّنْسنْ، إِژْرَا نُّوقَارْثْ نّسْ ذڭْ أَرْزَامْ ن ؤُقمُّومْ ن ثْخَانْشثْ نّسْ.
\v 28 إِنَّا إِ يَايْثْمَاسْ: ”نُّوقَارْثْ إِنُو ثذْوڒْ أَيِي-د. خْزَارْ، أَقَا-ت ذَا ذِي ثْخَانْشثْ إِنُو!“ ڒخْذنِّي إِبدّْ أَسنْ وُوڒْ، أَرْجِيجنْ ؤُشَا نَّانْ إِ وَايَاوْيَا: ”مَانَاوْيَا إِ ذ أَنغْ إِتّڭّْ أَربِّي؟“
\v 29 ؤُشَا رحّْڭنْ غَارْ بَابَاثْسنْ يَاعْقُوبْ ذِي ثمُّورْثْ ن كنْعَانْ ؤُشَا عَاوْذنْ أَسْ مَارَّا مِينْ خَاسنْ إِكِّينْ، نَّانْ:
\v 30 ”أَرْيَازْ، بَابْ ن ثمُّورْثْ، إِسِّيوڒْ أَكِيذْنغْ س ڒقْسَاحثْ، إِحسْبْ أَنغْ ذ إِبرْڭَاڭنْ ن ثمُّورْثْ.
\v 31 \add مَاشَا\add* ننَّا أَسْ: ’نشِّينْ ذ إِرْيَازنْ ذ إِمْثِيقَّانْ، \add عمَّارْصْ\add* وَارْ ندْجِي ذ إِبرْڭَاڭنْ.
\v 32 أَقَا أَنغْ ذِي ثنْعَاشْ ن وَاوْمَاثنْ، إِحنْجِيرنْ ن بَابَاثْنغْ. إِجّنْ وَارْ إِقِّيمْ، أَمَاژُوژْ أَقَا-ث أَسّْ-أَ أَكْ-ذ بَابَاثْنغْ ذِي ثمُّورْثْ ن كنْعَانْ.‘
\v 33 ؤُ أَرْيَازْ نِّي، بَابْ ن ثمُّورْثْ، إِنَّا أَنغْ: ’س ؤُيَا أَذْ سّْنغْ، مَا أَقَا كنِّيوْ ذ إِمْثِيقَّانْ. أَذْ كِيذِي ثجّمْ إِجّنْ زڭْ أَيْثْمَاثْومْ ؤُشَا أَذْ ثكْسِيمْ \add مَاشَّا\add* إِ ڒَاژْ نِّي ذِينْ غَارْ أَيْثْبَابْ ن ثَادَّارْثْ نْومْ، خنِّي فّْغمْ.
\v 34 أَوْيمْ-د \add ذَا\add* ؤُمَاثْومْ، أَمَاژُوژْ، \add خنِّي\add* أَذْ سّْنغْ بلِّي وَارْ ثدْجِيمْ ذ إِبرْڭَاڭنْ، مَاشَا ذ إِمْثِيقَّانْ ؤُشَا أَذْ أَومْ د-أَرْخُوغْ إِ وَامَاثْومْ نْومْ ؤُشَا أَذْ ثْرَاحمْ أَذْ ثْجُوڒمْ ذِي ثمُّورْثْ.‘ “
\v 35 \add ؤُمِي\add* سّخْوَانْ ثِيخُونْشَايْ نْسنْ، حكَّارنْ بلِّي ذِي ثْخَانْشثْ ن كُوڒْ إِجّنْ، أَقَا ذَايسْ ثَاشْيَارْثْ س نُّوقَارْثْ نّسْ. ژْرِينْ نِيثْنِي ذ بَابَاثْسنْ ثِيشْيَارْ س نُّوقَارْثْ نْسنْ ؤُشَا ثُوذفْ إِ-ثنْ ثِيڭّْوُوذِي. \x ◘ \xo 42:‏35 \xt أَمز. 42‏:‏25؛ 44‏:‏1. \x*
\m 
\v 36 إِنَّا أَسنْ بَابَاثْسنْ يَاعْقُوبْ: ”أَقَا ثْحَارّْممْ أَيِي \add زڭْ إِحنْجِيرنْ إِنُو\add*! يُوسُوفْ وَارْ د-إِضْهَارْ \add عَاذْ\add* ؤُڒَا ذ شِيمْعُونْ، ؤُشَا \add ڒخُّو\add* ثتّخْسمْ أَذْ ثْنذْهمْ بِينْيَامِينْ. مَارَّا مَانْ أَيَا إِتّمْسَارنْ ذِي ڒعْكسْ إِنُو!“
\v 37 \add خنِّي\add* إِسِّيوڒْ رُوبِينْ غَارْ بَابَاسْ، إِنَّا: ”أَذْ ثنْغذْ ثْنَاينْ ن إِحنْجِيرنْ إِنُو، مَاڒَا وَارْ ذ أَشْ ث-إِ-د-أَرِّيغْ. أوْشْ أَيِي ث ذڭْ ؤُفُوسْ إِنُو، نشّْ أَقَا أَذْ أَشْ ث-إِ-د-أَرّغْ!“
\v 38 \add مَاشَا\add* نتَّا إِنَّا أَسْ: ”مِّي وَارْ إِتّْرِيحْ شَا أَكِيذْومْ، مِينْزِي ؤُمَاسْ إِمُّوثْ ؤُ نتَّا وحّْذسْ إِ ذ أَيِي إِقِّيمنْ. مَاڒَا إِڒْقفْ إِ-ث شَا ن ڒْغَارْ ذڭْ وبْرِيذْ نِّي إِ غَا ثكّمْ، أَذْ ثسّهْوَامْ شِّيبْ إِنُو س وشْضَانْ غَارْ ڒَاخَارْثْ.“
\b
\b
\c 43
\s1 أَيْثْمَاسْ ن يُوسُوفْ ؤُسِينْ-د غَارْ مِيصْرَا إِ ثْوَاڒَا وِيسّْ ثْنَاينْ
\m 
\v 1 \add مَاشَا\add* ڒَاژْ ثُوغَا إِمْغَارْ أَطَّاسْ ذِي ثمُّورْثْ.
\v 2 \add ڒَْامِي\add* كمّْڒنْ شِّينْ ڒْحبّْ \add ن يِيرْذنْ\add* نِّي كِيذْسنْ د-إِوْينْ زِي مِيصْرَا، إِنَّا أَسنْ بَابَاثْسنْ: ”ذوْڒمْ-د عَاوذْ ؤُشَا سْغمْ أَنغْ-د شْوَايْثْ ن مَاشَّا.“
\v 3 \add خنِّي\add* إِسِّيوڒْ يَاهُوذَا، إِنَّا: ”أَقَا أَرْيَازْ نِّي إِنَّا أَنغْ س ؤُركّزْ: ”وَارْ ثْژَارّمْ \add عَاذْ\add* ؤُذمْ إِنُو، مْغِيرْ مَاڒَا ثِيوْيمْ-د ؤُمَاثْومْ أَكِيذْومْ.“
\v 4 مَاڒَا ثسّكّذْ ؤُمَاثْنغْ أَكِيذْنغْ، أَذْ نْرَاحْ ذِينْ ؤُشَا أَذْ أَشْ د-نْسغْ مَاشَّا،
\v 5 مَاشَا مَاڒَا وَارْ ث ثسّكِّيذْ \add أَكِيذْنغْ\add*، خنِّي وَارْ ذِينِّي نتّْرَاحْ، مِينْزِي أَرْيَازْ نِّي إِنَّا أَنغْ: ’وَارْ ثْژَارّمْ \add عَاذْ\add* ؤُذمْ إِنُو مْغِيرْ مَاڒَا يُوسَا-د ؤُمَاثْومْ أَكِيذْومْ.‘ “ \x ◘ \xo 43:‏5 \xt أَمز. 42‏:‏20؛ 44‏:‏23؛ \x*
\v 6 إِنَّا إِسْرَائِيل: ”مَاغَارْ ذ أَيِي ثڭِّيمْ ڒْغَارْ ؤُشَا ثنَّامْ إِ ورْيَازْ نِّي بلِّي أَقَا غَارْومْ عَاذْ ؤُمَاثْومْ نّغْنِي؟“
\v 7 نِيثْنِي نَّانْ: ”أَرْيَازْ نِّي إِسّقْسَا خَانغْ نِيشَانْ، ؤُ خْ ثمُّورْثْ مَانِي نخْڒقْ، إِنَّا: ’مَا إِدَّارْ عَاذْ بَابَاثْومْ؟ مَا غَارْومْ شَا ن ؤُمَاثْومْ نّغْنِي؟‘ \add خنِّي\add* نْعَاوذْ أَسْ \add ث\add*. مَا نْزمَّارْ زڭْ وَاوَاڒنْ-أَ أَذْ د-نجْبذْ إِلَّا أَذْ نسّنْ زعْمَا أَذْ يِينِي: ’أَوْيمْ-د ؤُمَاثْومْ؟‘ “
\v 8 ؤُشَا إِنَّا يَاهُوذَا إِ بَابَاسْ إِسْرَائِيل: ”سكّْ أَكِيذِي أَحنْجِيرْ ؤُشَا أَذْ نكَّارْ أَذْ نْرَاحْ، حِيمَا أَذْ ندَّارْ ؤُ وَارْ نتّْمتِّي شَا نشِّينْ ذ شكْ ذ ثَارْوَا نّغْ.
\v 9 نشّْ أَذْ أَسْ إِڒِيغْ ذ أَضْمَانْ ؤُ زڭْ ؤُفُوسْ إِنُو أَذْ ث ثتَّارذْ عَاوذْ. مَاڒَا وَارْ ذ أَشْ ث-إِ-د-أَرِّيغْ، أَذْ ث سّْبدّغْ زَّاثكْ، أَذْ يِيڒِي خْضِيغْ أَكِيذكْ إِ ڒبْذَا! \x ◘ \xo 43:‏9 \xt أَمز. 44‏:‏32. \x*
\v 10 معْلِيكْ وَارْ نقِّيمْ نتّْرَاجَا \add أَطَّاسْ\add*، ثِيڒِي ڒخُّو نذْوڒْ-د ثْنَاينْ ن ثْوَاڒَاوِينْ.“
\m 
\v 11 \add ؤُشَا\add* يَارَّا-د خَاسنْ إِسْرَائِيل، بَابَاثْسنْ: ”مَاڒَا أَمُّو إِ يدْجَا س ثِيذتّْ، ڭّمْ أَمُّو ؤُشَا كْسِيمْ مِينْ إِشْنَانْ أَطَّاسْ ن ثمُّورْثْ ذِي ثْخُونْشَايْ نْومْ، هْوَامْ-د مَاحنْذْ أَذْ ث ثِيوْيمْ ذ أَرِّيغَالُو إِ ورْيَازْ نِّي: شْوَايْثْ ن بَالْسَامْ ذ شْوَايْثْ ن ثَامّنْثْ، ڒعْطُورْ ذ مِيرُّو ذ ثغْيَاشْثْ ن پِيسْثَاشْ ذ دْجُوزْ.
\v 12 كْسِيمْ ثْنَاينْ ن ثْسقَّارْ ن \add ثنْعَاشِينْ ن\add* نُّوقَارْثْ أَكِيذْومْ ؤُشَا أَرّمْ س ؤُفُوسْ نْومْ نُّوقَارْثْ إِ د-إِعقْبنْ ذِي ثْخُونْشَايْ نْومْ. أَذْ ثَاغْ ثُوغَا ذ شَا ن لْغَالَاطْ.
\v 13 أَوْيمْ-د عَاوذْ ؤُمَاثْومْ أَكِيذْومْ، كَّارمْ،عقْبمْ غَارْ ورْيَازْ نِّي.
\v 14 ؤُشَا أَقَا أَربِّي، أَمْزمَّارْ خْ كُوڒْشِي، أَذْ أَومْ إِوْشْ أَرّحْمثْ زَّاثْ إِ وُوذمْ ن ورْيَازْ نِّي ؤُشَا أَذْ يَارْخُو إِ ؤُمَاثْومْ نّغْنِي ذ بِينْيَامِينْ. ؤُ مِينْ ذ أَيِي إِقِّيمنْ نشّْ، مَاڒَا تّْوَاحَارّْمغْ زڭْ إِحنْجِيرنْ إِنُو، أَقَا أَذْ زَّايْسنْ تّْوَاحَارّْمغْ!“
\m 
\v 15 \add خنِّي\add* إِوْينْ إِرْيَازنْ أَرِّيغَالُو ؤُشَا كْسِينْ ذڭْ ؤُفُوسْ نْسنْ ثْنَاينْ ن ثْسقَّارْ ن \add ثْمنْيَاثْ\add* ن نُّوقَارْثْ ؤُڒَا ذ بِينْيَامِينْ ؤُشَا كَّارنْ، هْوَانْ غَارْ مِيصْرَا ؤُشَا بدّنْ زَّاثْ إِ وُوذمْ ن يُوسُوفْ.
\v 16 \add ؤُمِي\add* إِژْرَا يُوسُوفْ بِينْيَامِينْ أَكِيذْسنْ، إِنَّا إِ ونِّي \add ثُوغَا\add* خْ ثَادَّارْثْ نّسْ: ”سِيذفْ إِرْيَازنْ-أَ غَارْ ثَادَّارْثْ، ثْغَارْصذْ \add إِ شَا\add* مِينْ إِدْجَانْ إِ ثْغَارْصْثْ، سوْجذْ إِ-ت، مِينْزِي إِرْيَازنْ-أَ أَذْ كِيذِي شّنْ غَارْ وزْينْ ن وَاسّْ.“
\v 17 إِڭَّا ورْيَازْ أَمْ مَامّشْ ذ أَسْ إِنَّا يُوسُوفْ ؤُشَا يِيوِي إِرْيَازنْ غَارْ ثَادَّارْثْ ن يُوسُوفْ.
\v 18 \add خنِّي\add* ذوْڒنْ يرْيَازنْ نِّي ڭّْوذنْ أَطَّاسْ، ؤُمِي ثنْ سِّيذْفنْ ذِي ثَادَّارْثْ ن يُوسُوفْ ؤُشَا نِيثْنِي نَّانْ: ”خْ \add ثْمنْيَاثْ ن\add* نُّوقَارْثْ إِ ذ أَنغْ د-إِذوْڒنْ ذِي ثْخُونْشَايْ نّغْ ثْوَاڒَا ثَامزْوَارُوثْ إِوْينْ أَنغْ-د ذَا حِيمَا \add خنِّي عَاوذْ\add* أَذْ خَانغْعفْسنْ ؤُشَا أَذْ خَانغْعدَّانْ، \add خنِّي\add* أَذْ أَنغْ كْسِينْ ذ إِسمْغَانْ أَكْ-ذ يغْيَاڒْ نّغْ.“
\v 19 قَارّْبنْ-د غَارْ ورْيَازْ نِّي إِڭَّا يُوسُوفْ خْ ثَادَّارْثْ ؤُشَا سِّيوْڒنْ أَكِيذسْ غَارْ وَاذَافْ ن ثَادَّارْثْ،
\v 20 نَّانْ: ”أَ سِيذِي إِنُو، نشِّينْ أَقَا نِيشَانْ نهْوَا-د ذ أَمزْوَارْ، مَاحنْذْ أَذْ نْسغْ مَاشَّا. \x ◘ \xo 43:‏20 \xt أَمز. 42‏:‏3. \x*
\v 21 إِمْسَارْ ؤُمِي د-نِيوضْ غَارْ ڒمْرَاحْ ؤُشَا نَارْزمْ ثِيخُونْشَايْ نّغْ، نژْرَا نُّوقَارْثْ ن كُوڒْ إِجّْ غَارْ ورْزَامْ ن ؤُقمُّومْ ن ثْخَانْشثْ نّسْ، نُّوقَارْثْ نّغْ س ڒْمِيزَانْ نّسْ نِيشَانْ. أَقَا نَارَّا إِ-ت-إِ-د س إِفَاسّنْ نّغْ. \x ◘ \xo 43:‏21 \xt أَمز. 42‏:‏27، 35. \x*
\v 22 عَاوذْ نِيوِي-د ذڭْ إِفَاسّنْ نّغْ نُّوقَارْثْ نّغْنِي، حِيمَا أَذْ نْسغْ مَاشَّا. نشِّينْ وَارْ نسِّينْ وِي إِڭِّينْ نُّوقَارْثْ ذِي ثْخُونْشَايْ نّغْ.“
\v 23 يَارَّا-د \add خَاسنْ\add*: ”سْڒَامْ خَاومْ، وَارْ تّڭّْوذمْ شَا! أَربِّي نْومْ ذ أَربِّي ن بَابَاثْومْ إِوْشَا أَومْ إِشْثْ ن ثْخَابشْثْ ذِي ثْخُونْشَايْ نْومْ. أَقَا نُّوقَارْثْ نْومْ طّْفغْ ت.“ ؤُشَا إِسُّوفّغْ-د غَارْسنْ شِيمْعُونْ.
\v 24 \add خنِّي\add* إِسِّيذفْ ورْيَازْ إِرْيَازنْ نِّي غَارْ ثَادَّارْثْ ن يُوسُوفْ، إِوْشَا \add أَسنْ\add* أَمَانْ ؤُشَا سِيرْذنْ إِضَارنْ نْسنْ. إِوْشَا \add أَسنْ\add* عَاوذْ ڒعْڒفْ إِ يغْيَاڒْ نْسنْ. \x ◘ \xo 43:‏24 \xt أَمز. 18‏:‏4. \x*
\v 25 ؤُ نِيثْنِي سّْوجْذنْ أَرِّيغَالُو إِ يُوسُوفْ، ونِّي إِڭُّورنْ أَذْ د-يَاسْ غَارْ وزْينْ ن وَاسّْ، مِينْزِي نِيثْنِي سْڒِينْ أَقَا أَذْ شّنْ ذِينِّي.
\m 
\v 26 \add ڒَْامِي د-\add* يُوذفْ يُوسُوفْ غَارْ ثَادَّارْثْ، وْشِينْ أَسْ-د ذِي ثَادَّارْثْ أَرِّيغَالُو نِّي د-إِوْينْ أَكِيذْسنْ، ؤُشَا بنْذْقنْ أَسْ غَارْ ثمُّورْثْ. \x ◘ \xo 43:‏26 \xt أَمز. 37‏:‏9؛ 42‏:‏6. \x*
\v 27 إِسّقْسَا ثنْ خْ مَامّشْ دْجَانْ ؤُشَا إِنَّا: ”مَامّشْ إِدْجَا بَابَاثْومْ أَوسَّارْ إِ خفْ ثسِّيوْڒمْ؟ مَا أَقَا عَاذْ إِدَّارْ؟“
\v 28 نِيثْنِي أَرِّينْ: ”مْلِيهْ إِ يدْجَا ؤُمْسخَّارْ نّشْ، بَابَاثْنغْ، نتَّا عَاذْ إِدَّارْ.“ ؤُضَارنْ نِيثْنِي ؤُشَا نتَّا إِبنْذقْ.
\v 29 \add ڒَْامِي\add* نتَّا إِسّْڭعّذْ ثِيطَّاوِينْ نّسْ ؤُشَا إِژْرَا بِينْيَامِينْ، ؤُمَاسْ، مِّيسْ ن يمَّاسْ، إِنَّا: ”مَا ذ وَا ذ ؤُمَاثْومْ، أَمَاژُوژْ، مِينْ خفْ ذ أَيِي ثسِّيوْڒمْ؟“ \add خنِّي\add* إِنَّا: ”أَذْ خَاكْ إِحِينّْ أَربِّي، أَ مِّي!“ \x ◘ \xo 43:‏29 \xt أَمز. 42‏:‏13. \x*
\v 30 يُوسُوفْ إِفّغْ خنِّي ذغْيَا، مِينْزِي ثَاحْنُونشْثْ نّسْ خْ ؤُمَاسْ ثُوغَا ثمْغَارْ. يَارْزُو خْ مَانِي غَا إِرُو ؤُشَا يُوذفْ غَارْ إِجّْ ن وخَّامْ ؤُشَا إِرُو ذِينْ. \x ◘ \xo 43:‏30 \xt أَمز. 45‏:‏2. \x*
\v 31 إِسِّيرْذْ ؤُذمْ نّسْ ؤُشَا إِفّغْ-د غَارْ بَارَّا، إِطّفْ ذڭْ إِخفْ نّسْ، إِنَّا: ”قذْممْ-د مَاشَّا.“
\v 32 نِيثْنِي سّْوجْذنْ أَسْ إِ نتَّا وحّْذسْ ؤُ إِ نِيثْنِي وحّذْسنْ ؤُڒَا إِ إِمِيصْرِييّنْ إِنِّي أَكِيذسْ شِّينْ وحّذْسنْ، مِينْزِي إِمِيصْرِييّنْ وَارْ زمَّارنْ أَذْ شّنْ أَغْرُومْ أَكْ-ذ إِعِيبْرَانِييّنْ، مِينْزِي ذ مَانْ أَيَا ذ جّْعِيفشْثْ غَارْ إِمِيصْرِييّنْ.
\v 33 ؤُشَا نِيثْنِي قِّيمنْ زَّاثْ إِ وُوذمْ نّسْ: أَمنْزُو \add ذڭْ ومْشَانْ نّسْ\add* عْلَاحْسَابْ ثَاسْغَارْثْ ن ثْمنْزُوثْ نّسْ ؤُشَا أَمَاژُوژْ \add ذڭْ ومْشَانْ نّسْ\add* عْلَاحْسَابْ ثمْژِي نّسْ. ثُوغَا إِرْيَازنْ تّْبهَاثنْ، خزَّارنْ إِجّنْ ذڭْ ونّغْنِي.
\v 34 ؤُشَا نتَّا إِقدّمْ أَسنْ-د زِي مِينْ \add ثُوغَا إِدْجَانْ\add* زَّاثسْ، مَاشَا ثَاسْغَارْثْ ن بِينْيَامِينْ ثُوغَا-ت خمْسَا ن ثْسقَّارْ كْثَارْ زِي ثْسقَّارْ ن مَارَّا إِذْسنْ. ؤُشَا سْوِينْ نِيثْنِي، سّنِّي ذوْڒنْ فَارْحنْ أَكِيذسْ.
\b
\b
\c 44
\s1 ثَاخْشفْثْ إِ إِڭَّا يُوسُوفْ إِ أَيْثْمَاسْ
\m 
\v 1 إِسّكّْ يُوسُوفْ غَارْ \add ؤُمْسخَّارْ\add* نِّي \add ثُوغَا\add* خْ ثَادَّارْثْ نّسْ، إِنَّا أَسْ: &عمَّارْ ثِيخُونْشَايْ ن يرْيَازنْ نِّي س مَاشَّا، مَارَّا مِينْ زمَّارنْ أَذْ كْسِينْ. أڭّْ نُّوقَارْثْ ن كُوڒْ إِجّْ ذڭْ وَارْزَامْ ن ؤُقمُّومْ ن ثْخَانْشثْ نّسْ.
\v 2 سَارْسْ ڒْكَاسْ إِنُو، ڒْكَاسْ ن نُّوقَارْثْ، ذڭْ وَارْزَامْ ن ؤُقمُّومْ ن ثْخَانْشثْ ن ؤُمَاژُوژْ أَكْ-ذ \add ثْمنْيَاثْ\add* ن نُّوقَارْثْ ن ڒْحبّْ نّسْ \add ن يِيرْذنْ\add*.“ ؤُشَا إِڭَّا أَمْ مَامّشْ ذ أَسْ إِنَّا يُوسُوفْ.
\v 3 غَارْ صّْبحْ ؤُمِي د-يفُّو ڒْهَاڒْ، جِّينْ إِرْيَازنْ أَذْ ؤُيُورنْ، نِيثْنِي أَكْ-ذ يغْيَاڒْ نْسنْ.
\v 4 ؤُمِي فّْغنْ نِيثْنِي زِي ثنْذِينْثْ، ثُوغَا \add عَاذْ\add* وَارْ ڭّْوِيجنْ شَا، إِنَّا يُوسُوفْ إِ ونِّي \add ثُوغَا\add* خْ ثَادَّارْثْ نّسْ: ”كَّارْ، ضْفَارْ إِرْيَازنْ نِّي ؤُشَا، خْمِي خَاسنْ غَا ثعْذُوذْ، إِنِي أَسنْ: ’مَاغَارْ د-ثَارَّامْ ڒْخَارْ س ڒْغَارْ؟
\v 5 مَا وَارْ إِدْجِي ذ وَا \add ذ ڒْكَاسْ\add* إِ زِي إِسسّْ سِيذِي إِنُو ؤُ \add مَا وَارْ إِدْجِي\add* س وَا إِ زِي غَا إِكَاشفْ مِينْ غَا إِمْسَارنْ ثِيوشَّا؟ أَقَا ثڭِّيمْ ڒْغَارْ ؤُمِي ثڭِّيمْ أَمْيَا.‘ “
\m 
\v 6 \add أَمْ\add* ثنْ إِعْذُو، إِنَّا أَسنْ أَوَاڒنْ-أَ سِيمَانْثْ نْسنْ.
\v 7 نِيثْنِي أَرِّينْ-د خَاسْ: ”مَايمِّي إِقَّارْ سِيذِي إِنُو أَوَاڒنْ-أَ؟ إِڭّْوجْ خْ إِمْسخَّارنْ نّشْ أَذْ ڭّنْ مَانْ أَيَا.
\v 8 خْزَارْ، نُّوقَارْثْ إِ نُوفَا ذڭْ وَارْزَامْ ن ؤُقمُّومْ ن ثْخُونْشَايْ نّغْ، أَقَا نَارّْ أَشْ ت-إِ-د زِي ثمُّورْثْ ن كنْعَانْ. مَامّشْ \add عَاذْ\add* إِ غَا نڭّْ أَذْ نَاشَارْ نُّوقَارْثْ نِيغْ ؤُرغْ زِي ثَادَّارْثْ ن سِيذِي نّشْ؟
\v 9 وِي زڭْ إِمْسخَّارنْ نّشْ إِ غَارْ إِ غَا إِتّْوَافْ \add ڒْْكَاسْ\add*، أَذْ إِمّثْ، ؤُشَا نشِّينْ عَاوذْ أَذْ نِيڒِي ذ إِسمْغَانْ ن سِيذِي إِنُو!“
\v 10 نتَّا إِنَّا: ”خنِّي ڒخُّو أَذْ يِيڒِي أَمْ مَامّشْ ثنَّامْ كنِّيوْ. ونِّي غَارْ ث غَا نَافْ، ذ نتَّا أَذْ يِيڒِي ذ إِسْمغْ إِنُو، مَاشَا كنِّيوْ أَذْ ثِيڒِيمْ ذ إِفُورَّا.“
\v 11 ؤُشَا كُوڒْ إِجّْ زَّايْسنْ إِقدْجقْ أَذْ إِسَّارْسْ ثَاخَانْشثْ نّسْ ذِي ثمُّورْثْ ؤُشَا كُوڒْ إِجّْ يَارْزمْ ثَاخَانْشثْ.
\v 12 ؤُشَا نتَّا إِفتّشْ إِ-ثنْثْ، إِبْذَا زڭْ ؤُمقّْرَانْ، إِكمّڒْ زڭْ ؤُمژْيَانْ، ؤُشَا ؤُفِينْ ڒْكَاسْ ذِي ثْخَانْشثْ ن بِينْيَامِينْ.
\m 
\v 13 \add خنِّي\add* شَارّْڭنْ أَرُّوضْ نْسنْ، ؤُشَا كُوڒْ إِجّْ إِسَّارْبُو \add عَاوذْ\add* خْ وغْيُوڒْ نّسْ ؤُشَاعقْبنْ نِيثْنِي غَارْ ثنْذِينْثْ.
\v 14 ؤُشَا يِيوضْ يَاهُوذَا أَكْ-ذ أَيْثْمَاسْ غَارْ ثَادَّارْثْ ن يُوسُوفْ، ونِّي ثُوغَا ذِينْ عَاذْ، ؤُشَا وْضَانْ زَّاثسْ غَارْ ثمُّورْثْ.
\v 15 إِنَّا أَسنْ يُوسُوفْ: ”مَانَا شْغڒْ-أَ إِ ثڭِّيمْ؟ مَا وَارْ ثفْهِيممْ شَا بلِّي إِجّْ ن ورْيَازْ أَمْ نشّْ، إِڭُّورْ أَذْ خَاسْ إِكَاشفْ نِيشَانْ؟“
\v 16 إِنَّا يَاهُوذَا: ”مِينْ غَا نِينِي إِ سِيذِي إِنُو ذ مَامّشْ إِ غَا نسِّيوڒْ نِيغْ س مِينْ زِي غَا نْسڭّذْ إِخفْ نّغْ؟ أَربِّي إِقدْجبْ دّنْبْ ن إِمْسخَّارنْ نّشْ، خْزَارْ، نشِّينْ ذ إِمْسخَّارنْ ن سِيذِي إِنُو، نشِّينْ ذ وِي غَارْ ؤُفِينْ ڒْكَاسْ.“
\v 17 \add مَاشَا\add* نتَّا يَارَّا: ”إِڭّْوجْ خَافِي أَذْ ڭّغْ أَيَا! أَرْيَازْ نِّي غَارْ ؤُفِينْ ڒْكَاسْ، نتَّا أَذْ يِيڒِي ذ إِسْمغْ إِنُو، \add مَاشَا\add* كنِّيوْ رُوحمْ ذِي ڒهْنَا غَارْ بَابَاثْومْ.“
\m 
\v 18 \add خنِّي\add* يِيوضْ-د يَاهُوذَا غَارسْ، إِنَّا: ”\add أَ\add* سِيذِي إِنُو، أجّْ أَذْ إِسِّيوڒْ ؤُمْسخَّارْ نّشْ إِجّْ ن وَاوَاڒْ ذڭْ ؤُمزُّوغْ ن سِيذِي إِنُو، وَارْ يَارقّْ ؤُخيّقْ نّشْ خْ ؤُمْسخَّارْ نّشْ، مِينْزِي أَقَا شكْ أَمْ فِيرْعُونْ.
\v 19 سِيذِي إِنُو إِسّقْسَا إِمْسخَّارنْ نّسْ، إِنَّا: ’مَا غَارْومْ \add عَاذْ\add* بَابَاثْومْ نِيغْ ثَاوْمَاثْ؟‘
\v 20 ؤُشَا نشِّينْ نَارَّا خْ سِيذِي إِنُو: ’أَقَا غَارْنغْ بَابَاثْنغْ ذ أَوسَّارْ ذ يِيجّْ ن ؤُحنْجِيرْ، \add ونِّي ذ أَسْ د-إِتّْوَاخڒْقنْ\add* خْ ثوْسَارْ نّسْ، ذ أَمَاژُوژْ عَاذْ. ؤُمَاسْ إِمُّوثْ، نتَّا وَاهَا إِ إِقِّيمنْ \add زڭْ إِحنْجِيرنْ\add* ن يمَّاسْ، ؤُ بَابَاسْ إِتّخْسْ إِ-ث.‘
\v 21 \add خَاسْ ؤُشَا\add* ثنِّيذْ شكْ إِ إِمْسخَّارنْ نّشْ: ’أَوْيمْ ث-إِ-د \add ذَا\add* غَارِي، حِيمَا أَذْ ث ژَترغْ س ثِيطَّاوِينْ إِنُو.‘ \x ◘ \xo 44:‏21 \xt أَمز. 42‏:‏15. \x*
\v 22 ؤُشَا نشِّينْ ننَّا إِ سِيذِي إِنُو: ’وَارْ إِزمَّارْ ؤُحنْجِيرْ أَذْ يجّْ بَابَاسْ، مِينْزِي مَاڒَا إِجَّا إِ-ث، بَابَاسْ أَذْ إِمّثْ.‘
\v 23 \add خنِّي\add* ثنِّيذْ إِ إِمْسخَّارنْ نّشْ: ’مَاڒَا ؤُمَاثْومْ أَمَاژُوژْ وَارْ د-يُوسِي أَكِيذْومْ، وَارْ ثْژَارّمْ عَاذْ ؤُذمْ إِنُو.‘ \x ◘ \xo 44:‏23 \xt أَمز. 43‏:‏3، 5 \x*
\v 24 ڒَامِي نْڭعّذْ غَارْ بَابَا، أَمْسخَّارْ نّشْ، نسّعْذُو أَسْ أَوَاڒنْ ن سِيذِي إِنُو.
\v 25 ؤُشَا بَابَاثْنغْ إِنَّا: عقْبمْ عَاوذْ مَاحنْذْ أَذْ ثسْغمْ شْوَايْثْ ن مَاشَّا إِ نشِّينْ.‘
\v 26 \add خنِّي\add* نَارَّا-د: ’وَارْ نْزمَّارْ أَذْ نْرَاحْ. \add مَاشَا\add* مَاڒَا ؤُمَاثْنغْ، أَمَاژُوژْ، إِرُوحْ أَكِيذْنغْ، أَذْ نْرَاحْ، مِينْزِي وَارْ نْزمَّارْ أَذْ نْژَارْ ؤُذمْ ن ورْيَازْ نِّي، مْغِيرْ مَاڒَا أَقَا أَكِيذْنغْ ؤُمَاثْنغْ أَمَاژُوژْ.‘
\v 27 \add خنِّي\add* إِنَّا أَنغْ ؤُمْسخَّارْ نّشْ، بَابَاثْنغْ: ’كنِّيوْ ثسّْنمْ بلِّي ثْنَاينْ \add ن إِحنْجِيرنْ\add* إِ ذ أَيِي د-ثُورُووْ ثمْغَارْثْ إِنُو.
\v 28 إِفّغْ إِجّنْ زِي غَارِي ؤُشَا نِّيغْ: أَقَا س ثِيذتّْ إِتّْوَابتّقْ! ؤُ أَڒْ ڒخُّو عَاذْ وَارْ ث ژْرِيغْ. \x ◘ \xo 44:‏28 \xt أَمز. 37‏:‏32. \x*
\v 29 مَاڒَا عَاوذْ ثكّْسمْ أَيِي وَا ؤُشَا إِمْسَارْ شَا ن ڒْغَارْ، أَذْ ثسّهْوَامْ شِّيبْ إِنُو س وشْضَانْ غَارْ ڒَاخَارْثْ!‘ \x ◘ \xo 44:‏29 \xt أَمز. 42‏:‏38. \x*
\v 30 ڒخُّو \add خنِّي\add*، مَاڒَا رُوحغْ نشّْ غَارْ ؤُمْسخَّارْ نّشْ، بَابَا، ؤُشَا أَحنْجِيرْ وَارْ كِيذِي إِدْجِي - ڒعْمَارْ نّسْ إِڒْصقْ غَارْ ڒعْمَارْ ن \add بَابَاسْ\add* -
\v 31 أَقَا أَذْ إِمّثْ خْمِي غَا إِژَارْ أَحنْجِيرْ وَارْ إِدْجِي، ؤُشَا إِمْسخَّارنْ نّشْ أَذْ سّهْوَانْ شِّيبْ ن ؤُمْسخَّارْ نّشْ، بَابَاثْنغْ، س وشْضَانْ غَارْ ڒَاخَارْثْ.
\v 32 أَقَا زعْمَا أَمْسخَّارْ نّشْ ذ أَضْمَانْ إِ ؤُحنْجِيرْ-أَ غَارْ بَابَا ؤُمِي إِنَّا: ’مَاڒَا وَارْ ذ أَشْ ث-إِ-د-أَرِّيغْ، ڒخْذنِّي نشّْ أَذْ إِڒِيغْ ذ أَمذْنُوبْ إِ بَابَا إِ ڒبْذَا!‘ \x ◘ \xo 44:‏32 \xt أَمز. 43‏:‏9. \x*
\v 33 إِوَا ڒخُّو، أجّْ أَمْسخَّارْ نّشْ أَذْ إِقِّيمْ ذڭْ ومْشَانْ ن ؤُحنْجِيرْ-أَ أَمْ يِيسْمغْ غَارْ سِيذِي إِنُو، ؤُشَا أجّْ أَحنْجِيرْ أَذْ إِرَاحْ أَكْ-ذ أَيْثْمَاسْ!
\v 34 مَاغَارْ مَامّشْ غَا ڭّغْ أَذْ ڭعّْذغْ غَارْ بَابَا، بْڒَا أَحنْجِيرْ\add -أَ\add* أَكِيذِي؟ مَامّشْ إِ غَا ژَترغْ ڒمْحَاينْ إِ د غَا إِوْضَانْ خْ بَابَا؟“
\b
\b
\c 45
\s1 يُوسُوفْ إِسَّارْڭبْ إِخفْ نّسْ إِ أَيْثْمَاسْ
\m 
\v 1 \add خنِّي\add* وَارْ إِزمَّارْ \add عَاذْ\add* يُوسُوفْ أَذْ إِطّفْ إِخفْ نّسْ زَّاثْ إِ يِينِّي أَكِيذسْ مَارَّا ؤُشَا إِڒَاغَا: ”سُوفّْغمْ مَارَّا إِنِّي أَكِيذِي \add ذَا\add*!“ وَارْ إِقِّيمْ حذْ أَكِيذسْ ڒَامِي إِسّْشنْ يُوسُوفْ إِ يَايْثْمَاسْ مِينْ إِعْنَا.
\v 2 \add ڒخْذنِّي\add* يَارْخُو ثْمِيجَّا نّسْ س إِغُويَّانْ، \add أَڒَامِي ذ أَسْ\add* سْڒِينْ إِمِيصْرِييّنْ، ؤُشَا ؤُڒَا ذ ثَادَّارْثْ ن فِيرْعُونْ ثسْڒَا \add أَيَا\add*.
\v 3 إِنَّا يُوسُوفْ إِ يَايْثْمَاسْ: ”نشّْ ذ يُوسُوفْ! مَا إِدَّارْ عَاذْ بَابَا؟“ أَيْثْمَاسْ وَارْ زمَّارنْ أَذْ خَاسْ د-أَرّنْ، مِينْزِي ثُوغَا ڭّْوذنْ زَّايسْ.
\v 4 إِنَّا يُوسُوفْ إِ يَايْثْمَاسْ: ”قَارّْبمْ-د ڒخُّو غَارِي!“ ؤُشَا نِيثْنِي قَارّْبنْ \add غَارسْ\add*. إِنَّا خنِّي: ”نشّْ ذ يُوسُوفْ ؤُمَاثْومْ، ونِّي ثزّنْزمْ إِ مِيصْرَا. \x ◘ \xo 45:‏4 \xt أَمز. 37‏:‏27؛ إِزهد. 105‏:‏17؛ ڒخ. 7‏:‏9، 13. \x*
\v 5 ڒخُّو، وَارْ كسِّيمْ س ومْنُوسْ ؤُ وَارْ ث تّجِّيمْ أَذْ يِيڒِي ذ أَخيّقْ ذِي ثِيطَّاوِينْ نْومْ ؤُمِي ذ أَيِي ثزّنْزمْ ذَانِيثَا \add إِ مِيصْرَا\add*، أَقَا أَربِّي إِسّكّْ أَيِي-د، مَاحنْذْ أَذْ \add كنِّيوْ\add* جّغْ ثدَّارمْ. \x ◘ \xo 45:‏5 \xt أَمز. 50‏:‏19، 20، 21. \x*
\v 6 أَقَا ڒخُّو \add عَاذْ\add* ثْنَاينْ ن إِسڭّْوُوسَا ن ڒَاژْ ذِي ثمُّورْثْ ؤُشَا قِّيمْ عَاذْ خمْسَا ن إِسڭّْوُوسَا وَارْ ذَايْسنْ إِتِّيڒِي ثْيَارْزَا نِيغْ ثَاميْرَا.
\v 7 \add مَاشَا\add* أَربِّي إِسّكّْ أَيِي-د زَّاثْومْ، حِيمَا أَذْ أَومْ ڭّغْ مِينْ إِقِّيمنْ خْ ثمُّورْثْ ؤُ حِيمَا أَذْ حْضِيغْ ثُوذَارْثْ نْومْ إِ يِيجّْ ن ؤُسنْجمْ إِمْغَارْ. \x ◘ \xo 45:‏7 \xt أَمز. 50‏:‏20\x*
\v 8 \add خنِّي\add* ڒخُّو، كنِّيوْ وَارْ ذ أَيِي د-ثسّكّمْ شَا ذَا، مَاشَا أَربِّي ذ ونِّي ذ أَيِي إِڭِّينْ ذ بَابَاسْ إِ فِيرْعُونْ ذ سِيذِي خْ مَارَّا ثَادَّارْثْ نّسْ ذ ڒْحَاكمْ خْ مَارَّا ثَامُّورْثْ ن مِيصْرَا.
\v 9 قدْجْقمْ ذغْيَا، سْڭعّْذمْ غَارْ بَابَا، إِنِيمْ أَسْ: ’أَمُّو إِ إِقَّارْ مِّيشْ يُوسُوفْ: أَربِّي إِڭَّا أَيِي ذ سِيذِي ن مَارَّا مِيصْرَا. أَرَاحْ-د غَارِي، وَارْ تّعْڭِيزْ.
\v 10 أَذْ ثْزذْغذْ ذِي ثمُّورْثْ ن جُوشَانْ، أَذْ ثِيڒِيذْ زَّاثِي، شكْ ذ إِحنْجِيرنْ نّشْ، ذ إِحنْجِيرنْ ن إِحنْجِيرنْ نّشْ، ذ وُودْجِي ذ إِفُونَاسنْ ذ ثْفُونَاسِينْ ؤُڒَا ذ مَارَّا مِينْ غَاركْ.
\v 11 أَذْ أَشْ ڭّغْ أَرْزقْ ذِينْ، مِينْزِي \add أَذْ د-أَسنْ\add* عَاذْ خمْسَا ن إِسڭّْوُوسَا ن ڒَاژْ، حِيمَا وَارْ ثتّضْعِيفذْ، شكْ \add لَّ\add*، ثَادَّارْثْ نّشْ \add لَّ\add*، ؤُڒَا ذ مَارَّا مِينْ غَاركْ \add لَّ\add*!
\v 12 خْزَارْ، ثِيطَّاوِينْ نْومْ ژْرِينْثْ، ؤُڒَا ذ ثِيطَّاوِينْ ن ؤُمَا بِينْيَامِينْ، أَقَا ذ نشّْ إِ كِيذْومْ إِسَّاوَاڒنْ.
\v 13 عڒْممْ إِ بَابَا خْ مَارَّا أَعُودْجِي إِنُو ذِي مِيصْرَا ؤُ خْ مَارَّا مِينْ ثژْرِيمْ. قدْجْقمْ ذغْيَا، ثِيوْيمْ-د بَابَا ذَا.“ \x ◘ \xo 45:‏13 \xt ڒخ. 7‏:‏14. \x*
\v 14 ؤُشَا إِنْڭزْ خْ يِيرِي ن بِينْيَامِينْ ؤُمَاسْ، إِرُو، ؤُشَا بِينْيَامِينْ إِرُو خْ يِيرِي نّسْ.
\v 15 إِسُّوذمْ مَارَّا أَيْثْمَاسْ، إِرُو خَاسنْ. أَوَارْنِي مَانْ أَيَا سِّيوْڒنْ أَكِيذسْ أَيْثْمَاسْ.
\m 
\v 16 \add ڒَْامِي\add* ثسْڒَا ثَادَّارْثْ ن فِيرْعُونْ ڒخْبَارْ\add -أَ\add*، نَّانْ: ”أَيْثْمَاسْ ن يُوسُوفْ ؤُسِينْ-د!“. ثُوغَا-ث ذ ڒخْبَارْ أَصبْحَانْ ذِي ثِيطَّاوِينْ ن فِيرْعُونْ ذ إِمْسخَّارنْ نّسْ.
\v 17 إِنَّا فِيرْعُونْ إِ يُوسُوفْ: ”إِنِي إِ أَيْثْمَاشْ: ’ڭّمْ أَيَا: سَارْبُومْ زْوَايڒْ نْومْ ؤُشَا ڭعّْذمْ، رُوحمْ غَارْ ثمُّورْثْ ن كنْعَانْ.
\v 18 كْسِيمْ-د بَابَاثْومْ ذ رَادْجْ نْومْ، ثُوسِيمْ-د غَارِي. أَقَا أَذْ أَومْ وْشغْ لمْلِيحْ ن ثمُّورْثْ ن مِيصْرَا ؤُشَا أَذْ ثشّمْ زِي مِينْ إِشْنَانْ ن ثمُّورْثْ. \f ◼ \fr 45:‏18 \ft \bd ’مِينْ إِشْنَانْ‘\bd* - س ثْعِيبْرَانِيثْ ثمَّارْسْ أَمُّو ’ثَاذُونْثْ ن ثمُّورْثْ‘.\f*
\v 19 أَقَا تّْوَاڭّنْثْ ثِيوصَّا ذِي طّْوعْ نّكْ. ڭّمْ أَيَا: كْسِيمْ زِي ثمُّورْثْ ن مِيصْرَا إِكَارُّوثنْ إِ إِحنْجِيرنْ نْومْ ؤُ إِ ثمْغَارِينْ نْومْ، أَوْيمْ-د \add زَّايسْ\add* بَابَاثْومْ ؤُشَا أَسمْ-د \add ذَا\add*.
\v 20 وَارْ تّجِّيمْ ثِيطَّاوِينْ نْومْ أَذْ سّْحِيسّْفنْثْ إِ ڒْقشّْ نْومْ، مِينْزِي لمْلِيحْ ن ثمُّورْثْ ن مِيصْرَا أَذْ يِيڒِي نْومْ.‘ “
\m 
\v 21 ؤُشَا أَمُّو إِ ڭِّينْ أَيْثْ ن إِسْرَائِيل. إِوْشَا أَسنْ يُوسُوفْ إِكَارُّوثنْ خْ ڒُومُورْ ن فِيرْعُونْ ؤُشَا إِوْشَا أَسنْ \add عَاوذْ\add* مَاشَّا إِ وبْرِيذْ.
\v 22 إِوْشَا إِ كُوڒْ إِجّْ زَّايْسنْ وحّْذسْ أَرُّوضْ ن جْذِيذْ، مَاشَا إِ بِينْيَامِينْ إِوْشَا أَسْ ثڒْثْ-مْيَا ن \add ؤُقِييَّاثْ ن\add* نُّوقَارْثْ ذ خمْسَا ن وَارُّوضْ ذ جْذِيذْ.
\v 23 ؤُ أَمُّو \add عَاوذْ\add* إِسّكّْ إِ بَابَاسْعشْرَا ن يغْيَاڒْ شُّورنْ س مِينْ إِفَارْزنْ ن مِيصْرَا ؤُعشْرَا ن ثغْيَاڒْ شُّورنْثْ س إِمنْذِي ذ وغْرُومْ ذ مَاشَّا إِ بَابَاسْ \add ؤُمِي غَا يِيڒِي نتَّا\add* ذڭْ وبْرِيذْ.
\v 24 إِقبّضْ أَيْثْمَاسْ ؤُشَا رُوحنْ. إِنَّا أَسنْ نتَّا: ”وَارْ تّْمنْغِيمْ شَا ذڭْ وبْرِيذْ.“
\v 25 ڭعّْذنْ زِي مِيصْرَا، إِوْضنْ غَارْ ثمُّورْثْ ن كنْعَانْ غَارْ يَاعْقُوبْ، بَابَاثْسنْ.
\v 26 وْشِينْ أَسْ ڒخْبَارْ، نَّانْ: ”يُوسُوفْ أَقَا إِدَّارْ عَاذْ، وَاهْ، أَقَا-ث ذ ڒْحَاكمْ ن مَارَّا ثَامُّورْثْ ن مِيصْرَا!“ \add خنِّي\add* إِسْخفْ وُوڒْ نّسْ، مِينْزِي وَارْ ثنْ يُومِينْ شَا.
\v 27 ؤُمِي ذ أَسْ عَاوْذنْ مَارَّا أَوَاڒنْ ن يُوسُوفْ إِنِّي ذ أَسنْ إِنَّا ؤُ \add ڒَْامِي\add* إِژْرَا إِكَارُّوثنْ إِنِّي د-إِسّكّْ يُوسُوفْ حِيمَا أَذْ ث أَوْينْ، إِعْقبْ-د بُوحْبڒْ ن بَابَاثْسنْ يَاعْقُوبْ.
\v 28 ؤُشَا إِنَّا إِسْرَائِيل: ”كْفَا! يُوسُوفْ مِّي أَقَا إِدَّارْ! أَذْ رَاحغْ ؤُشَا أَذْ ث ژَترْغْ قْبڒْ إِ غَا مّْثغْ!“
\b
\b
\c 46
\s1 أَيْثْمَاسْ ن يُوسُوفْ ؤُسِينْ-د غَارْ مِيصْرَا أَكْ-ذ يَاعْقُوبْ
\m 
\v 1 إِفْسِي إِسْرَائِيل إِقِيضَانْ نّسْ \add سّنِّي\add*، \add يُويُورْ\add* س مَارَّا مِينْ غَارسْ ؤُشَا يِيوضْ غَارْ بِئرْ-سبْعَا. إِقدّمْ \add ذِينْ\add* ثِيغَارْصَا إِ أَربِّي ن بَابَاسْ إِسْحَاقْ.
\v 2 ؤُشَا إِسِّيوڒْ أَربِّي أَكْ-ذ إِسْرَائِيل ذِي إِوحَّانْ ذِي دْجِيڒثْ، إِنَّا: ”يَاعْقُوبْ، يَاعْقُوبْ!“ ؤُشَا إِنَّا نتَّا: ”أَقَا أَيِي ذَا!“
\v 3 \add خنِّي\add* إِنَّا: ”نشّْ ذ أَربِّي، أَربِّي ن بَابَاشْ. وَارْ تّڭّْوذْ، مَاحنْذْ أَذْ ثهْوِيذْ غَارْ مِيصْرَا، مِينْزِي نشّْ أَذْ شكْ ڭّغْ ذِينْ ذ إِجّْ ن ڒْڭنْسْ إِمْغَارْ. \x ◘ \xo 46:‏3 \xt أَمز. 13‏:‏16؛ 16‏:‏10؛ 17‏:‏2؛ 22‏:‏17؛ 26‏:‏24؛ 28‏:‏13؛ 32‏:‏9؛ 35‏:‏11؛ 48‏:‏4. \x*
\v 4 أَذْ كِيذكْ هْوِيغْ غَارْ مِيصْرَا ؤُشَا نشّْ أَذْ شكْ سّْڭعّْذغْ \add عَاوذْ\add* ؤُ يُوسُوفْ أَذْ خَاكْ إِسَّارْسْ إِفَاسّنْ نّسْ خْ ثِيطَّاوِينْ نّشْ.“ \x ◘ \xo 46:‏4 \xt ڒخْڒ. 20‏:‏15؛ أَعَوذ. 10‏:‏22؛ ياش. 24‏:‏4، 5، 6؛ إِزهد. 105‏:‏23، 24؛ إِشا. 52‏:‏4؛ حُوش. 11‏:‏1. \x*
\m 
\v 5 إِكَّارْ يَاعْقُوبْ، إِفّغْ زِي بِئرْ-سبْعَا. كْسِينْ أَيْثْ ن إِسْرَائِيل بَابَاثْسنْ يَاعْقُوبْ ذ إِحنْجِيرنْ نْسنْ ذ ثمْغَارِينْ نْسنْ ذڭْ إِكَارُّوثنْ نِّي د-إِسّكّْ فِيرْعُونْ مَاحنْذْ أَذْ ث يَاوِي. \x ◘ \xo 46:‏5 \xt ڒخ. 7‏:‏15. \x*
\v 6 كْسِينْ ڒبْهَايمْ نْسنْ ذ وَاڭْڒَا إِ يَاربْحنْ ذِي ثمُّورْثْ ن كنْعَانْ ؤُشَا إِوْضنْ غَارْ مِيصْرَا، يَاعْقُوبْ ذ مَارَّا إِحنْجِيرنْ نّسْ أَكِيذسْ:
\v 7 إِحنْجِيرنْ نّسْ ذ إِحنْجِيرنْ ن إِحنْجِيرنْ نّسْ \add جْمِيعْ\add* أَكِيذسْ، ؤُڒَا ذ يسِّيسْ ذ يسِّيثْسنْ ن إِحنْجِيرنْ نّسْ، أَقَا يِيوِي أَكِيذسْ مَارَّا ثَارْوَا نّسْ غَارْ مِيصْرَا. \f ◼ \fr 46:‏7 \ft \bd ’مَارَّا ثَارْوَا نّسْ‘\bd* - س ثْعِيبْرَانِيثْ ’مَارَّا زَّارِيعثْ نّسْ‘.\f*
\b
\s1 ثَارْوَا ن يَاعْقُوبْ
\m 
\v 8 إِنَا ذ \bd إِسْمَاونْ ن أَيْثْ ن إِسْرَائِيل، إِنِّي يُوذْفنْ غَارْ مِيصْرَا\bd*:
\m \bd يَاعْقُوبْ\bd* ذ إِحنْجِيرنْ نّسْ.
\m أَمنْزُو ن يَاعْقُوبْ: رُوبِينْ. \x ◘ \xo 46:‏8 \xt ؤُف. 1‏:‏2؛ 6‏:‏13؛ ڒخْڒ. 26‏:‏5؛ 1 إِم. 4‏-‏8. \x*
\m 
\v 9 ثَارْوَا ن \bd رُوبِينْ\bd*: حَانُوكْ ذ فَالُّو ذ حَاصْرُونْ ذ كَارْمِي. \f ◼ \fr 46:‏9 \ft \bd ’حَانُوكْ‘\bd* - خْزَارْ أَفسْسَّارْ غَارْ أَمز. 4:17. \bd ’فَالُّو‘\bd* - ’أَرْيَازْ إِشنْعنْ‘. \bd ’حَاصْرُونْ‘\bd* - ’ونِّي ذ إِقوَّارنْ س إِجّْ ن ڒْحِيضْ‘. \bd ’كَارْمِي‘\bd* - ’ثَازَايَارْثْ إِنُو‘ نِيغْ ’بَابْ ن ثْزَايَارْثْ‘.\f*
\m 
\v 10 ثَارْوَا ن \bd شِيمْعُونْ\bd*: يَامُويِيلْ ذ يَامِينْ ذ ؤُهَاذْ ذ يَاكِينْ ذ صُوحَارْ ذ شَاوُولْ، مِّيسْ ن \add ثمْغَارْثْ\add* ثَاكنْعَانِيثْ. \x ◘ \xo 46:‏10 \xt ؤُف. 6‏:‏15؛ 1 إِم. 4‏:‏24. \x*
\m 
\v 11 ثَارْوَا ن \bd لَاوِي\bd*: جَارْشُونْ ذ قَاهَاثْ ذ مَارَارِي. \x ◘ \xo 46:‏11 \xt 1 إِم. 5‏:‏27. \x*
\m 
\v 12 ثَارْوَا ن \bd يَاهُوذَا\bd*: عِيرْ ذ ؤُنَانْ ذ شَايْلَا ذ فَارِيصْ ذ زَارَاحْ. مَاشَا عِيرْ ذ ؤُنَانْ مُّوثنْ ذِي ثمُّورْثْ ن كنْعَانْ. ثَارْوَا ن فَارِيصْ ثُوغَا أَثنْ حَاصْرُونْ ذ حَامُولْ. \x ◘ \xo 46:‏12 \xt أَمز. 38‏:‏3، 4، 5؛ 1 إِم. 2‏:‏5. \x*
\m 
\v 13 ثَارْوَا ن \bd إِسَّاكَارْ\bd*: ثُولَاعْ ذ فَاوَّا ذ يُوبْ ذ شِيمْرُونْ.
\m 
\v 14 ثَارْوَا ن \bd زابُولُونْ\bd*: سَارَاذْ ذ إِلُونْ ذ يَاحْلِييِيلْ.
\m 
\v 15 \bd إِنَا \bdit ثُوغَا أَثنْ\bdit* ذ إِحنْجِيرنْ ن لِييَا\bd* إِنِّي ذ أَسْ د-ثُورُووْ إِ يَاعْقُوبْ ذِي فَاذَانْ-أَرَامْ، ؤُشَا \add عَاوذْ\add* يدْجِيسْ ذِينَا. مَارَّا ڒعْمُورْ ن إِحنْجِيرنْ نّسْ ذ ثْحنْجِيرِينْ ثُوغَا أَثنْ ذِي ثْڒَاثَا ؤُ-ثْڒَاثِينْ.
\b
\m 
\v 16 ثَارْوَا ن \bd جَاذْ\bd*: صِيفْيُونْ ذ حَاجِّي ذ شُونِي ذ أَصْبُونْ ذ عِيرِي ذ أَرُوذِي ذ أَرْوِيلِي. \x ◘ \xo 46:‏16 \xt 1 إِم. 5‏:‏11. \x*
\m 
\v 17 إِحنْجِيرنْ ن \bd أَشِيرْ\bd*: يِيمْنَا ذ يِيسْوِي ذ بَارِيعَا ذ ؤُتْشْمَاثْسنْ شَارَاحْ. ذ إِحنْجِيرنْ ن بَارِيعَا: حَابِيرْ ذ مَالْكِييِيلْ. \x ◘ \xo 46:‏17 \xt 1 إِم. 7‏:‏30. \x*
\m 
\v 18 \bd إِنَا \bdit ثُوغَا أَثنْ\bdit* ذ إِحنْجِيرنْ ن زِيلْپَا\bd* ثنِّي إِوْشَا لَابَانْ إِ يدْجِيسْ لِييَا. نتَّاثْ ثُورُووْ-د إِنَا إِ يَاعْقُوبْ، إِنَا سطَّاشْ ذ أَرُّوحْ. \x ◘ \xo 46:‏18 \xt أَمز. 29‏:‏24. \x*
\b
\m 
\v 19 ثَارْوَا ن \bd رَاحِيلْ، ثَامْغَارْثْ ن يَاعْقُوبْ:\bd* يُوسُوفْ ذ بِينْيَامِينْ.
\m 
\v 20 تّْوَاخڒْقنْ-د إِ \bd يُوسُوفْ\bd* ذِي ثمُّورْثْ ن مِيصْرَا مَانَاسَّا ذ إِفْرَايِيمْ، إِنِّي ذ أَسْ د-ثُورُووْ أَسْنَاثْ، يدْجِيسْ ن فُوطِي-فَارَاعْ، أَكهَّانْ ن ؤُنْ. \x ◘ \xo 46:‏20 \xt أَمز. 41‏:‏50؛ 48‏:‏5. \x*
\m 
\v 21 ثَارْوَا ن \bd بِينْيَامِينْ\bd*: بِيلَاعْ ذ بَاكِيرْ ذ أَشْبِيلْ ذ جِيرَا ذ نَاعْمَانْ ذ إِحِي ذ رُوشْ ذ مُوفِّيمْ ذ حُوفِّيمْ ذ أَرْذْ. \x ◘ \xo 46:‏21 \xt 1 إِم. 7‏:‏6؛ 8‏:‏1. \x*
\m 
\v 22 \bd إِنَا \bdit ثُوغَا أَثنْ\bdit* ذ إِحنْجِيرنْ ن رَاحِيلْ\bd*، إِنِّي د-إِتّْوَاوَارْونْ إِ يَاعْقُوبْ، مَارَّا أَرْبعْطَاشْ ذ أَرُّوحْ.
\b
\m 
\v 23 ثَارْوَا ن \bd ذَانْ\bd*: \add مْغِيرْ\add* حُوشِيمْ.
\m 
\v 24 ثَارْوَا ن \bd نَافْثَالِي\bd*: يَاحَاصْوِيلْ ذ جُونِي ذ يِيصْرُو ذ شِيلِّيمْ. \x ◘ \xo 46:‏24 \xt 1 إِم. 7‏:‏13. \x*
\m 
\v 25 \bd إِنَا \bdit ثُوغَا أَثنْ\bdit* ذ إِحنْجِيرنْ ن بِيلْهَا\bd*، ثنِّي إِ ذ أَسْ إِوْشَا لَابَانْ إِ رَاحِيلْ يدْجِيسْ. ثُورُووْ أَسْ-د إِنَا إِ يَاعْقُوبْ، إِنَا مَارَّا \add ثُوغَا أَثنْ\add* سبْعَا ذ أَرُّوحْ. \x ◘ \xo 46:‏25 \xt أَمز. 29‏:‏29. \x*
\b
\m 
\v 26 مَارَّا ڒعْمُورْ نِّي د-يُوسِينْ غَارْ مِيصْرَا أَكْ-ذ يَاعْقُوبْ، إِنِّي د-إِفّْغنْ زڭْ ؤُغزْذِيسْ نّسْ، بْڒَا ثِيمْغَارِينْ ن إِحنْجِيرنْ ن يَاعْقُوبْ، إِنَا مَارَّا ثُوغَا أَثنْ ذِي ستَّا ؤُ-ستِّينْ ڒعْمُورْ.
\v 27 ثَارْوَا ن يُوسُوفْ إِنِّي ذ أَسْ د-إِتّْوَاخڒْقنْ ذِي مِيصْرَا، أَقَا ثْنَاينْ ن ڒعْمُورْ. مَارَّا ڒعْمُورْ ن ثَادَّارْثْ ن يَاعْقُوبْ نِّي د-يُوسِينْ غَارْ مِيصْرَا، \add ثُوغَا أَثنْ\add* ذِي سبْعِينْ. \x ◘ \xo 46:‏27 \xt أَعَوذ. 10‏:‏22؛ ڒخ. 7‏:‏14. \x*
\b
\m 
\v 28 ؤُشَا نتَّا إِسّكّْ يَاهُوذَا زَّاثسْ غَارْ يُوسُوفْ، حِيمَا أَذْ إِسّْشنْ أَبْرِيذْ زَّاثسْ غَارْ جُوشَانْ ؤُشَا إِوْضنْ غَارْ ثمُّورْثْ ن جُوشَانْ.
\v 29 إِنْذهْ يُوسُوفْ \add عَاوذْ\add* أَكَارُّو نّسْ ؤُشَا إِڭعّذْ غَارْ جُوشَانْ، مَاحنْذْ أَذْ إِڒْقَا إِسْرَائِيل، بَابَاسْ. ؤُمِي ذ أَسْ إِمّڒْ إِخفْ نّسْ، إِنْڭزْ أَسْ خْ يِيرِي، إِقِّيمْ إِتّْرُو خْ يِيرِي نّسْ أَطَّاسْ.
\v 30 إِنَّا إِسْرَائِيل إِ يُوسُوفْ: ”ڒخُّو زمَّارغْ نشّْ أَذْ مّْثغْ، ڒخُّو ؤُمِي ژْرِيغْ أَغمْبُوبْ نّشْ، زعْمَا أَقَا عَاذْ ثدَّارذْ!“
\v 31 \add خنِّي\add* إِنَّا يُوسُوفْ إِ يَايْثْمَاسْ ؤُ إِ \add أَيْثْبَابْ ن\add* ثَادَّارْثْ ن بَابَاسْ: ”أَذْ ڭعّْذغْ أَذْ خبَّارغْ فِيرْعُونْ، أَذْ إِنِيغْ: ’أَيْثْمَا ذ ثَادَّارْثْ ن بَابَا، إِنِّي إِدْجَانْ ذِي ثمُّورْثْ ن كنْعَانْ، أَقَا ؤُسِينْ-د غَارِي.
\v 32 إِرْيَازنْ ذ إِمكْسَاونْ ن وُودْجِي، ثُوغَا شغْڒنْ إِخفْ نْسنْ أَكْ ذ ڒبْهَايمْ. أَقَا إِوْينْ-د ؤُدْجِي نْسنْ ذ إِفُونَاسنْ ذ ثْفُونَاسِينْ نْسنْ ذ مَارَّا مِينْ غَارْسنْ.‘
\v 33 مَاڒَا إِمْسَارْ أَذْ أَومْ د-إِڒَاغَا فِيرْعُونْ ؤُشَا أَذْ أَومْ يِينِي: ’مِينْ ثعْنَا ڒْخذْمثْ إِ ثتّڭّمْ؟‘،
\v 34 أَذْ ثِينِيمْ: ’إِمْسخَّارنْ نّشْ ذ إِرْيَازنْ إِنِّي إِشغْڒنْ أَكْ-ذ ڒبْهَايمْ زِي ثمْژِي نْسنْ أَڒْ إِ ڒخُّو، نشِّينْ ؤُڒَا ذ ڒجْذُوذْ نّغْ!‘، حِيمَا أَذْ غَارْومْ يِيڒِي تّسْرِيحْ مَاحنْذْ أَذْ ثْزذْغمْ ذِي ثمُّورْثْ ن جُوشَانْ، مِينْزِي كُوڒْ أَمكْسَاوْ ن وُودْجِي، أَقَا-ث ذ جّْعِيفشْثْ إِ إِمِيصْرِييّنْ.“ \x ◘ \xo 46:‏34 \xt أَمز. 43‏:‏32؛ ؤُف. 8‏:‏22. \x*
\b
\b
\c 47
\s1 إِسْرَائِيلْ أَذْ إِزْذغْ ذِي جُوشَانْ
\m 
\v 1 \add ڒَْامِي\add* د-يُوسَا يُوسُوفْ، إِخبَّارْ فِيرْعُونْ، إِنَّا أَسْ: ”بَابَا ذ أَيْثْمَا ذ وُودْجِي نْسنْ ذ إِفُونَاسنْ ذ ثْفُونَاسِينْ نْسنْ ذ مَارَّا مِينْ غَارْسنْ، أَقَا ؤُسِينْ-د زِي ثمُّورْثْ ن كنْعَانْ. خْزَارْ، \add أَقَا أَثنْ\add* ذِي ثمُّورْثْ ن جُوشَانْ.“ \x ◘ \xo 47:‏1 \xt أَمز. 45‏:‏10. \x*
\v 2 ؤُشَا زِي جَارْ مَارَّا أَيْثْمَاسْ يِيوِي خمْسَا ن يرْيَازنْ، إِقدّمْ أَسْ ثنْ إِ فِيرْعُونْ.
\v 3 \add خنِّي\add* إِنَّا فِيرْعُونْ إِ يَايْثْمَاسْ: ”مِينْ ثعْنَا ڒْخذْمثْ إِ ثتّڭّمْ؟“ نِيثْنِي أَرِّينْ-د خْ فِيرْعُونْ: ”إِمْسخَّارنْ نّشْ ذ إِمكْسَاونْ ن وُودْجِي، أَمْ نشِّينْ أَمْ ڒجْذُوذْ نّغْ.“ \x ◘ \xo 47:‏3 \xt أَمز. 46‏:‏34. \x*
\v 4 نَّانْ عَاوذْ إِ فِيرْعُونْ: ”إِ ثْزذِّيغْثْ ذِي ثمُّورْثْ-أَ أَمْ إِبَارَّانِييّنْ إِ د-نُوسَا، مِينْزِي وَارْ يدْجِي وفْسُو إِ وُودْجِي ن إِمْسخَّارنْ نّشْ، مِينْزِي ڒَاژْ إِقْسحْ ذِي ثمُّورْثْ ن كنْعَانْ. \add خنِّي\add* ڒخُّو، نتّْزَاوڭْ إِ شكْ، أجّْ إِمْسخَّارنْ نّشْ أَذْ زذْغنْ ذِي ثمُّورْثْ ن جُوشَانْ!“
\v 5 ؤُشَا إِسِّيوڒْ فِيرْعُونْ أَكْ-ذ يُوسُوفْ، إِنَّا: ”بَابَاشْ ذ أَيْثْمَاشْ ؤُسِينْ-د غَاركْ.
\v 6 ثَامُّورْثْ ن مِيصْرَا أَقَا-ت نّشْ مَارَّا. أجّْ بَابَاشْ ذ أَيْثْمَاشْ أَذْ زذْغنْ ذِي ثمُّورْثْ إِصبْحنْ، أجّْ إِ-ثنْ أَذْ زذْغنْ ذِي ثمُّورْثْ ن جُوشَانْ ؤُشَا مَاڒَا ثْحكَّارذْ بلِّي أَقَا جَارْ أَسنْ إِرْيَازنْ إِونْڭِيثنْ، ڭّمْ ثنْ ذ إِمحْضَاينْ خْ ڒبْهَايمْ إِنُو.“
\v 7 ؤُشَا إِنْذهْ يُوسُوفْ بَابَاسْ، إِقدّمْ إِ-ث إِ فِيرْعُونْ ؤُشَا يَاعْقُوبْ إِبَاركْ فِيرْعُونْ.
\v 8 إِنَّا فِيرْعُونْ إِ يَاعْقُوبْ: ”مشْهَاڒْ غَاركْ ن إِسڭّْوُوسَا؟“ \f ◼ \fr 47:‏8 \ft \bd ’مشْهَاڒْ غَاركْ ن إِسّڭْوُوسَا؟‘\bd* - س ثْعِيبْرَانِيثْ ’مشْحَاڒْ ؤُسَّانْ ن إِسڭّْوُوسَا ن ثُوذَارْثْ نّشْ؟‘\f*
\v 9 يَاعْقُوبْ يَارَّا-د خْ فِيرْعُونْ: ”مْيَا ؤُ-ثْڒَاثِينْ ن إِسڭّْوُوسَا إِ دَّارغْ ذ أَبَارَّانِي. ؤُسَّانْ ن إِسڭّْوُوسَا ن ثُوذَارْثْ إِنُو يُوقْڒِيڒنْ ؤُ \add شُّورنْ س\add* ڒْغَارْ. وَارْ إِوِيضنْ شَا وُوسَّانْ ن إِسڭّْوُوسَا ن ثُوذَارْثْ ن ڒجْذُوذْ إِنُو ذڭْ وُوسَّانْ ن لْغُورْبَا نْسنْ.“ \x ◘ \xo 47:‏9 \xt إِزهد. 119‏:‏19؛ عبر. 11‏:‏9، 13. \x*
\v 10 \add خنِّي\add* يَاعْقُوبْ إِبَارْكْ فِيرْعُونْ ؤُشَا إِفّغْ سّنِّي زَّاثْ إِ وُوذمْ ن فِيرْعُونْ.
\m 
\v 11 إِسّْشنْ يُوسُوفْ ثَازذِّيغْثْ إِ بَابَاسْ ذ أَيْثْمَاسْ، إِوْشَا أَسنْ ثَاسْغَارْثْ ذِي ثمُّورْثْ ن مِيصْرَا، زِي لمْلِيحْ ن ثمُّورْثْ، ذِي ثمُّورْثْ ن رَاعَامْسِيسْ أَمْ مَامّشْ ث إِوصَّا فِيرْعُونْ.
\v 12 إِعوّڒْ يُوسُوفْ بَابَاسْ ذ أَيْثْمَاسْ ذ مَارَّا ثَادَّارْثْ ن بَابَاسْ. \add إِعوّڒْ ؤُڒَا ذ\add* مَاشَّا إِ إِحنْجِيرنْ إِمژْيَاننْ. \f ◼ \fr 47:‏12 \ft \bd ’مَاشَّا إِ إِحنْجِيرنْ‘\bd* - س ثْعِيبْرَانِيثْ ’مَاشَّا إِ ؤُقمُّومْ ن إِحنْجِيرنْ‘.\f*
\b
\s1 أَسيَّارْ ن يُوسُوفْ ذِي ڒْوقْثْ ن ڒَاژْ
\m 
\v 13 أَغْرُومْ ثُوغَا وَارْ إِدْجِي ذِي ثمُّورْثْ مَارَّا، مِينْزِي ڒَاژْ ثُوغَا إِقْسحْ أَطَّاسْ، أَڒَامِي ثِيوضْ ثمُّورْثْ ن مِيصْرَا ذ ثمُّورْثْ ن كنْعَانْ فنَّانْثْ س ڒَاژْ.
\v 14 \add خنِّي\add* إِيْرُو يُوسُوفْ مَارَّا نُّوقَارْثْ نِّي إِتّْوَافنْ ذِي ثمُّورْثْ ن مِيصْرَا ؤُ ذِي ثمُّورْثْ ن كنْعَانْ ذڭْ ؤُبدّڒْ ن إِمنْذِي إِ إِسْغِينْ. إِڭَّا يُوسُوفْ نُّوقَارْثْ نِّي ذِي ثَادَّارْثْ ن فِيرْعُونْ.
\v 15 \add ؤُمِي\add* ثقْضَا نُّوقَارْثْ زِي ثمُّورْثْ ن مِيصْرَا ذ ثمُّورْثْ ن كنْعَانْ، ؤُسِينْ-د مَارَّا إِمِيصْرِييّنْ غَارْ يُوسُوفْ نَّانْ: ”أوْشْ أَنغْ أَغْرُومْ، مَاغَارْ مَايمِّي غَا نمّثْ زَّاثكْ؟ وَارْ ذِينْ \add عَاذْ\add* شَا نُّوقَارْثْ.“
\v 16 يُوسُوفْ إِنَّا: ”مَاڒَا وَارْ غَارْومْ بُو نُّوقَارْثْ عَاذْ، وْشمْ \add خنِّي\add* ڒبْهَايمْ نْومْ ؤُ نشّْ أَذْ أَومْ وْشغْ \add مَاشَّا\add* ذڭْ ؤُبدّڒْ ن ڒبْهَايمْ نْومْ.“
\v 17 نِيثْنِي إِوْينْ-د ڒبْهَايمْ نْسنْ غَارْ يُوسُوفْ ؤُشَا إِوْشَا أَسنْ يُوسُوفْ أَغْرُومْ ذڭْ \add ومْشَانْ ن\add* إِيْسَانْ ذ وُودْجِي ذ إِفُونَاسنْ ذ ثْفُونَاسِينْ ذ يغْيَاڒْ \add نْسنْ\add* ؤُشَا إِسّشّْ إِ-ثنْ س وغْرُومْ ذڭْ \add ومْشَانْ ن\add* مَارَّا ڒبْهَايمْ نْسنْ ذڭْ ؤُسڭّْوَاسْ نِّي.
\m 
\v 18 \add ؤُمِي\add* إِعْذُو ؤُسڭّْوَاسْ نِّي، ؤُسِينْ-د غَارسْ ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْنَاينْ ؤُشَا نَّانْ أَسْ: ”وَارْ نتّفَّارْ شَا خْ سِيذِي إِنُو بلِّي أَقَا نُّوقَارْثْ نّغْ ثقْضَا ؤُشَا ڒبْهَايمْ أَقَا أَثنْثْ \add ذڭْ ؤُفُوسْ\add* ن سِيذِي إِنُو. وَارْ إِقِّيمْ وَالُو زَّاثْ إِ وُوذمْ ن سِيذِي إِنُو، مْغِيرْ أَرِّيمثْ نّغْ ذ إِيَّارنْ نّغْ.
\v 19 مَايمِّي غَا نمّثْ زَّاثْ إِ ثِيطَّاوِينْ نّشْ، ؤُڒَا ذ نشِّينْ ؤُڒَا ذ إِيَّارنْ نّغْ؟ سغْ أَنغْ، ثسْغذْ ثَامُّورْثْ نّغْ إِ وغْرُومْ ؤُشَا نشِّينْ ذ ثمُّورْثْ نّغْ أَذْ نِيڒِي ذ إِمْسخَّارنْ ن فِيرْعُونْ. أوْشْ \add أَنغْ\add* زَّارِيعثْ \add حِيمَا\add* أَذْ ندَّارْ وَارْ نتّْمتِّي شَا ؤُشَا ثَامُّورْثْ وَارْ ثذِّيكّْوِيڒْ ذ أَمسُّوشِي!“
\m 
\v 20 \add خنِّي\add* إِسْغَا يُوسُوفْ مَارَّا ثَامُّورْثْ ن مِيصْرَا إِ فِيرْعُونْ، مِينْزِي إِمِيصْرِييّنْ زّنْزنْ مَارَّا إِيَّارْ نْسنْ، مِينْزِي ثُوغَا ڒَاژْ إِقْسحْ خَاسنْ. ؤُ \add أَمُّو إِ\add* ثذْوڒْ ثمُّورْثْ \add ذ أَڭْڒَا\add* ن فِيرْعُونْ.
\v 21 ؤُشَا إِسّْمُوطِّييْ ڒْڭنْسْ زڭْ ؤُنڭَّارُو ن ويْمِيرْ أَڒْ أَنڭَّارُو نّغْنِي ن \add ويْمِيرْ\add* ن مِيصْرَا غَارْ ثْندَّامْ.
\v 22 مْغِيرْ ثَامُّورْثْ ن إِكهَّاننْ وَارْ ت إِسْغِي شَا. أَقَا إِكهَّاننْ غَارْسنْ إِشْثْ ن ڒْمُونثْ زِي فِيرْعُونْ، نِيثْنِي تّتّنْ ثَاسْغَارْثْ نْسنْ، ثنِّي إِ ذ أَسنْ إِوْشَا فِيرْعُونْ. خْ ؤُيَا وَارْ زّنْزنْ شَا ثَامُّورْثْ نْسنْ.
\v 23 \add خنِّي\add* إِنَّا يُوسُوفْ إِ ڒْڭنْسْ: ”خْزَارْ، أَسّْ-أَ نشّْ سْغِيغْ كنِّيوْ ؤُڒَا ذ ثَامُّورْثْ نْومْ إِ فِيرْعُونْ. خْزَارمْ، أَقَا ذَا زَّارِيعثْ نْومْ. زَارْعمْ زَّايسْ ثَامُّورْثْ!
\v 24 زِي ڒْغِيدْجثْ أَذْ ثوْشمْ ثَاسْغَارْثْ ثخْمُوسشْثْ إِ فِيرْعُونْ ؤُ أَربْعَا ن ثْسقَّارْ \add إِ إِقِّيمنْ\add* أَذْ إِڒِينْثْ \add إِ يِيخفْ\add* نْومْ ذ زَّارِيعثْ إِ ييَّارْ ؤُشَا \add أَذْ إِڒِينْثْ\add*، مَاحنْذْ أَذْ زَّايْسنْثْ ثشّمْ كنِّيوْ أَكْ-ذ أَيْثْبَابْ ن ثَادَّارْثْ نْومْ ؤُ \add عَاوذْ\add*، مَاحنْذْ أَذْ \add زَّايْسنْثْ\add* شّنْ إِحنْجِيرنْ إِمژْيَاننْ نْومْ.“
\v 25 نِيثْنِي نَّانْ: ”شكْ ثحْضِيذْ ثُوذَارْثْ نّغْ. أجّْ أَنغْ أَذْ نَافْ أَرْضَا ذِي ثِيطَّاوِينْ ن سِيذِي إِنُو ؤُشَا نشِّينْ أَذْ نِيڒِي ذ إِمْسخَّارنْ إِ فِيرْعُونْ.“
\v 26 إِڭَّا يُوسُوفْ مَانْ أَيَا ذ ثَاوْصيّثْ إِ ذِينْ إِدْجَانْ أَڒْ أَسّْ-أَ، بلِّي إِشْثْ ن ثسْغَارْثْ ن ثخْمُوسشْثْ \add ن ڒْغِيدْجثْ\add* ن ثمُّورْثْ ن مِيصْرَا أَذْ ثِيڒِي إِ فِيرْعُونْ. مْغِيرْ إِيَّارنْ ن إِكهَّاننْ \add قِّيمنْ\add* ذ أَڭْڒَا نْسنْ، وَارْ دِّيكّْوِيڒنْ شَا \add ذ أَڭْڒَا\add* ن فِيرْعُونْ.
\b
\s1 ڒْموْثْ ن يَاعْقُوبْ ثُوذسْ-د
\m 
\v 27 أَمُّو إِ إِزْذغْ إِسْرَائِيل ذِي ثمُّورْثْ ن مِيصْرَا، ذِي ثمُّورْثْ ن جُوشَانْ، ملّْكنْ ذَايسْ ؤُشَا وْشِينْ ڒْغِيدْجثْ ؤُشَا كْثَارنْ س يِيجّْ ن شّْكلْ إِمْغَارْ.
\v 28 إِدَّارْ يَاعْقُوبْ ذِي ثمُّورْثْ ن مِيصْرَا سْبعْطَاشْ ن إِسڭّْوُوسَا ؤُشَا ثُوغَا ؤُسَّانْ ن يَاعْقُوبْ، إِسڭّْوُوسَا ن ثُوذَارْثْ نّسْ، مْيَا ؤُ-سبْعَا ؤُ-ربْعِينْ ن إِسڭّْوُوسَا.
\v 29 \add ؤُمِي\add* د-إِوْضنْ وُوسَّانْ إِ إِسْرَائِيل أَذْ إِمّثْ، إِڒَاغَا-د خْ يُوسُوفْ مِّيسْ، إِنَّا أَسْ: ”مَاڒَا ؤُفِيغْ أَرْضَا ذِي ثِيطَّاوِينْ نّشْ، تّْزَاوَاڭغْ شكْ، أَذْ ثڭّذْ أَفُوسْ نّشْ سَاذُو ثْمصَّاضْثْ إِنُو ؤُشَا أڭّْ أَكِيذِي س ثْمخْسِيوْثْ إِشوَّارنْ ذ ڒَامَانْ ؤُ وَارْ ذ أَيِي نطّڒْ شَا ذِي مِيصْرَا، \x ◘ \xo 47:‏29 \xt أَمز. 24‏:‏2. \x*
\v 30 مَاشَا خْمِي غَا ڭّغْ أَذْ أَريّْحغْ جَارْ ڒجْذُوذْ إِنُو، \add خنِّي\add* أَوِي أَيِي زِي مِيصْرَا ؤُشَا نْضڒْ أَيِي ذڭْ ونْضڒْ نْسنْ. يَارَّا-د خَاسْ: ”نشّْ أَذْ ڭّغْ مِينْ ثنِّيذْ!“
\v 31 \add خَاسْ ؤُشَا\add* إِنَّا أَسْ: ”جَادْجْ أَيِي!“، ؤُشَا إِجُّودْجْ أَسْ. ڒخْذنِّي يُوضَارْ إِسْرَائِيل خْ ؤُزدْجِيفْ ن قَامَا. \x ◘ \xo 47:‏31 \xt عبر. 11‏:‏21. \x*
\b
\b
\c 48
\s1 يَاعْقُوبْ إِبَاركْ ثَارْوَا ن يُوسُوفْ
\m 
\v 1 أَوَارْنِي مَانْ أَيَا إِمْسَارْ، إِتّْوَانَّا إِ يُوسُوفْ: ”خْزَارْ، أَقَا بَابَاشْ إِحْڒشْ!“ \add خنِّي\add* إِكْسِي أَكِيذسْ ثْنَاينْ ن إِحنْجِيرنْ نّسْ مَانَاسَّا ذ إِفْرَايِيمْ.
\v 2 خبَّارنْ يَاعْقُوبْ، نَّانْ: ”خْزَارْ، أَقَا مِّيشْ يُوسُوفْ أَذْ غَاركْ د-يَاسْ!“ \add خنِّي\add* إِڭَّا إِسْرَائِيل ؤُڒْ ذڭْ إِخفْ نّسْ ؤُشَا إِكَّارْ إِقِّيمْ خْ قَامَا.
\v 3 \add خنِّي\add* إِنَّا يَاعْقُوبْ إِ يُوسُوفْ: ”أَربِّي، أَمْزمَّارْ خْ كُوڒْشِي، أَقَا إِبَانْ أَيِي-د ذِي لُوزْ، ذِي ثمُّورْثْ ن كنْعَانْ، ؤُ أَقَا نتَّا إِبَارْكْ أَيِي. \x ◘ \xo 48:‏3 \xt أَمز. 17‏:‏1. \x*
\v 4 ؤُ أَقَا نتَّا إِنَّا أَيِي: ”خْزَارْ، أَذْ شكْ أَرّغْ أَذْ ثڭّذْ ڒْغِيدْجثْ ؤُشَا أَذْ شكْ كتَّارغْ، أَذْ شكْ ڭّغْ ذ إِجّْ ن وڭْرَاوْ ن ڒڭْنُوسْ، أَذْ أَشْ وْشغْ ثَامُّورْثْ-أَ ذ أَڭْڒَا إِ ڒبْذَا ؤُ إِ زَّارِيعثْ نّشْ أَوَارْنِي أَشْ. \x ◘ \xo 48:‏4 \xt أَمز. 28‏:‏3؛ 35‏:‏11. \x*
\v 5 ؤُشَا ڒخُّو، أَقَا ثْنَاينْ ن إِحنْجِيرنْ نّشْ، إِفْرَايِيمْ ذ مَانَاسَّا، إِنِّي ذ أَشْ د-إِتّْوَاخڒْقنْ ذِي ثمُّورْثْ ن مِيصْرَا قْبڒْ إِ غَاركْ د-ؤُسِيغْ ذِي ثمُّورْثْ ن مِيصْرَا، أَقَا أَثنْ إِنُو، أَمْ رُوبِينْ ذ شِيمْعُونْ إِ إِدْجَانْ إِنُو. \x ◘ \xo 48:‏5 \xt أَمز. 41‏:‏50؛ 46‏:‏20. \x*
\v 6 \add مَاشَا\add* إِنِّي ذ أَشْ د-إِتّْوَاخڒْقنْ أَوَارْنِي أَسنْ، أَذْ إِڒِينْ نّشْ. أَذْ تّْوَاسمَّانْ خْ يِيسمْ ن أَيْثْمَاثْسنْ ذِي ڒْوَارْثْ نْسنْ.
\v 7 ؤُمِي د-ؤُسِيغْ زِي فَاذَانْ-أَرَامْ، ثمُّوثْ رَاحِيلْ زَّاثِي ذِي ثمُّورْثْ ن كنْعَانْ ذڭْ وبْرِيذْ، ڒَامِي ثُوغَا عَاذْ وَارْ ثِيڭّْوِيجْ خْ إِفْرَاثَا. نضْڒغْ ت ذِينْ ذڭْ وبْرِيذْ غَارْ إِفْرَاثَا!“، أَقَا-ت ذ بَايْثْ-لَاحْمْ. \x ◘ \xo 48:‏7 \xt أَمز. 35‏:‏19. \x*
\v 8 إِژْرَا إِسْرَائِيل إِحنْجِيرنْ ن يُوسُوفْ، إِنَّا: ”مِينْ عْنَانْ إِنَا؟“
\v 9 يَارَّا-د يُوسُوفْ خْ بَابَاسْ: ”ذ إِحنْجِيرنْ إِنُو إِ ذ أَيِي إِوْشَا أَربِّي ذَانِيثَا.“ إِنَّا \add أَسْ\add*: ”سْقَارّْبمْ ثنْ-د غَارِي ؤُشَا أَذْ ثنْ بَارْكغْ!“
\v 10 ثُوغَا ثِيطَّاوِينْ ن إِسْرَائِيل ؤُژْغنْثْ س ثوْسَارْ، وَارْ إِقِّيمْ إِتّْوَاڒَا. إِسّْقَارّبْ أَسْ ثنْ-د، خنِّي إِسُّوذمْ إِ-ثنْ، إِذَارّعْ أَسنْ.
\v 11 إِنَّا إِسْرَائِيل إِ يُوسُوفْ: ”وَارْ ذ أَيِي إِتّْغِيڒْ أَذْ ژَترغْ \add عَاذْ\add* ؤُذمْ نّشْ. خْزَارْ، أَربِّي إِڭَّا أَيِي أَذْ ژَترغْ عَاذْ ثَارْوَا نّشْ!“ \f ◼ \fr 48:‏11 \ft \bd ’ثَارْوَا نّشْ‘\bd* - س ثْعِيبْرَانِيثْ ’زَّارِيعثْ نّشْ‘.\f*
\v 12 \add خنِّي\add* إِسّْضَارْ إِ-ثنْ يُوسُوفْ خْ إِفَادّنْ نّسْ ؤُشَا إِبنْذقْ س وُوذمْ نّسْ غَارْ ثمُّورْثْ.
\v 13 ؤُشَا إِكْسِي إِ-ثنْ يُوسُوفْ س ثْنَاينْ إِذْسنْ، إِفْرَايِيمْ س ؤُفُوسِي نّسْ أَرنْذَاذْ ن ؤُزڒْمَاضْ ن إِسْرَائِيل ؤُ مَانَاسَّا س ؤُزڒْمَاضْ نّسْ أَرنْذَاذْ ن ؤُفُوسِي ن إِسْرَائِيل ؤُشَا إِسّْقَارّبْ أَسْ \add ثنْ\add*-د.
\v 14 إِسّْوِيژّضْ إِسْرَائِيل يفُوسْ نّسْ، إِسَّارْسْ إِ-ث خْ ؤُزدْجِيفْ ن إِفْرَايِيمْ، وَاخَّا ثُوغَا-ث ذ أَمَاژُوژْ، ذ أَزڒْمَاضْ نّسْ خْ ؤُزدْجِيفْ ن مَانَاسَّا. إِسَّارْسْ أَمُّو إِفَاسّنْ نّسْ مَامّشْ نّغْنِي نعْمَاذَا، وَاخَّا مَانَاسَّا ثُوغَا-ث ذ أَمنْزُو.
\v 15 إِسْرَائِيل إِبَارْكْ يُوسُوفْ، إِنَّا: ”ذ أَربِّي، ونِّي ؤُمِي ڒجْذُوذْ إِنُو، إِبْرَاهِيمْ ذ إِسْحَاقْ، ؤُيُورنْ زَّاثسْ، أَربِّي، ونِّي إِدْجَانْ ذ أَمكْسَاوْ إِنُو زڭْ وَامِي دْجِيغْ أَڒْ أَسّْ-أَ، \f ◼ \fr 48:‏15 \ft \bd ’زَّاثسْ‘\bd* - س ثْعِيبْرَانِيثْ ’زَّاثْ إِ ؤُغمْپُوبْ نّسْ‘، إِخْسْ أَذْ يِينِي ’ذِي ڒْحضْرَا نّسْ‘.\f*  \x ◘ \xo 48:‏15 \xt عبر. 11‏:‏21. \x*
\v 16 لْمَالَاكْ نِّي ذ أَيِي إِفْذِينْ زِي مَارَّا ثُوعفّْنَا، إِڒِي نتَّا أَذْ إِبَارْكْ إِحنْجِيرنْ-أَ ؤُ إِڒِي أَذْ إِتّْوَاڒَاغَا إِسمْ إِنُو ذَايْسنْ ؤُڒَا ذ إِسمْ ن ڒجْذُوذْ إِنُو، إِبْرَاهِيمْ ذ إِسْحَاقْ. إِڒِي أَذْ مَّارنْينْ أَڒْ غَا ذوْڒنْ ذ إِجّْ ن ؤُبَارُّو \add أَمْ إِسڒْمَانْ ذڭْ وَامَانْ\add* ذِي ڒْوسْطْ ن ثمُّورْثْ!“ \f ◼ \fr 48:‏16 \ft \bd ’إِفْذِينْ‘\bd* - خْزَارْ إِزهد. 78:35.\f*  \x ◘ \xo 48:‏16 \xt أَمز. 31‏:‏42؛ 32‏:‏1. \x*
\m 
\v 17 \add ؤُمِي\add* إِژْرَا يُوسُوفْ، بلِّي بَابَاسْ إِڭَّا أَفُوسْ أَفُوسِي نّسْ خْ ؤُزدْجِيفْ ن إِفْرَايِيمْ، ثُوغَا-ت ذ إِشْثْ ن ڒعْڒَامثْ وَارْ ثحّْڒِي غَارسْ ذِي ثِيطَّاوِينْ نّسْ ؤُشَا إِطّفْ أَفُوسْ ن بَابَاسْ، حِيمَا أَذْ ث إِبدّڒْ زڭْ ؤُزدْجِيفْ ن إِفْرَايِيمْ غَارْ ؤُزدْجِيفْ ن مَانَاسَّا.
\v 18 إِنَّا يُوسُوفْ إِ بَابَاسْ: ”وَارْ تّڭّْ شَا أَمُّو، \add أَ\add* بَابَا، مِينْزِي ذ وَا ذ أَمنْزُو، أڭّْ أَفُوسِي نّشْ خْ ؤُزدْجِيفْ نّسْ.“
\v 19 \add مَاشَا\add* بَابَاسْ وَارْ إِخْسْ شَا، إِنَّا: ”سّْنغْ، \add أَ\add* مِّي، سّْنغْ. عَاوذْ نتَّا أَذْ إِذْوڒْ ذ إِجّْ ن ڒْڭنْسْ، أَذْ إِمْغَارْ عَاوذْ، مَاشَا ؤُمَاسْ أَمَاژُوژْ أَذْ يِيڒِي كْثَارْ زَّايسْ، زَّارِيعثْ نّسْ أَذْ ثذْوڒْ ذ ثَاشُورّثْ ن ڒڭْنُوسْ.“ \x ◘ \xo 48:‏19 \xt رَاع. 4‏:‏11، 12. \x*
\v 20 ؤُشَا \add أَمُّو\add* إِ ثنْ إِبَاركْ ذڭْ وَاسّْ نِّي، إِنَّا: ”ذَايكْ، \add ذڭْ يِيسمْ نّكْ\add*، \add أَ يُوسُوفْ\add* أَذْ إِبَاركْ \add ڒْْڭنْسْ\add* إِسْرَائِيل، أَذْ إِنِينْ: ’أَذْ كنِّيوْ يَارّْ أَربِّي أَمْ إِفْرَايِيمْ ذ مَانَاسَّا!‘ “ ؤُشَا يَارَّا إِفْرَايِيمْ أَذْ إِبدّْ زَّاثْ إِ مَانَاسَّا. \x ◘ \xo 48:‏20 \xt إِرْم. 31‏:‏20. \x*
\v 21 \add أَوَارْنِي أَسْ\add* إِنَّا إِسْرَائِيل إِ يُوسُوفْ: ”خْزَارْ، أَذْ مّْثغْ، مَاشَا أَربِّي أَذْ يِيڒِي أَكِيذْومْ، أَذْ كنِّيوْ إِسّْمُوطِّييْ غَارْ ثمُّورْثْ ن ڒجْذُوذْ نْومْ.
\v 22 أَقَا وْشِيغْ أَشْ إِشْثْ ن ثسْغَارْثْ ن إِذُورَارْ خْ مِينْ وْشِيغْ إِ يَايْثْمَاشْ، ثنِّي كْسِيغْ نشّْ زڭْ إِفَاسّنْ ن إِمُورِييّنْ س سِّيفْ ذ ڒْقوْسْ إِنُو.“ \x ◘ \xo 48:‏22 \xt ياش. 13‏:‏7؛ 16‏:‏1؛ 17‏:‏1؛ 24‏:‏8. \x*
\b
\b
\c 49
\s1 يَاعْقُوبْ إِبَاركْ ثَارْوَا نّسْ
\m 
\v 1 إِڒَاغَا يَاعْقُوبْ خْ إِحنْجِيرنْ نّسْ، إِنَّا: ”سْمُونمْ-د إِخفْ نْومْ، أَذْ أَومْ إِنِيغْ مِينْ ذ أَومْ غَا إِمْسَارنْ ذڭْ ؤُنڭَّارْ ن وُوسَّانْ.
\v 2 سْمُونمْ-د إِخفْ نْومْ ؤُشَا سْڒمْ، \add أَ\add* ثَارْوَا ن يَاعْقُوبْ، سْڒمْ إِ إِسْرَائِيل، بَابَاثْومْ.
\m 
\v 3 \bd رُوبِينْ\bd*، شكْ ذ أَمنْزُو إِنُو، جّهْذْ إِنُو، ذ أَمزْوَارْ ن ثرْيَاسْثْ إِنُو، أَقَا شكْ ذ أَمْسضْفَارْ إِنُو ذِي ڒُوعْڒَا، ذ أَمْسضْفَارْ \add إِنُو\add* ذِي ڒْعزّْ. \x ◘ \xo 49:‏3 \xt أَمز. 29‏:‏32؛ Deu. 21‏:‏17؛ إِزهد. 78‏:‏51. \x*
\v 4 شكْ أَمشْنَاوْ أَمَانْ إِتّْنقْڒَابنْ، وَارْ د أَيِي ثْضفَّارذْ، أَقَا شكْ ثْڭعّْذذْ غَارْ ڒشْثُو ن ڒمْڒَاشْ ن بَابَاشْ، ڒخْذنِّي ثسّْفضْحذْ \add ث\add*، أَقَا غَارْ ڒشْثُو إِنُو إِڭعّذْ. \x ◘ \xo 49:‏4 \xt أَمز. 35‏:‏22؛ 1 إِم. 5‏:‏1. \x*
\m 
\v 5 \bd شِيمْعُونْ\bd* ذ \bd لَاوِي\bd* ذ أَوْمَاثنْ! ڒمْوَاسْ نْسنْ ذ ڒسْنَاحْ ن لْعُونْفْ.
\v 6 ذِي ثْمعْمُوتْشْ نْسنْ وَارْ إِتِّيذفْ ڒعْمَارْ إِنُو، ذڭْ وڭْرَاوْ نْسنْ وَارْ إِشَارّشْ وُوڒْ إِنُو. أَقَا ذڭْ ؤُخيّقْ نْسنْ نْغِينْ إِجّْ ن ورْيَازْ ؤُشَا إِعْجبْ أَسنْ أَذْ قسّنْ إِژوْرَانْ ن إِضَارنْ ن ؤُفُونَاسْ. \x ◘ \xo 49:‏6 \xt أَمز. 34‏:‏25. \x*
\v 7 ذ أَمنْعُوڒْ أَخيّقْ نْسنْ، مِينْزِي وَانِيثَا إِجْهذْ أَطَّاسْ، ؤُڒَا ذ أَذُوقّزْ \add ن ؤُفُوڭمْ\add* نْسنْ، مِينْزِي إِقْسحْ. نشّْ أَذْ ثنْ بْضِيغْ خْ يَاعْقُوبْ، أَذْ ثنْ سُّويُوسغْ ذِي إِسْرَائِيل. \x ◘ \xo 49:‏7 \xt ياش. 19‏:‏1؛ 21‏:‏3‏-‏45. \x*
\m 
\v 8 \bd يَاهُوذَا\bd*، أَيْثْمَاشْ أَذْ شكْ سّمْغَارنْ. أَفُوسْ نّشْ أَذْ يِيڒِي خْ يِيرِي ن ڒْعذْيَانْ نّشْ ؤُ إِحنْجِيرنْ ن بَابَاشْ أَذْ أَشْ بنْذْقنْ.
\v 9 يَاهُوذَا ذ إِجّْ ن مِّيسْ ن وَايْرَاذْ. زِي زَّارْذثْ إِ ثُوڒْيذْ، \add أَ\add* مِّي. إِقْوسْ أَمشْنَاوْ أَيْرَاذْ ؤُ أَمشْمَاوْ ثَايْرَاذْثْ. وِي إِزعّمنْ أَذْ ث-د-إِسّْفَاقْ؟ \x ◘ \xo 49:‏9 \xt ڒخْڒ. 24‏:‏9؛ مِيخَا 5‏:‏7. \x*
\v 10 ثَاغَّارْشْثْ \add ن ڒْحَاكمْ\add* وَارْ إِتّْوَاكّسْ خْ يَاهُوذَا ؤُڒَا ذ أَزدْجَاضْ \add ن صُّولْطَا\add* زِي جَارْ إِضَارنْ نّسْ، أَڒْ د غَا يَاسْ ونِّي إِ غَا إِوْشنْ أَرَّاحثْ ؤُشَا أَذْ أَسْ طَاعنْ ڒڭْنُوسْ. \x ◘ \xo 49:‏10 \xt مت. 2‏:‏6. \x*
\v 11 إِقّنْ غَارْ ثْزَايَارْثْ أَسْنُوسْ نّسْ ذ مِّيسْ نّسْ ن ثغْيُوتْشْ غَارْ ثْزَايَارْثْ إِشنّْعنْ أَطَّاسْ، إِسِّيرْذْ أَرُّوضْ نّسْ ذِي بِينُو ؤُ أَرُّوضْ نّسْ ذڭْ إِذَامّنْ ن ؤُضِيڒْ.
\v 12 ثِيطَّاوِينْ \add نّسْ\add* ذ ثِيبَارْشَانِينْ س بِينُو ؤُ ثِيغْمَاسْ \add نّسْ\add* ذ ثِيشمْڒَاڒِينْ س ؤُغِي.
\m 
\v 13 \bd زابُولُونْ\bd* أَذْ إِزْذغْ غَارْ ثْمَا ن ڒبْحَارْ، أَذْ يِيڒِي ذ ڒْمُويِّي إِ إِغَارُّوبَا. أَغزْذِيسْ نّسْ أَذْ يَاريّحْ خْ صِيذُونْ. \x ◘ \xo 49:‏13 \xt ياش. 19‏:‏10، 11. \x*
\m 
\v 14 \bd إِسَّاكَارْ\bd* ذ إِجّْ ن وغْيُوڒْ إِقْسحْ، إِزّڒْ جَارْ ثْنَاينْ ن ڒْمذْوَاثْ.
\v 15 ؤُمِي إِژْرَا أَرَّاحثْ ذ لمْلِيحْ ؤُ ثَامُّورْثْ أَقَا ثَارشّقْ، إِقْوسْ، إِڭَّا ثِيغَارْضِينْ نّسْ مَاحنْذْ أَذْ يَارْبُو \add أَرّْمحْ\add* ؤُشَا \add أَمُّو إِ\add* إِذْوڒْ سَاذُو أَزَايْڒُو ن إِسْمغْ.
\m 
\v 16 \bd ذَانْ\bd* أَذْ إِحْكمْ ڒْڭنْسْ نّسْ أَمْ يِيشْثْ زِي ثْقبَّاڒْ ن إِسْرَائِيل.
\v 17 أَذْ يِيڒِي ذَانْ ذ أَفِيغَارْ ذڭْ وبْرِيذْ، ثَاڒفْسَا ذڭْ ؤُمسْرُوقْ، ونِّي إِزعّْفنْ ذڭْ إِنِيرْزَاونْ ن ؤُيِيسْ، أَڒْ غَا إِوْضَا ونِّي \add خَاسْ\add* إِنْيِينْ غَارْ ضفَّارْ.
\v 18 أَسنْجمْ نّشْ إِ تّْرَاجِيغْ، \add أَ\add* سِيذِي!
\m 
\v 19 \bd جَاذْ\bd*، أَذْ خَاسْ حجْمنْثْ بَانْذِييَّاثْ، \add مَاشَا\add* أَذْ خَاسنْ إِذَارّشْ.
\m 
\v 20 \bd أَشِيرْ\bd*، أَغْرُومْ نّسْ أَذْ يِيڒِي ذ أَغْرُومْ إِسْمنْ، نتَّا أَذْ إِقدّمْ مَاشَّا يِيزِيذنْ إِڭلّْذنْ.
\m 
\v 21 \bd نَافْثَالِي\bd* ذ إِشْثْ ن ثُوذَاذْثْ إِتّْوَاضڒْقنْ، إِسُّوفُّوغْ أَوَاڒنْ شْنَانْ.
\m 
\v 22 \bd يُوسُوفْ\bd* ذ مِّيسْ ن ثْشجَّارْثْ إِتِّيشنْ ڒْغِيدْجثْ، مِّيسْ ن ثْشجَّارْثْ إِتِّيشنْ ڒْغِيدْجثْ غَارْ ثَاڒَا. يسِّيسْ ڭُّورنْثْ خْ وغْبَارْ. \x ◘ \xo 49:‏22 \xt 1 إِم. 5‏:‏1. \x*
\v 23 نِيثْنِي سَّارزْڭنْ خَاسْ \add ثُوذَارْثْ\add*، نيّْشنْ خَاسْ، \add وَاهْ\add* إِمْجبَّاذنْ نْ ڒْقوْسْ ضْفَارنْ ث، \x ◘ \xo 49:‏23 \xt أَمز. 50‏:‏20. \x*
\v 24 مَاشَا ڒْقوْسْ نّسْ إِقِّيمْ إِمْحضْ ؤُ إِغَادْجنْ ن إِفَاسّنْ نّسْ قِّيمنْ أَرْخُونْ س إِفَاسّنْ ن ؤُمْزمَّارْ ن يَاعْقُوبْ - خْ ؤُيَا نتَّا ذ أَمكْسَاوْ ذ ثَاصْضَارْثْ ن إِسْرَائِيل -
\v 25 س أَربِّي ن بَابَاشْ ونِّي شكْ إِ غَا إِعَاوْننْ، أَمْزمَّارْ خْ كُوڒْشِي، ونِّي شكْ إِ غَا إِبَارْكنْ س لْبَارَاكَاثْ ن ؤُجنَّا سنّجْ، س لْبَارَاكَاثْ ن \add وَامَانْ\add* إِهوْڒنْ إِ ذِينْ إِدْجَانْ سْوَادَّايْ، س لْبَارَاكَاثْ ن ثُوبّشْثْ ذ ڒمْڒَاوثْ.
\v 26 لْبَارَاكَاثْ ن بَابَاشْ ذ ثِيمقّْرَانِينْ ؤُعْڒَانْثْ خْ لْبَارَاكَاثْ ن يِينِّي ذ أَيِي د-يجِّينْ \add ؤُشَا تَّاكّْوَاضنْثْ\add* غَارْ ثْقِيشَّاثِينْ ن ثوْرِيرِينْ ن ڒبْذَا. أَذْ إِڒِينْثْ خْ ؤُزدْجِيفْ ن يُوسُوفْ، خْ ثُوشّنْثْ ن ؤُشُوَّافْ ن ونِّي يَاربُّو تَّاجْ \add ن وعْزَارْ\add* جَارْ أَيْثْمَاسْ. \x ◘ \xo 49:‏26 \xt أَعَوذ. 33‏:‏16\x*
\m 
\v 27 \bd بِينْيَامِينْ\bd* ذ إِجّْ ن وُوشّنْ إِتّْمزَّاقْ. غَارْ صّْبحْ أَذْ إِسَارْضْ زَّارْذثْ ؤُ س دْجِيڒثْ إِبطَّا ثَاكشَّاضْثْ.“
\m 
\v 28 مَارَّا إِنَا ذ ثنْعَاشْ ن ثْقبَّاڒْ ن إِسْرَائِيل. ذ مَانْ أَيَا مِينْ ذ أَسنْ إِنَّا بَابَاثْسنْ ؤُشَا إِبَارْكْ إِ-ثنْ، \add وَاهْ،\add* إِبَارْكْ إِ-ثنْ، كُوڒْ إِجّْ س لْبَارَاكَا نّسْ.
\v 29 يُومُورْ إِ-ثنْ، إِنَّا أَسنْ: ”أَذْ مَّارنْيغْ غَارْ ڒْڭنْسْ إِنُو. نضْڒمْ أَيِي أَكْ-ذ ڒجْذُوذْ إِنُو ذڭْ إِفْرِي ونِّي إِدْجَانْ ذڭْ إِيَّارْ ن إِفْرُونْ، أَحِيتِّي،
\v 30 ذڭْ إِفْرِي ونِّي إِدْجَانْ ذڭْ إِيَّارْ ن مَاكْفِيلَا إِ إِدْجَانْ زَّاثْ إِ مَامْرِي ذِي ثمُّورْثْ ن كنْعَانْ، ثنِّي إِسْغَا إِبْرَاهِيمْ أَكْ-ذ ييَّارْ زِي إِفْرُونْ، أَحِيتِّي، حِيمَا أَذْ يِيڒِي ذ أَنْضڒْ نّسْ. \x ◘ \xo 49:‏30 \xt أَمز. 23‏:‏9، 16. \x*
\v 31 ذِينِّي إِ نضْڒنْ إِبْرَاهِيمْ ذ سَارَا ثَامْغَارْثْ نّسْ. ذِينِّي إِ نضْڒنْ إِسْحَاقْ ذ ثمْغَارْثْ نّسْ رِيفْقَا. ؤُ نشّْ نضْڒغْ ذِينْ لِييَا. \x ◘ \xo 49:‏31 \xt أَمز. 25‏:‏9؛ 35‏:‏29؛ ڒخ. 7‏:‏16. \x*
\v 32 إِيَّارْ س إِفْرِي إِ ثُوغَا ذَايسْ إِدْجَانْ إِمّْسغْ خْ ثَارْوَا ن حِيثْ.“
\m 
\v 33 \add ؤُمِي\add* إِكمّڒْ يَاعْقُوبْ أَذْ إِوصَّا إِحنْجِيرنْ نّسْ، إِكمّشْ إِضَارنْ نّسْ ذِي قَامَا، إِفّغْ إِ-ث بُوحْبڒْ ؤُشَا إِمَّارْنِي غَارْ ڒْڭنْسْ نّسْ. \x ◘ \xo 49:‏33 \xt ڒخ. 7‏:‏15. \x*
\b
\b
\c 50
\s1 أَنْضڒْ ن يَاعْقُوبْ
\m 
\v 1 \add خنِّي\add* إِنْڭزْ يُوسُوفْ خْ ؤُغمْبُوبْ ن بَابَاسْ، إِرُو خَاسْ ؤُشَا إِسُّوذمْ إِ-ث.
\v 2 يُومُورْ يُوسُوفْ إِ إِمْسخَّارنْ نّسْ، إِضْبِيبنْ، أَذْ حنّْضنْ بَابَاسْ ؤُشَا إِضْبِيبنْ حنّْضنْ إِسْرَائِيل.
\v 3 أَربْعِينْ ن وُوسَّانْ إِ ذَايسْ كِّينْ، مِينْزِي حْذَاجنْ ؤُسَّانْ نِّي مَاحنْذْ أَذْ كمّْڒنْ أَحنّطْ ؤُشَا رُونْ مَارَّا إِمِيصْرِييّنْ سبْعِينْ ن وُوسَّانْ ذِي سِّيبّثْ نّسْ.
\v 4 \add ؤُمِي\add* عْذُونْ وُوسَّانْ ن ڒعْزَاثْ خَاسْ، إِسِّيوڒْ يُوسُوفْ أَكْ-ذ \add ينِّي ن\add* ثَادَّارْثْ ن فِيرْعُونْ، إِنَّا: ”مَاڒَا ؤُفِيغْ ڒخُّو أَرْضَا ذِي ثِيطَّاوِينْ نْومْ، تّْزَاوَاڭغْ كنِّيوْ، أَذْ ثسِّيوْڒمْ ذڭْ إِمجَّانْ ن فِيرْعُونْ، إِنِيمْ:
\v 5 ”بَابَا إِنُو إِجَّا أَيِي أَذْ جَّادْجغْ ؤُشَا إِنَّا: ’أَقَا تّْمتِّيغْ. إِتّْخصَّا أَذْ أَيِي ثْنضْڒذْ ذڭْ ونْضڒْ نِّي نقْشغْ إِ يِيخفْ إِنُو ذِي ثمُّورْثْ ن كنْعَانْ!‘ خنِّي، تّْزَاوَاڭغْ، أجّْ أَيِي أَذْ رَاحغْ ڒخُّو أَذْ نضْڒغْ بَابَا ؤُشَا \add أَوَارْنِي مَانْ أَيَا\add* أَذْ د -عقْبغْ.“ \x ◘ \xo 50:‏5 \xt أَمز. 47‏:‏29. \x*
\v 6 ؤُشَا إِنَّا فِيرْعُونْ: ”رُوحْ، نْضڒْ بَابَاشْ، أَمْ مَامّشْ يَارَّا شكْ أَذْ أَسْ ثجُّودْجذْ.“
\m 
\v 7 ؤُشَا إِڭعّذْ يُوسُوفْ حِيمَا أَذْ إِنْضڒْ بَابَاسْ ؤُشَا ڭعّْذنْ مَارَّا إِمْسخَّارنْ ن فِيرْعُونْ أَكِيذسْ، إِمْغَارنْ ن ثَادَّارْثْ نّسْ ذ مَارَّا إِمْغَارنْ ن ثمُّورْثْ ن مِيصْرَا،
\v 8 ؤُڒَا ذ مَارَّا ثَادَّارْثْ ن يُوسُوفْ ذ أَيْثْمَاسْ نّسْ ذ ثَادَّارْثْ ن بَابَاسْ. مْغِيرْ إِحنْجِيرنْ إِمژْيَاننْ نْسنْ ذ وُودْجِي نْسنْ ذ إِفُونَاسنْ ذ ثْفُونَاسِينْ نْسنْ جِّينْ ثنْ ذِي ثمُّورْثْ ن جُوشَانْ.
\v 9 ڭعّْذنْ أَكِيذسْ إِكَارُّوثنْ ذ يِينِّي إِنْيِينْ خْ ييْسَانْ ؤُشَا ڭِّينْ إِجّْ ن ؤُقَارُّو ن ڒْعسْكَارْ إِمْغَارْ.
\v 10 \add ؤُمِي\add* إِوْضنْ غَارْ ؤُنذْرَارْ ن أَثَاذْ، ونِّي إِدْجَانْ خْ ؤُجمَّاضْ ن لْ-ؤُرْذُونْ، سّْڭعّْذنْ ذِينْ إِشْثْ ن ثْغُويِّيثْ ثمْغَارْ، ثجْهذْ أَطَّاسْ ؤُشَا إِڭَّا يُوسُوفْ \add ذِينْ\add* إِجّْ ن وشْضَانْ خْ بَابَاسْ إِ يِيجّْ ن ڒْمِيجَاڒْ ن سبْعَا ن وُوسَّانْ.
\v 11 ژْرِينْ إِمزْذَاغْ ن ثمُّورْثْ، أَيْثْ ن كنْعَانْ، أَشْضَانْ ذڭْ ؤُنذْرَارْ ن أَثَاذْ، نَّانْ: ”وَا ذ أَشْضَانْ إِمْغَارْ ن إِمِيصْرِييّنْ.“ خْ ؤُيَا ڒَاغَانْ إِسمْ نّسْ أَبَالْ-مِيصْرَايِيمْ، ونِّي إِدْجَانْ خْ ؤُجمَّاضْ ن لْ-ؤُرْذُونْ. \f ◼ \fr 50:‏11 \ft \bd ’أَبَالْ-مِيصْرَايِيمْ‘\bd* - إِسمْ-أَ وَانِيثَا إِخْسْ أَذْ يِينِي ’أَشْضَانْ ن إِمِيصْرِييّنْ‘.\f*
\v 12 ڭِّينْ أَسْ إِحنْجِيرنْ نّسْ أَمْ مَامّشْ ثنْ إِوصَّا.
\v 13 أَرْبُونْ ث إِحنْجِيرنْ نّسْ غَارْ ثمُّورْثْ ن كنْعَانْ، نضْڒنْ ث ذڭْ إِفْرِي ذڭْ إِيَّارْ ن مَاكْفِيلَا نِّي إِسْغَا إِبْرَاهِيمْ أَكْ-ذ ييَّارْ زِي إِفْرُونْ، أَحِيتِّي، أَرنْذَاذْ ن مَامْرِي، مَاحنْذْ أَذْ يِيڒِي ذ أَنْضڒْ نّسْ. \x ◘ \xo 50:‏13 \xt أَمز. 23‏:‏16؛ ڒخ. 7‏:‏15، 16. \x*
\v 14 أَوَارْنِي ڒَامِي إِنْضڒْ بَابَاسْ، إِعْقبْ يُوسُوفْ غَارْ مِيصْرَا، نتَّا ذ يَايْثْمَاسْ ذ مَارَّا إِنِّي أَكِيذسْ د-إِڭعّْذنْ، مَاحنْذْ أَذْ نضْڒنْ بَابَاسْ.
\m 
\v 15 \add ؤُمِي\add* ژْرِينْ أَيْثْمَاسْ ن يُوسُوفْ بَابَاثْسنْ إِمُّوثْ، نَّانْ: ”مَاڒَا إِشَارْهْ أَنغْ يُوسُوفْ، أَذْ أَنغْ إِخدْجصْ نِيشَانْ مَارَّا ڒْغَارْ نِّي ذَايسْ نڭَّا.“
\v 16 \add س ؤُينِّي\add* سّكّنْ أَذْ خبَّارنْ يُوسُوفْ \add س مَانْ أَيَا\add*، نَّانْ: ”بَابَاشْ إِوصَّا قْبڒْ ڒْموْثْ نّسْ، إِنَّا:
\v 17 ’أَمُّو إِ غَا ثِينِيمْ إِ يُوسُوفْ: تّْزَاوْڭغْ شكْ، غْفَارْ ڒخُّو أَخطُّو ن أَيْثْمَاشْ ذ دّنْبْ نْسنْ ذ ڒْغَارْ إِ ذ أَشْ ڭِّينْ. غْفَارْ ڒخُّو أَخطُّو ن إِمْسخَّارنْ ن أَربِّي ن بَابَاشْ!‘ “ ؤُشَا إِسْغُويْ يُوسُوفْ أَمْ كِيسْ سِّيوْڒنْ \add أَمُّو\add*.
\v 18 \add خنِّي\add* ؤُسِينْ-د عَاوذْ أَيْثْمَاسْ \add س يِيخفْ نْسنْ\add*، وْضَانْ أَسْ زَّاثْ إِ ؤُغمْبُوبْ نّسْ، نَّانْ: ”أَقَا-نغْ ذَا ذ إِمْسخَّارنْ نّشْ!“
\v 19 يَارَّا-د خَاسنْ يُوسُوفْ: ”وَارْ تّڭّْوْذمْ شَا! مَا أَقَا أَيِي نشّْ ذڭْ ومْشَانْ ن أَربِّي؟ \x ◘ \xo 50:‏19 \xt أَمز. 45‏:‏5. \x*
\v 20 وَاخَّا كنِّيوْ ثْخَارّْصمْ ذَايِي س ڒْغَارْ، أَقَا أَربِّي إِنْوَا زَّايسْ ڒْخَارْ، حِيمَا أَذْ يڭّْ أَمْ مَامّشْ \add إِ ثدْجَا\add* أَسّْ-أَ، أَذْ يجّْ ذِي ثُوذَارْثْ إِجّْ ن ڒْڭنْسْ ذ أَمقّْرَانْ. \x ◘ \xo 50:‏20 \xt أَمز. 45‏:‏7\x*
\v 21 ڒخُّو، وَارْ تّڭّْوْذمْ شَا! نشّْ أَذْ كنِّيوْعوّْڒغْ، كنِّيوْ ذ إِحنْجِيرنْ إِمژْيَاننْ نْومْ.“ أَمُّو ثنْ إِسّْفوّجْ ؤُشَا إِسِّيوڒْ أَكِيذْسنْ غَارْ وُوڒَاونْ نْسنْ.
\m 
\v 22 ثُوغَا يُوسُوفْ إِزدّغْ ذِي مِيصْرَا، نتَّا ذ ثَادَّارْثْ ن بَابَاسْ، ؤُشَا إِدَّارْ يُوسُوفْ مْيَا ؤُ -عشْرَا ن إِسڭّْوُوسَا.
\v 23 إِژْرَا يُوسُوفْ إِحنْجِيرنْ ن إِفْرَايِيمْ أَڒْ جِّيڒْ وِيسّْ ثْڒَاثَا. أَقَا تّْوَارْونْ-د إِحنْجِيرنْ ن مَاكِيرْ، مِّيسْ ن مَانَاسَّا، عَاوذْ خْ إِفَادّنْ ن يُوسُوفْ. \x ◘ \xo 50:‏23 \xt ڒخْڒ. 32‏:‏39. \x*
\m 
\v 24 ؤُشَا إِنَّا يُوسُوفْ إِ يَايْثْمَاسْ: ”نشّْ أَذْ مّْثغْ، مَاشَا أَربِّي أَذْ كنِّيوْ يَارْزفْ س ثِيذتّْ ؤُشَا أَذْ كنِّيوْ إِسّْڭعّذْ زِي ثمُّورْثْ-أَ غَارْ ثمُّورْثْ إِ إِوَاعْذْ س ثْجَادْجِيثْ إِ إِبْرَاهِيمْ ذ إِسْحَاقْ ذ يَاعْقُوبْ.“ \x ◘ \xo 50:‏24 \xt عبر. 11‏:‏22. \x*
\v 25 \add خَاسْ ؤُشَا\add* إِسّْجِّيدْجْ يُوسُوفْ أَيْثْ ن إِسْرَائِيل، إِنَّا: ”أَربِّي أَذْ كنِّيوْ يَارْزفْ س ثِيذتّْ ؤُشَا \add خنِّي\add* أَذْ ثكْسِيمْ سَّا إِغْسَانْ إِنُو!“ \x ◘ \xo 50:‏25 \xt ؤُف. 13‏:‏19؛ ياش. 24‏:‏32. \x*
\v 26 إِمُّوثْ يُوسُوفْ ؤُمِي ثُوغَا غَارسْ مْيَا ؤُ -عشْرَا ن إِسڭّْوُوسَا. حنّْضنْ ث ؤُشَا سَّارْسنْ ث ذِي ڒْمحْمڒْ ن ؤُمتِّينْ ذِي مِيصْرَا. 
