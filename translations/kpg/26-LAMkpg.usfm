\id LAM Kapingamarangi 
\h Taahili Manawa gee 
\toc1 Taahili Manawagee Hagadagadagagee 
\toc2 Taahili Manawa gee 
\toc3 Lam 
\mt1 LAMENTATIONS  
\mt2 Taahili Manawagee Hagadagadagagee  
\imt1 Di haga modongoohia:  
\im \bk Taahili Manawagee Hagadagadagagee\bk* la nia daahili e lima ala e helekai manawa gee gi di mooho o Jerusalem i di ngadau 586 i mua o Christ, mo di haadanga balua o nia daangada ala mai i di mooho deelaa mo nadau hagabagi gi daha mo nadau henua. Di lodo huaidu huoloo dela ne haga honu di beebaa deenei, gei di mee mada hagalabagau la taahili hagadagadagagee ang gi Dimaadua i lodo di haingadaa (3.22-47), mo di hagadagadagagee gi di madagoaa dela e hanimoi.  
\ip Digau o Jew e hai hegau gi nia daahili aanei nia ngadau huogodoo i nadau daumaha i nadau laangi hagaonge mo di manawa gee e haga langahia ai di mooho o nadau guongo i di ngadau 586 i mua o Christ.  
\ip Taahili deenei le e hai nia gubu e madalua maa lua i lodo nia mada e 1, 2, 4, mo 5. Nia gubu dagi dahi i lodo nia mada e 1, 2, 4 e daamada i di leder e dahi o di aiu Hebrew. Nia gubu e dolu i di mada e 3 e daamada i nia leder o di aiu Hebrew. Telekai Hebrew la nia leder e madalua maa lua. Tadinga o di mee deenei bolo gi haga modongoohia taahili deenei le e hagi anga nia mee huogodoo ala e mee di daahili i di hai o di manawa gee mo di hagadagadagagee i lodo di haingadaa la i lodo nia mada e lima aanei.  
\iot Di hagahonu di beebaa deenei:  
\io1 Nia manawa gee o Jerusalem \ior (1.1-22) \ior*  
\io1 Di hagaduadua a Dimaadua ang gi Jerusalem \ior (2.1-22) \ior*  
\io1 Taahili manawa gee \ior (3.1-21) \ior*  
\io1 \bk Taahili hagadagadagagee\bk* \ior (3.22-42) \ior*  
\io1 Taahili manawa gee \ior (3.43-66) \ior*  
\io1 Jerusalem i muli dono mooho \ior (4.1-22) \ior*  
\io1 Talodalo gi dumaalia \ior (3.1-22) \ior*  
\c 1  
\s1 Nia manawa gee o Jerusalem  
\qa xalephx-Aleph  
\q1
\v 1 E haga manawa gee idimaa gu deai digau i Jerusalem ai,  
\q1 di waahale dela nogo dogologo ono daangada i mua!  
\q1 Henuailala hagatau nogo hagalaamua a mee i mua,  
\q1 dolomeenei guu hai gadoo be di ahina guu made dono lodo.  
\q1 Di waahale dela koia e aamua guu hai di hege dolomeenei.   
\b  
\qa xbethx - Beth  
\q1
\v 2 Mee e dangidangi i di boo hagatau,  
\q1 ono golomada e halidangi gi lala i dono gili.  
\q1 Deai dono ehoo mai mua i dono baahi ai  
\q1 belee haga manawa lamalia a mee.  
\q1 Ono ihoo hagaaloho guu buhi gu hai baahi gi mee.   
\b  
\qa xgimelx - Gimel  
\q1
\v 3 Digau Judah guu hula gi daha mo nadau gowaa donu,  
\q1 guu noho i lodo di haingadaa mo di mouli hege.  
\q1 Digaula guu noho i nnuai gowaa, gu deai di gowaa e mee  
\q1 di haga ingoo bolo di gowaa donu ni digaula ai.  
\q1 Nadau hagadaumee gu daabui digaula,  
\q1 gu deai di gowaa e mee di lellele hagammuni ginai ai.   
\b  
\qa xdalethx - Daleth  
\q1
\v 4 Digau e hula gi di Hale Daumaha ai  
\q1 belee hai nadau daumaha i nia laangi dabu.  
\q1 Nia dama ahina ala nogo dadaahili i mua  
\q1 la guu noho i lodo nadau hagaduadua,  
\q1 gei ogo digau hai mee dabu gu tangitangi mo di manawa gee.  
\q1 Nia ngudu nia bontai o di waahale nadau daangada ai,  
\q1 gei Zion guu noho i lodo di manawa hagammaemmae.   
\b  
\qa xhex - He  
\q1
\v 5 Ono hagadaumee gu aali,  
\q1 gei mee guu noho i lala nadau mogobuna.  
\q1 Dimaadua gu hagaduadua a mee,  
\q1 idimaa mee guu hai ana hala e logo.  
\q1 Nia dama a maa guu kumi guu lahi gi daha.   
\b  
\qa xwawx - Waw  
\q1
\v 6 Di madamada o Jerusalem gu hagalee.  
\q1 Nia dagi o maa guu hai be nia ee ma ga hiigai ga paagege.  
\q1 Nia mahi digaula gu hagalee i di madagoaa  
\q1 digaula e llele gi daha mo digau puu manu.   
\b  
\qa xzayinx - Zayin  
\q1
\v 7 Jerusalem gu ongeonge dolomeenei,  
\q1 gu hagalee madamada be di maa i mua,  
\q1 gei mee gu langahia dono madamada  
\q1 dela i mua dono kumi go ono hagadaumee,  
\q1 deai tangada e hagamaamaa a mee ai,  
\q1 ono hagadaumee gu gadagada gi dono doo.   
\b  
\qa xhethx - Heth  
\q1
\v 8 Dono hagalaamua gu hagalee,  
\q1 gu ono goloo ai, gu haga huaidu.  
\q1 Mee gu manawa gee, guu pono ono golomada idimaa mee gu langaadia.  
\q1 Jerusalem guu bida haga gulugulua ia gi nia huaidu.   
\b  
\qa xtethx - Teth  
\q1
\v 9 Ono gulugulua gu modongoohia hagammaa,  
\q1 gei mee e dehei eia nia mee ala gaa tale ang gi deia.  
\q1 Dono doo gi lala e huaidu,  
\q1 idimaa tangada e haga manawa lamalia a mee ai.  
\q1 Ono hagadaumee gu aali,  
\q1 gei mee gu dangidangi gi Dimaadua gi dumaalia ang gi deia.   
\b  
\qa xyodhx - Yodh  
\q1
\v 10 Ono hagadaumee gu gaiaa ono goloo hagalabagau huogodoo.  
\q1 Mee gu gidee ia di nadau ulu gi lodo di Hale Daumaha,  
\q1 di gowaa dela guu bule go Dimaadua  
\q1 bolo digau tuadimee gi dee ulu gi lodo.   
\b  
\qa xkaphx - Kaph  
\q1
\v 11 Ana daangada gu tangitangi mo di manawa gee  
\q1 i nadau madagoaa e halahala nadau mee e gai.  
\q1 Digaula gu koodai nadau goloo hagalabagau  
\q1 gi nia meegai bolo gi mouli ai ginaadou.  
\q1 Di waahale e dangidangi boloo,  
\q1 “Meenei Dimaadua, mmada mai gi di au,  
\q1 gi gidee Goe dogu haingadaa.”   
\b  
\qa xlamedhx - Lamedh  
\q1
\v 12 Mee e dangidangi gi digau ala e hula laalaa i dono baahi boloo,  
\q1 “Mmada mai gi di au, deai tangada guu mmae  
\q1 be di mmae deenei i di au ai,  
\q1 go di mmae a Dimaadua ne gaamai gi ogu nua  
\q1 i di madagoaa o dono hagawelewele.   
\b  
\qa xmemx - Mem  
\q1
\v 13 “Mee ne hagau eia dana ahi i di langi,  
\q1 di ahi dela ne dudu ogu lodo.  
\q1 Mee ne gaamai dana hele i ogu mua  
\q1 gi hinga au gi hongo di gelegele,  
\q1 gei Mee gaa hudu au gi daha gi lodo di mmae dee odi.   
\b  
\qa xnunx - Nun  
\q1
\v 14 “Mee gu hagailongo ogu huaidu huogodoo,  
\q1 guu nnoo gi di gowaa e dahi,  
\q1 gu daudau gi dogu uwa,  
\q1 gei au gu daamaha gu hagalongo gee.  
\q1 Dimaadua guu wanga au gi ogu hagadaumee,  
\q1 dela ga deemee iei au di duu aga  
\q1 e hai baahi gi digaula.   
\b  
\qa xsamekhx - Samekh  
\q1
\v 15 “Dimaadua gu gadagada gi agu gau dauwa ala koia e maaloo,  
\q1 gu hagau ana gau dauwa belee hagahuaidu agu dama daane,  
\q1 gu dagadagahi agu daangada be nia ‘grape’ i di gowaa dagadagahi waini.   
\b  
\qa xayinx - Ayin  
\q1
\v 16 “Deenei tadinga ogu golomada ala e halidangi.  
\q1 Tangada e haga manawa lamalia au ai,  
\q1 tangada e hai au gii mahi ogu lodo ai.  
\q1 Ogu hagadaumee gu aali i di au,  
\q1 gei ogu daangada nadau mee e dubu ai.   
\b  
\qa xpex - Pe  
\q1
\v 17 “Au guu holo ogu lima gi daha,  
\q1 gei tangada e hagamaamaa au ai.  
\q1 Dimaadua gu gahigahi ogu hagadaumee  
\q1 gi hai baahi mai gi di au mai i nia gowaa huogodoo.  
\q1 Digaula guu hai au be di mee gulugulua.   
\b  
\qa xtsadhex - Tsadhe  
\q1
\v 18 “Gei Dimaadua le e donu,  
\q1 gei di maa ko au dela gu de hagalongo gi Mee.  
\q1 Hagalongo mai gi di au, goodou go nia henua huogodoo,  
\q1 mmada mai gi dogu hagaduadua nei.  
\q1 Agu dama daane mo agu dama ahina huogodoo  
\q1 gu lawalawa, guu lahi gi daha.   
\b  
\qa xqophx - Qoph  
\q1
\v 19 “Au gu gahigahi ogu ihoo,  
\q1 gei digaula hagalee hiihai e hagamaamaa au.  
\q1 Digau hai mee dabu, mo nia dagi  
\q1 guu mmade i hongo nia ala o di waahale  
\q1 i di nadau halahala nadau meegai belee hagamouli ginaadou.   
\b  
\qa xreshx - Resh  
\q1
\v 20 “Meenei Dimaadua, mmada mai gi dogu mmae huoloo,  
\q1 au gu huaidu ogu lodo!  
\q1 Ogu lodo gu daamaha huoloo gi ogu huaidu.  
\q1 Taaligi dangada guu hai i hongo nia ala,  
\q1 di made hogi gu i golo i lodo nia hale.   
\b  
\qa xshinx - Sin ma Shin  
\q1
\v 21 “Hagalongo mai gi dogu lee manawa gee,  
\q1 tangada e haga manawa lamalia au ai.  
\q1 Ogu hagadaumee gu tenetene gi do gaamai di haingadaa deenei.  
\q1 Gaamai gi di au di laangi dela gu hagababa Kooe,  
\q1 hagaduadua ina ogu hagadaumee  
\q1 be dau hai dela nogo hai mai gi di au.   
\b  
\qa xtawx - Taw  
\q1
\v 22 “Haga huaidu ina digaula  
\q1 idimaa digaula ala nogo haihai nia mee huaidu.  
\q1 Hagaduadua ina digaula be dau hai  
\q1 nogo hagaduadua au i ogu huaidu.  
\q1 Au gu manawa gee huoloo i lodo ogu haingadaa,  
\q1 gei au guu magi i lodo dogu manawa.”   
\c 2  
\s1 Di hagaduadua a Dimaadua ang gi Jerusalem  
\qa xalephx - Aleph  
\q1
\v 1 I lodo di hagawelewele o Dimaadua,  
\q1 gei Mee guu gahu Zion gi bouli dongoeho,  
\q1 gu oho gi daha dono madamada hagatau.  
\q1 I di laangi o dono hagawelewele,  
\q1 gei Mee guu hudu gi daha dono Hale Daumaha.   
\b  
\qa xbethx - Beth  
\q1
\v 2 Dimaadua gu oho gi daha nia dama waahale hagalligi huogodoo o Judah,  
\q1 gei guu wweu gi daha di abaaba o digau dauwa  
\q1 ala nogo hagaloohi nia guongo aalaa,  
\q1 gu hagatee tenua deelaa mo nadau dagi.   
\b  
\qa xgimelx - Gimel  
\q1
\v 3 I lodo dono hagawelewele, gei Mee gu oho nia mahi o Israel.  
\q1 Mee guu huli gi daha mo gidaadou, e de hiihai e hagamaamaa gidaadou  
\q1 i di madagoaa tadau hagadaumee ne dau i tadau baahi.  
\q1 Mee gu hagawelewele huoloo mai gi gidaadou  
\q1 gadoo be di ahi ma gaa dudu nia mee huogodoo.   
\b  
\qa xdalethx - Daleth  
\q1
\v 4 Mee guu hai gadoo be tadau hagadaumee  
\q1 ma ga lui mai ana amu mai gi gidaadou,  
\q1 gei Mee gu daaligi digau huogodoo  
\q1 ala nogo haga tenetene mo e haga manawa lamalia gidaadou.  
\q1 Gidaadou gu longono dono hagawelewele damana i Jerusalem nei.   
\b  
\qa xhex - He  
\q1
\v 5 Dimaadua gu haga huaidu Israel gadoo be dahi hagadaumee,  
\q1 gu oho gi daha nia gowaa hai dauwa mo nia waahale o nia king,  
\q1 guu wanga gi Judah di manawa gee dela dono hagaodi ai.   
\b  
\qa xwawx - Waw  
\q1
\v 6 Mee gu oho haga ligiligi di Hale Daumaha,  
\q1 di gowaa nogo daumaha ai gidaadou gi Mee,  
\q1 gei Mee gu haga lawa nia laangi hagamadagu mono Laangi Sabad.  
\q1 Nia king mo digau hai mee dabu gu longono e ginaadou  
\q1 nia mahi o dono hagawelewele.   
\b  
\qa xzayinx - Zayin  
\q1
\v 7 Di Tagi guu huli gi daha mo dono gowaa hai tigidaumaha,  
\q1 gu diiagi dono Hale Daumaha,  
\q1 gu dumaalia gi nia hagadaumee gi ohaa nia abaaba.  
\q1 Digaula guu wwolo gi nua i tadau gowaa nogo tenetene ai,  
\q1 nogo haihai tadau daumaha i mua.   
\b  
\qa xhethx - Heth  
\q1
\v 8 Dimaadua guu hai bolo di abaaba o Zion la gi mooho gi lala.  
\q1 Mee gu haganoho gii donu nia mee ala belee haga mooho hagatau.  
\q1 Nia angulaa madaloohi mono abaaba ala i golo  
\q1 guu tinga gi hongo di gelegele, gu mooho.   
\b  
\qa xtethx - Teth  
\q1
\v 9 Nia ngudu di abaaba la gu i hongo di gelegele,  
\q1 nia bontai baalanga la gu mooho dagidahi.  
\q1 Nia king mono gau aamua guu hula gi daha gi nnenua o digau tuadimee,  
\q1 tangada e kuulu gi taganoho ai,  
\q1 gei nia soukohp e kae nadau moe mai baahi o Dimaadua ai.   
\b  
\qa xyodhx - Yodh  
\q1
\v 10 Nia daane mmaadua o Jerusalem guu noho deemuu i hongo di gelegele.  
\q1 Nia dogolia pigi gu i hongo nadau libogo,  
\q1 digaula guu gahu gi nia gahu manawa gee.  
\q1 Nia dama ahina guu pala nadau libogo gi hongo di gelegele.   
\b  
\qa xkaphx - Kaph  
\q1
\v 11 Nia ngogo ogu golomada guu mmae i dogu dangidangi.  
\q1 Dogu hagataalunga gu huaidu, gu ogu mahi ai  
\q1 i lodo dogu manawa gee gi agu daangada ala gu hagamooho.  
\q1 Nia dama mono dama lligi gu bobouli nadau golomada  
\q1 i hongo nia ala o di waahale deelaa.   
\b  
\qa xlamedhx - Lamedh  
\q1
\v 12 Digaula gu hiigai gei gu hieinu, e tangitangi gi nadau dinana.  
\q1 Digaula guu tinga gi hongo nia ala, gadoo be digau gu moholehole,  
\q1 gei gu mmade mai loo maalia i hongo nia lima o nadau dinana.   
\b  
\qa xmemx - Mem  
\q1
\v 13 Go Jerusalem, dogu ihoo hagaaloho Jerusalem,  
\q1 au e mee di helekai bolo aha?  
\q1 Dehee dagu hai e mee di haga manawa lamalia goe?  
\q1 Tangada ne hagaduadua beenei ai.  
\q1 O haingadaa e damanaiee be di moana,  
\q1 deai dahi mee e mee di hagadagadagagee ginai ai.   
\b  
\qa xnunx - Nun  
\q1
\v 14 Au soukohp nadau mee e helekai adu gi di goe ai,  
\q1 nia kai tilikai hua.  
\q1 Nadau agoago gu halahalau goe,  
\q1 i ginaadou digi hagamodongoohia adu o huaidu,  
\q1 bolo goe gi hudee hai bolo goe e lui do manawa e huli hoou.   
\b  
\qa xsamekhx - Samekh  
\q1
\v 15 Nia daangada ala e hula taalinga di waahale  
\q1 e dadaumada hagahuaidu goe,  
\q1 gu lialiagi nadau libogo mo di gadagada gi di mooho Jerusalem,  
\q1 e helekai boloo, “Ma deenei di waahale humalia?  
\q1 Deenei di waahale e haga tenetene henuailala?”   
\b  
\qa xayinx - Ayin  
\q1
\v 16 O hagadaumee huogodoo e gadagada adu gi di goe  
\q1 mo di haihai goe haga huaidu.  
\q1 Digaula ga huli adu ga haganneennee boloo,  
\q1 “Gimaadou gu haga mooho di maa!  
\q1 Deenei di laangi nogo talitali go gimaadou!”   
\b  
\qa xpex - Pe  
\q1
\v 17 Dimaadua gu haga gila aga ana mee ala ne hiihai bolo e hai.  
\q1 Mee gu hagahuaidu gidaadou i dono hagalee dumaalia,  
\q1 be dana hai dela gu hagi mai gi gidaadou i mua,  
\q1 gu dumaalia gi tadau hagadaumee gi aali i gidaadou  
\q1 gei gi tenetene gi tadau tingatinga.   
\b  
\qa xtsadhex - Tsadhe  
\q1
\v 18 Jerusalem, dumaalia gi au abaaba gi tangi gi nua gi Tagi,  
\q1 heia oo dangi gi malingi gadoo be di monowai i di boo mo di aa.  
\q1 Hudee dugua au dangidangi i di manawa gee!   
\b  
\qa xqophx - Qoph  
\q1
\v 19 Goe gii ala haga logo i di boo,  
\q1 gii hai au dangidangi ang gi Dimaadua.  
\q1 Goe gi dangidangi hagamahi i lala dono manawa dumaalia ang gi au dama,  
\q1 go nia dama ala e mmade i hongo nia ala huogodoo i nadau hiigai!   
\b  
\qa xreshx - Resh  
\q1
\v 20 Meenei Dimaadua, Goe e aha dela e hagaduadua gimaadou beenei?  
\q1 Nia ahina guu gai nia huaidina o nadau dama ala nogo aloho ai!  
\q1 Digau hai mee dabu mo nia soukohp gu daaligi gii mmade i lodo di Hale Daumaha.   
\b  
\qa xshinx - Sin ma Shin  
\q1
\v 21 Digau mmaadua mono gau ala e lligi e mmoe mmoe i hongo nia ala.  
\q1 Nia hulumanu dauwa o nia hagadaumee gu dadaaligi nia dama daane mono dama ahina.  
\q1 Goe gu dadaaligi digaula i lodo do hagawelewele hagalee manawa dumaalia.   
\b  
\qa xtawx - Taw  
\q1
\v 22 Goe gu gahi mai ogu hagadaumee bolo gi madagu au i nia baahi huogodoo,  
\q1 e hai gadoo be dau hai ma gaa gahi digaula gi tagamiami,  
\q1 hagalee tangada e lele gi daha mo do hagawelewele ai.  
\q1 Digaula gu daaligi agu dama, ala nogo tomo aga ge aloho iei au labelaa.   
\c 3  
\s1 Hagaduadua, huli hoou, mo di hagadagadagagee  
\qa xalephx - Aleph  
\q1
\v 1 Ma ko au dela e iloo di hai o di hagaduadua mai baahi o God.   
\q1
\v 2 Mee guu hono au gi lodo di bouli dongoeho,   
\q1
\v 3 gu hagamamaawa au hagalee manawa dumaalia.   
\b  
\qa xbethx - Beth  
\q1
\v 4 Mee guu huge ogu goneiga, gu oho ogu iwi.   
\q1
\v 5 Mee guu nnoo au gi lodo di haingadaa mo di haga mmaemmae.   
\q1
\v 6 Mee guu hono au gii noho i lodo di gowaa bouli dongoeho o di made.   
\b  
\qa xgimelx - Gimel  
\q1
\v 7 Mee guu nnoo au gi nia daula baalanga.  
\q1 Au gu deai dogu hagadagadagagee ai bolo au e mee di dagaloaha.   
\q1
\v 8 Au gu dangidangi loo gi nua i di hagamaamaa,  
\q1 gei God hagalee hiihai e hagalongo mai.   
\q1
\v 9 Au e hagadubedube i dogu heehee,  
\q1 gu duuli go nia abaaba hadugalaa i nia gowaa huogodoo  
\q1 ala e heehee iei au, be e hana ginai au.   
\b  
\qa xdalethx - Daleth  
\q1
\v 10 Mee gu talitali au gadoo be di ‘bear’,  
\q1 guu hobo gi ogu nua gadoo be di laion.   
\q1
\v 11 Mee gu hagabagi au gi daha mo hongo di ala,  
\q1 gu hahaahi ogu goloo, gu diiagi au i golo.   
\q1
\v 12 Mee gu taiaga dana maalei,  
\q1 guu lui hagahuudonu dana amu maalei mai gi di au.   
\b  
\qa xhex - He  
\q1
\v 13 Mee guu puu dana amu gu ulu gi lodo dogu huaidina.   
\q1
\v 14 Nia daangada gu gadagada mai gi di au i lodo di laangi hagatau.  
\q1 Au guu hai di mee hai dadaagala ni digaula.   
\q1
\v 15 Di haangai huaidu, mo di haga inu di hagammaemmae guu hai mai gi di au.   
\b  
\qa xwawx - Waw  
\q1
\v 16 Mee guu hono ogu golomada gi hongo di gelegele,  
\q1 guu tugi ogu niha gi nia hadugalaa.   
\q1
\v 17 Au gu de langahia eau di mahi o dogu huaidina,  
\q1 di noho i di aumaalia mo di manawa lamalia.   
\q1
\v 18 Dogu mouli gu haga bodobodo mai,  
\q1 dogu hagadagadagagee gi Dimaadua gu hagalee.   
\b  
\qa xzayinx - Zayin  
\q1
\v 19 Di hagamamaanadu dogu mmae, dogu ongeonge guu hai di mee e mmala.   
\q1
\v 20 Au e hagamamaanadu beenei, gei e daadaamee ginai dogu hagataalunga.   
\q1
\v 21 Gei dogu hagadagadagagee gu gila mai i dogu langahia eau di mee deenei:   
\b  
\qa xhethx - Heth  
\q1
\v 22 Di aloho Dimaadua mo dono manawa dumaalia hagalee noho loo.   
\q1
\v 23 E haga manawa lamalia au gadoo be di haga manawa lamalia o di luada,  
\q1 ge dee odi gadoo be di hobo aga o di laa.   
\q1
\v 24 Dimaadua modogoia ni aagu, deelaa laa Mee go dogu hagadagadagagee.   
\b  
\qa xtethx - Teth  
\q1
\v 25 Dimaadua e humalia huoloo gi digau huogodoo ala e hagadonu a Mee.   
\q1
\v 26 Mai i Mee e humalia, gidaadou huogodoo gi talitali mo di hagakono gi dono hagamouli gidaadou.   
\q1
\v 27 E humalia maa gidaadou e kabe tadau noho hagalongo i tadau lligi.   
\b  
\qa xyodhx - Yodh  
\q1
\v 28 Maa gidaadou gu manawa gee,  
\q1 gei gidaadou gii noho mada gidaadou deemuu.   
\q1
\v 29 Gidaadou gii pala gi lala i lodo tadau manawa hila gi lala,  
\q1 holongo tadau hagadagadagagee la i golo hua.   
\q1
\v 30 Ma e aha maa gidaadou gu dadaaligi gu lauwa,  
\q1 gei gidaadou gi manawa balabala hua.   
\b  
\qa xkaphx - Kaph  
\q1
\v 31 Di Tagi e manawa dumaalia,  
\q1 hagalee huli gi daha mo gidaadou, gaa hana hua beelaa.   
\q1
\v 32 Maa Mee ga gaamai di manawa gee,  
\q1 gei dono aloho i gidaadou le e donu, ge e maaloo.   
\q1
\v 33 Mee hagalee tenetene gi dono gaamai gi gidaadou di manawa gee mo di mmae.   
\b  
\qa xlamedhx - Lamedh  
\q1
\v 34 Di Tagi e modongoohia e Ia di madagoaa tadau hagataalunga ala e manawa gee i lodo di hale galabudi.   
\q1
\v 35 Mee e iloo di madagoaa gidaadou hagalee hai mee gi di tonu o Maa ne gaamai gi gidaadou.   
\q1
\v 36 Gei Mee e iloo Ia di madagoaa di tonu gu hai gee i lodo di gowaa hai gabunga.   
\b  
\qa xmemx - Mem  
\q1
\v 37 Di manawa o Tagi le e gila i nia madagoaa huogodoo.   
\q1
\v 38 Nia mee humalia mo huaidu e gila aga i di gowaa a Mee gu haganoho.   
\q1
\v 39 Gidaadou e leelee logo eiaha i di madagoaa gidaadou ga hagaduadua i tadau huaidu?   
\b  
\qa xnunx - Nun  
\q1
\v 40 Gidaadou gii mmada gi tadau huaidu, gaa huli labelaa gi Dimaadua.   
\q1
\v 41 Gidaadou gii huge tadau lodo ang gi God i di langi, ga dalodalo gi Mee boloo,   
\q1
\v 42 “Meenei Dimaadua, gimaadou gu ihala,  
\q1 gu de hagalongo adu gi di Goe,  
\q1 gei Goe gu hagalee dumaalia mai gi gimaadou.   
\b  
\qa xsamekhx - Samekh  
\q1
\v 43 “Goe gu daudali mai gimaadou mo di dadaaligi gimaadou.  
\q1 Do manawa dumaalia la guu ngala i lodo do hagawelewele,   
\q1
\v 44 guu ngala i lala di gololangi maadolu,  
\q1 gaa hidi ai madau dangidangi e deemee di dau i di Goe.   
\q1
\v 45 Goe guu hai gimaadou be di gowaa dugu geinga o henuailala.   
\b  
\qa xayinx - Ayin  
\q1
\v 46 “Gimaadou guu hai haga huaidu go madau hagadaumee.   
\q1
\v 47 Gimaadou guu noho i lodo di haingadaa mo di hagaloale,  
\q1 guu noho i lodo di mouli hagalliga mo e haga madagudagu dangada.   
\q1
\v 48 Nia dangi o ogu golomada guu hali gi lala,  
\q1 i di gili di hagahuaidu o agu daangada.   
\b  
\qa xpex - Pe  
\q1
\v 49 “Nia wai o ogu golomada gaa hali gi lala, hagalee noho,   
\q1
\v 50 gaa dae loo gi Dimaadua ga helekai mai i di langi,  
\q1 ga gidee Ia gimaadou.   
\q1
\v 51 Nia mee ala e mmada ginai au gu haga manawa gee au,  
\q1 i dogu gidee nia mee ala ne hai gi nia ahina o dogu guongo.   
\b  
\qa xtsadhex - Tsadhe  
\q1
\v 52 “Ogu hagadaumee e helehele au gadoo be di manu,  
\q1 gei dono hadinga belee hudi wou mai gi di au ai.   
\q1
\v 53 Digaula guu hudu au mouli gi lodo di luwa mo di tai di ngudu di luwa deelaa gi di hadu.   
\q1
\v 54 Nia wai gu hoohoo aga gi dogu libogo, gei au gu hagamaanadu bolo au gu hoohoo gaa made.   
\b  
\qa xqophx - Qoph  
\q1
\v 55 “Au gu gahigahi Goe, meenei Dimaadua, mai i lodo di luwa deelaa iei au no lodo.   
\q1
\v 56 Goe gu hagalongo gi dagu dangidangi bolo gi hudee taidia o dalinga i dagu dangidangi.   
\q1
\v 57 Goe gu helekai mai i di madagoaa au nogo gahigahi Goe,  
\q1 gei Goe gu hagi mai boloo, ‘Hudee madagu.’   
\b  
\qa xreshx - Resh  
\q1
\v 58 “Meenei dogu Dagi, Goe gu haga dagaloaha au, gu hagamouli au.   
\q1
\v 59 Gabunga ina gi di tonu, idimaa Goe gu gidee Goe nia hai ala nogo hai mai gi di au, meenei Dimaadua.   
\q1
\v 60 Goe gu iloo Goe di hai o ogu hagadaumee ala e hudi wou mai gi di au, e hai baahi mai gi di au.   
\b  
\qa xshinx - Sin ma Shin  
\q1
\v 61 “Meenei Dimaadua goe gu longono e Goe di nadau haganneennee au, gu iloo nadau hai huaidu.   
\q1
\v 62 Di laangi hagatau, gei ogu hagadaumee e haganohonoho mai nadau huaidu.   
\q1
\v 63 Digaula e gadagada mai gi di au mai luada gaa dae gi di boo.   
\b  
\qa xtawx - Taw  
\q1
\v 64 “Meenei Dimaadua, hagaduadua ina digaula gi nadau haihai huaidu.   
\q1
\v 65 Haga huaidu ina digaula, mo di haga honu ina digaula gi nia hagabaubau e logo!   
\q1
\v 66 Gumudia digaula, mo di haga mmaa ina digaula gi daha mo henuailala.”   
\c 4  
\s1 Jerusalem i muli dono mooho  
\qa xalephx - Aleph  
\q1
\v 1 Tadau goolo madamada gu bilau,  
\q1 nia hadu hagalabagau o di Hale Daumaha gu meheu gi hongo nia ala.   
\b  
\qa xbethx - Beth  
\q1
\v 2 Nia dama daane o Zion nogo hagalabagau gadoo be nia goolo,  
\q1 gei dolomeenei gu balumee gadoo be nia baalanga ne hai gi nia gelegele.   
\b  
\qa xgimelx - Gimel  
\q1
\v 3 Nia paana lodo geinga e haga uu nadau dama,  
\q1 gei agu daangada e hai gadoo be nia manu ‘ostrich’ e hagamuamua gi nadau dama.   
\b  
\qa xdalethx - Daleth  
\q1
\v 4 Digaula e dugu hua nadau dama bolo gii mmade i di hiigai mo di hieinu.  
\q1 Nia dama le e tangi bolo gii wanga nadau meegai,  
\q1 gei di maa tangada e haangai digaula ai.   
\b  
\qa xhex - He  
\q1
\v 5 Nia daangada nogo gai nadau meegai humalia i mua,  
\q1 gei dolomeenei digaula gaa mmade i nadau hiigai i hongo nia ala.  
\q1 Digau ala nogo tomo aga humalia i mua,  
\q1 gei dolomeenei digaula e heehee i lodo nia hagabae geinga,  
\q1 e hai di nadau halahala meegai.   
\b  
\qa xwawx - Waw  
\q1
\v 6 Agu daangada guu kae di hagaduadua koia e huaidu i di hagaduadua digau Sodom,\x * \xo 4.6 \xt Genesis 19.24\x*  
\q1 di hagaduadua ne tale ang gi ginaadou limalima mai i nia lima o God.   
\b  
\qa xzayinx - Zayin  
\q1
\v 7 Tadau gau aamua nogo madammaa ge kene be nia ‘snow’.  
\q1 Nnuaidina digaula nogo humalia ge maaloo, nogo dabadaba ge mahi.   
\b  
\qa xhethx - Heth  
\q1
\v 8 Gei dolomeenei digaula e mmoe mmoe i hongo nia ala,  
\q1 tangada e iloo digaula ai,  
\q1 nadau hadumada gu luuli i nadau mmade,  
\q1 nadau gili gu maangoo be di laagau,  
\q1 gu haga wini i di gili nia iwi.   
\b  
\qa xtethx - Teth  
\q1
\v 9 Digau ala ne mmade i lodo tauwa e haadanga lamalia i digau ala ne mmade nomuli,  
\q1 ala gu paagege gu mmade mai maalia i di hiigai,  
\q1 idimaa nia meegai ai belee mouli ai digaula.   
\b  
\qa xyodhx - Yodh  
\q1
\v 10 Di haingadaa dela ne tale ang gi agu daangada  
\q1 e haga madagudagu dangada huoloo,\x * \xo 4.10 \xt Deuteronomy 28.57; Ezekiel 5.10\x*  
\q1 nia dinana ala e aloho i nadau dama, guu dunu nadau dama belee gai.   
\b  
\qa xkaphx - Kaph  
\q1
\v 11 Dimaadua gu taiaga dono hagawelewele,  
\q1 guu dudu dana ahi i Zion, bolo gii wele di waahale deelaa gii odi.   
\b  
\qa xlamedhx - Lamedh  
\q1
\v 12 Gu deai tangada i golo,  
\q1 ge gu deai hogi nia dagi o nnenua tuadimee  
\q1 ne hagadonu ai bolo nia hagadaumee e mee di ulu  
\q1 gi lodo nia ngudu o di abaaba Jerusalem.   
\b  
\qa xmemx - Mem  
\q1
\v 13 Nia mee aanei guu hai mai i ana soukohp mo ana gau hai mee dabu  
\q1 la guu hai di huaidu di nadau haga hali nia dodo o nia daangada madammaa.   
\b  
\qa xnunx - Nun  
\q1
\v 14 Nia dagi digaula gu heehee i hongo nia ala  
\q1 gadoo be digau deegida,  
\q1 digaula gu gulugulua i nia dodo,  
\q1 gei nia daangada gu hagalee hiihai e bili gi digaula.   
\b  
\qa xsamekhx - Samekh  
\q1
\v 15 Nia daangada gu wwolowwolo boloo,  
\q1 “Goodou tuu i daha, goodou e gulugulua! Hudee bili mai!”  
\q1 Malaa, digaula gu hagadau adu gi nnuai guongo,  
\q1 tangada ne benebene digaula ai.   
\b  
\qa xayinx - Ayin  
\q1
\v 16 Dimaadua gu hagalee hila gi digaula,  
\q1 Mee ne bida hai digaula gi heehee beelaa,  
\q1 gu hagalee hila anga gi digau hai mee dabu mo nia dagi.   
\b  
\qa xpex - Pe  
\q1
\v 17 Gidaadou gu halahala di hagamaamaa dela digi hanimoi,  
\q1 dela gu deemee di gidee.  
\q1 Gidaadou gu talitali di hagamaamaa mai i tenua dela e deemee di hagamouli gidaadou.   
\b  
\qa xtsadhex - Tsadhe  
\q1
\v 18 Nia hagadaumee nogo talitali gidaadou,  
\q1 gei gidaadou gu deemee di heehee i hongo nia ala.  
\q1 Tadau madagoaa la guu lawa, di hagaodi la gu dae mai.   
\b  
\qa xqophx - Qoph  
\q1
\v 19 Di hai o tadau hagadaumee la guu hai be di ‘eagle’  
\q1 e mamaangi ia i lala di langi.  
\q1 Digaula gu hagabagibagi gidaadou,  
\q1 gu aali i gidaadou i hongo nia dama gonduu,  
\q1 guu kumi gidaadou haga homouli i lodo di anggowaa.   
\b  
\qa xreshx - Resh  
\q1
\v 20 Digaula guu kumi di hagamau o tadau mouli,  
\q1 go di king dela ne hilihili go Dimaadua,  
\q1 dela nogo hagadagadagagee ginai gidaadou  
\q1 e haga dagaloaha gidaadou gi daha mo tadau hagadaumee huogodoo.   
\b  
\qa xshinx - Sin ma Shin  
\q1
\v 21 Goodou go digau Edom mo Uz, goodou gadagada.  
\q1 Goodou tenetene i di godou madagoaa ala e mee.  
\q1 Di haingadaa gaa dae mai gi goodou labelaa,  
\q1 gei goodou ga heehee godou goloo ai, e haga langaadia dangada.   
\b  
\qa xtawx - Taw  
\q1
\v 22 Zion guu kae di hui o nadau huaidu.  
\q1 Dimaadua ga hagalee daahi gidaadou i lodo di gowaa  
\q1 dela e noho galabudi ai gidaadou i daha mo tadau gowaa donu.  
\q1 Malaa, goe go Edom, Dimaadua ga hagaduadua goe,  
\q1 ga hagi aga au haihai hala huogodoo.   
\c 5  
\s1 Talodalo gi dumaalia  
\q1
\v 1 Meenei Dimaadua, gi langahia mai mua nia mee ala gu hai mai gi gimaadou.  
\q1 Mmada mai gi gidee Goe di madau langaadia.   
\b  
\q1
\v 2 Madau goloo guu dada go digau mai i daha.  
\q1 Digaula guu noho i lodo madau hale.   
\b  
\q1
\v 3 Madau damana gu daaligi go nia hagadaumee,  
\q1 gei dolomeenei madau dinana guu hai nia ahina nadau lodo ai.   
\b  
\q1
\v 4 Gimaadou e hai gii hui madau wai e inu,  
\q1 gei e hai gii hui labelaa madau laagau e hai madau dohomu.   
\b  
\q1
\v 5 Gimaadou guu dagi hagaduadua  
\q1 gadoo be nia ‘donkey’ be nia ‘camel’,  
\q1 gimaadou gu duadua,  
\q1 gei di maa deai tangada e haga molooloo gimaadou ai.   
\b  
\q1
\v 6 Gimaadou e madamadau madau meegai gi digau Egypt mo Assyria  
\q1 bolo gii mee ai gimaadou di mouli.   
\b  
\q1
\v 7 Madau damana mmaadua gu ihala,  
\q1 gei dolomeenei digaula gu hagalee,  
\q1 gei gimaadou gu hagaduadua mai i nadau huaidu ne hai.   
\b  
\q1
\v 8 Digau ala e dagi gimaadou le e hai gadoo be nia hege,  
\q1 tangada e mee di haga dagaloaha gimaadou gi daha mo nadau mogobuna ai.   
\b  
\q1
\v 9 Digau daaligi dangada gu heehee i lodo nia gowaa maalama,  
\q1 madau mouli gu i lodo di hagalliga di madagoaa e halahala madau meegai.   
\b  
\q1
\v 10 Madau hiigai gu hidi ai madau magi welengina huoloo.  
\q1 Madau gili gu welengina gadoo be di gili o di baalanga wele.   
\b  
\q1
\v 11 Madau lodo guu kumi go digau hai huaidu i hongo di Gonduu Zion.  
\q1 Madau dama ahina guu hono bolo gi wanga ina nadau huaidina  
\q1 i lodo nia guongo o Judea hagatau.   
\b  
\q1
\v 12 Madau dagi guu lahi gu daudau i tomo nia laagau.  
\q1 Madau daane mmaadua gu hagalee e hagalabagau.   
\b  
\q1
\v 13 Madau dama daane guu hai ginai  
\q1 bolo gi holeholee nia gili meegai be digau hege,  
\q1 nia damagiigi lligi guu wanga nadau laagau daamaha gi aamo.   
\b  
\q1
\v 14 Digau mmaadua gu hagalee noho hua igolo  
\q1 i di ngudu di bontai o di abaaba,  
\q1 gei digau lligi gu hagalee dadaahili.   
\b  
\q1
\v 15 Di tenetene gu hagalee, guu maa gi daha i lodo madau mouli,  
\q1 di manawa gee guu pono nia gonigoni.   
\b  
\q1
\v 16 Nia mee ne dubu i lodo madau mee ala nogo hagapuu ginai ai.  
\q1 Gimaadou gu ihala, gei dolomeenei gimaadou gaa mmade.   
\b  
\q1
\v 17 Madau manawa guu magi,  
\q1 gei gimaadou gu deemee di mmada  
\q1 i madau golomada guu honu dangi.   
\b  
\q1
\v 18 Idimaa di Gonduu Sinai guu duu modogoia, guu hai di anggowaa,  
\q1 gei nia manu lodo geinga ‘jackal’ gu heehee i baahi nia gowaa ala gu mooho.   
\b  
\q1
\v 19 Gei Goe, meenei Dimaadua, Goe gaa king gaa hana hua beelaa,  
\q1 gaa dagi gaa dae loo gi di hagaodi o di madagoaa.   
\b  
\q1
\v 20 Goe e aha dela ne haga de langahia e Goe gimaadou di madagoaa looloo ehaa?  
\q1 Goe ga langahia e Goe gimaadou labelaa?   
\b  
\q1
\v 21 Dimaadua, daahia adu gimaadou labelaa gi di Goe!  
\q1 Daahia adu gimaadou labelaa!  
\q1 Dugu ina mai labelaa madau madamada mai mua.   
\b  
\q1
\v 22 Be Goe ga haga de langahia e Goe gimaadou gaa hana hua beelaa?  
\q1 Do hagawelewele laa dono hagageinga i golo ai?   