\id PRO - Biblica® Open Shona Contemporary Bible 2017 
\h Zvirevo 
\toc1 Zvirevo 
\toc2 Zvirevo 
\toc3 Zvi 
\mt1 ZVIREVO 
\c 1  
\s1 Mavambo: Chinangwa neDingindira 
\p  
\v 1 Zvirevo zvaSoromoni mwanakomana waDhavhidhi, mambo weIsraeri: 
\q2  
\v 2 kuti uwane uchenjeri nokurayirwa; 
\q2 nokunzwisisa mashoko enjere; 
\q1  
\v 3 kuti uve noupenyu hwokuzvibata hune uchenjeri 
\q2 uchiita zvakarurama nokururamisira uye nokuenzanisira; 
\q1  
\v 4 kuti vasina mano vapiwe uchenjeri, 
\q2 jaya ripiwe ruzivo namano, 
\q1  
\v 5 vakachenjera ngavanzwe uye vagowedzera pakudzidza kwavo, 
\q2 uye vanonzvera ngavawane kutungamirirwa, 
\q1  
\v 6 kuti vanzwisise zvirevo nemifananidzo, 
\q2 mashoko nezvirahwe zvavakachenjera. 
\p  
\v 7 Kutya Jehovha ndiwo mavambo ezivo, 
\q2 asi mapenzi anoshora uchenjeri nokurayirwa. 
\s1 Kugamuchira Uchenjeri kunokurudzirwa 
\s2 Yambiro pamusoro poUnyengeri 
\q1  
\v 8 Mwanakomana wangu, teerera, 
\q2 kurayira kwababa vako, uye usarasa kudzidzisa kwamai vako. 
\q1  
\v 9 Zvichava chishongo chakanaka pamusoro wako 
\q2 nouketani hunoshongedza mutsipa wako. 
\b  
\q1  
\v 10 Mwanakomana wangu, kana vatadzi vachikukwezva, 
\q2 usabvuma zvavari kuda kuti uite. 
\q1  
\v 11 Kana vakati, “Handei tose; 
\q2 ngativandirei munhu timuuraye; 
\q2 ngativandirei mweya usina mhosva; 
\q1  
\v 12 ngativamedzei vari vapenyu, seguva, 
\q2 uye vakakwana kudaro savaya vanodzika mugomba; 
\q1  
\v 13 tichawana marudzi ose ezvinhu zvinokosha 
\q2 tigozadza dzimba dzedu nezvatichapamba; 
\q1  
\v 14 isa zvinhu zvako pamwe chete nesu, 
\q2 tigova nechikwama chimwe chete,” 
\q1  
\v 15 mwanakomana wangu, usabvumirana navo, 
\q2 usaisa rutsoka panzira dzavo; 
\q1  
\v 16 nokuti tsoka dzavo dzinomhanyira muchivi, 
\q2 vanokurumidza kundodeura ropa. 
\q1  
\v 17 Hazvibatsiri sei kutambanudza mumbure 
\q2 shiri dzose dzichinyatsoona! 
\q1  
\v 18 Varume ava vanovandira ropa ravo vomene; 
\q2 vanozvivandira ivo pachavo! 
\q1  
\v 19 Aya ndiwo magumo avaya vanotsvaka pfuma nenzira yakaipa; 
\q2 inouraya vaya vanoiwana. 
\s2 Yambiro pamusoro poKuramba Uchenjeri 
\q1  
\v 20 Uchenjeri hunodanidzira nenzwi guru mumugwagwa, 
\q2 hunokwidza inzwi rahwo pachivara; 
\q1  
\v 21 kumusoro kwemigwagwa ine ruzha hunodanidzira, 
\q2 pamasuo eguta hunotaura shoko rahwo huchiti: 
\b  
\q1  
\v 22 “Kusvikira riniko imi vasina mano, muchingoda kugara musina mano? 
\q2 Kusvikira riniko vaseki vachifarira kuseka, 
\q2 uye mapenzi achivenga zivo? 
\q1  
\v 23 Dai makateerera kutsiura kwangu, 
\q2 ndingadai ndakadurura mwoyo wangu kwamuri 
\q2 uye ndakazivisa pfungwa dzangu kwamuri. 
\q1  
\v 24 Asi sezvo makandiramba pandakakudanai 
\q2 uye pasina kana mumwe akateerera pandakatambanudza ruoko rwangu, 
\q1  
\v 25 sezvo makashaya hanya nokurayira kwangu, 
\q2 uye mukasagamuchira kutsiura kwangu, 
\q1  
\v 26 iniwo ndichaseka panguva yenjodzi yenyu; 
\q2 ndichaseka dambudziko parichakusvikirai, 
\q1  
\v 27 dambudziko parichakukundai sedutu, 
\q2 njodzi paichavhuvhuta pamusoro penyu sechamupupuri, 
\q2 nhamo namatambudziko pazvichakukundai. 
\b  
\q1  
\v 28 “Ipapo vachadana kwandiri asi ini handingavapinduri; 
\q2 vachanditsvaka asi havangandiwani. 
\q1  
\v 29 Sezvo vakavenga zivo 
\q2 uye vakasasarudza kutya Jehovha, 
\q1  
\v 30 sezvo vasina kugamuchira yambiro yangu, 
\q2 uye vakashora kutsiura kwangu, 
\q1  
\v 31 vachadya zvibereko zvenzira dzavo 
\q2 uye vachazadzwa nezvibereko zvemano avo. 
\q1  
\v 32 Nokuti kusateerera kwavasina mano kuchavaurayisa, 
\q2 uye kushaya hanya kwamapenzi kuchavaparadza; 
\q1  
\v 33 asi ani naani achanditeerera achagara murugare, 
\q2 uye achagara akasununguka, asingatyi kuparadzwa.” 
\c 2  
\s2 Kunaka kwoUchenjeri 
\q1  
\v 1 Mwanakomana wangu, kana ukagamuchira mashoko angu, 
\q2 ukachengeta mirayiro yangu mauri, 
\q1  
\v 2 ukarerekera nzeve yako kuuchenjeri 
\q2 uye ukaisa mwoyo wako pakunzwisisa, 
\q1  
\v 3 uye kana ukadanidzira kuti uwanze njere 
\q2 uye ukadanidzira nenzwi guru kuti uwane kunzwisisa, 
\q1  
\v 4 uye kana ukahutsvaka sounotsvaka sirivha 
\q2 nokuhutsvaka sounotsvaka pfuma yakavanzwa, 
\q1  
\v 5 ipapo uchanzwisisa kutya Jehovha 
\q2 uye uchawana ruzivo rwaMwari. 
\q1  
\v 6 Nokuti Jehovha anopa uchenjeri, 
\q2 uye mumuromo make munobuda zivo nokunzwisisa. 
\q1  
\v 7 Anochengetera vakarurama kukunda, 
\q2 iye ndiye nhoo kuna avo vane mufambiro usina chaunopomerwa, 
\q1  
\v 8 nokuti anochengetedza nzira yavakarurama, 
\q2 uye anodzivirira nzira yavakatendeka vake. 
\q1  
\v 9 Ipapo uchanzwisisa zvakarurama, 
\q2 kururamisira nokuenzanisira nzira dzose dzakanaka. 
\q1  
\v 10 Nokuti uchenjeri huchapinda mumwoyo mako, 
\q2 uye ruzivo ruchafadza mweya wako. 
\q1  
\v 11 Kungwara kuchakuchengetedza, 
\q2 uye kunzwisisa kuchakurinda. 
\q1  
\v 12 Uchenjeri huchakuponesa panzira dzavanhu vakaipa, 
\q2 vanhu vane mashoko asakarurama, 
\q1  
\v 13 vanosiya nzira yakarurama 
\q2 kuti vafambe munzira dzerima, 
\q1  
\v 14 vanofarira kuita zvakaipa 
\q2 uye vanofarira kusarurama kwezvakaipa, 
\q1  
\v 15 vane nzira dzakaminama 
\q2 uye vanonyengera pamaitiro avo. 
\b  
\q1  
\v 16 Zvichakuponesazve pamukadzi chifeve, 
\q2 kubva pamudzimai asingazvibati, anokwezva namashoko ake, 
\q1  
\v 17 uyo akasiya murume woumhandara hwake 
\q2 uye akashaya hanya nesungano yaakaita pamberi paMwari. 
\q1  
\v 18 Nokuti imba yake inoenda kurufu, 
\q2 uye nzira dzake kumweya yavakafa. 
\q1  
\v 19 Hakuna anoenda kwaari achidzoka 
\q2 kana kuzowana nzira dzoupenyu. 
\b  
\q1  
\v 20 Naizvozvo iwe uchafamba munzira dzavanhu vakanaka 
\q2 uye ucharamba uri munzira dzavakarurama. 
\q1  
\v 21 Nokuti vakarurama vachagara munyika, 
\q2 uye vasina chavanopomerwa vacharamba vari mairi; 
\q1  
\v 22 asi vakaipa vachaparadzwa panyika, 
\q2 uye vasina kutendeka vachabviswa pairi. 
\c 3  
\s1 Munhu ngaatye Jehovha, avimbe naye uye amuteerere 
\q1  
\v 1 Mwanakomana wangu, usakanganwa kudzidzisa kwangu, 
\q2 asi uchengete mirayiro yangu mumwoyo mako, 
\q1  
\v 2 nokuti zvichawedzera makore mazhinji kuupenyu hwako, 
\q2 uye nokubudirira. 
\q1  
\v 3 Rudo nokutendeka ngazvirege kukusiya; 
\q2 uzvisungirire pamutsipa wako, 
\q2 zvinyore pahwendefa romwoyo wako. 
\q1  
\v 4 Ipapo uchawana nyasha nezita rakanaka 
\q2 pamberi paMwari navanhu. 
\b  
\q1  
\v 5 Vimba naJehovha nomwoyo wako wose 
\q2 urege kuzendamira panjere dzako; 
\q1  
\v 6 munzira dzako dzose umutungamidze, 
\q2 uye acharuramisa nzira dzako. 
\b  
\q1  
\v 7 Usazviita munhu akachenjera pamaonero ako; 
\q2 itya Jehovha uvenge zvakaipa. 
\q1  
\v 8 Izvi zvichava utano pamuviri wako 
\q2 uye nokusimbiswa kwamapfupa ako. 
\b  
\q1  
\v 9 Kudza Jehovha nepfuma yako, 
\q2 zvokutanga zvezvirimwa zvako; 
\q1  
\v 10 ipapo matura ako achazadzwa kusvikira pakufashukira, 
\q2 uye makate ako achazara kusvika pamusoro newaini itsva. 
\b  
\q1  
\v 11 Mwanakomana wangu, usazvidza kuranga kwaJehovha, 
\q2 uye usatsamwira kutsiura kwake, 
\q1  
\v 12 nokuti Jehovha anoranga avo vaanoda, 
\q2 sababa nomwanakomana wavanofarira. 
\b  
\q1  
\v 13 Akaropafadzwa munhu anowana uchenjeri, 
\q2 munhu anowana kunzwisisa, 
\q1  
\v 14 nokuti hwakanyanya kunaka kupfuura sirivha, 
\q2 uye hunopfumisa kupfuura goridhe. 
\q1  
\v 15 Hunokosha kupfuura marubhi; 
\q2 zvose zvaunoshuva hazvingafananidzwi nahwo. 
\q1  
\v 16 Mazuva mazhinji oupenyu ari muruoko rwahwo rworudyi; 
\q2 muruboshwe rwahwo mune upfumi nokukudzwa. 
\q1  
\v 17 Nzira dzahwo dzinofadza, 
\q2 uye makwara ahwo ose rugare. 
\q1  
\v 18 Ndihwo muti woupenyu kuna vose vanohumbundikira; 
\q2 vose vanohubata vacharopafadzwa. 
\b  
\q1  
\v 19 Nouchenjeri Jehovha akateya nheyo dzenyika, 
\q2 nokunzwisisa akaisa matenga munzvimbo dzawo; 
\q1  
\v 20 noruzivo rwake mvura dzakadzika dzakapatsanurwa, 
\q2 uye makore akadonhedza dova. 
\b  
\q1  
\v 21 Mwanakomana wangu, chengetedza kutonga kwakanaka nokungwara, 
\q2 usazvirega zvichibva pameso ako; 
\q1  
\v 22 zvichava upenyu kwauri, 
\q2 chishongo chakanaka pamutsipa wako. 
\q1  
\v 23 Ipapo uchafamba panzira yako murugare, 
\q2 uye rutsoka rwako harungagumburwi; 
\q1  
\v 24 paunovata pasi, haungatyi; paunovata pasi, 
\q2 hope dzako dzichava dzakanaka. 
\q1  
\v 25 Usatya zvako dambudziko rinovhundutsa 
\q2 kana kuparadza kunokunda vakaipa, 
\q1  
\v 26 nokuti Jehovha achava chivimbo chako 
\q2 uye achachengeta rutsoka rwako kuti rurege kubatwa. 
\b  
\q1  
\v 27 Usarega kuitira zvakanaka kuno uyo akafanirwa nazvo, 
\q2 kana zviri musimba rako kuzviita. 
\q1  
\v 28 Usati kumuvakidzani wako, 
\q2 “Ugodzoka imwe nguva; ndichazokupa mangwana,” 
\q2 iwe uchitova nazvo pauri. 
\b  
\q1  
\v 29 Usaronga kuitira muvakidzani wako zvakaipa, 
\q2 anogara nechivimbo pedyo newe. 
\q1  
\v 30 Usapomera munhu mhosva pasina chikonzero, 
\q2 iye asina zvaakutadzira. 
\b  
\q1  
\v 31 Usachiva munhu anoita zvinhu nechisimba, 
\q2 kana kusarudza ipi zvayo yenzira dzake, 
\q1  
\v 32 nokuti Jehovha anovenga munhu akatsauka, 
\q2 asi anoudza akarurama zvaanoda kuita. 
\b  
\q1  
\v 33 Kutuka kwaJehovha kuri paimba yeakaipa, 
\q2 asi anoropafadza musha womunhu akarurama. 
\q1  
\v 34 Anoseka vaseki vanozvikudza, 
\q2 asi anoitira nyasha vanozvininipisa. 
\q1  
\v 35 Vakachenjera vanowana kukudzwa, 
\q2 asi mapenzi anozviwanira kunyadziswa. 
\c 4  
\s2 Uchenjeri chinhu chikuru 
\q1  
\v 1 Teererai, vanakomana vangu, kurayira kwababa venyu; 
\q2 nyatsoteererai mugowana kunzwisisa. 
\q1  
\v 2 Ndinokupai dzidziso yakanaka, 
\q2 saka regai kurasa dzidziso yangu. 
\q1  
\v 3 Pandakanga ndiri mukomana mumba mababa vangu, 
\q2 ndichiri muduku uye mwana mumwe chete wamai vangu, 
\q1  
\v 4 baba vangu vakandidzidzisa vachiti, 
\q2 “Mwoyo wako ngaubatisise mashoko angu; 
\q2 chengeta mirayiro yangu ugorarama. 
\q1  
\v 5 Wana uchenjeri, wana kunzwisisa; 
\q2 usakanganwa mashoko angu kana kubva paari. 
\q1  
\v 6 Usarasa uchenjeri, ipapo huchakuchengeta; 
\q2 hude, ihwo hugokurinda. 
\q1  
\v 7 Uchenjeri chinhu chikuru; naizvozvo wana uchenjeri. 
\q2 Kunyange huchikutorera zvose zvaunazvo, wana kunzwisisa. 
\q1  
\v 8 Uhukudze; ipapo huchakusimudzira; 
\q2 uhumbundikire, ipapo huchakukudza. 
\q1  
\v 9 Huchakupfekedza chishongo chenyasha mumusoro mako, 
\q2 uye huchakupa korona yokubwinya.” 
\q1  
\v 10 Teerera, mwanakomana wangu, gamuchira zvandinotaura, 
\q2 ipapo makore oupenyu hwako achava mazhinji. 
\q1  
\v 11 Ndinokudzidzisa nzira youchenjeri 
\q2 uye ndiri kukutungamirira panzira dzakarurama. 
\q1  
\v 12 Paunofamba, tsoka dzako hadzingapinganidzwi, 
\q2 paunomhanya, haungagumburwi. 
\q1  
\v 13 Batisisa kurayirwa, usarega kuchienda; 
\q2 nyatsokurinda zvakanaka, nokuti ndihwo upenyu hwako. 
\q1  
\v 14 Usaisa rutsoka panzira dzavakaipa, 
\q2 kana kufamba panzira dzavanhu vakaipa. 
\q1  
\v 15 Udzinzvenge, usafamba padziri; 
\q2 tsauka padziri ugopfuurira mberi. 
\q1  
\v 16 Nokuti havangavati vasati vaita zvakaipa; 
\q2 havangabatwi nehope kusvikira vaita kuti mumwe munhu aputsike. 
\q1  
\v 17 Vanodya zvokudya zvezvakaipa, 
\q2 uye vanonwa waini yezvechisimba. 
\b  
\q1  
\v 18 Nzira yavakarurama yakafanana nechiedza chamambakwedza, 
\q2 chinoramba chichiwedzera kubwinya kusvikira pachiedza chamasikati makuru. 
\q1  
\v 19 Asi nzira yavakaipa yakaita serima guru; 
\q2 havazivi zvinoita kuti vagumburwe. 
\b  
\q1  
\v 20 Mwanakomana wangu, nyatsoteerera zvandinotaura; 
\q2 teereresa kumashoko angu. 
\q1  
\v 21 Usaite kuti abve pameso ako, 
\q2 achengete pakati pomwoyo wako; 
\q1  
\v 22 nokuti upenyu kuna avo vanoawana 
\q2 uye noutano kumuviri wose womunhu. 
\q1  
\v 23 Pamusoro pazvo zvose, chengetedza mwoyo wako, 
\q2 nokuti ndicho chitubu choupenyu. 
\q1  
\v 24 Bvisa zvinotsausa pamuromo wako; 
\q2 kutaura kwakaora ngakuve kure nemiromo yako. 
\q1  
\v 25 Meso ako ngaatarire mberi bedzi, 
\q2 ramba wakatarira mberi kwako. 
\q1  
\v 26 Gadzirira tsoka dzako gwara 
\q2 ugofamba munzira dzakasimba chete. 
\q1  
\v 27 Usatsaukira kurudyi kana kuruboshwe; 
\q2 chengetedza rutsoka rwako kuti rusaende pane zvakaipa. 
\c 5  
\s1 Yambiro pamusoro poUpombwe 
\q1  
\v 1 Mwanakomana wangu, nyatsoteerera kuuchenjeri hwangu, 
\q2 teereresa kumashoko angu oungwaru, 
\q1  
\v 2 kuti ugare wakachengeta kungwara 
\q2 uye kuti miromo yako ichengetedze zivo. 
\q1  
\v 3 Nokuti miromo yomukadzi chifeve inodonha uchi, 
\q2 nomutauriro wake unotedza kupfuura mafuta; 
\q1  
\v 4 asi pakupedzisira anovava senduru, 
\q2 anopinza somunondo unocheka namativi ose. 
\q1  
\v 5 Tsoka dzake dzinoenda kurufu; 
\q2 nhambwe dzake dzinonanga kuguva. 
\q1  
\v 6 Haafungi pamusoro penzira youpenyu; 
\q2 nzira dzake dzakaminama, asi iye haazvizivi. 
\q1  
\v 7 Saka zvino, vanakomana vangu, nditeererei; 
\q2 musatsauka pane zvandinotaura. 
\q1  
\v 8 Fambai nenzira iri kure naye, 
\q2 musasvika pedyo nomusuo wemba yake, 
\q1  
\v 9 kuti murege kupa vamwe zvakanaka zvesimba renyu, 
\q2 uye namakore enyu kuno uyo ane utsinye, 
\q1  
\v 10 kuti vatorwa varege kudya upfumi hwenyu, 
\q2 uye kushanda kwenyu nesimba kurege kupfumisa imba yomumwe munhu. 
\q1  
\v 11 Pakupedzisira kwoupenyu hwako uchagomera, 
\q2 kana nyama nomuviri wako zvaparadzwa. 
\q1  
\v 12 Uchazoti, “Mavengero andaiita kurayirwa! 
\q2 Mashorero aiita mwoyo wangu kudzorwa! 
\q1  
\v 13 Ndakanga ndisingateereri vadzidzisi vangu, 
\q2 kana kunzwa varairidzi vangu. 
\q1  
\v 14 Ndasvika pakuparara chaiko 
\q2 pakati peungano yose.” 
\b  
\q1  
\v 15 Inwa mvura pachirongo chako chaicho, 
\q2 mvura inoerera patsime rako chairo. 
\q1  
\v 16 Ko, zvitubu zvako zvinofanira kuerera mumigwagwa here; 
\q2 nzizi dzako dzemvura pazvivara? 
\q1  
\v 17 Ngadzive dzako woga, 
\q2 hadzitombofaniri kugoveranwa navatorwa. 
\q1  
\v 18 Tsime rako ngariropafadzwe, 
\q2 uye ufadzwe nomudzimai woujaya hwako. 
\q1  
\v 19 Sehadzi yengururu inofadza, nehadzi yenondo yakanaka, 
\q2 mazamu ake ngaakufadze nguva dzose, 
\q2 ugare uchigutswa norudo rwake. 
\q1  
\v 20 Unosungirweiko, mwanakomana wangu, nomukadzi chifeve? 
\q2 Unombundikirireiko chipfuva chomukadzi womumwe murume? 
\b  
\q1  
\v 21 Nokuti nzira dzomunhu dziri pachena pamberi paJehovha, 
\q2 uye anoongorora nzira dzake dzose. 
\q1  
\v 22 Zviito zvakaipa zvomunhu akaipa zvichamusunga; 
\q2 tambo dzechivi chake dzichamubata iye kwazvo. 
\q1  
\v 23 Achafa nokuda kwokushayiwa kuzvibata kwake, 
\q2 atsauswa noupenzi hwake hukuru. 
\c 6  
\s1 Yambiro pamusoro poUpenzi 
\q1  
\v 1 Mwanakomana wangu, kana uchinge waita rubatso kumuvakidzani wako, 
\q2 kana uchinge waita mhiko nokumbunda noruoko rwako kuno mumwe, 
\q1  
\v 2 kana uchinge wasungwa nokuda kwezvawakataura, 
\q2 wabatwa namashoko omuromo wako, 
\q1  
\v 3 ipapo ita izvi, mwanakomana wangu, 
\q2 kuti uzvisunungure, sezvo wawira mumaoko omuvakidzani wako! 
\q1 Enda undozvininipisa; 
\q2 ukumbire zvikuru kumuvakidzani wako! 
\q1  
\v 4 Usatendera meso ako hope, 
\q2 usatendera meso ako kutsumwaira. 
\q1  
\v 5 Zvipukunyutse, semhara kubva paruoko rwomuvhimi, 
\q2 seshiri kubva paugombe hwomuteyi. 
\q1  
\v 6 Enda kusvosve, iwe simbe; 
\q2 cherechedza nzira dzaro ugova wakachenjera! 
\q1  
\v 7 Harina mutungamiri, 
\q2 mutariri kana mutongi, 
\q1  
\v 8 asi rinochengeta zvokudya zvaro muzhizha, 
\q2 uye rinounganidza zvokudya zvaro pakukohwa. 
\b  
\q1  
\v 9 Uchasvika riniko wakarara ipapo, iwe simbe? 
\q2 Uchamuka riniko kubva pahope dzako? 
\q1  
\v 10 Kumbovata zvishomanana, kumbotsumwaira zvishomanana, 
\q2 kumbopeta maoko zvishomanana kuti ndizorore. 
\q1  
\v 11 Naizvozvo urombo huchauya kwauri segororo, 
\q2 uye kushayiwa somurwi akashonga nhumbi dzokurwa. 
\b  
\q1  
\v 12 Munhu asina maturo uye anoita zvakaipa, 
\q2 anofamba-famba achitaura zvakaora, 
\q2  
\v 13 anochonya nameso ake, 
\q2 anonongedzera netsoka dzake, 
\q2 uye anodudzira neminwe yake, 
\q2  
\v 14 anoronga zvakaipa nounyengeri mumwoyo make, 
\q2 iyeyo anogaromutsa kupesana. 
\q1  
\v 15 Naizvozvo njodzi ichamuwira munguva shoma shoma; 
\q2 achaparadzwa nokukurumidza, pasina chingamubatsira. 
\b  
\li1  
\v 16 Pane zvinhu zvitanhatu zvakavengwa naJehovha, 
\li2 zvinomwe zvinomunyangadza zvinoti: 
\li3  
\v 17 meso anozvikudza, 
\li3 rurimi runoreva nhema, 
\li3 maoko anodeura ropa risina mhosva, 
\li3  
\v 18 mwoyo unoronga mano akaipa, 
\li3 tsoka dzinokurumidza kumhanyira muzvakaipa, 
\li3  
\v 19 chapupu chenhema chinodurura nhema, 
\li3 uye munhu anomutsa kupesana pakati pehama. 
\s2 Yambiro pamusoro poUpombwe 
\q1  
\v 20 Mwanakomana wangu, chengetedza mirayiro yababa vako, 
\q2 uye usarasa kudzidzisa kwamai vako. 
\q1  
\v 21 Zvisungirire pamwoyo wako nokusingaperi; 
\q2 uzvishonge pamutsipa wako. 
\q1  
\v 22 Paunofamba zvichakutungamirira; 
\q2 paucharara, zvichakurinda; 
\q2 pauchamuka, zvichataura newe. 
\q1  
\v 23 Nokuti mirayiro iyi ndiyo mwenje kwauri, dzidziso iyi ndiyo chiedza, 
\q2 uye kudzora kwokurayira ndiko nzira youpenyu, 
\q1  
\v 24 kunokuchengetedza pamukadzi asingazvibati, 
\q2 kubva parurimi runonyengera rwomudzimai asingazvibati. 
\q1  
\v 25 Usachiva runako rwake mumwoyo mako, 
\q2 kana kumurega achikubata namaziso ake, 
\q1  
\v 26 nokuti chifeve chinokuderedza kusvikira wafanana nechingwa, 
\q2 uye mukadzi womumwe asi ari chifeve anoendesa upenyu hwako chaihwo kurufu. 
\q1  
\v 27 Ko, munhu angaisa moto pamakumbo ake, 
\q2 nguo dzake dzikasatsva here? 
\q1  
\v 28 Ko, munhu angafamba pamazimbe anopisa, 
\q2 tsoka dzake dzikasatsva here? 
\q1  
\v 29 Ndizvo zvakaita uyo anorara nomudzimai womumwe murume; 
\q2 hapana angabate mukadzi iyeyo akasarangwa. 
\b  
\q1  
\v 30 Vanhu havazvidzi mbavha 
\q2 kana ikaba kuti ipedze nzara yayo painenge yoziya. 
\q1  
\v 31 Asi kana akabatwa, anofanira kuripa kakapetwa kanomwe, 
\q2 kunyange zvichimutorera pfuma yose yeimba yake. 
\q1  
\v 32 Asi munhu anoita upombwe, anoshayiwa njere; 
\q2 ani naani anozviita anozviparadza iye pachake. 
\q1  
\v 33 Kurohwa nokunyadziswa ndiwo mugove wake, 
\q2 uye kunyadziswa kwake hakungatongobviswi; 
\q1  
\v 34 nokuti godo rinomutsa hasha dzomurume, 
\q2 uye haanganzwiri tsitsi kana otsiva. 
\q1  
\v 35 Haangagamuchiri muripo upi zvawo; 
\q2 acharamba fufuro, kunyange rakakura sei. 
\c 7  
\s1 Yambiro pamusoro poMukadzi Chifeve 
\q1  
\v 1 Mwanakomana wangu, 
\q2 chengeta mashoko angu ugoviga mirayiro yangu mauri. 
\q1  
\v 2 Chengeta mirayiro yangu ugorarama; 
\q2 uchengete dzidziso dzangu semboni yeziso rako. 
\q1  
\v 3 Uzvisungirire paminwe yako; 
\q2 uzvinyore pahwendefa yomwoyo wako. 
\q1  
\v 4 Uti kuuchenjeri, “Uri hanzvadzi yangu,” 
\q2 uye uti kunzwisisa ndiyo hama yako; 
\q1  
\v 5 zvichakuchengeta kure nomukadzi chifeve; 
\q2 kubva pamudzimai asingazvibati anokwezva namashoko ake. 
\q1  
\v 6 Napawindo remba yangu 
\q2 ndakatarira panze nomumagirazi. 
\q1  
\v 7 Ndakaona pakati pavasina mano 
\q2 ndikacherechedza pakati pamajaya, 
\q2 rimwe jaya rakanga risina njere. 
\q1  
\v 8 Rakanga richidzika nomugwagwa pedyo nepakona yomukadzi uya, 
\q2 richifamba rakananga kumba kwake, 
\q1  
\v 9 panguva yorubvunzavaeni, 
\q2 zuva ravira, kunze kwosviba. 
\b  
\q1  
\v 10 Ipapo mukadzi akabuda kuzosangana naye, 
\q2 akapfeka sechifeve uye azere nounyengeri. 
\q1  
\v 11 Anotaura noruzha uye anozvikudza, 
\q2 tsoka dzake hadzigari pamba; 
\q1  
\v 12 imwe nguva ari munzira, imwe nguva ari pazvivara. 
\q2 Anorindira pamakona ose. 
\q1  
\v 13 Akamubata ndokumutsvoda, 
\q2 uye nechiso chisina nyadzi akati: 
\b  
\q1  
\v 14 “Ndine zvipiriso zvokuwadzana kumba kwangu; 
\q2 nhasi ndazadzisa mhiko dzangu. 
\q1  
\v 15 Saka ndauya kuzosangana newe; 
\q2 ndanga ndichikutsvaka, zvino ndazokuwana! 
\q1  
\v 16 Ndawaridza mubhedha wangu machira ane mavara, 
\q2 anobva kuIjipiti. 
\q1  
\v 17 Ndasasa zvinonhuhwira pamubhedha wangu, zvinoti: 
\q2 mura, gavakava nesinamoni. 
\q1  
\v 18 Uya, tinwe tigute norudo kusvikira mangwanani; 
\q2 ngatifare zvedu norudo! 
\q1  
\v 19 Murume wangu haako kumba, 
\q2 akafamba rwendo rurefu. 
\q1  
\v 20 Akatakura homwe yake izere nemari 
\q2 uye haangadzoki kumba kusvikira pajenaguru.” 
\b  
\q1  
\v 21 Namashoko okunyengetedza akamutsausa; 
\q2 akamukwezva nokutaura kwake kunonyengera. 
\q1  
\v 22 Pakarepo akamutevera senzombe 
\q2 inoenda kundobayiwa, 
\q1 senondo inopinda mumusungo, 
\q2  
\v 23 kusvikira museve wabaya chiropa chake, 
\q1 seshiri inokurumidza kupinda muugombe, 
\q2 asingazivi kuti zvichamuurayisa. 
\b  
\q1  
\v 24 Saka zvino, vanakomana vangu, teererai kwandiri; 
\q2 nyatsoteererai zvandinotaura. 
\q1  
\v 25 Usarega mwoyo wako uchitsaukira kunzira dzake, 
\q2 kana kurasikira pamakwara ake. 
\q1  
\v 26 Vazhinji vakakuvadzwa naye vakawisirwa pasi; 
\q2 vaakauraya vakawanda kwazvo. 
\q1  
\v 27 Imba yake mugwagwa mukuru unoenda kuguva, 
\q2 uchitungamirira kumakamuri orufu. 
\c 8  
\s1 Kudana kwoUchenjeri 
\q1  
\v 1 Ko, uchenjeri hahudanidziri here? 
\q2 Kunzwisisa hakusimudziri inzwi rako here? 
\q1  
\v 2 Panzvimbo dzakakwirira panzira, 
\q2 pamharadzano dzenzira, ndipo pahumire; 
\q1  
\v 3 parutivi rwamasuo okupinda muguta, pamikova, 
\q2 hunodanidzirisa huchiti, 
\q1  
\v 4 “Kwamuri, imi varume, ndinodanidzira; 
\q2 ndinosimudzira inzwi rangu kuvanhu vose. 
\q1  
\v 5 Imi vasina mano, wanai uchenjeri; 
\q2 imi mapenzi, wanai kunzwisisa. 
\q1  
\v 6 Teererai, nokuti ndine zvinhu zvinokosha zvokutaura; 
\q2 ndinozarura muromo wangu kuti nditaure zvakarurama. 
\q1  
\v 7 Muromo wangu unotaura zvokwadi, 
\q2 nokuti miromo yangu inovenga zvakaipa. 
\q1  
\v 8 Mashoko ose omuromo wangu akarurama; 
\q2 hapana kana rimwe rakakombama kana rakaipa. 
\q1  
\v 9 Kune ane njere ose zvawo akarurama, 
\q2 akarurama kuna avo vane zivo. 
\q1  
\v 10 Sarudza kurayira kwangu panzvimbo yesirivha, 
\q2 ruzivo panzvimbo yegoridhe rakaisvonaka, 
\q1  
\v 11 nokuti uchenjeri hunokosha kupfuura marubhi, 
\q2 uye hapana chaungada chingaenzaniswa nahwo. 
\b  
\q1  
\v 12 “Ini, uchenjeri ndinogara pamwe chete navakachenjera; 
\q2 ndine ruzivo nenjere. 
\q1  
\v 13 Kutya Jehovha ndiko kuvenga zvakaipa; 
\q2 ndinovenga kuzvikudza namanyawi, 
\q2 maitiro akaipa nokutaura kunonyangadza. 
\q1  
\v 14 Zano nokutonga kwakanaka ndezvangu; 
\q2 ndine kunzwisisa nesimba. 
\q1  
\v 15 Madzimambo anobata ushe neni 
\q2 uye vatongi vanodzika mirayiro yakarurama; 
\q1  
\v 16 machinda anofambisa ushe neni, 
\q2 navakuru vose vanotonga panyika. 
\q1  
\v 17 Ndinoda avo vanondida, 
\q2 uye vaya vanonditsvaka vanondiwana. 
\q1  
\v 18 Pfuma nokukudzwa zvineni, 
\q2 upfumi hunogara nokururama. 
\q1  
\v 19 Chibereko changu chakanaka kupfuura goridhe rakaisvonaka; 
\q2 zvandinobereka zvinopfuura sirivha yakaisvonaka. 
\q1  
\v 20 Ndinofamba munzira dzokururama, 
\q2 pamakwara okururamisira, 
\q1  
\v 21 ndichipa upfumi kuna avo vanondida, 
\q2 uye ndichiita kuti matura avo azare. 
\b  
\q1  
\v 22 “Jehovha akandibudisa sebasa rake rokutanga pamabasa ake, 
\q2 kutangira mabasa ake akare; 
\q1  
\v 23 ndakagadzwa kubva pakusingaperi, 
\q2 kubva pakutanga, nyika isati yavapo. 
\q1  
\v 24 Makungwa asati avapo, ndakaberekwa, 
\q2 pasati pava nezvitubu zvine mvura zhinji; 
\q1  
\v 25 makomo asati aiswa munzvimbo dzawo, 
\q2 zvikomo zvisati zvavapo, ndakaberekwa, 
\q1  
\v 26 asati aita nyika neminda 
\q2 kana guruva ripi zvaro renyika. 
\q1  
\v 27 Ndakanga ndiripo paakaisa matenga munzvimbo dzawo, 
\q2 paakaita denderedzwa pamusoro pamakungwa, 
\q1  
\v 28 paakaita makore kudenga 
\q2 uye paakasimbisa zvitubu zvamakungwa, 
\q1  
\v 29 paakapa gungwa miganhu yaro 
\q2 kuti mvura dzirege kudarika zvaakarayira, 
\q1 uye paakateya nheyo dzenyika. 
\q2  
\v 30 Ipapo ndini ndaiva mhizha parutivi rwake. 
\q1 Ndaigara ndichifara zuva nezuva, 
\q2 ndichifara nguva dzose pamberi pake, 
\q1  
\v 31 ndichifadzwa nenyika yake yose 
\q2 uye ndichifadzwa navanhu vose. 
\b  
\q1  
\v 32 “Saka zvino, vanakomana vangu, teererai kwandiri; 
\q2 vakaropafadzwa avo vanochengeta nzira dzangu. 
\q1  
\v 33 Teererai kurayira kwangu mugova vakachenjera; 
\q2 musakushayira hanya. 
\q1  
\v 34 Akaropafadzwa munhu anoteerera kwandiri, 
\q2 anorinda mazuva ose pamasuo angu. 
\q2 Anomira pamukova womusuo wangu. 
\q1  
\v 35 Nokuti ani naani anondiwana anowana upenyu 
\q2 uye anogamuchira nyasha kubva kuna Jehovha. 
\q1  
\v 36 Asi ani naani asingandiwani anozvikuvadza; 
\q2 vose vanondivenga vanoda rufu.” 
\c 9  
\s2 Kukoka kwoUchenjeri nekwoUpenzi 
\q1  
\v 1 Uchenjeri hwakavaka imba yahwo; 
\q2 hwakaveza mbiru dzahwo nomwe. 
\q1  
\v 2 Hwakabika nyama yahwo; uye hukagadzira waini yahwo; 
\q2 hwakagadzirawo tafura yahwo. 
\q1  
\v 3 Hwakatuma varandakadzi vahwo, 
\q2 uye hunodanidzira kubva panzvimbo yakakwirira kwazvo yeguta. 
\q1  
\v 4 Kuna avo vanoshayiwa njere hunoti, 
\q2 “Vose vasina uchenjeri ngavauye muno! 
\q1  
\v 5 Uyai, mudye zvokudya zvangu 
\q2 munwe waini yandagadzira. 
\q1  
\v 6 Siyai nzira dzenyu dzisina mano mugorarama; 
\q2 fambai munzira yokunzwisisa. 
\b  
\q1  
\v 7 “Ani naani anorayira mudadi anozvitsvakira kutukwa; 
\q2 ani naani anotsiura munhu akaipa anozviwanira kutukwa. 
\q1  
\v 8 Usatsiura mudadi kuti arege kukuvenga; 
\q2 tsiura munhu akachenjera uye achakuda. 
\q1  
\v 9 Rayira munhu akachenjera uye achawedzera uchenjeri hwake; 
\q2 dzidzisa munhu akarurama uye achawedzera kudzidza kwake. 
\b  
\q1  
\v 10 “Kutya Jehovha ndiwo mavambo ouchenjeri, 
\q2 uye kuziva Iye Mutsvene ndiko kunzwisisa. 
\q1  
\v 11 Nokuti neni mazuva ako achava mazhinji, 
\q2 uye makore achawedzerwa kuupenyu hwako. 
\q1  
\v 12 Kana uri wakachenjera, uchenjeri hwako huchakupa mubayiro; 
\q2 kana uri mudadi, iwe woga ndiwe uchatambura.” 
\b  
\q1  
\v 13 Mukadzi benzi ane ruzha; 
\q2 haana kudzikama uye haana zivo. 
\q1  
\v 14 Anogara pamusuo wemba yake, 
\q2 napachigaro chiri panzvimbo yakakwiririsa yeguta, 
\q1  
\v 15 achidanidzira kuna avo vanenge vachipfuura napo, 
\q2 vaya vanofamba zvakarurama nenzira yavo. 
\q1  
\v 16 Anoti kuna vaya vasina njere, 
\q2 “Vose vasina mano ngavauye muno! 
\q1  
\v 17 Mvura yakabiwa inozipa; 
\q2 zvokudya zvinodyirwa muchivande zvinonaka!” 
\q1  
\v 18 Asi zvavasingazivi ndezvokuti mune vakafa, 
\q2 uye kuti vanomushanyira vari mukati kati meguva. 
\c 10  
\s1 Zvirevo zvaSoromoni 
\p  
\v 1 Zvirevo zvaSoromoni: 
\q1 Mwanakomana akachenjera anofadza baba vake, 
\q2 asi mwanakomana benzi anosuwisa mai vake. 
\b  
\q1  
\v 2 Pfuma yakawanikwa zvakaipa haibatsiri chinhu, 
\q2 asi kururama kunorwira parufu. 
\b  
\q1  
\v 3 Jehovha haatenderi akarurama kuti anzwe nzara, 
\q2 asi kupanga kwowakaipa anokusundira kure. 
\b  
\q1  
\v 4 Maoko ane usimbe anoita kuti munhu ave murombo, 
\q2 asi maoko anoshingaira anopfumisa. 
\b  
\q1  
\v 5 Anounganidza zvirimwa muzhizha, mwanakomana akachenjera, 
\q2 asi anorara munguva yokukohwa, mwanakomana anonyadzisa. 
\b  
\q1  
\v 6 Maropafadzo ndiwo korona yomusoro woakarurama, 
\q2 asi kuita nechisimba kuzere mumuromo womunhu akaipa. 
\b  
\q1  
\v 7 Kuyeukwa kwowakarurama kuchava chikomborero, 
\q2 asi zita rowakaipa richaora. 
\b  
\q1  
\v 8 Akachenjera pamwoyo anogamuchira mirayiro, 
\q2 asi benzi rinotaura zvisina maturo richaparara. 
\b  
\q1  
\v 9 Munhu akarurama anofamba akachengetedzeka, 
\q2 asi uyo anofamba nenzira dzakaminama achabatwa. 
\b  
\q1  
\v 10 Uyo anochonya neziso roruvengo anouyisa kusuwa, 
\q2 asi benzi rinotaura zvisina maturo richaparara. 
\b  
\q1  
\v 11 Muromo womunhu akarurama chitubu choupenyu, 
\q2 asi kuita nechisimba kuzere mumuromo womunhu akaipa. 
\b  
\q1  
\v 12 Ruvengo runomutsa kupesana, 
\q2 asi rudo runofukidzira zvakaipa zvose. 
\b  
\q1  
\v 13 Uchenjeri hunowanikwa pamiromo yavane njere, 
\q2 asi shamhu yakafanira musana wouyo asina njere. 
\b  
\q1  
\v 14 Vanhu vakachenjera vanochengeta zivo, 
\q2 asi muromo webenzi unotsvaka kuparara. 
\b  
\q1  
\v 15 Upfumi hwavakapfuma ndiro guta ravo rina masvingo, 
\q2 asi urombo ndiko kuparadzwa kwavarombo. 
\b  
\q1  
\v 16 Mubayiro wavakarurama ndihwo upenyu, 
\q2 asi zvinowanikwa nowakaipa ndiko kurangwa. 
\b  
\q1  
\v 17 Uyo anoteerera kurayira anoratidza nzira youpenyu, 
\q2 asi ani naani anozvidza kudzorwa anotsausa vamwe. 
\b  
\q1  
\v 18 Uyo anovanza ruvengo rwake ane miromo inoreva nhema, 
\q2 uye ani naani anoparadzira guhwa ibenzi. 
\b  
\q1  
\v 19 Kana mashoko ari mazhinji, chivi hachingashayikwi, 
\q2 asi uyo anodzora rurimi rwake akachenjera. 
\b  
\q1  
\v 20 Rurimi rwakarurama isirivha yakaisvonaka, 
\q2 asi mwoyo wowakaipa haubatsiri chinhu. 
\b  
\q1  
\v 21 Miromo yemunhu akarurama inosimbisa vazhinji, 
\q2 asi mapenzi anofa nokuda kwokushayiwa zivo. 
\b  
\q1  
\v 22 Kuropafadza kwaJehovha kunowanisa upfumi, 
\q2 uye haawedzeri matambudziko kwahuri. 
\b  
\q1  
\v 23 Benzi rinofadzwa nokuita zvakaipa, 
\q2 asi munhu anonzwisisa anofarira uchenjeri. 
\b  
\q1  
\v 24 Zvinotyiwa nowakaipa ndizvo zvichaitika kwaari; 
\q2 zvinoshuviwa nowakarurama zvichapiwa kwaari. 
\b  
\q1  
\v 25 Kana dutu rapfuura napo, vakaipa havazowanikwi, 
\q2 asi vakarurama vachamira vakasimba nokusingaperi. 
\b  
\q1  
\v 26 Sevhiniga kumazino noutsi kumaziso, 
\q2 ndizvo zvakaita simbe kuna avo vachamutuma. 
\b  
\q1  
\v 27 Kutya Jehovha kunowedzera mazuva kuupenyu, 
\q2 asi makore owakaipa achatapudzwa. 
\b  
\q1  
\v 28 Tarisiro yowakarurama mufaro, 
\q2 asi tariro dzowakaipa dzichaparadzwa. 
\b  
\q1  
\v 29 Nzira yaJehovha ndiyo utiziro hwavakarurama, 
\q2 asi ndiko kuparadzwa kwaavo vanoita zvakaipa. 
\b  
\q1  
\v 30 Akarurama haangatongodzurwi, 
\q2 asi vakaipa havangarambi vari munyika. 
\b  
\q1  
\v 31 Muromo womunhu akarurama unobudisa uchenjeri, 
\q2 asi rurimi rwakaipa ruchabviswa. 
\b  
\q1  
\v 32 Miromo yomunhu akarurama inoziva zvakafanira, 
\q2 asi muromo womunhu akaipa, zvakaipa chete. 
\c 11  
\q1  
\v 1 Jehovha anovenga zviero zvinonyengera, 
\q2 asi zviero zvakakwana zvinomufadza. 
\q1  
\v 2 Kana kuzvikudza kwasvika, ipapo kunyadziswa kwasvikawo, 
\q2 asi uchenjeri huri kune akazvininipisa. 
\b  
\q1  
\v 3 Unhu hwavakarurama hunovatungamirira, 
\q2 asi vasina kutendeka vanoparadzwa nokunyengera kwavo. 
\b  
\q1  
\v 4 Pfuma haibatsiri chinhu pazuva rokutsamwa, 
\q2 asi kururama kunorwira parufu. 
\b  
\q1  
\v 5 Kururama kwavasina chavangapomerwa kunovaruramisira nzira yavo, 
\q2 asi vakaipa vachaparadzwa nezvakaipa zvavo. 
\b  
\q1  
\v 6 Kururama kwavakarurama kunovarwira, 
\q2 asi vasina kutendeka vanosungwa nezvishuvo zvavo zvakaipa. 
\b  
\q1  
\v 7 Kana munhu akaipa afa, tariro yake yaparara; 
\q2 zvose zvaaitarisira kubva pasimba rake zvaparadzwa. 
\b  
\q1  
\v 8 Munhu akarurama anonunurwa kubva mudambudziko, 
\q2 uye rigoenda kuno munhu akaipa panzvimbo yake. 
\b  
\q1  
\v 9 Munhu asina umwari anoparadza muvakidzani wake nomuromo wake, 
\q2 asi kubudikidza nezivo akarurama anopunyuka. 
\b  
\q1  
\v 10 Vakarurama pavanobudirira, guta rinofara; 
\q2 vakaipa pavanoparara, kupembera nomufaro zvinonzwikwa. 
\b  
\q1  
\v 11 Kubudikidza nokuropafadzwa kwomunhu akarurama, 
\q2 guta rinosimudzirwa, asi nomuromo womunhu akaipa rinoparadzwa. 
\b  
\q1  
\v 12 Munhu anoshayiwa uchenjeri anoseka muvakidzani wake, 
\q2 asi munhu anonzwisisa anodzora rurimi rwake. 
\b  
\q1  
\v 13 Guhwa rinoparadza chivimbo, 
\q2 asi munhu akavimbika anochengetedza zvakavanzika. 
\b  
\q1  
\v 14 Nokuda kwokushaya utungamiri rudzi runoparara, 
\q2 asi varayiri vazhinji vanoita kuti kukunda kuvepo. 
\b  
\q1  
\v 15 Uyo anoisira mumwe rubatso zvirokwazvo achaona nhamo, 
\q2 asi ani naani anoramba kumbundana maoko achiita mhiko achapona. 
\b  
\q1  
\v 16 Mukadzi ane mwoyo munyoro achakudzwa, 
\q2 asi varume vane utsinye vachawana pfuma chete. 
\b  
\q1  
\v 17 Munhu ane tsitsi anozviitira zvakanaka iye pachake, 
\q2 asi munhu ane utsinye anozviunzira dambudziko. 
\b  
\q1  
\v 18 Munhu akaipa anowana mubayiro wokunyengedzera, 
\q2 asi uyo anodyara kururama anokohwa mubayiro wechokwadi. 
\b  
\q1  
\v 19 Munhu akarurama zvechokwadi anowana upenyu, 
\q2 asi uyo anotevera zvakaipa anoenda kurufu rwake. 
\b  
\q1  
\v 20 Jehovha anovenga vanhu vane mwoyo yakaipa, 
\q2 asi anofarira avo vane nzira dzisina chadzingapomerwa. 
\b  
\q1  
\v 21 Zvirokwazvo akaipa acharangwa bedzi, 
\q2 asi vakarurama vachasunungurwa. 
\b  
\q1  
\v 22 Sezvakaita mukaro wegoridhe mumhino dzenguruve, 
\q2 ndizvo zvakaitawo mukadzi akanaka pachiso asi asina njere. 
\b  
\q1  
\v 23 Chishuvo cheakarurama chinoguma mune zvakanaka chete, 
\q2 asi tariro yeakaipa inogumira mukutsamwirwa. 
\b  
\q1  
\v 24 Mumwe munhu anongopa pachena, asi achitowana zvimwe zvakawanda; 
\q2 mumwe anonyima zvaanofanira kupa, asi agova murombo. 
\b  
\q1  
\v 25 Munhu anopavhurira achabudirira; 
\q2 uyo anomutsiridza vamwe achamutsiridzwawo. 
\b  
\q1  
\v 26 Vanhu vanotuka munhu anounganidza zviyo vamwe vasina, 
\q2 asi mukomborero uchava korona youyo anofarira kutengesa. 
\b  
\q1  
\v 27 Uyo anotsvaka zvakanaka achawana nyasha, 
\q2 asi zvakaipa zvinosvika kune uyo anozvitsvaka. 
\b  
\q1  
\v 28 Ani naani anovimba noupfumi hwake achawa, 
\q2 asi akarurama achanaka seshizha nyoro. 
\b  
\q1  
\v 29 Uyo anouyisa dambudziko kumhuri yake achagara nhaka yemhepo chete, 
\q2 uye benzi richava muranda womunhu akachenjera. 
\b  
\q1  
\v 30 Chibereko chokururama ndiwo muti woupenyu, 
\q2 uye anotungamirira mweya yavanhu kuruponeso ndiye akachenjera. 
\b  
\q1  
\v 31 Kana vakarurama vachiwana zvakavafanira panyika, 
\q2 ko, kuzoti akaipa nomutadzi! 
\c 12  
\q1  
\v 1 Ani naani anofarira kuzvirovedza anoda zivo, 
\q2 asi uyo anovenga kudzorwa ibenzi. 
\q1  
\v 2 Munhu akanaka anowana nyasha kubva kuna Jehovha, 
\q2 asi Jehovha anotuka munhu ane mano akaipa. 
\b  
\q1  
\v 3 Munhu haangasimbiswi nezvakaipa, 
\q2 asi mudzi womunhu akarurama haungadzurwi. 
\b  
\q1  
\v 4 Mudzimai ane unhu hwakanaka ikorona kumurume wake, 
\q2 asi mudzimai anonyadzisa akafanana nokuora mumapfupa omurume wake. 
\b  
\q1  
\v 5 Urongwa hwomunhu akarurama hwakarurama, 
\q2 asi kurayira kwavakaipa kunonyengera. 
\b  
\q1  
\v 6 Mashoko owakaipa anovandira ropa, 
\q2 asi kutaura kwavakarurama kunovanunura. 
\b  
\q1  
\v 7 Vanhu vakaipa vanobviswa pachigaro uye havazovapozve, 
\q2 asi imba yowakarurama icharamba yakasimba. 
\b  
\q1  
\v 8 Munhu anorumbidzwa maererano nouchenjeri hwake, 
\q2 asi vanhu vane pfungwa dzakatsauka vanozvidzwa. 
\b  
\q1  
\v 9 Zviri nani kuva munhu anoninipiswa asi iwe une muranda, 
\q2 pane kuzviita munhu wapamusoro iwe usina zvokudya. 
\b  
\q1  
\v 10 Munhu akarurama ane hanya nechipfuwo chake, 
\q2 asi zviito zvakanaka zvowakaipa utsinye. 
\b  
\q1  
\v 11 Uyo anoshanda mumunda wake achava nezvokudya zvakawanda, 
\q2 asi uyo anongotevera zvisina maturo anoshayiwa zivo. 
\b  
\q1  
\v 12 Vakaipa vanopanga zvakapambwa zvavanhu vakaipa, 
\q2 asi mudzi woakarurama unobereka zvibereko. 
\b  
\q1  
\v 13 Munhu akaipa anobatwa nokutaura kwake kwakaipa, 
\q2 asi munhu akarurama anopunyuka padambudziko. 
\b  
\q1  
\v 14 Kubva pazvibereko zvemiromo yake munhu anozadzwa nezvinhu zvakanaka, 
\q2 zvirokwazvo sokupiwa mubayiro kwaanoitwa nebasa ramaoko ake. 
\b  
\q1  
\v 15 Nzira yebenzi inoita seyakanaka kwaari, 
\q2 asi munhu akachenjera anoteerera kurayira. 
\b  
\q1  
\v 16 Benzi rinoratidza kutsamwa pakarepo, 
\q2 asi munhu akachenjera anoshayira hanya kutukwa. 
\b  
\q1  
\v 17 Chapupu chezvokwadi chinopa uchapupu hwezvokwadi, 
\q2 asi chapupu chenhema chinoreva nhema. 
\b  
\q1  
\v 18 Mashoko anotaurwa nokusarangarira anobaya somunondo, 
\q2 asi rurimi rwomunhu akachenjera runoporesa. 
\b  
\q1  
\v 19 Miromo yezvokwadi ichasimbiswa nokusingaperi, 
\q2 asi rurimi runoreva nhema runogara kwechinguva chiduku. 
\b  
\q1  
\v 20 Mune kunyengera mumwoyo yaavo vanoronga zvakaipa, 
\q2 asi rufaro rwuri kune avo vanokurudzira rugare. 
\b  
\q1  
\v 21 Akarurama haangatongowirwi nezvakaipa, 
\q2 asi vakaipa vachava namatambudziko akavafanira. 
\b  
\q1  
\v 22 Jehovha anovenga miromo inotaura nhema, 
\q2 asi anofadzwa navanhu vanotaura chokwadi. 
\b  
\q1  
\v 23 Munhu akachenjera anovanza zivo yake, 
\q2 asi mwoyo yamapenzi inotaura zvoupenzi. 
\b  
\q1  
\v 24 Maoko anoshingaira achatonga, 
\q2 asi usimbe hunopedzisira mukushanda somuranda. 
\b  
\q1  
\v 25 Mwoyo unopunyaira unoremedza munhu, 
\q2 asi shoko nyoro rinomufadza. 
\b  
\q1  
\v 26 Munhu akarurama anochenjerera ushamwari, 
\q2 asi nzira yavakaipa inovatungamirira mukurasika. 
\b  
\q1  
\v 27 Munhu ane usimbe haagochi mhuka yaabata, 
\q2 asi munhu anoshingaira anokoshesa pfuma yake. 
\b  
\q1  
\v 28 Munzira yokururama mune upenyu; 
\q2 kwainoenda hakuna rufu. 
\c 13  
\q1  
\v 1 Mwanakomana akachenjera anoteerera kurayira kwababa vake, 
\q2 asi mudadi haateereri kana achitsiurwa. 
\q1  
\v 2 Kubva pazvibereko zvomuromo wake munhu achadya zvinhu zvakanaka, 
\q2 asi vasina kutendeka vanofarira kumanikidza. 
\b  
\q1  
\v 3 Uyo anobata muromo wake anochengeta upenyu hwake, 
\q2 asi uyo anokurumidzira kutaura achaparadzwa. 
\b  
\q1  
\v 4 Simbe inopanga asi igoshayiwa chinhu, 
\q2 asi zvishuvo zvavanoshingaira zvichazadziswa. 
\b  
\q1  
\v 5 Vakarurama vanovenga nhema, 
\q2 asi vakaipa vanouyisa kunyadziswa nokunyangadza. 
\b  
\q1  
\v 6 Kururama kunorinda munhu ane unhu hwakanaka, 
\q2 asi kuipa kunowisira mutadzi pasi. 
\b  
\q1  
\v 7 Mumwe munhu anozviti mupfumi, asi asina chinhu; 
\q2 mumwewo anozviti murombo, asi aine upfumi huzhinji. 
\b  
\q1  
\v 8 Upfumi hwomunhu hunogona kudzikinura upenyu hwake, 
\q2 asi murombo haana chinomutyisidzira. 
\b  
\q1  
\v 9 Chiedza cheakarurama chinopenya kwazvo; 
\q2 asi mwenje woakaipa uchadzimwa. 
\b  
\q1  
\v 10 Kuzvikudza kunongouyisa kukakavara chete, 
\q2 asi uchenjeri hunowanikwa mune avo vanogamuchira kurayirwa. 
\b  
\q1  
\v 11 Mari yakawanikwa zvisakarurama ichakurumidza kupera, 
\q2 asi uyo anounganidza mari zvishoma nezvishoma achaita kuti iwande. 
\b  
\q1  
\v 12 Tariro kana ichinonoka inoodza mwoyo, 
\q2 asi chishuvo chazadziswa muti woupenyu. 
\b  
\q1  
\v 13 Uyo anozvidza kurayirwa achazozviripira izvozvo, 
\q2 asi uyo anokudza murayiro achawana mubayiro. 
\b  
\q1  
\v 14 Kudzidzisa kwowakachenjera itsime roupenyu, 
\q2 rinobvisa munhu pamusungo worufu. 
\b  
\q1  
\v 15 Kunzwisisa kwakanaka kunowanisa nyasha, 
\q2 asi nzira yavasina kutendeka ihukutu. 
\b  
\q1  
\v 16 Munhu wose akachenjera anoita zvinhu noruzivo, 
\q2 asi benzi rinoratidza upenzi hwaro. 
\b  
\q1  
\v 17 Nhume yakaipa inowira munjodzi, 
\q2 asi munyai akatendeka anouya nokuporesa. 
\b  
\q1  
\v 18 Uyo anozvidza kurayirwa achava murombo uye achanyadziswa, 
\q2 asi ani naani anoteerera kurayirwa achakudzwa. 
\b  
\q1  
\v 19 Chishuvo chazadziswa chinozipa pamweya, 
\q2 asi mapenzi anovenga kusiya zvakaipa. 
\b  
\q1  
\v 20 Uyo anofamba navakachenjera achachenjerawo, 
\q2 asi shamwari yamapenzi ichakuvadzwa. 
\b  
\q1  
\v 21 Zvakaipa zvinotevera mutadzi, 
\q2 asi kubudirira ndiwo mugove wavakarurama. 
\b  
\q1  
\v 22 Munhu akanaka anosiyira vana vevana vake nhaka, 
\q2 asi upfumi hwomutadzi hunounganidzirwa vakarurama. 
\b  
\q1  
\v 23 Munda womurombo ungabereka zvokudya zvakawanda, 
\q2 asi kusaruramisira kunozvitsvairira kure. 
\b  
\q1  
\v 24 Anorega kushandisa shamhu anovenga mwanakomana wake, 
\q2 asi uyo anomuda anochenjerera kumuranga. 
\b  
\q1  
\v 25 Vakarurama vanodya zvinogutsa mwoyo yavo, 
\q2 asi dumbu reakaipa richanzwa nzara. 
\c 14  
\q1  
\v 1 Mukadzi akachenjera anovaka imba yake, 
\q2 asi benzi rinoputsa imba yaro namaoko aro. 
\q1  
\v 2 Uyo ano mufambiro wakarurama anotya Jehovha, 
\q2 asi uyo ano mufambiro wakatsauka anomuzvidza. 
\b  
\q1  
\v 3 Kutaura kwebenzi kunouyisa shamhu kumusana kwaro, 
\q2 asi miromo yavakachenjera inovadzivirira. 
\b  
\q1  
\v 4 Kana pasina nzombe, chidyiro hachina chinhu, 
\q2 asi pasimba renzombe ndipo panobva kukohwa kukuru. 
\b  
\q1  
\v 5 Chapupu chechokwadi hachinyengeri, 
\q2 asi chapupu chenhema chinodurura nhema. 
\b  
\q1  
\v 6 Mudadi anotsvaka uchenjeri asi anohushaya, 
\q2 asi ruzivo runouya zviri nyore kune anonzvera. 
\b  
\q1  
\v 7 Gara kure nomunhu benzi, 
\q2 nokuti haungawani ruzivo kubva pamiromo yake. 
\b  
\q1  
\v 8 Uchenjeri hwomunhu akangwara ndiko kunzwisisa nzira dzake, 
\q2 asi upenzi hwamapenzi ndihwo unyengeri. 
\b  
\q1  
\v 9 Mapenzi anoseka kutendeuka pazvivi, 
\q2 asi kuita zvakanaka kunowanikwa pakati pavakarurama. 
\b  
\q1  
\v 10 Mwoyo mumwe nomumwe unoziva kutambudzika kwawo, 
\q2 uye hapana munhu angagoverana nawo mufaro wawo. 
\b  
\q1  
\v 11 Imba yeakaipa ichaparadzwa, 
\q2 asi tende rowakarurama richabudirira. 
\b  
\q1  
\v 12 Kune nzira inoita seyakanaka kumunhu, 
\q2 asi kumagumo inotungamirira kurufu. 
\b  
\q1  
\v 13 Kunyange mukuseka mwoyo unogona kurwadziwa, 
\q2 uye mufaro ungangoperera mukusuwa. 
\b  
\q1  
\v 14 Vasingatendi vachapiwa mubayiro wakazara wenzira dzavo, 
\q2 uye munhu akanaka achapiwa mubayiro wenzira dzakewo. 
\b  
\q1  
\v 15 Munhu asina mano anongotenda zvose zvose, 
\q2 asi munhu akangwara anongwarira mafambiro ake. 
\b  
\q1  
\v 16 Munhu akachenjera anotya Jehovha uye anovenga zvakaipa, 
\q2 asi benzi rina manyawi uye harina hanya. 
\b  
\q1  
\v 17 Munhu anokurumidza kutsamwa anoita zvinhu zvoupenzi, 
\q2 uye munhu anoita zvounyengeri achavengwa. 
\b  
\q1  
\v 18 Vasina mano vachagara nhaka youpenzi, 
\q2 asi vakangwara vachapfekedzwa korona yezivo. 
\b  
\q1  
\v 19 Vanhu vakaipa vachagwadama pamberi pavakanaka, 
\q2 uye vakaipa pamasuo avakarurama. 
\b  
\q1  
\v 20 Varombo vanoraswa kunyange navavakidzani vavo, 
\q2 asi vapfumi vane shamwari zhinji. 
\b  
\q1  
\v 21 Uyo anozvidza muvakidzani wake anotadza, 
\q2 asi akaropafadzwa ane tsitsi kune vanoshayiwa. 
\b  
\q1  
\v 22 Ko, vanoronga zvakaipa havarasiki here? 
\q2 Asi avo vanoronga zvakanaka vanowana rudo nokutendeka. 
\b  
\q1  
\v 23 Kushanda nesimba kwose kunopa mubayiro, 
\q2 asi kungotaura kunotungamirira kuurombo bedzi. 
\b  
\q1  
\v 24 Upfumi hwavakachenjera ikorona yavo, 
\q2 asi upenzi hwamapenzi hunobereka upenzi. 
\b  
\q1  
\v 25 Chapupu chechokwadi chinoponesa upenyu, 
\q2 asi chapupu chenhema chinonyengera. 
\b  
\q1  
\v 26 Uyo anotya Jehovha ane nhare yakasimba, 
\q2 uye ichava utiziro kuvana vake. 
\b  
\q1  
\v 27 Kutya Jehovha ndicho chitubu choupenyu, 
\q2 kunodzora munhu kubva pamisungo yorufu. 
\b  
\q1  
\v 28 Mukuwanda kwavanhu ndimo mune ukuru hwamambo, 
\q2 asi pasina vanhu muchinda anoparadzwa. 
\b  
\q1  
\v 29 Munhu ane mwoyo murefu anonzwisisa, 
\q2 asi munhu anokurumidza kutsamwa anoratidza upenzi. 
\b  
\q1  
\v 30 Mwoyo wakagadzikana unopa upenyu kumuviri, 
\q2 asi ruchiva runoodza mapfupa. 
\b  
\q1  
\v 31 Uyo anomanikidza varombo anoratidza kuti anozvidza Musiki wavo, 
\q2 asi ani naani ane hanya nevanoshayiwa anokudza Mwari. 
\b  
\q1  
\v 32 Kana njodzi yauya, akaipa anowisirwa pasi, 
\q2 asi kunyange murufu akarurama ane utiziro. 
\b  
\q1  
\v 33 Uchenjeri hunogara mumwoyo yavanohunzvera 
\q2 uye kunyange pakati pamapenzi hunozvizivisa. 
\b  
\q1  
\v 34 Kururama kunosimudzira rudzi, 
\q2 asi chivi chinonyadzisa vanhu vapi zvavo. 
\b  
\q1  
\v 35 Mambo anofarira muranda akachenjera, 
\q2 asi muranda anonyadzisa achatsamwirwa naye. 
\c 15  
\q1  
\v 1 Mhinduro nyoro inodzora kutsamwa, 
\q2 asi shoko rinorwadza rinomutsa hasha. 
\q1  
\v 2 Rurimi rwowakachenjera runobudisa zivo, 
\q2 asi muromo webenzi unodurura upenzi. 
\b  
\q1  
\v 3 Meso aJehovha ari pose pose, 
\q2 achicherechedza vakaipa navakanaka. 
\b  
\q1  
\v 4 Rurimi runouyisa kuporesa ndirwo muti woupenyu, 
\q2 asi rurimi runonyengera runopwanya mweya. 
\b  
\q1  
\v 5 Benzi rinoramba kurayira kwababa varo, 
\q2 asi ani naani anogamuchira kurayirwa anoratidza kungwara. 
\b  
\q1  
\v 6 Imba yowakarurama ine pfuma zhinji, 
\q2 asi zvinowanikwa nowakaipa zvinomuunzira kutambudzika. 
\b  
\q1  
\v 7 Miromo yavakachenjera inokusha zivo; 
\q2 asi mwoyo yamapenzi haidaro. 
\b  
\q1  
\v 8 Jehovha anovenga chibayiro chowakaipa, 
\q2 asi munyengetero womunhu akarurama unomufadza. 
\b  
\q1  
\v 9 Jehovha anovenga nzira yeakaipa, 
\q2 asi anoda vaya vanotevera kururama. 
\b  
\q1  
\v 10 Kurangwa kwakaomarara kwakamirira uyo anotsauka kubva panzira; 
\q2 uyo anovenga kudzorwa achafa. 
\b  
\q1  
\v 11 Rufu nokuparadzwa zviri pachena pamberi paJehovha, 
\q2 ko, kuzoti mwoyo yavanhu! 
\b  
\q1  
\v 12 Mudadi anovenga kudzorwa; 
\q2 haangabvunzi vakachenjera. 
\b  
\q1  
\v 13 Mwoyo wakafara, unofadza chiso, 
\q2 asi mwoyo une shungu unopwanya mweya. 
\b  
\q1  
\v 14 Mwoyo unonzvera unotsvaka ruzivo, 
\q2 asi muromo webenzi unodya upenzi. 
\b  
\q1  
\v 15 Mazuva ose omunhu anotambudzika akaipa, 
\q2 asi mwoyo unofara une mutambo nguva dzose. 
\b  
\q1  
\v 16 Zviri nani kuva nezvishoma uchitya Jehovha, 
\q2 pane kuva nepfuma zhinji namatambudziko. 
\b  
\q1  
\v 17 Zviri nani kuva nezvokudya zvomuriwo pane rudo, 
\q2 pane kuva nemhuru yakakodzwa pane ruvengo. 
\b  
\q1  
\v 18 Munhu ane hasha anomutsa bopoto, 
\q2 asi munhu ane mwoyo murefu anonyaradza kukakavara. 
\b  
\q1  
\v 19 Nzira yesimbe yakasoswa neminzwa, 
\q2 asi nzira yavakarurama mugwagwa mukuru. 
\b  
\q1  
\v 20 Mwanakomana akachenjera anounzira baba vake mufaro, 
\q2 asi munhu benzi anozvidza mai vake. 
\b  
\q1  
\v 21 Upenzi hunofadza munhu anoshayiwa njere, 
\q2 asi munhu anonzwisisa anochengetedza nzira yakarurama. 
\b  
\q1  
\v 22 Urongwa hunoparara kana pasina vanopa mazano, 
\q2 asi vanopa mazano vakawanda hunobudirira. 
\b  
\q1  
\v 23 Munhu anowana mufaro mukupa mhinduro yakanaka, 
\q2 uye rakanaka seiko shoko rinouya nenguva! 
\b  
\q1  
\v 24 Nzira youpenyu kumunhu akachenjera inokwidza kumusoro, 
\q2 ichimuchengetedza kuti asaenda muguva. 
\b  
\q1  
\v 25 Jehovha anoparadza imba yomunhu anozvikudza, 
\q2 asi agochengeta miganhu yechirikadzi yakasimba. 
\b  
\q1  
\v 26 Jehovha anovenga pfungwa dzowakaipa, 
\q2 asi dzavakachena dzinomufadza. 
\b  
\q1  
\v 27 Munhu anokara pfuma anouyisa kutambudzika kumhuri yake, 
\q2 asi anovenga fufuro achararama. 
\b  
\q1  
\v 28 Mwoyo wokururama unoyera mhinduro dzawo, 
\q2 asi muromo woakaipa unodurura zvakaipa. 
\b  
\q1  
\v 29 Jehovha ari kure neakaipa, 
\q2 asi anonzwa munyengetero weakarurama. 
\b  
\q1  
\v 30 Chiso chinobwinya chinofadza mwoyo, 
\q2 uye mashoko akanaka anopa utano kumapfupa. 
\b  
\q1  
\v 31 Uyo anoteerera kutsiura 
\q2 kunopa upenyu achagara pakati pavakachenjera. 
\b  
\q1  
\v 32 Uyo asina hanya nokurangwa anozvizvidza iye pachake, 
\q2 asi ani naani anogamuchira kurayira achawana kunzwisisa. 
\b  
\q1  
\v 33 Kutya Jehovha kunodzidzisa munhu uchenjeri, 
\q2 uye kuzvininipisa kunotanga, kukudzwa kwozotevera. 
\c 16  
\q1  
\v 1 Kuronga kwomwoyo ndekwomunhu, 
\q2 asi mhinduro yorurimi inobva kuna Jehovha. 
\q1  
\v 2 Nzira dzose dzomunhu dzinoita sedzakanaka pakuona kwake, 
\q2 asi Jehovha anoyera zvinangwa. 
\b  
\q1  
\v 3 Kumikidza kuna Jehovha chose chaunoita, 
\q2 ipapo urongwa hwako huchabudirira. 
\b  
\q1  
\v 4 Jehovha anoitira zvinhu zvose magumo azvo; 
\q2 kunyange akaipa anomuitira zuva renjodzi. 
\b  
\q1  
\v 5 Jehovha anovenga vose vane mwoyo inozvikudza. 
\q2 Zvirokwazvo, havangaregi kurangwa. 
\b  
\q1  
\v 6 Kubudikidza norudo nokutendeka, chivi chinoyananisirwa, 
\q2 kubudikidza nokutya Jehovha munhu anorega kuita zvakaipa. 
\b  
\q1  
\v 7 Kana nzira dzomunhu dzichifadza Jehovha, 
\q2 anoita kuti kunyange vavengi vake vagarisane naye murugare. 
\b  
\q1  
\v 8 Zviri nani kuva nezvishoma mukururama, 
\q2 pane kuva nezvakawanda kwazvo mukusaruramisira. 
\b  
\q1  
\v 9 Mumwoyo make munhu anoronga gwara rake, 
\q2 asi Jehovha ndiye anotonga kufamba kwake. 
\b  
\q1  
\v 10 Miromo yamambo inotaura seinotaura chirevo chaMwari, 
\q2 uye muromo wake haufaniri kurega kururamisira. 
\b  
\q1  
\v 11 Zviyero nezvienzaniso zvechokwadi zvinobva kuna Jehovha; 
\q2 zviyero zvose zviri muhomwe ndiye akazviita. 
\b  
\q1  
\v 12 Madzimambo anovenga kuita zvakaipa, 
\q2 nokuti chigaro choushe chinosimbiswa nokururama. 
\b  
\q1  
\v 13 Madzimambo anofarira miromo inotaura chokwadi; 
\q2 anoremekedza munhu anotaura chokwadi. 
\b  
\q1  
\v 14 Kutsamwa kwamambo inhume yorufu, 
\q2 asi munhu akachenjera anonyaradza kutsamwa uku. 
\b  
\q1  
\v 15 Kana chiso chamambo chichibwinya, zvinoreva upenyu, 
\q2 nyasha dzake dzakaita segore remvura panguva yomunakamwe. 
\b  
\q1  
\v 16 Zviri nani sei kuwana uchenjeri pane goridhe, 
\q2 kusarudza njere pane sirivha! 
\b  
\q1  
\v 17 Mugwagwa mukuru wavakarurama unonzvenga zvakaipa; 
\q2 uye anochengeta nzira yake anochengeta upenyu hwake. 
\b  
\q1  
\v 18 Kuzvikudza kunotangira kuparadzwa, 
\q2 mweya wamanyawi unotangira kuwa. 
\b  
\q1  
\v 19 Zviri nani kuva nomweya unozvininipisa pakati pavakadzvinyirirwa 
\q2 pane kugoverana zvakapambwa navanozvikudza. 
\b  
\q1  
\v 20 Ani naani anoteerera kurayirwa achabudirira, 
\q2 uye akaropafadzwa uyo anovimba naJehovha. 
\b  
\q1  
\v 21 Vakachenjera pamwoyo vanonzi ndivo vanonzvera, 
\q2 uye mashoko akanaka anokurudzira kurayirwa. 
\b  
\q1  
\v 22 Njere itsime roupenyu kuna avo vanadzo, 
\q2 asi upenzi hunouyisa kurangwa kumapenzi. 
\b  
\q1  
\v 23 Mwoyo womunhu akachenjera unotungamirira muromo wake, 
\q2 uye miromo yake inokurudzira kurayirwa. 
\b  
\q1  
\v 24 Mashoko anofadza akafanana nezinga rouchi, 
\q2 anozipa kumweya, anoporesa mapfupa. 
\b  
\q1  
\v 25 Kune nzira inoita seyakanaka kumunhu, 
\q2 asi magumo ayo inoenda kurufu. 
\b  
\q1  
\v 26 Nzara yomushandi inomushandira; 
\q2 nzara yake inoita kuti arambe achishanda. 
\b  
\q1  
\v 27 Munhu asina maturo anoronga zvakaipa, 
\q2 uye matauriro ake akaita somoto unopisa. 
\b  
\q1  
\v 28 Munhu akatsauka anomutsa kupesana, 
\q2 uye guhwa rinoparadzanisa shamwari dzepedyo. 
\b  
\q1  
\v 29 Munhu anoita nechisimba anonyengera muvakidzani wake, 
\q2 uye anomufambisa napanzira isina kunaka. 
\b  
\q1  
\v 30 Uyo anochonya nameso ake ari kuronga zvakaipa; 
\q2 uyo anoruma miromo yake ari kuda kuita zvakaipa. 
\b  
\q1  
\v 31 Bvudzi rakachena ikorona yakaisvonaka; 
\q2 inowanikwa noupenyu hwakarurama. 
\b  
\q1  
\v 32 Zviri nani kuva munhu ane mwoyo murefu pane kuva murwi, 
\q2 munhu anozvibata pakutsamwa kwake ari nani pane uyo anotapa guta. 
\b  
\q1  
\v 33 Mujenya unokandirwa pamakumbo, 
\q2 asi zvirevo zvose zvinobva kuna Jehovha. 
\c 17  
\q1  
\v 1 Zviri nani kuva nechimedu chakaoma chechingwa uine rugare norunyararo 
\q2 pane imba izere namabiko, ine kupesana. 
\q1  
\v 2 Muranda akachenjera achatonga mwanakomana anonyadzisa, 
\q2 uye achagoverwa nhaka somumwe wehama. 
\b  
\q1  
\v 3 Hari ndeyokunyautsira sirivha uye choto ndechokunatsa goridhe, 
\q2 asi Jehovha ndiye anoedza mwoyo. 
\b  
\q1  
\v 4 Munhu akaipa anoteerera miromo yakaipa; 
\q2 murevi wenhema anorerekera nzeve yake kururimi runoparadza. 
\b  
\q1  
\v 5 Uyo anoseka varombo anozvidza Musiki wavo, 
\q2 ani naani anofarira njodzi dzavamwe haangaregi kurangwa. 
\b  
\q1  
\v 6 Vana vevana ikorona kune vakwegura, 
\q2 uye vabereki ndivo kukudzwa kwavana vavo. 
\b  
\q1  
\v 7 Kutaura kuna manyawi hakuna kufanira benzi, 
\q2 zvikuru sei kutaura nhema kwomubati! 
\b  
\q1  
\v 8 Fufuro inofadza uyo anoipa; 
\q2 kwose kwose kwaanoenda, anobudirira. 
\b  
\q1  
\v 9 Uyo anofukidzira kudarika kwomumwe anotsvaka rudo, 
\q2 asi ani naani anomutsazve mhaka anoparadzanisa shamwari dzepedyo. 
\b  
\q1  
\v 10 Kutsiurwa kunofadza munhu ane njere 
\q2 kupfuura kurohwa kwebenzi kazana. 
\b  
\q1  
\v 11 Munhu akaipa anongotsvaka kumukira chete; 
\q2 nhume isina tsitsi ichatumirwa kundomurwisa. 
\b  
\q1  
\v 12 Zviri nani kusangana nechikara chatorerwa vana vacho 
\q2 pane benzi muupenzi hwaro. 
\b  
\q1  
\v 13 Kana munhu akaripira zvakanaka nezvakaipa 
\q2 zvakaipa hazvizombobvi paimba yake. 
\b  
\q1  
\v 14 Kuvamba kwokukakavara kwakafanana nokudziurira mvura yedhamu; 
\q2 saka rega nharo kurwa kusati kwatanga. 
\b  
\q1  
\v 15 Kupembedza ane mhosva nokupomera asina mhaka, 
\q2 Jehovha anozvivenga zvose. 
\b  
\q1  
\v 16 Ine basa reiko mari kana iri muruoko rwebenzi, 
\q2 sezvo risina chishuvo chokuwana uchenjeri? 
\b  
\q1  
\v 17 Shamwari inoda panguva dzose, 
\q2 uye hama yakaberekerwa kupikisana. 
\b  
\q1  
\v 18 Munhu anoshayiwa njere ndiye anombunda noruoko rwake pamhiko, 
\q2 uye anoitira muvakidzani wake rubatso. 
\b  
\q1  
\v 19 Uyo anoda zvokukakavara anoda chivi; 
\q2 uyo anovaka suo refu anotsvaka kuparadzwa. 
\b  
\q1  
\v 20 Munhu ane mwoyo wakaipa haabudiriri; 
\q2 uyo ane rurimi runonyengera achawira mudambudziko. 
\b  
\q1  
\v 21 Kuva nomwanakomana benzi kunouyisa kurwadziwa; 
\q2 baba vebenzi havana mufaro. 
\b  
\q1  
\v 22 Mwoyo wakafara mushonga wakanaka, 
\q2 asi mweya wakaputsika unoomesa mapfupa. 
\b  
\q1  
\v 23 Munhu akaipa anogamuchira fufuro muchivande, 
\q2 kuti aminamise nzira dzokururamisira. 
\b  
\q1  
\v 24 Munhu ane njere anoisa uchenjeri pamberi, 
\q2 asi meso ebenzi anosvika kumagumo enyika. 
\b  
\q1  
\v 25 Mwanakomana benzi anorwadzisa baba vake, 
\q2 uye anoitisa shungu uyo akamubereka. 
\b  
\q1  
\v 26 Hazvina kunaka kuranga munhu asina mhosva, 
\q2 kana kurova machinda nokuda kwokururama kwavo. 
\b  
\q1  
\v 27 Munhu ano ruzivo anoshandisa mashoko achizvidzora, 
\q2 uye munhu anonzwisisa akadzikama. 
\b  
\q1  
\v 28 Kunyange benzi, kana rakanyarara, rinonzi rakachenjera, 
\q2 uye rikabata muromo waro rinonzi rakangwara. 
\c 18  
\q1  
\v 1 Munhu asina ukama navamwe anongozvitsvakira zvake; 
\q2 anozvidza kutonga kwakanaka kwose. 
\q1  
\v 2 Benzi harifariri kunzwisisa, 
\q2 asi rinofarira kungotaura zvarinofunga chete. 
\b  
\q1  
\v 3 Panosvika chakaipa, kuzvidzwa kunouyawo, 
\q2 uye kana nyadzi dzichisvika kusakudzwa kwasvikawo. 
\b  
\q1  
\v 4 Mashoko omuromo womunhu imvura yakadzika, 
\q2 asi tsime rouchenjeri chitubu chinoyerera. 
\b  
\q1  
\v 5 Hazvina kunaka kutsaura akaipa 
\q2 kana kusaruramisira asina mhosva. 
\b  
\q1  
\v 6 Miromo yebenzi inoriunzira kukakavara, 
\q2 uye muromo wake unomukokera kurohwa. 
\b  
\q1  
\v 7 Muromo webenzi ndiwo kuparadzwa kwaro, 
\q2 uye miromo yaro ndiwo musungo kumweya waro. 
\b  
\q1  
\v 8 Mashoko amakuhwa akaita semisuva yakanakisisa; 
\q2 anoenda pakadzikadzika mukati momunhu. 
\b  
\q1  
\v 9 Uyo ano usimbe pakubata kwake 
\q2 ihama youyo anoparadza. 
\b  
\q1  
\v 10 Zita raJehovha inhare yakasimba; 
\q2 vakarurama vanomhanyira kwariri vagochengetedzwa. 
\b  
\q1  
\v 11 Pfuma yavapfumi ndiro guta ravo rina masvingo; 
\q2 vanoriona sorusvingo rurefu pakufunga kwavo. 
\b  
\q1  
\v 12 Kuparadzwa kusati kwasvika, mwoyo womunhu unozvikudza, 
\q2 asi kuzvininipisa kunotangira kukudzwa. 
\b  
\q1  
\v 13 Uyo anopindura asati anzwa, 
\q2 ndihwo upenzi hwake nokunyadziswa kwake. 
\b  
\q1  
\v 14 Mweya womunhu unomusimbisa panguva yokurwara, 
\q2 asi mweya wakapwanyika ndiani angautakura? 
\b  
\q1  
\v 15 Mwoyo woune njere unowana ruzivo, 
\q2 nzeve dzowakachenjera dzinorutsvaka. 
\b  
\q1  
\v 16 Chipo chinozarurira nzira kune achipa, 
\q2 uye chinomusvitsa pamberi pavakuru. 
\b  
\q1  
\v 17 Anotanga kusvitsa nyaya yake anoita seakanaka, 
\q2 kusvikira mumwe auya mberi kuzomubvunza. 
\b  
\q1  
\v 18 Kukanda mijenya kunopedza gakava, 
\q2 uye kunotonga pakati pavaviri vanopikisana zvikuru. 
\b  
\q1  
\v 19 Hama yatadzirwa yakavangarara kupfuura guta rakakomberedzwa namasvingo, 
\q2 uye kukakavara kwakafanana namazariro amasuo omuzinda wamambo. 
\b  
\q1  
\v 20 Kubva pazvibereko zvomuromo wake dumbu romunhu rinogutiswa; 
\q2 nezvinobva pamiromo yake achagutiswa. 
\b  
\q1  
\v 21 Rurimi rune simba roupenyu norufu, 
\q2 uye vaya vanoruda vachadya chibereko charwo. 
\b  
\q1  
\v 22 Uyo anowana mudzimai anowana chinhu chakanaka, 
\q2 uye anogamuchira nyasha kubva kuna Jehovha. 
\b  
\q1  
\v 23 Murombo anokumbira kuitirwa tsitsi, 
\q2 asi mupfumi anopindura nehasha. 
\b  
\q1  
\v 24 Munhu ane shamwari dzakawanda angangoparadzwa, 
\q2 asi kune shamwari inonamatira kupfuura hama. 
\c 19  
\q1  
\v 1 Zviri nani kuva murombo ane mafambiro akarurama, 
\q2 pane benzi rine muromo wakatsauka. 
\q1  
\v 2 Hazvibatsiri kushingaira usina zivo, 
\q2 kana kukurumidza uchizorasika nzira. 
\b  
\q1  
\v 3 Upenzi hwomunhu hunoparadza upenyu hwake, 
\q2 asi mwoyo wake unotsamwira Jehovha. 
\b  
\q1  
\v 4 Pfuma inouyisa shamwari zhinji, 
\q2 asi murombo anosiyiwa neshamwari dzake. 
\b  
\q1  
\v 5 Chapupu chenhema hachingaregi kurangwa, 
\q2 uye uyo anodurura manyepo haangaregedzwi. 
\b  
\q1  
\v 6 Vazhinji vanotsvaka nyasha kumutongi, 
\q2 uye mumwe nomumwe ishamwari yomunhu anopa zvipo. 
\b  
\q1  
\v 7 Murombo anoraswa nehama dzake dzose, 
\q2 kuzoti shamwari dzake, dzinomunzvenga zvakadii! 
\q1 Kunyange akavatevera achidemba kwazvo 
\q2 havangawanikwi. 
\b  
\q1  
\v 8 Uyo anowana uchenjeri anoda upenyu hwake; 
\q2 uye anochengeta kunzwisisa anobudirira. 
\b  
\q1  
\v 9 Chapupu chenhema hachingaregi kurangwa, 
\q2 uye uyo anodurura manyepo achaparara. 
\b  
\q1  
\v 10 Hazvina kufanira kuti benzi rigarike, 
\q2 ko, zvakanyanya kuipa sei kuti muranda atonge machinda! 
\b  
\q1  
\v 11 Uchenjeri hwomunhu hunomupa mwoyo murefu; 
\q2 kukudzwa kwake ndiko kukanganwira kudarika kwomumwe. 
\b  
\q1  
\v 12 Kutsamwa kwamambo kwakafanana nokuomba kweshumba, 
\q2 asi nyasha dzake dzakaita sedova pauswa. 
\b  
\q1  
\v 13 Mwanakomana benzi ndiko kuparara kwababa vake, 
\q2 uye mukadzi anokakavara akafanana nemvura inoramba ichingodonha. 
\b  
\q1  
\v 14 Dzimba nepfuma inhaka inobva kuvabereki, 
\q2 asi mukadzi akanaka anobva kuna Jehovha. 
\b  
\q1  
\v 15 Usimbe hunouyisa hope dzakadzama, 
\q2 uye munhu asingashandi achafa nenzara. 
\b  
\q1  
\v 16 Uyo anoteerera kurayira anochengetedza upenyu hwake, 
\q2 asi uyo asina hanya nenzira dzake achafa. 
\b  
\q1  
\v 17 Uyo anonzwira varombo tsitsi anopa kuna Jehovha, 
\q2 uye achamupa mubayiro wezvaakaita. 
\b  
\q1  
\v 18 Ranga mwanakomana wako, nokuti mukuranga ndimo mune tariro; 
\q2 usava nechikamu pakuparadzwa kwake. 
\b  
\q1  
\v 19 Munhu ane hasha zvikuru anofanira kuripa mhosva yake; 
\q2 kana ukamununura, unofanira kuzomununurazve. 
\b  
\q1  
\v 20 Teerera zano ugamuchire kurayirwa, 
\q2 uye pakupedzisira uchava wakachenjera. 
\b  
\q1  
\v 21 Mune urongwa huzhinji mumwoyo momunhu, 
\q2 asi kuda kwaJehovha ndiko kunobudirira. 
\b  
\q1  
\v 22 Chinodiwa nomunhu rudo rusingagumi; 
\q2 zviri nani kuva murombo pano kuva murevi wenhema. 
\b  
\q1  
\v 23 Kutya Jehovha kunotungamirira kuupenyu: 
\q2 Ipapo munhu achazorora zvakanaka, asingawirwi nedambudziko. 
\b  
\q1  
\v 24 Simbe inoisa ruoko rwayo mundiro; 
\q2 igotadza kunyange kurwudzosa kumuromo wayo! 
\b  
\q1  
\v 25 Rova museki, ipapo vasina mano vachadzidzawo ungwaru; 
\q2 tsiura munhu ane njere, ipapo achawana zivo. 
\b  
\q1  
\v 26 Uyo anobira baba vake uye achidzinga mai vake 
\q2 mwanakomana anonyadzisa. 
\b  
\q1  
\v 27 Mwanakomana wangu, ukasateerera kurayirwa, 
\q2 uchatsauka kubva pamashoko oruzivo. 
\b  
\q1  
\v 28 Chapupu chakaipa chinoseka kururamisira, 
\q2 uye muromo womunhu akaipa unomedza zvakaipa. 
\p  
\v 29 Kurangwa kwakagadzirirwa vaseki, uye kurohwa misana yamapenzi. 
\c 20  
\q1  
\v 1 Waini museki uye doro mupopoti; 
\q2 ani naani anotsauswa nazvo haana kuchenjera. 
\q1  
\v 2 Kutsamwa kwamambo kwakafanana nokuomba kweshumba; 
\q2 uyo anomutsamwisa anotadzira upenyu hwake. 
\b  
\q1  
\v 3 Munhu achakudzwa kana akagara kure nokukakavara, 
\q2 asi benzi rimwe nerimwe rinokurumidza kupopota. 
\b  
\q1  
\v 4 Simbe hairimi mumwaka wokurima; 
\q2 saka panguva yokukohwa anotsvaka asi hapana chaanowana. 
\b  
\q1  
\v 5 Zvinangwa zvomwoyo womunhu imvura yakadzika, 
\q2 asi munhu akachenjera achaichera. 
\b  
\q1  
\v 6 Vanhu vazhinji vanoti vane rudo rusingagumi, 
\q2 asi munhu akatendeka angawanikwa kupiko? 
\b  
\q1  
\v 7 Munhu akarurama anorarama upenyu hwakanaka; 
\q2 vana vake vanomutevera vakaropafadzwa. 
\b  
\q1  
\v 8 Kana mambo achinge agara pachigaro chake kuti atonge, 
\q2 anopepeta zvakaipa zvose nameso ake. 
\b  
\q1  
\v 9 Ndiani angati, “Ndakachengeta mwoyo wangu wakachena; 
\q2 ndakachena uye handina zvivi”? 
\b  
\q1  
\v 10 Zviereso zvakasiyana nezvipimo zvakasiyana 
\q2 Jehovha anozvivenga zvose. 
\b  
\q1  
\v 11 Kunyange mwana anozivikanwa nezvaanoita, 
\q2 kuti tsika dzake dzakanaka uye kuti dzakarurama here. 
\b  
\q1  
\v 12 Nzeve dzinonzwa nameso anoona, 
\q2 Jehovha ndiye akazviita zvose zviri zviviri. 
\b  
\q1  
\v 13 Usafarira kurara kana kuti uchava murombo; 
\q2 svinudza meso ako ipapo uchava nezvokudya zvakawanda. 
\b  
\q1  
\v 14 “Hazvina kunaka, hazvina kunaka!” ndizvo zvinotaura mutengi; 
\q2 ipapo hoyo oenda achizvirumbidza pamusoro pezvaatenga. 
\b  
\q1  
\v 15 Goridhe riripo, uye matombo anokosha amarubhi azere, 
\q2 asi miromo inotaura zivo ndicho chinhu chinokosha chisipo. 
\b  
\q1  
\v 16 Mutorerei nguo yake, uyo anoitira mutorwa rubatso; 
\q2 itorei sorubatso kana azviitira mukadzi asingazvibati. 
\b  
\q1  
\v 17 Zvokudya zvakawanikwa nokunyengera zvinonaka kumunhu, 
\q2 asi achapedzisira ava nomukanwa mazara jecha. 
\b  
\q1  
\v 18 Ita urongwa nokutsvaga mazano; 
\q2 kana uchironga hondo, tsvaka kutungamirirwa. 
\b  
\q1  
\v 19 Guhwa rinoputsa chivimbo; 
\q2 saka furatira munhu anotaurisa. 
\b  
\q1  
\v 20 Kana munhu akatuka baba vake kana mai vake, 
\q2 mwenje wake uchadzimwa parima guru. 
\b  
\q1  
\v 21 Nhaka yakakurumidza kuwanikwa pakutanga 
\q2 haingaropafadzwi pamagumo ayo. 
\b  
\q1  
\v 22 Usati, “Ndichatsiva zvawanditadzira izvi!” 
\q2 Mirira Jehovha, uye iye achakubatsira. 
\b  
\q1  
\v 23 Jehovha anovenga zviereso zvinosiyana, 
\q2 uye zviero zvinonyengera hazvimufadzi. 
\b  
\q1  
\v 24 Kufamba kwomunhu kunotungamirirwa naJehovha. 
\q2 Zvino munhu anganzwisisa sei nzira yake? 
\b  
\q1  
\v 25 Musungo kumunhu kuti akumikidze chimwe chinhu nokukurumidza 
\q2 uye ozorangarira mhiko dzake pava paya. 
\b  
\q1  
\v 26 Mambo akachenjera anopepeta zvakaipa; 
\q2 anofambisa vhiri rokupura pamusoro pavo. 
\b  
\q1  
\v 27 Mwenje waJehovha unonzvera mweya womunhu; 
\q2 unonzvera zviri mukatikati make. 
\b  
\q1  
\v 28 Rudo nokutendeka zvinochengetedza mambo; 
\q2 kubudikidza norudo chigaro chake chinosimbiswa. 
\b  
\q1  
\v 29 Kukudzwa kwamajaya ndiro simba ravo, 
\q2 bvudzi jena kubwinya kwavakwegura. 
\b  
\q1  
\v 30 Kurohwa nokukuvadzwa zvinobvisa zvakaipa, 
\q2 uye kurohwa neshamhu kunovaka munhu womukati. 
\c 21  
\q1  
\v 1 Mwoyo wamambo uri muruoko rwaJehovha; 
\q2 anouendesa kwaanoda sehova dzemvura. 
\q1  
\v 2 Nzira dzose dzomunhu dzinoita sedzakarurama kwaari, 
\q2 asi Jehovha anoyera mwoyo pachikero. 
\b  
\q1  
\v 3 Kuita zvakarurama nokururamisira 
\q2 zvinonyanya kufadza Jehovha kupfuura chibayiro. 
\b  
\q1  
\v 4 Meso ana manyawi nomwoyo unozvikudza, 
\q2 mwenje woakaipa, ndizvo chivi! 
\b  
\q1  
\v 5 Urongwa hwavanoshingaira hunouyisa zvizhinji, 
\q2 sezvo, zvirokwazvo, kukurumidzisa kuchiuyisa urombo. 
\b  
\q1  
\v 6 Pfuma yakaunganidzwa norurimi 
\q2 runoreva nhema imhute inopupurutswa uye muteyo wakaipisisa. 
\b  
\q1  
\v 7 Kumanikidza kwavakaipa kuchavazvuzvurudzira kure, 
\q2 nokuti vanoramba kuita zvakarurama. 
\b  
\q1  
\v 8 Nzira yeane mhosva yakaminama, 
\q2 asi kufamba kwaasina mhosva kwakarurama. 
\b  
\q1  
\v 9 Zviri nani kugara pakona yedenga remba, 
\q2 pano kugara mumba nomudzimai anokakavara. 
\b  
\q1  
\v 10 Munhu akaipa anoshuvira zvakaipa; 
\q2 muvakidzani wake haawani tsitsi kubva kwaari. 
\b  
\q1  
\v 11 Kana museki akarangwa vasina mano vanowana uchenjeri; 
\q2 kana munhu akachenjera akarayirwa anowana zivo. 
\b  
\q1  
\v 12 Iye Akarurama anocherechedza imba yeakaipa, 
\q2 uye anoisa akaipa kukuparadzwa. 
\b  
\q1  
\v 13 Kana munhu akadzivira nzeve dzake kumurombo, 
\q2 naiyewo achachema uye hapana achamunzwa. 
\b  
\q1  
\v 14 Chipo chinopiwa muchivande chinonyaradza hasha, 
\q2 uye fufuro yakavigwa mujasi inonyaradza kutsamwa kukuru. 
\b  
\q1  
\v 15 Kana kururamisira kwaitwa, kunouyisa mufaro kuna vakarurama, 
\q2 asi kunovhundutsa vaiti vezvakaipa. 
\b  
\q1  
\v 16 Munhu anorasika panzira yokunzwisisa 
\q2 achandozororera muungano yavakafa. 
\b  
\q1  
\v 17 Uyo anofarira mafaro achava murombo; 
\q2 ani naani anofarira waini namafuta haazombopfumi. 
\b  
\q1  
\v 18 Akaipa achava dzikinuro yavakarurama, 
\q2 uye vasina kutendeka vachava dzikinuro yaakatendeka. 
\b  
\q1  
\v 19 Zviri nani kugara mugwenga, 
\q2 pano kugara nomudzimai anokakavara uye ane hasha. 
\b  
\q1  
\v 20 Mumba mowakachenjera mune zvokudya zvakaisvonaka zvakawanda namafuta, 
\q2 asi benzi rinodya zvose zvarinazvo. 
\b  
\q1  
\v 21 Uyo anotevera kururama norudo anowana upenyu, 
\q2 nokubudirira norukudzo. 
\b  
\q1  
\v 22 Munhu akachenjera anorwisa guta ravane simba 
\q2 agoputsa nhare dzaro dzavanovimba nadzo. 
\b  
\q1  
\v 23 Uyo anorinda muromo wake norurimi rwake 
\q2 anozvidzivirira kubva panjodzi. 
\b  
\q1  
\v 24 Munhu anozvikudza uye ana manyawi “Mudadi” ndiro zita rake; 
\q2 anoita zvinhu namanyawi uye nokuzvikudza. 
\b  
\q1  
\v 25 Kushuva kwesimbe kunova rufu rwake, 
\q2 nokuti maoko ake anoramba kushanda. 
\b  
\q1  
\v 26 Muswere wose wezuva anoramba achida zvimwe, 
\q2 asi akarurama anopa asinganyimi. 
\b  
\q1  
\v 27 Chibayiro chowakaipa chinonyangadza, 
\q2 zvikuru sei kana akauya nacho nomufungo wakaipa! 
\b  
\q1  
\v 28 Chapupu chenhema chichaparara, 
\q2 uye ani naani anoteerera kwaari achaparadzwa nokusingaperi. 
\b  
\q1  
\v 29 Munhu akaipa ane chiso chisinganyari, 
\q2 asi munhu akarurama anofunga pamusoro penzira dzake. 
\b  
\q1  
\v 30 Hapana uchenjeri kana njere kana urongwa 
\q2 hungabudirira huchipikisana naJehovha. 
\b  
\q1  
\v 31 Bhiza rinogadzirirwa zuva rokurwa, 
\q2 asi kukunda kunobva kuna Jehovha. 
\c 22  
\q1  
\v 1 Zita rakanaka rinodiwa kwazvo kupfuura pfuma zhinji; 
\q2 kuremekedzwa kuri nani pane sirivha kana goridhe. 
\q1  
\v 2 Vapfumi navarombo vakafanana pachinhu ichi: 
\q2 Jehovha ndiye Musiki wavo vose. 
\b  
\q1  
\v 3 Munhu akangwara anoona njodzi agohwanda, 
\q2 asi asina mano anoramba achienda uye agotambudzika nokuda kwaizvozvo. 
\b  
\q1  
\v 4 Kuzvininipisa nokutya Jehovha 
\q2 kunouyisa pfuma nokukudzwa uye noupenyu. 
\b  
\q1  
\v 5 Munzira yeakaipa mune minzwa nemisungo, 
\q2 asi uyo anochengeta mweya wake anogara kure nazvo. 
\b  
\q1  
\v 6 Rovedza mwana munzira yaanofanira kufamba nayo, 
\q2 uye kana achinge akura haazotsauki kubva pairi. 
\b  
\q1  
\v 7 Mupfumi anobata ushe pamusoro pomurombo, 
\q2 uye anokwereta anova muranda weanokweretesa. 
\b  
\q1  
\v 8 Uyo anodyara kuipa anokohwa dambudziko, 
\q2 uye tsvimbo yokutsamwa kwake ichaparadzwa. 
\b  
\q1  
\v 9 Munhu anopa zvakawanda acharopafadzwa, 
\q2 nokuti anopa varombo zvokudya zvake. 
\b  
\q1  
\v 10 Dzinga museki, kukakavara kunobva kwaendawo; 
\q2 kupopotedzana nokutukana kunoguma. 
\b  
\q1  
\v 11 Uyo anoda mwoyo wakachena uye anotaura zvakanaka, 
\q2 achava shamwari yamambo. 
\b  
\q1  
\v 12 Meso aJehovha anorinda zivo, 
\q2 asi anokonesa mashoko omunhu asina kutendeka. 
\b  
\q1  
\v 13 Simbe inoti, “Panze pane shumba,” 
\q2 kana kuti, “Ndinourayiwa munzira!” 
\b  
\q1  
\v 14 Muromo womukadzi chifeve igomba rakadzika; 
\q2 uyo ari pasi pokutsamwa kwaJehovha achawira mariri. 
\b  
\q1  
\v 15 Upenzi hwakasungirirwa mumwoyo momwana, 
\q2 asi shamhu yokuranga ichahudzingira kure naye. 
\b  
\q1  
\v 16 Uyo anomanikidza varombo kuti awedzere pfuma yake 
\q2 nouyo anopa zvipo kuvapfumi, vose vachava varombo. 
\s1 Mashoko oMuchenjeri 
\q1  
\v 17 Nyatsoteerera unzwe mashoko omuchenjeri; 
\q2 isa mwoyo wako kumashoko andinokudzidzisa, 
\q1  
\v 18 nokuti chinhu chinofadza kana ukaachengeta mumwoyo mako, 
\q2 uye ugare wakagadzirira kuataura ose. 
\q1  
\v 19 Kuti uvimbe naJehovha, 
\q2 ndinokudzidzisa nhasi, kunyange iyewe. 
\q1  
\v 20 Handina kukunyorera zvirevo makumi matatu here, 
\q2 mashoko edzidziso noruzivo, 
\q1  
\v 21 kukudzidzisa mashoko echokwadi anovimbika, 
\q2 kuitira kuti ugopa mhinduro dzakafanira kuno 
\q2 uyo akakutuma? 
\b  
\q1  
\v 22 Usatorera varombo nokuti varombo, 
\q2 uye usamanikidza vanoshayiwa mudare redzimhosva, 
\q1  
\v 23 nokuti Jehovha achavarwira pamhaka yavo, 
\q2 uye achapamba vanovapamba. 
\b  
\q1  
\v 24 Usaita ushamwari nomunhu ane hasha, 
\q2 uye usafambidzana nomunhu anokurumidza kutsamwa, 
\q1  
\v 25 kuti urege kudzidza tsika dzake, 
\q2 uye urege kuzviteya nomusungo. 
\b  
\q1  
\v 26 Usava munhu anombunda ruoko pamhiko, 
\q2 kana kuzviita rubatso pazvikwereti; 
\q1  
\v 27 kana usina chaungaripa nacho, 
\q2 uchatorerwa mubhedha wako chaiwo, paurere chaipo. 
\b  
\q1  
\v 28 Usabvisa dombo romuganhu wakare, 
\q2 wakaiswapo namadzibaba ako. 
\b  
\q1  
\v 29 Unoona munhu ane unyanzvi pabasa rake here? 
\q2 Achashanda pamberi pamadzimambo; 
\q2 haangashandiri vanhu vasina maturo. 
\c 23  
\q1  
\v 1 Kana ukagara pakudya pamwe chete nomubati, 
\q2 nyatsocherechedza zviri pamberi pako, 
\q1  
\v 2 uise banga pahuro 
\q2 kana uri munhu wamadyo. 
\q1  
\v 3 Usapanga zvokudya zvake zvinonaka 
\q2 nokuti zvokudya izvozvo zvinonyengera. 
\q1  
\v 4 Usazvionza nokuda kuwana pfuma; 
\q2 iva nouchenjeri hunoita kuti uzvibate. 
\q1  
\v 5 Kungoti tarisei papfuma, wanei yaenda, 
\q2 nokuti zvirokwazvo inomera mapapiro 
\q2 igobhururuka ichienda kudenga segondo. 
\b  
\q1  
\v 6 Usadya zvokudya zvomunhu anonyima, 
\q2 kana kupanga zvokudya zvake zvinonaka; 
\q1  
\v 7 nokuti munhu uya anongofunga chete mutengo wazvo. 
\q2 Anoti kwauri, “Idya ugonwa,” asi mumwoyo make asingadi. 
\q1  
\v 8 Ucharutsa zvishoma izvozvo zvawadya, 
\q2 uye unenge watambisa mashoko ako nokumutenda. 
\b  
\q1  
\v 9 Usataura nebenzi, 
\q2 nokuti richashora uchenjeri hwamashoko ako. 
\b  
\q1  
\v 10 Usabvisa dombo romuganhu wakare 
\q2 kana kupinda paminda yenherera, 
\q1  
\v 11 nokuti Mudziviriri wavo ane simba; 
\q2 iye achavarwira pamhaka yavo newe. 
\b  
\q1  
\v 12 Isa mwoyo wako kumurayiro 
\q2 nenzeve dzako kumashoko ezivo. 
\b  
\q1  
\v 13 Usarega kuranga mwana; 
\q2 ukamuranga neshamhu, haafi. 
\q1  
\v 14 Murange neshamhu 
\q2 ugoponesa mweya wake kubva parufu. 
\b  
\q1  
\v 15 Mwanakomana wangu, kana mwoyo wako wakachenjera, 
\q2 ipapo mwoyo wangu uchafara; 
\q1  
\v 16 mukatikati mangu muchapembera 
\q2 kana miromo yako ichitaura zvakarurama. 
\b  
\q1  
\v 17 Usarega mwoyo wako uchichiva vatadzi, 
\q2 asi nguva dzose shingairira kutya Jehovha. 
\q1  
\v 18 Zvirokwazvo ramangwana rako rine tariro, 
\q2 uye tariro yako haingaparadzwi. 
\b  
\q1  
\v 19 Teerera, mwanakomana wangu, ugova nouchenjeri, 
\q2 uye uchengete mwoyo wako panzira yakarurama. 
\q1  
\v 20 Usabatana navaya vanonwa waini zhinji, 
\q2 kunyange vaya vanokara nyama, 
\q1  
\v 21 nokuti zvidhakwa nevane madyo vachava varombo, 
\q2 uye hope dzichavapfekedza mamvemve. 
\b  
\q1  
\v 22 Teerera kuna baba vako, ivo vakakubereka, 
\q2 uye usazvidza mai vako kana vachinge vakwegura. 
\q1  
\v 23 Tenga zvokwadi urege kuzoitengesa; 
\q2 uwane uchenjeri, kuzvibata nokunzwisisa. 
\q1  
\v 24 Baba vomunhu akarurama vane mufaro mukuru; 
\q2 uyo ane mwanakomana akachenjera anofadzwa naye. 
\q1  
\v 25 Baba vako namai vako ngavafare; 
\q2 mai vakakubereka ngavafare kwazvo! 
\b  
\q1  
\v 26 Mwanakomana wangu, ndipe mwoyo wako 
\q2 uye meso ako ngaananʼanidze nzira dzangu, 
\q1  
\v 27 nokuti chifeve igomba rakadzika, 
\q2 uye mukadzi asingazvibati itsime rakamanikana. 
\q1  
\v 28 Segororo anohwandira, 
\q2 anowedzera vasina kutendeka pakati pavarume. 
\b  
\q1  
\v 29 Ndiani ane nhamo? Ndiani akasuwa? 
\q2 Ndiani anokakavara? Ndiani anonyunyuta? 
\q1 Ndiani ane mavanga pasina mhaka? Ndiani ane meso akatsvuka? 
\q1  
\v 30 Vaya vanogara pawaini, 
\q2 vanoenda kundoravira makate ewaini yakavhenganiswa. 
\q1  
\v 31 Usatarisa waini kana yatsvuka, 
\q2 kana ichivaima iri mumukombe, 
\q2 kana ichidzika zvakanaka pakunwa! 
\q1  
\v 32 Pakupedzisira inoruma senyoka 
\q2 uye ine uturu semvumbi. 
\q1  
\v 33 Meso ako achaona zvisakamboonekwa 
\q2 uye pfungwa dzako dzichafunga zvakapesana. 
\q1  
\v 34 Uchava souya akarara pamusoro pamafungu amakungwa, 
\q2 kana somunhu avete pamusoro pedanda rechikepe. 
\q1  
\v 35 Uchati, “Vakandirova, asi handina kukuvara! 
\q2 Vakandirova asi handina kuzvinzwa! 
\q1 Ndichamuka rinhiko 
\q2 kuti ndigotsvakazve waini?” 
\c 24  
\q1  
\v 1 Usachiva vanhu vakaipa, 
\q2 usashuva kufamba navo; 
\q1  
\v 2 nokuti mwoyo yavo inoronga kuita nechisimba, 
\q2 uye miromo yavo inotaura pamusoro pokuita mhirizhonga. 
\q1  
\v 3 Nouchenjeri imba inovakwa, 
\q2 uye kubudikidza nokunzwisisa inosimbiswa; 
\q1  
\v 4 kubudikidza nezivo makamuri ayo anozadzwa nezvinhu 
\q2 zvinoshamisa uye nepfuma yakaisvonaka inokosha. 
\b  
\q1  
\v 5 Munhu akachenjera ane simba guru, 
\q2 uye munhu ane zivo anowedzera simba; 
\q1  
\v 6 nokuti kundorwa hondo kunoda kutungamirirwa, 
\q2 uye kuti ukunde unoda vapi vamazano vazhinji. 
\b  
\q1  
\v 7 Uchenjeri hahusvikirwi nebenzi; 
\q2 padare repasuo reguta harina chokutaura. 
\b  
\q1  
\v 8 Uyo anoronga kuita zvakaipa 
\q2 achazivikanwa senhubu. 
\q1  
\v 9 Mufungo woupenzi chivi, 
\q2 uye vanhu vanonyangadzwa nomuseki. 
\b  
\q1  
\v 10 Kana ukapera simba panguva dzokutambudzika, 
\q2 simba rako ishoma sei! 
\b  
\q1  
\v 11 Nunurai avo vari kuiswa kurufu; 
\q2 dzosai avo vari kudzedzereka vachienda kundourayiwa. 
\q1  
\v 12 Asi kana mukati, “Hapana zvataiziva pamusoro paizvozvi?” 
\q2 Ko, iye anoyera mwoyo haangazvioni here? 
\q1 Iye anorinda upenyu hwako haangazvizivi here? 
\q2 Haangaripire munhu mumwe nomumwe maererano nezvaakaita here? 
\b  
\q1  
\v 13 Idya uchi, mwanakomana wangu, nokuti hwakanaka; 
\q2 uchi hunobva pazinga hunozipa parurimi. 
\q1  
\v 14 Uzivewo zvakare kuti uchenjeri hunozipa kumweya wako; 
\q2 kana wahuwana, ramangwana rako rine tariro, 
\q2 uye tariro yako haingaparari. 
\b  
\q1  
\v 15 Usavandira sezvinoita akaipa paimba yomunhu akarurama, 
\q2 usaparadza paanogara; 
\q1  
\v 16 nokuti kunyange munhu akarurama achiwa runomwe, anosimukazve, 
\q2 asi akaipa anowisirwa pasi nenjodzi. 
\b  
\q1  
\v 17 Usafara kana muvengi wako achiwa; 
\q2 paanogumburwa, mwoyo wako ngaurege kufara, 
\q1  
\v 18 kana kuti Jehovha achazviona akasafara nazvo 
\q2 uye agobvisa kutsamwa kwake kwaari. 
\b  
\q1  
\v 19 Usashungurudzika nokuda kwavanhu vakaipa, 
\q2 kana kuchiva vakaipa, 
\q1  
\v 20 nokuti vanhu vakaipa havana tariro yeramagwana, 
\q2 uye mwenje wavakaipa uchadzimwa. 
\b  
\q1  
\v 21 Itya Jehovha namambo, mwanakomana wangu, 
\q2 usabatana navanopanduka, 
\q1  
\v 22 nokuti vaviri ivavo vanouyisa kuparadzwa kwavari nokukurumidza, 
\q2 uye ndiani anoziva njodzi dzavangauyisa? 
\s1 Zvimwe Zvirevo zvoMuchenjeri 
\p  
\v 23 Izviwo zvirevo zvomuchenjeri: 
\q1 Kuita rusaruro mukutonga hakuna kunaka: 
\q1  
\v 24 Ani naani anoti kune ane mhosva, “Hauna mhosva,” 
\q2 marudzi achamutuka uye ndudzi dzichamushora. 
\q1  
\v 25 Asi zvichanakira vaya vanopa mhosva kune vane mhosva, 
\q2 uye kuropafadzwa kukuru kuchauya pamusoro pavo. 
\b  
\q1  
\v 26 Mhinduro yechokwadi 
\q2 yakafanana nokutsvoda pamiromo. 
\b  
\q1  
\v 27 Pedza basa rako rapanze 
\q2 ugadzirire minda yako; 
\q2 shure kwaizvozvo, uvake imba yako. 
\b  
\q1  
\v 28 Usava chapupu chinopomera muvakidzani wako pasina mhaka, 
\q2 kana kushandisa miromo yako kuti unyengere. 
\q1  
\v 29 Usati, “Ndichamuitirawo zvaakandiitira; 
\q2 ndicharipira munhu uya zvaakaita.” 
\b  
\q1  
\v 30 Ndakapfuura napamunda wesimbe, 
\q2 ndikapfuura napamunda womuzambiringa womunhu asina njere; 
\q1  
\v 31 minzwa yakanga yamera pose pose, 
\q2 munda wakanga wafukidzwa nesora, 
\q2 uye rusvingo rwamabwe rwakanga rwakoromoka. 
\q1  
\v 32 Ndakafungisisa zvandakanga ndacherechedza 
\q2 ndikadzidza chidzidzo pane zvandakanga ndaona. 
\q1  
\v 33 Kumbovata zvishomanana, kumbotsumwaira, 
\q2 kumbofungatira maoko kuti ndizorore, 
\q1  
\v 34 ipapo urombo huchauya pauri segororo 
\q2 uye kushayiwa kuchauya somunhu akashonga nhumbi dzokurwa nadzo. 
\c 25  
\s1 Zvimwe Zvirevo zvaSoromoni 
\p  
\v 1 Izvi ndizvo zvimwe zvirevo zvaSoromoni, zvakanyorwa namachinda aHezekia mambo weJudha: 
\q1  
\v 2 Kukudzwa kwaMwari kuviga chinhu; 
\q2 kunzvera nyaya ndiko kukudzwa kwamadzimambo. 
\b  
\q1  
\v 3 Sokukwirira kwakaita denga nokudzika kwakaita nyika, 
\q2 saizvozvowo mwoyo yamadzimambo haigoni kunzverwa. 
\b  
\q1  
\v 4 Bvisa marara pasirivha, 
\q2 panobva pabuda zvinoshandiswa nomuumbi wemidziyo yesirivha; 
\q1  
\v 5 bvisa akaipa pamberi pamambo, 
\q2 ipapo chigaro chake choushe chichasimbiswa kubudikidza nokururama. 
\b  
\q1  
\v 6 Usazvikudza pamberi pamambo, 
\q2 uye usazvipa chigaro pakati pavanhu vakuru; 
\q1  
\v 7 Zviri nani kuti ati kwauri, “Kwira pano,” pano kuti akunyadzise pamberi pavanhu vanoremekedzwa. 
\b  
\q1  
\v 8 Zvawakaona nameso ako 
\q2 usakurumidze kuzvikwidza kumatare edzimhosva, 
\q1 nokuti uchazoiteiko pamagumo, 
\q2 kana muvakidzani wako akakunyadzisa? 
\b  
\q1  
\v 9 Kana uchipikisana nomuvakidzani wako, 
\q2 usarase chivimbo chomumwe munhu, 
\q1  
\v 10 kana kuti uyo achazvinzwa angangokunyadzisa, uye uchazoramba uine chimiro chakaipa. 
\b  
\q1  
\v 11 Shoko rataurwa nenguva yakafanira 
\q2 rakafanana namaapuro egoridhe mumidziyo yesirivha. 
\b  
\q1  
\v 12 Semhete yomunzeve yegoridhe kana chishongo chegoridhe rakaisvonaka, 
\q2 ndizvo zvakaita kutsiura kwomunhu akachenjera, kunzeve inoteerera. 
\b  
\q1  
\v 13 Nhume yakatendeka kune anoituma 
\q2 yakafanana nokutonhorera kwechando panguva yokukohwa; 
\q2 inonyevenutsa mweya yavanatenzi vake. 
\b  
\q1  
\v 14 Samakore nemhepo zvisina mvura, 
\q2 ndizvo zvakaita munhu anozvirumbidza pamusoro pezvipo zvaasingapi. 
\b  
\q1  
\v 15 Kubudikidza nomwoyo murefu mutongi anogona kunyengetedzwa, 
\q2 uye rurimi runyoro runogona kuvhuna mapfupa. 
\b  
\q1  
\v 16 Kana wawana uchi, idya hunokuringana chete, hukawandisa, ucharutsa. 
\q1  
\v 17 Usanyanyoenda pamba pomuvakidzani wako, 
\q2 ukanyanya kuendapo, achakuvenga. 
\b  
\q1  
\v 18 Setsvimbo kana munondo kana museve unopinza, 
\q2 ndizvo zvakaita munhu anopa uchapupu hwenhema achipikisa muvakidzani wake. 
\b  
\q1  
\v 19 Sezino rakaora kana tsoka yakaremara, 
\q2 ndizvo zvakafanana nokuvimba nomunhu asina kutendeka panguva yokutambudzika. 
\b  
\q1  
\v 20 Souya anokurura nguo musi unotonhora, 
\q2 kana sevhiniga inodururwa pasoda, 
\q2 ndizvo zvinoita uyo anoimbira nziyo kumwoyo wakaremerwa. 
\b  
\q1  
\v 21 Kana muvengi wako ane nzara, mupe zvokudya adye; 
\q2 kana aine nyota, mupe mvura anwe. 
\q1  
\v 22 Mukuita izvi, uchaunganidzira mazimbe anopisa pamusoro wake, 
\q2 uye Jehovha achakupa mubayiro. 
\b  
\q1  
\v 23 Semhepo yokumusoro inouyisa mvura, 
\q2 naizvozvo rurimi rwakaipa runouyisa zviso zvakashatirwa. 
\b  
\q1  
\v 24 Zviri nani kugara pakona redenga reimba 
\q2 pano kugara mumba nomudzimai anokakavara. 
\b  
\q1  
\v 25 Semvura inotonhorera kumweya wakaneta 
\q2 ndizvo zvakaita nhau dzakanaka dzinobva kunyika iri kure. 
\b  
\q1  
\v 26 Sechitubu chizere madhaka kana tsime rasvibiswa, 
\q2 ndizvo zvakaita munhu akarurama anopa mukana kumunhu akaipa. 
\b  
\q1  
\v 27 Hazvina kunaka kudya uchi huzhinji, 
\q2 kana kuti munhu azvitsvakire kukudzwa kwake iye. 
\b  
\q1  
\v 28 Seguta rakakoromoka masvingo 
\q2 ndizvo zvakaita munhu asingagoni kuzvibata. 
\c 26  
\q1  
\v 1 Sechando muzhizha kana mvura pakukohwa, 
\q2 rukudzo haruna kufanira kubenzi. 
\q1  
\v 2 Sezvinoita kadhimba pakubhururuka kwako, kana nyenganyenga pakubhururuka kwayo somuseve, 
\q2 saizvozvowo kutuka pasina mhosva hakuna zvakunoita. 
\b  
\q1  
\v 3 Tyava yakaitirwa bhiza, matomu akaitirwa mbongoro, 
\q2 uye shamhu musana webenzi! 
\b  
\q1  
\v 4 Usapindura benzi maererano noupenzi hwaro, 
\q2 kana kuti iwe pachako uchafanana naro. 
\b  
\q1  
\v 5 Pindura benzi maererano noupenzi hwaro, 
\q2 kuti rirege kuona sokuti rakachenjera. 
\b  
\q1  
\v 6 Sokuzvigura tsoka kana kunwa bongozozo, 
\q2 ndizvo zvakaita kutumira shoko noruoko rwebenzi. 
\b  
\q1  
\v 7 Samakumbo echirema akangorembera ndizvo 
\q2 zvakaita chirevo mumuromo webenzi. 
\b  
\q1  
\v 8 Sokusungira ibwe pachipfuramabwe 
\q2 ndizvo zvakaita kupa rukudzo kubenzi. 
\b  
\q1  
\v 9 Segwenzi reminzwa riri muruoko rwechidhakwa, 
\q2 ndizvo zvakaita chirevo chiri mumuromo webenzi. 
\b  
\q1  
\v 10 Somuwemburi weuta anopfura pose pose, 
\q2 ndizvo zvakaita anoshandirwa nebenzi kana nomupfuuri zvake. 
\b  
\q1  
\v 11 Sembwa inodzokera kumarutsi ayo, 
\q2 ndizvo zvakaita benzi rinodzokorora upenzi hwaro. 
\b  
\q1  
\v 12 Unoona munhu anozviti akachenjera pakuona kwake here? 
\q2 Benzi rinotova netariro kupfuura iye. 
\b  
\q1  
\v 13 Simbe inoti, “Kune shumba kunzira, 
\q2 shumba inotyisa iri kufamba-famba munzira dzomumusha!” 
\b  
\q1  
\v 14 Segonhi rinotenderera pamahinji aro, 
\q2 ndizvo zvinoita simbe pamubhedha wayo. 
\b  
\q1  
\v 15 Simbe inoisa ruoko rwayo mundiro; 
\q2 inoita usimbe hwokutadza kurudzosera kumuromo wayo. 
\b  
\q1  
\v 16 Simbe inozviti yakachenjera pakuona kwayo 
\q2 kupfuura vanhu vanomwe vanopindura nenjere. 
\b  
\q1  
\v 17 Somunhu anobata imbwa nenzeve dzayo, 
\q2 ndizvo zvakaita mupfuuri anopindira pagakava risinei naye. 
\b  
\q1  
\v 18 Somupengo unopotsera zvitsiga zvomoto, 
\q2 kana miseve inouraya, 
\q1  
\v 19 ndizvo zvakaita munhu anonyengera muvakidzani wake 
\q2 uye achizoti, “Ndanga ndichiita zvangu je-e!” 
\b  
\q1  
\v 20 Pasina huni moto unodzima; 
\q2 pasina makuhwa kukakavara kunopera. 
\b  
\q1  
\v 21 Sezvakaita mazimbe pazvitsiga zvinopfuta nehuni pamoto, 
\q2 ndizvo zvakaita munhu wegakava pakupfutidza rukave. 
\b  
\q1  
\v 22 Mashoko eguhwa akaita semisuva 
\q2 yakaisvonaka inodzika mukatikati momunhu. 
\b  
\q1  
\v 23 Sezvinopenya zvakanamirwa kunze kwomudziyo wevhu, 
\q2 ndizvo zvakaita miromo inotaura zvinoyevedza, asi nomwoyo wakaipa. 
\b  
\q1  
\v 24 Muparadzi anozvivanza namatauriro ake, 
\q2 asi mumwoyo make akaviga ruvengo. 
\q1  
\v 25 Kunyange mashoko ake achitapira, usatenda zvaanotaura, 
\q2 nokuti mumwoyo make mune zvinonyangadza zvinomwe. 
\q1  
\v 26 Ruvengo rwake rungavigwa mukunyengera kwake, 
\q2 asi kuipa kwake kuchabudiswa pachena paungano. 
\b  
\q1  
\v 27 Kana munhu akachera gomba, achawira mariri; 
\q2 kana munhu akakungurutsa ibwe, richakunguruka, richidzokera pamusoro pake. 
\b  
\q1  
\v 28 Rurimi runoreva nhema runovenga varunorwadzisa, 
\q2 uye muromo unobata kumeso unoparadza. 
\c 27  
\q1  
\v 1 Usazvirumbidza pamusoro pezuva ramangwana, 
\q2 nokuti hauzivi zvingauyiswa nezuva. 
\q1  
\v 2 Rega mumwe akurumbidze, kwete muromo wako; 
\q2 mumwe munhuwo zvake, kwete miromo yako iwe. 
\b  
\q1  
\v 3 Ibwe rinorema uye jecha mutoro, 
\q2 asi kudenhwa nebenzi kunorema kupfuura zvose. 
\b  
\q1  
\v 4 Hasha dzine utsinye uye kutsamwa kunokurira, 
\q2 asi ndiani angamira pamberi pomunhu ane godo? 
\b  
\q1  
\v 5 Kutsiurwa pachena kuri nani 
\q2 pane rudo rwakavanzika. 
\b  
\q1  
\v 6 Maronda okukuvadzwa neshamwari anogamuchirika, 
\q2 asi kutsvoda kwomuvengi kunonyengera. 
\b  
\q1  
\v 7 Uyo akaguta anovenga uchi, 
\q2 asi kune ane nzara kunyange zvinovava zvinozipa. 
\b  
\q1  
\v 8 Seshiri inorasika kubva padendere rayo, 
\q2 ndizvo zvakaita munhu anorasika kubva pamusha wake. 
\b  
\q1  
\v 9 Mafuta nezvinonhuhwira zvinouyisa mufaro kumwoyo, 
\q2 uye kunaka kwoushamwari kunobva padzidziso dzake dzakanaka. 
\b  
\q1  
\v 10 Usarasa shamwari yako kana shamwari yababa vako, 
\q2 uye usangoenda kumba yehama yako kana wawirwa nedambudziko chete, 
\q2 muvakidzani ari pedyo ari nani kupfuura hama iri kure. 
\b  
\q1  
\v 11 Iva wakachenjera, mwanakomana wangu, ugofadza mwoyo wangu; 
\q2 ipapo ndichagona kupindura ani naani anondishora. 
\b  
\q1  
\v 12 Munhu akangwara anoona njodzi agovanda, 
\q2 asi asina mano anoramba achienda uye agokuvadzwa nayo. 
\b  
\q1  
\v 13 Torera nguo uyo anozviita rubatso kumutorwa; 
\q2 uitore semhiko kana achinge aiita rubatso kumukadzi asingazvibati. 
\b  
\q1  
\v 14 Kana munhu akafumira rungwanangwana 
\q2 kukwazisa muvakidzani wake achidaidzirisa zvichaonekwa sechituko. 
\b  
\q1  
\v 15 Mudzimai anokakavara akafanana 
\q2 nemvura inoramba ichidonha-donha mushure mokunge kwanaya; 
\q1  
\v 16 kumudzivisa zvakafanana nokudzivisa mhepo, 
\q2 kana kuchingidzira mafuta noruoko. 
\b  
\q1  
\v 17 Simbi inorodza simbi, 
\q2 saizvozvowo mumwe munhu anorodza mumwe. 
\b  
\q1  
\v 18 Uyo anochengeta muonde achadya zvibereko zvawo, 
\q2 uye uyo anochengeta tenzi wake achakudzwa. 
\b  
\q1  
\v 19 Sezvo mvura ichiratidza chiso, 
\q2 saizvozvowo mwoyo womunhu unoratidza munhu. 
\b  
\q1  
\v 20 Rufu nokuparadza hazvimboguti, 
\q2 kunyangewo maziso omunhu haaguti. 
\b  
\q1  
\v 21 Hari ndeyokunyautsira sirivha uye choto ndechokunatsa goridhe, 
\q2 asi munhu anoedzwa nerumbidzo yaanowana. 
\b  
\q1  
\v 22 Kunyange ukatswa benzi muduri, 
\q2 kumutswa sezviyo nomutswi, 
\q2 haungabvisi upenzi hwake maari. 
\q1  
\v 23 Iva nechokwadi kuti unoziva mamiriro amakwai ako, 
\q2 uchengete zvakanaka mapoka ako; 
\q1  
\v 24 nokuti pfuma haigari nokusingaperi, 
\q2 uye korona haigari kusvikira kuzvizvarwa zvose. 
\q1  
\v 25 Kana uswa hukabviswa, uye bumhudza rikabuda, 
\q2 nesora rikaunganidzwa kubva kuzvikomo, 
\q1  
\v 26 makwayana achakuwanisa zvokupfeka, 
\q2 uye mbudzi nomutengo womunda. 
\q1  
\v 27 Uchava nomukaka wembudzi 
\q2 wakawanda wokudya iwe nemhuri yako, 
\q2 uye wokuraramisa varandakadzi vako. 
\c 28  
\q1  
\v 1 Munhu akaipa anotiza kusina anomudzinganisa, 
\q2 asi vakarurama vakashinga seshumba. 
\q1  
\v 2 Kana nyika ikapanduka, inova navatungamiri vakawanda, 
\q2 asi munhu anonzwisisa uye ane ruzivo anochengetedza runyararo. 
\b  
\q1  
\v 3 Mutongi anomanikidza varombo 
\q2 akaita semvura inokukura ichisiya pasina zvirimwa. 
\b  
\q1  
\v 4 Avo vanorasa murayiro vanorumbidza vakaipa, 
\q2 asi avo vanochengeta murayiro vanovapikisa. 
\b  
\q1  
\v 5 Vanhu vakaipa havanzwisisi kururamisira, 
\q2 asi avo vanotsvaka Jehovha vanozvinzwisisa kwazvo. 
\b  
\q1  
\v 6 Zviri nani kuva murombo ane mafambiro akarurama 
\q2 pane mupfumi ane nzira dzakatsauka. 
\b  
\q1  
\v 7 Uyo anochengeta murayiro mwanakomana akachenjera, 
\q2 asi anofambidzana navanhu vane madyo anonyadzisa baba vake. 
\b  
\q1  
\v 8 Uyo anowedzera pfuma yake nokutengesa nomutengo uri pamusoro-soro, 
\q2 anozviunganidzira mumwe, uyo anozonzwira varombo tsitsi. 
\b  
\q1  
\v 9 Kana munhu akaramba kunzwa murayiro nenzeve dzake, 
\q2 kunyange minyengetero yake inonyangadza. 
\b  
\q1  
\v 10 Uyo anotungamirira vakarurama panzira yakaipa, 
\q2 achawira mumuteyo wake pachake, 
\q2 asi vasina mhosva vachagamuchira nhaka yakanaka. 
\b  
\q1  
\v 11 Munhu akapfuma angazviti akachenjera pakuona kwake, 
\q2 asi murombo ane njere anomuonorora. 
\b  
\q1  
\v 12 Kana vakarurama vachikunda, kune mufaro mukuru; 
\q2 asi kana akaipa akava pachigaro chokutonga, vanhu vanohwanda. 
\b  
\q1  
\v 13 Uyo anofukidzira zvivi zvake haabudiriri, 
\q2 asi ani naani anozvireurura uye agozvirasa achawana nyasha. 
\b  
\q1  
\v 14 Akaropafadzwa munhu anogara achitya Jehovha, 
\q2 asi uyo anoomesa mwoyo wake achawira mudambudziko. 
\b  
\q1  
\v 15 Seshumba inoomba, kana bere rinodzingirira, 
\q2 ndizvo zvakaita munhu akaipa anobata ushe pamusoro pavarombo. 
\b  
\q1  
\v 16 Mutongi anoshusha haana njere, 
\q2 asi uyo anovenga pfuma yakapambwa achararama kwamakore mazhinji. 
\b  
\q1  
\v 17 Munhu anoshushikana nemhosva yake yokuuraya, 
\q2 acharamba ari wokutiza kusvikira pakufa; 
\q2 ngapasava nomunhu anomutsigira. 
\b  
\q1  
\v 18 Uyo ano mufambiro wakarurama anogara akachengetedzeka, 
\q2 asi uyo ane nzira dzakatsauka achawa nokukurumidza. 
\b  
\q1  
\v 19 Uyo anorima munda wake achava nezvokudya zvakawanda, 
\q2 asi uyo anodzinganisana nezviroto achava nourombo hwakamufanira. 
\b  
\q1  
\v 20 Munhu akatendeka acharopafadzwa zvikuru, 
\q2 asi uyo anokara pfuma haangaregi kurangwa. 
\b  
\q1  
\v 21 Kuita rusarura hakuna kunaka, 
\q2 asi kunyange zvakadaro munhu anogona kuita zvakaipa kuti awane chimedu chechingwa. 
\b  
\q1  
\v 22 Munhu anonyima ane shungu dzokuda kupfuma 
\q2 asingazivi kuti urombo hwakamugaririra. 
\b  
\q1  
\v 23 Uyo anotsiura munhu iye achawana nyasha dzakawanda pakupedzisira, 
\q2 kupfuura uyo ane rurimi runonyengera. 
\b  
\q1  
\v 24 Uyo anobira baba kana mai vake 
\q2 achiti, “Hazvina kuipa,” 
\q2 ndiye shamwari youya anoparadza. 
\b  
\q1  
\v 25 Munhu ane ruchiva anomutsa kupesana, 
\q2 asi uyo anovimba naJehovha achabudirira. 
\b  
\q1  
\v 26 Uyo anovimba nesimba rake ibenzi, 
\q2 asi uyo anofamba muuchenjeri achachengetedzeka. 
\b  
\q1  
\v 27 Uyo anopa kuvarombo haangashayiwi chinhu, 
\q2 asi uyo anotsinzina meso ake kuvarombo achagamuchira kutukwa kuzhinji. 
\b  
\q1  
\v 28 Kana akaipa achienda pachigaro chokutonga, vanhu vanohwanda; 
\q2 asi kana vakaipa vachiparara, vakarurama vanowanda. 
\c 29  
\q1  
\v 1 Munhu anoramba akaomesa mutsipa wake mushure mokutsiurwa 
\q2 kazhinji achaparadzwa nokukurumidza, kusina chingamubatsira. 
\q1  
\v 2 Kana vakarurama vachiwanda, vanhu vanofara; 
\q2 asi kana vakaipa vachitonga, vanhu vanogomera. 
\b  
\q1  
\v 3 Munhu anoda uchenjeri anouyisa mufaro kuna baba vake, 
\q2 asi anoshamwaridzana nechifeve anoparadza pfuma yake. 
\b  
\q1  
\v 4 Nokururamisira mambo anosimbisa nyika, 
\q2 asi uyo anokara fufuro anoiparadza. 
\b  
\q1  
\v 5 Ani naani anonyengera muvakidzani wake 
\q2 anodzikira tsoka dzake mumbure. 
\b  
\q1  
\v 6 Munhu akaipa anoteyiwa nezvivi zvake, 
\q2 asi munhu akarurama anogona kuimba uye agofara. 
\b  
\q1  
\v 7 Vakarurama vane hanya nokururamisirwa kwavarombo, 
\q2 asi vakaipa havana hanya naizvozvo. 
\b  
\q1  
\v 8 Vatuki vanomutsa bope muguta, 
\q2 asi vanhu vakachenjera vanodzora kutsamwa. 
\b  
\q1  
\v 9 Kana munhu akachenjera akaenda kumatare nebenzi, 
\q2 benzi rinotsamwa uye rigotuka, zvokuti hapangavi norugare. 
\b  
\q1  
\v 10 Vanhu vanofarira kudeura ropa vanovenga munhu akarurama, 
\q2 uye vanotsvaka kuuraya vakarurama. 
\b  
\q1  
\v 11 Benzi rinobudisa hasha dzaro dzose, 
\q2 asi munhu akachenjera anozvibata. 
\b  
\q1  
\v 12 Kana mutongi akateerera nhema 
\q2 machinda ake ose achava akaipa. 
\b  
\q1  
\v 13 Murombo nomunhu anomanikidza vakafanana pachinhu ichi: 
\q2 Jehovha ndiye anoita kuti meso avo vose aone. 
\b  
\q1  
\v 14 Kana mambo akatonga varombo nokururamisira, 
\q2 chigaro chake choushe chinogara chakachengetedzeka nguva dzose. 
\b  
\q1  
\v 15 Shamhu yokuranga inopa uchenjeri, 
\q2 asi mwana anosiyiwa akadaro achanyadzisa mai vake. 
\b  
\q1  
\v 16 Kana vakaipa vachiwanda, nezvivi zvinowandawo, 
\q2 asi vakarurama vachaona kuwa kwavo. 
\b  
\q1  
\v 17 Ranga mwanakomana wako, ipapo achakupa rugare; 
\q2 achauyisa mufaro kumweya wako. 
\b  
\q1  
\v 18 Pasina chizaruro, vanhu vanoramba kuzvidzora; 
\q2 asi akaropafadzwa uyo anochengeta murayiro. 
\b  
\q1  
\v 19 Muranda haarayirwi namashoko zvawo chete, 
\q2 nokuti kunyange achinzwisisa, haangadaviri. 
\b  
\q1  
\v 20 Unoona here munhu anotaura achikurumidza? 
\q2 Benzi rine tariro zhinji kupfuura iye. 
\b  
\q1  
\v 21 Kana munhu akaregerera muranda wake kubva paudiki, 
\q2 achazotarisira kodzero dzomwanakomana pakupedzisira. 
\b  
\q1  
\v 22 Munhu akashatirwa anomutsa kupesana, 
\q2 uye munhu ane hasha anoita zvivi zvizhinji. 
\b  
\q1  
\v 23 Kuzvikudza kwomunhu kunomudzikisira pasi, 
\q2 asi munhu ane mweya wokuzvininipisa achawana kukudzwa. 
\b  
\q1  
\v 24 Anoshamwaridzana nembavha anozvivenga iye pachake; 
\q2 anoiswa pasi pemhiko, asi haangakwanisi kupa uchapupu. 
\b  
\q1  
\v 25 Kutya munhu kuchava musungo, 
\q2 asi ani naani anovimba naJehovha achagara akachengetedzeka. 
\b  
\q1  
\v 26 Vazhinji vanotsvaka nyasha kumutongi, 
\q2 asi kururamisirwa kwomunhu kunobva kuna Jehovha. 
\b  
\q1  
\v 27 Vakarurama vanovenga vasina kutendeka; 
\q2 vakaipa vanovenga vakarurama. 
\c 30  
\s1 Zvirevo zvaAguri 
\p  
\v 1 Zvirevo zvaAguri mwanakomana waJake, shoko rake: 
\q1 Murume uyu akati kuna Itieri, 
\q2 kuna Itieri nokuna Ukari: 
\b  
\q1  
\v 2 “Ndini munhu asingazivi zvikuru kwazvo pakati pavanhu; 
\q2 handina kunzwisisa kwomunhu. 
\q1  
\v 3 Handina kudzidza uchenjeri, 
\q2 uye handina ruzivo rwaiye Mutsvene. 
\q1  
\v 4 Ndiani akakwidza kudenga uye akazoburuka? 
\q2 Ndiani akabata mhepo mumaoko ake? 
\q1 Ndiani akasungirira mvura munguo yake? 
\q2 Ndiani akaisa migumo yose yenyika? 
\q1 Zita rake ndiani, uye nezita romwanakomana wake? 
\q2 Ndiudzei kana muchiriziva! 
\b  
\q1  
\v 5 “Shoko rimwe nerimwe raMwari nderechokwadi; 
\q2 iye chidzitiro kuna avo vanovanda maari. 
\q1  
\v 6 Usawedzera kumashoko ake, 
\q2 kana kuti achakutsiura uye agokuratidza kuti uri murevi wenhema. 
\b  
\q1  
\v 7 “Zvinhu zviviri zvandinokumbira kwamuri, imi Jehovha, 
\q2 musandirambira izvi ndisati ndafa: 
\q1  
\v 8 Bvisai kusatendeka nenhema zvive kure neni; 
\q2 musandipa urombo kana pfuma, 
\q2 asi ndipei chete zvokudya zvemisi yose. 
\q1  
\v 9 Zvichida, ndingava nezvakawanda kwazvo ndikasakukudzai, 
\q2 uye ndikazoti, ‘Jehovha ndianiko?’ 
\q1 Kana kuti zvimwe ndingava murombo ndikaba, 
\q2 uye ndikasaremekedza zita raMwari wangu. 
\b  
\q1  
\v 10 “Usareva muranda kuna tenzi wake, 
\q2 nokuti achakutuka, uye uchazviripira izvozvo. 
\b  
\q1  
\v 11 “Kuna avo vanotuka madzibaba avo 
\q2 uye vasingaropafadzi vanamai vavo; 
\q1  
\v 12 vaya vanozviti vakachena pamaonero avo 
\q2 asi vasina kusukwa tsvina yavo; 
\q1  
\v 13 vaya vane meso anozvikudza nguva dzose, 
\q2 vane matarisiro okushora; 
\q1  
\v 14 vaya vane meno anenge minondo 
\q2 nameno eshaya dzavo anenge mapanga 
\q1 kuti vaparadze varombo panyika, 
\q2 navanoshayiwa kubva pakati pavanhu. 
\b  
\q1  
\v 15 “Chikwevaropa chine vanasikana vaviri. 
\q2 Vanodanidzira vachiti, ‘Tipei! Tipei!’ 
\b  
\li1 “Kune zvinhu zvitatu zvisingatongoguti, 
\li2 zvina zvisingamboti, ‘Zvaringana!’: 
\li3  
\v 16 guva, 
\li3 chizvaro chisingabereki, 
\li3 pasi pasingaguti mvura, 
\li3 nomoto usingamboti, ‘Zvaringana!’ 
\b  
\q1  
\v 17 “Ziso rinotuka baba, 
\q2 rinoshora kuteerera mai, 
\q1 richanongorwa namakunguo omumupata, 
\q2 richadyiwa namagora. 
\b  
\li1  
\v 18 “Pane zvinhu zvitatu zvinondishamisa kwazvo, 
\li2 zvina zvandisinganzwisisi, zvinoti: 
\li3  
\v 19 nzira yegondo riri mudenga, 
\li3 nenzira yenyoka paruware, 
\li3 nenzira yechikepe pagungwa, 
\li3 uye nzira yomurume ane musikana. 
\b  
\q1  
\v 20 “Iyi ndiyo nzira yomukadzi chifeve: 
\q2 Anodya agopukuta muromo wake uye agoti, 
\q2 ‘Hapana chinhu chakaipa chandaita ini.’ 
\b  
\li1  
\v 21 “Nyika inodedera nokuda kwezvinhu zvitatu, 
\li2 zvinhu zvina zvaisingadi kuona: 
\li3  
\v 22 muranda anozova mambo, 
\li3 benzi rine zvokudya zvizhinji, 
\li3  
\v 23 mukadzi akaroorwa asi asingadiwi, 
\li3 nomurandakadzi anotorera vatenzi vake murume. 
\b  
\li1  
\v 24 “Panyika pane zvinhu zvina zvidiki, 
\li2 asi zvakachenjera kwazvo: 
\li2  
\v 25 Masvosve zvipuka zvine simba duku 
\li3 asi anounganidza zvokudya zvawo muzhizha: 
\li2  
\v 26 mbira zvipuka zvisina simba guru, 
\li3 asi dzinoita imba yadzo mumatombo; 
\li2  
\v 27 mhashu hadzina mambo, 
\li3 asi dzinofamba pamwe chete mumapoka adzo; 
\li2  
\v 28 dzvinyu rinogona kubatwa namaoko, 
\li3 asi rinowanikwa mumizinda yamadzimambo. 
\b  
\li1  
\v 29 “Kune zvinhu zvitatu zvino kufamba kunokudzwa kwazvo, 
\li2 zvina zvino kufamba kunokudzwa kwazvo; 
\li3  
\v 30 shumba, ine simba pakati pezvikara, isingadududzi pamberi pechikara chipi zvacho; 
\li3  
\v 31 mafambiro okuzvikudza ejongwe, 
\li3 nenhongo yembudzi, 
\li3 uye namambo akakomberedzwa navarwi vake. 
\b  
\q1  
\v 32 “Kana uchinge waita upenzi nokuzvirumbidza pachako, 
\q2 kana kuti waronga zvakaipa, 
\q2 bata muromo wako noruoko rwako! 
\q1  
\v 33 Nokuti somukaka warozva unobudisa ruomba, 
\q2 uye sokudzvinyirira mhino kunobudisa ropa, 
\q2 nokudaro kumutsa hasha kunobudisa kukakavara.” 
\c 31  
\s1 Zvirevo zvaMambo Remueri 
\p  
\v 1 Zvirevo zvaMambo Remueri, zvirevo zvaakadzidziswa namai vake: 
\q1  
\v 2 “Nhaiwe mwanakomana wangu, iwe mwanakomana wokubereka, 
\q2 iwe mwanakomana wemhiko dzangu, 
\q1  
\v 3 usapedzera simba rako pavakadzi, 
\q2 nenzira dzako pane avo vanoparadza madzimambo. 
\b  
\q1  
\v 4 “Hazvisi zvamadzimambo, nhaiwe Remueri, 
\q2 hazvina kufanira madzimambo kunwa waini, 
\q2 hazvina kufanira vatongi kukara doro, 
\q1  
\v 5 nokuti vangazonwa vakakanganwa zvakatemwa nomurayiro, 
\q2 uye vakazotadza kururamisira kodzero dzavanomanikidzwa vose. 
\q1  
\v 6 Ipai doro kuna avo vari kuparara, 
\q2 newaini kuna avo vari mukurwadziwa: 
\q1  
\v 7 regai vanwe vakanganwe urombo hwavo, 
\q2 uye varege kuzorangarirazve kutambudzika kwavo. 
\b  
\q1  
\v 8 “Taurai pachinzvimbo chaavo vasingagoni kuzvitaurira, 
\q2 pamusoro pekodzero dzavose vanoshayiwa. 
\q1  
\v 9 Taura utonge zvakanaka; 
\q2 udzivirire kodzero dzavarombo navanoshayiwa.” 
\s1 Mudzimai ane Unhu Hwakanaka 
\q1  
\v 10 Mudzimai ane unhu hwakanaka ndiani angamuwana? 
\q2 Mutengo wake unopfuura nokure matombo anokosha emarubhi. 
\q1  
\v 11 Murume wake anovimba naye zvizere, 
\q2 uye haana chaanoshayiwa chinokosha. 
\q1  
\v 12 Anoitira murume wake zvakanaka, kwete zvakaipa, 
\q2 mazuva ose oupenyu hwake. 
\q1  
\v 13 Anosarudza wuru neshinda 
\q2 uye anoshanda namaoko anoshingaira. 
\q1  
\v 14 Akafanana nezvikepe zvavatengesi, 
\q2 anondotora zvokudya zvake kure. 
\q1  
\v 15 Anomuka kuchakasviba; 
\q2 agotsvagira mhuri yake zvokudya 
\q2 uye agopa varandakadzi vake basa ravo. 
\q1  
\v 16 Anonanʼanidza munda agoutenga; 
\q2 anosima munda wemizambiringa nezvaakawana namaoko ake. 
\q1  
\v 17 Anoita basa rake nesimba; 
\q2 maoko ake akasimba kuti aite mabasa ake. 
\q1  
\v 18 Anoona kuti kushambadzira kwake kunobatsira, 
\q2 uye mwenje wake haudzimi pausiku. 
\q1  
\v 19 Muruoko rwake anobata chirukiso, 
\q2 uye anobata chirukwa neminwe yake. 
\q1  
\v 20 Anotambanudzira maoko ake kuvarombo, 
\q2 uye anotandavadzira maoko ake kune vanoshayiwa. 
\q1  
\v 21 Kana kwotonhora, haatyire mhuri yake; 
\q2 nokuti vose vakapfeka nguo dzinodziya. 
\q1  
\v 22 Anozvigadzirira zvokuwaridza panhoo yake; 
\q2 anozvipfekedza nguo yomucheka wakaisvonaka, uye nomucheka wepepuru. 
\q1  
\v 23 Murume wake anoremekedzwa pasuo reguta, 
\q2 kana agere pakati pavakuru venyika. 
\q1  
\v 24 Mudzimai anoita nguo dzemicheka yakanaka agodzitengesa, 
\q2 uye anotengesera vanotengesa micheka yokumonera muhuro. 
\q1  
\v 25 Simba nokukudzwa ndizvo nguo dzake; 
\q2 anofara akatarisana namazuva anouya. 
\q1  
\v 26 Anotaura nouchenjeri, 
\q2 uye kurayira kwakatendeka kuri parurimi rwake. 
\q1  
\v 27 Anotarira zvakanaka mararamiro emhuri yake, 
\q2 uye haadyi zvokudya zvousimbe. 
\q1  
\v 28 Vana vake vanosimuka vagomuti akaropafadzwa, 
\q2 murume wakewo, anomurumbidza: 
\q1  
\v 29 “Vakadzi vazhinji vanoita zvinhu zvakanaka, 
\q2 asi iwe unovakunda vose.” 
\q1  
\v 30 Zvinofadza zvinonyengera, uye runako ndorwenguva duku; 
\q2 asi mukadzi anotya Jehovha anofanira kurumbidzwa. 
\q1  
\v 31 Mupeiwo mubayiro wake waakashandira, 
\q2 uye mabasa ake ngaamupe kurumbidzwa pasuo reguta.