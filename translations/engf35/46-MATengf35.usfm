\p
\v 16 “\w Also|strong="G1161"\w*, \w whenever|strong="G3752"\w* \w you|strong="G5210"\w* \w fast|strong="G3522"\w* \w do|strong="G1096"\w* \w not|strong="G3361"\w* \w become|strong="G1096"\w* \w gloomy|strong="G4659"\w* \w like|strong="G5613"\w* \w the|strong="G1161"\w* \w hypocrites|strong="G5273"\w*, \w because|strong="G1063"\w* \w they|strong="G1161"\w* disfigure \w their|strong="G3588"\w* \w faces|strong="G4383"\w* \w so|strong="G1161"\w* \w that|strong="G3588"\w* \w people|strong="G4383"\w* \w will|strong="G1096"\w* notice \w that|strong="G3588"\w* \w they|strong="G1161"\w* \w are|strong="G3588"\w* \w fasting|strong="G3522"\w*. Assuredly \w I|strong="G1161"\w* \w say|strong="G3004"\w* \w to|strong="G3004"\w* \w you|strong="G5210"\w* \w that|strong="G3588"\w* \w they|strong="G1161"\w* \it already\it* \w have|strong="G5210"\w* \w their|strong="G3588"\w* \w reward|strong="G3408"\w*.  
