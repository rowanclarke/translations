\v 9 \w Y|strong="H3068"\w* le dijo: \wj \+w Toma|strong="H3947"\+w* para Mí una \+w becerra|strong="H5697"\+w* de tres años, una \+w cabra|strong="H5795"\+w* de tres años, un carnero de tres años, una tórtola y un palomino.\wj*   
\p
\v 10 \w Tomó|strong="H3947"\w* \w todos|strong="H3605"\w* \w éstos|strong="H3605"\w*, \w los|strong="H3605"\w* \w partió|strong="H1335"\w* \w por|strong="H5414"\w* \w la|strong="H3605"\w* \w mitad|strong="H8432"\w*, y \w puso|strong="H5414"\w* \w cada|strong="H3605"\w* \w mitad|strong="H8432"\w* enfrente \w de|strong="H5414"\w* \w la|strong="H3605"\w* otra, pero \w no|strong="H3808"\w* \w partió|strong="H1335"\w* las aves.  
\v 11 \w Descendían|strong="H3381"\w* \w las|strong="H5921"\w* \w aves|strong="H5861"\w* \w de|strong="H5921"\w* rapiña \w sobre|strong="H5921"\w* \w los|strong="H5921"\w* \w cuerpos|strong="H6297"\w* \w muertos|strong="H6297"\w*, pero Abram \w las|strong="H5921"\w* ahuyentaba.   
\p
\v 12 \w Cuando|strong="H1961"\w* \w el|strong="H5921"\w* \w sol|strong="H8121"\w* \w se|strong="H1961"\w* iba \w a|strong="H3068"\w* ocultar, un profundo adormecimiento \w cayó|strong="H5307"\w* \w sobre|strong="H5921"\w* Abram, \w y|strong="H5921"\w* \w el|strong="H5921"\w* terror \w de|strong="H5921"\w* una intensa oscuridad \w vino|strong="H1961"\w* \w sobre|strong="H5921"\w* \w él|strong="H5921"\w*.   
\p
\v 13 \w Y|strong="H3068"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* dijo \w a|strong="H3068"\w* Abram: \wj \+w Sabe|strong="H3045"\+w* \+w por|strong="H3588"\+w* \+w cierto|strong="H3588"\+w* \+w que|strong="H3588"\+w* tu \+w descendencia|strong="H2233"\+w* \+w será|strong="H1961"\+w* forastera \+w en|strong="H3588"\+w* una tierra \+w ajena|strong="H3808"\+w*. Allí \+w será|strong="H1961"\+w* esclavizada \+w y|strong="H3588"\+w* oprimida 400 \+w años|strong="H8141"\+w*.\wj*  
\v 14 \wj Pero Yo \+w también|strong="H1571"\+w* \+w juzgaré|strong="H1777"\+w* \+w a|strong="H3068"\+w* \+w la|strong="H1571"\+w* \+w nación|strong="H1471"\+w* \+w a|strong="H3068"\+w* \+w la|strong="H1571"\+w* cual \+w servirán|strong="H5647"\+w*. Después \+w saldrán|strong="H3318"\+w* \+w con|strong="H1571"\+w* \+w gran|strong="H1419"\+w* \+w riqueza|strong="H7399"\+w*.\wj*  
\v 15 \wj Pero tú te reunirás con tus antepasados \+w en|strong="H6912"\+w* \+w paz|strong="H7965"\+w* y serás \+w sepultado|strong="H6912"\+w* \+w en|strong="H6912"\+w* \+w buena|strong="H2896"\+w* \+w vejez|strong="H7872"\+w*.\wj*  
\v 16 \wj \+w Y|strong="H3068"\+w* \+w en|strong="H5704"\+w* \+w la|strong="H3588"\+w* cuarta \+w generación|strong="H1755"\+w* regresarán \+w acá|strong="H2008"\+w*, \+w porque|strong="H3588"\+w* \+w hasta|strong="H5704"\+w* \+w ahora|strong="H2008"\+w* \+w la|strong="H3588"\+w* \+w iniquidad|strong="H5771"\+w* del amorreo \+w no|strong="H3808"\+w* \+w llegó|strong="H5704"\+w* \+w al|strong="H5704"\+w* colmo.\wj*   
\p
\v 17 \w Sucedió|strong="H1961"\w* \w que|strong="H1961"\w* \w cuando|strong="H1961"\w* \w el|strong="H5674"\w* \w sol|strong="H8121"\w* \w se|strong="H1961"\w* ocultó, \w hubo|strong="H1961"\w* una densa oscuridad. Apareció un \w horno|strong="H8574"\w* encendido, y una antorcha \w pasaba|strong="H5674"\w* y ardía entre aquellos trozos.   
\p
\v 18 \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w hizo|strong="H3772"\w* \w Pacto|strong="H1285"\w* \w con|strong="H5704"\w* Abram: \wj \+w A|strong="H3068"\+w* tu \+w descendencia|strong="H2233"\+w* \+w daré|strong="H5414"\+w* \+w esta|strong="H2063"\+w* tierra, \+w desde|strong="H5704"\+w* \+w el|strong="H1931"\+w* \+w río|strong="H5104"\+w* \+w de|strong="H5704"\+w* \+w Egipto|strong="H4714"\+w* \+w hasta|strong="H5704"\+w* \+w el|strong="H1931"\+w* \+w Río|strong="H5104"\+w* \+w Grande|strong="H1419"\+w*, \+w el|strong="H1931"\+w* \+w río|strong="H5104"\+w* \+w Éufrates|strong="H6578"\+w*,\wj*  
\v 19 \wj la tierra de los ceneos, los cenezeos, los cadmoneos,\wj*  
\v 20 \wj los heteos, los ferezeos, los refaítas,\wj*  
\v 21 \wj los amorreos, los \+w cananeos|strong="H3669"\+w*, los \+w gergeseos|strong="H1622"\+w* y los \+w jebuseos|strong="H2983"\+w*.\wj*   
\c 16  
\s1 Agar e Ismael  
\p
\v 1 Saray, esposa de Abram, \w no|strong="H3808"\w* le daba hijos. Pero ella tenía una esclava \w egipcia|strong="H4713"\w* cuyo \w nombre|strong="H8034"\w* era \w Agar|strong="H1904"\w*.  
\v 2 \w Y|strong="H3068"\w* Saray dijo \w a|strong="H3068"\w* Abram: \w Mira|strong="H2009"\w*, \nd \+w Yavé|strong="H3068"\+w*\nd* \w me|strong="H4480"\w* impidió tener hijos. \w Te|strong="H4480"\w* \w ruego|strong="H4994"\w* \w que|strong="H4480"\w* \w te|strong="H4480"\w* unas \w a|strong="H3068"\w* \w mi|strong="H2009"\w* esclava. Quizás los obtenga \w de|strong="H4480"\w* \w ella|strong="H4480"\w*. \w Y|strong="H3068"\w* Abram \w escuchó|strong="H8085"\w* la \w voz|strong="H6963"\w* \w de|strong="H4480"\w* Saray.   
\p
\v 3 \w Y|strong="H3068"\w* \w después|strong="H3427"\w* \w de|strong="H5414"\w* \w diez|strong="H6235"\w* \w años|strong="H8141"\w* \w de|strong="H5414"\w* vivir Abram en la tierra \w de|strong="H5414"\w* \w Canaán|strong="H3667"\w*, su esposa Saray \w tomó|strong="H3947"\w* \w a|strong="H3068"\w* \w Agar|strong="H1904"\w*, su esclava \w egipcia|strong="H4713"\w*, y la \w dio|strong="H5414"\w* como mujer \w a|strong="H3068"\w* su esposo Abram.  
\v 4 \w Él|strong="H3588"\w* se unió \w a|strong="H3068"\w* \w Agar|strong="H1904"\w* \w y|strong="H3588"\w* \add ella\add* \w concibió|strong="H2029"\w*. Sin embargo, \w cuando|strong="H3588"\w* \w vio|strong="H7200"\w* \w que|strong="H3588"\w* \w concibió|strong="H2029"\w*, \w miraba|strong="H7200"\w* \w con|strong="H3588"\w* desprecio \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w señora|strong="H1404"\w*.   
\p
\v 5 \w Entonces|strong="H3588"\w* Saray dijo \w a|strong="H3068"\w* Abram: ¡\w Mi|strong="H5921"\w* afrenta sea \w sobre|strong="H5921"\w* \w ti|strong="H5921"\w*! \w Yo|strong="H3588"\w* \w puse|strong="H5414"\w* \w a|strong="H3068"\w* \w mi|strong="H5921"\w* esclava \w en|strong="H5921"\w* \w tu|strong="H8199"\w* \w seno|strong="H2436"\w*, \w y|strong="H3588"\w* \w ella|strong="H5921"\w*, \w al|strong="H5921"\w* \w ver|strong="H7200"\w* \w que|strong="H3588"\w* \w está|strong="H5921"\w* \w embarazada|strong="H2029"\w*, \w me|strong="H5921"\w* \w mira|strong="H7200"\w* \w con|strong="H5921"\w* desprecio. \w Juzgue|strong="H8199"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w entre|strong="H5921"\w* \w tú|strong="H8199"\w* \w y|strong="H3588"\w* \w yo|strong="H3588"\w*.   
\p
\v 6 Abram contestó \w a|strong="H3068"\w* Saray: \w Mira|strong="H2009"\w*, \w tu|strong="H6213"\w* esclava está en tus \w manos|strong="H3027"\w*. \w Haz|strong="H6213"\w* con ella \w lo|strong="H6213"\w* \w que|strong="H3027"\w* \w te|strong="H5869"\w* parezca \w bien|strong="H2896"\w*.  
\p Entonces Saray la afligió, y ella \w huyó|strong="H1272"\w* \w de|strong="H6440"\w* su \w presencia|strong="H6440"\w*.   
\p
\v 7 Pero \w el|strong="H5921"\w* \w Ángel|strong="H4397"\w* \w de|strong="H5921"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* \w la|strong="H5921"\w* \w halló|strong="H4672"\w* \w junto|strong="H5921"\w* \w a|strong="H3068"\w* un pozo \w de|strong="H5921"\w* \w agua|strong="H4325"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w desierto|strong="H4057"\w*, \w junto|strong="H5921"\w* \w al|strong="H5921"\w* pozo \w que|strong="H5921"\w* \w está|strong="H5921"\w* \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w camino|strong="H1870"\w* \w de|strong="H5921"\w* \w Shur|strong="H7793"\w*,  
\v 8 y le dijo: \wj \+w Agar|strong="H1904"\+w*, esclava \+w de|strong="H6440"\+w* Saray, ¿\+w de|strong="H6440"\+w* dónde \+w vienes|strong="H3212"\+w* y \+w a|strong="H3068"\+w* dónde \+w vas|strong="H3212"\+w*?\wj*  
\p Ella respondió: \w Huyo|strong="H1272"\w* \w de|strong="H6440"\w* la \w presencia|strong="H6440"\w* \w de|strong="H6440"\w* mi \w señora|strong="H1404"\w* Saray.   
\p
\v 9 \w Entonces|strong="H7725"\w* el \w Ángel|strong="H4397"\w* \w de|strong="H8478"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* le dijo: \wj \+w Vuelve|strong="H7725"\+w* \+w a|strong="H3068"\+w* tu \+w señora|strong="H1404"\+w* y humíllate \+w bajo|strong="H8478"\+w* sus \+w manos|strong="H3027"\+w*.\wj*  
\v 10 \w Y|strong="H3068"\w* le dijo el \w Ángel|strong="H4397"\w* de \nd \+w Yavé|strong="H3068"\+w*\nd*: \wj \+w Multiplicaré|strong="H7235"\+w* inmensamente tu \+w descendencia|strong="H2233"\+w*, y debido \+w a|strong="H3068"\+w* su \+w multitud|strong="H7230"\+w*, \+w no|strong="H3808"\+w* \+w se|strong="H3808"\+w* \+w podrá|strong="H3808"\+w* \+w contar|strong="H5608"\+w*.\wj*   
\p
\v 11 \w El|strong="H3588"\w* \w Ángel|strong="H4397"\w* \w de|strong="H3588"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* también le dijo:  
\q1 \wj \+w Mira|strong="H2009"\+w*, estás embarazada \+w y|strong="H3588"\+w* darás \+w a|strong="H3068"\+w* luz un \+w hijo|strong="H1121"\+w*. \wj*  
