\q2 \w Elle|strong="H1121"\w* \w est|strong="H1961"\w* affûtée \w pour|strong="H4616"\w* \w le|strong="H1121"\w* \w carnage|strong="H2874"\w*.
\q1 
\v 16 Rassemblez-vous.
\q2 Allez \w à|strong="H5414"\w* droite.
\q1 Mettez-vous \w en|strong="H5414"\w* ordre \w de|strong="H3027"\w* bataille.
\q2 Allez \w à|strong="H5414"\w* gauche,
\q2 partout \w où|strong="H3027"\w* \w votre|strong="H5414"\w* visage \w est|strong="H1931"\w* dirigé.
\q1 
\v 17 \w Moi|strong="H1121"\w* \w aussi|strong="H3651"\w*, \w je|strong="H3588"\w* frapperai \w des|strong="H1121"\w* mains,
\q2 \w et|strong="H1121"\w* j'assouvirai \w ma|strong="H5971"\w* fureur.
\q2 \w Moi|strong="H1121"\w*, \w le|strong="H1121"\w* \w SEIGNEUR|strong="H3478"\w*, j'\w ai|strong="H5971"\w* \w parlé|strong="H1121"\w*. »
\p 
\v 18 \w La|strong="H3588"\w* \w parole|strong="H5002"\w* du \w SEIGNEUR|strong="H3588"\w* \w me|strong="H3588"\w* \w fut|strong="H1961"\w* \w encore|strong="H1571"\w* \w adressée|strong="H1961"\w* :
