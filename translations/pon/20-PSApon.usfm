\id PSA Psalms in the old Pohnpeian Bible - Public Domain
\h Pjalm
\toc1 PUK EN PJALM.
\toc2 Pjalm
\toc3 Pj.
\mt1 PUK EN PJALM.
\c 1
\q1 
\v 1 MEID pai ol o, me jota alialu ni padak en me doo ja\it n\it* Kot akan o me jo duki o\it n\it* me dipan akan, o me jo mondi ren me malaun akan,
\q1 
\v 2 A me kin peren kida kapu\it n\it* en leowa o madamadaua duen a kapu\it n\it* ni ran o ni po\it n\it*!
\q1 
\v 3 A rajo\it n\it* tuka pot, me padedier ni kailan pilap akan me kin kapareda wa ni a anjau, o ta kan jota kin mo\it n\it*ala, a karoj a wiawia pwaida.
\q1 
\v 4 Me doo ja\it n\it* Kot akan jota kin dueta, a re rajo\it n\it* dip me an kin iririp jili.
\q1 
\v 5 I me doo ja\it n\it* Kot akan jota pan pwai kida nan kadeik, o me dipan akan nan momod en me pu\it n\it* kan.
\q1 
\v 6 Pwe leowa kotin ma\it n\it*i al en me pu\it n\it* kan; a al en ir, me doo ja\it n\it* Kot akan, pan joredi.
\c 2
\q1 
\v 1 DA me men liki kan li\it n\it*ari\it n\it*arki, o da me wei kan lamelam eki me mal akan?
\q1 
\v 2 Nanmarki en jappa kan kin kanudi o jaupeidi kan kapukapu\it n\it* pena, en kaokaoe dodok en leowa o Japwilim a me keidier.
\q1 
\v 3 Kitail en kawela ara men jaliedi o kaje ja\it n\it* kitail ara jal akan!
\q1 
\v 4 A me kotikot nanla\it n\it*, kotin kiparamateki, o Kaun o kotin mamale kin irail.
\q1 
\v 5 Eu ran a pan kotin kapu\it n\it* o\it n\it* ir ni a o\it n\it*io\it n\it*; o ni a o\it n\it*io\it n\it* lapalap a pan kotin kamajak irail.
\q1 
\v 6 A \it n\it*ai kajapwilada ai Nanmarki pon dol en Jion jaraui.
\q1 
\v 7 A \it n\it*ai pan padaki wei duen aude pan kapu\it n\it* en leowa! A kotin majani o\it n\it* ia er: Koe nai Ol, ran wet I kaipwi uk adar!
\q1 
\v 8 Poeki re i, I ap pan ki o\it n\it* uk, en jojoki men liki kan, o en aneki imwin jappa kan.
\q1 
\v 9 Koe pan kawe irail ekidi jokon mata, o kamor irail paja\it n\it* raj o\it n\it* dal akan.
\q1 
\v 10 Ari, komail nanmarki kan en dukidi, o komail jaunkapu\it n\it* en jappa kan en lolekonala!
\q1 
\v 11 Papan leowa ni lan o pereperen ni majak!
\q1 
\v 12 Metik japwilim a Ol, pwe a der o\it n\it*io\it n\it*, o komail ap lokidokila pon al o, pwe a o\it n\it*io\it n\it* kak mada\it n\it* tapida. A meid pai ir karoj, me liki i.
\c 3
\q1 
\v 1 O IEOWA, ai imwintiti me toto, o ir me toto, me kanudi o\it n\it* ia!
\q1 
\v 2 Me toto kin inda duen \it n\it*en i, me dene jota jauaj pa i ren Kot. Jela.
\q1 
\v 3 A komui Ieowa pere pa i, o komui pan kotin kali\it n\it*ana ia da, o kamait ia la.
\q1 
\v 4 I kin likwiri o\it n\it* Ieowa ki \it n\it*il laud; o a kotin ma\it n\it*i ai \it n\it*idi\it n\it*id ja\it n\it* ni japwilim a dol jaraui.
\q1 
\v 5 I kin wonon, o mamair, o pirida, pwe Ieowa kin kotin kolekol ia.
\q1 
\v 6 I jota kin majak jaunpei \it n\it*en pak toto, me kin kapil ia pena.
\q1 
\v 7 Kom kotida Mai\it n\it*, Ieowa o jauaj a ia, ai Kot! Pwe kom kotin pikir ai imwintiti karoj, o kawelar ni en me japu\it n\it* kan.
\q1 
\v 8 Ieowa me jauaj patail Kom kotin kamauiada japwilim omui aramaj akan! Jela.
\c 4
\q1 
\v 1 KOT kapu\it n\it* pa i, kom kotin mani ia ni ai likelikwir. Pwe kom kin kotin kamait ia la ni ai anjau apwal. Kom kotin maki on ia o mani ai kapakap.
\q1 
\v 2 Komail jaumaj akan! Arai da mar ai pan jujued? Arai da omail pok on me mal kot, o omail perenki likam? Jela.
\q1 
\v 3 Komail loleko\it n\it*ala, ap aja, me Ieowa kotin piladar japwilim a lelapok o. Ieowa kin kotin ma\it n\it*i ia ni ai likelikwir o\it n\it* i.
\q1 
\v 4 Ni omail makar, komail der wia dip. Komail madamadauaki mo\it n\it*io\it n\it* omail ni omail wendi pon loj o ap auiaui. Jela.
\q1 
\v 5 Komail mairo\it n\it*ki mairo\it n\it* pu\it n\it* o liki Ieowa.
\q1 
\v 6 Me toto kin inda: Ij me pan kajale o\it n\it* kitail me mau kan? A Ieowa, kom kotin kamaraine kin kit marain en jila\it n\it* omui!
\q1 
\v 7 Komui kotin kaperenda mo\it n\it*io\it n\it* i laud ja\it n\it* anjaun arail wain o korn me toto.
\q1 
\v 8 I kin wonon o mamair ni popol; pwe komui ta Mai\it n\it*, me kotin jauaj a ia da, pwe i en kak moleilei.
\c 5
\q1 
\v 1 IEOWA kom kotin ereki ai lokaia o kotin ma\it n\it*i ai madamadaua.
\q1 
\v 2 O kotin ma\it n\it*i ai likelikwir, ai Nanmarki o ai Kot, pwe i pan potoan kapakap o\it n\it* komui.
\q1 
\v 3 Mai\it n\it* Ieowa, kotin ma\it n\it*i \it n\it*il ai nin joran, nin joran i men tu o\it n\it* komui o majamajan.
\q1 
\v 4 Pwe komui kaidin Kot amen, me kin mauki tiak japu\it n\it*, me morjued jota pan mimieta mo ’mui.
\q1 
\v 5 Me aklapalap akan jota pan pwaida mon jila\it n\it* omui, kom kin kotin juede ki me japu\it n\it* kan.
\q1 
\v 6 Kom pan kotin kamela me likam kan; Ieowa kin kotin tataki me kamela o kotaue aramaj akan.
\q1 
\v 7 A i pan pedelo\it n\it* o\it n\it* nan tanpaj omui, pweki omui kalanan lapalap, o kaudok ni lan inen wo\it n\it* japwilim omui im en kaudok o.
\q1 
\v 8 Mai\it n\it* kom kotin kalua ia ni omui pun, pweki ai imwintiti kan; kom kotin kaineneta al omui mo i.
\q1 
\v 9 Pwe jota me melel kot ni au arail; o lol arail rokeki kaopa. Kapinwor arail rajo\it n\it* joujou me jo jer pena; o re kin akjanjale mauki lo arail.
\q1 
\v 10 Kom kotin kadeik irail da, Mai\it n\it* Kot, pwe ren pup kidi pein arail ino\it n\it*. Jikin ir wei, pweki arail dip lapalap, pwe re kin kanudi o\it n\it* komui.
\q1 
\v 11 Karoj, me liki komui ap pan peren kida, re pan pereperen kokolata, pwe kom kin kotin jinjila irail. Irail pan pereperen, me kin pok o\it n\it* mar omui.
\q1 
\v 12 Pwe komui Mai\it n\it* kin kapaiada me pu\it n\it* kan. Komui kin kotin nekid ir ala ki omui kala\it n\it*an dueta pere eu.
\c 6
\q1 
\v 1 MAIi\it N\it*, kom der kotin kaloke kin ia omui o\it n\it*io\it n\it*, o der kame kin ia omui o\it n\it*io\it n\it* lapala!
\q1 
\v 2 Mai\it n\it*, kom kotin maki o\it n\it* ia, pwe \it n\it*ai me luet. Mai\it n\it*, kom kotin kamau ia la, Mai\it n\it* Ieowa, pwe ti kan me luetalar.
\q1 
\v 3 Main, kom kotin jaupei do\it n\it* ia, dorela \it n\it*en i. Kom kotin jauaja ia ni omui kalanan.
\q1 
\v 4 Mai\it n\it*, kom kotin jaupei do\it n\it* ia, dorela \it n\it*en i. Kom kotin jauaja ia ni omui kalanan!
\q1 
\v 5 Pwe murin melar jolar me pan tamanda komui; o ij me pan kapi\it n\it*a komui wajan mela?
\q1 
\v 6 I pa\it n\it*a kida ai ja\it n\it*eja\it n\it* ja\it n\it* jautik lel manja\it n\it*; i kawijoki jokela ai loj pil en maj ai.
\q1 
\v 7 Mom ai juede kilar ai injenjued, o i malar, pweki kamakama jak pai me toto.
\q1 
\v 8 Komail aramaj morjued akan karoj kaiwei ja\it n\it* ia, pwe Ieowa kotin ma\it n\it*i ai ja\it n\it*eja\it n\it*.
\q1 
\v 9 Ieowa kotin ma\it n\it*i ai \it n\it*idi\it n\it*id, o Ieowa kotin ma\it n\it*ier ai kapakap.
\q1 
\v 10 Ai imwintiti karoj pan namenokela o majakada melel, re pan tanwei o mada\it n\it* jarodi.
\c 7
\q1 
\v 1 MAI\it N\it*, i kin liki komui Ieowa, ai Kot. Kom kotin jauaja ia o\it n\it* ai imwintiti kan karoj, o kotin dore ia la,
\q1 
\v 2 Pwe ren der dueta laien amen kol ia di o tape\it n\it* ia paja\it n\it*, pwe jota pil amen jaundor.
\q1 
\v 3 Mai\it n\it*, ai Kot, ma i wiadar mepukat, o ma pa i kat wiadar japu\it n\it*,
\q1 
\v 4 O ma i depukki mejued en akai ar wiawia mau o\it n\it* ia, pwe I dorelar, me imwintiti o\it n\it* ia, ap jota karepa,
\q1 
\v 5 A ma jo due, ai imwintiti en kaloke ia, o kol ia di, o tiakedi maur i nani pwel, o kawela mar ai. Jela.
\q1 
\v 6 Mai\it n\it*, kom kotida ni omui o\it n\it*io\it n\it* o kotin palian makar en ai imwintiti kan, o kotin opada\it n\it* ia, pwe re kotin inau kidar kapu\it n\it*,
\q1 
\v 7 Pwe wei kan pan pokon do\it n\it* ir; o re kotin purodala pweki irail.
\q1 
\v 8 leowa iei jaunkapu\it n\it* en wei kan. Mai\it n\it*, kotin jauaja ia, duen ai pu\it n\it* o duen ai lelapok!
\q1 
\v 9 Re kotin kadukiedi mejued en me doo ja\it n\it* Kot akan, ap kotin kate\it n\it*edi me pu\it n\it* kan. Pwe komui Kot pu\it n\it*, kin kotin kajaui mo\it n\it*io\it n\it* o mudilik kan.
\q1 
\v 10 Kot iei pere pa i, me kin kotin jauaja me melel ni mo\it n\it*io\it n\it* arail.
\q1 
\v 11 Kot jaunkapu\it n\it* pu\it n\it* amen, me kotin onionada ni ran karoj.
\q1 
\v 12 Ma meamen jota pan wukila, a ap kotin ada japwilim a kodlaj o onopada kajik katieu o kainene wo\it n\it* i,
\q1 
\v 13 O kotin pwil poa kana\it n\it*an kajik katieu men kamela. A kotin kaonopada japwilim a kana\it n\it*an kajik katieu, pwe men karo\it n\it*ala.
\q1 
\v 14 Kila\it n\it*, a lamelam me dir en jued, a lijenaneki men kaokaoe o pan naitikedi likam.
\q1 
\v 15 A weiradar por eu o wiadar lolia, ap pein pupedi o\it n\it* lole, me a weiradar.
\q1 
\v 16 A men kamela pan japale do\it n\it* pein mon a, o a dodok jued pan pupedi o\it n\it* pein a al en wei.
\q1 
\v 17 I pan kapi\it n\it*a leowa, pweki a pu\it n\it*, o i pan kauleki mar en leowa me lapalapia.
\c 8
\q1 
\v 1 MAI\it N\it* at Kaun, mar omui meid li\it n\it*an nan jap karoj! Irail kin kapi\it n\it*a komui nanla\it n\it*!
\q1 
\v 2 Ja\it n\it* nan au en jeri pwelel, o ir me kin kankan didi, re kotin wia kidar manaman eu o\it n\it* omui imwintiti kan, pwe komui en kamela me imwintiti o, o me aktuau o.
\q1 
\v 3 Ma i kilekila\it n\it* la\it n\it*, dodok en lim omui, jaunipo\it n\it* o uju kan, me re kotin wiadar:
\q1 
\v 4 Dakot aramaj o, pwe komui kin kotin kupkupura i, de nain aramaj, pwe komui kin kotin apapwali i?
\q1 
\v 5 Re kotin kajapwilidier i anjau kij pan tounla\it n\it* kan, a re kali\it n\it*anadar i, o kawauialar i.
\q1 
\v 6 Re kajapwilada\it n\it*er i wiawia en lim omui kan. Kom kotin kaloedier karoj pan na a kan:
\q1 
\v 7 Jip o kau kan, o pil man en jap akan.
\q1 
\v 8 O manpir en pan la\it n\it*, o mam en nan jed, karoj me kin memaureki nan madau.
\q1 
\v 9 leowa at Kaun, mar omui meid li\it n\it*an nan jap karoj!
\c 9
\q1 
\v 1 I MEN kapi\it n\it*a leowa ja\it n\it* nan mo\it n\it*io\it n\it* i meler, o kajokajoiia duen japwilim omui dodok kapuriamui kan karoj.
\q1 
\v 2 I men pereperen o polauleki komui o kauleki mar omui; komui me lapalapia,
\q1 
\v 3 Pwe re kotin kaloedier ai imwintiti kan, irail pupedier o melar.
\q1 
\v 4 Pwe re kotin apwali ia ni ai pu\it n\it* o ai dodok. Komui kainpokedi pon mol omui duen jaunkapu\it n\it* pu\it n\it* amen.
\q1 
\v 5 Kom kotin kapu\it n\it* o\it n\it* men liki kan o kotin kamela me japu\it n\it* kan, kom kotin kawelar mar arail kokolata.
\q1 
\v 6 Imwintiti o joredier, a namenokalar melel. Komui kotin wuketedi kanim akan; o jolar, me pan taman irail ada o tou ar akan.
\q1 
\v 7 A Ieowa pan kotin kaunda kokolata. A kotin kaonopada mol a, pwen kadeikada.
\q1 
\v 8 O a pan kotin kadeikada jappa ni pu\it n\it*, o kakaunda wei kan pu\it n\it*.
\q1 
\v 9 Ieowa jile pan me jamama kan, jilepa ni anjau apwal.
\q1 
\v 10 I me irail, me aja mar omui kin liki komui, pwe komui jota kin muei ja\it n\it* irail, me kin rapaki komui, Mai\it n\it* Ieowa.
\q1 
\v 11 Kauleki Ieowa, me kin kaunda nan Jion. Komail padaki o\it n\it* wei kan a wiawia!
\q1 
\v 12 Pwe a kotin taman irail ada o kotin kainoma nta ’rail. A jota kin kotin maliela likwir en me jamama kan.
\q1 
\v 13 Mai\it n\it* Ieowa, kom kotin maki o\it n\it* ia. Re kotin ma\it n\it*i ai apwal ren ai imwintiti kan, kom kotin dore ia la ja\it n\it* nan wanim en mela.
\q1 
\v 14 Pwe i en kajokajoiia duen omui dodok kapuriamui pan wanim en nain Jion, perenki jauaj pa om.
\q1 
\v 15 Men liki kan pupedi o\it n\it* nan por o, me pein irail weiradar, o \it n\it*il ’rail lodi o\it n\it* injar, me pein irail wiadar.
\q1 
\v 16 I me kitail ajaki, Ieowa me kotin kapu\it n\it* pu\it n\it*. Me japu\it n\it* kan jalidi o\it n\it* pein ar dodok en pa ar akan. Jela.
\q1 
\v 17 Me japu\it n\it* kan en lokidokila nan wajan mela, o men liki kan karoj, me kin monokela Kot.
\q1 
\v 18 Pwe me jamama o jota pan monokinokla kokolata, o me luet akan jota pan kaporoporeki mal kokolata.
\q1 
\v 19 Mai\it n\it*, kom kotida! Pwe aramaj ender pwaida, a men liki kan karoj en pakadeikada mo omui.
\q1 
\v 20 Mai\it n\it*, kotiki o\it n\it* ir men kamajak, pwe men liki kan en dedeki, me re udan aramaj eta. Jela.
\c 10
\q1 
\v 1 MAI\it N\it*, da me kom kotin doo ja\it n\it* ia, o da me kom kotin rir ja\it n\it* ia ni anjau apwal?
\q1 
\v 2 Me japu\it n\it* kan ni ar aklapalap re kin kaloke me jamama o; re kin pokon pena o madamadaua duen ar morjued.
\q1 
\v 3 Pwe me japu\it n\it* o kin juaiki a tiak jued, o me norok moni, kin muei ja\it n\it* Ieowa, lalaue i.
\q1 
\v 4 Me japu\it n\it* o kin lamelame ni a aklapalap, me a jota kotin ma\it n\it*i duen mepukat. Ni jo\it n\it* en a tiak jued karoj, a kin lamelame me jota Kot.
\q1 
\v 5 A kin pwaida ni a dodok kan. A japwilim omui kapu\it n\it* me doo ja\it n\it* i; a kin lalaue a imwintiti kan karoj.
\q1 
\v 6 A kin indinda nan mo\it n\it*io\it n\it* i: I jota pan lodi; i jota pan diar ai apwal kot kokolata.
\q1 
\v 7 Au a me dir en lalaue, o malaun, o kotaue, o pan lo a kin me jued o me apwal.
\q1 
\v 8 A wonon o majamajan nan kanim akan, a kin rir kamela me makelekel o, o por en maj a kin majamajan me japai o.
\q1 
\v 9 A kin majamajan waja rir dueta laien amen nan deu a, a kin auiaui, pwen koledi me luet o, a kin jaikidi me luet o ni a injar.
\q1 
\v 10 A kin dairukorokedi o karakarakedi, o me japai kan pan lodi o\it n\it* ni kiki ko\it n\it* kelail akan.
\q1 
\v 11 A kin indinda nan mo\it n\it*io\it n\it* i: Kot pan monokela, a kin karirila jila\it n\it* i, a iota man ma\it n\it*i.
\q1 
\v 12 Re kotida Mai\it n\it* Kot, kotin pokada lim ar, kom der kotin maliela me luet akan.
\q1 
\v 13 Menda me doo ja\it n\it* Kot o kin mamaleki Kot, o a kin indinda nan mo\it n\it*io\it n\it* i, me dene kom jota pan kotin ma\it n\it*i.
\q1 
\v 14 Ari jo, kom kotin ma\it n\it*i, pwe kom kotin irero\it n\it* me luet o kanka\it n\it*era\it n\it*er akan, pwen jauaja ir. Me japai o kin mueid o\it n\it* komui pein i, o komui me jauaj pa en me japoupou o.
\q1 
\v 15 Kom kotin katip paja\it n\it* pa en me japu\it n\it* o, o kotin depuk o\it n\it* mejued o a tiak jued lao jolar pan diarokada.
\q1 
\v 16 Ieowa me Nanmarki kokolata; men liki kan en nikilar ja\it n\it* nan japwe.
\q1 
\v 17 Mai\it n\it*, kom kotin ma\it n\it*ier ino\it n\it* en me luet akan; kom kotin kamanada mo\it n\it*io\it n\it* arail, karo\it n\it* omui mama\it n\it*i mepukat,
\q1 
\v 18 Pwen jauaja me japoupou o jamama o, pwe aramaj en jappa en jolar ka\it n\it*udi.
\c 11
\q1 
\v 1 I LIKI Ieowa, a menda komail inda\it n\it* \it n\it*en i: Piridala\it n\it* pon omail nana dueta manpir amen?
\q1 
\v 2 Pwe kila\it n\it*, me doo ja\it n\it* Kot akan kaonopadar kajik katieu o pwilikidi ar kanan en kajik katieu pon jal o, pwen rir kajikiedi me melel ni mo\it n\it*io\it n\it* arail.
\q1 
\v 3 Pwe ma ur akan ro\it n\it*k paja\it n\it*, da me aramaj pun en wiada?
\q1 
\v 4 Ieowa kotikot nan tanpaj a jaraui, mol en Ieowa mimi nanla\it n\it*, jila\it n\it* i kin mamajani jili, kil en jila\it n\it* i kin jojon aramaj akan.
\q1 
\v 5 Ieowa kotin jo\it n\it* me pu\it n\it*, ap kotin tataki me japu\it n\it* o morjued.
\q1 
\v 6 A pan kotin kamoredi o\it n\it* me doo ja\it n\it* Kot akan liol, o kijiniai, o jwepel, o a pan katine kin irail melimel.
\q1 
\v 7 Ieowa me pu\it n\it* o a kotin pok o\it n\it* me pu\it n\it*. Jila\it n\it* i irero\it n\it* o\it n\it* me melel o.
\c 12
\q1 
\v 1 MAI\it N\it* kom kotin jauaja, pwe me lelapok kan malaulaular, o me melel akan me malaulau ren aramaj akan.
\q1 
\v 2 Irail kin lokaia likam, amen amen o\it n\it* men impa, re lokaiaki lol riapot.
\q1 
\v 3 Ieowa pan kotin ujada kil en au karoj me li\it n\it*kapi\it n\it* o lo, me kin lokaia wei ni aklapalap.
\q1 
\v 4 Me kin indinda: Lo atail, me kit pan pwai kida, o kil en au at me kit keleki; ij at kaun?
\q1 
\v 5 Ieowa kotin majani: I pan uda, pweki kanka\it n\it*era\it n\it*er en me luet akan o ja\it n\it*eja\it n\it* en me jamama kan: I pan jauaja i, me kin ino\it n\it* io\it n\it*.
\q1 
\v 6 Majan en Ieowa me makelekeleta jilper, me kamakelekel kidar nan dal pwel en kijiniai pan pak iju.
\q1 
\v 7 Komui Mai\it n\it*, pan kotin pera irail, o jinjila mon di wet kokolata.
\q1 
\v 8 Pwe me japu\it n\it* kan pan totolar waja karoj, ma aramaj jued pukat kin kaunda aramaj akan.
\c 13
\q1 
\v 1 MAI\it N\it* arai da kom pan kotin malie ia la? Arai da komui pan kotin karirila jila\it n\it* omui mo i?
\q1 
\v 2 Arai da i en perki nan lol ai o jalo mi nan mo\it n\it*io\it n\it* i ran karoj? Arai da ai imwintiti en kaurur kin ia?
\q1 
\v 3 Mai\it n\it* ai Kot, kom kotin majan do\it n\it* ia o jape\it n\it* ia. Kom kotin kamaraini maj ai, pwe i ender mela.
\q1 
\v 4 Pwe ai imwintiti ender inda: I kaloedier i. O me palian ia ender perenki ai pupedier.
\q1 
\v 5 A i kin liki omui kala\it n\it*an; mo\it n\it*io\it n\it* i en peren kida omui kotin jauaja ia. I pan kauleki Ieowa duen a kotin wiawia mau o\it n\it* ia.
\c 14
\q1 
\v 1 ME pweipwei o kin indinda nan mo\it n\it*io\it n\it* i: Jota Kot. Jota katepa ’rail, o arail tiak meid jued; jota amen mia, me kin wia me mau.
\q1 
\v 2 Ieowa kin irero\it n\it* aramaj akan ja\it n\it* nanla\it n\it*, pwen majani, ma amen mia, me loleko\it n\it* o rapaki Kot.
\q1 
\v 3 A ir karoj juedelar o karoj jota kon o\it n\it*, jota me kin wiada me mau, jota amen.
\q1 
\v 4 Irail karoj me kin wiada mejued, jota ar loleko\it n\it*, o me kin kawela nai aramaj akan, lao medi kila, a re jota kin likwir o\it n\it* Ieowa?
\q1 
\v 5 I waja re kin majak, pwe Kot kotikot ren kadaudok en me pu\it n\it* kan.
\q1 
\v 6 Komail kin kawela ino\it n\it* en me luet; aki Ieowa, me a kin kaporoporeki.
\q1 
\v 7 O i men, jauaj pan Ijrael en kodo ja\it n\it* nan Jion, o Ieowa en kotin lapwada japwilim a jalidi kan! I me Iakop pan injenemauki o Ijrael pan pereperenki.
\c 15
\q1 
\v 1 MAI\it N\it*, ij me pan kaukaujon nan tanpaj omui? Ij me pan mimieta pon japwilim omui dol jaraui?
\q1 
\v 2 Me kin kekeitwei ni makelekel, o me kin wia me pu\it n\it*, o me kin lokaia melel ja\it n\it* nan mo\it n\it*io\it n\it*;
\q1 
\v 3 Me jota karaun mal ki lo a, o me jota kin wia mejued o\it n\it* men imp a;
\q1 
\v 4 Me kin mamaleki me lokidokilar o, ap kakaki me majak Ieowa kan, o me kin kaula melel, menda ma a juedi o\it n\it* pein i;
\q1 
\v 5 Me jota pan piti ja\it n\it* en amen na moni, o me jota pan ale kijakij, pwen kawela me pu\it n\it* amen. Ari, me kin apwali mepukat, jota pan luetala kokolata.
\c 16
\q1 
\v 1 MAI\it N\it* Kot, kom kotin jinjila ia, pwe i liki komui.
\q1 
\v 2 \it N\it*ai potoan o\it n\it* Ieowa: Komui ta ai Kaun, jota eu pai, me i aja, pwe komui eta.
\q1 
\v 3 O I kin inda\it n\it* jaraui kan, me kin mi nan jappa: Met akan pwin ijou, me I kin pokepoke ja\it n\it* ni mo\it n\it*io\it n\it* i.
\q1 
\v 4 A irail me kin idedauen amen, pan lodi o\it n\it* apwal toto. I jota mauki arail mairo\it n\it*, me doleki nta, de mar arail I jota pan inda.
\q1 
\v 5 A Ieowa ai pai o ai peren; Komui kin kolekol ai jojo.
\q1 
\v 6 I diaradar ai pwaij en jap kajelel eu, ei pai kajelel eu, me i jojokier.
\q1 
\v 7 I kapi\it n\it*a Ieowa, me kotin kaloleko\it n\it* ia; pil ni po\it n\it* mudilik i kan kin padaki o\it n\it* ia.
\q1 
\v 8 I kin ariri Ieowa anjau karoj, pwe a kotikot ni pali maun i, i ap jota pan luetala.
\q1 
\v 9 I me mo\it n\it*io\it n\it* i kin peren kida, o \it n\it*en i kin popol, pwe pil pali uduk ai pan moleilei.
\q1 
\v 10 Pwe kom jota pan kotin mauki, nen i en mimieta nan wajan mela, o kom jota pan mueid o\it n\it*, me japwilim omui jaraui men pan mor paja\it n\it*.
\q1 
\v 11 Kom kin kotin kaaja kin ia al maur; peren lapalap mi mon jila\it n\it* omui, o meid li\it n\it*an ni pali maun en lim omui kokolata.
\c 17
\q1 
\v 1 MAI\it N\it* kom kotin ereki me pu\it n\it* o kotin ma\it n\it*i ai likwir o kotin kupura ai kapakap, me jota kin kowei ja\it n\it* nan kil en au likam eu.
\q1 
\v 2 Ai pu\it n\it* en pwili ja\it n\it* re omui, o kom kotin majan do\it n\it* me pu\it n\it*.
\q1 
\v 3 Kom kotin kajaui mo\it n\it*io\it n\it* I ni po\it n\it*, o komui kotin jojo\it n\it* ia, ap jota me kom kotin diar. I inaukidi, me i jota pan japu\it n\it* ni ai lokaia.
\q1 
\v 4 I kin rukila pan majan en jila\it n\it* omui ja\it n\it* mon tiak en aramaj o al en men kamela.
\q1 
\v 5 Ni ai alialu wei i jota muei jan nan lip en aluwilu omui, ai kakawei jota katia ja\it n\it*.
\q1 
\v 6 I likwiri o\it n\it* komui, Mai\it n\it*. Kot, kom kotin ma\it n\it*i ia, o kapaike do\it n\it* ia karo\it n\it* omui, o kotin ereki ai kapakap.
\q1 
\v 7 Kom kotin kajaleda omui kala\it n\it*an kapuriamui, pwe pali maun omui jauaj pan ir, me kin liki komui, o\it n\it* ir me palian ir.
\q1 
\v 8 Jinjila ia dueta por en maj eu, o kotin pera kin ia mot en lim omui,
\q1 
\v 9 Mon me japu\it n\it* kan, me men kawe ia la, mon ai imwintiti, me kin kapil ia pena.
\q1 
\v 10 Re kin kapiridi mo\it n\it*io\it n\it* arail; o ja\it n\it* nan au arail re kin lokaia aklapalap.
\q1 
\v 11 Waja je kin kola ia, re kin kapil kit pena, maj arail kin majamajan, pwen kaje kit di o\it n\it* nan pwel.
\q1 
\v 12 Dueta laien amen, me ino\it n\it* io\it n\it* ma\it n\it*a, o dueta laien pul amen, me wonon nan waja rir.
\q1 
\v 13 Mai\it n\it*, kom kotida, kaloedi o kanamonokla i; dorela maur i ja\it n\it* me japu\it n\it* kan ki omui kodlaj,
\q1 
\v 14 Ja\it n\it* ren aramaj akan ki lim omui, Mai\it n\it* Ieowa, ja\it n\it* ren aramaj en jappa wet, me pwaij arail ni maur et; kom kotin kadire kila kaped arail omui dipijo kan, me nairail jeri ol me toto, o nairail akan me pan jojoki luan arail kapwa.
\q1 
\v 15 A i pan ariri jila\it n\it* omui ni ai pu\it n\it*, o i pan medikila mom omui ni ai pan pirida.
\c 18
\q1 
\v 1 I KIN pok o\it n\it* komui Mai\it n\it*, ai kel.
\q1 
\v 2 Ieowa ai paip, ai kel, ai jaundor, ai Kot, ai paipalap, me i kin liki, pere pa i, menkamaur pa i o jile pa i!
\q1 
\v 3 I kin \it n\it*idi\it n\it*id o\it n\it* Ieowa, me kapi\it n\it* en ko o\it n\it*, o i pan dorela ja\it n\it* ai imwintiti kan.
\q1 
\v 4 I lodi o\it n\it*er jal en mela kan, o pilap en Pileam akan kamajak ia er.
\q1 
\v 5 Jal en wajan mela kol ia dier, o jal en mela kaloe ia dier.
\q1 
\v 6 Ni ai majak i likwir o\it n\it* Ieowa o weriwer o\it n\it* ai Kot; I ap kotin ereki \it n\it*il ai ja\it n\it* nan tanpaj a, o ai likwir lel o\it n\it* karo\it n\it* a kan.
\q1 
\v 7 Jappa rerer o mokidedar, o pajon en nana kan ititekok o rerer, ni a kotin o\it n\it*io\it n\it*idar.
\q1 
\v 8 Atiniai koda ja\it n\it* nan jila\it n\it* i, o kijiniai kelail ja\it n\it* nan au a, ap kareda liol.
\q1 
\v 9 O a kotikidier nanla\it n\it* o kotidido, o rotorot impan aluwilu a kan.
\q1 
\v 10 O a kotikot pon Kerup amen o kotin pirwei, o a kotin dake pa en a\it n\it*.
\q1 
\v 11 Tanpaj a im pwal iei rotorot, o katau laud, o tapok rotorot, kapil pena i.
\q1 
\v 12 Li\it n\it*an me mi mo a, kamueit paja\it n\it* tapok kan ian akel o liol.
\q1 
\v 13 O Ieowa kotin wiadar nanjapwe nanla\it n\it*, o me Lapalapia kotin poronelar kapit i ia\it n\it* akel o liol.
\q1 
\v 14 A kotin kajik wei japwilim a kana\it n\it* en kajik katieu, o kotin kamueit irail paja\it n\it*. A kotin wiadar liol toto o kamajak irail adar.
\q1 
\v 15 Al en pil akan ap janjaladar, o pajon en jappa weiweidar ki ar o\it n\it*io\it n\it* Mai\it n\it*, mon a\it n\it* en jila\it n\it* omui.
\q1 
\v 16 A kotikidier lim a ja\it n\it* nan waja ileile, a kotin kol ia di o kotin api ia dar ja\it n\it* nan pil kalaimun akan.
\q1 
\v 17 A kotin dore ia la ja\it n\it* ai imwintiti kelail akan, ja\it n\it* ir, me kailo\it n\it* kin ia, ir me i jota itar o\it n\it*.
\q1 
\v 18 Irail kaloe ia dier ni ai ran apwal, a Ieowa kotin wialar jauaj pa i.
\q1 
\v 19 O a kotin kalua ia wajan jaladok, a kotin kamaio ia da, aki a kotin kupukupura ia.
\q1 
\v 20 Ieowa kin kotin jauaja ia duen ai pu\it n\it*, a kotin kati\it n\it*i o\it n\it* ia duen makelekel en pa i kan.
\q1 
\v 21 Pwe i kin weweid nani al en Ieowa, o i jota kin katiwo o\it n\it* ai Kot.
\q1 
\v 22 Pwe a majan akan mi mo i, o i jota pan kaje ja\it n\it* ia a kujoned akan.
\q1 
\v 23 Pwe \it n\it*ai unjokalar mon jila\it n\it* i o juedeki ai japu\it n\it*.
\q1 
\v 24 O Ieowa kotin katini o\it n\it* ia duen ai pu\it n\it*, o duen makelekel en pa i kan mon jila\it n\it* i.
\q1 
\v 25 Komui me kala\it n\it*an o\it n\it* me mau kan, o lelapok o\it n\it* me lelapok kan,
\q1 
\v 26 O makelekel ren me makelekel akan, o japu\it n\it* ren me japu\it n\it* kan.
\q1 
\v 27 Pwe kom kin kotin dorela aramaj luet akan, ap kadukiedi maj en me aklapalap akan.
\q1 
\v 28 Pwe kom kin kotin kamaraini ai lamp, Ieowa ai Kot kin kamaraini ai rotorot.
\q1 
\v 29 Pwe ni ai ia\it n\it* komui i kak kaloedi karij en jaunpei kan, o ni ai ia\it n\it* ai Kot, i kak lujwei pon kel takai.
\q1 
\v 30 AI en Kot me unjokala; majan en Ieowa me makelekel. I pere pan karoj, me liki i.
\q1 
\v 31 Pwe ia amen Kot impan Ieowa, de ia paip eu impan atail Kot?
\q1 
\v 32 lei Kot, me kotin aude kin ia manaman, o kaunjokala al ai.
\q1 
\v 33 A kin kotin wiai o\it n\it* na i kan dueta na en tia, o kotin kajapwil ia da\it n\it* waja ileile.
\q1 
\v 34 A kotin padaki o\it n\it* pa i kan tiak en mauin o, pwen kak on kaonopada kaiik katieu mata.
\q1 
\v 35 Kom kotiki o\it n\it* ia pere pan maur omui, o lim omui pali maun kama\it n\it*a ia da, o omui opampap me kajapwil ia da.
\q1 
\v 36 Kom kotin kaonopadar al, me i pan weweid ia, pwe nil i kan ender krijedi.
\q1 
\v 37 I pan ta\it n\it* wo\it n\it* ai imwintiti kan o kono irail edi, o i jota pan puredo, lao karoj lodier.
\q1 
\v 38 I pan kamor irail paja\it n\it*, re jota pan kak palian ia, o re pan pupedi o\it n\it* pan na i kan.
\q1 
\v 39 Kom kak kamana kin ia omui manaman o\it n\it* ni pei; Kom kak kajedi o\it n\it* pan na i kan karoj me palian ia.
\q1 
\v 40 Kom kin kotin kaloedi o\it n\it* ia ai imwintiti kan, pwen kawela, me kailo\it n\it* kin ia.
\q1 
\v 41 Re kin likelikwir, a jota jauaj parail ren Ieowa, a jota kotin jape\it n\it* ir.
\q1 
\v 42 I pan juk irail paja\it n\it* dueta pwel par nan kijinia\it n\it*; i pan kaje ir ala dueta pwel jamin ja\it n\it* nani al o.
\q1 
\v 43 Kom kin kotin dore ia ja\it n\it* ren akamai en aramaj, o kom kotin kajapwil ia da\it n\it* men liki kan; o wei eu me i jaja kin upa o\it n\it* ia.
\q1 
\v 44 Ni ar ro\it n\it*er, re peiki o\it n\it* ia er, o nain men wai kan peikio\it n\it* ia ni li\it n\it*kapi\it n\it*.
\q1 
\v 45 Nain men wai kan poridier o rerer o pwarado ja\it n\it* nan ar im kalaimun akan.
\q1 
\v 46 Ieowa kotin ieiaj; kapi\it n\it* o\it n\it* ai paipalap; o kapi\it n\it* o\it n\it* Kot ai jaundor.
\q1 
\v 47 Kot me kotin depuk o\it n\it* ai imwintiti kan, o a kotin kaloedi o\it n\it* ia ai imwintiti kan;
\q1 
\v 48 Kom kotin dore ia la ja\it n\it* ai imwintiti kan, o kom kotin kajapwil ia da\it n\it* ir, me palian ia. Kom kin kotin jauaja ia o\it n\it* me, morjued o\it n\it* ia.
\q1 
\v 49 I me i men danke komui, Mai\it n\it* Ieowa, nan pu\it n\it* en men liki kan o kauleki duen mar Omui,
\q1 
\v 50 Komui me kotin kamaurada melel japwilim a nanmarki o a kotin jauaja mau japwilim a Dawid keiedier o kadaudok a kokolata.
\c 19
\q1 
\v 1 LAN pokon kin kajokajoi duen li\it n\it*an en Kot o aude pan la\it n\it* kin katitiki dodok en lim a kan.
\q1 
\v 2 Ran eu kin kajokajoi o\it n\it* eu ran o po\it n\it* eu kin padaki o\it n\it* eu po\it n\it*.
\q1 
\v 3 Jota kaparok o jota lepen lokaia, ari jo, \it n\it*il a kin peido.
\q1 
\v 4 O a loua padak lel o\it n\it* jap karoj, o a kaparok lel imwin jappa. A kotin wiai o\it n\it* katipin im pwal eu pan la\it n\it*;
\q1 
\v 5 O a kin pedoi ja\it n\it* nan a pera dueta ol kamod amen, o kin pereperen dueta ol kamod amen ni a ta\it n\it*wei pon al o.
\q1 
\v 6 A dakada ni eu imwin la\it n\it* ap ta\it n\it*ala\it n\it* imwin teio, o jota me kak rir ja\it n\it* mon karakar a.
\q1 
\v 7 Kapu\it n\it* en Ieowa me unjok o kin kainjenemauiala \it n\it*en en aramaj akan. Kadede en Ieowa me melel o kin kaloleko\it n\it*la me lolepon.
\q1 
\v 8 Kujoned en Ieowa me pu\it n\it* o kin kaperenda mo\it n\it*io\it n\it* en aramaj. Kujoned en Ieowa me makelekel o kamarainiada maj en aramaj.
\q1 
\v 9 Lomwin Ieowa me min o kin duedueta. Majan en Ieowa kan me melel, o pu\it n\it* kaualap.
\q1 
\v 10 Irail me kajampwal ja\it n\it* kold o kold li\it n\it*an toto, o iau ja\it n\it* onik o onik kajampwal.
\q1 
\v 11 Ir me pil kin katamanda japwilim omui ladu, o me kin kapwai ir ada, ar katin me lapalap.
\q1 
\v 12 Ij me kak aja duen toto en a japu\it n\it*? Kom kotin lapwada dip ai me rir akan.
\q1 
\v 13 Pil perewei ja\it n\it* japwilim omui ladu me aklapalap, pwe ren der kaloe ia di, i ap pan pu\it n\it*ala, o pan makelekel ja\it n\it* dip lapalap kokolata.
\q1 
\v 14 Kom kotin kupura kaparok en au ai o lokolokaia en mo\it n\it*io\it n\it* I mo ’mui, Ieowa ai paipalap o ai jaundor.
\c 20
\q1 
\v 1 IEOWA en kotin ma\it n\it*i om kapakap ni ran apwal o; mar en Kot en Iakop en pera uk!
\q1 
\v 2 A en kotin porone do\it n\it* uk jauaj pam ja\it n\it* nan tanpaj jaraui o kama\it n\it*a uk ada ja\it n\it* nan Jion.
\q1 
\v 3 A en kotin kupura om mairo\it n\it* karoj, o om mairo\it n\it* ijij en konkon re a.
\q1 
\v 4 A en kotiki o\it n\it* uk, me mo\it n\it*io\it n\it* om anane, o kotin kapaiada om ino\it n\it* karoj.
\q1 
\v 5 Je pan \it n\it*iji\it n\it*ijki omui jauaja kit, o ni mar en atail Kot kit pan kida at plak. Ieowa en kotin kapwaiada om poekipoek karoj!
\q1 
\v 6 I ap ajaer, me Ieowa kin kotin dorela japwilim a me keiedier, o a pan ma\it n\it*i i ja\it n\it* nan japwilim a la\it n\it* jaraui, lim a pali maun kin jauaja kaualap.
\q1 
\v 7 Mo kan kin kaporoporeki war o oj akan; a kit kin keleki mar en Ieowa atail Kot.
\q1 
\v 8 Irail lodier o pupedier, a kit uda o kajinenda.
\q1 
\v 9 Mai\it n\it* kom kotin jauaja nanmarki o, o kotin ma\it n\it*i at likwir o\it n\it* komui!
\c 21
\q1 
\v 1 MAI\it N\it* Ieowa, nanmarki o kin peren kida omui manaman, o a polauleki melel omui jauaja i!
\q1 
\v 2 Kom kotiki o\it n\it* i, me mo\it n\it*io\it n\it* I ino\it n\it* io\it n\it*, o kom jota kin jopeiwei ja\it n\it*, me kilin aua poekipoki.
\q1 
\v 3 Pwe kom kin wudokedi o\it n\it* poa me mau kan; kom kotin kalijorop kidi i nin kold kajampwal eu.
\q1 
\v 4 A kin poeki re omui maur, komui ap kotiki o\it n\it* i maur warai kokolata.
\q1 
\v 5 A li\it n\it*an me lapalap ki omui kotin jauaja i. Kom kin kotin kapwataki i manaman o li\it n\it*an.
\q1 
\v 6 Kom kotin kajapwilada i, pwen wia kamau men kokolata; kom kaperenda i mon jila\it n\it* omui.
\q1 
\v 7 Pwe nanmarki kin liki Ieowa, o a pan dadaurata ki kala\it n\it*an en me lapalapia.
\q1 
\v 8 Lim omui pan diar omui imwintiti kan karoj, o lim omui maun pan diar me kailo\it n\it* kin komui.
\q1 
\v 9 Kom pan wia kin ir ala jtop en kijiniai eu, ni omui pan kotin pwarado. Ieowa pan kotin kawe ir ala ni a o\it n\it*io\it n\it*, o kijiniai pan kan ir ala.
\q1 
\v 10 Kom pan kotin karojela kadaudok arail ja\it n\it* nan jappa, o wa ’rail ja\it n\it* nan pu\it n\it* en aramaj akan.
\q1 
\v 11 Pwe irail inau kidar, me re pan wia jued o\it n\it* komui a re jota pan itar o\it n\it*.
\q1 
\v 12 Pwe komui pan kotin kajaloe ir ada, pwe ren ta\it n\it*; kom pan kotin padok wo\it n\it* ir omui jal en kajik katieu.
\q1 
\v 13 Mai\it n\it* kom kotida ni omui rojo\it n\it* kit ap kauleki o kapi\it n\it*a omui manaman.
\c 22
\q1 
\v 1 A I Kot, ai Kot da me komui likidmalie kin ia la? I likelikwir, a jauaj pa i me doo.
\q1 
\v 2 Ai Kot, nin ran i kin likwir, a kom jota kin jape\it n\it*, o ni po\it n\it* I pil jota kin nenenla.
\q1 
\v 3 Ari jo, komui ta me jaraui, komui me kotikot pan kaul en kapi\it n\it* en Ijrael.
\q1 
\v 4 Jam at akan liki komui, o ni ar liki, kom kotin jauaja irail er.
\q1 
\v 5 Irail likwir o\it n\it* komui, rap dorelar, re liki komui, rap jota namenokala.
\q1 
\v 6 A \it n\it*ai dueta kamatol amen, a kaidin ol amen, me aramaj akan kin lalaue o mamaleki.
\q1 
\v 7 Karoj me kila\it n\it* ia, kin lalaue, ia, jara paja\it n\it* au arail o tuetual mo\it n\it* arail:
\q1 
\v 8 A kin liki Ieowa, i en dorela i, o kamaioda i, pwe a kin kupura i.
\q1 
\v 9 Pwe komui kotin kaipwi ia ja\it n\it* nan kaped en in ai; komui ta, me i liki ja\it n\it* ni anjaun ai mi ni maramaran in ai.
\q1 
\v 10 Ja\it n\it* nan’ kaped en in ai i lokidokila\it n\it* komui; komui ta ai Kot ja\it n\it* ni anjaun ai mi pon kopan in ai.
\q1 
\v 11 Kom der kotin doo ja\it n\it* ia, pwe anjaun kalokolok korendor, ap jolar jauaj pa i.
\q1 
\v 12 Kau ol kalaimun kan kapil ia penaer, o kau ol en Paja\it n\it* kele ia pena.
\q1 
\v 13 Irail jara do\it n\it* ia dueta laien weriwer o laualo amen.
\q1 
\v 14 \it N\it*ai wudokilar dueta pil, ai kokon akan karoj muei paja\it n\it*er, o mo\it n\it*io\it n\it* i pei paja\it n\it*er nan kaped i dueta wi.
\q1 
\v 15 Ai kelail \it n\it*ala\it n\it*al lar dueta diper en dal eu, o lo i pajada\it n\it* pan \it n\it*ata\it n\it*at ai, o komui kin wia kin ia me melar amen.
\q1 
\v 16 Pwe kidi kan kapil ia pena, o pwin aramaj jued eu kele ia pena, irail kapore paja\it n\it* pa i o na i kat.
\q1 
\v 17 I kak wadok kokon ai kan karoj; a irail kin kilekila\it n\it* ap peren kida.
\q1 
\v 18 Re kin nek paja\it n\it* ai likau kan nan pu\it n\it* arail, o re doropweki ai likau pup.
\q1 
\v 19 A komui Mai\it n\it* ender doo ja\it n\it* ia! Ai kel mada\it n\it*do o jauaja ia!
\q1 
\v 20 Dorela maur i ja\it n\it* kodlaj, pwe me ta ieu, o ja\it n\it* nan kel en kidi!
\q1 
\v 21 Jauaja ia ja\it n\it* nan au en laien, o dore ia la ja\it n\it* oje en man laualo!
\q1 
\v 22 I pan padaki o\it n\it* ri ai kan duen mar omui, o i pan kapi\it n\it*a komui nan momodijou.
\q1 
\v 23 Kapi\it n\it*a leowa komail me majak i, o kadaudok en Iakop en kali\it n\it*a\it n\it*ada i, o wan Ijrael karoj majak i.
\q1 
\v 24 Pwe a jota kotin mamaleki de juedeki me luet akan; o a jota kotin karirila jila\it n\it* i ja\it n\it* irail; o ni a likwir o\it n\it* i, a kotin erekier.
\q1 
\v 25 I pan kapi\it n\it*a komui nan momodijou kalaimun; i pan kapwaiada ai inau mon ir me lan i.
\q1 
\v 26 Me luet akan en ma\it n\it*a o medila, o me idok leowa, pan kapi\it n\it*a i; \it n\it*en omail pan me maureta kokolata.
\q1 
\v 27 Ni imwin jap karoj re pan tamanda leowa, ap wuki o\it n\it* i, o di en men liki karoj pan kaudoki o\it n\it* i.
\q1 
\v 28 Pwe wein leowa, o a kotin kaunda men liki kan.
\q1 
\v 29 Me wi kan karoj nin jappa pan ma\it n\it*ama\it n\it*a o kelepuki; karoj, me pan wiala pwel o jota kak kolekol maur ar, pan po\it n\it*i i.
\q1 
\v 30 Kadaudok eu mia, me pan papa i, re pan padaki o\it n\it* jeri o jeri en jeri kan duen leowa.
\q1 
\v 31 Re pan pwarado o padaki o\it n\it* aramaj akan, me pan ipwidi mur duen a pu\it n\it*, o duen me a kotin wiadar.
\c 23
\q1 
\v 1 IEOWA jile pa i, i jota pan anane meakot.
\q1 
\v 2 A kotin kama\it n\it*a ia nan moj kajelel o kalua ia wo\it n\it* ni pil lamelamur.
\q1 
\v 3 A kotin kamanada \it n\it*en i, a kalua ia pon al pu\it n\it* pweki mar a.
\q1 
\v 4 I lao weid nan mot en mela, i jota pan majak me jued kot, pwe kom kotin ieia\it n\it* ia, omui irar o lepin jaipali kamait ia la.
\q1 
\v 5 Kom kotin kaonop da\it n\it* ia tepel eu jalo\it n\it* ai imwintiti kan. Kom kotin keiekidi mon ai le, o ai dal kin wudewudok.
\q1 
\v 6 Pai o kala\it n\it*an pan idauen ia arain ai maur, o i pan mimieta nan tanpaj en leowa kokolata.
\c 24
\q1 
\v 1 JAPWILIM en leowa jappa o audepa kan, jap o meakaroj me kaujon poa.
\q1 
\v 2 Pwe a kotin pajonedier ni kailan madau, o a kotin wiadar pon pil akan.
\q1 
\v 3 Ij me pan kodala\it n\it* pon dol en leowa? O ij me pan kak uda ni mol en Ieowa jaraiui?
\q1 
\v 4 me pa a kan jota japu\it n\it* o kin mauki padak japu\it n\it*, o me jota kin kaula likam.
\q1 
\v 5 I me pan kamaula ren Ieowa, o a pan pu\it n\it* kila ren Kot a jaunkamaur.
\q1 
\v 6 I kainok, me kin peiki on Kot, me kin rapaki jila\it n\it* omui, Kot en Iakop.
\q1 
\v 7 Komail riti\it n\it*ada wanim laud o la\it n\it*ada wanim nin jappa, pwe Nammarki li\it n\it*an en kotilo\it n\it*!
\q1 
\v 8 Ij Nanmarki li\it n\it*an men et? I Ieowa rojon o manaman, Ieowa me rajo\it n\it* nan mauin.
\q1 
\v 9 Komail riti\it n\it*da wanim laud o lanada wanim ni jappa, pwe Nanmarki li\it n\it*an en kotilo\it n\it*!
\q1 
\v 10 Ij Nanmarki li\it n\it*an men et? I Ieowa Jepaot; I Nanmarki li\it n\it*an.
\c 25
\q1 
\v 1 MAI\it N\it*, I kin ino\it n\it* io\it n\it* komui.
\q1 
\v 2 Ai Kot, I liki komui, jauaja ia, pwe I ender jarodi, o ai imwintiti kan ender peren kida.
\q1 
\v 3 Pwe karoj me liki komui, jota pan jarodi, a me pan muei ja\it n\it* komui pan jarodi.
\q1 
\v 4 Mai\it n\it*, kom kotin kajale o\it n\it* ia al omui kan, o kotin padaki o\it n\it* ia omui tiak kan;
\q1 
\v 5 Kalua ia ni omui melel o kaloleko\it n\it* ia! Pwe komui ta ai Kot, me kin jauja ia, ran karoj, I kin auiai komui.
\q1 
\v 6 Mai\it n\it*, kom kotin tamanada omui kala\it n\it*an o omui kapu\it n\it*lol, me tapidar mon kaua.
\q1 
\v 7 Re der kotin kupura dip en ai tikitik o ai jopeik; a kupure ia ni ar kupu\it n\it*lol o kala\it n\it*a\it n\it*! Mai\it n\it* Ieowa.
\q1 
\v 8 Ieowa me mau o lelapok, I me a kotin padaki o\it n\it* me dipan akan pon al o.
\q1 
\v 9 A kin kalua pu\it n\it* me luet akan, o a kotin padaki o\it n\it* me luet akan al a.
\q1 
\v 10 Al en Ieowa kan me dir en kala\it n\it*an o melel o\it n\it* ir, me kin kolekol a inau o majan akan.
\q1 
\v 11 Mai\it n\it*, kom kotin maki o\it n\it* ai ai japu\it n\it* kan me lapalap, pweki mar omui.
\q1 
\v 12 Ij ol, me kin Ian Ieowa? A pan kotin padaki o\it n\it* I duen al o, me a en pilada.
\q1 
\v 13 \it N\it*en e pan mi waja mau o kaudaudok a pan aneki jap o.
\q1 
\v 14 Ieowa kompoke pan me kin lan i, a pan kotin padaki on I duen a inau.
\q1 
\v 15 Maj ai kin ariri Ieowa anjau karoj, pwe a pan kotin jau karoj, pwe a pan kotin lapwada na I kat ja\it n\it* nan injar.
\q1 
\v 16 Kom kotin majan do\it n\it* ia, pwe \it n\it*ai japoupou o luet.
\q1 
\v 17 Majak en mo\it n\it*io\it n\it* I laluedalar; kotin kalua ia ja\it n\it* nan ai apwal akan!
\q1 
\v 18 Kom kotin ma\it n\it*i ai luet o ai kanka\it n\it*era\it n\it*er, o kotin maki o\it n\it* ia dip ai kan karoj!
\q1 
\v 19 Kom kotin ma\it n\it*i duen ai imwintiti kan, pwe re me toto, o re kin kailo\it n\it* kin ai ni ar aklapalap.
\q1 
\v 20 Kom kotin jinjila ai maur o dore ia la, kom kotin apwali ia, pwe I der namenokala, pwe I kin liki komui.
\q1 
\v 21 Melel o pu\it n\it* en jinjila ia, pwe I auiaui komui.
\q1 
\v 22 Mai\it n\it* Kot, kom kotin dorela Ijrael jan nan ar apwal akan karoj!
\c 26
\q1 
\v 1 IEOWA kom kotin jauaja ia, pwe I kekeit wei ni melel, I kin liki Ieowa, i jota pan luetala
\q1 
\v 2 Mai\it n\it* kom kotin kajaui ia da o kajo\it n\it*ejo\it n\it* ia, o kamakelekele mudilik I kan o mo\it n\it*io\it n\it* i.
\q1 
\v 3 Pwe I aja duen omui kala\it n\it*an, o I kin weweid ni omui melel.
\q1 
\v 4 I jota kin mondi ren aramaj aklapalap akan, o I jota kin waroki o\it n\it* me morjued akan.
\q1 
\v 5 I kin tataki pokon en mejued akan, o i jota kin mondi ren me japu\it n\it* kan.
\q1 
\v 6 I omiomi ki makelekel o i kin pok o\it n\it* japwilim omui pei jaraui, Mai\it n\it*, Ieowa.
\q1 
\v 7 Waja I pan kapikapi\it n\it*a, \it n\it*il laudeta o padak duen omui manaman akan karoj.
\q1 
\v 8 Mai\it n\it* Ieowa, I kin pok o\it n\it* wajan tanpaj omui, o wajan ar li\it n\it*an.
\q1 
\v 9 Kom der kotin kajapoke ia la ia\it n\it*aki me dipan akan, de maur I ia\it n\it*aki me kamela aramaj akan.
\q1 
\v 10 Pwe pa arail me dir en morjued o re ki men ale kijakij.
\q1 
\v 11 A \it n\it*ai kin weweid ni makelekel. Dore ia la o kotin maki o\it n\it* ia!
\q1 
\v 12 Na I kin aluwei pu\it n\it*. I pan kapina Ieowa nan momodijo kan.
\c 27
\q1 
\v 1 IEOWA kamarain pa I o kamaur pa i, ij me i en majak? Ieowa kel pan maur i, ij me I en lomwinki?
\q1 
\v 2 Ma mejued akan pan ta\it n\it*a do\it n\it* ia, pwen kawela uduk ai o ai imwintiti kan, re pan dipikelkel o pupedi.
\q1 
\v 3 Ma pwin jaunpei pan kapil ia pena, i jota pan majapwekada, o ma mauin pan wiaui o\it n\it* ia, I pan liki i.
\q1 
\v 4 Iet eta, me I ino\it n\it* io\it n\it* o men poeki ren Ieowa, I en mimita nan tanpaj en Ieowa arain ai maur, pwen kilekila\it n\it* jaraui kajelel en Ieowa kan, o ududial japwilim a im en kaudok.
\q1 
\v 5 Pwe ni anjau apwal a kotin jinila ia nan tanpaj a im pwal. A pan kotin karuk ia la nan tanpaj a im likau, o kotin kau ia da pon paip eu.
\q1 
\v 6 A pan kotin kajapwil ia da\it n\it* pon ai imwintiti kan, me kapil ia pena; i ap pan wiada mairo\it n\it* en kapi\it n\it* nan tanpaj a im pwal, i pan kaul o kapi\it n\it* o\it n\it* Ieowa.
\q1 
\v 7 Mai\it n\it*, kom kotin ereki \it n\it*il ai, ma I pan likwir o\it n\it* komui, kom kotin maki o\it n\it* ia o ma\it n\it*i ia.
\q1 
\v 8 Mo\it n\it*io\it n\it* i kin kataman kin komui omui majan: Komail rapakin ia! I me I pil kin rapaki jila\it n\it* omui. Mai\it n\it* Ieowa!
\q1 
\v 9 Der karir ja\it n\it* jila\it n\it* omui mo i, o der kajapokela japwilim omui ladu ni omui o\it n\it*io\it n\it*; pwe komui me jauja pa i. Kom der kotin kaje ia la, o ender muei jan I, Kota i jaunkamaur.
\q1 
\v 10 Pwe jam ai in ai likimalie ia la; a Ieowa kotin japwilim anekin ia la.
\q1 
\v 11 Mai\it n\it*, kom kotin kajale o\it n\it* ia japwilim omui al o kalua ia nani al pu\it n\it* pweki ai imwintiti kan.
\q1 
\v 12 Kom der kotin mueid o\it n\it* ai imwintiti kan en kaloe ia di; pwe jaunkadede likam palian ia, o re wia japu\it n\it* o\it n\it* ia jo majak.
\q1 
\v 13 Ari jo, I aja, me I pan ududial kala\it n\it*an en Ieowa nan jap en me memaur akan.
\q1 
\v 14 Auiaui Ieowa! Der majak, o mo\it n\it*io\it n\it* om ender majak, o auiaui Ieowa!
\c 28
\q1 
\v 1 MAI\it N\it*, ai paipalap, I lao likwir wo\it n\it* komui, kom der kotin japaimokid, pwe ma re pan japaimokid, i pan duet ir, me pan lokidokila nan por o.
\q1 
\v 2 Kom kotin ma\it n\it*i \it n\it*il en ai \it n\it*idi\it n\it*id, I lau likwir won komui, I lao kapa wo\it n\it* pa I kat mol omui jaraui.
\q1 
\v 3 Re der kotin kajapoko ia la ia\it n\it*aki me japu\it n\it* kan, ia\it n\it*aki me wia jued, me kin lokaia kajelel o\it n\it* men impa, ap lamelame jued nan mo\it n\it*io\it n\it* arail.
\q1 
\v 4 Kotin depuk o\it n\it* ir duen ar dodok o duen ar tiak jued; kotiki o\it n\it* ir duen dodok en pa arail; katini o\it n\it* ir duen ar wiawia.
\q1 
\v 5 Pwe re jota injenoki dodok en Ieowa de wiawia en lim a kan; e me a pan kotin kawe ir ala, a jota kauada.
\q1 
\v 6 Kapi\it n\it* o\it n\it* Ieowa, pwe a kotin erekier \it n\it*il en ai \it n\it*idi\it n\it*id.
\q1 
\v 7 Ieowa kel pa i o pere pa i, mo\it n\it*io\it n\it* i kin liki i, o jauaja pa i mia. Mo\it n\it*io\it n\it* i liki i o i pan danke i ki ai kaul.
\q1 
\v 8 Ieowa kelel parail; I me manaman o\it n\it* jauaja japwilim a me keidier.
\q1 
\v 9 Kotin jauaja japwilim omui aramaj omui jojo, o kotin kamana ir o apwali irail ada kokolata!
\c 29
\q1 
\v 1 KOMAIL lapalap akan, wa do\it n\it* leowa, wa do\it n\it* Ieowra wau o manaman!
\q1 
\v 2 Wa do\it n\it* leowa wau en mar a, po\it n\it*i leowa ni omail kapwat jaraui!
\q1 
\v 3 Kapiti en leowa mi pon pil akan; Kot en li\it n\it*an kin wiada nanjapwe, iei leowa en pil kalaimun akan.
\q1 
\v 4 Kapiti en leowa me manaman, kapiti en leowa me li\it n\it*an.
\q1 
\v 5 Kapiti en leowa kin katip paja\it n\it* jeder akan; leowa kin kotin katip paja\it n\it* jeder akan en Lipanon.
\q1 
\v 6 A kin kotin kalukaluj irail dueta kau pul amen, Lipanon o Jirion dueta kau pul ol amen.
\q1 
\v 7 Kapiti en leowa kin lujwei dueta umpul en kijiniai.
\q1 
\v 8 Kapiti en leowa kin kamokidada jap tan; leowa kotin kamokidada jap tan en Kadej.
\q1 
\v 9 Kapiti en leowa kin kamokidada tia kan o kakilejauiada nana kan, o nan tanpaj a im en kaudok karoj kin kapi\it n\it*a i.
\q1 
\v 10 Ieowa kotikot pon pil akan o Ieowa pan Nanmarki kokolata.
\q1 
\v 11 Ieowa pan kamanada japwilim a aramaj akan; Ieowa pan kotin kamaui japwilim a aramaj akan ki popol.
\c 30
\q1 
\v 1 I kapi\it n\it*a komui Mai\it n\it*, pwe komui me kotin kajapwil ia dar, o jota mueid o\it n\it* ai imwintiti kan ren peren kin ia da.
\q1 
\v 2 Ieowa, ai Kot, i likwir wo\it n\it* komui, komui ap kotin kakel ia dar.
\q1 
\v 3 Mai\it n\it*, kom kotin kalua \it n\it*en i ja\it n\it* nan wajan mela. Kom kotin dore ia lar ni anjau me irail lokidokila nan pweleko.
\q1 
\v 4 Komail lelapok kan en kapi\it n\it*a Ieowa, o kapi\it n\it*a mar a li\it n\it*an!
\q1 
\v 5 Pwe a o\it n\it*io\it n\it* kin marep ta ieu, a a mak arain maur en aramaj amen; nin jautik re kin ja\it n\it*eja\it n\it*, a ni manja\it n\it* \it n\it*iji\it n\it*ij.
\q1 
\v 6 A \it n\it*ai inda ni ai anjau mau: I jota pan lodi kokolata.
\q1 
\v 7 Mai\it n\it*, ni omui kala\it n\it*an, kom kotin kate\it n\it*edi ai dol, a ni anjau me re karuki ja\it n\it* mo i jila\it n\it* omui, i majapwekadar.
\q1 
\v 8 I likwir wo\it n\it* komui Mai\it n\it*, o i \it n\it*idi\it n\it*ideki o\it n\it* Kaun.
\q1 
\v 9 Da kadepa en nt’ ai, i lao kodila nan por o? Pwel par pan kak kapi\it n\it*a komui, o kapakaparok duen omui kalanan?
\q1 
\v 10 Mai\it n\it* Ieowa, re kotin ma\it n\it*i ia o kotin maki o\it n\it* ia; Ieowa jauaj pa i.
\q1 
\v 11 Kom kotin kawukila ai injenjued o\it n\it* \it n\it*iji\it n\it*ij; kom koti ki ja\it n\it*er ai tuken likau, ap id kalikauwi ia dar popol.
\q1 
\v 12 Pwe \it n\it*en i en kauli o\it n\it* komui, a ender nenenla. Mai\it n\it* ai Kot, i pan kapi\it n\it*a komui kokolata.
\c 31
\q1 
\v 1 MAI\it N\it*, i liki komui, kom kotin ieia\it n\it* ia, pwe i ender namenokala kokolata; dore kin ia la duen omui pu\it n\it*.
\q1 
\v 2 Kapaikidi do\it n\it* ia karo\it n\it* ar akan, mada\it n\it* jauaja ia! Kom kotin wiala ai paipalap rojo\it n\it*, o kele pa i, pwen jauaja ia!
\q1 
\v 3 Pwe komui ai paip, o ai kel. Kom kotin kalua ia pweki mar omui.
\q1 
\v 4 Kom kotin api ia ja\it n\it* nan injar, me re wiai o\it n\it* ia, pwe komui kele pa i.
\q1 
\v 5 I kakaliki o\it n\it* komui \it n\it*en i; kom kotin dore ia la, komui Mai\it n\it* Kot melel.
\q1 
\v 6 I juedeki me kin kaporoporeki dikedik en ani mal akan, a i liki Ieowa.
\q1 
\v 7 I pan pereperen o polauleki omui kala\it n\it*an, pwe komui me kotin ma\it n\it*i ai luet, o kotin kupura \it n\it*en i ni anjau apwal.
\q1 
\v 8 O re der mueid o\it n\it* ai imwintiti, ren kaloe ia di. Kom kotin kajone na i kat nan waja jalatok.
\q1 
\v 9 Ieowa, kom kotin maki o\it n\it* ia, pwe i majak; maj ai juedelar ki ai mamauk, pil dueta \it n\it*en I o pali war ai.
\q1 
\v 10 Pwe maur i luet kilar ai injenjued, o ai par akan malaulaular ki ai ja\it n\it*eja\it n\it*, ai kelail tikitikelar pweki dip ai, o kokon aikna luetalar.
\q1 
\v 11 Ai imwintiti kan karoj lalaue ia, o i wialar kanamenok pan men imp ai kan, o kamajak pan jau i kan; me kila\it n\it* ia nani al o, kin tanwei ja\it n\it* ia.
\q1 
\v 12 Aramaj monoke ia lar dueta me melar amen; \it n\it*ai rajo\it n\it* dal eu me mor paja\it n\it*.
\q1 
\v 13 Pwe i ro\it n\it*er duen me toto kin pujerokio\it n\it* ia; men kamajak kapil ia pena; re kin kapu\it n\it* pena duen \it n\it*ai, pwen kae ia la.
\q1 
\v 14 A I kin kaporoporeki komui Mai\it n\it*, I ap inda: Komui ta ai Kot!
\q1 
\v 15 Ai anjau mi nan lim omui, dore ai ja\it n\it* nan pa en ai imwintiti kan o ja\it n\it* me kin pakipaki ia.
\q1 
\v 16 Kamarainki japwilim omui ladu jila\it n\it* omui, dore ia ki omui, dore ia ki omui kala\it n\it*an.
\q1 
\v 17 Mai\it n\it*, kom der kotin mueid o\it n\it*, i en joredi; pwe i likwiri wo\it n\it* komui. Me japu\it n\it* kan en joredi, pwe irail en nenenla nan wajan mela.
\q1 
\v 18 Kil en au en me likam akan mi nenenla, irail, me lalaue me pu\it n\it* kan ni laumaum, o aklapalap, o kaurur.
\q1 
\v 19 Meid laud omui kala\it n\it*an, me kom kotin nekinekid o\it n\it* me Ian komui kan, o me kom kin kajale o\it n\it* ir, me liki komui janjal mon aramaj akan.
\q1 
\v 20 Kom kin kotin karir ir ala re omui ja\it n\it* karoj, me kailo\it n\it* kin ir, kom kin kadupal ir edi ja\it n\it* mon lo akamai.
\q1 
\v 21 Kapi\it n\it*a o\it n\it* Ieowa, me kotin kala\it n\it*an laud o\it n\it* ia nan kanim te\it n\it*ete\it n\it* eu.
\q1 
\v 22 Pwe ni ai peikajal i indindar: I lokidokilar ja\it n\it* mon jila\it n\it* ar. Ari jo, kom kotin ereki \it n\it*il en ai \it n\it*idi\it n\it*id, ni ai potoan wer wiwer o\it n\it* komui.
\q1 
\v 23 Komail japwilim a jaraui kan karoj, pok o\it n\it* Ieowa! Ieowa kin kotin jinjila me pojon akan, ap depuk o\it n\it* ir melel, me akla palap akan.
\q1 
\v 24 Komail karoj me kaporo poreki Ieowa, en kelail o der majak!
\c 32
\q1 
\v 1 MEID pai, me dip arail lap wadar, o me ar japu\it n\it* pwaipwaidier!
\q1 
\v 2 Aramaj meid pai, me Ieowa jolar pan kapokoki o\it n\it* dip ar, me jota likam nan mo\it n\it*io\it n\it* ar.
\q1 
\v 3 Pwe ni ai men okila, kokon ai kan ap jujueda kilar ai janojan ran karoj.
\q1 
\v 4 Pwe lim omui katoutou ia nin ran o ni po\it n\it*, o ai kelail mo\it n\it*edier, dueta ni anjau o\it n\it* karakar.
\q1 
\v 5 I me i weokada\it n\it* komui dip ai kan, o jota okila ai japu\it n\it* kan. \it N\it*ai indinda: I pan weokada\it n\it* Ieowa ai katiwo kan, komui ap kotin maki o\it n\it* la jued en dip ai.
\q1 
\v 6 I me jaraui kan karoj pan potoan kapakap o\it n\it* komui arain anjau me komui kak diarokda Lapake kalaimun pan wiaui a jota pan lel o\it n\it* ir.
\q1 
\v 7 Komui me pere pa i, kom pur kotin perawei ja\it n\it* ia men kamajak, i ap pan dorela o kapi\it n\it*a ni peren.
\q1 
\v 8 I pan padaki o\it n\it* uk o kajale o\it n\it* uk al o, me koe en weweid ia; I pan kalua kin uk por en maj ai.
\q1 
\v 9 Komail der dueta oj de aj amen me jota ar madamadaua, me mau o\it n\it*, kijin mata en ko o\it n\it* au arail, a ma jo, re jota pan duki o\it n\it* uk.
\q1 
\v 10 Me japu\it n\it* o kin lodi o\it n\it* jo\it n\it* en madak to to, a me kaporoporeki Ieowa, kala\it n\it*an en Ieowa pan kapil pena i.
\q1 
\v 11 Polauleki Ieowa, o pereperen komail me pu\it n\it* kan, o kapikapi\it n\it*a komail karoj me lelapok melel akan.
\c 33
\q1 
\v 1 KOMAIL me pu\it n\it* kan polauleki Ieowa, me lelapok kan en kapi\it n\it*a i.
\q1 
\v 2 Danke Ieowa o kapikapi\it n\it*a ki men kaja\it n\it* o kaule ki o\it n\it* i jal en arp eijok.
\q1 
\v 3 Kauleki o\it n\it* i kaul kap pot, komail kanai o\it n\it* arp o \it n\it*il!
\q1 
\v 4 Pwe maj an en Ieowa me inen o a wiawia kan karoj melel.
\q1 
\v 5 A kin kotin pok o\it n\it* me pu\it n\it* o melel, jappa direki kala\it n\it*an en Ieowa.
\q1 
\v 6 Nanla\it n\it* wiaui kida majan en Ieowa o audepan a karoj ki \it n\it*en en jila\it n\it* i.
\q1 
\v 7 A kotin kolekol pena pil en madau dueta nan dal eu, o a kotin nekidala ad akan nan waja rir.
\q1 
\v 8 Jappa karoj en lan Ieowa o karoj me kaukaujon nan jappa en wauneki i.
\q1 
\v 9 Pwe ma a kotin majanta, ap pan wiaui, o ma a kotin panokada, ap pan miela.
\q1 
\v 10 Ieowa kin kotin kawela kapu\it n\it* en men liki kan, o a kin kawukila madamadaua en wei kan.
\q1 
\v 11 A me Ieowa kileledier, pan duedueta, o me a kotin kupurada, pan kokolata.
\q1 
\v 12 Meid pai wei o, me Ieowa ar Kot, o wei, me a kotin pilada\it n\it* a jojo.
\q1 
\v 13 Ieowa kin kotin irero\it n\it* aramaj akan karoj ja\it n\it* nanla\it n\it*.
\q1 
\v 14 A kotin irero\it n\it* karoj, me kaujon jappa jan mol a teneten.
\q1 
\v 15 A kotin wiadar mo\it n\it*io\it n\it* arail karoj, o a kotin ma\it n\it*i ar wiawia kan karoj.
\q1 
\v 16 Nanmarki amen jota pan pwai kida a karij toto, o ol komad amen jota pan dore kila a kelail.
\q1 
\v 17 Oj akan pil jota kak jauaja ekij o a kelail melel jota kadepa.
\q1 
\v 18 Kila\it n\it*, jila\it n\it* en Ieowa kin irero\it n\it* o\it n\it* me lan i, o me kaporoporeki a kala\it n\it*an.
\q1 
\v 19 Pwen kapit ir ala ja\it n\it* ni mela o katekatu\it n\it*ole ni anjau en lek.
\q1 
\v 20 \it N\it*en atail kin auiaui Ieowa, i me jauaj patail o pere patail.
\q1 
\v 21 Pwe mo\it n\it*io\it n\it* atail kin peren kida i, pwe kitail kin liki mar a jaraui.
\q1 
\v 22 Mai\it n\it*, Ieowa, omui kala\it n\it*an en mi po at duen at kaporoporeki komui.
\c 34
\q1 
\v 1 I PAN kapi\it n\it*a Ieowa anjau karoj; au ai pan kapi\it n\it*a i kokolata.
\q1 
\v 2 \it N\it*en i en juaiki Ieowa, me luet akan pan ro\it n\it*, ap peren kida.
\q1 
\v 3 Komail ia\it n\it* ia kapi\it n\it*a Ieowa, pwe kitail en wiaki eu, kala\it n\it*ada mar a.
\q1 
\v 4 Ni ai rapaki Ieowa, a kotin jape\it n\it* ia, o dore ia la ja\it n\it* nan ai majak karoj.
\q1 
\v 5 Me ariri i, pan kakelada, a maj arail jota pan namenokala.
\q1 
\v 6 Ol luot men et lao likwir, Ieowa ap kotin erekier o dorela i ja\it n\it* nan a apwal akan karoj.
\q1 
\v 7 Toula\it n\it* en Ieowa kotikot ren me Ian i o kotin jauaja ir.
\q1 
\v 8 Komail jo\it n\it* o kila\it n\it* duen kala\it n\it*an en Ieowa! Meid pai, me liki i!
\q1 
\v 9 Lan Ieowa japwilim a jaraui kan! pwe me kin lan i, jota pan anane meakot.
\q1 
\v 10 Laien pulepul akan lekila o men manada, a me kin rapaki Ieowa, jota pan anane meakot.
\q1 
\v 11 Jama ko, komail kodo re i, ro\it n\it* ia, i pan padaki o\it n\it* komail duen lan Ieowa:
\q1 
\v 12 Ij me ino\it n\it* io\it n\it* maur warai, o ij me mauki ran kajelel akan?
\q1 
\v 13 Pere ja\it n\it* mejued lo om o kilin au om, pwe re der kotaue.
\q1 
\v 14 A muei ja\it n\it* mejued, ap wiada me mau, rapaki popol ap dadaurata.
\q1 
\v 15 Jila\it n\it* en Ieowa mama\it n\it*i me pu\it n\it* kan, o karo\it n\it*a ereki ar likwir;
\q1 
\v 16 jila\it n\it* en Ieowa kin palian ir, me kin wia mejued, pwen kawe ir ala ja\it n\it* nan jappa.
\q1 
\v 17 Irail kin likwir, Ieowa ap kotin ma\it n\it*i ir o kotin jauaja ir ja\it n\it* ni ar apwal akan karoj.
\q1 
\v 18 Ieowa koren io\it n\it* ir, me mo\it n\it*io\it n\it* arail arail olar, o kotin jauja ir, me \it n\it*en arail olar.
\q1 
\v 19 Kalokolok toto lel o\it n\it* mo pun kan, a Ieowa kin kotin jauaja ir ja\it n\it* nan mepukat karoj.
\q1 
\v 20 A kotin jinjila kokon akan karoj, pwe eu ender tip paja\it n\it*.
\q1 
\v 21 Me jued kot pan kamela mo doo ja\it n\it* Kot akan, o me kin kailo\it n\it*ki me pu\it n\it* kan, pan kalokolok.
\q1 
\v 22 Ieowa kin kotin dorela \it n\it*en en japwilim a ladu kan, o karoj me liki i jota pan kalokolok.
\c 35
\q1 
\v 1 MAI\it N\it*, kom kotin pei o\it n\it* ir, me kin pei o\it n\it* ia; o kotin palian o\it n\it* ir, me kin u o\it n\it* ia.
\q1 
\v 2 Re kotin ale pere o tatan mauin ap kotida, pwen jauaja ia.
\q1 
\v 3 \it N\it*apekida katieu jauaja ia o\it n\it* ai imwintiti kan. Kotin majan do\it n\it* \it n\it*en i: \it N\it*ai jauaj pam!
\q1 
\v 4 Me men kame ia la, en namenokala o kankaururala; o me men wia jued o\it n\it* ia, en pure wei o jarodi.
\q1 
\v 5 Ren wiala dueta dip en kijin war akan mon kijinia\it n\it*, o tounla\it n\it* en Ieowa jikin irail wei.
\q1 
\v 6 Al arail en rotorotala o kitentel la, o tounla\it n\it* en Ieowa o\it n\it* kotin pakipaki irail.
\q1 
\v 7 Pwe re injenjara ia, pwen kame ia la, ap jota karepa, o re wia por o\it n\it* ia, a jota karepa.
\q1 
\v 8 A en jejeinlek lodi o\it n\it* kalokolok; o injar me a wiadar, pein i en lodi o\it n\it*; o mela o\it n\it* lel o\it n\it* i waja o.
\q1 
\v 9 A \it n\it*en i en perenki Ieowa o polauleki a kotin jauaja ia.
\q1 
\v 10 Kokon ai kan karoj pan inda: Mai\it n\it*, ij me rajo\it n\it* komui? Pwe kom kotin jauaja me luet o o\it n\it* me a jota itar o\it n\it*, o kom kotin jauaja me luet o jamama o\it n\it* me lolap akan.
\q1 
\v 11 Jaunkadede likam kai u o\it n\it* ia, kalelapok re i, me i jota aja due.
\q1 
\v 12 Re kin depukki me mau me jued, pwen kainjenjuede kin ia.
\q1 
\v 13 A \it n\it*ai, ni ar jomau, i puri o\it n\it* nan tuk en likau, o kaloke pein \it n\it*ai ni ai kaijejol, o kapakap jan mo\it n\it*ion i.
\q1 
\v 14 \it N\it*ai wiai o\it n\it* ir dueta o\it n\it* kompoke pa i o udan ri ai; \it n\it*ai injenjued dueta amen, me kin loleitki in a.
\q1 
\v 15 A irail peren kida ai jikilikel o pokon pena. Men lalaue pokon penan ia o jo\it n\it* en aramaj, me i jaja, kin lalaue ia anjau karoj.
\q1 
\v 16 Re \it n\it*i tete o\it n\it* ia, irail, me kin janjalmau o lalaue pweki kijin ma\it n\it*a.
\q1 
\v 17 Mai\it n\it*, arai da, me kom pan kotin majani mepukat? Dorela \it n\it*en i ja\it n\it* arail me jued, o maur ta ieu ia\it n\it* laien pulepul akan.
\q1 
\v 18 I pan kapi\it n\it*a komui nan momodijou laud, o nan pu\it n\it* en aramaj toto i pan danke komui.
\q1 
\v 19 Der mueid o\it n\it* ai imwintiti nin jokarepa, ren peren kin ia, o me kin kailon kin ia nin jokarepa, ren der lalaue ia ki maj arail.
\q1 
\v 20 Pwe ar lokaia jota kin kareda popol, o re kin madamadaua, en dipi o\it n\it* me lelapok kan nan jap o.
\q1 
\v 21 O re jar pajan au arail o\it n\it* ia indada: Io io, pein kit kila\it n\it*er.
\q1 
\v 22 Mai\it n\it*, kom kotin ma\it n\it*i mepukat, kom der kotin nenenla, Mai\it n\it*, kom der doo ja\it n\it* ia!
\q1 
\v 23 Kotin opala waja o kipada, pwen kapu\it n\it* ia la o ai dodok, ai Kot o ai Kaun.
\q1 
\v 24 Mai\it n\it*, ai Kot, kotin kapu\it n\it* ia la duen omui pu\it n\it*, pwe ren der peren kin ia.
\q1 
\v 25 Der mueid o\it n\it*, ren inda nan mo\it n\it*io\it n\it* arail: Io, io, i me je men! Der mueid o\it n\it*, ren inda: Kitail katalalar i.
\q1 
\v 26 Irail karoj, me peren kida ai apwal akan, en namenokala o kankaurura la, ir me poponmajo o\it n\it* ia, en likau kida namenok o kankaurur.
\q1 
\v 27 Irail me kin peren kida ai pu\it n\it* en \it n\it*iji\it n\it*ij o pereperen, o ren inda anjau karoj: Meid kapi\it n\it*a o\it n\it* Ieowa, me kin perenki jauaja japwilim a ladu o,
\q1 
\v 28 O lo i en kapakaparok duen omui pu\it n\it*, o kapi\it n\it*a komui ran karoj.
\c 36
\q1 
\v 1 IET me i men inda ja\it n\it* lol en mo\it n\it*io\it n\it* i duen tiak en me japu\it n\it* o: Jota lan Kot mi mon maj a.
\q1 
\v 2 A kin kotaue o li\it n\it*kapi\it n\it*, pwen pein i dadaurata a dodok jued, ap tataki me tei kan.
\q1 
\v 3 A lokaia karoj me jued o likam; a pil jota kin duki o\it n\it* padak, pwen wiada me mau.
\q1 
\v 4 A kin madamadaua pon a loj. A kin weweid nani al me jota mau o jota kin juedeki me japu\it n\it*.
\q1 
\v 5 Mai\it n\it*, omui kala\it n\it*an me ideda wo\it n\it* la\it n\it*, o omui melel pil lel o\it n\it* tapok kan.
\q1 
\v 6 Omui pu\it n\it* rajo\it n\it* nana en Kot akan, o omui kadeik kan me rajo\it n\it* iluk ileile kalank; Mai\it n\it*, komui me kotin dorela aramaj o man akan.
\q1 
\v 7 Meid kajampwal omui kala\it n\it*an Mai\it n\it* Kot, pwe aramaj akan kin diar wajan kamaio pan mot en lim omui!
\q1 
\v 8 Re pan jaliel kila dipijou toto nan tanpaj omui, o kom kotin kanim pil kin irail peren laud rajo\it n\it* pilap pot.
\q1 
\v 9 Pwe parer o\it n\it* maur mi re omui, o ni omui marain, je kin kila\it n\it* marain.
\q1 
\v 10 Kom kotin dadaurata omui kala\it n\it*an o\it n\it* mo aja komui, o omui pu\it n\it* o\it n\it* me melel ja\it n\it* ni mo\it n\it*io\it n\it* arail.
\q1 
\v 11 Kom der mueid o\it n\it*, i en tiatidi pan me aklapalap akan, o pa en me japu\it n\it* kan ender kapup ia di.
\q1 
\v 12 A mejued akan en pupedi waja o, pwen ren lokidokila o jolar memaureda.
\c 37
\q1 
\v 1 KOE dor makaraki me jued akan; o dor peirinki me kin wia japu\it n\it*.
\q1 
\v 2 Pwe re pan jorala mada\it n\it* jora lii ni, o ro pan monedi dueta tan tuka kan.
\q1 
\v 3 Kaporoporeki Ieowa o wiada me amu, kaukaujonta nan jap o, o wiawia me pun.
\q1 
\v 4 Plauleki Ieowa, a pan kotiki on uk, me mo\it n\it*ion om ino\it n\it* io\it n\it*.
\q1 
\v 5 Mueid o\it n\it* Ieowa om wiawia kan o kaporoporeki i, a pan kotin wia mau.
\q1 
\v 6 A pan kapwareda o\it n\it* wiawia me pu\it n\it* dueta marain, o om tiak pu\it n\it* dueta nin jauaj.
\q1 
\v 7 Kaporoporeki Ieowa ap nenenla o auiaui, o koe der makar kida pan me kin pwaida ni a wiawia kan, ol o, me kin kapwaida me jued.
\q1 
\v 8 Muei ja\it n\it* makar o pwilikidi om linaranar; koe der makar, pwe koe der pil wia me jued.
\q1 
\v 9 Pwe me jued akan pan kokoka ja\it n\it*, a me liki leowa, pan japa\it n\it*eki jap o.
\q1 
\v 10 Anjau takij, ap jolar me japu\it n\it* o, o ma koe men kila\it n\it* deu a, a jolar mia.
\q1 
\v 11 A me opampap akan pan jojoki jap o, o re pan pereperen ki ar kapwa toto.
\q1 
\v 12 Me japu\it n\it* o kin kamajak me pu\it n\it* o, o ni tete o\it n\it* i.
\q1 
\v 13 A leowa kotin kiparamateki i, pwe a kotin ma\it n\it*i a anjau.
\q1 
\v 14 Me japu\it n\it* kan kin nape kida kodlaj o kaonopada kajik katieu, pwen kajikiedi me luet o jamama, o kamela me kekeit wei ni melel.
\q1 
\v 15 A ar kodlaj pan dokodi pein mo\it n\it*io\it n\it* arail, o ar kajik katieu pan tip paja\it n\it*.
\q1 
\v 16 Me malaulau en me pu\it n\it* amen, me mau ja\it n\it* dipijou toto en me japu\it n\it* kan.
\q1 
\v 17 Pwe pa en me japu\it n\it* kan pan tip paja\it n\it*, a leowa pan kotin kolekol me pu\it n\it* kan.
\q1 
\v 18 leowa kotin ma\it n\it*ier ran en me lelapok kan, o ar dipijou pan duedueta.
\q1 
\v 19 Re jota pan namenokala ni anjau apwal, o ni anjaun lok a pan itar o\it n\it* ir.
\q1 
\v 20 Pwe me japu\it n\it* kan pan lokidokila, o imwintiti o\it n\it* leowa, ma re rajo\it n\it* jap kajelel eu, re pil pan mokonaidi duota at itiniai.
\q1 
\v 21 Me japu\it n\it* kan kin pwaipwand ap jota kapu\it n\it*ala, a me pu\it n\it* o kin kadek o kin kijakija wei.
\q1 
\v 22 Pwe me paie kin i, pan jojoki jap o, a me a kotin karialar akan pan kokoka ja\it n\it*.
\q1 
\v 23 Ieowa kin kotin kate\it n\it*ete\it n\it*e jo\it n\it* en aramaj due met ar kakakewei, o a kotin peren kida a wiawia kan.
\q1 
\v 24 Ma a pan pupedi, a jota pan lokidokila; pwe Ieowa kotin kolekidi i lim a.
\q1 
\v 25 \it N\it*ai pulepul ap malar, a i jaikenta kila\it n\it*er me pu\it n\it* amen likidmalielar, de na kan poekipoeki prot.
\q1 
\v 26 A kin kadek anjau karoj o kin men kijakij wei, o na kan pan paida.
\q1 
\v 27 Muei ja\it n\it* me jued ap wia me mau, koe ap pan mimieta nan jap o.
\q1 
\v 28 Pwe Ieowa kotin peren kida me pu\it n\it*, o a jota pan kotin likid maliela japwilim a jaraui kan; re pan nekinek kokolata, a kadaudok en me japu\it n\it* kan pan kokoka ja\it n\it*.
\q1 
\v 29 Me pu\it n\it* kan pan jojoki jap o, ap mimieta kokolata.
\q1 
\v 30 Au en me pu\it n\it* amen kin kida me loleko\it n\it*, o lo a kaparokki me pu\it n\it*.
\q1 
\v 31 Majan en a Kot mi nan mo\it n\it*io\it n\it* i, a jota pan krijedi.
\q1 
\v 32 Me japu\it n\it* kin majamajan me pu\it n\it*, pwen kamela i.
\q1 
\v 33 A Ieowa jota pan kotin mueid o\it n\it*, en mi nan pa a kan, o a jota pan kotin kajela i, a lao pan pakadeikada.
\q1 
\v 34 Auiaui Ieowa o weweid nan a al akan, a ap pan kotin kajapwil uk ada, pwe koe en jojoki jap o; koe pan kila\it n\it*, me japu\it n\it* kan pan kokoka ja\it n\it*.
\q1 
\v 35 I kila\it n\it*er me doo ja\it n\it* Kot amen, me katiwo o pwaida o maurada dueta tuka mau pot.
\q1 
\v 36 A ni at dauli waja o, kila\it n\it*, a joer mia; i idok duen i, a a jolar kak diarokada.
\q1 
\v 37 Dadaurata om lelapok, o wiawia me pu\it n\it*; pwe jo\it n\it* due met pan pwaida mau ni imwi.
\q1 
\v 38 A me katiwo kan pan wiaki eu lokidokila, o me japu\it n\it* kan pan koka ja\it n\it* ni imwi.
\q1 
\v 39 A Ieowa kotin jauaja me pu\it n\it* kan, i me kele parail ni ar apwal akan.
\q1 
\v 40 O Ieowa pan kotin ieia\it n\it* ir o pan dore ir ala; A pan kotin dore ir ala ja\it n\it* me japu\it n\it* kan, o a pan jauaja ir, pwe re kin liki i.
\c 38
\q1 
\v 1 MAI\it N\it*, der kotin kaloke ia ni omui kupur jued, o der kame ia ni omui o\it n\it*io\it n\it*.
\q1 
\v 2 Pwe japwilim omui kana\it n\it*an kajik katieu lei do\it n\it* ia, o lim omui katoutou ia.
\q1 
\v 3 Jota mau kot ni pali war ai pweki omui o\it n\it*io\it n\it*, o jota moleilei nan kokon ai kan pweki dip ai
\q1 
\v 4 Pwe dip ai kin kadupaledi mon ai, re kin katoutou ia dueta meakot me toutou melel.
\q1 
\v 5 Ai ola kan pojuedelaonanan pweki ai pweipwei.
\q1 
\v 6 I kin koj pena o pairok wei alialu, i kin injenjued anjau karoj,
\q1 
\v 7 Pwe lo\it n\it*elo\it n\it* ai mo\it n\it*edier melel, o jota mau kot ni pali war ai.
\q1 
\v 8 \it N\it*ai Iuetalar melel o i wokiwok paja\it n\it*er. I kin ja\it n\it*eja\it n\it*, pweki mo\it n\it*io\it n\it* i jota kak moleilei.
\q1 
\v 9 Mai\it n\it*, kom kotin ma\it n\it*i ai ino\it n\it* karojo ai ja\it n\it*eja\it n\it*, o ai jota rir ja\it n\it* komui.
\q1 
\v 10 Mo\it n\it*io\it n\it* i rerer, ai kelail ko ja\it n\it*er i, o marain en maj ai pil rotolala.
\q1 
\v 11 Kompoke pai o ai warok kan kin doo wei ja\it n\it* ia, o juedeki ai kalokolok, o jau i kan kin doo ja\it n\it* ia.
\q1 
\v 12 O me kin ino\it n\it* io\it n\it* kameia la, kin majmajan ia, o me men wia jued o\it n\it* ia, kin indinda duen ar pan wiada dodok jued, o re kin widwidi\it n\it* anjau karoj.
\q1 
\v 13 A \it n\it*ai dueta me jalo\it n\it*epon amen, me jota ro\it n\it* waja, o dueta, o duata me loto\it n\it*, me jota kak jar paja\it n\it* au a.
\q1 
\v 14 \it N\it*ai dueta ol amen me jolar ro\it n\it* waja, o jota depuk en lokaia mi nan au ai.
\q1 
\v 15 A I kin awiawi Komui Mai\it n\it* ai Kot pan kotin jape\it n\it* ia.
\q1 
\v 16 Pwe i men, ren der peren kin ia. Ma na I pan krijedi, re pan peren kida melel.
\q1 
\v 17 Pwe i koren io\it n\it* pupedi, o ai kalokolok kin koren io\it n\it* ia anjau karoj.
\q1 
\v 18 Pwe I weokada dip ai kano juedeki dip ai.
\q1 
\v 19 A ai imwintiti kan memauretat o irail me kelail; me kailo\it n\it* kin ia ni jota karepa me toto.
\q1 
\v 20 O me kin depukki ai me mau me jued, kin palian ia, pweki ai dadaurata me mau.
\q1 
\v 21 Ieowa ai Kot, kom der muei ja\it n\it* ia o der doowei ja\it n\it* ia!
\q1 
\v 22 Kom kotin mada\it n\it* do\it n\it* ia, Main jauja pa i.
\c 39
\q1 
\v 1 \it N\it*ai kan, pwe i ender wia dip ki lo i. I pan jali pena au ai arain en me japun o mi re i.
\q1 
\v 2 I kadukiedier ai lokaia o nenenlar o jolar inda duen peren a ai kalokolok lalaudalar.
\q1 
\v 3 Mo\it n\it*io\it n\it* i karakaradar nan kapedi, o ma i pan tamanda mepukat, a rajo\it n\it* kijiniai lulada; i ap lokaia kida lo i.
\q1 
\v 4 Mai\it n\it*, kotin padaki o\it n\it* ia, me maur i pan imwijokela, o imwi pan ai ran akan, me i pan jamoer.
\q1 
\v 5 Ma\it n\it*i, ai ran akan dueta talap en pa en aramaj re omui; o maur i likamata jota meakot mo ’mui. Melel aramaj, me kin keleki pein i, kin dueta adiniai.
\q1 
\v 6 Re kin alialu jili rajo\it n\it* mota, re kin katoutouki pein irail dodok mal. Re kin nanak pena ap jaja, ij me pan naineki.
\q1 
\v 7 Ari Mai\it n\it*, ij me i en auiaui? I kaporoporeki komui.
\q1 
\v 8 Dore ia la ja\it n\it* dip ai karoj, o kom der mueid o\it n\it*, me pweipwei kan en kaurur kin ia.
\q1 
\v 9 I pan nenenla o jota jar paja\it n\it* au ai, pwe kom kotin wiadar.
\q1 
\v 10 Kotin katukiedi omui kaloko ia; pwe \it n\it*ai dupok kilar ai kalokolok pan lim omui.
\q1 
\v 11 Ma kom pan kaloke amen pweki dip a, mom a kajelel ap pan juedala likamada man en mot ka\it n\it*ala. O meid mal aramaj karoj!
\q1 
\v 12 Mai\it n\it* kom kotin ereki ni kapakap, o ma\it n\it*i ai likwir, o der japaimokid ni ai ja\it n\it*eja\it n\it*, pwe \it n\it*ai japwilim omui men kairu o pweledan omui wei men dueta jam ai kan karoj.
\q1 
\v 13 Kom kotin muei ja\it n\it* ia, pwe i en kelailada, mon ai pan kokowei o jolar mia.
\c 40
\q1 
\v 1 I AUIAUIER Ieowa, o a kotin iroir do\it n\it* ia o kotin erekier ai likelikwir.
\q1 
\v 2 A kotin api ia da ja\it n\it* nan por jued o ja\it n\it* waja lujujur, o kotin kajonedier na i kat pon paip eu, pwen kak alu mau;
\q1 
\v 3 O a kotiki o\it n\it* nan au ai kaul kap pot, pwen kapi\it n\it*a atail Kot; i me aramaj toto pan udial ap lan Ieowa o kaporoporeki i.
\q1 
\v 4 Meid pai ol o me kaporoporeki Ieowa o jota waroki o\it n\it* me aklapalap akan, de me weweid nin tiak likam!
\q1 
\v 5 Mai\it n\it* ai Kot, meid kapuriamui japwilim omui dodok kan o omui madamadaua, me komui kotin kajale o\it n\it* kit. Jota me rajo\it n\it* komui. I men kaparok o kajokajoi duen, a re jota mau o\it n\it* wadok.
\q1 
\v 6 Kom jota kotin kupura mairo\it n\it* man de mairo\it n\it* wan tuka kan; a kom kotin kawajak paja\it n\it* jalo\it n\it* ai; kom jota kotin mauki mairo\it n\it* ijij de mairo\it n\it* en dip.
\q1 
\v 7 \it N\it*ai ap inda: Kila\it n\it*, I kokodo; nan puk o me inti\it n\it*idier duen \it n\it*ai.
\q1 
\v 8 I men kapwaiada kupur omui, ai Kot; o japwilim omui kapu\it n\it* o mi nan lol en mo\it n\it*io\it n\it* i.
\q1 
\v 9 I pan padaki o\it n\it* momodijou laud duen me pu\it n\it*. Kila\it n\it*, i jota pan nenenla, Mai\it n\it* kom kotin ma\it n\it*i.
\q1 
\v 10 I jota okila omui pu\it n\it* nan mo\it n\it*io\it n\it* i. I kin kapakaparok duen omui melel o maur, i jota kin okila omui kala\it n\it*a\it n\it* o melel mon momodijou laud.
\q1 
\v 11 A komui Mai\it n\it* der kotiki ja\it n\it* ia omui kala\it n\it*a\it n\it*, omui kala\it n\it*an o melel en jinjila ia anjau karoj.
\q1 
\v 12 Pwe ai kalokolok kapil ia pena, o re jota mau o\it n\it* wadok; dip ai katoutou ia, i ap jolar kila\it n\it* waja; ir me toto ja\it n\it* pit en mo\it n\it* ai, ap jolar a\it n\it*ia\it n\it*.
\q1 
\v 13 Kom kotin kupura ia Mai\it n\it*, o kotin dore ia la; Mai\it n\it* kom kotin jauaja mada\it n\it*!
\q1 
\v 14 Me kin majamajan ia, pwen kame ia la, en namenokala o lijela; me men wia jued o\it n\it* ia, en purewei o lijela.
\q1 
\v 15 Ir me kin likelikwirki due ai: “Io, io!” en majak o lijela.
\q1 
\v 16 Karoj me idok komui, en pereperen o popol. O me pok o\it n\it* omui maur, anjau karoj ren inda: Meid kapi\it n\it*an Ieowa!
\q1 
\v 17 Pwe \it n\it*ai jamama o luet; a Ieowa kin kotin apwali ia. Komui jauaj pa i o ai jaundor; ai Kot, kom der kotin pwand!
\c 41
\q1 
\v 1 MEID pai me kin apwali me jamama o. Ieowa pan kotin dorela i ni ran apwal.
\q1 
\v 2 Ieowa pan kotin apwali i o jinjila a maur, o a pan pwaida nin jappa, o a jota pan mueidala i nan pa en a imwintiti kan.
\q1 
\v 3 Ieowa pan kotin kakelada i ni a pan mela; kom kin kotin jauaja i ni a jomau karoj.
\q1 
\v 4 \it N\it*ai inda: Mai\it n\it*, kom kotin maki o\it n\it* ia; kakelada \it n\it*en i, pwe \it n\it*ai wiadar dip o\it n\it* komui.
\q1 
\v 5 Ai imwintiti kan kin lokaia jued duen \it n\it*ai. lad a pan mela mara pan ririla?
\q1 
\v 6 A kin kodo\it n\it* kila\it n\it* ia, a kin lokelokaia due.
\q1 
\v 7 Karoj me kailo\it n\it* kin ai, kin lidilidumo\it n\it*in kin ia, o re madadaue jued duen \it n\it*ai.
\q1 
\v 8 Me juedkot mi re a; a pupedier o jolar pan uda.
\q1 
\v 9 Pil kompoke pa i, me I liki, o me ia\it n\it* ia ma\it n\it*ama\it n\it*a, kin tiaki ia di.
\q1 
\v 10 A komui Mai\it n\it* kotin maki o\it n\it* ia, o kau ia da, pwe ai imwintiti eder \it n\it*iji\it n\it*ij kin ia.
\q1 
\v 11 I me I pan ajaki, me kom kotin kupura ia, pwe ai imwintiti ender \it n\it*iji\it n\it*ij kin ia.
\q1 
\v 12 A kom kin kolekol ia pweki ia lelapok, o kom pan kotin kajone ia di mon jila\it n\it* omui kokolata.
\q1 
\v 13 Kapi\it n\it*a o\it n\it* Ieowa, Kot en Ijrael ja\it n\it* met o kokolata! Amen, Amen.
\c 42
\q1 
\v 1 Duen tia amen ino\it n\it* io\it n\it* pil iduen \it n\it*en i kin ino\it n\it* io\it n\it* komui o Kot.
\q1 
\v 2 \it N\it*en i ino\it n\it* io\it n\it* Kot, o\it n\it* Kot ieiaij. Iad I pan lel waja o, me I pan ariri jila\it n\it* en Kot.
\q1 
\v 3 Pil en maj ai, iei kan ai ma\it n\it*a ni ran o ni po\it n\it*, pwe irail kin inda\it n\it* ia ran karoj: ia om Kot?
\q1 
\v 4 Ma i madamadaua duen mepukat, i ap wudokila audepan mo\it n\it*io\it n\it* i o\it n\it* pein \it n\it*ai, pwe i ino\it n\it* io\it n\it* ia\it n\it* pokon o kokodala\it n\it* tanpaj en Kot, o i men ia\it n\it* pokon, me kin wiada a ran, pereperen o kapikapina.
\q1 
\v 5 \it N\it*en i, da me koe injenjuedeki o jota moleileiki? Auiaui Kot! I pan puro\it n\it* kapi\it n\it*a i. Pwe a kotin jauaja kin ia jila\it n\it* i.
\q1 
\v 6 Ai Kot, \it n\it*en i me injenjued; I ap madamadaua duen komui nan jap en kailan Iordan o Ermonin, pon dol Mijar.
\q1 
\v 7 Japwilim omui pil akan \it n\it*iri\it n\it*irjok, pil laud akan \it n\it*iri\it n\it*irjok; japwilim omui iluk kan karoj kadupal ia di.
\q1 
\v 8 Ieowa kotin inaukidar a kalanan ni ran, a ni po\it n\it* i kin kauli o\it n\it* i, o i kapakap o\it n\it* Kot en maur i.
\q1 
\v 9 I kin inda\it n\it* Kot ai paip: Da me kom kotin likidmalie kin ia la? Da me i en weweideki ni injenjued pweki ai imwintiti kelail o\it n\it* ia?
\q1 
\v 10 Likamata kokon ai kan mut paja\it n\it*er, ni ai imwintiti lalaue ia. Pwe re kin inda\it n\it* ia ran karoj: Ia om Kot?
\q1 
\v 11 \it N\it*en i, da me koe injenjuedeki o jota moleileiki? Auiaui Kot! Pwe i pan danke i, pwe i jauaj pan maj ai o ai Kot.
\c 43
\q1 
\v 1 MAI\it N\it* Kot! Kotin jauaja ai pu\it n\it*, o kotin ieia\it n\it* ia nan kapu\it n\it* o\it n\it* aramaj jued pukat, o kotin dore ia la ja\it n\it* aramaj likam o morjued akan.
\q1 
\v 2 Pwe komui Kot en ai kel; da me kom kotin kaje kin ia la? Da me kom kotin mueid o\it n\it*, i en weweidwei ni ai injenjued, ma ai imwintiti kelail o\it n\it* ia?
\q1 
\v 3 Kom kotin kadarado omui marain o melel, pwe ira en kalua ia, o wa ia la\it n\it* ni omui dol jaraui o tanpaj omui.
\q1 
\v 4 Pwe i en pedelo\it n\it* o\it n\it* nan pei jaraui en Kot, iei Kot me kaperen pa i o kapol pa i, o i en danke komui Kot ki arp, ai Kot.
\q1 
\v 5 \it N\it*en i, da me koe injenjuedeki o jota moleileiki? Aui aui Kot! Pwe i pan danke i, pwe i jauaj pan maj ai o ai Kot.
\c 44
\q1 
\v 1 MAI\it N\it* Kot, je ro\it n\it*er ki jalo\it n\it* at, jam at oko kajokajoi o\it n\it* kit er, me kom kotin wiadar ni ar anjau maj.
\q1 
\v 2 Kom kotin pakiweier men liki kan ki lim omui, ap wilian ir di; kom kotin koko ja\it n\it* wei kan, ap id katotoe ir ala.
\q1 
\v 3 Pwe re jota kaloedier jap o ki ar kodlaj, o pa arail jota katepa o\it n\it* ir, pwe pali maun omui o lim omui, o marain en jila\it n\it* omui; pweki kom kotin kupura irail er.
\q1 
\v 4 Pwe komui Kot ai Nanmarki, me inauki o\it n\it*, Iakop, en jauaja i.
\q1 
\v 5 Komui, me je pan kawekila at imwintiti kan; ni mar omui me je pan tiakekidi me kin palian kit.
\q1 
\v 6 Pwe i jota kin kaporoporeki ai kajik katieu, o ai kodlaj jota kak dore ia la.
\q1 
\v 7 Pwe komui me kin jauaja kit ja\it n\it* at imwintiti kan, o kom kin kanamenokala, me kailo\it n\it* kin kit.
\q1 
\v 8 Ran karoj je pan kapi\it n\it*a Kot, o je pan danke o\it n\it* mar omui kokolata.
\q1 
\v 9 Ari jo, kom kotin likidmalie kin kit ala, pwe jen lijela, o komui jota ia\it n\it* at karij akan.
\q1 
\v 10 Kom kotin mueid o\it n\it* at imwintiti, ren paki kit wei, o me kailo\it n\it* kin kit, kin kulia ja\it n\it* at kapwa.
\q1 
\v 11 Kom kotin mueid o\it n\it* ir, ren kawe kit ala dueta jip oko, o kom kotin kamueit kit paja\it n\it* nan pu\it n\it* en men liki kan.
\q1 
\v 12 Kom netikila japwilim omui kan ni pwai jued, a komui ap jota kapwapwa kilar.
\q1 
\v 13 Kom kin kotin wiai o\it n\it* kit, jen kankaurur ren men imp at, o lalaue o jarodi ren me kapil kit pena.
\q1 
\v 14 Kom kotin wia kin kit karajepa eu ren men liki kan o aramaj akan kin duedualok kin kit.
\q1 
\v 15 I kin jaro nin ran karoj o maj ai me dir en namenok,
\q1 
\v 16 Ni ai ro\it n\it*ero\it n\it* aramaj morjued o lalaue, o ni ai kilekila\it n\it* ai imwintiti o me kin akdepuk kan.
\q1 
\v 17 Mepukat karoj lel do\it n\it* kit er, ari jo, je jota kak monokela komui, de wia dip o\it n\it* japwilim omui inau.
\q1 
\v 18 Mo\it n\it*io\it n\it* at jota pupwei ja\it n\it* komui, o je jota wuki wei ja\it n\it* al omui.
\q1 
\v 19 A komui kawe kit alar ni wajan man jued, o kom kadupale kidi mot en mela.
\q1 
\v 20 Ma je monokela mar en at Kol, o pokada pa at o\it n\it* amen kot,
\q1 
\v 21 Kot jota pan kotin diarada? Pwe a kotin ma\it n\it*i lol en mo\it n\it*io\it n\it* at.
\q1 
\v 22 Pwe kit kin kalokoloke kin komui ni ran karoj, o kit rajo\it n\it* jip me pan kamela.
\q1 
\v 23 Mai\it n\it* i, kom kotida! Da me kom kotin jaimokela? Kotin opada waja, o der kajapoke kit ala kolata!
\q1 
\v 24 Da me kom kotin karirila jila\it n\it* omui, o kotin maliela at luet o at kalokolok?
\q1 
\v 25 Pwe \it n\it*en it poridier ni pwel par; kaped it paj o\it n\it* pwel.
\q1 
\v 26 Kom kotida, jauaja kit, o dore kit ala pweki omui kala\it n\it*an.
\c 45
\q1 
\v 1 MO\it N\it*IO\it N\it* I kin wiada kaul kajelel apot; I pan kaule ki duen Nanmarki amen, lo I rajo\it n\it* penjil en jauninti\it n\it* koiok aman.
\q1 
\v 2 Komui ta me kajelel ja\it n\it* aramaj karoj; meid kajalel jila\it n\it* omui; i me Kot kapai kin komui ta kokolata.
\q1 
\v 3 Pira wo\it n\it* omui koldaj ni lo\it n\it*elo\it n\it* omui, komui ol komad, o kapwata kin komui!
\q1 
\v 4 Komui en pwaida ni omui kapwat, Kom kotiwei, pwen jauaja me melel, o me luet akan, pwen kolekol o\it n\it* ir me pu\it n\it*. Lim omui maun ap pan wia dodok kapuriamui.
\q1 
\v 5 Kana\it n\it*an omui kajik katieu me kon wei kan kin lodi o\it n\it* komui; re kin lel o\it n\it* nan mo\it n\it*io\it n\it* en imwintiti en nanmarki.
\q1 
\v 6 Mai\it n\it* Kot, mol omui pan duedueta kokolata; o jokon en wei omui me jokon en pu\it n\it* apot.
\q1 
\v 7 Kom kin pok o\it n\it* me pu\it n\it* ap tataki tiak jued; i me Kot, omui Kot, keie kin komui le en kaperen mon omui warok kan.
\q1 
\v 8 Omui likau kan kin pomauki mire, aloe, o kajia ni omui pedoi ja\it n\it* tanpaj omui im elpenpain, komui kin polauleki kaul o arp.
\q1 
\v 9 Japwilim en Nanmarki jeri pein ko mi nan pu\it n\it* en toun tanpaj omui; li Nanmarki a kotikot ni pali maun omui kapwateki kold en opir.
\q1 
\v 10 \it N\it*ai jeripein koe ro\it n\it*, o kila\it n\it*, o kapaikedi jalon om, o monokela jap om o jau om akan.
\q1 
\v 11 Nanmarki ap pan peren kida mom om kajelel; pwe i om Kaun, a koe en kaudoki o\it n\it* i.
\q1 
\v 12 Nain Tiruj, me kapwapa re ’rail pan wado kijakij; o \it n\it*idi\it n\it*id re om.
\q1 
\v 13 Japwilim en Nanmarki jeripein, me mi lole, meid kajelel ni mo\it n\it*io\it n\it* i, a kapwateki likau kold.
\q1 
\v 14 A pan pakaluala ren Nanmarki ni a likau li\it n\it*an o a warok peinekap akan, me idauen i, kompoke pa, pan kalua do\it n\it* komui.
\q1 
\v 15 Re pan kalua irail ki peren o \it n\it*iji\it n\it*ij, o re kin pedelo\it n\it* o\it n\it* nan tanpaj en Nanmarki.
\q1 
\v 16 Noumui manakap akan pan wiliandi jam omui kan; i me kom pan kajapwilada\it n\it* jaupeidi en jap akan karoj.
\q1 
\v 17 I pan tamanda mar omui ni di kan karoj; i me wei kan karoj pan kapi\it n\it*a komui kokolata.
\c 46
\q1 
\v 1 KOT atail kaporopor o kele patail, o jauaj patail ni atail apwal akan, me lel do\it n\it* kitail.
\q1 
\v 2 I me je jota pan majak, menda ma jappa pan jorela, o nana kan pan kirila nan waro\it n\it* en madau.
\q1 
\v 3 Menda ma a iluk kan pan o\it n\it*io\it n\it*ida o pudopudeda, o ma a kelail o\it n\it* kawela nana kan.
\q1 
\v 4 Pwe kanim en Kot pan pereperen a duedueta ia\it n\it*aki utun pil, me mi lole, waja me tanpaj jaraui en me Lapalap o mia ia.
\q1 
\v 5 Kot kotikot lole, i me a pan te\it n\it*ete\it n\it*ki kokolata; Kot pan kotin jauaja i nin joran.
\q1 
\v 6 Men liki kan kin li\it n\it*ara\it n\it*ar o wei kan pan ola, jappa pan joredi, ma a pan kotin majani.
\q1 
\v 7 leowa Jepaot kotin ieia\it n\it* kitail; Kot en Iakop i pere patail.
\q1 
\v 8 Komail kodo, kila\it n\it* dodok lapalap en leowa, me kotin dodok kelail nin jappa,
\q1 
\v 9 Me kotin kadukiedi mauin lel ni imwin jap karoj o katip paja\it n\it* kajik katieu, o kawela katieu, o karo\it n\it*a kila kijiniai war en mauin akan.
\q1 
\v 10 Komail nenenla o ajada, me \it N\it*ai ta Kot. I pan kawauwi pein \it N\it*ai ren men liki kan, I pan kali\it n\it*anada nin jappa.
\q1 
\v 11 leowa Jepaot kotin ieia\it n\it* kitail; Kot en Iakop i pere patail.
\c 47
\q1 
\v 1 KOMAIL kainok karoj lopolop o kapi\it n\it*a Kot ki \it n\it*il kaperen!
\q1 
\v 2 Pwe leowa me lapalap kaualap, a meid kalank; i Nanmarki lapalap nin jap akan karoj.
\q1 
\v 3 A kotin kaloedi o\it n\it* kitail wei kan o aramaj akan pan na atail.
\q1 
\v 4 A kotin pilada\it n\it* kitail atail jojo, li\it n\it*an en Iakop, me a kotin pok o\it n\it*.
\q1 
\v 5 Kot kotida \it n\it*iji\it n\it*ij, o leowa ki \it n\it*il en koronete kelail.
\q1 
\v 6 Kauli o\it n\it* Kot pjalm ko! Kaulki pjalm ko! Kauli o\it n\it* atail Nanmarki! Kakaul!
\q1 
\v 7 Pwe Kot Nanmarki nan jap karoj; komail kaul ki pjalm ni loleko\it n\it*.
\q1 
\v 8 Kot Nanmarki en men liki kan; Kot kotikot pon mol a jaraui.
\q1 
\v 9 Jaupeidi en wei kan pokon pena wiala wein Kot en Apraam; pwe pere en mauin nin jappa me japwilim en Kot. A kotin lapalap melel.
\c 48
\q1 
\v 1 IEOWA meid lapalap, o a indand mau melel nan kanim en atail Kot, pon japwilim a dol jaraui!
\q1 
\v 2 Meid kajelel en dol Jion a uda, me jap karoj kin peren kida; ni pali apo\it n\it* kanim en nanamarki lapalap mimi ia.
\q1 
\v 3 Toun im kalaimun akan aja Kot, me i pere parail.
\q1 
\v 4 Pwe kila\it n\it*, nanmarki kan pokon pena, ap daulul wei.
\q1 
\v 5 Irail puriamui kila ni ar kila\it n\it*er mepukat; irail majapwekadar o ta\it n\it*er.
\q1 
\v 6 Irail rerer, o re majak dueta Ii pan naitik amen.
\q1 
\v 7 Kom kin kotin kawela jop en Tarjij ki an e\it n\it* maj en la\it n\it*.
\q1 
\v 8 Duen atail ro\it n\it*adar, iduen kitail kin kila\it n\it*ada nan kanim en Ieowa Jopaot, nan kanim en atail Kot; Kot kin kolekol i kokolata.
\q1 
\v 9 Mai\it n\it* Kot je kin tamataman da omui kala\it n\it*an nan japwilim ar tanpaj im en kaudok.
\q1 
\v 10 Mai\it n\it* Kot duen mar omui iduen wau omui lel ni imwin jappa; pali maun omui kadeik kan.
\q1 
\v 11 Dol en Jion en pereperen, o nan Iuda jeripein ko en injenemauki omui kadeik kan.
\q1 
\v 12 Komail kaido\it n\it* kapil pena Jion, wadok im te\it n\it* kan;
\q1 
\v 13 Kilekila\it n\it* mau a kel takai kan, o kajakajaui a im kalaimun akan, pwe komail en kak kajoia o\it n\it* men mur akan.
\q1 
\v 14 Me Kot me et, pan atail Kot anjau karoj kokolata, A pan kotin kalua kitail kokolata.
\c 49
\q1 
\v 1 Komail kainok kan karoj ro\it n\it* o dedeki, komail toun jap karoj.
\q1 
\v 2 Ir karoj, aramaj o jaupeidi, ir karoj me kapwapwa o jamama kan!
\q1 
\v 3 Au ai pan kaparok duen loleko\it n\it*, o mo\it n\it*io\it n\it* I duen lamalam pu\it n\it*.
\q1 
\v 4 I pan kapaike do\it n\it* jalo\it n\it* ai lepen majan, o i pan kajaleda me rir akan ni \it n\it*il en arp.
\q1 
\v 5 Da me i en majak ni ran apwal akan, ma me japu\it n\it* kan kapil ia pena,
\q1 
\v 6 Me kin kaporoporeki ar dipijou o juaiki ar kapwa toto?
\q1 
\v 7 Pwe jota me kak dorela ri a, de tomeki i ren Kot,
\q1 
\v 8 (Pwe meid apwal, en dorela \it n\it*en ar; a jota pan pwaida kokolata).
\q1 
\v 9 Pwen maur potopot o jota kila\it n\it* joujou o.
\q1 
\v 10 Pwe a kin kila\it n\it*, me loleko\it n\it* kan kin mela dueta me pweipwei o iakalar akan, o re pan mueid o\it n\it* amen ar dipijou kan.
\q1 
\v 11 I me re kin peren kida, ma im arail pan duedueta, o deu ’rail pan mimieta kokolata; o re konekon melel nin jappa.
\q1 
\v 12 Ari jo, aramaj me konekon jota kak mimieta ni mepukat, pwe a pan kokowei dueta man amen.
\q1 
\v 13 let ar wiawia pukat meid pweipwei; ari jo, kadaudok ar kin kapi\it n\it*a ki au arail.
\q1 
\v 14 Re wonon nan wajan mela dueta pwin jip; mela kin kama\it n\it*a ir; a me lelapok kan pan kaun irail da mada\it n\it*, o mom ar pan joredi, o re pan doo ja\it n\it* deurail, mimieta nan pweleko.
\q1 
\v 15 A Kot pan kotin dorela \it n\it*en i jan nan mana en wajan mela, pwe a pan kotin japwilimane kin ia.
\q1 
\v 16 Koe der puriamuiki, ma amen pan kapwapwala, o ma li\it n\it*an en im a pan laudala.
\q1 
\v 17 Pwe a jota pan wala meakot ni a pan mela, o a li\it n\it*an jota pan idauenla i.
\q1 
\v 18 A kin injenemau kila peren en maur kajelel wet, o aramaj kin kapi\it n\it*a ir, me kin apapwali pein ir eta ni maur et.
\q1 
\v 19 A pan idauen la jam a kan, ap jolar kila\it n\it* marain kokolata.
\q1 
\v 20 Ari, ma aramaj amen indand mau, ap jota a lamalam, a pan kokowei dueta man amen.
\c 50
\q1 
\v 1 KOT Ieowa manaman majanier o molipedo jappa ja\it n\it* ni tapin katipin lel ni a kiridi.
\q1 
\v 2 Li\it n\it*an en Kot tapida ja\it n\it* Jion.
\q1 
\v 3 Atail Kot kotido, o a jota kin kotin japaimokit. Kijiniai kelail kin tio\it n\it* mo a, o melimel laud kin mi impa.
\q1 
\v 4 A kotin molipe la\it n\it* o jappa, pwen kapu\it n\it*ala japwilim a aramaj akan!
\q1 
\v 5 Komail kapokon pena nai lelapok kan, me wiadar ar inau o\it n\it* ia ni anjau en mairon!
\q1 
\v 6 Nanla\it n\it* pan kajaleda a pu\it n\it*; pwe Kot kin kotin kadeikada.
\q1 
\v 7 Komail nai aramaj akan ro\it n\it*, I pan padaki o\it n\it* komail. Ijrael, I pan kaparoki o\it n\it* komail: \it N\it*ai Kot, om Kot.
\q1 
\v 8 I jota pan kaloke uk pweki om mairo\it n\it*, pwe om mairo\it n\it* ijij kin wiaui o\it n\it* ia anjau karoj.
\q1 
\v 9 Ari jo, I jota pan ale ja\it n\it* komail kau ol de kut o jip ol ja\it n\it* nan im omail.
\q1 
\v 10 Pwe man en nan wei karoj me ai o pil man akan, me mimi pon nana kid pak toto.
\q1 
\v 11 I aja manpir en nana karoj o jo\it n\it* en man karoj, me mi nan jap, kin mi re i.
\q1 
\v 12 Ma I men ma\it n\it*adar, I jota pan inda\it n\it* uk, pwe jappa me ai o audepa karoj.
\q1 
\v 13 Da, koe lamelame, me I kin ino\it n\it* io\it n\it* uduk en kau ol, de I men nim ntan kut ol?
\q1 
\v 14 Mairo\it n\it*ki danke o\it n\it* Kot o kapu\it n\it*ala\it n\it* me Lapalap o om inau.
\q1 
\v 15 Likwir do\it n\it* ia ni om injenjued, I ap pan dore uk ala, a koe pan kapi\it n\it*a ia.
\q1 
\v 16 A Kot kotin majani o\it n\it* me japu\it n\it* o: Da me koe kaparok duen ai kujoned akan, o lokaia kida au om duen ai inau,
\q1 
\v 17 Pwe koe kin tateki tiak pu\it n\it* o mamaleki ai kujoned akan?
\q1 
\v 18 Ma koe pan kila\it n\it* lipirap amen, koe kin ia\it n\it* i, o koe kin waroki o\it n\it* me kamal akan.
\q1 
\v 19 Au om kin lokaia kiwei me jued o lo om me likam.
\q1 
\v 20 Koe kin wonon o lokaia likam duen ri om; o nain in om putak koe kin karaune mal.
\q1 
\v 21 Koe wiada mepukat, a \it n\it*ai kin nenenla; koe ap kiki o\it n\it*, me \it n\it*ai dueta koe. A I pan kapu\it n\it* o\it n\it* uk o kajaleda mon maj om.
\q1 
\v 22 Komail me mamaleki Kot, en aja, I pan kajor komail la o jota jauaj pamail pan mia.
\q1 
\v 23 Me kin maironki danke, kin kapi\it n\it*a ia; o i al o, me I pan kajale o\it n\it* i duen maur en Kot.
\c 51
\q1 
\v 1 MAI\it N\it* Kot, kom kotin maki o\it n\it* ia duen omui kala\it n\it*an, o kotin lapwada dip ai duen ar kala\it n\it*an lapalap.
\q1 
\v 2 Kom ketin widen ia ja\it n\it* ai wiawia japu\it n\it*, o kotin kamakel ia da ja\it n\it* ni dip ai.
\q1 
\v 3 Pwe i aja duen ai wiadar me jued, o dip ai me janjal o\it n\it* ia anjau karoj.
\q1 
\v 4 O\it n\it* komui eta me I wiai dip o\it n\it*, o wiadar japu\it n\it* mon jila\it n\it* omui, pwe komui me pu\it n\it* eta ni omui majan akan, o komui makelekel eta ni omui pan kadeikada.
\q1 
\v 5 Kotin majani, me I ipwidier ni japu\it n\it*, o in ai ape kin ia dar ni ma\it n\it* en dip.
\q1 
\v 6 Kotin majani, kom kin kotin mauki melel, me mi waja rir; kom kin kajale o\it n\it* ia loleko\it n\it* rir.
\q1 
\v 7 Kom kotin kamakele kin in Ijop, pwe i en minla, widen ia, pwe i en puetepueteta jno.
\q1 
\v 8 Kom kotiki o\it n\it* ia peren o popol, pwe kokon ai kan, me kom kotin kawelar, en injenemaula.
\q1 
\v 9 Kom kotin jopwei ja\it n\it* dip a kan, o kotin lapwada ai japu\it n\it* karoj.
\q1 
\v 10 Mai\it n\it* Kot, kom kotin wiai o\it n\it* ia mo\it n\it*io\it n\it* makelekel, o kotin kawiliakapwada \it n\it*en i.
\q1 
\v 11 Kom der kaje ia la ja\it n\it* mon jila\it n\it* omui o der kotiki ja\it n\it* ia ar \it N\it*en Jaraui.
\q1 
\v 12 Kom kotin pur o\it n\it* kamait ia la ki omui jauaja ia, o kotiki o\it n\it* ia \it n\it*en en kaperen.
\q1 
\v 13 I pan padaki o\it n\it* me katiwo kan duen al omui kan, pwe me dipan akan en wuki o\it n\it* komui.
\q1 
\v 14 Mai\it n\it* Kot, kom kotin dore ia la ja\it n\it* dip en nta, pwe komui Kot ai jaunkamaur, pwe lo i en kapi\it n\it*a omui pu\it n\it*.
\q1 
\v 15 Mai\it n\it* leowa, kom kotin kajar paja\it n\it* kilen au ai, pwe au ai en kapikapi\it n\it*a komui.
\q1 
\v 16 Pwe kom jota kotin mauki mairo\it n\it* kamela a ma iei, i pan wiada o mairo\it n\it* ijij kom jota kotin kupura.
\q1 
\v 17 A iet mairo\it n\it*, me Kot kin kotin kupura: \it N\it*en olar, o mo\it n\it*io\it n\it* injenjuedalar, o karakarak, iei me komui Mai\it n\it* Kot jota pan kotin mamaleki.
\q1 
\v 18 Kom kotin jauaja Jion ki omui kala\it n\it*an, kotin kauada kel en Ierujalem.
\q1 
\v 19 Komui ap pan kupura mairo\it n\it* pu\it n\it*, mairo\it n\it* ijij o mairo\it n\it* unjok. I anjau me kau ol pan ijeda pon japwilim omui pei jaraui.
\c 52
\q1 
\v 1 KOE ol weit, da me koe juaikeki me jued, pwe kala\it n\it*an en leowa kin duedueta ni ran karoj.
\q1 
\v 2 Lo om ino\it n\it* io\it n\it* me jued, o kin raj o\it n\it* naip ko\it n\it* pot, ni a wia likam.
\q1 
\v 3 Koe kin mauki lokaia jued ja\it n\it* me mau, o lokaia likam ja\it n\it* me pu\it n\it*.
\q1 
\v 4 Koe kin men lokaiaki me jued lo om likam.
\q1 
\v 5 I me Kot pil pan kawe uk ala, o lepuk uk paja\it n\it*, o waik uk ja\it n\it* nan im om, o koko uk ja\it n\it* nan jap en me maur akan.
\q1 
\v 6 A me pu\it n\it* kan pan kila\it n\it* o majapwekada, o re pan kaurureki i:
\q1 
\v 7 Kila\it n\it*, iei ol o, me jota kaporoporeki leowa, pwe a keleki a dipijou toto o a kelail o\it n\it* a wiada me jued.
\q1 
\v 8 A \it n\it*ai dueta tuka oliwe pot nan tanpaj en Kot, i kaporoporeki kala\it n\it*an en Kot kokolata.
\q1 
\v 9 I pan kapi\it n\it*a komui kokolata, pwe kom kak kotin wiada; i pan kapi\it n\it*a mar omui, pwe a li\it n\it*an ren japwilim omui lelapok kan.
\c 53
\q1 
\v 1 ME pweipwei kan kin indinda nan mo\it n\it*io\it n\it* arail: Jota Kot. Arail tiak meid jued. Arail japu\it n\it* kan jakanekan. Jota amen mia, me kin wia me mau.
\q1 
\v 2 leowa kin irero\it n\it* aramaj akan ja\it n\it* nanla\it n\it*, pwen majani, ma amen mia, me loleko\it n\it* o rapaki Kot.
\q1 
\v 3 A ir karoj juedalar, o karoj japu\it n\it*alar, jota me kin wiada me mau, jota amen.
\q1 
\v 4 Ir karoj me kin wiada me jued, jota arail loleko\it n\it*, irail, me kin namala nai aramaj akan rajo\it n\it* prot, a re jota kin likwir o\it n\it* Kot.
\q1 
\v 5 Rap majak ni jota karepa, pwe Kot kotin kamueit paja\it n\it*er kokon en ir, me kin kapil uk pena. Kom kotin kanamenok ir alar, pwe Kot kotin kaje ir ala.
\q1 
\v 6 O i men, jauaj pan Ijrael en kodo ja\it n\it* nan Jion, o Kot en kotin lapwada japwilim a jalidi kan! I me Iakop pan injen mauki o Ijrael pan pereperenki.
\c 54
\q1 
\v 1 MAI\it N\it* Kot, kom kotin jauaj a ia ki mar omui, o kotin kajanjaleda ai pu\it n\it* ki omui manaman.
\q1 
\v 2 Mai\it n\it* Kot, kom kotin ereki ai kapakap, o kotin ma\it n\it*i lokaia en au i.
\q1 
\v 3 Pwe men wai kai palian ia, o me weit akan majamajan maur i, o re jota weweid mon Kot.
\q1 
\v 4 Kila\it n\it*, Kot jauaj pa i, leowa kin kolekol \it n\it*en i.
\q1 
\v 5 A pan kotin depuk o\it n\it* ai imwintiti kan ar me jued. Kom kotin kawe ir ala ki omui melel.
\q1 
\v 6 I ap pan wiai o\it n\it* komui mairo\it n\it* kaperen, o kapi\it n\it*a mar omui, pwe a me mau.
\q1 
\v 7 Pwe a kotin dore ia la ja\it n\it* nan ai apwal akan karoj, o maj ai peren kidar ai imwintiti kan.
\c 55
\q1 
\v 1 MAI\it N\it* Kot, kom kotin ereki ai kapakap, o kom der rirwei ja\it n\it* mon ai \it n\it*idi\it n\it*id.
\q1 
\v 2 Kom kotin ma\it n\it*i ia o kotin jape\it n\it* ia. Pwe i kin janjalo\it n\it* jili o ja\it n\it*eja\it n\it*ki,
\q1 
\v 3 Pwe \it n\it*il en ai imwintiti kin kainjenjued ia o me doo ja\it n\it* Kot akan kin pakipaki ia; pwe re kin men wia jued o\it n\it* ia, o re kin kailo\it n\it* kin ia.
\q1 
\v 4 Mo\it n\it*io\it n\it* i majapwekada nan kapek i, o majak en mela lel o\it n\it* ia.
\q1 
\v 5 Majak o rerer lel don ia; wapon kadupal ia di.
\q1 
\v 6 I apindada: O ma pa I ka dueta pa en muroi, pwen pirwei o mi ekij waja.
\q1 
\v 7 I ap pan pirla waja doo, o kaukajon jap tan.
\q1 
\v 8 I pan mada\it n\it*la\it n\it* wajan moleilei mon melimel o katau.
\q1 
\v 9 Mai\it n\it* Ieowa, kom kotin kawuk paja\it n\it* lo arail, o kotin kajore ir ala, pwe i kilekila\it n\it*, me toun kanim o kin weit o Akamai pena.
\q1 
\v 10 Mepukat kin wiaui ni ran o ni po\it n\it* pon arail kel takai, o a dir en apwal o dodok kan.
\q1 
\v 11 Me jued akan kin kaunda kanim o; o tou a kan jota kin muei ja\it n\it* likam o kotaue.
\q1 
\v 12 Ma ai imwintiti pan wia jued o\it n\it* ia, I jota pan injenoki, o ma me kailo\it n\it* kin ia pan pei o\it n\it* ia, I pan ruki ja\it n\it* mo a.
\q1 
\v 13 A koe, ai warok, o kompole pa I o kij ai.
\q1 
\v 14 Pwe kitail minimin penaer nan pu\it n\it* atail, Kitail wiaki eu nan pu\it n\it* en pokon nan tanpaj en Kot.
\q1 
\v 15 Mela en mada\it n\it* lel wo\it n\it* irail, pwe ren lokidokila nan wajan mela ni ar memaur; pwe im arail o lol arail me dir en morjued.
\q1 
\v 16 A I pan likwir o\it n\it* Kot, o Ieowa pan kotin jauaja ia.
\q1 
\v 17 Nin jautik, o ni manja\it n\it*, o nin jauaj I pan ja\it n\it*eja\it n\it* o weiwer, a ap pan kotin ma\it n\it*i \it n\it*il ai.
\q1 
\v 18 A pan kotin dorela \it n\it*en i ja\it n\it* ren me men palian ia, o pan kotin kamoleilei ia; pwe ir me toto, me u o\it n\it* ia.
\q1 
\v 19 Kot pan kotin ereki o kanamenok ir ala, pwe a kotikot eta ja\it n\it* tapin kaua.
\q1 
\v 20 A jaikidi japwilim a popol akan, o a kawela a inau.
\q1 
\v 21 Au a me kitentel ja\it n\it* wi, ap lamelame duen mauin, a lokaia me muterok ja\it n\it* le, ap rajo\it n\it* kodlaj ko\it n\it*, me onopa da\it n\it* pei.
\q1 
\v 22 Mueid o\it n\it* Ieowa, me koe ino\it n\it* io\it n\it*, a pan apwali uk ada, a jota pan kotin mueid o\it n\it* me pu\it n\it* kan en wukiwuk jili.
\q1 
\v 23 Mai\it n\it* Kot, kom pan kotin kaje ir Io\it n\it* o\it n\it* nan por lol en me jued o; me ino\it n\it* io\it n\it* nta o likam kan jota pan lel o\it n\it* apali en maur arail. A i pan kaporoporeki komui.
\c 56
\q1 
\v 1 MAI\it N\it* Kot, kom kotin maki o\it n\it* ia, pwe aramaj akan \it n\it*iri\it n\it*ir o\it n\it* ia; re kin peipei o kamajak ia ni ran karoj.
\q1 
\v 2 Ai imwintiti kan kin \it n\it*iri\it n\it*ir nin ran karoj, pwe me toto pei o\it n\it* ia ni ar aklapalap.
\q1 
\v 3 Ni ai majak i kin kaporoporeki komui.
\q1 
\v 4 I pan kapi\it n\it*a majan en Kot, i pan kaporoporeki Kot o pan jota majak, da me aramaj kak wiai o\it n\it* ia?
\q1 
\v 5 Ran karoj re kin kawukila ai lokaia, re kin madamadauata, duen ar pan kawe ia la.
\q1 
\v 6 Re pokon pena, o majamajan, o kanakanai o\it n\it* kaimwin na i kat, duen ar pan kak kame ia la.
\q1 
\v 7 Iaduen, re pan kak pitila ni ar morjuet? Mai\it n\it* Kot, kom kotin kajapokala jo\it n\it* en aramaj due met.
\q1 
\v 8 Kom kotin wadok pena al en ai pitilar akan, o kotin kolekol pena pil en maj ai nan japwilim omui dal o. Pwe kaidin karoj kileledier nan japwilim omui puk o?
\q1 
\v 9 Ai imwintiti kan ap pan japale wei ni ran o me i pan likelikwir; let me i aja, me Kot jauaj pa i.
\q1 
\v 10 I pan kapi\it n\it*a majan en Kot; i pan kapi\it n\it*a majan en Ieowa.
\q1 
\v 11 I kaporoporeki Kot, ap jota majak, pwe da me aramaj akan pan kak wiai o\it n\it* ia?
\q1 
\v 12 Mai\it n\it* Kot, i inauki o\it n\it* komui, me i pan mairo\it n\it*ki danke o\it n\it* komui;
\q1 
\v 13 Pwe kom kotin dorelar \it n\it*en i ja\it n\it* mela o na, i kat ja\it n\it* ai krijidi, pwe i en weweid mon jila\it n\it* en Kot nan marain en me maur akan.
\c 57
\q1 
\v 1 MAI\it N\it* Kot, kom kotin maki o\it n\it* ia, maki o\it n\it* ia! Pwe \it n\it*en i kin kaporoporeki komui, o pan mot en lim omui i wajan ai maur, lao anjau apwal daulier.
\q1 
\v 2 I likwir o\it n\it* Kot, me lapalapia, o\it n\it* Kot, me kotin kaimwijokala ai kanka\it n\it*era\it n\it*er.
\q1 
\v 3 A kotin poronedo ja\it n\it* nanla\it n\it* jauaj pa i o\it n\it* me kanamenok ia, o me kin \it n\it*iri\it n\it*ir o\it n\it* ia. Kot pan kotin kadarado a kala\it n\it*an o melel.
\q1 
\v 4 \it N\it*en i mi nan pu\it n\it* en laien akan, aramaj rajo\it n\it* umpul en kijiniai; ni arail rajo\it n\it* katieu o kana\it n\it*an kajik katieu, o lo arail rajo\it n\it* kodlaj ko\it n\it* o.
\q1 
\v 5 Mai\it n\it* Kot, kom kotida ileila ja\it n\it* la\it n\it*, o wau omui nan jappa karoj.
\q1 
\v 6 Irail injarai ia nan al ai kan; re kin katoutoui \it n\it*en i; re weirada mo i por eu, ap pein pupedi o\it n\it* lole.
\q1 
\v 7 Mo\it n\it*io\it n\it* i injenemaular, Mai\it n\it* Kot, \it n\it*en i onoper o\it n\it* kaul o kapi\it n\it*.
\q1 
\v 8 \it N\it*en i pirida! Kaul o arp pirida! I pan pirida nin joran.
\q1 
\v 9 Ieowa, i men danke o\it n\it* komui nan wei kan; i pan kauli o\it n\it* komui nan pu\it n\it* en aramaj akan.
\q1 
\v 10 Pwe omui kala\it n\it*an me laud dueta nanla\it n\it*, o omui melel dueta tapok kan.
\q1 
\v 11 Mai\it n\it* Kot, kom kotida ileila ja\it n\it* la\it n\it*, o wau omui li\it n\it*an nan jappa karoj.
\c 58
\q1 
\v 1 IADUEN komail loto\it n\it*, pwe komail jota men lokaia me pu\it n\it*, o komail jota men kapu\it n\it* nin tiak inen, komail aramaj akan?
\q1 
\v 2 Melel, komail kin wia me japu\it n\it* nan mo\it n\it*io\it n\it* o, o nan jap o komail kin kelail o\it n\it* wiada me jued.
\q1 
\v 3 Me doo ja\it n\it* Kot akan me japu\it n\it* ja\it n\it* pon kapan in ar akan; me likam kan kin janjalo\it n\it* jili ja\it n\it* nan kaped en in ar akan.
\q1 
\v 4 Ar li\it n\it*ara\it n\it*ar rajo\it n\it* li\it n\it*ara\it n\it*ar en jerpent amen, rajo\it n\it* jerpent jalo\it n\it*epon, me penala jalo\it n\it* a.
\q1 
\v 5 Pwen der ro\it n\it* \it n\it*il en jaunwunani o kati ani men, me kadek wunani.
\q1 
\v 6 Mai\it n\it* Kot, kom kotin katip paja\it n\it* ni nan au arail; Mai\it n\it* Ieowa, kom kotin kawela ni en laien pulepul akan.
\q1 
\v 7 Kom kotin kawe ir ala dueta pil me kin pwilipwili wei. Ma a kaonopada a kana\it n\it*an kajik katieu, re kin tip paja\it n\it*.
\q1 
\v 8 Re pan joredi dueta kamedel aman kin mo\it n\it* pena; re jota pan kila\it n\it* katipin dueta jeri amen, me jota dar pu\it n\it*i.
\q1 
\v 9 Mon omial ainpot pan pam tui, a pan kotin jipet wei ni a o\it n\it*io\it n\it*.
\q1 
\v 10 Me pu\it n\it* o pan peren kida a lao kila\it n\it* depuk o\it n\it* ir, o a pan widen na a nana ntan me doo jan Kot o.
\q1 
\v 11 Aramaj akan ap pan inda: Me pu\it n\it* kan pan tu\it n\it*ole katin; pwe Kot eta jaunkadeik nin jappa.
\c 59
\q1 
\v 1 AI Kot, kom kotin dore ia la ja\it n\it* ai imwintiti kan, o kotin pera ja\it n\it* ia mon me palian ia.
\q1 
\v 2 Dore ia la ja\it n\it* me morjued akan, o kotin jauaja ia ja\it n\it* me ino\it n\it* io\it n\it* nta.
\q1 
\v 3 Irail kin majamajan maur i, me kelail akan pokon pena o\it n\it* ia, a jota dip ai, o jota me jued kot, me i wiadar, Mai\it n\it* leowa.
\q1 
\v 4 Irail ta\it n\it* pena o kaonopada a jota dip ai. Kom kotin opada waja, o kotin ieia\it n\it* ia, o irero\it n\it* mepukat.
\q1 
\v 5 Mai\it n\it* leowa, Kot Jepaot, Kot en Ijrael, kotin opada waja, o kotin kadeikada men liki kan karoj. Kom der maki o\it n\it* amen ir, me kin wia dip ni ar aklapalap.
\q1 
\v 6 Nin jautik re kin puredo \it n\it*u\it n\it*u\it n\it* dueta kidi kan, o re kin ta\it n\it*ata\it n\it* jili nan kanim o.
\q1 
\v 7 Kom kotin ma\it n\it*i, re kin lidelidu mo\it n\it*in; kodlaj kan mi pan kilin au arail: Ij me pan ro\it n\it*?
\q1 
\v 8 A komui, Mai\it n\it* leowa, pan kotin kiparamat kin irail, o kom pan kotin kalij irail la.
\q1 
\v 9 Kele pa i, i pan rukila re omui. Pwe Kot pere pa i.
\q1 
\v 10 Kot kin kotin kajale o\it n\it* ia melel a kala\it n\it*an; Kot kin kotin wiai o\it n\it* ia, i en peren kida ai imwintiti.
\q1 
\v 11 Kom der kotin kame ir ala, pwe nai aramaj akan pan monokela, a kotin kamueit ir paja\it n\it* ki omui mana, leowa pere pat, kajapoke ir ala.
\q1 
\v 12 Dip eta lokaia en kilin au arail; i me re pan lokidi ni ar aklapalap; pwe re kin lokaia lalaue o likam eta.
\q1 
\v 13 Kom kotin kawe ir ala o der maki o\it n\it* ir; kawe ir ala, pwe ren jolar meakot, ap aja, me Kot kotin kaunda kadaudok en Iakop o jap karoj.
\q1 
\v 14 Nin jautik re kin puredo \it n\it*unu\it n\it* dueta kidi kan, o re kin ta\it n\it*ata\it n\it* jili nan kanim o.
\q1 
\v 15 Re kin ta\it n\it*ata\it n\it* jili rapaki kan ar ma\it n\it*a, ap lipaned, ma re jota pan medila.
\q1 
\v 16 A i pan kauleki duen omui manaman, o ni i manjan i pan kapi\it n\it*a omui kala\it n\it*an, pwe komui pere pa i o ai paip ni ran en ai apwal.
\q1 
\v 17 I pan kauli o\it n\it* komui ai paip, pwe Kot pere pa i o ai Kot kala\it n\it*an.
\c 60
\q1 
\v 1 MAI\it N\it* Kot, kom kotin kaje kit alar, o kamueit kit paja\it n\it*er ni omui o\it n\it*io\it n\it*, kom kotin pur o\it n\it* kamait kit ala.
\q1 
\v 2 Kom kotin kamokitadar jap o, o kawelar i, kom kotin kamauiala waja ola kan, pwe a kin mokimokid.
\q1 
\v 3 Pwe kom kotiki o\it n\it*er japwilim omui kan katoutou parail. Kom kotiki o\it n\it* kit er wain men kapweipwei kit alar.
\q1 
\v 4 A kilel eu, me kom kotiki o\it n\it* irail er, me majak komui, i me irail kauadar, ap kelail kidar.
\q1 
\v 5 Pwe kompoke pamui kan en jaladokala; kom kotin jauaja ki pali maun ar o kotin ereki kit.
\q1 
\v 6 Kot kotin majanier nan japwilim a mol jaraui, i me i peren kida; i pan nek paja\it n\it* Jikem o jojo\it n\it* jap Jukot.
\q1 
\v 7 Kilead o Manaje iei japwe; \it n\it*ai kin kaunda Epraim; a Iuda iei ai jokon;
\q1 
\v 8 Moap iei ai dal en dudu; i kin tiakedi Edom; Pilijta kin \it n\it*iji\it n\it*ij o\it n\it* ia.
\q1 
\v 9 Ij me pan kalua ia nan kanim te\it n\it*ete\it n\it* eu? Ij me pan ia\it n\it* ia lel Edom?
\q1 
\v 10 Kaidin komui ai Kot? Komui me kaje kit alar o jota ia\it n\it* at karij akan.
\q1 
\v 11 Kom kotin jauaja kit ni at apwal akan, pwe en aramaj ar jauaje jota katepa.
\q1 
\v 12 Ia\it n\it*aki at Kot kit pan kapwaiada dodok apwal akan. A pan kotin tiakedi at imwintiti kan.
\c 61
\q1 
\v 1 MAI\it N\it* Kot, kom kotin ereki ai likelikwir o kotin ma\it n\it*i ai kapakap!
\q1 
\v 2 Ja\it n\it* ni imwin jappa i pan likwir wo\it n\it* komui, ma mo\it n\it*io\it n\it* i majakada, kom pan kotin kalua ia pon paip ileile eu.
\q1 
\v 3 Pwe komui kapore pa i o imaten kelail o\it n\it* ai imwintiti kan.
\q1 
\v 4 Kom kotin mueid o\it n\it* ia, i en mimieta nan japwilim tanpaj omui kokolata, o diar wajan kamaur pan lim omui kan.
\q1 
\v 5 Pwe komui Kot ma\it n\it*i duen ai inau; kom kin kotiki o\it n\it* ia er jojo en ir, me majak mar omui.
\q1 
\v 6 Komui en kotiki o\it n\it* nanmarki maur warai, pwe a jaunpar akan en totola kokolata.
\q1 
\v 7 Pwe a en mimieta mon Kot kokolata; kom kotin kajale o\it n\it* I kala\it n\it*an o melel, me pan jinjila i.
\q1 
\v 8 I ap pan kauli o\it n\it* mar omui kokolata, pwe i en kapwaiada ai inau kan ni ran karoj.
\c 62
\q1 
\v 1 \it N\it*EN i moleileilar ren Kot, me kotin jauaja ia.
\q1 
\v 2 Pwe i eta ai paip, o jauaj pa i, o pere pa i, pwe i en jota luetala kokolata.
\q1 
\v 3 Arai da komail kin majamajan ol ta men, pwen kamela, me rajo\it n\it* did panpanla o kel me paul paja\it n\it*er?
\q1 
\v 4 Re kin madamadaua duen ar pan kak kapupedi i, re kadek likam, re kin lokaia kajelel, a nan mo\it n\it*io\it n\it* arail re kin lalaue.
\q1 
\v 5 \it N\it*en I kaporoporeki Kot, pwe I kapre pa i.
\q1 
\v 6 I eta ai paip o jauaj pa I, o pere pa I, pwe I ender pupedi.
\q1 
\v 7 Ai maur mi ren Kot, o ai li\it n\it*an, o ai paiap, o ai kel; I kaporoporeki Kot.
\q1 
\v 8 Komail aramaj akan karoj kaporoporeki I anjau karoj kajanjale on I mo\it n\it*io\it n\it* omail, Kot kapore patail.
\q1 
\v 9 A aramaj akan jota meakot, o me lapalap akan pil kin japu\it n\it*ala. Ni men tenok re kin kokoda, menda ma irail me toto.
\q1 
\v 10 Komail der keleki omial dipijou japu\it n\it* o der kaporoporeki me komail kuliadar. Ma komail pan kapwapwala, komwail der kajampaleki!
\q1 
\v 11 Kot kotikidar majan eu, me I ro\it n\it*er akai anjau, iet: Kot eta me manaman.
\q1 
\v 12 Komui Mai\it n\it* me kala\it n\it*an o komui kin pwain o\it n\it* amen amen duen a wiawia kan.
\c 63
\q1 
\v 1 Kot komui ai Kot, nin joran I kin pirida\it n\it* komui. \it N\it*en i kin ino\it n\it* io\it n\it* komui. Pali war ai kin ino\it n\it* io\it n\it* komui nan jap madeko\it n\it* o mo\it n\it*edi, waja me jota pil mi ia.
\q1 
\v 2 I waja i kin tamanda komui nan japwilim omui tanpaj im jaraui, pwe i men kila\it n\it* omui manaman o li\it n\it*an.
\q1 
\v 3 Pwe omui kala\it n\it*an mau ja\it n\it* maur; kil en au ai kin kapi\it n\it*a komui.
\q1 
\v 4 I waja i ino\it n\it* io\it n\it* kapi\it n\it*a komui arain ai maur, o men pokada pa i kat ni mar omui.
\q1 
\v 5 I me pan kaperen pan \it n\it*en I o ai popol, ma i pan kak kapi\it n\it*a komui ki au ai kaperen.
\q1 
\v 6 Ni ai kin wendi pon loj, i kin madamadaua duen komui, o ni ai pirida, i kin lokelokaia duen komui.
\q1 
\v 7 Pwe komui jauaj pa i, o pan mot en lim omui kan i kin \it n\it*iji\it n\it*ij.
\q1 
\v 8 \it N\it*en i kin te\it n\it*idi o\it n\it* komui; lim omui pali maun kin apapwali
\q1 
\v 9 A irail me majamajan ia, pwen jaik ia di, pan lokidokila pan jappa.
\q1 
\v 10 Re pan pupedi o\it n\it* nan kodlaj, o kidi en wel pan ka\it n\it* ir ala;
\q1 
\v 11 A nanmarki pan peren kida Kot. Me kin kaula o\it n\it* i, pan pwaida, pwe au en me likam akan pan pena pinla.
\c 64
\q1 
\v 1 MAI\it N\it* Kot, kotin ereki \it n\it*il ai ni ai injenjued. Kom kotin jinjila maur i mon ai imwintiti weit.
\q1 
\v 2 Kom kotin karuki ia la ja\it n\it* mon pokon en me jued akan, mon pwin en me wia japu\it n\it* kan.
\q1 
\v 3 Me kin ada lo ’rail dueta kodlaj pot, o me kaonopada ar kajik katieu, iei ar lokaia jued,
\q1 
\v 4 Pwen rir kajikiedi me lelapok o; mada\it n\it* re pan kajikiedi i, o jota injenoki.
\q1 
\v 5 Irail me weit ni ar tiak jued, o re kin inda, duen ar pan injar, o re kin inda: Ij me pan kak kila\it n\it*?
\q1 
\v 6 Irail kin madamadaua duen me jued. Kitail kapwaiadar, karoj kileledier. Mo\it n\it*io\it n\it* en aramaj me widi\it n\it* o meid koiok ni morjued.
\q1 
\v 7 A Kot pan kotin kajik ir edi mada\it n\it*, pwen kamadak o\it n\it* ir.
\q1 
\v 8 Pein lo arail pan kapup ir edi, o karoj, me pan kila\it n\it*, pan kaurureki.
\q1 
\v 9 O aramaj karoj pan majak o inda: Mepukat Kot kotin wiadar. O re pan aja, me i japwilim a dodok.
\q1 
\v 10 Me pu\it n\it* o pan perenki Ieowa, o pan liki i, o me lelapok kan karoj pan pereperen.
\c 65
\q1 
\v 1 MAI\it N\it* Kot, je kin auiaui o kapi\it n\it*a komui nan Jion, o je kin kapwaiada at inau o\it n\it* komui.
\q1 
\v 2 Komui kotin ereki at kapakap, pwe i me aramaj karoj pan pwara wo\it n\it* komui.
\q1 
\v 3 Dip at kin katoutoui kit kaualap. Kom kotin maki o\it n\it* kit dip at akan.
\q1 
\v 4 Meid pai, me kom kotin pilada o mueid o\it n\it*, en pwarala re omui, pwen kaujon nan japwilim omui kel; kit pan tu\it n\it*etu\it n\it*ole o medikila dipijou en tanpaj omui, japwilim omui im en kaudok jaraui.
\q1 
\v 5 Kom kotin ma\it n\it*i kit duen omui pu\it n\it* kapuriamui, Kot, at jaunkamaur, komui me kapore pan meakaroj nin jappa, o me mi waja doo ni kailan madau;
\q1 
\v 6 Me kotin pajonedier nana kan, pwen te\it n\it*ete\it n\it* ni a kelail, I me audeki manaman.
\q1 
\v 7 Komui katukiedi \it n\it*irjok en madau, \it n\it*irjok en a iluk kan, o moro\it n\it*aro\it n\it* en aramaj akan.
\q1 
\v 8 Me kaujon ni imwin jappa, kin majakada omui kilel akan; komui kin kaperenda me kaujon ni pali maj o ni pali apo\it n\it*.
\q1 
\v 9 Kom kin kotin kupura jappa o kawujokejok o kakepwapwala i melel. Parer en Kot me dir en pil kaualap. Kom kin kotin jauaja ar wantuka kan, iduen omui kotin kapaiada jap o.
\q1 
\v 10 Kom kin kotin kapileda ar jap akan o kawujokejok ar mad akan o kamuterok kila katau o kapaiada ar tuka kan.
\q1 
\v 11 Kom kotin kapwada kidar jaunpar omui kala\it n\it*an; o lip en aluwilu ar me dir en kamau kan.
\q1 
\v 12 Moj en nan jap tan pil pwaida mau, o dol akan kin pereperen.
\q1 
\v 13 O mal akan me dir en pwin jip, o jap me rokeki korn, me mau o\it n\it* \it n\it*iji\it n\it*ij o kakaul.
\c 66
\q1 
\v 1 \it N\it*IJI\it N\it*IJ o\it n\it* Ieowa nan jap karoj.
\q1 
\v 2 Kauleki li\it n\it*an en mar a; kapikapi\it n\it*a i melel!
\q1 
\v 3 Komail potoan o\it n\it* Kot: Meid kapuriamui japwilim omui dodok kan! Japwilim omui imwintiti kapi\it n\it*a komui pweki omui manaman.
\q1 
\v 4 Jap karoj en kaudok o\it n\it* komui o kapi\it n\it*a komui pweki omui manaman.
\q1 
\v 5 Komail kodo, kila\it n\it* dodok en Kot, pe a wiawia kan me kapuriamui ren aramaj akan.
\q1 
\v 6 A kotin kawukila madau on jap madako\it n\it*, pwe aramaj en kak alu pon pil o, I waja je peren kidar kaualap.
\q1 
\v 7 A kotin kakaunda ni a manaman kokolata; jila\it n\it* i kin irero\it n\it* wei kan. Me ka\it n\it*udi kan jota kak pwaida.
\q1 
\v 8 Komail wei kan kapi\it n\it*a atail Kot, o komail kalaudela \it n\it*il omail, pwen lel o\it n\it* waja doo.
\q1 
\v 9 Me kotin kolekol o\it n\it* kitail maur atail, o jota mued o\it n\it*, na atail en krijedi.
\q1 
\v 10 Pwe komui Kot me kotin kajonejon kit o kamakelekel kit er, dueta jilper kin kamekelekelda.
\q1 
\v 11 Kom kotin mueid o\it n\it*, jen lodi ni injar o, kom katoutou kin kit men katoutou eu.
\q1 
\v 12 Kom kotin mueid o\it n\it* aramaj kai, en tiakedi pon mo\it n\it* at; kit lel o\it n\it* kijiniai o pil; a kom kotin kaptiki ja\it n\it* kit o kakele kit adar.
\q1 
\v 13 I me i pan pedekilo\it n\it* o\it n\it* nan tanpaj omui, pwen mario\it n\it* ijij, o i pan kapwaiada ai inau o\it n\it* komui.
\q1 
\v 14 Duen kil en au ai inaukidar, o duen au ai inda ni ai anjau apwal.
\q1 
\v 15 I pan mairo\it n\it* ijij o\it n\it* komui jip wi kan ia\it n\it*aki adiniai en jip ol, I pan mairo\it n\it*ki kau ia\it n\it*aki jip o kut akan.
\q1 
\v 16 Komail karoj, me majak Kot, kodo re i, i pan kajoi o\it n\it* komail, duen me a kotin wiai o\it n\it* \it n\it*en i.
\q1 
\v 17 I likwirki o\it n\it* i au ai o i kapi\it n\it*aki i lo i.
\q1 
\v 18 Ma i pan lamelame nan mo\it n\it*io\it n\it* i, me i pan wiada me jued, Ieowa ap jota pan ma\it n\it*i ia.
\q1 
\v 19 A Kot kotin ereki ai kapakap, o a kotin ma\it n\it*ier ai \it n\it*idi\it n\it*id.
\q1 
\v 20 Kapi\it n\it*a o\it n\it* Kot, me jota kotin mamaleki ai kapakap, o a jota kotiki wei ja\it n\it* ia a kala\it n\it*an.
\c 67
\q1 
\v 1 KOT en kotin maki o\it n\it* kit, o kotin kapaia kin kit. A kotin kamaraine kin kit, jila\it n\it* i.
\q1 
\v 2 Pwe japwilim a al akan me janjaleda nin jappa o ren men liki kan a maur.
\q1 
\v 3 Mai\it n\it* Kot, wei kan pan kapi\it n\it*a komui, wei kan karoj pan kapi\it n\it*a komui.
\q1 
\v 4 Wei kan pan peren kida o \it n\it*iji\it n\it*ij, pwe kom kin kotin kapu\it n\it* o\it n\it* wei kan ni tiak pu\it n\it*, o kom kotin kaunda aramaj akan nin jappa.
\q1 
\v 5 Mai\it n\it* Kot, wei kan pan kapi\it n\it*a komui, wei kan karoj pan kapi\it n\it*a komui.
\q1 
\v 6 Jap o kin kapwaiada a tuka kan. Kot pan kotin kapai kit ada, at Kot.
\q1 
\v 7 Kot pan kotin kapai kit ada, o toun jappa karoj pan majak i!
\c 68
\q1 
\v 1 KOT en kotida, pwe a imwintiti en kamueit paja\it n\it*, o me kailo\it n\it*ki i, en ta\it n\it* wei.
\q1 
\v 2 Kom kotin paki irail wei dueta adiniai, dueta krij kin pei paja\it n\it* nan kijiniai, iduen me doo ja\it n\it* Kot akan en joredi.
\q1 
\v 3 A me pu\it n\it* kan en pereperen o popol mon jila\it n\it* en Kot o ren pereperen melel.
\q1 
\v 4 Kauli o\it n\it* Kot, kauli o\it n\it* mar a! Kaonopada al o o\it n\it* i, me kotiwei nan jap tan, a maraneki leowa komail perenki i!
\q1 
\v 5 Pwe i Jam en me japoupou kan o jaunkapu\it n\it* en li odi kan. I Kot nan japwilim a tanpaj jaraui.
\q1 
\v 6 Kot me kotin kadire kila jeri ko im en me kin kelep, me kin lapwada me jalidi kan, pwen pwaida o pereperen a me katiwo kan pan mimieta nan wajan lek.
\q1 
\v 7 Mai\it n\it* Kot, ni anjau kom kotiwei mon japwilim omui aramaj akan, ni omui kotiwei nan jap tan!
\q1 
\v 8 I anjau jap o rerer, o audepan la\it n\it* kan moredier mon jila\it n\it* en Kot, nana Jinai mon jila\it n\it* en Kot en Ijrael.
\q1 
\v 9 Mai\it n\it* Kot, kom kotin kamoredier katau mau, o kom kotin kamauradar japwilim omui jojo, me mo\it n\it*edier
\q1 
\v 10 Pwe japwilim omui pwin diar waja, me a kak kotikot ia. Mai\it n\it* Kot, kom kotin apwalilar me luet akan duen omui kala\it n\it*an.
\q1 
\v 11 leowa kotikidier a majan ki pwin en wanporon kalaimun akan.
\q1 
\v 12 Nanmarki en karij toto ta\it n\it* wei mada\it n\it*, o waun im akan nek paja\it n\it*er, me re atia ja\it n\it* ar imwintiti kan.
\q1 
\v 13 Ni omail kairu nan pu\it n\it* en noumail pwin man akan, komail rajo\it n\it* pa en muroi men, me li\it n\it*an dueta jilper o pa a kan dueta kold li\it n\it*an.
\q1 
\v 14 Ma me Manaman o lao kotin kamueit paja\it n\it* nanmarki kan, nana Jalmon rotorot ap pan marainla.
\q1 
\v 15 Nana Pajan iei nana en Kot; Pajan nana kalaimun eu.
\q1 
\v 16 Menda komail nana kalaimun akan kin kilekila\it n\it* ap peirin o\it n\it* nana, me Kot kotin piladar en kotikot ia? o leowa pan kotikot waja o kokolata.
\q1 
\v 17 War en Kot me kid toto pan pak kid; leowa kotikot re ’rail ni nana Jinai.
\q1 
\v 18 Komui kotidala\it n\it* poa o jaliedier me jalidi kan, o kom kotin ale o\it n\it* aramaj pai kan, pil o\it n\it* ir me katiwo kan, pwe leowa en kotikot waja o.
\q1 
\v 19 Kapi\it n\it*a leowa nin ran akan karoj; Kot kin kotiki o\it n\it* kitail katoutou patail, ap pil kotin jauaja kitail.
\q1 
\v 20 Atail Kot iei jauaj patail, o leowa Kaun kin kotin dorela ja\it n\it* mela.
\q1 
\v 21 Melel, Kot pan kotin kawela mo\it n\it*an a imwintiti kan, o a pan kotin lejer paja\it n\it* takain mo\it n\it*an ir, me dadaurata ar katiwo.
\q1 
\v 22 leowa kotin majanier: I pan kapure do\it n\it* ir ja\it n\it* nan Pajan, I pan wa ir do ja\it n\it* nan kapin madau.
\q1 
\v 23 Pwe koe en tiakedi on nan ntan imwintiti kan, o noum kidi kan en tamotamo.
\q1 
\v 24 Mai\it n\it* Kot, a janjal duen omui kotikot jili, duen omui kotikot jili nan mol omui jarawi, ai Kot o ai Nanmwarki.
\q1 
\v 25 Pwin en kaul kin tio\it n\it*, ap pwin en jaunkaja\it n\it* nan pu\it n\it* en peinakap akan, me wiadar aip.
\q1 
\v 26 Kapina Kot Ieowa nan momodijo kan, komail me kijan parer en Ijrael.
\q1 
\v 27 Peniamin tikitik kin kakaun nan pu\it n\it* ar, jaupeidi en Iuda ia\it n\it*aki japwilim ar akan toto, jaupeidi en Jepulon, o jaupeidi en Naptali.
\q1 
\v 28 Omail Kot kotin kauadar omail wei; Mai\it n\it* Kot, I me komui en kotin kate\it n\it*ete\it n\it*edi, pwe japwilim omui dodok.
\q1 
\v 29 Nanmarki kan pan wa do\it n\it* uk ar kijakir pweki omail im en kaudok nan Ierujalem.
\q1 
\v 30 Kom kotin lipor o\it n\it* man en nan rau, o pwin kau ol ia\it n\it*aki na kan, o wei kan, me kin pepei pweki kijin moni. Kotin kamueit paja\it n\it* wek kan, me kin men mauin.
\q1 
\v 31 Jaupedi en Akipten pan pwarado; men Moren pan pokadan Kot pa’rail.
\q1 
\v 32 Komail wei kan nin jappa kauli o\it n\it* Kot, kakaul o kapi\it n\it*a Ieowa.
\q1 
\v 33 I, me kin kotikot jili nanla\it n\it*, nanla\it n\it* en majia! Kila\it n\it*, a kin kotiki o\it n\it* japwilim a nanjapwe manaman.
\q1 
\v 34 Komail kamelele mana en Kot! A li\it n\it*an mi ren Ijrael, o a mana mi nan tapok kan.
\q1 
\v 35 Kot meid kapuriamui nan mole jaraui. I Kot en Ijrael. A pan kotiki o\it n\it* aramaj akan mana o kelail. Kapina Kot!
\c 69
\q1 
\v 1 MAI\it N\it* Kot, kotin jauaja ia, pwe pil itida lel o\it n\it* maur i.
\q1 
\v 2 I pan kirila nan waja lujujur lol, waja me jota kakaluak; i mi nan pil lol, o ad pan kamop ia la.
\q1 
\v 3 I pa\it n\it*a kila ai ja\it n\it*eja\it n\it*, kapi\it n\it* wor ai kirkilar, maj ai juedalar, pwe a warailar ai auiaui Kot.
\q1 
\v 4 Me kin tata kin ia nin joka repa me toto ja\it n\it* pit en mo\it n\it* ai. Me imwintiti o\it n\it* ia, o me kin kawe ia la, ap jota karepa, kin kelail. I en pwain, me i jota kulia ja\it n\it*.
\q1 
\v 5 Mai\it n\it* Kot, kom kotin ma\it n\it*i ai pweipwei, o ai japu\it n\it* kan me jota rir ja\it n\it* komui.
\q1 
\v 6 Kom der mueid o\it n\it* irail, me auiaui komui, en jarodi pweki \it n\it*ai, Mai\it n\it* Ieowa Jepaot; kom der mueid o\it n\it* irail, me rapaki komui, en namenokala pweki \it n\it*ai, Kot en Ijrael.
\q1 
\v 7 Pwe i kin kankaururla pweki komui, maj ai me dir en namenok.
\q1 
\v 8 I wialar men wai amen ren ri ai kan, o nain in ai jaja ia lar.
\q1 
\v 9 Pwe limpok o\it n\it* tanpaj omui kajor ia dier, o lalaue en ir, me kin lalaue komui id ko do\it n\it* ia.
\q1 
\v 10 I kin ja\it n\it*eja\it n\it* melel o kaijejol, ari jo, re kin lalaue ia.
\q1 
\v 11 I likau kidar ed eu, a re kin lalaue ia.
\q1 
\v 12 O me mondi pan wanim, kin kajekajenda ia, o wajan ka\it n\it* jakau, re kin kakaul kin ia.
\q1 
\v 13 A i kin kapakap o\it n\it* komui Mai\it n\it* Ieowa ni anjau me kon o\it n\it*; Mai\it n\it* Kot, kom kotin ma\it n\it*i ia pweki omui kala\it n\it*an lapalap o kotin jauaja ia.
\q1 
\v 14 Kotin dore ia la ja\it n\it* nan pwel, pwe i ender kirila; pwe i en piti ja\it n\it*, me kailo\it n\it* kin ia o ja\it n\it* nan pil lol;
\q1 
\v 15 Pwe lapake ender kamop ia la, o waja lol ender kadala ia la, o au en por o ender pur pena o\it n\it* po i.
\q1 
\v 16 Ma\it n\it*i ia, Mai\it n\it* Ieowa, pwe omui kala\it n\it*an meid mau, kom kotin majan do\it n\it* ia, pweki omui kala\it n\it*an lapalap.
\q1 
\v 17 O kom der karirela ja\it n\it* japwilim omui ladu jila\it n\it* omui, pwe i majak; kom kotin mada\it n\it* ma\it n\it*i ia!
\q1 
\v 18 Kom kotido ren \it n\it*en i o dorela i, kotin dore ia la pweki ai imwintiti kan.
\q1 
\v 19 Komui ma\it n\it*ier duen ai jarodier, o ai lijela, o ai namenok, me palian ia, kin janjal o\it n\it* komui.
\q1 
\v 20 Ai jarodier kin kawela nan mo\it n\it*io\it n\it* i, o i luetalar melel. i auiaui, ma jota me pan injenjuedeki mepukat, a jota man amen; o ma jota, me pan kamait ia la, a jota me i kak diar.
\q1 
\v 21 Irail kin kamana kin ia ede, o kanim pil kin ia pi\it n\it*ika ni ai men nim piladar kaualap
\q1 
\v 22 Arail tepel en wiala injar arail, o lidip arail, o kapup arail.
\q1 
\v 23 Maj arail en rotorotala, pwe ren der kila\it n\it* waja, o irail en koj pena kokolata.
\q1 
\v 24 Wudokidi o\it n\it* po ’rail omui o\it n\it*io\it n\it*, o omui o\it n\it*io\it n\it* melel en lel o\it n\it* irail.
\q1 
\v 25 Deu ’rail en lijelipi\it n\it*da, o jota me pan kaujon nan im arail.
\q1 
\v 26 Pwe re kin pakipaki, me kom kotin kaloker, o re kin indinda, me dene komui kin kaloke mal japwilim omui kan.
\q1 
\v 27 Kom kotin kaloedi o\it n\it* ir ni japu\it n\it* toto, pwe ren der konodi omui pu\it n\it*.
\q1 
\v 28 Irij ja\it n\it* ir nan puk en kamaur, pwe ren der ian me pu\it n\it* kan kileledi.
\q1 
\v 29 A \it n\it*ai me luet, o i kin waiwairok. Mai\it n\it* Kot, omui jauaja ia en jinjila ia.
\q1 
\v 30 I pan kapi\it n\it*a mar en Kot ki kaul pot, o i pan wauneki i melel ki danke.
\q1 
\v 31 I me Ieowa kotin kupura ja\it n\it* kau ol, me oje o pat en na pualapual mia.
\q1 
\v 32 Me luet akan kin kila\it n\it*, o peren kida, o me kin rapaki Kot, mo\it n\it*io\it n\it* arail pan maurada.
\q1 
\v 33 Pwe Ieowa kotin ma\it n\it*i me jamama kan, o a jota kotin mamaleki japwilim a jalidi kan.
\q1 
\v 34 Nanla\it n\it* en kapi\it n\it*a i, pil jappa, o madau, o karoj me kin mokimokid lole.
\q1 
\v 35 Pwe Kot pan kotin jauaja Jion, o a pan kauada kanim en Iuda kan, pwe aramaj en kaujon waja o, o aneki.
\q1 
\v 36 O wan a ladu kan pan jojoki irail, o me kin pok o\it n\it* mar a, pan kaujon waja o.
\c 70
\q1 
\v 1 MAI\it N\it* Kot kom kotin mada do, dore ia la, Mai\it n\it* Ieowa, pwen jauaja ia!
\q1 
\v 2 Me kin majamajan ia, en namenokala o jarodi, o me kin peren kida ai apwal akan, en ponjeker wei o lejila.
\q1 
\v 3 Pwe irail me kin indinda due ai: Io ol o! ren namenokala.
\q1 
\v 4 A me kin idok komui, en pereperen o popolki komui, o me kin pok on omui maur, en indinda anjau karoj: Kot meid kapi\it n\it*an.
\q1 
\v 5 A \it n\it*ai me luet o jamama. Mai\it n\it* Kot, kom kotin mada\it n\it* do\it n\it* ia, pwe komui ta jauaj pa i o ai jaundor; Mai\it n\it* Ieowa, kom der kotin pwand!
\c 71
\q1 
\v 1 MAI\it N\it* Ieowa, i liki komui, kom der mueid o\it n\it*, i en jarodi kokolata.
\q1 
\v 2 Kom kotin dore ia la pweki omui pu\it n\it*, o kotin jauaja ia, o kotin kapaike do\it n\it* ia karo\it n\it* omui kan o jauaja ia.
\q1 
\v 3 Komui en koti wiala ia paipalap, waja i pan kak pitila ia anjau karoj, pwe kom kotin inauki o\it n\it* ia er, me kom pan dore ia la, pwe komui ai paip o ai kel.
\q1 
\v 4 Ai Kot, jauaja ia ja\it n\it* nan pa en me doo ja\it n\it* Kot, o ja\it n\it* nan pa en me japu\it n\it* o weit.
\q1 
\v 5 Pwe komui kapore pa i, Mai\it n\it* Ieowa, komui ai kel ja\it n\it* ni ai pulepul.
\q1 
\v 6 I liki komui ja\it n\it* ni ai ipwidier, o komui me kaipwi ia ja\it n\it* nan kaped en in ai, i pan kapi\it n\it*a komui kokolata.
\q1 
\v 7 \it N\it*ai dueta meakot me kapuriamui o\it n\it* me toto; a komui kel pa i manaman.
\q1 
\v 8 Kom kotin kadireki au ai kapi\it n\it* o danke o\it n\it* komui.
\q1 
\v 9 Kom der kotin kaje ia la ni ai mala, o der muei ja\it n\it* ia ni ai pan luetala.
\q1 
\v 10 Pwe ai imwintiti kin palian ia ni ar lokaia, o me kin majamajan ia, kin kapakapu\it n\it* pena,
\q1 
\v 11 O indinda: Kot muei ja\it n\it*er i, komail paki o koledi i, pwe jota jauaj pa a.
\q1 
\v 12 Mai\it n\it* Kot, kom der kotin doo wei ja\it n\it* ia, Mai\it n\it* Kot! Kom kotin mada\it n\it*do o jauaja ia.
\q1 
\v 13 A me palian ia en namenokala o jarodi; o me rapa kin ia, pwen kame ia la, ren kadupale kidi namenok o lalaue.
\q1 
\v 14 A i pan auiauita, o i pan kalaudela ai kapi\it n\it* o\it n\it* komui kokolata.
\q1 
\v 15 Au ai en kaloki jili omui pu\it n\it*, o omui kamau pan ran karoj, me jota kak wadawad pena.
\q1 
\v 16 I kin weweid jili ni mana en Ieowa Kaun; i pan kapi\it n\it*a omui pu\it n\it* eta.
\q1 
\v 17 Mai\it n\it* Kot, kom kotin padaki o\it n\it* ia er ja\it n\it* ni ai pulepul, o i kaloki jili omui manaman akan ja\it n\it* maj kokodo lel met.
\q1 
\v 18 Mai\it n\it* Kot, kom der kotin muei ja\it n\it* ia ni ai mala, pit en mo\it n\it* ai lao puetepuetala, lao i pan padaki o\it n\it* jeri en jeri kan omui wiawia o o\it n\it* me pan kokodo omui manaman.
\q1 
\v 19 Mai\it n\it* Kot, omui pu\it n\it* meid ileile, kom kin wiada dodok lapalap. Mai\it n\it* Kot, ij me rajo\it n\it* komui?
\q1 
\v 20 Pwe komui kotiki o\it n\it* kit er kamajak laud o toto, o kom kotin pur o\it n\it* kamau kit ada o wai ia dado ja\it n\it* nan waja lol.
\q1 
\v 21 Komui pan kotin kaileile ia da, o kom pan kotin pur o\it n\it* kamait ia la.
\q1 
\v 22 I ap pan kapi\it n\it*aki komui kaja\it n\it*, pweki omui melel, ai Kot, I pan kauleki o\it n\it* komui arp, o\it n\it* komui, me Jaraui en Ijrael.
\q1 
\v 23 Kil in au ai o \it n\it*en i, me re kotin dorelar, pan pereperen o kauli o\it n\it* komui.
\q1 
\v 24 Pil lo i pan indinda duen omui pu\it n\it* ja\it n\it* manja\it n\it* lel jautik. Pwe irail, me men kawe ia la, namenokala o jarodier.
\c 72
\q1 
\v 1 MAI\it N\it* Kot, kom kotiki o\it n\it* nanmarki en kapu\it n\it*, o kotiki o\it n\it* nain nanmarki ol omui pu\it n\it*.
\q1 
\v 2 Pwen kaunda japwilim omui aramaj akan nin tiak pu\it n\it*, o dorela japwilim omui me luet akan.
\q1 
\v 3 Nana kan en kare do\it n\it* aramaj akan popol o dol akan me pu\it n\it*.
\q1 
\v 4 A pan jauaja pu\it n\it* en me luet ren aramaj akan; a pan dorela nain me jamama kan, o pan tiakedi me morjued o.
\q1 
\v 5 Aramaj pan majak komui ja\it n\it* eu kainok lel eu kainok, arain katipin o jaunipo\it n\it* mia.
\q1 
\v 6 A pan kotidi dueta katau o\it n\it* mat kap, dueta katau me kawujokejok jap o.
\q1 
\v 7 Me pu\it n\it* o pan memaurata ni a ran akan, o muei mau pan pwaida, lao jaunipo\it n\it* jolar mia.
\q1 
\v 8 A pan kotin kaunda ja\it n\it* eu madau lel wo\it n\it* eu, o ja\it n\it* pilap o lel ni imwin jappa.
\q1 
\v 9 Me kaukaujon nan jap tan, pan dairukedi o\it n\it* mo a, o a imwintiti kan pan ka\it n\it*ala pwel par.
\q1 
\v 10 Nanmarki en Tarjij o me mi nan dake kan, pan wa do\it n\it* i ar kijakij; nanmarki en Arapia o Jepa pan wia nopwei.
\q1 
\v 11 Nanmarki kan karoj pan kaudoki o\it n\it* i, men liki kan karoj pan upa o\it n\it* i.
\q1 
\v 12 Pwe a pan dorela me jamama o, me kin weriwer, o me luet, me jota jauaj pa.
\q1 
\v 13 A pan kupura me tikitik o jamama, o pan kotin jauaja \it n\it*en en me jamama kan.
\q1 
\v 14 A pan kotin dorela \it n\it*en arail ja\it n\it* ren me morjued o weit, o nt’ arail me kajampwal mon jila\it n\it* i.
\q1 
\v 15 A pan ieiajata o kold ja\it n\it* wein Arapia pan wijik wo\it n\it* i, o aramaj akan pan kapakapaki i anjau karoj, a pan kapaida ni anjau karoj.
\q1 
\v 16 Wantuka kan pan pwaida mau nin jappa o pon nana kan, korn pan momand dueta Lipanon; o aramaj akan pan woj ada nan kanim akan dueta ra nan jap o.
\q1 
\v 17 Mar a pan duedueta kokolata; arain katipi\it n\it* a pan mimieta, iduen warai en mar a, o re pan kapaikida i; men liki kan karoj pan kapi\it n\it*a i.
\q1 
\v 18 Kapi\it n\it* o\it n\it* Kot leowa, Kot en jrael, i eta, me kin wiada manaman akan.
\q1 
\v 19 O kapi\it n\it* o\it n\it* mar a li\it n\it*an kokolata, o jap karoj en direki a wau! Amen, amen!
\q1 
\v 20 Iet imwilan kapakap en Dawid nan Ijai.
\c 73
\q1 
\v 1 MELEL, Kot kompoke pan men Ijrael, irail me makelekel nan monion arail.
\q1 
\v 2 A \it n\it*ai, ekij ta, a na i kat pan lodi, o I koren io\it n\it* krijedi ni ai kakakawei.
\q1 
\v 3 Pwe I juedeki me aklapalap akan, ni ai kila\it n\it*er en me japu\it n\it* akn ar pwaidar.
\q1 
\v 4 Pwe jota apwal kot lel o\it n\it* irail ni ar pan mela, re kin kelail o war arail wilar melel.
\q1 
\v 5 Jota ar apwal kot dueta aramaj tei kan, o re jota pan kalokolok dueta aramaj tei kan.
\q1 
\v 6 Ari aklapalap, iei kapwat en tapin wor arail, o arail likau, iei arail tiak weit.
\q1 
\v 7 Por en maj arail tikitik o jued kilar ar wilar, o re kin wiada, me re ino\it n\it* io\it n\it*.
\q1 
\v 8 Re kin mamaleki meakaroj, o re kin lokelokaia me jued, o re kin lalaue o lokaia ni ar aklapalap.
\q1 
\v 9 Dene arail lokaia tapi ja\it n\it* nanla\it n\it*, o me irail indinda, dene I eta me pu\it n\it* ni jappa.
\q1 
\v 10 I me aramaj akan lokididi o\it n\it* irail; o pil totoia re kin nimala.
\q1 
\v 11 Re kin inda: Iaduen, Kot pan kotin injenoki irail? O menda ren me aklapalap irail?
\q1 
\v 12 Kila\it n\it*, iduen me doo ja\it n\it* Kot akan; irail meid pai nin jappa, o re pan kapwapwala.
\q1 
\v 13 Iaduen, likamata jota katopa ai kamakelekeladar mo\it n\it*io\it n\it* i o kaminela pa i kat ni me pu\it n\it*?
\q1 
\v 14 Pwe ran karoj i pan kalokolok, o ni manjan karoj ai kamekam mia.
\q1 
\v 15 Koren io\it n\it* i pil pan indinda dueta irail, a jo, pwe i de pan juedeki japwilim omui jeri kan karoj ja\it n\it* maj kokodo lel met.
\q1 
\v 16 I ap madamadaua duen mepukat, pwen dedeki, a i jota kak o\it n\it*.
\q1 
\v 17 \it N\it*ai lao pedelo\it n\it* o\it n\it* mon mol en Kot jaraui o kila\it n\it*er imwin mo doo ja\it n\it* Kot akan.
\q1 
\v 18 Melel kom kotin pwili kin irail edi waja likakerij; kom kotin kapup irail edi o\it n\it* nani pwel.
\q1 
\v 19 Iaduen arail mada\it n\it* joredier. Irail lokidokila, o imwila ’rail meid kamajapwek.
\q1 
\v 20 Mai\it n\it* Ieowa, kom kin kotin kawela mom arail nan kanim o dueta auramen.
\q1 
\v 21 Ni ai madak nan mo\it n\it*io\it n\it* i, o waiwairok nan ai mudilik kan,
\q1 
\v 22 I ap diaradar, me \it n\it*ai ol pweipwei men, me jota aja meakot; dueta man amen mo omui.
\q1 
\v 23 Ari jo, i pan mimieta re omui kokolata, pwe komui kotin kolekol eta pa i pali maun.
\q1 
\v 24 Komui kin kalua ia duen kupur omui, o kom pan kotin kajamo ia nan li\it n\it*an omui.
\q1 
\v 25 Ma komui ta ai Kot, i jota pan anane meakot nanla\it n\it* de jappa.
\q1 
\v 26 Ma pali war ai o \it n\it*en i pan dupokala, pil menda, pwe komui Mai\it n\it* Kot kamait pa i o pwaij ai kokolata.
\q1 
\v 27 Pwe kom kotin ma\it n\it*i irail, me muei ja\it n\it* komui pan lokidokila; Kom pan kotin kajapokela karoj, me wuki wei ja\it n\it* komui.
\q1 
\v 28 A iet ai peren, i en te\it n\it*ete\it n\it* o\it n\it* Kot, o i en kaporoporeki Kot leowa, pwen kalok jili omui wia wia kan karoj.
\c 74
\q1 
\v 1 MAI\it N\it* Kot, da me kom kotin kaje kin kit ala, o da me re o\it n\it*io\it n\it*iki japwilim omui jip akan?
\q1 
\v 2 Kom kotin kupura japwilim omui momodijou, me kom kotin pwaindar maj o, o me komui dorelar, pwen wiala japwilim omui, kotin kupura dol Jion, waja me kom kotikot ia.
\q1 
\v 3 Kom koti do\it n\it* waja me lijelipi\it n\it* anjau warai; imwintiti me kawelar meakaroj nan im jaraui.
\q1 
\v 4 Me palian komui, kin weriwer nan tanpaj omui o pwilikidi arail dikedik en ani mal akan lole.
\q1 
\v 5 Irail pwaradar dueta ir, me wia palapal nan wei.
\q1 
\v 6 Re kin kawela did kajelel akan ki jile laud o tikitik.
\q1 
\v 7 Irail karo\it n\it*ala tanpaj omui; irail kajaminela o tiakedi waja me mar omui kotikot ia.
\q1 
\v 8 Irail kin inda nan mo\it n\it*io\it n\it* arail: Na, kitail pan kawela! Irail karo\it n\it*alar wajan kaudok karoj nan jap o.
\q1 
\v 9 Jolar manaman akai janjal o\it n\it* kitail, o jolar jaukop amen mia, o jota amen re atail me pan aja imwilan mepukat.
\q1 
\v 10 O Mai\it n\it* Kot, arai da me morjued o pan lalaue, o imwintiti o pan mamaleki mar omui?
\q1 
\v 11 Da me komui kotiki wei ja\it n\it* lim omui? Kotikida pali maun omui o kaimwijokala.
\q1 
\v 12 Pwe Kot ai Nanmarki ja\it n\it* maj o. I me jauaj pan meakaroj, me kin wiaui nin jappa.
\q1 
\v 13 Kom kotin kamueit paja\it n\it*er madau ki omui manaman, o kom kotin kawelar mo\it n\it*an drake nan pil.
\q1 
\v 14 Kom kotin kawelar mo\it n\it*an walroj, ap kotiki o\it n\it* aramaj nan jap tan, pwen ka\it n\it*ala.
\q1 
\v 15 Komui kotin kapwaredar parer o pilap akan, o pilap kalaimun akan me kom kotin ka\it n\it*ala\it n\it*aladi.
\q1 
\v 16 Ran o po\it n\it* me japwilim omui; komui kotin wiadar jaunipo\it n\it* o katipin.
\q1 
\v 17 Komui wiadar irair en jap akan; komui me kin wia anjaun karakar o kapou.
\q1 
\v 18 Kom kotin kupura mepukat: Imwintiti o lalaue komui Mai\it n\it*, o aramaj pweipwei kan mamaleki mar omui.
\q1 
\v 19 Kom der kotiki o\it n\it* man laualo \it n\it*en en japwilim omui muroi, o kom der likidmaliela pwin en japwilim omui luet akan.
\q1 
\v 20 Kom kotin tamanda inau o, pwe jap olar waja karoj o im akan pual paja\it n\it*er.
\q1 
\v 21 Re der kotin mueid o\it n\it* me luet o, en namenok purela, me jamama o luet akan en kapi\it n\it*a mar omui.
\q1 
\v 22 Mai\it n\it* Kot, kom kotida o kotin kaimwijokala japwilim omui dodok; kom kotin tamanda kankaurur, me kin wiaui o\it n\it* kmui ja\it n\it* ren me pweipwei kan.
\q1 
\v 23 Kom kotin der maliela weriwer en japwlim omui imwintiti, moro\it n\it*oro\it n\it* en me palian komui kan, me kin lalaudalar karoj.
\c 75
\q1 
\v 1 Je kapi\it n\it*a komui, Mai\it n\it* Kot, je kapi\it n\it*a komui, pwe mar omui me koren, o omui manaman akan kaloki jili due.
\q1 
\v 2 Pwe ni a anjau I pan wiada kapu\it n\it* pu\it n\it*.
\q1 
\v 3 Jap o tou a kan kin rerer; a I kin kolekol a ur akan.
\q1 
\v 4 I inda\it n\it* me aklapalap akan: Komail der aklapalap! O o\it n\it* me doo ja\it n\it* Kot akan: Komail der keleki omail manaman!
\q1 
\v 5 Komail der kaileilada mo\it n\it* omial, komail der kokaia jued ni omail aklapalap.
\q1 
\v 6 Pwe jota jauajpa ja\it n\it* ni maj en la\it n\it* de kapin la\it n\it*, de ja\it n\it* nana en jap tan.
\q1 
\v 7 Pwe Kot, me kin kadeikada, o me kin kajapwilidi amen, o kajapwilada amen.
\q1 
\v 8 Pwe dal eu mi nan lim en Ieowa, me dir en wain kelail, me a kotin kodidodie; a me doo ja\it n\it* Kot akan karoj nan jappa pan nim ja\it n\it*, o re pan nimala moroke.
\q1 
\v 9 A I pan padapadak kokolata, o kaulion Kot en Iakop.
\q1 
\v 10 I pan kawela mana en me doo ja\it n\it* Kot akan karoj, a mana en me pu\it n\it* kan pan kakairida.
\c 76
\q1 
\v 1 KOT me indand mau ren Iuda, o mar a me li\it n\it*an ren men Ijrael.
\q1 
\v 2 Tanpaj a im pwal mi nan Jalem, o tanpaj a mi Jion.
\q1 
\v 3 I waja a kotin katip paja\it n\it* ia kana\it n\it*an kajik katieu, o pere, o kodlaj, O tatan mauin.
\q1 
\v 4 Komui me li\it n\it*an o manaman ja\it n\it* dol en mauin kan.
\q1 
\v 5 Me aklapalap akan lodier o\it n\it* men kul akan o mela, o jaunpei komad karoj en kidi pa arail.
\q1 
\v 6 Mai\it n\it* Kot en Iakop oj o war kin pupekidi omui majan akan.
\q1 
\v 7 Komui meid kamajapwek. Ij me kak u mo ’mui ni omui o\it n\it*io\it n\it*?
\q1 
\v 8 Ni omui kotin kajaledar omui kadeik ja\it n\it* nanla\it n\it*, jappa ap majapwekadar o nenenlar,
\q1 
\v 9 Ni en Kot a kotidar, pwen kadeik, o jauaja me luet akan karoj nin jappa.
\q1 
\v 10 Pwe makar en aramaj kin kali\it n\it*a\it n\it*ada komui, o ma re pan pur o\it n\it* moromoro\it n\it*, luan omui o\it n\it*io\it n\it* pan itar o\it n\it* irail.
\q1 
\v 11 Komail inau o\it n\it* Ieowa omail Kot o kapwaiada. Komail karoj, me mi impa, wa do\it n\it* ren me kalom omail kijakij akan.
\q1 
\v 12 I me pan atia ja\it n\it* jaupeidi kan ar komad, a meid kalom o\it n\it* nanmarki en jappa kan.
\c 77
\q1 
\v 1 I KIN likwirki \it n\it*il ai o\it n\it* Kot, o\it n\it* Kot, me i pan likwir o\it n\it*, o i me kotin ma\it n\it*i ia.
\q1 
\v 2 Ni ai anjau apwal, i kin rapaki leowa; ni po\it n\it* pa i kin u wei o jota kin dukedi, pwe wen I jota kak injenemaula.
\q1 
\v 3 Ni ai tamanda Kot, i kin ajenokida, ni ai madamadaua, \it n\it*en i kin luetala.
\q1 
\v 4 Kom kin kotin kolekol por en maj ai, pwe ira en papat; \it n\it*ai inen en luet, jolar itar o\it n\it* lokaia.
\q1 
\v 5 I kin lamelame duen ran en maj akan, duen par akan me jamalar.
\q1 
\v 6 Ni po\it n\it* i kin lamelame duen ai kaja\it n\it* arp, o mo\it n\it*io\it n\it* i kin madamadaua; \it n\it*en i kin raparapaki.
\q1 
\v 7 Kalelapok, leowa pan kotin o\it n\it*io\it n\it* kokolata, o a jota pan kotin maki o\it n\it*?
\q1 
\v 8 A kala\it n\it*an rojelar melel, o a inau imwijokalar kokolata?
\q1 
\v 9 Kot kotin malielar a mak o\it n\it* kit, o a karirikilar o\it n\it*io\it n\it* a kala\it n\it*an?
\q1 
\v 10 Ari jo, i indadar: Mepukat me mau o\it n\it* ia; pali maun en lim en me Lapalap pan kak dorela meakaroj.
\q1 
\v 11 I me i kin taman kida wiawian leowa; melel i kin tamanda omui manaman akan ja\it n\it* maj o,
\q1 
\v 12 O madamadaua duen omui wiawia kan karoj, o kilekila\it n\it* duen omui dodok.
\q1 
\v 13 Mai\it n\it* Kot, al omui me pu\it n\it*. Ia waja amen Kot manaman mia dueta Kaun o?
\q1 
\v 14 Komui ta Kot me kin wia manaman akan. Komui kotin kajanjaledar omui manaman nan pu\it n\it* en wei kan.
\q1 
\v 15 Komui kotin dore kila japwilim omui kan omui manaman, iei jeri en Iakop o Iojep akan.
\q1 
\v 16 Pil akan ariri komui, Mai\it n\it* Kot, pil akan ariri komui, rap majapwekadar, o waja lol rererdar.
\q1 
\v 17 Tapok kalaimun akan kamoredier pil, tapok kan wiadar nanjapwe, o liol piripir jili.
\q1 
\v 18 Nanjapwe wiauier nanla\it n\it*; japwilim omui liol akan kamaraini jappa; jappa mokieda o rerer.
\q1 
\v 19 Al omui mi nan madau, al omui tatik nan pil kalaimun akan, o jota me kaan aluwilu omui.
\q1 
\v 20 Kom kotin kalua japwilim omui kan dueta pwin eu ren Mojej o Aron.
\c 78
\q1 
\v 1 KOMAIL nai aramaj akan, ro\it n\it* ai kujoned; komail kapaike do\it n\it* jalo\it n\it* omail padak en au ai!
\q1 
\v 2 I pan ki paja\it n\it* au ai, pwen padak, o pan kida kajoi en maj o,
\q1 
\v 3 Me kitail ro\it n\it*adar o ajaer, o jam atail kajoi o\it n\it* kitail er,
\q1 
\v 4 Pwe kitail ender karirila ja\it n\it* kadaudok arail, me pan pwarado mur, o kaparokki wau en leowa, o a manaman o a dodok kapuriamui kan.
\q1 
\v 5 Pwe a kotin kauada men kataman eu ren Iakop, o kotikida kapu\it n\it* eu ren men Ijrael, me u kotin kakaliki o\it n\it* jam atail akan, pwe ren ujela\it n\it* nair jeri kan,
\q1 
\v 6 Pwe di en mur en aja due, o jeri ko, me pan ipwidi; o ni ar kokoda, ren pil kajoi o\it n\it* nair jeri kan
\q1 
\v 7 Pwe irail en kaporoporeki Kot, o ren der monokela en Kot a wiwia kan, o ren kapwaiada a kujoned akan.
\q1 
\v 8 O ren der dueta jam arail akan, me kainok ka\it n\it*udi o katiwo eu, me mo\it n\it*io\it n\it* arail jota te\it n\it*ete\it n\it*, o \it n\it*en arail jota melel on Kot.
\q1 
\v 9 Dueta kainok Epraim, me wa tatan mauin, ap purela ja\it n\it* nan pei.
\q1 
\v 10 Irail jota dadaurata inau en Kot, o re jota men weweideki duen a kujoned akan.
\q1 
\v 11 O re monokelar a wiawia kan o a manaman akan, me a kotin kajaljale o\it n\it* irail er.
\q1 
\v 12 A kotin wiadar manaman akai janjal mon jam arail akan nan Akipten, nan jap Joan.
\q1 
\v 13 A kotin pala\it n\it* paja\it n\it* madau o kotin mueid o\it n\it* ir, en kotela, o wiadar pil dueta kel takai eu.
\q1 
\v 14 A kotin kalua kin irail tapik ni ran o, o ni po\it n\it* umpul en kijiniai.
\q1 
\v 15 A kotin palan paja\it n\it* paip nan jap tan o kanim pile kin irail pil toto.
\q1 
\v 16 O a kotin kapkapwile wei pilap kai ja\it n\it* nan paip, pwe ren pwile wei dueta pilap laud akan.
\q1 
\v 17 Ari jo, re dadaurata ni arail didi o\it n\it* I, o re kao\it n\it*io\it n\it*i me Lapalap o nan jap tan.
\q1 
\v 18 O re kajo\it n\it*ejon Kot nan mo\it n\it*io\it n\it* arail, ni ar ino\it n\it* io\it n\it* kan arail ma\it n\it*a.
\q1 
\v 19 O re palian Kot ni ar inda: Melel Kot pan kak wiada tepel eu nan jap tan?
\q1 
\v 20 Kila\it n\it*, a poki paip o, pe pil en pwarado o pilap akan pwilepwile wei, a iaduen, a pan kak kida prot o uduk on na aramaj akan?
\q1 
\v 21 Ieowa lao ma\it n\it*ier mepukat, ap kotin o\it n\it*io\it n\it*adar, o kijiniai wiauier ren Iakop, o o\it n\it*io\it n\it* lel o\it n\it* Ijrael,
\q1 
\v 22 Pweki ar jo kamelele Kot, o jota kaporoporeki a jauaj.
\q1 
\v 23 A ap kotin majani o\it n\it* tapok en poa kan, o riti\it n\it*ida wanim o\it n\it* la\it n\it* akan.
\q1 
\v 24 O kotin kamoredi o\it n\it* ir mana, pwe ren ma\it n\it*a, o a kotiki o\it n\it* ir prot en la\it n\it*.
\q1 
\v 25 Irail ka\it n\it*alar prot en tounla\it n\it* kan; a kotin kadar o\it n\it* ir kijin ma\it n\it*a toto.
\q1 
\v 26 A kotin kapwaredar pan la\it n\it* a\it n\it* en maj en la\it n\it*, o ni a manaman a kotin kamokidada an en pali air.
\q1 
\v 27 O a kotin kamoredi o\it n\it* ir uduk dueta pwel par, o manpir dueta pik en oror.
\q1 
\v 28 O a kotin kapup irail di waja karoj, me irail kaujon ia.
\q1 
\v 29 Rap ma\it n\it*ama\it n\it*a o medilar kaualap, o a kotin mueid o\it n\it* ir ar ino\it n\it*.
\q1 
\v 30 A ni ar kapwaiadar ar ino\it n\it*, o ni ar ma\it n\it*ama\it n\it*a.
\q1 
\v 31 O\it n\it*io\it n\it* en Kot ap lel o\it n\it* irail er, o kamelar ol lapalap re ’rail, o kotin wokiedi mana kap en Ijrael kajampwal akan.
\q1 
\v 32 A re kalaudelar arail dip, o re jota kamelele a manaman akan.
\q1 
\v 33 I me a kotin mueidoki ren mela, re jota paida, o ar apwal akan me toto arain ar maur.
\q1 
\v 34 Ni a kotin kame irail la, rap idok i, o wukila, o rapaki Kot.
\q1 
\v 35 O re tamandar, me Kot kele parail o Kot lapalap ar jaundor.
\q1 
\v 36 O re lik janjal mau o\it n\it* i ni au arail o re likam o\it n\it* i ni lo ar.
\q1 
\v 37 A mo\it n\it*ion arail jota te\it n\it*ete\it n\it* o\it n\it* i, o re jota dadaurata melel a inau.
\q1 
\v 38 Ari jo, a kotin kala\it n\it*an o\it n\it* ir, o kotin makeki o\it n\it* ir dip arail, o jota kame irail la, o katukiedi a o\it n\it*io\it n\it* pan pak toto, o jota o\it n\it*io\it n\it*i melel.
\q1 
\v 39 Pwe a kotin kupura, me irail pali uduk, dueta kijinia\it n\it*, me pir wei o jolar puredo.
\q1 
\v 40 Pan pak toto re ka\it n\it*udi o\it n\it* i nan jap tan, o kakupur juedi i nan mal.
\q1 
\v 41 Irail pur o\it n\it* anjau karoj kajo\it n\it*ejo\it n\it* Kot, o re akapu\it n\it*i o\it n\it* me Jaraui ren men Ijrael.
\q1 
\v 42 Re jolar tamanda lim a manaman, me dore ir ala ja\it n\it* ar imwintiti kan ni ran o.
\q1 
\v 43 Duen a kotin wiadar a manaman akan nan Akipten o a dodok kapuriamui nan Joan.
\q1 
\v 44 A kotin kawuki o\it n\it* nta ar pil akan, rap jolar kak nima ja\it n\it* ar pilap akan.
\q1 
\v 45 Ni a kotin kapwaredar man jued akan nan pu\it n\it* arail, me ka\it n\it* ir ala, o proj akan, me kawe ir ala.
\q1 
\v 46 A kotiki o\it n\it* muedi ar tuka kan, o ar wantuka o\it n\it* man jiek.
\q1 
\v 47 A kotin kawekilar akel ar wain o tuka kan ki akel tikitik.
\q1 
\v 48 A kotin kamekila ar man akel akan o ar pwin man akan liol.
\q1 
\v 49 A kotin o\it n\it*io\it n\it* melel o porone wo\it n\it* ir tounla\it n\it* jued kai, o mueid o\it n\it* ir, ren li\it n\it*ara\it n\it*ar, o morjued, o kainjenjued.
\q1 
\v 50 A kotin kaonopa da\it n\it* o\it n\it*io\it n\it* al apot, o jota dorelar maur arail ja\it n\it* mela, o kotin mueid o\it n\it* kilitop ni maur arail.
\q1 
\v 51 A kotin kamelar mejeni karoj nan Akipten, mejeni en ar kelail nan im en Am akan.
\q1 
\v 52 A kotin kaluala japwilim a kan dueta pwin jip eu nan jap tan.
\q1 
\v 53 A kotin kalua irail ni pu\it n\it*, pwe ren der majak meakot, a madau kadupaledi ar imwintiti kan.
\q1 
\v 54 A kotin wa ir ala lel ni irair en jap jaraui, lel nana wet, me lim a pali maun kileledier.
\q1 
\v 55 O kotin pakipaki men liki kan mo ’rail, o kotin nek o\it n\it* ir jap arail, pwen jojoki, o a kotiki o\it n\it* kainok en Ijrael akan, en kaukaujon nan im arail.
\q1 
\v 56 A re jo\it n\it*ejo\it n\it*? o kao\it n\it*io\it n\it* Kot lapalap, o jota peiki o\it n\it* i, o jota duki o\it n\it* a majan akan.
\q1 
\v 57 O re muei ja\it n\it* o mamaleki meakaroj, dueta jam arail akan, o re jota te\it n\it*ete\it n\it*, dueta kajik katieu luet eu.
\q1 
\v 58 O re kao\it n\it*io\it n\it* i ni ar kaudok pon dol akan, o re kupur juedeki i ki arail dikedik en ani kan.
\q1 
\v 59 A Kot lao kotin ma\it n\it*i mepukat, ap kotin o\it n\it*io\it n\it*ada o kajapok ir ala melel.
\q1 
\v 60 A kotin muei ja\it n\it* tanpaj a nan Jilo, im pwal o, waja a kotikot ia ren aramaj akan.
\q1 
\v 61 A kotiki wei japwilim akan nan imate\it n\it*, o a li\it n\it*an nan pa en imwintiti kan.
\q1 
\v 62 A kotiki wei japwilim a aramaj akan ni kodlaj, o kotin o\it n\it*io\it n\it*i japwilim a jojo.
\q1 
\v 63 Kijiniai ka\it n\it*ala ar manakap akan, o ar peinekap akan jolar kak papaud.
\q1 
\v 64 Arail jamero kan mekilar kodlaj, a jolar li odi kan, me kin maiei.
\q1 
\v 65 Ieowa ap kotin opala waja dueta amen me mairelar, dueta ol komad amen kin \it n\it*iji\it n\it*ij ni a ka\it n\it* wain.
\q1 
\v 66 A kotin kaloedier a imwintiti kan o kanamenok ir ala kokolata.
\q1 
\v 67 A kotin kajelar im en Iojep, o jota piladar kainok en Epraim.
\q1 
\v 68 Pwe a kotin piladar kainok en Iuda, kol Jion, me a koti kupura.
\q1 
\v 69 O a kotin kauadar tanpaj a im jaraui waja ileile, dueta jappa me pan te\it n\it*ete\it n\it* ea kokolata.
\q1 
\v 70 Ap kotin piladar japwilim a ladu Dawid, o a kotin ale i ja\it n\it* nan deun jip akan.
\q1 
\v 71 A kotin kalua i ja\it n\it* ren jip en kadidi kan, pwen kama\it n\it*a japwilim a kainok en Iakop o a jojo men Ijrael.
\q1 
\v 72 O a kotin apapwali ir ni tiak en mo\it n\it*io\it n\it* melel o pu\it n\it*, o kakaun irail ada ni koiok en lim a kan.
\c 79
\q1 
\v 1 MAI\it N\it* Kot, men liki kan ta\it n\it* do\it n\it* japwilim omui jojo; irail kajamilela japwilim omui im jaraui, o re wiaki Ierujalem kantakai eu.
\q1 
\v 2 Re ki o\it n\it*er manpir en pan la\it n\it* akan kalep en japwilim omui ladu kan, o uduk en japwilim omui jaraui kan o\it n\it* man en nan jap akan.
\q1 
\v 3 Impan Ierujalem irail wudo kila nt’ ar dueta pil, o jota, me pan jarepedi.
\q1 
\v 4 Kit wialar kanamenok eu o\it n\it* men imp at, o me kapil kit pena, kin lalaue o kaurur kin kit.
\q1 
\v 5 Mai\it n\it* leowa, arai da kom pan kotin o\it n\it*io\it n\it*, o ino\it n\it* en kupur omui pan lulada dueta kijiniai?
\q1 
\v 6 Kom kotin wudokidi o\it n\it* men liki kan, me jaja komui, omui o\it n\it*io\it n\it*, o o\it n\it* wei kan, me jota kin likwir o\it n\it* mar omui.
\q1 
\v 7 Pwe re kawelar Iakop o im ar akan.
\q1 
\v 8 Kom der kotin tamanda dip en jam at akan; a kom kotin mada\it n\it* jauaja kit, pwe kit me malaulaular.
\q1 
\v 9 Mai\it n\it* Kot, jauaj pat, kom kotin jauaja kit, pweki wau en mar omui. Kom kotin dore kit ala o kotin maki o\it n\it* kit dip at akan, pweki mar omui!
\q1 
\v 10 Da me kom kotin mueid o\it n\it* men liki kan en inda: Ari, ia arail Kot? Kom kotin kajale o\it n\it* men liki kan depuk en ntan japwilim omui ladu kan, me wudokilar, en pil janjal mo at!
\q1 
\v 11 Kotin ma\it n\it*i ja\it n\it*ejan en me jalidi o; kom kotin kolekol kidi lim omui manaman me kileledier o\it n\it* kamela.
\q1 
\v 12 Kom kotin depukki o\it n\it* men imp at pan pak iju ar lalaue, me re lalaue kin komui.
\q1 
\v 13 A kit, japwilim omui aramaj akan, o jip en japwilim omui moj, pan danke komui kokolata, kapakaparok duen omui li\it n\it*an anjau karoj.
\c 80
\q1 
\v 1 KOMUI jile pan Ijrael, kotin ma\it n\it*i; komui me kin apapwali Iojep dueta jip akan. Kom kotido, me kaipokedi pon a\it n\it*in Kerup.
\q1 
\v 2 Kom kotin kajaleda omui manaman mon Epraim, o Peniamin, o Manaje, o kotido, pwen jauaja kit!
\q1 
\v 3 Mai\it n\it* Kot Jepaot, kom kotin kamait kit ala o kotin kajaleda jila\it n\it* omui, kit ap pan kelail kida.
\q1 
\v 4 Ieowa Kot Jepaot, arai da, kom pan kotin o\it n\it*io\it n\it*iki kapakap en japwilim omui aramaj akan?
\q1 
\v 5 Kom kin kotin kama\it n\it*a kin ir prot en pil en maj, o kom kin kanim pile kin irail pil en maj toto.
\q1 
\v 6 Kom kotin wiai o\it n\it* kit, me men imp at kin akamaiki o\it n\it* kit, o imwintiti pat kin lalaue kit.
\q1 
\v 7 Kot Jepaot, kom kotin kamait kit ala o kotin kajaleda jila\it n\it* omui, kit ap pan kelail kida.
\q1 
\v 8 Kom kotin wado ja\it n\it*er Akipten tuka wain pot, o kom kokoja\it n\it* men liki kan, ap id padukedi i
\q1 
\v 9 Kom kotin kokoi o\it n\it* i al a o kawojada i, pwen kadirela jap o.
\q1 
\v 10 Nana kan mi pan mot a, o ra kan kadupaledi jedern en Kot.
\q1 
\v 11 Kom kotin kalaudelar i lel o\it n\it* madau o ra kan lel ni pilap o.
\q1 
\v 12 Da me kom kotin kawe kilar a kel, pwe karoj me dauli kin kawela?
\q1 
\v 13 Pwik laualo dekadar, o man en nan jap kawelar.
\q1 
\v 14 Mai\it n\it* Kot Jepaot, kom kotin wukedoke do\it n\it* kit, o ireredo ja\it n\it* nanla\it n\it*, o majani, o kotin jauaja tukan wain pot et,
\q1 
\v 15 O kotin apapwali i, me lim omui padukedier, o me kom kotin apapwalier.
\q1 
\v 16 A ro\it n\it* kilar kijiniai, a paledier, re okilar majan en jila\it n\it* omui.
\q1 
\v 17 Lim omui apwali ol en pali maun omui, o irail, me kom kotin apapwalier.
\q1 
\v 18 Kit ap jota pan wuki wei ja\it n\it* komui. Kom kotin kamaur kit da, kit ap pan kapi\it n\it*a mar omui.
\q1 
\v 19 Ieowa Kot Jepaot, kom kotin kamait kit ala o kotin kajaleda jila\it n\it* omui, kit ap pan kelail kida.
\c 81
\q1 
\v 1 KOMAIL pereperen kauli o\it n\it* Kot, me kel patail; \it n\it*iji\it n\it*ij o\it n\it* Kot en Iakop!
\q1 
\v 2 Tapia kida kaul en kapi\it n\it*, o wiada tampurin, o laute kajelel ia\it n\it*aki arp!
\q1 
\v 3 Ni jaunipo\it n\it* kap komail peuk koronete, ni maram, ni ran en im tantuka!
\q1 
\v 4 Pwe iduen tiak en Ijrael kujoned en Kot en Iakop eu.
\q1 
\v 5 A kotin wiadar kujoned wet o\it n\it* Iojep, ni a lipa ja\it n\it* Akipten. I ro\it n\it*er majan pot, me i jaikenta aja:
\q1 
\v 6 I kija\it n\it*er katoutou kan pon apar a, o pa a jaladokalar ja\it n\it* kopu kan.
\q1 
\v 7 Ni om likwirki do\it n\it* ia om apwal, I ap jauaja uk; I kajale dok uk alar, ni anjau me koe lel o\it n\it* nanjapwe, o o\it n\it* jojon uk ni pil en akamai.
\q1 
\v 8 Komail nai aramaj akan ro\it n\it* ia, I pan padaki on komail! O Ijrael, ma koe pan peiki on ia!
\q1 
\v 9 Jota amen Kot en mi re om, o koe der kaudoki on kot en men wai amen.
\q1 
\v 10 \it N\it*ai Ieowa om Kot, me kalua uk ja\it n\it* nan Akipten. Ki pajan au om, i pan kadirela.
\q1 
\v 11 A nai aramaj akan joata kin peiki o\it n\it* \it n\it*il ai, o Ijrael jota duki o\it n\it* ia.
\q1 
\v 12 I ari mued on irail ere injen arail ni ar aklapalap, pwe ren kekeid wei ni pein arail lamelam.
\q1 
\v 13 O ma nai aramaj akan pan peiki on ia, o Ijrael pan weweid nan al ai kan,
\q1 
\v 14 I ap pan kaloedi ar imwintiti kan mada\it n\it*, o pa i pan u o\it n\it* me pali o\it n\it* irail akan,
\q1 
\v 15 O irail me kailonki Ieowa, jota pan kak on irail; o anjaun arail pakadeik pan duedeuta kokolata;
\q1 
\v 16 O I pan kamana kin irail korn kajelelia, o I pan katu\it n\it*ole kin I onik ja\it n\it* nan paip o.
\c 82
\q1 
\v 1 KOT kotikot nan momodijou en Kot, o I jaunkapu\it n\it* en kaun akan.
\q1 
\v 2 Arai da komail pan kadeik japu\it n\it* o kajampwaleki me doo ja\it n\it* Kot akan?
\q1 
\v 3 Jauaja pu\it n\it* en jamama o japoupou kan, o jauaja me luet o jamama kan ni ar pu\it n\it*!
\q1 
\v 4 Komail dorela me tikitik o jamama o, o kamaioda ja\it n\it* nan pa en me doo jan Kot akan.
\q1 
\v 5 A re jota kin duki o\it n\it*, o jota ar lokeko\it n\it*; re kin weweid nan rotorot; pajon en jappa kan karoj mokimokideda.
\q1 
\v 6 \it N\it*ai indada: Komail rajo\it n\it* kot akan, o nain me lapalap;
\q1 
\v 7 Ari jo, komail pan mela dueta aramaj akan, o komail pan lokidokila dueta me weit amen.
\q1 
\v 8 Mai\it n\it* Kot, kom kotida o kotin kadeikada jappa, pwe komui pan jojoki men liki kan karoj.
\c 83
\q1 
\v 1 MAI\it N\it* Kot, kom der jo majan do\it n\it*, o der japaimokid, Mai\it n\it* Kot, kom der kotin nenenla!
\q1 
\v 2 Pwe kom kotin ma\it n\it*i, japwilim omui imwintiti kan kin li\it n\it*ara\it n\it*ar, o me kailo\it n\it* kin komui, me aklapalap.
\q1 
\v 3 Irail kin widi\it n\it* ni ar kapakapu\it n\it* ki japwilim omui kan, o re kin raparapaki duen ar pan kawela japwilim omui me nekinekilar akan.
\q1 
\v 4 Re kin inda: Na kitail, kitail kokoja\it n\it* irail, pwe ren jolar wei eu, o jolar me pan inda duen wein Ijrael!
\q1 
\v 5 Pwe irail wiaki eu o re inauki pena, ren palian komui.
\q1 
\v 6 Im pwal en Edom, o Ijmael, Moap, o Akar,
\q1 
\v 7 O Kepal, o Anion, o Amalek, men Pilijta ia\it n\it*aki men Tiruj.
\q1 
\v 8 Ajor pil waroki o\it n\it* ir; re kin jauaja kadaudok en Lot.
\q1 
\v 9 Kom kotin wiai o\it n\it* ir dueta o\it n\it* men Midian, o Jijera, o lapin ni pilap Kijon.
\q1 
\v 10 Me kamelar impan Endor, rap wia pwel la nan pwel.
\q1 
\v 11 Kom kotin wiala ar jaupeidi kan dueta Orep o Jeep, o ar monjap akan karoj dueta Jepa o Jalmuna.
\q1 
\v 12 Pwe re indinda: Kitail pan kaloedi im en Kot akan!
\q1 
\v 13 Mai\it n\it* Kot kom en kotin wia kin irail la alepip en kijinia\it n\it*, dueta dip en ra mon kijinia\it n\it*.
\q1 
\v 14 Duen kijiniai kin karo\it n\it*ala tuka en wei o duen umpul en kijiniai kin ijikeda nan wel,
\q1 
\v 15 Iduen kom kotin paki kin irail japwilim omui liol ape, o kamajak kin irail omui melimel.
\q1 
\v 16 Kadire kila maj arail namenok, pwe ren rapaki mar omui, Mai\it n\it* leowa.
\q1 
\v 17 Ken namenokala o majapwekada kokolata, o ren joredi o mela.
\q1 
\v 18 Rap pan ajaki, me komui ta maraneki Kaun o me komui ta lapalap nan jap karoj.
\c 84
\q1 
\v 1 MEID kajelel tanpaj omui kan, Mai\it n\it* Ieowa Jepaot!
\q1 
\v 2 \it N\it*en i kin ino\it n\it* io\it n\it* o anane pera en tanpaj en leowa kan; pali war ai o \it n\it*en i kin polauleki Kot ieiaj.
\q1 
\v 3 Pwe manpir diaradar deu a, o jwalpe paj a, waja a kin naitik ia: Japwilim omui pei jaraui kan, Mai\it n\it* leowa Jepaot, ai Nanmarki o ai Kot.
\q1 
\v 4 Meid pai ir, me kin kaujon nan tanpaj omui! Re kin kapi\it n\it*a komui anjau karoj.
\q1 
\v 5 Meid pai karoj, me kin keleki komui, o idedauen komui melel.
\q1 
\v 6 Me kin weweid nan jap en mamaiei, waja re kin weirad parer ia; pil katau kin pwain kidi i pai kan.
\q1 
\v 7 Re kin kakairida ni ar manaman akan, lao re pan janjalada mon Kot nan Jion.
\q1 
\v 8 Mai\it n\it* leowa, Kot Jepaot, kom kotin ereki ai kapakap: Mai\it n\it* Kot en Iakop kotin ma\it n\it*i ia!
\q1 
\v 9 Kot pere pat, kom kotin majan do\it n\it* kit; kom kotin irero\it n\it* maj en japwilim omui keidier men.
\q1 
\v 10 Pwe ran ta ieu mon japwilim omui pera jaraui kan me mau ja\it n\it* ran kid; i mauki mimi pan wanim en tanpaj en Kot, ja\it n\it* kaujon nan im en me doo ja\it n\it* Kot akan.
\q1 
\v 11 Pwe Kot leowa rajo\it n\it* katipin o pere, leowa kin kotikida mak o wau, a jota pan kotin mueid o\it n\it* me lelapok kan, en anane me mau kot.
\q1 
\v 12 Mai\it n\it* leowa Jepaot, meid pai aramaj amen, me kin liki komui!
\c 85
\q1 
\v 1 MAI\it N\it* leowa, kom kotin maki o\it n\it*er japwilim omui jap maj o, o kom kotin dorelar jalidi en Iakop akan.
\q1 
\v 2 Re kotin lapwadar me jued en japwilim omui aramaj akan, o kom kotin pwaidier dip arail karoj.
\q1 
\v 3 Komui kotin kadukiedi omui o\it n\it*io\it n\it* karoj, o kotin wukidoki wei ja\it n\it*er omui o\it n\it*io\it n\it* melel.
\q1 
\v 4 Kom kotin puro\it n\it* kamait kit ala, komui Kot at jaunkamaur, o kotin katukeidi omui jokala\it n\it*an o\it n\it* kit.
\q1 
\v 5 Kom pan kotin o\it n\it*io\it n\it*i kit kokolata? Omui o\it n\it*io\it n\it* pan dueduata jan en kainok lel eu?
\q1 
\v 6 Kom jota pan kotin puron kamaur kit da, pwe japwilim omui aramaj kan en peren kin komui da?
\q1 
\v 7 Mai\it n\it* Ieowa, kom kotin kajanjaleda ar kala\it n\it*an o\it n\it* kit, o jauaja kit?
\q1 
\v 8 I men ro\it n\it*, da me Kot Ieowa pan kotin majani; pwe a pan mamajani duen mauei mau o\it n\it* japwilim a aramaj o me lelapok kan, pwe ren der lodi o\it n\it* me pweipwei.
\q1 
\v 9 Melel, a jauaj me koren io\it n\it* ir, me majak I, pwe a li\it n\it*an en mi nan jap atail.
\q1 
\v 10 Kala\it n\it*an o melel pan tu pena, pu\it n\it* o muei mau en metik pena.
\q1 
\v 11 Melel pan wojada ja\it n\it* nan jap o, o pu\it n\it* pan ireredo jan nanla\it n\it*.
\q1 
\v 12 Ieowa pil pan kotikido me mau, pwe jap atail en kida wa kan.
\q1 
\v 13 Pwe pu\it n\it* pan ti o\it n\it* mo a, o a kak akan pan wiala al arail.
\c 86
\q1 
\v 1 MAI\it N\it* Ieowa, kom kotin kapaike do\it n\it* ia karo\it n\it* omui kan o ma\it n\it*i ia, pwe \it n\it*ai me luet o jamama.
\q1 
\v 2 Kom kotin apali maur i, pwe \it n\it*ai me lelapok. Mai\it n\it* Kot, kom kotin jauaja ia, japwilim omui ladu men et, me liki komui.
\q1 
\v 3 Mai\it n\it*, kom kotin maki o\it n\it* ia, pwe i kin likwir o\it n\it* komui ni anjau karoj.
\q1 
\v 4 Kom kotin kaperenda mo\it n\it*io\it n\it* en japwilim omui ladu, pwe mo\it n\it*io\it n\it* i kin anane komui Mai\it n\it*.
\q1 
\v 5 Pwe komui Mai\it n\it* me mau o kala\it n\it*an, o kom kotin kala\it n\it*an o\it n\it* ir karoj, me kin likwir o\it n\it* komui.
\q1 
\v 6 Mai\it n\it* Ieowa, kom kotin ereki ai kapakap, o kotin ma\it n\it*i \it n\it*il en ai \it n\it*idi\it n\it*id.
\q1 
\v 7 Ni ai apwal akan i kin likwir o\it n\it* komui, pwe kom, kotin ma\it n\it*i ia!
\q1 
\v 8 Mai\it n\it*, jota me dueta komui nan pu\it n\it* en kot akan; o jota me kak wiawia dueta komui.
\q1 
\v 9 Men liki kan karoj pan pwarado, pwen kaudoki o\it n\it* komui Mai\it n\it*, o wauneki mar omui.
\q1 
\v 10 Pwe komui me lapalap, me kin wiada manaman, o komui ta me Kot.
\q1 
\v 11 Mai\it n\it* Ieowa, re kotin kajale o\it n\it* ia al omui, pwe i en weweid ni omui melel, kom kotin kolekol mo\it n\it*io\it n\it* i o\it n\it* iet eta: Majak mar omui.
\q1 
\v 12 I men kapi\it n\it*a komui Mai\it n\it*, ai Kot, ja\it n\it* nan mo\it n\it*io\it n\it* i, o wauneki mar omui kokolata.
\q1 
\v 13 Pwe omui kala\it n\it*an me laud o\it n\it* ia; komui dore maur i ja\it n\it* nan wajan mela.
\q1 
\v 14 Mai\it n\it* Kot, me aklapalap akan kin palian ia, o pwin en me weit akan kin majamajan maur i, o re jota kin weweid mon jila\it n\it* omui.
\q1 
\v 15 A komui Mai\it n\it* Kot, me dir en kala\it n\it*an, o mak, o kano\it n\it*ama, o omui kapunlol o melel me lapalap.
\q1 
\v 16 Kom kotin wukidoki do\it n\it* ia, o maki o\it n\it* ia, o kamaui kida japwilim omui ladu omui manaman, o kotin jauaja nain japwilim omui lidu!
\q1 
\v 17 Kom kotiki o\it n\it* ia kilel eu, me i pan paie kida, pwe ai imwintiti kan en kila\it n\it*, rap namenok kila omui kotin jauaja ia, Mai\it n\it* Ieowa, o kom kotin kamait ia la.
\c 87
\q1 
\v 1 A kakaudar mau pon dol jaraui kan.
\q1 
\v 2 Ieowa kotin kupura wanim en Jion ja\it n\it* wajan kaujon en Iakop karoj.
\q1 
\v 3 Kajoi kajelel mia duen koe kanim en Kot.
\q1 
\v 4 I pan kajokajoi duen Raap o Papel, me aja ia. Kila\it n\it*, Pilijta o Tiruj, o pil men Atiopia: Mepukat ipwidier waja o.
\q1 
\v 5 A kajokajoi duen Jion indinda, me jo\it n\it* en aramaj karoj ipwidi waja o, o me Lapalap o pan kotin kamanada i.
\q1 
\v 6 Ieowa pan kotin wadok, ni a pan kotin kileledi aramaj akan: Mepukat ipwidier waja o.
\q1 
\v 7 O ni ar madomado\it n\it* re pan kauleki: Ai parer karoj mi re om!
\c 88
\q1 
\v 1 MAI\it N\it* Ieowa, Kot ai jaunkamaur, i kin likwir nin ran o ni pon mo ’mui.
\q1 
\v 2 Kom kotin mueid o\it n\it*, ai kapakap en lelda wo\it n\it* komui. Kom kotin kapaik don karo\it n\it* omui kan ai likelikwir.
\q1 
\v 3 Pwe \it n\it*en i me dir en mamauk, o maur i koren io\it n\it* mela.
\q1 
\v 4 \it N\it*ai kin wadok o\it n\it* ir memelar, \it n\it*ai dueta ol amen, me jolar
\q1 
\v 5 I wonon nan pu\it n\it* en me melar akan, me wonon nan joujou, me kom jolar kotin kupura, pwe re lokidokilar ja\it n\it* nan lim omui.
\q1 
\v 6 Kom kotin kaje ia lar nan joujou, waja rotorot o lol.
\q1 
\v 7 Omui o\it n\it*io\it n\it* kin katoutou ia, o kom kotin idan kin ia di omui iluk kan.
\q1 
\v 8 Kom kotiki wo\it n\it*er kompoke pa i kan waja doo, kom kotin wia kin ia la me jued kot o\it n\it* ir, i jalidier o jo kak pitila.
\q1 
\v 9 Maj ai juede kilar ai luet, nin ran karoj i potoan o\it n\it* komui, Mai\it n\it* Ieowa, o i kapa wo\it n\it* komui pa i kat.
\q1 
\v 10 Kom pan kotin kajaleda omui manaman ren me melar akan? De me melar akan pan maurada danke komui?
\q1 
\v 11 Re pan kojoia duen omui kala\it n\it*an nan joujou kan? O wajan mela duen omui melel?
\q1 
\v 12 Omui manaman akan pan janjaleda waja rotorot, o omui pu\it n\it* nan jap en me re jolar kin lamelame?
\q1 
\v 13 A i kin potoan likwir o\it n\it* komui, Mai\it n\it* Ieowa nin manja\it n\it*, ai kapakap pan lel wo\it n\it* komui.
\q1 
\v 14 Mai\it n\it* Ieowa, da me kom kotin kaje ia kila, o da me kom okila ki jila\it n\it* ar mo i?
\q1 
\v 15 \it N\it*ai me luet o jaliel ja\it n\it* ni ai pulepul; i kin kamekamki omui kalom, i koren io\it n\it* jolar kaporopor.
\q1 
\v 16 Omui o\it n\it*io\it n\it* kin kadupal ia di, omui kalom kawe ia Iar
\q1 
\v 17 Re kapil ia pena dueta pil akan ja\it n\it* ni manja\it n\it* lel jautik, ir karoj kapil ia pena.
\q1 
\v 18 Kom kotiki wo\it n\it*er kompoke pa I oai warok kan waja doo, rotorot eta ai warok.
\c 89
\q1 
\v 1 I PAN kauleki duen kala\it n\it*an en Ieowa kokolata, o i pan kaparokki au ai omui melel ja\it n\it* eh kainok lel eu.
\q1 
\v 2 Pwe I indinda: Mak joutik eu pan pwarado, o kom pan kotin kolekol ar melel nanla\it n\it*.
\q1 
\v 3 I inauki o\it n\it*er, ai pilipildar akan; I kaulki o\it n\it*er Dawid nai ladu.
\q1 
\v 4 Kadoudok om pan mimieta kokolata, o I pan kauada mol om ja\it n\it* eu kainok lel eu.
\q1 
\v 5 Nanla\it n\it* ap kapi\it n\it*a omui manaman akan, Mai\it n\it* Ieowa, o omui melel nan pokon en japwelim omui jaraui kan.
\q1 
\v 6 Pwe ij nan tapok kan me rajo\it n\it* Ieowa? De ij me rajo\it n\it* Ieowa nan pu\it n\it* en me lapalap akan?
\q1 
\v 7 Kot meid manaman nan pokon en me jaraui kan, o meid kapuriamui o\it n\it* me kaukaujon re a.
\q1 
\v 8 Main Ieowa, Kot Jepaot, ij me jaro\it n\it* komui. Omui melel kin kapil komui pena.
\q1 
\v 9 Komui me kotin kaunda madau a\it n\it*ia\it n\it*. Komui kin kamoleilei iluk kan ni ar pan kokoda.
\q1 
\v 10 Komui me kotin tiakedi Raap dueta kamelar amen. Kom kotin kamueit paja\it n\it*er imwintiti kan ki lim omui manaman.
\q1 
\v 11 La\it n\it* o jappa me japwilim omui, jappa o audepa. Komui me kotin pajonedier.
\q1 
\v 12 Komui me kotin wiadar pali apo\it n\it* o pali air, Tapor o Ermon kin \it n\it*iji\it n\it*ijki mar omui.
\q1 
\v 13 Lim omui me mananan o kumut en lim omui me rojon, lim omui pali maun me ileile.
\q1 
\v 14 Melel o pu\it n\it* iei pajon on mol omui; kala\it n\it*an o melel kin tio\it n\it* mo omui.
\q1 
\v 15 Meid pai aramaj kan, me aja \it n\it*iji\it n\it*ij! Ieowa, re pan weweid ni marain en jila\it n\it* omui.
\q1 
\v 16 Re kin polauleki mar omui ja\it n\it* ni manja\it n\it* lel jautik, o re kin pwai kida omui pu\it n\it*.
\q1 
\v 17 Pwe li\it n\it*an en ar kelail komui, o komui pan pokada oj at.
\q1 
\v 18 Pwe Ieowa pere patail o me Jaraui en Ijrael, i atail Nanmarki.
\q1 
\v 19 Maj o kom kotin majanier ki kajanjal kai o\it n\it* me lelapok kan: I kamanadar me Lapalap amen, I kajapwiladar pilipildar amen ja\it n\it* ren aramaj akan.
\q1 
\v 20 I diaradar ai ladu Dawid, I keiekidier i ai le jaraui.
\q1 
\v 21 Pa i pan kolekol i, o pa i pan kamanada i anjau karoj.
\q1 
\v 22 Imwintiti kan jota pan kak widi\it n\it* o\it n\it* i, o me japu\it n\it* kan jota pan kak kaloedi.
\q1 
\v 23 I pan kamela me palian i mo a, o I pan kaloke ir, mo kailo\it n\it*ki i.
\q1 
\v 24 A ai melel o kala\it n\it*an pan mi re a, o ni mar ai oj a pan pokapokada.
\q1 
\v 25 I pan ki o\it n\it* pa a, en kaunda madau, o pa a maun, en kaunda pil akan.
\q1 
\v 26 A pan likwir do\it n\it* ia: Komui Jam ai, ai Kot, o paip en maur i.
\q1 
\v 27 O I pan wia kila i nai mejeni, ileila ja\it n\it* nanmarki en jappa kan.
\q1 
\v 28 I pan kala\it n\it*an o\it n\it* i kokolata, o ai inau o\it n\it* i pan duedueta.
\q1 
\v 29 I pan ki o\it n\it* i kadaudok a kokolata, o mol a pan warai dueta la\it n\it*.
\q1 
\v 30 A ma na kan pan muei ja\it n\it* ai kapu\it n\it*, o re jota pan weweid ni ai kujoned akan,
\q1 
\v 31 Ma re pan kajaminela ai tiak kan, o jota peiki o\it n\it* ai kujoned akan,
\q1 
\v 32 I ap pan kaloke kin ir ar katiwo ki jokon pot, o pan woki ir, pweki ar japu\it n\it*.
\q1 
\v 33 A I jota pan kiwei ja\it n\it* i ai mak, o ai melel pan mimieta re a.
\q1 
\v 34 I jota pan kawela ai inau, o I jota pan kawukila, me kowei ja\it n\it* nan au ai.
\q1 
\v 35 I kaukilar ai jaraui pan me pak, me I jota pan likam o\it n\it* Dawid.
\q1 
\v 36 Kadaudok a pan joutuk, o mol a dueta katipin mo i.
\q1 
\v 37 A pan duedueta dueta jaunipo\it n\it*; o jaunkadede nan tapok kan me melel.
\q1 
\v 38 A met komui kajapokela o o\it n\it*io\it n\it*i japwilim omui me keidier.
\q1 
\v 39 Kom kotin kajela inau en omui ladu, o kom kotin kajaminela mar a.
\q1 
\v 40 Kom kotin karonk paja\it n\it* a kel akan karoj, o kawelar a im te\it n\it*ete\it n\it* kan.
\q1 
\v 41 Karoj me daulier waja o kulia ja\it n\it*er; a wialar kankaurur o\it n\it* men imp a kan.
\q1 
\v 42 Kom kotin pokada pali maun en me palian i, o kaperen dar a imwintiti kan karoj.
\q1 
\v 43 Kom pil kotiki ja\it n\it*er mana en a kodlaj ko\it n\it*, o jota kapwaiada i ni pei.
\q1 
\v 44 Kom kotin kaimwijokalar a li\it n\it*an, o kajedi o\it n\it* nan pwel mol a.
\q1 
\v 45 Kom kamotomotala ran en a manakap, o kadupalekidi i namenok.
\q1 
\v 46 Arai da, Mai\it n\it* Ieowa, me kom pan kotin karirela pein komui; arai da omui o\it n\it*io\it n\it* pan lulada dueta kijiniai?
\q1 
\v 47 Kom kotin tamanda duen motomot en maur i; de me mal kot omui kotin wiadar aramaj akan?
\q1 
\v 48 Ij ol o, me maur ap jota pan lel o\it n\it* mela? A pan kak dorela pein i ja\it n\it* mana en wajan mela?
\q1 
\v 49 Mai\it n\it*, ia omui kala\it n\it*an en maj o, me kom kotin inauki o\it n\it* Dawid ni omui melel?
\q1 
\v 50 Mai\it n\it*, kotin tamanda kan kaurur en japwilim omui ladu kan ja\it n\it* ni wei toto, me kin katoutoui mo\it n\it*io\it n\it* i.
\q1 
\v 51 Mai\it n\it* Ieowa, iaduen lalauo en omui imwintiti kan, iduen ar lalaue lip en japwilim omui me keidier.
\q1 
\v 52 Kapi\it n\it* o\it n\it* Ieowa kokolata! Amen, iei Amen!
\c 90
\q1 
\v 1 MAI\it N\it*, kom me kotin nekid pat ja\it n\it* eu kainok o\it n\it* eu.
\q1 
\v 2 Mon nana kan o jappa, o aude pan jappa a wiauiada, Kot kotin mia, ja\it n\it* maj kokodo o pil kokolata joutuk, Mai\it n\it* Kot.
\q1 
\v 3 Kom kin kotin kapurela\it n\it* pwel par aramaj akan o kotin mamajani: Puredo komail aramaj akan.
\q1 
\v 4 Pwe par kid dueta aio me jamalar mon jila\it n\it* omui o rajo\it n\it* majamajan eu ni po\it n\it*.
\q1 
\v 5 Kom kin kotin kapwil irail wei, re rajo\it n\it* mair, dueata ra, me kin mo\it n\it*edi mada\it n\it*.
\q1 
\v 6 Me kin majel pajan ni manjan, a ni joutik a pan palepaledi o monedi.
\q1 
\v 7 Omui o\it n\it*io\it n\it* me je kin jojore kidi, o omui o\it n\it*io\it n\it* melel, me je kin mekila mada\it n\it*.
\q1 
\v 8 Pwe kom kotin kajanjale on pein komui dip at akan, o dip at rir akan nan marain en jila\it n\it* omui.
\q1 
\v 9 I me at ran akan karoj kin ta\it n\it* weiki omui o\it n\it*io\it n\it*, at par akan rajo\it n\it* kajoi pot.
\q1 
\v 10 Warain at mour me jaunpar ijeijok, a ma re toto, a pan waleijok, a ma me kajampwal, a pan apwal o dodok. Pwe a kin ta\it n\it* wei mada\it n\it*, dueta kit kin pir wei.
\q1 
\v 11 A ij me kak dedeki mana en omui o\it n\it*io\it n\it*, o ij me kin majak o\it n\it*io\it n\it* wet?
\q1 
\v 12 Kom kotin padaki o\it n\it* kit, me kit pan mela, pwe jen loleko\it n\it*kila.
\q1 
\v 13 Mai\it n\it* Ieowa, kom kotin puro\it n\it* wukedoke do\it n\it* kit; arai da omui o\it n\it*io\it n\it*? Kom kotin maki o\it n\it* japwilim omui ladu kan!
\q1 
\v 14 Kom kotin kadire kin kit ala ar kala\it n\it*an ni manjan, kit ap pan kapi\it n\it* o pereperen arain at maur.
\q1 
\v 15 Kom kotin kaperen kit da murin at kalokoloker, o murin at kamekam warai.
\q1 
\v 16 Kom kotin kajale o\it n\it* japwilim omui ladu kanomui wiawia kan o omui wau o\it n\it* na jeri kan.
\q1 
\v 17 leowa at Kot, en kala\it n\it*an do\it n\it* kit o kotin kapwaiada dodok en pa at akan re at; ei kom kotin kapwaiada dodok en pa at akan!
\c 91
\q1 
\v 1 ME kin momod pan lim en me lapalap, o me pan mimieta pan mot en me manaman o.
\q1 
\v 2 Iei me kin inda\it n\it* leowa: Ai paip, o ai kel, ai Kot, me i liki.
\q1 
\v 3 Pwe a pan kotin dore uk ja\it n\it* injar en jauninjar, o ja\it n\it* ni kilitop jued.
\q1 
\v 4 A pan kotin kadupal kin uk edi lim a, o koe pan moleilei pan lim a kan; a melel rajo\it n\it* kadauk o pere eu.
\q1 
\v 5 Koe jota pan majak kalom en ni po\it n\it*, de kana\it n\it*an kajik katieu, me kin ta\it n\it* wei nin ran,
\q1 
\v 6 De kilitop, me kin wawai jili po\it n\it*, de eu jo\it n\it* en kilitop me kin kaukawela nin jauaj.
\q1 
\v 7 Kid pan mela imp om, o nen ni pali maun om, ap jota pan lel o\it n\it* uk.
\q1 
\v 8 Koe pan kila\it n\it*ki maj om kan, o koe pan kila\it n\it* duen a pan depuk o\it n\it* me doo ja\it n\it* Kot akan.
\q1 
\v 9 Pwe komui Mai\it n\it* leowa, kapore pa i. Koe piladar me lapalap o, pwen om kel.
\q1 
\v 10 Jota me jued kot pan lel o\it n\it* uk, o jota kalokolok pan lel o\it n\it* im om.
\q1 
\v 11 Pwe a kotin kakaliki o\it n\it* japwilim a tounla\it n\it* kan, en apapwali uk o jinjila uk nan al omui kan karoj.
\q1 
\v 12 Re pan wa kin uk ala lim ar akan, pwe na om ender dipikelekel nin takai eu.
\q1 
\v 13 Koe pan tiakedi laien o oter kai, laien pulepul o jerpent, me koe pan jok poa.
\q1 
\v 14 A kin peren kin ia, I ap pan jauaja i, a aja mar ai, I ap pan jinjila i.
\q1 
\v 15 A pan likwir do\it n\it* ia, I ap pan jape\it n\it* i, I pan ia\it n\it* i ni waja apwal, I pan kapitila i o kali\it n\it*a\it n\it*ada i.
\q1 
\v 16 I pan kamedi kin i maur warai, o I pan kajale o\it n\it* i ai jauaj.
\c 92
\q1 
\v 1 IET me kajampwal: Danke leowa, o kauleki pjalm akan o\it n\it* mar omui, ir me kotin lapaplap.
\q1 
\v 2 Ni manja\it n\it* omui kala\it n\it*an o ni po\it n\it* omui melel en lolok jili.
\q1 
\v 3 Ja\it n\it* kaja\it n\it* jal eijok o arp o laute.
\q1 
\v 4 Pwe kom kotin kaperen kin ia, Mai\it n\it* leowa ki ar wiawia; i pan \it n\it*iji\it n\it*ijki dodok en lim ar akan.
\q1 
\v 5 Meid laud ar wiawia kan, Mai\it n\it* leowa! O meid lol kupur omui!
\q1 
\v 6 Aramaj pweipwei men jota kak dedeki mepukat, o me rotorot amen jota kin injenoki.
\q1 
\v 7 Me doo ja\it n\it* Kot akan kin wojada dueta ra, o me katiwo kan karoj kin majal paja\it n\it*, lao re pan lokidokila kokolata.
\q1 
\v 8 A komui ta Mai\it n\it* leowa, me lapalapia, o komui pan duedueta.
\q1 
\v 9 Pwe kom kotin ma\it n\it*i duen ar imwintiti kan, Mai\it n\it* leowa, kom kotin ma\it n\it*i, ar imwintiti kan pan joredi, o me morjued akan en kamueit paja\it n\it*.
\q1 
\v 10 A ai oje pan pwaida dueta oj en man oje tapot, o i pan keikidier le kap.
\q1 
\v 11 O por en maj ai pan perenki ai imwintiti kan, o jalo\it n\it* ai pan polauleki me morjued akan, me kin palian ia.
\q1 
\v 12 Me pu\it n\it* o pan pwaida mau dueta ni pot, a pan kakairida dueta jeder en Lipanon.
\q1 
\v 13 Me patidier nan tanpaj en leowa, pan pwaida mon pera jaraui en atail Kot.
\q1 
\v 14 Menda ma re pan mala, pwe re pan pil majal paja\it n\it*, o wa, o kelail.
\q1 
\v 15 Pwe re pan kajaleda, me Kot me pu\it n\it*, i ai paip o jota japu\it n\it* mi re a.
\c 93
\q1 
\v 1 IEOWA kotin kaunda, a kotin kapwateki pein i manaman, leowa kotin kalikauwiada pein i, a kotin piraki pein i manaman; pil jappa me te\it n\it*ete\it n\it* o jota pon mokimokid.
\q1 
\v 2 Ja\it n\it* maj lel met mol omui mo te\it n\it*ete\it n\it*; komui me joutuk.
\q1 
\v 3 Mai\it n\it* leowa pil akan lalaudala, pil akan \it n\it*iri\it n\it*irjok, pil akan pil pan kokodo o \it n\it*iri\it n\it*irjok.
\q1 
\v 4 leowa kotikot waja ileile. A manaman ja\it n\it* \it n\it*il en pil kalaimun akan o iluk en madau kalaimun akan.
\q1 
\v 5 Omui majan akan meid pu\it n\it*. Tanpaj omui me li\it n\it*anaki jarawi kokolata, Mai\it n\it* leowa.
\c 94
\q1 
\v 1 MAI\it N\it* Kot, komui jaundepuk, leowa Kot jaundepuk, kom kotin janjaleda!
\q1 
\v 2 Kom kotida, komui jaunkapu\it n\it* en jappa, kom kotin depuk o\it n\it* wiawia en me aklapalap akan.
\q1 
\v 3 MAI\it N\it* Ieowa, arai da me doo ja\it n\it* Kot akan, arai da me doo ja\it n\it* Kot, akan pan poponmaju,
\q1 
\v 4 O pudupudada lokaia jued o arai da, me japu\it n\it* kan karoj en juauki ar morjued?
\q1 
\v 5 Re kin tiakedi japwilim omui aramaj akan, o re kame omui jojo.
\q1 
\v 6 Re kin kamela li odi o men wai, o patik takain wor en me japoupou kan.
\q1 
\v 7 Re inda: Ieowa jota kak kilan, o Kot en Iakop jota pan aja due.
\q1 
\v 8 Komail me pweipwei nan pu\it n\it* en aramaj akan, en dedeki! O komail lolepn akan, iad me komail pan loleko\it n\it*ala?
\q1 
\v 9 Me kotin wiada jalo\it n\it*, o a jota pan ereki? Me kotin wiadar por en maj o, a jota pan kak majani?
\q1 
\v 10 Me kin kotin Kaunda wei kan, o jota pan kaloke? Pwe I me kotin kaloleko\it n\it*i aramaj.
\q1 
\v 11 Ieowa kotin mani lamelam en aramaj akan, me re aklapalap.
\q1 
\v 12 Meid pai ol o, me kom kotin kaloke, Mai\it n\it*, Ieowa, o me kom kotin padaki o\it n\it* ja\it n\it* nan ar majan akan.
\q1 
\v 13 Pwen kano\it n\it*ama ni a apwal akan, lao jaujau en me doo ja\it n\it* Kot akan pan weweida.
\q1 
\v 14 Pwe Ieowa jota pan kotin kajela japwilim a araman akan, o a jota pan muei ja\it n\it* a jojo.
\q1 
\v 15 Pwe me pu\it n\it*, pan pu\it n\it*puneta, i me lelapok kan karoj pan weweideki.
\q1 
\v 16 Ij me pan jauaja ia on me morjued akan? O ij me pan jauaje ia o\it n\it* me dipan akan?
\q1 
\v 17 Ma Ieowa jota kotin jauaja ia, metar ekij \it n\it*en i pan kola\it n\it* wajan kapormen.
\q1 
\v 18 Ni ai indada: Na i pan krijedi, omui kala\it n\it*an, Mai\it n\it* Ieowa, pan kolekol ia.
\q1 
\v 19 Ai injenjued laud nan mo\it n\it*io\it n\it* i, a omui kotin kamait ia la kaperenda \it n\it*en i.
\q1 
\v 20 Kom jota man paroki o\it n\it* mol o, me kin kajapu\it n\it*ala japwilim omui majan.
\q1 
\v 21 Re kin onop on kamela me pun amen, o re kin kadeikada nta makelekel.
\q1 
\v 22 A Ieowa ai paip lapalap, o Kot iei paip, me i pan rukila ia.
\q1 
\v 23 A pan kotin depuk o\it n\it* ir ar me jued, o a pan kotin kame ir ala, pweki ar katiwo, Ieowa atail Kot pan kame ir ala.
\c 95
\q1 
\v 1 KOMAIL kodo, pwe kitail pan kapi\it n\it*a Ieowa o \it n\it*iji\it n\it*ij o\it n\it* paip en maur atail.
\q1 
\v 2 Kitail pan kola tuki o\it n\it* i kapi\it n\it*. Kitail en \it n\it*iji\it n\it*ijki o\it n\it* I pjalm!
\q1 
\v 3 Pwe Ieowa Kot lapalap amen, o Nanmarki lapalap amen pon a\it n\it*in kot akan karoj.
\q1 
\v 4 Pan jappa mi ni lim a, o pon komon nana me japwilim a.
\q1 
\v 5 Madau me japwilim a, pwe i me kotin wiadar, o lim a kan wiadar waja madeko\it n\it*.
\q1 
\v 6 Komail kodo, kitail pan kaudok, o dairukedi, o kelepuki mon Ieowa, me kotin wia kitail dar.
\q1 
\v 7 Pwe i atail Kot, a kitail aramaj en japwilim a wajan kama\it n\it*a o pwin en lim a. Ran wet, ma komail pan ro\it n\it* kapitie,
\q1 
\v 8 Komail der kapitakaila mo\it n\it*io\it n\it* omail, duen a wiauier Meripa o ni ran en Maja nan jap tan.
\q1 
\v 9 Ni jam omail akan jo\it n\it*ejo\it n\it* ia o kajau ia da, pwe re kila\it n\it*er ai dodok kan.
\q1 
\v 10 Par paeijok I juede kilar di wet, o I indada: Mo\it n\it*io\it n\it* en jo\it n\it* en aramaj duen met kin wukiwuk jili, o re jota men aja duen al ai kan.
\q1 
\v 11 I ap kaula ni ai makar: Irail jota pan konodi ai kamol.
\c 96
\q1 
\v 1 KAKAULEKI o\it n\it* Ieowa kaul kap pot, jap karoj en kakauli o\it n\it* Ieowa!
\q1 
\v 2 Kakaul o\it n\it* Ieowa o kapi\it n\it*a mar a; padapadak ja\it n\it* eu ran lel eu duen a maur!
\q1 
\v 3 Kajokajoi o\it n\it* men liki kan wau i, o o\it n\it* wei kan a manaman akan!
\q1 
\v 4 Pwe Ieowa meid lapalap o meid kapi\it n\it*an, o meid kalom mon kot akan karoj.
\q1 
\v 5 Pwe Kot en aramaj akan me mal a Ieowa kotin kapikadar lan akan.
\q1 
\v 6 Wau o li\it n\it*an mi mon jila\it n\it* i, manaman o li\it n\it*an kin kadirela nan tanpaj a im jaraui.
\q1 
\v 7 Komail men liki kan, ki o\it n\it* Ieowa, ki o\it n\it* Ieowa li\it n\it*an o manaman.
\q1 
\v 8 Komail ki o\it n\it* Ieowa li\it n\it*an en mar a; komail ko do\it n\it* mon japwilim a pera jaraui ia\it n\it*aki kijakij.
\q1 
\v 9 Komail kaudoki o\it n\it* Ieowa ni omail kapwat jaraui, toun jappa karoj en majak i.
\q1 
\v 10 Komail kaireki o\it n\it* men liki kan: Ieowa ta Nanmarki! Pil jappa me te\it n\it*ete\it n\it* o jota pan mokimokid. A pan kotin kaunda kainok kan ni tiak pu\it n\it*.
\q1 
\v 11 La\it n\it* en peren kida, o jappa en popol; madau en \it n\it*ir\it n\it*irjok o audepa!
\q1 
\v 12 Jap en pereperen o audepa karoj, o tuka en nan wei karoj en \it n\it*iji\it n\it*ij.
\q1 
\v 13 O\it n\it* Ieowa, ni a kotido, ni a kotido, en kadeikada jappa. A pan kotin kaunda jappa ni tiak pu\it n\it*, o kainok kan ni a melel.
\c 97
\q1 
\v 1 IEOWA ta Nanmarki, i me jappa en polaule kida o dako kan karoj en pereperen!
\q1 
\v 2 Tapok o rotorot mi imp a, pu\it n\it* o melel iei pajon en mol a.
\q1 
\v 3 Kijiniai kin tio\it n\it* mo a, o ijikeda japwilim a imwintiti kan karoj.
\q1 
\v 4 Japwilim a liol akan kin kamaraini jappa, toun jappa kin kila\it n\it* ap majapwekadar.
\q1 
\v 5 Nana kan pei paja\it n\it* duata krij mon Ieowa, Kaun en jap karoj.
\q1 
\v 6 La\it n\it* akan kaparokki a pu\it n\it*, o kainok karoj kin kila\it n\it* a li\it n\it*an
\q1 
\v 7 Me kaudoki o\it n\it* dikedik en mal kan en jarodi, o me kin juaiki ani kan; kot akan karoj dairukedi o\it n\it* mo a!
\q1 
\v 8 Jion kin ro\it n\it* mepukul tip peren kida, o peinekap en Iuda kan kin polauleki omui kapu\it n\it* kan, Mai\it n\it* Ieowa.
\q1 
\v 9 Pwe komui ta Mai\it n\it* Ieowa me lapalap nan jappa karoj, komui meid ileila ja\it n\it* Kot akan karoj.
\q1 
\v 10 Komail me kin pok o\it n\it* Ieowa en tataki me jued. A kin kotin apwali \it n\it*en en japwilim a lelapok kan. A pan kotin dore ir ala ja\it n\it* nan pa en me doo ja\it n\it* Kot akan.
\q1 
\v 11 Marain pan dakada\it n\it* me pu\it n\it* kan, o peren o\it n\it* me lelapok melel.
\q1 
\v 12 Komail me pu\it n\it* kan perenki Ieowa o kapi\it n\it*a mar a jaraui!
\c 98
\q1 
\v 1 KAKAULEKI o\it n\it* Ieowa kaul kap pot; pwe a kotin wiadar dodok kapuriamui. A kotin kaloe kidi lim a pali maun o lim a jaraui.
\q1 
\v 2 Ieowa kotin kajaledar a kamaur, o mon maj en kainok kan a koti kajanjaledar a pu\it n\it*.
\q1 
\v 3 A kotin kolekol o\it n\it* men Ijrael a kala\it n\it*an o melel; imwin jap karoj kin kila\it n\it* pai en atail Kot.
\q1 
\v 4 Jap karoj en \it n\it*iji\it n\it*ij o\it n\it* Ieowa! Popol o kauleki pjalm!
\q1 
\v 5 Kauleki o\it n\it* Ieowa pjalm ia\it n\it*aki laute, wiada laute o kaul!
\q1 
\v 6 Ia\it n\it* trompete o \it n\it*il en koronete, komail \it n\it*iji\it n\it*ij o\it n\it* Nanmarki Ieowa!
\q1 
\v 7 Madau en \it n\it*iri\it n\it*irjok o audepa, jappa o tou akan.
\q1 
\v 8 Pilap akan en lopolopeki pa arail; o nana kan en pereperenki.
\q1 
\v 9 Ieowa, ni a kotidon kadeikada jappa. A pan kotin kadeikada jappa nin tiak pu\it n\it* o kainok kan nin tiak inen.
\c 99
\q1 
\v 1 IEOWA ta kotin kakaunda, kainok kan kin rerer; a kotikot nan pu\it n\it* en Kerup akan, jappa kin mokimokid.
\q1 
\v 2 Ieowa me lapalap nan jion, o lapalap melel ja\it n\it* wei kan karoj.
\q1 
\v 3 Ren kapi\it n\it*a mar omui, me lapalap o kalom, i me jaraui.
\q1 
\v 4 O manaman en Nanmarki me kin pok o\it n\it* me pu\it n\it*. Kom kotin kate\it n\it*edier tiak pu\it n\it*. Komui me kotin wiadar me pu\it n\it* o inen nan kadaudok en Iakop.
\q1 
\v 5 Kapi\it n\it*a Ieowa atail Kot o poridier o\it n\it* ni utipa, pwe i me jaraui!
\q1 
\v 6 Mojej o Aron kijan japwilim a jamero kan o Jamuel nan pu\it n\it* en ir, me kin likwir o\it n\it* mar a, re likwir wo\it n\it*er Ieowa, i ap kotin ma\it n\it*i ir.
\q1 
\v 7 A kotin majan o\it n\it* irail ja\it n\it* nan ur en tapok; irail peiki o\it n\it* a majan o kujoned akan, me a kotiki o\it n\it* irail er.
\q1 
\v 8 Ieowa at Kot, kom kotin jape\it n\it* irail er. Mai\it n\it* Kot kom kotin maki o\it n\it* irail er, o kotin depuk o\it n\it* ir ar japu\it n\it* kan.
\q1 
\v 9 Kapi\it n\it*a Ieowa atail Kot, o poridier ni japwilim a nana jaraui, pwe Ieowa atail Kot me jaraui.
\c 100
\q1 
\v 1 \it N\it*IJI\it N\it*IJ on Ieowa jap karoj!
\q1 
\v 2 Papa\it n\it* Ieowa ki peren; koki don mon jilan i nijinij!
\q1 
\v 3 Komail en aja, me Ieowa Kot. I me kotin wia kitail dar a kaidin pein kitail pwen japwilim a aramaj o jip en japwilim a pwin.
\q1 
\v 4 Pedelo\it n\it* o\it n\it* nan japwilim a wanim laud ki danke, o kaul en kapin mon japwilim a pera jaraui. Danke i o kapi\it n\it*a mar a!
\q1 
\v 5 Pwe leowa me mau, a kalanan joutuk, o a melel pan duedueta kokolata.
\c 101
\q1 
\v 1 I pan kauleki duen kala\it n\it*an o pu\it n\it*; i pan kauleki pjalm akan o\it n\it* komui. Mai\it n\it* leowa.
\q1 
\v 2 I men inen eweita ni al pu\it n\it* iad kom pan koti don ia? i men weweid ni melel ren toun im ai.
\q1 
\v 3 I jota men wia morjued; i tataki wiawian me dipan akan, a jota pan pat o\it n\it* ia.
\q1 
\v 4 Mo\it n\it*io\it n\it* japu\it n\it* pan muei ja\it n\it* ia; i jota men aja duen me jued.
\q1 
\v 5 Me kin rir karaunemali men impa, i pan kamela; i juedeki me aklapalap ni maj ar o mo\it n\it*io\it n\it* arail.
\q1 
\v 6 Maj ai pan apapwali me melel akan nan jap o, pwe ren kaujon re i; me kin weweid ni al pu\it n\it*, pan papa ia.
\q1 
\v 7 Me kin kotaue, jota pan kaujon nan im ai, me kin likam, jota pan pwaida mon maj ai.
\q1 
\v 8 Ni manjan karoj i pan kawela me katiwo nan jap o, pwen kokojan kanim en leowa karoj, me kin wia japu\it n\it*.
\c 102
\q1 
\v 1 IEOWA, kom kotin ereki ai kapakap, o ai weriwer en lel o\it n\it* komui!
\q1 
\v 2 Kom der kotin karirala jila\it n\it* ir mo i ni ran en ai apwal; kom kotin kapaike do\it n\it* ia karo\it n\it* omui kan; ni ran o, me i likelikwir, kom kotin ma\it n\it*i ia mada\it n\it*!
\q1 
\v 3 Pwe ai ran akan kin ta\it n\it*wei dueta adiniai, o kokon ai kan ro\it n\it*alar dueta nan kijiniai.
\q1 
\v 4 Kapedi mo\it n\it*edier dueta ra, I me i monoke kila ai ma\it n\it*ama\it n\it*a.
\q1 
\v 5 Kokon o uduk ai mo\it n\it* penaer pweki ai weriwer o ja\it n\it*eja\it n\it*.
\q1 
\v 6 \it N\it*ai rajo\it n\it* pelikan nan jap tan, o rajo\it n\it* daap nan waja lijelipi\it n\it*.
\q1 
\v 7 I kin papad o rajo\it n\it* manpir kelep amen, me mondi pon oj en im o.
\q1 
\v 8 Ai imwintiti kin lalaue ia ja\it n\it* ni manja\it n\it* lel ni jautik, o me palian ia, kin kaula kin ia.
\q1 
\v 9 Pwe i kin ka\it n\it*ka\it n\it* paj dueta prot, o lim ai pil kin doloki pil en maj ai.
\q1 
\v 10 Pweki omui o\it n\it*io\it n\it* o o\it n\it*io\it n\it* melel; pwe kom kotin pok ia da, ap kaje ia di.
\q1 
\v 11 Ai ran akan ta\it n\it*wei dueta mota, o i mo\it n\it*edier dueta ra.
\q1 
\v 12 A komui Mai\it n\it* leowa pan kotikoteta kokolata, o kupur omui pan ja\it n\it* eu kainok lel eu potopoteta.
\q1 
\v 13 Kom pan kotida o kupurela Jion, pwe anjau leler, mo kom pan kotin mak o\it n\it* i, a auer leler.
\q1 
\v 14 Pwe japwilim omui ladu kan kin pok o\it n\it* takai (en Jion), o re injenjuedeki moan im akan,
\q1 
\v 15 O men liki kan pan majak mar en leowa, o Nanmarki en jap akan karoj omui li\it n\it*an.
\q1 
\v 16 Pwe leowa kotin kauadar Jion. A kotin pwarada ni a li\it n\it*an.
\q1 
\v 17 A kotin wukedoke do\it n\it* kapakap en me jamama o, o a jota kotin mamaleki a kapakap.
\q1 
\v 18 Mepukat pan kileledi o\it n\it* kainok en mur akan; o wei eu, me pan wiaui, pan kapi\it n\it*a Ieowa.
\q1 
\v 19 Pwe a kotin irero\it n\it* ja\it n\it* mol a jaraui ileile; Ieowa kotin irero\it n\it* jappa jan nanla\it n\it*.
\q1 
\v 20 Pwen ereki ja\it n\it*eja\it n\it* en me jalidi kan, pwen lapwada, me kiledi o\it n\it*er kamela.
\q1 
\v 21 Pwe mar en Ieowa en lolok jili nan Jion, o a kapi\it n\it*apa nan Ierujalem.
\q1 
\v 22 Kainok kan lao pokon pene o wei kan, pwen papa o\it n\it* Ieowa.
\q1 
\v 23 A kotiki ja\it n\it*er ai kelail pon al o, a kamotemotelar ai ran akan.
\q1 
\v 24 I potoan o\it n\it*: Ai Kot, kom der kotikiwei ja\it n\it* ia ni apali en ai ran akan. Omui par akan kin ja\it n\it* eu kainok lel eu kokolata.
\q1 
\v 25 Kom kotin kajonedier jappa maj o, o la\it n\it* pokon me dodok en lim omui.
\q1 
\v 26 Irail pan jorela, a kom pan kotikot eta. Irail pan mari\it n\it*ala rajo\it n\it* tuk en likau eu. Kom pan kotin kawuk ir ala likamata likau eu, irail ap pan wukila.
\q1 
\v 27 A kom pan deudeuta o anjaun omui rojon jota pan tukedi.
\q1 
\v 28 Nain japwilim omui ladu kan pan mimieta, o kadaudok a pan pwaida re omui.
\c 103
\q1 
\v 1 \it N\it*eni i kapi\it n\it*a Ieowa o lol i mar a jaraui!
\q1 
\v 2 \it N\it*eni i kapina Ieowa, o der monokela a kotin wiawia mau o\it n\it* uk!
\q1 
\v 3 Me kotin makeki o\it n\it* uk dip om karoj, ap kotin kamauiala om jomau kan.
\q1 
\v 4 Me kotin dore uk ala ja\it n\it* ni waja apwal, me kotin ninie kin uk mak o kala\it n\it*an.
\q1 
\v 5 Me kotin kapai uk adar ni om malar, o kotin kapulpul uk ala dueta adler.
\q1 
\v 6 En Ieowa a wiawia me pu\it n\it*, o a kotin kapu\it n\it*ala, me mi ni kalokolok japu\it n\it*.
\q1 
\v 7 A kotin kajale o\it n\it* Mojej al en a meakaroj, o o\it n\it* men Ijrail a wiawia kan.
\q1 
\v 8 Ieowa me dir en kala\it n\it*an o mak, a kin kotin kano\it n\it*ama, o a kala\it n\it*an me lapalap.
\q1 
\v 9 A jota kin kotin kaloke aramaj anjau karoj, o pil jota o\it n\it*io\it n\it* kokolata.
\q1 
\v 10 A jota kotin pwain o\it n\it* kitail duen dip atail, o jota depuk o\it n\it* kitail duen atail japu\it n\it* kan.
\q1 
\v 11 A duen ileile en la\it n\it* ja\it n\it* jappa, iduen a mak lapalap o\it n\it* ir, me kin majak i.
\q1 
\v 12 Duen maj en la\it n\it* o kapi\it n\it* lan ara doo paja\it n\it*, iduen a kotin kadooana wei ja\it n\it* kitail dip atail.
\q1 
\v 13 Duen jam amen pokepoko na jeri, iduen Kot kotin kupukupura irail, me lan i.
\q1 
\v 14 Pwe a kotin ma\it n\it*i, da me kitail wiaui kida, a kotin ma\it n\it*i, me kitail me pwel par.
\q1 
\v 15 Aramaj amen kin rajo\it n\it* ra, a kin majal paja\it n\it* dueta wan tuka nan jap o.
\q1 
\v 16 Ma kijinia\it n\it* pan leler, a joer mia, o a jolar aja deu a.
\q1 
\v 17 A kala\it n\it*an en Ieowa pan duedueta kokolata o\it n\it* ir, me lan i, o a melel o\it n\it* jeri en jeri kan,
\q1 
\v 18 O\it n\it* ir, me kin kolekol a inau, o madamadaua duen a majan kan, pwen kapwaiada.
\q1 
\v 19 Ieowa kotin kauada mol a nanlan, o a kotin kaunda meakan karoj.
\q1 
\v 20 Kapikapi\it n\it*a Ieowa, komail japwilim a tounla\it n\it* kan, komail me lapalap akan ni manaman, me kin kapwaiada a majan kan, o peiki o\it n\it* moat en a majan!
\q1 
\v 21 Kapikapi\it n\it*a Ieowa japwilim a pokon akan karoj, o japwilim a ladu kan, me kin kapwaiada kupur a!
\q1 
\v 22 Kapikapi\it n\it*a Ieowa japwilim a dipijou kan ni waja karoj, me a kotin kakaun, \it n\it*en i kapi\it n\it*a Ieowa!
\c 104
\q1 
\v 1 \it N\it*EN i kapi\it n\it*a Ieowa! Ieowa ai Kot, komui meid lapalap, komui me kapwateki li\it n\it*an o manaman.
\q1 
\v 2 Japwilim ar likau iei marain, me komui kot lole; kom kotin pak paja\it n\it* nanla\it n\it* dueta likau eu.
\q1 
\v 3 Kom kin kotin wia kida pil pali poa en ponepon, a tapok kan wiala tan war omui, me kom kin kotikot jili ki pa en a\it n\it*.
\q1 
\v 4 Kom me kotin wia kila japwilim omui tounla\it n\it* kan kijinia\it n\it* o japwilim ar ladu kan umpul en kijiniai.
\q1 
\v 5 A kotin kajonedier jappa pon a pajon, a jota pan mokid kokolata.
\q1 
\v 6 Kom kotin kadupale kidi i dueta likau eu, pil akan ileilada ja\it n\it* nana kan.
\q1 
\v 7 Re ta\it n\it* wei mon ar majan, re mada\it n\it* wei mon \it n\it*il en omui nanjapwe.
\q1 
\v 8 Nana kan kokodar, a wau kan kokodier o\it n\it* waja, me kom kotin kileledier o\it n\it* ir.
\q1 
\v 9 Kom kotiki o\it n\it* ir irair eu, me re jota pan dauli wei; re jolar pan pur o\it n\it* kadupaledi jappa.
\q1 
\v 10 Kom kin kotin wiada, parer en kujukujda nan wau kan; re kin pwilipwil wei nan pu\it n\it* en nana kan.
\q1 
\v 11 Re kotin kanim pileda man en nan jap akan o man en nan wei.
\q1 
\v 12 Manpir en pan la\it n\it* kin kaukaujon ni kail a, re kin kakaul nin tuka kan.
\q1 
\v 13 Komui me kin kotin kanim pileda nana kan ja\it n\it* japwilim omui pera poa. Kom kin kotin kadire kila wa kan jappa, me kom kotin wiadar.
\q1 
\v 14 Komui me kotin kawojada\it n\it* man akan ra, o wan tuka me mau o\it n\it* aramaj, pwen kapwareda ja\it n\it* nan pwel mana o\it n\it* aramaj akan.
\q1 
\v 15 O wain en kaperenda mo\it n\it*io\it n\it* en aramaj, o le en kali\it n\it*anada maj en aramaj, o prot en kakelada war en aramaj.
\q1 
\v 16 Japwilim en Ieowa tuka kan pan medila, jeder en Lipanon akan, me a kotin padukedier.
\q1 
\v 17 Waja manpir kin paj kin ia, o raier kaujon nan jeder.
\q1 
\v 18 Nana ileile iei deun kemjo, a paip akan deun repit en wel.
\q1 
\v 19 A kotin wiadar jaunipo\it n\it* i, pwen kilelekidi anjau kan, ketipin aja waja me a pan kirila ia.
\q1 
\v 20 Kom kin kotin wiada po\it n\it*, man en nan wel rap mokidada.
\q1 
\v 21 Laien pulepul weriwerki kan arail ma\it n\it*a, re kin idok ren Kot, me re pan kan.
\q1 
\v 22 Katipin lao dakada, re kin purela wonon nan por ar akan.
\q1 
\v 23 Aramaj ap kola\it n\it* ar dodok, wia japajap lel nin jautik.
\q1 
\v 24 Mai\it n\it* leowa, ar wiawia kan me dodok melel! Kom kotin kajone irail di ki omui erpit o jappa me direki japwilim omui dipijou kan.
\q1 
\v 25 Madau me kalaimun o dalap in pali karoj; i waja me dir en mam, me jota kak wadawad, man tikitik o kalaimun.
\q1 
\v 26 I waja me jop akan kin ta\it n\it*ata\it n\it* ia, o walroj, me komui kotin wiadar, kin madomado\it n\it* lole.
\q1 
\v 27 lr karoj kin auiaui komui, pwe komui en kotin katu\it n\it*ole kin ir kan arail ni ar anjau.
\q1 
\v 28 Kom kin kotiki o\it n\it* ir, rap nanak pena; komui kotiki paja\it n\it* lim omui, rap pan medi kila me mau kan.
\q1 
\v 29 Ni omui pan karirila jila\it n\it* omui, rap pan majapwekada, kom kin kotiki ja\it n\it* ir a\it n\it*ia\it n\it* arail, rap pan mela o purela\it n\it* ar pwel par.
\q1 
\v 30 Kom kin kotin kadarala a\it n\it* omui, ran pan wiauiada, o komui kin kawilikapada maj en jap o.
\q1 
\v 31 Li\it n\it*an en leowa pan duedueta. leowa pan kotin peren kida japwilim a wiawia kan.
\q1 
\v 32 A lau kotin irero\it n\it* toun jappa, jappa ap rerer; a lao kotin jair nan kan, rap adida.
\q1 
\v 33 Arain ai maur i pan kakauli o\it n\it* Ieowa, o arain ai mi jappa er, i pan kauleki pjalm kan o\it n\it* ai Kot.
\q1 
\v 34 I men, ai kajokajoi en kaperenda kupur a; i pan polauleki leowa.
\q1 
\v 35 Me dipan akan en niki ja\it n\it* jappa, o me doo ja\it n\it* Kot akan en jola mia. \it N\it*en i kali\it n\it*aila leowa! Aleluia!
\c 105
\q1 
\v 1 KAPI\it N\it*A leowa, likwir wo\it n\it* mar a, kapakaparoki o\it n\it* kainok kan duen a wiawia kan.
\q1 
\v 2 Kauli o\it n\it* i, kauliki o\it n\it* i pjalm akan, kajokajoi duen a manaman akan karoj;
\q1 
\v 3 Peren kida mar a jaraui; mo\it n\it*io\it n\it* en me rapaki leowa, en popol.
\q1 
\v 4 Komail ino\it n\it* io\it n\it* leowa o a manaman; rapaki jila\it n\it* i anjau karoj.
\q1 
\v 5 Tamatamanda japwilim a dodok kapuriamui, me a kotin wiadar, o a manaman akan o majan en kadeik ja\it n\it* nan jila\it n\it* i.
\q1 
\v 6 Kadaudok en Apraam koe japwilim a ladu, o nain Ijrael komail, me a kotin piladar!
\q1 
\v 7 I leowa atail Kot; a kotin kaunda nan jap karoj.
\q1 
\v 8 A kin kotin tamanda japwilim a inau kokolata, majan o me a kotin inauki o\it n\it*er di kid.
\q1 
\v 9 Inau me a kotin wiada\it n\it* Apraam, o a kaula, me a kotin kauki o\it n\it* Ijaak.
\q1 
\v 10 O a kotiki o\it n\it* Iakop kujoned eu, o o\it n\it* Ijrael inau joutuk,
\q1 
\v 11 Ni a kotin majanier: I pan ki o\it n\it* uk Kanaan, iei me I kileledier, en pwaij omail jojo;
\q1 
\v 12 I anjau, me irail pwin tikitik eu, o men kairu nan jap o.
\q1 
\v 13 Ni ar kokola ja\it n\it* eu kainok lel eu, o ja\it n\it* eu wei lel eu.
\q1 
\v 14 A jota kotin mueid o\it n\it* amen aramaj, en katoutou irail, o a kotin kaloke nanmarki kai pweki irail.
\q1 
\v 15 Komail der jair nai me keidier akan, o der wiai o\it n\it* ai jaukop akan me jued kot!
\q1 
\v 16 A lao kotiki o\it n\it* jap o anjaun lek; o kotin kawelar wajan kaporopor en ma\it n\it*a,
\q1 
\v 17 A kotin poronelar ol amen mo ’rail; Iojep, me netilar, pwen wiala ladu men.
\q1 
\v 18 Na a kan kalokolokki jal mata, o pali war a wonon nan mata,
\q1 
\v 19 Lao anjau me japwilim a majan pwarado; majan en Ieowa kamakelekeleda i.
\q1 
\v 20 Nanmarki ap ilakila, pwen lapwada i, iei kaun en wei kan, me kotin kamaioda i.
\q1 
\v 21 A kajapwilada\it n\it* i pein im a, o kaun en a dipijou karoj.
\q1 
\v 22 Pwen jaliedi a jaupeidi kan duen me a mauki, o padaki o\it n\it* japwilim a lapalap akan loleko\it n\it*.
\q1 
\v 23 O Ijrael lipala\it n\it* Akipten, o Iakop wiala men kairu nan jap en Am.
\q1 
\v 24 I anjau Kot kotin kapara irail ada mada\it n\it*, o kotin kakelail ir ada ja\it n\it* a imwintiti kan.
\q1 
\v 25 A kotin kawukila kupur a, pwen kailo\it n\it*ki japwilim a aramaj akan, o widiwidi\it n\it* o\it n\it* japwilim a ladu kan.
\q1 
\v 26 A ap kotin poronela Mojej, japwilim a ladu, o Aron, me a kotin piladar.
\q1 
\v 27 Ira wiadar manaman akai nan pu\it n\it* ar, o dodok kapuriamui nan jap en Am.
\q1 
\v 28 A kotin kadarado rotorot, ap pon pena, o re jota injenoki a majan kan.
\q1 
\v 29 A kotin kawuk o\it n\it* nta ar pil akan, o kamelar ar man akan.
\q1 
\v 30 Jap arail me direki proj lao lel o\it n\it* nan pera en ar nanmarki kan.
\q1 
\v 31 A kotin majanier, Io\it n\it* jued ap rokilar, o amuje nan jap karoj.
\q1 
\v 32 A kotiki o\it n\it* ir akel wiliandi katau, umpul en kijiniai nan jap ar.
\q1 
\v 33 A kotin kawelar ar tuka en wain akan o tuka en paiken, o kotin katip paja\it n\it* tuka en jap ar akan.
\q1 
\v 34 A kotin majanier, manjiok o Io\it n\it* ap pwarada, rap pwaradar o re jota kak wadawad.
\q1 
\v 35 Rap ka\it n\it*ala tuka kan karoj nan jap o, o ka\it n\it*ala wan tuka kan nan matuel o.
\q1 
\v 36 O a kotin kamelar mejeni karoj nan jap arail, mejeni karoj en ar kelail.
\q1 
\v 37 O a kotin kalua irail ja\it n\it* nan jap o ia\it n\it*aki jilper o kohl, o jota me luet nan pu\it n\it* en ar kainok kan.
\q1 
\v 38 Akipten peren kida ar jamalar, pwe re majapwekadar.
\q1 
\v 39 A kotin wiada tapok en kadupal irail edi, o kijiniai en jereda irail ni po\it n\it*.
\q1 
\v 40 Irail poekipoeki, i ap kotin kadarado manpir akan; o a kotin kama\it n\it*a kin ir prot en nanla\it n\it*.
\q1 
\v 41 A kotin pala\it n\it* paja\it n\it* paip o, pil akan ap kujkuj wei ja\it n\it*, re pwilipwile wei nan jap tan dueta pilap pot.
\q1 
\v 42 Pwe a kotin tamanda majan jaraui, o japwilim a ladu Apraam.
\q1 
\v 43 A kotin kaluaki peren japwilim a aramaj akan ja\it n\it* nan jap o, o \it n\it*iji\it n\it*ij japwilim a pilipildar akan!
\q1 
\v 44 A ap kotiki o\it n\it* ir jap en men liki kan, o re aleer dipijou en kainok kan.
\q1 
\v 45 Pwe ren peiki o\it n\it* japwilim a majan kan o kolekol a kujoned akan. Aleluia!
\c 106
\q1 
\v 1 KAPI\it N\it*A Ieowa, pwe i me mau, pwe a kala\it n\it*an pan potopot
\q1 
\v 2 Ij me kak inda duen dodok manaman en Ieowa, o ij me kak kapina japwilim a dodok kajapwal?
\q1 
\v 3 Meid pai, me kolekol me pu\it n\it*, o me kin wiada me pu\it n\it* anjau karoj!
\q1 
\v 4 Mai\it n\it* Ieowa, kom kotin taman ia da duen ar kala\it n\it*an, me kom kotin inauki o\it n\it* japwilim omui aramaj akan, kajanjanle do\it n\it* kit omui jauaj!
\q1 
\v 5 Pwe i en kila\it n\it* pai en japwilim omui pilipildar akan o peren kidar peren en japwilim omui aramaj akan, o kapi\it n\it*a ia\it n\it* omui jojo.
\q1 
\v 6 Kit ia\it n\it* jam at oko wiadar dip, je wiadar japu\it n\it*, je kawelar kujoned o kapwaiada tiak en me pu\it n\it* kan.
\q1 
\v 7 Jam at akan nan Akipten jota injenoki japwilim omui manaman akan, pwe re jota tamanda omui kala\it n\it*an lapalap, o re katiwo o\it n\it* me lapalap o ni kailan madau ni jed waitata.
\q1 
\v 8 Ari jo, a kotin dore ir ala pweki mar a, pwen kajaleda a manaman.
\q1 
\v 9 A kotin majani o\it n\it* jed waitata, ap \it n\it*ala\it n\it*aledier; o a kotin kalua irail waja lol dueta jap tan eu.
\q1 
\v 10 Iduen a kotin dore ir ala ja\it n\it* nan pa en me kailo\it n\it* kin ir, o a kotin jauja ir jan nan pa en imwintiti.
\q1 
\v 11 Pil kadupaledi arail imwintiti kan, jota amen pitila.
\q1 
\v 12 Irail ap kamelele a majan akan, o kaul en kapi\it n\it* o\it n\it* i.
\q1 
\v 13 A re pil mada\it n\it* monokelar a wiawia kan, o re jota auiaui a majan.
\q1 
\v 14 Irail dire kila ino\it n\it* jued, ap kajo\it n\it*ejo\it n\it*. Kot nan jap tan,
\q1 
\v 15 Ap kotin mueid o\it n\it* injen arail, o kotiki o\it n\it* ir, lol ar lao juedala.
\q1 
\v 16 Re ap ka\it n\it*udi o\it n\it* Mojej nan deu ’rail, o\it n\it* Aron me jaraui en Ieowa men.
\q1 
\v 17 Jap ap jar paja\it n\it* katalala Datan, o pur pena\it n\it* pon pwin en Apiram.
\q1 
\v 18 O kijiniai eu kamajikada nan pu\it n\it* en arail pwin, umpul en kijiniai eu karo\it n\it*alar me doo ja\it n\it* Kot akan.
\q1 
\v 19 Re wiadar kau pul amen ni Orep, o dairukedi ja\it n\it* mon kilel kold eu.
\q1 
\v 20 O re kawilianeki arail li\it n\it*an kilel en kau ol amen, me kin ka\it n\it*ka\it n\it* ra.
\q1 
\v 21 Re monokelar Kot, arail jaunkamaur, me kotin wiadar dodok lapalap nan Akipten.
\q1 
\v 22 O manaman akan nan jap en Am, o men kamajak ni jed waitata.
\q1 
\v 23 I ap kotin kupukupura, me a pan kame ir ala, ma Mojej japwilim a pilipildar amen jota pan pukoki dip arail, pwen kotiki wei ja\it n\it* japwilim a o\it n\it*io\it n\it*, pwe ren der mela.
\q1 
\v 24 A re mamaleki jap kajelel, o jota kamelele a majan kan.
\q1 
\v 25 O re lipaned nan im arail, o jota peiki on majan en Ieowa.
\q1 
\v 26 I ap kotin kaula o\it n\it* ir, me a pan kame ir ala nan jap tan.
\q1 
\v 27 O kadaudok ar en wowokidi nan pu\it n\it* en men liki kan, o kamueit ir pajan nan jap akan.
\q1 
\v 28 O re wuki o\it n\it* PalPeor, o ka\it n\it*ala kijan mairo\it n\it* en ani mal.
\q1 
\v 29 O re kupur jued kin i ar wiawia kan, kalokolok eu ap lel o\it n\it* ir.
\q1 
\v 30 Pineaj ap kotida, kadeik irail ada, kalokolok ap imwijokalar.
\q1 
\v 31 Mepukat me a wadekida ni pu\it n\it*, ja\it n\it* eu kainok lel eu kokolata.
\q1 
\v 32 O re kupur juede kin i ni pil en Meripa, i me irail kareki o\it n\it* Mojej apwal laud.
\q1 
\v 33 Pwe re kapataui \it n\it*en i, ap kotin japu\it n\it*ala ekij ni a majan kan.
\q1 
\v 34 Re jota pil kanikiala wei kan, me Ieowa kotin majani o\it n\it* ir.
\q1 
\v 35 O re dolola men liki kan, o padakki arail tiak kan.
\q1 
\v 36 O re kaudoki on arail dikedik en ani kan, rap wialar injar arail.
\q1 
\v 37 O re mairo\it n\it*ki o\it n\it* tewil jued akan nairail putak o jeripein kan.
\q1 
\v 38 O re kamelar mal aramaj, iei udan nair putak o jeripein oko, me re mairo\it n\it*ki o\it n\it* ani mal en Kanaan, a jap o kajamin kila nta.
\q1 
\v 39 O re kajamine kila pein irail ar wia kan, o nenekki ar dodok jued.
\q1 
\v 40 Ieowa ap kotin o\it n\it*io\it n\it*i o\it n\it* japwilim a aramaj akan o kotin juedeki japwilim a jojo.
\q1 
\v 41 A kotin mueid o\it n\it* ir nan pa en men liki kan, o me kailo\it n\it* kin ir, wialar ar kaun.
\q1 
\v 42 O ar imwintiti katoutoui ir, o re namenokalar pan pa ’rail
\q1 
\v 43 A kotin dore ir ala pan pak toto, a re duedueta ni ar ino\it n\it* jued o madamadaua, o re malaulau kilar ar japu\it n\it*.
\q1 
\v 44 A a kotin irero\it n\it* ar kan ka\it n\it*era\it n\it*er, ni a kotin ereki ai weriwer.
\q1 
\v 45 O a kotin tamanda japwilim a inau, o a kotin kalukila duen a kala\it n\it*an lapalap.
\q1 
\v 46 O a kotin maki o\it n\it* ir mon karoj, me jali irail weier.
\q1 
\v 47 Ieowa at Kot, kom kotin dore kit ala, ja\it n\it* ren men liki kan, pwe kit en danke mar omul jaraui o japwilim ar dodok mau kan.
\q1 
\v 48 Kapi\it n\it* o\it n\it* Ieowa, Kot en Ijrael, ja\it n\it* maj kokodo o pil kokolata! 0 aramaj karoj en inda: Amen, Aleluia!
\c 107
\q1 
\v 1 KAPIi\it N\it*A Ieowa, pwe i me mau, pwe a kala\it n\it*an pan potopot eta.
\q1 
\v 2 Iduen me dorelar ren Ieowa kan pan indinda, irail me a kotin dorelar ja\it n\it* nan pa en arail imwintiti;
\q1 
\v 3 Me a kotin kapokon pena ja\it n\it* jap en maj en la\it n\it*, o kapin la\it n\it*, o pali apa\it n\it*, o ja\it n\it* madau.
\q1 
\v 4 Irail janjalo\it n\it* jili nan jap tan, pol al apwal, re jota diarada deurail.
\q1 
\v 5 Re men manadar o men nim piladar, o kaped arail luetalar.
\q1 
\v 6 Rap weriwer wo\it n\it* Ieowa ni ar kanka\it n\it*era\it n\it*er, o a kotin dore ir ja\it n\it* nan ar apwal akan.
\q1 
\v 7 O a kotin kalua ir o\it n\it* al pu\it n\it*, pwe ren lele o\it n\it* wajan kaukaujon.
\q1 
\v 8 Ren kapi\it n\it*a Ieowa, pweki a kala\it n\it*an o pweki a dodok manaman o\it n\it* aramaj akan.
\q1 
\v 9 Pwe a kotin kamede kilar kaped en me men nim piladar, o kadir kila me mau kan kaped en me men ma\it n\it*adar.
\q1 
\v 10 Me mi ni waja rotorot o mot en mela, me jalikidi luet o mata.
\q1 
\v 11 Pweki ar katiwo on majan en Kot, o ar mamaleki kujoned en ma lapalap o.
\q1 
\v 12 I ap kaloke kin ir apwal akan, re wonon, a jota jauaj parail.
\q1 
\v 13 Rap weriwer wo\it n\it* Ieowa ni ar apwal akan, i ap kotin dore ir ala jan katoutou parail.
\q1 
\v 14 A kotin kalua ir ja\it n\it* nan rotorot, o mot en mela, o kotin kamueit paja\it n\it* ar jal akan.
\q1 
\v 15 Ren kapi\it n\it*a Ieowa, pweki a kala\it n\it*an o pweki a dodok manaman o\it n\it* aramaj akan.
\q1 
\v 16 Pwe a kotin kawela wanim mata, o a kotin juk paja\it n\it* kate\it n\it* mata pan wanim akan.
\q1 
\v 17 Me pweipwei kan pan kalokolokki al en ar katiwo o ar japu\it n\it* kan.
\q1 
\v 18 Kaped arail kin juedeki jo\it n\it* en ma\it n\it*a karoj, o re lel on kalian mela.
\q1 
\v 19 Rap weriwer wo\it n\it* Ieowa ni ar apwal akan, i ap kotin dore ir ala jan katoutou parail.
\q1 
\v 20 A kotin kadarado japwilim a majan, o kotin kamaur irail da, o kotin jauaja ir ja\it n\it* nan ar por akan.
\q1 
\v 21 Ren kapi\it n\it*a leowa pweki a kala\it n\it*an o pweki a dodok mau o\it n\it* aramaj akan.
\q1 
\v 22 O ren mairo\it n\it*ki mairo\it n\it* en kapi\it n\it* o kajokajoia duen a wiawia kan ki peren!
\q1 
\v 23 Me kin mi pon madau o dake jop akan, o me kin netinet pon pil kalaimun akan,
\q1 
\v 24 Irail pukat kin kilekila\it n\it* wiawian leowa kan, o a manaman akan nan madau.
\q1 
\v 25 A kotin majan eta, melimel ap wiaui, me kin kalaudela iluk kan.
\q1 
\v 26 Re kin koda ileile o kodi loledi, likamata kaped arail pei pajan ni ar majak.
\q1 
\v 27 Re rarauk jili dueta me jakaular, o ar loleko\it n\it* karoj pan joredi.
\q1 
\v 28 Rap weriwer wo\it n\it* leowa ni ar apwal akan, i ap kotin dore ir ala ja\it n\it* katoutou parail.
\q1 
\v 29 A kotin kawuki o\it n\it* mole melimel, iluk kan ap moledi.
\q1 
\v 30 Rap peren kida, ma re pan moledi, o a kotin kalua ir nan kapitau me re inon ion.
\q1 
\v 31 Ren kapi\it n\it*a leowa, pweki a kalanan, o pweki a dodok manaman o\it n\it* aramaj akan.
\q1 
\v 32 O ren kapi\it n\it*a i nan pokon en aramaj, o ren kapi\it n\it*a i nan momod en jaumaj akan.
\q1 
\v 33 A kotin kawuki o\it n\it* jap tan pilap akan, o utun pil akan o\it n\it* jap madeko\it n\it*.
\q1 
\v 34 O jap kajelel eu wiala jap tan en jol, pweki dip en me kaukaujon waja o.
\q1 
\v 35 A kotin kawuki o\it n\it* len pil jap tan, o jap jued o\it n\it* utun pil.
\q1 
\v 36 O a kotin mueid o\it n\it* me men ma\it n\it*adar akan, en kaukaujon waja o, o re wiadar deu arail.
\q1 
\v 37 O re kin wia japajap o padukedi mat en wain, me kin wa ni a anjau.
\q1 
\v 38 O a kotin kamau irail la, rap kin totolar, o a kotin ka\it n\it*ederela arail man akan.
\q1 
\v 39 O irail malaulaular o namenok kilar me jued, o japai o luet akan.
\q1 
\v 40 A kotin wudokidi om jaupeidi kan namenok, o mueid o\it n\it* ir, ren janjalo\it n\it* jili nan jap tan, waja me jota al mia ia.
\q1 
\v 41 O a kotin pokada me jamama o ja\it n\it* ni a luet, o katotolar kadaudok a dueta pwin akai.
\q1 
\v 42 Me melel akan pan kila\it n\it*, ap peren kida, o japu\it n\it* kan karoj pan kaku pena au arail.
\q1 
\v 43 Me loleko\it n\it* kan pan kajampwale ki mepukat, o re pan dedeki kala\it n\it*an en Ieowa.
\c 108
\q1 
\v 1 MAI\it N\it* Kot, mo\it n\it*io\it n\it* i kin moleilei; i men kakaul o kakauleki pjalm akan, o pil \it n\it*en i.
\q1 
\v 2 Koma arp o laute pirida! I pan paurida nin joran.
\q1 
\v 3 I pan kapi\it n\it*a komui nan pu\it n\it* en kainok kan, Mai\it n\it* Ieowa, o i pan kaule kin komui nan pu\it n\it* en aramaj akan.
\q1 
\v 4 Pwe omui kala\it n\it*an me laud, ileila ja\it n\it* nanla\it n\it*, o omui melel lelada wo\it n\it* tapok kan.
\q1 
\v 5 Re kotida pona\it n\it*in nanla\it n\it*, Mai\it n\it* Kot, o omui li\it n\it*an en kipadi jappa.
\q1 
\v 6 Pwe kompoke pamui kan en jaladokala; kom kotin jauajaki pali maun ar, o kotin ereki kit.
\q1 
\v 7 Kot kotin majanier nan japwilim a mol jaraui, i me i peren kida; i pan nek paja\it n\it* Jikem o jojo\it n\it* jap Jukot.
\q1 
\v 8 Kilead o Manaje iei jap ai, \it n\it*ai kin kaunda Epraim; a iuda iei ai jokon.
\q1 
\v 9 Moap iei ai dal en dud; i kin tiakedi Edom; i pan \it n\it*iji\it n\it*ijiki men Pilijta.
\q1 
\v 10 Ij me pan kalua ia nan kanim te\it n\it*ete\it n\it* eu? Ij me pan ia\it n\it* ia Iel Edom?
\q1 
\v 11 Kaidin komui ai Kot? Komui me kaje kit ala, o jota ia\it n\it* at karij akan. Mai\it n\it* Kot.
\q1 
\v 12 Kom kotin ieia\it n\it* kit ni ul apwal akan, pwre en aramaj jauaja jota katepa.
\q1 
\v 13 la\it n\it*aki at Kot kit pan kapwaiada dodok manaman akan. A pan kotin tiakedi at imwintiti kan.
\c 109
\q1 
\v 1 MAI\it N\it* Kot, me i kin kapikapi\it n\it*a, kom der kotin japaimokid!
\q1 
\v 2 Pwe au en me doo ja\it n\it* Kot, o me kin kotaue jara do\it n\it* ia, re lokelokaia o\it n\it* ia ki lo likam.
\q1 
\v 3 Re lokaia jued o\it n\it* ia waja karoj, o pei o\it n\it* ia ni jo karepa
\q1 
\v 4 Ni ai pok o\it n\it* ir, re kin imwintiti o\it n\it* ia; a \it n\it*ai kin poten kapakap.
\q1 
\v 5 Irail depukki ai me mau me jued, o re kin tata kin ia ni ai pok o\it n\it* ir.
\q1 
\v 6 Kotin kajapwilada\it n\it* i me doo ja\it n\it* Kot amen, pwen a jaunkapu\it n\it* o me palian I, en mi ni pali maun a.
\q1 
\v 7 Ma a pan pakajau, a pan pakadeikada, pil a kapakap en kadipala i.
\q1 
\v 8 A ran akan en malaulaula, o a koa en ko o\it n\it* amen.
\q1 
\v 9 Na jeri kan en japoupou, o a paud en li odi amen.
\q1 
\v 10 Na jeri kan en janjarwaru jili o wia poekipoek, o re rapaki kan ar ma\it n\it*a, doo ja\it n\it* nan moan im arail.
\q1 
\v 11 Me norok moni en pitia ja\it n\it* i a meakoaroj, o men wai en kulia ja\it n\it* i a dipijou kan.
\q1 
\v 12 O jota me pan kadek o\it n\it* i, o jota me pan jauja na japoupou kan.
\q1 
\v 13 Kadaudok a en kokoka ja\it n\it*; o mar arail en niki ja\it n\it* nin di kaieu.
\q1 
\v 14 Japu\it n\it* en jam a ko en janjal mon Ieowa, o dip en in a ender lapwada.
\q1 
\v 15 Ieowa en kotin majamajan irail ajau karoj, o kataman parail en niki ja\it n\it* in jappa.
\q1 
\v 16 Pweki a jota man kadek, pwe a pakipaki me luet o jamama, o me injenjued, pwen kamela i.
\q1 
\v 17 O a ino\it n\it* io\it n\it* en riala; ari en lel o\it n\it*! O a jota injenoki kapai, ari, en doo ja\it n\it* i!
\q1 
\v 18 A kapwateki me jued duata a likau, ari me jued en kolon lole dueta pil o nan kokon akan dueta le.
\q1 
\v 19 Me jued en rajo\it n\it* a likau pup, me a kin likauwiada, o rajo\it n\it* men pirapir me a kin pirapireki.
\q1 
\v 20 Iduen Ieowa pan kotin pwain on me palian ia, o me kin lokaia jued duen \it n\it*ai.
\v 21 A komui, Mai\it n\it* Ieowa ai Kot kotin wiawia ia, pweki mar omui; pwe omui kala\it n\it*an kajampwal, dore ia la!
\q1 
\v 22 Pwe \it n\it*ai me luet o jamama, o nan mo\it n\it*io\it n\it* i olar.
\q1 
\v 23 I kin tanwei dueta mota, o i pan kamajak wei dueta manjiek amen.
\q1 
\v 24 Na i kat luete kilar kaijejol, o uduk ai tikitikilar;
\q1 
\v 25 O i wialar men lalaue re ’rail; ni ar kila\it n\it* ia, re kin due duailok!
\q1 
\v 26 Mai\it n\it* Ieowa, ai Kot, kom kotin dore ia la duen omui kala\it n\it*an!
\q1 
\v 27 Pwe ren aja, mepukat tapi ja\it n\it* ni lim omui, me komui Ieowa kotin wiadar mepukat.
\q1 
\v 28 Menda, ma re lalaue, kom kotin kapai ia da. Ma re palian ia, ren namenokala, pwe japwilim omui ladu en pereperen.
\q1 
\v 29 Re kotin wiai o\it n\it* ai imwintiti, ren likau kida namenok, o ren purio\it n\it* nan me jued dueta likau pup.
\q1 
\v 30 I pan danke Ieowa melel ni au ai, o i pan kapi\it n\it*a i nan pu\it n\it* en me toto.
\q1 
\v 31 Pwe a kotikot ni pali maun en me jamama, pwen dorela i ja\it n\it* ir, me kadeikada i, en kamela.
\c 110
\q1 
\v 1 IEOWA kotin majani o\it n\it* ai Kaun, mondi o\it n\it* ni pali maun i, lao I pan wia kida om imwintiti utipan na om.
\q1 
\v 2 Ieowa pan kotin kadarado jokon en wei omui ja\it n\it* nan Jion; kakaun nan pu\it n\it* en omui imwintiti kan.
\q1 
\v 3 Murin omui poedier, japwilim omui kan pan pereperen, wia mairo\it n\it* o\it n\it* komui ni ar kapwat jaraui. Japwilim omui jeri kan pan ipwidi o\it n\it* komui dueta poik en ni manja\it n\it*.
\q1 
\v 4 Ieowa kotin kaula, o a jota pan kalula: Komui jamero joutuk amen, duen al en Melkijedek.
\q1 
\v 5 Kaun o kotikot ni pali maun om a pan kamela nanmarki kan ni ran en a o\it n\it*io\it n\it*.
\q1 
\v 6 A pan kotin kaunda nan pu\it n\it* en men liki kan, a pan kadir kila kalep akan waja karoj, a kotin pala\it n\it* paja\it n\it* tapwi en wei lapalap.
\q1 
\v 7 A pan nima ja\it n\it* pil ni kailan al, i me a pan jara kida.
\c 111
\q1 
\v 1 I PAN kapi\it n\it*a Ieowa ja\it n\it* nan mo\it n\it*io\it n\it* i nan pu\it n\it* en me lelapok kan o nan momodijou.
\q1 
\v 2 Meid laud wiawian Ieowa kan, ir me injenoki, pan dedeki due.
\q1 
\v 3 A wiawia kan me pun o li\it n\it*an, o a pu\it n\it* pan duedueta kokolata.
\q1 
\v 4 A manaman akan men kataman eu. Ieowa me dir en mak o kala\it n\it*an.
\q1 
\v 5 A kotin kama\it n\it*a ir, me majak i, a kin kolekol japwilim a inau kokolata.
\q1 
\v 6 A kotin kajanjale o\it n\it* japwilim a aramaj akan mana en a wiawia kan, pwen kotiki o\it n\it* ir jojo en men liki kan.
\q1 
\v 7 Dodok en lim a kan me melel o pu\it n\it*; japwilim a majan kan karoj me melel.
\q1 
\v 8 Re pan duedueta kokolata, o re wiauier ni melel o pu\it n\it*.
\q1 
\v 9 A kotiki o\it n\it* japwilim a kan jaunkamaur, o a kupureda, me a inau pan duedueta kokolata; mar a me jaraui o kalom.
\q1 
\v 10 Majak Ieowa iei tapin loleko\it n\it*; irail meid pai, me kin wia due met, pwe a pai potopot eta.
\c 112
\q1 
\v 1 MEID pai ol o me majak Ieowa, me kin peren kola a kujoned akan.
\q1 
\v 2 Kadaudok a pan kelail nan jap o; kainok en me melel akan pan pwaida.
\q1 
\v 3 Im a pan dir en dipijou melel o a pu\it n\it* pan potopot eta.
\q1 
\v 4 Marain kin daka da\it n\it* me melel akan nan waja rotorot, a kin dir en mak o kala\it n\it*an o pu\it n\it*.
\q1 
\v 5 Meid pai ol o me kala\it n\it*an, o kin kijakija wei; a pan pwaida ni anjaun kadeik.
\q1 
\v 6 Pwe a jota pan luetala kokolata; me pu\it n\it* amen iei men kataman joutuk eu.
\q1 
\v 7 A jota pan majak ro\it n\it* jued mo\it n\it*io\it n\it* i me kelail ni a kaporoporeki Ieowa.
\q1 
\v 8 Mo\it n\it*io\it n\it* i me kelail, a jota km majak, lao a pan peren kida a imwintiti kan.
\q1 
\v 9 A kin kamoredi o kijakij o\it n\it* me jamama kan; a pu\it n\it* pan potopot eta; oj a pan kokoda o indand mau.
\q1 
\v 10 Me doo ja\it n\it* Kot pan kila\it n\it* ap makara kida; a pan teterokki \it n\it*i akan ap joredi; ino\it n\it* en me doo ja\it n\it* Kot akan pan nikila.
\c 113
\q1 
\v 1 KOMAIL ladun Ieowa kapi\it n\it*a mar en Ieowa!
\q1 
\v 2 Mar en Ieowa en pakapi\it n\it*ala ja\it n\it* met o kokolata!
\q1 
\v 3 Mar en Ieowa en pakapi\it n\it*ala ja\it n\it* wajan katipin a dakada ia lel wo\it n\it* waja me a kin kirila ia!
\q1 
\v 4 Ieowa me ileila ja\it n\it* men liki kan karoj, a li\it n\it*an mi pona\it n\it*in nanla\it n\it*.
\q1 
\v 5 Ij me rajon Ieowa atail Kot, me kotikot pon mol a ileile melel?
\q1 
\v 6 Me kotin irero\it n\it* me tikitik me tikitik kan nanla\it n\it* o nin jappa?
\q1 
\v 7 Me kotin kajapwilada me tikikit o jan nan pwel par, o ja\it n\it* nanpwel me jamma o.
\q1 
\v 8 Pwen komondi i ren me lapalap en japwilim a aramaj akan.
\q1 
\v 9 Me kotin jauja li dapwan men, pwen wiala en ol oko ar nono pere amen. Aleluia!
\c 114
\q1 
\v 1 Ni anjau men Ijrael lipa ja\it n\it* Akipten, kadaudok en Iakop jan nan wai.
\q1 
\v 2 I anjau men Iuda wiala japwilim a jaraui kan, o men Ijrael japwilim a wei.
\q1 
\v 3 Madau kila\it n\it*er, ap ta\it n\it*wei, o Iordan pal paja\it n\it*er.
\q1 
\v 4 Nana kan lujiluj dueta jip ol, o dol akan dueta jippul akan.
\q1 
\v 5 Madau, da me koe ta\it n\it*weier ki? Koe Iordan, da me koe palki paja\it n\it*er?
\q1 
\v 6 Komail nan kan, da me komail lujilujki dueta jip ol, o komail dol akan dueta jippul akan?
\q1 
\v 7 Jappa, koe en rere mon Ieowa, mon Kot en Iakop.
\q1 
\v 8 Me kotin kawuki o\it n\it* len pil paip o, o kantakai o\it n\it* utun pil.
\c 115
\q1 
\v 1 KAIDIN kit Ieowa, kaidin kit, pwe mar omui, kom kotiki o\it n\it* waui, pweki omui kala\it n\it*an o melel!
\q1 
\v 2 Menda men liki kan en inda: Ia arail Kot?
\q1 
\v 3 Atail Kot kotikot nanla\it n\it*, a kak kotin wia karoj, me a kupura.
\q1 
\v 4 Arail dikedik en ani kan, me wia kidar jilper de kold, iei dodok en pa en aramaj.
\q1 
\v 5 Au arail mia, ap jaja lokaia, por en maj arail mia, ap jota kak kila\it n\it* waja.
\q1 
\v 6 Jalo\it n\it* arail mia, ap jota ro\it n\it* waja; tum arail mia, ap jota ned waja.
\q1 
\v 7 Pa arail mia, ap jota kak koledi meakot; na arail mia, ap jota kak alu; re jota kak lokaiaki kapin wor arail.
\q1 
\v 8 Me kin wiada pukat, me duet a irail, o pil karoj, me kin liki irail.
\q1 
\v 9 A koe Ijrael, liki Ieowa; i jauaj o pere parail.
\q1 
\v 10 Komail, kadaudok en Aron, liki Ieowa, i jauaj o pere parail.
\q1 
\v 11 Komail, me kin majak Ieowa, liki Ieowa, i jauaj o pere parail.
\q1 
\v 12 Ieowa kotin kupura kitail er, o a pan kotin kapai kitail la; a pan kotin kapaida kadaudok en Ijrael, kapaida kadaudok en Aron;
\q1 
\v 13 A pan kotin kapaida, me majak Ieowa, me tikitik o me laud akan.
\q1 
\v 14 Ieowa en kotin kapai komail da kokolata, pein komail o nou mail jeri kan!
\q1 
\v 15 Komail me kapaidar ren leowa, me kotin kapikadar la\it n\it* o jappa.
\q1 
\v 16 La\it n\it* me japwilim en leowa, a jappa me a kotiki o\it n\it*er aramaj akan.
\q1 
\v 17 Me melar akan jolar pan kapi\it n\it*a leowa, pil karoj, me kodi wajan kaporemen.
\q1 
\v 18 A kitail pan kapina leowa jan met o kokolata. Aleluia!
\c 116
\q1 
\v 1 I KIN pok o\it n\it* leowa, pwe a kotin ereki \it n\it*il ai o ai \it n\it*idi\it n\it*id.
\q1 
\v 2 Pwe a kotin kapaike do\it n\it* ia karo\it n\it* a, i me i pan likwir wo\it n\it* i arain maur i.
\q1 
\v 3 Jal en mela jali ia dier, o kamajak en pajed lel o\it n\it* ia, i lel o\it n\it*er kalokolok o mamauk.
\q1 
\v 4 I ap likwir won mar en leowa: Mai\it n\it* leowa, kom kotin dorela maur i!
\q1 
\v 5 leowa me dir en mak o pu\it n\it*, o atail Kot me dir en kala\it n\it*an.
\q1 
\v 6 leowa kin kotin apapwali me opampap akan; \it n\it*ai luetalar, i ap kotin dore ia lar.
\q1 
\v 7 \it N\it*en i pur o\it n\it* om moleilei, pwe leowa kotin jauaja uk mau.
\q1 
\v 8 Pwe kom me kotin dorelar maur i ja\it n\it* nan mela, o por en maj ai ja\it n\it* ja\it n\it*eja\it n\it*, o na i ja\it n\it* a pan krijedi.
\q1 
\v 9 I pan weweid mon leowa nan jap en me maur akan.
\q1 
\v 10 I liki, o i karepen ai padapadak; a i kin kalokolok laud.
\q1 
\v 11 I indinda ni ai injenjued: Aramaj karoj me likam!
\q1 
\v 12 Iaduen i pan kak depuk o\it n\it* leowa a kapai ia kan?
\q1 
\v 13 I pan ale dal en kamaur, o likwir o\it n\it* mar en leowa.
\q1 
\v 14 I pan kapwai o\it n\it* Ieowa ai inau janjal mon japwilim a aramaj akan karoj.
\q1 
\v 15 Meid kajampwal ren Ieowa melan japwilim a lelapok kan.
\q1 
\v 16 O Mai\it n\it* leowa, \it n\it*ai japwilim omui ladu men, \it n\it*ai japwilim omui ladu, nain omui lidu; kom kotin kamueit paja\it n\it* ai jal akan
\q1 
\v 17 I pan mairo\it n\it*ki o\it n\it* komui danke, o likwir o\it n\it* mar en Ieowa.
\q1 
\v 18 I pan kapwai o\it n\it* Ieowa ai inau janjal mon japwilim a aramaj akan karoj.
\q1 
\v 19 Mon pera en tanpaj omui im jaraui, nan waro\it n\it* en Ierujalem Aleluia!
\c 117
\q1 
\v 1 MEN liki kan karoj kapi\it n\it*a leowa! O kainok karoj kapi\it n\it*a i!
\q1 
\v 2 Pwe a kala\it n\it*an me janjal melel o\it n\it* kitail, o melel en leowa pan potopot eta. Aleluia!
\c 118
\q1 
\v 1 DANKE leowa, pwe i me man, pwe a kala\it n\it*an pan potopot eta.
\q1 
\v 2 Ijrael en indinda: A kala\it n\it*an pan potopot eta.
\q1 
\v 3 Kadaudok en Aron en indinda: A kala\it n\it*an pan potopot eta.
\q1 
\v 4 Me majak Kot akan en inda: A kala\it n\it*an pan potopot eta.
\q1 
\v 5 Ni ai apwal akan i likwir wo\it n\it* leowa; leowa kotin ma\it n\it*i ia er o kotin kajo\it n\it*e ia dier waja jaledok.
\q1 
\v 6 leowa kin kotin ieian ia, i jota majak, da me aramaj akan kak wiai o\it n\it* ia?
\q1 
\v 7 Ieowa kin kotin ieia\it n\it* ia nan pu\it n\it* en me jauaja ia, o i pan peren kida, me kailo\it n\it* kin ia.
\q1 
\v 8 Me mau, en liki Ieowa, ja\it n\it* kaporoporeki aramaj akan.
\q1 
\v 9 Me mau en liki Ieowa, ja\it n\it* kaporoporeki jaupeidi kan.
\q1 
\v 10 Men liki kan karoj kapil ia penaer; a ni mar en Ieowa i kaloe ir edier.
\q1 
\v 11 Re kapil ia penaer waja karoj, a ni mar en Ieowa i pan kaloe irail edier.
\q1 
\v 12 Re kapil ia penaer dueta lo\it n\it*lap akan, a re kunlar dueta kinjiniai nan tuka; ni mar en Ieowa i kaloe irail edier.
\q1 
\v 13 Re woki ia, pwe i ne pupedi, a Ieowa kotin jauaja iaer.
\q1 
\v 14 Ieowa iei ai kel o ai kaul, o i me kotin wiala ai jaunkamaur.
\q1 
\v 15 Kaul en kaperen o kamaur kin wiaui nan im en me pu\it n\it* kan, lim en Ieowa pali maun kin kapwaiada dodok manaman.
\q1 
\v 16 Pali maun en Ieowa me ileile, pali maun en Ieowa kin kapwaiada dodok manaman.
\q1 
\v 17 I jota pan mela, pwe memaur eta o padaki duen wiawian Ieowa.
\q1 
\v 18 Ieowa kotin kaloke ia laud, ap jota meuid o\it n\it*, i en mela.
\q1 
\v 19 Komail riti\it n\it*ada\it n\it* ia wanim en pu\it n\it*, pwe i waja me i pan pedelo\it n\it* ia, pwen danke Ieowa.
\q1 
\v 20 Iet wanim en Ieowa, waja me pu\it n\it* kan pan pedelo\it n\it* ia.
\q1 
\v 21 I danke komui, pwe kom kotin erekier ai kapakap o jauaja ia.
\q1 
\v 22 Takai o me pwin jauje kajelar, wialar takain pukakaim.
\q1 
\v 23 Mepukat wiauier ia\it n\it* ro\it n\it* Ieowa, meid kapuriamui ni maj at!
\q1 
\v 24 let ran o, me Ieowa kotin wiadar, kitail en popol o peren kida i.
\q1 
\v 25 O Mai\it n\it* Ieowa, kom kotin jauaja! O Mai\it n\it* Ieowa, kom kotin kapwaiada!
\q1 
\v 26 Meid kapi\it n\it*an me kotido ni mar en Ieowa! Kit kapai komail da, me kijan toun tanpaj en Ieowa.
\q1 
\v 27 Ieowa iei Kot, o i me kotin kamarain kitail er; jaliedi men mairo\it n\it* ni oj en pei jaraui!
\q1 
\v 28 Komui ai Kot, o i pan danke komui; ai Kot, i pan kalina\it n\it*ada komui.
\q1 
\v 29 Danke Ieowa, pwe i me mau, pwe a kala\it n\it*an pan potopot eta.
\c 119
\q1 
\v 1 RE meid pai, me jota kin japu\it n\it* ni al arail, me kin weweid ni kapu\it n\it* en Ieowa!
\q1 
\v 2 Re meid pai, me kin kolekol a kadede akan, me kin rapaki i ja\it n\it* nan mo\it n\it*io\it n\it* arail!
\q1 
\v 3 Me jota kin wia me jued, a weweid nan a al akan.
\q1 
\v 4 Pein komui kotikidar japwilim omui kujoned akan, pwe jen porijok kapwaiada.
\q1 
\v 5 O ma al ai kan inen wei, pwen kapwaiada omui kujoned akan.
\q1 
\v 6 I ap jota pan jarodi, ni ai pan apapwali japwilim omui kujonod akan karoj.
\q1 
\v 7 I danke komui ja\it n\it* nan mo\it n\it*io\it n\it* i melel, pwe kom kotin padaki do\it n\it* ia duen omui majan pu\it n\it*.
\q1 
\v 8 I pan kanai o\it n\it* japwilim omui kujoned akan, kom der likidmaliela.
\q1 
\v 9 Iaduen, manakap amen pan kak weweid ni makelekel? Ma a pan wiawia duen ar majan akan.
\q1 
\v 10 I raparapa kin komui ja\it n\it* nan mo\it n\it*io\it n\it*. i; kom der kotin mueid o\it n\it*, i en pup wei ja\it n\it* ni omui kujoned akan.
\q1 
\v 11 I kolekol omui majan nan mo\it n\it*io\it n\it* i, pwe i ender wia dip o\it n\it* komui.
\q1 
\v 12 Kapi\it n\it* en ko o\it n\it* komui, Mai\it n\it* Ieowa! Kom kotin padaki do\it n\it* ia omui kujoned akan.
\q1 
\v 13 I kajokajoi ki au ai duen kujoned en jila\it n\it* omui karoj.
\q1 
\v 14 I kin peren kita al en omui kadede kan, dueta dipijou toto.
\q1 
\v 15 I pan madamadaua duen omui kujoned akan, o kanai o\it n\it* omui al akan.
\q1 
\v 16 I kin peren kida omui kujoned akan, i jota pan monokela omui majan akan.
\q1 
\v 17 Kom kotin kamauiada japwilim omui ladu, pwe i en memaur eta; i ap pan kapwaiada omui majan o.
\q1 
\v 18 Kom kotin kapad paja\it n\it* maj ai, pwe i en kila\it n\it* manaman akan nan japwilim omui kapu\it n\it* o.
\q1 
\v 19 \it N\it*ai men kairu men nin jappa; kom der kotin karir ja\it n\it* mo i omui kujoned akan.
\q1 
\v 20 \it N\it*en i okilar ai ino\it n\it* io\it n\it* omui kujoned akan anjau karoj.
\q1 
\v 21 Kom kotin o\it n\it*io\it n\it*i me aklapalap o, me pan wuki wei ja\it n\it* omui kujoned akan, en riala.
\q1 
\v 22 Kom kotin katoror ja\it n\it* ia namenok o me jued; pwe i kin apapwali ar kadede kan.
\q1 
\v 23 Pil jaupeidi kan kin momod pena, kaokao ad ai; japwilim omui ladu kin madamadaua duen omui kujoned akan.
\q1 
\v 24 Melel, i kin peren kida omui kadede kan, pwe ir me jaua pa i.
\q1 
\v 25 \it N\it*en i onon nan pwel; kama\it n\it*a ia duen omui majan.
\q1 
\v 26 I potoan o\it n\it* komui duen al ai kan, komui ap kotin ma\it n\it*i ai er; kotin padaki o\it n\it* ia omui kujoned akan.
\q1 
\v 27 Kom kotin padaki o\it n\it* ia duen al en japwilim omui kujoned akan, i ap pan madamadaua duen ar manaman akan.
\q1 
\v 28 Mo\it n\it*io\it n\it* i luet kilar ai injenjued; kom kotin kama\it n\it*a ia da duen ar majan.
\q1 
\v 29 Re kotin pera wei ja\it n\it* ia al en likam, o kotiki o\it n\it* ia ar majan.
\q1 
\v 30 I piladar al en melel; i kin madamadaua duen omui kujoned.
\q1 
\v 31 I kin te\it n\it*eti o\it n\it* omui kadede kan; Mai\it n\it* Ieowa, kom der mueid o\it n\it*, i en namenokala.
\q1 
\v 32 Ma kom pan kotin kamaitala mo\it n\it*io\it n\it* i, i pan ta\it n\it* wei nan al en omui kujoned akan.
\q1 
\v 33 Mai\it n\it* Ieowa, kom kotin kawewe o\it n\it* ia al en omui kujoned akan, pwe i en apapwali lao lel imwi.
\q1 
\v 34 Kotin padaki o\it n\it* ia, pwe i en kolekol omui kapu\it n\it* o peiki o\it n\it* ja\it n\it* nan mo\it n\it*io\it n\it* i.
\q1 
\v 35 Kalua ia nan al en omui kujoned akan, pwe i kin peren kin irail.
\q1 
\v 36 Kaino\it n\it*io\it n\it* mo\it n\it*io\it n\it* i omui kadede kan, a der norok moni.
\q1 
\v 37 Pirer wei maj ai, pwen der kila\it n\it* me jued kot; a re kotin kakel ia da pon al omui.
\q1 
\v 38 Kolekol omui inau on japwilim omui ladu, pwe i en majak komui.
\q1 
\v 39 Kotiki ja\it n\it* ia namenok, me i juedeki; pwe omui kujoned akan me mau.
\q1 
\v 40 Kotin ma\it n\it*i, i kin ino\it n\it* io\it n\it* ar majan akan; kakele kin ia omui pu\it n\it*.
\q1 
\v 41 Mai\it n\it* Ieowa, kom kotin maki o\it n\it* ia, o kotin jauja ia duen omui inau.
\q1 
\v 42 Pwe i en aja, jape\it n\it* ir, me mamale kin ia, pwe i kin liki omui inau.
\q1 
\v 43 O kom der kotiki ja\it n\it* au ai majan en omui melel; pwe i kapororporki omui kujoned akan.
\q1 
\v 44 I pan kolekol omui kapun o anjau karoj kokolata.
\q1 
\v 45 I pan weweid ni peren, pwe i raparapaki omui kujoned akan anjau karoj.
\q1 
\v 46 O i pan kajokajoi o\it n\it* nanmarki kan duen omui kadede kan, ap jota namenok.
\q1 
\v 47 Pwe I kin peren kida omui kujoned akan, o i kin pok o\it n\it* ir.
\q1 
\v 48 I kin pokada\it n\it* pa i kat omui kujoned akan, me i pok o\it n\it*, o i pan madamadaua duen omui kujoned akan.
\q1 
\v 49 Kotin tamanda japwilim omui ladu, duen omui majan, me i kin kaporoporeki.
\q1 
\v 50 I me kin kamait ia la ni ai luet; omui ianu kan kin kakel ia da.
\q1 
\v 51 Me aklapalap akan kin mamale kin ia; ari jo, i jota kin meui ja\it n\it* omui kapu\it n\it* o.
\q1 
\v 52 Mai\it n\it* Ieowa, ma I lamelame duen omui kujoned akan ja\it n\it* nin tapin jappa, i ap injenamau kila.
\q1 
\v 53 I makar kila me doo ja\it n\it* Kot akan, me kin mui ja\it n\it* japwilim omui kapu\it n\it* o.
\q1 
\v 54 Omui kujoned akan, iei ai kaul en kapi\it n\it* nan ai im en kairu.
\q1 
\v 55 Mai\it n\it* leowa, ni po\it n\it* i kin madamadaua duen mar omui, o peiki o\it n\it* omui kapu\it n\it*.
\q1 
\v 56 Mepukat wiaui o\it n\it* ia er, pweki ai peiki o\it n\it* omui kujoned akan.
\q1 
\v 57 Mai\it n\it* leowa, iet pwaij ai, en kolekol omui majan kan.
\q1 
\v 58 I kin \it n\it*idi\it n\it*id o\it n\it* komui ja\it n\it* nan mo\it n\it*io\it n\it* i; kom kotin maki o\it n\it* ia duen omui inau o.
\q1 
\v 59 I kin madamadaua duen al ai, ap kainen wo\it n\it* omui kadede kan na i kat.
\q1 
\v 60 I kin nantio\it n\it* o jota pwapwand kolekol omui kujoned akan.
\q1 
\v 61 Pwin en me doo ja\it n\it* Kot akan kapil ia pena, ari jo, i jota monokela omui kapu\it n\it* kan.
\q1 
\v 62 Ni ailep en po\it n\it* i kin paurida, pwen danke komui, pweki omui kujoned pu\it n\it*.
\q1 
\v 63 I kin waroki o\it n\it* ir karoj, me majak komui o ir, me apapwali omui kujoned akan.
\q1 
\v 64 Mai\it n\it* leowa, jappa direki omui kala\it n\it*an; padaki o\it n\it* ia omui kujoned akan.
\q1 
\v 65 Mai\it n\it* leowa, komui me kotin wiai o\it n\it* japwilim omui ladu kamau kan duen omui inau o.
\q1 
\v 66 Padaki o\it n\it* ia tiak mau o loleko\it n\it*, pwe i kin liki omui kujoned akan.
\q1 
\v 67 Mon ai aktikitikila, i kin japujapu\it n\it*, a met i kin apapwali omui majan.
\q1 
\v 68 Komui me mau o kapu\it n\it*lol, kotin padaki do\it n\it* ia japwilim omui kujoned akan.
\q1 
\v 69 Me aklapalap akan kin kalikama ia; a \it n\it*ai kin apapwali omui kujoned akan ja\it n\it* nan monion i.
\q1 
\v 70 Mo\it n\it*io\it n\it* arail majul kila wi; a i kin peren kida omui kapu\it n\it*.
\q1 
\v 71 Meid mau o\it n\it* ia omui kaopampap ia la, pwe i en padakki omui kujoned akan.
\q1 
\v 72 Kapu\it n\it* ja\it n\it* nan jila\it n\it* omui mau o\it n\it* ia, ja\it n\it* kold o jilper kid toto.
\q1 
\v 73 Lim omui kan kapik o wia ia dar, padaki o\it n\it* ia, pwe i en aja omui kujoned akan.
\q1 
\v 74 Me kin majak komui, pan kila\it n\it* ia, ap peren kida, pwe i auiaui omui majan.
\q1 
\v 75 Mai\it n\it* Ieowa, i aja, me omui kadeik kan me pu\it n\it*, o kom kotin kaopampap ia la ni omui melel.
\q1 
\v 76 Omui mak pan kamait ia la, duen me kom kotin inauki o\it n\it* japwilim omui ladu.
\q1 
\v 77 Kom kotin kupura ia, i ap pan memaur eta, pwe i kin peren kida omui kapu\it n\it*.
\q1 
\v 78 Me aklapalap akan en jarodi, pwe re japu\it n\it* o\it n\it* ia ni jokarepa; a \it n\it*ai madamadaua duen omui kujoned akan.
\q1 
\v 79 Me majak komui, ren waroki o\it n\it* ia, o me aja duen omui kadede kan.
\q1 
\v 80 Mo\it n\it*io\it n\it* i en pu\it n\it* ni omui kujoned akan, pwe i ender jarodi.
\q1 
\v 81 \it N\it*en i kin ino\it n\it* io\it n\it* omui dore ia la, i auiaui omui majan.
\q1 
\v 82 Por en maj ai kin anane omui inau, kalelapok: lad me kom pan kotin kamait ia la?
\q1 
\v 83 Pwe i luetalar rajo\it n\it* deun pil eu nan adiniai, i jota monokela omui kujoned akan.
\q1 
\v 84 Arai da, japwilim omui ladu pan memaurada? lad me kom pan kotin kadeikada ai imwintiti kan?
\q1 
\v 85 Me aklapalap akan weirada\it n\it* ia por akai, irail me jota kin duki o\it n\it* japwilim omui kapu\it n\it* o.
\q1 
\v 86 Japwilim omui kujoned akan karoj me melel. Irail raparapakin ia ni jota karepa; kom kotin jauaja ia!
\q1 
\v 87 Me ekij, re pan kame ia la ja\it n\it* nin jappa, a \it n\it*ai jota mui ja\it n\it* omui kujoned akan.
\q1 
\v 88 Kamaur ia da duen omui kala\it n\it*an, a \it n\it*ai pan kolekol kadede en jila\it n\it* omui.
\q1 
\v 89 Mai\it n\it* Ieowa, omui majan pan potopot eta nanla\it n\it*.
\q1 
\v 90 Omui melel kin ja\it n\it* eu kainok lel eu; komui me kotin kajonedier jappa o a pan mimieta.
\q1 
\v 91 Irail karoj mimieta lao leI ran wet, duen omui kujoned akan, pwe karoj kin upa komui.
\q1 
\v 92 Ma omui kapu\it n\it* jota pan kaperen pa i, i pan mela ni ai luet.
\q1 
\v 93 I jota pan monokela omui kujoned akan kokolata, pwe ir me komui kakela kin ia da.
\q1 
\v 94 \it N\it*ai japwilim omui, kom kotin jauaja ia! Pwe i ino\it n\it* io\it n\it* japwilim omui kujoned akan.
\q1 
\v 95 Me doo ja\it n\it* Kot akan mamajan ia, pwen kame ia la; i kin apwali omui kadede kan.
\q1 
\v 96 I kila\it n\it*er imwin meakaroj, a japwilim omui kujoned pan mimieta.
\q1 
\v 97 Ia wan ai pok o\it n\it* japwilim omui kapu\it n\it*! Nin ran karoj i kin kajokajoi due.
\q1 
\v 98 Kom kin kaloleko\it n\it* kin ia omui kujoned akan ja\it n\it* ai imwintiti kan, pwe irail pan ieia\it n\it* ia kokolata.
\q1 
\v 99 \it N\it*ai loleko\it n\it* ja\it n\it* ai jaunpadak kan karoj, pe I kin madamadaua duen omui kadede kan.
\q1 
\v 100 \it N\it*ai loleko\it n\it* ja\it n\it* me ma kan, pwe I kin apapwali japwilim omui kujoned akan.
\q1 
\v 101 I jota mued o\it n\it* na i, en weweid pol al japu\it n\it*, pwe i en kolekol omui majan.
\q1 
\v 102 I jota wuki wei jan omui kujoned akan, pwe kom kotin padaki o\it n\it* ia er.
\q1 
\v 103 Omui majan me iau ja\it n\it* onik nan au ia.
\q1 
\v 104 Omui kujoned akan kin kaloleko\it n\it* ia, i me i kin tataki al japu\it n\it* karoj.
\q1 
\v 105 Japwilim omui majan me jer pan na i, o kamarain pan al ai.
\q1 
\v 106 I kaukilar, me i pan kolekol omui kujoned pun kan, o i pan kapwaiada.
\q1 
\v 107 I injenjued melel; Mai\it n\it* Ieowa, re kin kotin kamaur ia da duen omui inau.
\q1 
\v 108 Mai\it n\it* Ieowa, kom kotin kupura kijakij en au ai, o kotin padaki o\it n\it* ia omui kujoned akan.
\q1 
\v 109 I kin wewa maur i nan pa I kat; i jota monokela omui kapu\it n\it*.
\q1 
\v 110 Me doo ja\it n\it* Kot akan injenjare ia, a i jota wuki wei ja\it n\it* omui kujoned akan.
\q1 
\v 111 Omui kadede kan iei ai jojo joutuk, pwe re kaperenda mo\it n\it*io\it n\it* i.
\q1 
\v 112 Monion i kin ino\it n\it* io\it n\it* kapwaiada omui kujoned akan anjau karoj kokolata.
\q1 
\v 113 I kin kailo\it n\it*ki me lol riapot, o i kin pok o\it n\it* omui kapu\it n\it*.
\q1 
\v 114 Komui ai kadauk o pere pa i, i kaporoporeki omui majan.
\q1 
\v 115 Komail me jued akan en muei jan ia! I men apapwali kujoned en ai Kot akan.
\q1 
\v 116 Jauaja ia duen omui inau, i ap pan memaur eta; o kom der kotin mueid o\it n\it*, i en namenokala ni ai kaporopor.
\q1 
\v 117 Kama\it n\it*a ia da, i ap pan kelailada, i ap pan apapwali omui kujoned akan anjau karoj.
\q1 
\v 118 Kom kin kotin tiakedi karoj, me pan wuki wei ja\it n\it* omui kujoned akan; pwe arail japu\it n\it* me dir en likam.
\q1 
\v 119 Kom kin kotin kaje ja\it n\it* jappa me doo ja\it n\it* Kot akan karoj dueta jamit; i me i kin pok o\it n\it* ki omui kadede kan.
\q1 
\v 120 I kin majak komui, i me i kin mujerereki, o i kin majak omui kadeik kan.
\q1 
\v 121 I kin apapwali me inen o pu\it n\it*; kom der kotin pa\it n\it* ia la\it n\it* ren me kin wia jued o\it n\it* ia.
\q1 
\v 122 Jauaja japwilim omui ladu o kamaitala i; me aklapalap akan ender jued o\it n\it* ia.
\q1 
\v 123 Por en maj ai ino\it n\it* io\it n\it* omui kamaur ia, o omui inau pu\it n\it*.
\q1 
\v 124 Wia o\it n\it* japwilim omui ladu duen omui kala\it n\it*an, o kotin padaki o\it n\it* ia omui kujoned akan.
\q1 
\v 125 \it N\it*ai japwilim omui ladu; kotin padaki o\it n\it* ia, pwe i en dedeki japwilim omui kujoned kan.
\q1 
\v 126 Anjau leler, me Ieowa pan kotin wiawia; pwe irail kawala japwilim omui kapu\it n\it*.
\q1 
\v 127 I me i kin pok ki o\it n\it* japwilim omui kujoned akan, ja\it n\it* kold o kold li\it n\it*an.
\q1 
\v 128 I me i kin kajampwaleki japwilim omui kujoned akan karoj, i tata ki al en likam karoj.
\q1 
\v 129 Omui kadede kan meid kapuriamui, i me mo\it n\it*io\it n\it*, i apapwali kin ir.
\q1 
\v 130 Ma omui majan pan janjalada, a pan kareda peren o loleko\it n\it* o\it n\it* me opampap akan.
\q1 
\v 131 Au ai kin jar paja\it n\it* o ino\it n\it* io\it n\it* japwilim omui kujoned akan; pwe i kin anane ir.
\q1 
\v 132 Kom kotin wukedoke do\it n\it* ia, o maki o\it n\it* ia, duen me kom kin wiai o\it n\it* ir, me pok o\it n\it* mar omui.
\q1 
\v 133 Kotin kainenela al ai nan japwilim omui majan, o der mueid o\it n\it*, me jued kot en wiawia ia.
\q1 
\v 134 Kotin dore ia la ja\it n\it* mor jued en aramaj akan, a i ap pan kolekol omui kujoned akan.
\q1 
\v 135 Kotin kamarainiki omui ladu jila\it n\it* omui, o kotin padaki o\it n\it* ia duen omui kujoned akan.
\q1 
\v 136 Por en maj ai me dir en pil, pweki ar jota peiki o\it n\it* omui kapu\it n\it*.
\q1 
\v 137 Mai\it n\it* Ieowa, komui me kotin pu\it n\it*, o omui kujoned akan me pu\it n\it*.
\q1 
\v 138 Komui me kotiki o\it n\it* kit er kadede pan omui pu\it n\it* o melel, pwe i en nantio\it n\it* kapwaiada.
\q1 
\v 139 I injenjued melel, koren io\it n\it* mela, pweki ai imwintiti kan monokela omui majan akan.
\q1 
\v 140 Omui majan meid makelekel, o japwilim omui ladu kin pok o\it n\it*.
\q1 
\v 141 \it N\it*ai me tikitik o mo inn I amen, a i jota kin monokela omul kujoned akan.
\q1 
\v 142 Omui pu\it n\it* me pu\it n\it* joutik eu, o omui kapu\it n\it* me melel.
\q1 
\v 143 Majak o apwal lel do\it n\it* ia omui kujoned akan ai peren.
\q1 
\v 144 Pu\it n\it* en japwilim omui kadede kan me joutuk, padaki o\it n\it* ia, i ap pan memaur eta.
\q1 
\v 145 I \it n\it*idi\it n\it*id ja\it n\it* nan mo\it n\it*io\it n\it* i, Ieowa kom kotin ma\it n\it*i ia! I pan apapwali omui kujoned akan.
\q1 
\v 146 I likwir wo\it n\it* komui, kom kotin jauaja ia, a i ap pan kolekol omui kadede kan.
\q1 
\v 147 Nin joran i kodo o \it n\it*idi\it n\it*id, i auiaui omui majan.
\q1 
\v 148 I kin pirida ni ailep en po\it n\it*, pwen madamadaua duen omui majan.
\q1 
\v 149 Ereki \it n\it*ilai duenar kala\it n\it*an; Mai\it n\it* Ieowa, kamaur ia da duen omui kujoned akan.
\q1 
\v 150 Ai imwintiti jued akan koren io\it n\it* ia, a re doo ja\it n\it* japwilim omui kapu\it n\it*.
\q1 
\v 151 Mai\it n\it* Ieowa, komui me koren io\it n\it* ia, o omui kujoned akan karoj me melel.
\q1 
\v 152 I aja ja\it n\it* maj o, me komui kajonedier japwilim omui kadede kan, pwen potopot eta.
\q1 
\v 153 Kom kotin irero\it n\it* ai luet, o kamaio ia da! Pwe i jota monokela omui kapu\it n\it*.
\q1 
\v 154 Kotin apapwali ia, o dore ia la, o kamaur ia da duen omui inau.
\q1 
\v 155 Me doo ja\it n\it* Kot akan kin doo ja\it n\it* maur, pwe re jota kin ijenoki omui kujoned akan.
\q1 
\v 156 Omui kala\it n\it*an meid laud, Mai\it n\it* Ieowa; kom kotin kamaur ia da duen omui kujoned akan.
\q1 
\v 157 Me pakipaki ia, o palian ia me toto; ari jo, i jota wuk wei ja\it n\it* omui kadede kan.
\q1 
\v 158 I kin kilekila\it n\it* me mor jued akan, ap pokela, o i kin juedeki, pwe re jota kin peiki o\it n\it* omui kujoned o.
\q1 
\v 159 Kotin majando, me i kin pok o\it n\it* japwilim omui kujoned akan; Mai\it n\it* Ieowa, kotin kakel ia da, duen omui kala\it n\it*an.
\q1 
\v 160 Omui majan me dir en melel, o majan en omui kapu\it n\it* pan duedueta.
\q1 
\v 161 Jaupeidi kan kin majamajan ia ni jokarepa; a mo\it n\it*io\it n\it* i kin makaj omui majan akan.
\q1 
\v 162 I kin peren kida omui inau dueta amen, me diarada pai kajapwal eu.
\q1 
\v 163 I kailo\it n\it*ki likam o juede kin irail, a i kin pok o\it n\it* japwilim omui kapu\it n\it*.
\q1 
\v 164 Pan ije pak i kin kapi\it n\it*a komui ni ran ta ieu, pweki kujoned en omui kapu\it n\it* kan.
\q1 
\v 165 Me kin pok on japwilim omui kapun, kin popol melel, re jota pan jalo\it n\it*ala.
\q1 
\v 166 Mai\it n\it* Ieowa, i kin auiaui omui kamaur, o i kin peiki o\it n\it* japwilim omui kujoned akan.
\q1 
\v 167 Mo\it n\it*io\it n\it* i kin kolekol japwilim omui kadede kan, o kin pok o\it n\it* irail melel.
\q1 
\v 168 I kin kolekol japwilim omui kujoned o kadede kan, pwe al ai kan karoj me janjal momui.
\q1 
\v 169 Mai\it n\it* Ieowa, kotin ma\it n\it*i ai \it n\it*idi\it n\it*id, o kotin padaki o\it n\it* ia duen omui majan.
\q1 
\v 170 Re kotin ma\it n\it*i ai kapakap, o dore ia la duen omui inau.
\q1 
\v 171 Komui lao padaki o\it n\it* ia omui kujoned akan, kil en au ai ap pan kapi\it n\it*a komui.
\q1 
\v 172 Lo i pan kauleki duen omui majan, pwe omui kujoned akan karoj me pu\it n\it*.
\q1 
\v 173 Lim omui en jauaja ia, pwe i piladar omui kujoned akan.
\q1 
\v 174 Mai\it n\it* Ieowa, i kin ino\it n\it* io\it n\it* omui kamaur, o i kin peren kida omui kapu\it n\it*.
\q1 
\v 175 Kom kotin ieia\it n\it* \it n\it*en i, pwen memaur eta ap kapi\it n\it*a komui, o lim omui pali maun en jauaja ia.
\q1 
\v 176 \it N\it*ai raj o\it n\it* jip amen me janjalo\it n\it* jili o jalo\it n\it*ala; kom kotin rapaki japwilim omui ladu, pwe i jota monokela omui kujoned akan.
\c 120
\q1 
\v 1 NI ai apwal akan i likwir wo\it n\it* Ieowa, a ap kotin ma\it n\it*i ia.
\q1 
\v 2 Mai\it n\it* Ieowa, kotin dore ia la, ja\it n\it* au en me kin likam, o lo en kotaue.
\q1 
\v 3 Da me lo likam kak wiai o\it n\it* uk, o da me a kak kapwaiada!
\q1 
\v 4 A rajo\it n\it* kana\it n\it*an kajik katieu ko\it n\it* kan ren me kelail amen, dueta kijiniai nan alek.
\q1 
\v 5 Meid apwal o\it n\it* ia, ai kairu nan Mejek, o ai kaujon impan im en men Kedar!
\q1 
\v 6 Meid warai o\it n\it* ai kaukaujon ren aramaj akan me kin tataki muei mau.
\q1 
\v 7 I ino\it n\it* io\it n\it* muei mau, a ni ai pan lokaia, re kin mauki mauin.
\c 121
\q1 
\v 1 I JARADA\it N\it* nana kan, waja jauaj pa i pan pwarado ja\it n\it* ia.
\q1 
\v 2 Jauaj pa i pan pwarado ja\it n\it* ren Ieowa, me kotin kapikadar la\it n\it* o jappa.
\q1 
\v 3 A jota pan kotin mueid o\it n\it* na om, en krijedi; o me kin jinjila uk, jota kin jaimokala.
\q1 
\v 4 Kila\it n\it*, jile pan Ijrael jota kin jaimok de jaimok kalik.
\q1 
\v 5 Ieowa iei jile pa om, Ieowa iei motan pa om pali maun.
\q1 
\v 6 Katipin jota pan dakar uk nin ran de maram ni po\it n\it*.
\q1 
\v 7 Ieowa pan kotin pera wei ja\it n\it* uk jo\it n\it* en jued karoj, a pan kotin jinjila \it n\it*en om.
\q1 
\v 8 Ieowa pan kotin jinjila uk ni om pedoi o pedelo\it n\it*, ja\it n\it* met o kokolata.
\c 122
\q1 
\v 1 I PEREN kida ar indai o\it n\it* ia: Kitail en kola\it n\it* nan tanpaj en Ieowa!
\q1 
\v 2 Na at akan pan mi ni wanim en kel en Ierujalem.
\q1 
\v 3 Ierujalem kanim eu me kakaudar, pwen kanim kelail eu.
\q1 
\v 4 Waja me kainok kan kin momaitala ia, kainok en Ieowa kan, jaunkadede en Ijrael, pwen kapi\it n\it*a mar en Ieowa.
\q1 
\v 5 Pwe i waja me mol en kadeik mi ia, mol en kadaudok en Dawid.
\q1 
\v 6 Poeki o\it n\it* Ierujalem a pai kan! Me kin pok o\it n\it* uk, en paida!
\q1 
\v 7 Muei mau en mi ni om kel, o pai nan om im akan!
\q1 
\v 8 I pan kapakapa kin uk pweki ri ai o kompoke pai kan.
\q1 
\v 9 I pan rapaki o\it n\it* uk me mau melel, pweki tanpaj en Ieowa at Kot.
\c 123
\q1 
\v 1 I KIN jarada wo\it n\it* komui, me kotikot nanla\it n\it*.
\q1 
\v 2 Kila\it n\it*, duen maj en ladu kan kin kilekila\it n\it* lim en ar jaumaj akan, o duen maj en lidu kan kin kilekila\it n\it* a jaumaj li, iduen maj at kin ariri Ieowa at Kol, a lao kotin maki o\it n\it* kit.
\q1 
\v 3 Mai\it n\it* Ieowa, kom kotin maki o\it n\it*, kotin maki o\it n\it* kit! Two kit me dir en namenok.
\q1 
\v 4 Monio\it n\it* i toutouki en me jued akan ar mamale kin kit o en me aklapalap akan ar kanamenok kin kit.
\c 124
\q1 
\v 1 IJRAEL en inda: Ma Ieowa jota pan kotin ieia\it n\it* kit.
\q1 
\v 2 Ma Ieowa jota pan kotin ieia\it n\it* kit, ni en aramaj akan ni palian kit.
\q1 
\v 3 Re pan katala kit ala ni at memaur, ni ar li\it n\it*ara\it n\it*ar kin kit.
\q1 
\v 4 Pil akan ap pan kamop kit ala, pilap akan kadupwaledi \it n\it*en it.
\q1 
\v 5 Pil akan itida melel lao kadupwaledi \it n\it*en it.
\q1 
\v 6 Kapi\it n\it* o\it n\it* Ieowa, me jota mueid o\it n\it*, \it n\it*i arail en ter kit pajan!
\q1 
\v 7 \it N\it*en it piti ja\it n\it* injar en jaun injar dueta manpir amen; injar ola, a kit pitila.
\q1 
\v 8 Jauaj pat iei mar en Ieowa, me kotin kapikadar la\it n\it* o jappa.
\c 125
\q1 
\v 1 Me liki Ieowa kin rajo\it n\it* dol Jion, me jota kin mokid, a pan potopot eta.
\q1 
\v 2 Duen dol akan kin kapil pena Ierujalem, iduen Ieowa kin kotikot ren japwilim a aramaj akan, ja\it n\it* met o kokolata.
\q1 
\v 3 Pwe jokon en me doo ja\it n\it* Kot akan jota pan mimieta ren kijin pwin en me pu\it n\it* kan, pwe me pu\it n\it* kan ender kapa wo\it n\it* pa ar an nin japu\it n\it*.
\q1 
\v 4 Mai\it n\it* Ieowa, kotin kajanjaleda omui kalanan on me mau kan o o\it n\it* ir, me melel nan mo\it n\it*io\it n\it* arail.
\q1 
\v 5 A me kin wuki wo\it n\it* ni al japu\it n\it*, Ieowa pan kotin paki irail wei ia\it n\it*aki me jued akan, Ijrael en popol!
\c 126
\q1 
\v 1 NI anjau Ieowa kotin kapuredor me jalidi en Ijrael akan, kit rajo\it n\it* ir, me auramen.
\q1 
\v 2 I anjau au at me dir en kaurur, o Io at me dir en \it n\it*iji\it n\it*ij. I anjau men iki kan ap inda: Meid laud dodok en Ieowa re ’rail!
\q1 
\v 3 Melel, dodok en Ieowa meid Iaud o\it n\it* kit er, o i me je kin peren kida.
\q1 
\v 4 Mai\it n\it* Ieowa, re kotin kapuredo at jalidi kan dueta pilap en jap en pali air akan.
\q1 
\v 5 Me kamore kidi pil en maj arail, pan dolu\it n\it* ni peren.
\q1 
\v 6 Re kin weweidki ja\it n\it*eja\it n\it*, o kin wewa wa kajampwal, a ni ar puredo, re pan peren, wad oar kap en wa kan.
\c 127
\q1 
\v 1 MA Ieowa jota pan kauada im o, dodok en pwin jauje jota pan katepa; ma Ieowa jota pan jinjila kanim o, jaunmajamajan pan majamajan mal.
\q1 
\v 2 Jota katepa o\it n\it* komail, ma komail pan paurida nin joran, ap pil pwand kamol ni po\it n\it*, o toutouki okotme, ni omail ma\it n\it*ama\it n\it*a, pwe a kin kakepwapwala japwilim a kompokepa kan ni ar mamair.
\q1 
\v 3 Kila\it n\it*, jeri ko iei kijakij eu ja\it n\it* ren Ieowa, o wan aramaj pai eu.
\q1 
\v 4 Duen kana\it n\it*an kajik katieu nan pa en ol komad amen, iduen putak ko ar pan pwaida.
\q1 
\v 5 Meid pai ol o, me a lepan me direki mepukat! Re jota pan jarodi, ni ar kapu\it n\it* pena ren ar imwintiti kan.
\c 128
\q1 
\v 1 MEID pai karoj, me kin majak Ieowa, me kin weweid nan japwilim a al akan!
\q1 
\v 2 Pwe koe pan memauroki dodok en pa om akan, koe meid pai o pwaida mau.
\q1 
\v 3 Om paud pan rajo\it n\it* tuka en wain pot, me wa mau nan im om, o noum jeri kan pan dueta paini, me kapwata om tepel.
\q1 
\v 4 Kila\it n\it*, iduen ol o, me majak Ieowa, a pan pwaida.
\q1 
\v 5 Ieowa pan kapai uk ada ja\it n\it* nan Jion, pwe koe en kila\it n\it* pai en Ierujalem arain om maur.
\q1 
\v 6 O koe pan kila\it n\it* jeri eu noum jeri ko. Ijrael en popol!
\c 129
\q1 
\v 1 IJRAEL en inda: Re katoutou ia melel ja\it n\it* ni ai tikitik lel met pak toto.
\q1 
\v 2 Pan pak toto re katoutou ia melel ja\it n\it* ni ai tikitik lel met; ari jo, re jota kak kaloe ia di.
\q1 
\v 3 Men japajap weirada pon tinjau ai, wiadar warawar reirei.
\q1 
\v 4 A Ieowa me pu\it n\it*, a kotin lepuk paja\it n\it*er jal en me doo ja\it n\it* Kot akan.
\q1 
\v 5 Karoj me kin tataki Jion, en jarodi o tanwei!
\q1 
\v 6 Ren rajo\it n\it* ra pon oj en im o, me kin mo\it n\it* pena mon a pan ujujda!
\q1 
\v 7 Me jota kin kadirela kumut en pa en jaundolu\it n\it*, de pa en me kin pir pena kap akan.
\q1 
\v 8 Pwe me kin daulul waja o, ren der inda: Kot en kotin kupura maui komail! Kit kapai komail da ni mar en Ieowa!
\c 130
\q1 
\v 1 MAI\it N\it* Ieowa, i kin likwirda wo\it n\it* komui ja\it n\it* nan waja lol.
\q1 
\v 2 Mai\it n\it*, kotin ereki \it n\it*il ai! Karo\it n\it* omui en mama\it n\it*i ai \it n\it*idi\it n\it*id!
\q1 
\v 3 Ma komui Ieowa, pan kotin kapokonki o\it n\it* aramaj dip akan, Mai\it n\it*, ij me ap pan kak kajinenda mo ’mui?
\q1 
\v 4 A komui kin kotin mak, pwe aramaj en majak komui.
\q1 
\v 5 I kin auiaui Ieowa, \it n\it*en i kin auiaui, o i kin auiaui a inau.
\q1 
\v 6 \it N\it*en i kin auiaui Kaun o, ja\it n\it* jaunmajamajan kin auiaui manja\it n\it*, jaunmajamaja\it n\it* kin auiaui manja\it n\it*.
\q1 
\v 7 Ijrael auiaui Ieowa, pwe Ieowa me kala\it n\it*an, o waja en kamaio mi re a.
\q1 
\v 8 A pan kotin dorela Ijael ja\it n\it* dip a kan karoj.
\c 131
\q1 
\v 1 MAI\it N\it* Ieowa, mo\it n\it*io\it n\it* i jota aklapalap, o por en maj ai jota aklapalap; i jota kin ino\it n\it* io\it n\it* dodok, me i jota itar o\it n\it*.
\q1 
\v 2 Melel, i kamoleileilar mo\it n\it*io\it n\it* i dueta kijin jeri me muei ja\it n\it* didi en a nono; duen jeri me muei ja\it n\it* didi en a nono, iduen mo\it n\it*io\it n\it* i moleileilar.
\q1 
\v 3 Ijrael, auiaui Ieowa ja\it n\it* met o kokolata!
\c 132
\q1 
\v 1 MAI\it N\it* Ieowa, kom kotin tamanda Dawid o a apwal akan karoj.
\q1 
\v 2 Me kauki o\it n\it* Ieowa, o a inauki o\it n\it* Kot manaman en Iakop.
\q1 
\v 3 I jota pan pedelo\it n\it* o\it n\it* nan im ai, o i jota pan wendi pon loj.
\q1 
\v 4 I jota pan mueid o\it n\it* maj ai en mair, de por en maj ai, en mair pena.
\q1 
\v 5 Lao i pan diar ekij waja o\it n\it* Ieowa, wajan tanpaj en Kot manaman en Iakop.
\q1 
\v 6 Melel, je ro\it n\it*er duen i nan Eprata; je diaradar i nan jap en laar.
\q1 
\v 7 Je pan pedelo\it n\it* o\it n\it* nan tanpaj a o kaudok ni utipa.
\q1 
\v 8 Kotida, Mai\it n\it* Ieowa, koti do\it n\it* omui kamol, komui o kopan omui kala\it n\it*an.
\q1 
\v 9 Japwilim omui jamero kan en likau kida pu\it n\it*, o japwilim omui me jaraui kan en pereperen.
\q1 
\v 10 Re der jopwei ja\it n\it* maj en japwilim omui me keidier, pweki Dawid japwilim omui ladu.
\q1 
\v 11 Ieowa kotin kaula o\it n\it* Dawid kaula melel eu, o a jota pan kawukila: I pan kajapwilda\it n\it* mol om kijan kadaudok om.
\q1 
\v 12 Ma noum jeri ko pan kolekol ai inau, o ai kujoned akan, me I pan kawewe o\it n\it* irail, nairail jeri ko ap pil pan mondi pon mol om kokolata.
\q1 
\v 13 Melel Ieowa kotin pilada Jion, o a kotin men kotikot waja o.
\q1 
\v 14 Iet wajan ai kamol kokolata; wata et, me I pan kaukaujon ia, pwe waja et I kin mauki.
\q1 
\v 15 I pan kapaiada kan a ma\it n\it*a, o pan ki o\it n\it* me jamma re’rail prot toto.
\q1 
\v 16 O I pan kalikauwi kida maur arail, jamero kan, o me lelapok re’rail pan \it n\it*iji\it n\it*ij laud.
\q1 
\v 17 I waja mana en Dawid pan pwaida mau, I kaonopada\it n\it* nai, me kedier, marain eu.
\q1 
\v 18 I pan kalikauwi kida namenok a imwintiti kan a kapwat en nanmwarki pan mi pon mo\it n\it*a.
\c 133
\q1 
\v 1 KILA\it N\it*, meid kajelel, ma pirien eu kaujon pena ni limpok!
\q1 
\v 2 A dueta le pon kadokenmai, me kin kerekeredi nan alij en Aron, me kin kon keredi ni imwin a likau.
\q1 
\v 3 Dueta poik en Ermon, me kin moredi pon dol en Jion kan; pwe i waja, me Ieowa pan kotin kapaiada o kamaurada kokolata.
\c 134
\q1 
\v 1 KILA\it N\it*, kapi\it n\it*a Ieowa komail ladun Ieowa karoj, me kin mi nan tanpaj en Ieowa ni po\it n\it* kan!
\q1 
\v 2 Komail pokada pa omail nan pera jaraui o kapi\it n\it*a Ieowa!
\q1 
\v 3 Ieowa kotin kapai uk ada ja\it n\it* nan Jion, i me kotin kapikadar la\it n\it* o jappa.
\c 135
\q1 
\v 1 KAPI\it N\it*A mar en Ieowa, papan Ieowa, komail kapi\it n\it*a!
\q1 
\v 2 Komail me mi nan tanpaj en Ieowa, nan pera moa en tanpaj en atail Kot.
\q1 
\v 3 Kapi\it n\it*a Ieowa, pwe Ieowa me kala\it n\it*an; kauleki mar a, pwe I me mau.
\q1 
\v 4 Pwe Ieowa kotin piladar Iakop, o Ijrael, pwen japwilim a.
\q1 
\v 5 Pwe i aja, Ieowa meid lapalap, o atail Kot me lapa ja\it n\it* kot akan karoj.
\q1 
\v 6 Karoj me Ieowa kotin kupura, a kin wiada nanla\it n\it* o pil ni jappa, nan madau o pajed.
\q1 
\v 7 A kin kotin wiai o\it n\it* tapok kan, ren dauda ja\it n\it* ni imwin jappa, me kin kotin wiada liol o pil katau, me kin kotin kadatala kijinia\it n\it* ja\it n\it* nan a peril kan.
\q1 
\v 8 A kotin kamelar mejeni kan nan Akipten karoj ren aramaj o man akan.
\q1 
\v 9 O kotikida\it n\it* uk, Akipten, kilel o manaman akan, o\it n\it* Parao o na ladu kan karoj.
\q1 
\v 10 Me kotin kaloedi wein men liki kalaimun akan o kamelar nanmarki kelail akan.
\q1 
\v 11 Jion, nanmarki en Amon, o Ok, nanmarki en Pajan, o wei en Kanaan karoj.
\q1 
\v 12 O kotiki o\it n\it* japwilim a men Ijrael jap arail, pwe ren jojoki.
\q1 
\v 13 Ieowa, mar omui pan potopot eta; Mai\it n\it* Ieowa, kataman pa omui pan ja\it n\it* eu kainok lel eu.
\q1 
\v 14 Pwe Ieowa pan kotin kapu\it n\it* japwilim a aramaj akan, o a pan kotin maki o\it n\it* japwilim a ladu kan.
\q1 
\v 15 Dikedik en ani mal en men liki kan wiaui kida jilper o kold, me pa en aramaj wiadar.
\q1 
\v 16 Au arail mia, ap jaja lokaia, por en maj arail mia, ap jota kak kila\it n\it* waja;
\q1 
\v 17 Jalo\it n\it* arail mia, ap jota kak ro\it n\it* waja, pil jota a\it n\it* mi nan au ar.
\q1 
\v 18 Me kin wiada pukat me dueta irail, o pil karoj, me kin liki irail.
\q1 
\v 19 Kadaudok en Ijrael en kapi\it n\it*a Ieowa! Kadaudok en Aron en kapi\it n\it*a Ieowa.
\q1 
\v 20 Kadaudok en Lewi en kapi\it n\it*a Ieowa! Komail me majak Ieowa, en kapi\it n\it*a Ieowa!
\q1 
\v 21 Kapi\it n\it* o\it n\it* Ieowa ja\it n\it* nan Jion, me kotikot Ierujalem! Aleluia!
\c 136
\q1 
\v 1 DANKE Ieowa, pwe i me mau, pwe a kala\it n\it*an pan potopot eta.
\q1 
\v 2 Danke o\it n\it* Kot en kot akan, pwe a kala\it n\it*an pan potopot eta.
\q1 
\v 3 Danke o\it n\it* Kaun en kaun akan, pwe a kala\it n\it*an pan potopot eta.
\q1 
\v 4 Pwe i ta me kin wiada manaman akan, pwe a kala\it n\it*an pan potopot eta.
\q1 
\v 5 Me kotin wiadar la\it n\it* akan ni a erpit, pwe a kala\it n\it*an pan potopot eta.
\q1 
\v 6 Me kotin pak paja\it n\it*er jappa pon pil, pwe a kala\it n\it*an pan potopot eta.
\q1 
\v 7 Me kotin wiadar marain laud akan, pwe a kala\it n\it*an pan potopol eta.
\q1 
\v 8 Pwe katipin en kaunda ran, pwe a kala\it n\it*an pan potopot eta.
\q1 
\v 9 Jaunipo\it n\it* o uju kan en kaun da po\it n\it*, pwe a kala\it n\it*an pan potopot eta.
\q1 
\v 10 Me kotin kaloedi Akipten, ni a kamelar ar mejeni kan, pwe a kala\it n\it*an pan potopot eta.
\q1 
\v 11 O kotin kalua Ijrael ja\it n\it* waja o, pwe a kala\it n\it*an pan potopot eta.
\q1 
\v 12 Ki lim a manaman o, ni a kotin kapa wei lim a, pwe a kala\it n\it*an pan potopot eta.
\q1 
\v 13 Me pala\it n\it* paja\it n\it* jed waitata, wia pali ria pali, pwe a kala\it n\it*an pan potopot eta.
\q1 
\v 14 O mueid o\it n\it* Ijrael, en kotelu nan waro\it n\it* a, pwe a kala\it n\it*an pu\it n\it* potopot eta.
\q1 
\v 15 Me kotin kajedi o\it n\it* nan jed waitata Parao o na karij akan, pwe a kala\it n\it*an pan potopol eta.
\q1 
\v 16 Me kotin kalua japwilim a aramaj akan nan jap tan, pwe a kala\it n\it*an pan potopot eta.
\q1 
\v 17 Me kotin kamelar nanmarki lapalap akan, pwe a kala\it n\it*an pan potopot eta.
\q1 
\v 18 O kotin kamelar nanmarki kelail kan, pwe a kala\it n\it*an pan potopot eta.
\q1 
\v 19 Jiion, nanmarki en Amon, pwe a kala\it n\it*an pan potopot eta.
\q1 
\v 20 Ok, nanmarki en Pajan, pwe a kala\it n\it*an pan potopot eta.
\q1 
\v 21 O wiakila jap arail men jojo, pwe a kala\it n\it*an pan potopot eta.
\q1 
\v 22 Jojo en japwilim a ladu Ijrael, pwe a kala\it n\it*an pan potopot eta.
\q1 
\v 23 Pwe a kotin kupura kit ni at kanka\it n\it*era\it n\it*er, pwe a kala\it n\it*an pan potopot eta.
\q1 
\v 24 O kotin dore kitail la ja\it n\it* atail imwintiti kan, pwe a kala\it n\it*an \it n\it*an pan potopot eta.
\q1 
\v 25 Me kotin kama\it n\it*a me maur akan karoj, pwe a kala\it n\it*an pan potopot eta.
\q1 
\v 26 Danke o\it n\it* Kot en nanla\it n\it*, pwe a kala\it n\it*an pan potopot eta.
\c 137
\q1 
\v 1 KIT momoder ni kailan pilap en Papel o ja\it n\it*eja\it n\it*, ni ni tamanda Jion.
\q1 
\v 2 Kit la\it n\it*adar at arp akan nin tuka kan, me mi waja o.
\q1 
\v 3 Pwe me jali kit edi inda, jen kaul, o jen pereperen ni at mamaiei: Komail wiai o\it n\it* kit kaul apot duen Jion.
\q1 
\v 4 Iaduen at pan kak wiada kaul \it n\it*il leowa nan jap en men wai?
\q1 
\v 5 Ma i pan monoke uk ala Ierujalem, pa i pali maun ap pil pu\it n\it* monokinokla.
\q1 
\v 6 Lo i pan paj o\it n\it* pan \it n\it*ata\it n\it*at ai, ma i jolar pan taman uk adar, ma i jolar pan peren kida Ierujalem mon meakaroj.
\q1 
\v 7 Mai\it n\it* leowa, kom kotin tamanda en men Edom ar lokolokaia ni ran apwal en lerujalem Kawela, kawela lao Iel o\it n\it* nan pwel!
\q1 
\v 8 Toun Papel, morjued koe, re meid pai, me pan wiai o\it n\it* uk duen me koe wiadar!
\q1 
\v 9 Meid pai ir, me pan koledi noum jeri pwelel o kajuk pajan nin takai!
\c 138
\q1 
\v 1 I KAPI\it N\it*A komui ja\it n\it* nan mo\it n\it*ion i, i pan kakaule kin komui mon dikedik en ani kan.
\q1 
\v 2 I pan kakaudok inen wo\it n\it* japwilim omui im en kaudok jaraui, o kapi\it n\it*a mar omui, pweki omui kala\it n\it*an o melel, pwe kom kotin kali\it n\it*anada mar omui ja\it n\it* meakaroj ki omui majan.
\q1 
\v 3 Ni ai likwir wo\it n\it* komui, komui ap kotin ma\it n\it*i ia, o kom kamanada mo\it n\it*ion i melel.
\q1 
\v 4 Mai\it n\it* leowa, nanmarki en jappa karoj pan kapi\it n\it*a komui, ni ar pan ro\it n\it* majan en jila\it n\it* ir.
\q1 
\v 5 O re pan kauleki al en leowa kan, pwe li\it n\it*an en leowa meid laud.
\q1 
\v 6 Pwe leowa me lapalap ap kotin irero\it n\it* me tikitik kan, o a kotin ma\it n\it*i me aklapalap, ja\it n\it* ni waja doo.
\q1 
\v 7 Ni ai weweid nan kamajak melel, kom kin kotin kolekol o\it n\it* ia maur i, o kom kin kapa wo\it n\it* lim omui pan makar en ai imwintiti kan, o kom jaunja ia da ki lim omui maun.
\q1 
\v 8 leowa pan kotin wiawia ia. Mai\it n\it* leowa, omui kala\it n\it*an me pan potopot eta; Kom der kotin muei ja\it n\it* dodok en lim omui kan.
\c 139
\q1 
\v 1 MAI\it N\it*, leowa, kom kotin kadiarokada lol i, ap kotin mam ia.
\q1 
\v 2 Kom pil kotin ma\it n\it*i ma i momod de uda, ap kotin ma\it n\it*i ai lamelam ni ar kotin doo ja\it n\it* ia.
\q1 
\v 3 Ir me kotin kupura ia ni ai potopoto jili, o ni ai wonon, ap kotin ma\it n\it*i ai tiak kan karoj.
\q1 
\v 4 Melel Mai\it n\it* leowa, jota ai poto ja\it n\it* ni lo i, me kom jota kotin ma\it n\it*i.
\q1 
\v 5 Kom kin kotin ieia\it n\it* ia waja karoj, o kom kin kapado lim omui po i.
\q1 
\v 6 Mepukat meid kapuriamui o\it n\it* ia, meid apwal, i jota kak dedeki.
\q1 
\v 7 Ia waja, i pan kak ko ja\it n\it* mon \it n\it*en ar ia? O ia waja, i pan kak piti ja\it n\it* jila\it n\it* ar ia?
\q1 
\v 8 Ma i piridala nanla\it n\it*, kom kotikot waja o, o ma i onop o\it n\it* wendi nan wajan mela, kom pil kotikot ia.
\q1 
\v 9 Ma i ale pan pir en umpul en katipin, ap mimieta ni kailan madau.
\q1 
\v 10 Lim ar pil pan kare ia waja o, o lim ar maun pan kolekol ia.
\q1 
\v 11 Ma i pan inda: Rotorot en kadupwal ia di, pon ap pil pan marainla imp ai.
\q1 
\v 12 Pwe rotorot jo kin rotorot mo omui, o po\it n\it* i kin marain dueta nin ran, rotorot kin dueta marain.
\q1 
\v 13 Pwe kom me kotin wiadar mudilik i, o kom kotin wia ia da nan kaped en in ai.
\q1 
\v 14 I danke komui, duen kapuriamui en ai wiaui ia da, meid kapuriamui japwilim ar dodok kan, \it n\it*en i pil dedeki melel mepukat.
\q1 
\v 15 Kokon ai kan me janjal o\it n\it* komui ni ai wiauier waja rir, ni ai wiauier waja lol en jappa.
\q1 
\v 16 Jila\it n\it* ir ma\it n\it*i ia ni ai jaikenta wiauier, o ran karoj me kokodo, ap jaikenta mia, me kileledier nan iapwilim omui puk o.
\q1 
\v 17 Mai\it n\it* Kot, meid kajampwal o\it n\it* ia duen meakan karoj, me komui kin kupukupura!
\q1 
\v 18 Ma i pan wadok ir, i jota pan kak o\it n\it*, pwe re me toto ja\it n\it* pik en oror, ni ai pirida, i kin mimieta re omui.
\q1 
\v 19 O Mai\it n\it* Kot, kom jota men kamela me doo ja\it n\it* Kot akan; o me kin ino\it n\it* io\it n\it* nta, en muei ja\it n\it* ia!
\q1 
\v 20 Pwe re kin lokaia jued duen komui, o japwilim omui imwintiti kan kin ka\it n\it*udi ni jokarepa.
\q1 
\v 21 I kin kailonki, Mai\it n\it* leowa, me kin kailo\it n\it*ki komui, o i juedeki ar palian komui.
\q1 
\v 22 I kin kailo\it n\it* kin ir melel, re wialar ai imwintiti.
\q1 
\v 23 Mai\it n\it* Kot, kom kotin kajaui ia, o ma\it n\it*i duen mo\it n\it*io\it n\it* i, kotin rapaki duen me i kin lamelame,
\q1 
\v 24 O kom kotin majani, ma i mi pon al jued, o kotin kalua ia pon al joutuk.
\c 140
\q1 
\v 1 MAI\it N\it* leowa kom kotin dore ia la ja\it n\it* aramaj jued akan; pera ja\it n\it* ia aramaj morjued akan.
\q1 
\v 2 Me lamelame jued nan mo\it n\it*ion arail, o kareda pei nin ran karoj.
\q1 
\v 3 Irail kin ada lo arail dueta jerpent; poijen en jerpent mi pan lo arail.
\q1 
\v 4 Pera wei ja\it n\it* ia pa en me doo ja\it n\it* Kot akan, o aramaj morjued akan, me kin madamadaua duen in pan kawe ia la.
\q1 
\v 5 Me aklapalap akan kin rir injare ia, o uk pot, me re wiai o\it n\it* ai liman al o; o jo\it n\it*, en men kol ia di, me re wiadar.
\q1 
\v 6 A \it n\it*ai inda\it n\it* Ieowa: Komui ai Kot; kom kotin ereki ai \it n\it*idi\it n\it*id, Mai\it n\it* Ieowa!
\q1 
\v 7 Ieowa Kaun, iei jauaj pa i kelail; ni anjau en pei komui peraer mo\it n\it* ai.
\q1 
\v 8 Mai\it n\it* Ieowa, kom der kotin mueid o\it n\it* me doo ja\it n\it* Kot akan ar ino\it n\it*; o der kotin kapwaiada injen ar, pwe re de aklapalapala.
\q1 
\v 9 Me jued kot, me ai imwintiti kuonopada\it n\it* ia en japal wo\it n\it* pein irail.
\q1 
\v 10 Kijiniai en moredi on po rail; A en kotin kaje irail di nan kijiniai, nan lapake, pwe ren jolur pitila.
\q1 
\v 11 Me lo a jued, ender pwaida nan jap o, ol morjued, me jued en pakipaki i, lao a pan pupedi.
\q1 
\v 12 I aja, me Ieowa pan kotin apapwali me luet akan, o jauaj pu\it n\it* en me jamama kan.
\q1 
\v 13 Melel, me pu\it n\it* kan pan kapina mar omui, me melel akan pan mimieta mon jila\it n\it* ar.
\c 141
\q1 
\v 1 MAI\it N\it* leowa, i kin likwir wo\it n\it* komui, kom kotin mada\it n\it* do\it n\it* ia; kom kotin ereki \it n\it*il ai, ni ai pan likwir wo\it n\it* komui.
\q1 
\v 2 Kom kotin kajampwaleki ai kapakap dueta mairo\it n\it* ijij; o pokadan pa i kat dueta mairo\it n\it* eu ni jautik.
\q1 
\v 3 Mai\it n\it* Ieowa, kom kotin jinjile au ai, o pera kil en au.
\q1 
\v 4 O der kotin kaino\it n\it* o\it n\it* me jued kot mo\it n\it*io\it n\it* i, pwe i ender ia\it n\it* me doo ja\it n\it* Kol, akan wiada me jued, o i ender ia\it n\it* ir ka\it n\it*ka\it n\it*, me re kin iauki.
\q1 
\v 5 Me pu\it n\it* amen en kame ia ni a kadek, o kapu\it n\it* ia, pwe iei me pan mau o\it n\it* ia dueta le o\it n\it* mon ai, mepukat i jota pan ka\it n\it*, o i kin kapakap anjau karoj, pwe ren der wiai o\it n\it* ia me jued.
\q1 
\v 6 Kalua parail en pijikendi ja\it n\it* pon paip; irail ap pan duki o\it n\it* ai padak o aja, me ir me mau.
\q1 
\v 7 Duen amen pan wera paja\it n\it* jap, iduen ti ’t akan, melokidokila ni kailan wajan mela.
\q1 
\v 8 Ari jo, maj ai kin ariri komui, Mai\it n\it* ai Kot, i liki komui, kom der kotin kajapokela maur i.
\q1 
\v 9 Pera wei ja\it n\it* ia injar, me re kaonop o\it n\it* ia, o jo\it n\it* en men kol ia di ren me morjued akan.
\q1 
\v 10 Me doo ja\it n\it* Kot akan en pein lodi o\it n\it* arail injar, a \it n\it*ai en dauli.
\c 142
\q1 
\v 1 I LIKWIRKI \it n\it*il laud o\it n\it* Ieowa, Ki \it n\it*il ai i kin \it n\it*idi\it n\it*ideki o\it n\it* Ieowa.
\q1 
\v 2 I kin kajanjale o\it n\it* i ai apwal akan, o i padaki o\it n\it* i katoutou pa i kan.
\q1 
\v 3 \it N\it*en i lao luetala, kom ap pan kotin apapwali. Irail rir wiai o\it n\it* ia injar eu liman al, me i kin weid ia.
\q1 
\v 4 I kila\it n\it* ni pali maun i, ari jota, me men jauaja ia; i jota kak pitila, pwe jota me kill idok ia.
\q1 
\v 5 Mai\it n\it* Ieowa, i likwir wo\it n\it* komui, o potoan: Komui me ai paip, o pwaij ai nan jap en me maur akan.
\q1 
\v 6 Kom kotin ma\it n\it*i ai weriwer, pwe \it n\it*ai meid luet; dore ia la ja\it n\it* me kin pakipaki ia, pwe \it n\it*ai jota itar o\it n\it* ir.
\q1 
\v 7 Kalua ja\it n\it* \it n\it*en i nan imaten, pwe i en kapi\it n\it*a mar omui. Me pu\it n\it* kan pan pokon do\it n\it* ia, ma kom pan kotin jauaja ia.
\c 143
\q1 
\v 1 MAI\it N\it* Ieowa, kom kotin ereki ai kapakap, o karo\it n\it* ar en ma\it n\it*i ai \it n\it*idi\it n\it*id; ma\it n\it*i ia ni ar melel o ar pu\it n\it*.
\q1 
\v 2 Kom der kotin kadeikada japwilim omui ladu, pwe mo ’mui jota me maur men me pu\it n\it*.
\q1 
\v 3 Pwe imwintiti kin majamajan ia, o kin tiakedi maur i; a kin kaje ia di waja rotorot dueta ir me melar maj o.
\q1 
\v 4 \it N\it*en i kin luetala, o mo\it n\it*io\it n\it* i ponla.
\q1 
\v 5 I kin tamanda anjau maj akan, o madamadaua duen ar wriawia kan; i kin lamelame duen dodok en lim omui kan.
\q1 
\v 6 I kin kapa wo\it n\it* komui pa i kat, duen jap madeko\it n\it* eu, me kin ino\it n\it* io\it n\it* katau, iduen \it n\it*en i kin ino\it n\it* io\it n\it* ir.
\q1 
\v 7 Mai\it n\it* Ieowa, kom kotin ma\it n\it*i ia mada\it n\it*, \it n\it*en i kin dupokala. Kom der kotin karirala jila\it n\it* omui ja\it n\it* mo i, pwe i ender dueta ir, me pan lokidokila. pj. 28.1
\q1 
\v 8 Nin joran omui kala\it n\it*an en pwara do\it n\it* ia, pwe i kin liki komui; kom kotin kajale o\it n\it* ia al, me i en weid ia, pwe \it n\it*en i kin auiaui komui.
\q1 
\v 9 Mai\it n\it* Ieowa, kom kotin doro ia la ja\it n\it* ai imwintiti kan, i kin kaporoporeki komui.
\q1 
\v 10 Padaki o\it n\it* ia, pwe i en dodok duen kupur omui; pwe komui ni Kot; \it n\it*en omui mau en kotin kalua ia pon al pu\it n\it*.
\q1 
\v 11 Mai\it n\it* Ieowa, kom kotin kamau ia da pweki mar omui; kalua ia ja\it n\it* nan waja apwal ni omui pu\it n\it*.
\q1 
\v 12 O kotin kawela ai imwintit i kan, pweki omui kala\it n\it*an; o kotin kamela karoj me kin katoutoui \it n\it*en i, pwe \it n\it*ai japwilim omui ladu.
\c 144
\q1 
\v 1 KAPI\it N\it* o\it n\it* Ieowa ai paip, me kin padaki o\it n\it* pa i kat pei, o jondin pa i kat mauin.
\q1 
\v 2 Komui ai mak, o ai kel, o ai imate\it n\it* ileile, o ai jaundor, o pere pa i, i me i kin liki, me kin kaloedi o\it n\it* ia nai aramaj akan.
\q1 
\v 3 Dakot aramaj o, pwe komui kin kotin kupukupura i, de nain aramaj, pwe komui kin kotin apapwali i?
\q1 
\v 4 Aramaj amen dueta jota meakot, a anjau kin ta\it n\it*wei dueta mota.
\q1 
\v 5 Mai\it n\it* Ieowa, kotikidi japwilim ar la\it n\it* akan o kotidi do\it n\it* kit, kotin jair nana kan, pwe adiniai en kujuda.
\q1 
\v 6 O kotin kadarado liol, pwen kamueit ir paja\it n\it*, kajiki wei japwilim ar kana\it n\it*an kajik kan, pwen kamajak ir wei.
\q1 
\v 7 Kapawei lim ar akan ja\it n\it* ni mol omui waja ileile o dore ia la, o kotin kamaur ia da ja\it n\it* nan pil kalaimun o ja\it n\it* nan pa en nain men wai.
\q1 
\v 8 Me au arail kin lokaia likam o ar wiawia kan me japu\it n\it*.
\q1 
\v 9 MAI\it N\it* Kot, i pan kaule kin komui kaul kap pot, i pan kajanki o\it n\it* komui arp, pjalter me jal eijok.
\q1 
\v 10 Komui me kotiki o\it n\it* nanmarki kan, ren poedi, o dorela japwilim omui ladu Dawrid ja\it n\it* ni kodlaj en me jued.
\q1 
\v 11 Re pil kotin dore ia la ja\it n\it* nan pa en nain men wai, me au arail kin lokaia likam o ar wiawia kan me japu\it n\it*.
\q1 
\v 12 Pwe nait putak kan en kakairida dueta tuka mau kan, o nait jeripein dueta maj en did en nan kaim en im li\it n\it*an eu.
\q1 
\v 13 Pwe at pera en nak en dir en kijin ma\it n\it*a, en itar o\it n\it* kikiwei jo\it n\it* karoj, o at jip akan en kaparapar mau, wiala kid o \it n\it*en pon at moj o.
\q1 
\v 14 O at kau ol en kak o\it n\it* dodok toto, pwe jota me jued kot de men kuli, de ja\it n\it*eja\it n\it* en wiaui nan al at akan.
\q1 
\v 15 Meid pai wei eu, me kin due met! Meid pai wei eu, me Ieowa arail Kot!
\c 145
\q1 
\v 1 I PAN kapi\it n\it*a komui, ai Kot o Nanmarki, o kapi\it n\it*a mar omui anjau karoj kokolata.
\q1 
\v 2 I pan kapi\it n\it*a komui ni ran akan karoj, o kapi\it n\it*a mar omui anjau kan karoj kokolata.
\q1 
\v 3 Ieowa meid lapalap, o kapi\it n\it*a pan, o jota me kak dedeki duen a lapalap.
\q1 
\v 4 Jeri en jeri kan pan kapi\it n\it*a omui dodok kan, o kajokajoi duen omui manaman.
\q1 
\v 5 I pan kajokajoia duen li\it n\it*an en omui kapwat, o i pan kaulki duen omui manaman akan.
\q1 
\v 6 O re pan kajokajoia duen manaman en omui dodok kan, o pan kapakaparok duen omui lapalap.
\q1 
\v 7 Irail pan kajokajoia duen omui kala\it n\it*an lapalap, o pere peren o kapi\it n\it*a duen omui pu\it n\it*.
\q1 
\v 8 Ieowa me dir en mak o kapu\it n\it*lol, kano\it n\it*ama o limpok.
\q1 
\v 9 Ieowa me kala\it n\it*an o\it n\it* karoj o a kapu\it n\it*lol o\it n\it* a wiawia kau karoj.
\q1 
\v 10 Japwilim omui wiawia kan en kapi\it n\it*a komui. Mai\it n\it* Ieowa, o japwilim omui lelapok kan en kapi\it n\it*a komui.
\q1 
\v 11 O ren kajokajoia duen li\it n\it*an en wei omui, o ren kapaka parokki duen omui manaman.
\q1 
\v 12 Pwe aramaj akan en dedeki duen omui manaman o li\it n\it*an o\it n\it* wei omui.
\q1 
\v 13 Wei omui wei joutuk eu, o omui kakaun pan duedueta kokolata.
\q1 
\v 14 Ieowa kin kotin kolekol karoj, me pan pupedi, o kainjeu maula karoj, me mamauk.
\q1 
\v 15 Por en maj karoj kajikajik komui, o kom kotiki o\it n\it* ir kan ar kijin ma\it n\it*a ni ar anjau.
\q1 
\v 16 Kom kotiki paja\it n\it* Lim omui o kadirela karoj, me memaur, duen kupur omui.
\q1 
\v 17 Ieowa me pu\it n\it* ni al karoj o jaraui ni a wiawia kan karoj.
\q1 
\v 18 Ieowa kotikot ren karoj, me likwir o\it n\it* i, karoj, me likwir melel.
\q1 
\v 19 A kotin wiai o\it n\it*, me majak i duen ar ino\it n\it*. A kotin ma\it n\it*i ar \it n\it*idi\it n\it*id, ap kotin jauaja ir.
\q1 
\v 20 Ieowa kin kotin jinjila karoj, me pok o\it n\it* i, a pan kamela me doo ja\it n\it* Kot akan karoj.
\q1 
\v 21 Au ai pan kapi\it n\it*a Ieowa, o uduk karoj kapi\it n\it*a mar a jaraui anjau kan karoj kokolata.
\c 146
\q1 
\v 1 EN i kapi\it n\it*a Ieowa!
\q1 
\v 2 I pan kapi\it n\it*a Ieowa arain ai maur, i pan kauleki pjalm akan o\it n\it* ai Kot arain maur i.
\q1 
\v 3 Der kaporoporeki jaupeidi kan, pwe irail aramaj o jota kak jauaja.
\q1 
\v 4 Pwe \it n\it*en en aramaj udan a pan kokola, o a pan pur o\it n\it* wiala pwel, i rah ota a jolar kak madamadaua meakot.
\q1 
\v 5 Meid pai me jauaj parail Kot en Iakop, me kin kaporoporeki Ieowa a Kot.
\q1 
\v 6 Me kotin kapikadar la\it n\it* o jappa, o madau, o audeparail karoj, me kin melel potopot eta.
\q1 
\v 7 Me kotin jauaja pu\it n\it* en me lodi o\it n\it* kalokolok mal, me kama\it n\it*a me men ma\it n\it*adar. Ieowa kin kotin lapwada me jalidi kan.
\q1 
\v 8 Ieowa kin kotin kapad paja\it n\it* maj en me majkun akan. Ieowa kin kotin kainjenemaula me mauk; Ieowa kin kotin pok o\it n\it* me pu\it n\it* kan.
\q1 
\v 9 Ieowa kin kotin jinjila men wai kan, o jauaja me japoupou o li odi kan, ap kotin kawela al en me doo ja\it n\it* Kot akan.
\q1 
\v 10 Ieowa iei Nanmarki joutuk, om Kot Jion kokolata. Aleluia!
\c 147
\q1 
\v 1 KAPI\it N\it*A Ieowa! Pwe meid kajampwal, en kapi\it n\it*a atial Kot; pwe mak eta en kauleki kaul en kapi\it n\it*.
\q1 
\v 2 Ieowa kin kotin kauada Ierujalem, o a kin kapokon pena me jalo\it n\it*ala ren men Ijrael.
\q1 
\v 3 A kotin kamauiala me lol olar akan, o kotin kitim pena ar olar akan.
\q1 
\v 4 A kin kotin wadok pena uju kan, o kin kida ad arail karoj.
\q1 
\v 5 Atail Kaun me lapalap o meid manaman, o jota me kak dedeki duen a erpit.
\q1 
\v 6 Ieowa kin kotin kamanada me luet akan, ap jikendi me doo ja\it n\it* Kot akan nan pwel.
\q1 
\v 7 Komail kakaul o\it n\it* Ieowa, en wia pwin paja\it n\it* o danke o kapi\it n\it*a atail Kot ia\it n\it* arp.
\q1 
\v 8 Me kin kotin pena kila la\it n\it* tapok kan, o kotin kamoredi katau o\it n\it* jappa; me kotin kawojada ra pon dol akan.
\q1 
\v 9 Me kin kotiki o\it n\it* man akan kan ar, rape pulepul akan, me kin likwir o\it n\it* i.
\q1 
\v 10 A jota kin kotin kupura kelail en oj o, de na en ol amen.
\q1 
\v 11 Ieowa kin kotin kupura, me majak i, me kin kaporoporeki a kala\it n\it*an.
\q1 
\v 12 Ierujalem, kapi\it n\it*a Ieowa! Jion, kapi\it n\it*a om Kot!
\q1 
\v 13 Pwe i me kin kotin kate\it n\it*ete\it n\it*edi jal mata en om wanim akan, o kotin kapaiada noum jeri ko, me mimi lole.
\q1 
\v 14 A kin kotiki o\it n\it* irair en jap om muei mau, o kin kotin kama\it n\it*a kin uk korn kajampwalia.
\q1 
\v 15 A kin kotin kadardi o\it n\it* jappa a majan akan, a kujoned kin lokok jili mada\it n\it*.
\q1 
\v 16 A kin kotikidi jno dueta koten o kamoredi poik dueta paj.
\q1 
\v 17 A kin kotin kajedi akel: IJ me kak injenemau ni a kapou?
\q1 
\v 18 A kin majani, ap pan pei paja\it n\it*, a kin kotin kadar wei a\it n\it*, ap kin pwilewei.
\q1 
\v 19 A kotin kajanjale o\it n\it* Iakop a majan o o\it n\it* Ijrael a kujoned o pu\it n\it*.
\q1 
\v 20 A jota kin kotin wia due o\it n\it* eu wei, i me re jota kin aja ki a pu\it n\it*. Aleluia!
\c 148
\q1 
\v 1 KOMAIL kapina Ieowa nanla\it n\it*, kapi\it n\it*a i nan waja ileile!
\q1 
\v 2 Komail japwilim a tounla\it n\it*, karoj kapi\it n\it*a i, komail japwilim a men en kadar karoj, kapi\it n\it*a i!
\q1 
\v 3 Koma katipin o jaunipo\it n\it*, kapi\it n\it*a i, o komail uju piripir karoj, kapi\it n\it*a i!
\q1 
\v 4 Komail la\it n\it* pokon, o pil komail pil akan pon ira pan la\it n\it*, kapi\it n\it*a i!
\q1 
\v 5 Irail en kapi\it n\it*a mar en Ieowa, pwe a me kotin pa\it n\it*ok, ap miala.
\q1 
\v 6 Ap kotiki o\it n\it* ir, ren mimieta kokolata, o kotiki o\it n\it* ir kujoned eu, me re jota pan kawela.
\q1 
\v 7 Toun jappa, kapi\it n\it*a Ieowa, walroj o man akan karoj, o pil en madau kan karoj.
\q1 
\v 8 O kijiniai, o akel, o jno, o tokoi, o melimel, me kin kaloki jili a kujoned akan.
\q1 
\v 9 Komail nana o dol akan karoj, tuka me wa mau o jeder karoj.
\q1 
\v 10 Man laualo o mand akan karoj, man korop o manpir akan.
\q1 
\v 11 Komail nanmarki en jappa o wei kan karoj, jaupeidi o jaunkadeik kan.
\q1 
\v 12 Manakap o peinekap, me ma o jeri kan.
\q1 
\v 13 Irail karoj en kapi\it n\it*a mar en Ieowa; pwe i eta mar, me lapalap, a manaman mi pon a\it n\it*in jappa o la\it n\it*.
\q1 
\v 14 A kotin jauaja oj en japwilim a kan. Japwilim a lelapok kan en kapi\it n\it*a i, kadaudok en Ijrael, iei wei, me kin upa i. Aleluia!
\c 149
\q1 
\v 1 KAULEKI kaul kap pot o\it n\it* Ieowa; pokon jaraui en kapi\it n\it*a i.
\q1 
\v 2 Ijrael en peren kida i, me kotin wia irail da; jeri en Jion en peren kida arail Nanmarki.
\q1 
\v 3 Ren kapi\it n\it*a mar a ni pwin en pokol; ren wia aip o arp.
\q1 
\v 4 Pwe Ieowa kotin peren kida japwilim a aramaj akan; a kotin kapwate kin me luet akan li\it n\it*an.
\q1 
\v 5 Lelapok kan en pereperen o kapi\it n\it*a, o \it n\it*iji\it n\it*ij pon ki arail akan.
\q1 
\v 6 Au arail en kapi\it n\it*a Kot, o kodlaj ko\it n\it* en mi nan pa arail.
\q1 
\v 7 Pwe ren depuk o\it n\it* men liki kan, o kaloke wei kan.
\q1 
\v 8 Pwen jalie kidi arail nanmarkikan jal, o me kajampwal re ’rail ki jal mata.
\q1 
\v 9 Pwe ren kapwaiada kalokolok, me kileledi on irail er maj o. Iduen wau en japwilim a lelapok kan. Aleluia!
\c 150
\q1 
\v 1 KAPI\it N\it*A Kot nan japwilim a tanpaj jaraui; kapi\it n\it*a i duen a manaman akan.
\q1 
\v 2 Kapi\it n\it*a i duen a wiawia kan; kapi\it n\it*a i ni a li\it n\it*an lapalap!
\q1 
\v 3 Kapi\it n\it*a i ki trompete; kapi\it n\it*a i ki arp o laute!
\q1 
\v 4 Kapi\it n\it*a i ki aip o pwin en pokol; kapi\it n\it*a i ki jal en kaja\it n\it* o pilote.
\q1 
\v 5 Kapi\it n\it*a i ki jimpel; kapi\it n\it*a i ki jimpel kajelel!
\q1 
\v 6 Karoj, me kin memaur, en kapi\it n\it*a leowa! Aleluia! 
