\p
\v 19 Te \w vaengah|strong="H9999"\w* \w Pathen|strong="H0430"\w* loh \w Lehi|strong="H3896"\w* \w ah|strong="H9996"\w* a \w khui|strong="H4388"\w* a \w vueh|strong="H1234"\w* pah \w tih|strong="H9999"\w* \w tui|strong="H4325"\w* a \w phuet|strong="H3318"\w* pah. Samson loh a \w ok|strong="H8354"\w* \w tih|strong="H9999"\w* a \w hil|strong="H7307"\w* a \w sang|strong="H7725"\w* \w daengah|strong="H9999"\w* ni a \w hing|strong="H2421"\w* pueng. \w Te|strong="H3651"\w* \w dongah|strong="H5921"\w* \w a|strong="H9907"\w* \w ming|strong="H8034"\w* te \w Enehakore|strong="H5875"\w* a \w sak|strong="H7121"\w* tih \w tihnin|strong="H3117"\w* \w duela|strong="H5704"\w* \w Lehi|strong="H3896"\w* \w ah|strong="H9996"\w* om.  
\v 20 \w Philisti|strong="H6430"\w* \w tue|strong="H3117"\w* \w vaengah|strong="H9996"\w* \w Israel|strong="H3478"\w* te \w kum|strong="H8141"\w* \w kul|strong="H6242"\w* lai a \w tloek|strong="H8199"\w* pah.   
\b  
\c 16  
\s1 Samson neh Delilah  
\p
\v 1 \w Samson|strong="H8123"\w* te \w Gaza|strong="H5804"\w* \w la|strong="H9911"\w* a \w caeh|strong="H1980"\w* \w vaengah|strong="H9999"\w* \w pumyoi|strong="H2185"\w* \w nu|strong="H0802"\w* a \w hmuh|strong="H7200"\w* \w hatah|strong="H9999"\w* \w a|strong="H9907"\w* \w taengla|strong="H0413"\w* a \w kun|strong="H0935"\w* thil.  
\v 2 \w Azzathi|strong="H5841"\w* rhoek loh, “\w Samson|strong="H8123"\w* \w he|strong="H2008"\w* la ha \w pawk|strong="H0935"\w* coeng,” a \w ti|strong="H0559"\w* uh. Te \w dongah|strong="H9999"\w* a \w vael|strong="H5437"\w* uh \w tih|strong="H9999"\w* \w khoyin|strong="H3915"\w* \w puet|strong="H3605"\w* \w khopuei|strong="H5892"\w* \w vongka|strong="H8179"\w* \w ah|strong="H9996"\w* \w rhongngol|strong="H0693"\w* uh. \w Khoyin|strong="H3915"\w* \w puet|strong="H3605"\w* te \w hil|strong="H2790"\w* a phah uh tih \w mincang|strong="H1242"\w* \w khothaih|strong="H0216"\w* \w hlanah|strong="H5704"\w* ng'\w ngawn|strong="H2026"\w* pawn ni,” a \w ti|strong="H0559"\w* uh.  
\v 3 \w Tedae|strong="H9999"\w* \w Samson|strong="H8123"\w* te \w khoyin|strong="H3915"\w* \w boengli|strong="H2677"\w* \w duela|strong="H5704"\w* \w yalh|strong="H7901"\w* \w tih|strong="H9999"\w* \w khoyin|strong="H3915"\w* \w boengli|strong="H2677"\w* \w ah|strong="H9996"\w* koep \w thoo|strong="H6965"\w*. Te \w vaengah|strong="H9999"\w* \w khopuei|strong="H5892"\w* \w vongka|strong="H8179"\w* kah \w thohkhaih|strong="H1817"\w* \w te|strong="H9996"\w* \w rhungsut|strong="H4201"\w* \w rhoi|strong="H8147"\w* \w neh|strong="H9999"\w* rhen a \w tuuk|strong="H0270"\w* \w tih|strong="H9999"\w* \w thohkalh|strong="H1280"\w* khaw a \w phil|strong="H5265"\w*. Te \w phoeiah|strong="H9999"\w* \w a|strong="H9909"\w* \w laengpang|strong="H3802"\w* \w ah|strong="H5921"\w* a \w tloeng|strong="H7760"\w* \w tih|strong="H9999"\w* \w Hebron|strong="H2275"\w* \w dan|strong="H6440"\w* kah \w tlang|strong="H2022"\w* \w som|strong="H7218"\w* \w la|strong="H0413"\w* a \w koh|strong="H5927"\w*.   
\p
\v 4 \w Te|strong="H3651"\w* tlam te a \w om|strong="H1961"\w* \w phoeiah|strong="H9999"\w* \w Sorek|strong="H7796"\w* \w soklong|strong="H5158"\w* \w kah|strong="H9996"\w* \w huta|strong="H0802"\w* pakhat, \w a|strong="H9907"\w* \w ming|strong="H8034"\w* ah \w Delilah|strong="H1807"\w* te a \w lungnah|strong="H0157"\w*.  
\v 5 Te \w vaengah|strong="H9999"\w* \w Delilah|strong="H9907"\w* \w te|strong="H0413"\w* \w Philisti|strong="H6430"\w* \w boei|strong="H5633"\w* rhoek loh a \w paan|strong="H5927"\w* uh \w tih|strong="H9999"\w*, “\w Anih|strong="H9909"\w* \w te|strong="H0853"\w* \w hloih|strong="H6601"\w* \w lamtah|strong="H9999"\w* \w ba|strong="H4100"\w* \w nen|strong="H9996"\w* lae a \w thadueng|strong="H3581"\w* a \w len|strong="H1419"\w* \w tih|strong="H9999"\w* \w ba|strong="H4100"\w* \w nen|strong="H9996"\w* lae \w anih|strong="H9909"\w* n'\w na|strong="H3201"\w* eh ti han \w so|strong="H7200"\w* laeh. Te \w vaengah|strong="H9999"\w* \w anih|strong="H9909"\w* \w phaep|strong="H6031"\w* \w ham|strong="H9997"\w* ka \w khit|strong="H0631"\w* \w uh saeh\w* \w lamtah|strong="H9999"\w* \w nang|strong="H9903"\w* \w te|strong="H9997"\w* \w kaimih|strong="H0587"\w* loh \w tangka|strong="H3701"\w* \w thawngkhat|strong="H0505"\w* \w yakhat|strong="H3967"\w* \w rhip|strong="H0376"\w* kam \w pae|strong="H5414"\w* uh eh,” a \w ti|strong="H0559"\w* nah.   
\p
\v 6 Te \w dongah|strong="H9999"\w* \w Samson|strong="H8123"\w* \w te|strong="H0413"\w* \w Delilah|strong="H1807"\w* loh, “\w Me|strong="H4100"\w* \w nen|strong="H9996"\w* lae \w na|strong="H9905"\w* \w thadueng|strong="H3581"\w* a \w len|strong="H1419"\w* \w tih|strong="H9999"\w* \w nang|strong="H9905"\w* \w phaep|strong="H6031"\w* \w ham|strong="H9997"\w* te \w ba|strong="H4100"\w* \w nen|strong="H9996"\w* lae ng'\w khih|strong="H0631"\w* eh \w tite|strong="H9912"\w* \w kai|strong="H9901"\w* \w taengah|strong="H9997"\w* \w bet|strong="H4994"\w* han \w thui|strong="H5046"\w* lah,” a \w ti|strong="H0559"\w* nah.   
\p
\v 7 \w Tedae|strong="H9999"\w* \w anih|strong="H9907"\w* \w te|strong="H0413"\w* \w Samson|strong="H8123"\w* loh, “\w Kai|strong="H9901"\w* he \w kuelrhui|strong="H3499"\w* aka \w rhae|strong="H2717"\w* \w pawh|strong="H3808"\w* a \w thingsup|strong="H3892"\w* \w yungrhih|strong="H7651"\w* \w nen|strong="H9996"\w* \w te|strong="H0834"\w* ng'\w khit|strong="H0631"\w* uh \w koinih|strong="H0518"\w* ka \w kha|strong="H2470"\w* sut \w vetih|strong="H9999"\w* \w hlang|strong="H0120"\w* \w mailai|strong="H0259"\w* \w banglam|strong="H9995"\w* ni ka \w om|strong="H1961"\w* eh?,” a \w ti|strong="H0559"\w* nah.   
\p
\v 8 Te \w dongah|strong="H9999"\w* \w Delilah|strong="H9907"\w* \w ham|strong="H9997"\w* \w Philisti|strong="H6430"\w* \w boei|strong="H5633"\w* rhoek te \w kuelrhui|strong="H3499"\w* aka \w rhae|strong="H2717"\w* \w pawh|strong="H3808"\w* \w yungrhih|strong="H7651"\w* \w te|strong="H0834"\w* a \w thingsup|strong="H3892"\w* la a \w khuen|strong="H5927"\w* pa uh \w tih|strong="H9999"\w* \w Samson|strong="H9909"\w* te a \w khih|strong="H0631"\w*.  
\v 9 \w Delilah|strong="H9907"\w* te \w imkhui|strong="H2315"\w* \w ah|strong="H9996"\w* a \w rhongngol|strong="H0693"\w* doela \w om|strong="H3427"\w* \w tih|strong="H9999"\w*, “\w Samson|strong="H8123"\w* \w nang|strong="H9905"\w* pum \w dongkah|strong="H5921"\w* \w Philisti|strong="H6430"\w* rhoek te,” a \w ti|strong="H0559"\w* nah \w hatah|strong="H9999"\w* \w hmai|strong="H0784"\w* loh a \w laeh|strong="H7306"\w* \w vaengkah|strong="H9996"\w* \w hamnak|strong="H6616"\w* \w rhui|strong="H5296"\w* a \w pat|strong="H5423"\w* \w bangla|strong="H0834"\w* \w kuelrhui|strong="H3499"\w* \w te|strong="H0853"\w* a \w bawt|strong="H5423"\w*. Te \w dongah|strong="H9999"\w* \w a|strong="H9909"\w* \w thadueng|strong="H3581"\w* te \w ming|strong="H3045"\w* uh \w pawh|strong="H3808"\w*.   
\p
\v 10 \w Tedae|strong="H9999"\w* \w Samson|strong="H8123"\w* \w te|strong="H0413"\w* \w Delilah|strong="H1807"\w* loh, “\w Kai|strong="H9901"\w* \w taengah|strong="H9996"\w* na \w omsaa|strong="H2048"\w* \w tih|strong="H9999"\w* \w kai|strong="H9901"\w* \w taengah|strong="H0413"\w* \w laithae|strong="H3577"\w* na \w thui|strong="H1696"\w* \w he|strong="H2009"\w*. \w Tahae|strong="H6258"\w* ah \w kai|strong="H9901"\w* \w ham|strong="H9997"\w* han \w thui|strong="H5046"\w* \w laeh|strong="H4994"\w*, \w ba|strong="H4100"\w* \w nen|strong="H9996"\w* lae ng'\w khih|strong="H0631"\w* eh?,” a \w ti|strong="H0559"\w* nah.   
