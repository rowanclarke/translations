\id ECC Ecclesiastes in Boko, Ross Jones 2/08
\h Làasoode
\toc1 Làasoode
\toc2 Làasoode
\toc3 Laa
\mt1 LÀASOODE
\imt1 Yã́ pↄ́ kú láɛ bee guuↄ
\ip Sɛa za lápi dↄ̀ↄ sɛ̃́iawa lápi kɛ̃na lɛ́ azĩa yã́ bↄↄlɛkɛwɛ̃ɛ lá á ↄ̃nↄ, ãma lápi ↄ̃nↄ yã́ↄ doũ ń Yáasi lá pↄ́oo. Aà ↄ̃nↄ doũ ń fɛlɛkaa pↄ́oo. Aà kua dṹnia guu à yã́ pↄ́ á kɛ̀ↄ ń yã́ pↄ́ a leↄ gwà, ↄ̃ a è nama dɛ lán suawaɛ, mɛ́ gbɛ̃nazĩna ì dɛ̃ɛka, kɛ́ à e namable yã́iɛ, ↄ̃ ìↄ bↄ pã mↄ̀ↄmↄↄ. À làasookɛ̀ azĩawa tó kua dṹniau dↄ̀ↄ vĩ, ge tó a bɛɛɛ vĩ. Ì to gbɛ̃́ pↄ́ lɛ́ lápi kyokɛↄ yã́ doũpiↄ wàaipa. Lá a ku Yobu lá guuwa, yãwea àao. Làasoode ń a ↄ̃nↄkɛo à bílikɛ̀ gbɛ̃nazĩna kuana yã́wa. Ɔ̃ à lɛdàwá wà zĩkɛ maamaa wà pↄnakɛ ń pↄ́ pↄ́ Lua wá gbáↄ e wá wɛ̃ni lɛ́u.
\ip Làasoode yã́ dasiↄ bↄ̀ yã́ↄ kpɛɛ, ì gbɛ̃́ kãdɛ. À zɛ̀ò kɛ́ dɛ̃ɛ pↄ́ wì ká ń pↄna pↄ́ wì e dṹnia guuoá yãpãɛ. Ɛ̀waasokɛ, ↄdekɛ, àizɛɛdekɛ, zĩkɛa, ↄ̃nↄkũa, yãkɛa a zɛ́wa, a dìlɛ yã́piiá pãɛ mɛ́ gugiiyaaɛ. Lá gbɛ̃nazĩnaↄ ìↄ ku ga lɛ́zĩ mɛ́ yã́zɛsai ku, bee tò nama líↄ kuo. Wìliↄ yã́ pↄ́ Lua lɛ́ yá ń dṹniao dↄ̃o, ↄ̃ bee tò wá gbɛ̃nazĩna zia gbá dↄ̃o. Yã́piↄ ì to wà làasookɛ zɛ́ pↄ́ maa wà sɛↄwa.
\ip Bibeli láↄ ì wá wɛ̃ni mi ↄlↄwɛ̃ɛ. A maa wà lápiↄ kyokɛ, wí e dↄ̃, wí bↄ seakɛa ń pↄyaao guu. A maa wà làasookɛ wá kua dṹniauwaɛ, wí zĩkɛ yã́ pↄ́ wa kɛ̃̀ Bibeliuwa, wí e Lua náaikɛ a zɛ́wa. Wɛdↄa Luazi mɛ́ a tó wá kua dṹniau àↄ dɛ gugiiyaa ũo.
\c 1
\s1 Yã́pii pãɛ
\p 
\v 1 Làasoode Davidi nɛ́, Yelusalɛũ kía yã́n kɛ:
\q1 
\v 2 Mámɛmaa Làasoode ma mɛ̀:
\q1 Yãpã búubuu,
\q1 yãpã búubuu, yã́pii pãɛ.
\q1 
\v 3 Bↄ́ ài gbɛ̃nazĩna ì e dṹniau
\q1 taasi pↄ́ àlɛ kɛ a zĩ píi guuwai?
\q1 
\v 4 Kpàiↄ ì gɛ̃, Wueↄ ì su,
\q1 ń beeo dṹnia ìↄ ku gↄↄpiiɛ.
\q1 
\v 5 Ĩatɛ̃ ì bilɛ ì gɛ̃ kpɛ́u,
\q1 ì wã à ɛa gɛ́ gu pↄ́ a bↄu.
\q1 
\v 6 Ĩana ì na gɛↄmidↄkĩi oi,
\q1 ì liaa su gugbãntoo oi,
\q1 ìↄ liaaliaa à gɛ́ le à su la.
\q1 
\v 7 Swa píi í ìↄ ka ísiauɛ,
\q1 kási ísia lí pao,
\q1 ípiↄ i ɛa su swapiↄ miwa.
\q1 
\v 8 Pↄ́pii ì ń kpasa,
\q1 kpasapi yã́ gɛ̃̀ oaa.
\q1 Gugwaa lí mↄ́ wɛ́wao,
\q1 yãmaa lí swã́ pao.
\q1 
\v 9 Yã́ pↄ́ kú yãa mɛ́ a ɛa àↄ ku lↄ,
\q1 yã́ pↄ́ wa kɛ̀ yãa ↄ̃ wa ɛa kɛ lↄ.
\q1 A dafue ku dṹniauo.
\q1 
\v 10 Pↄe ku kɛ́ wà mɛ:
\q1 Pↄ́ dafue gwaa?
\q1 Aawo! À dↄ̀aa kú wá ãa za zi kↄ̀.
\q1 
\v 11 Gbɛ̃́ káauↄ yã́ líↄ dↄ gbɛ̃egu lↄo.
\q1 Baa gbɛ̃́ pↄ́ aaↄ ku ziaↄ,
\q1 an yã́ a dↄ gbɛ̃egu gbɛzão.
\m 
\v 12 Ma làasoode ma kɛ Isailiↄ kía ũ Yelusalɛũ.
\v 13 Ma mɛkpà yã́ pↄ́ wàlɛ kɛ dṹniau píi tàasikaawa, má yↄ̀ɛ ↄ̃nↄ'ↄ̃nↄ, má è Lua zĩ pãsĩ dà gbɛ̃nazĩnaↄnɛ aa kɛ.
\v 14 Ma yã́ pↄ́ wàlɛ kɛ dṹniau è píi, a píiá pãɛ mɛ́ gugiiyaaɛ.
\q1 
\v 15 Pↄ́ fĩaa pooa vĩo,
\q1 wìli e pↄ́ pↄ́ kɛ̃̀sã nào ń a kĩniↄo.
\m 
\v 16 Ɔ̃ má ò ma nↄ̀sɛu ma mɛ̀: Gwa! Ma ↄ̃nↄ zↄ̃ↄ dɛ gbɛ̃́ pↄ́ kpalablè Yelusalɛũ ma ãaↄla píi, ma ↄ̃nↄ ń ma dↄ̃ao wɛbↄ̀ maamaaɛ.\f + \fr 1.16 \ft 1Kia 5.9-11, 10.23-24\f*
\v 17 Ɔ̃ ma mɛkpà ↄ̃nↄ asii dↄ̃awa mà sↄũkɛ ń mìsaiyão asii dↄ̃, ↄ̃ má è beeá gugiiyaaɛ lↄ.
\q1 
\v 18 Asa ↄ̃nↄ zↄ̃ↄ ì mↄ́ ń pↄyaa zↄ̃ↄoɛ,
\q1 mɛ́ wì yã'ↄ̃ma e ń dↄ̃a lɛ́uɛ.
\c 2
\s1 Pↄnakɛaá pãɛ
\p 
\v 1 Má ò mazĩawa mà fɛlɛ mà pↄnakɛa lɛ́ gwa, mí namablea dↄ̃, ↄ̃ má è beeá pãɛ lↄ.
\v 2 Má è yaalↄá sↄũkɛɛ. Pↄnakɛa sↄ̃, bↄ́ ì inɛ́i?
\v 3 Ma pↄna wɛ̀ɛlɛ vɛ̃ɛmia guu, ma ↄlìa mìsaiyãi, ãma ma làasoo lɛ́ tamanↄ ↄ̃nↄwa, kɛ́ mà yã́ pↄ́ maa gbɛ̃nazĩna lí kɛ dṹnia guu a wɛ̃ni kpòona lɛ́u dↄ̃.
\p 
\v 4 Ma ↄkpà zĩ zↄ̃ↄↄwa, ma kpɛdↄ̀dↄ mazĩaɛ, ma vɛ̃ɛliↄ pɛ̀pɛ kpɛ́lɛkpɛlɛ.
\v 5 Ma kaaↄ dàda, ma swa saɛↄ kɛ̀kɛ, ma lí pↄ́ wì a bɛ ble bui píi bàbau.
\v 6 Ma íkalɛkĩiↄ kɛ̀kɛ aaↄ mↄ̀sɛpisi líkpɛpiↄwa.
\v 7 Ma zↄↄ lùlu gↄ̃ɛↄ ń nↄɛↄ, mɛ́ wà ń keeↄ ì ma bɛɛ. Má zuↄ ń pↄtuo keleↄ vĩ dasidasi dɛ gbɛ̃́ pↄ́ kú Yelusalɛũ ma ãaↄla píi.\f + \fr 2.7 \ft 1Kia 5.2-3\f*
\v 8 Ma ã́nusu ń vuao kã̀aamazi ń kíaↄ àizɛɛↄ ń ń bùsu pↄ́ↄ.\f + \fr 2.8 \ft 1Kia 10.14-27\f* Ma lɛ̀sinaↄ sɛ̀ gↄ̃ɛↄ ń nↄɛↄ, ma nↄ pↄ́ gↄ̃ɛ ì luaiↄ sɛ̀ dasi.
\v 9 Ma tↄbↄ̀, ma zↄ̃ↄ dɛ gbɛ̃́ pↄ́ kú Yelusalɛũ ma ãaↄla píi, mɛ́ ma gi má ↄ̃nↄ apii guu.
\q1 
\v 10 Mi gi mazĩaɛ ń pↄ́ pↄ́ ma wɛ́ blèoo.
\q1 Mi pↄ́ pↄ́ ma pↄ gbàe to weo.
\q1 Ma pↄ kɛ̀na ma zĩkɛa píiwa,
\q1 ↄ̃mɛ ma isimagakpaa píi asea ũ.
\q1 
\v 11 Kɛ́ ma wɛtɛ̀ yã́ pↄ́ má kɛ̀ↄzi píi
\q1 ń isima pↄ́ má gà má kpà a musuo,
\q1 má è apii pãɛ mɛ́ gugiiyaaɛ,
\q1 a ài vĩ dṹniauo.
\q1 
\v 12 Ɔ̃ ma làasoo tà ↄ̃nↄ ń sↄũkɛo ń mìsaikɛowa.
\q1 Yã́ pↄ́ wa kɛ̀ za zi bàasio,
\q1 a kpele kí gɛ̃ɛ a kɛ lↄi?
\q1 
\v 13 Má è ↄ̃nↄ ài vĩ dɛ mìsaikɛa
\q1 lá gupua ìↄ ài vĩ dɛ gusiaawa.
\q1 
\v 14 Ɔ̃nↄna wɛ́ ìↄ ku aà aɛ,
\q1 sↄũ ìↄ bɛ gusiau.
\q1 Ɔ̃ má è gó doũ mɛ́ a ń bua ḿpii.
\q1 
\v 15 Ɔ̃ ma làasookɛ̀ ma sↄ̃u ma mɛ̀:
\q1 Lá gó doũ mɛ́ a wá bua ń sↄũↄ,
\q1 bↄ́ ài má e ma ↄ̃nↄwai?
\q1 Ɔ̃ ma mɛ̀: Beeá yãpãɛ lↄ.
\q1 
\v 16 Ɔ̃nↄna yã́ a dↄ gbɛ̃egu dɛ sↄũao,
\q1 ampii an yã́ a sã gbɛ̃́ↄgu zia.
\q1 Ɔ̃nↄna ì ga lán sↄũwaɛ.
\s1 Isimagakpaaá pãɛ
\p 
\v 17 Ɔ̃ ma sakà ma kuau, asa yã́ pↄ́ wàlɛ kɛ dṹniau píi ì kɛmɛɛ yã'ↄ̃ma ũɛ. Apii pãɛ mɛ́ gugiiyaaɛ.
\v 18 Ɔ̃ ma sakà zĩ pↄ́ má kɛ̀ dṹniauↄgu píi, kɛ́ má tó ma gɛ̃ɛɛ yã́i.
\v 19 Démɛ dↄ̃ tó ↄ̃nↄna ge sↄũn aà ũi? Kásile zĩ pↄ́ má kɛ̀ dṹniau ń ↄ̃nↄo a gↄ̃ɛ̀ɛ. Beeá pãɛ lↄ.
\v 20 Ɔ̃ ma pↄ yà isima pↄ́ má gà má kpà dṹniau píi yã́ musu.
\v 21 Asa gbɛ̃́ ì zĩkɛ ń ↄ̃nↄo ń dↄ̃ao ń gↄ̃io, ↄ̃ ì to gbɛ̃́ pↄ́ i a kee kɛoɛ a pↄ́ ũ. Beeá pãɛ lↄ, yãvãiɛ maamaa.
\v 22 Bↄ́ gbɛ̃́ ì e isima pↄ́ a ga kpà dṹniau ń dɛ̃ɛ pↄ́ a kào píi yã́ musui?
\v 23 Aà kua dṹniau gↄↄpii aà zĩ ì mↄɛ̀ ń yã'ↄ̃mao ń pↄyaaoɛ.\f + \fr 2.23 \ft Yob 14.1\f* Baa gwã́ aà nↄ̀sɛ lí dadoũo. Beeá pãɛ lↄ.
\p 
\v 24 Yã́ pↄ́ maa ń gbɛ̃nazĩnao mɛ́ dɛ aà pↄble, aà imi, aà a zĩ sáaukpa.\f + \fr 2.24 \ft Isa 56.12, Luk 12.19, 1Kln 15.32\f* Má è bee bↄ̀ Lua ↄzĩɛ lↄ.
\v 25 Lua dↄnlɛ sai démɛ a fↄ̃ pↄble à pↄnakɛi?
\v 26 Lua ì gbɛ̃́ pↄ́ kàagu gba ↄ̃nↄ ń dↄ̃ao ń pↄnao,\f + \fr 2.26 \ft Yob 32.8, Yaa 2.6\f* ãma Lua ì àizɛɛsɛlɛkãaaa zĩda duunkɛnaɛ, kɛ́ à kpa gbɛ̃́ pↄ́ kàaguwa. Beeá pãɛ lↄ mɛ́ gugiiyaaɛ.
\c 3
\s1 Yã́pii ń a gↄↄoɛ
\q1 
\v 1 Yã́pii ń a gↄↄoɛ,
\q1 bↄↄlɛ píi ń a kɛgↄↄo.
\q1 
\v 2 Nɛ'igↄↄ ku, gagↄↄ ku,
\q1 pↄ́tↄ̃gↄↄ ku, a wolɛgↄↄ ku.
\q1 
\v 3 Dɛgↄↄ ku, gbã́gbãgↄↄ ku,
\q1 gboogↄↄ ku, a dↄgↄↄ ku.
\q1 
\v 4 Ɔↄlↄgↄↄ ku, yaalↄgↄↄ ku,
\q1 wɛ̃nakɛgↄↄ ku, kↄ̃̀ↄ'ogↄↄ ku.
\q1 
\v 5 Gbɛkↄlɛgↄↄ ku, gbɛkãaagↄↄ ku,
\q1 bↄ̃̀nↄblegↄↄ ku, a zɛgↄↄ ku.
\q1 
\v 6 Pↄwɛɛlɛgↄↄ ku, a ↄkpaigↄↄ ku,
\q1 ↄdidia pↄ́wa gↄↄ ku, a gbaɛa gↄↄ ku.
\q1 
\v 7 Pↄ́gakɛ̃gↄↄ ku, a namigↄↄ ku,
\q1 lɛkpaaũgↄↄ ku, yã'ogↄↄ ku.
\q1 
\v 8 Yenzigↄↄ ku, zangugↄↄ ku,
\q1 zĩkagↄↄ ku, kálɛa aafia gↄↄ ku.
\m 
\v 9 Bↄ́ ài zĩkɛna ì e taasi pↄ́ a kɛ̀wai?
\v 10 Ma zĩ pↄ́ Lua dà gbɛ̃nazĩnaↄnɛ aa kɛ è.
\v 11 Lua tò pↄ́pii maa a gↄↄwa. À kua gↄↄpii làasoo dà gbɛ̃nazĩna sↄ̃u lↄ, kási a fↄ̃ yã́ pↄ́ Lua lɛ́ kɛ za dṹnia daalɛa e a midɛawa gbadↄ̃o.
\v 12 Má dↄ̃ kɛ́ pↄe maa ń gbɛ̃nazĩnao dɛ aà kua pↄna guu ń maakɛao aà wɛ̃ni lɛ́ulao.
\v 13 Tó gbɛ̃́ lɛ́ pↄble, àlɛ imi, àlɛ a zĩ píi sáaukpa, Lua mɛ́ aà gbà.
\v 14 Má dↄ̃ kɛ́ yã́ pↄ́ Lua lɛ́ kɛ aↄ ku gↄↄpiiɛ. Wa fↄ̃ pↄe kã́fĩuo, mɛ́ wa fↄ̃ pↄe laouo. Lua kɛ̀ màa, kɛ́ wàↄ a vĩa vĩ yã́iɛ.
\v 15 Pↄ́ pↄ́ kú tia ku za zi kↄ̀, mɛ́ pↄ́ pↄ́ aↄ ku zia ku yãa lↄ. Lua ì yã́ pↄ́ kɛ̀ yãaↄ gbɛsisi.
\p 
\v 16 Ma yã́ è dṹniau lↄ:
\q1 Gu pↄ́ dɛ yã́zɛde àↄ kuu,
\q1 yã́zɛsai mɛ́ kú we,
\q1 mɛ́ gu pↄ́ dɛ yãmaa àↄ kuu,
\q1 yãvãi mɛ́ kú we.
\q1 
\v 17 Má ò mazĩawa:
\q1 Lua a yã́kpalɛkɛ ń gbɛ̃maaↄ ń gbɛ̃vãiↄ píi,
\q1 asa yã́pii ń a gↄↄoɛ,
\q1 bↄↄlɛ píi ń a kɛgↄↄo.
\p 
\v 18 Má ò ma sↄ̃ guu lↄ: Gbɛ̃nazĩnaↄ ì kɛ màa, Lua a ń yã́wɛ wɛ̃nɛ́, aai dↄ̃ ńzĩawa wa dɛ lán nↄ̀bↄↄwaɛ.
\v 19 Sĩanaɛ, gbɛ̃nazĩnaↄ ń nↄ̀bↄↄ, gó doũ mɛ́ a ń bua. Lá nↄ̀bↄ ì ga, màa gbɛ̃nazĩna ì ga lↄ, an wea doũɛ. Gbɛ̃nazĩna dɛ nↄ̀bↄlao, asa yã́pii pãɛ.
\v 20 Ampii aaì gɛ́ gudoũ, asa ampii aa bↄ̀ bùsutiuɛ, mɛ́ ampii aa ɛa gↄ̃ bùsutipi ũɛ.
\v 21 Tó gbɛ̃nazĩna nisĩna ì ta musu, nↄ̀bↄ pↄ́ ì ta zĩ́lɛn lò, démɛ dↄ̃i?
\v 22 A yã́i tò má è yãe maa ń gbɛ̃nazĩnao dɛ aà a zĩ sáaukpalao, asa aà luakpaman we. Démɛ a to aà dↄ̃ yã́ pↄ́ a mↄ aà kpɛi?
\c 4
\s1 Kua ń kↄ̃o
\p 
\v 1 Ɔ̃ ma gbãa pↄ́ wàlɛ mↄ gbɛ̃́ↄnɛ dṹniau yã́ gwà lↄ píi. Ma gbɛ̃́ pↄ́ wàlɛ ń wɛtãↄ wɛ́'i è, aa nↄ̀sɛninina vĩo. Aa nↄ̀sɛninina vĩo, asa an wɛtãnapiↄ mɛ́ gbãa vĩ.
\v 2 Ɔ̃ ma mɛ̀, gbɛ̃́ pↄ́ gà yãaↄ Lua sáaukɛ̀ dɛ gbɛ̃́ pↄ́ kúↄla,
\v 3 ãma gbɛ̃́ pↄ́ wi i yãao, i wɛsi vãi pↄ́ wì kɛ dṹniaulɛo sã̀ↄmá ḿpii.
\v 4 Má è pↄ́ pↄ́ tò gbɛ̃́ ì zĩkɛ à mɛkpawà, kɛ́ à e àↄ dɛ a gbɛ̃́deela yã́iɛ. Beeá pãɛ lↄ mɛ́ gugiiyaaɛ.
\q1 
\v 5 Sↄũ ì a ↄ kpaaũ à ibaba.
\q1 
\v 6 Kua ń pↄ́ ↄkũ doo ń sↄ̃daadoũo
\q1 maa dɛ kua ń pↄ́ ↄkũ plao
\q1 ń isimagakpaao ń gugiiyaaola.
\m 
\v 7 Ɔ̃ ma ɛa yãpã pãle è dṹnia guu lↄ.
\v 8 Zĩ̀loe ku, a nɛ́ vĩo, a vĩ̀i ge dãuna vĩo. Aà isima lí bao, kási aà àizɛɛ lí mↄ́wào. Dé yã́i àlɛ zĩkɛii? Bↄ́yãi à pↄnakɛa tɛ̃̀ azĩaɛi? Beeá pãɛ lↄ, bↄↄlɛ pãsĩɛ.
\q1 
\v 9 Plaa dɛ doũa,
\q1 asa an taasi ài aↄ maa.
\q1 
\v 10 Tó gbɛ̃do lɛ̀lɛ, aà gbɛ̃do a aà sɛ́.
\q1 Waiyoo gbɛ̃doũna!
\q1 Tó à lɛ̀lɛ, aↄ sɛna vĩo.
\q1 
\v 11 Tó gbɛ̃ↄn plaↄ wúlɛa gudoũ,
\q1 aa kↄ̃ pusu ma.
\q1 Kpelewa gbɛ̃doũna a bↄ ĩ́ana yã́ui?
\q1 
\v 12 Wì gbãamↄ gbɛ̃doũnaɛɛ,
\q1 gbɛ̃ↄn plaↄ sↄ̃ aaì zɛ wà giɛ.
\q1 Bà nian àaↄ̃ lí kɛ̃́ kpaao.
\m 
\v 13 Ɛ̀waaso ↄ̃nↄna taaside maa dɛ kía zi sↄũ pↄ́ lí lɛdama ma lↄola,
\v 14 baa tó ɛ̀waasopi bↄ̀ dakpɛunakɛ guu ↄ̃ à gↄ̃̀ kía ũ, ge wà aà ì bùsupiu táaa ũn lò.
\v 15 Má è dṹnia a tɛ kí gɛ̃ɛ ɛ̀waasopizi,
\v 16 gↄↄ bee aà gbɛ̃́ↄ aaↄ lɛ́ vĩo, gbɛ̃́ pↄ́ a dɛ ń dↄaana ũↄ. Ń beeo gbɛ̃́ pↄ́ aa mↄ gbɛzãↄ aa aà sáaukpao. Beeá pãɛ lↄ mɛ́ gugiiyaaɛ.
\s1 Vĩakɛa Luaɛ
\p 
\v 17 Tó n gɛ Lua kpɛ́u, ǹyↄ̃ kú ń laaio. Sↄ̃aaàzi ǹ aà yãma maa dɛ sↄũↄ sa'oa wea, asa an yãdↄ̃sai mɛ́ ì to aa yãvãikɛ.
\c 5
\p 
\v 1 N lɛ́ su àↄ wãao, ńsu nↄnwãakɛ ǹ yã'o Lua aɛo. Lá a ku musu mɛ́ ń kú zĩ́lɛ, ńsu yã'o dasio.
\v 2 Lá bↄↄlɛ dasi ì mↄ́ ń nana'oao, màa yã́ dasi bↄlɛa ì mↄ́ ń sↄũyã'oo.
\v 3 Tó n lɛkɛ̀ Luawa,\f + \fr 5.3 \ft Soũ 66.13-14\f* ńsu ǹ a fĩaboa gágao. Ǹ a fĩabo, asa sↄũↄ yã́ lí kaaàguo.
\v 4 Lɛkɛa Luawa sai maa dɛ a kɛawà fĩabosaia.
\v 5 Ńsu to n lɛ́ n dayãuo. Ńsu o sa'onaɛ n zã lɛkɛawaɛo. Ń ye Lua pↄ panzi n yã́pi yã́i, i zĩ pↄ́ ńlɛ kɛ bãdɛ yã̀?
\v 6 Nana dasi oa ń yã́ dasi bↄlɛao ì mↄ́ ń yãpão. A yã́i tò ǹyↄ̃ Lua vĩa vĩ.
\s1 Àizɛɛá pãɛ
\p 
\v 7 Tó ń è wàlɛ gbãamↄ taasideↄnɛ guei, wàlɛ gínɛ́ ń yã́zɛdeo, wàlɛ yã́gↄ̃gↄ̃nɛ́ a zɛ́wao, ńsu to yã́pi dimao, asa bùsupi gbãadeↄ lɛ́ wɛ́tɛkↄ̃iɛ, mɛ́ an gbɛ̃zↄ̃ↄↄ lɛ́ wɛ́tɛńzi lↄ.
\v 8 Ampii aaì bùsupi baa bleɛ, asa kía mɛ́ buaↄ vĩ.
\q1 
\v 9 Gbɛ̃́ pↄ́ ye ↄ̃ai lí kã́òo,
\q1 gbɛ̃́ pↄ́ ye àizɛɛi ài lí mↄ́wào.
\q1 Beeá pãɛ lↄ.
\q1 
\v 10 Tó àizɛɛ lɛ́ kã́fĩ,
\q1 a blenaↄ ìↄ kã́fĩɛ.
\q1 Bↄ́ ài a vĩ a diiɛi?
\q1 Aà wɛbiiwà bàasio.
\q1 
\v 11 Zĩgbãakɛna ì i na ma,
\q1 à pↄblè yↄↄ ge maamaan nò.
\q1 Ɔde sↄ̃, aà kãa lí tó à i'oo.
\q1 
\v 12 Ma yãvãi pãsĩ è dṹniau,
\q1 gbɛ̃e zɛtà a ↄdalɛ,
\q1 à azĩa kpà ĩai,
\q1 
\v 13 ↄ̃ à bↄↄlɛ vãi kɛ̀ò,
\q1 aà àizɛɛ mìdɛ píi.
\q1 Kɛ́ à nɛgↄ̃ɛ ì, a pↄe vĩ à toɛ̀ lↄo.
\q1 
\v 14 Gbɛ̃nazĩna ì bↄ a da gbɛɛu puiziɛ.
\q1 Lá à mↄ̀, màa ì ɛa ta lↄ,
\q1 ìli a zĩ àie e sɛ nà a ↄzĩ à tàòo.\f + \fr 5.14 \ft Yob 1.21, Soũ 49.17-18, 1Tim 6.7\f*
\q1 
\v 15 Yã́ɛ beeá yãvãi pãsĩɛ lↄ.
\q1 Lá gbɛ̃́ mↄ̀, màa ì ɛa ta lↄ.
\q1 À isima ga kpà, à gugiiyàɛ,
\q1 bↄ́mɛ gↄ̃̀ɛ̀i?
\q1 
\v 16 Bee gbɛa à a gↄↄ mↄaokɛ̀ gusiau
\q1 ń pↄyaa zↄ̃ↄo ń gyão ń pↄfɛ̃o.
\p 
\v 17 Ɔ̃ má è a maa ń gbɛ̃nazĩnao aà pↄble, aà imi, aà zĩ pↄ́ a kɛ̀ ń taasio dṹniau a wɛ̃ni kpòona pↄ́ Lua aà gbà lɛ́u sáaukpa, asa aà luakpaman we.
\v 18 Bee gbɛa tó Lua gbɛ̃́ kà ↄdawa ń àizɛɛo, mɛ́ à aà gbà zɛ́ aà pↄnakɛò, aà zɛ ń a luakpamao, aà a zĩ sáaukpa. Lua mɛ́ aà gbà.
\v 19 Ìliↄ làasookɛ a wɛ̃ni gesenawa mↄ̀ↄmↄↄ lↄo, asa Lua mɛ́ yãmàwà ń pↄnao.
\c 6
\p 
\v 1 Ma vãi è dṹnia guu lↄ, à tↄ̃̀ gbɛ̃nazĩnaↄwa.
\v 2 Lua gbɛ̃́ kà ↄdawa, à aà gbà àizɛɛ ń bɛɛɛo, a pↄ́ pↄ́ dɛ àↄ a ni vĩ píi vĩ, ↄ̃ Lua i to à pↄnakɛ̀òo, gbɛ̃pãle mɛ́ gↄ̃̀ vĩ. Beeá pãɛ, yãvãi pãsĩɛ.
\p 
\v 3 Tó gbɛ̃́ nɛ'ì mɛ̀n basↄo mɛ́ à zikũ̀ táotao, baa ń aà gɛ̃gɛ̃akɛo, tó i e pↄnakɛ̀ a guuo, tó à gà mɛ́ aà vĩa kpɛlaao, nɛ́ pↄ́ wa ì gɛ̀ sã̀ↄwà.
\v 4 Asa nɛ́pi mↄ̀ pãɛ, ↄ̃ à tà gusiau, aà tↄ́ gↄ̃̀ balau.
\v 5 Baa kɛ́ i ĩatɛ̃ eo mɛ́ a yãe dↄ̃o, à niɛ è dɛ ↄdepia.
\v 6 A dɛ gbɛ̃́ pↄ́ kú wɛ̃̀ ↄ̀aa kwi pↄnakɛsaila. Aali gɛ́ gudoũ ḿpiio lé?
\q1 
\v 7 Gbɛ̃nazĩna isima pↄ́ a gà lɛ́ kpá,
\q1 à pↄ́ e da lɛ́ɛ yã́ɛ,
\q1 kási aà gbɛɛ lí kã́o.
\q1 
\v 8 Bↄ́ ↄ̃nↄna dɛò sↄũai?
\q1 Bↄ́ ài yãkɛa a zɛ́wa ì i taasideɛi?
\q1 
\v 9 Pↄnakɛa ń pↄ́ pↄ́ ń vĩo
\q1 maa dɛ a pãle nidɛaa.
\q1 Beeá pãɛ lↄ mɛ́ gugiiyaaɛ.
\q1 
\v 10 Pↄ́ pↄ́ kɛ̀ yãa tↄ́ vĩ kↄ̀,
\q1 mɛ́ wa dↄ̃ lá gbɛ̃nazĩna dɛ.
\q1 Gbɛ̃nazĩna a fↄ̃ lɛkpaakɛ
\q1 ń gbɛ̃́ pↄ́ a gbãa dɛalaoo.
\q1 
\v 11 Yãbↄlɛ dasi ì yãpã kↄ̃́.
\q1 Bↄ́ ài bee vĩ gbɛ̃́ɛi?
\m 
\v 12 Démɛ dↄ̃ pↄ́ pↄ́ maa ń gbɛ̃nazĩnao aà wɛ̃ni gii kpòona pↄ́ ì gɛ̃ lán uenawa guui? Démɛ a fↄ̃ yã́ pↄ́ a kɛ aà kpɛ dṹnia guu oɛ̀i?
\c 7
\s1 Ɔ̃nↄdaanɛ́
\q1 
\v 1 Tↄ́ na maa dɛ tulale bɛɛɛdea,\f + \fr 7.1 \ft Yaa 22.1\f*
\q1 mɛ́ gagↄↄ maa dɛ igↄↄa.
\q1 
\v 2 Gɛ̃a ua pↄ́ wàlɛ gɛwiipɛu maa
\q1 dɛ gɛ̃a ua pↄ́ wàlɛ dikpɛkɛula,
\q1 asa gbɛ̃́pii midɛan we,
\q1 mɛ́ a maa gbɛ̃́ pↄ́ kúↄ yã́pi da.
\q1 
\v 3 Wɛ̃nakɛa maa dɛ yáalↄaa,
\q1 oosisia gbɛa nↄ̀sɛ ì wee.
\q1 
\v 4 Ɔ̃nↄna laai ìↄ ku ua pↄ́ wàlɛ ↄ́ↄlↄuwa.
\q1 Sↄũ laai ìↄ ku ua pↄ́ wàlɛ pↄnakɛuwaɛ.
\q1 
\v 5 Ɔ̃nↄna n lelea yãdaa maa dɛ
\q1 swã́sɛa sↄũ n táasilɛaia,
\q1 
\v 6 asa sↄũↄ yaalↄ dɛ
\q1 lán kù tɛ́ pũnaa kĩnauwaɛ.
\q1 Beeá pãɛ lↄ.
\q1 
\v 7 Gbãa mↄa gbɛ̃́ↄnɛ ì to ↄ̃nↄna sↄũkũɛ,
\q1 mɛ́ gbagusaɛ ì gbɛ̃́ ↄ̃̀ↄkpaɛ.
\q1 
\v 8 Yã́ midɛa maa dɛ a fɛlɛaa,
\q1 sùuu maa dɛ kàamaia.
\q1 
\v 9 Ńsu to n pↄ lí pa àao,\f + \fr 7.9 \ft Zaa 1.19\f*
\q1 asa sↄũ mɛ́ ìↄ pↄfɛ̃ vĩ.
\q1 
\v 10 Ńsu yãgbɛa ǹ mɛ
\q1 bↄ́yãi yãagↄↄ maa dɛ tiaaio,
\q1 asa yãlaa bee taaá ↄ̃nↄyã no.
\q1 
\v 11 Ɔ̃nↄá pↄmaaɛ lán túbiwa,
\q1 a ài vĩ gbɛ̃́ pↄ́ lɛ́ ĩatɛ̃ eↄnɛ píi.
\q1 
\v 12 Ɔ̃nↄá kpanziɛɛ,
\q1 lá ↄ̃a dɛ kpanziɛ ũwa,
\q1 mɛ́ dↄ̃a àin kɛ:
\q1 Ɔ̃nↄnaↄ ↄ̃nↄ ì ń misi.
\q1 
\v 13 Làasookɛ Lua yãkɛaↄwa.
\q1 Démɛ a fↄ̃ pↄ́ pↄ́ a kɛ̀ kolea pooi?
\q1 
\v 14 Tó gↄↄ na mↄ̀ma, pↄnakɛò.
\q1 Tó gↄↄ vãiɛ sↄ̃, làasookɛ,
\q1 Lua mɛ́ kɛ̀ píi, kɛ́ gbɛ̃e su àↄ a zia dↄ̃o yã́i.
\q1 
\v 15 Ma wɛ̃ni giiɛ bee guu ma yã́ɛ beeↄ è píi.
\q1 Ma gbɛ̃maa è à gà a maakɛa guu,
\q1 mɛ́ ma gbɛ̃vãi è àlɛ gɛ̃gɛ̃ a yãvãikɛa guu.
\q1 
\v 16 Ńsu to n maakɛa gɛ̃agɛ̃o,
\q1 ńsu to n ↄ̃nↄ gɛ̃agɛ̃o.
\q1 Bↄ́yãi ńyↄ̃ yã́yia nzĩawai?
\q1 
\v 17 N vãi su gɛ̃agɛ̃o,
\q1 ńsu ǹyↄ̃ sↄũo.
\q1 Bↄ́yãi ńyↄ̃ ga kpóoi?
\q1 
\v 18 A maa ǹyↄ̃ yã́ mɛ̀n plapiↄ kũaɛ,
\q1 ńsu ↄkpaio,
\q1 asa gbɛ̃́ pↄ́ Lua vĩa vĩ ì yã́piↄ zɛ́ e píiɛ.
\q1 
\v 19 Ɔ̃nↄ ì to ↄ̃nↄna gbãa àↄ dɛ
\q1 wɛ̃́lɛ gbãade gbɛ̃ↄn kwiↄla.
\q1 
\v 20 Gbɛ̃maa pↄ́ ìↄ yãmaakɛ
\q1 mɛ́ ìli duunakɛo ku dṹniauo.
\q1 
\v 21 Ńsu swã́sɛ yã́ pↄ́ wàlɛ ozi píio,
\q1 kɛ́ tó n zĩkɛna lɛ́ n ká, ńsu mao yã́i.
\q1 
\v 22 Asa ń dↄ̃ nzĩawa,
\q1 kɛ́ mpi sↄ̃ n gbɛ̃́ↄ kà dasi.
\q1 
\v 23 Ma wɛtɛ̀ yã́ beeↄi ↄ̃nↄ'ↄ̃nↄ píi,
\q1 ma mɛ̀ má ↄ̃nↄkũ, ↄ̃ à zã̀kũmanↄ.
\q1 
\v 24 Ɔ̃nↄ kúkĩi zã̀,
\q1 a asii zↄ̃ↄ maamaaɛ,
\q1 démɛ a fↄ̃ bↄwài?
\q1 
\v 25 Ma ↄ̃nↄ ń yã́pii mio tàasikà,
\q1 má yↄ̀ɛ kɛ́ mà e dↄ̃,
\q1 mí yãvãikɛa dↄ̃ sↄũkɛ ũ,
\q1 mí sↄũkɛ dↄ̃ mìsaikɛ ũ.
\q1 
\v 26 Má è nↄɛ pↄ́ dɛ bai ũ,
\q1 aà sↄ̃á mↄmusunaɛ,
\q1 mɛ́ aà ↄↄá mↄdaonaɛ,
\q1 aà yã́ ì ma pↄ ya dɛ gaa.
\q1 Gbɛ̃́ pↄ́ a yã́ kà Luagu ì pili nↄɛpiwa,
\q1 ãma nↄɛpi ì duunkɛna kũɛ.
\q1 
\v 27 Mámɛmaa Làasoode ma mɛ̀:
\q1 Yã́ pↄ́ ma bↄwà gwa.
\q1 Kɛ́ málɛ yã́ gwa zɛ́zɛ mà e a midↄ̃,
\q1 
\v 28 gↄↄ pↄ́ málɛ wɛɛlɛ málɛ eo,
\q1 ma gↄ̃ɛ bɛɛɛde è mɛ̀ndo gbɛ̃ↄn ↄ̀aa sↄoↄ guu,
\q1 ãma baa mɛ̀ndo mi nↄɛ bɛɛɛde e ń guuo.
\q1 
\v 29 Yã́ pↄ́ ma bↄwàn kɛ:
\q1 Lua gbɛ̃nazĩnaↄ kɛ̀ nↄ̀sɛpuadeↄ ũɛ,
\q1 ↄ̃ aa pɛ̀lɛpɛlɛ kↄ̃ni zɛ́u.
\c 8
\q1 
\v 1 Démɛ dɛ lán ↄ̃nↄnawai?
\q1 Démɛ yã́ↄ bↄↄlɛ dↄ̃i?
\q1 Ɔ̃nↄ ì gbɛ̃nazĩna oa weeɛ̀,
\q1 ì oa pãsĩ lilɛ.
\q1 
\v 2 Misiilɛ kía yã́ɛ,
\q1 asa n lɛkɛ̀wà ń Lua tↄ́oɛ.
\q1 
\v 3 Ńsu wã ǹ go aà aɛo,
\q1 ńsu ǹyↄ̃ yã́ pↄ́ lɛ́ kɛɛ̀ ĩ́i kṹkũao,
\q1 asa a yã́ pↄ́ kàagu kɛ píiɛ.
\q1 
\v 4 Lá kía yã́ mɛ́ zɛvĩ,
\q1 démɛ a fↄ̃ oɛ̀, bↄ́ ńlɛ kɛ weii?
\q1 
\v 5 Gbɛ̃́ pↄ́ misìilɛɛ̀ a ĩa eo,
\q1 gbɛ̃́ pↄ́ ↄ̃nↄ a a gↄↄ ń a kɛkɛáo dↄ̃.
\q1 
\v 6 Yã́pii a gↄↄ ń a kɛkɛáo vĩɛ,
\q1 baa tó taasi lɛ́ tↄ̃́ gbɛ̃́wa gbã́ugbãu.
\q1 
\v 7 Lá gbɛ̃e zia dↄ̃o,
\q1 démɛ a fↄ̃ yã́ pↄ́ a mↄ oɛ̀i?
\q1 
\v 8 Gbɛ̃e a wɛ̃ni kũa gbãa vĩo,
\q1 màa gbɛ̃e a fↄ̃ à a gagↄↄ sɛ sↄ̃òo.
\q1 Wìli e bↄ̀ sosau zĩgↄↄo,
\q1 màa vãi lí a kɛnaↄ gbaɛo.
\m 
\v 9 Kɛ́ ma yã́ pↄ́ wàlɛ kɛ dṹniau wàaipà píi, má è gbɛ̃nazĩna ì gbãablemá à ĩakpańzi.
\v 10 Ɔ̃ ma vãikɛna pↄ́ wàlɛ ń vĩↄ è. Gbɛ̃́ↄ bↄ̀ Lua kpɛ́u, aa mↄ̀ ń tↄnasì wɛ̃́lɛ pↄ́ aa ń yãkɛaↄ kɛ̀u guu. Beeá pãɛ lↄ.
\v 11 Tó wi ĩada dàakɛnawa kpakpao, a yã́ ì to gbɛ̃nazĩna zɛò a sↄ̃u à vãikɛ sↄ̃ɛ.
\v 12 Baa tó duunkɛna dàakɛ̀ gɛ̃n basↄo mɛ́ à gɛ̃̀gɛ̃, má dↄ̃ kɛ́ gbɛ̃́ pↄ́ Lua vĩa vĩ aalɛ misiilɛɛ̀ↄ dáama dɛaàla.
\v 13 Vãikɛnaↄ aaↄ dáamavĩo, kɛ́ aa Lua vĩa vĩo yã́i, an gↄↄ a gbã̀akũ lán uenawao.
\p 
\v 14 Yãpã pãle lɛ́ kɛ dṹniau. Yã́ ì gbɛ̃maa le lán vãikɛnan aà ũwa, yã́ ì vãikɛna le lán gbɛ̃maan aà ũwa. Ma mɛ̀ beeá pãɛ lↄ.
\v 15 Mi pↄnakɛa sáaukpa, asa a maa ń gbɛ̃nazĩnao dṹniau aà pↄble, aà imi, aà pↄnakɛ, pↄnapi i dↄaaɛ̀ aà zĩkɛa guu lá Lua aà gbà aà wɛ̃ni lɛ́u dṹnia guuɛ.
\p 
\v 16 Ma mɛkpà ↄ̃nↄkũawa, ↄ̃ ma bↄↄlɛ pↄ́ wàlɛ kɛ dṹniau, kɛ́ i lí na ń wɛ́uo fãanɛ ń gwãasĩnao wàaipà.
\v 17 Má è Lua tò gbɛ̃e a fↄ̃ yã́ pↄ́ lɛ́ kɛ dṹniau dↄ̃o. Baa tó gbɛ̃́ kpálɛkɛ̀i maamaa, a a midↄ̃o. Baa tó ↄ̃nↄna mɛ̀ á dↄ̃, a fↄ̃ bↄwào.
\c 9
\s1 Wɛ̃ni kulunkɛ
\p 
\v 1 Ma beeↄ wàaipà píi, ↄ̃ ma zɛò kɛ́ gbɛ̃maaↄ ń ↄ̃nↄnaↄ ń ń yãkɛaↄ ku Lua ↄzĩɛ. Gbɛ̃e líↄ dↄ̃ tó wàↄ yeazi ge wàↄ zaagu gbɛzão.
\v 2 Yã doũ mɛ́ lɛ́ gbɛ̃́pii dã́, gbɛ̃́ dↄ̀ↄdeↄ ń gbɛ̃́ dↄ̀ↄsaiↄ, gbɛ̃maaↄ ń gbɛ̃vãiↄ, gbɛ̃́ pↄ́ aa gbãlɛaↄ ń gbãlɛnsaiↄ, sa'onaↄ ń sa'onsaiↄ. Lá a dɛ ń gbɛ̃maao, màa a dɛ ń duunkɛnaↄ. Lá a dɛ ń gbɛ̃́ pↄ́ aaì mɛ wa sì ń Luaoↄ, màa a dɛ ń gbɛ̃́ pↄ́ aa a oa vĩa vĩↄ.
\v 3 Yãvãi pↄ́ ì kɛ dṹniau píin kɛ: Yã doũ ì gbɛ̃́pii le. Vãi kↄ̃̀ gbɛ̃nazĩnaↄ sↄ̃u, mìsaiyã mɛ́ ì dↄaanɛ́, a gbɛa aaì ta gɛↄ guu.
\v 4 Gↄↄ pↄ́ gbɛ̃́ bɛ̃́ɛ, ìↄ tãmaa vĩɛ. Baa se gbɛ̃ bɛ̃́ɛ sã̀ↄ nↄ̀ↄmusu gɛwa.
\v 5 Gbɛ̃́ bɛ̃́ɛↄ dↄ̃ kɛ́ wa ga, gɛↄ sↄ̃ aa pↄe dↄ̃o. Aa àie vĩ lↄo, an yã́ a dↄ gbɛ̃egu lↄo.
\v 6 An yea gbɛ̃́zi ń ń zaa gbɛ̃́guo ń ń dɛnlawɛɛlɛao gɛ̃̀zɛan we kↄ̀. An bàa aↄ kú ń yã́ pↄ́ lɛ́ kɛ dṹniauo bau lↄo.
\v 7 Gɛ ǹ pↄble ń pↄnao, vɛ̃ɛmi ń yaalↄo, asa Lua n yãkɛapiↄ sáaukpà kↄ̀.
\v 8 Ǹyↄ̃ ula pua daa gↄↄpii. Ńsu líↄ ku nísidↄↄa n miwa saio.
\v 9 Dṹnia ble ń n na yenzideo n wɛ̃ni gii pↄ́ Lua kpàma dṹniau lɛ́u, asa n luakpaman we gↄↄ pↄ́ n isima gà ńlɛ kpá dṹniau.
\v 10 Zĩ pↄ́ ń è n ↄkpàwà, mɛkpawà n gbãa lɛ́u, asa zĩ ge làasoo ge dↄ̃a ge ↄ̃nↄ ku bɛdau, gu pↄ́ ńlɛ táuo.
\p 
\v 11 Má è dṹnia guu lↄ kɛ́
\q1 bakpaaĩbleaá kàsakasa yã́ɛ adoo,
\q1 zĩbleaá nɛgↄ̃nkɛyãɛ adoo,
\q1 pↄbleaá ↄ̃nↄyãɛ adoo,
\q1 àizɛɛ'eaá wɛzɛ̃yãɛ adoo,
\q1 na ń gbɛ̃́ↄá ladↄ̃yãɛ adoo,
\q1 asa gↄↄ vãi ń kìsiao ì gbɛ̃́pii leɛ,
\q1 
\v 12 mɛ́ gbɛ̃e gↄↄ pↄ́ vãi a a le dↄ̃o.
\q1 Lán kpↄ pↄ́ sì táalu guuwa,
\q1 lán bã pↄ́ fíi aà kũ̀wa,
\q1 màa gu ì dↄ gbɛ̃́ɛ vãivãi,
\q1 ì aà kũ kã́ndo.
\s1 Ɔ̃nↄ dɛ gbãaa
\p 
\v 13 Ma ↄ̃nↄe taa è dṹniau, a yã́ ma kũ gbãa.
\v 14 Wɛ̃́lɛ kú yãa a gbɛ̃́ↄ dasio, ↄ̃ kía gbãadee mↄ̀ lɛ́lɛiwa, à koezↄ̃̀i.
\v 15 Gↄ̃ɛ taaside ↄ̃nↄnae ku wɛ̃́lɛpi guu, a fↄ̃ wɛ̃́lɛ bↄ ń a ↄ̃nↄo, ãma gbɛ̃e i aà yãdao.
\v 16 Ɔ̃ ma mɛ̀ ↄ̃nↄ dɛ gbãaa, ãma wì saka taaside ↄ̃nↄuɛ, wìli aà yãdao.
\q1 
\v 17 Ɔ̃nↄna yã́ pↄ́ wà swãdↄ̀i niɛniɛ
\q1 maa dɛ sↄũↄ dↄaana zↄakaala.
\q1 
\v 18 Ɔ̃nↄ ì mↄ́ ń maao dɛ gↄ̃kɛbↄↄla,
\q1 ãma duunkɛna mɛ̀ndo ì yãmaa zↄ̃ↄ ↄ̃̀ↄkpaɛ.
\c 10
\s1 Sↄũkɛ kai
\q1 
\v 1 Ũsĩn gɛↄ ì to tulalekɛna nísi gĩ ĩ́ikũ,
\q1 sↄũkɛ yↄↄna ì gbɛ̃́ pↄ́ ↄ̃nↄ ń bɛɛɛo vĩ tↄ́ ↄ̃̀ↄkpa.
\q1 
\v 2 Ɔ̃nↄna làasoo ì ta ↄplaai,
\q1 sↄũ pↄ́ ì ta ↄzɛɛi.
\q1 
\v 3 Baa tó sↄũ bɛ zɛ́u,
\q1 aà ↄ̃nↄ ìↄ kɛ̃́sãwàɛ,
\q1 ì to gbɛ̃́pii a mìsaikɛ dↄ̃.
\q1 
\v 4 Tó gbãade pↄ pànzi,
\q1 ńsu go n tíao.
\q1 Kua n laaiwa ì láka tàae zↄ̃ↄa.
\q1 
\v 5 Ma yãvãie è dṹniau,
\q1 a dɛ gbãade zãa yã́wa ũɛ.
\q1 
\v 6 Wì sↄũↄ kpa kpala gbiau dasi,
\q1 mɛ́ ↄdeↄ ìↄ ku kpala yãfũnau.
\q1 
\v 7 Ma zↄↄ è di sↄ̃́ kpɛ,
\q1 mɛ́ wɛ̃́ɛↄ bɛ kɛ̀sɛ lán zↄↄwa.
\q1 
\v 8 Gbɛ̃́ pↄ́ lɛ́ ɛyↄ̃ a zu a guu,\f + \fr 10.8 \ft Soũ 7.16, Yaa 26.27\f*
\q1 gbɛ̃́ pↄ́ lɛ́ gĩ gboo, mlɛ̃ a aà só.
\q1 
\v 9 Gbɛ̃́ pↄ́ lɛ́ gbɛwi, gbɛ a aà kɛ'ĩa,
\q1 gbɛ̃́ pↄ́ lɛ́ lipaa, lí a aà kaikɛ.
\q1 
\v 10 Tó mↄo lɛnao, mɛ́ wi a lɛkɛo,
\q1 sema ǹ gã̀sĩwa bↄbↄwà ń gbãao,
\q1 ãma ↄ̃nↄ ì to wà zɛ'eɛ.
\q1 
\v 11 Tó mlɛ̃ bↄn'ãa kɛ̀ a kↄ̃̀ↄ'onaɛ à aà sò,
\q1 a ài vĩ a guu lↄo.
\q1 
\v 12 Ɔ̃nↄna lɛgbɛ'i na,
\q1 ãma sↄũ lɛ́ ì aà kaalɛɛ.
\q1 
\v 13 Ì na yã'owa sↄũsↄũ,
\q1 ì a midɛ ń mìsaiyãvãio,
\q1 
\v 14 asa sↄũ ì da yãaɛ.
\q1 Lá gbɛ̃e yã́ pↄ́ a mↄ dↄ̃o,
\q1 démɛ a fↄ̃ yã́ pↄ́ a kɛ aà kpɛ oɛ̀i?
\q1 
\v 15 Sↄũ zĩ ì aà kpasa,
\q1 ↄ̃ ìliↄ wɛ̃́lɛ zɛ́ dↄ̃o.
\q1 
\v 16 Waiyoo bùsu pↄ́ a kía dɛ ɛ̀waasona ũ,
\q1 mɛ́ aà ìwaↄ ìↄ blɛ gbɛ̃ kↄↄ.
\q1 
\v 17 Násaa bùsu pↄ́ a kíaá kíabuiɛ,
\q1 mɛ́ aà ìwaↄ ì pↄble a gↄↄwa
\q1 gbãakãfĩa yã́i, i kɛ idɛkɛa yã́i no.
\q1 
\v 18 Tó gbɛ̃́ màa vĩ,
\q1 aà kpɛ́ zaↄ ìↄ wozuzuaɛ,
\q1 tó à ↄkpà a sì, aà kpɛ́ ì ibↄ.
\q1 
\v 19 Wì blɛ zↄ̃ↄ kɛ pↄnakɛa yã́iɛ,
\q1 vɛ̃ɛmia ì mↄ́ ń yaalↄo,
\q1 ãma ↄ̃a mɛ́ ì mↄ́ ń a píio.
\q1 
\v 20 Ńsu kía sↄ̃́sↄ̃o, baa n nↄ̀sɛu,
\q1 ńsu ↄde kao, baa n kpɛa,
\q1 asa bã a yã́pi sɛ́lɛ gɛ́ siuinɛ́ɛ.
\c 11
\q1 
\v 1 Ɔzↄ̃ gbɛ̃́ↄnɛ blɛi,
\q1 gↄↄewa ńyↄ̃ e lↄ.
\q1 
\v 2 Biilɛ gbɛ̃ↄn soplaↄnɛ ge swaaↄ̃,
\q1 asa ń músi pↄ́ a bùsu le dↄ̃o.
\q1 
\v 3 Tó luabɛsiana pà ń ío, ì ma tↄↄlɛ lou ũɛ,
\q1 tó lí lɛ̀lɛ gukpɛ ge bɛ'aɛn nò,
\q1 gu pↄ́ à lɛ̀lɛu, we ìↄ wúlɛu.
\q1 
\v 4 Gbɛ̃́ pↄ́ a wɛ́ dↄ ĩ́anai lí pↄ́tↄ̃o,
\q1 gbɛ̃́ pↄ́ lɛ́ luabɛsia gwa lí pↄkɛkɛo.
\q1 
\v 5 Lá ń wɛ̃nibↄkĩi ge nɛ́ daalɛa nɛasakpɛu dↄ̃o,
\q1 ńyↄ̃ fↄ̃ ǹ Lua Pↄ́piikɛna yãkɛa dↄ̃o.
\q1 
\v 6 Pↄ́tↄ̃ kↄↄ, ńsu ↄkpa n kùɛ oosio,
\q1 asa ń dↄ̃ a kpele mɛ́ a kɛ báaa vĩo.
\q1 Kɛ́ bee yã̀, ge kee yã̀,
\q1 ge aaↄ maa ḿpii yã̀, ń dↄ̃o.
\q1 
\v 7 Gupua na,
\q1 mɛ́ wɛsia ĩatɛ̃lɛ ì káńgu.
\q1 
\v 8 Lá gbɛ̃́ wɛ̃ni lɛ́ gɛ́ lɛ́u,
\q1 aà pↄnakɛu píi.
\q1 Ń beeo aà làasookɛ gusia gↄↄↄwa,
\q1 asa aaↄ dasiɛ.
\q1 Yã́ pↄ́ lɛ́ mↄ́ píi pãɛ.
\s1 Lɛdaa ɛ̀waasoↄwa
\q1 
\v 9 Ɛ̀waaso, pↄnakɛ n ɛ̀waasogↄↄ,
\q1 to n pↄ kɛ n ɛ̀waasogↄↄwa na.
\q1 Yã́ pↄ́ n pↄ gbà kɛ,
\q1 tɛ yã́ pↄ́ kàngui,
\q1 ãma apii guu ǹyↄ̃ dↄ̃
\q1 kɛ́ Lua a yã́kpalɛkɛnnↄ.
\q1 
\v 10 Ńsu to n pↄ yao,
\q1 ǹ n gu'ĩaↄ bↄnla,
\q1 asa ɛ̀waasokɛ ń mikã siao ì gɛ̃zɛaɛ.
\c 12
\q1 
\v 1 To n Kɛna yã́ dↄngu n ɛ̀waasogↄↄ
\q1 e gu àↄ gɛ́ dↄinɛ vãi,
\q1 e wɛ̃ pↄ́ ńyↄ̃ mɛ n pↄ nawào aↄ gɛ́ kái.
\q1 
\v 2 To aà yã́ dↄngu
\q1 e ĩatɛ̃ ń gupuao àↄ lao,
\q1 e mↄvua ń saanaↄ aaↄ siakũ,
\q1 e loumaa gbɛa gu weesai àↄ gɛ́ mↄ́i.
\q1 
\v 3 Gↄↄ bee n ↄↄ lualua,
\q1 n gbáↄ koo,
\q1 n pↄ́sobↄↄ kã́mabo kɛ́ aa dasi lↄo,
\q1 n gugwabↄↄ gu'e ń tↄ́ↄnau dã̀adãa.
\q1 
\v 4 N lɛ́ aↄ kpaaũa gãaɛ,
\q1 wísilↄgbɛ kↄ̃fĩ a busɛkũnɛ.
\q1 Bãↄ wii a n vu iu,
\q1 mɛ́ nɛnↄɛnaↄ lɛ a kɛnɛ busɛ.
\q1 
\v 5 Ńyↄ̃ vĩakɛ gulɛsĩɛ ń bɛa zɛ́ guuo,
\q1 n mikã a pu lán gyavuwa.
\q1 Ńyↄ̃ nzĩa gálɛ lán kwa táa'oawa,
\q1 pↄe a n mɛ fɛlɛ lↄo,
\q1 asa gbɛ̃nazĩna ì gɛ́ a gɛ́kĩiɛ,
\q1 ↄ̃ ↄↄlↄnaↄ ìↄ bɛ gãaɛ.
\q1 
\v 6 To n Kɛna yã́ dↄngu
\q1 e n ã́nusu ba àↄ gɛ́ kɛ̃́i,
\q1 e n vua ta àↄ gɛ́ kpàolokũi,
\q1 e n nibↄna lo àↄ gɛ́ wíwii,
\q1 e n lↄ̀ↄ wuluu àↄ gɛ́ ɛ́i,
\q1 
\v 7 e n bùsuti à ɛa àↄ gɛ́ gɛ̃i tɛ̃́ɛnau,
\q1 gu pↄ́ à bↄ̀u,
\q1 e n nisĩna àↄ gɛ́ tái
\q1 Lua pↄ́ kpàma kĩ́i.
\q1 
\v 8 Mapi ma Làasoode ma mɛ̀:
\q1 Yãpã búubuu, yã́pii pãɛ.
\s1 Yã́pi midɛa
\p 
\v 9 Bee gbɛa lá Làasoodepi ↄ̃nↄ, à dↄ̃a dàdanɛ́. À làasookɛ̀ à kpálɛkɛ̀ yã́ↄi, ↄ̃ à yáasiↄ kɛ̀kɛ dasi.
\v 10 À kpálɛkɛ̀ yãmaai, ↄ̃ à yã́piↄ kɛ̃̀ a zɛ́wa, mɛ́ sĩanaɛ.
\q1 
\v 11 Ɔ̃nↄnaↄ yã́ↄ dɛ lán gése pↄ́ wì lɛ́ sↄ̃́uwaɛ,
\q1 an yã'onɛↄ dɛ lán kusa pↄ́ wa pà gíũgiũↄwaɛ.
\q1 Sãdãn mɛ̀ndona mɛ́ dànɛ́.
\m 
\v 12 Ma nɛ́, laaika, ńsu yãe kã́fĩuo. Wì taalaↄ bↄ dasidasi a lɛ́ vĩo, mɛ́ kyokɛa zↄ̃ↄ ì mɛ kpasaɛ.
\v 13 Wà apii mà, a midɛan kɛ:
\q1 Vĩakɛ Luaɛ,
\q1 níↄ aà yãdilɛaↄ kũa,
\q1 asa gbɛ̃́pii yã́n we.
\q1 
\v 14 Lua a yã́kpalɛkɛwanↄ wá yã́ píiwa,
\q1 baa asiiyã, a maa ge a vãin nò.
