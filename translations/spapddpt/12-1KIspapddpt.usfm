\v 42 \w Los|strong="H5921"\w* \w días|strong="H3117"\w* \w que|strong="H5921"\w* \w Salomón|strong="H8010"\w* \w reinó|strong="H4427"\w* \w en|strong="H5921"\w* Jerusalén \w sobre|strong="H5921"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* fueron 40 \w años|strong="H8141"\w*.
\v 43 \w Salomón|strong="H8010"\w* \w durmió|strong="H7901"\w* \w con|strong="H5973"\w* sus antepasados y fue \w sepultado|strong="H6912"\w* \w en|strong="H5973"\w* la \w ciudad|strong="H5892"\w* \w de|strong="H8478"\w* su padre \w David|strong="H1732"\w*, y \w Roboam|strong="H7346"\w* su \w hijo|strong="H1121"\w* \w reinó|strong="H4427"\w* \w en|strong="H5973"\w* su \w lugar|strong="H8478"\w*.
\c 12
\s1 Rebelión de Israel
\p 
\v 1 \w Roboam|strong="H7346"\w* \w fue|strong="H3212"\w* \w a|strong="H3068"\w* Siquem, \w porque|strong="H3588"\w* \w todo|strong="H3605"\w* \w Israel|strong="H3478"\w* \w fue|strong="H3212"\w* \w a|strong="H3068"\w* Siquem \w para|strong="H3588"\w* proclamarlo \w rey|strong="H4427"\w*.
\v 2 \w Sucedió|strong="H1961"\w* \w que|strong="H1931"\w* \w cuando|strong="H1961"\w* \w lo|strong="H1931"\w* \w oyó|strong="H8085"\w* \w Jeroboam|strong="H3379"\w*, \w hijo|strong="H1121"\w* \w de|strong="H6440"\w* \w Nabat|strong="H5028"\w*, \w quien|strong="H1931"\w* \w vivía|strong="H3427"\w* \w en|strong="H5750"\w* \w Egipto|strong="H4714"\w*, \w porque|strong="H6440"\w* \w aún|strong="H5750"\w* \w estaba|strong="H1961"\w* \w en|strong="H5750"\w* \w Egipto|strong="H4714"\w*, adonde \w huyó|strong="H1272"\w* \w de|strong="H6440"\w* \w la|strong="H1931"\w* \w presencia|strong="H6440"\w* del \w rey|strong="H4428"\w* \w Salomón|strong="H8010"\w*,
\v 3 mandaron \w a|strong="H3068"\w* llamarlo. \w Jeroboam|strong="H3379"\w* llegó con \w toda|strong="H3605"\w* \w la|strong="H3605"\w* \w congregación|strong="H6951"\w* de \w Israel|strong="H3478"\w* para \w hablar|strong="H1696"\w* \w a|strong="H3068"\w* \w Roboam|strong="H7346"\w*:
\v 4 Tu padre \w agravó|strong="H7186"\w* nuestro \w yugo|strong="H5923"\w*. \w Ahora|strong="H6258"\w*, \w disminuye|strong="H7043"\w* tú \w el|strong="H5921"\w* \w duro|strong="H7186"\w* trabajo \w de|strong="H5921"\w* esclavo \w de|strong="H5921"\w* tu padre, \w para|strong="H5921"\w* \w que|strong="H6258"\w* \w el|strong="H5921"\w* \w pesado|strong="H3515"\w* \w yugo|strong="H5923"\w* \w que|strong="H6258"\w* \w nos|strong="H5921"\w* \w impuso|strong="H5414"\w* sea \w más|strong="H5921"\w* llevadero, \w y|strong="H5921"\w* \w te|strong="H5921"\w* \w serviremos|strong="H5647"\w*.
\p 
\v 5 Él les dijo: ¡\w Vuelvan|strong="H7725"\w* \w a|strong="H3068"\w* mí \w dentro|strong="H5750"\w* \w de|strong="H5750"\w* \w tres|strong="H7969"\w* \w días|strong="H3117"\w*! \w Y|strong="H3068"\w* el \w pueblo|strong="H5971"\w* \w se|strong="H5971"\w* retiró.
\p 
\v 6 El \w rey|strong="H4428"\w* \w Roboam|strong="H7346"\w* consultó \w a|strong="H3068"\w* \w los|strong="H1961"\w* \w ancianos|strong="H2205"\w* \w que|strong="H5971"\w* \w estuvieron|strong="H1961"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* su padre \w Salomón|strong="H8010"\w* \w cuando|strong="H1961"\w* \w aún|strong="H7725"\w* vivía: ¿\w Cómo|strong="H1961"\w* aconsejan \w que|strong="H5971"\w* \w responda|strong="H7725"\w* \w a|strong="H3068"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w*?
\p 
\v 7 \w Y|strong="H3068"\w* \w ellos|strong="H3605"\w* le \w respondieron|strong="H6030"\w*: \w Si|strong="H1961"\w* te constituyes \w hoy|strong="H3117"\w* en \w siervo|strong="H5650"\w* \w de|strong="H5971"\w* \w este|strong="H2088"\w* \w pueblo|strong="H5971"\w*, \w los|strong="H3605"\w* atiendes y les hablas \w palabras|strong="H1697"\w*, \w entonces|strong="H3117"\w* \w serán|strong="H1961"\w* tus esclavos \w por|strong="H1697"\w* \w siempre|strong="H3605"\w*.
\p 
