\id EPH - Biblica® Open Kurdi Sorani Standard Version
\h ئەفەسۆس
\toc1 نامەی پۆڵس بۆ باوەڕدارانی ئەفەسۆس
\toc2 ئەفەسۆس
\toc3 ئەفەسۆس
\mt1 نامەی پۆڵس بۆ باوەڕدارانی ئەفەسۆس
\c 1
\p 
\v 1 لە پۆڵسەوە کە بە خواستی خودا نێردراوی عیسای مەسیحە،
\b
\p بۆ گەلی پیرۆزی خودا لە شاری ئەفەسۆس، بۆ ئەوانەی کە بە یەکبوون لەگەڵ عیسای مەسیحدا دڵسۆزن:
\b
\p 
\v 2 با نیعمەت\f + \fr 1:2 \ft نیعمەت بەخشینێکی خودایە بە مرۆڤ بەبێ شایستەبوونی پێی دەبەخشێت.\f* و ئاشتی لە خودای باوکمان و عیسای مەسیحی خاوەن شکۆوە لەگەڵتان بێت.
\b
\s1 بەرەکەتی ڕۆحی لە ڕێگەی یەکبوون لەگەڵ مەسیح
\p 
\v 3 ستایش بۆ خودا، باوکی عیسای مەسیحی خاوەن شکۆمان، کە ئێمەی بە یەکبوون لەگەڵ مەسیحدا\f + \fr 1:3 \fq بە یەکبوون لەگەڵ مەسیحدا \ft لە زمانی یۆنانیدا (لە مەسیحدا) بەکارهاتووە. هەروەها بڕوانە ئایەتی 4‏، 6، 7، 9، 11، 13.‏\f* بە هەموو بەرەکەتێکی ڕۆحی لە شوێنەکانی ئاسماندا\f + \fr 1:3 \ft شوێنەکانی ئاسمان: مەبەست لەو شوێنەیە کە خودا سەبارەت بە ژیانی ڕۆحیمان بڕیار دەدات. بڕوانە 1‏:20، 2‏:6، 3‏:10، 6‏:12.‏\f* بەرەکەتدار کردووە،
\v 4 وەک پێش دامەزراندنی جیهان بە یەکبوونمان لەگەڵ مەسیحدا هەڵیبژاردین، تاکو لەبەردەمی پیرۆز و بێ کەموکوڕی بین.
\v 5 پێشتر بە خۆشەویستی ئێمەی دیاری کرد، تاکو لە ڕێگەی عیسای مەسیحەوە بەگوێرەی خواستی خۆشحاڵانەی، وەکو منداڵی خۆی لە خۆیمان بگرێتەوە\f + \fr 1:5 \ft لێرەدا زاراوەیەکی یاسایی لە دەقی یۆنانی هاتووە کە لەو سەردەمدا بەپێی دابونەریتی ڕۆمانییەکان مەبەست لە بەخشینی تەواوی مافی میراتگری نێرینە بووە.‏\f*،
\v 6 ئەمەش دەبێتە مایەی ستایشکردنی نیعمەتە شکۆدارەکەی کە بە یەکبوون لەگەڵ مەسیحی خۆشەویستیەوە بەخۆڕایی پێیداوین.
\v 7 ئێمە بە یەکبوون لەگەڵ مەسیحدا و بەهۆی خوێنی ئەوەوە کڕدراینەوە، واتا لێخۆشبوونی گوناهمان وەرگرت، بەگوێرەی دەوڵەمەندی نیعمەتەکەی،
\v 8 ئەوەی بەوپەڕی دانایی و تێگەیشتنەوە بەسەرمانی داباراند.
\v 9 نهێنی خواستی خۆی پێ ناساندین، بەگوێرەی خۆشحاڵی خۆی کە لە ڕێگەی مەسیحەوە مەبەستی بوو،
\v 10 بۆ بەجێگەیاندنی لە تەواوی زەمانەدا، تاکو هەموو شتێک لە زەوی و ئاسمان لەژێر دەسەڵاتی مەسیحدا و لە ڕێگەی ئەوەوە یەک بخات.
\p 
\v 11 خودا پێشوەخت بە یەکبوون لەگەڵ مەسیحدا ئێمەی هەڵبژارد تاکو بەگوێرەی پلانەکەی بۆ ئەو بین. خودا هەموو شتێک بەگوێرەی مەبەست و ویستی خۆی بەڕێوە دەبات،
\v 12 بۆ ئەوەی ئێمە کە یەکەمین بووین هیوای خۆمان بە مەسیحەوە گرێ بدەین، ببینە مایەی ستایشکردن بۆ شکۆی مەسیح.
\v 13 هەروەها ئێوە، کاتێک گوێتان لە پەیامی ڕاستی گرت کە مزگێنیی ڕزگاریتانە، خودا ئێوەی لەگەڵ مەسیحدا کرد بە یەک، چونکە کاتێک باوەڕتان هێنا ڕۆحی پیرۆزی بەڵێندراو وەک مۆرێک دەستنیشانی کردن.
\v 14 ڕۆحی پیرۆزیش پێشەکی دەستەبەری میراتەکەمانە، بۆ کڕینەوەی گەلی تایبەتی خودا، بۆ ستایشکردنی شکۆیەکەی.
\s1 نوێژ بۆ ڕۆحی دانایی
\p 
\v 15 لەبەر ئەم هۆیە کاتێک منیش باوەڕی ئێوەم بیست بە عیسای خاوەن شکۆ و خۆشەویستیتان بۆ هەموو گەلی پیرۆزی خودا،
\v 16 بێ وەستان لە پێناوتاندا سوپاسی خودا دەکەم، لە نوێژەکانمدا یادتان دەکەم.
\v 17 داوا دەکەم لە باوکی شکۆدار، کە خودای عیسای مەسیحی پەروەردگارمانە، ڕۆحی دانایی و ئاشکراکردنتان بداتێ هەتا بتوانن بە شێوەیەکی دروست بیناسن.
\v 18 نزا دەکەم بیروهۆشتان ڕووناک بێتەوە تاکو بزانن چییە ئەو هیوایەی ئێوەی بۆ بانگ کراون، هەروەها لە شکۆ و دەوڵەمەندیی میراتەکەی بۆ خوشک‏ و برا پیرۆزەکان تێبگەن،
\v 19 هەروەها گەورەیی بێ سنووری هێزەکەشی بۆ ئێمە کە باوەڕدارین. ئەم هێزە هەمان ئەو توانا مەزنەیە
\v 20 کە خودا بەکاریهێنا ئەو کاتەی کە مەسیحی لەنێو مردووان هەستاندەوە و لە دەستەڕاستی خۆی لە شوێنەکانی ئاسماندا داینا،
\v 21 لە سەرووی هەموو فەرمانڕەوا و حوکومڕان و هێز و دەسەڵاتێک و هەموو ئەوانەی ناویان هەیە، نەک تەنها لەم دنیایە، بەڵکو لەو دنیاش.
\v 22 خودا هەموو شتێکی خستە ژێر پێیەکانی، لە سەرووی هەموو شتێکدا کردییە سەر بۆ کڵێسا،
\v 23 کە جەستەی مەسیحە، واتا پڕیی ئەو بە هەموو شێوەیەک هەموو گەردوون پڕ دەکات.
\c 2
\s1 زیندووبوونەوە لەگەڵ مەسیح
\p 
\v 1 ئێوەش بەهۆی خراپە و گوناهەکانتانەوە مردبوون
\v 2 کە پێشتر تێیدا دەژیان کاتێک پەیڕەوی ڕێبازی ئەم جیهانە و سەرۆکی دەسەڵاتی هەواتان دەکرد، ئەو ڕۆحەی ئێستا لە یاخیبوواندا کار دەکات.
\v 3 ئێمەش هەموو لەوان بووین، لە هەوەسەکانی سروشتی دنیاییماندا دەژیاین، بە خواستەکانی ئەم سروشتە و بیرەکانیمان دەکرد، وەکو خەڵکی دیکە بە سروشت شایانی تووڕەیی خودا بووین.
\v 4 بەڵام خودا کە دەوڵەمەندە لە بەزەیی، لەبەر ئەو خۆشەویستییە مەزنەی بۆ ئێمەی دەربڕیوە،
\v 5 ئێمە کە بەهۆی گوناهەکان مردبووین، لەگەڵ مەسیح زیندووی کردینەوە. بە نیعمەت ڕزگارتان بووە.
\v 6 خودا ئێمەی لەگەڵ عیسای مەسیحدا هەستاندەوە و بەهۆی ‏یەکبوون لەگەڵ ئەودا لە شوێنەکانی ‏ئاسمان دایناین،
\v 7 تاکو لە دنیای داهاتوو دەوڵەمەندی نیعمەتی بێ هاوتای خۆی لە ڕێگەی میهرەبانییەکەیەوە بۆ ئێمە دەربخات کە لەگەڵ عیسای مەسیحدا یەکین.
\v 8 لەبەر ئەوەی بە نیعمەت ڕزگارتان بوو لە ڕێگەی باوەڕەوە، ئەمەش لە خۆتانەوە نییە، بەڵکو دیاری خودایە،
\v 9 بە کردار نییە، تاکو کەس شانازی نەکات.
\v 10 ئێمە دروستکراوی دەستی خوداین و بە یەکبوونمان لەگەڵ عیسای مەسیح دەبینە بەدیهێنراوێک بۆ کاری چاکە، کە خودا پێشتر ئامادەی کردووە تاکو بە ئەنجامی بگەیەنین.
\s1 مەسیح ئاشتیی ئێمەیە
\p 
\v 11 بۆیە وەبیرتان بێتەوە، ئێوە بە جولەکەیی لەدایک نەبوون، پێتان دەگوترا «خەتەنەنەکراو» لەلایەن ئەوانەی پێیان دەگوترا «خەتەنەکراو»، ئەوەی لە جەستەدا بە دەست کراوە،
\v 12 ئەو کاتە بێ مەسیح بوون، لە هاوڵاتییەتی ئیسرائیل بێگانە بوون و لە پەیمانەکانی بەڵێن نامۆ بوون، لە جیهاندا بێ هیوا و بێ خودا بوون.
\v 13 بەڵام ئێوە ئێستا لەگەڵ عیسای مەسیحدا یەکن، هەرچەندە پێشتر دوور بوون، بە خوێنی مەسیح نزیک بوونەوە.
\p 
\v 14 لەبەر ئەوەی مەسیح ئاشتی ئێمەیە، جولەکە و ناجولەکەی کرد بە‏ یەک‏، دیواری ناوبڕی دوژمنایەتی ڕووخاند،
\v 15 بە جەستەی خۆی شەریعەتی تەوراتی بە فەرمان و فەرزەکانییەوە بەلاوە نا\f + \fr 2:15 \ft ڕێساکانی بێتاوانکردنی لە تەوراتدا بەلاوە نا، بڕوانە \xt مەتا 5‏:17‏\xt*\ft ‏.‏\f*، بە ئامانجی ئەوەی بە یەکبوونیان لەگەڵ خۆی لە هەردووکیان\f + \fr 2:15 \ft مەبەستی لە جولەکە و ناجولەکەیە.‏\f* مرۆڤێکی نوێ دروستبکات و بەم شێوەیە ئاشتی بچەسپێنێت،
\v 16 تاکو هەردووکیان لە یەک لەشدا لەگەڵ خودا ئاشت بکاتەوە بە خاچ، بەوەش دوژمنایەتیی لەناوبرد.
\v 17 مەسیح هات و مژدەی ئاشتیی بە ئێوە دا کە دوورن هەروەها ئەوانەش کە نزیکن،
\v 18 چونکە لە ڕێگەی ئەوەوە هەردوو لامان لە یەک ڕۆحدا ڕێپێدراویێتیمان\f + \fr 2:18 \ft بڕوانە \xt ڕۆما 5‏:2.‏\xt*\ft ‏\f* هەیە بۆ چوونە لای باوک.
\p 
\v 19 بۆیە ئیتر نامۆ و بێگانە نین، بەڵکو دەبنە هاوڵاتی لەگەڵ گەلی پیرۆزی خودا و بنەماڵەی خودا،
\v 20 لەسەر بناغەی نێردراوان و پێغەمبەران بنیاد نراون، عیسای مەسیحیش خۆی گرنگترین بەردی بناغەیە\f + \fr 2:20 \ft گرنگترین بەردی بناغە: بەردی قولینچک، بەردێکی گەورەیە لە گۆشەی دیوار دادەنرێت لەو بەردانە بەهێزترە کە لە دیوارەکە بەکاردێت و دەبێتە هۆی بەهێزکردنی دیوارەکە.‏\f*.
\v 21 هەموو خانووەکە بە یەکبوون لەگەڵ مەسیحدا پێکەوە بەستراوە و گەشە دەکات هەتا ببێتە پەرستگایەکی پیرۆز بۆ مەسیح.
\v 22 ئێوەش بە یەکبوون لەگەڵ ئەودا پێکەوە بنیادنراون، تاکو ببنە خانووێک بۆ ڕۆحی خودا.
\c 3
\s1 پەیامی پۆڵس بۆ نەتەوەکان
\p 
\v 1 بەهۆی ئەمەوە\f + \fr 3:1 \ft بڕوانە 2‏:11‏-22.‏\f*، من کە پۆڵسم، لە پێناوی ئێوەی ناجولەکە ئێستا دیلی عیسای مەسیحم…
\p 
\v 2 بێگومان گوێتان لەوە بووە کە ئەرکی ڕاگەیاندنی نیعمەتی خودا بۆ ئێوە بە من سپێردراوە،
\v 3 کە خودا بە ئاشکراکردن نهێنییەکەی بۆ دەرخستم، هەروەک پێشتر بە کورتی نووسیم.
\v 4 بە خوێندنەوەی ئەم نامەیە، دەتوانن لە تێگەیشتنی من لە نهێنی مەسیح حاڵی بن،
\v 5 ئەو نهێنییەی بۆ هیچ کەسێک لە نەوەکانی پێشتر ئاشکرا نەکراوە، وەک ئێستا بە ڕۆحی پیرۆز بۆ نێردراوە پیرۆزەکانی و پێغەمبەران ئاشکرا کرا.
\v 6 نهێنییەکە ئەوەیە کە لە ڕێگەی پەیامی ئینجیلەوە ناجولەکە بوو بە هاومیراتی جولەکە و پێکەوە بوونە ئەندامانی یەک جەستە و هاوبەشی ئەو بەڵێنەی کە بەهۆی عیسای مەسیحەوە پێمان دراوە.
\p 
\v 7 بەپێی هێزە کردەییەکەی خودا و بەگوێرەی بەخشینی نیعمەتەکەی کە پێمدرا، بوومە خزمەتکاری پەیامی ئینجیل.
\v 8 هەرچەندە من بچووکترینی هەموو گەلی پیرۆزی خودام، ئەم نیعمەتە درایە من: مژدەی دەوڵەمەندی بێ سنووری مەسیح بدەمە نەتەوەکان و
\v 9 پلانی ئەم نهێنییە بۆ هەمووان ڕوون بکەمەوە، ئەوەی لە دێرزەمانەوە بەهۆی خوداوە شاردراوەتەوە، ئەوەی هەموو شتێکی بەدیهێناوە،
\v 10 بۆ ئەوەی ئێستا لە ڕێگەی کڵێساوە، دانایی هەمەجۆرەی خودا بۆ فەرمانڕەوا و دەسەڵاتداران لە شوێنەکانی ئاسمان زانراو بێت،
\v 11 بەگوێرەی خواستی هەتاهەتایی، ئەوەی بەهۆی عیسای مەسیحی خاوەن شکۆمانەوە هێنایە دی.
\v 12 بەهۆی یەکبوونمان لەگەڵ مەسیح\f + \fr 3:12 \fq بەهۆی یەکبوونمان لەگەڵ مەسیح \ft لە زمانی یۆنانیدا (لە مەسیحدا) بەکارهاتووە.‏\f* و باوەڕهێنانمان پێی، بە دڵنیاییەوە ئەو ئازادییەمان هەیە بۆ چوونە\f + \fr 3:12 \ft بڕوانە \xt ئەفەسۆس 2‏:18‏\xt*\ft ‏.‏\f* لای خودا.
\v 13 بۆیە داواتان لێ دەکەم لە ناخۆشییەکانم ورە بەرنەدەن کە بۆ ئێوەیە، شکۆمەندی ئێوەیە.
\p 
\v 14 لەبەر ئەمە چۆک بۆ باوک دادەدەم،
\v 15 ئەوەی هەموو خێزانێک لە ئاسمان و سەر زەوی بوونیان لە ئەوەوە سەرچاوەی گرتووە.
\v 16 لێی دەپاڕێمەوە کە بەپێی دەوڵەمەندی شکۆی خۆی بەهێزتان بکات لە ڕێگەی ڕۆحەکەی کە لە ناختاندایە،
\v 17 تاکو بە باوەڕ مەسیح لە دڵتاندا نیشتەجێ بێت و ڕەگ و بناغەتان لە خۆشەویستیدا دابمەزرێت،
\v 18 تاکو توانادار بن، لەگەڵ تەواوی گەلی پیرۆزی خودا تێبگەن کە پانی و درێژی و بەرزی و قووڵی خۆشەویستی مەسیح چییە،
\v 19 تاکو ئەم خۆشەویستییە بناسن کە لە سەرووی زانیارییەوەیە، بۆ ئەوەی پڕبن لە هەموو پڕیێتی خودا.
\p 
\v 20 بۆ ئەو خودایەی توانادارە هەموو شتێک بکات زۆر زیاتر لەوەی کە داوای دەکەین یان بیری لێ دەکەینەوە، بەگوێرەی ئەو هێزەی کە تیاماندا کار دەکات،
\v 21 با نەوە لەدوای نەوە، خودا بۆ هەتاهەتایە لە کڵێسا و لە عیسای مەسیحدا شکۆدار بێت. ئامین.
\c 4
\s1 یەک جەستە و یەک ڕۆح
\p 
\v 1 منی بەندکراو لە پێناوی مەسیحی خاوەن شکۆ لێتان دەپاڕێمەوە بە شێوەیەک بژین شایانی ئەم بانگەوازە بێت کە پێی بانگکراون.
\v 2 بەوپەڕی بێفیزی و دڵنەرمی و ئارامگرتنەوە، بە خۆشەویستی بەرگەی یەکتری بگرن.
\v 3 تێکۆشەر بن بۆ پاراستنی یەکێتی ڕۆحی پیرۆز بە پشتێنی ئاشتی.
\v 4 هەروەک یەک جەستە و یەک ڕۆح هەیە، بۆ یەک هیوای بانگەوازەکەتان کە بانگکران،
\v 5 یەک پەروەردگار، یەک باوەڕ، یەک لەئاوهەڵکێشان،
\v 6 یەک خودا، باوکی هەمووانە، گەورەی هەمووانە، لەناو ناخی هەموواندا کار دەکات و لەنێو هەموواندایە.
\p 
\v 7 بەڵام بەگوێرەی پێوانەی بەخشینی مەسیح نیعمەت بە هەر یەکێکمان دراوە،
\v 8 بۆیە دەفەرموێ:
\q1 ﴿کاتێک ئەو بەرزبووەوە بۆ بەرزایی،
\q2 دیلێکی زۆری لەگەڵ خۆی برد،
\q2 دیاری بە خەڵکی بەخشی.﴾\f + \fr 4:8 \ft \xt زەبوورەکان 68‏:18.‏\xt*\ft ‏\f*
\m 
\v 9 مەبەست لە «بەرزبووەوە» چییە، جگە لەوەی کە دابەزیوەتە نزمترین شوێنی زەوی؟
\v 10 ئەوەی دابەزی هەر خۆی بەرزبووەوە بۆ سەر هەموو ئاسمان، تاکو هەمووی پڕ بکاتەوە.
\v 11 ئیتر مەسیح بە هەندێکی دا ببنە نێردراو، هەندێک پێغەمبەر، هەندێک مزگێنیدەر، هەندێک شوان و مامۆستا،
\v 12 بۆ ئامادەکردنی گەلی پیرۆزی خۆی بۆ کاری خزمەت، بۆ بنیادنانی جەستەی مەسیح،
\v 13 هەتا هەموومان بگەین بە یەکێتی باوەڕ و ناسینی کوڕی خودا، ببینە مرۆڤێکی پێگەیشتوو، بگەینە ئەندازەی تەواوی پڕیێتی مەسیح.
\p 
\v 14 بۆ ئەوەی لەمەولا ساوا نەبین، شێواو و هەڵگیراو بە هەموو بایەکی فێرکردن، بە فێڵی خەڵکی، بە مەکر بەرەو چەواشەی تەڵەکەبازی،
\v 15 بەڵکو لە خۆشەویستیدا ڕاستگۆ بین، با لە هەموو شتێکدا گەشە بکەین، لەناو ئەوەی سەرە، واتا مەسیح.
\v 16 بەهۆی مەسیحەوە هەموو کڵێسا لە خۆشەویستیدا گەشە دەکات و خۆی بنیاد دەنێت، وەک چۆن ئەندامەکانی لەشی مرۆڤ تێک هەڵکێشراون و بە جومگەکان بەیەکەوە بەستراونەتەوە، هاوکاری یەکتری دەکەن.
\s1 ژیانی نوێ بە مەسیح
\p 
\v 17 لەبەر ئەوە پێتان دەڵێم و بە ناوی مەسیحی خاوەن شکۆوە پێداگریش لەسەر ئەمە دەکەم، کە ئیتر وەک ناجولەکەکان مەژین، ئەوانەی کە بیریان پووچە،
\v 18 کە مێشکیان تاریکە، لەبەر ئەو نەزانییەی تێیاندایە و لەبەر دڵڕەقییان لە ژیانی خودا دابڕاون.
\v 19 ئەوانەی هەستیان نەماوە خۆیان داوەتە دەست بەڕەڵایی، بۆ ئەوەی بە چاوچنۆکییەوە هەموو کارێکی گڵاو بکەن.
\p 
\v 20 بەڵام ئێوە بەم شێوەیە فێری مەسیح نەبوون،
\v 21 کاتێک لەبارەی مەسیحەوە بیستتان و بەگوێرەی ئەو ڕاستییەی کە لە عیسادایە فێرکراون.
\v 22 سەبارەت بە شێوازی ژیانی پێشووتان فێرکراون کە مرۆڤە کۆنەکە دابکەنن، چونکە بە ئارەزووە هەڵخەڵەتێنەرەکانی گەندەڵ بووە،
\v 23 هەروەها شێوازی بیرکردنەوەتان نوێ بکەنەوە و
\v 24 مرۆڤی نوێ لەبەر بکەن، ئەوەی خودا وەکو خۆی بەدیهێناوە لە ڕاستودروستی و پیرۆزیی ڕاستەقینە.
\p 
\v 25 بۆیە واز لە درۆ بهێنن، با هەریەکە ڕاستگۆ بێ لەگەڵ نزیکەکەی، چونکە ئەندامی یەک جەستەین.
\v 26 ﴿کاتێک تووڕە دەبن، گوناه مەکەن.﴾\f + \fr 4:26 \ft \xt زەبوورەکان 4‏:4.‏\xt*\ft ‏\f* مەهێڵن ڕۆژ ئاوا بێت بەسەر تووڕەییتاندا،
\v 27 دەرفەت بۆ شەیتان مەڕەخسێنن.
\v 28 دز ئیتر با دزی نەکات، بەڵکو با ڕەنج بدات و بە دەستی خۆی ئیشێکی پاک بکات، تاکو هەیبێت بداتە ئەوەی پێویستی پێیەتی.
\p 
\v 29 وشەی خراپ لە دەمتان دەرنەچێت، بەڵکو هەرچییەکی باشە بۆ بنیادنان، بەگوێرەی پێویستی، تاکو نیعمەت بداتە گوێگران.
\v 30 ڕۆحی پیرۆزی خودا خەمبار مەکەن، ئەوەی بۆ ڕۆژی ڕزگاری\f + \fr 4:30 \ft یۆنانی: کڕینەوە‏\f* پێی مۆرکران.
\v 31 هەموو تاڵی و تووڕەیی و توندی و هاوارکردن و بوختان و هەموو دڵڕەشییەک فڕێبدەن.
\v 32 لەگەڵ یەکتری نەرمونیان و بە بەزەیی بن، لە یەکتری خۆشبن، هەروەک چۆن خودا بە یەکبوونتان لەگەڵ مەسیح لێتان خۆشبوو.
\c 5
\s1 وەک ڕۆڵەی ڕووناکی بژین
\p 
\v 1 کەواتە وەک ڕۆڵەی خۆشەویست، لاسایی خودا بکەنەوە،
\v 2 لە خۆشەویستیدا بژین، وەک مەسیح خۆشیویستین و لە پێناوی ئێمەدا خۆی بەختکرد، قوربانییەک و سەربڕاوێک، بۆنخۆش بۆ خودا.
\p 
\v 3 بەڵام داوێنپیسی و هەموو گڵاوییەک یان چاوچنۆکییەک با لەنێوتاندا ناوی نەبێت، چونکە ئەمانە لە گەلی پیرۆزی خودا ناوەشێتەوە،
\v 4 نەک بێ شەرمی و قسەی ناشیرین و سووک کە ناشێت، بەڵکو لە جیاتی ئەمە سوپاسکردن.
\v 5 بێگومان بن لەوەی هەموو داوێنپیسێک یان گڵاو یان چاوچنۆکێک لە شانشینی مەسیح و خودا میراتی نییە، چونکە چاوچنۆک بتپەرستە.
\v 6 کەس بە قسەی پووچ هەڵتاننەخەڵەتێنێ، چونکە بەهۆی ئەمانە تووڕەیی خودا دێتە سەر کوڕەکانی یاخیبوون.
\v 7 بۆیە هاوبەشییان مەکەن.
\p 
\v 8 پێشتر ئێوە تاریکی بوون، بەڵام ئێستا ڕووناکین بەهۆی یەکبوونتان لەگەڵ مەسیحی باڵادەست. وەک ڕۆڵەی ڕووناکی بژین،
\v 9 چونکە بەروبوومی ڕووناکی لە هەموو چاکە و ڕاستودروستی و ڕاستییەکدایە،
\v 10 هەروەها بزانن کە چی جێگەی ڕەزامەندی مەسیحی خاوەن شکۆیە.
\v 11 بەشداری کرداری تاریکی بێ بەرهەم مەکەن، بەڵکو ئاشکرای بکەن،
\v 12 چونکە ئەو کارانەی بە دزی دەیکەن، تەنانەت ناوهێنانیشی شەرمەزارییە.
\v 13 بەڵام هەموو شتێک لە ڕووناکیدا ئاشکرا بکرێت دەبینرێت،
\v 14 چونکە هەر شتێک ببینرێت ڕووناکییە. بۆیە دەڵێت:
\q1 «ئەی نوستوو هەستە،
\q2 لەنێو مردووان هەستەوە،
\q2 مەسیح بەسەرتدا دەدرەوشێتەوە.»\f + \fr 5:14 \ft بڕوانە \xt ئیشایا 60‏:1‏\xt*\ft ‏.‏\f*
\p 
\v 15 ئاگاداربن چۆن دەژین، نەک وەک نەفام، بەڵکو وەک دانا،
\v 16 کات بقۆزنەوە، چونکە زەمانە بەدکارە.
\v 17 گێل مەبن، بەڵکو تێبگەن خواستی مەسیحی باڵادەست چییە.
\v 18 بە شەراب سەرخۆش مەبن کە بەڕەڵایی تێدایە، بەڵکو پڕبن لە ڕۆحی پیرۆز:
\v 19 لەگەڵ یەکتری بە زەبوور و سروود و گۆرانی ڕۆحی بدوێن، لە دڵتانەوە گۆرانی و ستران بۆ یەزدان بڵێن،
\v 20 هەموو کاتێک و بۆ هەموو شتێک بە ناوی عیسای مەسیحی خاوەن شکۆمان سوپاسی خودای باوک بکەن،
\v 21 بە ترسی مەسیح ملکەچی یەکتری بن.
\s1 ژن و مێرد
\p 
\v 22 ئەی ژنان، ملکەچی مێردەکانتان بن هەروەک چۆن ملکەچی مەسیحن.
\v 23 وەک چۆن مەسیح سەری کڵێسایە کە جەستەی خۆیەتی و خۆی ڕزگارکەریەتی، ئاوا پیاو سەری ژنە.
\v 24 وەک چۆن کڵێسا ملکەچی مەسیحە، ژنانیش دەبێت لە هەموو شتێک ملکەچی مێردەکانیان بن.
\p 
\v 25 ئەی مێردەکان، ژنەکانتان خۆشبوێ، هەروەک مەسیحیش کڵێسای خۆشویست و لە پێناوی خۆی بەختکرد،
\v 26 تاکو پیرۆزی بکات و بە شوشتنی بە ئاو لە ڕێگەی وشەوە پاکی بکاتەوە،
\v 27 بۆ ئەوەی کڵێسایەکی شکۆدار بۆ خۆی ئامادە بکات، لەکە و لۆچ و هیچ شتێکی ئاوای نەبێت، بەڵکو پیرۆز و بێ کەموکوڕی بێت.
\v 28 بە هەمان شێوە پێویستە پیاوان ژنەکانیان وەک جەستەی خۆیان خۆشبوێت، ئەوەی ژنی خۆی خۆشبوێت خۆی خۆشدەوێ.
\v 29 کەس ڕقی لە جەستەی خۆی نابێتەوە، بەڵکو نانی دەدات و بەخێوی دەکات، هەروەک چۆن مەسیح بایەخ بە کڵێسا دەدات،
\v 30 چونکە ئێمە ئەندامی جەستەی ئەوین.
\v 31 ﴿لەبەر ئەوە پیاو دایک و باوکی خۆی بەجێدەهێڵێت و بە ژنەکەیەوە دەنووسێت، ئیتر هەردووکیان دەبنە یەک جەستە.﴾\f + \fr 5:31 \ft \xt پەیدابوون 2‏:24.‏\xt*\ft ‏\f*
\v 32 ئەمە نهێنییەکی گەورەیە، بەڵام من باسی مەسیح و کڵێسا دەکەم.
\v 33 ئێوەش با هەر یەکێکتان ژنەکەی وەک خۆی خۆشبوێ، ژنیش ڕێز لە مێردەکەی بگرێت.
\c 6
\s1 دایک و باوک و منداڵ
\p 
\v 1 ئەی منداڵان، ئێوە وەک شوێنکەوتەی مەسیحی باڵادەست، گوێڕایەڵی دایک و باوکتان بن، چونکە دروستەکەی ئەوەیە.
\v 2 ﴿ڕێزی دایک و باوکتان بگرن.﴾ ئەمە یەکەم ڕاسپاردەیە لەگەڵ بەڵێنەوە دێت
\v 3 ﴿بۆ ئەوەی چاکە بێتە ڕێتان و تەمەن درێژ بن لەسەر زەوی.﴾\f + \fr 6:3 \ft \xt دواوتار 5‏:16‏\xt*\ft .‏\f*
\p 
\v 4 ئێوەش ئەی باوکان، منداڵەکانتان تووڕە مەکەن، بەڵکو بەگوێرەی ڕێنمایی و فێرکردنی مەسیحی باڵادەست پەروەردەیان بکەن.
\s1 کۆیلە و گەورەکانیان
\p 
\v 5 ئەی کۆیلەکان، بە ترس و لەرزەوە بە دڵپاکی گوێڕایەڵی گەورەکانتان بن لەسەر زەوی، وەک بۆ مەسیح بێت،
\v 6 نەک بە خزمەتی بەرچاوان وەک ئەوەی خەڵک ڕازی بکەن، بەڵکو وەک کۆیلەی مەسیح بەدڵ خواستی خودا بەجێبهێنن.
\v 7 با خزمەتتان لە دڵەوە بێت، وەک بۆ عیسای خاوەن شکۆی بکەن نەک بۆ خەڵکی،
\v 8 چونکە دەزانن عیسای خاوەن شکۆ پاداشتی هەرکەسێک دەداتەوە کە کاری چاک دەکات، جا کۆیلە بێت یاخود ئازاد.
\p 
\v 9 ئێوەش ئەی گەورەکان، هەمان شتیان بۆ بکەن، واز لە هەڕەشەلێکردنیان بهێنن، بزانن گەورەی ئەوان و ئێوە لە ئاسمانە، ئەویش لایەنگری ناکات.
\s1 چەکی تەواوی خودا
\p 
\v 10 لە کۆتاییدا پێتان دەڵێم کە بە یەکبوون لەگەڵ مەسیحی باڵادەست و هێزە گەورەکەی بەهێز بن.
\v 11 بە چەکی تەواوی خودا خۆتان چەکدار بکەن، تاکو بتوانن بەرامبەر پیلانی شەیتان خۆتان ڕابگرن،
\v 12 چونکە زۆرانبازی ئێمە لەگەڵ گۆشت و خوێن نییە، بەڵکو لە دژی سەرۆک و دەسەڵاتدار و فەرمانڕەوایانی ئەم جیهانە تاریکەیە، هەروەها لە دژی سەربازە بەدکارە ڕۆحییەکانە لە شوێنەکانی ئاسمان.
\v 13 بۆیە چەکی تەواوی خودا هەڵبگرن، تاکو بتوانن لە ڕۆژی بەدکاردا خۆڕاگر بن و دوای تەواوبوونی هەموو شتێک، بچەسپێن.
\v 14 بە بەستنی پشتێنی ڕاستی بە ناوقەدتان و زرێی\f + \fr 6:14 \ft جلێکی ئاسنینە بۆ پاراستنی سنگی سەرباز لە کاتی جەنگدا. بڕوانە \xt ئیشایا 59‏:17.‏\xt*\ft ‏\f* ڕاستودروستی بە سنگتانەوە،
\v 15 ئامادەیی لە پێ بکەن بۆ ڕاگەیاندنی مزگێنیی ئاشتی\f + \fr 6:15 \ft ڕاگەیاندنی مژدەی ئاشتبوونەوە لەگەڵ خودا.‏\f*،
\v 16 لە سەرووی هەموو ئەوانە قەڵغانی باوەڕ هەڵبگرن، بەمە دەتوانن هەموو تیرە گڕدارەکانی شەیتان بکوژێننەوە.
\v 17 هەروەها کڵاوی ئاسنینی ڕزگاری لەسەر بکەن و شمشێری ڕۆحی پیرۆز هەڵبگرن کە پەیامی خودایە.
\p 
\v 18 بە هەموو جۆرە نوێژ و پاڕانەوەیەک، هەموو کاتێک لە ڕۆحی پیرۆزدا نوێژ بکەن. بۆ ئەمەش ئێشک بگرن و بە بەردەوامی بۆ تەواوی گەلی پیرۆزی خودا بپاڕێنەوە.
\v 19 نوێژ بۆ منیش بکەن تاکو هەر کاتێک دەمم دەکەمەوە قسەی گونجاوم بدرێتێ و ئازایانە نهێنی پەیامی ئینجیل ڕابگەیەنم.
\v 20 من لێرە باڵوێزی ئینجیلم، هەرچەندە لە پێناویدا کۆت و بەند کراوم، نوێژ بکەن بۆ ئەوەی بەگوێرەی پێویست ئازابم بۆ قسەکردن.
\b
\s1 سڵاوی کۆتایی
\p 
\v 21 تیخیکۆس کە برایەکی خۆشەویست و بە یەکبوون لەگەڵ مەسیح خزمەتکارێکی دڵسۆزە، هەموو شتێکتان پێ دەڵێت بۆ ئەوەی ئێوەش هەواڵی من بزانن و ئاگاداری ئەوە بن کە خەریکی چیم.
\v 22 بە تایبەتی بۆ ئەمە ناردمە لاتان، تاکو هەواڵی ئێمە بزانن و ورەتان بەرز بکاتەوە.
\b
\p 
\v 23 لە خودای باوک و عیسای مەسیحی خاوەن شکۆوە، ئاشتی و خۆشەویستییەکی لەگەڵ باوەڕ بۆ باوەڕداران.
\b
\p 
\v 24 نیعمەت لەگەڵ هەموو ئەوانە بێت کە بە خۆشەویستییەکی نەمر عیسای مەسیحی پەروەردگاری ئێمەیان خۆشدەوێت.
