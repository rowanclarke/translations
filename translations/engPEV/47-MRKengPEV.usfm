\p
\v 38 \w They|strong="G2532"\w* got close \w to|strong="G1519"\w* \w the|strong="G2532"\w* \w house|strong="G3624"\w*, \w and|strong="G2532"\w* \w Jesus|strong="G2532"\w* heard \w other|strong="G4183"\w* \w people|strong="G4183"\w* inside \w it|strong="G2532"\w* \w making|strong="G2532"\w* \w a|strong="G2532"\w* big noise. \w They|strong="G2532"\w* \w were|strong="G3588"\w* \w crying|strong="G2799"\w* \w for|strong="G1519"\w* \w that|strong="G3588"\w* dead girl \w and|strong="G2532"\w* shouting \w out|strong="G2532"\w* \w loud|strong="G4183"\w*.  
