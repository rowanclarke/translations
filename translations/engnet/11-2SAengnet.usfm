\v 31  \w Then|strong="H6965"\w* \w the|strong="H3605"\w* \w Cushite|strong="H3569"\w* arrived \w and|strong="H6965"\w* said, “\w May|strong="H3068"\w* \w my|strong="H3605"\w* \w lord|strong="H3068"\w* \w the|strong="H3605"\w* \w king|strong="H4428"\w* \w now|strong="H3117"\w* \w receive|strong="H1319"\w* \w the|strong="H3605"\w* \w good|strong="H1319"\w* \w news|strong="H1319"\w*! \w The|strong="H3605"\w* \nd \+w Lord|strong="H3068"\+w*\nd* \w has|strong="H3068"\w* vindicated \w you|strong="H3588"\w* \w today|strong="H3117"\w* \w and|strong="H6965"\w* \w delivered|strong="H3027"\w* \w you|strong="H3588"\w* \w from|strong="H5921"\w* \w the|strong="H3605"\w* \w hand|strong="H3027"\w* \w of|strong="H4428"\w* \w all|strong="H3605"\w* \w who|strong="H3605"\w* \w have|strong="H3068"\w* \w rebelled|strong="H6965"\w* \w against|strong="H5921"\w* \w you|strong="H3588"\w*!”  
\v 32  \w The|strong="H3605"\w* \w king|strong="H4428"\w* asked \w the|strong="H3605"\w* \w Cushite|strong="H3569"\w*, “\w How|strong="H7965"\w* \w is|strong="H3605"\w* \w the|strong="H3605"\w* \w young|strong="H5288"\w* \w man|strong="H5288"\w* Absalom?” \w The|strong="H3605"\w* \w Cushite|strong="H3569"\w* replied, “\w May|strong="H1961"\w* \w the|strong="H3605"\w* \w enemies|strong="H6965"\w* \w of|strong="H4428"\w* \w my|strong="H3605"\w* lord \w the|strong="H3605"\w* \w king|strong="H4428"\w* \w and|strong="H6965"\w* \w all|strong="H3605"\w* \w who|strong="H3605"\w* \w have|strong="H1961"\w* \w plotted|strong="H7451"\w* \w against|strong="H5921"\w* \w you|strong="H3605"\w* \w be|strong="H1961"\w* \w like|strong="H1961"\w* \w that|strong="H3605"\w* \w young|strong="H5288"\w* \w man|strong="H5288"\w*!”   
\p
\v 33  The king then became very upset. He went up to the upper room over the gate and wept. As he went he said, “My son, Absalom! My son, my son, Absalom! If only I could have died in your place! Absalom, my son, my son!”   
\c 19  
\p
\v 1  Joab \w was|strong="H4428"\w* told, “\w The|strong="H5921"\w* \w king|strong="H4428"\w* \w is|strong="H4310"\w* \w weeping|strong="H1058"\w* \w and|strong="H1121"\w* mourning \w over|strong="H5921"\w* Absalom.”  
\v 2  \w So|strong="H5921"\w* \w the|strong="H5921"\w* victory \w of|strong="H4428"\w* \w that|strong="H4428"\w* day \w was|strong="H4428"\w* turned \w to|strong="H5921"\w* mourning \w as|strong="H4428"\w* \w far|strong="H5921"\w* \w as|strong="H4428"\w* \w all|strong="H1058"\w* \w the|strong="H5921"\w* people \w were|strong="H4428"\w* concerned. \w For|strong="H5921"\w* \w the|strong="H5921"\w* people \w heard|strong="H5046"\w* \w on|strong="H5921"\w* \w that|strong="H4428"\w* day, “\w The|strong="H5921"\w* \w king|strong="H4428"\w* \w is|strong="H2009"\w* grieved \w over|strong="H5921"\w* \w his|strong="H5921"\w* son.”  
\v 3  \w That|strong="H3588"\w* \w day|strong="H3117"\w* \w the|strong="H3605"\w* \w people|strong="H5971"\w* stole \w away|strong="H3605"\w* \w to|strong="H1961"\w* \w go|strong="H1961"\w* \w to|strong="H1961"\w* \w the|strong="H3605"\w* \w city|strong="H1931"\w* \w the|strong="H3605"\w* \w way|strong="H5921"\w* \w people|strong="H5971"\w* \w who|strong="H3605"\w* \w are|strong="H3117"\w* embarrassed steal \w away|strong="H3605"\w* \w in|strong="H5921"\w* fleeing \w from|strong="H5921"\w* \w battle|strong="H3117"\w*.  
\v 4  \w The|strong="H3117"\w* king covered \w his|strong="H3117"\w* face \w and|strong="H3117"\w* \w cried|strong="H5892"\w* \w out|strong="H5127"\w* loudly, “\w My|strong="H1589"\w* son, Absalom! Absalom, \w my|strong="H1589"\w* son, \w my|strong="H1589"\w* son!”   
\p
\v 5  \w So|strong="H6440"\w* Joab visited \w the|strong="H6440"\w* \w king|strong="H4428"\w* \w at|strong="H4428"\w* \w his|strong="H6440"\w* home. \w He|strong="H6440"\w* said, “Today \w you|strong="H6440"\w* \w have|strong="H1121"\w* embarrassed \w all|strong="H1419"\w* \w your|strong="H6440"\w* \w servants|strong="H6440"\w* \w who|strong="H1121"\w* \w have|strong="H1121"\w* saved \w your|strong="H6440"\w* life \w this|strong="H6440"\w* day, \w as|strong="H6440"\w* well \w as|strong="H6440"\w* \w the|strong="H6440"\w* lives \w of|strong="H1121"\w* \w your|strong="H6440"\w* \w sons|strong="H1121"\w*, \w your|strong="H6440"\w* \w daughters|strong="H1121"\w*, \w your|strong="H6440"\w* wives, \w and|strong="H1121"\w* \w your|strong="H6440"\w* concubines.  
\v 6  \w You|strong="H6440"\w* seem \w to|strong="H6440"\w* love \w your|strong="H3605"\w* enemies \w and|strong="H1121"\w* hate \w your|strong="H3605"\w* friends! \w For|strong="H6440"\w* \w you|strong="H6440"\w* \w have|strong="H1121"\w* \w as|strong="H3117"\w* \w much|strong="H3605"\w* \w as|strong="H3117"\w* declared \w today|strong="H3117"\w* \w that|strong="H3605"\w* leaders \w and|strong="H1121"\w* \w servants|strong="H5650"\w* don’t matter \w to|strong="H6440"\w* \w you|strong="H6440"\w*. \w I|strong="H3117"\w* realize \w now|strong="H3117"\w* \w that|strong="H3605"\w* \w if|strong="H1121"\w* Absalom \w were|strong="H1121"\w* \w alive|strong="H5315"\w* \w and|strong="H1121"\w* \w all|strong="H3605"\w* \w of|strong="H1121"\w* \w us|strong="H6440"\w* \w were|strong="H1121"\w* \w dead|strong="H5315"\w* \w today|strong="H3117"\w*, \w it|strong="H6440"\w* \w would|strong="H5315"\w* \w be|strong="H1121"\w* \w all|strong="H3605"\w* right \w with|strong="H1004"\w* \w you|strong="H6440"\w*.  
\v 7  \w So|strong="H4191"\w* get \w up|strong="H3605"\w* \w now|strong="H3117"\w* \w and|strong="H3117"\w* go \w out|strong="H3045"\w* \w and|strong="H3117"\w* \w give|strong="H2416"\w* \w some|strong="H3117"\w* encouragement \w to|strong="H4191"\w* \w your|strong="H3605"\w* \w servants|strong="H5650"\w*. \w For|strong="H3588"\w* \w I|strong="H3588"\w* \w swear|strong="H3588"\w* \w by|strong="H3117"\w* \w the|strong="H3605"\w* \nd Lord\nd* \w that|strong="H3588"\w* \w if|strong="H3588"\w* \w you|strong="H3588"\w* don’t go \w out|strong="H3045"\w* \w there|strong="H3117"\w*, \w not|strong="H3045"\w* \w a|strong="H3068"\w* single \w man|strong="H4191"\w* \w will|strong="H5650"\w* stay \w here|strong="H4191"\w* \w with|strong="H3045"\w* \w you|strong="H3588"\w* tonight! \w This|strong="H3588"\w* disaster \w will|strong="H5650"\w* \w be|strong="H4191"\w* worse \w for|strong="H3588"\w* \w you|strong="H3588"\w* \w than|strong="H3588"\w* \w any|strong="H3605"\w* disaster \w that|strong="H3588"\w* \w has|strong="H5650"\w* overtaken \w you|strong="H3588"\w* \w from|strong="H3117"\w* \w your|strong="H3605"\w* youth \w right|strong="H3477"\w* \w to|strong="H4191"\w* \w the|strong="H3605"\w* \w present|strong="H3117"\w* \w time|strong="H3117"\w*!”   
\p
\v 8  \w So|strong="H3318"\w* \w the|strong="H3605"\w* \w king|strong="H5921"\w* \w got|strong="H6965"\w* \w up|strong="H6965"\w* \w and|strong="H6965"\w* sat \w at|strong="H5921"\w* \w the|strong="H3605"\w* city gate. \w When|strong="H3588"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w people|strong="H1696"\w* \w were|strong="H5650"\w* informed \w that|strong="H3588"\w* \w the|strong="H3605"\w* \w king|strong="H5921"\w* \w was|strong="H3068"\w* sitting \w at|strong="H5921"\w* \w the|strong="H3605"\w* city gate, \w they|strong="H3588"\w* \w all|strong="H3605"\w* \w came|strong="H3318"\w* \w before|strong="H5921"\w* \w him|strong="H5921"\w*.  
\s1 David \w Goes|strong="H3318"\w* \w Back|strong="H3318"\w* \w to|strong="H1696"\w* Jerusalem  
\p \w But|strong="H3588"\w* \w the|strong="H3605"\w* Israelite \w soldiers|strong="H5650"\w* \w had|strong="H3068"\w* \w all|strong="H3605"\w* fled \w to|strong="H1696"\w* \w their|strong="H3605"\w* own homes.  
\v 9  \w All|strong="H3605"\w* \w the|strong="H3605"\w* \w people|strong="H5971"\w* \w throughout|strong="H3605"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* tribes \w of|strong="H4428"\w* \w Israel|strong="H3478"\w* \w were|strong="H3478"\w* arguing \w among|strong="H3427"\w* \w themselves|strong="H6440"\w* saying, “\w The|strong="H3605"\w* \w king|strong="H4428"\w* delivered \w us|strong="H5046"\w* \w from|strong="H6440"\w* \w the|strong="H3605"\w* hand \w of|strong="H4428"\w* \w our|strong="H3605"\w* \w enemies|strong="H6965"\w*. \w He|strong="H3605"\w* rescued \w us|strong="H5046"\w* \w from|strong="H6440"\w* \w the|strong="H3605"\w* hand \w of|strong="H4428"\w* \w the|strong="H3605"\w* Philistines, \w but|strong="H2009"\w* \w now|strong="H2009"\w* \w he|strong="H3605"\w* \w has|strong="H3478"\w* \w fled|strong="H5127"\w* \w from|strong="H6440"\w* \w the|strong="H3605"\w* \w land|strong="H6440"\w* \w because|strong="H6440"\w* \w of|strong="H4428"\w* Absalom.  
\v 10  \w But|strong="H1961"\w* Absalom, \w whom|strong="H5971"\w* \w we|strong="H3068"\w* anointed \w as|strong="H1961"\w* \w our|strong="H3605"\w* \w king|strong="H4428"\w*, \w has|strong="H1961"\w* died \w in|strong="H5921"\w* battle. \w So|strong="H4480"\w* \w now|strong="H6258"\w* \w why|strong="H5921"\w* \w do|strong="H3605"\w* \w you|strong="H3605"\w* hesitate \w to|strong="H3478"\w* \w bring|strong="H1961"\w* \w the|strong="H3605"\w* \w king|strong="H4428"\w* back?”   
\p
\v 11  \w Then|strong="H6258"\w* \w King|strong="H4428"\w* David \w sent|strong="H7725"\w* \w a|strong="H3068"\w* message \w to|strong="H7725"\w* Zadok \w and|strong="H7725"\w* Abiathar \w the|strong="H5921"\w* priests saying, “Tell \w the|strong="H5921"\w* elders \w of|strong="H4428"\w* Judah, ‘\w Why|strong="H4100"\w* \w should|strong="H4100"\w* \w you|strong="H5921"\w* delay \w any|strong="H4191"\w* further \w in|strong="H5921"\w* \w bringing|strong="H7725"\w* \w the|strong="H5921"\w* \w king|strong="H4428"\w* \w back|strong="H7725"\w* \w to|strong="H7725"\w* \w his|strong="H7725"\w* palace, \w when|strong="H7725"\w* everything \w Israel|strong="H4421"\w* \w is|strong="H4100"\w* saying \w has|strong="H4428"\w* \w come|strong="H7725"\w* \w to|strong="H7725"\w* \w the|strong="H5921"\w* \w king|strong="H4428"\w*’s \w attention|strong="H5921"\w*.  
\v 12  \w You|strong="H3605"\w* \w are|strong="H3478"\w* \w my|strong="H3605"\w* brothers – \w my|strong="H3605"\w* very \w own|strong="H1961"\w* flesh \w and|strong="H3063"\w* blood! \w Why|strong="H4100"\w* \w should|strong="H4100"\w* \w you|strong="H3605"\w* delay \w any|strong="H3605"\w* further \w in|strong="H3478"\w* \w bringing|strong="H7725"\w* \w the|strong="H3605"\w* \w king|strong="H4428"\w* \w back|strong="H7725"\w*?’  
\v 13  \w Say|strong="H7725"\w* \w to|strong="H7725"\w* Amasa, ‘\w Are|strong="H6106"\w* \w you|strong="H7725"\w* \w not|strong="H1961"\w* \w my|strong="H7725"\w* \w flesh|strong="H1320"\w* \w and|strong="H7725"\w* blood? God \w will|strong="H1961"\w* punish \w me|strong="H7725"\w* severely, \w if|strong="H1961"\w* \w from|strong="H7725"\w* \w this|strong="H7725"\w* \w time|strong="H1961"\w* \w on|strong="H1961"\w* \w you|strong="H7725"\w* \w are|strong="H6106"\w* \w not|strong="H1961"\w* \w the|strong="H7725"\w* commander \w of|strong="H4428"\w* \w my|strong="H7725"\w* army \w in|strong="H4428"\w* \w place|strong="H1961"\w* \w of|strong="H4428"\w* Joab!’”   
\p
\v 14  \w He|strong="H3117"\w* won \w over|strong="H8269"\w* \w the|strong="H3605"\w* hearts \w of|strong="H3117"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w men|strong="H3605"\w* \w of|strong="H3117"\w* Judah \w as|strong="H3117"\w* though \w they|strong="H3117"\w* \w were|strong="H1961"\w* \w one|strong="H3605"\w* \w man|strong="H3605"\w*. \w Then|strong="H1961"\w* \w they|strong="H3117"\w* sent word \w to|strong="H1961"\w* \w the|strong="H3605"\w* \w king|strong="H6440"\w* saying, “\w Return|strong="H8478"\w*, \w you|strong="H6440"\w* \w and|strong="H3117"\w* \w all|strong="H3605"\w* \w your|strong="H3605"\w* \w servants|strong="H6440"\w* \w as|strong="H3117"\w* well.”  
\v 15  \w So|strong="H7971"\w* \w the|strong="H3605"\w* \w king|strong="H4428"\w* \w returned|strong="H7725"\w* \w and|strong="H3063"\w* \w came|strong="H7725"\w* \w to|strong="H7725"\w* \w the|strong="H3605"\w* Jordan River.  
