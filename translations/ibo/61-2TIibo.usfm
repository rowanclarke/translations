\id 2TI - Biblica® Open Igbo Contemporary Bible 2020
\h 2 Timoti
\toc1 2 Timoti
\toc2 2 Timoti
\toc3 2Tm
\mt1 2 Timoti
\c 1
\p 
\v 1 Pọl, onyeozi Kraịst Jisọs, dị ka uche Chineke si dị, na dị ka nkwa ndụ nʼime Kraịst Jisọs si dị,
\b
\p 
\v 2 Nye gị Timoti, ezi nwa m.
\b
\p Ka amara, na ebere na udo nke sitere na Chineke bụ Nna, na Kraịst Jisọs Onyenwe anyị dịrị gị.
\b
\s1 Ekele
\p 
\v 3 Ana m ekele Chineke, bụ onye m na-ejere ozi ekele, dị ka nna nna m ha mere site nʼakọnuche dị ọcha, ọtụtụ mgbe ka m na-echeta gị nʼekpere m ehihie na abalị.
\v 4 Ka m na-echeta anya mmiri gị, ọ na-agụsị m agụụ ike ehihie na abalị ịhụ gị, ka ọṅụ m zuo oke.
\v 5 Emere m ka m cheta okwukwe ihu abụọ nʼadịghị nke i nwere, bụ okwukwe nke burii ụzọ dịrị nʼime nne nne gị Lọịsi, bịa dịkwa nʼime nne gị Yunaịsi. Emere ka m kwenye na otu okwukwe ahụ dịkwa nʼime gị.
\s1 Arịrịọ ikwesi ntụkwasị obi nye Pọl na oziọma
\p 
\v 6 Nʼihi nke a, achọrọ m ichetara gị ka i mee ka onyinye Chineke ahụ i nwere na-enwu dị ka ọkụ, bụ nke i natara mgbe m bikwasịrị gị aka m abụọ nʼisi.
\v 7 Nʼihi na Chineke enyeghị anyị mmụọ ịtụ ụjọ, kama o nyere anyị mmụọ na-emejupụta anyị nʼike, na ịhụnanya, na uche zuruoke.
\v 8 Ihere emela gị ikwupụta ama banyere Onyenwe anyị maọbụ banyere m bụ onye mkpọrọ ya. Kama, site nʼike Chineke, soro m hụọ ahụhụ nʼihi oziọma ahụ.
\v 9 Ọ zọpụtara anyị, kpọbata anyị na ndụ dị nsọ. Ọ bụghị nʼihi na anyị kwesiri ka a kpọọ anyị, kama, ọ bụ nʼihi nzube ya na amara ya. E nyere anyị amara nʼime Kraịst Jisọs tupu a tọọ ntọala ụwa a.
\v 10 Ugbu a, o meela ka ihe niile o zubere pụta ìhè site nʼọbịbịa Onye nzọpụta anyị Jisọs Kraịst, onye lara ike ọnwụ nʼiyi, zi anyị ụzọ anyị ga-esi nwee ndụ ebighị ebi site nʼoziọma ahụ.
\v 11 Nʼihi oziọma a, ahọpụtara m ka m bụrụ onye na-ekwusa oziọma a, na onyeozi, na onye nkuzi.
\v 12 Ọ bụkwa nʼihi nke a ka m ji na-ahụ ahụhụ ndị a nʼebe a, ma nʼeziokwu, ihere adịghị eme m, nʼihi na amaara m onye m na-atụkwasị obi, amakwaara m nke ọma, na o nwere ike ichebe ihe niile m nyere ya nʼaka idebe tutu ruo ụbọchị ahụ.
\p 
\v 13 Jidesie eziokwu ahụ aka ike, ụdị eziokwu ahụ mụ onwe m ziri gị, eziokwu ahụ gbasara okwukwe ahụ, na ịhụnanya ahụ dị nʼime Kraịst Jisọs.
\v 14 Chezie onyinye ọma ahụ e sitere nʼaka Mmụọ Nsọ bi nʼime gị nye gị idebe.
\s1 Ekwesighị ntụkwasị obi na ikwesi ntụkwasị obi
\p 
\v 15 Dị ka i maara, ndị niile si nʼEshịa bịa nʼebe a agbakụtala m azụ. Ọ bụladị Faigelọs na Hamogịnịs ahapụla m laa.
\p 
\v 16 Ka Onyenwe anyị mere ezinaụlọ Onisiferọs ebere, nʼihi ume ọ gbara m ọtụtụ mgbe. Ihere emeghị ya na-abụ m onye mkpọrọ.
\v 17 Mgbe ọ bịaruru Rom, ọ chọgharịrị m nʼebe niile, ma nʼikpeazụ, ọ chọtara m.
\v 18 Ka Onyenwe anyị kwe ka ọ nata ebere nʼaka Onyenwe anyị nʼụbọchị ahụ. Ị mara nke ọma ụdị aka o nyere m nʼEfesọs.
\c 2
\s1 Ezi onye agha nke Kraịst
\p 
\v 1 Ya mere, nwa m, bụrụ onye dị ike site nʼamara ahụ Kraịst Jisọs na-enye.
\v 2 Ihe niile nke ị nụrụ nʼọnụ m nʼihu ọtụtụ ndị ama ka ị ga-enyefe nʼaka ndị kwesiri ntụkwasị obi, bụ ndị nwekwara ike izi ndị ọzọ ihe ndị a.
\v 3 Soro m kere oke nʼahụhụ dị ka ezi onye agha Jisọs Kraịst.
\v 4 Ọ dịghị onye agha ọbụla na-ekekọta onwe ya nʼihe nke ụwa a, kama ọ na-achọ ime ihe ga-atọ onye họpụtara ya dị ka onye agha ụtọ.
\v 5 Otu aka ahụ, onye na-agba ọsọ agaghị enweta okpu mmeri, ma ọ bụrụ na ọ gbaghị ọsọ ya dịka usoro iwu ịgba ọsọ si dị.
\v 6 Onye ọrụ ubi na-adọgbu onwe ya nʼọrụ kwesiri ịbụ onye ga-ebu ụzọ rie mkpụrụ sitere nʼubi ya.
\v 7 Na-atụgharị uche nʼihe m kwuru, nʼihi na Onyenwe anyị ga-enye gị nghọta nʼime ha niile.
\p 
\v 8 Echefula Jisọs Kraịst, onye a kpọlitere site nʼọnwụ, onye sikwa nʼagbụrụ Devid, nke a bụ oziọma m.
\v 9 Ọ bụ nʼihi na m na-ekwu eziokwu ndị a ka m ji nọọ na-ahụ ahụhụ dị otu a dị ka onye ọjọọ, ma otu ọ dị, ekeghị okwu Chineke agbụ.
\v 10 Ya mere, ana m anagide ihe niile nʼihi ndị a họpụtara, ka ha bụrụkwa ndị ga-anata nzọpụta dị nʼime Kraịst Jisọs, na ebube ebighị ebi.
\p 
\v 11 Nke a bụ okwu kwesiri ntụkwasị obi:
\q1 Ọ bụrụ na anyị esoro ya nwụọ,
\q2 anyị ga-esokwa ya dị ndụ.
\q1 
\v 12 Ọ bụrụ na anyị anagide,
\q2 anyị ga-esokwa ya chịa ọchịchị.
\q1 Ọ bụrụ na anyị ajụ ya,
\q2 ọ ga-ajụkwa anyị.
\q1 
\v 13 Ọ bụrụ na anyị ekweghị ekwe,
\q2 ọ ga-anọgide nʼikwesị ntụkwasị obi,
\q2 nʼihi na o nweghị ike ịjụ onwe ya.
\s1 Onye ọrụ nke Chineke na-anabata
\p 
\v 14 Na-echetara ha nke a, na-agwasikwa ha ike nʼaha Chineke ka ha ghara ịrụ ụka banyere okwu efu. Nʼihi na okwu ndị a abaghị uru, ha na-ewetara ndị na-anụ ya ịla nʼiyi.
\v 15 Gbalịsie ike ka iche onwe gị nʼihu Chineke dị ka onye a nabatara. Onye ọrụ nke ihere na-apụghị ime, onye na-akọwa eziokwu ahụ nke ọma.
\v 16 Zere onwe gị nʼokwu nzuzu nke rụrụ arụ, nʼihi na ọ na-aga nʼihu iduba ndị mmadụ nʼọnọdụ amaghị Chineke karịa.
\v 17 Ozizi ha ga-agbasa dị ka nsị, Haimeniọs na Filetus soo na ndị dị otu a.
\v 18 Ha ahapụla ịgbaso ụzọ eziokwu ahụ bido na-ekwusa okwu ụgha, na-asị na oge mbilite nʼọnwụ agafeela. Site nʼokwu ha, ha na-ekpu okwukwe mmadụ ụfọdụ ihu nʼala.
\v 19 Ma ntọala Chineke hiwere na-eguzosi ike. Nʼelu ya ka eji ihe e dere kaa akara: “Onyenwe anyị maara ndị bụ ndị nke ya,”\f + \fr 2:19 \ft \xt Ọnụ 16:5\xt*\f* ya na, “Ka onye ọbụla kpọrọ onwe ya onye nke Kraịst kwụsị ibi ndụ ajọ omume.”
\p 
\v 20 Nʼime ụlọ ukwuu, ọtụtụ ngwa ọrụ dị ya, ndị e ji ọlaedo maọbụ ọlaọcha, maọbụ osisi maọbụ ụrọ kpụọ. Ụfọdụ ka e ji eje ozi nʼoge nkwanye ugwu dị mkpa, ndị ọzọ ka e ji eje ozi nʼoge ọbụla.
\v 21 Ọ bụrụ na onye ọbụla edoo onwe ya ọcha pụọ nʼihe ọjọọ niile, ọ ga-abụ ngwa ọrụ e mere maka ọrụ ndị kwesiri nkwanye ugwu, bụrụkwa onye dị nsọ, onye na-abara Onyenwe ya uru, na onye dị njikere mgbe ọbụla ịrụ ezi ọrụ.
\p 
\v 22 Gbanarị ihe ọbụla na-etinye ụdị echiche ọjọọ nke ụmụ okorobịa na-enwe nʼime gị, kama, na-agbaso ezi omume na okwukwe, na ịhụnanya na udo, ka gị na ndị na-akpọkukwa Onyenwe anyị site nʼobi dị ọcha na-emekọrịta.
\v 23 Wezuga onwe gị nʼịrụ ụka nzuzu na nke amaghị ihe niile, nʼihi na ị maara na ha na-eweta ise okwu.
\v 24 O kwesikwaghị ka ohu Onyenwe anyị bụrụ onye na-ese okwu, kama, ọ ga-abụ onye obiọma nye mmadụ niile, na onye ma otu e si ezi ihe, onye dị njikere ịnagide ihe ọjọọ e mere ya.
\v 25 Ọ ga-ejiri obi dị nwayọ mgbe ọ na-adụ ndị iro ya ọdụ. Eleghị anya Chineke nwere ike mee ka ha chegharịa, bịa mata eziokwu.
\v 26 Mgbe ahụ, ha nwere ike gbanahụ ọnya ekwensu, ka o jidechara ha ka ha mee uche ya.
\c 3
\s1 Oge ikpeazụ
\p 
\v 1 Ma mara nke a, na nʼoge dị oke egwu ga-adị mgbe ikpeazụ.
\v 2 Nʼihi na ndị mmadụ ga-abụ ndị na-ahụ naanị onwe ha nʼanya, na ndị na-ahụ ego nʼanya. Ha ga-abụ ndị mpako, na ndị na-anya isi, ndị na-ekwujọ ibe ha, ndị na-adịghị asọpụrụ ndị mụrụ ha, maọbụ ikele ha ekele, na ndị na-adịghị ọcha nʼobi ha.
\v 3 Ndị na-enweghị ịhụnanya nʼobi ha, ndị na-enweghị obi mgbaghara, ndị na-agba asịrị, ndị na-emebiga ihe ọjọọ oke, ndị na-eme dị ka anụ ọhịa, na ndị ihe ọma na-adịghị atọ ụtọ.
\v 4 Ndị na-arara ibe ha nye nʼaka ndị iro ha, ndị isiike, ndị onwe ha juru afọ; ndị na-ahụ ihe ụtọ nke ụwa a nʼanya, kama ịhụ Chineke nʼanya.
\v 5 Ha bụ ndị na-ebi ndụ ndị nke Chineke ma ha adịghị egosipụta ike dị na ndụ ahụ. Zere onwe gị nʼebe ndị dị otu a nọ.
\p 
\v 6 Ụfọdụ nʼime ha bụ ndị na-abanye nʼime ụlọ ndị mmadụ na-eduhiekwa ụmụ nwanyị na-enweghị uche, ndị ibu mmehie ha na-anyịgbu, na ndị a pụrụ iduhie nʼihi ọtụtụ ihe ọjọọ na-agụ mkpụrụobi ha agụụ.
\v 7 Ndị a na-akụziri ihe oge niile, ma ha apụghị inweta amamihe nke eziokwu.
\v 8 Dị ka Jenas na Jembaras si lụso Mosis ọgụ, otu a ka ndị a na-alụsokwa eziokwu ahụ ọgụ. Ha bụ ndị nwere obi rụrụ arụ, na ndị ndụ ha mere ka ha bụrụ ndị a jụrụ ajụ nʼebe okwukwe anyị dị.
\v 9 Ma ha agaghị aga nʼihu nʼihi na nzuzu ha ga-apụta ihe nʼihu mmadụ niile, dịka nke mmadụ abụọ ahụ.
\s1 Ndụmọdụ ikpeazụ
\p 
\v 10 Ma ugbu a, ị maara ihe niile banyere ozizi m, na omume m, na ebumnuche m, na okwukwe m na ntachiobi m, na ịhụnanya m, na ndidi m,
\v 11 na mkpagbu m na ahụhụ niile nke dakwasịrị m nʼAntiọk, na Aikoniọm, na Listra. Ị maara ụdị mkpagbu dị iche iche m gabigara. Ma Onyenwe anyị napụtara m site nʼime ha niile.
\v 12 Nʼezie, ndị niile chọrọ ibi ndụ ịsọpụrụ Chineke nʼime Kraịst Jisọs ga-agabiga mkpagbu.
\v 13 Ma ndị mmadụ ọjọọ na ndị na-ebi ndụ aghụghọ ga-ajọ njọ karịa ka ha dị. Ha ga-eduhie ndị ọzọ, ma bụrụkwa ndị a ga-eduhie.
\v 14 Ma gị onwe gị, nọgidesie ike nʼihe ịmụtara na ihe i kwenyesịrị ike na ya, ebe ị maara onye i si nʼaka ya mụta ha.
\v 15 Ị maara na ọ bụ site nʼoge ị bụ nwantakịrị ka ihe e dere nʼakwụkwọ nsọ jiri doo gị anya, nke nwere ike ikuziri gị maka nzọpụta site nʼokwukwe i nwere nʼime Kraịst Jisọs.
\v 16 Ihe niile dị nʼakwụkwọ nsọ bụ ihe si nʼuche Chineke pụta. Ha bara uru maka izi anyị ihe, igosi erughị eru anyị, ịtụziri anyị aka nʼụzọ dị mma, na ịzụ anyị nʼụzọ ezi omume:
\v 17 ka onye nke Chineke zuo oke, dịkwa njikere maka ịrụ ezi ọrụ niile ọbụla.
\c 4
\p 
\v 1 Ya mere, ana m adụsi gị ọdụ ike nʼihu Chineke na nʼihu Kraịst Jisọs, onye ga-ekpe ndị dị ndụ na ndị nwụrụ anwụ ikpe. Ejikwa m ọbịbịa ya na alaeze ya na-asị gị,
\v 2 kwusaa okwu ahụ mgbe niile; dịkwa njikere, mgbe o kwesiri ekwesi na mgbe ọ na-ekwesighị, jiri ya nye ntụziaka, jiri ya baa mba, jirikwa ya gbaa ndị mmadụ ume, site na ntachiobi na ilezi anya inye ezi ndụmọdụ.
\v 3 Nʼihi na oge na-abịa mgbe ụfọdụ mmadụ na-agaghị anagidekwa eziokwu ahụ, kama ha ga-agagharị ịchọ ndị ozizi ha ga-eji gbaa onwe ha gburugburu, ndị ga-ezi ha ihe ha chọrọ ịnụ.
\v 4 Ha agaghị ege ntị nʼeziokwu ahụ, kama ha ga-ege ntị nʼakụkọ na-enweghị isi.
\v 5 Ma guzosie ike, nọọ na nche mgbe niile, na-edi ahụhụ, na-arụkwa ọrụ gị dịka onye oziọma. Rụzukwaa ihe ị kwesiri ịrụ nʼọrụ gị.
\p 
\v 6 Nʼihi na ugbu a, abụrụla m rịị onye a na-awụpụ dị ka aja ihe ọṅụṅụ, oge ụla m eruokwala.
\v 7 Alụsịala m ọgụ ọma ahụ, agbasịala m ọsọ ahụ, edebezuokwala m okwukwe ahụ.
\v 8 Ugbu a, e deberela m okpueze nke ezi omume, nke Onyenwe anyị, onye ikpe ezi omume ahụ, ga-enye m nʼụbọchị ahụ. Ma ọ bụghị naanị m ka ọ ga-enye ya, kama ọ ga-enyekwa ya ndị ahụ niile ọ na-agụsị agụ ike ịhụ ya anya.
\s1 Okwu banyere ihe mere
\p 
\v 9 Gbalịsie ike ịbịakwute m ọsịịsọ,
\v 10 nʼihi na Dimas onye hụrụ ihe ndụ a nʼanya ahapụla m gaa Tesalonaịka. Kresens agaala Galeshịa, Taịtọs agakwaala Dalmetia.
\v 11 Ọ bụ naanị Luk nọnyere m. Mgbe ị na-abịa, kpọta Mak nʼihi na ọ ga-enyere m aka nʼije ozi m.
\v 12 Ezipụla m Taịkikọs ka ọ gaa Efesọs.
\v 13 Mgbe ị na-abịa, wetara m uwe m ji achụ oyi, bụ nke m hapụrụ nʼaka Kapọs na Troas, wetakwara m akwụkwọ m niile ahụ dị nʼebe ahụ, ọkachasị akwụkwọ akpụkpọ anụ niile ahụ.
\p 
\v 14 Alegzanda onye na-akpụ ọla emeela m ọtụtụ ihe ọjọọ. Onyenwe anyị ga-akwụghachi ya dị ka ihe o mere m si dị.
\v 15 Kpachara anya nʼebe ọ nọ, nʼihi na o guzosiri ike megide ihe niile anyị kwuru.
\p 
\v 16 Na mbụ, mgbe m pụtara ikpere ọnụ m, ọ dịghị onye kwụnyeere m. Ha niile gbahapụrụ m. Ka a hapụ ịgụnyere ha omume a dị ka mmehie.
\v 17 Ma Onyenwe anyị nọnyeere m, nyekwa m ike ikwusa oziọma ka ndị mba ọzọ niile nụrụ ya. Ọ zọpụtara m, site nʼọnụ ọdụm.
\v 18 Onyenwe anyị ga-azọpụtakwa m site nʼihe ọjọọ niile ọbụla, kpọbata m nʼudo baa nʼalaeze eluigwe ya. Ọ bụ ya ka otuto dịrị ruo mgbe niile ebighị ebi. Amen.
\b
\s1 Ekele ikpeazụ
\p 
\v 19 Keleere m Prisila na Akwila na ndị niile bi nʼụlọ Onisiferọs.
\b
\p 
\v 20 Erastọs nọ na Kọrint, ma ahapụrụ m Trofimọs na Melitọs nʼọnọdụ ahụ esighị ike.
\v 21 Jisie ike bịarute nʼebe a tupu oge oyi eruo.
\b
\p Yubulọs na-ekele gị, ya na Pudins, na Lainọs na Klọdia na ụmụnna anyị niile.
\b
\p 
\v 22 Ka Onyenwe anyị nọnyere mmụọ gị. Ka amara dịnyere gị.
