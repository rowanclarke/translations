\v 6 \w So|strong="H1768"\w* \w I|strong="H1768"\w* issued \w a|strong="H3068"\w* decree \w that|strong="H1768"\w* \w all|strong="H3606"\w* \w the|strong="H3606"\w* wise men \w of|strong="H1768"\w* Babylon \w be|strong="H3809"\w* brought before me \w to|strong="H3046"\w* interpret \w the|strong="H3606"\w* \w dream|strong="H2493"\w* \w for|strong="H1768"\w* me.
\v 7 When \w the|strong="H5922"\w* magicians, enchanters, astrologers,\f + \fr 4:7 \ft Or Chaldeans\f* \w and|strong="H1934"\w* diviners came \w in|strong="H5922"\w*, I told \w them|strong="H5922"\w* \w the|strong="H5922"\w* dream, \w and|strong="H1934"\w* they could not interpret \w it|strong="H1934"\w* \w for|strong="H5922"\w* \w me|strong="H5922"\w*.
\b
\m 
\v 8 \w But|strong="H3606"\w* at last, into my presence \w came|strong="H4291"\w* Daniel (\w whose|strong="H3606"\w* name \w is|strong="H3606"\w* Belteshazzar after \w the|strong="H3606"\w* name \w of|strong="H3606"\w* my god, \w and|strong="H8065"\w* \w in|strong="H8631"\w* whom \w is|strong="H3606"\w* \w the|strong="H3606"\w* spirit \w of|strong="H3606"\w* \w the|strong="H3606"\w* holy gods). \w And|strong="H8065"\w* I told him \w the|strong="H3606"\w* dream:
\v 9 “\w O|strong="H3068"\w* Belteshazzar, chief \w of|strong="H4481"\w* \w the|strong="H3606"\w* magicians, \w I|strong="H4481"\w* know \w that|strong="H3606"\w* \w the|strong="H3606"\w* spirit \w of|strong="H4481"\w* \w the|strong="H3606"\w* holy gods \w is|strong="H3606"\w* \w in|strong="H1753"\w* \w you|strong="H4481"\w* \w and|strong="H8065"\w* \w that|strong="H3606"\w* \w no|strong="H3606"\w* mystery baffles \w you|strong="H4481"\w*. \w So|strong="H4481"\w* explain \w to|strong="H4481"\w* \w me|strong="H4481"\w* \w the|strong="H3606"\w* visions \w I|strong="H4481"\w* saw \w in|strong="H1753"\w* \w my|strong="H4481"\w* dream, \w and|strong="H8065"\w* \w their|strong="H3606"\w* interpretation.
\v 10 \w In|strong="H5922"\w* \w these|strong="H4481"\w* \w visions|strong="H2376"\w* \w of|strong="H4481"\w* \w my|strong="H5922"\w* \w mind|strong="H7217"\w* as \w I|strong="H4481"\w* \w was|strong="H1934"\w* lying \w in|strong="H5922"\w* \w bed|strong="H4903"\w*, \w I|strong="H4481"\w* \w saw|strong="H2370"\w* \w this|strong="H4481"\w* come \w to|strong="H5922"\w* \w pass|strong="H1934"\w*:
\b
\q1 There \w was|strong="H1934"\w* \w a|strong="H3068"\w* tree \w in|strong="H5922"\w* \w the|strong="H5922"\w* midst \w of|strong="H4481"\w* \w the|strong="H5922"\w* land,
\q2 \w and|strong="H8065"\w* \w its|strong="H4481"\w* height \w was|strong="H1934"\w* great.
\q1 
\v 11 \w The|strong="H4481"\w* tree grew large \w and|strong="H3652"\w* strong;
\q2 \w its|strong="H5426"\w* top reached \w the|strong="H4481"\w* sky,
\q1 \w and|strong="H3652"\w* \w it|strong="H8479"\w* \w was|strong="H2423"\w* visible
\q2 \w to|strong="H2429"\w* \w the|strong="H4481"\w* ends \w of|strong="H4481"\w* \w the|strong="H4481"\w* earth.
\q1 
\v 12 Its leaves \w were|strong="H1768"\w* beautiful,
\q2 its fruit \w was|strong="H2423"\w* abundant,
\q2 \w and|strong="H6523"\w* upon it \w was|strong="H2423"\w* food \w for|strong="H1768"\w* all.
\q1 Under it \w the|strong="H1768"\w* \w beasts|strong="H2423"\w* \w of|strong="H2920"\w* \w the|strong="H1768"\w* \w field|strong="H1251"\w* found shelter,
\q2 \w in|strong="H2508"\w* its branches \w the|strong="H1768"\w* birds \w of|strong="H2920"\w* \w the|strong="H1768"\w* air nested,
\q2 \w and|strong="H6523"\w* \w from|strong="H1768"\w* it every creature \w was|strong="H2423"\w* fed.
\b
\m 
\v 13 As \w I|strong="H4481"\w* lay \w on|strong="H5922"\w* \w my|strong="H5922"\w* bed, \w I|strong="H4481"\w* \w also|strong="H4481"\w* saw \w in|strong="H5922"\w* \w the|strong="H5922"\w* visions \w of|strong="H4481"\w* \w my|strong="H5922"\w* \w mind|strong="H3825"\w* \w a|strong="H3068"\w* watcher,\f + \fr 4:13 \ft Or an angelic watcher or a messenger; also in verses 17 and 23\f* \w a|strong="H3068"\w* holy one, coming down \w from|strong="H4481"\w* heaven.
\v 14 \w He|strong="H1768"\w* called \w out|strong="H6966"\w* \w in|strong="H5922"\w* \w a|strong="H3068"\w* loud voice:
\b
\q1 ‘Cut down \w the|strong="H5922"\w* tree \w and|strong="H4437"\w* chop off \w its|strong="H3046"\w* branches;
\q2 strip off \w its|strong="H3046"\w* leaves \w and|strong="H4437"\w* scatter \w its|strong="H3046"\w* fruit.
\q1 Let \w the|strong="H5922"\w* beasts flee \w from|strong="H1768"\w* under \w it|strong="H5922"\w*,
\q2 \w and|strong="H4437"\w* \w the|strong="H5922"\w* birds \w from|strong="H1768"\w* \w its|strong="H3046"\w* branches.
\q1 
\v 15 \w But|strong="H6903"\w* leave \w the|strong="H3606"\w* stump \w with|strong="H6903"\w* \w its|strong="H6591"\w* roots \w in|strong="H5020"\w* \w the|strong="H3606"\w* ground,
\q2 \w and|strong="H4430"\w* \w a|strong="H3068"\w* band \w of|strong="H4437"\w* iron \w and|strong="H4430"\w* bronze around it,
\q2 \w in|strong="H5020"\w* \w the|strong="H3606"\w* tender grass \w of|strong="H4437"\w* \w the|strong="H3606"\w* field.
\b
\q1 Let him \w be|strong="H3809"\w* drenched \w with|strong="H6903"\w* \w the|strong="H3606"\w* dew \w of|strong="H4437"\w* heaven
\q2 \w and|strong="H4430"\w* graze \w with|strong="H6903"\w* \w the|strong="H3606"\w* beasts on \w the|strong="H3606"\w* grass \w of|strong="H4437"\w* \w the|strong="H3606"\w* earth.
\q1 
\v 16 Let \w his|strong="H1768"\w* mind \w be|strong="H8160"\w* changed \w from|strong="H1768"\w* \w that|strong="H1768"\w* \w of|strong="H4430"\w* \w a|strong="H3068"\w* man,
