\id OBA - Guajajara Bible -Brazil 2007 (DBL 2013)
\h OPAXI
\toc1 Opaxi
\toc2 Obadias
\toc3 Ob
\mt1 OPAXI
\c 1
\nb 
\v 1 Tupàn Tuweharupi Wiko Ma'e umume'u ko uze'eg Enom ywy rehe har Opaxi her ma'e pe a'e.
\s1 Tupàn uzepyk Enom ywy rehe har wanehe
\q1 Tupàn Tuweharupi Wiko Ma'e omono kar amo uze'eg heraha har ywy nànàn a'e. Urenu ize'eg awer ure.
\q1 Nezewe i'i a'e.
\p — Pezemuàgà'ym nehe. Xiàmàtyry'ym putar Enom ywy rehe har zaha nehe,
\q2 i'i a'e.
\b
\q1 
\v 2 Tupàn Tuweharupi Wiko Ma'e umume'u ko uze'eg Enom ywy rehe har wanupe.
\q1 — Apumuigo kar putar teko ikàg 'ym ma'e romo ihe nehe.
\q1 Ni amo nuzeruze'eg kwaw penehe a'e wà nehe.
\q1 
\v 3 Peneko wera'u haw hemu'em peme.
\q1 Peiko itakwaruhu wapupe,
\q1 'a pe ywytyr apyr.
\q1 A'e rupi peze'eg pezeupeupe nezewe.
\q1 — Ni amo nupuner kwaw zanereitykaw rehe xe a'e wà. Nupuner kwaw zanezuka haw rehe xe a'e wà, peze peiko.
\q1 
\v 4 Aze pewewe ywate wiràhu ài nehe,
\q1 aze pezapo penaity zahytata wainuinuromo nehe,
\q1 ihe apuityk putar a'e wi ihe nehe.
\b
\q1 
\v 5 Aze imunar ma'e uhem pyhaw wà,
\q1 xo wemimutar zo weraha wà.
\q1 Aze amo opo'o uwà, tuweharupi wezar amo uwà i'yw rehe.
\q1 Peàmàtyry'ymar pemumaw putar a'e wà nehe.
\q1 
\v 6 Teko Enom izuapyapyr wà. Amo imunar pema'e rehe upaw rupi wà.
\q1 Weraha penemetarer upaw rupi wà no.
\p 
\v 7 Pemyrypar uzeapo peàmàtyry'ymar romo wà.
\q1 Pemono kar peiwy wi wà.
\q1 Kwehe mehe pezapokatu peze'egaw amo teko wanehe we zeàmàtyry'ym 'ymaw imume'u pà. Nezewe rehe we a'e teko upyhyk peiwy pewi wà.
\q1 Pemyryparete umume'u ikatu 'ym ma'e peme wemiapo ràm uzeupeupe wà.
\q1 — Enom izuapyapyr wiko iranaiw ma'e romo wà, i'i peme wà.
\b
\q1 
\v 8 Nezewe i'i Tupàn Tuweharupi Wiko Ma'e kury.
\q1 — Azepyk putar Enom wanehe amo 'ar mehe ihe nehe.
\q1 A'e 'ar mehe azuka putar ma'ekwaw katu har Enom wainuromo har upaw rupi ihe wà nehe.
\q1 Naheta kwaw ni pitài teko ma'e kwaw katu har waiwy rehe wà nehe.
\p 
\v 9 Zauxiapekwer Temà tawhu pe har uryryryryz putar ukyze haw wi a'e wà nehe.
\q1 Zauxiapekwer zeàmàtyry'ymawhu pe oho ma'e umàno putar wà nehe. Amo uzuka putar wà nehe.
\s1 Enom ywy rehe har wanemiapo kwer ikatu 'ym ma'e
\q1 
\v 10 Tupàn Tuweharupi Wiko Ma'e uze'eg teko Enom ywy rehe har wanupe kury.
\q1 — Pepuraraw kar ma'erahy penywyr wanupe. Pezuka amo pe wà no.
\q1 Zako izuapyapyr romo wanekon wà.
\q1 A'e rupi apuzuka kar putar ihe nehe.
\q1 Iaiw paw oho putar penupi tuweharupi nehe.
\q1 
\v 11 Zauxiapekwer weityk ukenuhu Zeruzarez pe har wà.
\q1 Wixe tawhu pupe wà. Weraha ikatu ma'e paw wà. Weraha temetarer paw wà no.
\q1 A'e ma'e iapo mehe napezekaiw kwaw penywyr Izaew wanehe.
\q1 A'e zauxiapekwer amo ae ywy rehe har omomor ita ma'e papar haw hereko har wà,
\q1 a'e ma'e wemipyhyk kwer izar ràm romo hexakaw rehe wà.
\q1 A'e ma'e iapo mehe, pezapo nezewegatete pe no.
\b
\q1 
\v 12 Penurywete a'e 'ar mehe iaiw paw penywyr Zuta wanehe i'ar awer rehe.
\q1 Na'ikatu kwaw penurywete awer ihewe.
\q1 A'e zauxiapekwer uzuka Zuta ywy rehe har tetea'u wà. Peme'e a'e ma'e rehe penurywete pà.
\q1 Na'ikatu kwaw penurywete awer ihewe.
\q1 Pepuka wanehe ma'erahy ipuraraw mehe.
\q1 Na'ikatu kwaw pepuka awer ihewe.
\q1 
\v 13 Peixe Zeruzarez tawhu pupe heremiaihu waneityk mehe.
\q1 Na'ikatu kwaw ipupe peneixe awer ihewe.
\q1 Penurywete a'e iaiw paw wanehe i'ar mehe. Na'ikatu kwaw penurywete awer ihewe.
\q1 Zauxiapekwer weityk Zuta ywy rehe har wà. Peraha wama'e wanuwi a'e 'ar mehe. Na'ikatu kwaw wama'e heraha awer ihewe.
\q1 
\v 14 Amo 'ar mehe pepyta pe iza'akaw pe. Amo Zuta uzeagaw uzàn pà wà.
\q1 Pepyhyk pe wà, wazuka pà wà.
\q1 Pemono umàno 'ym ma'e kwer uzàn ma'e pe wà, waàmàtyry'ymar wanupe pe wà. Iro penemiapo kwer ihewe.
\s1 Ywy rehe har paw wanehe uzepyk àwàm
\q1 
\v 15 Nezewe uze'eg Tupàn Tuweharupi Wiko Ma'e.
\q1 — Amo 'ar mehe amume'u putar teko paw wanemiapo kwer ihe nehe.
\q1 Azepyk putar ikatu 'ym ma'e wanehe nehe. A'e 'ar uhem etea'i.
\q1 Pe Enom izuapyapyr wà. Pemekuzar putar iaiw ma'e penemiapo kwer nehe.
\q1 Pezapo iaiw ma'e amo wanupe. A'e rupi amo teko uzapo putar iaiw ma'e peme nezewegatete a'e wà nehe no.
\q1 
\v 16 Teko uzepyk heremiaihu wanehe heywytyr ikatu ma'e rehe wà.
\q1 A'e rupi azepyk wera'u putar teko a'e ywy huwake har wanehe ihe nehe no.
\q1 Azepyk putar wanehe nehe. A'e re ukàzym putar wà nehe.
\s1 Izaew heta wakàgaw a'e wà kury
\q1 
\v 17 Uze'eg Tupàn Tuweharupi Wiko Ma'e kury.
\q1 — Ywytyr Xiàw ihewe imonokatu pyrer rehe amo teko uzepyro putar wà nehe.
\q1 Teko Izaew ywy rehe har upyhyk wi putar ywy heremimono kwer wà nehe.
\q1 
\v 18 Teko Zuta ywy rehe har a'e wà nehe, teko Izaew ywy rehe har a'e wà nehe no, nuzawy kwaw tata a'e wà nehe.
\q1 Tata wapy ka'akyr a'e. Nezewegatete Izaew umumaw putar Ezau izuapyapyr wà nehe.
\q1 Ni pitài Enom izuapyapyr nuzepyro kwaw wanuwi wà nehe.
\q1 Ihe Tupàn Tuweharupi Wiko Ma'e aze'eg kwez ihe kury.
\b
\p 
\v 19 Izaew izuapyapyr Zuta ywy kwarahy ihemaw awyze har kutyr har weityk putar Enom ywy rehe har wà nehe. Teko Zuta rehe har ywytyr heta 'ymaw rehe har upyro putar Piri ywy rehe har waiwy wà nehe. Izaew upyro putar Eparai waiwy wà nehe. Upyro putar Xamari wà nehe no. Teko Mezàmi izuapyapyr upyro putar ywy pehegwer Zireaz pe har a'e wà nehe no.
\p 
\v 20 Izaew uiwy wi muitea'u heraha pyrer uzewyr putar wà nehe. Upyro putar ywy pehegwer Peni pe har a'e wà nehe. A'e ywy oho Xarepita tawhu kwarahy heixe haw awyze har kutyr har pe. Zeruzarez wi heraha pyrer Xeparaz pe wiko ma'e uzewyr putar wà nehe no. Upyro putar ywy Zuta ywy rehe har kwarahy ihemaw awyze har kutyr har wà nehe no.
\p 
\v 21 Tupàn hemiaihu a'e wà, wàmàtyry'ymar waneityk arer a'e wà. Uzeupir putar Xiàw ywytyr rehe wà nehe. Upyta putar a'e pe teko Enom wanuwihaw romo wiko pà wà nehe. Tupàn Tuweharupi Wiko Ma'e wiko putar wanuwihawete romo a'e nehe. Upaw 
