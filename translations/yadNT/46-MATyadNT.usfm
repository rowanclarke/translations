\id MAT - Yagua NT -Peru 2008 (web -2013)
\h Matévu
\toc1 Samitu̱choda Sanu̱yada Matevu Jesucristunchiy
\toc2 Matévu
\toc3 Mt
\mt1 Samitu̱choda Sanu̱yada Matevu Jesucristunchiy
\c 1
\s1 Jesucrístu munatyavay
\r (Dúcasiy 3.23-38)
\p 
\v 1 Nu̱tyuramusiy su̱ndayada Jesucrístu jiryatiy Davyíbe ju̱débini̱, Avurá̱bay ju̱débi jarye risa̱ju̱ni̱.
\p 
\v 2 Jesucrístu munatyi̱ Avurá̱bay ji̱ta detuyadani̱ Isácubay, jadchintyi Isácubay detuyadani̱ Jacóbubay, jadchintyi Jacóbubay detuyadani̱ Judábay, sataryi̱vedabay jarye yisa̱ju̱.
\v 3 Jadchintyi Judábay detuyadani̱ Várvisibe, Sárabay jaryentiy nadimu Tamáraju̱be, jadchintyi Várvisibe detuyadani̱ Esrúmibe, jadchintyi Esrúmibe detuyadani̱ Ará̱bay.
\v 4 Jadchintyi Ará̱bay detuyadani̱ Amyinadábebe, jadchintyi Amyinadábebe detuyadani̱ Na̱sú̱bay, jadchintyi Na̱sú̱bay detuyadani̱ Sarumú̱bay.
\v 5 Jadchintyi Sarumú̱bay detuyadani̱ Boósibe nadimu Raábiju̱be, jadchintyi Boósibe detuyadani̱ Jobénubay nadimu Rúdiju̱be; jadchintyi Jobénubay detuyadani̱ Isayíbe.
\v 6 Jadchintyi Isayíbe detuyadani̱ Davyíbe jiryatiy ja̱mu nutyityu̱ savichanu̱yada.
\p Jadchintyi Davyíbe detuyadani̱ Sadumú̱bay nadimu Uríyasibe vaturu̱be.
\v 7 Jadchintyi Sadumú̱bay detuyadani̱ Robová̱bay, jadchintyi Robová̱bay detuyadani̱ Abíyasibe, jadchintyi Abíyasibe detuyadani̱ Asábay.
\v 8 Jadchintyi Asábay detuyadani̱ Josavátubay, jadchintyi Josavátubay detuyadani̱ Jorá̱bay, jadchintyi Jorá̱bay detuyadani̱ Jusíyasibe.
\v 9 Jadchintyi Jusíyasibe detuyadani̱ Jotá̱bay, jadchintyi Jotá̱bay detuyadani̱ Acásubay, jadchintyi Acásubay detuyadani̱ Esequíyabay.
\v 10 Jadchintyi Esequíyabay detuyadani̱ Manasésibe, jadchintyi Manasésibe detuyadani̱ Amú̱bay, jadchintyi Amú̱bay detuyadani̱ Jusíyasibe.
\v 11 Jadchintyi Jusíyasibe detuyadani̱ Jeconíyasibe, sataryi̱vedabay jarye rijya̱tatyadedanumatiy Judíyuveda mityasimyi Babinóniya mucadimuju̱ riy.
\p 
\v 12 Babinóniyamuju̱ ja̱tedivasiy ji̱ta sadetuyada Jeconíyasibeñi̱ Sadatyérubay, jadchintyi Sadatyérubay detuyadani̱ Sorobabénubay.
\v 13 Jadchintyi Sorobabénubay detuyadani̱ Abiyúbay, jadchintyi Abiyúbay detuyadani̱ Edyaquí̱bay, jadchintyi Edyaquí̱bay detuyadani̱ Jasórubay.
\v 14 Jadchintyi Jasórubay detuyadani̱ Sadócubay, jadchintyi Sadócubay detuyadani̱ Aquí̱bay, jadchintyi Aquí̱bay detuyadani̱ Ediyúbay.
\v 15 Jadchintyi Ediyúbay detuyadani̱ Edyasárubay, jadchintyi Edyasárubay detuyadani̱ Matá̱bay, jadchintyi Matá̱bay detuyadani̱ Jacóbubay.
\v 16 Jadchintyi Jacóbubay detuyadani̱ Jusíbe, ni̱tiy vicha̱da Maríyaju̱be vanubay. Maríyaju̱be ji̱ta detuyadani̱ Jesús jiryatiy ru̱tachara Ju̱denu jaryeti̱ni̱.
\p 
\v 17 Ramuni̱ vu̱dyi riva vu̱yaju̱y detuyada, daryaju̱yu detuyada ranchaju̱ Avurá̱bamyusiy, Davyíbe sa̱ra̱ju̱; daryaday Davyíbemyusiy Babinóniyamuju̱ ja̱tedasa̱ra̱ju̱ ravicha̱da vu̱yaju̱y detuyada, daryaju̱yu detuyada ranchaju̱ntiy; jadchintyi Babinóniyamuju̱ ja̱tedamusiy, Ju̱denu jaryeti̱ rupedasa̱ra̱ju̱, ravicha̱da vu̱yaju̱y detuyada, daryaju̱yu detuyada ranchaju̱.
\s1 Jesús pi̱ra rupedanchiy
\r (Dúcasiy 2.1-7)
\p 
\v 18 Jesucrístu pi̱ra rupeda ji̱ta vichanu̱yada daryá: Saja̱mu̱ryu̱yadanumatiy Maríyabañi̱ Jusíbe, netimyu̱ nanuvicha̱da vatajuu didye, samudasiiyada ji̱ta Ju̱denu Jnutumusiy variy.
\v 19 Savanubay Jusíbe ji̱ta, jiryatiy savichanu̱yada vase jvaarya, ne sa̱ntaniryu̱yada vijyo̱mujacheni̱ jivyaturabay Maríyabay. Ramuni̱day sajachipiya̱jada: “Ra̱tochiy dutya̱damusiñi̱.”
\v 20 Darya sajachipiya̱jadamu ji̱ta, mityamusiy samu̱ti̱jada Ju̱denu jpa̱nu sama̱ryi̱sa̱damu Jusíbe yimu, su̱teda variy siva: “Jusíy, Davyíbe ju̱débi, ne ya̱suvu̱y jmutya̱jada yisa̱ju̱ni̱ Maríya jivyaturaju̱, tapi samudasiityi Ju̱denu Jnutumusiy.
\v 21 Sa̱day rupachuni̱ jidyenu, ya̱ma̱ bay variy si̱tyaju̱ra Jesús jiryatiy vuryi̱tay Vuryeyada Rá̱ñu, tapi ni̱ni̱day ra̱ramityaniy jiñijya̱nvavyara jijyuuchuveda.” Darya su̱teda Ju̱denu jpa̱nu siva Jusíbe.
\p 
\v 22 Ravichanu̱yada ji̱ta ti̱ta̱ju̱ daryá, ra̱tidye jto̱tanichara Ju̱denu niquejada, jiryatiy jityu̱choda saju̱ tu̱chu̱bay jtosirya:
\q1 
\v 23 “Jirya̱jnu̱y, sa̱mudasiichara ji̱ta vatura jútu, sa̱rupachu variñi̱ jidyenu. Rirya̱ntacharara si̱tya Emanuvé, ratatiy vuryi̱tay: Ju̱denu vuryisa̱.”
\p 
\v 24 Si̱dyojadanumatiy Jusíbe, sivaayada ji̱ta daryatiy su̱teda Ju̱denu jpa̱nu sivara, su̱mutya̱jada variy yisa̱ju̱ni̱ vatura.
\v 25 Ne saja̱tyo̱jada ji̱ta saniy, netimyu̱ ne sarupachoda dinñi̱ jidyenu didye. Sarupedanumatiy sadenu sabayada ji̱ta variy si̱tyaju̱ra Jesús.
\c 2
\s1 Rijeñu̱yada nijya̱nvay datyavay simu Jesús pi̱ra
\p 
\v 1 Sarupedanumatiy Jesús Bení̱mu, savicha̱da ji̱ta Jeródesbe ja̱mu nutyityu̱ Judéya mucadimu. Ruuti̱jada ji̱ta nijya̱nvay jaryi datyavay variryundamu, jiñi̱ mu̱ti̱jomusiy Jerusarí̱mu.
\v 2 Ruuti̱nuvi̱jada jtaja̱nuvay: “¿Nu̱tyiryani̱ Judíyuveda ja̱mu nutyityu̱, jiryatiy vadi rupi̱ni̱, nu̱tyi? Nu̱dyityi daryaju̱ siva sanu̱ya̱ jdarichiy, samu̱ti̱jadamu, nu̱dyiti̱ ji̱ta nu̱ña̱tidye jadasiñu sana̱cho̱ju̱yu.”
\v 3 Satuva̱chodanumatiy nutyityu̱ Jeródesberya, paru̱cha̱riy savicha̱da variy ranchiy, Jerusarí̱ ja̱nvabe jarye tuva̱choda paru̱cha̱riy rana̱cho̱ sisa̱ju̱.
\v 4 Santye̱ryadedanumatiy Jeródesberyi caserdótevyeda nutyityu̱mibe, Ju̱denu niquejada datyanuvabe jarye ruusa̱ju̱, nijya̱nvay cabyimusiy, sitaja̱doda variy jasiryi: “¿Tena̱ sa̱rupachara Ju̱denu jaryeti̱, Vuryeyada Ra̱yasi̱, te?”
\v 5-6 Ru̱mutya̱jada ji̱ta variñi̱: “Tena̱ Bení̱mu, te, jiryatiy Judéya mucadimura, tapi darya nu̱charavitya Ju̱denuju̱ tu̱chu̱bay niquejadamura:
\q1 Ji Bení̱ vicha̱da, ne jivyichasara tamitya pasi vicha̱da, Judéya mucadi vicha̱da cabyiva, nutyityu̱miy diya; tapi yimusiy ji̱ta sa̱sipyatay nutyityu̱ ni̱tiy ra̱nsu̱charariy rañijya̱nvay, jiryatiy Irayénuveda daryi.”
\p 
\v 7 Jadchiy ji̱ta sanatutyadeda Jeródesbe nijya̱nvañiya̱resiryi jañu̱vye jaryi datyavabe. Sani jiyasanta̱da ji̱ta variryi: “¿Nu̱tyeryivye samu̱ti̱ti jiryatiy sanu̱ya̱ti variy jdarichiy, nu̱tyeryivye?” Rityu̱choda ji̱ta variy sivara.
\v 8 Su̱pa̱jada ji̱ta Jeródesbe variy Bení̱mu riy: “Jirya̱datyanuve samiy jiñu deranchiy. Jirya̱numatiy diy siva, jirya̱tu̱chosiy variy riva, ra̱tidye jadasiñu sana̱cho̱ju̱ntidyerye.”
\v 9 Rityuva̱chodanumatirya Jeródesbe niquejada, riya̱da ji̱ta variy jadchiy. Jdarichiy ji̱ta, jiryatiy ridyityi siva samu̱ti̱jadamu, rañi jiya̱da jiyanti̱ rimyo̱musiy, jasityi saradeda si̱yu derapudera.
\v 10 Ridyiyadanumatiy siva jdarichiy, riichana̱yada ji̱ta jaryi yichana̱yadamu.
\v 11 Rijeyadanumatiy rorivyimu sana̱cho̱, ridyiyada ji̱ta siva dera, su̱no̱da Maríyaju̱be jarye yisa̱ju̱. Rirye̱yada ji̱ta mucomu, rirya̱dasidyoda sana̱cho̱ju̱ variyu. Rimyutta̱da ji̱ta varirya jibejyo, ru̱ntatya̱da variy sivara sa̱chara jaryi murichetara: órutera, vu̱rudijuru, vu̱rudiricha jarye risa̱ju̱.
\v 12 Rime̱ryi̱sa̱damu ji̱ta sadatyadoda Ju̱denuyu: “Ne jirya̱ta̱rya simuju̱ Jeródes,” tanú̱vanuma ritye̱rya̱da variy jimyucadimuju̱ day.
\s1 Nanubayada Jesús ja̱jyu̱be Ejíptumuju̱
\p 
\v 13 Ritye̱rya̱danumatiy nijya̱nvay datyavabe, mityamusiy samu̱ti̱jada Ju̱denu jpa̱nu Jusíbe ma̱ryi̱sa̱damu yimu, su̱teda ji̱ta variy jasiy siva: “Ya̱numa nubesumiy, ya̱numa bay Ejíptu mucadimuju̱, ya̱pu̱chiy rumuni̱ dera, su̱no̱da yisa̱ju̱. Ya̱ma̱ ma̱cho̱ rumu, jasityi ra̱tu̱chu yiva, tapi sa̱numa va̱ta Jeródes sana̱cho̱ dera, su̱vedaju̱.”
\p 
\v 14 Sanubeseda ji̱ta Jusíbe nupora, sapu̱cheda ji̱tani̱ dera, su̱no̱dabay yisa̱ju̱, saya̱da ji̱ta variy Ejíptumuju̱.
\v 15 Jasiñuma rime̱cho̱jada Jeródesbe diiyadasa̱ra̱ju̱, ra̱tidye jto̱tanirya Ju̱denu niquejada, jiryatiy su̱teda jijyu̱ tu̱chu̱bamyusiy:
\q1 “Ejíptumusiy ji̱ta rañatumya̱ni̱ radyenu.”
\s1 Su̱vatyadeda Jeródesberyi deramidyera
\p 
\v 16 Jadchiy ji̱ta, sadatya̱danumatiy Jeródesbe: “Riquivu̱chuma̱ nijya̱nvay datyavarye,” sanique̱yada jaryi variy, su̱pa̱jada variryi su̱tarumibe, rirya̱tidye jvaryi deramidyera ti̱ta̱ju̱ jiryatiy vaduryi, danijya̱ju̱tyavay sa̱ra̱ju̱ ti̱ta̱ju̱, jiryatiy rivyichanu̱yada Bení̱ ju̱ro̱ ti̱ta̱ju̱, daryatiy sadatya̱da Jeródesberya dera rupeda runda, nijya̱nvay datyavabemyusiy.
\v 17 Rito̱tadeda ji̱ta rata varirya Ju̱denuju̱ tu̱chu̱bay niquejada, jiryatiy Jiryimyíya jtyati̱bay savichanu̱yada:
\q1 
\v 18 “Rityuva̱chusarara nana̱nsa̱da Ramá vicha̱damu, jna̱yada jaryi, sa̱ñe̱ya̱jadasuma jarye, jiryatiy nanunuvachara Raquédaju̱ryi jidyedyeñujuu. Ne nanuparu̱ryu̱yada riva nuvayada rinchiy, jiryatiy diivyeñuma daryaju̱ daryi.”
\p Darya saniquenu̱yada Jiryimyíyabay ta̱riy.
\s1 Nanuta̱rya̱jada Jesús ja̱jyu̱be Ejíptumusiy
\p 
\v 19 Jadchiy ji̱ta, sadiiyadanumatiy Jeródesbe, mityamusiy samu̱ti̱jada Ju̱denu jpa̱nu variy simu Jusíbentyi, sama̱ryi̱sa̱damu, Ejíptumuntiy.
\v 20 Su̱teda ji̱ta Ju̱denu jpa̱nu siva: “Ya̱nubesumiy, ya̱numa jiyata dañi̱ derapude day, su̱no̱da yisa̱ju̱. Ye̱jiya variy Irayénuveda mucadimuju̱, tapi sadiityimya̱ ni̱tiy rañi va̱tanu̱yada sana̱cho̱ derapu, yivedaju̱.”
\v 21 Sanubesubeda ji̱ta Jusíbe variy, sayata̱dani̱ derapu, su̱no̱dabay yisa̱ju̱, sito̱jada ji̱ta Irayénuveda mucadimu.
\v 22 Satuva̱chodanumatiy Jusíberya sa̱ticheyada: “Sajamya̱ Arquedávu nutyityu̱ju̱, Judéya mucadimu, jijye̱be Jeródesbe ju̱bivaju̱,” sasuvu̱yada Jusíberya jti̱jada Judéyamu. Sadatya̱danumatiy Jusíbe jime̱ryi̱sa̱damu ne ra̱jiya Judéyamu, sanumuteda variy Cadidéya ju̱ro̱ju̱.
\v 23 Ti̱ta̱ju̱numa saya̱da variy Nasaryému vicha̱daju̱ day. Ramusiy sito̱tadeda ji̱tara Ju̱denuju̱ tu̱chuvabe niquejada, jiryatiy rirya̱jtachara Nasaryémusi̱ni̱.
\c 3
\s1 Juán Bautístabay tu̱chodara Ju̱denu niquejada mityatomu
\r (Márcu 1.1-8; Dúcasiy 3.1-9, 15-17; Juán 1.19-28)
\p 
\v 1 Variryundamu ji̱ta su̱deda Juán Bautístabay tu̱chu̱ Judéya mityatomu.
\v 2 Saniquejada ji̱ta: “Jirya̱paru̱y riva va̱cha jachipiya̱jada, jiryatiy ratuudiñuma Jarichumuvichi̱ nusu̱yada nijya̱nvay jachipiya̱jadamu.”
\v 3 Juán Bautístabaynchiy ji̱ta satu̱choda Ju̱denuju̱ tu̱chu̱bay Isayíyasiy jtyati̱bay, jiryatiy saniquejada:
\q1 “Ti̱ jtani̱te natuye̱ tajityomudaque: Ya̱numa jdutya ji̱tyaju̱ra nú̱ Vu̱ntyityu̱jiju̱, vasenú̱ ya̱barya nú̱ sa̱jiju̱.”
\p 
\v 4 Juánbay ji̱ta jachodara jasi̱jasityera jvaachara jichujay yiva, caméllujasityera jvaachara. Sapuchoda ji̱tara jicyannujay caméllu jatyera. Si̱myisi̱ ji̱ta vichanu̱yada vindya ruvá, to quisijya̱ jarye sisa̱ju̱.
\v 5 Jadchiy ji̱ta ru̱deda nijya̱nvay simu Juánbay Jerusarí̱ ja̱nvavyedabay, Judéya mucadija̱nvavyedabay ruusa̱ju̱, Jurdá̱ja̱ ju̱ro̱ vichavabe jarye ti̱ta̱ju̱.
\v 6 Riityu̱ñu̱yada ji̱ta simu Juánbay Jurdá̱ja̱mu riñiquejadanumatiy vijyo̱mujachera jijyuuchuveda variy.
\p 
\v 7 Sadiyadanumatiy Juánbay ruuva rajuuvay Varyisévuveda tevabe, Saadusévuveda tevabe jarye ruusa̱ju̱, jiryatiy ruuti̱tityiyada rirya̱tidye jtyu̱y variy simu, su̱teda ji̱ta variy ruuva: “Codityevay rapu̱ryamiy, ¿chi̱ra datyadosiy ji̱tyaju̱ jirye, chi̱? ¡Jirya̱numa bay ra̱jisiy Ju̱denu nique̱yada!
\v 8 Daryatiy rajontay ni̱nu, darya jirya̱jontay samirya vicha̱damuju̱ntidye, jirya̱tidye dityanu ratara va̱cha jvaayadiva paru̱yada.
\v 9 Ne jirya̱jachipiya̱ jivyimu: Avurá̱bay ji̱ta vu̱myunatyi̱, ramutiy sa̱jantyuy Ju̱denu vuryiva. Ri̱tatye ji̱ta jiryiva: Saryi ju̱de Ju̱denu jiñu ravichu̱musiy Avurá̱bay dadyeñuju̱ rityidye ra̱tuva̱chu variy simu.
\v 10 Netimyu̱ ne jirya̱jontay samirya vicha̱damuju̱, jirya̱ma̱ datya: Ni̱nu ruva̱tuununumara jaseé, ru̱nusa̱daju̱. Ramuni̱day rirya̱jnura jirya ni̱nuvicha̱ jiryatimyu̱ ne samirya jorara, rirya̱tidye jatya jiidamyu variy rivara.
\v 11 Ray ji̱ta jtyanu ja̱a̱ta jirye, jirya̱tidye dityanu ratara jiryepyaru̱yada riva va̱cha jachipiya̱jada. Ni̱ni̱ ji̱ta jiryatiy sa̱jti̱ ri̱bivaju̱ savichasara jaryi datyara rimusidye. Ne vinu sasaapatu jtodasa̱ra̱ ntate darye. Ni̱ni̱ ji̱ta ra̱jtyanu Ju̱denu Jnututa jiryedye, jiidatya jarye risa̱ju̱.
\v 12 Sapa̱pe̱tyu variy jijyomu, sa̱tidye ju̱pay varirya yivaajyo, sa̱jato varirya rasiy rabajyovimuju̱, raqui̱suy ji̱ta sa̱rupay jiidatya jiryatimyu̱ ne vana̱y ji̱richasarara.”\f * \fr 3:12 \ft Su̱tarya rasiy yimu tuva̱chuvajyu̱, raqui̱suy ji̱ta su̱tay rijyu̱ jiryatimyu̱ ne rityuva̱churu̱y simu.\f*
\s1 Jesús jtyu̱yadanchiy
\r (Márcu 1.9-11; Dúcasiy 3.21-22)
\p 
\v 13 Jadchiy ji̱ta su̱deda Jesús Cadidéyamusiy, Jurdá̱ja̱ tuudiche, sa̱tidye jtyanutaniy jasiy Juánbayu.
\v 14 Juánbay rañi ju̱bayada sa̱jisidyerya: “Rañi ji̱ta raryi jtyu̱y yimu. ¿Ta̱raju̱ yiniy variy rimu, ta̱raju̱?”
\v 15 Su̱mutya̱jada ji̱ta Jesús variñi̱: “Ne, daryanuma ra̱cha day, daryanuma vurya̱jto̱taniy ti̱ta̱ju̱ Ju̱denu jtedamuju̱ darya.” Su̱mutya̱jada ji̱ta Juánbay variy jtyadodaju̱ni̱ Jesús.
\v 16 Si̱tyu̱yadanumatiy Jesús, sasipyateda ji̱ta varicha̱ra̱ju̱ ja̱a̱musiy, mityamusiy raseteda jarichu variy, sadiyada ji̱ta siva Ju̱denu Jnutu variy, nu̱tyu ja̱rityude saju̱u̱jeyada variy sivaju̱.
\v 17 Mityamusiy rara̱yada niquejada jarichuvimusiy variy simuntiy: “Jiñu ji̱ta radyenu jaryi ravya̱tasi̱, jaryi ri̱chana̱tyateni̱.”
\c 4
\s1 Bayantu nutyityu̱ juuchanuru̱yadani̱ Jesús
\r (Márcu 1.12-13; Dúcasiy 4.1-13)
\p 
\v 1 Jadchiy ji̱ta sayata̱subeda Ju̱denu Jnutu tajityomuju̱ variñi̱ Jesús, jasityidye sani juuchanuru̱yada bayantu nutyityu̱ variñi̱.
\v 2 Sinra̱da ji̱tara jmyichara variy, daryaju̱yu vu̱yaju̱y rundasa̱ra̱ju̱ ti̱ta̱ju̱, sajachi̱jada ji̱ta variy rivasiy.
\v 3 Siti̱jada ji̱ta Juuchanuru̱ñu variy, su̱teda variy siva Jesús: “Jiñi̱chatiy si̱tenu Ju̱denu denu, ya̱jtay ruuva jivye ravichu̱miy, rirya̱ti̱tuy pa̱joju̱.”
\v 4 Su̱mutya̱jada ji̱ta Jesús variñi̱: “Ne, nu̱charanuma Ju̱denu niquejadamu daryaju̱ darya: Ne sa̱jnu̱chara nijya̱mi̱ ne vinu pa̱ta, sa̱jnu̱chara ji̱ta Ju̱denu niquejadata, ti̱ta̱ju̱ jiryatiy su̱tachara nu̱jyu̱ra.”
\p 
\v 5 Jadchiy ji̱ta sapu̱cheda bayantu nutyityu̱ni̱ Jesús Jerusarí̱muju̱, jiryatiy ru̱tachara Ju̱denumu jiintyasarara vicha̱da. Saranityaniñuvejada Ju̱denu rorivyu̱ nrodencha variñi̱.
\v 6 Su̱teda variy siva: “Jiñi̱chatiy si̱tenu Ju̱denu denu, ya̱jatyate mucomu jiicyu̱, nu̱chara daryaju̱ darya:
\q1 Sa̱jpa̱ Ju̱denuriy yipa̱vay rirya̱tidye jnu̱tya ji, jadchintyi: Rirya̱jiryesumiy jijyomututa ji, jiiñuma jpatyara jiñumutu saniy ravichu̱.”
\p 
\v 7 Su̱teda ji̱ta Jesús variy sivantiy: “Nu̱charanuma Ju̱denu niquejadamuntidyerya:
\q1 Ne ya̱jantya mitya simu yintyityu̱ Ju̱denu.”
\p 
\v 8 Sayata̱da ji̱ta bayantu nutyityu̱ ju̱na̱y ja̱mu musiquisumanchaju̱ni̱ Jesús, sani dityadoda variy ti̱ta̱ju̱ nijya̱nvay mucadini̱, mucadi su̱tyeryasa̱ra̱ju̱ ti̱ta̱ju̱, rádá jarye risa̱ju̱.
\v 9 Su̱teda ji̱ta bayantu nutyityu̱ variy siva Jesús: “Raryi sa̱y jiirya jirya ti̱ta̱ju̱, jiiryityi jadasiñu rañijyu̱ ji.”
\v 10 Jadchiy ji̱ta su̱teda Jesús siva: “¡Ya̱batyé jiyusiy Satanásiy! nu̱charanuma daryaju̱ darya:
\q1 Vurya̱jadasiñu ji̱ta Vu̱ntyityu̱ Vuryi̱ndenu nijyu̱ vu̱y, vinu sanijyu̱ ni̱day vurya̱jachipiya̱sara ti̱ta̱ju̱.”
\p 
\v 11 Jadchiy ji̱ta, satocheda bayantu nutyityu̱ni̱ Jesús. Mityamusiy ruuto̱jada Ju̱denu jpa̱vay simu, ru̱nu̱mya̱nu̱yada variy jasiñi̱.
\s1 Jesús jo̱ta̱da jvaayada Cadidéyamu
\r (Márcu 1.14-15; Dúcasiy 4.14-15)
\p 
\v 12 Satuva̱chodanumatiy Jesús: “Riityema̱ni̱ Juán Bautísta tanuvu̱nujovimu,” sanumuteda ji̱ta variy Cadidéyamuju̱.
\v 13-16 Sasipyateda ji̱ta Nasaryémusiy, savichanuvejada Capernavú̱mu, jiryatiy jmityo̱ jidora, jiryatiy ravichanu̱yada Saburó̱ ju̱rirya vichajo, Nejtadí ju̱rirya vichajo jarye risa̱ju̱, ra̱tidye jto̱tanirya Ju̱denuju̱ tu̱chu̱bay niquejada, Isayíyasibe niquejada:
\q1 “Saburó̱ jtyatara mucadimu, Nejtadí mucadimu jarye, jiryatiy jmityo̱jidora, Jurdá̱ja̱ rudamyu jarye, Cadidéya mucadi ti̱ta̱ju̱ jasityi rivyichasara nijya̱nvay jiryatimyu̱ ne Judíyuveda daryi, rumu vichavajyuu ti̱ta̱ju̱ jiryatiy rivyichasara juuchuveda nupocudimu, riñi dimya̱ ji̱ta riva no̱no̱suma, ratatiy rirya̱datyara Ju̱denu ramityadeda; ra̱sachama̱ rijyu̱ rityi vichasara diiyada nuvachiy jare, jiryatiy rivyichasara diiyasavay.” Daryani̱ su̱teda Isayíyasibe ta̱riy.
\p 
\v 17 Jadchiy ji̱ta sajo̱ta̱da Jesús datyadoda: “Jirya̱paru̱y riva va̱cha jachipiya̱jada, jiryatiy ratuudiñuma Jarichumuvichi̱ nusu̱yada jiryeñe̱cho̱ju̱.”
\s1 Jesús natuyada jichiityari̱vajyu̱ riy dañuju̱yu riicyanuvay
\r (Márcu 1.16-20; Dúcasiy 5.1-11)
\p 
\v 18 Sarupiyadamu Jesús, jiryatiy sarupiyada Cadidéya jmityo̱ jido, sadiyada nadiva danu̱ju̱y nu̱ñi taryi̱ju̱y. Ti̱qui savicha̱da Siimyó̱bay jiryatiy ru̱tañu̱yada Pyítrubantyiñi̱, sataryi̱ vicha̱da Antrésibe. Nanujatyanu̱yadara jiryiicya jmityo̱mu jiryatiy nanuvicha̱da riicyanu̱jyu̱y.
\v 19 Su̱teda ji̱ta Jesús variy nadiva: “Jiyuju̱, ri̱sijyu̱, jiryatiy ra̱bay sa̱da nijya̱nvay ju̱ri̱sanu̱jú̱jyu̱, rirya̱tidye tuva̱chu variy simu Ju̱denu. Ne sa̱na̱ju̱riñi̱ quiva̱nu̱day.”
\v 20 Nanutocheda ji̱ta varicha̱ra̱ju̱ra jiryiicya, nanusiityari̱jada ji̱ta variñi̱.
\p 
\v 21 Saya̱da ji̱ta Jesús jadchiy rayadadeju̱ntiy, sadiñuvejada nadiva tanu̱ju̱y nu̱ñi taryi̱ju̱ntyi, Santiyácuju̱be, sataryi̱ Juánbatya, jiryatiy Sebedévubay denuju̱be nada. Nanuvicha̱da riicya curuchuva̱ñuju̱y jijye̱bejsa̱ cartyevimu. Sanatuyada ji̱ta Jesús nadantiy.
\v 22 Nanutocheda ji̱ta varicha̱ra̱ju̱ra cartye, nanuja̱be risa̱ju̱ntiy, nanusiityari̱jada ji̱ta jadchiñi̱ Jesús.
\s1 Jesús datyadoda riy rajuuvay nijya̱nvay
\r (Dúcasiy 6.17-19)
\p 
\v 23 Sadatyanunumaya̱jada ji̱ta Jesús Cadidéya mucadiva ti̱ta̱ju̱, riintye̱ryanijyovimu, satu̱chutityiyadara samitu̱choda Ju̱denu nusu̱yadanchiy. Sami̱saniñu̱yada riy jdiva̱jnuvay ti̱ta̱ju̱, ti̱ta̱ju̱ rityi vichanu̱yada vadiiryo̱vay nijya̱nvay cabyiva.
\v 24 Rara̱yada ji̱ta sa̱ticheyada variy Síriya mucadimu ti̱ta̱ju̱. Ripyu̱cheda variy simuju̱ riy ti̱ta̱ju̱ jdiva̱jnuvay jiryatiy jaryedo jdiva̱jadatavadyeryi, nuvadavye, ju̱richi̱ni̱miy jarye ruusa̱ju̱, jatamyi jarye, rityi vichanu̱yada bayantutavay yiva ti̱ta̱ju̱. Sami̱sadeda ji̱ta ti̱ta̱ju̱ variryi.
\v 25 Richiityari̱nu̱yada ji̱ta nijya̱nvajyuu variñi̱, jiryatiy ruuti̱jada Cadidéyamusiy, Decápudimusiy, Jerusarí̱musiy jarye risa̱ju̱, ti̱ta̱ju̱ Judéya mucadimusiy, Jurdá̱rudamyusiy jarye risa̱ju̱.
\c 5
\s1 Jesús datyadoda ja̱mumusincha
\p 
\v 1 Sadiyadanumatiy Jesús ruuva nijya̱nvajyuu, sa̱subeda ji̱ta variy ja̱mumusivya. Sama̱sanuvejadanumatiy, rityuudiyada sisa̱ datyavay variyu.
\v 2 Sajo̱ta̱da datyadoda variy jasiryi.
\s1 Muvyerya riñi̱cha Ju̱denu jmu̱tyasavay, muvye
\r (Dúcasiy 6.20-23)
\q1 
\v 3 “Ju̱denu jmu̱tyasavaryi rityi datya jivyichasara jantyuyani̱miy yintumu, tapitya rijyu̱ ji̱ta ravichasara Jarichumuvichi̱ nusu̱jyo day.
\q1 
\v 4 Ju̱denu jmu̱tyasavaryi nuvavye, jiryatiy sa̱jmu̱tyasara riñuvayadajisiyu.
\q1 
\v 5 Ju̱denu jmu̱tyasavaryi sabora jachityavay, jiryatiy rirya̱jmutya̱ra mucadi jiyaru̱ryaju̱.
\q1 
\v 6 Ju̱denu jmu̱tyasavaryi jiryatiy rivyichasara jachi̱vay, jchu̱mu̱vye jarye, samirya jachivyeda vichasa̱dajiju̱, jiryatiy rirye̱cha potyadimyi Ju̱denu jtedamuju̱.
\q1 
\v 7 Ju̱denu jmu̱tyasavaryi jantyutyavay, jiryatiy rirye̱cha jantyutyasavay.
\q1 
\v 8 Ju̱denu jmu̱tyasavaryi jiryatiy pu̱chara jachityavadyeryi, rirya̱dichara daryaju̱ siva Ju̱denu.
\q1 
\v 9 Ju̱denu jmu̱tyasavaryi rityi datyasara jdutya̱dara nique̱tya̱da, jiryatiy rirya̱jtachara tavay rinchiy: Ju̱denu dadyeñu daryi.
\q1 
\v 10 Ju̱denu jmu̱tyasavaryi jiryatiy rivyichasara jarupantasavay vase vichasa̱da jiyadaju̱, tapitya rijyu̱ ji̱ta ravichasara Jarichumuvichi̱ nusu̱yada day.
\q1 
\v 11 Ju̱denu jmu̱tyasavay ji̱ta jiryeñi̱cha rirya̱numatiy javityiye̱ nijya̱nvay rayadasiy jirye, rirya̱numatiy jarupanta jiryentyi, jiryatiy riñiquesara va̱cha tu̱choda quivu̱yadamu jiryeñijyu̱ntiy.
\q1 
\v 12 Jirya̱jchana̱yasiy jaryi jchana̱vye, jiryatiy ja̱murasuma ra̱cha jiryemyurichenusa̱da jarichumu. Darya ni̱day rivyichadeda nijya̱nvay daryaju̱riy Ju̱denuju̱ tu̱chuvabe ta̱riy, jiryatiy jiryemyunatyavaryi, rivyicha̱da Ju̱denu jmu̱tyasavay ru̱co̱siy varintyi.”
\s1 Jesús datyadoda: “Ju̱denu siityari̱vay rañi̱cha nu̱tyu tivyi nta, nu̱tyu no̱no̱ nta jarye, mucadimu vichavajyu̱”
\r (Márcu 9.50; Dúcasiy 14.34-35)
\p 
\v 13 “Jiryeñi̱cha nu̱tyu tivyi jirya mucadi ja̱nvajyu̱; varityi ji̱ta raryi baryi̱ rativyijyu̱vyeda, ¿nu̱tyuramusiña̱ vu̱ryi ta̱ryataniy tivyijyu̱ryaju̱ntirya, nu̱tyuramusiy? Ne samirya taraju̱nu̱darya, vinu jatya̱daju̱ra, rirya̱raniye̱chara nijya̱nvay jasirya.
\p 
\v 14 Jiryeñi̱cha nu̱tyu no̱no̱da jirya mucadija̱nvajyu̱. Ne vana̱y ridyutya ntara ja̱mu vicha̱da jiryatiy musiquincha jvaacharara.
\v 15 Dantyamu̱y ne riryupay nijya̱nvarya jiño̱no̱siiy rirya̱tidye mutanu tarata varirya. Ribechara ji̱ta rabajyonchayu, jasityi rano̱no̱nu̱y rijyu̱ rorimyu vichavay ti̱ta̱ju̱.
\v 16 Ramuni̱ jirya̱no̱no̱nu̱tyanirya jiño̱no̱ nijya̱nvay diya, rirya̱tidye jnu̱rya jiryevyicha̱da samirya, rirye̱jchana̱tya variñi̱ Vu̱jye̱, jiryatiy Jarichumuvichi̱ni̱.”
\s1 Jesús datyadoda Ju̱denu jtedanchiy jiryatiy sabayada samiy vuryi̱nu̱yadaju̱ra
\p 
\v 17 “Ne jirya̱jachipiya̱ raynchiy: Sani jnichara sa̱tidye parutara Ju̱denu jteda, jiryatiy su̱pa̱jada Muyusésibemyusirya, varimyata jijyu̱ tu̱chuvabe jtosiy. Ne ri̱niy paruta̱daju̱ra, ri̱niy ji̱ta ra̱tidye jto̱tanirya.
\v 18 Ri̱tatye ji̱ta si̱tenu daryaju̱ jiryiva: Netimyu̱ ne ra̱parutay jarichu, mucadi jarye risa̱ju̱ didye, ne ra̱ramiy mitya Ju̱denu niquejada nu̱chara teradera, mitya, ra̱day jto̱tanimyu̱chara ti̱ta̱ju̱ra.
\v 19 Ramuni̱ mi̱ni̱tyi raryi rrachura Ju̱denu niquejada teradera jiryatiy pasidyeva̱ju̱ nta darya, saryityi datyanusara darya rrachodariy nijya̱nvantyi, rirya̱jtachara ru̱co̱siy sanchiy: Ni̱day vichasara tamityi̱ Jarichumuvichi̱ nusu̱jyomu. Ni̱ni̱ ji̱ta jiryatiy sito̱tanirya, sadatyanusara varintyirya, rirya̱jtachara sanchiy: Ni̱day vichasara jaryiñu̱ Jarichumuvichi̱ nusu̱jyomu.
\v 20 Ri̱tatye daryaju̱ jiryiva: Netimyu̱ jiryevyichasara vase vichavavya̱ju̱ ruumusiy Ju̱denu niquejada datyanuvay, Varyisévuveda jarye ruusa̱ju̱, ne jirya̱jay Jarichumuvichi̱ nusu̱jyomu variñu̱day.”
\s1 Jesús datyadoda nique̱yadanchiy
\r (Dúcasiy 12.57-59)
\p 
\v 21 “Jiryetyuva̱chuma̱ ji̱ta nu̱tyura su̱teda Ju̱denu ruuva vu̱myunatyavay, nu̱tyu: Ne vurya̱jvay ti̱. Mi̱ni̱tyi jvay ti̱, saryi jmutya̱ra ramurichirya variy ru̱co̱siy.
\v 22 Ray ji̱ta jtay jiryiva: Mi̱ni̱tyi nique̱y riñijyu̱ jityevay nijya̱nvay, saryi jmutya̱ra ramurichirya ru̱co̱siy varintyidye. Ni̱tiy javityiye̱ryi jityevay, saryi nta jiya cadnadumu, sa̱tidye jmutya̱ra ramurichirya; ni̱ jarye jiryatiy sajatyara va̱cha niquejada riñijyu̱ jityevay, saryi nta jmutya̱ra jiidatyo̱mu jatyasa̱da variy ru̱co̱sintyidye.
\v 23-24 Ramuni̱tiy, yintatyaru̱ñumatirya tara Ju̱denunijyu̱, jijechipityatiy varirya: Ratyenu ji̱ta jachipiya̱ tara va̱cha niquejada rañijyu̱, variñi̱ ji̱ta ya̱tojo munatyara yintatyasara, ru̱mutya̱jomu, ya̱tidye jdutyanuve munatya sisa̱ jityenura, rivasiy ji̱ta ya̱jnutatya Ju̱denu nijyu̱ra jiche̱yasara.
\p 
\v 25 Ya̱jachipiya̱ samiy, ya̱tidye jdutya sisa̱ jityu̱chuti̱rá, ya̱numatiy jiya sisa̱ cadnadumu, sañuma ju̱rityaniy nu̱tyu jimyityasiy nta cadnaduta ji, cadnadu ji̱ta ra̱pu̱chityaniy jiivu̱setavay variy ji, rirya̱tidye tanuvu̱nu tanuvu̱nujovimu variy ji.
\v 26 Ri̱tatye si̱tenu yiva: Ne vana̱y ya̱sipyatay jadchiy netimyu̱ ne ya̱murichenu tamitya jicyuriquitya jiyadaju̱ didye.”
\s1 Jesús datyadoda jmuchanutavaynchiy
\p 
\v 27 “Jiryetyuva̱chuma̱ ji̱ta nu̱tyu su̱teda Ju̱denu: Ne jirya̱rupi ti̱ vaturu̱jsa̱.
\v 28 Ray ji̱ta jtay jiryiva: Mi̱ni̱tyi ra̱jnu̱y vaturu̱ñe̱cho̱ jiñi̱ru̱yadamu, sani rupimya̱ nadisa̱ jijechimyu.
\v 29 Nu̱tyi rani̱day jiñi̱siy nutyityuday rañi care Ju̱denu nú̱jisiy ji, ya̱sitya varirya jiñi̱sityadi, ya̱jatya variy yimusirya. Samiryava̱ju̱ daryaju̱ jiijyu̱ ya̱caretanirya taraqui jivyu̱tera, riñuma jatya miryanuvu̱ jiidatyo̱vimuju̱ riva ji.
\v 30 Nu̱tyi rani̱day jijyomutu nutyityuday rañi care Ju̱denu nú̱jisiy ji, ne jirye̱charaju̱u̱, ya̱jatya variy yimusirya; samiryava̱ju̱ daryaju̱ jiijyu̱ ya̱caretanirya taraqui jivyu̱tera, jiiñuma jti̱ miryanuvu̱ jiidatyo̱vimuju̱ riva.”
\s1 Jesús datyadoda tova̱jadanchiy
\r (Matévu 19.9; Márcu 10.11-12; Dúcasiy 16.18)
\p 
\v 31 “Su̱teda ji̱ta Muyusésibentyi: Mi̱ni̱tyi jatyani̱ jivyatura, sa̱ma̱ sa̱y caterava nu̱charani̱, tochivyi̱.
\v 32 Ray ji̱ta jtay jiryiva: Ti̱ vanu jiryatiy sani jatya nada jivyaturu̱y, netimyu̱ naryi rupi ti̱ vanujsa̱, sa̱jarupanu varirya nanuvicha̱da ti̱ta̱ju̱ nijya̱nvay diya, jiryatiy rirya̱diy variy nadiva nu̱tyu jmuchanutanu̱ñada. Daryadantyi mi̱nintyi ja̱mu̱ñada jatyasanu̱y, sa̱jarupanu ratantirya jivyicha̱da nijya̱nvay diyantiy jiryatiy rirya̱diy nu̱tyu jmuchanutodati̱ variy siva.”
\s1 Jesús datyadoda Ju̱denu jtyamu niquejadanchiy
\p 
\v 33 “Jiryetyuva̱chuma̱ ji̱tantiy nu̱tyu su̱teda Ju̱denu ruuva vu̱myunatyavay: Ne jirya̱tu̱chu quivu̱yada Ju̱denu jtyamu tara; ya̱ma̱ jto̱taniy Ju̱denumuju̱ra ti̱ta̱ju̱ jiryatiy yitay si̱tyamura.
\v 34-35 Ray ji̱ta jtay jiryiva: Ne ya̱nique Ju̱denu jtyamu mitya, dantyamu̱y ne vinu jarichunijyu̱ jiryatiy Ju̱denu ma̱sajo daryaju̱ darya, dantyamu̱y ne vinu mucadinijyu̱ jiryatiy Ju̱denu numutu bajyo daryaju̱ra, dantyamu̱y ne vinu Jerusarí̱nijyu̱, jiryatiy ja̱mu nutyityu̱ Ju̱denu nijyu̱ jiintyasara daryaju̱ darya.
\v 36 Daryantyamu̱y ne ya̱nique yino̱nijyu̱, jiryatimyu̱ ne vana̱y ya̱ti̱tunura tajasiqui yino̱jasiy pupajasijyu̱, daryantyamu̱y ne vadacujasijyu̱.
\v 37 Ya̱tiy jtaryu̱y: Jo, mityani̱ ya̱nique: Jo, varimyata ya̱tiy jtaryu̱y Ne, mityani̱ ya̱nique: Ne. Jiryetyi nique ranchaju̱ tara, rani̱ ji̱ta bayantu nicyara̱myusidyerya.”
\s1 Jesús datyadoda jamirya vichadeda murichenutadedanchiy
\r (Dúcasiy 6.29-30)
\p 
\v 38 “Jiryetyuva̱chuma̱ ji̱ta nu̱tyu su̱teda Muyusésibe: Ni̱tiy buchara ti̱ ni̱siy, rirya̱ma̱ bucha rivara sani̱sintyidye; ni̱tiy jarupanura ti̱ ja̱da jachejo, rirya̱ma̱ jarupanu rivara sajachejontidye.
\v 39 Ray ji̱ta jtay jiryiva: Ne jirya̱vanu̱tya sa̱jisiy nicyara̱y jvaaryayu. Ri̱tatye jiryiva: Saryityi jvay ti̱ jiryentyityuday ma̱yaniy jiryejyu̱, jirya̱janumitya variy sana̱cho̱ju̱ra ratarya ma̱yantiy.
\v 40 Saryityi ju̱rityaniryu̱y ti̱ jirye, saryi so̱vay jiryimusirya jiryechujay variy, jirya̱sa̱y jicho̱tájay varintyiñi̱.
\v 41 Saryityi tiityataniy taraqui kilometrusa̱ra̱ju̱ ti̱ tara jijyu̱ jirye, jirya̱ma̱ tiitya daraju̱y kilometrusa̱ra̱ju̱ saju̱ra.
\v 42 Jirya̱sa̱ñi̱ ratiy sajachiñu̱y ti̱ jiryiva; daryaday ne jirya̱jbay sa̱jisirya jiryatiy sava̱tatiy ti̱ jiryimusirya tara jitye̱ryatadedaju̱.”
\s1 Jesús datyadoda: “Vurya̱ntya va̱tasara riy vu̱myityasimyi”
\r (Dúcasiy 6.27-28, 32-36)
\p 
\v 43 “Jiryetyuva̱chuma̱ ji̱ta nu̱tyura ru̱teda: Vurya̱ma̱ va̱tani̱ vu̱tyuunuvichi̱, vu̱myityasiy ji̱ta vurya̱javittyuy.
\v 44 Ray ji̱ta jtay jiryiva: Vurya̱ma̱ va̱tasara riy vu̱myityasimyi; vurya̱tu̱chu sisa̱ Ju̱denu riyadaju̱ntiy rityi jarupantasara vu̱y.
\v 45 Daryamusiy jirye̱cha si̱tenu Vu̱jye̱ dadyeñu, jiryatiy Jarichumuvichi̱ni̱, daryatiy sano̱no̱nu̱tyaniñi̱ jiñi̱ jidchavu̱ ruumu nicyara̱y vichavay, samirya vichavamyu jarye. Daryaday su̱pa̱sarantirya ru̱mura jidchavu̱ rinchaju̱ vase vichavantyi, va̱cha vichavaynchaju̱ jarye ruusa̱ju̱.
\v 46 Vu̱ryityi va̱tasara riy, vinu riy, rityi va̱ta̱da munatya vu̱y, ¿ta̱ra vurya̱jmutya̱ ramusiy, ta̱ra? Tapi darya riñi jvaavya̱ criquiy jmutya̱vantyique, jiryatiy juuchatavaryi.
\v 47 Daryadantyi, vu̱ryityi mu̱chuvachara riy vinu vu̱tyeryi̱veda, ¿ta̱ra vuryivaay ruumusiy tavay, ta̱ra? ¿Ne viy ruuvaay munu̱ñumiy daryantiy?
\v 48 Ramuni̱ vurye̱cha ja̱myi samiy vichavay, daryaday savichasara Vu̱jye̱ Jarichumuvichi̱ntiy.”
\c 6
\s1 Jesús datyadoda samirya jvaayadanchiy
\p 
\v 1 “Jatyí vuryivaarya vase jvaayada, mityatidye rirya̱diy nijya̱nvay riva. Ne vurya̱ jmutya̱ra Vu̱jye̱ Jarichumuvichi̱ murichedoda variy riva.
\p 
\v 2 Ramuni̱tiy, vurya̱numatiy sa̱y tara riy jantyuyani̱miy, ne vurya̱va̱ta rana̱cho̱ nijya̱nvay jchana̱tya̱da vijyo̱mujache, ju̱tye̱ryanijyomu, rupijyomu jarye, nu̱tyu ruuvaay jiryatiy ru̱tu̱yadamu yivaay Ju̱denu jacharaju̱ra. Ri̱tay si̱tenu jiryiva: Ru̱mutya̱mu̱mya̱ra ramurichirya.
\v 3-4 Vurya̱numatiy sa̱y tarariy jantyuyani̱miy, ne vurya̱datyataniryu̱y ti̱ ranchiy, ne vinu vurya̱datyaru̱y vu̱jechimyura, vurya̱tidye sa̱chara dutya̱damusirya. Vu̱jye̱ ji̱ta ni̱tiy dichara riva jiryatiy dutyasara darya, ni̱day ra̱murichenu rivantidyevyu̱y.”
\s1 Jesús datyadoda nu̱tyuramusiy vu̱ryityu̱chu sisa̱ Ju̱denu, nu̱tyuramusiy
\r (Dúcasiy 11.2-4)
\p 
\v 5 “Vurya̱numatiy tu̱chu sisa̱ Ju̱denu, ne vurya̱tu̱chu vijyo̱mujache sisa̱ ju̱tye̱ryanijyomu, rupijyomu jarye, jasityi rirya̱jnu̱y nijya̱nvay rana̱cho̱, nu̱tyu ruuvaay jiryatiy ru̱tu̱yadamu jijyoráchara Ju̱denu jacharaju̱. Ri̱tay si̱tenu jiryiva: Ru̱mutya̱mu̱mya̱ra ramurichirya.
\v 6 Vurya̱numatiy tu̱churu̱y sisa̱ Ju̱denu, vurya̱jay vu̱ryorichivyimu variy, vurya̱mutanu varirya rorijyu̱. Jasiñuma vurya̱tu̱chu Vu̱jye̱jsa̱, ni̱tiy vichasara dutyasi̱. Vu̱jye̱ ji̱ta, ni̱tiy dichara riva jiryatiy dutyasara rani̱cha, ni̱day ra̱murichenu rivantivyu̱y.
\p 
\v 7 Vurya̱numatiy tu̱churu̱y sisa̱ Ju̱denu, ne vurya̱viña̱ra niquejadajuu mitya, nu̱tyu riryesááchara ma̱myi daryá, jiryatiy rijechipiya̱ daryaju̱: Sa̱tuva̱chuta Ju̱denu rajuura rañiquejadiva ray.
\v 8 Ne vurya̱jantyariy darya vichavay, tapitya sadatya Vu̱jye̱ daryaju̱ra ta̱ra vu̱vya̱ta. Vu̱jechiñu̱yadajisiy sadatya̱dara.
\v 9-13 Daryani̱ ji̱ta vurya̱tu̱chu variy sisa̱ Ju̱denu day:
\q1 Ye̱ye̱, jiryatiy Jarichumuvichi̱ ji, suvu̱chara ra̱cha yitya. Ra̱ma̱ ju̱ti̱ yinsu̱yada; ya̱jvaarya jivya̱tara jiyu mucadinchantiy, nu̱tyu daryatiy yivaay jarichumuntirya. Ya̱sa̱y diye jmyichara nu̱y, jirya rundamuju̱, ra̱vintye suru̱y tarundaqui nu̱y. Ya̱ramityaniy mityara nu̱jyuuchuveda murichirya, daryani̱ nu̱ryamityaniy mitya nu̱ntyidyerya jiryatiy ridyivyi tavay nu̱ntyidye. Ne ya̱jara̱y jantya̱damuju̱ nu̱y, dantyamu̱y ne ya̱tochiy nu̱ña̱siquita ramuyu. Ya̱jantyuy nicyara̱y bayantujisiy nu̱dyiva. (Tapi jiberya ji̱ta daryaju̱ra nusu̱yada day, vanu̱yada jarye, vanda jarye ti̱ta̱ju̱ ju̱na̱reju̱. Daryanuma ra̱chajaya̱sara.)
\m 
\v 14 Tapi vu̱tyi ramityaniy mitya daryaju̱ra ricyarayada nijya̱nvay, daryaday Vu̱jye̱ Jarichumuvichi̱ ra̱ramityaniy mityara vu̱cyarayadantidye.
\v 15 Netimyu̱ ne vurya̱ramityaniy mityara nijya̱nvay carayada, dantyamu̱y ne sa̱ramityaniy Vu̱jye̱ mityara vu̱cyarayada varintyidye.”
\s1 Jesús datyadoda jmyichara jnura̱danchiy
\p 
\v 16 “Vurya̱numatiy jdara jmyichara, ne vurya̱dityanu vayivye varivyu̱y, nu̱tyu rirya̱vatya nijya̱nvarya jimyo̱ jiryatiy ru̱tu̱yadamu jidyityanuru̱y Ju̱denunijyu̱ jachipiya̱vayu. Riñi va̱ta daryaju̱ rirya̱datya tavarya yinra̱da. Ri̱tay si̱tenu jiryiva: Ru̱mutya̱mu̱mya̱ra ramurichirya.
\v 17-18 Vurya̱numatiy jdara jmyichara, vurya̱jdutyara vuryi̱no̱jasiy variy, vurya̱suutantirya vu̱myo̱ varintyi, riñuma datya nijya̱nvarya vuryi̱nra̱da day, vinu Vu̱jye̱ dutyasi̱ ra̱datya darya. Vu̱jye̱ ji̱ta ni̱tiy dichara riva jiryatiy dutyasara darya, ni̱day ra̱murichenu rivantivyu̱y.”
\s1 Jesús datyadoda nu̱tyuramusiy vurye̱cha jaryi taratavay jarichumu
\r (Dúcasiy 12.33-34)
\p 
\v 19 “Ne vurya̱bay jirya mucadimu vurya̱jiju̱ra jaryi murichevarya tara, jasityi ra̱baryi̱sara ruvá jbyedamusiy, cansiiyadamusiy jarye, varimyata jasityi rirya̱jay paranu̱ni̱miy paradodana̱cho̱.
\v 20 Vurya̱numa bay jarichumu vurya̱jiju̱ra jaryi murichevarya tara, jasityimyu̱ ne ra̱baryi̱sara ruvá toyedamusiy, dantyamu̱y ne cansiiyadamusiy, dantyamu̱y ne rirya̱jachara paranu̱ni̱miy paradodana̱cho̱.
\v 21 Jasityi ravichasara vu̱berya jaryi murichevarya, jasintya ra̱chasara vu̱jechipiya̱jada varintyi.”
\s1 Jesús datyadoda vu̱vyu̱ no̱no̱siinchiy
\r (Dúcasiy 11.34-36)
\p 
\v 22 “Vu̱ñi̱siy ji̱ta vu̱vyu̱ no̱no̱siiy. Ramuni̱tiy, samichityirya vu̱ñi̱siy, jiryatiy vu̱jechipiya̱sara samirya jvaacharanijyu̱, ti̱ta̱ju̱ vu̱vyu̱ ji̱ta ra̱cha variy no̱no̱mu.
\v 23 Netimyu̱ ne raryi jnu̱y vu̱ñi̱siy samiryana̱cho̱, ti̱ta̱ju̱ vu̱vyu̱ ji̱ta ra̱cha variy nupocudi. Varityi ra̱vichasara nupocudi vu̱ño̱no̱, nupocusuma ra̱cha variy vu̱jechimyu.”
\s1 Jesús datyadoda: “Ne vana̱y vuryivaay Ju̱denuju̱, criquijyu̱ jarye risa̱ju̱”
\r (Dúcasiy 16.13)
\p 
\v 24 “Ne vana̱y vuryivaachara danu̱ju̱y patru̱sa̱. Vu̱ryityi jvaaryu̱y nadisa̱, vu̱ryi javittyuñi̱ ti̱qui, vu̱ryi va̱tasara variñi̱ ratarya patru̱, varimyata vu̱ryi jvaay vani̱ri̱ sisa̱ ti̱qui, vu̱ryi javiryu̱tya variñi̱ ratarya patru̱. Dantyamu̱y ne vana̱y vuryivaay sisa̱ Ju̱denu, criquisa̱ jarye, jiryatiy vu̱vyichasara criquiy ju̱redacanumiy.”
\s1 Jesús datyadoda: “Su̱nu̱tyasara Ju̱denuriy jidyedyeñu”
\r (Dúcasiy 12.22-34)
\p 
\v 25 “Ramuni̱ ri̱tay jiryiva: Ne vurya̱jachipiya̱ jaryi: ¿Ta̱ra vurye̱jmyi, ta̱ra? varimyata: ¿Ta̱ra vurya̱jatu vuryi̱nu̱yadaju̱, ta̱ra? dantyamu̱y ne vurya̱jachipiya̱: ¿Ta̱ra vurya̱jachu vuryiva, ta̱ra? ¿Neviy vuryi̱nu̱yada jaryi jmyichara jiyadaju̱ day, vu̱vyu̱ ji̱ta sujay jiyadaju̱ntidye?
\v 26 Jirya̱jnu̱y ruuva vindyamu vichavay viichemyi. Ne rinta, dantyamu̱y ne rirya̱to jatosara bajyomuju̱ra, Vu̱jye̱ Jarichumuvichi̱ ji̱ta potyanichara varidyeryi. ¿Neviy vu̱myurichevay jaryi ruumusidye?
\v 27 ¿Mi̱ra vuryisa̱ vichi̱ ra̱sityechu jijechipiya̱jadamusirya yinu̱yada, mi̱? rata̱savu̱ métrusa̱ra̱ju̱.
\v 28 ¿Ta̱raju̱na̱ vurya̱jachipiya̱ variy ranijyu̱ vu̱chujay, ta̱raju̱? Vurya̱jachipiya̱ ranijyu̱ tova vichara javu̱ñi̱sityu, nu̱tyuramusiy raja̱vye, nu̱tyuramusiy. Ne rivaay, dantyamu̱y ne raruyinura nura̱biju̱u̱ jichujajyu̱sara.
\v 29 Ri̱tatye ji̱ta jiryiva: Ne vinu nutyityu̱ Sadumú̱bay samiy yidutyasa̱damu jivyicha̱da sami̱va̱ju̱ ramusiy.
\v 30 Saryityi sujañu Ju̱denu daryara samirya vachuy jiryatiy nudivyara, jiryatiy raja̱vye diye, ta̱rimyusiy rirya̱jatya jiidamyura, ¿ne vidye sa̱sujañu Ju̱denu jirye, nijya̱nvay pasidye jachipiya̱vay?
\v 31 Ramuni̱mu̱y ne vurya̱jachipiya̱: ¿Ta̱ra vurye̱jmyi, ta̱ra? dantyamu̱y ne vurya̱jachipiya̱: ¿Ta̱ra vurya̱jatuntiy, ta̱ra? dantyamu̱y ne vurya̱jtay: ¿Ta̱ra vurya̱jachu vuryivanticyu̱, ta̱ra?
\v 32 Nijya̱nvay ji̱ta va̱tasara daryaju̱ra jirya ti̱ta̱ju̱. Sadatya ji̱ta Vu̱jye̱ Jarichumuvichi̱ jiryatiy vu̱vya̱tasarara jirya ti̱ta̱ju̱.
\v 33 Vurya̱ntya va̱ta munatya rana̱cho̱ Ju̱denu nusu̱yada nijya̱nvay jachipiya̱jadamu, vase vichasa̱da jarye risa̱ju̱, vurya̱sarye varirya vuryi̱myi̱sara, vurya̱tu̱sara jarye risa̱ju̱ ti̱ta̱ju̱.
\v 34 Ramuni̱mu̱y ne vurya̱jachipiya̱ jaryi ta̱rimyusiy rundamuju̱, tapitya rani jachipiya̱sara ta̱rimyusiy yajiju̱. Rasa̱ra̱numa ji̱ta paru̱cha̱riy nu̱ñi tarundaquiju̱.”
\c 7
\s1 Jesús datyadoda: “Ne vurya̱jachipiya̱ taji tu̱chuta̱da ti̱nijyu̱”
\r (Dúcasiy 6.37-38, 41-42)
\p 
\v 1 “Ne vurya̱jachipiya̱ taji ti̱nijyu̱, sañuma jachipiya̱ taji variy vu̱ñijyu̱ntidye.
\v 2 Tapitya sa̱jachipiya̱ Ju̱denu vu̱ñijyu̱, daryaday vu̱jechipiya̱ tavañijyu̱ntidye. Daryatiy vu̱charanu tavajyu̱ tara, daryaday rirya̱saranu variy vu̱jyu̱ntidye.
\v 3 ¿Nu̱tyichiy vu̱ryidyi vu̱tyeryi̱ ni̱simyu riva radaryudyera, nu̱tyichiy? netimyu̱ ne vu̱dyetya ravicha jiipudaryuy vu̱ñi̱simyu.
\v 4 ¿Nu̱tyuramusiy vurya̱jtay siva vu̱tyeryi̱, nu̱tyuramusiy? Ra̱day sipyata jiñi̱simyusirya radaryudyera, ravichatiy jiipudaryuy vu̱ñi̱simyu.
\v 5 Netimyu̱ ne vuryi̱tu̱yadamu vichavavyu̱y, vurya̱sipyata munatya vu̱ñi̱simyusirya jiipudaryuy, rivasiy ji̱ta vurya̱diy riva vanda, vurya̱tidye sipyata variy vu̱tyeryi̱ ni̱simyusirya radaryudyerantidye.
\p 
\v 6 Ne vurya̱tu̱churu̱rya Ju̱denu datyadoda samirya ruuva, jiryatiy rivyichasara nu̱tyu nibyimiy rapu̱ryamiy, riñuma seta su̱yadamu vu̱y; varimyatamu̱y ne vurya̱jatyara Ju̱denu niquejada samirya ruuva, jiryatiy rivyichasara nu̱tyu cuchimyi rapu̱ryamiy, riñuma raniye̱ mucadinubeju̱ra.”
\s1 Jesús datyadoda: “Vu̱ryi jachiñu̱y, vu̱ryi va̱ta, vu̱ryi natuye̱ sana̱cho̱ rorijya̱mi̱”
\r (Dúcasiy 11.9-13)
\p 
\v 7 “Vurya̱ma̱ jachiñu̱yencha Ju̱denuvara vu̱vya̱tara, sa̱sa̱y ji̱ta variy vu̱rya; vurya̱ma̱ va̱ta̱numucha simu rana̱cho̱, vurya̱sarye ji̱ta varirya; vurya̱ma̱ natuye̱yencha rorijyu̱mu, sa̱muttay ji̱ta rorijya̱mi̱ variy vurya̱jisirya.
\v 8 Tapi ni̱tiy jachiñu̱yencha, sa̱jmutya̱ varirya; ni̱tiy va̱ta̱numucha rana̱cho̱ntiy, sa̱sarye varintyirya; ni̱tiy natuye̱yencha rorijyu̱mu, daryaday ra̱muttay variy saju̱ntiy.
\v 9 Saryityi jachiñu̱y dera siva jijye̱rya pa̱, ¿sa̱ni̱tiy sa̱y variy ravichu̱ dañi̱?
\v 10 Varimyata saryityi jachiñu̱y jijye̱vyani̱ quiva̱, ¿sanitiy sa̱y codiy varidyeñi̱?
\v 11 Jirye ji̱ta, jiryatiy jamirya vichavay jiryedye, jiryedyetyatiy sa̱yada tara samirya riy jidyedyeñu, ta̱ jaryivya̱ju̱ sa̱sa̱y Vu̱jye̱ Jarichumuvichi̱ tara samirya vu̱y vu̱tyi jachiñu̱y sivara tara.
\p 
\v 12 Ramuni̱ vurya̱ma̱ vichaniy darya riy tavantyidye, daryaday vu̱ryivya̱ta rirya̱vichanintyidyevyu̱y, tapi daryani̱ sadatyadoda Ju̱denu Muyusésibemyusiy vu̱y, saju̱ tu̱chuvabemyusiy jaryentiy.”
\s1 Jesús datyadoda pasijyu̱ jajyonchiy, jasityi vurya̱jachara Ju̱denu nusu̱jyomuju̱
\r (Dúcasiy 13.24)
\p 
\v 13 “Vurya̱jay pasijyu̱ rorijyu̱demusiy; tapi jajyo ji̱ta jiryatiy vojotarara, ne surra jajyo darya, rumutiy vurya̱jay vu̱pyarutedaju̱. Rajuuvay ji̱ta jachara rumu day.
\v 14 Tapi jajyo ji̱ta rumutiy vurya̱jay ju̱na̱re jnu̱yadaju̱, jiryatiy pasijyu̱derara, vu̱je paru̱cha̱rimyusiy variy ravimu. Rajuutya variryi jiryatiy richeryera pasijyu̱mu jayada.”
\s1 Jesús datyadoda: “Vu̱dyetyara ni̱nu rajomusiy daryatiy sadatyasara Ju̱denuni̱ nijya̱mi̱ sivaayadamusintyi”
\r (Dúcasiy 6.43-44)
\p 
\v 15 “Vurya̱jnu̱tyasara rirya̱jisivyu̱y, rityimyu̱ ne si̱tenu Ju̱denuju̱ tu̱chuvadyeryi. Riñi dityanu nu̱tyu Ju̱denu siityari̱vay nta vu̱quebyimuyu, nu̱tyu carni̱rumiy sabuvye nta. Dañumamu̱y ne rivyichasara si̱tenu jijechimyu. Rivyichasara ji̱ta nu̱tyu jmyirya jachi̱jadacanumiy, jiryatiy ricya̱siryu̱ryi Ju̱denu siityari̱vay.
\v 16 Vurya̱datya ruuvaayadamusiyu, daryani̱ vu̱dyetyara ni̱nu rajomusiy. ¿Vu̱cho ni̱tidyerya samu̱siy cariitunumusidye? ¿varimyata ramuya̱ ju̱bonumusiy?
\v 17 Darya ni̱day ti̱ta̱ju̱ra ni̱nu samiñu, rani jontay samijyo; ni̱nu nicyara̱ñu ji̱ta jontay nicyara̱jyo day.
\v 18 Ne vana̱y rajontay samiñu, nicyara̱jyo; dantyamu̱y ne vana̱y rajontay nicyara̱ñu, samijyo.
\v 19 Rirya̱jnu ji̱tara ni̱nuvicha̱ jiryatimyu̱ ne samirya jorara, rirya̱jatya jiidamyu variy rivara.
\v 20 Darya ni̱day vurya̱datya riy nijya̱nvay ruuvaayadamusiy, nu̱tyu vu̱dyetya daryara ni̱nu jijyomusiy, samiryavidye rani̱cha.”
\s1 Jesús datyadoda: “Ne rirya̱jay ti̱ta̱ju̱ nijya̱nvay Jarichumuvichi̱ nusu̱jyomuju̱”
\r (Dúcasiy 13.25-27)
\p 
\v 21 “Rityi jtachara riva: Nutyityu̱, ne rirya̱jay ti̱ta̱ju̱ Jarichumuvichi̱ nusu̱jyomuju̱; vinu rityevay jiryatiy ruuvaacharara rajye̱ va̱tara, jiryatiy Jarichumuvichi̱ni̱, vinu riy ra̱jay ramuju̱.
\v 22 Tamitya rundamu ji̱ta rirya̱jtay rajuuvay riva: Nutyityu̱, ¿neviy nu̱tyu̱choda yityamu, nu̱jetya̱dantiryi bayantuveda nijya̱nvavyasiy yityamuntiy, nu̱dyivaayadantirya rajuura mityamusiy ju̱dejada yityamuntidye?
\v 23 Jadchiy ji̱ta ra̱jmutya̱ variryi: ¡Tama̱ radyetyavay jirye, tama̱; jirya̱numa jiya ratyuunusiy, nicyara̱y vichavaryapu̱rya!”
\s1 Jesús datyadoda nu̱tyura ju̱daryancha vu̱ryi vichajaya̱sara ti̱ta̱ju̱
\r (Dúcasiy 6.47-49)
\p 
\v 24 “Ti̱ta̱ju̱ nijya̱mi̱ ni̱tiy tuva̱chusarara rañiquejada, sasiityesara variy raju̱ntiy, ni̱ni̱ sani̱cha nu̱tyu vanu datyara jiryatiy sivaayada samidyera jiryoriy, su̱muchura yituvu̱ surraju̱ntiy.
\v 25 Ru̱boda ji̱ta variy, ranijye̱yada ji̱ta varintyi. Ja̱mu riicho jarye ja̱tyo̱jada ranintyi, raryi no̱tavya̱ ramusiy riicho, jiryatiy samiy jmuchusara daryaju̱ra ru̱tuvu̱.
\v 26 Ti̱ta̱ju̱ nijya̱mi̱ ni̱tiy tuva̱chu ji̱tara rañiquejada, dantyamu̱y ne sasiityeru̱y variy raju̱, ni̱ni̱ sani̱cha nu̱tyu vanu datyi̱sa̱ jiryatiy sivaayada ti̱cha̱nchara jiryoriy.
\v 27 Ru̱boda ji̱ta, ranijye̱yada varintyi, ja̱mu riicho jarye ja̱tyo̱jada ranintyi, rano̱ta̱da variy riichora, rajottimyu̱yada ti̱ta̱ju̱ varirya, pattaryityera.”
\p 
\v 28-29 Sadatyanumu̱yadanumatiy Jesúsra jirya datyadoda, rityi̱tta̱da nijya̱nvay varirya jiryatiy sadatyadoda jidyirya datya̱data riy, ne nu̱tyu Ju̱denu niquejada datyanuvadye.
\c 8
\s1 Jesús mi̱sadedani̱ vatajo̱nni̱bay
\r (Márcu 1.40-45; Dúcasiy 5.12-16)
\p 
\v 1 Su̱musa̱danumatiy Jesús musiquimusiy, richiityari̱jada nijya̱nvajyuu variñi̱.
\v 2 Mityamusiy sa̱dasiñunuvi̱jada vatajo̱ju̱ñubay satuunuyu, su̱teda variy siva Jesús: “Nutyityu̱, jivya̱tatiy, ya̱pu̱y rivasirya vatajo̱.”
\v 3 Saratya̱da ji̱ta Jesúsra jijyase variy sana̱cho̱ju̱, saja̱tyo̱jada variy saniy. Su̱teda ji̱ta variy siva: “Ravya̱tantye, sami̱numa ye̱cha.” Varicha̱ra̱ju̱ rabayada vatajo̱ sivasiy.
\v 4 Su̱teda ji̱ta Jesús variy siva: “Jatyí jityu̱chosiy ti̱devara. Ya̱numa ji̱ta jiya, ya̱tiy dityanunuve caserdóte ji. Rapu̱chama̱ daryaju̱ jivyatajo̱ yivasiyu, ne ti̱ ji̱ta ra̱suvu̱ñu̱day ji. Ramuni̱ ya̱sa̱dyerya jnutatyasara Ju̱denumu day, jiryatiy Muyusésibe jtedamuju̱ra, rirya̱tidye datya nijya̱nvay variy ránchiy: Ne ra̱ja̱tay ji̱ta jivyatajo̱ ti̱vaju̱nu̱day.”
\s1 Jesús mi̱sadedani̱ su̱tarumiy nutyityu̱bay muchechibe
\r (Dúcasiy 7.1-10; Juán 4.43-54)
\p 
\v 5-6 Sajayadanumatiy Jesús Capernavú̱mu, sayasantanuvi̱jada su̱tarumiy nutyityu̱bay variy jasiñi̱: “Nutyityu̱, detiryo̱numa ju̱richi̱ni̱ ramyuchechiy raryorimyu, paru̱cha̱riñumani̱.”
\v 7 Su̱teda ji̱ta Jesús variy siva: “Ra̱day jiya sami̱sadedana̱cho̱.”
\v 8 Su̱tarumiy nutyityu̱bay ji̱ta jmutya̱jada jasiñi̱: “Nutyityu̱, tama̱ racha̱ra̱nu ntate day ji ya̱jto̱jay raryorimyu, tama̱. Mitya ya̱niquera niquejada, sa̱day mi̱sa̱sumiy variy ramyuchechiy.
\v 9 Tapi ray ji̱ta vichasara sabonichi̱ rayntyityu̱ju̱ day, rachabonintyiryi su̱tarumintyi. Ri̱tay siva ti̱: ¡Ye̱jiya! saya variy; nu̱vantiy: ¡Ya̱jniy! su̱niy varintyi; ri̱tatyi ramyuchechivyantiy: ¡Ya̱jvaarya jirya! sivaay varintyirya.”
\p 
\v 10 Satuva̱chodanumatiy Jesúsra saniquejada, sati̱tta̱da varirya, su̱teda variy ruuva jichiityari̱vay: “Ri̱tatye si̱tenu jiryiva: Netaramu vinu vu̱tyevay Irayénuveda cabyimu radyi ti̱va nu̱tyu jiñu, vuryimu tuva̱churá.
\v 11 Ri̱tay jiryiva: Rirya̱jti̱ rajuuvay jiryatimyu̱ ne Judíyuveda daryi. Rirya̱jti̱ jiñi̱ mu̱ti̱jomusiy, sapuryejomusintyi Jarichumuvichi̱ nusu̱jyomu, jasityi rirya̱ma̱sa jmyijyomu Avurá̱ bayanujsa̱, Isácu bayanujsa̱ jarye, Jacóbu bayanujsa̱ jarye ruusa̱ju̱ ti̱ta̱ju̱.
\v 12 Rityi jaryu̱y nta Ju̱denu nusu̱jyomu, jiryatiy Avurá̱bay dadyeñu daryi, rirye̱cha jatyasavay bimuju̱, nupocudimuju̱, jiryatimyu̱ ne rityuva̱churu̱y daryaju̱ rimu. Jasidye ji̱ta rirya̱jna̱vya̱ nijya̱nvay variy, rirya̱su̱y ji̱ta jijya̱dajchantiy.”
\p 
\v 13 Su̱teda ji̱ta Jesús variy siva su̱tarumiy nutyityu̱bay: “Ya̱numa jiya, daryanuma ra̱cha jiijyu̱ daryatiy jityuva̱chosiy ramu.”
\p Sami̱sa̱da ji̱ta samuchechibe varenude variy.
\s1 Jesús mi̱sadeda nada Pyítrubay desedabay
\r (Márcu 1.29-31; Dúcasiy 4.38-39)
\p 
\v 14 Sajayadanumatiy Jesús variy Pyítrubay rorivyimu, sadiyada ji̱ta nadiva Pyítrubay desedabay nanderu̱y tiryo̱ saduyadanu̱y.
\v 15 Saja̱tyo̱jada ji̱ta nanujomutuniy, raparu̱yada ji̱ta saduyada variy nadiva. Nanunubesubeda ji̱ta variy, nanupotyadeda variy jasiñi̱ Jesús.
\s1 Jesús mi̱sadeda riy jdiva̱jnuvajyuubay
\r (Márcu 1.32-34; Dúcasiy 4.40-41)
\p 
\v 16 Sapuryeyadanumatiy jiñi̱, ruuti̱ta̱da ji̱ta Jesúsmu riy rajuuvay bayantutavabe, sajatya̱da jiñiquejadata jasiy ruuvasiryi bayantuveda, sami̱sadeda ji̱ta riy ti̱ta̱ju̱ jiryatiy jdiva̱jnuvay jasidyeryi.
\v 17 Ramusiy ji̱ta sito̱tadedara Ju̱denuju̱ tu̱chu̱ Isayíyasibe jteda:
\q1 “Saso̱vedara vuryi̱diva̱jada, satiitya̱dara vurya̱rupantasa̱da variy risa̱ju̱.”
\s1 Rityi siityari̱ru̱yadani̱ Jesús
\r (Dúcasiy 9.57-62)
\p 
\v 18 Sadiyadanumatiy Jesús ruuva nijya̱nvajyuu yiro̱, su̱teda ruuva yisa̱ datyavabe: “Vurya̱ramityeryi̱ jmityo̱rudamyuju̱.”
\v 19 Su̱tañuvi̱jada ji̱ta Ju̱denu niquejada datyanu̱bay variy siva: “Datyanu̱, ra̱siityari̱ ji rumutiy ye̱jiya.”
\v 20 Su̱teda ji̱ta Jesús variy siva: “Vitiñu ji̱ta vuditi̱, viiche jarye ruutyi̱, Nijya̱mi̱denu ji̱tamu̱y ne vichajoti̱ jasityi sa̱tiryo̱ jime̱yadaju̱.”
\v 21 Nu̱ntiy, sasiityari̱vay tenubay jteda siva Jesús: “Nutyityu̱, ra̱jmuchuchidyi munatyara rajye̱ babyi.”
\v 22 Su̱teda ji̱ta Jesús variy siva: “Ya̱siityari̱sara ray. Rityi vichasara jijyuuchuvedamu diivye rirya̱ma̱ jmuchuni̱ jiryenu diibyi day.”
\s1 Jesús ndasadedara riicho, ri̱ye̱rya jarye risa̱ju̱
\r (Márcu 4.35-41; Dúcasiy 8.22-25)
\p 
\v 23 Su̱musa̱danumatiy Jesús cartyevimuju̱, richiityari̱jada ji̱ta sisa̱ datyavayu.
\v 24 Mityamusiy rariichósubeda ji̱ta jmityo̱mu, ramutanuru̱yada ri̱ye̱rya varirya cartye. Jesús ji̱ta ma̱yada jasiy variy.
\v 25 Rityuudiyadanumatiy sisa̱ datyavabeyu, riidyoseda ji̱ta variñi̱ Jesús jiñiquejadata: “¡Ya̱jantyuy nu̱dyiva, Nutyityu̱, vurya̱numa caraye̱!”
\v 26 Su̱teda ji̱ta Jesús variy ruuva: “¿Ta̱raju̱ra jiryechuvu̱y, pasidye jachipiya̱vay, ta̱raju̱?” Sanubesubeda ji̱ta variy, sanique̱tya̱da ji̱tara riicho, jmityo̱ jarye risa̱ju̱, ju̱vaya̱numa rama̱cho̱jada ja̱a̱ variy.
\v 27 Rityi̱tta̱da ji̱ta vaduy varirya: “¿Nu̱tyu̱ nijya̱mi̱na̱ sani̱cha jiñu, nu̱tyu̱? ¿Nu̱tyi ratuva̱chu riicho simu, jmityo̱ja̱a̱ jarye tuva̱chu simuntiy?”
\s1 Jerása ja̱mi̱ju̱y bayantutanu̱jyu̱be
\r (Márcu 5.1-20; Dúcasiy 8.26-39)
\p 
\v 28 Sito̱jadanumatiy Jesús jmityo̱ rudamyu, Jerása ja̱nvay mucadimu, nani̱deda ji̱ta danu̱ju̱y vanuju̱y bayantutanu̱jyu̱be variy si̱dcho̱ju̱. Nanusipyateda suvu̱chanu̱jyu̱y bapyo cabyimusiy, ne riryamiryi̱ru̱yada nijya̱nvay ranú̱va variy.
\v 29 Nanuniquejasubeda ji̱ta mityamusiy: “¿Ta̱ra na̱dyimu jijyu̱, Ju̱denu denu, ta̱ra? ¿Yiti̱ma̱viy ya̱tidye jantyunuva̱y murichenutadeda rundajisiy na̱y?”
\p 
\v 30 Riibyesa̱deda ji̱ta tajuuqui cuchimyi ripyapude jasiy.
\v 31 Riyasanta̱da ji̱ta bayantuvedani̱ Jesús: “Ya̱numatiy jatya nu̱y, ya̱jpa̱jasiy cuchijyuuvaju̱ nu̱y.”
\v 32 Su̱teda ji̱ta ruuva: “¡Jirya̱numa jiya jiyusiy!” Richipyateda ji̱ta vanuju̱bevyasiy, rijeyada variy cuchivya. Mityamusiy richiichiye̱yada cuchijyuu ti̱ta̱ju̱ nubañuco̱vimu jmityo̱vimuju̱, ripyaruteda ji̱ta ja̱a̱jariy, pattaryitye ti̱ta̱ju̱riy.
\v 33 Cuchiy jnu̱tyavabe ji̱ta baye̱yada variy, rityu̱chunuvejada ja̱mu vicha̱damu ti̱ta̱ju̱ra, nu̱tyunuma nanuvicha̱da bayantuvedatanu̱jyu̱ntyi.
\v 34 Jadchiy ji̱ta richipyateda vicha̱da ja̱nvavyedabay si̱dcho̱ju̱ Jesús. Ridyiyadanumatiy siva, riyasanta̱da ji̱tani̱: “¡Ya̱numa jiya nu̱myucadimusiy!”
\c 9
\s1 Jesús mi̱sadedani̱ ju̱richi̱ni̱bay
\r (Márcu 2.1-12; Dúcasiy 5.17-26)
\p 
\v 1 Su̱musa̱danumatiy Jesús cartyevimuju̱, saramityeda ji̱ta jmityo̱ rudamyuju̱ntiy, su̱deda ji̱ta jivyicha̱damuju̱ntiy.
\v 2 Mityamusiy ruuti̱ta̱dani̱ ju̱richi̱ni̱bay detiryo̱ jime̱yancha. Su̱nu̱yadanumatiy Jesús riñe̱cho̱, jiryatiy rijechipityaja̱jada si̱tenu mi̱sanirya daryaju̱ni̱, su̱teda ji̱ta siva ju̱richi̱ni̱bay: “Ya̱vanu̱tya ji, Pi̱, jiryatiy jijyuuchuveda ra̱ramiy mitya yiva.”
\p 
\v 3 Mitya ru̱teda Ju̱denu niquejada datyanuvay tevabe jivyimu: “Jiñu vanu ji̱ta javityiye̱ñi̱ Ju̱denu day.”
\v 4 Sadatya̱danumatiy Jesúsra rijechipiya̱jada, su̱teda ji̱ta ruuva: “¿Nu̱tyuraju̱ra jiryejechipiya̱ va̱cha jijechimyu, nu̱tyuraju̱?
\v 5 ¿Miryara jaryi datyasara, mirya? ra̱tiy jtay: Jijyuuchuveda ra̱ramiy mitya yiva, varimyata ra̱jtay: Ya̱nubesumiy, ya̱rupichiy.
\v 6 Jirya̱tidye jnu̱yasiy sa̱vidye ramityaniy Nijya̱mi̱denu sivara jijyuuchuveda jirya mucadimu,” su̱teda variy siva ju̱richi̱ni̱bay: “Ya̱nubesumiy, ya̱nchura jime̱ya, ya̱numa jiya jiryorimyuju̱ day.”
\v 7 Sanubesubeda ji̱ta, saya̱da variy jiryorimyuju̱.
\v 8 Ridyiyadanumatiy nijya̱nvajyuuvedabay variy riva, ru̱nteda ji̱ta, riichana̱tya̱da variñi̱ Ju̱denu, jiryatiy sasa̱yada darya jvaayadaju̱ni̱ nijya̱mi̱.
\s1 Jesús natuyadani̱ Matévubay
\r (Márcu 2.13-17; Dúcasiy 5.27-32)
\p 
\v 9 Saramiryi̱jadanumatiy Jesús jadchiy, sadiyada siva nu̱ vanu, sama̱sa̱da criquiy jmutya̱jomu, Matévu jtyati̱bay. Su̱teda ji̱ta siva: “Ya̱siityari̱sara ray.” Sanubeseda ji̱ta variy, sasiityari̱jada ji̱ta jadchiñi̱ Jesús.
\p 
\v 10 Sama̱sa̱danumatiy Jesús jmyijyomu Matévubay rorimyu, mityamusiy rimya̱sa̱da ji̱ta rajuuvay criquiy jmutya̱vavyedabay, jiryatiy juuchatavay risa̱ju̱ntiryi sisa̱ Jesús, sisa̱ datyavabejsa̱ jarye.
\v 11 Ridyiyadanumatiy Varyisévuvedabay riva jiryatiy si̱byeda ruusa̱ juuchatavabe, ru̱teda ji̱ta ruuva Jesúsjsa̱ datyavabe: “¿Ta̱raju̱ si̱myi jiryedyetyanu̱ ruusa̱ criquiy jmutya̱vay, ta̱raju̱? ¿Ne jiryi̱nu̱y juuchatavadyeryi?”
\v 12 Satuva̱chodanumatiy Jesúsra riñiquejada, su̱teda ji̱ta ruuva: “Jiryatimyu̱ ne jdiva̱jnuvadyeryi, ne rivya̱tani̱ jdanu̱nu̱day; jiryatiy jdiva̱jnuvadyeryi, riñi ji̱ta va̱tani̱ ji̱ndanu̱ day.\f * \fr 9:12 \ft Juuchatavay vichasara jdiva̱jnuvay Ju̱denu diya; jndanu̱ vichasara Vuryeyada Rá̱ñu.\f*
\v 13 Jirya̱numa datyanuve ta̱ra ranique, ta̱ra: Radyiryu̱y ji̱ta riva jantyutya̱da, ne vinu jiryatiy jiryi̱ntatyani̱ yasi̱ rimu. Ne ri̱niy daryaju̱ samirya vichavay natuyadana̱cho̱ day, juuchatavay natuyadana̱cho̱ ji̱ta ri̱nidye.”
\s1 Ruutaja̱dodani̱ Jesús jmyichara jnura̱danchiy
\r (Márcu 2.18-22; Dúcasiy 5.33-39)
\p 
\v 14 Jadchiy ji̱ta ru̱deda Juán Bautístabaysa̱ datyavabe simu Jesúsntiy: “¿Ta̱raju̱ vuryi̱nurasarara jmyichara japichiy, ta̱raju̱? Varyisévuvedajsa̱ datyavay jarye, jiryisa̱ datyavay ji̱ta tama̱ riñi jnura darya jmyichara day, tama̱.”
\v 15 Su̱teda ji̱ta Jesús variy ruuva: “Ne vana̱y rirya̱yivay musuchavay ja̱mu̱yada rundamu, netimyu̱ ne sani jiintye ja̱mu̱ñu ruusa̱siy didye. Ra̱jti̱ rarunda varityi rirya̱so̱vay riquebyimusiñi̱ vadi ja̱mu̱ñu, variryundamu ji̱ta rirya̱ndara jmyichara.
\v 16 Ne vu̱cyuruchuva̱y vadijatyara ta̱rijepyo, tapitya ra̱cantya jaryi varirya ta̱rijepyo.
\v 17 Dantyamu̱y ne vu̱bechara bínuja̱ vadija̱ ravimu ta̱rijevyu̱po: vu̱becharatiy ravimu, rabuy ta̱rijevyu̱po variy, rarumiye̱chara bínuja̱ variy, ta̱rijevyu̱po jarye pa̱chitye variy risa̱ju̱. Vu̱bechara ji̱ta vadijavyu̱vimura bínuja̱ vadija̱, rañuma pa̱chitye bínuja̱, ne vinu sajavyu̱ risa̱ju̱ntiy.”
\s1 Jáyirubay detubay, vaturu̱y ja̱mundatanu̱be jarye, jiryatiy nanumutyeda raniy Jesús sujay
\r (Márcu 5.21-43; Dúcasiy 8.40-56)
\p 
\v 18 Saniquenu̱yadanumatirya jirya niquejada ruuva, mityamusiy sa̱dasiñunuvi̱jada ti̱qui nutyityu̱bay Jesúsna̱cho̱ju̱yu. Su̱teda ji̱ta siva: “Sadiiyasimya̱ radyetu, dañuma varenunuma ya̱tidye barya jijyomutu saniy, sa̱tidye mi̱sa̱sumiy radyetu varintyi.”
\v 19 Sanubesubeda ji̱ta Jesús variy, sasiityari̱jada variñi̱, sisa̱ datyavabe jarye yisa̱ju̱.
\v 20 Mityamusiy nani̱deda ji̱ta vaturu̱y ja̱mundatanu̱be sarudivasiy Jesús, nanuja̱tyo̱jada variy raniy sasujacho. Taraqui vu̱yaju̱y nijya̱ ravicha̱da ja̱munda nadiva, danijya̱ju̱y ranchaju̱.
\v 21 Nanujachipiya̱jada ji̱ta jivyimu: “Raryitye ja̱tyo̱ vinu sasujantyecu̱, ra̱tidye mi̱sanirye.”
\v 22 Jesús ji̱ta janumityeda, sadiyadanumatiy nadiva, su̱teda ji̱ta variy nadiva: “Sa̱na̱jva̱ju̱ni vanu̱tyayu, Popoju̱y. Samiy sa̱nujachipiya̱jadamu jimyi̱sa.” Nanumi̱sa̱da ji̱ta varicha̱ra̱ju̱.
\v 23 Sito̱jadanumatiy Jesús nutyityu̱bay rorimyu, sadiñuvejada jasiy ruuva ruudivye, nijya̱nvajyuuveda jansa̱da jarye.
\v 24 Su̱teda ji̱ta ruuva: “Jirya̱numa jiintye jiyusiy, tama̱ diiñu daryaju̱ sani̱cha dera, tama̱, nu̱tyu sani ma̱ñi̱ndye.” Rityodiyada ji̱ta variy siva.
\v 25 Jatyasavañumatiy rivyicha̱da nijya̱nvajyuuveda bimuju̱, sajayada Jesús, sireda sajomutuniy dera babyi variy, sanubesubeda ji̱ta dera variy.
\v 26 Ra̱ticheyada ji̱ta ru̱ro̱ ti̱ta̱ju̱ variy.
\s1 Jesús mi̱sadeda nada ni̱sipyuryijyu̱be
\p 
\v 27 Saramiryi̱jadanumatiy Jesús jadchiy, nanusiityari̱jada ji̱ta danu̱ju̱y ni̱sipyuryijyu̱be jadchiñi̱. Nanuniquejasubeda variy: “¡Ya̱jantyutyate na̱y, Davyíbe jasi̱!”
\v 28 Sajayadanumatiy Jesús rorivyimu, nani̱deda ji̱ta ni̱sipyuryijyu̱be simu, Jesús jteda variy nadiva: “¿Sa̱da jachipiya̱ dyetya raryi jvaay daryaday?” Nani̱teda variy siva: “Joonu, Nutyityu̱.”
\v 29 Jadchiy ji̱ta saja̱tyo̱jada raniy nanuni̱siy jiñiquejadamu: “Ra̱cha sa̱daju̱ daryatiy sa̱nutuva̱chu simu Ju̱denu.”
\v 30 Ramutteda ji̱ta nanuni̱siy variy, nanudiyada ji̱ta tariva variy. Su̱teda ji̱ta Jesús jamiryamu variy nadiva: “Ne sa̱na̱datyataniy ti̱ra.”
\v 31 Nada ji̱ta tu̱chunuvejadara sa̱ticheyada ru̱ro̱ ti̱ta̱ju̱ variy.
\s1 Jesús mi̱sadedani̱ vanu niquejasa̱bay
\p 
\v 32 Riya̱danumatiy Jesúsveda jadchiy, mityamusiy ruuti̱ta̱da ji̱tani̱ vanu niquejasa̱bay, bayantuti̱bay simu Jesús.
\v 33 Jatyasi̱numatiñi̱ bayantu, saniquejada vanubay variy rivasiy. Rityi̱tta̱da ji̱ta nijya̱nvajyuuveda varirya, riñiquejada variy: “Ne ti̱ diyada tariva darya jvaayada Irayénuveda cabyimu.”
\v 34 Varyisévuvedabay ji̱ta niquejada variy: “Bayantu nutyityu̱ jtedamu sani jatyatityiryi bayantuveda nijya̱nvavyasiy.”
\s1 Jesús jantyutya̱da riy nijya̱nvajyuuvedabay
\p 
\v 35 Sarupityityiyada Jesús variy ti̱ta̱ju̱ vicha̱da cabyiva, rorivyiñu cabyiva jarye. Sadatyanunumaya̱jada ji̱ta riintye̱ryanijyovimu, satu̱chutityiyadara samitu̱choda Ju̱denu nusu̱yadanchiy, sami̱saniñu̱yadantiryi jdiva̱jnuvavyeda ti̱ta̱ju̱ntiy, ti̱ta̱ju̱ rityi vichanu̱yada vadiiryo̱vavyeda.
\v 36 Sadiyadanumatiy Jesús ruuva nijya̱nvajyuuveda, sa̱ntyutya̱da variryi, jiryatiy rivyicha̱da jarupantasavay, jantyuyani̱miy jarye, ta̱jnu̱tyiñi carni̱rumiy ne jnu̱tyi̱tavay.
\v 37 Su̱teda ji̱ta variy ruuva yisa̱ datyavabe: “Jasinrya rajuura jatojadaju̱, jvaavye ji̱tamu̱y ne rajuuvay.
\v 38 Ramuni̱ jirya̱jachiñu̱y siva jatojadaja̱mi̱, sa̱tidye jpa̱ riy jvaavye yivaajyomuju̱.”
\c 10
\s1 Jesús jaryeta̱da riy vu̱yaju̱y vaduvyedabay, danu̱ju̱y rinchaju̱, sansu̱byimijyu̱
\r (Márcu 3.13-19; Dúcasiy 6.12-16)
\p 
\v 1 Sanatuyada ji̱ta variy yimuju̱ riy yisa̱ datyavabe jiryatiy rivyichanu̱yada vu̱yaju̱y vaduy, danu̱ju̱y rinchaju̱ daryi. Sasa̱yada ji̱ta datya̱da variryi, ratatiy rirya̱jatyanumaya̱ riy bayantuveda jamirya vichavay nijya̱nvavyasiy; rirya̱mi̱saniy ratantiryi jaryedo jdiva̱jadatavantyi, jarupantasavay jarye ruusa̱ju̱ ti̱ta̱ju̱.
\v 2 Daryani̱ ji̱ta ravicha̱da jivye jtya vu̱yaju̱y nusu̱byimibe, danu̱ju̱y rinchaju̱: munatya Siimyó̱bay jiryatiy ru̱tachara Pyítruni̱, jadchintyi sataryi̱ Antrésibe, Sebedévubay denuju̱be Santiyácubay, sataryi̱ Juánbatya.
\v 3 Jadchintyi Vedípebe, Bartodomévubay, Tumásabay, Matévubay jarye jiryatiy criquiy jmutya̱nubañi̱, Santiyácubay jarye jiryatiy Ajéñubay denubañi̱, Tadévubay jaryentiy.
\v 4 Jadchintyi Siimyó̱bay jiryatiy ru̱tañu̱yada jaryi vani̱ra niquerabañi̱, Judásiy Iscaryótibe jarye jiryatiy samityasiiñu̱yadani̱ Jesús.
\s1 Jesús jpa̱jada riy yisa̱ datyavavyedabay rirya̱tidye datyanunumaya̱
\r (Márcu 6.7-13; Dúcasiy 9.1-6)
\p 
\v 5 Su̱pa̱jada ji̱ta Jesús riy jivye vu̱yaju̱y, danu̱ju̱y rinchaju̱, su̱teda variy ruuva: “Ne jirye̱jiya ruumu jiryatimyu̱ ne Judíyuveda daryi, mitya, daryantyamu̱y ne jirya̱jay Samáriya ja̱nvay vicha̱damu.
\v 6 Jirye̱jiya ji̱ta ruumu Irayénuveda day, jiryatiy caravye Ju̱denuvasidyeryi.
\v 7 Jirye̱jiya tu̱chuvay: Ratuudiñuma Jarichumuvichi̱ nusu̱yada.
\v 8 Jirya̱mi̱saniryi jdiva̱jnuvay, diibyimiy jarye jirya̱nubesityaniy, jirya̱pu̱y vatajo̱ju̱vyevyasirya jivyatajo̱ risa̱ju̱ntiy, jirya̱jatyantiryi bayantuveda nijya̱nvavyasiy ti̱ta̱ju̱ntiy. Daryatiy jiryi̱mutya̱jasiy mityara datya̱da, daryaday jirya̱mi̱saniy mityantidye.
\v 9-10 Ne jirya̱jtu tara, ne vinu criquiy surraday yimu, dantyamu̱y ne dusuuy, dantyamu̱y ne dajajyu̱y sujacya̱, dantyamu̱y ne saapatu, dantyamu̱y ne ruvese mitya, tapi sava̱tasara ju̱vaañu daryaju̱ra jimyi̱sara.
\v 11 Mirya vicha̱damuni̱ttyi jirya̱jay munatya, varimyata rorimyimyu, jirya̱va̱ta jasiy sana̱cho̱ nijya̱mi̱ samiy jachityi̱, jasityi jirya̱ma̱cho̱ jiryechipyatedasa̱ra̱ju̱.
\v 12 Jirya̱numatiy jay rorivyimu, jirya̱mu̱chuvesiryi raja̱nvay: ¡Samirya vichasara jiryejyu̱!
\v 13 Riryityi vichasara samirya jachityavay, ra̱day ma̱cho̱sara samirya vichasa̱da variy rijyu̱; riryityimyu̱ ne vichasara samirya jachityavay, ra̱day ta̱rya samirya vichasa̱da jiryimuju̱ntiy.
\v 14 Mi̱ni̱tyimyu̱ ne ra̱diryeru̱y jirye, dantyamu̱y ne rirya̱tuva̱churu̱rya jiryeñiquejada, jirya̱numatiy sipyatay rivyicha̱damusiy, jirya̱muchutya jiryeñumutuvasirya rirujuu riñijyu̱.
\v 15 Ri̱tatye si̱tenu jiryiva: Jachi̱ntyava̱ju̱ day ra̱cha Sodóma ja̱nvajyu̱, Comórra ja̱nvajyu̱ jarye, Ju̱denu paruta̱da rundamu, rivyicha̱da ja̱nvamyusiy jiryatimyu̱ ne ridyiryeru̱y jasiy jirye.”
\s1 Jesús datyadoda jarupanta̱danchiy
\r (Márcu 13.9-13; Dúcasiy 21.12-17)
\p 
\v 16 “Jirya̱jnu̱y, ri̱pa̱ ji̱ta jirye nu̱tyu ra̱si̱miy jmyiryajuu cabyimuju̱. Ramuni̱ jirye̱cha vani̱ra jachipiya̱vay nu̱tyu codiy, nu̱tyu ja̱rityudentiy jirye̱cha tapide vichavay.
\v 17 Jiryi̱nu̱tyata̱ta nijya̱mi̱jisiyu, tapitya rirya̱ju̱riy jirye rirya̱tidye jara̱chiy tu̱chujomuju̱ variy jirye, rirya̱musiye̱ ju̱tye̱ryanijyomu variy jiryentyi.
\v 18 Rirya̱tiiy variy japuvedamuju̱ jiryentyi, ja̱mu nutyityu̱vedamuju̱ jarye rayadaju̱, jirya̱tidye tu̱chu vijyo̱mujache ridyiya raynchiy, rirya̱tidye tuva̱chuntiy jiryatimyu̱ ne Judíyuveda daryi.
\v 19 Rirya̱numatiy sa̱y japuvedamu jirye, ne jirya̱jachipiya̱ jaryi variy nu̱tyuramusiy jirya̱nique, nu̱tyuramusiy, tapi jirya̱jmutya̱ variryundamura niquejada jirya̱tidye nique.
\v 20 Tapi ne jirya̱nique jidyirya day, Vu̱jye̱ Ju̱denu Jnutu ji̱ta ra̱nique jiryimusiy.
\v 21 Nijya̱mi̱ ra̱sa̱ryi jityeryi̱veda rirya̱tidye munu variy jasiryi, tavañi̱day ra̱sa̱ryi jidyedyeñu day rirya̱tidye munu varintyiryi, tavay ji̱ta ra̱nubesumiy jijye̱myi jiyaro̱ju̱, rirya̱tidye munu varintyidyeryi.
\v 22 Jirya̱vichasara javittyuchavay variy ti̱ta̱ju̱ nijya̱nvajyu̱, ri̱tya jiyadaju̱. Ni̱ni̱ ji̱ta jiryatiy sa̱jachi̱nichara ta̱rijyu̱ raju̱yu, sadiiyada sa̱ra̱ju̱, sa̱day ramityasara variy riva.
\v 23 Rirya̱numatiy jarupanta tavicha̱daquimu jirye, jirya̱bay tavicha̱damuju̱ntiy, tapi ri̱tay si̱tenu jiryiva: Ne jirya̱ramiryi̱ ti̱ta̱ju̱ Irayénuveda vicha̱diva, Nijya̱mi̱denu jti̱jadajisiy.
\p 
\v 24 Ne savichasara sisa̱ datyi̱ jaryiñu̱ simusiy jidyetyanu̱, dantyamu̱y muchechiy jaryiñu̱ simusiy jipyatru̱.
\v 25 Rasa̱ra̱numa ji̱ta sa̱cha sisa̱ datyi̱ nu̱tyu jidyetyanu̱, muchechiy jarye ra̱cha nu̱tyu jipyatru̱. Riryityi jtay raynchiy: Bayantumiy nutyityu̱, jiryatiy rañi̱cha rorijya̱mi̱, ta̱ jaryivya̱ju̱ rirya̱javityiye̱chara jirye, jiryatiy raryorimyu vichavay jirye.”
\s1 Jesús datyadoda chi̱ra vu̱ryichuvu̱chara, chi̱
\r (Dúcasiy 12.2-7)
\p 
\v 26 “Ramuni̱ ne jirya̱suvu̱ryi nijya̱nvay, tapi ne taradera ra̱ma̱cho̱ samiy mutanusara, mitya; ti̱ta̱ju̱tidye ra̱chasara dityanusara; dantyamu̱y ne ra̱ma̱cho̱sara tara dutyasara, ti̱ta̱ju̱ ra̱chasara datyasara.
\v 27 Jiryatiy ri̱tañu̱y nupocudimu jirye, jirya̱tu̱chu vindyamura; jiryatiy jiryetyuva̱chu cucuye̱yadamu tara, rani̱ ji̱ta jirya̱tu̱chu vijyo̱mujache day.
\v 28 Ne vurya̱suvu̱ryi jivye jiryatiy ru̱varya vu̱vyu̱, ne vana̱y rirya̱jvay variñi̱ vu̱beyanu. Vurya̱ntya suvu̱y ji̱tani̱ ni̱tiy parutasara jiidatyo̱muni̱ vu̱beyanu vatajuu vu̱vyu̱ta.
\v 29 Rajuura criquivyitya samurichevay danu̱ju̱y vachuchijyu̱y, dañumamu̱y ne saju̱u̱y ti̱qui vachuchiy tenu mucadincha Vu̱jye̱ va̱ta̱da niya̱resiy.
\v 30 Vuryi̱no̱jasiy jarye suranusara ti̱ta̱ju̱ saju̱ Ju̱denu day.
\v 31 Ramuni̱mu̱y ne vurya̱suvu̱y; vu̱ñi̱ ji̱ta murichevay jaryi ruumusiy vachuchimyi.”
\s1 Jesús datyadoda rinchiy rityi tu̱chusara vijyo̱mujache sayadaju̱
\r (Dúcasiy 12.8-9)
\p 
\v 32 “Ramuni̱, ni̱tiy tu̱chu vijyo̱mujache nijya̱nvavya: Ray ji̱ta datyani̱ Jesús, daryaday ra̱tu̱chu siva Rajye̱ Jarichumuvichi̱ntiy: Ray datyani̱ jiñu.
\v 33 Mi̱nintyi ji̱ta ra̱tu̱chu nijya̱nvavya raynchiy: Ne radyetyani̱ Jesús, daryaday ra̱tu̱chu siva Rajye̱ Jarichumuvichi̱ varintyidye: Ne radyetya dañi̱ jiñu̱ day.”
\s1 Rirya̱mityasiiy nu̱ñi tevajyuu Jesúsnchiyu
\r (Dúcasiy 12.51-53; 14.26-27)
\p 
\v 34 “Ne jirya̱jachipiya̱sara riti̱jada ra̱tidye barya samirya vichasa̱da jirya mucadimu. Ne riti̱jada samirya vichasa̱da bayadaju̱, vinu jchityitya̱ta ju̱vedaju̱ ji̱ta day.
\v 35 Ri̱deda ji̱ta daryaju̱ sa̱tidye jiyaro̱nu vanuni̱ jijye̱, vatura ji̱ta ra̱jiyaro̱nu nada yino̱da day, nana̱si̱ntu ji̱ta ra̱jiyaro̱nu nada jidyesedantidye.
\v 36 Rirya̱mityasiiy sarorimyu vichavay vanuyu.
\v 37 Ni̱tiy va̱tasara jaryi rimusiñi̱ jijye̱, varimyata su̱no̱da, ne sasa̱ra̱ rachiityari̱sa̱da; daryaday ni̱tiy va̱tasara jaryi rimusiñi̱ jidyenu, varimyata sadetu, ne sasa̱ra̱ rachiityari̱sa̱dantiy.
\v 38 Daryadantyi, ni̱timyu̱ ne sa̱nichujaya̱ ji̱tara jicyurusiy, jiryatiy sabay nu̱tyu diiñuyu, ne sa̱riryi̱ variñu̱darya ta̱riy jivyicha̱danu̱day, sa̱tidye siityari̱sara varirye, ne sasa̱ra̱ rachiityari̱sa̱da.
\v 39 Ni̱day ji̱ta jiryatiy sasaryera yinu̱yada, sa̱pa̱chitya mityara. Ni̱day ji̱ta jiryatiy sa̱pa̱chitya rayadaju̱ra yinu̱yada, sa̱day saryesara varintyirya.”
\s1 Jesús datyadoda jiryatiy Ju̱denu murichedodara samiy vichasa̱da murichirya
\r (Márcu 9.41)
\p 
\v 40 “Ni̱day ji̱ta jiryatiy sani dirye jirye, daryaday sadirye variy ramusintyidyerye; ni̱tiy ra̱dirye varirye, sa̱dirye varintyidyeñi̱ jiryatiy su̱pa̱jada jiyuju̱ ray.
\v 41 Ni̱tiy ra̱diryeni̱ Ju̱denuju̱ tu̱chu̱ jiryatiy satu̱chu Ju̱denunijyu̱, sa̱jmutya̱sarara Ju̱denuju̱ tu̱chu̱ murichedoda. Daryaday ni̱tiy diryeni̱ vanu vase vichara jiryatiy savichasara vase jvaarya, sa̱jmutya̱sarara vase vichasa̱da murichirya.
\v 42 Daryadantyi mi̱nintyi jatutaniy vinu sudoja̱a̱ni̱ ti̱quidera jivyetyenu, jiryatiy savichasara rachiityari̱nu, ri̱tatye si̱tenu jiryiva: Ne sa̱carera jimyurichenusa̱da riva.”
\c 11
\s1 Ruuti̱jada Juán Bautístabay jpa̱vabe simu Jesús
\r (Dúcasiy 7.18-35)
\p 
\v 1 Sadatyadodanumatiy Jesús riy yisa̱ datyavavyedabay vu̱yaju̱y danu̱ju̱y rinchaju̱, saya̱da ji̱ta jadchiy sa̱tidye datyanunumaya̱, sa̱tidye tu̱chunumaya̱ risa̱ju̱ rivyicha̱damu.
\p 
\v 2-3 Satuva̱chodanumatiy Juán Bautísta tanuvu̱nujovimusiy ranchiy sivaayada Ju̱denu jaryeti̱ Crístu, su̱pa̱jada ji̱ta riy yisa̱ datyavavyeda simu, rirya̱tidye jtaja̱nuni̱: “¿Jiñi̱viy jiryatiy yatiche jti̱jada, varimyata nu̱ryi nutuyasiy ti̱jiju̱ntiy?”
\v 4 Su̱mutya̱jada ji̱ta Jesús riy: “Jirya̱tu̱chunuve siva Juán ranchiy ti̱ta̱ju̱ jiryatiy jiryetyuva̱chura, jiryedyije risa̱ju̱ riva.
\v 5 Ru̱nu̱yasumiy ni̱sipyuryimyi, canuya̱sivyeda jarye rupi, vatajo̱ju̱vye jarye mi̱sa, tu̱yupuryimyi jarye tuva̱chu, diibyimiy jarye mi̱sa̱sumiy, jantyuyadavay jarye tuva̱chusarara samitu̱choda.
\v 6 Ju̱denu jmu̱tyasi̱ ji̱ta sa̱cha ni̱timyu̱ ne sa̱casinu̱ya̱ rachiityari̱sa̱dajisiy.”
\p 
\v 7 Riya̱danumatiy Juánbay siityari̱vavyedabay, sajo̱ta̱da niquejada Jesús nijya̱nvavya Juánbaynchiy varintyi: “¿Ta̱rana̱cho̱ jiryevya̱tanuveti tajityomu, ta̱rana̱cho̱? ¿Jiryeyati vinu jirya̱tidye diñuve riva jiryatiy ranuvatyaja̱ riichora vachuy?
\v 8 ¿Ta̱rana̱cho̱ jiryeyati variy, ta̱rana̱cho̱? ¿Jirya̱tidye diy siva nijya̱mi̱ vasidyajay sujatyi̱ day? Ne jiryi̱nu̱y, rityi vichasara vasidyajay sujatyavay, riñi vichasara ja̱mu nutyityu̱ rorimyu.
\v 9 ¿Ta̱rana̱cho̱ jiryeyati variy, ta̱rana̱cho̱? ¿Jirya̱tidye diy siva Ju̱denuju̱ tu̱chu̱ day? Jo, jaryivya̱ju̱ Ju̱denuju̱ tu̱chu̱ jiyadaju̱teni̱.
\v 10 Ni̱ni̱ ji̱ta sani̱cha jiryatiy nu̱chara sanchiy:
\q1 Ri̱pa̱ ji̱tani̱ raynsu̱byi jimyo̱muju̱, sa̱tidye jdutyara nú̱ yajiju̱.
\m 
\v 11 Ri̱tay ji̱ta si̱tenu jiryiva: Ne ti̱ nubesumiy jaryiñu̱ Juánmusiy, jiryatiy vaturu̱myusiy rupi̱ni̱. Dañuma sani̱cha jaryiñu̱ Juánmusiy, mi̱ni̱tyi vichasara rirya̱rijyu̱ játarya Jarichumuvichi̱ siityari̱vamyusiy.
\v 12 Juán Bautísta rundamusiy ji̱ta, diyesa̱ra̱ju̱ ti̱ta̱ju̱, rapana̱tyityi Jarichumuvichi̱ nusu̱yada, nijya̱nvay panavye ji̱ta rañi ju̱riy vani̱ravarya.
\v 13 Tapi ru̱vatadoda ji̱ta Ju̱denuju̱ tu̱chuvabe tu̱choda ji̱tyaju̱ Ju̱denu nusu̱yadanchiy, Muyusésibemyusiy, Juán Bautísta sa̱ra̱ju̱ ti̱ta̱ju̱.
\v 14 Jiryetyi tuva̱churu̱y ramu, ni̱ni̱ Juán sani̱cha Edíyasiy jiryatiy sa̱jti̱sara.
\v 15 Jiryetyuva̱chuta̱ta tu̱yutavay.
\p 
\v 16-17 ¿Nu̱tyura ni̱ta ra̱jtay riñijyu̱ nijya̱nvay jijyomu, nu̱tyura? Riñi̱cha ji̱ta nu̱tyu deramiy pudásamu ma̱savay. Rityiyi̱saru̱yadamu jityu̱chuta jityevavyayu: Dañuma nu̱ñi ruudiye̱ jiryejyu̱, ne jiryerye̱ya̱ru̱y nta variy. Dañuma nu̱ñi sutyaniy nu̱tyi diibyituunu jna̱yadamu nta, ne jiryi̱na̱ryu̱y nta variy ranchintyi.
\v 18 Darya ri̱tay, jiryatiy su̱deda Juán jmyichara jnurara, ne si̱byeda, dantyamu̱y ne sa̱toda. Ru̱teda variy sanchiy: Bayantu siva.
\v 19 Siti̱jada ji̱ta Nijya̱mi̱denu ne jmyichara jnurara, jiryatiy ri̱myiñu̱y, ra̱tu jarye risa̱ju̱, ru̱tay variy raynchiy: Ta̱ jaryi jibyedajachi̱ni̱ day, niyu̱yadacanuy risa̱ju̱ni̱, ni̱ni̱day criquiy jmutya̱vay jaamyicyu, jiryatiy juuchatavaryi. Dañuma ravichasara vase jvaayada jiryatiy Ju̱denumusiy datya̱damu jvaacharara.”
\s1 Jesús datyadoda tuva̱chu̱sa̱minchiy
\r (Dúcasiy 10.13-15)
\p 
\v 20 Jadchiy ji̱ta sajo̱ta̱da Jesús tu̱chuta̱da riy vicha̱da ja̱nvay, jasityi sivaañu̱yadara mityamusiy ju̱dejada, jiryatimyu̱ ne ripyaru̱ryu̱y riva va̱cha jachipiya̱jada variy.
\v 21 “¡Acuu, jiryeñijyu̱ Curasí̱ ja̱nvay! ¡Acuu, jiryeñijyu̱ Betsáyina ja̱nvay! Tapi raryityi jvaayada Tíru ja̱nvay cabyimura rivaayada ti̱ttasara nu̱tyu jiryequebyimutiy rivaayasiy daryantiy, ta̱riñuma riryi paru̱yada riva va̱cha vicha̱da, riryi dityadoda varirya jiñuvayada riva jiryatiy riryimya̱sa varivyunujay sujatyavay pupujurunube. Sitú̱ ja̱nvay jarye raryi jvaayada daryantidye.
\v 22 Ri̱tatye jiryiva: Jachi̱ntya̱da ra̱cha rijyu̱ Tíru ja̱nvay, Sitú̱ ja̱nvajyu̱ jarye jiryimusiy, juuchuveda murichenutadeda rundamu.
\v 23 ¿Va̱, jiryeque Capernavú̱ ja̱nvay? jiryi̱tay vidye jirye̱cha jasuminichavay jarichumuju̱ day. Jiryedye day ra̱chava̱ jmusanichavay jiidatyo̱muju̱ cay. Raryityi jvaachara daryaju̱ Sodóma ja̱nvay cabyimura mityamusiy ju̱dejada, daryatiy rivaayasiy jiryequebyimu, raryi ma̱cho̱jada Sodóma diyesa̱ra̱ju̱.
\v 24 Ri̱tatye jiryiva: Jachi̱ntyava̱ju̱ day ra̱cha Sodóma ja̱nvabejyu̱ juuchuveda murichenutadeda rundamu jiryimusiy.”
\s1 Samusuyada Jesús: “Jirye̱ntya jniy rimuju̱ jirya̱tidye datyara si̱tenu jiituyada”
\r (Dúcasiy 10.21-22)
\p 
\v 25 Variryundamu ji̱ta saniquejada Jesús: “Ri̱chana̱tyate ji, Ye̱ye̱, jarichu Nutyityu̱, jiryatiy mucadi Nutyityu̱ jarye risa̱ju̱ ji, jiryatiy jidyutya̱dara jirya datya̱da rirya̱jisiy mityamusiy datyavay, datya̱da jachityavay jarye. Jidyityadoda ji̱ta datyi̱sa̱mimyura.
\v 26 Jo, Ye̱ye̱, jiryatiy samiy jvadichara jidyiya darya.”
\v 27 Su̱teda ji̱ta variy nijya̱nvavya: “Sasa̱mya̱ ji̱ta rajye̱ ti̱ta̱ju̱ ray. Ne ti̱ datya chi̱ra sani̱cha sadenu, chi̱, vinu rajye̱ datya, dantyamu̱y ne ti̱ datya chi̱ra sani̱cha rajye̱, chi̱, vinu sadenu datya, ni̱ jarye jiryatiy sadityanuru̱ñi̱.
\v 28 Jiyuju̱ rimuju̱ jirye ti̱ta̱ju̱ jiryatiy paru̱cha̱riy jvaatyityivye jirye, jaryi tiityavay risa̱ju̱ jirye, ra̱day jiitutyaniy variy jirye.
\v 29 Jirya̱jmutya̱ nu̱tyu datyanu̱ ray, jirya̱tidye datyara samiy vichasa̱da rimusiy, jiryatiy ravyichasara tapide jvaarya, ravyichasarantiy nu̱tyu jantyuyani̱ rajechimyu. Jirya̱day sarye varirya jiituyada jiryejechipiya̱jadamu.
\v 30 Tapitya radyetyadoda ji̱ta ne surra day, ratyiityatadeda jarye ne jinra.”
\c 12
\s1 Jesúsjsa̱ datyavavyedabay rotyatityiyadara jaruusibyi jiituyada rundamu
\r (Márcu 2.23-28; Dúcasiy 6.1-5)
\p 
\v 1 Variryundamu ji̱ta riryamiryi̱jada Jesúsveda racabyimu jaruusiñi̱. Jiryatiy rijechi̱jada sisa̱ datyavavyeda daryaju̱, rijyo̱ta̱da rotyatityiyada jibyedaju̱ra jaruusibyi variy.
\v 2 Ridyiyadanumatiy Varyisévuvedabay riva, ru̱teda variy siva Jesús: “Ya̱jnu̱y, yisa̱ datyavay jvaarya jiryatiy ju̱bachara jiituyada rundamu jvaayadaju̱ra.”
\v 3 Su̱teda Jesús variy ruuva Varyisévuvedabay: “¿Ne jiryeñiquettara catera padye didye, nu̱tyura sivaayada Davyíbe sajachi̱jadanumatiy, nu̱tyura? yisa̱ vichavabetya.
\v 4 Nu̱tyuramusiy sajayada Ju̱denu rorivyimu, nu̱tyuramusiy, si̱byeda ji̱tara pa̱, jiryatiy ribeñu̱yada Ju̱denu jiyadaju̱ra, jiryatiy ju̱bachara riibyedajisidyerya, daryaday ju̱bachara rijyu̱ sisa̱ vichavabejisiy varintyidyerya, jiryatiy vinu caserdótevyeda jbyedaju̱ rani̱cha pa̱ day.
\v 5 ¿Daryantyamu̱y ne jiryeñiquettara Muyusésibe nu̱rya Ju̱denu jtedamu day, nu̱tyuramusiy ruuvaañu̱yada caserdótevyedabay Ju̱denu rorivyimu, nu̱tyuramusiy, jiituyada rundamu? Ne ti̱ jiyasayada riva varidyeryi.
\v 6 Ri̱tatye ji̱ta jiryiva: Sani̱cha ti̱qui nijya̱mi̱ jiyu, jiryatiy jaryiñu̱ ramusiy Ju̱denu roriñi̱.
\v 7 Jiryetyi datya̱da ta̱ra ránique jirya niquejada: Radyiryu̱y ji̱tara jantyutya̱da, ne vinu jiryatiy ru̱ntatya yasi̱ rimu, jiryeryi jiyasayadava̱ riy jiryatimyu̱ ne jiyasayadatavadyeryi.
\v 8 Tapi Nijya̱mi̱denu ji̱ta jiituyada runda ja̱mi̱ day.”
\s1 Vanu jomutu susa̱ñubaynchiy
\r (Márcu 3.1-6; Dúcasiy 6.6-11)
\p 
\v 9 Saya̱da ji̱ta Jesús jadchintyi, sajayada riintye̱ryanijyovimu variy.
\v 10 Mityamusiy savicha̱da nu̱ vanu jomutu susa̱ñubay jasiy. Ruutaja̱doda ji̱ta variñi̱ Jesús: “¿Samiryavidye Ju̱denu diya mi̱sadeda jiituyada rundamu, varimyatamu̱y ne?” Riñi jachipiya̱jada tu̱chuta̱da rivani̱.
\v 11 Su̱teda Jesús variy ruuva: “¿Mi̱ra jiryetyenu, ti̱quide jasi̱ti̱, mi̱, saryityi ju̱u̱y sa̱si̱ jiituyada rundamu vataju̱vimu, nevidye sa̱sipyata variy ravimusiñi̱?
\v 12 ¡Ta̱ jaryivya̱ju̱ samurichevay nijya̱mi̱ simusiy jasi̱! Ramuni̱ samirya Ju̱denu diya vurya̱jvaarya samirya jvaayada jiituyada rundamu.”
\v 13 Jadchiy ji̱ta su̱teda Jesús siva jomutu susa̱ñubay: “Ya̱ratyara jijyomutu.” Saratya̱da vanubay varirya, rata̱rya̱jada variy yibivaju̱ nu̱tyu rataryarantiy.
\v 14 Rimya̱seda ji̱ta Varyisévuvedabay, rityu̱chudoda variy sayaro̱ju̱ Jesúsyu: “¿Nu̱tyuramusiy vu̱ryi jvañi̱, nu̱tyuramusiy?”
\s1 Jesús jto̱tadedara Ju̱denu niquejada jiryatiy Isayíyasibe jtosirya
\p 
\v 15 Sadatya̱da ji̱ta Jesús jiryatiy ru̱varyu̱yada Varyisévuvedabañi̱, sanumuteda variy jadchiy. Richiityari̱jada rajuuvay variñi̱, sami̱sadeda ji̱ta ti̱ta̱ju̱ variy jasiryi.
\v 16 Su̱teda ji̱ta variy ruuva: “Ne jirya̱datyanu tavajyu̱ raynchiy.”
\v 17 Rani̱ ji̱ta jto̱tadedara Ju̱denuju̱ tu̱chu̱bay niquejada, Isayíyasiy jtyati̱bay, jiryatiy saniquejada:
\q1 
\v 18-21 “Jirya̱jnu̱ñi̱ ramyuchechiy jaryetasi̱, ravya̱tasi̱ samiy jvadichi̱ radyiyani̱. Ra̱day bay ri̱ntu siva, sa̱day tu̱chura ramyurichedoda nijya̱nvajyu̱. Ne sa̱nique nta, dantyamu̱y ne sa̱sa̱ñe̱ya̱, dantyamu̱y ne ti̱ ra̱tuva̱chu vijyo̱mujachera saniquejada. Ne sa̱patara tanchedu jiryatiy mururyara, dantyamu̱y ne saryi jiryichara no̱no̱siiy jiryatiy jaryi ránuvachíityityi, rarundasa̱ra̱ju̱tiy sa̱vuunu vase jvaayadata ti̱ta̱ju̱ra. Rirya̱ntuy nijya̱nvajyuu variy sa̱ntyutya̱dajiju̱.”
\s1 Rityu̱chuta̱dani̱ Jesús: “Sajatyasarariy bayantuveda nijya̱nvavyasiy bayantu nutyityu̱ vanu̱yadata”
\r (Márcu 3.20-30; Dúcasiy 11.14-23; 12.10)
\p 
\v 22 Jadchiy ji̱ta ruuti̱ta̱da Jesúsmuju̱ni̱ vanu bayantuti̱bay jiryatiy ni̱sipyuryiñi̱, niquejasa̱ risa̱ju̱ni̱. Sami̱sadeda ji̱ta variñi̱ sa̱tidye nique variy niquejasa̱bay, su̱nu̱yasubeda ji̱ta varintyi.
\v 23 Rityi̱tta̱da ji̱ta nijya̱nvabe variñi̱, ruutaja̱doda variy: “¿Neviy ni̱ sani̱cha Davyíbe jasi̱ jiñu day?”
\v 24 Rityuva̱chodanumatiy Varyisévuvedabarya ruutaja̱doda, ru̱teda ji̱ta variy ruuva: “Vinu bayantu nutyityu̱ Satanásimyusiy sani jatyajaya̱sara jiñu vanuriy bayantuveda nijya̱nvavyasiy.”
\v 25 Sadatya̱danumatiy Jesúsra rijechipiya̱jada, su̱teda ji̱ta variy ruuva: “Riryiñumatiy panaryi̱ jiñique̱yadamu curaca nijya̱nvay nu̱ñi riy jiñijyu̱, rirya̱raay variyu, mityanuma ra̱ma̱cho̱ rivyicha̱da variy; vicha̱daja̱nvay jarye ra̱ju̱raay varintyiyu. Varimyata rorijya̱nvantyi, riryiñumatiy panaryi̱ jiñique̱yadamu nu̱ñi riy jiñijyu̱ntidye, ne riryichuru̱y variy.
\v 26 Daryaday ravicha Satanásiy nusu̱yadamuntiy; riryityi panaryi̱ jiñique̱yadamu Satanásivyeda jiñijyu̱ntidye, ¿nu̱tyichiñuma ra̱suru̱y sansu̱yada varintyi, nu̱tyichiy?
\v 27 Raryityi jatya Satanásimyusiryi bayantuveda, ¿chi̱ vanu̱yadata rijetyasara jiryetyevadyeryi bayantuveda nijya̱nvavyasidye, chi̱? Ramuni̱tiy rirya̱dityanu jiryetyevarya jiryecyarayada.
\v 28 Ray ji̱ta raryi jatya Ju̱denu Jnututa riy bayantuveda nijya̱nvavyasiy, ranuma Ju̱denu nusu̱yada rañi jti̱ jiryimu.
\v 29 ¿Nu̱tyuramusiy ti̱ jayadasa̱ra̱ ravimu saroriy vanu vanu̱rya nu̱tyu savichasara bayantu nutyityu̱, nu̱tyuramusiy? Ne saryi jay ya̱tidye so̱varya sabarya variy, tetya sapuchusa̱siy munatyayu. Rivasiy ji̱ta sa̱so̱varya sabarya.
\p 
\v 30 Mi̱ni̱tyimyu̱ ne vichasara risa̱ jvaañu, savichasara ji̱ta rayaro̱ju̱; daryadantyi mi̱nintyimyu̱ ne jmu̱tyaru̱rye, jiryatiy rañi ju̱tye̱ryaniryu̱ryi nijya̱nvay, su̱resara variryi.
\v 31 Ramuni̱ ri̱tay jiryiva: Sa̱ramityaniy Ju̱denura juuchuveda ti̱ta̱ju̱ nijya̱nvavya, ti̱ta̱ju̱ rirya̱vityiye̱yadiva jarye; vinu rityi javityiye̱ñi̱ Ju̱denu Jnutu, ne sa̱ramityaniy Ju̱denu ruuvara.\f * \fr 12:31 \ft Jiryatiy ru̱teda Varyisévuvedabay: “Sani jatyasara Jesús riy bayantuveda nijya̱nvavyasiy, bayantuveda nutyityu̱ Satanásimyusiy,” rirya̱vityiye̱yada variñi̱ Ju̱denu Jnutu.\f*
\v 32 Mi̱ni̱tyi ra̱nique sayaro̱ju̱ Nijya̱mi̱denu, sa̱ramityaniy mitya rajye̱rya. Mi̱nintyi ji̱ta ra̱nique sayaro̱ju̱ Ju̱denu Jnutu, ne sa̱ramityaniy mityara saniquejada, ne vinu diye, dantyamu̱y ne ju̱na̱reju̱.”
\s1 Jesús datyadoda: “Vu̱dyetyara ni̱nu rajomusiy”
\r (Dúcasiy 6.43-45)
\p 
\v 33 “Jirya̱ntya datya samiy vu̱vyichasa̱danchiy, nu̱tyu ni̱nu, raryityi vicha samiñu, darya samijyo raryicha rajontidye; raryityi vicha nicyara̱ñu, darya nicyara̱jyo raryicha rajo varintyidye. Tapi vu̱dyetyara ni̱nu nu̱ñi rajonchiy daryaju̱.
\v 34 ¡Codityevay rapu̱ryamiy! ¿Nu̱tyichiy jirya̱nique samirya tara, nu̱tyichiy? jiryatiy nicyara̱myi daryaju̱ jirye. Vuryi̱tosiy ji̱ta rasipyatachara niquejada daryaju̱, jiryatiy vu̱beyada vu̱jechimyura.
\v 35 Daryaday sivaachara samiy nijya̱mi̱ra samiy jvaayadantiy, jiryatiy rajontay sajachiy samirya jachipiya̱jadamusiy. Sivaachara jamirya vicharara va̱cha jvaayada, jiryatiy rajontay sajachiy va̱cha jachipiya̱jadamusiy.
\v 36 Ri̱tay ji̱ta jiryiva: Ti̱ta̱ju̱ niquejada jiryatiy vu̱ñique mityara, vurya̱day murichenura ramurichirya Ju̱denu murichenutadeda rundamu.
\v 37 Tapi vu̱ñiquejadamusiy ji̱ta sa̱jtay Ju̱denu vu̱ñi̱cha samivye, varimyata sa̱jtay vu̱ñi̱cha nicyara̱myi.”
\s1 Va̱cha vichavay jachiñu̱yadara mityamusiy dityadoda
\r (Márcu 8.12; Dúcasiy 11.29-32)
\p 
\v 38 Jadchiy ji̱ta ru̱mutya̱jada Ju̱denu niquejada datyanuvay tevabe, Varyisévuveda tevabe jarye ruusa̱ju̱ni̱: “Datyanu̱, nu̱vya̱ta diyada yimusiy riva mityamusiy dityadoda.”
\v 39 Su̱mutya̱jada ji̱ta Jesús variryi: “Nijya̱nvay jamirya vichavay, jiryatiy rityochicharani̱ Ju̱denu nu̱tyu rityochichara jmuchanuvedacanumiryi jivyatuy, riñi va̱tasara rana̱cho̱ mityamusiy dityadoda. Ne rirya̱diy ji̱ta riva mityamusiy dityadoda day, vinu ra jiryatiy sabayada Ju̱denu Jonásibenchiy tu̱chodara, ni̱tiy vichanu̱yada ta̱riy Ju̱denuju̱ tu̱chu̱.
\v 40 Tapi nu̱tyu savicha̱da Jonásibe mumurundamiy ti̱ta̱ju̱ quiva̱suma vimu, daryaday sa̱chasara Nijya̱midenu mumurundamiy ti̱ta̱ju̱ mucadinubentiy.
\v 41 Ñíñivye ja̱nvay bayanumiy ji̱ta ra̱nubesumiy tamitya rundamu, rirya̱tidye tu̱chuta riy diye vichavay, tapi rivyitya paru̱yada variy riva ta̱riy jivyicha̱da, rityuva̱chodanumatirya Jonásibe niquejada Ju̱denunchiy. Dañuma sani̱cha ti̱qui vanu jaryi datyara simusiy Jonásibe, dantyamu̱y ne rityuva̱churu̱y diye nijya̱nvay variy simu day.
\v 42 Nana̱nubesiy ji̱ta ranro nutyityu̱toda bayanu tamitya rundamu, nana̱tidye tu̱chuta variryi diye vichavay, jiryatiy naditi̱jada mucadi su̱tyeryamusiy, nana̱tidye tuva̱chura Sadumú̱bay datya̱da. Dañuma sani̱cha ti̱qui vanu jiyu, jaryi datyarava̱ju̱ Sadumú̱bamyusiy, dantyamu̱y ne rityuva̱churu̱y diye nijya̱nvay ramusiy simu day.”
\s1 Jesús datyadoda bayantu jamirya vicharanchiy, jiryatiy sata̱rya̱jada yibivaju̱
\r (Dúcasiy 11.24-26)
\p 
\v 43 “Sasipyatedanumatiy bayantu jamirya vichara sivasiy vanu, savu̱taya̱numaya̱ vassatova variy, sava̱tana̱ya̱ rana̱cho̱ samityo yajiju̱ jasityi sani nta ya̱jiituy. Ne sasarye ji̱ta daryaju̱ra.
\v 44 Jadchiy ji̱ta sajachipiya̱: Ra̱ta̱ryava̱ ri̱bivaju̱ day. Sasaryenuvi̱ ji̱tani̱ vanuntiy, nu̱tyu mitya roriy nunichara, samiy jdutyasara nta ti̱ta̱ju̱ra.
\v 45 Jadchiy ji̱ta saya, sapu̱chiy yisa̱ju̱ riy danu̱ju̱ñijyate bayantu rapu̱ryamiy, jiryatiy jamirya vichavavya̱ju̱ simusiryi. Rije ji̱ta jivyicha̱daju̱ jasiy siva. Sa̱ma̱cho̱ ji̱ta vanu variy jaryi jamiryanu ruumusiy, ta̱riy jivyicha̱da jiyadaju̱. Daryaday ra̱chasara rijyu̱ diye vichavay nijya̱nvay nicyara̱myintyi.”
\s1 ¿Muvye riñi̱cha si̱tenu Jesús tevay, muvye?
\r (Márcu 3.31-35; Dúcasiy 8.19-21)
\p 
\v 46 Saniquejadanumatiy Jesús darya ruuva nijya̱nvay, mityamusiy nanuvicha̱da raniñu̱y bimu Jesús jno̱dabay, sataryi̱vedabatya, riñi va̱ta̱da sana̱cho̱, rirya̱tidye tu̱chu sisa̱.
\v 47 Ti̱ tu̱choda variy siva: “Nanuraniy yino̱da bimu, jityeryi̱vedata, riñi va̱ta jiñe̱cho̱ rirya̱tidye tu̱chu yisa̱.”
\v 48 Su̱mutya̱jada ji̱ta variñi̱ tu̱chu̱: “¿Miñu̱ña̱ ri̱no̱da, miñu̱y? ¿Mi̱ra ratyeryi̱, mi̱?”
\v 49 Saratya̱danumatirya jijyomutu riñe̱cho̱ yisa̱ datyavavyedabay, su̱teda variy: “Jiñu̱tyiñada ri̱no̱da, jivyetyiryi ratyeryi̱vedantiy.
\v 50 Tapi mi̱ni̱tyi jvaaryu̱rya ratiy sava̱ta rajye̱ Jarichumuvichi̱ jvaayada day, ni̱ni̱ ji̱ta ratyeryi̱ day, ri̱tyamutu jarye, ri̱no̱da jarye ruusa̱ju̱.”
\c 13
\s1 Jesús tu̱choda nuti̱nchiy
\r (Márcu 4.1-9; Dúcasiy 8.4-8)
\p 
\v 1 Variryundamu ji̱ta saya̱da Jesús, sama̱sanuvejada jmityo̱jiniy variy.
\v 2 Riintye̱ryadeda ji̱ta nijya̱nvajyuuvedabay simuyu. Pariche su̱musa̱da cartyevimu, sama̱sanuvejada ravimu variy. Nijya̱nvajyuuvedabay ji̱ta rañi radeda ti̱cha̱ncha varidye.
\v 3 Satu̱choda ji̱tara rajuura datyadoda, dityadoda niquejadata. Su̱teda jidyetyadodamu ruuva:
\p “Saya̱da ji̱ta ti̱qui nuti̱ nuta̱dana̱cho̱.
\v 4 Santa̱damu ji̱ta raju̱u̱ya̱jada ratesiy nú̱va, riibyesumiñuvi̱jada ji̱ta nipya̱tavay varirya.
\v 5 Ratesiy jarye ju̱u̱yada ravichu̱ cabyiva, jiryatimyu̱ ne vatanuco ravicha̱da mucadi jasiy. Varicha̱ra̱ju̱ radipuvesubeda variy jasiy, jiryatimyu̱ ne vatanuco mucadi jasiy.
\v 6 Na̱vapyunumatiy savicha̱da jiñi̱ variy, ramu̱mya̱ variy sadára nutasara, jiryatimyu̱ ne jnutityara ravicha̱da daryaju̱, ramuni̱tiy ramu̱yada variy.
\v 7 Tasiñi̱ ju̱u̱yada cariitujnutincha day, rani̱ cariitu jo̱ta̱da ja̱vyeda ra̱jisiy nutasara day, radiryo̱doda variy jasirya.
\v 8 Tasiñi̱ ju̱u̱yada samiy mucadimu day, jasiñi̱ ji̱ta rasinteda samirya. Raja̱vyedanumatiy, ra̱sa̱yada ji̱ta variy, tarani̱ jayada day ra̱sa̱yada taraqui pachasijyu̱, tarantiy jasa̱yada taraquinijyate vu̱yaju̱chijyu̱, tarantiy jasa̱yada mumuri̱ vu̱yaju̱chijyu̱ntidye.
\v 9 Jiryetyuva̱chuta̱ta tu̱yutavay.”
\s1 Nu̱tyuraju̱ saniquejada Jesús dityadoda niquejadata, nu̱tyuraju̱
\r (Márcu 4.10-12; Dúcasiy 8.9-10)
\p 
\v 10 Rityuudiyada ji̱ta sisa̱ datyavay variyu, ru̱teda ji̱ta variy siva: “¿Nu̱tyuraju̱ jiñique dityadoda niquejadata ruuva, nu̱tyuraju̱?”
\v 11 Su̱mutya̱jada ji̱ta variryi: “Jiryejyu̱ ji̱ta sasa̱yada Ju̱denu darya datya̱da day, jiryatiy mityamusiy datya̱da Jarichumuvichi̱ nusu̱yadanchirya, rijyu̱ ji̱ta ne sasa̱yada darya.
\v 12 Tapi simu jiryatiy tarati̱ni̱, sa̱sa̱y Ju̱denu variy ju̱na̱ntyiñi̱, rajuura ra̱cha simu variy. Simusiy ji̱ta jiryatimyu̱ ne tarati̱ni̱, sa̱so̱vay Ju̱denu variy simusintyirya jiryatiy simuntidyerya.
\v 13 Ramuni̱ rañiquesara dityadoda niquejadata ruuva, jiryatiy dañuma ru̱nu̱y, ne ridyi variy tariva; dañuma rityuva̱chu, ne ridyetya varirya, dantyamu̱y ne ridyetyaru̱y.
\v 14-15 Ruumu ji̱ta, rito̱tanimya̱ Ju̱denuju̱ tu̱chu̱ Isayíyasibe tu̱choda:
\q1 Jiryeñi̱ ji̱ta ra̱tuva̱chu, tama̱ jirya̱datya varirya, tama̱, jirya̱jnu̱y rana̱cho̱, tama̱ jirya̱diy variy riva, tama̱. Tapi ne radatya rijechiy jivye nijya̱nvay, ne rirya̱datya variy ramusiy. Rimyutanu dyetyara jiñi̱siy, riñuma jnu̱y, jaryi surra riberya jityu̱yuvudi, riñuma tuva̱chu, rijechiy jarye jibe surra, riñuma datyara. Riryityi datyara, varityi riryijetyara taji jachipiya̱jada, variñi̱day raryijetya ruuvasirya jijyuuchuveda.
\m 
\v 16 Jiryeñi̱ ji̱ta Ju̱denu jmu̱tyasavay, jiryatiy jiryedyi jiñi̱sitya, jiryetyuva̱chuntiy jityu̱yuta.
\v 17 Ri̱tatye si̱tenu jiryiva: Rajuu Ju̱denuju̱ tu̱chuvabe, vase vichavabe jarye, riñi diryu̱yada riva jiryatiy jiryedyi diye riva, tama̱ ridyiyada riva, tama̱; daryantya, riñi tuva̱churu̱yadantidyerya jiryatiy jiryetyuva̱chura, tama̱ rityuva̱choda nu̱nrya, tama̱, mitya.”
\s1 Jesús datyatadedara tu̱choda nuti̱nchiy
\r (Márcu 4.13-20; Dúcasiy 8.11-15)
\p 
\v 18 “Jirya̱numa tuva̱chu varirya dityadoda niquejada nuti̱nchiy.
\v 19 Satuva̱chunumatiy ti̱ra Ju̱denu nusu̱yada datyadoda, netimyu̱ ne sadatya didyerya, su̱nichara ji̱ta bayantu nicyara̱y variy, saso̱vacharara jiryatiy nutasara sajachimyura. Jiryatirya rasiy jiryatiy nutasara nú̱vara.
\v 20 Rasiy ji̱ta jiryatiy ravichu̱ cabyiva nutasarara, rani̱ ji̱ta nu̱tyu nijya̱mi̱, satuva̱chunumatirya Ju̱denu niquejada, su̱mutya̱sara variy jichana̱yadamura.
\v 21 Jiryatimyu̱ ne jnutityi̱ daryaju̱ni̱, sajachi̱nichara vinu taraquideju̱yu. Sadatyasaranumatirya paru̱tyasa̱da Ju̱denu niquejadiva, ti̱ jiyasantasara Ju̱denu niquejadiva risa̱ju̱ntiñi̱, ramutiy saparu̱ryu̱chara variy riva.
\v 22 Jiryatiy nutasara cariitujnutiy cabyiva, rani̱ ji̱ta nu̱tyu nijya̱mi̱, sani tuva̱chura Ju̱denu niquejada, sajachipiya̱sara jaryi variy taranijyu̱, jirya vicha̱divasiy, jaryi su̱canucharara tarati̱ vicha̱da jarye variy. Ramuni̱tiy radiryo̱nusara jasirya Ju̱denu niquejada, ne vana̱y rajay satuva̱chodamu variy.
\v 23 Rani̱ ji̱ta jiryatiy nutasara samiy mucadivara, rani̱ ji̱ta nu̱tyu nijya̱mi̱ jiryatiy rañi tuva̱chura Ju̱denu niquejada, sadatyasara varirya. Ni̱ni̱ ji̱ta nu̱tyu samiy nutasarasiy nta sajachara, sa̱sa̱chara ji̱ta variy. Ti̱ni̱ jasa̱yada taraqui pacha sa̱ra̱ju̱ day, nu̱ntiy taraquinijyate vu̱yaju̱cha̱ra̱ju̱, tamityi̱ntiy jasa̱yada mumuri̱ vu̱yaju̱cha̱ra̱ju̱ntidye.”
\s1 Jesús tu̱choda vachunchiy, jiryatiy jaruusiy cabyiva nutasarara
\p 
\v 24 Satu̱choda ji̱ta Jesúsra ratarya dityadoda niquejada:
\p “Jarichumuvichi̱ nusu̱yada ji̱ta rani̱cha nu̱tyu vanu nta jiryatiy sani nuta̱dara samirya nutasarasiy yindimyu.
\v 25 Nijya̱nvay ma̱yadamu, su̱deda ji̱ta samityasiy, santa̱da samiy nutasarasiy cabyivara vachutyadi, sata̱rya̱da ji̱ta variy rivasintyi.
\v 26 Radipuvañumatiy ravi̱, rasivyeda varintyi, ramu̱ti̱jada vachuy variy risa̱ju̱ntiy.
\v 27 Ru̱deda ji̱ta nudijya̱mi̱ muchechimyi yimu, ru̱teda variy siva: ¿Neviy yinta̱da nutasarasiy samichiy yindimyu day, Patru̱? ¿Nu̱tyuramusiy variy vachuy ramu day, nu̱tyuramusiy?
\v 28 Ni̱ni̱ ji̱ta jteda ruuva: Jirya ji̱ta mityasiy jvaayada day. Ru̱teda ji̱ta samuchechimyi variy yiva: ¿Jivya̱taviy nu̱ña̱sipyatara vachuy?
\v 29 Su̱mutya̱jada ji̱ta variryi: Ne, jiryeñuma tiirya jaruusiy risa̱ju̱ vachuy.
\v 30 Ra̱ma̱ ja̱vye vatajuu, ra̱tosa̱da rundasa̱ra̱ju̱. Ra̱tosa̱da rundamu ji̱ta ra̱tu̱chosiy ruuva jvaavye, rirya̱jato munatyara vachuy, rirya̱puchu mityatuuju̱ rupedaju̱ra. Jaruusiy ji̱ta rirya̱jato rábajyovimuju̱ day.”
\s1 Jesús tu̱choda quica̱tadinchiy
\r (Márcu 4.30-32; Dúcasiy 13.18-19)
\p 
\v 31 Satu̱choda ji̱ta Jesúsra ratarya dityadoda niquejadantiy: “Jarichumuvichi̱ nusu̱yada ji̱ta rañi̱cha nu̱tyu quica̱tadi nta day, jiryatiy sireda vanura, santa̱da variy yindimyuntirya.
\v 32 Dañuma pasityadidera rani̱cha ratadi, raja̱vyeñumatiy ravicha ja̱mura tiquiraju̱ tara nutasaramusiy. Raja̱vye ja̱muqui jiiqui nipya̱ti̱jiju̱ntiy, jasityi saruuvyeñuvi̱ rajiica̱mu variy.”
\s1 Jesús tu̱choda pa̱ cari̱vatya̱nchiy
\r (Dúcasiy 13.20-21)
\p 
\v 33 Saniquejada ji̱tara ratarya dityadoda niquejada ruuvantiy: “Jarichumuvichi̱ nusu̱yada ji̱ta rani̱cha nu̱tyu pa̱ cari̱vatya̱ nta, jiryatiy nanubayada vaturu̱y mumuri̱ quinu pa̱jurudinubera, jasicha̱ra̱ju̱tiy racari̱vay ti̱ta̱ju̱ variy.”
\s1 Jesús datyadodariy nijya̱nvay vinu dityadoda niquejadata
\r (Márcu 4.33-34)
\p 
\v 34 Jirya datyadoda ti̱ta̱ju̱ saniquejada Jesús dityadoda niquejadata ruuva nijya̱nvajyuuvedabay. Saniquejada ji̱ta ruuva vinu dityadoda niquejadamu.
\v 35 Rani̱ ji̱ta rani̱cha sa̱tidye jto̱tanirya Ju̱denuju̱ tu̱chu̱bay jteda:
\q1 “Ra̱muttara ri̱to ra̱tidye nique dityadoda niquejadata; ra̱tu̱chu varirya jiryatiy dutyasara mucadi ju̱desa̱damusidyerya.”
\s1 Jesús datyatadedara tu̱choda vachunchiy jiryatiy jaruusiy cabyivara
\p 
\v 36 Jadchiy ji̱ta satocheda Jesús riy nijya̱nvajyuuvedabay, sajayada ji̱ta rorivyimu. Rityuudiyadanumatiy sisa̱ datyavavyedabayu, ru̱teda variy siva: “Ya̱datyanu nu̱rya raniquejada tu̱choda vachunchiy nta, jiryatiy nutasara nta nudimyura.”
\v 37 Ni̱ni̱ ji̱ta jmutya̱jada variryi: “Ni̱ni̱ ji̱ta jiryatiy santa̱da ntara nutasarasiy samichiy, ni̱day sani̱cha Nijya̱mi̱denu.
\v 38 Nudiy nta ji̱ta rani̱cha jirya mucadi. Nutasarasiy samichiy nta ji̱ta riñi̱cha Ju̱denu nusu̱yadamuju̱ javye. Vachuchiy nta ji̱ta rani̱cha bayantu nicyara̱y quivu̱chuvay.
\v 39 Mityasiy ji̱ta jiryatiy santa̱da ntara vachutyadi, bayantu nutyityu̱ daryaju̱ dañi̱. Ra̱tosa̱da runda ji̱ta rani̱cha jiryatiy tamitya runda darya. Ra̱tovay ji̱ta Ju̱denu jpa̱vadye.
\v 40 Daryatiy rirya̱tora vachuy jiidamyu rupedaju̱, daryaday ra̱cha̱siy tamitya rundamuntiy.
\v 41 Sa̱jpa̱ Nijya̱mi̱denu riy yipa̱vay, rirya̱tidye jatosara sansu̱yadamusirya ti̱ta̱ju̱ jiryatiy juuchanuvaryi, Ju̱denu jiyaro̱nuvay jarye ruusa̱ju̱.
\v 42 Rirya̱jatya ri̱pa̱vay jiidatyo̱muju̱ variryi. Jasiñi̱ ji̱ta rirya̱jna̱vya̱ nijya̱nvay variy, rirya̱su̱y ji̱ta jijya̱dajchantiy.
\v 43 Jadchiy ji̱ta rirya̱viiday vase vichavay, nu̱tyu jiñi̱ nta, Vu̱jye̱ Ju̱denu nusu̱jyomu. Jiryetyuva̱chuta̱ta tu̱yutavay.”
\s1 Jesús tu̱choda dutyasaranchiy jiryatiy jaryi murichevaryara
\p 
\v 44 “Jarichumuvichi̱ nusu̱yada ji̱ta nu̱tyu tara nta jiryatiy jaryi murichevarya, jiryatiy ravichanu̱yada dutyasara nudivya. Sasaryejadanumatiy ti̱qui nijya̱mi̱ra, samutadodantirya. Si̱chana̱yadamu, saya̱da ji̱ta variy, sata̱ryu̱tya̱dara jiberya ti̱ta̱ju̱ jiryatiy simura, sa̱tidye ta̱ryu̱y variy ramurichiryatara nudiy.”
\s1 Jesús tu̱choda pérdanchiy jiryatiy jaryi murichevaryara
\p 
\v 45 “Ju̱na̱ntyi, Jarichumuvichi̱ nusu̱yada ji̱ta nu̱tyu ricyatu̱ nta jiryatiy sava̱tanumaya̱jada rana̱cho̱ pérda samichiy.
\v 46 Sasaryejadanumatirya tasiqui jaryi ja̱mura murichevarya, saya̱da variy, sata̱ryu̱tya̱dara ti̱ta̱ju̱ jiryatiy simura, sa̱tidye ta̱ryu̱y varirya pérda.”
\s1 Jesús tu̱choda ja̱mu riicyanchiy
\p 
\v 47 “Ju̱na̱ntyi, Jarichumuvichi̱ nusu̱yada ji̱ta vichasara nu̱tyu ja̱mu riicya nta, jiryatiy rijetya̱da jmityo̱mura. Rireda ji̱ta ja̱mu riicya variñi̱ quiva̱juu jaryedo.
\v 48 Rámu̱cha̱danumatiy riicya quiva̱ju̱, rityiiyada nijya̱nvay variy ti̱cha̱nchaju̱ra. Rimya̱sa̱da riicyanuvay quiva̱ jaryeta̱daju̱ variy jasiy. Ribeyada ji̱ta jtyuvimuni̱ quiva̱ jiryatiy jmyichi̱ dañi̱; jiryatimyu̱ ne jmyichi̱ dañi̱, rijetya̱da variy ja̱a̱muntiñi̱.
\v 49-50 Daryaday ra̱cha tamitya rundamuntiy. Rirya̱jaryetanuve Ju̱denu jpa̱varyi nijya̱nvay nicyara̱myi riquebyivasiy vase vichavay, rirya̱jatyasara variy jiidatyo̱muju̱ variryi. Jasiñi̱ ji̱ta rirya̱jna̱vya̱ nijya̱nvay variy, rirya̱su̱y ji̱ta variy jijya̱dajchantiy.”
\s1 Su̱teda Jesús: “Jasirya samirya datya̱da ta̱rijye̱myi datya̱damu, vadi datya̱damu jarye risa̱ju̱”
\p 
\v 51 Sitaja̱doda Jesús variryi yisa̱ datyavavyedabay: “¿Jiryedyetyama̱virya jirya ti̱ta̱ju̱ day?” Ru̱teda ji̱ta siva: “Joonu.”
\v 52 Ni̱ni̱ ji̱ta jteda variy ruuva: “Ramuni̱ nu̱ñi Ju̱denu niquejada datyanuvay tenu jiryatiy datyasi̱ Jarichumuvichi̱ nusu̱yadamu jayadaju̱ni̱, sani̱cha nu̱tyu rorijya̱mi̱ nta ni̱tiy rañi sipyatasara rabachajomusirya vadi datya̱da, ta̱riy datya̱da jarye risa̱ju̱.”
\s1 Jesús jañu̱yada Nasaryému
\r (Márcu 6.1-6; Dúcasiy 4.16-30)
\p 
\v 53 Satu̱chumu̱yadanumatiy Jesúsra jirya dityadoda niquejada, saya̱da ji̱ta jadchiy.
\v 54 Siti̱jadanumatiy jivyichajomuntiy, sadatyadoda variy riintye̱ryanijyomu nijya̱nvabeyu. Rityi̱tta̱da ji̱tara sadatyadoda, riñiquejada variy: “¿Tesiy sadatya jiñu vanura darya datya̱da day, tesiy? darya mityamusiy jvaayada jarye.
\v 55 ¿Ni̱ni̱ta jiiray jvaañu denuday? ¿Neviy su̱no̱da Maríya jtyatanu̱y, sataryi̱veda jarye Santiyácu, Jusíy, Siimyó̱, Judásiy jarye sisa̱ju̱ day?
\v 56 ¿Va̱ si̱tyamutuveda cay, nu̱tyi jiyu jtaday riñi̱cha vuryisa̱ day? ¿Tesiy ji̱ta sadatya jiñura jirya ti̱ta̱ju̱, tesiy?”
\v 57 Ne samirya ridyiyada variy sivanu̱day. Su̱teda ji̱ta Jesús variy ruuva: “Vinu taji vichavañi̱ tuva̱chu simu Ju̱denuju̱ tu̱chu̱, satuunuvichi̱ ji̱tamu̱y ne tuva̱churu̱y yimu day, sarorimyu vichavay jarye ne tuva̱churu̱y yimu.”
\v 58 Ne sivaañu̱yada Jesús rajuura mityamusiy tara jasiy, jiryatimyu̱ ne rityuva̱churu̱ñu̱yada daryaju̱ simu.
\c 14
\s1 Juán Bautístabay jvacha̱danchiy
\r (Márcu 6.14-29; Dúcasiy 9.7-9)
\p 
\v 1 Variryundamu ji̱ta satuva̱choda nutyityu̱ Jeródesberya sa̱ticheyada Jesús.
\v 2 Su̱teda variy ruuva jimyuchechimyibe: “Jiñutiñi̱ Juán Bautístabay. Sami̱sa̱sumimya̱ diibyimusiy, ramuni̱ ravichasara jaryi datya̱da simu.”
\p 
\v 3 Tapitya sirityadeda Jeródesbeñi̱ Juán Bautístabay, sapuchutadeda ji̱tani̱, sabayada nupocu rorivyimu variñi̱. Jerodíyaju̱be jiyasayadamu savichadeda darya variñi̱. Nanuvicha̱da Jerodíyaju̱be Jeródesbe taryi̱bay vaturu̱be, jiryatiy Vedípe jtyati̱bañi̱.
\v 4 Jiryatiy su̱teda Juán Bautístabay siva Jeródesbe: “Ju̱bachara ji̱ta ya̱vichasara nadisa̱ jityeryi̱ vaturu̱y Jerodíyaju̱y,” ramuni̱ savichadeda daryani̱ Juánbay.
\v 5 Dañuma su̱varyu̱ñu̱yada Jeródesbeñi̱ Juánbay, sasuvu̱ñu̱yada riy nijya̱nvabe jiryatiy ridyiñu̱yada siva Juánbay nu̱tyu Ju̱denuju̱ tu̱chu̱.
\v 6 Jadchiy ji̱ta, ravicha̱danumatiy sanijya̱ jto̱jada Jeródesbe, sara̱ya̱jada Jerodíyaju̱be detubay musuchavabe diya, jaryi su̱canuyada Jeródesbe varirya sara̱ya̱jada.
\v 7 Su̱teda Jeródesbe variy Ju̱denu jtyamu siva jidyetuvichi̱bay: “Ra̱day sa̱y ji jiryatiy ya̱jachiñu̱y rivara.”
\v 8 Su̱mutya̱jada vatura variñi̱ daryatiy nanudatyanunu̱yada ji̱tyaju̱ su̱no̱dabadyeyu: “Ya̱sa̱y Juán Bautísta jno̱ diyede musirye, sidyepye̱cya̱vimu.”
\v 9 Sayivatya̱da ji̱ta nutyityu̱ Jeródesbe variyu, dañuma sani jpa̱jada rirya̱sa̱y ni̱ra, jiryatiy saniquejasiy Ju̱denu jtyamu jimyusuvye diyara.
\v 10 Su̱pa̱jada ji̱ta variryi rirya̱tidye ra̱chara su̱no̱ Juánbay nupocu rorivyimu.
\v 11 Ru̱toda ji̱ta variy sidyepye̱cya̱vimura su̱no̱, riche̱yada variñi̱ vaturabay, ni̱day ji̱ta rañi jtoda yino̱dabamyuju̱ra.
\v 12 Juánbaysa̱ datyavavyedabay ji̱ta jiryi̱jada varirya sababyi, ru̱muchoda varirya. Rityu̱chunuvejada ji̱ta siva Jesús variy ranchiy.
\s1 Jesús potyadeda riy tadajyo vara̱nca vaduy
\r (Márcu 6.30-44; Dúcasiy 9.10-17; Juán 6.1-14)
\p 
\v 13 Satuva̱chodanumatiy Jesús Juán Bautístabay batyedanchiy, sanumuteda ji̱ta cartyevimu jadchiy vayitomuju̱. Ridyetya̱danumatiy nijya̱nvajyuubarya riya̱da Jesúsveda, richiityari̱jada jiñumututa ti̱ta̱ju̱ vicha̱divasiy variñi̱ Jesús.
\v 14 Ruutanuvejadanumatiy Jesúsveda, ridyiñuvejada ruuva nijya̱nvajyuubay, sa̱ntyutya̱da ji̱ta Jesús variryi, sami̱sadeda variryi ru̱diva̱jnuvay.
\v 15 Ri̱ñuvayadamu, ruuti̱jada ji̱ta sisa̱ datyavavyedabay yimu, ru̱teda variy siva: “Vu̱vyicha vayitomu jiyu. Jiryatiy ri̱ñuvañuma, ya̱tu̱chu ruuva nijya̱nvajyuu rirya̱tidye jiya̱siy rorivyicha̱mu, rirya̱tidye ta̱ryu̱y jimyi̱saraju̱ variy.”
\v 16 Su̱teda ji̱ta Jesús ruuva: “Ne rava̱tara riya̱da. Jirya̱ntya potyaniy jiyu riy nijya̱nvajyuu.”
\v 17 Ru̱teda ji̱ta variy siva: “Ne tara rajuura jmyichara nu̱dyimu jiyu, vinu tadajyojo pa̱, danu̱ju̱y quiva̱ju̱y risa̱ju̱.”
\v 18 Su̱teda ji̱ta ruuva: “Rumusiy jiyuju̱ra.”
\v 19 Sama̱satadeda ji̱tariy nijya̱nvajyuubay vachuncha variy. Siredanumatirya tadajyojo pa̱, danu̱ju̱y quiva̱ju̱y risa̱ju̱, su̱nu̱yada ji̱ta jarichuna̱cho̱ variy, si̱chana̱tya̱da variñi̱ jijye̱: “Ya̱bay samiy nu̱jyu̱ra jmyichara.” Sapatatiyada ji̱ta varirya pa̱jo, sasa̱yada variryi yisa̱ datyavavyedabay, riñuma ji̱ta sa̱yada variy nijya̱nvantyidyerya.
\v 20 Riibyeda ji̱ta ti̱ta̱ju̱, ripyoyada variy riva. Riryeda ji̱ta jtyu panujora jmyicharajuve, vu̱yaju̱y jtyu, dajtyuju̱y ranchaju̱.
\v 21 Jiryatiy riibyeda jasiy, rivyicha̱da tadajyo vara̱ncatuunu vaduy, rivyicha̱da vatuy jarye, deramiy jarye ruusa̱ju̱ rinchaju̱.
\s1 Jesús rupiyada jmityo̱ dutuuvya
\r (Márcu 6.45-52; Juán 6.16-21)
\p 
\v 22 Varicha̱ra̱ju̱ su̱musanityadeda riy yisa̱ datyavavyedabay cartyevimu: “Jirya̱numa jiya ra̱jiju̱ rudamyuju̱, ra̱tu̱chuchijedyi ruuva nijya̱nvadye.”
\v 23 Satu̱chuchedanumatiy ruuva nijya̱nvajyuu, saya̱da ji̱ta ja̱mu musimyuju̱ sa̱tidye tu̱chu yasiquita sisa̱ Ju̱denu jasiy. Ri̱ñupuyadanuma sa̱siquita variy jasiyu.
\v 24 Cartyequii ji̱ta ripyapunuma munayjisidyerya, rasantaja̱numa ri̱ye̱rya variy jasidyerya, tapi riicho daryaju̱ ju̱rirya.
\v 25 Rappa̱tyiryamu, saya̱da Jesús yisa̱ datyavavyedabamyu, jmityo̱ dutuuvya, sarupiyada ruumuju̱.
\v 26 Sisa̱ datyavavyedabay ji̱ta riñi diyadanumatiy siva sarupi jmityo̱ dutuuvya ruumuju̱, ru̱nteda ji̱ta variy: “¡Bayantu dyetya!” Riche̱ñe̱ya̱jada ji̱ta jichuvu̱yadamu variy.
\v 27 Varenude su̱teda Jesús variy ruuva: “Ne jirya̱jachipiya̱ ranijyu̱ suvu̱yada. Randye. Ne jirya̱jnutay.”
\v 28 Su̱mutya̱jada ji̱ta Pyítrubay variñi̱: “Jiñi̱ta Nutyityu̱, ya̱rupityaniy yimuju̱ ja̱a̱ dutuuvya darye.”
\v 29 Su̱teda ji̱ta siva: “Varenumacu̱.” Su̱musa̱da ji̱ta Pyítrubay variy cartyequiivimusiy, sarupicheda ji̱ta ja̱a̱ dutuuvya Jesúsmuju̱.
\v 30 Sadiyadanumatiy Pyítrubay riva riicho, sasuvu̱yada ji̱ta variy. Sajo̱ta̱da ji̱ta jayada variy, sasa̱ñe̱ya̱jada: “¡Ya̱jantyuy riva, Nutyityu̱!”
\v 31 Varicha̱ra̱ju̱ saratya̱da Jesúsra jijyase, sireda ji̱ta variy jasiñi̱, su̱teda variy siva: “Ne jaryi jachipiya̱ra ji. ¿Nu̱tyuramu jijechipurya jijechipiya̱jada, nu̱tyuramu?”
\v 32 Nana̱subeda ji̱ta cartyevimuju̱ntiy, randasa̱da ji̱ta riicho variy.
\v 33 Jiryatiy cartyevimu daryi, rirya̱dasidyoda Jesúsna̱cho̱ju̱yu, ru̱teda ji̱ta variy siva; “¡Jiñi̱ si̱tenu Ju̱denu denu!”
\s1 Jesús mi̱sadeda riy jdiva̱jnuvabe Jenesaryé mucadimu
\r (Márcu 6.53-56)
\p 
\v 34 Riryamityedanumatiy rudamyuju̱, ruuto̱jada ji̱ta Jenesaryé mucadimu.
\v 35 Ridyetya̱danumatiy jasiy vichavay vadubeñi̱ Jesús, ru̱pa̱jada ji̱ta variryi tu̱chuvay ru̱ro̱ vichavamyu ti̱ta̱ju̱. Ruuti̱ta̱da variy Jesúsmu riy ti̱ta̱ju̱ jiryatiy jdiva̱jnuvaryi.
\v 36 Riyasanta̱da variñi̱: “¡Vinu jichujay jidudyeniy ra̱ja̱tya̱quiii!” Rityi ja̱tya̱jada raniy, rimyi̱sa̱da variy riva.
\c 15
\s1 Nu̱tyuramusiy sami̱nu nijya̱mi̱ Ju̱denu diyayu, nu̱tyuramusiy
\r (Márcu 7.1-23)
\p 
\v 1-2 Jadchiy ji̱ta ruuti̱jada Varyisévuvedabay, Ju̱denu niquejada datyanuvavyedabay jarye Jesúsmu, Jerusarí̱musiy, ruutaja̱doda variñi̱: “¿Ta̱raju̱ra rirya̱vatya yisa̱ datyavarya ta̱rijye̱myi jtedamu vichasa̱da, ta̱raju̱? Tapitya ne richuutara jijyomutu jibyedajisiy.”
\v 3 Su̱mutya̱jada ji̱ta Jesús variryi: “Va̱ jiryeque, ¿ta̱raju̱ra jirya̱vatyara Ju̱denu jteda, ta̱raju̱? jirya̱tidye jiriryi̱ra ta̱rijye̱myi jteda variy.
\v 4 Tapi su̱teda ji̱ta Ju̱denu vuryiva: Vurya̱ntya tuva̱chu simu vu̱jye̱, vuryi̱no̱damu jarye, jadchintyi: Ni̱tiy ra̱javityiye̱ñi̱ jijye̱, varimyata su̱no̱da, rirya̱ma̱ jvachara variy rivani̱.
\v 5-6 Jiryeñi̱ ji̱ta rañi jtay: Saryityi jtay nijya̱mi̱ siva jijye̱, varimyata su̱no̱dava yitay: Rache̱yasimya̱te Ju̱denura jiryatiy raryi jmu̱tya raberyaterata sa̱da, ne sa̱tuva̱chu variy simu jijye̱. Ramuni̱ jiryebeyada mityara Ju̱denu niquejada, ta̱rijye̱myi jteda siityari̱jadaju̱.
\v 7-9 ¡Jiryi̱tu̱yada vichavay jirye! Si̱tenuni̱ sani tu̱choda Isayíyasibe Ju̱denuju̱ jiryenchiy:
\q1 Jivye nijya̱nvay jnuva̱y jiñiquejadata rivayu, rijechiy ji̱ta ripya ra̱jisiy varidye. Rirya̱dasiñu mitya ratyuunuyu, jiryatiy riñi datyadoda nu̱tyu Ju̱denu jteda rani̱cha daryaju̱ nijya̱mi̱ jteda.
\p Nu̱rya sanu̱yada Isayíyasibedyerya.”
\p 
\v 10 Sanatuyada ji̱ta Jesús variryi nijya̱nvabe yimuju̱, su̱teda variy ruuva: “Jiryetyuva̱chuta̱ta, jiryedyetyata̱tantiy.
\v 11 Ne vu̱me̱cho̱ jiyasachavay ru̱co̱siy tara jiryatiy vu̱ryi jmyidyerya; rani̱ ji̱ta ra̱juuchanu vu̱y, jiryatiy ra̱sipyatay vu̱jechivyimusidye.”
\p 
\v 12 Rityu̱chunuvi̱jada ji̱ta sisa̱ datyavavyedabay variy siva: “¿Jidyetyavidye Varyisévuveda vicha̱siy javityiye̱chavay jiñiquejadiva day?”
\v 13 Su̱mutya̱jada ji̱ta Jesús riy: “Ti̱ta̱ju̱ nijya̱nvay jiryatimyu̱ ne rityuva̱churu̱y simu Rajye̱, rivyichasara nu̱tyu nutasara jiryatimyu̱ ne santa̱da Rajye̱ Jarichumuvichi̱ra, ra̱chasara variy nuputasara.
\v 14 Rirye̱cha̱miy Varyisévuveda. Rivyichasara ji̱ta jiyantavamyi ni̱sipyuryimyi. Saryityi mutay ni̱sipyuryiñi̱ jityeryi̱ ni̱sipyuryi, nana̱ju̱u̱y mityijyijyu̱y vatajomu.”
\v 15 Su̱teda ji̱ta Pyítrubay variy siva Jesús: “Ya̱datyanura raniquejada, jirya dityadoda niquejada.”
\v 16 Su̱teda ji̱ta Jesús variy ruuva: “¿Daryani̱ ne datyavatye jiryetye didye?
\v 17 Ne jiryi̱nu̱tyeju̱u̱, jiryatiy si̱myi nijya̱mi̱ra tara, raramijechara variy savimuju̱, jadchiy ji̱ta raramijetyityi saqui̱najyomuju̱.
\v 18 Rani̱ ji̱ta jiryatiy rani sipyatay vuryi̱tosiy, vu̱jechimyusidyerya; rani̱ ji̱ta ra̱jarupanuni̱ nijya̱mi̱.
\v 19 Tapi rasipyatay nijya̱mi̱ jachivyasiy jachipiya̱jada, jiryatiy rani jachipiya̱taniy nicyara̱y jvaayadaju̱ni̱, nu̱tyu nijya̱mi̱ ju̱vedaju̱, ti̱ vaturu̱jsa̱ rupiyadaju̱, cadnavedacanuyadaju̱, paradodaju̱, quivu̱yada tu̱choda ti̱nijyu̱, javityiye̱yadaju̱ jarye ti̱ta̱ju̱.
\v 20 Rani̱ ji̱ta jarupanusarani̱ nijya̱mi̱. Jiryatiy sani jmyirya tara netimyu̱ sasuuta̱dara jijyomutu didye, ne ra̱jarupanu variy rivani̱.”
\s1 Nanutuva̱choda taji vicha̱da ja̱munu̱be simu Jesús
\r (Márcu 7.24-30)
\p 
\v 21 Saya̱da ji̱ta Jesús jadchiy, sanumuteda variy Tíru ju̱ro̱ju̱, Sitú̱ ju̱ro̱ju̱ jarye risa̱ju̱.
\v 22 Mityamusiy nanumu̱ti̱jada vaturu̱y Caná̱ ja̱munu̱be, jiryatimyu̱ ne nanuvicha̱da Judíyutoda day. Nanuniquejasubeda ji̱ta jasiy: “¡Ya̱jantyutyate ray, Nutyityu̱, Davyíbe jasi̱! Radyetu ji̱ta vichasara jaryi jarupantasi̱ bayantuta.”
\v 23 Jesús ji̱ta ne jmutya̱jada nada, mitya. Rityuudiyadanumatiy sisa̱ datyavavyedabayu, riyasanta̱da variñi̱: “Ya̱jpa̱ vuryimusiy nada, jiryatiy nanunatutyityi vu̱ryudivasivyu̱y.”
\v 24 Su̱mutya̱jada ji̱ta Jesús variryi: “Su̱pa̱jada ji̱ta Rajye̱rye, vinu ratyevay Irayénuvedamu, jiryatiy caravye Ju̱denu nú̱vasiryi.”
\v 25 Nana̱dasiñunuvi̱jada ji̱ta vaturu̱be variy satuunu Jesúsyu, nani̱teda variy siva: “¡Nutyityu̱, ya̱jmu̱tya ray!”
\v 26 Su̱mutya̱jada ji̱ta variñada: “Ne samirya vurya̱so̱varya Ju̱denu jmu̱tya̱da, nu̱tyu raryi vicha deramiy jmyi̱sara, vurya̱tidye jatya variy ruumuju̱ jiryatimyu̱ ne Ju̱denu jaryetasavaryi, nu̱tyu vu̱jetyara jmyichara ruumuju̱ vurya̱si̱miy nibyimidyera.”
\v 27 Nani̱teda variy siva: “Jo, Nutyityu̱, dañuma rani̱cha, nu̱tyi sani jmyidye nibyidera ra̱riy mi̱sara jmyichara daryuujyuu, jiryatiy raju̱u̱ya̱ saja̱mi̱ mi̱sanchasiy.”
\v 28 Jadchiy ji̱ta su̱mutya̱jada Jesús nada: “¡Vaturu̱y, jaryi tuva̱churu̱y sa̱da! Daryanuma ra̱cha sa̱daju̱, daryatiy sa̱dava̱tasara.” Sami̱sa̱da ji̱ta nanudetubay varicha̱ra̱ju̱.
\s1 Jesús mi̱sadeda riy jdiva̱jnuvajyuubay
\p 
\v 29 Saya̱da ji̱ta Jesús variy jadchiy, saramiryi̱jada variy Cadidéya jmityo̱jido. Sa̱subeda ji̱ta variy riva musiqui, sama̱sa̱da variy jasiy.
\v 30 Ruuti̱jada ji̱ta nijya̱nvajyuusuma variy simu, ruuti̱ta̱da yisa̱ variryi canuya̱sivyeda, jarapu̱yani̱miy, ni̱sipyuryimyi jarye ruusa̱ju̱, niquejasa̱miy, rajuuvay tara jdiva̱jadatavay jarye ruusa̱ju̱ ti̱ta̱ju̱, ribeyada Jesús numututuunu variryi. Sami̱sadeda ji̱ta variy jasiryi.
\v 31 Rityi̱tta̱da ji̱ta nijya̱nvarya, jiryatiy ridyiyada ruuva niquejasa̱miy jiryatiy riñiquejada daryaju̱, jarupanusavay jarye vicha̱da ratyevye, canuya̱sivyeda jarye vicha̱da vase rupivye varintyi, ni̱sipyuryimyi jarye vicha̱da ni̱sityavay ti̱ta̱ju̱ ruusa̱ju̱ntiy, riichana̱tya̱da variñi̱ Ju̱denu, Irayénuveda nutyityu̱.
\s1 Jesús potyadeda riy daryaju̱yu vara̱nca vadube
\r (Márcu 8.1-10)
\p 
\v 32 Jesús ji̱ta natuyada variy yimuju̱riy yisa̱ datyavavyedabay, su̱teda variy ruuva: “Ra̱ntyutya ji̱tariy nijya̱nvay, tapi rime̱cho̱siy mumurundamiñuma jiyu risa̱ riy, netara jna̱y tara riibyedaju̱, mitya. Ne ri̱pa̱ru̱y rimusiy jachi̱numu riy, riñuma diiryo̱vay nú̱ta̱sa.”
\v 33 Ru̱teda ji̱ta sisa̱ datyavavyedabay variy yiva: “¿Tesiy nu̱ña̱sarye jivye jmyityadedaju̱ra pa̱, tesiy? nu̱ña̱tidye potyaniryi nijya̱nvajyuusuma.”
\v 34 Sitaja̱doda ji̱ta Jesús variryi: “¿Nurijyo pa̱ jiryimu, nurijyo?” Ru̱mutya̱jadani̱: “Dajoju̱ñijyate, quiva̱midye jarye risa̱ju̱.”
\v 35-36 Sama̱satadedanumatiy Jesús mucadinchariy nijya̱nvay, saryeda ji̱ta dajoju̱ñijyate pa̱, quiva̱miy jarye risa̱ju̱, su̱teda ji̱ta variy Ju̱denunijyu̱: “Yentyutyama̱te pa̱ta nu̱y.” Sapatatityiyada varirya jmyichara, sasa̱yada ji̱ta yisa̱ datyavavyedabay varintyirya, riñi̱ ji̱ta sa̱yada variy nijya̱nvabentyidyerya.
\v 37 Riibyeda ji̱ta ti̱ta̱ju̱ nijya̱nvay variy, ripyoyada ji̱ta variy riva. Riryeda ji̱ta jtyu panujora jmyichara jve, dajtyuju̱ñijyate riinda.
\v 38 Jiryatiy riibyeda jasiy rivyicha̱da daryaju̱yu vara̱nca vaduy, rivyicha̱da vatuntyi, deramiy jarye ruusa̱ju̱.
\v 39 Sata̱rya̱tadedanumatiy Jesús riy nijya̱nvajyuuvedabay, su̱musa̱da ji̱ta cartyevimu, saya̱da variy Mardána ju̱ro̱ju̱.
\c 16
\s1 Varyisévuvedabay, Saadusévuvedabatya jachiñu̱yadara mityamusiy dityadoda
\r (Márcu 8.11-13; Dúcasiy 12.54-56)
\p 
\v 1 Ruuti̱jada ji̱ta Varyisévuvedabay, Saadusévuvedabatya simu Jesús, riñi jantyaru̱yada saniy Jesús. Ruutaja̱doda ji̱ta variñi̱: “Ya̱dityanura mityamusiy dityadoda jarichumusiy nu̱y.”
\v 2 Ni̱day ji̱ta jmutya̱jada varintyiryi: “Ra̱sacha̱damu jiryi̱tay: Diye ra̱viiday jaryi, jiryatiy ra̱sacha daryaju̱ samiryunda.
\v 3 Jiryi̱nu̱ñumatiy nupocu runda, jiryi̱tay variy: Ra̱numa jmu, jiryatiy radacutyityi rapuryerya. Jiryedyetya ji̱ta tu̱chodara nu̱tyura runda ra̱cha taranchiy, nu̱tyura, ne jiryedyetyaru̱y ji̱ta vu̱ryundanchiy, nu̱tyura ra̱chacu̱.
\v 4 Nijya̱nvay jamirya vichavay, jiryatiy rityochicharani̱ Ju̱denu, nu̱tyu rityochichara jmuchanuvedacanumiryi jivyatuy, riñi va̱tasara rana̱cho̱ mityamusiy dityadoda. Ne rirya̱diy ji̱ta riva mityamusiy dityadoda, mitya, vinu ra, jiryatiy sabayada Ju̱denu Jonásibenchirya.”
\p Satochedanumatiy Jesús variryi, saya̱da ji̱ta jadchiy.
\s1 Varyisévuvedabay datyadoda jiryatiy quivu̱chodatarara
\r (Márcu 8.14-21)
\p 
\v 5 Ruuto̱jadanumatiy sisa̱ datyavavyedabay jmityo̱ rudamyuntiy, ridyetya̱da variy jiryatiy ne rijechipitya̱da jtodara pa̱ yimu.
\v 6 Jesús ji̱ta jteda variy ruuva: “Jiryi̱nu̱tyata̱ta ra̱jisiy ricyari̱vatya̱ Varyisévuvedayu, Saadusévuveda jarye ruusa̱ju̱.”
\v 7 Ridyirya jiñiquetta̱da sisa̱ datyavavyedabay varidyeyu: “Su̱tay dyetya Jesúste dacyu̱, jiryatimyu̱ ne vuryi̱tura pa̱.”
\v 8 Sadatya̱danumatiy Jesúsra, su̱teda variy ruuva: “¿Ta̱raju̱ jiryeñiquettayu, ta̱raju̱? ¿Jiryatimyu̱ ne pa̱tavay jiryedye, pasidye jachipiya̱vay?
\v 9 ¿Ne jiryedyetyate didyejyu̱ú̱? ¿Ne jiryejechipityate nu̱nrya tadajyojo pa̱ nu̱dajyu̱ú̱, jiryatiy tadajyo vara̱nca vadujyuu jmyichirya? ¿Nurintyu panujo jirya̱tosirya jmyichara jve day, nurintyu?
\v 10 Va̱, dajoju̱ñijyate pa̱ jiryatiy daryaju̱yu vara̱nca vadujyuu jmyijerya, ¿nurintyu jirya̱tojay varintyi, nurintyu?
\v 11 ¿Nu̱tyuramusiy ne jiryecha̱ra̱ datya̱daju̱ra, nu̱tyuramusiy? jiryatiy ne rañiquejasiy pa̱nchidye. Jiryi̱nu̱tyata̱ta ra̱jisiy ricyari̱vatya̱ Varyisévuvedayu, Saadusévuveda jarye ruusa̱ju̱.”
\v 12 Jadchiy ji̱ta ridyetya̱da jiryatimyu̱ ne satu̱chuta Jesús ra̱jisiy pa̱ cari̱vatya̱, satu̱chuta ji̱ta ridyetyadodajisiyu, jiryatiy ridyetyanunu̱yada Varyisévuvedabarya, Saadusévuvedabay jarye.
\s1 Pyítrubay jteda vijyo̱mujache siva Jesús: “Jiñi̱ jiñi̱cha Ju̱denu jaryeti̱”
\r (Márcu 8.27-30; Dúcasiy 9.18-21)
\p 
\v 13 Siti̱jadanumatiy Jesús ru̱ro̱ Sesaréya Vidípu Vicha̱da, sitaja̱doda ji̱ta riy yisa̱ datyavavyedabay variy: “¿Nu̱tyura riñique nijya̱nvay Nijya̱mi̱denunijyu̱, nu̱tyura? ¿Chi̱ra rañi jtadye rañi̱day, chi̱?”
\v 14 Ru̱mutya̱jada ji̱tani̱: “Nu̱y ru̱tay: Juán Bautístabay ru̱tay ji. Ti̱ni̱ jtadye: Ne ni̱day, Edíyasibedye, ti̱ni̱ jtadye ji: Jiryimyíyabay, varimyata: Ju̱denuju̱ tu̱chuvay tenubay.”
\v 15 Su̱teda ji̱ta variy ruuva: “¿Va̱ jiryeque? ¿Chi̱ra jiryi̱tadyerye, chi̱?”
\v 16 Su̱mutya̱jada ji̱ta Siimyó̱ Pyítrubay variñi̱: “¡Jiñi̱ rañi̱cha Ju̱denu jaryeti̱ day, ju̱na̱re vichi̱ Ju̱denu denu!”
\v 17 Su̱mutya̱jada ji̱ta Jesús variñi̱: “Ju̱denu jmu̱tyasi̱ ji Siimyó̱ Jonásibe denu, jiryatiy ne jidyetyara jirya nijya̱mi̱ datya̱damusiy. Rajye̱ Jarichumuvichi̱ dityadosiy jiirya.
\v 18 Ri̱tatye yiva: Jiñi̱ rañi̱cha Pyítru (ravichu̱). Ra̱day roriirya raryorintyi (jiryatiy rachiityari̱vajyuu day) jiñu ravichu̱sumancha, dantyamu̱y ne rirya̱vuunu jiidatyo̱ja̱mi̱veda riy rachiityari̱vay.
\v 19 Ra̱day sa̱y jiirya Jarichumuvichi̱ nusu̱yada yevyijyu̱y. Jiryatiy ya̱puchu yevyitya jirya mucadincha, ra̱ma̱cho̱ puchusara jarichuvimuntiy, daryaday jiryatiy ya̱vita yevyitya mucadincha, ra̱ma̱cho̱ vitasara jarichuvimuntiy.”
\p 
\v 20 Jadchiy ji̱ta su̱bayada Jesús variy yisa̱ datyavavyedabayjisirya ratu̱chusa̱da: “Ne jirya̱tu̱chosiy ti̱devara jiryatiy rañi̱cha Ju̱denu jaryeti̱.”
\s1 Jesús tu̱choda jibetyedajiju̱
\r (Márcu 8.31-34; Dúcasiy 9.22)
\p 
\v 21 Jadchiñi̱ ji̱ta sajo̱ta̱da Jesús dityadoda riy yisa̱ datyavavyedabay: “Ra̱ma̱ jiya Jerusarí̱muju̱ jasityi ra̱paru̱tyajaya̱sara ray. Rirya̱vichaniy rimyityumiy darya ray, caserdótevyeda nutyityu̱miy, Ju̱denu niquejada datyanuvay jarye ruusa̱ju̱ ra̱vichanirye. Rirya̱jvay varirye, mumurundamimyusiy ji̱ta sa̱mi̱saniy Ju̱denuntirye.”
\p 
\v 22 Sa̱ra̱cheda ji̱ta Pyítrubañi̱ Jesús tajiñe̱cho̱ju̱, sajo̱ta̱da ji̱ta nique̱tya̱da variñi̱. Su̱teda siva: “¡Sa̱ma̱ jantyutya Ju̱denu ji, Nutyityu̱! ¡Tama̱ ra̱cha̱siy daryá jiijyu̱, tama̱!”
\v 23 Jesús ji̱ta janumityeda sana̱cho̱ju̱ Pyítrubay, su̱teda variy siva: “¡Ya̱jiintye ra̱jisiy, Satanásiy rapu̱rya! Jiñi̱cha nu̱tyu ta̱a̱nu̱ ra̱jiju̱, jiryatimyu̱ ne jijechipiya̱sarara Ju̱denu jachipiya̱jada. Jijechipiya̱ ji̱ta nu̱tyu nijya̱mi̱.”
\s1 Vu̱tyi siityari̱ru̱ñi̱ Crístu
\r (Márcu 8.34–9.1; Dúcasiy 9.23-27)
\p 
\v 24 Jadchiy ji̱ta su̱teda Jesús yisa̱ datyavavya: “Saryityi siityari̱ru̱y ti̱ ray, sa̱ma̱ paru̱y riva yivaaryu̱yada, sa̱ma̱ nichujaya̱ ntara jicyurusiy, jiryatiy sa̱bay nu̱tyu diiñuyu, ne sa̱riryi̱ varirya ta̱riy jivyicha̱danu̱day sa̱tidye siityari̱ varirye.
\v 25 Tapi mi̱ni̱tyi ramityaniryu̱rya yinu̱yada, sa̱pa̱chitya variy mityara; mi̱nintyi ji̱ta pa̱chityara yinu̱yada rayadaju̱, sa̱day saryesara varirya.
\v 26 Tapi ¿ta̱raju̱ra saryi ca̱na̱y nijya̱mi̱ra criquiy ti̱ta̱ju̱ vicha̱divasidye, ta̱raju̱? saryityi care varirya yinu̱yada riisa̱ju̱. ¿Ta̱ra murichiryana̱ sa̱sa̱y nijya̱mi̱ yinu̱yadaju̱, ta̱ra murichirya?
\v 27 Tapitya sa̱day jniy Nijya̱mi̱denu jijye̱ vandata ruusa̱ yipa̱vay, jadchiy ji̱ta sa̱murichenutaniñi̱ nu̱ñi ti̱qui nijya̱mi̱ yivaayada murichirya.
\v 28 Ri̱tatye si̱tenu jiryiva: Jiyu daryi jiryetyevay nijya̱nvay jiryatimyu̱ ne rirya̱datyara diiyada, netimyu̱ ne ridyi munatya riva su̱deda Nijya̱mi̱denu didye, jiryatiy sa̱jniy yinsu̱yadamu.”
\c 17
\s1 Jesús ti̱tuyadanchiy
\r (Márcu 9.2-13; Dúcasiy 9.28-36)
\p 
\v 1 Jadchiy ji̱ta tarundaquinijyatemusiy, Jesús jara̱yada yisa̱ju̱ riy Pyítrubay, Juánbay, Santiyácubay jarye, sayata̱da ji̱ta ja̱mumusimyuju̱ rirya̱siquitayu.
\v 2 Sati̱tuyada ji̱ta Jesús ridyiyadajache variy. Raviideda ji̱ta samo̱, nu̱tyu jiñi̱ nta variy, sasujay ji̱ta vicha̱da jaryi pupajay, vandajay ravicha̱da risa̱ju̱, nu̱tyu vindya nta.
\v 3 Mityamusiy nanumu̱ti̱jada ji̱ta Muyusésijyu̱be bayanu, Edíyasiy bayanu jarye sisa̱ju̱, jiryatiy nanutu̱choda Jesúsjsa̱.
\v 4 Su̱teda ji̱ta Pyítrubay variy siva Jesús: “¡Ta̱ jaryi samiryani̱te nu̱jyu̱te jiyu, Nutyityu̱, ta̱ju̱! Jivya̱tatiy, ra̱su̱ta̱y mumuta̱myi jiyu, tata̱qui jijyu̱ day, da tata̱qui Muyusésijyu̱, da tata̱qui Edíyasijyu̱.”
\v 5 Saniquejadamu, mityamusiy racanuvu̱doda rapuryerya vandasumarya variryi. Rityuva̱choda ji̱tara ti̱ niquejada virinubesiy: “¡Jiñu ji̱ta radyenu jaryi va̱tasi̱, jaryi ri̱chana̱tyateni̱! ¡Jirya̱ma̱ tuva̱chu simu!”
\v 6 Rityuva̱chodanumatiy sisa̱ datyavavyedabarya jirya niquejada, rirye̱yada ji̱ta jimyo̱ta variy, jichuvu̱yadamu.
\v 7 Saja̱tyo̱nuvi̱jada ji̱ta Jesús variy riñiy, su̱teda variy ruuva: “Jirya̱nubesumiy, ne jirya̱suvu̱y.”
\v 8 Ru̱nu̱yasubedanumatiy, ne ru̱nu̱yada ti̱na̱cho̱, vinu Jesús.
\p 
\v 9 Ru̱musa̱danumatiy ja̱mumusimyusiy, su̱bayada ji̱ta Jesús variy rirya̱jisirya: “Ne jirya̱tu̱chu ti̱devara jiryatiy jiryedyiyasiy riva. Sa̱numatiy mi̱sa Nijya̱mi̱denu diibyimusiy, variñuma ji̱ta jirya̱tu̱chura.”
\p 
\v 10 Ruutaja̱doda ji̱ta sisa̱ datyavavyedabay variyu: “¿Nu̱tyura ru̱tay variy Ju̱denu niquejada datyanuvay, nu̱tyura? Saryi jnijedyi munatya Edíyasiy.”
\v 11 Su̱mutya̱jada ji̱ta Jesús riy: “Ri̱tatye ji̱ta jiryiva: Su̱nichara ji̱ta Edíyasiy, saryi ratyanu ti̱ta̱ju̱ra tara.
\v 12 Ri̱tatye ji̱ta jiryiva: Su̱nimya̱ ji̱ta Edíyasiy, tama̱ ridyetya̱da variñi̱, tama̱, rivyichanichiy rumu tarani̱, daryatiy rivyichaniryu̱chidyeñi̱. Darya ni̱day sa̱paru̱tyajaya̱sara Nijya̱mi̱denu rijyomutumusiyu.”
\p 
\v 13 Jadchiy ji̱ta ridyetya̱da sisa̱ datyavavyedabay jiryatiy saniquenu̱yada Juán Bautístabaynchirya.
\s1 Jesús mi̱sadedani̱ dera jatayani̱bay jiryatiy jamiryanu bayantuti̱ni̱
\r (Márcu 9.14-29; Dúcasiy 9.37-43)
\p 
\v 14-15 Siti̱jadanumatiy nijya̱nvajyuumu, sa̱dasiñunuvi̱jada ti̱qui vanu satuunu Jesúsyu, su̱teda variy siva: “Nutyityu̱, ya̱jantyutyani̱ radyenu jiryatiy jatayani̱ni̱, saparu̱tyasara jaryi rivayu, tapi japichiy saju̱u̱y jiidamyu, ja̱a̱mu jarye saju̱u̱y.
\v 16 Rañi pu̱chesiy ji̱ta yisa̱ datyavamyuni̱, ne vana̱y rimyi̱saniñi̱.”
\v 17 Su̱mutya̱jada ji̱ta Jesús variñi̱: “¡Jiii, ta̱ra nijya̱nvay jachipiya̱jadaruyutavay jiryeñi̱cha day, jiryatimyu̱ ne jiryetyuva̱churu̱y simu Ju̱denu! ¿Nuriryundasa̱ra̱ju̱ ra̱ma̱cho̱ jiryisa̱, nuriryundasa̱ra̱ju̱? ¿Nuriryundasa̱ra̱ju̱ ra̱jachi̱niy variy jiryimusirye, nuriryundasa̱ra̱ju̱? Ya̱pu̱chiy jiyuju̱ni̱.”
\v 18 Sanique̱tya̱da ji̱ta Jesús variñi̱ bayantu, sasipyateda ji̱ta variy sivasiy, sami̱sa̱da ji̱ta derapubay varicha̱ra̱ju̱.
\v 19 Jadchiy ji̱ta rityuudiyada sisa̱ datyavavyedabay yasiquitayu, ruutaja̱doda ji̱ta variñi̱: “¿Nu̱tyuramuna̱mu̱y ne vana̱y nu̱jetya nu̱ntyidyeñi̱ bayantuntidye, nu̱tyuramu?”
\v 20 Su̱mutya̱jada ji̱ta Jesús variryi: “Jiryatiy jaryi pasidye jachipiya̱vay daryaju̱ jiryedye. Tapi ri̱tay si̱tenu jiryiva: Raryityi vicha jiryetyuva̱choda nu̱tyu quica̱tadidera, jiryejtay variy riva jirya musiqui: Ya̱ja̱ta jiyusiy mu̱jyu̱ ji, ra̱day ja̱ta variyu. Ne ra̱su̱tye tara variy jiryivaayadaju̱.
\v 21 Ne vana̱y sasipyateda dañu bayantu, tetya vu̱tyu̱chosiy munatya vuryi̱nra̱damu sisa̱ Ju̱denu.”
\s1 Jesús jatyiyada tu̱choda jibetyedajiju̱ntiy
\r (Márcu 9.30-32; Dúcasiy 9.43-45)
\p 
\v 22-23 Riryupiyadanumatiy Jesúsveda Cadidéyava, su̱teda ji̱ta Jesús ruuva yisa̱ datyavavyedabay: “Ra̱numa ju̱to̱ sasa̱cha̱da runda Nijya̱mi̱denu, jiryatiy sa̱sa̱y ti̱qui nijya̱mi̱ tavay nijya̱nvay jomuni̱, rirya̱jvay variñi̱, sa̱mi̱saniy Ju̱denu mumurundamimyusiy varintyiñi̱.” Riñuvayada jaryi variy saniquejadanchiy.
\s1 Samurichedodara criquiy Ju̱denu roriy jdutyatanitya̱ju̱
\p 
\v 24 Ruuto̱jadanumatiy Capernavú̱mu, rityuudiyada ji̱ta vadubeñi̱ Pyítrubay, jiryatiy rivya̱ta̱da rana̱cho̱ criquiy, Ju̱denu roriy jdutyatanitya̱ju̱. Ruutaja̱doda ji̱tani̱ Pyítrubay: “¿Neviy samurichenu jiryedyetyanu̱ra criquiy, Ju̱denu roriy jdutyatanitya̱ju̱ day?”
\v 25 Su̱mutya̱jada ji̱ta variryi: “Jo.” Sajayadanumatiy Pyítrubay variy rorivyimu, saniquejada Jesús munatya siva: “¿Nu̱tyura jijechipiya̱ Siimyó̱, nu̱tyura? Jirya mucadiva vichavay nutyityu̱miy, ¿chi̱musiy riryi jmutya̱ra criquiy taraju̱, chi̱musiy? ¿riñijya̱nvamyusiy dyetya, varimyata tavamyusiy?”
\v 26 Su̱mutya̱jadanumatiy Pyítrubañi̱: “Tavamyusiy ji̱ta,” su̱teda Jesús variy siva: “Ne riryi murichenu variy riñijya̱nvarya.
\v 27 Dañuma, vu̱ñuma nique̱ttaniryi criquiy jmutya̱vay, ya̱jachityanuvera ja̱muca̱ju̱u̱ jmityo̱mu, jasityi sa̱siryi̱ quiva̱ toyaniy. Ni̱tiy ya̱jo̱ta piryu̱yada, ya̱janantyadesiñi̱, jasityi ya̱diy riva criquidye. Ya̱sa̱yasiy variy criquiy jmutya̱varya, ranuma ra̱cha vatajuu vuryimusiy.”
\c 18
\s1 ¿Mi̱ra sani̱cha nijya̱mi̱ jaryiñu̱ Jarichumuvichi̱ nusu̱yadamu, mi̱?
\r (Márcu 9.33-37; Dúcasiy 9.46-48)
\p 
\v 1 Varidyeni̱day rityuudiyada sisa̱ datyavavyedabay Jesúsyu, ruutaja̱doda variñi̱: “¿Mi̱ra sani̱cha nijya̱mi̱ jaryiñu̱ Jarichumuvichi̱ nusu̱yadamu, mi̱?”
\v 2 Sanatuyada ji̱ta Jesús variñi̱ ti̱qui derapubay, saranityadeda ji̱ta riquebyimuni̱.
\v 3 Su̱teda ji̱ta variy ruuva: “Ri̱tay si̱tenu jiryiva: Netimyu̱ jirya̱ta̱rya̱sara nta nu̱tyu deramiy ntaju̱, ne jirya̱jachara Jarichumuvichi̱ nusu̱yadamu.
\v 4 Ramuni̱ mi̱ni̱tyi ra̱cha tapimusiy siityera, nu̱tyu jiñu derapude daryá, ni̱ni̱ ji̱ta ra̱chasara jaryiñu̱ Jarichumuvichi̱ nusu̱yadamu.
\v 5 Mi̱nintyi ji̱ta ra̱dirye ri̱tyamuni̱ deradera nu̱tyu jiñu, ni̱ni̱ ra̱dirye varintyirye.”
\s1 Jatyí vu̱cyareni̱ ti̱ Ju̱denu nú̱jisiy
\r (Márcu 9.42-48; Dúcasiy 17.1-2)
\p 
\v 6 “Mi̱ni̱tyi ra̱care ra̱jisiy Ju̱denu nú̱quini̱ jivyetyenu, ni̱tiy rañi tuva̱chu rimu, nu̱tyu derapudera, samiryava̱ju̱ ji̱ta raryicha saju̱, riryityi puchu nijya̱nvañi̱ ravichu̱suma sapita̱sa, riryi jatya variy ja̱mu na̱vajacheni̱.
\v 7 Ta̱ju̱na̱te nijya̱nvajyu̱ juuchanitya̱, ta̱ju̱, tapi ra̱day jniy juuchanitya̱. ¡Acuu! ta̱ju̱na̱tedañi̱, ta̱ju̱, simusityi riti̱ juuchanitya̱.
\p 
\v 8 Nu̱tyi rani̱day jijyomutu, varimyata jiñumutu, rañi care Ju̱denu nú̱jisiy ji, ne jirye̱charaju̱u̱, ya̱jatya variy yimusirya. Samiryava̱ju̱ daryaju̱ jiijyu̱ ya̱jay jomutuvu̱, varimyata numutuvu̱, ju̱na̱reju̱ jnu̱yadamu, jiiñuma jti̱ miryanuvu̱ jiidatyo̱vimuju̱.
\v 9 Nu̱tyi rani̱day jiñi̱siy rañi care Ju̱denu nú̱jisiy ji, ya̱sitya varirya jiñi̱sityadi, ya̱jatya variy yimusintyirya. Samiryava̱ju̱ daryaju̱ jiijyu̱ ya̱jay tadañi̱siy ju̱na̱re jnu̱yadamu, riñuma jatya datadiju̱y ni̱sityi̱ jiidatyo̱vimuju̱ ji.”
\s1 Jesús tu̱choda carni̱ru carañunchiy
\r (Dúcasiy 15.3-7)
\p 
\v 10 “Jiryi̱nu̱tyata̱ta rrachodajisiñi̱ ti̱quide jivye deramiy tenu, tapi ri̱tatye jiryiva jiryatiy ru̱nu̱tyavay ji̱ta jnu̱chara riva samo̱ Rajye̱ Jarichumuvichi̱, jiryatiy su̱pa̱vay daryaju̱ riy.
\v 11 Tapi siti̱ma̱ ji̱ta Nijya̱mi̱denu, sa̱tidye jantyuy ruuva nijya̱nvay caravye.
\v 12 ¿Nu̱tyura jiryejechipiya̱, nu̱tyura? Saryityi vichasara nu̱ vanu taraqui pacha jasi̱ti̱, saryityi caray ti̱qui rityenu, ¿neviy sa̱tochiy pástumu riy yasi̱ jnura, sa̱tidye jiya va̱ti̱ sana̱cho̱ carañu?
\v 13 Saryityi saryeñi̱, ri̱tay si̱tenu jiryiva: Si̱chana̱tya jaryi variñi̱ saryechi̱, ruumusiy yasi̱ jnuramiy jiryatimyu̱ ne caravyedyeryi.
\v 14 Darya ni̱day ne sava̱ta rajye̱ Jarichumuvichi̱ sa̱caray ti̱quide rityenu jivye derapudera.”
\s1 Jesús datyadoda nu̱tyuramusiy vurya̱ramityaniy mitya siva vu̱tyeryi̱ra juuchuveda, nu̱tyuramusiy
\r (Dúcasiy 17.3)
\p 
\v 15 “Saryityi juuchuvay ti̱ jityeryi̱ jiiñijyu̱, ya̱tu̱chu yasiquita sivara. Saryityi tuva̱chu yimu, jicya̱na̱mya̱ni̱ jityeryi̱.
\v 16 Netimyu̱ satuva̱churu̱y yimu, ya̱pu̱chiy ti̱quintiy, varimyata danu̱ju̱y jityevay yisa̱ simu, rirya̱tidye datya danu̱ju̱myusiy, varimyata mu̱nvamyusirya ti̱ta̱ju̱ sa̱daniquejada.
\v 17 Netimyu̱ saryi tuva̱churu̱y nadimuntiy, ya̱tu̱chu ruuva Ju̱denu siityari̱vajyuura. Netimyu̱ ne saryi tuva̱churu̱y ne vinu siityari̱vajyuumu, ya̱vichaniy nu̱tyu nijya̱mi̱ carañu variñi̱, varimyata criquiy jmutya̱nu jiryatiy juuchati̱ni̱.
\p 
\v 18 Ri̱tatye si̱tenu jiryiva: Jiryatiy jirya̱puchu jirya mucadinchara, ra̱ma̱cho̱ puchusara jarichuvimuntiy. Daryaday jiryatiy jirya̱vita mucadinchara, ra̱ma̱cho̱ vitasara jarichuvimuntiy.
\v 19 Ju̱na̱ntyi ri̱tay jiryiva: Naryityi jachipiya̱ vatajuu danu̱ju̱myusiy jiryetyenuju̱y taranchiy, jiryatiy nana̱jachiñu̱y Ju̱denuvara, daryani̱ ra̱cha nadaju̱ Rajye̱ Jarichumuvichi̱musiy.
\v 20 Tapi jasityi riintye̱ryaniy ri̱tyamu mu̱nvamyusiyu, varimyata danu̱ju̱myusiy, jasiñuma rañi̱cha riquebyimu variy.”
\p 
\v 21 Jadchiy ji̱ta satuudiyada Pyítrubañi̱ Jesús, su̱teda variy siva: “¿Nutyityu̱, nuriryaju̱ra ra̱ramityaniy mitya siva ratyeryi̱ra juuchuveda, nuriryaju̱? jiryatiy sajuuchuvay rañijyu̱. ¿Daraju̱ñijyateju̱ day?”
\v 22 Su̱teda ji̱ta Jesús siva: “Ne ri̱tay vinu daraju̱ñijyateju̱; ri̱tatye ji̱ta daraju̱ñijyate vu̱yaju̱jyu̱ra daraju̱ñijyate.”
\s1 Jesús tu̱choda muchechinchiy, jiryatimyu̱ ne saramityaniryu̱y mityara jityenu divyiyada
\p 
\v 23 “Ramuni̱day Jarichumuvichi̱ nusu̱yada rani̱cha nu̱tyu ja̱mu nutyityu̱ ni̱tiy rañi jdutyaru̱y jimyuchechimyityara cuenta.
\v 24 Sajo̱ta̱danumatiy jdutya̱da, rityuudityaniñi̱ ti̱qui nijya̱mi̱, sadivyiñu̱yada rajuura vara̱nca criquichumani̱.
\v 25 Jiryatimyu̱ ne vana̱y samurichenura jidyivyi, su̱pa̱jada ja̱mu nutyityu̱ ritye̱ryu̱tya̱daju̱ variñi̱, savaturu̱y jarye yisa̱ju̱, sadadyeñu jarye, ratatiy sa̱murichenura jidyivyi.
\v 26 Ramuni̱tiy sa̱dasidyoda ji̱ta muchechiy satuunuyu, sayasanta̱da ji̱ta variñi̱: ‘¡Ya̱jachi̱niy ji, Patru̱, tapimusiy ra̱murichenu ti̱ta̱ju̱ jiquiii!’
\v 27 Sa̱ntyutya̱da ji̱ta ja̱mu nutyityu̱ variñi̱ jimyuchechiy, su̱mu̱rya variñi̱, saramityaniy mitya varirya sadivyintyi.
\v 28 Ni̱day ji̱ta, sasipyatedanumatiy jadchiy, sasaryejada ji̱tani̱ ti̱qui jiryenu muchechiy, jiryatiy sani divyi vinu mu̱nvay jarimyuni̱ jvaayada murichiryani̱. Siredanumatiy sapita̱sa, su̱teda siva: ‘¡Ya̱murichenura jidyivyi!’
\v 29 Ramuni̱ sara̱yada saryenu muchechiy jityuunu, sajachiñu̱yada variy siva: ‘Ya̱jachi̱niy ji, tapimusiy ra̱murichenu ji.’
\v 30 Sava̱tavitya. Saya̱da ji̱ta variy, satanuvu̱nutadeda variñi̱ jiryenu muchechiy, jasicha̱ra̱ju̱tiy sa̱murichenura jidyivyi.
\v 31 Ru̱nu̱yadanumatiy saryenu muchechimyi, riyiveda jaryi ranchiy, riya̱da variy tu̱chuvay simu ja̱mu nutyityu̱.
\v 32 Sanatutyadeda ji̱ta ja̱mu nutyityu̱ variñi̱, su̱teda ji̱ta siva: ‘¡Muchechiy nicyara̱ryapu̱rya! Raryamityadesiy mitya ti̱ta̱ju̱ra jidyivyi, jiryatiy jiyasanta̱da riva ray.
\v 33 ¿Neviy jiryi jantyutyani̱ jiryenu muchechiy, daryatiy ray jantyutya̱sidye ji?’
\v 34 Sanique̱yadamu, sapatru̱ sa̱yada tanuvu̱nujo jnu̱tyavamyuju̱yu, jasicha̱ra̱ju̱tiy sa̱murichenu ti̱ta̱ju̱ra jidyivyi.
\v 35 Darya ni̱day Rajye̱ Jarichumuvichi̱ ra̱vichaniy nu̱ñi ti̱quimusiy jirye, jiryeñuma ramityaniy mitya jijechimyusirya jiryetyenu juuchuveda.”
\c 19
\s1 Jesús datyadoda tova̱jadanchiy
\r (Márcu 10.1-12; Dúcasiy 16.18)
\p 
\v 1 Satu̱chumu̱yadanumatiy Jesúsra jirya niquejada, saya̱da variy Cadidéyamusiy Judéyamuju̱ jiryatiy Jurdá̱ja̱ rudamyura.
\v 2 Richiityari̱jada nijya̱nvajyuusumani̱, sami̱sadeda ji̱ta variy jasiryi.
\p 
\v 3 Ru̱deda ji̱ta Varyisévuvedabay variy simu Jesús, rirya̱ntya̱da variñi̱ jiryatiy ruutaja̱dodani̱: “¿Samiryavidye sa̱tova̱ ti̱qui nijya̱mi̱ tariva nada jivyaturu̱y?”
\v 4 Ni̱ni̱ ji̱ta jmutya̱jada variryi: “¿Neviy jiryi̱nu̱yada catera nu̱charamu, nu̱tyu su̱ndejada Ju̱denu jo̱ta̱damuni̱ nijya̱mi̱, su̱ndejadani̱ ti̱qui vanu, ti̱qui vatura sisa̱ju̱ day?”
\v 5 Saniquejada ji̱ta variy: “Ramuni̱ sa̱tochiy vanu nada yino̱da, saja̱y jarye, sa̱tidye ja̱mu̱ñi̱ vatura, danu̱ju̱myusiy nana̱cha ti̱qui variy.
\v 6 Ne danu̱ju̱y variñada nu̱ndye, ti̱quinuma sa̱cha varidye. Ramuni̱tiy, jiryatiy sabayada Ju̱denu daryá, sa̱tiy ja̱mu̱chara nijya̱mi̱, ne sa̱jiintyetyaniy ti̱ variñi̱.”
\v 7 Ru̱teda ji̱ta variy siva Jesús: “¿Ta̱ju̱ramusiy variy su̱teda Muyusésibe: Sa̱ma̱ sa̱y vanura catera nu̱chara tová̱vi̱, sa̱tidye tova̱ rata nada jivyaturu̱y?”
\v 8 Su̱mutya̱jada riy: “Jiryatiy surra daryaju̱ra jiryejechiy, ramuni̱tiy su̱mutya̱jada Muyusésiberya jiryevyaturu̱y tova̱jada. Ne ravichanu̱yada daryá jo̱ta̱damusiy.
\v 9 Ri̱tatye ji̱ta jiryiva: Mi̱ni̱tyi tova̱nada jivyaturu̱y, netimyu̱ naryi rupi vanujsa̱, saryityi ja̱mu̱y ti̱ nadivasintyi, sa̱jarupanu variy ratara nanuvicha̱da ti̱ta̱ju̱ nijya̱nvay diya, jiryatiy rirya̱diy nadiva nu̱tyu jmuchanutanu̱y variñada.”
\v 10 Ru̱teda ji̱ta sisa̱ datyavavyedabay variy yiva: “Daryatiy ravichasara vanuju̱ jivyaturu̱tya, ne dyetya samirya vurya̱ja̱mu̱y variy.”
\v 11 Su̱teda ji̱ta variy ruuva: “Ne vana̱y rirya̱jmutya̱ ti̱ta̱ju̱ nijya̱nvarya rañiquejada, vinuni̱ saju̱tiy rache̱rya.
\v 12 Jasidye ji̱tariy nijya̱nvay jiryatiy riryupedamusiy jiñi̱cha myistyasavay. Jasintyiryi nijya̱nvantyi jiryatiy riñi̱cha myistyasavay nijya̱nvay vichadedamusiy. Jadchiy, rivyichasara nijya̱nvay myistyasavay nta, jiryatiy Jarichumuvichi̱ nusu̱yada jiyadaju̱ rivyichasara daryá. Ni̱tiy jmutya̱ru̱rya jirya niquejada, sa̱ma̱ jmutya̱ra.”
\s1 Jesús jachiñu̱yadara Ju̱denu jmu̱tya̱da deramiy jiyadaju̱
\r (Márcu 10.13-16; Dúcasiy 18.15-17)
\p 
\v 13 Jadchiy ji̱ta ruuti̱ta̱da riy deramidyera simu Jesús sa̱tidye ja̱tyo̱ jijyomututa riñiy, sa̱tu̱chu variy riyadaju̱ sisa̱ Ju̱denu. Sisa̱ datyavavyedabay ji̱ta nique̱tya̱da riy nijya̱nvabe riva.
\v 14 Jesús ji̱ta niquejada variy: “Ne jirya̱niquetta riy deramiy, rirya̱ma̱ ju̱ti̱ rimu. Ne jirya̱jbarya ruuti̱jada, tapi ritya ra̱chasara Jarichumuvichi̱ nusu̱yadamu, riñi̱cha nu̱tyu deramidyera.”
\v 15 Sabayadanumatirya jijyomutu variy riñiy, saya̱da ji̱ta variy jadchiy.
\s1 Satu̱choda vadero̱nubay jaryi tarati̱ sisa̱ Jesús
\r (Márcu 10.17-31; Dúcasiy 18.18-30)
\p 
\v 16 Mityamusiy su̱tañuvi̱jada ti̱qui vanubay siva Jesús: “Datyanu̱, ¿ta̱ra jvaayada raryi jvaachara samirya, ta̱ra? ra̱tidye vichasara ju̱na̱reju̱ jnu̱yadati̱.”
\v 17 Su̱teda ji̱ta Jesús variy siva: “¿Ta̱ju̱ra yitaja̱nu ranchiy samirya ray, ta̱ju̱? Ti̱qui sani̱cha si̱tenu sami̱. Jityi jaryu̱y ju̱na̱reju̱ jnu̱yadamu, ya̱vichasara su̱tedamu Ju̱denu.”
\v 18 Su̱teda ji̱ta variy siva Jesús: “¿Mirya su̱teda, mirya?” Su̱teda ji̱ta Jesús siva: “Jirya: Ne vurya̱jvañi̱ ti̱, ne vurya̱rupi ti̱ vaturu̱jsa̱ vu̱ntyi, ne vurya̱paranu risa̱ju̱, ne vurya̱niquera quivu̱yada ti̱nijyu̱ntiy.
\v 19 Vurya̱ma̱ tuva̱chu simu vu̱jye̱, vuryi̱no̱damu jarye, jadchintyi: Vurya̱ma̱ va̱tasarani̱ vu̱tyuunuvichi̱ntidye, nu̱tyu vu̱vya̱tatiy darya vu̱y.”
\v 20 Su̱teda vadero̱nubay variy siva Jesús: “Ratyuva̱chumu̱yada ramu ti̱ta̱ju̱. ¿Ta̱ranuma ra̱su̱tye variy rajyu̱, ta̱ra?”
\v 21 Su̱teda ji̱ta Jesús variy siva: “Jityi vicharu̱y si̱tenu tuva̱churá ti̱ta̱ju̱mu, ye̱jiya, ya̱ta̱ryu̱tyara jiryatiy ti̱ta̱ju̱ yimura, ya̱sa̱y variy ramurichirya riy jantyuyadavay. Variñi̱ ji̱ta ye̱cha tarati̱ jarichumu. Varenumacu̱, ya̱siityari̱sara varirye.”
\v 22 Satuva̱chodanumatiy vadero̱nubarya jirya niquejada, saya̱da ji̱ta vayivacha̱ variy, jiryatiy jaryi tarati̱ daryaju̱ dañi̱.
\p 
\v 23 Jesús ji̱ta jteda variy ruuva yisa̱ datyavavyedabay: “Ri̱tatye si̱tenu jiryiva: Surra ji̱ta ra̱cha Jarichumuvichi̱ nusu̱yadamu jayada saju̱ ni̱tiy jaryi tarati̱.
\v 24 Ju̱na̱ntyi ri̱tay jiryiva: Saryityi ramije camélluquisuma rodanru̱ju̱ vimu, saryi jay ji̱ta jaryi tarati̱ variy Ju̱denu nusu̱jyomuntidye.”
\v 25 Rityuva̱chodanumatiy sisa̱ datyavavyedabarya jirya niquejada, rityi̱tta̱da jaryi varirya, riñiquejada variy: “¿Chi̱rana̱te ra̱ramityasarate, chi̱?”
\v 26 Su̱teda ji̱ta Jesús variy yinu̱yadamu: “Ne vana̱y sivaayada nijya̱mi̱ra, Ju̱denu ji̱ta ti̱ta̱ju̱ ra̱jvaachara darya.”
\p 
\v 27 Jadchiy ji̱ta su̱mutya̱jada Pyítrubañi̱: “Ya̱jnu̱y, nu̱y ji̱ta tochedara jiberya ti̱ta̱ju̱, nu̱chiityari̱jada variy ji. ¿Ta̱ra ra̱cha nu̱dyimu riva, ta̱ra?”
\v 28 Su̱teda Jesús variy ruuva: “Ri̱tatye si̱tenu jiryiva: Vadi mucadimu, sa̱numatiy ma̱sa Nijya̱mi̱denu vanda jimya̱sajoncha, jirye rachiityari̱vay, jirya̱day ma̱sa jimya̱sajonchantidye, vu̱yaju̱jyo ma̱sajo, dajoju̱y ranchaju̱, jasityi jirya̱jdutyasarara rityu̱chutasa̱da Irayénuveda, jiryatiy rajuumusiy ti̱ta̱ju̱, taraqui vu̱yaju̱y ju̱riiñutavaryi, dariiñuju̱y ranchaju̱.
\v 29 Mi̱ni̱tyi tochiy ri̱tya jiyadaju̱ra jiryoriy, varimyata sataryi̱veda, varimyata si̱tyamutuveda, varimyata saja̱y, varimyata su̱no̱da, varimyata sadadyeñu, sandiy jarye, sa̱day jmutya̱ taraqui pachaju̱ ru̱bivaju̱, sa̱jmutya̱ra jiyaru̱rya ju̱na̱reju̱ jnu̱yada ranchaju̱ntiy.
\v 30 Rajuu ji̱ta jiryatiy rivyichasara munatyavay diye, rirye̱chasara tamityavay rivasiy. Rityi vichasara ji̱ta tamityavay diye, rirye̱chasara ji̱ta munatyavay variy rivasintyi.”
\c 20
\s1 Jesús tu̱choda jvaavyenchiy
\p 
\v 1 “Jarichumuvichi̱ nusu̱yada ji̱ta rañi̱cha nta nu̱tyu rorijya̱mi̱, jiryatiy sani ju̱u̱ryi̱ sa̱tidye va̱ta nudiy jvaavyeñe̱cho̱.
\v 2 Su̱dutya̱danumatiy jvaavyejsa̱ra nuriryara sa̱murichenu tarundaqui jvaayada murichirya riy, su̱pa̱jada ji̱ta yindimyu variryi, jiryatiy ni̱nsijyu̱u̱ni̱ra.
\v 3-4 Sama̱seda ji̱ta ju̱na̱ntyi mumuri̱ jóramusiy, sadiyada ji̱ta ruuva tavay, mitya ranivye pudásamu, su̱teda variy ruuva: ‘Jirya̱numa jiya jvaavye ni̱nsijyu̱u̱ni̱mu, ra̱murichenu vase variy jirye.’
\v 5 Riya̱da ji̱ta variy. Ju̱na̱ntyi sama̱seda ji̱ta nu̱ñi mumuri̱ jóramusiy, sivaayada daryadantyi.
\v 6 Taraqui jóradenumatiy su̱tyeda ruuvaamyu̱yadaju̱, sama̱seda rorijya̱mi̱ pudásamuntiy, sasaryeda riy tavay ranivyentyi, su̱teda ji̱ta variy ruuva: ‘¿Ta̱raju̱ jiryeryaniy pituvye ju̱daca̱ jiyu, ta̱raju̱?’
\v 7 Ru̱mutya̱jadani̱: ‘Ne ti̱ jvaatyaniryu̱y daryaju̱ nu̱dye.’ Su̱teda ji̱ta variy ruuva: ‘Jiryejerye ra̱jiya jvaavye ni̱nsijyu̱u̱ni̱mu.’
\v 8 Jidyenumatiy ravicha̱da, su̱teda rorijya̱mi̱ siva yivaatyani̱: ‘Ya̱numa naturyi jvaavye, ya̱murichenu varintyiryi. Ya̱jo̱ta murichedoda tamityavamyusiy, munatyavacha̱ra̱ju̱ ti̱ta̱ju̱.’
\v 9 Ruuto̱jadanumatiy tamityavay, ru̱mutya̱jada nu̱ñi ti̱quimusirya tarundaqui jvaayada murichirya, miryanura.
\v 10 Ru̱to̱jadanumatiy munatyavay, rijechipiya̱jada: ‘Nu̱ña̱jmutya̱ dyetya ja̱mura ruumusiy.’ Ru̱mutya̱jada ji̱ta ti̱ta̱ju̱ nu̱ñi tarundaqui jvaayada murichirya nu̱ñi ti̱quimusiy.
\v 11 Ru̱mutya̱jadanumatirya, ricyucuye̱yada ji̱ta rorijya̱mi̱nijyu̱.
\v 12 Riñiquejada ji̱ta: ‘Jivye tamityavay, rañi jvaayasiy taraqui jóradera, jiiñi bay vatajuu nu̱dyisa̱ riy, jiryatiy nu̱jechi̱desiy ju̱daca̱ jvaayada vidyaquisumajareyu.’
\v 13 Su̱mutya̱jada ji̱tani̱ ti̱qui rityenu: ‘Ne rapyaranu ji, Jaamyicyu. ¿Neviy vuryi̱dutyajay tarundaqui jvaayada murichirya dajyu̱ú̱?
\v 14 Ya̱jirirya jiyaru̱rya, ye̱jiya varintyi. Ramyurichenuru̱ryi tamityavay daryatiy ramyurichenuntiy ji.
\v 15 ¿Samirya dyetya ra̱jvaay racyuriquitya daryatiy rivaaryu̱y? ¿Jamiryamuviy yinu̱y rana̱cho̱ jiryatiy rivaay samirya mitya day?’
\v 16 Ramuni̱, rityi vichasara tamityavay, rirye̱chasara ji̱ta munatyavay, daryadantyi, rityi vichasara ji̱ta munatyavay, rirye̱chasara tamityavay varintyi. Ti̱quitya daryaju̱ riñi̱cha natuchavay, rajuutya ji̱ta jaryetasavadye.”
\s1 Jesús tu̱choda ju̱na̱y jibetyedajiju̱ntiy
\r (Márcu 10.32-34; Dúcasiy 18.31-34)
\p 
\v 17-18 Saya̱danumatiy Jesús Jerusarí̱ na̱cho̱ju̱, sa̱ra̱cheda ji̱ta riy vinu yisa̱ datyavavyedabay vu̱yaju̱y, danu̱ju̱y rinchaju̱, satu̱chutityiyada ruuva: “Vurya̱sumiñuma ji̱ta Jerusarí̱muju̱. Nijya̱mi̱denu rirya̱sa̱chara caserdótevyeda nutyityu̱mimyuju̱, Ju̱denu niquejada datyanuvamyu jarye, rirya̱bay ji̱ta diiyasi̱ju̱ variñi̱.
\v 19 Jadchiy ji̱ta rirya̱sa̱y variy ma̱myimyuni̱, rirya̱tidye jarupantani̱, rirya̱tidye musiye̱ varintyiñi̱, rirya̱jvay variy crusitya̱sa ti̱ta̱ju̱ni̱; jadchiy ji̱ta mumurundamimyusiy sa̱cha mi̱sanichi̱.”
\s1 Sebedévubay vaturu̱be jachiñu̱yada simu Jesús jidyenuju̱be jiyadaju̱
\r (Márcu 10.35-45)
\p 
\v 20 Jadchiy ji̱ta, nanutuudiyada ji̱ta Sebedévubay vaturu̱be nanudenuju̱betyani̱ Jesús, nana̱dasidyodanumatiy satuunuyu, nanujachiñu̱yada tara variy siva.
\v 21 Ni̱ni̱ ji̱ta jteda nadiva: “¿Ta̱rana̱ sa̱nuva̱ta, ta̱ra?” Nani̱teda variy siva: “Ya̱jtay nana̱ma̱sa radyenuju̱y jityuunu, yinsu̱yadamu, ti̱qui ra̱cha yintyityudamyuju̱, nu̱ntiy ra̱cha jimyidámyuju̱ntidye.”
\v 22 Su̱mutya̱jada ji̱ta Jesús variy: “Ne sa̱dadatya ta̱na̱ sa̱ni va̱ta. ¿Sa̱na̱vidye jachi̱niy rajuura jantya̱daju̱ dayu, nu̱tyi ratyi ra̱paru̱tyajaya̱sara darya ray?” Nani̱mutya̱jada ji̱tani̱: “¡Neviy na̱ña̱ju̱ú̱!”
\v 23 Su̱teda Jesús variy nadiva: “Daryaday sa̱na̱paru̱tyajaya̱ntidyeyu, nu̱tyu ratyi ra̱paru̱tyajaya̱ntidyerye. Tama̱ vana̱y ntate rabe rayntyityudamyuju̱ ma̱sa̱daju̱ ji, tama̱, dantyamu̱y ne ramyidámyuju̱. Rijyu̱ ji̱ta ra̱chasara daryatiy su̱dutyama̱ Rajye̱rya.”
\v 24 Rityuva̱chodanumatiy vu̱yaju̱y nanutevarya darya niquejada, riñique̱yada ji̱ta nadisa̱ mityijyi taryi̱ju̱y.
\v 25 Jesús ji̱ta natuyada variy yimuju̱ riy, saniquejada variy: “Jiryedyetyanuma jiryatiy ma̱y nutyityu̱ rañi jpa̱ jaryiryi jiryenu ma̱myi. Ni̱tiy vichasara jaryi ma̱myi nutyityu̱ nubesi̱, ni̱ni̱ nusu̱y jaryiryi jityevay.
\v 26 Jiryequebyimu ji̱tamu̱y ne raryicha daryá. Ni̱tiy ra̱charu̱y jaryiñu̱ jiryimusiy, sa̱ma̱ jvaay nu̱tyu jiryemyuchechiy.
\v 27-28 Ni̱tiy ra̱charu̱y munatyi̱ jiryimusiy, sa̱ma̱ jvaay nu̱tyu jiryecyumude, daryatiy su̱deda Nijya̱mi̱denu, ne sa̱tidye jvaatyaniy jiyadaju̱ riy tavay, su̱deda ji̱ta sa̱tidye jmu̱tyasara riy tavay, sa̱tidye sa̱charara yinu̱yada nijya̱nvajyuu jantyutya̱daju̱ varintyi.”
\s1 Jesús mi̱sadeda nada ni̱sipyuryijyu̱be
\r (Márcu 10.46-52; Dúcasiy 18.35-43)
\p 
\v 29 Richipyatedanumatiy Jesúsveda Jericómusiy, richiityari̱jada nijya̱nvajyuubañi̱ Jesús.
\v 30 Mityamusiy, nanutuva̱chodanumatiy danu̱ju̱y ni̱sipyuryijyu̱be nú̱tuva̱rya ma̱sanu̱y: “Saramiryi̱ Jesús,” nanuniquejasubeda ji̱ta: “¡Ya̱jantyutya na̱y, Davyíbe jasi̱!”
\v 31 Nijya̱nvay ji̱ta nique̱tya̱da nada: “¡Sa̱na̱ndasa!” Nanuniquejasubeda ji̱ta jaryivya̱ju̱ variy: “¡Nutyityu̱, ya̱jantyutya na̱y, Davyíbe jasi̱!”
\v 32 Saradedanumatiy Jesús, sanatuyada variy nada: “¿Nu̱tyura sa̱dava̱ta ra̱chaniyu, nu̱tyura?”
\v 33 Nani̱teda ji̱ta siva: “¡Nutyityu̱, ya̱muttara na̱ñi̱siquiii!”
\v 34 Sa̱ntyutya̱damu jije̱tyo̱jada Jesús nanuni̱simyu, nani̱nu̱yasubeda varicha̱ra̱ju̱, nanusiityari̱jada ji̱ta variñi̱.
\c 21
\s1 Jesús jayada Jerusarí̱mu
\r (Márcu 11.1-11; Dúcasiy 19.28-40; Juán 12.12-19)
\p 
\v 1-2 Rityuudiyadanumatirya Jerusarí̱, ruuto̱jada Betuvájemu, Odivu musiquituunu. Jadchiy ji̱ta su̱pa̱jada Jesús nada yisa̱ datyanu̱jyu̱bentyi: “Sa̱na̱jiya vicha̱dademu jiryatiy vu̱cha̱ra̱ra. Jasiñi̱ sa̱na̱diñuve siva cavañu puchusi̱, sadenu yisa̱ jasiy. Sa̱na̱vita̱siñi̱, sa̱na̱pu̱chesiy mityijyijyu̱y rumusiy nanudenutayu.
\v 3 Ti̱tiy ra̱jtesiy tara sa̱diva, sa̱na̱ma̱ jmutya̱jasiy variñi̱: Nutyityu̱ va̱ta mityijyijyu̱y nada. Varidye sa̱jpa̱jasiy nada.”
\v 4-5 Rani̱ ji̱ta vicha̱da daryá, ra̱tidye jto̱tanirya saniquejada Ju̱denuju̱ tu̱chu̱bay:
\q1 “Ya̱tu̱chu siva Siyó̱ detu daryatiy vuryi̱tay Jerusarí̱ ja̱nvañi̱: Ya̱jnu̱y, su̱niy yintyityu̱ yimu, tapimusiy ma̱si̱ cavañuncha, sadenuncha jarye.”
\m 
\v 6 Nadaya̱da ji̱ta sisa̱ datyanu̱jyu̱be variy, nadivaañuvejada ji̱ta daryatiy su̱teda Jesús nadiva.
\v 7 Nadaryitya̱da ji̱tani̱ cavañu, sadenu yisa̱ju̱. Nanubayada ji̱tara jichujajyuu nadancha, sama̱sa̱da ji̱ta Jesús variy rancha.
\v 8 Riryetya̱da ji̱ta nijya̱nvajyuu tevaberya jichujay nú̱va. Ti̱ni̱ ra̱cha̱da darya nutasarajii ti̱ta̱ju̱ vi̱tara day, rirya̱tidye bay nú̱vara.
\v 9 Rityi jiya̱da jo̱ta̱da nijya̱mi̱juu sa̱jiju̱, rityi rupiyada su̱sintyi, riyaro̱vaya̱tityiyada vatajuu variy: “¡Ya̱jantyutya nu̱y, Davyíbe jasi̱! ¡Jchana̱tyasi̱ ji̱ta si̱tenuni̱ ni̱tiy jniy Ju̱denu jtyamu! ¡Ya̱jantyutya na̱vachiy nu̱y!”
\v 10 Sajayadanumatiy Jesús Jerusarí̱mu, riche̱ñe̱ya̱jada ji̱ta vicha̱daja̱nvabe variy yichana̱yadamu, ruutaja̱doda variyu: “¿Chi̱ra jiñu, chi̱?”
\v 11 Ru̱mutya̱jada ji̱ta nijya̱nvajyuu variy: “Ni̱ni̱ sani̱cha Ju̱denuju̱ tu̱chu̱, Jesús jtyati̱, jiryatiy Nasaryémusi̱ni̱, jiryatiy Cadidéya mucadimura.”
\s1 Jesús jatya̱da Ju̱denu nijyu̱ jachipiya̱jomusiryi ta̱ryu̱tyavabe
\r (Márcu 11.15-19; Dúcasiy 19.45-48; Juán 2.13-22)
\p 
\v 12 Sajayada ji̱ta Jesús Ju̱denunijyu̱ jachipiya̱jovimu, sajatya̱da ji̱ta jadchiryi ta̱ryu̱tyavabe, jiryatiy ritye̱ryu̱tyanu̱yada jasiy, ta̱ryu̱vyebe jarye ruusa̱ju̱. Sajatyatimyu̱yada ji̱tara criquiy ta̱ritanivyebe mi̱sa variy, putuvinu ta̱ryu̱tyavabe ma̱sajo jarye risa̱ju̱.
\v 13 Su̱teda ji̱ta variy ruuva: “Nu̱charanuma:
\q1 Rirya̱jtacharara raryoriy Ju̱denusa̱ tu̱chujo, jiryeñi̱ ji̱ta vichaniy paranujoju̱ dárya.”
\p 
\v 14 Ni̱sipyuryimyi ji̱ta ju̱deda simu Jesús, Ju̱denunijyu̱ jachipiya̱jovimu, canuya̱simyi jarye ruusa̱ju̱, sami̱sadeda variy jasiryi.
\v 15 Ridyiyada ji̱ta caserdótevyeda nutyityu̱mibe, Ju̱denu niquejada datyanuvabetya riva mityamusiy su̱ndejada, rityuva̱chodantirya riyaro̱vaya̱ derajuubay, jiryatiy ru̱tay: “¡Ya̱jantyutya, Davyíbe jasi̱!” Riñique̱yada ji̱ta variy ranchiy.
\v 16 Ru̱teda ji̱ta variy siva Jesús: “¿Ne jityuva̱chu nu̱tyura ru̱tay jivye derajuu, nu̱tyura?” Su̱teda ji̱ta Jesús variy ruuva: “Jo. ¿Neviy jiryi̱nu̱tya Ju̱denu niquejadamu:
\q1 Deramidyera, jiryatimyu̱ ne jiintyevye didyedyeryi, ru̱tosiy ji̱ta jichipyatara jchana̱tya̱da samirya?”
\m 
\v 17 Satochedanumatiy variryi, sasipyateda ji̱ta Jerusarí̱musiy Betániyamuju̱, sama̱yada variy jasiy.
\s1 Jesús nique̱tya̱dara jígunu, jiryatimyu̱ ne jarya ravicha̱da daryaju̱
\r (Márcu 11.12-14, 20-26)
\p 
\v 18 Sata̱rya̱danumatiy ta̱rimyusidyera Jerusarí̱muju̱ntiy, sajachi̱jada ji̱ta variy.
\v 19 Sadiñuvejada ji̱ta nú̱tuva̱rya riva jígunu, saya̱da ji̱ta: “Ra̱jnu̱dyi,” ne sadiyada riva rajo tiii, mitya, vinu ravi̱vaniy sadiyada day. Saniquetta̱da ji̱ta Jesús varirya jígunu: “¡Ne taramu̱y ya̱jacharanu̱day!” Radiijeyada jígunu varenude variy.
\v 20 Ridyiyadanumatiy sisa̱ datyavavyedabay riva, rityi̱tta̱da varirya: “¿Nu̱tyuramusiy radiijeyasiy jígunu mityamusidye, nu̱tyuramusiy?”
\v 21 Su̱mutya̱jada ji̱ta Jesús variryi: “Ri̱tatye si̱tenu jiryiva: Jiryetyi vichasara tuva̱chodatavay, ne siquityavay jiryejechipiya̱jadamu, jirya̱jvaachara ne vinu jiryatiy ravyichadesirya jígunu. Jiryetyi jtay ji̱ta riva jirya musiqui: Ya̱numa bay jadchidye, ja̱mu na̱vamu ya̱jatyanuve ji, daryani̱ ra̱cha variy.
\v 22 Miryani̱ntyi jiryejechiñu̱y siva Ju̱denu sisa̱ tu̱chodamu, jirya̱day jmutya̱ varirya, jiryetyi tuva̱chu simucu̱.”
\s1 Chi̱ jtedamuju̱ sivaayada Jesús, chi̱ jtedamuju̱
\r (Márcu 11.27-33; Dúcasiy 20.1-8)
\p 
\v 23 Sajayadanumatiy Jesús Ju̱denunijyu̱ jachipiya̱jovimu, ruuti̱jada ji̱ta caserdótevyeda nutyityu̱mibe, nijya̱nvay rimyityumibe jarye simu, sadatyadodamu, ru̱teda ji̱ta jasiy siva: “¿Nu̱tyura jpa̱jadata yivaacharara yivaayada day, nu̱tyura? varimyata ¿chi̱ jtedamuju̱ jiñi jvaadyerya, chi̱ jtedamuju̱?”
\v 24 Su̱mutya̱jada ji̱ta Jesús riy: “Rajerye ra̱jtaja̱nu jiryentyidye, jiryetyi jtay rivara jmutya̱jada, rajerye ra̱tu̱chu jiryiva nu̱tyura jpa̱jadata rivaacharara rivaayada day, nu̱tyura.
\v 25 ¿Tesiy ravicha̱da Juán Bautístabay jtyadoda day, tesiy? varimyata Ju̱denu jtedamusirya, nijya̱mi̱ jtedamusiy dyetyara.” Riñi̱ ji̱ta niquetasa̱deda riva dayu: “Vurya̱tiy jmutya̱: Ju̱denu jtedamusirya Juánbay jtyadoda, sa̱jtay ji̱ta variy vuryiva day: ¿Daryamuni̱mu̱y ne jiryetyuva̱churu̱yada simu?
\v 26 Vurya̱tiy jmutya̱ ji̱ta: Nijya̱mi̱ jtedamusirya Juánbay jtyadoda, vu̱chuvu̱ryi nijya̱nvajyuu, tapitya rijechipiya̱ daryaju̱ sanijyu̱ Juánbay: Ni̱ni̱ dyetyate Ju̱denuju̱ tu̱chu̱.”
\v 27 Ru̱mutya̱jada ji̱ta variñi̱ Jesús: “Ne nu̱dyetya day.” Su̱teda ji̱ta variy ruuvantiy: “Dantyamu̱y ne vinu ray ra̱tu̱chuntidyerya nu̱tyura jpa̱jadata rivaacharara rivaayada, nu̱tyura.”
\s1 Jesús tu̱choda danu̱ju̱y denuju̱y nchiy
\p 
\v 28 “¿Ta̱ra jiryejechipiya̱, ta̱ra? Savicha̱da vanu danu̱ju̱y denuti̱. Su̱tañuvejada ji̱ta siva jimyunatyi̱: ‘Pi̱, ye̱jiya ju̱vaañu randimyu diye.’
\v 29 Su̱mutya̱jada ji̱tani̱ jijye̱: ‘¡Ne ra̱jiya!’ Rivasiy ji̱ta saparu̱yada riva jijechipiya̱jada, saya̱da variy ju̱vaañu.
\v 30 Su̱tañuvejada ji̱ta vanu variy siva jidyenu tamityi̱ daryantiy, ni̱ni̱ ji̱ta jmutya̱jadani̱: ‘Ray ji̱ta ra̱jiya, Ye̱ye̱.’ Dañumamu̱y ne saya̱da varidye.
\v 31 ¿Mi̱ra danu̱ju̱myusiy rañi jvaayadara jijye̱ va̱tara, mi̱?” Ru̱mutya̱jada ji̱tani̱ Jesús: “Samunatyi̱.” Su̱teda ji̱ta Jesús variy ruuva: “Ri̱tay si̱tenu jiryiva: Criquiy jmutya̱varyapu̱ryamiy, cadnatuveda jarye, rirya̱jay jirya̱jisiy Ju̱denu nusu̱jyomu.
\v 32 Tapi su̱deda Juán Bautístabay jiryimu Ju̱denu nú̱va rupiñu, tama̱ jiryeñi tuva̱churu̱yada simu, tama̱. Criquiy jmutya̱vay ji̱ta, cadnatuveda jarye tuva̱choda si̱tenu simu. Dañuma jiryeñi diyada riva, ne jiryepyaru̱ryu̱yada variy riva jijechipiya̱jada, jirya̱tidye tuva̱chu variy simu Juánbay.”
\s1 Jesús tu̱choda jamirya jvaavyenchiy
\r (Márcu 12.1-12; Dúcasiy 20.9-19)
\p 
\v 33 “Jirya̱tuva̱chura ratarya dityadoda niquejadantiy. Savichanu̱yada ti̱qui rorijya̱mi̱, santa̱da ji̱tara ni̱nsijyu̱u̱ni̱. Sapuryejada ji̱ta ravichu̱ta rayada; su̱beda ji̱tantirya ni̱nsiy muchijyoju̱ risa̱ju̱ntiy, sivaayada ji̱ta ni̱nsijyu̱u̱ni̱mura rorivyu̱qui, jiryatiy ru̱nu̱tya̱da ravimusirya yindiy. Satocheda ji̱ta nuta̱daja̱mi̱ variy ruumu jvaavyerya, rirya̱tidye jvaadyerya. Rateratanuma nutasarasiy rirya̱murichenu dañi̱ mucadi ja̱mi̱ day, rateranuma ra̱ma̱cho̱ rijyu̱ day. Saya̱da ji̱ta variy tajijyu̱ day.
\v 34 Rito̱jadanumatiy ra̱tosa̱da runda, su̱pa̱jada ji̱tariy jimyuchechimyi ruumu jvaavye, rirya̱tidye jmutya̱ra sayaru̱rya ni̱nusityera.
\v 35 Rureda ji̱ta jvaavyeryi samuchechimyi, rimyusiye̱yadani̱ ti̱qui, nu̱ntiy ru̱veda ti̱ta̱ju̱, puutyi. Ti̱ni̱ rijecheda ravichu̱ta day.
\v 36 Sajatyiiyada jpa̱jada ti̱ jimyuchechintyi, nu̱ntiy, nu̱ntiy, nu̱ntiy, jaryi rajuuvavya̱ju̱ ruumusiy munatya jpa̱savaryi, riñi vichadeda jvaavye daryantyiryi.
\v 37 Pariche su̱pa̱jada ji̱tani̱ jidyenu ruumu, saniquejada variy: Rirya̱suvu̱y dyetyani̱ radyenu.
\v 38 Ridyiyadanumatiy jvaavye siva sadenu, riñiquejada ji̱ta variy yiva: Jiñu ji̱ta mucadi ja̱mi̱ denu day. Sa̱numatiy diichara saja̱y, ni̱numa ra̱ma̱cho̱sara raja̱mi̱ju̱ varintyidye. Vañú, vurya̱jvañi̱, vurya̱tidye ju̱riy vu̱jyu̱ra samucadi.
\v 39 Ruredanumatiy variñi̱, rijetya̱da ji̱ta nudimyusiñi̱, ru̱veda variy jasiñi̱, puutyityeni̱.
\v 40 Ramuni̱tiy, sa̱numatiy jti̱ mucadi ja̱mi̱ yindimyuntiy, ¿nu̱tyura sa̱chaniy variryi jvaavye rapu̱ryamiy, nu̱tyura?”
\v 41 Ru̱teda variy siva Jesús: “Ne jantyutya̱damusiy sa̱paruta riy nicyara̱myi, sa̱sa̱y variy tavantyidyerya ni̱nsijyu̱u̱ni̱ntidye, jiryatiy rirya̱sa̱ryu̱rya jiyaru̱rya ra̱tosa̱da rundamu.”
\v 42 Su̱teda ji̱ta Jesús variy ruuva: “¿Neviy jiryi̱nu̱ñu̱yada Ju̱denu niquejadamu didyerya jirya niquejada didye?
\q1 Ravichu̱ ji̱ta jiryatiy rrachusi̱ roriy jvaavyejyu̱ni̱, ni̱numa rañi̱cha ji̱ta roriy suru̱tya̱, jiryenu ravichu̱musiy. Rani̱ jirya sivaayada Nutyityu̱, mityanuma vuryi̱nu̱y rana̱cho̱ day, vu̱tyi̱tta varirya.\f * \fr 21:42 \ft Ya̱jnu̱rya Murra̱pedye 118.22; Nusu̱byimiy Jvaachara 4.11; Rajo̱ttya̱ Pyítru 2.7\f*
\m ¿Neviy jiryi̱nu̱ñu̱yada didyerya daryaday?
\v 43 Ramuni̱ ri̱tatye jiryiva: Sa̱so̱vay ji̱ta Ju̱denu jiryimusirya yinsu̱yada, sa̱sa̱y variy tavantyidyerya jiryatiy rirya̱jontay nta daryatiy sava̱ta̱da ruumusiy.
\v 44 Ni̱day ji̱ta ni̱tiy raryijyu̱u̱y jiñu ravichu̱ncha, saryiryotyatimyu̱y variy sanchasiy; jiñu ji̱ta, sanchatiy saryijyu̱u̱y jiñu ravichu̱, saryiñe̱ya vamidideju̱ variñi̱.”
\p 
\v 45 Rityuva̱chodanumatiy caserdótevyeda nutyityu̱mibe, Varyisévuvedabay jarye ruusa̱ju̱ra saniquejada dityadoda, ridyetya̱da ji̱ta jiñijyu̱ saniquejada darya.
\v 46 Ruuriryu̱yadanumatiy rivasiñi̱ Jesús, richuvu̱yada riy nijya̱nvajyuubay, jiryatiy rijechipiya̱jada daryaju̱: “Ju̱denuju̱ tu̱chu̱ sani̱cha.”
\c 22
\s1 Jesús tu̱choda ja̱mu̱yada vichtyanchiy
\r (Dúcasiy 14.15-24)
\p 
\v 1 Sajatyiiyada tu̱choda dityadoda tu̱chodata ruuvantiy:
\v 2 “Jarichumuvichi̱ nusu̱yada rañi̱cha nu̱tyu ja̱mu nutyityu̱ jiryatiy sivaayadara vichtya jidyenu ja̱mu̱yadamu.
\v 3 Su̱pa̱jada ji̱tariy jimyuchechimyi: Jirya̱numa naturyi musuchavay vichtyamuju̱. Musuchavay ji̱tamu̱y ne jiyaru̱yada variy.
\v 4 Sajatyiiyada jpa̱jada ti̱ntiy: Ya̱numa tu̱chu ruuva musuchavay: Jdutyasaranuma ravyichtya. Ri̱vatyanimya̱ni̱ ra̱si̱ nu̱chusi̱, voca denu. Jdutyasaranuma ti̱ta̱ju̱ra. Varenuma vichtyamuju̱cu̱.
\v 5 Musuchavay ji̱ta jiya̱da yavuryu̱tya̱damu, nu̱ jiya̱da yindimyu, nu̱ntiy jvaadyi ta̱ryu̱tya̱da na̱cho̱.
\v 6 Rityevay ji̱ta rañi ju̱reda riy samuchechimyi, rirya̱rupanta̱da variryi, ru̱vamyu̱yada ti̱ta̱ju̱ riy, pattaryi.
\v 7 Ja̱mu nutyityu̱ ji̱ta nique̱yada jaryi variy ranchiy, su̱pa̱jada ji̱ta variryi jichu̱tarumiy, rirya̱tidye parutamu̱ryi jvavye, rirya̱rupamyu̱y varirya rivyichajo.
\v 8 Su̱teda ji̱ta ja̱mu nutyityu̱ variy ruuva jimyuchechimyi: Jdutyasaranuma vichtya, ramyusuvye ji̱ta vicha̱siy nicyara̱myi.
\v 9 Jirya̱numa jiya nú̱qui nantaryaju̱myu, jirya̱numa musuy vichtyamuju̱riy ti̱ta̱ju̱ jiryatiy jirya̱sarye rumuriy.
\v 10 Riya̱da ji̱ta samuchechimyi variy nú̱quiva, rirya̱tonuvejada variryi jicheryevye ti̱ta̱ju̱, nijya̱nvay nicyara̱myi, samivye jarye ruusa̱ju̱ ti̱ta̱ju̱. Rimyu̱chadeda varirya vichtya roriy.
\v 11 Sajayadanumatiy ja̱mu nutyityu̱ sa̱tidye jnu̱ñuvi̱ riy musuchavay, sadiyada jasiy siva ti̱qui vanu, jiryatimyu̱ ne ja̱mu̱yada sujatyi̱ dañi̱.
\v 12 Su̱tañuvi̱jada ji̱ta variy siva: Jaamyicyu, ¿nu̱tyuramusiy jijeyasiy jiyu, nu̱tyuramusiy? tama̱ ja̱mu̱yada sujatyi̱ jiñi̱cha, tama̱. Sama̱cho̱jada mitya vapuu variy ranchiy.
\v 13 Jadchiy ji̱ta su̱teda ja̱mu nutyityu̱ ruuva jnu̱tyavantyi: Jirya̱numa puchumu̱y ti̱ta̱ju̱ni̱, jirya̱jatya̱siy variy bimuju̱ni̱, nupocudimuju̱. Jasidye ji̱ta rirya̱jna̱vya̱ nijya̱nvay variy, rirya̱su̱y ji̱ta jijya̱dajchantiy.
\v 14 Ti̱quitya daryaju̱ riñi̱cha natuchavay, rajuuvatya ji̱ta jaryetasavadye.”
\s1 Criquinchiy, jiryatiy ja̱mu nutyityu̱ murichenutaniy nijya̱nvarya
\r (Márcu 12.13-17; Dúcasiy 20.20-26)
\p 
\v 15 Riya̱da ji̱ta Varyisévuvedabay variy riñiquetta̱dayu: “¿Nu̱tyuramusiy vurya̱ju̱riy taji niquejadivani̱ Jesús, nu̱tyuramusiy?”
\v 16 Ru̱pa̱jada ji̱ta variy yisa̱ datyavavyedabay simu Jesús, Jeródesbe siityari̱vabe jarye ruusa̱ju̱. Ru̱teda ji̱ta variy siva Jesús: “Datyanu̱, nu̱dyetyara jiryatiy jiiñi̱ ji̱ta si̱tenu jtarya. Jiiñi̱ ji̱ta datyanusara si̱tenura Ju̱denu nú̱. Ne yinu̱y jaryi sami̱va̱ju̱ ti̱na̱cho̱, dañuma sani̱cha ti̱.
\v 17 Ramuni̱, ya̱numa tu̱chu nu̱dyiva, nu̱tyura jijechipiya̱, nu̱tyura: ¿Samiryavidye vurya̱murichenura criquiy, jiryatiy ja̱mu nutyityu̱ Sésar murichenutaniy vuryi̱nu̱yadamusirya?”
\v 18 Sadatya̱da ji̱ta Jesúsra rijechipiya̱jada jiyaro̱ju̱, su̱teda ji̱ta variy ruuva: “¿Ta̱ju̱ra jirye̱ntya rañiy, ta̱ju̱? Jiryi̱tu̱yadamu yitay.
\v 19 Jirya̱dityanu rarya criquidye, ratatiy vurya̱murichenuracu̱.” Riryeda ji̱ta variy saju̱ra criquidye.
\v 20 Su̱teda ji̱ta Jesús variy ruuva: “¿Chi̱ra sani̱cha criquitya̱sa jantyasi̱ day, chi̱? su̱ro̱ nu̱chara jarye, ¿ta̱ra rani̱cha daryamusidye, ta̱ra?”
\v 21 Ru̱mutya̱jada ji̱tani̱: “Ja̱mu nutyityu̱ Sésar jantyasi̱.” Su̱teda jadchiy ruuvantiy: “Ramuni̱tiy jirya̱murichenu variñi̱ Sésar jiryatiy sabarya darya, jirya̱murichenuni̱ Ju̱denuntiy jiryatiy sabaryantidyerya.”
\v 22 Rityuva̱chodanumatirya saniquejada, rityi̱tta̱da variñi̱. Rityocheda ji̱ta variñi̱ Jesús, riya̱da variy jadchiy.
\s1 Saadusévuvedabay jtaja̱dodani̱ Jesús diibyimusiy mi̱sadedanchiy
\r (Márcu 12.18-27; Dúcasiy 20.27-40)
\p 
\v 23-24 Ruuti̱jada Saadusévuvedabay variryundamu simuntiy. Ne ridyetaru̱ñu̱yada rimyi̱sa diibyimiñu̱day. Ruutaja̱doda ji̱ta variñi̱: “Datyanu̱, su̱teda ji̱ta Muyusésibe: Ti̱qui nijya̱mi̱tiy ra̱diiy dejsa̱, sataryi̱numa ra̱ja̱mu̱y variñi̱ savatura ma̱cho̱nu, sa̱tidye detuchu jityeryi̱bay jiyadaju̱ni̱.
\v 25 Rivyichanu̱yada ji̱ta danu̱ju̱ñijyate nu̱ñi taryi̱veda nu̱quebyimu. Saja̱mu̱yada ji̱ta rimyunatyi̱ vaturajsa̱, sadiiyada ji̱ta mitya dejsa̱ sisa̱siy, sama̱cho̱ vatura variy sanijyu̱ vichi̱ju̱.
\v 26 Daryaday savicha̱da sanijyu̱ vichi̱ntiy, nu̱numa rañi ja̱mu̱ntyiñi̱, nu̱ñi taryi̱veda, tamityi̱ sa̱ra̱ju̱, pattaryitye.
\v 27 Tamityanuma ji̱ta sadiiyada vaturantidye, puutyitye.
\v 28 Daryamusiy, rirya̱numatiy mi̱sa jidyiijyomusintyi, mi̱ju̱rate sa̱ma̱cho̱ vatura variy, tapi riñi ja̱mu̱yada ti̱ta̱ju̱musiñi̱ vatura.”
\v 29 Su̱mutya̱jada ji̱ta Jesús variryi: “Jiryecyaramya̱ jijechipiya̱jadamu, jiryedyetyatya daryaju̱ra Ju̱denu niquejada, ne vinu sadatya̱da jarye.
\v 30 Tapitya rirya̱tiy mi̱sa̱sumiy nijya̱nvay jidyiijyomusiy, ne rirya̱ja̱mu̱charayu, dantyamu̱y ne rirya̱ja̱mu̱tyanicharayu, jiryatiy rirye̱chasara daryaju̱ nu̱tyu Ju̱denu jpa̱vay daryá, jiryatiy jarichumu vichavaryi.
\v 31-32 Ranchiy ji̱ta jiryatiy rimyi̱sasara jidyiijyomusiy, nu̱tyi jiryeñi niquema̱ catera nu̱charamuntirya, jiryatiy su̱teda Ju̱denu jiryivara:
\q1 Rañuma rañi̱cha Avurá̱bay Ju̱denu, Isácubay Ju̱denu jarye, Jacóbubay Ju̱denu jaryentiy.
\m ¿Va̱ diibyimiy riñi̱chacay? ¡Jnu̱vyentya riñi̱cha jasidye! Ni̱ni̱ta diibyimiy Ju̱denu day, nu̱tyi ni̱ni̱ ji̱ta sani̱cha jnu̱vye Ju̱denu.”
\v 33 Rityuva̱chodanumatiy nijya̱nvarya saniquejada, rityi̱tta̱da varirya sadatyadoda.
\s1 Miryara vichasara jaryinra Ju̱denu datyadoda, mirya
\r (Márcu 12.28-34; Dúcasiy 10.25-28)
\p 
\v 34 Rityuva̱chodanumatiy Varyisévuvedabarya jiryatiy sandasadeda Jesús riy Saadusévuvedabay, riintye̱ryadeda ji̱ta variy simuyu.
\v 35-36 Ti̱qui rityenu jiryatiy niquejada datyi̱ni̱, sani jtaja̱doda ji̱ta jantya̱daju̱ variñi̱ Jesús: “Datyanu̱, ¿miryara vichasara jaryinra Ju̱denu datyadoda ti̱ta̱ju̱ su̱teda cabyimu, mirya?”
\v 37 Su̱mutya̱jada ji̱ta jasiñi̱: “Vurya̱ma̱ va̱tasara ti̱ta̱ju̱ vu̱jechityani̱ Vu̱ntyityu̱ Ju̱denu, ti̱ta̱ju̱ vuryi̱ntuta jarye, ti̱ta̱ju̱ vu̱jechipiya̱jadata jarye risa̱ju̱.
\v 38 Rani̱ ji̱ta jaryinra datyadoda jiryatiy munatyara.
\v 39 Daraju̱jyu̱ datyadoda ji̱ta nu̱tyu ratiy daryantiy: Vurya̱ma̱ va̱tasarani̱ vu̱tyuunu vichi̱ntidye, nu̱tyu vu̱vya̱tasaratiy daryantidyevyu̱y.
\v 40 Jirya daraju̱y datyadodamusiy ru̱ndayada ti̱ta̱ju̱ su̱teda Ju̱denu, jiryatiy su̱teda Muyusésibemyusirya, jijyu̱ tu̱chuvabe jtomusiy jarye risa̱ju̱.”
\s1 ¿Chi̱denu sani̱cha Ju̱denu jaryeti̱, chi̱denu?
\r (Márcu 12.35-37; Dúcasiy 20.41-44)
\p 
\v 41-42 Riintye̱ryadedamu, sitaja̱doda Jesús Varyisévuvedayu: “¿Nu̱tyura jiryejechipiya̱ sanchiy Ju̱denu jaryeti̱, nu̱tyura? ¿Chi̱ denu sani̱cha, chi̱ denu?” Ru̱teda ji̱ta siva: “Davyíbe jasi̱.”
\v 43-44 Su̱teda ji̱ta variy ruuva: “Nu̱tyuramusiy variy su̱teda Davyíbe, Ju̱denu Jnutumusiy siva: ¡Nutyityu̱! Su̱teda daryaju̱:
\q1 Su̱teda ji̱ta Ju̱denu siva rayntyityu̱: Ya̱ma̱sa rayntyityudamyuju̱, jasicha̱ra̱ju̱tiy ra̱vuunutaniryi jimyityasimyi.
\m 
\v 45 Jiryatiy Davyíbeñuma ji̱ta jtay jintyityu̱ntidyeñi̱, ¿nu̱tyichiy sa̱cha variy sa̱si̱, nu̱tyichiy?”
\v 46 Ne vana̱y ti̱ jmutya̱jada variy tarani̱, dantyamu̱y ne ruutaja̱nuru̱yada tara ju̱na̱y jadchiñu̱nñi̱.
\c 23
\s1 Jesús tu̱chuta̱dariy Varyisévuvedabay, Ju̱denu niquejada datyanuvabe ruusa̱ju̱
\r (Márcu 12.38-40; Dúcasiy 11.37-54; 20.45-47)
\p 
\v 1-2 Jadchiy ji̱ta saniquejada Jesús ruuva nijya̱nvajyuubay, sisa̱ datyavavyedabavya jarye: “Riñi ma̱cho̱ma̱ Ju̱denu niquejada datyanuvay, Varyisévuveda jarye ruusa̱ju̱ Muyusésibe ju̱bivaju̱, jiryatiy ridyetyanusarara Ju̱denu jteda jiryatiy Muyusésibemyusirya.
\v 3 Ramuni̱, ti̱ta̱ju̱ jiryatiy rityu̱chu jiryiva jirya̱jvaajeya̱sarara, dantyamu̱y ne jirya̱jvaachara daryatiy riñi jvaachara, tapitya riñi jvaaryu̱y daryatiy rityu̱chusara.
\v 4 Riñi puchusara ntara tiityasara nijya̱nvajyu̱ rajuura ru̱tedata, jiryatimyu̱ ne rityiityaru̱y, rintya ji̱tamu̱y ne ja̱tyo̱ru̱y ne vinu jijyomutu jana̱ta raniy, jiryatimyu̱ ne vinu riy jvaaryu̱rya daryatiy riñi jvaatyaniryu̱y nijya̱nvarya.
\v 5 Ruuvaacharara yivaayada vinu rirya̱tidye diy nijya̱nvay riva, nu̱tyu ruuvaachara ja̱murasumara rimyo̱siy, jasityi ribeyadara Ju̱denu niquejadatera jimyo̱ta̱sa, richujachoniy jarye.
\v 6 Ru̱canurya ma̱sa̱da vichtya ja̱mi̱tuunu jivyichtyamu, munatya ma̱sajomu ma̱sa̱dantiy, ju̱tye̱ryanijyomu jarye.
\v 7 Ru̱canuntyirya nijya̱nvay mu̱chuveda pudásamuntiy, jadchintyi jiryatiy ru̱tachara nijya̱nvay ruuva: Datyanu̱.
\v 8 Jirye ji̱ta, ne jirya̱jtatyanichara Datyanu̱yu, tapitya ti̱quide sani̱cha jiryedyetyanu̱. Jiryevyichasara nu̱ñi taryi̱veda ti̱ta̱ju̱.
\v 9 Dantyamu̱y ne jirya̱jtachara siva mucadincha vichi̱ nijya̱mi̱, Vu̱jye̱, tapitya ti̱quide sani̱cha Vu̱jye̱, jiryatiy Jarichumuvichi̱ni̱.
\v 10 Dantyamu̱y ne jirya̱jtatyaniy yiva: Nutyityu̱, tapi ti̱quide jiryentyityu̱, jiryatiy Ju̱denu jaryeti̱ni̱.
\v 11 Ni̱day vichasara jaryiñu̱ jiryequebyimuntiy, ni̱tiy ra̱cha jiryi̱mu̱tyi̱si̱ju̱.
\v 12 Mi̱ni̱tyi jchana̱tyayu, sa̱cha jantanichi̱ riva, daryaday mi̱ni̱tyi jtay jidyetya pasidyeva̱ju̱, sa̱cha ji̱ta jchana̱tyasi̱ rivantidye.
\p 
\v 13 ¡Jiii, rani̱tte jiryejyu̱te, ra, Ju̱denu niquejada datyanuvay, Varyisévuveda jarye, jiryatiy jiryi̱tu̱yadamu vichaváyu! Jiryemyutanusara daryaju̱ra Jarichumuvichi̱ nusu̱jyo nijya̱mi̱jisiy, tapitya ne jiryeñi jaryu̱y jirye, dantyamu̱y ne jiryejetyaniryu̱ryi, jiryatiy riryi jaryu̱y.
\v 14 ¡Jiii, rani̱tte jiryejyu̱te, ra, Ju̱denu niquejada datyanuvay, Varyisévuveda jarye, jiryatiy jiryi̱tu̱yadamu vichaváyu! Jiryevyiché̱chavañuma dayu, nu̱ñi jiryeñi so̱vacharara bacheno̱daveda barya, jadchintyi jiryi̱tu̱yada jityu̱chu jamuca̱ sisa̱ Ju̱denu. Ramuni̱tiy, jiryeñi̱ ji̱ta ra̱jmutya̱ jaryirya jijyuuchuveda murichenusa̱da.
\p 
\v 15 ¡Jiii, rani̱tte jiryejyu̱te, ra, Ju̱denu niquejada datyanuvay, Varyisévuveda jarye, jiryatiy jiryi̱tu̱yadamu vichavayu! Jirye ramityeñumaya̱ daryaju̱ra jmityo̱, mucadi jarye, jirya̱tidye jatachuni̱ ti̱qui nijya̱mi̱ jichiityari̱nuju̱. Sasiityari̱numatiy jirye, jiryetyi̱tunu jiidatyo̱mu paruti̱si̱ju̱ni̱, savichasara jaryi nicyara̱vya̱ju̱ jiryimusiy variy.
\p 
\v 16 ¡Acuu, ta̱ju̱na̱te darya jiryejyu̱ jiyantavay ni̱sipyuryimyi, ta̱ju̱! Jiryi̱tachara daryaju̱: Saryityi nique ti̱ Ju̱denunijyu̱ jachipiya̱jo jtyamu, ne sanique si̱tenu variy riva; saryityi nique ti̱ óru jtyamu jiryatiy Ju̱denunijyu̱ jachipiya̱jomura, variñi̱ ji̱ta sanique si̱tenu.
\v 17 ¡Ni̱sipyuryimyi datyi̱sa̱miy jirye! ¿Miryara ji̱ta jaryinra, mirya? ¿Óruviy, varimyata Ju̱denu nijyu̱ jachipiya̱jo, ratatiy jiintyasara Ju̱denu nijyu̱ra óru?
\v 18 Jiryi̱tacharantiy: Saryityi nique ti̱ Ju̱denu nijyu̱ rupajyo jtyamu, ne sanique si̱tenu variy riva; saryityi nique ti̱ sa̱chara jtyamu, jiryatiy Ju̱denu nijyu̱ rupajyonchara, variñi̱ ji̱ta saryi jto̱taniy rivara jiñiquejada.
\v 19 ¡Ni̱sipyuryimyi jirye! ¿Miryara ji̱ta jaryinra, mirya? ¿Sa̱charaviy, varimyata Ju̱denunijyu̱ rupajyo, ranchatiy riryupay Ju̱denunijyu̱ra?
\v 20 Ramuni̱tiy, ni̱tiy nique Ju̱denunijyu̱ rupajyo jtyamu, ni̱ni̱ nique ri̱tyamu, sanique variy ri̱tyamuntiy ti̱ta̱ju̱ jiryatiy ravicha rancha risa̱ju̱.
\v 21 Darya ni̱day, ni̱tiy nique Ju̱denu nijyu̱ jachipiya̱jo jtyamu, sanique ne vinu ri̱tyamu, sanique variy si̱tyamuntiy ni̱tiy vichasara ravimu.
\v 22 Darya ni̱day, ni̱tiy nique jarichu jtyamu, sanique ne vinu ri̱tyamu Ju̱denu ma̱sajo, sanique variy si̱tyamuntiy ni̱tiy ma̱sasara rancha.
\p 
\v 23 ¡Jiii, rani̱tte jiryejyu̱te, ra, Ju̱denu niquejada datyanuvay, Varyisévuveda jarye, jiryatiy jiryi̱tu̱yadamu vichavayu! Jiryemyurichenu daryaju̱ Ju̱denu jiyaru̱ryaju̱ra rate nutasara, jiryatiy jiryejye̱vyechu jmyichara jaryedoju̱ra, dantyamu̱y ne jiryi̱nu̱ryu̱yada rana̱cho̱ Ju̱denu jteda tera day, jiryatiy jaryinrara, jiryatiy vase vichasa̱da darya, jantyutya̱da jarye, Ju̱denumu tuva̱choda jarye risa̱ju̱ra. Jirya̱ma̱ jvaayasiy daryá, dantyamu̱y ne jirya̱paru̱y riva murichedoda Ju̱denu jiyaru̱rya.
\v 24 ¡Jiyantavay ni̱sipyuryimyi jirye! ¡Jirye ramityanirya ja̱ nta cani̱tujisiy, jiryatiy jiryebecharara rajuura ju̱bayada nijya̱nvajyu̱, jiryeryamichu nta ji̱ta rivasiñi̱ camélluqui nta, jiryatiy jiryepyaru̱y riva jantyutya̱da, Ju̱denumu tuva̱choda jarye risa̱ju̱!
\p 
\v 25 ¡Jiii, rani̱tte jiryejyu̱te, ra, Ju̱denu niquejada datyanuvay, Varyisévuveda jarye, jiryatiy jiryi̱tu̱yadamu vichavayu! Jirye ji̱ta rañi suutasara rarudivasiy jatusiidye, siidye jarye, jiryevyimu ji̱tara paradoda day, ni̱ru̱yadacanuyadamu vichasa̱da jarye risa̱ju̱.
\v 26 ¡Varyisévuveda ni̱sipyuryimyi jirye! Jirya̱pu̱y munatya ravimu jatusiidye, siidye jarye, ra̱tidye vichasara pu̱chara rárudivantiy.
\p 
\v 27 ¡Jiii, ta̱ju̱na̱te darya jiryejyu̱te day, ta̱ju̱, Ju̱denu niquejada datyanuvay, Varyisévuveda jarye, jiryatiy jiryi̱tu̱yadamu vichavayu! Jiryeñi̱cha daryaju̱ nu̱tyu bapyo muchanusara, rirya̱tidye diy nijya̱nvay samirya riva. Ravimu ji̱ta diibyi binda, javityichara jarye.
\v 28 Darya ni̱day jirye, jiryatiy jiryeñi̱cha samiy jvadichavay nijya̱nvay diya, jiryejechimyu ji̱ta jivyichasara jiryi̱tu̱yadamu jachipiya̱vay, nicyara̱y jachipiya̱jadatavay jarye risa̱ju̱.
\p 
\v 29-30 ¡Jiii, rani̱tte jiryejyu̱te, ra, Ju̱denu niquejada datyanuvay, Varyisévuveda jarye, jiryatiy jiryi̱tu̱yadamu vichavayu! Jirye ji̱ta jvaachara bapyonchara rorichidyera, Ju̱denuju̱ tu̱chuvabe jachipityasa̱daju̱, jiryi̱dutyasara samintyirya ribepyontiy, jiryatiy rivyichanu̱yada vase vichavay daryaju̱, jiryi̱tachara variy: Vu̱ryityi vicha̱da ta̱riy vu̱myunatyavabe rundamu, ne vu̱ryi vichadeda vatajuu ruusa̱riy Ju̱denuju̱ tu̱chuvabe, jiryatiy ru̱veda riy.
\v 31 Ramuni̱tiy jiryeñi tu̱chuta jiñijyu̱, jiryatiy jiryeñi̱cha ridyedyeñu, rityi ju̱veda riy Ju̱denuju̱ tu̱chuvabe.
\v 32 ¡Jirya̱numa jto̱tanirya jiryemyunatyavabe jiyasayada day!
\v 33 ¡Codityevay rapu̱ryamiy! ¿nu̱tyuramusiña̱ jirya̱ramityara jiidatyo̱muju̱ jatyasa̱da, nu̱tyuramusiy?
\v 34 Ramuni̱ ri̱pa̱sara jiryimu riy rajyu̱ tu̱chuvay, nijya̱nvay datyavay jarye, Ju̱denu niquejada datyanuvay jarye ruusa̱ju̱. Jirya̱jvaryi rityevay, jirya̱jvay crusitya̱santiryi; ti̱ni̱ jirya̱musiye̱ ju̱tye̱ryanijyovimuntidye, jirya̱jarupantanumaya̱ vicha̱damusiy, ratarya vicha̱damuju̱ variryi.
\v 35 Jiryatiy jirya̱jvaachara daryá, ra̱day ju̱u̱y jiryiva ju̱veda murichenusa̱da, jiryatiy riryubedara vase vichavay nuda, samiy vichi̱ Abénubay nudamusiy, Sacaryébay nuda sa̱ra̱ju̱, jiryatiy Baraquíyabay denubañi̱, jiryatiy jiryeñi jvay raparudamu jnutatyasara rupajyo, Ju̱denu nijyu̱ jachipiya̱jo jarye.
\v 36 Ri̱tatye si̱tenu jiryiva: Ra̱day ju̱u̱y jirya murichenusa̱da ti̱ta̱ju̱ ruuva jivye jamirya vichavay.”
\s1 Jesús jna̱yada rivasiy Jerusarí̱
\r (Dúcasiy 13.34-35)
\p 
\v 37 “Jerusarí̱, Jerusarí̱, jiñijya̱nvay ji̱ta jvachara riy Ju̱denuju̱ tu̱chuvabe, rijechichara ravichu̱ta riy, jiryatiy su̱pa̱sara Ju̱denu riy yinsu̱byimiy ruumu. Rajuuraju̱ rañi ju̱tye̱ryaniryu̱yada riy ridyedyeñu, nu̱tyu tavaryityoda mutanusara jiñipya̱ta suvu̱charajisiryi jidyenujuu darya; tiii, riryivya̱tava̱ra.
\v 38 ¡Tíjyiii, satochimye̱ttye Ju̱denu mityara jiryevyichajo!
\v 39 Ri̱tatye daryaju̱ jiryiva: Ne jirya̱diy ju̱na̱y riva rabetyedivasiñu̱day, netimyu̱ ne jirya̱jtay didye: ¡Jchana̱tyasi̱te ni̱tiy jnitye Nutyityu̱ jtyamute!”
\c 24
\s1 Jesús jteda ra̱parutachara Ju̱denu nijyu̱ jachipiya̱jo
\r (Márcu 13.1-2; Dúcasiy 21.5-6)
\p 
\v 1 Sasipyateda Jesús variy Ju̱denu nijyu̱ jachipiya̱jovimusiy. Saya̱damu ji̱ta, sisa̱ datyavavyedabay dityadoda variy Ju̱denunijyu̱ jachipiya̱jo rorivyicha̱yu.
\v 2 Su̱mutya̱jada ji̱ta Jesús variryi: “¿Jiryi̱nu̱vidye jirya ti̱ta̱ju̱ day? Ri̱tay si̱tenu jiryiva: Ne sa̱ma̱cho̱ ti̱ ravichu̱ jiryenu ravichu̱nchanu̱day. Rirya̱jotatimyu̱rya roriy variy, pattaryitye ti̱ta̱ju̱ra.”
\s1 ¿Nu̱tyuramusiy vurya̱datya rajo̱tanuma mucadi baryi̱jada, nu̱tyuramusiy?
\r (Márcu 13.3-13; Dúcasiy 21.7-19; 17.22-24)
\p 
\v 3 Sama̱sa̱danumatiy Jesús ja̱mu musincha jiryatiy ravicha̱da ri̱tya Odivu, rityuudiyada ji̱ta sisa̱ datyavay sa̱siquita Jesús variy jasiyu, ru̱teda ji̱ta variy siva: “Ya̱tu̱chu nu̱dyiva: ¿Nu̱tyeryivye ra̱cha daryá, jiryatiy yitesiy darya ra̱cha, nu̱tyeryivye? ¿Mirya rani̱cha rajo̱tara day, mirya? ranchityi nu̱ña̱datya: Diye ni̱day sa̱jti̱, ra̱numatiy baryi̱ jirya mucadi runda risa̱ju̱.”
\v 4 Su̱mutya̱jada ji̱ta Jesús variryi: “Jiryi̱nu̱tyata̱ta quivu̱chodajisiyu.
\v 5 Tapi rirya̱jniy rajuuvay ri̱tyamu, rirya̱jtachara variy: Rañi rañi̱cha Ju̱denu jaryeti̱, riñi ra̱caretanichara riy rajuu nijya̱nvay variy riva.
\v 6 Jirya̱tuva̱chu rana̱cho̱ ju̱veda, ju̱veda jaticheyadana̱cho̱ jarye, jiryi̱nu̱tyata̱tayu, ne jirya̱suvu̱y ranchiy, tapi daryatya ra̱cha si̱tenu, ra̱viy baryi̱te jiryi̱tay didye.
\v 7 Ra̱numa richatay ju̱veda tavicha̱dajsa̱, rirya̱numa richata tavicha̱da ja̱nvay munu̱ñumirya ju̱veda runda. Ra̱numa vicha jachi̱nu variy, muco siityeya̱jada jarye tajijyu̱ ti̱ta̱ju̱ risa̱ju̱ntiy.
\v 8 Nu̱tyi raday rani̱cha jirya ti̱ta̱ju̱ rajo̱ttya̱ paru̱tyajaya̱jada.
\v 9 Jadchiy ji̱ta rirya̱ju̱riy nijya̱nvay jirye jarupanta̱damuju̱, rirya̱jvay variy jirye. Jirya̱vichasara javittyuchavay variy ti̱ta̱ju̱ nijya̱nvajyu̱, ri̱tya jiyadaju̱.
\v 10 Jadchintyi rirya̱paru̱y rajuuvay rachiityari̱sa̱diva, rirya̱sa̱y jimyityasimyiyu, rirya̱javittyuy varintyiyu.
\v 11 Rirya̱mu̱ti̱sara rajuuvay jiryatiy ru̱tu̱yada ya̱jtay Ju̱denuju̱ tu̱chuvayu, rirya̱jatachusara Ju̱denu nú̱vasiryi rajuuvay nijya̱nvay.
\v 12 Jiryatiy ra̱jasa̱chusarara nicyara̱y vichasa̱da variy, ra̱day sudovachara variy rivya̱ta̱da rajuuvay Ju̱denunijyu̱.
\v 13 Ni̱tiy ra̱jachi̱nchara ta̱rijyu̱ raju̱yu, sadiiyada sa̱ra̱ju̱, sa̱day ramityasara variy.
\v 14 Rirya̱tu̱chunumaya̱ ji̱ta ti̱ta̱ju̱ mucadivara jirya samitu̱choda Ju̱denu nusu̱yadanchiy variy, rirya̱tidye tuva̱chu ti̱ta̱ju̱ nijya̱nvay jasirya. Jadchiy ji̱ta ra̱jti̱ tara baryi̱jada runda.”
\s1 Paru̱tya̱da rundanchiy
\r (Márcu 13.14-23; Dúcasiy 21.20-24)
\p 
\v 15-17 “Jirya̱numatiy diy riva javityichara jiryatiy ra̱bay mityarorirya raryoriy, jiryatiy satu̱choda Ju̱denuju̱ tu̱chu̱ Ta̱ñírubay ranchiy, (ni̱tiy ra̱jnu̱y ramu variy, jidyetyata̱ta taryera), variñi̱ ji̱ta rityi vichasara Judéyamu variryundamu, riryi bay variy ja̱mu musimyuju̱; ni̱tiy ra̱tu̱chu sisa̱ jityuunu vichi̱, dañuma ra̱vicha sabarya jiryorivyimu, ne sa̱jay variy jiberya ju̱redana̱cho̱.
\v 18 Darya ni̱day ni̱tiy ra̱cha yindimyu, ne sa̱siityityi jichujay ju̱redana̱cho̱ jiryorivyimusiy.
\v 19 Ta̱ju̱na̱te day ni̱tiy mudasiy, ta̱ju̱, ni̱tiy ra̱rupatyaniy variryundamuni̱ jidyenuntiy.
\v 20 Jirya̱ntya va̱ta Ju̱denusa̱ tu̱chodamura: ne nijya̱ rundamu ra̱cha variy, dantyamu̱y jiituyada rundamu.
\v 21 Tapi rarundamu ji̱ta ra̱cha paru̱tya̱da runda, vu̱dyiyadatya riva daryacu̱, jiryatiy rajo̱ta̱damusiy ju̱dejadara, diye rundasa̱ra̱ju̱ ne vu̱dyi riva, dantyamu̱y ne vurya̱dichara daryiva jadchiñu̱ndye.
\v 22 Netimyu̱ ne sa̱jmuchaniy Ju̱denu varirya paru̱tya̱da runda, ne ti̱ dera raryi ramitya nijya̱mi̱ variy. Jiryatiy sava̱ta Ju̱denu daryaju̱ daryi jijeryetasavadye, sa̱jmuchaniy varirya paru̱tya̱da runda.
\p 
\v 23 Saryityi jtay ti̱ variryundamu jiryiva: ¡Jiñutiy jiyuni̱ Ju̱denu jaryeti̱! varimyata sa̱jtay jiryiva: ¡Mu̱ñumani̱! ne jirya̱tuva̱chu variy ramu.
\v 24 Rirya̱mu̱ti̱sara daryaju̱ ru̱tu̱yada ya̱jtay Crístuyu, ru̱tu̱yada ya̱jtay Ju̱denuju̱ tu̱chuvay jarye risa̱ju̱ntiyu. Riñi ra̱jvaañuvi̱ mityamusiy tara nijya̱nvay diya, riñi jtay ya̱quivu̱chu ratariy Ju̱denu jaryetasavay variy.
\v 25 Jiryi̱nu̱tyata̱tayu, rañi tu̱chuma̱ ra̱jisiy jiryivara.
\v 26 Ramuni̱, riryityi jtay jiryiva: ¡Mu̱ñumani̱, tajityomu! ne jirye̱jiya rumu. Riryityi jtay jiryiva: ¡Jiñutiñi̱, rorichiy puryesaravimuni̱! ne jirya̱tuva̱chu variy ramu.
\v 27 Tapi Nijya̱mi̱denu jti̱jada ra̱chasara nu̱tyu ra̱duya̱ra, jiryatiy ra̱jaduya̱ nta jiñi̱ mu̱ti̱jomusiy jarichu su̱tyeryasa̱ra̱ju̱, daryani̱ ra̱chasara.
\v 28 Jasityiñi̱ diibyi, jasiñi̱ ji̱ta rirya̱ntye̱ryaniy didapasuyanujuuyu.”\f * \fr 24:28 \ft Jasityi rivyichasara nijya̱nvay jaryi nicyara̱myi, rapotiye̱ rivyichasa̱da Ju̱denuju̱, nu̱tyu rapotiye̱chara diidabi daryá.\f*
\s1 Jesús datyadoda nu̱tyura ra̱chasara Nijya̱mi̱ denu jti̱jada, nu̱tyura
\r (Márcu 13.24-27; Dúcasiy 21.25-28; 17.22-37)
\p 
\v 29 “Varenude paru̱tya̱da rundavasiy, jiñi̱ ra̱nupocudivay variy, jarimyuni̱ jarye ne ra̱nu̱y vanda variy, jdarichiy jarye ra̱ju̱u̱ya̱ variy jarichumusiy, jarichu vanu̱yada ra̱muchutyecharantiy.
\v 30 Jadchiy ji̱ta ra̱mu̱ti̱ Nijya̱mi̱denu dityanuta̱ jarichumu, rirya̱nuvay nijya̱nvajyuu, ti̱ta̱ju̱ mucadiva vichavay jichuvu̱yadamu, rirya̱diy nijya̱nvay variy siva Nijya̱mi̱denu, jiryatiy su̱niy rapuryeryadinube, jaryi vanu̱yadata, jaryi vandanube jarye risa̱ju̱.
\v 31 Sa̱jpa̱ ji̱ta riy yipa̱vay, natutya̱ jaryi suryata, rirya̱ju̱ryityanumaya̱ tajichiy riy sajaryetavay, jarichu su̱tyeryamusiy, ráramiryivasiy ti̱ta̱ju̱.”
\s1 Jiivyíryanu datyadoda
\r (Márcu 13.28-31; Dúcasiy 21.29-33)
\p 
\v 32 “Jirya̱numa datya jiivyíryanumusirya radatyadoda. Radipuvesumiñumatiy ravi̱, jiryedyiñumatiy variy riva, jiryedyetyanuma ranchiy: Ravicharu̱ñuma nijya̱ rundantiy.
\v 33 Daryaday ra̱chantiy, jirya̱numatiy diy riva jirya ti̱ta̱ju̱ daryatiy ratyu̱chosiy jiryivara, ranchiñi̱day jirya̱datya̱siy: Ne ripya nu̱nrya siti̱jadanu̱day; jativyenumani̱.
\v 34 Ri̱tay si̱tenu jiryiva: Ne rirya̱baryi̱ jivye va̱cha vichavay, netimyu̱ ne ra̱jto̱taniy ti̱ta̱ju̱ra jirya ti̱ta̱ju̱ didye.
\v 35 Jarichu, mucadi jarye risa̱ju̱ ra̱baryi̱sara, rañiquejada ji̱tamu̱y ne ra̱ma̱cho̱sara mitya, ra̱jto̱tanichara ti̱ta̱ju̱yu.”
\s1 Ne ti̱ datyara nu̱tyeryivye ra̱cha paru̱tya̱da runda, nu̱tyeryivye
\r (Márcu 13.32-37; Dúcasiy 17.26-30; 21.34-36)
\p 
\v 36 “Ta̱ra rundamuni̱ntyi jirye̱cha darya, ta̱ra rundamu, nu̱tyeryivye ni̱ntyi dyetya, nu̱tyeryivye, ti̱tya datya. Dantyamu̱y ne Ju̱denu jpa̱vay datya jarichumu, netimyu̱ ne vinu Sadenu, tapi vinu ni̱day Vu̱jye̱ datya day.
\v 37 Daryani̱ rivyicha̱da Nuvébay rundamuntiy, daryaday ra̱cha Nijya̱mi̱denu ju̱dedantiy.
\v 38-39 Tapitya daryani̱ riñi jmyiñu̱yada, rirya̱tunu̱yada jarye risa̱ju̱, ja̱mu nijya̱ paruta̱dajisiy. Rijya̱mu̱ñu̱yada, rijya̱mu̱tyaniñu̱yadantiyu, Nuvévedabay jmusa̱dasa̱ra̱ju̱ cartyequiivimu, ne ridyetya̱da nijya̱nvay tara, jasicha̱ra̱ju̱tiy ranijye̱yada ji̱ta riñiya̱resiy, raso̱veda rivyichajomusiy variy ripyarutedaju̱yu. Darya ni̱day ra̱chasara Nijya̱mi̱denu ju̱dedantiy.
\p 
\v 40 Jadchiy ji̱ta danu̱ju̱y vanuju̱y ra̱cha yindimyu, ti̱qui ji̱ta ra̱cha jara̱chi̱, sisa̱ vichi̱ ji̱ta ra̱cha tochichi̱.
\v 41 Nana̱cha danu̱ju̱y vaturu̱jyu̱y, tunu̱nuvimu tanunu̱jyu̱y, tanu̱qui ji̱ta ra̱cha pu̱chichanu̱y, nadisa̱ vichanu̱y ji̱ta ra̱cha tochichanu̱dye.
\v 42 Ramuni̱tiy jirya̱ntya jnu̱tya samiyu, jiryedyetyaviy yinu̱y nu̱tyeryivye sa̱jniy Vu̱ntyityu̱, nu̱tyeryivye.
\v 43 Jirya̱ma̱ datya ji̱tara jirya: Saryityi datya̱da rorijya̱mi̱ nu̱tyeryivye sa̱jti̱ paranu̱ni̱ nupora, nu̱tyeryivye, saryi ma̱cho̱jada jnu̱tyi̱ paranu̱ni̱jiju̱, ne saryi jatyadeda jiryorivyimu variñi̱.
\v 44 Ramuni̱tiy jirye jarye ra̱ma̱cho̱ jnu̱tyavay, tapi varityimyu̱ ne jirya̱nutuy sa̱jiju̱ Nijya̱mi̱denu, mityamusiy sa̱jti̱sara variy jiryi̱biva.”
\s1 Jesús datyadoda muchechiy siityeranchiy, sasiityejadasa̱nchiy jarye
\r (Dúcasiy 12.41-48)
\p 
\v 45 “¿Mi̱rana̱te muchechiy siityera, mi̱? datyara jarye risa̱ju̱ni̱, jiryatiy sa̱bay patru̱ jiryoriy jnu̱tyi̱si̱ju̱ni̱, sa̱tidye sa̱chara riyaru̱rya jmyichara jiryenu muchechimyiyu.
\v 46 Jchana̱tyasi̱ ji̱ta jiñu muchechiy, ni̱tiy sa̱saryenuvi̱ sapatru̱ yivaayadamu.
\v 47 Ri̱tay si̱tenu jiryiva: Sa̱day bay jiberya jnu̱tyi̱ju̱ni̱, sa̱tidye jnu̱tyajaya̱ ti̱ta̱ju̱ jasirya.
\v 48-50 Saryityi jachipiya̱jada jiñu nicyara̱y muchechiy jivyimu: Saricheñuma rapyatru̱, saryijyo̱ta̱da ji̱ta musiye̱yada variryi jiryenu muchechimyi, saryi jmyi, saryi jatu ruusa̱ niyu̱byimintyi, sa̱jti̱ ji̱ta sapatru̱ varityimyu̱ ne sa̱nutuy sa̱jiju̱, jiryatimyu̱ ne sadatya sa̱jti̱ daryaju̱.
\v 51 Sa̱tanuvu̱nunuvi̱ sapatru̱ variy ruusa̱ju̱yu jiryatiy ru̱tay yitu̱yadamu muchechimyi ntayu. Jasidye ji̱ta rirya̱jna̱vya̱ nijya̱nvay variy, rirya̱su̱y ji̱ta jijya̱dajchantiy.”
\c 25
\s1 Jesús tu̱choda vu̱yaju̱y vaturavedanchiy
\p 
\v 1 “Jadchiy ji̱ta Jarichumuvichi̱ nusu̱yada rañi̱cha nu̱tyu vu̱yaju̱y vatuy, jiryatiy riya̱da no̱no̱siityavay si̱dcho̱ju̱ vadi ja̱mu̱ñu.
\v 2 Tadajyo rityevay vicha̱da datyi̱sa̱miy, darya tadajyo datyavay varintyi.
\v 3 Rityi vicha̱da datyi̱sa̱miy ne ru̱toda yimura no̱no̱ja̱ ta̱ratya rirya̱ju̱chiy ru̱bivaju̱ jiño̱no̱siivyimu variy.
\v 4 Vatuy datyavay ji̱ta jtoda putiyavu̱vimura no̱no̱ja̱ yimu, jiño̱no̱siiju̱sa̱ju̱.
\v 5 Saricheyadanumatiy vadi ja̱mu̱ñu, rime̱ryu̱yadamu jime̱ñu̱yada vatuy.
\v 6 Nuporata̱sa ji̱ta ti̱ niquejasubeda: ¡Jativyenumani̱ vadi ja̱mu̱ñu! ¡Jirya̱numa jiya si̱dcho̱ju̱!
\v 7 Jadchiy ji̱ta riñubesubeda vatuy ti̱ta̱ju̱, ru̱dutya̱da varirya jiño̱no̱siiy sa̱jiju̱.
\v 8 Vatuy datyi̱sa̱miy ji̱ta jteda ruuva vatuy datyavay: Jirya̱sa̱y jiño̱no̱ja̱te nu̱y, jiryatiy rabaryi̱ru̱ñuma nu̱ño̱no̱ja̱ day.
\v 9 Vatuy datyavay ji̱ta jmutya̱jada variryi: Tama̱ ne rasa̱ra̱ ntate vu̱jyu̱ ti̱ta̱ju̱ darya, tama̱, jirya̱numa jiya ta̱ryu̱vye, no̱no̱ja̱ ta̱ryu̱tyavamyu.
\v 10 Riya̱danumatiy ta̱ryu̱vye, su̱deda ji̱ta vadi ja̱mu̱ñu. Rityi vichasara vatuy jdutyasavay, riñi jayada variy sisa̱ ja̱mu̱yada vichtyamu. Samutadoda ji̱ta varirya rorijyu̱.
\v 11 Rivasiy ji̱ta ru̱deda vatuy datyi̱sa̱mintyi, riñiquejada: ¡Nutyityu̱, Nutyityu̱, ya̱mutta nu̱ña̱jisiy!
\v 12 Ni̱ni̱ ji̱ta jmutya̱jada riy: Ri̱tay si̱tenu jiryiva: Ne radyetya jirye.
\v 13 Ramuni̱tiy jiryentya jnu̱tya samiyu, jiryedyetyaviy yinu̱y ta̱ra rundamu sa̱jniy, ta̱ra rundamu, dantyamu̱y ne ta̱ra jóramu.”
\s1 Jesús tu̱choda Ju̱denu murichenutadedanchiy
\r (Dúcasiy 19.11-27)
\p 
\v 14 “Ju̱denu nusu̱yada ji̱ta ra̱cha daryaju̱ nu̱tyu vanu jiryatiy sayaru̱yada rupiñu. Sanatuyada ji̱ta yimuju̱ riy jimyuchechimyi, sabayada ji̱tara jiberya ruumu ru̱nu̱tya̱daju̱.
\v 15 Ti̱qui sasa̱yada tadajyo pacha vara̱nca sonu, ti̱ntiy sasa̱yada daraju̱y pacha vara̱nca, nu̱ntiy taraqui pacha vara̱nca, nu̱ñi ti̱quimusiy ru̱mutya̱jada jidyetya̱da jvaayada sa̱ra̱ju̱. Saya̱da ji̱ta vanu variy.
\v 16 Muchechiy ji̱ta, jiryatiy su̱mutya̱jada tadajyo pacha vara̱nca sonu, ni̱day jiya̱da varicha̱ra̱ju̱ ju̱vaañu rata, saca̱na̱yada ji̱ta tadajyo pacha vara̱nca ranchaju̱ntiy.
\v 17 Daryaday, ni̱tiy jmutya̱jada daraju̱y pacha vara̱nca, ni̱ni̱ rañi ca̱na̱yada daraju̱y pacha vara̱nca ranchaju̱ntidye.
\v 18 Ni̱ni̱ ji̱ta jiryatiy su̱mutya̱jada taraqui pacha vara̱nca, ni̱day jiya̱da, su̱beda ji̱ta mucadinube, sadutya̱da jasirya jipyatru̱ criquiy.
\v 19 Ta̱riñi̱day, ta̱riñi̱day, sata̱rya̱jada patru̱ sa̱tidye jdutyara ridyivyi yimu.
\v 20 Siti̱jadanumatiy muchechiy jiryatiy tadajyo pacha vara̱nca jmutya̱nuni̱, su̱toda ji̱tara tadajyo pacha vara̱nca ranchaju̱, su̱teda ji̱ta jipyatru̱va: Patru̱, jiche̱yada tadajyo pacha vara̱nca sonu ray. Jiryatirya tadajyo pacha vara̱nca ráca̱na̱rya ranchaju̱.
\v 21 Su̱teda ji̱ta sapatru̱ variy yiva: ¡Rantye ji, samirya muchechiy ri̱tay variy ji! Jiryatiy yito̱tanicharara yinsu̱cha̱da pasidyeta, ra̱nusu̱tyaniy rajuura ji. Ya̱numa jay yintyityu̱ jchana̱yadamu.
\v 22 Siti̱jada ji̱tantiy daraju̱y pacha vara̱nca jmutya̱nu, su̱teda siva jipyatru̱: Patru̱, jiche̱yada daraju̱y pacha vara̱nca criquirye. Jiryatirya daraju̱y pacha vara̱nca ráca̱na̱rya ranchaju̱ntiy.
\v 23 Su̱teda ji̱ta sapatru̱ variy yiva: ¡Rantye ji, samirya muchechiy ri̱tay variy ji! Jiryatiy yito̱tanicharara yinsu̱cha̱da pasidyeta, ra̱nusu̱tyaniy rajuura ji. Ya̱numa jay yintyityu̱ jchana̱yadamu.
\v 24 Ni̱day ji̱ta jiryatiy taraqui pacha vara̱nca sonu jmutya̱nuni̱, rañi jti̱jadantiy, su̱teda ji̱ta siva jipyatru̱: Patru̱, radyetyama̱ ji, jiryatiy jaryi vuryito̱tanirya ji. Yatosara ji̱tatera teni̱ntimyu̱ ne jiñi nuta̱da tara, jiryichara ji̱tate jiryatimyu̱ ne yirejada tara jasiy.
\v 25 Rachuvu̱yadamu ji̱ta radyutyanuvejadara jicyuriquiy, taraqui pacha vara̱nca, mucadinube. Jiryanuma jiberya.
\v 26 Su̱mutya̱jada sapatru̱ variyu: ¡Nicyara̱y muchechiy piturya! ¿Jidyetya̱da viy ravyichasara jaryi jaryuvu̱rya, jiryatiy ra̱tosarara teni̱ntimyu̱ ne raynta tara, rajarye, jiryatiy raryichara jadchirya, jasityimyu̱ ne ri̱rejada tara?
\v 27 Ramuni̱, jiryi bayadara racyuriquiy criquiy jasa̱chuvamyu, raryityi jiryiñuvi̱ ra̱sa̱chusaratayu.
\v 28 Ramuni̱ jirya̱so̱vay simusirya taraqui pacha vara̱nca sonu, jirya̱sa̱y variñi̱, ni̱tiy vu̱yaju̱y pacha vara̱nca sonuti̱.
\v 29 Tapi simu jiryatiy tarati̱ni̱, sa̱sa̱y Ju̱denu variy ju̱na̱ntyiñi̱, rajuura ra̱cha simu varidye. Simusiy ji̱ta jiryatimyu̱ ne tarati̱ dañi̱, sa̱so̱vay Ju̱denu variy simusintyirya jiryatiy simuntidyerya.
\v 30 Su̱teda ji̱ta patru̱ varintyi: Jirya̱numa jatyani̱ muchechiy rapu̱rya bimuju̱, nupocudimuju̱. Jasidye ji̱ta rirya̱jna̱vya̱ nijya̱nvay variy, rirya̱su̱y ji̱ta jijya̱dajchantiy.”
\s1 Jesús datyadoda tamitya Ju̱denu murichenutadeda rundanchiy
\p 
\v 31 “Sa̱numatiy jniy Nijya̱mi̱denu jidyamu ruusa̱ yipa̱vay ti̱ta̱ju̱, variñi̱ ji̱ta sa̱ma̱sa vanda ma̱sajoncha.
\v 32 Sa̱ji̱tye̱ryanityaniryi ti̱ta̱ju̱ mucadi nijya̱nvajyuu jityuunuju̱, sa̱tidye jiintyani̱ ti̱ jityevamyusiy, daryani̱ sajiintyasara jasi̱jnu̱tyi̱ riy yasi̱veda nicyara̱myi ruumusiy samivyentyi.
\v 33 Sa̱day bay variryi samivye yintyityudamyuju̱, nicyara̱myi ji̱ta sa̱bay jimyidámyuju̱ day.
\v 34 Variñi̱ ji̱ta sa̱jtay ja̱mu nutyityu̱ ruuva: Jiryatiy rayntyityudamyu jirye: Jirya̱numa jniy, Rajye̱ Ju̱denu jmu̱tyasavay. Jirya̱numa jmutya̱ra nusu̱jyo, jiryatiy su̱dutya̱da yindejada jo̱ta̱damusiy jiryejyu̱ra.
\v 35 Ravyichanu̱yada jachi̱numu daryaju̱, jiryepyotyadeda varirye; ravyichanu̱yadatiy jchu̱mu̱ñu, jiryeche̱yada jatusara varintyirye; ravyichanu̱yadatiy ne ti̱ datyi̱, jiryedyiryejada variy yisa̱ju̱ ray.
\v 36 Ravyichanu̱yadatiy sidyavu̱, jiryejechodara sujay variy riva; ravyichanu̱yadatiy jdiva̱jni̱, jiryejeñu̱yada variy rimuntiy; ravyichanu̱yadatiy tanuvu̱nujovimu, jiryi̱deda variy rimu.
\v 37 Rirya̱jmutya̱ vase vichavay variñi̱: Nutyityu̱, ¿nu̱tyeryivye nu̱dyiyada jachi̱numu yiva, nu̱tyeryivye? nu̱pyotyadeda variy ji, varimyata nu̱dyiyada jchu̱mu̱ñu yiva, nu̱che̱yada jatusara varintyi ji.
\v 38 ¿Nu̱tyeryivye nu̱dyiyada ne nu̱dyetyi̱ nta yiva, nu̱tyeryivye? nu̱dyiryejada variy ji, varimyata sidyavu̱, nu̱ña̱tidye jachura sujay variy yiva.
\v 39 ¿Nu̱tyeryivye nu̱dyiyada jdiva̱jni̱ yiva, nu̱tyeryivye? varimyata nupocu rorivyimu, nu̱ña̱tidye jañu̱y variy yimu.
\v 40 Sa̱jmutya̱ ji̱ta ja̱mu nutyityu̱ variryi: Ri̱tatye si̱tenu jiryiva: Jiryatiy jiryevyichadeda daryani̱ ti̱quide ratyeryi̱veda tenu tamityi̱, jiryevyichadeda darya varintyidyerye.
\p 
\v 41 Jadchiy ji̱ta sa̱jtay variy ruuva jiryatiy samidámyu riy: ¡Jirya̱jiintye ratyuunusiy parutasavay! ¡Jirya̱jiya jiidamyuju̱, jiryatiy jdutyasara bayantu nutyityu̱jiju̱ra, su̱pa̱vayjiju̱ jarye yisa̱ju̱!
\v 42 Ravyicha̱da jachi̱numu daryaju̱, ne jiryepyotyadeda varirye; ravyichanu̱yada jchu̱mu̱ñu, ne jiryeche̱yada jatusara varirye.
\v 43 Ravyichanu̱yada ne ti̱ datyi̱, ne jiryedyiryejada variy yisa̱ju̱ ray; varityidye ravyichanu̱yada sidyavu̱, ne jiryejechuru̱yada varirya sujay riva; ravyichanu̱yadatiy jdiva̱jni̱, varimyata tanuvu̱nujovimu, ne jiryejeñu̱yada variy rimu.
\v 44 Jadchiy ji̱ta rirya̱jmutya̱ variñi̱: ¿Nutyityu̱, nu̱tyeryivye nu̱dyiyada jachi̱numu yiva, nu̱tyeryivye? varimyata jchu̱mu̱ñu, varimyata ne ti̱ datyi̱, varimyata sidyavu̱, varimyata jdiva̱jni̱, varimyata nupocu rorivyimu vichi̱, jiryatimyu̱ ne nu̱ñi̱mu̱tya̱da variy ji.
\v 45 Jadchiy ji̱ta sa̱jmutya̱riy: Ri̱tay si̱tenu jiryiva: Jiryatimyu̱ ne jiryevyichadeda daryani̱ ti̱quide rityenu jivye, dantyamu̱y ne jiryevyichaniy darya ray.
\v 46 Rirye̱jyasara variy ju̱na̱reju̱ tanuvu̱nusavajyu̱. Vase vichavay ji̱ta ra̱jay ju̱na̱reju̱ jnu̱yadamuju̱ day.”
\c 26
\s1 Judíyuveda tu̱chudoda Jesús ju̱redaju̱yu
\r (Márcu 14.1-2; Dúcasiy 22.1-2; Juán 11.45-53)
\p 
\v 1-2 Saca̱siyadanumatiy Jesúsra jirya datyadoda ti̱ta̱ju̱, su̱teda ji̱ta ruuva yisa̱ datyavavyedabay: “Jiryedyetyi̱satya ra̱jti̱ Pásco vichtya runda darundaju̱myusiy, variñi̱ ji̱ta rirya̱sa̱ñi̱ Nijya̱mi̱denu tavamyu, rirya̱tidye jvay crusitya̱sa variñi̱.”
\p 
\v 3 Jadchiy ji̱ta riintye̱ryadeda caserdótevyeda nutyityu̱mibe ruusa̱ nijya̱nvay rimyityumibeyu. Rivyicha̱da caserdóte ja̱mu nutyityu̱ roriquisumavimu, jiryatiy ravicha̱da si̱tya Cayivásu.
\v 4 Riñiquetasa̱dedayu: “¿Nu̱tyuramusiy vurya̱ju̱riy nijya̱nvay niya̱resiñi̱ Jesús, nu̱tyuramusiy? vurya̱tidye jvay variñi̱.
\v 5 Ne vana̱y nta vichtya rundamu day, riñuma siryi̱ nijya̱nvay variy sayadaju̱.”
\s1 Vatura rubedara vu̱rudija̱ siva Jesús
\r (Márcu 14.3-9; Juán 12.1-8)
\p 
\v 6-7 Savicha̱danumatiy Jesús Betániyamu, Siimyó̱ vatajo̱nni̱bay rorivyimu, su̱deda ji̱ta ti̱qui vatura simu, siti̱ta̱da ji̱tara vu̱rudija̱ tavu̱qui, adabástru ravichu̱teravu̱dera, jaryi murichetara. Sarumiye̱yada variy su̱no̱va Jesúsra, jiryatiy jmyijyomu sata̱yada variy.
\v 8 Ridyiyadanumatiy sisa̱ datyavay riva, riñique̱yada variy ranchiy: “¿Ta̱raju̱ra jirya pa̱chitya̱da, ta̱raju̱?
\v 9 Saryi ta̱ryu̱tya ja̱mura murichiryara, sa̱tidye sa̱yasiy variy jantyuyani̱ra ramurichirya.”
\v 10 Sadatya̱danumatiy Jesúsra rivyichadeda, su̱teda ji̱ta ruuva: “¿Ta̱ju̱ra jirya̱rupanta rivani̱ vatura, ta̱ju̱? Savichadesiy daryaju̱ samirya darye.
\v 11 Rirya̱day vichasara jantyuyadavay jiryisa̱, ray ji̱tamu̱y ne ra̱cha ju̱na̱reju̱ jiryisa̱nu̱ndye.
\v 12 Jiryatiy sarumiye̱yasirya jirya vu̱rudija̱ riva, sivaayasiy ri̱muchusa̱dajiju̱ra.
\v 13 Ri̱tatye si̱tenu jiryiva: Tavicha̱damu jasityi rirya̱tu̱chusarara samitu̱choda ti̱ta̱ju̱ vicha̱diva, rirya̱tu̱chu ji̱tantirya jiryatiy sivaayasiy vaturantirya; ranchiñuma rirya̱jachipityasara nijya̱nvay variy rivani̱.”
\s1 Judásibe mityasiiyadani̱ Jesús
\r (Márcu 14.10-11; Dúcasiy 22.3-6)
\p 
\v 14 Jadchiy ji̱ta Judásiy Iscaryótibe, jiryatiy savicha̱da vu̱yaju̱y Jesúsjsa̱ datyavavyedabay tenu, danu̱ju̱y rinchaju̱, rañi jiya̱da caserdótevyeda nutyityu̱mibemyu.
\v 15 Su̱teda ji̱ta variy ruuva: “¿Ta̱ra jirya̱sa̱rye, ta̱ra? ra̱tidye sa̱y Jesús jirye.” Rimyurichedoda ji̱ta mumuri̱ vu̱yaju̱dye pupaday criquitya variñi̱.
\v 16 Jadchidye ji̱ta sajachipiya̱jada Judásibe: “¿Nu̱tyichitya rache̱yadate samiryamuni̱cu̱, nu̱tyichiy?”
\s1 Jesús jbyedara tamitya jidye jmyi̱sara vatajuu yisa̱ datyavatya
\r (Márcu 14.12-21; Dúcasiy 22.7-14; Juán 13.21-30)
\p 
\v 17 Pa̱ suro̱ vichtya runda jo̱ta̱damu, rityuudiyada ji̱ta sisa̱ datyavavyedabay Jesúsyu: “¿Tera jivya̱ta nu̱ña̱jdutyara jmyichara jibyedaju̱, te? Pásco vichtya rundamu jmyi̱saraju̱.”
\v 18 Su̱teda ji̱ta ruuva: “Jirya̱numa jiya ja̱mu vicha̱damu simu ti̱qui nijya̱mi̱, jirya̱jtay variy siva: Su̱tesiy Datyanu̱: Rito̱ma̱ raryunda; nu̱ña̱jvaarya Pásco vichtya risa̱ datyavatya jiryorimyu.”
\v 19 Ruuvaayada ji̱ta sisa̱ datyavay daryatiy sadatyadoda riy, ru̱dutya̱da ji̱tara Pásco rundamu jmyi̱sara variy jasiy.
\p 
\v 20 Jidyenumatiy ravicha̱da, sata̱yada ji̱ta jmyijyomu yisa̱ datyavavyedabatya.
\v 21 Riibyedamu ji̱ta, saniquejada Jesús: “Ri̱tay si̱tenu jiryiva: Ti̱qui jiryetyenu ra̱sa̱y ramyityasimyimyu ray.”
\v 22 Riyiveda ji̱ta variy ranchiy, rijyo̱ta̱da jtaja̱doda variy nu̱ñi ti̱quimusiñi̱ Jesús: “¿Ray vidye, Nutyityu̱?”
\v 23 Ni̱ni̱ ji̱ta jmutya̱jada variryi: “Ni̱tiy parodesiy jijyomutara pa̱ tapa̱quivimu vatajuu risa̱, ni̱ni̱ ra̱sa̱y ramyityasimyimyu ray.
\v 24 Sa̱jyasara ji̱ta Nijya̱mi̱denu jiyusiy, daryatiy riñu̱yada sanchiy. ¡Acuu, ta̱ju̱na̱te darya, ta̱ju̱, chi̱na̱ sa̱yasitye ni̱ Nijya̱mi̱denute day, chi̱! Saju̱ni̱ ji̱ta raryicha samirya netimyu̱ ne sarupeda day.”
\v 25 Judásibe ji̱ta, ni̱tiy sa̱yadani̱, su̱teda variy siva: “¿Ravyidye, Datyanu̱?” Su̱mutya̱jada ji̱tani̱: “Yitesimya̱ day.”
\s1 Sadatyadoda Jesús riy: “Pa̱ ravyu̱, bínuja̱ ji̱ta rayndaja̱day”
\r (Márcu 14.22-26; Dúcasiy 22.14-20; 1 Coríntyu 11.23-26)
\p 
\v 26 Riibyedanumatiy variy, saryeda ji̱ta Jesúsra pa̱, si̱chana̱tya̱danumatiñi̱ Ju̱denu ranchiy, sapata̱da ji̱ta rata̱sa pa̱, sasa̱yada variy yisa̱ datyavavyedabarya. Su̱teda ji̱ta ruuva: “Jirya̱numa ju̱riy, jirya̱numa jmyirya; jiryatirya ravyu̱ day.”
\v 27-28 Sapu̱ya̱da ji̱ta varirya jatuvu̱, si̱chana̱tya̱danumatiñi̱ Ju̱denu ranchiy, sasa̱yada ji̱ta variryi, su̱teda variy ruuva: “Jirya̱numa jatura ratera ti̱ta̱ju̱musiy, tapi jiryatirya rayndaja̱, ratatiy rito̱tanirya ri̱teda, nijya̱nvay jantyutya̱daju̱, jiryatiy rumichara nijya̱nvajyuu jiyadaju̱ darya, ra̱tidye ramityaniy ruuvasirya jijyuuchuveda.
\v 29 Ri̱tay ji̱ta jiryiva: Ne ra̱jatu ju̱na̱ñu̱darya nuri̱ju̱u̱sijya̱nu̱day, rarundasa̱ra̱ju̱ varityi ra̱jatu darya vadija̱ jiryisa̱ rajye̱ nusu̱jyomu day.”
\s1 Jesús jteda siva Pyítrubay: “Ya̱ra̱yasiy rayadaju̱”
\r (Márcu 14.27-31; Dúcasiy 22.31-34; Juán 13.36-38)
\p 
\v 30 Rimyurra̱yadanumatiy Ju̱denu nijyu̱, richipyateda ji̱ta variy jadchiy Odivu musiqui na̱cho̱ju̱.
\v 31 Jadchiy ji̱ta Jesús jteda variy ruuva: “Jiryeñi ra̱sabuya̱te raynchiy diye nupora, nu̱chara Ju̱denu niquejadamu daryaju̱ra:
\q1 Ra̱jvañi̱ jasi̱jnu̱tyi̱, rirya̱ju̱rachara jasi̱veda variy sivasiyu.
\m 
\v 32 Ra̱numatiy mi̱sa̱sumiy radyiijyomusiy, ra̱day jiyanta jirye Cadidéyamuju̱.”
\v 33 Su̱mutya̱jada ji̱ta Pyítrubay variñi̱: “Dañuma riñi sabuy ti̱ta̱ju̱ jiinchiy, tama̱ rachaburyu̱charate radye, tama̱.”
\v 34 Su̱teda ji̱ta Jesús variy siva: “Ri̱tay si̱tenu yiva: Diye nupora, netimyu̱ ne sa̱suy tavaryi didye, ya̱ra̱yasiy mumuri̱ju̱ rayada.”
\v 35 Su̱teda ji̱ta Pyítrubay variy siva: “Dañuma rirya̱jvay yisa̱ju̱ ray, dantyamu̱y ne ra̱ra̱yasiy variy jiyada.” Daryaday ru̱teda sisa̱ datyavavyedabay ti̱ta̱ju̱ntiy.
\s1 Jesús tu̱choda Ju̱denusa̱ Jetsemaní̱mu
\r (Márcu 14.32-42; Dúcasiy 22.39-46)
\p 
\v 36 Jadchiy ji̱ta riya̱da Jesúsveda vichajomu, ravicha̱da ri̱tya Jetsemaní̱. Su̱teda ji̱ta Jesús ruuva yisa̱ datyavavyedabay variy: “Jiyuni̱ jirya̱ma̱sajadyi munatya, ra̱tu̱chujadyi munatya sisa̱ Rajye̱ mu̱y.”
\v 37 Sa̱ra̱yadanumatiy yisa̱ni̱ Pyítrubay, Sebedévubay denuju̱be jarye sisa̱ju̱, sani jo̱ta̱da Jesús yivatyadayu, saparu̱tya̱da variy risa̱ju̱yu.
\v 38 Su̱teda ji̱ta variy ruuva: “Saparu̱tyanuma ri̱ntu rimuyu, radyiiyadajiju̱. Jiyuni̱ jirya̱ma̱cho̱ jnu̱tyavay munatya ra̱jiju̱.”
\v 39 Saya̱da ji̱ta Jesús nu̱jipyudeju̱ variy, su̱patyeñuvejada jimyo̱ta, satu̱choda ji̱ta sisa̱ Ju̱denu jasiy: “Ye̱ye̱, vana̱tyi ra̱ramityaniy rivara jirya paru̱tyasa̱da jatusiiy, ya̱ramityanirya. Dañumamu̱y ne ye̱chaniy darya, daryatiy ravya̱ta yivara, daryani̱ ji̱ta ye̱chanidyerye, daryatiy jivya̱ta dacyu̱.”
\p 
\v 40 Sata̱rya̱jada ji̱ta Jesús variy rumusiy, sadiñuvi̱jada ji̱ta ruuva yisa̱ datyavavyedabay ma̱vye. Su̱teda ji̱ta variy siva Pyítrubay: “¿Daryani̱ ne vana̱y yinu̱tya̱sitye taraquideju̱te ra̱jiju̱téju̱ú̱?
\v 41 Jirya̱jnu̱tya̱siy, jirya̱tu̱chu sisa̱ Ju̱denu, jirya̱tidye ramijeryi̱ su̱mu̱tya̱data jiryimu jantyasa̱damu, tapi vu̱jechiy rañi̱cha vani̱ra, vu̱vyu̱ ji̱ta ne.”
\p 
\v 42 Ju̱na̱ntyi, daraju̱jyu̱ saya̱dantiy, satu̱choda ji̱ta sisa̱ Ju̱denuntiy: “Ye̱ye̱, netimyu̱ ne vana̱y ra̱ramityaniy jatusiiy rivara jirya paru̱tya̱da, netimyu̱ ne raryi jatura, ye̱chaniy darya ray, daryatiy jivyichaniryu̱rye.”
\v 43 Sajatyiiyada ji̱ta ta̱rya̱da rumusintyi, sadiñuvi̱jada ji̱ta ruuva ma̱vyentyi, jaryi rasu̱jeyada riñi̱sije daryaju̱yu, ramuni̱timyu̱ ne ru̱nu̱ryu̱yada variy.
\v 44 Ramuni̱tiy satocheda varintyiryi, satu̱chunuvejada ji̱ta sisa̱ Ju̱denu mumuri̱ju̱, daryaday satu̱chodantiy, nu̱tyu satu̱choda munatyantiy.
\v 45 Jadchiy ji̱ta sata̱rya̱da yisa̱ datyavavyedabamyuju̱ntiy, su̱tañuvi̱jada variy ruuva: “Jasintyate jiryeme̱jeya̱sarate jasiy. ¿Ne jiryejiitumyu̱tye didyejyu̱ú̱? Ratuudimya̱ ji̱tara rarunda, sa̱chi̱numani̱ Nijya̱mi̱denu juuchatavamyu.
\v 46 Jirya̱nubesumiy, vañunuma. Jirya̱jnu̱y, jativyenumani̱ ni̱tiy ra̱sa̱rye.”
\s1 Ruredani̱ Jesús
\r (Márcu 14.43-50; Dúcasiy 22.47-53; Juán 18.1-12)
\p 
\v 47 Jesús niquejadamu ji̱ta siti̱jada Judásibe, sisa̱ datyavavyedabay tenu. Sisa̱ni̱ ji̱ta ru̱deda nijya̱nvajyuubay jichityitya̱tavay, ju̱mu̱tyavay jarye. Ru̱deda ji̱ta caserdótevyeda nutyityu̱mibe jpa̱vay, nijya̱nvay rimyityumibemyusiy jarye ruusa̱ju̱.
\v 48 Ni̱tiy sa̱yada variñi̱ Jesús, satu̱choda ji̱tyaju̱ ruuva yisa̱ vichavabe: “Ni̱tiy ra̱mu̱chuvay siiñuva̱yadamusiy, ni̱ni̱ sa̱cha̱siy, jirya̱ju̱resiy ji̱tani̱.”
\v 49 Su̱deda ji̱ta Judásibe vase simu Jesús variy, saniquejada ji̱ta: “¿Jivyi, Datyanu̱?” Sasiiñuva̱ya̱jada ji̱ta sama̱yaniy variy jasiy.
\v 50 Su̱teda ji̱ta Jesús variy siva Judásibe: “Jaamyicyu, ¿rana̱cho̱ jivyicha jiyu?” Variñi̱ ji̱ta riñi ju̱riñuvi̱jada nijya̱nvañi̱ Jesús.
\v 51 Mityamusiy, ti̱qui Jesúsveda tenubay ratya̱dara jijyomutu, sasitya̱da ji̱ta varirya jichityitya̱, savatajo̱doda ji̱ta variñi̱ caserdótevyeda ja̱mu nutyityu̱bay muchechibe, jiryatiy sara̱cha̱dara satuva̱y.
\v 52 Jadchiy ji̱ta su̱teda Jesús sivantiy: “Ya̱barya jichityitya̱ ravichajomuntiy, tapi mi̱ni̱tyi jvay jichityitya̱ta, daryaday sa̱batye riva jichityitya̱tantidye.
\v 53 ¿Jijechipiya̱ dyetya ne vana̱y rajechiñu̱y siva Rajye̱, saryi jpa̱ varidye rimuju̱ riy yipa̱vay, taraqui pacha vara̱nca jiyadaju̱ satuunu vichavay?
\v 54 ¿Nu̱tyuramusiy variy ra̱jto̱tanichara Ju̱denu niquejada, nu̱tyuramusiy? jiryatiy su̱teda daryani̱ ra̱ni̱cha day.”
\v 55 Jadchiy ji̱ta sitaja̱doda Jesús riy nijya̱nvajyuubantyi: “¿Nu̱tyichiy jiryemya̱siñu̱y rayaro̱ju̱ jichityitya̱ta, nu̱tyichiy? ju̱mu̱tya jarye jirya̱tidye ju̱rirye, nu̱tyu paranu̱ni̱ nta rañi̱cha variy jiryejyu̱. Ramya̱sajaya̱nu̱yada datyanu̱ ti̱ta̱ju̱ rundamu Ju̱denu nijyu̱ jachipiya̱jovimu, tama̱ jiryireda variy jasirye, tama̱.
\v 56 Ravichama̱ jirya ti̱ta̱ju̱, ra̱tidye jto̱tanirya Ju̱denu niquejada jiryatiy rityu̱choda saju̱ tu̱chuvaberya.” Jadchiy ji̱ta ribeye̱yada sisa̱ datyavavyedabantyi, rityocheda ji̱ta sa̱siquitade variyu.
\s1 Ripyu̱cheda nutyityu̱miy rimyityumibemyuju̱ni̱ Jesús
\r (Márcu 14.53-65; Dúcasiy 22.54-55, 63-71; Juán 18.13-14, 19-24)
\p 
\v 57 Jadchiy ji̱ta rityi ju̱redani̱ Jesús, ruutó̱ta̱da Cayivásubamyuni̱, jiryatiy caserdótevyeda ja̱mu nutyityu̱bay dañi̱. Riñi ju̱tye̱ryadeda Ju̱denu niquejada datyanuvabe jasiyu, nijya̱nvay rimyityumibe jarye ruusa̱ju̱.
\v 58 Pyítrubay ji̱ta siityari̱jada ripyasiñi̱ Jesús, caserdótevyeda ja̱mu nutyityu̱bay roriqui vatapadasa̱ra̱ju̱. Sama̱sanuvejada ji̱ta jasiy ruusa̱ jiivu̱setavabe, sa̱tidye diy jadchiy riva, tesa̱ra̱ju̱ra ra̱baryi̱, tesa̱ra̱ju̱, jiryatiy rirya̱vichaniñi̱ Jesús.
\v 59 Caserdótevyeda nutyityu̱mibe ji̱ta vicha̱da ju̱tye̱ryanivye ruusa̱ nijya̱nvay rimyityumibe, tu̱chujomu. Riñi va̱ta̱da nijya̱nvañe̱cho̱, rirya̱tidye tu̱chuta jiquivu̱yadamu sanijyu̱ Jesús, rivatiy rirya̱jvatyaniñi̱.
\v 60-61 Riryi saryeva̱ra darya tu̱chuta̱da sanijyu̱, dañuma riñi mu̱ti̱jada rajuu tu̱chutavabe quivu̱vye. Pariche nanumu̱ti̱jada danu̱ju̱y, nanutu̱choda ji̱ta: “Jiñu vanu jteda: Raryi javatyara Ju̱denu nijyu̱ jachipiya̱jo, ra̱tidye jatyi roriiyada mumurundamimyusintyirya.”
\v 62 Saradeda ji̱ta caserdótevyeda ja̱mu nutyityu̱bay variy jasiy, su̱teda ji̱ta siva Jesús: “¿Ne yimutya̱ru̱y tara dajyu̱ú̱? ¿Nu̱tyura yitay ranchiy nanutu̱chuta̱da jiñijyu̱, nu̱tyura?”
\v 63 Jesús ji̱ta ma̱cho̱jada mitya vajerya variy jasiy. Su̱teda ji̱ta caserdótevyeda ja̱mu nutyityu̱bay variy siva: “Ri̱tatye yiva Ju̱denu jtyamu, ya̱tu̱chu nu̱dyiva: ¿Jiñi̱ta Ju̱denu jaryeti̱, si̱tenu sadenu?”
\v 64 Su̱teda ji̱ta Jesús variy siva: “Yitamya̱ daryadarye. Dañuma ri̱tay jiryiva: Diyemusiy ji̱ta jirya̱numa diy siva Nijya̱mi̱denu ma̱si̱ santyityudamyuju̱ ni̱tiy Jaryi Vanu̱rya. Jirya̱day jnu̱y sa̱numatiy jniy rapuryeryadinube jarichumusiy.”
\v 65 Jadchiy ji̱ta sarotya̱da caserdótevyeda ja̱mu nutyityu̱barya jichujay, ¡roooy! su̱teda ji̱ta variy: “¡Sa̱vityiye̱mya̱ni̱ Ju̱denu! ¿Ta̱raju̱ra vu̱ryivya̱ta ju̱na̱ñu̱nryi vijyo̱mu tu̱chuvañu̱day, ta̱raju̱? Jiryetyuva̱chuma̱ diyera sa̱vityiye̱yada Ju̱denu nijyu̱.
\v 66 ¿Nu̱tyura jiryi̱tay jirye, nu̱tyura?” Ru̱mutya̱jada ji̱ta variñi̱: “Dañuma rirya̱munu yivedatani̱.”
\v 67-68 Rityochiye̱yada ji̱ta variy samo̱va day, ru̱vatyiyada jasintyiñi̱. Ti̱ni̱ jvatyiyada sama̱yaniy jijyomututa day, ru̱teda variy siva: “Ya̱tu̱chu Ju̱denu datya̱damusiy nu̱dyiva, Ju̱denu jaryeti̱: ¿Chi̱ra ju̱vesiy jiiñiy, chi̱?”
\s1 Pyítrubay ra̱yada sayada Jesús
\r (Márcu 14.66-72; Dúcasiy 22.56-62; Juán 18.15-18, 25-27)
\p 
\v 69 Pyítrubay ji̱ta ma̱sa̱da bimu, vatapadamu. Su̱deda ji̱ta muchechityubay simu, saniqueta̱da variñi̱: “Jiñi̱ta vicha̱siy sisa̱ Jesús Cadidéya ja̱mi̱.”
\v 70 Sara̱yada ji̱ta Pyítrubay variy sayada, ridyiyadajache ti̱ta̱ju̱: “Ne radyetya ta̱ra jiñique riva, ta̱ra.”
\v 71 Sasipyatedanumatiy Pyítrubay variy roriy jajyona̱cho̱ju̱, nanudiyada tanu̱y muchechityodabay variy sivantiy, nani̱teda ji̱ta variy ruuva jasiy vichavay: “¡Ni̱ni̱day vichasara sisa̱ Jesús Nasaryémusi̱!”
\v 72 Sajatyiiyada ra̱yada Pyítrubay variy sayada Ju̱denu jtyamu: “¡Ne radyetyani̱ jiñu nijya̱mi̱!”
\v 73 Varidyeday ru̱tañuvi̱jada jasiy vichavabe siva Pyítrubantyi: “Si̱tenu jijerye rañi̱cha rityenu, jiryatiy jiñique ji̱tara Cadidéya ja̱mi̱ niquejada day.”
\v 74 Jadchiy ji̱ta sajo̱ta̱da jteda: “¡Tama̱ ray rañi̱cha, tama̱! Ratyi ra̱cha, Ju̱denu raryichaniy tara varirye. ¡Ne radyetya dañi̱ jiñu nijya̱mi̱ day!” Varidye day sasuyada tavaryi.
\v 75 Sajachipitya̱da ji̱ta Pyítrubay varirya Jesús niquejadantiy: “Netimyu̱ ne sa̱suy tavaryi didye, ya̱ra̱yasiy variy mumuri̱ju̱ rayada.” Sasipyateda ji̱ta Pyítrubay variy, su̱na̱yada jivyara jachipiya̱jadamu variy.
\s1 Ripyu̱cheda japu Pyidátubamyuju̱ni̱ Jesús
\r (Márcu 15.1; Dúcasiy 23.1-2; Juán 18.28-32)
\c 27
\p 
\v 1 Ra̱sacha̱danumatiy rityu̱chudoda caserdótevyeda nutyityu̱mibe, nijya̱nvay rimyityumibe, Ju̱denu niquejada datyanuvabe jarye yisa̱ju̱yu, rirya̱tidye jvatyaniñi̱ Jesús variy.
\v 2 Ripyuchoda ji̱tani̱, ru̱toda variñi̱ rirya̱tidye sa̱yasiy japu Pyidátu ni̱.
\s1 Saso̱tadeda Judásibeyu
\r (Jvaayada 1.18-19)
\p 
\v 3 Jadchiy ji̱ta su̱nu̱yadanumatiy Judásibe jiryatiy ribemya̱ batyi̱si̱ju̱ni̱ Jesús, saparu̱tya̱dama̱ variy riva taji jachipiya̱jada dayu. Sata̱ryatadeda ji̱ta varirya criquiy, mumuri̱ vu̱yaju̱dye pupaday, caserdótevyeda nutyityu̱mibemyuju̱, nijya̱nvay rimyityumibemyuju̱ jarye.
\v 4 Su̱teda ji̱ta variy ruuva: “¡Rajyuuchuvamya̱te! Rache̱mya̱teni̱ ti̱qui nijya̱mi̱ mitya. Nu̱tyu tara jiyasayadamu nta rache̱ñi̱.” Ru̱teda ji̱ta variy siva: “Ne dañuma nu̱ñe̱cha mitya day. Ya̱ma̱ datya day ji.”
\v 5 Sajatya̱da ji̱ta Judásibe variy Ju̱denu rorivyimuju̱ra criquiy, ¡ti̱ri̱ryin! saya̱da ji̱ta variy rivasiy. Saya̱da ji̱ta jicho̱tanicha̱dana̱cho̱, jiryatiy saso̱tadedayu.
\v 6 Caserdótevyeda nutyityu̱mibe ji̱ta jiryeda varirya criquiy sajatyajomusiy, riñiquejada ji̱ta variy: “Ne vana̱y vu̱berya jirya criquiy ru̱mutya̱jomu, jiryatiy nijya̱mi̱ jnu̱yada murichirya daryaju̱ra.”
\v 7 Rityu̱chudoda ji̱ta variyu: “¿Ta̱ra vurya̱jvaay jirya criquitya, ta̱ra?” Ritye̱ryu̱yada ji̱tara jiimo̱ jvaañu nudiy variy, taji vichavay bapyojiju̱.
\v 8 Ramuni̱tiy ru̱tachara nijya̱nvay diye sa̱ra̱ju̱ra Nudanudiy.
\v 9-10 Daryani̱ ji̱ta rito̱tadeda Ju̱denuju̱ tu̱chu̱bay niquejadayu, jiryatiy saniquejada Jiryimyíyabarya:
\q1 “Rureda ji̱tara mumuri̱ vu̱yaju̱dye criquiy pupaday, nijya̱mi̱ murichirya, jiryatiy ribeyada Irayénuveda tevarya samuricheveda, riche̱yada variy jiimo̱ jvaañu nudiy ta̱ryu̱yadaju̱ra, darya su̱tesiy Ju̱denu riva.”
\m Rito̱tadeda varirya Jiryimyíyabay tu̱choda.
\s1 Jesús vicha̱da japu Pyidátubay tuunu
\r (Márcu 15.2-5; Dúcasiy 23.3-5; Juán 18.33-38)
\p 
\v 11 Jesús ji̱ta radeda puchusi̱ japubatyuunu. Sitaja̱doda ji̱ta japubay variñi̱: “¿Jiñi̱ta Judíyuveda ja̱mu nutyityu̱?” Su̱mutya̱jada ji̱ta Jesús jasiñi̱: “Jityi jtay daryadacyu̱.”
\v 12 Rityu̱chuta̱danumatiy caserdótevyeda nutyityu̱mibe, nijya̱nvay rimyityumibe jarye ruusa̱ju̱ni̱, ne su̱mutya̱jada Jesús variy taranu̱day, mitya.
\v 13 Jadchiy ji̱ta su̱teda japu Pyidátubay siva: “¿Ne jityuva̱chura jiryatiy rityu̱chu rajuura niquejada jiñijyu̱?”
\v 14 Ne su̱mutya̱jada variy tarani̱, netiy vinu taraqui tu̱chuta̱danchiy. Sati̱tta̱da ji̱ta japubay jaryi variy rivani̱.
\s1 Pyidátubay sa̱yada crusitya̱sa jvatyadedaju̱ni̱ Jesús
\r (Márcu 15.6-15; Dúcasiy 23.13-25; Juán 18.38–19.16)
\p 
\v 15 Saviche̱chi̱numa japu dajidyeyu, nu̱ñi ja̱mu vichtya rundamu, su̱mu̱ryasara variñi̱ ti̱qui ju̱richi̱ jiryatiy rijechiñu̱ñu̱yada nijya̱nvay variy sivani̱.
\v 16 Savichanu̱yada variy jasiy ju̱richi̱ samiy datyasi̱, Barába jtyati̱bay.
\v 17 Riintye̱ryadedanumatiy nijya̱nvabeyu, su̱teda ji̱ta Pyidátubay variy ruuva: “¿Mi̱ra jiryevya̱ta ra̱jmu̱rya yimu, mi̱? Barábaviy. ¿Jiryevya̱ta dyetya ra̱jmu̱ryani̱ Jesús, jiryatiy ru̱tachara Ju̱denu jaryeti̱ni̱?”
\v 18 Sadatya̱da ji̱ta Pyidátubay daryaju̱ jiryatiy rivyichaniryu̱y caserdótevyeda nutyityu̱mibe tarani̱ Jesús riva, jiryatiy samirya ridyiryejada nijya̱nvañi̱.
\v 19 Jadchiy ji̱ta sama̱sa̱danumatiy Pyidátubay cadnadu ma̱sajoncha, nani̱pa̱jada ji̱ta savaturu̱rya jiñiquejada yimu: “Ne ya̱jtye sisa̱ jiñu nijya̱mi̱ vase vichara ji, ya̱ni̱viy vichaniy tara yitañi̱, ne yinu̱y samiryaco rame̱ryi̱sa̱siy va̱cha simusiy.”
\p 
\v 20 Caserdótevyeda nutyityu̱mibe ji̱ta, nijya̱nvay rimyityumibe jarye ruusa̱ju̱ rañi jatachoda riy nijya̱nvajyuu, rirya̱tidye jachiñu̱y Pyidátubavya sa̱jmu̱ryani̱ Barábabay ruumu, sa̱parutataniy ji̱ta variñi̱ Jesús.
\v 21 Ju̱na̱ntyi su̱teda japubay ruuva: “¿Mi̱ra danu̱ju̱myusiy jiryevya̱ta ra̱jmu̱rya yimu, mi̱?” Ru̱mutya̱jada ji̱tani̱: “¡Barába!”
\v 22 Sitaja̱doda Pyidátubay variryi: “¿Nu̱tyuna̱ jiryi̱tay ra̱vichaniñi̱ Jesús, nu̱tyu? jiryatiy ru̱tachara Ju̱denu jaryeti̱ni̱.” Ru̱tacha̱deda variy siva: “¡Sa̱cha batyi̱si̱ crusitya̱sa!”
\v 23 Su̱teda Pyidátubay variy ruuva: “¿Ta̱raju̱ra? ¿Ta̱ra sivaay nicyara̱y, ta̱ra?” Jaryiñuma riche̱ñe̱ya̱jada ji̱tate varidye: “¡Sa̱numa batye crusitya̱sa! ¡Sa̱numa batye crusitya̱sa!”
\v 24 Su̱nu̱yadanumatiy Pyidátubarya ruuvaayada nijya̱nvajyuu, sajachipiya̱jada variy: “Tama̱ vana̱y jtate ri̱mu̱ryani̱ Jesús day, tama̱, nijya̱nvajyuu ji̱ta rañi jo̱taru̱yada jvatyiyada riva.” Sasuuta̱da ji̱ta varirya jijyomutu ja̱a̱ta nijya̱nvajyuu diyadajache, su̱teda ji̱ta variy ruuva: “Ne rayasayadamu sa̱batye jiñu nijya̱mi̱ day. Jirya̱numa jnu̱chara riva.”
\v 25 Ru̱mutya̱sa̱deda nijya̱nvajyuu variñi̱: “¡Sabatyeda jiyasayada ra̱chasara nu̱ñijyu̱, nu̱dyedyeñunijyu̱ jarye nu̱dyisa̱ju̱!”
\v 26 Jadchiy ji̱ta su̱mu̱rya̱da Pyidátubay ruusa̱ju̱ni̱ Barábabay. Samusiye̱tyadedanumatiy variñi̱ Jesús, sasa̱yada ji̱ta variy crusitya̱sa batyedaju̱ni̱.
\s1 Su̱tarumiy jarupanta̱dani̱ Jesús
\r (Márcu 15.16-20; Juán 19.2-3)
\p 
\v 27 Jadchiy ji̱ta japu su̱tarumivyedabay pu̱chedani̱ Jesús japubay roriy vatapadamuju̱, riintye̱ryadeda variryi ti̱ta̱ju̱ jityevay Jesús tuunuju̱.
\v 28 Richipyata̱da ji̱ta sivasirya jichujay, rijechoda variy sivara sujacya̱ vadacudijay ru̱bivaju̱.
\v 29 Richamu̱yadanumatiy cariituju̱u̱musiy sanuviiju̱, ribeyada ji̱ta su̱no̱mu varirya. Ribeyadantirya tanchedu santyityuday jomutuvimuntiy nu̱tyu ja̱mu nutyityu̱ jiivu̱se nta rani̱cha variy. Jadchintyi rirya̱dasidyodanumatiy satuunuyu, rirya̱rupanta̱da jasiñi̱: “¡Sa̱jnu̱jeya̱sara Judíyuveda ja̱mu nutyityu̱!”
\v 30 Rityochiye̱yada ji̱ta variy siva, ruredanumatirya tanchedu sajomusiy, ru̱vatya̱da varicha̱ra̱ju̱ su̱no̱mura.
\v 31 Rirya̱rupantamu̱yadanumatiñi̱, rimerchoda ji̱ta variy sivasintyirya sujacya̱ntiy, rijechoda ji̱ta varirya sasujay yivantiy, rirya̱ra̱yada jadchiñi̱ rirya̱tidye jvay crusitya̱sa variñi̱.
\s1 Ru̱veda crusitya̱sani̱ Jesús
\r (Márcu 15.21-32; Dúcasiy 23.26-43; Juán 19.17-27)
\p 
\v 32 Rimya̱sedanumatiy jadchiy, richaryejadani̱ nijya̱mi̱ Sirénemusi̱, Siimyó̱ jtyati̱bay. Jiñu ji̱ta rinchutadeda saju̱ Jesúsra crusiy.
\v 33-34 Ruuto̱jadanumatiy vichajomu jiryatiy ru̱tachara Córucotara (jiryatiy ru̱tay Nijya̱mi̱ Jno̱siiy Vichajora), ru̱ntatyaja̱jada ji̱ta jasiy sivara bínu jivyaja̱a̱ sa̱todaju̱, jiryatiy nu̱tyi jtijya̱ta jaryenusarara. Sa̱ntya̱danumatirya, saryi jatuva̱ varirya.
\v 35 Ru̱vedanumatiy crusitya̱sani̱, riñantaja̱jada ji̱tara sasujay yiva, jiryatiy ribeñu̱yada jityiyi̱sa̱damusiy ca̱na̱yadaju̱ra.
\v 36 Rimya̱sa̱da ji̱ta variy jasiy, rirya̱tidye jnu̱tya jasiñi̱.
\v 37 Ribeyada ji̱ta su̱no̱ jiyuju̱ra jityu̱chutasa̱da, ta̱riva ru̱veda crusitya̱sani̱, ta̱riva. Ranu̱chara vicha̱da: “Jiñu ji̱ta Jesús, Judíyuveda ja̱mu nutyityu̱.”
\v 38 Jadchiy ji̱ta ru̱veda crusitya̱sa nada danu̱ju̱y paranu̱ni̱ju̱ntyi, ti̱qui santyityudamyuju̱, nu̱ntiy samidámyuju̱.
\p 
\v 39-40 Rityi ramiya̱nu̱yada satuunu, riñi javityiye̱yadani̱ Jesús, rimyichutyaja̱jadara yino̱ yavityiye̱yadamuju̱, ru̱teda ji̱ta variy siva: “Daryamu ni̱day yiteda ya̱javatyara Ju̱denu roriy, yiteda ji̱tantiy mumurundamimyusiy ra̱nubesityanintyirya, ya̱numa jantyuy jiñuberiy yiva.
\v 41-42 Jiityi rañi̱cha Ju̱denu denu, ya̱numa jmusa variy crusitya̱sasiy.” Darya ni̱day caserdótevyeda nutyityu̱mibe, Ju̱denu niquejada datyanuvabetya, nijya̱nvay rimyityumibe jarye ruusa̱ju̱ riñi jarupanta̱da yitedamu: “Sa̱ntyuyada ji̱ta tavavya, tama̱ sa̱ntyuy yivanticyu̱, tama̱. Ni̱ni̱ rañi̱cha Irayénuveda nutyityu̱, sa̱numata jmusaniy diye crusitya̱sasiyu, vurya̱tuva̱chu variy simu.
\v 43 Sajachipiya̱sara sanijyu̱ Ju̱denu. Sa̱ma̱ jantyuy Ju̱denu diye siva sava̱tasaratiñi̱, tapi su̱teda: Rañi rañi̱cha Ju̱denu denu.”
\v 44 Daryaday paranu̱ni̱ju̱bentyi, jiryatiy crusitya̱sa jvachi̱ju̱y vatajuu sisa̱ju̱ nada, rañi javityiye̱yada daryani̱.
\s1 Jesús diiyadanchiy
\r (Márcu 15.33-41; Dúcasiy 23.44-49; Juán 19.28-30)
\p 
\v 45 Vase jiñi̱tanuma ravicha̱da, ri̱ñupuyada ji̱ta variy mucadiva ti̱ta̱ju̱, ni̱nutijcha vichi̱tasa̱ra̱ju̱ ri̱ñupuyada.
\v 46 Ni̱nutijcha vichi̱ta tuunu, saniquejasubeda ji̱ta Jesús: “Elí, Elí, láma sabactáni.” Rani̱ ji̱ta jtay: “Ri̱ndenu, Ri̱ndenu, ¿ta̱raju̱ jijiintyemya̱ risa̱siy, ta̱raju̱?”
\v 47 Tavay vicha̱da satuunu variy, riñi̱ ji̱ta tuva̱chodara saniquejada day, ru̱teda ji̱ta variy: “Jiñu vanu natuye̱ñi̱ Edíyasiy.”
\v 48 Ti̱qui ji̱ta rityenu siicheda variy, sireda varirya vatsari̱juujay, saparodeda bínuja̱tara, sabayada ji̱ta tanchedujchara, su̱ntatya̱da variy sivara, sa̱tidye riñirya.
\v 49 Satevay ji̱ta jteda variy: “Jadyityara, vurya̱jnu̱jedyi sa̱vidye jniy Edíyasiy siva jantyuyadaju̱.”
\v 50 Jesús ji̱ta jatyiyada sa̱ñe̱ya̱jada, su̱mu̱rya̱da ji̱ta variñi̱ yintu.
\p 
\v 51 Mityamusiy ji̱ta rarotyeda Ju̱denu rorijyu̱ mutanujay jache, na̱vachiy mucomuju̱, ¡siyooo! mucadi jarye santaya̱jada variy, riryuvayada ji̱ta ravichu̱viñusuma risa̱ju̱.
\v 52 Ramutteda ji̱ta bapyo, rimyi̱sa̱subeda ji̱ta rajuuvay Ju̱denu siityari̱vabe, jiryatiy diibyimiy riñi̱cha̱da bapyovimu.
\v 53 Richipyateda ji̱ta bapyovimusiy variy. Jesús mi̱sa̱divasiy, rijeyada ji̱ta vicha̱damu, ridyityadoda variy rajuuyu.
\v 54 Su̱tarumiy nutyityu̱bay ji̱ta, sisa̱ jnu̱tyavabetya, ru̱nu̱yadanumatirya mucadi santaya̱jada, ti̱ta̱ju̱ jiryatiy ravicha̱da risa̱ju̱ variy, ru̱nteda jaryi variy ranchiy, ru̱teda ji̱ta: “¡Si̱tenuni̱te Ju̱denu denu sani̱cha jiñu, si̱tenu!”
\p 
\v 55 Rivyicha̱da ji̱ta rajuuvay vatube jasintyi, ru̱nu̱yada ripyapusiy sana̱cho̱. Richiityari̱nu̱yadani̱ Jesús Cadidéyamusiy jiryatiy ru̱mu̱tyatityiñu̱yadani̱.
\v 56 Rityevay rañi̱cha̱da Maríya Mardánamusi̱bay, jadchintyi da Maríyaju̱bentyi, jiryatiy nanuvicha̱da Santiyácuju̱be jno̱dabay, Sebedévubay denuju̱be jno̱dabay jarye risa̱ju̱ nada.
\s1 Jesús jmuchusa̱danchiy
\r (Márcu 15.42-47; Dúcasiy 23.50-56; Juán 19.38-42)
\p 
\v 57 Ravicha̱danumatiy jidye, su̱deda ji̱ta jaryi tarati̱ nijya̱mi̱ Arimatéyamusi̱, Jusíy jtyati̱bay. Ni̱ni̱ vichanu̱yada Jesús siityari̱nuntiy.
\v 58 Siti̱jada ji̱ta Pyidátubamyu, sava̱ta̱da variy sivara Jesús babyi. Su̱pa̱jada ji̱ta Pyidátubay variryi: “Jirya̱sa̱y ni̱ra sababyi.”
\v 59 Su̱toda ji̱ta Jusíbe varirya sababyi, sarayada ji̱ta samiy sujajyuutara.
\v 60 Sajachunuvejada ji̱ta jibepyovimu varirya sababyi, jiryatiy ravichu̱nube jmuchura vadi vudira sabapyo vudi day. Sasiichudoda ji̱tani̱ ja̱mi̱ ravichu̱ bapyo vudimuju̱, saya̱da variy jadchiy.
\v 61 Jasidye ji̱ta nanuvicha̱da ma̱sanu̱y Maríya Mardánamusi̱bay, ratarya Maríyaju̱betya, bapyosá̱rá̱.
\s1 Judíyuvedabay jnu̱tyatadedara Jesús bapyo
\p 
\v 62 Judíyuvedabay jdutya̱da runda bivadeju̱, riintye̱ryadeda caserdótevyeda nutyityu̱mibe Varyisévuvedabatya Pyidátubamyuyu.
\v 63 Ru̱teda ji̱ta variy siva: “Nu̱dyivi̱ yimu, Nutyityu̱, nu̱jechipitya daryaju̱ra jiryatiy jnu̱ñutidye sani̱chanu̱tyi jiñu quivu̱ryabay, sani jteda: Mumurundamimyusiy ra̱mi̱santiy.
\v 64 Ramuni̱tiy ya̱jpa̱ jnu̱tyi̱si̱ju̱ sabapyomu, rurundasa̱ra̱ju̱, riñuma jiya sisa̱ datyavay paranuvay, sababyi sipyata̱dana̱cho̱, riryi jtay ruuva nijya̱nvay: Sami̱sa̱simya̱ diibyimusiy. Daryamusiy raryicha tamitya quivu̱choda, jaryi ramusiy munatya saquivu̱choda.”
\v 65 Su̱teda ji̱ta Pyidátubay variy ruuva: “Jasinryi su̱nu̱tyavay su̱tarumiy, jirya̱numa jdutyanuve darya jiryetyi datyara.”
\v 66 Riya̱da ji̱ta variy, ru̱dutyanuvejada samiy varirya bapyo, jiryatiy ribeyada nu̱chara vatatu saniy ravichu̱, ribeyada ji̱ta variryi jnu̱tyavabe jasintyi.
\c 28
\s1 Jesús mi̱sa̱danchiy
\r (Márcu 16.1-8; Dúcasiy 24.1-12; Juán 20.1-10)
\p 
\v 1 Jiituyada rundavasiy, Tumyícyurunda jasacharu̱ryamu, su̱deda ji̱ta Maríya Mardánamusi̱bay ratarya Maríyaju̱betya, nana̱tidye jnu̱rya bapyo variy.
\v 2 Mityamusiñi̱day ravicha̱da muco sityeya̱jada jaryi variy, tapitya su̱musa̱da Ju̱denu jpa̱nu jarichumusiy, sasiichununuvi̱jadani̱ ravichu̱ bapyo vudiju̱musiy, sama̱sa̱da ji̱ta variy sancha.
\v 3 Sadanu̱yada ji̱ta nu̱tyu ra̱duya̱ra nijya̱nvay diya, sasujay ji̱ta vicha̱da jaryi pupajay, vandajay risa̱ju̱ra.
\v 4 Richuvu̱yadamu ji̱ta rityutoja̱jada jnu̱tyavabe variy, rime̱cho̱jada vadiiryo̱ ru̱ve variy.
\v 5 Su̱teda ji̱ta Ju̱denu jpa̱nu variy nadiva vaturaju̱bentyi: “Ne sa̱na̱suvu̱y, radyetya daryaju̱ sa̱dava̱ta sana̱cho̱ Jesús, jiryatiy ru̱vaje crusitya̱sani̱.
\v 6 Nu̱tyu sani mi̱sa̱simya̱, tama̱ ti̱jna̱y rañi̱cha jiyunu̱day, tama̱. Varenunumacu̱. Sa̱na̱jnu̱ñuvi̱ra satiryo̱jo.
\v 7 Varenuva̱ju̱ sa̱na̱tu̱chunuve ruuva sisa̱ datyavay: Sami̱sa̱simya̱ diibyimusiy, ni̱ni̱ ra̱jiya jirya̱jisiy Cadidéyamuju̱. Jasiñuma jirya̱diy siva day. Ri̱tamya̱ sa̱divara.”
\v 8 Nadaya̱da ji̱ta vani̱radera bapyomusiy, nanusuvu̱yadamu, nani̱chana̱yadamu jarye risa̱ju̱. Nanusiicheda ji̱ta variy tu̱chunu̱jyu̱y sisa̱ datyavavyedabamyuju̱ day.
\v 9 Mityamusiñi̱day sasaryejada Jesús nada, samu̱chuveda ji̱ta jasiy variñada. Nanutuudiyada ji̱ta vaturaju̱beñi̱, nadireda varirya sanumutu, nana̱dasidyoda variy sana̱cho̱ju̱yu.
\v 10 Jadchiy ji̱ta su̱teda Jesús nadiva: “Ne sa̱na̱suvu̱y, sa̱na̱numa tu̱chu ruuva ratyeryi̱veda: Jirye̱jiya Cadidéyamuju̱, mu̱ñuma rirya̱jnu̱ñuve ray.”
\s1 Bapyo jnu̱tyavabe tu̱choda
\p 
\v 11 Varidye nadaya̱da niya̱re, ru̱deda ji̱ta jnu̱tyavay tevabe ja̱mu vicha̱damu, rityu̱chunuvejada ruuva caserdótevyeda nutyityu̱miberya ti̱ta̱ju̱ daryatiy ravicha̱da.
\v 12-13 Riintye̱ryadedanumatiy caserdótevyedabay, nijya̱nvay rimyityumibetyayu, riñiquetta̱da ji̱ta variyu. Riche̱yada ji̱ta ja̱viñu criquiryi su̱tarumibe, rirya̱tidye jtay: “Ru̱desiy ji̱ta sisa̱ datyavay nupora, jasiy ripyaradosiy nu̱me̱yara Jesús babyi.”
\v 14 Ru̱teda caserdótevyedabay ruuva su̱tarumibentyi: “Saryityi tu̱chuta ti̱ japumu jirye, nu̱ña̱sabonidyeñi̱ japu day, jirya̱tidye ma̱cho̱ jachipiya̱sa̱miy riva.”
\v 15 Ru̱mutya̱jada ji̱ta su̱tarumiberya criquiy variy, rivyicha̱da ji̱ta daryá, jiryatiy ridyetyadoda caserdótevyeda nutyityu̱mibe darya riy. Ramutiy ra̱ticheyada Judíyuvedamu diyesa̱ra̱ju̱ riñiquejada.
\s1 Su̱pa̱jada Jesús tu̱chuvaryi yisa̱ datyavavyedabay
\r (Márcu 16.14-18; Dúcasiy 24.36-49; Juán 20.19-23; Jvaayada 1.6-8)
\p 
\v 16 Vu̱yaju̱y sisa̱ datyavavyedabay ji̱ta, ti̱qui rinchaju̱, rañi jiya̱da variy Cadidéyamuju̱, ja̱mumusimyu, jiryatiy sadityadoda Jesús rana̱cho̱ ji̱tyaju̱ riy.
\v 17 Ridyiyadanumatiy siva, rirya̱dasidyoda ji̱ta variy sana̱cho̱ju̱yu, ti̱ni̱ jachipiya̱jada day: “¿Si̱tenuni̱viy sani̱cha?”
\v 18 Satuudiyadanumatiy Jesús riy, saniquejada variy ruuva: “Sasa̱mya̱ Ju̱denu jarichu nusu̱yadaju̱ ray, mucadi nusu̱yadaju̱ jarye ti̱ta̱ju̱.
\v 19 Ramuni̱tiy jirya̱rupiñumaya̱ datyanuvay ti̱ta̱ju̱ nijya̱nvamyu, rirya̱tidye vicha̱siy rachiityari̱vay. Jirya̱ji̱tyanutaniy variy Ju̱denu jtyamu riy, Sadenu jtyamu jarye, Su̱ntu jtyamu jarye risa̱ju̱.
\v 20 Jirya̱datyanunumaya̱ rirya ti̱ta̱ju̱ jiryatiy ri̱teda darya jiryiva. Ne jiryi̱nu̱y, ray rañi̱cha jiryisa̱ ti̱ta̱ju̱ rundamu, ravyichasara jiryisa̱; rito̱tadeda rundasa̱ra̱ju̱ rañi̱cha jiryisa̱.”
