\id PSA .01, Psalms 1, Motu, PNG, RTWP 9/92 
\h SALAMO 
\toc1 SALAMO 
\toc2 SALAMO 
\mt1 SALAMO  
\c 1  
\q1
\v 1 Taunimanima binai vada e namo:  
\q2 ia na kara dika taudia edia henega sela,  
\q1 kara kerere-kerere taudia edia dala ai se gini,  
\q2 hevaseha taudia edia helai gabudia ai se helai;   
\q1
\v 2 A Iehova ena taravatu ia ese e moalelaiamu,  
\q2 ena taravatu e laloa boimu, e laloa ranimu.   
\q1
\v 3 Ia na sinavai isena ai e hadoa auna na heto:  
\q2 ena huahua negana ai ia anina do baine dobi,  
\q1 ia rauna danu do basine marai,  
\q1 ḡau idoidiai ia baine kara be anidia do bae vara ḡoevaḡoeva.   
\b  
\q1
\v 4 Kara dika taudia na dia unuheto:  
\q2 idia na uit momodia na heheto,  
\q2 lai ese e oda ohomu.   
\q1
\v 5 Taunabunai kara dika taudia na  
\q2 hahemaoro negana ai do basie gini,  
\q1 kara kerere-kerere taudia danu  
\q2 kara maoromaoro hebouna ai do basie gini.   
\q1
\v 6 Badina be Iehova na kara maoromaoro taudia  
\q2 edia dala dibana;  
\q1 A kara dika taudia,  
\q2 edia dala do baine doko.   
\c 2  
\q1
\v 1 Badina be dahaka lalo-dibura taudia na e heloḡo-heloḡomu?  
\q2 Badina be dahaka taunimanima edia lalo-hadai na kavakava?   
\q1
\v 2 Tanobada pavapavadia e gini toremu,  
\q2 bona lohia taudia na e henega boumu;  
\q1 Iehova bona ia ese e horoa tauna na  
\q2 idia ese e inai henidiamu.  
\q1 Idia na e tomu:   
\q1
\v 3 Edia gadea baita hamotudia,  
\q2 e ḡuilaida varodia baita negedia.   
\b  
\q1
\v 4 Guba ai e nohomu Diravana ese baine kirikirilaidia;  
\q2 Ḡaubada ese baine hevasehalaidia.   
\q1
\v 5 Ia ese baine gwau henidia mai baduna ida,  
\q2 ena badu-ḡaraḡara ese baine hahisihisidia.  
\q1 Baineto:   
\q2
\v 6 Egu pavapava vada na atoa,  
\q2 egu ororo Siona dorina ai.   
\b  
\q1
\v 7 Iehova ena hereva baina harorolaia,  
\q2 ia ese vada e hadibagu heḡereḡerena, eto:  
\q1 Oi na lau natugu,  
\q2 hari dina ai vada na havaramu.   
\q1
\v 8 Ba noigu, bena bese idau-idau baina henimu, oi ahumu,  
\q2 tanobada dokodia do baina henimu, emu.   
\q1
\v 9 Auri itotohina amo ba hamakohidia,  
\q2 uro na heto ba huaridia.   
\b  
\q1
\v 10 Pavapava e, ba aonega;  
\q2 tanobada lohiamui e, ba diba.   
\q1
\v 11 Iehova ba toma henia diho mai garimui,  
\q2 bona mai heude-heudemui ida.   
\q1
\v 12 Ia aena palapaladia ba harahudia,  
\q2 baine badu henimui bena dala ai ba mase na garina;  
\q1 badina be ena badu e vara haraḡamu.  
\b  
\q1 Ia e abidadama heniamu taudia be nanamo.   
\c 3  
\p
\v 1 Iehova e, e inai henigumu taudia na ede hohodia!  
\q2 E tuari henigumu taudia na hutuma.   
\q1
\v 2 Hutuma herea ese lau e herevalaigumu,  
\q2 etomu, Dirava ese se kahaiamu. (Selah)   
\q1
\v 3 Iehova, e, o ḡeḡegu ahumu, egu kesi ai o laomu;  
\q2 oi na egu diari, lau kwaragu o abia isimu.   
\b  
\q1
\v 4 Iehova na boi heniamu,  
\q2 bena ena ororo helaḡana amo e haere henigumu. (Selah)   
\q1
\v 5 Lau na hekure, na mahuta, ma na noga;  
\q2 badina be Iehova na egu imuda.   
\q1
\v 6 Taunimanima gerebu gerebu basina gari henidia;  
\q2 e ḡeḡegu ahumu bona e tuari henigumu taudia na garidia basina gari.   
\b  
\q1
\v 7 Iehova e, a tore isi!  
\q2 Egu Dirava e, a hamaurigu!  
\q1 Badina be inaigu iboudiai na vahadia vada o patadia,  
\q2 kara dika taudia danu isedia vada o hakwaidudia.   
\q1
\v 8 Hahemauri na Iehova ena amo e maimu;  
\q2 emu hahenamo na emu orea taudia latadiai e miamu. (Selah)   
\c 4  
\q1
\v 1 Egu kara maoromaoro Diravana e!  
\q2 Na boi henimumu negadia ai na ba haere henigu.  
\q1 Egu dika amo vada o ruhagu nege;  
\q2 A bogagu hisi, egu noinoi a kamonai.   
\b  
\q1
\v 2 Taunimanima e, umui ese lau namogu na hemarai ai ba halaoa ela bona edena nega ai?  
\q1 Hereva kavakavadia ba ura henidia bona hereva koikoidia ba tahudia  
\q2 ela bona edena nega ai? (Selah)   
\q1
\v 3 Ba diba, Iehova ese ia ibadinana tauna na vada e abia hidi;  
\q2 Iehova na boi heniamu negadia ai na ia ese e kamonai henigumu.   
\b  
\q1
\v 4 Ba hemataurai, basio kara dika;  
\q2 sibomu lalomu ba tahua emu mahuta gabuna ai,  
\q2 a basio hereva. (Selah)   
\q1
\v 5 Kara maoromaoro bouboudia ba hahelaḡadia,  
\q2 bona Iehova bavabidadama henia.   
\q1
\v 6 Hutuma na e tomu, Daika ese baine hanamomai?  
\q2 Iehova e, oi vairamu diarina bavabia isi ai emai ai.   
\b  
\q1
\v 7 Lau lalogu vada o hamoalea;  
\q2 egu moale ese edia uit bona edia vine ranuna e habadamu taudia edia moale na e hereaiamu.   
\q1
\v 8 Mai mainogu ida baina hekure bona baina mahuta,  
\q2 Iehova e, badina be oi mo sibomu ese o gimagumu.   
\c 5  
\q1
\v 1 Iehova e, egu hereva a hakala henidia;  
\q2 egu ḡanaḡana a kamonai.   
\q1
\v 2 Egu Pavapava bona egu Dirava e, egu taitai a kamonai,  
\q2 badina be oi na tai henimumu.   
\q1
\v 3 Iehova e, daba ai lau gadogu o kamonaimu;  
\q2 daba ai na toma henimu dihomu, bona na hegimamu.   
\b  
\q1
\v 4 Badina be oi na dia kara dika imoalelaina Diravana;  
\q2 oi dekemu ai dika ta se miamu.   
\q1
\v 5 Hekokoroku taudia na oi vairamu ai basie gini;  
\q2 kara dika taudia iboudiai o inai henidiamu.   
\q1
\v 6 Koikoi taudia o habuadia tarimu;  
\q2 Iehova ese ala-ala taudia bona koikoi taudia e inai henidiamu.   
\q1
\v 7 A lau be emu ruma lalonai baina raka vareai,  
\q2 emu hebogahisi bada-herea bagunai;  
\q1 emu dubu helaḡana baina haḡerea, baina toma diho;  
\q2 oi baina gari henimu.   
\q1
\v 8 Iehova e, emu kara maoromaoro ai ba hakaugu,  
\q2 lau inaigu daidiai;  
\q1 Emu dala ba hamaoromaoroa  
\q2 lau vairagu ai.   
\b  
\q1
\v 9 Badina be asi hereva momokanina ta idia ududia ai;  
\q2 lalodia na kara dika ai eme honu honu dae,  
\q1 gadodia na gara na heto,  
\q2 maladia na e hereva manada-manada koikoimu.   
\q1
\v 10 Dirava e, edia dika davadia ba henidia;  
\q2 edia lalo-hadai dikadia ese bae hahekwakwanaidia;  
\q1 edia kara dikadia momo daidiai ba negedia daure;  
\q2 badina be idia ese oi vada e gwau tubu henimu.   
\b  
\q1
\v 11 Oi e abidadama henimumu taudia na bae moale,  
\q2 bae moale hisi dae ela bona hanaihanai,  
\q1 oi ese o gimadiamu dainai;  
\q2 oi ladamu e ura heniamu taudia ese bae moalelaimu.   
\q1
\v 12 Badina be oi ese kara maoromaoro tauna o hanamoamu;  
\q2 Iehova e, emu harihari-bada amo o gimaiamu, kesi na heto.   
\c 6  
\q1
\v 1 Iehova e, emu badu ai basio gwau henigu,  
\q2 emu badu ḡaragarana ai basio hahisigu.   
\q1
\v 2 Iehova e, a bogagu hisi, badina be na manokamu;  
\q2 Iehova e, a hamaurigu, badina be turiagu e hisihisimu.   
\q1
\v 3 Laumagu danu e hisihisi badamu;  
\q2 Iehova e, ela bona edena nega?   
\b  
\q1
\v 4 Iehova e, a gini kerehai, lau laumagu ba hamauria,  
\q2 emu hebogahisi dainai ba hamaurigu;   
\q1
\v 5 badina be mase ai tau ta ese basine lalomu tao;  
\q2 mase taudia edia gabu ai daika ese baine imodaimu?   
\b  
\q1
\v 6 Ḡanaḡana ai na hesikumu,  
\q2 hanuaboi iboudiai egu mahuta gabuna ai na tai noho  
\q2 egu mahuta gedana na iruru-matagu ai e pariparumu.   
\q1
\v 7 Matagu na e valahu-valahumu, egu lalo-hisihisi dainai,  
\q2 egu roharoha e manokamu, inaigu loḡora iboudiai daidiai.   
\q1
\v 8 Kara havara taumui iboumui ai, egu amo a raka oho,  
\q2 badina be Iehova ese egu taitai reḡena vada e kamonai.   
\q1
\v 9 Iehova ese egu noinoi vada e kamonai,  
\q2 Iehova ese egu ḡuriḡuri e abia daemu.   
\q1
\v 10 Lau inaigu iboudiai bae hemarai, lalodia na bae hekwarahi.  
\q2 idia na bae raka kerehai, hemarai ese baine abidia haraḡa.   
\c 7  
\q1
\v 1 Iehova e, egu Dirava, lau oi na abidadama henimumu;  
\q2 e havagumu taudia edia amo ba harohogu mauri, ba hamaurigu   
\q1
\v 2 leona na heto bae daregu na garina,  
\q2 asi ihamaurigu bae verigu oho na garina.   
\b  
\q1
\v 3 Iehova e, egu Dirava, ini bama kara toma,  
\q2 eiava imagu bema kerere,   
\q1
\v 4 eiava turagu bama kara dika henia,  
\q2 eiava inaigu ena ḡau bama dadi kava.   
\q1
\v 5 Inaigu ese baine havagu ela bona baine lasigu tao,  
\q2 egu mauri na tano ai baine moia tao,  
\q2 bona laumagu na ḡahu ai baine moimoilaia.   
\q1
\v 6 Iehova e, mai badumu ida a tore isi,  
\q2 lau inaigu edia badu ba laoa ahu totona a tore isi;  
\q1 Egu Durava e, a noga,  
\q2 hahemaoro vada o haheḡanilaia.   
\q1
\v 7 Bese idau-idau edia hegogo ese baine ḡeḡemu ahu;  
\q2 atai ai ba helai, idia daediai.   
\q1
\v 8 Iehova ese bese idau-idau e hahemaoro henidiamu:  
\q2 Iehova e, egu kara maoromaoro bona egu lalo-ḡoevaḡoeva heḡereḡeredia ba hahemaoro henigu.   
\b  
\q1
\v 9 Kara havara taudia edia dika ba hadokoa,  
\q2 a kara maoromaoro taudia do ba haginidia;  
\q1 badina be oi na kara maoromaoro Diravana,  
\q2 taunimanima daradia bona lalodia o dibadiamu.   
\q1
\v 10 Dirava na egu kesi,  
\q2 ia ese laloḡoevaḡoeva taudia e hamauridiamu.   
\q1
\v 11 Dirava na hahemaoro tauna, mai ena kara maoromaoro;  
\q2 dina iboudiai Dirava ese kara dika e badu heniamu.   
\q1
\v 12 Tau ta basine helalo kerehai,  
\q2 Dirava ese ena dare baine segea.  
\q1 Ena peva vada e beua, vada e rohea,   
\q2
\v 13 ena ala-ala ḡaudia vada e abi heḡaeḡae,  
\q2 ena diba na lahi dibadia ai e halaodiamu.   
\q1
\v 14 A itaia, kara havara tauna ese dika e havaraiamu,  
\q2 kara dika ai e rogorogomu,  
\q2 koikoi daladia e havaramu.   
\q1
\v 15 Ia ese guri e ḡeia dobumu,  
\q2 bena e ḡeia gurina lalonai e moru dobimu.   
\q1
\v 16 Ena kara dika na sibona kwarana ai ma e kaumu,  
\q2 ena daḡedaḡe na sibona tubuana ai e dihomu.   
\b  
\q1
\v 17 Iehova baina hanamoa, ena kara maoromaoro dainai,  
\q2 Iehova, atai doriva-doriva Diravana, ladana baina imodaia.   
\c 8  
\q1
\v 1 Iehova e, ai emai Lohiabada,  
\q2 tanobada idoinai oi ladamu vada e namo herea,  
\q2 oi hairaimu na guba ai vada o atoa.   
\b  
\q1
\v 2 Natudia karukarudia, rata e inumu memerodia, ududia amo  
\q2 goada vada o hadaia, e inai henimumu taudia daidiai;  
\q1 inai tauna bona dika davana ma e haloua tauna  
\q2 oi ese ba hatuidia totona.   
\b  
\q1
\v 3 Emu guba name itaia, oi imamu kwakikwakidia ese e karaia,  
\q2 hua bona hisiu danu oi ese o atodia:   
\q1
\v 4 Taunimanima be dahaka oi ese o laloamu?  
\q2 taunimanima natuna be daika oi ese o igoa itamu?   
\q1
\v 5 Vada o karaia, Dirava ese sisina mo ia e hereaiamu;  
\q2 hairai bona hemataurai ia kwarana vada o havavalaia,   
\q1
\v 6 Oi imamu amo o kara ḡaudia iboudiai vada o henia, baine biagudia,  
\q2 ḡau iboudiai ia aena henudiai vada o atodia:   
\q1
\v 7 mamoe bona boromakau iboudiai,  
\q2 uda boromadia danu,   
\q1
\v 8 atai manudia bona davara gwarumedia,  
\q2 bona gadobada daladia ai e loamu ḡaudia iboudiai.   
\b  
\q1
\v 9 Iehova e, ai emai Lohiabada,  
\q2 tanobada idoinai oi ladamu vada e namo herea.   
\c 9  
\q1
\v 1 Iehova baina hanamoa mai lalogu idoinai:  
\q2 emu hoa karadia iboudiai baina herevalaidia.   
\q1
\v 2 Baina moale, oi baina imodaimu,  
\q2 oi ladamu ihanamolaina anena baina abia,  
\q2 Herea-Mikamika Diravana e!   
\q1
\v 3 Lau inaigu e raka kerehai negana ai,  
\q2 e hekwakwanai bona e mase oi vairamu ai.   
\q1
\v 4 Badina be egu dala maoromaorona vada o hamomokania,  
\q2 terono ai vada o helai, hahemaoro maoromaorona vada o karaia.   
\b  
\q1
\v 5 Bese idau-idau vada o gwau henidia,  
\q2 kara dika taudia vada o habuadia tari;  
\q2 ladadia vada o Ialodia nege ela bona hanaihanai.   
\q1
\v 6 Inai taudia vada e dika hanaihanai, vada e puki;  
\q2 edia hanua vada o raḡadia oho,  
\q2 ilalotaodia vada e boio.   
\b  
\q1
\v 7 A Iehova na terono ai e helai hanaihanaimu,  
\q2 ena terono vada e haginia, hahemaoro totona;   
\q1
\v 8 ia ese tanobada e hahemaoro heniamu mai maoromaorona ida,  
\q2 tanobada besedia e hahemaoro henidiamu mai maoromaorona ida.   
\b  
\q1
\v 9 Haida ese e daḡedaḡe henidiamu taudia edia kohoro na Iehova,  
\q2 ia na edia kohoro, dika negadia ai.   
\q1
\v 10 Oi ladamu dibadia taudia ese e abidadama henimumu,  
\q2 badina be, Iehova e, oi vada e tahumu taudia na asio rakatanidia.   
\b  
\q1
\v 11 Iehova, Siona ai e nohomu Diravana, ba imodaia!  
\q2 Iena kara na bese idau-idau bogaragidiai ba herevalaidia!   
\q1
\v 12 Badina be rara davana iabina Diravana ese e lalodiamu;  
\q2 haida ese e daḡedaḡe henidiamu taudia edia taitai na ia ese se laloa boiomu.   
\q1
\v 13 Iehova e, ba bogagu hisi!  
\q2 E inai henigumu taudia edia amo na abi hisidia na ba itadia,  
\q2 mase ikoukoudia amo o abigu isimu Diravana e!   
\q1
\v 14 Bena oi ihanamolaimu herevadia iboudiai baina gwaurai;  
\q2 Siona natuna kekenina ena ikoukou ai emu hahemauri baina moalelaia.   
\b  
\q1
\v 15 Bese idau-idau na sibodia e ḡei guridia lalodiai vada e moru dobi;  
\q2 sibodia e otoa huona ai aedia vada e headai,   
\q1
\v 16 Iehova na sibona e hahedinarai, hahemaoro vada e karaia;  
\q2 kara dika taudia na sibodia imadia karadia ai vada e heidoa. (Higgaion. Selah)   
\b  
\q1
\v 17 Kara dika taudia na mase taudia edia gabu baela;  
\q2 Dirava e laloa boiomu besedia iboudiai na unu baela.   
\q1
\v 18 Badina be e dabumu taudia na basine lalodia boio hanaihanai,  
\q2 bona ogoḡami taudia edia helaro na basine mase hanaihanai.   
\b  
\q1
\v 19 Iehova e, a tore isi! Taunimanima na basie kwalimu;  
\q2 bese idau-idau na oi vairamu ai bae hahemaoro henidia.   
\q1
\v 20 Iehova e, ba hagaridia!  
\q2 Bese idau-idau taudia bae diba idia na taunimanima mo. (Selah)   
\c 10  
\q1
\v 1 Iehova e, dahaka dainai oi na dauhai o ginimu?  
\q2 Dahaka dainai dika negadia ai o noho hehunimu?   
\q1
\v 2 Kara dika taudia ese ogoḡami taudia e hahisihisidiamu mai hekokorokudia ida;  
\q2 sibodia edia lalo-hadai dikadia ai bae heidoa.   
\q1
\v 3 Badina be kara dika tauna ese sibona ena ura e heagilaiamu,  
\q2 bona mata-ḡaniḡani tauna ese Iehova e uduguiraiamu bona e dadaraiamu.   
\q1
\v 4 Kara dika tauna vairana hekokorokuna ai ia se tahuamu;  
\q2 ena lalo-hadai idoinai be Dirava na lasi.   
\b  
\q1
\v 5 Nega idoidiai ena dala na auka;  
\q2 oiemu hahemaoro na atai ai, ia na se itamu;  
\q2 ia inaina iboudiai e pururudiamu.   
\q1
\v 6 Lalona e hadaiamu, e tomu “Basina marere-marere,  
\q2 uru iboudiai lalodiai basina dika”.   
\b  
\q1
\v 7 Uduna na heuduguirai bona koikoi bona daḡedaḡe eme honu honu dae,  
\q2 malana henunai kara havara bona kara dika na mimia.   
\q1
\v 8 Hanua lalodiai e bani taomu,  
\q2 gabu hehunidia ai asi edia kerere taudia e aladia masemu.   
\b  
\q1
\v 9 Ia matana ese manoka-manoka taudia e hasinadodiamu;  
\q2 ia na komu gabuna ai e banimu, leona ese ena kohua ai e banimu na heto;  
\q1 ogoḡami tauna e bani heniamu, baine dabaia tao totona;  
\q2 ena huo ai e koia vareaimu, bena e dabaia taomu.   
\b  
\q1
\v 10 Manoka-manoka tauna e hapataia tarimu, e moru dihomu,  
\q2 kara dika tauna ena goada ese e hamoruamu.   
\q1
\v 11 Kara dika tauna na lalona e hadaiamu, e tomu  
\q2 “Dirava vada e helalo boio;  
\q2 vairana vada e hamuea, egu kara dika basine itaia”.   
\q1
\v 12 Iehova e, a tore isi! Dirava e, imamu a duduia isi!  
\q2 Hisi e animu taudia na basio lalodia boio.   
\q1
\v 13 Badina be dahaka kara dika tauna ese Dirava e dadaraiamu?  
\q2 Dahaka dainai lalona e hadaiamu, e tomu “Anina basio tahua”?   
\q1
\v 14 Hekwarahi bona hisihisi vada o itaia, oibe, vada o haeroa,  
\q2 oi imamu ai bavabia totona;  
\q1 manoka-manoka tauna ese oiemu ai e taomu;  
\q2 oi ese ihareha o kahadiamu.   
\b  
\q1
\v 15 Kara havara bona kara dika tauna imana na ba hakwaidua;  
\q2 ena dika ba tahua ela bona ta basio davaria.   
\q1
\v 16 Iehova baine pavapava hanaihanai;  
\q2 bese idau-idau na iena tano amo bae ore.   
\b  
\q1
\v 17 Iehova e, manau taudia edia noinoi ba kamonai, ani;  
\q2 Ialodia ba hagoadadia, bona ba hakala henidia,   
\q1
\v 18 ihareha bona hisihisi taudia ba kara maoromaoro henidia totona;  
\q2 unu amo tanobada tauna na hahegari karadia basine kara lou.   
\c 11  
\q1
\v 1 Iehova na abidadama heniamu; dahaka dainai o hamaorogumu, o tomu  
\q2 “Ororo ba roho henia, manu na heto;   
\q1
\v 2 a itaia, kara dika taudia na peva e rohemu,  
\q1 edia diba na maora ai e adaimu,  
\q2 lalo-ḡoevaḡoeva taudia na dibura ai bae tarakidia totona;   
\q1
\v 3 badidia bema habua tari, kara maoromaoro taudia na ede bae kara toma?”   
\b  
\q1
\v 4 Iehova na ena dubu helaḡana ai e nohomu,  
\q2 Iehova ena terono na guba ai mia;  
\q1 ia matana ese taunimanima natudia e nenediamu,  
\q2 ia matana kopidia ese e dibadiamu.   
\b  
\q1
\v 5 Iehova ese kara maoromaoro taudia bona kara dika taudia e dibadiamu;  
\q2 ia laumana ese daḡedaḡe karadia e ura henimu tauna na e inai heniamu.   
\q1
\v 6 Ia ese lahi gidadia bona teio\f + \fr 11:6 \ft Teio: Nadi ta ladana, Helene gado ai. E aramu, bena bonana dika-hereana e daemu, taunimanima e hamasediamu. Ladana English gado ai na “sulphur”.\f* na kara dika taudia latadiai baine ḡiḡi dobi;  
\q2 lai siahuna na edia kehere anina ai bainela.   
\q1
\v 7 Badina be Iehova na maoromaoro, bona kara maoromaorodia ia ese e ura henidiamu;  
\q2 kara maoromaoro taudia ese ia vairana bae itaia.   
\c 12  
\q1
\v 1 Iehova e, a kahamai! Badina be Dirava imatauraina taudia vada e ore;  
\q2 kamonai taudia na taunimanima natudia bogaragidia amo vada e puki oho.   
\q1
\v 2 Iboudiai na dekedia taudia e koidiamu;  
\q2 bibinadia na hereva manada-manadadia amo e koikoimu,  
\q2 bona lalo-rua amo e herevamu.   
\b  
\q1
\v 3 Bibinadia amo hereva manada-manadadia koikoidia  
\q2 bona maladia amo hekokoroku herevadia e gwauraimu taudia na Iehova ese bema negedia daure be namo.   
\q1
\v 4 Badina be idia na e tomu  
\q2 “Malada amo baita kwalimu, bibinada na siboda eda;  
\q2 ita biaguda be daika?”   
\b  
\q1
\v 5 Iehova na e tomu  
\q2 “Ogoḡami tauna ena ḡau e dadihaimu dainai,  
\q2 bona asi ena tauna e ḡanaḡanamu dainai,  
\q2 lau na baina tore-isi,  
\q2 e ura heniamu mauri-gabuna ai baina atoa”.   
\q1
\v 6 Iehova ena gwauhamata na gwauhamata ḡoeva-daedia,  
\q2 \it silver\it* na tano ai ihavevelaina lahina ai nega hahitu e haḡoevaiamu na heto.   
\q1
\v 7 Iehova e, oi ese ba gimamai,  
\q2 ina uru amo ba gimamai hanaihanai.   
\q1
\v 8 Kaha iboudiai kara dika taudia na e hetahu loaloamu;  
\q2 kara havara na taunimanima natudia bogaragidiai e imodaimu.   
\c 13  
\q1
\v 1 Iehova e, ela bona edena nega ai?  
\q2 Ba lalogu boio ela bona hanaihanai a?  
\q1 Vairamu na egu amo ba hamuea ela bona edena nega ai?   
\q2
\v 2 Daragu baine doko ela bona edena nega ai?  
\q1 Lalogu na dina idoinai baine hisihisi a?  
\q2 Lau inaigu baine hereagu ela bona edena nega ai?   
\b  
\q1
\v 3 Iehova e, egu Dirava, ba haeroa bona ba haere henigu;  
\q2 matagu ba hadiaridia, mase ena mahuta ai baina mahuta na garina,   
\q1
\v 4 inaigu na baineto “Vada na hadarerea” na garina,  
\q2 bona na manokamu dainai e inai henigumu taudia bae moale na garina.   
\b  
\q1
\v 5 A lau na emu hebogahisi vada na abidadama henia;  
\q2 lau lalogu ese emu hahemauri baine moalelaia.   
\q1
\v 6 Ane baina abia, Iehova ena;  
\q2 badina be ia ese ena harihari-bada ai vada e hanamogu.   
\c 14  
\q1
\v 1 Kavakava tauna ese lalona e hadaiamu, e tomu  
\q1 “Dirava na lasi”.  
\q2 Idia na didika, kara mirodia vada e kara;  
\q1 asi tauna ta ese kara namodia e karamu.   
\b  
\q1
\v 2 Iehova na guba amo e roha dobimu,  
\q2 taunimanima natudia e nenediamu;  
\q1 baine itadia, ta e kara aonegamu eiava,  
\q2 ta ese Dirava e tahuamu eiava.   
\q1
\v 3 Iboudiai vada e raka boioboio, iboudiai na didika;  
\q2 ta se kara namomu, lasi ona lasi vaitani.   
\b  
\q1
\v 4 Hari kara dika taudia,  
\q2 hari egu bese taudia e anidiamu flaoa e animu heḡereḡerena  
\q2 bona Iehova ladana asie hahaneamu taudia na  
\q1 asi aonegadia a?   
\b  
\q1
\v 5 Gari bada ese baine butudia tao,  
\q2 badina be Dirava na kara maoromaoro taudia edia uru ida e nohomu.   
\q1
\v 6 Ogoḡami tauna ena lalo-hadai vada o hahemaraidia,  
\q2 a Iehova na iena maḡu.   
\b  
\q1
\v 7 Israel ihamaurina na Siona amo bainema be namo!  
\q1 Iehova ese ena bese taudia baine ruhadia nege negana ai na  
\q2 Iakob baine moale,  
\q2 Israel baine moale hisi dae.   
\c 15  
\q1
\v 1 Iehova e, daika oiemu ḡuriḡuri kalagana ai baine noho?  
\q2 Daika na oiemu ororo helaḡana ai baine taruha?   
\b  
\q1
\v 2 Taunimanima binai: e raka ḡoevaḡoevamu,  
\q2 kara maoromaoro e karamu,  
\q2 bona lalona amo hereva momokani e gwauraimu;   
\q1
\v 3 ia malana amo haida se hadikadiamu,  
\q2 turana ihadikana karana ta se karaiamu,  
\q2 bona dekena tauna ihadikana herevana ta se gwauraiamu;   
\q1
\v 4 kara gageva-gageva tauna na ia ese e ihi-ihiraiamu,  
\q2 a Iehova garina e garimu taudia na ia ese e hanamodiamu;  
\q1 ia sibona ihadikana gwauhamatana e gwauraiamu negana ai  
\q2 ma se idaumu;   
\q1
\v 5 ia ese ena moni se heni torehaimu davana iabina totona,  
\q2 bona asi ena kerere tauna ihadikana monina danu ia se abiamu.  
\q1 Unu e kara tomamu tauna na do basine marere ela bona hanaihanai.   
\c 16  
\q1
\v 1 Dirava e, a hamaurigu,  
\q2 badina be oi na abidadama henimumu.   
\q1
\v 2 Iehova na hereva heniamu, na tomu  
\q2 “Oi na egu Ḡaubada, asi egu namo idauna ta,  
\q2 egu namo na oi mo emu ai”.   
\b  
\q1
\v 3 Tanobada ena helaḡa taudia na heherea-dadae,  
\q2 lau ese na moalelaidiamu.   
\q1
\v 4 Dirava idauna e abia hidimu taudia ese edia lalo-hisihisi e habadaiamu;  
\q2 edia inuinu bouboudia na rara, a lau be basina sei nege,  
\q2 ladadia na udugu bibinadia amo basina gwaurai.   
\b  
\q1
\v 5 Iehova vada na abia hidi, lau ahugu bona lauegu kehere;  
\q2 oi ese lau ahugu o gimaiamu.   
\q1
\v 6 Egu dala na gabu namodia amo e laomu;  
\q2 oibe, lau ahugu na namo herea.   
\b  
\q1
\v 7 Iehova na hanamoamu, ia ese e hahealo henigumu;  
\q2 hanuaboi lalonai lau lalogu ese e hadibagumu.   
\q1
\v 8 Iehova na vairagu ai na atoamu nega idoinai;  
\q2 badina be ia na lau idibagu kahana ai dainai lau na basina marere.   
\b  
\q1
\v 9 Taunabunai, lalogu na e moalemu, bona laumagu na e hisi daemu;  
\q2 tau-anigu danu e noho namonamomu.   
\q1
\v 10 Badina be oi ese basio kahugu nege, mase taudia edia gabu ai;  
\q2 e matauraimumu tauna na guri basio haheitalaia.   
\b  
\q1
\v 11 Mauri dalana oi ese o haheitalaigumu;  
\q2 oi vairamu ai moale e ḡuḡurumu,  
\q2 oi imamu idibana ai moale ḡaudia na e mia hanaihanaimu.   
\c 17  
\q1
\v 1 Iehova e, lalo-hadai maoromaorona a hakala henia; egu taitai a kamonai.  
\q2 Egu ḡuriḡuri a hakala henia, bibinagu asi koikoidia ese e gwauraiamu.   
\q1
\v 2 Ihahemaoro-henigu na oiemu amo bainema;  
\q2 oi matamu ese kara maoromaoro bae itaia.   
\b  
\q1
\v 3 Lalogu boma dibaia, hanuaboi ai boma vadivadi henigu,  
\q2 boma tohogu, a kara dika na lalogu ai basioma davaria;  
\q2 udugu na se kereremu.   
\q1
\v 4 Taunimanima edia ḡaukara lalodiai lau na daḡedaḡe taudia edia dala amo vada na raka siri,  
\q2 oi udumu bibinadia herevadia daidiai.   
\q1
\v 5 Oiemu dala ai vada na raka balaheni,  
\q2 lau aegu na asie dedi.   
\b  
\q1
\v 6 Dirava e, na boi henimumu, badina be oi ese ba haere henigu dainai;  
\q2 a hakala henigu, egu hereva ba kamonai.   
\q1
\v 7 Oi imamu idibana ai inaidia amo e roho maurimu taudia ihamauridia Taumu e,  
\q2 emu hebogahisi ba hahedinaraia, hoa ḡauna na heto.   
\b  
\q1
\v 8 A gimagu, ta ese matana nadinadina e gimaiamu na heto;  
\q2 oi hanimu ikerukerudia ai ba hunigu,   
\q1
\v 9 kara dika taudia, egu ḡau e dadihaimu taudia, edia amo,  
\q2 bona inaigu, e daigu heḡeḡemu taudia edia amo.   
\b  
\q1
\v 10 Lalodia e koudiamu, asi edia hebogahisi;  
\q2 ududia e kehodiamu, hekokoroku herevadia e gwauraimu.   
\q1
\v 11 Idia na e gavagu taomu, e daigu heḡeḡemu,  
\q2 e itagu taomu, tano ai bae tahogu dobi e tomu.   
\q1
\v 12 Idia na leona damuna idarena e ura lalodikamu na heto,  
\q2 leona natuna na komu gabuna ai e banimu na heto.   
\b  
\q1
\v 13 Iehova e, a tore isi! Ba tuari henidia, ba tahodia dobi!  
\q2 Emu dare bavabia, dika taudia edia amo ba hamaurigu;   
\q1
\v 14 Iehova e, oi imamu amo ba hamaurigu, taunimanima edia amo,  
\q2 tanobada ai mo edia mauri ahuna e abiamu taudia edia amo.  
\q1 Adia vada o abi heḡaeḡae ḡaudia amo bogadia ba hakunu;  
\q2 natudia bogadia bae kunu bona bahu baine mia;  
\q2 edia bahu baine mia, natudia karukarudia adia.   
\b  
\q1
\v 15 A lau be kara maoromaoro ai oi vairamu baina itaia;  
\q2 baina noga negana ai oi oromamu itana ai lalogu do baine namo.   
\c 18  
\q1
\v 1 Iehova e, egu goada, na lalokau henimumu!   
\b  
\q1
\v 2 Iehova na egu nadi-gini, egu maḡu, egu hahemauri tauna;  
\q2 egu Dirava, egu nadi-gini, na abidadama heniamu tauna;  
\q2 egu kesi, egu mauri doana, bona egu kohoro.   
\q1
\v 3 Iehova, e imodaiamu Diravana, na tai heniamu,  
\q2 bena inaigu edia amo e hamaurigumu.   
\b  
\q1
\v 4 Mase iḡuidia ese e ḡeḡegu ahuva,  
\q2 hahedika abatadia ese e hagariguva;   
\q1
\v 5 Mase Gabuna ena iḡui varodia ese e idoagu,  
\q2 mase huodia ida na tata hedavari.   
\b  
\q1
\v 6 Egu hisihisi ai Iehova na boi henia;  
\q2 egu Dirava na tai henia, baine durugu nato.  
\q1 Ena dubu ai lau gadogu e kamonai;  
\q2 egu taitai na ia taiana ai e kau.   
\b  
\q1
\v 7 Una negana ai tanobada e laga, e heude-heude,  
\q2 ororo badidia danu e heude-heude, e marere-marere,  
\q2 badina be ia vada e badu.   
\q1
\v 8 Kwalahu na ia uduna matudia amo e dae,  
\q2 Iahi siahuna na ia uduna amo e lasi,  
\q2 lahi hururu-hururudia na iena amo ema.   
\q1
\v 9 Guba e beua tari, bena e diho;  
\q2 dibura badana na ia aena henudiai.   
\b  
\q1
\v 10 Kerubi ai e gui, e roho lao;  
\q2 lai hanina amo e roho haraḡa-haraḡa.   
\q1
\v 11 Dibura na e hekoulaia,  
\q2 dagadaga dubana e hetarulaia.   
\q1
\v 12 Hururu-hururu na ia vairanai,  
\q2 unu amo medu-hetari bona lahi-hururuhururu na  
\q2 ena dagadaga amo e diho.   
\q1
\v 13 Iehova ese guba-rahua ai e hereva,  
\q2 Herea Mikamika na e gwau isi,  
\q2 bena medu-hetari bona lahi-hururuhururu na e diho.   
\q1
\v 14 Ena diba e kino, e hakarohodia;  
\q2 ena kevaru e hakevarua isi, e hadareredia.   
\q1
\v 15 Bena davara dobudobudia e heita,  
\q2 bona tanobada badidia e hedinarai,  
\q1 oi Iehova ese o gwau henidia negana ai,  
\q2 oi udumu matudia amo o hahodi lasi negana ai.   
\q1
\v 16 Atai amo e dau dobi, e abigu,  
\q2 ranu momo amo e verigu lasi.   
\q1
\v 17 Lau inaigu goadana ena amo e hamaurigu,  
\q2 e inai henigu taudia imadia amo e hamaurigu,  
\q2 badina be idia ese bema hadareregu diba.   
\q1
\v 18 Egu hisihisi dinana ai e davarigu,  
\q2 a Iehova na egu imuda.   
\q1
\v 19 Ia ese taora bada gabuna ai e hakaugu lasi;  
\q2 ia ese e hamaurigu, e moalelaigu dainai.   
\b  
\q1
\v 20 Iehova ese davagu vada e henigu, egu kara maoromaoro heḡereḡerena,  
\q2 vada e hanamogu, imagu edia ḡoevaḡoeva heḡereḡeredia.   
\q1
\v 21 Badina be Iehova ena dala vada na badinadia;  
\q2 lalo-hadai dikadia daidiai egu Dirava asina rakatania.   
\q1
\v 22 Badina be ena haheḡani iboudiai na lau vairagu ai;  
\q2 ena taravatu asina negedia daure.   
\q1
\v 23 Ia vairanai lau na asi egu kerere;  
\q2 kara dika amo na raka oho.   
\q1
\v 24 Taunabunai, Iehova ese vada e hanamogu, ena kara maoromaoro heḡereḡerena ai;  
\q2 imagu na ia vairanai vada e ḡoevaḡoeva heḡereḡerena vada e hanamogu.   
\b  
\q1
\v 25 Hebogahisi tauna oi ese o bogaia hisimu;  
\q2 kara maoromaoro tauna oi ese o kara maoromaoro heniamu.   
\q1
\v 26 Lalo-ḡoevaḡoeva tauna enai oi lalomu danu baine ḡoevaḡoeva;  
\q2 a kara gageva-gageva tauna enai oiemu kara danu bae gageva-gageva.   
\q1
\v 27 Badina be lalo-manau taudia na oi ese o hamauridiamu;  
\q2 a hekokoroku taudia na oi ese matadia o ha-igodia dihomu.   
\q1
\v 28 Momokani, oi ese egu lamepa o haraiamu;  
\q2 Iehova, egu Dirava, ese egu dibura e hadiariamu.   
\q1
\v 29 Momokani, oi bagumu ai orea badana baina hadarerea diba;  
\q2 egu Dirava bagunai maḡu ta baina rohoa hanai diba.   
\q1
\v 30 Ina Dirava ena dala na herea dae;  
\q2 Iehova ena gwauhamata vada e momokani;  
\q2 ia na e abidadama heniamu taudia edia kesi.   
\b  
\q1
\v 31 Dirava be daika? Iehova mo.  
\q2 Nadi-gini be daika? Iseda Dirava mo.   
\q1
\v 32 Ia na goada e hariolaigu Diravana;  
\q2 ia na egu dala e halailaia Diravana.   
\q1
\v 33 Ia ese lau aegu na dia aedia heḡereḡeredia ai e halaodia;  
\q2 ia ese atai gabudia ai e haginigu kau.   
\q1
\v 34 Ia ese lau imagu e hadibadiamu, tuari karadia ai,  
\q2 bena ima u na mai goadadia auri-laboralabora pevana baina marea.   
\q1
\v 35 Emu hahemauri kesina vada o henigu;  
\q2 oi imamu idibana ese vada e dogogu tao,  
\q2 emu kara manada-manada ese vada e imodaigu.   
\q1
\v 36 Taora bada gabuna vada o lailaia, lau aegu bae moia tao;  
\q2 aegu na asie dedi.   
\q1
\v 37 Lau inaigu na havadia, na lasidia tao;  
\q2 lau asina gini kerehai ela bona idia na e bua tari.   
\b  
\q1
\v 38 Na gwadadia uru, asie tore diba;  
\q2 e keto, aegu henudiai.   
\q1
\v 39 Oi ese goada o hariolaigu, baina tuari totona;  
\q2 lau inaigu o tahodia dobi henugu ai.   
\q1
\v 40 Lau inaigu o hakerehaidia lau vairagu ai;  
\q2 e ina heniguva taudia na na habuadia tari.   
\q1
\v 41 Hekaha e noilaia, a ta ese se hamauridia;  
\q2 Iehova e tai henia, a ia ese se haere henidia.   
\q1
\v 42 Lau na botadia patapata, ḡahu lai vairanai na heto;  
\q2 lau na negedia lasi murimuri ai, ariara mirona na heto.   
\b  
\q1
\v 43 Taunimanima edia tuari amo o hamaurigu;  
\q2 bese idau-idau ikwaradia ai o halaogu;  
\q2 asi dibagu taudia ese isiaigu e lao heniva.   
\q1
\v 44 Lau harigu e kamonai, bena e kamonai henigu;  
\q2 idau bese taudia na lau vairagu ai e igo diho.   
\q1
\v 45 Idau bese taudia na kudoudia e hetaha;  
\q2 edia komu gabudia amo e raka lasi mai heude-heudedia ida.   
\b  
\q1
\v 46 Iehova na e maurimu; egu nadi-gini na hanamoamu;  
\q2 egu hahemauri Diravana bae imodaia.   
\q1
\v 47 Dirava ese lau inaigu davadia e henidiamu;  
\q2 ia ese taunimanima na lau henugu ai e atodiamu;   
\q2
\v 48 ia ese lau inaigu edia amo e hamaurigu.  
\q1 Momokani, oi ese o imodaigu, lau inaigu daediai;  
\q2 daḡedaḡe taudia edia amo o hamaurigu.   
\b  
\q1
\v 49 Ina dainai, Iehova e, lau baina imodaimu bese idau-idau bogaragidiai;  
\q2 oi ladamu baina hanamoa egu ane ai.   
\q1
\v 50 Kwalimu badana ia ese ena pavapava e heniamu;  
\q2 e horoa tauna ia ese e bogaia hisimu;  
\q2 David mai garana ida baine bogadia hisi ela bona hanaihanai.   
\c 19  
\q1
\v 1 Guba ese Dirava hairaina e gwauraia hedinaraiamu;  
\q2 guba ḡaudia ese ia imana gaukaradia e hahedinaraiamu.   
\q1
\v 2 Dina ta ese dina ta e herevalai heniamu;  
\q2 hanuaboi ta ese hanuaboi ta enai iena aonega e gwauraimu.   
\q1
\v 3 Asi hereva ta, asi gado ta;  
\q2 eredia na se hekamonaimu.   
\q1
\v 4 A reḡedia na tanobada idoinai vada ela;  
\q2 edia hereva na tanobada dokona ai vada e kau.  
\b  
\q1 Idia ediai ia ese dina ena kalaga vada e atoa,   
\q2
\v 5 dina na e raka lasimu, headava matamata tauna na ena ruma amo e raka lasimu na heto;  
\q2 goada tauna na heto ia na ena dala ai e heaumu mai moalena ida.   
\q1
\v 6 Guba dokona ta amo e daemu,  
\q2 e hanaimu bona guba dokona ta;  
\q2 ḡau ta na ia siahuna amo basine komu diba.   
\b  
\q1
\v 7 Iehova ena taravatu vada e namo ḡuḡuru;  
\q2 ia ese lauma e hamauria loumu.  
\q1 Iehova ena hahediba herevana vada e momokani;  
\q2 ia ese asi aonegana tauna na e ha-aonegaiamu.   
\q1
\v 8 Iehova ena hahedua herevadia vada e maoromaoro;  
\q2 ia ese taunimanima lalodia e hamoalediamu.  
\q1 Iehova ena haheḡani vada e ḡoevaḡoeva;  
\q2 ia ese taunimanima matadia e hapapadiamu.   
\q1
\v 9 Iehova imatauraina vada e ḡoevaḡoeva,  
\q2 e mia hanaihanaimu.  
\q1 Iehova ena hahemaoro vada e momokani,  
\q2 bona vada e maoromaoro.   
\q1
\v 10 Edia namo ese \it gold\it* ena namo e hereaiamu,  
\q2 \it gold\it* ḡoevaḡoevadia momo edia namo e hereadiamu.  
\q1 Edia gaiho ese bada ranuna e hereaiamu,  
\q2 labolabo edia ruma amo e hetuturu dobimu ḡauna.   
\b  
\q1
\v 11 Idia ese oiemu hesiai tauna e sisiba heniamu;  
\q2 ibadinadia ahuna na bada.   
\q1
\v 12 To daika ese ena kara kerere-kereredia baine diba;  
\q2 Egu kara dika hehuni-hehunidia amo ba haḡoevagu.   
\q1
\v 13 Oiemu hesiai tauna ba rua, ena hekokoroku ai basine kara dika;  
\q2 egu kara dika basie hadareregu.  
\q1 bena basina kerere;  
\q2 kara dika badana ta basina karaia.   
\q1
\v 14 Iehova e, egu nadi-gini, egu hahemauri tauna, ba durugu;  
\q2 udugu herevadia bona lalogu ena lalo-hadai bae ḡoeva  
\q2 oi vairamu ai.   
\c 20  
\q1
\v 1 Iehova ese baine haere henimu, hisihisi dinana ai.  
\q2 Iakob ena Dirava ladana ese baine gimamu.   
\q1
\v 2 Helaḡa gabuna amo ena hekaha baine siaia vasi;  
\q2 Siona amo goada baine henimu.   
\q1
\v 3 Emu boubou iboudiai baine lalodia tao;  
\q2 emu ḡole-oho bouboudia baine abi dae. (Selah)   
\q1
\v 4 Lalomu ena ura baine henimu;  
\q2 emu lalo-hadai iboudiai anidia baine havara.   
\q1
\v 5 Emu hahemauri baia moalelaia,  
\q2 bona emai Dirava ladana ai emai pepe baia haodaia isi.  
\q1 Iehova ese emu noinoi iboudiai anidia baine havara henimu.   
\b  
\q1
\v 6 Harihari lau name diba, Iehova ese e horoa tauna na baine kahaia;  
\q2 ena gabu helaḡana amo baine haere henia,  
\q2 bona imana idibana amo kwalimu badadia baine henia.   
\q1
\v 7 Haida ese kariota e heaḡilaidiamu;  
\q2 ma haida ese hosi e heaḡilaidiamu;  
\q2 a ai ese Iehova, emai Dirava, ladana a heaḡilaiamu.   
\q1
\v 8 Idia na vada e hekwakwanai, vada e keto;  
\q2 a ai na vada a tore isi, vada a gini tore.   
\b  
\q1
\v 9 Iehova e, a hamaurimai!  
\q2 Baia boiboi negana ai, emai Pavapava ese baine haere henimai.   
\c 21  
\q1
\v 1 Iehova e, oi goadamu ai hanua pavapavana na e moalemu;  
\q2 oiemu hekaha e heaḡilaia badamu.   
\q1
\v 2 Lalona e uramu ḡauna oi ese vada o henia;  
\q2 uduna bibinadia edia noinoi na so rua. (Selah)   
\q1
\v 3 Emu hahenamo ḡaudia namo-hereadia ese ia e gunalaiamu;  
\q2 havava ḡauna, \it gold\it* namo-hereana amo e karaia, na ia kwarana ai o havavalaiamu.   
\q1
\v 4 Ia ese mauri e noia emu ai; oi ese o henia;  
\q2 ena mauri dinadia o hadaudau, ela bona hanaihanai.   
\q1
\v 5 Oiemu hekaha dainai taunimanima ese e imodaia badamu;  
\q2 hairai bona siahu oi ese vada o henia.   
\q1
\v 6 Momokani, oi ese vada o hanamoa bada ela bona hanaihanai;  
\q2 oi vairamu moalena amo vada o hamoalea.   
\q1
\v 7 Badina be hanua pavapavana ese Iehova e abidadama heniamu;  
\q2 Herea Mikamika ena hebogahisi dainai ia na basine marere.   
\q1
\v 8 Oi imamu ese oi inaimu iboudiai baine davaridia;  
\q2 oi imamu idibana ese e inai henimumu taudia iboudiai do baine davaridia.   
\q1
\v 9 Ba hedinarai negana ai amu mai siahuna heḡereḡerena ai ba halaodia.  
\q2 Iehova ese ena badu ai baine hadonodia,  
\q2 lahi ese baine aradia ore.   
\q1
\v 10 Oi ese idia garadia na tanobada amo ba habuadia;  
\q2 idia natudia na taunimanima natudia bogaragidia amo ba habuadia tari.   
\q1
\v 11 Oi ihadikamu dalana e haeroa,  
\q2 lalo-hadai dikana ta e laloa heḡaeḡae;  
\q2 to asi edia dala karana bae karaia.   
\q1
\v 12 Badina be oi ese ba hakarohodia;  
\q2 oi ese oiemu peva amo vairadia ba kino henidia.   
\b  
\q1
\v 13 Iehova e, emu goada ai bae imodaimu!  
\q2 Ai ese danu ane baia abi,  
\q2 oiemu siahu baia imodaia emai ane ai.   
\c 22  
\q1
\v 1 Egu Dirava e, egu Dirava e, dahaka dainai vada o rak-atanigu?  
\q2 Dahaka dainai emu hekaha na dauhai e miamu?  
\q2 Dahaka dainai egu ḡanaḡana so kamonaimu?   
\q1
\v 2 Egu Dirava e, dina ai na tai henimumu,  
\q2 a so haere henigumu;  
\q1 hanuaboi ai danu,  
\q2 to laḡa-ani asina davariamu.   
\q1
\v 3 A oi na helaḡa;  
\q2 Israel taudia edia heimodai latadiai o nohomu.   
\q1
\v 4 Tamamai ese oi e abidadama henimuva;  
\q2 e abidadama henimuva, bena oi ese o hamauridiava.   
\q1
\v 5 E tai henimuva, bena e mauri;  
\q2 e abidadama henimuva, bena asie baia.   
\b  
\q1
\v 6 A lau na biluga mo, dia taunimanima;  
\q2 taunimanima ese e ihi-ihiraigumu,  
\q2 egu bese taudia ese e dadaraigumu.   
\q1
\v 7 E itagumu taudia iboudiai ese e kirikirilaigumu,  
\q2 bibinadia e hamue henigumu,  
\q2 kwaradia e taiko-taikomu, e tomu   
\q1
\v 8 “Ia ese Iehova e abidadama henia,  
\q2 Iehova ese baine hamauria, baine harohoa mauri;  
\q2 badina be ia ese e moalelaiamu”.   
\q1
\v 9 Ḡau tamona, oi ese sinagu bogana amo o verigu lasi;  
\q2 oi ese o gimaguva sinagu kemena ai.   
\q1
\v 10 Egu vara dinana amo oiemu ai na tao;  
\q2 sinagu bogana amo na lasi dinana amo oi na egu Dirava.   
\q1
\v 11 Egu amo dauha basiola,  
\q2 badina be hisihisi vada eme kahira-kahira,  
\q2 bona lau na asi ikahagu ta.   
\b  
\q1
\v 12 Boromakau mamaruanedia momo ese e ḡeḡegu ahumu,  
\q2 Basan boromakaudia mai goadadia ida ese e kougu heḡeḡemu;   
\q1
\v 13 Idia ese ududia e haga henigumu,  
\q2 leona na mai daḡedaḡena ida e ḡoumu na heto.   
\b  
\q1
\v 14 Na aru ohomu ranu na heto,  
\q2 turiagu na e heridemu;  
\q1 kudougu na bada na heto,  
\q2 kemegu ai e veve ohomu.   
\q1
\v 15 Egu goada na e kaukaumu, ataga na heto,  
\q2 malagu na udugu ai e kaki taomu;  
\q2 mase ḡahuna ai vada o hagorugu diho.   
\b  
\q1
\v 16 Momokani, sisia ese e ḡegegu ahumu;  
\q2 kara dika taudia vada e hebou, vada e kougu ahu;  
\q2 imagu palapaladia bona aegu palapaladia vada e daidia uru,   
\q1
\v 17 (Turiagu idoinai na ita hedinaraimu).  
\q2 Idia ese e raraigumu, e itagu taomu;   
\q1
\v 18 egu dabua e hari,  
\q2 egu hahedoki na mari amo e hari.   
\b  
\q1
\v 19 A oi, Iehova e, basio noho dahu ai!  
\q2 Ikahagu e, aoma haraḡa, ba durugu!   
\q1
\v 20 Laumagu na dare amo ba hamauria,  
\q2 egu mauri na sisia ena siahu amo ba rauaia.   
\q1
\v 21 Leona uduna amo ba hamaurigu,  
\q2 uda boromakaudia doadia amo lau laumagu ba hamauria.   
\b  
\q1
\v 22 Oi ladamu baina hatoa, tadikakagu vairadiai;  
\q2 baina imodaimu, hebou bogaraginai.   
\q1
\v 23 Iehova garina o garimu taumui e, ia ba imodaia!  
\q2 Iakob natuna iboumui ai, ia ba heatolaia!  
\q2 Israel natuna iboumui ai, ia ba matauraia!   
\q1
\v 24 Badina be hisi ani tauna ena hisihisi  
\q2 ia ese se dadaraia bona se lalo dika henia;  
\q1 ia vairana na iena amo se hunia,  
\q2 e tai henia negana ai e kamonai.   
\b  
\q1
\v 25 Hebou badana ai baina imodaimu;  
\q2 egu gwauhamata anidia baina kara,  
\q2 ia garina e garimu taudia vairadiai.   
\q1
\v 26 Ogoḡami taudia na bae aniani, bogadia bae kunu;  
\q2 e tahuamu taudia ese Iehova bae imodaia.  
\q2 Oi lalomu baine mauri hanaihanai.   
\b  
\q1
\v 27 Tanobada dokodia iboudiai na bae helalo tao,  
\q2 bena Iehova bae haḡerea;  
\q1 bese idau-idau edia iduhu iboudiai ese  
\q2 ia bae toma henia diho.   
\q1
\v 28 Badina be basileia na Iehova ena,  
\q2 ia ese bese bese e lohiadiamu.   
\q1
\v 29 Momokani, heaḡi taudia iboudiai tanobada ai ese  
\q2 ia bae toma henia diho;  
\q1 ḡahu ai e dihomu taudia iboudiai na  
\q2 ia vairanai bae igo diho,  
\q1 bona sibona ihamaurina asi dibana tauna danu.   
\q1
\v 30 Garada ese ia isiaina bae lao henia;  
\q2 taunimanima ese uru gabena na Iehova sivaraina bae hamaorolaidia;  
\v 31   
\q1 do asie vara taudia na iena hahemauri bae hadibalaidia,  
\q2 hari vada e hahedinaraia heḡereḡerena.   
\c 23  
\q1
\v 1 Lau ireḡugu tauna mamoe ireḡuna na heto Iehova mo;  
\q2 lau na ḡau ta ai basina dabu.   
\q1
\v 2 Rei manoka-manoka gabudia ai ia ese e hahekuregumu;  
\q2 deḡedeḡerahu gabuna ranudia badibadidiai e hakaugumu.   
\q1
\v 3 Lau laumagu ia ese e hamauria loumu;  
\q2 kara maoromaoro daladia ai ia ese e hakaugumu,  
\q2 ia ladana dainai.   
\b  
\q1
\v 4 Oibe, ena be mase diburana kourana ai baina raka,  
\q2 to dika garina basina gari;  
\q1 badina be oi na lau ida,  
\q2 emu kareva bona emu itotohi ese lau taugu e haloamu.   
\q1
\v 5 Agu aniani oi ese o dabaraiamu,  
\q2 lau inaigu vairadiai;  
\q1 lau kwaragu na dehoro ai o horoamu,  
\q2 egu kehere na e hepurai dobimu.   
\q1
\v 6 Momokani, namo bona hebogahisi do bae ḡavagu,  
\q2 egu mauri dinadia idoidiai;  
\q1 bona Iehova ena ruma ai  
\q2 baina noho hanaihanai.   
\c 24  
\q1
\v 1 Tanobada mai anidia iboudiai ida, Iehova ena,  
\q2 tanobada idoinai mai inoho-henina taudia ida;   
\q1
\v 2 badina be ia sibona ese vada e hadaia, davara latadiai,  
\q2 ia ese vada e haginia utu-utu latadiai.   
\b  
\q1
\v 3 Daika ese Iehova ena ororo baine dara dae?  
\q2 Daika ese ena gabu helaḡana ai baine gini?   
\q1
\v 4 Ima-ḡoevaḡoeva bona lalo-ḡoevaḡoeva tauna ese;  
\q2 kara havara se ura henimu  
\q2 bona se gwau hamata koikoimu tauna ese.   
\q1
\v 5 Hahenamo na Iehova ena amo baine abia,  
\q2 ena kara igwaurai-maorona danu  
\q2 ia ihamaurina Diravana ena amo baine abia.   
\q1
\v 6 Ia e tahuamu taudia edia uru bunai;  
\q2 idia na oi vairamu e tahuamu, Iakob ena Dirava e! (Selah)   
\b  
\q1
\v 7 Ikoukoumui e, umui kwaramui avabi isi!  
\q2 Idau nega iduaradia, umui na sibomui a heabi isi!  
\q2 Hanua Pavapavana diaḡau namona baine raka vareai.   
\q1
\v 8 Hari Hanua Pavapavana diaḡau namona be daika?  
\q2 Iehova bunai, mai goadana ida bona mai siahuna ida;  
\q2 Iehova bunai, tuari ai e kwalimumu.   
\q1
\v 9 Ikoukoumui e, umui kwaramui avabi isi!  
\q2 Oibe, idau nega iduaradia, umui na sibomui a heabi isi!  
\q2 Hanua Pavapavana diaḡau namona baine raka vareai.   
\q1
\v 10 Hari Hanua Pavapavana diaḡau namona be daika?  
\q2 Iehova Sabaota, ia bunai Hanua Pavapavana diaḡau namona. (Selah)   
\c 25  
\q1
\v 1 Iehova e, laumagu na abia isimu oiemu ai;   
\q2
\v 2 egu Dirava e, lau oi na abidadama henimumu.  
\q1 Ba durugu, hemarai na basine abigu;  
\q2 ba durugu, inaigu na basie herouheroua latagu ai.   
\q1
\v 3 Oibe, e narimumu tauna ta basie hahemaraia;  
\q2 a asi badina e tao toremu taudia vada bae hahemaraidia.   
\b  
\q1
\v 4 Iehova e, emu kara ba haheitalaigu,  
\q2 emu dala ba hadibalaigu.   
\q1
\v 5 Emu hereva momokanidia ai ba hakaugu, ba hadibagu,  
\q2 badina be oi na lau ihamaurigu Diravana;  
\q2 oi na narimumu dina idoinai.   
\b  
\q1
\v 6 Iehova e, emu hebogahisi ba laloa,  
\q2 emu lalokau ba laloa tao;  
\q2 badina be idia na nega gunadia amo e hemailaimu.   
\q1
\v 7 Tauhaugu negana ena kara dika na basio Ialoa tao,  
\q2 eiava egu kara havara danu;  
\q1 Iehova e, lau ba lalogu tao,  
\q2 emu hebogahisi dainai.   
\b  
\q1
\v 8 Iehova na namo bona maoromaoro;  
\q2 taunabunai ia ese kara dika taudia na dala ai e hadibadiamu.   
\q1
\v 9 Ia ese lalo-manau taudia na kara maoromaoro ai e hakaudiamu,  
\q2 lalo-manau taudia na iena dala e hadibalaidiamu.   
\q1
\v 10 Iehova ena dala iboudiai na hebogahisi bona momokani daladia,  
\q2 ena taravatu bona ena hahediba herevadia e badinadiamu taudia edia.   
\b  
\q1
\v 11 Iehova e, oi ladamu dainai egu kara dika ba gwau tao,  
\q2 badina be vada e bada.   
\q1
\v 12 Iehova garina e garimu tauna be daika?  
\q2 Iehova ese ia baine hadibaia, edena dala baine abia hidi.   
\q1
\v 13 Ia na taḡa ai baine noho,  
\q2 bona ia natuna ese tano bae abia, edia.   
\q1
\v 14 Iehova ena hetura na ia garina e garimu taudia edia;  
\q2 ia ese ena taravatu baine hadibalaidia.   
\q1
\v 15 Matagu ese Iehova e haḡereamu,  
\q2 badina be ia ese lau aegu na huo amo baine veridia oho.   
\b  
\q1
\v 16 A haḡeregu, a bogagu hisi;  
\q2 badina be lau na sibogu, bona na hisihisimu.   
\q1
\v 17 Lalogu ena hisihisi na e bada e laomu;  
\q2 egu hisihisi amo ba hakaugu lasi.   
\q1
\v 18 Egu hisihisi bona egu hekwarahi ba haerodia,  
\q2 bona egu kara dika iboudiai ba gwau tao.   
\b  
\q1
\v 19 A haeroa, inaigu na hutuma,  
\q2 bona edia badu na auka herea egu ai.   
\q1
\v 20 Egu mauri ba gimaia, ba hamaurigu;  
\q2 ba durugu, basie hahemaraigu;  
\q2 badina be egu roho-mauri be oiemu ai.   
\q1
\v 21 Kara momokani bona kara maoromaoro ese bae hamaurigu;  
\q2 badina be oi na narimumu.   
\b  
\q1
\v 22 Dirava e, Israel ba hamauria,  
\q2 ena hisihisi iboudiai lalodia amo.   
\c 26  
\q1
\v 1 Iehova e, ba gwauraigu maoro,  
\q2 badina be vada na raka mai maoromaorogu ida,  
\q2 bona Iehova vada na abidadama henia, asi egu daradara.   
\q1
\v 2 Iehova e, ba tahugu, ba dibagu;  
\q2 lalogu bona daragu ba dibadia.   
\q1
\v 3 Badina be emu hebogahisi na lau matagu ai,  
\q2 bona oi iabidadama-henimu karana ai na rakamu.   
\q1
\v 4 Koikoi taudia ida asina helaimu,  
\q2 bona boga-alaga taudia ida asina raka heboumu;   
\q1
\v 5 kara dika taudia edia hebou na inai heniamu,  
\q2 bona kara havara taudia ida basina helai hebou.   
\b  
\q1
\v 6 Ialo-ḡoevaḡoeva ai lau imagu na huriamu;  
\q2 Iehova e, emu ihaboulaina patana na rakaia heḡeḡemu,   
\q1
\v 7 oi ihanamolaimu anena na lololaiamu,  
\q2 bona oiemu hoa karadia iboudiai na gwauraidiamu.   
\b  
\q1
\v 8 Iehova e, oi o noholaiamu rumana na ura heniamu,  
\q2 oi hairaimu e miamu gabuna na lalokau heniamu.   
\q1
\v 9 Kara dika taudia ida basio darogu tabe,  
\q2 egu mauri danu rara e hahebubuamu taudia ida basio bibia tabe;   
\q1
\v 10 idia imadia na kara dikadia ai e honumu,  
\q2 imadia idibadia na koikoi karadia davadia ai e honumu.   
\b  
\q1
\v 11 A lau be egu kara maoromaoro ai na rakamu;  
\q2 ba hamaurigu, ba bogagu hisi.   
\q1
\v 12 Aegu na taora ai gini;  
\q2 hebou badana lalonai Iehova baina hanamoa.   
\c 27  
\q1
\v 1 Iehova na egu diari, lau ihamaurigu;  
\q2 daika garina baina gari?  
\q1 Iehova na egu mauri maḡuna;  
\q2 daika baina gari henia?   
\b  
\q1
\v 2 Kara dika taudia ese bae ala-ala henigu,  
\q2 lau taugu ianina totona,  
\q1 una negana ai lau inaigu bona e daḡedage henigumu taudia na  
\q2 bae hetutuhi bona bae keto.   
\b  
\q1
\v 3 Ena be tuari taudia hutuma bae taruha, lau bae ala-ala henigu,  
\q2 to kudougu basine hetaha;  
\q1 ena be tuari na egu ai baine kau,  
\q2 to lalogu do baine goada.   
\q1
\v 4 Ḡau tamona mo Iehova enai na noiamu,  
\q2 una mo baina tahua;  
\q1 Iehova ena ruma ai baina noho,  
\q2 egu mauri dinadia iboudiai;  
\q1 Iehova hairaina baina itaia,  
\q2 bona ena dubu ai lalo-parara baina tahua.   
\q1
\v 5 Badina be hahedika baine kau dinana ai,  
\q2 ia ese ena kalaga ai baine hunigu;  
\q1 ena ḡuriḡuri kalagana ai ia ese baine hunigu,  
\q2 baine abigu isi, nadi latanai baine atogu.   
\q1
\v 6 Lau kwaragu baine heabi isi,  
\q2 inaigu, e daigu ahu taudia, daediai;  
\q1 bena ena ḡuriḡuri kalagana ai  
\q2 boubou ḡaudia baina hahelaḡadia mai moalegu ida;  
\q2 bona ane baina abi, Iehova ihanamolaina anedia.   
\b  
\q1
\v 7 Iehova e, na boi lolomu negana ai na ba kamonai,  
\q2 ba bogagu hisi, ba haere henigu.   
\q1
\v 8 Vada oto “Lau vairagu ba tahua;”  
\q2 bena lau lalogu e haere henimumu, e tomu  
\q2 “Iehova e, oi vairamu na tahuamu.”   
\q1
\v 9 Oi vairamu na egu amo basio hunia.  
\b  
\q1 Oiemu hesiai tauna basio lulua mai badumu ida;  
\q2 ikahagu na oi.  
\q1 Lau ihamaurigu Diravana e,  
\q2 basio negegu, bona basio rakatanigu.   
\q1
\v 10 Badina be tamagu bona sinagu vada e rakatanigu,  
\q2 a Iehova ese baine abigu dae.   
\b  
\q1
\v 11 Iehova e, emu dala ba hadibalaigu;  
\q2 dala maoromaorona ai ba hakaugu, lau inaigu daidiai.   
\q1
\v 12 E daḡedaḡe henigumu taudia edia ura ai basio negegu;  
\q2 badina be hahebade koikoi taudia vada e gini tore, bae hadikagu totona,  
\q1 idia na mai daḡedaḡedia ida e ḡosimu.   
\q1
\v 13 Lau lalogu na e abia daemu Iehova ena kara namo baina itaia,  
\q2 mauri taudia edia tano ai.   
\q1
\v 14 Iehova ba naria;  
\q2 ba goada balaheni, ba boga auka;  
\q2 oibe, Iehova ba naria.   
\c 28  
\q1
\v 1 Iehova e, lau oi na boiboi henimumu;  
\q2 egu nadi-gini, taiamu na basio koudia egu ai,  
\q1 basio haere henigu negana ai na  
\q2 mase gabuna e laomu taudia heḡereḡeredia ai bainala na garina.   
\q2
\v 2 Egu noinoi herevadia a kamonai,  
\q1 ba kahagu totona na tai henimumu negana ai,  
\q2 bona imagu na emu gabu helaḡana na dudui isi heniamu negara ai.   
\q1
\v 3 Kara dika taudia ida basio abigu oho,  
\q2 kara havara taudia ida basio negegu daure;  
\q1 idia ese dekedia taudia na maino herevadia e gwaurai henidiamu,  
\q2 a lalo-hadai dikadia na lalodia ai mimia.   
\q1
\v 4 Edia ḡaukara heḡereḡeredia ai davadia na ba henidia,  
\q2 edia kara dikadia davadia do ba henidia;  
\q1 imadia ḡaukaradia heḡereḡeredia ai davadia na ba henidia,  
\q2 davadia korikori do ba henidia.   
\q1
\v 5 Badina be Iehova ena ḡaukara asie matauraidiamu,  
\q2 ia imana ḡaukaradia asie matauraidiamu;  
\q1 ia ese baine ḡiḡidia dobi,  
\q2 ma basine hadaidia lou.   
\b  
\q1
\v 6 Iehova aina hanamoa!  
\q2 Badina be egu noinoi vada e kamonai.   
\q1
\v 7 Iehova na egu goada bona egu kesi,  
\q2 lau lalogu ese ia e abidadama heniamu;  
\q1 unu amo hekaha na davariamu, bona lalogu na e moalemu,  
\q2 egu ane ai danu ia na hanamoamu.   
\q1
\v 8 Iehova na ena bese taudia edia goada;  
\q2 ia na e horoa tauna ena kohoro.   
\q1
\v 9 Emu bese taudia ba hamauridia, oi dihimu ba hanamodia;  
\q2 ba reḡudia, bona bavabidia isi hanaihanai.   
\c 29  
\q1
\v 1 Siahu taudia natudia e, Iehova ba imodaia;  
\q2 Iehova hairaina bona siahuna ba heatolaidia.   
\q1
\v 2 Iehova ladana hairaina ba heatolaia;  
\q2 Dabua helaḡadia ai Iehova ba imodaia.   
\b  
\q1
\v 3 Iehova gadona na ranu latadiai;  
\q2 Hairai Diravana gadona na guba-rahu na heto,  
\q2 Iehova na ranu badadia latadiai.   
\q1
\v 4 Iehova gadona na mai siahuna,  
\q2 Iehova gadona na pavapava gadona.   
\b  
\q1
\v 5 Iehova gadona ese sida audia e hakwaidudiamu,  
\q2 Iehova ese Lebanon ena sida audia e hakwaidudiamu.   
\q1
\v 6 Ia ese Lebanon e harohoamu, boromakau natuna na heto,  
\q2 Sirion danu e harohoamu, uda boromakauna natuna maruanena na heto.   
\b  
\q1
\v 7 Iehova gadona ese lahi hururu-hururudia e hakevaru isimu;   
\q2
\v 8 Iehova gadona ese tano ḡaḡaena e haheude-heudeamu,  
\q2 Iehova ese Kade tano-gaḡaena e haheude-heudeamu.   
\q1
\v 9 Iehova gadona ese \it oak\it* audia e odadia hirihirimu,  
\q2 bona uda au-raudia e oda ohomu;  
\q2 iena dubu ai ḡau iboudiai ese ia hairaina e gwauraiamu.   
\b  
\q1
\v 10 Iehova na ena terono ai e helaimu, utu-utu daediai;  
\q2 Iehova na ena terono ai e helaimu, e pavapava hanaihanaimu.   
\q1
\v 11 Iehova ese ena orea taudia na goada baine henidia;  
\q2 Iehova ese ena orea taudia na maino amo baine hanamodia.   
\c 30  
\q1
\v 1 Iehova e, aina heatolaimu, badina be oi ese vada o verigu isi;  
\q2 lau inaigu vada o rudia, basie kirikirilaigu.   
\q1
\v 2 Iehova e, egu Dirava, na tai henimu, ba kahagu nato;  
\q2 bena oi ese o hamaurigu.   
\q1
\v 3 Iehova e, lau laumagu na mase taudia edia gabu amo vada o hakaua dae;  
\q1 mase gabuna vada ela taudia bogaragidia amo vada o hamaurigu.   
\b  
\q1
\v 4 Iehova ena helaḡa taumui e, ia ihanamolaina anedia bavabi,  
\q2 ia ladana helaḡana ba hanamoa.   
\q1
\v 5 Badina be ena badu na e ore haraḡamu,  
\q2 a ena hahenamo na e hesiriumu ela bona mauri dokona.  
\q1 Taitai na reana baine hesiriu rani,  
\q2 a daba ai moale na baine vara lou.   
\b  
\q1
\v 6 Lau be egu noho namo ai nato  
\q2 “Lau na basina marere ela hanaihanai”.   
\q1
\v 7 Iehova e, emu hahenamo amo vada o haginigu,  
\q2 ororo aukana na heto;  
\q1 Oi vairamu o hunia,  
\q2 bena kudougu e hetaha.   
\b  
\q1
\v 8 Iehova e, lau oi na tai henimu;  
\q2 Iehova enai na noinoi, nato   
\q1
\v 9 “Mase gabuna bama lao henia,  
\q2 egu mase ena namo be dahaka?  
\q1 Ḡahu ese oi baine hanamomu a?  
\q2 Ḡahu ese oiemu heabi-dae baine gwauraia a?   
\q1
\v 10 Iehova e, a kamonai, a bogagu hisi!  
\q2 Iehova e, a kahagu!”   
\b  
\q1
\v 11 Egu tai gadeḡade na mavaru ai vada o halaoa;  
\q2 egu guma dabuadia vada o hadoki oho,  
\q2 moale vada o hariolaigu,   
\q1
\v 12 laumagu ese baine imodaimu bona udugu basina hakapua helaoreana.  
\q2 Iehova e, egu Dirava,  
\q2 lau oi baina hanamomu ela bona hanaihanai.   
\c 31  
\q1
\v 1 Iehova e, lau oi na abidadama henimumu;  
\q2 hemarai na nega idoinai basine abigu,  
\q2 emu kara maoromaoro ai ba hamaurigu!   
\q1
\v 2 Ame igo diho, a hakala henigu,  
\q2 ba hamaurigu haraḡa-haraḡa!  
\q1 Egu komu nadina ai baola,  
\q2 egu kohoro ai baola, ihamaurigu totona.   
\b  
\q1
\v 3 Oibe, oi na egu nadi-gini bona egu kohoro;  
\q2 oi ladamu dainai ba gunalaigu bona ba hakaugu;   
\q1
\v 4 iabigu totona e otoa huona amo ba hamaurigu,  
\q2 badina be egu maḡu na oi.   
\q1
\v 5 Laumagu na oi imamu ai na atoamu;  
\q2 Iehova e, heabi-dae Diravana e, oi ese vada o hamaurigu.   
\b  
\q1
\v 6 Dirava koikoidia laulaudia e badinadiamu taudia na inai henidiamu;  
\q2 a Iehova na abidadama heniamu.   
\q1
\v 7 Lau baina moale, emu hebogahisi baina moalelaia;  
\q2 badina be egu hisihisi vada o itaia,  
\q2 egu hekwarahi vada o haeroa;   
\q1
\v 8 lau inaigu imadia ai so negegu,  
\q2 a lau aegu na taora bada gabuna ai vada o atodia.   
\b  
\q1
\v 9 Iehova e, ame bogagu hisi,  
\q2 badina be hisihisi ese a gugubagumu,  
\q1 taitai ese matagu e hadikamu,  
\q2 laumagu bona tau-anigu danu e dikamu.   
\q1
\v 10 Badina be egu mauri na lalo-hisihisi ai e oremu,  
\q2 egu mauri laḡanidia na ḡanaḡana ai e oremu;  
\q1 egu goada na e oremu, egu kara dika daidiai,  
\q2 bona turiagu na e mamano.   
\b  
\q1
\v 11 Inaigu iboudiai ese e dadaraigumu,  
\q2 dekegu taudia ese e dadaraigu hereamu,  
\q1 turagu ese e gari henigumu,  
\q2 ariara ai e itagumu taudia ese e heautanigumu.   
\q1
\v 12 Taunimanima ese vada e lalogu boio, mase tauna na heto;  
\q2 lau na uro makohina na heto.   
\q1
\v 13 Oibe, hutuma edia hemaunu na kamonaimu,  
\q2 kudou hetaha na kaha iboudiai e miamu.  
\q1 Idia ese e henega heboumu, lau ihadikagu totona,  
\q2 egu mauri iabi-ohona dalana e tahuamu.   
\b  
\q1
\v 14 Iehova e, lau oi na abidadama henimumu,  
\q2 na tomu “Oi na egu Dirava”.   
\q1
\v 15 Egu nega na oi imamu ai;  
\q2 lau inaigu bona e daḡedaḡe henigumu taudia imadia amo ba hamaurigu.   
\q1
\v 16 Oi vairamu ese emu hesiai tauna baine hadiaria;  
\q2 emu hebogahisi ai ba hamaurigu.   
\q1
\v 17 Iehova e, hemarai ese basine abigu,  
\q2 badina be oi na hahanemumu;  
\q1 kara dika taudia na bae hemarai,  
\q2 asi reḡereḡedia na mase taudia edia gabu baela.   
\q1
\v 18 Koikoi taudia bibinadia na bae mu;  
\q2 edia heaḡi ai bona edia hedadarai ai  
\q2 kara maoromaoro taudia bae ihi-ihiraidia taudia na  
\q1 ududia bae hahekapu.   
\b  
\q1
\v 19 Emu hahenamo na bada herea,  
\q2 o abia heḡaeḡaemu, oi e gari henimumu taudia edia,  
\q1 bona o karaiamu, oi metaimu e heau heniamu taudia edia,  
\q2 taunimanima natudia vairadiai o karaiamu.   
\q1
\v 20 Oi metaimu ai o hunidiamu,  
\q2 taunimanima edia hedibaḡani karadia amo o hunidiamu;  
\q1 emu kalaga ai o naridiamu,  
\q2 badu taudia maladia amo o gimadiamu.   
\b  
\q1
\v 21 Iehova aina hanamoa;  
\q2 badina be ena hebogahisi na egu ai vada e hahedinaraia,  
\q1 hoa ḡauna na heto,  
\q2 e heḡeḡe dae hanuana lalonai e kougu ahu negana ai.   
\q1
\v 22 Egu gari ai nato  
\q2 “Oi vairamu amo na henege daure”.  
\q1 A oi ese egu noinoi o kamonai,  
\q2 na tai henimu negana ai.   
\b  
\q1
\v 23 Iehova ena helaḡa taumui e, ia ba lalokau henia.  
\q2 Iehova ese kamonai taudia e hamauridiamu,  
\q2 a heaḡi karadia e karamu taudia na davadia e henidiamu.   
\q1
\v 24 Ba goada, ba boga auka,  
\q2 Iehova o nariamu taumui iboumui ai.   
\c 32  
\q1
\v 1 Ena kara dika eme hegwau tao tauna be namo,  
\q2 ena kara havara e heḡova ahu tauna danu namo.   
\q1
\v 2 Iehova ese se habadelaiamu tauna na namo,  
\q2 laumana na asi koikoina tauna danu namo.   
\b  
\q1
\v 3 Egu kara dika asina gwauraia hedinarai negana ai,  
\q2 lau taugu anina na e varoda-varodava,  
\q2 dina idoinai na ḡanaḡanava dainai.   
\q1
\v 4 Badina be imamu metauna na latagu ai e miava,  
\q2 dina ai bona hanuaboi ai danu;  
\q1 taugu vada e geakageaka,  
\q2 lahara negana ena dina ḡaraḡara ese bema raraia na heto. (Selah)   
\q1
\v 5 Egu kara dika na vairamu ai na gwauraia hedinarai,  
\q2 egu kara havara na asina hunia;  
\q1 nato “Egu kerere baina gwaurai hedinarai Iehova vairanai”;  
\q2 bena oi ese egu kara dika ena metau o abia oho. (Selah)   
\q1
\v 6 Taunabunai, helaḡa taudia iboudiai ese oi bae ḡurimu,  
\q2 bena hisihisi negana ai utu-utu baine utua dae,  
\q2 to ediai basine kau.   
\q1
\v 7 Oi na egu komu gabuna,  
\q2 dika amo o hamaurigumu,  
\q2 bona hahemauri anedia amo o hahegeḡegu daemu. (Selah)   
\q1
\v 8 Lau ese baina hadibamu, emu raka dalana baina hadibalaimu;  
\q2 lau matagu ese baine itamu tao.   
\q1
\v 9 Hosi eiava doniki ida basio heḡereḡere,  
\q2 idia na asi daradia;  
\q1 ududia auridia bona varodia amo bae hamanadadia,  
\q2 basie kamonai henimu na garina.   
\b  
\q1
\v 10 Kara dika taurla ena hisihisi na momo;  
\q2 a Iehova e abidadama heniamu tauna na  
\q2 hebogahisi ese e ḡeḡea daemu.   
\q1
\v 11 Iehova ba moalelaia! Kara maoromaoro taumui e, ba moale!  
\q2 Lalomui mamaoro-mamaoro taumui, ba moale hisidae.   
\c 33  
\q1
\v 1 Kara namo taumui e, Iehova ba moalelaia;  
\q2 badina be heimodai be ḡau namona,  
\q2 kara maoromaoro taudia ududia ai.   
\q1
\v 2 Hatai-hatai ḡauna maraḡina amo Iehova ba hanamoa,  
\q2 ma badana, varo gwauta ḡauna, ba hataia, ia ihanamolaina.   
\q1
\v 3 Ane matamatana avabia iena;  
\q2 varo ḡaudia ba hatai, ba hatai balaheni,  
\q2 mai lolomui ida.   
\b  
\q1
\v 4 Badina be Iehova ena hereva na maoromaoro;  
\q2 ena ḡaukara idoinai e karaiamu mai momokanina ida.   
\q1
\v 5 Ia ese kara maoromaoro bona hahemaoro e ura henidiamu,  
\q2 tanobada na Iehova ena hebogahisi ai e honu honu daemu.   
\b  
\q1
\v 6 Iehova ena hereva ese guba e karaia,  
\q2 ia uduna amo e hahodi, bena guba taudia iboudiai e vara.   
\q1
\v 7 Ia ese davara ranudia e haboudia, kavabu ai bema haboudia na heto;  
\q2 bona gadobada na e haboudia, roge ai bema haboudia na heto.   
\b  
\q1
\v 8 Tanobada idoinai ese Iehova garina baine gari,  
\q2 tanobada taudia iboudiai ese ia bae matauraia.   
\q1
\v 9 Badina be ia e hereva, bena e hekara;  
\q2 ia e hahedua, bena e gini tutuka-tutuka.   
\b  
\q1
\v 10 Iehova ese bese idau-idau edia henega e hakarohodiamu,  
\q2 orea idau-idau edia lalo-hadai ia ese e laodia ahumu.   
\q1
\v 11 Iehova ena henega e gini hanaihanaimu,  
\q2 bona ena lalo-hadai ela bona uru iboudiai.   
\q1
\v 12 Iehova na ena Dirava ai e halaoamu besena be namo;  
\q2 vada e abidia hidi ia dihina ai baela taudia be nanamo.   
\b  
\q1
\v 13 Iehova na guba amo e roha dobimu,  
\q2 taunimanima natudia iboudiai e nenediamu;   
\q1
\v 14 terono ai e helaimu gabuna amo e roha laomu.  
\q2 tanobada taudia iboudiai e itadiamu;   
\q1
\v 15 ia ese idia iboudiai lalodia e karadiamu,  
\q2 edia kara iboudiai danu e itadia taomu.   
\b  
\q1
\v 16 Hanua pavapavana na dia ena tuari oreana badana dainai basine roho mauri;  
\q2 tuari tauna na dia ena goada badana dainai basine mauri.   
\q1
\v 17 Tuari hosina na mauri e tahuamu tauna ese basine abidadama henia;  
\q2 dia ena goada badana ese tau ta basine hamauria diba.   
\b  
\q1
\v 18 A itaia, Iehova ese ia garina e garimu taudia na e itadiamu;  
\q2 iena hebogahisi e laroamu taudia ia ese e itadia taomu;   
\q1
\v 19 idia laumadia na mase amo baine harohodia mauri totona,  
\q2 bona doe negana ai baine hamaundia totona.   
\b  
\q1
\v 20 Ita laumada ese Iehova e nariamu;  
\q2 ia na ita ikahada, bona eda kesi.   
\q1
\v 21 Oibe, ita laloda ese ia e moalelaiamu,  
\q2 badina be ia ladana helaḡana ta abidadama heniamu.   
\q1
\v 22 Iehova e, emu hebogahisi na ai latamai ai baine mia,  
\q2 ai emai helaro na oiemu ai e miamu heḡereḡerena.   
\c 34  
\q1
\v 1 Nega iboudiai Iehova baina hanamoa;  
\q2 ia iheatolaina na udugu ai baine mia hanaihanai.   
\q1
\v 2 Laumagu ese Iehova e heaḡilaiamu;  
\q2 manau taudia ese bae kamonai, bena bae moale.   
\q1
\v 3 Lau ida Iehova baita imodaia,  
\q1 ia ladana baita heatolaia hebou.   
\b  
\q1
\v 4 Iehova na tahua, bena ia ese e haere henigu;  
\q2 egu gari idoidiai lalodia amo e hamaurigu.   
\q1
\v 5 Ia ba haḡerea, bena ba diari;  
\q2 una dainai vairamui na nega ta basie hemarai.   
\q1
\v 6 Ina ogoḡami tauna e taitai, bena Iehova ese e kamonai henia,  
\q2 bona ena hekwarahi iboudiai lalodia amo e hamauria.   
\b  
\q1
\v 7 Iehova ena aneru e taruhamu,  
\q2 ia garina e garimu taudia e ḡeḡedia ahumu,  
\q2 bona e hamauridiamu.   
\q1
\v 8 A mamia toho, bena ba diba, Iehova na namo;  
\q2 ia e abidadama heniamu tauna danu e moalemu.   
\q1
\v 9 Ena helaḡa taumui e, Iehova garina ba gari,  
\q2 badina be ia garina e garimu taudia na asie dabumu.   
\q1
\v 10 Leona natudia na e dabumu bona e hitolodiamu;  
\q2 a Iehova e tahuamu taudia na ḡau namona ta ai asie dabumu.   
\b  
\q1
\v 11 Memero kekeni e, aoma, lau ba hakala henigu;  
\q2 Iehova imatauraina baina hadibamui.   
\q1
\v 12 Tau be daika, mauri urana e uramu,  
\q2 e uramu danu ena mauri dinadia bae hoho,  
\q2 namo baine itaia helaoreana,   
\q1
\v 13 Malamu ba naria, basine ere dika,  
\q2 udumu bibinadia danu, koikoi herevadia basie gwaurai.   
\q1
\v 14 Dika ba rakatania, kara namo ba kara;  
\q2 maino ba tahua, bona ba ḡavaia.   
\b  
\q1
\v 15 Iehova ese kara maoromaoro taudia e haḡerediamu;  
\q2 edia taitai ia ese e hakala henidiamu.   
\q1
\v 16 Iehova ese kara dika taudia e vaira hua henidiamu;  
\q2 idia ilalo-taodia na tanobada amo e abia ohomu.   
\q1
\v 17 Kara maoromaoro taudia e boiboimu negadia ai na Iehova ese e kamonaimu,  
\q2 bona edia hekwakwanai iboudiai lalodia amo e hamauridiamu.   
\q1
\v 18 Iehova na lalo-hisihisi taudia dekedekediai;  
\q2 dara-doko taudia ia ese e hamauridiamu.   
\b  
\q1
\v 19 Kara maoromaoro tauna ena hisihisi na momo,  
\q2 a Iehova ese iboudiai lalodia amo e hamauriamu.   
\q1
\v 20 Ia turiana iboudiai Iehova ese e gimadiamu,  
\q2 ta se kwaidumu.   
\q1
\v 21 Kara dika tauna na dika ese baine alaia;  
\q2 kara maoromaoro tauna e inai heniamu taudia na bae baia.   
\q1
\v 22 Iehova ese ena hesiai taudia laumadia e hamauridiamu;  
\q2 ia e abidadama heniamu tauna ta basine baia.   
\c 35  
\q1
\v 1 Iehova e, e heai henigumu taudia na ba heai henidia,  
\q2 e tuari henigumu taudia na ba tuari henidia.   
\q1
\v 2 Kesi bona keme aurina avabi,  
\q2 a tore isi, ba durugu.   
\q1
\v 3 Io bona dare a veridia lasi,  
\q2 e havagumu taudia ba laodia ahu.  
\q1 Lau laumagu a hereva henia, aoto  
\q2 “Lau binai oi ihamaurimu”.   
\q1
\v 4 Egu mauri iabi-ohona e tahuamu taudia na  
\q2 ba hadareredia bona ba hahemaraidia;  
\q1 lau ihadikagu karadia e haeromu taudia na  
\q2 ba haloudia bona ba hadaradaradia.   
\q1
\v 5 Uit momona na lai ese e odaia ohomu heḡereḡerena ai baela;  
\q2 Iehova ena aneru ese do baine luludia oho.   
\q1
\v 6 Edia dala baine dibura bona baine dedidedi;  
\q2 Iehova ena aneru ese baine havadia.   
\b  
\q1
\v 7 Badina be lau iabigu totona edia huo e otoa, asi badina;  
\q2 asi badina guri e ḡeia, egu mauri iabi-ohona.   
\q1
\v 8 Mase ese baine hahoadia;  
\q2 e otoa huona ese baine hatoadia,  
\q2 ia lalonai vada bae mase.   
\b  
\q1
\v 9 Una negana ai laumagu ese Iehova baine moalelaia;  
\q2 ena hahemauri baine imodaia.   
\q1
\v 10 Turiagu iboudiai baeto  
\q2 “Iehova e, daika na oi heḡereḡeremu?  
\q1 Oi ese manoka tauna o hamauriamu,  
\q2 goada ai e hereaiamu tauna imana amo;  
\q1 bona manoka tauna bona ogoḡami tauna  
\q2 ena kohu e dadihaiamu tauna imana amo”.   
\b  
\q1
\v 11 Hahebade koikoi taudia e tore isimu,  
\q2 asi dibagu ḡaudia e nanadailaigumu.   
\q1
\v 12 Na kara namo henidia davana na e kara dika henigumu;  
\q2 laumagu na e dauremu.   
\q1
\v 13 A lau be e goreredia negana ai na guma dabuadia na dokilai,  
\q2 bona anivaga ai sibogu na hahedika;   
\q1
\v 14 na ḡuriḡuri igo-diho,  
\q2 turagu eiava tadikakagu taina bama tai na heto;  
\q1 na loa eva-eva, sinana e tailaiamu tauna na heto,  
\q2 na igo diho, na tai noho tai noho.   
\b  
\q1
\v 15 A lau na hekwakwanai negana ai na idia na e moale hebouva,  
\q2 lau ihadikagu totona e hegogova;  
\q1 idau taudia, asi dibagu taudia, na  
\q2 lau ihadikagu totona e hebouva,  
\q2 e ihi-ihiraiguva asi dokona.   
\q1
\v 16 Dirava asie matauraiava taudia ese e hevaseha henigu loulouva,  
\q2 gadigadidia e hahedai heniguva.   
\b  
\q1
\v 17 Ḡaubada e, ba herarai tao ela bona edena nega ai?  
\q2 Laumagu na edia ala-ala amo ba hamauria,  
\q2 egu mauri na leona edia amo ba rauaia;   
\q1
\v 18 bena hebou badana lalonai baina hanamomu,  
\q2 hutuma bada bogaragidiai baina imodaimu.   
\b  
\q1
\v 19 Ba durugu, e inai henigu koikoimu taudia ese basie kirikirilaigu,  
\q2 e inai henigu kavamu taudia ese ibunidia basie ha-roro.   
\q1
\v 20 Badina be maino herevadia asie gwauraimu,  
\q2 a tano ai e noho mainomu taudia latadiai na  
\q2 koikoi herevadia e gwauraimu.   
\q1
\v 21 Ududia e ahagamu, lau ihadikagu, e tomu  
\q2 “Aha, aha, matamai ese vada e itaia”.   
\b  
\q1
\v 22 Iehova e, vada o itaia; udumu basio hakapua;  
\q2 Iehova e, dahu ai basio noho.   
\q1
\v 23 Legamu a gadaia, lau ihahemaoro-henigu totona a noga;  
\q2 egu Dirava, egu Ḡaubada, lau ihamaoromaorogu totona a noga.   
\q1
\v 24 Iehova e, egu Dirava, a gvauraigu maoro, oiemu kara maoromaoro heḡereḡerena;  
\q2 bona ba laodia ahu, basie kirikirilaigu.   
\q1
\v 25 Idia na basie hereva heheni, basieto  
\q2 “Aha, eda ura vada ta abia;”  
\q1 ma basieto  
\q2 “Ita ese vada ta hadonoa”.   
\b  
\q1
\v 26 Egu hisihisi e moalelaiamu taudia na  
\q2 ba hahemaraidia bona ba dadaraidia vaitani;  
\q1 edia daḡedaḡe egu ai e habadaiamu taudia na  
\q2 hemarai bona hedadarai amo ba ḡovadia.   
\b  
\q1
\v 27 Igwaurai-maorogu e uramu taudia na  
\q2 bae hisi dae bona bae moale;  
\q1 bae hereva hanaihanai, baeto  
\q2 “Iehova na herea,  
\q2 ia ese ena hesiai tauna ihanamona e moalelaiamu”.   
\q1
\v 28 Bena malagu ese oiemu kara maoromaoro baine gwauraia,  
\q2 bona dina idoinai baine imodaimu.   
\c 36  
\q1
\v 1 Kerere ese kara dika tauna e hereva heniamu,  
\q2 ia lalona ai e herevamu;  
\q1 Dirava igari-henina na  
\q2 ia matana ai se miamu.   
\q1
\v 2 Ia sibona matana ai e heaḡimu, e tomu,  
\q2 ena kara dika na ta ese basine davaria,  
\q2 bona basine inai henia diba.   
\q1
\v 3 Ia uduna herevadia na didika bona kokoikoi;  
\q2 aonega karadia bona kara namodia vada e hadoko.   
\q1
\v 4 Ena mahuta patana ai kara dikadia e haeromu;  
\q2 dala asi namona e rakalaiamu,  
\q2 kara dika na se dadaraiamu.   
\b  
\q1
\v 5 Iehova e, oiemu hebogahisi na guba e dae laomu,  
\q2 emu heabidadama na ori ai e kaumu.   
\q1
\v 6 Oiemu kara maoromaoro na Dirava ena ororo na heheto,  
\q2 emu hahemaoro na gadobada na heto.  
\q1 Iehova e, taunimanima bona mauri ḡaudia idau-idau danu  
\q2 oi ese o hamauridiamu.   
\b  
\q1
\v 7 Dirava e, emu hebogahisi na herea-dae;  
\q2 taunimanima natudia ese oi hanimu ikerukerudia ai e komumu.   
\q1
\v 8 Emu ruma anianidia e ani boga kunumu;  
\q2 emu moale sinavaina amo o ha-inudiamu.   
\q1
\v 9 Badina be mauri ranuna na oiemu amo e lohi lohi daemu,  
\q2 bona oiemu diari ai diari a itaiamu.   
\b  
\q1
\v 10 Emu hebogahisi ba hahesiriua, oiemu ai e manadamu taudia ediai;  
\q2 emu hahemauri danu, lalodia mamaoro-mamaoro taudia ediai.   
\q1
\v 11 Hekokoroku tauna aena ese basine moigu tao,  
\q2 kara dika tauna imana ese basine dorigu oho.   
\q1
\v 12 Kara dika taudia na e goru paraparamu;  
\q2 vada e doridia dobi, asi edia tore isi dalana ta.   
\c 37  
\q1
\v 1 Alomu na basine hekwarahi kara dika taudia daidiai,  
\q2 kara kerere taudia danu basio vaḡeḡe henidia.   
\q1
\v 2 Badina be asi vanahana bae utudia, rei na heto;  
\q2 bae kakoro, au raudia na heheto.   
\b  
\q1
\v 3 Iehova bavabidadama henia, kara namo ba kara;  
\q2 bena tano ai ba noho, mai mainomu ida.   
\q1
\v 4 Iehova ba moalelaia;  
\q2 oi lalomu ena ura ia ese baine henimu.   
\b  
\q1
\v 5 Oiemu dala idoinai Iehova imana ai bavatoa;  
\q2 ia bavabidadama henia, ia ese baine gaukaralaia.   
\q1
\v 6 Oi igwaurai-maoromu ia ese baine hahedinaraia diari na heto;  
\q2 oiemu kara maoromaoro danu dina tubua na heto.   
\q1
\v 7 Iehova enai ba laḡa ani,  
\q2 ia ba naria mai haheaukamu ida;  
\q1 Ialomu basine hekwarahi, ena ḡaukara ai e tagamu tauna dainai,  
\q2 eiava ena lalo-hadai dikadia anidia e karamu tauna dainai.   
\b  
\q1
\v 8 Badu baine mia, daḡedaḡe ba rakatania.  
\q2 Lalomu basio hahekwarahia: una na kara dika e havaraiamu.   
\q1
\v 9 Badina be kara dika taudia na bae henege daure;  
\q2 a Iehova e nariamu taudia ese tano bae abia.   
\b  
\q1
\v 10 Asi vanahana kara dika tauna baine puki;  
\q2 ena gabu ba tahua, to basio davaria.   
\q1
\v 11 A manau taudia ese tano bae abia;  
\q2 maino ena harihari-bada idia ese bae moalelaia.   
\b  
\q1
\v 12 Kara dika tauna ese kara maoromaoro tauna ihadikana daladia e haeromu,  
\q2 gadigadina e hahedai heniamu;   
\q1
\v 13 a Ḡaubada ese kara dika tauna e kirikirilaiamu,  
\q2 badina be e itaiamu, ena dina be maimu.   
\b  
\q1
\v 14 Kara dika taudia ese dare e veridia lasimu,  
\q2 bona edia peva e marediamu,  
\q1 ogoḡami taudia bona e dabumu taudia ialadia totona,  
\q2 bona kara maoromaoro taudia iala-masedia totona.   
\q1
\v 15 Edia dare na sibodia kudoudia ai bae vareai,  
\q2 bona edia peva bae kwaidu.   
\b  
\q1
\v 16 Kara maoromaoro tauna ena ogoḡami ese  
\q2 kara dika taudia hutuma edia taḡa e hereaiamu.   
\q1
\v 17 Badina be kara dika taudia imadia na bae kwaidu,  
\q2 a Iehova ese kara maoromaoro taudia e haginidia toremu.   
\b  
\q1
\v 18 Iehova ese asi edia kerere taudia edia dina dibana,  
\q2 idia ahudia bae mia hanaihanai.   
\q1
\v 19 Haida ese asie hahemaraidiamu dika negadia ai,  
\q2 bona doe negadia ai bogadia e kunumu.   
\b  
\q1
\v 20 A kara dika taudia na e mase oremu;  
\q2 Iehova inaina loḡora na rei gabudia hairaidia na heto,  
\q2 idia na e boiomu, kwalahu ai e boio vaitanimu.   
\q1
\v 21 Kara dika tauna na e abi torehaimu, bena ihalouna asi dibana  
\q2 a kara maoromaoro tauna na mai ena harihari-bada ida e henimu.   
\q1
\v 22 Badina be Iehova ese e hanamodiamu taudia ese tano bae abia  
\q2 a baine ihi-ihiraidia taudia na bae henege daure.   
\b  
\q1
\v 23 Tau namona ena ae-raka na Iehova ese e reḡuamu,  
\q2 bona ena dala e moalelaiamu tauna na ia ese e haginiamu.   
\q1
\v 24 Ia na baine keto, to basine moru dobi;  
\q2 badina be Iehova ese ia imana amo e dogoa taomu.   
\b  
\q1
\v 25 Lau be gunaguna na eregabe, harihari vada na buruka;  
\q2 a lau ese nega hata kara maoromaoro tauna ta vada e baia na do asina itaia,  
\q2 eiava natuna na aniani e noi hegame ai do asina itaia.   
\q1
\v 26 Ia na nega iboudiai e hariharimu bona e heni torehaimu,  
\q2 bona ia natuna na taunimanima ihanamodia taudia ai vada ela.   
\b  
\q1
\v 27 Kara dika ba rakatanidia, kara namo ba kara;  
\q2 bena ba noho hanaihanai.   
\q1
\v 28 Badina be Iehova na kara maoromaoro e ura heniamu;  
\q2 ena helaḡa taudia na basine rakatanidia.  
\q1 Kara maoromaoro taudia na bae mauri hanaihanai;  
\q2 a kara dika taudia natudia na bae henege daure.   
\q1
\v 29 Kara maoromaoro taudia ese tano bae abia,  
\q2 bae noholaia hanaihanai.   
\b  
\q1
\v 30 Kara maoromaoro tauna uduna ese aonega herevadia e gwauraimu,  
\q2 ia malana ese hahemaoro herevadia e gwauraimu.   
\q1
\v 31 Ena Dirava ena taravatu na lalona ai;  
\q2 ia aena na se dedimu.   
\b  
\q1
\v 32 Kara dika tauna ese kara maoromaoro tauna e itaia taomu,  
\q2 ia iala-masena dalana e tahuamu.   
\q1
\v 33 Iehova ese ia imana ai basine negea,  
\q2 bona bae hahemaoro henia negana ai baine rudia, basie revaia.   
\q1
\v 34 Iehova ba naria, iena dala ai ba raka,  
\q2 bena baine abimu dae, tano na bavabia oiemu;  
\q2 kara dika taudia ihabua-taridia danu ba itaia.   
\b  
\q1
\v 35 Kara dika tauna vada na itaia, e lao hereava,  
\q2 e tubu badabadava, Lebanon ai sida auna ta na heto;   
\q1
\v 36 Ma na raka hanai, ia na lasihia;  
\q2 na tahua, to asina davaria.   
\q1
\v 37 Asi ena kerere tauna ba haeroa, bona kara maoromaoro tauna ba itaia,  
\q2 badina be dokona ai ia ese maino baine abia.   
\q1
\v 38 A kara dika taudia na bae mase ore,  
\q2 dokona ai bae henege daure.   
\b  
\q1
\v 39 Kara maoromaoro taudia ihamauridia na Iehova ena amo;  
\q2 ia na edia hahemauri gabuna, hekwarahi negadia ai.   
\q1
\v 40 Iehova ese e durudiamu bona e hamauridiamu;  
\q2 ia ese kara dika taudia imadia amo e hamauridiamu, e harohodia maurimu,  
\q2 badina be idia ese ia e abidadama heniamu.   
\c 38  
\q1
\v 1 Iehova e, emu badu ai basio gwvau henigu,  
\q2 emu badu ḡaraḡara ai basio hahisigu;   
\q1
\v 2 badina be emu diba na lauegu ai vada e heholo vareai,  
\q1 oi imamu metauna na latagu ai.   
\b  
\q1
\v 3 Hidiogu na se digaramu, emu badu dainai;  
\q2 turiagu na asie aukamu, egu kara dika daidiai;   
\q1
\v 4 badina be egu kara havara na kwaragu ai vada e kau,  
\q2 idia na maduna metauna na heto, ihuana na asi goadagu.   
\b  
\q1
\v 5 Berogu na bonadia e daemu, vada e bodaga,  
\q2 egu kavakava dainai.   
\q1
\v 6 Lau na igo dihomu, na goru dihomu,  
\q2 dina idoinai na tai ḡadeḡademu.   
\b  
\q1
\v 7 Badina be taugu anina e siahumu,  
\q2 hidiogu na se aukamu.   
\q1
\v 8 Vada na manoka, hisi ese e gugubagumu;  
\q2 na ḡanaḡanamu, daragu e dokomu dainai.   
\b  
\q1
\v 9 Ḡaubada e, egu ura idoinai oi dibamu,  
\q2 egu ḡanaḡana na emu ai se hehunimu.   
\q1
\v 10 Kudougu e hetahamu, egu goada e oremu;  
\q2 matagu diaridia danu vada e rakatanigu.   
\q1
\v 11 Turagu bona bamogu na egu gorere amo e gini daudaumu,  
\q2 bona varavaragu na dahu ai gigini.   
\b  
\q1
\v 12 Egu mauri e tahuamu taudia ese edia idoa e atomu;  
\q2 ihadikagu e uramu taudia ese hereva dikadia na latagu ai e gwauraimu,  
\q2 bona dina idoinai ikoigu daladia e haeromu.   
\q1
\v 13 A lau na taia-kudima tauna na heto, asina kamonaimu,  
\q2 mu tauna, uduna se haḡaiamu, na heto.   
\q1
\v 14 Oibe, lau na se kamonaimu tauna na heto,  
\q2 uduna ai gwaugwau herevadia asie miamu tauna na heto.   
\b  
\q1
\v 15 Iehova e, lau oi na narimumu;  
\q2 Ḡaubada e, egu Dirava, oi ba haere.   
\q1
\v 16 Badina be na ḡuriḡurimu, na tomu  
\q2 “Mani emu kara aegu e dedimu negadia ai e heaḡimu taudia na ba laodia ahu, basie kirikirilaigu”.   
\b  
\q1
\v 17 Badina be lau na vada ba ketomu,  
\q2 egu hisihisi na vairagu ai e miamu nega idoinai.   
\q1
\v 18 Egu kara dika na gwaurai hedinaraimu,  
\q2 egu kara havara amo na helalo kerehaimu.   
\q1
\v 19 Asi badina e inai henigumu taudia na mai goadadia,  
\q2 e inai henigu koikoimu taudia na hutuma.   
\q1
\v 20 Egu kara namo na dika e davanalaiamu taudia na lau inaigu,  
\q2 badina be lau ese namo na ḡavaiamu.   
\b  
\q1
\v 21 Iehova e, basio rakatanigu;  
\q2 egu Dirava e, egu amo dauhai basio noho.   
\q1
\v 22 Ḡaubada e, lau ihamaurigu Diravana,  
\q2 a durugu haraḡa.   
\c 39  
\q1
\v 1 Lau nato “Egu dala nahuadia baina toho,  
\q2 malagu amo kara dika baina havaraia na garina;  
\q1 udugu baina hakapua,  
\q2 kara dika taudia na dekegu ai e nohomu negadia iboudiai”.   
\q1
\v 2 Lau na asi reḡereḡegu, asi egu hereva,  
\q2 hereva ta asina gwauraia, to se heḡereḡere;   
\q1
\v 3 egu lalo-hisihisi vada e bada e laova,  
\q2 lalogu na e siahu e laova;  
\q1 na haeroava lalonai lahi e arava,  
\q2 bena malagu amo na hereva.   
\b  
\q1
\v 4 Iehova e, egu doko negana boma hadibagu,  
\q2 egu dina na ede hohodia;  
\q2 egu mauri ede e heau tomamu bama diba.   
\q1
\v 5 A itaia, egu dina vada o kara, ima lababadia hida hodia na heto;  
\q2 egu mauri na dia ḡau ta oi vairamu ai.  
\q1 Momokani, taunimanima iboudiai edia mauri na hahodi tamona na heto; (Selah)   
\q2
\v 6 momokani, taunimanima na e loaloamu, vabura na heto.  
\q1 Momokani, edia hekwarahi na asi anina;  
\q2 idia ese taḡa e habouamu, a asi dibadia daika ese baine abia.   
\q1
\v 7 Ḡaubada e, dahaka na nariamu?  
\q2 Egu helaro na oi.   
\q1
\v 8 Egu kara dika iboudiai lalodia amo ba harohogu mauri;  
\q2 kavakava taudia na ba laodia ahu, basie ihi-ihiraigu.   
\q1
\v 9 Lau na asi reḡereḡegu, udugu asina haḡaia;  
\q2 badina be oi ese o karaia.   
\q1
\v 10 Emu hekwadi na egu amo bavabia oho;  
\q2 oi imamu ena hedadaba ese vada e alagu.   
\b  
\q1
\v 11 Taunimanima na edia kara dika daidiai o gwau henidiamu negedia ai na  
\q2 idia hairaidia o ha-oreamu, kaubebe na heto.  
\q2 Momokani, taunimanima iboudiai na hahodi tamona na heto. (Selah)   
\b  
\q1
\v 12 Iehova e, egu ḡuriḡuri ba kamonai;  
\q2 egu taitai ba hakala henia;  
\q1 iruru-matagu ba itadia negana ai,  
\q2 udumu basio hakapua.  
\q1 Badina be lau na emu vadivadi;  
\q2 lau na noho-hedoa taugu, senegu iboudiai heḡereḡeredia.   
\q1
\v 13 Egu amo ba mede kerehai, bena moale baina diba,  
\q2 ini amo do basina raka oho basina lao bubuni negana ai.   
\c 40  
\q1
\v 1 Iehova na nariava mai haheaukagu ida;  
\q2 ia ese e igo diho henigu, egu taitai e kamonai.   
\q1
\v 2 Ia ese guri dikana amo e verigu lasi,  
\q2 kopukopu gabuna amo e abigu isi;  
\q1 aegu na nadi badana latanai e atodia kau,  
\q2 egu raka e reḡua.   
\q1
\v 3 Ia ese ane matamata na udugu ai e atoa,  
\q2 eda Dirava ihanamolaina anena.  
\q1 Hutuma bae itaia, bena bae gari,  
\q2 bona Iehova bae abidadama henia.   
\b  
\q1
\v 4 Iehova e abidadama heniamu tauna na namo;  
\q2 ia ese heaḡi taudia se matauraidiamu,  
\q2 bona dirava koikoidia ilao-henidia totona e raka sirimu taudia se haḡerediamu.   
\q1
\v 5 Iehova e, egu Dirava, emu hoa karadia bona ilalolaimai lalo-hadaidia  
\q2 vada o habada emai ai;  
\q2 oi na asi idaimu.  
\q1 Bama gwauraidia bona bama herevalaidia,  
\q2 to basinama duahidia diba.   
\b  
\q1
\v 6 Rara boubouna bona flaoa boubouna na so uramu,  
\q2 a taiagu vada o hakiraradia.  
\q1 Ḡole-oho boubouna bona kara-dika boubouna  
\q2 oi ese so gwauraimu.   
\q1
\v 7 Bena lau nato “A itaia, na vasimu,  
\q2 buka ilokuna ta ai vada e torelaigu:   
\q1
\v 8 egu Dirava e, oiemu ura ikarana na moalelaiamu,  
\q2 oiemu taravatu na lalogu ai e miamu”.   
\b  
\q1
\v 9 Hahemauri sivaraina namona vada na gwauraia,  
\q2 hebou badana lalonai;  
\q1 Iehova e, oi dibamu,  
\q2 bibinagu asina hakapudia.   
\q1
\v 10 Oiemu kara maoromaoro na lalogu ai asina hunia,  
\q2 emu heabidadama bona emu hahemauri vada na herevalaidia;  
\q1 emu hebogahisi bona emu hereva momokani na  
\q2 hebou badana amo asina hunia.   
\b  
\q1
\v 11 Iehova e, emu hebogahisi na egu amo basio rua;  
\q2 emu lalokau bona emu heabidadama ese bae reḡugu hanaihanai.   
\q1
\v 12 Badina be hahedika momo herea vada e ḡeḡegu ahu,  
\q2 egu kara havara ese vada e lasigu tao,  
\q2 asi egu dala baina gaga isi;  
\q1 idia na momo herea, kwaragu huidia na dia hoho;  
\q2 daragu na e dokomu.   
\b  
\q1
\v 13 Iehova e, mani emu kara ba hamaurigu,  
\q2 Iehova e, ba durugu haraḡa.   
\q1
\v 14 Egu mauri iabi ohona dalana e tahuamu taudia na  
\q2 ba hahemaraidia bona ba haheḡonudia;  
\q1 ihahisigu e uramu taudia na  
\q2 ba haloudia bona ba hahemaraidia;   
\q1
\v 15 e gwau henigumu, e tomu “Aha, aha”, taudia na  
\q2 edia hemarai dainai bae kudou hetaha.   
\b  
\q1
\v 16 A e tahumumu taudia iboudiai na bae moale,  
\q2 oi bae moalelaimu.  
\q1 Emu hahemauri e ura heniamu taudia bae hereva loulou,  
\q2 baeto “Iehova na herea dae”.   
\q1
\v 17 Lau be na ogoḡamimu bona na dabumu,  
\q2 A Ḡaubada ese e lalogumu.  
\q1 Dirava e, basio halahe;  
\q2 oi na lau ikahagu bona lau ihamaurigu Diravana.   
\c 41  
\q1
\v 1 Ogoḡami taudia e lalodiamu tauna na namo;  
\q2 Iehova ese e harohoa maurimu, hekwakwanai dinana ai;   
\q1
\v 2 Iehova ese e gimaiamu bona e hamauriamu;  
\q2 tano ai namo e gwauraiamu;  
\q2 ia na inaina edia ura dalana ai asio heni.   
\q1
\v 3 Gorere dainai ena geda ai e hekuremu negadia ai  
\q2 Iehova ese e abia isimu;  
\q1 ena gorere lalodiai,  
\q2 oi ese ena hisihisi iboudiai o abi ohomu.   
\b  
\q1
\v 4 Lau nato “Iehova e, a bogagu hisi, ba hamaurigu;  
\q2 badina be lau ese vada na kara havara henimu”.   
\q1
\v 5 Lau inaigu ese e maumauraigumu, e tomu  
\q2 “Edena nega ai baine mase?  
\q2 Ia ladana na edena nega ai baine boio?”   
\q1
\v 6 Ta dekegu ai e maimu negana ai,  
\q2 ia ese hereva asi anidia e gwauraimu.  
\q1 Lalo-hadai dikadia na lalona ai e haboumu;  
\q2 bena e raka lasimu, e piu rohorohomu.   
\q1
\v 7 E inai henigumu taudia iboudiai ese lau e hemaunulai henigumu,  
\q2 ihadikagu daladia e haeromu.   
\b  
\q1
\v 8 Idia na e tomu “Gorere dikana ese vada e abia,  
\q2 ena hekure gabuna amo basine tore isi lou”.   
\q1
\v 9 Turagu lalokauna danu, na abidadama heniava tauna, egu aniani e aniava tauna,  
\q2 ia ese danu ia ae-geduna amo vada e lahagu.   
\q1
\v 10 Iehova e, oi ese ba bogagu hisi;  
\q2 bavabigu isi, bena davadia do baina henidia.   
\b  
\q1
\v 11 Ini amo lau dibagu oi ese o lalo namo henigumu,  
\q2 inaigu ese se hadareregu dainai.   
\q1
\v 12 Oi ese vada o haginigu tore, egu kara maoromaoro dainai;  
\q2 oi vairamu ai vada o haginigu hanaihanai.   
\q1
\v 13 Iehova, Israel Diravana, bae hanamoa,  
\q2 harihari ela bona hanaihanai. Amen. Amen.   
\c 42  
\q1
\v 1 Dirava e, dia hahinena ese sinavai ranudia e ura henidiamu na heto,  
\q2 lau laumagu ese unu e ura henimu tomamu.   
\q1
\v 2 Laumagu na e ranu masemu, Dirava enai, Mauri Diravana enai.  
\q2 Edena nega ai Dirava vairana baina itaia?   
\b  
\q1
\v 3 Iruru-matagu na agu aniani ḡauna,  
\q2 dina ai bona hanuaboi ai;  
\q1 Nega idoinai taunimanima ese e nanadaigu louloumu,  
\q2 e tomu “Emu Dirava be edeseni ai?”   
\b  
\q1
\v 4 Laumagu ena hisihisi ai  
\q2 na lalodia taomu ḡaudia bini:  
\q1 hutuma ida na laova,  
\q2 Dirava ena ruma ai na hakaudia vareaiva,  
\q1 mai moale lolodia bona ihanamolaidia anedia ida;  
\q2 hutuma bada ese aria helaḡana e karaiava.   
\b  
\q1
\v 5 Laumagu e, dahaka dainai vada o metau?  
\q2 Dahaka hekwarahina lalogu ai o karaiamu?  
\q1 Dirava ba laroa; badina be lau do baina hanamoa lou,  
\q2 lau ikahagu bona egu Dirava.   
\q1
\v 6 Laumagu na e metaumu lalogu ai;  
\q2 taunabunai oi mo na lalomu taomu,  
\q1 Ioridane tanona bona Heremon tanona amo,  
\q2 bona Misara ororona amo.   
\b  
\q1
\v 7 Dobu gabuna ta ese dobu gabuna ta e boi heniamu,  
\q2 ranu seiraina guruna ai.  
\q1 Emu hurehure bona emu sinaia iboudiai ese  
\q2 vada e habubunigu.   
\q1
\v 8 Dina ai Iehova ese ena hebogahisi e haheḡanilaiamu,  
\q2 hanuaboi ai ena ane ese e bamogumu;  
\q2 ḡuriḡuri danu, egu mauri Diravana ena.   
\b  
\q1
\v 9 Dirava, egu nadi-gini, na hereva heniamu, na tomu  
\q2 “Dahaka dainai vada o lalogu boio?  
\q1 Badina be dahaka na tai ḡadeḡademu,  
\q2 inaigu edia daḡedaḡe karadia daidiai?”   
\q1
\v 10 Tau-anigu bema haberoa na heto,  
\q2 inaigu ese lalogu e daia urumu.  
\q1 E nanadaigu louloumu, e tomu  
\q2 “Emu Dirava be edeseni ai?”   
\q1
\v 11 Laumagu e, dahaka dainai vada o metau?  
\q2 Dahaka hekwarahina lalogu ai o karaiamu?  
\q1 Dirava ba laroa; badina be lau do baina hanamoa lou,  
\q2 lau ikahagu bona egu Dirava.   
\c 43  
\q1
\v 1 Dirava e, ba gwauraigu maoro;  
\q2 se matauraimumu besena enai maorogu ba gwauraia;  
\q2 kara koikoi bona kara gageva-gageva taudia imadia amo ba hamaurigu.   
\q1
\v 2 Oi na lau igimagu Diravana;  
\q2 dahaka dainai vada o negegu daure?  
\q1 Badina be dahaka na tai ḡadeḡademu,  
\q2 inaigu edia daḡedaḡe karadia daidiai?   
\b  
\q1
\v 3 Emu diari bona emu hereva momokani a siaia mai,  
\q2 idia ese bae hakaugu;  
\q1 emu ororo helaḡana bona emu noho kalagana ediai  
\q2 bae hakaugu vasi.   
\q1
\v 4 Bena Dirava ena ihaboulaina patana baina lao henia;  
\q2 na moalelaia badamu Diravana baina lao henia.  
\q1 Dirava e, egu Dirava,  
\q2 lau ese gitara amo baina hanamomu.   
\b  
\q1
\v 5 Laumagu e, dahaka dainai vada o metau?  
\q2 Dahaka hekwarahina lalogu ai o karaiamu?  
\q1 Dirava ba laroa; badina be lau do baina hanamoa lou,  
\q2 lau ikahagu bona egu Dirava.   
\c 44  
\q1
\v 1 Dirava e, taiamai amo vada a kamonai,  
\q2 tamamai ese vada e hamaoromai,  
\q1 idia edia dina ai dahaka dahaka o kara,  
\q2 nega gunadia ai.   
\q1
\v 2 Sibomu imamu amo bese idau-idau o luludia lasiva,  
\q1 a idia na o atodia;  
\q2 bese idau-idau oi ese o hahisidiava,  
\q1 a idia na o hamauridia.   
\q2
\v 3 Badina be dia idia sibodia edia dare amo tano e abia,  
\q2 bona dia idia sibodia imadia amo e kwalimu;  
\q1 a oi imamu idibana amo,  
\q2 oi imamu bona oi vairamu diarina amo;  
\q2 badina be oi ese o moalelaidiava.   
\q1
\v 4 Oi na egu Pavapava bona egu Dirava;  
\q2 oi ese Iakob ihamaurina vada o gwauraia.   
\q1
\v 5 Oi bagumu ai ai inaimai a hadarerediamu,  
\q2 oi ladamu bagunai e tuari henimaimu taudia na baia moimoilaidia.   
\q1
\v 6 Badina be dia egu peva asina abidadama heniamu,  
\q2 dia egu dare ese basine hamaurigu;   
\q1
\v 7 a oi ese ai inaimai imadia amo vada o hamaurimai,  
\q2 e inai henimaimu taudia vada o haheḡonudia.   
\q1
\v 8 Nega idoinai Dirava vada a heaḡilaia;  
\q2 oi ladamu baia imodaia hanaihanai. (Selah)   
\q1
\v 9 A oi ese vada o negemai daure, bona vada o hahemaraimai,  
\q2 emai tuari oredia ida asiola.   
\q1
\v 10 Inaimai vairadiai vada o haloumai;  
\q2 inaimai ese emai kohu vada e dadihai.   
\q1
\v 11 E aladiamu mamoedia heḡereḡeredia ai vada o halaomai,  
\q2 bese idau-idau bogaragidiai vada o hakarohomai rohoroho.   
\q1
\v 12 Emu orea taudia na vada o hoidia, dava maraḡi ai,  
\q2 idavalaidia badana na asio tahuamu.   
\b  
\q1
\v 13 Dekemai taudia ese bae kirikirilaimai taudia ai vada o halaomai,  
\q2 e ḡeḡemai daemu taudia ese bae hevasehalaimai bona bae dadaraimai taudia ai vada o halaomai;   
\q1
\v 14 bese idau-idau bogaragidiai bae ihi-ihiraimai taudia ai vada o halaomai,  
\q2 orea idau-idau bogaragidiai kwaradia bae taiko-taiko henimai taudia ai vada o halaomai.   
\q1
\v 15 Dina idoinai egu keto na vairagu ai,  
\q2 hemarai ese vairagu vada e ḡovaia;   
\q1
\v 16 hevaseha taudia bona heihi-ihirai taudia edia hereva daidiai,  
\q2 inai tauna bona dava iabina tauna daidiai.   
\b  
\q1
\v 17 Ena be asia lalomu boio, bona emu taravatu asia tataia utu,  
\q2 to ina idoinai na ai latamai ai vada e kau   
\q1
\v 18 Ai lalomai na asie lou,  
\q2 bona aemai na emu dala amo asie raka siri;   
\q1
\v 19 matona, oi ese uda sisiadia edia gabu ai vada o huarimai,  
\q2 bona dibura masemase ai vada o ḡovamai.   
\b  
\q1
\v 20 Emai Dirava ladana baiama laloa boio,  
\q2 eiava imamai na dirava idauna ta bema toi roro henia,   
\q1
\v 21 Dirava basinema davaria a?  
\q2 Badina be ia na lalo-hadai hehunidia dibana.   
\q1
\v 22 Lasi, oi daimu ai dina idoinai e alamaimu,  
\q2 e duahimaimu, bae aladia mamoedia na heheto.   
\q1
\v 23 A noga! Ḡaubada e, dahaka dainai o mahutamu?  
\q2 A tore isi! Basio negemai daure hanaihanai.   
\q1
\v 24 Dahaka dainai vairamu o huniamu?  
\q2 Dahaka dainai emai hekwarahi bona emai hisihisi o lalo boiomu?   
\q1
\v 25 Badina be laumamai na ḡahu ai e igo dihomu,  
\q2 tau-animai na tano ai e goru dihomu.   
\q1
\v 26 A tore isi, ikahamai aoma!  
\q2 emu hebogahisi dainai ba hamaurimai.   
\c 45  
\q1
\v 1 Lalogu na ḡau namona amo e hepurai dobimu;  
\q2 egu hereva na hanua pavapavana enai na gwauraiamu,  
\q2 malagu na toretore e manadamu tauna ena pen na heto.   
\b  
\q1
\v 2 Taunimanima natudia iboudiai bogaragidiai  
\q2 oi mo sibomu o raho namo hereamu;  
\q1 harihari-bada na bibinamu ai e hebubu kaumu,  
\q2 taunabunai Dirava ese vada e hanamomu hanaihanaimu.   
\q1
\v 3 Siahu taumu e, emu dare na koekoemu ai bavatoa,  
\q2 mai hairaimu ida bona mai siahumu ida.   
\q1
\v 4 Emu hosi ai ba gui, mai siahumu ida baola, ba kwalimu;  
\q2 hereva momokani dainai bona kara maoromaoro igimana totona,  
\q2 imamu idibana ese hahegari karadia baine hadibalaimu.   
\q1
\v 5 Emu diba na mai matadia, hanua pavapavana inaina kudoudia ai e hedai kaumu;  
\q2 bese idau-idau taudia na oi henumu ai e ketomu.   
\b  
\q1
\v 6 Oiemu terono helaḡana e mia hanaihanaimu,  
\q2 oiemu pavapava aurla na hahemaoro auna.   
\q1
\v 7 Kara maoromaoro o ura henimu,  
\q2 bona kara dika o inai henimu;  
\q1 taunabunai Dirava, oiemu Dirava, ese vada e horomu,  
\q2 moale dehorona vada e horolaimu, oi bamomu daediai.   
\q1
\v 8 Emu dabua amo muro bona aloe bona kasia\f + \fr 45:8 \ft “Muro” bona “aloe” bona “kasia” na muramura mai bonadia ladadia. “Aivori” na elefant doadia.\f* bonadia e daemu;  
\q2 pavapava edia aivori rumadia amo hatai-hatai ḡaudia ese e hamoalemumu.   
\q1
\v 9 Pavapava natudia hahinedia na emu ruma hahinedia bogaragidiai;  
\q2 oi idibamu kahana ai pavapava hahinena mai Ofiri \it gold\it* dabuana ida gini.   
\q1
\v 10 Hane-ulato e, a haeroa, a hakala henigu,  
\q2 emu bese taudia bona tamamu ena ruma ba lalodia boio;   
\q2
\v 11 bena hanua pavapavana ese oi hairaimu baine ura henia.  
\q1 Ia na emu lohia dainai ba igo henia diho;   
\q2
\v 12 bena Turo ulatodia na herahia bae mailai.  
\q2 bona taḡa herea taudia edia noinoi na oi dekemu bae mailai.   
\q1
\v 13 Hanua pavapavana natuna kekenina na mai hairaina, ena daiutu lalonai;  
\q2 ena dabua na \it gold\it* varodia ai e haheraiamu.   
\q1
\v 14 Dabua herea-daedia ai ia na hanua pavapavana dekena e hakaua vareaimu,  
\q2 mai bamona, hane-ulato rami-heboudia, ida, ia murinai e rakamu;   
\q1
\v 15 mai moaledia ida, mai moale-badadia ida e hakaudia laomu,  
\q2 hanua pavapavana ena ruma ai e raka vareaimu.   
\b  
\q1
\v 16 Natumui mamaruanedia ese tamamui bae bolodia,  
\q2 tanobada idoinai lohiadia ai ba halaodia.   
\q1
\v 17 Oi ladamu baina habadaia, uru iboudiai ese bae imodaia,  
\q2 taunabunai bese idau-idau ese bae hanamomu ela bona hanaihanai.   
\c 46  
\q1
\v 1 Dirava na eda roho-mauri gabuna, bona eda goada,  
\q2 ikahada namo-hereana dika negadia ai.   
\q1
\v 2 Una dainai ita na basita gari,  
\q2 ena be tanobada baine idau,  
\q2 ena be ororo bae marere-marere davara bogaraginai,   
\q1
\v 3 ena be davara ranudia bae regerege bona bae gwaragwara,  
\q2 ena be ororo bae heude-heude una regerege dainai,  
\q2 to ita na basita gari. (Selah)   
\q1
\v 4 Sinavai ta ena aru parara ese Dirava ena hanua vada e hamoalea,  
\q2 Herea Mikamika ena noho gabuna helaḡana bunai.   
\q1
\v 5 Dirava na ia bogaraginai, ia na basine marere;  
\q2 Dirava ese ia baine kahaia, daba matana ai.   
\q1
\v 6 Tanobada besedia e heloḡo-heloḡomu,  
\q2 basileia idau-idau e raivaraivamu;  
\q1 ia gadona e gwau isimu,  
\q2 bena tanobada e vevemu.   
\q1
\v 7 Iehova Sabaota na ita ida;  
\q2 Iakob ena Dirava na eda kohoro. (Selah)   
\q1
\v 8 Aoma, Iehova ena ḡaukara a itaia;  
\q2 hahedika karadia ia ese tanobada ai vada e kara.   
\q1
\v 9 Tuari ia ese e hadokodiamu ela bona tanobada dokona,  
\q2 peva ia ese e bituamu,  
\q2 io ia ese e hakwaiduamu,  
\q2 kariota ia ese lahi ai e douamu.   
\q1
\v 10 Eremui, ba diba, lau na Dirava;  
\q2 bese idau-idau bogaragidiai e imodaigumu,  
\q2 tanobada ai e heatolaigumu.   
\q1
\v 11 Iehova Sabaota na ita ida;  
\q2 Iakob ena Dirava na eda kohoro. (Selah)   
\c 47  
\q1
\v 1 Bese idau-idau iboumui ai, imamui ba poupou;  
\q2 Dirava ba lolo henia, moale anedia ba lololai.   
\q1
\v 2 Badina be Iehova, Herea Mikamika, na mai garina;  
\q2 ia na Pavapava badana, tanobada idoinai e lohiaiamu.   
\q1
\v 3 Ia ese bese idau-idau ita henudai vada e hamanadadia,  
\q2 orea idau-idau aeda henudiai vada e atodia.   
\q1
\v 4 Ia ese ahuda vada e abia hidi,  
\q2 ena lalokau tauna Iakob ena heaḡi. (Selah)   
\q1
\v 5 Dirava na mai lolona ida vada e dae,  
\q2 Iehova na mai kibi reḡena ida vada e dae.   
\q1
\v 6 Dirava ba hanamoa, ia ihanamolaina anedia bavabi;  
\q2 eda Pavapava ba hanamoa, ia ihanamolaina anedia bavabi.   
\q1
\v 7 Badina be Dirava na tanobada idoinai pavapavana;  
\q2 salamo amo ba hanamoa.   
\b  
\q1
\v 8 Dirava ese bese idau-idau e lohiadiamu;  
\q2 Dirava na ena terono helaḡana ai e helaimu.   
\q1
\v 9 Bese idau-idau lohiadia e heboumu,  
\q2 Abraham ena Dirava ena bese ai baela.  
\q1 Badina be tanobada kesidia na Dirava ena;  
\q2 ia bae imodaia bada.   
\c 48  
\q1
\v 1 Iehova na bada; ia ihanamona danu baine bada,  
\q2 eda Dirava ena hanua ai.   
\q1
\v 2 Ena ororo helaḡana dorina na mai hairaina;  
\q2 tanobada idoinai ese ia e moalelaiamu.  
\q1 Siona ororona na dahu ai, mirigini kahana ai;  
\q2 ia na Pavapava badana ena hanua.   
\q1
\v 3 Ena ruma bogaragidiai Dirava eme hedinarai,  
\q2 kohoro na heto.   
\b  
\q1
\v 4 A itaia! Hanua pavapavadia e hebou,  
\q2 e raka hebouva.   
\q1
\v 5 E itaia negana ai e hoa dikadika,  
\q2 laumadia e daure, bena e heau;   
\q1
\v 6 unuseni ai taudia e heude-heude,  
\q2 e hisihisi bada danu, hahine e hekamonaimu na heto.   
\q1
\v 7 Lai mairiveina amo  
\q2 Tarasisi lagatoidia o huaridia.   
\b  
\q1
\v 8 Ai a kamonaiva heḡereḡerena vada a itaia danu,  
\q2 Iehova Sabaota ena hanua ai,  
\q2 emai Dirava ena hanua ai,  
\q1 Dirava ese vada e haginia hanaihanai hanuana bunai. (Selah)   
\q1
\v 9 Dirava e, emu hebogahisi vada a haeroa,  
\q2 emu dubu helaḡana bogaraginai.   
\q1
\v 10 Dirava e, oi ladamu e piua e laomu heḡereḡerena,  
\q2 ihanamomu danu e piua e laomu,  
\q2 ela bona tanobada dokodia.  
\b  
\q1 Oi imamu idibana na kwalimu ai e honumu;   
\q2
\v 11 Siona ororona baine moale,  
\q2 Iuda natuna hahinedia bae moale hisi dae,  
\q2 emu hahemaoro herevadia daidiai.   
\q1
\v 12 Siona ai ba loa, ba rakaia heḡeḡe,  
\q2 ena kohoro ba duahidia,   
\q2
\v 13 ena maḡu ba haerodia;  
\q1 ena ruma namodia ba itadia loaloa,  
\q2 uru gabena taudia do ba hamaorodia helaoreana.   
\b  
\q1
\v 14 Ina na Dirava, eda Dirava hanaihanai;  
\q2 ia ese baine kahada ela bona dokona.   
\c 49  
\q1
\v 1 Bese idau-idau taumui iboumui ai, a kamonai!  
\q2 Tanobada taumui iboumui ai, a hakala!   
\q1
\v 2 Henu taumui bona atai taumui,  
\q2 taḡa taumui bona ogoḡami taumui,  
\q2 orea tamona mo.   
\q1
\v 3 Udugu ese aonega baine gwauraia,  
\q2 lalogu ese lalo-parara herevadia baine haerodia.   
\q1
\v 4 Hereva heḡereḡerena baina hakala henia,  
\q2 egu hereva hehunina na gitara reḡena ese baine hahedinaraia.   
\b  
\q1
\v 5 Dahaka dainai baina gari, hekwakwanai negadia ai,  
\q2 eiava e daḡedaḡe henigumu taudia edia kara dika ese e ḡeḡegu ahumu negadia ai?   
\q1
\v 6 Idia ese edia taḡa e abidadama heniamu,  
\q2 edia kohu momo herea e heagilaimu.   
\q1
\v 7 Momokani, tau ta sibona basine hehoi lasi diba,  
\q2 ena mauri davana na Dirava basine henia diba;   
\q2
\v 8 badina be ena mauri davana na bada herea.  
\q1 Tau ta dia heḡereḡere   
\q2
\v 9 ena mauri baine hadaudaua hanaihanai,  
\q2 bona mase gabuna basine itaia.   
\q1
\v 10 Oibe, ia baine itaia, aonega taudia danu e masemu;  
\q2 kava tauna bona lalo-duhu tauna raruosi bae mase,  
\q2 bona edia taḡa na bae rakatani, haida edia.   
\q1
\v 11 Ena be tano haida e gwauraidia edia,  
\q2 to edia guri na edia ruma ela bona hanaihanai,  
\q2 edia noho gabudia ela bona uru iboudiai.   
\q1
\v 12 Tau ta na ena hairai ai basine noho diba,  
\q2 ia na e masemu boromadia na heheto.   
\b  
\q1
\v 13 E heaḡi kavamu taudia davadia binai,  
\q2 ahudia e moalelaimu taudia dokodia binai.   
\q1
\v 14 Mamoe na heheto mase gabuna baela;  
\q2 mase ese baine regudia, mamoe iregudia tauna na heto.  
\q1 Maoromaoro guri ai e dihomu,  
\q2 hairaidia vada bae ore,  
\q2 mase taudia edia gabu ai bae noho.   
\q1
\v 15 A Dirava ese lau laumagu davana baine karaia,  
\q2 mase siahuna amo baine rauaia;  
\q2 badina be ia ese baine abigu dae. (Selah)   
\b  
\q1
\v 16 Tau ta baine taḡa negana ai,  
\q2 bona ena ruma hairaina baine bada negana ai,  
\q2 basio gari.   
\q1
\v 17 Badina be baine mase negana ai ḡau ta basine abia kau, basine laohaia;  
\q2 ia hairaina basine diholaia.   
\q1
\v 18 Ena be ena mauri dinadia ai ia na sibona moale tauna ai baine hegwaurai,  
\q1 ena be sibona ena namo e havaraiamu tauna na bae imodaia,   
\q2
\v 19 to tamana ena uru taudia baine lao henidia;  
\q2 idia ese diari basie itaia lou.   
\q1
\v 20 Tau ta na ena hairai ai basine noho diba,  
\q2 ia na e masemu boromadia na heheto.   
\c 50  
\q1
\v 1 Goada-bada Diravana Iehova, vada e hereva,  
\q2 tanobada vada e boiria,  
\q1 dina e daemu gabuna amo  
\q2 ela bona dina e dihomu gabuna.   
\q1
\v 2 Siona, hairai-herea gabuna, amo  
\q2 Dirava diarina e taramu.   
\q1
\v 3 Eda Dirava na e maimu, asine mai kumamu,  
\q2 ia vairanai na lahi hururu-hururuna,  
\q2 lai gubadia ese e gegea ahumu.   
\q1
\v 4 Ia ese guba atai ai e boi heniamu, tanobada danu e boi heniamu,  
\q2 ena orea taudia baine hahemaoro henidia totona.   
\q1
\v 5 “E abidadama henigumu taudia ba haboudia egu” e tomu,  
\q2 “idia ese boubou karadia e kara, lau ida a herohemaino”.   
\q1
\v 6 Guba ese ena kara maoromaoro e gwauraimu,  
\q2 badina be Iehova sibona na hahemaoro tauna. (Selah)   
\q1
\v 7 Egu orea taumui e, a hakala, lau baina hereva;  
\q2 Israel e, baina habadelaimu.  
\q2 Lau na Dirava, emui Dirava.   
\q1
\v 8 Asina gwau henimuimu emui boubou daidiai;  
\q2 emui ḡole-oho bouboudia na lau vairagu ai nega idoinai.   
\q1
\v 9 Boromakau maruanena ta emui ruma amo basina abia,  
\q2 nani maruanena ta emui maḡu amo basina abia dae;   
\q1
\v 10 badina be uda ḡaudia iboudiai na lauegu,  
\q2 bona ororo daha-ta boromakaudia danu;   
\q1
\v 11 atai manudia iboudiai be dibagu,  
\q2 tano paka ai e laomu ḡaudia iboudiai na egu.   
\b  
\q1
\v 12 Bama hitolo, umui basinama hamaoromui;  
\q2 badina be tanobada mai anina idoinai ida na lauegu.   
\q1
\v 13 Boromakau mamaruanedia hidiodia na animu a?  
\q2 Nani raradia na inumu a?   
\q1
\v 14 Hahenamo na Dirava ba henia, emui boubou bunai;  
\q2 emui gwauhamata anidia ihamomokanidia na Herea Mikamika ba henia.   
\q1
\v 15 Hekwakwanai dinana ai lau ba boi henigu;  
\q2 bena lau ese umui baina hamaurimui,  
\q2 bona umui ese lau ba imodaigu.   
\b  
\q1
\v 16 A kara dika taudia na  
\q2 Dirava ese e hereva henidiamu, e tomu:  
\q1 Badina be dahaka egu taravatu o gwauraimu?  
\q2 Dahaka dainai egu gwauhamata herevadia na udumui bibinadia ai mimia?   
\q1
\v 17 Badina be mata-hakani o inai heniamu,  
\q2 bona egu hereva na murimui ai o negediamu.   
\q1
\v 18 Henao tauna o itaiamu negana ai o hetura heniamu;  
\q2 bona heuda-hanai taudia o bamodiamu.   
\q1
\v 19 Hereva dikadia na udumui amo e lasimu,  
\q2 malamui na hereva koikoidia e gwauraimu;   
\q1
\v 20 o helaimu, tadikakamui o habadelaidiamu,  
\q2 sinamui natudia mamaruanedia o habadelaidia koikoimu.   
\q1
\v 21 Ini vada o kara toma, asina hereva;  
\q2 umui banava oto lau na umui heḡereḡeremui.  
\q1 A harihari na gwau henimuimu,  
\q2 egu hahebade na vairamui ai na gwauraiamu.   
\q1
\v 22 Ina na ba laloa, Dirava o laloa boiomu taumui,  
\q2 baina daremui, bena ta ese basine hamaurimui diba, na garina.   
\q1
\v 23 Hahenamo e mailaiamu tauna na ena boubou bunai,  
\q2 una tau ese e matauraigumu.  
\q1 Ena mauri dalana e reḡua namonamomu tauna na  
\q2 Dirava ena hahemauri baina haheitalaia.   
\c 51  
\q1
\v 1 Dirava e, a bogagu hisi,  
\q2 emu lalokau heḡereḡerena;  
\q1 emu hebogahisi bada-herea heḡereḡerena ai  
\q2 egu kara dika ba rohodia.   
\q1
\v 2 Egu kara havara ba huridia oho,  
\q2 egu kerere amo ba haḡoevagu.   
\b  
\q1
\v 3 Badina be egu kara dika na dibagu,  
\q2 egu kerere na vairagu ai nega iboudiai.   
\q1
\v 4 Oiemu ai, oi mo sibomu emu ai, vada na kerere,  
\q2 oi vairamu ai vada na kara havara;  
\q1 taunabunai emu hereva na maoromaoro,  
\q2 bona emu hahemaoro herevana na asi kererena.   
\q1
\v 5 Momokani, lau na kara havara ai na vara,  
\q2 bona kara dika ai sinagu ese e havaragu.   
\b  
\q1
\v 6 Momokani, oi o uramu hereva momokani na lalomai ai baine mia,  
\q2 taunabunai, lalogu ai aonega hehunidia ba hadibagu.   
\q1
\v 7 Muramura avana amo ba haḡoevagu, bena baina ḡoevaḡoeva;  
\q2 a hurigu, bena \it snow\it* ena kurokuro baina hereaia.   
\q1
\v 8 Moale bona lalo-namo amo ba hahonugu;  
\q2 vada o hakwaidu turiadia do bae moale.   
\q1
\v 9 Vairamu na egu kara dika amo ba hunia,  
\q2 bona egu kara havara iboudiai na ba rohodia.   
\b  
\q1
\v 10 Dirava e, lalo-ḡoevaḡoeva na lalogu ai ba havaraia,  
\q2 bona lauma matamatana bona maoromaorona na lalogu ai bavatoa.   
\q1
\v 11 Oi vairamu amo basio negegu daure;  
\q2 emu Lauma helaḡana na egu amo basio abia oho.   
\q1
\v 12 Emu hahemauri moalena na ba henigu lou,  
\q2 bona ura-kwalimu laumana amo bavabigu isi.   
\b  
\q1
\v 13 Bena emu dala na kara kerere taudia baina hadibalaidia,  
\q2 bona kara dika taudia ese oi bae lou henimu.   
\q1
\v 14 Dirava e, lau ihamaurigu Diravana,  
\q2 rara ihahebubuna amo ba hamaurigu,  
\q1 bena lau malagu ese ane baine abia badabada,  
\q2 oiemu hahemauri anena.   
\b  
\q1
\v 15 Ḡaubada e, lau bibinagu ba hapapadia,  
\q2 bena udugu ese baine imodaimu.   
\q1
\v 16 Badina be boubou karadia so moalelaidiamu,  
\q2 ḡole-oho boubouna bama henimu, to basioma moalelaia.   
\q1
\v 17 Dirava ese e abia daemu boubouna be lauma manauna;  
\q2 Dirava e, lalona e manaumu bona ena dika amo e helalo kerehaim tauna na basio dadaraia.   
\b  
\q1
\v 18 Emu lalo-namo ai Siona ba kara namo henia;  
\q2 Ierusalem maḡuna ba haginia lou;   
\q1
\v 19 bena kara maoromaoro bouboudia ba moalelaidia,  
\q2 lahi bouboudia bona ḡole-oho bouboudia;  
\q1 bena boromakau mamaruanedia na emu ihaboulaina patana ai  
\q2 bae hahelaḡadia.   
\c 52  
\q1
\v 1 Goada-herea taumu e,  
\q2 Dahaka dainai Dirava e matauraiamu taudia e kara dika henidiamu  
\q2 na o heaḡilaiamu?  
\q1 Dina idoinai hahebua-tari daladia o haero heḡaeḡaemu.   
\q1
\v 2 Kara koikoi taumu e,  
\q2 malamu na kaia mai ganona na heto.   
\q1
\v 3 Dika o ura henia badamu, namo o ura henia maraḡimu,  
\q2 hereva koikoi o ura henia badamu, hereva momokani o ura henia maragimu. (Selah)   
\q1
\v 4 Koikoi malana e,  
\q2 hahemase herevadia iboudiai o ura henidiamu.   
\b  
\q1
\v 5 A Dirava ese baine huarimu ela bona hanaihanai;  
\q2 ia na baine verimu oho, emu kalaga amo baine dadihaimu,  
\q2 mauri taudia edia tano amo baine raḡamu. (Selah)   
\q1
\v 6 Kara maoromaoro taudia bae itaia, bena bae gari,  
\q2 bae kirikirilaia, baeto   
\q1
\v 7 “Hari Dirava enai se tao tauna mani a itaia;  
\q2 ia ese ena kohu momo e abidadama henia,  
\q2 bona ena taḡa ai mo e helalokau”.   
\b  
\q1
\v 8 A lau na olive auna mai rauna matamatadia na heto, Dirava ena ruma ai;  
\q2 Dirava ena hebogahisi na abidadama henia hanaihanaimu.   
\q1
\v 9 Lau ese baina imodaimu ela bona hanaihanai,  
\q2 badina be oi ese vada o karaia;  
\q1 oi ladamu baina heatolaia, badina ia na namo  
\q2 Dirava e matauraiamu taudia vairadiai.   
\c 53  
\q1
\v 1 Kava tauna na lalona ai e tomu  
\q2 “Dirava na lasi”.  
\q1 Idia na mimiro, kara dika-hereadia e karamu;  
\q2 asi tauna ta ese kara namo e karamu.   
\b  
\q1
\v 2 Dirava na guba amo e roha dobimu,  
\q2 taunimanima natudia e nenediamu;  
\q1 baine itadia, aonega taudia haida nonoho,  
\q2 eiava Dirava e tahuamu taudia haida nonoho.   
\b  
\q1
\v 3 Iboudiai vada e keto,  
\q2 iboudiai vada e miro;  
\q1 asi tauna ta ese kara namo e karamu,  
\q2 lasi ona lasi vaitani.   
\b  
\q1
\v 4 Kara dika taudia na asi edia lalo-parara a?  
\q2 Idia na egu orea taudia e anidiamu, flaoa e animu na heto;  
\q2 idia ese Dirava asie boi heniamu.   
\b  
\q1
\v 5 Idia bunu, gari bada ese e butudia taomu,  
\q2 gari idauna, nega gunana ta se vara ḡauna.  
\q1 Badina be Dirava ese asie matauraiamu taudia turiadia baine ḡiḡidia rohoroho;  
\q2 idia na bae hahemaraidia, badina be Dirava ese vada e dadaraidia.   
\b  
\q1
\v 6 Israel ihamaurina na Siona amo bema mai be namo!  
\q2 Dirava ese ena orea taudia baine haginidia lou negana ai  
\q2 Iakob baine moale, bona Israel baine hisi dae.   
\c 54  
\q1
\v 1 Dirava e, oi ladamu amo ba hamaurigu,  
\q2 oi goadamu amo ba gwauraigu maoro.   
\q1
\v 2 Dirava e, egu noinoi a kamonai,  
\q2 lau udugu herevadia ba hakala henidia.   
\b  
\q1
\v 3 Badina be asi edia hemataurai taudia vada e tore isi,  
\q2 lau ihadikagu totona;  
\q1 daḡedaḡe taudia ese egu mauri iabi-ohona e tahuamu,  
\q2 idia lalodia ai na Dirava asie hanohoamu. (Selah)   
\q1
\v 4 A itaia, Dirava na lau ikahagu,  
\q2 Ḡaubada na egu mauri imudana.   
\q1
\v 5 Lau inaigu na dava dikana baine henidia;  
\q2 emu momokani ai ba habuadia tari.   
\b  
\q1
\v 6 Egu lalo-namo ai egu boubou ḡauna baina hahelaḡaia oiemu;  
\q2 Iehova e, oi ladamu baina hanamoa,  
\q2 badina be ia na namo.   
\q1
\v 7 Badina be oi ese hekwakwanai iboudiai lalodia amo vada o harohogu mauri;  
\q2 inaigu na egu kwalimu ai na itadia nenenenemu.   
\c 55  
\q1
\v 1 Dirava e, egu guriḡuri a kamonai,  
\q2 egu noinoi na basio dadaraia.   
\q1
\v 2 A hakala henigu, a haere henigu;  
\q2 egu hisihisi ese vada e hadareregu.   
\q1
\v 3 Inai tauna gadona ese vada e hadaradaragu,  
\q2 kara dika taudia edia daḡedaḡe karadia daidiai;  
\q1 badina be idia ese e hahekwakwanaigumu,  
\q2 bona edia badu ai e inai henigumu.   
\b  
\q1
\v 4 Lalogu na e hisihisi badamu;  
\q2 mase ena hahegari na latagu ai vada e kau.   
\q1
\v 5 Gari bona kudou-hetaha ese e butugu taomu,  
\q2 laumagu na e dauremu.   
\q1
\v 6 Na tomu “Bema mai hanigu, pune na heto,  
\q2 bena bama roho lao, bama laga ani;   
\q1
\v 7 oibe, dauha bama lao,  
\q2 tano ḡaḡaena ai bama noho; (Selah)   
\q1
\v 8 bama lao haraḡa, hemetai gabuna bama tahua,  
\q2 lai bona medu ilao-ahudia”.   
\b  
\q1
\v 9 Ḡaubada e, edia lalo-hadai ba hadikadia,  
\q2 gadodia ba haheḡonudia;  
\q1 badina be haheala bona heatu na  
\q2 hanua ai na itamu.   
\q1
\v 10 Dina ai bona hanuaboi ai maḡuna e rakaia heḡeḡemu,  
\q2 hedibaḡani bona hekwarahi na ia lalonai e miamu,  
\q2 hahebua-tari na ia bogaraginai;   
\q1
\v 11 daḡedaḡe bona koikoi karadia na  
\q2 ena ariara ai asie dokomu.   
\b  
\q1
\v 12 E kirikirilaigumu tauna na dia inai tauna,  
\q2 bema unuheto, bama haheauka;  
\q1 e ihi-ihiraigumu tauna na dia inai tauna,  
\q2 bema unuheto, iena amo bama komu.   
\q1
\v 13 A tauna na oi, lau idaigu,  
\q2 lau bamogu, lau turagu korikori.   
\q1
\v 14 Ta hereva-herevava mai moaleda ida,  
\q2 ta raka hebouva Dirava ena ruma ai.   
\q1
\v 15 Mase na ediai baine kau,  
\q2 mauridia ai mase gabuna ai bae diho,  
\q1 mai garidia ida edia guri ai bae diho,  
\q2 be namo.   
\b  
\q1
\v 16 A lau be Dirava do baina boi henia;  
\q2 Iehova ese baine hamaurigu.   
\q1
\v 17 Adorahi ai bona daba ai bona dina tubua ai  
\q2 na maumaumu bona na ḡanaḡanamu.  
\q1 Ia ese lau gadogu baine kamonaia,   
\q2
\v 18 ia ese lau laumagu baine hamauria;  
\q1 na tuarilaiamu tuarina amo baine hamaurigu,  
\q2 badina be hutuma ese e tuari henigumu.   
\q1
\v 19 Dirava na baine hakala, baine tuidia,  
\q2 sene negana amo e nohomu Diravana;  
\q1 badina be taravatu asie badinaiamu,  
\q2 bona Dirava garina se garimu. (Selah)   
\q1
\v 20 Bamogu ese imana e haroroa, ia turana ihadikadia totona,  
\q2 ena gwauhamata e hadikaia.   
\q1
\v 21 Ena hereva na manada-manada, bata ena manada-manada e hereaia,  
\q2 a tuari be ia lalona ai.  
\q1 Ena hereva na manoka-manoka, dehoro ena manoka-manoka e hereaia,  
\q2 a idia na e veri lasi daredia.   
\b  
\q1
\v 22 Emu maduna na Iehova enai ba tahoa kau,  
\q2 ia ese baine abimu isi;  
\q1 ia ese kara maoromaoro taudia baine gimadia,  
\q2 idia na basie marere-marere.   
\b  
\q1
\v 23 Dirava e, oi ese ba tahodia dobi,  
\q2 henu herea gurina lalonai;  
\q1 rara ihahebubuna bona koikoi karadia ikaradia taudia na  
\q2 edia mauri kahana basie haḡuḡurua.  
\q1 A lau ese oi baina abidadama henimu.   
\c 56  
\q1
\v 1 Dirava e, ame bogagu hisi,  
\q2 badina be taunimanima ese e moigu taomu,  
\q2 dina idoinai tuari taudia ese e daḡedaḡe henigumu.   
\q1
\v 2 Inaigu na dina idoinai e moigu taomu,  
\q2 hutuma ese e tuari henigumu mai heaḡidia ida.   
\q1
\v 3 Lau na garimu negadia ai na  
\q2 oi mo na abidadama henimumu.   
\q1
\v 4 Ena hereva na imodaiamu Diravana,  
\q2 Dirava mo na abidadama heniamu, asi egu gari;  
\q2 hidio na ede baine karagu toma?   
\b  
\q1
\v 5 Dina idoinai idia ese egu hereva e hagagevadiamu,  
\q2 edia lalo-hadai iboudiai na lau ihadikagu mo e laloamu.   
\q1
\v 6 Idia na e heboumu, e bani taomu,  
\q2 egu raka marere e itaia taomu.  
\q1 Egu mauri iabi-ohona totona vada e narigu heḡereḡerena,   
\q2
\v 7 edia kara dika davana unu ba henidia toma.  
\q1 Dirava e, bese idau-idau taudia na  
\q2 mai badumu ida ba tahodia dobi.   
\b  
\q1
\v 8 Egu loa eva-eva vada o hagaudia,  
\q2 irurumatagu na emu kavabu ai ba udadia;  
\q2 emu buka ai e miamu, ani?   
\q1
\v 9 Baina boiboi dinana ai,  
\q2 lau inaigu na ba haloudia.  
\q1 Ina na dibagu, Dirava na lau ida:   
\q2
\v 10 Dirava, ena hereva na imodaiamu Diravana;  
\q2 Iehova, ena hereva na imodaiamu Diravana.   
\q1
\v 11 Ia mo na abidadama heniamu, asi egu gari;  
\q2 taunimanima na ede bae karagu toma?   
\b  
\q1
\v 12 Dirava e, egu gwauhamata emu ai na anidia do baina kara;  
\q2 egu hehenamo bouboudia na oi baina henimu.   
\q1
\v 13 Badina be oi ese lau laumagu na mase amo vada o rauaia;  
\q2 oibe, aegu na hetutuhi amo vada o hamauria.  
\q1 Dirava vairanai baina raka totona,  
\q2 mauri diarina lalonai.   
\c 57  
\q1
\v 1 Ame bogagu hisi, Dirava e, ame bogagu hisi.  
\q2 Badina be oi lalomu ai lau laumagu e komumu;  
\q2 oi hanimu ikerukerudia na egu hemetai gabuna,  
\q2 ela bona hahebua-tari baine ore.   
\q1
\v 2 Dirava Herea Mikamika na tai heniamu,  
\q2 egu ai ena ura e haḡuḡuruamu Diravana.   
\q1
\v 3 Ia na guba amo ena hesiai baine siaia, baine hamaurigu;  
\q2 e moigu taomu taudia ia ese baine hahemaraidia. (Selah)  
\q1 Dirava ese ena hebogahisi bona ena momokani  
\q2 baine siai lasi.   
\b  
\q1
\v 4 Leona bogaragidiai na hekuremu,  
\q2 taunimanima natudia e anidia lava daemu ḡaudia;  
\q1 isedia na io bona diba,  
\q2 bona maladia na dare ganoka-ganokadia.   
\b  
\q1
\v 5 Dirava e, guba doriva-dorivana ai bae imodaimu,  
\q2 oi hairaimu na tanobada idoinai daenai baine mia.   
\b  
\q1
\v 6 Idia na huo e otoa, lau aegu ihatoadia;  
\q2 laumagu na e igo diho.  
\q1 Idia na egu dala ai guri e ḡeia,  
\q2 a ḡau be idia sibodia na lalonai e moru dobi. (Selah)   
\q1
\v 7 Lau lalogu na auka;  
\q2 Dirava e, lau lalogu na auka.  
\q1 Ane baina abia, hahenamo anedia baina abi;   
\q2
\v 8 laumagu e, a noga.  
\q1 Gitara bona hatai-hatai ḡauna maragina, a noga;  
\q2 lau na daba matana ai baina noga.   
\q1
\v 9 Ḡaubada e, lau oi baina hanamomu,  
\q2 bese idau-idau bogaragidiai;  
\q1 oi ihanamolaimu anedia baina abi,  
\q2 orea idau-idau bogaragidiai.   
\q1
\v 10 Badina be emu hebogahisi na bada ela bona guba,  
\q2 emu momokani na bada ela bona ori.   
\b  
\q1
\v 11 Dirava e, guba doriva-dorivana ai bae imodaimu,  
\q2 oi hairaimu na tanobada idoinai daenai baine mia.   
\c 58  
\q1
\v 1 Lohiamui e, emui hahemaoro herevadia na maoromaoro eiava?  
\q2 Taunimanima o hahemaoro henidiamu mai maoromaoromui ida a?   
\q1
\v 2 Lasi, lalomui ai kara kerere-kereredia o haeromu;  
\q2 imamui na daḡedaḡe karadia e karamu tanobada ai.   
\b  
\q1
\v 3 Kara dika taudia na dounu sinadia bogadia lalodiai e nohova negadia amo vada e raka muri matama,  
\q2 edia vara dinadia amo vada e kerere, koikoi herevadia e gwauraimu.   
\q1
\v 4 Idia na mai edia mase muramurana, gaigai ena mase muramurana na heto,  
\q2 taia kudima gaigaina na heto.  
\q1 Ia na taiana e kouamu,   
\q2
\v 5 mea tauna gadona basine kamonai totona,  
\q2 babalau tauna mai aonegana gadona basine kamonai helaoreana.   
\b  
\q1
\v 6 Dirava e, isedia ba hakwaidudia ududia ai,  
\q2 Iehova e, leona natudia gadigadidia ba ragadia lasi.   
\q1
\v 7 E aru ohomu ranuna na heto bae puki;  
\q2 rei na heto bae moidia tao, bena bae marai.   
\q1
\v 8 Bisisi na kwari ai e hepunimu na heto bae boio,  
\q2 e vara dika merona heḡereḡerena, dina nega hata se itaia.   
\q1
\v 9 Ava ḡiniḡini, mauridia eiava kakorodia, siahudia na emui uro ese do se abi negana ai,  
\q2 ia ese baine petadia oho.   
\b  
\q1
\v 10 Kara maoromaoro tauna baine moale,  
\q2 dava ihenina baine itaia negana ai;  
\q1 kara dika tauna rarana ai  
\q2 ia aena baine huridia.   
\q1
\v 11 Bena taunimanima baeto:  
\q2 Momokani, kara maoromaoro na mai davana;  
\q2 momokani, tanobada ihahemaoro-henina Diravana na e nohomu.   
\c 59  
\q1
\v 1 Egu Dirava e, inaigu edia amo ba hamaurigu,  
\q2 e tuari henigumu taudia edia amo ba gimagu;   
\q1
\v 2 kara dika taudia edia amo ba hamaurigu,  
\q2 rara ihebubuna e uramu taudia edia amo ba harohogu mauri.   
\b  
\q1
\v 3 A itaia, egu mauri iabi-ohona totona e bani henigumu;  
\q2 daḡedaḡe taudia na lau ihadikagu totona e heboumu.   
\q1
\v 4 Iehova e, dia lauegu kara dika eiava lauegu kara havara daidiai,  
\q2 eiava dia lauegu kerere dainai,  
\q2 idia ese e heaumu bona e heḡaeḡaemu.  
\q1 A noga, ikahagu aoma, a itaia!   
\q2
\v 5 Iehova Sabaota, oi na Israel edia Dirava.  
\q1 A noga, bese iboudiai matadia ba hakanidia,  
\q2 kara dika e haero hehunimu taudia ta basio bogaia hisi. (Selah)   
\b  
\q1
\v 6 Adorahi iboudiai idia na e lou maimu,  
\q2 sisia na heheto e ḡoumu,  
\q2 hanua lalonai e igo Ioamu.   
\q1
\v 7 Ḡaudia bunu, ududia amo e lolomu,  
\q2 bibinadia amo e ḡiḡimu.  
\q1 Badina be idia na e tomamu  
\q2 “Daika ese baine kamonai?”   
\b  
\q1
\v 8 Iehova e, oi ese o kirikirilaidiamu,  
\q2 bese iboudiai oi ese o kirikirilaidiamu.   
\q1
\v 9 Egu Goada e, oi ihanamolaimu anedia baina abi,  
\q2 badina be, Dirava e, oi na egu kohoro.   
\q1
\v 10 Egu Dirava na ena hebogahisi ai baine hedavari henigu,  
\q2 egu Dirava ese egu dala baine kehoa,  
\q2 inaigu edia darere do baina itaia.   
\b  
\q1
\v 11 Basio aladia mase, egu orea taudia bae helalo boio na garina,  
\q2 emu siahu amo ba hahekwakwanaidia bona ba haketodia,  
\q2 Ḡaubada e, emai kesi.   
\q1
\v 12 Ududia edia dika, bibinadia edia hereva, daidiai  
\q2 edia heaḡi ai bae hedoa.  
\q1 Heuduguirai bona koikoi herevadia vada e gwaurai daidiai,   
\q2
\v 13 badu ai ba ha-oredia,  
\q2 ba ha-oredia ela bona bae boio vaitani.  
\q1 Unu amo taunimanima bae diba Dirava ese Iakob e lohiaiamu  
\q2 ela bona tanobada dokona.   
\q1
\v 14 Adorahi iboudiai idia na e lou maimu,  
\q2 sisia na heheto e ḡoumu,  
\q2 hanua lalonai e igo loamu.   
\q1
\v 15 Aniani itahuna e loa eva-evamu,  
\q2 bona bogadia asie kumumu negadia ai e ḡiḡimu.   
\b  
\q1
\v 16 A lau na oiemu goada baina anelaia,  
\q2 daba ai emu hebogahisi baina anelaia bada;  
\q1 badina be oi na egu kohoro,  
\q2 bona egu roho-mauri gabuna, egu hisihisi dinana ai.   
\q1
\v 17 Egu Goada e, oi ihanamolaimu anedia baina abi,  
\q2 badina be, Dirava e, oi na egu kohoro;  
\q2 e bogagu hisimu Diravana.   
\c 60  
\q1
\v 1 Dirava e, oi ese vada o dadaraimai, vada o hadareremai,  
\q2 vada o badu; mani emu kara bavabimai dae lou.   
\q1
\v 2 Oi ese tano vada o haheude-heudea, vada o hapararaia;  
\q2 ba haginia lou, badina be e marere-mareremu.   
\q1
\v 3 Kara aukadia amo emu bese taudia vada o hahisidia;  
\q2 vine ranuna vada o henimai, vada a inua, vada a kekero.   
\q1
\v 4 Pepe vada o veria dae, e gari henimumu taudia edia,  
\q2 ienai bae hahegoada hebou, peva bae heautania negana ai; (Selah)   
\q2
\v 5 unu amo emu lalokau taudia na bae roho mauri.  
\q1 Imamu idibana amo kwalimu ba henimai,  
\q2 bona ba haere henimai.   
\b  
\q1
\v 6 Dirava na ena gabu helaḡana ai vada e hereva, eto,  
\q2 Mai moalegu ida Sekem baina hapararaia,  
\q2 bona Sukoto kourana baina haria.   
\q1
\v 7 Gilead na lauegu; Manase na lauegu;  
\q2 Efraim na egu kwara ḡauna;  
\q2 Iuda na egu dagi auna.   
\q1
\v 8 Moab na imagu ihuridia dihuna;  
\q2 Edom Iatanai egu tamaka na tahoa kaumu;  
\q2 Filistia daenai na heaḡimu, na lolomu.   
\b  
\q1
\v 9 Daika ese hanua mai maḡuna lalonai baine hakaugu vareai?  
\q2 Daika ese Edom baine haka-lgu lao?   
\q1
\v 10 Dirava e, vada o dadaraimai ani?  
\q2 Dirava e, emai tuari oreadia ida so raka lasimu.   
\q1
\v 11 Ame kahamai, inaimai ituari-henidia ai;  
\q2 badina be taunimanima edia hekaha na asi anina.   
\q1
\v 12 Dirava ida baita goada balaheni;  
\q2 ia ese ita inaida baine moidia tao.   
\c 61  
\q1
\v 1 Dirava e, egu taitai a kamonai,  
\q2 egu ḡuriḡuri bavabia dae;   
\q1
\v 2 lau kudougu e hetahamu negana ai na  
\q2 tanobada dokona amo baina boi henimu.  
\b  
\q1 Mani a hakaugu lao,  
\q2 baine hagagu tao nadina enai;   
\q1
\v 3 badina be egu roho mauri gabuna na oiemu ai,  
\q2 egu kohoro na oi, inai taudia ilao-ahudia.   
\q1
\v 4 Emu kalaga ai baina noho hanaihanai,  
\q2 oi hanimu ikerukerudia ai baina mauri. (Selah)   
\q1
\v 5 Badina be, Dirava e, oi ese egu gwauhamata vada o kamonai  
\q2 oi ese oi ladamu e matauraiamu taudia ahudia vada o henigu.   
\b  
\q1
\v 6 Hanua pavapavana ena mauri ba hadaudaua,  
\q2 ena mauri laḡanidia bae hesiriu ela bona uru iboudiai,   
\q2
\v 7 ena terono ai baine helai hanaihanai, Dirava vairanai;  
\q1 lalokau bona momokani amo ba reḡua.   
\b  
\q1
\v 8 Taunabunai lau ese oi ladamu baina hanamoa egu ane ai;  
\q2 dina ta ta amo egu gwauhamata anidia baina kara.   
\c 62  
\q1
\v 1 Lau laumagu ese Dirava mo e nariamu, asi reḡereḡegu;  
\q2 ihamaurigu na iena amo e maimu.   
\q1
\v 2 Ia mo sibona na egu nadi-gini bona egu hahemauri,  
\q2 egu kohoro; lau na basina marere-marere.   
\b  
\q1
\v 3 Iboumui ai ese tau tamona bavala-ala henia ela bona edena nega ai?  
\q2 e gini sehemu maḡuna eiava e marere-mareremu arana na heto?   
\q1
\v 4 Edia lalo-hadai tamona be ena dagi amo bae doria dobi;  
\q2 hereva koikoidia e moalelaimu;  
\q1 ududia amo hahenamo herevadia e gwauraimu,  
\q2 a lalodia ai e heuduguirai. (Selah)   
\q1
\v 5 Lau laumagu ese Dirava mo e nariamu, asi reḡereḡegu;  
\q2 badina be egu helaro na ienai.   
\q1
\v 6 Ia mo sibona na egu nadi-gini bona egu hahemauri,  
\q2 egu kohoro; lau na basina marere.   
\q1
\v 7 Egu mauri bona ihamomokanigu na Dirava enai;  
\q2 egu nadi-gini badana na Dirava,  
\q2 egu roho-mauri gabuna na Dirava.   
\q1
\v 8 Taunimanima e, nega iboudiai ia bavabidadama henia;  
\q2 lalomui anidia na ia vairanai ba hahedinarai;  
\q2 eda roho-mauri gabuna na Dirava enai. (Selah)   
\q1
\v 9 Dagi maraḡi taudia na hahodi ta na heto;  
\q2 dagi bada taudia na asi anidia;  
\q1 metau hahetoho ḡauna ai e haraḡamu,  
\q2 metaudia idoinai na maraḡi,  
\q2 hahodi tamona metauna ida asie heḡereḡere.   
\q1
\v 10 Dadidadi karadia basio abidadama henidia,  
\q2 henao karadia basio larodia kava;  
\q2 emui taḡa bema bada, basio lalokau henia.   
\q1
\v 11 Nega hata Dirava vada e hereva,  
\q2 nega harua ini vada o kamonai toma:  
\q2 siahu na Dirava ena.   
\q1
\v 12 Ḡaubada e, hebogahisi na oi mo emu;  
\q2 badina be taunimanima ta ta ena ḡaukara ena ḡaukara heḡereḡeredia,  
\q2 davadia o henidiamu.   
\c 63  
\q1
\v 1 Dirava e, oi na lauegu Dirava, lau oi na tahumumu,  
\q2 lau laumagu e ranu masemu oiemu ai;  
\q1 lau hidiogu na e manorimu oiemu ai,  
\q2 tano kaukauna ai, tano gaḡaena ai,  
\q2 asi ranuna tanona ai, na heto.   
\q1
\v 2 Taunabunai, lau ese vada na raraimu, gabu helaḡana ai,  
\q2 oi siahumu bona hairaimu vada na itadia;   
\q1
\v 3 badina be emu hebogahisi ese mauri e hereaiamu,  
\q2 una dainai lau bibinagu ese bae imodaimu.   
\q1
\v 4 Taunabunai, egu mauri dinadia iboudiai baina hanamomu,  
\q2 imagu baina dudui isi, oi ladamu baina hahanea.   
\b  
\q2
\v 5-6 Egu geda ai oi na lalomu negadia ai,  
\q1 hanuaboi lalonai oi na haeromu negadia ai,  
\q2 laumagu be bogagu na turia harana bona digara amo bema kunu na heto;  
\q1 lau udugu ese e hanamomumu, mai bibina moaledia ida;   
\q2
\v 7 badina be oi ese vada o kahagu,  
\q2 oi hanimu ikerukerudia ai moale anedia na abimu.   
\q1
\v 8 Lau laumagu na oiemu ai e taomu;  
\q2 oi imamu idibana na egu imuda.   
\q1
\v 9 A egu mauri iabi-ohona e tahuamu taudia na  
\q2 tanobada ena dobu gabudia ai bae diho.   
\b  
\q1
\v 10 Dare ese bae aladia;  
\q2 uda sisiadia ese bae daredia.   
\q1
\v 11 A hanua pavapavana ese Dirava baine moalelaia;  
\q2 ia ladana ai e gwau hamatamu taudia na hairaina bae abia,  
\q2 badina be koikoi taudia ududia na bae dai ahu.   
\c 64  
\q1
\v 1 Dirava e, egu taitai ai lau gadogu ba kamonai;  
\q2 egu mauri na inaigu igari-henidia amo ba rauaia.   
\q1
\v 2 Kara dika taudia edia lalohadai dikadia hehunidia amo ba hunigu,  
\q2 kara havara taudia edia ura dikadia amo ba hunigu.   
\q1
\v 3 Idia na maladia e segediamu dare na heheto,  
\q2 edia hereva iditadia e kinodiamu, diba na heheto;   
\q1
\v 4 e bani taomu, asi ena kerere tauna e tarakiamu,  
\q2 e tarakia takumu, asie garimu.   
\q1
\v 5 Edia ura dikadia na e dogodia taomu;  
\q2 idoa iato-hehunidia na e herevalaimu.  
\q1 E tomu “Daika ese baine itada diba?   
\q2
\v 6 Daika ese eda kara dika baine tahudia diba?  
\q2 Eda ura dalana vada ta haeroa mai aonegada ida”.  
\q1 Badina be taunimanima lalona na dobu,  
\q2 ena lalo-hadai danu dobu.   
\b  
\q1
\v 7 A Dirava ese ena diba amo baine tarakidia;  
\q2 idia na bae bero haraḡa-haraḡa.   
\q1
\v 8 Badina be idia sibodia maladia daidiai ia ese edia dika do baine havaraia;  
\q2 bae itadia taudia iboudiai na kwaradia bae taiko-taiko.   
\q1
\v 9 Bena taunimanima iboudiai bae gari,  
\q2 Dirava ena kara bae herevalaia,  
\q2 bona ena ḡaukara bae haeroa.   
\b  
\q1
\v 10 Kara maoromaoro taudia ese Iehova bae moalelaia,  
\q2 ienai bae roho mauri;  
\q1 lalo-maoromaoro taudia iboudiai ese  
\q2 ia bae imodaia.   
\c 65  
\q1
\v 1 Dirava e, Siona ai bae imodaimu;  
\q2 bona gwauhamata anidia na oi bae henimu.   
\q1
\v 2 Ḡuriḡuri ikamonaina Diravana e,  
\q2 taunimanima iboudiai na bae vasi,   
\q2
\v 3 kara dika daidiai  
\q1 Emai kara dika ese e hadareremaimu negadia ai na  
\q2 oi ese o gwaudia taomu.   
\q1
\v 4 Emu maḡu ai baine noho totona o abia hidimu bona o hakaua kahimu tauna be namo;  
\q2 emu ruma ena namo ai ese baia moalelaia, emu dubu helaḡana bunai.   
\b  
\q1
\v 5 Ai ihamaurimai Diravana e,  
\q2 hahegari karadia amo o haere henimaimu bona o hamaurimaimu;  
\q1 oi na tanobada dokodia iboudiai edia helaro,  
\q2 bona davara daudau-hereadia edia danu.   
\q1
\v 6 Oi ese emu goada amo ororo o hadaidia,  
\q2 oi na siahu o hariolaiamu;   
\q1
\v 7 oi na davara reḡedia o gwaudia taomu,  
\q2 edia hurehure reḡedia bona taunimanima edia heloḡo-heloḡo danu.   
\q1
\v 8 Taunabunai tanobada hetoadia daudau-hereadia ai e nohomu taudia ese  
\q2 oiemu toa e gari henidiamu;  
\q1 oi ese dina dae tanodia bona dina diho tanodia o hamoalediamu.  
\q2 bena e moale hisi daemu.   
\q1
\v 9 Tanobada o vadivadi heniamu, o haparipariamu,  
\q2 uma tanodia o hanamodiamu;  
\q1 Dirava ena sinavai na ranu ai e honumu,  
\q2 uma anidia o henidiamu,  
\q2 vada o haheḡaeḡaedia tanodia lalodiai.   
\q1
\v 10 E ruadia tanodia o hapariparidia badamu,  
\q2 tano latalatadia o hataoradiamu,  
\q1 medumedu amo o hamanokadiamu,  
\q2 lalodiai e tubumu ḡaudia o hanamodiamu.   
\b  
\q1
\v 11 Emu herahia ese laḡani ihanamona e haḡuḡuruamu,  
\q2 aemu gabudia amo digara e dihomu,   
\q1
\v 12 tano ḡaḡaena reidia ai e dihomu,  
\q2 ororo ese edia moale e rioamu.   
\q1
\v 13 Rei gabudia ese mamoe seridia na e hadabuadiamu,  
\q2 koura ese uit e hadokiamu,  
\q2 ane e abimu, e moale hisi daemu.   
\c 66  
\q1
\v 1 Tanobada idoinai, Dirava ba hisi dae henia;   
\q2
\v 2 ia ladana hairaina anedia bavabi,  
\q2 ba imodaia badabada.   
\q1
\v 3 Dirava ba hanamoa, baoto:  
\q2 Emu kara na hahegari karadia.  
\q2 emu siahu na bada herea,  
\q2 oi inaimu na vairamu ai e gari igo dihomu.   
\q1
\v 4 Tanobada idoinai ese oi e toma henimu dihomu,  
\q2 oi ihanamolaimu anedia e abimu,  
\q2 oi ladamu iheatolaina anedia.   
\q1
\v 5 Aoma, Dirava ena kara ba itaia;  
\q2 ena kara taunimanima bogaragidiai na hahegari karadia.   
\q1
\v 6 Davara na tano kaukauna ai e halaoa,  
\q2 taunimanima na aedia amo sinavai e rakaia hanai,  
\q2 unuseni ai ia ta moalelaiava.   
\q1
\v 7 lena siahu amo e lohia hanaihanaiamu,  
\q2 ia matana ese bese idau-idau e nenediamu;  
\q2 gwau-hemuri taudia na sibodia basie heaḡi. (Selah)   
\q1
\v 8 Bese idau-idau e, emui Dirava ba hanamoa,  
\q2 ia iheatolaina reḡedia bae dae.   
\q1
\v 9 Ia ese mauri ai vada e dogomai tao,  
\q2 aemai vada e naridia dainai asie dedi.   
\q1
\v 10 Badina be, Dirava e, oi ese vada o tohomai;  
\q2 \it silver\it* e tohoamu na heto vada o tohomai.   
\q1
\v 11 Huo ai vada o abimai,  
\q2 koekoemai vada o hahisidia.   
\q1
\v 12 Edia hosi aedia amo e moimai tao taudia na so rudia;  
\q2 lahi amo a raka hanai, bona ranu amo danu.  
\q1 A oi ese gabu namona ai vada o hakaumai lasi.   
\b  
\q1
\v 13 Lau be ḡole-oho bouboudia na emu dubu ai baina rakalai vareai,  
\q2 egu gwauhamata anidia na oiemu ai baina kara,   
\q1
\v 14 hisi na ani negana ai bibinagu ese e gwauraia heḡereḡerena,  
\q2 udugu ese e gwauraia hamata na heto.   
\q1
\v 15 Ubu-ubu ḡaudia baina hahelaḡadia, emu ḡole-oho bouboudia ḡaudia,  
\q2 bona mamoe mamaruanedia iḡole-ohodia kwalahuna danu;  
\q2 boromakau mamaruanedia bona nani danu ba hahelaḡadia oiemu. (Selah)   
\b  
\q1
\v 16 Dirava garina o garimu taumui iboumui ai,  
\q2 aoma, ba kamonai.  
\q1 Ia ese ede vada e karagu toma na  
\q2 baina gwauraia hedinarai.   
\q1
\v 17 Lau ese ia na boi henia,  
\q2 lau malagu ese ia e imodaia.   
\q1
\v 18 Lalo-hadai dikadia na lalogu ai bema mia,  
\q2 Ḡaubada ese basinema kamonai henigu.   
\q1
\v 19 A momokani Dirava ese vada e kamonai,  
\q2 ia ese egu noinoi herevadia vada e abi dae.   
\b  
\q1
\v 20 Dirava aina hanamoa,  
\q2 badina be egu ḡuriḡuri se dadaraia,  
\q2 ena hebogahisi egu amo na se abia oho.   
\c 67  
\q1
\v 1 Dirava baine bogada hisi, baine hanamoda,  
\q2 ia vairana diarina baine henida. (Selah)   
\q1
\v 2 Tanobada ai oiemu dala bae diba totona;  
\q2 bona emu hahemauri siahuna bese iboudiai bogaragidiai danu.   
\q1
\v 3 Dirava e, bese idau-idau bae hanamomu,  
\q2 bese iboudiai bae imodaimu.   
\q1
\v 4 Bese idau-idau bae moale, moale anedia bae abi,  
\q2 badina be tanobada taudia o hahemaoro henidiamu mai maoromaoromu ida,  
\q2 bona tanobada besedia o hakaudiamu.   
\q1
\v 5 Dirava e, bese idau-idau bae hanamomu,  
\q2 bese iboudiai bae imodaimu.   
\b  
\q1
\v 6 Tano anina vada e vara ḡoevaḡoeva;  
\q2 Dirava, iseda Dirava, ese vada e hanamoda.   
\q1
\v 7 Dirava vada e hanamoda;  
\q2 bona tanobada dokodia iboudiai ese ia garina bae gari.   
\c 68  
\q1
\v 1 Dirava baine tore isi, ia inaina baine hakarohodia rohoroho;  
\q2 e inai heniamu taudia na ia vairanai bae heau.   
\q1
\v 2 Lai ese kwalahu e odaia ohomu heḡereḡerena  
\q2 unu bae odadia oho toma;  
\q1 \it Wax\it* na lahi badibadinai e vevemu na heto,  
\q2 kara dika taudia na unu bae mase toma,  
\q2 Dirava vairanai.   
\q1
\v 3 A kara maoromaoro taudia na bae moale;  
\q2 Dirava vairanai bae hisi dae,  
\q2 moale ai bae honu honu dae.   
\b  
\q1
\v 4 Ane avabia, Dirava ena, ia ladana ba hanamoa emu ane ai;  
\q2 ane ba ladaia isi, ori ai e guimu Diravana ena;  
\q1 ia ladana na Iehova,  
\q2 ia vairanai ba hisi dae.   
\b  
\q1
\v 5 Dirava na ihareha tamadia bona vabu igimadia,  
\q2 ena noho gabuna helaḡana ai.   
\q1
\v 6 Dirava ese noho-edea taudia edia iduhu e henidiamu,  
\q2 iḡui taudia e hakaudia lasimu, e hataḡadiamu;  
\q2 a gwau-emuri taudia na tano kaukauna ai e nohomu.   
\b  
\q1
\v 7 Dirava e, emu orea taudia vairadiai o raka lasi  
\q2 bona tano gagaena o rakaia hanai negana ai, (Selah)   
\q1
\v 8 tano e laga bona guba medudia e diho badabada,  
\q2 Dirava vairanai.  
\q1 Sinai ororona bunai, Dirava vairanai e heude-heude,  
\q2 Israel Diravana vairanai.   
\q1
\v 9 Dirava e, medu o hadihoa badabada;  
\q2 emu tano e kaukauva negana ai o hapariparia;   
\q2
\v 10 emu seri na ia lalonai edia noho gabuna e davaria.  
\q1 Dirava e, emu kara namo bagunai ogoḡami taudia adia o henidia.   
\b  
\q1
\v 11 Ḡaubada ese ena hahedua herevana e gwauraiamu  
\q2 hutuma bada ese e piuamu;   
\q2
\v 12 tuari oreadia pavapavadia e heaumu, e heaumu.  
\q1 Ruma ai e nohomu hahinedia ese tuari ai e dadi kohudia e haridiamu,   
\q2
\v 13 mamoe edia maḡu ai e nohomu hahinedia ese.  
\q1 Pune hanina na \it silver\it* amo e heḡova,  
\q2 hanina huidia na \it gold\it* gadoka-gadokana amo e heḡova.   
\q1
\v 14 Siahu-idoinai Diravana ese hanua pavapavadia na Salmon ai e hakarohodia negana ai,  
\q2 \it snow\it* na unuseni ai e diho.   
\b  
\q1
\v 15 Ororo badana e, Basan ororona!  
\q2 Dorina momo ororona e, Basan ororona!   
\q1
\v 16 Dorina momo ororona e,  
\q2 dahaka o hamuemu?  
\q1 Dirava e uramu baine noholaia ororona,  
\q1 Oibe, Iehova baine noholaia hanaihanai ororona,  
\q2 dahaka hamuena o karaiamu?   
\b  
\q1
\v 17 Ḡaubada na Sinai amo gabu helaḡana ema,  
\q2 mai kariota aukadia gerebu rua ida,  
\q2 oibe, mai kariota daha daha ida.   
\q1
\v 18 Oi na ororo ḡaulatalatana ai o dara dae,  
\q2 iḡui taudia na murimu ai o hakaudia dara.  
\q1 Herahia ḡaudia na taunimanima edia amo o abi,  
\q2 oibe, gwau-hemuri taudia edia amo danu,  
\q2 Ḡaubada Iehova unuseni ai baine noho na totona.   
\b  
\q1
\v 19 Ḡaubada aita hanamoa!  
\q2 Ia ese dina iboudiai e abida isimu;  
\q2 Dirava na eda mauri. (Selah)   
\q1
\v 20 Eda Dirava na hahemauri Diravana;  
\q2 Ḡaubada Dirava ese mase amo e harohoda maurimu.   
\b  
\q1
\v 21 A Dirava ese ia inaina kwaradia baine huaridia,  
\q2 ena kara havara ai e rakamu tauna na  
\q2 tubuana mai huina baine huaria.   
\q1
\v 22 Ḡaubada eto:  
\q2 Basan amo baina loulaidia,  
\q2 davara dobuna gabudia amo baina loulaidia,   
\q1
\v 23 aemui na rara ai ba hadigudia totona,  
\q2 bona emui sisia maladia na inaimui raradia bae demaria totona.   
\b  
\q1
\v 24 Dirava e, mai hairaimu ida o raka hanaimu,  
\q2 egu Dirava, egu Pavapava, na gabu helaḡana ai e raka vareaimu,  
\q2 mai hairaina ida.   
\q1
\v 25 Ane e abimu taudia na vairai e rakamu,  
\q2 hatai-hatai ḡaudia e hataimu taudia na muri ai,  
\q2 bogaragi ai na ulato ese edia tareko e hareḡemu.   
\q1
\v 26 Hebou badana ai Dirava ba hanamoa,  
\q2 Israel ena ranu-lohilohi gabuna amo o maimu taumui,  
\q2 Ḡaubada ba hanamoa.   
\q1
\v 27 Beniamina, tau muritai, na vairai;  
\q2 Iuda lohiadia na mai edia orea ida,  
\q2 Sebulun lohiadia bona Napatali lohiadia danu unuseni ai.   
\b  
\q1
\v 28 Dirava e, siahumu avabia,  
\q1 Dirava e, goadamu ba hahedinaraia,  
\q2 emu siahu karadia vada o kara, ai daimai ai.   
\q1
\v 29 Emu Dubu Helaḡa Ierusalem ai dainai,  
\q2 pavapava ese edia herahia e mailaimu emu.   
\q1
\v 30 Siriho ai e nohomu boromadia ba gwau henidia,  
\q2 boromakau mamaruanedia seridia bona taunimanima edia boromakau natudia ba gwau henidia.  
\q1 Heaiva kohuna iabina e uramu taudia ba moidia tao,  
\q2 tuari e moalelaiamu besedia ba hakarohodia.   
\q1
\v 31 Auri labora-labora na Aigupto amo bae mailaia,  
\q2 Etiopia ese mase mauri imana na Dirava baine toi roro henia.   
\b  
\q1
\v 32 Tanobada basileiadia, ane bavabi, Dirava ena;  
\q2 hahenamo anedia bavabi, Ḡaubada ena, (Selah)   
\q2
\v 33 nega gunana ai e miava gubana latanai e guimu Diravana ena.  
\q1 A kamonai, ia gadona e siaia lasimu,  
\q2 ia gadona mai siahuna ida.   
\q1
\v 34 Dirava ena siahu ba gwauraia,  
\q2 ia ese Israel e lohiaiamu,  
\q2 ia siahuna na guba ai,   
\q1
\v 35 Dirava na mai garina, ena gabu helaḡana ai,  
\q2 ia na Israel Diravana.  
\q1 Ia ese siahu bona goada ena orea taudia e henidiamu;  
\q2 Dirava aita hanamoa.   
\c 69  
\q1
\v 1 Dirava e, a harohogu mauri!  
\q2 Badina be abata vada e dae ema bona aiogu.   
\q1
\v 2 Kopukopu dobuna ai vada na hepuni,  
\q2 aegu na asi ihadaina gabuna.  
\q1 Ranu dobudia ai vada na diho,  
\q2 abata ese e habubunigu.   
\q1
\v 3 Lau vada na tai mase,  
\q2 gadogu eme haurahaura;  
\q1 matagu vada e valahu-valahu,  
\q2 egu Dirava inarina ai.   
\b  
\q1
\v 4 Kwaragu huidia na gagadoi,  
\q2 asi badina e inai henigumu taudia na hutuma;  
\q1 bae hamasegu e tomu taudia na gogoada,  
\q2 edia koikoi amo e hadikagumu taudia na gogoada.  
\q1 Asina henaoa ḡauna na  
\q2 harihari baine haloua a?   
\q1
\v 5 Dirava e, egu kavakava be dibamu,  
\q2 egu kerere na oiemu amo se hehunimu.   
\b  
\q1
\v 6 Ḡaubada e, Iehova Sabaota e,  
\q2 ba durugu, oi e laromumu taudia na basie hemarai lau daigu ai.  
\q1 Israel Diravana e,  
\q2 ba durugu, oi e tahumumu taudia na basie hahemaraidia lau daigu ai.   
\q1
\v 7 Badina be oi daimu ai haida ese vada e gwau henigu;  
\q2 oi daimu ai hemarai ese vairagu vada e ḡovaia.   
\q1
\v 8 Tadikakagu ediai idau tauna ai vada nala;  
\q2 sinagu natuna ediai idau bese tauna ai vada nala.   
\b  
\q1
\v 9 Badina be emu ruma iura-henina ese vada e hamasegu,  
\q2 bona oi e gwau henimumu taudia edia gwaugwau na lau latagu ai vada e kau.   
\q1
\v 10 Anivaga amo laumagu na hamanaua negana ai,  
\q2 una na ihahemaraigu ḡauna ai ela;   
\q1
\v 11 Guma dabuadia na dokilai negana ai,  
\q2 idia ese e ihi-ihiraigu.   
\q1
\v 12 Hanua ikoukouna ai e helaimu taudia ese e herevalaigumu,  
\q2 kekero taudia ese edia ane ai e herevalaigumu.   
\b  
\q1
\v 13 Iehova e, oi mo na hahanemu,  
\q2 Dirava e, nega namona ai na hahanemu;  
\q1 emu hebogahisi bada-herea amo  
\q2 ba haere henigu.   
\q1
\v 14 Emu hekaha momokanina amo ba harohogu mauri,  
\q2 kopukopu ai baina hepuni na garina;  
\q1 lau inaigu amo ba hamaurigu,  
\q2 bona ranu dobudia amo danu.   
\q1
\v 15 Ba durugu, abata basine habubunigu,  
\q2 dobu gabudia basie hadonogu,  
\q2 mase gurina iduarana basine kougu ahu.   
\b  
\q1
\v 16 Iehova e, a haere henigu,  
\q2 badina be emu lalokau na namo;  
\q1 emu hebogahisi bada-herea heḡereḡerena  
\q2 ba haḡeregu.   
\q1
\v 17 Vairamu na emu hesiai tauna ena amo basio hunia,  
\q2 badina be hisi ese e gugubagumu;  
\q1 a haere henigu haraḡa,   
\q2
\v 18 a raka kahira, ba hamaurigu,  
\q2 ba ruhagu nege, lau inaigu daidiai.   
\b  
\q1
\v 19 Dibamu ede e gwau henigu tomamu,  
\q2 egu hemarai bona egu koikoi oi dibamu,  
\q2 inaigu iboudiai na oi dibamu.   
\q1
\v 20 Laumagu e dauremu, gwaugwau herevadia daidiai  
\q2 daragu e dokomu.  
\q1 Hebogahisi na tahua, to asi ḡauna;  
\q2 tauhalo taudia na tahudia, to ta asina davaria.   
\q1
\v 21 Mase muramurana e henigu, agu;  
\q2 ranu e masegu ai na vine ranuna iditana e henigu,  
\q2 baina inua.   
\b  
\q1
\v 22 Sibodia edia dabara vairadiai na idoa ai bainela,  
\q2 edia aria helagadia na rikiriki ai baela ediai.   
\q1
\v 23 Matadia bae valahu-valahu, basie ita;  
\q2 batubatudia na bae heude-heude loulou.   
\q1
\v 24 Emu badu na latadiai ba seia dobi,  
\q2 emu badu ḡaraḡarana ese baine lasidia tao.   
\q1
\v 25 Edia taruha baine vahu,  
\q2 edia kalaga ai tau ta basine noho.   
\q1
\v 26 Badina be oi ese vada o hahisia tauna na  
\q2 idia ese ma e daḡedaḡe heniamu,  
\q1 bona oi ese vada o haberoa tauna na  
\q2 idia ese ma e hahisihisiamu.   
\q1
\v 27 Mata-hakani latanai mata-hakani ma bavatoa idia ediai;  
\q2 emu hahemaoro ai basio ruhadia nege.   
\q1
\v 28 Ladadia na mauri taudia edia buka amo bae heroho,  
\q2 ladadia na kara maoromaoro taudia ladadia ida basie hetore.   
\b  
\q1
\v 29 A lau be na ogoḡamimu bona na hisihisimu:  
\q2 Dirava e, emu hahemauri ese atai ai baine atogu.   
\b  
\q1
\v 30 Lau ese Dirava ladana na egu ane ai baina heatolaia,  
\q2 egu hahenamo herevadia ai baina imodaia.   
\q1
\v 31 Ina kara na Iehova baine moalelaia bada,  
\q2 a boromakau baine moalelaia maraḡi,  
\q2 boromakau maruanena mai doana bona mai aena kahaudia ida baine moalelaia maraḡi.   
\q1
\v 32 Ogoḡami taumui, ba itaia bona ba moale;  
\q2 Dirava o tahuamu taumui, lalomui bae mauri lou;   
\q1
\v 33 badina be Iehova ese e dabumu taudia na e kamonai henidiamu, ena orea taudia iḡuidia ai e nohomu na se dadaraidiamu.   
\b  
\q1
\v 34 Guba bona tanobada ese bae imodaia,  
\q2 davara danu, bona lalonai e loamu ḡaudia.   
\q1
\v 35 Badina be Dirava ese Siona baine hamauria,  
\q2 bona Iuda hanuadia baine haginidia lou;  
\q1 iena hesiai taudia na unuseni ai bae noho,  
\q2 bae abia edia gabu;   
\q1
\v 36 iena hesiai taudia natudia ese bae abia, idia ahudia,  
\q2 bona ia ladana e lalokau heniamu taudia ese bae noholaia.   
\c 70  
\q1
\v 1 Dirava e, a harohogu mauri,  
\q2 Iehova e, ba durugu haraḡa.   
\q1
\v 2 Lauegu mauri iabi-ohona dalana e tahuamu taudia na  
\q2 ba hahemaraidia bona ba haheḡonudia;  
\q1 ihahisigu e uramu taudia na  
\q2 ba haloudia bona ba hahemaraidia.   
\q1
\v 3 E gwau henigumu, e tomu “Aha, aha”, taudia na  
\q2 edia hemarai dainai bae kudou hetaha.   
\b  
\q1
\v 4 E tahumunu taudia iboudiai na  
\q2 bae moale, oi bae moalelaimu;  
\q1 emu hahemauri e ura heniamu taudia na  
\q2 bae hereva loulou, baeto “Dirava na herea-dae”.   
\q1
\v 5 A lau be na ogoḡamimu bona na dabumu;  
\q2 Dirava e, aoma haraḡa dekegu ai.  
\q1 Oi na lau ikahagu bona lau ihamaurigu;  
\q2 Iehova e, basio halahe.   
\c 71  
\q1
\v 1 Iehova e, oi mo na abidadama henimumu;  
\q2 ba durugu, nega ta basie hahemaraigu.   
\q1
\v 2 Emu kara maoromaoro ai ba rauagu bona ba hamaurigu;  
\q2 ba hakala henigu, ba harohogu mauri.   
\q1
\v 3 Egu roho-mauri nadina ai baola,  
\q2 egu kohoro aukana ai baola, ihamaurigu totona;  
\q2 badina be oi na egu nadi-gini bona egu kohoro.   
\b  
\q1
\v 4 Egu Dirava e, kara dika tauna imana amo ba hamaurigu,  
\q2 kara gageva-gageva bona daḡedaḡe tauna imana amo.   
\q1
\v 5 Badina be, Ḡaubada e, egu helaro na oi,  
\q2 Iehova e, tauhaugu negana amo egu abidadama na oi.   
\q1
\v 6 Egu vara dinana amo oiemu ai vada na tabe kau;  
\q2 oi ese sinagu bogana amo o abigu.  
\q1 Oi mo na umodaimu hanaihanaimu.   
\b  
\q1
\v 7 Lau na toa ta, hutuma ediai;  
\q2 a oi na egu roho-mauri gabuna aukana.   
\q1
\v 8 Lau udugu na oi ihanamomu ai e honumu,  
\q2 bona oi hairaimu ai danu, dina idoinai.   
\q1
\v 9 Baina buruka negana ai basio negegu daure,  
\q2 egu goada e oremu negana ai basio rakatanigu.   
\q1
\v 10 Badina be inaigu ese e herevalaigumu,  
\q2 egu mauri iabi-ohona totona e bani taomu taudia na e henega boumu;   
\q1
\v 11 e tomu: Dirava ese vada e rakatania;  
\q2 a havaia, ba dabaia tao,  
\q2 badina be asi ihamaurina tauna ta.   
\b  
\q1
\v 12 Dirava e, dauhai basio noho  
\q2 egu Dirava e, a durugu haraḡa.   
\q1
\v 13 Ihabadelaigu taudia na hemarai bona hahebua-tari ese bae abidia,  
\q2 heihi-ihirai bona hedadarai ese bae ḡovadia ahu.   
\q1
\v 14 A lau be baina helaro Ioulou,  
\q2 bona oi ihanamomu baina habadaia loulou.   
\q1
\v 15 Udugu ese emu kara maoromaoro baine herevalai,  
\q2 emu hahemauri karadia baine gwaurai dina idoinai,  
\q2 badina be iduahidia na asi dibagu.   
\q1
\v 16 Ḡaubada Iehova ena siahu karadia baina gwauraidia,  
\q2 oiemu kara maoromaorodia baina imodaidia, oi mo sibomu emu.   
\q1
\v 17 Dirava e, tauhaugu negana amo vada o hadibagu;  
\q2 emu hoa karadia doini na gwauraidiamu.   
\q1
\v 18 Taunabunai, ena be baina iahu, huigu baine buruka,  
\q2 to, Dirava e, basio rakatanigu,  
\q1 ela bona oi siahumu baina gwauraia,  
\q2 do bae vara urudia iboudiai ediai.   
\q1
\v 19 Dirava e, oi siahumu bona emu kara maoromaoro na e dae e laomu.  
\q2 ela bona guba doriva-dorivana.  
\b  
\q1 Oi ese kara siahudia vada o kara,  
\q2 Dirava e, daika na oi idaimu?   
\q1
\v 20 Hisihisi dikadia momo amo vada o hahisigu,  
\q2 to vada ba hagoadagu lou;  
\q1 tanobada ena dobu gabudia amo  
\q2 ba hakaugu dae lou.   
\q1
\v 21 Oi ese imatauraigu ba habadaia,  
\q2 bona taugu ma ba haloa lou.   
\b  
\q1
\v 22 Egu Dirava e, hatai-hatai ḡauna amo danu baina hanamomu;  
\q2 emu momokani baina hanamoa.  
\q1 Israel ena Helaḡa Diravana e,  
\q2 gitara amo do baina hanamomu.   
\q1
\v 23 Oi ihanamolaimu anedia baina abi negadia ai,  
\q2 bibinagu na bae lolo, moale dainai,  
\q2 laumagu danu, oi ese o hamauria dainai.   
\q1
\v 24 Malagu danu oiemu hekaha maoromaorona baine gwauraia,  
\q2 dina idoinai;  
\q1 badina be ihahisigu dalana e tahuava taudia na  
\q2 vada e hahemaraidia bona vada e dadaraidia.   
\c 72  
\q1
\v 1 Dirava e, emu hahemaoro ḡoeva-daena na hanua pavapavana ba henia,  
\q2 emu kara maoromaoro na hanua pavapavana natuna ba henia.   
\q1
\v 2 Ba durua, emu orea taudia baine hahemaoro henidia mai maoromaorona ida,  
\q2 emu ogoḡami taudia baine hahemaoro henidia ḡoevaḡoeva.   
\q1
\v 3 Ororo badadia ese taunimanima edia maino bae havaraia,  
\q2 ororo maraḡidia ese taunimanima edia kara maoromaoro bae havara.   
\q1
\v 4 Ia na ogoḡami taudia ediai baine tao;  
\q2 e dabumu taudia na ia ese baine hamauridia,  
\q2 e daḡedaḡe henidiamu tauna na ia ese baine taoa tari.   
\q1
\v 5 Dina bona hua bae mia negadia iboudiai,  
\q2 iena mauri danu do baine mia, uru iboudiai lalodiai.   
\q1
\v 6 Medu na e utua guna reina latanai e dihomu na heto,  
\q1 medu maraḡidia na tanobada e haparipariamu na heto,  
\q2 ia danu unu baine heto.   
\q1
\v 7 Ena dina iboudiai kara maoromaoro baine tubu,  
\q2 maino danu baine bada, ela bona hua baine puki oho.   
\b  
\q1
\v 8 Davara ta amo ela bona davara ta, ia baine lohia;  
\q2 sinavai badana ela bona tanobada dokodia danu.   
\q1
\v 9 Ia inaina na ia vairanai bae igo diho,  
\q2 bae goru goru diho, kahu bae demari.   
\q1
\v 10 Tarasisi pavapavadia bona motumotu pavapavadia ese  
\q2 edia heaiva ḡaudia bae mailai, ena.  
\q1 Sieba bona Seba pavapavadia ese  
\q2 herahia ḡaudia bae mailai.   
\q1
\v 11 Pavapava iboudiai na ia vairanai bae goru diho;  
\q2 bese iboudiai na ia isiaina bae lao heni.   
\b  
\q1
\v 12 Badina be e dabumu tauna e boiboimu negana ai ia ese e hamauriamu,  
\q2 ogoḡami tauna bona asi iduruna tauna danu.   
\q1
\v 13 Ia ese manoka-manoka taudia bona ogoḡami taudia e bogadia hisimu  
\q2 bona e dabumu taudia e hamauridiamu.   
\q1
\v 14 Daḡedaḡe bona ala-ala amo ia ese edia mauri e rauadiamu,  
\q2 raradia na ḡau herea-daena ia vairanai.   
\b  
\q1
\v 15 Ena mauri baine daudau baine namo,  
\q2 Sieba \it gold\it*-na bae henia.  
\q1 Ia dainai bae ḡuriḡuri hanaihanai,  
\q2 dina idoinai ia ihanamolaina bae noinoilaia.   
\q1
\v 16 Aniani reidia na tano ai bae vara momomomo,  
\q2 ororo doridia reidia bae helado,  
\q2 anidia bae vara Lebanon ai na heto.  
\q1 Hanua hanua lalodiai taunimanima na bae hutuma,  
\q2 tano reidia na heheto.   
\q1
\v 17 Ia ladana baine mia hanaihanai,  
\q2 ia harina baine hesiriu,  
\q2 dina do baine mia heḡereḡerena.  
\q1 Ia dainai taunimanima ese namo bae davaria,  
\q2 bese iboudiai ese ia namona bae gwauraia.   
\b  
\q1
\v 18 Iehova, Israel Diravana, aita hanamoa;  
\q2 ia sibona hoa karadia e karamu.   
\q1
\v 19 Ia ladana herea-daena baita imodaia hanaihanai;  
\q2 ia hairaina ese tanobada idoinai baine hahonua. Amen. Amen.   
\b  
\q1
\v 20 David Iese ena ḡuriḡuri iniseni ai e dokomu.   
\c 73  
\q1
\v 1 Momokani, Dirava ena kara na namo, Israel enai;  
\q2 lalo-ḡoevaḡoeva taudia ediai ena kara na namo.   
\q1
\v 2 A lau be aegu mokona e hetutuhi,  
\q2 egu raka ai mokona na dedi.   
\q1
\v 3 Badina be kara dika taudia edia taḡa na itaia negana ai,  
\q2 hekokoroku taudia na vaḡeḡe henidia.   
\b  
\q1
\v 4 Badina be idia na asi edia hisihisi,  
\q2 tau-anidia na a'auka-a'auka bona tonika-tonika.   
\q1
\v 5 Idia na asie hisihisimu, haida heḡereḡeredia,  
\q2 bona se gorerediamu, haida bamodia.   
\q1
\v 6 Taunabunai, hekokoroku na aiodia agevana,  
\q2 daḡedaḡe ese e ḡovadiamu, dabua na heto.   
\q1
\v 7 Matadia na digara ese e hagudu lasimu,  
\q2 kavakava na lalodia amo e hepurai dobimu.   
\q1
\v 8 Idia na hevaseha bona badu herevadia e gwauraimu,  
\q2 atai gabudia amo dagedaḡe herevadia e gwauraimu.   
\q1
\v 9 Ududia reḡedia na guba ai e daemu,  
\q2 maladia reḡedia ese tanobada e hahonuamu.   
\b  
\q1
\v 10 Taunabunai, taunimanima e gini kerehaimu, e hanamodiamu,  
\q2 ediai kerere ta asie davariamu.   
\q1
\v 11 Idia na e tomu “Dirava na ede baine diba toma a?  
\q2 Herea Mikamika na mai dibana a?”   
\q1
\v 12 A itaia, kara dika taudia bini;  
\q2 asie hekwarahimu, to edia taḡa e bada e laomu.   
\q1
\v 13 Asi badina lalogu vada na haḡoevaia,  
\q2 asi badina imagu na kerere amo vada na huridia;   
\q1
\v 14 badina be dina idoinai vada na hisihisi,  
\q2 daba iboudiai hisi na animu.   
\q1
\v 15 Bama toma “Unu baina hereva toma”,  
\q2 natumu na edia uru ai bama koidia.   
\q1
\v 16 To na haeroa ede baina dibaia toma negana ai,  
\q2 ita-itana egu ai na hekwarahi ḡauna;   
\q1
\v 17 ela bona Dirava ena gabu helaḡana nala,  
\q2 bena edia doko daladia na diba.   
\q1
\v 18 Momokani, oi ese dedidedi gabudia ai o atodiamu,  
\q2 o habuadia tarimu;   
\q1
\v 19 vada e hebua tari haraḡa-haraḡa,  
\q2 gari ese vada e butudia tao.   
\q1
\v 20 Idia na nihi na heto, e noga tauna enai;  
\q2 o nogamu ai nihi ai o ita ḡaudia o dadaraidiamu.   
\b  
\q1
\v 21 Laumagu e hisihisiva  
\q2 bona lalogu na e kodoava negana ai,   
\q1
\v 22 lau na kavakava bona mata-lahui,  
\q2 lau na boroma na heto, oi vairamu ai.   
\q1
\v 23 Ḡau tamona, lau na hanaihanai oi ida,  
\q2 oi ese imagu idibana o dogoa taomu.   
\q1
\v 24 Emu sisiba amo o hakaugumu,  
\q2 gabe amo hairai ai bavabigu dae.   
\q1
\v 25 Guba ai daika baina davaria? Oi mo sibomu.  
\q2 Tanobada ai ḡau ta asina ura heniamu, oi mo sibomu.   
\q1
\v 26 Hidiogu bona lalogu bae manoka,  
\q2 a Dirava na lau lalogu ena goada,  
\q2 bona lau ahugu ela bona hanaihanai.   
\b  
\q1
\v 27 A itaia, oiemu amo dauhai e nohomu taudia na bae mase;  
\q2 oiemu ai e koikoimu taudia na o hamasediamu.   
\q1
\v 28 A Dirava badibadinai na nohomu be namo;  
\q2 Ḡaubada Iehova na egu roho-mauri gabuna ai vada na halaoa,  
\q2 emu kara iboudiai baina herevalaidia totona.   
\c 74  
\q1
\v 1 Dirava e, dahaka dainai o negemai daure hanaihanaimu?  
\q2 Badina be dahaka emu badu vada e siahu, o ubudiamu mamoedia latadiai?   
\q1
\v 2 Emu orea, idau nega ai o hoia, na ba laloa tao;  
\q2 oi ese o hamauria, emu bese korikori ai bainela totona;  
\q2 Siona ororona, vada o noholaia gabuna, ba laloa tao.   
\q1
\v 3 Vada e hekohutani vaitani hanuana ba raka henia kahi;  
\q2 inai taudia ese gabu helaḡana vada e habuaia tari.   
\b  
\q1
\v 4 Oi inaimu na emu gabu helaḡana bogaraginai vada e ḡou;  
\q2 sibodia edia toa vada e hagini, una gabu toana ai baela.   
\q1
\v 5 Atai iduarana ai perepere audia na ira amo e tara patapata;   
\q2
\v 6 au amo e koro ḡaudia iboudiai na ira bona hama amo vada e hamakohidia.   
\q1
\v 7 Emu gabu helaḡana vada e doua,  
\q2 oi ladamu e noholaiava gabuna vada e hamiroa tari ela bona tano.   
\q1
\v 8 Idia na e hereva heheni, eto “Aita hadareredia vaitani”;  
\q2 idia ese Dirava ena hebou gabudia iboudiai e doudia, tano idoinai.   
\q1
\v 9 Ai toamai na asia itadiamu,  
\q2 asi emai peroveta tauna ta,  
\q2 bogaragimai ai nega ena daudau idibana tauna ta lasi.   
\q1
\v 10 Dirava e, inai taudia bae kirikirilaimai ela bona edena nega ai?  
\q2 inai tauna ese oi ladamu baine ihi-ihiraia hanaihanai a?   
\q1
\v 11 Dahaka dainai oi imamu o veria loumu?  
\q2 Badina be dahaka oi imamu idibana na kememu dabuana ai o huniamu?   
\b  
\q1
\v 12 Ḡau tamona, matamana negana amo Dirava na egu Pavapava;  
\q2 tanobada bogaraginai ia ese ena hahemauri karadia e karamu.   
\q1
\v 13 Oi siahumu amo davara o hapararaia;  
\q2 lakara-donodono kwaradia o huaridia.   
\q1
\v 14 Leviathan\f + \fr 74:14 \ft Leviathan na uda ḡauna badana ta, reana Sia na heto. Heberu taudia na e laloa una ḡau kwarana na momo.\f* kwarana iboudiai o huaridia patapata,  
\q2 tano ḡaḡaena taudia o henidia, adia.   
\q1
\v 15 Tano o hapararaia, ranu baine lohilohi bona baine aru totona;  
\q2 e aru hanaihanaiva sinavaidia o hakororodia.   
\b  
\q1
\v 16 Dina na oiemu, hanuaboi danu oiemu,  
\q2 diari o karaia, bona dina danu.   
\q1
\v 17 Tano hetoadia iboudiai oi ese o kara;  
\q2 lahara negana o karaia, bona guitau danu.   
\b  
\q1
\v 18 Iehova e, inai taudia edia heihi-ihirai ba laloa tao,  
\q2 asie matauraimu taudia na oi ladamu e ihi-ihiraiamu danu.   
\q1
\v 19 Emu pune laumana na uda boromadia basio henidia,  
\q2 emu ogoḡami taudia edia mauri na basio laloa boio vaitani.   
\b  
\q1
\v 20 Emu gwauhamata ba laloa;  
\q2 badina be tano ena dibura gabudia na daḡedaḡe rumadia ai e honumu.   
\q1
\v 21 Vada e moidia tao taudia na basie hahemaraidia;  
\q2 ogoḡami taudia bona e dabumu taudia ese oi ladamu bae hanamoa.   
\b  
\q1
\v 22 Dirava e, a tore isi; emu hahemaoro na sibomu ba karaia;  
\q2 dina idoinai asie matauraimu taudia ese ede e kirikirilaimu toma na ba laloa tao.   
\q1
\v 23 Oi inaimu gurudia basio lalo boio;  
\q2 e inai henimumu taudia edia heloḡo-heloḡo reḡena na e dae louloumu.   
\c 75  
\q1
\v 1 Dirava e, ai oi a hanamomumu, a imodaimumu;  
\q2 oi ladamu a hahaneamu, emu hoa karadia a gwauraidia hedinaraimu.   
\b  
\q1
\v 2 Na gwauraia guna negana baine kau,  
\q2 bena baina hahemaoro ḡoevaḡoeva.   
\q1
\v 3 Tanobada mai inoho-henina taudia iboudiai ida e raragararagamu negana ai,  
\q2 lau ese na imudadiamu. (Selah)   
\q1
\v 4 Hekokoroku taudia na hamaorodiamu, na tomu  
\q2 “Basio hekokoroku”.  
\q1 Kara dika taudia na hamaorodiamu, na tomu  
\q2 “Doamui basio abi isi;   
\q1
\v 5 doamui basio dudui isi atai ai;  
\q2 basio hereva aio haboḡe isi”.   
\b  
\q1
\v 6 Heabi-isi na dia dina-dae gabudia amo eiava dina-diho gabudia amo,  
\q2 bona dia tano ḡaḡaena amo se maimu;   
\q1
\v 7 a Dirava ese hahemaoro e karaiamu,  
\q2 ta e atoa dihomu, ma ta e abia isimu.   
\q1
\v 8 Badina be kehere ta na Iehova imana ai,  
\q2 lalonai vine ranuna na kakakaka,  
\q2 e buloa namonamo ḡauna;  
\q1 ia ese baine seia,  
\q2 bena tanobada ena kara dika taudia iboudiai ese bae inua ore.   
\b  
\q1
\v 9 A lau be baina moale hanaihanai,  
\q2 Iakob ena Dirava ihanamolaina anedia baina abi.   
\q1
\v 10 Kara dika taudia doadia iboudiai ia ese baine utu oho,  
\q2 a kara maoromaoro taudia doadia bae heabi isi.   
\c 76  
\q1
\v 1 Iuda ai idia dibadia Dirava,  
\q2 Israel ai ia ladana na bada.   
\q1
\v 2 Salem ai ena ruma vada e hadaia,  
\q2 Siona ai ena noho gabuna vada e haginia.   
\q1
\v 3 Unuseni ai diba kiama-kiamadia e hakwaidudia,  
\q2 kesi bona dare bona tuari ḡaudia idau-idau danu. (Selah)   
\q1
\v 4 Oi na herea dae; oi hairaimu ese  
\q2 mia-hanaihanai ororodia hairaidia e hereadiamu.   
\q1
\v 5 Goada taudia edia dadihai kohudia na edia amo ma e dadihai,  
\q2 mahuta ese e abidia;  
\q1 tuari taudia iboudiai na  
\q2 imadia edia goada vada e ore.   
\q1
\v 6 Iakob Diravana e, o gwau henidia negana ai  
\q1 hosi mai iguina tauna ida e habereredia.   
\b  
\q1
\v 7 A oi na mai igari-henimu;  
\q2 emu badu baine ḡaraḡara negana ai,  
\q2 daika ese oi vairamu ai baine gini diba?   
\q1
\v 8 Guba amo oi ese hahemaoro o gwauraia;  
\q2 tanobada na e gari, bena se marere-marere.   
\q1
\v 9 Una negana ai Dirava e tore isi, hahemaoro ihaginina totona,  
\q2 tanobada ai hisi e animu taudia iboudiai ihamauridia halaoreana. (Selah)   
\b  
\q1
\v 10 Momokani, taunimanima edia badu ese baine hanamomu,  
\q2 badu orena na oi ese ba haheriolaia.   
\q1
\v 11 Emu gwauhamata na Iehova, emui Dirava, ba henia,  
\q2 bona anidia danu ba kara.  
\q1 E ginia heḡeḡemu taudia iboudiai na herahia bae mailai,  
\q2 e gari heniamu Diravana ena.   
\q1
\v 12 Ia ese lohia laumadia e laodia ahumu,  
\q2 bona tanobada pavapavadia e hagaridiamu.   
\c 77  
\q1
\v 1 Dirava na tai henia lolomu,  
\q2 Dirava na tai henia goadagoadamu,  
\q2 baine kamonai henigu halaoreana.   
\q1
\v 2 Egu hekwarahi dinana ai Ḡaubada na tahuamu,  
\q2 hanuaboi ai imagu na toia roromu, asina hesikumu,  
\q2 laumagu ese ihalolaina se ura heniamu.   
\b  
\q1
\v 3 Dirava na laloamu, bena na ḡanaḡanamu;  
\q2 lalogu na hadaiamu, bena laumagu na e dauremu. (Selah)   
\q1
\v 4 Matagu kopidia o dogo taomu, basie kapu;  
\q2 egu hekwarahi e badamu dainai basina hereva dibamu.   
\q1
\v 5 Dina gunadia na haerodiamu,  
\q2 vada e lao bubuni laḡanidia na lalodia taomu.   
\q1
\v 6 Hanuaboi ai lalogu na tahuamu;  
\q2 lalogu na hadaiamu, bona laumagu na tahuamu.   
\q1
\v 7 Ḡaubada baine dadaraigu hanaihanai,  
\q2 nega ta basine lalo namo henigu lou a?   
\q1
\v 8 Ena hebogahisi vada e doko vaitani,  
\q2 ena gwauhamata vada e doko ela bona hanaihanai a?   
\q1
\v 9 Dirava ese harihari-bada vada e laloa boio,  
\q2 ena badu ese ena hebogahisi vada e laoa ahu a? (Selah)   
\q1
\v 10 Lau na tomamu “Egu lalo-hisihisi binai,  
\q2 Herea Mikamika ese imana idibana na vada e ha-idaua”.   
\b  
\q1
\v 11 Iehova ena kara baina lalodia une;  
\q2 oibe, oiemu hoa karadia gunadia baina lalodia tao.   
\q1
\v 12 Emu ḡaukara idoinai baina lalo-hadailaia,  
\q2 emu siahu karadia danu baina haerodia.   
\q1
\v 13 Dirava e, emu dala na helaḡa.  
\q2 Edena dirava na emai Dirava idaina?   
\q1
\v 14 Hoa karadia ikaradia Diravana na oi,  
\q2 oi ese emu siahu vada o hahedinaraia,  
\q2 bese idau-idau bogaragidiai.   
\q1
\v 15 Oi imamu amo emu bese taudia o hamauridia,  
\q2 Iakob bona Iosef garadia.   
\q1
\v 16 Dirava e, ranu ese e itamu negana ai,  
\q2 ranu ese e itamu negana ai, ia na e gari;  
\q2 oibe, dobu gabudia e heude-heude.   
\q1
\v 17 Ori ese medu e hadihoa,  
\q2 guba danu e rahua,  
\q2 bona emu kevaru e kevarua isi, kaha iboudiai.   
\q1
\v 18 Emu guba rahurahu e makohi dagu, koea hirihiri lalonai,  
\q2 emu kevaru ese tanobada e hadiaria,  
\q2 tanobada e marere-marere bona e heude-heude.   
\q1
\v 19 Emu raka na davara bogaragina amo,  
\q2 emu dala na ranu badadia bogaragidia amo;  
\q2 a vataḡamu na tau ta ese se itadia.   
\q1
\v 20 Emu bese taudia na o hakaudia, mamoe serina na heto,  
\q2 Mose bona Aaron imadia amo.   
\c 78  
\q1
\v 1 Egu orea taumui e, egu hahediba herevadia a kamonai,  
\q2 taiamui a hakala, lau udugu herevadia a kamonai.   
\q1
\v 2 Sivarai heḡereḡerena ta baina gwauraia,  
\q2 sene herevadia hehunidia;   
\q1
\v 3 ai a kamonai bona dibamai,  
\q2 tamamai ese vada e hamaoromai ḡaudia,  
\q2 baina gwaurai.   
\q1
\v 4 Besedia edia amo basia hunidia,  
\q2 a Iehova ena kara herea-daedia bona ena goada,  
\q1 bona hoa karadia ia ese vada e kara,  
\q2 uru gabena taudia baia hamaorolaidia.   
\q1
\v 5 Ia ese haheḡani e atoa Iakob ena,  
\q2 bona taravatu na Israel e henia.  
\q1 Bena seneda e haḡanidia,  
\q2 idia ese natudia bae hadibadia eto;   
\q1
\v 6 uru gabena taudia bae diba totona,  
\q2 do asie vara memerodia danu;  
\q1 bena idia na bae tore isi,  
\q2 natudia ma bae hamaorolaidia.   
\q1
\v 7 Unu amo Dirava bae laroa,  
\q2 bona Dirava ena ḡaukara basie laloa boio,  
\q2 a ena haheḡani bae badinadia.   
\q1
\v 8 Unu amo danu tamadia ida basie heḡereḡere:  
\q2 lalo-auka bona gwau-edeede uruna bunai,  
\q1 lalodia asie hadai maoromaoro uruna,  
\q2 laumadia ese Dirava asie badinaia.   
\b  
\q1
\v 9 Efraim taudia mai edia peva na  
\q2 tuari dinana ai e lou.   
\q1
\v 10 Dirava ena gwauhamata asie badinaia,  
\q2 bona ena taravatu irakalaina e dadaraia.   
\q1
\v 11 E kara ḡaudia e lalodia boio,  
\q2 bona ena hoa karadia e hahedinaraiva ḡaudia danu.   
\q1
\v 12 Senedia vairadiai ia ese hoa karadia e kara,  
\q2 Aigupto tanona ai bona Soan taorana ai.   
\q1
\v 13 Davara e hapararaia, bena idia ese e rakaia hanai,  
\q2 ranu na e haginia tao, senu ta na heto.   
\q1
\v 14 Dina ai ia ese ori dubuna amo e hakaudia,  
\q2 bona hanuaboi idoinai lahi mamana amo.   
\q1
\v 15 Tano ḡaḡaena ai nadi e hapararadia,  
\q2 inuinu ranuna momo e henidia, ranu dobuna heḡereḡerena.   
\q1
\v 16 Ranu na nadi amo e ha-arua lasi,  
\q2 ranu na e aru dobi, sinavai na heheto.   
\q1
\v 17 Ḡau tamona idia ese edia kara havara e habadaia ienai,  
\q2 tano ḡaḡaena ai Herea Mikamika e gwau edeede henia.   
\q1
\v 18 Lalodia ai Dirava e tohoa,  
\q2 edia ura anianidia e gwaurai;   
\q1
\v 19 Dirava e ihi-ihiraia, eto  
\q2 “Tano gaḡaena ai Dirava ese aniani baine dabaraia a?   
\q1
\v 20 Ia ese nadi e botaia, bena ranu e aru lasi,  
\q2 koupa-koupa e aru rohoroho;  
\q1 a aniani danu baine heni diba,  
\q2 eiava vamu na ena orea taudia baine henidia diba a?”   
\q1
\v 21 Taunabunai Iehova e kamonai negana ai na e badu dikadika,  
\q2 Iahi e ara Iakob enai,  
\q2 ena badu e ḡaraḡara Israel enai;   
\q1
\v 22 badina be Dirava asie abiabiraia,  
\q2 ena hahemauri siahuna asie abidadama henia.   
\q1
\v 23 Ḡau tamona, ia ese guba atai ai e haḡanidia,  
\q2 bona guba iduaradia e kehodia;   
\q1
\v 24 mana na latadiai e hadihoa medu na heto, adia,  
\q2 guba anianidia e henidia.   
\q1
\v 25 Taunimanima ese aneru adia aniani e aniva;  
\q2 ia na aniani momo e siaia, adia.   
\q1
\v 26 Guba ai lai mairiveina e toa, ena hahedua dainai,  
\q2 ena siahu amo lai diho e hakaua lasi;   
\q1
\v 27 vamu na latadiai e hadihoa gahu na heto,  
\q2 roho manudia e hadihodia kone mirina na heto;   
\q1
\v 28 ia ese e hamorudia edia taruha bogaraginai,  
\q2 edia noho gabudia heḡeḡemadai.   
\q1
\v 29 Idia na e aniani, bogadia e kunu;  
\q2 e gadodiava ai e urava ḡaudia na e henidia.   
\q1
\v 30 A dounu e gadova negana ai,  
\q2 aniani na dounu ududia ai,   
\q1
\v 31 Dirava ena badu na e vara latadiai;  
\q2 bena goada-herea taudia ia ese e aladia mase,  
\q2 Israel ena abi-hidi taudia ia ese e hamasedia.   
\b  
\q1
\v 32 Ena be unu e kara toma, to idia na dounu e kara havara;  
\q2 ena be ena hoa karadia e ita, to idia na asie abia dae.   
\q1
\v 33 Taunabunai, ia ese edia dina e ha-oredia, hahodi tamona na heto,  
\q2 edia laḡani danu gari ai e ha-oredia.   
\q1
\v 34 E aladiava negadia ai, idia ese ia e tahuava,  
\q2 e helalo kerehaiva, bona Dirava e tahua malaka-malakava.   
\q1
\v 35 E helalo taova, Dirava na edia nadi-gini,  
\q2 Dirava Herea Mikamika na idia ihamauridia.   
\q1
\v 36 A ududia amo e hanamoa kava,  
\q2 maladia amo e koia;   
\q1
\v 37 lalodia na asie hatutukadia ienai,  
\q2 ena taravatu asie badinaia.   
\q1
\v 38 Ḡau tamona, ena hebogahisi dainai  
\q2 ia ese edia dika e gwau tao,  
\q2 bona se habuadia tari;  
\q1 nega momo ena badu e dogoa tao,  
\q2 ena badu siahuna idoinai asine havaraia.   
\q1
\v 39 E helalo tao, idia na hidio mo,  
\q2 lai nega tamona e toa bena ma se toa lou.   
\q1
\v 40 Nega momo idia ese tano ḡaḡaena ai e gwau edeede heniava,  
\q2 oibe, tano deḡedeḡe rahu ai lalona e hahisihisiava.   
\q1
\v 41 E tohoa loulouva,  
\q2 Israel edia Helaḡa Diravana e habaduava.   
\q1
\v 42 Ena siahu asie laloa taova,  
\q2 inai tauna imana amo e hamauridia dinana na asie laloa taova.   
\q1
\v 43 Una negana ai, ia ese ena toa e kara Aigupto ai,  
\q2 bona ena hoa karadia Soan taorana ai.   
\q1
\v 44 Edia sinavai na rara ai e halaodia,  
\q2 taunabunai edia sinavai ranudia asie inu dibava.   
\q1
\v 45 Lao momo herea e siaidia, idia taudia e ani,  
\q2 bona parapara danu, idia e habuadia.   
\q1
\v 46 Edia uma anidia na rautunutunu e henidia,  
\q2 bona edia hekwarahi huahuadia na kwadi e henidia.   
\q1
\v 47 Edia vine na medu hetari amo e habuadia tari,  
\q2 bona edia suke audia danu keru amo.   
\q1
\v 48 Edia boromakau na medu hetari amo e hadikadia,  
\q2 edia mamoe danu kevaru amo.   
\b  
\q1
\v 49 Ena badu ḡaraḡara na idia latadiai e halasia,  
\q2 badu bona daḡedaḡe bona hahehisi,  
\q2 hahedika anerudia oreana ta na heto.   
\q1
\v 50 Ena badu dalana e lailaia;  
\q2 mase amo se rauadia,  
\q2 a dai-hanai goreredia amo e hamasedia.   
\q1
\v 51 Aitupto taudia natudia roboadia iboudiai e aladia mase,  
\q2 edia goada roboadia, Ham ena kalaga lalodiai.   
\q1
\v 52 Bena ena orea taudia e hakaudia lasiva, mamoe na heheto,  
\q2 tano ḡaḡaena ai e hakaudiava, seri na heto.   
\q1
\v 53 Dala namona ai e hakaudia, taunabunai asie gari;  
\q2 a inaidia na davara ese e habubunidia.   
\q1
\v 54 Ena tano helaḡana ai e hakaudia lao,  
\q2 ia imana idibana e kwalimu ororona ai.   
\q1
\v 55 Bese idau-idau na idia vairadia amo e luludia oho,  
\q2 edia tano e haridia;  
\q1 Israel iduhudia na  
\q2 idia edia kalaga ai e hanohodia.   
\b  
\q1
\v 56 A idia ese Dirava Herea-mikamika e tohoa bona e gwau edeede henia;  
\q2 ena hereva momokanidia asie badinadia.   
\q1
\v 57 E raka muri, e kara koikoi, tamadia heḡereḡeredia;  
\q2 e kara gageva-gageva, peva dikana, koikoi ḡauna, na heto.   
\q1
\v 58 Badina be edia atai gabudia helaḡadia amo e habadua,  
\q2 edia kaivakuku e koro ḡaudia amo e havaḡeḡea.   
\q1
\v 59 Dirava e kamonai negana ai,  
\q2 ia na e badu dikadika,  
\q2 ia ese Israel e dadaraia vaitani.   
\q1
\v 60 Ena noho kalagana Silo ai e rakatania,  
\q2 taunimanima bogaragidiai e noholaiava ḡauna;   
\q1
\v 61 ena siahu e negea, heabi-mauri ḡauna ai ela.  
\q2 ia hairaina e negea, inai tauna imana ai.   
\q1
\v 62 Ena orea taudia na dare matana ai e henidia,  
\q2 ia dihina e badu henidia.   
\q1
\v 63 Lahi ese edia uhau e haḡoledia oho;  
\q2 edia ulato na asi edia headava anedia.   
\q1
\v 64 Edia hahelaḡa taudia na dare matana ai e moru,  
\q2 vabudia ese idia taidia asie tai.   
\q1
\v 65 Bena Ḡaubada na mahuta amo e noga,  
\q2 goada tauna vine ranuna e inua dainai e lolomu na heto;   
\q1
\v 66 ia inaina e hakarohodia rohoroho,  
\q2 e hahemaraidia ela hanaihanai.   
\b  
\q1
\v 67 Ia ese Iosef ena kalaga e dadaraia,  
\q2 bona Efraim iduhuna se abia hidi;   
\q1
\v 68 a Iuda iduhuna e abia hidi,  
\q2 Siona ororona, ena lalokau.   
\q1
\v 69 Ena gabu helaḡana e hadaia, guba doriva-dorivana na heto,  
\q2 eiava tanobada na heto, vada e hadaia mia hanaihanai ḡauna.   
\q1
\v 70 Ia ese David e abia hidi, ena hesiai tauna,  
\q2 mamoe maḡudia amo e abia;   
\q1
\v 71 mamoe hahinedia mai natudia ida ireḡudia amo e hakaua mai,  
\q2 ena orea taudia, Iakob besena, ireḡudia,  
\q2 ia dihina Israel ireḡudia totona.   
\q1
\v 72 Mai lalo-maoromaorona ida e reḡudia,  
\q2 bona mai ima namona ida e hakaudia.   
\c 79  
\q1
\v 1 Dirava e, bese idau-idau ese oi ahumu vada e abia,  
\q2 emu dubu helaḡana vada e hamiroa,  
\q2 Ierusalem vada e ḡiḡia dobi.   
\q1
\v 2 Emu hesiai taudia tau-anidia na  
\q2 atai manudia vada e henidia, adia;  
\q1 emu helaḡa taudia hidiodia na  
\q2 tanobada boromadia vada e henidia.   
\q1
\v 3 Raradia vada e hahebubua, ranu heḡereḡerena, Ierusalem heḡeḡemadai ai,  
\q2 asi tauna ta noho, idia baine guridia.   
\q1
\v 4 Dekemai taudia ese e ihi-ihiraimaimu,  
\q2 e ḡeḡemai daemu taudia ese e ḡonaḡonalaimaimu,  
\q2 bona e kirikirilaimaimu.   
\q1
\v 5 Iehova e, ba badu henimai ela bona edena nega ai? Ela hanaihanai a?  
\q2 Emu vaḡeḡe baine ara lahi na heto a?   
\q1
\v 6 Asia dibamu besedia latadiai emu badu ba seia dobi,  
\q2 oi ladamu asie hahaneamu basileiadia latadiai danu;   
\q1
\v 7 badina be idia ese Iakob vada e ania ore,  
\q2 ena noho gabuna vada e havahua.   
\b  
\q1
\v 8 Senemai edia kara havara na basio lalo tao, ai ihadikalaimai;  
\q2 emu hebogahisi baine mai henimai haraḡa,  
\q2 badina be ai na vada ame baia.   
\q1
\v 9 Ihamaurimai Diravana e, ba kahamai,  
\q2 oi ladamu hairaina bagunai;  
\q1 ba hamaurimai bona emai dika ba gwau tao,  
\q2 oi ladamu dainai.   
\q1
\v 10 Anina be dahaka bese idau-idau baeto  
\q2 “Edia Dirava be edeseni ai?”  
\q1 Emu hesiai taudia raradia e hebubu idavalaidia na  
\q2 bese idau-idau bae diba,  
\q2 ai vairamai ai.   
\b  
\q1
\v 11 Iḡui taudia edia ḡanaḡana na oiemu ai baine dae;  
\q2 vada e revadia mase taudia na oi siahumu badana amo ba hamauridia.   
\q1
\v 12 Ḡaubada e, ai dekemai taudia latadiai  
\q2 oi vada e ihi-ihiraimu taudia edia heihi-ihirai na  
\q2 nega hahitu ba halou henidia;   
\q1
\v 13 bena ai, emu bese taudia, emu seri mamoedia,  
\q2 baia imodaimu hanaihanai;  
\q1 uru ta ela bona ma uru ta  
\q2 oi ihanamomu baia gwaurai hesiriu-hesiriu.   
\c 80  
\q1
\v 1 Israel Ireḡuna e, a hakala!  
\q2 Oi ese Iosef o hakauamu, mamoe serina na heto.  
\q1 Kerubi latadiai o helaimu Diravana, a diari,   
\q2
\v 2 Efraim bona Beniamina bona Manase vairadiai.  
\q1 Mai goadamu ida ba tore isi;  
\q2 ihamaurimai totona baoma.   
\b  
\q1
\v 3 Dirava e, ma bavabimai dae lou;  
\q2 oi vairamu baine diari, bena baia roho mauri.   
\b  
\q1
\v 4 Iehova Sabaota e, emu bese taudia edia ḡuriḡuri na  
\q2 ba badulai ela bona edena nega ai?   
\q1
\v 5 Iruru-mata o ha-anilaidia,  
\q2 bona ma o ha-inulaidia davana.   
\q1
\v 6 Dekemai taudia edia ihi-ihirai ḡauna ai vada o halaomai;  
\q2 ai inaimai ese e kirikirilaimai hehenimu.   
\b  
\q1
\v 7 Iehova Sabaota e, ba hamaurimai;  
\q2 oi vairamu baine diari, bena baia roho mauri.   
\b  
\q1
\v 8 Vine auna ta Aigupto amo o mailaia;  
\q2 bese idau-idau o luludia lasi, bena o hadoa;   
\q1
\v 9 tano o lailaia, ia ihadona totona,  
\q2 ramuna e hedai, tano e vevea ahu.   
\q1
\v 10 Ororo na ia ese e hakerukerudia,  
\q2 sida audia badadia na ia rigina ese e lahea ahu;   
\q1
\v 11 ia rigina e toia roro ela bona davara,  
\q2 ia tuhutuhuna ela bona sinavai badana.   
\q1
\v 12 Dahaka dainai ia maḡuna vada o hamakohia,  
\q2 bena raka-hanai taudia iboudiai ese ia huahuana e burukimu?   
\q1
\v 13 Uda boromana ese e raḡaiamu;  
\q2 uda ḡaudia iboudiai ese e heubulaimu.   
\b  
\q1
\v 14 Iehova Sabaota e, a roha kerehai!  
\q2 Guba amo a roha dobi, a itaia.  
\q1 Ina vine auna a haḡerea,   
\q2
\v 15 ia na oi imamu idibana ese e hadoa ḡauna.   
\q1
\v 16 Idia ese lahi amo e doua, bona e utua oho;  
\q2 oi vairamu baduna ese baine hamasedia be namo.   
\q1
\v 17 Oi imamu na idibamu kahana tauna latanai baine mia,  
\q2 bona taunimanima natuna, o hagoadaia sibomu emu, latanai.   
\q1
\v 18 Bena oiemu amo basia raka muri;  
\q2 mauri ba henimai, bena oi ladamu baia hahanea.   
\b  
\q1
\v 19 Iehova Sabaota e, ba hamaurimai;  
\q2 oi vairamu baine diari, bena baia roho mauri.   
\c 81  
\q1
\v 1 Ane avabia lolololo, eda goada Diravana ena;  
\q1 a hisi dae, Iakob ena Dirava enai.   
\q2
\v 2 Ane a ladaia isi, tareko a hareḡedia;  
\q1 gitara bona hatai-hatai ḡauna badana danu a hatai.   
\q2
\v 3 Hua matamatana negana ai kibi a hiriria,  
\q1 hua e idoi negana ai danu,  
\q2 eda aria dinana bunai.   
\q1
\v 4 Badina be taravatu bunai Israel ena;  
\q2 Iakob ena Dirava ena haheḡani bunai;   
\q1
\v 5 ena hahediba herevana Iosef e henia,  
\q2 Aigupto ai e loa eva-eva negana ai.  
\b  
\q1 Asi dibagu gadona ta na kamonaia;   
\q2
\v 6 Maduna na paḡamu amo na abia oho,  
\q2 imamu na bosea amo na kokidia.   
\q1
\v 7 Emu hisihisi ai o boi henigu, bena na hamaurimu;  
\q2 guba rahu-rahu ena gabu hehunina ai na haere henimu,  
\q2 Meriba ena ranu gabudia ai na tohomu. (Selah)   
\q1
\v 8 Egu bese taumui e, a hakala, baina sisiba henimui;  
\q2 Israel e, boma kamonai henigu bema namo.   
\q1
\v 9 Bogaragimui ai dirava idauna ta basine noho,  
\q2 idau taudia edia dirava ta basio toma henia diho.   
\q1
\v 10 Lau binai Iehova, emui Dirava,  
\q2 Aigupto amo na hakaumui lasi.  
\q2 Udumui a haḡadia, bena baina hahonudia.   
\b  
\q1
\v 11 A egu bese taudia na gadogu asie kamonaia;  
\q2 Israel ese e dadaraigu.   
\q1
\v 12 Taunabunai na negedia,  
\q2 sibodia edia lalo-auka bae badinaia,  
\q2 sibodia edia lalo-hadai karadia bae kara.   
\q1
\v 13 Egu bese taudia bema kamonai henigu bema namo;  
\q2 Israel na egu dala ai bema raka bema namo.   
\q1
\v 14 Bena idia inaidia bama hadareredia haraga,  
\q2 e tuari henidia taudia bama tuari henidia.   
\q1
\v 15 Iehova e inai heniamu taudia na ia vairanai bema igo diho;  
\q2 matadia ihakanidia bema hesiriu hanaihanai.   
\q1
\v 16 Uit namo-hereana amo bama ubumui,  
\q2 bada-ranuna nadi amo e abiamu na bama ubulaimui.   
\c 82  
\q1
\v 1 Dirava ese dirava edia hebou lalonai ena gabu vada e abia,  
\q2 dirava idau-idau bogaragidiai hahemaoro e karaiamu.   
\q1
\v 2 Umui na ba hahemaoro kerere-kerere ela bona edena nega ai?  
\q2 Kara dika taudia ediai ba tao ela bona edena nega ai? (Selah)   
\q1
\v 3 Asie goadamu taudia bona ihareha na hahemaoro maorona ba henidia,  
\q2 hisihisi taudia bona ogoḡami taudia edia dala maorodia ba gwaurai.   
\q1
\v 4 Asie goadamu taudia bona e dabumu taudia ba hamauridia;  
\q2 kara dika taudia imadia amo ba harohodia mauri.   
\b  
\q1
\v 5 Idia na asi edia aonega bona asi edia lalo-parara,  
\q2 dibura ai a loa eva-evamu;  
\q2 tanobada badidia iboudiai na e heude-heudemu.   
\b  
\q1
\v 6 Lau na tomamu: Umui na dirava;  
\q2 iboumui ai na Herea Mikamika natuna;   
\q1
\v 7 ḡau tamona, taunimanima heḡereḡeredia do ba mase,  
\q2 hanua pavapavana natuna ta heḡereḡerena ba keto.   
\b  
\q1
\v 8 Dirava e, a tore isi, tanobada ba hahemaoro henia;  
\q2 badina be bese iboudiai na oiemu.   
\c 83  
\q1
\v 1 Dirava e, basio noho hedavauhe,  
\q2 Dirava e, eremu basio kumaia, Iaḡamu basio ania.   
\q1
\v 2 A itaia, oi inaimu na e heloḡo-heloḡomu,  
\q2 e inai henimumu taudia na e gaga isimu.   
\q1
\v 3 Oiemu bese idoadia daladia e ato hatamu,  
\q2 o reḡudiamu taudia ihadikadia totona e henega boumu.   
\q1
\v 4 Idia na e tomu “Aoma, una bese baita habuaia tari,  
\q2 Israel ladana basie laloa tao Iou ela bona hanaihanai”.   
\q1
\v 5 Oibe, mai lalodia tamona e henegamu,  
\q2 oi ihadikamu totona e gwau hamata hehenimu.   
\q1
\v 6 Taudia bini: Edom bona Ismael iduhudia iboudiai,  
\q2 bona Moab taudia, bona Hagara besena danu;   
\q1
\v 7 Gebala bona Amono bona Amalek,  
\q2 bona Filistia bona Turo taudia danu.   
\q1
\v 8 Asuria danu idia ida vada e hebou,  
\q2 idia na Lot garana e ima henia heboumu. (Selah)   
\q1
\v 9 Midian taudia o kara henidia heḡereḡerena,  
\q2 idia danu unu ba kara henidia toma;  
\q1 eiava Sisera bona Iabin na Kison sinavaina isena ai  
\q2 o kara henidia heḡereḡerena.   
\q1
\v 10 En-doro ai o habuadia tari,  
\q2 tano seriserina ai o halaodia.   
\q1
\v 11 Edia lohia na Oreb bona Sebe heḡereḡeredia ai ba halaodia,  
\q2 edia pavapava iboudiai na Sebaha bona Salmuna heḡereḡeredia ai.   
\q1
\v 12 Idia na eto “Dirava ena rei gabudia na  
\q2 baita abidia iseda”.   
\b  
\q1
\v 13 Egu Dirava e, mariu nadinadidia e morumu e hegiromu heḡereḡeredia ai ba halaodia,  
\q2 eiava uit momodia lai ese e oda ohomu heḡereḡeredia ai.   
\q1
\v 14 Lahi ese uda e ḡoleamu na heto,  
\q2 lahi hururuna ese ororo udadia e aradiamu na heto,   
\q1
\v 15 emu lai badana ese unu baine havadia toma,  
\q2 emu lai gubana ese unu baine hagaridia toma.   
\q1
\v 16 Iehova e, vairadia ba hahemaraidia,  
\q2 oi ladamu bae tahua helaoreana;   
\q1
\v 17 ba hahemaraidia bona ba hadaradaradia hanaihanai,  
\q2 edia hemarai ai do bae mase.   
\q1
\v 18 Ba hadibadia, bena bae diba,  
\q2 oi ladamu na Iehova;  
\q2 oi mo sibomu Herea Mikamika, tanobada idoinai daenai.   
\c 84  
\q1
\v 1 Iehova Sabaota e,  
\q2 emu noho gabuna na mai hairaina.   
\q1
\v 2 Lau laumagu na e ganaḡanamu,  
\q2 Iehova ena maḡu e mase heniamu;  
\q1 lalogu bona hidiogu na moale anedia e abimu,  
\q2 mauri Diravana ena.   
\b  
\q1
\v 3 Iehova Sabaota e,  
\q2 egu pavapava, egu Dirava,  
\q1 bisini na ena noho gabuna e davariamu,  
\q2 emu pata helaḡana enai;  
\q1 aibisi danu ena ruma unuseni ai e karaiamu,  
\q2 bona natuna e havaradiamu.   
\q1
\v 4 Emu ruma ai e nohomu taudia na nanamo,  
\q2 idia ese oi ihanamomu anedia e abi hanaihanaimu. (Selah)   
\q1
\v 5 Edia goada oiemu amo e abiamu taudia na nanamo,  
\q2 Siona ilao-henina daladia na idia lalodia ai.   
\q1
\v 6 Baka kourana e rakaia hanaimu negana ai,  
\q2 idia ese ranu lohilohi gabuna ai e halaoamu;  
\q1 medu matamana ai danu,  
\q2 una koura na gohugohu ai e hahonuamu.   
\q1
\v 7 Edia goada na e bada e laomu;  
\q2 dirava edia Dirava na Siona ai baine hedinarai.   
\q1
\v 8 Iehova Sabaota e, egu guriḡuri a kamonaia;  
\q2 Iakob ena Dirava e, a hakala henigu. (Selah)   
\q1
\v 9 Dirava e, emai kesi a itaia;  
\q2 o horoa tauna vairana ba haḡerea.   
\b  
\q1
\v 10 Badina be dina tamona emu maḡu ai ese  
\q2 dina daha idau gabu ai na e hereadiamu;  
\q1 egu Dirava ena ruma iduarana inarina ai bama lao hari namo herea,  
\q2 a kara dika taruhadia ai bama noho na dia namo.   
\q1
\v 11 Badina be Ḡaubada Iehova na dina bona kesi,  
\q2 ia na harihari-bada bona hailai e henimu.  
\q1 Iehova ese ḡau namona ta se ruamu,  
\q2 e raka maoromaoromu taudia ediai.   
\q1
\v 12 Iehova Sabaota e,  
\q2 oi e abidadama henimumu tauna be namo.   
\c 85  
\q1
\v 1 Iehova e, emu tano o lalo namo heniava,  
\q2 Iakob ena noho o hanamoava.   
\q1
\v 2 Emu bese taudia edia dika o gwau tao,  
\q2 edia kara dika idoinai o laloa nege.   
\q1
\v 3 Emu badu idoinai o abia oho,  
\q2 emu badu ḡaraḡarana amo o kerehai.   
\b  
\q1
\v 4 Ihamaurimai Diravana e, ba hamaurimai lou;  
\q2 emu badu emai ai ba negea daure.   
\q1
\v 5 Ba badu henimai hanaihanai a?  
\q2 Emu badu ba hadaudaua ela bona uru iboudiai a?   
\q1
\v 6 Emu bese taudia bae moalelaimu totona  
\q2 basio hamaurimai lou a?   
\q1
\v 7 Iehova e, emu hebogahisi na emai ai ba hahedinaraia,  
\q2 emu hahemauri ba henimai.   
\b  
\q1
\v 8 Ḡaubada Iehova ena hereva mani aina kamonai;  
\q2 badina be ia ese maino herevadia baine gvaurai, ena orea taudia ediai,  
\q2 ena helaḡa taudia danu, lalodia ai ia e haḡereamu taudia, ediai.   
\q1
\v 9 Momokani, iena hahemauri na ia e gari heniamu taudia ediai e kaumu,  
\q2 hairai na emai tano ai baine noho helaoreana.   
\b  
\q1
\v 10 Hebogahisi bona heabidama bae hedavari,  
\q2 kara maoromaoro bona maino bae haherahu heheni.   
\q1
\v 11 Heabidadama na tano amo baine tubu,  
\q2 kara maoromaoro na guba amo baine igo dobi.   
\q1
\v 12 Momokani, Iehova ese ḡau namodia baine henimai,  
\q2 bona emai tano ese anina baine hatubua.   
\q1
\v 13 Kara maoromaoro na ia vairanai bainela,  
\q2 ia aena gabudia baine lailai.   
\c 86  
\q1
\v 1 Iehova e, taiamu a hakala, a haere henigu,  
\q2 badina be na ogoḡamimu, na dabumu.   
\q1
\v 2 A hamaurigu, badina be oiemu ai na taomu;  
\q2 emu hesiai tauna oi e abidadama henimumu ba hamauria.   
\q1
\v 3 Oi na egu Dirava. Ḡaubada e, ba bogagu hisi;  
\q2 badina be oi na tai henimumu dina idoinai.   
\q1
\v 4 Emu hesiai tauna laumana ba hamoalea.  
\q2 Ḡaubada e, lau laumagu ese e tahumumu.   
\q1
\v 5 Ḡaubada e, oi na namo, oi na dika o gwaua taomu;  
\q2 emu hebogahisi na bada, oi e tai henimumu taudia iboudiai ediai.   
\q1
\v 6 Iehova e, egu ḡuriḡuri a hakala henia,  
\q2 egu noinoi a kamonaia.   
\q1
\v 7 Egu hekwarahi dinana ai na tai henimumu,  
\q2 badina be oi ese o haere henigumu.   
\b  
\q1
\v 8 Ḡaubada e, dirava idau-idau bogaragidiai oi na asi idaimu;  
\q2 ta ena ḡaukara danu dia oiemu heḡereḡeredia.   
\q1
\v 9 Ḡaubada e, o karadia besedia iboudiai na baema,  
\q2 oi vairamu ai bae igo diho,  
\q2 bona oi ladamu bae heatolaia.   
\q1
\v 10 Badina be oi na bada, bona hoa karadia o karamu,  
\q2 oi mo sibomu Dirava.   
\q1
\v 11 Iehova e, emu dala ba hadibagu,  
\q1 emu momokani ai baina raka helaoreana;  
\q1 lau lalogu ba haheboua tamona,  
\q2 oi ladamu imatauraina ai.   
\q1
\v 12 Ḡaubada Dirava e, lau oi na hanamomumu mai lalogu idoinai ida,  
\q2 oi ladamu baina imodaia hanaihanai.   
\q1
\v 13 Badina be emu hebogahisi na bada egu ai,  
\q2 lau laumagu na mase ena dobu gabudia amo vada o hamauria.   
\b  
\q1
\v 14 Dirava e, hekokoroku taudia vada e tuari henigu;  
\q2 daḡedaḡe taudia ese lauegu mauri iabi-ohona dalana e tahuamu,  
\q2 oi asie atomu lasi idia vairadiai.   
\q1
\v 15 A Ḡaubada e, oi na hebogahisi bona harihari-bada Diravana,  
\q2 emu badu e halahemu emu hebogahisi bona emu heabidadama na bada herea.   
\q1
\v 16 A haḡeregu, a bogagu hisi;  
\q2 emu goada na emu hesiai tauna na henia,  
\q2 emu hesiai hahinena natuna ba hamauria.   
\q1
\v 17 Emu lalo-namo toana ta ba hahedinarai henigu,  
\q2 bena e inai henigumu taudia na bae itaia, bona bae hemarai;  
\q1 badina be, Iehova e, oi ese vada o durugu,  
\q2 bona taugu vada o haloa.   
\c 87  
\q1
\v 1 Ororo helaḡana ai Iehova ese e hadaia hanuana na e ginimu;   
\q2
\v 2 ia ese Siona ikoukoudia e ura henidia badamu,  
\q2 Iakob ena noho gabudia iboudiai na e ura henidia maraḡimu.   
\q1
\v 3 Dirava ena hanua e,  
\q2 oi hairaimu na e imodaiamu. (Selah)   
\q1
\v 4 Rahaba bona Babulono na dibadia lau,  
\q2 Filistia bona Turo bona Etiopia danu:  
\q2 “Ina na unuseni ai e vara”, e tomu.   
\q1
\v 5 Siona danu bae herevalaia, baeto  
\q2 “Ina bona una na ia lalonai e vara”.  
\q1 Badina be Herea Mikamika ese  
\q2 baine haginia tutuka-tutuka.   
\b  
\q1
\v 6 Bese idau-idau e hagaudiamu negana ai Iehova na e gwaumu  
\q2 “Ina na unuseni ai e vara”. (Selah)   
\q1
\v 7 Ane-abi taudia bona mavaru taudia na e gwaumu  
\q2 “Lau badigu idoinai na oiemu ai”.   
\c 88  
\q1
\v 1 Iehova, ihamaurigu Diravana e,  
\q2 dina ai na boi henimumu, ba kahagu totona,  
\q2 hanuaboi ai danu na tai henimumu.   
\q1
\v 2 Egu ḡuriḡuri baine dae vasi emu ai,  
\q2 egu taitai ba hakala henia.   
\b  
\q1
\v 3 Lau laumagu na e hekwarahi masemu,  
\q2 egu mauri na mase gabuna e kahi laomu.   
\q1
\v 4 Mase gurina ai e dihomu taudia ida vada e gwauraigu hebou;  
\q2 lau na asi goadagu,   
\q1
\v 5 mase taudia bogaragidiai vada e kahua nege tauna na heto,  
\q2 e aladia taudia guri ai e hekuremu na heheto,  
\q1 oi so lalodia taomu badina be oi imamu ese  
\q2 vada e negedia daure taudia na heheto.   
\q1
\v 6 oi ese mase gurina ena dobu gabudia ai vada o atogu,  
\q2 dibura masemase bona dobu masemase gabudia ai;   
\q1
\v 7 oiemu badu na metau lau latagu ai,  
\q2 emu hurehure iboudiai ese vada e habubunigu. (Selah)   
\q1
\v 8 Bamogu na lalodia vada o ani, bena e dadaraigumu;  
\q2 hahegari ḡauna ai vada o halaogu ediai.  
\q1 Vada name hekou ahu, asi egu roho mauri dalana;   
\q2
\v 9 matagu vada eme valahu-valahu, Ialo-hisihisi dainai.  
\q1 Iehova e, dina iboudiai na boi henimumu,  
\q2 lau imagu na oiemu ai na toi roro henimumu.   
\q1
\v 10 Hoa karadia o karamu mase taudia edia,  
\q2 eiava mase taudia laulaudia na oi ihanamomu totona e tore isimu a? (Selah)   
\q1
\v 11 Mase gurina ai oiemu hebogahisi e gwauraia hedinaraimu,  
\q2 eiava dobu masemase gabuna ai oiemu heabidadama sivaraina e gwauraiamu a?   
\q1
\v 12 Dibura gabuna ai oiemu hoa karadia na mai dibadia,  
\q2 eiava helalo-boio tanona ai oiemu hahemauri karadia na e helalo taomu a?   
\b  
\q1
\v 13 Iehova e, lau oi na tai henimumu,  
\q2 daba ai egu ḡuriḡuri e dae vasimu.   
\q1
\v 14 Iehova e, dahaka dainai vada o kahugu nege?  
\q2 Dahaka dainai oi vairamu na egu ai o huniamu?   
\q1
\v 15 Merogu negana amo mai hisihisigu ida vada na noho,  
\q2 mase kahira-kahirana ai;  
\q1 emu hahegari ese e hadikagumu,  
\q2 lau na asi ikahagu.   
\q1
\v 16 Emu badu ese e habubunigumu,  
\q2 emu hahedika ese e habuagu tarimu;   
\q1
\v 17 abata na heto e kougu heḡegemu dina idoinai,  
\q2 vada e kougu ahu heboumu.   
\q1
\v 18 Egu lalokau tauna bona turagu lalodia vada o ani,  
\q2 bena e dadaraigumu;  
\q2 bamogu na dibura ai nonoho.   
\c 89  
\q1
\v 1 Iehova e, emu hebogahisi na do baina anelaia hanaihanai;  
\q2 lau udugu amo emu heabidadama baina gwauraia hedinarai uru iboudiai ediai.   
\q1
\v 2 Badina be emu hebogahisi vada o haginia hanaihanai,  
\q2 emu heabidadama na auka, guba na heto.   
\q1
\v 3 Oi na vada oto: Na abia hidi tauna ida vada a hegwau hamata heheni;  
\q2 egu hesiai tauna David na ini vada na gwau henia hamata toma,   
\q1
\v 4 “Oi garamu baina haginidia hanaihanai,  
\q2 oiemu terono baina haginia uru iboudiai lalodiai.” (Selah)   
\q1
\v 5 Iehova e, guba ese oiemu hoa ḡaudia bae imodaidia,  
\q2 bona emu heabidadama helaḡa taudia edia hebou ai danu.   
\q1
\v 6 Badina be Iehova idaina be daika guba ai?  
\q2 Guba taudia bogaragidiai daika na Iehova heḡereḡerena?   
\q1
\v 7 Ia na helaḡa taudia edia hebou ai e gari heniamu Diravana;  
\q2 ia na bada bona mai garina, e ginia hegegemu taudia iboudiai bogaragidiai.   
\q1
\v 8 Iehova Sabaota e,  
\q2 Iehova e, emu heabidadama ese e ḡeḡemu dae;  
\q2 daika na mai siahuna oi heḡereḡeremu?   
\q1
\v 9 Davara hurehuredia o biagudiamu;  
\q2 hurehure e daemu, to oi ese o hadokodiamu.   
\q1
\v 10 Rahaba o taoa kohi, mase ḡauna na heto;  
\q2 oi inaimu na imamu siahuna amo o hakarohodia rohoroho.   
\q1
\v 11 Guba na oiemu, tano danu oiemu;  
\q2 tanobada mai lalona ḡaudia iboudiai na oi ese o karadia.   
\q1
\v 12 Mirigini kahana bona diho kahana na oi ese o karadia,  
\q2 Taboro bona Heremon ese oi ladamu e heatolaiamu, mai moaledia ida.   
\q1
\v 13 Oi imamu na mai siahuna,  
\q2 imamu palapalana na mai goadana,  
\q2 imamu idibana na atai ai.   
\q1
\v 14 Emu terono badidia na kara maoromaoro bona hahemaoro ḡoevadia;  
\q2 hebogahisi bona heabidadama na oi vairamu ai e laomu.   
\q1
\v 15 Heimodai honedia mai dibadia taudia be nanamo;  
\q2 Iehova e, idia na oi vairamu diarina ai e rakamu.   
\q1
\v 16 Idia ese oi ladamu e heaḡilaiamu dina idoinai,  
\q2 idia ese oiemu kara maoromaoro e imodaiamu.   
\q1
\v 17 Badina be oi na edia goada hairaina;  
\q2 oiemu hahenamo ese emai doa e haduduia isimu.   
\q1
\v 18 Badina be emai kesi na Iehova ena;  
\q1 emai hanua pavapavana na Israel ena Helaga Diravana ena.   
\b  
\q1
\v 19 Sene negana ai e abidadama henimumu tauna na  
\q2 oi ese mata-hanai ai o hereva henia, oto:  
\q1 Goada tauna kwarana ai havava ḡauna vada na atoa,  
\q2 hanua taudia bogaragidia amo na abia hidi tauna vada na imodaia.   
\q1
\v 20 Egu hesiai tauna David vada na davaria;  
\q2 egu dehoro helaḡana amo vada na horoa,   
\q1
\v 21 lau imagu palapalana ese ia baine bamoa hanaihanai  
\q2 bona lau imagu ese ia baine hagoadaia totona.   
\q1
\v 22 Inai tauna ese basine haerotania,  
\q2 bona kara dika tauna ese basine hahemaraia.   
\q1
\v 23 Ia inaina baina taodia kohi ia vairanai;  
\q2 e inai heniamu taudia baina rahudia mase.   
\q1
\v 24 Egu heabidadama bona egu hebogahisi na ia ida,  
\q2 lau ladagu ai ena doa baine heabi isi.   
\q1
\v 25 Ia imana na davara latanai baine atoa kau,  
\q2 ia imana idibana sinavai latadiai danu.   
\q1
\v 26 Ia ese baine tai henigu, baineto “Oi na lau Tamagu,  
\q2 egu Dirava, ihamaurigu Nadi-ginina.”   
\q1
\v 27 Bena lau ese tau roboana ai baina halaoa,  
\q2 bona pavapava herea-daena, tanobada pavapavadia bogaragidiai.   
\q1
\v 28 Egu hebogahisi na ienai baina hamomokania hanaihanai,  
\q2 egu gwauhamata na ienai baine gini tutuka-tutuka.   
\q1
\v 29 Ia garana baina haginidia hanaihanai,  
\q2 iena terono do baine mia, guba baine mia dinadia heḡereḡerena.   
\q1
\v 30 Ia natuna ese egu taravatu bema rakatania,  
\q2 bona egu hahedua heḡereḡeredia basiema raka,   
\q1
\v 31 egu taravatu bema tata utu,  
\q2 bona egu haheḡani basiema badinadia,   
\q1
\v 32 bena edia kerere davadia na hedadaba auna amo,  
\q2 bona edia kara dika davadia na hekwadi varodia amo  
\q2 baina henidia.   
\q1
\v 33 A lau be egu hebogahisi na iena amo basina abia oho,  
\q2 egu heabidadama basina ha-idaua;   
\q1
\v 34 egu gwauhamata na basina rakatania,  
\q2 eiava udugu bibinadia amo e lasi herevadia na basina ha-idaudia.   
\q1
\v 35 Egu helaḡa ai vada na gwau hamata vaitani;  
\q2 David na basina koia.   
\q1
\v 36 Ia garana bae hesiriu hanaihanai,  
\q2 iena terono baine mia, dina na lau vairagu ai e miamu heḡereḡerena;   
\q1
\v 37 hua heḡereḡerena baine gini hanaihanai,  
\q2 baine gini tutuka-tutuka, guba e hesiriumu heḡereḡerena. (Selah)   
\q1
\v 38 A harihari vada o kahua nege bona vada o dadaraia,  
\q2 o horoa tauna na o badu henia lalodikamu.   
\q1
\v 39 Emu gwauhamata na emu hesiai tauna ena amo vada o haloua;  
\q2 ena havava ḡauna na gahu ai vada o hadikaia.   
\q1
\v 40 Ena maḡu iboudiai vada o hamakohidia,  
\q2 ena kohoro vada o ḡiḡidia dobi.   
\q1
\v 41 Raka-hanai taudia iboudiai ese ena kohu e dadihaimu;  
\q2 ia dekena taudia ese e ḡonaḡonalaiamu.   
\q1
\v 42 Ia inaina imadia idibadia vada o abi isi,  
\q2 ia inaina iboudiai vada o hamoaledia.   
\q1
\v 43 Oibe, iena dare matana vada o haloua;  
\q2 tuari ai so haginia auka.   
\q1
\v 44 Ena ḡoeva-dae vada o abia oho,  
\q2 ena terono na tano ai vada o ḡiḡia dobi.   
\q1
\v 45 Ena malaḡa dinadia vada o hakwadogidia,  
\q2 vada o hahemaraia vaitani. (Selah)   
\q1
\v 46 Iehova e, ba noho hehuni ela bona edena nega ai? Ela hanaihanai ai?  
\q2 emu badu baine ḡaraḡara lahi na heto ela bona edena nega ai?   
\q1
\v 47 Ba laloa tao, egu mauri dinadia na dia hoho;  
\q2 dahaka badina ai taunimanima natudia o havaradia!   
\q1
\v 48 Tau be daika ena mauri baine hesiriu, mase basine mamia toho?  
\q2 Daika sibona mase siahuna amo ia laumana baine hamauria? (Selah)   
\b  
\q1
\v 49 Ḡaubada e, emu hebogahisi gunana,  
\q2 emu heabidadama amo David o gwaurai henia hamata hebogahisina,  
\q2 ḡauna be edeseni ai?   
\q1
\v 50 Ḡaubada e, emu hesiai tauna e dadaraiamu na ba laloa tao;  
\q2 bese iboudiai edia heuduguirai na lau ese na huaiamu;   
\q1
\v 51 Iehova e, heuduguirai bunu, oi inaimu edia heuduguirai,  
\q2 unu amo idia ese oi o horoa tauna ena raka e ḡonaḡonalaiamu.   
\q1
\v 52 Iehova baita hanamoa hanaihanai.  
\q2 Amen. Amen.   
\c 90  
\q1
\v 1 Ḡaubada e, emai noho gabuna oi mo,  
\q2 uru iboudiai lalodiai.   
\q1
\v 2 Ororo do asie vara,  
\q2 tanobada bona motumotu do so kara,  
\q1 una negana ema bona hari ela bona hanaihanai  
\q2 oi mo Duava.   
\q1
\v 3 Oi ese taunimanima na ḡahu ai ma o halaodiamu,  
\q2 ini o gwau tomamu  
\q2 “Taunimanima natuna loḡora e, ba lou”.   
\q1
\v 4 Badina be laḡani daha oi vairamu ai na varani na heto vada e ore,  
\q2 eiava hanuaboi hegima negana tamona na heto.   
\q1
\v 5 Oi ese taunimanima na o ha-arudia oho; idia na nihi na heto;  
\q2 idia na rei daba ai e vara loumu na heto:   
\q1
\v 6 daba ai e varamu, e tubumu;  
\q2 adorahi ai e maraimu bona e kakoromu.   
\q1
\v 7 Badina be emu badu ese e habuamai tari,  
\q2 emu badu ese e ḡovamai.   
\q1
\v 8 Emai kara havara na oi vairamu ai vada o ato lasi,  
\q2 bona emai kerere hehunidia na oi vairamu diarina ai danu.   
\b  
\q1
\v 9 Badina be emai dina iboudiai na oiemu badu henunai vada e lao bubuni;  
\q2 emai mauri laḡanidia vada e oremu,  
\q2 hahodi tamona na heto.   
\q1
\v 10 Emai mauri laḡanidia na hitu-ahui,  
\q2 eiava goada dainai bae taurahani-ahui readia;  
\q1 to idia na hekwarahi ai bona lalo-hisihisi ai e honu honu daemu;  
\q2 idia na e ore haraḡamu, bena ai na dauha a roho laomu.   
\b  
\q1
\v 11 Daika ese emu badu siahuna e laloamu?  
\q2 Daika ese emu badu na igari-henimu ida e haheḡereḡereamu?   
\q1
\v 12 Oi ese emai dina ihagaudia ba hadibamai,  
\q2 bena lalomai ese aonega bae davari.   
\q1
\v 13 Iehova e, a lou mai! Edena nega ai baoma?  
\q2 Emu hesiai taudia a bogadia hisi.   
\q1
\v 14 Daba ai emu hebogahisi amo ba ubumai;  
\q2 emai dina iboudiai baia hisi dae bona baia moale helaoreana.   
\q1
\v 15 Ba hamoalemai dinadia na o hahisimaiva dinadia ida ba haheḡereḡeredia,  
\q2 bona dika a mamiava laḡanidia ida danu bae heḡereḡere.   
\q1
\v 16 Emu ḡaukara baine hedinarai emu hesiai taudia vairadiai,  
\q2 bona emu siahu herea-daena na idia natudia vairadiai.   
\q1
\v 17 Iehova, emai Dirava, ena lalo-namo na latamai ai baine mia,  
\q2 bona imamai ḡaukaradia ba haginidia ai emai ai;  
\q2 oibe, imamai gaukaradia ba haginidia.   
\c 91  
\q1
\v 1 Herea Mikamika metaina ai e nohomu tauna,  
\q2 Siahu-idoinai Diravana ikerukeruna ai e nohomu tauna ese   
\q1
\v 2 Iehova baine hereva henia, baineto,  
\q2 “Egu roho-mauri gabuna bona egu kohoro;  
\q2 egu Dirava, na abidadama henimumu”.   
\q1
\v 3 Ia ese manu-tahu tauna ena idoa amo baine harohomu mauri,  
\q2 mase gorerena amo baine hamaurimu.   
\q1
\v 4 Ia ese ia hanina amo baine gorumu ahu,  
\q2 ia hanina henudiai emu roho-mauri gabuna ba davaria;  
\q2 iena heabidadama na emu kesi bona keme aurina.   
\q1
\v 5 Hanuaboi ena hahegari na basio garilaia,  
\q2 dina ai e kinomu dibana danu garina basio gari;   
\q1
\v 6 hanuaboi ai e dai hanaimu gorerena,  
\q2 bona dina tubua ai e kaumu hahebua-tarina danu.   
\b  
\q1
\v 7 Taunimanima daha na ohemu ai bae keto,  
\q2 bona gerebu na oi imamu idibana kahana ai;  
\q2 a basine hakahikahimu.   
\q1
\v 8 Matamu amo ba roha roha,  
\q2 kara dika taudia davadia e abimu ba itaia.   
\b  
\q1
\v 9 Iehova na emu roho-mauri gabuna ai vada o halaoa,  
\q2 Herea Mikamika na emu noho gabuna bunai;   
\q1
\v 10 una dainai dika ta emu ai basine kau,  
\q2 gorere ta emu kalaga basine hakahikahia.   
\b  
\q1
\v 11 Badina be ia ese ena aneru baine haduadia,  
\q2 emu dala iboudiai bae gimamu.   
\q1
\v 12 Idia ese imadia ai bae abimu isi,  
\q2 aemu na nadi ai ba tutuhia na garina.   
\q1
\v 13 Leona bona hekori gaigaina do ba moidia,  
\q2 leona natuna bona gaigai na aemu amo ba moidia tao.   
\b  
\q1
\v 14 Ia ese e lalokau henigumu dainai,  
\q2 lau ese baina hamauria;  
\q1 lau ese baina gimaia,  
\q2 badina be lau ladagu na dibana.   
\q1
\v 15 Baine boi henigu negana ai,  
\q2 lau ese baina haere henia;  
\q1 lau ese ena hekwarahi ai baina bamoa,  
\q2 baina hamauria, bona imatauraina baina henia.   
\q1
\v 16 Mauri dinadia momo baina henia;  
\q2 egu hahemauri baina hahedinarai henia.   
\c 92  
\q1
\v 1 Iehova ihanamona be namo.  
\q2 Herea Mikamika e, oi ladamu iheatolaina be namo:   
\q1
\v 2 emu hebogahisi igwauraina daba ai,  
\q2 bona emu heabidadama hanuaboi ai,   
\q1
\v 3 gitara bona ivilikou reḡedia amo,  
\q2 bona hatai-hatai ḡauna reḡena amo.   
\q1
\v 4 Badina be, Iehova e, oi ese emu ḡaukara amo vada o hamoalegu;  
\q2 oi imamu ḡaukaradia daidiai ane na abimu mai moalegu ida.   
\b  
\q1
\v 5 Iehova e, emu ḡaukara na babada;  
\q2 emu lalo-hadai na dodobu heherea.   
\q1
\v 6 Lalo duhu tauna basine diba,  
\q2 kavakava tauna lalona basine parara:   
\q1
\v 7 ena be kara dika taudia na bae vara rei na heto,  
\q2 ena be kara havara taudia na bae tubu,  
\q2 to bae bua tari hanaihanai.   
\q1
\v 8 A oi, Iehova e, na atai ai hanaihanai;   
\q2
\v 9 Iehova e, oi inaimu ba itadia.  
\q1 A itaia, oi inaimu bae mase ore,  
\q2 kara dika taudia iboudiai bae karoho.   
\b  
\q1
\v 10 A oi ese egu doa vada o duduia isi,  
\q2 uda boromakauna maruanena doana na heto;  
\q2 dehoro matamata na latagu ai vada o seia.   
\q1
\v 11 Lau matagu ese inaigu ihadareredia vada e itaia,  
\q2 bona lau taiagu ese e kara havara henigu taudia ihabua-taridia reḡedia vada e kamonai.   
\b  
\q1
\v 12 Kara maoromaoro taudia na e varamu, pamu auna na heto,  
\q2 e tubumu, Lebanon sidana auna na heto;   
\q1
\v 13 Iehova ena ruma ai vada e hadodia,  
\q2 eda Dirava ena ikoukou ai e tubumu.   
\q1
\v 14 Sene audia na huahuadia dounu e havaramu;  
\q2 todedia e arumu, rau matamatadia e hekaramu;   
\q2
\v 15 unu ese e hahedinaraiamu Iehova na maoromaoro.  
\q1 Ia na egu nadi-gini;  
\q2 ia lalonai na asi kara dikana ta.   
\c 93  
\q1
\v 1 Iehova na pavapava, ia ese hairai e hahedokilaiamu;  
\q2 Iehova ese goada e hahedokilaiamu, bona e rioamu.  
\q1 Oibe, tanobada vada e gini tutuka-tutukamu,  
\q2 ia basine marere.   
\q2
\v 2 Oiemu terono sene negana amo vada o haginia;  
\q2 oi na o noho hanaihanaimu.   
\b  
\q1
\v 3 Iehova e, abata vada e dae,  
\q2 abata reḡedia vada e daemu,  
\q2 abata gurudia na babada.   
\q1
\v 4 Ranu momo reḡedia na babada,  
\q2 davara hurehuredia na gogoada;  
\q1 A Iehova na atai ai e nohomu,  
\q2 ena siahu ese idia e hereadiamu.   
\q1
\v 5 Iehova e, emu hereva na momokani;  
\q2 emu ruma na helaḡa,  
\q2 bona do baine helaḡa hanaihanai.   
\c 94  
\q1
\v 1 Iehova e, dika davana ihenina Diravana,  
\q2 dika davana ihenina Diravana e, a diari.   
\q1
\v 2 Tanobada ihahemaoro-henina Diravana e, a tore isi,  
\q2 heaḡi taudia na davadia ba henidia.   
\q1
\v 3 Iehova e, kara dika taudia na ela bona edena nega ai,  
\q2 ela bona edena nega ai, bae heaḡi?   
\b  
\q1
\v 4 Edia heaḡi herevadia e gwaurai momomu,  
\q2 kara havara taudia iboudiai na e hekokorokumu.   
\q1
\v 5 Iehova e, emu bese taudia e moidia taomu,  
\q2 emu tano e hadikaiamu;   
\q1
\v 6 vabu bona idau tauna e aladiamu,  
\q2 ihareha e aladia masemu.   
\q1
\v 7 Idia na e tomu: Iehova ese se itaiamu;  
\q2 Iakob ena Dirava ese se laloamu.   
\b  
\q1
\v 8 Lalo-duhu herea taumui e, ba diba.  
\q2 Kavakava taumui e, edena nega ai lalomui bae parara?   
\q1
\v 9 Taia vada e ato Diravana na se kamonaimu a?  
\q2 Mata vada e kara Diravana na se itamu a?   
\q1
\v 10 Bese idau-idau matadia e hakanimu Diravana na  
\q2 dava basine heni a?  
\q1 Taunimanima e ha-aonegadiamu Diravana,   
\q2
\v 11 Iehova, ia na taunimanima edia lalo-hadai dibana;  
\q2 ia dibana idia na hahodi tamona na heto.   
\b  
\q1
\v 12 Iehova e, matana o hakaniamu tauna be namo,  
\q2 emu taravatu o hadibalaia tauna danu.   
\q1
\v 13 Hekwarahi dinadia ai na laḡa-ani o heniamu,  
\q2 ela bona kara dika taudia iabidia rikirikina gurina baine heḡei.   
\q1
\v 14 Badina be Iehova ese ena bese taudia na basine rakatanidia;  
\q2 ena tano danu basine rakatania.   
\q1
\v 15 Badina be hahemaoro ḡoevaḡoevana ese kara maoromaoro taudia baine lou henidia,  
\q2 bona lalo-ḡoevaḡoeva taudia iboudiai ese bae ḡavaia.   
\b  
\q1
\v 16 Daika baine tore isi, baine durugu,  
\q2 kara dika taudia ilao-ahudia?  
\q1 Daika baine gini tore, baine kahagu,  
\q2 kara havara taudia ilao-ahudia?   
\q1
\v 17 Iehova basinema durugu,  
\q2 lau laumagu na asi reḡereḡena tanona bema hanoho haraḡa.   
\q1
\v 18 Lau banava nato “Aegu e dedimu” negana ai,  
\q2 Iehova e, emu hebogahisi ese e dogogu tao;   
\q1
\v 19 Ialogu e hekwarahi momomu negadia ai,  
\q2 emu tauhalo ese laumagu e hamoaleamu.   
\q1
\v 20 Lohia dikadia na oi ida bae hebou diba a?  
\q2 Idia ese edia taravatu amo dika e havaraiamu.   
\q1
\v 21 Idia na e henega boumu, kara maoromaoro taudia edia mauri iabiohona totona;  
\q2 idia ese asi edia kerere taudia na e revadia mase.   
\q1
\v 22 A Iehova na egu kohoro;  
\q2 egu Dirava na egu roho-mauri nadi-ginina.   
\q1
\v 23 Edia kara havara na idia latadiai ma baine haloua,  
\q2 bona edia kara dika daidiai baine ha-oredia;  
\q2 Iehova iseda Dirava ese baine havahuradia.   
\c 95  
\p
\v 1 Aoma, ita ane baita abia, Iehova ena;  
\q2 hamaurida nadi-ginina baita moale hisi dae henia.   
\q1
\v 2 Ia vairanai baita hebou, ia baita hanamoa;  
\q2 baita moale hisi dae henia mai ihanamolaina anedia ida.   
\q1
\v 3 Badina be Iehova na Dirava badana,  
\q2 Ḡaubada hereana, dirava iboudiai e hereadiamu.   
\q1
\v 4 Tanobada ena dobu gabudia na ia imana ai,  
\q2 ororo doridia danu iena.   
\q1
\v 5 Davara danu iena, badina be ia ese e karaia;  
\q2 tano danu ia imana ese e karaia.   
\b  
\q1
\v 6 Aoma, baita toma diho, baita igo diho,  
\q2 Iehova, ita ikarada Diravana, vairanai tuida baita hadai;   
\q1
\v 7 badina be ia na iseda Dirava;  
\q2 ita na iena heubu taudia,  
\q2 bona h imana mamoedia.  
\b  
\q1 Hari dina ai gadona boma kamonai bema namo.   
\q2
\v 8 Lalomui basio ha-aukadia, Meriba ai heḡereḡerena,  
\q2 eiava Masa tano-ḡagaena ai o nohova dinana ai na heto.   
\q1
\v 9 Una negana ai senemui ese e tohogu;  
\q2 ena be egu ḡaukara vada e itaia,  
\q2 to e dibaḡanigu.   
\q1
\v 10 Laḡani hari-ahui una uru na inai heniava,  
\q2 nato: Idia na lalo-kerere besena,  
\q2 egu dala asie badinaiamu.   
\q1
\v 11 Taunabunai egu badu ai na gwau hamata,  
\q2 idia na egu laḡa-ani ai basie vareai nato.   
\c 96  
\q1
\v 1 Ane matamatana avabia, Iehova ena;  
\q2 tanobada idoinai, ane avabia, Iehova ena.   
\q1
\v 2 Ane avabia, Iehova ena; ia ladana ba hanamoa;  
\q2 daba daba iboudiai ena hahemauri ba herevalaia,   
\q1
\v 3 Tanobada besedia bogaragidiai ia hairaina ba gwauraia hedinarai,  
\q2 ena hoa karadia danu taunimanima iboudiai bogaragidiai.   
\q1
\v 4 Badina be Iehova na bada ia ihanamona danu baine bada;  
\q2 ia mo bae matauraia, dirava idaudia iboudiai na basie matauraidia.   
\q1
\v 5 Badina be bese idau-idau edia dirava na kaivakuku mo,  
\q2 a Iehova ese guba vada e karaia.   
\q1
\v 6 Hemataurai bona heimodai na ia vairanai,  
\q2 goada bona hairai na ena dubu ai.   
\b  
\q1
\v 7 Bese idau-idau taumui kikina badana, Iehova ba herevalaia,  
\q2 hairai bona goada ba gwaurai, Iehova ena;   
\q1
\v 8 hairai ba gwauraia, Iehova ladana ena,  
\q2 boubou ḡauna ba mailaia, ena ikoukou ai ba raka vareai.   
\q1
\v 9 Dabua helaḡadia ai Iehova ba toma henia diho;  
\q2 tanobada idoinai, ia vairanai ba heude-heude.   
\b  
\q1
\v 10 Bese idau-idau bogaragidiai baoto: Iehova na pavapava.  
\q2 Oibe, tanobada vada e haginia, basine marere ela bona hanaihanai.  
\q1 Ia ese tanobada besedia baine hahemaoro henidia, mai maoromaorona ida.   
\b  
\q1
\v 11 Guba baine moale, tanobada baine hisi dae,  
\q2 davara baine lolo, mai lalona ḡaudia iboudiai ida;   
\q2
\v 12 uma danu bae moale, mai anidia iboudiai.  
\q1 Una negana ai uda audia iboudiai na moale anedia bae abi   
\q2
\v 13 Iehova vairanai.  
\q1 Badina be ia na e maimu,  
\q2 tanobada ihahemaoro henina totona e maimu.  
\q1 Ia ese tanobada baine hahemaoro henia mai maoromaorona ida,  
\q2 bese idau-idau taudia baine hahemaoro henidia mai momokanina ida.   
\c 97  
\q1
\v 1 Iehova na pavapava, tanobada baine moale,  
\q2 kone tanodia momo bae hisi dae.   
\q1
\v 2 Ori bona dagadaga ese e ḡeḡea ahumu,  
\q2 kara maoromaorodia bona hahemaoro ḡoevaḡoevadia na ena terono badidia.   
\q1
\v 3 Lahi na ia vairanai e daemu,  
\q2 inaina e aradia eva-evamu.   
\q1
\v 4 Ena kevaru ese tanobada idoinai e hadiariamu;  
\q2 tanobada ese e itaiamu, bena e heude-heudemu.   
\q1
\v 5 Ororo na e vevemu \it wax\it* na heto, Iehova vairanai,  
\q2 tanobada idoinai Lohiana vairanai.   
\b  
\q1
\v 6 Guba ese ena kara maoromaorodia e gwauraidia hedinaraimu;  
\q2 bese iboudiai na ia hairaina e itaiamu.   
\q1
\v 7 Ḡau laulaudia e toma henidia dihomu taudia iboudiai na e hahemaraidiamu,  
\q2 kaivakuku asi anidia e heaḡilaidiamu taudia danu;  
\q2 dirava iboudiai na ia vairanai e goru dihomu.   
\q1
\v 8 Iehova e, Siona e kamonaimu, bena e moalemu,  
\q2 Iuda natuna kekenidia na e hisi daemu,  
\q2 oiemu hahemaoro herevadia daidiai.   
\q1
\v 9 Badina be, Iehova e, oi na herea dae tanobada idoinai daenai;  
\q2 oi na o heabi isi hereamu dirava iboudiai daediai.   
\q1
\v 10 Iehova ese kara dika e inai heniamu taudia na e ura henidiamu;  
\q2 ia ese ena helaḡa taudia e hamauridiamu,  
\q2 kara dika taudia imadia amo e harohodia maurimu.   
\q1
\v 11 Diari na e taramu, kara maoromaoro taudia edia;  
\q2 moale na e varamu, lalo-ḡoevaḡoeva taudia edia.   
\q1
\v 12 Kara maoromaoro taumui iboumui ai, Iehova ba moalelaia,  
\q2 ia ladana helaḡana ba heatolaia.   
\c 98  
\q1
\v 1 Ane matamatana avabia, Iehova ena;  
\q2 ia ese hoa karadia vada e kara.  
\q1 Ia imana idibana, ia imana helaḡana ese  
\q2 kwalimu vada e abia, ena.   
\q1
\v 2 Iehova ese ena kwalimu vada e hahedinaraia,  
\q2 ena kara maoromaoro vada e hamomokania, bese idau-idau vairadiai.   
\q1
\v 3 Ena hebogahisi bona ena heabidadama Israel garana ediai  
\q2 vada e lalo tao;  
\q1 tanobada dokodia iboudiai ese  
\q2 eda Dirava ena kwalimu vada e itaia.   
\b  
\q1
\v 4 Iehova ba moale hisi dae henia, tanobada idoinai;  
\q2 moale anedia ba lada isi, hahenamo anedia bavabi.   
\q1
\v 5 Gitara anedia amo Iehova ba hanamoa,  
\q2 gitara bona ane reḡedia amo;   
\q1
\v 6 kibi badadia bona kibi maraḡidia reḡedia amo ba moale hisi dae,  
\q2 Pavapava Iehova vairanai.   
\b  
\q1
\v 7 Davara reḡena baine dae, bona e hahonuamu ḡaudia iboudiai,  
\q2 tanobada, bona e noholaiamu taudia iboudiai.   
\q1
\v 8 Abata na imadia bae patapata,  
\q2 ororo na moale anedia bae abi hebou   
\q2
\v 9 Iehova vairanai.  
\q1 Badina be ia na e maimu,  
\q2 tanobada baine biagua totona;  
\q1 ia ese tanobada baine hahemaoro henia mai maoromaorona ida,  
\q2 bona bese idau-idau ahudia korikoridia baine henidia.   
\c 99  
\q1
\v 1 Iehova na pavapava, bese idau-idau bae heude-heude;  
\q2 ena terono ai e helaimu, kerubi latadiai;  
\q2 tanobada na baine laga.   
\q1
\v 2 Iehova na herea dae Siona ai;  
\q2 ia na e heabi isimu, bese iboudiai daediai.   
\q1
\v 3 Oi ladamu herea-daena, oi ladamu mai garina, bae hanamoa;  
\q2 ia na Helaḡa.   
\q1
\v 4 Siahu Pavapavana, oi ese hahemaoro ḡoevaḡoevadia o ura henimu,  
\q2 oi ese taunimanima ahudia korikoridia o henidiamu;  
\q1 oi ese hahemaoro ḡoevaḡoevadia o karamu,  
\q2 bona kara maoromaorodia, Iakob garana ediai.   
\q1
\v 5 Iehova, iseda Dirava, ba heatolaia,  
\q2 ia aena ihadaina ḡauna vairanai ba toma diho:  
\q2 ia na Helaḡa.   
\b  
\q1
\v 6 Mose bona Aaron na iena hahelaḡa taudia rarua,  
\q2 Samuel na ia ladana e hahaneava taudia ta.  
\q1 Iehova e tai henia, bena ia ese e haere henidia,   
\q2
\v 7 ori dubuna lalona amo ia ese e hereva henidia.  
\q1 Idia ese iena haheḡani e badinadia,  
\q2 bona e henidia taravatudia danu.   
\b  
\q1
\v 8 Iehova e, ai emai Dirava, oi ese o haere henidia;  
\q2 oi na dika igwau-taona Diravana idia ediai,  
\q2 to, edia kerere davadia ihenidia Diravana danu.   
\q1
\v 9 Iehova eda Dirava ba heatolaia,  
\q2 ena ororo helaḡana ai ba toma diho;  
\q2 badina be Iehova, eda Dirava, na helaḡa.   
\c 100  
\q1
\v 1 Tanobada idoinai, Iehova ba moale hisi dae henia.   
\q1
\v 2 Iehova isiaina ba lao heni mai moalemui ida,  
\q2 ia vairanai baoma mai anemui ida.   
\b  
\q1
\v 3 Umui ba diba Iehova na Dirava.  
\q2 Ia ese e karada, ita na iena;  
\q2 ita na ia besena, bona ena heubu mamoedia.   
\b  
\q1
\v 4 Ena ikoukou ai ba raka vareai mai hahenamomui ida,  
\q2 ena dubu ai danu mai anemui ida  
\q2 ia ba hanamoa, ia ladana ba imodaia.   
\b  
\q1
\v 5 Badina be Iehova na namo;  
\q2 ena hebogahisi na e hesiriu hanaihanaimu,  
\q2 bona ena heabidadama ela bona uru iboudiai.   
\c 101  
\q1
\v 1 Hebogahisi bona hahemaoro ḡoevaḡoevana baina aneiaidia;  
\q2 Iehova e, oiemu ai egu ane baina abi.   
\q1
\v 2 Asi kerere dalana baina badinaia:  
\q2 edena nega ai dekegu ai baoma?  
\q1 Mai lalo-ḡoevaḡoevagu ida baina raka,  
\q2 egu ruma lalonai;   
\q1
\v 3 lau matagu vairadiai,  
\q2 ḡau mirona ta basina atoa.  
\b  
\q1 Raka muri taudia edia ḡaukara na inai heniamu;  
\q2 lau na basina badinaia;   
\q1
\v 4 Ialo-gagevagageva na lauegu amo baine daudau;  
\q2 kara dika ta basina dibaia.   
\b  
\q1
\v 5 Ia dekena tauna e habadelaia hehunimu tauna na  
\q2 lau ese baina alaia mase;  
\q1 e hekokorokumu bona lalona e heagimu tauna na  
\q2 lau basina haheauka henia.   
\q1
\v 6 Heabidadama taudia ina tano ai baina lalo namo henidia  
\q2 idia na lau dekegu ai bae noho;  
\q1 asi kererena dalana ai e rakamu tauna ese  
\q2 lau isiaigu baine lao heni.   
\b  
\q1
\v 7 Koikoi karadia e karamu tauna na  
\q2 lauegu ruma ai basine noho;  
\q1 koikoi herevadia e gwauraimu tauna na  
\q2 lau vairagu ai basine noho.   
\q1
\v 8 Daba ta ta amo kara dika taudia ina tano ai na  
\q2 iboudiai baina aladia mase;  
\q1 kara havara taudia iboudiai na  
\q2 Iehova ena hanua amo baina luludia oho.   
\c 102  
\q1
\v 1 Iehova e, egu noinoi a kamonai;  
\q2 egu taitai na dekemu aine vasi,   
\q1
\v 2 Oi vairamu na egu amo basio hunia,  
\q2 egu hisihisi dinana ai.  
\q1 Taiamu ae kirara egu ai;  
\q2 baina boiboi dinana ai ba haere henigu haraḡa.   
\q1
\v 3 Badina be egu mauri dinadia na e lao bubunimu, kwalahu na heto;  
\q2 turiagu na e aramu, lahi hururuna na heto.   
\q1
\v 4 Lalogu na vada e kakoro, rei na heto, bena vada e marai;  
\q2 agu aniani ianina na reaiamu.   
\q1
\v 5 Egu ḡanaḡana bada dainai,  
\q2 tau-anigu na e varoda-varodamu.   
\q1
\v 6 Lau na boebedi tano ḡaḡaena ai na heto,  
\q2 eiava baimumu gahu ḡaḡaena ai na heto.   
\q1
\v 7 Na noga ranimu;  
\q2 lau na manu edeana ta ruma guhina ai na heto.   
\q1
\v 8 Dina idoinai inaigu ese e ihi-ihiraigumu;  
\q2 e kirikirilaigumu taudia ese lau ladagu na hahedika ḡauna ai e halaoamu.   
\q1
\v 9 Badina be kahu na aniamu, aniani ḡauna na heto,  
\q2 bona iruru-mata na agu inuinu ḡauna ida na buloamu,   
\q1
\v 10 emu lalo-dika bona emu badu daidiai;  
\q2 badina be oi ese vada o abigu isi bona ma o tahogu nege.   
\q1
\v 11 Egu mauri dinadia na dina e dihomu ikerukeruna na heto;  
\q2 na maraimu, rei na heto.   
\b  
\q1
\v 12 Iehova e, oi na o lohia, bainela hanaihanai;  
\q2 oi ladamu na e hesiriumu ela bona uru iboudiai.   
\q1
\v 13 Oi na ba tore isi, Siona ba bogaia hisi;  
\q2 ilalonamo-henina negana binai,  
\q2 o gwauraia hamata negana vada e gini dae.   
\q1
\v 14 Badina be emu hesiai taudia ese ia nadina e lalokau henidiamu  
\q2 ia ḡahuna e bogaia hisimu.   
\q1
\v 15 Bese idau-idau ese Iehova ladana garina bae gari,  
\q2 tanobada pavapavadia iboudiai ese oi hairaimu garina bae gari.   
\q1
\v 16 Badina be Iehova ese Siona baine haginia,  
\q2 mai hairaina ida baine hedinarai.   
\q1
\v 17 Ia ese ogoḡami taudia edia ḡuriḡuri baine lalodia,  
\q2 bona edia noinoi na basine dadaraidia.   
\b  
\q1
\v 18 Ina na bae torea, uru gabedia edia,  
\q2 do asie vara taudia ese Iehova bae imodaia totona:   
\q1
\v 19 ia na ena gabu helaḡana amo e roha dobi,  
\q2 guba amo Iehova ese tanobada e nenea,   
\q1
\v 20 iḡui taudia edia ḡanaḡana baine kamonai  
\q2 bona e revadia mase taudia baine ruhadia nege helaoreana,   
\q1
\v 21 Siona ai taunimanima ese Iehova ladana bae gwauraia,  
\q2 bona Ierusalem ai bae imodaia totona.   
\q1
\v 22 Una negana ai bese idau-idau bona basileia idau-idau bae hebou,  
\q2 Iehova bae toma henia diho.   
\b  
\q1
\v 23 Egu mauri dinadia bogaragidiai ia ese egu goada vada e abia oho,  
\q2 egu mauri dinadia vada e hagadoidia.   
\q1
\v 24 Lau na tomamu: Egu Dirava e,  
\q2 egu mauri dinadia bogaragidiai basio abigu daudau;  
\q1 oi emu laḡani na e hesiriumu,  
\q2 uru iboudiai lalodiai.   
\b  
\q1
\v 25 Oi ese gunaguna tanobada badina o hadaia,  
\q2 guba danu oi imamu ese e karaia.   
\q1
\v 26 Idia na bae ore, a oi na ba hesiriu;  
\q2 idia iboudiai na bae mouka-mouka, dabua na heto.  
\q1 Oi ese o bolodiamu, hahedoki na heto,  
\q2 bena idia na e boiomu;   
\q2
\v 27 a oi na so idaumu, bona emu laḡani na asi dokodia.   
\q1
\v 28 Emu hesiai taudia natudia na bae noho namonamo;  
\q2 idia garadia na vairamu ai bae gini.   
\c 103  
\q1
\v 1 Laumagu e, Iehova ba hanamoa;  
\q2 lalogu idoinai, ia ladana helaḡana ba hanamoa.   
\q1
\v 2 Laumagu e, Iehova ba hanamoa;  
\q2 ena harihari-bada iboudiai na basio lalo boio.   
\q1
\v 3 Ia ese emu kara dikadia iboudiai e gwau taomu,  
\q2 ia ese emu gorere iboudiai lalodia amo e hamaurimumu.   
\q1
\v 4 Emu mauri ia ese mase gurina amo e rauaiamu,  
\q2 ia ese oi kwaramu na heuraheni bona hebogahisi e havavalaiamu.   
\q1
\v 5 Emu goada na ia ese ḡau namodia amo e ubuamu;  
\q2 una dainai emu eregabe na e hamatamataiamu ugava na heto.   
\q1
\v 6 Daḡedaḡe ese vada e hadikadia taudia iboudiai na  
\q2 Iehova ese e kara maoromaoro henidiamu,  
\q2 bona e hahemaoro henidia ḡoevaḡoevamu.   
\q1
\v 7 Ia ese ena dala na Mose e hadibalaia,  
\q2 ena kara danu Israel taudia e hadibalaidia.   
\q1
\v 8 Iehova na mai ena hebogahisi bona mai ena harihari-bada;  
\q2 ena badu na e halahemu, ena hebogahisi na e honu honu daemu.   
\q1
\v 9 Ia na basine gwau henida hanaihanai,  
\q2 ena badu na basine mia hanaihanai.   
\q1
\v 10 Eda kara dika heḡereḡeredia se kara henidamu,  
\q2 eda kara havara na davadia se henidamu.   
\q1
\v 11 Badina be guba bona tanobada padadia na bada herea heḡereḡerena,  
\q2 iena hebogahisi na unu e bada tomamu ia garina e garimu taudia ediai;   
\q1
\v 12 laurabada kahana bona lahara kahana padadia edia daudau heḡereḡerena,  
\q2 eda kara dika na ita eda amo unu e abidia oho tomamu.   
\q1
\v 13 Tamana ese natuna e bogadia hisimu heḡereḡerena,  
\q2 Iehova ese ia garina e garimu taudia na unu e bogadia hisi tomamu.   
\q1
\v 14 Badina be ede e karada toma na ia dibana;  
\q2 ia vada e helalo une, ita na tano ḡahuna mo.   
\b  
\q1
\v 15 Taunimanima ena mauri dinadia na rei na heto,  
\q2 au heraheradia na heheto e tubumu;   
\q1
\v 16 badina be lai e odaiamu, bena vada e boiomu;  
\q2 ena gabu na basine itaia lou.   
\q1
\v 17 A Iehova ena hebogahisi na sene ereguna amo, doini mia,  
\q2 bona baine mia ela bona hanaihanai,  
\q2 ia garina e garimu taudia ediai;  
\q1 ena kara maoromaoro danu,  
\q2 uru gabedia ediai;   
\q1
\v 18 ena taravatu e badinaiamu taudia ediai,  
\q2 bona ena haheḡani e lalo taomu bona e karamu taudia ediai.   
\b  
\q1
\v 19 Iehova ese ena terono na guba ai vada e hadaia;  
\q2 ena basileia ese taunimanima iboudiai e lohiadiamu.   
\q1
\v 20 Iehova ena aneru, ia ba hanamoa;  
\q2 umui goada taumui, ena hereva o badinamu,  
\q2 bona erena o kamonaimu.   
\q1
\v 21 Ena tuari oreadia iboumui ai, Iehova ba hanamoa;  
\q2 ena hesiai taumui, ena ura o karamu taumui.   
\q1
\v 22 Iehova ena karakara ḡaudia iboumui ai, ia ba hanamoa,  
\q2 ia e lohiadiamu gabudia iboudiai lalodiai.  
\q1 Laumagu e, Iehova ba hanamoa.   
\c 104  
\q1
\v 1 Laumagu e, Iehova ba hanamoa.  
\q2 Iehova, egu Dirava, oi na herea dae.  
\q1 Hairai bona siahu vada o riodia,   
\q2
\v 2 diari vada o hahedokilaia, dabua na heto.  
\q1 Guba vada o idia roro, dabua kalagana na heto,   
\q2
\v 3 emu ruma mukurodia na ranu latadiai vada o atodia,  
\q1 ori na emu kariota ai o halaodiamu,  
\q2 lai hanidia ai o guimu;   
\q1
\v 4 lai na emu gwaukau taudia ai o halaodiamu,  
\q2 lahi mai hururudia ida na emu hesiai taudia.   
\b  
\q1
\v 5 Tanobada na ia badina latanai vada o hadaia,  
\q2 una dainai nega ta basine heude-heude diba.   
\q1
\v 6 Gadobada amo o tarua ahu, dabua heḡereḡerena;  
\q2 utu-utu ese ororo e habubunidia.   
\q1
\v 7 O gwau henia negana ai na e karoho,  
\q2 emu guba rahurahu reḡena dainai e heau.   
\q1
\v 8 Ororo e dae, koura e diho;  
\q2 edia gabu o gwauraidia hidi, bena unua ela.   
\q1
\v 9 Hetoa o karaia, idia basie hanaia,  
\q2 una dainai tanobada basie habubunia lou.   
\b  
\q1
\v 10 Ranu o halohidia dae koura ai,  
\q2 unu ranu na ororo padadia amo e aru e laomu;   
\q1
\v 11 uda boromadia iboudiai adia ranu e henidiamu,  
\q2 uda donikidia ranu e inumu;   
\q1
\v 12 idia badibadidiai atai manudia na edia ruma e karamu,  
\q2 au rigidia lalodiai e taimu.   
\q1
\v 13 Emu noho gabuna na atai ai, unu amo ororo o hapariparidiamu;  
\q2 emu ḡaukara huahuadia ese tanobada e hahonuamu.   
\b  
\q1
\v 14 Rei o havaraiamu, boromakau adia,  
\q2 bona hadohado ḡaudia, taunimanima edia;  
\q1 aniani na tano amo bae abia totona,   
\q2
\v 15 bona vine ranuna, taunimanima lalodia ihamoaledia,  
\q1 bona dehoro, idia vairadia ihakimoredia,  
\q2 bona flaoa, taunimanima lalodia ihagoadalaidia.   
\q1
\v 16 Iehova ese ena au e hapariparidia badamu,  
\q2 Lebanon ena sida audia, ia ese e hado ḡaudia.   
\q1
\v 17 Idia lalodiai manu ese edia ruma e karamu;  
\q2 boḡe na beroso\f + \fr 104:17 \ft “beroso” na au ta ladana, Heberu gado ai.\f* audia ai e nohomu.   
\q1
\v 18 Ororo badadia na uda nanidia edia gabu;  
\q2 nadi hagahagadia na koni\f + \fr 104:18 \ft “koni” na uda ḡauna maragina ta, mada na heto.\f* edia komu gabudia.   
\q1
\v 19 Hua vada o karaia, nega hetoadia;  
\q2 dina na ena diho negana na mai dibana.   
\q1
\v 20 Dibura o karaiamu, bena hanua vada e boimu;  
\q2 una negana ai uda ḡaudia iboudiai e raka lasimu.   
\q1
\v 21 Leona natudia e ḡoumu, adia vamu e tahumu,  
\q2 Dirava enai edia aniani e tahumu.   
\q1
\v 22 Dina e daemu, idia na e raka ohomu,  
\q2 edia kohua ai e hekuremu.   
\q1
\v 23 Taunimanima na e raka lasimu, e ḡaukaramu,  
\q2 e hekwarahimu ela bona adorahi.   
\b  
\q1
\v 24 Iehova e, o kara ḡaudia dahaka ini heḡiḡi-boudia;  
\q2 iboudiai na mai aonegamu ida vada o kara,  
\q2 o kara ḡaudia ese tanobada e hahonuamu.   
\q1
\v 25 Davara bunai, bada herea bona mai lababana,  
\q2 ia lalonai na ḡau momo, diaḡau duahiduahi,  
\q2 mauri ḡaudia, maraḡidia bona badadia.   
\q1
\v 26 Unuseni ai lagatoi na e heaumu;  
\q2 bona lakara donodono, oi ese o karaia,  
\q2 davara ai baine gadara loaloa totona.   
\b  
\q1
\v 27 Ini ḡau iboudiai ese oi e haḡeremumu,  
\q2 aniani negadia ai adia ba henidia e tomamu.   
\q1
\v 28 O henidiamu negadia ai na idia ese e abi isimu;  
\q2 oi imamu o kehoamu negadia ai na idia bogadia e kunumu, ḡau namodia ai.   
\q1
\v 29 Oi vairamu o huniamu negadia ai na daradia e dokomu;  
\q2 idia laḡadia o abi ohomu negadia ai na e masemu,  
\q2 ḡahu ai ma e lou heniamu.   
\q1
\v 30 Oi laumamu o siaia laomu negadia ai, idia na e varamu,  
\q2 tanobada kopina o hamatamataiamu.   
\q1
\v 31 Namona binai: Iehova hairaina baine hesiriu hanaihanai;  
\q2 Iehova ese ia e kara ḡaudia na baine moalelaidia.   
\q1
\v 32 Ia ese tanobada e raraiamu,  
\q2 bena tanobada na e heude-heudemu;  
\q1 ia ese ororo e daudia tohomu,  
\q2 bena kwalahu na doridia amo e daemu.   
\q1
\v 33 Lau ane baina abia Iehova ena, egu mauri dinadia iboudiai;  
\q2 egu Dirava na egu ane ai baina hanamoa, na mauri nohomu ai.   
\q1
\v 34 Egu lalo-hadai na ia ihamoalelaina ḡauna ai bema lao,  
\q2 badina be lau ese Iehova na moalelaiamu.   
\q1
\v 35 Kara dika taudia na tanobada ai bae mase ore,  
\q2 bona kara havara taudia na bae puki be namo.  
\q1 Laumagu e, Iehova ba hanamoa.  
\q2 Iehova ba imodaia.   
\c 105  
\q1
\v 1 Iehova ba hanamoa, ia ladana ba hahanea;  
\q2 ena kara ba gwauraidia hedinarai bese idau-idau vairadiai.   
\q1
\v 2 Ane bavabi iena, ia ihanamolaina anedia bavabi,  
\q2 ena hoa karadia iboudiai sivaraidia ba gwaurai.   
\q1
\v 3 Ia ladana helaḡana ba heatolaia;  
\q2 Iehova e tahuamu taudia lalodia do bae moale.   
\q1
\v 4 Iehova ba tahua, bona ena goada danu;  
\q2 ia vairana ba tahua loulou.   
\q1
\v 5-6 Ena hesiai tauna Abraham garana e!  
\q2 Iakob natuna, ena abi-hidi taudia, e!  
\q1 Hoa karadia ia ese vada e kara ba lalodia tao,  
\q2 ena siahu karadia bona ena hahemaoro herevadia danu.   
\b  
\q1
\v 7 Ia na Iehova, eda Dirava;  
\q2 ena hahemaoro na tanobada idoinai e miamu.   
\q1
\v 8 Ia ese ena gwauhamata e laloa hanaihanaimu,  
\q2 bona ena haheḡani herevadia danu ela bona uru daha.   
\q1
\v 9 Abraham ida e hegwauhamata heheni,  
\q2 Isaak e gwau henia hamata;   
\q1
\v 10 Iakob enai e hamomokania, taravatu ai bainela,  
\q2 Israel enai baine mia hanaihanai ḡauna.   
\q1
\v 11 Eto “Kanaan tanona baina henimu,  
\q2 oi ahumu korikori ai bainela”.   
\b  
\q1
\v 12 Idia na dounu gagadoi,  
\q2 asi haridia, e noho hedoava una tano ai,   
\q1
\v 13 bese ta bese ta lalodia amo e loa eva-evava,  
\q2 basileia ta lalona amo ela bona ma orea ta ai;   
\q1
\v 14 una negana ai ta asine gwau maoro henia idia baine daḡedaḡe henidia;  
\q2 hanua pavapavadia ia ese e gwau henidia, idia daidiai.   
\q1
\v 15 Eto “Vada na horodia taudia basio daudia toho,  
\q2 egu peroveta taudia na basio hadikadia”.   
\q1
\v 16 Doe e gwauraia tano latanai,  
\q2 aniani ḡaudia iboudiai e utudia oho;   
\q1
\v 17 una negana ai ia ese idia edia amo tau ta e siaia guna;  
\q2 ladana na Iosef, e hoia, hesiai tauna ai ela.   
\q1
\v 18 Ia aena na auri gadeadia ese e haberodia,  
\q2 ia aiona na auri amo e ḡuia;   
\q1
\v 19 Iehova ena hereva ese e dibaia toho,  
\q2 ela bona e gwaurai guna ḡaudia vada e hekara.   
\q1
\v 20 Hanua Pavapavana ese haida e siaidia, bae ruhaia nege,  
\q2 bese lohiana ese e kahua nege;   
\q1
\v 21 ena ruma inarina tauna ai e halaoa,  
\q2 bona ena kohu iboudiai ireḡudia ai ela,   
\q1
\v 22 ena hanua lohiadia baine hadibadia ena ura heḡereḡerena  
\q2 bona ena tau badadia baine ha-aonegadia totona.   
\b  
\q1
\v 23 Bena Israel na Aigupto ema,  
\q2 Iakob na Ham ena tano ai e nohova.   
\q1
\v 24 Bona Iehova ese ena orea taudia e hahutumadia,  
\q2 e hagoadadia, ela bona idia vada e goada, inaidia vada e manoka.   
\q1
\v 25 Bena ia ese inaidia lalodia e ha-idaudia,  
\q2 ena orea taudia bae inai henidia,  
\q2 bona ena hesiai taudia bae koidia.   
\b  
\q1
\v 26 Ia ese Mose e siaia,  
\q2 bona Aaron danu, ena abi-hidi tauna;   
\q1
\v 27 raruosi ese iena toa e karava, taunimanima bogaragidiai,  
\q2 hoa karadia danu, Ham ena tano ai.   
\q1
\v 28 Dibura e siaia, tano e hadiburaia,  
\q2 to idia ese iena hereva e gwaua ede ede.   
\q1
\v 29 Edia ranu na rara ai e halaoa,  
\q2 edia gwarume e hamasedia.   
\q1
\v 30 Parapara e hahegiḡia bou edia tano ai,  
\q2 edia pavapava edia ruma ai danu.   
\b  
\q1
\v 31 Ia e gwau isi, bena lao momo ema,  
\q2 bona namo momo danu, edia tano idoinai.   
\q1
\v 32 Medu-hetari na latadiai e hadihoa,  
\q2 bona kevaru danu edia tano idoinai e hakevarua isi.   
\q1
\v 33 Edia vine bona edia suke audia e hakwaidudia,  
\q2 bona edia tano audia iboudiai e hagaridia.   
\q1
\v 34 Ma e gwau isi, bena kwadi ema,  
\q2 bona kwadi natudia asi iduahidia;   
\q1
\v 35 edia tano reina idoinai bona edia uma anidia danu  
\q2 e ani ore.   
\q1
\v 36 Natudia roboadia iboudiai edia tano ai na e aladia mase,  
\q2 edia goada anidia roboadia iboudiai.   
\b  
\q1
\v 37 Bena Israel taudia na ia ese e hakaudia lasi,  
\q2 mai edia \it silver\it* bona \it gold\it* ida;  
\q1 ena iduhu iboudiai lalodiai  
\q2 tau ta se hetutuhi.   
\q1
\v 38 E raka lasi negana ai Aigupto e moaleva,  
\q2 badina be idia garidia e gariva.   
\q1
\v 39 Ori e hapapaia, idia iḡovadia,  
\q2 bona lahi, hanuaboi ai edia diari ai bainela.   
\q1
\v 40 Idia e noinoi, bena ia ese kibi e siaidia,  
\q2 bona aniani momo na guba amo e henidia dobi.   
\q1
\v 41 Nadi hagahaga e hapararaia, bena ranu e aru lasi,  
\q2 tano ḡaḡaena ai e aruva, sinavai na heto.   
\q1
\v 42 Badina be ena gwauhamata helaḡana e laloa tao,  
\q2 bona ena hesiai tauna Abraham danu.   
\b  
\q1
\v 43 Ena orea taudia na unu e hakaudia lasi toma mai moaledia ida,  
\q2 ena abi-hidi taudia mai anedia ida.   
\q1
\v 44 Bese idau-idau edia tano ia ese e henidia;  
\q2 bena idia ese unu bese taudia edia biru anidia e abi,   
\q1
\v 45 ena hahedua karadia bae kara  
\q2 bona ena taravatu bae badinadia helaoreana.  
\b  
\q2 Iehova ba imodaia!   
\c 106  
\q1
\v 1 Iehova ba imodaia!  
\q1 Iehova ba hanamoa, badina be ia na namo,  
\q2 ena hebogahisi na e hesiriu hanaihanaimu.   
\q1
\v 2 Daika ese Iehova ena siahu karadia baine herevalaidia?  
\q2 Daika ese ena heimodai karadia iboudiai baine hahedinaraidia?   
\q1
\v 3 E hahemaoro goevaḡoevamu bona nega iboudiai kara maoromaoro e karamu  
\q2 taudia na nanamo.   
\b  
\q1
\v 4 Iehova e, emu orea taudia ba hanamodia negana ai na lau danu ba lalogu;  
\q2 ba hamauridia negana ai na lau danu ba durugu;   
\q1
\v 5 unu amo emu abi-hidi taudia edia namo ihabadana baina itaia,  
\q2 emu orea taudia edia moale baina moalelaia,  
\q2 bona oi ahumu baina heaḡilaia.   
\q1
\v 6 Ai bona tamamai vada a kerere,  
\q2 vada a kara dika, vada a kara havara.   
\q1
\v 7 Senemai na Aigupto ai e nohova negana ai na  
\q2 oiemu hoa karadia asie haerodia;  
\q1 asie laloa tao emu hebogahisi na bada herea,  
\q2 a Davara Kakakakana isena ai idia ese Herea Mikamika e gwau ede ede henia.   
\q1
\v 8 Ḡau tamona ia ese e hamauridia, ia ladana bagunai,  
\q2 ena siahu herea-daena baine hahedinarai helaoreana.   
\q1
\v 9 Ia ese Davara Kakakakana e gwau henia, bena e kororova,  
\q2 bena dobu gabuna amo e hakaudia hanai,  
\q2 tano ḡaḡaena amo bema hakaudia hanai heḡereḡerena.   
\q1
\v 10 Unu amo ia ese inaidia imadia amo e hamauridia,  
\q2 inai taudia edia siahu amo e harohodia mauri.   
\q1
\v 11 Davara ese idia inaidia e habubunidia,  
\q2 ta se roho mauri.   
\q1
\v 12 Bena idia ese ena hereva e abidia dae,  
\q2 bona ia ihanamolaina anedia e abi.   
\b  
\q1
\v 13 A idia ese ena kara e lalodia boio haraḡa;  
\q2 ena hahealo asie nariava.   
\q1
\v 14 Idia na tano ḡaḡaena ai e ura kava ura kavava,  
\q2 tano ḡaḡaena ai idia ese Dirava e dibaḡania.   
\q1
\v 15 Bena ia ese edia ura e henidia,  
\q2 a gorere dikana ta e siaia, idia tau-anidia ihavarodavarodadia.   
\b  
\q1
\v 16 Taruha taudia haida ese Mose bona Iehova ena hahelaḡa tauna Aaron  
\q2 e vaḡeḡe henidiava.   
\q1
\v 17 Una negana ai tano ese uduna e haḡaia, Datan e hadonoa;  
\q2 bona Abiram ena orea taudia e habubunidia;   
\q1
\v 18 lahi danu e ara edia orea bogaraginai,  
\q2 lahi hururuna ese kara dika taudia e haḡoledia oho.   
\b  
\q1
\v 19 Boromakau natuna laulauna e karaia Horeb ai,  
\q2 \it gold\it* kaivakukuna e toma henia diho;   
\q1
\v 20 Dirava hairaina na e bodohia,  
\q2 boromakau maruanena, rei e aniamu ḡauna, laulauna na ia gabuna ai e abia.   
\q1
\v 21 Ihamauridia Diravana, Aigupto ai kara badadia e karava   
\q2
\v 22 bona Ham ena tano ai hoa karadia e karava  
\q1 bona Davara Kakakakana isena ai hahegari karadia e karava  
\q2 Diravana na e laloa boio.   
\q1
\v 23 Taunabunai baine habuadia tari eto,  
\q2 a iena abi-hidi tauna Mose na pada ai e gini, ia vairanai,  
\q2 ena badu baine laoa ahu bena basine habuadia tari helaoreana.   
\b  
\q1
\v 24 Bena idia ese tano namo-hereana e dadaraia,  
\q2 iena gwauhamata asie abidadama henia.   
\q1
\v 25 Edia kalaga ai e maumau,  
\q2 bona Iehova gadona asie kamonai henia;   
\q1
\v 26 taunabunai ia ese imana e duduia isi, e gwau henidia hamata,  
\q2 tano ḡaḡaena ai baine hamorudia,   
\q1
\v 27 bona garadia na baine hakarohodia bese idau-idau bogaragidiai,  
\q2 baine hakarohodia rohoroho tano idau-idau ai eto.   
\b  
\q1
\v 28 Peoro ena Baal e badinaia,  
\q2 mase iboulaina ḡauna e ani.   
\q1
\v 29 Edia kara amo Iehova e habadua,  
\q2 bena gorere dikana na ediai e dai hanai;   
\q1
\v 30 Fineha e tore isi, e oro oro,  
\q2 bena gorere e doko.   
\q1
\v 31 Una na e gwauraia iena kara maoromaoro;  
\q2 uru iboudiai ese bae herevalaia ela bona hanaihanai.   
\b  
\q1
\v 32 Meriba ranudia badidiai idia ese e habadua,  
\q2 bona Mose na siriana e reaia, idia daidiai;   
\q1
\v 33 badina be idia daidiai ia lalona e turiariki,  
\q2 bena hereva kavakavadia e gwaurai.   
\b  
\q1
\v 34 Idia ese bese idau-idau taudia asie habuadia tari,  
\q2 Iehova ese e haḡanidia heḡereḡerena;   
\q1
\v 35 a unu bese ida e noho hebouva,  
\q2 edia kara e manadalaiva.   
\q1
\v 36 Edia kaivakuku e toma henidia dihova,  
\q2 bena idoa ai ela idia ediai.   
\q1
\v 37 Natudia mamaruanedia bona natudia hahinedia na  
\q2 boubou ḡaudia ai e halaodiava,  
\q2 lauma dikadia iboulaidia.   
\q1
\v 38 Kanaan taudia edia kaivakuku e boudia negadia ai na  
\q2 asi edia kerere taudia raradia e hahebubuva,  
\q1 natudia mamaruanedia bona natudia hahinedia raradia;  
\q2 bena rara ese tano idoinai e hadikaiava.   
\q1
\v 39 Unu amo edia kara ese e hamirodiava;  
\q2 lebulebu karadia e karava.   
\q1
\v 40 Bena Iehova ena badu e ḡaraḡara, ena orea taudia ediai;  
\q2 ena abi-hidi taudia e ihi-ihiraidia;   
\q1
\v 41 bese idau-idau taudia imadia ai e atodia,  
\q2 bena e inai henidia taudia ese e biagudia.   
\q1
\v 42 Inaidia ese e daḡedaḡe henidia,  
\q2 bena edia iḡui taudia ai ela;   
\q1
\v 43 nega momo ia ese e ruhadia nege,  
\q2 to lalodia na e gwau ede ede,  
\q2 bona edia kara dika ese e hahekwakwanaidia.   
\q1
\v 44 Ḡau tamona, edia taitai e kamonai negadia ai,  
\q2 edia hisihisi e laloa;   
\q1
\v 45 idia daidiai ena gwauhamata e laloa tao,  
\q2 ena hebogahisi bada-herea dainai edia dika e lalo nege.   
\q1
\v 46 Ia ese ibogahisidia dalana e havaraia,  
\q2 unu e ḡuidia taudia ese bae bogadia hisi totona.   
\b  
\q1
\v 47 Iehova e, emai Dirava, a hamaurimai;  
\q2 bese idau-idau bogaragidia amo ba haboumai gogogogo,  
\q1 oi ladamu helaḡana baia imodaia totona,  
\q2 oi ihanamomu baia heaḡilaia helaoreana.   
\q1
\v 48 Iehova, Israel Diravana, bae hanamoa,  
\q2 matamana amo ela bona dokona.  
\q1 Taunimanima iboudiai na baeto “Amen”.  
\b  
\q1 Iehova ba imodaia!   
\c 107  
\q1
\v 1 Iehova ba hanamoa;  
\q2 badina be ia na namo,  
\q1 ena hebogahisi na e hesiriu hanaihanaimu.   
\q1
\v 2 Iehova ese vada e hamauridia taudia,  
\q2 hisihisi amo vada e rauadia taudia,   
\q1
\v 3 tano idau-idau amo,  
\q2 laurabada amo bona lahara amo,  
\q1 mirigini amo bona tahodiho amo,  
\q2 vada e haboudia taudia na  
\q2 unu bae gwau toma.   
\b  
\q1
\v 4 Haida na tano ḡaḡaedia ai e loava,  
\q2 bae noholaia hanuana ta dalana asie davaria;   
\q1
\v 5 idia na hitolo bona ranu-mase ese e abidiava,  
\q2 laumadia na lalodiai e manoriva.   
\q1
\v 6 Bena edia hisihisi ai idia ese Iehova e tai henia,  
\q2 bena ia ese edia hisihisi amo e hamauridia,   
\q1
\v 7 bona dala maoromaorona amo e hakaudia laova,  
\q2 ela bona bae noholaia hanuana ai e kau.   
\q1
\v 8 Iehova bae hanamoa,  
\q2 ena hebogahisi bona ena hoa karadia taunimanima natudia ediai daidiai.   
\q1
\v 9 Badina be ranu-mase tauna na ia ese e ha-inuamu,  
\q2 bona hitolo tauna na ḡau namodia amo bogana e hakunuamu.   
\b  
\q1
\v 10 Haida na hanuaboi diburana ai e nohova, bona lalodia e diburava,  
\q2 hisihisi ai bona auri iguidia ai;   
\q1
\v 11 badina be Dirava ena hereva vada e gwau ede ede henidia,  
\q2 bona Herea Mikamika ena hahealo vada e dadaraia.   
\q1
\v 12 Hekwarahi ese lalodia e hametaudia;  
\q2 idia na e keto, asi idurudia ta.   
\q1
\v 13 Bena edia hekwarahi lalonai idia ese Iehova e tai henia,  
\q2 bena ia ese edia hisihisi amo e hamauridia;   
\q1
\v 14 hanuaboi diburana bona lalo-dibura amo e hakaudia lasi,  
\q2 edia iḡui e hamotudia.   
\q1
\v 15 Iehova bae hanamoa,  
\q2 ena hebogahisi bona ena hoa karadia taunimanima natudia ediai daidiai.   
\q1
\v 16 Badina be ia ese auri labora-labora iduaradia e huaridia,  
\q2 bona auri e rahu utu.   
\b  
\q1
\v 17 Haida na e goreredia, edia kara dika daidiai,  
\q2 edia kara havara daidiai hisi e ani;   
\q1
\v 18 aniani idau-idau iboudiai e dadaraidia,  
\q2 mase ikoukoudia e raka henidia kahi.   
\q1
\v 19 Edia hisihisi ai Iehova e tai henia,  
\q2 bena ia ese edia hisihisi amo e hamauridia;   
\q1
\v 20 iena hereva e halasia, e hamauridia,  
\q2 hahebua-tari amo e harohodia mauri.   
\q1
\v 21 Iehova bae hanamoa,  
\q2 ena hebogahisi bona ena hoa karadia taunimanima natudia ediai daidiai;   
\q1
\v 22 boubou ḡaudia bae hahelaḡadia mai heimodai herevadia ida,  
\q2 iena kara bae gwauraidia hedinarai, edia moale anedia ai.   
\b  
\q1
\v 23 Haida na davara ai e laolaova,  
\q2 bona gadobada ai e gaukarava;   
\q1
\v 24 Iehova ena kara e itadia,  
\q2 ena hoa karadia dobu gabudia ai.   
\q1
\v 25 Badina be ia e gwau isi, lai gubana e hatoaia,  
\q2 bena davara hurehuredia na e heabi isi.   
\q1
\v 26 Guba ai e daeva, dobu gabudia ai e dihova,  
\q2 edia hekwarahi ai edia haheauka e veve ohova.   
\q1
\v 27 Matadia e madai-madai, e raraga, kekero taudia na heheto,  
\q2 daradia e doko.   
\q1
\v 28 Bena edia hekwarahi ai Iehova e tai henia,  
\q2 bena ia ese edia hisihisi amo e hamauridia.   
\q1
\v 29 Lai gubana e gwaua tao, bena e vea,  
\q2 bona davara hurehurena e gaima.   
\q1
\v 30 Bena e moaleva, lagadia e aniva dainai;  
\q2 metai gabuna, e ura heniava gabuna, Ialonai e hakaudia vareai.   
\q1
\v 31 Iehova bae hanamoa,  
\q2 ena hebogahisi bona ena hoa karadia taunimanima natudia ediai daidiai.   
\q1
\v 32 Bese taudia edia hebou ai bae heatolaia,  
\q2 bona hanua tau-badadia edia henega ai bae imodaia.   
\b  
\q1
\v 33 Ia ese sinavai na tano ḡaḡaena ai e halaodiamu,  
\q2 bona ranu e lohilohimu gabudia na tano kaukaudia ai.   
\q1
\v 34 Tano mai anina na laguta ai e halaoamu,  
\q2 inoholaina taudia edia kara dika daidiai.   
\q1
\v 35 Ma tano ḡaḡaena na gohu ai e halaoamu,  
\q2 bona tano kaukauna na ranu e lohilohimu gabuna ai.   
\q1
\v 36 Unuseni ai ia ese hitolo taudia e hanohodiamu,  
\q2 bena idia ese hanua ta e hadaiamu, bae noholaia totona;   
\q1
\v 37 idia ese uma e karamu, bona vine imeadia e hadomu,  
\q2 anidia badadia e abimu.   
\q1
\v 38 lena hahenamo dainai idia na e hutuma e laomu;  
\q2 bona edia seri e gimadiamu, basie gadoi.   
\b  
\q1
\v 39 Daḡedaḡe eiava hekwakwanai eiava hisihisi daidiai,  
\q2 idia na e gadoimu bona e morumu,   
\q1
\v 40 una negana ai ia ese pavapava e ihi-ihiraidiamu,  
\q2 e siaidia laomu, tano ḡagaedia ai bae loaloa;   
\q1
\v 41 a ogoḡami taudia na edia hisihisi amo e abidia isimu,  
\q2 bona garadia e hahohodiamu, mamoe seridia na heheto.   
\q1
\v 42 Kara maoromaoro taudia ese e itaiamu, bena e moalemu;  
\q2 kara dika taudia iboudiai na ududia e hakapumu.   
\q1
\v 43 Daika na mai aonegana, ia ese ini ḡau do baine lalodia,  
\q2 taunimanima ese Iehova ena hebogahisi bae haeroa.   
\c 108  
\q1
\v 1 Lalogu vada eme heḡaeḡae,  
\q2 Dirava e, lalogu vada eme heḡaeḡae;  
\q1 ane baina abi, hahenamo anedia baina abi.  
\q2 Laumagu e, a noga.   
\q1
\v 2 Ivilikou e, gitara e, a noga;  
\q2 daba mamana baina haoa.   
\q1
\v 3 Iehova e, orea idau-idau bogaragidiai baina hanamomu,  
\q2 bese idau-idau bogaragidiai oi ihanamolaimu anedia baina abi.   
\q1
\v 4 Badina be emu hebogahisi na bada guba daenai,  
\q2 oiemu heabidadama na ori ai e kaumu.   
\b  
\q1
\v 5 Dirava e, guba daenai ba heaḡi,  
\q2 oi hairaimu na tanobada idoinai baine hedinarai.   
\q1
\v 6 Imamu idibana amo ba kahagu, ba haere henigu,  
\q2 emu lalokau tauna baine roho mauri totona.   
\b  
\q1
\v 7 Ena helaḡa gabuna ai Dirava vada e gwau hamata, eto:  
\q2 Sekem ihapararana baina heaḡilaia,  
\q2 Sukoto kourana baina haria.   
\q1
\v 8 Gilead na egu; Manase na egu;  
\q2 Efraim na kwaragu aurina;  
\q2 Iuda na egu dagi auna.   
\q1
\v 9 Moab na imagu ihurilaina dihuna;  
\q2 Edom latanai egu tamaka baina tahoa kau;  
\q2 Filistia latanai baina hone.   
\b  
\q1
\v 10 Daika ese hanua mai maḡuna lalonai baine hakaugu vareai?  
\q2 Daika ese Edom enai baine hakaugu lao?   
\q1
\v 11 Dirava e, vada o dadaraimai a?  
\q2 Dirava e, emai tuari oreadia ida so raka lasi.   
\q1
\v 12 A durumai, inai taudia imadia amo ba hamaurimai,  
\q2 badina be taunimanima edia hekaha na asi anina.   
\q1
\v 13 Dirava na ita ida baita goada;  
\q2 ia ese ita inaida baine moidia tao.   
\c 109  
\q1
\v 1 Na imodaiamu Diravana e,  
\q2 udumu basio hakapua.   
\q1
\v 2 Badina be dika bona koikoi taudia ududia ese lau ihadikagu herevadia e gwauraimu,  
\q2 maladia mai koikoidia ese lau e hadikagumu.   
\q1
\v 3 Inai herevadia amo e haheḡeḡegu daemu,  
\q1 asi badina e heatu henigumu.   
\q1
\v 4 Egu uraheni davana na e habadelaigumu,  
\q2 a lau be na ḡuriḡurimu.   
\q1
\v 5 E kara dika henigumu, egu kara namo davana;  
\q2 e inai henigumu, egu lalokau davana.   
\b  
\q1
\v 6 Kara dika tauna ta ba gwauraia hidi, ia ihadikana;  
\q2 hahebade tauna ta ese baine mailaia, ihahemaoro-heninatotona.   
\q1
\v 7 Bae hahemaoro henia negana ai, kererena bae gwauraia;  
\q2 ena ḡuriḡuri be kara dikana ai bae halaoa.   
\q1
\v 8 Ena mauri dinadia bae gadoi;  
\q2 ta ese ena kohu baine dadihai.   
\b  
\q1
\v 9 Natuna bae ihareha,  
\q2 adavana na baine vabu;   
\q1
\v 10 natuna bae loa eva-eva, bae noi hegame,  
\q2 e kohu rumana e noholaiamu amo bae luludia lasi.   
\q1
\v 11 Enai e abi torehai tauna ese ena ḡau iboudiai baine dadihai;  
\q2 idau taudia ese ena hekwarahi anina bae henao ore.   
\q1
\v 12 Asi tauna ta ese baine kara namo henia,  
\q2 asi tauna ta ese natuna baine bogadia hisi.   
\q1
\v 13 Garana na bae mase ore;  
\q2 ladana na baine heroho, uru iharuana ai.   
\q1
\v 14 Senena edia kara havara na Iehova vairanai bae helalolai une,  
\q2 sinana ena kara dika na basine heroho.   
\q1
\v 15 Unu kara na Iehova ese baine lalodia hanaihanai,  
\q2 a ia ilalolaina na tanobada amo baine boio.   
\q1
\v 16 Badina be hebogahisi ihahedinaraina se laloa tao,  
\q2 a ogoḡami taudia bona e dabu taudia na ia ese e havadia,  
\q1 hisi ese e gugubadia taudia na ia ese e havadia,  
\q2 ela bona edia mase negadia.   
\q1
\v 17 Heuduguirai e urava; ia danu bae uduguiraia;  
\q2 hahenamo se urava; iena amo dauhai baine mia.   
\q1
\v 18 Heuduguirai e hahedokilaia, ena hahedoki dabuana na heto,  
\q2 ia tauna ai baine dodoa vareai, ranu na heto,  
\q2 ia turiana ai baine vareai, digara na heto.   
\q1
\v 19 E rioamu dabuana heḡereḡerena ai bainela,  
\q2 dina iboudiai gabana ai e ḡeḡeamu ḡauna na heto.   
\b  
\q1
\v 20 Davadia bunu e habadelaigumu taudia ese Iehova ena amo bae abi,  
\q2 edia hereva ai egu mauri e hadikaiamu taudia danu.   
\q1
\v 21 A oi, Iehova e, egu Ḡaubada,  
\q2 lau daigu ai ba ḡaukara, oi ladamu bagunai;  
\q1 ba harohogu mauri,  
\q2 badina be emu hebogahisi na namo.   
\q1
\v 22 Badina be lau be na ogogamimu, na dabumu,  
\q2 lalogu na e hisihisi badamu.   
\q1
\v 23 Vada na boio, adorahi ikerukeruna e boiomu na heto;  
\q2 vada e tapogu oho, kwadi na heto.   
\q1
\v 24 Na anivaga dainai tuigu eme manoka,  
\q2 taugu danu eme varoda-varoda.   
\q1
\v 25 E habadelaigumu taudia ese e ihi-ihiraigumu,  
\q2 e itagumu negadia ai na kwaradia e taiko-taikomu.   
\b  
\q1
\v 26 Iehova e, egu Dirava,  
\q2 emu hebogahisi dainai ba hamaurigu.   
\q1
\v 27 Ba hadibadia ina na oi imamu;  
\q2 Iehova e, oi ese vada o karaia.   
\q1
\v 28 Bae heuduguirai, a oi na ba hahenamo,  
\q2 iheatu-henigu taudia na ba hahemaraidia;  
\q2 emu hesiai tauna baine moale.   
\q1
\v 29 E habadelaigumu taudia na hemarai bae hahedokilaia;  
\q2 sibodia edia hemarai bae rioa, dabua na heto.   
\b  
\q1
\v 30 Lau udugu amo Iehova baina hanamoa,  
\q2 hutuma bogaragidiai baina imodaia;   
\q1
\v 31 badina be e dabumu tauna imana idibana ai e ginimu,  
\q2 vada e revaia mase taudia imadia amo baine hamauria totona.   
\c 110  
\q1
\v 1 Iehova ese egu lohia e hamaoroamu, e tomu  
\q2 “Lau idibagu kahana ai ba helai,  
\q1 ela bona oi inaimu na aemu ihadaidia ḡaudia ai baina halaodia”.   
\b  
\q1
\v 2 Iehova ese ena siahu dagina auna na Siona amo vada e siaia,  
\q2 oi inaimu bogaragidiai ba lohia.   
\q1
\v 3 Emu tuari oreana na ororo helagadia ai ba hakaua lao dinana ai,  
\q2 emu orea taudia ese kunudia bae rahu pou;  
\q1 Daba matana ai, hunu na heto,  
\q2 emu goada matamatana bainema.   
\q1
\v 4 Iehova vada e gwau hamata,  
\q2 bona lalona basine ha-idaua:  
\q1 oi na hahelaḡa tauna hanaihanai,  
\q2 Melkisedek ena orea tauna.   
\b  
\q1
\v 5 Ḡaubada na oi idibamu kahana ai;  
\q2 ena badu dinana ai pavapava baine huaridia.   
\q1
\v 6 Bese idau idau bogaragidiai hahemaoro baine karaia,  
\q2 edia gabu na mase tau-anidia ai baine hahonudia;  
\q1 ia ese ikwaradia taudia baine huaridia, tanobada heḡeḡemadai ai.   
\q1
\v 7 Dala ai ia na sinavai ranuna baine inua;  
\q2 taunabunai ia na baine gaga dae.   
\c 111  
\q1
\v 1 Iehova ba imodaia.  
\q2 Lau ese Iehova baina hanamoa mai lalogu idoinai,  
\q2 kara maoromaoro taudia edia orea ai,  
\q2 hebou taudia bogaragidiai.   
\q1
\v 2 Iehova ena ḡaukara na babada,  
\q2 e moalelaidiamu taudia iboudiai ese e haerodiamu.   
\q1
\v 3 Ena ḡaukara na mai imatauraina bona mai siahuna,  
\q2 ena kara maoromaoro na e mia hanaihanaimu.   
\q1
\v 4 Ena hoa karadia vada e kara, taunimanima ese bae lalodia tao totona;  
\q2 Iehova na mai ena harihari-bada bona mai ena hebogahisi.   
\q1
\v 5 E gari heniamu taudia na adia e henidiamu;  
\q2 ena gwauhamata e laloa hanaihanaimu.   
\q1
\v 6 Ena orea taudia na ena kara siahudia e haheitalaidia,  
\q2 bese idau-idau edia tano e henidia negana ai.   
\q1
\v 7 Ia imana ḡaukaradia na momomokakani bona mamaoromamaoro,  
\q2 ena haheḡani iboudiai na mai heabidadamadia.   
\q1
\v 8 Idia na bae gini hanaihanai;  
\q2 taunimanima ese karadia bae kara mai momokanidia bona  
\q2 mai maoromaorodia ida.   
\q1
\v 9 Ia ese hahemauri na ena orea taudia ediai e siaia;  
\q2 ena gwauhamata vada e gwauraia, baine mia hanaihanai,  
\q2 ia ladana na helaḡa, bona mai garina.   
\q1
\v 10 Iehova igari-henina na aonega imatamana;  
\q2 e badinaiamu taudia iboudiai na e diba namonamomu,  
\q2 ia ihanamona e hesiriu hanaihanaimu.   
\c 112  
\q1
\v 1 Iehova ba imodaia.  
\q2 Iehova garina e garimu tauna be namo,  
\q2 ena haheḡani e moalelaidiamu tauna danu.   
\q1
\v 2 Ia garana bae goada edia tano ai;  
\q2 kara maoromaoro taudia edia uru baine hanamo.   
\q1
\v 3 Moni bona kohu na ena ruma ai,  
\q2 bona ena kara maoromaoro e hesinu hanaihanaimu.   
\q1
\v 4 Diari na dibura ai e taramu, kara maoromaoro taudia edia;  
\q2 Iehova na mai ena harihari-bada bona mai ena hebogahisi bona mai ena kara maoromaoro.   
\q1
\v 5 E hariharimu bona e heni torehaimu bona ena kara e karamu  
\q2 mai maoromaorona ida tauna be namo;   
\q1
\v 6 badina be kara maoromaoro tauna na nega ta basine mareremarere;  
\q2 bae laloa hanaihanai.   
\q1
\v 7 Ia na hari dikadia garidia se garimu;  
\q2 lalona na auka, Iehova e abidadama heniamu.   
\q1
\v 8 Lalona na auka, basine gari,  
\q2 ela bona ena ura baine hedinarai, ana inai taudia latadiai.   
\q1
\v 9 Vada e harihari momo, ogoḡami taudia vada e harihari henidia;  
\q2 ena kara maoromaoro e hesiriu hanaihanaimu,  
\q2 ena doa na mai hairaina ida e heabi isimu.   
\q1
\v 10 Kara dika tauna ese e itaiamu, bena e badumu,  
\q2 gadigadina a hahedaimu, bena e veve ohomu;  
\q1 kara dika tauna ena ura na  
\q2 anina basine vara.   
\c 113  
\q1
\v 1 Iehova ba imodaia.  
\q2 Iehova ena hesiai taumui, ia ba imodaia,  
\q2 Iehova ladana ba heatolaia.   
\q1
\v 2 Iehova ladana na bae hanamoa,  
\q2 ina harihari ela bona hanaihanai;   
\q1
\v 3 dina dae ela bona dina diho,  
\q2 Iehova ladana na bae heatolaia.   
\q1
\v 4 Iehova na atai ai, bese iboudiai daediai;  
\q2 ia hairaina na guba daenai.   
\b  
\q1
\v 5 Iehova, eda Dirava, idaina be daika?  
\q2 Ia na atai ai e helaimu,   
\q1
\v 6 e igo dobimu,  
\q2 guba bona tanobada e nenediamu.   
\q1
\v 7 Ia ese ogoḡami taudia na ḡahu amo e abidia isimu,  
\q2 e dabumu taudia na kahu gabuna amo e veridia isimu;   
\q1
\v 8 pavapava ida e hahelaidia heboumu,  
\q2 ena orea taudia edia pavapava ida.   
\q1
\v 9 Ia ese gabani hahinena na ena noho gabuna e heniamu,  
\q2 e hamoaleamu, memero kekeni sinadia ai e halaoamu.  
\q2 Iehova ba imodaia.   
\c 114  
\q1
\v 1 Israel na Aigupto amo e raka lasi,  
\q2 Iakob besena na gado-idau taudia edia amo e raka oho,   
\q1
\v 2 una negana ai Iuda na ena gabu helaḡana ai ela,  
\q2 Israel na ena basileia ai ela.   
\q1
\v 3 Davara e itaia, bena e heau,  
\q2 Ioridane sinavaina e lou ela;   
\q1
\v 4 ororo badadia e roho isi roho isi, mamoe mamaruanedia na heheto,  
\q2 bona ororo maraḡidia mamoe-mamoe na heheto.   
\q1
\v 5 Davara e, oi be edeheto, be o heaumu?  
\q2 Ioridane e, oi danu edeheto, be o Ioumu?   
\q1
\v 6 Ororo badadia e, umui be edeheto, be o roho isi roho isimu, mamoe mamaruanedia na heheto?  
\q2 Ororo maraḡidia e, umui danu edeheto, be mamoe-mamoe na o hetomu?   
\q1
\v 7 Tanobada e, Ḡaubada vairanai a heude-heude,  
\q2 Iakob ena Dirava vairanai.   
\q1
\v 8 Ia ese haga-nadina na gohu ai e halaoa,  
\q1 vasiga na ranu e lohilohimu gabuna ai e halaoa.   
\c 115  
\q1
\v 1 Dia ai emai ai, Iehova e, dia ai emai ai,  
\q2 a oi ladamu enai hairai bae henia,  
\q2 emu hebogahisi bona emu heabidadama daidiai.   
\q1
\v 2 Namona be dahaka bese idau-idau baeto  
\q2 “Edia Dirava be edeseni ai?”   
\b  
\q1
\v 3 Eda Dirava na guba ai,  
\q2 ena ura heḡereḡeredia e karamu.   
\q1
\v 4 Idia edia kaivakuku na \it silver\it* bona \it gold\it*,  
\q2 taunimanima imadia e kara ḡaudia.   
\q1
\v 5 Mai ududia, to asie herevamu;  
\q2 mai matadia, to asie itamu;   
\q1
\v 6 mai taiadia, to asie kamonaimu;  
\q2 mai udu-baubaudia, to asie bonabonamu;   
\q1
\v 7 mai imadia, to ḡau ta asie daua tohomu;  
\q2 mai aedia, to asie rakamu;  
\q2 bona gadodia na asi reḡedia.   
\q1
\v 8 Ikaradia taudia na idia heḡereḡeredia,  
\q2 bona e abidadama henidiamu taudia iboudiai danu.   
\b  
\q1
\v 9 Israel e, Iehova bavabidadama henia;  
\q2 ia na ikahadia bona edia kesi.   
\q1
\v 10 Aaron iduhuna e, Iehova bavabidadama henia;  
\q2 ia na ikahadia bona edia kesi.   
\q1
\v 11 Iehova garina o garimu taumui, Iehova bavabidadama henia;  
\q2 ia na ikahadia bona edia kesi.   
\q1
\v 12 Iehova vada e laloda tao; ia baine hanamoda;  
\q2 ia ese Israel besena baine hanamoa,  
\q2 ia ese Aaron iduhuna baine hanamoa;   
\q1
\v 13 ia ese Iehova garina e garimu taudia baine hanamodia,  
\q2 maraḡidia bona badadia danu.   
\b  
\q1
\v 14 Iehova ese garamui baine hahutumadia,  
\q2 umui garamui bona natumui garadia.   
\q1
\v 15 Iehova, guba bona tanobada ikaradia Diravana,  
\q2 ia ese baine hanamomui.   
\b  
\q1
\v 16 Guba na Iehova ena guba,  
\q2 a tanobada be ia ese taunimanima natudia vada e henidia.   
\q1
\v 17 Mase taudia ese Iehova asie imodaiamu,  
\q2 asi reḡereḡerena gabuna e lao heniamu taudia danu.   
\q1
\v 18 A ita ese Iehova baita hanamoa,  
\q2 hari ina negana amo ela bona hanaihanai.  
\q1 Iehova ba imodaia.   
\c 116  
\q1
\v 1 Iehova na lalokau heniamu,  
\q2 badina be gadogu bona egu noinoi danu vada e kamonai.   
\q1
\v 2 Badina be taiana vada e kirara egu ai;  
\q2 taunabunai lau ese ia baina boi henia, egu mauri dinadia iboudiai.   
\q1
\v 3 Mase ena idoa e ḡeḡegu ahuva,  
\q2 mase gabuna hisidia ese e gugubaguva,  
\q2 lalo-hisihisi bona dara-doko danu e alaguva.   
\q1
\v 4 Bena Iehova ladana na hahanea, nato  
\q2 “Iehova e, lau na noi henimumu, ba hamaurigu”.   
\b  
\q1
\v 5 Iehova na mai ena harihari-bada bona mai ena kara maoromaoro,  
\q2 eda Dirava na mai ena hebogahisi.   
\q1
\v 6 Iehova ese asi aonegana tauna e nariamu;  
\q2 na hekwakwanaiva negadia ai e hamauriguva.   
\q1
\v 7 Laumagu e, emu laḡa-ani gabuna ba lou henia,  
\q2 badina be Iehova ese vada e harihari henimu.   
\q1
\v 8 Badina be oi ese laumagu na mase amo vada o rauaia,  
\q2 iruru-matagu vada o dahu oho,  
\q2 aegu vada o rudia, basie hetutuhi.   
\q1
\v 9 Iehova vairanai na rakamu,  
\q2 mauri taudia edia tano ai.   
\q1
\v 10 Ena be lau nato “Vada na hisihisi hereamu”,  
\q2 to egu abidadama na ha-aukaia.   
\q1
\v 11 Egu kudou-hetaha ai lau nato  
\q2 “Taunimanima iboudiai ibadinadia na asi anina”.   
\b  
\q1
\v 12 Dahaka Iehova baina henia,  
\q2 ena harihari-bada idoinai egu ai na davana?   
\q1
\v 13 Hahemauri keherena baina abia isi,  
\q2 Iehova ladana baina hahanea.   
\q1
\v 14 Egu gwauhamata anidia na Iehova baina henia,  
\q2 ena orea taudia iboudiai vairadiai.   
\q1
\v 15 Iehova vairanai ḡau herea-daena na  
\q2 ena helaḡa taudia edia mase.   
\q1
\v 16 Iehova e, lau na emu hesiai tauna,  
\q2 lau na emu hesiai tauna, emu hesiai hahinena natuna;  
\q2 oi ese iḡuigu vada o ruha.   
\q1
\v 17 Oi ihanamomu na egu boubou ḡauna ai baina halaoa,  
\q2 bona Iehova ladana baina hahanea.   
\q1
\v 18 Egu gwauhamata anidia na Iehova baina henia,  
\q2 ena orea taudia iboudiai vairadiai,   
\q1
\v 19 Iehova ena ruma maḡudia lalodiai,  
\q2 Ierusalem e, oi bogaragimu ai.  
\q1 Iehova ba imodaia.   
\c 117  
\q1
\v 1 Bese idau-idau iboumui ai, Iehova ba imodaia;  
\q2 orea idau-idau taumui iboumui ai, ia ba heatolaia.   
\q1
\v 2 Badina be ena hebogahisi na bada ita edai,  
\q1 bona Iehova ena heabidadama na e hesiriu hanaihanaimu.  
\q1 Iehova ba imodaia.   
\c 118  
\q1
\v 1 Iehova ba hanamoa, badina be ia na namo;  
\q2 ena hebogahisi e hesiriu hanaihanaimu.   
\b  
\q1
\v 2 Israel na baineto,  
\q2 lena hebogahisi e hesiriu hanaihanaimu.   
\q1
\v 3 Aaron ena iduhu baineto,  
\q2 lena hebogahisi e hesiriu hanaihanaimu.   
\q1
\v 4 Iehova garina e garimu taudia baeto,  
\q2 lena hebogahisi e hesiriu hanaihanaimu.   
\b  
\q1
\v 5 Egu hisihisi lalona amo Iehova na boi henia,  
\q2 bena Iehova ese e haere henigu,  
\q2 bona e ruhagu nege.   
\q1
\v 6 Iehova na lau badibadigu ai dainai lau na asina garimu:  
\q2 taunimanima ese ede bae hadikagu toma?   
\q1
\v 7 Iehova na lau badibadigu ai, ikahagu totona;  
\q2 e inai henigumu taudia baina hadareredia.   
\q1
\v 8 Iehova enai baita roho mauri be namo,  
\q2 taunimanima baita abidadama henidia na dika.   
\q1
\v 9 Iehova enai baita roho mauri be namo,  
\q2 hanua pavapavadia baita abidadama henidia na dika.   
\b  
\q1
\v 10 Bese iboudiai e ḡeḡegu ahu,  
\q2 a Iehova ladana ai na hadareredia.   
\q1
\v 11 E geḡegu ahu, kaha iboudiai amo e kougu,  
\q2 a Iehova ladana ai na hadareredia.   
\q1
\v 12 E daigu kou, nanigo na heheto,  
\q2 e hururu-hururu, ava ḡiniḡini e aramu na heto,  
\q2 a Iehova ladana ai na hadareredia.   
\q1
\v 13 E dorigu lalo-dika, mokona na keto,  
\q2 a Iehova ese e durugu.   
\q1
\v 14 Iehova na egu goada bona egu ane;  
\q2 ia na vada e hamaurigu.   
\b  
\q1
\v 15 A hakala, kwalimu moale anedia,  
\q2 kara maoromaoro taudia edia kalaga ai;  
\q2 Iehova imana idibana na e ḡaukaramu mai kwalimuna ida.   
\q1
\v 16 Iehova imana idibana eme heabi isi,  
\q2 Iehova imana idibana na e ḡaukaramu mai kwalimuna ida.   
\q1
\v 17 Lau na basina mase, a do baina mauri;  
\q2 Iehova ena kara baina gwauraidia.   
\q1
\v 18 Iehova ese matagu vada e hakania, mata-hakani aukana amo,  
\q2 a se negegu mase enai.   
\b  
\q1
\v 19 Kara maoromaoro ikoukoudia na egu ai a kehodia,  
\q2 bena idia edia amo baina raka vareai,  
\q2 bona Iehova baina hanamoa.   
\b  
\q1
\v 20 Iehova ena ikoukou binai,  
\q2 kara maoromaoro taudia na iena amo bae raka vareai.   
\b  
\q1
\v 21 Lau na hanamomumu, badina be vada o haere henigu,  
\q2 bona vada o hamaurigu.   
\q1
\v 22 Ruma ilarebana taudia ese e dadaraia nadina na  
\q2 daiguni nadina ai vada ela.   
\q1
\v 23 Ina na Iehova ena kara;  
\q2 ta itaiamu, ta hoamu.   
\q1
\v 24 Ina na Iehova vada e karaia dinana;  
\q2 ia lalonai baita hisi dae, baita moale.   
\q1
\v 25 Iehova e, ai a noimumu, ba hamaurimai;  
\q2 Iehova e, ai a noimumu, kwalimu ba henimai.   
\q1
\v 26 Iehova ladana ai e maimu tauna aita hanamoa;  
\q2 Iehova ena ruma lalona amo vada a hanamomuimu.   
\q1
\v 27 Iehova na Dirava,  
\q2 ia ese diari vada e henida.  
\q1 Ba aru lao, imamui mai au heraheradia ida,  
\q2 ela bona ihaboulaina patana doana.   
\b  
\q1
\v 28 Oi na egu Dirava, baina hanamomu,  
\q2 oi na egu Dirava, baina heatolaimu.   
\b  
\q1
\v 29 Iehova ba hanamoa, badina be ia na namo;  
\q2 badina be ena hebogahisi e hesiriu hanaihanaimu.   
\c 119  
\q1
\v 1 Asi edia kerere e rakamu taudia,  
\q2 Iehova ena taravatu ai e rakamu taudia,  
\q2 idia na nanamo.   
\q1
\v 2 Ena hahediba herevadia e badinadiamu  
\q2 bona ia e tahuamu mai lalodia idoidiai taudia,  
\q2 idia na nanamo.   
\q1
\v 3 Idia na kara dika asie karamu,  
\q2 a iena dala ai e rakamu.   
\q1
\v 4 Oi ese vada o haḡanimai,  
\q2 emu hahedua herevadia na baia badinadia tarika-tarika.   
\q1
\v 5 Bama raka balaheni emu taravatu ibadinadia ai bema namo,   
\q2
\v 6 bena tau ta basine hahemaraigu;  
\q2 badina be emu haheḡani iboudiai baina raraidia tao.   
\q1
\v 7 Emu hahemaoro herevadia maoromaorodia baina diba negadia ai na baina imodaimu,  
\q2 mai lalogu maoromaorona ida.   
\q1
\v 8 Emu taravatu baina badinadia;  
\q2 basio negegu daure.   
\b  
\q1
\v 9 Eregabe tauna na ede baine raka ḡoevaḡoeva toma?  
\q2 Ena raka baine gimaia, emu hereva heḡereḡerena.   
\q1
\v 10 Mai lalogu idoinai na tahumumu,  
\q2 ba durugu, emu haheḡani basina rakatanidia.   
\q1
\v 11 Emu hereva na lalogu ai na balaia henimu,  
\q2 emu ai basina kara dika totona.   
\q1
\v 12 Iehova e, oi na namo;  
\q2 emu taravatu ba hadibagu.   
\q1
\v 13 Lau udugu bibinadia amo,  
\q2 oi udumu ena hahemaoro herevadia na gwauraimumu.   
\q1
\v 14 Emu hahediba herevadia dalana na moalelaia badamu,  
\q2 taḡa idoinai na moalelaia maraḡimu.   
\q1
\v 15 Emu hahedua herevadia baina haerodia,  
\q2 emu dala baina raraidia tao.   
\q1
\v 16 Emu taravatu baina moalelaidia,  
\q2 emu hereva na basina laloa boio.   
\b  
\q1
\v 17 Emu hesiai tauna ba hanamoa,  
\q2 bena baina mauri, bona emu hereva baina badinaia.   
\q1
\v 18 Matagu ba hapapa, bena emu taravatu lalona amo  
\q2 hoa ḡaudia baina itadia.   
\q1
\v 19 Lau na noho-kau taugu tanobada ai;  
\q2 emu haheḡani na egu amo basio hunidia.   
\q1
\v 20 Laumagu na eme daure,  
\q2 nega idoinai emu hahemaoro herevadia na ura henidia lalo-dikamu dainai.   
\q1
\v 21 Hekokoroku taudia, vada e baia taudia, oi ese vada o gwau henidia;  
\q2 idia ese oiemu haheḡani vada e rakatanidia.   
\q1
\v 22 Edia ihi-ihirai bona edia hedadarai na egu amo bavabi oho,  
\q2 badina be oiemu hahediba herevadia vada na badinadia.   
\q1
\v 23 Ena be hanua lohiadia na lau ihadikagu totona e henega boumu,  
\q2 to emu hesiai tauna ese emu taravatu baine haerodia.   
\q1
\v 24 Oiemu hahediba herevadia na egu moale ḡaudia,  
\q2 idia ese e hakaugumu.   
\b  
\q1
\v 25 Laumagu na ḡahu ai e goru dihomu;  
\q2 ba hamaurigu, emu hereva heḡereḡerena.   
\q1
\v 26 Egu dala na gwauraidia negana ai, oi ese o haere henigu;  
\q2 emu taravatu ba hadibalaigu.   
\q1
\v 27 Emu hahedua herevadia dalana ba hadibalaigu,  
\q2 bena emu hoa karadia baina haerodia.   
\q1
\v 28 Lalo-hisihisi dainai laumagu na e veve ohomu,  
\q2 emu hereva heḡereḡerena ai ba hagoadagu.   
\q1
\v 29 Dala koikoidia na egu amo bavato daudau;  
\q2 emu harihari-bada ai emu taravatu ba hadibalaigu.   
\q1
\v 30 Heabidadama dalana vada na abia hidi;  
\q2 emu hahemaoro herevadia na vairagu ai vada na atodia.   
\q1
\v 31 Iehova e, emu hahediba herevadia na badinadiamu;  
\q2 ba durugu, tau ta basine hahemaraigu.   
\q1
\v 32 Egu lalo-parara ba habadaia negana ai na  
\q2 emu haheḡani dalana ai baina heau.   
\b  
\q1
\v 33 Iehova e, emu taravatu dalana ba hadibagu,  
\q2 lau ese baina badinaia ela bona dokona.   
\q1
\v 34 Lalo-parara ba henigu, emu taravatu baina badinaia,  
\q2 bona baina abia dae mai lalogu idoinai.   
\q1
\v 35 Emu haheḡani dalana ai ba hakaugu,  
\q2 badina be una dala na moalelaiamu.   
\q1
\v 36 Lalogu na ba hamanadaia, emu hahediba herevadia ai,  
\q2 bena basina mata ḡaniḡani.   
\q1
\v 37 Matagu na ba naridia, ḡau asi anidia basie haḡeredia;  
\q2 emu dala ai ba hamaurigu.   
\q1
\v 38 Emu hesiai tauna enai emu gwauhamata ba hamomokania;  
\q2 una gwauhamata na e gari henimumu taudia edia.   
\q1
\v 39 Gwau-gwau, na gari heniamu ḡauna, na egu amo bavabia oho,  
\q2 badina be emu hahemaoro herevadia na nanamo.   
\q1
\v 40 A itaia, emu hahedua herevadia na ura henidia lalo-dikamu;  
\q2 emu kara maoromaoro ai ba hamaurigu.   
\b  
\q1
\v 41 Iehova e, emu hebogahisi ba henigu,  
\q2 bona emu hahemauri, emu gwauhamata heḡereḡerena.   
\q1
\v 42 Bena e ḡonaḡonalaigumu taudia na baina haere henidia diba,  
\q2 badina be emu hereva na abidadama heniamu.   
\q1
\v 43 Hereva momokanina na udugu amo basio abia oho vaitani,  
\q2 badina be emu hahemaoro herevadia na egu helaro.   
\q1
\v 44 Emu taravatu ibadinana basina hadokoa  
\q2 ela bona hanaihanai;   
\q1
\v 45 ura-kwalimu ai baina raka,  
\q2 badina be emu hahedua herevadia vada na tahudia.   
\q1
\v 46 Emu hahediba herevadia danu hanua pavapavadia vairadiai baina herevalai,  
\q2 bona tau ta basine hahemaraigu;   
\q1
\v 47 badina be emu haheḡani na ura henidiamu,  
\q2 idia lalodiai egu moale na davariamu.   
\q1
\v 48 Emu haheḡani, na ura henidiamu gaudia, na na matauraidiamu;  
\q2 emu taravatu baina haerodia.   
\b  
\q1
\v 49 Emu hesiai tauna o henia herevana na ba laloa tao,  
\q2 iena amo helaro o henigu.   
\q1
\v 50 Egu hisihisi ai egu tauhalo binai:  
\q2 emu gwauhamata ese e hamaurigumu.   
\q1
\v 51 Dirava garina asie garimu taudia ese e dadaraigu vaitanimu,  
\q2 a emu taravatu amo asina raka muri.   
\q1
\v 52 Emu hahemaoro herevadia gunadia na lalodiamu negana ai,  
\q2 Iehova e, taugu na e lomu.   
\q1
\v 53 Badu ḡaraḡara ese e abigumu, kara dika taudia daidiai,  
\q2 idia ese emu taravatu e rakataniamu dainai.   
\q1
\v 54 Emu taravatu na egu ane,  
\q2 egu dae-kau rumana ai.   
\q1
\v 55 Iehova e, hanuaboi ai oi ladamu na laloa taomu,  
\q2 emu taravatu na badinaiamu.   
\q1
\v 56 Ina hahenamo na egu ai vada e kau,  
\q2 emu hahedua herevadia vada na badinadia.   
\b  
\q1
\v 57 Iehova na lauegu;  
\q2 lau na gwau hamatamu, emu hereva baina badinadia.   
\q1
\v 58 Mai lalogu idoinai na noimumu, ba hanamogu,  
\q2 ba bogagu hisi, emu gwauhamata heḡereḡerena.   
\q1
\v 59 Emu dala na haerodia negadia ai,  
\q2 aegu na emu hahediba herevadia daladia ai e rakamu.   
\q1
\v 60 Lau na raka haraḡa-haraḡamu, asina halahemu,  
\q2 emu haheḡani ibadinadia ai,   
\q1
\v 61 Ena be kara dika taudia edia idoa ese e idoagumu,  
\q2 to emu taravatu asina reaiamu.   
\q1
\v 62 Malokihi ai na tore isimu, oi ihanamomu totona,  
\q2 emu hahemaoro herevadia maoromaorodia daidiai.   
\q1
\v 63 Lau na e gari henimumu taudia iboudiai  
\q2 bona emu hahedua herevadia e badinadia taudia bamodia.   
\q1
\v 64 Iehova e, tanobada na emu hebogahisi ai eme honu honu dae,  
\q2 emu taravatu ba hadibagu.   
\b  
\q1
\v 65 Iehova e, emu hesiai tauna vada o kara namo henia,  
\q2 emu hereva heḡereḡerena.   
\q1
\v 66 Lalo-parara bona aonega ba hadibagu,  
\q2 badina be emu haheḡani na abi daemu.   
\q1
\v 67 Hisihisi do se abigu negana ai na raka muri,  
\q2 a harihari emu hereva na badinaiamu.   
\q1
\v 68 Oi na namo, bona o kara namomu;  
\q2 emu taravatu ba hadibagu.   
\q1
\v 69 Dirava garina asie garimu taudia ese hereva koikoidia amo e hadikagumu,  
\q2 a lau ese mai lalogu idoinai emu hahedua herevadia na badinadiamu.   
\q1
\v 70 Lalodia na digara uduna masemasedia na heheto;  
\q2 a lau na emu taravatu na moalelaiamu.   
\q1
\v 71 Hisi na ani be namo,  
\q2 unu amo emu taravatu na lalo davari.   
\q1
\v 72 Udumu taravatuna na namo herea egu ai,  
\q2 \it gold\it* bona \it silver\it* monidia daha daha e hereadiamu.   
\b  
\q1
\v 73 Oi imamu ese vada e karagu, oromagu vada e henigu;  
\q2 lalo-parara danu ba henigu, emu haheḡani baina lalo davari helaoreana.   
\q1
\v 74 Oi garimu e garimu taudia bae itagu, bena bae moale,  
\q2 badina be emu hereva vada na laroa.   
\q1
\v 75 Iehova e, lau dibagu emu hahemaoro herevadia na mamaoro,  
\q2 bona heabidadama ai vada o hahisigu.   
\q1
\v 76 Emu lalokau ese taugu ihalona baine lailaia,  
\q2 emu hesiai tauna o gwau henia hamata heḡereḡerena.   
\q1
\v 77 Emu hebogahisi na egu ai baine kau, baina mauri totona;  
\q2 badina be emu taravatu na egu moale ḡauna.   
\q1
\v 78 Dirava garina e garimu taudia na bae hahemaraidia,  
\q2 badina be edia koikoi amo vada e dibaḡanigu;  
\q2 a lau ese emu hahedua herevadia baina haerodia.   
\q1
\v 79 Oi garimu e garimu taudia ese lau bae haḡeregu,  
\q2 bena emu hahediba herevadia bae dibadia.   
\q1
\v 80 Lalogu na asi kererena baine noho emu taravatu ai,  
\q2 bena basie hahemaraigu diba.   
\b  
\q1
\v 81 Laumagu ese emu hahemauri e ura henia lalo dikamu;  
\q2 emu hereva na laroamu.   
\q1
\v 82 Matagu e vaburamu emu gwauhamata inarina ai;  
\q2 na henanadaimu, na toma “Edena nega ai taugu ba haloa?”   
\q1
\v 83 Lau na vine ranuna ivedailaina kopina kwalahu ai e hetau daemu na heto,  
\q2 to emu taravatu asina lalodia boio.   
\q1
\v 84 Emu hesiai tauna baine haheauka ela bona edena nega ai?  
\q2 Edena nega ai e daḡedaḡe henigumu taudia ba hahemaoro henidia?   
\q1
\v 85 Dirava garina se garimu taudia ese rikiriki vada e karaia, lau iabigu totona,  
\q2 idia na emu taravatu asie badinaiamu.   
\q1
\v 86 Emu haheḡani iboudiai na momomo kakani;  
\q2 kara koikoi amo e hadikagumu; a kahagu.   
\q1
\v 87 Mokona vada e hamasegu tanobada ai,  
\q2 a lau ese emu hahedua herevadia asina rakatanidia.   
\q1
\v 88 Emu hebogahisi ai ba hamaurigu,  
\q2 bena udumu ena hahediba herevadia baina badinadia.   
\b  
\q1
\v 89 Iehova e, emu hereva na  
\q2 guba ai e mia hanaihanaimu.   
\q1
\v 90 Emu heabidadama na e hesiriumu ela bona uru. iboudiai;  
\q2 tanobada vada o hadaia, e gini tutuka-tutukamu.   
\q1
\v 91 Oi o gwau maoro dainai hari dina ai idia na gigini,  
\q2 badina be ḡau iboudiai ese oi isiaimu e lao henimu.   
\q1
\v 92 Emu taravatu basinama moalelaia,  
\q2 egu hisihisi ai bama mase.   
\q1
\v 93 Emu hahedua herevadia basina lalodia boio, lasi vaitani;  
\q2 badina be idia edia amo mauri vada o henigu.   
\q1
\v 94 Lau na oiemu, ba hamaurigu;  
\q2 badina be emu hahedua herevadia vada na tahudia.   
\q1
\v 95 Kara dika taudia na e bani taomu, bae alagu mase totona,  
\q2 a lau ese emu hahediba herevadia na haerodiamu.   
\q1
\v 96 Vada na itaia, asi ḡauna ta tanobada ai vada e namo guḡuru,  
\q2 a emu haheḡani na ḡamoḡa bada.   
\b  
\q1
\v 97 Emu taravatu na ura henia lalo dikamu;  
\q2 ia na egu haero-haero ḡauna dina idoinai.   
\q1
\v 98 Egu aonega ese inaigu edia aonega e hereaiamu,  
\q2 emu haheḡani ese lalogu vada e hapararaia dainai;  
\q2 badina be ia na egu ai hanaihanai.   
\q1
\v 99 Egu lalo-parara ese e hadibagu taudia iboudiai edia lalo-parara e hereadiamu,  
\q2 badina be emu hahediba herevadia na egu haero-haero ḡaudia.   
\q1
\v 100 Egu diba ese tatau burukadia edia diba na e hereaiamu,  
\q2 badina be emu hahedua herevadia na badinadiamu.   
\q1
\v 101 Aegu na dala dikadia iboudiai amo na rudiamu,  
\q2 emu hereva ibadinana totona.   
\q1
\v 102 Emu hahemaoro herevadia amo asina raka siri,  
\q2 badina be oi ese vada o hadibagu.   
\q1
\v 103 Emu hereva mamidia egu ai na daka gaiho!  
\q2 Edia gaiho mamina ese bada-ranuna gaihona e hereaiamu udugu ai.   
\q1
\v 104 Emu hahedua herevadia ese lalogu vada eme hapararaia,  
\q2 una dainai lau ese dala koikoidia iboudiai na inai henidiamu.   
\b  
\q1
\v 105 Emu hereva na lau aegu lamepana,  
\q2 bona egu dala diarina.   
\q1
\v 106 Vada na gwau hamata, bona egu gwauhamata vada na hamomokania,  
\q2 emu hahemaoro herevadia maoromaorodia baina badinadia.   
\q1
\v 107 Egu hisihisi na bada;  
\q2 Iehova e, ba hamaurigu, emu hereva heḡereḡerena.   
\q1
\v 108 Iehova e, egu heimodai herevadia bavabi dae;  
\q2 emu hahemaoro herevadia ba hadibagu.   
\q1
\v 109 Nega idoinai egu mauri na imagu ai,  
\q2 a emu taravatu asina reaiamu.   
\q1
\v 110 Kara dika taudia ese idoa vada e karaia, bae idoagu eto;  
\q2 a emu hahedua herevadia amo asina raka siri.   
\q1
\v 111 Emu hahediba herevadia na lau ahugu, ela bona hanaihanai;  
\q2 oibe, idia na lalogu ena moale badina.   
\q1
\v 112 Lalogu vada eme heḡaeḡae, emu taravatu karadia baina kara,  
\q2 nega iboudiai, ela bona dokona.   
\b  
\q1
\v 113 Lalo-rua taudia na inai henidiamu,  
\q2 a emu taravatu na ura heniamu.   
\q1
\v 114 Oi na egu komu gabuna bona egu kesi;  
\q2 emu hereva na laroamu.   
\q1
\v 115 Kara dika taumui e, egu amo ba raka oho,  
\q2 bena egu Dirava ena haheḡani baina badinadia diba.   
\q1
\v 116 Ba imudagu, emu gwauhamata heḡereḡerena,  
\q2 bena baina mauri,  
\q2 bona egu helaro ai tau ta ese basine hahemaraigu.   
\q1
\v 117 Egu imuda ai baola, bena baina mauri,  
\q2 bona emu taravatu baina lalodia loulou.   
\q1
\v 118 Emu taravatu amo e raka siri taudia iboudiai na o dadaraidiamu;  
\q2 oibe, edia aonega na asi anina.   
\q1
\v 119 Tanobada ena kara dika taudia iboudiai na negenege ḡaudia ai o halaodiamu;  
\q2 taunabunai emu hahediba herevadia na ura henidiamu.   
\q1
\v 120 Hidiogu e heude-heudemu, oi garimu na garimu dainai;  
\q2 emu hahemaoro herevadia danu na gari henidiamu.   
\b  
\q1
\v 121 Vada na kara ḡoevaḡoeva, vada na kara maoromaoro;  
\q2 e daḡedaḡe henigumu taudia imadia ai basio rakatanigu.   
\q1
\v 122 Turagu ai baola;  
\q2 Dirava garina asie garimu taudia ba laodia ahu, basie daḡedaḡe henigu.   
\q1
\v 123 Matagu vada eme hesiku, emu hahemauri irohana ai,  
\q2 bona emu gwauhamata maoromaoro ihaḡuḡuruna irohana ai danu.   
\q1
\v 124 Emu hebogahisi heḡereḡerena ai emu hesiai tauna ba kara henia,  
\q2 emu taravatu ba hadibagu.   
\q1
\v 125 Lau na emu hesiai tauna; lalo-parara ba henigu,  
\q2 bena emu hahediba herevadia baina diba.   
\q1
\v 126 Iehova ena kara baine hedinarai negana vada eme kau,  
\q2 badina be haida ese emu taravatu vada e tataia utu.   
\q1
\v 127 Taunabunai emu haheḡani na ura henidia badamu,  
\q2 \it gold\it* daenai, oibe, \it gold\it* namo-hereana daenai.   
\q1
\v 128 Una dainai emu hahedua herevadia iboudiai heḡereḡeredia ai aegu na davemu,  
\q2 dala koikoidia iboudiai na inai henidiamu.   
\b  
\q1
\v 129 Emu hahediba herevadia na nanamo heherea;  
\q2 una dainai laumagu ese e badinadiamu.   
\q1
\v 130 Emu hereva ikehodia ese diari e havaraiamu,  
\q2 asi aonegadia taudia lalodia e hadiaridiamu.   
\q1
\v 131 Udugu na haḡaiamu, na hodi dae hodi daemu,  
\q2 badina be emu haheḡani na ura henidia lalo-dikamu.   
\q1
\v 132 Ba haḡeregu, ba bogagu hisi,  
\q2 vaia oi ladamu e ura heniamu taudia o kara henidiamu heḡereḡerena.   
\q1
\v 133 Egu raka ba ha-aukaia, emu gwauhamata heḡereḡerena,  
\q2 kara dika ta basine biagugu.   
\q1
\v 134 Taunimanima edia daḡedaḡe amo ba hamaurigu,  
\q2 emu hahedua herevadia baina badinadia totona.   
\q1
\v 135 Oi vairamu diarina amo emu hesiai tauna ba hadiaria,  
\q2 emu taravatu ba hadibagu.   
\q1
\v 136 Iruru-matagu e aru badabadamu,  
\q2 badina be taunimanima ese emu taravatu asie badinaiamu.   
\b  
\q1
\v 137 Iehova e, emu kara na mamaoro-mamaoro;  
\q2 emu hahemaoro herevadia na mamaoro-mamaoro.   
\q1
\v 138 Emu hahediba herevadia na kara maoromaorodia ai vada o duanai,  
\q2 bona heabidadama idoinai Ialonai danu.   
\q1
\v 139 Lalogu siahuna ese e aragumu,  
\q2 badina be inaigu ese emu hereva e lalodia boiomu.   
\q1
\v 140 Emu gwauhamata vada e hekara toho ḡoeva;  
\q2 emu hesiai tauna ese e ura heniamu.   
\q1
\v 141 Lau na maraḡi, bona vada e dadaraigu,  
\q2 ḡau tamona, emu hahedua herevadia asina lalodia boiomu.   
\q1
\v 142 Emu kara maoromaorodia na maoromaoro hanaihanai,  
\q2 bona emu taravatu na momokani.   
\q1
\v 143 Hekwarahi bona hisihisi badadia na latagu ai eme kau,  
\q2 to emu haheḡani na moalelaidiamu.   
\q1
\v 144 Emu hahediba herevadia na maoromaoro hanaihanai,  
\q2 lalo-parara ba henigu, bena baina mauri.   
\b  
\q1
\v 145 Mai lalogu idoinai na taimu;  
\q2 Iehova e, a haere henigu; emu taravatu baina badinadia.   
\q1
\v 146 Na tai henimumu; a hamaurigu,  
\q2 bena emu hahediba herevadia baina badinadia.   
\q1
\v 147 Daba do se kiniamu na tore isimu,  
\q2 hekaha totona na taimu, emu hereva na larodiamu.   
\q1
\v 148 Hanuaboi gima negana ai matagu e nogamu,  
\q2 emu gwauhamata baina haeroa totona.   
\q1
\v 149 Emu hebogahisi ai gadogu a kamonai;  
\q2 Iehova e, emu kara maoromaoro ai do ba hamaurigu.   
\q1
\v 150 Edia lalo-hadai dikadia daidiai e daḡedaḡe henigumu taudia na e raka kahimu;  
\q2 idia bona emu taravatu padadia na daudau.   
\q1
\v 151 A oi, Iehova e, oi na kahira-kahira,  
\q2 bona emu haheḡani iboudiai na momomo-kakani.   
\q1
\v 152 Nega daudau emu hahediba herevadia vada na dibadia;  
\q2 vada o haginidia, bae gini hanaihanai.   
\b  
\q1
\v 153 Egu hisihisi ba itaia, ba hamaurigu,  
\q2 badina be emu taravatu asina laloa boiomu.   
\q1
\v 154 Idurugu herevana ba gwauraia, ba hamaurigu;  
\q2 mauri ba henigu, emu gwauhamata heḡereḡeredia.   
\q1
\v 155 Hahemauri bona kara dika taudia padadia na daudau,  
\q2 badina be idia ese emu taravatu asie tahudiamu.   
\q1
\v 156 Iehova e, emu hebogahisi na bada;  
\q2 mauri ba henigu, emu kara maoromaoro heḡereḡeredia ai.   
\q1
\v 157 E daḡedaḡe henigumu bona e inai henigumu taudia na hutuma,  
\q2 a emu hahediba herevadia amo asina raka sirimu.   
\q1
\v 158 Asi edia heabidadama taudia na itadiamu ai na lalogu e dikamu,  
\q2 badina be emu haheḡani asie badinadiamu.   
\q1
\v 159 Ba laloa, emu hahedua herevadia na ura henidia badamu;  
\q2 ba hamaurigu, emu hebogahisi heḡereḡerena ai.   
\q1
\v 160 Emu hereva iboudiai anidia na momokani,  
\q2 bona emu hahemaoro herevadia maoromaorodia iboudiai na e hesiriu hanaihanaimu.   
\b  
\q1
\v 161 Lohia ese e daḡedaḡe henigumu, asi badina;  
\q2 a lalogu ese emu hereva e matauraidiamu.   
\q1
\v 162 Emu hereva na moalelaiamu,  
\q2 abi-dadi kohudia e davarimu tauna ena moale na heto.   
\q1
\v 163 Koikoi na inai heniamu, na inai henia badamu;  
\q2 a emu taravatu na lalokau heniamu.   
\q1
\v 164 Dina ta ta ai, nega hahitu na imodaimumu,  
\q2 emu hahemaoro herevadia maoromaorodia daidiai.   
\q1
\v 165 Emu taravatu e wa heniamu taudia na maino badana e abiamu,  
\q2 ḡau ta ese basine hahekwakwanaidia diba.   
\q1
\v 166 Iehova e, emu hahemauri na laroamu,  
\q2 bona emu haheḡani na badinadiamu.   
\q1
\v 167 Laumagu na emu hahediba herevadia e badinadiamu;  
\q2 na ura henidia lalo-dikamu.   
\q1
\v 168 Emu hahedua herevadia bona emu hahediba herevadia na badinadiamu,  
\q2 badina be egu dala iboudiai na oi vairamu ai.   
\b  
\q1
\v 169 Iehova e, egu taitai aine vasi oi vairamu ai;  
\q2 lalo-parara ba henigu, emu hereva heḡereḡerena ai.   
\q1
\v 170 Egu noinoi aine dae vasi emu ai;  
\q2 ba hamaurigu, emu hereva heḡereḡerena ai.   
\q1
\v 171 Udugu bibinadia ese heimodai herevadia e gwaurai momomu,  
\q2 emu taravatu o hadibalaigumu dainai.   
\q1
\v 172 Malagu ese emu hereva baine anelaia,  
\q2 badina be emu haheḡani iboudiai na mamaoro-mamaoro.   
\q1
\v 173 Imamu na lau ikahagu baine heḡaeḡae,  
\q2 badina be emu hahedua herevadia vada na abidia hidi.   
\q1
\v 174 Iehova e, emu hahemauri na ura henia lalo-dikamu,  
\q2 bona emu taravatu na moalelaiamu.   
\q1
\v 175 Mauri ba henigu, baina imodaimu totona;  
\q2 emu hahemaoro herevadia amo ba durugu.   
\q1
\v 176 Lau vada na raka boioboio, dobi mamoena na heto;  
\q2 emu hesiai tauna ba tahua,  
\q2 badina be emu haheḡani herevadia asina lalodia boiomu.   
\c 120  
\q1
\v 1 Egu lalo-hisihisi ai Iehova na tai henia,  
\q2 baine haere henigu totona.   
\q1
\v 2 Nato: Iehova e,  
\q2 koikoi bibinadia bona hedibagani maladia amo ba hamaurigu.   
\q1
\v 3 Hedibaḡani malana e, dahaka baine henimu?  
\q2 ede ma baine kara henimu toma?   
\q1
\v 4 Tuari tauna ena diba mai matadia,  
\q2 roteme\f + \fr 120:4 \ft “Roteme” na au ta ladana Heberu gado ai.\f* audia e aramu gidadia.   
\b  
\q1
\v 5 Madi ihabaigu, Mesek ai na noho hedoamu,  
\q2 Kedara kalagadia bogaragidiai na nohomu.   
\q1
\v 6 Egu noho vada eme daudau herea,  
\q2 maino e inai heniamu taudia bogaragidiai.   
\q1
\v 7 Lau na maino na uramu,  
\q2 a na herevamu negadia ai,  
\q2 idia na tuari e uramu.   
\c 121  
\q1
\v 1 Lau matagu na gaga isimu, ororo na haḡerediamu;  
\q2 ikahagu na ede amo e maimu?   
\q1
\v 2 Ikahagu na Iehova ena amo e maimu;  
\q2 ia ese guba bona tanobada e karadia.   
\b  
\q1
\v 3 Oi aemu ia ese baine naria, basine marere;  
\q2 oi igimamu Diravana na basine mahuta.   
\q1
\v 4 Oibe, Israel igimana Diravana na  
\q2 matana basine ḡaraia, basine mahuta.   
\b  
\q1
\v 5 Iehova na oi igimamu Diravana;  
\q2 Iehova na oi ihahemetaimu, idibamu kahana ai.   
\q1
\v 6 Dina siahuna basine hagoreremu dina ai,  
\q2 eiava hua hanuaboi ai.   
\b  
\q1
\v 7 Iehova ese dika iboudiai lalodia amo baine gimamu;  
\q2 ia ese emu mauri baine gimaia.   
\q1
\v 8 Emu raka lasi ai bona emu raka vareai ai  
\q2 Iehova ese baine gimamu,  
\q2 harihari ela bona hanaihanai.   
\c 122  
\q1
\v 1 “Iehova ena ruma aitala”;  
\q2 unu e hamaorogu toma negana ai na moale.   
\b  
\q1
\v 2 Ierusalem e, ai aemai vada e gini,  
\q2 emu ikoukou lalodiai.   
\b  
\q1
\v 3 Ierusalem na vada e hadaia, hanua badana,  
\q2 vada e hahekuboua tutuka-tutuka;   
\q1
\v 4 iduhu hidaosi ese e dara heniamu,  
\q2 Iehova ena bese iduhudia;  
\q1 hahediba herevana na Israel e henia heḡereḡerena,  
\q2 Iehova ladana bae hanamoa totona.   
\q1
\v 5 Hahemaoro teronodia unuseni ai e hadai,  
\q2 David garana edia terono bunu.   
\q1
\v 6 Ierusalem ena maino dainai ba guriḡuri!  
\q2 E ura henimumu taudia na bae namo.   
\q1
\v 7 Maino na emu maḡu ialodiai baine mia,  
\q2 bona mauri na emu kohoro lalodiai.   
\q1
\v 8 Tadikakagu bona bamogu bagudiai bainato  
\q2 “Maino na oi lalomu ai baine mia”.   
\q1
\v 9 Iehova, eda Dirava, ena ruma bagunai,  
\q2 oi namomu baina tahua.   
\c 123  
\q1
\v 1 Matagu na roha isimu oiemu ai,  
\q2 guba ai emu terono ai o helaimu Diravana e!   
\q1
\v 2 Hesiai taudia matadia ese  
\q2 biagudia imana e raraia taomu  
\q1 eiava hesiai kekenina matana ese  
\q2 biaguna hahinena imana e raraia taomu na heto,  
\q1 ita matada ese Iehova, eda Dirava, unu ta raraia tao tomamu,  
\q2 ela bona ia ese baine bogada hisi.   
\b  
\q1
\v 3 A bogamai hisi, Iehova e, a bogamai hisi,  
\q2 badina be taunimanima ese vada e kirikirilaimai ai vada a hesiku.   
\q1
\v 4 Nega daudau herea taḡa taudia edia heihi-ihirai bona heaḡi taudia edia hekinkirilai ese  
\q2 lalomai vada e hahonu.   
\c 124  
\q1
\v 1 Iehova na bema dia iseda kaha ai,  
\q2 (Harihari Israel ini baine gwau toma),   
\q1
\v 2 Iehova na bema dia iseda kaha ai,  
\q2 taunimanima ese e tuari henida neganai,   
\q1
\v 3 idia ese maurida ai bema hadonoda,  
\q2 edia badu na ita eda ai e siahuva ai;   
\q1
\v 4 bena aru ese bema aruda oho,  
\q2 abata ese bema habubunida,   
\q1
\v 5 hurehure ese bema ḡovada ahu.   
\b  
\q1
\v 6 Iehova aita hanamoa,  
\q2 badina be ia ese ita na idia dinadia ai se halaoda.   
\q1
\v 7 Vada ta roho mauri,  
\q2 manu ese manu-tahu taudia edia idoa amo e roho maurimu na heto;  
\q1 idoa vada e motu,  
\q2 bona vada ta roho mauri.   
\q1
\v 8 Ikahada na Iehova ladana ai;  
\q2 ia ese guba bona tanobada e karadia.   
\c 125  
\q1
\v 1 Iehova e abidadama heniamu taudia na Siona ororona na heto;  
\q2 basine marere diba, baine mia hanaihanai.   
\q1
\v 2 Ororo ese Ierusalem e ḡeḡea ahumu heḡereḡerena,  
\q2 Iehova ese ena orea taudia unu e ḡeḡedia ahu tomamu,  
\q2 hari ina negana amo ela bona hanaihanai.   
\q1
\v 3 Badina be kara dika ena dagi auna na  
\q2 kara maoromaoro taudia e henidia tanona latanai basine mia  
\q1 kara maoromaoro taudia na imadia bema toia roro  
\q2 bona kara dika bema kara na garina.   
\b  
\q1
\v 4 Iehova e, kara namo taudia na ba hanamodia,  
\q2 bona lalodia mamaoro-mamaoro taudia danu.   
\q1
\v 5 A dala gageva-gagevadia ai e rakamu taudia na  
\q2 Iehova ese kara dika taudia ida baine hakaudia lao.  
\p Maino na Israel ai baine mia.   
\c 126  
\q1
\v 1 Iehova ese Siona e hanamoa lou negana ai,  
\q1 ita na e nihimu taudia na heheto.   
\q2
\v 2 Una negana ita ududa na kiri ai e honu honu dae,  
\q1 bona malada e moale hisi dae.  
\q2 Bena bese idau-idau bogaragidiai ini e gwau toma:  
\q1 Iehova ese kara badadia vada e kara idia edia.   
\q2
\v 3 Oibe, Iehova ese kara badadia vada e kara ita eda;  
\q1 ita na ta moalemu.   
\b  
\q1
\v 4 Iehova e, ma ba hanamomai lou,  
\q2 diho kahana sinavaidia na heheto.   
\q1
\v 5 Mai iruru-matadia ida e hadohadomu taudia na  
\q2 mai moaledia ida bae ḡeiḡei;   
\q1
\v 6 uhe ihadodia totona mai taitaina ida e raka lasimu tauna na  
\q2 mai hisi-daena ida ena ruma baine lou henia,  
\q2 ena uit iḡuidia baine lasilaidia.   
\c 127  
\q1
\v 1 Iehova ese ruma basinema haginia negana ai,  
\q2 e haginiamu taudia na bema hekwarahi kava;  
\q1 Iehova ese hanua basinema gimaia negana ai,  
\q2 gima taudia na bema noga kava.   
\q1
\v 2 Asi anina daba ai o tore boiboimu,  
\q2 e laomu bona hanuamu e boimu, bena lagamu o animu,  
\q2 murinai lalo-hekwarahi anidia o animu;  
\q1 badina be ia ese ena lalokau taudia na  
\q2 mahuta e henidiamu.   
\b  
\q1
\v 3 A itaia, memero na Iehova ena herahia,  
\q2 boga anidia na ena harihari ḡaudia.   
\q1
\v 4 Eregabe tauna natuna na tuari tauna imana dibadia na heheto,   
\q2
\v 5 ena diba pauana e honumu tauna na e moalemu.  
\q1 Hanua ikoukouna ai ia inaina ida bae hereva negana ai,  
\q2 tau ta ese basine hahemaraia.   
\c 128  
\q1
\v 1 Iehova garina e garimu taudia iboudiai na nanamo;  
\q2 idia na iena dala ai e rakamu.   
\q1
\v 2 Imamu edia hekwarahi anidia do bavani;  
\q2 ba moale bona ba namo danu.   
\b  
\q1
\v 3 Adavamu emu ruma ai na  
\q2 vine auna mai huahuana na heto;  
\q1 natumu na olive tuhutuhudia na heheto,  
\q2 emu pata bae helaia heḡeḡe.   
\q1
\v 4 A laloa, Iehova garina e garimu tauna na  
\q2 unu baine namo toma.   
\b  
\q1
\v 5 Siona amo Iehova ese baine hanamomu,  
\q2 Ierusalem ena namo do ba itaia, emu mauri dinadia iboudiai;   
\q1
\v 6 tubumu do ba itadia danu.  
\q2 Maino na Israel latanai baine mia.   
\c 129  
\q1
\v 1 Merogu negana amo vada e hahisigu bada,  
\q2 (Harihari Israel ini baine gwau toma),   
\q1
\v 2 Merogu negana amo vada e hahisigu bada,  
\q2 to asie hadareregu.   
\q1
\v 3 Ruarua taudia ese dorugu e ruaia,  
\q2 edia ruarua gabudia e halatadia.   
\q1
\v 4 Iehova ena kara na maoromaoro;  
\q2 ia ese kara dika varodia vada e utudia.   
\q1
\v 5 Siona e inai heniamu taudia iboudiai na  
\q2 bae hahemaraidia bona bae haloudia.   
\q1
\v 6 Idia na ruma guhidia ai rei e varamu na heto:  
\q2 do se huahua ai na e maraimu,   
\q1
\v 7 bena iutuna tauna na imana ai se abiamu,  
\q2 bona iḡuina tauna na kemena ai se rosiamu;   
\q1
\v 8 e raka hanaimu taudia danu asie herevalaiamu, asie tomu  
\q2 “Iehova ena hahenamo na latamu ai baine mia,  
\q2 Iehova ladana ai a hanamomumu”.   
\c 130  
\q1
\v 1 Iehova e, dobu gabuna amo na tai henimumu.  
\q2 Ḡaubada e, gadogu a kamonai.   
\q1
\v 2 Taiamu ae kirara,  
\q2 egu noinoi a hakala henia.   
\b  
\q1
\v 3 Iehova e, kara dika boma lalo tao,  
\q2 Ḡaubada e, daika bema gini?   
\q1
\v 4 A dika igwau-taodia na oiemu amo,  
\q2 una dainai oi garimu bae gari.   
\b  
\q1
\v 5 Iehova na nariamu, laumagu ese e nariamu,  
\q2 iena hereva na laroamu.   
\q1
\v 6 Laumagu ese Ḡaubada e nariamu,  
\q2 hegima taudia ese daba e nariamu na e hereadiamu,  
\q2 hegima taudia ese daba e nariamu na e hereadiamu.   
\b  
\q1
\v 7 Israel e, Iehova ba laroa.  
\q2 Badina be Iehova na mai ena hebogahisi,  
\q2 bona ena hahemauri na bada herea.   
\q1
\v 8 Ia ese Israel na  
\q2 ena kara dika iboudiai lalodia amo baine hamauria.   
\c 131  
\q1
\v 1 Iehova e, lalogu na se heabi isimu,  
\q2 matagu na se roha isi badabadamu.  
\q1 Ḡau bada-hereadia bona hoa bada karadia na  
\q2 asina ḡaukaralaidiamu.   
\b  
\q1
\v 2 A laumagu vada na hakerua bona vada na hamanaua,  
\q2 mero maragina na sinana kemena ai e manaumu na heto;  
\q2 laumagu na vada e hamanaua merona na heto.   
\q1
\v 3 Israel e, Iehova ba laroa,  
\q2 hari ina nega amo, ela bona hanaihanai.   
\c 132  
\q1
\v 1 Iehova e, David ba laloa;  
\q2 hisi-ani e haheaukalaia ba laloa tao.   
\q1
\v 2 Ia ese Iehova e gwau henia hamata,  
\q2 Iakob ena Dirava herea-daena e gwau henia hamata.   
\q1
\v 3 Nato: Egu ruma lalonai basina raka vareai,  
\q2 egu mahuta patana ai basina hekure,   
\q1
\v 4 matagu basina hamahutadia,  
\q2 matagu kopidia basina hakapudia,   
\q1
\v 5 ela bona Iehova ena gabu ta baina davaria,  
\q2 Iakob ena Dirava herea-daena ena noho gabuna ta.   
\b  
\q1
\v 6 Efrata ai sivaraina ta kamonai,  
\q2 Iara umadia ai ta davaria.   
\q1
\v 7 Ena noho gabuna aitala,  
\q2 aena ihadaina ḡauna vairanai baita toma diho.   
\b  
\q1
\v 8 Iehova e, a tore isi, emu laḡa-ani gabuna baola,  
\q2 oi bona emu siahu mauana helaḡana.   
\q1
\v 9 Emu hahelaḡa taudia na kara maoromaoro bae hahedokilai;  
\q2 emu helaḡa taudia na bae hisi dae.   
\q1
\v 10 Emu hesiai tauna David bagunai,  
\q2 vada o horoa tauna ena amo basio mede kerehai.   
\b  
\q1
\v 11 Iehova ese gwauhamata aukana David e henia,  
\q2 unu amo ia na basine lou.  
\q1 Eto: Natumu adorana ta  
\q2 emu terono ai baina hahelaia.   
\q1
\v 12 Bema natumu ese egu taravatu bae badinaia,  
\q2 bona egu hahediba herevadia, baina hadibalaidia ḡaudia,  
\q1 idia natudia danu emu terono ai bae helai,  
\q2 ela bona hanaihanai.   
\b  
\q1
\v 13 Badina be Iehova ese Siona e abia hidi;  
\q2 e ura henia, ena noho gabuna ai bainela.   
\q1
\v 14 Eto: Egu laḡa-ani gabuna binai,  
\q2 ela bona hanaihanai;  
\q1 iniseni ai baina noho,  
\q2 badina be vada na ura heniamu.   
\q1
\v 15 Ena roge baina hahonudia,  
\q2 ena ogoḡami taudia na adia baina henidia.   
\q1
\v 16 Ena hahelaḡa taudia na hahemauri amo baina hadokilaidia,  
\q2 ena helaḡa taudia na bae hisi dae.   
\q1
\v 17 Unuseni ai David ena doa ta baina havaraia;  
\q2 lamepa ta vada na abia heḡaeḡae, na horoa tauna ena.   
\q1
\v 18 Ia inaina na hemarai amo baina hadokilaidia,  
\q2 a ia be ena havava ḡauna ese baine hadiaria.   
\c 133  
\q1
\v 1 A itaia, tadikaka bae noho hebou mai lalodia tamona,  
\q2 una na namo, bona mai moalena danu.   
\q1
\v 2 Una na dehoro namo-hereana kwara ai na heto,  
\q2 auki-huina amo e veve dihomu,  
\q1 Aaron aukina huina amo e veve dihomu,  
\q2 ena dabua aiona ai.   
\q1
\v 3 Una na Heremon hununa na heto,  
\q2 Siona ororona ai e dihomu.  
\q1 Badina be unuseni ai Iehova ese hahenamo vada e hahedualaia.  
\q2 Hahenamona binai: mauri hanaihanai.   
\c 134  
\q1
\v 1 Aoma, Iehova ba hanamoa, umui Iehova ena hesiai taumui iboumui ai,  
\q2 hanuaboi idoinai Iehova ena ruma ai o ginimu taumui.   
\q1
\v 2 Imamui ba dudui isi, gabu helaḡana enai,  
\q2 bona Iehova ba hanamoa.   
\q1
\v 3 Iehova, guba bona tanobada ikaradia Diravana,  
\q2 ia ese Siona amo baine hanamomui.   
\c 135  
\q1
\v 1 Iehova ba imodaia.  
\q1 Iehova ladana ba imodaia;  
\q2 umui Iehova ena hesiai taumui, heimodai ba henia,   
\q1
\v 2 umui Iehova ena ruma ai o ginimu taumui,  
\q2 iseda Dirava ena ruma maḡudia ai o ginimu taumui.   
\q1
\v 3 Iehova ba imodaia, badina be Iehova na namo;  
\q2 ia ladana ba heatolaia emui ane ai,  
\q2 badina be ia na mai ena harihari-bada.   
\q1
\v 4 Badina be Iehova ese Iakob vada e abia hidi, ia sibona ena;  
\q2 Israel na iena korikori.   
\b  
\q1
\v 5 Badina be lau dibagu Iehova na bada;  
\q2 eda Ḡaubada ese dirava iboudiai e hereadiamu.   
\q1
\v 6 Badina be Iehova na sibona ena ura e karamu,  
\q2 guba ai bona tanobada ai,  
\q2 bona davara ai bona dobu gabudia iboudiai.   
\q1
\v 7 Ia ese ori e hadaediamu,  
\q2 tanobada dokona amo;  
\q1 bona kevaru e karaiamu, medu ena,  
\q2 bona lai na ena roge amo e halasidiamu.   
\b  
\q1
\v 8 Ia ese Aigupto ai natu-roboadia e aladia mase,  
\q2 taunimanima natudia roboadia bona boroma natudia roboadia.   
\q1
\v 9 Aitupto e, oi bogaragimu ai,  
\q2 ia ese toa bona hoa karadia e siaidia,  
\q2 Farao bona ena hesiai taudia iboudiai ihadikadia.   
\q1
\v 10 Ia ese bese momo e habuadia tari,  
\q2 bona pavapava mai siahudia e aladia mase:   
\q1
\v 11 Sihon, Amoro taudia edia pavapava,  
\q2 bona Og, Basan pavapavana,  
\q2 bona Kanaan basileiadia iboudiai.   
\q1
\v 12 Edia tano e heni lao, haida ese e ḡaunaia,  
\q2 ena orea taudia Israel ese e ḡaunaia.   
\b  
\q1
\v 13 Iehova e, oi ladamu na e hesiriu hanaihanaimu;  
\q2 Iehova e, oi harimu na laḡani laḡani e miamu.   
\q1
\v 14 Badina be Iehova ese ena orea taudia na maorodia baine gwaurai,  
\q2 bona ena hesiai taudia na baine bogadia hisi.   
\b  
\q1
\v 15 Bese idau-idau edia kaivakuku na \it silver\it* bona \it gold\it* amo e karadiamu,  
\q2 taunimanima imadia karakaradia:   
\q1
\v 16 mai ududia, to asie herevamu;  
\q2 mai matadia, to asie itamu;   
\q1
\v 17 mai taiadia, to asie kamonaimu;  
\q2 bona asi laḡadia ududia ai.   
\q1
\v 18 E karadiamu taudia na idia heḡereḡeredia ai baela;  
\q2 oibe, e abidadama henidiamu taudia iboudiai danu.   
\b  
\q1
\v 19 Israel besena e, Iehova ba hanamoa;  
\q2 Aaron iduhuna e, Iehova ba hanamoa;   
\q1
\v 20 Levi iduhuna e, Iehova ba hanamoa;  
\q2 Iehova garina o garimu taumui e, Iehova ba hanamoa.   
\q1
\v 21 Siona amo Iehova ba hanamoa;  
\q2 ia na Ierusalem ai e nohomu.  
\q1 Iehova ba imodaia.   
\c 136  
\q1
\v 1 Iehova ba hanamoa, badina be ia na namo;  
\q2 ena hebogahisi na e hesiriu hanaihanaimu.   
\q1
\v 2 Dirava edia Dirava ba hanamoa;  
\q2 badina be ena hebogahisi na e hesiriu hanaihanaimu.   
\q1
\v 3 Lohia edia Lohia ba hanamoa;  
\q2 badina be ena hebogahisi na e hesiriu hanaihanaimu.   
\b  
\q1
\v 4 Sibona hoa bada karadia e karamu Diravana ba hanamoa;  
\q2 badina be ena hebogahisi na e hesiriu hanaihanaimu.   
\q1
\v 5 Ena aonega amo guba e karaia;  
\q2 badina be ena hebogahisi na e hesiriu hanaihanaiamu.   
\q1
\v 6 Tanobada na davara latadiai e idia roro;  
\q2 badina be ena hebogahisi na e hesiriu hanaihanaimu.   
\q1
\v 7 Diari ḡaudia badadia e karadia;  
\q2 badina be ena hebogahisi na e hesiriu hanaihanaimu.   
\q1
\v 8 Dina tara ese dina e biaguamu;  
\q2 badina be ena hebogahisi na e hesiriu hanaihanaimu.   
\q1
\v 9 Hua bona hisiu ese hanuaboi e biaguamu;  
\q2 badina be ena hebogahisi na e hesiriu hanaihanaimu.   
\b  
\q1
\v 10 Aigupto ai natu-roboadia e aladia mase Diravana ba hanamoa;  
\q2 badina be ena hebogahisi na e hesiriu hanaihanaimu.   
\q1
\v 11 Idia bogaragidia amo Israel e hakaudia lasi;  
\q2 badina be ena hebogahisi na e hesiriu hanaihanaimu.   
\q1
\v 12 Imana na mai goadana ida e toia roro;  
\q2 badina be ena hebogahisi na e hesiriu hanaihanaimu.   
\q1
\v 13 Davara Kakakakana e hapararaia;  
\q2 badina be ena hebogahisi na e hesiriu hanaihanaimu.   
\q1
\v 14 Israel taudia na bogaragina amo e harakadia hanai;  
\q2 badina be ena hebogahisi na e hesiriu hanaihanaimu.   
\q1
\v 15 A Farao bona ena tuari oreana na Davara Kakakakana ai e hadareredia;  
\q2 badina be ena hebogahisi na e hesiriu hanaihanaimu.   
\q1
\v 16 Ena orea taudia na tano ḡaḡaena amo e hakaudia hanai;  
\q2 badina be ena hebogahisi na e hesiriu hanaihanaimu.   
\q1
\v 17 Pavapava badadia e aladia;  
\q2 badina be ena hebogahisi na e hesiriu hanaihanaimu.   
\q1
\v 18 Bona pavapava mai haridia e aladia mase;  
\q2 badina be ena hebogahisi na e hesiriu hanaihanaimu.   
\q1
\v 19 Sihon, Amoro pavapavana;  
\q2 badina be ena hebogahisi na e hesiriu hanaihanaimu.   
\q1
\v 20 Bona Og, Basan pavapavana;  
\q2 badina be ena hebogahisi na e hesiriu hanaihanaimu.   
\q1
\v 21 Bena edia tano na haida e henidia, bae ḡaunaia;  
\q2 badina be ena hebogahisi na e hesiriu hanaihanaiamu.   
\q1
\v 22 Ena hesiai tauna Israel ese e ḡaunaia;  
\q2 badina be ena hebogahisi na e hesiriu hanaihanaimu.   
\b  
\q1
\v 23 Ia ese e laloda tao eda noho dika ai;  
\q2 badina be ena hebogahisi na e hesiriu hanaihanaimu.   
\q1
\v 24 Bona inaidia imadia amo e harohoda mauri;  
\q2 badina be ena hebogahisi na e hesiriu hanaihanaimu.   
\q1
\v 25 Ia ese mauri ḡaudia iboudiai adia e henidiamu;  
\q2 badina be ena hebogahisi na e hesiriu hanaihanaimu.   
\q1
\v 26 Guba Diravana ba hanamoa;  
\q2 badina be ena hebogahisi na e hesiriu hanaihanaimu.   
\c 137  
\q1
\v 1 Babulono sinavaidia badibadidiai,  
\q1 a helai dihova, a taiva,  
\q2 Siona a laloa taova negadia ai.   
\q1
\v 2 Unuseni ai emai hatai-hatai ḡaudia na  
\q2 sinavai isedia audia ai a taudia dae.   
\q1
\v 3 Badina be unuseni ai e ḡuimai taudia ese e haḡanimai, ane baia abi,  
\q2 e hahisimai taudia ese e haḡanimai, baia moale;  
\q2 “Siona anedia ta bavabia” eto.   
\b  
\q1
\v 4 Idau tano ai Iehova ena ane na  
\q2 ede baia abia toma?   
\q1
\v 5 Ierusalem e, bama lalomu boio,  
\q2 imagu bema heveri;   
\q1
\v 6 basinama lalomu tao,  
\q2 bona egu moale ḡauna hereana daenai Ierusalem basinama atoa,  
\q2 malagu na udugu atai maona ai bema kape dae.   
\b  
\q1
\v 7 Iehova e, Ierusalem ena dina ba laloa tao,  
\q2 Edom taudia latadiai.  
\q1 Idia e tomava: A ḡiḡia dobi, a ḡiḡia dobi,  
\q2 a ḡiḡia rohoroho.   
\q1
\v 8 Babulono natuna hahinena e, hahebua-tari hahinemu:  
\q2 o kara henimaiva karadia davadia ma baine halou henimu tauna na baine moale;   
\q1
\v 9 bona natumu maraḡidia baine abidia, haga-nadina ai  
\q2 baine huaridia, tauna na baine moale.   
\c 138  
\q1
\v 1 Iehova e, mai lalogu idoinai na hanamomumu;  
\q2 dirava vairadiai na imodaimumu egu ane ai.   
\q1
\v 2 Emu dubu helaḡana vairanai na igo dihomu,  
\q2 bona ladamu na hanamoamu,  
\q2 emu hebogahisi bona emu heabidadama daidiai;  
\q1 badina be ladamu bona emu hereva vada o abidia isi  
\q2 ḡau iboudiai daediai.   
\q1
\v 3 Na boiboi dinana ai o haere henigu,  
\q2 bona laumagu goadana o habadaia.   
\b  
\q1
\v 4 Iehova e, tarlobada pavapavadia iboudiai bae imodaimu,  
\q2 badina be udumu herevadia vada e kamonai;   
\q1
\v 5 Iehova ena dala bae anelaidia,  
\q2 badina be Iehova hairaina na bada.   
\q1
\v 6 Badina ena be Iehova na atai ai, to manau taudia na e haḡerediamu;  
\q2 a hekokoroku taudia na dauha amo e dibadiamu.   
\b  
\q1
\v 7 Ena be hekwakwanai ḡaudia lalodiai na rakamu,  
\q2 to oi ese egu mauri o rauaiamu.  
\q1 Imamu o toia roromu, inaigu edia badu o laoa ahumu;  
\q2 bona imamu idibana ese e hamaurigumu.   
\q1
\v 8 Iehova ese ena lalo-hadai baine haḡuḡurua egu ai.  
\q2 Iehova e, emu hebogahisi na e hesiriu hanaihanaimu;  
\q2 imamu karakarana ḡaudia basio rakatanidia.   
\c 139  
\q1
\v 1 Iehova e, lalogu vada o tahua, vada o dibagu;   
\q1
\v 2 egu helai diho, egu tore isi, oi dibamu;  
\q2 dauha amo egu lalo-hadai o dibadiamu.   
\q1
\v 3 Egu raka o itaia taomu, egu hekure diho danu;  
\q2 egu kara iboudiai na oi dibamu.   
\q1
\v 4 Malagu ese hereva ta do se gwauraia negana ai,  
\q2 Iehova e, una hereva na vada o diba vaitani.   
\b  
\q1
\v 5 Oi ese o gunalaigumu, o gabelaigumu,  
\q2 imamu na latagu ai vada o atoa kau.   
\q1
\v 6 Aonega enehetomana na hoalaia badamu;  
\q2 ia na atai ai, idavarina na asi dibagu.   
\b  
\q1
\v 7 Oi Laumamu ena amo lau ede bainala?  
\q2 Oi vairamu ena amo lau ede baina heau henia?   
\q1
\v 8 Guba ai bama dae, to oi na unuseni ai;  
\q2 mase taudia edia gabu ai egu geda bama lahaia, ai danu.   
\q1
\v 9 Daba hanina bama abi, bama roho lao,  
\q2 gadobada daudauna ai bama hanoho,   
\q1
\v 10 unuseni ai danu oi imamu ese bema hakaugu,  
\q2 oi imamu idibana ese bema dogogu tao.   
\q1
\v 11 Bama toma “Dibura ese baine gorugu ahu,  
\q2 bona e ḡeḡegu daemu diarina na baine dibura”;   
\q1
\v 12 to, dibura na dia dibura oiemu ai,  
\q2 hanuaboi eme diari dina heḡereḡerena;  
\q2 badina be dibura bona diari na heḡereḡere oiemu ai.   
\b  
\q1
\v 13 Oi ese taugu anina o karaia,  
\q2 sinagu bogana ai o karagu.   
\q1
\v 14 Na imodaimumu, badina be oi na mai garimu bona mai hoamu;  
\q2 emu kara na hoa ḡaudia.  
\q1 Oi na dibamu herea lau;   
\q2
\v 15 gabu hehunina ai taugu e hekara;  
\q1 tanobada ena dobu gabudia ai e hekara ḡoevaḡoeva negana ai,  
\q2 taugu anitarana na emu amo se hehuni.   
\q1
\v 16 Tau-anigu na do asi oromana negana ai,  
\q2 oi matamu ese e itagu;  
\q1 dina o karadia egu na iboudiai emu buka ai vada e tore,  
\q2 ta do se vara negana ai.   
\q1
\v 17 Dirava e, emu lalo-hadai na ḡoeva-dae egu ai,  
\q2 idia na daka hutuma;   
\q2
\v 18 bama duahidia, idia na miri na heto.  
\q1 Na nogamu negana ai,  
\q2 lau na doini oi ida.   
\b  
\q1
\v 19 Dirava e, kara dika taudia boma aladia mase bema namo;  
\q2 bona rara ihahebubuna e uramu taudia bema rakatanigu danu bema namo;   
\q1
\v 20 idia ese e gwau edeede henimumu mai daḡedaḡedia ida,  
\q2 idia ese e inai henimumu, bae hadikamu totona.   
\q1
\v 21 Iehova e, e inai henimumu taudia na na inai henidiamu ani?  
\q2 e daḡedaḡe henimumu taudia na na badu henidiamu ani?   
\q1
\v 22 Na inai henidia lalo dikamu;  
\q2 idia na lau inaigu na tomamu.   
\q1
\v 23 Dirava e, ba tahugu, lalogu na ba diba;  
\q2 ba tohogu, egu lalo-hadai ba dibadia.   
\q1
\v 24 Ba itaia, dala dikana ta lalogu ai e miamu eiava;  
\q2 bona mia hanaihanai dalana ai ba hakaugu.   
\c 140  
\q1
\v 1 Iehova e, kara dika taudia edia amo ba harohogu mauri;  
\q2 daḡedaḡe taudia edia amo ba hamaurigu.   
\q1
\v 2 Idia ese kara dikadia e lalo hadailaimu,  
\q2 bona tuari e havaradia louloumu.   
\q1
\v 3 Maladia na e hamatakamu, gaigai malana na heto;  
\q2 bibinadia henudiai na hekori gaigaidia edia mase muramurana. (Selah)   
\q1
\v 4 Iehova e, kara dika taudia imadia amo ba gimagu,  
\q2 daḡedaḡe taudia edia amo ba hamaurigu;  
\q1 idia ese aegu ihahetutuhidia dalana vada e haeroa.   
\q2
\v 5 Heaḡi taudia ese rikiriki vada e hunia, iabigu totona,  
\q2 huo vada e otoa,  
\q2 dala isena ai idoalaigu ḡaudia vada e kara. (Selah)   
\q1
\v 6 Iehova na hamaoroamu, na tomu “Oi na egu Dirava”;  
\q2 Iehova e, egu noinoi herevadia ba hakala heni.   
\q1
\v 7 Iehova e, egu Ḡaubada, ihamaurigu tauna mai goadamu,  
\q2 tuari dinana ai kwaragu vada o laoa ahu.   
\q1
\v 8 Iehova e, kara dika tauna ena ura basio henia;  
\q2 ena lalo-hadai dikana basio durua. (Selah)   
\p
\v 9 E ḡeḡegu daemu taudia na kwaradia e abidia isimu;  
\q2 bibinadia herevadia dikadia ese bae hadareredia;   
\q1
\v 10 lahi gidadia na latadiai bae moru,  
\q2 guri ai bae tahodia dobi, basie tore isi lou,   
\q1
\v 11 Taunimanima ihadikadia herevadia e gwauraimu tauna na  
\q2 tano ai basine noho taritari;  
\q2 dika ese daḡedaḡe tauna na baine lasia tao haraḡa.   
\b  
\q1
\v 12 Lau dibagu Iehova ese hisi e animu tauna ena dala baine hamiaia,  
\q2 bona e dabumu tauna na ahuna maorona baine henia.   
\q1
\v 13 Momokani, kara maoromaoro taudia ese oi ladamu bae hanamoa,  
\q2 kara ḡoevaḡoeva taudia na oi vairamu ai bae noho.   
\c 141  
\q1
\v 1 Iehova e, na boi henimumu, aoma haraḡa dekegu ai,  
\q2 na boi henimumu negana ai ba hakala henigu.   
\q2
\v 2 Egu ḡuriḡuri na muramura mai bonana ai bainela oi vairamu ai,  
\q2 bona imagu na dudui isimu na adorahi boubouna ai bainela.   
\b  
\q1
\v 3 Iehova e, udugu ba gimaia,  
\q2 udugu bibinadia iduarana ba naria.   
\q1
\v 4 Lalogu na basio kehoa, dika ḡauna ta enai;  
\q2 bona kara dika ihekwarahilaidia ai kara havara taudia ida basina hebou,  
\q2 edia aniani ḡaudia namodia danu basina ani.   
\b  
\q1
\v 5 Tau namona ese ena hebogahisi ai baine kwadigu eiava baine gwau henigu be namo,  
\q2 a kara dika taudia edia dehoro amo nega ta kwaragu basie horoa;  
\q2 badina be nega idoinai edia kara dika ilao-ahudia ḡuriḡuridia na gwauraimu.   
\q1
\v 6 Bae revadia taudia imadia ai bae kau negana ai,  
\q2 lalodia na bae parara, Iehova ena hereva na momokani.   
\q1
\v 7 Haga nadina na ta hamakohiamu, tano ai ta ḡiḡia rohorohomu na heto,  
\q2 idia turiadia na unu bae karadia toma, mase gabuna iduarana ai.   
\b  
\q1
\v 8 Ḡaubada Iehova e, lau oi na hageremumu;  
\q2 oiemu ai na roho maurimu;  
\q2 asi igimagu ai basio rakatanigu.   
\q1
\v 9 Iabigu totona vada e atoa rikirikina amo ba rauagu;  
\q2 kara dika taudia edia idoa amo ba hamaurigu.   
\q1
\v 10 Kara dika taudia na sibodia edia huo ai bae heabi,  
\q2 a lau baina roho mauri.   
\c 142  
\q1
\v 1 Eregu amo Iehova na tai heniamu,  
\q2 eregu amo Iehova na noinoi heniamu.   
\q1
\v 2 Egu lalo-hisihisi na ia vairanai na herevalaiamu,  
\q2 egu lalo-hekwarahi na ia vairanai na gwauraiamu.   
\q1
\v 3 Laumagu e dauremu negana ai,  
\q2 egu dala oi mai dibamu.  
\b  
\q1 Na rakalaiamu dalana ai,  
\q2 iabigu rikirikina vada e hunia.   
\q1
\v 4 Idiba kahana na roha heniamu bona na henarimu,  
\q2 a ta ese se lalogumu;  
\q1 asi egu roho-mauri gabuna ta,  
\q2 asi tauna ta ese e dosigumu.   
\b  
\q1
\v 5 Iehova e, na tai henimumu,  
\q2 na tomu “Egu roho-mauri gabuna na oi,  
\q2 oi na lau ahugu, mauri taudia edia tano ai”.   
\q1
\v 6 Egu noinoi a kamonai,  
\q2 badina be vada e taogu tao.  
\b  
\q1 E daḡedaḡe henigumu taudia edia amo ba hamaurigu,  
\q2 badina be lauegu ai idia na gogoada heherea.   
\q1
\v 7 Dibura rumana amo ba hakaugu lasi,  
\q2 bena oi ladamu baina hanamoa.  
\q1 Kara maoromaoro taudia ese bae gegegu ahu,  
\q2 badina be oi ese ba harihari henigu.   
\c 143  
\q1
\v 1 Iehova e, egu ḡuriḡuri a kamonaia,  
\q2 egu noinoi a hakala henia.  
\q1 Emu heabidadama ai bona emu kara maoromaoro ai  
\q2 ba haere henigu.   
\q1
\v 2 Emu hesiai tauna basio hahemaoro henia,  
\q2 badina be harihari e maurimu tauna ta asi ena maoromaoro oi vairamu ai.   
\b  
\q1
\v 3 Badina be inai tauna vada e havagu,  
\q2 egu mauri na tano ai vada e taoa tao,  
\q1 dibura gabuna ai vada e atogu,  
\q2 idau nega masedia na heheto.   
\q1
\v 4 Taunabunai laumagu na e mase rea Ialogu ai,  
\q2 bona kudougu na eme hetaha tau-anigu ai.   
\b  
\q1
\v 5 Sene negana na laloamu,  
\q2 emu kara iboudiai na haerodiamu,  
\q2 imamu karakaradia na haerodiamu.   
\q1
\v 6 Imagu na dudui isimu emu ai,  
\q2 laumagu e ranu mase henimumu, tano kaukauna na heto. (Selah)   
\q1
\v 7 Iehova e, a haere henigu haraḡa;  
\q2 laumagu na e manokamu.  
\q1 Vairamu na egu ai basio hunia,  
\q2 mase gurina ai e dihomu taudia heḡereḡeredia ai bainala na garina.   
\q1
\v 8 Daba ai emu hebogahisi sivaraina baina kamonai,  
\q2 badina be na abidadama henimumu;  
\q1 egu lao dalana ba hadibagu,  
\q2 badina be laumagu na emu ai na abia isimu.   
\b  
\q1
\v 9 Iehova e, inaigu edia amo ba hamaurigu;  
\q2 oiemu ai vada na roho mauri.   
\q1
\v 10 Emu ura ikarana ba hadibagu,  
\q2 badina be oi na egu Dirava.  
\q1 Emu lauma namona ese baine hakaugu,  
\q2 dala heinina ai.   
\q1
\v 11 Iehova e, oi ladamu dainai egu mauri ba rauaia,  
\q2 emu kara maoromaoro ai hisihisi amo ba hakaugu lasi.   
\q1
\v 12 Emu hebogahisi ai lau inaigu na ba negedia dawe,  
\q2 e tuari henigumu taudia iboudiai na ba habuadia tari,  
\q2 badina be lau na emu hesiai tauna.   
\c 144  
\q1
\v 1 Iehova, egu nadi-gini, na hanamoamu;  
\q2 ia ese imagu e hadibadiamu, tuari ai,  
\q2 bona imagu kwakiwakidia danu heatu ai.   
\q1
\v 2 Ia na egu nadi-gini bona egu kohoro,  
\q2 igimagu bona ihamaurigu,  
\q2 egu kesi bona egu roho-mauri gabuna.  
\q1 Ia ese bese idau-idau na  
\q2 ia aena henudiai e atodiamu.   
\b  
\q1
\v 3 Iehova e, taunimanima be dahaka oi ese o haḡereamu?  
\q2 Taunimanima natuna be daika, oi ese o laloamu?   
\q1
\v 4 Taunimanima na hahodi tamona na heto,  
\q2 ena mauri dinadia na ikerukeru e hanaimu na heto.   
\b  
\q1
\v 5 Iehova e, emu guba ba haevaia, ba diho.  
\q2 Ororo ba daudia toho, bena bae ara;   
\q1
\v 6 kevaru ba hakevarua isi, ba hakarohodia rohoroho;  
\q2 emu diba ba kinodia, ba hadareredia.   
\q1
\v 7 Imamu na atai amo ba toia dobi,  
\q2 ranu momo lalodia amo ba rauagu bona ba hamaurigu,  
\q2 bona idau bese taudia imadia amo danu.   
\q1
\v 8 Idia ududia ese koikoi herevadia e gwauraimu,  
\q2 idia imadia idibadia na idiba koikoidia.   
\b  
\q1
\v 9 Dirava e, ane matamatana baina abia emu,  
\q2 varo-gwauta gitarana baina hataia, oi ihanamomu.   
\q1
\v 10 Oi ese pavapava na kwalimu o henidiamu,  
\q2 oi ese emu hesiai tauna David o hamauriamu.   
\q1
\v 11 Dare mai hisina amo ba hamaurigu,  
\q2 bona idau bese taudia imadia amo ba harohogu mauri;  
\q1 idia ududia ese koikoi herevadia e gwauraimu,  
\q2 bona imadia idibadia na idiba koikoidia.   
\b  
\q1
\v 12 Natuda mamaruanedia na maraḡidia amo bae bada oho bada oho,  
\q2 au babada na heheto;  
\q1 bona natuda hahinedia daiguni dudia na heheto,  
\q2 vada e utu, pavapava ena ruma ḡaudia.   
\q1
\v 13 Eda roge na bae honu honu dae,  
\q2 aniani ḡaudia idau-idau amo;  
\q1 eda mamoe na natudia daha daha bae havaradia,  
\q2 eda rei gabudia ai bae gerebu gerebu.   
\q1
\v 14 Eda boromakau na bae rogorogo,  
\q2 bona ta basine mara dika;  
\q1 eda hanua ariaradia ai na  
\q2 lalo-hisihisi taitaidia basie vara.   
\q1
\v 15 Hahenamo unuhetomadia e abimu besena na e moalemu;  
\q2 ena Dirava be Iehova besena na e moalemu.   
\c 145  
\q1
\v 1 Egu Dirava bona egu Pavapava, oi baina imodaimu,  
\q2 bona oi ladamu baina hanamoa ela bona hanaihanai.   
\q1
\v 2 Dina iboudiai baina hanamomu,  
\q2 bona ladamu baina imodaia ela bona hanaihanai.   
\q1
\v 3 Iehova na bada, ia iheatolaina danu baine bada;  
\q2 ena herea-dae na asi itahuna dalana.   
\q1
\v 4 Uru ta ese uru ta enai emu ḡaukara baine hanamolaia,  
\q2 bona emu siahu karadia baine gwaurai hedinarai.   
\q1
\v 5 Emu lohia toadia hairaidia bona emu hoa karadia  
\q2 baina haerodia.   
\b  
\q1
\v 6 Emu kara siahudia mai garidia na  
\q2 taunimanima ese bae gwauraidia;  
\q2 emu herea-dae baina gwauraia hedinarai.   
\q1
\v 7 Emu harihari-bada haridia bae hapiu,  
\q2 bona emu kara maoromaoro na bae anelai lalo-dika.   
\b  
\q1
\v 8 Iehova na mai ena harihari-bada bona mai ena hebogahisi;  
\q2 ena badu e halahemu, ena hebogahisi na bada herea.   
\q1
\v 9 Iehova ese taunimanima iboudiai e kara namo henidiamu,  
\q2 vada e kara ḡaudia iboudiai na ia ese e bogadia hisimu.   
\b  
\q1
\v 10 Iehova e, o kara ḡaudia iboudiai ese bae hanamomu,  
\q2 bona emu helaḡa taudia ese bae imodaimu.   
\q1
\v 11 Emu basileia hairaina bae herevalaia,  
\q2 bona emu siahu bae gwauraia;   
\q1
\v 12 emu siahu karadia na taunimanima natudia bae hadibalaidia,  
\q2 bona emu basileia hairaina ḡoeva-daena danu.   
\q1
\v 13 Emu basileia na mia-hanaihanai basileiana,  
\q2 emu lohia na e hesiriumu uru iboudiai lalodiai.  
\b  
\q1 Iehova na mai ena heabidadama, ena hereva iboudiai lalodiai,  
\q2 bona mai ena harihari-bada, ena kara iboudiai lalodiai.   
\q1
\v 14 Iehova ese e ketomu taudia iboudiai na e abidia isimu;  
\q2 e nunumaidia tarimu taudia iboudiai na ia ese e veridia toremu.   
\q1
\v 15 Mata iboudiai ese oi e haḡeremumu;  
\q2 oi ese adia o henidiamu, ta ta ena nega ena nega ai.   
\q1
\v 16 Oi imamu o kehoamu,  
\q2 mauri ḡaudia iboudiai bogadia o hakunudiamu.   
\q1
\v 17 Iehova ena dala iboudiai na mamaoro-mamaoro,  
\q2 ena kara idoinai na mai hebogahisina.   
\q1
\v 18 Iehova na e boi heniamu taudia iboudiai dekedekediai,  
\q2 e boi heniamu mai momokanidia ida taudia iboudiai dekedekediai.   
\q1
\v 19 Ia garina e garimu taudia iboudiai edia ura na ia ese e haḡuḡuruamu,  
\q2 edia taitai danu e kamonaimu, bona e hamauridiamu.   
\q1
\v 20 Ia e ura heniamu taudia iboudiai na Iehova ese e hamauridiamu,  
\q2 a kara dika taudia iboudiai na ia ese baine habuadia tari.   
\q1
\v 21 Lau udugu ese Iehova baine imodaia;  
\q2 taunimanima iboudiai ese ia ladana helaḡana bae hanamoa  
\q2 ela bona hanaihanai.   
\c 146  
\q1
\v 1 Iehova ba imodaia.  
\q2 Laumagu e, Iehova ba imodaia.   
\q1
\v 2 Iehova baina imodaia egu mauri dinadia iboudiai;  
\q2 egu Dirava ihanamolaina anedia baina abi ela bona egu mauri dokona.   
\b  
\q1
\v 3 Pavapava basio abidadama henidia;  
\q2 taunimanima natuna ta danu basio abidadama henia,  
\q2 ia na asi ena hekaha.   
\q1
\v 4 Laḡana e dokomu negana ai na ia ese tano e lou heniamu;  
\q2 una dina ai ena lalo-hadai e oremu.   
\b  
\q1
\v 5 Iakob ena Dirava ese e kahaiamu tauna na e moalemu  
\q2 ena helaro be Iehova, ena Dirava.   
\q1
\v 6 Iehova ese guba bona tanobada bona davara e karadia,  
\q2 bona lalodia ḡaudia iboudiai;  
\q2 ena heabidadama na e hesiriu hanaihanaimu.   
\q1
\v 7 E hadikadiamu taudia na ia ese e kara maoro henidiamu  
\q2 bona hitolo taudia na adia e henidiamu.  
\b  
\q1 Iehova ese iḡui taudia e ruhadia negemu;   
\q2
\v 8 Iehova ese mata-kepulu taudia matadia e hapapadiamu;  
\q1 E nunumaidia tarimu taudia na Iehova ese e veridia toremu;  
\q2 Iehova ese kara maoromaoro taudia e lalokau henidiamu.   
\q1
\v 9 Iehova ese noho-hedoa taudia e gimadiamu;  
\q2 vabu bona ihareha ia ese e naridiamu,  
\q2 a kara dika taudia na ia ese e habuadia tarimu.   
\q1
\v 10 Iehova baine lohia hanaihanai;  
\q2 Siona e, ia na emu Dirava ela bona uru iboudiai.  
\q1 Iehova ba imodaia.   
\c 147  
\q1
\v 1 Iehova ba imodaia.  
\q1 Badina be eda Dirava ihanamolaina anedia baita abi be namo;  
\q2 badina be ia na mai hariharibadana,  
\q2 bona heimodai anena iabina be namo.   
\q1
\v 2 Iehova ese Ierusalem e hadaiamu,  
\q2 Israel taudia vada e hakarohodia na ia ese e haboudia loumu.   
\q1
\v 3 Dara doko taudia na taudia e halodiamu,  
\q2 bona berodia e kumidiamu.   
\q1
\v 4 Ia ese hisiu na e hagaudiamu,  
\q2 bona iboudiai na ladadia e henidiamu.   
\q1
\v 5 Dirava na bada, ena siahu na bada herea,  
\q2 ena aonega na asi hahetohona.   
\q1
\v 6 Vada a moidia tao taudia na ia ese e abidia isimu,  
\q2 a kara dika taudia na ia ese tano ai e tahodia dobimu.   
\b  
\q1
\v 7 Iehova ihanamolaina anedia bavabi;  
\q2 eda Dirava na gitara anedia amo ba hamoalea.   
\q1
\v 8 Ia ese guba na ori amo vada e ḡovaia ahu;  
\q2 medu e heḡaeḡaelaiamu, tanobada ena,  
\q2 bona rei e hatubuamu ororo ai.   
\q1
\v 9 Uda ḡaudia na adia e henidiamu;  
\q2 mukou natudia e taimu negadia ai na ia ese e ubudiamu.   
\q1
\v 10 Hosi ena goada na se moalelaiamu,  
\q2 tau aena danu se moalelaiamu;   
\q1
\v 11 a Iehova ese ia garina e garimu taudia na e moalelaidiamu,  
\q2 bona ena hebogahisi e laroamu taudia danu.   
\b  
\q1
\v 12 Ierusalem e, Iehova ba imodaia.  
\q2 Siona e, emu Dirava be imodaia.   
\q1
\v 13 Badina be ia ese emu ikoukou auridia e ha-aukadiamu,  
\q2 bona natumu e hanamodiamu maḡumu ai.   
\q1
\v 14 Maino e havaraiamu emu tano hetoadia ai;  
\q2 uit namo-hereana amo e hahonumumu.   
\q1
\v 15 Ena haheḡani e siaiamu, tanobada enai;  
\q2 ena hereva na e lao haraḡamu.   
\q1
\v 16 \it Snow\it* e henimu, beberoho na heto;  
\q2 medu-hetarina e ḡiḡia rohorohomu, kahu na heto.   
\q1
\v 17 \it Ice\it* e tahoa lasimu, aniani momorudia na heheto.  
\q2 ena keru ai daika baine gini?   
\q1
\v 18 Ena hereva e siai lasimu, e havevedia ohomu;  
\q2 ena lai e hatoaiamu, bena ranu e arumu.   
\q1
\v 19 Ia ese ena hereva na Iakob e gwaurai heniamu;  
\q2 ena taravatu bona ena hahemaoro herevadia na Israel e heniamu.   
\q1
\v 20 Bese idauna ta unu se kara henia toma:  
\q2 idia na ena hahemaoro herevadia asi dibadia.  
\q1 Iehova ba imodaia.   
\c 148  
\q1
\v 1 Iehova ba imodaia.  
\q2 Guba amo Iehova ba imodaia,  
\q1 atai doriva-dorivana ai ba imodaia.   
\q1
\v 2 Ena aneru iboumui ai, ba imodaia;  
\q2 ena tuari oreadia iboumui ai, ba imodaia.   
\b  
\q1
\v 3 Dina bona hua, ba imodaia;  
\q2 hisiu mai diarimui, iboumui ai ba imodaia.   
\q1
\v 4 Guba atai dorivana ai, ba imodaia;  
\q2 ranu guba daenai, ba imodaia.   
\b  
\q1
\v 5 Iehova ladana bae imodaia;  
\q2 badina be ia e gwau isi, bena idia na e vara.   
\q1
\v 6 Ia ese vada e atodia, bae mia hanaihanai;  
\q2 ia ese hetoa vada e henidia, basie hanai.   
\b  
\q1
\v 7 Tanobada amo Iehova ba imodaia,  
\q2 umui davara ḡaudia badadia bona dobu gabudia iboudiai danu.   
\q1
\v 8 Lahi bona medu hetarina, \it snow\it* bona \it ice\it*;  
\q2 lai gubana, ena haheḡani ihamomokanina ḡauna.   
\b  
\q1
\v 9 Ororo badadia bona maraḡidia iboudiai;  
\q2 huahua audia bona sida audia iboudiai.   
\q1
\v 10 Uda boromadia bona boromakau iboudiai;  
\q2 tano-rau ḡaudia bona roho manudia.   
\b  
\q1
\v 11 Tanobada pavapavadia bona bese iboudiai;  
\q2 hanua lohiadia bona hahemaoro taudia iboudiai.   
\q1
\v 12 Uhau bona ulato;  
\q2 iahu bona memero.   
\b  
\q1
\v 13 Idia na Iehova ladana bae imodaia,  
\q2 badina be ia sibona ladana na herea dae;  
\q2 ia hairaina na tanobada bona guba daediai.   
\q1
\v 14 Ia ese ena bese taudia edia doa na vada e duduia isi,  
\q2 ena helaḡa taudia iboudiai edia heimodai toana,  
\q2 Israel besena, ia dekedekenai e nohomu taudia, toadia danu.  
\q1 Iehova ba imodaia.   
\c 149  
\q1
\v 1 Iehova ba imodaia.  
\q2 Ane matamatana avabia, Iehova ena;  
\q2 e abidadama heniamu taudia edia hebou ai ba   
\q1
\v 2 Israel ese ia ikarana Diravana baine moalelaia;  
\q2 Siona natuna ese edia Pavapava bae moalelaia.   
\q1
\v 3 Ia ladana bae imodaia mai mavarudia ida,  
\q2 tareko bona gitara reḡedia amo bae imodaia.   
\q1
\v 4 Badina be Iehova ese ena orea taudia na e moalelaidiamu,  
\q2 bona manau taudia na kwalimu e haheralaidiamu.   
\q1
\v 5 E abidadama heniamu taudia na hairai ai bae hisi dae,  
\q2 edia mahuta patadia ai moale anedia bae abi.   
\b  
\q1
\v 6 Gadodia ese Dirava bae imodaia badabada,  
\q2 bona matadia rua daredia na imadia ai bae abi.   
\q1
\v 7 Orea idau-idau taudia na davadia bae henidia;  
\q2 bese idau-idau taudia na matadia bae hakanidia.   
\q1
\v 8 Edia pavapava na auri amo bae ḡuidia,  
\q2 bona edia lohia na auri gadeadia amo.   
\q1
\v 9 Hahemaoro herevadia vada e tore ḡaudia heḡereḡeredia ai do bae kara henidia;  
\q2 e abidadama heniamu taudia iboudiai hairaidia binai.  
\q1 Iehova ba imodaia.   
\c 150  
\q1
\v 1 Iehova ba imodaia  
\q1 Dirava ba imodaia ena helaḡa gabuna ai;  
\q2 guba ai, ena siahu gabuna ai, ba imodaia.   
\q1
\v 2 Ena siahu karadia daidiai ba imodaia;  
\q2 ena goada herea-daena heḡereḡerena ba imodaia.   
\b  
\q1
\v 3 Kibi reḡena amo ba imodaia;  
\q2 gitara bona hatai ḡauna badana amo ba imodaia.   
\q1
\v 4 Tareko reḡedia bona mavaru amo ba imodaia;  
\q2 gitara bona ivilikou amo ba imodaia.   
\q1
\v 5 Botabota auridia reḡedia amo ba imodaia,  
\q2 auri ba botadia goada-goada, ia ba imodaia.   
\q1
\v 6 Mai laḡadia ḡaudia iboudiai Iehova ba imodaia.  
\q1 Iehova ba imodaia.   