\id 1PE
\h 1 Pedro
\toc1 Xo̱jo̱n carta xi kiskiì ítjòn San Pedro
\toc2 1 Pedro
\toc3 1 P.
\mt1 Xo̱jo̱n carta xi kiskiì ítjòn San Pedro
\c 1
\s1 Kó tsò Pedro nga síhixat'aà xi̱ta̱
\p 
\v 1 'A̱n xi 'mì‑na̱ Pedro, nga 'a̱n tsibíxáya‑na Jesucristo, sìhixat'aà‑nò ngats'ioò xi xó jaàjiìn‑nò Nainá nga mì ti̱ nangui‑nò titsa̱jna‑nò nga xki̱ xi ján na̱xa̱ndá kitsjohoya ya̱ nangui Ponto, Galacia, Capadocia, Asia ko̱ Bitinia;
\v 2 jñò xi xó kitjaàjiìn‑nò, koni s'ín jye tjíndaà‑la̱ xi kjo̱hítsjeèn‑la̱ Nainá xi Na̱'èn‑ná ma, nga jè Ini̱ma̱ Tsjeè‑la̱ k'oa̱á s'ín kisìko̱‑nò nga nguì xi̱ta̱‑la̱ Nainá ma, mé‑ne nga si̱kitasòn‑là Jesucristo ko̱ mé‑ne ma xíxteèn‑jno‑nò jní‑la̱ nga matsjeèya ini̱ma̱‑nò kjoa̱ ts'e̱ jé‑nò. Tseé kjo̱ndaà ko̱ kjoa̱'nchán kàtas'e‑la̱ ini̱ma̱‑nò.
\s1 Kjo̱tjò xi chiñàkjoa̱‑lá xi tíjnatjò‑la̱ Nainá ján ngajmiì
\p 
\v 3 Jeya kàtìjna Nainá xi Na̱'èn‑la̱ Jesucristo xi otíxoma‑ná. 'Ñó tse kjoa̱hi̱ma̱takòn tjín‑la̱: koni s'ín jaáya‑la̱ Jesucristo kjoa̱ ts'e̱ kjoa̱biyaà, k'oa̱á kisìko̱‑ná Nainá nga kits'in xi̱tse̱ ìjngoò k'aá mé‑ne nga kjit'aà na̱chrjein chíñakjoa̱á
\v 4 nga tsjá‑ná kjo̱tjò xi jè tíjnatjò‑la̱ ján ngajmiì, kjo̱tjò xi mìkiì bits'on ni̱ta̱ kjé‑ne, mìkiì bi'ndo ko̱ mìkiì bixòña. Kjo̱tjò jè, jñá tjoé‑ná.
\v 5 Ta nga̱tjì‑la̱ nga mokjeiín‑ná i̱t'aà ts'e̱ Nainá, jè nga'ñó‑la̱ síkinda̱‑ná skanda k'e̱ nga ki̱tjokàjñaá kjo̱'in koni s'ín tjíndaà‑la̱ Nainá k'e̱ nga jye kjoe̱het'aà na̱chrjein.
\p 
\v 6 Koií kjoa̱‑la̱, jñò, 'ñó tsja tjín‑nò, na̱s'ín tjín i'nga na̱chrjein nga makájno‑nò nga kjìn ska̱ya kjo̱'in nìkjioón.
\v 7 K'oa̱á ma‑ne nga kjo̱'in nìkjioón nga ma chít'aà‑nò tsà ndaà mokjeiín‑nò. K'oa̱á ngaya‑la̱ koni jè oro, mochjeén‑né nga ko̱ ni'ín ko̱tsjeèya‑ne. Ko̱ jè kjoa̱ nga mokjeiín‑nò ìsa̱á 'ñó chjí‑la̱ mì k'oa̱á‑ne koni jè oro xi bits'ón‑ya. Jñò, k'e̱ nga jye chít'aà‑nò koni s'ín mokjeiín‑nò, jeyaá ki̱tsa̱jnaà, 'ngaá ki̱tsa̱jnaà ko̱ jcha̱xkón‑nò k'e̱ nga kjoi̱í ìjngoò k'a Jesucristo.
\p 
\v 8 Jñò, matsjacha‑nò Jesucristo, na̱s'ín mìkiì kiyaxkoòn. Mokjeiín‑nò i̱t'aà ts'e̱, na̱s'ín mìkiì titsa̱'yaà. 'Ñó tsja ma‑nò skanda tsjìn 'én xi ma s'e̱no̱jmí nga 'ñó tjín‑nò kjo̱tsja.
\v 9 Koií kjoa̱‑la̱ nga matsja‑nò nga jye titsa̱bitjokàjñoò kjo̱'in ta nga̱tjì‑la̱ nga mokjeiín‑nò i̱t'aà ts'e̱ Cristo.
\p 
\v 10 Jè kjoa̱ nga bitjokàjñoò kjo̱'in, jñà xi̱ta̱ xi kiìchja̱ ngajo‑la̱ Nainá kjòtseé, kiskoòta'yàko̱‑né ti̱koa̱á kiskònanguiya‑né, i̱kjoàn kiìchja̱ya jè kjo̱ndaà xi tsjá‑nò Nainá.
\v 11 Jñà xi̱ta̱ koi, jè Ini̱ma̱‑la̱ Cristo kisìkichi̱ya ítjòn‑la̱ mé kjo̱'in xi si̱ìkjeiín Cristo ko̱ kjoa̱ jeya xi s'e̱‑la̱ k'e̱ nga ko̱ma i̱skan. Kiskònanguiya‑né mé na̱chrjein‑ne nga k'oa̱s'ín ko̱mat'in koa̱ kós'ín ko̱ma.
\v 12 Ta̱nga jè Nainá kisìkichi̱ya‑la̱ nga mìtsà kjo̱ndaà ts'e̱ nga ko̱s'ín kis'eno̱jmí‑la̱ 'én koi; kjo̱ndaà tsa̱jòn‑nò. Ko̱ jñà 'én koi, ti̱jñà‑ne 'én ndaà‑la̱ Nainá xi kjoa̱ ts'e̱ Cristo xi tís'eno̱jmí‑nò na̱chrjein i̱'ndei̱. Nga ti̱jé‑ne Ini̱ma̱ Tsjeè‑la̱ Nainá xi ngajmiì nchrobá‑ne tsjá‑la̱ nga'ñó jñà xi̱ta̱ xi béno̱jmí‑nò. Skanda jñà àkja̱le̱, mejèn‑la̱ skoe̱ kjoa̱ koi.
\s1 Mochjeén‑né nga tsjeè si̱jchá yijo‑ná
\p 
\v 13 Koií kjoa̱‑la̱ jñò, titsa̱jnandaà, ndaà ti̱kítsjeèn, nguì ndaà chíñakjoa̱‑là kjo̱ndaà xi tjoé‑nò k'e̱ nga kjoi̱í ìjngoò k'a Jesucristo.
\v 14 K'oa̱s'ín ndaà ti̱jchá yijo‑nò koni i̱xti xi ndaà 'nchréñijon. Kì k'oa̱ ti̱s'ín 'nè‑nò koni s'ín ki'nè nga sa̱ ítjòn nga ch'o tjín kjoa̱ xi kisìjé yijo‑nò k'e̱ nga ti̱kj'eè ndaà yaxkoòn Nainá.
\v 15 Ta̱ sa̱á tsjeè ti̱jchá yijo‑nò ngats'iì kjoa̱ xi 'nè, nga jè Nainá xi xó kiìchja̱‑nò, xi̱ta̱ tsjeè‑né.
\v 16 Nga jè Xo̱jo̱n‑la̱ Nainá, k'oa̱á s'ín tíchja̱ nga tsò: “Jñò, xi̱ta̱ tsjeè kàtama, nga 'a̱n, xi̱ta̱ tsjeè‑ná.”
\p 
\v 17 Jñò, tsà Na̱'èn 'mì‑là Nainá xi ta ngásòn tífìko̱ ngats'iì xi̱ta̱ k'e̱ nga bìndaàjiìn‑la̱ ni̱ta̱ mé kjoa̱ xi s'ín, mochjeén‑né nga kjit'aà na̱chrjein ndaà jcha̱xkón nga i̱ titsa̱jnaà i̱sò'nde nga mìtsà i̱ nangui‑nò.
\v 18 Jñò, jyeé ndaà tíjiìn‑nò nga mìtsà tsojmì xi ma‑la̱ bits'on kjòchjítjì‑nò nga ma titsa̱jnandei̱í‑nò ngats'iì kjoa̱ ch'o xi ni̱mé chjí‑la̱ koni s'ín tsakó‑nò xi̱ta̱ jchínga‑nò. Mìtsà to̱n oro ko̱ to̱n plata kjòchjítjì‑nò.
\v 19 Jè jní‑la̱ Cristo xi 'ñó tse chjí‑la̱ kjòchjítjì‑nò. Cristo kitsjaà kjo̱tjò yijo‑la̱ nga k'en‑t'aà krò koni jngoò orrè xi tsjeè kji, xi ni̱mé ch'in tjít'aà yijo‑la̱.
\v 20 Ti̱k'e̱‑ne nga ti̱kj'eè sindaà i̱sò'nde, Cristo, k'oa̱á s'ín kisinè‑la̱ kjoa̱ xi si̱ìkitasòn. Ta̱nga jè na̱chrjein xi titsa̱jnaá i̱'ndei̱ ki'ya‑la̱ nga j'iì Cristo nga kisìkitasòn kjoa̱ xi kisinè‑la̱ xi kjo̱ndaà tsa̱jòn.
\v 21 Xi i̱t'aà ts'e̱ Cristo, jñò mokjeiín‑nò i̱t'aà ts'e̱ Nainá; nga jè kisìkjaáya‑la̱ i̱t'aà ts'e̱ kjoa̱biyaà, ti̱koa̱ kitsjaà‑la̱ kjoa̱ jeya; k'oa̱á ma‑ne nga mokjeiín‑nò ko̱ chiñà nga si̱ìkitasòn Nainá koni s'ín kitsjaà‑nò tso'ba.
\p 
\v 22 Jè ini̱ma̱‑nò, jyeé kjòtsjeè, koií kjoa̱‑la̱ nga nìkitasòn koni tsò 'én kixi̱‑la̱ Nainá mé‑ne nga kixi̱ si̱tjòchaà xinguio̱o. K'oa̱á ma‑ne nga mochjeén‑né nga 'ñó ndaà ti̱tsjacha xinguio̱o nga tsjeè tjín ini̱ma̱‑nò.
\v 23 Jñò, ìjngoò k'a kits'iìn xi̱tse̱ ìjngoò k'a‑nò. Ta̱nga mìtsà tje̱‑la̱ xi̱ta̱ xi biyaà kits'iìn‑nò, jè tje̱‑la̱ Nainá xi mìkiì biyaà kits'iìn‑nò. Nga̱ jè 'én‑la̱ Nainá xi tíjnakon ko̱ xi mìkiì fehet'aà ni̱ta̱ kjé‑ne kits'iìn ìjngoò k'a‑nò.
\v 24 Nga k'oa̱á s'ín tíchja̱ Xo̱jo̱n‑la̱ Nainá nga tsò:
\q1 Ngats'iì xi̱ta̱, k'oa̱á s'ín ngaya‑la̱ koni xka̱ ijñá;
\q1 kjoa̱jeya‑la̱ xi̱ta̱, k'oa̱á s'ín ngaya‑la̱ koni naxó‑la̱ xka̱ ijñá;
\q1 jñà xka̱ ijñá, xì‑né; i̱kjoàn bixòjen naxó‑la̱.
\q1 
\v 25 Ta̱nga jè 'én‑la̱ Nainá tíjna‑né ni̱ta̱ kjé‑ne.
\m 'Én jè, jè 'én ndaà‑la̱ Nainá xi kjoa̱ ts'e̱ Cristo xi jye kis'eno̱jmí‑nò.
\c 2
\s1 Na̱xa̱ndá xi̱tse̱‑la̱ Nainá
\p 
\v 1 Chja̱àxìn‑là yijo‑nò xi kjoa̱ ts'e̱n, kjoa̱ chona̱cha̱n, kjoa̱ ts'e̱ xi̱ta̱ xi jò i̱sén tjín‑la̱, kjoa̱xìtakòn, ngats'iì 'én ndiso.
\v 2 Ko̱s'ín t'e̱en koni s'ín ndí i̱xti xi sa̱ kits'iìn nga 'ñó síjé tsjín nga mejèn‑la̱ ko̱ki. K'oa̱á ti̱s'ín 'ñó ti̱nchátsjioò jè 'én‑la̱ Nainá xi nguì 'én tsjeè mé‑ne nga jè ko̱jchá‑nò ko̱ ko̱chrjekàjiìn‑nò kjo̱'in Nainá,
\v 3 nga jyeé ki'yaà jñò nga jè Na̱'èn‑ná, 'ñó ndaà xi̱ta̱.
\s1 Jè nda̱jo̱ xi tíjnakon
\p 
\v 4 Jè Jesucristo, jè ngaya‑la̱ jngoò nda̱jo̱ xi tíjnakon, jè xi ochrjekàngui jñà xi̱ta̱, ta̱nga Nainá xó k'oa̱á s'ín jaàjiìn‑ne nga 'ñó tse chjí‑la̱. Jñò, k'e̱ nga binchat'aà chrañà‑là Cristo,
\v 5 ti̱koa̱á k'oa̱á s'ín ngaya‑nò koni nda̱jo̱ xi títsa̱jnakon. Nainá tísíkjeén‑nò koni nda̱jo̱ nga tíbíndaà ni'ya tsjeè‑la̱ mé‑ne jñò, no̱'miì tsjeè ko̱ma nga ya̱ si̱xá nga i̱t'aà ts'e̱ Jesucristo k'oi̱‑là kjo̱tjò Nainá xi jè ndaà sasén‑la̱ koni s'ín okóya Ini̱ma̱ Tsjeè‑la̱.
\v 6 K'oa̱á s'ín tíchja̱ Xo̱jo̱n‑la̱ Nainá nga tsò:
\q1 Chítsejèn‑là, 'a̱n síkíjna jngoaà nda̱jo̱ nga'ñó‑la̱ chrja̱ngui̱‑la̱ ni'ya ján na̱xa̱ndá Sión,
\q1 xi xó 'a̱n jaàjiìn‑na,
\q1 xi 'ñó ndaà kji ko̱ 'ñó tse chjí‑la̱.
\q1 Jè xi ko̱kjeiín‑la̱ i̱t'aà ts'e̱, mìkiì ko̱sobà‑la̱.
\m 
\v 7 Jñò, xi mokjeiín‑nò i̱t'aà ts'e̱ nda̱jo̱ jè, bixón‑nò: 'ñó tse chjí‑la̱. Ta̱nga jñà xi̱ta̱ xi mìkiì mokjeiín‑la̱, bitasòn‑né koni s'ín tíchja̱ Xo̱jo̱n‑la̱ Nainá nga tsò:
\q1 Jè nda̱jo̱ xi tsachrjekàngui chji̱ne̱chrjó,
\q1 jè xi nda̱jo̱ sko̱‑la̱ ko̱ma ts'e̱ chrja̱ngui̱‑la̱ ni'ya.
\m 
\v 8 Ìjngoò k'a tjít'aà Xo̱jo̱n‑la̱ Nainá ñánda tsò:
\q1 Nda̱jo̱ jè, kjìn xi̱ta̱ satíngui ko̱ kjìn xi̱ta̱ ki̱xangui.
\m Jñà xi̱ta̱ koi, k'oa̱á s'ín mat'in nga mìkiì síkitasòn koni tsò 'én‑la̱ Nainá; koií ko̱s'ín mat'in‑ne nga k'oa̱á s'ín ok'ìn‑la̱.
\s1 Jè na̱xa̱ndá‑la̱ Nainá
\p 
\v 9 Ta̱nga jñò, xi̱ta̱ na̱xa̱ndá xi xó kitjaàjiìn‑nò. Jñò, no̱'miì xi nìxá‑la Cristo, jè xi xi̱ta̱xá ítjòn tíjna. Jñò, xi na̱xa̱ndá tsjeè‑la̱ Nainá 'mì‑nò, jngoò na̱xa̱ndá xi ya̱ nokjoà‑nò i̱t'aà ts'e̱ Nainá mé‑ne nga ko̱ma ki̱nókjoa̱ya‑nò kjo̱ndaà‑la̱ Nainá xi tsachrjekàjiìn‑nò kjoa̱ ts'e̱ jé ñánda jñò choòn koa̱ ya̱á kisìkítsa̱jna‑nò ñánda iseèn choòn.
\v 10 Jñò, nga sa̱ kjòtseé skanda mìtsà xi̱ta̱ na̱xa̱ndá 'mì‑nò; ta̱nga i̱'ndei̱ na̱xa̱ndá‑la̱ Nainá 'mì‑nò. Nga sa̱ kjòtseé Nainá mìkiì mahi̱ma̱keè‑nò; ta̱nga i̱'ndei̱, jyeé mahi̱ma̱keè‑nò.
\p 
\v 11 Jñò ndí 'ndsè xi 'ñó matsjacha‑nò, bítsi'ba‑nò koni xi̱ta̱ xi mì ti̱ nangui‑nò titsa̱jna‑nò xi ta titsa̱bitjaàjtoò i̱ i̱sò'nde, kì kiì biì'nde‑la yijo‑nò kjoa̱ ts'e̱ jé xi síjé yijo‑nò xi kjaán‑ko̱ ini̱ma̱‑nò.
\v 12 Ndaà tanguíko̱o yijo‑nò ya̱ i̱jiìn‑la̱ xi̱ta̱ xi mìkiì mokjeiín‑la̱ i̱t'aà ts'e̱ Cristo. Jñà xi̱ta̱ koi, na̱s'ín chja̱jno‑nò i̱'ndei̱, ta̱nga k'e̱ nga kjoi̱í ìjngoò k'a Cristo tsjá‑la̱ kjo̱ndaà Nainá koií kjoa̱‑la̱ nga skoe̱xkon‑nò nga ndaà titsa̱'nè.
\s1 Jcha̱xkoán xi̱ta̱xá
\p 
\v 13 Nga jeya kíjna‑ne Na̱'èn‑ná, ti̱kitasòn‑là ngats'iì xi̱ta̱ i̱sò'nde xi kjo̱tíxoma tjíya tsja, jñà xi 'ñó 'nga xá tjín‑la̱, xi xi̱ta̱ sko̱‑la̱ títsa̱jna;
\v 14 ti̱koa̱ ti̱kitasòn‑là jñà xi gobernador títsa̱jna nga jè xi̱ta̱xá ítjòn síkasén nga tsjá‑la̱ kjo̱'in xi̱ta̱ xi kjoa̱ ótsji; koa̱ jñà xi ndaà s'ín, ndaà síkítsa̱jna.
\v 15 Nainá k'oa̱á s'ín mejèn‑la̱ nga jñò, ndaà s'e̱en, mé‑ne jñà xi̱ta̱ xi mìkiì machi̱ya‑la̱ jyò kítsa̱jna‑ne, nìmé 'én ki̱chja̱ xi kondra̱ tsa̱jòn.
\p 
\v 16 Jñò, k'oa̱á s'ín ti̱jchá yijo‑nò nga titsa̱jnandei̱í‑nò, ta̱nga kì k'oa̱á s'ín nìkítsjeèn nga tjí'nde‑nò nga ch'o s'e̱en. K'oa̱á s'ín ti̱jchá yijo‑nò nga chi̱'nda‑la̱ Nainá maà.
\v 17 Jcha̱xkón yije xi̱ta̱. Ti̱tsjacha xi 'ndsè chibà. Ti̱skón‑chaà Nainá. Jcha̱xkón jè xi xi̱ta̱xá ítjòn tíjna.
\s1 Kjoa̱ xi tjínè‑la̱ nga si̱ìkitasòn xi chi̱'nda 'mì
\p 
\v 18 Jñò xi xi̱ta̱ chi̱'nda 'mì‑nò, jcha̱xkón koa̱ ti̱kitasòn‑là nei‑nò. Mìtsà ta jñà nei‑nò xi ndaà síko̱‑nò ko̱ xi beètjò‑nò, ti̱koa̱á ti̱kitasòn‑là jñà xi ch'o síko̱‑nò.
\v 19 Ndaà bìtsa̱jna nga nguixko̱n Nainá jñà xi̱ta̱ xi kjo̱'in síkjeiín na̱s'ín mì jé tjín‑la̱ ta jè nga̱tjì‑la̱ nga machi̱ya‑la̱ kó tsò Nainá.
\v 20 Jñò, tsà kjo̱'in tsjá‑nò xi̱ta̱ nga jé binchaàtsjioò, ¿mé xi ndaà ki̱tsa̱jna‑nò? Ta̱nga tsà kjo̱'in titsa̱nìkjioón nga ndaà 'nè, ndaà si̱ìkítsa̱jna‑nò Nainá.
\v 21 Nga koií xá kiìchja̱‑nò Nainá nga jè Cristo kisìkjeiín kjo̱'in xi kjoa̱ tsa̱jòn. Tsibíjna jngoò‑nò chi̱ba̱ nga k'oa̱s'ín si̱kitasòn koni s'ín kisìkitasòn jè.
\v 22 Cristo, ni̱jngoò jé tsohótsji, ko̱ ni̱jngoò 'én ndiso kiìchja̱.
\v 23 K'e̱ nga kiìchja̱jno‑la̱ xi̱ta̱, mìkiì tsà kiìchja̱jno ngajo‑la̱. K'e̱ nga kisìkjeiín kjo̱'in, mìkiì tsà koa̱ ti̱s'ín kis'iìn ngajo‑ne. Ta Nainá tsibíya tsja, nga jè xi bíndaàjiìn kjoa̱kixi̱.
\v 24 Jè sobà Cristo tsakaje̱n jé‑ná k'e̱ nga kisìtjoòt'aà yijo‑la̱ ya̱ krò, mé‑ne jñá ki̱tsa̱jnakon‑ná nga nìkitasoán xi kjoa̱ kixi̱ nga jyeé titsa̱jnat'aàxìn‑lá kjoa̱ ts'e̱ jé koni tsà jye k'eén. Jè Cristo, koni s'ín kisìkjeiín kjo̱'in nga kitsì'on, jñò kjòndaá‑nò.
\v 25 Jñò, nga sa̱ kjòtseé, k'oa̱á s'ín tsitjaà koni orrè xi kisìjchàaxkon ndi̱yá‑la̱, ta̱nga i̱'ndei̱, jyeé inchrobàt'aà‑là Cristo koni jngoò paxtò xi síkinda̱ ini̱ma̱‑nò.
\c 3
\s1 Kós'ín si̱ìjchá yijo‑la̱ jè x'i̱n ko̱ chjo̱ón
\p 
\v 1 K'oa̱á ti̱s'ín tjín i̱t'aà tsa̱jòn xi íchjín 'mì‑nò, nangui titsa̱jna‑là x'i̱n‑nò, mé‑ne jñà xi̱ta̱ x'i̱n‑nò tsà tjín i'nga xi mìkiì mokjeiín‑la̱ 'én‑la̱ Nainá, ko̱kjeiín‑la̱, na̱s'ín mìkiì ki̱nókjoa̱ko̱o kjoa̱ ts'e̱ Nainá. K'e̱ nga skoe̱xkon‑nò nga ndaà titsa̱nìjchá yijo‑nò ti̱koa̱á si̱ìkjatjìyaá‑la̱ yijo‑la̱.
\v 2 Skótsejèn‑nò nga tsjeè titsa̱nìjchá yijo‑nò nga ndaà yaxkón Nainá.
\v 3 Ko̱ kì tà i̱sò'nga‑la̱ yijo‑nò 'ñó ndaà bíndaà, nga 'ñó ndaà bí'ñó tsja̱ skoò, nga ndáto̱n chjí nìkjeén xi nguì oro, nga jñà nikje x'ió‑nò 'ñó xkón kjoàn.
\v 4 Majìn, jè xi nchrobájiìn ini̱ma̱‑nò xi ndaà síkatsejèn‑nò, jè‑né xi mìkiì bits'on, jè ini̱ma̱ xi indaàkjoa̱ ko̱ xi 'nchán tíjna. Jè xi 'ñó tse chjí‑la̱ nga nguixko̱n Nainá.
\v 5 Nga sa̱ kjòtseé, jñà íchjín xi ndaà kijtseèxkón Nainá nga kiskoòñà‑la̱, k'oa̱á s'ín ndaà tsatsejèn nga nangui tsibìtsa̱jna‑la̱ x'i̱n‑la̱.
\v 6 K'oa̱á s'ín kis'iìn Sara nga kisìkitasòn‑la̱ Abraham. K'oa̱á ma‑ne nga ndaà kijtseèxkón nga jè xi Na̱'èn tíjna. Jñò, tsà ndaà 'nè ko̱ tsà nìmé kjo̱xkón tjín‑nò, tje̱‑la̱ Saraá ma.
\p 
\v 7 Jñò xi x'i̱n 'mì‑nò, ndaà ti̱tsa̱jnako̱o jñà íchjín‑nò nga ndaà kàtachi̱ya‑nò nga ìsa̱á indaàkjoa̱. Ndaà jcha̱xkón íchjín‑nò nga ngásòn tjoé‑nò jè kjo̱ndaà‑la̱ Nainá, jè kjoa̱binachon xi jè Nainá jye tjíndaà‑la̱ nga tsjá‑nò. K'oa̱á s'ín t'e̱en mé‑ne k'e̱ nga nokjoàt'aà‑là Nainá, ni̱mé si̱ìjti‑nò.
\s1 Kós'ín si̱ìjchá yijo‑la̱ ngats'iì xi̱ta̱‑la̱ Nainá
\p 
\v 8 Nga yije kjoa̱ koi, ngats'ioò, ta jngoò kjo̱hítsjeèn kàtas'e‑nò; ti̱jetakòn xinguio̱o; tjòcha t'e̱en xinguio̱o nga 'ndsè chiba; chahi̱ma̱a xinguio̱o; i̱ma̱ kjoa̱ t'e̱en.
\v 9 Tsà yá xi ch'o síko̱‑nò, kì k'oa̱á ti̱s'ín 'nè ngajo‑nò. Tsà yá xi 'on chja̱jno‑nò, kì k'oa̱á ti̱s'ín nokjoàjno ngajo‑là. Jñò, ta̱ sa̱á ti̱jét'aà‑là Nainá nga kàtasíchikon‑t'in; nga jyeé 'yaà nga koií xá kinokjoá‑nò nga Nainá si̱ìchikon‑t'in‑nò.
\v 10 Nga:
\q1 Jè xi mejèn‑la̱ nga tsja s'e‑la̱ nga tíjnakon,
\q1 nga mejèn‑la̱ skoe̱ na̱chrjein xi ndaà,
\q1 kàtasíkinda̱ ni̱je̱n‑la̱ nga mì ch'o ki̱chja̱;
\q1 ko̱ kàtasíkinda̱ tso'ba, nga mì 'én ndiso ki̱chja̱.
\q1 
\v 11 Ti̱nchat'aàxìn‑là kjoa̱ xi ch'o tjín; ndaà t'e̱en.
\q1 'Nchán titsa̱jnako̱o xinguio̱o ni̱ta̱ mé kjoa̱ xi tjín‑nò.
\q1 
\v 12 Nga jè Na̱'èn‑ná tísík'aá xko̱n nga tísíkinda̱ xi xi̱ta̱ kixi̱,
\q1 tíbinchá líká‑la̱ nga tí'nchré‑la̱ k'e̱ nga chja̱t'aà‑la̱,
\q1 ta̱nga jñà xi̱ta̱ xi ch'o s'ín bí'maá‑la̱ i̱sén‑la̱ nga kondra̱ ts'e̱‑né.
\p 
\v 13 Jñò, tsà kjit'aà na̱chrjein nga ndaà titsa̱'nè, mì yá xi̱ta̱ xi ch'o si̱ìko̱‑nò.
\v 14 Ta̱nga mé ta ndaà‑nò tsà kjo̱'in titsa̱nìkjioón ta koi kjoa̱‑la̱ nga kixi̱ 'nè. Ta̱nga ni̱ jngoò xi̱ta̱ tsakjoòn‑là, kì binchaxkón‑là yijo‑nò.
\v 15 Jè ti̱kíjna ítjòn Cristo nga jè kàtatíxoma‑nò ya̱ i̱jiìn ini̱ma̱‑nò. Ti̱tsa̱jnandaà nga kjit'aà na̱chrjein mé‑ne nga ko̱ma kéno̱jmíya‑là jñà xi̱ta̱ xi sko̱nanguiya‑nò i̱t'aà ts'e̱ kjoa̱ xi titsa̱chiñá‑là i̱t'aà ts'e̱ Cristo.
\v 16 K'e̱ nga ki̱nókjoa̱a, indaàkjoa̱ t'e̱en. Cha̱xkón jñà xi kéno̱jmíya‑là, tsjeè kàtìjna kjo̱hítsjeèn‑nò, mé‑ne jñà xi̱ta̱ xi ch'o chja̱jno‑nò nga ndaà 'nè nga mokjeiín‑nò i̱t'aà ts'e̱ Cristo, ko̱sobà‑la̱ nga jñò chja̱jno‑nò.
\v 17 Ìsa̱á ndaà tjín tsà ko̱s'ín mejèn‑la̱ Nainá nga kjo̱'in si̱kjioón k'e̱ nga ndaà 'nè, mì k'oa̱‑ne tsà k'e̱ nga ch'o 'nè.
\p 
\v 18 Nga skanda jè Cristo, jngoò k'aá kisìkjeiín kjo̱'in k'e̱ nga k'en xi kjoa̱ ts'e̱ jé‑ná. Cristo, mìtsà jé tsohótsji; xi̱ta̱ kixi̱‑né; kisìkjeiín kjo̱'in i̱t'aà ts'e̱ xi̱ta̱ xi jé tjín‑la̱ mé‑ne nga ko̱ma kji̱ko̱‑ná nguixko̱n Nainá. Yijo‑la̱, jñà xi̱ta̱ kisìk'en, ta̱nga i̱t'aà ts'e̱ Ini̱ma̱‑la̱ jaáya ìjngoò k'a‑la̱.
\v 19 Ko̱ jè Ini̱ma̱‑la̱ Cristo kiì i̱'nde ñánda títsa̱jna ini̱ma̱ xi títsa̱jnaya nda̱yá nga kiìchja̱yajiìn‑la̱.
\v 20 Ini̱ma̱ koi, ts'e̱é xi̱ta̱ xi mìkiì kiì'nchréñijon‑la̱ Nainá na̱chrjein ts'e̱ Noé. Nainá tseé kiskoòñà kjoa̱ k'e̱ nga Noé tsibíndaà chitso je. Ya̱ i̱ya chitso, tà jiìn ma‑ne xi̱ta̱ xi itjokàjiìn kjo̱'in nga mìkiì k'en k'e̱ nga ts'a jtsí xkón.
\v 21 Ko̱ jè nandá ts'e̱ jtsí xkón, jè ngaya‑la̱ nandá xi ma‑ná bautizar na̱chrjein i̱'ndei̱ nga bitjokàjñaá kjo̱'in. Ta̱nga nga maá bautizar, mìtsà yijo‑ná matsjeè‑ne, jè‑né nga nìjét'aà‑lá Nainá nga tsjeè kàtas'e kjo̱hítsjeèn‑ná. Ko̱ bitjokàjñaá kjo̱'in, koií kjoa̱‑la̱ nga jaáya‑la̱ Cristo,
\v 22 ko̱ kiì mijìn ján ngajmiì nga ya̱ tíjnat'aà chrja kixi̱‑la̱ Nainá. Jé tíhotíxoma‑la̱ àkja̱le̱ ko̱ ini̱ma̱ xi tjín‑la̱ kjo̱tíxoma ko̱ ngats'iì xi tjín‑la̱ nga'ñó.
\c 4
\p 
\v 1 Cristo, koni s'ín kisìkjeiín kjo̱'in yijo‑la̱, jñò, ti̱koa̱á mochjeén‑né nga ki̱tsa̱jnandaà nga si̱kjioón kjo̱'in. Nga̱ jè xi jye kisìkjeiín kjo̱'in, ya̱á jyehet'aà jé‑la̱,
\v 2 mé‑ne jñà na̱chrjein xi kíjna ìsa̱ i̱sò'nde, k'oa̱á s'ín kàtìjna koni s'ín mejèn‑la̱ Nainá, mìtsà k'oa̱s'ín kíjna koni s'ín mejèn‑la̱ yijo‑la̱.
\v 3 Jyeé 'ñó kjìn na̱chrjein kinìkato nga ch'o ki'nè koni s'ín xi̱ta̱ xi mìkiì beèxkon Nainá. K'oa̱á s'ín kinìko̱ò yijo‑nò kjoa̱ xi ch'o tjín koni kjoa̱ chijngui, kjoa̱ ch'o xi síjé yijo‑nò, ko̱ kjoa̱ ch'i̱, kjoa̱ ts'e̱ s'eí xi ch'o tjín, ko̱ nga ta xán ki'yò kjit'aà, ko̱ nga xkósòn kiyaxkón nga mìtsà kixi̱ kjoa̱ nga Nainá.
\v 4 I̱'ndei̱ jñà xi̱ta̱ koi, ta maxkón‑la̱ i̱t'aà tsa̱jòn nga mì ti̱ kiì ya̱ tsjahijtako̱‑nò kjoa̱ xi ch'o tjín; bijnòkeè‑nò; ch'oó chja̱jno‑nò.
\v 5 Ta̱nga jñà xi̱ta̱ koi, tjínè‑la̱ nga tsjá‑la̱ kinda̱ Nainá; jè Nainá xi tíjnandaà nga koi̱ìndaàjiìn‑la̱ xi̱ta̱ xi títsa̱jnakon ko̱ xi jye k'en.
\v 6 Koií kjoa̱‑la̱ nga k'oa̱ ti̱s'ín kis'eno̱jmí‑la̱ 'én ndaà‑la̱ Nainá xi kjoa̱ ts'e̱ Cristo jñà xi̱ta̱ xi jye k'en, mé‑ne na̱s'ín jñà yijo‑la̱ kisìkjeiín kjo̱'in koni s'ín bìndaàjiìn xi̱ta̱ i̱sò'nde, ta̱nga jñà ini̱ma̱‑la̱ títsa̱jnakon‑né ni̱ta̱ kjé‑ne koni s'ín tíjnakon kjit'aà Nainá.
\p 
\v 7 Jyeé tímachrañà nga kjoe̱het'aà i̱sò'nde, koií kjoa̱‑la̱ jñò, ndaà titsa̱jnako̱o kjo̱hítsjeèn‑nò; kjit'aà na̱chrjein tìtsi'ba‑là Nainá.
\v 8 Jè xi tíjna ítjòn, jè‑né nga 'ñó tjòcha t'e̱en xinguio̱o. Tsà tjín‑nò kjoa̱tjòcha, ko̱maá si̱jchàat'aà‑là jé‑la̱ xinguio̱o.
\v 9 Chjoétjò xi̱ta̱ xinguio̱o k'e̱ nga bijchókon‑nò tsà mejèn‑la̱ nga si̱ìkjáya ya̱ ni'ya‑nò. Tsja t'è‑là ini̱ma̱‑nò; kì ch'o chibàya‑nò.
\v 10 Nga jngoò ìjngoò, koni s'ín tjín kjo̱ndaà xi kitsjaà‑nò Nainá, k'oa̱s'ín ti̱si̱ko̱ò xinguio̱o nga ndaà ti̱chjeén, nga kjìn sko̱ya tjín‑ne kjo̱ndaà xi kitjoé‑nò.
\v 11 Jè xi̱ta̱ xi k'oa̱s'ín kits'iì‑la̱ nga 'én‑la̱ Nainá ki̱chja̱ya, k'oa̱á s'ín kàtìchja̱ya koni tsò 'én‑la̱ Nainá. Ko̱ jè xi̱ta̱ xi k'oa̱s'ín kits'iì‑la̱ nga si̱ìxá, k'oa̱á s'ín kàtasíxá koni tjín nga'ñó xi tsjá‑la̱ Nainá. Ni̱ta̱ mé xi s'e̱en, k'oa̱á s'ín t'e̱en mé‑ne nga i̱t'aà ts'e̱ Jesucristo jeya kíjna‑ne Nainá. Nga ts'e̱é Cristo jè kjoa̱jeya ko̱ ngats'iì nga'ñó xi tjín skanda ni̱ta̱ kjé‑ne. K'oa̱s'ín kàtama.
\s1 Si̱kjiaán kjo̱'in nga xi̱ta̱‑la̱ Cristo 'mì‑ná
\p 
\v 12 Jñò ndí 'ndsè xi matsjake̱‑nò, kì maxkón‑nò nga 'ñó 'in tjín kjoa̱ xi nchrobánè‑nò nga tíchìt'aà‑nò.
\v 13 Ta̱ sa̱á kàtas'e‑nò kjo̱tsja nga tíhoko̱ chiba‑nò kjo̱'in ts'e̱ Cristo, mé‑ne nga ti̱koa̱ s'e̱‑nò kjo̱tsja k'e̱ nga jcha̱‑la̱ kjoa̱jeya‑la̱ Cristo.
\v 14 Jñò, mé ta ndaà‑nò k'e̱ nga tsà xi̱ta̱ ko̱tít'aà‑nò xi kjoa̱ ts'e̱ Cristo nga jè kjoa̱jeya‑la̱ Ini̱ma̱ Tsjeè‑la̱ Nainá ya̱á tíjnako̱‑nò.
\v 15 Tsà kjo̱'in titsa̱nìkjioón, chítsejèn‑là yijo‑nò, a koií kjoa̱‑la̱ nga ch'o 'nè, nga xi̱ta̱ nìk'eèn, nga chijé 'nè, nga chingájiìn chingá'a kjoa̱. Kì k'oa̱á tjín jé xi binchaàtsjioò.
\v 16 Ta̱nga tsà kjo̱'in titsa̱nìkjioón nga xi̱ta̱‑la̱ Cristo maá, kì masobà‑nò; ta sa̱á jeya ti̱kíjna Nainá nga xi̱ta̱‑la̱ tsò‑nò.
\p 
\v 17 Jyeé ijchò na̱chrjein nga ko̱ts'ia̱ nga si̱ndaàjiìn‑la̱ xi̱ta̱ na̱xa̱ndá‑la̱ Nainá. Tsà jñá tímats'ia̱ ítjòn ko̱‑ná, ¿mé xi ko̱mat'in jñà xi̱ta̱ xi mìkiì síkitasòn 'én ndaà‑la̱ Nainá?
\q1 
\v 18 Jè xi xi̱ta̱ kixi̱, chjá ko̱ma‑la̱ nga ki̱tjokàjiìn kjo̱'in.
\q1 ¿Kós'ín ko̱mat'in jñà xi̱ta̱ xi mìkiì beèxkón Nainá ko̱ xi jé ótsji?
\p 
\v 19 K'oa̱á ma‑ne, jñà xi̱ta̱ xi kjo̱'in síkjeiín nga ko̱s'ín mejèn‑la̱ Nainá, kì bíkjoàn‑la̱ nga ndaà s'ín. Jè Nainá kàta'ñót'aà takòn nga jè kàtasíkinda̱, nga jè tsibíndaà jñà xi̱ta̱ ko̱ jè síkitasòn‑né koni s'ín tsjá tso'ba.
\c 5
\s1 Jñà xi̱ta̱ jchínga xi xá ítjòn tjín‑la̱ ya̱ na̱xa̱ndá‑la̱ Nainá
\p 
\v 1 Sìjét'aà‑la̱ jñà xi̱ta̱ jchínga xi xá ítjòn tjín‑la̱ nga ya̱ síxájiìn‑nò ya̱ na̱xa̱ndá‑la̱ Nainá. Ti̱koa̱á 'a̱n, xi̱ta̱ jchínga‑ná nga xá ítjòn tjín‑na koni jñà xi̱ta̱ koi; kìjtseè‑ná kjo̱'in xi kis'e‑la̱ Cristo; ti̱koa̱á s'e̱é‑na kjoa̱jeya xi i̱skan jcha̱‑la̱.
\v 2 Ti̱kinda̱a jñà xi̱ta̱‑la̱ Nainá xi jñò kjònga̱tsja koni tsà orrè; kì kjo̱'ñó 'nè‑là yijo‑nò; ko̱ó kjo̱ndaà‑nò nga ti̱kinda̱a koni s'ín mejèn‑la̱ Nainá. Mìtsà koií kjoa̱ nga tse to̱n si̱kijneè. Tà ko̱ó kjo̱tsja‑nò nga k'oa̱ t'e̱en.
\v 3 Kì yatoòn‑jèn jñà xi̱ta̱ xi jñò manga̱tsja koni tsà nei‑la̱ ma. Jñò ti̱ncha ítjòn‑là, ta̱kó‑la̱ ndi̱yá‑la̱ Nainá mé‑ne ko̱ma skíngui‑nò.
\v 4 Mé‑ne k'e̱ nga kjoi̱í ìjngoò k'a jè Paxtò ítjòn, tjoé‑nò kjoa̱jeya‑la̱ Nainá koni jngoò corona xi mìkiì fehejno ote‑la̱ ni̱ta̱ kjé‑ne.
\p 
\v 5 Ti̱koa̱ jñò xi i̱xti xo̱ngó 'mì‑nò, ti̱kitasòn‑là jñà xi̱ta̱ jchínga xi otíxoma ya̱ i̱jiìn na̱xa̱ndá‑la̱ Nainá. Ngats'ioò, indaàkjoa̱ tanguíko̱o xinguio̱o, nga:
\q1 Jè Nainá kondra̱á tíjna‑la̱ jñà xi̱ta̱ xi 'nga ikon;
\q1 koa̱ jñà xi̱ta̱ xi indaàkjoa̱ tjín ini̱ma̱‑la̱, tsjá‑la̱ kjo̱ndaà.
\m 
\v 6 Nangui titsa̱jna‑là Nainá nga tse nga'ñó tjín‑la̱ koni s'ín síko̱‑nò, mé‑ne k'e̱ nga ki̱jchò na̱chrjein jè Nainá 'nga si̱ìkítsa̱jna‑nò.
\v 7 Tsja Nainá ti̱kítsa̱jnaya ngats'iì kjoa̱ xi makájno‑nò nga jè tísíkinda̱‑nò.
\p 
\v 8 Ti̱kinda̱a yijo‑nò, kjit'aà na̱chrjein titsa̱jnandaà, nga jè xi̱ta̱ nei̱í xi kondra̱‑nò, k'oa̱á s'ín tsóbandiì‑nò k'oa̱á ngaya‑la̱ koni jngoò xa xi tíkjindáya nga 'ñó ijò‑la̱, nga tíhótsji yá xi ski̱ne̱.
\v 9 Nga ndaà mokjeiín‑nò, 'ñó ti̱ncha‑là xi̱ta̱ nei̱í. Nga jyeé tíjiìn‑nò nga jñà xi̱ta̱ xinguio̱o xi títsa̱jna nga tíjtsa i̱sò'nde, ti̱koa̱á k'oa̱á tjín kjo̱'in xi nchisíkjeiín.
\v 10 K'e̱ nga jye ko̱to chiba na̱chrjein nga titsa̱nìkjioón kjo̱'in, jè sobà Nainá si̱ìndaàya‑nò, si̱ìkíjnandaà‑nò, tsjá‑nò nga'ñó, ko̱ kixi̱ si̱ìkítsa̱jna‑nò. Ti̱jé‑ne Nainá xi ko̱ kjoa̱tjòcha‑la̱ kiìchja̱‑ná nga s'e̱‑ná kjoa̱jeya‑la̱ ni̱ta̱ kjé‑ne nga Jesucristo titsa̱jnakoa̱á.
\v 11 Ts'e̱é Nainá ngats'iì nga'ñó xi tjín skanda ni̱ta̱ kjé‑ne. K'oa̱s'ín kàtama.
\s1 Xi fehet'aà‑ne, Pedro síhixat'aà xi̱ta̱
\p 
\v 12 Silvano, xi 'ndsè xan‑la̱, nga kixi̱ tjín xá‑la̱, jè kisìchját'aà‑na nga kiskiì‑nò xo̱jo̱n carta jè. K'oa̱á s'ín tìbìnè‑nò ko̱ tìsìkixi̱ya‑nò nga ngats'iì 'én xi tìsìkasén‑nò, nguì k'oa̱á s'ín tjín kjo̱ndaà‑la̱ Nainá. Kixi̱ titsa̱jnako̱o kjo̱ndaà koi.
\p 
\v 13 Nchisíhixat'aà‑nò jñà xi̱ta̱ na̱xa̱ndá‑la̱ Cristo xi i̱ títsa̱jna Babilonia xi xó ta̱ña kitjaàjiìn‑nò. Ko̱ jè Marcos xi ki'ndí‑na̱ xan‑la̱ i̱t'aà ts'e̱ Cristo, ti̱koa̱á tísíhixat'aà‑nò.
\v 14 Ti̱ixot'aà xinguio̱o nga nguì ko̱ ini̱ma̱‑nò.
\p Kàtas'e‑la̱ kjoa̱'nchán i̱jiìn ini̱ma̱‑nò ngats'ioò xi ya̱ nokjoà‑nò i̱t'aà ts'e̱ Cristo. K'oa̱s'ín kàtama.
