\v 4  \w They|strong="H3808"\w* \w must|strong="H3808"\w* \w join|strong="H3867"\w* \w with|strong="H5921"\w* \w you|strong="H3605"\w*, \w and|strong="H7126"\w* \w they|strong="H3808"\w* \w will|strong="H3808"\w* \w be|strong="H3808"\w* responsible \w for|strong="H5921"\w* \w the|strong="H3605"\w* \w care|strong="H4931"\w* \w of|strong="H5921"\w* \w the|strong="H3605"\w* tent \w of|strong="H5921"\w* \w meeting|strong="H4150"\w*, \w for|strong="H5921"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w service|strong="H5656"\w* \w of|strong="H5921"\w* \w the|strong="H3605"\w* tent, \w but|strong="H3808"\w* \w no|strong="H3808"\w* \w unauthorized|strong="H2114"\w* \w person|strong="H7126"\w* \w may|strong="H3808"\w* \w approach|strong="H7126"\w* \w you|strong="H3605"\w*.  
\v 5  \w You|strong="H5921"\w* \w will|strong="H1961"\w* \w be|strong="H1961"\w* responsible \w for|strong="H5921"\w* \w the|strong="H5921"\w* \w care|strong="H4931"\w* \w of|strong="H1121"\w* \w the|strong="H5921"\w* \w sanctuary|strong="H6944"\w* \w and|strong="H1121"\w* \w the|strong="H5921"\w* \w care|strong="H4931"\w* \w of|strong="H1121"\w* \w the|strong="H5921"\w* \w altar|strong="H4196"\w*, \w so|strong="H1961"\w* \w that|strong="H3478"\w* \w there|strong="H1961"\w* \w will|strong="H1961"\w* \w be|strong="H1961"\w* \w no|strong="H3808"\w* \w more|strong="H5750"\w* \w wrath|strong="H7110"\w* \w on|strong="H5921"\w* \w the|strong="H5921"\w* \w Israelites|strong="H3478"\w*.  
\v 6  \w I|strong="H5414"\w* myself \w have|strong="H3068"\w* \w chosen|strong="H3947"\w* \w your|strong="H3068"\w* \w brothers|strong="H1121"\w* \w the|strong="H5414"\w* \w Levites|strong="H3881"\w* \w from|strong="H3478"\w* \w among|strong="H8432"\w* \w the|strong="H5414"\w* \w Israelites|strong="H3478"\w*. \w They|strong="H3068"\w* \w are|strong="H1121"\w* \w given|strong="H5414"\w* \w to|strong="H3478"\w* \w you|strong="H5414"\w* \w as|strong="H3068"\w* \w a|strong="H3068"\w* \w gift|strong="H4979"\w* \w from|strong="H3478"\w* \w the|strong="H5414"\w* \nd \+w Lord|strong="H3068"\+w*\nd*, \w to|strong="H3478"\w* \w perform|strong="H5647"\w* \w the|strong="H5414"\w* duties \w of|strong="H1121"\w* \w the|strong="H5414"\w* tent \w of|strong="H1121"\w* \w meeting|strong="H4150"\w*.  
