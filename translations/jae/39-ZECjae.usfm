\id ZEC -Jabem partial Bible [jae] -Papua New Guinea 1980 (web 2015) 
\h SAKARIA 
\toc1 Sakaria 
\toc2 Sakaria 
\toc3 Sak 
\mt1 Sakaria  
\ip Sakarianê buku gêwa tau kêkôc gêja ŋasêbu luagêc gebe  
\ili1 1. Môkêlatu 1-8 Sakaria katu kaiŋ teŋ kêsa e gêlic ŋakatu ma geoc biŋ lasê gêdêŋ jala 520-518 gêmuŋ Kilisi gêmêŋ nomŋa ŋasawa. Eŋ gêlêŋ biŋ lau gebe sêkwê Jerusalem to ŋalôm dabuŋ sa êtiam ma sênam tauŋ ôkwi têtu selec. Ma eŋ geoc lasê gebe Mesianê têm kêdabiŋ.  
\ili1 2. Môkêlatu 9-14 Lau taŋ sêkip Bibolo ŋam sa naŋ, nêŋ ŋagêdô sêsaê gebe biŋ, taŋ kêsêp môkêlatu tonec naŋ, lau teŋ teto. Êsêac sêjac têku Sakarianê biŋ ma sêsôm biŋ kêpi Mesianê têm to têm ŋamuŋa lasê.  
\c 2  
\s1 Sion ênam lasê êtu Apômtauŋa  
\p
\v 10 Sion latuo, ônam lasê to têmtac wapigeŋ gebe aê oc wacjaŋgôŋ aôm ŋaluŋ. Apômtau kêsôm amboac tonaŋ.  
\v 11 Êndêŋ bêc tônê tenteŋlatu gwalêkiŋ oc sêmbiŋ tauŋ tôŋ dêndêŋ Apômtau ma têtu aêŋoc laugeŋ, ma wacsêŋgôŋ aôm ŋaluŋgeŋ.  
\v 12 Ocgo ôjala gebe lausiŋ undambêŋa nêŋ Apômtau kêsakiŋ aê gawac. Ma Apômtau oc êkôc lau Juda sa têtu ênê gêŋlênsêm sêmoa gamêŋ dabuŋ ma êjaliŋ Jerusalem tau sa êtiam.”  
\v 13 Ŋamalac pebeŋ sênam tauŋ tôŋ jamaŋgeŋ sêkô Apômtau laŋônêm gebe eŋ gêdi aŋga gamêŋ dabuŋ taugoc.   
\c 9  
\s1 Kiŋ ŋamuŋa oc ênam nê lau sa  
\q1
\v 9 Ôtu samuc, o Sion latuo.  
\q1 Ônam lasê, o Jerusalem latuo.  
\q1 Gôlicgac me, nêm kiŋ gêdêŋ aôm gêwac.  
\q1 Eŋ ŋac gêdêŋ to gêjam sa.  
\q1 Ŋac malô jagêŋgôŋ doŋki teŋ,  
\q1 gêŋgôŋ bôc wabaŋa ŋalatu ŋaô.   
\q1
\v 10 “Aê oc janseŋ kareta siŋŋa su aŋga Epraim  
\q1 ma hos siŋŋa aŋga Jerusalem.  
\q1 Aê oc japôŋ talam siŋŋa tulu  
\q1 ma eŋ oc êjatu biŋmalôŋa êndêŋ tenteŋlatu samob.  
\q1 Ma nê gamêŋ kiŋŋa oc ênêc aŋga gwêc teŋ e êndêŋ gwêc teŋ,  
\q1 ma aŋga bu (Euprat) tau e êndêŋ nom ŋamadiŋ tau.   
\b  
\q1
\v 11 “Ma kêtu aômŋa, kêtu poac decŋa, taŋ kamoatiŋ gêdêŋ aôm naŋ,  
\q1 aê oc jaŋgamboac nêm lau kapoacwalôŋa, taŋ sêŋgôŋ sê sawa bu masiŋa naŋ su.   
\q1
\v 12 Amboac tonaŋ amac lau kapoacwalôŋa, taŋ akêŋ matem naŋ, amu andêŋ nêm lamu ŋaŋêŋŋa amêŋ.  
\q1 Ocsalô tonec aê jasôm lasê gebe jajô nêm gêŋ êtu dim luagêc êndêŋ aôm.   
\q1
\v 13 Gebe aê kakêkam Juda amboac ŋoc talam  
\q1 ma kakêŋ Epraim kêkô tikoc.  
\q1 O Sion, aê kajatu latômi gebe sênac lau Grik nêŋ latui.  
\q1 Aê jakam aôm amboac siŋwaga kêmêgôm nê siŋ.”   
\b  
\q1
\v 14 Êndêŋ tonaŋ Apômtau oc êô lasê êndêŋ êsêac  
\q1 ma nê sôb oc êlôp amboac ôsic.  
\q1 Apômtau Anôtô oc ênac dauc êtaŋ  
\q1 ma êmêŋ amboac mu ilai, taŋ gêmêŋ aŋga gêmu kêsêpŋa naŋ.   
\q1
\v 15 Lausiŋ undambêŋa nêŋ Apômtau oc ejop êsêac  
\q1 ma êsêac oc sêndaŋgôŋ lau dabaŋŋa  
\q1 ma sênôm nêŋ dec amboac wain  
\q1 e têntac êkôc amboac suc mêŋgêc, ŋawambuc kêsa amboac altar ŋakêclêsu.   
\b  
\q1
\v 16 Êndêŋ bêc tonaŋ nêŋ Apômtau Anôtô oc ênam êsêac kêsi.  
\q1 Eŋ oc ejop êsêac amboac gejobwaga gejob bôc ŋatoŋ teŋ  
\q1 gebe êsêacnêŋ ŋawê oc êpô ênê gamêŋ  
\q1 amboac sunsuŋ pocawa gêwê kô.   