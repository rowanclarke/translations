\id JOS - Biblica® Open Igbo Contemporary Bible 2020 
\h Joshua 
\toc1 Joshua 
\toc2 Joshua 
\toc3 Jos 
\mt1 Joshua 
\c 1  
\s1 Iwu \nd Onyenwe anyị\nd* nyere Joshua 
\p  
\v 1 Mgbe Mosis, bụ odibo \nd Onyenwe anyị\nd* nwụrụ, \nd Onyenwe anyị\nd* gwara Joshua nwa Nun, onye na-enyere Mosis aka okwu sị,  
\v 2 “Mosis, odibo m anwụọla.\f + \fr 1:2 \ft \xt Ọnụ 12:7\f* Ugbu a, jikere onwe gị,\f + \fr 1:2 \ft Nʼoge a, ndị Izrel nọ na Shitim \xt Jos 2:1; 3:1\ft  nʼala Moab \xt Dit 34:3\ft  dị nʼakụkụ Jọdan.\f* meekwa ka ndị m jikere ịgafe ofe ọzọ nke osimiri Jọdan, ịbanye nʼala ahụ m na-aga inye ha, bụ ndị Izrel.  
\v 3 Ana m agwa gị ihe m gwara Mosis mgbe ọ dị ndụ sị, Ebe ọbụla unu ga-azọkwasị ụkwụ unu nʼala, ala ahụ ga-abụ nke unu.  
\v 4 Oke ala unu ga-abụ site nʼọzara dị na ndịda ruo Lebanọn, ma site nʼiyi ukwu Yufretis, tinyere ala niile nke ndị Het, ruo nʼosimiri ukwu ahụ dị nʼọdịda anyanwụ.  
\v 5 Ọ dịghị onye ọbụla pụrụ iguzo imegide gị ụbọchị niile nke ndụ gị.\f + \fr 1:5 \ft \xt Dit 7:24\f* Aga m anọnyere gị dịka m si nọnyere Mosis.\f + \fr 1:5 \ft \xt Ọpụ 3:12; Dit 31:8,23\f* Agaghị m ahapụ gị aka. Agaghị m agbakụtakwa gị azụ.\f + \fr 1:5 \ft \xt Dit 31:6,8; Hib 13:5\f* 
\v 6 Dịrị ike, nweekwa ume, nʼihi na ị ga-abụ onye ga-edu ndị a iketa ala ahụ m ṅụrụ nʼiyi inye nna nna ha ochie. 
\p  
\v 7 “Naanị dịrị ike, nweekwa ume. Lezie anya ime ihe niile Mosis bụ odibo m nyere gị nʼiwu. Ewezugala onwe gị na ya gaa aka nri maọbụ aka ekpe, ka ihe si otu a gaara gị nke ọma nʼebe ọbụla ị na-aga.  
\v 8 Esitela nʼọnụ gị wezuga ihe dị nʼAkwụkwọ Iwu a. Kama na-atụgharị uche gị na ya ehihie na abalị, ka i si otu a lezie anya imezu ihe niile e dere nʼime ya. Mgbe ahụ ị ga-aba ụba, ihe ga-agakwara gị nke ọma.  
\v 9 Ọ bụ na m enyebeghị gị iwu sị gị, Nwee obi ike, dịrịkwa ike! Wezuga ụjọ niile na ịda mba nke obi. Cheta na mụ, bụ \nd Onyenwe anyị\nd* Chineke gị, nọnyeere gị ebe ọbụla ị na-aga.” 
\p  
\v 10 Mgbe ahụ, Joshua nyere ndịisi Izrel niile iwu sị ha,  
\v 11 “Jegharịanụ nʼetiti ebe obibi ụmụ Izrel gwa mmadụ niile okwu sị ha ‘Dozierenụ onwe unu ihe unu ga-eri nʼụzọ, nʼihi na nʼime ụbọchị atọ, anyị ga-agafe osimiri Jọdan, imeri na inweta ala ahụ \nd Onyenwe anyị\nd* bụ Chineke na-enye unu.’ ” 
\p  
\v 12 Joshua kpọkọtara ndịisi ebo Ruben, na Gad, na ọkara ebo Manase, gwa ha okwu sị,  
\v 13 “Chetanụ iwu ahụ Mosis odibo \nd Onyenwe anyị\nd* nyere unu, mgbe ọ sịrị, ‘\nd Onyenwe anyị\nd* Chineke unu na-enye unu izuike. O nyekwala unu ala a.’  
\v 14 Kama ndị nwunye unu, na ụmụntakịrị unu, na anụ ụlọ unu, ga-anọ nʼala a dị nʼọwụwa anyanwụ nke Mosis nyere unu. Ma ndị agha unu, ndị jikeere ejike, ga-eduru ndị Izrel ndị ọzọ gafee osimiri Jọdan inyere ụmụnna ha aka,  
\v 15 tutu ruo mgbe \nd Onyenwe anyị\nd* Chineke unu nyere ha izuike, dịka o si nye unu, na tutu ruo mgbe ha nwetara ala niile bụ nke \nd Onyenwe anyị\nd* Chineke unu ga-enye ha. Mgbe nke a mezuru, unu ga-alaghachi azụ, nweta ala ahụ Mosis onyeozi \nd Onyenwe anyị\nd* nyere unu nʼakụkụ ọwụwa anyanwụ osimiri Jọdan.” 
\p  
\v 16 Mgbe ahụ, ha zara Joshua, “Ihe ọbụla nke ị nyere anyị nʼiwu anyị ga-eme ha, ebe ọbụla i zigara anyị ka anyị ga-aga.  
\v 17 Anyị ga-ege gị ntị dịka anyị si gee Mosis ntị. Ka \nd Onyenwe anyị\nd* Chineke gị nọnyere gị dịka o si nọnyere Mosis.  
\v 18 Onye ọbụla nupuru isi nʼiwu i nyere anyị, ọ ga-anwụ. Naanị dịrị ike, nweekwa obi ike.” 
\c 2  
\s1 Rehab na ndị Nnyopụta 
\p  
\v 1 Joshua nwa Nun sitere na Shitim zipụ ndị nnyopụta abụọ na nzuzo sị ha, “Gaanụ leta otu ihe si aga nʼala ahụ, karịsịa nʼobodo Jeriko.”\f + \fr 2:1 \ft Jeriko bụ obodo ochie e wuru nke ọma, wusikwaa ike. Obodo e ji mgbidi e wusiri ike gbaa gburugburu, nke ọtụtụ iyi, tinyekwara osimiri gbara gburugburu. \xt Jos 15:1-6\ft  E wuru ya ka o nwee ike ịnagide atụmatụ ọbụla nke ndị iro na-atụ, maka ịba nʼime ya. O ruru ihe dịka kilomita asatọ ma a na-aga nʼakụkụ ọdịda anyanwụ nke osimiri Jọdan, bụrụkwa ụzọ dị oke mkpa a ga-eji baa nʼala nkwa ahụ.\f* Ha gara nʼobodo ahụ baa nʼụlọ nwanyị akwụna aha ya bụ Rehab nọọ ọnọdụ nʼebe ahụ. 
\p  
\v 2 Ma otu onye gwara eze Jeriko okwu sị, “Lee, ụfọdụ ụmụ ndị ikom Izrel batara obodo a nʼabalị inyochapụta ala anyị.”  
\v 3 Mgbe eze Jeriko nụrụ okwu a, o zigaara Rehab ozi sị, “Kpọpụta ndị ikom ahụ batara nʼụlọ gị nʼihi na ha bịara iledo ala anyị.” 
\p  
\v 4 Ma nwanyị ahụ zoro mmadụ abụọ ahụ. Mgbe ndị ahụ e ziri ozi bịarutere, ọ gwara ha okwu sị, “Ọ bụ eziokwu na ndị ikom ahụ bakwutere m, ma amaghị m ebe ha si bịa.  
\v 5 Ma ha apụọlarị. Ha hapụrụ obodo a mgbe a na-achọ imechi ọnụ ụzọ ama, nʼoge ọchịchịrị bidoro ịgba. Amaghị m ebe ha gara. Ma, nʼuche m, ọ bụrụ na unu achụso ha ọsọ ọsịịsọ unu nwere ike ijide ha.”  
\v 6 (Nʼeziokwu ọ bụ Rehab nʼonwe ya mere ka mmadụ abụọ ahụ rigoro nʼelu ụlọ ebe o zoro ha nʼokpuru ahịhịa flakisi ọ wụsara nʼebe ahụ.)  
\v 7 Ya mere, ndị ikom ahụ pụrụ na-achụ ndị nnyopụta ahụ nʼakụkụ ụzọ gara ngabiga Jọdan. Ma ngwangwa ha pụrụ, e mechiri ọnụ ụzọ ama e si abata obodo ahụ. 
\p  
\v 8 Ma tupu ndị nnyopụta ahụ edina ala ịrahụ ụra nʼabalị ahụ, Rehab rịgokwuru ha,  
\v 9 gwa ha sị, “Ama m na \nd Onyenwe anyị\nd* enyela unu ala a,\f + \fr 2:9 \ft \xt Jen 35:5\f* marakwa na oke ụjọ nke egwu unu adakwasịla anyị, nke mere na ndị niile bi nʼime ala a na-agbaze nʼegwu nʼihi unu,  
\v 10 nʼihi na anyị anụla otu \nd Onyenwe anyị\nd* si mee ka mmiri dị nʼOsimiri Uhie taa nʼihi unu, mgbe unu si nʼIjipt pụta. Anyị nụkwara ihe unu mere Saịhọn, na Ọg, bụ eze abụọ ndị Amọrị, ndị bi nʼọwụwa anyanwụ osimiri Jọdan, otu unu si bibie ha, gbuchapụ ndị niile bi nʼala ahụ.  
\v 11 Ma mgbe anyị nụrụ ihe ndị a, obi anyị gbazere nʼihi ụjọ, mmụọ onye ọbụla dara mba nʼihi unu, nʼihi na \nd Onyenwe anyị\nd* Chineke unu bụ Chineke nʼeluigwe na nʼụwa. 
\p  
\v 12 “Ugbu a, ebe ọ bụ na m emeelara unu ebere, jirinụ \nd Onyenwe anyị\nd* ṅụọrọ m iyi na unu ga-emere ezinaụlọ m ebere. Gosinụ m ihe ịrịbama nʼeziokwu,  
\v 13 na unu ga-emekwa ka ndụ nna m, na nne m, na ụmụnne m ndị ikom na ndị inyom, na ndị ezinaụlọ ha niile dịrị, na unu ga-anapụta anyị site nʼọnwụ.” 
\p  
\v 14 Ndị ikom ahụ kwere ya nkwa sị, “Ndụ anyị lara ndụ unu. Ọ bụrụ na ị gbaghị anyị ama, anyị ga-egosi gị obi ebere na ikwesi ntụkwasị obi mgbe \nd Onyenwe anyị\nd* ga-enye anyị ala a.” 
\p  
\v 15 Ụlọ Rehab dị nʼakụkụ mgbidi obodo ahụ. O ji ụdọ site na oghereikuku wedata ndị ikom abụọ ahụ.  
\v 16 Ọ gwakwara ha sị, “Gbalaganụ nʼugwu, zoonụ onwe unu nʼebe ahụ ụbọchị atọ, tutu ndị ahụ na-achọ unu alaghachi azụ. Mgbe ahụ, unu nwere ike ịpụta laghachi ebe unu si bịa.” 
\p  
\v 17 Ndị ahụ gwara ya sị, “Iyi a i mere ka anyị ṅụọ agaghị adị ire megide anyị,  
\v 18 ma ọ bụrụ na nʼụbọchị ahụ anyị ga-abata ala a, i wereghị ụdọ ahụ na-acha uhie uhie kenye ya na oghereikuku i si wedata anyị, ma ọ bụrụkwa na ịkpọbataghị nʼụlọ gị nna gị, na nne gị, na ụmụnne gị ndị ikom, na ndị ezinaụlọ gị niile.  
\v 19 Ọ bụrụ na onye ọbụla esite nʼụlọ gị pụọ nʼezi, ọbara ya agaghị adị anyị nʼisi, anyị agaghị abụkwa ndị ikpe mara. Ma ikpe ọmụma dịrị anyị ma ọ bụrụ nʼihe ọbụla emee onye ọbụla gị na ya so nọdụ nʼime ụlọ.  
\v 20 Ma ọ bụrụ na ị gbaa anyị ama, ọ dịkwaghị iwu ji anyị imezu iyi a i mere ka anyị ṅụọrọ gị.” 
\p  
\v 21 Rehab zara sị ha, “Dịka okwu niile unu kwuru si dị, otu a ka ọ ga-adị.” 
\p O zilagara ha. Ha pụkwara gaara onwe ha. Ma Rehab kekwasịrị ụdọ uhie uhie ahụ nʼọnụ oghereikuku ụlọ ya. 
\p  
\v 22 Ndị ikom abụọ ahụ gara zoo onwe ha nʼugwu ahụ. Ha nọrọ ụbọchị atọ nʼebe ahụ dịka Rehab gwara ha, tutu ndị ahụ na-achụ ha laghachiri nʼobodo Jeriko. Ndị a chọọrọ ha gaa ebe niile, nʼokporoụzọ niile, ma ha ahụghị ha.  
\v 23 Emesịa, mmadụ abụọ ahụ e zipụrụ iledo ala ahụ anya sitere nʼebe ha zoro onwe ha rịpụta, gafee osimiri Jọdan, laghachi nʼebe ụmụ Izrel nọ. Ha bịara kọọrọ Joshua nwa Nun otu ha si gaa ije ha.  
\v 24 Ha gwara Joshua sị, “Nʼezie, \nd Onyenwe anyị\nd* enyela anyị ala ahụ niile, nʼihi na ndị niile bi nʼala ahụ na-atụ anyị ụjọ.” 
\c 3  
\s1 Ngabiga osimiri Jọdan 
\p  
\v 1 Nʼisi ụtụtụ, Joshua na ụmụ Izrel niile hapụrụ Shitim bịaruo nʼakụkụ osimiri Jọdan, maa ụlọ ikwu nʼebe ahụ. Nʼebe a ka ha nọ chere tutu ruo mgbe ha ga-agafe.  
\v 2 Mgbe ụbọchị atọ gasịrị, ndịisi ụmụ Izrel gabigara jegharịa nʼetiti ọmụma ụlọ ikwu ahụ,  
\v 3 nye ha iwu sị, “Mgbe unu hụrụ igbe ọgbụgba ndụ \nd Onyenwe anyị\nd* Chineke unu, ka ndị nchụaja, ụmụ Livayị, bulitere ya, unu onwe unu ga-esi nʼebe unu nọ bilie soro ha nʼazụ.  
\v 4 Ma a ga-enwe oke nʼetiti unu na ha, ihe dịka otu kilomita site nʼebe igbe ọgbụgba ndụ ahụ dị. Unu agaghị abịaru ya nso. Nke a bụ maka ị mara ụzọ unu ga-eso, nʼihi na unu esibeghị nʼụzọ a gaa ije mbụ.” 
\p  
\v 5 Joshua gwara ndị Izrel sị, “Doonụ onwe unu nsọ, nʼihi na echi ka \nd Onyenwe anyị\nd* ga-eme oke ihe ebube dị iche iche nʼetiti unu.” 
\p  
\v 6 Joshua gwara ndị nchụaja sị ha, “Bulienụ igbe ọgbụgba ndụ ahụ, gabiga nʼihu ndị Izrel.” Ha buliri igbe ọgbụgba ndụ ahụ, bido ịga nʼihu ụmụ Izrel. 
\p  
\v 7 Mgbe ahụ, \nd Onyenwe anyị\nd* gwara Joshua sị, “Taa, ka m ga-amalite ime ka ị dị ukwuu nʼanya ụmụ Izrel niile, ka ha niile mata na dịka m si nọnyere Mosis, otu a ka m ga-esi nọnyere gị.  
\v 8 Ị ga-enye ndị nchụaja bụ ndị na-ebu igbe ọgbụgba ndụ iwu si, ‘Mgbe unu ruru nʼọnụ mmiri osimiri Jọdan, banyekwanụ gaa guzo nʼime osimiri ahụ.’ ” 
\p  
\v 9 Mgbe ahụ, Joshua gwara ụmụ Izrel niile sị, “Bịanụ nso, bịanụ nụrụ okwu niile nke \nd Onyenwe anyị\nd* Chineke unu.  
\v 10 Otu a ka unu ga-esi mata nʼezie na Chineke dị ndụ nọ nʼetiti unu, unu ga-amatakwa na ọ ghaghị ịnapụ ndị Kenan, na ndị Het, na ndị Hiv, na ndị Periz, na ndị Gigash, na ndị Amọrait, na ndị Jebus ala ha nʼihu unu.  
\v 11 Lee, igbe ọgbụgba ndụ \nd Onyenwe anyị,\nd* Onyenwe ụwa niile ga-agabiga nʼihu unu banye nʼime Jọdan.  
\v 12 Ugbu a sitenụ nʼebo Izrel niile họpụta ndị ikom iri na abụọ, site nʼebo ọbụla otu onye.  
\v 13 Ngwangwa ndị nchụaja bu igbe ọgbụgba ndụ \nd Onyenwe anyị\nd*, Onyenwe ụwa niile zọnyere ụkwụ na Jọdan, mmiri Jọdan nke si nʼebe elu ya na-arịdata ga-akwụsị ịsọ, guzoro dịka mgbidi.” 
\p  
\v 14 Ya mere, mgbe ndị Izrel sitere nʼụlọ ikwu ha bilie njem ịgabiga osimiri Jọdan, ndị nchụaja bụ igbe ọgbụgba ndụ buuru ha ụzọ na-aga ha nʼihu.  
\v 15 Nʼoge owuwe ihe ubi ọbụla, osimiri Jọdan na-etoju etoju, sọjukwaa akụkụ ya niile.\f + \fr 3:15 \ft \xt Jos 4:18; 1Ih 12:15\f* Ma ngwangwa ndị nchụaja bu igbe ọgbụgba ndụ a bịaruru nso zọnye ụkwụ ha nʼọnụ mmiri Jọdan,  
\v 16 mmiri si nʼelu elu osimiri ahụ kwụsịrị ịsọ, ọ gara elu tụkọta onwe ya dịka mgbidi nʼebe dị anya, nʼobodo a na-akpọ Adam, nke dị nso obodo Zaretan. Ebe mmiri nke na-eruda na-asọbanye osimiri Araba, ya bụ, osimiri Nnu kwụsịrị ịsọ kpamkpam. Ya mere, ndị Izrel gabigara na ncherita ihu Jeriko.  
\v 17 Ndị nchụaja bu igbe ọgbụgba ndụ \nd Onyenwe anyị\nd* guzoro nʼala akọrọ nʼetiti Jọdan, Izrel niile gabigakwara tutu ruo mgbe mba ahụ niile gafesịrị nʼala akọrọ. 
\c 4  
\p  
\v 1 Mgbe mba ahụ niile gafesịrị osimiri Jọdan, \nd Onyenwe anyị\nd* gwara Joshua okwu sị ya,  
\v 2 “Site nʼetiti ndị ụmụ Izrel họpụta ndị ikom iri na abụọ, otu onye site nʼebo ọbụla,  
\v 3 ka onye ọbụla nʼime ha site nʼebe ahụ ndị nchụaja guzoro nʼetiti osimiri Jọdan buputa otu nkume, otu nkume, gwa ha ka ha debe nkume ndị a ha buputara nʼebe unu ga-anọ ọnọdụ abalị taa.” 
\p  
\v 4 Ya mere, Joshua kpọrọ ndị ikom iri na abụọ ndị ahụ, ndị ọ họpụtara, site nʼetiti ndị Izrel, otu onye site nʼebo ọbụla,  
\v 5 Ọ gwara ha sị, “Sitenụ nʼetiti osimiri Jọdan, ebe ndị bu igbe ọgbụgba ndụ \nd Onyenwe anyị\nd* Chineke unu guzoro, buputa nkume. Onye ọbụla nʼime unu ga-ebuputa otu nkume, tụkwasị nʼubu ya, dịka ọnụọgụgụ ebo Izrel niile si dị,  
\v 6 ka ha bụrụ ihe ịrịbama nʼetiti unu. Nʼoge dị nʼihu, mgbe ụmụ unu ga-ajụ unu ajụjụ sị, ‘Gịnị bụ isi ogidi nkume a dị nʼebe a?’  
\v 7 Unu ga-asịkwa ha, ‘Ọ bụ ihe na-echetara anyị otu osimiri Jọdan si kwụsị ịsọ, mgbe ndị bụ igbe ọgbụgba ndụ \nd Onyenwe anyị\nd* zọnyere ụkwụ ha nʼosimiri ahụ.’ Nkume a ga-abụkwara ụmụ Izrel niile ihe ncheta ruo mgbe ebighị ebi.” 
\p  
\v 8 Ụmụ Izrel mere dịka Joshua gwara ha. Ha buputara nkume iri na abụọ site nʼetiti osimiri Jọdan, dịka \nd Onyenwe anyị\nd* si nye Joshua nʼiwu sị na otu onye, nʼebo Izrel ọbụla, ga-ebuputa otu nkume. Ha buuru nkume iri na abụọ ndị ahụ gaa nʼebe ha nọrọ ọnọdụ abalị, debe ha nʼebe ahụ.  
\v 9 Joshua nʼonwe ya kwa ji nkume iri na abụọ ahụ nke si nʼetiti osimiri Jọdan wuo ogidi ịrịbama, nʼebe ahụ ndị nchụaja bu igbe ọgbụgba ndụ ahụ guzoro. Ha dịkwa nʼebe ahụ ruo taa. 
\p  
\v 10 Ndị nchụaja, ndị bụ igbe ọgbụgba ndụ ahụ, guzoro nʼetiti osimiri Jọdan, tutu ruo mgbe e mezuru iwu ahụ niile \nd Onyenwe anyị\nd* nyere Joshua site nʼọnụ Mosis. Mgbe ahụ kwa, ndị Izrel mere ngwangwa gafee osimiri Jọdan.  
\v 11 Ngwangwa ha niile gafetasịrị, igbe ọgbụgba ndụ \nd Onyenwe anyị\nd* na ndị nchụaja gafetakwara nʼakụkụ nke ọzọ, ka ndị mmadụ na-ele ha anya.  
\v 12 Ndị agha ụmụ Ruben, na ụmụ Gad, na ọkara ebo Manase, buuru ụmụ Izrel niile ụzọ gafee, idu ha nʼagha, dịka Mosis nyere ha nʼiwu.  
\v 13 Ndị agha ọnụọgụgụ ha ruru iri puku anọ (40,000), ndị jikeere nke ọma ibu agha, duuru ebo ndị ọzọ, gafere nʼihu \nd Onyenwe anyị\nd* bata nʼobosara ala Jeriko maka ibu agha. 
\p  
\v 14 Ụbọchị ahụ bụ ụbọchị \nd Onyenwe anyị\nd* buliri Joshua elu nke ukwuu nʼihi na o mere Joshua ka ọ dị ukwuu nʼanya ndị Izrel niile, si otu a mee ka ha tụọ ya egwu nke ukwuu dịka ha si tụọ Mosis egwu, ma sọpụkwara ya ụbọchị niile nke ndụ ya. 
\p  
\v 15 Mgbe ahụ, \nd Onyenwe anyị\nd* gwara Joshua okwu sị,  
\v 16 “Nye ndị nchụaja, ndị bu igbe ọgbụgba ndụ ahụ iwu ka ha si nʼosimiri Jọdan pụta.” 
\p  
\v 17 Ya mere Joshua nyere ndị nchụaja iwu sị ha, “Sitenụ nʼosimiri Jọdan pụta.” 
\p  
\v 18 Mgbe ndị nchụaja bu igbe ọgbụgba ndụ \nd Onyenwe anyị\nd* ahụ si nʼosimiri Jọdan rịpụta, dịka ọbụ ụkwụ ha na-emetụ nʼala akọrọ, mmiri osimiri ahụ sọghachiri nʼọnọdụ ya ruchie akụkụ ya niile, ka ọ dị na mbụ. 
\p  
\v 19 Ihe ịrịbama a mere nʼụbọchị nke iri, nʼọnwa nke mbụ. Nʼụbọchị ahụ ka ndị Izrel niile gafere osimiri Jọdan, gaa maa ụlọ ikwu ha na Gilgal, ebe dị nʼọwụwa anyanwụ obodo Jeriko.  
\v 20 Nkume iri na abụọ ahụ ha si nʼosimiri Jọdan buputa, ka Joshua guzobere na Gilgal.  
\v 21 Ọ sịrị ndị Izrel, “Nʼoge dị nʼihu, mgbe ụmụ unu ga-ajụ ndị bụ nna ha ajụjụ sị, ‘Gịnị ka nkume ndị a pụtara, Gịnịkwa ka ha na-egosi?’  
\v 22 Gwa ha, ‘Izrel gafere osimiri Jọdan nʼala akọrọ.’  
\v 23 Nʼihi na \nd Onyenwe anyị\nd* bụ Chineke unu mere ka osimiri Jọdan takpọọ nʼihu unu tutu ruo mgbe unu gafesịrị nʼofe nke ọzọ. \nd Onyenwe anyị\nd* Chineke unu mere osimiri Jọdan ihe o mere osimiri Uhie\f + \fr 4:23 \ft \xt Ọpụ 14:21\f* mgbe o mere ka osimiri Uhie takpọọ nʼihu anyị, tutu ruo mgbe anyị gafesịrị nʼofe ya nke ọzọ.  
\v 24 O mere ihe ndị a niile ka ndị niile bi nʼelu ụwa mata na aka \nd Onyenwe anyị\nd* dị ike.\f + \fr 4:24 \ft \xt 1Ez 8:42; Abụ 106:8; 89:13; Ọpụ 15:16\f* O mekwara ya ka unu onwe unu tụọ egwu \nd Onyenwe anyị\nd* Chineke unu, mgbe niile.”\f + \fr 4:24 \ft \xt Ọpụ 14:14; Dit 6:2; Abụ 76:6\f* 
\c 5  
\p  
\v 1 Mgbe ndị eze ndị Amọrait niile, ndị bi nʼofe ọzọ nke osimiri Jọdan, nʼakụkụ ọdịda anyanwụ, na ndị eze ndị Kenan niile bi nʼakụkụ oke osimiri Mediterenịa, nụrụ na \nd Onyenwe anyị\nd* emeela ka osimiri Jọdan takpọọ nʼihu ụmụ Izrel, ruo mgbe anyị niile gafesịrị, obi lọrọ ha mmiri. Ọ dịkwaghị ike ọbụla fọdụụrụ ha iguzo nʼihu ụmụ Izrel. 
\s1 Obibi ugwu na Gilgal 
\p  
\v 2 Ma nʼoge ahụ, \nd Onyenwe anyị\nd* gwara Joshua okwu sị ya, “Jiri nkume mee mma ị ga-eji bie ụmụ Izrel niile ugwu ọzọ.”  
\v 3 Ya mere, Joshua ji nkume mee mma ntakịrị e ji bie ụmụ Izrel niile ugwu. Ebe a nọ bie ụmụ Izrel ugwu bụ ebe a na-akpọ Gibịat Haaralot. 
\p  
\v 4 Nke a bụ ihe mere o ji mee otu a: Ndị ikom niile si nʼIjipt pụta, ndị tozuru ije agha, nwụrụ nʼụzọ, nʼime ọzara, mgbe ha hapụchara Ijipt.  
\v 5 Mgbe ụmụ Izrel niile si Ijipt pụta, e biri ndị nwoke niile nọ nʼetiti ha ugwu. Ma nʼime iri afọ anọ ahụ ha na-awagharị nʼọzara, o nweghị ụmụ ha ndị nwoke a mụrụ nʼoge a e biri ugwu.  
\v 6 Ndị Izrel niile awagharịala nʼọzara iri afọ anọ tutu ruo mgbe ndị ikom niile toruru ije agha, bụ ndị hapụrụ Ijipt nwụchara, ebe ọ bụ na ha jụrụ irubere \nd Onyenwe anyị\nd* isi. Nʼihi na \nd Onyenwe anyị\nd* ṅụrụ iyi sị ha na ha agaghị ahụ ala ahụ anya, bụ ala ahụ o kwere nna nna ha na nkwa, inye anyị, ala mmiri ara ehi na mmanụ aṅụ na-eru na ya.  
\v 7 \nd Onyenwe anyị\nd* mere ka ụmụ ndị nnupu isi a mụtara nọchie anya ha. Ọ bụkwa ndị a ka Joshua biri ugwu, nʼihi na tutu ruo ugbu a, e bibeghị ha ugwu.  
\v 8 Mgbe e bizuru mba niile ahụ ugwu, ha nọdụrụ nʼebe ahụ ha mara ụlọ ikwu tutu ọnya obibi ugwu ha alaa. 
\p  
\v 9 Mgbe ahụ, \nd Onyenwe anyị\nd* gwara Joshua okwu sị, “Taa, ewezugala m site nʼebe unu nọ ihe nkọcha nke ya na Ijipt so.” Nʼihi nke a, ha kpọrọ ebe ahụ Gilgal.\f + \fr 5:9 \ft \xt Jos 4:9; 9:6\f* Ọ bụkwa aha ya ruo taa. 
\p  
\v 10 Mgbe ụmụ Izrel mara ụlọ ikwu ha na Gilgal nʼala ihe nʼadịghị nke Jeriko, ha mere Mmemme Ngabiga nʼuhuruchi nke ụbọchị iri na anọ nke ọnwa ahụ.  
\v 11 Nʼụbọchị sotere ụbọchị ngabiga, nʼotu ụbọchị ahụ, ha riri ụfọdụ ihe ubi nke ala Kenan. Ọ bụ achịcha a na-ejighị ihe na-eko achịcha mee, na ọka ahụrụ nʼọkụ ka ha tara.  
\v 12 Mánà kwụsịkwara nʼechi ya mgbe ha riri nri sitere nʼala ahụ. Ụmụ Izrel ahụkwaghị mánà anya ọzọ, ma nʼafọ ahụ ha riri ihe omume ubi si nʼala Kenan. 
\s1 Ọdịda Jeriko 
\p  
\v 13 Mgbe Joshua nọ nso obodo Jeriko, o weliri anya ya elu hụ otu nwoke ka o guzo nʼihu ya. Nwoke a mịpụtara mma agha ya jide ya nʼaka ya. Joshua jekwuru ya jụọ ya sị ya, “Ị dịnyeere anyị ka ị dịnyeere ndị iro anyị\f + \fr 5:13 \ft Maọbụ, \fqa ndị na-emegide anyị\f*?” 
\p  
\v 14 Nwoke ahụ zaghachiri ya sị, “Ọ dịghị onye m dịnyeere, kama abịara m ugbu a dịka ọchịagha usuu ndị agha \nd Onyenwe anyị\nd*.” Joshua dara nʼala kpuo ihu ya nʼala kpọọ isiala nye ya, sị ya, “Ejikerela m ime ihe ọbụla i nyere nʼiwu. Onyenwe m, gịnị ka ị chọrọ ka m mee?” 
\p  
\v 15 Ọchịagha usuu ndị agha \nd Onyenwe anyị\nd* zara sị Joshua, “Yipụ akpụkpọụkwụ gị, nʼihi na ebe ahụ i guzo bụ ala dị nsọ.” Joshua mere dịka ọ gwara ya. 
\c 6  
\p  
\v 1 Ma e mechiri ọnụ ụzọ e si abata Jeriko nke ọma, nʼihi ụmụ Izrel. Ọ dịghị onye ọbụla na-apụ nʼezi, ọ dịghịkwa onye na-abata nʼime ya. 
\p  
\v 2 Ma \nd Onyenwe anyị\nd* gwara Joshua sị, “Lee, enyefela m obodo a bụ Jeriko, ya na eze ya, na ndị dị ike ibu agha nọ nʼime ya, nʼaka gị.  
\v 3 Gị na ndị agha gị zọọnụ ije gburugburu obodo a. Unu ga-ejegharị gburugburu mgbidi obodo a otu ugbo nʼụbọchị. Unu ga-esi otu a jegharịa ụbọchị isii.  
\v 4 Ndị nchụaja asaa, ndị ga-eji opi mpi ebule asaa ga-ebu ụzọ gawa nʼihu. Ndị nchụaja ndị ọzọ ga-ebu igbe ọgbụgba ndụ. Nʼụbọchị nke asaa, unu ga-agba obodo ahụ gburugburu ugboro asaa. Mgbe unu na-eme nke a, ndị nchụaja asaa ahụ ga na-afụ opi mpi ebule ha.  
\v 5 Emesịa, ndị nchụaja ga-afụsi opi ahụ ike otu ugbo ọzọ, ha ga-afụ ya ka ọ daa ụda nke ukwu. Mgbe mmadụ niile nụrụ ụda opi a, ha niile ga-eti mkpu nke ga-ada ezi ụda. Nke a ga-eme ka mgbidi obodo ahụ daa. Mgbe ahụ, onye agha ọbụla ga-esite nʼebe ọbụla ọ nọ banye nʼime obodo ahụ.” 
\p  
\v 6 Ya mere, Joshua nwa Nun kpọrọ ndị nchụaja sị ha, “Burunu igbe ọgbụgba ndụ \nd Onyenwe anyị\nd* ahụ, ka ndị nchụaja asaa nʼime unu werekwa opi mpi ebule buru ụzọ na-aga nʼihu ya.”  
\v 7 Mgbe ahụ Joshua nyere ndị Izrel iwu sị ha, “Zọlịenụ ije! Gbaanụ obodo a gburugburu, ka ndị agha na-aga nʼihu igbe ọgbụgba ndụ \nd Onyenwe anyị\nd*.” 
\p  
\v 8 Mgbe Joshua gwachara ndị Izrel okwu, ndị nchụaja asaa ahụ bu opi ike nʼaka ha, nʼihu \nd Onyenwe anyị\nd*, gafere nʼihu na-afụ opi ike ha. Ndị bu igbe ọgbụgba ndụ \nd Onyenwe anyị\nd* sochiri ha azụ.  
\v 9 Ndị agha na-aga nʼihu ndị nchụaja bụ ndị na-afụ opi ike, ebe ndị agha ndị ọzọ na-esote igbe ọgbụgba ndụ nʼazụ. Nʼoge a niile ha na-azọ ije, ndị na-afụ opi ike gara nʼihu na-eme nke a.  
\v 10 Ma Joshua nyere ndị Izrel iwu sị ha, “Unu emela mkpọtụ agha ọbụla, maọbụ kwee ka anụ olu unu, maọbụ kwuo okwu ọbụla, tutu ruo ụbọchị m ga-asị unu tie mkpu. Mgbe m nyere unu iwu a, tienụ ezi mkpu.”  
\v 11 Ya mere, e buuru igbe ọgbụgba ndụ \nd Onyenwe anyị\nd* ahụ jegharịa obodo ahụ gburugburu otu ugboro nʼụbọchị ahụ. Mgbe ha mesịrị nke a, onye ọbụla laghachiri nʼebe ụlọ ikwu ya dị rahụ ụra abalị. 
\p  
\v 12 Joshua biliri nʼisi ụtụtụ echi ya, ndị nchụaja bulikwara igbe ọgbụgba ndụ \nd Onyenwe anyị\nd*.  
\v 13 Ndị nchụaja asaa ahụ bu opi ike asaa ndị ahụ, na-aga nʼihu igbe ọgbụgba ndụ \nd Onyenwe anyị\nd*, na-afụ opi ike ha na-esepụghị aka. Ndị agha nọ nʼihu ha, ebe ndị nche na-eso ndị bu igbe ọgbụgba ndụ \nd Onyenwe anyị\nd* nʼazụ, nʼoge niile a a na-afụ opi ike ndị a na-esepụghị aka.  
\v 14 Nʼụbọchị nke abụọ, ha gbara obodo ahụ gburugburu otu ugboro, laghachikwa nʼụlọ ikwu ha. Otu a ka ha mere ruo nʼụbọchị nke isii. 
\p  
\v 15 Ma nʼisi ụtụtụ ụbọchị nke asaa, ha bilitere mgbe chi na-abọbeghị, gbaa obodo ahụ gburugburu ugboro asaa dịka ha na-eme. Ma ọ dị iche nʼụbọchị ahụ, bụ naanị na ha gbara obodo ahụ gburugburu ugboro asaa.  
\v 16 O ruo, nʼoge njegharị nke ugboro asaa ahụ, mgbe ndị nchụaja asaa ndị a fụsiri opi ike asaa ndị ahụ ike karịa, ka Joshua gwara ndị Izrel sị ha, “Tienụ mkpu! Nʼihi na \nd Onyenwe anyị\nd* enyela unu obodo a!  
\v 17 Gbuonụ ihe niile na-eku ume ndụ, nʼihi na obodo a na ihe niile dị nʼime ha bụ ihe e doro nsọ nye \nd Onyenwe anyị\nd*. Ma ọ bụ naanị Rehab, nwanyị akwụna ahụ ka unu ga-ahapụ ndụ, ya na ndị ọbụla nọ nʼụlọ ya. Nʼihi na o zoro ndị anyị zigara inyochapụta obodo ahụ.  
\v 18 Ma unu onwe unu, wezuganụ onwe unu pụọ nʼebe ihe ndị a kwadoro mbibi dị, ka unu gharakwa iweta ịla nʼiyi nye onwe unu site na iwere ihe ọbụla nʼime ha. Ma ọ bụghị otu a, unu ga-eme ka mbibi dakwasị ụlọ ikwu ụmụ Izrel niile.  
\v 19 Ma ihe niile e ji ọlaọcha na ọlaedo kpụọ, na ihe niile e ji bronz na igwe kpụọ, ka a ga-edo iche nye \nd Onyenwe anyị\nd*. A ga-ewebata ha nʼụlọakụ \nd Onyenwe anyị\nd*.” 
\p  
\v 20 Mgbe ụda opi ike ahụ dasiri ike, ndị agha tiri mkpu, na ụda opi ike ahụ. Mgbe ndị ikom tiri oke mkpu, mgbidi ahụ dara dapịasịa, nke mere na onye ọbụla chere ihu banye nʼime obodo ahụ, lụgbuo obodo ahụ.  
\v 21 Ha debere obodo a iche nye \nd Onyenwe anyị\nd* site nʼiji mma agha ha gbuchapụ ihe niile dị ndụ nʼobodo ahụ, ma nwoke, ma nwanyị, ma nwantakịrị, ma okenye, ma ehi, ma atụrụ, ma ịnyịnya ibu, ihe niile dị nʼime ya. 
\p  
\v 22 Mgbe ahụ, Joshua gwara ndị ikom abụọ ahụ buru ụzọ gaa nnyochapụta obodo ahụ anya sị ha, “Mezuonụ nkwa unu kwere. Gaanụ nʼụlọ nwanyị akwụna, kpọpụta ya na ndị niile dị nʼụlọ ya.”  
\v 23 Ya mere, ụmụ okorobịa abụọ ahụ bụ ndị mere nledo ala ahụ, bara nʼụlọ ahụ, kpọpụta Rehab na nna ya na nne ya na ụmụnne ya na ndị ikwu ya niile. Ha kpọpụtara ndị ezinaụlọ ya niile debe ha nʼotu ebe nke dị nʼazụ ọmụma ụlọ ikwu ụmụ Izrel. 
\p  
\v 24 Ha kpọrọ obodo ahụ ọkụ, ya na ihe niile dị nʼime ya. Ma ha wepụtara naanị ọlaọcha na ọlaedo, na ihe niile e ji bronz na igwe kpụọ, tinye nʼụlọakụ \nd Onyenwe anyị\nd*.  
\v 25 Joshua mere ka Rehab, nwanyị akwụna ahụ, na ndị ezinaụlọ ya niile dịrị ndụ. Nʼihi na Rehab zoro ndị ikom abụọ Joshua zigara, mee ka ha dị ndụ, bụ ndị gara inyochapụta obodo Jeriko. Ya mere, o binyere ndị Izrel ruo taa. 
\p  
\v 26 Mgbe ahụ, Joshua gbara obodo Jeriko iyi sị, “Ọbụbụ ọnụ ka a na-abụ nwoke ọbụla nʼihu \nd Onyenwe anyị\nd* nke ga-ebili wuokwa obodo Jeriko ọzọ. 
\q1 “Ndụ ọkpara\f + \fr 6:26 \ft Ya bụ, ọkpara ya ga-anwụ mgbe ọ ga-atọ ntọala nʼihi iwugharị obodo ahụ.\f* ya ka ọ ga-eji 
\q2 tọọ ntọala ya niile, 
\q1 ndụ nwa ya nke nta, 
\q2 ka ọ ga-eji guzobe ọnụ ụzọ ama ya niile ọtọ.”\f + \fr 6:26 \ft \xt 1Ez 16:34\f* 
\p  
\v 27 Ya mere, \nd Onyenwe anyị\nd* nọnyeere Joshua. Akụkọ a kọrọ banyere ya gbasara nke ukwuu nʼala ahụ niile. 
\c 7  
\s1 Mmehie Ekan 
\p  
\v 1 Ma ụmụ Izrel ekwesighị ntụkwasị obi nʼihe gbasara ihe ndị ahụ e debere iche nye \nd Onyenwe anyị\nd*. Nʼihi na Ekan nwa Kami, nwa Zimri,\f + \fr 7:1 \ft Zabdi, dị na nsụgharị Griik nke akwụkwọ nsọ e dere nʼasụsụ Hibru.\f* nwa Zera, onye si nʼebo Juda gara were ụfọdụ nʼime ihe ndị ahụ. Nke a mere ka iwe wee \nd Onyenwe anyị\nd* nke ukwuu megide ụmụ Izrel. 
\p  
\v 2 Emesịa, Joshua si Jeriko zipụ ụfọdụ ndị mmadụ ka ha gaa Ai, obodo dị Bet-Aven nso, nʼọwụwa anyanwụ Betel. Ọ gwara ha sị ha, “Gaanụ nnyopụta akụkụ ala ahụ niile.” Ya mere, ndị ahụ gara nnyochapụta obodo Ai. 
\p  
\v 3 Mgbe ha lọghachiri azụ, ha gwara Joshua sị ya, “Ai bụ obodo nta. Ọ gaghị ewe karịa puku mmadụ abụọ maọbụ atọ imeri obodo ahụ. Ọ bakwaghị uru ka anyị niile gaa tigbuo obodo a, nʼihi na ha dị mmadụ ole na ole.”  
\v 4 Nʼihi nke a, ihe dịka puku ndị agha atọ ka e zigara imeri obodo Ai. Ma ngwangwa, ndị agha obodo Ai meriri ndị agha ụmụ Izrel, chụọ ha ọsọ.  
\v 5 Ihe dịka iri mmadụ atọ na isii nʼetiti ndị agha Izrel ka e gburu nʼagha ahụ. Ndị Ai chụrụ ha ọsọ site nʼụzọ ama obodo ruo nʼebe a na-awa nkume, gbuo ha na mgbada ugwu ahụ. Nʼihi nke a, ndị agha Izrel dara mba, obi lọkwara ha mmiri. 
\p  
\v 6 Mgbe ahụ, Joshua na ndị okenye Izrel sitere nʼobi mwute dọwaa uwe ha, daa nʼala kpuo ihu nʼala nʼihu igbe ọgbụgba ndụ \nd Onyenwe anyị\nd* site nʼụtụtụ ruo nʼanyasị. Ha wekwara ntụ wụkwasị onwe ha nʼisi igosi obi mwute ha.  
\v 7 Mgbe ahụ kwa, Joshua sịrị, “Ewoo, Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd*! Nʼihi gịnị ka i ji mee ka ndị a gabiga osimiri Jọdan, inyefe anyị nʼaka ndị Amọrait, ime ka ha tigbuo anyị? Ọ gaara adị anyị mma nke ọma ma ọ bụrụ na anyị nọdụrụ nʼofe ọzọ nke Jọdan.  
\v 8 Biko, Onyenwe m, Gịnị ka m ga-ekwu ugbu a ụmụ Izrel sitere nʼihu ndị iro ha gbaa ọsọ?  
\v 9 Nʼihi na mgbe ndị Kenan na ndị bi nʼakụkụ ala ahụ ga-anụ maka mmeri e meriri anyị, ha ga-agba anyị gburugburu lụso anyị agha, bipụ aha anyị nʼụwa. Ọ bụkwa gịnị ka ị ga-eme banyere aha ukwu gị dị ebube?” 
\p  
\v 10 Ma \nd Onyenwe anyị\nd* sịrị Joshua, “Bilie ọtọ! Gịnị bụ nke a, na ị dara kpuo ihu nʼala?  
\v 11 Izrel emehiela. Ha emebiela ọgbụgba ndụ m nyere ha nʼiwu idebe, ha ewerela ụfọdụ nʼime ihe ndị ahụ e doro iche nye \nd Onyenwe anyị\nd*. Ọ bụghị naanị na ha zuru ohi, ha nọkwa nʼelu ya ghaa ụgha banyere ya. Ha ewerekwala ihe ndị ahụ tinyekọta nʼihe nke aka ha.  
\v 12 Ọ bụ nʼihi nke a mere na ụmụ Izrel enwekwaghị ike iguzo nʼihu ndị iro ha. Ọ bụkwa nke a mere ha ji tụgharịa gbaa ọsọ, nʼihi na ha aghọọla ndị kwesiri ka e bibie. Ya mere, agaghị m anọnyere unu ọzọ, tutu ruo mgbe unu wezugara ma mebie site nʼetiti onwe unu, ihe ọbụla e debere iche maka mbibi. 
\p  
\v 13 “Bilie! Doo Izrel nsọ. Gwa ndị m okwu sị ha, ‘Onye ọbụla nʼetiti unu ga-ejikere doo onwe ya nsọ maka echi. Nʼihi na \nd Onyenwe anyị\nd*, Chineke Izrel na-ekwu sị, Ihe ndị e doro nsọ dị nʼetiti unu, Izrel. Unu apụghịkwa iguzosi ike nʼihu ndị iro unu, tutu ruo mgbe unu ga-esite nʼetiti onwe unu wezuga ihe ndị ahụ.’ 
\p  
\v 14 “ ‘Nʼụtụtụ echi, unu ga-apụta nʼebo nʼebo. Ebo ọbụla \nd Onyenwe anyị\nd* họpụtara ga-apụta nʼikwu nʼikwu,\f + \fr 7:14 \ft Ọ bụ nkume abụọ a na-eji ajụta ase nʼihu Chineke, nke a na-akpọ Urim na Tumim, ka ha ji chọpụta eziokwu banyere ihe mere. \xt Ọpụ 28:30; Lev 8:8; Ọnụ 27:21; 1Sa 28:6; Ezr 2:63; Neh 7:63-65\f* ikwu ọbụla \nd Onyenwe anyị\nd* họpụtara ga-apụta bịa nʼezinaụlọ nʼezinaụlọ, ụlọ ọbụla nke \nd Onyenwe anyị\nd* họọrọ, ndị ikom ya ga-apụta nʼotu nʼotu.  
\v 15 Ma onye ọbụla e jidere ji ihe ndị ahụ e doro nsọ ka a ga-akpọ ọkụ, ya onwe ya, na ihe niile ọ nwere, nʼihi o mebiela iwu ọgbụgba ndụ \nd Onyenwe anyị\nd*, meekwa ihe jọgburu onwe ya na njọ nʼIzrel.’ ” 
\p  
\v 16 Nʼihi nke a, Joshua biliri nʼisi ụtụtụ. O mere ka ebo niile dị nʼIzrel bịaruo nso nʼebo nʼebo, ebo Juda ka a họọrọ.  
\v 17 Mgbe ahụ, e mere ka ikwu niile dị nʼebo Juda bịaruo nso, ikwu Zera ka ahọpụtara. Mgbe e mere ka ikwu Zera pụta nʼezinaụlọ ha niile nʼotu nʼotu, ezinaụlọ Zimri bụ nke ahọpụtara.  
\v 18 Joshua mere ka ndị ikom niile dị nʼezinaụlọ Zimri pụta nʼotu nʼotu, ma e jidere Ekan, nwa Kami, nwa Zimri, nwa Zera onye ebo Juda. 
\p  
\v 19 Mgbe ahụ, Joshua sịrị Ekan, “Nwa m, nye \nd Onyenwe anyị\nd*, Chineke Izrel otuto, nyekwa ya nsọpụrụ. Gwa m ihe i mere. Ezonarịkwala m ihe ọjọọ i mere.” 
\p  
\v 20 Mgbe ahụ, Ekan zara Joshua sị ya, “Ọ bụ eziokwu! Emehiela m megide \nd Onyenwe anyị\nd*, Chineke Izrel. Lee ihe m mere.  
\v 21 Mgbe m hụrụ nʼetiti ihe ndị a kwatara nʼagha, otu uwe mwụda Babilọn\f + \fr 7:21 \ft Nʼasụsụ ndị Hibru, ihe e ji mara Babilọn bụ Shaịna. \xt Jen 10:10\f* mara mma, na narị Shekel ọlaọcha abụọ, na mkpirisi ọlaedo ịdị arọ ya ruru iri shekel ise. E nwere m anya ukwu nʼebe ihe ndị a dị, chịrị ha. Lee, ezoro m ha nʼime ala nʼụlọ ikwu m, ọlaọcha ahụ dịkwa nʼokpuru ya.” 
\p  
\v 22 Ya mere, Joshua zigara ụfọdụ ndị ikom ka ha gaa chọọ ihe ahụ Ekan zoro. Ndị a gara nʼụlọ ikwu ahụ, chọpụta ihe ahụ ezuru nʼohi. Dịka Ekan kwuru, ihe ikpeazụ ha hụrụ bụ ọlaọcha ahụ.  
\v 23 Ha chịkọtara ha niile chịtara ha Joshua. Mgbe ha bịaruru ebe Joshua na ndị Izrel niile nọ, ha chịsara ya nʼala nʼihu \nd Onyenwe anyị\nd*. 
\p  
\v 24 Mgbe ahụ, Joshua na ndị Izrel niile, duuru Ekan, nwa Zera, chịkọrọkwa ọlaọcha ahụ, na uwe mwụda ahụ, na mkpirisi ọlaedo ahụ, na ụmụ ya ndị ikom na ụmụ ya ndị inyom, na ehi na ịnyịnya ibu ya, na igwe ewu na atụrụ ya, na ụlọ ikwu ya, na ihe niile o nwere, gaa na Ndagwurugwu Akọ.  
\v 25 Mgbe ahụ, Joshua sịrị, “Gịnị mere i ji wetara anyị nsogbu ndị a? \nd Onyenwe anyị\nd* ga-eme ka nsogbu dakwasịkwa gị onwe gị taa.” 
\p Ndị Izrel niile weere nkume tugbuo ha nʼebe ahụ. Emesịa, a kpọrọ ha ọkụ.  
\v 26 Ha tụkọtara ọtụtụ nkume tụkwasị ya nʼelu Ekan. Nkume ndị a dị nʼebe ahụ ruo taa. Ọ bụkwa nʼụzọ dị otu a ka iwe ọkụ \nd Onyenwe anyị\nd* ji dajụọ. Ya mere, e ji akpọ ebe ahụ Ndagwurugwu Akọ ruo taa. 
\c 8  
\s1 Mbibi Ai 
\p  
\v 1 Mgbe ahụ, \nd Onyenwe anyị\nd* sịrị Joshua, “Atụla egwu, adakwala mba. Chịrị ndị agha gị niile gaa Ai, nʼihi na ugbu a, unu onwe unu ga-emeri ha. Aga m eme ka i merie eze ndị Ai, na ndị ya na obodo ya, na ala ya.  
\v 2 Ị ga-emekwa obodo Ai na eze ya ihe i mere Jeriko na eze ya. Ma ihe dị iche na nke a bụ na unu ga-edebere onwe unu ihe niile unu kwatara nʼagha, ya bụ anụ ụlọ niile na ngwongwo obodo ahụ niile. Jikerenụ ibuso ha agha. Ọ bụkwa nʼazụ obodo ha ka unu ga-esi lụso ha agha.” 
\p  
\v 3 Mgbe ahụ, Joshua na ndị agha ya niile, biliri gaa ibuso Ai agha. Joshua họpụtara iri puku ndị agha atọ zipụ ha nʼabalị  
\v 4 o nyere ha iwu a, “Lee! Unu ga-aga zoo onwe unu nʼọhịa dị nʼazụ obodo Ai. Unu ezola onwe unu nʼebe dị anya site nʼobodo ahụ, kama nọọnụ nso, nọọkwanụ na njikere.  
\v 5 Mụ na ndị niile so m ga-abịaru obodo ahụ nso. Mgbe ha ga-apụta ịlụso anyị ọgụ dịka ha mere na mbụ, anyị ga-agbakwa ọsọ nʼihu ha,  
\v 6 Ha ga-achụ anyị ọsọ, tutu ruo mgbe anyị mere ka ha niile hapụ nʼobodo ha pụta. Nʼihi nʼuche ha, ha ga-asị, ‘Ha na-agbara anyị ọsọ dịka ha mere na mbụ, bịanụ ka anyị chụọ ha ọsọ gbuo ha.’ Ya mere, dịka anyị na-agbapụ site nʼebe ha nọ,  
\v 7 unu ga-esite nʼebe unu zoro onwe unu bilie, nweta obodo ahụ, nʼihi na \nd Onyenwe anyị\nd* Chineke unu ga-enyefe ya nʼaka unu.  
\v 8 Mgbe unu weere obodo ahụ, unu ga-esunye obodo ahụ ọkụ. Meenụ ihe \nd Onyenwe anyị\nd* nyere nʼiwu. Hụnụ na unu mezuru ihe ndị a m nyere unu nʼiwu.” 
\p  
\v 9 Mgbe Joshua nyesịrị ha iwu ndị a, o zipụrụ ha. Ha hapụkwara nʼabalị ahụ gaa zoo onwe ha nʼọhịa dị nʼetiti Betel na ọdịda anyanwụ Ai. Ma Joshua na ndị agha ndị ọzọ fọdụrụ nọdụrụ nʼabalị ahụ nʼetiti ndị Izrel. 
\p  
\v 10 Nʼisi ụtụtụ echi ya, Joshua chịkọtara ndị agha ya, ya na ndị ndu Izrel gara nʼihu ha, ruo Ai.  
\v 11 Ndị agha niile ha na ya so, chere ihu ha gaa nso obodo ruo nʼihu ya. Ha mara ụlọ ikwu ha nʼakụkụ ugwu obodo Ai, ndagwurugwu bụ ihe kewara ha na obodo ahụ.  
\v 12 Joshua chịịrị ihe ruru puku ndị agha ise, zoo ha nʼakụkụ ọdịda anyanwụ obodo ahụ, nʼetiti Betel na Ai.  
\v 13 Ya mere, ndị agha were ọnọdụ ha nʼusoro, ndị ga-ebu agha nọ nʼakụkụ ugwu, ndị niile zoro onwe ha nʼakụkụ ọdịda anyanwụ nke obodo ahụ. Ma nʼabalị ahụ, Joshua gara nọdụ na ndagwurugwu ahụ. 
\p  
\v 14 Mgbe eze Ai hụrụ nke a, ya na ndị ikom obodo ahụ niile mere ngwangwa pụọ nʼisi ụtụtụ izute ndị Izrel nʼotu ebe, nke chere ihu nʼAraba. Ma ọ mataghị na o nwere ndị agha zubere imegide ya ndị zoro onwe ha nʼọhịa dị nʼazụ obodo.  
\v 15 Joshua na ndị Izrel niile mere ka ha chụghachi ha azụ site nʼihu ha, ha gbara ọsọ na-aga akụkụ ọzara ahụ niile dịka ndị e meriri emeri.  
\v 16 Nʼihi nke a, a kpọkuru ndị ikom niile nọ nʼime obodo Ai sị ha pụta bịa chụọ ụmụ Izrel ọsọ, ha chụrụ Joshua na-aga, e si otu a rapụta ha nʼebe dị anya site nʼobodo ahụ.  
\v 17 Ọ dịkwaghị otu onye nwoke nke fọdụrụ na Ai maọbụ na Betel. Ha hapụkwara obodo ahụ ka o ghere oghe, gaa ịchụ ndị Izrel ọsọ. 
\p  
\v 18 Mgbe ahụ, \nd Onyenwe anyị\nd* kpọrọ Joshua sị ya, “Setịpụ ùbe dị gị nʼaka nʼụzọ Ai, nʼihi na aga m enye gị obodo a.” Joshua mere dịka \nd Onyenwe anyị\nd* gwara ya.  
\v 19 Mgbe ndị agha ahụ zoro onwe ha nʼime ọhịa lere anya hụ na Joshua setịrị aka ya, ngwangwa, ha wụpụtara site nʼebe ha zoro onwe ha, gbara ọsọ gbaba nʼobodo Ai, merie ya, mụnye ya ọkụ. 
\p  
\v 20 Ma mgbe ndị agha Ai lere anya nʼazụ, hụ ka anwụrụ ọkụ si nʼobodo ha na-alali elu, ha dara mba nʼime onwe ha. Ohere ọbụla adịghịkwa nye ha ịgbalaga gaa otu ụzọ maọbụ ụzọ ọzọ. Nʼihi na ndị Izrel ahụ buuru ụzọ gbaa ọsọ, ndị ahụ gbara na-aga nʼọzara, chigharịrị bido ịlụso ndị agha Ai ahụ na-achụ ha ọsọ ọgụ.  
\v 21 Nʼihi na mgbe Joshua na ndị agha Izrel so ya lepụrụ anya hụ ka anwụrụ ọkụ si nʼobodo Ai na-arịgo elu, ha matara na ndị ha zoro onwe ha nʼọhịa abanyela obodo Ai, lụgbuo ya. Ya mere, Joshua na ndị agha so ya tụgharịrị bido igbu ndị agha obodo Ai.  
\v 22 Ndị agha Izrel ahụ gara kpọọ obodo ahụ ọkụ pụtakwara, site nʼobodo ahụ, bido ịlụso ndị agha Ai ọgụ. Nke a mere ka ndị agha Ai nọdụ nʼetiti ụzọ ndị agha Izrel abụọ. Otu nʼihu ha, ndị nke ọzọ nʼazụ ha. Ya mere, ndị agha Izrel menyụrụ ha anya, gbuo ha, ruo na ọ dịkwaghị otu onye fọdụrụ nʼime ha, maọbụ onye gbapụrụ agbapụ.  
\v 23 Naanị eze Ai ka e jidere na ndụ. A kpọtakwara ya bịaruo nʼebe Joshua nọ. 
\p  
\v 24 Mgbe ndị agha Izrel gbusịrị ndị agha Ai niile nọ nʼọhịa na nʼọzara, ha lọghachiri azụ gbuo ndị niile fọdụrụ nʼime obodo ahụ.  
\v 25 Ndị niile e gburu nʼụbọchị ahụ, ma nwoke ma nwanyị dị puku iri na abụọ. Ọ bụkwa ndị niile nọ nʼobodo ahụ ka e gburu.  
\v 26 Nʼihi na Joshua nọgidere setịpụ ùbe o ji nʼaka ya, megide obodo Ai, tutu e bibie ndị niile nọ nʼobodo ahụ kpamkpam.  
\v 27 Ma ndị Izrel kwaara anụ ụlọ, na ihe nkwata nʼagha nke obodo ahụ, dịka okwu \nd Onyenwe anyị\nd* nyere Joshua nʼiwu si dị. 
\p  
\v 28 Ya mere, Joshua kpọrọ obodo Ai ọkụ, mee ya ka ọ ghọọ mkpọmkpọ ebe nke tọgbọrọ nʼefu ruo taa.  
\v 29 Ma Joshua kwụbara eze ndị Ai nʼelu osisi site nʼụtụtụ ruo nʼanyasị. Mgbe anyanwụ dara, Joshua nyere iwu ka e wedata ozu eze Ai site nʼosisi ahụ, tụsa ya nʼihu ọnụ ụzọ e si abata obodo ahụ. Emesịa, ha tụkọtara ọtụtụ nkume nʼelu ya. Nkume ahụ ha tụkọtara dịkwa nʼebe ahụ ruo taa. 
\s1 Ngụpụta akwụkwọ iwu nʼugwu Ebal 
\p  
\v 30 Mgbe ahụ, Joshua wuuru \nd Onyenwe anyị\nd*, Chineke Izrel ebe ịchụ aja nʼelu ugwu Ebal,  
\v 31 dịka Mosis onyeozi \nd Onyenwe anyị\nd* nyere ndị Izrel nʼiwu. O wuru ya dịka ihe e dere nʼakwụkwọ iwu Mosis si dị, ebe ịchụ aja a na-ejighị nkume a wara awa wuo, nkume a na-ejighị ngwa ọrụ igwe waa. Nʼelu ebe ịchụ aja a ka ha chụụrụ \nd Onyenwe anyị\nd* aja nsure ọkụ na aja udo.  
\v 32 Ma mgbe ndị Izrel nọ na-ele anya, Joshua depụtara iwu ndị ahụ Mosis nyere ha nʼelu nkume.  
\v 33 Izrel niile, ha na ndị okenye ha, na ndị ọchịagha ha, na ndị ikpe ha, guzo nʼakụkụ abụọ nke igbe ọgbụgba ndụ \nd Onyenwe anyị\nd*, na ncherita ihu ndị nchụaja, bụ ndị Livayị ndị na-ebu ya. Ma ndị ọbịa bi nʼetiti ha, ma ndị amụrụ nʼala ahụ nọ nʼebe ahụ. Ọkara nʼime ha gara guzo nʼakụkụ ugwu Gerizim, ọkara ndị ọzọ guzoro nʼakụkụ ugwu Ebal, dịka Mosis onyeozi \nd Onyenwe anyị\nd* nyere nʼiwu na mbụ, na ha ga-agọzi ndị Izrel. 
\p  
\v 34 Emesịa, Joshua gụpụtara na ntị ha,\f + \fr 8:34 \ft \xt Dit 31:11; Neh 8:3\f* okwu niile nke iwu ahụ, ya na ngọzị na ọbụbụ ọnụ so ya,\f + \fr 8:34 \ft \xt Dit 28:2,15,45; 29:20-21; 30:19\f* dịka ihe niile e dere nʼAkwụkwọ\f + \fr 8:34 \ft \xt Jos 1:8\f* Iwu si dị.  
\v 35 Iwu niile Mosis nyere ha ka Joshua gụpụtara na ntị ndị Izrel niile. Ndị inyom na ụmụntakịrị, na ndị ọbịa niile bi nʼetiti ụmụ Izrel so nọkọọ nʼoge a ndị Izrel niile zukọrọ. 
\c 9  
\s1 Aghụghọ ndị Gibiọn 
\p  
\v 1 Mgbe eze ndị niile bi nʼakụkụ ọdịda anyanwụ osimiri Jọdan, nụrụ banyere ihe ndị a, ya bụ, ndị niile bi nʼala ugwu ugwu nʼọdịda anyanwụ ndagwurugwu, na ndị bi ogologo akụkụ osimiri Mediterenịa ruo Lebanọn, eze ndị Het na nke ndị Amọrait na nke ndị Kenan na nke ndị Periz na nke ndị Hiv na nke ndị Jebus,  
\v 2 ha niile zukọtara ibu agha megide Joshua na ụmụ Izrel. 
\p  
\v 3 Ma mgbe ndị Gibiọn\f + \fr 9:3 \ft Ọ ga-ewe onye si Jerusalem na-aga Gibiọn, ije njem ruru iri kilomita.\f* nụrụ ihe Joshua mere Jeriko na Ai,  
\v 4 ha sitere nʼaghụghọ chọọ ụzọ ha ga-esi zọpụta onwe ha. Ha zipụrụ ndị ozi, ndị bokwasịrị ịnyịnya ibu ha akpa mere ochie, na karama akpụkpọ mere ochie, nke a duchiri ebe dị iche iche nʼahụ ha.  
\v 5 Ndị ahụ yikwasịrị nʼụkwụ ha akpụkpọụkwụ kara nka nke a kwachiri akwachi, na uwe mere nnọọ ochie. Achịcha niile ha ji bụ nri ha, kpọrọ nkụ maakwa ebu.  
\v 6 Mgbe ha bịaruru nʼebe ndị Izrel mara ụlọ ikwu ha na Gilgal, ha jekwuuru Joshua, gwa ya na ndị Izrel okwu sị ha, “Anyị si nʼala dị anya bịa. Ugbu a, biko anyị chọrọ ka anyị na unu gbaa ndụ.” 
\p  
\v 7 Ndị ikom Izrel zaghachiri sị ndị Hiv\f + \fr 9:7 \ft Ndị Hiv, bụkwa ndị a na-akpọ ndị Amọrait, si Mesopotamịa pụta. \xt Jos 9:1; 10:5; 13:4\f* ahụ, “Olee otu anyị si amata na unu ebighị anyị nso? Ma eleghị anya unu bi anyị nso, anyị na unu ọ ga-esi aṅaa gbaa ndụ?” 
\p  
\v 8 Ha zara Joshua sị ya, “Anyị bụ ndị ohu unu.” 
\p Ma Joshua jụrụ ha ajụjụ sị, “Olee ndị unu bụ? Ebee ka unu si bịa?” 
\p  
\v 9 Ha zara ya sị, “Ala anyị, ebe ndị ohu gị si bịa dị anya nke ukwuu. Anyị bịara nʼihi na anyị anụla akụkọ banyere \nd Onyenwe anyị\nd* Chineke unu, na ihe niile o mere nʼIjipt.  
\v 10 Anyị anụkwala ihe niile o mere eze abụọ ndị Amọrait, ndị nọ nʼọwụwa anyanwụ Jọdan, Saịhọn eze Heshbọn, na Ọg eze Bashan, onye chịrị nʼAshtarọt.  
\v 11 Ndị okenye anyị na ndị niile bi nʼala anyị sịrị anyị, ‘Werenụ ihe unu ji aga njem, jekwurunụ ndị Izrel sị ha, “Anyị bụ ndị ohu unu, kwerenụ ka anyị na unu gbaa ndụ.” ’  
\v 12 Lee achịcha ndị a bụ nke anyị ji mgbe anyị hapụrụ ala anyị. Ha dị ọkụ mgbe anyị hapụrụ ụlọ anyị ịbịa njem a, nʼihi na e si nʼebe a na-eghe ya wepụta ya, ma ugbu a, dịka unu hụrụ, ha akpọọla nkụ, bidokwa ịma ebu.  
\v 13 A gbajuru karama akpụkpọ anyị ndị a mmanya ọhụrụ mgbe anyị hapụrụ, ma ugbu a, karama ndị a adọwaala. Uwe anyị, na akpụkpọụkwụ anyị, emeela ochie nʼihi ịga ije dị anya.” 
\p  
\v 14 Ndị ikom Izrel ritụrụ ụfọdụ nʼime ihe oriri ha ji bịa, ma ha ajụtaghị ihe bụ uche \nd Onyenwe anyị\nd*.  
\v 15 Mgbe ahụ, Joshua na ndị ahụ gbara ndụ udo ikwe ka ha dị ndụ. Ndịisi nzukọ Izrel mesiri ọgbụgba ndụ ahụ ike site nʼịṅụ iyi. 
\p  
\v 16 Mgbe ụbọchị atọ gasịrị site na mgbe ụmụ Izrel na ndị Gibiọn gbara ndụ, ndị Izrel nụrụ na ndị Gibiọn bụ ndị agbataobi ha, ndị bi ha nso.  
\v 17 Ya mere, ndị Izrel buliri ije gaa ịchọpụta ebe ndị a si bịa, si otu a bịaruo obodo ha niile nʼụbọchị nke atọ. Aha obodo ha bụ Gibiọn, Kefira, Beerọt na Kiriat Jearim.  
\v 18 Ma ndị Izrel ebusoghị ha agha nʼihi na ndịisi nzukọ Izrel ejirila aha \nd Onyenwe anyị\nd*, Chineke Izrel ṅụọ iyi idebe ha ndụ. 
\p Ma nzukọ Izrel niile tamuru ntamu megide ndịisi ha nʼihi ọgbụgba ndụ a.  
\v 19 Ma ndịisi Izrel kwuru sị, “Anyị aṅụọla iyi nʼihu \nd Onyenwe anyị\nd*, Chineke Izrel sị, na anyị agaghị emetụ ha aka, ugbu a kwa anyị agaghị eme ha ihe ọbụla.  
\v 20 Ma nke a ka anyị ga-eme. Anyị ga-ekwe ka ha dị ndụ, nʼihi na ọ bụrụ na anyị emezughị iyi anyị ṅụrụ, iwe \nd Onyenwe anyị\nd* ga-adakwasị anyị niile.”  
\v 21 Ya mere, ndịisi kwukwara sị, “Anyị ga-ahapụ ha ka ha dịrị ndụ, kama ha ga-aghọ ohu ndị Izrel, ndị ga na-awara anyị nkụ na ndị ga na-ekutere anyị mmiri.” Nʼụzọ dị otu a, e mere ka ha dịrị ndụ. 
\p  
\v 22 Emesịa, Joshua ziri ozi kpọọ ndịisi obodo Gibiọn jụọ ha ajụjụ sị, “Gịnị mere unu ji ghọgbuo anyị site nʼịgwa anyị, ‘Anyị bi nʼebe dịpụrụ anya, site nʼebe unu bi,’ ebe ọ bụ na unu bi anyị nso?  
\v 23 Ugbu a, unu ga-abụ ndị a bụrụ ọnụ. Site nʼụbọchị taa gaa nʼihu, unu aghọọla ndị ohu anyị, ndị ga na-awara anyị nkụ mgbe niile, na ndị ga na-ekutere anyị mmiri nke anyị ga-eji rụọ ọrụ nʼụlọnsọ Chineke m.” 
\p  
\v 24 Ha zara Joshua sị, “Anyị mere nke a nʼihi na agwala anyị na \nd Onyenwe anyị\nd* Chineke gị nyere Mosis iwu sị ya merie ala ndị a niile, ma kpochapụ ndị niile bi nʼime ya. Ọ bụ nke a mere ụjọ ji tụọ anyị. Ọ bụkwa ya mere anyị ji mee ihe dị otu a, nʼihi ichebe ndụ anyị.  
\v 25 Ma ugbu a, anyị dị unu nʼaka. Unu nwere ike ime anyị ihe dị unu mma.” 
\p  
\v 26 Nʼihi nke a, Joshua ekweghị ka ndị Izrel gbuo ha.  
\v 27 Joshua mere ha ndị ọwa nkụ na ndị ose mmiri nye ụmụ Izrel, na ịhụkwa banyere ihe ndị dị mkpa nʼebe ịchụ aja \nd Onyenwe anyị\nd*, nʼebe ahụ \nd Onyenwe anyị\nd* ga-ahọpụta. Ọ bụkwa nke a ka ha bụ ruo taa. 
\c 10  
\s1 Nguzo nke anyanwụ 
\p  
\v 1 Mgbe Adoni-Zedek, eze Jerusalem nụrụ na Joshua emeriela Ai, laa ya nʼiyi, gbukwaa eze ya, dịka ọ lara Jeriko na eze ya nʼiyi, mgbe ọ hụkwara na ndị Gibiọn na ndị Izrel emeela udo, na ha bikwa nso ndị Izrel,  
\v 2 ọ tụrụ egwu nke ukwuu, ya na ndị ya. Nʼihi na Gibiọn bụ obodo a ma ama, dịka otu nʼime obodo ndị eze, ndị ikom ya bụkwa ndị dị ike, nʼihi na ọ dịkwa ukwuu karịa Ai. Ndị ikom ya niile maara otu e si ebu agha.  
\v 3 Ya mere, Adoni-Zedek, eze Jerusalem ziri ozi zigara eze ndị a: Homa, eze Hebrọn, Piram, eze Jamut, Jafia, eze Lakish, na Debịa, eze Eglọn, na-asị,  
\v 4 “Bịanụ nyere m aka, ka anyị gaa tigbuo Gibiọn, nʼihi na ha na Joshua na ụmụ Izrel emeela udo.” 
\p  
\v 5 Mgbe ahụ, eze ise ndị Amọrait ndị a, eze Jerusalem, na eze Hebrọn, na eze Jamut, na eze Lakish na eze Eglọn chịkọtara ndị agha. Ha na ndị agha ha gara were ọnọdụ ha imegide Gibiọn, ha lụsokwara ha ọgụ. 
\p  
\v 6 Ma ndị Gibiọn mere ngwangwa zigara Joshua ozi nʼụlọ ikwu dị na Gilgal sị ya, “Bịa nyere ndị ohu gị aka. Bịa ngwangwa zọpụta anyị, nʼihi na eze niile nke ndị Amọrait, ndị bi nʼugwu, abịala nʼebe a, ha na ndị agha ha ibuso anyị agha.”\f + \fr 10:6 \ft Ọgbụgba ndụ ahụ dị nʼetiti ụmụ Izrel na ndị Gibiọn, pụtara na Joshua ga na-enyere ha aka, nʼoge ọbụla e nwere ndị bịara ibuso ha agha.\f* 
\p  
\v 7 Joshua na ndị agha ya niile, tinyere ndị ahụ niile ibu agha were anya, hapụrụ Gilgal gawa ịzọpụta Gibiọn.  
\v 8 Ma \nd Onyenwe anyị\nd* gwara Joshua okwu sị ya, “Atụla ha egwu! Nʼihi na ha bụ ndị e meriri emeri. Enyela m ha nʼaka unu ịla ha nʼiyi. Ọ dịkwaghị otu onye nʼetiti ha nwere ike iguzo nʼihu unu.” 
\p  
\v 9 Joshua bịakwutere ha na mberede, nʼihi na ogologo abalị niile ka o si Gilgal gaa njem.  
\v 10 Mgbe ahụ, \nd Onyenwe anyị\nd* tinyere ha nʼọnọdụ ọgbaaghara mgbe ha zutere ndị Izrel. Nke a mere ka ndị agha Izrel lụgbuo ha na Gibiọn. Nʼezie, ọnụọgụgụ ndị ha tigburu na Gibiọn dị nnọọ ukwuu. Ma ha chụkwara ndị fọdụrụ ọsọ chụruo ha Bet-Horon, na Azeka, na Makeda, na-egbu ha nʼụzọ.  
\v 11 Mgbe ha si nʼihu Izrel gbapụ ọsọ nʼụzọ nrịda Bet-Horon na-aga Azeka, \nd Onyenwe anyị\nd* sitere nʼelu na-atụdakwasị ha ọtụtụ mkpụrụ mmiri. Ọnụọgụgụ ndị mkpụrụ mmiri ndị a dagburu dị ukwuu karịa ndị ụmụ Izrel ji mma agha ha gbuo. 
\p  
\v 12 Nʼụbọchị ahụ, \nd Onyenwe anyị\nd* mere ka ndị Izrel lụgbuo ndị Amọrait. Joshua gwara \nd Onyenwe anyị\nd* okwu nʼihu ndị Izrel niile sị, 
\q1 “Gị, anyanwụ, guzo nʼotu ebe na mbara eluigwe Gibiọn. 
\q2 Gị, ọnwa, guzokwa nʼotu ebe na mbara eluigwe na Ndagwurugwu Aijalon” 
\q1  
\v 13 Anyanwụ guzoro, 
\q2 ọnwa guzokwa. 
\q2 Ha abụọ adaghị tutu ruo mgbe ndị agha mba ahụ gbuchasịrị ndị iro ha. 
\m Ihe banyere akụkọ agha a ka e dere nʼakwụkwọ Jasha. 
\p Ya mere, anyanwụ guzoro nʼotu ebe nʼetiti mbara eluigwe. Ọ nọkwa nʼotu ebe ihe dịka otu ụbọchị zuru ezu.  
\v 14 O nweghị ụbọchị ọzọ dịka ụbọchị ahụ nʼoge niile gara aga. Ọ dịbekwaghị ụbọchị yiri ụbọchị ahụ ruo taa. Ọ bụ ụbọchị \nd Onyenwe anyị\nd* mere ka anyanwụ na ọnwa kwụsị, nʼihi naanị ekpere otu nwoke. Nʼihi na \nd Onyenwe anyị\nd* na-eburu Izrel agha. 
\p  
\v 15 Joshua na ndị Izrel niile laghachiri nʼọmụma ụlọ ikwu dị na Gilgal. 
\s1 Ogbugbu ndị eze Amọrị ise 
\p  
\v 16 Ma nʼoge ahụ a na-alụ agha ahụ, ndị eze ise ahụ si nʼọgbọ agha gbapụ, zoo onwe ha nʼime ọgba nkume dị na Makeda.  
\v 17 Mgbe ozi ruru Joshua ntị, na a chọtala eze ise ndị ahụ, ebe ha zoro onwe ha nʼime ọgba nkume dị na Makeda,  
\v 18 Joshua nyere iwu sị, “Werenụ nkume buru ibu mechie ọnụ ọgba nkume ahụ. Debekwanụ ndị nche nʼebe ahụ, ka ha chee ndị eze ahụ nche.  
\v 19 Ma unu eguzola nʼebe ahụ nʼonwe unu, chụsonụ ndị iro unu, na-egbukwanụ ha site nʼazụ. Unu ekwela ka ha gbaba nʼobodo ha dị iche iche, nʼihi na \nd Onyenwe anyị\nd* Chineke unu enyefeela ha nʼaka unu.” 
\p  
\v 20 Ya mere, Joshua na ndị Izrel tigbuchara ha kpamkpam nʼụzọ dị egwu, ọ bụ naanị mmadụ ole na ole nʼime ha nwere ike gbaba nʼime obodo ha e wusiri ike.  
\v 21 Ndị agha niile laghachikwuru Joshua nʼọmụma ụlọ ikwu ha dị na Makeda nʼudo. Ọ dịkwaghị onye ọbụla nwara anwa kwuo okwu megide ndị Izrel nʼala ahụ. 
\p  
\v 22 Mgbe ahụ Joshua sịrị, “Megheenụ ọnụ ọgba nkume ahụ, wepụtanụ ndị eze ise ahụ.”  
\v 23 Ya mere, ha kpọpụtara ndị eze ise ahụ site nʼọgba nkume ahụ, ha bụ eze Jerusalem, na eze Hebrọn, na eze Jamut, na eze Lakish, na eze Eglọn.  
\v 24 Mgbe a kpụtara ha nʼihu Joshua, ọ kpọrọ ndị ikom Izrel niile ka ha zụkọta, ọ gwara ndịisi agha bụ ndị so ya jee, “Bịanụ nso, zọkwasịnụ ụkwụ unu nʼolu eze ndị a.” Ya mere, ha bịara zọkwasị ụkwụ ha nʼolu ha. 
\p  
\v 25 Joshua sịrị ha, “Unu atụla egwu, maọbụ daa mba. Dịnụ ike, nweekwanụ ume, nʼihi na otu a ka \nd Onyenwe anyị\nd* ga-eme ndị iro unu niile bụ ndị na-ebuso unu agha.”  
\v 26 Emesịa, Joshua ji mma agha ya gbuo eze ise ndị a. Ọ kwụbara ha nʼelu osisi ise, ebe ha nọ ruo nʼoge anyasị. 
\p  
\v 27 Ma mgbe anwụ bidoro ịda, Joshua nyere iwu ka e site nʼosisi wedata ozu ndị eze ise ahụ, tụba ha nʼime ọgba nkume ahụ, ebe ha zoro onwe ha. Ha ji nkume dị ukwuu mechie ọnụ ọgba nkume ahụ. Nkume ukwuu ahụ dịkwa nʼebe ahụ ruo taa. 
\s1 Obodo ndị ọzọ Joshua lụgburu 
\p  
\v 28 Nʼotu ụbọchị ahụ, Joshua lara obodo Makeda nʼiyi, jiri mma agha gbuo eze ya, na onye ọbụla bi nʼime ya. Ọ dịkwaghị onye ọbụla nọ nʼime obodo ahụ ọ hapụrụ ndụ. Otu ihe ahụ o mere eze Jeriko ka o mere eze Makeda. 
\p  
\v 29 Joshua na ndị Izrel niile so ya sitere na Makeda gaa na Libna lụso ya agha.  
\v 30 \nd Onyenwe anyị\nd* nyekwara obodo a na eze ya nʼaka Izrel. Joshua weere mma agha ya tigbuo mmadụ niile dị nʼime ya. O nweghị onye ọbụla nke ọ hapụrụ ndụ nʼebe ahụ. O mekwara eze obodo a ihe o mere eze Jeriko. 
\p  
\v 31 Site na Libna, Joshua na ndị Izrel gara ruo Lakish, lụso ha agha.  
\v 32 Ma \nd Onyenwe anyị\nd* nyefere Lakish nʼaka ụmụ Izrel. Joshua lụgburu ya nʼụbọchị nke abụọ ya. Ha weere mma agha ha tigbuo mmadụ niile bi nʼime ya, dịka ha mere Libna.  
\v 33 Ma mgbe a na-alụ agha na Lakish, Horam eze Gaza, duuru ndị agha ya bịa inyere ndị obodo Lakish aka, ka ha si otu a gbochie ndị agha Izrel ịbata nʼime ya. Ma ndị agha Joshua gburu ya, laa ndị agha ya niile nʼiyi, ruo na ọ fọdụghị otu onye. 
\p  
\v 34 Emesịa, nʼụbọchị ahụ kwa, Joshua na ndị Izrel hapụrụ Lakish gaa Eglọn lụgbuo ya.  
\v 35 Ha were obodo ahụ nʼotu ụbọchị ahụ, jiri mma agha ha tigbuo mmadụ niile dị nʼime obodo ahụ, dịka ha mere na Lakish. 
\p  
\v 36 Mgbe Joshua na ndị Izrel sitere nʼEglọn pụọ, ha gara Hebrọn buso ya agha.  
\v 37 Ha weere obodo ahụ, jiri mma agha gbuo eze ha, na obodo nta niile gbara ya gburugburu. Ha gburu ndị mmadụ niile bi nʼime ya dịka ha mere nʼEglọn. Ọ dịkwaghị otu onye a hapụrụ ndụ. 
\p  
\v 38 Joshua na ndị Izrel niile ya na ha so laghachiri azụ gaa busoo Debịa agha.  
\v 39 Ha meriri obodo a, na obodo nta niile gbara ya gburugburu, na eze ya, jiri mma agha gbuchapụ ha niile, mmadụ niile nọ nʼime ya ka ha gburu kpamkpam. Ha ahapụghị onye ọbụla ndụ, ha mere Debịa na eze ya dịka ha mere Libna na eze ya, na Hebrọn kwa. 
\p  
\v 40 Ya mere, Joshua na ndị agha ya meriri obodo ahụ niile, na ala ahụ niile. O meriri eze niile nke obodo ugwu ahụ, na ndị bi na Negeb, na mgbada ala ugwu dị nʼọdịda anyanwụ, na mgbada ala ugwu ugwu ahụ. O gbuchara mmadụ niile bi nʼala ahụ, dịka \nd Onyenwe anyị\nd*, Chineke Izrel si nye ya iwu.  
\v 41 Joshua tigburu ha niile site na Kadesh Banea ruo Gaza, sitekwa na Goshen\f + \fr 10:41 \ft Ka anyị ghara iche na Goshen nke a, bụ otu ihe ya na nke ahụ dị nʼakụkụ mmiri nʼala Ijipt, nke a dị ndịda ala Palestia. \xt Jos 11:16; 15:51\f* ruo Gibiọn.  
\v 42 Eze ndị a niile, na ala ha niile, ka Joshua meriri nʼotu oge ibu agha, nʼihi na \nd Onyenwe anyị\nd*, Chineke Izrel na-alụrụ Izrel agha. 
\p  
\v 43 Emesịa, Joshua na ndị Izrel niile laghachiri nʼọmụma ụlọ ikwu ha dị na Gilgal. 
\c 11  
\s1 Mmeri nke ndị eze si nʼugwu 
\p  
\v 1 Mgbe Jabin eze Hazọ nụrụ nke a, o ziri ozi zigara Jobab eze ndị Madọn, zigakwara ndị eze obodo Shịmrọn na Akshaf,  
\v 2 na ndị eze bi nʼobodo ugwu ugwu, na ndị bi nʼime Araba, na ndịda Kineret, na ndagwurugwu ọdịda anyanwụ, na nʼime Nafọt Doa, nke dị nʼọdịda anyanwụ,  
\v 3 zigakwara eze ndị Kenan ndị bi nʼọwụwa anyanwụ, na ọdịda anyanwụ, zigakwara eze ndị Amọrait, na eze ndị Het, na eze ndị Periz, na nke ndị Jebus nke dị nʼala ugwu. O zigakwara eze ndị Hiv ndị bi na ndịda Hemon, na mpaghara Mizpa.  
\v 4 Ndị eze a niile kwekọrịtara chịkọtaa ndị agha ha niile nʼotu. Ndị agha ha chịkọtara dị ukwuu dịka aja dị nʼakụkụ osimiri. Ha ji ọtụtụ ịnyịnya na ọtụtụ ụgbọ agha.  
\v 5 Eze ndị a niile zukọrọ maa ụlọ ikwu ha nʼakụkụ mmiri Merọm, maka ibuso Izrel agha. 
\p  
\v 6 Ma \nd Onyenwe anyị\nd* sịrị Joshua, “Atụla ha egwu, nʼihi na echi, nʼoge dịka ugbu a, aga m ewere ha niile nʼọnọdụ ndị egburu egbu nyefee ha nʼaka Izrel. Ị ga-ebipụ nkwonkwo ụkwụ ịnyịnya ha niile, kpọọkwa ụgbọ agha ha niile ọkụ.” 
\p  
\v 7 Ya mere, Joshua na ndị agha ya niile bịaruru akụkụ mmiri Merọm na mberede, lụso ha agha.  
\v 8 \nd Onyenwe anyị\nd* nyefere ndị agha ha nʼaka ndị Izrel, ndị lụgburu ha, chụọ ha ọsọ ruo nʼoke ala Saịdọn, ruokwa ebe a na-akpọ Mizrefot Maim, na ruo nʼakụkụ ọwụwa anyanwụ, nʼime Ndagwurugwu Mizpa. Ya mere, o nweghị ọ bụladị otu onye iro a hapụrụ ndụ nʼagha ahụ.  
\v 9 Joshua na ndị agha ya mere ha ihe \nd Onyenwe anyị\nd* kwuru na a ga-eme ha. Ha gbupụrụ nkwonkwo ụkwụ ịnyịnya ha niile, surekwaa ụgbọ agha ha niile nʼọkụ. 
\p  
\v 10 Mgbe ahụ, Joshua laghachiri azụ busoo Hazọ agha merie ya, were mma agha gbuo eze ya, nʼihi na Hazọ bụrịị isi obodo alaeze ahụ niile.  
\v 11 Ha ji mma agha gbuo ndị niile bi nʼobodo ahụ, bibie ha kpamkpam, ọ dịghị onye a hapụrụ nke na-eku ume. O sukwara Hazọ ọkụ. 
\p  
\v 12 Joshua weere obodo niile nke ndị eze ahụ na ndị eze ha niile,\f + \fr 11:12 \ft \xt Dit 7:2; 20:16\f* jiri mma agha gbuchapụ ha. Ọ lakwara ha niile nʼiyi, dịka Mosis onyeozi \nd Onyenwe anyị\nd* nyere nʼiwu.  
\v 13 Ma ndị Izrel esughị obodo ọbụla nʼime ndị ahụ niile e wuru na mkputamkpu ala ọkụ, karịakwa obodo Hazọ, nke Joshua kpọrọ ọkụ.  
\v 14 Ihe niile a kwatara nʼagha nʼobodo ndị a, na anụ ụlọ ha niile, ka ndị Izrel weere. Ma ha gburu mmadụ niile. Ha ahapụghị ọ bụladị otu onye ndụ.  
\v 15 Nʼihi na nke a bụ iwu \nd Onyenwe anyị\nd* nyere Mosis onyeozi ya. Mosis nyekwara Joshua otu iwu a. Ugbu a Joshua emeela dịka a gwara ya. O mezuru ihe ndị a niile, bụ nke \nd Onyenwe anyị\nd* nyere Mosis nʼiwu. 
\p  
\v 16 Ya mere, Joshua meriri ala ahụ niile, bụ ala ugwu ugwu ahụ, na ala Negeb, na ala Goshen, na obosara ala ọdịda anyanwụ ahụ niile, na ala Araba, na ala ugwu ahụ niile, na ala ahụ dị na mgbada ugwu Izrel.  
\v 17 Nʼihi nke a, ala ndị Izrel nwere gbasara nʼụzọ niile site nʼugwu Halak, nke dị nso na Sia, ruo Baal-Gad nke dị na Ndagwurugwu Lebanọn, na ndịda ugwu Hemon. Joshua jidere ma gbukwaa ndị eze ndị ala ahụ niile.  
\v 18 O were Joshua ogologo oge imeri obodo ndị a niile na eze ha nʼagha.  
\v 19 Ọ dịkwaghị obodo ọzọ e mere ka ha na ụmụ Izrel dị nʼudo karịa naanị ndị Hiv, ndị bi na Gibiọn. Obodo ndị ọzọ niile ka a lara nʼiyi.  
\v 20 Nʼihi na ọ bụ \nd Onyenwe anyị\nd*, nʼonwe ya, mere ka ndị eze ahụ nyịchie obi ha, ka ha lụso Izrel agha, ka o si otu a laa ha nʼiyi, kpochapụkwa ha niile, na-emereghị ha amara, dịka \nd Onyenwe anyị\nd* nyere Mosis nʼiwu. 
\p  
\v 21 Nʼoge ahụ kwa, Joshua gara kpochapụ ndị Anak ahụ bi nʼala ugwu ugwu, ya bụ, na Hebrọn, na Debịa, na Anab, na ala ugwu ugwu Juda, na ala ugwu ugwu Izrel. O gburu ha niile, laa obodo ha nʼiyi.  
\v 22 Ọ dịkwaghị otu onye Anak a hapụrụ ndụ nʼoke ala Izrel niile, karịakwa ndị fọdụrụ na Gaza, na Gat, na nʼime Ashdọd. 
\p  
\v 23 Ya mere, Joshua meriri ala ahụ niile dịka \nd Onyenwe anyị\nd* si nye ya Mosis nʼiwu. O nyekwara ndị Izrel ala ahụ dịka ihe nketa ha. O kenyere ha ala ahụ dịka ebo ha si dị. Site nʼoge ahụ gaa nʼihu, ala ahụ dara jụụ. Ibu agha adịghịkwa nʼime ya ọzọ. 
\c 12  
\s1 Ọnụọgụgụ ndị eze e meriri 
\li4  
\v 1 Ndị a bụ ndị eze ala ndị ahụ ndị Izrel lara nʼiyi, bụ ala ndị ahụ ha nwetara nʼakụkụ ọwụwa anyanwụ osimiri Jọdan. Obodo niile a lara nʼiyi bụ ndị dị site na ndagwurugwu iyi Anọn ruo nʼugwu Hemon ha na akụkụ ọwụwa anyanwụ Araba. 
\b  
\li1  
\v 2 Saịhọn, eze ndị Amọrait, onye bi na Heshbọn. 
\li2 Ala ya gbatịrị site nʼAroea, nʼakụkụ ndagwurugwu Anọn, na nʼetiti ndagwurugwu iyi Anọn, ruo iyi Jabọk, nke bụ oke ala ụmụ Amọn. Ọkara ala Gilead, nke dị nʼugwu iyi Jabọk bụkwa ala ya. 
\li2  
\v 3 Ọ bụkwa Saịhọn na-achị akụkụ ọwụwa anyanwụ Araba site nʼosimiri Kineret ruo nʼosimiri Araba (ya bụ, Osimiri Nnu), ruo Bet-Jeshimọt, gbadaakwa akụkụ ndịda ndịda ruo na mgbada ugwu Pisga. 
\li1  
\v 4 Ha merikwara Ọg, eze Bashan, onye bụ otu nʼime ndị eze ikpeazụ ndị agbụrụ Refaim. Isi alaeze ya dị nʼAshtarọt na Edrei. 
\li2  
\v 5 Ọ chịrị nʼugwu Hemon, Saleka, ala Bashan niile ruo nʼoke ha na ndị Geshua na Maaka nwere, nakwa ọkara nke Gilead, bụ oke ala Saịhọn, bụ eze Heshbọn. 
\b  
\li4  
\v 6 Ọ bụ Mosis onyeozi \nd Onyenwe anyị\nd*, na ụmụ Izrel, lara eze abụọ ndị a nʼiyi. Mosis nyekwara ebo Ruben, na ebo Gad, na ọkara ebo Manase ala ha. 
\b  
\p  
\v 7 Ndị a bụ aha ndị eze niile Joshua na ụmụ Izrel meriri, nʼofe osimiri Jọdan, nʼakụkụ ọdịda anyanwụ, site na Baal-Gad nke dị na ndagwurugwu Lebanọn, ruo nʼugwu Halak nke dị na mgbago nʼụzọ Sia. Joshua nyere ebo Izrel niile ala ha ndị a dịka ihe nketa, nʼusoro dịka ebo ha si dị.  
\v 8 Ala ndị ọzọ bụkwa ala ugwu ugwu ahụ, na ala dị na mgbada ugwu ọdịda anyanwụ, na ala Araba, na ala ndị dị na mgbada ugwu, na ọzara, nakwa Negev. Ndị a bụ ala ndị Het, na ndị Amọrait, na ndị Kenan, ndị Periz, na ndị Hiv, na ndị Jebus. 
\b  
\li4 Ndị a bụ ndị eze ahụ: 
\b  
\li1  
\v 9 Eze Jeriko, otu 
\li1 eze Ai (nke dị nso na Betel), otu 
\li1  
\v 10 eze Jerusalem, otu 
\li1 eze Hebrọn, otu 
\li1  
\v 11 Eze Jamut, otu 
\li1 eze Lakish, otu 
\li1  
\v 12 eze Eglọn, otu 
\li1 eze Gaza, otu 
\li1  
\v 13 eze Debịa, otu 
\li1 eze Geda, otu 
\li1  
\v 14 eze Homa, otu 
\li1 eze Arad, otu 
\li1  
\v 15 eze Libna, otu 
\li1 eze Adulam, otu 
\li1  
\v 16 eze Makeda, otu 
\li1 eze Betel, otu 
\li1  
\v 17 eze Tapụọa, otu 
\li1 eze Hefa, otu 
\li1  
\v 18 eze Afek, otu 
\li1 eze Lasharọn, otu 
\li1  
\v 19 eze Madọn, otu 
\li1 eze Hazọ, otu 
\li1  
\v 20 eze Shịmrọn Meron, otu 
\li1 eze Akshaf, otu 
\li1  
\v 21 eze Teanak, otu 
\li1 eze Megido, otu 
\li1  
\v 22 eze Kedesh, otu 
\li1 eze Jokneam, nʼime Kamel, otu 
\li1  
\v 23 eze Doa, (nʼime obodo Naftod), otu 
\li1 eze Goiim, nʼime Gilgal,\f + \fr 12:23 \ft Ka o doo anyị anya nʼobodo Gilgal nke a, abụghị otu ihe ya na nke dị nso nʼobodo Jeriko.\f* otu 
\li1 na  
\v 24 eze Tịaza, otu. 
\b  
\li4 Ha niile dị ndị eze iri atọ na otu. 
\c 13  
\s1 Ala fọdụrụ 
\p  
\v 1 Nʼoge a, Joshua aghọọla agadi nwoke,\f + \fr 13:1 \ft Nʼoge a, Joshua agbaala ihe dịka iri afọ itoolu, maọbụ narị afọ, ebe Kaleb ga-adị ihe dịka iri afọ asatọ na ise. \xt Jos 14:10; 23:1-2; 24:29\f*\nd Onyenwe anyị\nd* kpọrọ ya sị ya, “Ugbu a, ị ghọọla agadi, ụbọchị ọgwụgwụ ndụ gị abịala nso, ma ọtụtụ ala fọdụrụ ndị a ga-emeri. 
\b  
\li4  
\v 2 “Ndị a bụ ala nke fọdụrụ unu ga-enweta: 
\b  
\li1 “ala ndị Filistia niile na ala ndị Geshua niile,\f + \fr 13:2 \ft Ndị Geshua biri nʼakụkụ ọnụ mmiri nʼoke ala Ijipt, na ndịda ala Filistia.\f* 
\v 3 site nʼosimiri Shaịho dị nʼọnụ Ijipt ruo nʼoke ala Ekrọn, nʼakụkụ ugwu ya, nke a gụnyere ndị Kenan, na ndịisi ise ndị Filistia: ndị Gaza, ndị Ashdọd, ndị Ashkelọn, ndị Gat, na ndị Ekrọn; 
\li1 nakwa ala ndị Ava,  
\v 4 site na ndịda ala ahụ niile dị nʼugwu; 
\li1 nʼala ndị Kenan, na Meara, nke bụ ala ndị Saịdọn, ruo nʼAfek, na oke ala ndị Amọrait; 
\li1  
\v 5 na ala ndị Gebal niile; 
\li1 na Lebanọn niile ruo nʼọwụwa anyanwụ, site Baal-Gad nʼokpuru ugwu Hemon ruo na mbata Hamat. 
\b  
\p  
\v 6 “Ndị niile bi nʼala ugwu site na Lebanọn ruo Mizrefot Maim, ya bụ, ndị Saịdọn niile, Mụ onwe m ga-achụpụ ha site nʼihu ụmụ Izrel. Ihe dịrị gị bụ ike ala ahụ ka ọ bụrụ ihe nketa nye ndị Izrel, dịka mụ onwe m nyere gị iwu.  
\v 7 Ya mere, kere ebo itoolu, na ọkara Manase, ala ndị a niile, ka ọ bụrụ ihe nketa ha.” 
\s1 Ala dị nʼọwụwa anyanwụ Jọdan 
\li4  
\v 8 Ọkara ebo Manase, na ebo Ruben, na Gad, enwetala ihe nketa ha nʼofe ọzọ nke Jọdan, nʼakụkụ ọwụwa anyanwụ, dịka Mosis onyeozi \nd Onyenwe anyị\nd* nyere ha. 
\li1  
\v 9 Ala ha gbatịrị site nʼAroea nke dị na ndagwurugwu Anọn, na site nʼobodo dị nʼetiti ndagwurugwu ahụ, ruo nʼala dị larịị nke gbatịrị site na Medeba ruo Dibọn.  
\v 10 Ọ gbatịkwara ruo nʼoke ala ndị Amọn, tinyere obodo niile nke Saịhọn, eze ndị Amọrait na-achị mgbe o bi na Heshbọn. 
\li1  
\v 11 Ọ gụnyekwara Gilead, nʼoke ala ndị Geshua, na ndị Maaka, na ugwu Hemon niile, na Bashan niile, ruokwa Saleka.  
\v 12 Ya bụ, obodo niile nke Ọg eze ndị Bashan na-achị, mgbe isi alaeze ya dị nʼAshtarọt na Edrei. (Ọ bụ eze ikpeazụ nʼagbụrụ ndị Refaim.) Mosis busoro Saịhọn na Ọg agha, tigbuo ha, napụkwa ha ala ha.  
\v 13 Ma ndị Izrel achụpụghị ndị Geshua na ndị Maaka, ya mere, ha nọgidere na-ebi nʼetiti ụmụ Izrel ruo taa. 
\b  
\li1  
\v 14 O nweghị ala o kenyere ebo Livayị. Nʼihi na \nd Onyenwe anyị\nd* kwere ha nkwa na ihe nketa ha ga-abụ ihe aja onyinye niile e si nʼọkụ na-ewetara Onyenwe anyị Chineke Izrel. 
\b  
\li4  
\v 15 Nke a bụ ala Mosis nyere ebo Ruben dịka agbụrụ ha si dị, ka ọ bụrụ ihe nketa ha. 
\li1  
\v 16 Ala ha gbatịrị site nʼAroea, na ndagwurugwu iyi Anọn, sitekwa nʼobodo dị nʼetiti ndagwurugwu ahụ na ala dị larịị gabiga gafee Medeba,  
\v 17 ruo Heshbọn, na obodo ndị ọzọ dị nʼala larịị ahụ, tinyere obodo Dibọn, na Bamot Baal, na Bet-Baal-Meon,  
\v 18 na Jahaz, na Kedemot, na Mefaat,  
\v 19 na Kiriatem, na Sibma, na Zeret Shaha, nke dị nʼugwu nta dị na ndagwurugwu ahụ;  
\v 20 na Bet-Peoa, na Bet-Jeshimọt, nke dị nʼebe dị na mgbada ugwu Pisga;  
\v 21 na obodo niile dị nʼala larịị ahụ, na ala Saịhọn niile, onye bụ eze ndị Amọrị nke chịrị na Heshbọn. Mosis lụgburu ya, lụgbukwaa ndịisi Midia bụ Evi, na nke Rekem, na nke Zua, na nke Hua, na nke Reba, ụmụ ndị eze ha na Saịhọn jikọtara aka buo agha.  
\v 22 Tinyere ndị ha gburu nʼọgbọ agha, ụmụ Izrel ji mma agha gbuo Belam nwa Beoa, onye na-agba aja. 
\li4  
\v 23 Ya mere, oke ala ebo Ruben dị nʼọnụ mmiri osimiri Jọdan. Obodo ukwu na obodo nta ndị a bụ ihe ha nwetara dịka ihe nketa ha. Ezinaụlọ ọbụla nwetakwara oke nke ha dịka ikwu ha si dị. 
\b  
\li4  
\v 24 Mosis nyekwara ebo Gad ala nke ha site nʼala ahụ ha lụgburu, dịka ikwu ha si dị. 
\li1  
\v 25 Ndị a bụ ala ebo Gad nwetara: ala ahụ niile dị na Jeza, na obodo Gilead niile, na ọkara ala ndị Amọn nke ruru Areoa, nʼakụkụ Raba.  
\v 26 Na ala sitere Heshbọn ruo Ramat Mizpa, na Betonim, na sitekwa Mahanaim ruo oke ala Debịa.  
\v 27 Nʼime ndagwurugwu ala ha bụ Bet-Haram, na Bet-Nimra, na Sukọt, na Zafọn, na ala fọdụrụ nʼalaeze Saịhọn eze Heshbọn, nke dị nʼakụkụ ọwụwa anyanwụ osimiri Jọdan nʼoke ala ya ruokwa nsọtụ osimiri Galili.\f + \fr 13:27 \ft Osimiri Galili bụkwa Osimiri Kineret\f* 
\li4  
\v 28 Obodo ndị a na obodo nta ndị ọzọ bụ ihe nketa ụmụ Gad dịka agbụrụ ha si dị. 
\b  
\li4  
\v 29 Mosis nyekwara ikwu ọbụla dị nʼọkara ebo Manase ala nke ha, dịka mkpa ha si dị. 
\li1  
\v 30 Ala ha ketara gbatịrị ruo Mahanaim. Ọ bụ ha nwekwa ala Bashan niile, na ala niile Ọg, eze Bashan, na-achị, tinyere iri obodo nta isii dị na Bashan, nke Jaịa wuru. Ha nwetakwara  
\v 31 ọkara Gilead, na Ashtarọt, na Edrei bụ isi obodo alaeze Ọg nʼime Bashan. 
\li4 Ala ndị a niile ka e nyere ọkara ebo Manase, ya bụ ikwu niile e nwere site nʼụmụ Makia, ọkpara Manase. 
\b  
\li4  
\v 32 Ndị a bụ otu Mosis si keere ụmụ Izrel ala dị nʼakụkụ ọwụwa anyanwụ osimiri Jọdan, mgbe ụmụ Izrel mara ụlọ ikwu ha nʼobosara ala Moab, na ncherita ihu obodo Jeriko.  
\v 33 Ma Mosis enyeghị ebo Livayị ala ọbụla, nʼihi na ọ gwara ha na \nd Onyenwe anyị\nd*, Chineke Izrel bụ ihe nketa ha nwere, dịka o kwere ha na nkwa. 
\c 14  
\s1 Okike ala dị nʼọwụwa anyanwụ Jọdan 
\p  
\v 1 Otu a ka esi kenye ndị Izrel ala Kenan, bụ nke Elieza onye nchụaja,\f + \fr 14:1 \ft Elieza bụ nwa Erọn. \xt Ọpụ 6:23; 28:1\f* na Joshua, nwa Nun, na ndị ndu ikwu niile dị nʼebo Izrel kere.  
\v 2 Ebo ọbụla nʼime ebo itoolu na ọkara ahụ fọdụrụ nwetara ihe nketa ha site nʼife nza, dịka \nd Onyenwe anyị\nd* nyere ya Mosis nʼiwu.  
\v 3 Ma Mosis enyelarị ebo abụọ na ọkara ala nke ha nʼofe ọzọ nke osimiri Jọdan, nʼakụkụ ọdịda anyanwụ. Ma o kenyeghị ndị Livayị ihe nketa ọbụla nʼetiti ha.  
\v 4 Nʼihi na ụmụ Josef dị ebo abụọ, ya bụ Manase na Ifrem.\f + \fr 14:4 \ft Jekọb mere ụmụ ndị ikom abụọ a mụtara Josef nʼala Ijipt ndị nke ya, ị ga-agụta nke a nʼakwụkwọ \xt Jen 48:5\ft  Nʼihi ọnọdụ ọhụrụ a ha nwere dịka ụmụ Jekọb, o nyere ha ikike i keta oke nʼihe o nwere, dịka ụmụ ya ndị ọzọ si keta.\f* Enyeghị ndị Livayị oke nʼala ahụ, karịa obodo ụfọdụ ebe ha ga-ebi na ebe ịta nri nke anụ ụlọ ha.  
\v 5 Ndị Izrel keere ala ahụ nʼusoro dịka iwu \nd Onyenwe anyị\nd* nyere Mosis si dị. 
\s1 Ala Kaleb ketara 
\p  
\v 6 Nʼoge a, ụmụ Juda zipụrụ ndị ozi ndị jekwuuru Joshua na Gilgal. Kaleb, nwa Jefune, onye Keniz so ha nʼije a. Mgbe ha bịarutere, Kaleb gwara Joshua okwu sị ya, “I chetakwara okwu ahụ \nd Onyenwe anyị\nd* gwara Mosis onye nke Chineke banyere gị na banyere mụ onwe m, mgbe anyị nọ na Kadesh Banea?  
\v 7 Agbara m iri afọ anọ nʼoge ahụ Mosis onyeozi \nd Onyenwe anyị\nd* si na Kadesh Banea zipụ anyị ịga iledo ala ndị Kenan anya. Mgbe anyị lọghachiri, agwara m ya okwu, kọwaara ya ihe m chere nʼobi m bụ eziokwu.  
\v 8 Ma ụmụnna anyị, ndị anyị na ha so gaa, menyere ụmụ Izrel egwu, mee ka obi ha daa mba ịchọ ịbanye nʼala ahụ e kwere anyị na nkwa. Ma ebe m nọgidere jiri obi m niile soro \nd Onyenwe anyị\nd* Chineke m,  
\v 9 Mosis ṅụrụ iyi sị m, ‘Ebe ọ bụ na i ji obi gị niile soro \nd Onyenwe anyị\nd* Chineke m, ala ahụ i jegharịrị ije nʼelu ya ga-abụ ihe nketa nye gị na ụmụ gị ruo mgbe ebighị ebi.’ 
\p  
\v 10 “Ugbu a, dịka \nd Onyenwe anyị\nd* kwere na nkwa, o meela ka m dị ndụ. Nke a bụ iri afọ anọ na ise kemgbe \nd Onyenwe anyị\nd* gwara Mosis okwu ndị a, mgbe Izrel na-awagharị nʼọzara. Ma ugbu a, lee, agbaala m iri afọ asatọ na ise taa.  
\v 11 M dị ike taa dịka m dị nʼụbọchị ahụ Mosis zipụrụ m. Dịka ike m dị mgbe ahụ, adịkwa m ike ugbu a, ịpụ buo agha ma batakwa  
\v 12 Ya mere, nye m ala ugwu ugwu ahụ \nd Onyenwe anyị\nd* kwere m nkwa nʼụbọchị ahụ. Gị onwe gị nụrụ nʼoge ahụ na ụmụ Anak bi nʼebe ahụ, na obodo ha bukwara ibu, na e jikwa mgbidi e wusiri ike gbaa ha gburugburu. Ma site nʼinyeaka \nd Onyenwe anyị\nd*, aga m achụpụ ha dịka \nd Onyenwe anyị\nd* kwuru.” 
\p  
\v 13 Nʼihi nke a, Joshua gọziri Kaleb nwa Jefune. O nyere ya obodo Hebrọn ka ọ bụrụ ihe nketa ya.  
\v 14 Ya mere, obodo Hebrọn ghọrọ ihe nketa Kaleb nwa Jefune onye Keniz bido mgbe ahụ, nʼihi na o ji obi ya niile soro \nd Onyenwe anyị\nd*, Chineke Izrel.  
\v 15 Tupu oge a, aha a na-akpọ Hebrọn bụ Kiriat Aaba, nke pụtara Obodo Aaba. Aaba bụkwa aha nwoke kachasị ịdị ukwuu nʼetiti ndị Anak niile. 
\p Site nʼoge a gaa nʼihu, e nwere udo nʼala ahụ niile. 
\c 15  
\s1 Oke ndị Juda 
\li4  
\v 1 Ala ndị a ka e nyere ndị Juda dịka ikwu dị nʼebo ahụ si dị. Ikwu ọbụla ketara ala nke ha site nʼife nza. Ala Juda gbatịrị nnọọ ruo nʼoke ala Edọm, gbatịakwa ruo nʼọzara Zin, kwụsị nʼọnụ ọnụ ndịda ọzara a. 
\b  
\li1  
\v 2 Nʼakụkụ ndịda, oke ala ha malitere nʼọnụ ọnụ ndịda osimiri Nnu.\f + \fr 15:2 \ft Maọbụ, \fqa Osimiri Nwụrụ anwụ.\f* 
\v 3 Site nʼebe akụkụ ndịda nrigo Akrabim, gafee ruo nʼọzara Zin, ma rigoo nʼakụkụ nke ndịda Kadesh Banea, gafee Hezrọn rigoruo na Aada, gba gburugburu gaa Kaka;  
\v 4 site nʼebe ahụ ruo Azmọn, pụọ gbasoro iyi dị nʼoke ala ndị Ijipt gagide ruo nʼosimiri Mediterenịa. Nke a bụ oke ala nʼebe ndịda. 
\li1  
\v 5 Oke ala ha nʼọwụwa anyanwụ bụ oke osimiri Nnu, ruo nʼọnụ mmiri osimiri Jọdan. 
\li1 Oke ala ha nʼakụkụ ugwu bidoro nʼọnụ mmiri osimiri Jọdan,  
\v 6 gbatịrị ruo Bet-Hogla, ma ruo nʼugwu Bet-Araba,\f + \fr 15:6 \ft Maọbụ, \fqa Osimiri Mediterenịa \xt Ọnụ 34:14\f* rukwaa na nkume Bohan, nwa Ruben.  
\v 7 Site nʼebe ahụ, ọ gbatịrị ruo na Ndagwurugwu Akọ na Debịa, tụgharịa gbatịrịkwa ruo Gilgal, na ncherita ihu ala ala Adumim nke dị nʼakụkụ ndịda ndagwurugwu ahụ. Site nʼebe ahụ ọ gbatịrị ruo na mmiri En-Shemesh, kwụsị na En-Rogel.  
\v 8 Oke ala ahụ gbagoro Ndagwurugwu nke Ben Hinom, rukwaa nʼakụkụ ndịda Jebus nʼebe e wuru obodo Jerusalem. Oke ala ahụ sitekwara ebe ahụ gbagoo ruo nʼelu dị nʼakụkụ ọdịda anyanwụ nke Ndagwurugwu Hinom, na nsọtụ ugwu nke Ndagwurugwu Refaim.  
\v 9 Site nʼelu ugwu ebe ahụ, oke ala ahụ gbatịrị ruo na mmiri ime ala Neftoa, pụta site nʼebe ahụ ruo obodo niile dị nso ugwu Efrọn. Site nʼEfrọn, oke ala ahụ gbadara ruo Baala (nke aha ya ọzọ bụ Kiriat Jearim).  
\v 10 Oke ala ahụ mere dịka ọ ga-agba Baala gburugburu nʼakụkụ ọdịda anyanwụ, site nʼebe ahụ pụta nʼugwu Sia, sitekwa nʼebe ahụ ruo nʼakụkụ ugwu Jearim (ya bụ Kesalon), gbatịa ruo na ndịda Bet-Shemesh, gafee ruo nʼọdịda anyanwụ oke ala Timna.  
\v 11 O sikwara ebe ahụ ruo ndịda ugwu Ekrọn, tụgharịa ruo Shikerọn, gafee ya, ruo nʼugwu Baala, sitekwa nʼebe ahụ ruo Jabneel, oke ala ahụ kwụsịrị nʼosimiri. 
\li1  
\v 12 Oke ala ha nʼakụkụ ọdịda anyanwụ bụ ọnụ mmiri osimiri Mediterenịa. 
\b  
\li4 Ndị a bụ oke ala gbara ndị Juda gburugburu dịka ikwu ha niile si dị. 
\b  
\s1 Kaleb emerie Hebrọn na Debịa 
\p  
\v 13 Dịka iwu \nd Onyenwe anyị\nd* nyere si dị, Joshua nyere Kaleb nwa Jefune oke nʼetiti ndị Juda. O kenyere ya Kiriat Aaba, ya bụ, Hebrọn. Aaba bụ nna nna Anak.  
\v 14 Kaleb sitere nʼobodo Hebrọn chụpụ ndị ikom atọ, bụ Sheshai, na Ahiman, na Talmai, ụmụ Anak nʼala ha.  
\v 15 O si nʼebe ahụ bilie ịlụso ndị bi na Debịa ọgụ. Nke a na-akpọ Kiriat Sefa nʼoge mbụ.  
\v 16 Kaleb sịrị, “Nwoke ọbụla ga-aga busoo Kiriat Sefa agha ma merie ya ka m ga-akpọnye Aksa, bụ nwa m nwanyị ka ọ bụrụ nwunye ya.”  
\v 17 Ya mere, Otniel, nwa Kenaz, nwa nwanne Kaleb, lụgburu obodo ahụ nʼagha. Nʼihi nke a, Kaleb kpọnyere ya Aksa, bụ nwa ya nwanyị ka ọ bụrụ nwunye ya. 
\p  
\v 18 Otu ụbọchị, mgbe Aksa bịakwutere Otniel, ọ kwagidere ya ka ọ rịọọ ala ubi site nʼaka nna ya.\f + \fr 15:18 \ft \xt Nkp 1:14\f* Mgbe Aksa si nʼelu ịnyịnya ibu ya rịdata, Kaleb jụrụ ya sị, “Gịnị ka ị chọrọ ka m mere gị?” 
\p  
\v 19 Ọ zaghachiri, “Nyem onyinye pụrụ iche. Ebe ọ bụ na i nyela m ala Negev, biko nyekwa m isi mmiri ụfọdụ.” Nʼihi nke a, Kaleb nyere ya isi mmiri mgbago na isi mmiri nke ndịda. 
\b  
\li4  
\v 20 Nke a bụ ihe nketa ebo Juda dịka ikwu ha niile si dị. 
\b  
\li1  
\v 21 Obodo niile nke ndị ebo Juda dị na Negev, nʼakụkụ ndịda nʼoke ala Edọm bụ ndị a: 
\li2 Kabzeel, Eda, Jaguo,  
\v 22 Kina, Dimona, Adada,  
\v 23 Kedesh, Hazọ, Itnan,  
\v 24 Zif, Telem, Bealot,  
\v 25 Hazọ Hadata, Keriọt Hezrọn (ya bụ Hazoa),  
\v 26 Amam, Shema, na Molada,  
\v 27 Haza Gada, Heshmọn, Bet-Pelet,  
\v 28 Haza Shual, Bịasheba, Biziotịa,  
\v 29 Baala, Iyim, Ezem,  
\v 30 Eltolad, Kesil, Homa,  
\v 31 Ziklag, Madmanna, Sansanna,  
\v 32 Lebaot, Shilhim, Ain na Rimọn. Ọnụọgụgụ obodo ndị a dị iri abụọ na itoolu. Obodo nta ndị ọzọ gbara ha niile gburugburu. 
\li1  
\v 33 Obodo niile ndị a dị na ndịda ugwu ka e nyekwara ebo Juda. Obodo ndị a bụ, 
\li2 Eshtaol, Zora, Ashna,  
\v 34 Zanoa, En-Ganim, Tapụọa, Enam,  
\v 35 Jamut, Adulam, Soko, Azeka,  
\v 36 Shaaraim, Aditaịm na Gedera (maọbụ Gederotaịm). Ha niile dị obodo iri na anọ. Obodo nta ndị ọzọ gbakwara ha gburugburu. 
\li2  
\v 37 Ebo Juda ketara Zenan, Hadasha, Migdal Gad,  
\v 38 Dilean, Mizpa, Jekteel,  
\v 39 Lakish, Bozkat, Eglọn,  
\v 40 Kabọn, Laamam, Kitlish,  
\v 41 Gederọt, Bet-Dagọn, Naama na Makeda. Obodo ndị a dị iri na isii, tinyekwara obodo nta ha. Ndị Juda ketakwara: 
\li2  
\v 42 Libna, Eta, Ashan  
\v 43 Ifta, Ashna, Nezib,  
\v 44 Keila, Akzib na Maresha. Ha niile dị obodo itoolu, tinyekwara obodo nta ha niile. 
\li2  
\v 45 Ha ketakwara Ekrọn, na obodo nta ya niile.  
\v 46 Ọ bụ ha nwekwa obodo niile dị nʼakụkụ ọdịda anyanwụ Ekrọn, ndị dị nso nso Ashdọd, na obodo nta niile dị ha nso.  
\v 47 Ma Ashdọd nʼonwe ya, na ụmụ obodo nta ya niile, na Gaza na obodo nta ya niile, ruo nʼiyi Ijipt, na ruo nʼoke osimiri Mediterenịa. 
\li1  
\v 48 Ha nwetakwara ala ndị dị nʼugwu ugwu bụ, 
\li2 Shamia, Jatịa, Sokoh,  
\v 49 Dana, Kiriat-Sana (ya bụ Debịa),  
\v 50 Anab, Eshtemo, Anim,  
\v 51 Goshen, Họlọn na Gailo, ha niile dị obodo iri na otu tinyere obodo nta ha niile. 
\li2  
\v 52 Obodo ndị ọzọ bụ Arab, Duma, Eshan,  
\v 53 Janim, Bet-Tapụọa, Afeka,  
\v 54 Humta, Kiriat Aba nke bụ Hebrọn na Zior, obodo itoolu tinyere obodo nta ha niile. 
\li2  
\v 55 Maon, Kamel, Zif, Juta,  
\v 56 Jezril, na Jokdeam, Zanoa,  
\v 57 Kain, Gibea na Timna, obodo iri tinyere obodo nta ha niile. 
\li2  
\v 58 Halhaul, Bet Zoa, Gedoa,  
\v 59 Maarat, Bet-Anot na Eltekọn, obodo isii tinyere obodo nta ha niile. 
\li2  
\v 60 Kiriat Baal, ya bụ, Kiriat Jearim na Raba, obodo abụọ tinyere obodo nta ha niile. 
\li1  
\v 61 Obodo ha ndị dị nʼọzara bụ ndị a: 
\li2 Bet-Araba, Midin, Sekaka,  
\v 62 Nibshan, Obodo Nnu na En-Gedi, obodo isii tinyere obodo nta ha niile. 
\b  
\p  
\v 63 Ma ebo Juda enweghị ike ịchụpụ ndị Jebus bi nʼime Jerusalem; ruo taa ndị Jebus bi na Jerusalem, nʼetiti ụmụ Juda. 
\c 16  
\s1 Oke Ifrem na Manase 
\li1  
\v 1 Ala e kenyere ụmụ ụmụ Josef bidoro nʼosimiri Jọdan nʼakụkụ ọwụwa anyanwụ Jeriko gbatịrị ruo nʼọzara. O sitere na Jeriko gbagoo ala ugwu ugwu ahụ, ruokwa Betel.  
\v 2 O sitekwara Betel (ya bụ Luz), gafee ruo Atarọt, ebe ndị Akai bi.  
\v 3 Site nʼebe ahụ, ọ gbatịrị nʼakụkụ ọdịda anyanwụ rute ala ndị Jaflet, ruo ala mgbada mgbada Bet-Horon. O si nʼebe ahụ ruo Gaza, tutu kwụsị nʼosimiri Mediterenịa. 
\b  
\li4  
\v 4 Ụmụ Josef bụ Ifrem, na Manase nwetara ihe nketa ha. 
\b  
\b  
\s1 Ebo Ifrem 
\li4  
\v 5 Ndị a bụ ala nke ikwu dị iche iche dị nʼebo Ifrem nwetara. 
\b  
\li1 Oke ala ha nʼakụkụ ọwụwa anyanwụ malitere nʼAtarọt-Ada. Site nʼebe ahụ, o ruru nʼakụkụ elu elu Bet-Horon;  
\v 6 sitekwa nʼebe ahụ ruo nʼosimiri Mediterenịa. Oke ala ha nʼakụkụ ugwu malitere na Mikmetat, gafee nʼakụkụ ọwụwa anyanwụ ruo Taanat Shaịlo, gafee ya ruo na Janoa.  
\v 7 O sitere na Janoa gbadaa ruo Atarọt, na Naara, bịaruo Jeriko, gafee, kwụsị nʼosimiri Jọdan.  
\v 8 Oke ala ahụ nʼakụkụ ọdịda anyanwụ sitere na Tapụọa gaa ruo iyi Kana, na ruo nʼosimiri Mediterenịa. Nke a bụ ala ebo Ifrem ketara, dịka ikwu ha si dị. 
\li1  
\v 9 E tinyere obodo ukwu na obodo nta niile ekepụtara iche nʼihi ebo Ifrem nʼetiti ihe nketa ụmụ Manase. 
\b  
\p  
\v 10 Ma ha achụpụghị ndị Kenan ndị bi na Gaza.\f + \fr 16:10 \ft \xt Jos 15:63; 17:12-13; Nkp 1:29\f* Nʼihi nke a, ndị Kenan binyere ndị Ifrem ruo taa, ma e mere ka ha bụrụ ndị ọrụ ngo. 
\c 17  
\s1 Ọkara ebo Manase 
\p  
\v 1 Nke a bụ oke e kenyere ndị ebo Manase, bụ ọkpara Josef, ya bụ Makia ọkpara Manase, onye bụ nna nna ndị Gilead. Onye natara ala Gilead na Bashan, nʼihi na ndị agbụrụ Makia bụ dike nʼagha.  
\v 2 Ya mere, oke a dịịrị ndị fọdụrụ nʼebo Manase dịka ezinaụlọ ha si dị. Agbụrụ Abieza, Helek, Asriel, Shekem, Hefa na Shemida. Ndị a bụ ụmụ ndị ikom agbụrụ Manase, nwa Josef, dịka ikwu ha si dị. 
\p  
\v 3 Ma Zelofehad, nwa Hefa, nwa Gilead, nwa Makia, nwa Manase, amụtaghị ụmụ ndị ikom kama ọ mụtara naanị ụmụ ndị inyom, ndị aha ha bụ nke a: Mahla, Noa, Hogla, Milka na Tịaza.  
\v 4 Ndị inyom ndị a bịakwutere Elieza, onye nchụaja na Joshua nwa Nun, nʼihu ndị ndu ụmụ Izrel niile sị ha, “\nd Onyenwe anyị\nd* gwara Mosis sị ya kenye anyị ala nke anyị, dịka o si kenye ụmụ ndị ikom ikwu anyị.” Ya mere, dịka \nd Onyenwe anyị\nd* nyere ya Mosis nʼiwu, Joshua nyere ha ihe nketa ruuru ha nʼetiti ụmụnne nna ha, dịka ndị ọzọ si keta.  
\v 5 Manase chịtara ala oke iri, tinyere Gilead, na Bashan nke dị nʼakụkụ ọwụwa anyanwụ Jọdan,  
\v 6 nʼihi na e mere ka ndị inyom Manase keta oke nʼetiti ndị ikom ebo Manase. Ala fọdụrụ na Gilead bụ ndị ikom ebo Manase nwe ya. 
\b  
\li1  
\v 7 Oke ala ebo Manase gbatịrị site nʼAsha ruo na Mikmetat, nke dị nʼakụkụ ọwụwa anyanwụ Shekem. Ọ gbatịkwara nʼakụkụ ndịda site nʼebe ahụ tinyere ndị bi nʼala En-Tapụọa.  
\v 8 Ala dị gburugburu Tapụọa bụ ala ebo Manase, ma obodo Tapụọa nʼonwe ya, nke dị nʼoke ala ebo Manase, bụ obodo ebo Ifrem.  
\v 9 Oke ala ụmụ Manase gbatịrị ga ndịda ruo na mmiri iyi Kana. Ụfọdụ obodo ndị Ifrem dị nʼebe ahụ, nʼetiti obodo ndị Manase, kama oke ala ndị Manase nʼakụkụ ugwu iyi ahụ kwụsịrị nʼosimiri Mediterenịa.  
\v 10 Ala dị na ndịda bụ nke e kenyere Ifrem, ma ala mgbago ugwu bụ nke Manase. Ala ndị Manase gbatịrị ruo nʼosimiri Mediterenịa ma ha na ndị Asha nwekọrọ oke ala nʼakụkụ ugwu, ebe ha na ndị Isaka nwere oke ala nʼakụkụ ọwụwa anyanwụ. 
\li1  
\v 11 Manase ka e nyere obodo ndị a, nke dị nʼala e nyere Isaka na Asha: obodo Bet-Shan, na Ibleam, na Doa, na Endoa, na Teanak, na Megido, na obodo nta niile gbara ha gburugburu. Obodo nke atọ bụ Nafọt. 
\b  
\p  
\v 12 Ma ụmụ Manase enweghị ike ịchụpụ ndị Kenan bi nʼobodo ndị ahụ, nʼihi na ndị Kenan nọgidere bichie obodo ndị a.  
\v 13 Ma nʼikpeazụ, mgbe ụmụ Izrel ghọrọ ndị dị ike, ha achụpụghị ndị Kenan niile bi nʼobodo ndị a kpamkpam, kama ha mere ka ha bụrụ ndị na-ejere ụmụ Izrel ozi, dịka ndị ohu ha. 
\p  
\v 14 Ma ụmụ ụmụ Josef\f + \fr 17:14 \ft Ụmụ ụmụ Josef bụ ebo Ifrem na Manase \xt Jos 14:4\f* sịrị Joshua, “Gịnị mere i ji nye anyị naanị otu ụzọ ala ka ọ bụrụ ihe nketa anyị? Ị hụrụ na \nd Onyenwe anyị\nd* gọziri anyị mee ka ọnụọgụgụ anyị baa ụba.” 
\p  
\v 15 Joshua zara sị ha: “Ọ bụrụ na ala ugwu ugwu Ifrem agaghị ezuru unu nʼihi na unu bara ụba nʼọnụọgụgụ, gaanụ nʼoke ọhịa sụchasịa ala, nʼime ala ndị Periz, na nke ndị Refaim.” 
\p  
\v 16 Ụmụ Josef zara Joshua sị, “Ala ugwu ugwu a agaghị ezuru anyị. Ọzọ, ndị Kenan niile bi nʼala dị larịị nwere ụgbọala igwe, ma ndị niile bi na Bet-Shan, na ụmụ obodo nta ha na ndị bikwa na Ndagwurugwu Jezril.” 
\p  
\v 17 Ma Joshua zara ụmụ Josef, ya bụ, Ifrem na Manase, sị ha, “Unu dị ukwuu nʼọnụọgụgụ, bụrụkwa ndị dị ike, ọ bụghị naanị otu oke ka unu ga-eketa,  
\v 18 nʼihi na ala ugwu ugwu oke ọhịa ahụ bụkwa nke unu. Sụchaanụ ya, ruo na nsọtụ ya, ka ọ bụrụ nke unu. Ọ bụ ezie na ndị Kenan bi nʼime ya nwere ụgbọ agha igwe,\f + \fr 17:18 \ft \xt Dit 20:1\f* bụrụkwa ndị sịrị ike, unu nwere ike ịchụpụ ha.” 
\c 18  
\s1 Okike ala fọdụrụ 
\p  
\v 1 Ọgbakọ Izrel niile zukọtara na Shaịlo\f + \fr 18:1 \ft Obodo a nʼoge ochie, bụ isi obodo ebe ọchịchị ndị Izrel dị, nakwa ebe ha na-aga akpọ isiala nye Onyenwe anyị. Site Jerusalem jeruo ya bụ ihe ruru iri kilomita anọ. Ụlọ Ikwu ahụ dịgidere na Shaịlo ruo nʼoge Samuel bụ onyeisi nchụaja \xt 1Sa 4:1-11\ft , tutu ruo mgbe ebugara ya na Gibiọn. \xt Nkp 18:31; 1Ih 16:39; 21:29; Jer 7:12\f* maa ụlọ nzute nʼebe ahụ. Nʼoge a, ala ahụ niile bịara nʼokpuru ọchịchị ndị Izrel,  
\v 2 ma e nwekwara ebo Izrel asaa a na-ekenyebeghị ala nke ha dịka ihe nketa. 
\p  
\v 3 Ya mere, Joshua jụrụ ụmụ Izrel ajụjụ sị ha, “Ruo ole mgbe ka unu ga-eche tupu unu ekpochapụ ndị niile bi nʼala a, inweta ala \nd Onyenwe anyị\nd* Chineke nna nna unu nyere unu?  
\v 4 Họpụtanụ ndị ikom atọ site nʼebo ọbụla, ndị m ga-eziga ka ha gaa jegharịa nʼala niile ahụ, dee ya nʼakwụkwọ nkọwa otu ihe nketa ọbụla si dị, nʼakụkụ ya niile. Mgbe ahụ, ha ga-alọghachikwute m.  
\v 5 Ha ga-eke ala ahụ fọdụrụ ụzọ asaa. Ma ebo Juda ga-anọgide nʼala ha nʼakụkụ ndịda, ụmụ ụmụ Josef kwa ga-anọgide nʼala ha nʼakụkụ ugwu.  
\v 6 Unu depụtachaa ụzọ asaa ndị a nʼakwụkwọ, werenụ ya bịakwute m ka m feere unu nza nʼihu \nd Onyenwe anyị\nd* Chineke anyị ịchọpụta ebo ga-eketa akụkụ ọbụla nʼala ahụ.  
\v 7 Ma ndị Livayị agaghị eketa ala ọbụla nʼetiti unu, nʼihi na ihe nketa ha bụ ọrụ nchụaja ha na-arụ nʼihu \nd Onyenwe anyị\nd*. Ebo Gad, na Ruben, na ọkara ebo Manase agaghị enwetakwa oke ọzọ, nʼihi na ha anarala ihe nketa nke ha nʼofe Jọdan, nʼakụkụ ọwụwa anyanwụ, ebe Mosis onyeozi \nd Onyenwe anyị\nd* kwere ha na nkwa na ha ga-ebi.” 
\p  
\v 8 Ya mere, mgbe ndị ikom nledo ahụ gawara ijegharị nʼala ahụ niile, Joshua gwara ha okwu sị, “Jeenụ jegharịa nʼala ahụ niile. Depụtakwanụ otu unu chere a ga-esi kee ya nʼakwụkwọ. Mgbe unu lọtara aga m anọ nʼebe a bụ Shaịlo jụta \nd Onyenwe anyị\nd* ase site nʼife nza, chọpụta ala nke ebo ọbụla ga-eketa.”  
\v 9 Ndị ikom ahụ gabigara ala ahụ, depụta ya nʼakwụkwọ, nʼobodo nʼobodo dịka o si dị nʼoke asaa. Mgbe ha mesịrị nke a, ha lọghachikwutere Joshua nʼọmụma ụlọ ikwu nʼime Shaịlo. 
\b  
\li4  
\v 10 Joshua feere ha nza na Shaịlo nʼihu \nd Onyenwe anyị\nd*, nʼebe ahụ ka ọ nọ keere ndị Izrel ala ahụ dịka ebo ha si dị. 
\s1 Oke ụmụ Benjamin 
\li4  
\v 11 Ndị mbụ e kenyere ala site nʼife nza bụ ebo Benjamin dịka ikwu ha si dị. Ala niile e kenyere ebo Benjamin bụ nke dị nʼetiti ala e nyere ebo Juda na Josef. 
\li1  
\v 12 Oke ala ha nʼakụkụ ugwu sitere nʼosimiri Jọdan ruo nʼakụkụ ugwu Jeriko. Nʼọdịda anyanwụ o sitere na Jeriko ruo ala ugwu ugwu ahụ niile, ruokwa nʼọzara Bet-Aven.  
\v 13 Oke ala ahụ sitekwara nʼakụkụ ndịda ruo nʼakụkụ Luz (ebe a na-akpọkwa Betel), ruokwa Atarọt-Ada, nke dị nʼakụkụ ndịda ugwu dị na mgbada Bet-Horon. 
\li1  
\v 14 Site nʼugwu ahụ chere Bet-Horon ihu nʼakụkụ ndịda, oke ala ahụ gbadara ndịda gbasoro akụkụ ọdịda anyanwụ pụta na Kiriat Baal, ya bụ, Kiriat Jearim, otu nʼime obodo ndị Juda. Nke a bụ oke ala ahụ nʼọdịda anyanwụ. 
\li1  
\v 15 Oke ala ha na ndịda sitere na nsọtụ akụkụ Kiriat Jearim rute nʼisi iyi mmiri Neftoa.  
\v 16 O sitekwara nʼebe ahụ gbada ruo na ndịda ugwu ahụ nke chere ihu na Ndagwurugwu nke Ben Hinom, nʼakụkụ ugwu Ndagwurugwu nke Refaim. O sitekwara nʼebe ahụ gafee ruokwa nʼakụkụ ndịda ugwu obodo ndị Jebus, ruo En-Rogel.  
\v 17 Site nʼEn Rogel oke ala ahụ gbatịrị ruo En-Shemesh, gafee ruo Gelilọt, nke chere ihu na nrigo ugwu Adumim. O si nʼebe ahụ ruo na nkume Bohan, nwa Ruben.  
\v 18 O sitere nʼebe ahụ gafee nʼakụkụ ugwu Bet-Araba gbadata rute nʼAraba,  
\v 19 ọ gafere gbatịrị ruo nʼakụkụ Bet-Hogla na mgbago ugwu, pụta nʼakụkụ ugwu nke osimiri Nnu, nke bụ nʼakụkụ ndịda ọnụ mmiri osimiri Jọdan. Nke a bụ oke ala ha nʼakụkụ ndịda. 
\li1  
\v 20 Oke ala ha nʼakụkụ ọwụwa anyanwụ bụ osimiri Jọdan. 
\li4 Ndị a bụ ihe nketa ụmụ Benjamin, dịka oke ala ya niile si dị gburugburu, dị ka ikwu ya niile si dị nʼakụkụ niile. 
\b  
\li4  
\v 21 Ndị a bụ obodo e kenyere ebo Benjamin, dịka ikwu ha si dị: 
\li1 Jeriko, Bet-Hogla, Emek Keziz,  
\v 22 Bet-Araba, Zemaraim, Betel,  
\v 23 Avim, Para, Ofra,  
\v 24 Kefa Amoni, Ofni, Geba, obodo iri na abụọ na obodo nta ha ndị ọzọ. 
\li1  
\v 25 Na Gibiọn, Rema, Beerọt,  
\v 26 Mizpa, Kefira, Moza,  
\v 27 Rekem, Iapeel, Tarala,  
\v 28 Zela, Haelef na obodo ndị Jebus, nke aha ya bụ Jerusalem, Gibea na Kiriat Jearim, obodo iri na anọ na obodo nta niile gbara ha gburugburu. 
\li4 Ndị a bụ ihe nketa ụmụ Benjamin maka ikwu ya niile. 
\c 19  
\s1 Oke ụmụ Simiọn 
\li4  
\v 1 Ndị nke abụọ sitere nʼife nza nweta oke ha bụ ebo Simiọn dịka ikwu ha si dị. Ala ha ketara dị nʼime ala e kenyere ndị Juda.  
\v 2 Ihe nketa ụmụ Simiọn bụ ndị a: 
\li1 Bịasheba (maọbụ Sheba), Molada,  
\v 3 Haza Shual, Bala, Ezem,  
\v 4 Eltolad, Betul, Homa,  
\v 5 Ziklag, Bet-Makabot, Haza Susa,  
\v 6 Bet-Lebaot na Sharuhen, obodo iri na atọ na obodo nta ndị ọzọ gbara ha gburugburu. 
\li1  
\v 7 Na Ain, Rimọn, Eta na Ashan, obodo anọ na obodo nta ha,  
\v 8 tinyekwara obodo nta ndị ọzọ niile gbara obodo ukwu ndị a gburugburu, ruo obodo Baalat-Bịa, ya bụ (obodo Rema dị na Negev). 
\li4 Nke a bụ ihe nketa ebo Simiọn dịka ikwu ha si dị.  
\v 9 E sitere nʼoke ụmụ Juda wepụta oke ụmụ Simiọn, nʼihi na ihe ụmụ Juda ketara dị ukwuu karịa ihe ha kwesiri iketa. Ọ bụ nke a mere ụmụ Simiọn ji nweta ihe nketa site nʼetiti ala ndị Juda. 
\s1 Oke ụmụ Zebụlọn 
\li4  
\v 10 Ebo nke atọ nwetara ihe nketa ha site nʼife nza bụ ebo Zebụlọn dịka ikwu ha si dị. 
\li1 Ala ha nwetara gbatịrị ruo Sarid.  
\v 11 Site nʼebe ahụ, oke ala ahụ gbatịrị gaa nʼakụkụ ọdịda anyanwụ, ruo Marala na Dabeshet, rukwaa iyi dị nʼihu Jokneam.  
\v 12 O si na Sarid chigharịa ihu nʼakụkụ ọwụwa anyanwụ, oke ala ahụ ruru nʼoke ala Kislọt Teboa, gbagorokwa ruo Daberat, ruokwa Jafia.  
\v 13 Ọ gbatịkwara nʼakụkụ ọwụwa anyanwụ ruo Gat Hefa, Et Kazin na Rimọn, tụgharịa nʼụzọ e si aga Nea.  
\v 14 Nʼebe ahụ, ọ gara gburugburu nʼakụkụ ugwu ruo Hanatọn, ruokwa na Ndagwurugwu Ifta El ebe ọ sọtụrụ. 
\li1  
\v 15 Obodo ndị a niile dịkwa nʼime ihe nketa ụmụ Zebụlọn: Katat, Nahalal, Shịmrọn, Idala na Betlehem.\f + \fr 19:15 \ft Obodo Betlehem nke a, dị iche na Betlehem dị na Juda. \xt 1Sa 17:12; Rut 1:1\f* Obodo niile ndị a dị iri na abụọ, tinyere obodo nta niile gbara ha gburugburu. 
\li4  
\v 16 Obodo ndị a niile na obodo nta ha, so nʼala ụmụ Zebụlọn nwetara dịka ihe nketa ha, dịka ikwu ha si dị. 
\s1 Oke Ụmụ Isaka 
\li4  
\v 17 Ebo nke anọ sitere nʼife nza nweta ihe nketa ha bụ ụmụ Isaka dịka ikwu ha si dị.  
\v 18 Ala na obodo ha ketara bụ ndị a: 
\li1 Jezril, Kesulọt, Shunem,  
\v 19 Hafaraim, na Shịọn, Anaharat,  
\v 20 Rabit, Kishiọn, Ebez na  
\v 21 Remet, En-Ganim, En-Hada na Bet-Pazez. 
\li1  
\v 22 Oke ala ha ruru na Taboa, Shahazuma na Bet-Shemesh, ma kwụsị nʼosimiri Jọdan. 
\li1 Obodo ndị a niile dị iri na isii, tinyere obodo nta niile gbara ha gburugburu. 
\li4  
\v 23 Ya mere, obodo ukwu ndị a na obodo nta ha dị nʼala ahụ ebo Isaka nwetara dịka ihe nketa ha, dị ka ikwu ha si dị. 
\s1 Oke ụmụ Asha 
\li4  
\v 24 Ebo nke ise e kenyere ala site nʼife nza bụ ụmụ Asha dịka ikwu ha si dị.  
\v 25 Ala na obodo ha ketara bụ ndị a: 
\li1 Helkat, Hali, Beten, Akshaf,  
\v 26 Alamelek, Amad na Mishal. Oke ala ha nʼakụkụ ọdịda anyanwụ gbatịrị ruo Kamel na Shihoa-Libnat.  
\v 27 O sitere nʼebe ahụ tụgharịa nʼakụkụ ọwụwa anyanwụ gawa Bet-Dagọn, ma ruokwa Zebụlọn na Ndagwurugwu Ifta El, ma gbagoro ruokwa Bet-Emek na Neiel. O sikwa nʼebe ahụ gafee, ruo Kabul, nʼakụkụ aka ekpe.  
\v 28 Ọ gara ruo Ebrọn, Rehob, Hamọn na Kana, ruokwa ebe obodo Saịdọn gbasapụrụ.  
\v 29 Oke ala ahụ mere dịka ọ na-alaghachi azụ bịaruo Rema, ruokwa obodo e wusiri ike bụ Taịa, tụgharịakwa gawa Hosa pụta nʼọnụ mmiri osimiri Mediterenịa nke dị nʼakụkụ Akzib  
\v 30 na Umma, Afek na Rehob. 
\li1 Ọnụọgụgụ obodo ndị a niile bụ iri abụọ na abụọ tinyere obodo nta ha niile. 
\li4  
\v 31 Obodo ndị a na obodo nta ha niile dị nʼala ahụ ebo Asha nwetara dịka ihe nketa, dịka ikwu ha si dị. 
\s1 Oke ụmụ Naftalị 
\li4  
\v 32 Ebo nke isii e nyere ihe nketa site nʼife nza bụ ebo Naftalị, dịka ikwu ha si dị. 
\li1  
\v 33 Oke ala ha malitere na Helef ruo nʼosisi ukwu dị na Zaananim, Adami Nekeb na Jabneel, gafee ruo Lakum, kwụsị nʼosimiri Jọdan.  
\v 34 Site nʼebe ahụ oke ala ha gara nʼakụkụ ọdịda anyanwụ ruo Aznot Tabo, site nʼebe ahụ ruo Hukọk, rute Zebụlọn na ndịda, na Asha nʼọdịda anyanwụ, ruokwa Juda nʼakụkụ ọwụwa anyanwụ Jọdan. 
\li1  
\v 35 Obodo niile e wusiri ike e kenyere ha bụ ndị a: Zidim, Zea, Hamat, Rakat, Kineret,  
\v 36 Adama, Rema, Hazọ,  
\v 37 Kedesh, Edrei, En-Hazoa,  
\v 38 Iron,\f + \fr 19:38 \ft Maọbụ, \fqa Yiron\f* Migdal El, Horem, Bet-Anat na Bet-Shemesh. 
\li1 Ya mere, ọnụọgụgụ obodo ndị a niile bụ iri na itoolu, tinyere obodo nta niile gbara ha gburugburu. 
\li4  
\v 39 Obodo ndị a na obodo nta ha niile ka ebo Naftalị dịka ikwu ha si dị, nwetara dịka ihe nketa ha. 
\s1 Oke ụmụ Dan 
\li4  
\v 40 Site nʼife nza ebo Dan, bụ ebo nke asaa nwetara ihe nketa dịka ikwu ha si dị.  
\v 41 Oke ala ihe nketa ha bụ ndị a: 
\li1 Zora, Eshtaol, Ia-Shemesh,  
\v 42 Shaalabin, Aijalon, Itla,  
\v 43 Elọn, Timna, Ekrọn,  
\v 44 Elteke, Gibeton, Baalat,  
\v 45 Jehud, Bene-Berak, Gat Rimọn,  
\v 46 Me-Jakọn na Rakọn, obodo dị nʼoke ala, na ncherita ihu Jopa. 
\li4  
\v 47 Mgbe oke ala ụmụ Dan ketara sitere nʼaka ha pụọ. Ha gara buso obodo Leshem agha merie ha, were mma agha tigbuo ndị niile bi nʼime ya, bichie ya. Ha kpọrọ obodo ahụ Dan, nke bụ aha nna nna ha ochie. 
\li4  
\v 48 Obodo ndị a na obodo nta ha bụ ihe nketa ebo Dan nwetara dịka ikwu ha si dị. 
\s1 Oke Joshua 
\li1  
\v 49 Mgbe e kechara ala ahụ niile, nye ebo ọbụla ala dịka ọnụọgụgụ ha niile si dị, ụmụ Izrel nyere Joshua, nwa Nun ihe nketa ha nʼetiti ha.  
\v 50 Nʼihi na \nd Onyenwe anyị\nd* ekwuola na Joshua nwere ike iwere ala ọbụla ọ chọrọ. Ya mere, ha nyere Joshua obodo Timnat Sera nke dị nʼugwu Ifrem. Joshua wugharịrị obodo ahụ biri nʼime ya. 
\b  
\li4  
\v 51 Ndị a bụ oke ala nke Elieza onye nchụaja, Joshua nwa Nun na ndịisi ụlọ ebo ụmụ Izrel, kere na Shaịlo site nʼife nza nʼihu \nd Onyenwe anyị\nd*, nʼọnụ ụzọ ụlọ nzute. Ha si otu a kebie ala ahụ. 
\c 20  
\s1 Obodo mgbaba 
\p  
\v 1 Mgbe ahụ, \nd Onyenwe anyị\nd* gwara Joshua okwu sị ya,  
\v 2 “Gwa ụmụ Izrel okwu sị ha họpụtara onwe unu obodo mgbaba dịka m gwara unu site nʼaka Mosis.  
\v 3 Ka obodo ndị a bụrụ ebe onye gburu mmadụ nʼọghọm na-amaghị ama ga-agbaga nʼihi izere ndụ ya site nʼaka onye ahụ ga-achọ ịbọrọ ọbọ ọchụ.  
\v 4 Mgbe onye gburu mmadụ ahụ na-amaghị ama gbabara nʼime otu obodo ndị a, ọ ga-eguzo nʼọnụ ụzọ ama obodo ahụ gwa ndị okenye obodo ahụ ihe niile mere. Ndị okenye ahụ ga-akpọbata ya nʼime obodo ahụ, nye ya ebe ọ ga-ebi nʼetiti ha.  
\v 5 Ọ bụrụkwa na onye ikwu onye ahụ nwụrụ anwụ abịa ịbọrọ ọbọ ọchụ ahụ, ndị okenye obodo ahụ agaghị ekwe ka e gbuo onye ahụ gburu mmadụ na-amaghị ama, nʼihi na onye ahụ akpachaghị anya mee ihe o mere.  
\v 6 Onye ahụ gburu mmadụ na-amaghị ama ga-anọgide nʼobodo ahụ ruo mgbe ọ ga-akwụrụ nʼihu nzukọ maka ikpe ruokwa mgbe onyeisi nchụaja nọ nʼoge ahụ nwụrụ. Mgbe ahụ, o nwere ike laghachi nʼụlọ nke aka ya na nʼobodo ya bụ ebe o si gbapụ ọsọ.” 
\p  
\v 7 Obodo ndị ha kewapụtara iche dịka obodo mgbaba bụ, Kedesh,\f + \fr 20:7 \ft \xt Jos 21:32; 1Ih 6:76\f* nke dị nʼime Galili, nʼala ugwu ugwu ndị Naftalị; na Shekem,\f + \fr 20:7 \ft \xt Jos 21:21; 2Ih 10:1\f* nke dị nʼala ugwu ugwu Ifrem na Kiriat Aba,\f + \fr 20:7 \ft \xt Jos 14:15; 21:11,13\f* nke a na-akpọkwa Hebrọn. Ọ dị nʼala ugwu ugwu Juda.  
\v 8 Ha kewapụtara obodo atọ ọzọ nʼihi otu ihe ahụ, nʼakụkụ ọwụwa anyanwụ osimiri Jọdan nʼofe Jeriko. Obodo atọ ndị a bụ, Beza, nke dị nʼọzara, nʼala larịị ahụ e nyere ebo Ruben, na Ramọt; nke dị nʼime Gilead bụ ala ebo Gad; na Golan, nʼime Bashan, nke e si nʼala ebo Manase wepụta.  
\v 9 Obodo mgbaba ndị a a họpụtara bụ maka ndị ọbịa bi nʼetiti ụmụ Izrel, na maka ụmụ Izrel. Ọ bụ ebe onye ọbụla gburu mmadụ na-amaghị ama ga-agbaga. Onye na-abọrọ ọbọ ọchụ agaghị egbukwa onye ahụ tupu e kpee ya ikpe nʼọgbakọ ndị Izrel. 
\c 21  
\s1 Obodo ndị Livayị 
\p  
\v 1 Emesịa, ndị ndu ezinaụlọ Livayị bịakwutere Elieza, onye nchụaja, na Joshua, nwa Nun, na ndịisi ebo Izrel,  
\v 2 na Shaịlo, nʼime ala Kenan, sị ha, “\nd Onyenwe anyị\nd* nyere iwu site nʼaka Mosis ka enye anyị obodo ụfọdụ ebe anyị ga-ebi, na ala ebe anụ ụlọ anyị ga na-ata ahịhịa.” 
\b  
\s1 Oke ụmụ Kohat, Geshọn, na Merari 
\li4  
\v 3 Nʼihi nke a, dịka iwu \nd Onyenwe anyị\nd* si dị, ụmụ Izrel sitere nʼihe nketa ha nye ndị Livayị obodo ụfọdụ, nyekwa ha ala ebe anụ ụlọ ha ga-anọ taa nri. 
\b  
\li1  
\v 4 Ndị buru ụzọ nweta oke site nʼife nza bụ ikwu Kohat dịka ikwu ha si dị. E sitere nʼala ndị Juda, na Simiọn, na Benjamin nye ha obodo iri na atọ, ka ọ bụrụ ihe nketa ụmụ Kohat ndị si nʼebo Livayị, ndị bụkwa ụmụ ụmụ Erọn onye nchụaja. 
\li1  
\v 5 Ma ndị fọdụrụ nʼụmụ Kohat ka e nyere obodo iri site nʼobodo nke ikwu ndị ebo Ifrem, na Dan, na ọkara ebo Manase. 
\li1  
\v 6 Ụmụ Geshọn nwetara obodo iri na atọ site nʼife nza. Obodo ha nwetara dị na Bashan. Ha sikwa nʼala ndị ikwu ebo Isaka na Asha, na Naftalị, na ọkara ebo Manase nweta oke ahụ. 
\li1  
\v 7 Ụmụ Merari dịka ikwu ha si dị ketara obodo iri na abụọ site nʼala ndị ebo Ruben, na Gad, na Zebụlọn. 
\b  
\li4  
\v 8 Ya mere, ụmụ Izrel mezuru iwu niile \nd Onyenwe anyị\nd* nyere Mosis site nʼikenye ndị Livayị obodo ha ga-ebi, nakwa ebe anụ ụlọ ha ga-ata nri. 
\b  
\li1  
\v 9 Ha sitere nʼebo Juda na Simiọn, kepụta obodo ndị a akpọrọ aha  
\v 10 kenye ndị ikwu Kohat, ndị bụ ụmụ ụmụ Erọn, bụrụkwa ụmụ ụmụ Livayị. Ọ bụ ha ka e bụ ụzọ kenye ihe nketa site nʼife nza. 
\li2  
\v 11 E kenyere ha obodo Kiriat Aaba, nke a na-akpọkwa Hebrọn. Obodo a dị nʼala ugwu ugwu Juda, ya na ala gbara ya gburugburu ka ọ bụrụ ebe ịta nri anụ ụlọ. (Aaba bụ nna nna ndị Anak.)  
\v 12 Ma eburularị ụzọ nye Kaleb nwa Jefune obodo ukwu na obodo nta niile, na ala ubi niile dị nʼakụkụ ya ka ọ bụrụ ihe nketa ya.  
\v 13 Ya mere, ụmụ ụmụ Erọn, onye nchụaja, ka e kenyere obodo Hebrọn, nke bụkwa obodo mgbaba, kenyekwa ha obodo ndị a: Libna,  
\v 14 Jatịa, Eshtemoa,  
\v 15 Họlọn, Debịa,  
\v 16 Ain, Juta na Bet-Shemesh. E nyekwara ha ala niile gbara obodo ndị a gburugburu ka ọ bụrụ ebe anụ ụlọ ha ga-anọ taa nri. Ya mere, ọ bụ obodo itoolu ka e si nʼala ebo Juda na Simiọn kenye ha. 
\li1  
\v 17 Ebo Benjamin nyere ha obodo anọ ndị a, 
\li2 Gibiọn, Geba,  
\v 18 Anatot, Almon na ala dị ya gburugburu ebe anụ ụlọ ha ga-anọ taa nri, bụ obodo anọ. 
\li4  
\v 19 Ya mere, obodo niile e nyere ndị nchụaja, ụmụ ụmụ Erọn dị iri na atọ, tinyere ebe anụ ụlọ ha ga-anọ taa nri. 
\b  
\li4  
\v 20 Ụmụ Kohat\f + \fr 21:20 \ft Ndị a abụghị ndị nchụaja nʼihi na ha e sighị nʼagbụrụ Erọn. \xt Ọnụ 26:57; 1Ih 6:1,66-70\f* ndị fọdụrụ, ndị agbụrụ Livayị ka e kenyere obodo anọ ndị a site nʼaka ebo Ifrem. 
\li1  
\v 21 E sitere nʼala ugwu ugwu Ifrem nye ha: 
\li2 Shekem, nke bụ obodo mgbaba na Gaza,  
\v 22 Kibzaim na Bet-Horon, tinyere ebe ịta ahịhịa nke anụ ụlọ ha, bụ obodo anọ. 
\li1  
\v 23 Ha sitere nʼala ndị ebo Dan keta obodo anọ ndị a: 
\li2 Elteke na Gibeton,  
\v 24 Aijalon na Gat Rimọn, tinyere ebe ịta nri nke anụ ụlọ ha, bụ obodo anọ. 
\li1  
\v 25 Ọkara ebo Manase nyere ha obodo abụọ, 
\li2 Teanak, Gat Rimọn na ebe ịta ahịhịa nke anụ ụlọ ha. 
\li4  
\v 26 Ya mere, obodo niile na ebe ịta ahịhịa nke anụ ụlọ e nyere ndị fọdụrụ nʼikwu Kohat dị iri. 
\b  
\li4  
\v 27 Ụmụ Geshọn, ndị agbụrụ Livayị, ketara obodo abụọ ndị a, ya na ebe ịta nri nke anụ ụlọ ha. 
\li1 Ọkara ebo Manase nyere: 
\li2 Golan, nʼime Bashan, nke bụ obodo mgbaba, na Be Eshtera. 
\li1  
\v 28 Ebo Isaka nyere ha obodo anọ. Obodo ndị a bụ, 
\li2 Kishiọn, Daberat,  
\v 29 Jamut na En-Ganim, tinyere ebe ịta nri nke anụ ụlọ ha, obodo anọ. 
\li1  
\v 30 Ebo Asha nyekwara ha obodo anọ. Ha bụ, 
\li2 Mishal, Abdon,  
\v 31 Helkat na Rehob, tinyere ebe ịta nri nke anụ ụlọ ha, obodo anọ. 
\li1  
\v 32 Ebo Naftalị nyere ha obodo atọ, nyekwa ha ala ebe anụ ụlọ ha ga-anọ taa nri. Obodo ndị a bụ, 
\li2 Kedesh, nʼime Galili, nke bụkwa obodo mgbaba, Hamot Doa na Katan. 
\li4  
\v 33 Obodo iri na atọ, na ebe ịta ahịhịa nke anụ ụlọ ka e nyere ikwu Geshọn. 
\b  
\s1 Oke ụmụ Merari 
\li4  
\v 34 Ndị ikwu Merari, bụ ụmụ ụmụ Livayị fọdụrụ nwetara site nʼaka: 
\li1 Ebo Zebụlọn, 
\li2 Jokneam, Kata,  
\v 35 Dimna na Nahalal, obodo anọ tinyere ebe ịta nri nke anụ ụlọ ha. 
\li1  
\v 36 Ebo Ruben nyere ha obodo anọ: 
\li2 Beza, Jahaz,  
\v 37 Kedemot, Mefaat na ala ebe anụ ụlọ ha ga-anọ kpaa nri. 
\li1  
\v 38 Ebo Gad nyere ha obodo anọ. Obodo ndị a bụ, 
\li2 Ramọt, nʼime Gilead nke bụ obodo mgbaba, Mahanaim,  
\v 39 Heshbọn na Jeza, tinyere ebe ịta nri nke anụ ụlọ ha, bụ obodo anọ. 
\li4  
\v 40 Ọnụọgụgụ obodo niile e kenyere agbụrụ Merari bụ obodo iri na abụọ, ha bụ ndị fọdụrụ na ndị Livayị. 
\b  
\li4  
\v 41 Ọnụọgụgụ obodo niile na ebe ịta nri nke anụ ụlọ e sitere nʼala ụmụ Izrel nye ndị Livayị dị iri anọ na asatọ.  
\v 42 Obodo ọbụla nwere ala gbara ya gburugburu ebe anụ ụlọ ga-anọ kpaa nri. 
\b  
\p  
\v 43 Ya mere, \nd Onyenwe anyị\nd* nyere ụmụ Izrel ala ahụ ọ ṅụrụ iyi inye ndị nna nna ha. Ha nwetara ya, biri nʼime ya.  
\v 44 \nd Onyenwe anyị\nd* nyere ha izuike nʼakụkụ niile, dịka ọ ṅụrụ nʼiyi nye ndị nna nna ha. Ọ dịkwaghị otu nʼime ndị iro ha ọbụla guzogidere ha, nʼihi na \nd Onyenwe anyị\nd* nyefere ndị iro ha niile nʼaka ha.  
\v 45 O nweghị otu nʼime nkwa ọma niile \nd Onyenwe anyị\nd* kwere Izrel nke na-emezughị. O mezuru nkwa niile o kwere ha. 
\c 22  
\s1 Nlọghachi ndị bi nʼọwụwa anyanwụ Jọdan 
\p  
\v 1 Emesịa, Joshua kpọkọtara ndị agha si nʼebo Ruben, na Gad, na ọkara Manase, gwa ha okwu sị:  
\v 2 “Unu emeela ihe niile Mosis onyeozi \nd Onyenwe anyị\nd* nyere unu nʼiwu. Unu egeela ntị nʼolu m, mee ihe niile m nyere unu nʼiwu.  
\v 3 E, unu arụzuola ọrụ ahụ \nd Onyenwe anyị\nd* Chineke unu nyere unu. Unu ahapụghị ụmụnna unu nʼọgbọ agha ogologo ụbọchị ndị a niile.  
\v 4 Ugbu a, \nd Onyenwe anyị\nd* Chineke unu enyela ụmụnna unu mmeri. O meekwala ka ha zuru ike dịka o kwere nkwa na ọ ga-eme. Ugbu a, laghachinụ nʼụlọ unu, laghachikwanụ nʼala unu, ala ahụ Mosis onyeozi \nd Onyenwe anyị\nd* nyere unu nʼofe ọzọ nke osimiri Jọdan.  
\v 5 Ma lezienụ anya nke ọma idebe iwu na ụkpụrụ niile nke Mosis onyeozi \nd Onyenwe anyị\nd* nyere unu: nke bụ ịhụ \nd Onyenwe anyị\nd* Chineke unu nʼanya, ịga ije nʼirube isi nye ya, irube isi nʼiwu ya niile, ịdabere na ya, na iji obi unu niile na mkpụrụobi unu niile fee ya ofufe.” 
\p  
\v 6 Ya mere, Joshua gọziri ha, zipụ ha, ha lakwara nʼụlọ nke aka ha.  
\v 7 Ọkara ebo Manase ka Mosis nyere ihe nketa nke ha nʼime ala Bashan, ma ọkara ebo Manase nke ọzọ nwetara ihe nketa nke ha nʼakụkụ ọdịda anyanwụ osimiri Jọdan. Mgbe Joshua na-ezilaga ha nʼụlọ ha, ọ gọziri ha, gwa ha okwu sị,  
\v 8 “Werenụ ọtụtụ akụ unu lụtara nʼagha laa. Mgbe unu ruru, kenyenụ ndị ikwu unu ụfọdụ ihe site nʼime akụ ndị iro unu a.” Nʼihi na ihe ha kwatara nʼagha dị ukwuu: igwe anụ ụlọ, na ọlaọcha, na ọlaedo, na bronz, na igwe, na uwe dị iche iche. 
\p  
\v 9 Ya mere, ndị agha Ruben na Gad, na ọkara ebo Manase, hapụrụ ndị agha Izrel na Shaịlo, nʼime ala Kenan, nʼofe osimiri Jọdan, laghachi nʼala nke ha dị na Gilead, nke ha nwetara dịka iwu \nd Onyenwe anyị\nd* nyere Mosis si dị. 
\p  
\v 10 Mgbe ha rutere Gelilọt dị nʼakụkụ Jọdan, nʼala ndị Kenan, ụmụ Ruben, ndị Gad na ọkara ebo Manase wuru ebe ịchụ aja dị ukwu nʼebe ahụ nʼakụkụ Jọdan.  
\v 11 Mgbe ndị Izrel nụrụ na ha e wuola ebe ịchụ aja nʼoke ala Kenan, na Gelilọt, nʼebe dị nso Jọdan, nʼofe ala ndị Izrel,  
\v 12 ọgbakọ Izrel niile zukọtara na Shaịlo, jikere ịga ibuso ụmụnna ha ahụ agha. 
\p  
\v 13 Ya mere, ụmụ Izrel zigara Finehaz, nwa Elieza, bụ onye nchụaja ka ọ ga nʼala Gilead, ya bụ ijekwuru ụmụ Ruben, na ụmụ Gad, na ọkara ebo Manase.  
\v 14 Ndị so Finehaz nʼozi a bụ ndị ndu iri. Otu onyendu sitere nʼotu ebo, nʼime ebo iri nke ụmụ Izrel. 
\p  
\v 15 Mgbe ndị a rutere nʼala Gilead, ha kpọkọtara ụmụ Ruben, na ụmụ Gad, na ọkara ebo Manase gwa ha okwu sị,  
\v 16 “Otu a ka ọgbakọ niile nke \nd Onyenwe anyị\nd* sịrị, ‘Olee ụdị njehie dị nke a, nke unu mere megide Chineke? Olee otu unu si wezuga onwe unu site nʼebe \nd Onyenwe anyị\nd* nọ, gaa wuore onwe unu ebe ịchụ aja, si otu a nupu isi megide ya?  
\v 17 Ọ pụtara na mmehie Peoa ezubereghị anyị? Ruo taa anyị asachapụbeghị onwe anyị site na mmehie ahụ, ọ bụ ezie nʼọrịa na-efe efe dakwasịrị nzukọ nke \nd Onyenwe anyị\nd*.  
\v 18 Ugbu a, unu na-achọkwa isite nʼebe \nd Onyenwe anyị\nd* nọ chigharịa. 
\p “ ‘Ọ bụrụ na unu enupu isi megide \nd Onyenwe anyị\nd* taa, matakwanụ na echi ya, ọ ga-eweso nzukọ Izrel niile iwe.  
\v 19 Ọ bụrụ na unu wuru ebe ịchụ aja ahụ nʼihi na ala unu rụrụ arụ, bịakwutenụ anyị nʼakụkụ nke ọzọ, nke osimiri a, ebe \nd Onyenwe anyị\nd* bi nʼetiti anyị, nʼime ụlọ nzute obibi ya. Anyị ga-ekenyekwa unu ala anyị. Ma unu enupula isi megide \nd Onyenwe anyị\nd* site nʼiwu ebe ịchụ aja ọzọ, ebe ọ bụ na e nwere otu ebe bụ ezi ebe ịchụ aja nye \nd Onyenwe anyị\nd* Chineke anyị.  
\v 20 Mgbe Ekan, nwa Zera, zipụtara onwe ya dịka onye na-ekwesighị ntụkwasị obi nʼihe metụtara ihe e doro nsọ, ọ bụ na nzukọ Izrel niile esoghị keta oke nʼahụhụ dakwasịrị ya? Ọ bụghị naanị ya nwụrụ nʼihi mmehie ahụ.’ ” 
\p  
\v 21 Nke a bụ nzaghachi ụmụ Ruben, na ụmụ Gad na ọkara ebo ụmụ Manase, nyere ndị ndu ụmụ Izrel niile;  
\v 22 “Chineke onye kachasị chi niile, bụ \nd Onyenwe anyị\nd*! Chineke onye kachasị chi niile, bụ \nd Onyenwe anyị\nd*! Ya onwe ya maara, ka Izrel niile matakwa. A sị na nke a bụ nnupu isi, a sịkwarị na ọ bụ enweghị ntụkwasị obi nye \nd Onyenwe anyị\nd*, unu ahapụla anyị ka anyị dịrị ndụ.  
\v 23 Ọ bụrụ na anyị sitere na nnupu isi wuo ebe ịchụ aja a maka ịchụ aja udo maọbụ aja mkpụrụ ọka, ka \nd Onyenwe anyị\nd* nʼonwe ya taa anyị ahụhụ. 
\p  
\v 24 “Ma nke ahụ abụghị ihe anyị bu nʼobi! Anyị wuru ya nʼihi na anyị tụrụ ụjọ na nʼoge dị nʼihu, ụmụ unu ga-agwa ụmụ anyị okwu sị, ‘Gịnị ka unu na \nd Onyenwe anyị\nd*, Chineke Izrel nwekọrọ?  
\v 25 \nd Onyenwe anyị\nd* e jirila osimiri Jọdan kpaa oke nʼetiti anyị na unu, unu ụmụ Ruben na Gad. Unu enweghị oke nʼime \nd Onyenwe anyị\nd*!’ Nʼụzọ dị otu a, ụmụ unu nwere ike ime ụmụ anyị ka ha kwụsị ịtụ egwu \nd Onyenwe anyị\nd*. 
\p  
\v 26 “Ọ bụ nke a mere anyị ji kpebie sị, ‘Ka anyị jikere wuo ebe ịchụ aja, ma ọ bụghị ebe ịchụ aja nsure ọkụ maọbụ aja ndị ọzọ,’  
\v 27 Kama, ọ bụ ebe ịchụ aja\f + \fr 22:27 \ft \xt Jen 31:48; Jos 22:34; 24:27\f* ịhụba ama nʼetiti unu na anyị, nakwa ọgbọ ndị nke ga-esote anyị, na anyị ga-efe \nd Onyenwe anyị\nd* ofufe nʼụlọnsọ ya, site na ịchụrụ ya aja nsure ọkụ, na aja udo. Mgbe ahụ, nʼoge dị nʼihu, ụmụ ụmụ unu agaghị asị ụmụ ụmụ anyị, ‘Unu enweghị oke nʼime \nd Onyenwe anyị\nd* Chineke.’ 
\p  
\v 28 “Echiche obi anyị bụ na ọ bụrụ na ụmụ ụmụ unu ekwuo ihe dị otu a, ụmụ anyị ga-azaghachi ha sị, ‘Lee ebe ịchụ aja nna anyị ha wuru, nke yiri ebe ịchụ aja \nd Onyenwe anyị\nd*. E wughị ya maka ịchụ aja nsure ọkụ, kama e wuru ya dịka ihe ama na-egosi nnwekọ dị nʼetiti anyị na unu.’ 
\p  
\v 29 “Anyị agaghị enupu isi nʼebe \nd Onyenwe anyị\nd* nọ; anyị agaghị esitekwa nʼiso \nd Onyenwe anyị\nd* Chineke wezuga onwe anyị, site nʼiwuru onwe anyị ebe ịchụ aja nke aja nsure ọkụ, na aja mkpụrụ ọka maọbụ ụdị aja ọzọ dị iche iche. Ebe ịchụ aja anyị maara bụ ebe ịchụ aja \nd Onyenwe anyị\nd* Chineke anyị, nke guzo nʼihu ụlọ nzute ya.” 
\p  
\v 30 Mgbe Finehaz onye nchụaja, na ndị ndu nzukọ ahụ, bụ ndịisi ezinaụlọ ndị Izrel nụrụ ihe ụmụ Ruben, na ụmụ Gad, na ụmụ Manase kwuru, ọ masịrị ha.  
\v 31 Ya mere, Finehaz nwa Elieza, bụ onye nchụaja, sịrị Ruben, na Gad, na Manase, “Taa ka anyị maara na \nd Onyenwe anyị\nd* nọ nʼetiti anyị,\f + \fr 22:31 \ft \xt Ọpụ 25:8; Lev 26:11-12; 2Ih 15:2\f* nʼihi na unu emehieghị megide \nd Onyenwe anyị\nd* dịka anyị chere. Ya mere, unu azọpụtala ndị Izrel site na mbibi gaara abịakwasị ha site nʼaka \nd Onyenwe anyị\nd*.” 
\p  
\v 32 Mgbe ahụ Finehaz, nwa Elieza, onye nchụaja, na ndị ndu ahụ laghachitere Kenan site na nzukọ ha na ụmụ Ruben na Gad na ọkara Manase mere nʼala Gilead kọọrọ Izrel ihe ha gatara.  
\v 33 Okwu a tọrọ ụmụ Izrel ụtọ. Ha ṅụrịrị ọṅụ, too Chineke otuto. Ha ekwukwaghị okwu ibu agha megide ụmụ Ruben, ụmụ Gad na ụmụ Manase, banyere ibibi ala ha bi nʼime ya. 
\p  
\v 34 Ya mere, ụmụ Ruben na ụmụ Gad kpọrọ ebe ịchụ aja ha wuru, “Ebe ịchụ aja akaebe,” nʼihi na ha sịrị, “Ọ bụ ihe akaebe igosi mmadụ niile na \nd Onyenwe anyị\nd* bụkwa Chineke anyị.” 
\c 23  
\s1 Okwu ikpeazụ Joshua kwuru 
\p  
\v 1 Ma mgbe ọtụtụ oge gasịrị, site nʼoge \nd Onyenwe anyị\nd* mere ka Izrel nwee ezumike nʼebe ndị iro gbara ha okirikiri nọ, Joshua aghọọla agadi, gbaa ọtụtụ afọ.  
\v 2 Ya mere, Joshua kpọrọ ndị Izrel niile, ndị okenye ha, ndị ndu ha, ndị odozi okwu ha na ndịisi ha, sị ha, “Emeela m agadi gbaakwa ọtụtụ afọ.  
\v 3 Unu onwe unu ejirila anya unu hụ ihe niile \nd Onyenwe anyị\nd* Chineke unu mere mba ndị a niile, nʼihi unu. Ọ lụụrụ unu ọgụ, nyere unu aka imeri ndị iro unu.  
\v 4 Unu hụrụ na ekekwarala m unu ala mba ahụ niile nke fọdụrụnụ ka ha bụrụ ihe nketa ebo unu, site na Jọdan, tinyekwara mba niile ndị ahụ m kpochapụrụ nʼakụkụ osimiri Mediterenịa dị na mpaghara ọdịda anyanwụ.  
\v 5 \nd Onyenwe anyị\nd* bụ Chineke unu ga-akwapụ ndị bi nʼime ha nʼihi unu. Ọ ga-achụpụ ha nʼihu unu, mee ka unu nweta ala ha, dịka \nd Onyenwe anyị\nd* Chineke unu kwere unu nkwa. 
\p  
\v 6 “Ya mere, dịnụ ike, lezienụ anya idebezu na irube isi nʼihe niile e dere nʼAkwụkwọ Iwu Mosis. Unu esila nʼime ya wezuga onwe unu nʼụzọ ọbụla.  
\v 7 Lezienụ anya ka unu na mba ndị a fọdụrụ nʼala a ghara inwe mmekọ ọbụla. Unu akpọtụkwala chi ha niile aha. Unu aṅụkwala iyi nʼaha ha, maọbụ fee ha ofufe, maọbụ kpọọ isiala nye ha.  
\v 8 Kama raparanụ\f + \fr 23:8 \ft \xt Dit 10:20\f* nʼahụ \nd Onyenwe anyị\nd* Chineke unu dịka unu mere ruo taa. 
\p  
\v 9 “\nd Onyenwe anyị\nd* achụpụla mba dị ukwuu na mba siri ike site nʼebe unu nọ. O nwekwaghị otu mba nʼime ha o kwere ka ha merie unu.  
\v 10 Otu nwoke nʼime unu achụọla puku ndị ikom ndị iro unu ọsọ. Nʼihi na \nd Onyenwe anyị\nd* Chineke unu alụọlara unu ọgụ, dịka ya onwe ya kwere nkwa.  
\v 11 Nʼihi ya, lezienụ onwe unu anya nke ọma ka unu hụ \nd Onyenwe anyị\nd* Chineke unu nʼanya. 
\p  
\v 12 “Ma ọ bụrụ na unu alaghachi azụ, ma kwere ka e jikọọ unu na mba ndị a fọdụrụ nʼetiti unu. Ọ bụrụ na unu na ha ebido ịlụrịta di na nwunye, na-emekọrịta ihe ọnụ,  
\v 13 maranụ nke ọma, na \nd Onyenwe anyị\nd* Chineke unu agaghị achụpụrụ unu mba ndị a site nʼala unu. Kama ha ga-abụrụ unu igbudu na ọnya. Ha ga-abụkwara unu apịpịa nʼakụkụ unu, na ogwu nʼanya unu, ruo mgbe unu ga-ala nʼiyi nʼezi ala a, nke \nd Onyenwe anyị\nd* Chineke unu nyere unu. 
\p  
\v 14 “Mgbe na-adịghị anya, mụ onwe m ga-agbaso ụzọ ahụ ndị niile bi nʼụwa na-aghaghị ịgbaso. Unu niile maara nʼime obi unu na nʼime mkpụrụobi unu na o nweghị otu nʼime nkwa ọma \nd Onyenwe anyị\nd* Chineke unu kwere nye unu nke na-emezughị. E mezuola nkwa ndị a niile; o nweghị nke ọbụla a na-emezughị.  
\v 15 Ma dịka ezi nkwa niile \nd Onyenwe anyị\nd* Chineke unu kwere si bụrụ ihe e mezuru emezu, otu a kwa ka \nd Onyenwe anyị\nd* ga-esi mee ka ihe ọjọọ niile ọ bara mba ya mezuo nʼisi unu, tutu ruo mgbe o mere ka unu laa nʼiyi nʼezi ala ahụ ọ na-enye unu.  
\v 16 Ọ bụrụ na unu emebie ọgbụgba ndụ \nd Onyenwe anyị\nd* Chineke unu, nke o nyere unu iwu idebe, tụgharịa malite ịgbaso na ife chi ndị ọzọ na ịkpọ isiala nye ha, iwe \nd Onyenwe anyị\nd* ga-adị ọkụ megide unu, unu ga-alakwa nʼiyi ngwangwa nʼala ọma ahụ o nyere unu.” 
\c 24  
\s1 Imesi ọgbụgba ndụ ike 
\p  
\v 1 Joshua kpọkọtara ebo Izrel niile na Shekem. Ọ kpọrọ ndị okenye Izrel na ndịisi ha na ndị ikpe ha na ndị nlekọta ha. Ha niile bịara chee onwe ha nʼihu Chineke. 
\p  
\v 2 Mgbe ahụ, Joshua gwara ndị Izrel niile sị, “Otu a ka \nd Onyenwe anyị\nd*, Chineke nke Izrel kwuru, ‘Nna nna unu ochie ha, nke bụ Tera, nna Ebraham, na Nahọ, bikwara nʼakụkụ ọwụwa anyanwụ nke ofe osimiri Yufretis, ebe ha nọ fee chi ndị ọzọ ofufe.  
\v 3 Ma mụ onwe m kpọpụtara nna nna unu Ebraham site nʼala ahụ dị nʼofe osimiri dubata ya nʼala Kenan, nye ya ọtụtụ ụmụ ụmụ, site na nwa ya bụ Aịzik.  
\v 4 Ụmụ m nyere Aịzik bụ Jekọb na Ịsọ. Ịsọ ka m nyere ala ugwu ugwu Sia, ka o nweta ma Jekọb na ezinaụlọ ya gara nʼala Ijipt. 
\p  
\v 5 “ ‘Emesịa, ezigara m Mosis na Erọn, ma wetara ndị Ijipt ihe otiti ọjọọ niile dị iche iche site nʼihe m mere nʼebe ahụ. Nʼikpeazụ, akpọpụtara m ndị m site nʼala Ijipt.  
\v 6 Ma mgbe unu rutere nʼOsimiri Uhie, ndị agha Ijipt gbapụtara chịrị ụgbọ agha ha na ndị agha na-agba ịnyịnya ha chụwa unu ọsọ.  
\v 7 Mgbe ndị Izrel hụrụ ha, ha tiri mkpu kpọkuo \nd Onyenwe anyị\nd*. O tinyere oke ọchịchịrị nʼetiti unu na ndị Ijipt. O mere ka oke osimiri kpuchie ha, mee ka ha mikpuo nʼosimiri ahụ. Unu niile hụkwara ihe m mere ndị Ijipt. Emesịa, unu bikwara nʼọzara ọtụtụ afọ. 
\p  
\v 8 “ ‘Ma emesịa, emere m ka unu bata nʼime ala ndị Amọrait, ndị bi nʼakụkụ ọwụwa anyanwụ osimiri Jọdan. Ha lụsoro unu ọgụ, ma eweere m ha nyefee unu nʼaka. E bibiri m ha nʼihu unu, ma unu nwetara ala ha.  
\v 9 Mgbe Balak nwa Zipoa, eze Moab, jikeere ibuso Izrel agha, o zigaara Belam, nwa Beoa ozi ka ọ bịa bụọ unu ọnụ.  
\v 10 Ma egeghị m Belam ntị. Kama emere m ya ka ọ gọzie unu. Anapụtara m unu site nʼaka ya. 
\p  
\v 11 “ ‘Emesịa, unu gafere osimiri Jọdan bịaruo Jeriko. Ndị ikom Jeriko busoro unu agha, otu a kwa ka ndị Amọrait, na ndị Periz, na ndị Kenan, na ndị Het, na ndị Gigash, na ndị Hiv, na ndị Jebus. Ma eweere m ha niile nyefee unu nʼaka.  
\v 12 E zigara m ebu nʼihu unu nke chụpụrụ ha nʼihu unu, bụ eze abụọ ndị Amọrait. Ọ bụghị mma agha na ụta unu ka unu ji mee nke a.  
\v 13 \f + \fr 24:13 \ft \xt Dit 6:10-11\f*Ya mere enyere m unu ala ahụ, nke unu na-adọgbughị onwe unu nʼihi ya, nyekwa unu ọtụtụ obodo nke unu na-ewughị, bụ ala ndị a unu bi nʼime ya ugbu a. Enyere m unu ubi vaịnị na ubi oliv nke unu na-akụghị, nke unu na-eri mkpụrụ ha.’ 
\p  
\v 14 “Ya mere ugbu a, tụọnụ egwu \nd Onyenwe anyị\nd*, feekwanụ ya ofufe nʼụzọ ikwesi ntụkwasị obi na nʼeziokwu. Wezuganụ chi ndị ahụ niile nna nna unu ha fere ofufe nʼofe osimiri Yufretis ahụ, na nʼIjipt. Feenụ naanị \nd Onyenwe anyị\nd* ofufe.  
\v 15 Ọ bụrụkwanụ na ọ masịghị unu ife \nd Onyenwe anyị\nd*, họpụtaranụ onwe unu taa onye unu ga-efe. Ma ọ bụ chi ndị ahụ nna nna unu ha fere nʼofe ọzọ nke osimiri, maọbụ chi ndị Amọrait, ndị unu bi nʼala ha. Ma nʼebe mụ onwe m na ezinaụlọ m nọ, anyị ga-efe \nd Onyenwe anyị\nd*.” 
\p  
\v 16 Ndị Izrel niile zara sị ya, “O nweghị ihe ga-eme ka anyị hapụ \nd Onyenwe anyị\nd* fee chi ndị ọzọ!  
\v 17 Ọ bụ \nd Onyenwe anyị\nd* Chineke anyị, ya onwe ya si nʼala Ijipt, ebe anyị bụ ndị ohu, kpọpụta anyị na nna anyị ha. Ọ rụrụ ọrụ ịrịbama ndị ahụ niile dị oke egwu nʼihu anyị. O chebere anyị nʼije anyị niile nʼetiti mba ndị ahụ niile anyị si nʼala ha gafee.  
\v 18 Ọ bụ \nd Onyenwe anyị\nd* chụpụrụ ndị Amọrị na ọtụtụ mba ndị ọzọ bi nʼala a. E, anyị onwe anyị ga-efe \nd Onyenwe anyị\nd*, nʼihi na ọ bụ Chineke anyị.” 
\p  
\v 19 Joshua zaghachiri ndị Izrel sị, “Unu apụghị ife \nd Onyenwe anyị\nd* ofufe; nʼihi na ọ bụ Chineke dị nsọ, bụrụkwa Chineke ekworo. Ọ gaghị agbaghara unu nnupu isi unu na mmehie unu niile.  
\v 20 Ọ bụrụ na unu agbakụta \nd Onyenwe anyị\nd* azụ, fee chi ala ọzọ ofufe, ọ ga-echigharị laa unu nʼiyi, nʼagbanyeghị na ọ nọnyerela unu ụbọchị ndị a niile.” 
\p  
\v 21 Ma ndị Izrel sịrị Joshua, “Mba, kama \nd Onyenwe anyị\nd* ka anyị ga-efe ofufe.” 
\p  
\v 22 Mgbe ahụ, Joshua sịrị, “Unu bụ ndị ama megide onwe unu na unu ahọrọla ife \nd Onyenwe anyị\nd* ofufe.” 
\p Ha zara sị, “E, anyị bụ ndị akaebe.” 
\p  
\v 23 Joshua sịrị, “Ugbu a, wezuganụ chi ndị mba ọzọ niile dị nʼetiti unu. Werekwanụ obi unu nye maka irubere \nd Onyenwe anyị\nd* Chineke Izrel isi.” 
\p  
\v 24 Ndị ahụ sịrị Joshua, “Anyị ga-efe \nd Onyenwe anyị\nd* Chineke anyị ofufe. Anyị ga-egekwa ntị nʼolu ya, mee ihe o nyere nʼiwu.” 
\p  
\v 25 Ya mere, Joshua na ndị Izrel gbara ndụ nʼụbọchị ahụ na Shekem. O nyere ha iwu na ụkpụrụ ha ga-edebe.  
\v 26 Joshua dere iwu ndị a ụmụ Izrel kwere na ha ga-eme nʼAkwụkwọ Iwu Chineke. Emesịa, o bupụtara otu nkume buru ibu guzo ya nʼokpuru osisi ukwu ook dị nʼakụkụ ebe nsọ \nd Onyenwe anyị\nd*. 
\p  
\v 27 Joshua sịrị ndị ahụ niile, “Lee, nkume a ga-abụ ihe ama megide anyị. Nʼihi na ọ nụla okwu niile nke \nd Onyenwe anyị\nd* gwara anyị. Ọ ga-abụkwa ihe ama megide unu, ma ọ bụrụ na unu mee ihe mmekpu megide Chineke unu.” 
\p  
\v 28 Emesịa, Joshua zilara onye ọbụla, ka ha laa nʼihe nketa nke aka ha. 
\s1 Ọnwụ Joshua na Elieza 
\p  
\v 29 Ọ dịghị anya, mgbe ihe ndị a gasịrị, Joshua nwa Nun, odibo \nd Onyenwe anyị\nd* nwụrụ, mgbe ọ gbara narị afọ na iri.  
\v 30 E liri ya nʼoke ala nke ihe nketa ya, na Timnat Sera,\f + \fr 24:30 \ft \xt Jos 19:50; Nkp 2:9\f* nʼime ala ugwu ugwu Ifrem, nʼakụkụ ugwu dị nʼala Gaash. 
\p  
\v 31 Ndị Izrel fere \nd Onyenwe anyị\nd* ofufe ụbọchị niile nke ndụ Joshua, na nke ndụ ndị okenye ahụ, bụ ndị gara nʼihu bie ndụ mgbe ọ nwụsịrị, ndị maakwara ihe niile nke \nd Onyenwe anyị\nd* rụụrụ ndị Izrel. 
\p  
\v 32 Ọkpụkpụ Josef ndị Izrel chịtara mgbe ha si nʼala Ijipt pụta, ka ha liri na Shekem, nʼime ala ahụ Jekọb zụrụ narị mkpụrụ ọlaọcha nʼaka ụmụ Hamọ nna Shekem. Ala a ghọrọ nʼihe nketa ụmụ Josef. 
\p  
\v 33 Elieza nwa Erọn, nwụkwara. E liri ya nʼala ugwu ugwu ndị Ifrem, na Gibea, obodo e nyere nwa ya bụ Finehaz.