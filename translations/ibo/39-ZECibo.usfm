\id ZEC - Biblica® Open Igbo Contemporary Bible 2020 
\h Zekaraya 
\toc1 Zekaraya 
\toc2 Zekaraya 
\toc3 Zek 
\mt1 Zekaraya 
\c 1  
\s1 Lọghachitanụ nʼebe \nd Onyenwe anyị\nd* nọ 
\p  
\v 1 Nʼọnwa nke asatọ, nʼafọ nke abụọ nke ọchịchị eze Daraiọs, okwu \nd Onyenwe anyị\nd* ruru Zekaraya nwa Berekaya, nwa Ido, bụ onye amụma ntị, na-asị, 
\p  
\v 2 “\nd Onyenwe anyị\nd* were oke iwe megide nna unu ha.  
\v 3 Nʼihi ya, gwa ha, ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, na-ekwu. ‘Lọghachikwutenụ m,’ otu a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwupụtara, ‘Mụ onwe m kwa ga-alọghachikwute unu.’ Ọ bụ ihe \nd Onyenwe anyị\nd* Onye pụrụ ime ihe niile, na-ekwu.  
\v 4 Unu adịla ka ndị nna unu ha, ndị amụma mbụ kpọrọ oku si, Otu a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwupụtara: ‘Sitenụ nʼụzọ ọjọọ unu na ajọ omume unu chigharịa’ ma ha achọghị ịnụ maọbụ gee m ntị, otu a ka \nd Onyenwe anyị\nd* kwupụtara.  
\v 5 Olee ebe ka nna nna unu ha nọ ugbu a? Ndị amụma ahụ, ha na-adị ndụ ruo mgbe ebighị ebi?  
\v 6 Ọ bụ na okwu m na iwu bụ nke m nyere ụmụ ohu m ndị amụma, ọ bụ na ha emezughị nʼebe ndị nna nna unu ha nọ? 
\p “Mgbe ahụ, ha chegharịrị ma kwuo, ‘\nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, emesola anyị mmeso dịka ụzọ anyị na omume anyị si dị. O mekwara ya dịka o si zube na ọ ga-eme ya.’ ” 
\s1 Nwoke nọ nʼetiti osisi mietul 
\p  
\v 7 Nʼụbọchị nke iri abụọ na anọ, nke ọnwa iri na otu, bụ ọnwa Shebat, nʼafọ abụọ nke ọchịchị eze Daraiọs, okwu \nd Onyenwe anyị\nd* ruru Zekaraya onye amụma, bụ nwa Berekaya, nwa Ido ntị, na-asị: 
\p  
\v 8 Nʼabalị ahụ, ahụrụ m nʼọhụ, otu nwoke na-agba ịnyịnya na-acha ọbara ọbara. O guzokwa nʼetiti osisi mietul, nke dị nʼebe miri emi nke mgbawa dị nʼala. Nʼazụ ya, ọtụtụ ịnyịnya na-acha ọbara ọbara, ndị na-acha ka ahịhịa kpọrọ nkụ, na ndị na-acha ọcha dịkwa. 
\p  
\v 9 Ajụrụ m, “Nna m ukwu, gịnị bụ ihe ndị a?” 
\p Mmụọ ozi ahụ nke na-agwa m okwu sịrị m, “Aga m egosi gị ihe ha bụ.” 
\p  
\v 10 Mgbe ahụ onye ahụ guzo nʼetiti osisi mietul ndị ahụ sịrị, “Ndị a bụ ndị \nd Onyenwe anyị\nd* zitere ka ha jegharịa nʼụwa niile.” 
\p  
\v 11 Ha sịrị mmụọ ozi nke \nd Onyenwe anyị\nd* nke na-eguzo nʼetiti osisi mietul ahụ, “Anyị ejegharịala nʼụwa niile, ma lee anyị chọpụtara na ụwa niile nọ nʼudo, dịkwa jụụ.” 
\p  
\v 12 Mgbe ahụ, mmụọ ozi nke \nd Onyenwe anyị\nd* sịrị, “\nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, ọ bụ ruo ole mgbe ka ị ga-anọgide hapụ imere Jerusalem na obodo niile nke Juda ebere, bụ obodo ị na-eweso iwe iri afọ asaa ndị a gara aga?”  
\v 13 Mgbe ahụ, \nd Onyenwe anyị\nd* gwara mmụọ ozi ahụ guzo na-agwa m okwu, okwu nkasiobi na okwu ọma dị iche iche. 
\p  
\v 14 Mgbe ahụ, mmụọ ozi ahụ nọ na-agwa m okwu gwara m sị, “Kwusaa ozi a, otu a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwuru sị, ‘Ekworo m dị ukwuu nʼebe Jerusalem na Zayọn nọ,  
\v 15 ma iwe m dị ukwuu megide ndị mba niile ahụ onwe ha juru afọ. Nʼihi na mgbe iwe m dị nta, ha nyere aka ime ka ahụhụ ahụ karịa njọ.’ 
\p  
\v 16 “Nʼihi ya, ihe ndị a ka \nd Onyenwe anyị\nd* kwuru, ‘Aga m eji obi ebere lọghachi na Jerusalem. Nʼebe ahụ kwa ka a ga-ewugharị ụlọnsọ ukwuu m. A ga-esetikwa eriri e ji atụ ihe nʼelu Jerusalem.’ Otu a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwubiri. 
\p  
\v 17 “Kwusaakwa ọzọ, otu a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwuru. ‘Ọganihu ga-adịkwa nʼobodo m niile ọzọ.\f + \fr 1:17 \ft Obodo m niile ga-esite nʼụba basaa ọzọ\f*\nd Onyenwe anyị\nd* ga-akasị Zayọn obi ọzọ, ma họpụtakwa Jerusalem.’ ” 
\s1 Mpi anọ na ndị ọkpụ ụzụ anọ 
\p  
\v 18 Mgbe ahụ, eweliri m anya m abụọ elu hụ mpi anọ.  
\v 19 Ajụrụ m mmụọ ozi ahụ na-agwa m okwu sị, “Gịnị ka ihe ndị a bụ?” 
\p Ọ sịrị m, “Ndị a bụ mpi ndị ahụ chụsasịrị Juda, na Izrel, na Jerusalem.” 
\p  
\v 20 Mgbe ahụ, \nd Onyenwe anyị\nd* gosiri m ndị ọkpụ ụzụ anọ.  
\v 21 Asịrị m, “Gịnị ka ndị na-abịa ime?” 
\p Ọ zaghachiri m, “Ndị a bụ mpi anọ ndị ahụ chụsasịrị Juda, ime ka onye ọbụla ghara inwe ike iwelite isi ya. Ma ndị a abịala imenye ha ụjọ, na ịtụda mpi mba niile, bụ ndị ahụ buliri mpi ha imegide ala Juda, na ịchụsa ndị ya.” 
\c 2  
\s1 Nwoke ji Ihe ọtụtụ 
\p  
\v 1 Mgbe m weliri anya m, ahụrụ m otu nwoke ji eriri ihe ọtụtụ nʼaka ya.  
\v 2 Ajụrụ m, “Ebee ka ị na-aga?” 
\p Ọ sịrị m, “Ana m aga ịtụ Jerusalem, ịchọta ịdị ogologo ya, na ịdị obosara ya.” 
\p  
\v 3 Mgbe mmụọ ozi na-ekwuru m okwu na-apụ, mmụọ ozi ọzọ bịara izute ya,  
\v 4 ọ sịrị ya, “Gbaa ọsọ, gwa nwa okorobịa ahụ, sị, ‘Obodo na-enweghị mgbidi ka Jerusalem ga-abụ, nʼihi ọtụtụ igwe mmadụ na anụmanụ ga-ejupụta nʼime ya.  
\v 5 Ma mụ onwe m ga-abụrụ ya mgbidi ọkụ nke ga-agba ya gburugburu.’ Otu a ka \nd Onyenwe anyị\nd* kwubiri. ‘Aga m aghọ ebube nʼetiti ya.’ 
\p  
\v 6 “Bịa, lee anya! Sitenụ nʼala dị nʼugwu gbapụ,” otu a ka \nd Onyenwe anyị\nd* kwupụtara, “nʼihi na achụsasịrị m unu nye ikuku anọ nke eluigwe,” otu a ka \nd Onyenwe anyị\nd* kwubiri. 
\p  
\v 7 “Bịanụ, unu ndị bi na Zayọn. Gbalaganụ, unu ndị bi nʼala nke ada Babilọn.”  
\v 8 Nʼihi na otu a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwuru, “Mgbe Onye ahụ dị ebube zipụrụ m ịga megide mba ndị ahụ niile kwakọọrọ ihe unu. Nʼihi na onye ọbụla metụrụ unu aka bụ mkpụrụ anya m ka ọ na-emetụ aka.  
\v 9 Aghaghị m iweli aka m imegide ha, meekwa ka ndị ohu ha kwakọrọ ihe niile ha nwere. Mgbe ahụ, unu ga-amata na ọ bụ \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile zitere m. 
\p  
\v 10 “Tie mkpu ọṅụ, ka obi tọkwaa gị ụtọ, gị Ada Zayọn. Nʼihi na ana m abịa ibi nʼetiti gị,” otu a ka \nd Onyenwe anyị\nd* kwubiri.  
\v 11 “Nʼụbọchị ahụ, ọtụtụ mba dị iche iche ga-adịnyere \nd Onyenwe anyị\nd*, bụrụkwa ndị nke m. Aga m ebi nʼetiti gị, ị ga-amatakwa na \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile zitere m ka m bịakwute gị.  
\v 12 \nd Onyenwe anyị\nd* ga-eketa Juda dịka oke ya nʼime ala ahụ dị nsọ. Ọ ga-ahọrọkwa Jerusalem ọzọ.  
\v 13 Derenụ duu nʼihu \nd Onyenwe anyị\nd*, unu mmadụ niile, nʼihi na o sitela nʼebe obibi ya dị nsọ kpalie onwe ya.” 
\c 3  
\s1 Uwe dị ọcha maka onye nchụaja 
\p  
\v 1 Mgbe ahụ, o gosiri m Joshua onyeisi nchụaja ka ọ na-eguzo nʼihu mmụọ ozi nke \nd Onyenwe anyị\nd*, na ekwensu ka ọ na-eguzo nʼaka nri ya ibo ya ebubo.  
\v 2 \nd Onyenwe anyị\nd* sịrị ekwensu, “\nd Onyenwe anyị\nd* basiere gị mba ike, gị ekwensu. \nd Onyenwe anyị\nd*, onye họpụtara Jerusalem, basiere gị mba ike. Nwoke a, ọ bụghị ọlọkọ ọkụ na-ere ere, nke e si nʼime ọkụ gụpụta?” 
\p  
\v 3 Mgbe Joshua guzo nʼihu mmụọ ozi ahụ, uwe ya ruru unyi.  
\v 4 Mmụọ ozi ahụ gwara ndị ahụ guzo ya nʼihu, “Yipụnụ ya uwe a ruru unyi.” 
\p Mgbe ahụ, ọ gwara ya okwu sị, “Lee, ewepụla m mmehie gị, ma ugbu a, aga m eyikwasị gị uwe mmemme ndị a.” 
\p  
\v 5 Ekwuru m, “Ka ha were ezi akwa okike dị ọcha kee ya nʼisi.” Ya mere ha weere akwa okike dị ọcha kee ya nʼisi, yikwasịkwa ya uwe ọhụrụ. Mmụọ ozi \nd Onyenwe anyị\nd* guzokwa nʼebe ahụ. 
\p  
\v 6 Mgbe ahụ, mmụọ ozi nke \nd Onyenwe anyị\nd* nyere Joshua ndụmọdụ sị,  
\v 7 “Ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwuru, ‘Ọ bụrụ na i jee ije nʼụzọ m niile, ọ bụrụkwa na i debe ihe niile m nyere gị nʼiwu, ị ga-abụ onyeisi ezinaụlọ m, ị ga-elekọta ụlọnsọ m anya, aga m enyekwa gị ọnọdụ nʼetiti ndị a niile guzo nʼebe a. 
\p  
\v 8 “ ‘Gee m ntị, gị Joshua, onyeisi nchụaja na unu ndị nchụaja ndị ọzọ nọ nʼihu gị, ndị bụ ihe ngosi banyere ihe ọma niile nke gaje ịbịa. Agaje m ịkpọta nwaodibo m, onye bụ Ngalaba ahụ.  
\v 9 Lee, nkume nke m guzobere nʼihu Joshua. Nkume ahụ nwere akụkụ\f + \fr 3:9 \ft Maọbụ, \fqa ihu asaa\f* asaa nʼahụ ya, aga m egbunye akara dee ihe nʼelu ya. Aga m ewezugakwa mmehie nke ala a nʼotu ụbọchị.’ Ọ bụ ihe \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwuru. 
\p  
\v 10 “ ‘Nʼụbọchị ahụ, onye ọbụla nʼime unu ga-akpọbata mmadụ ibe ya, ka ọ bịa soro ya nọdụ nʼokpuru osisi vaịnị ya, na nʼokpuru osisi fiig ya.’ Otu a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwubiri ya.” 
\c 4  
\s1 Osisi oliv abụọ na ihe ịdọba oriọna 
\p  
\v 1 Mgbe ahụ, mmụọ ozi ahụ nke na-agwa m okwu lọghachiri kpọtee m, dịka e si akpọte onye nọ nʼụra.  
\v 2 Ọ sịrị m, “Gịnị ka ị na-ahụ?” 
\p Asịrị m, “Ana m ahụ ihe ịdọba oriọna e ji ọlaedo mee. O nwere ọkwa nʼisi ya, nweekwa oriọna asaa, nke na-enwu nʼelu ya. Oriọna asaa ndị a nwekwara okporo asaa e si agbanye mmanụ nʼime ha.  
\v 3 Ahụkwara m osisi oliv abụọ nke dị nʼakụkụ ihe ịdọba oriọna ahụ. Otu dị nʼotu akụkụ ya, nke ọzọ, nʼakụkụ nke ọzọ.” 
\p  
\v 4 A sịrị m mmụọ ozi ahụ na-ekwuru m okwu, “Nna m ukwu, gịnị ka nke a pụtara?” 
\p  
\v 5 Mmụọ ozi ahụ na-agwa m okwu sịrị m, “Ị na-ekwu na ị maghị ihe ha bụ?” 
\p Azara m sị, “Ee, nna m ukwu, amaghị m.” 
\p  
\v 6 Ọ sịrị m, “Nke a bụ okwu nke \nd Onyenwe anyị\nd* nye Zerubabel. ‘Ọ bụghị site nʼike, maọbụ site nʼume, kama ọ bụ site na Mmụọ m,’ ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwuru. 
\p  
\v 7 “Gịnị ka ị bụ, gị ugwu dị ukwuu? Ị ga-aghọ ala dị larịị nʼihu Zerubabel. Mgbe ahụ, ọ ga-awapụta isi nkume ahụ site nʼiti oke mkpu ọṅụ, ‘Amara! Amara dịrị ya!’ ” 
\p  
\v 8 Mgbe ahụ, okwu \nd Onyenwe anyị\nd* ruru m ntị sị,  
\v 9 “Zerubabel wara ntọala ụlọnsọ ukwu a, ọ bụ ya ga-ewuchakwa ya. Mgbe ahụ, ị ga-amata na ọ bụ \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile zitere m ịbịakwute unu. 
\p  
\v 10 “Onye na-eleda ụbọchị ihe nta anya ebe ọ bụ nʼanya asaa nke \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile na-ejegharị na-elezu ụwa dum, ga-aṅụ ọṅụ mgbe ha hụrụ nkume eji atụ mgbidi nʼaka Zerubabel?” 
\p  
\v 11 Mgbe ahụ, a sịrị m ya, “Gịnị bụ osisi oliv abụọ ahụ dị nʼaka nri na nʼaka ekpe ihe ịdọba oriọna ahụ?” 
\p  
\v 12 A sịkwara m ya nke ugboro abụọ, “Gịnị bụ alaka osisi oliv abụọ ndị a dị nʼakụkụ okporo ọlaedo abụọ ahụ, nke e si na ha na-awụpụta mmanụ ọlaedo?” 
\p  
\v 13 Ọ sịrị m, “Ọ pụtara na ị maghị ihe ha bụ?” 
\p Asịrị m, “Mba, nna m ukwu.” 
\p  
\v 14 Mgbe ahụ, ọ sịrị m, “Ndị a bụ mmadụ abụọ a họpụtara tee mmanụ, ife ya ofufe bụ Onyenwe ụwa niile.” 
\c 5  
\s1 Akwụkwọ a fụkọrọ afụkọ 
\p  
\v 1 Ọzọkwa, eleliri m anya elu, ma hụ akwụkwọ a fụkọrọ afụkọ nke na-efegharị efegharị. 
\p  
\v 2 Ọ sịrị m, “Gịnị ka ị na-ahụ?” 
\p Azara m, “Ahụrụ m akwụkwọ a fụkọrọ afụkọ nke na-efegharị efegharị. Ogologo ya dị mita iri, obosara ya dịkwa mita ise.” 
\p  
\v 3 Ọ gwara m, “Nke a bụ ọbụbụ ọnụ nke na-apụ na-ejezu nʼala ahụ niile. Nʼihi na dịka e si detuo ya, nʼotu akụkụ ya, a ga-esi nʼala a chụpụ ndị na-ezu ohi. Dịka e si deekwa ya nʼakụkụ nke ọzọ ya, onye ọ bụla na-aṅụ iyi ụgha ka a ga-esitekwa nʼala ahụ chụpụ.  
\v 4 Ezipụla m ya, otu a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwubiri, ‘Ọ ga-abanye nʼụlọ onye ọ bụla na-ezu ohi, na nʼụlọ ndị ji aha m na-aṅụ iyi ụgha. Ọ ga-anọgide nʼụlọ ahụ mebie ya kpamkpam. Ọ ga-emebi osisi na nkume niile e ji wuo ụlọ ahụ.’ ” 
\s1 Nwanyị nọ nʼime nkata 
\p  
\v 5 Mgbe ahụ, mmụọ ozi ahụ na-agwa m okwu bịakwutere m sị, “Lelie anya gị elu hụrụ ihe na-aga ịpụta ìhè.” 
\p  
\v 6 Asịrị m, “Gịnị ka ọ bụ?” 
\p Ọ sịrị, “Ọ bụ nkata.”\f + \fr 5:6 \ft Maọbụ, \fqa ihe ọtụtụ Efa.\f* O kwukwara, “Nke a bụ mmehie nke ndị niile bi nʼala a.” 
\p  
\v 7 Ngwangwa, e kpughepụrụ okwuchi nkata ahụ, ma lee, ahụrụ m otu nwanyị nọdụrụ ọdụ nʼime ya.  
\v 8 Ọ sịrị, “Nke a bụ ajọ omume.” O nughachiri ya azụ nʼime nkata ahụ werekwa okwuchi nkata ahụ kpuchie ya. 
\p  
\v 9 Mgbe ahụ, eleliri m anya hụ ụmụ nwanyị abụọ ọzọ, ndị ikuku na-efe nku ha. Ha nwere nku dịka nku ụgbala. Ha buliri nkata ahụ elu nʼetiti eluigwe na ala. 
\p  
\v 10 Ajụrụ m mmụọ ozi ahụ na-agwa m okwu, “Ebee ka ha bu nkata ahụ na-aga?” 
\p  
\v 11 Ọ gwara m, “Ha bu ya na-aga Babilọn\f + \fr 5:11 \ft Ya bụ, Shaịna\f* ebe ha ga-ewuru ya ụlọ. Mgbe ha wuchara ụlọ ahụ, ha ga-adọba nkata ahụ nʼelu ihe ndọkwasị.” 
\c 6  
\s1 Ụgbọala anọ 
\p  
\v 1 Elelikwara m anya elu ọzọ hụ ụgbọ ịnyịnya anọ nke si nʼetiti ugwu abụọ na-apụta. Ugwu ndị a bụ ugwu e ji bronz mee.  
\v 2 Ụgbọ ịnyịnya nke mbụ ka ịnyịnya na-acha ọbara ọbara na-adọkpụ. Nke abụọ ka ịnyịnya na-eji nji na-adọkpụ.  
\v 3 Nke atọ ka ịnyịnya dị ọcha na-adọkpụ, ma nke anọ ka ịnyịnya tụrụ agwa siekwa ike na-adọkpụ.  
\v 4 Ajụrụ m mmụọ ozi ahụ na-agwa m okwu, “Gịnị ka ihe ndị a bụ, nna m ukwu?” 
\p  
\v 5 Mmụọ ozi ahụ zara m, sị, “Ndị a bụ mmụọ anọ\f + \fr 6:5 \ft Maọbụ, \fqa ikuku\f* nke eluigwe, ka ha na-apụ mgbe ha guzochara nʼihu \nd Onyenwe\nd* elu ụwa niile.  
\v 6 Ụgbọala nke ịnyịnya ndị dị oji na-adọkpụ na-aga nʼakụkụ ugwu. Nke ịnyịnya ndị dị ọcha na-adọkpụ na-aga nʼọdịda anyanwụ. Nke ahụ ndị ịnyịnya na-adịghị ezi ọcha na-adọkpụ na-aga nʼakụkụ ndịda.” 
\p  
\v 7 Mgbe ịnyịnya ndị ahụ dị ike pụtara, chọọ ka e nye ha ike ijegharị nʼụwa niile, ọ gwara ha sị, “Gaanụ jegharịa nʼụwa niile.” Nʼihi ya, ha pụrụ jegharịa nʼụwa niile. 
\p  
\v 8 Mgbe ahụ, ọ gwara m, “Ndị ahụ jere nʼakụkụ ugwu emeela ka Mmụọ m dajụọ nʼala dị nʼakụkụ ugwu.” 
\s1 Okpueze Joshua 
\p  
\v 9 Okwu \nd Onyenwe anyị\nd* ruru m ntị, sị,  
\v 10 “Gaa nata Heldai, Tobaija na Jedaya, ndị a dọtara nʼagha si Babilọn lọta ọlaọcha na ọlaedo. Nʼotu ụbọchị ahụ, gakwaa nʼụlọ Josaya nwa Zefanaya.  
\v 11 Jiri ọlaọcha na ọlaedo ahụ kpụọ otu okpueze, were ya kpukwasị Joshua nwa Jehozadak bụ onyeisi nchụaja nʼisi.  
\v 12 Gwa ya na ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwuru, ‘Nke a bụ nwoke ahụ aha ya bụ Ngalaba. Ọ ga-esi nʼebe nke ya wapụta wuo ụlọnsọ ukwu nke \nd Onyenwe anyị\nd*.  
\v 13 Ọ bụ ya ga-arụ ụlọnsọ ukwu nke \nd Onyenwe anyị\nd*. A ga-eyikwasịkwa ya ịma mma dịka uwe, ọ ga-anọdụ nʼocheeze ya na-achị. Ọ ga-abụ onye nchụaja ga-anọ nʼocheeze ya, mee ka ịdị nʼotu dịrị nʼetiti ha abụọ.’  
\v 14 Okpueze ahụ ka a ga-enye Heldaya, Tobaija, Jedaya na Hen, nwa Zefanaya, ka ọ bụrụ ihe ncheta nʼụlọnsọ ukwu nke \nd Onyenwe anyị\nd*.  
\v 15 Ndị nọ nʼebe dị anya ga-esi ebe ahụ bịa nye aka nʼọrụ iwu ụlọnsọ ukwu nke \nd Onyenwe anyị\nd*. Unu ga-amatakwa na ọ bụ \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile zitere m ịbịakwute unu. Ihe ndị a niile ga-eme ma ọ bụrụ na unu akpachapụ anya rubere \nd Onyenwe anyị\nd* Chineke unu isi.” 
\c 7  
\s1 Obi ebere na ikpe ziri ezi 
\p  
\v 1 Nʼafọ nke anọ nke ọchịchị eze Daraiọs, okwu nke \nd Onyenwe anyị\nd* ruru Zekaraya ntị nʼụbọchị nke anọ, nʼọnwa nke itoolu, nke bụ ọnwa Kislev.  
\v 2 Nʼoge a, ndị bi nʼobodo Betel ezitela Shareza, na Regem Melek, ha na ndị ọzọ ka ha bịa rịọọ \nd Onyenwe anyị\nd* arịrịọ,  
\v 3 ka ọ jụkwaa ndị nchụaja nọ nʼụlọnsọ ukwu nke \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, na ndị amụma, sị, “Ọ bụ m ruo ụjụ, bukwaa ọnụ nʼọnwa nke ise, dịka m si eme kemgbe ọtụtụ afọ ndị a gara aga?” 
\p  
\v 4 Mgbe ahụ, okwu nke \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile ruru m ntị,  
\v 5 “Gwanụ ndị nchụaja na ndị niile bi nʼala a, ‘Mgbe unu na-ebu ọnụ nʼọnwa nke ise ọbụla, na nʼọnwa nke asaa ọbụla, iri afọ asaa ndị a niile gara aga, ọ bụ mụ ka unu na-eburu ọnụ?  
\v 6 Mgbe unu na-eri na-aṅụkwa, ọ bụ na unu anaghị eme ya maka nʼihi onwe unu?  
\v 7 Ihe ndị a ha ọ bụghị okwu niile \nd Onyenwe anyị\nd* kpọsara site nʼọnụ ndị amụma mbụ, mgbe Jerusalem na obodo niile dị ya gburugburu nọ nʼudo\f + \fr 7:7 \ft Ya bụ, ndị Jụụ\f* nwekwa ọganihu, nʼoge ndị mmadụ bi na Negev, ya na ala ndịda ugwu niile?’ ” 
\p  
\v 8 Mgbe ahụ, okwu nke \nd Onyenwe anyị\nd* ruru Zekaraya ntị na-asị,  
\v 9 “Ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwuru, ‘Kpeenụ ikpe ziri ezi, meerenụ ibe unu ebere, ma gosikwa ibe unu ọmịiko.  
\v 10 Unu emegbula ụmụ nwanyị di ha nwụrụ maọbụ nwa na-enweghị nne na nna maọbụ ndị ọbịa maọbụ ndị ogbenye. Unu echela echiche ọjọọ nʼobi unu megide ibe unu.’ 
\p  
\v 11 “Ma ha jụrụ ige ntị; ha sitere nʼobiike ha gbakụta m azụ ha, were mkpịsịaka rụchie ntị ha, ka ha ghara ige m ntị.  
\v 12 Ha mere ka obi ha sie ike dịka nkume, jụ ige ntị nʼiwu, na nʼokwu nke \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile sitere na Mmụọ ya zie ndị amụma mbụ ahụ. Nʼihi ya, \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile were oke iwe. 
\p  
\v 13 “ ‘Ebe ọ bụ na mgbe m kpọrọ ha, ha egeghị ntị, agaghị m ege ntị mgbe ha ga-akpọ m,’ Ọ bụ ihe \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile na-ekwu.  
\v 14 ‘Eji m oke ifufe gbasasịa ha nʼetiti mba niile, ndị ha na-amaghị. Emere m ka ala ha tọgbọrọ nʼefu, ka mmadụ ọbụla hapụ inwe ike ịpụ maọbụ ịbata nʼime ya. Otu a ka ha si mee ka ala ọma ahụ ghọọ ala tọgbọrọ nʼefu.’ ” 
\c 8  
\s1 \nd Onyenwe anyị\nd* ekwe nkwa ịgọzi Jerusalem 
\p  
\v 1 Okwu \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile ruru m ntị na-asị, 
\p  
\v 2 Ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwuru: “Ana m ekwo ekworo dị ukwuu nʼihi Zayọn. Nʼezie, ekworo ahụ na-anụ m ọkụ dị ukwuu nʼahụ.” 
\p  
\v 3 Ihe ndị a ka \nd Onyenwe anyị\nd* kwuru, “Aga m alọghachi na Zayọn, bịa biri na Jerusalem. Mgbe ahụ, a ga-akpọ Jerusalem, obodo Eziokwu. A ga-akpọkwa ugwu \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile Ugwu Nsọ.” 
\p  
\v 4 Ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwuru, “Agadi ndị ikom na agadi ndị inyom ga-anọdụkwa ala ọzọ na mbara ụzọ niile nke Jerusalem, onye ọbụla ga-ejidekwa mkpara nʼaka ya\f + \fr 8:4 \ft E ji mara ndị agadi.\f* nʼihi ọnụọgụgụ afọ ha gbara.  
\v 5 Okporoụzọ nke obodo ahụ niile ga-ejupụtakwa nʼụmụntakịrị ndị nwoke na ndị nwanyị na-egwugharị egwu na ama ebe ahụ.” 
\p  
\v 6 Ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwuru, “O nwere ike bụrụ na ihe ndị a ga-adị ka ihe dịkarịrị ike imezu nʼanya ndị ahụ ga-afọdụ nʼoge ahụ, ma ọ ga-abụ ihe dịkarịrị ike ime nʼanya m?” Otu a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwubiri. 
\p  
\v 7 Ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwuru, “Aga m azọpụta ndị m site na mba niile dị nʼọwụwa anyanwụ na nʼọdịda anyanwụ.  
\v 8 Aga m akpọghachitekwa ha, mee ka ha biri na Jerusalem. Ha ga-abụkwa ndị m, mụ onwe m ga-abụ Chineke ha, onye ezi omume na onye kwesiri ntụkwasị obi.” 
\p  
\v 9 Ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwuru: “Ka aka unu sie ike,\f + \fr 8:9 \ft O nwekwara ike ị bụ, ka obi sie unu ike\f* ka enwe ike wuo ụlọnsọ a, unu ndị na-anụ ugbu a otu okwu ahụ, nke ndị amụma kwuru mgbe a tọrọ ntọala iwugharị ụlọnsọ m, bụ ụlọ \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile.  
\v 10 Tupu ụbọchị ahụ, akwụbeghị ma ndị mmadụ ma ụmụ anụmanụ ụgwọ ọrụ ha. Ọ dịghịkwa udo dịrị onye ọbụla na-apụ apụ maọbụ onye na-abata abata nʼihi ndị iro ya, ebe m mere ka onye ọbụla bụrụ onye na-emegide ibe ya.  
\v 11 Ma ugbu a, agaghị m emeso ndị fọdụrụ nʼala a, dịka m si meso ha nʼoge gara aga.” Otu a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwupụtara. 
\p  
\v 12 “Nʼihi na mkpụrụ ga-eto nke ọma, osisi vaịnị ga-amị mkpụrụ ya, ala ubi ga-ewepụtakwa ihe omume, igirigi eluigwe ga-ezokwasịkwa ala. Ihe ndị a niile ka m ga-enye ndị fọdụrụ nʼala a ka ọ bụụrụ ha ihe nketa.  
\v 13 Dịka unu bụ Juda na Izrel si bụrụ ihe a na-abụ ọnụ nʼetiti mba dị iche iche, otu a ka m ga-esi zọpụta unu, unu ga-abụkwa ngọzị. Unu atụla ụjọ, kama meenụ ka aka unu sie ike nʼọrụ unu.” 
\p  
\v 14 Ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwuru, “Dịka m si kpebie ime ka ihe ọjọọ bịakwasị unu, na dịka m na-egosighị ebere nʼahụ nna nna unu ha mgbe ha kpasuru m iwe,” ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile na-ekwu,  
\v 15 “otu a ka m kpebikwara ọzọ nʼụbọchị ndị a imere Jerusalem na Juda ihe ọma. Unu atụla ụjọ.  
\v 16 Ihe ndị a ka unu ga-eme: Kwuonụ eziokwu nye ibe unu, kpeenụ ikpe eziokwu nʼụlọikpe unu, nke a na-eweta udo.  
\v 17 Unu echela echiche ọjọọ megide ibe unu; unu ahụla ịṅụ iyi ụgha nʼanya. Ihe ndị a niile ka m kpọrọ asị,” otu a ka \nd Onyenwe anyị\nd* kwubiri ya. 
\p  
\v 18 Okwu \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile ruru m ntị na-asị, 
\p  
\v 19 Ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile na-ekwu: “Ibu ọnụ unu na-ebu nʼọnwa nke anọ, ọnwa nke ise, ọnwa nke asaa na nʼọnwa nke iri ga-aghọrọ unu oge ịṅụrị ọṅụ na oge obi ụtọ. Ha ga-abụrụ Juda mmemme obi ụtọ. Nʼihi ya, hụnụ eziokwu na udo nʼanya.” 
\p  
\v 20 Ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile na-ekwukwa: “Ndị dị iche iche na ndị bi nʼọtụtụ obodo dị iche iche ka ga-abịa.  
\v 21 Ndị bi nʼotu obodo ga-ejekwa nʼobodo ọzọ, sị, ‘Ka anyị jee na-atụfughị oge gaa rịọọ \nd Onyenwe anyị\nd* arịrịọ, ka anyị chọọnụ \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile. Mụ onwe m na-ejekwa.’  
\v 22 Ọtụtụ ndị mmadụ na ọtụtụ mba dị ike ga-abịa Jerusalem ịchọ \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, na ịrịọ ya arịrịọ.” 
\p  
\v 23 Ihe ndị a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwuru, “Nʼụbọchị ndị ahụ, mmadụ iri, ndị ga-esi na mba dị iche iche, ndị na-asụkwa asụsụ dị iche iche, ga-ejide otu onye Juda aka nʼọnụ ọnụ uwe ya na-asị, ‘Kwere ka anyị soro gị jee, nʼihi na anyị anụla na Chineke nọnyeere unu.’ ” 
\c 9  
\s1 Ikpe ọmụma megide ndị iro Izrel 
\p  
\v 1 Okwu Amụma. 
\q1 Nke a bụ okwu \nd Onyenwe anyị\nd* megide ala Hadrak, 
\q2 na obodo Damaskọs ka ọ ga-ezukwa ike, 
\q1 nʼihi nʼebe \nd Onyenwe anyị\nd* nọ ka anya mmadụ niile 
\q2 na ebo niile nke Izrel dị. 
\q1  
\v 2 Otu ahụkwa ka ọ dị Hamat, nke dị ya nso; 
\q2 tinyekwara Taịa na Saịdọn, ọ bụ ezie na ha bụ ndị maara ihe nke ukwu. 
\q1  
\v 3 Taịa ewuolara onwe ya ebe e wusiri ike, 
\q2 tụkọba ọlaọcha dịka aja, 
\q2 na ọlaedo dịka uzuzu nke okporoụzọ. 
\q1  
\v 4 Ma Onyenwe anyị ga-anapụ ya ihe niile o nwere 
\q2 ọ ga-atụnye ike ya nʼoke osimiri, 
\q2 ọ ga-ejikwa ọkụ repịa ya. 
\q1  
\v 5 Ashkelọn ga-ejupụta nʼụjọ mgbe ọ ga-ahụ ihe ndị a ka ha na-eme. 
\q2 Gaza kwa, ga-aṅagharị onwe ya nʼime oke ihe mgbu. 
\q2 Ọ bụladị Ekrọn ga-ama jijiji nʼụjọ mgbe ha hụrụ na olileanya ha agwụla. 
\q1 A ga-anapụ Gaza eze ya ma gbukwaa ya. 
\q2 Ọ dịghị onye ọbụla ga-ebikwa nʼAshkelọn. 
\q1  
\v 6 Ụmụ amụtara nʼịkwa iko ga-ebichi obodo Ashdọd, 
\q2 aga m emekwa ka mpako ndị Filistia ndị a kwụsị. 
\q1  
\v 7 Aga m wezuga ọbara niile site nʼọnụ ha, 
\q2 wezugakwa ihe rụrụ arụ niile site nʼetiti eze ya. 
\q1 Ndị niile fọdụrụ ga-abụ ndị nke Chineke anyị, 
\q2 ha ga-adị ka otu agbụrụ na Juda. 
\q2 Ekrọn ga-adịkwa ka ndị Jebus. 
\q1  
\v 8 Aga m echebe ụlọ m dịka onye nche, 
\q2 ka ndị iro ghara ịbata na ya. 
\q1 Ndị mkpagbu agaghị emerikwa ndị m ọzọ nʼagha, 
\q2 nʼihi na anọ m na nche ugbu a. 
\s1 Ọbịbịa nke eze Zayọn 
\q1  
\v 9 Ṅụrịa ọṅụ nke ukwuu, gị Ada Zayọn! 
\q2 Tie mkpu ọṅụ, gị Ada Jerusalem! 
\q1 Nʼihi na lee, eze gị na-abịakwute gị, 
\q2 onye ezi omume na onye nwere mmeri, 
\q1 onye ewedara nʼala, nke na-anọkwasị nʼelu ịnyịnya ibu, 
\q2 ọ bụladị nʼelu nwa ịnyịnya ibu, nwa ịnyịnya na-ebu ibu. 
\q1  
\v 10 Ọ ga-ewezuga ụgbọ ịnyịnya niile nke Ifrem, 
\q2 na ịnyịnya agha niile nke Jerusalem; 
\q2 a ga-agbajikwa ụta agha. 
\q1 Ọ ga-ewetara mba niile udo, 
\q2 ọchịchị ya ga-esite nʼotu oke osimiri ruo nʼosimiri nke ọzọ, 
\q2 sitekwa nʼOsimiri Yufretis ruo na nsọtụ niile nke ụwa. 
\q1  
\v 11 Ma gị onwe gị kwa, aga m eme ka ndị a tụrụ mkpọrọ nʼolulu nke mmiri na-adịghị nwere onwe ha, 
\q2 nʼihi ọbara nke ọgbụgba ndụ ahụ mụ na unu gbara. 
\q1  
\v 12 Lọghachinụ nʼebe unu niile e wusiri ike, unu bụ ndị mkpọrọ nwere olileanya. 
\q2 Ọ bụladị taa, ana m ekwupụta ya na m ga-eme ka unu lọta, gọziekwa unu okpukpu abụọ. 
\q1  
\v 13 Aga m agbagọ Juda dịka m si ekwe ụta m, 
\q2 tinye Ifrem dịka àkụ. 
\q1 Aga m akwali ụmụ gị ndị ikom, gị Zayọn, 
\q2 ka ha megide ụmụ ndị ikom ndị Griis. 
\q2 Aga m eme gị ka ị dịrị ka mma agha dị nʼaka dike nʼagha. 
\s1 \nd Onyenwe anyị\nd* ga-egosi onwe ya 
\q1  
\v 14 Mgbe ahụ, \nd Onyenwe anyị\nd* ga-egosi onwe ya nʼebe dị elu karịa ha, 
\q2 àkụ ya ga-efekwa dịka amụma. 
\q1 Onye kachasị ihe niile elu, bụ \nd Onyenwe anyị\nd* ga-afụ opi ike, 
\q2 ọ ga-azọkwa ije nʼoke ifufe nke si na ndịda. 
\q2  
\v 15 \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile ga-echebe ha. 
\q1 Ha ga-ebibi, 
\q2 zọdakwa nkume ịtụ iche nʼebe niile. 
\q1 Ha ga-aṅụ ihe ọṅụṅụ mekwa mkpọtụ site na mmanya; 
\q2 ha ga-ejupụta dịka efere, 
\q2 dịka efere eji efesa ihe nʼakụkụ niile ebe a na-achụ aja na-ejupụta. 
\q1  
\v 16 Mgbe ụbọchị ahụ bịara, \nd Onyenwe anyị\nd* bụ Chineke ha ga-azọpụta ndị ya, 
\q2 dịka onye ọzụzụ atụrụ si azọpụta igwe ewu na atụrụ ya. 
\q1 Ha ga-acha, na-egbuke nʼala ya, dịka nkume dị oke ọnụahịa 
\q2 e tinyere nʼokpueze si na-egbuke. 
\q1  
\v 17 Nʼezie, lee ka ịdị mma nke ala ahụ si dị ukwuu! Leekwa ka ịma mma ya si dị ukwuu! 
\q2 Mkpụrụ ubi ga-eme ka ụmụ okorobịa tozuo oke nke ọma, 
\q2 mmanya vaịnị ọhụrụ ga-emekwa ka ụmụ agbọghọ doo ahụ. 
\c 10  
\s1 \nd Onyenwe anyị\nd* ga-elekọta Juda 
\q1  
\v 1 Rịọọnụ \nd Onyenwe anyị\nd* mmiri ozuzo nʼoge mmiri ozuzo nke ikpeazụ, 
\q2 nʼihi na ọ bụ \nd Onyenwe anyị\nd* na-ezite oke amụma mmiri. 
\q1 Ọ bụ ya na-enye ụmụ mmadụ mmiri ozuzo, 
\q2 na-enyekwa mmadụ niile ihe ọkụkụ nke ubi. 
\q1  
\v 2 Arụsị niile na-ekwu okwu aghụghọ, 
\q2 ndị na-agba aja nʼahụ ọhụ bụ ụgha, 
\q1 ndị ha na-arọ nrọ, na-akọwakwa nrọ ụgha, 
\q2 okwu nkasiobi nke ihe na-adịghị nʼime ya ka ha na-enye. 
\q1 Ya mere, ndị mmadụ na-akpagharị dịka atụrụ 
\q2 a na-akpagbu ha nʼihi enweghị onye ọzụzụ atụrụ. 
\b  
\q1  
\v 3 “Iwe m na-ere ọkụ megide ndị ọzụzụ atụrụ, 
\q2 aga m atakwa ndị ndu\f + \fr 10:3 \ft Ọ bụ mkpi na-ebuta ụzọ mgbe ha na-aga nʼigwe.\f* niile ahụhụ; 
\q1 nʼihi na \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile 
\q2 ga-elekọta igwe anụ ụlọ ya, ya bụ ndị Juda, 
\q2 ọ ga-eme ka ha dịrị ka ịnyịnya dị ebube nʼagha. 
\q1  
\v 4 A ga-esi na Juda nweta nkume bụ ide ji ụlọ,\f + \fr 10:4 \ft Maọbụ, \fqa nkume nkuku ụlọ\f* 
\q2 a ga-esi na ha nweta ǹtu ụlọ ikwu, 
\q1 a ga-esi na ha nweta ụta a kwadoro maka agha, 
\q2 sitekwa na ha nweta ndị ndu dị iche iche. 
\q1  
\v 5 Ha niile ga-ejikọta onwe ha ọnụ, dịka ndị bụ dike nʼagha, 
\q2 ha ga-azọda ndị iro ha nʼapịtị nke okporoụzọ niile. 
\q1 Nʼihi na \nd Onyenwe anyị\nd* nọnyeere ha, 
\q2 ha ga-alụgbukwa ndị iro niile na-agba ịnyịnya. 
\b  
\q1  
\v 6 “Aga m eme ka ụlọ Juda dị ike, 
\q2 zọpụtakwa ụlọ Josef. 
\q1 Aga m eme ka ha lọghachita, 
\q2 nʼihi na aga m egosi ha obi ebere. 
\q1 Ha ga-adị 
\q2 ka ndị m na-ajụghị mgbe ọbụla, 
\q1 nʼihi na mụ onwe m bụ \nd Onyenwe anyị\nd* Chineke ha, 
\q2 aga m azakwa arịrịọ ha. 
\q1  
\v 7 Ndị Ifrem ga-aghọ ndị dị ike nʼagha, 
\q2 ha ga-enwe ọṅụ dịka ndị na-aṅụ mmanya. 
\q1 Ụmụ ha ga-ahụ ya ṅụrịakwa ọṅụ, 
\q2 ha ga-ejikwa obi ha niile ṅụrịa ọṅụ nʼime \nd Onyenwe anyị\nd*. 
\q1  
\v 8 Mgbe ahụ, aga m akpọ ha oku, 
\q2 chịkọtaa ha. 
\q1 Nʼezie, aga m agbapụta ha, 
\q2 ha ga-adịkwa ukwuu dịka ha dị na mbụ. 
\q1  
\v 9 A sịkwarị na m chụsara ha nʼetiti ndị dị iche iche, 
\q2 ma ha ga-echeta m site nʼala niile ahụ dị anya. 
\q1 Ha na ụmụ ha ga-adịkwa ndụ; 
\q2 ha ga-alọtakwa. 
\q1  
\v 10 Aga m esi nʼala Ijipt kpọlata ha, 
\q2 sitekwa nʼAsịrịa chịkọtaa ha. 
\q1 Aga m akpọta ha na Gilead na Lebanọn. 
\q2 Ha agaghị enwekwa ebe ga-ezuru ha niile. 
\q1  
\v 11 Ha ga-esi nʼosimiri nsogbu gafee. 
\q2 A ga-emekwa ka mmali elu nke osimiri dajụọ. 
\q2 Ebe obibi niile nke osimiri Naịl ga-atakọrọkwa. 
\q1 A ga-egbuda mpako niile nke Asịrịa, 
\q2 wezugakwa mkpara ọchịchị nke ndị Ijipt. 
\q1  
\v 12 Aga m eme ka ha dị ike nʼime \nd Onyenwe anyị\nd*, 
\q2 ọ bụkwa nʼaha ya ka ha ga na-ejegharị nʼudo.” 
\q2 Otu a ka \nd Onyenwe anyị\nd* kwubiri. 
\b  
\c 11  
\q1  
\v 1 Meghee ọnụ ụzọ gị niile, gị Lebanọn. 
\q2 Ka ọkụ repịa osisi sida gị niile. 
\q1  
\v 2 Kwasie akwa ike, gị osisi junipa, nʼihi na osisi sida adaala, 
\q2 nʼihi na e mebiela osisi ukwu ndị niile ahụ mabigara mma oke. 
\q1 Kwasienụ akwa ike, unu osisi ook nke Bashan, 
\q2 nʼihi na e gbudachala oke ọhịa ahụ! 
\q1  
\v 3 Gee ntị nʼụzụ akwa nke ndị ọzụzụ atụrụ, 
\q2 e mebiela ebe ịta nri mara mma nke anụ ụlọ ha. 
\q1 Gee ntị ka unu nụrụ olu mbigbọ nke ụmụ ọdụm, 
\q2 nʼihi na e bibiela oke ọhịa nke Jọdan. 
\s1 Ndị ọzụzụ atụrụ abụọ 
\p  
\v 4 Ihe ndị a ka \nd Onyenwe anyị\nd* Chineke m kwuru, “Zụọnụ igwe ewu na atụrụ ndị a ga-egbu egbu nri.  
\v 5 Ndị na-azụrụ ha na-egbu ha ma ọ dịghị ahụhụ na-abịakwasị ha. Ndị na-erekwa ha na-asị, ‘Toonu \nd Onyenwe anyị\nd*, nʼihi na abụ m ọgaranya.’ Ndị ọzụzụ ha adịghị enwe ọmịiko nʼahụ ha.  
\v 6 Nʼihi na mụ onwe m agakwaghị egosi ndị ala a obi ebere.” Otu a ka \nd Onyenwe anyị\nd* kwubiri. “Aga m ewere onye ọbụla nʼime ha nyefee nʼaka onye agbataobi ya, na nʼaka eze ha. Ha ga-ebibi ala a kpamkpam, ma mụ onwe m agaghị anapụta onye ọbụla site nʼaka ha.” 
\p  
\v 7 Nʼihi ya, azụrụ m igwe ewu na atụrụ ndị ahụ a ga-egbu egbu, nke ka nke, ndị ahụ a na-emegbu emegbu. Eweere m mkpanaka abụọ, kpọọ otu nʼime ha Amara, kpọọ nke ọzọ Ịdị nʼotu. Azụkwara m igwe atụrụ ndị ahụ.  
\v 8 Nʼime otu ọnwa, ewezugara m ndị ọzụzụ atụrụ atọ. 
\p Igwe ewu na atụrụ ndị ahụ kpọkwazịrị m asị, enwezighị m ike nweere ha ndidi.  
\v 9 Nʼihi ya, ekwuru m si, “Agaghị m abụkwa onye ọzụzụ atụrụ unu ọzọ. Nke ọbụla na-anwụ, ya nwụọ, ọzọ, nke na-ala nʼiyi, ya laa nʼiyi. Ka ndị fọdụrụ rie anụ ahụ ibe ha.” 
\p  
\v 10 Mgbe ahụ, eweere m mkpanaka m, nke a kpọrọ Amara gbajie ya abụọ, igosi na emebiela m ọgbụgba ndụ nke mụ na ndị mmadụ gbara.  
\v 11 Nʼụbọchị ahụ ka e mere ka ọgbụgba ndụ ahụ gharakwa ịdị. Mgbe ahụ, ndị ahụ a na-akpagbu nʼetiti igwe ewu na atụrụ ahụ, bụ ndị na-ele m anya matara na ọ bụ okwu \nd Onyenwe anyị\nd*. 
\p  
\v 12 Mgbe ahụ, agwara m ha, “Ọ bụrụ na ọ masịrị unu, unu kwụọ m ụgwọ ọrụ m, ọ bụrụkwa na ọ masịghị unu, deberenụ onwe unu ego unu.” Nʼihi nke a, ha gụpụtara mkpụrụ ego ọlaọcha iri atọ, jiri ya kwụọ m ụgwọ. 
\p  
\v 13 \nd Onyenwe anyị\nd* gwara m, “Tụpụrụ ya ọkpụ ite,” bụ ọnụahịa magburu onwe ya bụ nke ha rụrụ nʼisi m. Ya mere, eweere m iri ọlaọcha atọ ahụ tụpụrụ ya ọkpụ ite nʼụlọnsọ ukwu nke \nd Onyenwe anyị\nd*. 
\p  
\v 14 Mgbe ahụ, agbajiri m mkpanaka m nke abụọ a na-akpọ Ịdị nʼotu, izipụta na njikọta maọbụ ịdị nʼotu dị nʼetiti Juda na Izrel adịghịkwa. 
\p  
\v 15 Mgbe ahụ, \nd Onyenwe anyị\nd* gwara m, “Chịrịkwa ngwa ọrụ nke onye ọzụzụ atụrụ nzuzu ahụ,  
\v 16 nʼihi na ana m aga ịkpọlite otu onye ọzụzụ atụrụ nke na-agaghị elekọta ụmụ atụrụ furu efu, maọbụ chọọ ndị na-etolite, maọbụ gwọọ ndị merụrụ ahụ, maọbụ nye ndị ahụ dị ike nri. Kama ọ ga-eri anụ atụrụ ndị ahụ ahụ ha dị mma, nyakapụkwa ụkwụ ha niile. 
\q1  
\v 17 “Ahụhụ dịrị onye ọzụzụ atụrụ ahụ na-abaghị uru, 
\q2 nke na-adịghị elezi igwe ewu na atụrụ ya anya. 
\q1 Ka mma agha gbupụ ya otu aka, ghụpụkwa ya anya aka nri ya. 
\q2 Ka ogwe aka ya kpọnwụọkwa kpamkpam. 
\q2 Otu a, anya aka nri ya ga-akpọkwa.” 
\c 12  
\s1 Mbibi dịrị ndị iro Jerusalem 
\p  
\v 1 Nke a bụ okwu nke \nd Onyenwe anyị\nd* banyere Izrel. Ọ bụ amụma. 
\b  
\p \nd Onyenwe anyị\nd*, onye gbasapụrụ eluigwe niile, onye tọrọ ntọala ụwa, na onye kpụrụ mmụọ nke dị nʼime mmadụ, ekwupụtala, sị,  
\v 2 “Agaje m ime Jerusalem ka ọ bụrụ iko mmanya nke ga-aṅagharị ndị niile gbara ya gburugburu. Ha ga-agba Juda na Jerusalem gburugburu, nọbichie ụzọ ya niile.  
\v 3 Nʼụbọchị ahụ, mgbe mba niile nke ụwa chịkọtara onwe ha ọnụ imegide ya, aga m eme Jerusalem ka ọ ghọọrọ mba ndị ahụ niile nkume dị ukwuu nke a na-apụghị inugharị enugharị. Ndị niile ga-agbalị inugharị ya ga-emerụ onwe ha ahụ.  
\v 4 Nʼụbọchị ahụ, aga m etinye ụjọ nʼobi ịnyịnya niile, mee ka ndị na-agba ha ghọọ ndị ara,” otu a ka \nd Onyenwe anyị\nd* kwubiri. “Aga m asaghe anya m lekwasị ụlọ Juda nke ọma, ma aga m eme ka ịnyịnya niile nke mba niile kpuo ìsì.  
\v 5 Mgbe ahụ, ndị ndu Juda ga-ekwu nʼobi ha sị, ‘Ndị Jerusalem achọtala ike nʼihi na \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, bụ Chineke ha.’ 
\p  
\v 6 “Nʼụbọchị ahụ, aga m eme ka ndị ndu Juda niile dịrị ka ite ọkụ, nke a dọnyere nʼebe a chịkọtara nkụ. Ha ga-adịkwa ka ọkụ na-enwu enwu, nke dị nʼetiti ukwu ọka. Ha ga-ere ọkụ nʼaka nri na nʼaka ekpe, rechapụ ndị niile bi gburugburu ha. Ma mmadụ ga-ejupụtakwa nʼime Jerusalem. 
\p  
\v 7 “\nd Onyenwe anyị\nd* ga-ebu ụzọ zọpụta ebe obibi niile nke Juda, ime ka ugwu na nsọpụrụ nke ụlọ Devid, na nke ndị niile bi na Jerusalem ghara ịdị ukwuu karịa nke Juda.  
\v 8 Nʼụbọchị ahụ, \nd Onyenwe anyị\nd* ga-echebe ndị bi na Jerusalem, mee ka ọ bụladị ndị na-asọ ngọngọ nʼetiti ha dịrị ike dịka Devid. Ụlọ Devid ga-adịkwa ka Chineke, dịka Mmụọ ozi \nd Onyenwe anyị\nd*, onye na-eje nʼihu ha.  
\v 9 Nʼụbọchị ahụ, aga m ebido ibibi mba ndị ahụ niile na-ebuso Jerusalem agha. 
\s1 Iru ụjụ banyere onye ahụ a mapuru ahụ 
\p  
\v 10 “Mgbe ahụ, aga m awụkwasị nʼụlọ Devid na ndị niile bi na Jerusalem, mmụọ nke amara na nke arịrịọ amara. Ha ga-elegidekwa m anya, bụ onye ahụ ha mapuru ahụ. Ha ga-eru ụjụ nʼihi ya, dịka mmadụ si eru ụjụ nʼihi ọnwụ nke nwa a mụrụ naanị ya. Ha ga-ebekwa akwa ilu nke ukwuu dịka mmadụ sị ebe akwa maka nwa mbụ ya.  
\v 11 Nʼụbọchị ahụ, akwa a ga-akwa na Jerusalem ga-adị ukwuu, dịka akwa nke Hadad Rimọn nʼobosara ala Megido.  
\v 12 Ndị ala ahụ niile ga-eru ụjụ. Ikwu ọbụla ga-eru ụjụ nke ha, ha na ndị nwunye ha. Ikwu Devid na ndị nwunye ha, na ikwu Netan na ndị nwunye ha,  
\v 13 na ikwu Livayị, na ndị nwunye ha, na ikwu Shimei na ndị nwunye ha,  
\v 14 na ikwu ndị ọzọ niile na ndị nwunye ha. 
\c 13  
\s1 Nsachapụ mmehie 
\p  
\v 1 “Nʼụbọchị ahụ, a ga-emeghe isi iyi mmiri nye ụlọ Devid na ndị niile bi na Jerusalem. Ọ ga-abụ isi iyi a ga-eji sachapụ mmehie na adịghị ọcha ha niile. 
\p  
\v 2 “Nʼụbọchị ahụ, otu a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, kwubiri, aga m ebipụ aha arụsị niile dị nʼala ahụ, a gaghị echetakwa ha ọzọ. Aga m esitekwa nʼala a wezuga ma ndị amụma ma mmụọ nke adịghị ọcha niile.  
\v 3 Ọ bụrụkwa na onye ọbụla a ga nʼihu na-ebu amụma, nne na nna ndị mụrụ ya ga-asị ya, ‘Ị ghaghị ịnwụ nʼihi na i kwuola okwu ụgha nʼaha \nd Onyenwe anyị\nd*.’ Mgbe onye dị otu a bukwara amụma, ọ bụ nne na nna ya ga-eji ùbe magbuo ya. 
\p  
\v 4 “Nʼụbọchị ahụ, ihere ga-emekwa ndị amụma nʼihi ibu amụma banyere ọhụ nke ha hụrụ. Ha agaghị eyikwa uwe ajị anụ nke ndị amụma na-eyi nʼihi iduhie ndị mmadụ,  
\v 5 Onye ọbụla nʼime ha ga-asịkwa, ‘Abụghị m onye amụma, onye ọrụ ubi ka m bụ, ọ bụ ihe si nʼala ka m ji azụ onwe m site na mgbe m bụ okorobịa.’  
\v 6 Ọ bụrụ na onye ọbụla ajụọ, ‘Gịnị bụ ọnya ndị a niile dị gị nʼahụ?’ Ha ga-azaghachi, ‘Ọnya ndị etipụtara m nʼụlọ ndị enyi m.’ 
\s1 Tigbuo onye ọzụzụ atụrụ, igwe atụrụ agbasasịa 
\q1  
\v 7 “Teta nʼụra, gị mma agha, imegide onye ọzụzụ atụrụ m, 
\q2 na imegide nwoke ibe m, nke nọ m nso,” 
\q2 otu a ka \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile kwubiri. 
\q1 “Tigbuo onye ọzụzụ atụrụ, 
\q2 igwe atụrụ\f + \fr 13:7 \ft Ya bụ, igwe atụrụ nke ọ na-achị\f* ga-agbasasịkwa. 
\q2 Aga m eweli aka m megide ndị dị nta. 
\q1  
\v 8 Nʼala ahụ niile,” otu a ka \nd Onyenwe anyị\nd* kwubiri ya, 
\q2 “Ụzọ mmadụ abụọ nʼime ụzọ atọ ka a ga-etida, 
\q2 ma otu ụzọ nʼime ụzọ atọ ga-afọdụ nʼime ya. 
\q1  
\v 9 Otu ụzọ nʼime ụzọ atọ a fọdụrụ ka m ga-ewebata nʼime ọkụ. 
\q2 Aga m eji ọkụ nụchaa ha dịka e si anụcha ọlaọcha, 
\q2 jiri ọkụ nwaa ha dịka e si anwa ọlaedo. 
\q1 Ha ga-akpọku aha m, 
\q2 aga m azakwa ha. 
\q1 Aga m asịkwa, ‘Ndị a bụ ndị m,’ 
\q2 Ha onwe ha ga-asịkwa, ‘\nd Onyenwe anyị\nd* bụ Chineke anyị.’ ” 
\c 14  
\s1 \nd Onyenwe anyị\nd* na-abịa Ịchị 
\p  
\v 1 Lee, ụbọchị \nd Onyenwe anyị\nd* na-abịa, mgbe a ga-ekesa ihe nkwata gị niile nʼetiti mgbidi gị. 
\p  
\v 2 Aga m achịkọta mba niile ka ha bịa Jerusalem ibuso ya agha. Ha ga-adọta obodo ahụ nʼagha, tụtụkọọ ihe dị nʼụlọ niile, dinaa ndị inyom nʼike. A ga-adọta ọkara ndị bi nʼobodo ahụ nʼagha, duru ha gaa mba ọzọ. Ma ọkara nke ọzọ ka ha ga-ahapụ.  
\v 3 Mgbe ahụ, \nd Onyenwe anyị\nd* ga-apụ ibuso ndị mba ọzọ ahụ agha, dịka o si ebu agha nʼụbọchị agha.  
\v 4 Nʼụbọchị ahụ, ụkwụ ya ga-eguzo nʼelu Ugwu Oliv, nke dị nʼọwụwa anyanwụ Jerusalem. Mgbe ahụ, Ugwu Oliv ga-ekewa abụọ, mee ka ndagwurugwu buru ibu dịrị site nʼọwụwa anyanwụ ruo nʼọdịda anyanwụ. Nʼihi ya, ugwu ahụ ga-eke onwe ya abụọ. Otu akụkụ ga-adị nʼugwu, nke ọzọ ga-adị nʼụzọ ndịda.  
\v 5 Unu ga-esi na ndagwurugwu nke ugwu m ahụ gbalaga, nʼihi na ndagwurugwu ahụ ga-eru Azel. Unu ga-agbapụ dịka unu si gbapụ nʼoge gara aga, mgbe ala ọma jijiji ahụ, nʼoge Uzaya bụ eze Juda. Mgbe ahụ, \nd Onyenwe anyị\nd* Chineke m ga-abịa, ya na ndị nsọ ya. 
\p  
\v 6 Nʼụbọchị ahụ, ìhè anyanwụ agaghị adị, oyi agaghị adị, mkpụrụ mmiri agaghị adịkwa.  
\v 7 Ọ ga-abụ ụbọchị pụrụ iche, ụbọchị ehihie na abalị na-agaghị adịkwa. Ọ bụ ụbọchị nke naanị \nd Onyenwe anyị\nd* maara. Ma ìhè ga-adịkwa nʼoge anyasị. 
\p  
\v 8 Nʼụbọchị ahụ, mmiri na-enye ndụ ga-esi na Jerusalem na-asọpụta. Ọ ga-ekewa abụọ, ọkara ya ga-asọbanye nʼosimiri Nnu dị nʼihu anyanwụ ebe ọkara nke ọzọ ga-asọbanye nʼosimiri Mediterenịa dị nʼọdịda anyanwụ. Ha ga na-asọ nʼọkọchị na nʼudu mmiri. 
\p  
\v 9 Ma \nd Onyenwe anyị\nd* ga-abụ eze nʼelu ụwa niile. Nʼụbọchị ahụ, naanị otu \nd Onyenwe anyị\nd* ga-adị, naanị aha ya kwa ka a ga na-efe ofufe. 
\p  
\v 10 Ala niile, site na Geba ruo Rimọn, nke dị na ndịda Jerusalem ga-adị ka ọzara. Ma ọ bụ naanị Jerusalem ga-adị nʼebe lara elu. Ọ ga-adịkwa nʼọnọdụ ya site nʼọnụ ụzọ ama nke Benjamin ruo nʼebe ọnụ ụzọ ama nke Mbụ, ruo nʼọnụ ụzọ ama nke dị nʼAkụkụ, sitekwa nʼỤlọ elu Hananel ruo nʼebe a na-azọchapụta mmanya eze.  
\v 11 A ga-ebiju na ya na-enweghị nsogbu. A gaghị emebikwa ya ọzọ. Jerusalem ga-ebikwa nʼudo na-atụghị egwu. 
\p  
\v 12 Nke a bụ ọrịa ọjọọ nke \nd Onyenwe anyị\nd* ga-eji kụda mba niile buru agha megide Jerusalem. Anụ ahụ ha ga-ere ure mgbe ha ka guzo ọtọ. Anya ha ga-erekwa ure, ire ha ga-erekwa ure nʼọnụ ha.  
\v 13 Nʼụbọchị ahụ, \nd Onyenwe anyị\nd* ga-etinye ndị mmadụ oke ụjọ nʼobi. Oke ọgbaaghara ga-adị nʼetiti ha, ha ga-alụsokwa ibe ha ọgụ.  
\v 14 Ọ bụladị Juda ga-ebu agha na Jerusalem. A ga-akwakọrọ akụ ndị mba ọzọ dị ha nso, bụ ọtụtụ ọlaedo na ọlaọcha, na uwe mara mma.  
\v 15 Ọrịa ọjọọ dị otu a ga-adakwasị ịnyịnya niile, na ịnyịnya muul, na ịnyịnya kamel niile, na ịnyịnya ibu niile, na anụ niile dị nʼogige ndị agha ha. 
\p  
\v 16 Mgbe ahụ, ndị fọdụrụ na mba niile ndị ahụ busoro Jerusalem agha, ga-abịa kwa afọ kpọọ isiala nye eze, \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile ka ha soro mee mmemme ụlọ Ikwu.  
\v 17 Ọ bụrụ na ndị ọbụla si na mba dị iche iche esoghị jee Jerusalem ife Eze ahụ, bụ \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile, ha agaghị enwetakwa mmiri ozuzo.  
\v 18 Ọ bụrụ na ndị Ijipt ajụ ịga soro ndị ọzọ ife ofufe ahụ, ha agaghị enweta mmiri ozuzo. \nd Onyenwe anyị\nd* ga-eme ka ọrịa ọjọọ ahụ bịakwasị ha, dịka ọ siri bịakwasị mba ndị ahụ niile jụrụ iso mee mmemme ụlọ Ikwu.  
\v 19 Nke a ga-abụ ahụhụ dịrị ndị Ijipt, na ndị mba dị iche iche, ndị na-agaghị eso na mmemme ụlọ Ikwu ahụ. 
\p  
\v 20 Nʼụbọchị ahụ, ihe a ga-ede nʼahụ ataṅụ nke ịnyịnya niile na-anya nʼolu ha bụ nke a: “Ihe dị Nsọ nye \nd Onyenwe anyị\nd*.” Ite niile e ji esi nri dị nʼụlọ nke \nd Onyenwe anyị\nd* ga-adị ka efere nsọ ndị ahụ dị nʼihu ebe ịchụ aja.  
\v 21 Ite niile dị na Juda, na nʼime Jerusalem ga-adị nsọ nye \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile. Ndị niile bịara ịchụ aja ga-ewere ụfọdụ nʼime ite ndị a sie nri ịchụ aja ha. Nʼụbọchị ahụ kwa, a gaghị ahụ kwa ndị na-atụ mgbereahịa\f + \fr 14:21 \ft Maọbụ, \fqa Onye Kenan\f* nʼụlọnsọ ukwu \nd Onyenwe anyị\nd*, Onye pụrụ ime ihe niile.