\id LAM - Biblica® Open Ndebele Contemporary Bible
\h Izililo
\toc1 Izililo
\toc2 Izililo
\toc3 Izi
\mt1 Izililo
\c 1
\q1 
\v 1 Kuthule kuthe cwaka!
\q2 Yeka lelidolobho elalinyakazela abantu!
\q1 Selinjengomfelokazi,
\q2 kanti lalilodumo phakathi kwezizwe.
\q1 Lona elaliyindlovukazi phakathi kwezigodi,
\q2 khathesi seliyisigqili.
\b
\q1 
\v 2 Linjengowesifazane okhala kabuhlungu ebusuku,
\q2 inyembezi zithe hlikilili ezihlathini.
\q1 Kakho phakathi kwazo
\q2 zonke izithandwa zakhe ongamduduza.
\q1 Bonke abangane bakhe bamhlamukele;
\q2 sebeyizitha zakhe.
\b
\q1 
\v 3 UJuda useye ebugqilini
\q2 ngemva kokuhlupheka lokudonsa nzima.
\q1 Usehlala phakathi kwabezizwe;
\q2 akatholi ndawo yokuphumula.
\q1 Bonke abamzingelayo bamxhumile
\q2 ephakathi kokuhlupheka kwakhe.
\b
\q1 
\v 4 Iyalila imigwaqo eya eZiyoni,
\q2 ngoba kasekho ozayo emikhosini yalo emisiweyo.
\q1 Wonke amasango alo asekhohlakele,
\q2 abaphristi balo bayabubula,
\q1 amantombazana alo ayagomela,
\q2 lona lidabukile kakhulu.
\b
\q1 
\v 5 Izitha zalo sezingababusi balo;
\q2 ziyaklamasa.
\q1 \nd UThixo\nd* ulehlisele usizi
\q2 ngenxa yezono zalo ezinengi.
\q1 Abantwabalo bathunjiwe,
\q2 baba yizigqili zezitha.
\b
\q1 
\v 6 Kuphelile konke ukubenyezela
\q2 kweNdodakazi yaseZiyoni.
\q1 Amakhosana ayo asenjengezimpala
\q2 ezingatholi amadlelo;
\q1 zibalekile zilambile zingelamandla
\q2 zibalekela umzingeli.
\b
\q1 
\v 7 Ngezinsuku zokuhlupheka lokuntula,
\q2 iJerusalema iyayikhumbula inotho
\q2 eyayingeyayo ngensuku zayo.
\q1 Kuthe abantu bayo sebewela ezandleni zezitha,
\q2 akubanga khona ongayinceda.
\q1 Zayikhangela nje izitha zayo
\q2 zahleka ukuchitheka kwayo.
\b
\q1 
\v 8 IJerusalema yonile kakhulu,
\q2 ngakho isingcolile.
\q1 Bonke ababeyihlonipha sebeyidelela,
\q2 ngoba sebebonile ubuze bayo;
\q1 yona ngokwayo ibubula
\q2 ize ifulathele.
\b
\q1 
\v 9 Ukungcola kwayo kwabhixa izidwaba zayo;
\q2 kayinakanga ikusasa yayo.
\q1 Ukuwa kwayo kwesabeka,
\q2 kungekho oyiduduzayo.
\q1 “Oh \nd Thixo\nd*, ake ukhangele ukuhlupheka kwami,
\q2 ngoba isitha sesinqobile.”
\b
\q1 
\v 10 Isitha saphanga
\q2 yonke inotho yayo;
\q1 yabona izizwe ezingakholwayo
\q2 zingena endlini yayo engcwele,
\q1 bona labo owabanqabela
\q2 ukungena phakathi kwebandla lakho.
\b
\q1 
\v 11 Bonke abantu bayo bayagomela
\q2 behamba bedinga ukudla;
\q1 bathengisa inotho yabo eligugu ngokudla
\q2 ukuze bangafi.
\q1 “Oh \nd Thixo\nd*, ake ungihawukele
\q2 ngoba sengidelelwa.”
\b
\q1 
\v 12 “Kakusilutho kini yini lina lonke elidlula lapha?
\q2 Ake likhangele nje libone.
\q1 Kambe kukhona ukuhlupheka okulingana lokwami,
\q2 khona lokhu engakwehliselwayo, \nd nguThixo\nd*
\q2 ngosuku lokuvutha kolaka lwakhe?
\b
\q1 
\v 13 Wehlisa umlilo uvela phezulu,
\q2 wawehlisela phakathi kwamathambo ami.
\q1 Wangithiya ezinyaweni ngomambule,
\q2 wangibuyisela emuva.
\q1 Wangenza ngaba lesizungu,
\q2 ngaswela amandla ilanga lonke.
\b
\q1 
\v 14 Izono zami zisongwe zaba lijogwe;
\q2 ngezandla zakhe wazelukela ndawonye.
\q1 Zetheswe entanyeni yami,
\q2 uThixo wangiqeda amandla.
\q1 Usengifuqele kulabo
\q2 engingeke ngimelane labo.
\b
\q1 
\v 15 UThixo kabemukelanga
\q2 bonke abangabebutho lami;
\q1 usebize impi ukuthi ingihlasele,
\q2 ichoboze zonke izinsizwa zami.
\q1 Esihluzweni sakhe sewayini, \nd uThixo\nd* unyathelele phansi
\q2 iNdodakazi yakoJuda eGcweleyo.
\b
\q1 
\v 16 Yikho ngilila,
\q2 amehlo ami empompoza inyembezi.
\q1 Kakho oseduze ongangiduduza,
\q2 kakho ongavusa umphefumulo wami.
\q1 Abantwabami sebeswela
\q2 ngoba isitha sinqobile.”
\b
\q1 
\v 17 IZiyoni yelulile isandla sayo
\q2 kodwa kakho oyiduduzayo.
\q1 \nd UThixo\nd* usekumisile ngoJakhobe
\q2 ukuthi abakhelene laye babe yizitha zakhe;
\q1 iJerusalema isiphenduke
\q2 yaba yinto engcolileyo kubo.
\b
\q1 
\v 18 “\nd UThixo\nd* ulungile,
\q2 kodwa ngaphikisana lomlayo wakhe.
\q1 Lalelani bantu lonke;
\q2 khangelani ukuhawula kwami.
\q1 Izinsizwa lezintombi zami zonke
\q2 sezaya ekuthunjweni.
\b
\q1 
\v 19 Ngakhala kulabo engidlelana labo,
\q2 kodwa banginina.
\q1 Abaphristi bami labadala bami
\q2 babhubhela phakathi kwedolobho
\q1 besadinga ukudla,
\q2 ukuze baziphilise.
\b
\q1 
\v 20 Ake ubone, Oh \nd Thixo\nd*, ukuthi ngihlupheka njani!
\q2 Ngiyatsha ngaphakathi kwami,
\q1 ngidungekile enhliziyweni yami,
\q2 ngoba bengilihlongandlebe.
\q1 Ngaphandle, inkemba iyadabukisa;
\q2 ngaphakathi, yikufa kodwa.
\b
\q1 
\v 21 Abantu bakuzwile ukububula kwami,
\q2 kodwa kakho ongangiduduza.
\q1 Zonke izitha zami zikuzwile ukuhlupheka kwami;
\q2 ziyathokoza ngalokhu okwenzileyo.
\q1 Sengathi ungalufikisa lolusuku owalumisayo,
\q2 ukuze labo babe njengami.
\b
\q1 
\v 22 Abuvele kuwe bonke ububi babo;
\q2 yenza kubo konke
\q1 okwenzileyo kimi
\q2 ngenxa yezono zami zonke.
\q1 Kunengi ukububula kwami,
\q2 lenhliziyo yami iphela amandla.”
\b
\b
\c 2
\q1 
\v 1 UThixo wembese iNdodakazi yeZiyoni
\q2 ngeyezi lolaka lwakhe!
\q1 Ubutaklazele phansi ubunkanyankanya buka-Israyeli
\q2 busuka ezulwini busiya emhlabeni;
\q1 kasinakanga isenabelo sakhe
\q2 mhla wentukuthelo yakhe.
\b
\q1 
\v 2 UThixo kabanga lozwelo lapho eginya
\q2 yonke imizi kaJakhobe;
\q1 ngolaka lwakhe udilizele phansi
\q2 izinqaba zeNdodakazi kaJuda.
\q1 Usewuchithile umbuso wakhe,
\q2 lababusi bawo wababhuqa phansi, baba lehlazo.
\b
\q1 
\v 3 Ngolaka lwakhe olwesabekayo,
\q2 usegumule zonke impondo zika-Israyeli.
\q1 Usegodle isandla sakhe sokunene
\q2 lapho kuqhamuka isitha.
\q1 Utshise koJakhobe njengelangabi
\q2 elihangula konke okuseduze.
\b
\q1 
\v 4 Usethiye idandili lakhe njengesitha;
\q2 isandla sakhe sokunene sesiqaphile.
\q1 Njengesitha usebabulele bonke
\q2 ababebahle ebusweni;
\q1 usethele ulaka lwakhe olungumlilo
\q2 phezu kwethente leNdodakazi yeZiyoni.
\b
\q1 
\v 5 UThixo unjengesitha;
\q2 usemginyile u-Israyeli.
\q1 Useziginyile zonke izigodlo zakhe,
\q2 wabhidliza zonke izinqaba zakhe.
\q1 Usekwandisile ukukhala lokulilela
\q2 iNdodakazi kaJuda.
\b
\q1 
\v 6 Usetshaye wakhukhula umuzi wakhe njengensimu;
\q2 usebhidlize indawo yakhe yokuhlanganela.
\q1 \nd UThixo\nd* usenze iZiyoni yakhohlwa
\q2 imikhosi yayo emisiweyo lamaSabatha ayo;
\q1 olakeni lwakhe olwesabekayo,
\q2 ukhukhulele khatshana oyinkosi longumphristi.
\b
\q1 
\v 7 \nd UThixo\nd* uselikhalele i-alithari lakhe,
\q2 wafulathela indlu yakhe engcwele.
\q1 Usenikele imithangala yezigodlo zakhe
\q2 ezandleni zesitha;
\q1 seziklabalala endlini \nd kaThixo\nd*
\q2 sengathi lilanga lomkhosi omisiweyo.
\b
\q1 
\v 8 \nd UThixo\nd* wazimisela ukudilizela phansi
\q2 umthangala ohonqolozele iNdodakazi yeZiyoni.
\q1 Welula intambo yesilinganiso sakhe,
\q2 akaze agodla isandla sakhe esibhidlizayo.
\q1 Wenza izinsika lemithangala kwalila;
\q2 kanyekanye kwatshabalala.
\b
\q1 
\v 9 Amasango akhe asegqibelekile;
\q2 izinti zawo zephulwe zabhidlizwa.
\q1 Inkosi yayo lamakhosana ayo achithizelwe kwabezizwe,
\q2 umthetho kawusekho,
\q1 labaphrofethi bakhe kabasayamukeli
\q2 imibono evela \nd kuThixo\nd*.
\b
\q1 
\v 10 Abadala beNdodakazi yeZiyoni
\q2 bahlezi emhlabathini bathule zwi;
\q1 bazithele ngothuli emakhanda abo,
\q2 bazembathisa amasaka.
\q1 Izintombi zeJerusalema
\q2 zimbozele amakhanda azo phansi.
\b
\q1 
\v 11 Amehlo ami ayehluleka ngokukhala,
\q2 ngiyatsha ngaphakathi kwami,
\q1 inhliziyo yami idabukile,
\q2 ngoba abantu bakithi babhujisiwe,
\q1 njalo abantwana lensane ziyaqaleka
\q2 emigwaqweni yomuzi.
\b
\q1 
\v 12 Zithi kubonina,
\q2 “Singaphi isinkwa lewayini?”
\q1 zilokhu ziqaleka njengamadoda alimeleyo
\q2 emigwaqweni yomuzi,
\q1 ziphela umphefumulo
\q2 ezandleni zabonina.
\b
\q1 
\v 13 Kambe ngingathini kuwe na?
\q2 Ngingakulinganisa lani,
\q2 wena Ndodakazi yaseJerusalema?
\q1 Kambe ngingakufanisa lani
\q2 ukuze ngikududuze,
\q2 wena Ndodakazi eGcweleyo yaseZiyoni?
\q1 Inxeba lakho lizike njengolwandle.
\q2 Ngubani ongakwelapha na?
\b
\q1 
\v 14 Imibono yabaphrofethi bakho
\q2 yayikhohlisa ingasizi lutho;
\q1 kabasivezanga obala isono sakho
\q2 ukuze ungehlelwa yikuthunjwa.
\q1 Ukuvumisa abalenzela khona
\q2 kwakungamanga, kulikhohlisa.
\b
\q1 
\v 15 Bonke abedlula eceleni kwakho
\q2 batshaya izandla ngawe;
\q1 bahleka iNdodakazi yaseJerusalema
\q2 baze banikine amakhanda besithi,
\q1 “Kambe yiwo yini umuzi lo
\q2 owawuthiwa yibuhle obupheleleyo,
\q2 igugu lomhlaba wonke jikelele?”
\b
\q1 
\v 16 Zonke izitha zakho zikukhamisele imilomo;
\q2 ziyakuhleka zikugedlela amazinyo
\q1 zisithi, “Sesimnqobile.
\q2 Selize lafika ilanga esasililindele;
\q2 kade salilindela.”
\b
\q1 
\v 17 \nd UThixo\nd* usekwenzile ayekuhlosile;
\q2 useligcwalisile ilizwi lakhe,
\q2 alikhuluma kudala.
\q1 Ukuwisile engakuzweli usizi,
\q2 uvumele isitha santela phezu kwakho,
\q2 uluphakamisile uphondo lwezitha zakho.
\b
\q1 
\v 18 Inhliziyo zabantu
\q2 ziyakhala eNkosini.
\q1 Awu, mthangala weNdodakazi yaseZiyoni,
\q2 kazigeleze njengomfula inyembezi zakho,
\q2 ebusuku lemini;
\q1 ungaziphi ikhefu,
\q2 lamehlo akho ungawaphi ukuphumula.
\b
\q1 
\v 19 Phakama, nqongoloza ebusuku,
\q2 lapho kuqalisa imilindo yebusuku;
\q1 thulula inhliziyo yakho njengamanzi
\q2 phambi kukaThixo.
\q1 Phakamisela izandla zakho kuye,
\q2 uncengela impilo yabantwabakho,
\q1 abaqalekiswa yindlala
\q2 ekuqaliseni kwemigwaqo yonke.
\b
\q1 
\v 20 Ake ukhangele, \nd Thixo\nd*, ube lozwelo:
\q2 Ngubani osewake wamphatha kanje?
\q1 Abesifazane badle inzalo yabo yini,
\q2 abantwana ababondlileyo na?
\q1 Umphristi lomphrofethi
\q2 babulawe endlini engcwele \nd kaThixo\nd* na?
\b
\q1 
\v 21 Abatsha labadala babhazalele ndawonye
\q2 ebhuqwini lwemigwaqo;
\q1 izinsizwa zami lezintombi
\q2 zibulewe ngenkemba.
\q1 Ubabulele ngosuku lokuthukuthela kwakho;
\q2 awaze waba lesihawu lapho ubabulala.
\b
\q1 
\v 22 “Njengokunxusela idili,
\q2 wanginxusela izitha inxa zonke.
\q1 Ngosuku lolaka \nd lukaThixo\nd*,
\q2 kakho owaphunyukayo loba owasilayo;
\q1 bonke engangibanakekela lengabondlayo
\q2 babulewe yisitha sami.”
\b
\b
\c 3
\q1 
\v 1 Yimi umuntu olubonileyo usizi
\q2 ngenxa yoswazi lokuthukuthela \nd kukaThixo\nd*.
\q1 
\v 2 Ungixotshile, wangiphumputhekisa
\q2 emnyameni hatshi ekukhanyeni;
\q1 
\v 3 ngempela usengiphakamisele isandla sakhe,
\q2 waphindaphinda ilanga lonke.
\b
\q1 
\v 4 Usenze ijwabu lami laluphala,
\q2 wangephula amathambo.
\q1 
\v 5 Ungihanqile wangihonqolozela
\q2 ngosizi langobunzima.
\q1 
\v 6 Ungenze ngahlala emnyameni
\q2 njengalabo abafa kudala.
\b
\q1 
\v 7 Ungihonqolozele ngenqaba ukuze ngingaphunyuki;
\q2 ungibophe nko ngamaketane.
\q1 
\v 8 Kuthi lanxa ngimemeza loba ngidinga usizo,
\q2 awuvalele phandle umkhuleko wami.
\q1 
\v 9 Uvale indlela yami ngamatshe;
\q2 waphambukisa izindlela zami.
\b
\q1 
\v 10 Njengebhele licathamile,
\q2 njengesilwane sicatshile,
\q1 
\v 11 wangihudulela eceleni kwendlela, wangifohloza,
\q2 wangitshiya ngingelamsizi.
\q1 
\v 12 Wadonsa idandili lakhe,
\q2 ngaba yikudla kwemitshoko yakhe.
\b
\q1 
\v 13 Wangiciba enhliziyweni
\q2 ngemitshoko evela emxhakeni wakhe.
\q1 
\v 14 Ngaba yinhlekisa ebantwini bakithi bonke;
\q2 sengitshona ngiyingoma eyinhlekisa kubo.
\q1 
\v 15 Ungigqibe ngemithi ebabayo,
\q2 wanginathisa inyongo.
\b
\q1 
\v 16 Ungihlafunise ukhethe ngamazinyo;
\q2 wangigiqa ebhuqwini.
\q1 
\v 17 Ngincitshiwe ukuthula;
\q2 angisakwazi ingabe iyini impumelelo.
\q1 
\v 18 Ngakho ngithi, “Sebuphelile ubucwazicwazi bami,
\q2 lakho konke engangikulindele \nd kuThixo\nd*.”
\b
\q1 
\v 19 Ngikhumbula ukuhlupheka lokuntula kwami,
\q2 ubumunyu lenyongo.
\q1 
\v 20 Konke ngikukhumbula kamhlophe,
\q2 umoya wami wephukile.
\q1 
\v 21 Kodwa ngikhumbula lokhu
\q2 ngibe lethemba:
\b
\q1 
\v 22 Ngenxa yothando olukhulu \nd lukaThixo\nd* kasibhujiswanga,
\q2 ngoba isihawu sakhe kasipheli.
\q1 
\v 23 Siba sitsha ukusa kwamalanga;
\q2 kukhulu ukuthembeka kwakho.
\q1 
\v 24 Ngiyazitshela ngithi, “\nd UThixo\nd* uyisabelo sami;
\q2 ngakho ngizalindela yena.”
\b
\q1 
\v 25 \nd UThixo\nd* ulungile kulowo omethembayo,
\q2 kulowo omdingayo;
\q1 
\v 26 kuhle ukulinda ngokuthula,
\q2 ukulindela insindiso \nd kaThixo\nd*.
\q1 
\v 27 Kuhle ukuthi umuntu alithwale ijogwe
\q2 ngesikhathi esesemutsha.
\b
\q1 
\v 28 Kahlale yedwa ngokuthula,
\q2 ngoba \nd uThixo\nd* ulibeke phezu kwakhe.
\q1 
\v 29 Kembele ubuso bakhe ethulini,
\q2 mhlawumbe ithemba lizakuba khona.
\q1 
\v 30 Kaphe isihlathi sakhe kulowo ofuna ukumhlankala,
\q2 agcwale ihlazo.
\b
\q1 
\v 31 Ngoba uThixo kabalahli abantu
\q2 kuze kube nini lanini.
\q1 
\v 32 Loba engaletha ubuhlungu, uzatshengisa uzwelo,
\q2 lukhulu kakhulu uthando lwakhe olungapheliyo.
\q1 
\v 33 Ngoba kehliseli ukuhlupheka
\q2 losizi ebantwini ngokuthanda.
\b
\q1 
\v 34 Ukuhlifiza ngezinyawo
\q2 zonke izibotshwa elizweni,
\q1 
\v 35 ukuncitsha umuntu amalungelo akhe
\q2 phambi koPhezukonke,
\q1 
\v 36 ukungahluleli kuhle,
\q2 kambe uThixo uyabe engaziboni izinto ezinjalo na?
\b
\q1 
\v 37 Ngubani ongatsho ulutho lwenzakale
\q2 nxa lungavunyelwanga nguThixo na?
\q1 
\v 38 Akuveli emlonyeni woPhezukonke
\q2 ukuthi kuyehla inhlupheko lezinto ezinhle na?
\q1 
\v 39 Pho kungani umuntu ophilayo esola
\q2 nxa ejeziselwa izono zakhe na?
\b
\q1 
\v 40 Kasilingeni njalo sihlole izindlela zethu,
\q2 sibuyele \nd kuThixo\nd*.
\q1 
\v 41 Asiphakamiseleni inhliziyo lezandla zethu
\q2 kuNkulunkulu ezulwini sithi:
\q1 
\v 42 “Sonile sahlamuka,
\q2 njalo kawusithethelelanga.
\b
\q1 
\v 43 Uzigubuzele ngolaka waxhumana lathi;
\q2 ubhubhisile ungelazwelo.
\q1 
\v 44 Uzisibekele ngeyezi
\q2 ukuze kungafinyeleli mkhuleko kuwe.
\q1 
\v 45 Usenze saba ngamanyala lengcekeza
\q2 phakathi kwezizwe.
\b
\q1 
\v 46 Izitha zethu zonke zivule imilomo yazo
\q2 zezwakala zisihoza.
\q1 
\v 47 Sesihlukuluzwe yikuthuthumela lokukhilikithela,
\q2 ukudilika lokubhidlika.”
\q1 
\v 48 Imifula yezinyembezi iyajuluka emehlweni ami
\q2 ngoba abantu bakithi babhujisiwe.
\b
\q1 
\v 49 Amehlo ami azajuluka kokuphela,
\q2 engelakuphumula,
\q1 
\v 50 \nd UThixo\nd* aze akhangele phansi
\q2 esezulwini, angibone.
\q1 
\v 51 Engikubonayo kuthelela usizi emphefumulweni wami
\q2 ngenxa yabesifazane bonke bomuzi wakithi.
\b
\q1 
\v 52 Labo ababa yizitha zami kungelasizatho,
\q2 bangizingela njengenyoni.
\q1 
\v 53 Bazama ukuquma impilo yami emgodini
\q2 bangijikijela ngamatshe;
\q1 
\v 54 amanzi asibekela ikhanda lami,
\q2 ngabona ukuthi okwami sekuphelile.
\b
\q1 
\v 55 Ngalimemezela ibizo lakho, Oh \nd Thixo\nd*,
\q2 ngisekujuleni komgodi.
\q1 
\v 56 Wezwa ukuncenga kwami: “Ungavali indlebe zakho
\q2 nxa ngikhalela ukwenyulwa.”
\q1 
\v 57 Wasondela lapho ngikumemeza,
\q2 wathi kimi, “Ungesabi.”
\b
\q1 
\v 58 Oh Thixo, wasamukela isikhalazo sami;
\q2 wahlenga ukuphila kwami.
\q1 
\v 59 Ububonile \nd Thixo\nd*, ububi obenziwe kimi.
\q2 Ngisekela kulobubunzima!
\q1 
\v 60 Usubonile ukujula kokusonga kwabo,
\q2 lamacebo abo wonke ngami.
\b
\q1 
\v 61 Awu \nd Thixo\nd*, uzwile inhlamba zabo,
\q2 wonke amacebo abo ngami,
\q1 
\v 62 ukunyenyeza lokungunguna kwabo ngami
\q2 ukusa kwamalanga.
\q1 
\v 63 Ake ubabone! Bahlezi kumbe bajamile,
\q2 bayangihleka ngezingoma zabo.
\b
\q1 
\v 64 Awu \nd Thixo\nd*, akubaphindisele ngokubafaneleyo,
\q2 ngalokho okwenziwe yizandla zabo.
\q1 
\v 65 Basibekele ngelembu ezinhliziyweni zabo,
\q2 isiqalekiso sakho sehlele phezu kwabo!
\q1 
\v 66 Xhumana labo ngolaka, ubabhubhise
\q2 ngaphansi kwamazulu \nd kaThixo\nd*.
\b
\b
\c 4
\q1 
\v 1 Yeka igolide eselilahlekelwe yikukhazimula kwalo,
\q2 igolide elicolekileyo selijujukile!
\q1 Amatshe aligugu angcwele aselahliwe
\q2 ekuqaliseni kwemigwaqo yonke.
\b
\q1 
\v 2 Yeka izinsizwa zaseZiyoni ezincomekayo,
\q2 ezake zaba lesisindo njengegolide,
\q1 okwamanje sezingathi zimbiza zebumba,
\q2 umsebenzi wezandla zombumbi!
\b
\q1 
\v 3 Ngitsho lamakhanka asemunyisa
\q2 abantwabawo emabeleni awo,
\q1 kodwa abantu bami kabaselazwelo
\q2 njengezintshe enkangala.
\b
\q1 
\v 4 Ngenxa yokoma, ulimi losane
\q2 lunamathele elwangeni lomlomo;
\q1 abantwana bancenga becela isinkwa
\q2 kodwa kakho obaphayo.
\b
\q1 
\v 5 Labo ababesidla izibiliboco
\q2 sebeyiziceli emigwaqweni.
\q1 Labo abondliwa ebutifitifini
\q2 sebelala esilotheni.
\b
\q1 
\v 6 Isijeziso sabantu bakithi
\q2 sikhulu kuleseSodoma,
\q1 yona eyabhujiswa ngomzuzwana,
\q2 akwaze kwaba lasandla esazama ukunceda.
\b
\q1 
\v 7 Amakhosana abo ayekhazimula kulongqwaqwane,
\q2 emhlophe nke kulochago,
\q1 imizimba yabo ibomvana njengamatshe ohlobo lwerubhi,
\q2 ukubukeka kwabo kunjengelitshe elikhazimulayo.
\b
\q1 
\v 8 Kodwa manje sebemnyama kulomsizi;
\q2 kabasananzwa langubani emigwaqweni.
\q1 Isikhumba sabo sesinamathele emathanjeni abo;
\q2 sesome okogodo.
\b
\q1 
\v 9 Bangcono labo ababulawa ngenkemba,
\q2 kulalabo abafa ngendlala;
\q1 bazaca baphele, bekhukhuzwa yindlala
\q2 ngoba kungelakudla okuvela emasimini.
\b
\q1 
\v 10 Ngezandla zabo abesifazane abalesihelo,
\q2 bapheke abantwababo,
\q1 babenza ukudla kwabo
\q2 ngesikhathi abantu bakithi bebulawa.
\b
\q1 
\v 11 \nd UThixo\nd* ubhodlisile intukuthelo yakhe;
\q2 uluthulule ulaka lwakhe olwesabekayo.
\q1 Uwulumathisile umlilo eZiyoni,
\q2 watshisa izisekelo zayo.
\b
\q1 
\v 12 Amakhosi omhlaba ayengakholwa,
\q2 labantu basemhlabeni babengakholwa
\q1 ukuthi izitha labahlaseli bangangena
\q2 emasangweni eJerusalema.
\b
\q1 
\v 13 Kodwa kwenzakala ngenxa yezono zabaphrofethi bakhona,
\q2 lamanyala abaphristi bakhona,
\q1 abachitha igazi labalungileyo
\q2 ngaphakathi kwalo iJerusalema.
\b
\q1 
\v 14 Manje sebephumputha emigwaqweni
\q2 njengabantu abayiziphofu.
\q1 Sebengcoliswe ligazi
\q2 kakuselamuntu ongathinta izembatho zabo.
\b
\q1 
\v 15 Abantu bayabaxotsha bathi, “Sukani! Lingcolile!
\q2 Sukani! Sukani! Lingasithinti!”
\q1 Nxa bebaleka bentula,
\q2 abantu bezizwe bathi,
\q2 “Ngeke bahlale lapha njalo.”
\b
\q1 
\v 16 \nd UThixo\nd* ngokwakhe ubahlakazile;
\q2 kasabalondolozi.
\q1 Abaphristi kabasahlonitshwa,
\q2 labadala kabasananzwa.
\b
\q1 
\v 17 Phezu kwalokho, amehlo ethu afiphala
\q2 elindele ize engaboni sizo;
\q1 siseziqongweni zethu zokulinda,
\q2 salinda silindele isizwe esasingelancedo kithi.
\b
\q1 
\v 18 Abantu babesicwathela indawo zonke,
\q2 ngakho sasesisesaba ukuhamba emigwaqweni yethu.
\q1 Sasesiphelelwe, insuku zethu sezibaliwe,
\q2 ngoba isiphetho sethu sesifikile.
\b
\q1 
\v 19 Abasixotshayo babelejubane
\q2 kulengqungqulu emkhathini;
\q1 baxotshana lathi ezintabeni
\q2 njalo basicathamela enkangala.
\b
\q1 
\v 20 Ogcotshiweyo \nd kaThixo\nd*, oyikuphila kwethu uqobo,
\q2 wabanjwa emijibileni yabo.
\q1 Sakhumbula ukuthi ngaphansi kwesithunzi sakhe
\q2 sizahlala phakathi kwezizwe.
\b
\q1 
\v 21 Jabula uthokoze, wena Ndodakazi yase-Edomi,
\q2 wena ohlala elizweni lase-Uzi.
\q1 Kodwa lakuwe izafika inkezo le;
\q2 uzanatha udakwe, unqunulwe.
\b
\q1 
\v 22 Ndodakazi yaseZiyoni, isijeziso sakho sizaphela;
\q2 akayikwelula isikhathi sokuthunjwa kwakho.
\q1 Kodwa, maye kuwe Ndodakazi yase-Edomi, uzakujezisa ngesono sakho,
\q2 achaye obala ububi bakho.
\b
\b
\c 5
\q1 
\v 1 Oh \nd Thixo\nd*, khumbula okusehleleyo
\q2 khangela ubone ukuyangeka kwethu.
\q1 
\v 2 Ilifa lethu seliphiwe abezizweni,
\q2 imizi yethu yathathwa ngabemzini.
\q1 
\v 3 Sesizintandane ezingelaboyise,
\q2 omama sebenjengabafelokazi.
\q1 
\v 4 Amanzi okunatha siyawathenga;
\q2 inkuni zethu zikhutshelwa imali.
\q1 
\v 5 Labo abasixotshayo basihlezi ezithende;
\q2 sikhathele asilakuphumula.
\q1 
\v 6 Sazinikela kwabeGibhithe labe-Asiriya
\q2 ukuze sizuze isinkwa.
\q1 
\v 7 Okhokho benza isono kodwa kabasekho,
\q2 thina yithi esesijeziswa.
\q1 
\v 8 Sibuswa yizigqili,
\q2 kakho osikhululayo ezandleni zazo.
\q1 
\v 9 Isinkwa sisithola ngendlela eyingozi
\q2 ngenxa yenkemba ekhona enkangala.
\q1 
\v 10 Isikhumba sethu sitshisa njengeziko,
\q2 silomkhuhlane wendlala.
\q1 
\v 11 Abesifazane bayahlukuluzwa eZiyoni
\q2 kanye lezintombi ezigcweleyo emadolobheni akoJuda.
\q1 
\v 12 Amakhosi alengisiwe ngezandla zawo;
\q2 abadala abasahlonitshwa.
\q1 
\v 13 Izinsizwa ziyahoqiswa ematsheni okuchola;
\q2 abafana babhensiswa yimithwalo yenkuni.
\q1 
\v 14 Abadala sebesukile esangweni lomuzi;
\q2 izinsizwa sezithule ukuhlabelela.
\q1 
\v 15 Ukuthokoza akusekho ezinhliziyweni zethu;
\q2 ukugida kwethu sekuphenduke ukukhala.
\q1 
\v 16 Umqhele usuwile ekhanda lethu.
\q2 Maye thina, ngoba sonile!
\q1 
\v 17 Ngenxa yalokhu inhliziyo zethu zibuthakathaka;
\q2 ngenxa yalezizinto amehlo ethu ayafiphala,
\q1 
\v 18 ngoba intaba iZiyoni silugwadule,
\q2 sekucathama amakhanka kuyo.
\b
\q1 
\v 19 Wena, Oh \nd Thixo\nd*, busa nini lanini;
\q2 ubukhosi bakho buhlezi kuzozonke izizukulwane.
\q1 
\v 20 Kungani uhlezi usikhohlwa?
\q2 Usifulathelelani isikhathi eside kangaka na?
\q1 
\v 21 Sibuyisele kuwe, Oh \nd Thixo\nd*, ukuze siphenduke;
\q2 buyisa kabutsha insuku zethu njengezakudala,
\q1 
\v 22 ngaphandle kokuba nxa ususilahle kokuphela
\q2 wasizondela ngokungalinganisekiyo.
