\q1 \w One|strong="H6810"\w* \w of|strong="H3068"\w* \w those|strong="H6810"\w* \w nations|strong="H1471"\w* \w will|strong="H3068"\w* \w be|strong="H3068"\w* stronger \w than|strong="H3068"\w* \w the|strong="H5647"\w* \w other|strong="H8147"\w* \w nation|strong="H1471"\w*.  
\q1 Yes, \w the|strong="H5647"\w* \w younger|strong="H6810"\w* \w son|strong="H6810"\w*’s \w nation|strong="H1471"\w* \w will|strong="H3068"\w* \w be|strong="H3068"\w* stronger, \w and|strong="H3068"\w* \w his|strong="H3068"\w* \w nation|strong="H1471"\w* \w will|strong="H3068"\w* \w be|strong="H3068"\w* boss \w over|strong="H3068"\w* \w the|strong="H5647"\w* \w older|strong="H7227"\w* \w son|strong="H6810"\w*’s \w nation|strong="H1471"\w*.”\x * \xo 25:23 \xt Romans 9:12\x*   
\p
\v 24 Later \w on|strong="H3117"\w*, \w the|strong="H3205"\w* \w time|strong="H3117"\w* came \w for|strong="H3117"\w* Rebekah \w to|strong="H3117"\w* \w have|strong="H3117"\w* \w her|strong="H4390"\w* babies, \w and|strong="H3117"\w* 2 boys \w were|strong="H3117"\w* \w born|strong="H3205"\w*.  
\v 25 \w The|strong="H3605"\w* 1st baby \w that|strong="H3605"\w* \w was|strong="H8034"\w* \w born|strong="H3318"\w*, \w his|strong="H3605"\w* skin colour \w was|strong="H8034"\w* \w a|strong="H3068"\w* bit red. \w He|strong="H3605"\w* \w also|strong="H8034"\w* \w had|strong="H8181"\w* \w hair|strong="H8181"\w* \w all|strong="H3605"\w* \w over|strong="H3318"\w* \w his|strong="H3605"\w* body, \w like|strong="H3318"\w* \w an|strong="H7121"\w* animal skin. \w Isaac|strong="H7121"\w* \w and|strong="H3318"\w* Rebekah \w named|strong="H7121"\w* \w that|strong="H3605"\w* baby \em Esau\em*.  
\v 26 \w Straight|strong="H3318"\w* \w away|strong="H3318"\w*, \w the|strong="H3205"\w* 2nd \w baby|strong="H1121"\w* \w was|strong="H8034"\w* \w born|strong="H3205"\w*. \w And|strong="H1121"\w* \w when|strong="H3318"\w* \w that|strong="H3651"\w* \w baby|strong="H1121"\w* \w came|strong="H3318"\w* \w out|strong="H3318"\w*, \w he|strong="H3651"\w* \w was|strong="H8034"\w* holding \w the|strong="H3205"\w* \w back|strong="H3318"\w* \w of|strong="H1121"\w* \w Esau|strong="H6215"\w*’s foot. \w So|strong="H3651"\w* \w Isaac|strong="H3327"\w* \w and|strong="H1121"\w* Rebekah \w named|strong="H7121"\w* \w that|strong="H3651"\w* \w baby|strong="H1121"\w* \em Jacob\em*. \w That|strong="H3651"\w* \w name|strong="H8034"\w* \w means|strong="H3027"\w* \em he holds the back of the foot\em*.  
\p \w Isaac|strong="H3327"\w* \w was|strong="H8034"\w* 60 \w years|strong="H8141"\w* \w old|strong="H1121"\w* \w when|strong="H3318"\w* Rebekah \w had|strong="H3205"\w* \w those|strong="H3318"\w* 2 babies.   
\s1 Esau let Jacob be the next leader for their family  
\p
\v 27 Isaac \w and|strong="H5288"\w* Rebekah’s sons \w grew|strong="H1431"\w* \w up|strong="H1431"\w* \w and|strong="H5288"\w* \w became|strong="H1961"\w* \w men|strong="H5288"\w*. \w Their|strong="H1961"\w* son \w Esau|strong="H6215"\w* \w became|strong="H1961"\w* \w a|strong="H3068"\w* good \w hunter|strong="H6718"\w*. \w He|strong="H3290"\w* liked \w to|strong="H1961"\w* \w go|strong="H1961"\w* \w out|strong="H3045"\w* bush \w and|strong="H5288"\w* catch \w wild|strong="H7704"\w* \w animals|strong="H1961"\w* \w to|strong="H1961"\w* eat. \w But|strong="H1961"\w* \w their|strong="H1961"\w* son \w Jacob|strong="H3290"\w* \w was|strong="H1961"\w* \w a|strong="H3068"\w* quiet \w man|strong="H5288"\w*, \w and|strong="H5288"\w* \w he|strong="H3290"\w* liked \w to|strong="H1961"\w* \w stay|strong="H3427"\w* \w at|strong="H3427"\w* \w their|strong="H1961"\w* camp.   
\p
\v 28 \w Isaac|strong="H3327"\w* loved \w to|strong="H6310"\w* \w eat|strong="H6310"\w* \w the|strong="H3588"\w* wild animals \w that|strong="H3588"\w* \w Esau|strong="H6215"\w* caught. \w So|strong="H3588"\w* \w Isaac|strong="H3327"\w* loved \w Esau|strong="H6215"\w* \w more|strong="H3588"\w* \w than|strong="H3588"\w* \w Jacob|strong="H3290"\w*. \w But|strong="H3588"\w* \w Rebekah|strong="H7259"\w* loved \w Jacob|strong="H3290"\w* \w more|strong="H3588"\w* \w than|strong="H3588"\w* \w Esau|strong="H6215"\w*.   
\p
\v 29 \w One|strong="H4480"\w* day, \w while|strong="H1931"\w* \w Esau|strong="H6215"\w* \w was|strong="H1931"\w* \w out|strong="H4480"\w* bush, \w Jacob|strong="H3290"\w* \w cooked|strong="H2102"\w* \w some|strong="H4480"\w* soup \w with|strong="H4480"\w* red beans \w in|strong="H4480"\w* \w it|strong="H1931"\w*. \w While|strong="H1931"\w* \w Jacob|strong="H3290"\w* \w was|strong="H1931"\w* cooking \w that|strong="H1931"\w* soup, \w Esau|strong="H6215"\w* came back home, \w and|strong="H7704"\w* \w he|strong="H1931"\w* \w was|strong="H1931"\w* really \w tired|strong="H5889"\w* \w and|strong="H7704"\w* hungry.  
\v 30-34 So Esau said to Jacob, “Please let me eat some of that red soup right now. I’m really tired and hungry.”\x * \xo 25:30-34 \xt Hebrews 12:16\x*  
\p Jacob said to Esau, “First, I want you to do something for me. You are the oldest son in our family. That means you are the most important son, and you will be the next leader for our family. But I want to be the most important son, instead of you. I want to be the next leader for our family. So you have to promise that you will let me be the most important son now, instead of you. Then you can eat some soup.”  
\p Esau said, “Look, I’m so tired and hungry that I’m going to die. So it doesn’t matter if I stop being the next leader for our family. I just need some food right now.” \fig Esau really wanted some soup, so he promised that Jacob can be the next leader for their family|src="CO00674B.TIF" size="col" copy="David C Cook" ref="25:30-34" \fig*  
\p But Jacob said, “First, you have to make me that strong promise.” So Esau did what Jacob asked. He said to Jacob, “I promise that you can be the most important son in our family, instead of me, and you can be the next leader for our family.” Then Jacob gave Esau some of that soup with red beans in it, and some bread. Esau ate that red soup and bread, and then he got up and left.  
\p That’s the story about how Esau let Jacob be the most important son. So Esau wasn’t the most important son any more, but he didn’t care.  
\p Later on, people sometimes called Esau \w a|strong="H3068"\w* different name. They called him \em Edom\em*. That name means \em red\em*, like that red soup.   
\c 26  
\s1 God made the same promise to Isaac that he made to Abraham  
\p
\v 1 \w At|strong="H3117"\w* another \w time|strong="H3117"\w*, \w there|strong="H1961"\w* \w was|strong="H1961"\w* \w no|strong="H1961"\w* rain \w and|strong="H4428"\w* \w no|strong="H1961"\w* food plants growing \w in|strong="H4428"\w* \w the|strong="H3117"\w* country where \w Isaac|strong="H3327"\w* \w and|strong="H4428"\w* Rebekah \w lived|strong="H1961"\w*. \w It|strong="H1961"\w* \w was|strong="H1961"\w* \w like|strong="H1961"\w* \w the|strong="H3117"\w* \w time|strong="H3117"\w* \w when|strong="H1961"\w* \w there|strong="H1961"\w* \w was|strong="H1961"\w* \w no|strong="H1961"\w* rain \w a|strong="H3068"\w* \w long|strong="H3117"\w* \w time|strong="H3117"\w* \w before|strong="H7223"\w*, \w while|strong="H1961"\w* Abraham \w was|strong="H1961"\w* still alive.  
\p \w So|strong="H1961"\w* \w Isaac|strong="H3327"\w* \w and|strong="H4428"\w* \w his|strong="H1961"\w* family \w left|strong="H1961"\w* \w that|strong="H3117"\w* country, \w and|strong="H4428"\w* \w they|strong="H3117"\w* \w went|strong="H3212"\w* \w to|strong="H3212"\w* \w the|strong="H3117"\w* town called \w Gerar|strong="H1642"\w*, \w in|strong="H4428"\w* Philistia country. \w The|strong="H3117"\w* big boss \w of|strong="H4428"\w* \w the|strong="H3117"\w* Philistia people \w was|strong="H1961"\w* called Abimelek, \w and|strong="H4428"\w* \w he|strong="H3117"\w* \w lived|strong="H1961"\w* \w in|strong="H4428"\w* \w that|strong="H3117"\w* town.   
\p
\v 2 \w God|strong="H3068"\w* \w showed|strong="H7200"\w* \w himself|strong="H3068"\w* \w to|strong="H3381"\w* Isaac \w in|strong="H3068"\w* \w that|strong="H7200"\w* \w place|strong="H7931"\w*, \w and|strong="H3068"\w* \w God|strong="H3068"\w* said, “Don’t \w go|strong="H3381"\w* \w to|strong="H3381"\w* \w Egypt|strong="H4714"\w* country \w to|strong="H3381"\w* try \w to|strong="H3381"\w* get food. \w I|strong="H7200"\w*’m \w going|strong="H3381"\w* \w to|strong="H3381"\w* \w tell|strong="H7200"\w* \w you|strong="H7200"\w* \w where|strong="H7931"\w* \w you|strong="H7200"\w* \w have|strong="H3068"\w* \w to|strong="H3381"\w* \w live|strong="H7931"\w*.  
\v 3-4 I’m telling you to camp here, in this country. You don’t need to worry. I will be with you, to take care of you. I will keep on being good to you. Remember that strong promise that I made to your father Abraham. Now I’m making the same promise to you. I will give you \w a|strong="H3068"\w* really big family. You see, lots of kids and grand-kids will be born into your family later on, and they will become \w a|strong="H3068"\w* really big mob of people. There will be lots and lots of them, just like there are lots of stars in the sky. And I will give them all of this country, and I will use them to do good things for all the nations in the world.\x * \xo 26:3-4 \xt Genesis 12:2-3, 7; 15:5; 22:16-18; Acts 3:25\x*  
\v 5 \w You|strong="H8104"\w* know, \w your|strong="H8104"\w* father Abraham \w listened|strong="H8085"\w* \w to|strong="H8104"\w* \w me|strong="H6963"\w* \w and|strong="H6963"\w* \w did|strong="H8104"\w* \w what|strong="H6963"\w* \w I|strong="H8085"\w* \w told|strong="H8085"\w* \w him|strong="H6963"\w* \w to|strong="H8104"\w* \w do|strong="H8104"\w*. \w That|strong="H8085"\w*’s why \w I|strong="H8085"\w*’m making \w that|strong="H8085"\w* same promise \w to|strong="H8104"\w* \w you|strong="H8104"\w* \w that|strong="H8085"\w* \w I|strong="H8085"\w* \w made|strong="H8085"\w* \w to|strong="H8104"\w* \w him|strong="H6963"\w*.”   
\p
\v 6 \w So|strong="H3427"\w* \w Isaac|strong="H3327"\w* \w set|strong="H3427"\w* \w up|strong="H3427"\w* \w his|strong="H3327"\w* camp \w in|strong="H3427"\w* \w Gerar|strong="H1642"\w*, just \w like|strong="H3427"\w* God told him \w to|strong="H3427"\w*.   
\s1 Isaac tried to trick the men in Gerar  
\p
\v 7 \w The|strong="H5921"\w* \w men|strong="H2896"\w* \w in|strong="H5921"\w* Gerar \w saw|strong="H4758"\w* Isaac’s wife \w Rebekah|strong="H7259"\w*, \w and|strong="H2896"\w* \w they|strong="H3588"\w* \w asked|strong="H7592"\w* Isaac, “\w Who|strong="H1931"\w* \w is|strong="H1931"\w* \w that|strong="H3588"\w* \w woman|strong="H4758"\w*?”\x * \xo 26:7 \xt Genesis 12:13; 20:2\x*  
\p \w You|strong="H3588"\w* know, \w Rebekah|strong="H7259"\w* \w was|strong="H1931"\w* \w very|strong="H2896"\w* \w beautiful|strong="H2896"\w*. \w So|strong="H6435"\w* Isaac got worried \w about|strong="H5921"\w* \w those|strong="H5921"\w* \w men|strong="H2896"\w*. \w He|strong="H1931"\w* thought, “Maybe \w those|strong="H5921"\w* \w men|strong="H2896"\w* want \w to|strong="H5921"\w* \w marry|strong="H5921"\w* \w Rebekah|strong="H7259"\w*. \w If|strong="H3588"\w* \w I|strong="H3588"\w* tell \w them|strong="H5921"\w* \w that|strong="H3588"\w* \w she|strong="H1931"\w* \w is|strong="H1931"\w* \w my|strong="H5921"\w* wife, maybe \w they|strong="H3588"\w* \w will|strong="H1931"\w* \w kill|strong="H2026"\w* \w me|strong="H5921"\w* \w to|strong="H5921"\w* get \w her|strong="H5921"\w*.”  
\p \w So|strong="H6435"\w* Isaac lied \w and|strong="H2896"\w* said, “\w She|strong="H1931"\w* \w is|strong="H1931"\w* \w my|strong="H5921"\w* sister.”   
\p
\v 8 \w After|strong="H1961"\w* \w that|strong="H3588"\w*, \w Isaac|strong="H3327"\w* \w and|strong="H4428"\w* \w Rebekah|strong="H7259"\w* \w lived|strong="H1961"\w* \w in|strong="H4428"\w* Gerar \w for|strong="H3588"\w* \w a|strong="H3068"\w* \w long|strong="H3117"\w* \w time|strong="H3117"\w*. \w But|strong="H3588"\w* \w one|strong="H7200"\w* \w day|strong="H3117"\w* Abimelek, \w the|strong="H7200"\w* big boss \w of|strong="H4428"\w* \w the|strong="H7200"\w* Philistia \w people|strong="H7200"\w*, \w he|strong="H3588"\w* \w looked|strong="H7200"\w* \w out|strong="H8259"\w* \w of|strong="H4428"\w* \w his|strong="H7200"\w* \w window|strong="H2474"\w*, \w and|strong="H4428"\w* \w he|strong="H3588"\w* \w saw|strong="H7200"\w* \w Isaac|strong="H3327"\w* hugging \w Rebekah|strong="H7259"\w*. \w Then|strong="H1961"\w* Abimelek knew \w that|strong="H3588"\w* \w Rebekah|strong="H7259"\w* \w was|strong="H1961"\w* \w Isaac|strong="H3327"\w*’s wife.  
\v 9 \w So|strong="H6435"\w* Abimelek \w sent|strong="H3327"\w* somebody \w to|strong="H4191"\w* get \w Isaac|strong="H3327"\w*. \w Then|strong="H2009"\w* Abimelek \w said|strong="H7121"\w* \w to|strong="H4191"\w* \w Isaac|strong="H3327"\w*, “\w Now|strong="H2009"\w* \w I|strong="H3588"\w* know \w that|strong="H3588"\w* Rebekah \w is|strong="H1931"\w* \w your|strong="H5921"\w* wife. \w Why|strong="H5921"\w* \w did|strong="H3327"\w* \w you|strong="H3588"\w* say, ‘\w She|strong="H1931"\w* \w is|strong="H1931"\w* \w my|strong="H5921"\w* sister’?”  
\p \w Isaac|strong="H3327"\w* \w said|strong="H7121"\w*, “\w I|strong="H3588"\w* \w was|strong="H1931"\w* \w too|strong="H5921"\w* frightened \w to|strong="H4191"\w* say, ‘\w She|strong="H1931"\w* \w is|strong="H1931"\w* \w my|strong="H5921"\w* wife.’ \w I|strong="H3588"\w* thought \w that|strong="H3588"\w* \w the|strong="H5921"\w* \w men|strong="H7121"\w* \w in|strong="H5921"\w* Gerar \w will|strong="H1931"\w* \w kill|strong="H4191"\w* \w me|strong="H5921"\w* \w and|strong="H3327"\w* take Rebekah \w for|strong="H3588"\w* \w themselves|strong="H7121"\w*. \w So|strong="H6435"\w* \w I|strong="H3588"\w* \w said|strong="H7121"\w*, ‘\w She|strong="H1931"\w* \w is|strong="H1931"\w* \w my|strong="H5921"\w* sister.’”   
\p
\v 10 \w Then|strong="H6213"\w* Abimelek \w was|strong="H6213"\w* angry. \w He|strong="H6213"\w* said \w to|strong="H5921"\w* Isaac, “\w That|strong="H5971"\w* \w was|strong="H6213"\w* \w a|strong="H3068"\w* bad \w thing|strong="H4592"\w* \w that|strong="H5971"\w* \w you|strong="H5921"\w* \w did|strong="H6213"\w* \w to|strong="H5921"\w* \w us|strong="H5921"\w*. \w You|strong="H5921"\w* didn’t tell \w us|strong="H5921"\w* \w that|strong="H5971"\w* Rebekah \w is|strong="H4100"\w* \w your|strong="H5921"\w* wife. \w We|strong="H6213"\w* thought \w that|strong="H5971"\w* \w she|strong="H5921"\w* \w is|strong="H4100"\w* \w not|strong="H6213"\w* married. \w What|strong="H4100"\w* if \w one|strong="H6213"\w* \w of|strong="H5971"\w* \w my|strong="H5921"\w* \w men|strong="H5971"\w* \w slept|strong="H7901"\w* \w with|strong="H6213"\w* \w her|strong="H5921"\w*, \w like|strong="H6213"\w* \w men|strong="H5971"\w* \w sleep|strong="H7901"\w* \w with|strong="H6213"\w* \w their|strong="H5921"\w* wives? Think \w about|strong="H5921"\w* \w that|strong="H5971"\w*. \w Then|strong="H6213"\w* \w me|strong="H5921"\w* \w and|strong="H5971"\w* \w all|strong="H6213"\w* \w my|strong="H5921"\w* \w people|strong="H5971"\w*, \w we|strong="H3068"\w* \w would|strong="H5971"\w* \w be|strong="H5971"\w* guilty \w of|strong="H5971"\w* \w that|strong="H5971"\w* bad \w thing|strong="H4592"\w*.”   
\p
\v 11 After \w that|strong="H5971"\w*, Abimelek talked strongly \w to|strong="H4191"\w* \w all|strong="H3605"\w* \w the|strong="H3605"\w* \w people|strong="H5971"\w* \w in|strong="H4191"\w* Gerar. \w He|strong="H3605"\w* said, “If \w any|strong="H3605"\w* \w one|strong="H2088"\w* \w of|strong="H5971"\w* \w you|strong="H6680"\w* hurts Isaac \w or|strong="H4191"\w* Rebekah, \w I|strong="H6680"\w* \w will|strong="H5971"\w* \w kill|strong="H4191"\w* \w you|strong="H6680"\w*.”   
\s1 God was good to Isaac  
\p
\v 12 \w While|strong="H1931"\w* \w Isaac|strong="H3327"\w* lived \w in|strong="H8141"\w* Gerar, \w he|strong="H1931"\w* \w planted|strong="H2232"\w* seeds \w in|strong="H8141"\w* \w the|strong="H3068"\w* ground. \w And|strong="H3967"\w* \w God|strong="H3068"\w* \w was|strong="H3068"\w* really good \w to|strong="H3068"\w* \w Isaac|strong="H3327"\w*. \w That|strong="H1931"\w* \w same|strong="H1931"\w* \w year|strong="H8141"\w*, \w those|strong="H1931"\w* seeds grew into really good food plants, \w so|strong="H1931"\w* \w Isaac|strong="H3327"\w* \w had|strong="H3068"\w* lots \w and|strong="H3967"\w* lots \w of|strong="H3068"\w* food.  
\v 13 \w And|strong="H1980"\w* Isaac \w got|strong="H1980"\w* \w more|strong="H3966"\w* \w and|strong="H1980"\w* \w more|strong="H3966"\w* money \w and|strong="H1980"\w* \w good|strong="H3966"\w* \w things|strong="H1431"\w*, \w and|strong="H1980"\w* \w he|strong="H3588"\w* \w became|strong="H1431"\w* \w very|strong="H3966"\w* \w rich|strong="H1431"\w*.  
\v 14 \w He|strong="H1241"\w* \w had|strong="H1961"\w* lots \w of|strong="H6629"\w* \w sheep|strong="H6629"\w* \w and|strong="H6629"\w* \w cows|strong="H1241"\w*, \w and|strong="H6629"\w* lots \w of|strong="H6629"\w* people \w that|strong="H1961"\w* worked \w for|strong="H1241"\w* \w him|strong="H7065"\w*.  
\p \w The|strong="H1961"\w* Philistia people \w that|strong="H1961"\w* \w lived|strong="H1961"\w* \w in|strong="H7227"\w* Gerar, \w they|strong="H6430"\w* saw \w that|strong="H1961"\w* Isaac \w was|strong="H1961"\w* \w very|strong="H7065"\w* rich, \w and|strong="H6629"\w* \w they|strong="H6430"\w* got \w jealous|strong="H7065"\w* \w of|strong="H6629"\w* \w him|strong="H7065"\w*.  
\v 15 \w So|strong="H5650"\w* \w they|strong="H3117"\w* got \w dirt|strong="H6083"\w* \w and|strong="H3117"\w* \w filled|strong="H4390"\w* \w up|strong="H5640"\w* \w the|strong="H3605"\w* water-holes \w that|strong="H3605"\w* Isaac \w was|strong="H3117"\w* using. \w A|strong="H3068"\w* \w long|strong="H3117"\w* \w time|strong="H3117"\w* \w before|strong="H3117"\w* \w that|strong="H3605"\w*, Isaac’s father Abraham got \w his|strong="H3605"\w* workers \w to|strong="H3117"\w* \w dig|strong="H2658"\w* \w those|strong="H3605"\w* water-holes.   
\s1 Isaac dug some water-holes  
\p
