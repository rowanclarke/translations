\id MIC MIK - Tsishingini (tsw) 
\h Mika 
\toc3 Mik 
\toc1 Mika 
\toc2 Mika 
\mt2 Aatagada a Mika 
\mt1 Mika 
\is1 Ucuɗuwu wa aatagada a nda 
\ip Mika vuma va̱ A̱sula̱ yuwan ta̱ ulinga a mantsa ma̱ ta̱ na̱ vumava̱sula̱ Ishaya, a̱yi za vi iɗa ya Yahuda ɗa vu upasu u tsugono tsu uyagi. U tsura̱ urevu u na iɗa ya Yahuda ya̱a̱ riya̱ a̱tsuma̱ a̱tsuma̱lima̱ a na vuma va̱ A̱sula̱ Emos yuwain adanshi a aci o upasu wu ugana waru o una̱ wi ili i ta̱ shi. A̱sula̱ a ta ca ama oforo adama a na a 'yuwain a yuwan amayun. Ikaka ya Mika yu uta̱ ta̱ alanga eteshe o rocosu iroci i na eleme o lobono. 
\ip Pasu ro na ma̱ ka̱mbuwa̱ ugbozu a aci e le ele ɗa: Iroci ya asuvu nden n na ma̱ da̱na̱ o uvaɗi ma̱ɓula̱ za̱la̱ tsugono tsa̱ a̱ A̱sula̱ 4:1-4, 
\ip adanshi a aci o Mogono ma gbain ma na ma̱ ta̱wa̱ diga o ugundo wa Da̱wuda za na a̱ ta̱wa̱a̱ iɗa na asuvu nden 5:2-5, 
\ip a̱a̱ɗiva̱ a̱ ta̱ a yuwan ta̱ adanshi a̱bunda̱ a aci e ili i na a ama a̱ A̱sula̱ a Isra'ila a yuwan adanshi aaci: A̱a̱ɗiva̱'a̱ u damma ta̱, <<Ili i na u cigai a̱ yi ɗa vu yuwan ili i na i ri mejege, vu roco wi icigi a̱ tyo uba̱ta̱ wa̱ A̱sula̱ oɓolo na ama, vu ka̱ɗa̱to wa a aci a̱ wu a̱tsuma̱ a mmalu ma̱ wu na̱ A̱sula̱ a̱ wu.>> 6:8 
\is1 Ili i na i ri pe: 
\io1 Uge'etosu a aci a Isra'ila na̱ Yahuda 1:1-3:12 
\io1 Ulapulu na̱ nden ma Asuvu 4:1-5:15 
\io1 Ikaka i morono ma atsuvu na̱ mazuwa mo okolo 6:1-7:20. 
\c 1  
\p  
\v 1 A̱sulazuva a ca ta̱ Mika vuma va Moreshete adanshi e ikaka i nda a̱tsuma̱ alavu alavu adama a Samariya na̱ Urishelima a mantsa ma̱ tsugono ma Yotam na̱ Ahaz na̱ Hezekiya ngono ma Yahuda. 
\s1 A̱tsumola̱ngu adama a Samariya na̱ Urishelima 
\q1  
\v 2 Uwwai, a̱ɗu ama o uvaɗi suru, 
\q2 polo atsuvu vu uwwa, a̱vu uvaɗi ni ili i na i ri pe a̱tsuma̱ wu suru. 
\q1 Lyawa A̱sulazuva Zagbain A̱sula̱ 
\q2 diga A̱a̱'isamapaɗa a akiza a̱yi wo o'wo, 
\q2 iroci a aci a̱ ɗu. 
\p  
\v 3 I reve, A̱sulazuva a̱ ta̱ ta̱wa̱ diga o uba̱ta̱ a̱ nden ma akiza a̱ yi. 
\q2 U ta̱ cipa̱ reve u dadasa ba̱ta̱ va̱ a̱ga̱nda̱ o uvaɗi. 
\q1  
\v 4 Nsasan n ta̱ jeruwe za̱la̱ va apata ana a̱ yi 
\q2 waru ka̱ri ta ɓatsa 
\q1 cine abaji e ishiki a tsu jejeruwe o una̱ wa akina, 
\q2 reve u ka̱ra̱ e ilaɗi a̱ cipa̱ cine o tsu oco mini diga a agaɗi. 
\b  
\q1  
\v 5 Ili i nda suru adama o unusu wa Yakubu u ɗa 
\q2 na̱ nusu va Isra'ila. 
\q1 Nyen ɗa unusu wu ugundo wa Yakubu? 
\q2 Ashe mayan ma̱ a̱ga̱nda̱ ma̱ a̱ma̱li a Samariya ɗa shi? 
\q1 A te ɗa gba ba̱ta̱ va̱ a̱ga̱nda̱ va Yahuda ri? 
\q2 Ashe a̱tsuma̱ a Urishelima ɗa a̱ ri shi? 
\q1  
\v 6 <<Adama o ndolo n ta̱ ka̱mba̱to Samariya oɓolo e edemu a̱ rulu, 
\q2 wo'o tsu uba̱ta̱ u na a̱ tsu cu'wa̱n a̱ɗuma̱ a̱ ina̱bi. 
\q1 Waru n ta gandalato atali a̱ yi a̱ tyo o uka̱ri 
\q2 reve waru n za̱ɓa̱luwa̱ atali e ikyun a̱ yi. 
\q1  
\v 7 N to ɓoɓoso a̱ma̱li a̱ yi 
\q2 a na a̱ zuɗa̱i, 
\q2 a̱ ta̱ kula̱to utsuru wa̱ yi na akina, 
\q2 n ta̱ kototo a̱ma̱li a̱ yi suru, 
\q1 adama a na a̱ tsura̱ le ta̱ diga o ure u tsushakala, 
\q2 waru a̱ ta̱ a̱ ka̱mba̱ o ure u tsu tsushakala'a.>> 
\s1 Mesun ma Mika adama a Isra'ila na̱ Yahuda 
\q1  
\v 8 A̱vu Mika damma, <<Adama e ili i nda, 
\q2 n ta yuwan a̱tsumola̱ngu reve n shon, 
\q2 n foɗo itana n wala ataɓu. 
\q1 N ta̱ shon tsa̱ musa̱n mu una, 
\q2 waru n yuwan a̱tsumola̱ngu tsa azamina, 
\q1  
\v 9 Adama a na antsu a Samariya 
\q2 aza a na e ina ɗa shi, 
\q2 hali fo u ju'wa̱n Yahuda, 
\q1 waru u rawa ta̱ a̱ na̱ntsu va ama a̱ va̱, 
\q2 hali a uwa Urishelima.>> 
\b  
\q1  
\v 10 She a yuwan adanshi a̱ yi a̱tsuma̱ a Gat wan, 
\q2 ko ke'en she a̱ shon wan. 
\q1 Amma a̱ɗu a̱za̱ Bet Leyafara 
\q2 i gandala a̱ ma̱buta̱ goon. 
\q1  
\v 11 A̱ɗu ama a Shafiri, 
\q2 i yuwan n manlu ataɓu na̱ a̱tsuma̱ o wono. 
\q1 Ama a Za'anan gba 
\q2 she yu uta̱ wan. 
\q1 Bet Eze na ama a̱ yi a̱ te e mesun 
\q2 ya̱ tsura̱ ikambi e ekere a̱ yi shi. 
\q1  
\v 12 Adama a na ama a Maroto 
\q2 a ta pura isa'ani na̱ meje'en. 
\q1 Agba iwuya diga uba̱ta̱ wa̱ A̱sulazuva 
\q2 a̱ cipa̱ ta̱ o una̱ntsu wa Urishelima. 
\q1  
\v 13 A̱ɗu ama a Lakish, 
\q2 i foɓo ikeke yi ido i ɗu, 
\q1 adama a na a̱ a̱tsura̱ ta̱ unusu 
\q2 wa Isra'ila a̱tsuma̱ a̱ ɗu. 
\q1 Hali na u zuwai Sihiyona 
\q2 mayan mo unusu gayin. 
\q1  
\v 14 Adama o ndolo, 
\q2 i ca ama Moreshete Gat ne'en vu ukosu. 
\q1 Waru lyuci va Akizibi ta̱ pura̱ ugbozu 
\q2 wu ngono ma Isra'ila. 
\b  
\q1  
\v 15 Reve A̱sulazuva a damma, 
\q2 n ta̱ ta̱wisa̱ na̱ za na a lyuwa ɗu nu uvon, 
\q2 aza a na a̱ ri na̱ nden a̱tsuma̱ a Maresha. 
\q1 Tsugbain tsa Isra'ila 
\q2 tsa̱ ta̱ ka̱mba̱ e ekere a Adulam. 
\q1  
\v 16 A̱vu Yahuda, vu puna aciya̱wu ogbondo adama a̱tsuma̱la̱ngu 
\q2 a̱ muwun ma̱ wu n na vu cigai. 
\q2 Vu puna aciya̱wu ogbondo vo o'wo tsa̱ a̱a̱kuru, 
\q2 adama a na muwun ma̱ wu n ta̱ 'ya̱wa̱ tsugbashi e iɗa i ro. 
\c 2  
\s1 Ukosu wa̱ a̱za̱ o ule'e 
\q1  
\v 1 A̱tsuma̱lima̱ a ta cina 
\q2 aza a na o foɓuso iwuya, 
\q2 e le na o foɓuso iwuya na ayin! 
\q1 Nu usana u tawa, 
\q2 a̱ tsu uta̱ ta̱ a yuwan iwuya'a, 
\q1 adama a na ucira u mayan me iwuya'a 
\q2 u ta̱ e ekere e le. 
\q1  
\v 2 A tsu yuwan ta̱ tsushu'un 
\q2 vu ɗuma̱ reve a usa le, 
\q1 na̱ tsushu'un vu 'wa 
\q2 reve fo a usa le. 
\q1 A tsu tsugba ta̱ vuma, 
\q2 reve a usa u'wa wa̱ yi 
\q2 ni ili ya agadu a̱ yi. 
\b  
\q1  
\v 3 Adama o ndolo ɗa A̱sulazuva a dammai, 
\q1 <<Gogo n to foɓuso addama a aci a̱ cu'un va ama a nda, 
\q2 za na aa gura uta̱a̱ aciyele a̱tsuma̱ a̱ yi shi. 
\q1 Waru aa gura yuwan mmalu na afalu shi, 
\q2 adama a na mantsa mo uyo'o u ɗa shi. 
\q1  
\v 4 O urana u ndolo a ta cana ishipa 
\q2 ya avandaru a aci a̱ ɗu, 
\q1 reve a yuwan mesun ma̱ a̱tsumola̱ngu lon adansa, 
\q2 <Za tsu koto ta̱! 
\q1 U kita'wa ta̱ akunda a ama a̱ va̱, 
\q2 u tawa le ta̱ e ekere a̱ va̱. 
\q1 A̱sulazuva e ne'eshen ta̱ ɗuma̱ tsu, 
\q2 e ekere a ama a na a lyuwa n tsu nu uvon.> >> 
\b  
\q1  
\v 5 Adama o ndolo ya̱ tsura̱ za, 
\q2 diga a̱tsuma̱ oɓolo a ama A̱sulazuva 
\q2 na eneshe iɗa'a 
\q2 o ure u mazuwa ma agita shi. 
\b  
\q1  
\v 6 Reve ama̱sula̱ e le a damma, 
\q2 <<She vu yuwan adanshi e ikaka i nda wan.>> 
\q1 <<She vu yuwan adanshi e ikaka i nda wan, 
\q2 Ili i wono yi lo 
\q2 na ya cina tsu shi!>> 
\q1  
\v 7 <<U ta̱ ulobono 
\q2 ama a Yakubu a damma, 
\q1 <Ruhu va̱ A̱sulazuva 
\q2 lamba ta̱ ankuri? 
\q1 Linga va̱ yi ɗa nda'a?> >> 
\b  
\q1 <<Ashe adanshi a̱ va̱ a tsu yuwan 
\q2 urana e ekere aza na o toni niyi mejege shi?>> 
\b  
\p  
\v 8 Reve A̱sulazuva a̱ usu le u damma, 
\q1 <<Babu usa̱n ama a̱ va̱ a̱ tsu 'yon ta̱ tsa n'yuwatan, 
\q2 tsa aza a na a̱ ri a̱ ma̱ka̱mba̱a̱ diga uba̱ta̱ wu uvon, 
\q2 o foɗoso a̱tugu aza na ili i burai shi. 
\q1  
\v 9 I loso ta̱ a̱ma̱ci a ama a̱ va̱ 
\q2 diga a 'wa sa'ani le. 
\q1 Reve i tara tsugbain tsa̱ va̱, 
\q2 diga a̱ muwun n le suru hali hali. 
\q1  
\v 10 Gogo a̱ɗu a̱za̱ a̱ɓula̱, 
\q2 'yoyin, i ka̱ra̱, 
\q1 adama a na uba̱ta̱ u nda 
\q2 uba̱ta̱ u wivuwun u ɗa shi. 
\q1 Adama a na iɗa'a 
\q2 wo o'wo ta̱ idaba. 
\b  
\q1  
\v 11 Na̱ vuma 'yon reve u reme epen a dansa, 
\q2 <N ta yuwan ɗu alajiya 
\q2 adama a masayan ma̱ ina̱bi 
\q2 ni ili i na i tsu tsura̱to.> 
\q1 To, a̱ yi ɗa wo o'wo 
\q2 za va alajiya a ama a nda'a.>> 
\q1  
\v 12 <<Adanshi o ro o lo shi, n to ɓoloto ɗu 
\q2 a̱za̱ o ugundo wa Yakubu, 
\q2 waru n to ɓoloto akapi ama a Isra'ila a na a buwai. 
\q1 N to ɓolo ɗu tso oɓolo e ikyon uba̱ta̱ wa aguta, 
\q1 tso oɓolo e ikyon uba̱ta̱ wa alyuna. 
\q2 I to o'wo a̱ba̱jini oɓolo a ama a na a uwwa elemu e le.>> 
\b  
\q1  
\v 13 A̱yi za na a̱ ba̱ma̱ ukari, 
\q2 u to rono le a aaɗanga 
\q2 reve a̱ uta̱la̱i nu uba̱ta̱'a̱. 
\q1 U to o'wo le una̱ntsu u mo uta̱. 
\q2 Mogono me le ma̱ ta̱ ka̱ra̱ elime e le. 
\q2 A̱sulazuva na aciya̱yi a ɗa wo rono le a aaɗanga. 
\c 3  
\s1 Tsuɓari a̱ tyo uba̱ta̱ wa azagbain na ama̱sula̱ 
\q1  
\v 1 Poloi atsuvu yu uwwa, 
\q2 a̱ɗu azagbain o ugundo a Yakubu, 
\q2 a̱ɗu a̱za̱ o tsugono tsu u'wa wa Isra'ila! 
\q1 Ashe wuntsaa i reve uge'etosu wa amayun shi? 
\q2  
\v 2 A̱ɗu na i 'yuwain ili i na i ri ulobonu, 
\q2 reve i ciga iwuya. 
\q2 a̱ɗu na ya munusa ukwan u lipu wa ama a̱ va̱, 
\q1 a̱ɗu na ya tawusa inama i lipu i le 
\q2 diga etele e le. 
\q1  
\v 3 A̱ɗu na ya tamusa inama ya ama a̱ va̱, 
\q2 reve i ka̱ra̱ a munusa kwan lipu le, 
\q1 a kukuɗusa etele e le, 
\q2 ni paɗasai inama i lipu i le 
\q2 vadama a̱ ta̱ tsun le o upondo na a su'wan. 
\q1  
\v 4 A̱vu nda gogo i ciga i showen A̱sulazuva, 
\q2 i reve gba wa̱ usu ɗu shi. 
\q1 A mantsa'a, u to sokowo ɗu urewesu wa̱ a̱ yi 
\q2 adama a na i yuwain iwuya. 
\b  
\q1  
\v 5 Apa ili i na A̱sulazuva a dammai 
\q2 e ekere ama̱sula̱ a na a zuwai ama a̱ va̱ a̱ puwa̱yin, 
\q1 aza a na a̱ 'ya̱sa̱sa̱n ɗyo a dansa, 
\q2 <<<Nden ma asuvu> a mantsa ma na a ca nle ilyalya. 
\q2 Agba a dansa, <uvon> e ekere aza a na ca nle ili shi. 
\q1  
\v 6 Adama o ndolo, a̱ɗu ama̱sula̱, 
\q2 ili suru i to o'wo ɗu ayin, alavu alavu a̱ da̱na̱ lo shi, 
\q2 Irumbu i ɗa yo o'wo ɗu, i buwa a yuwan walu shi. 
\q1 Urana u ta̱ riya̱ ɗu a aci a̱ ɗu ama̱sula̱ a nda, 
\q2 ulivu u to o'wo ɗu irumbu picim. 
\q1  
\v 7 A̱ɗu a̱za̱ a̱ yindi, i ta uwwa wono, 
\q2 aza a walu a̱ ta̱ ra̱pula̱. 
\q1 Suru n ɗu i ta̱ ɓa̱ru na̱ ɗu, 
\q2 adama a na A̱sula̱ a uwwa ɗu shi. >> 
\q1  
\v 8 A̱mu gba shi, n ta̱ tapu 
\q2 nu ucira nu Ruhu va A̱sulazuva. 
\q1 N ta̱ tapu nu ugbamu wa asuvu 
\q2 u na ma yuwan uge'etosu wa amayun. 
\q1 Babu wovon n ta damma Yakubu 
\q2 ulinga wu ulambu wa̱ a̱ɓula̱ a̱ yi alanga eteshe. 
\q2 Isra'ila waru n damma yi unusu wa̱ yi. 
\q1  
\v 9 Uwwai ili i nda, 
\q2 azagbain o ugundo wa Yakubu, 
\q2 na̱ a̱za̱ o tsugono tsu u'wa wa Isra'ila, 
\q1 a̱ɗu na ya 'yuwusan uge'etosu wa amayun 
\q2 reve i vadala amayun suru. 
\q1  
\v 10 A̱ɗu na i suwai Sihiyona na̱ mpasa, 
\q2 Urishelima gba nu unusu. 
\q1  
\v 11 Azagbain o u'wa wa Yakubu 
\q2 a̱ ta̱ ushishi utowusu wu una̱ 
\q2 na paɗa ugana o uge'etosu. 
\q1 Nan ganu a ta yuwusan uritosu 
\q2 adama a̱ tsura̱ ili i na ya uwa le, 
\q1 waru ama̱sula̱ a̱ yi a ta yuwusan adanshi 
\q2 adama a̱ tsura̱ ikebe. 
\q1 Agba suru na̱ ne a ta majiyan 
\q2 A̱sulazuva a̱ ta̱ ɓolo na̱ e le a dansa, 
\q2 <<Ee, A̱sulazuva a̱ te e memere ma̱ tsu, 
\q1 upepu ucingi wu lo 
\q2 na wa faba tsu shi. 
\q1  
\v 12 Adama a̱ ɗu, 
\q2 aa ta cimba Sihiyona tsu uɗuma̱, 
\q1 Urishelima gba to o'wo oɓolo o okongo. 
\q2 Aagaɗi a na A̱a̱'isamapaɗa a̱ ri 
\q2 u to o'wo olopu.>>\x - \xo 3:12 \xt Irm 26:18.\x* 
\c 4  
\s1 Tsugono tsa̱ A̱sulazuva za va asuvu nden 
\r (Isha 2:2-4) 
\q1  
\v 1 A mantsa mo ukosu, 
\q2 masasan ma na u'wa wa̱ A̱sulazuva a̱ ri 
\q1 u to o'wo masasan ma na ma la'ai a̱ɓula̱ suru suru. 
\q2 A ta cuwa yi ulawu na̱ nsasan na agaɗi suru. 
\q2 Nɗa n ta̱ da̱na̱ a sumusa a̱ 'ya̱wusa̱ ɗe. 
\q1  
\v 2 Nɗa na̱ a̱bunda̱ a̱ ta̱ ta̱wa̱ a damma, 
\q2 <<Ta̱wa̱ yi, tsu kumbai masasan ma A̱sulazuva, 
\q1 a̱ 'ya̱wa̱ o u'wa wa̱ A̱sula̱ a Yakubu, 
\q2 adama u roco tsu re va̱ yi, 
\q1 tsura̱ a̱tsu fo tsu yuwan mmalu o ure wa̱ yi. >> 
\q1 Adama a na uritosu wa̱ A̱sulazuva 
\q2 u ta̱ o uta̱ diga Sihiyona, 
\q2 waru adanshi A̱sula̱ a̱ ta̱ ta̱wa̱ diga Urishelima. 
\q1  
\v 3 A̱sulazuva a̱ ta̱ ge'eto ama o uvaɗi a̱bunda̱. 
\q2 Waru u ta̱ ge'eto nɗa m gbain gbain. 
\q1 A ta ruma mutsun mu pe'eni n le 
\q2 a̱ ka̱mba̱to le a̱ba̱ri e iluma, 
\q1 ibata i le waru a ta ruma le 
\q2 a̱ ka̱mba̱to le mutsun n wukoɗu wu ɗanga. 
\q1 Nɗa n buwa o uta̱ a̱ 'ya̱wa̱ uvon shi, 
\q2 waru a̱ da̱shi rito uvon shi. 
\q1  
\v 4 Vuma suru ta̱ da̱nu e ikyun ya ataci a ina̱bi a̱ yi, 
\q2 na̱ e ikyun yu uɗanga vu biri va̱ yi na asuvu nden.\x - \xo 4:4 \xt Zak 3:10.\x* 
\q1 Za lo na da'waton yi shi, 
\q2 adama a na A̱sulazuva oɓolo a̱ a̱soja a zuva a ɗa a dammai ne. 
\q1  
\v 5 Ko na wo o'woi nɗa suru n ta̱ kurusu musula̱ n le, 
\q2 amma a̱tsu tsu ta̱ toni A̱sulazuva A̱sula̱ a̱ tsu. 
\s1 Ama a Isra'ila a̱ ta̱ ka̱mba̱ diga e iɗa i tsugbashi 
\p  
\v 6 Reve A̱sulazuva a damma, 
\q2 <<O urana u ndolo, n to oɓoloto aza a na a̱ pura̱i a̱ tyo tsugbashi 
\q2 waru n to ɓoloto aza a na o losoi, 
\q2 na aza a na n cayi a̱tsuma̱lima̱. 
\q1  
\v 7 N ta̱ ka̱mba̱to aza a na a̱ pura̱i 
\q2 a̱ tyo tsugbashi na la'ai ama a̱ va̱, 
\q2 aza a na o losoi o'wo iɗa yu ucira. 
\q1 A̱mu A̱sulazuva n ta yuwan tsugono a aci e le 
\q2 a masasan ma Sihiyona 
\q2 diga gogo hali hali. 
\q1  
\v 8 A̱vu usa wu uga'an wu uba̱ta̱ e ipiri yi ikyon, 
\q2 uba̱ta̱ wu upa'anta wu ucira wa Sihiyona 
\q1 a aci a̱ wu a ɗa tsugono tsu ufaru tsa̱ a̱ ka̱mba̱, 
\q2 tsugono'o u ta̱ ka̱mba̱ Urishelima.>> 
\q1  
\v 9 Gogo nye i zuwai vu ri a yisali nu ucira? 
\q2 Mogono me pe a̱tsuma̱ a̱ wu gogo shi? 
\q1 Za na a casu wu a̱sa̱la̱ a̱ kuwa̱ ta̱ ɗa? 
\q2 A̱yi ɗa ili i na i zuwai a̱tsuma̱lima̱ a̱ riya̱ nuwu 
\q2 tsa ka na ri a uwwusa mɓa̱la̱ n limatan? 
\q1  
\v 10 Vu yuwan ma̱nga̱ vu sala a̱vu Sihiyona, 
\q2 tsa ka na ri a̱ a̱tsuma̱lima̱ a̱ mɓa̱la̱ n limatan. 
\q1 Adama a na gogo vu ta̱ o uta̱ pe a̱tsuma̱ a̱ lyuci'i 
\q2 reve vu da̱nu oogodo aagalaci o ugyuru. 
\q1 Vu ta̱ ka̱ra̱ a̱ tyo Babila. 
\q2 Diga ɗe ɗa A̱sulazuva a wawa wu 
\q2 diga e ekere a n'yuwatan ma̱ wu. 
\q1  
\v 11 Gogo, nɗa na̱ a̱bunda̱ o ɓoloto ta̱ 
\q2 e reme tsushu'un na̱ a̱ vu 
\q2 a dansa, <<Lyawa a̱ lungusa̱ yi, 
\q2 lyawa tsu zuwa esu a aci a Sihiyona.>> 
\q1  
\v 12 Agba a̱ reve majiyan ma A̱sulazuva shi, 
\q2 waru e reve ifoɓi ya̱ yi shi, 
\q1 na wo ɓoloto le 
\q2 tsa aakatalu e ishina shi, 
\q2 tsi ishina i na o ɓolotoi 
\q2 o osoroto a na a faba. 
\q1  
\v 13 Reve A̱sulazuva a damma, 
\q2 <<A̱vu Sihiyona aaɗanga o usuɗa 
\q2 'yon vu yuwan usuɗa. 
\q1 Adama a na n ta ca wu ucira tsa̱ rumu 
\q2 no ookotsu e irumushili. 
\q1 Vu ta̱ lungusa̱ nɗa na̱ a̱bunda̱, 
\q2 a̱vu vu ca utsuru u le 
\q2 uba̱ta̱ wa̱ A̱sulazuva o uvaɗi suru.>> 
\c 5  
\q1  
\v 1 Gogo, vu ɓoloto a̱ a̱soja a̱ wu 
\q2 adama a na a̱ ka̱nda̱ruwa̱ tsu ta̱ nu uvon. 
\q1 Waru a ta faba mogono ma Isra'ila 
\q2 na aaɗanga o ugbaguzu. 
\s1 A̱sula̱ a yuwan ta̱ nzuwulai mu za tsugono diga Batalami 
\q1  
\v 2 A̱vu A̱sulazuva a damma, 
\q1 <<A̱vu lyuci va Batalami va Efarata, 
\q2 a̱tsuma̱ o ugundo wa Yahuda wa'a ɗa vu ri, 
\q1 agba a̱tsuma̱ a̱ wu n ta̱ o uta̱a̱ vuma 
\q2 na a yuwan tsugono tsa Isra'ila, 
\q1 za na ri nu ugundo ɗe ɗe, 
\q2 za na ri ɗe ɗe a̱ ta̱wa̱.>> 
\q1  
\v 3 Adama o ndolo A̱sulazuva 
\q2 a̱ ta̱ uta̱ aɗa a ama a̱ yi, 
\q2 hali she na a matsan za tsugono'o, 
\q1 waru she na ama a 'wa va̱ yi 
\q2 a̱ ka̱mba̱ a̱tsuma̱ a Isra'ila. 
\q1  
\v 4 Tsa za va aguɓa, 
\q2 u ta̱ e idana ama a̱ yi, 
\q1 nu ucira u na wu uta̱i 
\q2 diga uba̱ta̱ wa̱ A̱sulazuva, 
\q2 a̱tsuma̱ a tsugbain tsa̱ aala A̱sulazuva A̱sula̱ a̱ yi. 
\q1 Ama a̱ yi a̱ ta̱ da̱nu gbaga, 
\q2 adama a na a̱ ta̱ reve nu ucira wa aala a̱ yi 
\q2 a̱tsuma̱ o uvaɗi suru. 
\p  
\v 5 Waru u to o'wo asuvu nden n tsu, 
\q2 a mantsa ma na ama a Asuriya 
\q2 a̱ riya̱a̱ iɗa i tsu nu uvon, 
\q1 hali a̱ ba̱ma̱ kari tsu, 
\q2 tsu ta zuwa a̱za̱ o uka̱lyusa̱ e cindere, 
\q2 oɓolo na azagbain kunla̱ a yuwan uvon ne le, 
\q1  
\v 6 na a yuwan tsugono 
\q2 tsa Asuriya na̱ matsun me pe'eni. 
\q2 Nimro waru na̱ matsun mepe'eni ma na a talai. 
\q1 Waru u ta wawa tsu diga e ekere aza a Asuriya, 
\q2 a mantsa ma na a̱ ta̱wa̱yi 
\q2 iɗa i tsu nu uvon, 
\q2 ko na̱ shi a uwa o tyo wi iɗa i tsu. 
\q1  
\v 7 Akapi o ugundo wa Yakubu na la'ai 
\q2 o to o'wo a̱tsuma̱ a ama na̱ a̱bunda̱, 
\q1 tsa a'iza na a̱ ta̱wusa̱ diga uba̱ta̱ wa̱ A̱sulazuva, 
\q2 tsa̱ yiji'in a anlya, 
\q1 za na tsu puro za shi 
\q2 ko u zuwa ucira uba̱ta̱ wu vaɗilima̱ shi. 
\q1  
\v 8 Akapi o ugundo wa Yakubu na la'ai 
\q2 o to o'wo a̱tsuma̱ a ama na̱ a̱bunda̱, 
\q1 tsa a kamu e memere me inama yu una yo ogozo, 
\q2 tsa kamu vu ucira e memere mo oɓolo e ikyon, 
\q1 za na nu wu 'yawan a̱vu u riya̱a̱ le, 
\q2 waru za lo na wawa le shi. 
\q1  
\v 9 Ukere wa̱ wu u ta la'a ucira wu n'yuwatan ma̱ wu, 
\q2 waru a̱ ta̱ kototo n'yuwatan ma̱ wu! 
\b  
\q1  
\v 10 Reve A̱sulazuva a damma, 
\q2 <<O urana u ndolo u ɗa mo una ido i ɗu 
\q2 waru n kototo ikeke yi ido i ɗu. 
\q1  
\v 11 N ta̱ kototo ilyuci yi iɗa i ɗu 
\q2 waru mu ɓoso pa'atan vu ucira ɗu. 
\q1  
\v 12 N ta̱ gba o kototo a̱za̱ a̱ nkunu a̱ ɗu, 
\q2 waru ya̱ da̱shi tsura̱ boci shi. 
\q1  
\v 13 N ta̱ fo o kototo a̱ma̱li a̱ ɗu 
\q2 na atali a̱ga̱nda̱ a na a̱ ri a̱tsuma̱ a̱ ɗu. 
\q1 Ya̱ da̱shi ka̱ɗa̱towa̱a̱ ili i na 
\q2 i yuwain ne e ekere a̱ ɗu shi. 
\q1  
\v 14 N ta̱ mumula̱ a̱ma̱li a ka Ashera 
\q2 na a̱ ri a̱tsuma̱ a̱ ɗu 
\q2 a mantsa ma na n kototoi ilyuci i ɗu. 
\q1  
\v 15 Na asuvu usuɗu u ɗa ma tsupa nɗa 
\q2 n na n 'yuwain a yuwan tsutoni na̱ a̱mu.>> 
\c 6  
\s1 Adanshi A̱sulazuva a aci a Isra'ila 
\p  
\v 1 Uwwai ili i na A̱sulazuva a dammai Isra'ila: 
\q1 << 'Yon vu 'ya̱wa̱ na adanshi a̱ va̱ eleme a nsasan, 
\q2 lyawa agaɗi a uwwa ili i na vaa damma.>> 
\q1  
\v 2 Uwwai a̱ ɗu nsasan ili i na A̱sulazuva a yuwusan adanshi a aci a̱ ɗu, 
\q2 poloi atsuvu a̱ ɗu nkyun mu uvaɗi. 
\q1 Adama a na A̱sulazuva a̱ ta̱ na adanshi a aci a ama a̱ yi, 
\q2 u ta karishi Isra'ila ana. 
\q1  
\v 3 <<Ama a̱ va̱, nye i ɗa n yuwaan nɗu? 
\q2 Cine tsa ɗa n damaton nɗu? 
\q2 Usu numu! 
\q1  
\v 4 A̱mu ɗa mu uta̱a̱ nɗu a̱tsuma̱ e iɗa ya Masar 
\q2 reve n wawa ɗu diga e iɗa i tsugbashi. 
\q1 A̱mu ɗa n lyunguyi Musa na̱ Haruna na̱ Maryamu o rono ɗu aaɗanga.\x - \xo 6:4 \xt Mta̱ 4:10-16; 12:50-51; 15:20.\x* 
\q1  
\v 5 Ama a̱ va̱, cuwain 
\q2 ili i na Mogono Balak ma Mowa mo foɓoi 
\q2 ni ili i na Balam mawun ma Beyo ma̱ usu niyi. 
\q1 Cuwain na̱ mmalu n ɗu diga Shitim a̱ tyo Gilga, 
\q2 adama i reve nu ulinga wa̱ a̱ɓula̱ wa̱ A̱sulazuva.>>\x - \xo 6:5 \xt Mkc 22:2; 24:25; Juwe 3:1; 4:19.\x* 
\s1 Ili i na A̱sulazuva a cigai 
\q1  
\v 6 Na̱ nye ma̱ ta̱wa̱ a̱ ma̱ka̱ka̱n ma A̱sulazuva 
\q2 n yuwan a̱ga̱nda̱ a̱ ma̱ka̱ka̱n ma̱ A̱sula̱ a gbain? 
\q1 N ta̱ ta̱wa̱ a̱ ma̱ka̱ka̱n ma̱ yi na̱ kucci vu ukula̱tosu u ma̱dindim ma aa'wan a̱ ta̱? 
\q1  
\v 7 Ko A̱sulazuva a ta uwwa uyo'o 
\q2 wa̱ a̱giri'i ukpakukupa kupa va̱ a̱bunda̱, 
\q2 na̱ ɗolu mani'in ma̱ zetun ɗa? 
\q1 Ko n ta ca mawun mo ufaru ma̱ va̱ 
\q2 kucci vu unusu u va̱, 
\q1 ko mpasa n va̱ 
\q2 adama o unusu u wuma u va̱? 
\q1  
\v 8 O'o vaɗilima̱, 
\q2 A̱sulazuva o roco wu ta̱ ɗe 
\q2 ili i na i ri ulobonu. 
\q1 Gogo ili i na A̱sulazuva a cigai ya̱'a̱ wu, 
\q2 a̱yi ɗa vu yuwan mejege, 
\q2 a̱vu vu ciga mayan me iliyali, 
\q2 vu ka̱ɗa̱to vu yuwan mmalu na̱ A̱sula̱ a̱ wu. 
\s1 Unusu wa Isra'ila nu uge'etosu wa̱ yi 
\q1  
\v 9 Poloi atsuvu! 
\q2 A̱sulazuva a̱ ta̱ ɗewu 
\q2 va ama a̱ Urishelima. 
\q1 Ugbozu ɗa lon a uwwa wovon wa̱ A̱sulazuva! 
\q2 Uwwai a̱ ɗu ugundo 
\q2 oɓolo ni iɓolo ilyuci'i! 
\q1  
\v 10 Ko n ta̱ e icina nu utsuru 
\q2 u na a̱ tsura̱i o ure wi iwuya 
\q2 o u'wa u vuma vi iwuya? 
\q1 Ko n ta̱ e icina na̱ makundatsu 
\q2 ma na a da̱da̱'wain? 
\q1  
\v 11 Ko me ge'eto vuma 
\q2 na ri na̱ makundatsu me epen, 
\q2 na̱ buhu yipalishi shi? 
\q1  
\v 12 A̱za̱ o utsuru a̱ lyuci ɗu, 
\q2 aza a na e le'eshe alambi a ɗa. 
\q1 Aza a na a̱ ri pe na̱ nden a̱ lyuci'i 
\q2 a̱za̱ epen a ɗa suru. 
\q1  
\v 13 Adama o ndolo, n ta amaton ɗu, 
\q2 n ta̱ ka̱mba̱to ɗu okongo adama a̱ nusu ɗu. 
\q1  
\v 14 I ta lyuwa, agba ya̱ cuwa̱n shi, 
\q2 a̱a̱tsuma̱ a̱ ɗu a̱ ta̱ da̱na̱ o upunda̱ra̱sa̱ 
\q2 adama a ambulu. 
\q1 I to ɓoloto wi ili, 
\q2 agba ya gura zuwa ili shi, 
\q1 ili i ke'en i na i zuwai waru, 
\q2 n ta̱ lungusa̱ le a̱tsuma̱ o uvon. 
\q1  
\v 15 I ta̱ cu'wa̱n, 
\q2 agba ya yuwan ugasa shi. 
\q2 I ta pisha mani'in ma̱ zetun, 
\q2 agba ya yuwan ulinga na̱ mani'in ma̱ yi shi. 
\q1 I ta pisha matsun ina̱bi, 
\q2 agba yo sowo masayan ma̱ yi shi. 
\q1  
\v 16 Adama a na i toni ta̱ re vama va Omri, 
\q2 na̱ linga vu u'wa wa Ahabu suru, 
\q2 reve i yuwan ulinga na̱ a̱sa̱la̱ e iwuya i le. 
\q1 Adama o ndolo, n ta̱ ka̱mba̱to ɗu okongo, 
\q2 waru a ama a̱ wu o'wo ili macuru. 
\q1 Ne ɗa, a̱ ɗu ama a̱ va̱, 
\q2 a 'yuwan na a cuwa ɗu uba̱ta̱ suru.>>\x - \xo 6:16 \xt 1 Ngo 16:23-34; 21:25-26.\x* 
\c 7  
\s1 Ula̱ngu wa Isra'ila 
\p  
\v 1 U yo'ono mu shi! 
\q2 Adama a na mo o'wo ta̱ 
\q2 tsa za vu u'yanlu, 
\q1 a mantsa ma na o kotoi ugasa, 
\q2 u muwun ma̱ ina̱bi. 
\q1 Maani ma̱ ina̱bi ma lo na a ta'an a lyuwa shi. 
\q2 Waru umatsun wu ufaru wu biri lo na okolo a̱ va̱ a cigai shi. 
\q1  
\v 2 Ama a̱ a̱ɓula̱ o koto ta̱ a̱tsuma̱ o uvaɗi, 
\q2 za lo na buwai na ri no okolo asa'ani shi, 
\q1 za suru ta zama ure u na wo una za ro, 
\q2 za suru ta azusu moron ma̱ nden ma̱ yi ni igolo. 
\q1  
\v 3 E veɗece ta̱ a yuwan iwuya ne ekere e le. 
\q2 Ngono n ta zama ne'en, 
\q2 a̱za̱ o uge'etosu a̱ ta̱ ushishi utowusu wu una̱, 
\q1 azagbain a tsu zuwa ta̱ a yuwan ili i na a cigai. 
\q2 Ne ɗa o ɓoloi una̱ suru. 
\q1  
\v 4 Vuma va̱ a̱ɓula̱ le tsa awanda ɗa u ri, 
\q2 za va amayun a̱tsuma̱ e le 
\q2 u ta̱ tsu ubara u na a yuwain na awanda. 
\b  
\q1 Urana u na A̱sula̱ e ge'eto le yuwan ta̱, 
\q2 u rana u na a damma n le 
\q2 o una̱ wa ama̱sula̱ 
\q2 aza a na a yuwusan ipiri i le, 
\q1 gogo za suru wo o'wo ta̱ utogbolyuwu. 
\q1  
\v 5 She vu zuwaa moron me nden ma̱ wu okolo wan 
\q2 waru vu soɗuwo i'utsa̱ ya̱ wu ma̱tsa̱n wan, 
\q1 vu goloɓo una̱ wa̱ wu 
\q2 a̱ tyo a ka va̱ wu na vu ri e icigi 
\q2 za na ri nven na̱ a̱vu. 
\q1  
\v 6 Ama o u'wa u vuma, ele ɗa n'yuwatan ma̱ yi, 
\q2 adama a na ulobo u ta yuwaan dada va̱ yi ulamu, 
\q2 mawun mo usheli waru u ta̱ 'ya̱sa̱a̱n mma va̱ yi aci, 
\q2 jene ta yuwan tsushu'un na̱ a̱na̱wa̱ le fo.\x - \xo 7:6 \xt Mat 10:35-36; Luk 12:53. \x* 
\s1 A̱sulazuva a̱ ta̱ ta̱wa̱ ni ica ni iwawi 
\q1  
\v 7 A̱mu gba n ta zuwaa A̱sulazuva esu, 
\q2 n puro A̱sula̱ e iwawi i va̱, 
\q2 A̱sula̱ a̱ va̱ u ta uwwa mu. 
\q1  
\v 8 A̱vu ma'yuwatan ma̱ va̱, 
\q2 she vu yuwan ma̱za̱nga̱ a aci a̱ va̱ wan, 
\q1 ko na wo o'woi n riya̱i 
\q2 n ta̱ 'yowisa̱n. 
\q1 A mantsa ma na n da̱nuyi 
\q2 a̱tsuma̱ e irumbu, 
\q2 A̱sulazuva oto o'wo ekan a̱ va̱. 
\q1  
\v 9 N yuwaan ta̱ A̱sulazuva unusu, 
\q2 n ta kaɓa asuvu 
\q2 a̱tsuma̱ o upan wa̱ yi. 
\q1 Hali she nu u ge'eto 
\q2 iwuya i na a yuwaan numu 
\q2 a̱vu u zuwa mu mo o'wo fa̱a̱n. 
\q1 U ta̱ ta̱wa̱to mu uba̱ta̱ e ekan, 
\q2 waru n ta̱ ene a̱ɓula̱ a̱ yi. 
\q1  
\v 10 A mantsa'a n'yuwatan n va̱ n te ene, 
\q2 waru wono u ta̱ kpoto le 
\q1 ele na a damma numu, 
\q2 <<A̱ te ɗa A̱sulazuva A̱sula̱ a̱ wu?>> 
\q1 Esu a̱ va̱ e te ene uriyu u le, 
\q2 gogo a ta dadasa le 
\q2 tso yilyo'o a̱ re. 
\b  
\q1  
\v 11 Urana u na a suwisa kari ɗu ta̱ lo a̱ ta̱wa̱, 
\q1 o urana u ndolo a̱ ta̱ da̱shi 
\q2 washin wu utyo wi iɗa i ɗu. 
\q1  
\v 12 O urana u ndolo ama a̱ ɗu 
\q2 a̱ ta̱ ka̱mba̱ uba̱ta̱ u ɗu, 
\q2 diga Asuriya oɓolo ni ilyuci ya Masar, 
\q1 hali diga Masar a̱ tyo Yufiriti, 
\q2 na̱ diga a mala a̱ tyo a mala, 
\q2 na̱ diga a masasan a̱ tyo a masasan. 
\q1  
\v 13 Uvaɗi gba u to o'wo okongo, 
\q2 adama a ama a na a̱ ri pe nden, 
\q2 adama e iwuya ya ama a na a̱ ri pe. 
\s1 Iliyali ya̱ A̱sula̱ e ekere a Isra'ila 
\q1  
\v 14 Vu guɓa ama a̱ wu 
\q2 na aaɗanga aguɓa a̱ wu, 
\q2 oɓolo e ikyon ya̱ wu ya agadu, 
\q1 za na a yuwusan nden ma aciyele a̱tsumona, 
\q2 a̱tsuma̱ o uba̱ta̱ wa alyuna u sa'ani. 
\q1 Lyawa a yuwan aguɓa a̱tsuma̱ Bashan na̱ Giliyadu, 
\q2 cine a yuwain ɗe nu ujimu. 
\b  
\q1  
\v 15 Reve A̱sulazuva a damma, 
\q1 <<Tsu rana na yu uta̱i a̱tsuma̱ e iɗa ya Masar, 
\q2 n ta̱ roco le ili ya asalama a̱ va̱.>> 
\b  
\q1  
\v 16 Nɗa n ta̱ e ene reve o sowo wono 
\q2 o una̱ wu ucira u le suru. 
\q1 A̱ ta̱ ɓa̱ru na̱ le ne ekere 
\q2 waru atsuvu e le a ta ula. 
\q1  
\v 17 E te peɗe ma̱buta̱ tsi iyo, 
\q2 tsi inama i na yo ronoso a̱a̱tsuma̱ e iɗa. 
\q1 A̱ ta̱ o uta̱ na̱ meje'en diga a pa'atan n le, 
\q2 a ta vadala na̱ wovon 
\q2 uba̱ta̱ wa̱ A̱sulazuva A̱sula̱ a̱ tsu. 
\q2 waru a uwwa wovon wa̱ wu.>> 
\q1  
\v 18 Zane ɗa A̱sula̱ tsa̱ wu, 
\q2 na tsu yuwan gafura vu unusu 
\q2 na̱ matawa mo unusu 
\q2 va akapi a ama agadu a̱ yi? 
\q1 Vu tsu guza̱ upan wa̱ wu hali hali shi, 
\q2 adama a na vu ta uwwusa uyo'o 
\q2 vu roco icigi i na i tsu vadala shi. 
\q1  
\v 19 Vu ta da̱shi ene iliyali i tsu, 
\q2 vu ta dadasa nusu tsu 
\q2 za̱la̱ va apata ana a̱ wu. 
\q1 Vu ta vari nusu tsu suru 
\q2 a̱tsuma̱ a mala ma̱ a̱ru'un. 
\q1  
\v 20 Vu to roco Yakubu amayun a̱ wu, 
\q1 Ibrahim waru icigi i na i tsu vadala shi. 
\q2 Cine vu kucinayi nkaya ntsu ɗe nu ujimu.