\id 1CH - Biblica® Open Kikuyu Holy Word of God
\h 1 Maũndũ Ma Matukũ Ma Tene
\toc1 1 Maũndũ Ma Matukũ Ma Tene
\toc2 1 Maũndũ Ma Matukũ Ma Tene
\toc3 1Maũ
\mt1 IBUKU RĨA MBERE RĨA
\mt1 MAŨNDŨ MA MATUKŨ MA TENE
\c 1
\s1 Maandĩko ma Maũndũ ma Tene kuuma Adamu nginya Iburahĩmu
\s3 Nginya Ariũ a Nuhu
\p 
\v 1 Njiaro cia Adamu ciarĩ Sethi, na Enoshu,
\v 2 na Kenani, na Mahalaleli, na Jaredi,
\v 3 na Enoku, na Methusela, na Lameku, na Nuhu.
\b
\li1 
\v 4 Ariũ a Nuhu maarĩ:
\li2 Shemu, na Hamu, na Jafethu.
\s3 Ariũ a Jafethu
\li1 
\v 5 Ariũ a Jafethu maarĩ:
\li2 Gomeri, na Magogu, na Madai, na Javani, na Tubali, na Mesheki, na Tirasi.
\li1 
\v 6 Ariũ a Gomeri maarĩ:
\li2 Ashikenazu, na Difatha, na Togarima.
\li1 
\v 7 Ariũ a Javani maarĩ:
\li2 Elisha, na Tarishishi, na Kitimu, na Rodanimu.
\s3 Ariũ a Hamu
\li1 
\v 8 Ariũ a Hamu maarĩ:
\li2 Kushi, na Miziraimu, na Putu, na Kaanani.
\li1 
\v 9 Ariũ a Kushi maarĩ:
\li2 Seba, na Havila, na Sabita, na Raama, na Sabiteka.
\li1 Ariũ a Raama maarĩ:
\li2 Sheba, na Dedani.
\li1 
\v 10 Kushi nĩwe warĩ ithe wa
\li2 Nimurodi ũrĩa wakũrire agĩtuĩka njamba ya ita ĩrĩ hinya thĩinĩ wa thĩ.
\li1 
\v 11 Miziraimu nĩwe warĩ ithe wa
\li2 andũ a Ludimu, na Anamini, na Lehabimu, na Nafituhimu,
\v 12 na Pathirusimu, na Kasuluhimu (nĩwe warĩ kĩhumo kĩa Afilisti), o na Kafitorimu.
\li1 
\v 13 Kaanani nĩwe warĩ ithe wa
\li2 
\v 14 Sidoni, mũriũ wake wa irigithathi, na Ahiti, na Ajebusi, na Aamori, na Agirigashi,
\v 15 na Ahivi, na Aariki, na Asini,
\v 16 na Aarivadi, na Azemari, na Ahamathi.
\s3 Ariũ a Shemu
\li1 
\v 17 Ariũ a Shemu maarĩ:
\li2 Elamu, na Ashuri, na Arafakasadi, na Ludu, na Aramu.
\li1 Ariũ a Aramu maarĩ:
\li2 Uzu, na Hulu, na Getheru, na Mesheki.
\li1 
\v 18 Arafakasadi nĩwe warĩ ithe wa Shela, nake Shela aarĩ ithe wa Eberi.
\li1 
\v 19 Eberi aarĩ na ariũ eerĩ:
\li2 Ũmwe eetagwo Pelegu, tondũ hĩndĩ yake nĩrĩo thĩ yagayũkanirio; na mũrũ wa nyina eetagwo Jokitani.
\li1 
\v 20 Jokitani nĩwe warĩ ithe wa
\li2 Alimodadi, na Shelefu, na Hazarimavethu, na Jera,
\v 21 na Hadoramu, na Uzali, na Dikila,
\v 22 na Ebali, na Abimaeli, na Sheba,
\v 23 na Ofiri, na Havila, na Jobabu. Acio othe maarĩ ariũ a Jokitani.
\b
\li1 
\v 24 Shemu, na Arafakasadi, na Shela,
\li2 
\v 25 na Eberi, na Pelegu, na Reu,
\li2 
\v 26 na Serugu, na Nahoru, na Tera,
\li2 
\v 27 na Aburamu (na nĩwe Iburahĩmu).
\s2 Nyũmba ya Iburahĩmu
\li1 
\v 28 Ariũ a Iburahĩmu maarĩ:
\li2 Isaaka na Ishumaeli.
\s3 Njiaro cia Hagari
\li1 
\v 29 Ici nĩcio njiaro ciao:
\li2 Nebaiothu nĩwe warĩ irigithathi rĩa Ishumaeli, nao ariũ ake arĩa angĩ maarĩ Kedari, na Adibeeli, na Mibisamu,
\v 30 na Mishima, na Duma, na Masa, na Hadadi, na Tema,
\v 31 na Jeturu, na Nafishu, na Kedema. Acio nĩo maarĩ ariũ a Ishumaeli.
\s3 Njiaro cia Ketura
\li1 
\v 32 Ariũ a Ketura, ũrĩa warĩ thuriya ya Iburahĩmu, maarĩ:
\li2 Zimirani, na Jokishani, na Medani, na Midiani, na Ishibaku, na Shua.
\li1 Ariũ a Jokishani maarĩ:
\li2 Sheba na Dedani.
\li1 
\v 33 Ariũ a Midiani maarĩ:
\li2 Efa, na Eferi, na Hanoku, na Abida, na Elidaa.
\li1 Acio othe maarĩ a rũciaro rwa Ketura.
\s3 Njiaro cia Sara
\li1 
\v 34 Iburahĩmu nĩwe warĩ ithe wa Isaaka.
\li1 Ariũ a Isaaka maarĩ:
\li2 Esaũ na Isiraeli.
\s2 Ariũ a Esaũ
\li1 
\v 35 Ariũ a Esaũ maarĩ:
\li2 Elifazu, na Reueli, na Jeushu, na Jalamu, na Kora.
\li1 
\v 36 Ariũ a Elifazu maarĩ:
\li2 Temani, na Omari, na Zefi, na Gatamu, na Kenazu;
\li2 na Amaleki, ũrĩa waciarirwo nĩ Timina.
\li1 
\v 37 Ariũ a Reueli maarĩ:
\li2 Nahathu, na Zera, na Shama, na Miza.
\s2 Andũ a Seiru kũu Edomu
\li1 
\v 38 Ariũ a Seiru maarĩ:
\li2 Lotani, na Shobali, na Zibeoni, na Ana, na Dishoni, na Ezeri, na Dishani.
\li1 
\v 39 Ariũ a Lotani maarĩ:
\li2 Hori na Homamu.
\li2 Nake Timina aarĩ mwarĩ wa nyina na Lotani.
\li1 
\v 40 Ariũ a Shobali maarĩ:
\li2 Alivani, na Manahathu, na Ebali, na Shefo, na Onamu.
\li1 Ariũ a Zibeoni maarĩ:
\li2 Aia na Ana.
\li1 
\v 41 Mũriũ wa Ana aarĩ:
\li2 Dishoni.
\li1 Ariũ a Dishoni maarĩ:
\li2 Hemudani, na Eshibani, na Ithirani, na Kerani.
\li1 
\v 42 Ariũ a Ezeri maarĩ:
\li2 Bilihani, na Zaavani, na Akani.
\li1 Ariũ a Dishani maarĩ:
\li2 Uzu, na Arani.
\s3 Athamaki a Edomu
\li1 
\v 43 Nao aya nĩo maarĩ athamaki arĩa maathamakaga Edomu mbere ya Isiraeli gũthamakĩrwo nĩ mũthamaki o na ũmwe:
\li2 Nĩ Bela mũrũ wa Beori, narĩo itũũra rĩake inene rĩetagwo Dinihaba.
\li1 
\v 44 Rĩrĩa Bela aakuire, Jobabu mũrũ wa Zera wa kuuma Bozira agĩtuĩka mũthamaki ithenya rĩake.
\li1 
\v 45 Rĩrĩa Jobabu aakuire, Hushamu wa kuuma bũrũri wa Atemani agĩtuĩka mũthamaki ithenya rĩake.
\li1 
\v 46 Rĩrĩa Hushamu aakuire, Hadadi mũrũ wa Bedadi ũrĩa wahootire Midiani kũu bũrũri wa Moabi, agĩtuĩka mũthamaki ithenya rĩake. Itũũra rĩake inene rĩetagwo Avithu.
\li1 
\v 47 Rĩrĩa Hadadi aakuire, Samala wa kuuma Masereka agĩtuĩka mũthamaki ithenya rĩake.
\li1 
\v 48 Rĩrĩa Samala aakuire, Shauli wa kuuma Rehobothu kũu gũkuhĩ na Rũũĩ rwa Farati, agĩtuĩka mũthamaki ithenya rĩake.
\li1 
\v 49 Rĩrĩa Shauli aakuire, Baali-Hanani mũrũ wa Akibori agĩtuĩka mũthamaki ithenya rĩake.
\li1 
\v 50 Rĩrĩa Baali-Hanani aakuire, Hadadi agĩtuĩka mũthamaki ithenya rĩake. Itũũra rĩake inene rĩetagwo Pau, na mũtumia wake eetagwo Mehetabeli mwarĩ wa Matiredi, ũrĩa warĩ mwarĩ wa Me-Zahabu.
\v 51 Hadadi o nake agĩkua.
\b
\li1 Anene a Edomu maarĩ:
\li2 
\v 52 Timina, na Aliva, na Jethethu, na Oholibama, na Ela, na Pinoni,
\v 53 na Kenazu, na Temani, na Mibizaru,
\v 54 na Magidieli, na Iramu. Acio nĩo maarĩ anene a Edomu.
\c 2
\s1 Ariũ a Isiraeli
\li1 
\v 1 Aya nĩo maarĩ ariũ a Isiraeli:
\li2 Rubeni, na Simeoni, na Lawi, na Juda, na Isakaru, na Zebuluni,
\v 2 na Dani, na Jusufu, na Benjamini, na Nafitali, na Gadi, na Asheri.
\s2 Juda
\s3 Kũrĩ ariũ a Hezironi
\li1 
\v 3 Ariũ a Juda maarĩ:
\li2 Eri, na Onani, na Shela. Acio atatũ maaciarĩirwo Juda nĩ mũtumia Mũkaanani, mwarĩ wa Shua. Eri, irigithathi rĩa Juda, aarĩ mwaganu maitho-inĩ ma Jehova; nĩ ũndũ ũcio Jehova akĩmũũraga.
\v 4 Tamaru, mũtumia wa mũrũ wa Juda, akĩmũciarĩra Perezu na Zera. Ariũ othe a Juda maarĩ atano.
\b
\li1 
\v 5 Ariũ a Perezu maarĩ:
\li2 Hezironi na Hamula.
\li1 
\v 6 Ariũ a Zera maarĩ:
\li2 Zimuri, na Ethani, na Hemani, na Kalikoli, na Darida; othe maarĩ atano.
\li1 
\v 7 Mũriũ wa Karimi aarĩ:
\li2 Akaru, ũrĩa wareheire Isiraeli thĩĩna nĩ ũndũ wa kuuna watho na kuoya indo iria ciarĩ nyamũre.
\li1 
\v 8 Mũriũ wa Ethani aarĩ:
\li2 Azaria.
\li1 
\v 9 Ariũ arĩa maaciarĩrĩirwo Hezironi maarĩ:
\li2 Jerameeli, na Ramu, na Kalebu.
\s3 Ciana cia Ramu Mũrũ wa Hezironi
\li1 
\v 10 Ramu nĩwe warĩ ithe wa
\li2 Aminadabu, nake Aminadabu aarĩ ithe wa Nahashoni, ũrĩa warĩ mũtongoria wa andũ a Juda.
\v 11 Nahashoni nĩwe warĩ ithe wa Salimoni, nake Salimoni aarĩ ithe wa Boazu,
\v 12 nake Boazu nĩwe warĩ ithe wa Obedi, ũria warĩ ithe wa Jesii.
\li1 
\v 13 Jesii nĩwe warĩ ithe wa Eliabu, irigithathi rĩake; nake Abinadabu aarĩ wa keerĩ, na Shimea wa gatatũ,
\v 14 na Nethaneli wa kana, nake Radai wa gatano,
\v 15 na Ozemu wa gatandatũ, nake Daudi aarĩ wa mũgwanja.
\v 16 Nao aarĩ a nyina maarĩ Zeruia na Abigaili. Ariũ a Zeruia maarĩ atatũ, na nĩo Abishai, na Joabu, na Asaheli.
\v 17 Abigaili nĩwe warĩ nyina wa Amasa, na ithe wa Amasa aarĩ Jetheri ũrĩa Mũishumaeli.
\s3 Kalebu Mũrũ wa Hezironi
\li1 
\v 18 Kalebu mũrũ wa Hezironi nĩagĩire ciana na mũtumia wake Azuba (o na ningĩ na Jeriothu). Ariũ a mũtumia ũcio maarĩ: Jesheri, na Shobabu, na Aridoni.
\v 19 Hĩndĩ ĩrĩa Azuba aakuire, Kalebu akĩhikia Efiratha, ũrĩa wamũciarĩire Huru.
\v 20 Huru nĩwe warĩ ithe wa Uri, nake Uri nĩwe warĩ ithe wa Bezaleli.
\li1 
\v 21 Thuutha ũcio, Hezironi agĩkoma na mwarĩ wa Makiru ũrĩa warĩ ithe wa Gileadi (Hezironi aarĩ wa mĩaka mĩrongo ĩtandatũ akĩmũhikia), nake akĩmũciarĩra Segubu.
\v 22 Segubu nĩwe warĩ ithe wa Jairu, ũrĩa warĩ na matũũra mĩrongo ĩĩrĩ na matatũ kũu Gileadi.
\v 23 (No rĩrĩ, Geshuru na Aramu magĩtunyana matũũra ma Havothu-Jairu, o hamwe na Kenathu na ciikaro iria ciarĩthiũrũrũkĩirie, namo maarĩ matũũra mĩrongo ĩtandatũ.) Aya othe nĩo maarĩ njiaro cia Makiru, o we ithe wa Gileadi.
\b
\li1 
\v 24 Thuutha wa Hezironi gũkua arĩ kũu Kalebu-Efiratha-rĩ, Abija mũtumia wa Hezironi akĩmũciarĩra Ashuru, ithe wa Tekoa.
\s2 Jerameeli Mũrũ wa Hezironi
\li1 
\v 25 Ariũ a Jerameeli, ũrĩa warĩ irigithathi rĩa Hezironi, maarĩ:
\li2 Ramu ũrĩa warĩ irigithathi rĩake, na Buna, na Oreni, na Ozemu, na Ahija.
\v 26 Jerameeli aarĩ na mũtumia ũngĩ wetagwo Atara, nake nĩwe warĩ nyina wa Onamu.
\li1 
\v 27 Ariũ a Ramu, ũrĩa warĩ irigithathi rĩa Jerameeli, maarĩ:
\li2 Maazu, na Jamini, na Ekeri.
\li1 
\v 28 Ariũ a Onamu maarĩ:
\li2 Shamai na Jada.
\li1 Nao ariũ a Shamai maarĩ:
\li2 Nadabu na Abishuri.
\li1 
\v 29 Mũtumia wa Abishuri eetagwo Abihaili, ũrĩa wamũciarĩire Ahabani na Molidi.
\li1 
\v 30 Ariũ a Nadabu maarĩ:
\li2 Seledi na Apaimu. No rĩrĩ, Seledi aakuire atarĩ na ciana.
\li1 
\v 31 Mũrũ wa Apaimu aarĩ:
\li2 Ishi, ũrĩa warĩ ithe wa Sheshani.
\li2 Nake Sheshani nĩwe warĩ ithe wa Ahalai.
\li1 
\v 32 Ariũ a Jada, mũrũ wa nyina na Shamai, maarĩ:
\li2 Jetheri na Jonathani. Jetheri aakuire atarĩ na ciana.
\li1 
\v 33 Ariũ a Jonathani maarĩ:
\li2 Pelethu na Zaza.
\li1 Acio nĩo maarĩ njiaro cia Jerameeli.
\li1 
\v 34 Sheshani ndaarĩ na aanake, no airĩtu.
\li2 Aarĩ na ndungata ya kuuma Misiri yetagwo Jariha.
\v 35 Sheshani akĩhe Jariha ndungata ĩyo yake mwarĩ ĩmũhikie, nake akĩgĩa mwana wetagwo Atai.
\li1 
\v 36 Atai nĩwe warĩ ithe wa Nathani,
\li2 nake Nathani nĩwe warĩ ithe wa Zabadi,
\li2 
\v 37 nake Zabadi nĩwe warĩ ithe wa Efilali,
\li2 nake Efilali nĩwe warĩ ithe wa Obedi,
\li2 
\v 38 nake Obedi nĩwe warĩ ithe wa Jehu,
\li2 nake Jehu nĩwe warĩ ithe wa Azaria,
\li2 
\v 39 nake Azaria nĩwe warĩ ithe wa Helezu,
\li2 nake Helezu nĩwe warĩ ithe wa Eleasa,
\li2 
\v 40 nake Eleasa nĩwe warĩ ithe wa Sisimai,
\li2 nake Sisimai nĩwe warĩ ithe wa Shalumu,
\li2 
\v 41 nake Shalumu nĩwe warĩ ithe wa Jekamia,
\li2 nake Jekamia nĩwe warĩ ithe wa Elishama.
\s3 Mbarĩ cia Kalebu
\li1 
\v 42 Ariũ a Kalebu, ũrĩa warĩ mũrũ wa nyina na Jerameeli, maarĩ:
\li2 Mesha irigithathi rĩake, na nĩwe warĩ ithe wa Zifu, na mũriũ Maresha ũrĩa warĩ ithe wa Hebironi.
\li1 
\v 43 Ariũ a Hebironi maarĩ:
\li2 Kora, na Tapua, na Rekemu, na Shema.
\v 44 Shema nĩwe warĩ ithe wa Rahamu, na Rahamu nĩwe warĩ ithe wa Jorikeamu. Rekemu aarĩ ithe wa Shamai.
\v 45 Mũrũ wa Shamai aarĩ Maoni, nake nĩwe warĩ ithe wa Bethi-Zuru.
\li1 
\v 46 Nake Efa, thuriya ya Kalebu, nĩwe warĩ nyina wa Harani, na Moza, na Gazezi. Nake Harani nĩwe warĩ ithe wa Gazezi.
\li1 
\v 47 Ariũ a Jahadai maarĩ:
\li2 Regemu, na Jothamu, na Geshani, na Peleti, na Efa, na Shaafu.
\li1 
\v 48 Nake Maaka, thuriya ya Kalebu, nĩwe warĩ nyina wa Sheberi na Tirihana.
\v 49 Ningĩ nowe waciarire Shaafu ũrĩa warĩ ithe wa Madimana, na Sheva ithe wa Makibena na Gibea. Mwarĩ wa Kalebu eetagwo Akisa.
\v 50 Acio nĩo maarĩ njiaro cia Kalebu.
\b
\li1 Ariũ a Huru, irigithathi rĩa Efiratha, maarĩ:
\li2 Shobali ithe wa Kiriathu-Jearimu,
\v 51 na Salima ithe wa Bethilehemu, na Harefu ithe wa Bethi-Gaderi.
\li1 
\v 52 Njiaro cia Shobali, ithe wa Kiriathu-Jearimu, ciarĩ:
\li2 Haroe, na nuthu ya Amanahathi,
\v 53 na mĩhĩrĩga ya Kiriathu-Jearimu ĩrĩa yatariĩ ta ũũ: Aithiri, na Aputhi, na Ashumathi, na Amishirai. Kuuma kũrĩ acio gũkĩgĩa njiaro cia Azorathi na Aeshitaoli.
\li1 
\v 54 Njiaro cia Salima ciarĩ:
\li2 Bethilehemu ũrĩa Mũnetofathi, na Aatirothu-Bethi-Joabu, na nuthu ya Amanahathi, na Azori,
\v 55 na mĩhĩrĩga ya aandĩki-marũa arĩa maatũũraga Jabezu ĩrĩa yatariĩ ta ũũ: Atirathi, na Ashimeathi, na Asukathi. Aya nĩo Akeni arĩa moimĩte harĩ Hamathu, ithe wa nyũmba ya Rekabu.
\c 3
\s3 Ariũ a Daudi
\li1 
\v 1 Aya nĩo maarĩ ariũ a Daudi arĩa maaciarĩirwo Hebironi:
\li2 Irigithathi rĩarĩ Amunoni mũrũ wa Ahinoamu wa kuuma Jezireeli;
\li2 nake wa keerĩ aarĩ Danieli mũrũ wa Abigaili wa kuuma Karimeli;
\li2 
\v 2 nake wa gatatũ aarĩ Abisalomu mũrũ wa Maaka mwarĩ wa Talimai mũthamaki wa Geshuru;
\li2 nake wa kana aarĩ Adonija mũrũ wa Hagithu;
\li2 
\v 3 nake wa gatano aarĩ Shefatia mũrũ wa Abitali;
\li2 nake wa gatandatũ aarĩ Ithireamu ũrĩa aaciarĩirwo nĩ mũtumia wake Egila.
\li2 
\v 4 Acio atandatũ maaciarĩirwo Daudi kũu Hebironi, kũrĩa aathamakĩire mĩaka mũgwanja na mĩeri ĩtandatũ.
\m Daudi aathamakire arĩ Jerusalemu mĩaka mĩrongo ĩtatũ na ĩtatũ,
\v 5 nacio ici nĩcio ciana ciake iria ciaciarĩirwo kũu:
\li2 Shimea, na Shobabu, na Nathani, na Solomoni. Acio ana maaciarirwo nĩ Bathisheba mwarĩ wa Amieli.
\v 6 Ningĩ nĩ kwarĩ na Ibiharu, na Elishua, na Elifeleti,
\v 7 na Noga, na Nefegu, na Jafia,
\v 8 na Elishama, na Eliada, na Elifeleti; othe maarĩ kenda.
\v 9 Acio othe maarĩ ariũ a Daudi, ariũ a thuriya ciake matatarĩtwo. Nake Tamaru nĩwe warĩ mwarĩ wa ithe wao.
\s3 Athamaki a Juda
\li1 
\v 10 Mũriũ wa Solomoni eetagwo Rehoboamu,
\li2 nake mũriũ eetagwo Abija,
\li2 nake Asa aarĩ mũriũ wa Abija,
\li2 nake Jehoshafatu aarĩ mũriũ wa Asa,
\li1 
\v 11 nake Jehoramu aarĩ mũriũ wa Jehoshafatu,
\li2 nake Ahazia aarĩ mũriũ wa Jehoramu,
\li2 nake Joashu aarĩ mũriũ wa Ahazia,
\li2 
\v 12 nake Amazia aarĩ mũriũ wa Joashu,
\li2 nake Azaria aarĩ mũriũ wa Amazia,
\li2 nake Jothamu aarĩ mũriũ wa Azaria,
\li2 
\v 13 nake Ahazu aarĩ mũriũ wa Jothamu,
\li2 nake Hezekia aarĩ mũriũ wa Ahazu,
\li2 nake Manase aarĩ mũriũ wa Hezekia,
\li2 
\v 14 nake Amoni aarĩ mũriũ wa Manase,
\li2 nake Josia aarĩ mũriũ wa Amoni.
\li1 
\v 15 Ariũ a Josia maarĩ:
\li2 Johanani irigithathi rĩake,
\li2 nake wa keerĩ aarĩ Jehoiakimu,
\li2 nake wa gatatũ aarĩ Zedekia,
\li2 nake wa kana aarĩ Shalumu.
\li1 
\v 16 Arĩa maathamakire thuutha wa Jehoiakimu maarĩ:
\li2 mũriũ Jekonia
\li2 na Zedekia.
\s3 Rũciaro rwa Nyũmba ya Ũthamaki thuutha wa Ithaamĩrio
\li1 
\v 17 Njiaro cia Jekonia, ũrĩa watahĩtwo, ciarĩ:
\li2 Mũriũ Shealitieli,
\v 18 na Malikiramu, na Pedaia, na Shenazaru, na Jekamia, na Hoshama, na Nedabia.
\li1 
\v 19 Ariũ a Pedaia maarĩ:
\li2 Zerubabeli na Shimei.
\li1 Ariũ a Zerubabeli maarĩ:
\li2 Meshulamu na Hanania;
\li2 Shelomithu aarĩ mwarĩ wa nyina wao.
\li2 
\v 20 Nĩ kwarĩ na ariũ angĩ atano, nao nĩ:
\li2 Hashuba, na Oheli, na Berekia, na Hasadia, na Jushabu-Hesedi.
\li1 
\v 21 Njiaro cia Hanania ciarĩ:
\li2 Pelatia, na Jeshaia, na ningĩ nĩ kwarĩ na ariũ a Rafaia, na a Arinani, na a Obadia, o na a Shekania.
\li1 
\v 22 Njiaro cia Shekania ciarĩ:
\li2 Shemaia na ariũ ake:
\li2 Hatushu, na Igali, na Baria, na Nearia, na Shafati; othe maarĩ atandatũ.
\li1 
\v 23 Ariũ a Nearia maarĩ:
\li2 Elioenai, na Hizikia, na Azirikamu; othe maarĩ atatũ.
\li1 
\v 24 Ariũ a Elioenai maarĩ:
\li2 Hodavia, na Eliashibu, na Pelaia, na Akubu, na Johanani, na Delaia, na Anani; othe maarĩ mũgwanja.
\c 4
\s3 Mĩhĩrĩga Ĩngĩ ya Juda
\li1 
\v 1 Njiaro cia Juda ciarĩ:
\li2 Perezu, na Hezironi, na Karimi, na Huru, na Shobali.
\li1 
\v 2 Reaia mũrũ wa Shobali nĩwe warĩ ithe wa Jahathu, nake Jahathu nĩwe warĩ ithe wa Ahumai na Lahadi. Icio nĩcio ciarĩ mbarĩ cia Azorathi.
\li1 
\v 3 Ariũ a Etamu maarĩ:
\li2 Jezireeli, na Ishima, na Idibasha.
\li2 Mwarĩ wa nyina wao eetagwo Hazeleliponi.
\v 4 Penueli nĩwe warĩ ithe wa Gedori, nake Ezeri nĩwe warĩ ithe wa Husha.
\li1 Ici nĩcio ciarĩ njiaro cia Huru ũrĩa irigithathi rĩa Efiratha, na ithe wa Bethilehemu.
\li1 
\v 5 Ashuri ithe wa Tekoa aarĩ na atumia eerĩ, nĩo Hela na Naara.
\li1 
\v 6 Naara akĩmũciarĩra Ahuzamu, na Heferi, na Temeni, na Haahashatari. Icio nĩcio ciarĩ njiaro cia Naara.
\li1 
\v 7 Ariũ a Hela maarĩ:
\li2 Zerethi, na Zoharu, na Ethinani,
\v 8 na Kozu, ũrĩa warĩ ithe wa Anubu, na Hazobeba, na wa mĩhĩrĩga ya Ahariheli mũrũ wa Harumu.
\b
\p 
\v 9 Jabezu aarĩ mũtĩĩku mũno gũkĩra ariũ a nyina. Nyina nĩwe wamũtuire Jabezu, tondũ oigire atĩrĩ, “Ndaamũciarire na ruo.”
\v 10 Nake Jabezu agĩkaĩra Ngai wa Isiraeli, akiuga atĩrĩ, “Naarĩ korwo wandathima na ũnjaramĩrie mĩhaka ya bũrũri wakwa! Reke guoko gwaku gũkorwo hamwe na niĩ, na ũngitĩre harĩ ũũru nĩguo ndikanakorwo na ruo.” Nake Ngai akĩigua ihooya rĩake. \f + \fr 4:10 \ft Rĩĩtwa Jabezu rĩgĩtaũrwo na Kĩhibirania nĩ ta kuuga “Ruo” kana “Kũnyariirĩka.”\f*
\b
\li1 
\v 11 Kelubu, mũrũ wa nyina na Shuha, nĩwe warĩ ithe wa Mehiru, ũrĩa warĩ ithe wa Eshitoni.
\v 12 Eshitoni nĩwe warĩ ithe wa Bethi-Rafa, na Pasea, na Tehina ũrĩa warĩ ithe wa Iri-Nahashu. Acio nĩo maarĩ andũ a Reka.
\b
\li1 
\v 13 Ariũ a Kenazu maarĩ:
\li2 Othinieli na Seraia.
\li1 Ariũ a Othinieli maarĩ:
\li2 Hathathu, na Meonothai.
\v 14 Meonothai nĩwe warĩ ithe wa Ofara.
\li1 Seraia nĩwe warĩ ithe wa Joabu
\li2 ũrĩa ithe wa andũ a Ge-Harashimu. Gwetagwo ũguo nĩ ũndũ andũ akuo maarĩ mabundi.
\li1 
\v 15 Ariũ a Kalebu, mũrũ wa Jefune, maarĩ:
\li2 Iru, na Ela, na Naamu.
\li1 Mũriũ wa Ela eetagwo:
\li2 Kenazu.
\li1 
\v 16 Ariũ a Jehaleleli maarĩ:
\li2 Zifu, na Zifa, na Tiria, na Asareli.
\li1 
\v 17 Ariũ a Ezara maarĩ:
\li2 Jetheru, na Meredi, na Eferi, na Jaloni. Mũtumia ũmwe wa Meredi nĩwe waciarire Miriamu, na Shamai, na Ishiba ũrĩa warĩ ithe wa Eshitemoa.
\v 18 (Mũtumia wake wa kuuma Judea agĩciara Jeredi ũrĩa ithe wa Gedori, na Heberi ithe wa Soko, na Jekuthieli ithe wa Zanoa.) Acio nĩo maarĩ ciana cia Bithia mwarĩ wa Firaũni ũrĩa wahikĩtio nĩ Meredi.
\li1 
\v 19 Ariũ a mũtumia wa Hodia (mwarĩ wa nyina na Nahamu) maarĩ:
\li2 Ithe wa Keila ũrĩa Mũgarimi, na Eshitemoa ũrĩa Mũmaakathi.
\li1 
\v 20 Ariũ a Shimoni maarĩ:
\li2 Amunoni, na Rina, na Beni-Hanani, na Tiloni.
\li1 Njiaro cia Ishi nĩ:
\li2 Zohethu na Beni-Zohethu.
\li1 
\v 21 Nao ariũ a Shela mũrũ wa Juda maarĩ:
\li2 Eri ithe wa Leka, na Laada ithe wa Maresha, na mbarĩ cia arĩa maathondekaga gatani ĩrĩa njega\f + \fr 4:21 \ft Andũ a nyũmba ĩmwe nĩmamenyekaga na wĩra ũrĩa warutagwo nĩ ithe wao.\f* kũu Bethi-Ashibea,
\v 22 na Jokimu, na andũ a Kozeba, na Joashu na Sarafi arĩa maathanaga bũrũri wa Moabi, na Jashubi-Lehemu. (Ũhoro ũyũ ũrutĩtwo maandĩko-inĩ ma tene mũno.)
\v 23 Acio nĩo moombaga indo cia rĩũmba, nao maatũũraga Netaimu na Gedera; maikaraga kũu, marutagĩre mũthamaki wĩra.
\s3 Njiaro cia Simeoni
\li1 
\v 24 Njiaro cia Simeoni nĩ:
\li2 Nemueli, na Jamini, na Jaribu, na Zera, na Shauli;
\li2 
\v 25 Shalumu aarĩ mũriũ wa Shauli, nake Mibisamu aarĩ mũriũ wa Shalumu, nake Mishima aarĩ mũriũ wa Mibisamu.
\li1 
\v 26 Njiaro cia Mishima ciarĩ:
\li2 Mũriũ Hamueli, na Zakuri mũriũ wa Hamueli, na Shimei mũriũ wa Zakuri.
\p 
\v 27 Shimei aarĩ na ariũ ikũmi na atandatũ na airĩtu atandatũ, no ariũ a nyina matiarĩ na ciana nyingĩ; nĩ ũndũ ũcio mbarĩ yao ndĩongererekire ta ya andũ a Juda.
\v 28 Nao maatũũraga Birishiba, na Molada, na Hazari-Shuali,
\v 29 na Biliha, na Ezemu, na Toladi,
\v 30 na Bethueli, na Horoma, na Zikilagi,
\v 31 na Bethi-Marikabothu, na Hazari-Susimu, na Bethi-Biri, na Shaaraimu. Macio nĩmo maarĩ matũũra mao nginya rĩrĩa Daudi aathamakaga.
\v 32 Matũũra matano marĩa maamarigiicĩirie maarĩ: Etamu, na Aini, na Rimoni, na Tokenina Ashani,
\v 33 na tũtũũra tũnini tũrĩa twarigiicĩirie matũũra macio o nginya Baalathu. Macio nĩmo maarĩ ũtũũro wao. Nao nĩmaigaga maandĩko ma njiarwa.
\b
\li2 
\v 34 Meshobabu, na Jamuleki, na Josha mũrũ wa Amazia,
\v 35 na Joeli; na Jehu mũrũ wa Joshibia, mũrũ wa Seraia, mũrũ wa Asieli;
\v 36 o na Elioenai, na Jaakoba, na Jeshohaia, na Asaia, na Adieli, na Jesimieli, na Benaia;
\v 37 na Ziza mũrũ wa Shifi, mũrũ wa Aloni, mũrũ wa Jedaia, mũrũ wa Shimuri, mũrũ wa Shemaia.
\b
\p 
\v 38 Andũ acio marĩĩtwa mao magwetetwo hau igũrũ nĩo maarĩ atongoria a mbarĩ ciao. Nyũmba ciao nĩciongererekire mũno,
\v 39 nao magĩthiĩ mĩhaka-inĩ ya Gedori mwena wa irathĩro wa gĩtuamba kĩu gũcaria ũrĩithio wa mahiũ mao.
\v 40 Nĩmoonire kũndũ kũnoru kũrĩ ũrĩithio mwega, bũrũri warĩ mwariĩ, ũrĩ na thayũ na ũkahoorera. Na rĩrĩ, andũ a Hamu\f + \fr 4:40 \ft Andũ a Kaanani maarĩ njiaro cia Hamu.\f* amwe nĩo maatũũraga kuo mbere.
\p 
\v 41 Andũ arĩa marĩĩtwa mao maandĩkĩtwo mookĩte kuo matukũ-inĩ ma Hezekia mũthamaki wa Juda. Nao magĩtharĩkĩra andũ a Hamu ciikaro-inĩ cia andũ acio o na cia Ameunimu arĩa maatũũraga kuo, na makĩmaniina biũ o ta ũrĩa gũtariĩ nginya ũmũthĩ. Nao magĩtũũra ciikaro-inĩ cia andũ acio tondũ kwarĩ na ũrĩithio mwega wa mahiũ mao.
\v 42 Nao andũ magana matano a nyũmba ya Simeoni, matongoretio nĩ Pelatia, na Nearia, na Refaia na Uzieli, ariũ a Ishi, magĩtharĩkĩra bũrũri ũrĩa ũrĩ irĩma wa Seiru.
\v 43 Nao makĩũraga Aamaleki arĩa meetharĩte magatigara, nao matũire kuo nginya ũmũthĩ.
\c 5
\s2 Njiaro cia Rubeni
\p 
\v 1 Ariũ a Rubeni ũrĩa irigithathi rĩa Isiraeli (nĩwe warĩ irigithathi, no rĩrĩa aathaahirie ũrĩrĩ wa ithe, ũrigithathi wake waheirwo ariũ a Jusufu mũrũ wa Isiraeli; nĩ ũndũ ũcio, ndangĩandĩkirwo maandĩko-inĩ ma njiarwa kũringana na ũrigithathi wake,
\v 2 o na gũtuĩka Juda nĩwe warĩ hinya gũkĩra ariũ a ithe, na mũtongoria oimĩte gwake-rĩ, ũrigithathi watuĩkire wa Jusufu);
\v 3 ariũ a Rubeni, irigithathi rĩa Isiraeli, maarĩ:
\li1 Hanoku, na Palu, na Hezironi, na Karimi.
\li1 
\v 4 Njiaro cia Joeli ciarĩ:
\li2 Mũriũ Shemaia, na mũriũ Gogu, na mũriũ Shimei,
\v 5 na mũriũ Mika,
\li2 na mũriũ Reaia, na mũriũ Baali,
\li2 
\v 6 na mũriũ Beera, ũrĩa watahirwo agĩthaamio nĩ Tigilathu-Pileseru mũthamaki wa Ashuri. Beera nĩwe warĩ mũtongoria wa andũ a Rubeni.
\li2 
\v 7 Andũ ao kũringana na mbarĩ ciao, mandĩkĩtwo kũringana na maandĩko ma njiarwa ciao maarĩ aya:
\li2 Jeieli ũrĩa mũnene, na Zekaria,
\v 8 na Bela mũrũ wa Azazi, mũrũ wa Shema, mũrũ wa Joeli. Maatũũraga rũgongo rũrĩa ruumĩte Aroeri nginya Nebo na Baali-Meoni.
\v 9 Maikarire bũrũri mwena wa irathĩro nginya rũteere-inĩ rwa werũ ũrĩa ũtambũrũkĩte nginya Rũũĩ rwa Farati, tondũ mahiũ mao nĩmaingĩhire mũno marĩ kũu Gileadi.
\li2 
\v 10 Hĩndĩ ya wathani wa Saũlũ nĩmarũire na Ahagari,\f + \fr 5:10 \ft Ahagari maarĩ njiaro cia Ishumaeli mũrũ wa Hagari, na Aarabu nĩ a rũciaro rwao.\f* na makĩmahoota; nao makĩĩnyiitĩra ciikaro cia Ahagari acio rũgongo-inĩ ruothe rwa mwena wa irathĩro wa Gileadi.
\s2 Njiaro cia Gadi
\li1 
\v 11 Nao andũ a Gadi maatũũire mariganĩtie na andũ a Rubeni kũu bũrũri wa Bashani,\f + \fr 5:11 \ft Bashani warĩ bũrũri wa irĩma wa mwena wa irathĩro rĩa Iria rĩa Galili.\f* o nginya Saleka:
\li2 
\v 12 Joeli nĩwe warĩ mũnene kũu Bashani, mũnini wake aarĩ Shafamu, akarũmĩrĩrwo nĩ Janai, na Shafati.
\li1 
\v 13 Andũ ao kũringana na nyũmba ciao maarĩ:
\li2 Mikaeli, na Meshulamu, na Sheba, na Jorai, na Jakani, na Zia, na Eberi, othe maarĩ andũ mũgwanja.
\li2 
\v 14 Acio nĩo maarĩ ariũ a Abihaili mũrũ wa Huru, mũrũ wa Jaroa, mũrũ wa Gileadi, mũrũ wa Mikaeli, mũrũ wa Jeshishai, mũrũ wa Jahido, mũrũ wa Buzi.
\li2 
\v 15 Ahi mũrũ wa Abidieli, mũrũ wa Guni nĩwe warĩ mũtongoria wa nyũmba yao.
\li1 
\v 16 Nao andũ a Gadi maatũũraga Gileadi, kũu Bashani na matũũra-inĩ marĩa maakuhĩrĩirie kuo, o na kũrĩa guothe ũrĩithio wa Sharoni wakinyĩte.
\p 
\v 17 Ũhoro ũyũ wothe nĩ wandĩkirwo maandĩko-inĩ ma njiarwa ciao hĩndĩ ĩrĩa Jothamu mũthamaki wa Juda na Jeroboamu mũthamaki wa Isiraeli maathamakaga.
\b
\p 
\v 18 Andũ a Rubeni, na a Gadi, na nuthu ya mũhĩrĩga wa Manase, maarĩ na andũ 44,760 mehaarĩirie gũthiĩ mbaara-inĩ: andũ marĩ na hinya wa mwĩrĩ, na mangĩahotire kũhũthĩra ngo, na rũhiũ rwa njora, na mooĩ gũikia mĩguĩ na ũta, na maarutĩtwo kũrũa mbaara.
\v 19 Nao makĩhithũkĩra Ahagari, na Ajeturi, na Anafishi, na Anodabu.
\v 20 Nĩmateithirio kũmahũũra, nake Ngai akĩneana Ahagari moko-inĩ mao, marĩ hamwe na arĩa othe maamateithagia, tondũ nĩmamũkaĩire marĩ mbaara-inĩ. Nĩamacookeirie mahooya mao, nĩ ũndũ nĩmamwĩhokete.
\v 21 Magĩtaha mahiũ ma Ahagari acio: ngamĩĩra 50,000, na ngʼondu 250,000, na ndigiri 2,000, ningĩ nĩmatahire andũ 100,000,
\v 22 na angĩ aingĩ makĩũragwo, tondũ Ngai nĩwe wamarũagĩrĩra. Nao magĩikara bũrũri ũcio o nginya hĩndĩ ĩrĩa maatahirwo rĩngĩ.
\s2 Nuthu ya Mũhĩrĩga wa Manase
\p 
\v 23 Andũ a nuthu ya mũhĩrĩga wa Manase maarĩ aingĩ mũno; maatũũrire bũrũri ũcio kuuma Bashani nginya Baali-Herimoni, ũguo nĩ kuuga nginya Seniru (nĩkĩo Kĩrĩma kĩa Herimoni).
\p 
\v 24 Aya nĩo maarĩ atongoria a nyũmba ciao: Eferi, na Ishi, na Elieli, na Azirieli, na Jeremia, na Hodavia, na Jahadieli. Maarĩ atongoria a nyũmba ciao, na njamba cia ita, na andũ marĩ igweta.
\v 25 No matiarĩ ehokeku harĩ Ngai wa maithe mao, tondũ nĩmeheanĩte kũrĩ ngai cia andũ a bũrũri ũcio, arĩa Ngai aaniinĩte mehere mbere yao.
\v 26 Nĩ ũndũ ũcio Ngai wa Isiraeli akĩarahũra roho wa Puli mũthamaki wa Ashuri (ũguo nĩ kuuga Tigilathu-Pileseru, mũthamaki wa Ashuri), ũrĩa watahire andũ a Rubeni, na andũ a Gadi, na nuthu ya mũhĩrĩga wa Manase, akĩmatwara ithaamĩrio. Akĩmathaamĩria Hala, na Habori, na Hara, na rũũĩ-inĩ rwa Gozani, kũrĩa matũire nginya ũmũthĩ.
\c 6
\s2 Njiaro cia Lawi
\p 
\v 1 Ariũ a Lawi maarĩ:
\li2 Gerishoni, na Kohathu, na Merari.
\li1 
\v 2 Ariũ a Kohathu maarĩ:
\li2 Amuramu, na Iziharu, na Hebironi, na Uzieli.
\li1 
\v 3 Ciana cia Amuramu ciarĩ:
\li2 Harũni, na Musa, na Miriamu.
\li1 Ariũ a Harũni maarĩ:
\li2 Nadabu, na Abihu, na Eleazaru, na Ithamaru.
\li2 
\v 4 Eleazaru nĩwe warĩ ithe wa Finehasi,
\li2 na Finehasi nĩwe warĩ ithe wa Abishua,
\li2 
\v 5 na Abishua nĩwe warĩ ithe wa Buki,
\li2 na Buki nĩwe warĩ ithe wa Uzi,
\li2 
\v 6 na Uzi nĩwe warĩ ithe wa Zerahia,
\li2 na Zerahia nĩwe warĩ ithe wa Meraiothu,
\li2 
\v 7 na Meraiothu nĩwe warĩ ithe wa Amaria,
\li2 na Amaria nĩwe warĩ ithe wa Ahitubu,
\li2 
\v 8 na Ahitubu nĩwe warĩ ithe wa Zadoku,
\li2 na Zadoku nĩwe warĩ ithe wa Ahimaazu,
\li2 
\v 9 na Ahimaazu nĩwe warĩ ithe wa Azaria,
\li2 na Azaria nĩwe warĩ ithe wa Johanani,
\li2 
\v 10 na Johanani nĩwe warĩ ithe wa Azaria (ũrĩa watungataga arĩ mũthĩnjĩri-Ngai thĩinĩ wa hekarũ ĩrĩa Solomoni aakire kũu Jerusalemu),
\li2 
\v 11 na Azaria nĩwe warĩ ithe wa Amaria,
\li2 na Amaria nĩwe warĩ ithe wa Ahitubu,
\li2 
\v 12 na Ahitubu nĩwe warĩ ithe wa Zadoku,
\li2 na Zadoku nĩwe warĩ ithe wa Shalumu,
\li2 
\v 13 na Shalumu nĩwe warĩ ithe wa Hilikia,
\li2 na Hilikia nĩwe warĩ ithe wa Azaria,
\li2 
\v 14 na Azaria nĩwe warĩ ithe wa Seraia,
\li2 na Seraia nĩwe warĩ ithe wa Jehozadaku.
\li4 
\v 15 Jehozadaku nĩathaamirio hĩndĩ ĩrĩa Jehova aarekereirie andũ a Juda na a Jerusalemu matahwo nĩ Nebukadinezaru.
\b
\li1 
\v 16 Ariũ a Lawi maarĩ:
\li2 Gerishoni, na Kohathu, na Merari.
\li1 
\v 17 Maya nĩmo marĩĩtwa ma ariũ a Gerishoni:
\li2 Libini na Shimei.
\li1 
\v 18 Ariũ a Kohathu maarĩ:
\li2 Amuramu, na Iziharu, na Hebironi, na Uzieli.
\li1 
\v 19 Ariũ a Merari maarĩ:
\li2 Mahili na Mushi.
\li1 Icio nĩcio mbarĩ cia Alawii ciandĩkĩtwo kũringana na maithe mao:
\li1 
\v 20 Ariũ a Gerishoni maarĩ:
\li2 mũriũ Libini, nake Jehathu aarĩ mũriũ wa Libini,
\li2 nake Zima aarĩ mũriũ wa Jehathu,
\v 21 nake Joa aarĩ mũriũ wa Zima,
\li2 nake Ido aarĩ mũriũ wa Joa, nake Zera aarĩ mũriũ wa Ido,
\li2 nake Jeatherai aarĩ mũriũ wa Zera.
\li1 
\v 22 Njiaro cia Kohathu ciarĩ:
\li2 mũriũ Aminadabu, nake Kora aarĩ mũriũ wa Aminadabu,
\li2 nake Asiru aarĩ mũriũ wa Kora,
\v 23 nake Elikana aarĩ mũriũ wa Asiru,
\li2 nake Ebiasafu aarĩ mũriũ wa Elikana, nake Asiru aarĩ mũriũ wa Ebiasafu,
\li2 
\v 24 nake Tahathu aarĩ mũriũ wa Asiru, nake Urieli aarĩ mũriũ wa Tahathu,
\li2 nake Uzia aarĩ mũriũ wa Urieli, nake Shauli aarĩ mũriũ wa Uzia.
\li1 
\v 25 Njiaro cia Elikana ciarĩ:
\li2 Amasai na Ahimothu,
\li2 
\v 26 nake mũriũ aarĩ Elikana, nake Zofai aarĩ mũriũ wa Elikana,
\li2 nake Nahathu aarĩ mũriũ wa Zofai,
\v 27 nake Eliabu aarĩ mũriũ wa Nahathu,
\li2 nake Jerohamu aarĩ mũriũ wa Eliabu, nake Elikana aarĩ mũriũ wa Jerohamu,
\li2 nake Samũeli aarĩ mũriũ wa Elikana.
\p 
\v 28 Ariũ a Samũeli maarĩ:
\li2 Joeli irigithathi,
\li2 na mũriũ wa keerĩ aarĩ Abija.
\li1 
\v 29 Njiaro cia Merari ciarĩ:
\li2 Mahili, nake mũriũ aarĩ Libini,
\li2 nake Shimei aarĩ mũriũ wa Libini, nake Uza aarĩ mũriũ wa Shimei,
\li1 
\v 30 nake Shimea aarĩ mũriũ wa Uza, nake Hagia aarĩ mũriũ wa Shimea,
\li2 nake Asaia aarĩ mũriũ wa Hagia.
\s1 Aini a Hekarũ
\p 
\v 31 Aya nĩo andũ arĩa Daudi aatuire arũgamĩrĩri a ũini nyũmba-inĩ ya Jehova thuutha wa ithandũkũ rĩa kĩrĩkanĩro gũkinya kũu.
\v 32 Maatungataga na ũini Hema-inĩ-ya-Gũtũnganwo o nginya rĩrĩa Solomoni aakire hekarũ ya Jehova kũu Jerusalemu. Nao maarutaga wĩra wao kũringana na mawatho marĩa maatuĩtwo.
\p 
\v 33 Aya nĩo andũ arĩa maarutaga wĩra, hamwe na ariũ ao:
\li1 Kuuma kũrĩ Akohathu maarĩ:
\li2 Hemani ũrĩa mũini,
\li2 mũrũ wa Joeli, mũrũ wa Samũeli,
\li2 
\v 34 mũrũ wa Elikana, mũrũ wa Jerohamu,
\li2 mũrũ wa Elieli, mũrũ wa Toa,
\li2 
\v 35 mũrũ wa Zufu, mũrũ wa Elikana,
\li2 mũrũ wa Mahathu mũrũ wa Amasai,
\li2 
\v 36 mũrũ wa Elikana, mũrũ wa Joeli,
\li2 mũrũ wa Azaria, mũrũ wa Zefania,
\li2 
\v 37 mũrũ wa Tahathu, mũrũ wa Asiru,
\li2 mũrũ wa Ebiasafu, mũrũ wa Kora,
\li2 
\v 38 mũrũ wa Iziharu, mũrũ wa Kohathu,
\li2 mũrũ wa Lawi, mũrũ wa Isiraeli;
\li1 
\v 39 na Asafu, mũthiritũ wa Hemani, ũrĩa watungataga mwena wake wa ũrĩo: Asafu aarĩ mũrũ wa Berekia, mũrũ wa Shimea,
\li2 
\v 40 mũrũ wa Mikaeli, mũrũ wa Baaseia,
\li2 mũrũ wa Malikija
\v 41 mũrũ wa Ethini,
\li2 mũrũ wa Zera, mũrũ wa Adaia,
\li2 
\v 42 mũrũ wa Ethani, mũrũ wa Zima,
\li2 mũrũ wa Shimei,
\v 43 mũrũ wa Jahathu,
\li2 mũrũ wa Gerishoni, mũrũ wa Lawi;
\li1 
\v 44 na kuuma kũrĩ athiritũ ao, Amerari, arĩa maatungataga marĩ mwena wake wa ũmotho, maarĩ:
\li2 Ethani mũrũ wa Kishi, mũrũ wa Abudi,
\li2 mũrũ wa Maluku,
\v 45 mũrũ wa Hashabia,
\li2 mũrũ wa Amazia, mũrũ wa Hilikia,
\li1 
\v 46 mũrũ wa Amuzi, mũrũ wa Bani,
\li2 mũrũ wa Shemeri,
\v 47 mũrũ wa Mahali,
\li2 mũrũ wa Mushi, mũrũ wa Merari,
\li2 mũrũ wa Lawi.
\b
\p 
\v 48 Alawii arĩa maarĩ a thiritũ yao maagaĩirwo mawĩra marĩa mangĩ mothe ma hema ĩrĩa nyamũre, o ĩyo nyũmba ya Ngai.
\v 49 No Harũni na njiaro ciake nĩo maarutaga magongona kĩgongona-inĩ kĩa igongona rĩa njino, na kĩgongona-inĩ gĩa gũcinĩrwo ũbumba, na wĩra wothe warutagwo ũkonainie na Handũ-hau-Hatheru-Mũno, nĩ ũndũ wa kũhoroheria andũ a Isiraeli mehia, kũringana na ũrĩa Musa ndungata ya Ngai yaathanĩte.
\b
\li1 
\v 50 Ici nĩcio njiaro cia Harũni:
\li2 Mũriũ aarĩ Eliazaru, nake mũriũ wake aarĩ Finehasi,
\li2 nake Abishua aarĩ mũriũ wa Finehasi,
\v 51 nake Buki aarĩ mũriũ wa Abishua,
\li2 nake Uzi aarĩ mũriũ wa Buki, nake Zerahia aarĩ mũriũ wa Uzi,
\li2 
\v 52 nake Meraiothu aarĩ mũriũ wa Zerahia, nake Amaria aarĩ mũriũ wa Meraiothu,
\li2 nake Ahitubu aarĩ mũriũ wa Amaria,
\v 53 nake Zadoku aarĩ mũriũ wa Ahitubu,
\li2 nake Ahimaazu aarĩ mũriũ wa Zadoku.
\b
\p 
\v 54 Na rĩrĩ, gũkũ nĩkuo kũndũ kũrĩa maagaĩirwo kũrĩ bũrũri wao (nakuo kwagaĩirwo njiaro cia Harũni iria ciarĩ cia mbarĩ ya Kohathu, tondũ igai rĩa mbere rĩarĩ rĩao):
\pi1 
\v 55 Maaheirwo Hebironi kũu Juda, o hamwe na ũrĩithio ũrĩa warigiicĩirie.
\v 56 No mĩgũnda na matũũra marĩa maakuhĩrĩirie itũũra inene maaheirwo Kalebu mũrũ wa Jefune.
\pi1 
\v 57 Nĩ ũndũ ũcio njiaro cia Harũni ciaheirwo Hebironi (itũũra inene rĩa kũũrĩra) na Libina, na Jatiri, na Eshitemoa,
\v 58 na Hileni, na Debiri,
\v 59 na Ashani, na Juta, na Bethi-Shemeshu, hamwe na ũrĩithio wamo.
\v 60 Na kuuma mũhĩrĩga wa Benjamini maaheirwo Gibeoni, na Geba, na Alemethu, na Anathothu, hamwe na ũrĩithio wamo.
\pi1 Matũũra marĩa maagaĩirwo mĩhĩrĩga ya Akohathu mothe maarĩ ikũmi na matatũ.
\p 
\v 61 Njiaro icio ingĩ cia Kohathu ciaheirwo matũũra ikũmi, kuuma kũrĩ nuthu ya mũhĩrĩga wa Manase.
\p 
\v 62 Njiaro cia Gerishoni, mbarĩ o mbarĩ ciagaĩirwo matũũra ikũmi na matatũ kuuma kũrĩ mũhĩrĩga wa Isakaru, na wa Asheri, na wa Nafitali, na kuuma kũrĩ gĩcunjĩ kĩa mũhĩrĩga wa Manase ũrĩa ũrĩ Bashani.
\p 
\v 63 Njiaro cia Merari, mbarĩ o mbarĩ, ciagaĩirwo matũũra ikũmi na meerĩ kuuma kũrĩ mũhĩrĩga wa Rubeni, na wa Gadi, na wa Zebuluni.
\p 
\v 64 Nĩ ũndũ ũcio andũ a Isiraeli makĩhe Alawii matũũra macio na ũrĩithio wamo.
\v 65 Kuuma mũhĩrĩga wa Juda, na wa Simeoni, na wa Benjamini makĩmahe matũũra macio magwetetwo.
\p 
\v 66 Mbarĩ imwe cia Akohathu ciaheirwo matũũra nĩ mũhĩrĩga wa Efiraimu matuĩke bũrũri wao.
\pi1 
\v 67 Kuuma bũrũri ũrĩa ũrĩ irĩma wa Efiraimu maaheirwo Shekemu (itũũra rĩa kũũrĩra), na Gezeri,
\v 68 na Jokimeamu, na Bethi-Horoni,
\v 69 na Aijaloni, na Gathi-Rimoni, hamwe na ũrĩithio wamo.
\pi1 
\v 70 Na kuuma nuthu ya mũhĩrĩga wa Manase-rĩ, andũ a Isiraeli makĩheana matũũra ma Aneri na Bileamu, hamwe na ũrĩithio wamo, kũrĩ mbarĩ iria ingĩ cia Akohathu.
\b
\li1 
\v 71 Agerishoni maagaĩirwo matũũra maya:
\li1 Kuuma nuthu ya mũhĩrĩga wa Manase makĩheo Golani kũu Bashani, o na Ashitarothu, hamwe na ũrĩithio wamo;
\li1 
\v 72 Kuuma mũhĩrĩga wa Isakaru
\li2 makĩheo Kadeshi, na Daberathu,
\v 73 na Ramothu, na Anemu, hamwe na ũrĩithio wamo;
\li1 
\v 74 Kuuma mũhĩrĩga wa Asheri
\li2 makĩheo Mashali, na Abidoni,
\v 75 na Hukoku, na Rehobu, hamwe na ũrĩithio wamo;
\li1 
\v 76 Na kuuma mũhĩrĩga wa Nafitali
\li2 makĩheo Kedeshi kũu Galili, na Hamoni, na Kiriathaimu, hamwe na ũrĩithio wamo.
\b
\li4 
\v 77 Amerari (Alawii arĩa angĩ) maagaĩirwo matũũra maya:
\li1 Kuuma mũhĩrĩga wa Zebuluni
\li2 makĩheo Jokineamu, na Karita, na Rimono, na Taboru, hamwe na ũrĩithio wamo;
\li1 
\v 78 kuuma mũhĩrĩga wa Rubeni mũrĩmo wa Jorodani mwena wa irathĩro wa Jeriko,
\li2 makĩheo Bezeri werũ-inĩ, na Jahaza,
\v 79 na Kedemothu, na Mefaathu, hamwe na ũrĩithio wamo;
\li1 
\v 80 na kuuma mũhĩrĩga wa Gadi
\li2 makĩheo Ramothu o kũu Gileadi, na Mahanaimu,
\v 81 na Heshiboni, na Jazeri, hamwe na ũrĩithio wamo.
\c 7
\s2 Njiaro cia Isakaru
\li1 
\v 1 Ariũ a Isakaru maarĩ:
\li2 Tola, na Pua, na Jashubu, na Shimuroni; othe maarĩ ana.
\li1 
\v 2 Ariũ a Tola maarĩ:
\li2 Uzi, na Refaia, na Jerieli, na Jahamai, na Ibisamu, na Shemueli; nao maarĩ atongoria a nyũmba ciao. Hĩndĩ ya wathani wa Daudi, njiaro cia Tola iria ciaandĩkĩtwo maandĩko-inĩ ma njiarwa ciao marĩ andũ a kũrũa mbaara maarĩ 22,600.
\li1 
\v 3 Mũriũ wa Uzi aarĩ:
\li2 Izirahia.
\li1 Ariũ a Izirahia maarĩ:
\li2 Mikaeli, na Obadia, na Joeli, na Ishia. Othe atano maarĩ anene a andũ ao.
\v 4 Kũringana na maandĩko ma njiarwa cia nyũmba ciao, maarĩ na arũme mehaarĩirie kũrũa mbaara 36,000, nĩgũkorwo maarĩ na atumia aingĩ na ciana nyingĩ.
\li1 
\v 5 Andũ ao arĩa maangĩarũire mbaara kuuma mĩhĩrĩga-inĩ yothe ya Isakaru, kũringana na maandĩko ma njiarwa ciao, maarĩ 87,000 marĩ othe.
\s2 Njiaro cia Benjamini
\li1 
\v 6 Ariũ atatũ a Benjamini maarĩ:
\li2 Bela, na Bekeri, na Jediaeli.
\li1 
\v 7 Ariũ a Bela maarĩ:
\li2 Eziboni, na Uzi, na Uzieli, na Jerimothu, na Iri; othe maarĩ atano, na maarĩ atongoria a nyũmba ciao. Maandĩko ma njiarwa ciao moonanagia arũme a kũrũa mbaara maarĩ 22,034.
\li1 
\v 8 Ariũ a Bekeri maarĩ:
\li2 Zemira, na Joashu, na Eliezeri, na Elioenai, na Omuri, na Jeremothu, na Abija, na Anathothu, na Alemethu. Acio othe maarĩ ariũ a Bekeri.
\v 9 Maandĩko ma njiarwa ciao moonanagia atongoria a nyũmba, na arũme a kũrũa mbaara 20,200.
\li1 
\v 10 Mũriũ wa Jediaeli aarĩ:
\li2 Bilihani.
\li1 Ariũ a Bilihani maarĩ:
\li2 Jeushu, na Benjamini, na Ehudu, na Kenaana, na Zethani, na Tarishishi, na Ahishaharu.
\v 11 Ariũ acio othe a Jediaeli maarĩ atongoria a nyũmba ciao. Nĩ kwarĩ na arũme 17,200 a kũrũa mehaarĩirie gũthiĩ mbaara-inĩ.
\li1 
\v 12 Nao andũ a Shupimu na a Hupimu maarĩ a rũciaro rwa Iru, nao Ahushimu maarĩ a rũciaro rwa Aheri.
\s2 Njiaro cia Nafitali
\li1 
\v 13 Ariũ a Nafitali maarĩ:
\li2 Jahazieli, na Guni, na Jezeri, na Shalumu; aya maarĩ a rũciaro rwa Biliha.
\s2 Njiaro cia Manase
\li1 
\v 14 Njiaro cia Manase ciarĩ:
\pi2 Asirieli, ũrĩa aaciarĩirwo nĩ thuriya yake ĩrĩa yarĩ Mũaramiti. Ningĩ thuriya ĩyo ĩkĩmũciarĩra Makiru, ũrĩa warĩ ithe wa Gileadi.
\v 15 Makiru aahikanirie kuuma kwa Ahupimu na Ashupimu. Mwarĩ wa nyina eetagwo Maaka.
\pi2 Ũrĩa ũngĩ wa rũciaro rwake eetagwo Zelofehadi, nake aaciarĩte o airĩtu.
\pi2 
\v 16 Mũtumia wa Makiru, Maaka nĩaciarire mwanake na akĩmũtua Pereshu. Mũrũ wa nyina na Pereshu eetagwo Shereshu, na ariũ a Shereshu maarĩ Ulamu na Rakemu.
\li1 
\v 17 Mũriũ wa Ulamu eetagwo:
\li2 Bedani.
\li2 Acio nĩo maarĩ ariũ a Gileadi mũrũ wa Makiru, mũrũ wa Manase.
\v 18 Mwarĩ wa nyina Hamolekethu nĩaciarire Ishihodi, na Abiezeri, na Mahala.
\li2 
\v 19 Ariũ a Shemida maarĩ:
\li2 Ahiani, na Shekemu, na Liki, na Aniamu.
\s2 Njiaro cia Efiraimu
\li1 
\v 20 Njiaro cia Efiraimu ciarĩ:
\li2 Shuthela na mũriũ Beredi,
\li2 na Tahathu mũriũ wa Beredi, na Eleada mũriũ wa Tahathu,
\li2 na Tahathu mũriũ wa Eleada, na mũriũ Zabadi,
\li2 na Shuthela mũriũ wa Zabadi,
\v 21 na Zabadi aarĩ mũriũ wa Tahathu,
\li2 nake Shuthela aarĩ mũriũ wa Zabadi.
\pi2 Ezeri na Eleadi mooragirwo nĩ andũ arĩa maaciarĩirwo Gathi hĩndĩ ĩrĩa maathiĩte gũtaha mahiũ mao.
\v 22 Ithe wao Efiraimu nĩamacakaĩire mĩthenya mĩingĩ, nao andũ ao magĩũka kũmũhooreria.
\v 23 Ningĩ agĩkoma na mũtumia wake rĩngĩ, nake akĩgĩa nda agĩciara kahĩĩ. Nake agĩgatua Beria, tondũ nĩ gwakoretwo na mũtino thĩinĩ wa nyũmba yake.
\v 24 Mwarĩ wa Efiraimu eetagwo Sheera, ũrĩa waakire Bethi-Horoni ya kĩanda na ya rũgongo, na agĩaka Uzeni-Sheera.
\li1 
\v 25 Refa aarĩ mũriũ wa Efiraimu, na mũriũ eetagwo Resefu,
\li2 na Tela mũriũ wa Resefu, na Tahani mũriũ wa Tela,
\li1 
\v 26 na Ladani mũriũ wa Tahani, na Amihudu mũriũ wa Ladani,
\li2 na Elishama mũriũ wa Amihudu,
\v 27 na Nuni mũriũ wa Elishama,
\li2 na Joshua mũriũ wa Nuni.
\p 
\v 28 Ithaka na ciikaro ciao ciarĩ Betheli, na matũũra marĩa maakũrigiicĩirie, na nĩ Naara mwena wa irathĩro, na Gezeri na matũũra makuo ma mwena wa ithũĩro, na Shekemu na matũũra makuo, nginya Gaza na matũũra makuo.
\v 29 Kũrigania na mĩhaka ya Manase maarĩ na Bathi-Shani, na Taanaka, na Megido, na Dori, hamwe na matũũra makuo. Njiaro cia Jusufu mũrũ wa Isiraeli nĩcio ciaikaraga matũũra macio.
\s1 Njiaro cia Asheri
\li1 
\v 30 Ariũ a Asheri maarĩ:
\li2 Imuna, na Ishiva, na Ishivi, na Beria. Mwarĩ wa nyina wao eetagwo Sera.
\li1 
\v 31 Ariũ a Beria maarĩ:
\li2 Heberi na Malikieli ũrĩa warĩ ithe wa Birizaithu.
\li1 
\v 32 Heberi nĩwe warĩ ithe wa Jefileti, na Shomeri, na Hothamu, na mwarĩ wa nyina wao eetagwo Shua.
\li1 
\v 33 Ariũ a Jafileti maarĩ:
\li2 Pasaka, na Bimihali, na Ashavathu. Acio maarĩ ariũ a Jefileti.
\li1 
\v 34 Ariũ a Shomeri maarĩ:
\li2 Ahi, na Rohaga, na Jehuba, na Aramu.
\li1 
\v 35 Ariũ a mũrũ wa nyina na Helemu maarĩ:
\li2 Zofa, na Imuna, na Sheleshu, na Amali.
\li1 
\v 36 Ariũ a Zofa maarĩ:
\li2 Sua, na Harineferi, na Shuali, na Beri, na Imura,
\v 37 na Bezeri, na Hodi, na Shama, na Shilisha, na Ithirani, na Beera.
\li1 
\v 38 Ariũ a Jetheri maarĩ:
\li2 Jefune, na Pisipa, na Ara.
\li1 
\v 39 Ariũ a Ula maarĩ:
\li2 Ara, na Hanieli, na Rizia.
\p 
\v 40 Acio othe maarĩ njiaro cia Asheri; nĩo maarĩ atongoria a nyũmba ciao, na andũ athuure, na njamba cia ita, na atongoria arĩa maarĩ igweta. Mũigana wa andũ arĩa maangĩathiire mbaara kũringana na maandĩko ma njiarwa ciao maarĩ 26,000.
\c 8
\s1 Maandĩko ma Njiarwa cia Saũlũ ũrĩa Mũbenjamini
\li1 
\v 1 Benjamini nĩwe warĩ ithe wa Bela, mũriũ wake wa irigithathi;
\li2 Ashibeli aarĩ mũriũ wa keerĩ, nake Ahara wa gatatũ,
\li2 
\v 2 nake Noha wa kana, nake Rafa wa gatano.
\li1 
\v 3 Ariũ a Bela maarĩ:
\li2 Adari, na Gera, na Abihudi,
\v 4 na Abishua, na Naamani, na Ahoa,
\v 5 na Gera, na Shefufani, na Huramu.
\li1 
\v 6 Aya nĩo maarĩ njiaro cia Ehudu, arĩa maarĩ atongoria a nyũmba cia arĩa maatũũraga Geba, na nĩo maathaamĩirio Manahathu:
\li2 
\v 7 Naamani, na Ahija, na Gera ũrĩa wamathaamirie, na nĩwe warĩ ithe wa Uza na Ahihudu.
\li1 
\v 8 Shaharaimu nĩaciarĩirwo ciana kũu Moabi thuutha wa gũte atumia ake Hushimu na Baara.
\v 9 Mũtumia wake Hodeshu akĩmũciarĩra ciana ici: Jobabu, na Zibia, na Mesha, na Malikamu,
\v 10 na Jeuzu, na Shakia, na Mirima. Acio nĩo maarĩ ariũ ake, na maarĩ atongoria a nyũmba ciao.
\v 11 Mũtumia wake Hushimu akĩmũciarĩra Ahitubu na Elipaali.
\li1 
\v 12 Ariũ a Elipaali maarĩ:
\li2 Eberi, na Mishamu, na Shemedi (ũrĩa wakire Ono, o na Lodi na matũũra marĩa maakũrigiicĩirie),
\v 13 na Beria, na Shema arĩa maarĩ atongoria a nyũmba cia arĩa maatũũraga Aijaloni, na nĩo maingatire andũ arĩa maatũũraga Gathu.
\li1 
\v 14 Ahio, na Shashaka, na Jeremothu,
\v 15 na Zebadia, na Aradi, na Ederi,
\v 16 na Mikaeli, na Ishipa, na Joha maarĩ ariũ a Beria.
\li1 
\v 17 Zebadia, na Meshulamu, na Hiziki, na Heberi,
\v 18 na Ishimerai, na Izilia, na Jababu maarĩ ariũ a Elipaali.
\li1 
\v 19 Jakimu, na Zikiri, na Zabedi,
\v 20 na Elienai, na Zilethai, na Elieli,
\v 21 na Adaia, na Beraia, na Shimirathu maarĩ ariũ a Shimei.
\li1 
\v 22 Ishipani, na Eberi, na Elieli,
\v 23 na Abidoni, na Zikiri, na Hanani,
\v 24 na Hanania, na Elamu, na Anithothija,
\v 25 na Ifĩdeia, na Penueli maarĩ ariũ a Shashaka.
\li1 
\v 26 Shamusherai, na Sheharia, na Athalia,
\v 27 na Jaareshia, na Elija, na Zikiri maarĩ ariũ a Jerohamu.
\p 
\v 28 Aya othe maarĩ atongoria a nyũmba o na anene, ta ũrĩa maandĩkĩtwo maandĩko-inĩ ma njiarwa ciao, na maaikaraga Jerusalemu.
\b
\li1 
\v 29 Jeieli ithe wa Gibeoni aatũũraga Gibeoni.
\li2 Mũtumia wake eetagwo Maaka,
\v 30 na mũriũ wake wa irigithathi eetagwo Abidoni, akarũmĩrĩrwo nĩ Zuru, na Kishu, na Baali, na Neri, na Nadabu,
\v 31 na Gedori, na Ahio, na Zekeri,
\v 32 na Mikilothu ũrĩa warĩ ithe wa Shimea. O nao maaikaraga hakuhĩ na andũ ao kũu Jerusalemu.
\li1 
\v 33 Neri aarĩ ithe wa Kishu, nake Kishu aarĩ ithe wa Saũlũ. Saũlũ aarĩ ithe wa Jonathani
\li1 
\v 34 Mũriũ wa Jonathani:
\li2 eetagwo Meribu-Baali, na nĩwe warĩ ithe wa Mika.
\li1 
\v 35 Ariũ a Mika maarĩ:
\li2 Pithoni, na Meleku, na Tarea, na Ahazu.
\li1 
\v 36 Ahazu aarĩ ithe wa Jehoada, nake Jehoada aarĩ ithe wa Alemethu, na Azamavethu, na Zimuri; nake Zimuri aarĩ ithe wa Moza.
\v 37 Moza aarĩ ithe wa Binea; nake Rafa aarĩ mũriũ wa Binea, nake Eleasa aarĩ mũriũ wa Rafa, nake Azeli aarĩ mũriũ wa Eleasa.
\li1 
\v 38 Azeli aarĩ na ariũ atandatũ, na maya nĩmo marĩĩtwa mao:
\li2 Azirikamu, na Bokeru, na Ishumaeli, na Shearia, na Obadia, na Hanani. Acio nĩo maarĩ ariũ a Azeli.
\li1 
\v 39 Ariũ a Esheku, mũrũ wa nyina, maarĩ:
\li2 Ulamu irigithathi rĩake, na Jeushu wa keerĩ, na Elifeleti wa gatatũ.
\v 40 Ariũ a Ulamu maarĩ njamba cia ita, na nĩmamenyete gũtũmĩra ũta. Maarĩ na ariũ aingĩ o na ciana cia ciana ciao, na othe maarĩ 150.
\li1 Acio othe nĩo maarĩ njiaro cia Benjamini.
\b
\c 9
\p 
\v 1 Andũ a Isiraeli othe nĩmandĩkĩtwo maandĩko-inĩ ma njiarwa marĩa maarĩ mbuku-inĩ ya athamaki a Isiraeli.
\s1 Andũ arĩa maarĩ Jerusalemu
\p Andũ a Juda nĩmatahĩtwo magatwarwo Babuloni nĩ ũndũ wa kwaga kwĩhokeka.
\v 2 Na rĩrĩ, andũ arĩa maambire gũcooka gũikara mĩgũnda-inĩ yao o kũu matũũra-inĩ mao, maarĩ andũ amwe a Isiraeli, na athĩnjĩri-Ngai, na Alawii, na ndungata cia hekarũ.
\p 
\v 3 Andũ arĩa maatũũraga Jerusalemu kuuma Juda, na Benjamini, na Efiraimu, na Manase maarĩ:
\li1 
\v 4 Uthai mũrũ wa Amihudu, mũrũ wa Omuri, mũrũ wa Imuri, mũrũ wa Bani wa rũciaro rwa Perezu mũrũ wa Juda.
\li1 
\v 5 Andũ a Shiloni maarĩ:
\li2 Asaia ũrĩa warĩ irigithathi, na ariũ ake.
\li1 
\v 6 Kuuma Zera aarĩ:
\li2 Jeueli.
\li2 Andũ othe a kuuma Juda maarĩ 690.
\li1 
\v 7 Andũ a Benjamini maarĩ:
\li2 Salu mũrũ wa Meshulamu, mũrũ wa Hodavia, mũrũ wa Hasenua;
\v 8 na Ibineia mũrũ wa Jerohamu; Ela mũrũ wa Uzi, mũrũ wa Mikiri; na Meshulamu mũrũ wa Shefatia, mũrũ wa Reueli, mũrũ wa Ibinija.
\li2 
\v 9 Andũ a kuuma Benjamini, ta ũrĩa maandĩkĩtwo maandĩko-inĩ ma njiarwa ciao, maarĩ 956. Arũme acio othe maarĩ atongoria a nyũmba ciao.
\li1 
\v 10 Athĩnjĩri-Ngai maarĩ:
\li2 Jedaia, na Jehoiaribu, na Jakini;
\li2 
\v 11 na Azaria mũrũ wa Hilikia, mũrũ wa Meshulamu, mũrũ wa Zadoku, mũrũ wa Meraiothu, mũrũ wa Ahitubu ũrĩa warĩ mũmenyereri mũnene wa nyũmba ya Ngai;
\v 12 na Adaia mũrũ wa Jerohamu, mũrũ wa Pashuru, mũrũ wa Malikija; na Maasai mũrũ wa Adieli, mũrũ wa Jahazera, mũrũ wa Meshulamu, mũrũ wa Meshilemithu, mũrũ wa Imeri.
\li2 
\v 13 Athĩnjĩri-Ngai arĩa maarĩ atongoria a nyũmba ciao maarĩ 1,760. Maarĩ arũme maarĩ na ũhoti, na nĩ meehokeirwo gũtungata nyũmba-inĩ ya Ngai.
\li1 
\v 14 Alawii maarĩ:
\li2 Shemaia mũrũ wa Hashubu, mũrũ wa Azirikamu, mũrũ wa Hashabia ũrĩa Mũmerari,
\v 15 na Bakabakari, na Hereshi, na Galali, na Matania mũrũ wa Mika, mũrũ wa Zikiri, mũrũ wa Asafu;
\v 16 na Obadia mũrũ wa Shemaia, mũrũ wa Galali, mũrũ wa Jeduthuni; na Berekia mũrũ wa Asa, mũrũ wa Elikana, arĩa maaikaraga matũũra-inĩ ma Anetofathi.
\li1 
\v 17 Arangĩri a ihingo maarĩ:
\li2 Shalumu, na Akubu, na Talimoni, na Ahimani na ariũ a nyina, na Shalumu mũnene wao,
\v 18 acio maigĩtwo kĩhingo-inĩ kĩa mũthamaki mwena wa irathĩro, nginya ihinda-inĩ rĩu. Acio nĩo maarĩ arangĩri a ihingo a gĩkundi kĩa Alawii.
\v 19 Shalumu mũrũ wa Kore, mũrũ wa Ebiasafu, mũrũ wa Kora, na athiritũ ake arangĩri a ihingo kuuma nyũmba yake ya Akohathu. Acio nĩo meehokeirwo ũrangĩri wa itoonyero rĩa hema o ta ũrĩa maithe mao meehokeirwo ũrangĩri wa itoonyero rĩa Gĩikaro kĩa Jehova.
\v 20 Mahinda ma mbere Finehasi mũrũ wa Eleazaru nĩwe warũgamagĩrĩra arangĩri a ihingo, nake Jehova aarĩ hamwe nake.
\li2 
\v 21 Zekaria mũrũ wa Meshelemia nĩwe warĩ mũrangĩri wa itoonyero rĩa Hema-ya-Gũtũnganwo.
\p 
\v 22 Arĩa othe maathuurĩtwo matuĩke arangĩri a ihingo maarĩ 212. Marĩĩtwa mao nĩmandĩkirwo maandĩko-inĩ ma njiarwa ciao, matũũra-inĩ mao. Arangĩri a ihingo maigirwo o mũndũ harĩa ehokeirwo nĩ Daudi na Samũeli ũrĩa muoni-maũndũ.
\v 23 O ene na njiaro ciao nĩo maarũgamagĩrĩra ũrangĩri wa ihingo cia nyũmba ya Jehova, nyũmba ĩrĩa yetagwo Hema.
\v 24 Arangĩri a ihingo maarĩ mĩena yothe ĩna: irathĩro, na ithũĩro, na gathigathini, na gũthini.
\v 25 Ariũ a ithe wao a matũũra mao nĩmookaga rĩmwe na rĩmwe magateithania mawĩra nao ihinda rĩa mĩthenya mũgwanja.
\v 26 No anene arĩa ana maaroraga arangĩri a ihingo, arĩa maarĩ Alawii, nĩmehokeirwo kũmenyerera tũnyũmba na igĩĩna cia nyũmba ya Ngai.
\v 27 Maikaraga ũtukũ wothe hakuhĩ na nyũmba ya Ngai nĩgeetha mamĩrangagĩre; na nĩo maamenyagĩrĩra cabi ya kũmĩhingũra o rũciinĩ.\f + \fr 9:27 \ft Arangĩri a hekarũ nĩo maigaga cabi nĩgũkorwo nĩyahingagwo ũtukũ.\f*
\p 
\v 28 Amwe ao maarĩ amenyereri a indo iria ciatũmagĩrwo ũtungata-inĩ wa hekarũ; nĩmacitaraga ikĩrutwo na igĩcookio nyũmba thĩinĩ.
\v 29 Angĩ maaheetwo wĩra wa kũmenyerera indo cia nyũmba na indo iria ingĩ ciothe ciakoragwo handũ-harĩa-haamũre, o hamwe na mũtu, na ndibei, na maguta, na ũbani, na mahuti marĩa manungi wega.
\v 30 No athĩnjĩri-Ngai amwe nĩo maarutaga wĩra wa gũtukania mahuti macio manungi wega.
\v 31 Mũlawii wetagwo Matithia, irigithathi rĩa Shalumu ũrĩa Mũkoora, nĩwe wehokeirwo wĩra wa gũthondeka mĩgate ya maruta.
\v 32 Ariũ a ithe amwe ao a mũhĩrĩga wa Kohathu nĩo marũgamagĩrĩra ũthondeki wa mĩgate ya kũigĩrĩrwo metha-inĩ hĩndĩ ya thabatũ.
\p 
\v 33 Arĩa maarĩ aini, na atongoria a nyũmba cia Alawii, maaikaraga tũnyũmba-inĩ kũu hekarũ thĩinĩ na matiarutaga mawĩra mangĩ tondũ maarĩ a kũmenyerera wĩra ũcio wao mũthenya na ũtukũ.
\p 
\v 34 Acio othe maarĩ atongoria a nyũmba cia Alawii, na anene o ta ũrĩa maandĩkĩtwo ibuku-inĩ rĩa njiarwa ciao, nao maatũũraga Jerusalemu.
\s1 Njiarwa cia Saũlũ
\li1 
\v 35 Jeieli ithe wa Gibeoni aatũũraga Gibeoni.
\li2 Mũtumia wake eetagwo Maaka,
\v 36 na mũriũ wake wa irigithathi eetagwo Abidoni, akarũmĩrĩrwo nĩ Zuru, na Kishu, na Baali, na Neri, na Nadabu,
\v 37 na Gedori, na Ahio, na Zekaria, na Mikilothu.
\v 38 Mikilothu nĩwe warĩ ithe wa Shimeami. O nao maikaraga hakuhĩ na andũ ao kũu Jerusalemu.
\li1 
\v 39 Neri aarĩ ithe wa Kishu, nake Kishu aarĩ ithe wa Saũlũ, nake Saũlũ aarĩ ithe wa Jonathani, na Maliki-Shua, na Abinadabu, na Eshi-Baali.
\li1 
\v 40 Mũriũ wa Jonathani eetagwo Meribu-Baali, na nĩwe warĩ ithe wa Mika.
\li1 
\v 41 Ariũ a Mika maarĩ:
\li2 Pithoni, na Meleku, na Taharea, na Ahazu.
\li2 
\v 42 Ahazu aarĩ ithe wa Jara, nake Jara aarĩ ithe wa Alemethu, na Azimavethu, na Zimuri, nake Zimuri aarĩ ithe wa Moza.
\v 43 Moza aarĩ ithe wa Binea, nake Refaia aarĩ mũriũ wa Binea, nake Eleasa aarĩ mũriũ wa Refaia, nake Azeli aarĩ mũriũ wa Eleasa.
\li1 
\v 44 Azeli aarĩ na ariũ atandatũ, na maya nĩmo marĩĩtwa mao:
\li2 Azirikamu, na Bokeru, na Ishumaeli, na Shearia, na Obadia, na Hanani.
\li2 Acio nĩo maarĩ ariũ a Azeli.
\c 10
\s1 Saũlũ Kwĩyũraga
\p 
\v 1 Na rĩrĩ, Afilisti nĩmarũire na Isiraeli; nao andũ a Isiraeli makĩmoorĩra, na aingĩ ao makĩũragĩrwo Kĩrĩma-inĩ kĩa Giliboa.
\v 2 Afilisti makĩhatĩrĩria Saũlũ na ariũ ake mũno, na makĩũraga ariũ ake Jonathani, na Abinadabu, na Maliki-Shua.
\v 3 Na rĩrĩ, mbaara nĩyaneneheire Saũlũ mũno, na hĩndĩ ĩrĩa aikia a mĩguĩ maamũkinyĩrire, makĩmũguraria.
\p 
\v 4 Nake Saũlũ akĩĩra mũkuui wa indo ciake cia mbaara atĩrĩ, “Comora rũhiũ rwaku rwa njora ũũthece naruo, nĩguo andũ aya mataruaga matigooke kũnyararithia.”
\p No mũndũ ũcio mũkuui wa indo ciake cia mbaara agĩĩtigĩra mũno, akĩrega gwĩka ũguo; nĩ ũndũ ũcio Saũlũ akĩoya rũhiũ rwake rwa njora, akĩrũgwĩra.
\v 5 Rĩrĩa mũkuui wa indo cia mbaara onire atĩ Saũlũ nĩakua, o nake akĩgwĩra rũhiũ rwake rwa njora, agĩkua.
\v 6 Nĩ ũndũ ũcio Saũlũ na ariũ ake atatũ magĩkua, nao andũ othe a nyũmba yake magĩgĩkua o hamwe.
\p 
\v 7 Rĩrĩa andũ a Isiraeli othe arĩa maarĩ kĩanda moonire atĩ ita nĩrĩorĩte, na atĩ Saũlũ na ariũ ake nĩmakuĩte-rĩ, magĩtiganĩria matũũra mao, makĩũra; nao Afilisti magĩthiĩ magĩikara kuo.
\p 
\v 8 Mũthenya ũyũ ũngĩ, Afilisti magĩthiĩ gũcuuma ciimba, magĩkora Saũlũ na ariũ ake makuĩte kũu Kĩrĩma-inĩ kĩa Giliboa.
\v 9 Makĩmũbora, na magĩkuua mũtwe wake, na indo ciake cia mbaara; magĩcooka magĩtũma andũ mathiĩ bũrũri wothe wa Afilisti makaanĩrĩre ũhoro ũcio kũrĩ mĩhianano yao ya kũhooywo, na kũrĩ andũ ao.
\v 10 Makĩiga indo cia Saũlũ cia mbaara thĩinĩ wa hekarũ ya ngai ciao, naguo mũtwe wake makĩwoherera kũu hekarũ ya Dagoni.
\p 
\v 11 No rĩrĩa andũ a Jabeshi-Gileadi maaiguire ũhoro wa maũndũ marĩa mothe Afilisti meekĩte Saũlũ-rĩ,
\v 12 njamba ciao cia ita igĩthiĩ, igĩkuua mĩĩrĩ ya Saũlũ na ya ariũ ake, ikĩmĩrehe Jabeshi. Magĩcooka magĩthika mahĩndĩ mao gĩtina-inĩ kĩa mũtĩ ũrĩa mũnene kũu Jabeshi, na makĩĩhinga kũrĩa irio mĩthenya mũgwanja.
\p 
\v 13 Saũlũ aakuire nĩ ũndũ ndaarĩ mwĩhokeku kũrĩ Jehova; ndaamenyereire kiugo kĩa Jehova, o na nĩahooire kĩrĩra kuuma kũrĩ mũragũri atĩ amũtongorie,
\v 14 no ndahooire kĩrĩra kũrĩ Jehova. Nĩ ũndũ ũcio Jehova akĩmũũraga, na akĩneana ũthamaki kũrĩ Daudi mũrũ wa Jesii.
\c 11
\s1 Daudi Gũtuĩka Mũthamaki wa Isiraeli
\p 
\v 1 Hĩndĩ ĩyo andũ othe a Isiraeli magĩcookanĩrĩra harĩ Daudi kũu Hebironi, makĩmwĩra atĩrĩ, “Ithuĩ tũrĩ a mũthiimo na thakame yaku.
\v 2 Ihinda rĩrĩa rĩhĩtũkĩte, o na Saũlũ arĩ o mũthamaki, wee nĩwe ũratongoragia Isiraeli mbaara-inĩ ciao. Nake Jehova Ngai waku agĩkwĩra atĩrĩ, ‘Nĩwe ũkaarĩithia andũ akwa Isiraeli, na nĩũgatuĩka mwathi wao.’ ”
\p 
\v 3 Nĩ ũndũ ũcio athuuri othe a Isiraeli magĩthiĩ Hebironi kũrĩ Mũthamaki Daudi, nake Daudi akĩgĩa na kĩrĩkanĩro nao mbere ya Jehova o kũu Hebironi, nao magĩitĩrĩria Daudi maguta mũtwe atuĩke mũthamaki wa Isiraeli, o ta ũrĩa Jehova eranĩire na kanua ga Samũeli.
\s1 Daudi Gũtooria Jerusalemu
\p 
\v 4 Daudi hamwe na andũ a Isiraeli othe magĩthiĩ gũtharĩkĩra Jerusalemu, o kũu gwetagwo Jebusi. Nao Ajebusi arĩa maatũũraga kũu
\v 5 makĩĩra Daudi atĩrĩ, “Ndũngĩtoonya gũkũ.” No rĩrĩ, Daudi nĩagĩtunyanire gĩikaro kĩu kĩairigĩirwo na thingo cia hinya gĩa Zayuni, Itũũra Inene rĩa Daudi.\f + \fr 11:5 \ft Tene kĩrĩma kĩrĩa kĩarĩ mwena wa irathĩro wa Jerusalemu nĩkĩo kĩoĩkaine ta “Zayuni” no thuutha-inĩ rĩĩtwa rĩu rĩarũgamĩrĩire Jerusalemu yothe.\f*
\p 
\v 6 Daudi oigĩte atĩrĩ, “Ũrĩa wothe ũgũtongoria mbaara ya kũhũũra Ajebusi nĩwe ũgaatuĩka mũnene wa thigari ciothe.” Joabu mũrũ wa Zeruia nĩwe waambire kwambata, na nĩ ũndũ ũcio nĩwe watuĩkire mũnene wa thigari.
\p 
\v 7 Daudi agĩgĩtũũra gĩikaro kĩu kĩairigĩirwo na rũthingo rwa hinya, na nĩ ũndũ ũcio gĩgĩtwo Itũũra Inene rĩa Daudi.
\v 8 Nake agĩaka itũũra inene rĩthiũrũrũkĩirie gĩikaro kĩu, kuuma benji-inĩ nginya rũthingo-inĩ rũrĩa rwakĩrigiicĩirie, nake Joabu agĩcookereria mĩena ĩrĩa ĩngĩ ya itũũra rĩu inene.
\v 9 Daudi agĩkĩrĩrĩria kũgĩa na ũhoti mũingĩ, tondũ Jehova Mwene-Hinya-Wothe aarĩ hamwe nake.
\s1 Andũ Njamba a Daudi
\p 
\v 10 Aya nĩo maarĩ anene a andũ arĩa njamba a Daudi, o ene hamwe na andũ a Isiraeli othe, nĩmatirĩrĩire ũthamaki wake na hinya nĩguo ũtheereme bũrũri wothe, o ta ũrĩa Jehova eeranĩire.
\v 11 Maya nĩmo marĩĩtwa ma andũ acio maarĩ njamba a Daudi:
\p Jashobeamu ũrĩa Mũhakimoni nake aarĩ mũtongoria wa anene; nĩwe woire itimũ rĩake ahũũrane na andũ 300, nake akĩmooraga mbaara-inĩ ĩmwe.
\p 
\v 12 Mũnini wake eetagwo Eleazaru mũrũ wa Dodo ũrĩa Mũahohi, ũmwe wa andũ atatũ arĩa maarĩ njamba.
\v 13 Nake aarĩ hamwe na Daudi kũu Pasi-Damimu hĩndĩ ĩrĩa Afilisti moonganĩte marũe nao. Maarĩ handũ haarĩ mũgũnda waiyũire cairi, nacio thigari ikĩũrĩra Afilisti.
\v 14 No-o nĩmaregeire gatagatĩ ka mũgũnda ũcio. Makĩũgitĩra, na makĩũraga Afilisti, nake Jehova akĩmahe ũhootani mũnene.
\p 
\v 15 Anene atatũ a acio mĩrongo ĩtatũ, nĩmaikũrũkire magĩthiĩ kũrĩ Daudi ihiga-inĩ rĩrĩa rĩarĩ ngurunga-inĩ ya Adulamu, hĩndĩ ĩrĩa mbũtũ ya Afilisti yaambĩte hema Kĩanda kĩa Refaimu.
\v 16 Hĩndĩ ĩyo Daudi aarĩ kĩĩhitho-inĩ kĩrũmu nayo mbũtũ ya Afilisti yarĩ Bethilehemu.
\v 17 Daudi akĩĩrirĩria maaĩ, akiuga atĩrĩ, “Naarĩ korwo kũrĩ mũndũ ũngĩndehera maaĩ ma kũnyua kuuma gĩthima-inĩ kĩrĩa kĩrĩ hakuhĩ na kĩhingo kĩa Bethilehemu!”
\v 18 Nĩ ũndũ ũcio andũ acio atatũ magĩtuĩkanĩria gatagatĩ ka ita rĩa Afilisti, magĩtaha maaĩ gĩthima-inĩ kĩu kĩarĩ hakuhĩ na kĩhingo kĩa Bethilehemu, na makĩmatwarĩra Daudi. No Daudi akĩrega kũmanyua; akĩmaita mbere ya Jehova.
\v 19 Akiuga atĩrĩ, “Ngai arogiria njĩke ũguo! No ngĩnyue thakame ya andũ aya mathiĩrĩire ũgwati-inĩ wa gĩkuũ?” Tondũ nĩmathiĩrĩire ũgwati-inĩ wa gĩkuũ nĩguo mamarehe-rĩ, Daudi akĩrega kũmanyua.
\p Maũndũ ta macio nĩmo meekagwo nĩ njamba icio ithatũ.
\p 
\v 20 Abishai mũrũ wa nyina na Joabu nĩwe warĩ mũnene wa acio Atatũ. Nake akĩoya itimũ rĩake, agĩtharĩkĩra andũ magana matatũ, akĩmooraga, nĩ ũndũ ũcio akĩgĩa igweta o ta acio Atatũ.
\v 21 Nĩatĩĩkire mũno gũkĩra acio angĩ Atatũ na agĩtuĩka mwathi wao o na gũtuĩka ndaataranĩirio nao.
\p 
\v 22 Benaia mũrũ wa Jehoiada aarĩ mũrũi njamba wa kuuma Kabizeeli, ũrĩa wekire maũndũ manene ma ũcamba. Nĩooragire njamba nene igĩrĩ cia ita cia Moabi. Ningĩ nĩatoonyire irima mũthenya warĩ na tharunji, na akĩũraga mũrũũthi.
\v 23 Na nĩooragire Mũmisiri warĩ wa ũraihu wa buti mũgwanja na nuthu.\f + \fr 11:23 \ft nĩ ta mita igĩrĩ na robo (2:25)\f* O na gũtuĩka Mũmisiri ũcio nĩanyiitĩte itimũ rĩaiganaga ta mũtĩ wa mũtumi ngoora, Benaia akĩmũtharĩkĩra na njũgũma. Akĩhuria itimũ kuuma guoko-inĩ kwa Mũmisiri ũcio, na akĩmũũraga na itimũ rĩu rĩake.
\v 24 Macio nĩmo maũndũ ma ũcamba marĩa mekirwo nĩ Benaia mũrũ wa Jehoiada. O nake aarĩ igweta o ta andũ arĩa atatũ maarĩ njamba.
\v 25 Nĩatĩĩtwo gũkĩra arĩa Mĩrongo Ĩtatũ, no ndaataranĩirio na acio Atatũ. Nake Daudi akĩmũtua mũnene wa arĩa maamũrangagĩra.
\b
\li1 
\v 26 Andũ arĩa maarĩ njamba maarĩ:
\li2 Asaheli mũrũ wa nyina na Joabu,
\li2 na Elihanani mũrũ wa Dodo wa kuuma Bethilehemu,
\li2 
\v 27 na Shamothu ũrĩa Mũharori,
\li2 na Helezu ũrĩa Mũpeloni,
\li2 
\v 28 na Ira mũrũ wa Ikeshu kuuma Tekoa,
\li3 na Abiezeri kuuma Anathothu,
\li2 
\v 29 na Sibekai ũrĩa Mũhushathi,
\li2 na Ilai ũrĩa Mũahohi,
\li2 
\v 30 na Maharai ũrĩa Mũnetofathi,
\li2 na Helebu mũrũ wa Baana ũrĩa Mũnetofathi,
\li2 
\v 31 na Ithai mũrũ wa Ribai, wa kuuma Gibea kũu Benjamini,
\li2 na Benaia ũrĩa Mũpirathoni,
\li2 
\v 32 na Hurai kuuma tũrũũĩ-inĩ twa Gaashu,
\li2 na Abieli ũrĩa Mũaribathi,
\li2 
\v 33 na Azamavethu ũrĩa Mũbahurimu,
\li2 na Eliahaba ũrĩa Mũshaaliboni,
\li2 
\v 34 na ariũ a Hashemu ũrĩa Mũgizoni,
\li2 na Jonathani mũrũ wa Shage ũrĩa Mũharari,
\li2 
\v 35 na Ahiamu mũrũ wa Sakaru ũrĩa Mũharari,
\li2 na Elifali mũrũ wa Uri,
\li2 
\v 36 na Heferi ũrĩa Mũmekerathi,
\li2 na Ahija ũrĩa Mũpeloni,
\li2 
\v 37 na Hezoro ũrĩa Mũkarimeli,
\li2 na Naarai mũrũ wa Ezibai,
\li2 
\v 38 na Joeli mũrũ wa ithe na Nathani,
\li2 na Mibihari mũrũ wa Hagari,
\li2 
\v 39 na Zeleku ũrĩa Mũamoni,
\li2 na Naharai ũrĩa Mũberothi, ũrĩa wakuuagĩra Joabu mũrũ wa Zeruia indo cia mbaara,
\li2 
\v 40 na Ira ũrĩa Mũithiri,
\li2 na Garebu ũrĩa Mũithiri,
\li2 
\v 41 na Uria ũrĩa Mũhiti,
\li2 na Zabadi mũrũ wa Ahalai,
\li2 
\v 42 na Adina mũrũ wa Shiza ũrĩa Mũrubeni, ũrĩa warĩ mũnene wa Arubeni, arĩ na andũ mĩrongo ĩtatũ arĩa maarĩ nake,
\li2 
\v 43 na Hanani mũrũ wa Maaka,
\li2 na Joshafatu ũrĩa Mũmithini,
\li2 
\v 44 na Uzia ũrĩa Mũashiterathi,
\li2 na Shama na Jeieli, ariũ a Hothamu ũrĩa Mũaroeri,
\li2 
\v 45 na Jediaeli mũrũ wa Shimuri,
\li2 o na Joha mũrũ wa ithe ũrĩa Mũtizi,
\li2 
\v 46 na Elieli ũrĩa Mũmahavi,
\li2 na Jeribai na Joshavia, ariũ a Elinaamu,
\li2 na Ithima ũrĩa Mũmoabi,
\li2 
\v 47 na Elieli, na Obedi, na Jaasieli ũrĩa Mũmezobai.
\c 12
\s1 Njamba cia Ita Kũnyiitana na Daudi
\p 
\v 1 Aya nĩo andũ arĩa mookire kũrĩ Daudi arĩ kũu Zikilagi, hĩndĩ ĩrĩa aaingatĩtwo akehera maitho-inĩ ma Saũlũ mũrũ wa Kishu (maarĩ amwe a njamba cia ita iria ciamũteithirie mbaara-inĩ;
\v 2 Nao maakuuaga mota na nĩmooĩ gũikia mĩguĩ, na gũikia mahiga na kĩgũtha, na guoko kwa ũrĩo kana kwa ũmotho; maarĩ a mbarĩ ĩmwe na Saũlũ kuuma mũhĩrĩga wa Benjamini), nao maarĩ:
\b
\mi1 
\v 3 Ahiezeri ũrĩa warĩ mũnene wao na Joashu, ariũ a Shemaa ũrĩa Mũgibea; na Jezieli, na Peleti, ariũ a Azimavethu; na Beraka, na Jehu ũrĩa Mũanathothu,
\v 4 na Ishimaia ũrĩa Mũgibeoni, mũndũ warĩ njamba thĩinĩ wa andũ arĩa Mĩrongo Ĩtatũ, nake aarĩ mũtongoria ũmwe thĩinĩ wa acio Mĩrongo Ĩtatũ; na Jeremia, na Jahazieli, na Johanani, na Jozabadu ũrĩa Mũgederathi,
\v 5 na Eluzai, na Jerimothu, na Bealia, na Shemaria, na Shefatia ũrĩa Mũharufi;
\v 6 na Elikana, na Ishia, na Azareli, na Joezeru, na Jashobeamu arĩa maarĩ a mbarĩ ya Kora;
\v 7 na Joela, na Zebadia, ariũ a Jerohamu kuuma Gedori.
\b
\p 
\v 8 Agadi amwe nĩmagarũrũkire magĩcooka mwena wa Daudi o kũu werũ-inĩ kĩĩhitho-inĩ gĩake. Maarĩ njamba cia ita irĩ ũrũme ciehaarĩirie gũthiĩ mbaara, na nĩmooĩ kũhũthĩra ngo na itimũ. Mothiũ mao maahaanaga ta mothiũ ma mĩrũũthi, na maarĩ ihenya ta thwariga irĩ irĩma-inĩ.
\li1 
\v 9 Ezeri nĩwe warĩ mũnene wao,
\li1 na Obadia aarĩ mũnini wake; nake Eliabu aarĩ wa gatatũ,
\li1 
\v 10 na Mishimana aarĩ wa kana, na Jeremia aarĩ wa gatano,
\li1 
\v 11 na Atai aarĩ wa gatandatũ, na Elieli aarĩ wa mũgwanja,
\li1 
\v 12 na Johanani aarĩ wa kanana, na Elizabadu aarĩ wa kenda,
\li1 
\v 13 na Jeremia aarĩ wa ikũmi, na Makabanai aarĩ wa ikũmi na ũmwe.
\p 
\v 14 Agadi acio maarĩ anene a mbũtũ cia ita; ũrĩa warĩ mũnini mũno wao aarũaga mbaara ĩrĩa ĩngĩarũirwo nĩ andũ igana, nake ũrĩa warĩ mũnene mũno wao aarũaga mbaara ĩrĩa ĩngĩarũirwo nĩ andũ ngiri ĩmwe.
\v 15 Nĩo maaringire Rũũĩ rwa Jorodani mweri wa mbere rĩrĩa rwaiyũrĩte nginya rũkoina hũgũrũrũ ciaruo ciothe, na makĩingatithia andũ arĩa othe maaikaraga cianda-inĩ cia mwena wa irathĩro na mwena wa ithũĩro.
\p 
\v 16 Andũ amwe a kuuma Benjamini na angĩ a kuuma Juda o nao magĩũka kũrĩ Daudi kũu kĩĩhitho-inĩ gĩake.
\v 17 Daudi agĩthiĩ kũmatũnga, akĩmeera atĩrĩ, “Angĩkorwo mũrooka kũrĩ niĩ na thayũ kũndeithia-rĩ, nĩndĩhaarĩirie kũmwamũkĩra tũtuĩke kĩndũ kĩmwe; no angĩkorwo mũũkĩte kũngunyanĩra kũrĩ thũ ciakwa o rĩrĩa itarenda haaro-rĩ, Ngai wa maithe maitũ arorora ũndũ ũcio na amũtuĩre ciira.”
\p 
\v 18 Hĩndĩ ĩyo Roho agĩikũrũkĩra Amasai, mũnene wa arĩa Mĩrongo Ĩtatũ, akiuga atĩrĩ:
\q1 “Tũrĩ aku, wee Daudi!
\q2 Tũrĩ hamwe nawe, wee mũrũ wa Jesii!
\q1 Ũrogaacĩra, ũgaacĩre ki,
\q2 na arĩa magũteithagia marogaacĩra,
\q3 nĩgũkorwo Ngai waku nĩegũgũteithia.”
\p Nĩ ũndũ ũcio Daudi akĩmaamũkĩra na akĩmatua atongoria a mbũtũ ciake cia gũtharĩkĩra thũ.
\p 
\v 19 Andũ amwe a Manase nĩmagarũrũkire magĩthiĩ mwena wa Daudi rĩrĩa aathiire na Afilisti kũhũũrana na Saũlũ. (Daudi na andũ ake matiateithirie Afilisti, tondũ thuutha wa kwaranĩria, aathani ao nĩmamũingatire. Maamwĩrire atĩrĩ, “Tũkaarĩha na mĩoyo iitũ angĩgatũtiganĩria acookerere mwathi wake Saũlũ.”)
\v 20 Hĩndĩ ĩrĩa Daudi aathiire Zikilagi, aya nĩo andũ a Manase arĩa maagarũrũkire magĩthiĩ mwena wake: Adina, na Jozabadu, na Jediaeli, na Mikaeli, na Jozabadu, na Elihu, na Zilethai, atongoria a ikundi cia ngiri kũu Manase.
\v 21 Nĩmateithirie Daudi kuuma kũrĩ mbũtũ iria ciamũtharĩkĩire, nĩgũkorwo othe maarĩ njamba cia ita irĩ ũrũme, na maarĩ anene a ita ciake.
\v 22 Mũthenya o mũthenya andũ nĩmookaga gũteithia Daudi, o nginya akĩgĩa na mbũtũ nene, o ta mbũtũ ya Ngai.
\s1 Andũ arĩa angĩ Maanyiitaniĩre na Daudi kũu Hebironi
\p 
\v 23 Ũyũ nĩguo mũigana wa andũ arĩa meehaarĩirie gũthiĩ mbaara arĩa maathiire Hebironi kũrĩ Daudi nĩgeetha magarũre ũthamaki wa Saũlũ, maũnengere Daudi, o ta ũrĩa Jehova oigĩte:
\li1 
\v 24 andũ a Juda arĩa meehaarĩirie kũrũa mbaara maakuĩte ngo na matimũ, maarĩ 6,800;
\li1 
\v 25 andũ a Simeoni arĩa njamba cia ita meehaarĩirie kũrũa mbaara, maarĩ 7,100;
\li1 
\v 26 andũ a Alawii maarĩ 4,600;
\v 27 amwe ao maarĩ Jehoiada, mũtongoria wa nyũmba ya Harũni ũrĩa warĩ na andũ 3,700,
\v 28 na Zadoku, mwanake mũnini warĩ njamba ya ita ĩrĩ ũrũme, ũrĩa warĩ na anene a thigari mĩrongo ĩĩrĩ na eerĩ kuuma nyũmba yake;
\li1 
\v 29 andũ a Benjamini, na nĩo maarĩ a mbarĩ ĩmwe na Saũlũ, maarĩ 3,000; aingĩ ao maatũũrĩte maathĩkagĩra nyũmba ya Saũlũ, o nginya hĩndĩ ĩyo;
\li1 
\v 30 andũ a Efiraimu, njamba cia ita irĩ ũrũme na irĩ ngumo mĩhĩrĩga-inĩ yao, maarĩ 20,800;
\li1 
\v 31 andũ a nuthu ya mũhĩrĩga wa Manase, arĩa maagwetetwo na marĩĩtwa nĩguo mathiĩ matue Daudi mũthamaki, maarĩ 18,000;
\li1 
\v 32 andũ a Isakaru, arĩa maarĩ na ũmenyo wa mahinda, na makamenya ũrĩa Isiraeli magĩrĩirwo nĩ gwĩka, maarĩ anene 200 arĩa maathaga andũ othe a nyũmba ciao;
\li1 
\v 33 andũ a Zebuluni, thigari iria ciamenyerete mbaara, na nĩmehaarĩirie kũrũa mbaara me na mĩthemba yothe ya indo cia mbaara, nĩguo mateithie Daudi marĩ na ngoro ĩmwe, nao maarĩ 50,000;
\li1 
\v 34 andũ a Nafitali maarĩ anene 1,000 hamwe na andũ 37,000 arĩa makuuĩte ngo na matimũ;
\li1 
\v 35 andũ a Dani arĩa mehaarĩirie kũrũa mbaara, maarĩ 28,600;
\li1 
\v 36 andũ a Asheri, thigari iria ciamenyerete mbaara na mehaarĩirie kũrũa mbaara, maarĩ 40,000;
\li1 
\v 37 na kuuma mwena wa irathĩro wa Jorodani, andũ a Rubeni, na Gadi, na nuthu ya mũhĩrĩga wa Manase, marĩ na mĩthemba yothe ya indo cia mbaara, maarĩ 120,000.
\p 
\v 38 Acio othe maarĩ andũ a kũrũa arĩa meerutĩte gũtungata marĩ ita-inĩ. Magĩũka Hebironi marĩ na ngoro ĩmwe ya gũtua Daudi mũthamaki wa Isiraeli guothe. Andũ a Isiraeli arĩa angĩ othe o nao maarĩ na rĩciiria o rĩmwe rĩa gũtua Daudi mũthamaki.
\v 39 Andũ acio maikarire kũu na Daudi mĩthenya ĩtatũ makĩrĩa na makĩnyua, nĩgũkorwo andũ a nyũmba ciao nĩmaheanĩte irio nĩ ũndũ wao.
\v 40 O na ningĩ andũ arĩa maatũũraga hakuhĩ nao kuuma Isakaru, na Zebuluni, na Nafitali nĩmarehire irio ikuuĩtwo nĩ ndigiri, na ngamĩĩra, na nyũmbũ, na ndegwa. Nĩ kwarehetwo mũtu mũingĩ, na ngũmba cia ngũyũ na cia thabibũ nyũmũ, na ndibei, na maguta, na ngʼombe, na ngʼondu, nĩgũkorwo kwarĩ na gĩkeno kũu Isiraeli.
\c 13
\s1 Gũcookia Ithandũkũ rĩa Kĩrĩkanĩro
\p 
\v 1 Daudi nĩmagĩire ndundu na anene ake a ita, arĩa maathaga ikundi cia thigari ngiri na ikundi cia thigari igana.
\v 2 Ningĩ agĩcooka akĩĩra kĩũngano gĩothe gĩa Isiraeli atĩrĩ, “Mũngĩona kwagĩrĩire na angĩkorwo nĩ kwenda kwa Jehova Ngai witũ, nĩ tũtũme ũhoro kũndũ na kũndũ kũrĩ ariũ a ithe witũ arĩa angĩ marĩ kũndũ guothe ngʼongo-inĩ cia Isiraeli, o na kũrĩ athĩnjĩri-Ngai na Alawii arĩa me hamwe nao matũũra-inĩ mao na ũrĩithio-inĩ wao, moke manyiitanĩre na ithuĩ.
\v 3 Nĩtũrehei ithandũkũ rĩa kĩrĩkanĩro rĩa Ngai witũ tũrĩcookie kũrĩ ithuĩ, nĩgũkorwo tũtiatuĩragia ũhoro harĩ rĩo hĩndĩ ya ũthamaki wa Saũlũ.”
\v 4 Kĩũngano gĩothe gĩgĩtĩkĩra gwĩka ũguo tondũ andũ othe nĩmoonire ũndũ ũcio nĩwagĩrĩire.
\p 
\v 5 Nĩ ũndũ ũcio Daudi agĩcookanĩrĩria andũ a Isiraeli othe kuuma Rũũĩ rwa Shihoru kũu Misiri nginya Lebo-Hamathu, makagĩĩre ithandũkũ rĩa Ngai kuuma Kiriathu-Jearimu.
\v 6 Daudi na andũ a Isiraeli othe arĩa maarĩ nake magĩthiĩ Baala kũu Juda (nĩkuo Kiriathu-Jearimu) makagĩĩre ithandũkũ rĩa Jehova Ngai ũrĩa ũikarĩire gĩtĩ kĩa ũnene gatagatĩ ka makerubi, o ithandũkũ rĩu rĩĩtanĩtio na Rĩĩtwa rĩake.
\p 
\v 7 Makĩruta ithandũkũ rĩa Ngai kuuma nyũmba ya Abinadabu rĩkuuĩtwo na ikaari rĩerũ, rĩtongoretio nĩ Uza na Ahio.
\v 8 Daudi na andũ a Isiraeli othe magĩkũngũĩra na hinya wao wothe marĩ mbere ya Ngai, makĩinaga na inanda cia mũgeeto na cia kĩnũbi, na tũhembe, na thaani iria ihũũrithanagio ikagamba, na tũrumbeta.
\p 
\v 9 Hĩndĩ ĩrĩa maakinyire kĩhuhĩro-inĩ kĩa ngano gĩa Kidoni, Uza agĩtambũrũkia guoko nĩguo anyiitĩrĩre ithandũkũ rĩu rĩa kĩrĩkanĩro, tondũ ndegwa nĩciahĩngirwo.
\v 10 Na rĩrĩ, marakara ma Jehova nĩmakanĩire Uza, akĩmũgũtha, akĩgũa tondũ nĩanyiitire ithandũkũ rĩu na guoko. Nĩ ũndũ ũcio Uza agĩkuĩra o hau mbere ya Ngai.
\p 
\v 11 Nake Daudi akĩrakara tondũ mangʼũrĩ ma Jehova nĩmookĩrĩire Uza, nĩ ũndũ ũcio handũ hau hetagwo Perezu-Uza nginya ũmũthĩ.
\p 
\v 12 Daudi agĩĩtigĩra Ngai mũthenya ũcio, akĩũria atĩrĩ, “Ngaahota atĩa kũrehe ithandũkũ rĩĩrĩ rĩa Ngai kũrĩ niĩ?”
\v 13 Tondũ ũcio Daudi ndaathiire na ithandũkũ rĩu Itũũra-inĩ Inene rĩa Daudi. Handũ ha ũguo, aarĩtwarire kwa Obedi-Edomu ũrĩa Mũgiiti.
\v 14 Ithandũkũ rĩu rĩa Ngai rĩaikarire na andũ a nyũmba ya Obedi-Edomu gwake mũciĩ mĩeri ĩtatũ, nake Jehova akĩrathima andũ a mũciĩ wake, o na kĩrĩa gĩothe aarĩ nakĩo.
\c 14
\s1 Nyũmba ya Daudi na Andũ Ake
\p 
\v 1 Na rĩrĩ, Hiramu mũthamaki wa Turo, nĩatũmĩire Daudi andũ, marĩ na mĩgogo ya mĩtarakwa, na aaki a mahiga na a mbaũ, nĩguo mamwakĩre nyũmba ya ũthamaki.
\v 2 Nake Daudi nĩamenyire atĩ Jehova nĩamũhaandĩte atuĩke mũthamaki wa Isiraeli, na atĩ ũthamaki wake nĩwatũũgĩrĩtio mũno nĩ ũndũ wa andũ ake a Isiraeli.
\p 
\v 3 Daudi nĩahikirie atumia angĩ arĩ kũu Jerusalemu, nake agĩtuĩka ithe wa aanake na airĩtu angĩ.
\v 4 Maya nĩmo marĩĩtwa ma ciana ciake iria ciaciarĩirwo kũu: Shamua, na Shobabu, na Nathani, na Solomoni,
\v 5 na Ibiharu, na Elishua, na Elipeleti,
\v 6 na Noga, na Nefegu, na Jafia,
\v 7 na Elishama, na Beeliada, na Elifeleti.
\s1 Daudi Kũhoota Afilisti
\p 
\v 8 Na rĩrĩa Afilisti maaiguire atĩ Daudi nĩaitĩrĩirio maguta agatuĩka mũthamaki wa Isiraeli guothe-rĩ, makĩambata, magĩthiĩ na mbũtũ ciao ciothe makamũcarie, nake Daudi aigua ũhoro ũcio akiumagara, agĩthiĩ akahũũrane nao.
\v 9 Na rĩrĩ, Afilisti nĩmookĩte magatharĩkĩra Gĩtuamba kĩa Refaimu;
\v 10 nĩ ũndũ ũcio Daudi agĩtuĩria ũhoro kũrĩ Ngai, akĩmũũria atĩrĩ, “Thiĩ ngatharĩkĩre Afilisti? Nĩũkũmaneana moko-inĩ makwa?”
\p Nake Jehova akĩmũcookeria atĩrĩ, “Thiĩ, nĩngũmaneana moko-inĩ maku.”
\p 
\v 11 Nĩ ũndũ ũcio Daudi na andũ ake makĩambata, magĩthiĩ nginya Baali-Perazimu, na akĩmatooreria kuo. Nake akiuga atĩrĩ, “O ta ũrĩa maaĩ moinaga, noguo Ngai aharaganĩtie thũ ciakwa na guoko gwakwa.” Nĩ ũndũ ũcio handũ hau hagĩĩtwo Baali-Perazimu.
\v 12 Afilisti magĩtiganĩria ngai ciao kũu, nake Daudi agĩathana ngai icio icinwo na mwaki.
\p 
\v 13 Afilisti nĩmatharĩkĩire Gĩtuamba kĩu rĩngĩ;
\v 14 nĩ ũndũ ũcio Daudi agĩtuĩria ũhoro harĩ Ngai rĩngĩ, nake Ngai akĩmũcookeria atĩrĩ, “Tiga kwambata, no mathiũrũrũkĩrie, na ũmatharĩkĩre ũmarutĩtie na mbere ya mĩtĩ ya mĩkũngũgũ.
\v 15 Rĩrĩa ũrĩigua mũkubio uumĩte igũrũ rĩa mĩtĩ ĩyo ya mĩkũngũgũ-rĩ, thiĩ ũkarũe, tondũ ũguo nĩkuonania atĩ Ngai arĩ mbere yaku akĩhũũra ita rĩa Afilisti.”
\v 16 Nĩ ũndũ ũcio Daudi agĩĩka o ta ũrĩa Ngai aamwathĩte, nao makĩhũũra mbũtũ cia Afilisti, o kuuma Gibeoni nginya Gezeri.
\p 
\v 17 Nĩ ũndũ ũcio ngumo ya Daudi ĩkĩhunja o bũrũri o bũrũri, nake Jehova agĩtũma ndũrĩrĩ ciothe imwĩtigĩre.
\c 15
\s1 Ithandũkũ rĩa Kĩrĩkanĩro Kũrehwo Jerusalemu
\p 
\v 1 Daudi aarĩkia gwaka nyũmba ciake mwene kũu Itũũra Inene rĩa Daudi, nĩahaarĩirie handũ ha kũiga ithandũkũ rĩa Ngai, na akĩrĩambĩra hema.
\v 2 Ningĩ Daudi akiuga atĩrĩ, “Gũtirĩ mũndũ ũngĩ wagĩrĩirwo nĩ gũkuua ithandũkũ rĩa Ngai tiga o Alawii, tondũ nĩo Jehova aathuurire makuuage ithandũkũ rĩu rĩa Jehova na mamũtungatagĩre nginya tene.”
\p 
\v 3 Daudi nĩacookanĩrĩirie andũ othe a Isiraeli hamwe kũu Jerusalemu nĩguo marehe ithandũkũ rĩa Jehova handũ harĩa aarĩthondekeire.
\v 4 Nĩacookanĩrĩirie njiaro cia Harũni na Alawii ta ũũ:
\b
\li1 
\v 5 Kuuma kũrĩ njiaro cia Kohathu,
\li2 Urieli nĩwe warĩ mũtongoria, na andũ a nyũmba yao 120;
\li1 
\v 6 kuuma kũrĩ njiaro cia Merari,
\li2 Asaia nĩwe warĩ mũtongoria, na andũ a nyũmba yao 220;
\li1 
\v 7 kuuma kũrĩ njiaro cia Gerishoni,
\li2 Joeli nĩwe warĩ mũtongoria, na andũ a nyũmba yao 130;
\li1 
\v 8 kuuma kũrĩ njiaro cia Elizafani,
\li2 Shemaia nĩwe warĩ mũtongoria, na andũ a nyũmba yao 200;
\li1 
\v 9 kuuma kũrĩ njiaro cia Hebironi,
\li2 Elieli nĩwe warĩ mũtongoria, na andũ a nyũmba yao 80;
\li1 
\v 10 kuuma kũrĩ njiaro cia Uzieli,
\li2 Aminadabu nĩwe warĩ mũtongoria, na andũ a nyũmba yao 112.
\p 
\v 11 Ningĩ Daudi agĩĩta Zadoku na Abiatharu arĩa athĩnjĩri-Ngai, na Urieli, na Asaia, na Joeli, na Shemaia, na Elieli, na Aminadabu arĩa Alawii.
\v 12 Akĩmeera atĩrĩ, “Nĩ inyuĩ anene a nyũmba cia Alawii; inyuĩ ene na Alawii arĩa angĩ no nginya mwĩtherie na mwambatie ithandũkũ rĩa Jehova Ngai wa Isiraeli nginya handũ harĩa ndĩrĩthondekeire.
\v 13 Nĩ ũndũ inyuĩ, Alawii, mũtiarĩambatirie ihinda rĩa mbere, nĩkĩo Jehova Ngai witũ aatũũkĩrĩire na marakara. Tũtiigana gũtuĩria ũhoro wa ũrĩa tũngĩekire kũrĩ we, kũringana na ũrĩa gwatuĩtwo.”
\v 14 Nĩ ũndũ ũcio, athĩnjĩri-Ngai na Alawii magĩĩtheria nĩgeetha maambatie ithandũkũ rĩa Jehova, Ngai wa Isiraeli.
\v 15 Nao Alawii magĩkuua ithandũkũ rĩa Ngai na mĩtĩ mĩraaya mamĩigĩrĩire ciande, o ta ũrĩa Musa aathanĩte kũringana na kiugo kĩa Jehova.
\p 
\v 16 Daudi akĩĩra atongoria a Alawii mathuure ariũ a ithe wao matuĩke aini, nao maine nyĩmbo cia gĩkeno makĩhũũraga inanda cia kĩnũbi, na cia mũgeeto, na thaani iria ihũũrithanagio ikagamba.
\p 
\v 17 Nĩ ũndũ ũcio Alawii magĩthuura Hemani mũrũ wa Joeli; kuuma harĩ ariũ a ithe, na magĩthuura Asafu mũrũ wa Berekia; na kuuma harĩ ariũ a ithe Amerari magĩthuura Ethani mũrũ wa Kushaia;
\v 18 na ningĩ hamwe nao magĩthuura ariũ a ithe matuĩke anini ao wathani-inĩ. nao nĩ: Zekaria, na Jaazieli, na Shemiramothu, na Jehieli, na Uni, na Eliabu, na Benaia, na Maaseia, na Matithia, na Elifelehu, na Mikineia, na Obedi-Edomu, na Jeieli, arĩa arangĩri ihingo.
\p 
\v 19 Hemani, na Asafu na Ethani maarĩ aini na maahũũrithanagia thaani cia gĩcango;
\v 20 Zekaria, na Azieli, na Shemiramothu, na Jehieli, na Uni, na Eliabu, na Maaseia, na Benaia maarĩ a kũhũũra inanda cia kĩnũbi, kũringana na Alamothu.
\v 21 Nake Matithia, na Elifelehu, na Mikineia, na Obedi-Edomu, na Jeieli, na Azazia maarĩ a kũhũũra inanda cia mũgeeto, matongoretie kũringana na Sheminithu (ũguo nĩ ta kuuga mũgambo ũkũruruma).
\v 22 Kenania ũrĩa mũtongoria wa Alawii nĩwe warũgamĩrĩire ũini; ũcio nĩguo warĩ wĩra wake tondũ aarĩ na ũũgĩ wa guo.
\p 
\v 23 Berekia na Elikana nĩo maarĩ a kũrangĩra mĩrango nĩ ũndũ wa ithandũkũ rĩu.
\v 24 Athĩnjĩri-Ngai, nĩo Shebania, na Joshafatu, na Nethaneli, na Amasai, na Zekaria, na Benaia, na Eliezeri maarĩ a kũhuha tũrumbeta mbere ya ithandũkũ rĩa Ngai. Obedi-Edomu na Jehia o nao maarĩ arangĩri a mĩrango nĩ ũndũ wa ithandũkũ rĩu.
\p 
\v 25 Nĩ ũndũ ũcio Daudi na athuuri a Isiraeli, na anene a ikundi cia ngiri, magĩthiĩ kwambatia ithandũkũ rĩa kĩrĩkanĩro kĩa Jehova kuuma nyũmba ya Obedi-Edomu makenete.
\v 26 Tondũ Ngai nĩateithĩtie Alawii arĩa maakuuaga ithandũkũ rĩa kĩrĩkanĩro kĩa Jehova-rĩ, ndegwa mũgwanja na ndũrũme mũgwanja nĩciarutirwo igongona.
\v 27 Hĩndĩ ĩyo Daudi eehumbĩte nguo ya igũrũ ndaaya ya gatani ĩrĩa njega, na noguo Alawii othe arĩa makuuĩte ithandũkũ rĩu mehumbĩte, o na aini na Kenania ũrĩa warĩ mũtongoria wa ũini. O na ningĩ Daudi nĩehumbĩte ebodi ya gatani.
\v 28 Nĩ ũndũ ũcio andũ othe a Isiraeli makĩambatia ithandũkũ rĩa kĩrĩkanĩro kĩa Jehova makĩanagĩrĩra, makĩhuhaga macoro na tũrumbeta, na makĩhũũrithanagia thaani iria ihũũrithanagio na ikagamba, na makĩhũũraga inanda cia kĩnũbi na cia mũgeeto.
\p 
\v 29 Hĩndĩ ĩrĩa ithandũkũ rĩa kĩrĩkanĩro kĩa Jehova rĩatoonyaga Itũũra Inene rĩa Daudi-rĩ, Mikali mwarĩ wa Saũlũ nĩacũthĩrĩirie arĩ ndirica-inĩ. Na rĩrĩa onire Mũthamaki Daudi akĩina akĩrũgarũgaga, akĩmũnyarara ngoro-inĩ yake.
\c 16
\p 
\v 1 Alawii makĩrehe ithandũkũ rĩa Ngai, makĩrĩtoonyia thĩinĩ wa hema ĩrĩa yaambĩtwo nĩ Daudi nĩ ũndũ warĩo, na makĩrutĩra Ngai maruta ma njino na maruta ma ũiguano.
\v 2 Daudi aarĩkia kũruta maruta ma njino na maruta ma ũiguano-rĩ, akĩrathima andũ acio thĩinĩ wa rĩĩtwa rĩa Jehova.
\v 3 Ningĩ akĩhe andũ a Isiraeli othe, arũme na andũ-a-nja o mũndũ mũgate, na gĩcunjĩ kĩa nyama, na ngũmba ya thabibũ nyũmũ.
\p 
\v 4 Nĩathuurire Alawii amwe matungatage mbere ya ithandũkũ rĩa Jehova, na mathaithanagĩre andũ, na macookagie ngaatho, na magoocage Jehova, Ngai wa Isiraeli, nao nĩo:
\v 5 Asafu ũrĩa warĩ mũnene wao, na mũnini wake aarĩ Zekaria, agacookwo nĩ Jeieli, na Shemiramothu, na Jehieli, na Matithia, na Eliabu, na Benaia, na Obedi-Edomu, na Jeieli. Acio maarĩ a kũhũũraga inanda cia kĩnũbi na inanda cia mũgeeto, nake Asafu agambagie thaani iria ihũũrithanagio ikagamba,
\v 6 nao athĩnjĩri-Ngai, Benaia na Jahazieli, maarĩ a kũhuha tũrumbeta hĩndĩ ciothe marĩ mbere ya ithandũkũ rĩa kĩrĩkanĩro kĩa Ngai.
\s1 Thaburi ya Daudi ya Gũcookia Ngaatho
\p 
\v 7 Mũthenya ũcio ũndũ wa mbere, ũrĩa Daudi eekire nĩ kũnengera Asafu na athiritũ ake thaburi ĩno ya gũcookeria Jehova ngaatho:
\q1 
\v 8 Cookeriai Jehova ngaatho, kaĩrai rĩĩtwa rĩake;
\q2 menyithaniai ndũrĩrĩ-inĩ ũrĩa ekĩte.
\q1 
\v 9 Mũinĩrei, mũmũinĩre mũkĩmũgoocaga,
\q2 mũheane ũhoro wa ciĩko ciake ciothe cia magegania.
\q1 
\v 10 Mwĩrahei nĩ ũndũ wa rĩĩtwa rĩake itheru;
\q2 ngoro cia arĩa marongoragia Jehova nĩ ikene.
\q1 
\v 11 Mathaai Jehova o na hinya wake;
\q2 mũmaathage ũthiũ wake hĩndĩ ciothe.
\q1 
\v 12 Ririkanai magegania marĩa ekĩte,
\q2 na ciama ciake, na matuĩro ma ciira marĩa atuĩte,
\q1 
\v 13 inyuĩ njiaro cia Isiraeli ndungata yake,
\q2 o inyuĩ ciana cia Jakubu, inyuĩ andũ ake arĩa athuurĩte.
\b
\q1 
\v 14 Jehova nĩwe Ngai witũ;
\q2 matuĩro make ma ciira marĩ thĩ yothe.
\q1 
\v 15 Nĩaririkanaga kĩrĩkanĩro gĩake nginya tene,
\q2 nĩkĩo kiugo kĩrĩa aathanire, kĩrũmagĩrĩrwo nĩ njiarwa ngiri,
\q1 
\v 16 kĩrĩkanĩro kĩrĩa aarĩkanĩire na Iburahĩmu,
\q2 na noguo mwĩhĩtwa ũrĩa eehĩtire harĩ Isaaka.
\q1 
\v 17 Nĩagĩĩkĩrire hinya harĩ Jakubu kĩrĩ kĩrĩra gĩake kĩa watho wa kũrũmagĩrĩrwo,
\q2 agĩgĩĩkĩra hinya kũrĩ Isiraeli kĩrĩ kĩrĩkanĩro gĩa gũtũũra tene na tene, akiuga atĩrĩ:
\q1 
\v 18 “Wee nĩwe ngaahe bũrũri wa Kaanani,
\q2 ũtuĩke igai rĩrĩa ũkaagaya.”
\b
\q1 
\v 19 Hĩndĩ ĩrĩa maarĩ o anini magĩtarwo,
\q2 o anini biũ, na maarĩ ageni kuo-rĩ,
\q1 
\v 20 moorũũraga kuuma rũrĩrĩ rũmwe nginya rũrĩa rũngĩ,
\q2 na kuuma ũthamaki-inĩ ũmwe nginya ũrĩa ũngĩ.
\q1 
\v 21 Ndarĩ mũndũ o na ũmwe etĩkĩririe amanyariire;
\q2 nĩarũithirie athamaki nĩ ũndũ wao, akĩmeera atĩrĩ:
\q1 
\v 22 “Mũtikanahutie andũ arĩa akwa aitĩrĩrie maguta;
\q2 mũtikaneke anabii akwa ũũru.”
\b
\q1 
\v 23 Inĩrai Jehova, inyuĩ andũ a thĩ yothe;
\q2 mũhunjagie ũhonokio wake mũthenya o mũthenya.
\q1 
\v 24 Umbũrai riiri wake kũrĩ ndũrĩrĩ,
\q2 mumbũre mawĩko make ma magegania kũrĩ andũ othe.
\q1 
\v 25 Nĩgũkorwo Jehova nĩ mũnene, na nĩ wa kũgoocwo mũno;
\q2 nĩwe wa gwĩtigĩrwo gũkĩra ngai ciothe.
\q1 
\v 26 Nĩgũkorwo ngai ciothe cia ndũrĩrĩ nĩ mĩhianano,
\q2 no Jehova nĩwe wombire igũrũ.
\q1 
\v 27 Riiri na ũnene irĩ mbere yake;
\q2 hinya na gĩkeno itũũraga gwake.
\q1 
\v 28 Tũũgĩriai Jehova, inyuĩ mĩhĩrĩga ya ndũrĩrĩ,
\q2 mũtũũgĩrie Jehova nĩ ũndũ wa riiri na hinya wake,
\q2 
\v 29 Tũũgĩriai Jehova, nĩ ũndũ wa riiri ũrĩa wagĩrĩire rĩĩtwa rĩake.
\q1 Mũreherei maruta na mũũke mbere yake;
\q2 mũhooe Jehova thĩinĩ wa riiri wa ũtheru wake.
\q1 
\v 30 Inainai mũrĩ mbere yake, inyuĩ andũ a thĩ yothe!
\q2 Thĩ ĩhaandĩtwo ĩkarũma; ndĩngĩenyenyeka.
\q1 
\v 31 Igũrũ nĩ rĩkene, thĩ nĩĩcanjamũke;
\q2 nakuo ndũrĩrĩ-inĩ nĩ kuugwo atĩrĩ, “Jehova nĩwe ũthamakaga!”
\q1 
\v 32 Iria nĩ rĩrurume, na indo iria ciothe irĩ thĩinĩ warĩo;
\q2 mĩgũnda nĩĩkenerũrũke na indo iria ciothe irĩ thĩinĩ wayo!
\q1 
\v 33 Hĩndĩ ĩyo mĩtĩ ya mĩtitũ nĩĩkaina;
\q2 ĩine nĩ gũkena ĩrĩ mbere ya Jehova,
\q2 nĩgũkorwo nĩarooka gũciirithia thĩ.
\b
\q1 
\v 34 Cookeriai Jehova ngaatho, nĩgũkorwo nĩ mwega;
\q2 wendo wake ũtũũraga nginya tene.
\q1 
\v 35 Anĩrĩrai muuge atĩrĩ, “Tũhonokie, Wee Ngai Mũhonokia witũ;
\q2 tũcookanĩrĩrie na ũtũkũũre kuuma kũrĩ ndũrĩrĩ,
\q1 nĩguo tũcookagĩrie rĩĩtwa rĩaku itheru ngaatho,
\q2 nĩgeetha twĩrahage nĩ ũndũ wa ũgooci waku.”
\q1 
\v 36 Jehova arogoocwo, o we Ngai wa Isiraeli,
\q2 kuuma tene na tene, nginya tene na tene.
\m Nao andũ othe makiuga atĩrĩ, “Ameni” na “Goocai Jehova.”
\p 
\v 37 Daudi agĩtiga Asafu na athiritũ ake hau mbere ya ithandũkũ rĩa kĩrĩkanĩro kĩa Jehova nĩguo matungatage kuo hĩndĩ ciothe, kũringana na mabata ma o mũthenya.
\v 38 O na ningĩ agĩtiga Obedi-Edomu na athiritũ ake mĩrongo ĩtandatũ na anana matungatage hamwe nao. Obedi-Edomu mũrũ wa Jeduthuni marĩ na Hosa maarĩ arangĩri a kĩhingo.
\p 
\v 39 Daudi agĩtiga Zadoku ũrĩa mũthĩnjĩri-Ngai hamwe na athĩnjĩri-Ngai arĩa angĩ hau mbere ya hema ĩrĩa nyamũre,\f + \fr 16:39 \ft Gĩikaro kĩa Jehova no kĩo Hema ĩrĩa yaakĩtwo werũ-inĩ harĩa magongona maarutagĩrwo.\f* kũndũ kũrĩa gũtũũgĩru kũu Gibeoni,
\v 40 nĩguo marutagĩre Jehova maruta ma njino kĩgongona-inĩ kĩa maruta ma njino hĩndĩ ciothe, rũciinĩ na hwaĩ-inĩ, kũringana na ũrĩa kwandĩkĩtwo watho-inĩ wa Jehova ũrĩa aaheete andũ a Isiraeli.
\v 41 Arĩa maarĩ hamwe nao nĩ Hemani na Jeduthuni, na arĩa angĩ maarĩ athuure na makagwetwo na marĩĩtwa nĩgeetha macookagĩrie Jehova ngaatho, makiugaga atĩrĩ, “Tondũ wendo wake ũtũũraga nginya tene.”
\v 42 Hemani na Jeduthuni nĩo meehokeirwo kũhuha tũrumbeta, na kũhũũrithania thaani iria ihũũrithanagio ikagamba, o na kũhũũraga inanda iria ingĩ cia kũina rwĩmbo rwamũre. Ariũ a Jeduthuni nĩo maaheirwo wĩra wa kũrangĩra kĩhingo.
\p 
\v 43 Hĩndĩ ĩyo andũ othe magĩthiĩ o mũndũ gwake mũciĩ, nake Daudi agĩcooka mũciĩ akarathime andũ a nyũmba yake.
\c 17
\s1 Kĩĩranĩro kĩa Ngai kũrĩ Daudi
\p 
\v 1 Thuutha wa Daudi gũikara nyũmba yake ya ũthamaki kwa ihinda, akĩĩra mũnabii Nathani atĩrĩ, “Niĩ njikaraga nyũmba ya ũthamaki yakĩtwo na mĩtarakwa, o rĩrĩa ithandũkũ rĩa kĩrĩkanĩro kĩa Jehova rĩigĩtwo hema-inĩ.”
\p 
\v 2 Nathani agĩcookeria Daudi atĩrĩ, “Ũndũ ũrĩa ũreciiria gwĩka-rĩ, wĩke, nĩgũkorwo Ngai arĩ hamwe nawe.”
\v 3 Ũtukũ ũcio kiugo kĩa Ngai gĩgĩkinyĩra Nathani, akĩĩrwo atĩrĩ:
\b
\pm 
\v 4 “Thiĩ ũkeere ndungata yakwa Daudi atĩrĩ, ‘Jehova ekuuga ũũ: Wee tiwe wa kũnjakĩra nyũmba ya gũtũũra.
\v 5 Niĩ ndirĩ ndatũũra nyũmba kuuma mũthenya ũrĩa ndaarutire andũ a Isiraeli kuuma bũrũri wa Misiri nginya ũmũthĩ. Ndũũraga hema-inĩ, thaamaga kuuma handũ hamwe ngathiĩ harĩa hangĩ, ngoima gĩikaro kĩmwe ngathiĩ kĩrĩa kĩngĩ.
\v 6 Kũrĩa guothe ndaanathiĩ na andũ a Isiraeli othe-rĩ, ndĩ ndooria mũtongoria o na ũmwe wa arĩa ndaathire marĩithagie andũ akwa atĩrĩ, “Mwagĩte kũnjakĩra nyũmba ya mĩtarakwa nĩkĩ?” ’
\pm 
\v 7 “Na rĩrĩ, ĩra ndungata yakwa Daudi atĩrĩ, ‘Jehova Mwene-Hinya-Wothe ekuuga ũũ: Ndaakũrutire rũũru-inĩ, ngĩgũtigithia kũrũmĩrĩra mahiũ nĩguo ũtuĩke mwathi wa andũ akwa a Isiraeli.
\v 8 Nĩngoretwo nawe kũrĩa guothe wanathiĩ, na ngakwehereria thũ ciaku ciothe ikehera mbere yaku. Rĩu nĩngũtũma rĩĩtwa rĩaku rĩtuĩke inene o ta marĩĩtwa ma andũ arĩa anene mũno a thĩ.
\v 9 Na nĩngaahe andũ akwa a Isiraeli handũ na ndĩmahaande wega nĩgeetha magĩe na mũciĩ wao kĩũmbe, na matigacooka gũthĩĩnĩka. Andũ aaganu matigacooka kũmahinyĩrĩria rĩngĩ, ta ũrĩa meekaga kĩambĩrĩria-inĩ
\v 10 na matũire meekaga kuuma rĩrĩa ndathuurire atongoria a gũtongoragia andũ akwa a Isiraeli. O na nĩngatooria thũ cianyu ciothe.
\pm “ ‘Na ningĩ ngũkwĩra atĩ Jehova we mwene nĩwe ũgũgwakĩra nyũmba:
\v 11 Hĩndĩ ĩrĩa matukũ maku magaathira nawe ũthiĩ ũgatũũranie na maithe manyu, nĩngarũgamia mũndũ wa rũciaro rwaku athamake ithenya rĩaku, agaakorwo arĩ ũmwe wa ariũ aku, na nĩngahaanda ũthamaki wake.
\v 12 Ũcio nĩwe ũkaanjakĩra nyũmba, na nĩngahaanda gĩtĩ gĩake kĩa ũnene nginya tene.
\v 13 Nĩngatuĩka ithe, nake nĩagatuĩka mũrũ wakwa. Ndikeheria wendo wakwa harĩ we, ta ũrĩa ndehereirie ũrĩa warĩ mbere yaku.
\v 14 Nĩngamũtua mwathi wa nyũmba yakwa na ũthamaki wakwa nginya tene; gĩtĩ gĩake kĩa ũnene gĩkehaanda nginya tene.’ ”
\p 
\v 15 Nathani akĩmenyithia Daudi ũhoro wa ũguũrio ũcio wothe.
\s1 Ihooya rĩa Daudi
\p 
\v 16 Nake Mũthamaki Daudi agĩtoonya, agĩikara thĩ mbere ya Jehova, akiuga atĩrĩ:
\b
\pm “Niĩ ndĩkĩrĩ ũ, Wee Jehova Ngai, nayo nyũmba yakwa-rĩ, ĩkĩrĩ kĩ, atĩ nĩkĩo ũnginyĩtie nginya haha?
\v 17 Na ta ũndũ ũcio ũrĩ o mũnini maitho-inĩ maku, Wee Ngai-rĩ, nĩwarĩtie ũhoro wa matukũ marĩa magooka makoniĩ nyũmba ya ndungata yaku. Na rĩu Wee Jehova Ngai, ũnyonete ta ndĩ mũndũ ũmwe wa arĩa atũũgĩrie mũno.
\pm 
\v 18 “Nĩ atĩa ũngĩ Daudi angĩkwĩra nĩ ũndũ wa gũtĩĩa ndungata yaku? Nĩgũkorwo nĩũũĩ ndungata yaku, Wee Jehova.
\v 19 Nĩ ũndũ wa ndungata yaku na kũringana na wendo waku-rĩ, nĩwĩkĩte ũndũ ũyũ mũnene na ũgatũma ciĩranĩro ici nene imenyeke.
\pm 
\v 20 “Gũtirĩ ũngĩ ũhaana tawe, Wee Jehova, na gũtirĩ Ngai ũngĩ tiga Wee, o ta ũrĩa tũiguĩte na matũ maitũ.
\v 21 Na nũũ ũhaana ta andũ aku a Isiraeli, rũrĩrĩ rũmwe gũkũ thĩ rũrĩa Ngai waruo aakũũrire rũtuĩke andũ ake, nĩgeetha wĩgĩĩre igweta, na wĩke maũndũ manene na ma magegania ma gwĩtigĩrwo, nĩ ũndũ wa kũingata ndũrĩrĩ ciehere mbere ya andũ aku arĩa wakũũrire kuuma bũrũri wa Misiri?
\v 22 Watũmire andũ aku a Isiraeli matuĩke andũ aku mwene nginya tene, nawe, Wee Jehova, nĩũtuĩkĩte Ngai wao.
\pm 
\v 23 “Na rĩrĩ, Jehova, tũma kĩĩranĩro kĩrĩa weranĩire gĩkoniĩ ndungata yaku na nyũmba yake kĩrũme nginya tene. Na wĩke o ta ũguo wĩranĩire,
\v 24 nĩgeetha kĩĩranĩro kĩu kĩĩhaande, narĩo rĩĩtwa rĩaku rĩnenehe nginya tene. Ningĩ andũ nĩmakoiga atĩrĩ, ‘Jehova Mwene-Hinya-Wothe, Ngai wa Isiraeli, nĩwe Ngai wa andũ a Isiraeli!’ Na nyũmba ya ndungata yaku Daudi nĩĩkehaanda mbere yaku.”
\pm 
\v 25 “Wee Ngai wakwa, nĩũguũrĩirie ndungata yaku atĩ nĩũkamĩakĩra nyũmba. Nĩ ũndũ ũcio ndungata yaku nĩĩgĩĩte na ũmĩrĩru wa gũkũhooya.
\v 26 Wee Jehova, nĩwe Ngai! Nĩwĩrĩire ndungata yaku maũndũ maya mega.
\v 27 Rĩu nĩwonete kwagĩrĩire ũrathime nyũmba ya ndungata yaku, nĩgeetha ĩtũũre nginya tene maitho-inĩ maku; nĩgũkorwo, Wee Jehova nĩũmĩrathimĩte, na ĩgũtũũra ĩrĩ ndaathime nginya tene.”
\c 18
\s1 Ũhootani wa Daudi
\p 
\v 1 Thuutha wa mahinda macio, Daudi nĩatharĩkĩire Afilisti na akĩmatooria biũ, na agĩtunyana Gathu na matũũra marĩa maarĩrigiicĩirie kuuma watho-inĩ wa Afilisti.
\p 
\v 2 O na ningĩ Daudi nĩahootire andũ a Moabi, na magĩtuĩka a gwathwo nĩwe, makamũrutagĩra igooti.
\p 
\v 3 Ningĩ Daudi nĩahũũranire na Hadadezeri mũthamaki wa Zoba, akĩmũingata akĩmũkinyia Hamathu, rĩrĩa mũthamaki ũcio aathiiaga gũtũma wathani wake ũrũme wega ndwere-inĩ cia Rũũĩ rwa Farati.
\v 4 Daudi akĩmũtunya ngaari ciake cia ita ngiri ĩmwe, na andũ a gũcitwara ngiri mũgwanja, na thigari cia magũrũ ngiri mĩrongo ĩĩrĩ. Nake agĩtemenga mbarathi icio cia mbaara magũrũ, agĩcithuithia ciothe tiga o igana rĩmwe.
\p 
\v 5 Rĩrĩa Asuriata a kuuma Dameski mookire gũteithia Hadadezeri mũthamaki wa Zoba, Daudi akĩũraga Asuriata 22,000.
\v 6 Akĩiga mbũtũ ciake cia kũrangĩra ũthamaki wa Asuriata kũu Dameski, nao Asuriata magĩtuĩka a gwathagwo nĩwe na makamũrutagĩra igooti. Jehova nĩaheire Daudi ũhootani kũrĩa guothe aathiiaga.
\p 
\v 7 Daudi nĩatunyanire ngo cia thahabu iria ciarĩ na anene a Hadadezeri, na agĩcitwara Jerusalemu.
\v 8 Kuuma matũũra ma Teba na Kuni marĩa maarĩ ma Hadadezeri, Daudi agĩtunyana gĩcango kĩingĩ mũno kĩrĩa Solomoni aahũthĩrire gũthondeka Karia ga gĩcango, na itugĩ, na mĩthemba mĩingĩ ya indo cia gĩcango.
\p 
\v 9 Rĩrĩa Tou, mũthamaki wa Hamathu, aiguire atĩ Daudi nĩahootete mbũtũ ciothe cia mbaara cia Hadadezeri mũthamaki wa Zoba-rĩ,
\v 10 agĩtũma mũriũ Hadoramu kũrĩ Mũthamaki Daudi akamũgeithie na amũkũngũĩre nĩ ũndũ wa kũhoota Hadadezeri ũrĩa wakoretwo akĩrũa na Tou. Hadoramu agĩtwarĩra Daudi indo cia mĩthemba mĩingĩ ithondeketwo na thahabu na betha na gĩcango.
\p 
\v 11 Mũthamaki Daudi akĩamũrĩra Jehova indo icio o ta ũrĩa aamũrĩte betha na thahabu iria aatahĩte kuuma kũrĩ andũ a ndũrĩrĩ ici ciothe: Edomu, na Moabi, na kuuma kũrĩ Amoni na Afilisti, na Amaleki.
\p 
\v 12 Abishai mũrũ wa Zeruia nĩooragire andũ a Edomu 18,000 o kũu Gĩtuamba-inĩ gĩa Cumbĩ.
\v 13 Nake akĩiga mbũtũ cia kũrangĩra kũu Edomu nao andũ a Edomu othe magĩtuĩka a gwathagwo nĩ Daudi. Jehova nĩaheire Daudi ũhootani kũrĩa guothe aathiiaga.
\s1 Ndungata cia Daudi
\p 
\v 14 Daudi nĩathamakire Isiraeli guothe, akahũthagĩra kĩhooto, na akahingĩria andũ ake othe maũndũ marĩa maagĩrĩire.
\v 15 Joabu mũrũ wa Zeruia nĩwe warĩ mũnene wa ita, nake Jehoshafatu mũrũ wa Ahiludu nĩwe warĩ mwandĩki wa maũndũ ma ihinda rĩu.
\v 16 Zadoku mũrũ wa Ahitubu, na Ahimeleku mũrũ wa Abiatharu maarĩ athĩnjĩri-Ngai, nake Shavisha nĩwe warĩ mwandĩki-marũa;
\v 17 Benaia mũrũ wa Jehoiada nĩwe warĩ mũnene wa Akerethi na Apelethi; nao ariũ a Daudi nĩo maarĩ atongoria na anene a gũikaranagia na mũthamaki.
\c 19
\s1 Mbaara ya Kũhũũrana na Aamoni
\p 
\v 1 Thuutha wa mahinda macio-rĩ, Nahashu mũthamaki wa Aamoni agĩkua, nake mũriũ agĩtuĩka mũthamaki ithenya rĩake.
\v 2 Nake Daudi agĩĩciiria atĩrĩ, “Nĩngwĩka Hanuni mũrũ wa Nahashu maũndũ mega ma ũtugi tondũ ithe nĩanjĩkire maũndũ mega ma ũtugi.” Nĩ ũndũ ũcio Daudi agĩtũma andũ kũrĩ Hanuni makamũcakaithie nĩ ũndũ wa gũkuĩrwo nĩ ithe.
\p Rĩrĩa andũ acio maatũmĩtwo nĩ Daudi maakinyire kũrĩ Hanuni o kũu bũrũri wa Amoni nĩguo mamũcakaithie-rĩ,
\v 3 andũ arĩa maarĩ igweta a Amoni makĩũria Hanuni atĩrĩ, “Ũreciiria Daudi nĩ thoguo aratĩĩa nĩ ũndũ wa gũgũtũmĩra andũ magũcakaithie? Githĩ andũ ake matiũkĩte kũrĩ we matuĩrie na mathigaane bũrũri nĩguo macooke maũtunyane?”
\v 4 Nĩ ũndũ ũcio Hanuni akĩnyiitithia andũ acio a Daudi, akĩmenjithia nderu, nacio nguo ciao igĩtinio irima gatagatĩ ka njikarĩro, na akĩmaingata.
\p 
\v 5 Rĩrĩa mũndũ ũmwe aakinyĩirie Daudi ũhoro wa andũ acio-rĩ, Daudi agĩtũma andũ makamatũnge, tondũ andũ acio nĩmaconorithĩtio mũno. Mũthamaki akiuga atĩrĩ, “Ikarai kũu Jeriko nginya nderu cianyu ikũre, mũcooke mũũke.”
\p 
\v 6 Rĩrĩa andũ a Amoni maamenyire atĩ nĩmatuĩkĩte kĩndũ kĩnungu harĩ Daudi-rĩ, Hanuni na andũ a Amoni makĩneana betha taranda ngiri ĩmwe\f + \fr 19:6 \ft nĩ ta tani 34\f* cia gũkombora ngaari cia ita na atwarithia a cio kuuma Mesopotamia, na Aramu-Maaka, na Zoba.
\v 7 Magĩkombora ngaari cia ita ngiri mĩrongo ĩtatũ na igĩrĩ na atwarithia a cio, hamwe na mũthamaki wa Maaka na mbũtũ ciake, arĩa mookire makĩamba hema hakuhĩ na Medeba; hĩndĩ ĩyo andũ a Amoni nao magĩcookanĩrĩrio kuuma matũũra-inĩ mao, magĩthiĩ kũrũa mbaara.
\p 
\v 8 Nake Daudi aigua ũhoro ũcio-rĩ, agĩtũma Joabu na ita rĩothe rĩa mbaara.
\v 9 Nao andũ a Amoni makiumagara, makĩarania mbũtũ cia mbaara kĩhingo-inĩ gĩa itũũra rĩao inene, nao athamaki arĩa mookĩte mbaara, magĩkorwo maarĩ oiki kũu werũ-inĩ.
\p 
\v 10 Joabu nĩonire atĩ thigari nĩciaranĩtio mbere yake o na thuutha wake; nĩ ũndũ ũcio agĩthuura mbũtũ imwe iria njega mũno kũu Isiraeli, agĩcitũma ikarũe na Asuriata.
\v 11 Andũ acio angĩ akĩmaiga watho-inĩ wa Abishai mũrũ wa nyina. Nao akĩmatũma makarũe na andũ a Amoni.
\v 12 Joabu akiuga atĩrĩ, “Asuriata mangĩngĩria hinya-rĩ, wee ũũke ũndeithie; no Aamoni mangĩgũkĩria hinya, nĩngagũteithia.
\v 13 Wĩyũmĩrĩrie nĩgeetha tũrũe na ũcamba nĩ ũndũ wa andũ aitũ, na nĩ ũndũ wa matũũra manene ma Ngai witũ. Jehova nĩegwĩka ũrĩa ekuona kwagĩrĩire maitho-inĩ make.”
\p 
\v 14 Nake Joabu arĩ na mbũtũ ciake agĩtharĩkĩra Asuriata, nao makĩmũũrĩra.
\v 15 Rĩrĩa Aamoni moonire atĩ Asuriata nĩmaroora-rĩ, o nao makĩũrĩra Abishai mũrũ wa nyina magĩtoonya itũũra thĩinĩ. Nĩ ũndũ ũcio Joabu agĩcooka Jerusalemu.
\p 
\v 16 Thuutha wa Asuriata kuona atĩ nĩmatoorio nĩ andũ a Isiraeli, magĩtũma andũ makarehithie Asuriata a kuuma mũrĩmo wa Rũũĩ rwa Farati matongoretio nĩ Shofaku ũrĩa warĩ mũnene wa mbũtũ cia ita cia Hadadezeri.
\p 
\v 17 Rĩrĩa Daudi eerirwo ũhoro ũcio, agĩcookanĩrĩria ita rĩa Isiraeli rĩothe, makĩringa Rũũĩ rwa Jorodani, nake akĩmakinyĩra na akĩiga mbũtũ ciake imangʼetheire. Daudi akĩhaarĩria mbũtũ ciake nĩguo itũngane na Asuriata acio mbaara-inĩ, nao Asuriata makĩrũa nake.
\v 18 No rĩrĩ, Asuriata makĩũrĩra Isiraeli, nake Daudi akĩũraga atwarithia a ngaari ciao cia ita ngiri mũgwanja, na thigari ciao cia magũrũ ngiri mĩrongo ĩna. Ningĩ akĩũraga Shofaku, mũnene wa mbũtũ ciao.
\p 
\v 19 Hĩndĩ ĩrĩa ndungata cia Hadadezeri cionire atĩ nĩmahootwo nĩ Isiraeli-rĩ, magĩthondeka thayũ na Daudi, nao magĩtuĩka a gwathagwo nĩwe.
\p Nĩ ũndũ ũcio Asuriata matiacookire gwĩtĩkĩra gũteithia Aamoni rĩngĩ.
\c 20
\s1 Itũũra rĩa Raba Gũtunyanwo
\p 
\v 1 Na rĩrĩ, hĩndĩ ya kĩmera yakinya, ihinda rĩrĩa athamaki maathiiaga mbaara, Joabu agĩtongoria mbũtũ cia ita. Nake akĩananga bũrũri wa Aamoni, na agĩthiĩ Raba akĩrĩrigiicĩria, no Daudi agĩtigwo Jerusalemu. Joabu agĩtharĩkĩra Raba agĩtiga aarĩananga.
\v 2 Daudi akĩruta mũthamaki wao thũmbĩ mũtwe, nayo yarĩ na ũritũ wa taranda ĩmwe\f + \fr 20:2 \ft nĩ ta kilo 34\f* ya thahabu, na nĩyagemetio na tũhiga twa goro, nayo ĩkĩigĩrĩrwo mũtwe wa Daudi. Nake agĩtaha indo nyingĩ mũno kuuma itũũra rĩu inene,
\v 3 na akĩrutũrũra aikari akuo, akĩmahe wĩra wa gwatũra mbaũ na mĩthumeno, na kũruta wĩra na harũ cia igera na mathanwa. Ũguo nĩguo Daudi eekire matũũra mothe ma Amoni. Thuutha ũcio Daudi na mbũtũ ciake ciothe cia ita magĩcooka Jerusalemu.
\s1 Kũrũa na Afilisti
\p 
\v 4 Mahinda macio-rĩ, gũkĩgĩa mbaara ya kũrũa na Afilisti kũu Gezeri. Hĩndĩ ĩyo Sibekai ũrĩa Mũhushathi akĩũraga Sipai, ũmwe wa njiaro cia Refai, nao Afilisti magĩtoorio biũ.
\p 
\v 5 Mbaara-inĩ ĩngĩ makĩrũa na Afilisti, nake Elihanani mũrũ wa Jairu akĩũraga Lahami mũrũ wa nyina na Goliathũ, ũrĩa Mũgiiti, ũrĩa warĩ na itimũ rĩarĩ na mũtĩ waiganaga ta mũtĩ wa mũtumi ngoora.
\p 
\v 6 Ningĩ mbaara-inĩ ĩngĩ ĩrĩa yarũĩirwo Gathu, kwarĩ na mũndũ mũnene mũno, warĩ na ciara ithathatũ o guoko, na ciara ithathatũ o kũgũrũ, ciothe ciarĩ ciara mĩrongo ĩĩrĩ na inya. O nake aarĩ wa rũciaro rwa Rafa.
\v 7 Rĩrĩa aanyũrũririe andũ a Isiraeli, Jonathani mũrũ wa Shimea, mũrũ wa nyina na Daudi, akĩmũũraga.
\p 
\v 8 Acio nĩo maarĩ a rũciaro rwa Rafa wa kũu Gathu, nao makĩũragwo nĩ Daudi na andũ ake.
\c 21
\s1 Daudi Gũtara Andũ a Mbaara
\p 
\v 1 Na rĩrĩ, Shaitani nĩookĩrĩire andũ a Isiraeli, na akĩarahũra Daudi nĩguo atarithie andũ a Isiraeli.
\v 2 Nĩ ũndũ ũcio Daudi akĩĩra Joabu na anene a mbũtũ cia ita atĩrĩ: “Thiĩi mũgatare andũ a Isiraeli kuuma Birishiba nginya Dani, mũcooke mũndehere ũhoro nĩguo menye ũrĩa maigana.”
\p 
\v 3 Nowe Joabu akĩmũcookeria atĩrĩ, “Jehova aroingĩhia mbũtũ ciake cia ita maita igana. Mwathi wakwa mũthamaki, githĩ othe matirĩ watho-inĩ waku? Nĩ kĩĩ gĩgũtũma mwathi wakwa ende gwĩka ũguo? Nĩ kĩĩ gĩgũtũma ahĩtithie Isiraeli?”
\p 
\v 4 No rĩrĩ, mũthamaki agĩkararia Joabu; nĩ ũndũ ũcio Joabu akiuma hau agĩthiĩ Isiraeli guothe, na agĩcooka Jerusalemu.
\v 5 Joabu akĩmenyithia Daudi mũigana wa andũ arĩa maangĩarũire mbaara ta ũũ: Isiraeli guothe kwarĩ na andũ 1,100,000 arĩa maangĩahotire kũhũthĩra rũhiũ rwa njora, thĩinĩ wao haarĩ na andũ 470,000 kuuma Juda.
\p 
\v 6 No rĩrĩ, Joabu ndaatarire andũ a Lawi na a Benjamini, tondũ watho ũcio wa mũthamaki nĩwamũiguithĩtie ũũru mũno.
\v 7 O na ningĩ watho ũcio warĩ mũũru maitho-inĩ ma Ngai; nĩ ũndũ ũcio akĩherithia Isiraeli.
\p 
\v 8 Hĩndĩ ĩyo Daudi akĩĩra Ngai atĩrĩ, “Nĩnjĩhĩtie mũno nĩ gwĩka ũndũ ũyũ. Rĩu ndagũthaitha ũnjehererie mahĩtia, niĩ ndungata yaku. Nĩnjĩkĩte ũndũ wa ũrimũ mũno.”
\p 
\v 9 Nake Jehova akĩĩra Gadi ũrĩa woonagĩra Daudi maũndũ atĩrĩ,
\v 10 “Thiĩ ũkeere Daudi ũũ, ‘Jehova ekuuga atĩrĩ: Ũrĩ na maũndũ matatũ ma gũthuura. Nowe ũthuure ũmwe wamo ũrĩa ngũkũherithia naguo.’ ”
\p 
\v 11 Nĩ ũndũ ũcio Gadi agĩthiĩ kũrĩ Daudi, akĩmwĩra atĩrĩ, “Jehova ekuuga ũũ: ‘Thuura ũndũ ũmwe wa maya:
\v 12 Ũthuure mĩaka ĩtatũ ya ngʼaragu, kana mĩeri ĩtatũ ya kũniinwo nĩ thũ ciaku igũthingatĩte na hiũ ciao cia njora, kana mĩthenya ĩtatũ ya rũhiũ rwa njora rwa Jehova, naguo nĩ atĩ kũgĩe na mĩthenya ya mũthiro bũrũri-inĩ, rĩrĩa mũraika wa Jehova akaaniinana Isiraeli guothe.’ Na rĩrĩ, tua itua ũnjĩĩre ũrĩa ngũthiĩ gũcookeria ũrĩa ũndũmĩte.”
\p 
\v 13 Daudi akĩĩra Gadi atĩrĩ, “Rĩu niĩ ndĩ na thĩĩna mũno. Nĩ kaba niĩ ngwe moko-inĩ ma Jehova, tondũ tha ciake nĩ nyingĩ mũno; no ndũkareke ngwe moko-inĩ ma andũ.”
\p 
\v 14 Nĩ ũndũ ũcio Jehova akĩrehera Isiraeli mũthiro, na andũ a Isiraeli 70,000 magĩkua.
\v 15 Nake Ngai agĩtũma mũraika akanange Jerusalemu. No rĩrĩa mũraika ekaga ũguo-rĩ, Jehova akĩona ũndũ ũcio na akĩigua kĩeha nĩ ũndũ wa kĩnyariirĩko kĩu, nake akĩĩra mũraika ũcio wanangaga andũ atĩrĩ, “Tigĩra hau! Eheria guoko gwaku.” Hĩndĩ ĩyo mũraika ũcio wa Jehova aarũgamĩte kĩhuhĩro-inĩ kĩa ngano kĩa Arauna ũrĩa Mũjebusi.
\p 
\v 16 Nake Daudi akĩrora igũrũ akĩona mũraika wa Jehova arũngiĩ gatagatĩ ka igũrũ na thĩ acomorete rũhiũ rwa njora, arũnyiitĩte na guoko gwake gũtambũrũkĩirio Jerusalemu. Nake Daudi na athuuri, mehumbĩte nguo cia makũnia, makĩgũa magĩturumithia mothiũ mao thĩ.
\p 
\v 17 Daudi akĩũria Ngai atĩrĩ, “Githĩ ti niĩ ndaathanire atĩ arũi a mbaara matarwo? Niĩ nĩ niĩ njĩhĩtie o na ngeeka ũũru. Andũ aya matariĩ o ta ngʼondu. Nĩ atĩa mekĩte? Wee Jehova Ngai wakwa, reke guoko gwaku kũnjũkĩrĩre niĩ na nyũmba yakwa, no rĩrĩ, ndũkareke mũthiro ũyũ ũikare na andũ aku.”
\p 
\v 18 Nake mũraika wa Jehova agĩatha Gadi eere Daudi aambate athiĩ agaakĩre Jehova kĩgongona o kũu kĩhuhĩro-inĩ kĩa ngano kĩa Arauna ũrĩa Mũjebusi.
\v 19 Nĩ ũndũ ũcio Daudi akĩambata agĩathĩkĩra kiugo kĩu Gadi aarĩtie thĩinĩ wa rĩĩtwa rĩa Jehova.
\p 
\v 20 Hĩndĩ ĩrĩa Arauna aakonyoraga ngano-rĩ, akĩĩhũgũra akĩona mũraika ũcio; nao ariũ ake ana arĩa maarĩ nake makĩĩhitha.
\v 21 Nake Daudi agĩkuhĩrĩria, na rĩrĩa Arauna aarorire akĩmuona, akiuma kĩhuhĩro-inĩ kĩa ngano, akĩinamĩrĩria mũtwe wake mbere ya Daudi, na agĩturumithia ũthiũ thĩ.
\p 
\v 22 Daudi akĩmwĩra atĩrĩ, “Njĩtĩkĩria njakĩre Jehova kĩgongona haha kĩhuhĩro-inĩ gĩkĩ gĩaku kĩa ngano, nĩguo mũthiro ũyũ ũkorete andũ ũthire. Nyenderia o ũrĩa thogora wakĩo ũigana.”
\p 
\v 23 Arauna akĩĩra Daudi atĩrĩ, “Kĩoe! Reke mũthamaki mwathi wakwa eeke ũndũ ũrĩa ũngĩmũkenia. Na rĩrĩ, nĩngũkũhe ndegwa ici irutwo igongona rĩa njino, ihũũri ici cia ngano ituĩke ngũ, ngano nayo ĩtuĩke ya igongona rĩa mũtu. Icio ciothe nĩngũkũhe.”
\p 
\v 24 Nowe Mũthamaki Daudi agĩcookeria Arauna atĩrĩ, “Aca, no nginya ndĩhe thogora wakĩo ũrĩa ũigana. Ndingĩrutĩra Jehova kĩndũ gĩaku, kana ndute igongona rĩa njino na kĩndũ kĩrĩa itarutĩire thogora.”
\p 
\v 25 Nĩ ũndũ ũcio Daudi akĩrĩha Arauna cekeri magana matandatũ\f + \fr 21:25 \ft nĩ ta kilo 7\f* cia thahabu nĩ ũndũ wa handũ hau.
\v 26 Daudi agĩakĩra Jehova kĩgongona handũ hau, na akĩruta maruta ma njino na maruta ma ũiguano. Agĩkaĩra Jehova, nake Jehova akĩmwĩtĩka na njĩra ya mwaki uumĩte igũrũ, ũgĩakana kĩgongona-inĩ kĩu kĩa maruta ma njino.
\p 
\v 27 Ningĩ Jehova akĩarĩria mũraika ũcio nake agĩcookia rũhiũ rwake njora.
\v 28 Hĩndĩ ĩyo, rĩrĩa Daudi onire atĩ Ngai nĩamũiguĩte arĩ kũu kĩhuhĩro-inĩ kĩa ngano kĩa Arauna ũcio Mũjebusi-rĩ, akĩrutĩra magongona hau.
\v 29 Hema ya Jehova ĩrĩa nyamũre ĩrĩa Musa aathondekeire werũ-inĩ, na kĩgongona kĩa maruta ma njino, hĩndĩ ĩyo ciarĩ harĩa hatũũgĩru o kũu Gibeoni.
\v 30 No rĩrĩ, Daudi ndangĩathiire mbere yakĩo gũtuĩria ũhoro harĩ Ngai tondũ nĩetigagĩra rũhiũ rwa njora rwa mũraika ũcio wa Jehova.
\c 22
\p 
\v 1 Hĩndĩ ĩyo Daudi akiuga atĩrĩ, “Nyũmba ya Jehova Ngai ĩgaakwo haha, o na kĩgongona gĩa kũrutagĩrwo maruta ma njino nĩ Isiraeli.”
\s1 Kũhaarĩria Mwako wa Hekarũ
\p 
\v 2 Nĩ ũndũ ũcio Daudi agĩathana atĩ ageni othe arĩa maatũũraga Isiraeli\f + \fr 22:2 \ft Ageni aya maarĩ njiaro cia andũ a Kaanani arĩa maatũũraga kuo mbere ya gũtoorio nĩ Aisiraeli.\f* macookanĩrĩrio, nake agĩthuura kuuma thĩinĩ wao mabundi a mahiga, nĩgeetha mahaarĩrie na maicũhie mahiga ma gwaka nyũmba ya Ngai.
\v 3 Nake akĩruta igera nyingĩ cia gũthondeka mĩcumarĩ ya mĩrango ya ihingo na ya kũnyiitithania indo cia nyũmba thĩinĩ, na gĩcango kĩingĩ gĩtangĩthimĩka.
\v 4 Ningĩ akĩruta mĩgogo ya mĩtarakwa ĩtangĩtarĩka, nĩgũkorwo andũ a Sidoni na a Turo nĩmareheire Daudi mĩgogo mĩingĩ.
\p 
\v 5 Daudi akiuga atĩrĩ, “Mũriũ wakwa Solomoni nĩ mwĩthĩ na ndarĩ na ũũgĩ wa kũigana, nayo nyũmba ĩrĩa ĩgwakĩrwo Jehova yagĩrĩirwo nĩgũkorwo ĩrĩ na ũthaka mũnene na ngumo na riiri maitho-inĩ ma ndũrĩrĩ ciothe. Nĩ ũndũ ũcio nĩ ngũhaarĩria mwako wayo.” Nĩ ũndũ ũcio Daudi akĩhaarĩria maũndũ ma mwako ũcio na njĩra nene atanakua.
\p 
\v 6 Ningĩ agĩĩta mũriũ Solomoni akĩmwatha aakĩre Jehova Ngai wa Isiraeli nyũmba.
\v 7 Daudi akĩĩra Solomoni ũũ: “Mũrũ wakwa, ndũire nyendaga gwaka nyũmba ĩtanĩtio na rĩĩtwa rĩa Jehova Ngai wakwa.
\v 8 No rĩrĩ, kiugo gĩkĩ kĩa Jehova gĩkĩnginyĩrĩra, ngĩĩrwo atĩrĩ, ‘Wee nĩũitĩte thakame nyingĩ na ũkarũa mbaara nyingĩ. Ndũgwaka nyũmba ĩtanĩtio na rĩĩtwa rĩakwa, nĩ ũndũ nĩũitithĩtie thakame nyingĩ gũkũ thĩ, maitho-inĩ makwa.
\v 9 No nĩũkagĩa na mũriũ ũrĩa ũgaatuĩka mũndũ wa thayũ na wa kũhoorera, na nĩngamũhe ũhurũko kuuma kũrĩ thũ ciake mĩena yothe. Rĩĩtwa rĩake ageetwo Solomoni, na hĩndĩ ya ũthamaki wake nĩngaahe Isiraeli thayũ na ũhurũko.
\v 10 Ũcio nĩwe ũgaaka nyũmba ĩtanĩtio na Rĩĩtwa rĩakwa. Agaatuĩka mũrũ wakwa, na niĩ nduĩke ithe. Ningĩ nĩngahaanda gĩtĩ kĩa ũnene wake kũu Isiraeli nginya tene.’
\p 
\v 11 “Na rĩrĩ, mũrũ wakwa, Jehova aroikara nawe, na ũrogaacĩra na wake nyũmba ya Jehova Ngai waku, ta ũrĩa oigire nĩũgeeka.
\v 12 Jehova arokũhe ũbaarĩrĩri na ũmenyo rĩrĩa agaakũnengera ũthamaki wa Isiraeli, nĩgeetha ũrũmie watho wa Jehova Ngai waku.
\v 13 Hĩndĩ ĩyo wee nĩũkagaacĩra, ũngĩgatuĩka wa kũmenyagĩrĩra kĩrĩra kĩa watho wake wa kũrũmĩrĩrwo o na watho ũrĩa Jehova aaheire Musa nĩ ũndũ wa Isiraeli. Gĩa na hinya na ũmĩrĩrie. Ndũgetigĩre kana ũkue ngoro.
\p 
\v 14 “Nĩndutĩte wĩra mũnene wa kũhaarĩria mwako wa hekarũ ya Jehova, ngaigithia taranda 100,000\f + \fr 22:14 \ft nĩ ta tani 3,450\f* cia thahabu, na taranda 1,000,000\f + \fr 22:14 \ft nĩ ta tani 34,500\f* cia betha, na icango nyingĩ na igera nyingĩ itangĩthimĩka, na mbaũ na mahiga. Nawe no wongerere ingĩ.
\v 15 Ũrĩ na aruti wĩra aingĩ: aicũhia a mahiga, na aaki a mahiga, na aaki a mbaũ, o hamwe na andũ marĩ na ũũgĩ wa kũruta wĩra o wothe
\v 16 wa thahabu na wa betha, na wa gĩcango na wa igera, na mabundi maingĩ makĩria. Rĩu kĩambĩrĩrie wĩra, nake Jehova aroikara hamwe nawe.”
\p 
\v 17 Hĩndĩ ĩyo Daudi agĩatha atongoria othe a Isiraeli mateithie mũriũ Solomoni.
\v 18 Akĩmeera atĩrĩ, “Githĩ Jehova Ngai wanyu ndarĩ hamwe na inyuĩ? Na githĩ ndamũheete ũhurũko mĩena yothe? Nĩgũkorwo nĩaneanĩte atũũri a bũrũri ũyũ moko-inĩ makwa, na rĩu bũrũri ũrĩ watho-inĩ wa Jehova na andũ ake.
\v 19 Rĩu mwĩheanei ngoro na muoyo mũcarie Jehova Ngai wanyu. Ambĩrĩriai gwaka handũ-harĩa-haamũre ha Jehova Ngai, nĩgeetha mũrehe ithandũkũ rĩa Jehova rĩa kĩrĩkanĩro na indo iria nyamũre cia Ngai itoonyio hekarũ ĩrĩa ĩgwakwo nĩ ũndũ wa Rĩĩtwa rĩa Jehova.”
\c 23
\s1 Alawii
\p 
\v 1 Na rĩrĩ, rĩrĩa Daudi aakũrire na agĩkorwo arĩ na mĩaka mĩingĩ-rĩ, agĩtua mũriũ Solomoni mũthamaki wa gũthamakĩra Isiraeli.
\p 
\v 2 Ningĩ agĩcookanĩrĩria atongoria othe a Isiraeli hamwe na athĩnjĩri-Ngai na Alawii.
\v 3 Alawii arĩa maakinyĩtie mĩaka mĩrongo ĩtatũ kana makĩria magĩtarwo, nao arũme othe maarĩ 38,000.
\v 4 Daudi akiuga atĩrĩ, “Thĩinĩ wa aya, 24,000 nĩ marũgamagĩrĩre wĩra wa hekarũ ya Jehova, nao 6,000 matuĩke anene na atuithania a ciira.
\v 5 Nao andũ 4,000 matuĩke arangĩri a ihingo, nao acio angĩ 4,000 matuĩke a kũgoocaga Jehova marĩ na inanda cia ũini iria heanĩte nĩ ũndũ wa wĩra ũcio kĩũmbe.”
\p 
\v 6 Daudi nĩagayanirie Alawii acio ikundi kũringana na ariũ a Lawi na nĩo Gerishoni, na Kohathu, na Merari.
\s1 Andũ a Gerishoni
\m 
\v 7 Ariũ a Gerishoni maarĩ:
\li2 Ladani na Shimei.
\li1 
\v 8 Ariũ a Ladani maarĩ:
\li2 Jehieli na nĩwe warĩ mũtongoria wao, na Zethamu, na Joeli; othe maarĩ atatũ.
\li1 
\v 9 Ariũ a Shimei maarĩ:
\li2 Shelomothu, na Hazieli, na Harani, othe maarĩ atatũ.
\li2 Acio nĩo maarĩ atongoria a nyũmba cia Ladani.
\li1 
\v 10 Na ariũ a Shimei maarĩ:
\li2 Jahathu, na Ziza, na Jeushu, na Beria.
\li2 Acio nĩo maarĩ ariũ a Shimei; othe maarĩ ana.
\li2 
\v 11 Jahathu nĩwe warĩ mũtongoria wao, nake Ziza aarĩ mũnini wake, no Jeushu na Beria matiarĩ na ariũ aingĩ; nĩ ũndũ ũcio maatarirwo ta maarĩ a nyũmba ĩmwe, na makĩheo wĩra ũmwe.
\s1 Andũ a Kohathu
\m 
\v 12 Ariũ a Kohathu maarĩ:
\li1 Amuramu, na Iziharu, na Hebironi, na Uzieli: othe maarĩ ana.
\li1 
\v 13 Ariũ a Amuramu maarĩ:
\li2 Harũni na Musa.
\li2 Harũni nĩamũrirwo hamwe na njiaro ciake nginya tene, nĩgeetha maamũrage indo iria theru mũno, na marutagĩre Jehova magongona, na mamũtungatagĩre, na marathimanage thĩinĩ wa rĩĩtwa rĩake nginya tene.
\v 14 Ariũ a Musa, mũndũ wa Ngai, maataranĩirio na mũhĩrĩga wa Lawi.
\li1 
\v 15 Ariũ a Musa maarĩ: Gerishomu na Eliezeri.
\li1 
\v 16 Njiaro cia Gerishomu nĩ:
\li2 Shebueli nĩwe warĩ mũtongoria wao.
\li1 
\v 17 Njiaro cia Eliezeri nĩ:
\li2 Rehabia na nĩwe warĩ mũtongoria wao.
\li2 Eliezeri ndaarĩ na ariũ angĩ, no ariũ a Rehabia maarĩ aingĩ mũno.
\li1 
\v 18 Ariũ a Iziharu maarĩ:
\li2 Shelomithu na nĩwe warĩ mũtongoria wao.
\li1 
\v 19 Ariũ a Hebironi maarĩ:
\li2 Jeria na nĩwe warĩ mũtongoria wao, na Amaria aarĩ wa keerĩ, na Jahazieli aarĩ wa gatatũ, na Jekameamu aarĩ wa kana.
\li1 
\v 20 Ariũ a Uzieli maarĩ:
\li2 Mika na nĩwe warĩ mũtongoria wao, nake Ishia aarĩ mũnini wake.
\s1 Andũ a Merari
\m 
\v 21 Ariũ a Merari maarĩ:
\li2 Mahali na Mushi.
\li1 Ariũ a Mahali maarĩ:
\li2 Eleazaru na Kishu.
\li2 
\v 22 Eleazaru aakuire atarĩ na aanake; aarĩ o na airĩtu. Makĩhikio nĩ ariũ a mũrũ wa nyina na ithe wao Kishu.
\li1 
\v 23 Ariũ a Mushi maarĩ:
\li2 Mahali, na Ederi, na Jeremothu; othe maarĩ atatũ.
\b
\p 
\v 24 Acio nĩo maarĩ njiaro cia Lawi kũringana na nyũmba ciao: na nĩo maarĩ atongoria a nyũmba ciao ta ũrĩa marĩĩtwa mao maandĩkĩtwo, na maatarirwo mũndũ o mũndũ, ũguo nĩ kuuga aruti a wĩra arĩa maarĩ na ũkũrũ wa mĩaka mĩrongo ĩĩrĩ na makĩria, arĩa maatungataga hekarũ-inĩ ya Jehova.
\v 25 Nĩgũkorwo Daudi nĩoigĩte atĩrĩ, “Kuona atĩ Jehova Ngai wa Isiraeli nĩaheete andũ ake ũhurũko, na nĩokĩte gũtũũra Jerusalemu nginya tene-rĩ,
\v 26 Alawii matigũcooka kũbatario nĩgũkuuaga hema ĩrĩa nyamũre kana kĩndũ o nakĩ kĩa iria ihũthagĩrwo cia gũtungata thĩinĩ wayo.”
\v 27 Kũringana na ciugo cia Daudi cia mũthia, Alawii arĩa maarĩ na ũkũrũ wa mĩaka mĩrongo ĩĩrĩ kana makĩria nĩmatarirwo.
\p 
\v 28 Wĩra wa Alawii warĩ wa gũteithia njiaro cia Harũni ũtungata-inĩ wa hekarũ ya Jehova ta ũũ: kũrũgamĩrĩra nja cia hekarũ na tũnyũmba twa ithaku-inĩ, na gũtherithia indo iria nyamũre, na kũruta mawĩra marĩa mangĩ thĩinĩ wa nyũmba ya Ngai.
\v 29 Nĩo maarĩ arũgamĩrĩri a mĩgate ĩrĩa yaigagwo metha-inĩ, na maruta ma mũtu wa ngano, na tũmĩgate tũrĩa tũtarĩ na ndawa ya kũimbia, na wĩra wa gũkanda na kũruga mĩgate, na mawĩra mothe ma gũthima ũingĩ na mũigana wa indo.
\v 30 Ningĩ marũgamage o rũciinĩ gũcookeria Jehova ngaatho na kũmũgooca. Ningĩ magekaga ũguo o hwaĩ-inĩ,
\v 31 na rĩrĩa rĩothe maruta ma njino mangĩarutĩirwo Jehova, mĩthenya ya Thabatũ, na ciathĩ cia Karũgamo ka Mweri, na ciathĩ iria ingĩ ciathanĩtwo. No nginya matungatage mbere ya Jehova mahinda mothe marĩ mũigana ũrĩa ũtuĩtwo, ningĩ na njĩra ĩrĩa maathĩtwo marutage nayo.
\p 
\v 32 Na nĩ ũndũ ũcio Alawii magĩthiĩ na mbere kũruta wĩra ũrĩa mehokeirwo wa Hema-ya-Gũtũnganwo, na wa Handũ-harĩa-Hatheru, matongoretio nĩ ariũ a ithe wao a rũciaro rwa Harũni, nĩ ũndũ wa ũtungata wa hekarũ ya Jehova.
\c 24
\s1 Ikundi Cia Athĩnjĩri-Ngai
\p 
\v 1 Ici nĩcio ciarĩ ikundi cia ariũ a Harũni:
\p Ariũ a Harũni maarĩ Nadabu, na Abihu, na Eleazaru, na Ithamaru.
\v 2 No rĩrĩ, Nadabu na Abihu nĩmakuire ithe wao atakuĩte, na matiarĩ na ciana cia aanake; nĩ ũndũ ũcio Eleazaru na Ithamaru magĩtungata marĩ athĩnjĩri-Ngai.
\v 3 Zadoku wa rũciaro rwa Eleazaru na Ahimeleku wa rũciaro rwa Ithamaru nĩo maateithĩrĩirie Daudi kũmagayania ikundi, nĩ ũndũ wa mũtaratara wa ũtungata ũrĩa maathuurĩirwo.
\v 4 Atongoria arĩa aingĩ moimĩte njiaro-inĩ cia Eleazaru gũkĩra arĩa moimĩte njiaro-inĩ cia Ithamaru, nao makĩgayanio ta ũũ: kuuma njiaro-inĩ cia Eleazaru kwarĩ na atongoria a nyũmba ikũmi na atandatũ, na kuuma njiaro-inĩ cia Ithamaru kwarĩ na atongoria a nyũmba anana.
\v 5 Maamagayanirie na kĩhooto na ũndũ wa gũcuuka mĩtĩ, nĩgũkorwo nĩ haarĩ na anene a handũ-harĩa-haamũre, na anene a nyũmba ya Ngai gatagatĩ-inĩ ka njiaro icio cia Eleazaru na cia Ithamaru.
\p 
\v 6 Shemaia mũrũ wa Nethaneli, ũrĩa mwandĩki-marũa Mũlawii, nĩandĩkire marĩĩtwa mao arĩ mbere ya mũthamaki na anene aya: Zadoku ũrĩa-mũthĩnjĩri-Ngai, na Ahimeleku mũrũ wa Abiatharu, na atongoria a nyũmba cia athĩnjĩri-Ngai na cia Alawii. Nyũmba ĩmwe ĩgathuurwo kuuma kũrĩ Eleazaru, na ĩrĩa ĩngĩ ĩgathuurwo kuuma kũrĩ Ithamaru.
\b
\li1 
\v 7 Mũtĩ wa mbere wagũire kũrĩ Jehoiaribu,
\li1 na wa keerĩ kũrĩ Jedaia,
\li1 
\v 8 na wa gatatũ kũrĩ Harimu,
\li1 na wa kana kũrĩ Seroimu,
\li1 
\v 9 na wa gatano kũrĩ Malikija,
\li1 na wa gatandatũ kũrĩ Mijamini,
\li1 
\v 10 na wa mũgwanja kũrĩ Hakozu,
\li1 na wa kanana kũrĩ Abija,
\li1 
\v 11 na wa kenda kũrĩ Jeshua,
\li1 na wa ikũmi kũrĩ Shekania,
\li1 
\v 12 na wa ikũmi na ũmwe kũrĩ Eliashibu,
\li1 na wa ikũmi na ĩĩrĩ kũrĩ Jakimu,
\li1 
\v 13 na wa ikũmi na ĩtatũ kũrĩ Hupa,
\li1 na wa ikũmi na ĩna kũrĩ Jeshebeabu,
\li1 
\v 14 na wa ikũmi na ĩtano kũrĩ Biliga,
\li1 na wa ikũmi na ĩtandatũ kũrĩ Imeri,
\li1 
\v 15 na wa ikũmi na mũgwanja kũrĩ Heziri,
\li1 na wa ikũmi na ĩnana kũrĩ Hapizezu,
\li1 
\v 16 na wa ikũmi na kenda kũrĩ Pethahia,
\li1 na wa mĩrongo ĩĩrĩ kũrĩ Jehezekeli,
\li1 
\v 17 na wa mĩrongo ĩĩrĩ na ũmwe kũrĩ Jakini,
\li1 na wa mĩrongo ĩĩrĩ na igĩrĩ kũrĩ Gamuli,
\li1 
\v 18 na wa mĩrongo ĩĩrĩ na ĩtatũ kũrĩ Delaia,
\li1 na wa mĩrongo ĩĩrĩ na ĩna kũrĩ Maazia.
\b
\p 
\v 19 Ũyũ nĩguo warĩ mũtaratara wa ũtungata wao rĩrĩa maatoonya hekarũ ya Jehova, kũringana na watho ũrĩa maatuĩrĩirwo nĩ ithe wao Harũni, ta ũrĩa Jehova Ngai wa Isiraeli aamwathĩte.
\s1 Alawii arĩa Angĩ
\m 
\v 20 Njiaro iria ingĩ cia Lawi ciarĩ:
\li1 kuuma kũrĩ ariũ a Amuramu: nĩ Shubaeli;
\li2 na kuuma kũrĩ ariũ a Shubaeli: nĩ Jehedeia.
\li2 
\v 21 Kuuma kũrĩ ariũ a Rehabia:
\li2 nĩ Ishia na nĩwe warĩ mũtongoria wao.
\li1 
\v 22 Kuuma kũrĩ andũ a Iziharu: nĩ Shelomothu;
\li2 na kuuma ariũ a Shelomothu: nĩ Jahathu.
\li1 
\v 23 Ariũ a Hebironi maarĩ: Jeria na nĩwe warĩ mũtongoria wao, Amaria aarĩ wa keerĩ, nake Jahazieli aarĩ wa gatatũ, na Jekameamu aarĩ wa kana.
\li1 
\v 24 Mũrũ wa Uzieli: aarĩ Mika;
\li2 kuuma ariũ a Mika: nĩ Shamiru.
\li2 
\v 25 Mũrũ wa nyina na Mika: aarĩ Ishia;
\li2 kuuma ariũ a Ishia: nĩ Zekaria.
\li1 
\v 26 Ariũ a Merari: maarĩ Mahali na Mushi.
\li2 Mũrũ wa Jaazia: aarĩ Beno.
\li1 
\v 27 Ariũ a Merari:
\li2 kuuma kũrĩ Jaazia: maarĩ Beno, na Shohamu, na Zakuri, na Ibiri.
\li1 
\v 28 kuuma kũrĩ Mahali: nĩ Eleazaru, ũrĩa ũtaarĩ na aanake.
\li1 
\v 29 Kuuma kũrĩ Kishu: nĩ mũriũ Jerameeli.
\li1 
\v 30 Nao ariũ a Mushi: maarĩ Mahali, na Ederi, na Jeremothu.
\b
\p Acio nĩo maarĩ Alawii kũringana na nyũmba ciao.
\v 31 O nao nĩmacuukire mĩtĩ o ta ũrĩa ariũ a ithe wao a rũciaro rwa Harũni meekire, marĩ mbere ya Mũthamaki Daudi o na mbere ya Zadoku, na Ahimeleku, na atongoria a nyũmba cia athĩnjĩri-Ngai na cia Alawii. Nyũmba cia mũrũ wa nyina ũrĩa mũkũrũ ciekirwo o ta ũrĩa nyũmba cia ũrĩa mũnini mũno ciekirwo.
\c 25
\s1 Aini
\p 
\v 1 Daudi arĩ hamwe na anene a mbũtũ cia ita nĩamũrire ariũ amwe a Asafu, na Hemani, na Jeduthuni marutage wĩra wa ũrathi makĩhũũraga inanda cia mũgeeto, na cia kĩnũbi, na thaani iria ihũũrithanagio ikagamba. Maya nĩmo marĩĩtwa ma andũ arĩa maarutaga wĩra ũyũ wa kũina:
\b
\li1 
\v 2 Kuuma kũrĩ ariũ a Asafu:
\li2 maarĩ Zakuri, na Jusufu, na Nethania, na Asarela. Ariũ a Asafu maarũgamagĩrĩrwo nĩ Asafu, ũrĩa warathaga ũhoro arũgamĩrĩirwo nĩ mũthamaki.
\li1 
\v 3 Kuuma kũrĩ ariũ a Jeduthuni:
\li2 maarĩ Gedalia, na Zeri, na Jeshaia, na Shimei, na Hashabia, na Matithia; othe maarĩ atandatũ, marũgamĩrĩirwo nĩ ithe wao Jeduthuni, ũrĩa warathaga ũhoro, akĩhũũraga kĩnanda kĩa mũgeeto, agacookagĩria Jehova ngaatho na akamũgoocaga.
\li1 
\v 4 Kuuma kũrĩ ariũ a Hemani:
\li2 maarĩ Bukia, na Matania, na Uzieli, na Shubaeli, na Jerimothu, na Hanania, na Hanani, na Eliatha, na Gidaliti, na Romamuti-Ezeri, na Joshibekasha, na Malothi, na Hothiru, na Mahaziothu.
\v 5 Acio othe maarĩ ariũ a Hemani ũrĩa wonagĩra mũthamaki maũndũ. Maaheanĩtwo kũrĩ we kũringana na ciĩranĩro cia Ngai nĩguo mamũtũũgagĩrie. Ngai aaheete Hemani ariũ ikũmi na ana, na airĩtu atatũ.
\b
\p 
\v 6 Andũ aya othe maarũgamagĩrĩrwo nĩ maithe mao nĩguo mainage thĩinĩ wa hekarũ ya Jehova, marĩ na thaani iria ihũũrithanagio ikagamba, na inanda cia kĩnũbi, na inanda cia mũgeeto, nĩ ũndũ wa ũtungata wa nyũmba ya Ngai. Asafu, na Jeduthuni, na Hemani nao maarũgamagĩrĩrwo nĩ mũthamaki.
\v 7 Hamwe na andũ a nyũmba ciao, arĩa othe maarutĩtwo na makagĩa na ũũgĩ wa kũinĩra Jehova, othe maarĩ andũ 288.
\v 8 Andũ ethĩ na akũrũ ũndũ ũmwe, na arutani o na arutwo, nĩmacuukire mĩtĩ nĩguo magaĩrwo mawĩra mao.
\b
\li1 
\v 9 Mũtĩ wa mbere, ũrĩa warĩ wa Asafu, wagwĩrĩire Jusufu, na ariũ ake, na andũ a nyũmba yao, maarĩ andũ 12;
\li1 wa keerĩ wagwĩrĩire Gedalia, we na andũ a nyũmba yao, na ariũ ao, maarĩ andũ 12;
\li1 
\v 10 wa gatatũ wagũĩrĩire Zakuri, na ariũ ake, na andũ a nyũmba yao, maarĩ andũ 12;
\li1 
\v 11 wa kana wagũĩrĩire Iziri, na ariũ ake, na andũ a nyũmba yao, maarĩ andũ 12;
\li1 
\v 12 wa gatano wagũĩrĩire Nethania, na ariũ ake, na andũ a nyũmba yao, maarĩ andũ 12;
\li1 
\v 13 wa gatandatũ wagũĩrĩire Bukia, na ariũ ake, na andũ a nyũmba yao, maarĩ andũ 12;
\li1 
\v 14 wa mũgwanja wagũĩrĩire Jesarela, na ariũ ake, na andũ a nyũmba yao, maarĩ andũ 12;
\li1 
\v 15 wa kanana wagũĩrĩire Jeshaia, na ariũ ake, na andũ a nyũmba yao, maarĩ andũ 12;
\li1 
\v 16 wa kenda wagũĩrĩire Matania, na ariũ ake, na andũ a nyũmba yao, maarĩ andũ 12;
\li1 
\v 17 wa ikũmi wagũĩrĩire Shemei, na ariũ ake, na andũ a nyũmba yao, maarĩ andũ 12;
\li1 
\v 18 wa ikũmi na ũmwe wagũĩrĩire Azareli, na ariũ ake, na andũ a nyũmba yao, maarĩ andũ 12;
\li1 
\v 19 wa ikũmi na ĩĩrĩ wagũĩrĩire Hashabia, na ariũ ake, na andũ a nyũmba yao, maarĩ andũ 12;
\li1 
\v 20 wa ikũmi na ĩtatũ wagũĩrĩire Shubaeli, na ariũ ake, na andũ a nyũmba yao, maarĩ andũ 12;
\li1 
\v 21 wa ikũmi na ĩna wagũĩrĩire Matithia, na ariũ ake, na andũ a nyũmba yao, maarĩ andũ 12;
\li1 
\v 22 wa ikũmi na ĩtano wagũĩrĩire Jerimothu, na ariũ ake, na andũ a nyũmba yao, maarĩ andũ 12;
\li1 
\v 23 wa ikũmi na ĩtandatũ wagũĩrĩire Hanania, na ariũ ake, na andũ a nyũmba yao, maarĩ andũ 12;
\li1 
\v 24 wa ikũmi na mũgwanja wagũĩrĩire Joshibekasha, na ariũ ake, na andũ a nyũmba yao, maarĩ andũ 12;
\li1 
\v 25 wa ikũmi na ĩnana wagũĩrĩire Hanani, na ariũ ake, na andũ a nyũmba yao, maarĩ andũ 12;
\li1 
\v 26 wa ikũmi na kenda wagũĩrĩire Malothi, na ariũ ake, na andũ a nyũmba yao, maarĩ andũ 12;
\li1 
\v 27 wa mĩrongo ĩĩrĩ wagũĩrĩire Eliatha, na ariũ ake, na andũ a nyũmba yao, maarĩ andũ 12;
\li1 
\v 28 wa mĩrongo ĩĩrĩ na ũmwe wagũĩrĩire Hothiru, na ariũ ake, na andũ a nyũmba yao, maarĩ andũ 12;
\li1 
\v 29 wa mĩrongo ĩĩrĩ na ĩĩrĩ wagũĩrĩire Gidaliti, na ariũ ake, na andũ a nyũmba yao, maarĩ andũ 12;
\li1 
\v 30 wa mĩrongo ĩĩrĩ na ĩtatũ wagũĩrĩire Mahaziothu, na ariũ ake, na andũ a nyũmba yao, maarĩ andũ 12;
\li1 
\v 31 wa mĩrongo ĩĩrĩ na ĩna wagũĩrĩire Romamuti-Ezeri, na ariũ ake, na andũ a nyũmba yao, maarĩ andũ 12.
\c 26
\s1 Arangĩri a Ihingo
\p 
\v 1 Ikundi cia arangĩri a ihingo:
\b
\li1 kuuma kũrĩ andũ a Kora maarĩ: Meshelemia mũrũ wa Kore, ũmwe wa ariũ a Asafu.
\li1 
\v 2 Ariũ a Meshelemia maarĩ:
\li2 Zekaria, na nĩwe warĩ wa irigithathi,
\li2 na Jediaeli aarĩ wa keerĩ,
\li2 na Zebadia aarĩ wa gatatũ,
\li2 na Jathinieli aarĩ wa kana,
\li2 
\v 3 na Elamu aarĩ wa gatano,
\li2 na Jehohanani aarĩ wa gatandatũ,
\li2 na Eliehoenai aarĩ wa mũgwanja.
\li1 
\v 4 Ariũ a Obedi-Edomu maarĩ:
\li2 Shemaia, na nĩwe warĩ wa irigithathi,
\li2 na Jehozabadu aarĩ wa keerĩ,
\li2 na Joa aarĩ wa gatatũ,
\li2 na Sakaru aarĩ wa kana,
\li2 na Nethaneli aarĩ wa gatano,
\li2 
\v 5 na Amieli aarĩ wa gatandatũ,
\li2 na Isakaru aarĩ wa mũgwanja,
\li2 na Peulethai aarĩ wa kanana,
\li2 nĩgũkorwo Ngai nĩarathimĩte Obedi-Edomu.
\b
\li1 
\v 6 Mũriũ Shemaia o nake aarĩ na ariũ ake, arĩa maarĩ atongoria thĩinĩ wa nyũmba ya ithe wao, tondũ maarĩ andũ ehoti.
\v 7 Ariũ a Shemaia maarĩ: Othini, na Refaeli, na Obedi, na Elizabadu, nao andũ a nyũmba yao, Elihu, na Semakia, maarĩ andũ ehoti.
\v 8 Acio othe maarĩ a njiaro cia Obedi-Edomu; o hamwe na ariũ ao, na andũ a nyũmba yao maarĩ andũ ehoti, na maarĩ na hinya wa kũruta wĩra. Njiaro cia Obedi-Edomu othe maarĩ andũ 62.
\li1 
\v 9 Meshelemia nĩ aarĩ na ariũ ake na andũ a nyũmba yao, arĩa maarĩ andũ ehoti, othe maarĩ andũ 18.
\b
\li1 
\v 10 Ariũ a Hosa ũrĩa Mũmerari maarĩ: Shimuri na nĩwe warĩ mũtongoria wao (o na gũtuĩka tiwe warĩ irigithathi, ithe nĩamũthuurĩte atuĩke mũtongoria wao),
\v 11 Hilikia aarĩ wa keerĩ, nake Tabalia aarĩ wa gatatũ, na Zekaria aarĩ wa kana. Ariũ a Hosa na andũ a nyũmba yao othe maarĩ andũ 13.
\b
\p 
\v 12 Ikundi icio cia arangĩri a ihingo ciĩtanĩtio na anene ao, ciarĩ na mawĩra ma gũtungata thĩinĩ wa hekarũ ya Jehova o ta andũ arĩa angĩ a nyũmba yao.
\v 13 Andũ ethĩ na andũ akũrũ o ũndũ ũmwe nĩmacuukĩire o kĩhingo mĩtĩ kũringana na nyũmba ciao.
\p 
\v 14 Mũtĩ wa Kĩhingo kĩa Irathĩro wagwĩrĩire Shelemia. Ningĩ magĩcuuka mĩtĩ nĩ ũndũ wa mũriũ Zekaria, ũrĩa warĩ mũheani kĩrĩra mũũgĩ, nake akĩgwĩrwo nĩ mũtĩ wa Kĩhingo gĩa Gathigathini.
\v 15 Mũtĩ wa Kĩhingo gĩa Gũthini wagwĩrĩire Obedi-Edomu, naguo mũtĩ wa nyũmba-ya-kũigwo-indo ũkĩgwĩra ariũ ake.
\v 16 Mĩtĩ ya Kĩhingo gĩa Ithũĩro, na Kĩhingo gĩa Shalekethu mwena wa njĩra ya rũgongo, yagwĩrĩire Shupimu na Hosa.
\p Arangĩri maaikaraga metanĩrĩire.
\v 17 O mũthenya gwakoragwo na Alawii atandatũ mwena wa irathĩro, na Alawii ana mwena wa gathigathini, na Alawii ana mwena wa gũthini, na Alawii eerĩ mahinda mothe nyũmba-inĩ ya kũigwo-indo.
\v 18 Nayo nja ya mwena wa ithũĩro, Alawii ana maikaraga njĩra-inĩ, na Alawii eerĩ maikaraga kũu nja.
\p 
\v 19 Icio nĩcio ciarĩ ikundi cia arangĩri a ihingo arĩa maarĩ a njiaro cia Kora na Merari.
\s1 Aigi Kĩgĩĩna, na Anene arĩa Angĩ
\p 
\v 20 Alawii arĩa angĩ nĩo maarũgamagĩrĩra igĩĩna cia nyũmba ya Ngai na igĩĩna cia indo iria nyamũre.
\p 
\v 21 Njiaro cia Ladani, arĩa maarĩ Agerishoni na ũndũ wa Ladani, na maarĩ atongoria a nyũmba cia Ladani ũcio Mũgerishoni, maarĩ: Jehieli,
\v 22 na ariũ a Jehieli, na Zethamu, na mũrũ wa nyina Joeli. Acio nĩo maarũgamagĩrĩra igĩĩna cia hekarũ ya Jehova.
\p 
\v 23 Kuuma kũrĩ andũ a Amuramu, na Iziharu, na Hebironi, na Uzieli maarĩ:
\b
\li1 
\v 24 Shubaeli wa rũciaro rwa Gerishomu mũrũ wa Musa, na nĩwe warĩ mũnene wa kũrũgamĩrĩra igĩĩna.
\v 25 Andũ a nyũmba yao kuuma kũrĩ Eliezeri: maarĩ mũriũ Rehabia, na Jeshia aarĩ mũriũ wa Rehabia, na Joramu aarĩ mũriũ wa Jeshia, na Zikiri aarĩ mũriũ wa Joramu, na Shelomithu aarĩ mũriũ wa Zikiri.
\v 26 Shelomithu na andũ a nyũmba yao nĩo maarũgamagĩrĩra igĩĩna ciothe cia indo iria ciarĩ nyamũre nĩ Mũthamaki Daudi, na indo iria ciarĩ nyamũre nĩ atongoria a nyũmba arĩa maarĩ anene a ikundi cia ngiri ngiri na ikundi cia igana igana, na ikaamũrwo nĩ anene arĩa angĩ a mbũtũ cia ita.
\v 27 Indo imwe cia iria ciatahĩtwo mbaara-inĩ maaciamũrĩire wĩra wa gũcookereria hekarũ ya Jehova.
\v 28 Na rĩrĩ, indo ciothe iria ciaamũrĩtwo nĩ Samũeli ũrĩa muoni-maũndũ, na ikaamũrwo nĩ Saũlũ mũrũ wa Kishu, na Abineri mũrũ wa Neri, na Joabu mũrũ wa Zeruia, na indo iria ingĩ ciothe ciaamũrĩtwo-rĩ, ciamenyagĩrĩrwo nĩ Shelomithu na andũ a nyũmba yao.
\li1 
\v 29 Kuuma kũrĩ andũ a Iziharu: Kenania na ariũ ake nĩmaheirwo mawĩra na kũu nja ya hekarũ matuĩke anene na aciirithania a Isiraeli.
\li1 
\v 30 Kuuma kũrĩ andũ a Hebironi: maarĩ Hashabia na andũ a nyũmba yao, andũ ehoti 1,700; nĩo maarũgamĩrĩire wĩra wa Jehova wothe kũu Isiraeli mwena wa ithũĩro wa Jorodani, o na wĩra wa gũtungatĩra mũthamaki.
\v 31 Kuuma kũrĩ andũ a Hebironi, Jeria nĩwe warĩ mũnene wao kũringana na maandĩko ma njiarwa cia nyũmba ciao. Mwaka wa mĩrongo ĩna wa ũthamaki wa Daudi nĩ gwatuĩririo maandĩko-inĩ, na gũkĩoneka thĩinĩ wao andũ ehoti o kũu Jazeri ya Gileadi.
\v 32 Jeria aarĩ na andũ a nyũmba yao 2,700 arĩa maarĩ ehoti na maarĩ atongoria a nyũmba, nake Mũthamaki Daudi akĩmatua arũgamĩrĩri a andũ a Rubeni, na a andũ a Gadi, na nuthu ya mũhĩrĩga wa Manase maũndũ-inĩ mothe marĩa maakonainie na Ngai, o na marĩa maakonainie na ũhoro wa mũthamaki.
\c 27
\s1 Ikundi cia Mbũtũ cia Ita
\p 
\v 1 Ũyũ nĩguo mũtaratara wa andũ a Isiraeli arĩa maarĩ atongoria a nyũmba, na anene a ikundi cia o ngiri ngiri na ikundi cia o igana igana, na anene ao, arĩa maatungatagĩra mũthamaki maũndũ-inĩ mothe makoniĩ ikundi cia mbũtũ cia ita iria ciakoragwo wĩra-inĩ mweri o mweri, mwaka wothe. O gĩkundi kĩarĩ kĩa andũ 24,000.
\b
\li1 
\v 2 Mũrũgamĩrĩri wa gĩkundi kĩa mbere kĩa mweri wa mbere aarĩ Jashobeamu mũrũ wa Zabidieli. Gĩkundi gĩake kĩarĩ na andũ 24,000.
\v 3 Nake aarĩ wa rũciaro rwa Perezu, na nĩwe warĩ mũnene wa anene othe a mbũtũ cia ita mweri wa mbere.
\li1 
\v 4 Mũrũgamĩrĩri wa gĩkundi kĩa mweri wa keerĩ aarĩ Dodai ũrĩa Mũahohi; mũtongoria wa gĩkundi gĩake aarĩ Mikilothu. Gĩkundi gĩake kĩarĩ na andũ 24,000.
\li1 
\v 5 Mũnene wa mbũtũ cia ita wa gatatũ, wa mweri wa ĩtatũ aarĩ Benaia mũrũ wa Jehoiada ũrĩa mũthĩnjĩri-Ngai. Nĩwe warĩ mũnene, na gĩkundi gĩake kĩarĩ na andũ 24,000.
\v 6 Benaia ũcio nĩwe warĩ njamba mũno gatagatĩ-inĩ ka arĩa Mĩrongo Ĩtatũ na nĩwe warĩ mũnene wao. Gĩkundi gĩake kĩarũgamagĩrĩrwo nĩ mũriũ Amizabadi.
\li1 
\v 7 Mũnene wa kana, wa mweri wa ĩna, aarĩ Asaheli mũrũ wa nyina na Joabu; mũriũ Zebadia nĩwe wacookire ithenya rĩake. Gĩkundi gĩake kĩarĩ na andũ 24,000.
\li1 
\v 8 Mũnene wa gatano mweri wa ĩtano, aarĩ Shamuhuthu ũrĩa Mũizirahi. Gĩkundi gĩake kĩarĩ na andũ 24,000.
\li1 
\v 9 Mũnene wa gatandatũ wa mweri wa ĩtandatũ, aarĩ Ira mũrũ wa Ikeshu ũrĩa Mũtekoa. Gĩkundi gĩake kĩarĩ na andũ 24,000.
\li1 
\v 10 Mũnene wa mũgwanja wa mweri wa mũgwanja, aarĩ Helezu ũrĩa Mũpeloni, wa rũciaro rwa Efiraimu. Gĩkundi gĩake kĩarĩ na andũ 24,000.
\li1 
\v 11 Mũnene wa kanana, wa mweri wa ĩnana, aarĩ Sibekai ũrĩa Mũhushathi wa rũciaro rwa Azerahi. Gĩkundi gĩake kĩarĩ na andũ 24,000.
\li1 
\v 12 Mũnene wa kenda wa mweri wa kenda aarĩ Abiezeri ũrĩa Mũanathothu wa rũciaro rwa Abenjamini. Gĩkundi gĩake kĩarĩ na andũ 24,000.
\li1 
\v 13 Mũnene wa ikũmi, wa mweri wa ikũmi, aarĩ Maharai ũrĩa Mũnetofathi wa rũciaro rwa Azerahi. Gĩkundi gĩake kĩarĩ na andũ 24,000.
\li1 
\v 14 Mũnene wa ikũmi na ũmwe, wa mweri wa ikũmi na ũmwe, aarĩ Benaia ũrĩa Mũpirathoni wa rũciaro rwa Aefiraimu. Gĩkundi gĩake kĩarĩ na andũ 24,000.
\li1 
\v 15 Mũnene wa ikũmi na eerĩ, mweri wa ikũmi na ĩĩrĩ, aarĩ Helidai ũrĩa Mũnetofathi, wa kuuma nyũmba ya Othinieli. Gĩkundi gĩake kĩarĩ na andũ 24,000.
\s1 Anene a Mĩhĩrĩga
\li1 
\v 16 Anene arĩa maathaga mĩhĩrĩga ya Isiraeli maarĩ aya:
\b
\li1 mũnene wa mũhĩrĩga wa Rubeni aarĩ Eliezeri mũrũ wa Zikiri;
\li1 mũnene wa mũhĩrĩga wa Simeoni aarĩ Shefatia mũrũ wa Maaka;
\li1 
\v 17 mũnene wa mũhĩrĩga wa Lawi aarĩ Hashabia mũrũ wa Kemueli;
\li1 mũnene wa mũhĩrĩga wa Harũni aarĩ Zadoku;
\li1 
\v 18 mũnene wa mũhĩrĩga wa Juda aarĩ Elihu mũrũ wa ithe na Daudi;
\li1 mũnene wa mũhĩrĩga wa Isakaru aarĩ Omuri mũrũ wa Mikaeli;
\li1 
\v 19 mũnene wa mũhĩrĩga wa Zebuluni aarĩ Ishimaia mũrũ wa Obadia;
\li1 mũnene wa mũhĩrĩga wa Nafitali aarĩ Jeremothu mũrũ wa Azirieli;
\li1 
\v 20 mũnene wa mũhĩrĩga wa Aefiraimu aarĩ Hoshea mũrũ wa Azazia;
\li1 mũnene wa nuthu ĩmwe ya mũhĩrĩga wa Manase aarĩ Joeli mũrũ wa Pedaia;
\li1 
\v 21 mũnene wa nuthu ĩrĩa ingĩ ya mũhĩrĩga wa Manase kũu Gileadi aarĩ Ido mũrũ wa Zekaria;
\li1 mũnene wa mũhĩrĩga wa Benjamini aarĩ Jaasieli mũrũ wa Abineri;
\li1 
\v 22 mũnene wa mũhĩrĩga wa Dani aarĩ Azareli mũrũ wa Jerohamu;
\p Acio nĩo maarĩ anene arĩa maathaga mĩhĩrĩga ya Isiraeli.
\b
\p 
\v 23 Daudi ndaatarire andũ a mĩaka mĩrongo ĩĩrĩ na arĩa mataakinyĩtie, tondũ Jehova nĩeranĩire atĩ nĩakaingĩhia Isiraeli matuĩke o ta njata cia matu-inĩ.
\v 24 Joabu mũrũ wa Zeruia nĩambĩrĩirie gũtara andũ, no ndaarĩkirie. Mangʼũrĩ nĩmakinyĩire Isiraeli nĩ ũndũ wa itarana rĩu. Naguo mũigana wa itarana rĩu ndwandĩkirwo ibuku-inĩ rĩa maũndũ ma Mũthamaki Daudi.
\s1 Arori a Maũndũ ma Mũthamaki
\p 
\v 25 Azimavethu mũrũ wa Adieli nĩwe warũgamagĩrĩra nyũmba iria ciaigagwo indo cia ũthamaki.
\p Jonathani mũrũ wa Uzia nĩwe warũgamagĩrĩra nyũmba cia kũigwo indo kũu ngʼongo-inĩ, na matũũra-inĩ, na tũtũũra-inĩ, o na mĩthiringo ĩrĩa mĩraihu na igũrũ ya arangĩri.
\p 
\v 26 Eziri mũrũ wa Kelubu nĩwe warũgamagĩrĩra andũ arĩa maarutaga wĩra wa kũrĩma mĩgũnda.
\p 
\v 27 Shimei ũrĩa Mũramathi nĩwe warũgamagĩrĩra mĩgũnda ya mĩthabibũ.
\p Zabadi ũrĩa Mũshifimi nĩwe warũgamagĩrĩra maciaro ma mĩthabibũ matanekĩrwo mĩtũngi-inĩ.
\p 
\v 28 Baali-Hanani ũrĩa Mũgederi nĩwe warũgamagĩrĩra mĩtĩ ya mĩtamaiyũ na ya mĩborothandi magũrũ-inĩ ma irĩma cia mwena wa irathĩro.
\p Joashu nĩwe warũgamagĩrĩra kũrĩa kwaigagwo maguta ma mĩtamaiyũ.
\p 
\v 29 Shitirai ũrĩa Mũsharoni nĩwe warũgamagĩrĩra ndũũru cia ngʼombe iria ciarĩithagio Sharoni.
\p Shafati mũrũ wa Adilai nĩwe warũgamagĩrĩra ndũũru cia ngʼombe iria ciarĩ cianda-inĩ.
\p 
\v 30 Obili ũrĩa Mũishumaeli nĩwe warũgamagĩrĩra ngamĩĩra.
\p Jehedeia ũrĩa Mũmeronothu nĩwe warũgamagĩrĩra ndigiri.
\p 
\v 31 Jazizi ũrĩa Mũhagari nĩwe warũgamagĩrĩra ndũũru cia mbũri.
\p Acio othe nĩo maarĩ anene arĩa marũgamagĩrĩra indo ciothe cia Mũthamaki Daudi.
\b
\p 
\v 32 Jonathani mamawe wa Daudi aarĩ mũheani kĩrĩra, mũndũ mũmenyi maũndũ na mwandĩki-marũa. Nake Jehieli mũrũ wa Hakimoni nĩwe wamenyagĩrĩra ariũ a mũthamaki.
\p 
\v 33 Ahithofeli nĩwe waheaga mũthamaki kĩrĩra.
\p Nake Hushai ũrĩa Mũariki aarĩ mũrata wa mũthamaki.
\v 34 Jehoiada mũrũ wa Benaia na Abiatharu nĩo maacookire ithenya rĩa Ahithofeli.
\p Joabu nĩwe warĩ mũnene wa mbũtũ cia ita cia mũthamaki.
\c 28
\s1 Daudi Kũhaarĩria Mwako wa Hekarũ
\p 
\v 1 Daudi nĩatũmanĩire anene othe a Isiraeli moongane Jerusalemu, nao nĩo: anene arĩa maarũgamĩrĩire mĩhĩrĩga, na anene a ikundi iria ciatungatagĩra mũthamaki, na anene a ikundi cia o ngiri ngiri na anene a ikundi cia o igana igana, na anene arĩa maarũgamĩrĩire indo ciothe na mahiũ ma mũthamaki na ma ariũ ake o na anene a nyũmba ya ũthamaki, na andũ arĩa maarĩ njamba, na andũ othe arĩa maarĩ ũrũme wa kũrũa mbaara.
\p 
\v 2 Mũthamaki Daudi nĩarũgamire akĩmeera atĩrĩ: “Ta thikĩrĩriai, inyuĩ ariũ a baba na andũ akwa. Nĩndatuĩte na ngoro yakwa gwaka nyũmba ĩtuĩke handũ ha kũhurũkio ithandũkũ rĩa kĩrĩkanĩro kĩa Jehova, arĩ ho gaturwa ka makinya ma Ngai witũ, na ngĩĩhaarĩria kũmĩaka.
\v 3 No Ngai akĩnjĩĩra atĩrĩ, ‘Wee ndũgwaka nyũmba ĩtanĩtio na Rĩĩtwa rĩakwa, tondũ wee ũrĩ mũndũ wa mbaara na nĩũitĩte thakame.’
\p 
\v 4 “No Jehova, Ngai wa Isiraeli, nĩathuurire kuuma kũrĩ nyũmba iitũ yothe nduĩke mũthamaki wa Isiraeli nginya tene. Nĩathuurire Juda atuĩke mũtongoria, na kuuma nyũmba ya Juda agĩthuura nyũmba ya baba, na kuuma kũrĩ ariũ a baba akĩona kwagĩrĩire aandue niĩ mũthamaki wa Isiraeli yothe.
\v 5 Harĩ ariũ akwa othe, tondũ Jehova nĩaheete ariũ aingĩ-rĩ, nĩathuurĩte mũriũ wakwa Solomoni aikarĩre gĩtĩ kĩa ũthamaki wa Jehova, athamakĩre Isiraeli.
\v 6 Aanjĩĩrire atĩrĩ: ‘Mũriũ waku Solomoni nĩwe ũgaaka nyũmba yakwa na nja ciakwa, nĩgũkorwo nĩndĩmũthuurĩte atuĩke mũriũ wakwa na niĩ nduĩke ithe.
\v 7 Nĩngahaanda ũthamaki wake nginya tene angĩtũũra arũmĩtie maathani na mawatho makwa ta ũrĩa kũrekwo ihinda rĩĩrĩ.’
\p 
\v 8 “Nĩ ũndũ ũcio, rĩu ndamwatha o haha maitho-inĩ ma andũ a Isiraeli othe na kĩũngano gĩkĩ kĩa Jehova, o nake Ngai witũ akĩiguaga: Mũmenyerere, na mũrũmagĩrĩre maathani mothe ma Jehova Ngai wanyu, nĩgeetha mwĩgwatĩre bũrũri ũyũ mwega, na mũkaũtigĩra njiaro cianyu ũtuĩke igai rĩao nginya tene.
\p 
\v 9 “Nawe mũrũ wakwa Solomoni-rĩ, tũũra ũmenyete Ngai wa thoguo, na ũmũtungatagĩre wĩrutĩire na ngoro yaku yothe na kwĩyendera, nĩgũkorwo Jehova atuĩragia ngoro o yothe, na akamenya gĩtũmi o gĩothe kĩa meciiria ma cio. Ũngĩmũrongooria no ũmuone; no ũngĩmũtirika, agaakũrega nginya tene.
\v 10 Gĩĩciirie rĩu, nĩgũkorwo Jehova nĩwe athuurĩte wa gwaka hekarũ ĩrĩ handũ hatheru. Gĩa na hinya na ũrute wĩra ũcio.”
\p 
\v 11 Hĩndĩ ĩyo Daudi akĩnengera mũriũ Solomoni mĩcoro ya mwako wa gĩthaku kĩa hekarũ, na nyũmba ciayo, na nyũmba cia kũigwo indo, na tũnyũmba twayo twa igũrũ, na tũnyũmba twa thĩinĩ, na handũ ha kũhoroherio mehia.
\v 12 Akĩmũnengera mĩcoro ya mĩako yothe ĩrĩa Roho eekĩrĩte meciiria-inĩ make ĩkoniĩ nja cia hekarũ ya Jehova, na ya tũnyũmba tuothe tũrĩa twamĩthiũrũrũkĩirie na tũnyũmba twa kũigwo igĩĩna cia hekarũ ya Ngai, na gwa kũigwo igĩĩna cia indo iria nyamũre.
\v 13 Ningĩ akĩmũtaarĩria wĩra wa ikundi cia athĩnjĩri-Ngai, na wa Alawii, na wĩra wothe wa ũtungata thĩinĩ wa hekarũ ya Jehova, o na wa indo ciothe cia kũhũthagĩrwo ũtungata-inĩ wayo.
\v 14 Nake akĩheana mũigana wa ũritũ wa thahabu ya gũthondeka indo ciothe cia thahabu cia kũhũthagĩrwo ũtungata-inĩ wa mĩthemba o mĩthemba, na ũritũ wa betha ya gũthondeka indo ciothe cia betha cia kũhũthagĩrwo ũtungata-inĩ wa mĩthemba o mĩthemba, ta ũũ:
\v 15 ũritũ wa thahabu ya gũthondeka mĩtĩ ya thahabu ya kũigĩrĩrwo matawa na matawa mayo, na ũritũ wa o mũtĩ na matawa maguo; na ũritũ wa betha ya gũthondeka o mũtĩ wa betha wa kũigĩrĩra tawa na matawa maguo, kũringana na ũrĩa mũtĩ wa kũigĩrĩra matawa wahũthagĩrwo:
\v 16 ũritũ wa thahabu ya gũthondeka metha ya kũigĩrĩra mĩgate ĩrĩa mĩamũre; na ũritũ wa betha ya gũthondeka metha cia betha;
\v 17 na ũritũ wa thahabu therie ya gũthondeka hũũma, na mbakũri cia kũminjaminjĩria, na nyũngũ, ũritũ wa thahabu ya gũthondeka o thaani ya thahabu; na ũritũ wa betha ya gũthondeka o thaani ya betha;
\v 18 na ũritũ wa thahabu therie ya gũthondeka kĩgongona gĩa gũcinĩrwo ũbumba. O na ningĩ akĩmũnengera mũcoro wa ngaari ya ita, ũguo nĩ kuuga ya makerubi ma thahabu marĩa maatambũrũkĩtie mathagu makahumbĩra ithandũkũ rĩa kĩrĩkanĩro kĩa Jehova.
\p 
\v 19 Daudi akiuga atĩrĩ, “Maũndũ maya mothe ndĩmandĩkĩte ũrĩa ndatongoririo nĩ guoko kwa Jehova kũrĩ igũrũ rĩakwa, na akĩĩhe ũmenyo wa maũndũ mothe ma mũcoro ũyũ.”
\p 
\v 20 Ningĩ Daudi akĩĩra mũriũ Solomoni atĩrĩ, “Gĩa na hinya na wĩyũmĩrĩrie, na ũrute wĩra ũcio. Ndũgetigĩre na ndũgakue ngoro, tondũ Jehova Ngai, o we Ngai wakwa, arĩ hamwe nawe. Ndagagũtiganĩria kana agũtirike nginya rĩrĩa wĩra wothe ũrĩa ũkaarutwo nĩ ũndũ wa ũtungata wa hekarũ ya Jehova ũgaathira.
\v 21 Ikundi cia athĩnjĩri-Ngai na Alawii, nĩciĩhaarĩrie nĩ ũndũ wa wĩra wothe wa hekarũ ya Ngai, na mũndũ o wothe ũrĩ na wendo na nĩoĩ wĩra wa ũbundi o wothe nĩagagũteithia wĩra-inĩ ũyũ. Anene na andũ othe nĩmarĩathĩkagĩra wathani waku wothe.”
\c 29
\s1 Iheo cia Gwaka Hekarũ
\p 
\v 1 Ningĩ Mũthamaki Daudi akĩĩra kĩũngano kĩu gĩothe atĩrĩ: “Mũriũ wakwa Solomoni, ũrĩa Ngai athuurĩte, nĩ mwĩthĩ na ndarĩ na ũmenyo wa kũigana. Wĩra ũyũ nĩ mũnene, tondũ nyũmba ĩno ĩhaana ta ya ũthamaki ti ya mũndũ no nĩ ya Jehova Ngai.
\v 2 Nĩnjigithĩtie indo na ũhoti wakwa wothe nĩ ũndũ wa hekarũ ya Ngai wakwa, ngaiga thahabu nĩ ũndũ wa gũthondeka indo cia thahabu, na betha nĩ ũndũ wa gũthondeka indo cia betha, na gĩcango nĩ ũndũ wa gũthondeka indo cia gĩcango, na kĩgera nĩ ũndũ wa gũthondeka indo cia kĩgera, na mbaũ nĩ ũndũ wa gũthondeka indo cia mbaũ, o na tũhiga tũrĩa twĩtagwo onigithi tũrĩa tũtheecagĩrĩrwo indo-inĩ, na tũhiga tũrĩa tũhenagia twa kũgemia nyũmba, na tũhiga twa rangi wa mĩthemba mĩingĩ, na tũhiga twa goro twa mĩthemba mĩingĩ, na mahiga ma nyaigĩ ma mũthemba ũrĩa mwega, indo icio ciothe ngaigithia irĩ nyingĩ mũno.
\v 3 Makĩria ma ũguo, harĩ kwĩrutĩra gwakwa igũrũ rĩa hekarũ ya Ngai wakwa nĩngũheana kĩgĩĩna gĩakwa mwene gĩa thahabu na betha nĩ ũndũ wa hekarũ ya Ngai wakwa, na icio ngũciheana nyongerere kĩrĩa kĩngĩ njigithĩtie nĩ ũndũ wa hekarũ ĩno theru:
\v 4 ngũheana taranda ngiri ithatũ\f + \fr 29:4 \ft nĩ ta tani 100\f* cia thahabu, o thahabu ĩrĩa ya Ofiri, na taranda ngiri mũgwanja\f + \fr 29:4 \ft nĩ ta tani 240\f* cia betha ĩrĩa therie nĩ ũndũ wa kũgemia thingo cia nyũmba,
\v 5 o na nĩ ũndũ wa wĩra wa thahabu na indo cia wĩra wa betha ũrĩa wothe ũkaarutwo nĩ mabundi. Na rĩrĩ, nũũ ũkwĩĩamũrĩra Jehova ũmũthĩ na kwĩyendera?”
\p 
\v 6 Hĩndĩ ĩyo atongoria a nyũmba, na anene a mĩhĩrĩga ya Isiraeli, na anene a ikundi cia ngiri ngiri na anene a ikundi cia igana igana na anene arĩa maarũgamagĩrĩra wĩra wa mũthamaki makĩheana indo na kwĩyendera.
\v 7 Nĩ ũndũ wa wĩra wa hekarũ ya Ngai nĩmaheanire taranda ngiri ithano,\f + \fr 29:7 \ft nĩ ta tani 170\f* na dariki ngiri ikũmi\f + \fr 29:7 \ft nĩ ta kilo 84\f* cia thahabu, na taranda ngiri ikũmi\f + \fr 29:7 \ft nĩ ta tani 345\f* cia betha, na taranda ngiri ikũmi na inyanya\f + \fr 29:7 \ft nĩ ta tani 620\f* cia gĩcango, na taranda ngiri igana rĩmwe\f + \fr 29:7 \ft nĩ ta tani 3,450\f* cia kĩgera.
\v 8 Mũndũ o wothe warĩ na tũhiga twa goro nĩatũheanire thĩinĩ wa kĩgĩĩna kĩa hekarũ ya Jehova kĩrĩa kĩamenyagĩrĩrwo nĩ Jehieli ũrĩa Mũgerishoni.
\v 9 Andũ nĩmakenirio nĩ ũrĩa atongoria ao maamũkĩire ũhoro ũcio na kwĩyendera, tondũ nĩmarutĩire Jehova indo na ngoro yao yothe matekũringĩrĩrio. Mũthamaki Daudi o nake nĩakenire mũno.
\s1 Ihooya rĩa Daudi
\p 
\v 10 Daudi nĩagoocire Jehova arĩ mbere ya kĩũngano kĩu gĩothe, akiuga atĩrĩ,
\q1 “Ũrogoocwo wee, o Wee Jehova,
\q2 Ngai wa ithe witũ Isiraeli,
\q2 kuuma tene nginya tene.
\q1 
\v 11 Wee Jehova-rĩ, ũnene, na hinya,
\q2 na riiri, na wathani, na ũkengi nĩ ciaku,
\q2 nĩgũkorwo kĩndũ o gĩothe kĩrĩ igũrũ na thĩ nĩ gĩaku.
\q1 Wee Jehova, ũthamaki nĩ waku;
\q2 nĩũtũũgĩrĩtio, ũkanenehio gũkĩra indo ciothe.
\q1 
\v 12 Ũtonga na gĩtĩĩo ciumaga kũrĩ we;
\q2 Wee nĩwe wathaga indo ciothe.
\q1 Hinya na ũhoti wa gũtũũgĩria
\q2 o na kũhe andũ othe hinya irĩ moko-inĩ maku.
\q1 
\v 13 Na rĩrĩ, Ngai witũ, nĩtũgũgũcookeria ngaatho,
\q2 na tũkagooca rĩĩtwa rĩaku rĩrĩ riiri.
\p 
\v 14 “No niĩ ngĩrĩ ũ, nao andũ akwa-rĩ, makĩrĩ a, atĩ no tũhote kũheana na ũtaana ta ũyũ? Indo ciothe ciumaga kũrĩ we, na kĩrĩa twakũhe no kĩrĩa kiumĩte moko-inĩ maku.
\v 15 Ithuĩ tũrĩ ageni na agendi maitho-inĩ maku, o ta ũrĩa maithe maitũ ma tene othe maatariĩ. Matukũ maitũ gũkũ thĩ matariĩ o ta kĩĩruru, na gũtirĩ mwĩhoko wa gũtũũra.
\v 16 Wee Jehova Ngai witũ, ũingĩ wa indo ici twaruta cia gũgwakĩra hekarũ nĩ ũndũ wa Rĩĩtwa rĩaku Itheru ciumĩte guoko-inĩ gwaku, na ciothe no ciaku.
\v 17 Niĩ nĩnjũũĩ atĩ Wee Ngai wakwa nĩũtuĩragia ngoro, na nĩũkenagio nĩ ũrũngĩrĩru wa ngoro. Indo ici ciothe ndĩciheanĩte na kwĩyendera na wĩhokeku. Na rĩu ndĩ na gĩkeno nĩ ũndũ wa kwĩonera ũrĩa andũ aya aku marĩ haha makũrutĩire indo na wendo.
\v 18 Wee Jehova, Ngai wa maithe maitũ Iburahĩmu, na Isaaka na Isiraeli, tũũria wendo ũyũ ũrĩ ngoro-inĩ cia andũ aku nginya tene na ũtũme matũũre magwathĩkagĩra.
\v 19 Na ũhotithie mũriũ wakwa Solomoni kwĩrutĩra na ngoro yake yothe, kũmenyagĩrĩra maathani maku, na maũndũ marĩa wee wendaga o na kĩrĩra gĩaku kĩa watho wa kũrũmĩrĩrwo, na ekage maũndũ mothe nĩguo aake mwako wa nyũmba ĩno ĩhaana ta nyũmba ya ũthamaki, ĩrĩa niĩ njigithĩirie indo ciayo.”
\p 
\v 20 Ningĩ Daudi akĩĩra kĩũngano gĩothe atĩrĩ, “Goocai Jehova Ngai wanyu.” Nĩ ũndũ ũcio andũ othe makĩgooca Jehova Ngai wa maithe mao; makĩinamĩrĩra, na makĩĩgũithia thĩ mbere ya Jehova na mbere ya mũthamaki.
\s1 Solomoni Kwamũkĩrwo ta Mũthamaki
\p 
\v 21 Mũthenya ũyũ ũngĩ makĩrutĩra Jehova magongona na makĩmũrutĩra maruta ma njino, ta ũũ: ndegwa ngiri ĩmwe, na ndũrũme ngiri ĩmwe na tũtũrũme ngiri ĩmwe, o hamwe na maruta mao ma indo cia kũnyuuo na magongona mangĩ maingĩ nĩ ũndũ wa andũ a Isiraeli othe.
\v 22 Makĩrĩa na makĩnyua marĩ na gĩkeno kĩnene mũthenya ũcio marĩ hau mbere ya Jehova.
\p Ningĩ makĩamũkĩra Solomoni mũrũ wa Daudi arĩ mũthamaki hĩndĩ ya keerĩ, na makĩmũitĩrĩria maguta mbere ya Jehova atuĩke wa kũmathamakĩra, nake Zadoku atuĩke mũthĩnjĩri-Ngai.
\v 23 Nĩ ũndũ ũcio Solomoni agĩikarĩra gĩtĩ gĩa ũthamaki kĩa Jehova, na agĩtuĩka mũthamaki ithenya rĩa ithe Daudi. Nake akĩgaacĩra na agĩathĩkĩrwo Isiraeli guothe.
\v 24 Anene othe, na andũ arĩa maarĩ njamba, hamwe na ariũ a Mũthamaki Daudi othe magĩtĩkĩra Mũthamaki Solomoni amaathage.
\p 
\v 25 Jehova agĩtũũgĩria Solomoni mũno maitho-inĩ ma andũ a Isiraeli othe, na akĩmũhe ũthamaki ũrĩ na riiri ũtaahetwo mũthamaki ũngĩ wa Isiraeli mbere ĩyo.
\s1 Gĩkuũ kĩa Daudi
\p 
\v 26 Daudi mũrũ wa Jesii aarĩ mũthamaki wa Isiraeli guothe.
\v 27 Aathamakĩire Isiraeli mĩaka mĩrongo ĩna, mĩaka mũgwanja yayo agĩthamaka arĩ Hebironi, nayo mĩaka mĩrongo ĩtatũ na ĩtatũ agĩthamaka arĩ Jerusalemu.
\v 28 Aakuire arĩ mũkũrũ mũno, arĩkĩtie gũkenera gũtũũra gwake matukũ maingĩ, na arĩ mũtongu, na agatĩĩo. Mũriũ Solomoni nĩwe wathamakire ithenya rĩake.
\p 
\v 29 Naho ha maũndũ marĩa makoniĩ wathani wa Mũthamaki Daudi kuuma kĩambĩrĩria nginya mũthia, nĩmandĩkĩtwo thĩinĩ wa maandĩko ma Samũeli ũrĩa warĩ muoni-maũndũ, na maandĩko-inĩ ma Nathani ũrĩa mũnabii na maandĩko-inĩ ma Gadi ũrĩa muoni-maũndũ,
\v 30 hamwe na maũndũ mothe marĩa maakoniĩ ũthamaki wake na ũhoti ũrĩa aarĩ naguo, na ũrĩa maũndũ marĩa maamũthiũrũrũkĩirie maatariĩ na ma Isiraeli na mothamaki ma mabũrũri marĩa mangĩ mothe.
