\c 3  
\p
\v 1 \w Fiel|strong="G4103"\w* \w es|strong="G1487"\w* \w esta|strong="G3588"\w* \w palabra|strong="G3056"\w*: \w si|strong="G1487"\w* \w alguno|strong="G5100"\w* \w desea|strong="G1937"\w* ser supervisor, \w desea|strong="G1937"\w* \w una|strong="G5100"\w* \w buena|strong="G2570"\w* \w obra|strong="G2041"\w*.   
