\id MAT
\h Matta
\toc1 Matta
\toc2 Matta
\toc3 Mt.
\mt1 Matta
\c 1
\s1 Adlis n umezruy n wexřaq n Yasuɛ Lmasiḥ
\m 
\v 1 Adlis n umezruy n wexřaq n Yasuɛ Lmasiḥ, Mmis n Dawud, mmis n Ibrahim. \x ◘ \xo 1:1 \xt [Lk. 3:23-38] — Lk. 1:31, 32\x*
\m 
\v 2 Ibrahim ijja-dd Isḥaq, Isḥaq ijja-dd Yaɛqub, Yaɛqub ijja-dd Yahuda d aytmas. \x ◘ \xo 1:2 \xt Amz. 21:2; 25:26, 35. \x*
\v 3 Yahuda ijja-dd Fariṣ d Zaraḥ ak-d Tamar, Fariṣ ijja-dd Ḥaṣrun, Ḥaṣrun ijja-dd Aram, \x ◘ \xo 1:3 \xt Amz. 38:27, 29; Raɛ. 4:18, 19; 1 Im. 2:5, 9. \x*
\v 4 Aram ijja-dd Ɛamminadab, Ɛamminadab ijja-dd Naḥcun, Naḥcun ijja-dd Salmun,
\v 5 Salmun ijja-dd Buɛaz zi Raḥab, Buɛaz ijja-dd Ɛubid ak-d Raɛut, Ɛubid ijja-dd Yassa,
\v 6 Yassa ijja-dd Dawud, ajeǧid, uca Dawud ijja-dd Suliman ak-d temɣart n Uriya. \x ◘ \xo 1:6 \xt Raɛ. 4:22; 1 Ṣm. 16:1; 17:12; 1 Im. 2:15; 12:18. \x*
\m 
\v 7 Suliman ijja-dd Raḥabɛam, Raḥabɛam ijja-dd Abiya, Abiya ijja-dd Asa, \x ◘ \xo 1:7 \xt 1 Ij. 11:43; 1 Im. 3:10. \x*
\v 8 Asa ijja-dd Yahucafaṭ, Yahucafaṭ ijja-dd Yuram, Yuram ijja-dd Ɛuzziya,
\v 9 Ɛuzziya ijja-dd Yutam, Yutam ijja-dd Aḥaz, Aḥaz ijja-dd Ḥizqiya,
\v 10 Ḥizqiya ijja-dd Manassa, Manassa ijja-dd Amun, Amun ijja-dd Yuciya,
\v 11 Yuciya ijja-dd Yakunya d aytmas deg \add wussan n\add* lmenfa n Babil. \x ◘ \xo 1:11 \xt 1 Im. 3:16. \x*
\m 
\v 12 Awarni i lmenfa di Babil, Yakunya ijja-dd Caɛaltiyil, Caɛaltiyil ijja-dd Zarubbabil. \x ◘ \xo 1:12 \xt 1 Im. 3:17; Ɛiz. 3:2. \x*
\v 13 Zarubbabil ijja-dd Abihud, Abihud ijja-dd Alyaqim, Alyaqim ijja-dd Ɛazur,
\v 14 Ɛazur ijja-dd Ṣaduq, Ṣaduq ijja-dd Axim, Axim ijja-dd Aliyud,
\v 15 Aliyud ijja-dd Aliɛazar, Aliɛazar ijja-dd Mattan, Mattan ijja-dd Yaɛqub,
\v 16 Yaɛqub ijja-dd Yusuf, aryaz n Maryam, tenni i dd-ijjin Yasuɛ umi qqaren Lmasiḥ.
\m 
\v 17 S uyenni marra arrawen zi Ibrahim ař Dawud iwḍen arbeɛṭac n warrawen. Zi Dawud ař lmenfa di Babil arbeɛtac n warrawen uca zi lmenfa di Babil ař Lmasiḥ arbeɛtac n warrawen.
\b
\s1 Axřaq n Yasuɛ Lmasiḥ
\m 
\v 18 Ammu i yemsar wexřaq n Yasuɛ Lmasiḥ. Umi yemmas Maryam tuɣa-tt d tanexḍebt n Yusuf, iḍhar-dd belli nettat teksi aɛeddis zi Arruḥ Iqeddsen qbeř i ɣa meřcen. \x ◘ \xo 1:18 \xt [Lk. 2:1-7] — 1:27, 34\x*
\v 19 Umi aryaz nnes Yusuf tuɣa iggur nican, war ixs ca ad tt issbehdeř, tuɣa yarezzu ad as iǧef s tnuffra.
\v 20 Am tuɣa ittxarraṣ di man aya, iḍhar as-dd lmalak n SIDI di tarjit, inna:
\b
\m \qt “A Yusuf, a mmis n Dawud,\qt*
\m \qt war tteggʷed ad dd-tawyed\qt*
\m \qt Maryam d tamɣart nnec,\qt*
\m \qt minzi wenni i dayes dd-ixeřqen,\qt*
\m \qt aqa Netta zi Arruḥ Iqeddsen.”\qt*
\m 
\v 21 \qt Nettat ad dd-taruw Aḥenjir,\qt*
\m \qt nettat ad t tsemma Yasuɛ,\qt*
\m \qt minzi Netta ad issenjem řgens nnes\qt*
\m \qt zi ddnub nsen.”\qt* \x ◘ \xo 1:21 \xt Lk. 1:31; Řex. 4:12. \x*
\b
\m 
\v 22 Marra aya imsar, ḥima ad ittwakemmeř min inna SIDI s \add uqemmum n\add* unabi, \add umi inna\add*:
\b
\m 
\v 23 \qt “Xẓar, taɛzarect ad teksi ddeyset,\qt*
\m \qt uca ad dd-taruw Aḥenjir,\qt*
\m \qt ad as ggen ‘Ɛimmanu-Il’\qt*
\m \qt min ixs ad yini:\qt*
\m \qt ‘AREBBI nneɣ aqa-t akidneɣ.’”\qt* \x ◘ \xo 1:23 \xt Ica. 7:14; 8:8, 10 \x*
\b
\m 
\v 24 Řami dd-ifaq Yusuf zeg iḍeṣ, igga am mammec tt yumur lmalak n SIDI, uca yiwyi-dd tamɣart nnes ɣares.
\v 25 Uca netta war ɣares dd-iqarreb ca ařami dd-turuw Mmis amenzu, uca tsemma t ‘Yeccu’. \x ◘ \xo 1:25 \xt Lk. 2:21. \x*
\b
\b
\c 2
\s1 Imusnawen n itran zi ccarq
\m 
\v 1 Řami dd-ixřeq Yasuɛ di Bayt-Laḥm di Yahudiyya deg wussan n ujeǧid Hirudus, usin-dd ca n imusnawen \add n itran\add* zi manis d tneqqar tfuct ɣar Urcalim. \x ◘ \xo 2:1 \xt Lk. 2:4. \x*
\v 2 Nnan: “Mani iǧa wenni dd-ixeřqen d Ajeǧid n Wudayen? Aqa neẓra itri nnes di ccarq, nusa-dd ad as nesjed.”
\v 3 \add Řami\add* isřa ujeǧid Hirudus \add man aya\add*, inneḥweř netta d qaɛ Urcalim akides.
\v 4 Issmun-dd zi řgens marra imeqqranen n ikehhanen d imseřmaden n idlisen uca isseqsa ten x mani ɣa ixřeq Lmasiḥ.
\v 5 Nnan: “Di Bayt-Laḥm di Yahudiyya, minzi d man aya i yuran s ufus n unabi:
\b
\m 
\v 6 \qt ‘Uřa d cem, Bayt-Laḥm\qt*
\m \qt di \tl temmurt n\tl* Yahuda,\qt*
\m \qt cem war teǧid ca d tameẓyant\qt*
\m \qt jar ijeǧiden n Yahuda,\qt*
\m \qt minzi zzayem dd ɣa iffeɣ Ujeǧid\qt*
\m \qt wenni i ɣa yarewsen řgens inu, Israil.’”\qt* \x ◘ \xo 2:6 \xt Mixa 5:1, 2; 1 Ṣm. 16:1; Yḥ. 7:42. \x*
\b
\m 
\v 7 Řexdenni iřaɣa Hirudus x imusnawen \add n itran\add* s tnuffra uca yiweḍ ad zzaysen issen řweqt i di tuɣa d asen dd-iffeɣ itri.
\v 8 \add Xenni\add* issekk i-ten ɣar Bayt-Laḥm, inna: “Ruḥem dinni, tarzum mliḥ x Uḥenjir. Mařa tufim t, asem-dd, xebbarem ayi, ḥima uřa d necc ad dd-aseɣ, ad as sejdeɣ.”
\v 9 Awarni řami sřin \add i wawař\add* n ujeǧid, ruḥen uca xzar, itri i ẓrin di ccarq iggur zzatsen ařami dd-yiweḍ uca ibedd sennej i wemcan mani iǧa Uḥenjir.
\v 10 Řami ẓrin itri, farḥen s řefraḥet tameqqrant aṭṭas.
\v 11 Udfen ɣar taddart, ẓrin Aḥenjir ak-d Maryam, yemmas, wḍan ɣar temmurt uca sejden as. \add Xenni\add* arezmen řeknuz nsen uca qeddmen as tirzifin: ureɣ, mirru d řefwaḥet n řebxur. \f ◼ \fr 2:11 \fk tirzifin\ft - niɣ ‘iriɣaluten’.\f*
\v 12 Umi d asen dd-iweḥḥa di tarjit ḥima war ttɛiqqiben ɣar Hirudus, ɛeqben ɣar temmurt nsen zeg ijj n webrid nneɣni.
\b
\s1 Tarewřa ɣar Miṣra
\m 
\v 13 Umi ruḥen, iḍhar-dd lmalak n SIDI ɣar Yusuf di tarjit, inna: “Kkar, awi-dd Aḥenjir d yemmas, arweř ɣar Miṣra u qqim din ař cek i ɣa xebbareɣ, minzi Hirudus yarezzu x Uḥenjir ḥima ad t isshellek.”
\v 14 Uca ikkar-dd Yusuf, yiwi Aḥenjir d yemmas s ǧiřet uca yarweř ɣar Miṣra.
\v 15 Iqqim dinni ařami immut Hirudus, ḥima ad ittwakemmeř min ittwannan zi SIDI zeg unabi i innan: “Řaɣiɣ-dd x Mmi \add ḥima ad iffeɣ\add* zi Miṣra.” \x ◘ \xo 2:15 \xt Uf. 4:22, 23; Ḥuc. 11:1. \x*
\b
\s1 Anɣay n iḥenjiren di Bayt-Laḥm
\m 
\v 16 Řami iẓra Hirudus belli imusnawen cemten t, ixeyyeq aṭṭas, uca issekk, inɣa marra iḥenjiren n Bayt-Laḥm d qaɛ jjwayeh i d as dd-yudsen, marra iḥenjiren zi tnayen n iseggʷusa swadday ɛlaḥsab řweqt i yiweḍ ad issen zeg imusnawen.
\v 17 Řexdenni ittwakemmeř min ittwannan zeg unabi Irmiya, umi inna:
\b
\m 
\v 18 \qt “Tmijja tᵉttwaseř di Rama,\qt*
\m \qt imeṭṭawen d tɣuyyit n wecḍan aṭṭas.\qt*
\m \qt Rahil tᵉttru x iḥenjiren nnes,\qt*
\m \qt war tᵉttexs ad tᵉttwaɛezza,\qt*
\m \qt minzi nitni war qqimen \tl ɛad\tl*!”\qt* \x ◘ \xo 2:18 \xt Irm. 31:15 \x*
\b
\s1 Adwař zi Miṣra
\m 
\v 19 Řami immut Hirudus, iḍhar-dd lmalak n SIDI di tarjit i Yusuf di Miṣra,
\v 20 inna: “Kkar, awi-dd Aḥenjir d yemmas uca ruḥ ɣar temmurt n Israil, minzi inni tuɣa yarezzun ad nɣen Aḥenjir, aqa mmuten.”
\v 21 \add Řexdenni\add* ikkar, yiwi-dd Aḥenjir d yemmas uca yusa-dd ɣar temmurt n Israil.
\v 22 Maca ařami isřa belli Arxilawus idweř d ajeǧid di Yahudiyya deg wemcan n babas Hirudus, iggʷed ad iraḥ dinni. \add Xenni\add* iweḥḥa as-dd \add Arebbi\add* di tarjit maḥend ad iraḥ ɣar jjwayeh n Ljalil.
\v 23 \add Řami\add* dd-yiweḍ, izdeɣ di tendint qqaren as Nnaṣira, ḥima ad ittwakemmeř min ittwannan zeg unabi i innan: “Ad t semman Nnaṣiri!” \x ◘ \xo 2:23 \xt Ica. 11:1; 60:21; Zak. 6:12. \x*
\b
\b
\c 3
\s1 Abarreḥ n Yuḥanna Amseɣḍaṣ
\m 
\v 1 Deg wussan nni yusa-dd Yuḥanna Amseɣḍaṣ, tuɣa ittbarreḥ di řexřa n Yahudiyya, \x ◘ \xo 3:1 \xt [Mk. 1:1-8; Lk. 3:1-9; 15-17; Yḥ. 1:19-28] — Mk. 1:4; Lk. 3:3.\x*
\v 2 inna:
\b
\m \qt “Tubem, minzi Tageldit n ijenwan.\qt*
\m \qt aqa tudes-dd.”\qt*
\b
\m 
\v 3 Minzi netta d wenni xef ittwannan zeg unabi Icaɛya \add am inna\add*:
\b
\m \qt “Tmijja i ittřaɣan di řexřa:\qt*
\m \qt ‘Swejdem abrid n SIDI,\qt*
\m \qt seggem imesraq nnes.’”\qt* \x ◘ \xo 3:3 \xt Ica. 40:3; Mk. 1:3; Lk. 3:4; Yḥ. 1:23. \x*
\b
\m 
\v 4 Yuḥanna wanita tuɣa yarreḍ \add arruḍ n\add* taḍuft n iřeɣman, ibekkes ijj n webyas n yiřem. Uca macca nnes tuɣa d iburexsen d tamment taḥurrect. \x ◘ \xo 3:4 \xt Mk. 1:6. \x*
\v 5 Řexdenni teffeɣ-dd ɣares Urcalim d qaɛ Yahudiyya d marra jjwayeh i d as dd-innḍen i L’Urdun,
\v 6 uca ttwassɣeḍṣen zzayes deg iɣzar n L’Urdun, neɛmen s ddnub nsen. \x ◘ \xo 3:6 \xt Mk. 1:5. \x*
\m 
\v 7 Řami iẓra aṭṭas n Ifarisiyyen d Iṣaduqiyyen ttasen-dd maḥend ad ttwassɣeḍṣen, inna asen: “A tarwa n ifiɣran, wi d awem imřen, aqa tzemmarem ad tarewřem zeg weɣḍab i dd ɣa yasen? \x ◘ \xo 3:7 \xt Mt. 12:34; 23:33; Lk. 3:7. \x*
\v 8 Ggem řɣiǧet i ɣa iřiqqen i ttubet. \x ◘ \xo 3:8 \xt Lk. 3:8. \x*
\v 9 War ttɣiřem ca ad tinim deg ixef nwem: ‘Ibrahim d jedditneɣ!’, minzi Necc ad awem iniɣ belli AREBBI izemmar ad issnekkar zeg iẓra-ya tarwa i Ibrahim. \x ◘ \xo 3:9 \xt Yḥ. 8:39. \x*
\v 10 Xzar, tacaqurt tᵉttwassars ɣar iẓewran n tcejjura. S uya kuř tacejjart i war itticen řɣiǧet tecna, ad tᵉttwaqess uca ad tewḍa di tmessi. \f ◼ \fr 3:10 \fk tacejjart\ft - niɣ ‘addag’ (‘iddagen’).\f*  \x ◘ \xo 3:10 \xt Mt. 7:19; Yḥ. 15:6. \x*
\v 11 Necc ad kenniw ssɣeḍṣeɣ deg waman i ttubet, maca wenni i dd ɣa yasen awarni ayi, Netta ijhed xafi, necc war sdihiǧeɣ ad ksiɣ sandaliyat nnes. Aqa Netta ad kenniw isseɣḍeṣ di Arruḥ Iqeddsen d tmessi. \x ◘ \xo 3:11 \xt Mk. 1:7; Lk. 3:16; Yḥ. 1:15, 26; Řex. 1:5; 11:16; 19:4. \x*
\v 12 Tazzart nnes deg ufus nnes, ad izzuzar andrar nnes qaɛ, ad iyru irden ɣar řemrasi nnes, \add maca\add* icarfa ad ten issecmeḍ s tmessi i war ixessyen.”
\b
\s1 Aseɣḍeṣ n Yasuɛ
\m 
\v 13 Řexdenni yusa-dd Yasuɛ zi Ljalil ɣar L’Urdun, ɣar Yuḥanna, ḥima ad ittwaseɣḍeṣ zzayes. \f ◼ \fr 3:13 \fk ittwaseɣḍeṣ\ft - nzemmar ad nessemqudda aseɣḍes ak-d wenḍeř n bnadem di řebḥar, deg waman, xenni awarni as ittwassnekkar-dd zzaysen. D man aya d ijj n umedya n wenḍeř n bnadem aqdim d tnukkra n bnadem n jdid s l’iman di Yasuɛ Lmasiḥ. Aseɣḍeṣ di Yasuɛ war iǧi d ict n řeɛřamet n ṭharet waha, maca ɣar umezwar aqa aseɣḍeṣ řeɛřamet n umenḍar n bnadem aqdim deg waman u n tnukkra nnes zeg waman am bnadem d jdid s liman di Yasuɛ Lmasiḥ. Xzar Rum. 6:1-14.\f*  \x ◘ \xo 3:13 \xt [Mk. 1:9-11; Lk. 3:21-22] — Mk. 1:9; Lk. 3:21.\x*
\v 14 Maca Yuḥanna yugi as, inna: “Necc ḥdajeɣ ad ttwassɣeḍṣeɣ zzayek. Ma aqa d Cek i ɣari i dd ɣa yasen?”
\m 
\v 15 Maca Yasuɛ yarra-dd, inna as: “Ewc řexxu ttesriḥ, minzi ammu i d aneɣ ittřiq ḥima ad nkemmeř marra tasegda.” Řexdenni isamḥ as.
\v 16 \add Awarni řami\add* ittwasseɣḍeṣ Yasuɛ, yuři-dd zeg waman deɣya, u ttwarzmen as ijenwan, uca iẓra Arruḥ n AREBBI ihwa-dd am tadbirt, tarsa xas. \x ◘ \xo 3:16 \xt Ica. 11:2; 42:1; Yḥ. 1:32. \x*
\v 17 Xzar, tusa-dd ict n tmijja zeg ijenwan, tenna: “D Wa d Mmi iɛizzen, dayes ufiɣ arḍa inu.” \x ◘ \xo 3:17 \xt Ica. 42:1; Mt. 12:18; 17:5; Mk. 1:11; Lk. 9:35; Kul. 1:13; 2 Bṭ. 1:17. \x*  *
\b
\b
\c 4
\s1 Ibřis ittjarreb Yasuɛ di řexřa
\m 
\v 1 Řexdenni ittwandeh Yasuɛ ɣar řexřa zi Arruḥ Iqeddsen, ḥima ad ittwajarreb zeg ibřis. \f ◼ \fr 4:1 \fk ibřis\ft - isem-a wanita ixs ad yini ‘wenni iɛeyyben’. Ibřis netta d cciṭan ameqqran.\f*  \x ◘ \xo 4:1 \xt [Mk. 1:12-13; Lk. 4:1-13] — Mk. 1:12; Lk. 4:1.\x*
\v 2 Awarni řami tuɣa iẓumm arebɛin n wussan d arebɛin n ǧyaři, yusa as-dd jjuɛ ɣar uneggar.
\v 3 Yusa-dd ɣares umjarrab, inna as: “Mařa Cek d Mmis n AREBBI, ini i iẓra-ya ad dewřen d aɣrum!”
\v 4 Yarra-dd xas inna: “Aqa tura:
\b
\m \qt ‘Bnadem war iddar s weɣrum waha,\qt*
\m \qt maca zi kuř awař\qt*
\m \qt i dd-ittekken zeg uqemmum n AREBBI.’”\qt* \x ◘ \xo 4:4 \xt Aɛwd. 8:3\x*
\b
\m 
\v 5 Řexdenni yiwyi t ibřis ɣar tendint iqeddsen uca issbedd i-t ɣar ṭṭarf n tzeqqa n Zzawect Tameqqrant,
\v 6 inna as: “Mařa Cek d Mmis n AREBBI, iwa, nḍar Ixef nnec ɣar wadday, minzi aqa tura:
\b
\m \qt ‘Ad yumur lmalakat nnes xak,\qt*
\m \qt ad Cek ksint x ifassen nsent,\qt*
\m \qt ḥima aḍar nnec war ineggeḥ ca aẓru.’”\qt* \x ◘ \xo 4:6 \xt Izhd. 91:11, 12. \x*
\b
\m 
\v 7 Yasuɛ inna as: “Tura ɛawed:
\b
\m \qt ‘War ttjarrab SIDI, AREBBI nnec!’”\qt* \x ◘ \xo 4:7 \xt Aɛwd. 6:16. \x*
\b
\m 
\v 8 Yiwyi t ɛawed ibřis ɣar wedrar yuɛřan aṭṭas, isscen as marra tigeldiwin n ddunect d uɛuǧi nsent,
\v 9 inna as: “Ad ac wceɣ marra man aya, mařa tewḍid ayi ɣar iḍaren, ad ayi tsejded!”
\v 10 Inna as Yasuɛ: “Ruḥ, \add a\add* cciṭan, minzi tura:
\b
\m \qt ‘SIDI, AREBBI nnec, umi ɣa tsejded\qt*
\m \qt u i Netta weḥḥdes umi ɣa tsexxared.’”\qt* \f ◼ \fr 4:10 \fk cciṭan\ft - aqa-t d cciṭan ameqqran wenni iǧan x marra ccwaṭen.\f*  \x ◘ \xo 4:10 \xt Aɛwd. 6:13; 10:20. \x*
\b
\m 
\v 11 Řexdenni ijja i-t ibřis, u xzar, lmalakat usint-i-dd, tuɣa sexxarent as.
\b
\s1 Amezwaru n tsexxart n Yasuɛ di Ljalil
\m 
\v 12 Řami isřa Yasuɛ belli Yuḥanna tuɣa ittwasellem, iruḥ ɣar Ljalil. \x ◘ \xo 4:12 \xt [Mk. 1:14-20; Lk. 4:14-15; Lk. 5:1-11; 6:17-19; 16,31; Yḥ. 4:43] — Mk. 1:14; Lk. 4:14; 16:31; Yḥ. 4:43. \x*
\v 13 Ijja Nnaṣira uca yusa-dd ɣar Kafarnaḥum, tenni ɣar ṭṭarf n řebḥar, di temmurt n Zibulun d Naftali uca izdeɣ din
\v 14 ḥima ad ittwakemmeř min ittwannan zeg unabi Icaɛya umi inna:
\b
\m 
\v 15 \qt “Tammurt n Zibulun d temmurt n Naftali\qt*
\m \qt deg Webrid n Řebḥar,\qt*
\m \qt ɣar ujemmaḍ n L’Urdun, Ljalil n řegnus.\qt* \x ◘ \xo 4:15 \xt Ica. 8:23; 9:1. \x*
\m 
\v 16 \qt Řgens i iqqimen di taǧest\qt*
\m \qt iẓra Tafawt tameqqrant,\qt*
\m \qt u x yinni izedɣen\qt*
\m \qt di temmurt d tiři n řmewt,\qt*
\m \qt aqa tenqar-dd xasen Tfawt.”\qt* \x ◘ \xo 4:16 \xt Ica. 9:1\x*
\b
\m 
\v 17 Zi ssin ibda Yasuɛ ittbarreḥ, inna: “Tubem minzi Tageldit n ijenwan aqa tudes-dd.” \x ◘ \xo 4:17 \xt Mk. 1:15. \x*
\b
\m 
\v 18 Řami tuɣa Netta iggur x tma n řebḥar n Ljalil, iẓra tnayen n wawmaten, Cimɛun umi qqaren Buṭrus, \add isem wanita ixs ad yini ‘D Aẓru’\add*, d Andrawus umas, tuɣa neṭṭaren traccawin di řebḥar minzi nitni d ineymaren n iseřman. \x ◘ \xo 4:18 \xt [Mk. 1:16-20; Lk. 5:1-11] — Mk. 1:16. \x*
\v 19 Inna asen Yasuɛ: “Ḍfarem ayi-dd, ad kenniw arreɣ d ineymaren n iwdan.”
\v 20 Ssarsen deɣya tiracciwin nsen, ḍfaren t.
\m 
\v 21 Řami yeɛdu ssenni, iẓra tnayen n wawmaten nneɣni, Yaɛqub mmis n Zabdi d umas Yuḥanna, tuɣa aten ak-d babatsen Zabdi deg uɣarrabu, ɛeddřen tiracciwin nsen uca Netta iřaɣa xasen.
\v 22 Deɣya semḥen deg uɣarrabu u di babatsen, ḍfaren t.
\b
\m 
\v 23 Tuɣa Yasuɛ ittenneḍ di temmurt n Ljalil marra, isseřmad di temzidawin nsen, ittbarreḥ s Řexbar Aṣebḥan n Tgeldit uca issgenfa kuř řehřac d kuř řeɛyubat i iǧan di řgens. \x ◘ \xo 4:23 \xt [Lk. 6:17-19]\x*
\v 24 Iffeɣ řexbar xas di Suriya marra, uca iwyen-dd ɣares marra imehřac inni ɣar iǧa ɛřam kuř řehřac řa d yinni daysen řeḥriq řa d inni daysen ccwaṭen řa d yinni ittbarkikkiḍen uřa d ineɛḍaben, uca issgenfa i-ten.
\v 25 Ḍfaren t-i-dd aṭṭas n řɣaci zi Ljalil, zi Dikapulis, zi Urcalim, zi Yahudiyya u zeg ujemmaḍ n L’Urdun.
\b
\b
\c 5
\s1 ABARREḤ X WEDRAR
\m 
\v 1 Řami iẓra Yasuɛ řɣaci, yuři ɣar wedrar, uca awarni řami din iqqim, usin-dd ɣares imeḥḍaren nnes. \x ◘ \xo 5:1 \xt [Mk. 9:50; Lk. 6:20-23; 14:34-35]\x*
\v 2 Uca yarzem aqemmum nnes, isseřmed i-ten, inna:
\b
\m 
\v 3 \qt Sseɛd n yinni arruḥ nsen izřeḍ,\qt*
\m \qt minzi Tageldit n ijenwan aqa-tt i nitni.\qt* \x ◘ \xo 5:3 \xt Ica. 57:15; 66:2; Lk. 6:20. \x*
\m 
\v 4 \qt Sseɛd n yinni ittecḍinen,\qt*
\m \qt minzi nitni ad ttwaɛezzan.\qt* \x ◘ \xo 5:4 \xt Ica. 61:2; 66:10, 13; Lk. 6:21. \x*
\m 
\v 5 \qt Sseɛd n imwaḍɛen,\qt*
\m \qt minzi nitni ad warten tammurt.\qt* \x ◘ \xo 5:5 \xt Izhd. 37:11. \x*
\m 
\v 6 \qt Sseɛd n yinni ittřaẓan\qt*
\m \qt d yinni ittfaden ɣar tsegda,\qt*
\m \qt minzi nitni ad jjiwnen.\qt* \x ◘ \xo 5:6 \xt Ica. 55:1 \x*
\m 
\v 7 \qt Sseɛd n yinni yareḥḥmen,\qt*
\m \qt minzi ad ɣarsen tiři arreḥmet.\qt*
\m 
\v 8 \qt Sseɛd n yinni i ɣar iǧa uř izdig,\qt*
\m \qt minzi nitni ad ẓaren AREBBI.\qt* \x ◘ \xo 5:8 \xt Izhd. 15:2; 24:4; Ɛbr. 12:14. \x*
\m 
\v 9 \qt Sseɛd n yinni itteggen řehna,\qt*
\m \qt minzi nitni ad ttwasemman arrawen n AREBBI.\qt*
\m 
\v 10 \qt Sseɛd n yinni inneḥṣaren x ssibbet n tsegda,\qt*
\m \qt minzi Tageldit n ijenwan ad ɣarsen tiři.\qt* \x ◘ \xo 5:10 \xt 2 Kur. 4:10; 2 Tim. 2:12; 1 Bṭ. 3:14. \x*
\m 
\v 11 \qt Sseɛd i kenniw mařa ttɛayaren\qt*
\m \qt u ttdarracen xawem\qt*
\m \qt uca ad xawem inin\qt*
\m \qt ɛřam kuř awařen iɛeffanen x ssibbet inu,\qt*
\m \qt waxxa ssxarriqen.\qt* \x ◘ \xo 5:11 \xt 1 Bṭ. 4:14. \x*
\m 
\v 12 \qt Farḥem, sřiweřwem,\qt*
\m \qt minzi řmunet nwem d tameqqrant deg ijenwan,\qt*
\m \qt minzi ammu i tuɣa ttdarracen inabiyyen,\qt*
\m \qt inni qbeř nwem.”\qt* \x ◘ \xo 5:12 \xt Lk. 6:23. \x*
\b
\m 
\v 13 “Kenniw d \bd tameǧaḥt n temmurt\bd*. Maca mařa tameǧaḥt ixsar uředdi nnes, mammec ɣa negg ad tt narr d tameǧaḥt? War tneffeɛ ɛad i walu, ḥaca ad temmenḍar ɣar barra, ad xas ɛefsen iwdan.”
\m 
\v 14 “Kenniw d \bd tafawt n ddunect\bd*. Tandint i ittwabnan x wedrar, war tzemmar ad tᵉnnuffar.
\v 15 War ssreqqin řefnar uca ad t ssarsen sadu řmud, maca ad t ssarsen x řmerfeɛ, \add maḥend\add* ad yarɣ i marra inni iǧan di taddart. \x ◘ \xo 5:15 \xt Mk. 4:21; Lk. 8:16; 11:33. \x*
\v 16 Jjem tafawt nwem ad tarɣ i iwdan, ḥima ad ẓaren řexdayem nwem icnan, ad ssuɛřan Babatwem i iǧan deg ijenwan.” \x ◘ \xo 5:16 \xt 1 Bṭ. 2:12. \x*
\m 
\v 17 “Aqa ad awem ittɣiř aqa usiɣ-dd ḥima ad ssbeṭṭřeɣ \bd Ccariɛa niɣ Inabiyyen. Necc war dd-usiɣ ca ḥima ad ssbeṭṭřeɣ, maca ḥima ad kemmřeɣ.\bd* \f ◼ \fr 5:17 \fk Ccariɛa n Musa\ft - ixs ad yini Ttawrat am mammec d as qqaren Wudayen.\f*
\v 18 S tidett, Necc ad awem iniɣ: Ař i ɣa iɛdu ujenna d temmurt, war ibeṭṭeř uřa d ijjen řḥarf niɣ d icten taneqqiṭ zi Ccariɛa ař ɣa yiři kuřci. \x ◘ \xo 5:18 \xt Lk. 16:17. \x*
\v 19 S uya wenni i ɣa issbeṭṭřen zi tweṣṣa-ya icten, waxxa d tameẓyant, uca isseřmad iwdan ammu, ad ittwasemma d ameẓyan di Tgeldit n ijenwan, maca wenni zzaysent iggin u isseřmad i-tent, netta ad ittwasemma d ameqqran di Tgeldit n ijenwan. \x ◘ \xo 5:19 \xt Yaɛ. 2:10. \x*
\v 20 Minzi Necc ad awem iniɣ: Mařa tasegda nwem war tmeqqar ca x tenni n imseřmaden n idlisen d tenni n Ifarisiyyen, s tidett war tᵉttidfem ca ɣar Tgeldit n ijenwan!”
\b
\m 
\v 21 “Aqa tesřim belli ittwanna i řejdud: \bd ‘War neqq!’\bd*, u: ‘Wenni ineqqen, ad ittwaḥaseb!’ \x ◘ \xo 5:21 \xt Uf. 20:13; Aɛwd. 5:17. \x*
\v 22 Maca Necc ad awem iniɣ: Marra wenni ittxeyyaqen x umas břa ssibbet, nhřa ma ad xas ittwaḥakem, u marra wenni iqqaren i umas: ‘Ad xak ssusfeɣ!’, ad ittwaḥkem xas zzat i Jmaɛet \add Tameqqrant\add*, u wenni iqqaren: ‘\add A\add* abuhaři!’ ad ittwaḥakem, ad yadef ɣar tmessi n jᵉhennama. \f ◼ \fr 5:22 \fq ’Jmaɛet \bdit Tameqqrant\bdit*\ft - niɣ: ‘Jmaɛet n řḥukkam imeqqranen n Wudayen’.\f*
\v 23 Mařa tqeddmed tawhibt nnec x uɛalṭar \add min xef ssarsen tiɣarṣa d tewhibin\add*, uca dinni tɛeqřed belli umac aqa-t ca xak,
\v 24 ejj tawhibt nnec \add din\add* zzat i uɛalṭar, ruḥ amezwaru, tṣeřḥed ak-d umac, xenni dweř-dd, uca ewc tawhibt nnec.
\v 25 Iři twejded i weṣřaḥ ak-d weɣrim nnec umi cek ɛad akides deg webrid, ḥima aɣrim nnec war cek ittiwi ɣar řqaḍi, \add xenni\add* řqaḍi ad cek yawi ɣar umxazni uca ad temmenḍared di řeḥbes. \x ◘ \xo 5:25 \xt Lk. 12:58; Afa. 4:26. \x*
\v 26 S tidett, Necc ad ac iniɣ: War dd-teffɣed ssenni, ař ɣa txeǧṣed aṣuldi aneggaru.”
\b
\m 
\v 27 Aqa tesřim belli ittwanna: \bd ‘War zenni ca!’\bd*, \x ◘ \xo 5:27 \xt Uf. 20:14; Aɛwd. 5:18. \x*
\v 28 \add maca\add* Necc ad awem iniɣ, marra wenni i ɣa ixzaren ɣar temɣart s nnecwet, aqa izna deɣya akides deg wuř nnes. \x ◘ \xo 5:28 \xt Ayub 31:1; Izhd. 119:37. \x*
\v 29 Mařa tessenqarḍ cek tiṭṭ nnec tafusect, qess i-tt, nḍar i-tt xak. Iḥřa ac mařa iweddar ijj n ṭṭarf \add n arrimet nnec\add* x uweṭṭu n arrimet nnec marra di jᵉhennama. \x ◘ \xo 5:29 \xt Mt. 18:8; Mk. 9:43. \x*
\v 30 Mařa tessenqarḍ cek afus nnec afusi, qess i-t, nḍar i-t xak, minzi iḥřa ac mařa iweddar ijj n ṭṭarf \add n arrimet nnec waha\add* x uweṭṭu n arrimet nnec marra di jᵉhennama.”
\b
\m 
\v 31 “Aqa ittwanna ɛawed: \bd ‘Wenni i ɣa iǧfen i temɣart nnes, ad as iwc tabrat n waǧaf!’\bd* \x ◘ \xo 5:31 \xt [Mt. 19:9; Mk. 10:11-12; Lk. 16:18] — Řxř. 30:2; Aɛwd. 23:20-22; 24:1; \x*
\v 32 Maca Necc ad awem iniɣ: Marra wenni i ɣa iǧfen i temɣart nnes, war iǧi zi ssibbet n farq-ccɣeř, ittarra i-tt ad tezna, uca wenni i ɣa imeřcen tenni umi iǧfen, aqa netta izna.” \x ◘ \xo 5:32 \xt Mt. 19:7; Mk. 10:4, 11; Lk. 16:18; 1 Kur. 7:10. \x*
\b
\m 
\v 33 “Aqa tesřim ɛawed belli ittwanna i řejdud: \bd ‘War tejjaǧid ẓur, \bdit maca\bdit* egg min tejjuǧed i SIDI!’\bd* \x ◘ \xo 5:33 \xt Uf. 20:7; Lawi 19:12; Aɛwd. 5:11; 23:22 \x*
\v 34 \add Maca\add* Necc ad awem iniɣ: War tejjaǧam ɛemmarṣ, uřa ɣar ujenna minzi netta d řɛarc n AREBBI, \x ◘ \xo 5:34 \xt Ica. 66:1; Yaɛ. 5:12. \x*
\v 35 uřa ɣar temmurt, minzi nettat d tanebdat sadu iḍaren nnes, uřa ɣar \add tendint n\add* Urcalim, minzi nettat d tandint n Ujeǧid d ameqqran, \x ◘ \xo 5:35 \xt Izhd. 48:3; Ica. 66:1. \x*
\v 36 uca war tejjaǧam uřa ɣar uzeǧif nnec, minzi war tzemmared ad tarred uřa d ijj n uẓeṭṭu \add n ucuwwaf\add* d acemřař niɣ d abarcan.
\v 37 Ad iqqim wawař nwem ‘Wah!’ d ‘Wah!’, ‘Lla!’ d ‘Lla!’. Mana ktar zi man aya, aqa netta zeg umɛeffan.”
\b
\m 
\v 38 “Aqa tesřim belli ittwanna: \bd ‘Tiṭṭ s tiṭṭ d tiɣmest s teɣmest!’\bd*, \x ◘ \xo 5:38 \xt [Lk. 6:29-30] — Uf. 21:24; Lawi 24:20; Aɛwd. 19:21; \x*
\v 39 \add Maca\add* Necc ad awem iniɣ, war tᵉttemɛařam ca ak-d ijj n uɛeffan, maca wenni i ɣa isseqqřen ameggiz nnec afusi, seřqa yas uřa d \add ameggiz\add* nneɣni. \x ◘ \xo 5:39 \xt Awřn. 24:29; Lk. 6:29; Rum. 12:17; 1 Kur. 6:7; 1 Ts. 5:15; 1 Bṭ. 3:9. \x*
\v 40 Mařa din ḥed ixs ad kik igg ccreɛ uca netta ad xak ikkes tcamir nnec, ejj i-t ad iksi uřa d ajeǧab. \x ◘ \xo 5:40 \xt Lk. 6:29\x*
\v 41 Wenni xak iggin bezzez ḥima ad kides tuyured ijj n kilumitr, uyur akides tnayen. \f ◼ \fr 5:41 \fk ijj n kilumitr\ft - s Tramit ‘ijj n mayl’.\f*
\v 42 Man wen d ac i ɣa ittaren ca n řḥajjet, ewc as tt, u wenni yarezzun ad xak yarḍeř, war d t ttarra amenni.” \x ◘ \xo 5:42 \xt Aɛwd. 15:8; Lk. 6:35. \x*
\b
\m 
\v 43 “Aqa tesřim belli ittwanna: \bd ‘Ad texsed jjar nnec, ad tcarhed řeɛdu nnec!’\bd* \x ◘ \xo 5:43 \xt [Lk. 6:27-28; 32-36] — Lawi 19:18\x*
\v 44 Maca Necc ad awem iniɣ: Xsem řɛedyan nwem u barkem inni kenniw ineɛɛřen, ggem tcuni i yinni kenniw icarrhen, ẓaǧem i yinni kenniw ittawyen d imeḥbas d yinni xawem ittdarracen, \x ◘ \xo 5:44 \xt Lk. 6:27; 23:34; Řex. 7:60; Rum. 12:20; 1 Kur. 4:13; 1 Bṭ. 2:23. \x*
\v 45 ḥima ad tiřim d tarwa n Babatwem i iǧan deg ijenwan, minzi Netta issneqqar tafuct nnes x iṣebḥanen d iɛeffanen, uca Netta yarexxu-dd i wenẓar, ḥima ad iwwet x imseggaden u x yinni war iseggden.
\v 46 Minzi mařa texsem inni kenniw ittexsen, man arbeḥ i ɣarwem? Ma war tteggen ayt n ḍḍariba uřa ammu? \f ◼ \fr 5:46 \fk ayt n ḍḍariba\ft - niɣ ‘iɛeccaren’. Ayt n ḍḍariba nitni d Udayen i ixeddmen ak-d řmexzen n Irumaniyyen, jemmɛen ḍḍariba. Ca zzaysen ksin zi ḍḍariba i yixef nsen.\f*  \x ◘ \xo 5:46 \xt Lk. 6:32. \x*
\v 47 Mařa tseǧmem x wawmaten nwem waha, min i tᵉtteggem ktar \add x wenneɣni\add*? Ma war tteggen ayt n ḍḍariba uřa ammu?
\v 48 S uya iřim nican qaɛ am mammec uřa d Babatwem i iǧan deg ijenwan iǧa nican qaɛ.” \x ◘ \xo 5:48 \xt Amz. 17:1\x*
\b
\b
\c 6
\m 
\v 1 “Ḥḍam, war tṣeddaqem zzat i iwdan, ḥima ad kenniw ẓaren. Mařa amya, war ɣarwem ittiři bu řajar zi Babatwem i iǧan deg ijenwan.
\v 2 \bd Mařa tṣeddqed\bd*, war tt ttegg di řbuq am mammec t tteggen imnafqen di temzidawin u di zznaqi, ḥima ad ten cennɛen iwdan. S tidett Necc ad awem iniɣ, nitni aqa ufin řajar nsen zi beɛda. \x ◘ \xo 6:2 \xt Rum. 12:8. \x*
\v 3 \add Maca\add* cek, xmi ɣa tṣeddqed, ittxeṣṣa afus nnec azeřmaḍ war issin min ittegg ufusi nnec,
\v 4 ḥima ṣṣedqet nnec ad tiři s tnuffra uca Babac, wenni ittwařan di tnuffra, ad cek ixeǧeṣ s bṭayṭay.” \x ◘ \xo 6:4 \xt Lk. 14:14. \x*
\b
\m 
\v 5 “\bd Mařa teẓẓuǧed\bd*, war ttiři ca am yimnafqen inni umi iɛjeb asen řḥař ad ẓẓaǧen am bedden di temzidawin d tɣemmura n zznaqi ḥima ad ten ẓaren iwdan. S tidett Necc ad awem iniɣ, aqa nitni ufin řajar nsen zi beɛda. \x ◘ \xo 6:5 \xt [Lk. 11:2-4] \x*
\v 6 Maca cek, mařa teẓẓuǧed, adef ɣar wexxam nnec, belleɛ tawwart, ẓẓaǧ i Babac wenni iǧan di tnuffra, uca Babac i ittwařan di tnuffra d Netta i cek i ɣa ixeǧṣen s bṭayṭay. \x ◘ \xo 6:6 \xt 2 Ij. 4:33; Řex. 10:4. \x*
\v 7 Mařa teẓẓuǧem war ttɛawadem i wawař am mammec ttẓaǧan lkuffar, minzi ittɣiř asen s wawařen \add nsen\add* aṭṭas ad asen ittwaseř. \x ◘ \xo 6:7 \xt 1 Ij. 18:28; Ica. 1:15. \x*
\v 8 War ttiřim xenni am nitni, minzi Babatwem issen min teḥdajem qbeř d as i ɣa tᵉttarem ca.
\v 9 Ammu i ɣa teẓẓaǧem kenniw:
\b
\m \qt ‘A Babatneɣ i iǧan deg ijenwan,\qt*
\m \qt ad yiři Isem nnec ittwaqeddes,\qt* \x ◘ \xo 6:9 \xt Lk. 11:2. \x*
\m 
\v 10 \qt ejj ad dd-tas Tgeldit nnec,\qt*
\m \qt ad yiři řxaḍar nnec\qt*
\m \qt am deg ujenna ammu ɛawed di temmurt.\qt*
\m 
\v 11 \qt Ewc aneɣ ass-a aɣrum i nehdaj.\qt*
\m 
\v 12 \qt Ɣfar aneɣ imarwusa nneɣ,\qt*
\m \qt am mammec nsameḥ ɛawed\qt*
\m \qt i yinni dd aneɣ ittursen,\qt*
\m 
\v 13 \qt u war d aneɣ sidif ca deg ujarreb,\qt*
\m \qt maca fekk aneɣ zeg umɛeffan.\qt*
\m \qt Minzi Tageldit d jjehd d uɛuǧi\qt*
\m \qt ad iřin i Cek i řebda qaɛ!’\qt* \x ◘ \xo 6:13 \xt Mt. 13:19. \x*
\b
\m 
\v 14 Maɣar mařa kenniw tsamḥem i iwdan i iɛeddiyen nsen, uřa d Babatwem i iǧan deg ijenwan ad awem iɣfar. \x ◘ \xo 6:14 \xt Mk. 11:25; Kul. 3:13. \x*
\v 15 Maca mařa kenniw war tᵉttsimiḥem i iwdan, aqa uřa d Babatwem war iɣeffar ca iɛeddiyen nwem.” \x ◘ \xo 6:15 \xt Mt. 18:35; Yaɛ. 2:13. \x*
\b
\m 
\v 16 “\bd Řami tẓummem\bd*, war tteggem aɣembub abarcan am yimnafqen, inni issneqřaben aɣembub nsen ḥima ad ten ẓaren iwdan belli aqa ẓummen. S tidett Necc ad awem iniɣ, aqa nitni ufin řajar nsen zi beɛda. \x ◘ \xo 6:16 \xt Ica. 58:3; Mt. 9:14; Mk. 2:18; Lk. 5:33. \x*
\v 17 \add Maca\add* cek, mařa tẓummed, dhen azeǧif nnec uca sired aɣembub nnec,
\v 18 ḥima war tbinid ca i iwdan belli tᵉttẓummed, maca i Babac wenni iǧan di tnuffra, uca Babac i ittwařan di tnuffra, aqa Netta i cek i ɣa ixeǧṣen.”
\b
\m 
\v 19 “\bd War smunam ca řeknuz i yixef nwem da di ddunect\bd* mani i ten ɣa tecc tcinda d ddra, u mani ɣa ssnuqqben ixewwanen, ad \add ten\add* acaren, \x ◘ \xo 6:19 \xt [Lk. 12:33-34; 11:34-36; 16:13] — Awřn. 23:4; Ɛbr. 13:5; Yaɛ. 5:1. \x*
\v 20 \add maca\add* smunem i yixef nwem řeknuz deg ujenna mani war ten tᵉttett ca tcinda d ddra, u mani war ssnuqquben ixewwanen, war \add ten\add* ttacaren. \x ◘ \xo 6:20 \xt Lk. 12:33; 1 Tim. 6:19. \x*
\v 21 Minzi mani ɣa yiři řkenz nnec, aqa ad din yiři uřa d uř nnec.”
\b
\m 
\v 22 “\bd Řefnar n arrimet netta d tiṭṭ.\bd* Mařa xenni tiṭṭ nnec aqa teṣfa, ad tiři arrimet nnec marra d tafawt. \x ◘ \xo 6:22 \xt Lk. 11:34-36;\x*
\v 23 Mara tiṭṭ nnec d taɛeffant, xenni ad tiři arrimet nnec marra d taǧest. Mařa tafawt tenni dayek d taǧest, mecḥař temɣar taǧest!
\b
\m 
\v 24 \bd Uřa d ijj war izemmar ad ixdem i tnayen n isiditen,\bd* minzi \add xenni\add* netta ad icarh ijjen, ad ixs wenneɣni, niɣ ad iweqqar ijjen, ad isseḥqar wenneɣni. Kenniw war tzemmarem ad tsexxarem i AREBBI d tenɛacin.” \x ◘ \xo 6:24 \xt Lk. 16:13. \x*
\b
\m 
\v 25 “S uya Necc ad awem iniɣ: ‘\bd War kessim amnus di tudart nwem\bd*, min ɣa teccem niɣ min ɣa teswem, uřa i arrimet nwem mammec tt i ɣa tessyarḍem. Xzarem, ma war teḥři tudart x macca niɣ arrimet x warruḍ? \x ◘ \xo 6:25 \xt [Lk. 12:22-34] — Izhd. 37:5; 55:23; Fil. 4:6; 1 Tim. 6:8; 1 Bṭ. 5:7. \x*
\v 26 Xzarem ɣar ijḍaḍ n ujenna, aqa nitni war zarrɛen, war mejjaren uca war ttxemmiřen di řemrasi. Waxxa amenni Babatwem i iǧan deg ijenwan i ten isseccan. Xzarem, ma kenniw war tessekkwim ca ktar aṭṭas xasen? \x ◘ \xo 6:26 \xt Ayub 38:41; Izhd. 147:9. \x*
\v 27 Man wen zzaywem izemmar s wemnus nnes ad yarni \add mɣir\add* ijj n uɣiř di tuzzeggart nnes?
\v 28 U mayemmi tkessim amnus i warruḍ? Xzarem mammec ɣemmyent tlillicin deg iyyar. Nitenti war xeddment, war ttqarḍcent, \f ◼ \fr 6:28 \fk tilillicin\ft - ijj n marka n nnuwarat daysen aẓri aṭṭas.\f*
\v 29 \add maca\add* Necc ad awem iniɣ, uřa d Suliman di marra aɛuǧi nnes war yarḍ ca am yijjen zzaysen.
\v 30 Mařa AREBBI issyarḍ ammu arbiɛ n iyyar i iǧan ass-a uca tiwecca ad immenḍar di tefqunt, ma xenni war kenniw \add issyirreḍ\add* aṭṭas ḥsen zzayes, \add a\add* kenniw i di iǧa drus n l’iman?
\v 31 S uya war kessim ca amnus, war qqarem: ‘Min ɣa necc?’, u: ‘Min ɣa nsu?’, niɣ: ‘Min ɣa nyarḍ?’
\v 32 Maɣar řegnus n ddunect arezzun man aya marra, \add maca\add* Babatwem i iǧan deg ijenwan issen aqa teḥdajem man aya marra.
\v 33 Arzum amezwaru x Tgeldit n AREBBI d tsegda nnes, uca man aya marra ad ɣarwem immarni ɛawed. \x ◘ \xo 6:33 \xt 1 Ij. 3:13; Izhd. 37:25; 55:23. \x*
\v 34 S uya war kessim amnus i \add min i ɣa yiři\add* tiwecca, minzi tiwecca ad teksi amnus i yixef nnes. Icfa i \add kuř\add* ass tuɛeffna nnes.”
\b
\b
\c 7
\m 
\v 1 “\bd War ḥekkmem, ḥima war tᵉttwaḥakamem,\bd*\x ◘ \xo 7:1 \xt [Lk. 6:37-38; 41-42] — Rum. 2:1; 1 Kur. 4:3, 5. \x*
\v 2 minzi ɛlaḥsab řḥukm i zi ɣa tḥekmem, ad tᵉttwaḥakmem, u ɛlaḥsab řeɛbar i zi ɣa teɛbarem, ad tᵉttwaɛbarem ɛawed. \x ◘ \xo 7:2 \xt Mk. 4:24; Lk. 6:38. \x*
\v 3 Mayemmi txezzared ɣar \bd uxecciw\bd* di tiṭṭ n umac, \add maca\add* war tḥekkared ca i \bd teḥnact\bd* tenni di tiṭṭ nnec? \x ◘ \xo 7:3 \xt Lk. 6:41, 42. \x*
\v 4 Xenni mammec ɣa tegged ad tinid i umac: ‘Ejj ayi ad ac dd-ssuffɣeɣ axecciw zi tiṭṭ nnec’, \add uca\add* xzar, aqa cek ɣarek taḥnact di tiṭṭ nnec?
\v 5 Cek, \add a\add* amnafeq, suffeɣ-dd amezwaru taḥnact zi tiṭṭ nnec, xenni tzemmared ad texzared mliḥ ḥima ad tessuffɣed axecciw zi tiṭṭ n umac. \x ◘ \xo 7:5 \xt Awřn. 18:17. \x*
\m 
\v 6 \bd War tticem min iqeddsen i yiṭan\bd*, war neṭṭarem ca tiyaqutin nwem i iřfan, ḥima war xasent ɛeffsen s iḍaren nsen uca ad \add ɣarwem\add* dd-nqeřben, ad kenniw mezzqen.” \x ◘ \xo 7:6 \xt Awřn. 9:8; 23:9. \x*
\b
\m 
\v 7 “\bd Ttarem, ad awem immewc\bd*, arzum, ad tafem, sqarqbem, ad awem ittwarzem. \x ◘ \xo 7:7 \xt [Lk. 11:9-13] — Mt. 21:22; Mk. 11:24; Yḥ. 14:13; 16:24; Yaɛ. 1:5, 6; 1 Yḥ. 3:22; 5:14. \x*
\v 8 Maɣar marra wenni i ɣa ittaren, ad iṭṭef u wenni i ɣa yarzun ad yaf, u wenni i ɣa issqarqben ad \add as\add* ittwarzem. \x ◘ \xo 7:8 \xt Awřn. 8:17; Irm. 29:12. \x*
\v 9 Niɣ man bnadem jar awem, mařa mmis ittar as aɣrum, ad as iwc aẓru?
\v 10 Niɣ mařa ittar as tasřemt, ad as iwc afiɣar?
\v 11 Mařa kenniw, waxxa kenniw d iɛeffanen, aqa tessnem mammec ɣa tewcem min iṣebḥen i tarwa nwem, mecḥař ɛad Babatwem i iǧan deg ijenwan ad yewc min iṣebḥen i yinni d as i ɣa ittaren! \x ◘ \xo 7:11 \xt Amz. 6:5; 8:21. \x*
\v 12 Qaɛ am mammec texsem ad awem ggen iwdan, ggem amya kenniw i nitni, minzi man aya d Ccariɛa d Inabiyyen.” \x ◘ \xo 7:12 \xt Lk. 6:31. \x*
\b
\m 
\v 13 “\bd Adfem zi tewwart iḥṣaren\bd*, minzi tawwart temɣar uřa d abrid i ittawyen ɣar uhellek d miriw, uca aṭṭas i zzayes ittadfen. \x ◘ \xo 7:13 \xt [Lk. 13:24] \x*
\v 14 Mammec teḥṣar tewwart u mammec imẓi webrid i ittawyen ɣar tudart! Mɣir drus n yinni t ittafen.” \x ◘ \xo 7:14 \xt Řex. 14:22. \x*
\b
\m 
\v 15 “\bd Ḥḍam ixef nwem zeg inabiyyen issxarriqen\bd* i dd-ittasen ɣarwem s thiḍurt n izmaren, maca deg iɛeddisen nsen aqa nitni d uccanen itteṭṭfen. \x ◘ \xo 7:15 \xt [Lk. 6:43-44; 13:25-27] — Aɛwd. 13:4; Irm. 23:16; Mt. 24:4; Rum. 16:17; Afa. 5:6; Kul. 2:8; 1 Yḥ. 4:1.\x*
\v 16 Zi řɣiǧet nsen ad ten tessnem. Ma ad řeqḍen aḍiř zeg isennanen niɣ tazart zi tzeggʷart?
\v 17 Ammu kuř tacejjart taṣebḥant tᵉttawi-dd řɣiǧet teṣbeḥ, uca tacejjart taɛeffant tᵉttawi-dd řɣiǧet taɛeffant. \f ◼ \fr 7:17 \fk tacejjart\ft - niɣ ‘addag’ (‘iddagen’).\f*  \x ◘ \xo 7:17 \xt Mt. 3:10; 12:33; Mk. 11:13; Lk. 8:8. \x*
\v 18 Tacejjart taṣebḥant war tzemmar ad tewc řɣiǧet taɛeffant, uca tacejjart taɛeffant war tzemmar ad tewc řɣiǧet taṣebḥant.
\v 19 Kuř tacejjart tenni war itticen řɣiǧet teṣbeḥ, ad tᵉttwaqess uca ad temmenḍar di tmessi.
\v 20 S uyenni ad ten tessnem zi řɣiǧet nsen.”
\b
\m 
\v 21 “\bd War iǧi ca kuř ijjen wenni d ayi ɣa inin: ‘A Sidi, a Sidi!’\bd*, ad yadef ɣar Tgeldit n ijenwan, maca d wenni itteggen min ixs Baba i iǧan deg ijenwan. \x ◘ \xo 7:21 \xt Mt. 25:11; Lk. 6:46; 13:25-27; Řex. 19:13; Rum. 2:13; Yaɛ. 1:22. \x*
\v 22 Aṭṭas i d ayi ɣa inin deg wass nni: ‘A Sidi, a Sidi, ma war nettnabb ca s Yisem nnec, ma war nuẓẓiř x ccwaṭen s Yisem nnec u s Yisem nnec ma war neggi aṭṭas n řeɛjayeb?’ \x ◘ \xo 7:22 \xt Irm. 14:14; 27:15; Lk. 13:26. \x*
\v 23 Xenni Necc ad asen iniɣ nican: ‘Ɛemmarṣ war kenniw ssineɣ, beɛɛdem xafi, \add a\add* kenniw inni itteggen řmuɛṣiyyet!’” \x ◘ \xo 7:23 \xt Izhd. 6:9; Mt. 25:12,41; Lk. 13:25, 27. \x*
\b
\m 
\v 24 “\bd S uya marra wenni ittesřan i wawařen inu, ittegg zzaysen\bd*, ad ittwamqudda ak-d ijj n bnadem d amiɣis wenni ibnan taddart nnes x sseǧaḥ. \x ◘ \xo 7:24 \xt Irm. 17:8; Lk. 6:47; Rum. 2:13; Yaɛ. 1:25. \x*
\v 25 Xenni iwta wenẓar, ḥemřen-dd iɣezran, suḍen-dd isemmiḍen uca řeqfen taddart nni, \add maca\add* waxxa amenni war dd-tewḍi ca, minzi dsas nnes immars x sseǧaḥ.
\v 26 \add Maca\add* marra wenni ittesřan i wawařen inu, war zzaysen ittegg, ad yiři am yijj n bnadem d afɣuř i ibnan taddart nnes x ijdi. \x ◘ \xo 7:26 \xt Ḥiz. 13:11; Rum. 2:13; Yaɛ. 1:23. \x*
\v 27 Xenni iwta wenẓar, ḥemřen-dd iɣezran, suḍen-dd isemmiḍen, řeqfen taddart nni uca tewḍa, tuɣa aweṭṭu nnes d ameqqran.”
\b
\s1 ANEGGAR N UBARREḤ X WEDRAR
\m 
\v 28 \bd Awarni řami ikemmeř Yasuɛ awařen-a\bd*, aqa imsar belli řɣaci iqqim ittebhet s tɣuri nnes,
\v 29 minzi tuɣa isseřmad i-ten amecnaw wenni ɣar teǧa ṣṣulṭa, war iǧi ca am yimseřmaden n idlisen d Ifarisiyyen. \x ◘ \xo 7:29 \xt Mk. 1:22; 6:2; Lk. 4:32. \x*
\b
\b
\c 8
\s1 Asgenfi n ijj n bu-řbarṣ
\m 
\v 1 Řami dd-ihwa zeg wedrar, ḍfaren t-i-dd aṭṭas n řɣaci. \x ◘ \xo 8:1 \xt [Mk. 1:40-45; Lk. 5:12-16]\x*
\v 2 Xzar, yusa-dd ɣares ijjen i di iǧa řbarṣ, isjed as, inna: “A Sidi, mařa texsed, tzemmared ad ayi tessizdeged!” \x ◘ \xo 8:2 \xt Mk. 1:40; Lk. 5:12. \x*
\v 3 Yasuɛ isswiẓẓeḍ afus nnes uca iḥada t, inna: “Necc xseɣ, zdeg!” Uca ittwassizdeg zi řbarṣ nnes řexdenni.
\v 4 \add Xenni\add* inna as Yasuɛ: “Xzar, war tteqqar i ḥed, maca ruḥ, scen ixef nnec i ukehhan uca ewc taɣarṣt i Arebbi ɛlaḥsab min zzayes iweṣṣa Musa, aqa-tt d cchadet i nitni.” \x ◘ \xo 8:4 \xt Lawi 13:2; 14:2; Lk. 5:14. \x*
\b
\s1 Amsexxar n řqebṭan arumani
\m 
\v 5 Řami yudef Yasuɛ ɣar Kafarnaḥum, yusa-dd ɣares ijj n řqebṭan x mya, ittar zzayes \add ammu\add*, \x ◘ \xo 8:5 \xt [Lk. 7:1-10; Yḥ. 4:43-54] — Lk. 7:1\x*
\v 6 inna: “A Sidi, amsexxar ameẓyan inu izzeř di taddart d aneɛḍab, aqa dayes řeḥriq aṭṭas!”
\v 7 Inna as Yasuɛ: “Necc ad dd-aseɣ, ad t ssgenfiɣ!”
\v 8 Uca řqebṭan x mya yarra-dd, inna: “A Sidi, necc war sdiheǧeɣ ad tadfed swadday i tzeqqa inu, maca ini ijj n wawař waha, xenni ad iggenfa umsexxar ameẓyan inu. \x ◘ \xo 8:8 \xt Izhd. 107:20. \x*
\v 9 Minzi uřa d necc ɛawed d bnadem sadu ifassen uca ɣari iɛeskariyyen sadu ufus inu, qqareɣ i wa: ‘Ruḥ!’, xenni ad iraḥ, u i wenneɣni: ‘As-dd!’, xenni ad dd-yas, u i umsexxar inu \add qqareɣ as\add*: ‘Egg man aya!’, uca ad t igg.”
\v 10 Řami isřa Yasuɛ man aya, ittebhet, inna i yinni akides iǧan: “S tidett Necc ad awem iniɣ, war ufiɣ uřa di Israil l’iman am wanita.
\v 11 Necc ad awem iniɣ, belli aṭṭas i dd ɣa yasen zi ccarq u zi řɣarb, ad qqimen \add ɣar ṭṭabřa\add* ak-d Ibrahim d Isḥaq d Yaɛqub di Tgeldit n ijenwan, \x ◘ \xo 8:11 \xt Lk. 13:29. \x*
\v 12 \add maca\add* tarwa n Tgeldit ad mmenḍaren barra ɣar ṭṭarf aneggaru n taǧest. Dinni ad iřin imeṭṭawen d uɣezzi n teɣmas.” \x ◘ \xo 8:12 \xt Mt. 13:42; 21:43; 22:13; 24:51; Lk. 13:28. \x*
\v 13 Yasuɛ inna i řqebṭan x mya: “Ruḥ, ad imsar am mammec tumned.” Uca iggenfa uḥenjir nnes di tsaɛɛet nni.
\b
\s1 Asgenfi n tḍekkwač n Buṭrus
\m 
\v 14 \add Řexdenni\add* yusa-dd Yasuɛ ɣar taddart n Cimɛun, iẓra taḍekkwač nnes tezzeř, dayes timessi. \x ◘ \xo 8:14 \xt [Mk. 1:29-34; Lk. 4:38-41] — Mk. 1:29; Lk. 4:38.\x*
\v 15 Iḥada afus nnes uca truḥ as tmessi, řexdenni tekkar, tsexxar xas.
\v 16 Ɣar uɛecci iwyen-dd ɣares aṭṭas n imaryaḥen i daysen ccwaṭen. Issuffeɣ ccwaṭen nsen s yijj n wawař \add waha\add*, uca issgenfa marra imehřac,
\v 17 ḥima ad ittwakemmeř min ittwannan zeg unabi Icaɛya: “Ad iksi řeḥriq nneɣ u ad yarbu řehřac nneɣ.” \x ◘ \xo 8:17 \xt Ica. 53:4; 1 Bṭ. 2:24. \x*
\b
\s1 Aḍfar n Yasuɛ
\m 
\v 18 Řami iẓra Yasuɛ řɣaci ameqqran i d as dd-innḍen, yumur \add i-ten\add* ad ẓwan ɣar ujemmaḍ. \x ◘ \xo 8:18 \xt [Lk. 9:57-62] \x*
\v 19 Uca yusa-dd ɣares ijj n umseřmad n idlisen, inna as: “\add A\add* Amseřmad inu, ad Cek ḍfareɣ mani ma i ɣa traḥed!” \x ◘ \xo 8:19 \xt Lk. 9:57. \x*
\v 20 Inna as Yasuɛ: “Iceɛban ɣarsen ifran u ijḍaḍ n ujenna ɣarsen řeɛwacc, maca Mmis n bnadem war yufi ca mani ɣa isenned azeǧif nnes.”
\v 21 Inna as ijjen nneɣni zeg imeḥḍaren nnes: “\add A\add* Sidi, ejj ayi d amezwar ad uyureɣ ad neḍřeɣ baba!”
\v 22 Inna as Yasuɛ: “Ḍfar ayi-dd, ejj imettinen ad neḍřen imettinen nsen!” \x ◘ \xo 8:22 \xt 1 Tim. 5:6. \x*
\b
\s1 Yasuɛ d tḥaryaḍt
\m 
\v 23 Řami inya di tɣarrabut, nyin imeḥḍaren nnes akides. \x ◘ \xo 8:23 \xt [Mk. 4:35-41; Lk. 8:22-25] — Mk. 4:35; Lk. 8:22\x*
\v 24 Uca xzar, tekkar-dd ict n tḥaryaḍt di řebḥar ař mani dřint řemwaj aɣarrabu, maca Yasuɛ tuɣa iṭṭeṣ.
\v 25 Usin-dd ɣares imeḥḍaren nnes uca ssfaqen t-i-d, nnan as: “\add A\add* Siditneɣ, senjem aneɣ, aqa ad nettwahellek!”
\v 26 Inna asen: “Mayemmi tᵉtteggʷedem, \add a\add* kenniw i di iǧa drus n l’iman?” Xenni ikkar, iwebbex asemmiḍ d řebḥar, uca tusa-dd řhudnet tameqqrant. \x ◘ \xo 8:26 \xt Ayub 26:12; Izhd. 107:29; Ica. 51:10. \x*
\v 27 Tbehten iwdan, nnan: “Min iɛna wa umi isemmiḍen d řebḥar ttᵉṭṭaɛen as?”
\b
\s1 Asgenfi n tnayen n imeryaḥen
\m 
\v 28 Řami yiweḍ ɣar ujemmaḍ ɣar temmurt n Gadarinis, řqan t-i-dd tnayen n imaryaḥen, ffɣen-dd zeg imeḍřan, tuɣa mmuzzaren aṭṭas ař mani uřa d ijj war izemmar ad yekk abrid nni. \x ◘ \xo 8:28 \xt [Mk. 5:1-20; Lk. 8:26-39] — Mk. 5:1; Lk. 8:26\x*
\v 29 Sɣuyyen, nnan: “Min din jar aneɣ d Cek, a Yasuɛ, Mmis n AREBBI? Ma tusid-dd danita ḥima ad aneɣ tɛeddbed qbeř řweqt?”
\v 30 Tuɣa din ict n tḥimart n iřfan tameqqrant tiggʷej xasen, thedda din.
\v 31 Uca ccwaṭen ttaren zzayes, nnan: “Mařa tessuffɣed aneɣ, ejj aneɣ ad nadef ɣar tḥimart n yeřfan!”
\v 32 Inna asen: “Ruḥem!” Řexdenni ffɣen-dd, udfen deg iřfan. Uca xzar, taḥimart n iřfan amen tmun teḥduddar zi teysart, uca iřfan wḍan di řebḥar, mmuten deg waman.
\v 33 Arewřen imeksawen uca řami iwḍen ɣar tendint, xebbaren x kuřci min imsaren, uřa x imaryaḥen.
\v 34 Uca xzar, ffɣen-dd aytbab n tendint marra i umsagar ak-d Yasuɛ. Umi t ẓrin, ttaren zzayes maḥend ad iffeɣ zi temmurt nsen.
\b
\b
\c 9
\s1 Asgenfi n ijj n uneɛḍab
\m 
\v 1 \add Awarni řami\add* inya deg uɣarrabu, iẓwa řebḥar, yiweḍ ɣar tendint nnes. \x ◘ \xo 9:1 \xt [Mk. 2:1-12; Lk. 5:17-26] — Řex. 9:33. \x*
\v 2 Uca iwyen as-dd ijj n uneɛḍab i tuɣa izzřen di tassut. \add Řami\add* iẓra Yasuɛ l’iman nsen, inna i uneɛḍab: “Egg uř, \add a\add* mmi, ddnub nnec ttwaɣfaren!”
\v 3 Uca xzar, ca n imseřmaden n idlisen nnan deg yixef nsen: “Wanita ittceqqaf \add di AREBBI\add*.” \x ◘ \xo 9:3 \xt Izhd. 32:5; Ica. 43:25. \x*
\v 4 Yasuɛ, umi issen min di tuɣa ttfekkaren, inna asen: “Mayemmi tᵉttxemmamem di min war iḥřin deg wuřawen nwem?
\v 5 Maɣar min ihewnen ad iniɣ i wanita: ‘Ddnub nnec ttwaɣfaren!’, niɣ ad iniɣ: ‘Kkar, uyur’?
\v 6 Maca ḥima ad tessnem belli Mmis n bnadem ɣares ṣṣulṭa di temmurt ḥima ad iɣfar ddnub, ad iniɣ i uneɛḍab-a: “Kkar, ksi tassut nnec, tarekkweḥed ɣar taddart nnec!”
\v 7 Xenni ikkar, iruḥ ɣar taddart nnes.
\v 8 Řami iẓra řɣaci man aya, tbehten, ssɛuǧen AREBBI wenni iwcin ṣṣulṭa am tanita i iwdan.
\b
\s1 Tařaɣit n Yasuɛ x Matta
\m 
\v 9 Řami ssenni ikka Yasuɛ, iẓra aryaz wenni umi qqaren Matta, iqqim ɣar taddart n ḍḍariba. Inna as: “Ḍfar ayi-dd!” Uca ikkar, iḍfar i-t. \x ◘ \xo 9:9 \xt [Mk. 2:13-17; Lk. 5:27-32] \x*
\v 10 Řami qqimen nitni \add ɣar ṭṭabřa\add* di taddart, usin-dd waṭṭas n ayt n ḍḍariba d imednab, qqimen \add ɣar ṭṭabřa\add* ak-d Yasuɛ d imeḥḍaren nnes.
\v 11 \add Řami\add* ẓrin Ifarisiyyen man aya, nnan i imeḥḍaren nnes: “Mayemmi ittett Umseřmad nwem ak-d ayt n ḍḍariba d imednab?”
\v 12 Umi isřa Yasuɛ \add man aya\add*, inna asen: “Inni iṣeḥḥen, war ḥdijen ca aḍbib, maca imehřac.
\v 13 Ruḥem, ad třemdem min ixs ad yini \add wawař-a\add*: ‘Xseɣ arreḥmet, war xseɣ ca taɣarṣt!’, minzi Necc war dd-usiɣ, ḥima ad řaɣiɣ x imseggaden, maca x imednab.” \x ◘ \xo 9:13 \xt Ḥuc. 6:6; Mixa 6:8; Mt. 12:7; Mk. 2:17; Lk. 5:32; 19:10; 1 Tim. 1:15. \x*
\b
\s1 Aseqsi x uẓummi
\m 
\v 14 Xenni usin-dd ɣares imeḥḍaren n Yuḥanna, nnan as: “Mayemmi nettẓumma neccin d Ifarisiyyen aṭṭas, maca imeḥḍaren nnec war ttẓummin ca?” \x ◘ \xo 9:14 \xt [Mk. 2:18-22; Lk. 5:33-39] \x*
\v 15 Yasuɛ inna asen: “Ma izemmar ad ceḍnen řeḥbab n umuřay umi amuřay ɛad akidsen? Ad dd-asen wussan ad xasen immeksi Umuřay, xenni ad ẓummen. \x ◘ \xo 9:15 \xt 2 Kur. 11:2. \x*
\b
\m 
\v 16 Uřa d ijj war ittegg taneqqič n tcuqqet n jdid x warruḍ aqdim, ḥima war tqeǧiɛ tneqqič zeg warruḍ uca ad iqqarṣ \add warruḍ\add* ktar.
\v 17 Uřa d binu n jdid war ittwagg ca di txuncay tibuřay, ḥima war dduqquzent txuncay, ad izeǧeɛ binu uca tixuncay ad ḍeyyɛent. Ittxeṣṣa ad tteggen binu n jdid di txuncay n jdid, ḥima ad ttwaxemmřen nitni s tnayen.” \x ◘ \xo 9:17 \xt Mk. 2:22. \x*
\b
\s1 Aḥinni n Yasuɛ d isgenfan nnes
\m 
\v 18 Am tuɣa issawař akidsen x tmesřayin-a, yusa-dd ijj n umeqqran, isjed as, inna: “Řexxu \bd yeǧi bḥřa temmut\bd*, maca as-dd, sars xas afus nnec uca ad teddar ɛawed.” \x ◘ \xo 9:18 \xt [Mk. 5:21-43; Lk. 8:40-56] \x*
\v 19 Yasuɛ ikkar, iḍfar i-t ak-d imeḥḍaren nnes.
\b
\m 
\v 20 Uca xzar, \bd ict n temɣart, tuɣa ttazzřen zzayes idammen řmijař n tenɛac n iseggʷusa\bd*, tekka as-dd ɣar ḍeffar uca tḥada abeḥřuř n ujeǧab nnes, \x ◘ \xo 9:20 \xt Lawi 15:25; Mk. 5:25; Lk. 8:43. \x*
\v 21 minzi nettat tuɣa tenna deg ixef nnes: “Icfa mɣir ad ḥadiɣ ajeǧab nnes, ad ggenfiɣ!”
\v 22 Maca inneqřeb-dd Yasuɛ, iẓra i-tt, inna: “Egg uř, a yeǧi, aqa l’iman nnem i cem issnejmen!” Uca tᵉttwassggenfa temɣart nni di tsaɛɛet nni. \x ◘ \xo 9:22 \xt Mk. 5:38; Lk. 8:51. \x*
\b
\m 
\v 23 \add Xenni\add* yusa-dd Yasuɛ ɣar taddart n umeqqran, iẓra iɣeyyaḍen d řɣaci sɣuyyun. \x ◘ \xo 9:23 \xt Mk. 5:38; Lk. 8:51. \x*
\v 24 Inna asen: “Ffɣem ssa! Taḥenjirt war temmut ca, aqa tᵉṭṭeṣ!” Nitni ḍeḥcen dayes. \x ◘ \xo 9:24 \xt Yḥ. 11:11. \x*
\v 25 Ařami issuffeɣ řɣaci, yudef ɣar daxeř uca iṭṭef i-tt zeg ufus nnes, xenni tekkar tḥenjirt.
\v 26 Uca iffeɣ řexbar ɣar temmurt nni marra.
\b
\m 
\v 27 Řami ssenni ikka Yasuɛ, ḍfaren t \bd tnayen n idarɣařen\bd*, ttřaɣan, qqaren: “Arḥem aneɣ, a Mmis n Dawud!”
\v 28 Ařami yudef ɣar taddart, usin-dd ɣares idarɣařen nni. Yasuɛ inna asen: “Ma tumnem belli zemmareɣ ad ggeɣ man aya?” Nnan as: “Wah, \add a\add* Siditneɣ!”
\v 29 Řexdenni iḥada tiṭṭawin nsen, inna: “Ad ɣarwem yiři ɛlaḥsab l’iman nwem!”
\v 30 Řexdenni ttwarezment tiṭṭawin nsen. \add Xenni\add* iḥarrem i-ten Yasuɛ, inna: “Ɣarwem, war ssargabem ḥed!” \x ◘ \xo 9:30 \xt Mt. 12:16; Lk. 5:14. \x*
\v 31 Maca nitni, ařami ruḥen, ssuffɣen xas řexbar di marra tammurt! \x ◘ \xo 9:31 \xt Mk. 7:36. \x*
\b
\m 
\v 32 Řami dd-ffɣen nitni, iwyen as-dd \bd ijj n weryaz aynaw, dayes ijj n cciṭan\bd*. \x ◘ \xo 9:32 \xt Mt. 12:22; Lk. 11:14. \x*
\v 33 Řami \add zzayes\add* iffeɣ cciṭan nni, issiweř weynaw. Tuɣa ittebhet řɣaci, nnan: “Ɛemmarṣ war neẓri am wanita di Israil!”
\v 34 Maca Ifarisiyyen nnan: “S umeqqran n ccwaṭen issuffuɣ ccwaṭen!” \x ◘ \xo 9:34 \xt Mt. 12:24; Mk. 3:22; Lk. 11:15. \x*
\b
\m 
\v 35 \bd Yeccu tuɣa ittenneḍ x marra tineddam d dcurat, isseřmad i-ten di temzidawin nsen. Tuɣa ittbarreḥ s Řexbar Aṣebḥan n Tgeldit uca issgenfa marra řehřacat d řeɛyub n řgens.\bd* \x ◘ \xo 9:35 \xt Mk. 6:6; Lk. 13:22. \x*
\v 36 Řami iẓra Yasuɛ řɣaci, iḥinn xasen, minzi uḥřen nnhewřen am wuǧi i war ɣar iǧi umeksaw. \x ◘ \xo 9:36 \xt Irm. 23:1; Ḥiz. 34:2; Mk. 6:34. \x*
\v 37 Xenni inna i imeḥḍaren nnes: “Tameyra temɣar aṭṭas, maca aqa din drus n icewwařen. \x ◘ \xo 9:37 \xt Lk. 10:2; Yḥ. 4:35. \x*
\v 38 S uyenni ttarem i Bab n tmeyra, ad dd-issekk icewwařen i tmeyra nnes.” \x ◘ \xo 9:38 \xt 2 Ts. 3:1. \x*
\b
\b
\c 10
\s1 Tařaɣit n Yasuɛ x tenɛac n rrusul
\m 
\v 1 Iřaɣa Yasuɛ x tenɛac n imeḥḍaren nnes, iwca asen ṣṣulṭa ḥima ad ssuffɣen řaryaḥ imengas u ḥima ad ssgenfan marra řeɛyubat d řehřacat. \x ◘ \xo 10:1 \xt [Mk. 3:13-19; 6:7-13; Lk. 6:12; 9:1-6] \x*
\v 2 Ismawen n tenɛac n rrusul d yina: amezwaru nsen Cimɛun umi qqaren Buṭrus, \add isem wanita ixs ad yini ‘Aẓru’,\add* d umas Andrawus, d Yaɛqub, mmis n Zabdi, d umas Yuḥanna, \f ◼ \fr 10:2 \fk rrusul' - niɣ ‘imazanen’.\f*
\v 3 d Filippus d Bar-Tulumawus, Tuma d Matta, wenni d bu-ḍḍariba, d Yaɛqub, mmis n Ḥalfa, d Labbawus, umi qqaren Tadday,
\v 4 d Cimɛun, wenni d Amɛessab, d Yahuda Isxariyuṭi wenni t isellmen.
\v 5 Yasuɛ issekk tenɛac-a, yumur i-ten, inna: “War ttruḥem ca x webrid n lkuffar, war ttadfem ca ɣar tendint n Isamariyyen,
\v 6 maca ḥsen ad traḥem ɣar wuǧi iweddaren n taddart n Israil. \x ◘ \xo 10:6 \xt Řex. 3:26; 13:26,46. \x*
\v 7 Xmi ɣa traḥem, barrḥem am teqqarem: ‘Tageldit n ijenwan aqa tiweḍ-dd!’ \x ◘ \xo 10:7 \xt Lk. 9:2. \x*
\v 8 Sgenfam imehřac, sizdgem inni di iǧa řbarṣ, suffɣem ccwaṭen. Kenniw teksim břa ca, xenni wcem tt břa ca. \x ◘ \xo 10:8 \xt Lk. 10:9; Řex. 8:18, 20. \x*
\v 9 War kessim ca wureɣ uřa d nnuqart uřa d nnḥas deg ibuyas nwem, \x ◘ \xo 10:9 \xt Mk. 6:8; Lk. 9:3; 22:35. \x*
\v 10 war kessim ca ttesṭim i webrid řa d tnayen n tcamirat řa d sandaliyat uřa d taɣɣarct \add nneɣni\add*, minzi axeddam isdaheǧ macca nnes. \x ◘ \xo 10:10 \xt Lawi 19:13; Aɛwd. 24:14; 25:4; Lk. 10:7; 1 Kur. 9:4, 14; 1 Tim. 5:18. \x*
\v 11 Man tandint niɣ dcar i ɣa tadfem, arzum wi dayes isdaheǧ, uca qqimem din ař d traḥem. \x ◘ \xo 10:11 \xt Mk. 6:10; Lk. 9:4; 10:8. \x*
\v 12 Mařa tudfem ɣar taddart, seǧmem x aytbab n taddart s řehna.
\v 13 Mařa taddart tesdaheǧ, jjem xas řehna nwem, mařa war t tesdiheǧ, xenni řehna nwem ad ɣarwem dd-iɛqeb.
\v 14 Mařa tufim ca n yijjen war kenniw iqebbeř u war ittesři i wawařen nwem, ffɣem zi taddart nni niɣ zi dcar nni, zzerzem taɛejjajt zeg iḍaren nwem. \x ◘ \xo 10:14 \xt Mk. 6:11; Lk. 9:5; Řex. 13:51; 18:6. \x*
\v 15 S tidett, Necc ad awem iniɣ: Ad yiři řḥař i temmurt n Sadum d Ɛamurra ihwen zi tendint nni deg wass n lḥisab.” \x ◘ \xo 10:15 \xt Mk. 6:11; Lk. 10:12. \x*
\b
\s1 Yasuɛ issawař x řeḥṣaret d udarrec
\m 
\v 16 “Xzarem, řexxu ad kenniw ssekkeɣ am uǧi di řwesṭ n wuccanen. Iřim tfettnem amecnaw ifiɣran u ɣeffřem amecnaw idbiren. \x ◘ \xo 10:16 \xt [Mk. 9:41, 13:9–13; Lk. 12:2-9; 12:51-53; 14:26, 27; 21:12–17] — Lk. 10:3\x*
\v 17 Maca ḥḍam ixef nwem zeg iwdan, minzi nitni ad kenniw sellmen i taddart n ccreɛ, ad kenniw hettken s urekkuḍ di temzidawin nsen. \x ◘ \xo 10:17 \xt Mt. 24:9; Lk. 21:12; Yḥ. 15:20; 16:2; Asa. 2:1. \x*
\v 18 Ad kenniw nedhen zzat i řḥukkam d zzat i ijeǧiden di ssibbet inu, ḥima ad tiřim d cchadet i nitni uřa i řegnus. \x ◘ \xo 10:18 \xt Řex. 24:1; 25:4. \x*
\v 19 Mařa sellmen kenniw, war kessim ca s wemnus mammec d min ɣa tessiwřem, minzi ad awem immewc di tsaɛɛet nni min ittxeṣṣa ad tinim. \x ◘ \xo 10:19 \xt Mk. 13:11; Lk. 12:11; 21:14. \x*
\v 20 Maɣar war iǧi d kenniw inni issawařen, maca d Arruḥ n Babatwem d Netta i daywem issawařen.
\m 
\v 21 Umas ad isellem umas ḥima ad itwaneɣ u babas mmis, uca ad kkaren tarwa d aɣezdis i lwalidin nsen, ad ten nɣen. \x ◘ \xo 10:21 \xt Mixa 7:2, 5; Lk. 21:16. \x*
\v 22 Ad kenniw carhen marra idsen x ssibbet n Yisem inu, maca wenni i ɣa iṣbaren ař aneggaru ad ittwassenjem. \x ◘ \xo 10:22 \xt Mt. 24:13; Mk. 13:13; Lk. 21:19; Asa. 2:10; 3:10. \x*
\v 23 Mařa darrcen xawem di tendint-a, arewřem ɣar tenneɣnit. S tidett, Necc ad awem iniɣ: kenniw war tᵉttekkem ca x marra tineddam n Israil ař dd ɣa yas Mmis n bnadem.” \x ◘ \xo 10:23 \xt Mt. 2:13; 4:12; 12:15; Řex. 8:1; 9:25; 14:6. \x*
\b
\m 
\v 24 “War iǧi umeḥḍar yuɛřa x umseřmad nnes, uřa d amsexxar x bab nnes. \x ◘ \xo 10:24 \xt Lk. 6:40; Yḥ. 13:16; 15:20. \x*
\v 25 Ikfa i umeḥḍar ad yiři am umseřmad nnes u amsexxar am bab nnes. Mařa řaɣan as i Bab n taddart ‘Bᵉɛalzabul’, \add ixs ad yini ‘ibřis’\add*, mecḥař \add ɛad\add* i aytbab n taddart nnes! \x ◘ \xo 10:25 \xt Mt. 9:34; 12:24; Mk. 3:22; Lk. 11:15; Yḥ. 8:48. \x*
\v 26 War tteggʷedem ca zzaysen. Minzi war din min idřin ad iqqim war ittwaɛarri, uřa \add war din\add* min inuffaren ad iqqim war ittwissen.” \x ◘ \xo 10:26 \xt Ayub 12:22; Ica. 8:12; Irm. 1:8; Mk. 4:22; Lk. 8:17; 12:2. \x*
\b
\m 
\v 27 “Min d awem qqareɣ di taǧest, inim t di tfawt, min tesřim, \add qqaren t\add* deg imezzuɣen nwem, barrḥem zzayes x tzeɣwin.
\v 28 War tteggʷedem ca zeg inni ineqqen arrimet, \add maca\add* war zemmaren ad nɣen řeɛmar. Ggʷedem d amezwaru zeg Wenni izemmaren ad isshellek řeɛmar d arrimet di jᵉhennama. \x ◘ \xo 10:28 \xt Irm. 1:8; Lk. 12:4. \x*
\v 29 Ma war ttmenzin tnayen n ẓẓawec s yijj n uṣuldi n nnḥas? Uřa d ijj zzaysen war dd-iweṭṭi ca x temmurt břa Babatwem,
\v 30 maca uřa d iẓuṭṭan \add n ucuwwaf\add* n uzeǧif nwem ttwaḥessben marra. \x ◘ \xo 10:30 \xt 1 Ṣm. 14:45. \x*
\v 31 S uyenni war tteggʷedem ca, aqa kenniw teɛdum ẓẓawec aṭṭas.
\v 32 S uya kuř ijjen wenni zzayi i ɣa icehden zzat i iwdan, uřa d Necc ad zzayes cehdeɣ zzat i Baba i iǧan deg ijenwan. \x ◘ \xo 10:32 \xt Mk. 8:38; Lk. 9:26; 12:8; 2 Tim. 2:12. \x*
\v 33 Maca wenni d ayi ɣa inkaren zzat i iwdan, uřa d Necc ad t nkareɣ zzat i Baba i iǧan deg ijenwan.”
\m 
\v 34 “War ttɣiřem ca belli usiɣ-dd ḥima ad awyeɣ řehna i ddunect. Necc war dd-usiɣ ca ḥima ad awyeɣ řehna, maca ssif. \x ◘ \xo 10:34 \xt Lk. 12:51. \x*
\v 35 Usiɣ-dd ḥima ad bḍiɣ aryaz x babas, d yeǧis x yemmas, d tesřit x řallas. \x ◘ \xo 10:35 \xt Mixa 7:6. \x*
\v 36 Aytbab n taddart n bnadem ad iřin d řɛedyan \add nnes\add*. \x ◘ \xo 10:36 \xt Izhd. 41:10; 55:13; Yḥ. 13:18. \x*
\v 37 Wenni ittexsen babas niɣ d yemmas xafi, war d ayi isdiheǧ ca, uca wenni ittexsen mmis niɣ d yeǧis xafi, war d ayi isdiheǧ ca. \x ◘ \xo 10:37 \xt Lk. 14:26. \x*
\v 38 Wenni war ikessin ṣṣalib nnes uca ad ayi dd-iḍfar, aqa netta war d ayi isdiheǧ ca. \f ◼ \fr 10:38 \fk ṣṣalib\ft - di řweqt n řḥukm arumani, tuɣa Irumaniyyen neqqen iwdan inni war ǧin d Irumaniyyen di ṣṣalib. D man aya tuɣa d ijj n řɛiqab iqseḥ aṭṭas.\f*  \x ◘ \xo 10:38 \xt Mt. 16:24; Mk. 8:34; Lk. 9:23; 14:27. \x*
\v 39 Wenni i ɣa yafen tudart nnes ad tt ixsar, d wenni i ɣa ixsaren tudart nnes di ṭṭweɛ inu ad tt yaf. \x ◘ \xo 10:39 \xt Mt. 16:25; Mk. 8:35; Lk. 9:24; 17:33; Yḥ. 12:25. \x*
\m 
\v 40 Wenni kenniw i ɣa iqebřen, iqebbeř ayi, u wenni d ayi ɣa iqebřen, iqebbeř wenni d ayi dd-issekken. \x ◘ \xo 10:40 \xt Lk. 10:16; Yḥ. 13:20. \x*
\m 
\v 41 Wenni i ɣa iqebřen anabi minzi netta d anabi, ad iṭṭef řmunet n unabi, d wenni i ɣa iqebřen amseggad s minzi netta d amseggad, ad iṭṭef řmunet n umseggad. \x ◘ \xo 10:41 \xt 1 Ij. 17:10; 18:4; 2 Ij. 4:8. \x*
\v 42 Wenni i ɣa iwcen i yijjen zeg ina imeẓyanen ijj n řkas n waman d asemmaḍ, mɣir minzi netta d ameḥḍar \add inu\add*, s tidett, Necc ad awem iniɣ, war d as tᵉttriḥ řmunet nnes \add ɛemmarṣ\add*.” \x ◘ \xo 10:42 \xt Mt. 25:40; Mk. 9:41; Ɛbr. 6:10. \x*
\b
\b
\c 11
\s1 Yasuɛ d Yuḥanna Amseɣḍaṣ
\m 
\v 1 Awarni řami ikemmeř Yasuɛ řumur nnes i tenɛac n imeḥḍaren nnes, yuyur ssenni ḥima ad isseřmed u ad ibarreḥ di tneddam nsen. \x ◘ \xo 11:1 \xt [Lk. 7:18-35] \x*
\m 
\v 2 Řami tuɣa Yuḥanna ittesřa di řeḥbes x řexdayem n Lmasiḥ, issekk ca zeg imeḥḍaren nnes. \x ◘ \xo 11:2 \xt Lk. 7:18. \x*
\v 3 Inna as: “Ma d Cek d wenni dd ɣa yasen niɣ \add ittxeṣṣa\add* ad nraja ijjen nneɣni?”
\v 4 Yarra-dd Yasuɛ, inna asen: “Ruḥem, tɛawdem i Yuḥanna min tesřam d min teẓrim!
\v 5 Aqa idarɣařen ttwařan, ineɛḍaben gguren d yinni di iǧa řbarṣ ttwassizdigen, idehcar dewřen ttesřan, imettinen ttwassnekkaren-dd u Řexbar Aṣebḥan ittwabarraḥ i imezřaḍ. \x ◘ \xo 11:5 \xt Ica. 29:18; 35:5; 61:1; Lk. 4:18. \x*
\v 6 Sseɛd n wenni war dayi ittendrifen.”
\m 
\v 7 Řami uyuren ina, ibda Yasuɛ issawař ak-d řɣaci x Yuḥanna, inna: “Min ɣar dd-teffɣem ɣar řexřa maḥend ad t tẓarem? Ma ɣar ijj n uɣanim issenhezza t usemmiḍ? \x ◘ \xo 11:7 \xt Lk. 7:24. \x*
\v 8 Mařa lla, min ɣar dd-teffɣem ad t tẓarem? Ma ɣar ijj n bnadem s warruḍ yarḍeb? Xzar, inni yarrḍen arruḍ iɣřan yarḍeb, aqa aten di tudrin n ujeǧid.
\v 9 Min ɣar dd-teffɣem \add xenni\add* maḥend ad t tẓarem? Ijj n unabi? Wah, Necc ad awem iniɣ, aqa d ameqqran \add ɛad\add* x unabi.
\v 10 Maɣar aqa d wa d wenni i xef ittwari \add wawař-a\add*: ‘Xẓar, ad dd-ssekkeɣ lmalak inu zzat i wudem nnec, wenni i ɣa isswejden abrid nnec zzatek.’ \x ◘ \xo 11:10 \xt Uf. 23:20; Mal. 3:1; Mk. 1:2; Lk. 7:27. \x*
\v 11 S tidett, Necc ad awem iniɣ, jar inni dd-ittwaxeřqen zi temɣarin, war dd-iffiɣ uřa d ijj d ameqqran x Yuḥanna Amseɣḍaṣ. Waxxa amenni ameẓyan di Tgeldit n ijenwan d ameqqran xas.
\v 12 Zeg wussan n Yuḥanna Amseɣḍaṣ ař iḍa temmars Tgeldit n ijenwan i lɛunf, uca ayt n bu-řexcunet \add arezzun\add* ttᵉṭṭfen tt. \x ◘ \xo 11:12 \xt Lk. 16:16. \x*
\v 13 Minzi marra inabiyyen d Ccariɛa tuɣa ttnabban ař dd-yas Yuḥanna. \f ◼ \fr 11:13 \fk Ccariɛa\ft - aqa-t d xemsa n idlisen imezwura n Wedlis Iqeddsen di Řɛahd Aqdim nni yuran s ufus n Musa: Amezwaru, Uffuɣ, Ilawiyyen (niɣ ‘Ayt n Lawi’), Di Řexřa (niɣ ‘Lɛadad’) d Aɛawed n Ccariɛa (niɣ ‘Awařen n Musa’). Di tutlayt n Tɛibranit qqaren as ‘Ttawrat’, ixs ad yini ‘Aseřmed’ niɣ ‘Taɣuri’.\f*
\v 14 Mařa texsem, qebřem aqa wanita d Iliya wenni tuɣa igga ad dd-yas. \x ◘ \xo 11:14 \xt Mal. 3:23; Lk. 1:17. \x*
\v 15 Wenni ɣar iǧa imezzuɣen i useǧi ad iseř.”
\m 
\v 16 “Wi ak-d i ɣa ssemquddeɣ jjiř-a? Aqa-t amecnaw iḥenjiren iqqimen di řeswaq ttřaɣan x imeddukkař nsen, \x ◘ \xo 11:16 \xt Lk. 7:31. \x*
\v 17 qqaren: ‘Aqa nɣennej i kenniw, kenniw war tecḍiḥem. Aqa newta awem agejdur, war tecḍinem.’
\m 
\v 18 Maɣar yusa-dd Yuḥanna, war ittett, war isess, uca qqaren nitni: ‘Dayes ijj n cciṭan!’ \x ◘ \xo 11:18 \xt Mt. 3:4; Mk. 1:6. \x*
\v 19 Aqa Mmis n bnadem yusa-dd, ittᵉtt, isess, uca nitni qqaren: ‘Aqa din bnadem iřhef x macca d binu, Netta d ameddukkeř n ayt n ḍḍariba d imednab!’ \add Maca\add* tiɣit tᵉttwasegged s řexdayem nnes.”
\b
\s1 Řḥukm x tneddam i war yuminen
\m 
\v 20 Řexdenni ibda ittwebbex tineddam i di igga aṭṭas n řeɛjayeb nnes, minzi nitenti war tubent ca. \x ◘ \xo 11:20 \xt [Lk. 10:13-15] \x*
\v 21 “Uct xam, a Xurazin, uct xam, a Bayt-Ṣayda! Mři tuɣa ttwaggent di Ṣur d Ṣaydun řeɛjayeb ijehden tinni ittwaggen daykent, iři aqa tubent aṭṭas zeg wami s txancet n wecḍan d yiɣɣeḍ \add x izeǧifen nsent\add*. \x ◘ \xo 11:21 \xt 2 Ṣm. 13:19; 2 Ij. 6:30; 19:1. \x*
\v 22 Maca Necc ad awem iniɣ: Ad yiři řḥař \add i tendint\add* n Ṣur d Ṣaydun ihwen zi řḥař nwem deg wass n lḥisab. \x ◘ \xo 11:22 \xt Mt. 10:15. \x*
\v 23 I cem, a \add tandint n\add* Kafarnaḥum, tenni ittwassgeɛɛden ař ajenna? Ɣar řaxart i ɣar dd ɣa tehwid. Minzi mařa ttwaggent di Sadum řeɛjayeb ijehden i dayem ittwaggen, iři aqa teqqim ař ass n yiḍa.
\v 24 Maca Necc ad am iniɣ, ad yiři řḥař i temmurt n Sadum ihwen zi \add řḥař\add* nnem deg wass n lḥisab.” \x ◘ \xo 11:24 \xt Mt. 10:15. \x*
\b
\s1 Taẓaǧit n Yasuɛ
\m 
\v 25 Di řweqt nni ibda Yasuɛ ad yini: “Ḥemdeɣ Cek a Baba, Sidi n ujenna d temmurt, minzi tessnuffared aya x imiɣisen d imusnawen, \add maca\add* tessaregbed aya i iḥenjiren. \x ◘ \xo 11:25 \xt [Lk. 10:21-22] — Ayub 5:12; Ica. 29:14; 1 Kur. 1:19; 2:7, 8. \x*
\v 26 Wah, \add a\add* Baba, minzi d wa d arḍa i Cek.
\v 27 Marra min iǧan immewc ayi-dd zi Baba, uca uřa d ijj war issin Mmis mɣir Babas, uca uřa d ijj war issin Babas mɣir Mmis u wi umi ixs Mmis ad t issargeb.” \x ◘ \xo 11:27 \xt Mt. 28:18; Lk. 10:22; Yḥ. 1:18; 3:35; 6:46. \x*
\m 
\v 28 “Asem-dd ɣari marra kenniw, inni yuḥřen d yinni yarbun ddqeř, uca Necc ad awem wceɣ arraḥet,
\v 29 ksim-dd azayřu inu xawem, řemdem zzayi, \add minzi\add* Necc d amhin d amwaḍeɛ n wuř uca ad tafem arraḥet i řeɛmur nwem. \x ◘ \xo 11:29 \xt Izhd. 45:5; Irm. 6:16. \x*
\v 30 Minzi azayřu d řeḥmeř inu fsusen.” \x ◘ \xo 11:30 \xt 1 Yḥ. 5:3. \x*
\b
\b
\c 12
\s1 Yasuɛ d Bab n wass n ssebt
\m 
\v 1 Di řweqt nni icuq Yasuɛ deg iyyaren n zzariɛet n imendi di ssebt. Tuɣa imeḥḍaren nnes ǧuẓen uca bdan řeqqḍen tidrin, ccin \add zzaysent\add*. \x ◘ \xo 12:1 \xt [Mk. 2:23-28; 3:1-6; Lk. 6:1-11] — Aɛwd. 23:24 \x*
\v 2 \add Ařami\add* ten ẓrin Ifarisiyyen, nnan as: “Xzar imeḥḍaren nnec tteggen min war iɛeddřen di ssebt!” \x ◘ \xo 12:2 \xt Uf. 20:10. \x*
\v 3 Yarra-dd xasen: “Ma war teɣřim ca min igga Dawud umi iǧuẓ netta d yinni akides?
\v 4 Mammec yudef ɣar Taddart n AREBBI, icca aɣrum \add n wescan\add* zi Tzewḍa n SIDI i war iḥeǧřen macca nnes i netta uřa i yinni akides, maca mɣir i ikehhanen waha. \x ◘ \xo 12:4 \xt Uf. 29:33; Lawi 24:9; 1 Ṣm. 21:6. \x*
\v 5 Niɣ war teɣrim ca di Ccariɛa belli ikehhanen inni iǧan di Zzawect Tameqqrant di ssebt, xeṭṭan di \add tewṣiyyet n\add* ssebt, waxxa amenni war xasen ibin řɛib? \x ◘ \xo 12:5 \xt Řxř. 28:9. \x*
\v 6 Necc ad awem iniɣ, wenni iǧan d ameqqran x Zzawect Tameqqrant, aqa-t danita! \x ◘ \xo 12:6 \xt 2 Im. 6:18. \x*
\v 7 Maca mařa tuɣa tfehmen min ixs ad yini: ‘Necc xseɣ arreḥmet, war iǧi d taɣarṣt!’, xenni ad tiři war tᵉttḥasabem ca x imezdagen, \x ◘ \xo 12:7 \xt Ḥuc. 6:6; Mixa 6:8; Mt. 9:13; 23:23. \x*
\v 8 minzi Mmis n bnadem d Bab n ssebt.” \x ◘ \xo 12:8 \xt Mk. 2:28; Lk. 6:5. \x*
\b
\m 
\v 9 Yasuɛ yuyur ssenni, yudef ɣar temzida nsen.
\v 10 Tuɣa din ijj n weryaz, afus nnes iqucceḥ. Sseqsan t maḥend zemmaren ad zzayes cettcan, nnan: \bd “Ma iɛeddeř usgenfi di ssebt?”\bd* \x ◘ \xo 12:10 \xt Lk. 14:3. \x*
\v 11 Inna asen: “Man bnadem i dinni jar awem wenni ɣar iǧa izmar i iwḍan di tesraft di ssebt, war t itteṭṭef, ḥima ad t-i-dd issuffeɣ? \x ◘ \xo 12:11 \xt Uf. 23:4; Aɛwd. 22:4. \x*
\v 12 Mecḥař iɛdu bnadem x izmar! S uyenni iɛeddeř ad ittwagg min iṣebḥen di ssebt.” \x ◘ \xo 12:12 \xt Amz. 1:27. \x*
\v 13 Řexdenni inna as i bnadem nni: “Swiẓẓeḍ afus nnec!” Isswiẓẓeḍ afus nnes uca idweř iggenfa am wenneɣni. \x ◘ \xo 12:13 \xt Mk. 3:5; Lk. 6:10\x*
\m 
\v 14 Ifarisiyyen ffɣen-dd ɣar barra, mcawaren xas, mammec ɣa ggen ad t nɣen. \x ◘ \xo 12:14 \xt Mk. 3:6; Yḥ. 5:18; 10:39; 11:53. \x*
\v 15 Maca Yasuɛ issen \add aya\add* uca yuyur ssenni. Iḍfar i-t-i-dd ijj n řɣaci d ameqqran, issgenfa i-ten marra. \x ◘ \xo 12:15 \xt Mt. 10:23. \x*
\v 16 Yumur i-ten s jjehd maḥend war xas ssuffuɣen řexbar, \x ◘ \xo 12:16 \xt Mt. 9:30; Lk. 5:14. \x*
\v 17 ḥima ad ittwakemmeř wawař i innan unabi Icaɛya:
\b
\m 
\v 18 \qt “Xzar, Amsexxar inu, wenni farrzeɣ,\qt*
\m \qt Amɛizz inu, wenni di ufiɣ arḍa inu.\qt*
\m \qt Ad xas ssarseɣ Arruḥ inu\qt*
\m \qt u Netta ad ibarreḥ s řḥukm i řegnus.\qt* \x ◘ \xo 12:18 \xt Ica. 42:1; Mt. 3:17; 17:5; Mk. 1:11; Kul. 1:13; 2 Bṭ. 1:17. \x*
\m 
\v 19 \qt War ittemcubbuc, war isɣuyyu,\qt*
\m \qt uřa d ijj war ittesři tmijja nnes\qt*
\m \qt deg ibriden.\qt*
\m 
\v 20 \qt Aɣanim yarẓen war t yareẓẓi,\qt*
\m \qt uřa d taftič idduxxunen,\qt*
\m \qt war tt issxessi\qt*
\m \qt ař dd ɣa issuffeɣ řeḥkam\qt*
\m \qt i ɣa inedhen i uɣelleb,\qt*
\m 
\v 21 \qt uca ad ssitmen řegnus deg Yisem nnes.”\qt* \x ◘ \xo 12:21 \xt Ica. 42:1-4. \x*
\b
\s1 Awař n Yasuɛ x Arruḥ Iqeddsen
\m 
\v 22 Řexdenni iwyen as-dd ijj n umeryaḥ, tuɣa-t d adarɣař d aynaw, uca Netta issgenfa i-t, ařami wenni tuɣa iǧan d aynaw d adarɣař idweř issawař u ittwařa. \x ◘ \xo 12:22 \xt [Mk. 3:20-30; Lk. 11:14-23; 12:10; Lk. 6:43-45] — Mt. 9:32\x*
\v 23 Itebhet řɣaci marra, nnan: “Ma Wanita \add xenni\add* war iǧi d Mmis n Dawud?” \x ◘ \xo 12:23 \xt Yḥ. 4:29. \x*
\v 24 Maca sřin Ifarisiyyen man aya, nnan: “Wanita issuffuɣ ccwaṭen mɣir s webrid n Bᵉɛalzabub, ameqqran n ccwaṭen.” \f ◼ \fr 12:24 \fk Bᵉɛalzabub\ft - wanita d isem n ibřis s tutlayt n Tramit.\f*  \x ◘ \xo 12:24 \xt Mt. 9:34; Mk. 3:22; Lk. 11:15. \x*
\v 25 Maca Yasuɛ issen ixarriṣen nsen, inna asen: “Kuř tageldit ittemsebḍan x yixef nnes ad tᵉttwahellek, u kuř taddart niɣ tandint ittemsebḍan x yixef nnes war tᵉttɣimi ca.
\v 26 Mařa aqa-t d cciṭan issuffuɣ cciṭan, aqa netta ittemsebḍa x yixef nnes, \add xenni\add* mammec ɣa teqqim tgeldit nnes?
\v 27 Mařa Necc ssuffuɣeɣ ccwaṭen s webrid n Bᵉɛalzabub, s min zi ten i ɣa ssuffɣen tarwa nwem? S uyenni nitni ad iřin d řquḍat xawem.
\v 28 Maca mařa Necc ssuffuɣeɣ ccwaṭen s Arruḥ n AREBBI, aqa tudes awem-dd Tgeldit n AREBBI. \x ◘ \xo 12:28 \xt Lk. 11:20\x*
\v 29 Niɣ mammec izemmar ḥed ad yadef ɣar taddart n wenni ijehden maḥend ad ikecceḍ řeqcuɛ nnes, mařa war icarf wenni ijehden amezwar? Xenni izemmar ad ikecceḍ taddart nnes.
\v 30 Wenni war iǧin akidi, aqa-t ḍidd inu, wenni war kidi issmunan, aqa ittzeǧaɛ waha. \x ◘ \xo 12:30 \xt Mt. 12:30; Mk. 9:39; Lk. 9:50; 11:23. \x*
\v 31 S uyenni ad awem iniɣ: marra ddnub d uceqqef ad ittwaɣfar i iwdan, maca aceqqef di Arruḥ war ittwaɣfar ca i iwdan. \x ◘ \xo 12:31 \xt Mk. 3:28; Lk. 12:10; 1 Yḥ. 5:16. \x*
\v 32 Wenni i ɣa inin awař d aɛeffan x Mmis n bnadem ad as ittwaɣfar, maca wenni i ɣa inin awař d aɛeffan x Arruḥ Iqeddsen war d as ittwaɣfar ca, uřa di řweqt-a uřa di řweqt i dd ɣa yasen. \x ◘ \xo 12:32 \xt Řxř. 15:30; 1 Ṣm. 2:25; 1 Yḥ. 5:16. \x*
\b
\m 
\v 33 Ḥesbem tacejjart d taṣebḥant uřa d řɣiǧet nnes d taṣebḥant, niɣ ḥesbem tacejjart texsar uřa d řɣiǧet nnes texsar, minzi tacejjart tᵉttwassen zi řɣiǧet \add nnes\add*.” \f ◼ \fr 12:33 \fk tacejjart\ft - niɣ ‘addag’ (‘iddagen’).\f*  \x ◘ \xo 12:33 \xt Mt. 7:18. \x*
\b
\s1 Uř d uqemmum
\m 
\v 34 “A tarwa n ifiɣran, mammec ɣa teggem ad tessiwřem x min iṣebḥen, waxxa kenniw d iɛeffanen, minzi \bd zeg uɛemmar n wuř ad issiweř uqemmum\bd*. \x ◘ \xo 12:34 \xt Izhd. 40:11; Mt. 3:7; Lk. 6:45. \x*
\v 35 Bnadem aṣebḥan issuffuɣ-dd min iṣebḥen zi řkenz aṣebḥan \add n wuř nnes\add* uca bnadem aɛeffan \add issuffuɣ-dd\add* zi řkenz aɛeffan nnes min iɛeffnen.
\v 36 Maca Necc ad awem iniɣ, belli kuř awař ixwan ad zzayes ssiwřen iwdan, ad zzayes ttwaḥasben deg wass n lḥisab. \x ◘ \xo 12:36 \xt Amb. 12:14; Afa. 5:4. \x*
\v 37 Minzi s wawařen nnec ad tᵉttwaseggded uca s wawařen nnec ad tᵉttwaḥasbed.” \x ◘ \xo 12:37 \xt 2 Ṣm. 1:16; Lk. 19:22. \x*
\b
\s1 Řeɛřamet n Yunus
\m 
\v 38 Ca n imseřmaden n idlisen d Ifarisiyyen, arrin-dd xas: “\add A\add* Amseɣɣar, neccin nexs ad nẓar ict n řeɛřamet zzayek.” \x ◘ \xo 12:38 \xt [Mk. 8:11-12; Lk. 11:29-32] — Mt. 16:1; 1 Kur. 1:22. \x*
\v 39 Maca Netta yarra-dd xasen: “Jjiř aɛeffan izennan ittettar ict n řeɛřamet, war d as ittmewci uřa d ict n řeɛřamet \add mɣir\add* \bd řeɛřamet n Yunus\bd*.
\v 40 Minzi am mammec tuɣa Yunus třata n wussan jar ǧyaři d wussan deg uɛeddis n wesřem, ammu i ɣa yiři uřa d Mmis n bnadem deg wuř n temmurt třata n wussan jar ǧyaři d wussan. \x ◘ \xo 12:40 \xt Yun. 2:1, 11 \x*
\v 41 Iryazen n Ninwa ad dd-kkaren deg \add wass n\add* lḥisab ak-d jjiř-a, ad t ḥasben, minzi nitni tuben s tbarreḥt n Yunus, uca xzarem, aqa da Wenni iǧan d ameqqran x Yunus! \x ◘ \xo 12:41 \xt Yun. 3:5; Lk. 11:32. \x*
\v 42 Tajeǧidt n ljanub ad tekkar deg \add wass n\add* lḥisab ak-d jjiř-a, ad xas teḥkem minzi nettat tusa-dd zeg uneggaru n ddunect, ḥima ad tseř i tiɣit n Suliman, uca xzarem, aqa da Wenni iǧan d ameqqran x Suliman!” \x ◘ \xo 12:42 \xt 1 Ij. 10:1; 2 Im. 9:1; Lk. 11:31. \x*
\b
\s1 Awař n Yasuɛ x řxedmet n řaryaḥ amengus
\m 
\v 43 “Ařami iffeɣ řaryaḥ amengus zi bnadem, ibda ittsara deg imucan war daysen bu waman, yarezzu arraḥet, war tt ittif. \x ◘ \xo 12:43 \xt [Lk. 11:24-26] \x*
\v 44 Řexdenni ad yini: ‘Ad dewřeɣ ɣar taddart inu manis dd-ffɣeɣ!’ Uca iruḥ, yufa i-tt texwa, tfarḍ, tsettef.
\v 45 Řexdenni yuyur uca yiwi akides sebɛa n řaryaḥ nneɣni, d iɛeffanen ktar zzayes, ad dd-adfen, ad raḥen ad zedɣen dayes, uca aneggaru n bnadem nni ad idweř mahu x umezwaru. Ammu i ɣa yiři \add ɛawed\add* ak-d jjiř-a aɛeffan.” \x ◘ \xo 12:45 \xt Ɛbr. 6:4, 5; 10:26; 2 Bṭ. 2:20. \x*
\b
\s1 Yemmas d aytmas n Yasuɛ
\m 
\v 46 Řami tuɣa ɛad issawař ak-d řɣaci, xzar, yemmas d aytmas bedden barra, arezzun ad kides ssiwřen. \x ◘ \xo 12:46 \xt [Mk. 3:31-35; Lk. 8:19-21] \x*
\v 47 Inna as ijjen: “Xzar, yemmac d aytmac bedden di barra, arezzun ad kidek ssiwřen.”
\v 48 \add Maca\add* Netta yarra-dd x wenni tuɣa d as t innan, inna: “Min teɛna yemma d min ɛnan aytma?”
\v 49 \add Xas uca\add* isswiẓẓeḍ s ufus nnes ɣar imeḥḍaren nnes, inna: “Xzar, yemma, xzar, aytma!
\v 50 Minzi man wen itteggen min ixs Baba i iǧan deg ijenwan, aqa netta d uma d učma d yemma.” \x ◘ \xo 12:50 \xt Yḥ. 15:14; 2 Kur. 5:16; Gal. 5:6; 6:15; Kul. 3:11. \x*
\b
\b
\c 13
\s1 Amedya n ufeǧaḥ izarrɛen
\m 
\v 1 Deg wass nni iffeɣ Yasuɛ zi taddart, iruḥ iqqim x tma n řebḥar. \x ◘ \xo 13:1 \xt [Mk. 4:1-20; Lk. 8:4-15] \x*
\v 2 Imun-dd xas ijj n uhimur n řɣaci, ařami yenya di uɣarrabu, iqqim dayes uca řɣaci marra bedden x tma n řebḥar. \x ◘ \xo 13:2 \xt Lk. 5:3. \x*
\v 3 Issiweř akidsen x waṭṭas n tmesřayin s imedya, inna: “Xzar, afeǧaḥ iffeɣ, ḥima ad izarɛ. \x ◘ \xo 13:3 \xt Mk. 4:1-9; Lk. 8:4-8\x*
\v 4 Am tuɣa izarreɛ, tewḍa ca n zzariɛet x tma n webrid, xeccen-dd ijḍaḍ, neqben tt.
\v 5 Tewḍa ca nneɣni x weẓru mani tuɣa war iǧi ucař aṭṭas. Deɣya teɣmi-dd s minzi tammurt war tuǧiɣ.
\v 6 Umi dd-tenqar tfuct, icmeḍ \add uɣemmuy\add*, uca isřaw minzi war ɣares tuɣi bu weẓwar.
\v 7 Ca nneɣni tewḍa x isennanen. Mɣaren isennanen, jiyyfen tt.
\v 8 Ca nneɣni tewḍa x temmurt taṣebḥant, tiwi-dd řɣiǧet, ca mya, ca nneɣni settin, ca nneɣni třatin n tseqqar.
\v 9 Wenni ɣar iǧa imezzuɣen i useǧi, ejj i-t ad iseř.”
\b
\m 
\v 10 \add Xas uca\add* usin-dd ɣares imeḥḍaren nnes, nnan as: “Mayemmi akidsen tessawařed s imedya?” \x ◘ \xo 13:10 \xt [Mk. 4:10-12; Lk. 8:9-10] Mk. 4:10-12; Lk. 8:9-10\x*
\v 11 Netta yarra-dd, inna asen: “Minzi immewc awem ad tessnem ssirr n Tgeldit n ijenwan, nitni maca war d asen t immewc ca. \x ◘ \xo 13:11 \xt Mt. 11:25; 2 Kur. 3:14. \x*
\v 12 Minzi wenni ɣar iǧa ad as immewc uca ad ɣares yiři s waṭṭas, maca wenni war ɣar iǧi ca ad zzayes ittwakkes uřa d min ɣares. \x ◘ \xo 13:12 \xt Mt. 25:29; Mk. 4:24, 25; Lk. 8:18; 19:26. \x*
\v 13 S uyenni ssawařeɣ akidsen s imedya, ařami nitni ttwařan am war ttwiřin u ttesřan am war ttesřin, war fehhmen.
\v 14 Daysen i ɣa ikemmeř wawař i inebba Icaɛya, inna: ‘S useǧi ad tesřem, \add maca\add* war tfehhmen, s tmuɣři ad tẓarem, \add maca\add* war tfettnem, \x ◘ \xo 13:14 \xt Ica. 6:9-10; Mk. 4:12; Lk. 8:10; Yḥ. 12:40; Řex. 28:26; Rum. 11:8. \x*
\v 15 maɣar uř n řgens-a aqa iqbubbez, imezzuɣen nsen ḍeqřen deg useǧi u nitni aqa qqnen tiṭṭawin nsen, \add maḥend\add* war ttwiřin s tiṭṭawin nsen, ad sřen s imezzuɣen nsen, ad fehmen s wuř nsen, ḥima ad tuben uca Necc ad ten ssgenfiɣ.’ \x ◘ \xo 13:15 \xt Ica. 6:9-10\x*
\v 16 Maca sseɛd n tiṭṭawin nwem umi ttwařant, sseɛd n imezzuɣen nwem umi ttesřan! \x ◘ \xo 13:16 \xt Lk. 10:23; Yḥ. 20:29; 1 Bṭ. 1:8. \x*
\v 17 S tidett Necc ad awem iniɣ, aṭṭas n inabiyyen d imseggaden tuɣa xsen ad ẓaren min teẓrim, \add maca\add* war t ẓrin, xsen ad sřen min tesřim, war t sřin.” \x ◘ \xo 13:17 \xt 1 Bṭ. 1:10. \x*
\b
\m 
\v 18 “\add Xenni\add* kenniw, sřem i umedya n wenni izarrɛen.
\v 19 Kuř ijjen wenni ittesřan i Wawař n Tgeldit uca war t ifhim, ad ɣares dd-yas umɛeffan, ad ixḍef min ittwazarɛen deg wuř nnes. Aqa d man aya min ittwazarɛen x tma n webrid. \x ◘ \xo 13:19 \xt Mt. 4:23. \x*
\v 20 Min ittwazarɛen x weẓru, aqa wa d wenni i ɣa iseǧen Awař, ad t iqbeř deɣya s řefraḥet,
\v 21 maca war d as iwti ca weẓwar deg ixef nnes, ad iqqim drus waha. Xmi dd ɣa tas řmeḥnet niɣ amarret di ṭṭweɛ n Wawař ad innedref deɣya.
\v 22 Min ittwazarɛen jar isennanen aqa wa d wenni ittesřan Awař, \add maca\add* amnus n řweqt-a d uɣekkwi n wagřa ad jiyyfen Awař uca netta war dd-ittiwi ca řɣiǧet. \x ◘ \xo 13:22 \xt Mt. 19:23; Mk. 10:23; Lk. 18:24; 1 Tim. 6:9. \x*
\v 23 Min ittwazarɛen di temmurt taṣebḥant aqa wa d wenni ittesřan Awař uca ad t ifhem, ad yarbu u ad dd-yawi xenni řɣiǧet: ijjen ad yařu mya n tseqqar, wenneɣni settin uca wenneɣni třatin.”
\b
\s1 Amedya n řḥayyar di řwest n yirden
\m 
\v 24 Iwca asen ijj n umedya nneɣni, inna: “Tageldit n ijenwan am yijj n bnadem tuɣa izarreɛ zzariɛet taṣebḥant deg iyyar nnes.
\v 25 Ařami tuɣa iwdan ṭṭṣen, yusa-dd řeɛdu nnes, izarɛ řḥayyar di řwesṭ n yirden uca yuyur.
\v 26 Ařami dd-imɣar uɣemmuy uca yiwi-dd řɣiǧet, řexdenni iḍhar-dd řḥayyar ɛawed.
\v 27 Xenni usin-dd imsexxaren n bab n taddart, nnan as: ‘A Siditneɣ, ma war tzarɛed ca zzariɛet taṣebḥant deg iyyar nnec? Manis i dd-yusa \add xenni\add* řḥayyar-a i dayes iǧan?’
\v 28 Inna asen: ‘Aqa řeɛdu igga man aya’. Nnan as imsexxaren: ‘Ma texsed ad nraḥ, ad t neyru?’
\v 29 Maca netta inna: ‘Lla, ḥima xmi ɣa tyarrwem řḥayyar war kis tqeǧɛem uřa d irden.
\v 30 Ejj i-ten ad mɣaren s tnayen ař tameyra. Di řweqt n tmeyra ad iniɣ i yinni imejjaren: ‘Yarwem amezwar řḥayyar, ceddem t di tqebbiṭin ḥima ad ittwassecmeḍ, maca irden, yarwem t di řmarsi inu.’” \x ◘ \xo 13:30 \xt Mt. 3:12. \x*
\b
\s1 Amedya n tḥebbuct n zzariɛet n uxerdel d umedya n wentun
\m 
\v 31 Iwca asen \add ɛawed\add* ijj n umedya nneɣni, inna: “Tageldit n ijenwan am yict n tḥebbuct n zzariɛet n uxerdel, yiwyi tt-i-dd ijj n weryaz, izarɛ i-tt deg iyyar nnes. \x ◘ \xo 13:31 \xt [Mk. 4:30-34; Lk. 13:18-21] \x*
\v 32 Waxxa nettat d tameẓyant qaɛ zi marra zzariɛet nneɣni, xmi tmeqqar, tᵉddekkwař d tameqqrant zi \add marra\add* tibbi uca tdekkwař d tacejjart maḥend ad ɣares dd-asen yijḍaḍ n ujenna uca ad ggen řeɛwacc nsen x řefruɛ nnes.”
\b
\m 
\v 33 Iwca asen \add ɛawed\add* ijj n umedya nneɣni, inna: “Tageldit n ijenwan am wentun, tiwyi t-i-dd ict n temɣart uca tessnuffar i-t di třata n řemdud n waren, ařami issmemm \add warecti\add* qaɛ.” \x ◘ \xo 13:33 \xt Lk. 13:20, 21. \x*
\b
\m 
\v 34 Marra man aya issiweř zzayes Yasuɛ i řɣaci s imettiřen uca břa amedya war kisen issiweř ca, \x ◘ \xo 13:34 \xt Mk. 4:33. \x*
\v 35 ḥima ad ittwakemmeř min xef issiweř unabi i innan: “Ad arezmeɣ aqemmum inu s imedya, ad barrḥeɣ s min innufaren zeg wami ittwagg dsas n ddunect.” \x ◘ \xo 13:35 \xt Izhd. 78:2. \x*
\b
\s1 Afessar n umedya n řḥayyar di řwest n yirden
\m 
\v 36 Řami ismeḥ Yasuɛ di řɣaci ad uyuren, iruḥ ɣar taddart. Usin-dd ɣares imeḥḍaren nnes, qqaren: “Ini aneɣ min ixs ad yini umedya n řḥayyar d iyyar!”
\v 37 Yarra-dd, inna asen: “Wenni izarrɛen zzariɛet taṣebḥant Netta d Mmis n bnadem.
\v 38 Iyyar d ddunect uca zzariɛet taṣebḥant nettat d tarwa n Tgeldit uca řḥayyar netta d tarwa n umɛeffan.
\v 39 Řeɛdu wenni t izarɛen, aqa netta d cciṭan, uca ṣṣabet, aqa nettat d qeṭṭu n ddunect u inni imejjaren, nitni d lmalakat. \x ◘ \xo 13:39 \xt Yuw. 4:13; Asa. 14:15. \x*
\v 40 Am mammec ssmunen řḥayyar uca sscemḍen t s tmessi, ammu i ɣa yiři ɣar qeṭṭu n ddunect-a.
\v 41 Mmis n bnadem ad dd-issekk lmalakat nnes, ad ssḥeyydent zi Tgeldit nnes qaɛ tiɛenkřifin d marra iɛeffanen.
\v 42 Ad ten nḍaren di řkuccet n tmessi mani ɣa yiřin imeṭṭawen d uɣezzi n teɣmas. \x ◘ \xo 13:42 \xt Mt. 8:12; 22:13; 24:51; 25:30; Lk. 13:28. \x*
\v 43 Xenni imseggaden ad arɣen am tfuct di Tgeldit n Babatsen. Wenni ɣar iǧa imezzuɣen i useǧi ad iseř.” \x ◘ \xo 13:43 \xt Dan. 12:3; 1 Kur. 15:42. \x*
\b
\s1 Amedya n řkenz deg iyyar d umedya n tyaqut
\m 
\v 44 “Tageldit n ijenwan ɛawed am yijj n řkenz ittwassnuffaren deg iyyar, yufa i-t \add ijj n\add* weryaz, issnuffar i-t uca di řefraḥet nnes yuyur, izzenz qaɛ min iǧan ɣares uca isɣa iyyar nni.” \x ◘ \xo 13:44 \xt Fil. 3:7. \x*
\b
\m 
\v 45 “Tageldit n ijenwan ɛawed am yijj n usebbab i yarezzun tiyaqutin tiṣebḥanin.
\v 46 Řami yufa ict n tyaqut tiɣřa aṭṭas, yuyur, izzenz marra min tuɣa ɣares, xenni isɣa i-tt.”
\b
\s1 Amedya n tracca n iseřman
\m 
\v 47 “Tageldit n ijenwan ɛawed am tracca mmenḍaren tt di řebḥar, teyru ɛřam kuř \add asřem\add*.
\v 48 Xmi teccur, ssuffɣen tt-i-dd ibeḥriyyen ɣar tma n řebḥar, qqimen uca farzen \add zzayes\add* min iṣebḥen di řeqcuɛ \add nsen\add*, maca min war iḥřin nḍaren t.
\v 49 Ammu i ɣa tiři di qeṭṭu n ddunect. Ad dd-ffɣent lmalakat, ad farnent iɛeffanen zi řwesṭ n imseggaden.
\v 50 Ad ten nḍarent di řkuccet n tmessi mani ɣa yiřin imeṭṭawen d uɣezzi n teɣmas.” \x ◘ \xo 13:50 \xt Mt. 13:42. \x*
\v 51 Inna asen Yasuɛ: “Ma tfehmem i marra man aya?” Nnan as: “Wah, a Siditneɣ!”
\v 52 \add Xenni\add* inna asen: “S uya kuř amseřmad n idlisen wenni idweř d ameḥḍar n Tgeldit n ijenwan, aqa igga am yijj n bab n taddart issuffuɣ zi řkenz nnes min iǧan d jdid u min iǧan d aqdim.”
\v 53 Awarni řami ikemmeř Yasuɛ imedya-ya, yuyur ssenni.
\b
\s1 Anabi war ɣares bu ccan di tendint nnes
\m 
\v 54 Řami dd-yusa ɣar temmurt nnes, ikkar isseřmad i-ten di temzidawin nsen ařami qqimen tbehten, nnan: “Manis d as dd-tekka tiɣit-a d řeɛjayeb-a? \x ◘ \xo 13:54 \xt [Mk. 6:1-6; Lk. 4:16-30] \x*
\v 55 Ma war iǧi wa d mmis n unejjar? Ma war qqaren i yemmas Maryam, d aytmas ma war d asen qqaren Yaɛqub d Yasi d Cimɛun d Yahuda? \x ◘ \xo 13:55 \xt Mt. 1:25; Mk. 6:3; Yḥ. 6:42. \x*
\v 56 Ma war ǧint suyᵉtmas qaɛ ɣarneɣ? Manis d as dd-ikka man aya marra?”
\v 57 Uca nderfen zzayes. Maca Yasuɛ inna asen: “Anabi ɛemmarṣ war iǧi břa ccan, mɣir di tendint nnes u di taddart nnes.” \x ◘ \xo 13:57 \xt Mk. 6:4; Lk. 4:24; Yḥ. 4:44. \x*
\v 58 Uca war iggi diha řeɛjayeb aṭṭas zi ssibbet n břa l’iman nsen.
\b
\b
\c 14
\s1 Řmewt n Yuḥanna Amseɣḍaṣ
\m 
\v 1 Di řweqt nni isřa Hirudus, řḥakem x ijj n arbaɛ n temmurt, řexbar x Yasuɛ. \x ◘ \xo 14:1 \xt [Mk. 6:14-29; Lk. 9:7-9] \x*
\v 2 Inna i yimsexxaren nnes: “Wanita d Yuḥanna Amseɣḍaṣ. Aqa ittwassnekkar-dd zi taddart n imettinen, s uyenni ttwaggent zzayes řeɛjayeb nni.”
\v 3 Minzi Hirudus tuɣa iṭṭef Yuḥanna, icarf i-t, igga i-t di řeḥbes zi ssibbet n Hirudiyya, tenni d tamɣart n Filippus, wenni d umas \add n Hirudus\add*, \x ◘ \xo 14:3 \xt Mk. 6:17; Lk. 3:19. \x*
\v 4 minzi Yuḥanna tuɣa iqqar as: “War ɣarek bu ttesriḥ aqa tiwyed tt d tamɣart nnec.” \x ◘ \xo 14:4 \xt Lawi 18:16. \x*
\v 5 \add S uya\add* tuɣa ixs ad t ineɣ, \add maca\add* tuɣa iggʷed zi řɣaci, minzi nitni ḥesben t d anabi. \x ◘ \xo 14:5 \xt Mt. 21:26. \x*
\v 6 Maca řami dd-yiweḍ wass n wexřaq n Hirudus, tecḍeḥ yeǧis n Hirudiyya zzat i \add inewjiwen i dinni\add* iqqimen, uca teɛjeb as i Hirudus. \x ◘ \xo 14:6 \xt Amz. 40:20; Mk. 6:21. \x*
\v 7 S uyenni inna as s ict n tjaǧit ad as iwc marra min i ɣa tᵉttar \add zzayes\add*. \x ◘ \xo 14:7 \xt Řqḍ. 11:30. \x*
\v 8 Uca nettat, am tt tuɣa tᵉttwaɛarren zeg yemmas, tenna: “Ewc ayi da x ṭṭebṣi azeǧif n Yuḥanna Amseɣḍaṣ!”
\v 9 Icḍen ujeǧid, maca umi tuɣa ijjuǧ u x ssibbet n yinni akides iqqimen, yumur ad as immewc \add uzeǧif\add*.
\v 10 Issekk ḥed \add ɣares\add*, ḥima ad iqess azeǧif i Yuḥanna di řeḥbes.
\v 11 Iwyen-dd azeǧif nnes di ṭṭebṣi, immewc as i tḥenjirt uca nettat tiwyi-t i yemmas.
\v 12 Usin-dd imeḥḍaren nnes, ksin řxecbet, neḍřen tt. Řexdenni ruḥen, xebbaren Yasuɛ.
\b
\s1 Lmuɛjiza n usecci amezwaru
\m 
\v 13 Řami isřa Yasuɛ man aya, iffeɣ ssenni deg uɣarrabu ɣar ijj n wemcan ixřan, \add tuɣa-t din\add* weḥḥdes. Isřa řɣaci x man aya, uca ḍfaren t x temmurt zi tneddam. \x ◘ \xo 14:13 \xt [Mk. 6:30-44; Lk. 9:10-17; Yḥ. 6:1-14] — Mt. 12:15; \x*
\v 14 Umi dd-iffeɣ Yasuɛ zi tɣarrabut, iẓra aṭṭas n řɣaci uca iḥinn xasen, issgenfa imehřac nsen. \x ◘ \xo 14:14 \xt Mt. 9:36; Yḥ. 6:5. \x*
\v 15 Řami dd-tiweḍ tmeddit, usin-dd ɣares imeḥḍaren nnes, nnan: “Aqa amcan-a ixřa u řweqt teɛdu. Zeɛma sqebbeḍ řɣaci, ḥima ad uyuren ɣar ředcur, ad sɣen min ɣa ccen i yixef nsen.” \x ◘ \xo 14:15 \xt Mk. 6:35; Lk. 9:12. \x*
\v 16 Maca Yasuɛ inna asen: “Nhřa ma ruḥen, wcem asen kenniw min ɣa ccen.”
\v 17 Nnan as: “War da walu mɣir xemsa n tecnifin d tnayen n iseřman.”
\v 18 Inna: “Awyem ten-dd da ɣari.”
\v 19 Xenni yumur řɣaci ad qqimen x arbiɛ. \add Xenni\add* iṭṭef xemsa n tecnifin d tnayen nni n iseřman, ixzar ɣar ujenna, ibarek, yarẓa \add i-tent\add* uca iwca ticnifin nni i imeḥḍaren u imeḥḍaren wcin \add tent\add* i řɣaci. \x ◘ \xo 14:19 \xt 1 Ṣm. 9:13. \x*
\v 20 Marra ccin, jjiwnen. Řexdenni ksin iřeqqwaz iceṭṭen: tuɣa din tenɛac n tsuǧatin ɛemmarent.
\v 21 Inni ccin tuɣa aten di xemsa ařef n yeryazen, břa timɣarin d iḥenjiren.
\b
\s1 Yasuɛ iggur x waman n řebḥar
\m 
\v 22 Deɣya iziyyar Yasuɛ imeḥḍaren nnes ad nyen di tɣarrabut uca ad as izwaren ɣar ujemmaḍ, am issqebbeḍ Netta řɣaci. \x ◘ \xo 14:22 \xt [Mk. 6:45-56; Yḥ. 6:16-21] \x*
\v 23 \add Awarni\add* řami issqebbeḍ řɣaci, igeɛɛed ɣar wedrar weḥḥdes, ḥima ad iẓẓaǧ. Řami dd-tiweḍ tmeddit, tuɣa iqqim din weḥḥdes. \x ◘ \xo 14:23 \xt Mk. 6:46; Yḥ. 6:15. \x*
\v 24 Aɣarrabu tuɣa tiggʷej x temmurt ‘istadiyyen’ aṭṭas, uca tᵉttwaɛarn zi ssa ɣar diha s řemwaj, minzi asemmiḍ yusa asen-dd deg wudem.
\v 25 Maca deg ḥeṭṭu wiss arebɛa n ǧiřet, yusa-dd ɣarsen Yasuɛ am iggur x waman \add n řebḥar\add*.
\v 26 Umi t ẓrin imeḥḍaren iggur x waman \add n řebḥar\add*, nnxeřɛen, nnan: “Wa d řewḥiy aɣeddar!”, uca sɣuyen zi tiggʷudi.
\v 27 Deɣya issiweř-dd ɣarsen Yasuɛ, inna: “Ggem uř, aqa d NECC, war tteggʷedem ca!”
\v 28 Buṭrus yarra-dd xas, inna: “\add A\add* Sidi, mařa d Cek, weṣṣa ayi ad ɣarek dd-aseɣ x waman.”
\v 29 Inna as: “As-dd!” Uca ihwa-dd Buṭrus zeg uɣarrabu, yuyur x waman, ḥima ad dd-yaweḍ ɣar Yasuɛ.
\v 30 Maca umi iẓra asemmiḍ ijhed, teřqef i-t tiggʷudi uca, am ibda iɣarreq, iřaɣa, inna: “\add A\add* Sidi, senjem ayi!”
\v 31 Deɣya isswiẓẓeḍ Siditneɣ afus nnes, iṭṭef dayes, inna as: “\add A cek\add* wenni di iǧa drus n l’iman, mayemmi dayek yudef ccek?”
\v 32 Awarni řami nyin deg uɣarrabu, yarsa usemmiḍ.
\v 33 Inni iǧan deg uɣarrabu, usin-dd ɣares, sejden as, nnan: “S tidett, Cek d Mmis n AREBBI!”
\b
\m 
\v 34 Awarni řami ẓwan \add řebḥar\add*, iwḍen ɣar temmurt n Jinnisaret.
\v 35 \add Řami\add* t ɛeqřen yeryazen n temmurt nni, ssuffɣen řexbar di marra dcurat i d as dd-innḍen, iwyen-dd ɣares marra inni tuɣa iheřcen aṭṭas,
\v 36 ttaren zzayes ad ten yejj ad ḥadan mɣir abeḥřuř n ujeǧab nnes, u \add marra\add* inni t iḥadan, dewřen ggenfan.
\b
\b
\c 15
\s1 Ccariɛa n Arebbi war tᵉttis ak-d tɣuri d tweṣṣa n iwdan
\m 
\v 1 Řexdenni usin-dd imseřmaden n idlisen d Ifarisiyyen zi Urcalim ɣar Yasuɛ, nnan: \x ◘ \xo 15:1 \xt [Mk. 7:1-23] \x*
\v 2 “Mayemmi ttɛeddan imeḥḍaren nnec x tubbart n imɣaren \add nneɣ\add*. Nitni war ssiriden ca ifassen nsen qbeř i ɣa ccen aɣrum!”
\v 3 Yarra-dd Yasuɛ, inna asen: “Mayemmi kenniw ɛawed tᵉttɛeddam x tewṣeyyet n AREBBI zi ssibbet n tubbart nwem?
\v 4 Minzi AREBBI tuɣa inna: ‘Weqqar babac d yemmac!’ u: ‘Wenni i ɣa ixzan babas niɣ yemmas, ittxeṣṣa as ad immet!’ \x ◘ \xo 15:4 \xt Uf. 20:12; 21:17; Lawi 20:9; Aɛwd. 5:16; Awřn. 20:20; Afa. 6:2. \x*
\v 5 Maca kenniw teqqarem: ‘Marra wi ɣa yinin i babas niɣ i yemmas: Marra min tzemmarem ad zzayi tnefɛem, aqa ggiɣ t d tawhibt \add i Arebbi\add*! Ammu netta war iḥdij \add ɛad\add* ad iweqqar babas niɣ yemmas \add s marra man aya\add*!’
\v 6 Ammu tbeṭṭřem awař n AREBBI di ṭṭweɛ n tubbart nwem. \x ◘ \xo 15:6 \xt Mk. 7:13; 1 Tim. 4:3; 2 Tim. 3:2. \x*
\v 7 \add Kenniw, a\add* imnafqen! Icaɛya tuɣa ittnabba xawem s ṣṣeḥ, inna:
\v 8 ‘Řgens-a ittcenneɛ ayi s iyencicen nsen, maca uř nsen iggʷej xafi. \x ◘ \xo 15:8 \xt Ica. 29:13; Ḥiz. 33:31; Mk. 7:6. \x*
\v 9 Aqa nitni cennɛen ayi baṭeř, \add minzi\add* nitni sseřmaden tiɣuriwin nni iǧan d tiweṣṣa n iwdan.’” \x ◘ \xo 15:9 \xt Ica. 29:13; Mk. 7:6, 7; Kul. 2:18, 20, 22. \x*
\m 
\v 10 Řami d iřaɣa-dd x řɣaci ɣares, inna asen: “Sřem \add mliḥ\add*, fehmem! \x ◘ \xo 15:10 \xt Mk. 7:14. \x*
\v 11 War iǧi min ittadfen deg uqemmum issexmej bnadem, maca min i dd-itteffɣen zeg uqemmum d man aya i issexmajen bnadem.” \x ◘ \xo 15:11 \xt Řex. 10:15; Rum. 14:17, 20; Tit. 1:15. \x*
\m 
\v 12 Řexdenni usin-dd ɣares imeḥḍaren nnes, nnan as: “Ma tessned belli Ifarisiyyen nderfen di man aya, řami t sřin?”
\v 13 Maca Netta yarra-dd, inna asen: “Kuř aɣeddu, war t iẓẓu Baba, wenni iǧan deg ijenwan, ad ittwaqřeɛ. \x ◘ \xo 15:13 \xt Yḥ. 15:2. \x*
\v 14 Ejj i-ten! Nitni d idarɣařen neddhen idarɣařen. Mařa adarɣař ineddeh adarɣař, ad wḍan s tnayen idsen deg weḥfur.” \x ◘ \xo 15:14 \xt Ica. 42:19; Lk. 6:39. \x*
\m 
\v 15 Yarra-dd Cimɛun Buṭrus, inna as: “\add A\add* Sidi, fessar aneɣ amedya-ya!” \x ◘ \xo 15:15 \xt Mk. 7:17. \x*
\v 16 Maca Yasuɛ inna asen: “Ma kenniw ɛad břa řefhamet ař řexxu?
\v 17 Ma war tefhimem ca belli marra min ɣa yadfen deg uqemmum, ad iraḥ ɣar uɛeddis uca ssenni ad ittwassuffeɣ barra i usizdeg?
\v 18 Maca min i dd-itteffɣen zeg uqemmum ittas-dd zeg wuř, aqa d man aya i issxemmajen bnadem.
\v 19 Minzi zeg wuř n iwdan i dd-tteffɣen ixarriṣen iɛeffanen, zzina, anɣay, farq-ccɣeř, tuceffra, cchadat s ẓur d uceqqef. \x ◘ \xo 15:19 \xt Amz. 6:5; 8:21; Awřn. 6:14; Irm. 17:9. \x*
\v 20 Aqa d man aya min issxemmajen bnadem, maca macca s ifassen war issirden war tessxemmij ca bnadem.”
\b
\s1 L’iman n temɣart zeg ayt n Kenɛan
\m 
\v 21 Řexdenni iffeɣ-dd Yasuɛ ssenni, iruḥ ɣar jjwayeh n Ṣur d Ṣaydun. \x ◘ \xo 15:21 \xt [Mk. 7:24-30] \x*
\v 22 U xzar, ict n temɣart zeg ayt n Kenɛan zi jjwayeh nni tesɣuy, tenna: “\add A\add* Sidi, \add a\add* Mmis n Dawud, arḥem ayi! Yeǧi aqa dayes cciṭan issnexřaɛen.”
\v 23 Maca Netta war xas dd-yarri ca, uřa s yijj n wawař. Usin-dd ɣares imeḥḍaren nnes, ttaren zzayes, nnan: “Aẓẓeř xas, minzi nettat teḍfar aneɣ-dd s iɣuyyan.”
\v 24 Netta yarra-dd, inna asen: “Necc ttwassekkeɣ-dd ɣar wuǧi iweddaren n taddart n Israil waha.” \x ◘ \xo 15:24 \xt Mt. 10:6; Řex. 13:46. \x*
\v 25 Maca nettat tusa-dd, tesjed as, tenna: “A Sidi, ɛawen ayi!”
\v 26 Maca Netta yarra-dd, inna: “War iɛeddeř ad immeksi weɣrum n iḥenjiren, maḥend ad immenḍar i yiṭan.”
\v 27 Maca nettat tenna: “Wah, a Sidi, maɣar uřa d iṭan ttᵉtten iřeqqwaz i dd-iweṭṭan zi ṭṭabřa n siditsen uca \add ttɣiman\add* ddaren.”
\v 28 Řexdenni inna as Yasuɛ: “A tamɣart, l’iman nnem imɣar! Ad yiři am mammec řxaḍar nnem.” Uca yeǧis teggenfa di tsaɛɛet nni.
\b
\s1 Asgenfi n ineɛḍab, idařɣaren, ignawen d iqejdaḥen
\m 
\v 29 Uca yuyur Yasuɛ ssenni, yiweḍ-dd ɣar tma n řebḥar n Ljalil, igeɛɛed ɣar wedrar, iqqim dinni. \x ◘ \xo 15:29 \xt Mk. 7:31. \x*
\v 30 Yusa-dd ɣares ijj n ubarru ameqqran n řɣaci, iwyen-dd akidsen ineɛḍaben d idarɣařen d ignawen d iqejdaḥen d inneɣni aṭṭas, ssarsen ten ɣar iḍaren n Yasuɛ uca issgenfa ten, \x ◘ \xo 15:30 \xt Ica. 29:18; 35:5; Mt. 11:5; Lk. 7:22. \x*
\v 31 ařami itebhet řɣaci, aqa ẓrin ignawen ssawařen, iqejdaḥen ggenfan, ineɛḍaben gguren, idarɣařen ttwařan, uca ssɛuǧen AREBBI n Israil.
\b
\s1 Lmuɛjiza n usecci i twařa wiss tnayen
\m 
\v 32 Yasuɛ iřaɣa-dd x imeḥḍaren nnes, inna asen: “Ḥinneɣ x řɣaci minzi qqimen akidi třata n wussan, war ɣarsen min ɣa ccen. War xseɣ ca ad ten ssqebbḍeɣ ttẓuman, ḥima war tteḍɛifen ca deg webrid.” \x ◘ \xo 15:32 \xt [Mk. 8:1-10] \x*
\v 33 Nnan as imeḥḍaren nnes: “Manis d ɣa nawi aɣrum di řexřa\add -ya\add* i zi ɣa nessecc ijj n řɣaci d ameqqran am wanita?”
\v 34 Inna asen Yasuɛ: “Mecḥař ɣarwem d aɣrum?” Nnan as: “Sebɛa \add n tecnifin\add* d ca n iseřman imeẓyanen.”
\v 35 \add Xenni\add* yumur řɣaci, ḥima ad qqimen di temmurt.
\v 36 Iksi sebɛa n tecnifin d iseřman \add nni\add*, iqada, yarẓa i-tent uca iwca i-tent i imeḥḍaren nnes uca imeḥḍaren wcin tent i iwdan. \x ◘ \xo 15:36 \xt 1 Ṣm. 9:13. \x*
\v 37 Marra ccin, jjiwnen. Xenni yarwen-dd iřeqqwaz iceṭṭen: tuɣa din sebɛa n tsuǧatin ɛemmarent.
\v 38 Inni tuɣa iccen aqa aten di arebɛa ařaf n yeryazen břa timɣarin d iḥenjiren.
\v 39 Awarni řami issqebbeḍ řɣaci, inya deg uɣarrabu uca yiweḍ ɣar weymir \add n jjwayeh\add* n Magdu.
\b
\b
\c 16
\s1 Ifarisiyyen ttaren ict n řeɛřamet
\m 
\v 1 Usin-dd ɣares Ifarisiyyen d Iṣaduqiyyen, sseqsan t ḥima ad t jarrben, maḥend ad asen isscen ca n řeɛřamet zeg ujenna. \x ◘ \xo 16:1 \xt [Mk. 8:11-13; Lk. 12:54-56] — Mt. 12:38; Lk. 11:29; Yḥ. 6:30. \x*
\v 2 Maca Netta yarra-dd, inna asen: “Ɣar tmeddit ad tinim: ‘Aqa řḥař iffeɣ!’, minzi ajenna d azeggʷaɣ. \x ◘ \xo 16:2 \xt Lk. 12:54. \x*
\v 3 U ɣar řefjar \add ad tinim\add*: ‘Aqa ass-a ad isuḍ usemmiḍ!’, minzi ajenna d azeggʷaɣ ař abarcan. \add A\add* imnafqen, kenniw tessnem ad tfarzem udem n ujenna, maca řeɛřamat n zzman-a war tzemmarem ad tent tfarzem.
\v 4 Jjiř aɛeffan izennan yarezzu ict n řeɛřamet, \add maca\add* war d as ittmewci uřa d ict n řeɛřamet mɣir řeɛřamet n Yunus, anabi!” \add Xenni\add* ijja i-ten, iruḥ. \x ◘ \xo 16:4 \xt Yun. 2:1; Mt. 12:39; Lk. 11:29. \x*
\b
\s1 Antun n Ifarisiyyen d Isaḍuqiyyen
\m 
\v 5 Řami dd-iwḍen imeḥḍaren nnes ɣar ujemmaḍ \add n řebḥar\add*, ttun ad kisen dd-awyen aɣrum. \x ◘ \xo 16:5 \xt [Mk. 8:14-21] \x*
\v 6 Inna asen Yasuɛ: “Ḥḍam ixef nwem zeg wentun n Ifarisiyyen d Iṣaduqiyyen.” \x ◘ \xo 16:6 \xt Mk. 8:15; Lk. 12:1. \x*
\v 7 Nitni mcawaren jar asen \add x man aya\add*, nnan: “Aqa \add inna\add* man aya minzi war d niwi ca aɣrum!”
\v 8 Yasuɛ, am tuɣa issen man aya, inna asen: “\add A\add* kenniw i di iǧa drus n l’iman, mayemmi temcawarem jar awem aqa man aya iǧa umi war dd-tiwyem aɣrum?
\v 9 Ma ɛad war tefhimem ca? Ma war teɛqiřem ca x xemsa n iřeqqwaz n weɣrum i xemsa-ařaf, u mecḥař n tsuǧatin i tyarwem? \x ◘ \xo 16:9 \xt Mt. 14:17; Mk. 6:38; Lk. 9:13; Yḥ. 6:9. \x*
\v 10 Niɣ x sebɛa n iřeqqwaz n weɣrum i arebɛa ařaf, u mecḥař n tsuǧatin i tyarwem? \x ◘ \xo 16:10 \xt Mt. 15:34. \x*
\v 11 Ma ɛad war tefhimen ca belli Necc war kiwem ssiwřeɣ ca x weɣrum umi d awem nniɣ: ‘Ḥḍam ixef nwem zeg wentun n Ifarisiyyen d Iṣaduqiyyen’?”
\v 12 Ssenni fehmen aqa Netta war d asen inni, maḥend ad ḥḍan ixef nsen zeg wentun n weɣrum, maca zi tɣuri n Ifarisiyyen d Iṣaduqiyyen.
\b
\s1 Lmasiḥ d Mmis n AREBBI iddaren
\m 
\v 13 Řami dd-yiweḍ Yasuɛ ɣar temmurt n Qayṣariya-Filippus, isseqsa imeḥḍaren nnes: “Min ɛniɣ Necc, Mmis n bnadem, ɛlaḥsab min qqaren iwdan?” \x ◘ \xo 16:13 \xt [Mk. 8:27-30; Lk. 9:18-21] \x*
\v 14 Nnan as: “Ca qqaren ‘D Yuḥanna Amseɣḍaṣ’, u wenneɣni: ‘D Iliya’, u wenneɣni ɛawed: ‘D Irmiya’ niɣ ‘D ijjen zeg inabiyyen’.” \x ◘ \xo 16:14 \xt Mt. 14:2; Mk. 6:15; 8:28; Lk. 9:8, 19\x*
\v 15 Inna asen: “Maca kenniw, min xafi teqqarem?”
\v 16 Yarra-dd xas Cimɛun Buṭrus, inna: “Cek d Lmasiḥ, Mmis n AREBBI iddaren.” \x ◘ \xo 16:16 \xt Yḥ. 6:69. \x*
\v 17 Yarra-dd xas Yasuɛ, inna as: “Sseɛd nnec, a Cimɛun, mmis n Yuna, minzi war iǧi d aysum niɣ d idammen i d ac imřen man aya, maca d Baba i iǧan deg ijenwan. \x ◘ \xo 16:17 \xt Mt. 11:25. \x*
\v 18 Ɛawed Necc ad ac iniɣ, aqa cek d ‘Buṭrus’, \add d aẓru\add*, u x weẓru-ya ad bniɣ tamesmunt inu uca tiwwura n řaxart war d as zemmarent. \x ◘ \xo 16:18 \xt Izhd. 118:22; Ica. 28:16; 33:20; Yḥ. 1:43; 1 Kur. 3:11. \x*
\v 19 D Necc ad ac wceɣ tisarutin n Tgeldit n ijenwan, u marra min ɣa tcedded di temmurt, ad yiři icedd deg ijenwan, u marra min ɣa tfesyed di temmurt, ad yiři ifsi deg ijenwan.” \x ◘ \xo 16:19 \xt Mt. 18:18; Yḥ. 20:22. \x*
\v 20 Řexdenni yumur imeḥḍaren nnes, ḥima war xebbaren ḥed belli Netta d Lmasiḥ.
\b
\s1 Yasuɛ issawař x řmewt d tnukra nnes i twařa tamezwarut
\m 
\v 21 Ssenni ibda Yasuɛ ad isscen i imeḥḍaren nnes belli ittxeṣṣa as ad iraḥ ɣar Urcalim, ad iweddeb aṭṭas zeg imɣaren \add n řgens\add* u zeg imeqqranen n ikehhanen d imseřmaden n idlisen, ad ittwaneɣ uca ad dd-ittwassnekkar deg wass wiss třata. \x ◘ \xo 16:21 \xt [Mk. 8:31-9:1; Lk. 9:22-27] — Mt. 17:22; 20:18; Mk. 9:31; 10:33; Lk. 18:31; 24:7. \x*
\v 22 \add Maca\add* Buṭrus yiwyi t weḥḥdes, ibda ittwebbex i-t, inna: “War ittiři, \add a\add* Sidi! Man aya war d ac ittemsar ɛemmarṣ.”
\v 23 Maca Netta inneqřeb, inna i Buṭrus: “Ffeɣ xafi, \add a\add* cciṭan, cek d ict n tɛenkrift i Necc, minzi war cek icqi min iǧan n AREBBI, maca min iǧan n iwdan.” \x ◘ \xo 16:23 \xt 2 Ṣm. 19:22. \x*
\v 24 Řexdenni inna Yasuɛ i imeḥḍaren nnes: “Mařa ca n ijjen ixs ad ayi iḍfar, ad inkar ixef nnes, ad iksi ṣṣalib nnes uca ad ayi iḍfar. \x ◘ \xo 16:24 \xt Mt. 10:38; Mk. 8:34; Lk. 9:23; 14:27. \x*
\v 25 Minzi wenni ixsen ad issenjem tudart nnes, ad tt iweddar, \add maca\add* wenni i ɣa iweddaren tudart nnes di ṭṭweɛ inu ad tt yaf. \x ◘ \xo 16:25 \xt Mt. 10:39; Mk. 8:35; Lk. 9:24; 17:33; Yḥ. 12:25. \x*
\v 26 Minzi man řefḍeř i ɣares ɣar bnadem mařa yarbeḥ ddunect marra, \add maca\add* iřqef i-t druct di řeɛmar nnes? Niɣ min ɣa iwc bnadem i weṣřaḥ n řeɛmar nnes? \x ◘ \xo 16:26 \xt Izhd. 49:9; Mk. 8:37; Lk. 9:25. \x*
\v 27 Minzi Mmis n bnadem ad dd-yas s uɛuǧi n Babas ak-d lmalakat nnes, uca xenni ad ixeǧeṣ kuř ijjen ɛlaḥsab min igga. \x ◘ \xo 16:27 \xt Ayub 34:11; Izhd. 62:13; Mt. 24:30; 25:31; 26:64; Rum. 2:6. \x*
\v 28 S tidett Necc ad awem iniɣ, aqa ca zeg ina i da ibedden, war ttqisin ca řmewt ař ɣa ẓaren Mmis n bnadem ittas-dd di Tgeldit nnes.” \x ◘ \xo 16:28 \xt Mk. 9:1; Lk. 9:27. \x*
\b
\b
\c 17
\s1 Yasuɛ x wedrar ak-d Musa d Iliya
\m 
\v 1 Awarni setta n wussan Yasuɛ yiwi-dd Buṭrus d Yaɛqub d umas Yuḥanna akides, yiwyi i-ten weḥḥedsen ɣar ijj n wedrar yuɛřa. \x ◘ \xo 17:1 \xt [Mk. 9:2-13; Lk. 9:28-36] — 2 Bṭ. 1:17. \x*
\v 2 Uca ittwabeddeř waddud n Yasuɛ qibač nsen: tuɣa aɣembub nnes ittceɛciɛ am tfuct, idweř warruḍ nnes d acemřař am tfawt.
\v 3 Uřa d Musa d Iliya ḍharen asen-dd, ssawařen akides.
\v 4 Buṭrus iṭṭef deg wawař, inna i Yasuɛ: “\add A\add* Sidi, aqa mliḥ umi i da neǧa! Mařa texsed, ad newwet danita třata n iɛuccuten n tseṭṭa, ijjen i Cek, ijjen i Musa u ijjen i Iliya.”
\v 5 Am tuɣa issawař ɛad, ikka-dd xasen ijj n useynu ittseqsiq, issduriy ten s tiři nnes uca ict n tmijja zeg ujenna tenna: “D wa d Mmi iɛizzen, dayes ufiɣ arḍa inu, sřem ɣares!” \x ◘ \xo 17:5 \xt Aɛwd. 18:15; Ica. 42:1; Mt. 3:17; Mk. 1:11; 9:7; Lk. 3:22; 9:35; Řex. 3:22; Kul. 1:13; 2 Bṭ. 1:17. \x*
\v 6 Řami sřin imeḥḍaren man aya, wḍan x uɣembub nsen uca ggʷeden aṭṭas.
\v 7 Yusa-dd ɣarsen Yasuɛ, iḥada ten, inna: “Kkarem, war tteggʷedem ca!”
\v 8 Řami ssgeɛɛden tiṭṭawin nsen, war ẓrin ḥed mɣir Yasuɛ.
\m 
\v 9 Am dd-hwan zeg wedrar, yumur i-ten Yasuɛ, inna asen: “War ssiwiřem x řewḥiy-a am ɣarwem iǧa ijj nneɣni ař dd ɣa ikkar Mmis n bnadem jar imettinen.” \x ◘ \xo 17:9 \xt Mk. 9:9; Lk. 9:36. \x*
\v 10 Imeḥḍaren sseqsan t, nnan as: “Mayemmi qqaren imseřmaden n idlisen aqa Iliya ad dd-yas d amezwaru?” \x ◘ \xo 17:10 \xt Mal. 3:23; Mt. 11:14; Mk. 9:11. \x*
\v 11 Yarra-dd Yasuɛ, inna: “Iliya ad dd-yas d amezwaru, ḥima ad ittwakemmeř marra.
\v 12 Maca Necc ad awem iniɣ, xzar, Iliya aqa yusa-dd, war zzayes steɛtarifen, maca ggin zzayes min xsen. Ammu uřa d Mmis n bnadem ad zzaysen iweddeb.”
\v 13 Řexdenni fehmen imeḥḍaren, belli tuɣa issawař akidsen x Yuḥanna Amseɣḍaṣ.
\b
\s1 Yasuɛ issgenfa aḥenjir amaryaḥ
\m 
\v 14 Řami dd-usin ɣar řɣaci, yusa-dd ɣares ijj n bnadem, iwḍa \add as\add* ɣar iḍaren, inna as: \x ◘ \xo 17:14 \xt [Mk. 9:14-29; Lk. 9:37-43] \x*
\v 15 “\add A\add* Sidi, zziǧez i mmi, minzi aqa netta ittbarkikkiḍ, immarni xas řḥar, maɣar aṭṭas n twařawin iwḍa di tmessi u deg waman.
\v 16 Iwyeɣ t ɣar imeḥḍaren nnec, \add maca\add* nitni war zemmaren ad t ssgenfan.”
\v 17 Yasuɛ yarra-dd, inna: “A jjiř i war yuminen d imufriɣen, mecḥař i ɣa qqimeɣ ɛad akidwem, mecḥař ɛad i ɣa qqimeɣ ṣbareɣ awem? Awyem t-i-dd ɣari!”
\v 18 Xenni iwebbex i-t Yasuɛ uca iffeɣ zzayes cciṭan uca idweř uḥenjir iggenfa zi tsaɛɛet nni.
\m 
\v 19 Řexdenni usin-dd imeḥḍaren weḥḥedsen ɣar Yasuɛ, nnan as: “Mayemmi neccin war nzemmar ad t nessgenfa?” \x ◘ \xo 17:19 \xt Mk. 9:28. \x*
\v 20 Inna asen Yasuɛ: “Zi ssibbet n břa l’iman nwem. S tidett ad awem iniɣ, mařa daywem l’iman anect n ict n tḥebbuct n zzariɛet n uxerdel, ad as tinim i wedrar-a: ‘Muṭṭi ssa!’, xenni ad immuṭṭi, uca war din ittiři \add ɛad\add* uřa d ict n řḥajjet war d as tzemmarem \add ɛad\add*. \x ◘ \xo 17:20 \xt Mt. 21:21; Lk. 17:6. \x*
\v 21 Maca ddarb-a war dd-itteffeɣ mɣir s tẓaǧit d uẓummi.”
\b
\s1 Yasuɛ issawař x řmewt d tnukra nnes i twařa wiss tnayen
\m 
\v 22 Řami tuɣa ttsaran di Ljalil, inna asen Yasuɛ \add i imeḥḍaren nnes\add*: “Mmis n bnadem ad immewc deg ifassen n iwdan. \x ◘ \xo 17:22 \xt [Mk. 9:30-32; Lk. 9:43-45] — Mt. 16:21; 20:18; Mk. 8:31; 10:33; Lk. 9:22; 18:31. \x*
\v 23 Ad t nɣen uca ad dd-ittwassnekkar deg wass wiss třata.” \add Xenni\add* ceḍnen aṭṭas.
\b
\s1 Awař n Yasuɛ x ḍḍariba i Zzawect Tameqqrant
\m 
\v 24 Řami dd-usin ɣar Kafarnaḥum, qarrben-dd ayt n ḍḍariba, inni iṭṭfen tnayen n tepyasin n tnayen n ‘jjuzin’ n nnuqart i kuř uzeǧif \add i ḍḍariba n Zzawect Tameqqrant\add*, ɣar Buṭrus, nnan: “Amseřmad nwem, ma war ittxeǧiṣ tnayen n ‘jjuzin’ nnes \add i Zzawect Tameqqrant\add*?” Inna: “Wah, \add ad ten ixeǧes\add*!”
\v 25 Ařami dd-yudef Buṭrus ɣar taddart, izwar as-dd Yasuɛ, inna: “Cimɛun, mammec twařid cek, wi zi ṭṭfen ijeǧiden n ddunect řeɛcur d tenɛacin i izemmen i kuř azeǧif? Ma zi tarwa nsen niɣ zeg ibarraniyyen?” \x ◘ \xo 17:25 \xt Mt. 22:21; Rum. 13:7. \x*
\v 26 Inna as Cimɛun: “Zeg ibarraniyyen!” Inna as Yasuɛ: “S uya ǧan tarwa d iḥurriyyen!
\v 27 Maca ḥima war ten nessendrif \add ad ac umureɣ\add*: Ruḥ ɣar řebḥar, nḍar taṣennart uca arzem aqemmum i tesřemt tamezwarut i dd ɣa iffɣen uca ad tafed \add ict n tepyist n uṣulḍi n\add* ‘ustatir’. Ksi tt uca ewc i-tt xafi u x yixef nnec.”
\b
\b
\c 18
\s1 Man wen iǧan d ameqqran di Tgeldit n ijenwan?
\m 
\v 1 Di tsaɛɛet nni usin-dd imeḥḍaren ɣar Yasuɛ, nnan: “Man wen iǧan d ameqqran di Tgeldit n ijenwan?” \x ◘ \xo 18:1 \xt [Mk. 9:33-37; Lk. 9:46-48] — Lk. 22:24. \x*
\v 2 Yasuɛ iřaɣa-dd x ijj n uḥenjir ɣares, issbedd i-t di řwesṭ nsen,
\v 3 inna: “S tidett Necc ad awem iniɣ: Mařa war ttubem u tdewřem am iḥenjiren, ɛemmarṣ ad tadfem ɣar Tgeldit n ijenwan. \x ◘ \xo 18:3 \xt Mt. 19:14; 1 Kur. 14:20; 1 Bṭ. 2:2. \x*
\v 4 S uya wenni i ɣa issmeẓyen ixef nnes am uḥenjir-a, aqa d wenni d ameqqran di Tgeldit n ijenwan, \x ◘ \xo 18:4 \xt 1 Bṭ. 5:6. \x*
\v 5 u wenni i ɣa iqebřen ijj \add n uḥenjir\add* i iǧan am uḥenjir-a s Yisem inu, iqebbeř ayi. \x ◘ \xo 18:5 \xt Mk. 9:37; Lk. 9:48; Yḥ. 13:20. \x*
\b
\s1 Aɛřam ɣar řgens x min i ɣa iɣarren i ddenb
\m 
\v 6 \add Maca\add* kuř ijjen wenni i ɣa issenqarḍen ijjen zeg imeẓyanen-a i zzayi ittamnen, iḥřa as ad as tᵉttwagg ict n teṣḍart n tsirt tedqeř ɣar yiri nnes, ad ittwassɣareq di řaǧaɣ n řebḥar. \x ◘ \xo 18:6 \xt [Mk. 9:42-48; Lk. 17:1-2] \x*
\v 7 Uct x ddunect x ssibbet n tɛenkrifin. Iwa, ittxeṣṣa ad dd-asent tɛenkrifin, maca amcum n bnadem nni itteggen taɛenkrift. \x ◘ \xo 18:7 \xt Mt. 26:24; Řex. 2:23; 4:27, 28; 1 Kur. 11:19. \x*
\v 8 Mařa issenqarḍ cek ufus nnec niɣ aḍar nnec, xenni qess i-t, nḍar i-t xak. Iḥřa ac ad tadfed ɣar Tudart d aqejdaḥ niɣ d ameɛḍuř x umenḍar s tnayen n ifassen niɣ s tnayen n iḍaren di tmessi i řebda. \x ◘ \xo 18:8 \xt Aɛwd. 13:7; Mt. 5:29,30; Mk. 9:43. \x*
\v 9 Mařa tessenqarḍ cek tiṭṭ nnec, xenni qeřɛ i-tt, nḍar i-tt xak, iḥřa ac ad tadfed ɣar Tudart s ict n tiṭṭ x uweṭṭu di jᵉhennama iccuren s tmessi s tnayen n tiṭṭawin.
\b
\s1 Amedya n wuǧi iweddaren
\m 
\v 10 Ɣarwem ad tesseḥqarem ijjen zeg imeẓyanen-a. Minzi Necc ad awem iniɣ, aqa lmalakat nsen deg ijenwan aqa řebda ttwařant tifras n Baba i iǧan deg ijenwan. \x ◘ \xo 18:10 \xt Izhd. 34:8; Lk. 15:3-7 \x*
\v 11 Minzi Mmis n bnadem yusa-dd, ḥima ad issenjem min tuɣa iweddaren. \x ◘ \xo 18:11 \xt Lk. 19:10. \x*
\v 12 Mammec i d awem ittɣiř? Mařa din ca n bnadem ɣares mya n wuǧi uca ijjen zzaysen iweddar, ma xenni war ittejji tesɛa u-tesɛin deg idurar, ad iraḥ ad yarzu x wenni iweddaren? \x ◘ \xo 18:12 \xt Lk. 15:3. \x*
\v 13 U mařa yufa i-t, s tidett Necc ad awem iniɣ, ad zzayes ifarḥ ktar zi min ɣa ifarḥ zi tesɛa u-tesɛin inni war iweddaren.
\v 14 Ammu uřa d Babatwem i iǧan deg ijenwan war ixs ad iweddar uřa d ijj zeg imeẓyanen-a.”
\b
\s1 Ddenb n ijj n uma
\m 
\v 15 “Mařa ixḍa umac akidek, ruḥ ɣares, webbex i-t \add mɣir\add* jar ac d jar as \add waha\add*. Mařa isřa ɣarek, aqa tarbeḥed umac. \x ◘ \xo 18:15 \xt [Lk. 17:3] — Lawi 19:17; Awřn. 17:10; Yaɛ. 5:19. \x*
\v 16 Mařa war ɣarek isři ca, awi akidek ca n ijjen nneɣni niɣ tnayen, ḥima x uqemmum n tnayen niɣ n třata n řechud ad ittwaḍmen wawař marra. \x ◘ \xo 18:16 \xt Řxř. 35:30; Aɛwd. 17:6; 19:15; Yḥ. 8:17; 2 Kur. 13:1; Ɛbr. 10:28. \x*
\v 17 Mařa netta war ɣarsen isři, xenni ini tt i tmesmunt \add n řmuminin\add*, uca mařa war isři uřa ɣar tmesmunt, xenni ejj i-t ad ɣarwem yiři am yijj n bu-ḍḍariba niɣ am yijj n ukafriw. \x ◘ \xo 18:17 \xt 1 Kur. 5:9; 2 Ts. 3:14. \x*
\v 18 S tidett Necc ad awem iniɣ: Marra min ɣa tceddem di temmurt, ad yiři icedd deg ujenna, uca marra min ɣa tfesyem di temmurt, ad yiři ifsi deg ujenna. \x ◘ \xo 18:18 \xt Mt. 16:19; Yḥ. 20:23. \x*
\v 19 Ad awem iniɣ ɛawed, mařa tnayen n iwdan ad mmsetfaqen x temmurt x ca n řḥajjet i ɣa ttaren, aqa d man aya d asen i ɣa ittwagg zi Baba i iǧan deg ijenwan.
\v 20 Minzi mani ɣa munen tnayen niɣ třata s Yisem inu, Necc ad din iřiɣ di řwesṭ nsen.” \x ◘ \xo 18:20 \xt Lk. 24:15,36. \x*
\b
\s1 Amedya n umsexxar aɛeffan
\m 
\v 21 Řexdenni yusa-dd ɣares Buṭrus, inna: “A Sidi, mecḥař n twařawin i ɣa ixḍa akidi uma, necc ad as samḥeɣ? Ma ař sebɛa n twařawin?” \x ◘ \xo 18:21 \xt Lk. 17:4. \x*
\v 22 Inna as Yasuɛ: “War d ac qqareɣ ca ař sebɛa, maca ař sebɛin di sebɛa n imuren d sebɛa \add n imuren\add*! \x ◘ \xo 18:22 \xt Mt. 6:14; Mk. 11:25; Kul. 3:13. \x*
\v 23 S uya tᵉttawi-dd Tgeldit n ijenwan deg ijj n weryaz d ajeǧid i ixsen ad yegg řeḥsab ak-d imsexxaren nnes.
\v 24 Umi ibda ad imseḥseb, iwyen-dd ɣares ijj n \add bnadem\add* itturs as ɛecra-ařaf talint.
\v 25 Am war tuɣi ɣares min zi ɣa yarr \add amarwas\add*, yumur bab nnes, ḥima ad ittwammenz, netta d temɣart nnes d tarwa nnes d marra min ɣares, ḥima ad ittwaxeǧeṣ \add umarwas\add*. \x ◘ \xo 18:25 \xt Mt. 5:25. \x*
\v 26 Iwḍa as umsexxar \add nni ɣar iḍaren\add*, isjed as, inna: ‘\add A\add* sidi, ṣbar xafi, ad ac arreɣ marra.’
\v 27 Aqa izziǧez as bab n umsexxar nni, iḍřeq as uca isamḥ as deg umarwas.
\m 
\v 28 Řami dd-iffeɣ umsexxar nni, yufa ijjen zeg inni tuɣa d imsexxaren imɛacaren nnes u wanita itturs as mya dinar. Iṭṭef i-t, icebbar as deg yiri, inna as: ‘Xeǧeṣ ayi min d ac tturseɣ!’
\v 29 Iwḍa yas umsexxar amɛacar nnes ɣar iḍaren nnes, iḥeccem i-t, inna: ‘Ṣbar xafi, ad ac arreɣ \add marra\add*!’
\v 30 Maca netta war ixs, iruḥ inḍar i-t di řeḥbes ař dd ɣa yarr amarwas.
\m 
\v 31 Řami ẓřin imsexxaren imɛacaren nnes min imsaren, ceḍnen aṭṭas uca ruḥen, nnan tt i bab nsen.
\v 32 Uca iřaɣa-dd xas sidis, inna as: ‘\add A cek\add* amsexxar aɛeffan, marra min d ac tturseɣ, samḥeɣ ac, minzi tᵉttared ayi.
\v 33 Ma war iǧi zeɛma uřa d cek xak ad ac izziǧez wenni d amsexxar amɛacar nnec am mammec i d ayi tezziǧed cek?’
\v 34 Xenni ixeyyeq sidis, isseɛdu t deg ifassen n imɛaddeben ař ɣa ixeǧeṣ marra min dayes d amarwas.
\v 35 Ammu i ɣa yegg Baba wenni iǧan deg ujenna i kenniw, mařa kenniw war tsimiḥem s wuř kuř ijjen zzaywem i umas ixeṭṭan nnes.” \x ◘ \xo 18:35 \xt Mt. 6:14; Mk. 11:26; Yaɛ. 2:13. \x*
\b
\b
\c 19
\s1 Awařen n Yasuɛ x řemřac d waǧaf
\m 
\v 1 Ařami ikemmeř Yasuɛ awařen-a, iffeɣ zi Ljalil, yiweḍ ɣar jjwayeh n \add temmurt n\add* Yahudiyya, ɣar ujemmaḍ n \add yeɣzar n\add* L’Urdun. \x ◘ \xo 19:1 \xt [Mk. 10:1-12] \x*
\v 2 Aqa iḍfar i-t ijj n řɣaci d ameqqran, issgenfa i-ten dinni.
\v 3 Usin-dd ɣares uřa d Ifarisiyyen, tuɣa arezzun ad t jarrben, nnan \add as\add*: “Ma iḥeǧeř i weryaz ad iǧef i temɣart nnes zi mkuř sibbet?” \x ◘ \xo 19:3 \xt Mk. 10:2. \x*
\v 4 Yarra-dd, inna asen: “Ma war teɣrim ca belli wenni \add ten\add* dd-ixeřqen zeg umezwaru, ixřeq i-ten-dd d awtem d tewtemt, \x ◘ \xo 19:4 \xt Amz. 1:17, 2:24, 5:2 \x*
\v 5 uca aqa inna: ‘S uyenni ad ismeḥ weryaz di babas d yemmas, ad iqqen ɣar temɣart nnes, uca tnayen idsen nni ad iřin d ict n ddat’? \x ◘ \xo 19:5 \xt Amz. 2:24; Mt. 19:6; Mk. 10:8; Afa. 5:31; 1 Kur. 6:16. \x*
\v 6 S uya war ttiřin \add ɛad\add* d tnayen, maca d ict n arrimet. S uyenni min issmun AREBBI, war t ibeṭṭi bnadem.” \x ◘ \xo 19:6 \xt 1 Kur. 7:10. \x*
\v 7 Nnan as: “Mayemmi yumur Musa xenni, maḥend ad iwc tabrat n waǧaf, ḥima ad as iǧef?” \x ◘ \xo 19:7 \xt Aɛwd. 24:1; Irm. 3:1. \x*
\v 8 Inna asen: “Musa ijja kenniw ad teǧfem i temɣarin nwem zi ssibbet n řeqsaḥet n wuřawen nwem, maca war iǧi ammu zeg umezwaru.
\v 9 Maca Necc ad awem iniɣ: Wenni i ɣa iǧfen i temɣart nnes, břa ma tezna nettat, uca ad yiwi icten nneɣni, aqa netta izenna, u wenni i ɣa iwyen tamɣart tenni i iǧfen, aqa uřa d netta izenna.” \x ◘ \xo 19:9 \xt Mt. 5:32; Mk. 10:11; Lk. 16:18; 1 Kur. 7:10. \x*
\m 
\v 10 Imeḥḍaren nnes nnan as: “Mařa ammu i teǧa tmesřact jar bnadem d temɣart nnes, xenni nhřa ma ad imřec.”
\v 11 Maca Netta inna asen: “War iǧi marra zemmaren ad qebřen awař-a mɣir inni umi temmewc \add ad t iqbeř\add*. \x ◘ \xo 19:11 \xt 1 Kur. 7:7, 17. \x*
\v 12 Minzi aqa din inni ittwaqessen, minzi nitni d inni dd-ittwaxeřqen ammu zeg uɛeddis n yemmatsen, uca aqa din inni ittwaqessen, minzi nitni ttwaqessen zeg \add ifassen n\add* iwdan, uca aqa din inni ittwaqessen, minzi nitni qessen ixef nsen di ṭṭweɛ n Tgeldit n ijenwan. Wenni izemmaren ad t iqbeř, ejj i-t ad t iqbeř.”
\b
\s1 Yasuɛ ibarek iḥenjiren imeẓyanen
\m 
\v 13 Řexdenni iwyen as-dd iḥenjiren imeẓyanen maḥend ad xasen issars afus nnes uca ad \add asen\add* iksi s řmeɛruf, maca imeḥḍaren nnes webbxen ten. \x ◘ \xo 19:13 \xt [Mk. 10:13-16; Lk. 18:15-17] \x*
\v 14 Maca Yasuɛ inna asen: “Jjem iḥenjiren ad ɣari dd-asen, war ten mennɛem ca, minzi Tageldit n ijenwan i yinni am nitni.” \x ◘ \xo 19:14 \xt Mt. 18:3; 1 Kur. 14:20; 1 Bṭ. 2:2. \x*
\v 15 Issars xasen afus nnes uca iruḥ ssenni.
\b
\s1 Yasuɛ ak-d webřiɣ wenni d bab n wagřa
\m 
\v 16 Uca xzar, iqarreb-dd ijjen, inna as: “\add A\add* Amseɣɣar Aṣebḥan, min ɣa ggeɣ d aṣebḥan ḥima ad ɣari tiři Tudart ittduman?” \x ◘ \xo 19:16 \xt [Mk. 10:17-31; Lk. 18:18-30] \x*
\v 17 Inna as Yasuɛ: “Mayemmi d ayi třaɣid ‘Aṣebḥan’? War iǧi ḥed d aṣebḥan mɣir Ijjen, aqa-t d AREBBI. Maca mařa texsed ad tadfed ɣar Tudart, ṭṭef di tweṣṣa.”
\v 18 Inna as: “Man tina?” Inna as Yasuɛ: “War neqq, war zenni, war tticar, war cehhed s ẓur, \x ◘ \xo 19:18 \xt Uf. 20:12; Lawi 19:18; Aɛwd. 5:16-10; Rum. 13:9. \x*
\v 19 weqqar babac d yemmac uca ad texsed jjar nnec am yixef nnec.” \x ◘ \xo 19:19 \xt Lawi 19:17; Mt. 22:39; Mk. 12:31; Gal. 5:14; Yaɛ. 2:8. \x*
\v 20 Abřiɣ inna as: “Aqa ḍfareɣ timesřayin-a marra zi temẓi inu. Min d ayi ittxiṣṣen ɛad?”
\v 21 Yasuɛ inna as: “Mařa texsed ad tiřid tkemmřed, ruḥ, zenz marra min ɣarek, ewc i-t i imezřaḍ uca ad ɣarek yiři ijj n řkenz deg ijenwan. \add Xenni\add* as-dd, ḍfar ayi-dd.” \x ◘ \xo 19:21 \xt Mt. 6:19; Lk. 12:33; 16:9; 1 Tim. 6:19. \x*
\v 22 Řami isřa webřiɣ awař-a, iruḥ icḍen, minzi tuɣa ɣares aṭṭas n wagřa.
\m 
\v 23 \add Xas uca\add* inna Yasuɛ i imeḥḍaren nnes: “S tidett, Necc ad awem iniɣ, aqa yewɛar x bab n wagřa ad yadef ɣar Tgeldit n ijenwan. \x ◘ \xo 19:23 \xt Awřn. 11:28; Mk. 10:23; Lk. 18:24. \x*
\v 24 Uca Necc ad awem iniɣ ɛawed, aqa ihwen i weřɣem ad yekk zi tiṭṭ n tsineft x bu wagřa ad yadef ɣar Tgeldit n AREBBI.”
\v 25 Umi tt sřin imeḥḍaren nnes, nnxeřɛen, nnan: “Wi izemmaren xenni ad iṭṭef Tudart ɛad?”
\v 26 Am tuɣa daysen ixezzar Yasuɛ, inna asen: “Ɣar iwdan man aya war izemmar, maca ɣar AREBBI kuřci di tzemmar nnes!” \x ◘ \xo 19:26 \xt Ayub 42:2; Irm. 32:17; Zak. 8:6; Lk. 1:37; 18:27. \x*
\m 
\v 27 \add Xenni\add* yarra-dd Buṭrus, inna as: “Xzar, aqa neccin nejja kuřci, neḍfar i Cek. Min ɣarneɣ i ɣa yiřin?” \x ◘ \xo 19:27 \xt Mt. 4:20; Mk. 10:28; Lk. 5:11; 18:28. \x*
\v 28 Yasuɛ inna asen: “S tidett, Necc ad awem iniɣ, i kenniw inni d ayi dd-iḍfaren, aqa xmi ɣa tiři marra ddunect d jdid, xmi ɣa iqqim Mmis n bnadem x řɛarc n uɛuǧi nnes, aqa uřa d kenniw ad teqqimem x tenɛac n řekrasi igellden, ḥima ad tḥekmem x tenɛac n tqebbař n \add ayt n\add* Israil. \x ◘ \xo 19:28 \xt Lk. 22:30. \x*
\v 29 Kuř ijjen wenni isemḥen di tudrin niɣ deg aytmas niɣ di suyᵉtmas niɣ di babas niɣ deg yemmas niɣ di temɣart nnes d tarwa nnes uřa deg yeyyaren di ṭṭweɛ n Yisem inu, ad iksi mya n tseqqar uca ad iwart Tudart ittduman. \x ◘ \xo 19:29 \xt Aɛwd. 33:9; Ayub 42:12. \x*
\v 30 Maca aṭṭas n yinni iǧan d imezwura ad iřin d ineggura, uca ineggura ad iřin d imezwura.” \x ◘ \xo 19:30 \xt Mt. 20:16; Mk. 10:31; Lk. 13:30. \x*
\b
\b
\c 20
\s1 Amedya n ixemmasen deg umarjuɛ n uḍiř
\m 
\v 1 “Minzi Tageldit n ijenwan am yijj n bab n taddart, iffeɣ ɣar ṣṣbeḥ zic, ḥima ad icra ixemmasen i umarjeɛ nnes n uḍiř.
\v 2 Řami ikkes awař ak-d icewwařen s yijjen dinar i yijjen wass, issekk i-ten ɣar umarjeɛ nnes n uḍiř. \f ◼ \fr 20:2 \fk dinar\ft - di řweqt nni tuɣa řmunet i yijj n wass d ijj n dinar.\f*
\v 3 Řami dd-iffeɣ netta \add ɛawed\add* di jjwayeh n tsaɛɛet wiss třata, \add ixs ad yini ɣar tesɛa di ṣṣbeḥ\add*, iẓra inneɣni bedden di řmewqef břa řxedmet.
\v 4 Netta inna asen: ‘Ruḥem uřa d kenniw ɣar umarjeɛ \add inu\add* n uḍiř, ad awem wceɣ min d awem dd-ikkaren!’, uca ruḥen.
\v 5 Iffeɣ-dd ɛawed di jjwayeh n tsaɛɛet wiss setta d wiss tesɛa, uca igga amenni ɛawed.
\v 6 Řami dd-iffeɣ di jjwayeh n tsaɛɛet wiss hiṭɛac, \add ixs ad yini ɣar xemsa n tmeddit\add*, yufa din \add ɛawed\add* inneɣni bedden din břa řxedmet, inna asen: ‘Mayemmi tbeddem da ass ikmeř břa řxedmet?’
\v 7 Nnan as: ‘Minzi war d aneɣ icri ḥed.’ Inna asen: ‘Ruḥem uřa d kenniw ɣar umarjeɛ \add inu\add* n uḍiř, ad tᵉṭṭfem min d awem dd-ikkaren.’
\v 8 Řami dd-tiweḍ tmeddit, inna bab n umarjeɛ n uḍiř i uweqqaf nnes: ‘Řaɣa-dd x ixemmasen, xeǧeṣ asen řmunet, sizwar zeg \add inni dd-yusin d\add* ineggura uca ammu ař imezwura.’
\v 9 Uca usin-dd inni \add d icra\add* di jjwayeh n tsaɛɛet wiss ḥiṭac, uca kuř ijjen zzaysen iṭṭef ijjen dinar.
\v 10 Řami dd-usin inni tuɣa d imezwura, ittɣiř asen ad ṭṭfen ktar, \add maca\add* uřa d nitni ṭṭfen i kuř ijjen zzaysen ijj n dinar.
\v 11 Řami t ṭṭfen, aqa xeyyqen x bab n taddart,
\v 12 nnan: ‘Aqa ina d inni d ineggura xedmen ict n tsaɛɛet u cek tessemquded i-ten akidneɣ, neccin inni yarebbun ddqeř n wass d řeḥmu.’
\v 13 Maca netta yarra-dd x ijjen zzaysen, inna: ‘\add A\add* ameddukkeř inu, necc war cek ḍřimeɣ, ma war kidi tekkised awař x ijj n dinar?
\v 14 Ṭṭef min iǧan nnec uca uyur. Necc xseɣ ad wceɣ i ina d inni d ineggura anect min d ac wciɣ.
\v 15 Niɣ ma war ɣari bu řḥeqq maḥend ad ggeɣ min xseɣ ak-d min iǧan inu? Niɣ tiṭṭ nnec d taɛeffant, minzi necc d aṣebḥan?’
\m 
\v 16 Ammu i ɣa dewřen ineggura d imezwura, uca imezwura ad dewřen d ineggura, minzi aṭṭas inni ittwařaɣan, maca drus inni ittwafarzen.” \x ◘ \xo 20:16 \xt Mt. 19:30; 22:14; Mk. 10:31; Lk. 13:30. \x*
\b
\s1 Yasuɛ issawař x řmewt d tnukra nnes i twařa wiss třata
\m 
\v 17 Řami ikkar-dd Yasuɛ maḥend ad igeɛɛed ɣar Urcalim, yiwi tenɛac n imeḥḍaren nnes ɣar uɣezdis deg webrid, inna asen: \x ◘ \xo 20:17 \xt [Mk. 10:32-34; Lk. 18:31-34] — Lk. 24:7. \x*
\v 18 “Xzar, ad ngeɛɛed ɣar Urcalim, uca ad immewc Mmis n bnadem deg ifassen n imeqqranen n ikehhanen d imseřmaden n idlisen, u nitni ad xas ḥekmen s řmewt.
\v 19 Ad t sellmen i řegnus maḥend ad zzayes stehzan, ad t hettken s urekkuḍ uca ad t ṣellben, \add maca\add* deg wass wiss třata ad dd-ikkar.” \x ◘ \xo 20:19 \xt Mt. 27:2; Lk. 23:1; Yḥ. 18:28,31; Řex. 3:23. \x*
\b
\s1 Tutra n yemmas n Yaɛqub d Yuḥanna
\m 
\v 20 Řexdenni tusa-dd ɣares yemmas n tarwa n Zabdi ak-d iḥenjiren nnes, tesjed as, ḥima ad zzayes tᵉttar ca n řḥajjet. \x ◘ \xo 20:20 \xt [Mk. 10:35-45] \x*
\v 21 Inna as Netta: “Min texsed?” Tenna as nettat: “Ini maḥend ad qqimen tnayen n iḥenjiren-a inu, ijjen ɣar ufusi nnec u wenneɣni ɣar uzeřmaḍ nnec, di Tgeldit nnec.”
\v 22 Yasuɛ yarra-dd xasen, inna: “Kenniw war tessinem ca min tᵉttarem. Ma tzemmarem ad teswem řkas i ɣa sweɣ Necc, niɣ ad tᵉttwassɣeḍṣem s useɣḍeṣ i zi ɣa ttwassɣeḍṣeɣ Necc?” Nnan as: “Nzemmar!” \x ◘ \xo 20:22 \xt Mk. 10:38, 39; Lk. 12:50; Rum. 8:26. \x*
\v 23 Netta inna asen: “Řkas inu ad t teswem u aseɣḍeṣ i zi ɣa ttwassɣeḍṣeɣ, ad zzayes tᵉttwassɣeḍṣem, maca aɣimi ɣar ufusi inu d uzeřmaḍ inu war iǧi i Necc, maḥend ad t wceɣ, maca \add ad yiři\add* i yinni umi t issewjed Baba.” \x ◘ \xo 20:23 \xt Mt. 25:34. \x*
\m 
\v 24 Řami sřin ɛecra \add n imeḥḍaren\add* nneɣni man aya, xeyyqen aṭṭas x tnayen n wawmaten.
\v 25 Maca Yasuɛ iřaɣa-dd xasen ɣares, inna: “Kenniw aqa tessnem belli řḥukkam n řegnus ḥekkmen xasen uca uřa d imeqqranen nsen ttṣellaṭen xasen. \x ◘ \xo 20:25 \xt Mk. 10:42; Lk. 22:25. \x*
\v 26 War ittiři ammu jar awem, maca s řmeqřub: wenni ixsen ad yiři d ameqqran jar awem, ad yiři d amsexxar nwem, \x ◘ \xo 20:26 \xt 1 Bṭ. 5:3. \x*
\v 27 u wenni ixsen ad yiři d amezwaru jar awem, ad yiři d amsexxar nwem, \x ◘ \xo 20:27 \xt Mt. 23:11; Mk. 9:35; 10:43. \x*
\v 28 am mammec Mmis n bnadem war dd-yusi ḥima ad xas sexxaren, maca ḥima ad xasen isexxar uca ad iwc tudart nnes d aṣřaḥ i waṭṭas \add n yewdan\add*.” \x ◘ \xo 20:28 \xt Lk. 22:27; Yḥ. 13:14; Afa. 1:7; Fil. 2:7; 1 Tim. 2:6; 1 Bṭ. 1:19\x*
\b
\s1 Yasuɛ issgenfa tnayen n idarɣařen
\m 
\v 29 Řami dd-iffeɣ Yasuɛ zi Ariḥa, iḍfar i-t-i-dd aṭṭas n řɣaci. \x ◘ \xo 20:29 \xt [Mk. 10:46-52; Lk. 18:35-43] \x*
\v 30 Xzar, aqa din tnayen n idarɣařen qqimen x ṭṭarf n webrid, řami sřin belli Yasuɛ ad iɛdu, řaɣan, nnan: “A Sidi, Mmis n Dawud, arḥem aneɣ!”
\v 31 Maca řɣaci iziyyar xasen, ḥima ad sqaren. Maca nitni sɣuyen s jjehd ktar, nnan: “Arḥem aneɣ, \add a\add* Siditneɣ, Mmis n Dawud!”
\v 32 Xenni ibedd Yasuɛ, iřaɣa-dd xasen, inna: “Min texsem ad awem ggeɣ?”
\v 33 Nnan as nitni: “\add A\add* Siditneɣ, mařa texsed ad ttwarezment tiṭṭawin nneɣ.”
\v 34 Yasuɛ iḥinn xasen, xenni iḥada tiṭṭawin nsen. Řexdenni dewřent tiṭṭawin nsen ttwařant, uca nitni ḍfaren t-i-dd.
\b
\b
\c 21
\s1 Adaf n Yasuɛ ɣar Urcalim am ujeǧid
\m 
\v 1 Řami dd-qarrben ɣar Urcalim, iwḍen ɣar Bayt-Faji, ɣar uɣezdis n wedrar n Zzitun, issekk Yasuɛ tnayen n imeḥḍaren nnes, inna asen: \x ◘ \xo 21:1 \xt [Mk. 11:1-11; Lk. 19:28-38] — Yḥ. 12:12-19\x*
\v 2 “Ruḥem ɣar dcar nni qibač nwem. Deɣya ad tafem ict n teɣyuč teqqen d ijj n wesnus akides. Fesyem asen, tawyem ten-dd ɣari.
\v 3 Mařa inna awem ḥed ca, arrem xas ammu: ‘Aqa Siditneɣ iḥdaj i-ten. Netta ad ten dd-yarr deɣya.’”
\v 4 Man aya qaɛ imsar, ḥima ad ittwakemmeř marra min ittwannan zeg unabi am inna:
\b
\m 
\v 5 \qt “Inim i yeǧis n Ṣihyun:\qt*
\m \qt ‘Xzar, Ajeǧid nnem\qt*
\m \qt ad ɣarem dd-yas s uwaḍeɛ,\qt*
\m \qt yenya x weɣyuř d wesnus,\qt*
\m \qt aqa d mmis n teɣyuč.”\qt* \x ◘ \xo 21:5 \xt 1 Ij. 1:38-40; Ica. 62:11; Zak. 9:9; Yḥ. 12:15. \x*
\b
\m 
\v 6 Ruḥen imeḥḍaren uca ggin am mammec ten yumur Yasuɛ.
\v 7 Iwyen-dd aɣyuř d wesnus, sarsen arruḍ nsen x wesnus uca inya xas Yasuɛ. \x ◘ \xo 21:7 \xt 2 Ij. 9:13; Yḥ. 12:14. \x*
\v 8 Aṭṭas zi řɣaci ssun arruḍ nsen deg webrid u inneɣni qessen řefruɛ zi tcejjura, nḍaren ten deg webrid.
\v 9 Uca abarru n řɣaci nni d as izwaren d yinni i-t-i-dd iḍfaren, tuɣa sɣuyyun, nnan:
\b
\m \qt “Uṣanna i Mmis n Dawud!\qt*
\m \qt Lbaraka i Wenni dd-yusin s Yisem n SIDI.\qt*
\m \qt Uṣanna, di řuɛřa x řuɛřa \tl n ijenwan\tl*.”\qt* \x ◘ \xo 21:9 \xt Izhd. 118:25, 26; Mk. 11:9, 10; Yḥ. 12:13\x*
\b
\m 
\v 10 Řami yudef ɣar Urcalim, thaj tendint qaɛ, \add iwdan\add* nnan: “Min iɛna Wa?”
\v 11 Řɣaci inna: “D Wa d Anabi Yasuɛ zi Nnaṣira di Ljalil.”
\b
\s1 Yasuɛ di Zzawect Tameqqrant
\m 
\v 12 Yudef Yasuɛ ɣar Zzawect Tameqqrant n AREBBI, issuffeɣ marra inni izznuzan d yinni issaɣen di Zzawect Tameqqrant uca iqřeb ṭṭwabeř n iṣarrafen \add n tenɛacin\add* d řekrasi n yinni izznuzan idbiren. \x ◘ \xo 21:12 \xt [Mk. 11:15-19; Lk. 19:45-48; Yḥ. 2:13-22] — Aɛwd. 14:26\x*
\v 13 Inna asen: “Aqa tura: ‘Taddart inu ad tᵉttwasemma ‘Taddart n tẓaǧit’, maca kenniw tarrim tt d ifri n iceffaren.’” \x ◘ \xo 21:13 \xt 1 Ij. 8:29; Ica. 56:7; Irm. 7:11; Lk. 19:46. \x*
\v 14 Iwyen-dd ɣares di Zzawect Tameqqrant idarɣařen d ineɛḍaben uca issgenfa ten.
\v 15 Umi ẓrin imeqqranen n ikehhanen d imseřmaden n idlisen lmuɛjizat i yegga u aqa iḥenjiren ttřaɣan di Zzawect Tameqqrant, qqaren: “Uṣanna i Mmis n Dawud!”, xeyyqen aṭṭas,
\v 16 nnan as: “Ma tesřid min qqaren yina?” Inna asen Yasuɛ: “Wah, ma war teɣrim ɛemmarṣ: ‘Zeg iqemmumen n iḥenjiren d iseyman tesswejded Cek ttesbiḥ’?” \x ◘ \xo 21:16 \xt Izhd. 8:3. \x*
\v 17 Řexdenni ismeḥ daysen, iffeɣ barra i tendint ɣar Bayt-Ɛanya, insa din.
\b
\s1 Artu yuẓɣen
\m 
\v 18 Ɣar ṣṣbeḥ zic řami dd-idweř ɣar tendint, tuɣa dayes řaẓ. \x ◘ \xo 21:18 \xt [Mk. 11:12-14; 20-24] \x*
\v 19 Iẓra ijj n wartu x webrid, iruḥ ɣares, war dayes yufi mɣir tifray waha. \add Xenni\add* inna \add i wartu\add*: “War zzayek tteffeɣ řɣiǧet ɛemmarṣ.” Řexdenni yuẓeɣ wartu deɣya. \x ◘ \xo 21:19 \xt Ḥuc. 9:10\x*
\v 20 Umi ẓrin imeḥḍaren man aya, tbehten, nnan: “Mammec igga wartu yuẓeɣ deɣya?”
\v 21 Yasuɛ yarra-dd, inna asen: “S tidett Necc ad awem iniɣ: Mařa daywem l’iman u war tcekkim ca, aqa war tᵉtteggem min imsaren i wartu waha, maca ɛawed mařa tennam i wedrar-a: ‘Meksi, wḍa di řebḥar!’, ad yiři. \x ◘ \xo 21:21 \xt Mt. 17:20; Lk. 17:6. \x*
\v 22 D qaɛ min ɣa tᵉttarem di tẓaǧit s l’iman, ad \add t\add* tᵉṭṭfem.” \x ◘ \xo 21:22 \xt Mt. 7:7; Mk. 11:24; Lk. 11:9; Yḥ. 14:13; 16:24; Yaɛ. 1:5; 1 Yḥ. 3:22. \x*
\b
\s1 Aseqsi x ttesriḥ n Yasuɛ
\m 
\v 23 Řami yudef ɣar Zzawect Tameqqrant, usin-dd ɣares imeqqranen n ikehhanen d imɣaren n řgens am tuɣa isseřmad, nnan: “S man ṣṣulṭa i teggid timesřayin-a? Wi d ac iwcin ṣṣulṭa-ya?” \x ◘ \xo 21:23 \xt [Mk. 11:27-33; Lk. 20:1-8] — Uf. 2:14; Řex. 4:7; 7:2. \x*
\v 24 Yasuɛ yarra-dd, inna asen “Uřa d Necc ad kenniw sseqsiɣ ijj n useqsi u mařa tarrim-dd xafi uřa d Necc ad awem iniɣ s man ṣṣulṭa i tteggeɣ timesřayin-a.
\v 25 Aseɣḍaṣ n Yuḥanna, manis netta? Zeg ujenna niɣ zeg iwdan?” Mcawaren nitni jar asen, nnan: “Mařa nenna: ‘Zeg ujenna!’, ad aneɣ ini: ‘Mayemmi war zzayes tuminem?’,
\v 26 u mařa nenna: ‘Zeg iwdan!’, xenni dayneɣ tiggʷudi zi řɣaci, minzi marra ḥessben Yuḥanna d anabi.” \x ◘ \xo 21:26 \xt Mt. 14:5; Mk. 6:20. \x*
\v 27 Arrin-dd, nnan: “War nessin.” Inna asen Netta: “Xenni uřa d Necc war d awem qqareɣ s man ṣṣulṭa i tteggeɣ man aya.”
\b
\s1 Amedya n tnayen n wawmaten
\m 
\v 28 “Min d awem ittɣiř kenniw? Ijj n weryaz tuɣa ɣares tnayen n iḥenjiren. Iřaɣa x umezwaru, inna: ‘\add A\add* mmi, uyur, ass-a ad txedmed deg umarjeɛ n uḍiř!’
\v 29 Netta yarra-dd, inna: ‘Necc war xseɣ ca!’, maca awarni man aya indem uca iruḥ din.
\v 30 Uca yusa-dd netta ɣar wenni wiss tnayen, inna as amenni beɛda. Wanita yarra-dd xas: ‘Wah, a sidi!’, \add maca\add* war iruḥ ca!
\v 31 Man wen zzaysen i iggin řxaḍar i babas?” Nitni arrin-dd xas: “Wenni d amezwaru.” Yasuɛ inna asen: “S tidett, Necc ad awem iniɣ, aqa ayt n ḍḍariba d temɣarin n farq-ccɣeř ad awem izwaren ɣar Tgeldit n AREBBI.
\v 32 Minzi Yuḥanna yusa-dd ɣarwem deg webrid n tsegda, kenniw war zzayes tuminem, maca ayt n ḍḍariba d temɣarin n farq-ccɣeř aqa nitni umnen zzayes. Řami teẓrim man aya, war tᵉtubem ca ɣar uneggaru, maḥend ad zzayes tamnem.” \x ◘ \xo 21:32 \xt Mt. 3:1. \x*
\b
\s1 Amedya n ixemmasen deg umarjuɛ n tzayart
\m 
\v 33 “Sřem \add ɛawed\add* i yijj n umedya nneɣni. Tuɣa din ijj n weryaz, bab n taddart, igga ijj n umarjeɛ n uḍiř, iẓẓu dayes tizayarin. Netta iquwwar as-dd s yijj n wefray, iɣza dayes tasirt n uḍiř uca ibna dayes ict n ṣṣumɛet. Xenni yarhen \add amarjeɛ nni n uḍiř\add* i ca n ixemmasen uca isafar. \x ◘ \xo 21:33 \xt [Mk. 12:1-12; Lk. 20:9-19] — Izhd. 80:9; Ica. 5:1-7; Irm. 2:21; 12:10; \x*
\v 34 Umi dd-tiweḍ řweqt \add n ṣṣabet\add* n řɣiǧet, issekk imsexxaren nnes ɣar ixemmasen \add nni\add* ḥima ad dd-awyen řɣiǧet nnes.
\v 35 Ixemmasen ṭṭfen imsexxaren nnes, wtin ijjen, nɣin nneɣni uca arejmen \add ɛawed\add* ijjen nneɣni. \x ◘ \xo 21:35 \xt 2 Im. 24:21. \x*
\v 36 Ɛawed issekk imsexxaren nneɣni, ktar zeg umezwaru, uca ggin daysen ɛawed amenni.
\v 37 Ɣar uneggar issekk asen-dd mmis, inna: ‘Nican ad weqqaren mmi’.
\v 38 Maca řami ẓrin ixemmasen mmis, nnan jar asen: ‘Aqa d awrit, zidem, ad t neneɣ, ad as nekkes řwart i neccin.’ \x ◘ \xo 21:38 \xt Amz. 37:17; Izhd. 2:1, 8; Mt. 26:3; 27:1; Yḥ. 11:53; Ɛbr. 1:2. \x*
\v 39 Ṭṭfen t, nḍaren t barra i umarjeɛ n uḍiř uca nɣin t.
\v 40 Mařa yusa-dd bab n umarjeɛ nni, min ɣa yegg deg ixemmasen nni?”
\v 41 Nnan as: “Ad yareddeǧ iɛeffanen nni qaɛ, uca ad iwc amarjeɛ n uḍiř i ixemmasen nneɣni inni d as i ɣa iwcen řɣiǧet di řweqt nnes.”
\v 42 Yasuɛ inna asen: “Ma war teɣrim ɛemmarṣ deg idlisen:
\b
\m \qt ‘Aẓru i iɛiffen ibennayen,\qt*
\m \qt aqa idweř d \tl aẓru\tl* Azeǧif n teɣmart.\qt*
\m \qt Wa yusa-dd zi SIDI\qt*
\m \qt u man aya d řeɛjeb di tiṭṭawin nneɣ.’\qt* \x ◘ \xo 21:42 \xt Izhd. 118:22-23; Ica. 8:14; 28:16; Mk. 12:10; Lk. 20:17; Řex. 4:11; Rum. 9:33; 1 Bṭ. 2:6. \x*
\b
\m 
\v 43 S uyenni ad awem iniɣ, belli Tageldit n AREBBI ad awem tᵉttwakkes uca ad temmewc i yijj n řgens i ɣa iwcen řɣiǧet nnes. \x ◘ \xo 21:43 \xt Uf. 32:10; Ica. 55:5; Mt. 8:12. \x*
\v 44 Wi ɣa iwḍan x weẓru-ya, ad ittwařbez, u wi xef i ɣa iwḍa, ad t iřbez.” \x ◘ \xo 21:44 \xt Ica. 8:15; Dan. 2:34; Zak. 12:3; Lk. 20:18. \x*
\m 
\v 45 Řami sřin imeqqranen n ikehhanen d Ifarisiyyen imedya nnes, fehmen belli issawař xasen. \x ◘ \xo 21:45 \xt Lk. 20:19. \x*
\v 46 Arezzun ad t ṭṭfen, \add maca\add* ggʷeden zi řɣaci, minzi \add řɣaci\add* tuɣa iḥesseb i-t d ijj n unabi. \x ◘ \xo 21:46 \xt Lk. 7:16; Yḥ. 7:40. \x*
\b
\b
\c 22
\s1 Amedya x inni ittwaɛarḍen ɣar wurar
\m 
\v 1 Iṭṭef Yasuɛ ɛawed deg wawař uca issiweř akidsen ɛawed s imedya, inna: \x ◘ \xo 22:1 \xt [Lk. 14:15-24] \x*
\v 2 “Tageldit n ijenwan am yijj n weryaz, ijj n ujeǧid, igga urar i mmis. \x ◘ \xo 22:2 \xt Lk. 14:6; Asa. 19:7. \x*
\v 3 Issekk-dd imsexxaren nnes ḥima ad řaɣan x yinni ittwaɛarḍen ɣar wurar, \add maca\add* ugin ad dd-asen.
\m 
\v 4 Ɛawed issekk-dd imsexxaren nneɣni, inna: ‘Inim i yinni ittwaɛarḍen: Aqa sswejdeɣ awem amecři, ɣarṣeɣ i iyenduzen inu d řmař inu iṣeḥḥen, aqa marra iwjed, asem-dd ɣar wurar!’”
\v 5 Nitni maca war wcin ca taynit i man aya, ruḥen, ijjen ɣar řeɛraṣi nnes u wenneɣni ɣar ttijara nnes.
\v 6 Inni iqqimen ṭṭfen imsexxaren nnes, ɣezzan daysen uca nɣin \add ten\add*.
\m 
\v 7 \add Řami\add* isřa ujeǧid man aya, ixeyyeq aṭṭas, issekk-dd řɛeskar nnes uca yareyyeb iqettařen nni uca issecmeḍ tandint nsen.
\v 8 Xenni inna i imsexxaren nnes: ‘Aqa urar iwjed maca inni tuɣa ittwaɛarḍen war t sdihiǧen ca.
\v 9 S uya uyurem ɣar mani ttemsebḍan ibriden, řaɣam-dd x marra inni i ɣa tafem din ɣar wurar.’
\m 
\v 10 \add Xenni\add* ffɣen-dd imsexxaren nni ɣar ibriden uca ssmunen marra inni ufin, am yiṣebḥanen am yiɛeffanen, uca taddart n wurar tedweř teccur s \add inewjiwen\add* i iqqimen dinni.
\v 11 Řami dd-yudef ujeǧid, maḥend ad iẓar \add inewjiwen\add* nni iqqimen dinni, iḥekkar i yijj n bnadem war yarḍ ca arruḍ n wurar.
\v 12 Inna as: ‘\add A\add* ameddukkeř inu, mammec dd-tudfed danita břa arruḍ n wurar?’ Maca netta idweř ignu.
\v 13 Xenni inna ujeǧid i imsexxaren: ‘Carfem t s ifassen d iḍaren uca nḍarem t barra ɣar uneggar n taǧest mani ɣa iřin imeṭṭawen d uɣezzi n teɣmas.’ \x ◘ \xo 22:13 \xt Mt. 8:12; 13:42; 24:51; 25:30; Lk. 13:28. \x*
\v 14 Minzi aqa din aṭṭas inni ittwařaɣan maca drus inni ittwafarzen.” \x ◘ \xo 22:14 \xt Mt. 20:16. \x*
\b
\s1 Aseqsi x ḍḍariba i qayṣar
\m 
\v 15 Xenni ruḥen Ifarisiyyen, mcawaren mammec ad as ggen ijj n řfex di ssibbet n wawař\add en\add* nnes. \x ◘ \xo 22:15 \xt [Mk. 12:13-17; Lk. 20:20-26] \x*
\v 16 Ssekken ɣares imeḥḍaren nsen ak-d inni zi taddart n Hirudus, nnan: “\add A\add* Amseɣɣar, aqa nessen belli Cek d tidett, tesseřmaded abrid n AREBBI s tidett, nhřa ma tesseřqid uřa x yijj, minzi Cek war tᵉttegged s wudmawen.
\b
\m 
\v 17 Iwa ini aneɣ mammec i twařid Cek: Ma iḥeqq \add ɛlaḥsab Ccariɛa\add* ad tᵉttwaxeǧeṣ ḍḍariba i qayṣar niɣ lla?”
\v 18 Maca Yasuɛ issen taḥraymect nsen uca inna: “Mayemmi d ayi tᵉttjarrabem, \add kenniw, a\add* imnafqen?
\v 19 Seccnem ayi \add ijj n uqiyya n\add* dinar n ḍḍariba x kuř azeǧif!” Iwyen as-dd ijj n dinar.
\v 20 Xenni inna asen: “Wi yiřan taṣwirt-a d tira-ya?” \x ◘ \xo 22:20 \xt Mk. 12:16; Lk. 20:24\x*
\v 21 Nnan as: “N qayṣar!” Xenni inna asen: “Wcem i qayṣar min iǧan i qayṣar u i AREBBI min iǧan i AREBBI.” \x ◘ \xo 22:21 \xt Mt. 17:25; Rum. 13:7. \x*
\v 22 Řami sřin man aya, tbehten, semḥen dayes uca ruḥen.
\b
\s1 Aseqsi n Iṣaduqiyyen x tnukra
\m 
\v 23 Deg wass nni usin-dd ɣares Iṣaduqiyyen, qqaren as: ‘Aqa war din bu tudart \add i\add* imettinen!’, uca sseqsan t, \x ◘ \xo 22:23 \xt [Mk. 12:18-27; Lk. 20:27-40] — Řex. 23:8. \x*
\v 24 nnan as: “\add A\add* Amseɣɣar, Musa aqa inna: ‘Mařa immut ḥed war dd-yejji bu tarwa, ittxeṣṣa i umas ad imřec ak-d temɣart nnes ad kides dd-yejj aḥenjir i umas.’ \x ◘ \xo 22:24 \xt Aɛwd. 25:5-6; Amz. 38:8. \x*
\v 25 Tuɣa ɣarneɣ sebɛa n wawmaten. Amezwaru imřec, immut. Umi war dd-yejji ca tarwa, aqa ijja tamɣart nnes i umas.
\v 26 Ammu \add i immut\add* uřa d wenni wiss tnayen d wiss třata ař wenni wiss sebɛa.
\v 27 Ɣar uneggaru nsen marra temmut temɣart.
\v 28 I man wen zzaysen i ɣa tiři temɣart di tnukra, minzi nitni marra iwyen tt d tamɣart?”
\m 
\v 29 Yasuɛ yarra-dd, inna asen: “Aqa kenniw tweddarem, minzi war tessinem ca Tira \add Iqeddsen\add* uřa d jjehd n AREBBI.
\v 30 Minzi di tnukra war ttiwyen nitni timɣarin, u timɣarin war ttiřint i yeryazen, maca ad iřin am lmalakat n AREBBI deg ujenna.
\v 31 \add Maca\add* zi jjihet n tnukra jar imettinen, ma war teɣrim ca min d awem inna AREBBI i iqqaren:
\v 32 ‘Aqa Necc d AREBBI n Ibrahim, AREBBI n Isḥaq, AREBBI n Yaɛqub!’ AREBBI war iǧi d AREBBI n imettinen maca n yinni iddaren.” \x ◘ \xo 22:32 \xt Uf. 3:6, 15. \x*
\v 33 Řami sřin řɣaci man aya, tbehten deg useřmed nnes. \x ◘ \xo 22:33 \xt Mt. 7:28. \x*
\b
\s1 Tawṣeyyet tameqqrant
\m 
\v 34 Řami sřin Ifarisiyyen belli Netta ibelleɛ aqemmum n Iṣaduqiyyen, munen jar asen. \x ◘ \xo 22:34 \xt [Mk. 12:28-34; Lk. 10:25-28] \x*
\v 35 Ijjen zzaysen, ijjen wenni issnen Ccariɛa \add mliḥ\add*, isseqsa t ḥima ad t ijarreb: \x ◘ \xo 22:35 \xt Lk. 10:25. \x*
\v 36 “\add A\add* Amseɣɣar, man tawṣeyyet i iǧan d tameqqrant di Ccariɛa?”
\v 37 Inna as Yasuɛ: “Ad texsed SIDI, AREBBI nnec, s marra wuř nnec, s marra řeɛmar nnec, s marra jjehd nnec u s marra řeɛqeř nnec. \x ◘ \xo 22:37 \xt Aɛwd. 6:5; 10:12; 30:6; Mk. 12:30, 33; Lk. 10:27. \x*
\v 38 D ta d tawṣeyyet tameqqrant d tamezwarut.
\v 39 Tenni wiss tnayen tarwes dayes, aqa nettat: ‘Ad texsed jjar nnec amecnaw ixef nnec’. \x ◘ \xo 22:39 \xt Lawi 19:18; Mk. 12:31; Rum. 13:9; Gal. 5:14; Afa. 5:2; 1 Ts. 4:9; Yaɛ. 2:8. \x*
\v 40 X tnayen n tweṣṣa-ya tᵉttwabna marra Ccariɛa d Inabiyyen.”
\b
\s1 Yasuɛ isseqsa Ifarisiyyen x mmis n Dawud
\m 
\v 41 Am tuɣa munen Ifarisiyyen, isseqsa ten Yasuɛ, \x ◘ \xo 22:41 \xt [Mk. 12:35-37; Lk. 20:41-44] \x*
\v 42 inna: “Min teqqarem x Lmasiḥ? Umi igga mmis?” Nnan as: “Mmis n Dawud!”
\v 43 Inna asen: “Mammec i ɣa yegg Dawud ad as isemma zi Arruḥ ‘SIDI’, am iqqar:
\v 44 ‘SIDI inna i Sidi inu: Qqim-dd x ufusi inu ař ɣa ggeɣ řɛedyan nnec sadu iḍaren nnec.’ \x ◘ \xo 22:44 \xt Izhd. 110:1; Řex. 2:34; 1 Kur. 15:25; Ɛbr. 1:13; 10:13. \x*
\v 45 Mařa Dawud iřaɣa as ‘SIDI’, mammec ɣa yiři d mmis?”
\v 46 Uřa d ijjen war izemmar ad xas dd-yarr u uřa d ijj war iqqim izeɛɛem ittseqsa t \add ca\add* ɛad zeg wass nni.
\b
\b
\c 23
\s1 Awařen iqesḥen x Imseřmaden n Ccariɛa d Ifarisiyyen
\m 
\v 1 Řexdenni issiweř Yasuɛ ak-d řɣaci u ak-d imeḥḍaren nnes, \x ◘ \xo 23:1 \xt [Mk. 12:38-40; Lk. 11:37-52; 13:34-35; 20:45-47] \x*
\v 2 inna: “Imseřmaden n idlisen d Ifarisiyyen ssɣimen simant nsen x řkursi n Musa. \x ◘ \xo 23:2 \xt Naḥ. 8:4\x*
\v 3 S uya marra min d awem qqaren maḥend ad dayes tcebbarem, ggem t, maca war tteggem ɛlaḥsab řexdayem nsen, minzi nitni waxxa qqaren \add t\add*, war \add t\add* tteggen. \x ◘ \xo 23:3 \xt Aɛwd. 17:19; Mal. 2:6; Rum. 2:19. \x*
\v 4 Ttceddan řeḥmeř iḍeqřen, ssrusan ten x tɣardin n iwdan, maca nitni s yixef nsen war xsen ad ten ssenhezzen uřa s yijj n uḍaḍ. \x ◘ \xo 23:4 \xt Ica. 10:1; Lk. 11:46; Řex. 15:10. \x*
\v 5 Marra řexdayem nsen i itteggen, tteggen tent ḥima ad ten ẓaren iwdan minzi nitni tteggen tiḥezzanin nsen n tẓaǧit d imiriwen uca ticrurin \add i iǧan ɣar ubeḥřuř\add* n řkacni n tẓaǧit nsen, ggin tent d timeqqranin. \x ◘ \xo 23:5 \xt Řxř. 15:38; Aɛwd. 6:8; 22:12; Mt. 6:5. \x*
\v 6 Nitni ttexsen imucan iṣebḥen ɣar řefruḥ u řekrasi iṣebḥen di temzidawin, \x ◘ \xo 23:6 \xt Mk. 12:38,39; Lk. 11:43; 20:46. \x*
\v 7 uřa d ssřam di řeswaq, uca iɛjeb asen ad asen řaɣan iwdan ‘\add A\add* amseřmad inu!’ \x ◘ \xo 23:7 \xt Yaɛ. 3:1. \x*
\v 8 Maca kenniw war ttejjim ad awem řaɣan ‘\add A\add* amseřmad inu!’, minzi Amseřmad nwem d Ijjen, maca kenniw marra d awmaten.
\v 9 War ttejjim ad awem řaɣan di temmurt ‘\add A\add* baba!’, minzi Babatwem i iǧan deg ijenwan d Ijjen. \x ◘ \xo 23:9 \xt Mal. 1:6. \x*
\v 10 War ttejjim ad awem řaɣan ‘imgewwaden’, minzi Ijjen d wenni d Amgewwad nwem, aqa-t d Lmasiḥ.
\v 11 Maca ameqqran nwem ad yiři d amsexxar nwem. \x ◘ \xo 23:11 \xt Mt. 20:26. \x*
\v 12 Wenni i ɣa issuɛřan ixef nnes, ad ittwassemẓi, u wenni i ɣa issmeẓyen ixef nnes, ad ittwassuɛřa.” \x ◘ \xo 23:12 \xt Ayub 22:29; Awřn. 29:23; Lk. 14:11; 18:14; Yaɛ. 4:6, 10; 1 Bṭ. 5:5. \x*
\b
\m 
\v 13 \bd “Uct xawem\bd*, \add a kenniw\add* imseřmaden n idlisen d Ifarisiyyen, \add kenniw, a\add* imnafqen, kenniw tᵉttettem tudrin n tijjař am tᵉttarem tiwhibin di ṭṭweɛ n tẓaǧatin nwem tizirarin. S uyenni ad teksim řḥukm d ameqqran. \x ◘ \xo 23:13 \xt Lk. 11:52. \x*
\m 
\v 14 \bd Uct xawem\bd*, \add a kenniw\add* imseřmaden n idlisen d Ifarisiyyen, \add kenniw, a\add* imnafqen, kenniw tᵉttbellɛem Tageldit n ijenwan i iwdan, minzi kenniw simant nwem war tt tᵉttidfem, uca inni yarezzun ad dd-adfen, war ten tᵉttejjim ad dd-adfen. \x ◘ \xo 23:14 \xt Mk. 12:40; Lk. 20:47; 2 Tim. 3:6; Tit. 1:11. \x*
\m 
\v 15 \bd Uct xawem\bd*, \add a kenniw\add* imseřmaden n idlisen d Ifarisiyyen, \add kenniw, a\add* imnafqen, kenniw tekkem x řbarr u x řebḥar, ḥima ad dd-tarrem ijjen d amɛacar n ddin n Wudayen, u xmi i kidwem ɣa yiři, tᵉttarram t d mmis n jᵉhennama d aɛeffan mahu x kenniw tnayen n tseqqar.
\m 
\v 16 \bd Uct xawem\bd*, \add a kenniw\add* imgewwaden idarɣařen, inni iqqaren: ‘Wenni ijjuǧen ɣar Zzawect Tameqqrant, aqa tajaǧit nnes war tessekkwi walu, maca wenni i ɣa ijjuǧen s wureɣ i iǧan di Zzawect Tameqqrant, aqa netta iqqen ɣar iřes nnes.’
\v 17 \add A\add* ifɣař, \add a\add* idarɣařen, min isekkwan ktar, ureɣ niɣ Zzawect Tameqqrant tenni tessqeddes ureɣ?
\v 18 Uca \add ammu i teqqarem ɛawed\add*: ‘Wenni ijjuǧen ɣar uɛalṭar, aqa tajaǧit nnes war tsekkwi walu, maca wenni i ɣa ijjuǧen s tmewci i xas immarsen, aqa netta iqqen ɣar iřes nnes.’
\v 19 \add A\add* ifɣař, \add a\add* idarɣařen, min isekkwan ktar, tamewci niɣ aɛalṭar wenni issqeddes tamewci?
\v 20 S uya wi ɣa ijjaǧen \add xenni\add* ɣar uɛalṭar, aqa ijjuǧ ɣar uɛalṭar u ɣar marra min xas iǧan.
\v 21 U wi ɣa ijjaǧen ɣar Zzawect Tameqqrant, ijjuǧ ɣares u ɣar Wenni dayes izeddɣen. \x ◘ \xo 23:21 \xt 1 Ij. 8:13; 2 Im. 6:1, 2. \x*
\v 22 U wi ɣa ijjaǧen ɣar ujenna, aqa ijjuǧ ɣar řɛarc n AREBBI d Wenni xas iqqimen. \x ◘ \xo 23:22 \xt 2 Im. 6:33; Ica. 66:1; Mt. 5:34; Řex. 7:49. \x*
\m 
\v 23 \bd Uct xawem\bd*, \add a kenniw\add* imseřmaden n idlisen d Ifarisiyyen, \add kenniw, a\add* imnafqen, minzi kenniw tᵉtticem taɛcart n nneɛnaɛ d ssanuǧ d řcemmum, maca war d awem icqi min iǧan d ameqqran di Ccariɛa, aqa řḥukm d arreḥmet d l’iman. Ina i ittxeṣṣa ad teggem, war daysen tsemmḥem. \x ◘ \xo 23:23 \xt 1 Ṣm. 15:22; Ḥuc. 6:6; Mixa 6:8; Mt. 9:13; 12:7; Lk. 11:42. \x*
\v 24 A imgewwaden idarɣařen inni ifarrnen tizit, \add maca\add* tessɣeǧayem ařɣem.
\m 
\v 25 \bd Uct xawem\bd*, \add a kenniw\add* imseřmaden n idlisen d Ifarisiyyen, \add kenniw, a\add* imnafqen, minzi tessizdagem barra n řkas d ṭṭebṣi, maca ɣar daxeř aqa ccuren s tkeccaḍt d min war iseggden. \x ◘ \xo 23:25 \xt Lk. 11:39. \x*
\v 26 \add A\add* Ifarisiyyen idarɣařen, sizdegem amezwar daxeř n řkas d ṭṭebṣi, maḥend ad yiři izdig uřa min iǧan ɣar barra nsen. \x ◘ \xo 23:26 \xt Tit. 1:15. \x*
\m 
\v 27 \bd Uct xawem\bd*, \add a kenniw\add* imseřmaden n idlisen d Ifarisiyyen, \add kenniw, a\add* imnafqen, minzi teggim am yimeḍřan inni ittwajiyyaren, ttbanen d iṣebḥanen ɣar barra, maca ɣar daxeř aqa ccuren s iɣsan n řxecbat u s marra řexmej. \x ◘ \xo 23:27 \xt Řex. 23:3. \x*
\v 28 Amenni kenniw ɛawed, aqa teḍharem d imseggaden qibač i iwdan, maca ɣar daxeř aqa teccurem s řmuɛṣiyyet u s nnifaq.
\m 
\v 29 \bd Uct xawem\bd*, \add a kenniw\add* imseřmaden n idlisen d Ifarisiyyen, \add kenniw, a\add* imnafqen, minzi tbennam imeḍřan n inabiyyen u tzewwqem řqubbat n imeḍřan n imseggaden, \x ◘ \xo 23:29 \xt Lk. 11:47. \x*
\v 30 teqqarem: ‘Mři tuɣa neǧa deg wussan n řejdud nneɣ, ad yiři war ncarrec deg \add usizzeř n\add* idammen n inabiyyen.’
\v 31 S uya tcehhdem x yixef nwem belli kenniw d tarwa n yinni inɣin inabiyyen. \x ◘ \xo 23:31 \xt Řex. 7:51; 1 Ts. 2:15. \x*
\v 32 \add Iwa\add* kemmřem kenniw \add xenni\add* uřa řeqyas n \add min ggin\add* řejdud nwem!
\v 33 A iřefsawen, tarwa n ifiɣran, mammec ɣa teggem ad tᵉttwassnejmem zi řḥukm \add n tmessi\add* n jᵉhennama? \x ◘ \xo 23:33 \xt Mt. 3:7. \x*
\v 34 S uyenni xzarem, Necc ad ɣarwem dd-ssekkeɣ inabiyyen d imiɣisen d imseřmaden n idlisen. Ca zzaysen ad ten tenɣem, ca zzaysen ad ten tṣellbem u ca zzaysen ad ten thettkem s urekkuḍ di temzidawin nwem uca ad xasen taẓẓřem zi tendint ɣar tendint \add nneɣni\add*, \x ◘ \xo 23:34 \xt Mt. 10:16, 17; Lk. 10:3; 11:49; Yḥ. 16:2; Řex. 7:52. \x*
\v 35 ařami ad xawem iřin marra idammen iseggden i issizzřen x temmurt, zeg idammen n Habil amseggad ař idammen n Zakariyya, mmis n Birixya, i tenɣim jar Zzawect Tameqqrant d uɛalṭar. \x ◘ \xo 23:35 \xt Amz. 4:8; 2 Im. 24:21; Ɛbr. 11:4. \x*
\v 36 S tidett, Necc ad awem iniɣ: Marra timesřayin-a ad dd-asent x jjiř-a.”
\b
\m 
\v 37 “\add A\add* Urcalim, \add a\add* Urcalim, cem i ineqqen inabiyyen u yarejjmen inni d am dd-ittwassekken, mecḥař tuɣa xseɣ ad ssmuneɣ tarwa nnem am yict n tyaẓiḍt tegga ifiǧusen nnes sadu afriwen nnes, \add maca\add* kenniw tuɣa war tᵉttexsem. \x ◘ \xo 23:37 \xt Izhd. 17:8; 91:4; Mt. 21:35,36; \x*
\v 38 Xzar, Taddart nwem ad tᵉttwajj i cem d řxarbet, \x ◘ \xo 23:38 \xt Izhd. 69:26; Ica. 1:7; Irm. 7:34; Mixa 3:12; Řex. 1:20. \x*
\v 39 minzi Necc ad awem iniɣ: Kenniw war d ayi tẓarrem ař ɣa tinim: ‘Lbaraka i Wenni dd-yusin s Yisem n SIDI.’” \x ◘ \xo 23:39 \xt Izhd. 118:26. \x*  *
\b
\b
\c 24
\s1 Awař n Yasuɛ x tuqqat n ddunect
\m 
\v 1 \add Xenni\add* iffeɣ Yasuɛ zi Zzawect Tameqqrant maḥend ad yuyur, \add maca\add* usin-dd ɣares imeḥḍaren nnes, ssecnen as řebniyyat n Zzawect Tameqqrant. \x ◘ \xo 24:1 \xt [Mk. 13:1-37; Lk. 12:41-48; 17:26-30; 34-36; 21:5-33] \x*  *
\b
\m 
\v 2 Netta inna asen: “Ma war teẓrim marra man aya? S tidett, Necc ad awem iniɣ: War da ittɣimi uřa d ijj n weẓru x weẓru nneɣni i war ittnehdim.” \x ◘ \xo 24:2 \xt 1 Ij. 9:7, 8; Mixa 3:12; Lk. 19:44. \x*
\m 
\v 3 Umi tuɣa Yasuɛ iqqim x wedrar n Zzitun, usin-dd imeḥḍaren nnes, tuɣa ttemsawařan, nnan as: “Ini aneɣ, meřmi i ɣa imsar aya u man řeɛřamet n twasit nnec u n qeṭṭu n ddunect?” \x ◘ \xo 24:3 \xt Mk. 13:1, 3; Lk. 21:7; Řex. 1:6. \x*
\v 4 Yasuɛ yarra-dd, inna asen: “Ḥḍam ixef nwem, war kenniw ixeddeɛ ḥed. \x ◘ \xo 24:4 \xt Irm. 29:8; Afa. 5:6; Kul. 2:18; 2 Ts. 2:3; 1 Yḥ. 4:1. \x*
\v 5 Minzi aṭṭas ad dd-asen s Yisem inu, ad inin: ‘Aqa Necc d Lmasiḥ!’, uca ad xedɛen aṭṭas. \x ◘ \xo 24:5 \xt Irm. 14:14; 23:25; Yḥ. 5:43. \x*
\v 6 Uca ad tesřem x garrat u x řexburat n imenɣan. Ɣarwem aqa ad teggʷedem, minzi s uɣiř ad yiři man aya, maca war ittiři ɛad d aneggar.
\v 7 Minzi řgens ad iɣewweɣ x ijj n řgens \add nneɣni\add* u tageldit x tgeldit \add nneɣni\add*, ad yiři řaẓ d řehřacat yewɛaren d inhezzan n temmurt da d diha. \x ◘ \xo 24:7 \xt Ica. 19:2. \x*
\v 8 Marra man aya d beddu n řewjeɛ \add n tarut\add*.
\v 9 Xenni ad kenniw dd-awyen ɣar řmeḥnet uca ad kenniw nɣen, u marra řegnus ad kenniw carhen zi ssibbet n Yisem inu. \x ◘ \xo 24:9 \xt Mt. 10:17; Lk. 21:11, 12; Yḥ. 15:20; 16:2; Asa. 2:10. \x*
\v 10 Řexdenni ad nqarḍen waṭṭas, ad carhen ijjen wenneɣni uca ad sellmen ijjen wenneɣni.
\v 11 Ad kkaren waṭṭas n inabiyyen issxarriqen uca ad ɣwan aṭṭas. \x ◘ \xo 24:11 \xt 2 Bṭ. 2:1. \x*
\v 12 S waṭṭas n řmuɛṣiyyet ad tudrus tayri n waṭṭas \add n iwdan\add*, \f ◼ \fr 24:12 \fk tayri\ft - niɣ ‘řemḥibbet’.\f*  \x ◘ \xo 24:12 \xt 2 Tim. 3:1. \x*
\v 13 maca wi ɣa iṣbaren ɣar uneggar, aqa netta ad iddar. \x ◘ \xo 24:13 \xt Mt. 10:22; Mk. 13:13; Lk. 21:19; Asa. 2:7, 10; 3:10. \x*
\v 14 Řexbar-a Aṣebḥan n Tgeldit ad zzayes barrḥen di ddunect marra d cchadet i marra řegnus uca řexdenni ad dd-yas uneggar.”
\b
\m 
\v 15 “Xmi ɣa tẓarem řeɛřamet n nnɛi n wareyyeb, min xef issiweř unabi Daniyal, deg wemcan iqeddsen - ejj wenni t i ɣa iɣaren ad iften - \x ◘ \xo 24:15 \xt Dan. 9:27; Mk. 13:14; Lk. 21:20. \x*
\v 16 řexdenni jjem inni iǧan di Yahudiyya ad arewřen ɣar idurar. \x ◘ \xo 24:16 \xt Mk. 13:14; Lk. 21:21\x*
\v 17 Wenni iǧan x tzeqqa war dd-ihekkwi ca ḥima ad iksi ca zi taddart nnes,
\v 18 u wenni iǧan deg iyyar, war dd-iddikkʷiř ca ḥima ad dd-yawi arruḍ nnes.
\v 19 Uct x tinni iǧan s ddeyset d tinni issuṭṭuḍen deg wussan nni!
\v 20 Ẓaǧem, ḥima war tᵉttiři tarewřa nwem di řmecta niɣ di ssebt, \x ◘ \xo 24:20 \xt Řex. 1:12. \x*
\v 21 minzi řexdenni ad tiři řmeḥnet tameqqrant i war imsaren ɛemmarṣ zeg wami teǧa ddunect ař i řexxu u ɛemmarṣ war tᵉttiři ɛad. \x ◘ \xo 24:21 \xt Dan. 12:1. \x*
\v 22 Mři ussan nni war ttwassmeẓyen, xenni war ittwassenjem uřa d ijj n bnadem, maca \add ussan nni\add* ad ttwassmeẓyen di ṭṭweɛ n yinni ittwafarzen.
\v 23 Mařa inna awem ḥed: ‘Xzarem, aqa da Lmasiḥ!’ niɣ: ‘Aqa-t diha!’ war \add t\add* ttimnem. \x ◘ \xo 24:23 \xt Mk. 13:21; Lk. 21:8. \x*
\v 24 Minzi ad iřin imasiḥen ifalsuten d inabiyyen issxarriqen, ad ggen řeɛřamat mɣarent, ḥima, mři zemmaren, ad xedɛen ɛawed inni ittwafarzen. \x ◘ \xo 24:24 \xt Aɛwd. 13:2; 2 Ts. 2:11. \x*
\v 25 Xzarem, aqa nniɣ awem t qbeř.
\v 26 Mařa nnan awem: ‘Xzarem, Netta aqa-t di řexřa!’, war ttriḥem ca din, \add niɣ\add*: ‘Xzarem, Netta aqa-t daxeř i wexxam!’, war \add tt\add* ttimnem. \x ◘ \xo 24:26 \xt Lk. 17:23. \x*
\v 27 Minzi am wajjaj i dd-itteffɣen zi ccarq uca ittegg tafawt ař řɣarb, ammu i ɣa tiři twasit n Mmis n bnadem.
\v 28 Mani ɣa tiři arrimet diha ad munen igidaren.” \x ◘ \xo 24:28 \xt Ayub 39:30; Lk. 17:37. \x*
\b
\m 
\v 29 “Řexdenni awarni řmeḥnet n wussan nni, ad tbarcen tfuct u taziri war tᵉttic ɛad ṭṭya nnes u itran ad dd-wḍan zeg ujenna u ṣṣulaṭat n ijenwan ad ttwanhezzent. \x ◘ \xo 24:29 \xt Ica. 13:10; 34:4; Ḥiz. 32:7; Yuw. 3:4; 3:15; Mk. 13:24; Lk. 21:25. \x*
\v 30 Xenni ad dd-teḍhar řeɛřamet n Mmis n bnadem deg ujenna u marra tiqebbař n temmurt ad wtent agejdur uca ad ẓarent Mmis n bnadem yusa-dd x iseynuten n ujenna s jjehd u s uɛuǧi aṭṭas. \x ◘ \xo 24:30 \xt Dan. 7:10; Mt. 16:27; 25:31; 26:64; Mk. 13:26; 14:62; Lk. 21:27; Řex. 1:11; 2 Ts. 1:10; Asa. 1:7. \x*
\v 31 Netta ad issekk lmalakat nnes s řḥess ijehden n usuḍi deg \bd uyicc n icarri\bd*, uca ad dd-ssmunent inni ittwafarzen zi arebɛa n iɣezdisen n usemmiḍ, zi ṭṭarf aneggaru n ijenwan ař wenneɣni.” \x ◘ \xo 24:31 \xt 1 Kur. 15:52; 1 Ts. 4:16. \x*
\m 
\v 32 “Řemdem zeg umedya n wartu: xmi ɣa dewřen řefruɛ nnes d iřeqqaɣen, ad dd-ssuffɣen tifray, ad tessnem aqa anebdu yudes-dd. \x ◘ \xo 24:32 \xt Mk. 13:28; Lk. 21:29. \x*
\v 33 Ammu ɛawed kenniw, xmi ɣa tẓarem marra man aya, ad tessnem aqa yudes-dd, ɣar tewwart.”
\m 
\v 34 “S tidett, Necc ad awem iniɣ: Jjiř-a war iɛeddu ař ɣa imsar man aya marra.
\v 35 Ajenna d temmurt ad ɛdun, \add maca\add* awařen inu war ɛeddun ɛemmarṣ. \x ◘ \xo 24:35 \xt Izhd. 102:27; Ica. 51:6; Mk. 13:31; Ɛbr. 1:11. \x*
\b
\m 
\v 36 \bd Maca x wass nni niɣ x tsaɛɛet nni war xas issin uřa d ijj\bd*, uřa d lmalakat n ijenwan, mɣir Baba weḥḥdes. \x ◘ \xo 24:36 \xt Řex. 1:7\x*
\v 37 Am mammec tuɣa iǧa deg wussan n Nuḥ ammu i ɣa tiři ɣar twasit n Mmis n bnadem. \x ◘ \xo 24:37 \xt Amz. 6:2; Lk. 17:26; 1 Bṭ. 3:20; 2 Bṭ. 2:5. \x*
\v 38 Minzi am mammec ten tuɣa \add deg wussan\add* qbeř ṭṭufan, ttᵉtten, sessen, meǧcen u ssmeǧacen ař ass i di yudef Nuḥ ɣar uɣarrabu, \f ◼ \fr 24:38 \fk ṭṭufan\ft - ixs ad yini řḥemřet tameqqrant x marra ddunect deg wussan n Nuḥ, ɛřaḥař ařfayn u-xemsa-mya n iseggʷusa qbeř ma ad ixřeq Lmasiḥ. Xzar Amz. 6.\f*  \x ◘ \xo 24:38 \xt Amz. 7:7. \x*
\v 39 uca war ucin walu ařami dd-yusa ṭṭufan, imḥa i-ten marra, ammu i ɣa tiři ɣar twasit n Mmis n bnadem.
\v 40 Di řweqt nni ad iřin tnayen deg iyyar, ijjen ad t ksin u wenneɣni ad t jjen. \x ◘ \xo 24:40 \xt Lk. 17:34; 1 Ts. 4:17. \x*
\v 41 Tnayen n temɣarin ad ḥaryent s tsirt, icten ad tt ksin u tenneɣni ad tt jjen.
\v 42 S uya ḥḍam, minzi war tessinem ca di man tasaɛɛet i dd ɣa yas Siditwem. \x ◘ \xo 24:42 \xt Mt. 25:13; Mk. 13:33; Lk. 12:40; 21:36. \x*
\v 43 Maca ssnem aya: mařa bab n taddart issen di man ḥeṭṭu \add n ǧiřet\add* i dd ɣa yas uceffar, iři iqqim iḥeṭṭa, war t ittejji ad yadef ɣar taddart nnes. \x ◘ \xo 24:43 \xt Lk. 12:39; 1 Ts. 5:2; 2 Bṭ. 3:10; Asa. 3:3; 16:15. \x*
\v 44 S uya, iřim twejdem, minzi Mmis n bnadem ad dd-yas deg ict n tsaɛɛet war tt tᵉttrijim.”
\b
\m 
\v 45 “\bd Wi iǧan xenni d amsexxar amtiqqi d amiɣis\bd* i igga bab nnes, ḥima ad ibḍa x aytbab n taddart nnes min ɣa ccen di řweqt nnes? \x ◘ \xo 24:45 \xt Mt. 25:21\x*
\v 46 Sseɛd n umsexxar wenni i ɣa yafen sidis iřha ammu xmi dd ɣa yas.
\v 47 S tidett, Necc ad awem iniɣ, ad t igg x marra agřa nnes.
\v 48 Maca mařa amsexxar aɛeffan nni ad yini deg wuř nnes: ‘Sidi inu iɛeṭṭař maḥend ad dd-yas!’,
\v 49 uca ibda iccat imsexxaren imɛacaren nnes, ad icc ad isu ak-d imeskaren,
\v 50 xenni ad dd-yas sidis n umsexxar nni deg ijj n wass i di war t ittriji u deg ict n tsaɛɛet war tt issin,
\v 51 ad t iqess d iwetwiten uca ad tiři tesɣart nnes ak-d imnafqen. Din i ɣa yiřin imeṭṭawen d uɣezzi n teɣmas.” \x ◘ \xo 24:51 \xt Mt. 8:12; 13:42; 22:13; 25:30; Lk. 13:28. \x*
\b
\b
\c 25
\s1 Amedya n ɛecra n teɛzariyyin
\m 
\v 1 “Xenni ad tiři Tgeldit n ijenwan amecnaw ɛecra n teɛzariyyin iwyent řefnarat nsent, ffɣent, ḥima ad mmeřqent ak-d wesři d tesřit.
\v 2 Xemsa zzaysent d timiɣisin u xemsa d tifɣař.
\v 3 Tinni iǧan d tifɣař ksint řefnarat nsent, maca war iwyint ca zzect.
\v 4 Timiɣisin iwyent-i-dd zzect di tziyyatin nsent ak-d řefnarat nsent.
\v 5 Řami iɛḍeř umuřay, bdant ttnudument marra uca ṭṭṣent.
\m 
\v 6 Di řwesṭ n ǧiřet tuɣa din tɣuyyit: ‘Xzarem, aqa amuřay yusa-dd, ffɣem-dd, ad t teřqam!’
\v 7 Xenni kkarent teɛzariyyin nni, ssewjdent-i-dd řefnarat nsent.
\v 8 Tifɣař nnant i tmiɣisin: ‘Wcent aneɣ zi zzect nkent minzi řefnarat nneɣ xesyent.’
\v 9 Arrint-i-dd xasent tmiɣisin, nnant: ‘Ɛemmarṣ, war d aneɣ ittqeddi i neccin d kennint. Ruḥent ɣar isebbaben, maḥend ad tesɣent i yixef nkent.’
\v 10 Řami ruḥent nitenti ḥima ad sɣent, yusa-dd umuřay, u tinni tuɣa iwejden udfent akides ɣar taddart n řefraḥet n wurar uca tbelleɛ tewwart.
\v 11 Awarni man aya usint teɛzariyyin nneɣni, qqarent: ‘\add A\add* siditneɣ, \add a\add* siditneɣ, arzem aneɣ!’
\v 12 Netta yarra-dd, inna: ‘S tidett, necc ad akent iniɣ, war kennint ssineɣ.’
\v 13 S uyenni ḥḍam, minzi kenniw war tessinem ca ass uřa d tasaɛɛet.” \x ◘ \xo 25:13 \xt Mt. 24:42; Mk. 13:33,35. \x*
\b
\s1 Amedya n talintat
\m 
\v 14 “Minzi tamesřact am yijj n bnadem isafar barra i temmurt nnes, iřaɣa-dd x imsexxaren nnes uca ikellef i-ten x wagřa nnes. \x ◘ \xo 25:14 \xt [Lk. 19:11-27] \x*
\v 15 Iwca i yijjen xemsa talint, i wenneɣni tnayen, i wenni wiss třata icten \add n talint\add*, kuř ijjen ɛlaḥsab tizemmar nnes, řexdenni ikkar, isafar deɣya. \f ◼ \fr 25:15 \fk talintat\ft - ict n talint tᵉssekkwi ɛřaḥař 58-80 arḍeř n wureɣ niɣ n nnuqart.\f*
\v 16 Iruḥ wenni iṭṭfen xemsa talint, isebbeb daysen uca yarbeḥ xemsa.
\v 17 Amenni ɛawed wenni iṭṭfen tnayen \add talint\add*, yarbeḥ tnayen nneɣni.
\v 18 Maca wenni iṭṭfen ict \add n talint\add*, iruḥ, iɣza di temmurt uca issnuffar \add tmenyat n\add* nnuqart n bab nnes.
\m 
\v 19 Řami teɛdu aṭṭas n řweqt yusa-dd bab n imsexxaren nni uca igga akidsen řeḥsab.
\v 20 \add Xenni\add* yusa-dd wenni iṭṭfen xemsa talint, yiwi-dd xemsa talint nneɣni, inna: ‘A sidi, tewcid ayi xemsa talint, aqa da, arebḥeɣ xemsa nneɣni ktar.’
\v 21 Yarra-dd xas bab nnes, inna: ‘Mliḥ i teggid, \add a\add* amsexxar aṣebḥan d amtiqqi. Tuɣa cek d amtiqqi x drus, ad ac ggeɣ x waṭṭas, adef-dd ɣar řefraḥet n sidi nnec.’
\v 22 Xenni yusa-dd ɛawed wenni iṭṭfen tnayen talint, inna: ‘\add A\add* sidi, tewcid ayi tnayen talint, aqa arebḥeɣ tnayen nneɣni ktar.’
\v 23 Inna as sidi nnes: ‘Mliḥ i teggid, \add a\add* amsexxar aṣebḥan d amtiqqi. Tuɣa cek d amtiqqi x drus, ad ac ggeɣ x waṭṭas, adef-dd ɣar řefraḥet n sidi nekk.’
\m 
\v 24 Maca wenni iṭṭfen ict n talint, yusa-dd ɛawed, inna: ‘\add A\add* sidi, ssneɣ aqa cek d bnadem tqesḥed, tmejjared mani war tzarrɛed, tyarrwed mani war tᵉssarwated.
\v 25 \add S uyenni\add* ggʷedeɣ uca ruḥeɣ, ssnuffareɣ talint nnec di temmurt. Aɣac tenni nnec.’
\v 26 Yarra-dd sidi nnes, inna as: ‘\add A\add* amsexxar aɛeffan ameɛguz, aqa tessned belli aqa mjareɣ mani war zarɛeɣ u yarweɣ mani war ssarweteɣ.
\v 27 Xenni mři tiwyed nnuqart inu ɣar řbanku, xenni necc, xmi dd ɣa yaseɣ, ad ttareɣ min iǧan inu s arriba.
\v 28 S uya kksem as talint nni, ewc i-tt i wenni ɣar iǧa ɛecra talint!’
\v 29 Minzi i kuř ijjen wenni ɣar iǧa ad as immewc uca ad ɣares yiři s waṭṭas, maca wenni war ɣar iǧi, uřa d min ɣares ad as ittwakkes. \x ◘ \xo 25:29 \xt Mt. 13:12; Mk. 4:25; Lk. 8:18; 19:26. \x*
\v 30 Nḍarem amsexxar ibeṭṭřen ɣar barra deg uneggar n taǧest mani ɣa iřin imeṭṭawen d uɣezzi n teɣmas.” \x ◘ \xo 25:30 \xt Mt. 8:12; 13:42; 22:13; 24:51; Lk. 13:28. \x*
\b
\s1 Řḥukm n Mmis n Bnadem x iḥuřiyyen u x iɣayḍen
\m 
\v 31 “Xmi dd ɣa yas Mmis n bnadem deg uɛuǧi nnes u marra lmalakat nnes iqeddsen akides, xenni ad iqqim x řɛarc n uɛuǧi nnes. \x ◘ \xo 25:31 \xt Mt. 16:27; 26:64; Mk. 14:62; Lk. 21:27; Řex. 1:11; 1 Ts. 4:16; 2 Ts. 1:10; Asa. 1:7. \x*
\v 32 Ad ssmunen marra řegnus qibač nnes uca Netta ad ten imssebḍa am mammec ameksaw issbeṭṭa iḥuřiyyen x iɣayḍen. \x ◘ \xo 25:32 \xt Ḥiz. 34:17, 20; Mt. 13:49. \x*
\v 33 Netta ad igg iḥuřiyyen x ufusi nnes, maca iɣayḍen x uzeřmaḍ nnes.
\m 
\v 34 Řexdenni ad ini Ujeǧid i yinni x ufusi nnes: ‘Asem-dd, \add a\add* kenniw inni ittwabarken zi Baba, wartem Tageldit i d awem dd-iwejden zeg wami tᵉttwagg ddunect. \x ◘ \xo 25:34 \xt Mt. 20:23; Mk. 10:40. \x*
\v 35 Minzi tuɣa dayi řaẓ uca kenniw tesseccem ayi. Tuɣa ffudeɣ, tewcim ayi ad sweɣ. Tuɣa ayi d abarrani, kenniw tesszedɣem ayi, \x ◘ \xo 25:35 \xt Ica. 58:7; Ḥiz. 18:7; Ɛbr. 13:2. \x*
\v 36 tuɣa ayi d aɛaryan, kenniw tessyarḍem ayi, tuɣa heřceɣ, kenniw tessijem-dd xafi, tuɣa ayi di řeḥbes, kenniw tusim-dd ɣari.’ \x ◘ \xo 25:36 \xt Ica. 58:7; 2 Tim. 1:16; Yaɛ. 2:15, 16. \x*
\m 
\v 37 Xenni ad xas dd-arren imseggaden, qqaren: ‘A Siditneɣ, meřmi Cek neẓra tǧuẓed uca nessecc i Cek, niɣ \add meřmi Cek neẓra\add* tᵉffuded uca newc ac ad teswed?
\v 38 Meřmi Cek neẓra d abarrani uca nessezdeɣ i Cek, niɣ d aɛaryan uca nessyarḍ i Cek?
\v 39 Meřmi Cek neẓra theřced niɣ di řeḥbes uca nusa-dd ɣarek?’
\m 
\v 40 Ad dd-yarr ujeǧid, ad asen yini: ‘S tidett, Necc ad awem iniɣ, min i teggim i yijjen zeg wawmaten imeẓyanen inu, i Necc umi t teggim.’ \x ◘ \xo 25:40 \xt Awřn. 19:17; Mt. 10:42; Mk. 9:41; Yḥ. 13:20; 2 Kur. 9:6. \x*
\m 
\v 41 Řexdenni ad yini i yinni iǧan x uzeřmaḍ nnes: ‘Beɛɛdem xafi, a kenniw inni ittwaneɛřen, ɣar tmessi n řebda i iwejden i ibřis d lmalakat nnes. \x ◘ \xo 25:41 \xt Izhd. 6:9; Ica. 30:33; Mt. 7:23; Lk. 13:25, 27; Asa. 19:20. \x*
\v 42 Minzi tuɣa dayi řaẓ war d ayi tesseccem, ffudeɣ war d ayi tewcim ad sweɣ.
\v 43 tuɣa ayi d abarrani, kenniw war d ayi tesszedɣem, tuɣa ayi d aɛaryan, war d ayi tessyarḍem, heřceɣ u ttwaḥebseɣ war xafi dd-tessijem ca.’
\m 
\v 44 Řexdenni uřa d nitni ad \add xas\add* dd-arren, ad inin: ‘A Siditneɣ, meřmi Cek neẓra teǧuẓed niɣ tᵉffuded niɣ d abarrani niɣ d aɛaryan niɣ theřced niɣ di řeḥbes, xenni neccin war xak nsexxar ca?’
\v 45 Xenni ad xasen dd-yarr, ad yini: ‘S tidett, Necc ad awem iniɣ: Min war teggim i yijjen zeg imeẓyanen inu, i Necc umi war t teggim ɛawed.’ \x ◘ \xo 25:45 \xt Awřn. 14:31; 17:5; Zak. 2:12. \x*
\v 46 Ad raḥen nitni ɣar řeɛdab ittduman, maca imseggaden ɣar Tudart ittduman.” \x ◘ \xo 25:46 \xt Dan. 12:2; Yḥ. 5:29. \x*
\b
\b
\c 26
\s1 Tameɛmuč n Wudayen maḥend ad nɣen Yasuɛ
\m 
\v 1 Awarni řami ikemmeř Yasuɛ awařen-a, inna i imeḥḍaren nnes: \x ◘ \xo 26:1 \xt [Mk. 14:1-2; Lk. 22:1-2; Yḥ. 11:45-53] \x*
\v 2 “Tessnem belli awarni tnayen n wussan ad tiři \add Řɛid n Tɣarṣt n\add* Useɛdu u řexdenni ad immewc Mmis n bnadem, ḥima ad ittwaṣelleb.” \x ◘ \xo 26:2 \xt Mk. 14:1; Lk. 22:1; Yḥ. 13:1\x*
\v 3 Řexdenni munen imeqqranen n ikehhanen d imseřmaden n idlisen d imɣaren n řgens di řemraḥ n arrays n ikehhanen, wenni umi qqaren Qayafa, \x ◘ \xo 26:3 \xt Izhd. 2:2; Yḥ. 11:47; Řex. 4:27. \x*
\v 4 uca mcawaren mammec ɣa ṭṭfen Yasuɛ s teḥraymect uca ad t nɣen,
\v 5 nnan: “War ittiři di Řɛid ḥima war ittekkar uɣewweɣ di řgens.”
\b
\s1 Adhan n Yasuɛ di Bayt-Ɛanya
\m 
\v 6 Řami tuɣa Yasuɛ di Bayt-Ɛanya, di taddart n Cimɛun, wenni di iǧa řbarṣ, \x ◘ \xo 26:6 \xt [Mk. 14:3-9; Yḥ. 12:1-8] \x*
\v 7 tusa-dd ɣares ict n temɣart s ijj n uɣarraf n alabaster iccur s zzect iɣřan i wedhan, uca tfarreɣ i-tt x uzeǧif nnes am iqqim Yasuɛ \add ɣar ṭṭabřa\add*. \x ◘ \xo 26:7 \xt Mk. 14:3; Lk. 7:37; Yḥ. 11:2; 12:3. \x*
\m 
\v 8 Umi ẓrin imeḥḍaren man aya, iqqes asen řḥař aṭṭas, nnan: “Min umi teǧa txessart-a?
\v 9 Tuɣa izemmar ad temmenz \add zzect-a n wedhan\add* s ttaman d ameqqran, uca \add xenni\add* ad temmewc i imezřaḍ.”
\v 10 Maca Yasuɛ tuɣa issen man aya, inna: “Mayemmi tziyyarem x temɣart-a, minzi nettat tegga ayi ict n řxedmet teṣbeḥ.
\v 11 Minzi imezřaḍ aqa aten řebda akidwem, maca Necc war kiwem ttiřiɣ i řebda. \x ◘ \xo 26:11 \xt Aɛwd. 15:11; Mk. 14:7; Yḥ. 12:8. \x*
\v 12 Minzi nettat, mařa tfarreɣ-dd \add zzect-a i\add* wedhan x arrimet inu, aqa tegga man aya i usewjed n wenḍeř inu.
\v 13 S tidett, Necc ad awem iniɣ: Mani ma i ɣa ittwabarreḥ zi Řexbar-a Aṣebḥan xafi di marra ddunect, ad ssiwřen ɛawed x min \add dayi\add* tegga, d řiḍaret i nettat.”
\b
\s1 Yahuda izzenz ixef nnes maḥend ad isellem Yasuɛ
\m 
\v 14 Řexdenni iřuḥ ijjen zi tenɛac, qqaren as Yahuda Isxariyuṭi, ɣar imeqqranen n ikehhanen, \x ◘ \xo 26:14 \xt Mk. 14:10; Lk. 22:4. \x*
\v 15 inna: “Min d ayi ɣa tewcem maḥend ad awem sellmeɣ Yasuɛ?” Uca waɛden \add t\add* s třatin \add n řweznat\add* n nnuqart. \x ◘ \xo 26:15 \xt Zak. 11:12. \x*
\v 16 Ssenni tuɣa yarezzu ict n tewwart ḥima ad t isellem.
\b
\s1 Amensi n Tɣarṣt n Useɛdu
\m 
\v 17 Deg wass amezwaru n \add Weɣrum\add* břa Antun, usin-dd imeḥḍaren ɣar Yasuɛ, nnan: “Mani texsed ad nessewjed i Cek maḥend ad tecced \add amensi n\add* Useɛdu?” \x ◘ \xo 26:17 \xt [Mk. 14:21-22; Lk. 22:7-14; 21-23; Yḥ. 13:21-30] — Uf. 12:17; \x*
\v 18 Inna asen: “Uyurem ɣar tendint ɣar ijj n fřan, inim as: ‘Amseřmad nneɣ iqqar: Aqa řweqt inu tiweḍ-dd, ad ɣarek ggeɣ \add amensi n\add* Useɛdu ak-d imeḥḍaren inu.’”
\v 19 Imeḥḍaren ggin am mammec ten iweṣṣa Yasuɛ uca ssewjden i \add umensi n\add* Useɛdu.
\v 20 Řami dd-tiweḍ tmeddit, iqqim \add ɣar umensi\add* ak-d tenɛac \add n imeḥḍaren nnes\add*. \x ◘ \xo 26:20 \xt Mk. 14:17; Lk. 22:14; Yḥ. 13:21. \x*
\v 21 Am ttᵉtten nitni, inna: “S tidett, Necc ad awem iniɣ, ijjen zzaywem ad ayi iɣdar.” \x ◘ \xo 26:21 \xt Řex. 1:17. \x*
\v 22 Nitni dewřen ceḍnen aṭṭas uca kuř ijjen zzaysen ibda ad as yini: “Ma war iǧi d necc, a Sidi?”
\v 23 Yarra-dd xasen, inna: “Wenni issisnen afus akidi di ṭṭebṣi d netta i d ayi ɣa iɣdaren. \x ◘ \xo 26:23 \xt Izhd. 41:10; Lk. 22:21; Yḥ. 13:18. \x*
\v 24 Mmis n bnadem ad iraḥ am mammec xas tura, maca uct x bnadem nni i ɣa iɣdaren Mmis n bnadem. Iḥřa as i bnadem nni war dd-ixřiq ɛemmarṣ.”
\v 25 Yahuda, aɣeddar, yarra-dd, inna: “Ma war iǧi d necc, \add a\add* Amseřmad inu?” Netta inna as: “Aqa cek tennid \add t\add*.”
\b
\s1 Amensi n Siditneɣ
\m 
\v 26 Am tuɣa ttᵉtten, iksi Yasuɛ aɣrum u awarni řami ibarek, yarẓa \add i-t\add*, iwca \add i-t\add* i imeḥḍaren, inna: “Ksim, ccem, ta d Arrimet inu.” \x ◘ \xo 26:26 \xt [Mk. 14:22-26; Lk. 22:15-20; 1 Kur. 11:23-25] — Irm. 16:7\x*
\v 27 Iksi řkas, iqada uca iwca asen t, inna: “Swem zzayes marra idwem,
\v 28 minzi wa d Idammen inu n Řɛahd n Jdid inni i ɣa ittwassizřen i weɣfar n ddnub. \x ◘ \xo 26:28 \xt Uf. 24:8; Irm. 31:31; Mt. 26:28, Mk. 14:24, Lk. 22:20, 1 Kur. 11:25, 2 Kur. 3:6, Ɛbr. 8:6, 8, 13; 9:15; 12:24\x*
\v 29 Necc ad awem iniɣ, zi řexxu tsawent war sesseɣ ɛad zi řɣiǧet n tzayart ař ass i di tt ɣa sweɣ zi jdid akidwem di Tgeldit n Baba.”
\v 30 U \add awarni řami\add* ɣennjen izři n ttesbiḥ, ffɣen ɣar wedrar n Zzitun. \x ◘ \xo 26:30 \xt Mk. 14:26; Lk. 22:39; Yḥ. 18:1. \x*
\b
\s1 Yasuɛ izwar issiweř x wenkar zi Buṭrus
\m 
\v 31 Xenni inna asen Yasuɛ: “Marra kenniw ad dayi tenderfem di ǧiřet-a, minzi aqa tura: ‘Ad wteɣ Ameksaw, uca iḥuřiyyen n tḥimart ad ttwazuzzaren.’ \x ◘ \xo 26:31 \xt [Mk. 14:27-31; Lk. 22:31-34; Yḥ. 13:36-38] — Zak. 13:7; Yḥ. 16:32; \x*
\v 32 Maca awarni řami i dd ɣa ttwassnekkareɣ, ad awem izwareɣ ɣar Ljalil.” \x ◘ \xo 26:32 \xt Mk. 14:28; 16:7. \x*
\v 33 \add Maca\add* Buṭrus yarra-dd, inna as: “Mařa dayek i ɣa nderfen marra, necc war dayek ttendrifeɣ ca ɛemmarṣ!” \x ◘ \xo 26:33 \xt Lk. 22:33. \x*
\v 34 Inna as Yasuɛ: “S tidett, Necc ad ac iniɣ, di ǧiřet-a, qbeř i ɣa issquqeɛ uyaẓiḍ, ad ayi tenkared třata n twařawin.” \x ◘ \xo 26:34 \xt Yḥ. 13:38. \x*
\v 35 Buṭrus inna as: “Waxxa tuɣa ittxeṣṣa ayi ad mmteɣ akidek, necc war Cek nekkareɣ ɛemmarṣ.” Ammu i nnan marra imeḥḍaren ɛawed.
\b
\s1 Taẓaǧit n Yasuɛ deg weḥwic n Xitsimaniy
\m 
\v 36 Řexdenni iruḥ Yasuɛ akidsen ɣar ijj n wemcan qqaren as Xitsimaniy, inna i imeḥḍaren nnes: “Qqimem danita, am i ɣa ẓẓaǧeɣ \add din\add*.” \x ◘ \xo 26:36 \xt [Mk. 14:32-42; Lk. 22:39-46] — Yḥ. 18:1. \x*
\v 37 Am kis yiwi Buṭrus d tnayen n iḥenjiren n Zabdi, ibda ittnexřaɛ, iggʷed aṭṭas.
\v 38 Xenni inna asen: “Řeɛmar inu issḥissif aṭṭas ař řmewt. Qqimem da, ḥḍam akidi.” \x ◘ \xo 26:38 \xt Izhd. 69:2-4; Yḥ. 12:27. \x*
\v 39 \add Xenni\add* iɛzeř cwayt ktar, iwḍa x uɣembub nnes, ittẓaǧa, inna: “A Baba, mařa iɛeddeř, ejj ad xafi iɛdu řkas-a! Maca war ittiři am mammec xseɣ Necc, maca am mammec \add texsed\add* Cek.” \x ◘ \xo 26:39 \xt Mt. 20:22, 23; Mk. 14:35; Lk. 22:42; Yḥ. 6:38. \x*
\v 40 \add Řexdenni\add* idweř-dd ɣar imeḥḍaren nnes uca yufa i-ten ṭṭṣen. Inna i Buṭrus: “Ma war tzemmarem ad kidi teḥḍam uřa d ict n tsaɛɛet?
\v 41 Ḥḍam, ẓẓaǧem, ḥima war dd-tᵉttidfem deg ujarreb. Arruḥ aqa iwjed, maca ddat teḍɛef.” \x ◘ \xo 26:41 \xt Gal. 5:17. \x*
\m 
\v 42 Yuyur ɛawed i umur wiss tnayen uca iẓẓuǧ, inna: “A Baba, mařa řkas-a war izemmar ad xafi yekk mɣir mařa Necc swiɣ t, aqa ad yiři min texsed Cek!”
\v 43 Řami dd-idweř, yufa i-ten ɛawed ṭṭṣen, minzi tiṭṭawin nsen tuɣa ḍeqqřent.
\m 
\v 44 Ijja i-ten, yuyur ɛawed uca iẓẓuǧ i twařa wiss třata, iqqar awařen-a ɛawed.
\v 45 Řexdenni idweř-dd ɣar imeḥḍaren nnes, inna asen: “Kemmřem x yiḍeṣ nwem řexxu, areyyḥem. Xzarem, aqa tsaɛɛet tiweḍ-dd aqa Mmis n bnadem ad immewc deg ifassen n imednab.
\v 46 Kkarem, ad nraḥ. Xzarem, wenni d ayi ɣa iɣdaren, yudes-dd.”
\b
\s1 Uḍuf n Yasuɛ
\m 
\v 47 Am tuɣa issawař ɛad, yusa-dd Yahuda, aɣeddar, ijjen zi tenɛac, ak-d ijj n řɣaci ameqqran s řesyuf d iɛumad, usin-dd zeg imeqqranen n ikehhanen d imɣaren n řgens. \x ◘ \xo 26:47 \xt [Mk. 14:43-50; Lk. 22:47-53; Yḥ. 18:3-12] \x*
\v 48 Yahuda, aɣeddar, aqa iwca asen ict n řeɛřamet, inna: “Wenni i ɣa ssudmeɣ d wenni Netta, ṭṭfem t.”
\v 49 Řexdenni dd-iqarreb ɣar Yasuɛ, inna: “Sřam xak, \add a\add* Amseřmad inu!”, uca issudem i-t.
\v 50 \add Xas uca\add* Yasuɛ inna as: “\add A\add* ameddukkeř inu, min xef dd-tusid da?” Řexdenni qarrben-dd \add ɣares\add*, ḥarten x Yasuɛ uca ṭṭfen t.
\v 51 U xzar, ijjen zeg inni iǧan ak-d Yasuɛ, isswiẓẓeḍ afus nnes, ijbed ssif uca iwta amsexxar n arrays n ikehhanen, iqess as amezzuɣ.
\v 52 Xenni inna as Yasuɛ: “Arr ssif ɣar wemcan nnes, minzi marra inni ikessin ssif ad mmten s ssif.
\v 53 Niɣ ittɣiř ac belli Necc war zemmareɣ ad ẓẓaǧeɣ i Baba, aqa Netta ad d ayi dd-issekk řexxu ktar zi tenɛac n ilixiyunen n lmalakat? \f ◼ \fr 26:53 \fk tenɛac n ilixiyunen\ft - man aya ixs ad yini ɛřaḥař setta ařaf n lmalakat.\f*
\v 54 Mammec xenni i ɣa ttwakemmřent Tira \add Iqeddsen\add* \add i iqqaren\add* belli ittxeṣṣa ad imsar ammu?” \x ◘ \xo 26:54 \xt Izhd. 22:7; 69:2, 10; Lk. 24:25. \x*
\m 
\v 55 Di tsaɛɛet nni ɛawed issiweř Yasuɛ ak-d řɣaci: “Axmi x ijj n uqṭaṭɛiy i dd-teffɣem s řesyuf d iɛumad maḥend ad ayi tᵉṭṭfem. Kuř ass tuɣa qqimeɣ ɣarwem, sseřmadeɣ di Zzawect Tameqqrant, war dayi tᵉṭṭifem.
\v 56 Maca man aya marra imsar, ḥima ad ttwakemmřent Tira n inabiyyen.” Řexdenni semḥen dayes marra imeḥḍaren uca arewřen. \x ◘ \xo 26:56 \xt Ayub 19:13; Izhd. 88:9. \x*
\b
\s1 Yasuɛ zzat i Jmaɛet Tameqqrant n Wudayen
\m 
\v 57 Inni iṭṭfen Yasuɛ, iwyen t ɣar Qayafa, arrays n ikehhanen, wenni ɣar tuɣa munen imseřmaden n idlisen d imɣaren \add n řgens\add*. \x ◘ \xo 26:57 \xt [Mk. 14:53-65; Lk. 22:54-55; 63-71; Yḥ. 18:13-14, 19-24] \x*
\v 58 Cimɛun Buṭrus iḍfar i-t-i-dd zi řaggʷaj ařami d yiweḍ ɣar řemraḥ n arrays n ikehhanen u řami yudef, iqqim jar iɛessasen ḥima ad iẓar mammec i ɣa teffeɣ.
\v 59 Imeqqranen n ikehhanen d imɣaren \add n řgens\add* u marra Jmaɛet \add Tameqqrant\add*, tuɣa arezzun icehhaden issxarriqen x Yasuɛ, maḥend ad t nɣen. \x ◘ \xo 26:59 \xt Mk. 14:55; Řex. 6:13. \x*
\v 60 Maca war zemmaren ad tt afen, waxxa usin-dd aṭṭas n řechud issxarriqen. Ɣar uneggar usin-dd tnayen
\v 61 i innan: “Wa aqa inna: ‘Necc zemmareɣ ad hedmeɣ Zzawect Tameqqrant n AREBBI u di třata n wussan ad tt bniɣ \add ɛawed\add*.’” \x ◘ \xo 26:61 \xt Yḥ. 2:19. \x*
\v 62 Arrays n ikehhanen ikkar-dd, inna as: “Ma war dd-tarrid s walu? Min xak cehhden ina?” \x ◘ \xo 26:62 \xt Mk. 14:60. \x*
\m 
\v 63 Maca Yasuɛ isqar. Inna as arrays n ikehhanen: “Necc ad Cek jjeɣ ad tejjaǧed s AREBBI iddaren, belli Cek ad aneɣ tinid, ma xenni Cek d Lmasiḥ, Mmis n AREBBI?” \x ◘ \xo 26:63 \xt Ica. 53:7; Mt. 27:12, 14. \x*
\v 64 Inna as Yasuɛ: “Cek tennid \add t\add*. Maca Necc ad awem iniɣ: ‘Zi ssa tsawent ad tẓarem Mmis n bnadem iqqim x ufusi n jjehd xmi dd ɣa yas x iseynuten n ujenna.” \x ◘ \xo 26:64 \xt Izhd. 110:1; Dan. 7:13; Mt. 16:27; 24:30; Mk. 14:62; Lk. 22:69; Řex. 1:11; Rum. 14:10; 1 Ts. 4:16; Asa. 1:7. \x*
\m 
\v 65 Řexdenni icarreg arrays n ikehhanen arruḍ nnes, inna: “Netta aqa iceqqef \add di AREBBI\add*, mayemmi neḥdaj ɛad řechud? Xzarem, řexxu aqa tesřim i uceqqef nnes.
\v 66 Min d awem ittɣiř kenniw?” Nitni arrin-dd xas, nnan: “Netta isdaheǧ řmewt.” \x ◘ \xo 26:66 \xt Lawi 24:16. \x*
\v 67 Xenni bdan ssusufen \add as\add* x uɣembub, ccaten t s řpuniyyat \add x uzeǧif\add* u inneɣni wtin t \add ɛawed\add*, \x ◘ \xo 26:67 \xt Ica. 50:6. \x*
\v 68 nnan: “Nabb aneɣ, \add a Cek\add*, Lmasiḥ, wi Cek iwtin?” \x ◘ \xo 26:68 \xt Ayub 16:10; Lk. 22:64; Yḥ. 19:3. \x*
\b
\s1 Ankar n Yasuɛ zi Buṭrus
\m 
\v 69 Buṭrus iqqim ɣar barra di řemraḥ. Tqarreb-dd ɣares ict n tayya, tenna: “Uřa d cek tuɣa cek ak-d Yasuɛ, zi Nnaṣira.” \f ◼ \fr 26:69 \fk zi Nnaṣira\ft - ixs ad yini ‘zi tendint n Nnaṣira di temmurt n Ljalil’.\f*  \x ◘ \xo 26:69 \xt [Mk. 14:66-72; Lk. 22:56-62; Yḥ. 18:15-18; 25-27] \x*
\v 70 Maca netta inkar zzat i marra, inna: “War ssineɣ min xef tessawařed.”
\v 71 Am iggur ɣar usqif n tewwart, teẓra i-t ict n tayya nneɣni, tenna asen i yinni din iqqimen: “Uřa d wa tuɣa ak-d Yasuɛ zi Nnaṣira.”
\v 72 Netta inkar ɛawed s ict n tjaǧit, inna: “War ssineɣ Bnadem nni.”
\v 73 Cwayt ɣar zzat qarrben-dd inni din ibedden ɣar Buṭrus, nnan: “Nican, uřa d cek d ijjen zzaysen, minzi řhard nnec issbeyyen i cek.”
\v 74 Xenni ibda ineɛɛeř, ittjjaǧa: “Necc war ssineɣ Bnadem nni.” Řexdenni issquqeɛ uyaẓiḍ
\v 75 uca iɛqeř Buṭrus awař i d as inna Yasuɛ: “Qbeř i ɣa issquqeɛ uyaẓiḍ, ad ayi tenkared třata n twařawin.” Uca iffeɣ, iru s imeṭṭawen imerzagen. \x ◘ \xo 26:75 \xt Mt. 26:34; Mk. 14:30; Lk. 22:61; Yḥ. 13:38\x*
\b
\b
\c 27
\s1 Andam n Yahuda d řmewt nnes
\m 
\v 1 Ɣar ṣṣbeḥ zic, aqa marra imeqqranen n ikehhanen d imɣaren n řgens mcawaren x Yasuɛ, mammec i t ɣa nɣen. \x ◘ \xo 27:1 \xt [Mk. 15:1; Lk. 23:1-2; Yḥ. 18:28-32] — Izhd. 2:2 \x*
\v 2 Uca nitni carfen t, iwyen t uca sellmen t i lɛamil \add Arumani\add*, qqaren as Pilaṭus. \x ◘ \xo 27:2 \xt Řex. 3:13. \x*
\v 3 Umi iẓra Yahuda, aɣeddar, belli Yasuɛ ittwaḥkem, indem, uca yarra-dd třatin \add n řweznat\add* n nnuqart ɣar imeqqranen n ikehhanen d imɣaren \add n řgens\add*.
\v 4 Inna: “Necc xḍiɣ, aqa ɣdareɣ idammen imezdagen.” Maca nitni nnan: “Min d aneɣ iruḥen? Xzar-dd cek.”
\v 5 Awarni řami inḍar \add řweznat n\add* nnuqart di Zzawect Tameqqrant, iffeɣ uca iruḥ, yuyeř ixef nnes. \x ◘ \xo 27:5 \xt 2 Ṣm. 17:23; Řex. 1:18. \x*
\v 6 Imeqqranen n ikehhanen ksin \add řweznat n\add* nnuqart, nnan: “War icuwwar ad ten nessars deg wexxam n ṣṣdaqi, minzi \add řweznat nni\add* d ttaman n usizzeř n idammen.”
\v 7 Kksen awař jar asen maḥend ad zzayes sɣen iyyar n bu-třaxt, maḥend ad yiři i imeḍřan n ibarraniyyen. \f ◼ \fr 27:7 \fk bu-třaxt\ft - ixs ad yini ‘wenni ittṣennaɛen řeqcuɛ n třaxt’.\f*  \x ◘ \xo 27:7 \xt Řex. 1:19. \x*
\v 8 S uyenni ittwasemma iyyar nni ‘Iyyar n idammen’ ař ass n řexxu.
\m 
\v 9 Řexdenni ittwakemmeř min ittwannan zeg unabi i innan: “Ksiɣ třatin \add n řweznat n\add* nnuqart, řqedd n Wenni iɣřan, mixef inni zi tarwa n Israil kksen awař, \x ◘ \xo 27:9 \xt Zak. 11:12. \x*
\v 10 uca necc wciɣ tent i iyyar n bu-třaxt, am mammec i d ayi yumur SIDI.” \x ◘ \xo 27:10 \xt Irm. 32:6-9; Zak. 11:12, 13\x*
\b
\s1 Yasuɛ qibač lɛamil Pilaṭus
\m 
\v 11 Yasuɛ tuɣa ibedd qibač i lɛamil. Lɛamil isseqsa as, inna: “Ma Cek d Ajeǧid n Wudayen?” Yasuɛ inna as: “Cek aqa tennid \add t\add*!” \x ◘ \xo 27:11 \xt [Mk. 15:2-15; Lk. 23:3-5; 13-25; Yḥ. 18:33-40; 19:1-16] \x*
\v 12 Uca řami t tehmen imeqqranen n ikehhanen d imɣaren \add n řgens\add*, yarra-dd s walu.
\v 13 Xenni inna as Pilaṭus: “Ma war tesřid mecḥař xak cehhden?” \x ◘ \xo 27:13 \xt Mt. 26:62. \x*
\v 14 Netta war xas dd-yarri uřa s ijj n wawař, ařami iqqim \add lɛamil\add* ittebhet aṭṭas. \x ◘ \xo 27:14 \xt Ica. 53:7; Řex. 8:32. \x*
\b
\m 
\v 15 Tuɣa lɛamil innum yarexxu di kuř řɛid i yijj n umeḥbus i řɣaci, wenni ixsen nitni.
\v 16 Tuɣa ɣarsen deg wussan nni ijj n umeḥbus ittwassen, qqaren as Bar-Abbas. \x ◘ \xo 27:16 \xt Mk. 15:7; Lk. 23:19; Yḥ. 18:40. \x*
\v 17 Řami munen, inna asen Pilaṭus: “Wi texsem ad awem dd-arxuɣ, Bar-Abbas niɣ Yasuɛ wenni umi qqaren Lmasiḥ?”
\v 18 Minzi Pilaṭus issen aqa nitni sellmen t zi řeḥsed.
\v 19 Am tuɣa lɛamil iqqim x řkursi n řḥukm, tessekk-dd ɣares temɣart nnes, tenna: “Barra ixef nnec zeg Umseggad nni, minzi aqa ass-a ttwaɛeddbeɣ aṭṭas di tarjit inu di ssibbet nnes.”
\v 20 Maca imeqqranen n ikehhanen d imɣaren \add n řgens\add* ssqenɛen řɣaci, ḥima ad ttaren Bar-Abbas u ḥima ad areddǧen Yasuɛ. \x ◘ \xo 27:20 \xt Mk. 15:11; Lk. 23:18; Yḥ. 18:40; Řex. 3:14. \x*
\v 21 Lɛamil yarra-dd, inna asen: “Man wen zi tnayen-a i texsem ad arxuɣ i kenniw?” Nnan: “Bar-Abbas!”
\v 22 Pilaṭus inna asen: “Min ɣa ggeɣ \add xenni\add* ak-d Yasuɛ umi qqaren Lmasiḥ?” Nnan as marra: “Ṣellb i-t!”
\v 23 Inna asen lɛamil: “Man tuɛeffna i igga?” Sɣuyyen s jjehd ktar, nnan: “Ṣellb i-t.”
\v 24 Řami iẓra Pilaṭus belli war yiweḍ ɣar walu, mahu ad ikkar uɣuwweɣ, iksi aman, issird ifassen nnes qibač i řɣaci, inna: “Necc war tturseɣ ca deg idammen n Umseggad-a, xzarem kenniw!”
\v 25 Řgens marra yarra-dd, inna: “\add Ejj\add* idammen nnes \add ad\add* xaneɣ \add iřin\add* u x tarwa nneɣ.” \x ◘ \xo 27:25 \xt Řex. 5:28. \x*
\v 26 Xenni yarxu asen-dd i Bar-Abbas, maca awarni řami ihettek Yasuɛ s urekkuḍ, isellem i-t ḥima ad ittwaṣelleb.
\b
\s1 Aseḥqar n Yasuɛ zi řɛeskar
\m 
\v 27 Řexdenni iwyen iɛeskariyyen n lɛamil Yasuɛ ɣar Taddart n Ccraɛ, \add umi qqaren ‘Prituriyum’\add*, uca ssmunen xas marra řkumpaniyyet n řɛeskar. \x ◘ \xo 27:27 \xt [Mk. 15:16-20; Yḥ. 19:2-3] \x*
\v 28 Kksen as-dd arruḍ, uca arḍen as ijj n ujeǧab d azeggʷaɣ.
\v 29 Nitni muden as ijj n ttaj s isennanen, ssarsen t x uzeǧif nnes uca ggin as ijj n uɣanim deg ufus nnes afusi, xenni wḍan ɣar iḍaren nnes zzates, qqimen ttbuṣaren xas, nnan: “Azul xak, a Cek, \add a\add* Ajeǧid n Wudayen!”
\v 30 Ssusfen as x uɣembub nnes, ksin aɣanim uca wtin t \add zzayes\add* ɣar uzeǧif.
\v 31 \add Awarni řami\add* t deǧen, ksin xas aseřham, arḍen as arruḍ nnes uca nedhen t, maḥend ad t ṣellben.
\b
\s1 Abrid ɣar ṣṣalib
\m 
\v 32 Am ffɣen ɣar barra \add n tendint\add*, ufin ijj n weryaz zi Qayrawan, qqaren as Cimɛun, uca ziyyaren xas ḥima ad yarbu ṣṣalib nnes. \x ◘ \xo 27:32 \xt [Mk. 15:21-41; Lk. 23:26-39; 44-49; Yḥ. 19:17-19; 28-30] \x*
\v 33 Ařami iwḍen ɣar wemcan umi qqaren ‘Juljuta’, min ixs ad yini ‘Taceqquft’, \x ◘ \xo 27:33 \xt Izhd. 69:22; Mk. 15:22; Lk. 23:33; Yḥ. 19:17. \x*
\v 34 wcin as řxeǧ ixeǧḍen s tarzugi uca umi t iqqas, yugi ad isu.
\v 35 Awarni řami t ṣellben, bḍan arruḍ nnes jar asen umi xas ggin akeccuḍ, \x ◘ \xo 27:35 \xt Izhd. 22:19; Mk. 15:24; Yḥ. 19:23. \x*
\v 36 am qqimen dinni, ttɛessan xas.
\v 37 Ggin as sennej i uzeǧif nnes ict n tira mayemmi xas ḥekmen s řmewt: ‘Wa d Yasuɛ, Ajeǧid n Wudayen.’ \x ◘ \xo 27:37 \xt Mk. 15:26; Lk. 23:38; Yḥ. 19:19. \x*
\v 38 Xenni ṣellben akides tnayen n ixewwanen, ijjen ɣar ufusi nnes u ijjen ɣar uzeřmaḍ nnes. \x ◘ \xo 27:38 \xt Ica. 53:12. \x*
\v 39 Inni tuɣa ittekkan, ttceqqafen dayes, tthezzan azeǧif nsen, \x ◘ \xo 27:39 \xt Izhd. 22:8; 69:21; Mk. 15:29; Lk. 23:35. \x*
\v 40 nnan: “A Cek, wenni ihedmen Zzawect Tameqqrant u di třata n wussan ad tt tebnid \add ɛawed\add*, senjem Ixef nnec. Mařa Cek d Mmis n AREBBI, hwa-dd xenni zi ṣṣalib.” \x ◘ \xo 27:40 \xt Mt. 26:61; Yḥ. 2:19. \x*
\v 41 Uřa d imeqqranen n ikehhanen ak-d imseřmaden n idlisen d imɣaren \add n řgens\add* d Ifarisiyyen stehzan zzayes amenni, nnan:
\v 42 “Issenjem inneɣni maca war izemmar ad issenjem xef nnes. Mařa Netta d Ajeǧid n Israil, ejj i-t ad dd-ihwa zi ṣṣalib, ad zzayes namen.
\v 43 Ittceř x AREBBI. Ejj i-t Netta ad t issenjem mařa yarḍa xas, minzi inna: ‘Necc d Mmis n AREBBI’.”
\v 44 Uřa d ixewwanen, inni tuɣa ittwaṣellben akides, tuɣa ssfeṭṭaḥen zzayes amenni.
\b
\m 
\v 45 Zi tsaɛɛet wiss setta, \add aqa-tt d ḍḍhur\add*, tewḍa-dd taǧest x marra tammurt ař tasaɛɛet wiss tesɛa, \add aqa-tt d třata n uɛecci\add*.
\v 46 Jjwayeh n tsaɛɛet wiss tesɛa isɣuy Yasuɛ s tmijja ijehden, inna: “\add A\add* AREBBI inu, \add a\add* AREBBI inu, mayemmi dayi tsemḥed?” \f ◼ \fr 27:46 \fk Il, Il, lmana cabaqtani\ft - tuɣa Yasuɛ issawař s yiřes n Třamit am t ssawařen marra Wudayen di Urcalim d temmurt n Ljalil.\f*  \x ◘ \xo 27:46 \xt Izhd. 22:2; Ɛbr. 5:7. \x*
\v 47 Řami d as sřan inni din ibedden, nnan ca zzaysen: “Ittřaɣa x Iliya.”
\v 48 Deɣya yuzzeř-dd ɣares ijjen zzaysen, iksi spunxa, issuff i-tt s řxeǧ, igga i-tt x ijj n uɣanim uca iwca as ad isu. \x ◘ \xo 27:48 \xt Izhd. 69:22; Yḥ. 19:29. \x*
\v 49 Inneɣni nnan: “Ejj i-t, ad nẓar, ma ad dd-yas Iliya ḥima ad t issenjem.”
\v 50 Isɣuyy Yasuɛ ɛawed s tmijja ijehden uca issarxu Arruḥ nnes. \x ◘ \xo 27:50 \xt Lk. 23:46. \x*
\m 
\v 51 Xzar, ařeḥḥaf n wadaf ɣar Zzawect Tameqqrant ittwacarreg x tnayen zi sennej ař swadday, tammurt tenhezz, tiṣuḍar feǧqent, \f ◼ \fr 27:51 \fk ařeḥḥaf\ft - niɣ ‘arwaq’.\f*  \x ◘ \xo 27:51 \xt 2 Im. 3:14; Mk. 15:38; Lk. 23:45. \x*
\v 52 imeḍřan ttwarezmen uca aṭṭas n arrimat n imqeddasen inni tuɣa iṭṭṣen \add din\add*, ttwassnekkarent-dd.
\v 53 Nitni ffɣen \add zeg imeḍřan\add*, uca awarni i tnukra nnes udfen ɣar tendint iqeddsen uca banen-dd i waṭṭas.
\v 54 Řami řqebṭan x mya d yinni tuɣa akides iḥeṭṭan Yasuɛ, ẓrin anhezzi n temmurt d min imsaren, ggʷeden aṭṭas, nnan: “S tidett tuɣa Wa d Mmis n AREBBI.” \x ◘ \xo 27:54 \xt Mk. 15:39; Lk. 23:47. \x*
\v 55 Tuɣa din aṭṭas n temɣarin tinni tuɣa ixezzaren zi řaggʷaj, ḍfarent Yasuɛ zi Ljalil ḥima ad xas sexxarent. \x ◘ \xo 27:55 \xt Izhd. 38:12; Mk. 15:40; Lk. 8:2; 23:49. \x*
\v 56 Jarasent Maryam n Majdala d Maryam, yemmas n Yaɛqub d Yasi, d yemmas n ayt n Zabdi.
\b
\s1 Anḍeř n Yasuɛ
\m 
\v 57 Řami dd-tiweḍ tmeddit, yusa-dd ijj n weryaz zi Ramta, qqaren as Yusuf. Netta tuɣa ɛawed d ameḥḍar n Yasuɛ. \x ◘ \xo 27:57 \xt [Mk. 15:42-47; Lk. 23:50-56; Yḥ. 19:38-42] \x*
\v 58 Iruḥ ɣar Pilaṭus, ittar \add as\add* arrimet n Yasuɛ. \add Řexdenni\add* iweṣṣa Pilaṭus, maḥend ad as wcen arrimet
\v 59 Yusuf iksi arrimet inneḍ i-tt deg ict n txeyyaḍt n řeqṭen \add azdad\add* iṣfan,
\v 60 issars i-tt deg ijj n wenḍeř n jdid i tuɣa iɣza, uca awarni řami isseqnunni ict n teṣḍart ḥima ad iqfeř tawwart n wenḍeř, iruḥ. \x ◘ \xo 27:60 \xt Mk. 15:46; Lk. 23:53. \x*
\v 61 Tuɣa din Maryam n Majdala d Maryam nneɣnit qqiment qibač i wenḍeř.
\b
\m 
\v 62 Tiwecca nnes awarni \add ass n\add* Usewjed, munen imeqqranen n ikehhanen d Ifarisiyyen ɣar Pilaṭus, \f ◼ \fr 27:62 \fk ass n Usewjed\ft - netta d ass qbeř wass n ssebt (‹Matta 27:62›) n Řɛid n Tɣarṣt n Useɛdu (qqaren as 'Basxa') nni di sswejden Wudayen ijj n yezmar i macca, ssirden, yarḍen arruḍ ittxeṣṣen umi dd-ffɣen zi Miṣra (Uffuɣ 11-13).\f*
\v 63 nnan: “A siditneɣ, neɛqeř belli aɣeccac-a, am tuɣa \add ɛad\add* iddar, inna: ‘Awarni třata n wussan ad kkareɣ!’ \x ◘ \xo 27:63 \xt Mt. 16:21; 17:23; 20:19; Mk. 8:31; 10:34; Lk. 9:22; 18:33; 24:6. \x*
\v 64 S uya umur, ḥima ad ḍemnen anḍeř ař ass wiss třata, ḥima ad taɣ imeḥḍaren nnes war dd-ttisen s ǧiřet ad t acaren, \add xenni\add* ad inin i řgens, aqa ikkar-dd zi taddart n imettinen, uca \add ammu i\add* ɣa yiři uweddar aneggaru ktar x umezwar.”
\v 65 Inna asen Pilaṭus: “Aqa ɣarwem iɛessasen, ruḥem, ḍemnen t am mammec tᵉttwařam.”
\v 66 Ruḥen ḥima ad ɛessen x wenḍeř uca ḍemnen aẓru, nitni jmiɛ ak-d iɛessasen.
\b
\b
\c 28
\s1 Tanukra
\m 
\v 1 Awarni řami teɛdu ssebt, ɣar řefjar n \add wass\add* amezwaru n ssimana, tusa-dd Maryam n Majdala d Maryam nneɣnit ḥima ad ssijjent x wenḍeř. \x ◘ \xo 28:1 \xt [Mk. 16:1-8; Lk. 24:1-12; Yḥ. 20:1-10] \x*
\v 2 Xzar, imsar ijj n wenhezzi n temmurt imɣar, minzi lmalak n SIDI ihwa-dd zeg ujenna, iqarreb-dd, isseqnunni taṣḍart zeg wadaf uca iqqim xas.
\v 3 Tuɣa ṣṣifet nnes am wajjaj u warruḍ nnes d acemřař am wedfeř. \x ◘ \xo 28:3 \xt Dan. 7:9; Řex. 1:10. \x*
\v 4 Iɛessasen fecřen zi teggʷudi zzayes uca dewřen am yimettinen.
\m 
\v 5 Lmalak iṭṭef deg wawař, inna i temɣarin: “War tteggʷedent ca, minzi ssneɣ aqa kennint tarezzunt x Yasuɛ wenni ittwaṣellben. \x ◘ \xo 28:5 \xt Mk. 16:6; Lk. 24:4. \x*
\v 6 War da iǧi, minzi Netta ikkar-dd, am mammec inna. Asent-i-dd da, xzarent amcan mani tuɣa immars Siditneɣ. \x ◘ \xo 28:6 \xt Mt. 16:21; 17:23; 20:19; Mk. 8:31; 9:31; 10:34; Lk. 9:22; 18:33; 24:6. \x*
\v 7 Ruḥent deɣya, inint i imeḥḍaren nnes, aqa ittwassnekkar-dd zi taddart n imettinen, u xzar Netta d awem i ɣa izwaren ɣar Ljalil. Din ad t tẓarem. Xzar, aqa nniɣ awem tt.” \x ◘ \xo 28:7 \xt Mt. 26:32; Mk. 16:7. \x*
\b
\m 
\v 8 Ffɣent nitenti deɣya zeg wenḍeř s tiggʷudi d řefraḥet imɣaren, ttazzřent ḥima ad tt xebbarent imeḥḍaren. \x ◘ \xo 28:8 \xt Mk. 16:8; Yḥ. 20:18. \x*
\v 9 Uca xzar, Yasuɛ iřqa tent \add deg webrid\add*, inna asen: “Sřam xakent!” Nitenti usint-i-dd ɣares, ṭṭfent deg iḍaren nnes uca sejdent as. \x ◘ \xo 28:9 \xt Mk. 16:9; Yḥ. 20:14. \x*
\v 10 Řexdenni inna asent Yasuɛ: “War tteggʷedent ca, ssiwḍent řexbar\add -a\add* i aytma, ḥima ad raḥen ɣar Ljalil, diha ad ayi ẓaren.” \x ◘ \xo 28:10 \xt Řex. 1:3; 13:31; 1 Kur. 15:5. \x*
\b
\m 
\v 11 Am ruḥent, xzar, aqa ca zeg iɛessasen usin-dd ɣar tendint, ḥima ad xebbaren imeqqranen n ikehhanen x marra min imsaren.
\v 12 Řexdenni munen nitni ak-d imɣaren \add n řgens\add* uca mcawaren akidsen, \add uca\add* wcin asen i iɛessasen \add ttmenyat n\add* nnuqart, war iǧi drus,
\v 13 nnan: “Inim: ‘Imeḥḍaren nnes usin-dd s ǧiřet uca ucaren t am tuɣa neṭṭeṣ!’
\v 14 Mařa isřa i-t lɛamil, ad t nesseqneɛ uca ad negg war tᵉttiřim deg imunas.”
\v 15 Ṭṭfen \add tmenyat n\add* nnuqart uca ggin am mammec d asen ɛeřmen. \add Ammu\add* i dd-itteffeɣ řexbar-a jar Wudayen ař ass n yiḍa.
\b
\s1 Řumur ameqqran i ubarreḥ n Řexbar Aṣebḥan
\m 
\v 16 Ḥiṭac n imeḥḍaren nni ruḥen ɣar Ljalil, ɣar wedrar mani ten yumur Yasuɛ. \x ◘ \xo 28:16 \xt [Mk. 16:14-18; Lk. 24:36-49; Yḥ. 20:19-23; Uf. 1:6-8] — Mt. 26:32; \x*
\v 17 Ařami t ẓrin, sejden as, maca ca cekken.
\v 18 Iqarreb-dd ɣarsen Yasuɛ, issiweř akidsen, inna: “Temmewc ayi marra ṣṣulṭa deg ujenna u x temmurt. Am mammec i d ayi dd-issekk Baba, ammu kenniw i ɣa ssekkeɣ Necc. \x ◘ \xo 28:18 \xt Izhd. 8:7; Mt. 11:27; Lk. 10:22; Yḥ. 3:35; 17:2; 1 Kur. 15:27; Afa. 1:22; Ɛbr. 2:8. \x*
\v 19 Ruḥem, arrem marra řegnus d imeḥḍaren inu u ssɣeḍṣem ten s Yisem n Baba d Mmis d Arruḥ Iqeddsen, \x ◘ \xo 28:19 \xt Mk. 16:15; Yḥ. 15:16. \x*
\v 20 u sřemdem asen ad ṭṭfen di marra min xef kenniw umureɣ zzayes, u xzar, Necc aqa ayi akidwem marra ussan ař qeṭṭu n ddunect.”
\b
\m Aneggar n L’Injil Iqeddsen am mammec t ibarreḥ Matta. \x ◘ \xo 28:20 \xt Yḥ. 14:18. \x* 
