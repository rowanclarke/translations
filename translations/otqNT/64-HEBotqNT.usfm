\id HEB  
\h AR EBREO 
\toc1 AR EBREO Ar he̱ꞌmi bi mꞌe̱mpa ya ebreo 
\toc2 AR EBREO 
\toc3 He. 
\mt1 AR EBREO 
\mt2 Ar he̱ꞌmi bi mꞌe̱mpa ya ebreo 
\c 1  
\s1 Ár Tꞌu̱ Jö bi xikagihu̱ tema ne ár Dada ga pöhu̱ 
\p  
\v 1 Jö nze̱ye̱ ya pengi ba pe̱hna yá mꞌe̱hni mamꞌe̱tꞌo, hagatho bi japabi mi zo ma palehu̱. 
\p  
\v 2 Ne nuya ngöxapayu̱ xi me̱nse̱ ár Tꞌu̱ da zokagihu̱. Gehnu̱ xi zokwabi gatho ár me̱ti, ne bi ꞌye̱ntꞌwa hár ꞌye̱ bi hyoka gatho ar mhetsꞌi ne ar ximha̱i. 
\p  
\v 3 Gehnu̱ togo ñꞌu ár hyatsꞌi ár nsunda ñhe̱hwitho Jö, ne o hár ꞌye̱ da do̱xa xo̱ge, ho̱nse̱ da mönga ár mhö pe̱ꞌsa ar tsꞌe̱di. Gehnu̱ bi xu̱gagihu̱ ma tsꞌokihu̱ mi unga ár tese̱, ne bi hñuxa hár ñꞌe̱i ar Ndö bi ꞌbu̱ mhetsꞌi. 
\p  
\v 4 Ne bi hñuxa ár nsu ár Tꞌu̱ bi döta ya e̱nxe̱. Njapꞌu̱tho ár thuhu bi thuꞌspabi töpa ár nsu yá thuhuꞌu̱. 
\s1 Ár Tꞌu̱ Jö töpa yá nsu ya e̱nxe̱ 
\p  
\v 5 Ngetho tema e̱nxe̱ xi ꞌñemba Jö: 
\q1 Go ma Tꞌu̱ꞌi, 
\q1 nupya di ñꞌudi go ri Dadagi. 
\m Ne embabi manꞌagi: 
\q1 Nuga go ár Dadagi, 
\q1 ha nöꞌö go ma Tꞌu̱. 
\p  
\v 6 Manꞌagi enö núꞌmu̱ ba pe̱hna ár ꞌbe̱tꞌo Tꞌu̱ har ximha̱i: 
\q1 Gatho yá e̱nxe̱ Jö dá ndöñꞌö. 
\p  
\v 7 Ha núꞌmu̱ no̱nga ya e̱nxe̱ enö: 
\q1 Nuyá e̱nxe̱ japi da ñhö, 
\q1 ne nuyá ꞌbe̱go japi da mfagi. 
\p  
\v 8 Ne núꞌmu̱ no̱nga ár Tꞌu̱ enö: 
\q1 Nuna ri ndö, tsi Jö, hiñhamꞌu̱ da götsꞌi, 
\q1 ha nuna ri tsꞌu̱tꞌwi xa nꞌar hoga tsꞌu̱tꞌwi. 
\q1  
\v 9 Xka mö nöꞌö xiñho, ne xka u̱tsa nöꞌö hingi ho. 
\q1 Jange bi hñusꞌa ri nsu togo ri Jö. 
\q1 Bi goxꞌa ar nziki johya, gi töta gatho ri ñꞌohu̱. 
\p  
\v 10 Xi ꞌñenö nꞌe: 
\q1 Nuꞌge, tsi Hmu, ga hyoka ar ximha̱i hár ndu̱i, 
\q1 ne ar mhetsꞌi go xi hyoka ri ꞌye̱. 
\q1  
\v 11 Gathoꞌu̱ ma da götsꞌi, ha nuꞌge gi ꞌbu̱i hiñhamꞌu̱ da göxa ri te. 
\q1 Ne gathoꞌu̱ ma da thege ngu nꞌar dutu. 
\q1  
\v 12 Ngu nꞌar he ma da mꞌa̱tsꞌi ne da ꞌboni. 
\q1 Ha nuꞌge go getꞌaꞌi, 
\q1 ne nuya ri je̱ye̱ hinda ma da thege. 
\p  
\v 13 Ngetho tema e̱nxe̱ xi ꞌñemba njawa: 
\q1 Hñu ha ma ñꞌe̱i ga huxkwi, 
\q1 to̱ꞌmi ga tsiñꞌa nuya ri ñꞌu̱ni ga tse̱pꞌa ha ri wa. 
\p  
\v 14 Gatho ya e̱nxe̱ yá ꞌbe̱go Jö, bi pe̱hni da ma̱xa nuꞌu̱ togo ma da hñönga ar mpo̱ho̱. 
\c 2  
\s1 Nꞌar döta mpo̱ho̱ 
\p  
\v 1 Jange xa ma ga umba ma mu̱ihu̱ ga o̱thu̱ nöꞌö xta o̱hu̱, ne hinga mꞌe̱hu̱. 
\p  
\v 2 Ngetho nunar mhö bi mönga ya e̱nxe̱ bi me̱ꞌsa ár tsꞌe̱di, ne nuꞌu̱ togo himbi ne bi ꞌyo̱te, bi hñönga ár mfe̱i. 
\p  
\v 3 Hinda tsa̱ ga kꞌonthu̱ ꞌmu̱, nuꞌmu̱ hinga suhu̱ nunar döta mpo̱ho̱ xi tꞌakagihu̱. Gese̱ ar tsi Hmu togo bi xikagihu̱, ne mꞌe̱fa bi da̱majöni nuꞌu̱ togo bi ꞌyo̱de. 
\p  
\v 4 Ne gese̱ Jö mi da̱majöni mi ñꞌu ya döta ntꞌudi, ya ꞌbe̱fi hingi tsa̱ da ꞌyo̱tꞌase̱ ar jöꞌi, ne bi hyemba ár Hñö Jö ngu bi neꞌö. 
\s1 Togo unga ar mpo̱ho̱ 
\p  
\v 5 Jö himbi da̱twa ha yá ꞌye̱ ya e̱nxe̱ nunar te xi ꞌñepꞌu̱ ne di no̱ñhu̱pya. 
\p  
\v 6 ꞌBu̱i togo bi da̱majöni habu̱ enö njawa: 
\q1 Teme ar ñꞌo̱ho̱ xa gi beni, 
\q1 wa ar jöꞌi xa gi honi. 
\q1  
\v 7 Txꞌu̱tho bi ꞌbe̱di xka hye̱kwa ya e̱nxe̱. 
\q1 Xa ga umba ar nsunda ne ga hñuꞌspa ár nsu, 
\q1 ne ga ꞌye̱ntꞌwa hár ꞌye̱ gatho nöꞌö xi hyoka ri ꞌye̱. 
\q1  
\v 8 Gatho ga po̱kwa ha yá wa. 
\p Jö togo bi mo̱kwa gatho ha yá wa, hinte bi zo njapꞌu̱tho, mödi hinxta hanthu̱tho xi tho gathoyu̱. 
\p  
\v 9 Ha nupya xta hanthu̱ ar Hesu, nöꞌö togo ꞌra ya tsi pa bi thuxa ha̱i ya e̱nxe̱, xi tꞌumbabi ar nsunda ne ar nsu, ngetho bi tho ar u̱gi núꞌmu̱ mi thökwabi ár te. Njapꞌu̱ xki benga Jö ar Dada nda unga ár te ne nda hwëgagihu̱ ar mpo̱ho̱. 
\p  
\v 10 Gatho te jawa ne janu̱ mhetsꞌi, go bi hyokꞌö ne go o hár ꞌye̱ꞌö. Bi beñꞌö nda zixa nze̱ye̱ yá bötsi hár nsunda, jange bi japi bi tho ya u̱gi ár Tꞌu̱, ne njapꞌu̱ bi hyokwa ár mꞌu̱i yá Po̱ho̱teꞌu̱. 
\p  
\v 11 Ngetho nuꞌu̱ togo xi ntꞌaxkwabi yá te ne nöꞌö togo tꞌaxkwabi, nꞌatho togo yá me̱ti. Jange hingi ntsa̱ embabi gehyu̱ yá ku. 
\p  
\v 12 Ne enö njawa: 
\q1 Ma ga xipabi ri mhö ma ku, 
\q1 Madeda ar mhuntsꞌi ga tutꞌa ya thuhu. 
\p  
\v 13 Ne manꞌagi enö: 
\q1 Nuga ga ñꞌemu̱ibiꞌö. 
\m Ne enö nꞌehe: 
\q1 Di ꞌbu̱ꞌbewa nuya bötsi bi ꞌraka Jö. 
\p  
\v 14 Ngetho nuya bötsi pe̱ꞌsa ha yá ndoꞌyo ar ji ne ar ngo̱, nöꞌö nꞌehe bi mꞌu̱i njapꞌu̱. Ne núꞌmu̱ mi du, bi hwata togo hö ar ndöte, gehnu̱ ar tsꞌondöhi. 
\p  
\v 15 Ne njapꞌu̱ bi umba ar hogamꞌu̱i nuꞌu̱ togo mi ꞌbu̱i mi pe̱pa ar ndöte ngetho mi tsuꞌu̱. 
\p  
\v 16 Nunu̱ himba ehe bi ma̱xa ya e̱nxe̱, ba ehe bi ma̱xa yá ꞌbe̱to ar Abra. 
\p  
\v 17 Jange mi mahyoni nda ñhe̱hwi nuyá ku. Ne bi ndöngamöjö xa pe̱ꞌsa ar nhwëki, ne o̱tꞌa gatho nöꞌö di ꞌñepi hár ꞌbe̱fi Jö. Ne bi unse̱ ár te ngu nꞌar mꞌo̱ñho̱ da gutꞌwa yá tsꞌoki ya meximha̱i. 
\p  
\v 18 Ngetho gese̱ꞌö bi tho ar tsꞌa̱ti, jange pe̱ꞌsa ar tsꞌe̱di da ma̱xa nuꞌu̱ togo tsꞌa̱ti. 
\c 3  
\s1 Ar tsi Hmu Hesu töpa ár nsu ar Moise 
\p  
\v 1 Jange tsi kuhu̱, xi tꞌaxkꞌaꞌihu̱ ri mꞌu̱ihu̱ ne xi tsꞌoñꞌahu̱ ma gi ꞌbu̱hu̱ mhetsꞌi, beñhu̱ ar tsi Hmu Hesukristo, ár mpo̱te Jö ne ar döngamöjö togo tsiska ma jamfihu̱. 
\p  
\v 2 Nunu̱, o̱tꞌa xiñho ngu xi xipabi nöꞌö togo xi ꞌñetsꞌi, ngu bi ꞌyo̱tꞌa ar Moise nꞌehe hár nijö Jö. 
\p  
\v 3 Mahyoni di töte ar nsu di tꞌumba ar tsi Hmu Hesu, mꞌe̱fa ar Moise. Ngu di töte ar nsu di tꞌumba nꞌa di hoka ar ngu, ne mꞌe̱fa ar nguse̱. 
\p  
\v 4 Ngetho ja togo hoka nꞌar ngu, ha Jö bi hyoka gatho. 
\p  
\v 5 Majöni ar Moise bi ꞌyo̱tꞌa gatho nöꞌö xki xipa Jö nda ꞌyo̱tꞌa hár nijö, ngu ár ꞌbe̱go. Gehnu̱ bi da̱majöni nöꞌö ma nda mhönga mꞌe̱fa. 
\p  
\v 6 Ha nunar tsi Hmu Hesukristo, ngu nꞌar tꞌu̱ su xiñho ar ngu. Ne nuju̱ go dar nguhu̱ nuꞌmu̱ hinga he̱hu̱ ar ndo̱ꞌmi, ne ga tse̱thu̱ ma jamfihu̱ ga to̱ꞌmhu̱ da göxa xo̱ge. 
\s1 Ár tsa̱ya̱ yá bötsi Jö 
\p  
\v 7 Jange ngu enga ár Hñö Jö: 
\q1 Nuꞌmu̱ ar pania gi ꞌyo̱ꞌsfu̱ ár mhö Jö, 
\q1  
\v 8 yo gi kothu̱ ri mu̱ihu̱ ngu bi ꞌyo̱tꞌa ri palehu̱ nunar pa bi tso̱tꞌwa ár mu̱i Jö, ba tsa̱tnu̱ har otꞌatꞌo̱ho̱. 
\q1  
\v 9 Ka gehnu̱ ri palehu̱ bi tsa̱tkagi ne bi hyomgagiꞌu̱. 
\q1 Yonꞌa̱te nje̱ye̱ bi hyandga ma döta ntꞌudi ndi o̱tꞌwabiꞌu̱. 
\q1  
\v 10 Jange bi po̱nka ma kwe̱ gatho nuya jöꞌi mi ꞌbu̱ nuya paꞌu̱. 
\q1 Ne da ense̱ga: 
\q1 Hingi tsa̱ya̱ te gatho benda ha yá mu̱i, 
\q1 ne hinxi bötka ma ꞌñu. 
\q1  
\v 11 Ngetho xki mbo̱ ma kwe̱, da etꞌase̱ made ma te, 
\q1 hinda ma da yu̱tꞌa har tsa̱ya̱ di uni. 
\p  
\v 12 Tsi kuhu̱, hyanthu̱ hinte di ꞌbu̱pꞌu̱ nꞌa di pe̱ꞌsa nꞌar tsꞌomu̱i hingi ne da ñꞌemu̱i, ne da ꞌwe hár ꞌñu Jö togo hö ar te. 
\p  
\v 13 Nöꞌö gi ꞌyo̱thu̱, hñuꞌmba ár mu̱i ri kuhu̱ nꞌa ngu nꞌa hyaxꞌmu̱, núpya tsa̱ ga eñhu̱ di ꞌbu̱hu̱ ar pania. Hingi hye̱hu̱ da me ri mu̱ihu̱ gi o̱xu̱ yá nhemhñö ar tsꞌoki. 
\p  
\v 14 Ngetho nuꞌmu̱ xi tꞌakagihu̱ ar se̱ki ga ꞌbu̱hwihu̱ ar tsi Hmu Hesukristo, da njapꞌu̱ nuꞌmu̱ ho̱nse̱ hinga he̱hu̱ nunar ñꞌemu̱i da pe̱ꞌsu̱ hár ndu̱i. 
\p  
\v 15 Núpya tsa̱ gi ꞌyo̱hu̱ da tꞌenö: 
\q1 Nuꞌmu̱ ar pania gi ꞌyo̱ꞌsfu̱ ár mhö Jö, 
\q1 yo gi kotꞌa ri mu̱ihu̱, ngu bi ꞌyo̱tꞌa ri palehu̱ nunar pa bi ntso̱tꞌwa ár mu̱i Jö. 
\p  
\v 16 Togoꞌu̱ bi ꞌyo̱twa ár mhö Jö ne bi tso̱tꞌwa ár mu̱i. Hage hinge nuꞌu̱ ba ju̱ka ar Moise har ha̱i Ehipto. 
\p  
\v 17 Togo xi tso̱tꞌwa ár mu̱i yonꞌa̱te nje̱ye̱. Hage hinge nuꞌu̱ togo bi ꞌyo̱tꞌa ya tsꞌoki, ne bi go yá ndoꞌyo ha ya otꞌatꞌo̱ho̱. 
\p  
\v 18 Ne togo bi ꞌñetꞌase̱ made ár te, bi ꞌñembabiꞌu̱ hinge nda hñönga ar tsa̱ya̱ uñꞌö. Hage himbi xipabi njapꞌu̱ nuꞌu̱ togo himbi ꞌyo̱te. 
\p  
\v 19 Ne da nuhu̱ himbi yu̱tꞌu̱, ngetho himbi ñꞌemu̱i. 
\c 4  
\p  
\v 1 Jange ma ga tsuñhu̱ nöꞌö te di pe̱ꞌsu̱ ꞌmu̱. Ngetho mödi di pe̱ꞌsthu̱ ar ñhötꞌi bi ꞌrakagihu̱ ga ku̱thu̱ hár tsa̱ya̱, xiꞌmu̱ ꞌra hingi tsu̱hu̱. 
\p  
\v 2 Ngetho nuju̱ nguꞌu̱ xi nsikagihu̱ ar hoga mhö. Ha nuꞌu̱ hinte mañho bi nhwëkwabi, ngetho bi kꞌatꞌa yá ñꞌemu̱i nuꞌu̱ togo bi ꞌyo̱de. 
\p  
\v 3 Ne nuju̱ xta ñꞌemu̱ihu̱, di ꞌbu̱hu̱ hár tsa̱ya̱, ngu bi ꞌñeñꞌö: 
\q1 Númꞌu̱ mi mbo̱ ma kwe̱ da ꞌñetꞌase̱ made, 
\q1 hinge nda yu̱tꞌu̱ ha ma tsa̱ya̱. 
\m Mödi ár ꞌbe̱fi Jö bi wadi núꞌmu̱ mi jwata ar ximha̱i. 
\p  
\v 4 Ngetho ja nꞌa xe̱ni har tꞌofo habu̱ no̱nga ar yoto mpa, ne enga njawa: 
\q1 Bi ntsa̱ya̱ Jö bi wa gatho yá ꞌbe̱fi har yoto mpa. 
\p  
\v 5 Ne manꞌagi habu̱ enö: 
\q1 Hinda ma da yu̱tꞌu̱ ha ma tsa̱ya̱. 
\p  
\v 6 Jange kꞌatꞌa ꞌra da yu̱tꞌi, ha nuꞌu̱ togo bi tꞌumbabi mꞌe̱tꞌo ar hoga mhö himbi yu̱tꞌu̱ ngetho ya me̱ꞌsku. 
\p  
\v 7 Manꞌagi huxa nꞌar pa: ar pania. Ngu bi ꞌyotꞌa ar Dabi xki tho nze̱ye̱ ya je̱ye̱, habu̱ enö: 
\q1 Nuꞌmu̱ ar pania gi ꞌyo̱ꞌsfu̱ ár mhö Jö, 
\q1 yo ma gi kotꞌa ri mu̱ihu̱. 
\p  
\v 8 Ngetho nuꞌmu̱ ar Hosue xi umbahmö ar tsa̱ya̱, hinxi no̱mhö manꞌar pa ꞌmu̱. 
\p  
\v 9 Pongda nꞌar tsa̱ya̱ ꞌmu̱, to̱ꞌma yá bötsi Jö. 
\p  
\v 10 Ngetho nuꞌu̱ togo xi yu̱tꞌa hár tsa̱ya̱, xi hye̱pꞌu̱ ár ꞌbe̱fi, ngu Jö xi hye̱pꞌu̱ ár me̱tiꞌö. 
\p  
\v 11 Ma ga umba ma mu̱ihu̱ ga ku̱thu̱ har tsa̱ya̱, ne hinto da de̱mba yá tsꞌoꞌbe̱fi nuꞌu̱ togo himbi ne bi ꞌyo̱te. 
\p  
\v 12 Ngetho ár mhö Jö te, ne gatho tsa̱ da ꞌyo̱tꞌe. Töta ár ñho nꞌar ndo̱jwai di he̱nte ár hmi ne ár xu̱tha, ne ku̱tꞌa ya mbo da hye̱kwa ár pa ne ár hñö nꞌar jöꞌi. Da zo̱nga ha yá nto̱kndoꞌyo ne yá ngöbo, ne pötwathobi yá mfeni ne teme kwata hár mu̱i. 
\p  
\v 13 Hiñꞌotho tema xi hyokꞌö ne hinda ma da mꞌu̱ hár nthandi. Gatho te ja handatho, ngu xoxtho ne hingi joꞌmi hár da̱ nöꞌö togo ma ga da̱twabihu̱ majöni. 
\s1 Ar tsi Hmu Hesu ar Döngamöjö 
\p  
\v 14 Di ꞌñehu̱ nꞌar döngamöjö togo bi yu̱tꞌa mhetsꞌi, ar tsi Hmu Hesu ár Tꞌu̱ Jö. Jange ga suhu̱ nunar jamfinu̱ di te̱ñhu̱. 
\p  
\v 15 Ngetho hindi ꞌñehu̱ nꞌar döngamöjö nöꞌö hingi ne da me̱skagihu̱ ar tse̱ti ma ngwentꞌihu̱. Di ꞌñehu̱ nꞌa togo bi tsꞌa̱ti nguju̱ nꞌehe, mödi himbi ꞌyo̱tꞌa ar tsꞌoki. 
\p  
\v 16 Ma ga kwathu̱ ꞌmu̱ hár thuxandö unga ar nthekate, hinge ga ntsuhu̱. Ne ga tsu̱thwu̱ ár nhwëki, da hwëgagihu̱ ár mfa̱tsꞌi núꞌmu̱ di hoñhu̱. 
\c 5  
\p  
\v 1 Nꞌar döngamöjö xi thahna ha ya jöꞌi, xi tꞌetsꞌi da po̱ta da mꞌa̱ hár nthandi Jö, ne da unga ya mꞌo̱ñho̱, ne njapꞌu̱ da mpumba yá tsꞌoki ya jöꞌi. 
\p  
\v 2 Nöꞌö tsa̱ da me̱ꞌspa ar tsꞌe̱ti nuꞌu̱ xi mꞌe̱di ne hinte pödi, ngetho gese̱ꞌö tsa̱ da hya̱tꞌa ár mfeni ne da ꞌyo̱tꞌa ar tsꞌoki nꞌehe. 
\p  
\v 3 Jange núꞌmu̱ po̱xa ar mꞌo̱ñho̱, o̱tꞌa njapꞌu̱ honi da mpumba maꞌra, ne da mpumbase̱ yá tsꞌoki nꞌehe. 
\p  
\v 4 Hinga gatho tsa̱ da gu̱se̱ nunar ꞌbe̱finu̱ xa pe̱ꞌsa ar nsu, ho̱nse̱ nuꞌmu̱ da zohna Jö ngu bi zohna ar Aron. 
\p  
\v 5 Njapꞌu̱ ar tsi Hmu Hesukristo himbi ñꞌexase̱ ngu ar döngamöjö. Bi hñuxa togo bi mönga njawa: 
\q1 Go ma Tꞌu̱ꞌi, 
\q1 ha nupya di ñꞌudi go ri Dadagi. 
\p  
\v 6 Ne ngu enga manꞌa xe̱ni nꞌehe: 
\q1 Nuꞌge gar döngamöjö hiñhamꞌu̱ da götsꞌi, 
\q1 ngu bi tꞌexa ar Melkisedek. 
\p  
\v 7 Ar tsi Hmu Hesukristo núꞌmu̱ ba ekwa bi njöꞌi, xa mi umba ár mu̱i mi zoni, mi a̱pa nöꞌö togo mi pe̱ꞌsa ar tsꞌe̱di nda ñönga har ndöte. Ne bi tꞌumbabi nöꞌö mi a̱di, ngetho mi pe̱ꞌsa ar ntsu ne mi eꞌspa ár nsu togo bi ma̱tsꞌi. 
\p  
\v 8 Mödi mar tꞌu̱mhö, nuya u̱gi bi thogi bi uti hanja nda ꞌyo̱de. 
\p  
\v 9 Ne njapꞌu̱ bi ñꞌu ár tsꞌe̱di da umba nꞌar mpo̱ho̱ hiñhamꞌu̱ da göxa gatho nuꞌu̱ togo da ꞌyo̱te. 
\p  
\v 10 Ne Jö bi hñuxa ngu ar döngamöjö, ngu ar nsu mi pe̱ꞌsa ar Melkisedek. 
\s1 Ar mhö xikagihu̱ hinga he̱hu̱ ar ꞌñu majöni 
\p  
\v 11 Ja nze̱ye̱ te ga möñhu̱ nunar mhönu̱ xta no̱ñhu̱, mödi hingi tsa̱ ga utꞌahu̱ xo̱ge, ngetho xka kotꞌa ri mu̱ihu̱ hingi ne gi pöhu̱ nöꞌö tꞌutꞌahu̱. 
\p  
\v 12 Ngetho nze̱ye̱ nuya je̱ye̱ xi thogi, xi za̱mhö gi uthu̱ maꞌra. Ha gi hoñhu̱tho da tꞌutꞌahu̱ nunár ndu̱i ár mhö ar tsi Hmu, ngu nꞌar le̱le̱ ne da tꞌumbatho ar ꞌba, hinge ar ñhuni. 
\p  
\v 13 Ne gatho nuꞌu̱ ngu ya le̱le̱ tsu̱tho, hingi pötho tema xiñho ne tema hingi ho. 
\p  
\v 14 Ha nuꞌu̱ togo xi ñötsꞌi, xi bötwabi ar ñhuni, xi xo yá mfeni, ne pödi ndana xiñho ne ndana hingi ho. 
\c 6  
\p  
\v 1 Jange ga umba ma mu̱ihu̱ ga hoñhu̱ da ñöxa ma ñꞌemu̱ihu̱. Hinga ñhogamu̱ihu̱tho nunár ntꞌuti ar tsi Hmu Hesukristo ndi pöhu̱ nda ndu̱hu̱ da ñꞌemu̱ihu̱. Hinga penju̱ ga huxa ma mfenihu̱ nuya ntꞌuti da pöhu̱ mꞌe̱tꞌo. Nöꞌö ga pe̱hu̱, ga he̱hu̱ di thöꞌthu̱ ga o̱thwu̱ ár ntso̱ꞌmi, wa ga tho̱hu̱pꞌu̱ ya ꞌbe̱fi tsixju̱ har ndöte, ga tho̱hu̱ di no̱ñhu̱ ar mpo̱ho̱ bi e har ñꞌemu̱i Jö. 
\p  
\v 2 Ne nuya ntꞌutiyu̱, ar xixthe, ar thuꞌspa ár ꞌye̱ manꞌa, ár menga nte nuꞌu̱ xi du, ne ar pa da thöxamajöni habu̱ da tꞌumba nöꞌö di ꞌñepi hiñhamꞌu̱ da götsꞌi. 
\p  
\v 3 Gehnu̱ ma ga o̱thu̱ nuꞌmu̱ da ma̱xkagihu̱ Jö. 
\p  
\v 4 Ngetho nꞌa togo xi mꞌu̱ har hyatsꞌi, ne xi za̱ ar ntꞌuni di ꞌñe mhetsꞌi, ne xi me̱ꞌspa ár Hñö Jö, 
\p  
\v 5 xi za̱pa ár hoga mhö Jö ne ár tsꞌe̱di nuna te xi ꞌñepꞌu̱, 
\p  
\v 6 nuꞌmu̱ da da̱gi, hinda tsa̱ da njapabi da ꞌyo̱tꞌwa ár ntso̱ꞌmi manꞌagi. Ngetho po̱ntho pengi tsu̱tꞌwa ár Tꞌu̱ Jö har pontꞌi, ꞌbe̱twa ár tsa̱ njapꞌu̱ hár nthandi gatho ya jöꞌi. 
\p  
\v 7 Jangu nꞌar ha̱i hingi tsa̱ya̱ hönga ar ꞌye, ne umba ya hoga do̱ni nuꞌu̱ togo wöhi, hömba ár njöpi Jö. 
\p  
\v 8 Ha nunar ha̱i unga ya ꞌmini hingi nheꞌö, txꞌu̱tho ꞌbe̱di da tsꞌani, ne mꞌe̱fa da tsꞌötꞌi. 
\p  
\v 9 Di xiꞌahe njanu̱ tsi kuhu̱, ha di ka̱xmbenihe gi to̱ꞌmhu̱ ya ñho di ehwi ar mpo̱ho̱. 
\p  
\v 10 Ngetho Jö pe̱ꞌsa nꞌar hogamu̱i, ne hinda ma da pumhni ri ꞌbe̱fihu̱, ne nöꞌö ar ñho xka ꞌyo̱thwu̱ ya gamfi, ne hinxka hye̱hu̱ gi o̱thu̱, njapꞌu̱ gi ñꞌuhu̱ gi pe̱ꞌsfu̱ ár mhöte Jö. 
\p  
\v 11 Nuje di nemhöhe, nꞌa ngu nꞌa xa gi umba ri mu̱ihu̱ gi ꞌyo̱thu̱ njapꞌu̱ gatho ri tehu̱, ne hinda kꞌatꞌa ri ndo̱ꞌmhu̱. 
\p  
\v 12 Hindi nehe gi ndöhñehu̱. Nöꞌö gi ꞌyo̱thu̱, te̱mfu̱ yá mꞌu̱i nuꞌu̱ pe̱ꞌsa ar jamfi ne ar tsꞌe̱ti hönga ya ñhötꞌi. 
\p  
\v 13 Núꞌmu̱ Jö bi umba ar ñhötꞌi ar Abra, ngetho himi otho manꞌa togo di döta nda ꞌñetꞌa made, bi ꞌñetꞌase̱ made ár thuhu. 
\p  
\v 14 Bi ꞌñenö: Majöni xa ma ga jöpꞌaꞌi ne ga jaꞌi gi nxöndi. 
\p  
\v 15 Ne ar Abra bi me̱ꞌsa ar tsꞌe̱ti bi do̱ꞌmi, jange bi hñönga ar ñhötꞌi. 
\p  
\v 16 Majöni ya ñꞌo̱ho̱ etꞌa made nꞌa di töte ar döta, ne o̱tꞌa njapꞌu̱ hindi njoꞌo togo da ꞌñembi hingi njapꞌu̱ teme mö. Jange nuꞌu̱ te etꞌa made, enga njapꞌu̱ nöꞌö mö. 
\p  
\v 17 Jö mi ne nda ꞌyotꞌwa ár ꞌñu xiñho nuꞌu̱ togo ma nda gohwi ár me̱tiꞌö, ngetho hingi pa̱ta ár ne te xi mö, jange bi ꞌñetꞌa made ár thuhuse̱. 
\p  
\v 18 Jö bi zoju̱ ár ñhötꞌi ne ár ntꞌetꞌamade. Nuya yohoyu̱ hingi tsa̱ da mpa̱ti, ne Jö hingi tsa̱ da mönga nꞌar nhemhñö. Njapꞌu̱ xa hñubgagihu̱ ma mu̱ihu̱ ga to̱ꞌmhu̱ nöꞌö xi ꞌbo̱skagihu̱ núya xta ehu̱ ga kwathu̱ hár ndo̱ꞌmi. 
\p  
\v 19 Numa ndo̱ꞌmihu̱ to̱ska ma pahu̱, ñhe̱hwi ngu nꞌar bo̱jö xiñhu̱ to̱ꞌsa nꞌar motsa. Nunar ndo̱ꞌminu̱ foxa mbo mo̱te ar xu̱nidutu habu̱ ꞌbu̱ ár nsunda Jö. 
\p  
\v 20 Gehnu̱ habu̱ bi yu̱tꞌa mꞌe̱tꞌo ar tsi Hmu Hesukristo, mꞌe̱fa nga te̱ñhu̱ nꞌehe. Njapꞌu̱ bi tꞌetsꞌi ngu ar döngamöjö hiñhamꞌu̱ da götsꞌi, ngu ar nsu bi me̱ꞌsa ar Melkisedek. 
\c 7  
\s1 Ar ꞌbe̱fi ngu ar döngamöjö bi me̱ꞌsa ar Melkisedek 
\p  
\v 1 Nunar Melkisedek mar ndö har ha̱i Salem, ne már möjö Jö bi ꞌbu̱ mhetsꞌi. Bi bo̱ni ma ba thö ar Abra mi pengi xki ma ba hwata ya ndö, ne bi jöpi. 
\p  
\v 2 Ne ar Abra bi umba ár ꞌre̱tꞌa xe̱ni gatho nöꞌö mi hö. Nunar thuhu Melkisedek po̱ni da ꞌñenö, ar ndö o̱tꞌa ar hoga tsꞌu̱tꞌwi. Ne már ndö har ha̱i Salem, ne da ꞌñenö, ar ndö unga ar hogamꞌu̱i. 
\p  
\v 3 Hindi pöthwu̱ ár dada, ár nönö, yá pale. Hindi pöhu̱ hanja bi mꞌu̱i, hanja bi du, njangu ár Tꞌu̱ Jö, gehnu̱ ar möjö hiñhamꞌu̱ da göxa ár nsu. 
\p  
\v 4 Beñhu̱ ꞌmu̱ tengu mar döta ár nsu mi pe̱ꞌsa nunar Melkisedeknu̱. Ngetho nuna ma palehu̱ ar Abra, himbi kꞌontꞌi nda umba ár ꞌre̱tꞌa xe̱ni nöꞌö xki hñömba ya ndö bi döꞌö. 
\p  
\v 5 Majöni nuya xi ꞌñe ha yá ꞌbe̱to ar Lebi, gehyu̱ hönga ar ꞌbe̱fi ngu ar möjö. Xi mꞌe̱pabi da hñönga ár ꞌre̱tꞌa xe̱ni ngu mönga ha ya ꞌbe̱pate, mödi jotꞌwa yá ku, ngetho nuyu̱ xpa po̱nga ha yá bötsi ar Abra nꞌehe. 
\p  
\v 6 Ha nunar Melkisedek togo hinxpa ꞌñe ha yá ꞌbe̱to ar Lebi, bi hñönga ár ꞌre̱tꞌa xe̱ni bi umba ar Abra, togo xki hñönga ar ñhötꞌi, ne bi jöpabi. 
\p  
\v 7 Ne di pöhu̱ xiñho nöꞌö togo töte ár nsu, go unga ar njöpiꞌö. 
\p  
\v 8 Nuya möjö togo hönga ar ꞌre̱tꞌa xe̱ni, gehyu̱ ya ñꞌo̱ho̱ the yá te, ha nunar Melkisedek mhö nunu̱ tetho, hinxi du. 
\p  
\v 9 Ma ga möñhu̱ núꞌmu̱ mi unga ár ꞌre̱tꞌa xe̱ni ar Abra, po̱ntho bi gutꞌa yá ꞌbe̱to ar Lebi nꞌehe, ha nupya jotꞌa nuꞌu̱ xpa ehnu̱. 
\p  
\v 10 Ngetho ar Lebi hinxki mꞌu̱tho. Mꞌe̱fa ba e ha yá ꞌbe̱to ar Abra togo xki ma ba tsu̱ ar Melkisedek. 
\p  
\v 11 Nuꞌmu̱ da tꞌaxka yá te ya jöꞌi ha yá ꞌbe̱fi ya möjö yá ꞌbe̱to ar Lebi, ne ha ya ꞌbe̱pate bi tꞌunga nuyá pa ya möjöyu̱, yoꞌö ba pe̱hna Jö manꞌar möjö di pe̱ꞌspa ár nsu ar Melkisedek, ne himi pe̱ꞌspa ár nsu ar Aron. 
\p  
\v 12 Ha nuꞌmu̱ da ꞌba̱ta ar möjö, mahyoni da ꞌba̱ta ya ꞌbe̱pate nꞌehe. 
\p  
\v 13 Ne nöꞌö togo mhö, nꞌañꞌo yá pale, nuyá mëni hinto bi mpe̱ har nijö. 
\p  
\v 14 Gatho pödi, nuna ma tsi Hmuhu̱ ba e ha yá ꞌbe̱to ar Huda, ha nunar Moise hinte bi no̱ni ha nda nmöjöyu̱. 
\p  
\v 15 Ne xa nhekitho, nuꞌmu̱ da nanga manꞌar möjö nꞌañꞌo di pe̱ꞌspa ár nsu ar Melkisedek, hinxpa e ha yá ꞌbe̱to ar Aron. 
\p  
\v 16 Hinxki tꞌetsꞌi ngu enga har ꞌbe̱pate no̱nga ar jöꞌi da zokwa yá ꞌbe̱to. Ha nupya xi hñönga togo pe̱ꞌsa ar te hinda ma da götsꞌi. 
\p  
\v 17 Xi nda̱majöni nho̱ñꞌö habu̱ enö: 
\q1 Nuꞌge gar möjö hiñhamꞌu̱ da the ri tsꞌe̱di, 
\q1 gi pe̱ꞌspa ár nsu ar Melkisedek. 
\p  
\v 18 Xi thöka nunar ꞌbe̱tꞌo ꞌbe̱pate ꞌmu̱, himi pe̱ꞌsa ar tsꞌe̱di, ne himbi tsa̱ bi ꞌyo̱tꞌa nöꞌö mi mahyoni nda ꞌyo̱tꞌe. 
\p  
\v 19 Ya ꞌbe̱pate hinto bi umba nꞌar hogamꞌu̱i, ha nu mi tꞌunga nꞌar ꞌraꞌyo ndo̱ꞌmi xa töte ár ñho, fa̱xkagihu̱ ga kwathu̱ ga hoñhu̱ Jö. 
\p  
\v 20 Ne Jö bi ꞌñetꞌase̱ made ár thuhu bi no̱ñꞌö. 
\p  
\v 21 Ngetho majöni nu maꞌra ya möjö bi tꞌetsꞌi ne hinto bi tꞌetꞌa made. Ha nunu̱ hö, bi ꞌñetꞌa made nu togo bi ꞌñetsꞌi, bi ꞌñembabi: 
\q1 Bi ꞌñetꞌa made ár thuhu ar tsi Dada, ne hinda ma da pa̱ta ár ne. 
\q1 Bi ꞌñenö: 
\q1 Nuꞌge gar möjö gi pe̱ꞌspa ár nsu ar Melkisedek, 
\q1 hiñhamꞌu̱ da göxa ri tsꞌe̱di. 
\p  
\v 22 Ar tsi Hmu Hesu ꞌba̱ made, japi da tho nunar nkohinu̱ xa töte ár ñho. 
\p  
\v 23 Numaꞌra ya möjö bi nja nze̱ye̱, ngetho nda du ne himi tsa̱ nda mpe̱ nze̱ye̱ ya pa. 
\p  
\v 24 Ha nunu̱ hiñhamꞌu̱ da göxa ár te, jange pe̱ꞌsa ar ꞌbe̱fi möjö hiñhamꞌu̱ da thege. 
\p  
\v 25 Jange hyaxꞌmu̱ tsa̱ da po̱ho̱ nuꞌu̱ ñꞌemu̱ibiꞌö ne da e da watꞌi da hyonga Jö, ne hingi tsa̱ya̱ a̱pa Jö da ma̱xꞌu̱. 
\p  
\v 26 Ngetho nunar döngamöjönu̱, gehnu̱ ndi hoñhu̱: Ár mꞌu̱i xintꞌaxi, hingi pödi da ꞌyo̱tꞌa ar tsꞌoki, hinxi ja̱xtꞌa ár mꞌu̱i, hingi nthöskwi ya ꞌyo̱tꞌatsꞌoki, ne bi tsꞌixa mhetsꞌi ba ꞌbu̱hwi Jö. 
\p  
\v 27 Nuꞌmú̱, hinge mahyoni hyaxꞌmu̱ da unga nꞌár mꞌo̱ñho̱ ne da mpumbabi yá tsꞌokise̱, ne mꞌe̱fa da unga nuyá me̱ti ya jöꞌi, ngu o̱tꞌa nu maꞌra ya döngamöjö. Ngetho nunu̱, bi unse̱ ár te nꞌagitho, ne hiñhamꞌu̱ da unga manꞌagi. 
\p  
\v 28 Ngetho ya ꞌbe̱pate exa ngu ya döngamöjö ya jöꞌi hiñꞌotho yá tsꞌe̱di. Ha núꞌmu̱ mi tho ya ꞌbe̱pate, bi ꞌñetꞌase̱ made ár thuhu Jö, nda ꞌñexa ár Tꞌu̱ xa ja ár tsꞌe̱di, hiñhamꞌu̱ da the ár nsu. 
\c 8  
\s1 Nóꞌö ꞌba̱ made e̱nga ar ꞌraꞌyo nkohi 
\p  
\v 1 Gatho nuna xta möñhu̱, ho̱nse̱nu̱ di ne da zo ri mfenihu̱: Di pe̱ꞌsu̱ nunar döngamöjönu̱, togo bi hñuxnu̱ hár ñꞌe̱i ár thuxandö Jö mhetsꞌi. 
\p  
\v 2 Bi mpe̱ habu̱ majöni ar dönganijö xi hyokase̱ Jö, hinge ar meximha̱i. 
\p  
\v 3 Ngetho gatho ya döngamöjö, xi thutsꞌi da mo̱xa ya mꞌo̱ñho̱ ne ya ñhötꞌi. Jange nunu̱ nꞌehe mahyoni di pe̱ꞌsa te da mo̱ꞌspa Jö. 
\p  
\v 4 Nuꞌmu̱ di ꞌbu̱hmöwa har ximha̱i, hindar nmöjöhmöꞌö, ngetho jawa ya möjö po̱xa ya mꞌo̱ñho̱ ngu mönga yá ꞌbe̱pate ar Moise. 
\p  
\v 5 Nuꞌu̱ pe̱pa nöꞌö di hñötsꞌi ne ar xuditho nu te janu̱ mhetsꞌi. Ngu bi tꞌuta ar Moise núꞌmu̱ ma nda hyokwa ár ngu Jö, ne bi tꞌembabi: Hyanda xiñho gi hyoka ngu xi tꞌutꞌaꞌi har tꞌo̱ho̱. 
\p  
\v 6 Ha nupya nunar döngamöjönu̱ di te̱ñhu̱, xa döta ár ꞌbe̱fi, ngetho ꞌba̱ made e̱nga nunar ꞌraꞌyo nkohi. Gehnu̱ xi tꞌunga mahye̱giwi maꞌra ya ñhötꞌi xa töte yá ñho. 
\p  
\v 7 Ngetho nuꞌmu̱ nunar ꞌbe̱tꞌo nkohi di pe̱ꞌshmö ár tsꞌe̱di, hinge mi mahyoni nda tꞌumhö manꞌa ꞌmu̱. 
\p  
\v 8 Gese̱ Jö himbi numañho ár ꞌbe̱fi ya me Israel, jange bi zu̱i bi ꞌñembabiꞌu̱: 
\q1 Ar tsi Hmu enö: Ma da zo̱ ya pa 
\q1 ga nkoꞌbe ya me Israel ne ya me Huda manꞌar ꞌraꞌyo nkohi. 
\q1  
\v 9 Hinge ngu nunar nkohi da nkoꞌbe yá pale, 
\q1 núꞌmu̱ nda mipa yá ꞌye̱ da ju̱ka har ha̱i Ehipto. 
\q1 Ngetho nuꞌu̱ himbi umbyá mu̱i bi ꞌyo̱tꞌa nöꞌö da nkoꞌbe, 
\q1 ne nuga da he̱kaꞌu̱, enga njapꞌu̱ ar tsi Hmu. 
\q1  
\v 10 Nu xta tho nuya paꞌu̱, gehnu̱ ar nkohi ma ga nkoꞌbe ya me Israel, enga ar tsi Hmu: 
\q1 Ma ga otꞌwa ma ꞌbe̱pate ha yá mfeniꞌu̱, 
\q1 ne ma ga kötꞌwa ha yá mu̱i. 
\q1 Ma ga ꞌbu̱i ngu ár Jögi, 
\q1 ne ma ga nugaꞌu̱ ngu ma bötsi. 
\q1  
\v 11 Hinto ma da uta ár ñꞌohu̱, 
\q1 hinto ma da uta ár ku, di embabi: 
\q1 Pödi togo ar tsi Hmu. 
\q1 Ngetho gatho ma da bökagi, 
\q1 di ndu̱ nöꞌö tsi tꞌu̱lo, ne di göxa nöꞌö döta. 
\q1  
\v 12 Ma ga pumbabi yá tsꞌoki, 
\q1 hinga ma ga pengi ga bemba nöꞌö hingi njapꞌu̱ bi ꞌyo̱tꞌu̱. 
\p  
\v 13 Nuꞌmu̱ enö nꞌar ꞌraꞌyo nkohi, xi gönga nöꞌö manꞌa ꞌmu̱. Ha nöꞌö enö bi göngi ne bi thege, txꞌu̱tho ꞌbe̱di da mꞌe̱di. 
\c 9  
\s1 Ar nijö habu̱ mi ndönga Jö nuwa har ximha̱i, ne nöꞌö bi japꞌu̱ mhetsꞌi 
\p  
\v 1 Ha nunar ꞌbe̱tꞌo nkohi, Jö xki xipabi ya jöꞌi hanja nda ndömbabi har nijö mi ꞌbu̱kwa har ximha̱i. 
\p  
\v 2 Ne nunar nijö mi njanu̱: Har ñu̱tꞌi habu̱ mi tꞌembabi Mar Nsunda, ka mi ꞌbu̱hnu̱ ar mfoxꞌyo, ar mexa ne ya thuhme mi tꞌeꞌspabi Jö. 
\p  
\v 3 Ne mo̱te ár ñoho ar döta dutu, mi juta nöꞌö manꞌár xe̱ni ar nijö mar thuhu Xa Ar Nsunda. 
\p  
\v 4 Ka mi ꞌbu̱hnu̱ nꞌar ntꞌutsꞌi xki thoka ar kꞌaxtꞌabo̱jö, ne ar kꞌaxtꞌa ꞌbezankohi habu̱ ꞌbe̱ꞌsa nꞌar kꞌaxtꞌatꞌe̱ni, mi kö ar ñhuni ba e mhetsꞌi, ár tꞌo ar Aron bi ꞌrogi, ne ya nxindo nkohi. 
\p  
\v 5 Ne mañö ar ꞌbezankohi, ka xki thuxnu̱ ya döꞌe̱nxe̱ mi ñꞌu ár nsunda Jö, mi koꞌma ar kꞌaxtꞌaxithe̱, habu̱ mi nhöxa ar ji mi punga ya tsꞌoki. Nuyu̱ hinga ma ga otꞌahu̱ xiñho ar ꞌñupya. 
\p  
\v 6 Nu xki wadi xki thoka gatho, nu hár ñu̱tꞌitho ar nijö, hyaxꞌmu̱ mi ku̱tꞌa ya möjö mi o̱tꞌa yá ꞌbe̱fi mi ndöngajö. 
\p  
\v 7 Nu hár ñoxe̱ni ar nijö, ho̱nse̱ ar döngamöjö mi ku̱tꞌi ne nꞌagitho ar je̱ye̱. Himi tsa̱ nda yu̱tꞌi nuꞌmu̱ hinte mi hömpa ár ji ya me̱ti nda unga ngu ar mꞌo̱ñho̱. Njapꞌu̱ nda mpumbabi mꞌe̱tꞌo yá tsꞌokiꞌö, ne mꞌe̱fa yá tsꞌoki gatho nu maꞌra. 
\p  
\v 8 Ne ár Hñö Jö utkagihu̱ njapꞌu̱, hinxki tꞌunda ar se̱ki to gatho nda yu̱tꞌa habu̱ tꞌembabi Xa Ar Nsunda, núꞌmu̱ hár ñu̱tꞌi ar nijö hinxki ꞌbe̱ta ár nsu. 
\p  
\v 9 Nunu̱ ngu ár xuditho nöꞌö di thohu̱pya. Nuya mꞌo̱ñho̱ ne ya ñhötꞌi mi mꞌo̱ꞌspa Jö mamꞌe̱tꞌo, hinto bi hyokwa yá mꞌu̱i nuꞌu̱ mi o̱tꞌa njapꞌu̱. 
\p  
\v 10 Nuꞌmu̱ nuya ꞌbe̱tꞌo mhö xki mꞌe̱pabi, ho̱nse̱ nda mo̱xa ya ñhuni, te nda tsꞌi, ne ya nsu̱ki mpe̱ hár ndoꞌyo ya jöꞌi, mi tho̱ꞌmi nda zo̱nga ar pa nda mponga xo̱ge. 
\p  
\v 11 Ha nupya xi zo̱kwa ar tsi Hmu Hesukristo, ár döngamöjö nuya ñho ba epꞌu̱. Bi yu̱tꞌa har dönga nijö töta ár nsu, hinxi hyoka nꞌar jöꞌi, himbi thoka mahye̱giwi ar ximha̱i. 
\p  
\v 12 Ne bi yu̱tꞌa nꞌagitho har xe̱ni Xa Ar Nsunda, ne hiñhamꞌu̱ da yu̱tꞌa manꞌagi. Himbi hñöꞌspa ár ji ya tꞌöxi wa yá ji ya boi, nunár jise̱ bi gutꞌa nꞌagitho ya tha̱i ndi tuhu̱. 
\p  
\v 13 Ngetho nuꞌmu̱ nda nhöꞌspa ar jöꞌi yá ji ya tꞌöxi, yá ji ya boi ne ár ꞌbospi ya kero, ne nda nsu̱ki nda ntꞌaxka ár te, 
\p  
\v 14 tema hinda tsa̱ da ꞌyo̱tꞌa ár ji ar tsi Hmu Hesukristo, bi da̱twa Jö hinte xki ja̱xtꞌi. Bi ma̱xa ár Hñö Jö ꞌbu̱ gatho ya pa, bi unga ár te. Ha nunár jinu̱ da xu̱kꞌa ri mfenihu̱, gi hye̱hu̱pꞌu̱ nuya ꞌbe̱fi hinte unga ar te, ne gi pe̱fu̱ Jö togo hö ar te. 
\p  
\v 15 Jange bi ꞌñu ar ꞌraꞌyo nkohi. Ne núꞌmu̱ mi unga ár te, bi mpumbabi yá tsꞌoki xki ꞌyo̱tꞌa mamꞌe̱tꞌo nuꞌu̱ mi ꞌbu̱ har ꞌbe̱tꞌo nkohi. Ne njapꞌu̱ nuya xki thahni bi tꞌumba ya ñho xki ñhötꞌi hiñhamꞌu̱ da götsꞌi. 
\p  
\v 16 Ngetho habu̱ ja nꞌar he̱ꞌmi nkohi, mahyoni mꞌe̱tꞌo da du togo tso yá ñho. 
\p  
\v 17 Nunar nkohinu̱ da ndu̱i da me̱ꞌsa ár tsꞌe̱di xta du nöꞌö togo tso yá ñho. Ngetho nuꞌmu̱ tetho, hinto tsa̱ da hñöni. 
\p  
\v 18 Nu har ꞌbe̱tꞌo nkohi nꞌehe, hinge nda tsa̱ nda me̱ꞌsa ár tsꞌe̱di nuꞌmu̱ hinge nda nhöꞌma ar ji. 
\p  
\v 19 Ngetho ar Moise nu mi wadi bi xipa ya jöꞌi xo̱ge ya ꞌbe̱pate, bi gu̱mpa ár ji ya boi ne ár ji ya tꞌöxi, bi thönsa ar dehe. Ne bi gu̱ ar the̱ngaxiꞌyo ne ya do̱ni, bi nöxa ha ya tꞌofo mi huxa ya ꞌbe̱pate, ne bi nöxa gatho ya jöꞌi nꞌehe. 
\p  
\v 20 Ne bi ꞌñenö: Gehnu̱ ar ji umba ár tsꞌe̱di ar nkohi xi ꞌbe̱pꞌahu̱ Jö gi ꞌyo̱thu̱. 
\p  
\v 21 Hinge ho̱nse̱yu̱, bi nöxya ji ar nijö nꞌehe, ne gatho ya ntꞌe̱ni mpe̱ hár ꞌbe̱fi Jö. 
\p  
\v 22 Ha ya ꞌbe̱pate, txꞌu̱tho ꞌbe̱di da japa da tꞌaxka xo̱ge har ji nhöꞌmi, ne nuꞌmu̱ hinda nhöꞌma ar ji, hiñꞌotho ár mpumbate ya tsꞌoki. 
\s1 Ár ndöte ar tsi Hmu Hesukristo höka ya tsꞌoki 
\p  
\v 23 Njapꞌu̱ ꞌmu̱ nuya te jawa har ximha̱i, ñhe̱hwi nuya te janu̱ mhetsꞌi, mi mahyoni nda nsu̱ka ha yá ji ya me̱ti. Ha nuꞌu̱ gese̱ bi ja mhetsꞌi, mahyoni manꞌar mꞌo̱ñho̱ di töte ár ñho. 
\p  
\v 24 Ngetho ar tsi Hmu Hesukristo himbi yu̱tꞌa ha nꞌar nijö xi hyoka ar meximha̱i, ñhe̱hwi nöꞌö majöni bi ꞌbu̱ mhetsꞌi. Gese̱ꞌö bi yu̱tnu̱ har nijö mhetsꞌi nda po̱kagihu̱ hár nthandi Jö. 
\p  
\v 25 Ne hinge xa ku̱tꞌa ngu nu maꞌra ya döngamöjö, ta̱tꞌa je̱ye̱ mi ku̱tꞌa har xe̱ni Xa Ar Nsunda nda mo̱xa ar ji hingo már me̱tise̱. 
\p  
\v 26 Nuꞌmu̱ di njapꞌu̱, hangu ya mpengi xi dumhö nuꞌmu̱ ga pehu̱ hár ndu̱itho ar ximha̱i. Ne ha ya ngöxapayu̱, bi ñꞌudi bi unse̱ ár te nꞌagitho, ne hinda mengi da ꞌyo̱tꞌa manꞌagi, ne njapꞌu̱ bi hñöka ar tsꞌoki. 
\p  
\v 27 Ne ngu xi thuꞌspabi ya jöꞌi, ho̱nse̱ nꞌagi da duyu̱, ne da thöꞌspa majöni, 
\p  
\v 28 njapꞌu̱ ar tsi Hmu Hesukristo nꞌehe, nꞌagitho bi unga ár te, ne njapꞌu̱ bi hñöꞌspa yá tsꞌoki nze̱ye̱. Ne ma da ñꞌudi ár yoꞌgi manꞌagi, da po̱ho̱ gatho nuꞌu̱ ndo̱ꞌmi, hinte di benga ar tsꞌoki. 
\c 10  
\p  
\v 1 Nuya ꞌbe̱pate bi tꞌunga mahamꞌu̱, ho̱nse̱ ngu ár xudi nuya döta ñho ma nda tꞌaju̱ mꞌe̱fa, hinge mi gehyu̱. Nuya mꞌo̱ñho̱ ta̱tꞌa je̱ye̱ mi o̱tꞌa nuꞌu̱ mi e nda hyonga Jö, hinto bi tsa̱ bi hyokwa ár mꞌu̱i. 
\p  
\v 2 Ngetho nuꞌmu̱ xi hñökwahmö yá tsꞌokiyu̱, hinte di tsa̱ꞌu̱ ha yá mu̱i, ne xi hye̱hmö da ꞌyo̱tꞌa nuya mꞌo̱ñho̱yu̱. 
\p  
\v 3 Ha nuya mꞌo̱ñho̱yu̱, ho̱nse̱ mi japi da benga yá tsꞌoki ta̱tꞌa je̱ye̱. 
\p  
\v 4 Ngetho nuyá ji ya boi ne yá ji ya tꞌöxi hingi tsa̱ da hñöka ya tsꞌoki. 
\p  
\v 5 Jange nu mi yu̱tꞌa har ximha̱i ar tsi Hmu Hesukristo, bi ꞌñenö: 
\q1 Ya mꞌo̱ñho̱ ne ya ñhötꞌi hinga ne, 
\q1 ha ga ꞌrakawa nꞌar ndoꞌyo har ximha̱i. 
\q1  
\v 6 Nuya mꞌo̱ñho̱ tsꞌötꞌi ne nuya ñhötꞌi thöñꞌaꞌi gi pungya tsꞌoki, hinga numañho. 
\q1  
\v 7 Jange da enga: 
\q1 Ma Jöꞌi, di ꞌbu̱kwa xta e ga o̱tꞌa nöꞌö gi nege, 
\q1 ngu xi ntꞌotꞌa ha ya tꞌofo habu̱ no̱ngagi. 
\p  
\v 8 Ngu enga mꞌe̱tꞌo: Ya mꞌo̱ñho̱ ne ya ñhötꞌi tꞌaꞌi gi pungya tsꞌoki, hinga ne, ne hinga numañho. (Gathoyu̱ ꞌbo̱tsꞌe ngu mönga ha ya ꞌbe̱pate.) 
\p  
\v 9 Mꞌe̱fa bi ꞌñenö: Ma Jöꞌi, di ꞌbu̱kwa xta e ga o̱tꞌa nöꞌö gi nege. Njapꞌu̱ bi ꞌñenö, bi göxa nöꞌö mꞌe̱tꞌo, ne bi thuxa manꞌa ꞌraꞌyo. 
\p  
\v 10 Xi tꞌaxkagihu̱, ngetho ar tsi Hmu Hesukristo bi ꞌyo̱ta Jö, bi unga ár te ngu nꞌar mꞌo̱ñho̱ nꞌagitho, ne hinda ma da tho ár tsꞌe̱di. 
\p  
\v 11 Ha nuya möjö hyaxꞌmu̱ pe̱pa Jö, ne unga getꞌö ar mꞌo̱ñho̱ hiñhamꞌu̱ da hñöka ya tsꞌoki. 
\p  
\v 12 Ha nunar tsi Hmu Hesukristo, mi wadi bi unga nꞌadar mꞌo̱ñho̱ bi gutꞌwa yá tsꞌoki ya meximha̱i, bi hñuxa hár ñꞌe̱i Jö. 
\p  
\v 13 Bi ndu̱ nuya paꞌu̱ di njawa, ho̱nse̱ to̱ꞌmi da tsꞌimpa gatho yá ñꞌu̱ni da tsꞌe̱mꞌa ha yá wa. 
\p  
\v 14 Ngetho nuna nꞌadar mꞌo̱ñho̱nu̱, bi umba nꞌar hoga te hinda thege nuꞌu̱ xi tꞌaxkꞌö. 
\p  
\v 15 Ár Hñö Jö mahye̱gi da̱majöni núꞌmu̱ bi ꞌñenga mꞌe̱tꞌo: 
\q1  
\v 16 Nu xta tho nuya payu̱, gehnu̱ ar nkohi ma ga nkoꞌbe, enga ar tsi Hmu: 
\q1 Ma ga kötꞌwa ma ꞌbe̱pate ha yá mu̱i, 
\q1 ne ga otꞌwa ha yá mfeni. 
\p  
\v 17 Ne bi ꞌñenga mꞌe̱fa: 
\q1 Hiñhamꞌu̱ ma ga benga yá tsꞌoki, ne ga puhni ma ya me̱ꞌsku. 
\p  
\v 18 Nu habu̱ xi mpumbabiyu̱, hiñꞌotho maꞌra ya mꞌo̱ñho̱ da dukwa yá tsꞌoki. 
\s1 Ma ga umba ma mu̱ihu̱ ga hoñhu̱ Jö 
\p  
\v 19 Jange tsi kuhu̱, di pe̱ꞌsu̱pya ar se̱ki ga ku̱thu̱ har xe̱ni Xa Ar Nsunda, gehnu̱ bi gutꞌa núꞌmu̱ mi nöꞌma ár ji ar tsi Hmu Hesukristo. 
\p  
\v 20 Ga nehu̱ ar ꞌraꞌyo ꞌñu tsixju̱ har te, bi xogagihu̱ madeda ar döta xu̱ni dutu bi xoki, gehnu̱ ár ndoꞌyo. 
\p  
\v 21 Ne di ꞌñehu̱ hár nijö Jö nꞌar döta döngamöjö xa pe̱ꞌsa ár nsu. 
\p  
\v 22 Ma ga kwathu̱ habu̱ ꞌbu̱ Jö, hinte di tsu̱ka ma mfenihu̱, ne di tse̱ ma jamfihu̱. Ngetho xi nxu̱gagihu̱ ma mu̱ihu̱ xi thögagihu̱ ya tsꞌomfeni, ne xi nsu̱ga ma ndoꞌyohu̱ har tꞌaxdehe. 
\p  
\v 23 Hinge te gatho ga benthu̱. Ma ga umba ma mu̱ihu̱ ga ñꞌuhu̱ nunar ndo̱ꞌminu̱ di pe̱ꞌsu̱, ngetho nu togo bi ñötkagihu̱ hingi kate. 
\p  
\v 24 Ne nꞌa ngu nꞌa ga beñhu̱ ma ñꞌohu̱, ga nkahu̱ ga pe̱ꞌsu̱ ar mhöte, ne ga pe̱hu̱ ya hoga ꞌbe̱fi. 
\p  
\v 25 Yo ma ga he̱hu̱ ga kwathu̱ ha ya mhuntsꞌi ngu xi nzönga ꞌra. Nöꞌö ga o̱thu̱, ga humfu̱ ár mu̱i nꞌa ngu nꞌa ma kuhu̱, ngetho di pöhu̱ ꞌba̱pꞌu̱tho ar pa da penga ma tsi Hmuhu̱ Hesukristo. 
\s1 Nuꞌu̱ xa nese̱ da ntsꞌoki 
\p  
\v 26 Ngetho nuꞌu̱ xi bö nöꞌö majöni, ne di nese̱ da ꞌyo̱tꞌa ya tsꞌoki, hinda ma da tꞌo̱tꞌa manꞌar mꞌo̱ñho̱ da thökwa yá tsꞌokiyu̱. 
\p  
\v 27 Ho̱nse̱ to̱ꞌma nunar pa xa ñꞌu̱tho da thöꞌspa majöni, ne ar tsibi nthu̱ni da dutꞌa gatho nuꞌu̱ hingi ne da ꞌyo̱ta Jö. 
\p  
\v 28 Nuꞌu̱ togo tsꞌokwa yá ꞌbe̱pate ar Moise, nuꞌmu̱ yoho wa hñu ya jöꞌi da da̱majöni hö bi ꞌyo̱tꞌe, hinda kꞌontꞌi da tho. 
\p  
\v 29 Tengu ár dötahmö ar mfe̱i gi beñhu̱ to̱ꞌma nöꞌö togo hinda numansubi ár Tꞌu̱ Jö, ne da ꞌñenö, hingi ho ár ji nuna bi japabi bi tꞌaxki, ne da nto̱xkwi ár Hñö Jö xi nhwëgagihu̱. 
\p  
\v 30 Di pöhu̱ togo bi ꞌñenö: Go di koꞌspaga yá ñöni, go ga umga yá njutꞌi, enga njapꞌu̱ ar tsi Hmu. Ne manꞌagi enö: Ar tsi Dada ma da hñöꞌspa majöni yá bötsi. 
\p  
\v 31 Ñꞌu̱tho da zo nꞌa ha yá ꞌye̱ Jö togo te. 
\p  
\v 32 Beñhu̱ nuya pa xi thogi, núꞌmu̱ ja ngi jwahu̱ bi ꞌraꞌahu̱ ár hyatsꞌi ar tsi Hmu, xa ga tse̱ta ri mu̱ihu̱ ga thohu̱ ya thogi. 
\p  
\v 33 Mödi ngi thohu̱ ya thogi ne ya ntꞌu̱tsa, ga tse̱thu̱ ya jöꞌi mi theñꞌahu̱, ne njapꞌu̱ ga thohwihu̱ mahye̱gi nuꞌu̱ maꞌra mi tho ya thogi nꞌehe. 
\p  
\v 34 Ngetho ga hwëju̱ nuꞌu̱ mi ku̱ har fa̱di. Ha nuya ri ñhohu̱ bi thömpꞌahu̱, ga njohya ga tse̱thu̱, gi to̱ꞌmhu̱ gi hñöñhu̱ ya ñho xa nza̱tho ne hinda thege, bi to̱pꞌahu̱nu̱ mhetsꞌi. 
\p  
\v 35 Jange yo ma gi hye̱hu̱ gi ndöꞌmhu̱, ngetho bi to̱pꞌahu̱ nꞌar döta nthöhö. 
\p  
\v 36 Ngetho mahyoni gi tse̱thu̱ ya thogi, ne xki jwahu̱ gi ꞌyo̱thu̱ nöꞌö ne Jö, gi hñöñhu̱ nöꞌö xi ñötꞌahu̱. 
\p  
\v 37 Enga har Tꞌofo: 
\q1 Ga to̱ꞌmhu̱ da tho manꞌa tsi tu̱i, 
\q1 ne ngutꞌa ma da zo̱ nöꞌö da ehe. 
\q1  
\v 38 Ha nöꞌö togo ꞌbu̱ xiñho ha ma nthandi, ma da mꞌu̱i di ñꞌemu̱igi, 
\q1 ha nuꞌmu̱ da mengi, hinga numañho. 
\p  
\v 39 Mödi nuju̱ hinga gekagihu̱ nuꞌu̱ di penju̱ ga mꞌe̱hu̱. Nuju̱ di pe̱ꞌsu̱ ar ñꞌemu̱i, ne hinda mꞌe̱ ma pahu̱. 
\c 11  
\s1 Ar ñꞌemu̱i 
\p  
\v 1 Ar ñꞌemu̱i gehnu̱ ga pöhu̱ xiñho ma ga höñhu̱ nöꞌö di to̱ꞌmhu̱, ne di ñꞌemu̱ihu̱ ga höñhu̱ nöꞌö hindi handathohu̱. 
\p  
\v 2 Nunar ñꞌemu̱inu̱ bi ma̱xa ma palehu̱ mi ꞌbu̱ mamꞌe̱tꞌo nda numañho Jö. 
\p  
\v 3 Nunar ñꞌemu̱inu̱ fa̱xkagihu̱ ga pöhu̱ ho̱nse̱ bi mönga Jö, ne bi ho xo̱ge nöꞌö di hanthu̱pya. Gathonu̱ ba e habu̱ himi nhekitho ꞌmu̱. 
\p  
\v 4 Nunar ñꞌemu̱inu̱ bi ma̱xa ar Abel bi unga nꞌar mꞌo̱ñho̱ mi töpa ár ñho nöꞌö bi unga ár jödö Kain. Jange Jö bi da̱majöni mar hogajöꞌi, ngetho bi hñömba ár mꞌo̱ñho̱. Ne mi tho ya pa, mödi xi du, nho̱mbatho ár ñꞌemu̱i. 
\p  
\v 5 Nunar ñꞌemu̱inu̱ bi ma̱xa ar Enok bi tsꞌitsꞌi hinge nda nu ar ndöte. Ne himbi thini, ngetho bi zixa Jö. Númꞌu̱ hinxki tsꞌixtho, Jö bi damajöni mi numañho. 
\p  
\v 6 Ha nuꞌu̱ hinte pe̱ꞌsa ar ñꞌemu̱i, Jö hingi tsa̱ da numañho, ngetho nöꞌö togo ne da hyoni, mꞌe̱tꞌo mahyoni da ñꞌemu̱i di ꞌbu̱i, ne go ma da umba ár nthöhö togo honi. 
\p  
\v 7 Nunar ñꞌemu̱inu̱ bi ma̱xa ar Noe bi hyoka ar motsa habu̱ bi kꞌontꞌö ne gatho yá mëni, núꞌmu̱ mi xipa Jö nöꞌö ma nda thogi, mödi himi handatho. Nunar jamfinu̱ bi japi bi nheki yá tsꞌoki ya meximha̱i, ha nöꞌö bi tꞌembabi mi ꞌbu̱i xiñho hár nthandi Jö. 
\p  
\v 8 Nunar ñꞌemu̱inu̱ bi ma̱xa ar Abra nu mi tsꞌohni, ba po̱nga hár hnini ndi ma ha nꞌar ha̱i nda tꞌumbabi. Bi ꞌyo̱ta Jö mödi himi pödi habu̱ ndi ma. 
\p  
\v 9 Ar ñꞌemu̱i bi ma̱tsꞌi bi mꞌu̱ ngu nꞌar nzo̱ho̱ har ha̱i xki ñhötꞌwabi, nuyu̱ ma yá ha̱i maꞌra. Mi ꞌbu̱ta ha ya ngudutu. Bi njapꞌu̱ ar Isa ne ar Hakob, nuꞌu̱ togo bi hñönga ar ñhötꞌi nꞌehe. 
\p  
\v 10 Ngetho mi to̱ꞌma ar hnini xi tꞌei xiñho, gese̱ Jö togo xi beni hanja da thoki. 
\p  
\v 11 Nunar ñꞌemu̱inu̱ bi ma̱xa ar Sara togo himi tsa̱ nda ñꞌo̱nte. Bi hñönga ar tsꞌe̱di nda nda̱thi, ne bi mꞌu̱ ár bötsi, mödi xki tho ya je̱ye̱ ñꞌo̱nte nꞌar ꞌbe̱hñö. Ha bi ñꞌemu̱i mi tsa̱ nda ꞌyo̱tꞌa togo bi ñötꞌwabi. 
\p  
\v 12 Bi njapꞌu̱ nꞌehe ar Abra. Po̱ntho xki du, bi me̱ꞌsa ngu ár nze̱ye̱ ya tso̱ nuyá ꞌbe̱to bi dini, ne ngu ar ꞌbomu ja har ñönthe hingi tsa̱ da ꞌbede. 
\p  
\v 13 Bi du mi ñꞌemu̱i gathoꞌu̱, mödi himbi hñönga ar ñhötꞌi. Bi hyantꞌu̱ yapꞌu̱tho ne mi ñꞌemu̱i, mi ze̱ngwatho ne mi da̱majöniꞌu̱ ma ya nzo̱ho̱ ne thota nuwa har ximha̱i. 
\p  
\v 14 Ngetho nuꞌu̱ mönga njapꞌu̱, nheki xiñho honga nꞌar ha̱i habu̱ da mꞌu̱i. 
\p  
\v 15 Nuꞌmu̱ di bemhö nda penga habu̱ ba po̱ñꞌu̱, mi tsa̱ nda mengi. 
\p  
\v 16 Ha nuyu̱ mi hoñꞌu̱ manꞌa, mi töte ár nsu bi ꞌbu̱ mhetsꞌi. Jange Jö hingi ntsa̱ da ꞌñembabi ár Dadaꞌu̱, ne xpa hokwa nꞌar hnininu̱. 
\p  
\v 17 Nunar ñꞌemu̱inu̱ bi ma̱xa ar Abra núꞌmu̱ mi tsa̱ta Jö. Dama bi netho bi da̱twa ar Isa nöꞌö nꞌase̱ ár tꞌu̱ mi ñꞌehe, mödi xki hñönga ya ñhötꞌi, 
\p  
\v 18 nu xki wadi xki tꞌembabi: Nuya ri ꞌbe̱to xta ñötꞌaꞌi, ma da bo̱nga ha yá bötsi ar Isa. 
\p  
\v 19 Mi ñꞌemu̱i pe̱ꞌsa ar tsꞌe̱di Jö da gu̱xa nuꞌu̱ xi du, ngetho po̱ntho bi du ne bi mengi bi nte manꞌagi, ne bi mengi bi zitsꞌi. 
\p  
\v 20 Nunar ñꞌemu̱inu̱ bi ma̱xa ar Isa bi xipa ar Hakob ne ar Esau nöꞌö ma nda hwëkwa Jö mꞌe̱fa. 
\p  
\v 21 Nunar ñꞌemu̱inu̱ bi ma̱xa ar Hakob núꞌmu̱ mi da̱tꞌi nda du, bi xipa nöꞌö ma nda hwëkwa Jö yá bötsi ar Huse, ne bi ndönga Jö mi njwaxa hár ndo̱ho̱. 
\p  
\v 22 Nunar ñꞌemu̱inu̱ bi ma̱xa ar Huse núꞌmu̱ mi ꞌba̱pꞌu̱tho ár ndöte, bi ꞌñenö ma nda bo̱nga Ehipto nuya me Israel, ne bi ꞌbe̱pabiꞌu̱ nda gu̱kwa yá ndoꞌyo. 
\p  
\v 23 Nunar ñꞌemu̱inu̱ bi ma̱xa yá dada ar Moise, bi ꞌñö hñu nzönö, ngetho bi hyantꞌu̱ mar nza̱tho bötsi, ne himbi zuꞌu̱ nöꞌö xki mönga ar ndö. 
\p  
\v 24 Nunar ñꞌemu̱inu̱ bi ma̱xa ar Moise núꞌmu̱ mi ndöta, himbi ne bi tꞌembabi már tꞌu̱ ár tꞌinxu ar ndö me Ehipto. 
\p  
\v 25 Bi hwahna nda mfe̱i mahye̱giwi ár hnini Jö, himbi ne bi njohya ꞌra ya tsi pa ha yá ñho ar tsꞌoki. 
\p  
\v 26 Bi hyandi ngu nꞌar döta mꞌe̱tsꞌi yá ntꞌu̱tsa ar tsi Hmu Hesukristo, ne himbi nepa yá mꞌetsꞌi ya me Ehipto, ngetho xki hñuxa ár da̱ har nthöhö unga Jö. 
\p  
\v 27 Ar ñꞌemu̱i bi ma̱tsꞌi ba tsopꞌu̱ Ehipto, himbi zupa ár kwe̱ ar ndö, ngetho bi ze̱twa ár jamfi Jö togo hingi nheki. 
\p  
\v 28 Bi ma̱tsꞌi nꞌehe nda du̱ꞌma ar baxjwa ne ar nhöxa ji núꞌmu̱ nda thohnu̱ togo mi ho ya ꞌbe̱tꞌo bötsi, hinte nda japabiꞌu̱. 
\p  
\v 29 Ar ñꞌemu̱i bi ma̱tsꞌi bi thotꞌu̱ har The̱nga Ñho̱nthe ngu ar ꞌyoñha̱i, ha nuya me Ehipto bi tsa̱ti nda thoꞌu̱ nꞌehe, ne bi jötꞌu̱ xo̱ge. 
\p  
\v 30 Ar ñꞌemu̱i bi mfa̱xte bi yo̱tꞌa ya jödo mi kotꞌa ar hnini Heriko, nu mi wadi bi nthetꞌa yoto mpa. 
\p  
\v 31 Nunar ñꞌemu̱inu̱ bi ma̱xa nunar tsꞌoꞌbe̱hñö már thuhu ar Rahab. Himbi duwi gatho nu maꞌra ya me̱ꞌsku, ngetho bi umba nꞌar hoga tsa̱ya̱ nuꞌu̱ togo bi ma ba thexa ar ha̱i xki ñhötꞌi. 
\p  
\v 32 Tema manꞌa ga xiꞌahu̱. Ngetho hinda zu̱kagi ga petꞌahu̱ gatho tema bi tho ar Gedeon, ar Barak, ar Sanson, ar Hefte, ar Dabi, njapꞌu̱ ar Samuel ne maꞌra yá mꞌe̱hni Jö. 
\p  
\v 33 Nunar ñꞌemu̱i bi ma̱tsꞌi bi dö maꞌra ya ndö, bi ꞌyo̱tꞌa ar hoga tsꞌu̱tꞌwi, bi zu̱ ya ñhötꞌi, ne bi gotꞌwa yá ne ya ꞌmuhu. 
\p  
\v 34 Bi ma̱tsꞌi bi kꞌontꞌa ha ya tsibi xa mi fagi, ne ha ya ndo̱jwai. Bi tꞌumba ar tsꞌe̱di ha yá ngwentꞌi ne ha ya tuhni, ne bi japi nda ꞌbe̱ ar ꞌñu yá ndogu maꞌra ya ha̱i. 
\p  
\v 35 ꞌRa ya ꞌbe̱hñö bi mengi bi hyanda yá mëni xki mengi xki nte manꞌagi. Maꞌra bi ñhe̱gi bi mfe̱i, himbi ne togo nda ñöni, ne nda mengi nda nte ha nꞌar mꞌu̱i töte ár nsu. 
\p  
\v 36 Maꞌra bi tho ya ntꞌu̱tsa ne ya mfe̱i. Hinge ho̱nse̱ꞌö, bi nthötꞌa ya bo̱jö ne bi jotꞌa ha ya fa̱di. 
\p  
\v 37 Bi tsꞌoxa ya nkꞌahni, bi nju̱ ya nthe̱gi bi theka made, bi tsꞌa̱ti. Maꞌra bi tho ndo̱jwaitho, himi ñꞌotho habu̱ nda mꞌu̱i, hagatho mi ꞌyotho, ho̱nse̱ mi hempa yá ximhni ya de̱ti, ya tꞌöxi, xa mi hyoya, xa mi tho ya dumu̱i, mi tho ya mfe̱i. 
\p  
\v 38 Ar ximha̱i hinge ndi ꞌñepabi nda mꞌu̱kwa. Mi ꞌyoꞌu̱ ha ya otꞌaha̱i, ha ya tꞌo̱ho̱, ha ya ñeke ne ya oki ja ha ya maꞌye. 
\p  
\v 39 Mödi bi numañho Jö yá jamfi, himbi hyantꞌu̱ nda tho gatho nöꞌö xki ñhötꞌwabi. 
\p  
\v 40 Ngetho Jö xki ꞌye̱gagihu̱ maꞌra ya döta njöpi, ne nuꞌu̱ mahye̱gi nguju̱ nda hñönga nunar ñhonu̱, ne hinge nda hñönse̱ꞌu̱ ya njöpi. 
\c 12  
\s1 Hinga höju̱ ma da̱hu̱ xta huxu̱ har tsi Hmu Hesukristo 
\p  
\v 1 Ngetho xa xi gokathogihu̱ ra nze̱ye̱ togo xi da̱majöni mi pe̱ꞌsa ar ñꞌemu̱i, ma ga he̱hu̱ ꞌmu̱ gatho ma ꞌbe̱nihu̱, ne ya tsꞌoki hingi he̱gagihu̱ ga ꞌyohu̱. Ne ga nixtꞌihu̱ hinga tsa̱ya̱hu̱ ga tso̱ñhu̱ ár ñöni nunar ꞌñu di te̱ñhu̱. 
\p  
\v 2 Hinga höju̱ ma da̱hu̱ xta huxu̱ ar tsi Hmu Hesukristo, togo bi du̱ꞌmi ne bi jwatka ma jamfihu̱. Himbi jamasu hangu ma nda tho ya ntꞌu̱tsa, mi handar johya ma nda ꞌñepa mꞌe̱fa, bi netho nda tsꞌu̱ta har pontꞌi, ne bi hñúxa hár ñꞌe̱i ár thuxandö Jö. 
\p  
\v 3 Beñhu̱ nöꞌö togo bi me̱ꞌspa ar tse̱ti ya tsꞌokte xa mi u̱tsa, ne njapꞌu̱ hinda wentꞌahu̱ hingi ne gi pe̱fu̱. 
\p  
\v 4 Nuꞌahu̱ hinxi zo̱ta ar pa gi uñhu̱ ri tehu̱ gi ntsa̱wihu̱ ar tsꞌoki. 
\p  
\v 5 Hage xka pumhnihu̱ ya mhö bi hñupꞌa ri mu̱ihu̱ ngu yá bötsiꞌihu̱ Jö, bi tꞌeñꞌahu̱ njawa: 
\q1 Ma tsi bötsiꞌihu̱, yo gi tsamfu̱ ár nju̱tgu ꞌraꞌahu̱ ar tsi Hmu, 
\q1 ne yo gi wenthu̱ nuꞌmu̱ tsu̱ꞌahu̱ꞌö. 
\q1  
\v 6 Ngetho ar tsi Hmu umba ár mfu̱ki nuꞌu̱ togo mödi, 
\q1 ne umba ár mfe̱i gatho nuꞌu̱ embabi yá bötsi. 
\p  
\v 7 Tse̱thu̱ ar mfu̱ki ꞌraꞌahu̱ Jö, ngetho hantꞌahu̱ ngu yá bötsi. Hinjoꞌo nꞌar bötsi togo ár dada hingi umba ár mfu̱ki. 
\p  
\v 8 Ha nuꞌmu̱ hingi ꞌraꞌahu̱ ar mfu̱ki ngu nu maꞌra, hingyá bötsiꞌihu̱ ꞌmu̱, go yá ho̱tꞌu̱ꞌihu̱. 
\p  
\v 9 Nupya ma ga beñhu̱ xta ꞌñehu̱wa ma dadahu̱ har ximha̱i, mi fe̱bgagihu̱ ne ndi möhu̱. Yoꞌö hinga o̱thu̱ ár Dada ma hñöhu̱, ne ga pe̱ꞌsu̱ ar te. 
\p  
\v 10 Majöni numa dadahu̱wa mi tsu̱kagihu̱ ꞌra ya tsi pa, ngu mi beñꞌu̱ mar ñho. Ha Jö fe̱bgagihu̱ homga ma ñhohu̱, ne ga pe̱ꞌsu̱ nꞌar te xintꞌaxi nguꞌö. 
\p  
\v 11 Majöni hiñꞌotho nꞌar mfe̱i ga johya ga höñhu̱, gatho tso̱tkagihu̱ ma mu̱ihu̱. Ha nuꞌmu̱ da zo ma mfenihu̱, mꞌe̱fa ga pe̱ꞌsu̱ nꞌar hogamu̱i, ne da tsa̱ ga o̱thu̱ nöꞌö xiñho. 
\s1 Nuꞌu̱ togo he̱pꞌu̱ ár nhwëki Jö 
\p  
\v 12 Jange ju̱xu̱ ri ꞌye̱hu̱ xi da̱tho, ne nuya ri ñöhmuhu̱ xi nzatho. 
\p  
\v 13 Ne hyoju̱ nꞌar ꞌñu njöntho. Njapꞌu̱ nuna ri wahu̱ xi wengi hinda kꞌoxa ar ndoꞌyo, da mengi da zo xiñho manꞌagi. 
\p  
\v 14 Umba ri mu̱ihu̱ gi ꞌbu̱hwihu̱ nꞌar hogamꞌu̱i gatho nu maꞌra, ne gi pe̱ꞌsu̱ nꞌar mfeni xintꞌaxi. Ngetho nuꞌu̱ hinte pe̱tsꞌi, hinda ma da hyandwa ár hmi ar tsi Hmu. 
\p  
\v 15 Ntsuñhu̱, yo ma da bo̱mpꞌu̱ nꞌa da hye̱pꞌu̱ ár nhwëki Jö. Ne da mu̱di da zo̱tꞌa ár mu̱i, ne da ꞌyo̱tꞌa nöꞌö hingi ho. Ne njapꞌu̱ da mu̱di da tsꞌokwa yá mfeni maꞌra. 
\p  
\v 16 Yo ma da mꞌu̱pꞌu̱ nꞌa di ꞌbe̱ngwi ya jöꞌi, wa hindi ne da numansu nöꞌö di ꞌñe mhetsꞌi. Ngu ar Esau bi thoka nöꞌö mi tꞌembabi mar ꞌbe̱tꞌo tꞌu̱, bi pa̱ti nda tꞌumba nꞌa mohi ar ñhuni. 
\p  
\v 17 Xka pöhu̱ himbi tꞌe̱kwabi, mödi mꞌe̱fa mi nemhö nda hñönga ar njöpi, ne himbi tsa̱. Bi nöꞌmahmö yá gida̱, ha himbi tꞌumbabi ar se̱ki. 
\p  
\v 18 Nuꞌahu̱ hinxka kwathu̱ har tꞌo̱ho̱ mi tsa̱ ngi tha̱ñhu̱, ngu ya me Israel bi tho mamꞌe̱tꞌo, ne ngi hyanthu̱ mi po̱xa ar tsibi, xa mar mꞌe̱xui, ne mi ja ar ꞌyomndöhi. 
\p  
\v 19 Hinga ꞌyo̱hu̱ ár ñheti ar kꞌaxtꞌathu̱xi, ne hinga ꞌyo̱hu̱ nunar mhö mi nzote. Nuꞌu̱ togo bi ꞌyo̱de bi ꞌya̱di nda ñhe. 
\p  
\v 20 Ngetho himi tsa̱ nda ze̱ta nöꞌö mi nsipabi, mi enö: Nuꞌu̱ togo nda ꞌñexa ár wa har tꞌo̱ho̱ mödi mar me̱ti, nda tho nkꞌahni wa nda nsu̱ꞌsa nꞌar maza. 
\p  
\v 21 Xa mar döta ár nsu mi nheki. Gese̱ ar Moise bi ꞌñenö: Xa di nhwötꞌi di ntsu. 
\p  
\v 22 Nuꞌahu̱ xka kwathu̱ har tꞌo̱ho̱ ár thuhu Sion, hár hnini Jö togo te, har Herusalen mhetsꞌi, po̱ntho xka ꞌbu̱hwihu̱ nuꞌu̱ ra nze̱ye̱ ya e̱nxe̱. 
\p  
\v 23 Xka kwathu̱ hár mhuntsꞌi nuꞌu̱ ya hmökabötsi xi thuꞌspa yá thuhunu̱ mhetsꞌi, ne xka tsu̱hu̱ Jö togo o̱tꞌwa ar tsꞌu̱tꞌwi gatho. Ne xka nthöskwihu̱ ya hogajöꞌi xi du xi zo̱nga xiñho hár ñöni. 
\p  
\v 24 Xka kwathu̱ xka tsu̱hu̱ gese̱ ar tsi Hmu Hesukristo, togo ꞌñu ar ꞌraꞌyo nkohi. Ne ár ji bi nöꞌmi xa döta ar ñho ñꞌudi, hingi ñhe̱hwi ár ji ar Abel. 
\p  
\v 25 Jamasuhu̱ yo ma gi fe̱ꞌsfu̱ ár mhö togo zoju̱. Ngetho nuꞌmu̱ himbi kꞌontꞌa nuꞌu̱ bi me̱ꞌspa ár mhö togo mi zokwa har ximha̱i, hanja ga kꞌonthu̱ nuꞌmu̱ ga fe̱ꞌsfu̱ ár mhö Jö bi e mhetsꞌi. 
\p  
\v 26 Nunar mhö bi japi bi nhwötꞌa gatho nuwa har ximha̱i, nupya xi ñötkagihu̱ xi ꞌñenö: Ho̱nse̱ manꞌagi ma ga japa da nhwötꞌa hinge ho̱nse̱ ar ximha̱i, xo̱ge mhetsꞌi nꞌehe. 
\p  
\v 27 Núꞌmu̱ enö, manꞌagi, ne da ꞌñenö ma da hwönga gatho nöꞌö tsa̱ da ꞌñöni ne xi thoki. Ho̱nse̱ da gohi nuꞌu̱ hingi tsa̱ da ꞌñöni. 
\p  
\v 28 Jange nuꞌmu̱ xta höñhu̱ nꞌar tsꞌu̱tꞌwi hingi tsa̱ da ꞌñöni, ma ga umfu̱ njamödi Jö, ne ga pe̱pabihu̱ ngu neꞌö, ga pe̱ꞌsfu̱ ar ntsu ne ar ntsuni. 
\p  
\v 29 Ngetho ma tsi Dadahu̱ ñhe̱hwi nꞌar tsibi tsötꞌa xo̱ge. 
\c 13  
\s1 Njanu̱ da mꞌu̱i ya gamfi 
\p  
\v 1 Yo ma gi hye̱hu̱ da the ar mhöte di pe̱ꞌsu̱ nꞌa ngu nꞌa nuya di nkuhu̱. 
\p  
\v 2 Yo ma gi hye̱hu̱ gi umfu̱ ar tsa̱ya̱ maꞌra ha ri nguhu̱. Ngetho ꞌra mödi hinxi bödi, xi umba ar tsa̱ya̱ ya e̱nxe̱ ha yá ngu. 
\p  
\v 3 Beñhu̱ ya ꞌyofa̱di, hu ri mu̱ihu̱ wande gi owihu̱ mahye̱gi har fa̱di. Yo gi pumhnihu̱ nuꞌu̱ xi mfe̱i, ngetho gi pe̱ꞌsase̱hu̱ ri ndoꞌyohu̱ nꞌehe. 
\p  
\v 4 Tsuñhu̱ ar nthöti ne suhu̱ dar ntꞌaxi. Ha nuꞌu̱ ꞌbe̱ngwi nuꞌu̱ hinxi nthötwi ne nuꞌu̱ ka yá nthöti, Jö ma da hñöꞌspa majöni. 
\p  
\v 5 Nzöñhu̱ hingi hyo̱ju̱ ar bojö, ñhogamu̱ihu̱ nöꞌö gi pe̱ꞌsu̱. Ngetho Jö bi ꞌñenö: Hinga he̱kꞌaꞌi, hinga pumhniꞌi. 
\p  
\v 6 Jange hinga tu ma mu̱ihu̱ ga eñhu̱: 
\q1 Ar tsi Hmu go fa̱xkagi, hinga ntsu. 
\q1 Te da jakaga ar jöꞌi. 
\p  
\v 7 Beñhu̱ ri ma̱ꞌyohu̱ togo bi xiꞌahu̱ ár mhö Jö. Hyanthu̱ tengu bi njöpabi yá mꞌu̱i, ne te̱mfu̱ yá jamfi. 
\p  
\v 8 Ar tsi Hmu Hesukristo getꞌö ngu mahamꞌu̱, ar pania, ne hiñhamꞌu̱ da mponi. 
\p  
\v 9 Yo ma gi ñhe̱hu̱ da kaꞌahu̱ maꞌra ya ntꞌuti hingi o yá ꞌñu. Ngetho xiñho gi ze̱ta ri jamfihu̱ hár nhwëki ar tsi Hmu, hinge ha ya ñhuni. Nuyu̱ hinte bi ma̱xa nuꞌu̱ togo mi japꞌu̱. 
\p  
\v 10 Di pe̱ꞌsu̱ nꞌar mꞌo̱xmꞌo̱ñho̱ habu̱ nuya möjö mi mpe̱ hár nijö Jö mi ꞌbu̱ mahamꞌu̱, hingi tsa̱ da hñöka ar mꞌo̱ñho̱ da zi. 
\p  
\v 11 Nunar döngamöjö mi ku̱tꞌa har nijö ár ji ya me̱ti nda tꞌunga ngu ar mꞌo̱ñho̱, ne nda thökwa yá tsꞌoki ya jöꞌi. Ne nuyá ndoꞌyo nuya me̱tiyu̱ nda tsꞌötꞌa yapꞌu̱ habu̱ hinto mi ꞌbu̱i. 
\p  
\v 12 Jange ar tsi Hmu Hesukristo nꞌehe, bi tho nthi har hnini, ne njapꞌu̱ nunár jise̱ bi nöꞌmi, da hñökwa yá tsꞌoki ya jöꞌi. 
\p  
\v 13 Ma ga po̱ñhu̱ ꞌmu̱ ga thöhu̱ nthi, ne ga e̱nthu̱ ma tehu̱ ga thohu̱ nuya u̱gi ngu bi thoꞌö nꞌehe. 
\p  
\v 14 Ngetho hindi pe̱ꞌsu̱wa nꞌar hnini hiñhamꞌu̱ da götsꞌi. Di hoñhu̱ nöꞌö manꞌa xi ꞌñepꞌu̱. 
\p  
\v 15 Nuꞌmú̱, ma ga tutwabihu̱ Jö nꞌar thuhu ngu nꞌar mꞌo̱ñho̱, ngetho di ꞌbu̱hwihu̱ ar tsi Hmu Hesukristo. Ma ga eñhu̱ nunar mꞌo̱ñho̱nu̱, po̱nga ha ma nehu̱ matꞌwa ár thuhu Jö. 
\p  
\v 16 Ne ga o̱thu̱ xiñho hinga pumhnihu̱ ga mfa̱xu̱ nꞌa ngu nꞌa, ngetho nuya mꞌo̱ñho̱yu̱ numañho Jö. 
\p  
\v 17 ꞌYo̱thu̱ ri ma̱ꞌyohu̱, yo ma gi thöthu̱ nöꞌö xiꞌahu̱. Ngetho nuꞌu̱ hingi tsa̱ya̱ suꞌahu̱, pödi ma da thöꞌspa majöni. Jahu̱pꞌu̱ ne da njohya da ꞌyo̱tꞌe, hinge di tu yá mu̱i, ngetho nunu̱ hinte fa̱xꞌahu̱. 
\p  
\v 18 ꞌYa̱fu̱ Jö da ma̱xkagihe. Di beñhe hinte tsu̱kagihe ma mfenihe, ngetho di nehe ga o̱the xiñho gatho. 
\p  
\v 19 Ho̱nse̱ mꞌe̱tꞌo di xiꞌahu̱ gi ꞌya̱fu̱ ngutꞌa da tsa̱ ga mapꞌu̱ manꞌagi. 
\s1 Ntꞌëdi ya ku ne mhatꞌwa Jö 
\p  
\v 20 Jö unga ar hogamꞌu̱i, ne bi japi bi mengi bi nte ar tsi Hmu Hesukristo manꞌagi, nuna ar hoga Ma̱ꞌyo bi nöꞌma ár ji bi du̱ꞌma nꞌar ꞌraꞌyo nkohi hiñhamꞌu̱ da götsꞌi. 
\p  
\v 21 Gese̱ Jö da ma̱xꞌahu̱ gi ꞌyo̱thu̱ ya hoga ꞌbe̱fi ngu neꞌö, ne da mpe̱ ha ri mu̱ihu̱ da tsa̱ gi ꞌyo̱thu̱ nöꞌö numañho. Da njapꞌu̱ ngetho tsixꞌahu̱ ar tsi Hmu Hesukristo, togo di ꞌñepi da tꞌumba ar nsunda hiñhamꞌu̱ da götsꞌi. Dá njapꞌu̱. 
\p  
\v 22 Di a̱ꞌahu̱ tsi kuhu̱, gi hñöñhu̱ nunar mhönu̱ hupꞌa ri mu̱ihu̱, nuna nꞌa tsi tu̱i xta otꞌahu̱. 
\p  
\v 23 Pöhu̱, xi nthe̱ ma tsi kuhu̱ Timoteo. Nuꞌmu̱ ngutꞌa da thokwa, ga me̱ꞌbe ma ga kꞌösꞌahe. 
\p  
\v 24 Ze̱ngwagihu̱ gatho ri ma̱ꞌyohu̱ ne gatho ya ku. Pe̱ñꞌahu̱ nze̱ngwa nuya ku me Italia. 
\p  
\v 25 Dá hyexꞌathoꞌihu̱ ár nhwëki Jö. Dá njapꞌu̱.