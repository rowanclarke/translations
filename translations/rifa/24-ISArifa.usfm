\id ISA
\h إِشَاعْيَا
\toc1 إِشَاعْيَا
\toc2 إِشَاعْيَا
\toc3 إِشا.
\mt1 إِشَاعْيَا
\c 1
\s1 ثَامژْرِيوْثْ ن إِشَاعْيَا
\m 
\v 1 ڒوْحِييْ ن إِشَاعْيَا، مِّيسْ ن أَمُوصْ، نِّي إِژْرَا خْ يَاهُوذَا ذ ؤُرْشَالِيمْ، ذڭْ وُوسَّانْ ن عُوزِّييَا، يُوثَامْ، أَحَازْ ذ حِيزْقِييَا، إِجدْجِيذنْ ن يَاهُوذَا.
\b
\m 
\v 2 ”سْڒمْ، \add أَ\add* إِجنْوَانْ، ؤُشَا سّغْذْ، \add أَ\add* ثَامُّورْثْ، مِينْزِي سِيذِي إِسَّاوَاڒْ: ’نشّْ سّيْمغْ إِحنْجِيرنْ ؤُ سّمْغَارغْ ثنْ، \add مَاشَا\add* نِيثْنِيغوّْغنْ خَافِي. \x ◘ \xo 1:‏2 \xt أَعَوذ. 32‏:‏1\x*
\v 3 أَفُونَاسْ إِسّنْ بَابْ نّسْ ذ ؤُسْنُوسْ ڒْمذْوذْ ن سِيذِي نّسْ، \add مَاشَا\add* إِسْرَائِيل وَارْ غَارسْ بُو ثُوسّْنَا، ڒْڭنْسْ إِنُو وَارْ ذَايسْ ثدْجِي ڒفْهَامثْ.
\v 4 \bd ؤُشْثْ\bd* خْ ڒْڭنْسْ إِ إِخْضَانْ، ڒْڭنْسْ \add إِ خْ إِدْجَا\add* دّْقڒْ ن ڒْمُوعْصِييّثْ، زَّارِيعثْ ن إِعفَّاننْ، ثَارْوَا ن ؤُسْنخْڒِيعْ. نِيثْنِي جِّينْ سِيذِي، سّحْقَارنْ أَمْقدَّاسْ ن إِسْرَائِيل، أَرِّينْ \add أَسْ-د\add* س وعْرُورْ. \x ◘ \xo 1:‏4 \xt إِزهد. 78‏:‏8؛ إِشا. 57‏:‏3\x*
\v 5 مَانِي ثتّخْسمْ أَذْ ثتّْوَاوْثمْ عَاذْ، \add ؤُمِي\add* كنِّيوْ ثقِّيممْ ثتّْغوَّاغمْ. أَزدْجِيفْ مَارَّا إِهْڒشْ، ؤُڒْ مَارَّا يُوهڒْ أَطَّاسْ. \x ◘ \xo 1:‏5 \xt 2 إِم. 28‏:‏22؛ إِرْم. 2‏:‏30\x*
\v 6 زِي ثْڒقَّا ن ؤُضَارْ أَڒْ أَزدْجِيفْ وَارْ ذَايسْ ثتِّيفذْ مِينْ إِصبْحنْ! مْغِيرْ إِيزِّيمنْ، طّعْبَايَارْ ذ إِيزِّيمنْ يَارزْمنْ، وَارْ ثنْ هنّْضنْ، وَارْ ثنْ سّْيَارْضنْ، وَارْ ثنْ سَّارضْبنْ س زّشْثْ.
\v 7 ثَامُّورْثْ نْومْ ثخْڒَا، ثِيندَّامْ نْومْ سّْشمْضنْ ثنْثْ س ثْمسِّي، ثَامُّورْثْ نْومْ صَّارْذنْ ت إِبَارَّانِييّنْ زَّاثْ إِ ثِيطَّاوِينْ نْومْ، أَقَا-ت ذ ڒْخِيرْبثْ أَخْمِي سّنْقڒْبنْ ت إِبَارَّانِييّنْ. \x ◘ \xo 1:‏7 \xt أَعَوذ. 28‏:‏51، 52؛ إِشا. 5‏:‏5\x*
\v 8 يدْجِيسْ ن صِيهْيُونْ ثقِّيمْ غَارْ ضفَّارْ أَمْ يِيشْثْ ن ثْعِيشُّوثْ ذڭْ ؤُمَارْجعْ ن ؤُضِيڒْ، أَمْ ثخَّانْثْ \add ن ؤُعسَّاسْ\add* ذڭْ إِيَّارْ ن ڒخْيَارْ، أَمْ ثنْذِينْثْ إِتّْوَاحْصَارنْ.
\v 9 مْڒِي سِيذِي ن ڒْعسْكَارَاثْ وَارْ ذ أَنغْ إِجِّي ذْرُوسْ مِينْ يَاروْڒنْ، إِڒِي نذْوڒْ أَمْ سَاذُومْ، إِڒِي نڭَّا أَمْ عَامُورَّا.‘ “ \x ◘ \xo 1:‏9 \xt أَمز. 19‏:‏24؛ إِشا. 17‏:‏6؛ 24‏:‏6؛ 30‏:‏17؛ رُوم. 9‏:‏29\x*
\b
\m 
\v 10 ”سْڒمْ إِ وَاوَاڒْ ن سِيذِي، \add أَ\add* ڒْحُوكَّامْ ن سَاذُومْ! وْشمْ أَمزُّوغْ إِ شَّارِيعَا ن أَربِّي، \add أَ\add* ڒْڭنْسْ ن عَامُورَّا!
\v 11 مِينْ غَا ڭّغْ س ثْغَارْصِي نْومْ، إِقَّارْ سِيذِي. نشّْ جِّيوْنغْ زِي ثْغَارْصَا ن وشْمَاضْ ن إِشَارِّييّنْ ؤُ زِي ثَاذُونْثْ ن ڒْمَاڒْ إِصحّنْ. إِذَامّنْ ن إِفُونَاسنْ إِمژْيَاننْ ذ يزْمَارنْ ذ إِغَايْضنْ وَارْ ذ أَيِي تّعْجِيبنْ. \x ◘ \xo 1:‏11 \xt إِزهد. 50‏:‏8، 9؛ أَوڒن. 15‏:‏8؛ 21‏:‏27؛ إِشا. 66‏:‏3؛ إِرْم. 6‏:‏20؛ عَام. 5‏:‏22\x*
\v 12 خْمِي د-ثتَّاسمْ حِيمَا أَذْ ثْبَانمْ زَّاثْ إِ وُوذمْ إِنُو، وِي كنِّيوْ إِعَارْضنْ إِ ؤُيَا، مَاحنْذْ أَذْ ثْعفْسمْ خْ ڒمْرَاحَاثْ إِنُو؟
\v 13 وَارْ ذ أَيِي د-ثَاوْيمْ عَاذْ ثَاوْهِيبْثْ إِبضْڒنْ. ڒبْخُورْ غَارِي ذ نّْعِي. ؤُسَّانْ ن إِيُورنْ ن جْذِيذْ ذ وُوسَّانْ ن سّبْثْ ذ ؤُڒَاغِي إِ ثْمسْمُونِينْ إِقدّْسنْ وَارْ زمَّارغْ أَذْ حمْڒغْ \add مَارَّا\add* أَيَا، أَقَا-ث ذ ڒْمُوعْصِييّثْ، \add عَاذْ ؤُڒَا\add* ذ أَمُونِي إِفَارْزنْ.
\v 14 ڒعْمَارْ إِنُو إِشَارّهْ ؤُسَّانْ ن ؤُيُورْ ن جْذِيذْ نْومْ ذ ڒعْيُوذَاثْ نْومْ إِتّْوَاڭّنْ. أَقَا أَثنْ ذوْڒنْ غَارِي ذ ڒحْمڒْ، نشّْ ؤُحْڒغْ أَذْ ثنْ أَرْبُوغْ.
\v 15 خْمِي ثتّْسَارَّاحمْ إِفَاسّنْ نْومْ، تّْڒحّْفغْ إِ ثِيطَّاوِينْ إِنُو زَّايْومْ. عَاذْ مَاڒَا كنِّيوْ ثَارْنِيمْ ذِي ثْژَادْجِيثْ، نشّْ وَارْ ت تّسْڒِيغْ، مَاغَارْ إِفَاسّنْ نْومْعمَّارنْ س إِذَامّنْ.\x ◘ \xo 1:‏15 \xt أَوڒن. 1‏:‏28\x*
\v 16 سِيرْذمْ، سِيزْذڭمْ إِخفْ نْومْ، سِّيڭّْوجمْ ثُوعفّْنَا ن ثْمڭَّا نْومْ زِي زَّاثْ ن ثِيطَّاوِينْ إِنُو. سْبدّمْ زِي ڒْغَارْ إِ ثتّڭّمْ. \x ◘ \xo 1:‏16 \xt إِزهد. 34‏:‏15؛ 37‏:‏27؛ عَام. 5‏:‏15؛ رُوم. 12‏:‏9\x*
\v 17 ڒمْذمْ أَذْ ثڭّمْ مِينْ إِصبْحنْ، أَرْزُومْ خْ ڒْحقّْ، وْشمْ أَفُوسْ إِ ونِّي إِحْسَارنْ، ڭّمْ ثَاسْغَارْثْ إِ ؤُيُوجِيڒْ، وْثمْ خْ ثَاجَّاتْشْ.“
\b
\m 
\v 18 ”أَستِّيوْ-د ؤُ أجّْ أَنغْ أَذْ نتّمْحَاكمْ أَكْ-ذ وَايَاوْيَا!، إِقَّارْ سِيذِي. وَاخَّا دّْنُوبْ نّشْ ذ إِزڭّْوَاغنْ أَمْ ؤُزڭّْوَاغْ إِحذْقنْ، أَذْ ذوْڒنْ ذ إِشمْڒَارنْ أَمْ وذْفڒْ، وَاخَّا ذ إِزڭّْوَاغنْ أَمْ ؤُزڭّْوَاغْ يُودْجْغنْ، أَذْ ذوْڒنْ ذ إِشمْڒَاڒنْ أَمْ ثْضُوفْثْ. \x ◘ \xo 1:‏18 \xt إِزهد. 51‏:‏9\x*
\v 19 مَاڒَا كنِّيوْ ثْعوّْڒمْ، ؤُ أَذْ ثسْڒمْ، \add خنِّي\add* أَذْ ثشّمْ مِينْ إِصبْحنْ ن ثمُّورْثْ،
\v 20 مَاشَا مَاڒَا كنِّيوْ ثُوڭِيمْ ؤُشَا أَذْ ثْغوّْغمْ، أَذْ كنِّيوْ يشّْ سِّيفْ، مَاغَارْ أَقمُّومْ ن سِيذِي أَقَا إِسِّيوڒْ!“
\b
\m 
\v 21 \qt ”مَامّشْ ثذْوڒْ ثنْذِينْثْ\qt*
\m \qt نِّي ذَايسْ ڒَامَانْ\qt*
\m \qt ذ ثَامْغَارْثْ ن فَارْقْ-شّْغڒْ!\qt*
\m \qt نتَّاثْ ثُوغَا ثشُّورْ س ڒْحقّْ،\qt*
\m \qt ثَاسڭْذَا ثُوغَا ثتّْنُوسَا ذَايسْ،\qt*
\m \qt \tl مَاشَا\tl* ڒخُّو إِقتَّاڒنْ.\qt*
\m 
\v 22 \qt نُّوقَارْثْ نّمْ ثذْوڒْ ذ كُوفُّو،\qt*
\m \qt بِينُو نّمْ صُّورنْ ث أَكْ-ذ وَامَانْ.\qt* \x ◘ \xo 1:‏22 \xt حِز. 22‏:‏18، 19؛ حُوش. 4‏:‏18\x*
\m 
\v 23 \qt ڒْْحُوكَّامْ نّمْ تّْغوّْغنْ،\qt*
\m \qt أَقَا ڭِّينْ إِخوَّاننْ ذ إِمدُّوكَّاڒْ \tl نْسنْ\tl*،\qt*
\m \qt مَارَّا تّخْسنْ ثِيرْزِيفِينْ\qt*
\m \qt ؤُشَا أَرزُّونْ خْ أَرّشْوثْ.\qt*
\m \qt نِيثْنِي وَارْ تِّيغنْ إِ ؤُيُوجِيڒْ ثَاسْغَارْثْ نّسْ،\qt*
\m \qt دّعْوثْ ن ثِيجَّاڒْ وَارْ ثنْ ثتِّيكّْوِيضْ.“\qt* \x ◘ \xo 1:‏23 \xt إِرْم. 5‏:‏28؛ زَاك. 7‏:‏10\x*
\b
\m 
\v 24 ”س ؤُيَا إِقَّارْ سِيذِي، سِيذِي ن ڒْعسْكَارَاثْ، أَمْزمَّارْ ن إِسْرَائِيل: ’\bd ؤُشْثْ\bd* \add خَاومْ\add*! نشّْ أَذْ سّْفوّْجغْ إِخفْ إِنُو س إِغْرِيمنْ إِنُو، نشّْ أَذْ خڒْفغْ إِخفْ إِنُو زِي ڒْعذْيَانْ إِنُو.
\v 25 نشّْ أَذْ وْثغْ أَفُوسْ إِنُو خَاومْ، أَذْ كنِّيوْ صفِّيغْ أَكْ-ذ لِّيخِييَّا ؤُشَا مَارَّا ڒخْفِيفْ نّمْ أَذْ ث ودَّارغْ. \x ◘ \xo 1:‏25 \xt إِرْم. 6‏:‏29؛ مـَال. 3‏:‏3\x*
\v 26 نشّْ أَذْ \add أَمْ\add* وْشغْ عَاوذْ ڒْقُوضَاثْ نّمْ أَمْ غَارْ ؤُمزْوَارُو، ذ أَيْثْ ن شّْوَارْ نّمْ أَمْ غَارْ ؤُمزْوَارُو. أَوَارْنِي أَيَا أَذْ أَمْ ڒَاغَانْ: ’ثَانْذِينْثْ ن ثْسڭْذَا!‘ ذ ’ثنْذِينْثْ ذَايسْ ڒَامَانْ!‘
\v 27 صِيهْيُونْ أَذْ ثتّْوَاسّنْجمْ س ڒْحقّْ ذ يِينِّي زَّايسْ إِتُّوبنْ \add أَذْ تّْوَاسّنْجْمنْ\add* س ثْسڭْذَا،
\v 28 \add مَاشَا\add* إِمْغوّْغنْ ذ إِمذْنَابْ أَذْ تّْوَارْژنْ جْمِيعْ، ؤُشَا إِنِّي إِ غَا إِحيّْذنْ خْ سِيذِي، أَذْ تّْوَاقْضَانْ. \x ◘ \xo 1:‏28 \xt أَيُوبْ 31‏:‏3؛ إِزهد. 1‏:‏6؛ 5‏:‏6؛ 73‏:‏27؛ 92‏:‏10؛ 104‏:‏35\x*
\v 29 نِيثْنِي أَذْ سضْحَانْ زِي سِّيبّثْ ن ثْشجُّورَا ن لْ-أَصْنَامْ نِّي ذِي ثمّژْرمْ ؤُشَا كنِّيوْ أَذْ ثْسضْحَامْ زِي سِّيبّثْ ن إِحْوِيشنْ نِّي ثِيخْضَارمْ كنِّيوْ.
\v 30 مَاغَارْ كنِّيوْ أَذْ ثِيڒِيمْ أَمْ ثْشجَّارْثْ ن يِيڭّْ إِ زِي أَفَارْ نّسْ إِسْڒَاوْ، ؤُ أَمْ وحْوِيشْ إِ وَارْ غَارْ دْجِينْ وَامَانْ.
\v 31 أَذْ إِذْوڒْ ونِّي إِجهْذنْ ذ إِجّْ ن ؤُفِيڒُو ن ثِيفّسْثْ ؤُ ڒْخذْمثْ نّسْ ذ إِشْثْ ن ثْفطُّوثْ، أَذْ أَرْغنْ س ثْنَاينْ إِذْسنْ مُوننْ ؤُشَا وَارْ ذِينْ إِدْجِي ؤُڒَا ذ إِجّْ وِي غَا إِسّْخسْينْ.‘ “
\b
\b
\c 2
\s1 أَذْرَارْ ن ثَادَّارْثْ ن سِيذِي
\m 
\v 1 أَوَاڒْ نِّي إِژْرَا إِشَاعْيَا، مِّيسْ ن أَمُوصْ، خْ يَاهُوذَا ذ ؤُرْشَالِيمْ.
\b
\m 
\v 2 ”ذڭْ ؤُنڭَّارْ ن وُوسَّانْ أَذْ يِيڒِي وذْرَارْ ن ثَادَّارْثْ ن سِيذِي إِبدّْ إِمْثنْ خْ \add وذْرَارْ\add* أَمقّْرَانْ قَاعْ ن إِذُورَارْ. نتَّا أَذْ إِعْذُو مَارَّا ثِيوْرِيرِينْ ؤُشَا أَذْ غَارسْ د-أَزّْڒنْ مَارَّا ڒڭْنُوسْ. \x ◘ \xo 2:‏2 \xt مِيخَا 4‏:‏1\x*
\v 3 أَطَّاسْ ن ڒڭْنُوسْ أَذْ طّْفنْ أَبْرِيذْ \add ذِينِّي\add*، أَذْ إِنِينْ: ’أَسمْ-د، أجّْ أَنغْ أَذْ نْڭعّذْ غَارْ وذْرَارْ ن سِيذِي، غَارْ ثَادَّارْثْ ن أَربِّي ن يَاعْقُوبْ، حِيمَا نتَّا أَذْ أَنغْ إِسّڒْمذْ إِبْرِيذنْ نّسْ ؤُ نشِّينْ أَذْ نُويُورْ ذِي ثبْرِيذِينْ نّسْ!‘، مَاغَارْ زِي صِيهْيُونْ أَذْ د-ثفّغْ شَّارِيعَا ؤُ أَوَاڒْ ن سِيذِي زِي ؤُرْشَالِيمْ. \x ◘ \xo 2:‏3 \xt إِزهد. 110‏:‏2\x*
\v 4 نتَّا أَذْ إِحْكمْ جَارْ شُّوعُوبْ ؤُ أَذْ إِحَاكمْ خْ وَاطَّاسْ ن ڒڭْنُوسْ. نِيثْنِي أَذْ ڭّنْ ڒسْيُوفْ نْسنْ ذ دُّوزَانْ ؤُ فْڒِيثْشَاثْ نْسنْ ذ ڒمْوَاسْ إِ وزْبَارْ. وَارْ إِسّْڭعَّاذْ \add إِجّْ ن\add* ڒْڭنْسْ \add عَاذْ\add* سِّيفْ خْ \add إِجّْ ن\add* ڒْڭنْسْ \add نّغْنِي\add* ؤُ وَارْ ذَارِّيبنْ عَاذْ إِ ؤُمنْغِي. \x ◘ \xo 2:‏4 \xt يُووِ. 4‏:‏10؛ مِيخَا 4‏:‏3\x*
\v 5 \add أَ\add* ثَادَّارْثْ ن يَاعْقُوبْ، أَرَاحْ-د أجّْ أَنغْ أَذْ نُويُورْ ذِي ثْفَاوْثْ ن سِيذِي.“
\b
\s1 أَسّْ ن سِيذِي
\m 
\v 6 ”مَاغَارْ شكْ ثنْضَارذْ ڒْڭنْسْ نّشْ، ثَادَّارْثْ ن يَاعْقُوبْ، مِينْزِي نِيثْنِي شُّورنْ س ؤُقَارِّي زِي \add ثمُّورَا ن\add* شَّارْقْ ؤُشَا شغْڒنْ إِخفْ نْسنْ س ثْبزْڭِيوْثْ أَمْ \add ڒْڭنْسْ ن\add* إِفِيلِيسْطِينِييّنْ، ؤُشَا وْثِينْ إِفَاسّنْ أَكْ-ذ ثَارْوَا ن إِبَارَّانِييّنْ.
\v 7 ثَامُّورْثْ نْسنْ ثشُّورْ س نُّوقَارْثْ ذ وُورغْ ؤُ وَارْ ذِينْ أَنڭَّارْ غَارْ ثْخُوبَايْ نْسنْ. ثَامُّورْثْ نْسنْ ثشُّورْ س ييْسَانْ ؤُ وَارْ ذِينْ أَنڭَّارْ غَارْ \add ؤُبَارُّو ن\add* إِكَارُّوثنْ نْسنْ.
\v 8 ثَامُّورْثْ نْسنْ ثشُّورْ س لْ-أَصْنَامْ، نِيثْنِي بنْذْقنْ زَّاثْ إِ ڒْخذْمثْ ن إِفَاسّنْ نْسنْ، إِ مِينْ ڭِّينْ إِضوْضَانْ نْسنْ.
\v 9 \add أَمُّو\add* إِ غَا إِغْنسْ بْنَاذمْ ؤُشَا أَذْ إِسّهْوَا \add كُوڒْ\add* إِجّْ ن ورْيَازْ إِخفْ نّسْ. وَارْ ذ أَسنْ تّْسَامَاحْ!“
\m 
\v 10 ”أَذفْ غَارْ ڒجْرُوفْ، نُوفَّارْ ذڭْ ؤُشَاڒْ زِي سِّيبّثْ ن ؤُسْنخْڒِيعْ ن سِيذِي ؤُ زِي سِّيبّثْ ن ڒْعزّْ ن لْعَاضَامَا نّسْ!
\v 11 ثِيطَّاوِينْ إِنفْخنْ ن إِوْذَانْ أَذْ د-تّْوَاسّهْوَانْثْ ؤُ أَشنّعْ ن يرْيَازنْ أَذْ إِهْوَا. أَذْ إِتّْوَاسّْعُودْجْ سِيذِي وَاهَا \bd ذڭْ وَاسّْ نِّي\bd*. \x ◘ \xo 2:‏11 \xt إِشا. 5‏:‏15\x*
\m 
\v 12 مَاغَارْ أَسّْ إِ سِيذِي أَذْ د-يَاسْ خْ كُوڒْ بُو-نّْفَاخثْ ذ ؤُمْعفَّارْ ؤُ خْ كُوڒْ  إِجّْ ونِّي إِسّْعُودْجَانْ إِخفْ نّسْ، حِيمَا أَذْ د-إِتّْوَاسّهْوَا. \x ◘ \xo 2:‏12 \xt يُووِ. 2‏:‏10، 31؛ 3‏:‏15؛ إِشا. 13‏:‏6‏-‏13؛ 24‏:‏23؛ Am. 8‏:‏9؛ مت. 24‏:‏29؛ ڒخ. 2‏:‏20؛ أَسَا. 6‏:‏12‏-‏13\x*
\v 13 خْ مَارَّا ثِيشجُّورَا ن ثنْڭلْثْ يُوعْڒَانْ ذ إِتّْوَاسّْڭعّْذنْ \add ن وذْرَارْ\add* ن لُوبْنَانْ، خْ مَارَّا ثِيشجُّورَا ن ڒْبدْجُوضْ ن بَاشَانْ،
\v 14 خْ مَارَّا إِذُورَارْ إِعفَّارنْ، خْ مَارَّا ثِيوْرِيرِينْ يُوعْڒَانْ،
\v 15 خْ كُوڒْ لْبُورْجْ يُوعْڒَانْ، خْ كُوڒْ ڒْحِيضْ ن لْقلْعَا،
\v 16 خْ مَارَّا إِغَارُّوبَا ن ثَارْشِيشْ ؤُ خْ مَارَّا ڒقْشُوعْ إِغْڒَانْ.
\b
\m 
\v 17 نّْفَاخثْ ن بْنَاذمْ أَذْ ثسّهْوَا ؤُ إِرْيَازنْ إِعفَّارنْ أَذْ تّْوَاسّهْوَانْ. أَذْ إِتّْوَاسّْعُودْجْ سِيذِي وَاهَا \bd ذڭْ وَاسّْ نِّي\bd*.
\v 18 لْ‘أَصْنَامْ أَذْ تّْوَابضْڒنْ مَارَّا.
\v 19 \add خنِّي\add* أَذْ د-أَذْفنْ ذڭْ إِفْرَانْ ن ڒجْرُوفْ ذ إِحْفْرَاونْ ن ثمُّورْثْ زِي سِّيبّثْ ن ؤُسْنخْڒِيعْ ن سِيذِي ؤُ زِي سِّيبّثْ ن ؤُعُودْجِي ن لْعَاضَامَا نّسْ، خْمِي نتَّا أَذْ د-إِكَّارْ حِيمَا أَذْ إِسّْنخْڒعْ ثَامُّورْثْ. \x ◘ \xo 2:‏19 \xt أَسَا. 6‏:‏15‏-‏17\x*
\m 
\v 20 \bd ذڭْ وَاسّْ نِّي\bd* أَذْ إِنْضَارْ بْنَاذمْ لْ-أَصْنَامْ نّسْ ن نُّوقَارْثْ ذ لْ-أَصْنَامْ نّسْ ن وُورغْ، إِنِّي ڭِّينْ إِ يِيخفْ نْسنْ حِيمَا أَذْ أَسنْ بنْذْقنْ، \add أَڒَامِي إِ غَا يِيڒِينْ\add* إِ إِجَارْبُوعنْ ذ ڒْوضْوَاضَاثْ،
\v 21 مَاحنْذْ أَذْ د-أَذْفنْ ذِي ثزِّييِينْ ن ڒجْرُوفْ ؤُ ذڭْ إِفْرَانْ ذڭْ وژْرُو زِي ثِيڭّْوُوذِي ن سِيذِي ؤُ زِي سِّيبّثْ ن ڒْعزّْ ن لْعَاضَامَا نّسْ، خْمِي د غَا إِكَّارْ حِيمَا أَذْ إِسّْنخْڒعْ ثَامُّورْثْ.“
\b
\m 
\v 22 ”حيّْذمْ خْ بْنَاذمْ، ونِّي ذڭْ ونْزَارنْ نّسْ إِدْجَا مْغِيرْ نّفْسْ، مِينْزِي مِينْ إِعْنَا نتَّا قَاعْ أَذْ خَاسْ نحْسبْ؟“
\b
\b
\c 3
\s1 إِمْسيَّارنْ إِعفَّاننْ ن ؤُرْشَالِيمْ
\m 
\v 1 ”مَاغَارْ خْزَارْ، سِيذِي، سِيذِي ن ڒْعسْكَارَاثْ، أَذْ إِكّسْ خْ ؤُرْشَالِيمْ ذ يَاهُوذَا قَاعْ أَعكَّازْ ذ قَاعْ ثَاغَّارْشْثْ، قَاعْ ثَاموْشِيوْثْ س ؤُفُوسْ ن وغْرُومْ ذ قَاعْ ثَاموْشِيوْثْ س ؤُفُوسْ ن وَامَانْ،
\v 2 بُو-ثغْرُوضْثْ ذ ؤُعسْكَارِي، ڒْقَاضِي ذ ؤُنَابِي، أَڭزَّانْ ذ ؤُمْغَارْ،
\v 3 أَمقّْرَانْ خْ خمْسِينْ ذ بُو-شَّانْ، أَمْشَاوَارْ، بُو-صّنْعثْ ذ ونِّي غَارْ إِدْجَا ڒفْهَامثْ ن ثْحسّشْثْ ن ؤُعزّمْ.
\v 4 نشّْ أَذْ خَاسنْ ڭّغْ إِحُوضْرِييّنْ ذ ڒْحُوكَّامْ نْسنْ ؤُ نِيثْنِي أَذْ خَاسنْ سلّْطنْ أَمْ مَامّشْ تّخْسنْ نِيثْنِي.
\v 5 خنِّي ذِي ڒْڭنْسْ أَذْ حْسَارنْ إِجّْ إِ ونّغْنِي، أَرْيَازْ إِ ورْيَازْ \add نّغْنِي\add*، كُوڒْ إِجّْ إِ جَّارْ نّسْ. نِيثْنِي أَذْ هكّْوڒنْ إِجّْ إِ ونّغْنِي، أَحُوذْرِي إِ ؤُوسَّارْ، ونِّي إِتّْوَاسّحْقَارنْ إِ ونِّي إِتّْوَاشنّْعنْ.
\v 6 خْمِي غَا إِشبَّارْ شَا ن يِيجّنْ ؤُمَاسْ ذِي ثَادَّارْثْ ن بَابَاسْ، \add أَذْ يِينِي\add*: ’شكْ غَاركْ \add عَاذْ\add* إِجّْ ن ؤُپَارْثسُّو، إِتّْخصَّا أَذْ ثِيڒِيذْ ذ أَمْڭوّذْ خَانغْ. أَرّْ ڒْخَارْبثْ-أَ سَاذُو أَفُوسْ نّشْ!‘، \f ◼ \fr 3:‏6 \ft \bd ’أَرّْ ڒْخَارْبثْ-أَ ...‘\bd* - س ثْعِيبْرَانِيثْ ’حْضَا خْ ڒْخَارْبثْ-أَ سَاذُو إِفَاسّنْ نّكْ‘\f*
\v 7 \add خنِّي\add* أَذْ يَاڭِي نتَّا \bd ذڭْ وَاسّْ نِّي\bd*، أَذْ يِينِي: ’نشّْ وَارْ زمَّارغْ أَذْ إِڒِيغْ ذ أَمسْڭنْفُو. وَارْ ذِينْ بُو وغْرُومْ ؤُ وَارْ ذِينْ بُو وَارُّوضْ ذِي ثَادَّارْثْ إِنُو. وَارْ ذ أَيِي ثڭّمْ ذ أَمْڭوّذْ ن ڒْڭنْسْ!‘
\v 8 مَاغَارْ ثنّذْرفْ \add ثنْذِينْثْ ن\add* ؤُرْشَالِيمْ ؤُ ثوْضَا يَاهُوذَا، مِينْزِي إِڒسْ نْسنْ ذ ثْمڭَّا نْسنْ أَقَا أَثنْ ضِيدّْ إِ سِيذِي مَاحنْذْ أَذْ سْعَارنْ ثِيطَّاوِينْ ن ؤُعُودْجِي نّسْ.
\v 9 ثِيفْرَاسْ ن إِغمْبَابْ نْسنْ شهّْذنْثْ خَاسنْ. أَمْ سَاذُومْ سَّاوَاڒنْ نِيثْنِي س بْطَايْطَايْ خْ دّْنُوبْ نْسنْ، وَارْ ثنْ سّْنُوفَّارنْ. ؤُشْثْ خْ ڒعْمَارْ نْسنْ، مَاغَارْ نِيثْنِي تّڭّنْ ڒْغَارْ ذڭْ يِيخفْ نْسنْ.“
\m 
\v 10 ”إِنِيمْ إِ ؤُمْسڭّذْ أَقَا أَذْ يِيڒِي مْلِيحْ، أَقَا أَذْ شّنْ \add س يِيخفْ نْسنْ\add* ڒْغِيدْجثْ ن ثْمڭَّا نْسنْ.
\v 11 ؤُشْثْ خْ ؤُعفَّانْ. ؤُشْثْ خَاسْ، مَاغَارْ أَذْ ث خدْجْصنْ عْلَاحْسَابْ \add مِينْ ڭِّينْ\add* إِفَاسّنْ نّسْ.
\v 12 إِنِّي إِذدْجنْ ڒْڭنْسْ إِنُو أَقَا أَثنْ ذ إِحنْجِيرنْ، ؤُشَا ثِيمْغَارِينْ تّْصلّْطنْثْ خَاسْ. \add أَ\add* ڒْڭنْسْ إِنُو، إِنِّي شكْ إِندّْهنْ، أَقَا تّْغَارَّانْ شكْ، ؤُشَا ڒَاثَارْ ن ثْبْرِيذِينْ نّشْ مسّْحنْ ث.“
\m 
\v 13 ”سِيذِي إِوْجذْ حِيمَا أَذْ إِشَارّعْ، نتَّا إِبدّْ حِيمَا أَذْ إِشَارّعْ ڒڭْنُوسْ.
\v 14 سِيذِي أَذْ د-يَارْفعْ دّعْوثْ أَكْ-ذ إِمْغَارنْ ن ڒْڭنْسْ ؤُ أَكْ-ذ ڒْحُوكَّامْ نّسْ، مَاغَارْ كنِّيوْ ثسّْشمْضمْ أَمَارْجعْ ن ؤُضِيڒْ ؤُ مِينْ ثُوشَارمْ إِ إِمزْڒَاضْ أَقَا-ث ذِي ثُوذْرِينْ نْومْ.
\v 15 مِينْ كنِّيوْ يُوغِينْ، أَقَا ثْڒبّْزمْ ڒْڭنْسْ إِنُو ؤُ ثتّفّْژمْ إِغمْبَابْ ن إِمزْڒَاضْ؟، إِقَّارْ سِيذِي إِنُو، سِيذِي ن ڒْعسْكَارَاثْ.“
\b
\s1 ثِيمْغَارِينْ ثِيمْعفَّارِينْ ن ؤُرْشَالِيمْ
\m 
\v 16 \add أَمُّو\add* إِ إِقَّارْ سِيذِي: ”مِينْزِي يسِّيسْ ن صِيهْيُونْ ذَايْسنْثْ نّْفَاخثْ، ڭُّورنْثْ س إِرَاونْ ڭعّْذنْ، س ڒخْزْرَاثْ تّْغَارَّانْثْ، أَمْ تّْرَاحنْثْ ؤُ تّْقزْقِيزنْثْ س إِصُورَافْ مَاحنْذْ أَذْ سّْطنْطُوننْثْ إِخڒْخَاڒنْ ن إِضَارنْ نْسنْثْ،
\v 17 أَذْ يَارّْ سِيذِي إِنُو جْذَامْ خْ ثَاشقُّوفْثْ ن ؤُزدْجِيفْ ن يسِّيسْ ن صِيهْيُونْ ؤُشَا أَذْ إِعَارَّا سِيذِي ڒْعَارْ نْسنْثْ.“
\m 
\v 18 ”\bd ذڭْ وَاسّْ نِّي\bd* أَذْ أَسنْثْ إِكّسْ سِيذِي إِنُو \add مَارَّا\add* ڒهْزُوطْ \add نْسنْثْ\add*: إِخڒْخَاڒنْ خْ إِضَارنْ نْسنْثْ ذ ڒِيزَارَاثْ \add تّْوَاشدّنْثْ\add* خْ ثنْيَارْثْ ذ ثزْرِيوِينْ ثِيمژْيَانِينْ
\v 19 ذ ثخْرَازِينْ ذِي صِّيفثْ ن ثُوذِّيمِينْ ذ ثِيمقْيَاسِينْ ذ لّْثَامَاثْ
\v 20 ذ إِحوَّاقنْ إِزوّْقنْ إِ ؤُزدْجِيفْ ذ إِخرْخَاڒنْ ذ ثْحزَّامِينْ ذ ثْزِييَّاثِينْ إِتّْفُوحنْ ذ ڒحْرُوزْ
\v 21 ذ ثْخَاذِينْ ن ؤُفُوسْ ذ ثخْرَازِينْ ن ثنْزَارِينْ
\v 22 ذ وَارُّوضْ ن ويْذُوذْ ذ ڒِيزَارَاثْ ذ ثْسبْنَايْ ذ إِقُورَابْ
\v 23 ذ ثِيسِيثِينْ ذ ورُّوضْ نْ ڒقْطنْ أَزْذَاذْ ذ ثْشُوشَّايْ ذ فُونَارَاثْ ن ؤُزدْجِيفْ.
\v 24 ذڭْ ومْشَانْ \add ن ڒفْوَاحثْ\add* ن بَالْسَامْ أَذْ ثِيڒِي أَرِّيحثْ، ذڭْ ومْشَامْ ن ثْحزَّامْثْ \add أَذْ يِيڒِي\add* وسْغُونْ، ذڭْ ومْشَانْ ن ثْشنْكُوكِينْ إِشُووَّارنْ \add أَذْ يِيڒِي\add* ؤُزدْجِيفْ أَقشَّارْ، ذڭْ ومْشَانْ ن ورُّوضْ إِوْسعْ \add أَذْ ثِيڒِي\add* ثْخَانْشثْ \add ن وشْضَانْ\add* ؤُ ذڭْ ومْشَانْ ن وژْرِي ذ ؤُعدْجمْ ن وشْمَاضْ \add خْ ثڒْمشْثْ\add*.
\v 25 إِرْيَازنْ نّمْ أَذْ وْضَانْ س سِّيفْ ؤُ أَيْثْ ن بُو-ثغْرُوضْثْ نّمْ ذڭْ ؤُمنْغِي.
\v 26 ثِيوُّورَا نّسْ أَذْ شثْشَانْثْ ؤُ أَذْ شضْننْثْ ؤُشَا نتَّاثْ أَذْ ثقِّيمْ خْ ثمُّورْثْ س إِفَاسّنْ خْوَانْ.“ \f ◼ \fr 3:‏26 \ft \bd ’ثِيوُّورَا نّسْ‘\bd* - إِخْسْ أَذْ يِينِي ’ثِيوُّورَا ن ؤُرْشَالِيمْ‘ نِيغْ ’ثِيوُّورَا ن صِيهْيُونْ‘.\f*
\b
\b
\c 4
\m 
\v 1 ”\bd ذڭْ وَاسّْ نِّي\bd* أَذْ شبَّارنْثْ سبْعَا ن ثمْغَارِينْ ذڭْ إِجّْ ن ورْيَازْ، أَذْ قَّارنْثْ: ’نشِّينْ أَذْ نشّْ أَغْرُومْ نّغْ ؤُ أَذْ نسّْيَارْضْ إِخفْ نّغْ، أجّْ أَنغْ أَذْ نكْسِي إِسمْ نّشْ وَاهَا، كْسِي ڒفْضِيحثْ خَانغْ.‘ “
\b
\m 
\v 2 ”\bd ذڭْ وَاسّْ نِّي\bd* أَذْ إِذْوڒْ ؤُغدُّو ن سِيذِي ذ ثلْوِيزْثْ إِشوَّارنْ، ؤُ ڒْغِيدْجثْ ن ثمُّورْثْ ذ ڒْعزّْ ذ ؤُشوَّارْ إِ مِينْ إِنّجْمنْ ن إِسْرَائِيل.
\v 3 مِينْ إِقِّيمنْ ن صِيهْيُونْ ذ ونِّي إِقِّيمنْ ذِي ؤُرْشَالِيمْ عَاذْ، أَذْ أَسنْ إِنِينْ: ’ذ أَمْقدَّاسْ!‘، كُوڒْ إِجّْ ذِي ؤُرْشَالِيمْ ونِّي إِتّْوَازمّمنْ إِ ثُوذَارْثْ.
\v 4 خْمِي غَا إِسِّيرْذْ سِيذِي ڒخْمجْ ن يسِّيسْ ن صِيهْيُونْ ؤُ أَذْ إِسْرِيرْ زِي ڒْوسْثْ ن ؤُرْشَالِيمْ إِذَامّنْ س أَرُّوحْ ن ڒحْكَامْ ؤُ س أَرُّوحْ إِشمّْضنْ،
\v 5 خنِّي أَذْ إِڭّْ سِيذِي ذڭْ ؤُزِيڒْ إِجّْ ن ؤُسيْنُو خْ مَارَّا ثَازذِّيغْثْ خْ وذْرَارْ ن صِيهْيُونْ ؤُ خْ ثْمسْمُونِينْ نّسْ ؤُ س دْجِيڒثْ دّخَّانْ ذ ثِيسِّيقْثْ ن ثْمسِّي إِتّْشعْشِيعنْ، مَاغَارْ ثِيوَا مَارَّا مِينْ إِعُودْجنْ \add أَذْ ثِيڒِي\add* ثْقِيذُونْثْ إِ ؤُذُورِّي ن ثسْڒِيثْ.
\v 6 أَذْ يِيڒِي ؤُعِيشُّو إِ ثِيڒِي س ؤُزِيڒْ زِي ڒحْمُو ؤُ إِ ومْشَانْ ن ثَاروْڒَا ذ ؤُذُورِّي زِي ڒْحمْڒثْ ذ ونْژَارْ.“
\b
\b
\c 5
\s1 ثَادَّارْثْ ن إِسْرَائِيل: أَمَارْجُوعْ ن ؤُضِيڒْ ن سِيذِي
\m 
\v 1 ”تّخْسغْ أَذْغنّْجغْ \add إِزْڒِي\add* إِ لِّيفْ إِنُو، إِزْڒِي ن لِّيفْ إِنُو خْ \add ؤُمَارْجعْ\add* نّسْ ن ؤُضِيڒْ:
\b
\m \qt ’لِّيفْ إِنُو غَارسْ إِجّْ ن ؤُمَارْجعْ ن ؤُضِيڒْ\qt*
\m \qt خْ إِجّْ ن وذْرَارْ إِ د-إِتّْوَاسّْڭعّْذنْ\qt*
\m \qt أَمْ إِجّْ ن يِيشّْ ن إِجّْ ن مِّيسْ \tl ذهْننْ ث\tl* س زّشْثْ.\qt* \f ◼ \fr 5:‏1 \ft \bd ’س زّشْثْ‘\bd* - س ثْعِيبْرَانِيثْ ’ن زّشْثْ‘\f*
\m 
\v 2 \qt نتَّا إِنْقشْ إِ-ث ؤُ إِصفَّا إِ-ث زڭْ إِژْرَا،\qt*
\m \qt إِژُّو ث س ثْزَايَارِينْ إِشنّْعنْ.\qt*
\m \qt نتَّا إِسّْبدّْ إِجّْ ن لْبُورْجْ ذِي ڒْوسْطْ نّسْ.\qt*
\m \qt إِنْقشْ ذَايسْ ثَاسِيرْثْ \tl ن ؤُضِيڒْ\tl*.\qt*
\m \qt خنِّي ثُوغَا إِسِّيثِيمْ،\qt*
\m \qt أَحْوِيشْ ن ثْزَايَارْثْ أَذْ د-يَاوِي أَضِيڒْ،\qt*
\m \qt \tl مَاشَا\tl* نتَّا يِيوِي-د أَضِيڒْ أَسمَّامْ.‘ “\qt*
\b
\m 
\v 3 ”\add خنِّي\add* ڒخُّو، \add أَ\add* إِمزْذَاغْ ن ؤُرْشَالِيمْ ذ \add كنِّيوْ\add* إِرْيَازنْ ن يَاهُوذَا، حكْممْ جَارْ أَيِي ذ ؤُمَارْجعْ إِنُو ن ؤُضِيڒْ!
\v 4 مِينْ زمَّارغْ نشّْ عَاذْ أَذْ ڭّغْ إِ ؤُمَارْجعْ إِنُو ن ؤُضِيڒْ نِّي وَارْ ذ أَسْ ڭِّيغْ عَاذْ؟ مَايمِّي سِّيثِيمغْ أَقَا أَذْ د-يَاوِي أَضِيڒْ مْلِيحْ، \add ؤُمِي\add* د يِيوِي مْغِيرْ أَضِيڒْ أَسمَّامْ؟ \x ◘ \xo 5:‏4 \xt إِرْم. 2‏:‏5؛ مِيخَا 6‏:‏3، 8\x*
\v 5 \add خنِّي\add* ڒخُّو، نشّْ خْسغْ أَذْ أَومْ سّشْنغْ مِينْ غَا ڭّغْ أَكْ-ذ ؤُمَارْجعْ إِنُو ن ؤُضِيڒْ: نشّْ أَذْ كّْسغْ أَفْرَايْ نّسْ إِ ث إِحْضَانْ، حِيمَا أَذْ ث ڒقْضنْ قَاعْ، أَذْ ڭّغْ إِشْثْ ن ثَازِّيثْ ذِي ڒْحِيضْ أَڒْ خَاسْ إِ غَاعفْسنْ. \x ◘ \xo 5:‏5 \xt إِزهد. 80‏:‏13\x*
\v 6 أَذْ ث ڭّغْ ذ ڒخْڒَا، وَارْ ث زبَّارنْ نِيغْ أَذْ ث شَارْزنْ، \add مَاشَا\add* ثَازڭّْوَارْثْ ذ إِسنَّاننْ أَذْ ذِينِّيغمْينْ ؤُ نشّْ أَذْ ؤُمُورغْ إِسيْنُوثنْ مَاحنْذْ وَارْ ذ أَسْ تِّيشنْ أَنْژَارْ.
\v 7 مَاغَارْ أَمَارْجعْ ن ؤُضِيڒْ ن سِيذِي ن ڒْعسْكَارَاثْ ذ ثَادَّارْثْ ن إِسْرَائِيل ؤُ إِرْيَازنْ ن يَاهُوذَا ذ ثَاغدُّوثْ مِينْ خفْ يَارْضَا. إِرَاجَا ڒْحقّْ، \add مَاشَا\add* خْزَارْ، ثُوعفّْنَا، \add إِرَاجَا\add* ثَاسڭْذَا، \add مَاشَا\add* خْزَارْ، ثْغُويِّيثْ.“ \x ◘ \xo 5:‏7 \xt إِزهد. 80‏:‏9\x*
\b
\m 
\v 8 ”\bd ؤُشْثْ\bd* خْ يِينِّي إِتّْسدَّانْ ثَادَّارْثْ غَارْ ثَادَّارْثْ ؤُ أَرنّْينْ إِيَّارْ غَارْ ييَّارْ، أَڒْ ثَافذْ وَارْ ذَا إِدْجِي ومْشَانْ عَاذْ ؤُ كنِّيوْ وَاهَا إِ إِزدّْغنْ ذِي ڒْوسْطْ ن ثمُّورْثْ! \x ◘ \xo 5:‏8 \xt مِيخَا 2‏:‏2\x*
\v 9 إِنَّا أَيِي سِيذِي ن ڒْعسْكَارَاثْ ذڭْ إِمزُّوغنْ إِنُو: ’س ثِيذتّْ، أَطَّاسْ ن ثُوذْرِينْ أَذْ ذوْڒنْثْ ذ ڒْخِيرْبثْ إِسَّاڭّْوَاذنْ، \add ثُوذْرِينْ\add* ثِيمقّْرَانِينْ ذ ثِينِّي إِشْنَانْ وَارْ ذَايْسنْثْ إِزدّغْ عَاذْ ؤُڒَا ذ إِجّْ.‘
\v 10 مِينْزِيعشْرَا ن إِفدَّاننْ ن ؤُمَارْجعْ ن ؤُضِيڒْ أَذْ أَوْينْ مْغِيرْ إِجّْ ن ؤُبَاثُو، ؤُ إِجّْ ن ؤُحُومِيرْ ن زَّارِّيعثْ أَذْ يَاوِي مْغِيرْ إِجّْ ن إِفَا \add ن ڒْحبّْ ن إِرْذنْ\add*.“ \f ◼ \fr 5:‏10 \ft \bd ’أَبَاثُو‘\bd* - إِجّْ ن ’ؤُبَاثُو‘ عْرَاحَاڒْ 20 نِيغْ 40 لِيثْرُو.\f*
\m 
\v 11 ”\bd ؤُشْثْ\bd* خْ يِينِّي إِكَّارنْ زِيشْ، أَرزُّونْ خْ شّْرَابْ ؤُ تّْغِيمَانْ \add وْسوْسنْ\add* أَڒْ ثْبَامْبَاسْثْ، \add أَڒْ\add* ثنْ إِسّحْمَا بِينُو! \x ◘ \xo 5:‏11 \xt أَوڒن. 23‏:‏29، 30\x*
\v 12 ڒْڭَامْبْرِي ذ لهَارْپَا ذ ؤُبنْذِيرْ ذ ثمْجَا ذ بِينُو أَقَا أَثنْ غَارْ زّْرَاذِي نْسنْ، \add مَاشَا\add* مِينْ إِتّڭّْ سِيذِي وَارْ غَارسْ خزَّارنْ، ثَامڭِّيثْ ن إِفَاسّنْ نّسْ، وَارْ ت تّْوِيڒِينْ.
\v 13 س ؤُيَا أَذْ إِتّْوَانْذهْ ڒْڭنْسْ إِنُو ذِي لْمنْفَا، مِينْزِي وَارْ غَارسْ ثدْجِي ثُوسّْنَا. ثَارْوَا ن ثَاصِيڒثْ ن ڒْڭنْسْ أَذْ هيّْفنْ، أَذْ يَاژغْ ؤُبَارُّو نْسنْ س ؤُفَاذِي. \x ◘ \xo 5:‏13 \xt عَام. 6‏:‏7\x*
\v 14 س ؤُيَا إِ غَا ثَارْزمْ ڒَاخَارْثْ أَطَّاسْ ثْمِيجَّا نّسْ، أَذْ يَارْزمْ أَقمُّومْ نّسْ نْهْڒَا ڒقْيَاسْ، مَاحنْذْ أَذْ ذَايسْ إِهْوَا ڒْعزّْ نّسْ ذ ؤُبَارُّو نّسْ ذ دّْرِيزْ نّسْ ذ \add مَارَّا\add* إِنِّي ذَايسْ إِنڭّْزنْ \add أَمُّو\add* س ڒفْرَاحثْ.
\v 15 \add خنِّي\add* أَذْ إِخْنسْ بْنَاذمْ ؤُشَا \add كُوڒْ\add* أَرْيَازْ أَذْ إِتّْوَاسّهْوَا، ؤُشَا ثِيطَّاوِينْ ن أَيْثْ ن بُو-نّْفَاخثْ أَذْ ذوْڒنْثْ خزَّارنْثْ غَارْ سْوَادَّايْ.
\v 16 \add مَاشَا\add* سِيذِي ن ڒْعسْكَارَاثْ أَذْ إِتّْوَاسّْعُودْجْ س ڒْحقّْ ؤُ أَربِّي ذ أَمْقدَّاسْ أَذْ ؤُتّْوَاقدّسْ س ثْسڭْذَا.
\v 17 أَذْ هدّنْ ذِينِّي إِزْمَارنْ أَمْ \add تّْهدَّانْ\add* خْ ثْكسَّاوْثْ نْسنْ، ؤُشَا إِبَارَّانِييّنْ أَذْ شّنْ ڒخْرَابِي ن أَيْثْ ن بُو-وَاڭْڒَا.“ \x ◘ \xo 5:‏17 \xt إِشا. 14‏:‏30\x*
\m 
\v 18 ”\bd ؤُشْثْ\bd* خْ يِينِّي \add غَارْسنْ\add* د-إِجبّْذنْ ڒْمُوعْصِييّثْ س ثسْغُونِينْ ن ڒْغشّْ ؤُڒَا ذ دّنْبْ س إِسغْوَانْ \add إِقبُّوزنْ\add* ن ؤُكَارُّو ن إِعجْمِييّنْ،
\v 19 إِنِّي إِقَّارنْ: ’أجّْ إِ-ث أَذْ يَازّڒْ، أجّْ إِ-ث أَذْ ث إِڭّْ ذغْيَا حِيمَا أَذْ ث نْژَارْ، ؤُشَا شّْوَارْ ن ؤُمْقدّسْ ن إِسْرَائِيل أجّْ إِ-ث أَذْ إِخشّْ، أَذْ د-يَاسْ، حِيمَا أَذْ ث نسّنْ!‘ “
\m 
\v 20 ”\bd ؤُشْثْ\bd* خْ ينِّي، مِينْ وَارْ إِحْڒِينْ قَّارنْ أَسْ إِصْبحْ ؤُ مِينْ إِصبْحنْ وَارْ إِحْڒِي، إِنِّي إِتّڭّنْ ثَادْجسْثْ ذ ثْفَاوْثْ ؤُ ثَافَاوْثْ ذ ثَادْجسْثْ، إِنِّي إِتّڭّنْ مِينْ يَارْزِيڭنْ ذ مِيژِيذْ ؤُ مِينْ إِزِيضنْ ذ أَمَارْزَاڭْ.“
\m 
\v 21 ”\bd ؤُشْثْ\bd* خْ يِينِّي ؤُمِي إِتّْغِيڒْ أَسنْ أَقَا أَثنْ ذ إِمِيغِيسنْ إِ يِيخفْ نْسنْ، ؤُ \add ؤُشْثْ خْ يِينِّي إِحسّْبنْ\add* إِخفْ نْسنْ ذ إِفهَّامنْ!“ \x ◘ \xo 5:‏21 \xt أَوڒن. 3‏:‏7؛ رُوم. 12‏:‏16\x*
\m 
\v 22 ”\bd ؤُشْثْ\bd* خْ يِينِّي إِدْجَانْ ذ أَيْثْ ن بُو-ثغْرُوضْثْ غَارْ ثْسسِّيثْ ن بِينُو ؤُ \add خْ\add* يرْيَازنْ إِمحْضنْ غَارْ وحْرَايْ ن شّْرَابْ،
\v 23 إِنِّي إِتّْسَارَّاحنْ إِ ؤُعفَّانْ س ثرْزفْثْ \add إِغشّنْ\add*، \add مَاشَا\add* كّْسنْ ثَاسْغَارْثْ إِ إِمْسڭَّاذنْ.“ \x ◘ \xo 5:‏23 \xt أَوڒن. 17‏:‏15؛ 24‏:‏24\x*
\b
\m 
\v 24 ”س ؤُيَا إِ غَا إِخْسَارْ وژْوَارْ نْسنْ ؤُ ثَانوَّاشْثْ نْسنْ أَذْ ثضُووْ أَمْ ثْعجَّاجْثْ، أَمْ مَامّشْ إِتّتّْ إِڒسْ ن ثْمسِّي إِغدْجْ ؤُ أَمْ مَامّشْ إِهكّْوَا وُورُومْ س ؤُشعَّاڒْ، مَاغَارْ نِيثْنِي نْضَارنْ شَّارِيعَا ن سِيذِي ن ڒْعسْكَارَاثْ ؤُ سّحْقَارَانْ زڭْ وَاوَاڒنْ ن ؤُمْقدَّاسْ ن إِسْرَائِيل. \x ◘ \xo 5:‏24 \xt ؤُف. 15‏:‏7؛ إِشا. 9‏:‏18\x*
\v 25 خْ ؤُيَا يَارْغَا وغْضَابْ ن سِيذِي خْ ڒْڭنْسْ نّسْ ؤُشَا إِكْسِي خَاسْ أَفُوسْ نّسْ. أَقَا إِوْثَا إِ-ث أَڒَامِي أَرْجِيجنْ إِذُورَارْ ؤُ ڒْخشْبَاثْ نْسنْ مدّنْثْ خْ إِمسْرَاقْ أَمْ وفْرَاضْ. \bd س مَارَّا أَيَا وَارْ يَارخُّو وغْضَابْ نّسْ، \bdit مَاشَا\bdit* أَفُوسْ نّسْ إِقِّيمْ إِسَارّحْ.\bd* \x ◘ \xo 5:‏25 \xt إِشا. 9‏:‏11، 16، 20؛ 10‏:‏4، 6\x*
\v 26 مَاغَارْ أَذْ إِسّْڭعّذْ ثَاعدْجَانْثْ إِ ڒڭْنُوسْ نِّي إِدْجَانْ ذِي ڒَاڭّْوَاجْ، ؤُ زڭْ ؤُنڭَّارُو ن ثمُّورْثْ أَذْ ث إِصفَّارْ غَارسْ. خْزَارْ، إِتَّاسْ-د ذغْيَا س ثزْڒَا.
\v 27 وَارْ غَارسْ يُوحِيڒْ ؤُڒَا ذ إِجّْ، ؤُڒَا ذ إِجّنْ إِنْقَارْضْ، ؤُڒَا ذ إِجّنْ إِنُّوذمْ نِيغْ إِطّصْ، ؤُڒَا غَارْ إِجّنْ وَارْ إِفْسِي أَبْيَاسْ خْ ثجْعِينَّا نّسْ نِيغْ إِقطّسْ أَسْ إِجّْ ن ؤُفِيڒُو ن سَانْذَالِييَاثْ نّسْ.
\v 28 فْڒِيثْشَاثْ نّسْ قضْعنْثْ ؤُ مَارَّا ڒقْوَاسْ نّسْ تّْوَامحّْضنْ. ثِيشضْيِينْ ن ييْسَانْ نّسْ بَاننْثْ قسْحنْثْ أَمْ ؤُقَايَاسْ، ثِيجَارَّارِينْ نّسْ أَمْ ثْحَارْيَاضْثْ.
\v 29 زّْهِيرْ نّسْ أَمْ \add زّْهِيرْ ن\add* ثيْرَاذْثْ ؤُ \add نتَّا\add* إِتّْزهَّارْ أَمْ يِييْرَاذنْ إِمژْيَاننْ. أَذْ يَارُّودْجذْ، أَذْ إِطّفْ ثَايْمَارْثْ نّسْ ؤُشَا أَذْ \add ت\add* إِجَارّْ ؤُ وَارْ إِتِّيڒِي وِي ث غَا إِفكّنْ.
\v 30 \bd ذڭْ وَاسّْ نِّي\bd* أَذْ إِزهَّارْ ضِيدّْ \add ڒْْڭنْسْ\add* أَمْ زّْهِيرْ نْ ڒبْحَارْ. أَذْ خزَّارنْ غَارْ ثمُّورْثْ، أَقَا-ت \add مْغِيرْ ذ\add* ثَادْجسْثْ ذ ڒحْصَارثْ، ؤُشَا ثَافَاوْثْ أَذْ ثبَّارْشنْ س إِسيْنُوثنْ إِبَّارشْننْ.“ \x ◘ \xo 5:‏30 \xt إِشا. 8‏:‏22\x*
\b
\b
\c 6
\s1 ثَاڒَاغِيثْ ن أَربِّي خْ إِشَاعْيَا
\m 
\v 1 ذڭْ ؤُسڭّْوَاسْ ن ڒْموْثْ ن ؤُجدْجِيذْ عُوزِّييَا ژْرِيغْ سِيذِي إِقِّيمْ خْ ڒْعَارْشْ يُوعْڒَانْ إِتّْوَاسّْڭعّْذنْ ؤُشَا أَفْرَايْ ن وَارُّوضْ نّسْ إِتّْشُورْ زَّاوشْثْ ثَامقّْرَانْثْ. \x ◘ \xo 6:‏1 \xt 2 إِج. 15‏:‏7\x*
\v 2 ثِيوَا نّسْ بدّنْ إِسَارَافِييّنْ، \add لْمَالَاكَاثْ نِّي إِتّْبَاننْ أَمْ ذَايْسنْ ثِيمسِّي\add*، غَارْسنْ ستَّا ن وَافْرِيونْ. قَاعْ إِجّْ غَارسْ ستَّا ن وَافْرِيونْ. س ثْنَاينْ \add ن وَافْرِيونْ\add* إِڒحّفْ أَغمْبُوبْ نّسْ، س ثْنَاينْ إِڒحّفْ إِضَارنْ نّسْ ؤُ س ثْنَاينْ ثُوغَا إِطَّاوْ. \f ◼ \fr 6:‏2 \ft \bd ’إِسَارَافِييّنْ‘\bd* - إِجّْ ن مَارْكَا ن لْمَالَاكَاثْ إِنِّي إِتّْبَاننْ أَمشْنَاوْ ذَايْسنْ ثْمسِّي.\f*  \x ◘ \xo 6:‏2 \xt أَسَا. 4‏:‏8\x*
\v 3 إِڒَاغَا إِجّْ خْ ونّغْنِي، إِنَّا: ”أَمْقدَّاسْ، أَمْقدَّاسْ، أَمْقدَّاسْ ذ سِيذِي ن ڒْعسْكَارَاثْ. مَارَّا ثَامُّورْثْ ثشُّورْ س ؤُعُودْجِي نّسْ!“، \x ◘ \xo 6:‏3 \xt أَسَا. 4‏:‏8\x*
\v 4 أَڒَامِي نْهزّنْ ذْسُوسَا ن ثْنبْذَاثِينْ ن ثوَّارْثْ س ثْمِيجَّا ن ونِّي إِڒَاغَانْ ؤُشَا ثَادَّارْثْ ثشُّورْ س دّخَّانْ.
\m 
\v 5 \add خنِّي\add* نِّيغْ نشّْ: ”\bd ؤُشْثْ\bd* خَافِي، مَاغَارْ أَذْ هلّْكغْ، مَاغَارْ نشّْ ذ أَرْيَازْ بُو-إِينْشِيشنْ خمْجنْ ؤُ زدّْغغْ جَارْ ڒْڭنْسْ ن أَيْثْ ن بُو-إِينْشِيشنْ خمْجنْ، \add وَاخَّا أَمنِّي\add* ثِيطَّاوِينْ إِنُو ژْرِينْثْ أَجدْجِيذْ، سِيذِي ن ڒْعسْكَارَاثْ.“
\v 6 إِضْوَا-د إِجّْ زڭْ إِسَارَافِييّنْ غَارِي. يَارْبُو ڒفْحمْ إِتّحْذُوذُوقنْ ذڭْ ؤُفُوسْ نّسْ نِّي ثُوغَا إِكْسِي س ثْجقَّاضْثْ زڭْ ؤُعَالْطَارْ.
\v 7 نتَّا إِحَاذَا زَّايسْ أَقمُّومْ إِنُو، إِنَّا: ”خْزَارْ، إِحَاذَا \add ڒفْهمْ إِتّحْذُوذُوقنْ\add* وَانِيثَا إِينْشِيشنْ نّشْ. ثمّكْسِي ڒْمُوعْصِييّثْ نّشْ ؤُ إِتّْوَاسّصْڒحْ إِ دّنْبْ نّشْ.“ \x ◘ \xo 6:‏7 \xt إِرْم. 1‏:‏9؛ دَان. 10‏:‏16\x*
\m 
\v 8 أَوَارْنِي ؤُيَا سْڒِيغْ إِ ثْمِيجَّا ن سِيذِي إِنُو، ثقَّارْ: ”مَانْ ونْ إِ غَا سّكّغْ ؤُ وِي غَا يُويُورنْ مَاحنْذْ أَذْ إِزْوَارْ إِ نشِّينْ؟“ \add خَاسْ ؤُشَا\add* نِّيغْ: ”خْزَارْ، أَقَا أَيِي ذَا، سكّْ أَيِي!“
\v 9 \add خنِّي\add* إِنَّا: ”ؤُيُورْ ؤُشَا ثِينِيذْ إِ ڒْڭنْسْ-أَ: ’وَاخَّا أَذْ ثسْڒمْ س ثيْنِيثْ، وَارْ \add ث\add* ثْفهّْممْ!‘، ؤُشَا: ’وَاخَّا ثژْرِيمْ مْلِيحْ، وَارْ \add ث\add* ثسِّينمْ!‘\x ◘ \xo 6:‏9 \xt مت. 13‏:‏14؛ مك. 4‏:‏12؛ لك. 8‏:‏10؛ يُوح. 12‏:‏40 ڒخ. 28‏:‏26؛ رُوم. 11‏:‏8\x*
\v 10 سقْسحْ ؤُڒْ ن ڒْڭنْسْ-أَ، ؤُشَا بلّعْ أَسْ إِمزُّوغنْ نّسْ، سڒْسقْ أَسْ ثِيطَّاوِينْ مَاحنْذْ س ثِيطَّاوِينْ نّسْ وَارْ إِتّْوِيڒِي ؤُ س إِمزُّوغنْ نّسْ وَارْ إِتّسْڒِي ؤُ س وُوڒْ نّسْ وَارْ إِتّسّنْ، أَڒَامِي وَارْ إِذِّيكّْوِيڒْ ؤُشَا أَذْ إِتّْوَاسّْڭنْفَا.“ \x ◘ \xo 6:‏10 \xt إِرْم. 5‏:‏21\x*
\m 
\v 11 \add خنِّي\add* نِّيغْ: ”أَڒْ مڒْمِي، \add أَ\add* سِيذِي إِنُو؟“ نتَّا يَارَّا-د: ”أَڒْ إِ غَا تّْوَاخَارّْبنْثْ ثْندَّامْ، وَارْ \add ذَايْسنْثْ\add* إِتّْغِيمِي عَاذْ ؤُمزْذُوغْ، ؤُڒَا ذ ثُوذْرِينْ، وَارْ \add ذَايْسنْثْ\add* إِتّْغِيمِي عَاذْ بْنَاذمْ، ؤُشَا أَذْ ثِيڒِي ثمُّورْثْ ثَاردّدْجْ.
\v 12 مَاغَارْ سِيذِي أَذْ إِسّْبعّذْ إِوْذَانْ غَارْ ڒَاڭّْوَاجْ، ؤُشَا أَذْ ثِيڒِي ثمُّورْثْ ثخْوَا أَطَّاسْ.
\v 13 \add مَاشَا\add* أَذْ ذَايسْ ثقِّيمْ عَاذْ إِشْثْ ن ثعْشَارْثْ، \add مَاشَا\add* ؤُڒَا ذ مَانْ أَيَا أَذْ ثتّْوَاشّْ، \add مَاشَا\add* أَمْ مَامّشْ غَارْ ثْشجَّارْثْ ن يِيڭّْ ؤُ غَارْ ثْشجَّارْثْ ن ڒْبدْجُوضْ أَوَارْنِي ڒَامِي ثنْثْ إِ غَا زذْمنْ، أَذْ إِقِّيمْ عَاذْ جّْذعْ، \add أَمُّو\add* إِ غَا يِيڒِي جّْذعْ نّسْ ذ زَّارِيعثْ ثَامْقدّسْثْ.“
\b
\b
\c 7
\s1 ڒعْڒَامثْ ن عِيمَّانُو-إِلْ
\m 
\v 1 ذڭْ وُوسَّانْ ن أَحَازْ، مِّيسْ ن يُوثَامْ، مِّيسْ ن عُوزِّييَا، أَجدْجِيذْ ن يَاهُوذَا، إِڭعّذْ رَاصِينْ، أَجدْجِيذْ ن أَرَامْ، أَكْ-ذ فَاقَاحْ، مِّيسْ ن رَامَالْيَاهُو، أَجدْجِيذْ ن إِسْرَائِيل، غَارْ ؤُرْشَالِيمْ مَاحنْذْ أَذْ إِمّْنغْ أَكِيذسْ. \add مَاشَا\add* نتَّا وَارْ إِزمَّارْ أَذْ خَاسْ إِغلّبْ. \x ◘ \xo 7:‏1 \xt 2 إِج. 16‏:‏5؛ 2 إِم. 28‏:‏5\x*
\v 2 \add ؤُمِي\add* حَاجَانْ إِ ثَادَّارْثْ ن ذَاوُوذْ، نَّانْ: ”أَقَا إِهْوَا أَرَامْ خْ إِفْرَايِيمْ!“، يَارْجِيجْ وُوڒْ ن ؤُجدْجِيذْ ذ وُوڒْ ن ڒْڭنْسْ نّسْ، أَمْ مَامّشْ تَّارْجِيجِينْثْ ثْشجُّورَا ن وزْغَارْ س ؤُسمِّيضْ. \f ◼ \fr 7:‏2 \ft \bd ’أَزْغَارْ‘\bd* - نِيغْ ’ڒْغَابثْ‘ نِيغْ ’ثَازْڭَانْثْ‘.\f*
\m 
\v 3 إِنَّا سِيذِي إِ إِشَاعْيَا: ”فّغْ إِ ؤُمْسَاڭَارْ أَكْ-ذ أَحَازْ، شكْ ذ مِّيشْ شَاآرْ-يَاشُوبْ، غَارْ ؤُنڭَّارْ ن ؤُقَاذُوسْ ن وَامَانْ ن ؤُيڒْمَانْ ن سنّجْ، ونِّي \add إِدْجَانْ\add* غَارْ وبْرِيذْ يُوعْرَانْ غَارْ وحْوِيشْ ن ؤُصبَّانْ.
\v 4 إِنِي أَسْ: ’حْضَا، أَرْسْ، وَارْ تّڭّْوذْ شَا ؤُ وَارْ تّجِّي ؤُڒْ نّشْ أَذْ يَارْخُو خْ ثْنَاينْ ن إِسفْضَاونْ ن ؤُكشُّوضْ إِدُّوخُّوننْ، خْ ؤُخيّقْ يَارْغِينْ ن رَاصِينْ ذ أَرَامْ، ؤُ ن مِّيسْ ن رَامَالْيَاهُو،
\v 5 ؤُمِي إِخَارّصْ أَرَامْ ذِي ڒْغَارْ خَاكْ، \add جْمِيعْ\add* أَكْ-ذ إِفْرَايِيمْ ؤُ أَكْ-ذ مِّيسْ ن رَامَالْيَاهُو، إِنَّا:
\v 6 ’أجّْ أَنغْ أَذْ نْڭعّذْ خْ \add ثمُّورْثْ ن\add* يَاهُوذَا ؤُشَا أَذْ أَسْ نسِّيڭّْوذْ ؤُشَا أَذْ ت نبْضَا جَارْ أَنغْ ؤُ \add خنِّي\add* أَذْ نڭّْ ذِينِّي مِّيسْ ن طَابْيِيلْ ذ أَجدْجِيذْ.‘
\v 7 أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’أَيَا وَارْ إِتِّيڒِي، أَيَا وَارْ إِتّمّْسَارْ شَا!‘
\v 8 مَاغَارْ أَزدْجِيفْ ن أَرَامْ ذ ذِيمَاشْقْ ؤُ أَزدْجِيفْ ن ذِيمَاشْقْ ذ رَاصِينْ - وَاخَّا أَمّنِّي إِقِّيمْ عَاذْ مْغِيرْ خمْسَا ؤُ-ستِّينْ ن إِسڭّْوُوسَا خنِّي أَذْ يَارْژْ إِفْرَايِيمْ أَڒْ وَارْ إِتِّيڒِي \add عَاذْ\add* ذ ڒْڭنْسْ -
\v 9 ؤُشَا أَزدْجِيفْ ن إِفْرَايِيمْ ذ سَامَارْيَا ؤُ أَزدْجِيفْ ن سَامَارْيَا ذ مِّيسْ ن رَامَالْيَاهُو. مَاڒَا وَارْ ثُومِينمْ، وَارْ ثتّْغِيمَامْ أَذْ ثْبدّمْ.“
\m 
\v 10 يَارْنِي سِيذِي \add عَاذْ\add* ذڭْ وَاوَاڒْ أَكْ-ذ أَحَازْ، إِنَّا:
\v 11 ”تَّارْ إِشْثْ ن ڒعْڒَامثْ إِ يِيخفْ نّشْ زِي سِيذِي، أَربِّي نّشْ، تَّارْ إِ-ت سْوَادَّايْ ذِي رَادْجَاغْ نِيغْ تَّارْ إِ-ت ذِينِّي سنّجْ ذِي ڒُوعْڒَا.“
\v 12 \add مَاشَا\add* أَحَازْ إِنَّا: ”نشّْ وَارْ ت تّتَّارغْ شَا ؤُ وَارْ تّْقدْجَابغْ سِيذِي.“
\v 13 \add خنِّي\add* إِنَّا نتَّا: ”سْڒمْ، \add كنِّيوْ\add* \add أَ\add* ثَادَّارْثْ ن ذَاوُوذْ، مَا وَارْ كنِّيوْ إِقدّْ أَذْ ثسِّيحْڒمْ إِوْذَانْ، أَقَا كنِّيوْ ثسِّيحْڒمْ \add عَاوذْ\add* ؤُڒَا أَربِّي إِنُو؟
\v 14 س ؤُيَا أَذْ أَومْ إِوْشْ سِيذِي إِنُو سِيمَانْثْ نّسْ ڒعْڒَامثْ. خْزَارْ، ثَاعْزَارشْثْ أَذْ ثيْسِي دّيْسثْ، أَذْ ثَارُو مِّيسْ، أَذْ أَسْ ثڭّْ ’عِيمَّانُو-إِلْ‘، \add إِخْسْ أَذْ يِينِي ’سِيذِي أَقَا-ث أَكِيذْنغْ‘\add*. \x ◘ \xo 7:‏14 \xt مت. 1‏:‏23؛ لك. 1‏:‏31\x*
\v 15 نتَّا أَذْ إِشّْ ثْرُوسِّي ذ ثَامّنْثْ أَڒْ غَا إِفْثنْ أَذْ إِنْضَارْ مِينْ وَارْ إِحْڒِينْ ؤُ أَذْ إِخْضَارْ مِينْ إِصبْحنْ.
\v 16 مَاغَارْ قْبڒْ إِ غَا إِسّنْ ؤُحنْجِيرْ أَذْ إِنْضَارْ مِينْ وَارْ إِحْڒِينْ ؤُ أَذْ إِخْضَارْ مِينْ إِصبْحنْ، أَذْ ثخْڒَا ثمُّورْثْ نِّي ن ثْنَاينْ ن إِجدْجِيذنْ إِ زِي شكْ ثطّْفذْ ثِيڭّْوُوذِي.
\v 17 أَذْ إِسِّيوضْ سِيذِي خَاكْ ؤُ خْ ڒْڭنْسْ نّشْ ؤُ خْ ثَادَّارْثْ ن بَابَاشْ س ؤُفُوسْ ن ؤُجدْجِيذْ ن أَشُّورْ ؤُسَّانْ أَمْ مَامّشْ وَارْ د-ؤُسِينْ زڭْ وَاسّْ نِّي ذِي إِمّْسبْضَا إِفْرَايِيمْ خْ يَاهُوذَا.“
\m 
\v 18 ”\bd ذڭْ وَاسّْ نِّي\bd* أَذْ إِمْسَارْ، أَقَا سِيذِي أَذْ إِصفَّارْ إِژَانْ \add إِ إِدْجَانْ\add* غَارْ إِنڭُّورَا ن إِغزْرَانْ ن مِيصْرَا ؤُڒَا ذ ثْزِيزْوَا \add إِ إِدْجَانْ\add* ذِي ثمُّورْثْ ن أَشُّورْ.
\v 19 أَذْ د-أَسنْ ؤُشَا أَذْ أَرْسنْ مَارَّا ذِي ثغْزُورِينْ ؤُ ذِي ثزِّييِينْ ن ڒجْرُوفْ ؤُ خْ مَارَّا ڒْحَارَّاشْ ؤُ خْ مَارَّا إِيڒْمَامنْ ن ڒْوَارُوذْ.“
\m 
\v 20 ”\bd ذڭْ وَاسّْ نِّي\bd* أَذْ أَومْ إِڒْسْ سِيذِي إِنُو س إِجّْ ن ڒْمُوسّْ إِ ذ إِشْرَا خْ ؤُجمَّاضْ ن إِغْزَارْ \add ن لْفُورَاطْ\add*، س \add ؤُفُوسْ ن\add* ؤُجدْجِيذْ ن أَشُّورْ، \add أَشُوَّافْ ن\add* ؤُزدْجِيفْ ذ ؤُشُوَّافْ خْ إِضَارنْ ؤُڒَا ذ ثْمَارْثْ.“
\m 
\v 21 ”\bd ذڭْ وَاسّْ نِّي\bd* أَرْيَازْ أَذْ يَاربَّا إِشْثْ ن ثْعجْمِيثْ ن إِفُونَاسنْ ذ ثْنَاينْ ن وُودْجِي.
\v 22 س ثْيَاوَانْثْ ن ؤُغِي إِ غَا وْشنْثْ، أَذْ يشّْ ثْرُوسِّي. ثْرُوسِّي ذ ثَامّنْثْ أَذْ يشّْ مَارَّا وِي غَا إِقِّيمنْ ذِي ثمُّورْثْ.“
\m 
\v 23 ”\bd ذڭْ وَاسّْ نِّي\bd* أَذْ يِيڒِي كُوڒْ أَمْشَامْ إِ خفْ بدّنْ أَڒفْ ن ثْزَايَارِينْ إِ إِسكّْوَانْ أَڒفْ ن ڒوْزَانْ ن نُّوقَارْثْ، إِ إِسنَّاننْ ذ ثْزڭّْوَارْثْ. \x ◘ \xo 7:‏23 \xt لَاوِي 26‏:‏22؛ Hgd. 8‏:‏11، 12\x*
\v 24 أَذْ ؤُيُورنْ غَارْ ذِينْ س فْڒِيثْشَا ذ ڒْقوْسْ، مَاغَارْ مَارَّا ثَامُّورْثْ أَذْ ثِيڒِي ثشُّورْ س إِسنَّاننْ ذ ثْزڭّْوَارْثْ.
\v 25 ؤُڒَا خْ مَارَّا ثِيسَاوْنِينْ نِّي شَارّْزنْ س ؤُڒِيزِيمْ، وَارْ ذِينْ د-تَّاسنْ \add عَاذْ\add* زِي سِّيبّثْ ن ثِيڭّْوُوذِي زڭْ إِسنَّاننْ ذ ثْزڭّْوَارْثْ. \add ثَامُّورْثْ نِّي\add* أَذْ ثِيڒِي حِيمَا أَذْ أَرّنْ غَارْ ذِينِّي إِفُونَاسنْ ؤُ حِيمَا أَذْ \add خَاسْ\add*عفْسنْ وُودْجِي.“
\b
\b
\c 8
\s1 زَّارْذثْ س ثَازْڒَا، ثَاكشَّاضْثْ ذغْيَا
\m 
\v 1 إِنَّا أَيِي سِيذِي: ”كْسِي ثَاڒْوِيحْثْ ثَامقّْرَانْثْ، ثَارِيذْ خَاسْ س ڒقْڒمْ ن بْنَاذمْ \add أَڒَامِي زمَّارنْ أَذْ ث غَارنْ\add*: ’زَّارْذثْ س ثَازْڒَا، ثَاكشَّاضْثْ ذغْيَا!‘ “
\v 2 ڒشْهُوذْ إِمْثِيقَّانْ إِوْيغْ-ثنْ ذ أَشهَّاذْ إِ يِيخفْ إِنُو: أَكهَّانْ ؤُرِييَا ذ زَاكَارِييَّا، مِّيسْ ن يَابْرَاخْيَا.
\v 3 ثُوغَا ؤُذْفغْ خْ ثْنَابِيثْ ؤُ ثكْسِي س دّيْسثْ، ثُورُووْ-د إِجّْ ن ؤُحنْجِيرْ. ؤُشَا إِنَّا أَيِي سِيذِي: ”أڭّْ أَسْ: ’مَاهَارْ-شَالَالْ، خَاشْ-بَازْ!‘، \add إِخْسْ أَذْ يِينِي: ’زَّارْذثْ س ثَازْڒَا، ثَاكشَّاضْثْ ذغْيَا!‘\add*
\v 4 مَاغَارْ قْبڒْ مَا أَذْ إِڒْمذْ ؤُحنْجِيرْ أَذْ يِينِي: ’بَابَا!‘، نِيغْ: ’يمَّا!‘، أَذْ كّْسنْ أَڭْڒَا ن ذِيمَاشْقْ ذ زَّارْذثْ ن سَامَارْيَا زَّاثْ إِ وُوذمْ ن ؤُجدْجِيذْ ن أَشُّورْ.“
\b
\m 
\v 5 يَارْنِي سِيذِي ذڭْ وَاوَاڒْ أَكِيذِي، إِنَّا:
\v 6 ”مِينْزِي ڒْڭنْسْ-أَ إِسّحْقَارْ أَمَانْ يَارْسَانْ إِتَّازّْڒنْ ن شِيلُوهَا، س ؤُيَا إِفَارْحْ رَاصِينْ ذ مِّيسْ ن رَامَالْيَاهُو.
\v 7 س ؤُيَا، خْزَارْ، سِيذِي إِنُو أَذْ يَارّْ أَمَانْ يوْعَارنْ ذ إِمقّْرَاننْ ن إِغْزَارْ \add ن لْفُورَاطْ\add* أَذْ خَاسنْ حمْڒنْ، \add إِخْسْ أَذْ يِينِي\add* أَجدْجِيذْ ن أَشُّورْ ذ مَارَّا أَعُودْجِي نّسْ. أَذْ إِڭعّذْ زِي مَارَّا ثَارْيِيوِينْ نّسْ ؤُ أَذْ د-إِسّْفِييْ ثِيوَا ن مَارَّا ثِيمُووَّا نّسْ.
\v 8 أَذْ يَاذفْ غَارْ يَاهُوذَا، أَذْ ت إِسّْغَارْقْ ؤُشَا أَذْ يَارْنِي أَذْ غَارسْ د-يَازّڒْ أَڒْ د-أَسْ إِ غَا يَاوضْ أَڒْ يِيڒِي. خْمِي غَا إِسّْوِيژّضْ أَفْرِيونْ نّسْ أَذْ ذْڒنْ ثِيرُو ن ثمُّورْثْ نّشْ! \add أَ عِيمَّانُو-إِلْ\add*، أَربِّي أَقَا-ث أَكِيذنغْ.“
\m 
\v 9 ”هَاجَامْ، \add أَ كنِّيوْ\add* ڒڭْنُوسْ، \add مَاشَا عَاذْ\add* أَذْ ثتّْوَاڒبْزمْ! أجّْ مَارَّا جّْوَايهْ إِڭّْوجنْ ن دُّونشْثْ أَذْ وْشنْ إِمزُّوغنْ نْسنْ: وَاخَّا ثْحزّْممْ إِخفْ نْومْ، أَذْ ثتّْوَاڒبْزمْ، وَاخَّا ثْحزّْممْ إِخفْ نْومْ، أَذْ ثتّْوَاڒبْزمْ!
\v 10 مْشَاوَارمْ، \add مَاشَا\add* أَمْشَاوَارْ نْومْ أَذْ إِفْشڒْ! إِنِيمْ إِجّْ ن وَاوَاڒْ، وَارْ إِتِّيڒِي، مَاغَارْ أَربِّي أَقَا-ث أَكِيذْنغْ، \add ’عِيمَّانُو-إِلْ‘\add*.“
\b
\s1 ڒُومُورْ ن سِيذِي إِ إِشَاعْيَا
\m 
\v 11 مَاغَارْ أَمُّو إِ ذ أَيِي إِنَّا سِيذِي، ؤُمِي خَافِي إِجْهذْ ؤُفُوسْ نّسْ ؤُ إِعْڒمْ أَيِي حِيمَا وَارْ ڭُّورغْ خْ وبْرِيذْ ن ڒْڭنْسْ-أَ، إِنَّا:
\v 12 ”وَارْ قَّارمْ ’ثَامعْمُوتْشْ!‘ إِ مَارَّا ؤُمِي إِقَّارْ ڒْڭنْسْ-أَ ’ثَامعْمُوتْشْ!‘ وَارْ تّڭّْوذمْ ؤُ وَارْ تّْنخْڒِيعمْ!
\v 13 سِيذِي ن ڒْعسْكَارَاثْ أَذْ ث ثسّْقدّْسمْ، أَذْ زَّايسْ ثڭّْوذمْ ؤُ أَذْ زَّايسْ ثنّْخڒْعمْ.
\v 14 نتَّا أَذْ يِيڒِي ذ زَّاوشْثْ إِقدّْسنْ، ذ أَژْرُو ن ؤُنذْرَافْ ؤُڒَا ذ ثَاصْضَارْثْ ن ؤُنقْرَاضْ إِ ثْنَاينْ ن ثُوذْرِينْ ن إِسْرَائِيل، ذ ڒْفخْ ذ ثْرَاشَّا إِ إِمزْذَاغْ ن ؤُرْشَالِيمْ. \x ◘ \xo 8:‏14 \xt إِشا. 28‏:‏16؛ لك. 2‏:‏34؛ رُوم. 9‏:‏33؛ 1 بُط. 2‏:‏7\x*
\v 15 أَطَّاسْ جَارْ أَسنْ أَذْ نّْقَارْضنْ، أَذْ وْضَانْ، أَذْ تّْوَارْژنْ، أَذْ ذوْڒنْ غَارْ ڒْفخْ ؤُشَا أَذْ نَّاغنْ.“ \x ◘ \xo 8:‏15 \xt مت. 21‏:‏44؛ لك. 20‏:‏18\x*
\b
\m 
\v 16 ”شْفنْ شّْهَاذثْ، شمّعْ شَّارِيعَا جَارْ إِمحْضَارنْ إِنُو!“
\b
\m 
\v 17 ”نشّْ أَذْ رَاجِيغْ سِيذِي، ونِّي إِڒحّْفنْ إِ ؤُغمْبُوبْ نّسْ زَّاثْ إِ ثَادَّارْثْ ن يَاعْقُوبْ، خَاسْ إِ غَا ثشْڒغْ.
\v 18 خْزَارْ، نشّْ ذ إِحنْجِيرنْ نِّي ذ أَيِي إِوْشَا سِيذِي، أَقَا أَنغْ ندْجْ إِ ڒعْڒَامَاثْ ذ لْمُوعْجِيزَاثْ ذِي إِسْرَائِيل زِي سِّيبّثْ ن سِيذِي ن ڒْعسْكَارَاثْ نِّي إِزدّْغنْ خْ وذْرَارْ ن صِيهْيُونْ.“\x ◘ \xo 8:‏18 \xt عبر. 2‏:‏13\x*
\m 
\v 19 ”مَاڒَا نَّانْ أَومْ: ’سقْسَامْ إِنِّي إِسَّاوَاڒَانْ أَكْ-ذ إِمتَّانْ ذ إِڭزَّاننْ، إِنِّي إِتّْوسْوِيسنْ ؤُ إِتّْوشْوِيشنْ!‘، \add خنِّي إِنِي:\add* ’مَا وَارْ د-يُوسِي إِ يِيجّْ ن ڒْڭنْسْ أَذْ إِسّقْسَا أَربِّي نّسْ؟ مَا \add إِعدّڒْ أَذْ سّقْسَانْ\add* إِمتَّانْ ذِي طّْوعْ ن يِينِّي إِدَّارنْ؟‘ “\x ◘ \xo 8:‏19 \xt أَعَوذ. 18‏:‏11\x*
\b
\m 
\v 20 ”\add ذوْڒمْ\add* غَارْ شَّارِيعَا ؤُ غَارْ شّْهَاذثْ! مَاڒَا وَارْ ؤُيُورنْ عْلَاحْسَابْ أَوَاڒْ-أَ، وَارْ غَارْسنْ ثتِّيڒِي ثْفَاوْثْ ن ڒفْجَارْ.“
\b
\m 
\v 21 ”أَذْ إِنّضْ \add ڒْْڭنْسْ\add* ذَا ذ ذِيهَا \add ذِي ثمُّورْثْ\add*، إِشْضنْ ؤُ إِدْجُوزْ، ؤُشَا مَاڒَا إِدْجُوزْ ؤُشَا إِخيّقْ، أَذْ إِنْعڒْ \add ڒْْڭنْسْ\add* أَجدْجِيذْ نّسْ ذ أَربِّي نّسْ. مَا أَذْ خْزَارنْ غَارْ ؤُجنَّا،
\v 22 نِيغْ غَارْ ثمُّورْثْ، \add أَقَا ذَا مْغِيرْ\add* ڒحْصَارثْ ذ طّْڒَامْ، طّْڒَامْ إِسَّاڭّْوَاذْ. إِتّْوَاسُّوفّغْ \add ڒْْڭنْسْ\add* غَارْ ثُوبَّارْشنْثْ.“ \x ◘ \xo 8:‏22 \xt إِشا. 5‏:‏30\x*
\m 
\v 23 ”مَاشَا وَارْ إِتّْغِيمِي طّْڒَامْ إِسَّاڭّْوَاذْ مَانِي ثدْجَا ڒحْصَارثْ \add ڒخُّو\add*. زِيشْ يِيوِي-د نتَّا أَسحْقَارْ غَارْ ثمُّورْثْ ن زابُولُونْ ؤُ غَارْ ثمُّورْثْ ن نَافْثَالِي، أَمُّو إِ غَا يَاوِي ذِي ڒْوقْثْ إِ د غَا يَاسنْ شَّانْ خْ وبْرِيذْ ن ڒبْحَارْ، خْ ؤُجمَّاضْ ن لْ-ؤُرْذُونْ، غَارْ لْجَالِيلْ ن ڒڭْنُوسْ.“ \x ◘ \xo 8:‏23 \xt مت. 4‏:‏15\x*
\b
\b
\c 9
\s1 أَخْڒَاقْ ن لْمَاسِيحْ
\m 
\v 1 ”ڒْڭنْسْ إِ إِدَّارنْ ذِي ثَادْجسْثْ، أَذْ إِژَارْ ثَافَاوْثْ ثَامقّْرَانْثْ. ثِيوَا نِّي إِزدّْغنْ ذِي ثمُّورْثْ ن ثِيڒِي ن ڒْموْثْ أَذْ ثَارغْ ثْفَاوْثْ. \x ◘ \xo 9:‏1 \xt مت. 4‏:‏15، 16؛ أَفا. 5‏:‏14\x*
\v 2 شكْ أَذْ ثمَّارْنِيذْ ذِي ڒْڭنْسْ ؤُ أَذْ ثسّمْغَارذْ ڒفْرَاحثْ. نِيثْنِي أَذْ فَارْحنْ زَّاثْ إِ وُوذمْ نّشْ أَمْ مَامّشْ فَارْحنْ غَارْ ثْميْرَا، أَمْ مَامّشْ أَرشْڭنْ خْمِي بطَّانْ ثَاكشَّاضْثْ ...
\b
\m 
\v 3 \bd مَاغَارْ\bd* \add أَ\add*زَايْڒُو ن دّْقڒْ نّسْ ذ وعْمُوذْ خْ ثغْرُوضْثْ نّسْ ذ ؤُزدْجَاضْ ن ؤُوقَّافْ نّسْ، أَقَا ثَارْژِيذْ ثنْ أَمْ ذڭْ وَاسّْ ن مِيذْيَانْ، \x ◘ \xo 9:‏3 \xt ڒقض. 7‏:‏22؛ إِشا. 10‏:‏26\x*
\m 
\v 4 \bd مَاغَارْ\bd* كُوڒْ ڒْبُوطَا نِّي يُوذْفنْ ذڭْ ؤُزهَّارْ ن ؤُمنْغِي ؤُ كُوڒْ أَپَارْثسُّو نِّي مَارْغنْ ذڭْ إِذَامّنْ، أَذْ إِتّْوَاسَّارْغْ، أَذْ يِيڒِي ذ مَاشَّا إِ ثْمسِّي،
\m 
\v 5 \bd مَاغَارْ\bd* إِتّْوَارُو أَنغْ-د ؤُحنْجِيرْ، إِمّوْشْ أَنغْ مِّيسْ ؤُشَا ڒحْكَامثْ ثتّْوَاسَّارْسْ خْ ثغْرُوضْثْ نّسْ ؤُ تّْڒَاغَانْ أَسْ إِسمْ نّسْ: ڒعْجبْ، أَمْشَاوَارْ، أَربِّي إِجهْذنْ، بَابَاسْ ن ڒبْذَا، ڒْحَاكمْ ن ڒهْنَا. \x ◘ \xo 9:‏5 \xt إِشا. 11‏:‏2؛ 22‏:‏22؛ لك. 2‏:‏10، 11؛ يُوح. 4‏:‏10\x*
\v 6 إِ ڒمْغَارثْ ن ڒحْكَامثْ \add نّسْ\add* ؤُ إِ ڒهْنَا \add نّسْ\add* وَارْ إِتِّيڒِي قطُّو خْ ڒْعَارْشْ ن ذَاوُوذْ ؤُ خْ ثْڭلْذِيثْ نّسْ، حِيمَا أَذْ ثتّْوَاضْمنْ ؤُ أَذْ ثتّْوَاسّجْهذْ س ڒْحقّْ ذ ثْسڭْذَا، زِي ڒخُّو أَڒْ إِ ڒبْذَا. أَشْضَارْ ن سِيذِي ن ڒْعسْكَارَاثْ أَذْ إِڭّْ أَيَا.“ \x ◘ \xo 9:‏6 \xt 2 إِج. 19‏:‏31؛ إِشا. 37‏:‏32\x*
\b
\s1 أَفُوسْ ن سِيذِي ضِيدّْ إِ إِفْرَايِيمْ
\m 
\v 7 ”سِيذِي إِنُو إِسّكّْ أَوَاڒْ ضِيدّْ إِ يَاعْقُوبْ ؤُشَا إِوْضَا ذِي إِسْرَائِيل.
\v 8 مَارَّا ڒْڭنْسْ أَذْ \add ث\add* إِسّنْ، إِفْرَايِيمْ ذ إِمزْذَاغْ ن سَامَارْيَا نِّي إِقَّارنْ س نّْفَاخثْ ؤُ س وُوڒْ \add إِشُّورنْ\add* س ؤُكبَّارْ:
\v 9 ’\add رحْيُوضْ ن\add* لَّاجُورْ وْضَانْ، \add مَاشَا\add* أَذْ \add ثنْ\add* نبْنَا \add عَاوذْ\add* س ثْصُوضَارْ إِتّْوَاسُّويْذَانْ. ؤُرْثَانْ ن ڒخْڒَا تّْوَازذْمنْ، \add مَاشَا\add* أَذْ نژُّو ثِيشجُّورَا ن ثنْڭلْثْ ذڭْ ومْشَانْ نْسنْ!‘
\v 10 أَذْ خَاسْ إِسّكَّارْ سِيذِي إِغْرِيمنْ ن رَاصِينْ ؤُ نتَّا أَذْ إِسّهْوڒْ ڒْعذْيَانْ نّسْ \add خَاسْ\add*.
\v 11 أَرَامْ زِي شَّارْقْ ؤُ إِفِيلِيسْطِينِييّنْ زِي ضفَّارْ، أَڒَامِي نِيثْنِي أَذْ صَارْضنْ إِسْرَائِيل قَاعْ. \bd س مَارَّا أَيَا وَارْ يَارخُّو وغْضَابْ نّسْ، \bdit مَاشَا\bdit* أَفُوسْ نّسْ إِقِّيمْ إِسَارّحْ،\bd* \f ◼ \fr 9:‏11 \ft \bd ’أَذْ صَارْذنْ ... قَاعْ‘\bd* - س ثْعِيبْرَانِيثْ ’أَذْ شّنْ ... س مَارَّا أَقمُّومْ‘.\f*  \x ◘ \xo 9:‏11 \xt إِشا. 5‏:‏25؛ 10‏:‏4\x*
\v 12 \add مَاغَارْ\add* ڒْڭنْسْ وَارْ د-إِذِيكّْوِيڒْ غَارْ ونِّي ث إِوْثِينْ ؤُ نِيثْنِي وَارْ أَرزُّونْ سِيذِي ن ڒْعسْكَارَاثْ.“
\m 
\v 13 ”أَذْ إِقسّْ سِيذِي زِي إِسْرَائِيل أَزدْجِيفْ ذ ؤُكنَّاسْ، ثَاسطَّا ن ثِينِي ذ ؤُغَانِيمْ، ذڭْ إِجّْ ن وَاسّْ.
\v 14 أَوسَّارْ ذ ونِّي ؤُمِي غَا يِيڒِي شَّانْ، أَقَا أَثنْ ذ أَزدْجِيفْ، ؤُشَا أَنَابِي نِّي إِسّڒْمَاذنْ إِخَارِّيقنْ، نتَّا ذ أَكنَّاسْ.
\v 15 \add مَاغَارْ\add* إِمْڭوَّاذنْ ن ڒْڭنْسْ-أَ ذ إِمْغكّْوَاينْ ؤُ إِنِّي زَّايْسنْ إِتّْوَانذْهنْ أَذْ تّْوَاصَارْضنْ.
\v 16 خْ ؤُيَا وَارْ إِفَارّحْ سِيذِي إِنُو خْ إِحُوذْرِييّنْ نْسنْ، ؤُ وَارْ يَارحّمْ خْ إِيُوجِيڒنْ ذ ثجَّاڒْ نْسنْ، مَاغَارْ مَارَّا نِيثْنِي ذ إِمْنَافْقنْ ذ إِعفَّاننْ ؤُ كُوڒْ أَقمُّومْ إِسَّاوَاڒْ ثُوبُّوهڒْيَا. \bd س مَارَّا أَيَا وَارْ يَارخُّو وغْضَابْ نّسْ، \bdit مَاشَا\bdit* أَفُوسْ نّسْ إِقِّيمْ إِسَارّحْ.\bd*“\x ◘ \xo 9:‏16 \xt إِشا. 10‏:‏6\x*
\m 
\v 17 ”مَاغَارْ ثُوعفّْنَا ثَارقّْ أَمْ ثْمسِّي، ثتّتّْ إِسنَّاننْ ذ ثْزڭّْوَارْثْ، ثسّْرقَّا إِخشَّابنْ ن وزْغَارْ، \add أَڒَامِي\add* تّْڭعَّاذنْ ذِي دّخَّانْ. \f ◼ \fr 9:‏17 \ft \bd ’أَزْغَارْ‘\bd* - نِيغْ ’ڒْغَابثْ‘ نِيغْ ’ثَازْڭَانْثْ‘.\f*  \x ◘ \xo 9:‏17 \xt إِشا. 5‏:‏24؛ 24‏:‏6\x*
\v 18 س ؤُذُوقّزْ \add ن ؤُفُوڭمْ\add* ن سِيذِي ن ڒْعسْكَارَاثْ أَذْ إِسّْقُوسْبَارْ ثَامُّورْثْ ؤُشَا ڒْڭنْسْ أَذْ يِيڒِي ذ مَاشَّا ن ثْمسِّي. ؤُڒَا ذ إِجّنْ وَارْ إِتّْحِيوِيڒْ خْ ونّغْنِي.
\v 19 \add وَاخَّا\add* بْنَاذمْ إِنهّشْ غَارْ يفُوسْ، أَذْ إِقِّيمْ إِدْجُوزْ. \add وَاخَّا\add* إِتّتّْ غَارْ ؤُزڒْمَاضْ، وَارْ تّْيِيوِيننْ نِيثْنِي. كُوڒْ إِجّْ أَذْ إِسَارْضْ أَيْسُومْ ن ؤُغِيڒْ نّسْ.
\v 20 مَانَاسَّا \add أَذْ إِسَارْضْ\add* إِفْرَايِيمْ ؤُ إِفْرَايِيمْ \add أَذْ إِسَارْضْ\add* مَانَاسَّا ؤُشَا ثْنَاينْ إِذْسنْ مُوننْ أَذْ إِڒِينْ ضِيدّْ إِ يَاهُوذَا. \bd س مَارَّا أَيَا وَارْ يَارخُّو وغْضَابْ نّسْ، \bdit مَاشَا\bdit* أَفُوسْ نّسْ إِقِّيمْ إِسَارّحْ.\bd*“
\b
\b
\c 10
\m 
\v 1 ”\bd ؤُشْثْ\bd* خْ يِينِّي إِسُّوفُّوغنْ ڒُومُورَاثْ إِغشّنْ، إِنِّي إِتَّارِينْ ثِيوصَّا إِتّْضدْجنْ
\v 2 حِيمَا أَذْ سّْحيّْذنْ إِمزْڒَاضْ خْ ثسْغَارْثْ \add نْسنْ\add* ؤُ حِيمَا أَذْ أَشَارنْ ثَاسْغَارْثْ ن يِينِّي إِتّْوَاحْصَارنْ ن ڒْڭنْسْ إِنُو، أَڒَامِي غَا ذوْڒنْثْ ثِيجَّاڒْ ذ ثَاكشَّاضْثْ نْسنْ ؤُ إِيُوجِيڒنْ ذ ثَايْمَارْثْ.
\v 3 \add مَاشَا\add* مِينْ ثخْسمْ أَذْ ثڭّمْ ذڭْ وَاسّْ ن ؤُخدْجصْ ؤُ غَارْ ؤُردّدْجْ نِّي د غَا يَاسنْ زِي ڒَاڭّْوَاجْ؟ وِي غَارْ إِ غَا ثَاروْڒمْ حِيمَا أَذْ ثَافمْ ثْوِيزَا ؤُ مَانِي غَا ثجّمْ أَعُودْجِي نْومْ؟
\v 4 وَارْ \add ذِينْ\add* مِينْ غَا ڭّنْ مْغِيرْ أَذْ ؤُضَارنْ \add خْ إِفَادّنْ\add* وَاهَا جَارْ إِمحْبَاسْ ؤُ أَذْ وْضَانْ جَارْ إِنِّي إِتّْوَانْغنْ. \bd س مَارَّا أَيَا وَارْ يَارخُّو وغْضَابْ نّسْ، \bdit مَاشَا\bdit* أَفُوسْ نّسْ إِقِّيمْ إِسَارّحْ.\bd*“
\b
\m 
\v 5 ”\bd ؤُشْثْ\bd* خْ أَشُّورْ، أَزدْجَاضْ ن وغْضَابْ إِنُو، أَقَا أَسْخضْ إِنُو ذ أَعْمُوذْ ذڭْ إِفَاسّنْ نْسنْ!\x ◘ \xo 10:‏5 \xt إِشا. 36‏:‏1؛ إِرْم. 25‏:‏9؛ حِز. 21‏:‏14\x*
\v 6 أَذْ ث سّكّغْ غَارْ ڒْڭنْسْ \add إِشُّورنْ\add* س نِّيفَاقْ ؤُ نشّْ أَذْ ث ؤُمُورغْ خْ ڒْڭنْسْ إِ خْ إِدُّوقّزْ ؤُفُوڭمْ إِنُو، مَاحنْذْ أَذْ أَشَارنْ ثُوكَّارْضَا ؤُ مَاحنْذْ أَذْ ث كشّْضنْ قَاعْ ؤُ أَذْ ث عَارَّانْ إِ ؤُنعْفَاسْ أَمْ ثْعجَّاجْثْ خْ إِمسْرَاقْ.
\v 7 مَاشَا نتَّا س يِيخفْ نّسْ وَارْ ذ أَسْ إِتّْغِيڒْ أَمُّو ؤُ ؤُڒْ نّسْ إِتّْخَارّصْ مَامّشْ نّغْنِي، مَاغَارْ نتَّا غَارسْ ذڭْ وُوڒْ مْغِيرْ ڒكْحضْ ؤُ مَاحنْذْ أَذْ إِقْضَا خْ ڒڭْنُوسْ، وَارْ إِدْجِي ذْرُوسْ.
\v 8 مَاغَارْ إِقَّارْ: ’مَا وَارْ دْجِينْ ڒْحُوكَّامْ إِنُو ذ إِجدْجِيذنْ مَارَّا؟
\v 9 مَا وَارْ \add إِمْسَارْ\add* إِ كَالْنُو أَمشْنَاوْ \add مِينْ إِمْسَارنْ\add* إِ كَارْكَامِيشْ؟ مَا وَارْ \add إِمْسَارْ\add* إِ حَامَاثْ أَمشْنَاوْ \add مِينْ إِمْسَارنْ\add* إِ أَرْفَاذْ؟ مَا وَارْ \add إِمْسَارْ\add* إِ سَامَارْيَا أَمْ \add مِينْ إِمْسَارنْ\add* إِ ذِيمَاشْقْ؟
\v 10 أَمْ مَامّشْ أَفُوسْ إِنُو إِطّفْ ثِيڭلْذَاوِينْ ن لْ-أَصْنَامْ نِّي زِي عْذُونْثْ ڒخْيَاڒَاثْ نْسنْ إِنقْشنْ ڒخْيَاڒَاثْ ن ؤُرْشَالِيمْ ذ سَامَارْيَا،
\v 11 مَا وَارْ تّڭّغْ أَمُّو \add عَاوذْ\add*، أَمْ مَامّشْ إِ ث ڭِّيغْ أَكْ-ذ سَامَارْيَا ذ لْ-أَصْنَامْ نّسْ، ؤُڒَا أَكْ-ذ ؤُرْشَالِيمْ ذ ڒخْيَاڒَاثْ نّسْ ن لْ-أَصْنَامْ؟‘ “
\m 
\v 12 ”\add مَاشَا\add* خْمِي غَا إِكمّڒْ سِيذِي مَارَّا ڒْخذْمثْ نّسْ خْ وذْرَارْ ن صِيهْيُونْ ؤُ ذِي ؤُرْشَالِيمْ، \add خنِّي\add* أَذْ خدْجْصغْ نشّْ ڒْغِيدْجثْ ن ؤُكبَّارْ ذڭْ وُوڒْ ن ؤُجدْجِيذْ ن أَشُّورْ ؤُڒَا ذ أَعفَّارْ يُوفّنْ ذِي ثِيطَّاوِينْ نّسْ،
\v 13 مَاغَارْ نتَّا إِنَّا: ’أَيَا ڭِّيغْ ث س ؤُفُوسْ إِنُو إِجهْذنْ ؤُ س ثِيغِيثْ إِنُو، مَاغَارْ نشّْ غَارِي ڒعْقڒْ. إِيْمِيرنْ ن ڒڭْنُوسْ كّْسغْ ثنْ، ؤُ ڒعْوَايضْ نْسنْ كشّْضغْ ثنْ، ؤُ أَمْ جِّيهڒْ غضْڒغْ ڒْحُوكَّامْ \add نْسنْ\add*.
\v 14 أَمْ ڒْعُوشّْ، \add أَمُّو\add* يُوفَا ؤُفُوسْ إِنُو أَڭْڒَا ن ڒڭْنُوسْ، جَارْوغْ مَارَّا ثَامُّورْثْ أَمْ مَامّشْ جَارْونْ ثِيمدْجَاڒِينْ إِمّنْضَارنْ. ؤُڒَا ذ إِجّْ وَارْ إِسّنْهزِّي أَفْرِيونْ، وَارْ ذِينْ ونِّي يَارزْمنْ أَجقْمِيمْ نِيغْ إِجَاوْ.‘
\v 15 مَا إِتّْفيّشْ شَّاقُورْ قِيبَاتْشْ إِ ونِّي زَّايسْ إِتّْشقَّارنْ؟ نِيغْ إِتّْنفّخْ ڒْمنْشَارْ زَّاثْ إِ ونِّي زَّايسْ إِتّْقسّنْ؟ \add أَيَا إِڒِي\add* أَخْمِي أَعْمُوذْ إِتّْحنّضْ \add أَرْيَازْ\add* نِّي ث إِسّْڭعّْذنْ، نِيغْ أَخْمِي أَعْمُوذْ إِسّْڭعّذْ \add بَابْ نّسْ\add* نِّي وَارْ إِدْجِينْ ذ أَكشُّوضْ.“
\m 
\v 16 س ؤُيَا أَذْ إِسّكّْ سِيذِي إِنُو، سِيذِي ن ڒْعسْكَارَاثْ، بُو-ذدْجِيسْ جَارْ إِرْيَازنْ نْسنْ إِقبُّوزنْ ؤُ نتَّا أَذْ إِسِّيرغْ ثِيمسِّي سَاذُو أَعُودْجِي ن أَشُّورْ أَمْ يِيجّْ ن ڒْحَاذُوقْ ن ثْمسِّي. \x ◘ \xo 10:‏16 \xt إِشا. 24‏:‏6\x*
\v 17 ثَافَاوْثْ ن إِسْرَائِيل أَذْ ثذْوڒْ ذ ثِيمسِّي ؤُ أَمْقدّسْ نّسْ ذ أَشعَّاڒْ نِّي إِ غَا إِشمْضنْ ؤُ أَذْ ثشّْ إِسنَّاننْ ذ ثْزڭّْوَارْثْ نّسْ ذڭْ إِجّْ ن وَاسّْ وَاهَا.
\v 18 نتَّا أَذْ يشّْ أَعُودْجِي ن وزْغَارْ نّسْ ؤُ ن ڒْعِيرْسْثْ إِصبْحنْ نّسْ س \add مَارَّا\add* ڒعْمَارْ ذ ويْسُومْ \add إِ ذَايْسنْ\add*، ؤُشَا أَذْ يِيڒِي \add ؤُعُودْجِي نّسْ\add* أَمْ يِيجّْ ن ؤُمحْڒُوشْ إِتّْرَاحنْ إِغدْجِي.
\v 19 مِينْ إِقِّيمنْ ن ثْشجُّورَا ن وزْغَارْ نّسْ أَذْ يِيڒِي ذْرُوسْ وَاهَا، إِجّْ ن ؤُحُوذْرِي إِزمَّارْ أَذْ ثنْ إِحْسبْ.“
\m 
\v 20 ”\bd ذڭْ وَاسّْ نِّي\bd* أَذْ يِيڒِي مِينْ إِقِّيمنْ ن إِسْرَائِيل ذ إِنِّي إِنجْمنْ زِي ثَادَّارْثْ ن يَاعْقُوبْ وَارْ تّْعمِّيذنْ عَاذْ خْ ونِّي ثنْ إِشَّاثنْ، مَاشَا أَذْ إِعمّذْ \add إِسْرَائِيل\add* خْ سِيذِي، أَمْقدَّاسْ ن إِسْرَائِيل، س ڒَامَانْ إِشُّورْ.
\v 21 مِينْ إِقِّيمنْ أَذْ د-إِذْوڒْ، مِينْ إِقِّيمنْ ن يَاعْقُوبْ \add أَذْ د-إِذْوڒْ\add* غَارْ أَربِّي إِجهْذنْ.
\v 22 \add أَ\add* إِسْرَائِيل، وَاخَّا ڒْڭنْسْ نّشْ أَمُّو إِوْسعْ أَمْ يِيدْجِي ن ڒبْحَارْ، أَذْ \add زَّايْسنْ\add* د-إِذْوڒْ مْغِيرْ مِينْ إِشطّنْ. أَكحّضْ بَاينْ، ثَاسڭْذَا ثوْسعْ. \x ◘ \xo 10:‏22 \xt رُوم. 9‏:‏27، 28\x*
\v 23 مَاغَارْ سِيذِي إِنُو، سِيذِي ن ڒْعسْكَارَاثْ، أَذْ إِقْضَا \add خْ مَانْ أَيَا\add* ؤُشَا أَذْ إِڭّْ مِينْ يُورَانْ ذِي مَارَّا ثَامُّورْثْ.“ \x ◘ \xo 10:‏23 \xt إِشا. 28‏:‏22\x*
\m 
\v 24 ”س ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي ن ڒْعسْكَارَاثْ: ’\add أَ\add* ڒْڭنْسْ إِنُو نِّي إِزدّْغنْ ذِي صِيهْيُونْ، وَارْ تّڭّْوذْ شَا زِي أَشُّورْ خْمِي شكْ إِشَّاثْ س ؤُزدْجَاضْ ؤُشَا إِسّْڭعّذْ خَاكْ أَعْمُوذْ، أَمْ مَامّشْ إِمْسَارْ ذِي مِيصْرَا.
\v 25 مَاغَارْ عَاذْ مْغِيرْ شْوَايْثْ، \add خنِّي\add* أَذْ إِكمّڒْ \add مْكُوڒْ\add* وسْخضْ نِّي ؤُشَا أَذْ يِيڒِي وغْضَابْ إِنُو خْ ؤُردّدْجْ نْسنْ.
\v 26 مَاغَارْ سِيذِي ن ڒْعسْكَارَاثْ أَذْ إِحنّضْ ثِيوَا نّسْ أَركُّوضْ، أَمْ مَامّشْ إِوْثَا مِيذْيَانْ غَارْ ثصْضَارْثْ ن غُورَابْ. ثَاغَّارْشْثْ نّسْ أَذْ ثِيڒِي \add ثسّْوِيژَّاضْ\add* ثِيوَا إِ ڒبْحَارْ ؤُ نتَّا أَذْ ت إِسّْڭعّذْ أَمْ مَامّشْ ث إِڭَّا ذِي مِيصْرَا. \x ◘ \xo 10:‏26 \xt ؤُف. 14\x*
\v 27 \bd ذڭْ وَاسّْ نِّي\bd* أَذْ إِوْضَا ڒحْمڒْ ن أَشُّورْ خْ ثغْرُوضْثْ نّشْ ؤُ ثَاغْنَاشْثْ نّسْ خْ يِيرِي نّشْ. أَزَايْڒُو أَذْ إِتّْوَابطّڒْ س إِجِيمَانْ نِّي إِصحّنْ.“
\m 
\v 28 ”أَذْ د-يَاسْ غَارْ عَايَّاثْ، إِعْذُو خْ مِيجْرُونْ، إِسَّارْسْ دُّوزَانْ نّسْ ذِي مِيخْمَاشْ.
\v 29 نِيثْنِيعدُّونْ خْ وبْرِيذْ ن ؤُژكّْوُو خْ إِذُورَارْ، أَذْ سّنْسنْ ذِي جَابَاعْ. رَامَا ثتَّارْجِيجِي، ثَارْوڒْ جِيبْعَا ن شَاوُولْ.
\v 30 سْغُويّْ س ثْمِيجَّا إِجهْذنْ، \add أَ\add* يدْجِيسْ ن جَالِّيمْ! أَرّْ ڒْبَاڒْ، لَايْشَا، \add أَ شمْ\add* عَانَاثُوثْ، مسْكِينَا!
\v 31 \add ثَانْذِينْثْ ن\add* مَاذْمِينَا ثَارْوڒْ، إِمزْذَاغْ ن جِيبِيمْ فّْغنْ مَاحنْذْ أَذْ أَفنْ ڒَامَانْ.
\v 32 أَسّْ-أَ عَاذْ أَذْ إِبدّْ ذِي نُوبْ. نتَّا أَذْ إِكْسِي أَفُوسْ نّسْ \add إِسَّاڭّْوَاذْ\add* غَارْ وذْرَارْ ن يدْجِيسْ ن صِيهْيُونْ، غَارْ ثوْرِيرْثْ ن ؤُرْشَالِيمْ.“
\m 
\v 33 ”خْزَارْ، سِيذِي، سِيذِي ن ڒْعسْكَارَاثْ، أَذْ إِقسّْ ڒفْرُوعْ س ؤُغِيڒْ. إِنِّي س ثِيذِّي يُوعْڒَانْ أَذْ تّْوَازذْمنْ، ؤُشَا إِنِّي إِسّْڭعّْذنْ إِخفْ نْسنْ أَذْ تّْوَاسّهْوَانْ.
\v 34 شْبَارْقْ ن وزْغَارْ أَذْ إِتّْوَاقْڒعْ س وُوزَّاڒْ ؤُشَا لُوبْنَانْ أَذْ إِوْضَا س ؤُفُوسْ ن ؤُمْزمَّارْ.“ \f ◼ \fr 10:‏34 \ft \bd ’لُوبْنَانْ‘\bd* - إِخْسْ أَذْ يِينِي ڒْعسْكَارْ ن أَشُّورْ ونِّي د-يُوسِينْ زِي جِّيهثْ ن إِذُورَارْ ن لُوبْنَانْ إِنِّي يُوعْڒَانْ خْ وذْرَارْ ن صِيهْيُونْ. مَاشَا لْمَالَاكْ ن سِيذِي، أَربِّي ن إِسْرَائِيل، إِوْثَا ڒْعسْكَارْ ن أَشُّورْ (خْزَارْ إِشا. 37‏:36).\f*
\b
\b
\c 11
\s1 ڒحْكَامثْ ن ڒهْنَا إِ د غَا يَاسنْ
\m 
\v 1 ”أَذْ د-ثفّغْ ثْسطَّا زِي جّْذعْ ن يَاسَّا ؤُ ثَاغدُّوثْ زڭْ إِژوْرَانْ نّسْ أَذْ د-ثَاوِي ڒْغِيدْجثْ. \x ◘ \xo 11:‏1 \xt إِشا. 4‏:‏2؛ ڒخ. 13‏:‏22، 23\x*
\v 2 أَذْ خَاسْ يَارْسَا أَرُّوحْ ن سِيذِي، أَرُّوحْ ن ثِيغِيثْ ذ ڒعْقڒْ، أَرُّوحْ ن شّْوَارْ ذ جّهْذْ، أَرُّوحْ ن ثُوسّْنَا ذ ثِيڭّْوُوذِي زِي سِيذِي. \x ◘ \xo 11:‏2 \xt ؤُف. 31‏:‏3؛ 35؛13؛ 1 كُور. 12‏:‏8؛ كُول. 1‏:‏9\x*
\v 3 أَرْضَا نّسْ أَذْ يِيڒِي ذِي ثِيڭّْوُوذِي ن سِيذِي. وَارْ إِشَارّعْ عْلَاحْسَابْ مِينْ تّْوَاڒَانْثْ ثِيطَّاوِينْ نّسْ، وَارْ إِحكّمْ عْلَاحْسَابْ مِينْ تّسْڒَانْ إِمزُّوغنْ نّسْ.
\v 4 أَذْ إِشَارّعْ إِمُوقْڒِيڒنْ س ثْسڭْذَا ؤُ أَذْ إِحْكمْ إِمْوَاضْعنْ ن ثمُّورْثْ س ڒْحقّْ، \add مَاشَا\add* ثَامُّورْثْ أَذْ ت إِوّثْ س ؤُزدْجَاضْ ن ؤُقمُّومْ نّسْ ؤُ س ؤُسُوضِي ن ؤُقمُّومْ نّسْ أَذْ إِنغْ أَعفَّانْ.
\v 5 ثَاسڭْذَا أَذْ ثِيڒِي ذ أَبْيَاسْ ن ثجْعِينَّاثِينْ نّسْ ؤُ ثِيذتّْ ذ أَبْيَاسْ خْ ثْمصَّاضِينْ نّسْ.
\m 
\v 6 أَذْ إِزْذغْ وُوشّنْ غَارْ إِزْمَارْ، أَغِيرَاسْ أَذْ إِجنْ غَارْ إِغَايْضْ أَمژْيَانْ. أَعجْمِي ذ وَايْرَاذْ أَمژْيَانْ ذ ڒْمَاڒْ إِصحّنْ \add أَذْ إِڒِينْ\add* مُوننْ ؤُشَا أَحنْجِيرْ أَمژْيَانْ أَذْ ثنْ إِنْذهْ. \f ◼ \fr 11:‏6 \ft \bd ’أَمْوَا‘\bd* - نِيغْ ’أَينْذُوزْ‘ نِيغْ ’يُوڭُّو‘.\f*  \x ◘ \xo 11:‏6 \xt إِشا. 65‏:‏25؛ حُوش. 2‏:‏20\x*
\v 7 ثَافُونَاسْثْ ذ دُّوبْ أَذْ هْذَانْ \add جْمِيعْ\add*، ؤُشَا إِمژْيَاننْ نْسنْ أَذْ جْننْ غَارْ وَايَاوْيَا ؤُشَا أَيْرَاذْ أَذْ يشّْ ڒُومْ أَمْ ؤُفُونَاسْ.
\v 8 أَحْضِيضْ أَذْ يَارّْ مزْڒِي زَّاثْ إِ وخْبُوشْ ن ثْڒفْسَا ؤُ أَنِيبُو إِ كّْسنْ زڭْ ؤُطُّوضْ، أَذْ إِسّْوِيژّضْ أَفُوسْ نّسْ غَارْ وَارْزَامْ ن ثْفَاوْثْ \add ن وحْفُورْ\add* ن ؤُفِيغَارْ.
\m 
\v 9 وَارْ تّڭّنْ ڒْغَارْ ؤُ وَارْ تّڭّنْ أَردّدْجْ خْ وذْرَارْ إِنُو إِقدّْسنْ مَارَّا، مَاغَارْ ثَامُّورْثْ ثشُّورْ س ثُوسّْنَا ن سِيذِي أَمْ مَامّشْ ذْڒنْ وَامَانْ ثِيسِي ن ڒبْحَارْ.
\v 10 \bd ذڭْ وَاسّْ نِّي\bd* أَذْ إِبدّْ وژْوَارْ ن يَاسَّا أَمْ ثْعدْجَانْثْ إِ ويْذُوذنْ. غَارسْ أَذْ سّقْسَانْ ڒڭْنُوسْ ؤُشَا أَمْشَانْ ن أَرَّاحثْ نّسْ أَذْ يِيڒِي إِشوَّارْ.“ \x ◘ \xo 11:‏10 \xt رُوم. 15‏:‏12\x*
\b
\m 
\v 11 ”\bd ذڭْ وَاسّْ نِّي\bd* أَذْ إِسّْڭعّذْ سِيذِي إِنُو أَفُوسْ نّسْ إِشْثْ ن ثْوَاڒَا نّغْنِيثْ، حِيمَا أَذْ إِسلّكْ مِينْ إِقِّيمنْ ن ڒْڭنْسْ نّسْ زِي أَشُّورْ، مِيصْرَا، فَاثْرُوسْ، كُوشْ، عِيلَامْ، شِينْعَارْ ذ حَامَاثْ ؤُ زِي ثڭْزِيرِينْ ن ڒبْحَارْ. \f ◼ \fr 11:‏11 \ft \bd ’ڒبْحَارْ‘\bd* - نِيغْ ’إِلْ‘.\f*
\v 12 نتَّا أَذْ إِسّْبدّْ ثَاعدْجَانْثْ إِ ڒڭْنُوسْ ؤُ أَذْ إِجَارْوْ عَاوذْ إِمنّعْرَاقْ ن إِسْرَائِيل، حِيمَا أَذْ إِسّْمُونْ إِنِّي إِتّْوَازدْجْعنْ زِي يَاهُوذَا زِي أَربْعَا ن ثْغمُّورَا ن ثمُّورْثْ.
\m 
\v 13 \add خنِّي\add* أَذْ إِڭّْوجْ وَاسَامْ ن إِفْرَايِيمْ ؤُ إِنِّي إِحصَّارنْ يَاهُوذَا أَذْ تّْوَاقضْعنْ. إِفْرَايِيمْ وَارْ إِتِّيسمْ عَاذْ زِي يَاهُوذَا ؤُ يَاهُوذَا وَارْ إِحصَّارْ عَاذْ إِفْرَايِيمْ.
\v 14 أَذْ فّْغنْ غَارْ ڒْغَارْبْ أَخْمِي طَّاونْ خْ ثْغَارْضِينْ ن إِفِيلِيسْطِينِييّنْ ؤُشَا مُوننْ أَذْ كشّْضنْ أَيْثْ ن شَّارْقْ. أَذْ سّْوِيژّْضنْ إِفَاسّنْ نْسنْ غَارْ إِذُومْ ذ مُوآبَ ؤُشَا أَيْثْ ن عَامُّونْ أَذْ أَسنْ طَّاعنْ.
\v 15 أَذْ إِحَارّمْ سِيذِي إِڒسْ ن ڒبْحَارْ ن مِيصْرَا ؤُشَا نتَّا أَذْ إِسّْڭعّذْ أَفُوسْ نّسْ خْ يغْزَارْ \add ن لْفُورَاطْ\add* س ؤُحَاذُوقْ ن أَرُّوحْ نّسْ ؤُ أَذْ ث إِوّثْ أَڒْ غَا إِذْوڒْ سبْعَا ن ثْغزْرَاثِينْ، ؤُشَا أَذْ يَارّْ أَقَا زمَّارنْ أَذْ كّنْ خْ وبْرِيذْ س سَانْذَالِييَاثْ. \x ◘ \xo 11:‏15 \xt أَسَا. 16‏:‏12‏-‏14. \x*
\v 16 أَذْ \add ذِينْ\add* يِيڒِي وبْرِيذْ إِسڭّْمنْ إِ مِينْ إِقِّيمنْ ن ڒْڭنْسْ نّسْ نِّي إِ غَا إِشطّنْ زِي أَشُّورْ، أَمْ مَامّشْ ثُوغَا إِدْجَا \add وبْرِيذْ\add* إِ إِسْرَائِيل ؤُمِي د-إِڭعّذْ زِي مِيصْرَا.“ \x ◘ \xo 11:‏16 \xt ؤُف. 14‏:‏29\x*
\b
\b
\c 12
\s1 إِزْڒِي ن ؤُصبّحْ زِي صِيهْيُونْ
\m 
\v 1 ”\bd ذڭْ وَاسّْ نِّي\bd* أَذْ ثِينِيذْ: ’نشّْ تّْقَاذِيغْ شكْ، \add أَ\add* سِيذِي، أَقَا ثُوغَا شكْ ثْخيّْقذْ خَافِي، \add مَاشَا\add* أَغْضَابْ نّشْ إِنّقْڒبْ ؤُ شكْ ثسّْفوَّاجذْ خَافِي.
\v 2 خْزَارْ، أَربِّي ذ أَسنْجمْ إِنُو، نشّْ أَذْ \add خَاسْ\add* تّشْڒغْ،عمَّارْصْ أَذْ ڭّْوذغْ، مَاغَارْ سِيذِي إِنُو، سِيذِي، أَقَا-ث ذ جّهْذْ ذ ؤُزهِّيذْ إِنُو، نتَّا إِذْوڒْ أَيِي ذ أَسنْجمْ.‘
\v 3 كنِّيوْ أَذْ ثَايْممْ أَمَانْ س ڒفْرَاحثْ زِي ثَاڒَاوِينْ ن ؤُسنْجمْ.“ \x ◘ \xo 12:‏3 \xt يُوح. 7‏:‏37، 38\x*
\m 
\v 4 ”\bd ذڭْ وَاسّْ نِّي\bd* أَذْ ثِينِيمْ: ’قَاذَامْ إِ سِيذِي، ڒَاغَامْ إِسمْ نّسْ، سشْنمْ ثِيمڭَّا نّسْ جَارْ ڒڭْنُوسْ، بَارّْحمْ أَقَا إِسمْ نّسْ إِعُودْجْ! \x ◘ \xo 12:‏4 \xt يُوح. 17‏:‏1، 4، 6، 26\x*
\v 5 زهّْذمْ إِ سِيذِي، مَاغَارْ نتَّا إِڭَّا ثِيمسْڒَايِينْ ثِيمقّْرَانِينْ. أجّْ أَيَا أَذْ إِتّْوَاسّنْ ذِي مَارَّا ثَامُّورْثْ.
\v 6 سْڒِيوْڒوْ ؤُغنّجْ، \add أَ شمْ\add* ثنِّي إِزدّْغنْ ذِي صِيهْيُونْ، مِينْزِي ذ أَمقّْرَانْ أَمْقدَّاسْ ن إِسْرَائِيل ذِي ڒْوسْطْ نّمْ.‘ “
\b
\b
\c 13
\m 
\v 1 \bd ڒْْحُوكْمْ إِسَّاڭّْوَاذنْ خْ بَابِيلْ\bd* نِّي إِژْرَا إِشَاعْيَا، مِّيسْ ن أَمُوصْ.
\m 
\v 2 ”سْڭعّْذمْ ثَاعدْجَانْثْ خْ وذْرَارْ أَقشَّارْ، سْغُويّمْ غَارْسنْ، شيَّارمْ س ؤُفُوسْ أَقَا أَذْ أَذْفنْ زِي ثوُّورَا ن ثَارْوَا ن ثَاصِيڒثْ!“
\m 
\v 3 ”نشّْ ؤُمُورغْ إِمْقدَّاسنْ إِنُو، نشّْ ڒَاغِيغْ خْ أَيْثْ ن بُو-ثغْرُوضْثْ إِنُو ذِي سِّيبّثْ ن وغْضَابْ إِنُو، إِنِّي إِنڭّْزنْ س ڒفْرَاحثْ خْ لْعَاضَامَا إِنُو.“
\m 
\v 4 ”أَقَا زّْهِيرْ ن إِجّْ ن ؤُبَارُّو \add أَمقّْرَانْ\add* خْ إِذُورَارْ، أَمْ ن إِجّْ ن ڒْڭنْسْ إِمْغَارْ، ڒْحسّْ ن دّْرِيزْ ن ثْڭلْذَاوِينْ، ن ڒڭْنُوسْ ؤُسِينْ-د مُوننْ. سِيذِي ن ڒْعسْكَارَاثْ إِسدّْ ڒْعسْكَارْ \add نّسْ\add*.
\v 5 أَذْ د-أَسنْ زِي ثمُّورْثْ ثِيڭّْوجْ، زِي طَّارْفْ ن ؤُجنَّا، سِيذِي ذ ڒقْشُوعْ ن وسْخضْ نّسْ، حِيمَا أَذْ خَارّْبنْ مَارَّا ثَامُّورْثْ.“
\m 
\v 6 ”سْغُويّمْ، مَاغَارْ أَسّْ ن سِيذِي يُوذسْ-د، أَذْ د-يَاسْ أَمْ ؤُردّدْجْ زڭْ ؤُمْزمَّارْ خْ كُوڒْشِي. \x ◘ \xo 13:‏6 \xt يُووِ. 2‏:‏10، 31؛ 3‏:‏15؛ إِشا. 13‏:‏6‏-‏13؛ 24‏:‏23؛ Am. 8‏:‏9؛ مت. 24‏:‏29؛ ڒخ. 2‏:‏20؛ أَسَا. 6‏:‏12‏-‏13\x*
\v 7 خْ ؤُيَا ذوْڒنْ مَارَّا إِفَاسّنْ فشْڒنْ ؤُ وُوڒْ ن كُوڒْ بْنَاذمْ إِفسِّي.
\v 8 نِيثْنِي نّْخڒْعنْ، إِڒقّفْ إِ-ثنْ وغْنَاسْ ذ ڒوْجعْ ن ثَارُوثْ، تّْنزْبَارنْ أَمْ ثمْغَارْثْ إِتَّارُونْ. كُوڒْ إِجّْ إِخزَّارْ غَارْ ونّغْنِي، إِغمْبَابْ نْسنْ \add ڭِّينْ\add* أَمْ يِيشعَّاڒنْ \add ن ثْمسِّي\add*.“
\m 
\v 9 ”خْزَارْ، أَسّْ ن سِيذِي أَذْ د-يَاسْ، \add س\add* ڒقْسَاحثْ إِوْعَارنْ ؤُ \add س\add* ڒْحَاذُوقْ ن وغْضَابْ \add نّسْ\add*، حِيمَا أَذْ يَارّْ ثَامُّورْثْ ذ وَاردّدْجْ ؤُ حِيمَا أَذْ زَّايسْ إِمْحَا إِمذْنَابْ.
\v 10 مَاغَارْ إِثْرَانْ ن ؤُجنَّا ذ إِوْرَافنْ ن إِثْرَانْ وَارْ تّجِّينْ عَاذْ ثَافَاوْثْ نْسنْ أَذْ ثَارْغْ، ثَافُوشْثْ أَذْ ثبَّارْشنْ خْمِي د غَا ثنْقَارْ، ؤُشَا ثَازِيرِي وَارْ تّجِّي عَاذْ ثَافَاوْثْ نّسْ أَذْ ثْشعْشعْ. \x ◘ \xo 13:‏10 \xt حِز. 32‏:‏7؛ يُووِ. 3‏:‏4؛ 3‏:‏15؛ مت. 24‏:‏29؛ مك. 13‏:‏24؛ لك. 21‏:‏25\x*
\v 11 \add مَاغَارْ\add* أَذْ خدْجْصغْ إِ دُّونشْثْ ثُوعفّْنَا نّسْ ؤُ إِ إِعفَّاننْ ڒْمُوعْصِييّثْ نْسنْ ؤُ نشّْ أَذْ سّْبدّغْ نّْفَاخثْ ن إِمْعفَّارنْ ؤُ أَذْ سّهْوِيغْ نّْفَاخثْ ن أَيْثْ ن بُو-ڒخْشُونثْ.
\v 12 أَذْ أَرّغْ أَرْيَازْ أَذْ يِيڒِي إِغْڒَا خْ وُورغْ أَزْذَاذْ، ؤُڒَا ذ بْنَاذمْ خْ وُورغْ إِغْڒَانْ زِي ؤُفِيرْ.
\v 13 خْ ؤُيَا أَذْ سَّارْجِيجغْ إِجنْوَانْ ؤُشَا أَذْ ثنْهزّْ ثمُّورْثْ زڭْ ومْشَانْ نّسْ زڭْ ؤُذُوقّزْ \add ن ؤُفُوڭمْ\add* ن سِيذِي ن ڒْعسْكَارَاثْ ؤُ زڭْ وَاسّْ ن ڒْحَاذُوقْ ن وغْضَابْ نّسْ.“
\v 14 ”أَمْ ثْغَايْضثْ ن وزْغَارْ إِنْجرْفنْ، أَمْ وُودْجِي وَارْ غَارسْ د-إِكْسِي ؤُڒَا ذ إِجّْ، \add أَمُّو\add* إِ غَا نّْقڒْبنْ نِيثْنِي كُوڒْ إِجّْ غَارْ ڒْڭنْسْ نّسْ ؤُ كُوڒْ  إِجّْ أَذْ يَارْوڒْ غَارْ ثمُّورْثْ نّسْ.
\v 15 قَاعْ ونِّي إِ غَا إِتّْوَافنْ، أَذْ خَاسْ شُوقنْ، ؤُ قَاعْ ونِّي إِ غَا طّْفنْ، أَذْ إِوْضَا س سِّيفْ.
\v 16 زَّاثْ إِ ثِيطَّاوِينْ نْسنْ أَذْ تّْوَادّْزنْ إِحنْجِيرنْ نْسنْ، أَذْ تّْوَاكشّْضنْثْ ثُوذْرِينْ نْسنْ ؤُ ثِيمْغَارِينْ نْسنْ أَذْ تّْوَاسّْنُوقّْبنْثْ.“
\m 
\v 17 ”خْزَارْ، نشّْ أَذْ خَاسنْ سّْحَارّْشغْ إِمَاذِييّنْ، نِيثْنِي وَارْ ذ أَسنْ ثشْقِي نُّوقَارْثْ ؤُ غَارْسنْ نِيثْنِي ؤُرغْ وَارْ إِسكّْوِي.
\v 18 ڒقْوَاسْ نْسنْ أَذْ خَارّْڭنْ إِحُوذْرِييّنْ، وَارْ أَرحّْمنْ شَا خْ ڒْغِيدْجثْ ن ؤُعذِّيسْ، ؤُ ثِيطّْ نْسنْ وَارْ ثتّْزِيدْجِيزْ إِ إِحنْجِيرنْ.
\v 19 \add ثَانْذِينْثْ ن\add* بَابِيلْ، ثَالْوِيزْثْ جَارْ ثْڭلْذَاثِينْ، \add ثنِّي\add* ذ ڒْعزّْ ذ ؤُسمْغَارْ ن إِكَالْذَانِييّنْ، أَذْ ثذْوڒْ أَمْ مَامّشْ ڒَامِي ثُوغَا أَربِّي إِسّْنقْڒبْ سَاذُومْ ذ عَامُورَّا. \x ◘ \xo 13:‏19 \xt أَمز. 19‏:‏25؛ إِشا. 1‏:‏9؛ إِرْم. 49‏:‏18؛ 50‏:‏40\x*
\v 20 إِ ڒبْذَا وَارْ إِتّْغِيمِي ذِينْ ؤُڒَا ذ إِجّْ، وَارْ \add ذَايسْ\add* زدّْغنْ عَاذْ زِي جِّيڒْ أَڒْ جِّيڒْ. أَعْرَابْ وَارْ ذِينِّي إِشِّيثْ أَقِيضُونْ نّسْ \add عَاذْ\add* ؤُ إِمكْسَاونْ وَارْ تّجِّينْ أَذْ ثَاريّحْ ذِينْ \add ثْحِيمَارْثْ نْسنْ\add*عمَّارْصْ. \x ◘ \xo 13:‏20 \xt إِرْم. 50‏:‏39\x*
\v 21 ڒوْحُوشْ ن ڒخْڒَا أَذْ زّْڒنْ ذِينِّي ؤُ ثِيزذِّيغِينْ نْسنْ أَذْ شُّورنْثْ س مُوكَاثْ، يسِّيسْ ن نّْعَامثْ أَذْ زذْغنْثْ ذِينِّي ؤُشَا إِمُويَانْ \add إِجنّنْ\add* أَذْ ذِينِّي نڭْزنْ.
\v 22 أَذْ سّْمِيعِّيونْ إِفِيسنْ إِجّْ غَارْ ونّغْنِي ذِي لْقلْعَاثْ إِتّْوَاجّنْ \add ن بَابِيلْ\add* ؤُڒَا ذ ؤُشَّاننْ ن ڒخْڒَا ذِي ڒقْصُورْ ن ڒهْزُوطْ. ڒْوقْثْ نّسْ أَذْ د-ثَاوضْ ذغْيَا ؤُ ؤُسَّانْ نّسْ وَارْ تّْزُوڭَّارْثنْ شَا.“
\b
\b
\c 14
\m 
\v 1 ”مَاغَارْ سِيذِي أَذْ إِحِينّْ خْ يَاعْقُوبْ ؤُشَا أَذْ إِفَارْزْ إِسْرَائِيل عَاذْ. نتَّا أَذْ أَسنْ إِوْشْ ڒْهُوذْنثْ ذِي ثمُّورْثْ نْسنْ. أَبَارَّانِي أَذْ كِيذْسنْ إِمُونْ ؤُ نِيثْنِي أَذْ ذوْڒنْ غَارْ ثَادَّارْثْ ن يَاعْقُوبْ.
\v 2 ڒڭْنُوسْ أَذْ ثنْ أَوْينْ ؤُ أَذْ \add ثنْ\add* سِّيذْفنْ غَارْ ومْشَانْ نْسنْ. ثَادَّارْثْ ن إِسْرَائِيل أَذْ ثنْ ثطّفْ ذ ثَاسْغَارْثْ ذِي ثمُّورْثْ ن سِيذِي، أَمْ يِيسمْغَانْ ذ ثِييَّا. أَذْ حبّْسنْ إِنِّي ثنْ إِحبّْسنْ، ؤُشَا أَذْ حكْمنْ خْ إِنِّي ثنْ إِحصَّارنْ.“
\m 
\v 3 ”ذڭْ وَاسّْ إِ ذ أَشْ إِ غَا إِسَّاريّحْ سِيذِي زِي ڒحْرِيقْ نّشْ، زڭْ ؤُنخْڒِيعْ نّشْ ؤُ زِي ثْسخَّارْثْ نّشْ إِقسْحنْ إِ زِي ڭِّينْ أَذْ \add أَسنْ\add* ثْسخَّارذْ، \x ◘ \xo 14:‏3 \xt أَعَوذ. 28‏:‏48\x*
\v 4 أَذْ ثسّْڭعّْذذْ أَمتِّيڒْ-أَ خْ ؤُجدْجِيذْ ن بَابِيلْ، أَذْ ثِينِيذْ: ’مَامّشْ إِسّْبدّْ ونِّي إِحصَّارنْ زِي \add ڒحْصَارثْ\add* نّسْ، \add مَامّشْ\add* ثتّْوَاقْضَا ڒقْسَاحثْ؟‘
\v 5 يَارْژَا سِيذِي أَعْمُوذْ ن إِعفَّاننْ، أَزدْجَاضْ ن أَيْثْ ن بُو-صُّولْطَا،
\v 6 ونِّي إِوْثِينْ ڒڭْنُوسْ ذڭْ إِجّْ ن ؤُذُوقّزْ \add ن ؤُفُوڭمْ\add* س ثِييِّيثَا بْڒَا قطُّو، ونِّي ثُوغَا إِحكّْمنْ خْ ڒڭْنُوسْ س وغْضَابْ، إِضَافَّارْ \add إِ-ثنْ\add* بْڒَا أَزِيدْجزْ.
\v 7 مَارَّا ثَامُّورْثْ ثَارْسَا، ثسْقَارْ. \add خنِّي\add* ذُوقُّوزنْ سْ ڒفْرَاحثْ.
\v 8 ؤُڒَا ذ ثِيشجُّورَا ن ؤُمرْزِي فَارّْحنْثْ زَّايكْ ؤُ ثِيشجُّورَا ن ثنْڭلْثْ ن \add إِذُورَارْ ن\add* لُوبْنَانْ \add قَّارنْثْ\add*: ’زڭْ وَامِي شكْ ثْمدّذْ غَارْ ثمُّورْثْ، وَارْ ذَا د-إِتِّيسْ ؤُڒَا ذ إِجّنْ عَاذْ حِيمَا أَذْ أَنغْ يَارْژْ!‘ “ \f ◼ \fr 14:‏8 \ft \bd ’أَمرْزِي‘\bd* - نِيغْ ’أَمضْزِي‘.\f*
\m 
\v 9 ”ڒَْاخَارْثْ سْوَادَّايْ أَذْ ثنْهزّْ ذِي طّْوعْ نّشْ، مَاحنْذْ أَذْ فّْغنْ نِيثْنِي غَارْ ؤُمْسَاڭَارْ أَكِيذكْ خْمِي د غَا ثَاسذْ. ذِي طّْوعْ نّشْ أَذْ ثسّْفَاقْ ڒخْيَاڒَاثْ \add ن إِمتَّانْ\add*، مَارَّا ڒْحُوكَّامْ ن ثمُّورْثْ، أَذْ ثڭّْ مَارَّا إِجدْجِيذنْ ن ثمُّورْثْ أَذْ كَّارنْ زِي ڒكْرَاسِي نْسنْ إِڭلّْذنْ.
\v 10 نِيثْنِي مَارَّا أَذْ طّْفنْ ذڭْ وَاوَاڒْ، أَذْ أَشْ إِنِينْ: ’ؤُڒَا ذ شكْ ثْذوْڒذْ ثَارهْفذْ، أَمْ نشِّينْ، \add ڒخُّو\add* شكْ ثَاروْسذْ ذَايْنغْ!‘
\v 11 أَقَا ثْمنْضَارْ نّْفَاخثْ نّشْ ذِي ڒَاخَارْثْ، ڒْحسّْ ن لهَارْپَاثْ نّشْ. سَاذُو نّشْ تّْوَابزّْعنْ إِوكِّيونْ \add أَمْ ڒمْثَاحْ\add*، ؤُ إِكشَّاونْ ذ مَالْثَا نّشْ.
\v 12 مَامّشْ \add ثڭِّيذْ\add* ثوْضِيذْ-د زڭْ ؤُجنَّا، \add شكْ،\add* \add أَ يِيثْرِي ن ڒفْجَارْ\add* إِتّْسقْسِيقنْ، مِّيسْ ن ثُوفُّوثْ ن ڒْحَاڒْ! مَامّشْ ثتّْوَارْژذْ غَارْ ثمُّورْثْ، \add شكْ\add* أَمَارْنِيوْ ن ڒڭْنُوسْ!
\v 13 ثنِّيذْ ذڭْ وُوڒْ نّشْ: ’نشّْ أَذْ ڭعّْذغْ غَارْ ؤُجنَّا، أَذْ سّْبدّغْ ڒْعَارْشْ إِنُو ثِيوَا إِ يثْرَانْ ن أَربِّي، أَذْ قِّيمغْ خْ وذْرَارْ ن ؤُمُونِي غَارْ طّْرُوفَا ن شَّامَالْ قَاعْ. \x ◘ \xo 14:‏13 \xt إِزهد. 48‏:‏3\x*
\v 14 نشّْ أَذْ ڭعّْذغْ ثِيوَا ن ثْقِيشَّاثِينْ ن إِسيْنُوثنْ، أَذْ أَرْوْسغْ ذڭْ ؤُمْعُودْجِي خْ كُوڒْشِي!‘
\v 15 لَّ، أَذْ شكْ د-سّهْوَانْ ذِي ڒَاخَارْثْ، ذِي ڒَادْجَاغْ قَاعْ ن وَانُو!
\v 16 إِنِّي شكْ إِ غَا إِژَارنْ، أَذْ ذَايكْ جْعَارنْ، أَذْ فهْمنْ \add ؤُشَا أَذْ إِنِينْ\add*: ’مَا وَا ذ أَرْيَازْ نِّي إِسَّارْجِيجنْ ثَامُّورْثْ، ونِّي إِجِّينْ ثِيڭلْذِينْ أَذْ نْهزّنْثْ،
\v 17 ونِّي يَارِّينْ ثَامُّورْثْ ذ ڒخْڒَا ؤُشَا يَاردّدْجْ ثِيندَّامْ نّسْ، ونِّي وَارْ يَارْخُونْ إِ إِمحْبَاسْ نّسْ أَذْ أَركّْوحنْ؟‘
\v 18 مَارَّا إِجدْجِيذنْ ن ڒڭْنُوسْ، مَارَّا نِيثْنِي زّْڒنْ \add ذِينْ\add* ذِي شَّانْ، كُوڒْ إِجّْ ذِي ثَادَّارْثْ نّسْ.
\v 19 \add مَاشَا\add* شكْ ثْمنْضَارذْ، سِّيڭّْوجنْ شكْ خْ ونْضڒْ نّشْ، \add أَمْ\add* إِشْثْ ن نّْعِي ن ثْغدُّوثْ \add مّنْضَارنْ ت\add*، سّْذُورْينْ ت س إِمتَّانْ إِتّْوَاسّْنُوقّْبنْ س سِّيفْ، إِنِّي د غَا إِهْوَانْ غَارْ إِژْرَا ن ثسْرَافْثْ \add ن ونْضڒْ\add*، أَمْ ڒْخشْبثْ إِ خْعفْسنْ.
\v 20 وَارْ ثمَّارْسذْ ذڭْ ونْضڒْ ذ إِجّنْ أَكِيذْسنْ، مَاغَارْ ثْخَارّْبذْ ثَامُّورْثْ نّشْ ؤُشَا ثنْغِيذْ ڒْڭنْسْ نّشْ. زَّارِيعثْ ن إِعفَّاننْعمَّارْصْ وَارْ ت إِتِّيذَارنْ إِ ڒبْذَا. \x ◘ \xo 14:‏20 \xt أَيُوبْ 18‏:‏19؛ إِزهد. 21‏:‏11؛ 37‏:‏28؛ 109‏:‏13\x*
\v 21 سْوجْذمْ طَّابْڒَا ن ثْغَارْصْثْ إِ إِحنْجِيرنْ نّسْ خْ ڒْمُوعْصِييّثْ ن إِبَابَاثنْ نْسنْ، مَاحنْذْ نِيثْنِيعمَّارْصْ وَارْ تّْبذِّينْ \add عَاذْ\add*، أَذْ وَارْثنْ ثَامُّورْثْ ؤُشَا أَذْ شُّورنْ ؤُذمْ ن ثمُّورْثْ س ثْندَّامْ. \x ◘ \xo 14:‏21 \xt ؤُف. 20‏:‏5؛ مت. 23‏:‏25\x*
\v 22 نشّْ أَذْ خَاسنْ كَّارغْ، \add أَمُّو\add* إِ إِسَّاوَاڒْ سِيذِي ن ڒْعسْكَارَاثْ، نشّْ أَذْ ثحِّيغْ زِي بَابِيلْ \add كُوڒْ\add* إِسمْ ذ \add مَارَّا\add* مِينْ إِقِّيمنْ، أَمْ مِّيسْ ؤُڒَا ذ مِّيسْ ن مِّيسْ، أَمُّو إِ إِقَّارْ سِيذِي. \x ◘ \xo 14:‏22 \xt أَيُوبْ 18‏:‏19؛ إِزهد. 21‏:‏11؛ 37‏:‏28\x*
\v 23 نشّْ أَذْ أَرّغْ \add بَابِيلْ\add* ذ ثَاسْغَارْثْ ن ثْوُوشْثْ ن دْجِيڒثْ ؤُڒَا ذ إِيڒْمَامنْ. أَذْ ثنْ مْحِيغْ س ثْمذْوَاسْثْ ن ؤُردّدْجْ، \add أَمُّو\add* إِ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ.“ \x ◘ \xo 14:‏23 \xt إِشا. 34‏:‏11؛ صَاف. 2‏:‏14\x*
\b
\m 
\v 24 سِيذِي ن ڒْعسْكَارَاثْ إِجِّيدْجْ، إِنَّا ”س ثِيذتّْ، أَمْ مَامّشْ نشّْ إِ ت خَارّْصغْ، أَمُّو إِ غَا إِمْسَارْ، أَمْ مَامّشْ نشّْ إِ ت ؤُرِيغْ، أَمُّو إِ د غَا يَاسْ.
\v 25 أَقَا نشّْ أَذْ أَرْژغْ \bd أَشُّورْ\bd* ذِي ثمُّورْثْ إِنُو ؤُ أَذْ خَاسْعفْسغْ خْ إِذُورَارْ إِنُو، حِيمَا \add أَ\add*زَايْڒُو نّسْ أَذْ زَّايْسنْ إِتّْوَاكْسِي ؤُ ڒحْمڒْ نّسْ أَذْ إِوْضَا خْ ثْغَارْضِينْ نْسنْ.
\v 26 وَا ذ أَشَاوَارْ نِّي إِتّْوَاڭّنْ خْ مَارَّا ثَامُّورْثْ ؤُ وَا ذ أَفُوسْ إِ إِسّْوِيژّْضنْ إِ مَارَّا ڒڭْنُوسْ.
\v 27 مَاغَارْ سِيذِي ن ڒْعسْكَارَاثْ إِخَارّصْ أَيَا، مَانْ ونْ إِزمَّارنْ أَذْ ث إِبْضڒْ؟ أَقَا أَفُوسْ نّسْ إِسّْوِيژَّاضْ إِ-ث، مَانْ ونْ إِزمَّارنْ أَذْ ث يَارّْ \add غَارْ ؤُغزْذِيسْ\add*؟“ \x ◘ \xo 14:‏27 \xt 2 إِم. 20‏:‏6؛ أَيُوبْ 9‏:‏12؛ أَوڒن. 21‏:‏30؛ دَان. 4‏:‏32\x*
\b
\s1 أَوَاڒْ ن أَربِّي خْ فِيلِيشِيثْ
\m 
\v 28 ذڭْ ؤُسڭّْوَاسْ ن ڒْموْثْ ن أَحَازْ، يُوسَا-د ڒْحُوكْمْ إِسَّاڭّْوَاذنْ وَانِيثَا: \x ◘ \xo 14:‏28 \xt 2 إِج. 16‏:‏20\x*
\m 
\v 29 ”وَارْ فَارّحْ، \add أَ شمْ،\add* مَارَّا \add ثَامُّورْثْ ن\add* \bd فِيلِيشِيثْ\bd*، أَقَا أَكشُّوضْ نِّي شمْ إِوْثِينْ، إِتّْوَارْژْ، مَاغَارْ زڭْ وژْوَارْ ن ؤُفِيغَارْ أَذْ د-إِفّغْ ؤُرفْسِيوْ أَمسْمُومْ ؤُ ڒْغِيدْجثْ نّسْ أَذْ ثِيڒِي ذ ڒْحَايْشثْ إِشمْضنْ إِطَّاونْ. \x ◘ \xo 14:‏29 \xt إِشا. 30‏:‏6\x*
\v 30 إِمنْزَا ن إِمُوقْڒِيڒنْ أَذْ هْذَانْ \add س ڒْهُوذْنثْ\add* ؤُشَا إِمزْڒَاضْ أَذْ زّْڒنْ ذِي ڒَامَانْ، \add مَاشَا\add* أَذْ نْغغْ أَژْوَارْ نّمْ س ڒَاژْ ؤُشَا \add أَرفْسِيوْ\add* أَذْ إِنغْ مِينْ زَّايمْ إِقِّيمنْ.“
\m 
\v 31 ”رُو، \add أَ\add* ثَاوَّارْثْ، سْغُويّْ، \add أَ\add* ثَانْذِينْثْ، أَقَا فشْڒنْ مَارَّا \add إِمزْذَاغْ ن\add* فِيلِيشِيثْ! مَاغَارْ زِي شَّامَالْ أَذْ د-يَاسْ دّخَّانْ ؤُشَا ؤُڒَا ذ إِجّنْ أَذْ يَاڭّْوجْ زڭْ إِسذِّييّنْ نّسْ ن ڒْعسْكَارْ.“
\m 
\v 32 ”مِينْ إِ د غَا يَارّنْ خْ إِرقَّاسنْ ن ڒْڭنْسْ؟“
\m ”أَقَا سِيذِي إِڭَّا \add ذْسَاسْ\add* ن صِيهْيُونْ حِيمَا ڒْمُوسَاكِينْ ن ڒْڭنْسْ نّسْ أَذْ غَارسْ أَروْڒنْ!“
\b
\b
\c 15
\m 
\v 1 \bd ڒْْحُوكْمْ إِسَّاڭّْوَاذنْ خْ مُوآبَ.\bd*
\m ”ذِي دْجِيڒثْ إِتّْوَاهْذمْ أَرْ-مُوآبَ، إِذْوڒْ إِسُّوسمْ، وَاهْ، ذِي دْجِيڒثْ إِتّْوَاهْذمْ قِيرْ-مُوآبَ، إِذْوڒْ إِسُّوسمْ! \x ◘ \xo 15:‏1 \xt إِرْم. 48‏:‏1؛ حِز. 25‏:‏9؛ عَام. 2‏:‏1\x*
\v 2 ڭعّْذنْ غَارْ بَايِيثْ ذ ذِيبُونْ، غَارْ ڒڭْعُوذِي حِيمَا أَذْ رُونْ. \add ذِينِّي\add* أَذْ إِرُو مُوآبَ خْ نابُو ذ مَايْذَابَا. قَاعْ أَزدْجِيفْ نْسنْ إِڒْسَا ذ أَقشَّارْ، مَارَّا ثِيمِيرَا تّْوَاحفّنْثْ. \x ◘ \xo 15:‏2 \xt إِرْم. 48‏:‏37؛ حِز. 7‏:‏18\x*
\v 3 بيْسنْ س ثْخُونْشَايْ \add ن وشْضَانْ\add* ذڭْ إِزْنِيقنْ نْسنْ، أَقَا \add ذِينْ\add* مْغِيرْ ثْغُويِّيثْ خْ ثْزغْوِينْ نْسنْ ؤُ ذڭْ وَازَّاينْ نْسنْ، إِمطَّاونْ وطَّانْ-د \add خْ ؤُغمْبُوبْ\add*.
\v 4 حَاشْبُونْ إِسْغُويُّو، ؤُڒَا ذ أَلِيعَالَا. تّسْڒَانْ إِ ثْمِيجَّا نْسنْ أَڒْ يَاهَاصْ. خْ ؤُيَا سْغُويُّونْ \add ؤُڒَا ذ\add* إِرْيَازنْ ن مُوآبَ نِّي غَارْ إِدْجَا ڒسْنَاحْ، بُوحْبڒْ \add ن مْكُوڒْ أَرْيَازْ\add* إِفْشڒْ ذَايسْ.“
\m 
\v 5 ”ؤُڒْ إِنُو إِسْغُويُّو خْ مُوآبَ. إِمَارْوَاڒْ نّسْ إِوْضنْ أَڒْ \add ثَانْذِينْثْ ن\add* صُوغَارْ، \add ثنِّي إِدْجَانْ أَمْ\add* ثَاعجْمِيثْ ن ثْڒَاثَا ن إِسڭّْوُوسَا. أَمْ تّْرُونْ تّْڭعَّاذنْ ثَاسَاونْثْ ن لُوحِيثْ، \add وَاهْ،\add* ذڭْ وبْرِيذْ غَارْ حُورُونَايِيمْ سّْڭَاعَّاذنْ نِيثْنِي ثَاغُويِّيثْ ن ثْخسَّارْثْ.
\v 6 وَاهْ، أَمَانْ ن نِيمْرِيمْ أَذْ ذوْڒنْ إِمُوشَانْ خْڒَانْ، \add وَاهْ،\add* أَرْبِيعْ إِسْڒَاوْ، أَغمُّويْ ن أَرْبِيعْ إِقْضَا، وَارْ إِتِّيڒِي عَاذْ ؤُغمُّويْ أَزِيزَا.
\v 7 خْ ؤُيَا أَذْ أَرْبُونْ مِينْ إِشطّنْ ذ مِينْ \add عَاذْ\add* غَارْسنْ، غَارْ ؤُجمَّاضْ ن إِغْزَارْ ن إِصفْصَافنْ.
\v 8 وَاهْ، أَذْ د-ثفّغْ ثْغُويِّيثْ ن ؤُشثْشِي ذِي ثمُّورْثْ ن مُوآبَ، أَوعّضْ نّسْ \add أَذْ د-إِفّغْ\add* أَڒْ أَجْلَايِيمْ، أَغُويِّي س إِمطَّاونْ أَڒْ بِي‘رْ-إِلِيمْ.
\v 9 عَاذْ شُّورنْ وَامَانْ ن ذِيمُونْ س إِذَامّنْ، وَاخَّا نشّْ أَذْ أَرنْيغْ خْ ذِيبُونْ عَاذْ كْثَارْ: أَيْرَاذْ \add أَذْ د-يَاسْ\add* خْ يِينِّي د-يَاروْڒنْ زِي مُوآبَ، خْ مِينْ إِقِّيمنْ ذِي ثمُّورْثْ.“
\b
\b
\c 16
\m 
\v 1 ” ’سكّمْ \add دّْمَانِي شُّورنْ س\add* إِزْمَارنْ ن ڒْحَاكمْ ن ثمُّورْثْ، زِي سَالَاعْ غَارْ ڒخْڒَا، غَارْ وذْرَارْ ن يدْجِيسْ ن صِيهْيُونْ!‘
\v 2 أَمْ إِجْضَاضْ يَاروْڒنْ، إِتّْوَاسّضْونْ زِي ڒْعُوشّْ، أَمُّو إِ غَا ڭّنْثْ يسِّيسْ ن مُوآبَ غَارْ إِمُوشَانْ ن ؤُژكّْوُو ن \add يغْزَارْ\add* ن أَرْنُونْ.
\v 3 ’أَوْيمْ \add خنِّي\add* شّْوَارْ، كْسِيمْ أَوَاڒْ، ڭّمْ ثِيڒِي نّمْ أَمْ دْجِيڒثْ ذڭْ ؤُزِيڒْ، سْنُوفَّارْ إِمثْلَاعْ، وَارْ زْنُوزِي إِنِّي يَاروْڒنْ!‘
\v 4 ’جّمْ إِنِّي زَّايِي خْ يُوژّْڒنْ أَذْ غَارمْ قِّيمنْ، \add أَ\add* \add ثَامُّورْثْ ن\add* مُوآبَ! إِڒِي ذ أَذُورِّي إِ نِيثْنِي زَّاثْ إِ وُوذمْ ن ؤُمْثحَّايْ!‘ “
\b
\m ”ڒحْصَارثْ \add مَاشَا\add* أَذْ ثْبدّْ، أَثحِّي أَذْ إِقْضَا، إِنِّي إِعفّْسنْ خْ ثمُّورْثْ أَذْ مْودَّارنْ زِي ثمُّورْثْ.
\v 5 ڒْكُورْسِي إِڭلّْذنْ أَذْ إِتّْوَاشدّْ س ثْمخْسِيوْثْ إِشُووَّارنْ ؤُ نتَّا أَذْ خَاسْ إِقِّيمْ ذِي ثِيذتّْ ذڭْ ؤُقِيضُونْ ن ذَاوُوذْ، نتَّا ذ ونِّي إِحكّْمنْ ذ ونِّي يَارزُّونْ ڒْحقّْ ؤُشَا إِسّفْڒحْ ثَاسڭْذَا.“ \x ◘ \xo 16:‏5 \xt إِشا. 9‏:‏6؛ دَان. 7‏:‏14، 27؛ مِيخَا 4‏:‏7؛ لك. 1‏:‏33\x*
\b
\m 
\v 6 ”نشِّينْ نسْڒَا خْ نّْفَاخثْ ن \add ثمُّورْثْ ن\add* مُوآبَ، أَقَا نتَّاثْ ذ ثَاعفَّارْثْ أَڒْ طَّارْفْ. ثَاعفَّارْثْ نّسْ ذ نّْفَاخثْ نّسْ ذ زّْعَامثْ نّسْ، أَقَا \add مَارَّا\add* ڒْهَارْذْ نّسْ إِخْوَانْ وَارْ إِدْجِي شَا نِيشَانْ. \x ◘ \xo 16:‏6 \xt إِرْم. 48‏:‏29، 30\x*
\v 7 س ؤُيَا إِ غَا ثْرُو \add ثمُّورْثْ ن\add* مُوآبَ خْ مُوآبَ، مَارَّا نِيثْنِي أَذْ رُونْ، أَذْ سْغُوينْ خْ زّْبِيبْ ن قِيرْ-حَارِيسَاثْ، نِيثْنِي ذوْڒنْ تّْوَاغڒْبنْ قَاعْ.
\v 8 مَاغَارْ إِسْڒَاونْثْ ثْزَايَارِينْ ذڭْ إِمَارْجَاعنْ ن ؤُضِيڒْ ن حَاشْبُونْ. ثِيسضْوِينْ ن ضِّيڒشْثْ ن سِيبْمَا أَرنّْينْثْ ڒْحُوكَّامْ نْ ڒڭْنُوسْ. ثِيسضْوِينْ يِيوْضنْثْ أَڒْ يَاعْزِيرْ، سُوحنْثْ ذِي ڒخْڒَا، بزّْعنْثْ، أَقَا ژْوَانْثْ ڒبْحَارْ. \x ◘ \xo 16:‏8 \xt إِرْم. 48‏:‏32، 33\x*
\v 9 خْ ؤُيَا تّْرُوغْ \add خْ\add* ضِّيڒشْثْ ن سِيبْمَا، أَمْ مَامّشْ رُوغْ خْ يَاعْزِيرْ. سُّوغْ شمْ س إِمطَّاونْ إِنُو، \add أَ، ثِيندَّامْ ن\add* حَاشْبُونْ ذ أَلِيعَالَا، مِينْزِي رُوحنْ إِغُويَّانْ ن ؤُسْڒِيوْڒوْ زِي ثِينِي نّمْ ن ؤُنبْذُو ؤُ زڭْ وڒْقَاضْ نّمْ. \x ◘ \xo 16:‏9 \xt إِرْم. 48‏:‏32\x*
\v 10 ثْحيّذْ ڒفْرَاحثْ ذ زّْهُو زڭْ إِيَّارْ\add أنْ\add* إِسّغْمَاينْ ن ثْفدْجَاحْثْ، وَارْ تّْغنِّيجنْ ؤُ وَارْ سْڒِيوْڒِيونْ \add عَاذْ\add* ذڭْ إِمَارْجَاعنْ ن ؤُضِيڒْ. ونِّي يَارفّْسنْ وَارْ يَارفّسْ \add عَاذْ\add* أَضِيڒْ ذِي ثْسِيڒْثْ \add ن ؤُضِيڒْ\add*. سّْبدّغْ نشّْ ڒعْيُوذَاثْ ن ؤُسْڒِيوْڒوْ.
\v 11 خْ ؤُيَا سْغُويُّونْثْ ثكْرِيشِينْ إِنُو أَمْ يِيجّْ ن ڒْڭَامْبْرِي خْ مُوآبَ، ؤُ ذَاخڒْ إِنُو خْ كِيرْ-حَارِيسْ.
\v 12 خْمِي إِ غَا يَاحڒْ مُوآبَ خْ ڒْڭعّْذثْ \add مَانِي تّْقدَّامنْ ثِيوْهِيبِينْ نّسْ\add* ؤُشَا أَذْ يَاذفْ غَارْ زَّاوشْثْ نّسْ إِقدّْسنْ حِيمَا أَذْ إِژَّادْجْ، \add خنِّي\add* أَذْ ژَترنْ أَقَا مُوآبَ وَارْ إِزمَّارْ أَذْ إِڭّْ وَالُو.“ \x ◘ \xo 16:‏12 \xt أَعَوذ. 32‏:‏37، 38، 39\x*
\m 
\v 13 وَا ذ أَوَاڒْ إِ إِسِّيوڒْ سِيذِي خْ مُوآبَ.
\v 14 \add ؤُشَا\add* ڒخُّو إِسَّاوَاڒْ سِيذِي، إِقَّارْ: ”ذِي ثْڒَاثَا ن إِسڭّْوُوسَا عْلَاحْسَابْ إِسڭّْوُوسَا ن ؤُشوَّاڒْ، أَذْ إِذْوڒْ ؤُعُودْجِي ن مُوآبَ إِتّْوَاسّحْقَارْ أَكْ-ذ مَارَّا أَبَارُّو نِّي أَمقّْرَانْ. مِينْ \add زَّايسْ\add* إِ غَا إِقِّيمنْ، أَذْ يِيڒِي ذْرُوسْ قَاعْ، وَارْ إِدْجِي أَطَّاسْ.“
\b
\b
\c 17
\m 
\v 1 \bd ڒْحُوكْمْ إِسَّاڭّْوَاذنْ خْ ذِيمَاشْقْ.\bd*
\b
\m ”أَقَا ذَا، ذِيمَاشْقْ وَارْ ثتِّيڒِي عَاذْ ذ ثَانْذِينْثْ، أَذْ ثذْوڒْ ذ ڒْخَارْبثْ إِتّْوَاهذْمنْ.
\v 2 ثِيندَّامْ ن عَارُوعِيرْ أَذْ ذوْڒنْثْ خْڒَانْثْ، أَذْ إِڒِينْثْ إِ ثْحِيمْرِيوِينْ. ثِينَا أَذْ ذِينِّي زّْڒنْثْ ؤُشَا ؤُڒَا ذ إِجّنْ وَارْ ثنْثْ إِسّْفعْفِيعْ.
\v 3 أَذْ ثتّْوَاقْضَا خْ لْقلْعَا زِي إِفْرَايِيمْ ؤُڒَا خْ ثَاڭلْذِيثْ زِي ذِيمَاشْقْ ؤُ خْ مِينْ إِقِّيمنْ ن أَرَامْ. نِيثْنِي أَذْ أَسنْ إِمْسَارْ أَمْ مَامّشْ إِمْسَارْ إِ ؤُعُودْجِي ن أَيْثْ ن إِسْرَائِيل، \add أَمُّو إِ\add* إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ.“
\m 
\v 4 ”\bd ذڭْ وَاسّْ نِّي\bd* أَذْ إِسْڒَاوْ ؤُعُودْجِي ن يَاعْقُوبْ ؤُشَا أَذْ ثذْوڒْ ثَاذُونْثْ ن أَرِّيمثْ نّسْ ثقِّيدْجثْ.
\v 5 أَذْ يِيڒِي أَخْمِي إِتّْقبّضْ ونِّي إِمجَّارنْ إِمنْذِي إِبدّنْ ؤُشَا إِمجَّارْ ؤُغِيڒْ نّسْ ثِيذْرِينْ، أَذْ يِيڒِي أَخْمِي إِجّْ إِڒقّضْ ثِيذْرِينْ ذِي ثغْزُورْثْ ن إِرَافَاوِييّنْ.
\v 6 أَذْ إِقِّيمْ \add مْغِيرْ\add* إِجّْ ن ؤُشطِّي إِ وڒْقَاضْ، أَمْ غَارْ وزْوَاضْ ن إِزمُّورنْ، ثْنَاينْ نِيغْ ثْڒَاثَا \add ن ثْزِيثُونِينْ\add* غَارْ ثْقِيشّثْ ن ثَاسطَّا سنّجْ، ؤُشَا أَربْعَا نِيغْ خمْسَا غَارْ ثِيسضْوِينْ إِغمَّاينْ أَطَّاسْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، أَربِّي ن إِسْرَائِيل.“
\m 
\v 7 ”\bd ذڭْ وَاسّْ نِّي\bd* أَذْ إِخْزَارْ بْنَاذمْ خْ ونِّي ث إِڭِّينْ ؤُ ثِيطَّاوِينْ نّسْ أَذْ ژَترنْ أَمْقدَّاسْ ن إِسْرَائِيل.
\v 8 وَارْ إِتّْوَاڒِي إِعَالْطَارنْ، ڒْخذْمثْ ن إِفَاسّنْ نّسْ، ؤُڒَا ذ مِينْ إِڭِّينْ إِضوْضَانْ نّسْ وَارْ ث إِژَّارْ، ثِيربِّينْ ن شْوَارْثِي لَّا ؤُڒَا ذ إِپِيلَارنْ ن أَربِّي ن ثْفُوشْثْ لَّا.“
\m 
\v 9 ”\bd ذڭْ وَاسّْ نِّي\bd* أَذْ إِڒِينْثْ ثْندَّامْ نّسْ إِفَارْينْ أَمْ ومْشَانْ إِخْڒَا ذڭْ وزْغَارْ ؤُ ثَاقِيشّثْ ن وذْرَارْ نِّي جِّينْ زَّاثْ إِ ثِيطَّاوِينْ ن أَيْثْ ن إِسْرَائِيل، أَذْ يِيڒِي ذ أَمْشَانْ إِتّْوَاردّْدْجنْ.
\v 10 مَاغَارْ شكْ ثتُّوذْ أَربِّي ن ؤُسنْجمْ نّشْ، وَارْ ثعْقِيڒذْ خْ ثصْضَارْثْ نّشْ إِجهْذنْ. خْ ؤُيَا ثتّژُّوذْ أَغمُّويْ إِضَارْفنْ ؤُشَا ثْزَارّْعذْ ثِيغدُّوثِينْ ثِيبَارَّانِييِّينْ.
\v 11 ذڭْ وَاسّْ نِّي ذِي ثنْثْ ثژُّوضْ، أَذْ ثنْثْ ثْفَارْيذْ، ؤُ غَارْ ؤُثفُّو ثجِّيذْ زَّارِيعثْ نّمْ أَذْ ثسّْفُوفِّي: \add ذ مَانْ أَيَا\add* ذ ثَامجْرَا إِعُورّْشنْ ذڭْ وَاسّْ ن ڒحْڒَاشْ نّشْ ذ ڒحْرِيقْ وَارْ إِتّْڭنْفِينْ.“
\m 
\v 12 ”\bd ؤُشْثْ\bd* خْ ؤُبَارُّو ن ڒڭْنُوسْ نِّي إِزهَّارنْ أَمْ زهَّارنْ ڒبْحُورْ، ؤُڒَا \add ؤُشْثْ خْ\add* دّْرِيزْ ن شُّوعُوبْ نِّي \add إِڭِّينْ\add* أَمْ ڒحْوڒْ ن وَامَانْ إِمقّْرَاننْ إِنْهوْڒنْ!
\v 13 أَذْ هوْڒنْ شُّوعُوبْ أَمْ ڒحْوڒْ ن وَامَانْ إِمقّْرَاننْ، \add مَاشَا\add* نتَّا أَذْ ثنْ يَاربَّا ؤُ نِيثْنِي أَذْ أَروْڒنْ غَارْ ڒَاڭّْوَاجْ. أَذْ إِتّْوَاعَارْنْ \add ؤُبَارُّو نْ ڒڭْنُوسْ\add* أَمْ ؤُڒُومْ خْ إِذُورَارْ \add إِتّْوَاعَارْننْ\add* زڭْ ؤُسمِّيضْ، أَمْ \add ؤُسيْنُو ن ثْعجَّاجْثْ\add* ثنّضْ أَسْ-د ثْحَارْيَاضْثْ. \x ◘ \xo 17:‏13 \xt أَيُوبْ 21‏:‏18؛ إِزهد. 1‏:‏4؛ 35‏:‏5؛ 83‏:‏14؛ حُوش. 13‏:‏3\x*
\v 14 غَارْ ڒْوقْثْ ن ثْمذِّيثْ، خْزَارْ، أَنخْڒِيعْ! قْبڒْ مَا أَذْ إِصْبحْ ڒْحَاڒْ، وَارْ إِدْجِي نتَّا عَاذْ. ثَا ذ ثَاسْغَارْثْ ن يِينِّي ذ أَنغْ إِكشّْضنْ، زّْهَارْ ن يِينِّي ذ أَنغْ يُوشَارنْ.“
\b
\b
\c 18
\s1 ثَامُّورْثْ ن كُوشْ أَذْ ثْسلّمْ إِخفْ نّسْ إِ سِيذِي أَربِّي
\m 
\v 1 ”\bd ؤُشْثْ\bd* خْ ثمُّورْثْ ن ڒْحسّْ ن وَافْرِيونْ، ثنِّي غَارْ ؤُرنْذَاذْ إِغزْرَانْ ن \add ثمُّورْثْ ن\add* كُوشْ،
\v 2 ثنِّي إِسّكّنْ إِمْسكَّانْ \add نّسْ\add* خْ ڒبْحَارْ، ذِي ثْغَارَّابُوثِينْ ن ؤُغَانِيمْ ثِيوَا إِ وَامَانْ.
\m ؤُيُورمْ، \add أَ كنِّيوْ\add* إِرقَّاسنْ إِفْسُوسنْ، غَارْ إِجّْ ن ڒْڭنْسْ إِزُّوڭَّارْثنْ ؤُ إِتّْوسّْڭنْ \add ن ثڒْمشْثْ\add*، غَارْ إِجّْ ن ڒْڭنْسْ نِّي زِي ڭّْوذنْ زڭْ وَامِي إِدْجَا ؤُ زِي سَّا ثْسَاونْثْ، غَارْ ڒْڭنْسْ نِّي إِتَّامَارَانْ ڒبْذَا ؤُ إِعفّسْ، ونِّي زِي قضْعنْ إِغزْرَانْ ثَامُّورْثْ نّسْ.
\v 3 \add أَ كنِّيوْ\add* مَارَّا إِمزْذَاغْ ن دُّونشْثْ ذ يِينِّي إِزدّْغنْ ذِي ثمُّورْثْ، خْمِي غَا سّْڭعّْذنْ ثَاعدْجَانْثْ خْ إِذُورَارْ، \add خنِّي\add* أَذْ \add ث\add* ثْژَارمْ، ؤُ خْمِي غَا سُوضنْ ذڭْ ؤُيِيشّْ ن إِشَارِّي، أَذْ \add ث\add* ثسْڒمْ!“
\m 
\v 4 ”مَاغَارْ أَمُّو إِ ذ غَارِي إِنَّا سِيذِي: ’نشّْ أَذْ حْضِيغْ ذِي ڒْهُوذْنثْ خْ ڒْعَارْشْ إِنُو، أَمْ ڒهْمُو يَارقّنْ غَارْ طّْحَا \add ن ؤُزِيڒْ\add*، أَمْ ؤُسيْنُو \add إِشُّورنْ س\add* نّْضَا غَارْ ڒهْمُو ن صَّابثْ.‘
\v 5 مَاغَارْ قْبڒْ صَّابثْ، خْمِي غَا إِكمّڒْ نُّووَّارْ، ثذْوڒْ ثْنوَّارْثْ ذ أَضِيڒْ إِننَّا، أَذْ إِزْبَارْ نتَّا إِزْبِيرنْ س إِجقَّاضنْ ن وزْبَارْ، أَذْ إِكّسْ أَرْبِيبنْ، أَذْ ثنْ إِقْضُو.
\v 6 نِيثْنِي مَارَّا أَذْ تّْوَاجّنْ إِ إِجْضَاضْ إِتّْكشَّاضنْ خْ إِذُورَارْ ؤُ إِ ڒوْحُوشْ ن ثمُّورْثْ. ذڭْ ؤُنبْذُو أَذْ خَاسنْ أَرْسنْ إِجْضَاضْ إِتّْكشَّاضنْ ؤُ ذِي ڒْمشْثَا أَذْ خَاسنْ أَرْسنْ ڒوْحُوشْ ن ڒخْرَا.
\v 7 ذِي ڒْوقْثْ نِّي أَذْ أَوْينْ إِشْثْ ن ثَارْزفْثْ إِ سِيذِي ن ڒْعسْكَارَاثْ: إِجّْ ن ڒْڭنْسْ إِزُّوڭَّارْثنْ ذ إِتّْوسّْڭنْ \add ن ثڒْمشْثْ\add* - ؤُ \add مَانْ أَيَا\add* زڭْ إِجّْ ن ڒْڭنْسْ إِمڭّْوذْ زَّايسْ زڭْ وَامِي إِدْجَا ذ ثْسَاونْثْ، زڭْ إِجّْ ن ڒْڭنْسْ نِّي إِتَّامَارنْ ڒبْذَا ؤُ إِعفّسْ، نِّي زِي قضْعنْ إِغزْرَانْ ثَامُّورْثْ نّسْ - غَارْ ومْشَانْ ن يِيسمْ ن سِيذِي ن ڒْعسْكَارَاثْ: غَارْ وذْرَارْ ن صِيهْيُونْ.“
\b
\b
\c 19
\m 
\v 1 \bd ڒْْحُوكْمْ خْ مِيصْرَا.\bd* ”خْزَارْ، سِيذِي إِنّْيَا خْ إِشْثْ ن ثْسيْنُوثْ إِتَّازّْڒنْ. نتَّا يُوذفْ غَارْ مِيصْرَا ؤُشَا لْ-أَصْنَامْ أَذْ أَرْجِيجنْ زَّاثْ إِ وُوذمْ نّسْ ؤُ أَيْثْ ن مِيصْرَا أَذْ أَسنْ إِفْشڒْ وُوڒْ ذڭْ إِذْمَارنْ نْسنْ.
\v 2 مَاغَارْ أَذْ سّْحَارّْشغْ إِمِيصْرِييّنْ خْ إِمِيصْرِييّنْ، مَاحنْذْ كُوڒْ  إِجّْ أَذْ إِمّْنغْ أَكْ-ذ ؤُمَاسْ، ؤُ كُوڒْ إِجّْ أَكْ-ذ وَاجَّارْ نّسْ، ثَانْذِينْثْ أَكْ-ذ ثنْذِينْثْ، ثَاڭلْذِيثْ أَكْ-ذ ثْڭلْذِيثْ.
\v 3 بُوهْبڒْ نْ إِمِيصْرِييّنْ أَذْ يَارْجفْ ذَايْسنْ ؤُ نشّْ أَذْ فسْخغْ إِخَارِّيصنْ نْسنْ. \add خنِّي\add* أَذْ سّقْسَانْ لْ-أَصْنَامْ نْسنْ ذ يِينِّي إِتّْعزّْمنْ ؤُڒَا ذ يِينِّي إِسَّاوَاڒنْ أَكْ-ذ إِمتَّانْ ذ إِڭزَّاننْ.
\v 4 أَذْ ڭّغْ إِمِيصْرِييّنْ ذڭْ ؤُفُوسْ ن أَيْثْبَابْ إِقسْحنْ ؤُشَا أَجدْجِيذْ إِوْعَارنْ أَذْ خَاسنْ إِحْكمْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، سِيذِي ن ڒْعسْكَارَاثْ.
\v 5 أَمَانْ ذِي ڒبْحَارْ أَذْ أَژْغنْ ؤُ إِغْزَارْ أَذْ إِذْوڒْ ذ إِجْذِي، أَذْ يَاژغْ.
\v 6 إِغزْرَانْ أَذْ أَرْخُونْ إِ أَرِّيحثْ يُورْسُوضنْ ؤُ إِغزْرَانْ ن مِيصْرَا أَذْ أَرْسنْ ؤُشَا أَذْ أَژْغنْ، أَغَانِيمْ ذ ثلْڭَا أَذْ إِسْڒَاونْ.
\v 7 دّْمَانِي ن ثَاروْسَا غَارْ نِيلْ، غَارْ ؤُقمُّومْ ن إِغْزَارْ \add ن نِيلْ\add*، ؤُڒَا ذ مَارَّا ثَامُّورْثْ غَارْ إِغزْرَانْ مَانِي زَارّْعنْ، أَذْ أَژْغنْ، أَذْ تّْوَاكّْسنْ، وَارْ تِّيڒِينْ عَاذْ.
\v 8 إِبحْرِييّنْ ن إِسڒْمَانْ أَذْ شضْننْ ؤُ مَارَّا إِنِّي إِنْضَارنْ ثَاسنَّارْثْ نْسنْ ذڭْ إِغْزَارْ \add ن نِيلْ\add*، ؤُ إِنِّي إِبزّْعنْ ثْرَاشَّا ن ؤُذلَّاعْ خْ وَامَانْ، أَذْ إِسْڒَاونْ \add زڭْ وشْضَانْ\add*.
\v 9 إِنِّي إِخدّْمنْ ثِيفّسْثْ أَزْذَاذْ مشّْضنْ أَذْ سضْحَانْ، ؤُڒَا ذ إِذَارَّازنْ ن ڒْكتَّانْ ذ أَشمْڒَاڒْ.
\v 10 أَذْ تّْوَادّْزنْ إِپِيلَارنْ ن ثمُّورْثْ، مَارَّا إِنِّي إِخدّْمنْ ذِي طّْوعْ نْ ڒْمُونثْ إِشْضنْ أَسْ ڒعْمَارْ.“
\m 
\v 11 ”وَاهْ، ڒْحُوكَّامْ ن صُوعَانْ ذ إِبُوهَاڒِييّنْ، شّْوَارْ ن إِمْشَاوَارنْ إِمِيغِيسنْ ن فِيرْعُونْ إِذْوڒْ إِبُّوهْڒِي. مَامّشْ ثْزعّْممْ أَذْ ثقَّارمْ \add عَاذْ\add* إِ فِيرْعُونْ: ’نشّْ ذ مِّيسْ ن إِمِيغِيسنْ، مِّيسْ ن إِجدْجِيذنْ ن وشْحَاڒْ ؤُيَا؟‘
\v 12 مَانِي دْجَانْ خنِّي إِمِيغِيسنْ نّشْ؟ أجّْ إِ-ثنْ أَذْ أَشْ سَّارْڭْبنْ ؤُ أَذْ \add شكْ\add* سّشْننْ مِينْ إِخَارّصْ سِيذِي ن ڒْعسْكَارَاثْ ضِيدّْ إِ مِيصْرَا!
\v 13 ڒْحُوكَّامْ ن صُوعَانْ ذوْڒنْ ذ إِبُوهَاڒِييّنْ، تّْوَاشمْثنْ ڒْحُوكَّامْ ن نُوفْ. أَذْ سّْودَّارنْ مِيصْرَا، \add أَقَا\add* إِنِّي ذ إِژْرَا ن ثغْمَارْثْ ن ثْقبَّاڒْ نّسْ.“
\m 
\v 14 ”سِيذِي إِكبّْ ذِي مِيصْرَا بُوحْبڒْ  إِسّْذوَّاخنْ ذِي ڒْوسْطْ نّسْ. نِيثْنِي سّْودَّارنْ مِيصْرَا ذِي مَارَّا مِينْ إِڭَّا، أَمْ ؤُمسْكَارْ إِودَّارْ ذِي ثْعُوقِّيثْ نّسْ.
\v 15 وَارْ إِتِّيڒِي \add عَاذْ\add* إِ مِيصْڒَا مِينْ غَا يڭّْ، مِينْ إِزمَّارْ أَذْ \add ث\add* إِڭّْ ؤُزدْجِيفْ نِيغْ أَكنَّاسْ، ثَاسطَّا نِيغْ أَغَانِيمْ.“ \x ◘ \xo 19:‏15 \xt إِشا. 9‏:‏13\x*
\m 
\v 16 ”\bd ذڭْ وَاسّْ نِّي\bd* أَذْ إِڒِينْ إِمِيصْرِييّمْ أَمْ ثمْغَارِينْ. أَذْ أَرْجِيجنْ، أَذْ نّْخڒْعنْ زِي سِّيبّثْ ن ونْهزِّي \add إِسَّاڭّْوَاذنْ\add* ن ؤُفُوسْ ن سِيذِي ن ڒْعسْكَارَاثْ، إِ زِي غَارْسنْ إِ غَا إِنْهزّْ سَّا ذ سَّا.
\v 17 ثَامُّورْثْ ن يَاهُوذَا أَذْ ثذْوڒْ ذ أَمذْيَا ن ؤُنخْڒِيعْ إِ إِمِيصْرِييّنْ. مَارَّا ونِّي ث إِتِّيذَارنْ، أَذْ إِنّخْڒعْ زِي سِّيبّثْ ن ؤُخَارّصْ ن سِيذِي ن ڒْعسْكَارَاثْ نِّي خَاسنْ إِخَارّصْ.“
\m 
\v 18 ”\bd ذڭْ وَاسّْ نِّي\bd* أَذْ ذِينْ إِڒِينْثْ خمْسَا ن ثْندَّامْ ذِي ثمُّورْثْ ن مِيصْرَا، أَذْ \add ذِينْ\add* سِّيوْڒنْ \add إِوْذَانْ\add* إِڒسْ ن كنْعَانْ ؤُشَا أَذْ جَّادْجنْ غَارْ سِيذِي ن ڒْعسْكَارَاثْ. إِشْثْ ن زَّايْسنْثْ أَذْ أَسْ قَّارنْ ’إِرْ-هَا-هرسْ!‘، \add ’ثَانْذِينْثْ ن وَاردّدْجْ‘\add*.\x ◘ \xo 19:‏18 \xt أَعَوذ. 10‏:‏20؛ إِرْم. 12‏:‏16\x*
\v 19 \bd ذڭْ وَاسّْ نِّي\bd* أَذْ \add ذِينْ\add* يِيڒِي إِجّْ ن ؤُعَالْطَارْ ذِي ڒْوسْطْ ن ثمُّورْثْ ن مِيصْرَا ؤُ إِجّْ ن ؤُمَايْضُو \add إِقدّْسنْ\add* غَارْ ويْمِيرْ نّسْ.
\v 20 أَيَا أَذْ يِيڒِي ذ ڒعْڒَامثْ ذ شّْهَاذثْ إِ سِيذِي ن ڒْعسْكَارَاثْ ذِي ثمُّورْثْ ن مِيصْرَا: خْمِي غَا ڒَاغَانْ إِ سِيذِي زِي سِّيبّثْ ن يِينِّي ثنْ إِحصَّارنْ، نتَّا أَذْ غَارْسنْ إِسّكّْ أَمْسنْجمْ ذ أَمقّْرَانْ، ؤُ وَانِيثَا أَذْ ثنْ إِفكّْ.
\v 21 أَذْ إِذْوڒْ سِيذِي إِتّْوَاسّنْ غَارْ إِمِيصْرِييّنْ ؤُشَا إِمِيصْرِييّنْ أَذْ سّْننْ سِيذِي \bd ذڭْ وَاسّْ نِّي\bd*. نِيثْنِي أَذْ أَسْ سخَّارنْ س ثْغَارْصْثْ ذ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* ؤُشَا أَذْ وْشنْ أَوَاڒْ إِ سِيذِي ؤُ أَذْ ث كمّْڒنْ. \x ◘ \xo 19:‏21 \xt مـَال. 1‏:‏11\x*
\v 22 أَذْ إِوّثْ سِيذِي إِمِيصْرِييّنْ س ثِييِّيثَا، نتَّا أَذْ \add ثنْ\add* إِوّثْ ؤُ أَذْ \add ثنْ\add* إِسّْڭنْفَا. نِيثْنِي أَذْ د-ذوْڒنْ غَارْ سِيذِي ؤُ نتَّا أَذْ يجّْ إِخفْ نّسْ أَذْ إِتّْوَاسّصْڒحْ س ثْژَادْجِيثْ يُودْجْغنْ نْسنْ ؤُ أَذْ ثنْ إِسّْڭنْفَا.“
\m 
\v 23 ”\bd ذڭْ وَاسّْ نِّي\bd* أَذْ \add ذِينْ\add* يِيڒِي وبْرِيذْ أَمقّْرَانْ زِي مِيصْرَا أَڒْ أَشُّورْ. أَيْثْ ن أَشُّورْ أَذْ د-أَسنْ ذِي مِيصْرَا ؤُشَا إِمِيصْرِييّنْ ذِي أَشُّورْ. أَذْ \add أَسْ\add*عبْذنْ إِمِيصْرِييّنْ \add إِ نتَّا\add* \add جْمِيعْ\add* أَكْ-ذ أَيْثْ ن أَشُّورْ.“
\m 
\v 24 ”\bd ذڭْ وَاسّْ نِّي\bd* أَذْ يِيڒِي إِسْرَائِيل ذ وِيسّْ ثْڒَاثَا أَكْ-ذ مِيصْرَا ذ أَشُّورْ، ذ لْبَارَاكَا ذِي ڒْوسْطْ ن ثمُّورْثْ.
\v 25 مَاغَارْ سِيذِي ن ڒْعسْكَارَاثْ أَذْ ثنْ إِبَاركْ، أَذْ يِينِي: ’إِڒِي أَذْ إِتّْوَابَاركْ ڒْڭنْسْ إِنُو مِيصْرَا، ؤُ ڒْخذْمثْ ن إِفَاسّنْ إِنُو أَشُّورْ، ؤُڒَا ذ ثَاسْغَارْثْ إِنُو إِسْرَائِيل!‘ “
\b
\b
\c 20
\s1 ڒْحُوكْمْ خْ مِيصْرَا ذ كُوشْ
\m 
\v 1 ذڭْ ؤُسڭّْوَاسْ نِّي ذِي د-يُوسَا ؤُكُومَانْذَارْ ن ڒْعسْكَارْ غَارْ أَشْذُوذْ، ؤُمِي ث إِسّكّْ سَارْجُونْ، أَجدْجِيذْ ن أَشُّورْ، ؤُ إِمّْنغْ نتَّا أَكْ-ذ أَشْذُوذْ ؤُشَا إِطّفْ إِ-ث،
\v 2 ذِي ڒْوقْثْ نِّي ثُوغَا إِسَّاوَاڒْ سِيذِي، س ؤُقمُّومْ ن إِشَاعْيَا، مِّيسْ ن أَمُوصْ، إِنَّا: ”ؤُيُورْ، سَارْسْ أَرُّوضْ ن ثْخَانْشثْ \add ن وشْضَانْ\add* نِّي خْ ثجْعِينَّا نّشْ ؤُ كّسْ سَانْذَالِييَاثْ نّشْ خْ إِضَارنْ نّشْ!“ إِڭَّا إِ-ث \add إِشَاعْيَا\add*، إِڭُّورْ ذ أَعَارْيَانْ ؤُ س ڒحْفَا خْ إِضَارنْ نّسْ. \f ◼ \fr 20:‏2 \ft \bd ’أَقمُّومْ‘\bd* - س ثْعِيبْرَانِيثْ ’أَفُوسْ‘.\f*
\v 3 \add ڒخْذنِّي\add* إِنَّا سِيذِي: ”أَمْ مَامّشْ إِڭُّورْ ؤُمْسخَّارْ إِنُو إِشَاعْيَا \add ڒخُّو عَاذْ\add* ثْڒَاثَا ن إِسڭّْوُوسَا ذ أَعَارْيَانْ ؤُ س ڒحْفَا ذَا ذ ذِيهَا، أَمْ ڒعْڒَامثْ ؤُ أَمْ يِيجّْ ن ڒعْجبْ إِ مِيصْرَا ؤُ إِ كُوشْ،
\v 4 أَمُّو إِ غَا إِنْذهْ ؤُجدْجِيذْ ن أَشُّورْ إِمحْبَاسْ ن مِيصْرَا ذ إِمنْفِييّنْ ن كُوشْ، أَمژْيَانْ ذ ؤُمقّْرَانْ، أَعَارْيَانْ ذ ؤُحفْيَانْ ن إِضَارنْ، ؤُڒَا س دَّابُوبْ إِعَارَّانْ، \add أَقَا\add* ذ ڒفْضِيحثْ إِ مِيصْرَا.
\v 5 \add خنِّي\add* أَذْ ڭّْوذنْ ؤُ أَذْ سضْحَانْ زِي سِّيبّثْ ن أَيْثْ ن كُوشْ إِ غَارْ ثُوغَا خزَّارنْ ذ شَا، ؤُ زِي سِّيبّثْ ن إِمِيصْرِييّنْ، أَفيّشْ نْسنْ. \f ◼ \fr 20:‏5 \ft \bd ’أَيْثْ ن كُوشْ‘\bd* - إِخْسْ أَذْ يِينِي ڒْڭنْسْ ن سُّوذَانْ ذ إِثْيُوبْيَا.\f*
\v 6 إِمزْذَاغْ ن ثمُّورْثْ-أَ خْ ثْمَا نْ ڒبْحَارْ أَذْ إِنِينْ \bd ذڭْ وَاسّْ نِّي\bd*: ’خْزَارْ، أَمُّو إِ إِمْسَارْ إِ ونِّي غَارْ نْخزَّارْ ذ شَا، ذ ونِّي غَارْ نَارْوڒْ حِيمَا أَذْ نَارْزُو ثْوِيزَا، حِيمَا أَذْ نتّْوَافكّْ زِي زَّاثْ ن وُوذمْ ن ؤُجدْجِيذْ ن أَشُّورْ. مَامّشْ \add خنِّي\add* نْزمَّارْ أَذْ ننْجمْ \add ڒخُّو\add*؟‘ “
\b
\b
\c 21
\m 
\v 1 \bd ڒْْحُوكْمْ إِسَّاڭّْوَاذنْ خْ ڒخْڒَا ن ڒبْحَارْ.\bd*
\b
\m ”أَمْ مَامّشْ تَّازّْڒنْثْ ثْحَارْيَاضِينْ ذِي \add ثمُّورْثْ ن\add* لْجَانُوبْ، \add أَمُّو إِ\add* غَا إِفّغْ نتَّا زِي ڒخْڒَا، زِي ثمُّورْثْ إِسَّاڭّْوَاذنْ. \f ◼ \fr 21:‏1 \ft \bd ’ڒبْحَارْ‘\bd* - نِيغْ ’إِلْ‘.\f*
\v 2 ثُوسَا-د غَارِي إِجّْ ن ڒوْحِييْ إِقْسحْ: ’أَغدَّارْ إِتّڭّْ س ڒغْذَارثْ ؤُ أَمْثحَّايْ أَذْ إِثحَّا. ڭعّذْ-د، \add أَ\add* عِيلَامْ، حْصَارْ، \add أَ\add* مَاذَايْ!‘ نشّْ أَذْ سّْبدّغْ مَارَّا أَزهَّارْ نّسْ.
\v 3 خْ ؤُيَا تّكْسنْثْ ذَايِي ثجْعِينَّاثِينْ إِنُو، ؤُ طّْفنْ أَيِي ڒوْجعْ ن ثَارُوثْ أَمْ ڒوْجعْ ن إِشْثْ ن ثمْغَارْثْ إِتَّارْونْ. نشّْ تّْنزْبَارغْ خْمِي \add ذ أَسْ\add* تّسْڒِيغْ، نّْخڒْعغْ ؤُمِي ث تّْوَاڒِيغْ.
\v 4 ؤُڒْ إِنُو إِنّجْرفْ، أَقَارْقبْ \add نّسْ\add* إِسّنْهزَّا ذَايِي ثِيڭّْوُوذِي. ثْبَامْبَاسْثْ ن ثْمذِّيثْ نِّي وهّْشغْ أَطَّاسْ، إِڭَّا أَيِي ت ذ ڒْعُورّثْ.“ \x ◘ \xo 21:‏4 \xt أَيُوبْ 7‏:‏3\x*
\b
\m 
\v 5 ”سْرُوسَا-د طَّابْڒَا، سْبدّْ أَعسَّاسْ، أشّْ، سُو!“
\b
\m ”كَّارمْ، \add أَ\add* ڒْحُوكَّامْ، ذهْنمْ ثَاسدَّارْثْ \add ن ؤُسڒْقِي\add*!“
\v 6 مَاغَارْ أَمُّو إِ ذ أَيِي إِنَّا سِيذِي: ”ؤُيُورْ، أڭّْ إِجّْ ن ؤُعسَّاسْ، أجّْ إِ-ث أَذْ إِخبَّارْ مِينْ إِتّْوَاڒَا!“
\v 7 أَقَا إِژْرَا إِرْيَازنْ نِّي إِنْيِينْ خْ ييْسَانْ، ثْيُويَا ن إِمْنَاينْ أَكْ-ذ ثْيُويَا نّغْنِي، إِجّْ ن ؤُكَارَابَانْ ن يغْيَاڒْ ذ إِجّْ ن ؤُكَارَابَانْ ن إِڒغْمَانْ. ثُوغَا إِحطَّا مْلِيحْ، مْلِيحْ أَطَّاسْ.
\v 8 \add خنِّي\add* إِڒَاغَا ونِّي ت إِژْرِينْ: ”\add أَ\add* سِيذِي إِنُو، ذڭْ وَاسّْ تّْبذِّيغْ بْڒَا قطُّو خْ وشْبَارْ ن ثْعسَّاسْثْ ؤُ كُوڒْ دْجِيڒثْ تّْعسّغْ. \x ◘ \xo 21:‏8 \xt حَاب. 2‏:‏1\x*
\v 9 خْزَارْ، ذِيهَا ؤُسِينْ-د إِرْيَازنْ نِّي إِنْيِينْ خْ ييْسَانْ، ثْيُويَا ن إِمْنَاينْ أَكْ-ذ ثْيُويَا نّغْنِي!“ \add عَاوذْ\add* إِطّفْ نتَّا ذڭْ وَاوَاڒْ، إِنَّا: ”ثوْضَا \add ثنْذِينْثْ ن\add* بَابِيلْ، ثوْضَا، ذ مَارَّا ڒخْيَاڒَاثْ إِنقْشنْ ن إِربِّيثنْ نّسْ إِڒْبزْ إِ-ثنْ خْ ثمُّورْثْ!“ \x ◘ \xo 21:‏9 \xt إِرْم. 25‏:‏12؛ 51‏:‏8؛ أَسَا. 14‏:‏8؛ 18‏:‏2 \x*
\v 10 \add أَ\add* أَسَارْوَاثْ إِنُو، \add أَ\add* مِّيسْ ن ؤُنذْرَارْ إِنُو! مِينْ سْڒِيغْ زِي سِيذِي ن ڒْعسْكَارَاثْ، أَربِّي ن إِسْرَائِيل، خبَّارغْ كنِّيوْ خَاسْ.
\b
\m 
\v 11 \bd ڒْْحُوكْمْ إِسَّاڭّْوَاذنْ خْ ذُومَا.\bd*
\m ”زِي سَاعِيرْ ڒَاغَانْ أَيِي-د: ’أَعسَّاسْ، مشْحَاڒْ \add عَاذْ\add* غَا ثكّْ دْجِيڒثْ؟ أَعسَّاسْ، مشْحَاڒْ \add عَاذْ\add* غَا ثكّْ دْجِيڒثْ؟‘
\v 12 إِنَّا ؤُعسَّاسْ: ’يُوسَا-د ؤُثفُّو ن ڒْحَاڒْ، ؤُڒَا ذ دْجِيڒثْ \add ثُوسَا-د\add*. مَاڒَا كنِّيوْ ثخْسمْ أَذْ ثسّقْسَامْ، سقْسَامْ! ذوْڒمْ-د، أَسمْ-د!‘ “
\b
\m 
\v 13 \bd ڒْْحُوكْمْ إِسَّاڭّْوَاذنْ ذِي ثْمذِّيثْ.\bd*
\m ”ذڭْ وزْغَارْ ذِي \add ثمُّورْثْ ن\add* وعْرَابنْ أَذْ ثسّنْسمْ، \add أَ كنِّيوْ\add*، إِكَارَابَاننْ ن أَيْثْ ن ذَاذَانْ! \f ◼ \fr 21:‏13 \ft \bd ’أَزْغَارْ‘\bd* - نِيغْ ’ڒْغَابثْ‘ نِيغْ ’ثَازْڭَانْثْ‘.\f*
\v 14 ؤُيُورمْ غَارْ وُومْسَاڭَارْ أَكْ-ذ ونِّي إِفُّوذنْ حِيمَا أَذْ أَسْ ثَاوْيمْ أَمَانْ! إِمزْذَاغْ ن ثمُّورْثْ ن ثَايْمَا فّْغنْ-د غَارْ ؤُمْسَاڭَارْ أَكْ-ذ ؤُمَارْوَاڒْ س وغْرُومْ.
\v 15 مَاغَارْ نِيثْنِي أَروْڒنْ زِي ڒسْيُوفْ، زِي سِّيفْ إِ د-إِتّْوَاجبْذنْ، زِي ڒْقوْسْ إِتّْوَامحْذنْ ؤُ زِي ڒغْبنْ ن ؤُمنْغِي.
\v 16 مَاغَارْ أَمُّو إِ ذ أَيِي إِنَّا سِيذِي إِنُو: ’عَاذْ ذڭْ إِجّْ ن ؤُسڭّْوَاسْ، عْلَاحْسَابْ إِسڭّْوُوسَا ن ؤُشوَّاڒْ، \add خنِّي\add* أَذْ إِقْضَا مَارَّا خْ ؤُعُودْجِي ن قِيذَارْ!
\v 17 ڒْقدّْ ن أَيْثْ ن بُو-ڒْقوْسْ إِقِّيمنْ، أَيْثْ ن بُو-ثغْڒُوذْطْ ن قِيذَارْ، أَذْ يِيڒِي ذْرُوسْ وَاهَا، مَاغَارْ سِيذِي، أَربِّي ن إِسْرَائِيل ذ ونِّي إِنَّانْ \add أَيَا\add*.‘ “
\b
\b
\c 22
\m 
\v 1 \bd ڒْْحُوكْمْ إِسَّاڭّْوَاذنْ خْ ثغْزُورْثْ ن ڒوْحِييْ.\bd*
\m ”مِينْ شمْ يُوغِينْ أَڒَامِي ثْڭعّْذذْ شمْ أَكْ-ذ مَارَّا \add إِوْذَانْ\add* خْ ثْزغْوِينْ؟
\v 2 \add أَ\add* شمْ، ثنِّي إِشُّورنْ س دّْرِيزْ، \add أَ شمْ\add* ثَانْذِينْثْ إِزْرُودّْحنْ، ثَانْذِينْثْ إِنڭّْزنْ س ڒفْرَاحثْ: إِنِّي ذَايمْ إِتّْوَانْغنْ، وَارْ تّْوَانْغنْ س سِّيفْ ؤُ وَارْ مّْثنْ ذڭْ ؤُمنْغِي.
\v 3 مَارَّا إِمْڭوَّاذنْ نّمْ مُوننْ أَروْڒنْ، \add مَاشَا\add* تّْوَاحبّْسنْ نْهْڒَا ؤُڒَا ذ إِشْثْ ن ثشْثِي ن ڒْقوْسْ، مَارَّا إِنِّي ذَايمْ ؤُفِينْ، تّْوَاشَارْفنْ، وَاخَّا أَروْڒنْ غَارْ ڒَاڭّْوَاجْ.“
\m 
\v 4 ”خْ ؤُيَا قَّارغْ: ’سَاڭّْوجمْ خَافِي ڒْخزْرَاثْ، أجّْ أَيِي أَذْ رُوغْ س إِمطَّاونْ إِمرْزَاڭنْ. وَارْ ذ أَيِي حصَّارمْ حِيمَا أَذْ أَيِي ثْعزَّامْ خْ وَاردّدْجْ ن يدْجِيسْ ن ڒْڭنْسْ إِنُو!‘ \x ◘ \xo 22:‏4 \xt إِرْم. 8‏:‏23\x*
\v 5 مَاغَارْ ذ إِجّْ ن وَاسّْ ن وزْرُودّحْ ذ ؤُعْفَاسْ ذ ؤُخَارْوضْ إِ د-إِسّكّْ سِيذِي إِنُو، سِيذِي ن ڒْعسْكَارَاثْ، ذِي ثغْزُورْثْ ن ڒوْحِييْ، \add إِجّْ ن وَاسّْ\add* ن وغْذَاڒْ نْ ڒْحِيضْ ؤُ ن إِغُويَّانْ إِ خْ د-تَّارَّانْ إِذُورَارْ.
\v 6 مَاغَارْ عِيلَامْ إِطّفْ أَقْرَابْ نّسْ س فْڒِيثْشَاثْ، \add جْمِيعْ\add* أَكْ-ذ ؤُكَارُّو ن ؤُمنْغِي ؤُ أَكْ-ذ أَرْيَازْ \add نِّي ث إِندّْهنْ\add* ذ يِينِّي إِنْيِينْ خْ ييْسَانْ، ؤُ قِيرْ إِعَارَّا ثَاسدَّارْثْ \add ن ؤُعسْكَارِي\add*. \f ◼ \fr 22:‏6 \ft \bd ’إِنِّي إِنّْيِينْ خْ إِيْسَانْ‘\bd* - نِيغْ ’إِمْنَاينْ‘.\f*
\v 7 أَذْ إِمْسَارْ أَقَا ڒمْخيّرْ ن ثيْسَارِينْ نّشْ أَذْ تّْوَاشُّورنْ س إِكَارُّوثنْ \add ن ؤُمنْغِي\add* ؤُ إِمْنَاينْ أَذْ سدّنْ إِخفْ نْسنْ \add إِ ؤُمنْغِي\add* \add أَرنْذَاذْ ن\add* ثوَّارْثْ \add ن ثنْذِينْثْ\add*. \f ◼ \fr 22:‏7 \ft \bd ’إِمْنَاينْ‘\bd* - نِيغْ ’إِنِّي إِنْيِينْ خْ ييْسَانْ‘.\f*
\v 8 أَذْ إِكّسْ نتَّا أَرُّوضْ خْ يَاهُوذَا. \bd ذڭْ وَاسّْ نِّي\bd* أَذْ ثخْزَارذْ غَارْ ڒسْنَاحْ \add إِ إِدْجَانْ\add* ذِي ثَادَّارْثْ ن وزْغَارْ. \f ◼ \fr 22:‏8 \ft \bd ’أَزْغَارْ‘\bd* - نِيغْ ’ڒْغَابثْ‘ نِيغْ ’ثَازْڭَانْثْ‘.\f*
\v 9 أَذْ ثْژَارمْ ثِيزّيِّينْ ذِي ثنْذِينْثْ ن ذَاوُوذْ، مِينْزِي أَقَا أَثنْثْ ذڭْ وَاطَّاسْ. أَذْ ثسّْمُونمْ أَمَانْ ن ؤُيڒْمَامْ ن وَادَّايْ.
\v 10 أَذْ ثْحسْبمْ ثُوذْرِينْ ن ؤُرْشَالِيمْ ؤُشَا أَذْ ثْهذْممْ ثُوذْرِينْ حِيمَا أَذْ ثسّْجهْذمْ ڒْحِيضْ.
\v 11 أَذْ ثڭّمْ إِجّْ ن ؤُيڒْمَامْ جَارْ ڒحْيُوضْ، حِيمَا أَذْ ثسّْمُونمْ أَمَانْ ن ؤُيڒْمَانْ أَقْذِيمْ، \add مَاشَا\add* وَارْ ثْخزَّارمْ غَارْ ونِّي ث إِڭِّينْ، ؤُ وَارْ ثْحطِّيمْ ونِّي ث إِصنّْعنْ زڭْ وشْحَاڒْ ؤُيَا.“
\m 
\v 12 ”\bd ذڭْ وَاسّْ نِّي\bd* أَذْ إِڒَاغَا سِيذِي إِنُو، سِيذِي نْ ڒْعسْكَارَاثْ، مَاحنْذْ أَذْ ثْرُومْ، أَذْ ثسْغُويمْ، أَذْ ثْحفّمْ أَزدْجِيفْ ؤُ مَاحنْذْ أَذْ ثْيَارْضمْ ثَاخَانْشثْ \add ن وشْضَانْ\add*.
\v 13 \add مَاشَا\add* خْزَارْ، \add ڒخُّو أَقَا ذِينْ\add* أَرْشَاقْ ذ ڒفْرَاحثْ، نقّنْ إِفُونَاسنْ، غَارْصنْ إِ وُودْجِي، تّتّنْ أَيْسُومْ ؤُ سسّنْ بِينُو، \add أَمْ قَّارنْ:\add* ’أجّْ أَنغْ أَذْ نشّْ، أَذْ نْسُو، مَاغَارْ ثِيوشَّا أَذْ نمّثْ!‘ \x ◘ \xo 22:‏13 \xt إِشا. 56‏:‏12؛ 1 كُور. 15‏:‏32\x*
\v 14 \add مَاشَا\add* سِيذِي ن ڒْعسْكَارَاثْ إِسَّارْڭبْ أَيِي \add خْ ؤُيَا\add* ذڭْ إِمزُّوغنْ إِنُو، \add إِنَّا:\add* ’ڒْمُوعْصِييّثْ-أَ وَارْ إِتّْوَاسّصْڒحْ إِ كنِّيوْ أَڒْ غَا ثمّْثمْ!‘، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، سِيذِي ن ڒْعسْكَارَاثْ.“
\b
\s1 أَوَاڒْ ن أَربِّي خْ شِيبْنَا ذ إِلْيَاقِيمْ
\m 
\v 15 ”أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي ن ڒْعسْكَارَاثْ: ’ؤُيُورْ، أَذفْ غَارْ ووْكِيڒْ نِّي، غَارْ شِيبْنَا، ڒمْقدّمْ ن ثْزذِّيغْثْ \add ن ؤُجدْجِيذْ\add*، \add ؤُشَا إِنِي\add*:
\v 16 مِينْ غَاركْ \add إِدْجَانْ\add* ذَانِيثَا، نِيغْ مَانْ ونْ غَاركْ \add إِدْجَانْ\add* ذَانِيثَا، أَقَا شكْ ثْنقْشذْ ذَا إِجّْ ن ونْضڒْ إِ يِيخفْ نّشْ؟ \add إِوَا\add* إِنقّشْ أَنْضڒْ نّسْ سنّجْ، إِنقّشْ إِ يِيخفْ نّسْ إِشْثْ ن ثْزذِّيغْثْ ذِي جَّارْفْ!
\v 17 خْزَارْ، سِيذِي أَذْ زَّايكْ إِحجَّارْ س إِجّْ ن ؤُحجَّارْ إِمْغَارْ، نتَّا أَذْ شكْ إِطّفْ س إِجّْ ن وُوضُوفْ إِقْسحْ.
\v 18 نتَّا أَذْ شكْ إِسّحْنُونّضْ قَاعْ أَڒَامِي \add ثْذوْڒذْ\add* ذ ثَاقُورَارْثْ، إِشْثْ ن ثْشَامَّا نِّي ت إِ غَا نْضَارنْ غَارْ إِشْثْ ن ثمُّورْثْ ثمْغَارْ. ذِينِّي إِ غَا ثمّْثذْ ؤُ ذِينِّي إِ غَا إِڒِينْ خنِّي إِكَارُّوثنْ نّشْ إِشُووَّارنْ، \add أَ شكْ\add* ڒفْضِيحثْ ن ثَادَّارْثْ ن بَابْ نّشْ!
\v 19 نشّْ أَذْ شكْ د-سُّوفّْغغْ زِي ڒْفُوسِينَا نّشْ، \add وَاهْ،\add* نتَّا أَذْ شكْ د-إِقْڒعْ زڭْ ومْشَانْ نّشْ.‘ “
\b
\m 
\v 20 ”\bd ذڭْ وَاسّْ نِّي\bd* أَذْ ڒَاغِيغْ إِ ؤُمْسخَّارْ إِنُو أَلْيَاقِيمْ، مِّيسْ ن حِيلْقِييَا. \x ◘ \xo 22:‏20 \xt 2 إِج. 18‏:‏18، 26، 37\x*
\v 21 نشّْ أَذْ أَسْ سّْيَارْضغْ أَرُّوضْ نّشْ ؤُ نشّْ أَذْ أَسْ بيْسغْ أَبْيَاسْ نّشْ ؤُ أَذْ وْشغْ ثِيزمَّارْ نّشْ ذڭْ ؤُفُوسْ نّسْ. نتَّا أَذْ يِيڒِي ذ بَابَاثْسنْ إِ إِمزْذَاغْ ن ؤُرْشَالِيمْ ذ ثَادَّارْثْ ن يَاهُوذَا.
\v 22 نشّْ أَذْ أَسْ سَّارْسغْ ڒْمفْثَاحْ ن ثَادَّارْثْ ن ذَاوُوذْ خْ ثغْرُوضْثْ نّسْ. \add مَاڒَا\add* نتَّا أَذْ يَارْزمْ، وَارْ إِزمَّارْ ؤُڒَا ذ إِجّْ أَذْ إِبلّعْ، \add مَاڒَا\add* نتَّا إِبلّعْ، وَارْ إِزمَّارْ ؤُڒَا ذ إِجّْ أَذْ يَارْزمْ. \x ◘ \xo 22:‏22 \xt أَسَا. 3‏:‏7 \x*
\v 23 نشّْ أَذْ ث وْثغْ أَمْ ڒوْثذْ ذڭْ إِجّْ ن ومْشَانْ إِمْثنْ ؤُ نتَّا أَذْ يِيڒِي ذ ڒْعَارْشْ ن ؤُعُودْجِي إِ ثَادَّارْثْ ن بَابَاسْ.
\v 24 أَذْ خَاسْ أَيْڒنْ مَارَّا أَعُودْجِي ن ثَادَّارْثْ ن بَابَاسْ، إِغدُّوينْ إِمژْيَانِينْ ذ ثْغدُّوثِينْ، زِي مَارَّا ثِيقْشُوعِينْ ثِيمژْيَانِينْ، زِي طّْبَاصِي أَڒْ مَارَّا ثِيقْنُوشِينْ.
\v 25 \bd ذڭْ وَاسّْ نِّي\bd* أَذْ إِتّْوَاكّسْ ڒوْثذْ إِ إِتّْوَاوْثنْ ذڭْ ومْشَانْ إِمثْننْ، إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ. أَذْ إِتّْوَاقْضعْ ؤُ \add خنِّي\add* أَذْ إِوْضَا ؤُشَا دّْقڒْ إِ ثُوغَا غَارسْ يُويْڒنْ، أَذْ إِتّْوَاقسّْ، مَاغَارْ \add أَمُّو إِ\add* إِنَّا سِيذِي.“
\b
\b
\c 23
\m 
\v 1 \bd ڒْحُوكْمْ إِسَّاڭّْوَاذنْ خْ صُورْ.\bd*
\m ” ’رُومْ، \add أَ\add* إِغَارُّوبَا ن ثَارْشِيشْ، مَاغَارْ ثهْذمْ \add ثنْذِينْثْ ن صُورْ\add* ؤُمِي وَارْ ثقِّيمْ ثَادَّارْثْ ؤُڒَا ذ ڒْمُويِّي.‘ وَاهْ، \add أَمُّو إِ\add* ذ أَسنْ إِتّْوَاسَّارْڭبْ زِي ثمُّورْثْ ن أَيْثْ ن كِيتِّيمْ. \x ◘ \xo 23:‏1 \xt إِرْم. 47‏:‏4؛ حِز. 26؛ 27؛ 28؛ زَاك. 9‏:‏3، 4\x*
\v 2 ’سُوسْممْ، \add أَ كنِّيوْ\add* إِمزْذَاغْ ن ثڭْزِيرْثْ! إِسبَّابنْ ن صِيذُونْ إِنِّي إِژكّْوَانْ ڒبْحَارْ \add س إِغَارُّوبَا نْسنْ\add*، أَقَا شُّورنْ شمْ \add س سّڒْعثْ\add*!‘
\v 3 زَّارِيعثْ ن سِيخُورْ، صَّابثْ ن إِغْزَارْ \add ن نِيلْ\add*، ثذْوڒْ ذ ڒْمُونثْ نّسْ. \add أَمُّو إِ\add* ثذْوڒْ \add ثنْذِينْثْ ن صُورْ\add* ذ ڒْمَارْسِي ن ڒڭْنُوسْ.“
\m 
\v 4 ” ’سضْحَا، \add أَ شمْ\add* صِيذُونْ!‘ مَاغَارْ ڒبْحَارْ إِقَّارْ، لْبُورْجْ ن ڒبْحَارْ إِقَّارْ: ’وَارْ ذَايِي ثُوغِي ڒوْجعْ ن ثَارُوثْ ؤُ نشّْ وَارْ ؤُرِيوغْ. نشّْ وَارْ سّْغِيمِيغْ إِحُوذْرِييّنْ ؤُ وَارْ أَربِّيغْ ثِيعْزُورَايْ.‘
\v 5 خْمِي غَا يَاوضْ ڒخْبَارْ غَارْ مِيصْرَا، \add خنِّي\add* أَذْ نزْبَارنْ نِيثْنِي س ڒحْرِيقْ خْمِي غَا سْڒنْ إِ ڒخْبَارْ خْ صُورْ.“
\m 
\v 6 ” ’ژْوَامْ غَارْ ثَارْشِيشْ، سْغُويّمْ، \add كنِّيوْ\add* إِمزْذَاغْ ن ثڭْزِيرْثْ!‘
\v 7 مَا وَا \add ذ أَشْثَابْ\add* نْومْ، \add أَ\add* \add ثَانْذِينْثْ\add* إِنڭّْزنْ س ڒفْرَاحثْ، ثنِّي زِي لْ-أَصلْ نّسْ \add إِدْجَانْ\add* زڭْ وُوسَّانْ ن وشْحَاڒْ ؤُيَا؟ إِصُورَافْ نّسْ أَذْ ت أَرْبُونْ غَارْ ڒَاڭّْوَاجْ حِيمَا أَذْ \add ذِينْ\add* ثقِّيمْ أَمْ ثْبَارَّانشْثْ.
\v 8 وِي إِخَارّْصنْ مَانْ أَيَا ذِي ڒْبَاڒْ نّسْ ضِيدّْ إِ صُورْ، \add ثَانْذِينْثْ\add* نِّي إِبطَّانْ تِّيجَانْ، أَقَا زعْمَا إِسبَّابنْ \add نّسْ\add* ذ ڒْحُوكَّامْ، إِتِّيجَارِييّنْ \add نّسْ\add* ذ إِمْشنّْعنْ ن ثمُّورْثْ؟
\v 9 سِيذِي ن ڒْعسْكَارَاثْ أَقَا غَارسْ ذِي ڒْبَاڒْ نّسْ حِيمَا أَذْ إِسّْعِيدْجثْ نّْفَاخثْ ن مَارَّا \add مِينْ إِدْجَانْ ذ\add* ثَالْوِيزْثْ، حِيمَا أَذْ يَارْژْ ڒْعزّْ ن مَارَّا إِمْشنّْعنْ ن ثمُّورْثْ.“
\m 
\v 10 ” ’سسْفِييْ ثَامُّورْثْ نّمْ أَمْ يغْزَارْ \add ن نِيلْ\add*، \add أَ شمْ\add* يدْجِيسْ ن ثَارْشِيشْ! وَارْ شمْ ثْمنّعْ ؤُڒَا ذ إِشْثْ ن ڒْحَاجّثْ عَاذْ!‘
\v 11 نتَّا إِسّْوِيژّضْ أَفُوسْ نّسْ خْ ڒبْحَارْ، نتَّا إِسّنْهزّْ ثِيڭلْذِيوِينْ. سِيذِي يُومُورْ ضِيدّْ إِ كنْعَانْ مَاحنْذْ أَذْ أَردّْدْجنْ لْبُورْجَاثْ نّسْ.
\v 12 نتَّا إِنَّا: ’عمَّارْصْ عَاذْ أَذْ ثِيڒِيذْ ثْفَارْحذْ، ثتّْوَاسّْعِيدْجْثذْ، \add أَ\add* ثَاعْزَارشْثْ، يدْجِيسْ ن صِيذُونْ! \add رُوحْ\add* غَارْ أَيْثْ ن كِيتِّيمْ، كَّارْ، ژْوَا. ؤُڒَا ذِينِّي وَارْ ثطِّيفذْ ڒهْنَا.‘ \f ◼ \fr 23:‏12 \ft \bd ’كِيتِّيمْ‘\bd* - إِخْسْ أَذْ يِينِي ’قُوبْرُوسْ‘.\f*
\v 13 خْزَارْ، ثَامُّورْثْ ن إِكَالْذَانِييّنْ، ڒْڭنْسْ-أَ إِ ثُوغَا وَارْ إِدْجِينْ، أَقَا إِنيّشْ أَشُّورْ \add ذ ثَامُّورْثْ\add* إِ ڒوْحُوشْ ن ڒخْڒَا - \add مَاغَارْ\add* نِيثْنِي سّْڭعّْذنْ لْبُورْجَاثْ نْسنْ إِ وهْجَامْ، سّْعَارَّانْ ڒقْصُورْ نّسْ - أَقَا ڒْڭنْسْ-أَ يَارَّا إِ-ت ذ ڒْخِيرْبثْ. \f ◼ \fr 23:‏13 \ft \bd أَفسَّارْ\bd* - أَيثْ-أَ ثسِّيوڒْ خْ إِكَالْذَانِييّنْ، خْ مَامّشْ غڒْبنْ ذ أَمزْوَارْ خْ إِمْبرَاثُورِييَا ن أَشُّورْ (إِخْسْ أَذْ يِينِي ثَانْذِينْثْ ن نِينْوَا) ؤُ خنِّي ؤُذْفنْ غَارْ ثمُّورْثْ ن إِفِينِيكِييّنْ (قَّارنْ أَسْ ڒخُّو لُوبْنَانْ) ؤُشَا هذْمنْ لْپُورْجْ نِّي إِدْجَانْ خْ ثڭْزِيرْثْ ن ثنْذِينْثْ ن صُورْ، ذِي ڒْوسْثْ ن ڒبْحَارْ، يُوذسْ-د غَارْ ثنْذِينْثْ ن صُورْ خْ ڒْبَارْ. ثُوغَا أَشُّورْ وَارْ إِزمَّارْ أَذْ إِطّفْ لْپُورْجْ-أَ ن إِفِينِيكِييّنْ، مَاشَا إِكَالْذَانِييّنْ هجْمنْ خَاسْ ڒْمِيجَاڒْ ن 13 ن إِسڭّْوُوسَا، خنِّي فڒْحنْ مَاشَا وَارْ غَارْسنْ ؤُفِينْ بُو ثْكشَّاضْثْ مِينْزِي مَارَّا إِمزْذَاغْ ن ثڭْزِيرْثْ فّْغنْ خْ ڒبْحَارْ غَارْ ڒڭْنُوسْ نِّي وِيكْ-ذ ڭِّينْ ثَاسبَّابْثْ نْسنْ.\f*
\v 14 رُومْ، \add كنِّيوْ\add* إِغَارُّوبَا ن ثَارْشِيشْ، مَاغَارْ لْبُورْجْ نْومْ إِتّْوَاهْذمْ.“
\m 
\v 15 ”\bd ذڭْ وَاسّْ نِّي\bd* أَذْ إِمْسَارْ، أَقَا صُورْ أَذْ ثتّْوَاتُّو \add ڒْْقدّْ ن\add* سبْعِينْ ن إِسڭّْوُوسَا، أَمْ \add ڒْْقدّْ ن\add* وُوسَّانْ ن إِجّْ ن ؤُجدْجِيذْ. غَارْ ؤُنڭَّارْ ن سبْعِينْ ن إِسڭّْوُوسَا \add نِّي\add* أَذْ إِمْسَارْ إِ صُورْ أَمْ مَامّشْ ذ أَسْ قَّارنْ ذڭْ إِزْڒِي ن ثمْغَارْثْ ن فَارْقْ-شّْغڒْ:
\v 16 ’كْسِي ڒْڭَامْبْرِي، ؤُيُورْ ؤُشَا نّضْ ذِي ثنْذِينْثْ، \add أَ شمْ،\add* ثَامْغَارْثْ ن فَارْقْ-شّْغڒْ إِتّْوَاتُّونْ! إِرَارْ إِجّْ ن دْجْغَا مْلِيحْ ؤُشَاغنّجْ أَطَّاسْ، مَاحنْذْ أَذْ خَامْعقْڒنْ!‘
\v 17 أَوَارْنِي سبْعِينْ ن إِسڭّْوُوسَا سِيذِي أَذْ يَارْزفْ صُورْ \add عَاوذْ\add* ؤُشَا نتَّاثْ أَذْ د-ثذْوڒْ غَارْ ڒْمُونثْ نّسْ ن فَارْقْ-شّْغڒْ ؤُشَا أَذْ ثسّفْسذْ إِخفْ نّسْ س مَارَّا ثِيڭلْذَاوِينْ ن دُّونشْثْ نِّي إِدْجَانْ خْ وُوذمْ ن ثمُّورْثْ.
\v 18 \add مَاشَا\add* ثَاسبَّابْثْ نّسْ ذ ڒْمُونثْ نّسْ ن فَارْقْ-شّْغڒْ أَذْ إِڒِينْثْ قدّْسنْثْ إِ سِيذِي. وَارْ ثتّْوَاخمّڒْ \add ذڭْ إِخَّامنْ ن ثْخُوبَايْ\add* ؤُ وَارْ ثتّْوَاخزّنْ، مَاغَارْ سّڒْعثْ نّسْ أَذْ ثِيڒِي إِ يِينِّي إِزدّْغنْ زَّاثْ إِ وُوذمْ ن سِيذِي، حِيمَا أَذْ شّنْ أَڒْ إِ غَا جِّيوْننْ ؤُشَا حِيمَا أَذْ يَارْضنْ أَرُّوضْ إِشُووَّارنْ.“
\b
\b
\c 24
\s1 رْحُوكْمْ خْ دُّونشْثْ
\m 
\v 1 ”خْزَارْ، سِيذِي أَذْ إِسّخْوَا ثَامُّورْثْ، أَذْ ت إِسّْخَارّبْ، أَذْ إِقدْجبْ ؤُذمْ نّسْ ؤُشَا أَذْ إِبزّعْ إِمزْذَاغْ نّسْ.
\v 2 أَمْ مَامّشْ إِدْجَا ڒْڭنْسْ، أَمُّو \add إِ غَا يِيڒِي\add* ؤُڒَا ذ أَكهَّانْ، أَمْ ؤُمْسخَّارْ ؤُڒَا ذ سِيذِي نّسْ، أَمْ ثَايَّا ؤُڒَا ذ لَّالَاسْ، أَمْ ؤُمْسوّقْ ؤُڒَا ذ أَمْزنْزِي، أَمْ أَرطَّاڒْ ؤُڒَا ذ ونِّي \add زَّايسْ\add* إِكْسِينْ أَرْضَاڒْ، أَمْ بَابْ ن ؤُمَارْوَاسْ ؤُڒَا ذ بُو-ؤُمَارْوَاسْ نّسْ. \x ◘ \xo 24:‏2 \xt حِز. 7‏:‏12، 13\x*
\v 3 أَذْ سّخْوَانْ ثَامُّورْثْ مَارَّا، أَذْ \add ت\add* كشّْضنْ قَاعْ، مَاغَارْ سِيذِي إِنَّا أَوَاڒْ-أَ!“
\m 
\v 4 ”ثَامُّورْثْ ثشْضنْ، ثِيسْڒَاوْ، دُّونشْثْ ثفْثُوتّسْ، ثِيسْڒَاوْ. إِمْشنّْعنْ نْ ڒْڭنْسْ ن ثمُّورْثْ ثفْثُوتُّوسنْ.
\v 5 ثَامُّورْثْ ثتّْوَاسّْعِيدْجثْ زڭْ إِمزْذَاغْ نّسْ، مَاغَارْ نِيثْنِي تّْعدَّانْ خْ إِزرْفَانْ، تّْبدَّاڒنْ ثِيوصَّا، تَّارژَّانْ ڒْعَاهْذْ ن ڒبْذَا.
\v 6 خْ ؤُيَا ثتّتّْ نّعْڒثْ ثَامُّورْثْ ؤُ يِينِّي خَاسْ إِزدّْغنْ أَقَا ذَايْسنْ ڒْعِيبْ. س ؤُينِّي أَذْ تّْوَاسّْشمْضنْ إِمزْذَاغْ ن ثمُّورْثْ، أَذْ شطّنْ ذْرُوسْ ن إِوْذَانْ وَاهَا.“ \x ◘ \xo 24:‏6 \xt إِشا. 9‏:‏18؛ 10‏:‏16\x*
\m 
\v 7 ”بِينُو ن جْذِيذْ إِشْضنْ، ثَازَايَارْثْ ثفْثُوتّسْ، مَارَّا إِنِّي ثُوغَا إِفَارْحنْ ذڭْ وُوڒْ، زهَّارنْ.
\v 8 صَافِي ثِيشْثِي إِسّْفَارَّاحنْ ن إِبنْذِيرنْ، دّْرِيزْ ن يِينِّي إِنڭّْزنْ س ڒفْرَاحثْ، صَافِي \add ثِينخْثْ\add* إِسّْفَارَّاحنْ ن ڒْڭَامْبْرِي. \x ◘ \xo 24:‏8 \xt إِرْم. 7‏:‏34؛ 16‏:‏9؛ 25‏:‏10؛ حِز. 26‏:‏13؛ حُوش. 2‏:‏13\x*
\v 9 وَارْ سسّنْ بِينُو \add عَاذْ\add* ذِي ڒْوقْثْ ن ؤُغنّجْ، شّْرَابْ أَذْ يِيڒِي ذ أَمرْزَاڭْ إِ يِينِّي \add ث\add* إِسسّنْ. \x ◘ \xo 24:‏9 \xt إِشا. 16‏:‏1\x*
\v 10 ثَانْذِينْثْ إِتّْوَاجّنْ ذ ڒْخَارْبثْ، مَارَّا ثُوذْرِينْ بلّْعنْثْ إِ وَاذَافْ.
\v 11 ذڭْ إِمسْرَاقْ تّْوعّْضنْ إِوْذَانْ خْ بِينُو، مَارَّا ڒفْرَاحثْ ثْودَّارْ، أَسْڒِيوْڒوْ إِفّغْ زِي ثَامُّورْثْ.
\v 12 مِينْ إِقِّيمنْ ن ثنْذِينْثْ ذ ڒْخِيرْبثْ إِسَّاڭّْوَاذنْ \add وَاهَا\add*، ؤُ ثَاوَّارْثْ ثتّْوَاڒْبزْ.
\v 13 أَمُّو إِ غَا ثِيڒِي \add ثنْذِينْثْ\add* ذِينْ ذِي ڒْوسْثْ ن ثمُّورْثْ، جَارْ ڒڭْنُوسْ. أَذْ ثِيڒِي أَمْ غَارْ وزْوَاضْ ن ؤُزمُّورْ، أَمْ غَارْ وڒْقَاضْ \add ن ؤُضِيڒْ\add* خْمِي غَا ثعْذُو صَّابثْ.“ \x ◘ \xo 24:‏13 \xt إِشا. 17‏:‏6\x*
\b
\m 
\v 14 ”نِيثْنِي أَذْ سّْڭعّْذنْ ثْمِيجَّا نْسنْ، أَذْ سْڒِيوْڒونْ. ؤُمِي سِيذِي إِعُودْجنْ أَطَّاسْ، أَذْ سّْغُوينْ نِيثْنِي س ڒفْرَاحثْ زِي مَانِي ثْغدْجِي ثْفُوشْثْ.
\v 15 خْ ؤُيَا، سْعُودْجمْ خنِّي سِيذِي ذِي ثمُّورَا ن ثْفَاوْثْ، \add سْعُودْجمْ\add* إِسمْ ن سِيذِي، أَربِّي ن إِسْرَائِيل، ذِي ثڭْزِيرِينْ نْ ڒبْحَارْ! \f ◼ \fr 24:‏15 \ft \bd ’ثِيمُّورَا ن ثْفَاوْثْ‘\bd* - إِخْسْ أَذْ يِينِي ثِيمُّورَا غَارْ شَّارْقْ ن إِسْرَائِيل مَانِيسْ د-ثتّْنقَّارْ ثْفُوشْثْ. \bd ’ثِيمُّورَا خْ ثْمَا ن ڒبْحَارْ‘\bd* - إِخْسْ أَذْ يِينِي ثِيمُّورَا غَارْ ڒْغَارْبْ ن ثمُّورْثْ ن إِسْرَائِيل، ثِينِّي إِدْجَانْ خْ ثْمَا ن ڒبْحَارْ أَشمْڒَاڒْ (نِيغْ ڒبْحَارْ أَمقّْرَانْ).\f*
\v 16 زِي ثْمُووَّا قَاعْ ن ثمُّورْثْ نتّسْڒَا إِ إِزْڒَانْ، إِ ؤُعُودْجِي ن ؤُمْسڭّذْ!“
\b
\m \add خنِّي\add* نِّيغْ: نشّْ فنِّيغْ، فنِّيغْ، ؤُشْثْ خَافِي! إِمْكشَّاضنْ تّْكشَّاضنْ، ؤُ إِمْكشَّاضنْ تّْكشَّاضنْ مِينْ مَا \add خْسنْ\add* أَذْ كشّْضنْ.
\v 17 ثِيڭّْوُوذِي ذ ثسْرَافْثْ ذ ڒْفخْ \add أَذْ\add* خَاكْ \add إِڒِينْ\add*، \add أَ\add* أَمزْذُوغْ ن ثمُّورْثْ! \x ◘ \xo 24:‏17 \xt إِرْم. 48‏:‏43\x*
\v 18 ونِّي إِ غَا يَاروْڒنْ زِي دّْرِيزْ إِسَّاڭّْوَاذنْ، أَذْ إِوْضَا ذِي ثسْرَافْثْ، ذ ونِّي إِ غَا إِڭعّْذنْ زِي ثسْرَافْثْ، أَذْ إِنَّاغْ ذِي ڒْفخْ، مَاغَارْ ثِيبُورْجَاثِينْ ذِي ڒُوعْڒَا أَذْ نُّورْزْمنْثْ، ذْسُوسَا ن ثمُّورْثْ أَذْ نْهزّنْ. \x ◘ \xo 24:‏18 \xt إِرْم. 48‏:‏44؛ عَام. 5‏:‏19\x*
\v 19 ثَامُّورْثْ أَذْ ثْشَارّڭْ قَاعْ، أَذْ ثْفدْجقْ ثمُّورْثْ ذ إِفدْجَاقنْ، أَذْ ثنْهزّْ ثمُّورْثْ أَطَّاسْ.
\v 20 أَذْ ثْميّڒْ ثمُّورْثْ سَّا غَارْ ذَا أَمْ يِيجّنْ إِسْشَارْ، أَذْ ثمْرَايْوَا أَمْ يِيجّْ ن ؤُعْشُوشْ إِ ثْمنْسِيوْثْ. إِعذِّيينْ نّسْ أَذْ خَاسْ زِييَّارنْ أَطَّاسْ، ؤُشَا نتَّاثْ أَذْ ثوْضَا، وَارْ ثْزمَّارْ أَذْ ثكَّارْ عَاذْ.“ \x ◘ \xo 24:‏20 \xt أَيُوبْ 27‏:‏18؛ إِشا. 1‏:‏8؛ 19‏:‏14\x*
\m 
\v 21 ”\bd ذڭْ وَاسّْ نِّي\bd* أَذْ إِخْڒفْ سِيذِي خْ ڒْعسْكَارْ ن ڒُوعْڒَا ذِي ڒُوعْڒَا، ؤُڒَا خْ إِجدْجِيذنْ نِّي \add إِدْجَانْ\add* خْ وُوذمْ ن ثمُّورْثْ \add أَذْ زَّايْسنْ إِخْڒفْ\add* خْ وُوذمْ ن ثمُّورْثْ.
\v 22 أَذْ تّْوَاسّْمُوننْ أَمْ يِيمحْبَاسْ ذڭْ إِشْثْ ن ثسْرَافْثْ ؤُ أَذْ تّْوَاحبْذْسنْ ذِي ڒحْبسْ ؤُ أَوَارْنِي إِ وَاطَّاسْ ن وُوسَّانْ أَذْ غَارْسنْ أَرْزْفنْ.
\v 23 ثَازِيرِي أَذْ ثزْوغْ س ؤُسضْحِي ؤُ ثَافُوشْثْ ثْسضْحَا خْمِي غَا يِيڒِي سِيذِي ن ڒْعسْكَارَاثْ ذ أَجدْجِيذْ خْ وذْرَارْ ن صِيهْيُونْ ؤُ ذِي ؤُرْشَالِيمْ، ؤُشَا زَّاثْ إِ إِمْغَارنْ نّسْ \add أَذْ ذِينِّي يِيڒِي\add* ؤُعُودْجِي.“ \x ◘ \xo 24:‏23 \xt إِشا. 13‏:‏10؛ حِز. 32‏:‏7؛ يُووِ. 3‏:‏4؛ 3‏:‏20\x*
\b
\b
\c 25
\s1 إِزْڒِي ن ؤُقَاذِي خْ ؤُسنْجمْ
\m 
\v 1 \qt ”\tl أَ\tl* سِيذِي، شكْ ذ أَربِّي إِنُو،\qt*
\m \qt نشّْ أَذْ شكْ سّْعُودْجغْ،\qt*
\m \qt أَذْ صبّْحغْ إِسمْ نّشْ،\qt*
\m \qt مَاغَارْ شكْ ثڭِّيذْ ڒعْجبْ،\qt*
\m \qt أَطَّاسْ ن شّْوَارْ نّشْ\qt*
\m \qt زڭْ وشْحَاڒْ ؤُيَا،\qt*
\m \qt أَقَا-ث ذ ثِيذتّْ ؤُ ذَايسْ ڒَامَانْ.\qt*
\m 
\v 2 \qt شكْ ثَارِّيذْ ثَانْذِينْثْ ذ أَعُورِّيشْ ن يژْرَا،\qt*
\m \qt ثَانْذِينْثْ إِتّْوَاسّْجهْذنْ ذ ڒْخِيرْبثْ،\qt*
\m \qt ڒقْصَارْ ن إِبَارَّانِييّنْ ذِي ثَانْذِينْثْ،\qt*
\m \qt وَارْ ث سّْبذِّينْعمَّارْصْ عَاوذْ.\qt* \x ◘ \xo 25:‏2 \xt إِشا. 21‏:‏9؛ 23‏:‏13؛ أَسَا. 14‏:‏8؛ 18‏:‏2\x*
\m 
\v 3 \qt خْ ؤُيَا أَذْ شكْ إِسّْعُودْجْ إِجّْ ن ڒْڭنْسْ إِجْهذْ،\qt*
\m \qt ثَانْذِينْثْ ن ڒڭْنُوسْ إِقسْحنْ أَطَّاسْ\qt*
\m \qt أَذْ زَّايكْ ثڭّْوذْ.\qt*
\m 
\v 4 \qt مَاغَارْ ثُوغَا شكْ ذ لْقلْعَا إِ ؤُمَارْخُو،\qt*
\m \qt ذ لْقلْعَا إِ ؤُمزْڒُوضْ\qt*
\m \qt خْمِي إِتّْنحْصَارْ،\qt*
\m \qt \tl شكْ\tl* ذ أَذُورِّي إِ ونْژَارْ إِشَّاثنْ،\qt*
\m \qt ؤُڒَا ذ ثِيڒِي ذِي ڒحْمُو\qt*
\m \qt مِينْزِي لْحَارَاجْ ن أَيْثْ ن بُو-ڒخْشُونشْثْ\qt*
\m \qt أَقَا-ث أَمْ ونْژَارْ إِشَّاثنْ خْ ڒْحِيضْ.\qt*
\m 
\v 5 \qt أَمْ ڒحْمُو ذڭْ إِجّْ ن ومْشَانْ يُوژغْ،\qt*
\m \qt \tl أَمُّو\tl* إِ غَا ثسّغْذذْ لْحَارَاجْ ن إِبَارَّانِييّنْ،\qt*
\m \qt أَمْ ثِيڒِي ن ؤُسيْنُو ثسّسْمِيضْ ڒهْمُو،\qt*
\m \qt \tl أَمُّو\tl* إِ غَا إِتّْوَاسّغْذْ\qt*
\m \qt إِزْڒِي ن أَيْثْ ن بُو-ڒخْشُونشْثْ.“\qt*
\b
\m 
\v 6 \qt ”سِيذِي ن ڒْعسْكَارَاثْ أَذْ إِسّوْجذْ خْ وذْرَارْ-أَ\qt*
\m \qt إِشْثْ ن زَّارْذثْ س مَاشَّا\qt*
\m \qt ثشُّورْ س ثَاذُونْثْ خْ وذْرَارْ-أَ\qt*
\m \qt إِ مَارَّا رڭْنُوسْ،\qt*
\m \qt إِشْثْ ن زَّارْذثْ س بِينُو إِصبْحنْ قَاعْ،\qt*
\m \qt س إِشْثْ ن مَاشَّا ثشُّورْ س ثَاذُونْثْ ذ وَاذُوفْ،\qt*
\m \qt س بِينُو إِصبْحنْ إِصْفَانْ.\qt*
\m 
\v 7 \qt نتَّا أَذْ إِبطّڒْ خْ وذْرَارْ-أَ أَڒحَّافْ\qt*
\m \qt إِ زِي تّْڒحَّافنْ مَارَّا ڒڭْنُوسْ\qt*
\m \qt ؤُڒَا ذ دُّورِي إِ زِي تّْوَاسّْذُورُّوينْ مَارَّا ڒڭْنُوسْ.\qt*
\m 
\v 8 \qt نتَّا أَذْ إِسَارْضْ ڒْموْثْ إِ ڒبْذَا\qt*
\m \qt ؤُشَا سِيذِي إِنُو، سِيذِي،\qt*
\m \qt أَذْ إِمْسحْ إِمطَّاونْ زِي مَارَّا إِغمْبَابْ،\qt*
\m \qt أَذْ إِكّسْ ڒفْضِيحثْ ن ڒْڭنْسْ نّسْ\qt*
\m \qt زِي مَارَّا ثَامُّورْثْ،\qt*
\m \qt مَاغَارْ \tl أَمُّو إِ\tl* إِنَّا سِيذِي.“\qt* \x ◘ \xo 25:‏8 \xt 1 كُور. 15‏:‏54\x*
\b
\m 
\v 9 \bdit ”ذڭْ وَاسّْ نِّي\bdit* \qt أَذْ إِنِينْ:\qt*
\m \qt ’أَقَا ذَا، وَا ذ أَربِّي نّغْ،\qt*
\m \qt خَاسْ إِ نڭَّا أَسِيثمْ نّغْ\qt*
\m \qt ؤُ نتَّا أَذْ أَنغْ إِسّنْجمْ.\qt*
\m \qt وَا ذ سِيذِي نِّي خْ نڭَّا أَسِيثمْ نّغْ،\qt*
\m \qt أَذْ نسْڒِيوْڒوْ، أَذْ نْفَارْحْ\qt*
\m \qt خْ ؤُسنْجمْ نّسْ!‘\qt*
\m 
\v 10 \qt مَاغَارْ أَفُوسْ ن سِيذِي أَذْ يَارْسْ خْ وذْرَارْ-أَ،\qt*
\m \qt \tl مَاشَا\tl* مُوآبَ أَذْ إِتّْوَادّزْ ذِي \tl ثمُّورْثْ\tl* نّسْ،\qt*
\m \qt أَمْ مَامّشْ إِتّْوَادّزْ ؤُڒُومْ،\qt*
\m \qt أَذْ إِذْوڒْ ذ ثَازُوبَاشْثْ.\qt*
\m 
\v 11 \qt \tl مُوآبَ\tl* أَذْ ذَايسْ إِبزّعْ س إِفَاسّنْ نّسْ،\qt*
\m \qt أَمْ ؤُفتَّاحْ ذڭْ وفْثَاحْ.\qt*
\m \qt \tl أَربِّي\tl* أَذْ إِسَّاضَارْ نّْفَاخثْ نّسْ\qt*
\m \qt \tl جْمِيعْ\tl* أَكْ-ذ مَارَّا\qt*
\m \qt مِينْ إِزمَّارْ أَذْ إِڭّْ\qt*
\m \qt س ثحْرَايْمشْثْ ن إِفَاسّنْ نّسْ.\qt* \x ◘ \xo 25:‏11 \xt إِشا. 16‏:‏6\x*
\m 
\v 12 \qt نتَّا أَذْ إِهْذمْ لْبُورْجْ ن إِغبْڒَاونْ نّشْ يُوعْڒَانْ،\qt*
\m \qt أَذْ \tl ثنْ\tl* إِسّهْوَا، أَذْ \tl ثنْ\tl* إِمّنْضَارْ\qt*
\m \qt غَارْ ثمُّورْثْ، ذڭْ ؤُشَاڒْ.“\qt*
\b
\b
\c 26
\s1 إِزْڒِي ن ثمُّورْثْ ن يَاهُوذَا
\m 
\v 1 \bd ذڭْ وَاسّْ نِّي\bd* أَذْغنّْجنْ إِزْڒِي-يَا
\m ذِي ثمُّورْثْ ن يَاهُوذَا:
\b
\m \qt ”نشِّينْ غَارْنغْ إِشْثْ ن ثنْذِينْثْ إِجهْذنْ،\qt*
\m \qt نتَّا إِسّْبدّْ ’أَسنْجمْ‘\qt*
\m \qt ذْ ڒحْيُوضْ ذ ڒقْوَارَاثْ.\qt* \x ◘ \xo 26:‏1 \xt إِزهد. 46‏:‏6؛ 125‏:‏1؛ أَوڒن. 18‏:‏10\x*
\m 
\v 2 \qt أَرْزْممْ ثِيوُّورَا،\qt*
\m \qt مَاحنْذْ ڒْڭنْسْ أَمْسڭّذْ أَذْ د-يَاذفْ،\qt*
\m \qt \tl ڒْڭنْسْ\tl* نِّي إِحطَّانْ\qt*
\m \qt ڒَْامَانْ \tl إِ سِيذِي\tl* ڒبْذَا.\qt*
\m 
\v 3 \qt س ڒْبَاڒْ إِمْثنْ \tl أَمْ ث إِدْجَا\tl*،\qt*
\m \qt شكْ ثْحطِّيذْ \tl ث ذِي\tl* ڒهْنَا،\qt*
\m \qt \tl وَاهْ ذِي\tl* ڒهْنَا،\qt*
\m \qt مَاغَارْ \tl ڒْڭنْسْ\tl* إِتّْشَاڒَا خَاكْ.“\qt*
\b
\m 
\v 4 \qt ”ثشْڒمْ خْ سِيذِي إِ ڒبْذَا،\qt*
\m \qt مَاغَارْ ذِي سِيذِي، سِيذِي،\qt*
\m \qt إِ ثدْجَا ذ ثَاصْضَارْثْ ن زّْمَانَاثْ.\qt*
\m 
\v 5 \qt مَاغَارْ نتَّا إِتَّارَّا أَذْ أَضَارنْ\qt*
\m \qt إِنِّي إِزدّْغنْ ذِينِّي ذِي ڒُوعْڒَا،\qt*
\m \qt ثَانْذِينْثْ يُوعْڒَانْ أَذْ ت إِسّهْوَا،\qt*
\m \qt أَذْ ت إِسّهْوَا أَڒْ ثَامُّورْثْ،\qt*
\m \qt أَذْ ت إِعَارْنْ ذڭْ ؤُشَاڒْ.\qt*
\m 
\v 6 \qt أَذْ خَاسْ إِعْفسْ ؤُضَارْ،\qt*
\m \qt إِضَارنْ ن ونِّي إِتّْوَاحْصَارنْ،\qt*
\m \qt ڒَْاثَارَاثْ ن إِضَارنْ ن إِمزْڒَاضْ.“\qt*
\b
\m 
\v 7 \qt ”أَبْرِيذْ ن ؤُمْسڭّذْ إِوَاطَا،\qt*
\m \qt نِيشَانْ إِ إِدْجَا ڒَاثَارْ ن ؤُمْسڭّذْ،\qt*
\m \qt شكْ ثتّْسڭَّامذْ ث.\qt*
\m 
\v 8 \qt ؤُڒَا ذڭْ وبْرِيذْ ن ڒحْكَامَاثْ نّشْ،\qt*
\m \qt \tl أَ\tl* \tl سِيذِي\tl*، ثُوغَا نسِّيثِيمْ أَشْ،\qt*
\m \qt ڒعْمَارْ \tl نّغْ\tl* إِمّژْرِي\qt*
\m \qt ذڭْ يِيسمْ نّشْ ؤُ ذِي ڒِيذَارثْ نّشْ.\qt*
\m 
\v 9 \qt ثُوغَا ڒعْمَارْ إِنُو إِتّْوحَّاشْ إِ شكْ ذِي دْجِيڒثْ،\qt*
\m \qt ؤُڒَا ذ بُوحْبڒْ إِنُو ذَايِي،\qt*
\m \qt ثُوغَا يَارزُّو خَاكْ س جّهْذْ.\qt*
\m \qt مَاغَارْ مَاڒَا ڒحْكَامَاثْ نّشْ\qt*
\m \qt ؤُسِينْثْ-إِ-د خْ ثمُّورْثْ،\qt*
\m \qt أَذْ ڒمْذنْ إِمزْذَاغْ ن ثمُّورْثْ ثَاسڭْذَا.“\qt*
\b
\m 
\v 10 \qt ”مَاڒَا إِسّْشنْ بْنَاذمْ أَحِينِّي إِ ؤُعفَّانْ،\qt*
\m \qt وَانِيثَا وَارْ إِڒمّذْ ثَاسڭْذَا،\qt*
\m \qt \tl مَاشَا\tl* أَذْ يڭّْ ڒْغَارْ\qt*
\m \qt ذِي ثمُّورْثْ إِشُّورنْ س ثْسڭْذَا،\qt*
\m \qt ؤُ وَارْ إِژَارّْ أَعُودْجِي ن سِيذِي.“\qt*
\b
\m 
\v 11 \qt ”\tl أَ\tl* سِيذِي، أَفُوسْ نّشْ إِتّْوَاسّْڭعَّاذْ،\qt*
\m \qt \tl مَاشَا\tl* نِيثْنِي وَارْ ث تّْوِيڒِينْ.\qt*
\m \qt \tl وَاخَّا أَمنِّي\tl* أَذْ ث ژَترنْ \tl عَاذْ،\tl*\qt*
\m \qt \tl مَاشَا\tl* أَذْ سضْحَانْ زڭْ وَاسَامْ \tl نّشْ\tl*\qt*
\m \qt إِ ڒْڭنْسْ \tl نّشْ\tl*،\qt*
\m \qt وَاهْ، ثِيمسِّي أَذْ ثشّْ إِغْرِيمنْ نّشْ.\qt*
\m 
\v 12 \qt \tl أَ\tl* سِيذِي، ڒْحُوكْمْ نّشْ خَانغْ\qt*
\m \qt أَذْ يِيڒِي ذ ڒهْنَا،\qt*
\m \qt مَاغَارْ شكْ ثْكمّْڒذْ\qt*
\m \qt مَارَّا ثِيمڭَّا نّغْ ذِي طّْوعْ نّغْ.\qt*
\m 
\v 13 \qt \tl أَ\tl* سِيذِي، أَربِّي نّغْ،\qt*
\m \qt إِسِيذِيثنْ نّغْنِي سدْجْضنْ خَانغْ.\qt*
\m \qt زَّايكْ شكْ وحّْذكْ\qt*
\m \qt أَقَا نتِّيذَارْ إِسمْ نّشْ.\qt*
\m 
\v 14 \qt إِمتَّانْ وَارْ تّدَّارنْ \tl عَاوذْ\tl*،\qt*
\m \qt ڒخْيَاڒَاثْ وَارْ تّْنكَّارَانْ.\qt*
\m \qt س ؤُيَا ثْخڒْفذْ أَسنْ \tl س ڒْغَارْ\tl*\qt*
\m \qt ؤُشَا ثقْضِيذْ ثنْ.\qt*
\m \qt شكْ ثكّْسذْ مَارَّا ڒْعقْرَانْ خَاسنْ.\qt*
\m 
\v 15 \qt \tl أَ\tl* سِيذِي، شكْ ثَارْنِيذْ ذِي ڒْڭنْسْ-أَ،\qt*
\m \qt شكْ ثَارْنِيذْ ذِي ڒْڭنْسْ-أَ،\qt*
\m \qt ثتّْوَاسّْعُودْجذْ ذَايسْ،\qt*
\m \qt \tl أَقَا\tl* ثسّْوسْعذْ مَارَّا إِيْمِيرنْ ن ثمُّورْثْ.“\qt*
\b
\m 
\v 16 \qt ”\tl أَ\tl* سِيذِي، ذِي ڒحْصَارثْ أَرْزُونْ خَاكْ،\qt*
\m \qt زدْجْعنْ ثِيژَادْجِيثِينْ نْسنْ س ثْحسّشْثْ،\qt*
\m \qt ؤُمِي خَاسنْ \tl د-ثُوسَا\tl* ثَارْبِييّثْ نّشْ.\qt*
\m 
\v 17 \qt أَمْ مَامّشْ ثتّْنزْبَارْ\qt*
\m \qt إِشْثْ ن ثمْغَارْثْ س دّيْسثْ،\qt*
\m \qt ثنِّي إِڭُّورنْ أَذْ ثَارُو \tl أَحنْجِيرْ نّسْ\tl*\qt*
\m \qt ؤُ ثسْغُويُّو س ڒوْجعْ ن ثَارُوثْ نّسْ،\qt*
\m \qt أَمُّو إِ ذ أَنغْ ثُوغَا نشِّينْ، \tl أَ\tl* سِيذِي،\qt*
\m \qt زَّاثْ إِ ثِيطَّاوِينْ نّشْ.\qt* \x ◘ \xo 26:‏17 \xt يُوح. 16‏:‏21\x*
\m 
\v 18 \qt ثُوغَا نشِّينْ \tl أَخْمِي\tl* نكْسِي س دّيْسثْ،\qt*
\m \qt إِمْنعْ أَنغْ ڒحْرِيقْ ن ثَارْوَا،\qt*
\m \qt ثُوغَا نشِّينْ أَخْمِي نُورُو أَسمِّيضْ.\qt*
\m \qt وَارْ د-نِيوِي أَسنْجمْ إِ ثمُّورْثْ،\qt*
\m \qt ؤُ إِمزْذَاغْ ن دُّونشْثْ وَارْ د-تّْوَاخڒْقنْ.“\qt*
\b
\m 
\v 19 \qt ”إِمتَّانْ نّشْ أَذْ دَّارنْ!\qt*
\m \qt ڒْْخشْبَاثْ إِنُو أَذْ بدّنْثْ!\qt*
\m \qt فَاقمْ، ؤُشَا سْڒِيوڒْومْ كنِّيوْ،\qt*
\m \qt إِنِّي إِزدّْغنْ ذڭْ ؤُشَاڒْ!\qt*
\m \qt أَقَا نّْذَا ن ثْفَاوِينْ أَمْ نّْذَا نّشْ،\qt*
\m \qt ؤُشَا ثَامُّورْثْ أَذْ ثَارُو ڒخْيَاڒَاثْ \tl ن إِمتَّانْ\tl*.“\qt*
\b
\m 
\v 20 \qt ”ؤُيُورْ، \tl أَ\tl* ڒْڭنْسْ إِنُو،\qt*
\m \qt أَذفْ غَارْ إِخَّامنْ نّشْ ن ذَاخڒْ،\qt*
\m \qt بلّعْ ثِيوُّورَا أَوَارْنِي أَشْ.\qt*
\m \qt سْنُوفَّارْ إِخفْ نّشْ\qt*
\m \qt \tl ڒْقدّْ ن\tl* إِشْثْ ن ثْزحْزِيحْثْ\qt*
\m \qt أَڒْ د إِعْذُو وسْخضْ.\qt* \x ◘ \xo 26:‏20 \xt 2 كُور. 4‏:‏17\x*
\m 
\v 21 \qt مَاغَارْ خْزَارْ، سِيذِي أَذْ إِفّغْ زڭْ ومْشَانْ نّسْ\qt*
\m \qt مَاحنْذْ أَذْ إِخْڒفْ إِ إِمزْذَاغْ ن ثمُّورْثْ\qt*
\m \qt ڒْْمُوعْصِييّثْ نْسنْ،\qt*
\m \qt ؤُشَا ثَامُّورْثْ أَذْ ثْعَارَّا إِذَامّنْ\qt*
\m \qt إِ خَاسْ إِتّْوَاسِّيزْڒنْ،\qt*
\m \qt وَارْ ثْخمِّيڒْ عَاذْ إِنِّي خَاسْ إِتّْوَانْغنْ.“\qt*
\b
\b
\c 27
\s1 أَسنْجمْ ن إِسْرَائِيل زڭْ ؤُفُوسْ ن ڒحْكَامَاثْ ن دُّونشْثْ
\m 
\v 1 ”\bd ذڭْ وَاسّْ نِّي\bd* أَذْ إِخْڒفْ سِيذِي زِي ’لِيبِييَاثَانْ‘، أَفِيغَارْ إِتّحْرُودْجُوضنْ س ثَازْڒَا، س سِّيفْ نّسْ إِقْسحْ، إِمْغَارْ ذ إِجْهذْ، \add وَاهْ أَذْ إِخْڒفْ\add* زِي ’لِيبِييَاثَانْ‘، أَفِيغَارْ إِتّحْرُورُوذنْ، ؤُشَا أَذْ إِنغْ ڒْهَايْشثْ نِّي إِدْجَانْ ذِي ڒبْحَارْ.“ \x ◘ \xo 27:‏1 \xt أَسَا. 12‏:‏9\x*
\b
\m 
\v 2 ”\bd ذڭْ وَاسّْ نِّي\bd* \add أَذْ ذِينْ يِيڒِي\add* ...
\m \qt إِجّْ ن ؤُمَارْجعْ ن ؤُضِيڒْ س بِينُو إِشْنَانْ.\qt*
\m \qt غنّْجمْ خَاسْ \tl س نُّوبْثَاثْ\tl*.\qt*
\m 
\v 3 \qt نشّْ، سِيذِي، أَذْ ت إِحْضَا،\qt*
\m \qt أَذْ ت سّْبزّْڭغْ،\qt*
\m \qt حِيمَا وَارْ ت إِجَارّحْ حذْ،\qt*
\m \qt نشّْ أَذْ خَاسْعسّغْ س وَاسّْ ذ دْجِيڒثْ.\qt*
\m 
\v 4 \qt ثَافْقحْثْ وَارْ ذَايِي ثدْجِي \tl قَاعْ\tl*،\qt*
\m \qt \tl مَاشَا\tl* مَاڒَا شَا ن يِيجّنْ إِزْعمْ\qt*
\m \qt أَذْ إِسَّارْسْ زَّاثِي ثَازڭّْوَارْثْ ذ إِسنَّاننْ،\qt*
\m \qt نشّْ أَذْ كِيذْسنْ مّنْغغْ،\qt*
\m \qt أَذْ ثنْ سَّارْغغْ مُوننْ،\qt*
\m 
\v 5 \qt إِلَّا مَاڒَا إِطّفْ بْنَاذمْ ذِي جّهْذْ إِنُو،\qt*
\m \qt \tl ؤُشَا\tl* أَذْ يڭّْ ڒهْنَا أَكِيذِي،\qt*
\m \qt \tl وَاهْ\tl* أَذْ يڭّْ ڒهْنَا أَكِيذِي!“\qt*
\b
\m 
\v 6 ”ذڭْ \add وُوسَّانْ\add* إِ د غَا يَاسنْ أَذْ إِوّثْ يَاعْقُوبْ أَژْوَارْ، إِسْرَائِيل أَذْ إِنُّووَارْ، أَذْ إِيْمَا، ؤُ نِيثْنِي أَذْ شُّورنْ ثَامُّورْثْ س ڒْغِيدْجثْ.“ \x ◘ \xo 27:‏6 \xt إِزهد. 72‏:‏16\x*
\b
\m 
\v 7 ”مَا إِوْثَا إِ-ث نتَّا، أَمْ مَامّشْ ونِّي إِوْثِينْ، إِوْثَا إِ-ث؟ مَا إِتّْوَانغْ نتَّا، أَمْ مَامّشْ تّْوَانْغنْ إِنِّي زَّايسْ إِتّْوَانْغنْ؟ \f ◼ \fr 27:‏7 \ft \bd ’زَّايسْ‘\bd* - إِخْسْ أَذْ يِينِي ’زِي أَربِّي‘.\f*
\v 8 شكْ ثَاربِّيذْ ت س ڒقْيَاسْ ڒَامِي ت ثنْضَارذْ، نتَّا إِسُّوزَّارْ \add إِ-ت\add* س ؤُسمِّيضْ نّسْ إِقسْحنْ، ذڭْ إِجّْ ن وَاسّْ ن ؤُسمِّيضْ زِي مَانِيسْ إِ د-ثْنقَّارْ ثْفُوشْثْ. \x ◘ \xo 27:‏8 \xt إِرْم. 30‏:‏11؛ 46‏:‏28\x*
\v 9 س ؤُيَا أَذْ إِتّْوَاڭّْ أَصْڒَاحْ خْ ڒْمُوعْصِييّثْ ن يَاعْقُوبْ س مَانْ أَيَا ؤُشَا أَذْ يِيڒِي أَيَا ذ ڒْغِيدْجثْ ثكْمڒْ زڭْ ؤُحيّذْ خْ دّْنُوبْ نّسْ: أَقَا نتَّا أَذْ يَارّْ مَارَّا إِژْرَا ن إِعَالْطَارنْ ذ إِژْرَا ن جَّارْ تّْوَاڒبْزنْ ؤُ وَارْ ذِينْ تّْبذِّينْثْ \add عَاذْ\add* ثْربِّينْ ن شْوَارْثِي ذ إِپِيلَارنْ ن أَربِّي ن ثْفُوشْثْ.“
\m 
\v 10 ”مَاغَارْ ثَانْذِينْثْ إِتّْوَاسّْجهْذنْ \add أَذْ ثذْوڒْ\add* حَافِي، أَمْ يِيشْثْ ن ثْزذِّيغْثْ إِتّْوَاجّنْ، إِخْڒَانْ أَمْ ڒخْڒَا. ذِينِّي أَذْ إِهْذَا ؤُعجْمِي، أَذْ ذِينْ إِجْنَا، أَذْ إِشّْ ثِيسضْوِينْ نّسْ. \f ◼ \fr 27:‏10 \ft \bd ’أَمْوَا‘\bd* - نِيغْ ’أَينْذُوزْ‘ نِيغْ ’يُوڭُّو‘.\f*
\v 11 خْمِي غَا يَاژْغنْ ڒفْرُوعْ نّسْ، أَذْ تّْوَاقضْعنْ. أَذْ د-أَسنْثْ ثمْغَارِينْ، أَذْ ثنْ سَّارْغنْثْ، \add مَاغَارْ\add* وَارْ إِدْجِي ذ إِجّْ ن ڒْڭنْسْ ذَايسْ ڒفْهَامثْ. خْ ؤُيَا ونِّي ث إِڭِّينْ، وَارْ ذ أَسنْ إِزِّيدْجِيزْ، ؤُ ونِّي ث إِكوّْننْ، وَارْ ذ أَسْ يَارطَّا.“
\m 
\v 12 ”\bd ذڭْ وَاسّْ نِّي\bd* أَذْ إِزْوضْ سِيذِي ثِيذْرِينْ زِي مَانِي إِدْجَا يغْزَارْ \add ن لْفُورَاطْ\add* أَڒْ ثغْزَارْثْ ن مِيصْرَا. \add مَاشَا كنِّيوْ\add* أَذْ تّْوَاڒقْضمْ، إِجّنْ أَوَارْنِي إِ ونّغْنِي، \add أَ\add* أَيْثْ ن إِسْرَائِيل. \x ◘ \xo 27:‏12 \xt إِشا. 17‏:‏5\x*
\v 13 \bd ذڭْ وَاسّْ نِّي\bd* أَذْ سُوضنْ ذڭْ ؤُيِيشّْ أَمقّْرَانْ ن إِشَارِّي. \add خنِّي\add* أَذْ د-أَسنْ إِنِّي إِسّْوجْذنْ أَذْ هلّْكنْ ذِي أَشُّورْ ؤُڒَا ذ يِينِّي إِتّْوَاعَارّْننْ غَارْ ثمُّورْثْ ن مِيصْرَا. نِيثْنِي أَذْ سجْذنْ إِ سِيذِي ذڭْ وذْرَارْ إِقدّْسنْ ذِي ؤُرْشَالِيمْ.“
\b
\b
\c 28
\s1 أَوَاڒْ ن أَربِّي خْ سَامَارْيَا
\m 
\v 1 ”\bd ؤُشْثْ\bd* خْ تَّاجْ ؤُعفَّارْ ن إِمسْشَارنْ ن إِفْرَايِيمْ، أَقَا ثَالْوِيزْثْ نّسْ إِشُووَّارنْ \add أَمشْنَاوْ\add* ثَانوَّاشْثْ إِسْڒَاونْ خْ ثْقِيشّثْ ن ثغْزُورْثْ إِصبْحنْ ن يِينِّي خْ يغْڒبْ بِينُو.
\v 2 خْزَارْ، سِيذِي إِنُو غَارسْ \add إِجّنْ\add* إِجْهذْ ؤُ إِوْعَارْ أَمْ ثشْثِي ن ثبْرُورِي، أَمْ ثْحَارْيَاضْثْ إِ إِتَّاوْينْ طَّاعُونْ ذ ؤُخَارّبْ. أَمْ ڒْحمْڒَاثْ ن وَامَانْ إِمْغَارنْ إِسّْفَاينْ أَذْ إِنْضَارْ نتَّا \add تَّاجْ نِّي\add* س ؤُفُوسْ \add نّسْ\add* غَارْ ثمُّورْثْ.
\v 3 تَّاجْ أَعفَّارْ ن إِمسْشَارنْ ن إِفْرَايِيمْ أَذْ ثعفْسنْ س إِضَارنْ.
\v 4 ثَانوَّاشْثْ إِسْڒَاونْ ن ثلْوِيزْثْ نّسْ إِشُووَّارنْ خْ ثْقِيشّثْ ن ثغْزُورْثْ إِسّغْمَاينْ، أَذْ ثِيڒِي أَمْ ثْبَاشُورْثْ ثِيوضْ قْبڒْ أَنبْذُو، ثنِّي ونِّي إِخزَّارنْ ذَا ذ ذِيهَا إِژْرَا إِ-ت ؤُشَا إِسّغْڒِي إِ-ت \add ذغْيَا\add* ؤُمِي ثُوغَا \add عَاذْ\add* ذڭْ ؤُفُوسْ نّسْ.“
\b
\m 
\v 5 ”\bd ذڭْ وَاسّْ نِّي\bd* أَذْ يِيڒِي سِيذِي ن ڒْعسْكَارَاثْ ذ ثَاجّْ ن ؤُشُووَّاضْ ذ تَّاجْ إِشوَّارنْ إِ مِينْ إِقِّيمنْ ن ڒْڭنْسْ نّسْ،
\v 6 ذ أَرُّوحْ ن ڒْحُوكْمْ إِ ونِّي إِقِّيمنْ \add خْ ڒْكُورْسِي\add* إِ ڒْحُوكْمْ، ؤُڒَا ذ \add أَرُّوحْ ن\add* ثَارْيَاسْثْ إِ أَيْثْ ن بُو-ثغْرُوضْثْ إِ يِينِّي إِتَّارَّانْ أَمنْغِي غَارْ ثوَّارْثْ \add ن ثنْذِينْثْ\add*.“
\b
\m 
\v 7 ”عَاذْ إِنَا تّمّْرَايْوَانْ س بِينُو، ؤُشَا تّْوَارنْينْ زِي شّْرَابْ. \bd إِتّمْرَايْوَا ؤُكهَّانْ ذ ؤُنَابِي س شّْرَابْ\bd*. تّْوَاصَارْضنْ س بِينُو، تّْوَارنْينْ زِي شّْرَابْ، تّمْرَايْوَانْ غَارْ إِوحَّانْ نْسنْ، تّنْهزَّانْ ذَا ذ ذِيهَا ؤُمِي حكّْمنْ غَارْ ؤُشَارّعْ. \x ◘ \xo 28:‏7 \xt إِشا. 5‏:‏11\x*
\v 8 مَاغَارْ مَارَّا طَّابْڒَاثْعمَّارنْثْ س ثْرَارِيثْ إِخمْجنْ، ؤُڒَا ذ إِجّْ ن ومْشَانْ \add وَارْ إِقِّيمْ ذ أَمزْذَاڭْ\add*.
\v 9 ’إِ ؤُمِي إِخْسْ نتَّا أَذْ إِسّْغَارْ ثُوسّْنَا، إِ ؤُمِي إِخْسْ أَذْ إِسّْشنْ أَرقَّاسْ؟ \add إِ\add* يِينِّي ؤُمِي إِتّْوَاكّسْ أَسنْ ؤُغِي، \add إِ\add* يِينِّي ؤُمِي إِكّْسنْ أَبُّوشْ؟
\v 10 مَاغَارْ أَقَا ذَا، ڒُومُورْ خْ ڒُومُورْ، ڒُومُورْ خْ ڒُومُورْ، لْفَارِيضَا خْ لْفَارِيضَا، لْفَارِيضَا خْ لْفَارِيضَا، ذَا ذْرُوسْثْ، ذِيهَا ذْرُوسْثْ.‘ “
\m 
\v 11 ”س ؤُيَا أَذْ إِسِّيوڒْ أَكْ-ذ ڒْڭنْسْ-أَ س إِينْشِيشنْ إِطّوْطِيونْ ؤُ س إِجّْ ن يِيڒسْ نّغْنِي، \x ◘ \xo 28:‏11 \xt 1 كُور. 14‏:‏21\x*
\v 12 نتَّا ذ ونِّي ثُوغَا إِ ذ أَسنْ إِنَّا: ’وَا ذ أَرَّاحثْ، وْشمْ أَرَّاحثْ إِ ونِّي يُوحْڒنْ!‘، ؤُشَا: ’وَا ذْ ڒْمَارْڭحْ!‘، \add مَاشَا\add* نِيثْنِي وَارْ خْسنْ شَا أَذْ سْڒنْ.
\v 13 أَذْ أَسنْ يِيڒِي وَاوَاڒْ ن سِيذِي: ’ڒُومُورْ خْ ڒُومُورْ، ڒُومُورْ خْ ڒُومُورْ، لْفَارِيضَا خْ لْفَارِيضَا، لْفَارِيضَا خْ لْفَارِيضَا، ذَا ذْرُوسْثْ، ذِيهَا ذْرُوسْثْ!‘، مَاحنْذْ نِيثْنِي، أَمْ ؤُيُورنْ، أَذْ وْضَانْ غَارْ ضفَّارْ، أَذْ تّْوَارْژنْ، أَذْ ذوْڒنْ ذِي ڒْفخْ ؤُ أَذْ تّْوَاحبّْسنْ.“ \x ◘ \xo 28:‏13 \xt 2 كُور. 2‏:‏16\x*
\b
\m 
\v 14 ”س ؤُيَا، سْڒمْ إِ وَاوَاڒْ ن سِيذِي، \add أَ كنِّيوْ\add* \bd إِمسْثهْزَاينْ، إِنِّي غَارْ إِدْجَا صُّولْطَا خْ ڒْڭنْسْ-أَ نِّي \bdit إِدْجَانْ\bdit* ذِي ؤُرْشَالِيمْ!\bd*
\v 15 مِينْزِي ثقَّارمْ: ’نشِّينْ نڭَّا ڒْعَاهْذْ أَكْ-ذ ڒْموْثْ ؤُ نڭَّا إِشْثْ ن ضّْمَانَا أَكْ-ذ ڒَاخَارْثْ. خْمِي غَا إِعْذُو ؤُركُّوضْ إِفَارْشنْ، وَارْ غَارْنغْ د-يِيوِيضْ، مَاغَارْ نڭَّا أَخَارِّيقْ أَخْمِي مَانِي غَارْ إِ غَا نَارْوڒْ ؤُ أَذْ ننُّوفَّارْ أَوَارْنِي إِ ڒْغشّْ!‘
\v 16 س ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’خْزَارْ، نشّْ أَذْ سَّارْسغْ إِجّْ ن وژْرُو ذِي صِيهْيُونْ، أَژْرُو إِقدْجْبنْ، أَژْرُو ن ثغْمَارْثْ إِغْڒَانْ، ذْسَاسْ إِمْثنْ. ونِّي يُومْننْ وَارْ إِتّْرِيكْوِيڒْ.‘ \x ◘ \xo 28:‏16 \xt إِزهد. 118‏:‏22؛ مت. 21‏:‏42؛ ڒخ. 4‏:‏11؛ رُوم. 9‏:‏33؛ 10‏:‏11؛ أَفا. 2‏:‏20؛ 1 بُط. 2‏:‏6، 7، 8\x*
\v 17 أَذْ سَّارْسغْ ڒْحقّْ ذ ؤُفِيڒُو ن ڒعْبَارْ ؤُشَا ثَاسڭْذَا ذ بْلُومُو. ثبْرُورِّي أَذْ ثحَّا أَمْشَانْ ن ثَاروْڒَا إِشُّورنْ س إِخَارِّيقنْ ؤُشَا أَمَانْ أَذْ د-سّفْينْ أَمْشَانْ \add نّسْ\add* ن ؤُدُّورِي.
\m 
\v 18 ڒْعَاهْذْ نْومْ أَكْ-ذ ڒْموْثْ أَذْ إِتّْوَامْحَا، ضّْمَانَا نْومْ أَكْ-ذ ڒَاخَارْثْ وَارْ ثتّْغِيمِي ثْبدّْ. خْمِي غَا إِعْذُو ؤُركُّوضْ إِفَارْشنْ، أَذْ زَّايسْ ثتّْوَاعفْسمْ كنِّيوْ.
\v 19 مڒْمِي مَا إِعْذُو، أَذْ كنِّيوْ يَاوِي \add أَكِيذسْ\add*، مَاغَارْ أَذْ ثعْذُو ثُوفُوثْ أَوَارْنِي إِ ثُوفُوثْ، س وَاسّْ ذ دْجِيرثْ. ؤُشَا أَفهَّامْ ن ؤُرقَّاسْ أَذْ يَاوِي مْغِيرْ أَسْنخْڒِيعْ.
\v 20 مَاغَارْ قَامَا أَذْ إِقُوضضْ أَڒَامِي وَارْ إِزمَّارْ \add بْنَاذمْ\add* أَذْ إِبُّوزّرْ ؤُشَا ثَاعْڒَاوْثْ أَذْ ثِيڒِي ثحْصَارْ أَڒَامِي \add بْنَاذمْ\add* وَارْ إِزمَّارْ أَذْ ذَايسْ يَاذفْ.
\v 21 مَاغَارْ سِيذِي أَذْ إِكَّارْ أَمْ خْ وذْرَارْ ن فَارَاصِيمْ، أَذْ إِهَاجْ أَمْ ذِي ثغْزُورْثْ ن جِيبْعُونْ، مَاحنْذْ أَذْ يڭّْ شّْغڒْ نّسْ: ’شّْغڒْ نّسْ أَذْ يِيڒِي ذ أَغْرِيبْ!‘، ؤُشَا مَاحنْذْ أَذْ يڭّْ ڒْخذْمثْ نّسْ: ’ڒْخذْمثْ نّسْ أَذْ ثِيڒِي ثَاغْرِيبْثْ!‘
\v 22 ؤُ ڒخُّو، وَارْ سّهْقَارَا، حِيمَا سّْنَاسڒْ نْومْ وَارْ ثنْثْ تّْزيَّارنْ عَاذْ كْثَارْ، مَاغَارْ سْڒِيغْ زِي سِيذِي إِنُو، سِيذِي ن ڒْعسْكَارَاثْ أَقَا إِكّسْ ذڭْ وَاوَاڒْ أَذْ يَاردّدْجْ إِمُونْ مَارَّا ثَامُّورْثْ.“
\b
\m 
\v 23 ”سْحسّمْ ؤُ سْڒمْ إِ ثْمِيجَّا إِنُو، حْضَامْ ؤُ سْڒمْ غَارْ وَاوَاڒنْ إِنُو!
\v 24 مَا إِشَارّزْ ؤُمْشَارّزْ أَسّْ إِمُونْ، حِيمَا أَذْ إِزَارْعْ؟ مَا \add ڒبْذَا\add* إِتّْفدْجحْ ؤُ إِنقّشْ إِيَّارْ نّسْ؟
\v 25 مَا وَارْ إِدْجِي أَمُّو، مَاڒَا نتَّا إِوَاطَا ؤُذمْ \add ن ييَّارْ\add*، إِسُّويُوسْ سَّانُودْجْ ؤُشَا \add زَّارِيعثْ ن\add* ڒْشمُّونْ إِبزّعْ إِ-ت، إِڭَّا إِرْذنْ ذِي ڒصْفُوفْ ذ إِمنْذِي ذِي إِكْوَاذْرُوننْ ؤُشَا كَارْصَانَا إِڭَّا إِ-ث غَارْ ثْمَاوِّينْ نّسْ؟ \f ◼ \fr 28:‏25 \ft \bd ’كَارْصَانَا‘\bd* - نِيغْ ’دُّوخْنْ‘ نِيغْ ’جَاوَارْسْ‘.\f*
\v 26 إِذَارّبْ إِ-ث أَربِّي نّسْ مَامّشْ إِتّْخصَّا أَذْ إِخْذمْ نِيشَانْ، إِسّڒْمذْ إِ-ث.
\v 27 مِينْزِي وَارْ سَّارْوَاثنْ سَّانُودْجْ س ثڒْوِيحْثْ إِتّحْڒُودْجُوضنْ إِ ؤُسَارْوثْ ؤُ وَارْ سّكِّينْ ثَاجَارَّارْثْ ن ؤُكَارُّو ثِيوَا ن ڒْشمُّونْ، مَاشَا زكّْوْضنْ سَّانُودْجْ س وعْمُوذْ ذ ڒْشمُّونْ س ؤُقطَّابْ.
\v 28 مَا حَارّْينْ إِمنْذِي \add غَارْ ؤُسَارْوثْ\add*؟ لَّ، \add بْنَاذمْ\add* وَارْ ث إِسَّارْوِيثْ إِ ڒبْذَا، وَارْ \add خَاسْ\add* إِندّهْ ثِيجَارَّارِينْ ن ؤُكَارُّو ذ ييْسَانْ نّسْ إِ ڒبْذَا: وَارْ ث إِحَارِّي.
\v 29 ؤُڒَا ذ مَانْ أَيَا إِفّغْ-د زِي سِيذِي ن ڒْعسْكَارَاثْ. شّْوَارْ نّسْ ذ ڒعْجبْ، أَقَا نتَّا إِمْغَارْ ذڭْ ؤُسُويَارْ.“ \x ◘ \xo 28:‏29 \xt إِرْم. 32‏:‏19\x*
\b
\b
\c 29
\s1 ؤُرْشَالِيمْ ثتّْوَاحْصَارْ زِي ڒڭْنُوسْ
\m 
\v 1 ”\bd ؤُشْثْ\bd* خْ أَرِييِيلْ، أَرِييِيلْ، ثَانْذِينْثْ ن ڒْمَارْڭحْ ن ڒْعسْكَارْ ن ذَاوُوذْ. أَرْنِيمْ \add عَاذْ\add* إِجّْ ن ؤُسڭّْوَاسْ غَارْ ؤُسڭّْوَاسْ\add -أَ\add*، جّمْ ڒعْيُوذَاثْ \add ن ؤُسڭّْوَاسْ\add* أَذْ عْذُونْثْ،
\v 2 \add خنِّي\add* أَذْ حْصَارغْ أَرِييِيلْ، ؤُشَا أَذْ \add ذِينْ\add* يِيڒِي ؤُوحْوحْ ذ وشْضَانْ ؤُ نتَّاثْ أَذْ ثِيڒِي إِ نشّْ أَمْ أَرِييِيلْ.
\v 3 أَذْ أَمْ قوَّارغْ ؤُ أَذْ شمْ حْصَارغْ س إِجّْ ن ڒْعسْكَارْ إِ ؤُحطُّو ؤُشَا أَذْ خَامْ سّْبدّغْ لْبَارَاجَاثْ. \x ◘ \xo 29:‏3 \xt إِرْم. 6‏:‏3؛ حِز. 17‏:‏17\x*
\v 4 أَذْ ثتّْوَاسّهْوِيذْ، أَذْ ثسِّيوْڒذْ زِي ثمُّورْثْ ؤُشَا أَوَاڒنْ نّمْ أَذْ ثنْ ثْرمْرمْذْ زِي ثْعجَّاجْثْ. ثْمِيجَّا نّمْ أَذْ ثفّغْ زِي ثمُّورْثْ أَمْ \add ثْمِيجَّا\add* ن ونِّي إِسَّاوَاڒَانْ أَكْ-ذ إِمتَّانْ ؤُشَا أَوَاڒنْ نّمْ \add أَذْ إِڒِينْ\add* أَمْ ؤُشوْشوْ \add وَاهَا\add* زڭْ ؤُشَاڒْ. \x ◘ \xo 29:‏4 \xt إِشا. 8‏:‏19\x*
\v 5 أَبَارُّو ن إِغْرِيمنْ نّمْ أَذْ يِيڒِي أَمْ ثْعجَّاجْثْ ثَازْذَاذْثْ، ؤُشَا أَبَارُّو ن أَيْثْ ن بُو-ڒخْشُونثْ أَمْ ؤُڒُومْ إِعدُّونْ، إِتَّاوْيْ إِ-ث ؤُسمِّيضْ. أَذْ إِمْسَارْ ذڭْ ورْمَاشْ ن وَابْڒِيونْ، ذڭْ إِشْثْ ن ثشْثِي! \x ◘ \xo 29:‏5 \xt أَيُوبْ 21‏:‏18؛ إِزهد. 1‏:‏4؛ 35‏:‏5؛ إِشا. 17‏:‏13؛ 30‏:‏13\x*
\v 6 سِيذِي ن ڒْعسْكَارَاثْ أَذْ غَاركْ إِنّوْجُو س وَاجَّاجْ ذ ونْهزِّي ن ثمُّورْثْ، \add س\add* ڒْحسّْ إِجهْذنْ ن ثْمِيجَّا \add نّسْ\add*، \add س\add* ؤُسمِّيضْ ن ثْحَارْيَاضْثْ ؤُ \add س\add* ؤُشعَّاڒْ ن ثْمسِّي إِتّتّنْ.
\v 7 أَمْ ثَارْجِيثْ، إِجّْ ن ڒوْحِييْ ذِي دْجِيڒثْ، أَمُّو إِ غَا يِيڒِي ؤُبَارُّو ن مَارَّا ڒڭْنُوسْ نِّي إِ غَا إِمّنْغنْ أَكْ-ذ أَرِييِيلْ، \add وَاهْ،\add* مَارَّا إِنِّي إِ غَا إِمّنْغنْ أَكِيذسْ ؤُ أَكْ-ذ لْبُورْجْ نّسْ ذ إِنِّي ت إِ غَا إِحْصَارنْ \add أَذْ إِڒِينْ أَمُّو\add*.
\v 8 أَذْ يِيڒِي أَمْ يِيجّنْ يُورْجَا ؤُمِي ذَايسْ يدْجَا ڒَاژْ. خْزَارْ، نتَّا إِتّتّْ، \add خنِّي مَاشَا\add* أَذْ د-إِفَاقْ، يُوفَا أَقَا ڒعْمَارْ نّسْ وَارْ إِجِّيونْ \add عَاذْ\add*. نِيغْ \add أَذْ يِيڒِي\add* أَمشْنَاوْ إِجّنْ يُورْجَا أَمْ إِفُّوذْ، ؤُ خْزَارْ، نتَّا إِسسّْ، \add خنِّي مَاشَا\add* أَذْ د-إِفَاقْ، يُوفَا أَقَا نتَّا إِفْنَا، ؤُشَا ڒعْمَارْ نّسْ إِتّْمژْرِي \add عَاذْ أَذْ إِسُو\add*. أَمُّو إِ غَا ثِيڒِي \add ثْمسْڒَاشْثْ\add* إِ مَارَّا ڒڭْنُوسْ نِّي إِ غَا إِمّنْغنْ أَكْ-ذ وذْرَارْ ن صِيهْيُونْ.“
\b
\m 
\v 9 ”جْعَارمْ ؤُ ثْبهْثمْ، سْمسْحمْ ثِيطَّاوِينْ نْومْ \add أَڒْ إِ غَا\add* ثِيڒِيمْ ذ إِذَارْغَاڒنْ! نِيثْنِي سْشَارنْ، \add مَاشَا\add* وَارْ إِدْجِي زِي بِينُو، تّمْرَايْوَانْ، \add مَاشَا\add* وَارْ إِدْجِي زِي شّْرَابْ.
\v 10 مَاغَارْ سِيذِي إِزدْجعْ خَاومْ بُوحْبڒْ ن يِيضصْ يُودْجْغنْ. إِبلّعْ ثِيطَّاوِينْ نْومْ، إِنَابِييّنْ، ؤُشَا إِزدْجِيفنْ نْومْ، إِمْوَاڒَاونْ \add ن ثْمژْرِيوِينْ\add*، إِڒحّفْ إِ-ثنْ. \x ◘ \xo 29:‏10 \xt رُوم. 11‏:‏8\x*
\v 11 أَمُّو إِ ذ أَومْ إِذْوڒْ ڒوْحِييْ ن مَارَّا أَيَا أَمْ وَاوَاڒنْ ن إِجّْ ن وذْلِيسْ إِتّْوَانّْضنْ نِّي إِمّوْشنْ إِ ونِّي إِسّْننْ ثِيغْرِي، قَّارنْ: ’غَارْ إِ-ث-إِ-ذ خَافِي!‘، ؤُشَا \add خنِّي\add* أَذْ يَارّْ: ’نشّْ وَارْ زمَّارغْ \add أَذْ ث غَارغْ\add*، مَاغَارْ إِشمّعْ.‘
\v 12 نِيغْ إِمّوْشْ وذْلِيسْ إِ ونِّي وَارْ إِسّْننْ أَذْ إِغَارْ، \add ؤُمِي\add* قَّارنْ: ’غَارْ إِ-ث-إِ-ذ خَافِي!‘، ؤُشَا \add خنِّي\add* أَذْ يَارّْ نتَّا: ’نشّْ وَارْ سِّينغْ أَذْ غَارغْ.‘ “
\m 
\v 13 ”إِنَّا أَيِي سِيذِي إِنُو: ’مِينْزِي ڒْڭنْسْ-أَ يُوذسْ أَيِي-د مْغِيرْ س وَاوَاڒنْ وَاهَا ؤُ \add مِينْزِي نِيثْنِي\add* تّڭّنْ أَيِي شَّانْ س إِينْشِيشنْ نْسنْ، \add أَمْ\add* إِڭّْوجْ خَافِي ؤُڒْ نْسنْ، ؤُ مِينْزِي أَوقَّارْ إِ زِي ذ أَيِي وقَّارنْ \add إِتّفّغْ\add* زِي ثْوصَّا نِّي ڒمْذنْ زڭْ إِوْذَانْ \add وَاهَا\add*، \x ◘ \xo 29:‏13 \xt مت. 15‏:‏8؛ مك. 7‏:‏6\x*
\v 14 س ؤُيَا، خْزَارْ، نشّْ أَرنِّيغْ أَذْ ڭّغْ ذِي ڒْڭنْسْ-أَ س ڒعْجبْ، س ڒعْجبْ ذ ؤُسْثبْهثْ. ثِيغِيثْ ن إِمِيغِيسنْ أَذْ ثفْنَا ؤُ ڒفْهَامثْ ن إِفهَّامنْ أَذْ ثْودَّارْ.“\x ◘ \xo 29:‏14 \xt إِرْم. 49‏:‏7؛ عُوب. 8؛ مت. 11‏:‏25؛ 1 كُور. 1‏:‏19\x*
\b
\m 
\v 15 \bd ؤُشْثْ\bd* خْ يِينِّي إِسّْنُوفَّارَانْ زَّاثْ إِ سِيذِي، إِنِّي إِسّْذُورُّوينْ أَخَارِّيصْ نْسنْ، ؤُشَا تّڭّنْ ثِيمڭَّا نْسنْ ذِي طّْڒَامْ، \add ؤُمِي\add* قَّارنْ: ’وِي ذ أَنغْ إِژْرِينْ ذ وِي ذ أَنغْ إِسّْننْ؟‘ \x ◘ \xo 29:‏15 \xt إِزهد. 94‏:‏7\x*
\v 16 كنِّيوْ ثسّنْقڒْبمْ \add ثَامسْڒَاشْثْ\add*! أَخْمِي زعْمَا إِزمَّارْ أَذْ إِتّْوَاحْسبْ بُو-ثْڒَاخْثْ أَمْ ثْڒَاخْثْ، أَڒَامِي مِينْ إِتّْوَاڭّنْ أَذْ يِينِي خْ ونِّي ث إِڭِّينْ: ’نتَّا وَارْ ذ أَيِي إِڭِّي!‘، ؤُشَا ڒْقشْعثْ ن ثْڒَاخْثْ أَذْ ثِينِي خْ ؤُقدَّارْ نّسْ: ’نتَّا وَارْ إِتّْحِيكِي وَالُو!‘ “ \x ◘ \xo 29:‏16 \xt إِشا. 45‏:‏9\x*
\b
\m 
\v 17 ”مَا وَارْ إِدْجِي ذْرُوسْ إِ إِقِّيمنْ أَڒْ غَا إِذْوڒْ لُوبْنَانْ ذ ڒْعَارْسثْ إِصبْحنْ ؤُ أَذْ ثتّْوَاحْسبْ ڒْعَارْسثْ إِصبْحنْ ذ أَزْغَارْ؟ \f ◼ \fr 29:‏17 \ft \bd ’أَزْغَارْ‘\bd* - نِيغْ ’ڒْغَابثْ‘ نِيغْ ’ثَازْڭَانْثْ‘.\f*
\v 18 \bd ذڭْ وَاسّْ نِّي\bd* أَذْ سْڒنْ إِذهْشُورنْ أَوَاڒنْ ن وذْلِيسْ-أَ إِتّْوَانّْضنْ، ؤُشَا أَذْ ثْوَاڒَانْثْ ثِيطَّاوِينْ ن إِضَارْغَاڒنْ زِي ثَادْجسْثْ ؤُ زِي طّْڒَامْ. \x ◘ \xo 29:‏18 \xt مت. 11‏:‏5\x*
\v 19 أَذْ أَرْنِينْ إِمْوَاضْعنْ ذِي ڒفْرَاحثْ ذِي سِيذِي، ؤُشَا أَذْ فَارْحنْ إِمزْڒَاضْ جَارْ إِوْذَانْ ذڭْ ؤُمْقدَّاسْ ن إِسْرَائِيل.
\m 
\v 20 مَاغَارْ بُو-ڒخْشُونثْ أَذْ إِقْضَا، ونِّي إِسْثْهزَانْ أَذْ إِفْنَا، ؤُ مَارَّا إِنِّي يَارزُّونْ ڒْغشّْ أَذْ نّْقضْعنْ،
\v 21 إِنِّي إِتّڭّنْ ڒْعِيبْ ذِي بْنَاذمْ زِي سِّيبّثْ ن إِجّْ ن وَاوَاڒْ \add وَاهَا\add*، إِنِّي إِسّْرُوسَانْ ڒفْخُوخْ إِ يِينِّي إِذفّْعنْ ڒْحقّْ ذِي ثوَّارْثْ \add ن ثنْذِينْثْ\add*، ؤُڒَا ذ إِنِّي إِعَارّْننْ أَمْسڭّذْ غَارْ ؤُغزْذِيسْ خْ وَالُو.“ \x ◘ \xo 29:‏21 \xt عَام. 5‏:‏10\x*
\b
\m 
\v 22 ”س ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي، ونِّي إِفكّنْ إِبْرَاهِيمْ، إِ ثَادَّارْثْ ن يَاعْقُوبْ: ’يَاعْقُوبْ وَارْ إِتّْسضْحِي \add عَاذْ\add* ؤُشَا أَغمْبُوبْ نّسْ وَارْ إِتّوْرِيغْ \add عَاذْ\add*.
\v 23 مَاغَارْ خْمِي غَا إِژَارْ نتَّا ثَارْوَا نّسْ، إِنِّي ذ ڒْخذْمثْ ن إِفَاسّنْ إِنُو، ذِي ڒْوسْطْ نّسْ، أَذْ سّْقدّْسنْ نِيثْنِي إِسمْ إِنُو، أَذْ سّْقدّْسنْ أَمْقدَّاسْ ن يَاعْقُوبْ ؤُ أَذْ ڭّْوذنْ أَربِّي ن إِسْرَائِيل.
\v 24 إِنِّي إِودَّارنْ ذِي بُوحْبڒْ أَذْ غَارْسنْ ثِيڒِي ثُوسّْنَا ن ڒفْهَامثْ، ؤُشَا إِنِّي إِتّْنذْقَامنْ، أَذْ أَرْزْمنْ ثَاوَّارْثْ أَذْ ڒمْذنْ.‘ “
\b
\b
\c 30
\s1 ڒْعَاهْذْ إِبطّْڒنْ أَكْ-ذ مِيصْرَا
\m 
\v 1 ”\add أَمُّو إِ\add* إِقَّارْ سِيذِي: ’\bd ؤُشْثْ\bd* خْ إِحنْجِيرنْ نِّي إِغوّْغنْ مَاحنْذْ أَذْ سُّوفّْغنْ شّْوَارْ، \add مَاشَا\add* وَارْ إِدْجِي زَّايِي، مَاحنْذْ أَذْ ڭّنْ إِجّْ نْ ڒْعَاهْذْ، \add مَاشَا\add* وَارْ إِدْجِي \add زِي\add* أَرُّوحْ إِنُو، حِيمَا أَذْ سّْعُورّْشنْ دّنْبْ خْ دّنْبْ،
\v 2 إِنِّي إِڭُّورنْ مَاحنْذْ أَذْ هْوَانْ غَارْ مِيصْرَا نْهْڒَا مَا أَذْ أَيِي سّقْسَانْ، حِيمَا أَذْ أَفنْ أَسڒْقِي غَارْ جّهْذْ ن فِيرْعُونْ ؤُ مَاحنْذْ أَذْ أَروْڒنْ غَارْ ثِيڒِي ن مِيصْرَا.
\v 3 \add مَاشَا\add* جّهْذْ ن فِيرْعُونْ أَذْ كنِّيوْ يَارّْ ثتّْسضْحَامْ ؤُشَا أَذُورِّي ذِي يِيڒِي ن مِيصْرَا أَذْ كنِّيوْ إِفْضحْ.
\v 4 مَاغَارْ ڒْحُوكَّامْ نّسْ دْجَانْ ذِي صُوعَانْ ؤُشَا إِمْسكَّانْ نّسْ إِوْضنْ غَارْ حَانِيسْ.
\v 5 نِيثْنِي مَارَّا أَذْ تّْوَاسّْبَارّْقنْ زِي ڒْڭنْسْ نِّي وَارْ ذ أَسنْ إِنفّْعنْ شَا، وَارْ إِتِّيشنْ أَفُوسْ ؤُڒَا ذ وَالُو ن ڒفْضڒْ، مَاشَا أَذْ ثنْ يَاوِي غَارْ ڒفْضِيحثْ ذ ڒْهڭْرَا.“ \x ◘ \xo 30:‏5 \xt إِرْم. 2‏:‏36\x*
\b
\m 
\v 6 \bd ڒْحُوكْمْ إِسَّاڭّْوَاذنْ خْ ڒْمَاڒْ ن \bdit ثمُّورْثْ ن\bdit* لْجَانُوبْ.\bd* ”ذڭْ إِشْثْ ن ثمُّورْثْ ن ڒحْصَارثْ ذ دّدْجْ، مَانِي زَّايسْ د-ؤُسِينْ ثَايْرَاذْثْ ذ ويْرَاذْ ذ ؤُفِيغَارْ ذ ڒْحَايْشثْ إِشمْضنْ إِطَّاونْ، أَربُّونْ-د نِيثْنِي أَڭْڒَا نْسنْ خْ وعْرُورْ ن إِسْنُوسنْ ذ ڒكْنُوزْ نْسنْ خْ ثعْرُورِينْ ن إِڒغْمَانْ غَارْ إِجّْ ن ڒْڭنْسْ وَارْ ثنْ إِنفّعْ ذِي شَا. \x ◘ \xo 30:‏6 \xt إِشا. 14‏:‏29\x*
\v 7 \add مَاغَارْ\add* مِيصْرَا أَذْ إِوْشْ أَفُوسْ بَاطڒْ ؤُ إِ وَالُو. س ؤُيَا ڒَاغِيغْ \add مِيصْرَا\add* وَانِيثَا: ’رَاهَابْ، \add بُو-ثغْرُوضْثْ أَمقّْرَانْ\add*، ثقِّيمْ وَاهَا!‘ “
\b
\s1 ثَاغنَّانْثْ ن إِسْرَائِيل
\m 
\v 8 ”\add خنِّي\add* ڒخُّو، أَسْ-د، أَرِي ث زَّاثْ إِ ثِيطَّاوِينْ نْسنْ خْ ثڒْوِيحْثْ، خبْشْ إِ-ث ذڭْ إِشْثْ ن ثبْرَاثْ إِتّْوَانّْضنْ، \add مَاحنْذْ\add* أَذْ ثِيڒِي ثتّْوَاحْضَا أَڒْ أَسّْ إِ د غَا يَاسنْ، إِ ڒبْذَا نْ ڒبْذَاثْ.
\v 9 مَاغَارْ نِيثْنِي ذ ڒْڭنْسْ إِغوّْغنْ، أَيْثْ ن بُو-إِخَارِّيقنْ، إِحنْجِيرنْ نِّي وَارْ إِخْسنْ أَذْ سْڒنْ إِ شَّارِيعَا ن سِيذِي،
\v 10 إِنِّي إِقَّارنْ إِ إِمْوَاڒَاونْ: ’وَارْ تّْوِيڒِيمْ وَالُو!‘، ؤُ إِ يِينِّي إِخزَّارنْ إِوحَّانْ: ’وَارْ تّْوِيڒِيمْ إِوحَّانْ نِّي إِدْجَانْ ذ ثِيذتّْ. سِيوْڒمْ أَكِيذْنغْ مِينْ د إِسّْحِينِّيبنْ، \add مْڒِي\add* ذ أَنغْ ثتّْوَاڒَامْ مِينْ إِغشّنْ!
\v 11 حيّْذمْ زڭْ وبْرِيذْ، فّْغمْ زڭْ وبْرِيذْ، جّمْ أَمْقدَّاسْ ن إِسْرَائِيل أَذْ خَانغْ يِيڭّْوجْ!‘ “
\m 
\v 12 ”س ؤُيَا، أَمُّو إِ إِقَّارْ ؤُمْقدَّاسْ ن إِسْرَائِيل: ’مِينْزِي كنِّيوْ ثنْضَارمْ أَوَاڒْ-أَ، ثتّشْڒمْ خْ دّدْجْ ؤُ خْ مِينْ إِفّْغنْ \add زڭْ وبْرِيذْ\add*، \add وَاهْ،\add* ثتّڭّمْ ڒَامَانْ نْومْ ذِي مَانْ أَيَا،
\v 13 س ؤُيَا أَذْ ثِيڒِي ڒْمُوعْصِييّثْ-أَ إِ كنِّيوْ أَمْ ثَازِّيثْ \add ذِي ڒْحِيضْ\add* إِ غَا إِوْضَانْ، نِّي إِضهَّارنْ ذِي ڒْحِيضْ يُوعْڒَانْ، أَقَا ثَارژِّيثْ نّسْ أَذْ د-ثَاسْ ذغْيَا، ذڭْ إِشْثْ ن ثشْثِي. \x ◘ \xo 30:‏13 \xt إِشا. 29‏:‏5\x*
\v 14 أَذْ ث يَارْژْ أَمْ إِتّْوَارْژْ إِجّْ ن ؤُغَارَّافْ ن بُو-ثْڒَاخْثْ نْهْڒَا أَحِينِّي. جَارْ مَارَّا إِفثْوِيثنْ نّسْ وَارْ إِتّْوَافْ \add عَاذْ\add* ؤُڒَا ذ إِجّْ ن ؤُشقُّوفْ عَاذْ إِ زِي د غَا يَاوْينْ ثِيمسِّي زِي ڒْمجْمَارْ نِيغْ أَذْ أَيْمنْ أَمَانْ زِي جُّوبْ.‘ “ \x ◘ \xo 30:‏14 \xt إِرْم. 19‏:‏11\x*
\b
\s1 تُّوبثْ ثتَّاوِي-د أَحِينِّي ذ ؤُسْڭنْفِي زِي أَربِّي
\m 
\v 15 ”مَاغَارْ أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي، أَمْقدَّاسْ ن إِسْرَائِيل: ’س تُّوبثْ ذ ڒْهُوذْنثْ أَذْ غَارْومْ يِيڒِي ؤُسنْجمْ، ذِي ثْرُوسِي ذ ڒَامَانْ أَذْ غَارْومْ يِيڒِي جّهْذْ، مَاشَا كنِّيوْ وَارْ ثخْسمْ.‘
\v 16 كنِّيوْ ثقَّارمْ: ’لَّ، خْ ييْسَانْ نخْسْ أَذْ نَارْوڒْ!‘ خْ ؤُيَا \add س ؤُغِيڒْ\add* أَذْ ثَاروْڒمْ. ؤُشَا \add ثقَّارمْ عَاوذْ\add*: ’خْ إِيْسَانْ ن حَامَاثْ نخْسْ أَذْ نِّييْ \add إِ ثَاروْڒَاثْ\add*!‘ خْ ؤُيَا أَذْ قدْجْقنْ ؤُڒَا ذ إِمْسضْفَارنْ نْومْ!
\v 17 إِجّْ نْ ڒُوڒُوفْ أَذْ يَارْوڒْ إِ ؤُهذِّي ن يِيجّْ \add ن ورْيَازْ\add*. إِ ؤُهذِّي ن خمْسَا أَذْ ثَاروْڒمْ مَارَّا أَڒْ غَا ثقِّيممْ أَمْ ثْسنْيَانْثْ ن ؤُشنْيَالْ خْ ثْقِيشّثْ ن وذْرَارْ، أَمْ ثْعدْجَانْثْ خْ ثوْرِيرْثْ.“ \x ◘ \xo 30:‏17 \xt إِشا. 17‏:‏6؛ 24‏:‏6، 13\x*
\m 
\v 18 ”س ؤُيَا أَذْ رَاجَا سِيذِي مَاحنْذْ أَذْ أَومْ إِسّْشنْ أَحِينِّي نّسْ، س ؤُينِّي أَذْ إِڭعّذْ سنّجْ أَڒَامِي إِ غَا يَارْحمْ كنِّيوْ \add أَوَارْنِي مَانْ أَيَا\add*، مَاغَارْ سِيذِي ذ أَربِّي ن ڒْحقّْ. سّعْذْ ن مَارَّا إِنِّي ث إِتّْرَاجَانْ. \x ◘ \xo 30:‏18 \xt إِزهد. 2‏:‏12؛ 34‏:‏9؛ أَوڒن. 16‏:‏20؛ إِرْم. 17‏:‏7\x*
\v 19 مَاغَارْ ڒْڭنْسْ أَذْ إِزْذغْ ذِي صِيهْيُونْ، ذِي ؤُرْشَالِيمْ. شكْ وَارْ ثتّْرُوذْعمَّارْصْ عَاذْ، نتَّا أَذْ خَاكْ إِحِينّْ، مَاڒَا إِسْڒَا إِ ثْمِيجَّا نّشْ ثتّْڒَاغَا، أَذْ خَاكْ د-يَارّْ.
\v 20 سِيذِي إِنُو أَذْ أَومْ إِوْشْ أَغْرُومْ ذِي ڒحْصَارثْ ؤُڒَا ذ أَمَانْ ذِي ڒغْبنْ، إِمسْغَارنْ نّشْ وَارْ إِتّْنُوفَّارنْ \add عَاذْ\add*، \add مَاشَا\add* ثِيطَّاوِينْ نّشْ أَذْ ژَترنْثْ إِمسْغَارنْ نّشْ.
\v 21 إِمزُّوغنْ نّشْ أَذْ سْڒنْ إِ وَاوَاڒْ زِي غَارْ ضفَّارْ نّشْ إِ إِقَّارنْ: ’أَقَا أَبْرِيذْ، ؤُيُورمْ ذَايسْ. وَارْ تّفّْغمْ يفُوسْ ؤُڒَا ذ أَزڒْمَاضْ.‘
\m 
\v 22 أَذْ ثْحسْبمْ إِشلّلنْ إِ إِتّْوَاڭّنْ س نُّوقَارْثْ نّشْ ن ڒخْيَاڒَاثْ نّشْ إِنقْشنْ ؤُڒَا ذ أَڒحّفْ ن وُورغْ ن ڒخْيَاڒَاثْ نّشْ إِفسْينْ ذ ثخْمُوجِي. أَذْ ثنْ ثنْضَارذْ أَمْ وَارُّوضْ ثسّخْمجْ إِ-ث \add ثمْغَارْثْ إِ خْ دْجَانْ\add* إِذَامّنْ، أَذْ ثِينِيذْ: ’غَارْ بَارَّا!‘ “
\m 
\v 23 ”\add خنِّي\add* أَذْ إِوْشْ نتَّا أَنْژَارْ إِ زَّارِيعثْ نّشْ إِ ثْزَارْعذْ ذڭْ إِيَّارْ ؤُڒَا ذ أَغْرُومْ ذ صَّابثْ ن ثمُّورْثْ نّشْ. \bd ذڭْ وَاسّْ نِّي\bd* أَذْ ثهْذَا ثْحِيمَارْثْ نّشْ خْ دّْمَانِي إِسَارّْحنْ.
\v 24 إِينْذُوزنْ ذ يغْيَاڒْ إِمژْيَاننْ، إِنِّي إِشَارّْزنْ ثَامُّورْثْ، أَذْ شّنْ ڒعْڒفْ إِردّْ إِ زُوزَّارنْ س دْجُوحْ ذ ثزَّارْثْ.
\v 25 خْ كُوڒْ أَذْرَارْ ؤُ خْ كُوڒْ ثَاوْرِيرْثْ إِڭعّْذنْ أَذْ إِڒِينْثْ ثِيغزْرَاثِينْ ذ ثْمِيزَابِينْ شُّورنْ س وَامَانْ، ذڭْ وَاسّْ ن ثْغَارْصْثْ ثَامقّْرَانْثْ، خْمِي غَا وْضَانْ صُّومْعَاثْ.
\v 26 ثَافَاوْثْ ن ثْزِيرِي أَذْ ثِيڒِي أَمْ ثْفَاوْثْ ن ثْفُوشْثْ ؤُشَا ثَافَاوْثْ ن ثْفُوشْثْ أَذْ ثِيڒِي ثجْهذْ سبْعَا ن ثْسقَّارْ خْ ثْفَاوْثْ ن سبْعَا ن وُوسَّانْ، ذڭْ وَاسّْ إِ ذِي إِ غَا إِشْفنْ سِيذِي ثَارژِّيثْ ن ڒْڭنْسْ نّسْ ؤُشَا أَذْ إِسّْڭنْفَا أَيزِّيمْ ن ثشْثِي إِ إِوْثَا نتَّا.“
\b
\s1 ڒْحُوكْمْ إِ د غَا يَاسنْ خْ أَشُّورْ
\m 
\v 27 ”خْزَارْ، إِتَّاسْ-د إِسمْ ن سِيذِي زِي ڒَاڭّْوَاجْ، يَارقّْ وغْضَابْ نّسْ ؤُ أَسِيڭّْوذْ إِمْغَارْ، شُّورنْ إِينْشِيشنْ نّسْ س وسْخضْ ؤُ إِڒسْ نّسْ إِڭَّا أَمْ ثْمسِّي إِتّتّنْ.
\v 28 أَسُوضِي ن نّفْسْ نّسْ أَمْ يغْزَارْ إِسّفْينْ، إِتَّاكّْوَاضنْ أَڒْ إِرِي، مَاحنْذْ أَذْ إِزُّوزَارْ ڒڭْنُوسْ س ثَازَّارْثْ ن ؤُردّدْجْ، ؤُ مَاحنْذْ أَذْ يڭّْ إِ ڒڭْنُوسْ سْڒِيمثْ ن ؤُغَارِّي خْ إِغسْمَارنْ نْسنْ.“ \x ◘ \xo 30:‏28 \xt إِشا. 8‏:‏8\x*
\m 
\v 29 ”أَذْ غَارْومْ يِيڒِي إِجّْ ن إِزْڒِي، أَمْ ذِي دْجِيڒثْ نِّي ذِي إِسّوْجذْ بْنَاذمْ إِخفْ نّسْ إِ ڒْعِيذْ، ؤُڒَا ذ ڒفْرَاحثْ ذڭْ وُوڒْ أَمْ غَارْ إِجّنْ إِڭُّورنْ ؤُمِي إِژمَّارْ ذِي ثمْجَا مَاحنْذْ أَذْ د-يَاسْ غَارْ وذْرَارْ ن سِيذِي، غَارْ ثصْضَارْثْ ن إِسْرَائِيل.
\v 30 سِيذِي أَذْ يجّْ أَذْ سْڒنْ إِ ثْمِيجَّا نّسْ يُوعْڒَانْ ؤُشَا أَذْ إِسّْشنْ مَامّشْ غَا إِهْوَا ؤُغِيڒْ نّسْ أَكْ-ذ وسْخضْ ن وغْضَابْ ذ ثْمسِّي إِتّحْذُوذُوقنْ إِتّتّنْ، أَذُوقّزْ ن ونْژَارْ ذ ڒْحَاڒْ ن ونْژَارْ ذ إِبْقُوقنْ ن ثبْرُورِي.
\v 31 مَاغَارْ أَشُّورْ أَذْ يَارْجِيجْ س ثْمِيجَّا ن سِيذِي خْمِي \add ث\add* غَا إِوّثْ نتَّا س وعْمُوذْ نّسْ.
\v 32 قَاعْ ثْوَاڒَا إِعدُّو خَاسْ وعْمُوذْ ن ؤُسڭّذْ، \add أَعْمُوذْ\add* نِّي خَاسْ إِسَّارْسْ سِيذِي، \add أَقَا\add* ذ مَانْ أَيَا أَذْ يِيڒِي غَارْ \add ثِينخْثْ ن\add* إِبنْذِيرنْ ذ \add سْنِيثْرَاثْ ن\add* ڒْڭَامْبْرِييَّاثْ، \add مَاغَارْ\add* نتَّا أَكِيذْسنْ إِمّْنغْ س إِغَادْجنْ إِتّنْهزَّانْ.
\v 33 مَاغَارْ زڭْ وشْحَاڒْ ؤُيَا إِوْجذْ \add ومْشَانْ إِ\add* نّْعِي نِّي، إِوْجذْ ؤُڒَا إِ ؤُجدْجِيذْ. إِڭَّا إِ-ث يُودْجغْ ذ ؤُمِيرِيوْ. أَقلِّيجْ نّسْ ن ثْمسِّي ذ ؤُكشُّوضْ ذ أَمقّْرَانْ. ثْوَارِّيثْ ن نّفْسْ ن سِيذِي أَذْ ث إِقدّْ أَمْ يغْزَارْ ن ڒشْبَارِييّثْ.“
\b
\b
\c 31
\s1 وَارْ تّشْڒمْ خْ مِيصْرَا
\m 
\v 1 ”\bd ؤُشْثْ\bd* خْ يِينِّي د-إِهْوَانْ غَارْ مِيصْرَا حِيمَا أَذْ أَفنْ ثْوِيزَا، إِنِّي إِتّشْڒنْ خْ ييْسَانْ ؤُ تّڭّنْ ڒَامَانْ ذڭْ إِكَارُّوثنْ، مِينْزِي نِيثْنِي ذڭْ وَاطَّاسْ، ؤُڒَا خْ يِينِّي إِنْيِينْ خْ ييْسَانْ، مِينْزِي نِيثْنِي جّهْذنْ، \add أَخْمِي\add* وَارْ خزَّارنْ غَارْ ؤُمْقدَّاسْ ن إِسْرَائِيل ؤُ وَارْ أَرزُّونْ سِيذِي.“ \x ◘ \xo 31:‏1 \xt إِزهد. 20‏:‏8؛ إِرْم. 17‏:‏5\x*
\m 
\v 2 ”\add مَاشَا\add* ؤُڒَا ذ نتَّا ذ أَمِيغِيسْ، نتَّا ڭُّورْ أَذْ يجّْ ڒْغَارْ أَذْ د-يَاسْ. وَارْ إِتّْذِيكّْوِيڒْ ذڭْ وَاوَاڒْ نّسْ، أَذْ إِكَّارْ ضِيدّْ إِ ثَادَّارْثْ ن إِعفَّاننْ ؤُ ضِيدّْ إِ ثْوِيزَا ن يِينِّي إِتّڭّنْ ڒْمُوعْصِييّثْ.
\v 3 \add مَاغَارْ\add* إِمِيصْرِييّنْ ذ إِوْذَانْ، وَارْ دْجِينْ ذ أَربِّي، ؤُشَا إِيْسَانْ نْسنْ ذ أَيْسُومْ، وَارْ إِدْجِي ذ أَرُّوحْ. أَذْ إِسَارّحْ سِيذِي أَفُوسْ نّسْ \add أَڒْ\add* إِ غَا إِنْقَارْضْ ونِّي إِوْشِينْ أَفُوسْ، ؤُشَا \add خنِّي\add* أَذْ إِوْضَا ؤُڒَا ذ ونِّي ذَايسْ إِوْشِينْ أَفُوسْ. \add أَمُّو\add* إِ غَا قْضَانْ نِيثْنِي مَارَّا إِذْسنْ.“
\m 
\v 4 ”مَاغَارْ أَمُّو إِ ذ أَيِي إِنَّا سِيذِي: ’أَمْ مَامّشْ إِتَّارُّوجْذُوذْ وَايْرَاذْ نِيغْ وَايْرَاذْ أَمژْيَانْ خْ زَّارْذثْ نّسْ خْمِي خَاسْ د-تّْڒَاغَانْ إِجّْ ن ؤُبَارُّو ن إِمكْسَاونْ، بْڒَا مَا أَذْ إِنّخْڒعْ زِي ثْمِيجَّا نْسنْ ؤُ وَارْ إِخنّسْ زڭْ ؤُبَارُّو نْسنْ، أَمُّو إِ غَا إِهْوَا ؤُڒَا ذ سِيذِي ن ڒْعسْكَارَاثْ حِيمَا أَذْ إِمّْنغْ خْ وذْرَارْ ن صِيهْيُونْ ؤُ خْ ثوْرِيرْثْ نّسْ. \f ◼ \fr 31:‏4 \ft \bd ’إِمكْسَاونْ‘\bd* - نِيغْ ’إِنِيتْشَانْ‘.\f*
\v 5 أَمْ يِيجْضَاضْ إِتّْفَارْفِيرنْ \add سنّجْ إِ ڒْعُوشّْ نْسنْ\add*، أَمُّو إِ غَا إِسّڒْقَا سِيذِي ن ڒْعسْكَارَاثْ خْ ؤُرْشَالِيمْ. أَذْ ت إِسَّارْ، أَذْ ت إِسّنْجمْ، أَذْ \add خَاسْ\add* يكّْ ؤُشَا أَذْ ت إِسّنْجمْ.“ \x ◘ \xo 31:‏5 \xt أَعَوذ. 32‏:‏11\x*
\m 
\v 6 ”ذوْڒمْ-د غَارْ ونِّي خْ حيّْذنْ أَيْثْ ن إِسْرَائِيل س وَاطَّاسْ.
\v 7 مَاغَارْ \bd ذڭْ وَاسّْ نِّي\bd* أَذْ إِمّنْضَارْ كُوڒْ إِجّْ لْ-أَصْنَامْ نّسْ ن نُّوقَارْثْ ذ لْ-أَصْنَامْ نّسْ ن وُورغْ، إِنِّي يڭِّينْ إِفَاسّنْ نْومْ إِ يِيخفْ نْومْ، \add إِ\add* دّنْبْ. \x ◘ \xo 31:‏7 \xt إِشا. 2‏:‏20\x*
\v 8 أَشُّورْ أَذْ إِوْضَا س سِّيفْ، وَارْ إِدْجِي \add سِّيفْ\add* ن إِجّْ ن ورْيَازْ. أَذْ ث يشّْ سِّيفْ، وَارْ إِدْجِي ن إِجّْ ن بْنَاذمْ. أَذْ يَارْوڒْ أَشُّورْ زَّاثْ إِ سِّيفْ ؤُشَا إِحُوذْرِييّنْ نّسْ أَذْ ذوْڒنْ غَارْ ثسْمُوغِي.
\v 9 ثَاصْضَارْثْ نّسْ أَذْ ثڭّْوجْ س ثِيڭّْوُوذِي ؤُشَا ڒْحُوكَّامْ نّسْ أَذْ أَروْڒنْ زِي ثْعدْجَانْثْ!‘، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، ونِّي غَارْ ثدْجَا ثْمسِّي ذِي صِيهْيُونْ ؤُڒَا ذ ثَافْقُونْثْ ذِي ؤُرْشَالِيمْ.“ \x ◘ \xo 31:‏9 \xt 2 إِج. 19‏:‏36، 37\x*
\b
\b
\c 32
\s1 أَجدْجِيذْ أَمْسڭّذْ إِ ذ غَا يَاسنْ
\m 
\v 1 ”خْزَارْ، إِجّْ ن ؤُجدْجِيذْ أَذْ إِحْكمْ ذِي ثْسڭْذَا ؤُ ڒْحُوكَّامْ أَذْ حكْمنْ س ڒْحقّْ. \x ◘ \xo 32:‏1 \xt إِزهد. 45‏:‏7؛ زَاك. 9‏:‏9\x*
\v 2 أَرْيَازْ نِّي أَذْ يِيڒِي أَمْ يِيجّْ ن ؤُذُورِّي زڭْ ونْژَارْ، أَمْ ثْسدَّارْثْ إِسّْڒقَّانْ زِي ثْحَارْيَاضْثْ، أَمْ ثْغزْرَاثِينْ ن وَامَانْ ذِي ثمُّورْثْ يُوژْغنْ، أَمْ ثِيڒِي ن إِجّْ ن جَّارْفْ إِذقْڒنْ ذِي ثمُّورْثْ إِتّْفَاذَانْ.
\v 3 ثِيطَّاوِينْ ن يِينِّي إِتّْوَاڒَانْ وَارْ تّْبلِّيعنْثْ \add عَاذْ\add*، ؤُ إِمزُّوغنْ ن يِينِّي إِتّسْڒَانْ أَذْ سّْحسّنْ \add عَاوذْ\add*، \x ◘ \xo 32:‏3 \xt إِشا. 29‏:‏18؛ 30‏:‏21\x*
\v 4 ؤُڒْ ن إِمْقدْجْقنْ أَذْ يِيڒِي إِحطَّا \add عَاوذْ\add* مَاحنْذْ أَذْ يَافْ ثُوسّْنَا، ؤُ إِڒسْ ن يِينِّي إِسّْثوْثِيونْ إِزمَّارْ أَذْ إِسِّيوڒْ عَاوذْ س ڒْفَارْزْ.
\m 
\v 5 أَبُوهَاڒِي وَارْ ذ أَسْ تّْڒِيغِينْ \add عَاذْ\add* ’أَمْشنّعْ!‘، ؤُشَا ونِّي إِشمّْثنْ وَارْ ذ أَسْ قَّارنْ \add عَاذْ\add* ’مِّيسْ ن ڒْخِيرْ!‘
\v 6 مَاغَارْ أَبُوهَاڒِي إِسَّاوَاڒْ ثُوبُّوهڒْيَا ؤُ ؤُڒْ نّسْ إِتّڭّْ ڒْمُوعْصِييّثْ ؤُمِي نتَّا إِتّڭّْ أَفُوشّحْ ؤُ إِتّْشقّفْ ذِي سِيذِي، ؤُ ؤُمِي إِتّجِّي ڒعْمَارْ ن ونِّي إِدْجُوژنْ أَذْ إِقِّيمْ إِخْوَا، ذ ونِّي إِفُّوذنْ وَارْ ث إِتّجِّي أَذْ إِسُو.
\v 7 ثَاحْرَايْمشْثْ ن ؤُشمَّاثْ ثْعفّنْ. نتَّا إِتّْخَارّصْ ذِي ڒفْضِيحثْ حِيمَا أَذْ إِغْضڒْ إِنِّي إِتّْوَاحْصَارنْ س وَاوَاڒنْ إِخَارِّيقنْ، \add وَاخَّا\add* أَمزْڒُوضْ إِشَّاثْ خْ ڒْحقّْ \add نّسْ\add*.
\v 8 \add مَاشَا\add* أَمْشنّعْ أَذْ إِخَارّصْ ذڭْ إِنْوَاينْ إِشنّْعنْ، أَذْ إِكَّارْ ذِي طّْوعْ ن مِينْ إِشنّْعنْ.“
\b
\m 
\v 9 ”كَّارنْثْ، \add كنِّينْثْ\add* ثِيمْغَارِينْ وَارْ ذِي إِدْجِي ومْنُوسْ، سْڒنْثْ إِ ثْمِيجَّا إِنُو، \add أَ كنِّينْثْ\add* ثِيحنْجِيرِينْ إِتّْشَاڒنْ خْ سِيمَانْثْ نْكنْثْ، سْڒنْثْ غَارْ وَاوَاڒْ إِنُو!
\v 10 أَوَارْنِي وُوسَّانْ نِيغْ أَسڭّْوَاسْ، \add خنِّي\add* أَذْ ثَارْجِيجنْثْ، \add أَ\add* كنِّينْثْ إِ إِتّْشَاڒنْ خْ يِيخفْ نْكنْثْ، مَاغَارْ أَذْ ثقْضَا صَّابثْ ن ؤُضِيڒْ، وَارْ إِتِّيڒِي وڒْقَاضْ عَاذْ.
\v 11 قفْقْفنْثْ، \add أَ كنِّينْثْ\add* نْبْڒَا أَمْنُوسْ، أَرْجِيجنْثْ، \add كنِّينْثْ\add* ثِينِّي إِتّْشَاڒنْثْ خْ يِيخفْ نْكنْثْ، كّْسنْثْ أَرُّوضْ، عَارْيْننْثْ، \add خنِّي\add* بيْسنْثْ ثِيجْعِينَّاثِينْ نْكنْثْ \add س وَارُّوضْ ن وشْضَانْ\add*.“
\m 
\v 12 ”أَذْ وْثنْثْ نِيثنْثِي ذڭْ إِذْمَارنْ س إِڭجْذُورنْ خْ إِحْوِيشنْ إِعِيزّنْ، خْ ثْزَايَارِينْ إِسّغْمَاينْ.
\v 13 أَذْ ڭعّْذنْ إِسنَّاننْ ذ ثْزڭّْوَارْثْ خْ ثمُّورْثْ ن ڒْڭنْسْ إِنُو، \add وَاهْ،\add* خْ مَارَّا ثُوذْرِينْ ن ڒفْرَاحثْ ذِي ثنْذِينْثْ إِنڭّْزنْ س ؤُسْڒوْڒِيوْ.
\v 14 مَاغَارْ ڒقْصَارْ أَذْ إِتّْوَاجّْ، دّْرِيزْ ن ثنْذِينْثْ أَذْ إِبْكمْ، \add ثَاوْرِيرْثْ ن\add* ’عُوفِيلْ‘ ذ لْبُورْجْ ن ثْعسَّاسْثْ أَذْ ذوْڒنْ ذ إِفْرَانْ إِ ڒبْذَا، ذ أَمْشَانْ ن ڒفْرَاحثْ مَانِي تّمْزُوعْبُوضنْ إِغْيَاڒْ ن ڒخْڒَا، ذ دّْمَانِي إِ ثْحِيمْرِيوِينْ.
\v 15 أَڒْ غَا إِتّْوَافَارّغْ خَانغْ أَرُّوحْ زِي سنّجْ.“
\m ”\add خنِّي\add* أَذْ إِذْوڒْ ڒخْڒَا ذ ڒْعِيرْسْثْ إِصبْحنْ ؤُ ڒْعِيرْسْثْ إِصبْحنْ أَذْ ثتّْوَاحْسبْ ذ أَزْغَارْ. \f ◼ \fr 32:‏15 \ft \bd ’أَزْغَارْ‘\bd* - نِيغْ ’ڒْغَابثْ‘ نِيغْ ’ثَازْڭَانْثْ‘.\f*  \x ◘ \xo 32:‏15 \xt إِشا. 29‏:‏17؛ يُووِ. 3‏:‏1؛ يُوح. 7‏:‏37، 38؛ ڒخ. 2‏:‏17، 18\x*
\v 16 ڒْحقّْ أَذْ إِزْذغْ ذِي ڒخْڒَا ؤُشَا ثَاسڭْذَا أَذْ ثقِّيمْ ذڭْ إِيَّارْ إِسّغْمَاينْ.
\v 17 مِينْ د-إِتَّاوْينْ ثَاسڭْذَا أَذْ يِيڒِي ذ ڒهْنَا ؤُشَا ڒْغِيدْجثْ ن ثْسڭْذَا أَذْ ثِيڒِي ذ ڒْهُوذْنثْ ذ ڒَامَانْ إِ ڒبْذَا.
\v 18 ڒْڭنْسْ إِنُو أَذْ إِزْذغْ ذڭْ ومْشَانْ ن ڒهْنَا، ذِي ثْزذِّيغِينْ ذَايْسنْثْ ڒَامَانْ ؤُ ذڭْ إِمُوشَانْ ذَايْسنْ أَرَّاحثْ.“ \x ◘ \xo 32:‏18 \xt إِرْم. 33‏:‏16\x*
\m 
\v 19 ”أَذْ ثشَّاثْ ثْبْرُورِّي أَڒْ د غَا ثسّهْوَا أَزْغَارْ ؤُشَا ثَانْذِينْثْ أَذْ ثهْوَا ذِي ڒوْضَا.“ \f ◼ \fr 32:‏19 \ft \bd ’أَزْغَارْ‘\bd* - نِيغْ ’ڒْغَابثْ‘ نِيغْ ’ثَازْڭَانْثْ‘.\f*
\m 
\v 20 ”سّعْذْ ن كنِّيوْ إِنِّي إِزَارّْعنْ غَارْ مَارَّا ثِيغزْرَاثِينْ، إِنِّي \add ذِينْ\add* إِندّْهنْ إِضَارنْ ن ؤُفُونَاسْ ذ وغْيُوڒْ!“
\b
\b
\c 33
\s1 ڒحْصَارثْ ن ؤُرْشَالِيمْ ذ ؤُسنْجمْ نّسْ
\m 
\v 1 ”\bd ؤُشْثْ\bd* خَاكْ، \add أَ\add* أَمْثحَّايْ، \add شكْ ذ\add* ونِّي \add سِيمَانْثْ نّسْ\add* وَارْ إِتّْوَاثحِّي، \add شكْ ذ\add* ونِّي إِتّْكشّْضنْ، وَاخَّا نِيثْنِي وَارْ شكْ كشّْضنْ. مَاڒَا ثْكمّْڒذْ أَثحِّي نّشْ، أَذْ ثتّْوَاثحِّيذْ \add سِيمَانْثْ نّشْ\add*، مَاڒَا ثْكمّْڒذْ ثَاكشَّاضْثْ، أَذْ ثتّْوَاكشّْضذْ \add سِيمَانْثْ نّشْ\add*.“
\b
\m 
\v 2 ”\add أَ\add* سِيذِي، حِينّْ خَانغْ، أَقَا نسِّيثِيمْ أَشْ. إِڒِي ذ أَغِيڒْ نْسنْ \add إِجهْذنْ\add* ذِي كُوڒْ صّْبحْ، وَاهْ، ذِي ڒْوقْثْ ن ڒحْسَارثْ إِڒِي ذ أَسنْجمْ نّغْ.“
\b
\m 
\v 3 ”خْ ڒْحسّْ ن زّْهِيرْ أَذْ أَروْڒنْ ڒڭْنُوسْ. مَاڒَا شكْ ثسّْڭعّْذذْ إِخفْ نّشْ أَذْ تّْوَازدْجْعنْ ڒڭْنُوسْ غَارْ مَارَّا إِغزْذِيسَا.
\v 4 \add خنِّي\add* أَذْ ثتّْوَاكّسْ زَّارْذثْ نْومْ، أَمْ ثْمُورْغِي إِصَارّْضنْ تّكّْسنْثْ \add صَّابثْ\add*. أَمْ تَّازّْڒنْثْ ثْمُورْغِي سَّا ذ سَّا، أَمُّو إِ تَّازّْڒنْ ؤُڒَا ذ نِيثْنِي غَارْ زَّارْذثْ.“
\m 
\v 5 ”إِتّْوَاسُّوعْڒَا سِيذِي مَاغَارْ نتَّا إِزدّغْ قَاعْ سنّجْ. نتَّا إِشُّورْ صِيهْيُونْ س ڒْحقّْ ذ ثْسڭْذَا.
\v 6 أَذْ يِيڒِي ڒَامَانْ \add خْمِي إِ غَا يِيڒِينْثْ\add* ڒْمِيجَاڒَاثْ ن ڒْوقْثْ نّشْ، إِجّْ ن ؤُبَارُّو ن إِسنْجَامنْ، ثِيغِيثْ ذ ثُوسّْنَا. أَذْ ثِيڒِي ثِيڭّْوُوذِي ن سِيذِي ذ ڒْكنْزْ نّسْ.“
\m 
\v 7 ”خْزَارْ، إِنِّي ذَايْسنْ ثَارْيَاسْثْ أَمشْنَاوْ أَيْرَاذْ سْغُويُّونْ بَارَّا، \add وَاهْ،\add* إِرقَّاسنْ ن ڒهْنَا تّْرُونْ س إِمطَّاونْ إِمرْزَاڭنْ.
\v 8 إِبْرِيذنْ إِسڭّْمنْ تّْوَاجّنْ، ونِّي إِنُّومنْ أَذْ يكّْ خْ ؤُمسْرُوقْ، إِسْمحْ ذَايسْ. أَقَا يَارْژَا ڒْعَاهْذْ، إِسّحْقَارْ ثِيندَّامْ، وَارْ إِحسّبْ بْنَاذمْ.
\v 9 ثشْضنْ ؤُ ثِيسْڒَاوْ ثمُّورْثْ. لُوبْنَانْ إِسضْحَا، يُوژغْ. \add ڒوْضَا إِسّغْمَاينْ ن\add* شَارُونْ ثذْوڒْ ذ ڒخْڒَا ؤُشَا بَاشَانْ ذ كَارْمَالْ تّْسدْجْضنْ \add أَفَارْ نْسنْ\add*.“
\b
\m 
\v 10 ”ڒخُّو أَذْ كَّارغْ، ڒخُّو أَذْ تّْوَاسّْڭعّْذغْ، ڒخُّو أَذْ تّْوَاسّْعُودْجغْ، إِقَّارْ سِيذِي.“
\b
\m 
\v 11 ”كنِّيوْ ثكْسِيمْ دّيْسثْ س ؤُڒُومْ، أَذْ ثَارْومْ إِغدْجْ. بُوحْبڒْ نْومْ ذ ثِيمسِّي إِ كنِّيوْ غَا يشّنْ.
\v 12 ڒڭْنُوسْ أَذْ ذوْڒنْ أَمْ جَّارْ سَّارْغنْ ث، أَمْ ڒْحَارَّاشْ س إِسنَّاننْ إِتّْوَاقسّنْ أَذْ ثنْ سّْشمْضنْ س ثْمسِّي.
\v 13 كنِّيوْ \add إِ إِدْجَانْ\add* ذِي ڒَاڭّْوَاجْ، سْڒمْ مِينْ ڭِّيغْ، ؤُشَا كنِّيوْ ذِي ڒَاذَاسْ، سْنمْ صُّولْطَا إِنُو!
\v 14 إِمذْنَابْ ذِي صِيهْيُونْ تّڭّْوذنْ، إِمْنَافْقنْ تّْقفْقَافنْ، قَّارنْ: ’مَانْ ونْ زَّايْنغْ إِزمَّارْ أَذْ إِزْذغْ ذِي ثْمسِّي إِتّتّنْ، مَانْ ونْ زَّايْنغْ إِزمَّارْ أَذْ إِزْذغْ ذِي ڒْحَاذُوقْ ن ڒبْذَا؟‘ “
\m 
\v 15 ”ونِّي إِڭُّورنْ ذِي ثْسڭْذَا ؤُ إِقَّارْ ڒْحقّْ، ونِّي إِنْضَارنْ أَرْبحْ س ؤُبعّجْ، ونِّي إِمنّْعنْ إِفَاسّنْ نّسْ زڭْ وُوضُوفْ ن ثرْزِيفِينْ ن أَرّشْوثْ، ونِّي إِتّْبلَّاعنْ أَمزُّوغْ نّسْ معْلِيكْ يُوفَا أَذْ إِسڒْ خْ ؤُسِيزّڒْ ن إِذَامّنْ، ونِّي إِتّقّْننْ ثِيطَّاوِينْ نّسْ معْلِيكْ يُوفَا أَذْ إِثْوَاڒَا مِينْ إِدْجَانْ ذ أَعفَّانْ، \x ◘ \xo 33:‏15 \xt إِزهد. 15‏:‏2؛ 24‏:‏3\x*
\v 16 ذ وَانِيثَا إِ غَا إِزذْغنْ خْ ڒڭْعُوذِي. لْقلْعَاثْ ذِي ڒجْرُوفْ أَذْ إِڒِينْثْ لْبُورْجْ نّسْ يُوعْڒَانْ، أَذْ أَسْ إِمّوْشْ وغْرُومْ نّسْ، أَمَانْ نّسْ أَذْ تّْوَاضمْننْ.
\v 17 ثِيطَّاوِينْ نّشْ أَذْ ثْوَاڒَانْثْ أَجدْجِيذْ ذڭْ وژْرِي نّسْ، نِيثنْثِي أَذْ ژَترنْثْ إِشْثْ ن ثمُّورْثْ ذَايسْ تَّاسِيعْ أَطَّاسْ.
\v 18 ؤُڒْ نّشْ أَذْ إِعْقڒْ خْ ؤُسْنخْڒِيعْ. مَانِي إِدْجَا ؤُمَارِيرْ؟ مَانِي إِدْجَا ونِّي إِوزْننْ؟ مَانِي إِدْجَا ونِّي إِسّطّنْ لْبُورْجَاثْ؟
\v 19 شكْ وَارْ ثْژَارّذْ عَاذْ ڒْڭنْسْ إِقسْحنْ \add نِّي\add*، ڒْڭنْسْ س يِيڒسْ إِذقْڒنْ أَڒَامِي وَارْ إِزمَّارْ أَذْ أَسْ إِسڒْ \add بْنَاذمْ\add*، \add ڒْڭنْسْ\add* نِّي إِسّْطوْطِيونْ س يِيڒسْ أَڒَامِي وَارْ إِزمَّارْ أَذْ أَسْ إِفْهمْ \add ؤُڒَا ذ إِجّْ\add*.“
\m 
\v 20 ”خْزَارْ غَارْ صِيهْيُونْ، ثَانْذِينْثْ ن ؤُمُونِيثنْ نّغْ. ثِيطَّاوِينْ نّشْ أَذْ ژَترنْثْ ؤُرْشَالِيمْ، ثَازذِّيغْثْ نِّي ذِي إِدْجَا ڒَامَانْ، أَقِيضُونْ إِ وَارْ سّْمُوطُّوينْ، إِ زِي ڒوْثَاذْ نّسْعمَّارْصْ أَذْ تّْوَاقڒْعنْ ؤُڒَا ذ إِمُورَارْ نّسْ وَارْ تّْوَاقطَّاسنْ. \x ◘ \xo 33:‏20 \xt إِزهد. 46‏:‏6؛ 125‏:‏1، 2\x*
\v 21 مَاغَارْ ذِينِّي أَذْ غَارْنغْ يِيڒِي سِيذِي س ڒْعزّْ. أَيَا أَذْ يِيڒِي ذ أَمْشَانْ ن إِغزْرَانْ ذ ثْسدْجْيَاوِينْ إِمِيرِيونْ. وَارْ خَاسنْ نذْهنْ إِغَارُّوبَا إِمقّْرَاننْ ن ڒمْقَاذفْ، ؤُڒَا ذ إِجّْ ن ؤُغَارَّابُو س ڒجْوَاذْ أَذْ \add ذِينْ\add* إِعْذُو.
\v 22 مِينْزِي سِيذِي ذ ڒْقَاضِي نّغْ، سِيذِي ذ أَمْڭوَّاذْ نّغْ، سِيذِي ذ أَجدْجِيذْ نّغْ. نتَّا أَذْ أَنغْ إِسّنْجمْ.“
\m 
\v 23 ”\add ڒخُّو مَاشَا\add* أَرْخُونْ إِسغْوَانْ نّمْ، وَارْ منّْعنْ \add عَاذْ\add* ثِيسنْيَانِينْ ذڭْ ؤُضَارْ نّسْ، وَارْ تّْبزَّاعنْ \add عَاذْ\add* ڒْبَاشّْ. \add مَاشَا\add* ذِي ڒْوقْثْ نِّي أَذْ ثتّْوَابْضَا زَّارْذثْ ثَامقّْرَانْثْ، \add عَاذْ\add* إِنعْضَابْ أَذْ كشّْضنْ ثَاكشَّاضْثْ.
\v 24 ؤُڒَا ذ إِجّْ ن ؤُمزْذُوغْ أَذْ يِينِي: ’نشّْ هڒْشغْ!‘، \add مَاغَارْ\add* ڒْڭنْسْ إِ ذَايسْ إِزدّْغنْ، أَذْ \add أَسْ\add* إِتّْوَاغْفَارْ ڒْمُوعْصِييّثْ.“
\b
\b
\c 34
\s1 ڒْحُوكْمْ ن أَربِّي خْ إِذُومْ
\m 
\v 1 ”قَارّْبمْ-د، \add أَ\add* ڒڭْنُوسْ، مَاحنْذْ أَذْ ثسْڒمْ، \add كنِّيوْ أَ،\add* شُّوعُوبْ، أَرّمْ-د ڒْبَاڒْ! سڒْ، \add أَ\add* ثَامُّورْثْ ذ مَارَّا مِينْ ذَايسْ، دُّونشْثْ ذ مَارَّا مِينْ زَّايسْ د-إِسّْفُوفُّوينْ.
\v 2 مَاغَارْ أَذُوقّزْ \add ن وغْضَابْ\add* ن سِيذِي \add أَذْ د-يَاسْ\add* خْ مَارَّا ڒڭْنُوسْ ؤُ أَسْعَارْ خْ مَارَّا ڒْعسْكَارْ نْسنْ. نتَّا إِحَارّمْ إِ-ثنْ \add إِ ؤُثحِّي\add*، أَقَا إِڭَّا إِ-ثنْ إِ ثْغَارْصْثْ.
\v 3 إِنِّي زَّايْسنْ إِتّْوَانْغنْ أَذْ ثنْ نْضَارنْ، ؤُشَا أَرِّيحثْ ن ڒْخشْبَاثْ نْسنْ أَذْ ثْڭعّذْ. أَذْ فسْينْ إِذُورَارْ س إِذَامّنْ نْسنْ.
\v 4 مَارَّا ڒْعسْكَارْ ن ؤُجنَّا أَذْ إِفْنَا ؤُشَا إِجنْوَانْ أَذْ تّْوَانّْضنْ أَمْ وذْلِيسْ إِتّْوَانّْضنْ ؤُ أَذْ إِوْضَا مَارَّا ڒْعسْكَارْ نْسنْ أَمْ وَافَارْ خْ ثْزَايَارْثْ ؤُ أَمْ مَامّشْ د-ثوْضَا ثَازَارْثْ زڭْ وَارْثُو.“ \x ◘ \xo 34:‏4 \xt أَسَا. 6‏:‏13، 14\x*
\m 
\v 5 ”مَاغَارْ سِّيفْ إِنُو أَذْ إِتّْوَاژَارْ ذڭْ إِجنْوَانْ. خْزَارْ، أَذْ د-إِهْوَا خْ إِذُومْ ؤُ خْ ڒْڭنْسْ نِّي حَارّْمغْ قَاعْ إِ ڒْحُوكْمْ.
\v 6 سِّيفْ ن سِيذِي إِشُّورْ س إِذَامّنْ، إِذْوڒْ إِتّحْرُودْجُوضْ س ثَاذُونْثْ، س إِذَامّنْ ن إِزْمَارنْ ذ إِغَايْضنْ، س ثَاذُونْثْ ن ثِيژَّاڒْ ن إِشَارِّييّنْ، مَاغَارْ سِيذِي إِڭَّا إِجّْ ن ڒْعِيذْ ن ثْغَارْصْثْ ذِي بُوصْرَا، ذ إِشْثْ ن ثْغَارْصْثْ ثَامقّْرَانْثْ ذِي ثمُّورْثْ ن إِذُومْ. \f ◼ \fr 34:‏6 \ft \bd ’ثِيژَّاڒْ‘\bd* - نِيغْ ’ثِيڭژْڒِينْ‘.\f*  \x ◘ \xo 34:‏6 \xt إِشا. 63‏:‏1، 2\x*
\v 7 أَذْ كِيذْسنْ وْضَانْ إِغَايْضنْ ن ڒخْڒَا أَكْ-ذ وَاشَّاونْ نْسنْ ذ إِزِيرَارنْ، ؤُشَا ؤُڒَا ذ إِفُونَاسنْ إِمژْيَاننْ \add جْمِيعْ\add* أَكْ-ذ \add إِفُونَاسنْ\add* إِجهْذنْ ؤُشَا ثَامُّورْثْ نْسنْ أَذْ ثْسُو إِذَامّنْ ؤُ أَشَاڒْ \add ن ثمُّورْثْ\add* أَذْ إِجّْونْ س ثَاذُونْثْ.
\v 8 مَاغَارْ أَذْ يِيڒِي إِجّْ ن وَاسّْ ن نّقْمثْ إِ سِيذِي، إِجّْ ن ؤُسڭّْوَاسْ ن ؤُخدْجصْ إِ دّعْوثْ ن صِيهْيُونْ.
\v 9 ثِيغْزَارِينْ ن إِذُومْ أَذْ ذوْڒنْثْ ذ ثِيزفْثْ ؤُ أَشَاڒْ نّسْ أَذْ إِذْوڒْ ذ ڒشْبَارِييّثْ، \add وَاهْ،\add* ثَامُّورْثْ نّسْ أَذْ ثذْوڒْ ذ ثِيزفْثْ يَارقّنْ.
\v 10 وَارْ تّْخسِّي \add ثْمسِّي نّسْ\add* سْ دْجِيڒثْ ؤُڒَا س وَاسّْ، دّخَّانْ نّسْ أَذْ إِڭعّذْ إِ ڒبْذَا. زِي جِّيڒْ أَڒْ جِّيڒْ أَذْ ثِيڒِي \add ثمُّورْثْ\add* ثتّْوَاردّدْجْ، إِ ڒبْذَا ن ڒبْذَاثْعمَّارْصْ وَارْ ت إِژْوِي ؤُڒَا ذ إِجّْ. \x ◘ \xo 34:‏10 \xt أَسَا. 14‏:‏11؛ 19‏:‏3\x*
\v 11 بُو-ؤُعُوقِّي ذ ثْوُوشْثْ نْ دْجِيڒثْ أَذْ ت طّْفنْ ذ ثَاسْغَارْثْ، بُو-ؤُسُوضِي \add ن ڒْموْثْ\add* ذ ؤُبَاغڒْ أَذْ ذَايسْ زذْغنْ. نتَّا أَذْ خَاسْ إِمْحضْ أَفِيڒُو ن ڒعْبَارْ ن ڒخْڒَا ؤُ أَذْ إِسَّارْسْ بْلُومُو ن ڒْخَاوِي. \x ◘ \xo 34:‏11 \xt إِشا. 13‏:‏21، 22؛ صَاف. 2‏:‏14؛ أَسَا. 18‏:‏2\x*
\v 12 ثَارْوَا نّسْ ن ثَاصِيڒثْ؟ وَارْ ذِينْ ثدْجِي بُو ثْڭلْذَا أَڒَامِي زَّايسْ إِ غَا بَارّْحنْ ؤُ مَارَّا ڒْحُوكَّامْ نّسْ قْضَانْ.
\v 13 ذِي ڒقْصُورْ نّسْ أَذْ إِڭعّذْ شْبَارْقْ أَكْ-ذ إِسنَّاننْ، إِرزَّازنْ ذ ثَابْغَا ن ؤُسنَّانْ أَذْغمْينْ ذِي لْقلْعَاثْ نّسْ. ثَامُّورْثْ أَذْ ثذْوڒْ ذ ثَازذِّيغْثْ إِ وُوشَّاننْ ن ڒخْڒَا، ذ إِجّْ ن وحْوِيشْ إِ يسِّيسْ ن نّْعَامثْ.
\v 14 ڒوْحُوشْ ن ڒخْڒَا أَذْ مّڒْقَانْ أَكْ-ذ إِفِيسنْ ؤُشَا أَمْيَانْ \add إِجنّنْ\add* أَذْ إِڒَاغَا إِ ؤُمْعَاشَارْ نّسْ، وَاهْ، ڒْوحْشْ ن دْجِيڒثْ أَذْ يَاريّحْ ذِينِّي، أَذْ يَافْ أَغِيمِي إِ يِيخفْ نّسْ.
\v 15 ذِينِّي أَذْ ثسَّارْسْ ثْفِيغَارْثْ ن فْڒِيثْشَا ڒْعُوشّْ نّسْ، أَذْ ثسَّارْسْ ثِيمدْجَاڒِينْ، أَذْ ثنْثْ ثسّْفْرُورِييْ ؤُشَا ذِي ثِيڒِي نّسْ أَذْ ثْهِيلَّا \add ذڭْ إِمژْيَاننْ نّسْ\add*، وَاهْ، ذِينِّي أَذْ مُوننْ إِجْضَاضْ إِتّْكشَّاضنْ.
\v 16 أَرْزُومْ ذڭْ وذْلِيسْ ن سِيذِي ؤُ غَارمْ زَّايسْ: ’ؤُڒَا ذ إِجّْ \add زِي ڒوْحُوشْ-أَ\add* إِزمَّارْ أَذْ زَّايسْ إِنْقصْ، ؤُڒَا ذ إِجّْ وَارْ يَارزُّو خْ وعْشِيرْ نّسْ!‘، مَاغَارْ أَقمُّومْ إِنُو يُورَا إِ-ث، ؤُشَا أَرُّوحْ نّسْ ذ ونِّي ثنْ إِ غَا إِسّْمُوننْ.
\v 17 نتَّا سِيمَانْثْ نّسْ إِنْضَارْ ثَاقدُّوحْثْ ذِي طّْوعْ نْسنْ، ؤُشَا أَفُوسْ نّسْ إِبْضَا أَسنْ ثَامُّورْثْ س ؤُفِيڒُو نْ ڒعْبَارْ. نِيثْنِي أَذْ ت وَارْثنْ إِ ڒبْذَا، زِي جِّيڒْ أَڒْ جِّيڒْ أَذْ ذَايسْ زذْغنْ.“
\b
\b
\c 35
\s1 نّقْمثْ ن أَربِّي أَذْ د-ثَاوِي أَسنْجمْ
\m 
\v 1 ”أَذْ إِفَارْحْ ڒخْڒَا ذ ثمُّورْثْ يُوژْغنْ، أَذْ ثسْڒِيوْڒوْ ڒوْضَا، أَذْ ثْنوَّارْ أَمْ ثْنوَّاشْثْ وَارْ زَّايسْ وْضَانْثْ ثِيفْرَايْعمَّارْصْ.
\v 2 أَذْ ثْنوَّارْ أَذْ ثْشُووَّارْ، \add وَاهْ،\add* أَذْ ثسْڒوْڒِيوْ \add ڒوْضَا\add* س ڒفْرَاحثْ ذ ؤُسْڒِيوْڒوْ. أَذْ أَسْ إِمّوْشْ ؤُعُودْجِي ن لُوبْنَانْ، ڒْعزّْ ن كَارْمِيلْ ؤُ \add ن ڒوْضَا ن\add* شَارُونْ. نِيثْنِي أَذْ ژَترنْ أَعُودْجِي ن سِيذِي، ڒْعزّْ ن أَربِّي نّغْ.“
\m 
\v 3 ”سْمحْضمْ إِفَاسّنْ أَرْخُونْ ؤُ سْجهْذمْ إِفَادّنْ إِتّمْرَايْوَانْ. \x ◘ \xo 35:‏3 \xt عبر. 12‏:‏12\x*
\v 4 إِنِيمْ إِ يِينِّي غَارْ إِدْجَا ؤُڒْ إِڭّْوذْ: ’إِڒِيمْ ذ إِرْيَازنْ، وَارْ تّڭّْوذمْ! خْزَارمْ، أَربِّي نْومْ أَذْ إِخْڒفْ، أَذْ د-يَاسْ وخْڒَافْ ن أَربِّي، نتَّا أَذْ د-يَاسْ س يِيخفْ نّسْ، أَذْ كنِّيوْ إِسّنْجمْ.‘
\v 5 خنِّي أَذْ نُّورْزْمنْثْ ثِيطَّاوِينْ ن إِضَارْغَاڒنْ ؤُشَا أَذْ تّْوَارزْمنْ إِمزُّوغنْ ن إِذُوهْشَارْ. \x ◘ \xo 35:‏5 \xt مت. 9‏:‏27؛ 11‏:‏5؛ 12‏:‏22؛ 20‏:‏30؛ 21‏:‏14؛ يُوح. 9‏:‏6\x*
\v 6 خنِّي أَذْ إِنْڭزْ ؤُقِيذَارْ أَمْ ؤُذَاذْ ؤُشَا إِڒسْ ن ؤُزِينُونْ أَذْ إِسْڒِيوْڒوْ، مَاغَارْ أَذْ دُّوقّْزنْ وَامَانْ ذِي ڒخْڒَا ؤُڒَا ذ ثِيغْزَارِينْ ذِي ڒوْضَا. \x ◘ \xo 35:‏6 \xt مت. 9‏:‏32؛ 11‏:‏5؛ 15‏:‏30؛ 21‏:‏14؛ يُوح. 5‏:‏8، 9؛ 7‏:‏38، 39؛ ڒخ. 3‏:‏2؛ 8‏:‏7؛ 14‏:‏8\x*
\v 7 ثَامُّورْثْ يُوژْغنْ أَذْ ثذْوڒْ ذ سَّارِيجْ ؤُ ثَامُّورْثْ إِفُّوذنْ ذ ثَاڒَاوِينْ إِتّْبقْبُوقنْ. ذِي ثمُّورْثْ ن وُوشَّاننْ ن ڒخْڒَا، مَانِي أَرّيْحنْ، أَذْ يِيڒِي أَرْبِيعْ أَكْ-ذ ؤُغَانِيمْ ذ وزْرَافْ.“
\m 
\v 8 ”أَذْ ذِينْ يِيڒِي إِجّْ ن وبْرِيذْ إِسڭّْمنْ، أَبْرِيذْ نِّي إِ غَا ڒَاغَانْ ’أَبْرِيذْ أَمْقدَّاسْ!‘. ؤُڒَا ذ إِجّْ ن ؤُمخْمُوجْ وَارْ خَاسْ إِڭُّورْ، \add مَاشَا\add* أَذْ يِيڒِي إِ نِيثْنِي: مَانْ ونْ مَا إِڭُّورنْ خْ وبْرِيذْ-أَ، \add عَاذْ\add* إِبُوهَاڒِييّنْ وَارْ تّْوذِّيرِينْ.
\v 9 وَارْ ذِينِّي إِتِّيڒِي وَايْرَاذْ، \add وَاهْ،\add* وَارْ خَاسْ إِتّْڭِيعِّيذْ نِيغْ أَذْ إِتّْوَافْ ذِينْ ؤُڒَا ذ إِجّْ ن ڒْوحْشْ إِتّْشَارّڭْ، \add مَاشَا\add* إِنِّي إِتّْوَافكّنْ أَذْ خَاسْ ؤُيُورنْ.
\v 10 إِنِّي إِتّْوَاصڒْحنْ زِي سِيذِي أَذْعقْبنْ، أَذْ د-أَسنْ سْڒِيوْڒِيونْ غَارْ صِيهْيُونْ. ڒفْرَاحثْ ن ڒبْذَا \add أَذْ ثَارْسَا\add* خْ إِزدْجِيفنْ نْسنْ. أَفَارّجْ ذ ڒفْرَاحثْ أَذْ غَارْسنْ أَوْضنْ، أَشْضَانْ ذ وسْحِيسّفْ أَذْ \add زَّايْسنْ\add* أَروْڒنْ.“ \x ◘ \xo 35:‏10 \xt أَسَا. 21‏:‏4\x*
\b
\b
\c 36
\s1 أَهُوذِّي ن سَانْحَارِيبْ ضِيدّْ إِ ؤُرْشَالِيمْ
\m 
\v 1 ذڭْ ؤُسڭّْوَاسْ وِيسّْ أَرْبعْطَاشْ ن ؤُجدْجِيذْ حِيزْقِييَا إِڭعّذْ سَانْحَارِيبْ، أَجدْجِيذْ ن أَشُّورْ، خْ مَارَّا ثِيندَّامْ إِفَارْينْ ن يَاهُوذَا ؤُشَا إِحوّسْ إِ-ثنْثْ.
\v 2 إِسكّْ ؤُجدْجِيذْ ن أَشُّورْ أَكُومَانْذَارْ ن ڒْعسْكَارْ زِي لَاخِيشْ غَارْ ؤُرْشَالِيمْ غَارْ ؤُجدْجِيذْ حِيزْقِييَا، أَكْ-ذ إِجّْ ن ڒْعسْكَارْ ذ أَمقّْرَانْ أَطَّاسْ. نتَّا إِبدّْ غَارْ ؤُقَاذُوسْ ن وَامَانْ ن ؤُيڒْمَامْ ن سنّجْ، ونِّي \add إِدْجَانْ\add* غَارْ وبْرِيذْ أَمقّْرَانْ غَارْ وحْوِيشْ ن ؤُصبَّانْ. *
\b
\m 
\v 3 \add خنِّي\add* إِفّغْ غَارسْ أَلْيَاقِيمْ، مِّيسْ ن حِيلْقِييَا، ڒمْقدّمْ ن ثْزذِّيغْثْ \add ن ؤُجدْجِيذْ\add* أَكْ-ذ ؤُمَارِيرْ شِيبْنَا ذ يُووَاخْ، مِّيسْ ن أَسَافْ، أَمَارِيرْ ن ؤُمزْرُويْ.
\v 4 إِنَّا أَسنْ ؤُكُومَانْذَارْ ن ڒْعسْكَارْ: ”إِنِيمْ خنِّي إِ حِيزْقِييَا: أَمُّو إِ إِقَّارْ ؤُجدْجِيذْ أَمقّْرَانْ، أَجدْجِيذْ ن أَشُّورْ: ’مَانْ أَثشْڒِي وَا إِ خْ ثتَّاشْڒذْ؟
\v 5 نِّيغْ أَشْ، أَقَا-ث ذ ڒْهَارْذْ ن إِينْشِيشنْ وَاهَا. ذڭْ ؤُمنْغِي إِتّْخصَّا شّْوَارْ ذ ثْزمَّارْ. مَانْ ونْ خْ ثتَّاشْڒذْ ڒخُّو، أَقَا شكْ ثْغوّْغذْ خَافِي؟
\v 6 خْزَارْ، ثتّشْڒذْ خْ مِيصْرَا، خْ ؤُغَانِيمْ نِّي إِنّْضفْسنْ ونِّي إِتّجُّونْ ذڭْ ؤُفُوسْ نّسْ ؤُمِي حذْ خَاسْ إِ غَا إِعمّذْ، ؤُشَا \add خنِّي\add* إِسّْنُوقّبْ إِ-ث. أَمُّو \add إِ إِدْجَا\add* فِيرْعُونْ، أَجدْجِيذْ ن مِيصْرَا، إِ مَارَّا إِنِّي خَاسْ إِتَّاشْڒنْ. \x ◘ \xo 36:‏6 \xt حِز. 29‏:‏6، 7\x*
\v 7 مَاڒَا كنِّيوْ أَذْ ذ أَيِي ثِينِيمْ: نشِّينْ نتَّاشڒْ خْ سِيذِي، أَربِّي نّغْ!، \add خنِّي نشّْ أَذْ إِنِيغْ:\add* مَا نتَّا وَارْ إِدْجِي ذ ونِّي زِي إِحيّذْ حِيزْقِييَا ڒڭْعُوذِي ذ إِعَالْطَارنْ ؤُ \add خنِّي\add* إِنَّا إِ يَاهُوذَا ذ ؤُرْشَالِيمْ: أَذْ ثْبنْذْقمْ زَّاثْ إِ ؤُعَالْطَارْ-أَ ذِي ؤُرْشَالِيمْ؟‘
\v 8 خنِّي ڒخُّو، أڭّْ إِجّْ ن ؤُمْحَارّمْ أَكْ-ذ سِيذِي إِنُو، أَجدْجِيذْ ن أَشُّورْ: ’نشّْ أَذْ أَشْ وْشغْ أَڒْفَاينْ ن إِيْسَانْ مَاڒَا شكْ زڭْ ؤُغزْذِيسْ نّشْ أَذْ أَسنْ-د ثَاوْيذْ إِمْنَاينْ.‘
\v 9 مَامّشْ ثخْسذْ شكْ أَذْ ثنْقڒْبذْ خْ وُوذمْ ن لْوَالِي، ونِّي قَاعْ ذ أَمژْيَانْ ن إِمْسخَّارنْ ن سِيذِي إِنُو، ؤُشَا أَذْ ثتّشْڒذْ خْ مِيصْرَا ذِي سِّيبّثْ ن إِكَارُّوثنْ ذ إِمْنَاينْ؟
\v 10 \add خنِّي\add* ڒخُّو، مَا نشّْ ڭعّْذغْ-د ضِيدّْ ن ومْشَانْ-أَ حِيمَا أَذْ ث أَردّْدْجغْ بْڒَا سِيذِي؟ سِيذِي إِنِي أَيِي: ’ڭعّذْ ضِيدّْ إِ ثمُّورْثْ-أَ، أَردّدْجْ إِ-ت.‘ “
\m 
\v 11 ؤُشَا إِنَّا أَلْيَاقِيمْ، مِّيسْ ن حِيلْقِييَا، أَكْ-ذ شِيبْنَا ذ يُووَاخْ إِ ؤُكُومَانْذَارْ ن ڒْعسْكَارْ: ”سِيوڒْ عَافكْ س ثْرَامِيثْ أَكْ-ذ إِمْسخَّارنْ نّشْ، مِينْزِي نفْهمْ أَسْ مْلِيحْ. وَارْ كِيذْنغْ سِّيوِيڒْ س ثْيَاهُوذشْثْ ذڭْ إِمزُّوغنْ ن ڒْڭنْسْ \add إِ إِدْجَانْ\add* خْ ڒْحِيضْ.“
\m 
\v 12 \add مَاشَا\add* أَكُومَانْذَارْ ن ڒْعسْكَارْ إِنَّا: ”مَا إِسّكّْ أَيِي-د سِيذِي إِنُو غَارْ سِيذِي نّشْ ؤُ غَاركْ \add وَاهَا\add* حِيمَا أَذْ سِّيوْڒغْ أَوَاڒنْ-أَ، وَارْ إِدْجِي غَارْ يرْيَازنْ نِّي إِقِّيمنْ خْ ڒْحِيضْ، \add مَاحنْذْ أَذْ إِنِيغْ\add* أَقَا أَثنْ \add جْمِيعْ\add* أَكِيذْومْ أَذْ شّنْ أَسُوفّغْ نْسنْ ؤُ أَذْ سْونْ إِبشِّيشنْ نْسنْ؟“ \x ◘ \xo 36:‏12 \xt 2 إِج. 18‏:‏27\x*
\v 13 خنِّي إِكَّارْ ؤُكُومَانْذَارْ، إِڒَاغَا س جّْهذْ س ثْيَاهُوذشْثْ، إِسِّيوڒْ، إِنَّا: ”سْڒمْ إِ وَاوَاڒنْ ن ؤُجدْجِيذْ أَمقّْرَانْ، أَجدْجِيذْ ن أَشُّورْ!
\v 14 أَمُّو إِ إِقَّارْ ؤُجدْجِيذْ: ’حْضَامْ وَارْ كنِّيوْ إِتّْغشِّي حِيزْقِييَا مِينْزِي نتَّا وَارْ إِزمَّارْ أَذْ كنِّيوْ إِفكّْ.
\v 15 وَارْ تّجِّيمْ حِيزْقِييَا أَذْ كنِّيوْ يَارّْ أَذْ ثثشْڒمْ خْ سِيذِي، أَذْ ثِينِيمْ: سِيذِي أَذْ أَنغْ إِسّنْجمْ نِيشَانْ ؤُ وَارْ ثتّْموْشِي ثنْذِينْثْ ذڭْ إِفَاسّنْ ن ؤُجدْجِيذْ ن أَشُّورْ.
\v 16 وَارْ تّسْڒِيمْ شَا غَارْ حِيزْقِييَا، مَاغَارْ أَمُّو إِ إِقَّارْ ؤُجدْجِيذْ ن أَشُّورْ: ڭّمْ أَيِي أَرَّايْ ؤُشَا فّْغمْ-د \add زِي ثنْذِينْثْ\add* غَارِي، \add خنِّي\add* إِزمَّارْ كُوڒْ إِجّنْ زَّايْومْ أَذْ إِشّْ زِي ثْزَايَارْثْ نّسْ ؤُ كُوڒْ إِجّنْ زڭْ وَارْثُو ن ثَازَارْثْ نّسْ ؤُ كُوڒْ إِجّنْ أَذْ إِسُو أَمَانْ زڭْ وَانُو نّسْ،
\v 17 أَڒْ د غَا يَاسغْ ؤُ أَذْ كنِّيوْ أَوْيغْ غَارْ إِشْثْ ن ثمُّورْثْ أَمْ ثمُّورْثْ نْومْ: غَارْ إِشْثْ ن ثمُّورْثْ ثشُّورْ س إِمنْذِي ذ بِينُو ن جْذِيذْ، غَارْ إِشْثْ ن ثمُّورْثْ ثشُّورْ س وغْرُومْ ؤُ س إِمَارْجَاعنْ ن ؤُضِيڒْ.
\v 18 وَارْ تّجِّيمْ حِيزْقِييَا أَذْ كنِّيوْ إِغَارّْ خْمِي إِقَّارْ: سِيذِي أَذْ أَنغْ إِفكّْ. مَا زمَّارنْ \add خنِّي\add* إِربِّيثنْ ن ڒڭْنُوسْ، كُوڒْ إِجّْ \add زَّايْسنْ\add*، أَذْ فكّنْ ثَامُّورْثْ نْسنْ زڭْ ؤُفُوسْ ن ؤُجدْجِيذْ ن أَشُّورْ؟
\v 19 مَانِي دْجَانْ إِربِّيثنْ ن حَامَاثْ ذ أَرْفَاذْ؟ مَانِي دْجَانْ إِربِّيثنْ ن سْفَارْوَايِيمْ؟ مَا سّْنجْمنْ نِيثْنِي خنِّي سَامَارْيَا زڭْ ؤُفُوسْ إِنُو؟
\v 20 مَانْ ونْ زِي مَارَّا إِربِّيثنْ ن ثمُّورَا-يَا إِسّنْجمْ ثَامُّورْثْ نّسْ زڭْ ؤُفُوسْ إِنُو أَڒَامِي غَا إِسّنْجمْ سِيذِي ؤُرْشَالِيمْ زڭْ ؤُفُوسْ إِنُو؟‘ “
\v 21 \add مَاشَا\add* نِيثْنِي سّغْذنْ، وَارْ خَاسْ د-أَرِّينْ س ؤُڒَا ذ إِجّْ ن وَاوَاڒْ، مَاغَارْ ڒُومُورْ ن ؤُجدْجِيذْ ثُوغَا إِقَّارْ: ”كنِّيوْ وَارْ خَاسْ د-ثَارِّيمْ شَا!“
\v 22 \add خنِّي\add* يُوسَا-د أَلْيَاقِيمْ، مِّيسْ ن حِيلْقِييَا، ڒمْقدّمْ ن ثْزذِّيغْثْ \add ن ؤُجدْجِيذْ\add*، أَكْ-ذ شِيبْنَا، أَمَارِيرْ، ذ يُووَاخْ، مِّيسْ ن أَسَافْ، أَمَارِيرْ ن ؤُمزْرُويْ، س وَارُّوضْ إِشَارّْڭنْ غَارْ حِيزْقِييَا. نِيثْنِي حَاجَانْ أَسْ \add مَارَّا\add* أَوَاڒنْ ن ؤُكُومَانْذَارْ ن ڒْعسْكَارْ.
\b
\b
\c 37
\s1 أَوَاڒْ أَمزْوَارُو خْ ؤُفكِّي ن ؤُرْشَالِيمْ إِ د غَا يَاسنْ
\m 
\v 1 ؤُمِي إِسْڒَا ؤُجدْجِيذْ حِيزْقِييَا أَيَا، إِشَارّڭْ أَرُّوضْ نّسْ، إِذْڒَا إِخفْ نّسْ س إِشْثْ ن ثْخَانْشثْ \add ن وشْضَانْ\add* ؤُشَا يُوذفْ غَارْ ثَادَّارْثْ ن سِيذِي. \x ◘ \xo 37:‏1 \xt [2 إِج. 29]\x*
\v 2 \add أَوَارْنِي أَسْ\add* إِسّكّْ نتَّا أَلْيَاقِيمْ، ڒمْقدّمْ ن ثْزذِّيغْثْ \add ن ؤُجدْجِيذْ\add*، ذ شَابْنَا، أَمَارِيرْ، ذ إِمْغَارنْ ن إِكهَّاننْ ذڭْ وَارُّوضْ ن ثْخُونْشَايْ \add ن وشْضَانْ\add* غَارْ ؤُنَابِي إِشَايَا، مِّيسْ ن أَمُوصْ.
\v 3 نِيثْنِي نَّانْ أَسْ: ”أَمُّو إِ إِقَّارْ حِيزْقِييَا: ’أَسّْ-أَ ذ إِجّْ ن وَاسّْ ن ڒحْصَارثْ ؤُ ن وعْقَابْ ؤُ ن ؤُبهْذڒْ، مَاغَارْ إِحنْجِيرنْ إِوْضنْ-د أَڒْ أَرْزَامْ ن ؤُعذِّيسْ \add ن يمَّاثْسنْ\add*، \add مَاشَا\add* وَارْ ذِينْ جّهْذْ إِ ثْوَارُوثْ. \x ◘ \xo 37:‏3 \xt 1 إِج. 19‏:‏3\x*
\v 4 أَذْ ثَاغْ سِيذِي، أَربِّي نّشْ، إِسْڒَا مَارَّا أَوَاڒنْ ن ؤُكُومَانْذَارْ ن ڒْعسْكَارْ ونِّي د-إِسّكّْ سِيذِيسْ، أَجدْجِيذْ ن أَشُّورْ، حِيمَا أَذْ إِسْثهْزَا زِي أَربِّي إِدَّارنْ، ؤُ \add أَذْ ثَاغْ\add* سِيذِي، أَربِّي نّشْ، أَذْ إِعَاقبْ أَوَاڒنْ نِّي إِسْڒَا. سْڭعّذْ \add خنِّي\add* إِشْثْ ن ثْژَادْجِيثْ ذِي طّْوعْ ن ڒْبَاقِي نِّي إِ غَا إِتّْوَافنْ \add عَاذْ\add*.‘ “
\m 
\v 5 \add أَمُّو\add* إِوْضنْ إِمْسخَّارنْ ن ؤُجدْجِيذْ حِيزْقِييَا غَارْ إِشَاعْيَا.
\v 6 إِنَّا أَسنْ إِشَاعْيَا: ”أَمُّو إِتّْخصَّا أَذْ ثِينِيمْ إِ سِيذِيثْومْ: ’أَمُّو إِ إِقَّارْ سِيذِي: وَارْ ثڭّْوذْ شَا زڭْ وَاوَاڒنْ إِ ثسْڒِيذْ، إِ زِي إِ ذ أَيِي شقّْفنْ إِحُوذْرِييّنْ ن ؤُجدْجِيذْ ن أَشُّورْ.
\v 7 خْزَارْ، نشّْ أَذْ ذَايسْ ڭّغْ إِجّْ ن بُوحْبڒْ ؤُ نتَّا أَذْ إِسڒْ إِجّْ ن ڒخْبَارْ ؤُشَا \add خنِّي\add* أَذْ إِعْقبْ غَارْ ثمُّورْثْ نّسْ ؤُ نشّْ أَذْ ث نْغغْ \add ذِينْ\add* ذِي ثمُّورْثْ نّسْ س سِّيفْ.‘ “
\b
\s1 سَانْحَارِيبْ إِعَاوذْ أَهُوذِّي نّسْ إِ ؤُرْشَالِيمْ
\m 
\v 8 \add خنِّي\add* إِعْقبْ-د ؤُكُومَانْذَارْ ن ڒْعسْكَارْ ؤُشَا يُوفَا أَجدْجِيذْ ن أَشُّورْ إِتّْمنْغَا أَكْ-ذ \add ثنْذِينْثْ ن\add* لِيبْنَا، مَاغَارْ إِسْڒَا أَقَا إِقْڒعْ إِقِيضَانْ نّسْ \add إِفّغْ\add* زِي لَاخِيشْ.
\v 9 \add ؤُمِي\add* إِسْڒَا أَقَا نَّانْ خْ ثِيرْهَاقَا، أَجدْجِيذْ ن كُوشْ: ”خْزَارْ، إِفّغْ-د حِيمَا أَكِيذكْ إِمّْنغْ!“، \add ؤُمِي\add* إِسْڒَا \add أَيَا\add*، إِسّكّْ \add عَاوذْ\add* إِرقَّاسنْ غَارْ حِيزْقِييَا، إِنَّا:
\v 10 ”أَمُّو إِ إِتّْخصَّا أَذْ ثسِّيوْڒمْ أَكْ-ذ حِيزْقِييَا، أَجدْجِيذْ ن يَاهُوذَا، أَذْ ثِينِيمْ: ’وَارْ تّجِّي أَذْ شكْ إِغْوَا أَربِّي نّشْ ونِّي خْ ثتّْشَاڒذْ أَمْ إِقَّارْ: ؤُرْشَالِيمْ وَارْ ثْوطِّي إِ ؤُجدْجِيذْ ن أَشُّورْ ذڭْ إِفَاسّنْ!
\v 11 خْزَارْ، ثسْڒِيذْ مِينْ ڭِّينْ إِجدْجِيذنْ ن أَشُّورْ أَكْ-ذ مَارَّا ثِيمُّورَا نّغْنِي، ثِينِّي حَارّْمنْ نِيثْنِي إِ ؤُثحِّي. مَا إِتّْغِيڒْ أَشْ أَذْ ثتّْوَاسّْنجْمذْ؟
\v 12 مَا فكّنْ ثنْ إِربِّيثنْ ن ڒڭْنُوسْ إِنِّي يَاردّْدْجنْ ڒجْذُوذْ إِنُو؟ جُوزَانْ ذ حَارَانْ ذ رْصِيفْ ذ أَيْثْ ن عَاذَانْ، إِنِّي \add ثُوغَا إِزدّْغنْ\add* ذِي ثَالَاسَّارْ؟
\v 13 مَانِي إِدْجَا ؤُجدْجِيذْ ن حَامَاثْ ذ ؤُجدْجِيذْ ن أَرْفَاذْ ذ ؤُجدْجِيذْ ن ثنْذِينْثْ ن سْفَارْوَايِيمْ ؤُڒَا ذ \add أَجدْجِيذْ ن\add* هَانَاعْ ذ عِيوَّا؟‘ “
\b
\s1 ثَاژَادْجِيثْ ن حِيزْقِييَا
\m 
\v 14 حِيزْقِييَا إِكْسِي ثِيبْرَاثِينْ زڭْ ؤُفُوسْ ن إِرقَّاسنْ ؤُشَا إِغْرِي ثنْثْ. \add خنِّي\add* إِڭعّذْ غَارْ ثَادَّارْثْ ن سِيذِي ؤُشَا إِبزّعْ إِ-ثنْثْ حِيزْقِييَا زَّاثْ إِ وُوذمْ ن سِيذِي.
\v 15 إِژُّودْجْ حِيزْقِييَا إِ سِيذِي، إِنَّا:
\v 16 ”\add أَ\add* سِيذِي ن ڒْعسْكَارَاثْ، أَربِّي ن إِسْرَائِيل، ونِّي إِتّْغِيمَانْ \add جَارْ\add* إِكِيرُوبنْ! شكْ، \add وَاهْ\add* شكْ وحّْذكْ ذ أَربِّي ن مَارَّا ثِيڭلْذِيوِينْ ن دُّونشْثْ. شكْ ثڭِّيذْ إِجنْوَانْ ذ ثمُّورْثْ. \f ◼ \fr 37:‏16 \ft \bd ’إِكِيرُوبنْ‘\bd* - إِشْثْ ن مَارْكَا ن لْمَالَاكَاثْ.\f*
\v 17 أوْشْ أَمزُّوغْ نّشْ، \add أَ\add* سِيذِي، أَرْزمْ ثِيطَّاوِينْ نّشْ ؤُشَا ثخْزَارذْ! سڒْ مَارَّا أَوَاڒنْ ن سَانْحَارِيبْ ونِّي د-إِسّكّْ نتَّا حِيمَا أَذْ إِعيّبْ أَربِّي إِدَّارنْ.
\v 18 ذ ثِيذتّْ، \add أَ\add* سِيذِي، إِجدْجِيذنْ ن أَشُّورْ قْضَانْ ثِيمُّورَا نِّي، خَارّْبنْ ثَامُّورْثْ نْسنْ
\v 19 ؤُ نْضَارنْ إِربِّيثنْ نْسنْ ذِي ثْمسِّي، مَاغَارْ ثُوغَا وَارْ دْجِينْ ذ إِربِّيثنْ، مَاشَا ذ ثِيمڭَّا ن ؤُفُوسْ ن يوْذَانْ وَاهَا، زڭْ ؤُكشُّوضْ ذ وژْرُو، ؤُشَا نِيثْنِي قْضَانْ ثنْ.
\v 20 ڒخُّو \add مَاشَا\add*، \add أَ\add* سِيذِي، أَربِّي نّغْ، سنْجمْ أَنغْ زڭْ ؤُفُوسْ نّسْ، مَاحنْذْ مَارَّا ثِيڭلْذِيوِينْ ن دُّونشْثْ أَذْ سّْننْ، \add أَ\add* سِيذِي، أَقَا شكْ وحّْذكْ ذ أَربِّي.“
\b
\s1 أَوَاڒْ وِيسّْ ثْنَاينْ خْ ؤُفكِّي ن ؤُرْشَالِيمْ إِ د غَا يَاسنْ
\m 
\v 21 \add خنِّي\add* إِسّكّْ إِشَاعْيَا، مِّيسْ ن أَمُوصْ، \add إِجّْ ن ؤُرقَّاسْ\add* غَارْ حِيزْقِييَا، إِنَّا: ”أَمُّو إِ إِقَّارْ سِيذِي، أَربِّي ن إِسْرَائِيل: ’نشّْ سْڒِيغْ س مِينْزِي ثژُّودْجذْ-د غَارِي خْ سَانْحَارِيبْ، أَجدْجِيذْ ن أَشُّورْ.
\v 22 وَا ذ أَوَاڒْ إِ خَاسْ إِنَّا سِيذِي: ’ثَاعْزَارْشْثْ، يدْجِيسْ ن صِيهْيُونْ، ثسّحْقَارْ إِ شكْ، نتَّاثْ ثسْثهْزَا زَّايكْ، يدْجِيسْ ن ؤُرْشَالِيمْ ثْهزّْ أَزدْجِيفْ أَوَارْنِي أَشْ.
\v 23 مَانْ ونْ ثْعيّْبذْ ؤُ ذِي مَانْ ونْ ثْشقّْفذْ، مَانْ ونْ غَارْ ثسّْڭعّْذذْ ثْمِيجَّا ؤُ خْ مَانْ ونْ إِ خفْ ثسّْڭعّْذذْ س نّْفَاخثْ ثِيطَّاوِينْ نّشْ؟ \add شكْ ثتّْغنَّانذْ\add* خْ ؤُمْقدَّاسْ ن إِسْرَائِيل!
\v 24 س ؤُقمُّومْ ن إِمْسخَّارنْ نّشْ ثذْعِيذْ سِيذِي إِنُو، ثنِّيذْ: س ؤُبَارُّو ن إِكَارُّوثنْ إِنُو ڭعّْذغْ إِذُورَارْ يُوعْڒَانْ، إِغزْذِيسنْ ن لُوبْنَانْ. نشّْ أَذْ زذْمغْ ثِيشجُّورَا نّسْ ن ثنْڭلْثْ يُوعْڒَانْ ؤُڒَا ذ ثِيشجُّورَا نّسْ إِشْنَانْ قَاعْ ن إِمرْزَا ؤُ نشّْ أَذْ د-أَسغْ أَڒْ ثَاقِيشَّاثْ نّسْ يُوعْڒَانْ قَاعْ، غَارْ وزْغَارْ ن ؤُمَارْجعْ نّسْ ن ؤُضِيڒْ. \f ◼ \fr 37:‏24 \ft \bd ’أَزْغَارْ‘\bd* - نِيغْ ’ڒْغَابثْ‘ نِيغْ ’ثَازْڭَانْثْ‘. \bd ’أَمضْزِي‘\bd* - نِيغْ ’أَمرْزِي‘، إِخْسْ أَذْ يِينِي ثَاشجَّارْثْ ن ؤُمضْزِي.\f*
\v 25 نشّْ غْزِيغْ \add أَنُوثنْ\add* ؤُ سْوِيغْ أَمَانْ. س ثْڒقَّا ن إِضَارنْ إِنُو سِّيژْغغْ مَارَّا إِغزْرَانْ ن مِيصْرَا!‘ “
\m 
\v 26 ”مَا وَارْ ثسْڒِيذْ أَقَا \add أَطَّاسْ\add* زڭْ وَامِي ڭِّيغْ مَانْ أَيَا ؤُشَا وْشِيغْ أَسْ ؤُذمْ ذڭْ وُوسَّانْ ن مشْحَاڒْ ؤُيَا؟ ڒخُّو جِّيغْ ث أَذْ د-إِفّغْ، أَقَا شكْ ذ ونِّي إِ غَا يَارّنْ ثِيندَّامْ إِفَارْينْ ذ ڒْخِيرْبَاثْ.
\v 27 إِمزْذَاغْ نْسنْ ثُوغَا أَرْخُونْ، أَرْژِينْ، سضْحَانْ. نِيثْنِي ثُوغَا أَثنْ أَمْ وفْسُو ذڭْ إِيَّارْ، \add أَمْ\add* ؤُغمُّويْ أَزِيزَا، \add أَمْ\add* ؤُڒُومْ خْ ثْزغْوِينْ، \add أَمْ\add* \add إِمنْذِي\add* إِشمْضنْ \add س ؤُسمِّيضْ\add* قْبڒْ إِ غَا إِفّغْ.
\v 28 \add مَاشَا\add* نشّْ سّْنغْ أَغِيمِي نّشْ ذ ؤُفُّوغْ نّشْ ذ ثْوَاسِيثْ نّشْ ذ ؤُغوّغْ نّشْ خَافِي.
\v 29 مِينْزِي شكْ ثْغوّْغذْ خَافِي ؤُ ثُوفّثْ نّشْ ثِيوضْ-د غَارْ إِمزُّوغنْ إِنُو، أَذْ أَشْ د-سّكّغْ إِشْثْ ن ثْسنَّارْثْ ذڭْ ونْزَارنْ ؤُ \add أَذْ ڭّغْ\add* إِشْثْ ن سْڒِيمثْ جَارْ إِينْشِيشنْ نّشْ ؤُ نشّْ أَذْ شكْ أَرّغْ خْ وبْرِيذْ إِ ذِي د-ثُوسِيذْ ذَا.“
\m 
\v 30 ”ثَا أَذْ أَشْ ثِيڒِي ذ ڒعْڒَامثْ: ذڭْ ؤُسڭّْوَاسْ-أَ أَذْ ثشّمْ مِينْ غَا إِغمْينْ س يِيخفْ نّسْ ؤُ ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْنَاينْ مِينْ زَّايسْ غَا إِغمْينْ عَاوذْ، مَاشَا ذڭْ ؤُسڭّْوَاسْ وِيسّْ ثْڒَاثَا أَذْ ثْزَارْعمْ ؤُ أَذْ ثمْجَارمْ، أَذْ ثژُّومْ ثِيزَايَارِينْ ذڭْ إِمَارْجَاعنْ ؤُشَا أَذْ ثشّمْ ڒْغِيدْجثْ نّسْ.
\v 31 مَاغَارْ مِينْ إِنجْمنْ، مِينْ إِقِّيمنْ زِي ثَادَّارْثْ ن يَاهُوذَا، أَذْ إِوّثْ عَاوذْ إِژوْرَانْ غَارْ سْوَادَّايْ ؤُ سنّجْ أَذْ يَاوِي ڒْغِيدْجثْ.
\v 32 مَاغَارْ زِي ؤُرْشَالِيمْ أَذْ د-إِفّغْ مِينْ إِقِّيمنْ ؤُ زڭْ وذْرَارْ ن صِيهْيُونْ أَذْ إِفّغْ مِينْ إِ غَا إِنّجْمنْ، أَسَامْ \add إِقدّْسنْ\add* ن سِيذِي ن ڒْعسْكَارَاثْ أَذْ ت إِڭّْ.“
\m 
\v 33 ”س ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي خْ ؤُجدْجِيذْ ن أَشُّورْ: ’نتَّا وَارْ د-إِتِّيذفْ شَا غَارْ ثنْذِينْثْ-أَ ؤُ وَارْ ذَايسْ إِشِّيثْ شَا ؤُڒَا ذ إِشْثْ ن فْڒِيثْشَا ؤُ وَارْ غَارسْ د-إِقَارّبْ شَا س ؤُڒَا ذ إِشْثْ ن ثْسدَّارْثْ \add ن ؤُعسْكَارِي\add* ؤُ وَارْ خَاسْ إِتّْبقِّيضْ ؤُڒَا ذ إِجّْ ن لْبَارَاجْ إِ ڒحْصَارثْ.
\v 34 خْ وبْرِيذْ إِ خْ د-يُوسَا، أَذْ د-إِعْقبْ. وَارْ إِتِّيذِيفْ شَا غَارْ ثنْذِينْثْ-أَ، إِقَّارْ سِيذِي.
\v 35 نشّْ أَذْ سّڒْقِيغْ خْ ثنْذِينْثْ-أَ حِيمَا أَذْ ت سّْنجْمغْ ذِي طّْوعْ إِنُو ؤُ ذِي طّْوعْ ن ؤُمْسخَّارْ إِنُو ذَاوُوذْ.‘ “ \x ◘ \xo 37:‏35 \xt 2 إِج. 20‏:‏6\x*
\b
\s1 أَفكِّي ن ؤُرْشَالِيمْ
\m 
\v 36 خنِّي إِفّغْ لْمَالَاكْ ن سِيذِي ؤُشَا إِنْغَا مْيَا ؤُ-خمْسَا ؤُ-ثْمنْيِينْ-أَڒفْ \add ن يرْيَازنْ\add* ذِي ڒْمَارْڭحْ ن ڒْعسْكَارْ ن أَشُّورْ. ؤُمِي د-كَّارنْ نِيثْنِي ثِيوشَّا نّسْ، خْزَارْ، أَقَا أَثنْ مَارَّا إِذْسنْ ذ ڒْخشْبَاثْ. \x ◘ \xo 37:‏36 \xt 2 إِج. 19‏:‏35\x*
\m 
\v 37 ؤُشَا إِفْسِي سَانْحَارِيبْ، أَجدْجِيذْ ن أَشُّورْ، إِقِيضَانْ نّسْ، إِرُوحْ، إِعْقبْ \add غَارْ ثمُّورْثْ نّسْ\add*. إِقِّيمْ إِزدّغْ ذِي نِينْوَا.
\v 38 ؤُمِي إِسْجذْ \add إِجّْ ن وَاسّْ\add* ذِي ثَادَّارْثْ ن أَربِّي نّسْ نِيسْرُوخْ، إِمْسَارْ، أَقَا إِحنْجِيرنْ نّسْ أَذْرَامِّيلِيكْ ذ شَارَاصَارْ نْغِينْ ث س سِّيفْ. نِيثْنِي أَروْڒنْ غَارْ ثمُّورْثْ ن أَرَارَاثْ. مِّيسْ أَسَارْحَادُّونْ إِذْوڒْ ذ أَجدْجِيذْ ذڭْ ومْشَانْ نّسْ.
\b
\b
\c 38
\s1 ڒهْڒَاشْ ذ ؤُسْڭنْفِي ن حِيزْقِييَا
\m 
\v 1 ذڭْ وُوسَّانْ نِّي إِحْڒشْ حِيزْقِييَا س إِجّْ ن ڒحْڒَاشْ إِنقّنْ. يُوسَا-د غَارسْ ؤُنَابِي إِشَاعْيَا، مِّيسْ ن أَمُوصْ، إِنَّا أَسْ: ”أَمُّو إِ إِقَّارْ سِيذِي: ’أوْشْ ڒُومُورَاثْ إِ ثَادَّارْثْ نّشْ، مَاغَارْ أَذْ ثمّْثذْ، وَارْ ثتّْغِيمِيذْ ثدَّارذْ \add عَاذْ كْثَارْ\add*.‘ “
\v 2 \add خنِّي\add* إِنّقْڒبْ حِيزْقِييَا س ؤُغمْبُوبْ نّسْ غَارْ ڒْحِيضْ ؤُشَا إِژُّودْجْ غَارْ سِيذِي،
\v 3 إِنَّا: ”أَ، سِيذِي، عْقڒْ أَقَا نشّْ ؤُيُورغْ زَّاثْ إِ وُوذمْ نّشْ س ڒَامَانْ ؤُ س يِيجّْ ن وُوڒْ إِكمّْڒنْ ؤُ ڭِّيغْ مِينْ إِدْجَانْ نِيشَانْ ذِي ثِيطَّاوِينْ نّشْ.“ ؤُشَا إِبْذَا حِيزْقِييَا إِتّْرُو س جّْهذْ.
\m 
\v 4 يُوسَا-د وَاوَاڒْ ن سِيذِي غَارْ إِشَاعْيَا، إِنَّا:
\v 5 ”ؤُيُورْ، إِنِي إِ حِيزْقِييَا: ’أَمُّو إِ إِقَّارْ سِيذِي، أَربِّي ن بَابَاشْ ذَاوُوذْ: نشّْ سْڒِيغْ إِ ثْژَادْجِيثْ نّشْ ؤُ ژْرِيغْ إِمطَّاونْ نّشْ. خْزَارْ، نشّْ أَذْ أَرْنِيغْ خمّسْطَاشْ ن إِسڭّْوُوسَا إِ وُوسَّانْ ن ثُوذَارْثْ نّشْ.
\v 6 نشّْ أَذْ شكْ سّْنجْمغْ زڭْ ؤُفُوسْ ن ؤُجدْجِيذْ ن أَشُّورْ، ؤُڒَا ذ ثَانْذِينْثْ. نشّْ أَذْ سّڒْقِيغْ خْ ثنْذِينْثْ-أَ.
\v 7 أَيَا أَذْ يِيڒِي ذ ڒعْڒَامثْ ن سِيذِي إِ شكْ، أَقَا سِيذِي أَذْ إِڭّْ أَوَاڒْ-أَ نِّي إِنَّا.
\v 8 خْزَارْ، أَذْ سّْعقْبغْ ثِيڒِي خْ ثْرفِّيذِينْ ن أَحَازْ نِّي د-إِهْوَانْ خْ ثْرفِّيذِينْ ن دّْرُوجْ ن ثْفُوشْثْ،عشْرَا ن ثْرفِّيذِينْ.‘ “ \add خنِّي\add* ثعْقبْ-د ثْفُوشْثْعشْرَا ن ثْرفِّيذِينْ خْ ثْرفِّيذِينْ نِّي زِي د-ثهْوَا. \x ◘ \xo 38:‏8 \xt 2 إِج. 20‏:‏7‏-‏9\x*
\b
\s1 ثَاژَادْجِيثْ س ؤُقَاذِي ن حِيزْقِييَا
\m 
\v 9 ثِيرَا ن حِيزْقِييَا، أَجدْجِيذْ ن يَاهُوذَا، ڒَامِي ثُوغَا إِحْڒشْ ؤُشَا إِڭّنْفَا زِي ڒهْڒَاشْ نّسْ.
\m 
\v 10 ”نشّْ نِّيغْ: ’\add ڒخُّو\add* ذڭْ وزْينْ ن وُوسَّانْ \add ن ثُوذَارْثْ\add* إِنُو إِتّْخصَّا أَذْ ؤُيُورغْ خْ ثوُّورَا ن ڒَاخَارْثْ. مِينْ إِقِّيمنْ ن إِسڭّْوُوسَا إِنُو تّْوَاكّْسنْ زَّايِي.‘
\v 11 نشّْ نِّيغْ: ’وَارْ ژَترّغْ عَاذْ سِيذِي، سِيذِي، ذِي ثمُّورْثْ ن يِينِّي إِدَّارنْ، وَارْ تّْوِيڒِيغْ عَاذْ إِوْذَانْ أَكْ-ذ إِمزْذَاغْ ن ڒَاخَارْثْ.‘
\v 12 ثِيشْڒِي \add ن ثُوذَارْثْ إِنُو\add* أَذْ ت \add خَافِي\add* أَرْژنْ، أَذْ زَّايِي ت كّْسنْ أَمْ \add كّْسنْ\add* أَقِيضُونْ ن ؤُمكْسَاوْ. أَمْ بُو-ؤُزطَّا ضفْسغْ ثُوذَارْثْ إِنُو. أَذْ أَيِي إِقسّْ زِي دّبُّوزْ ن ثْخيَّاضْثْ: أَذْ ثقْضِيذْ \add ثُوذَارْثْ إِنُو\add* جَارْ وَاسّْ ذ دْجِيڒثْ! \f ◼ \fr 38:‏12 \ft \bd ’أَمكْسَاوْ‘\bd* - نِيغْ ’أَنِيتْشيِ‘.\f*
\v 13 رَاجِيغْ س صّْبَارْ أَڒْ أَثفُّو. نتَّا أَذْ يَارْژْ مَارَّا إِغْسَانْ إِنُو أَمْ وَايْرَاذْ: أَذْ ثقْضِيذْ \add ثُوذَارْثْ إِنُو\add* جَارْ ؤُثفُّو ذ دْجِيڒثْ!
\v 14 تّْجِيوْجِيوغْ أَمْ ثْفَاڒْدْجسْثْ إِتّنّْضنْ أَمْ ثطَّاوْ، تّْڭرْڭُورغْ أَمْ ثذْبِيرْثْ. سّْڭعّْذغْ ثِيطَّاوِينْ إِنُو: ’\add أَ\add* سِيذِي إِنُو، نشّْ تّْوَاحْصَارغْ، إِڒِي ذ أَضْمَانْ إِ نشّْ!‘ \x ◘ \xo 38:‏14 \xt إِشا. 59‏:‏11\x*
\m 
\v 15 مِينْ غَا إِنِيغْ؟ مِينْ ذ أَيِي إِنَّا، أَقَا إِڭَّا إِ-ث. مَارَّا إِسڭّْوُوسَا \add ن ثُوذَارْثْ\add* إِنُو أَذْ كّغْ خْ ثَارْزُوڭِي ن ڒعْمَارْ إِنُو.
\v 16 ’\add أَ\add* سِيذِي إِنُو، خْ مَانْ أَيَا إِزمَّارْ \add بْنَاذمْ\add* أَذْ إِدَّارْ ؤُشَا سنّجْ إِ مَارَّا أَيَا أَقَا ذَايسْ ثُوذَارْثْ ن بُوحْبڒْ إِنُو، \add مَاغَارْ\add* شكْ أَذْ أَيِي ثڭّنْفِيذْ ؤُ شكْ أَذْ أَيِي ثَارِّيذْ أَذْ ذوْڒغْ غَارْ ثُوذَارْثْ!
\m 
\v 17 خْزَارْ، ثَارْزُوڭِي ثُوغَا ثَارْزڭْ أَيِي إِ ڒهْنَا. شكْ ثْڒسْقذْ غَارْ ڒعْمَارْ إِنُو أَطَّاسْ \add أَڒَامِي ذ أَيِي ثحْضِيذْ\add* زڭْ \add وحْفُورْ ن\add* ثُورْصُوضِي، مَاغَارْ ثنْضَارذْ مَارَّا دّْنُوبْ إِنُو أَوَارْنِي إِ وعْرُورْ نّشْ.
\v 18 مَاغَارْ ڒَاخَارْثْ وَارْ شكْ ثْقَاذَا شَا، ڒْموْثْ وَارْ شكْ إِسّمْغَارْ. وِي غَا إِهْوَانْ ذڭْ وحْفُورْ، وَارْ تّْرِيجِينْ ڒَامَانْ نّشْ.
\v 19 ونِّي إِدَّارنْ، \add أَ\add* ونِّي إِدَّارنْ، أَقَا نتَّا أَذْ شكْ إِقَاذَا. بَابَاثْسنْ أَذْ إِسّْشنْ ڒَامَانْ نّشْ إِ إِحنْجِيرنْ \add نّسْ\add*.‘ “
\b
\m 
\v 20 ”سِيذِي \add يُوسَا-د\add* حِيمَا أَذْ أَيِي إِسّنْجمْ. أَذْ نُورَارْ س ؤُزنْزُونْ خْ إِفِيڒَانْ إِنُو مَارَّا ؤُسَّانْ ن ثُوذَارْثْ نّغْ ذِي ثَادَّارْثْ ن سِيذِي.“
\b
\m 
\v 21 أَقَا إِنَّا إِشَاعْيَا: ”أجّْ إِ-ثنْ أَذْ أَوْينْ إِجّْ ن وغْرُومْ ن ثَازَارْثْ ؤُشَا أَذْ ث ڒثْفنْ خْ ثْحبُّوشْثْ، \add خنِّي\add* أَذْ إِڭّنْفَا.“ \x ◘ \xo 38:‏21 \xt 2 إِج. 20‏:‏7\x*
\m 
\v 22 حِيزْقِييَا أَقَا إِنَّا: ”مَانْ إِ غَا ثِيڒِي ڒعْڒَامثْ أَقَا نشّْ أَذْ سّْڭعّْذغْ \add عَاوذْ\add* غَارْ ثَادَّارْثْ ن سِيذِي؟“
\b
\b
\c 39
\s1 ثَارْزفْثْ ن إِرقَّاسنْ زِي بَابِيلْ
\m 
\v 1 ذِي ڒْوقْثْ نِّي إِسّكّْ بَارَاذُوخْ-بَالَاذَانْ، مِّيسْ ن بَالَاذَانْ، أَجدْجِيذْ ن بَابِيلْ، ثِيبْرَاثِينْ ذ إِشْثْ ن ثَارْزفْثْ غَارْ حِيزْقِييَا، مَاغَارْ ثُوغَا إِسْڒَا أَقَا حِيزْقِييَا إِهْڒشْ ؤُشَا إِڭّنْفَا.
\v 2 إِفَارْحْ زَّايْسنْ حِيزْقِييَا ؤُشَا إِسّْشنْ أَسنْ مَارَّا ثَادَّارْثْ ن ثْخُوبَايْ نّسْ: نُّوقَارْثْ ذ وُورغْ ذ ڒعْطُورْ ذ زّشْثْ ذ ڒهْرِي ن ڒسْنَاحْ نّسْ ذ مَارَّا مِينْ إِتّْوَافنْ ذڭْ إِخَّامنْ نّسْ ن ثْخُوبَايْ. وَارْ إِقِّيمْ وَالُو ذِي ثَادَّارْثْ نّسْ ؤُ ذِي مَارَّا ڒحْكَامثْ نّسْ نِّي وَارْ ثُوغِي ذ أَسنْ ث إِسّْشنْ.
\m 
\v 3 \add خنِّي\add* يُوسَا-د ؤُنَابِي إِشَاعْيَا غَارْ ؤُجدْجِيذْ حِيزْقِييَا، إِنَّا أَسنْ: ”مِينْ نَّانْ إِرْيَازنْ نِّي ؤُ مَانِيسْ غَاركْ د-ؤُسِينْ؟“ حِيزْقِييَا إِنَّا: ”نِيثْنِي ؤُسِينْ-د زڭْ إِشْثْ ن ثمُّورْثْ ثِيڭّْوجْ، زِي بَابِيلْ.“
\v 4 نتَّا إِنَّا: ”مِينْ ژْرِينْ نِيثْنِي ذِي ثَادَّارْثْ نّشْ؟“ حِيزْقِييَا إِنَّا: ”نِيثْنِي ژْرِينْ مَارَّا مِينْ إِدْجَانْ ذِي ثَادَّارْثْ إِنُو. وَارْ إِقِّيمْ شَا زِي مِينْ إِدْجَانْ ذڭْ إِخَّامنْ ن ثْخُوبَايْ إِنُو، وَارْ ذ أَسنْ ث سّشْنغْ.“
\v 5 \add خنِّي\add* إِنَّا إِشَاعْيَا إِ حِيزْقِييَا: ”سڒْ إِ وَاوَاڒْ ن سِيذِي ن ڒْعسْكَارَاثْ:
\v 6 ’خْزَارْ، أَذْ د-أَسنْ وُوسَّانْ مڒْمِي مَارَّا مِينْ إِدْجَانْ ذِي ثَادَّارْثْ نّشْ ؤُڒَا ذ مِينْ يَارْونْ ڒجْذُوذْ نّشْ أَڒْ أَسّْ-أَ، أَذْ ث أَوْينْ غَارْ بَابِيلْ. وَارْ إِتّْغِيمِي وَالُو، إِقَّارْ سِيذِي.
\v 7 أَذْ أَوْينْ ؤُڒَا زڭْ إِحنْجِيرنْ نّشْ إِنِّي د غَا إِفّْغنْ زَّايكْ، إِنِّي د غَا ثجّذْ، حِيمَا أَذْ إِڒِينْ ذ إِمْسخَّارنْ إِمْشنّْعنْ ذِي ڒقْصَارْ ن ؤُجدْجِيذْ ن بَابِيلْ.‘ “
\v 8 حِيزْقِييَا إِنَّا إِ إِشَاعْيَا: ”أَوَاڒْ ن سِيذِي إِ ذ أَيِي ثنِّيذْ إِصْبحْ.“ نتَّا إِنَّا عَاوذْ: ”مَاڒَا \add خنِّي\add* ذڭْ وُوسَّانْ إِنُو أَذْ \add ذِينْ\add* يِيڒِي ڒهْنَا ذ ڒَامَانْ!“
\b
\b
\c 40
\s1 أَفوّجْ إِ ڒْڭنْسْ ن أَربِّي
\m 
\v 1 ”سْفوّجْ، سْفوّجْ ڒْڭنْسْ إِنُو، \add أَمُّو إِ\add* إِقَّارْ أَربِّي نْومْ!
\v 2 سِيوْڒمْ غَارْ وُوڒْ ن ؤُرْشَالِيمْ ؤُشَا بَارّْحمْ أَسْ أَقَا أَمنْغِي نّسْ إِقْضَا، أَقَا ڒْمُوعْصِييّثْ نّسْ ثصْڒحْ، أَقَا ثكْسِي س ؤُضفُّوسْ زڭْ ؤُفُوسْ ن سِيذِي إِ مَارَّا دّْنُوبْ نّسْ.
\v 3 ثْمِيجَّا ن ونِّي إِسْغُويُّونْ ذِي ڒخْڒَا: ’سْوجْذمْ أَبْرِيذْ إِ سِيذِي، سَارّْحمْ ذِي ڒخْڒَا أَبْرِيذْ إِ أَربِّي نّغْ!‘ \x ◘ \xo 40:‏3 \xt مت. 3‏:‏3؛ مك. 1‏:‏3؛ لك. 3‏:‏4؛ يُوح. 1‏:‏23\x*
\v 4 مَارَّا ثِيغْزُورِينْ أَذْ تّْوَاسّْڭعّْذنْثْ، مَارَّا إِذُورَارْ ذ ثوْرِيرِينْ أَذْ تّْوَاسّهْوَانْ. مِينْ إِفَارْغنْ، أَذْ إِذْوڒْ إِسڭّمْ ؤُشَا إِجّْ ن ؤُسذِّي ن إِذُورَارْ أَذْ إِذْوڒْ ذ ڒوْضَا إِوَاطَانْ.
\v 5 أَذْ إِتّْوَاسَّارْڭبْ ؤُعُودْجِي ن سِيذِي ؤُشَا مَارَّا دَّاثْ أَذْ ثْژَارْ أَقَا أَقمُّومْ ن سِيذِي إِسِّيوڒْ.“ \x ◘ \xo 40:‏5 \xt يُوح. 1‏:‏14\x*
\m 
\v 6 ”ثْمِيجَّا ثنَّا: ’بَارّحْ!‘ ؤُ نتَّا إِنَّا: ’مِينْ غَا بَارّْحغْ؟‘ ’مَارَّا دَّاثْ أَمْ أَرْبِيعْ ذ مَارَّا ثَامخْسِيوْثْ نّسْ إِشوَّارنْ أَمْ ثْنوَّاشْثْ ذڭْ إِيَّارْ. \x ◘ \xo 40:‏6 \xt أَيُوبْ 14‏:‏2؛ إِزهد. 90‏:‏5، 6؛ 102‏:‏12؛ 103‏:‏15؛ يَاع. 1‏:‏10؛ 1 بُط. 1‏:‏24\x*
\v 7 أَرْبِيعْ إِتَّاژغْ، ثَانوَّاشْثْ ثسْڒَاوْ خْمِي خَاسْ إِتّْسُوضْ أَرُّوحْ ن سِيذِي. ذ ثِيذتّْ، ڒْڭنْسْ ذ أَرْبِيعْ.
\v 8 أَرْبِيعْ إِتَّاژغْ، ثَانوَّاشْثْ ثسْڒَاوْ، مَاشَا أَوَاڒْ ن أَربِّي نّغْ إِتّْغِيمَا إِ ڒبْذَا.‘ “ \x ◘ \xo 40:‏8 \xt 1 بُط. 1‏:‏25\x*
\b
\m 
\v 9 ”ڭعّذْ خْ إِجّْ ن وذْرَارْ ذ أَمقّْرَانْ، \add أَ\add* صِيهْيُونْ، \add أَ\add* شمْ ثَامْبشَّارْثْ ن ڒخْبَارْ أَصبْحَانْ، سْڭعّذْ ثْمِيجَّا نّمْ س جّهْذْ، \add أَ\add* ؤُرْشَالِيمْ، \add أَ\add* شمْ ثَامْبشَّارْثْ ن ڒخْبَارْ أَصبْحَانْ، سْڭعّذْ ثْمِيجَّا نّمْ، وَارْ ثڭّْوذْ، إِنِي إِ ثْندَّامْ ن يَاهُوذَا: ’خْزَارْ، أَربِّي نْكنْثْ!‘
\v 10 خْزَارْ، أَذْ د-يَاسْ سِيذِي إِنُو، سِيذِي، نتَّا إِجْهذْ ؤُشَا أَغِيڒْ نّسْ أَذْ إِحْكمْ. خْزَارْ، ڒْمُونثْ نّسْ غَارسْ ؤُشَا أَخدْجصْ نّسْ إِزْوَارْ أَسْ. \x ◘ \xo 40:‏10 \xt إِشا. 62‏:‏11\x*
\v 11 أَذْ يَارْوسْ ثَاحِيمَارْثْ نّسْ أَمْ ؤُمكْسَاوْ، أَذْ إِسّْمُونْ إِزْمَارنْ غَارْ ؤُغِيڒْ نّسْ ؤُشَا أَذْ ثنْ يَارْبُو ذڭْ وحْسِينْ نّسْ. أَذْ إِنْذهْ إِنِّي إِسُّوطُّوضنْ س ڒعْقڒْ.“ \x ◘ \xo 40:‏11 \xt إِشا. 49‏:‏10؛ حِز. 34‏:‏23، 24؛ مِيخَا 7‏:‏14؛ يُوح. 10‏:‏11\x*
\b
\m 
\v 12 ”مَانْ ونْ إِعْبَارنْ أَمَانْ \add ن ڒبْحَارْ\add* س وُورُو ن ؤُفُوسْ نّسْ ؤُ \add مَانْ ونْ\add* إِكْسِينْ ڒقْيَاسْ ن إِجنْوَانْ س ڒعْبَارْ ن ؤُفُوسْ؟ ؤُ \add مَانْ ونْ\add* إِطّْفنْ ؤُشَاڒْ ن ثمُّورْثْ س إِجّْ ن ڒْمُوذْ؟ مَانْ ونْ إِوزّْننْ إِذُورَارْ س إِجّْ ن ڒْبَاسْكُو ؤُ ثِيوْرِيرِينْ س ڒْمِيزَانْ؟
\v 13 مَانْ ونْ إِبقّْشنْ خْ أَرُّوحْ ن سِيذِي ؤُ \add مَانْ ونْ\add* ث إِسّْغَارنْ أَمْ ؤُمْشَاوَارْ نّسْ؟ \x ◘ \xo 40:‏13 \xt رُوم. 11‏:‏34؛ 1 كُور. 2‏:‏16\x*
\v 14 وِي ث إِسقْسَانْ نتَّا خْ شّْوَارْ ذ مَانْ ونْ إِ ذ أَسْ إِسّْشْننْ ڒفْهَامثْ ؤُ وِي ذ أَسْ إِسّْڒمْذنْ أَبْرِيذْ ن ڒْحقّْ ؤُشَا يَارْنِي أَسْ ثُوسّْنَا؟ وِي ذ أَسْ إِسَّارْڭْبنْ أَبْرِيذْ إِشُّورنْ س ڒفْهَامثْ؟“
\m 
\v 15 ”خْزَارْ، ڒڭْنُوسْ تّْوَاحسْبنْ أَمْ يِيشْثْ ن ثُوذِّينْثْ زڭْ ؤُبُوقَاڒْ ؤُ أَمْ \add شْوَايْثْ ن\add* ثْنغْذَا خْ ڒْمِيزَانْ. أَقَا ذَا، نتَّا إِسّْڭعّذْ ثِيڭْزِيرِينْ أَمْ ثْعجَّاجْثْ إِفْسُوسنْ.
\v 16 لُوبْنَانْ وَارْ إِتّْقِيذِّي إِ ؤُكشُّوضْ ن ثْمسِّي ؤُشَا ڒْمَاڒْ نّسْ وَارْ تّْقِيذِّينْ إِ ثْغَارْصْثْ ن وشْمَاضْ.
\v 17 مَارَّا ڒڭْنُوسْ أَقَا أَثنْ أَمْ وَارْ ذِينْ دْجِينْ قِيبَاتْشْ نّسْ ؤُشَا إِحسّبْ إِ-ثنْ ذ وَالُو، ذ ڒعْوِينْ. \x ◘ \xo 40:‏17 \xt دَان. 4‏:‏32\x*
\v 18 وِي أَكْ-ذ إِ غَا ثسّمْقُودّمْ أَربِّي نِيغْ مَانْ أَرْوَاسْ إِ زِي ث غَا ثْخڒْفمْ؟“\x ◘ \xo 40:‏18 \xt إِشا. 46‏:‏5؛ ڒخ. 17‏:‏29\x*
\m 
\v 19 ”أَحْرَايْفِي إِتّْكبَّا ڒخْيَاڒْ إِنقْشنْ ؤُ أَمْزِيڒْ ن وُورغْ إِتّْغدْجفْ إِ-ث س وُورغْ ؤُ إِفسِّي أَسْ ثِيسدّْيِينْ ن نُّوقَارْثْ.
\v 20 ونِّي إِدْجَانْ ذ أَمزْڒُوضْ إِ ثوْهِيبْثْ ن ؤُسْڭعّذْ أَذْ إِخْضَارْ إِجّْ ن ؤُكشُّوضْ وَارْ يَارشِّي. نتَّا يَارزُّو إِجّْ ن بُو-صّنْعثْ مَاحنْذْ أَذْ إِڭّْ ڒخْيَاڒْ إِنقْشنْ نِّي وَارْ إِتّنْهزِّينْ.“
\m 
\v 21 ”مَا وَارْ \add ت\add* ثسِّينمْ؟ مَا وَارْ \add ت\add* تّسْڒِيمْ؟ مَا وَارْ \add ت\add* ثُوغِي غَارْومْ إِتّْوَاسّنْ زڭْ ؤُمزْوَارُو؟ مَا وَارْ ثُوغِي ثْحطَّامْ ذْسُوسَا ن ثمُّورْثْ؟
\v 22 نتَّا ذ ونِّي إِقِّيمنْ خْ ثْقُورَارْثْ ن ثَايُّوثْ إِ د-إِنّْضنْ إِ \add مَارَّا\add* ثَامُّورْثْ، \add ثَامُّورْثْ\add* مَانِي إِمزْذَاغْ نّسْ \add تّْبَاننْ-د\add* أَمْ يِيبُورخْسنْ، نتَّا ذ ونِّي إِمحّْضنْ إِجنْوَانْ أَمْ أَرْوَاقْ، إِتّْبزّعْ إِ-ثنْ أَمْ ؤُقِيضُونْ إِ وزْذَاغْ، \x ◘ \xo 40:‏22 \xt أَيُوبْ 9‏:‏8؛ إِزهد. 104‏:‏2؛ إِشا. 44‏:‏24\x*
\v 23 نتَّا ذ ونِّي إِتَّارَّانْ أَيْثْ ن جّهْذْ ذ وَالُو، ؤُ إِسّخْوَا ڒْقُوضَاثْ ن ثمُّورْثْ. \x ◘ \xo 40:‏23 \xt أَيُوبْ 12‏:‏21؛ إِزهد. 107‏:‏40\x*
\v 24 عَاذْ شْوَايْثْ وَاهَا تّْوَاژُّونْ، عَاذْ شْوَايْثْ وَاهَا تّْوَازَارْعنْ، عَاذْ شْوَايْثْ وَاهَا إِوْثَا جّْذعْ \add ن ثْشجَّارْثْ\add* نْسنْ أَژْوَارْ ذِي ثمُّورْثْ، أَقَا إِسُوضْ نتَّا خَاسنْ أَڒَامِي ؤُژْغنْ ؤُشَا ثَاحَارْيَاضْثْ ثكْسِي ثنْ أَمْ ؤُڒُومْ.“
\m 
\v 25 ”أَكْ-ذ مَانْ ونْ ثخْسمْ كنِّيوْ أَذْ أَيِي ثسّمْقُودّمْ، مَانْ ونْ إِ ذِي أَروْسغْ؟، إِقَّارْ ؤُمْقدَّاسْ.
\v 26 سْڭعّْذمْ ثِيطَّاوِينْ نْومْ ؤُ خْزَارمْ، مَانْ ونْ إِڭِّينْ مَانْ أَيَا؟ ذ نتَّا ونِّي إِسُّوفُّوغنْ ڒْعسْكَارْ نْسنْ مَارَّا، ونِّي ذ أَسنْ إِتّْڒَاغَانْ مَارَّا س إِسمْ نْسنْ س ڒمْغَارثْ ن جّهْذْ \add نّسْ\add* ؤُ س ڒْعزّْ \add نّسْ\add* إِجهْذنْ، وَارْ إِبطّڒْ ؤُڒَا ذ إِجّْ!“
\m 
\v 27 ”مَايمِّي ثقَّارذْ \add خنِّي\add*، \add أَ\add* يَاعْقُوبْ، ؤُ ثسَّاوَاڒذْ \add أَمُّو\add*، \add أَ\add* إِسْرَائِيل: ’أَبْرِيذْ إِنُو إِنُّوفَّارْ خْ سِيذِي ؤُ ثَاسْغَارْثْ إِنُو ثتّكّْ خْ أَربِّي إِنُو؟‘
\v 28 مَا وَارْ \add ت\add* ثسِّينذْ؟ مَا وَارْ \add ت\add* ثسْڒِيذْ أَقَا أَربِّي نْ ڒبْذَا، سِيذِي، ونِّي د-إِخڒْقنْ طّْرُوفَا ن ثمُّورْثْ، وَارْ إِتِّيحڒْ ؤُ وَارْ يَارخُّو؟ وَارْ إِزمَّارْ \add بْنَاذمْ\add* أَذْ إِفْهمْ ڒعْقڒْ نّسْ. \x ◘ \xo 40:‏28 \xt إِزهد. 147‏:‏5\x*
\v 29 نتَّا إِتِّيشْ جّهْذْ إِ ونِّي يُوحْڒنْ ؤُ ونِّي وَارْ غَارْ إِدْجِي جّهْذْ يَارنِّي أَسْ جّهْذْ س وَاطَّاسْ.
\v 30 إِحنْجِيرنْ تَّاحْڒنْ ؤُ أَرخُّونْ، إِبْڒِيغنْ تّنْقْرَاضنْ ؤُشَا وطَّانْ،
\v 31 \add مَاشَا\add* إِنِّي إِتّْرَاجَانْ سِيذِي، تَّايْمنْ جّهْذْ ن جْذِيذْ. نِيثْنِي تّطّْفنْ أَفْرِيونْ أَمْ ؤُڭِيذرْ، تَّازّْڒنْ، \add مَاشَا\add* وَارْ تِّيحْڒنْ، ڭُّورنْ \add مَاشَا\add* وَارْ أَرخُّونْ.“
\b
\b
\c 41
\s1 أَمْقدَّاسْ ن إِسْرَايِيلْ ذ أَمفْذِي ن ؤُمْسخَّارْ نّسْ إِسْرَايِيلْ
\m 
\v 1 ”سغْذمْ-د زَّاثِي، \add أَ\add* ثِيڭْزِيرِينْ خْ ثْمَا ن ڒبْحَارْ، ؤُشَا جّمْ شُّوعُوبْ أَذْ طّْفنْ جّهْذْ ن جْذِيذْ، جّمْ ثنْ أَذْ د-أَذْسنْ، خنِّي أَذْ سِّيوْڒنْ، جّمْ أَنغْ أَذْ نْقَارّبْ غَارْ ڒحْكَامْ مَارَّا نْمُونْ.
\v 2 مَانْ ونْ إِ د-إِسّْفَاقنْ زِي مَانِيسْ ذ ثْنقَّارْ ثْفُوشْثْ إِجّنْ ونِّي أَكِيذسْ ثمْسَاڭَارْ ثْسڭْذَا غَارْ إِضَارنْ نّسْ؟ \add مَانْ ونْ\add* إِسلّْمنْ ڒڭْنُوسْ ذڭْ ؤُفُوسْ نّسْ ؤُشَا إِڭَّا إِ-ث أَذْ يَاريّسْ خْ إِجدْجِيذنْ؟ \add مَانْ ونْ\add* يَارِّينْ \add ڒڭْنُوسْ\add* إِ سِّيفْ نّسْ أَمْ ثْعجَّاجْثْ، إِ ڒْقوْسْ نّسْ أَمْ ؤُڒُومْ نِّي ذِي إِتّْسُوضْ ؤُسمِّيضْ؟
\v 3 نتَّا إِضْفَارْ إِ-ثنْ، إِكمّڒْ غَارْ زَّاثْ ذِي ڒهْنَا خْ وبْرِيذْ وَارْ \add ث\add* إِحِيذِيعمَّارْصْ س إِضَارنْ نّسْ.
\v 4 مَانْ ونْ إِسّقْفڒْ ؤُشَا إِڭَّا أَيَا؟ نتَّا، ونِّي زڭْ ؤُمزْوَارُو إِبَارّْحنْ إِ جِّيڒَاثْ: ’نشّْ، سِيذِي، ذ أَمزْوَارُو ؤُ غَارْ إِنڭُّورَا \bd نشّْ نشّْ\bd*.‘ \x ◘ \xo 41:‏4 \xt إِشا. 43‏:‏10؛ 44‏:‏6؛ 48‏:‏12؛ أَسَا. 1‏:‏17؛ 22‏:‏13\x*
\v 5 ثِيڭْزِيرِينْ ژْرِينْثْ \add ث\add*، ڭّْوذنْثْ، إِنڭُّورَا ن ثمُّورْثْ أَرْجِيجنْ، نِيثْنِي ؤُذْسنْ-د، إِوْضنْ-د.
\v 6 إِجّنْ إِوْشَا أَفُوسْ إِ ؤُمدُّوكّڒْ نّسْ، إِنَّا إِ ؤُمَاسْ: ’إِڒِي ذ أَرْيَازْ!‘ “
\b
\m 
\v 7 ”أَصْنَايْعِي إِڭَّا ؤُڒْ ذڭْ ومْزِيڒْ ن وُورغْ نِّي \add ث\add* إِسّرْغنْ س وفْضِيسْ، ونِّي إِوتِّينْ خْ ژّبْرَا، أَمْ إِقَّارْ خْ مَامّشْ سّْڒسْقنْ إِزِييْنَانْ: ’ذ لمْلِيحْ!‘. \add خنِّي\add* إِسّمْثنْ \add ومْزِيڒْ\add* إِ ڒخْيَاڒْ س إِمسْمَارْ، أَڒَامِي وَارْ إِتّنْهزِّي.“
\b
\m 
\v 8 ”\add مَاشَا\add* شكْ، \add أَ\add* إِسْرَائِيل، أَمْسخَّارْ إِنُو، \add أَ\add* يَاعْقُوبْ نِّي إِخْضَارغْ، زَّارِيعثْ ن إِبْرَاهِيمْ، أَمدُّوكّڒْ إِنُو إِعِيزّنْ، \x ◘ \xo 41:‏8 \xt أَعَوذ. 7‏:‏6؛ 10‏:‏15؛ 14‏:‏2؛ 2 إِم. 20‏:‏7؛ إِزهد. 135‏:‏4؛ إِشا. 43‏:‏1؛ 44‏:‏1؛ يَاع. 2‏:‏23\x*
\v 9 طّْفغْ شكْ زڭْ إِنڭُّورَا ن ثمُّورْثْ ؤُشَا ڒَاغِيغْ-د خَاكْ زِي طّْرُوفَا نّسْ قَاعْ، نِّيغْ أَشْ: ’شكْ ذ أَمْسخَّارْ إِنُو، إِخْضَارغْ شكْ، وَارْ شكْ نْضَارغْ.‘
\v 10 وَارْ تّڭّْوذْ شَا، مَاغَارْ نشّْ دْجِيغْ أَكِيذكْ، وَارْ سْحِيسِّيفْ، مَاغَارْ نشّْ ذ أَربِّي نّشْ. نشّْ أَذْ شكْ سّْجهْذغْ، أَذْ أَشْ وْشغْ أَفُوسْ، \add وَاهْ،\add* نشّْ أَذْ ذَايكْ منْعغْ س ؤُفُوسِي إِشُّورْ س ثْسڭْذَا إِنُو.“
\b
\m 
\v 11 ”خْزَارْ، نِيثْنِي أَذْ سضْحَانْ، أَذْ ذوْڒنْ إِ ڒفْضِيحثْ، مَارَّا إِنِّي خَاكْ إِسّْحمَّانْ. إِرْيَازنْ نِّي أَكِيذكْ إِتّمْشُوبُّوشنْ، أَذْ ذوْڒنْ ذ وَالُو، أَذْ تّْوَاهلّْكنْ. \x ◘ \xo 41:‏11 \xt ؤُف. 23‏:‏22؛ إِشا. 60‏:‏12؛ زَاك. 12‏:‏3\x*
\v 12 شكْ أَذْ خَاسنْ ثَارْزُوذْ، \add مَاشَا\add* وَارْ ثنْ ثتِّيفذْ. إِرْيَازنْ نِّي كِيذكْ إِتّمْشُوبُّوشنْ أَذْ ذوْڒنْ ذ وَالُو ذ ڒْبَاطڒْ، \add وَاهْ،\add* إِرْيَازنْ نِّي إِتّْمنْغَانْ أَكِيذكْ.
\v 13 مَاغَارْ نشّْ ذ سِيذِي، أَربِّي نّشْ، ونِّي إِطّْفنْ أَفُوسْ أَفُوسِي نّشْ ذ ونِّي ذ أَشْ إِقَّارنْ: ’وَارْ تّڭّْوذْ شَا، نشّْ أَذْ أَشْ وْشغْ أَفُوسْ!
\v 14 وَارْ ثڭّْوذْ شَا، \add أَ شكْ\add* أَكشَّاوْ يَاعْقُوبْ، \add أَ\add* يرْيَازنْ ن إِسْرَائِيل! نشّْ أَذْ أَشْ وْشغْ أَفُوسْ، أَمفْذِي نّشْ ذ أَمْقدَّاسْ ن إِسْرَائِيل!‘، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.
\v 15 خْزَارْ، نشّْ ڭِّيغْ شمْ ذ ثَاڒْوِيحْثْ إِتّحْڒُودْجُوضنْ إِ ؤُسَارْوثْ ذ ثَامَايْنُوثْ، س ثغْمَاسْ إِقضْعنْ غَارْ ثْنَاينْ ن إِغزْذِيسنْ. إِذُورَارْ أَذْ ثنْ ثْسَّارْوْثذْ ؤُ أَذْ ثنْ ثدّْزذْ ؤُ ثِيوْرِيرِينْ أَذْ ثنْثْ ثڭّذْ ذ ڒُومْ. \x ◘ \xo 41:‏15 \xt إِشا. 17‏:‏13؛ 29‏:‏5\x*
\v 16 شكْ أَذْ ثنْ ثزُّوزَارذْ، أَذْ ثنْ يَاوِي ؤُسمِّيضْ، أَذْ ثنْ ثَاريّشْ ثْحَارْيَاضْثْ. شكْ مَاشَا أَذْ ثسْڒِيوْڒوذْ خْ سِيذِي، أَذْ ثْشنّْعذْ إِخفْ نّشْ ذڭْ ؤُمْقدَّاسْ ن إِسْرَائِيل.“
\b
\m 
\v 17 ”إِنِّي إِتّْوَاحْصَارنْ ذ إِمزْڒَاضْ أَرزُّونْ خْ وَامَانْ، \add مَاشَا\add* وَالُو ذَا. إِڒسْ نْسنْ يُوژغْ س ؤُفَاذِي. نشّْ، سِيذِي، أَذْ أَسنْ سْڒغْ، نشّْ، أَربِّي ن إِسْرَائِيل، وَارْ ذَايْسنْ سمّْحغْ. \x ◘ \xo 41:‏17 \xt مت. 5‏:‏6\x*
\v 18 خْ ثوْرِيرِينْ ثِيقشُّورَا أَذْ جّغْ إِغزْرَانْ أَذْ دُّوقّْزنْ ؤُڒَا ذ ڒْعُونْصَارَاثْ ذِي ڒْوسْطْ ن ڒوْضَاثْ. نشّْ أَذْ أَرّغْ ڒخْڒَا ذ أَيڒْمَامْ ن وَامَانْ ؤُڒَا ذ ثَامُّورْثْ يُوژْغنْ ذ ثِينذْوِينْ. \x ◘ \xo 41:‏18 \xt إِزهد. 107‏:‏35؛ إِشا. 35‏:‏7؛ 44‏:‏3\x*
\v 19 ذِي ڒخْڒَا أَذْ ژُّوغْ ثَاشجَّارْثْ ن ثنْڭلْثْ ذ ثْشجَّارْثْ ن ؤُكَاسِييَا ذ ثْشجَّارْثْ ن ثَارِيحَانْثْ ذ ؤُزمُّورْ، ذِي ثْنزْرُوفْثْ أَذْ ڭّغْ ثَاشجَّارْثْ ن ؤُمرْزِي ذ ثْشجَّارْثْ ن ذُولْبْ ذ ثَايْذَا أَكْ-ذ وَايَاوْيَا، \f ◼ \fr 41:‏19 \ft \bd ’ثَاشجَّارْثْ‘\bd* - نِيغْ ’أَدَّاڭْ‘ (’إِدَّاڭنْ‘). \bd ’أَمرْزِي‘\bd* - نِيغْ ’أَمضْزِي‘.\f*
\v 20 حِيمَا أَذْ ژَترنْ، أَذْ نعْمنْ، أَذْ أَرْڭْبنْ، أَذْ فهْمنْ جْمِيعْ، أَقَا أَفُوسْ ن سِيذِي إِڭَّا أَيَا، أَقَا أَمْقدَّاسْ ن إِسْرَائِيل إِخْڒقْ إِ-ت-إِ-د.“
\b
\m 
\v 21 ”قدّْممْ دّعْوثْ نْومْ \add زَّاثِي\add*، إِقَّارْ سِيذِي، أَوْيمْ-د بُورْهَانَاثْ نْومْ إِجهْذنْ قَاعْ، إِقَّارْ ؤُجدْجِيذْ ن يَاعْقُوبْ.
\v 22 أجّْ إِ-ثنْ أَذْ أَوْينْ ؤُ أَذْ أَنغْ بَارّْحنْ مِينْ غَا إِمْسَارنْ. سَارْڭْبمْ أَنغْ خْ ثْمسْڒَايِينْ ثِيمزْوُورَا قَاعْ، مَامّشْ دْجَانْثْ، حِيمَا أَذْ \add ثنْثْ\add* نكْسِي غَارْ وُوڒْ ؤُشَا أَذْ نسّنْ أَنڭَّارْ نْسنْثْ، نِيغْ أجّْ أَنغْ أَذْ نْسڒْ خْ ثْمسْڒَايِينْ إِ د غَا يَاسنْ \add عَاذْ\add*.
\v 23 بَارّْحمْ ثِيمسْڒَايِينْ إِ غَا يِيڒِينْ ذَاوحْذَا عَاذْ، \add مَاحنْذْ\add* أَذْ نسّنْ أَقَا كنِّيوْ ذ إِربِّيثنْ. ڭّمْ شَا ذ ڒْخَارْ نِيغْ ذ ڒْغَارْ، \add حِيمَا\add* أَذْ نْخزَّارْ ذڭْ وَايَاوْيَا س ڒْخزْرَاثْ إِبقّْشنْ، أَذْ \add ت\add* نْژَارْ \add جْمِيعْ\add*.
\v 24 خْزَارْ، كنِّيوْ قلّْ خْ وَالُو ؤُ مِينْ ثتّڭّمْ وَارْ ذَايسْ بُو نّْفَاعْ، ونِّي كنِّيوْ إِخْضَارنْ أَقَا-ث ذ نّْعِي.“
\b
\m 
\v 25 ”نشّْ أَذْ د-سّكَّارغْ \add إِجّنْ\add* زِي شَّامَالْ ؤُ نتَّا أَذْ د-إِفّغْ زِي مَانِيسْ د-ثْنقَّارْ ثْفُوشْثْ، أَذْ إِڒَاغَا خْ إِسمْ إِنُو. نتَّا أَذْ د-يَاسْ أَمْ بُو-ثْڒَاخْثْ نِّي إِعفّْسنْ خْ ؤُبدْجَاعْ، أَذْ إِعْفسْ خْ أَيْثْ ن جّهْذْ أَمْ خْ ثَارِّيسْثْ.“
\b
\m 
\v 26 ”مَانْ ونْ \add إِ-ت\add* إِبَارّْحنْ زڭْ ؤُمزْوَارُو قَاعْ، \add حِيمَا\add* أَذْ \add ت\add* نسّنْ، نِيغْ \add خنِّي\add* مَانْ ونْ \add إِ-ت\add* إِبَارّْحنْ قْبڒْ، حِيمَا نْزمَّارْ أَذْ نِينِي: ’أَقَا نتَّا ذَايسْ ڒَامَانْ!‘ مَاشَا وَارْ ذِينْ وِي \add ت\add* إِبَارّْحنْ، \add وَارْ ذِينْ\add* وِي ذ أَنغْ إِتَّارَّانْ أَذْ نْسڒْ شَا، ؤُڒَا ذ إِجّْ وَارْ إِسْڒِي أَومْ ثْنطْقمْ س شَا.
\v 27 \add أَمْ\add* ؤُمزْوَارُو \add نِّيغْ نشّْ\add* إِ صِيهْيُونْ: ’أَقَا-ثنْ ذَا!‘، ؤُ إِ ؤُرْشَالِيمْ: ’نشّْ أَذْ أَوْيغْ إِجّْ ن ؤُرقَّاسْ س ڒخْبَارْ أَصبْحَانْ.‘
\v 28 نشّْ خْزَارغْ، \add مَاشَا\add* وَارْ ذِينْ ثُوغِي ؤُڒَا ذ إِجّْ! وَارْ \add ذِينْ\add* ثُوغِي ؤُڒَا ذ إِجّْ زَّايْسنْ ونِّي إِزمَّارنْ أَذْ إِوْشْ شّْوَارْ، \add أَڒَامِي\add* زمَّارغْ أَذْ سّقْسِيغْ ؤُ نِيثْنِي أَذْ خَافِي د-أَرّنْ.
\v 29 خْزَارْ، نِيثْنِي مَارَّا ذِي ڒْبَاطڒْ، ڒخْذَايمْ نْسنْ وَارْ ذَايْسنْ نّْفَاعْ، ڒخْيَاڒَاثْ إِفسْينْ نْسنْ ذ ڒعْوِينْ \add وَاهَا\add* ؤُ خْوَانْثْ.“
\b
\b
\c 42
\s1 أَمْسخَّارْ ن سِيذِي ذ أَمْسخَّارْ نّسْ أَذَارْغَاڒْ، إِسْرَائِيل
\m 
\v 1 ”خْزَارْ، أَمْسخَّارْ إِنُو ونِّي تّْعَاوَانغْ، ذ ونِّي فَارْزغْ، ذ ونِّي د-يُوسِينْ خْ ڒْخَاضَارْ إِنُو. نشّْ سَّارْسغْ خَاسْ أَرُّوحْ إِنُو. نتَّا أَذْ إِسُّوفّغْ ڒحْكَامْ غَارْ ڒڭْنُوسْ. \x ◘ \xo 42:‏1 \xt إِشا. 11‏:‏2؛ مت. 3‏:‏17؛ 17‏:‏5؛ يُوح. 3‏:‏34؛ أَفا. 1‏:‏6\x*
\v 2 وَارْ إِسْغُويُّو ؤُ وَارْ إِسّْڭِيعِّيذْ ثْمِيجَّا نّسْ ؤُ وَارْ إِتَّارِّي ثْمِيجَّا نّسْ أَذْ أَسْ سْڒنْ ذِي بَارَّا.
\v 3 أَغَانِيمْ إِنْضفْسنْ وَارْ ث إِتَّارژِّي شَا ؤُ ثَافْثِيتْشْ ن ثِيفّسْثْ إِتّْذُوخُّوننْ وَارْ ث إِسّخْسِييْ شَا، \add وَاهْ،\add* س ثِيذتّْ أَذْ إِسُّوفّغْ ثَاسڭْذَا.
\v 4 نتَّا وَارْ إِتِّيحڒْ ؤُ وَارْ إِتّْوَارژِّي أَڒْ د-إِسّْبدّْ ثَاسڭْذَا خْ ثمُّورْثْ ؤُ غَارْ شَّارِيعَا نّسْ أَذْ رَاجَانْثْ ثِيڭْزِيرِينْ.“
\b
\m 
\v 5 ”أَمُّو إِ إِقَّارْ أَربِّي، سِيذِي، ونِّي إِڭِّينْ ؤُ إِبزّْعنْ إِجنْوَانْ، ونِّي إِڭِّينْ ثَامُّورْثْ ذ مِينْ خَاسْ إِغمّْينْ، ونِّي إِتِّيشنْ ثْوَارِّيثْ ن نّفْسْ إِ ڒْڭنْسْ إِ ذَايسْ إِزدّْغنْ، ؤُ بُوحْبڒْ إِ يِينِّي إِڭُّورنْ خْ \add ثمُّورْثْ\add*:
\v 6 ’نشّْ، سِيذِي، ڒَاغِيغْ أَشْ ذِي ثْسڭْذَا ؤُشَا أَذْ شكْ منْعغْ زڭْ ؤُفُوسْ، أَذْ شكْ حْضِيغْ ؤُشَا أَذْ شكْ أَرّغْ ذ ڒْعَاهْذْ إِ ڒْڭنْسْ ذ ثْفَاوْثْ إِ ڒڭْنُوسْ، \x ◘ \xo 42:‏6 \xt يُوح. 8‏:‏12\x*
\v 7 حِيمَا أَذْ ثَارْزْمذْ ثِيطَّاوِينْ إِذَاغَاڒنْ، أَذْ ثسُّوفّْغذْ إِمحْبَاسْ زِي ڒحْبسْ ؤُ يِينِّي إِقِّيمنْ ذِي ثَادْجسْثْ زِي ثَادَّارْثْ ن ثْعسَّاسْثْ.
\v 8 نشّْ ذ سِيذِي، وَا ذ إِسمْ إِنُو، ؤُشَا وَارْ تِّيشغْ شَّانْ إِنُو إِ ونّغْنِي ؤُ أَسمْغَارْ إِنُو وَارْ \add ث تِّيشغْ\add* إِ ڒخْيَاڒَاثْ إِنقْشنْ. \x ◘ \xo 42:‏8 \xt إِشا. 48‏:‏11\x*
\v 9 خْزَارْ، ثِيمسْڒَايِينْ ثِيمزْوُورَا إِوْضنْثْ ؤُشَا ثِيمسْڒَايِينْ ن جْذِيذْ أَذْ ثنْثْ بَارّْحغْ. قْبڒْ مَّا أَذْ فّْغنْثْ، أَذْ أَومْ ثنْثْ سّشْنغْ.‘ “
\b
\m 
\v 10 ”غنّْجمْ إِزْڒِي ن جْذِيذْ إِ سِيذِي، أَسمْغَارْ نّسْ زڭْ إِنڭُّورَا ن ثمُّورْثْ، \add كنِّيوْ\add* إِنِّي إِندّْهنْ ڒبْحَارْ، ذ مَارَّا مِينْ ذَايسْ: \add كنِّينْثْ أَ\add* ثِيڭْزِيرِينْ ذ إِمزْذَاغْ نْسنْثْ. \f ◼ \fr 42:‏10 \ft \bd ’ڒبْحَارْ‘\bd* - نِيغْ ’إِلْ‘.\f*  \x ◘ \xo 42:‏10 \xt إِزهد. 33‏:‏3\x*
\v 11 أَذْ إِسّْڭعّذْ ڒخْڒَا \add ثْمِيجَّا نّسْ\add* ؤُشَا ؤُڒَا ذ ثْندَّامْ نّسْ، \add جْمِيعْ\add* أَكْ-ذ ڒذْشُورْ نِّي ذِي إِزدّغْ قِيذَارْ. أجّْ إِنِّي إِزدّْغنْ ذِي ڒجْرُوفْ أَذْ سْڒِيوْڒونْ، \add أجّْ إِ-ثنْ\add* أَذْ سْغُوينْ س ڒفْرَاحثْ خْ ثْقِيشِّيثِينْ ن إِذُورَارْ،
\v 12 أجّْ إِ-ثنْ أَذْ سّْعُودْجنْ سِيذِي، أَذْ بَارّْحنْ شَّانْ نّسْ خْ \add مَارَّا\add* ثِيڭْزِيرِينْ.
\v 13 سِيذِي أَذْ د-إِفّغْ أَمْ بُو-ثغْرُوضْطْ، أَذْ إِسّكَّارْ مژْرِي ذڭْ ؤُمنْغِي أَمْ ورْيَازْ إِمحْضنْ، نتَّا أَذْ إِسْڒِيوْڒوْ، أَذْ إِسْغُويْ إِ ؤُمنْغِي، أَذْ إِحْصَارْ قَاعْ ڒْعذْيَانْ نّسْ.“
\b
\m 
\v 14 ”نشّْ ثُوغَا سّغْذغْ زڭْ وشْحَاڒْ ؤُيَا، ثُوغَا سْقَارغْ، تّبَّاثغْ إِخفْ إِنُو. أَذْ سْغُويغْ أَمْ يِيشْثنْ إِتَّارُونْ، أَذْ \add ثنْ\add* أَردّْدْجغْ ؤُ أَذْ \add ثنْ\add* صَارْضغْ \add جْمِيعْ\add*.
\v 15 إِذُورَارْ ذ ثوْرِيرِينْ أَذْ ثنْ أَرّغْ ذ أَمسُّوشِي ؤُ أَذْ جّغْ أَغمُّويْ أَزِيزَا نْسنْ مَارَّا أَذْ يَاژغْ، إِغزْرَانْ أَذْ ثنْ ڭّغْ ذ ثِيڭْزِيرِينْ، ؤُشَا أَذْ سِّيژْغغْ إِيڒْمَامنْ.
\v 16 إِذَارْغَاڒنْ أَذْ ثنْ نذْهغْ خْ إِجّْ ن وبْرِيذْ وَارْ ث سِّيننْ، أَذْ ثنْ جّغْ أَذْ ؤُيُورنْ خْ ثْبْرِيذِينْ وَارْ ثنْثْ أَرْڭْبنْ. طّْرَامْ زَّاثْ إِ ثِيطَّاوِينْ نْسنْ أَذْ ث ڭّغْ ذ ثْفَاوْثْ، مِينْ إِفَارْغنْ، أَذْ ث سڭّْذغْ. ثِينَا ذ ثِيمسْڒَايِينْ إِ غَا ڭّغْ ذِي طّْوعْ نْسنْ ؤُ وَارْ ذَايْسنْ سمْحغْ.
\v 17 إِنِّي إِتّْشَاڒَانْ خْ ڒخْيَاڒَاثْ إِنقْشنْ، إِنِّي إِقَّارنْ إِ ڒخْيَاڒَاثْ إِفسْينْ: ’كنِّيوْ ذ إِربِّيثنْ نّغْ!‘، أَقَا نِيثْنِي أَذْ ذوْڒنْ غَارْ ضفَّارْ، أَذْ سضْحَانْ أَطَّاسْ.“ \x ◘ \xo 42:‏17 \xt إِزهد. 97‏:‏7؛ إِشا. 1‏:‏29؛ 44‏:‏11؛ 45‏:‏16\x*
\b
\m 
\v 18 ”سْڒمْ، \add كنِّيوْ\add* إِذُوهْشَارْ! إِذَارْغَاڒنْ، خْزَارمْ ؤُ وَاڒَامْ.
\v 19 مَانْ ونْ إِدْجَانْ ذ أَذَارْغَاڒْ أَمْ ؤُمْسخَّارْ إِنُو، ذ أَذهْشُورْ أَمْ ؤُرقَّاسْ إِنُو؟ مَانْ ونْ إِدْجَانْ ذ أَذَارْغَاڒْ أَمْ ؤُمْثِيقِّي ؤُ ذ أَذَارْغَاڒْ أَمْ ؤُمْسخَّارْ ن سِيذِي؟
\v 20 أَطَّاسْ إِ ثتّْوَاڒِيذْ، \add مَاشَا\add* وَارْ ثُوشِيذْ وَالُو، \add إِوَا\add* نتَّا يَارْزمْ إِمزُّوغنْ، \add مَاشَا\add* وَارْ إِتّسْڒِي شَا. \x ◘ \xo 42:‏20 \xt رُوم. 2‏:‏2‏-‏11\x*
\v 21 ثُوغَا يَارْضَا سِيذِي ذِي طّْوعْ ن ثْسڭْذَا نّسْ \add مَاحنْذْ\add* أَذْ إِسّمْغَارْ ذ إِسّْعُودْجْ شَّارِيعَا.
\v 22 \add مَاشَا ڒخُّو\add* نِيثْنِي ذ إِجّْ ن ڒْڭنْسْ أَشَارنْ ت، كشّْضنْ ت. مَارَّا تّْوَاشدّنْ ذڭْ إِفْرَانْ، تّْوَاقّْننْ ذِي ڒحْبسْ. نِيثْنِي ذوْڒنْ ذ ثَايْمَارْثْ، \add أَمْ\add* وَارْ ذِينْ إِدْجِي ؤُمْسنْجمْ، ذوْڒنْ نِيثْنِي إِ ثْكشَّاضْثْ، \add مَاشَا\add* ؤُڒَا ذ إِجّْ إِقَّارْ: ’أَرّْ إِ-ث-إِ-د!‘
\v 23 مَانْ ونْ زَّايْومْ أَذْ إِوْشْ أَمزُّوغْ إِ مَانْ أَيَا؟ مَانْ ونْ إِ غَا إِحكَّارنْ، \add مَانْ ونْ\add* إِ غَا إِسڒْ ذِي طّْوعْ ن مِينْ غَا يِيڒِينْ أَوَارْنِي مَانْ أَيَا؟
\v 24 مَانْ ونْ إِسِّيوْضنْ يَاعْقُوبْ أَمْ ثيْمَارْثْ ذ إِسْرَائِيل إِ إِخوَّاننْ؟ مَا وَارْ ت إِڭِّي سِيذِي، ونِّي ذِي نخْضَا؟ \add مَاغَارْ\add* نِيثْنِي وَارْ خْسنْ أَذْ ؤُيُورنْ خْ إِبْرِيذنْ نّسْ، وَارْ خْسنْ أَذْ سْڒنْ غَارْ شَّارِيعَا نّسْ.
\v 25 س ؤُينِّي إِزدْجعْ خَاسْ أَسْعَارْ ن وغْضَابْ نّسْ ؤُڒَا ذ لْعُونْفْ ن ڭَارَّا. إِقوَّارْ أَسْ س إِشعَّاڒنْ، \add مَاشَا\add* نتَّا وَارْ ذ أَسْ إِحكَّارْ، إِقّذْ أَسْ ثِيمسِّي، \add مَاشَا\add* نتَّا وَارْ ت إِكسِّي غَارْ وُوڒْ نّسْ.“
\b
\b
\c 43
\s1 سِيذِي ذ أَينِّي ن ؤُمْسنْجمْ ذ ؤُمفْذِي ن إِسْرَايِيلْ
\m 
\v 1 ”\add مَاشَا\add* ڒخُّو، أَمُّو إِ إِقَّارْ سِيذِي، ونِّي شكْ د-إِخڒْقنْ، \add أَ\add* يَاعْقُوبْ، ذ ونِّي ذ أَمْكوَّانْ نّشْ، \add أَ\add* إِسْرَائِيل، وَارْ تّڭّْوذْ شَا، مَاغَارْ نشّْ فكّغْ شكْ، ڒَاغِيغْ أَشْ س يِيسمْ نّشْ، شكْ إِنُو.
\v 2 مَاڒَا ثْشُوقذْ ذڭْ وَامَانْ، أَذْ إِڒِيغْ أَكِيذكْ، مَاڒَا ذڭْ إِغزْرَانْ، وَارْ شكْ تِّيوْينْ. مَاڒَا ثژْوِيذْ خْ ثْمسِّي، وَارْ ثْشمّْضذْ، ؤُشَا أَشعَّاڒْ وَارْ شكْ إِسّْرُوغَا. \x ◘ \xo 43:‏2 \xt إِزهد. 66‏:‏12\x*
\v 3 مَاغَارْ نشّْ ذ سِيذِي، أَربِّي نّشْ، أَمْقدَّاسْ ن إِسْرَائِيل، أَمْسنْجمْ نّشْ. نشّْ وْشِيغْ مِيصْرَا ذ دّيّثْ إِ شكْ، كُوشْ ذ سبَا ذڭْ ومْشَانْ نّشْ.
\v 4 مِينْزِي ثْسكّْوِيذْ أَطَّاسْ ذِي ثِيطَّاوِينْ إِنُو، أَقَا ثتّْوَاسّْعُودْجذْ ؤُ نشّْ تّخْسغْ شكْ. وْشِيغْ إِوْذَانْ ذڭْ ومْشَانْ نّشْ ذ شُّوعُوبْ ذڭْ ومْشَانْ ن ڒعْمَارْ نّشْ.
\v 5 وَارْ تّڭّْوذْ شَا، مَاغَارْ نشّْ أَكِيذكْ. أَذْ أَوْيغْ إِحنْجِيرنْ نّشْ زِي مَانِي د-ثْنقَّارْ ثْفُوشْثْ، أَذْ شكْ سّْمُونغْ زِي مَانِي د-ثْغدْجِي ثْفُوشْثْ. \x ◘ \xo 43:‏5 \xt إِشا. 44‏:‏2؛ إِرْم. 30‏:‏10؛ 46‏:‏27\x*
\v 6 نشّْ أَذْ إِنِيغْ إِ شَّامَالْ: ’أوْشْ!‘ ؤُ إِ لْجَانُوبْ: ’وَارْ تّطّفْ!‘، أَركّْوحْ إِحنْجِيرنْ إِنُو زِي ڒَاڭّْوَاجْ، يسِّي زِي ثْمَا ن ثمُّورْثْ،
\v 7 كُوڒْ  إِجّنْ ونِّي ؤُمِي تّْڒَاغَانْ س يِيسمْ إِنُو، ونِّي د-خڒْقغْ إِ شَّانْ إِنُو، ونِّي كوّْنغْ ذ ونِّي ڭِّيغْ عَاوذْ.“
\b
\m 
\v 8 ”أجّْ أَذْ إِفّغْ ڒْڭنْسْ أَذَارْغَاڒْ، وَاخَّا \add غَارْسنْ\add* ثِيطَّاوِينْ، ؤُڒَا ذ إِذُوهْشَارنْ، وَاخَّا غَارْسنْ إِمزُّوغنْ.
\v 9 أجّْ أَذْ تّْوَاسّْمُوننْ مَارَّا ڒڭْنُوسْ ؤُشَا أجّْ شُّوعُوبْ أَذْ نّْجَارْونْ! مَانْ ونْ زَّايْسنْ إِزمَّارْ أَذْ إِبَارّحْ ثَا، ذ مَانْ ونْ إِزمَّارْ أَذْ أَنغْ يِينِي مِينْ ثُوغَا إِدْجَانْ زِيشْ؟ أجّْ إِ-ثنْ أَذْ أَوْينْ ڒشْهُوذْ نْسنْ مَاحنْذْ أَذْ تّْوَاسڭّْذنْ، ؤُشَا \add أجّْ ڒشْهُوذْ\add* أَذْ سْڒنْ، أَذْ إِنِينْ: ’ذ ثِيذتّْ!‘
\v 10 كنِّيوْ ذ ڒشْهُوذْ إِنُو ؤُڒَا ذ أَمْسخَّارْ إِنُو نِّي فَارْزغْ، حِيمَا أَذْ ثسّْنمْ، أَذْ ذَايِي ثَامْنمْ، أَذْ ثْفهْممْ أَقَا \bd نشّْ نشّْ\bd*. قْبڒْ نشّْ وَارْ إِتّْوَاڭّْ ؤُڒَا ذ إِجّْ ن أَربِّي ؤُشَا أَوَارْنِي أَيِي وَارْ إِتِّيڒِي ؤُڒَا ذ إِجّنْ!، إِقَّارْ سِيذِي. \x ◘ \xo 43:‏10 \xt إِشا. 41‏:‏4؛ 44‏:‏8؛ 45‏:‏21؛ حُوش. 13‏:‏4\x*
\v 11 نشّْ، نشّْ ذ سِيذِي، ؤُ وَارْ إِدْجِي ؤُمْسنْجمْ مْغِيرْ نشّْ.
\v 12 نشّْ بَارّْحغْ ؤُ سّْنجْمغْ ؤُ نشّْ إِوْيغْ أَومْ \add ث-إِ-د\add* غَارْ ؤُمجُّونْ. ؤُڒَا ذ إِجّْ ن \add أَربِّي\add* ڒْبَارَّانِي وَارْ ثُوغِي جَارْ أَومْ. كنِّيوْ ذ ڒشْهُوذْ أَقَا نشّْ ذ أَربِّي، أَمُّو إِ إِقَّارْ سِيذِي.
\v 13 ؤُڒَا زڭْ وَاسّْ-أَ، أَقَا \bd نشّْ نشّْ\bd* ؤُشَا ؤُڒَا ذ إِجّْ وَارْ إِزمَّارْ أَذْ إِسّْفكّْ زڭْ ؤُفُوسْ إِنُو! \add مَاڒَا\add* نشّْ خذْمغْ، مَانْ ونْ إِزمَّارنْ أَذْ ث إِنّقْڒبْ؟“ \x ◘ \xo 43:‏13 \xt إِشا. 14‏:‏27\x*
\b
\m 
\v 14 ”أَمُّو إِ إِقَّارْ سِيذِي، أَمفْذِي نْومْ، أَمْقدَّاسْ ن إِسْرَائِيل: ’ذِي طّْوعْ نْومْ سّكّغْ \add إِجّنْ\add* غَارْ بَابِيلْ ؤُشَا أَذْ ثنْ أَرّغْ أَذْ أَروْڒنْ، ؤُشَا أَذْ هْوَانْ مَارَّا إِكَالْذَانِييّنْ ذڭْ إِغُورَّابَا نِّي زِي ثُوغَا فَارّْحنْ \add أَمُّو قْبڒْ\add*.
\v 15 نشّْ ذ سِيذِي، أَمْقدَّاسْ نْومْ، ونِّي د-إِخڒْقنْ إِسْرَائِيل، أَجدْجِيذْ نْومْ.‘ “
\m 
\v 16 ”أَمُّو إِ إِقَّارْ سِيذِي نِّي إِڭِّينْ أَبْرِيذْ ذِي ڒبْحَارْ ذ ثبْرِيذْثْ ذڭْ وَامَانْ إِجهْذنْ،
\v 17 ونِّي إِجِّينْ إِكَارُّوثنْ ذ ييْسَانْ، ڒْعسْكَارْ ذ جّهْذْ أَذْ فّْغنْ - أَقَا ذَا، زّْڒنْ مُوننْ، وَارْ تّْنكَّارنْعمَّارْصْ، خسْينْ، قْضَانْ أَمْ ثفْثِيتْشْ ن ثِيفّسْثْ! -
\v 18 \add أَمُّو إِ إِقَّارْ سِيذِي\add*: ’وَارْ تّْعقِيڒمْ \add عَاذْ\add* خْ مِينْ ثُوغَا إِدْجَانْ زِيشْ، وَارْ تِّيذَارمْ \add عَاذْ\add* مِينْ إِعْذُونْ.
\v 19 خْزَارْ، أَذْ ڭّغْ مِينْ إِدْجَانْ ن جْذِيذْ، ڒخُّو أَذْ د-إِفّغْ. مَا وَارْ ذ أَسْ ثْحكَّارمْ شَا؟ وَاهْ، نشّْ أَذْ سَّارْسغْ أَبْرِيذْ ذِي ڒخْڒَا، إِغْزَارنْ ذِي ثْنزْرُوفْثْ. \x ◘ \xo 43:‏19 \xt أَسَا. 21‏:‏5\x*
\v 20 ڒْمَاڒْ ن ڒخْڒَا أَذْ أَيِي سّْعُودْجَانْ، ؤُشَّاننْ ن ڒخْڒَا ذ يسِّيسْ ن نّْعَامثْ، مَاغَارْ نشّْ أَذْ ڭّغْ أَمَانْ أَذْ أَزّْڒنْ ذِي ڒخْڒَا ؤُڒَا ذ إِغزْرَانْ ذِي ثْنزْرُوفْثْ، حِيمَا أَذْ سّسْوغْ ڒْڭنْسْ إِنُو، إِنِّي فَارْزغْ.
\v 21 ڒْڭنْسْ-أَ ڭِّيغْ ث إِ نشّْ، نِيثْنِي أَذْ بَارّْحنْ شَّانْ إِنُو.‘ “ \x ◘ \xo 43:‏21 \xt لك. 1‏:‏74، 75\x*
\b
\m 
\v 22 ”\add مَاشَا\add* شكْ وَارْ ذ أَيِي د-ثْڒَاغِيذْ، \add أَ\add* يَاعْقُوبْ، وَارْ ثسِّيحْڒذْ إِخفْ نّشْ أَكِيذِي، \add أَ\add* إِسْرَائِيل!
\v 23 شكْ وَارْ ذ أَيِي د-ثِيوْيذْ إِجّنْ زڭْ وُودْجِي ن ثْغَارْصَا نّشْ ن وشْمَاضْ، ؤُشَا س ثْغَارْصِي نّشْ وَارْ ذ أَيِي ثْشنّْعذْ.عمَّارْصْ وَارْ شكْ حْصَارغْ غَارْ ثوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* ؤُ وَارْ شكْ سِّيحْڒغْعمَّارْصْ س جَّاوِي.
\v 24 شكْ وَارْ ذ أَيِي ثسْغِيذْ أَغَانِيمْ ن ؤُحمُّومْ إِتّْفُوحنْ س ثْمنْيَاثْ ن نُّوقَارْثْ ؤُشَا وَارْ ذ أَيِي ثسّْجِيوْنذْ س ثَاذُونْثْ ن ثْغَارْصَا نّشْ، مَاشَا س دّْنُوبْ نّشْ ثَارْنِيذْ أَيِي-د ڒْخذْمثْ، س ڒْمُوعْصِييَّاثْ نّشْ ثسِّيحْڒذْ أَيِي.“
\b
\m 
\v 25 ”نشّْ، ذ نشّْ، ونِّي إِ غَا إِمسْحنْ إِعذِّيينْ نّشْ ذِي طّْوعْ إِنُو، نشّْ وَارْ تِّيذَارغْ عَاذْ دّْنُوبْ نّشْ.“ \x ◘ \xo 43:‏25 \xt حِز. 36‏:‏22‏-‏38\x*
\b
\m 
\v 26 ”أَرّْ \add إِ-ثنْ\add* غَارْ ڒْبَاڒْ إِنُو، أجّْ أَنغْ أَذْ نمْشَارّعْ، وّثْ خْ يِيخفْ نّشْ مَاحنْذْ أَذْ د-ثَاوْيذْ ثَاسْغَارْثْ نّشْ. \x ◘ \xo 43:‏26 \xt إِشا. 1‏:‏18\x*
\v 27 بَابَاشْ أَمزْوَارُو إِخْضَا ؤُ ؤُڒَا ذ إِمْسصْڒَاحنْ نّشْ عْذُونْ خَافِي. \f ◼ \fr 43:‏27 \ft \bd ’إِمْسصْڒَاحنْ‘\bd* - إِخْسْ أَذْ يِينِي ’إِكهَّاننْ ذ إِنَابِييّنْ نّكْ‘ إِنِّي ثُوغَا إِبدّنْ جَارْ أَربِّي ذ ڒْڭنْسْ نّسْ.\f*
\v 28 \add خنِّي\add* سّْعِيدْجْثغْ إِمقّْرَاننْ ن زَّاوشْثْ إِقدّْسنْ، ؤُ أَرِّيغْ يَاعْقُوبْ مَاحنْذْ أَذْ إِتّْوَاحَارّمْ \add إِ ؤُثحِّي\add* ؤُشَا جِّيغْ إِسْرَائِيل مَاحنْذْ أَذْ ثعيّْبنْ.“
\b
\b
\c 44
\s1 أَسْفَارّغْ ن أَرُّوحْ ن سِيذِي - كُورَاشْ ذ أَمكْسَاوْ
\m 
\v 1 ”ڒخُّو \add مَاشَا\add*، سڒْ، \add أَ\add* أَمْسخَّارْ إِنُو يَاعْقُوبْ، إِسْرَائِيل نِّي فَارْزغْ! \x ◘ \xo 44:‏1 \xt إِشا. 41‏:‏8؛ 43‏:‏5؛ إِرْم. 30‏:‏10؛ 46‏:‏27\x*
\v 2 أَمُّو إِ إِقَّارْ سِيذِي، ونِّي شكْ إِڭِّينْ، ونِّي شكْ إِڭِّينْ زڭْ ؤُعذِّيسْ \add ن يمَّاشْ\add*، ونِّي ذ أَشْ إِوْشِينْ أَفُوسْ: ’وَارْ تّڭّْوذْ شَا، \add أَ\add* يَاعْقُوبْ، أَمْسخَّارْ إِنُو، يَاشُورُونْ نِّي فَارْزغْ!
\v 3 مَاغَارْ نشّْ أَذْ سيّْحغْ أَمَانْ خْ مِينْ إِفُّوذنْ ذ ثْسدْجْيَاوِينْ خْ مِينْ يُوژْغنْ. نشّْ أَذْ زدْجْعغْ أَرُّوحْ إِنُو خْ زَّارِيعثْ نّشْ ؤُڒَا ذ لْبَارَاكَا إِنُو خْ ثَارْوَا نّشْ. \x ◘ \xo 44:‏3 \xt إِشا. 35‏:‏7؛ يُووِ. 3‏:‏1؛ يُوح. 7‏:‏38؛ ڒخ. 2‏:‏18\x*
\v 4 نِيثْنِي أَذْغمْينْ جَارْ أَرْبِيعْ، أَمْ يِيصفْصَافنْ غَارْ ثْغزْرَاثِينْ ن وَامَانْ.
\v 5 إِجّنْ أَذْ يِينِي: ’\add نشّْ\add* ن سِيذِي!‘ ؤُشَا إِجّنْ نّغْنِي أَذْ إِڒَاغَا إِخفْ نّسْ س يِيسمْ ن يَاعْقُوبْ، ؤُ \add عَاوذْ\add* إِجّنْ نّغْنِي أَذْ يَارِي س ؤُفُوسْ نّسْ: ’\add نشّْ\add* ن سِيذِي!‘ ؤُشَا أَذْ إِكنَّا إِخفْ نّسْ س يِيسمْ \add إِشنّْعنْ\add* ’إِسْرَائِيل‘.‘ “
\b
\m 
\v 6 ”أَمُّو إِ إِقَّارْ سِيذِي، أَجدْجِيذْ ن إِسْرَائِيل، ذ أَمفْذِي نّسْ، سِيذِي ن ڒْعسْكَارَاثْ: ’نشّْ ذ أَمزْوَارُو، نشّْ ذ أَنڭَّارُو، نْهْڒَا نشّْ وَارْ إِدْجِي ؤُڒَا ذ إِجّْ ن أَربِّي نّغْنِي. \x ◘ \xo 44:‏6 \xt إِشا. 41‏:‏4؛ 48‏:‏12؛ أَسَا. 1‏:‏8، 17؛ 22‏:‏13\x*
\v 7 مَانْ ونْ إِزمَّارنْ أَذْ إِبَارّحْ أَمْ نشّْ؟ أجّْ إِ-ث أَذْ \add ث\add* يِينِي ؤُ أَذْ أَيِي ث إِسّْشنْ زڭْ وَاسّْ نِّي ذِي ژُّوغْ ڒْڭنْسْ ن وشْحَاڒْ ؤُيَا. أجّْ إِ-ثنْ أَذْ أَسنْ عَاوْذنْ ثِيمسْڒَايِينْ ن ثِيوشَّا، مِينْ إِ د غَا يَاسنْ.
\v 8 وَارْ تّْنخْڒِيعمْ ؤُ وَارْ تّڭّْوْذمْ. مَا وَارْ ذ أَومْ ث-إِ-د-سِّيوْضغْ زڭْ \add وَاكُوذْ ن\add* زِيشْ غَارْ إِمزُّوغنْ نْومْ ؤُ مَا وَارْ حَاجِيغْ ث؟ كنِّيوْ ذ ڒشْهُوذْ إِنُو: مَا أَقَا ذِينْ إِجّْ ن أَربِّي نْهْڒَا نشّْ؟ وَارْ \add ذِينْ\add* إِدْجِي ؤُڒَا ذ إِشْثْ ن ثصْضَارْثْ نّغْنِي، نشّْ وَارْ سِّينغْ ؤُڒَا ذ إِجّنْ.‘ “ \x ◘ \xo 44:‏8 \xt أَعَوذ. 4‏:‏35، 39؛ 32‏:‏39؛ 1 صم. 2‏:‏2؛ إِشا. 45‏:‏21\x*
\b
\m 
\v 9 ”إِنِّي إِتّڭّنْ ڒخْيَاڒَاثْ إِنقْشنْ إِخْوَانْ، ؤُ \add ڒخْيَاڒَاثْ\add* نِّي تّخْسنْ نِيثْنِي وَارْ نفّْعنْثْ ذڭْ وَالُو. نِيثْنِي \add س يِيخفْ نْسنْ\add* ذ ڒشْهُوذْ نْسنْثْ أَقَا وَارْ تّْوِيڒِينْثْ ؤُ وَارْ سِّيننْثْ وَالُو، أَڒَامِي غَا ذوْڒنْ تّْسضْحَانْ نِيثْنِي.
\v 10 مَانْ ونْ إِتّڭّنْ إِجّْ ن أَربِّي ؤُ \add مَانْ ونْ\add* إِتّْكبَّانْ ڒخْيَاڒْ ن لْ-أَصْنَامْ أَمْ وَارْ غَارسْ بُو ثِيزِي زَّايسْ؟
\v 11 خْزَارْ، مَارَّا إِشْرِيشنْ نْسنْ أَذْ ذوْڒنْ تّْسضْحَانْ، مَاغَارْ أَيْثْ ن بُو-صّنْعثْ \add إِ إِخدّْمنْ س ؤُكشُّوضْ ذ وژْرُو\add* ذ إِوْذَانْ وَاهَا. أجّْ إِ-ثنْ أَذْ مُوننْ، أَذْ كَّارنْ، أَذْ نّْخڒْعنْ، نِيثْنِي أَذْ ذوْڒنْ تّْسضْحَانْ جْمِيعْ. \x ◘ \xo 44:‏11 \xt إِزهد. 97‏:‏7؛ إِشا. 1‏:‏29؛ 42‏:‏17؛ 45‏:‏16\x*
\m 
\v 12 أَمْزِيڒْ ن وُوزَّاڒْ غَارسْ إِميْذِي ن ومْزِيڒْ، إِخدّمْ غَارْ ڒفْحمْ إِتّحْذُوذُوقنْ، إِتّْقَارّسْ ڒخْيَاڒْ س إِفْضِيسنْ \add نّسْ\add*. إِخدّمْ إِ-ث س ؤُغِيڒْ إِجهْذنْ. نتَّا إِدْجُوژْ أَڒَامِي وَارْ غَارسْ إِقِّيمْ بُو جّْهذْ عَاذْ. وَارْ إِسسّْ أَمَانْ أَڒْ غَا يَاحڒْ أَطَّاسْ. \x ◘ \xo 44:‏12 \xt إِرْم. 10‏:‏3\x*
\v 13 أَنجَّارْ إِعبَّارْ ثَافْروْثْ س ؤُفِيڒُو نّسْ ن ڒعْبَارْ، يَارشّمْ \add ڒخْيَاڒْ إِنقْشنْ\add* س ؤُكرَّاجْ، ؤُ إِنجَّارْ إِ-ث س ڒْمُوسْ ؤُشَا يَارشّمْ إِ-ث س دّوَارَا ؤُ إِڭَّا إِ-ث ذ إِجّْ ن ڒخْيَاڒْ ن بْنَاذمْ مَاحنْذْ أَذْ إِتّْوَاسَّارْسْ ذڭْ إِشْثْ ن ثَادَّارْثْ.
\v 14 إِزدّمْ بْنَاذمْ ثِيشجُّورَا ن ثنْڭلْثْ إِ يِيخفْ نّسْ، إِكسِّي إِشْثْ ن \add ثْشجَّارْثْ ن\add* سِّيذْرِي نِيغْ ن ڒْبدْجُوضْ، يَارزُّو إِ يِيخفْ نّسْ جَارْ ثْشجُّورَا ن وزْغَارْ. إِتّژُّو إِشْثْ ن ثَايْذَا ؤُشَا ثْمقَّارْ س ونْژَارْ. \f ◼ \fr 44:‏14 \ft \bd ’أَزْغَارْ‘\bd* - نِيغْ ’ڒْغَابثْ‘ نِيغْ ’ثَازْڭَانْثْ‘.\f*
\v 15 أَذْ ثِيڒِي \add ثْشجَّارْثْ\add* ذ ڒفْحمْ إِ بْنَاذمْ. إِكسِّي زَّايسْ ؤُشَا إِژْغَاڒَا إِخفْ نّسْ غَارسْ. عَاوذْ إِسّْرَاقَّا ثِيمسِّي، إِسّْننَّا زَّايسْ أَغْرُومْ. زِي ثْشجَّارْثْ إِتّڭّْ \add بْنَاذمْ\add* عَاوذْ إِجّْ ن أَربِّي ؤُشَا إِتّْبنْذَاقْ أَسْ، إِتّڭّْ زَّايسْ ڒخْيَاڒْ إِنقْشنْ ؤُشَا إِسجَّاذْ أَسْ.
\v 16 إِجّْ ن وزْينْ \add ن ؤُكشُّوضْ\add* زَّايسْ إِسّشْمَاضْ إِ-ث س ثْمسِّي، أَكْ-ذ وزْينْ إِقِّيمنْ إِتّتّْ أَيْسُومْ. إِشنّفْ أَيْسُومْ ؤُشَا إِتّْيَاوَانْ. إِژْغَاڒَا إِخفْ نّسْ، إِقَّارْ: ’أَهْ، مَامّشْ حمِّيغْ، نشّْ تَّاشِيغْ أَكْ-ذ ثْمسِّي!‘
\v 17 زِي مِينْ إِقِّيمنْ \add ن ؤُكشُّوضْ\add* إِتّڭّْ إِجّْ ن أَربِّي، إِجّْ ن ڒخْيَاڒْ إِنقْشنْ. إِسجَّاذْ أَسْ، إِتّْبنْذَاقْ زَّاثسْ، إِتّْژَادْجْ غَارسْ، إِقَّارْ: ’سنْجمْ أَيِي، مِينْزِي شكْ ذ أَربِّي إِنُو!‘ “
\b
\m 
\v 18 ”وَارْ سِّيننْ، وَارْ تّْحِيكِينْ، مَاغَارْ ثِيطَّاوِينْ نْسنْ مسْحنْثْ ؤُمِي وَارْ تّْوِيڒِينْ وَالُو، ؤُشَا ؤُڒَاونْ نْسنْ وَارْ تّفْثِيننْ.
\v 19 ؤُڒَا ذ إِجّْ إِتّڭّْ إِ-ت غَارْ وُوڒْ نّسْ ؤُشَا وَارْ ذِينْ بُو ثُوسّْنَا ؤُڒَا ذْ ڒفْهَامثْ حِيمَا أَذْ إِنِينْ: ’إِجّْ ن وزْينْ زَّايسْ سّْشمْضغْ ث ذِي ثْمسِّي. سّْننّغْ أَغْرُومْ خْ ڒفْحمْ نّسْ \add إِتّحْذُوذُوقنْ\add* ؤُ شنْفغْ أَيْسُومْ ؤُ شِّيغْ ث. زِي مِينْ إِقِّيمنْ \add ن ؤُكشُّوضْ\add* مَا أَذْ زَّايسْ ڭّغْ جّْعِيفشْثْ \add ن صَّانَامْ\add*، مَا أَذْ سجْذغْ زَّاثْ إِ ؤُكشُّوضْ ن ثْشجَّارْثْ؟‘ \f ◼ \fr 44:‏19 \ft \bd ’ثَاشجَّارْثْ‘\bd* - نِيغْ ’أَدَّاڭْ‘ (’إِدَّاڭنْ‘).\f*
\v 20 نتَّا إِسّشَّا إِخفْ نّسْ س إِغّضْ، ؤُڒْ نّسْ إِتّْوَاغَارّنْ إِغكّْوَا إِ-ث. وَارْ إِزمَّارْ أَذْ إِسّنْجمْ ڒعْمَارْ نّسْ، أَذْ يِينِي: ’مَا \add خنِّي\add* وَارْ \add ذِينْ\add* إِدْجِي ڒْغشّْ ذڭْ ؤُفُوسْ أَفُوسِي إِنُو؟‘ “
\b
\m 
\v 21 ”عْقڒْ خْ مَانْ أَيَا، \add أَ\add* يَاعْقُوبْ، \add أَ شكْ\add* إِسْرَائِيل! مَاغَارْ أَقَا شكْ ذ أَمْسخَّارْ إِنُو، نشّْ كوّْنغْ شكْ، شكْ ذ أَمْسخَّارْ إِنُو، \add أَ\add* إِسْرَائِيل، وَارْ شكْ تّتُّوغْ شَا.
\v 22 نشّْ مسّْحغْ إِعذِّيينْ نّشْ أَمْ ثَايُّوثْ ؤُڒَا ذ دّْنُوبْ نّشْ أَمْ ؤُسيْنُو. ذْوڒْ-د غَارِي، مَاغَارْ نشّْ فكّغْ شكْ.“
\b
\m 
\v 23 ”غنّْجمْ س ڒفْرَاحثْ، \add أَ\add* إِجنْوَانْ، مَاغَارْ سِيذِي إِڭَّا إِ-ث. سْڒِيوْڒوثْ، \add أَ\add* ڒَادْجَاغْ ن ثمُّورْثْ، كْسِيمْ ذڭْ إِغُويَّانْ س ڒفْرَاحثْ، \add أَ\add* إِذُورَارْ، سْڒِيوْڒِيومْ، \add أَ شكْ\add*، أَزْغَارْ ذ كُوڒْ ثَاشجَّارْثْ إِ ذَايسْ \add إِدْجَانْ\add*! مَاغَارْ سِيذِي إِفكّْ إِ يَاعْقُوبْ، إِسّْعُودْجْ إِخفْ نّسْ ذِي إِسْرَائِيل.“ \f ◼ \fr 44:‏23 \ft \bd ’أَزْغَارْ‘\bd* - نِيغْ ’ڒْغَابثْ‘ نِيغْ ’ثَازْڭَانْثْ‘.\f*
\b
\m 
\v 24 ”أَمُّو إِ إِقَّارْ سِيذِي، أَمفْذِي نّشْ، ونِّي شكْ إِڭِّينْ زڭْ ؤُعذِّيسْ \add ن يمَّاشْ\add*: ’نشّْ ذ سِيذِي ونِّي إِڭِّينْ مَارَّا، ونِّي إِتّْبزَّاعنْ أَجنَّا، نشّْ وَاهَا، نشّْ ذ ونِّي إِسَّارْسنْ ثَامُّورْثْ. مَانْ ونْ \add ثُوغَا خنِّي\add* أَكِيذِي؟ \x ◘ \xo 44:‏24 \xt أَيُوبْ 9‏:‏8؛ إِزهد. 104‏:‏2؛ إِشا. 40‏:‏22؛ 42‏:‏5؛ 45‏:‏12\x*
\v 25 \add نشّْ\add* ذ ونِّي إِبطّْڒنْ ڒعْڒَامَاثْ ن أَيْثْ ن بُو-إِخَارِّيقنْ ؤُشَا سّْبُوهْڒِيغْ إِڭزَّاننْ، ذ ونِّي إِسّْوخَّارنْ إِمِيغِيسنْ ؤُ يَارَّا ثُوسّْنَا نْسنْ ذ ثَاغْيُوڒِي،
\v 26 ونِّي إِسّْمثْننْ أَوَاڒْ ن ؤُمْسخَّارْ نّسْ ؤُ إِسّقْفڒْ شّْوَارْ ن إِرقَّاسنْ نّسْ، ونِّي إِقَّارنْ إِ ؤُرْشَالِيمْ: ’أَذْ ذَايمْ إِڒِينْ إِمزْذَاغْ عَاذْ!‘ ؤُشَا إِ \add كُوڒْ إِشْثْ زِي\add* ثْندَّامْ ن يَاهُوذَا: ’شمْ أَذْ ثتّْوَاسّْبدّذْ عَاوذْ!‘ ؤُشَا ’نشّْ أَذْ سّْبدّغْ ڒْخِيرْبَاثْ نّسْ عَاوذْ!‘،
\v 27 ونِّي إِقَّارنْ إِ \add وَامَانْ\add* يُودْجْغنْ: ’أَژْغمْ، نشّْ أَذْ سِّيژْغغْ إِغزْرَانْ نْومْ!‘،
\v 28 ونِّي إِقَّارنْ إِ كُورَاشْ: ’\add نتَّا ذ\add* أَمكْسَاوْ إِنُو، نتَّا أَذْ إِسّقْفڒْ ڒْخَاضَارْ إِنُو، ؤُمِي غَا إِنِينْ إِ ؤُرْشَالِيمْ: ’أَذْ شمْعذْڒنْ!‘، ؤُ إِ زَّاوشْثْ ثَامقّْرَانْثْ: ’أَذْ أَمْ ڭّنْ ذْسَاسْ!‘ “
\b
\b
\c 45
\s1 كُورَاشْ، أَمذْهُونْ ن سِيذِي، أَذْ إِبَارّحْ س ؤُفكِّي
\m 
\v 1 ”أَمُّو إِ إِقَّارْ سِيذِي إِ ؤُمذْهُونْ نّسْ، إِ كُورَاشْ، ونِّي زِي طّْفغْ أَفُوسْ نّسْ أَفُوسِي مَاحنْذْ أَذْ أَسْ سَّاضَارغْ ڒڭْنُوسْ زَّاثْ إِ وُوذمْ نّسْ: ’أَذْ سَّارْخُوغْ ثِيحزَّامِينْ س ڒسْنَاحْ خْ ثجْعِينَّاثِينْ ن إِجدْجِيذنْ، حِيمَا أَذْ أَسْ أَرْزْمغْ ثِيوُّورَا، ؤُ ڒبْنِييَّاثْ ن ثوُّورَا وَارْ تّْوَابلِّيعنْثْ شَا.
\v 2 نشّْ أَذْ أَشْ إِزْوَارغْ، أَذْ وَاطِيغْ مِينْ وَارْ إِهوْننْ، أَذْ أَرْژغْ ثِيوُّورَا ن نّْحَاسْ ؤُ أَذْ وْثِيغْ زّكْرُونَاثْ ن وُوزَّاڒْ ذ إِوثْوِيثنْ.
\v 3 أَذْ أَشْ وْشغْ ڒكْنُوزْ ن ثَادْجسْثْ، أَڭْڒَا إِنُّوفَّارنْ، حِيمَا أَذْ ثسّْنذْ أَقَا نشّْ، سِيذِي، ذ ونِّي شكْ إِڒَاغَانْ س يِيسمْ نّشْ، أَربِّي ن إِسْرَائِيل.
\v 4 ذِي طّْوعْ ن ؤُمْسخَّارْ إِنُو يَاعْقُوبْ، إِسْرَائِيل ونِّي فَارْزغْ، ڒَاغِيغْ أَشْ س يِيسمْ نّشْ، وْشِيغْ أَشْ إِسمْ \add ن شَّانْ\add*، \add وَاخَّا\add* وَارْ ذ أَيِي ثسِّينذْ شَا.
\v 5 نشّْ ذ سِيذِي، وَارْ ذِينْ إِدْجِي ونّغْنِي، نْهْڒَا نشّْ وَارْ إِدْجِي أَربِّي. أَذْ أَشْ حزّْمغْ أَبْيَاسْ، وَاخَّا وَارْ ذ أَيِي ثسِّينذْ شَا، \x ◘ \xo 45:‏5 \xt أَعَوذ. 4‏:‏35، 39؛ 32‏:‏39؛ إِشا. 44‏:‏8\x*
\v 6 مَاحنْذْ أَذْ سّْننْ زِي مَانِي د-ثْنقَّارْ ثْفُوشْثْ أَڒْ مَانِي ثْغدْجِي، أَقَا نْهْڒَا نشّْ وَارْ \add ذِينْ\add* إِدْجِي ؤُڒَا ذ إِشْثْ ن ثْمسْڒَاشْثْ، نشّْ ذ سِيذِي، وَارْ ذِينْ إِدْجِي نّغْنِي.
\v 7 نشّْ تّڭّغْ ثَافَاوْثْ ؤُ خدْجْقغْ-د ثَادْجسْثْ، تّڭّغْ ڒهْنَا ؤُ خدْجْقغْ-د ڒْغَارْ، نشّْ، سِيذِي، ذ ونِّي إِتّڭّنْ مَارَّا أَيَا.‘ “
\b
\m 
\v 8 ”ؤُذُوممْ، \add أَ كنِّيوْ\add* إِجنْوَانْ، زِي سنّجْ، جّمْ إِسيْنُوثنْ أَذْ د-فَارّْغنْ ثَاسڭْذَا، أَذْ ثنُّورْزمْ ثمُّورْثْ، ؤُشَا \add جّمْ ثنْ\add* أَذْ أَوْينْ أَسنْجمْ إِ ڒْغِيدْجثْ ؤُ أجّْ ثَاسڭْذَا أَذْ ثغْمِي جْمِيعْ أَكِيذسْ. نشّْ، سِيذِي، خڒْقغْ ث.“
\b
\m 
\v 9 ”\bd ؤُشْثْ\bd* خْ ونِّي إِتّمْشُوبُّوشنْ أَكْ-ذ ونِّي ث إِڭِّينْ، إِجّْ ن ؤُقدُّوحْ جَارْ إِقدُّوحنْ نّغْنِي؟ مَا ثْزمَّارْ ثْڒَاخْثْ أَذْ ثِينِي إِ ونِّي ث إِڭِّينْ: ’مِينْ ثڭِّيذْ؟‘ نِيغْ ثْزمَّارْ ڒْقشْعثْ نّشْ أَذْ ثِينِي: ’وَارْ غَارسْ بُو إِفَاسّنْ‘؟ \x ◘ \xo 45:‏9 \xt إِرْم. 18‏:‏6؛ رُوم. 9‏:‏20\x*
\v 10 \bd ؤُشْثْ\bd* خْ ونِّي إِقَّارنْ إِ بَابَا\add س\add*: ’مِينْ د-ثجِّيذْ؟‘ نِيغْ إِ ثمْغَارْثْ: ’مِينْ د-ثُورُوذْ؟‘ “
\b
\m 
\v 11 ”أَمُّو إِ إِقَّارْ سِيذِي، أَمْقدَّاسْ ن إِسْرَائِيل، ذ ونِّي ث إِڭِّينْ: ’سقْسَامْ أَيِي خْ ثْمسْڒَايِينْ إِ د إِتَّاسنْ، تّشْڒمْ خَافِي أَذْ حْضِيغْ إِحنْجِيرنْ إِنُو ؤُڒَا ذ ڒْخذْمثْ ن إِفَاسّنْ إِنُو.
\v 12 نشّْ ڭِّيغْ ثَامُّورْثْ ؤُ خڒْقغْ-د خَاسْ بْنَاذمْ. \add وَاهْ\add* ذ نشّْ \add إِ ت يڭِّينْ\add*، إِفَاسّنْ إِنُو بزّْعنْ إِجنْوَانْ، ؤُ مَارَّا ڒْعسْكَارَاثْ نْسنْ تُّومُورغْ ثنْثْ. \f ◼ \fr 45:‏12 \ft \bd ’ڒْعسْكَارَاثْ نْسنْ‘\bd* - إِخْسْ أَذْ يِينِي: ثَافُوشْثْ ذ ثْزِيرِي ذ إِثْرَانْ ذ ثمُّورَا ن إِجنْوَانْ، مَاشَا ؤُڒَا ذ لْمَالَاكَاثْ ذ إِمْقدَّاسنْ ن سِيذِي أَربِّي.\f*
\v 13 نشّْ سّكَّارغْ ث ذِي ثْسڭْذَا ؤُشَا أَذْ سڭّْمغْ مَارَّا إِبْرِيذنْ نّسْ. نتَّا أَذْ إِبْنَا ثَانْذِينْثْ إِنُو عَاوذْ ؤُشَا أَذْ إِسّْنُوفْسڒْ إِمحْبَاسْ إِنُو، وَارْ إِدْجِي إِ تَّامَانْ ؤُ وَارْ إِدْجِي إِ ثَارْزفْثْ!‘ إِقَّارْ سِيذِي ن ڒْعسْكَارَاثْ.“ \f ◼ \fr 45:‏13 \ft \bd ’نشّْ سّكَّارغْ ث‘\bd* - إِخْسْ أَذْ يِينِي ’نشّْ سّكَّارغْ كُورَاشْ‘ (خْزَارْ أَيثْ 1).\f*  \x ◘ \xo 45:‏13 \xt 2 إِم. 36‏:‏22؛ عِز. 1‏:‏1؛ إِشا. 44‏:‏28؛ عبر. 11‏:‏10\x*
\b
\m 
\v 14 ”أَمُّو إِ إِقَّارْ سِيذِي: ’أَرْبرْ نْ إِمِيصْرِييّنْ ذ صّڒْعثْ ن أَيْثْ ن كُوشْ ذ سَابَا، إِرْيَازنْ إِمْغَارنْ ذِي ثِيذِّي، أَذْ غَارمْ د-ژْوَانْ ؤُشَا أَذْ إِڒِينْ نّمْ. نِيثْنِي أَذْ شمْ ضْفَارنْ، أَذْ غَارمْ عْذُونْ ذِي سّْنَاسڒْ، أَذْ أَمْ سجْذنْ، أَذْ أَمْ سلّْمنْ إِخفْ نْسنْ، أَذْ نعْمنْ: ’س ثِيذتّْ، غَارمْ إِ إِدْجَا أَربِّي، وَارْ ذِينْ إِدْجِي ونّغْنِي، ؤُڒَا ذ إِجّْ نّغْنِي مْغِيرْ أَربِّي!‘
\v 15 ذ ثِيذتّْ، شكْ ذ أَربِّي إِنُوفَّارنْ، أَربِّي ن إِسْرَائِيل، أَمْسنْجمْ.
\v 16 نِيثْنِي مَارَّا أَذْ سضْحَانْ، أَذْ تّْوَافضْحنْ عَاوذْ. إِمْزِيڒنْ نْ ڒخْيَاڒَاثْ ن لْ-أَصْنَامْ أَذْ فّْغنْ جْمِيعْ، نّْفضْهنْ. \x ◘ \xo 45:‏16 \xt إِشا. 44‏:‏11\x*
\v 17 إِسْرَائِيل أَذْ إِتّْوَاسّنْجمْ س \add ؤُفُوسْ ن\add* سِيذِي س إِجّْ ن ؤُسنْجمْ إِتّْذُومَانْ. وَارْ ثتّْسضْحِيمْ ؤُ وَارْ ثتّْنفْضِيحمْ إِ ڒبْذَا قَاعْ.‘ “
\b
\m 
\v 18 ”مَاغَارْ أَمُّو إِ إِقَّارْ سِيذِي، ونِّي د-إِخڒْقنْ إِجنْوَانْ، نتَّا، أَربِّي، ذ ونِّي إِكوّْننْ ثَامُّورْثْ ؤُشَا إِتّڭّْ إِ-ت، نتَّا، ذ ونِّي ت إِسّْمثْننْ. وَارْ ت-إِ-د-إِخْڒِيقْ ثخْوَا، \add مَاشَا\add* إِكوّنْ إِ-ت مَاحنْذْ أَذْ خَاسْ زدّْغنْ: نشّْ ذ سِيذِي، وَارْ إِدْجِي ؤُڒَا ذ إِجّْ نّغْنِي!“ \x ◘ \xo 45:‏18 \xt إِشا. 42‏:‏5؛ 45‏:‏5، 14\x*
\b
\m 
\v 19 ”وَارْ سِّيوْڒغْ س ثْنُوفّْرَا، ذِي شَا ن ومْشَانْ إِبَارّشْننْ ذِي ثمُّورْثْ. نشّْ وَارْ نِّيغْ إِ ثَارْوَا ن يَاعْقُوبْ: أَرْزُومْ أَيِي بَاطڒْ! نشّْ ذ سِيذِي نِّي إِسَّاوَاڒنْ ثَاسڭْذَا، ذ ونِّي إِتّْبَارّْحنْ مِينْ إِدْجَانْ إِسڭّْمنْ.“ \x ◘ \xo 45:‏19 \xt أَعَوذ. 30‏:‏11\x*
\b
\m 
\v 20 ”مُونمْ، أَسمْ-د، قَارّْبمْ-د مُوننْ، \add أَ كنِّيوْ،\add* إِنِّي إِنّجْمنْ زِي ڒڭْنُوسْ! نِيثْنِي وَارْ سِّيننْ وَالُو، إِنِّي يَاربُّونْ ڒخْيَاڒَاثْ إِنقْشنْ ن ؤُكشُّوضْ ؤُشَا تّْعبّْذنْ إِ يِيجّْ ن أَربِّي نِّي وَارْ إِزمَّارنْ أَذْ إِسّنْجمْ. \x ◘ \xo 45:‏20 \xt إِشا. 44‏:‏18، 19\x*
\v 21 بَارّْحمْ، قَارّْبمْ-د. مْشَاوَارمْ ذِي وِينْ جَارْ أَومْ: مَانْ ونْ إِڭِّينْ أَذْ سْڒنْ أَيَا زڭْ وشْحَاڒْ ؤُيَا، مَانْ ونْ زَّايسْ إِبَارّْحنْ زِي مڒْمِي؟ مَا وَارْ إِدْجِي ذ نشّْ، سِيذِي؟ نْهْڒَا نشّْ وَارْ إِدْجِي ؤُڒَا ذ إِجّْ ن أَربِّي نّغْنِي، نْهْڒَا نشّْ وَارْ \add ذِينْ\add* إِدْجِي أَربِّي أَمْسڭّذْ ذ ؤُمْسنْجمْ. \x ◘ \xo 45:‏21 \xt إِشا. 41‏:‏22، 26، 27؛ 43‏:‏9، 10؛ 45‏:‏5، 14، 18\x*
\v 22 قڒْبمْ-د غَارِي ؤُ ثجّمْ إِخفْ نْومْ أَذْ تّْوَاسّْنجْممْ، \add أَ كنِّيوْ،\add* مَارَّا \add إِوْذَانْ ن\add* طّْرُوفَا ن ثمُّورْثْ، مَاغَارْ نشّْ ذ أَربِّي ؤُ وَارْ \add ذِينْ\add* إِدْجِي ؤُڒَا ذ إِجّْ ن نّغْنِي.
\v 23 نشّْ جُّودْجغْ غَارْ إِخفْ إِنُو، إِفّغْ-د إِجّْ ن وَاوَاڒْ زڭْ ؤُقمُّومْ إِنُو ذِي ثْسڭْذَا ؤُشَا \add أَوَاڒْ-أَ\add* وَارْ ذِينْ إِقِّيمْ وذْوَاڒْ: أَقَا مَارَّا أَفُوذْ أَذْ يَاضَارْ زَّاثِي، مَارَّا إِڒسْ أَذْ غَارِي إِجَّادْجْ! \x ◘ \xo 45:‏23 \xt رُوم. 4‏:‏11؛ فِيل. 2‏:‏10\x*
\v 24 أَذْ خَافِي قَّارنْ: ’ذِي سِيذِي وَاهَا ثدْجَا ثَاسڭْذَا إِفيّْضنْ ذ جّهْذْ!‘ نِيثْنِي أَذْ غَارسْ د-أَسنْ، \add مَاشَا\add* مَارَّا إِنِّي خَاسْ إِتّْفُوڭْمنْ، أَذْ سضْحَانْ. \x ◘ \xo 45:‏24 \xt إِشا. 41‏:‏11\x*
\v 25 \add مَاشَا\add* مَارَّا زَّارِيعثْ ن إِسْرَائِيل، أَذْ تّْوَاسڭّْذنْ نِيثْنِي ذِي سِيذِي ؤُشَا أَذْ \add ث\add* شنّْعنْ.“
\b
\b
\c 46
\s1 أَوطُّو ن إِربِّيثنْ ن بَابِيلْ
\m 
\v 1 ”\add صَّانَامْ\add* بِيلْ يُوضَارْ، نابُو إِقْوسْ \add غَارْ ثمُّورْثْ\add*، أَقَا ڒخْيَاڒَاثْ ن لْ-أَصْنَامْ نْسنْ \add ذقّْڒنْثْ\add* إِ ڒْمَاڒْ ؤُ إِ ڒبْهَايمْ. مِينْ ثُوغَا ثَاربُّومْ كنِّيوْ، \add أَقَا ڒخُّو\add* ذ ڒحْمُوڒْ، دّْقڒْ إِ \add ڒْمَاڒْ\add* إِفْنَانْ س ڒْوحْڒَانْ.
\v 2 أَقَا قوْسنْ أَمْ كمّْڒنْ، ؤُضَارنْ، وَارْ زمَّارنْ أَذْ سّْنجْمنْ دّْقڒْ، ؤُشَا ؤُڒَا ذ نِيثْنِي سِيمَانْثْ نْسنْ ؤُيُورنْ ذِي ثْمحْبَاسْثْ.“
\b
\m 
\v 3 ”سْڒمْ غَارِي، \add أَ\add* ثَادَّارْثْ ن يَاعْقُوبْ، ذ مَارَّا مِينْ إِقِّيمنْ ن ثَادَّارْثْ ن إِسْرَائِيل، \add كنِّيوْ،\add* إِنِّي كْسِيغْ زڭْ ؤُعذِّيسْ ن يمَّاثْومْ، إِنِّي أَرْبُورغْ زڭْ وَامِي ثْسمْحمْ ذڭْ ؤُعذِّيسْ ن يمَّاثْومْ.
\v 4 أَڒْ ثَاوْسَارْثْ \add نْومْ\add* \bd نشّْ نشّْ\bd*، أَڒْ غَا ثْشَابمْ، أَذْ \add كنِّيوْ\add* أَرْبُوغْ. نشّْ ڭِّيغْ \add ث\add* ؤُ نشّْ أَذْ \add كنِّيوْ\add* كْسِيغْ، أَذْ \add كنِّيوْ\add* أَرْبُوغْ ؤُ أَذْ \add كنِّيوْ\add* سّْنجْمغْ.“
\b
\m 
\v 5 ”أَكْ-ذ مَانْ ونْ ثخْسمْ أَذْ أَيِي ثسّمْقُودَّامْ، ؤُ مَانْ ونْ ثخْسمْ أَكِيذِي ثسّكّْوِيمْ \add مَاحنْذْ\add* أَذْ نمْرَاوَاسْ؟ \x ◘ \xo 46:‏5 \xt إِشا. 40‏:‏18، 25\x*
\v 6 تّْفَارَّاغنْ نِيثْنِي ؤُرغْ زِي ثشْيَارْثْ ؤُ وزّْننْ نُّوقَارْثْ خْ ڒْمِيزَانْ. تّْخدْجْصنْ إِجّْ ن ومْزِيڒْ ن وُورغْ، \add مَاحنْذْ\add* نتَّا أَذْ زَّايسْ إِڭّْ إِجّْ ن أَربِّي. سجَّاذنْ، وَاهْ، بنْذْقنْ أَسْ.
\v 7 أَربُّونْ ث خْ ثغْرُوضْثْ، كسِّينْ ث ذَا ذ ذِيهَا، خنِّي سّْبدَّانْ ث ذڭْ ومْشَانْ نّسْ. ذِينِّي إِتّْغِيمَا إِبدّْ، وَارْ إِتّنْهِيزِّي سّنِّي. وَاهْ، مَاڒَا حذْ إِڒَاغَا أَسْ، وَارْ د-إِتَّارِّي، وَارْ ث إِسّنْجَامْ زِي ڒحْصَارثْ نّسْ.“ \x ◘ \xo 46:‏7 \xt إِشا. 45‏:‏20\x*
\m 
\v 8 ”عقْڒمْ خْ مَانْ أَيَا، ذوْڒمْ غَارْ ڒْبَاڒْ نْومْ، كْسِيمْ ث غَارْ وُوڒْ، \add أَ كنِّيوْ\add* إِنِّي إِتّْعدَّانْ!
\v 9 عقْڒمْ خْ ثْمسْڒَايِينْ ثِيمزْوُورَا زڭْ وشْحَاڒْ ؤُيَا: أَقَا نشّْ ذ أَربِّي: وَارْ ذِينْ إِدْجِي ؤُڒَا ذ إِجّْ ن أَربِّي نّغْنِي، ؤُشَا ؤُڒَا ذ إِجّْ وَارْ إِدْجِي أَمْ نشّْ، \x ◘ \xo 46:‏9 \xt إِشا. 45‏:‏5، 14، 18، 21، 22؛ 48‏:‏12\x*
\v 10 ونِّي إِبَارّْحنْ زڭْ ؤُمزْوَارْ مِينْ غَا يِيڒِي غَارْ ؤُنڭَّارْ، ؤُڒَا زڭْ وشْحَاڒْ ؤُيَا مِينْ وَارْ إِمْسَارنْ \add عَاذْ\add*، ونِّي إِقَّارنْ: ’أَخَارّصْ إِنُو يَارْشمْ، أَذْ ڭّغْ مَارَّا أَرْضَا إِنُو!‘، \x ◘ \xo 46:‏10 \xt إِزهد. 33‏:‏11؛ أَوڒن. 19‏:‏21؛ 21‏:‏30؛ عبر. 6‏:‏17\x*
\v 11 ونِّي إِڒَاغَانْ أَجْضِيضْ إِتّْكشَّاضنْ زِي شَّارْقْ، أَرْيَازْ ن ؤُخَارّصْ نّسْ زِي ثمُّورْثْ إِڭّْوجنْ. \add وَاهْ\add*، أَمْ مَامّشْ سِّيوْڒغْ، \add أَمُّو إِ\add* ت غَا ڭّغْ أَذْ د-يَاسْ، نشّْ سّْوجْذغْ ت، أَذْ ت ڭّغْ.“
\m 
\v 12 ”سْڒمْ غَارِي، \add كنِّيوْ\add* أَيْثْ ن بُو-صُّولْطَا، إِنِّي إِڭّْوجنْ خْ ثْسڭْذَا!
\v 13 أَذْ د-سّْقَارّْبغْ ثَاسڭْذَا إِنُو، أَقَا وَارْ ثتّڭّْوِيجْ، وَارْ إِتّْعطِّيڒْ ؤُسنْجمْ إِنُو. أَذْ أَوْيغْ أَسنْجمْ ذِي صِيهْيُونْ، \add أَذْ وْشغْ\add* أَعُودْجِي إِنُو إِ إِسْرَائِيل.“
\b
\b
\c 47
\s1 أَوطُّو ن بَابِيلْ
\m 
\v 1 ”هْوَا، قِّيمْ ذِي ثْعجَّاجْثْ، \add أَ شمْ،\add* ثَاعْزَارشْثْ، يدْجِيسْ ن بَابِيلْ! قِّيمْ خْ ثمُّورْثْ، وَارْ \add ذِينْ\add* إِدْجِي عَاذْ إِجّْ ن ڒْعَارْشْ، \add أَ\add* يدْجِيسْ ن إِكَالْذَانِييّنْ! مَاغَارْ وَارْ ذ أَمْ قَّارنْ عَاذْ ’ثَامُوذْرُوسْثْ‘ نِيغْ ’لِّيفْ‘. \x ◘ \xo 47:‏1 \xt إِشا. 26‏:‏5\x*
\v 2 كْسِي ثَاسِيرْثْ ؤُشَا حْرِييْ أَوْرنْ! كّسْ أَڒحَّافْ نّمْ، سْڭعّذْ أَبحْرُورْ نّمْ، عَارَّا إِفَادّنْ ؤُشَا ثْشُوقذْ ذڭْ إِغزْرَانْ!
\v 3 ڒحْيَا نّمْ أَذْ إِتّْوَاعَارَّا، أَذْ ثتّْوَاژَارْ عَاذْ ڒفْضِيحثْ نّمْ. أَذْ خڒْفغْ ؤُ وَارْ سّْعِيزِّيغْ خْ ؤُڒَا ذ إِجّْ ن بْنَاذمْ. \x ◘ \xo 47:‏3 \xt إِشا. 3‏:‏17؛ نَحُم. 3‏:‏5\x*
\v 4 أَمفْذِي نّغْ، سِيذِي ن ڒْعسْكَارَاثْ ذ إِسمْ نّسْ، أَقَا-ث ذ أَمْقدَّاسْ ن إِسْرَائِيل.“
\m 
\v 5 ”قِّيمْ ذِينْ ؤُشَا سّغْذْ، فّغْ \add غَارْ بَارَّا\add* ذِي ثَادْجسْثْ، \add أَ\add* يدْجِيسْ ن إِكَالْذَانِييّنْ، مَاغَارْ وَارْ ذ أَمْ قَّارنْ عَاذْ ’لَّلَاسْ ن ثْڭلْذِيوِينْ‘.
\v 6 نشّْ ڭِّيغْ أَغْضَابْ إِنُو أَذْ إِدُّوقّزْ خْ ڒْڭنْسْ إِنُو، سّْعِيدْجْثغْ ثَاسْغَارْثْ إِنُو ؤُشَا ڭِّيغْ ثنْ ذڭْ إِفَاسّنْ نّمْ، \add مَاشَا\add* شمْ وَارْ ذ أَسنْ ثسّشْنذْ أَرّحْمثْ. عَاذْ إِ ؤُوسَّارْ ثقّْنذْ أَسْ ثَاغْنَاشْثْ ثذْقڒْ.
\v 7 ثنِّيذْ: ’نشّْ أَذْ إِڒِيغْ ذ لَّالَاسْ \add ن ثْڭلْذِيوِينْ\add* إِ ڒبْذَا!‘، مِينْثْرَا وَارْ ثكْسِيذْ أَيَا مَارَّا غَارْ وُوڒْ،عمَّارْصْ وَارْ ثِيذَارذْ قطُّو ن ؤُيَا \add مَارَّا\add*.“ \x ◘ \xo 47:‏7 \xt أَسَا. 18‏:‏7\x*
\m 
\v 8 ”\add خنِّي\add* ڒخُّو، سڒْ إِ ؤُيَا، \add أَ شمْ،\add* \add ثَامْغَارْثْ\add* ن مژْرِي، ثنِّي \add إِ ذِينْ\add* إِقِّيمنْ ذِي ڒَامَانْ، ثنِّي إِقَّارنْ ذڭْ وُوڒْ نّسْ: ’ذ نشّْ، وَارْ \add ذِينْ\add* ثدْجِي ؤُڒَا ذ إِشْثْ نّغْنِيثْ!عمَّارْصْ أَذْ ذَا قِّيمغْ ذ ثَاجَّاتْشْ، نْهْڒَا إِحنْجِيرنْ وَارْ ث سِّينغْ!‘ \x ◘ \xo 47:‏8 \xt أَسَا. 18‏:‏7\x*
\v 9 \add مَاشَا\add* ثْنَاينْ-أَ أَذْ خَامْ وْضَانْ ذڭْ إِشْثْ ن ثشْثِي، ذڭْ إِجّْ ن وَاسّْ: نْهْڒَا إِحنْجِيرنْ ذ ثَاجَّاتْشْ أَذْ ثِيڒِيذْ! \add ثْنَاينْ-أَ\add* أَذْ خَامْ وْضَانْ زِي سِّيبّثْ ن وَاطَّاسْ ن ثْڭزَّانْثْ نّمْ ذ ؤُبَارُّو ن ثْسحَّارْثْ نّمْ. \x ◘ \xo 47:‏9 \xt إِشا. 51‏:‏19؛ أَسَا. 18‏:‏8\x*
\v 10 \add مَاغَارْ\add* ثتّشْڒذْ خْ ثُوعفّْنَا نّمْ، \add ثنِّيذْ\add*: ’وَارْ ذ أَيِي إِتّْوِيڒِي ؤُڒَا ذ إِجّنْ!‘ ثِيغِيثْ نّمْ ذ ثُوسّْنَا نّمْ أَرِّينْثْ شمْ أَذْ ثَارّذْ س وعْرُورْ \add غَارِي\add*. ذڭْ وُوڒْ نّمْ ثنِّيذْ: ’ذ نشّْ، وَارْ \add ذِينْ\add* إِدْجِي ؤُڒَا ذ إِجّْ ن نّغْنِي!‘
\v 11 أَذْ خَامْ د-يَاسْ ڒْغَارْ ذ أَمقّْرَانْ. مَامّشْ أَذْ د-إِنْقَارْ، وَارْ ثسِّينذْ \add قْبڒْ\add*. أَودَّارْ أَذْ خَامْ إِوْضَا أَڒَامِي وَارْ ثْزمَّارذْ أَذْ أَسْ ثسّْحيْذذْ. ذغْيَا أَذْ خَامْ د-ثَاسْ ثشْثِي، بْڒَا مَا أَذْ خَاسْ ثَارْڭْبذْ \add قْبڒْ\add*.“
\m 
\v 12 ”إِوَا، أَرْزُو أَذْ ثقِّيمذْ ثْبدّذْ \add ذِينْ\add* أَكْ-ذ ثْڭزَّانْثْ نّمْ ؤُ أَكْ-ذ ؤُبَارُّو نّمْ ن ثْسحَّارْثْ نِّي زِي ثسِّيحْڒذْ إِخفْ نّمْ زِي ثمْژِي نّمْ. بَالَاكْ ثْزمَّارذْ أَذْ غَارمْ ثِيڒِي ثِيزِي زِي مَانْ أَيَا، نِيغْ بَالَاكْ ثْزمَّارذْ أَذْ ثسِّيڭّْوذذْ س ؤُيَا!
\v 13 ثسِّيحْڒذْ إِخفْ نّمْ أَكْ-ذ وَاطَّاسْ ن إِخَارِّيصنْ نّمْ. إِوَا، أَذْ كَّارنْ إِنِّي إِتّْفكَّانْ أَجنَّا ؤُ حطَّانْ إِثْرَانْ، إِنِّي إِتّْكَاشَافنْ مِينْ إِ د غَا يَاسنْ غَارْ ؤُبذِّي ن ؤُيُورْ، أجّْ إِ-ثنْ أَذْ شمْ سّْنجْمنْ زِي مِينْ خَامْ غَا إِكّنْ غَارْ زَّاثْ.
\v 14 خْزَارْ، نِيثْنِي أَذْ ذوْڒنْ أَمْ ؤُڒُومْ: أَذْ ثنْ ثسّشْمضْ ثْمسِّي، وَارْ زمَّارنْ أَذْ فكّنْ ڒعْمَارْ نْسنْ زڭْ إِفَاسّنْ ن إِشعَّاڒنْ ن ثْمسِّي. وَارْ إِتِّيڒِي ڒفْحمْ إِتّحْذُوذُوقنْ نِّي غَارْ زْغَاڒنْ، وَارْ إِدْجِي ؤُحَاذُوقْ نِّي غَارْ زمَّارنْ أَذْ قِّيمنْ.
\v 15 أَمُّو إِ غَا إِڒِينْ إِ شمْ إِنِّي ؤُمِي ثُوغَا ثسَّاحَاڒذْ إِخفْ نّمْ، إِسبَّابنْ نّمْ زِي ثمْژِي نّمْ. كُوڒْ إِجّْ أَذْ يُويُورْ ذڭْ وبْرِيذْ نّسْ، ؤُڒَا ذ إِجّْ وَارْ شمْ إِسّنْجِيمْ.“ \x ◘ \xo 47:‏15 \xt أَسَا. 17‏:‏16\x*
\b
\b
\c 48
\s1 أَفكِّي زِي بَابِيلْ
\m 
\v 1 ”سْڒمْ أَيَا، \add أَ كنِّيوْ\add* ثَادَّارْثْ ن يَاعْقُوبْ، إِنِّي ؤُمِي تّْڒَاغَانْ س يِيسمْ ن إِسْرَائِيل، \add إِنِّي\add* إِفّْغنْ زڭْ وَامَانْ ن يَاهُوذَا، إِنِّي إِتّْجَادْجَانْ غَارْ يِيسمْ ن سِيذِي ؤُ تِّيذَارنْ أَربِّي ن إِسْرَائِيل، \add مَاشَا\add* وَارْ إِدْجِي ذِي ثِيذتّْ، ؤُ وَارْ إِدْجِي ذِي ثْسڭْذَا.
\v 2 نِيثْنِي تّْڒَاغَانْ إِخفْ نْسنْ ’\add ڒْڭنْسْ\add* زِي ثنْذِينْثْ ثَامْقدَّاسْثْ!‘ ؤُ تّْشَاڒنْ خْ أَربِّي ن إِسْرَائِيل، أَقَا سِيذِي ن ڒْعسْكَارَاثْ ذ إِسمْ نّسْ.“
\b
\m 
\v 3 ”ثِيمسْڒَايِينْ ثِيمزْوُورَا سَّارْڭْبغْ خَاسنْثْ عَاذْ أَطَّاسْ زڭْ وَامِي، أَقَا فّْغنْثْ-إِ-د زڭْ ؤُقمُّومْ إِنُو ؤُشَا بَارّْحغْ زَّايْسنْثْ. ذغْيَا ڭِّيغْ \add ثنْثْ\add* ؤُشَا \add خنِّي\add* ؤُسِينْثْ-إِ-د.
\v 4 مِينْزِي نشّْ سّْنغْ، أَقَا شكْ ثسّْقسْحذْ إِخفْ نّشْ، أَقَا إِجِيمَانْ نّشْ أَمْ ثْبَارَّاثْ ن وُوزَّاڒْ ؤُ ثَانْيَارْثْ نّشْ \add أَخْمِي د-ثكَّا زِي\add* نّْحَاسْ،
\v 5 سَّارْڭْبغْ \add أَشْ ثنْثْ\add* عَاذْ أَطَّاسْ زڭْ وَامِي. قْبڒْ مَا إِمْسَارْ، بَارّْحغْ زَّايْسنْثْ مَاحنْذْ شكْ وَارْ ثقَّارذْ: ’صَّانَامْ إِنُو إِڭَّا إِ-ثنْثْ!‘، \add نِيغْ\add* ’ڒخْيَارَاثْ إِنُو إِنقْشنْ!‘ \add نِيغْ:\add* ’ڒخْيَاڒْ إِنُو إِفسْينْ يُومُورْ إِ-ثنْثْ!‘
\v 6 شكْ ثسْڒِيذْ خَاسنْثْ، خْزَارْ مْلِيحْ غَارْ مَارَّا أَيَا. مَا وَارْ ثخْسمْ أَذْ زَّايْسنْثْ ثْبَارّْحمْ؟ زِي ڒخُّو أَذْ أَشْ بَارّْحغْ ثِيمسْڒَايِينْ ن جْذِيذْ، ثِيمسْڒَايِينْ إِنُّوفَّارنْ نِّي وَارْ ثسِّينذْ.
\m 
\v 7 ڒخُّو تّْوَاخڒْقنْثْ-د، وَارْ إِدْجِي أَطَّاسْ زڭْ وَامِي. قْبڒْ أَسّْ-أَ وَارْ خَاسنْثْ ثسْڒِيذْ مَاحنْذْ وَارْ ثقَّارذْ: ’خْزَارْ، سّْنغْ ت مڒْمِي!‘
\v 8 وَاهْ، وَارْ خَاسنْثْ ثسْڒِيذْ ؤُ عَاوذْ وَارْ ثنْثْ ثسِّينذْ ؤُ عَاوذْ أَمزُّوغْ نّشْ ثُوغَا وَارْ يَارْزِيمْ، مَاغَارْ نشّْ سّْنغْ، أَقَا شكْ أَذْ ثڭّذْ س ڒغْذَارثْ أَطَّاسْ ؤُشَا أَذْ أَشْ ڒَاغَانْ ’ونِّي إِتّْعدَّانْ!‘ \add عَاذْ\add* زڭْ ؤُعذِّيسْ ن يمَّاشْ.“
\b
\m 
\v 9 ”ذِي طّْوعْ ن يِيسمْ إِنُو أَذْ سّْعضْڒغْ أَغْضَابْ إِنُو، ؤُ \add ذِي طّْوعْ\add* ن شَّانْ إِنُو أَذْ ثبّْثغْ إِخفْ إِنُو إِ ڒْخَارْ نّشْ، مَاحنْذْ وَارْ شكْ محِّيغْ قَاعْ. \x ◘ \xo 48:‏9 \xt إِشا. 43‏:‏21، 25\x*
\v 10 خْزَارْ، نشّْ سّصْفِيغْ شكْ، \add مَاشَا\add* وَارْ إِدْجِي أَمْ نُّوقَارْثْ، قدْجْبغْ شكْ ذِي ثفْقُونْثْ ن ؤُسفْصِي ن ڒغْبنْ.
\v 11 ذِي طّْوعْ إِنُو، ذِي طّْوعْ إِنُو أَذْ ث ڭّغْ، مَاغَارْ مَامّشْ إِ غَا إِتّْوَاعَارَّا إِسمْ إِنُو؟ أَعُودْجِي إِنُو وَارْ ث تِّيشغْ إِ ؤُڒَا ذ إِجّنْ نّغْنِي.“ \x ◘ \xo 48:‏11 \xt إِشا. 42‏:‏8\x*
\b
\m 
\v 12 ”سڒْ-د غَارِي، \add أَ\add* يَاعْقُوبْ، \add شكْ، أَ\add* إِسْرَائِيل، ونِّي ؤُمِي ڒَاغِيغْ! \bd نشّْ نشّْ\bd*، نشّْ ذ أَمزْوَارُو ؤُڒَا ذ أَنڭَّارُو. \x ◘ \xo 48:‏12 \xt إِشا. 41‏:‏4؛ 44‏:‏6؛ أَسَا. 1‏:‏17؛ 22‏:‏13\x*
\v 13 أَفُوسْ إِنُو إِسَّارْسْ عَاوذْ ذْسُوسَا ن ثمُّورْثْ، ؤُشَا أَفُوسِي إِنُو إِبزّعْ إِجنْوَانْ. مَاڒَا ڒَاغِيغْ أَسنْ، تّْبدَّانْ نِيثْنِي \add ذِينِّي\add* جْمِيعْ.
\v 14 مُونمْ مَارَّا كنِّيوْ ؤُ سْڒمْ: مَانْ ونْ جَارْ أَسنْ إِبَارّحْ زِي \add مَارَّا\add* مَانْ أَيَا؟ سِيذِي إِتّخْسْ إِ-ث، ؤُ وَانِيثَا أَذْ يڭّْ عْلَاحْسَابْ ڒْخَاضَارْ نّسْ ضِيدّْ إِ بَابِيلْ، أَغِيڒْ نّسْ أَذْ يِيڒِي ضِيدّْ إِ إِكَالْذَانِييّنْ. \x ◘ \xo 48:‏14 \xt إِشا. 41‏:‏22، 23\x*
\v 15 أَقَا نشّْ، \add وَاهْ،\add* نشّْ نِّيغْ ث، ؤُ نشّْ ڒَاغِيغْ أَسْ \add عَاوذْ\add*. أَذْ ڭّغْ أَذْ د-يَاسْ، ؤُشَا نتَّا أَذْ إِفْڒحْ ذڭْ وبْرِيذْ نّسْ.
\v 16 قَارّْبمْ-د غَارِي، سْڒمْ أَيَا: زڭْ ؤُمزْوَارُو نشّْ وَارْ سِّيوْڒغْ س ثْنُوفّْرَا. زڭْ وَامِي مَارَّا أَيَا إِمْسَارْ، أَقَا أَيِي نشّْ ذِينْ! ’ؤُ ڒخُّو سِيذِي إِنُو، سِيذِي، إِسّكّْ أَيِي-د، أَكْ-ذ أَرُّوحْ نّسْ.‘ “
\b
\m 
\v 17 ”أَمُّو إِ إِقَّارْ سِيذِي، أَمفْذِي نّشْ، أَمْقدَّاسْ ن إِسْرَائِيل: ’نشّْ ذ سِيذِي، أَربِّي نّشْ، ونِّي شكْ إِسّْڒمْذنْ مِينْ إِنفّْعنْ، ذ ونِّي شكْ إِندّْهنْ ذڭْ وبْرِيذْ نِّي خْ إِ غَا ثُويُورذْ.
\v 18 أَخْ، مْڒِي ثخْزَارذْ \add مَاشَا\add* غَارْ ثْوصَّا إِنُو، \add خنِّي\add* أَذْ يَافْ ڒهْنَا نّشْ أَذْ يِيڒِي أَمْ يغْزَارْ ؤُ ثَاسڭْذَا نّشْ أَمْ ڒمْوَاجْ ن ڒبْحَارْ، \x ◘ \xo 48:‏18 \xt أَعَوذ. 32‏:‏29؛ إِزهد. 81‏:‏14\x*
\v 19 زَّارِيعثْ نّشْ ثُوغَا-ت أَمْ يِيجْذِي، ؤُ \add إِحنْجِيرنْ نّشْ\add* نِّي د-إِتّفّْغنْ زِي ثجْعِينَّا نّشْ أَمْ ڒْحبّْ إِ د-يُوسِينْ زَّايسْ. إِسمْ نّسْ وَارْ إِتّْنقْضِيعْ ؤُ وَارْ إِتّْوَاثحِّي زَّاثْ إِ وُوذمْ إِنُو.‘ “
\b
\m 
\v 20 ”فّْغمْ زِي بَابِيلْ، أَروْڒمْ زڭْ إِكَالْذَانِييّنْ، بَارّْحمْ \add أَسْ\add* س إِغُويَّانْ ن ؤُسْڒِيوْڒوْ، مَاحنْذْ أَذْ سْڒنْ أَيَا، سُوفّْغمْ \add ڒخْبَارْ\add* أَڒْ أَنڭَّارْ ن دُّونشْثْ، إِنِيمْ: ’سِيذِي إِفكّْ أَمْسخَّارْ نّسْ يَاعْقُوبْ!‘ \f ◼ \fr 48:‏20 \ft \bd ’دُّونِّيثْ‘\bd* - س ثْعِيبْرَانِيثْ ’ثَامُّورْثْ‘.\f*  \x ◘ \xo 48:‏20 \xt إِشا. 52‏:‏11؛ إِرْم. 50‏:‏8؛ 51‏:‏6،45؛ أَسَا. 18‏:‏4\x*
\v 21 وَارْ خَاسنْ إِكِّي ؤُفَاذِي ؤُمِي ثنْ د-إِڭوّذْ س إِمُوشَانْ إِتّْوَاخَارّْبنْ. نتَّا إِسُّوفّغْ أَسنْ-د أَمَانْ زِي ثصْضَارْثْ. ؤُمِي نتَّا إِفدْجقْ جَّارْفْ، دُّوقّْزنْ-د زَّايسْ وَامَانْ.“
\m 
\v 22 ”إِعفَّاننْ وَارْ تِّيفنْ ڒهْنَا!، إِقَّارْ سِيذِي.“\x ◘ \xo 48:‏22 \xt إِشا. 57‏:‏21\x*
\b
\b
\c 49
\s1 شّْهَاذثْ ن ؤُمْسخَّارْ ن سِيذِي خْ يِيخفْ نّسْ
\m 
\v 1 ”سْڒمْ-د غَارِي، \add أَ\add* ثِيڭْزِيرِينْ، سْحسّمْ، \add أَ\add* شُّوعُوبْ ن ڒَاڭّْوَاجْ! سِيذِي إِڒَاغَا أَيِي-د زڭْ \add وَامِي ذ أَيِي ثُوغَا ذڭْ\add* ؤُعذِّيسْ ن يمَّا، زڭْ \add وَامِي ذ أَيِي ثُوغَا عَاذْ ذِي\add* ڒمْڒَاوثْ إِڒَاغَا أَيِي-د س يِيسمْ إِنُو.
\v 2 نتَّا إِڭَّا أَقمُّومْ إِنُو ذ سِّيفْ إِقضْعنْ، نتَّا إِسّْذُورِييْ أَيِي ذِي ثِيڒِي ن ؤُفُوسْ نّسْ. نتَّا إِڭَّا أَيِي ذ فْڒِيثْشَا س ثِيخفْثْ إِقضْعنْ، إِڭَّا أَيِي ذڭْ وقْرَابْ نّسْ ن فْڒِيثْشَاثْ.
\v 3 إِنَّا أَيِي: ’شكْ ذ أَمْسخَّارْ إِنُو إِسْرَائِيل نِّي ذِي غَا تّْوَاسّْعُودْجغْ!‘ “
\b
\m 
\v 4 ”\add مَاشَا\add* نشّْ نِّيغْ: ’نشّْ أَرْبْرغْ خْ وَالُو، ضيّْعغْ جّهْذْ إِنُو ذِي ڒْخَاوِي ذ ڒْبَاطڒْ. س ثِيذتّْ، ثَاسْغَارْثْ إِنُو غَارْ سِيذِي ؤُ ڒْمُونثْ إِنُو غَارْ أَربِّي إِنُو.‘ “
\b
\m 
\v 5 ”ؤُشَا ڒخُّو إِقَّارْ سِيذِي، ونِّي ذ أَيِي إِڭِّينْ ذ أَمْسخَّارْ زڭْ وَامِي ذ أَيِي ثُوغَا ذڭْ ؤُعذِّيسْ ن يمَّا مَاحنْذْ أَذْ غَارسْ د-سّْعقْبغْ يَاعْقُوبْ ؤُ مَاحنْذْ أَذْ غَارسْ سّْمُونغْ إِسْرَائِيل - \add وَاهْ،\add* نشّْ تّْوَاسّْعُودْجغْ ذِي ثِيطَّاوِينْ ن سِيذِي ؤُشَا أَربِّي إِنُو ذ جّهْذْ إِنُو! -
\v 6 \add وَاهْ،\add* نتَّا إِقَّارْ: ’ذْرُوسْ، أَقَا شكْ أَذْ ثِيڒِيذْ ذ أَمْسخَّارْ إِنُو مَاحنْذْ أَذْ ثسّْنكَّارذْ \add عَاوذْ\add* ثِيقبَّاڒْ ن يَاعْقُوبْ ؤُ مَاحنْذْ أَذْ د-ثَارّذْ إِنِّي إِتّْوَاحْذَانْ زِي إِسْرَائِيل. نشّْ ڭِّيغْ شكْ ذ ثَافَاوْثْ إِ ڒڭْنُوسْ، مَاحنْذْ أَذْ ثِيڒِيذْ ذ أَسنْجمْ إِنُو أَڒْ ؤُنڭَّارْ ن ثمُّورْثْ!‘
\v 7 أَمُّو إِ إِقَّارْ سِيذِي، أَمفْذِي ن إِسْرَائِيل، أَمْقدّسْ نّسْ، إِ ورْيَازْ إِتّْوَاسّحْقَارنْ، إِ ونِّي ذ نّْعِي ن ڒْڭنْسْ، إِ ؤُمْسخَّارْ ن أَيْثْ نْ صُّولْطَا: ’إِجدْجِيذنْ أَذْ \add شكْ\add* ژَترنْ ؤُ أَذْ كَّارنْ، ڒْحُوكَّامْ أَذْ أَضَارنْ زَّاثكْ ذِي طّْوعْ ن سِيذِي، ونِّي ذ أَمْثِيقِّي، أَمْقدَّاسْ ن إِسْرَائِيل، ونِّي شكْ إِفَارْزنْ!‘ “
\b
\m 
\v 8 ”أَمُّو إِ إِقَّارْ سِيذِي: ’ذِي ڒْحَاڒْ ن أَرْضَا، سْڒِيغْ أَشْ، ؤُ ذڭْ وَاسّْ ن ؤُسنْجمْ، وْشِيغْ أَشْ أَفُوسْ. نشّْ أَذْ شكْ حْضِيغْ ؤُ أَذْ شكْ أَرشّْحغْ ذ ڒْعَاهْذْ ن ڒْڭنْسْ، مَاحنْذْ أَذْ ثسّْبدّذْ ثَامُّورْثْ، مَاحنْذْ أَذْ ثطّْفذْ ثِيسقَّارْ يَاردّْدْجنْ عَاوذْ ذ ثَاسْغَارْثْ، \x ◘ \xo 49:‏8 \xt 2 كُور. 6‏:‏2\x*
\v 9 مَاحنْذْ أَذْ ثِينِيذْ إِ إِمحْبَاسْ: فّْغمْ-د!، إِ يِينِّي \add إِدْجَانْ\add* ذِي ثَادْجسْثْ: ضْهَارمْ-د! أَذْ أَروْسنْ غَارْ إِبْرِيذنْ، خْ مَارَّا ثِيوْرِيرِينْ إِقُوشَّارنْ أَذْ إِڒِينْ دّْمَانِي نْسنْ ن ثَاروْسَا.
\v 10 وَارْ خَاسنْ إِتّكّْ ڒَاژْ ؤُڒَا ذ أَفَاذِي، ڒحْمُو ذ ثْفُوشْثْ وَارْ ثنْ ثشِّيثْ شَا، مَاغَارْ ونِّي خَاسنْ إِتّْحِينَّانْ أَذْ ثنْ إِڭوّذْ، أَذْ ثنْ إِنْذهْ غَارْ ثَاڒَاوِينْ ن وَامَانْ. \x ◘ \xo 49:‏10 \xt أَسَا. 7‏:‏16\x*
\v 11 مَارَّا إِذُورَارْ إِنُو أَذْ ثنْ ڭّغْ ذ إِبْرِيذنْ ؤُ إِبْرِيذنْ إِنُو إِوَاطَانْ أَذْ تّْوَاسُّوعْڒَانْ.
\v 12 خْزَارْ، أَذْ د-أَسنْ زِي ڒَاڭّْوَاجْ. خْزَارْ، إِنَا \add أَذْ د-أَسنْ\add* زِي شَّامَالْ ؤُ زِي ڒبْحَارْ ؤُ إِنّغْنِي زِي ثمُّورْثْ ن أَسْوَانْ.‘ “ \f ◼ \fr 49:‏12 \ft \bd ’أَسْوَانْ‘\bd* - ثَانْذِينْثْ ذِي لْجَانُوبْ ن مِيصْرَا، مَاشَا شْ ن ڒْمَاخْثِيطَّاثْ نّغْنِي قَّارنْثْ: ’سِينِيمْ‘. أَذْ ثَاغْ نِيثْنِي ذ إِشِينْوِييّنْ ن أَسّْ ن يِيضَا.\f*
\b
\m 
\v 13 ”سْڒِيوْڒِيومْ، \add أَ كنِّيوْ\add* إِجنْوَانْ، فَارْحثْ، \add أَ شمْ،\add* ثَامُّورْثْ! أَرّمْ إِذُورَارْ أَذْ دُّوقّْزنْ س ؤُسْڒِيوْڒوْ، مَاغَارْ سِيذِي إِسّْفوّجْ خْ ڒْڭنْسْ نّسْ، نتَّا أَذْ إِحِينّْ خْ ڒْمُوسَاكِينْ نّسْ!“
\b
\m 
\v 14 ”\add مَاشَا\add* صِيهْيُونْ ثنَّا: ’سِيذِي إِسْمحْ ذَايِي، سِيذِي إِنُو إِتُّو أَيِي.‘
\v 15 مَا ثْزمَّارْ ثمْغَارْثْ أَذْ ثتُّو أَسيْمِي نّسْ، ؤُمِي وَارْ ثتّْحِينِّي خْ مِّيسْ ن ؤُعذِّيسْ نّسْ؟ وَاخَّا ثتُّو ث، نشّْ وَارْ شمْ تّتُّوغْ.
\v 16 خْزَارْ، نشّْ نقْشغْ شمْ ذِي ثْنَاينْ ن ثْڒقَّا ن إِفَاسّنْ \add إِنُو\add*، ڒحْيُوضْ نّمْ ڒبْذَا غَارِي زَّاثْ إِ ثِيطَّاوِينْ.
\v 17 إِحنْجِيرنْ نّمْ أَذْعڒْفنْ، \add مَاشَا\add* إِمْثحَّاينْ نّمْ ؤُ إِنِّي شمْ إِخَارّْبنْ أَذْ خَامْ ؤُيُورنْ.
\v 18 سْڭعّذْ ثَامُوغْڒِي نّمْ ؤُشَا خْزَارْ ذَا ذ ذِيهَا. خْزَارْ، مَارَّا مُوننْ ؤُسِينْ-د غَارمْ. س ثِيذتّْ أَمْ دَّارغْ نشّْ، إِقَّارْ سِيذِي، أَذْ ثَارْضذْ إِخفْ نّمْ س مَارَّا إِنَا أَمْ س ڒهْزُوطْ، ؤُشَا أَذْ زَّايْسنْ ثْزوّْقذْ إِخفْ نّمْ أَمْ \add ث ثڭَّا\add* ثسْڒِيثْ.‘ \x ◘ \xo 49:‏18 \xt إِشا. 60‏:‏4\x*
\v 19 مَاغَارْ ڒْخِيرْبَاثْ نّمْ ذ إِمُوشَانْ نّمْ إِتّْوَاردّْدْجنْ، \add وَاهْ\add* ثَامُّورْثْ نّمْ إِتّْوَاثحَّانْ أَذْ ثِيڒِي ثحْصَارْ إِ إِمزْذَاغْ، ؤُشَا إِنِّي إِخْسنْ أَذْ شمْ صَارْضنْ، أَذْ إِڒِينْ غَارْ ڒَاڭّْوَاجْ.
\v 20 ؤُڒَا ذ إِحنْجِيرنْ نِّي زَّايمْ إِتّْوَاشَارنْ، أَذْ إِنِينْ ذڭْ إِمزُّوغنْ نّمْ: ’أَمْشَانْ ذَايسْ ڒْحصْرَانْ خَافِي، أڭّْ أَيِي أَمْشَانْ إِ نشّْ، \add مَاحنْذْ\add* زمَّارغْ أَذْ \add ذَايسْ\add* زذْغغْ!‘
\v 21 أَذْ ثِينِيذْ ذڭْ وُوڒْ نّمْ: ’مَانْ ونْ إِ ذ أَيِي د-يُورْونْ مَارَّا إِحنْجِيرنْ-أَ؟ ؤُشَارنْ أَيِي إِحنْجِيرنْ ؤُ وَارْ د-تِّيرْوغْ، سُّوفّْغنْ أَيِي-د ذ أَمحْبُوسْ ؤُشَا نْضَارنْ أَيِي-د. مَانْ ونْ إِ ثنْ إِسّيْمنْ؟ خْزَارْ، نشّْ وَاهَا ذ ثنِّي ثُوغَا إِشطّنْ، مَانِيسْ د-ؤُسِينْ نِيثْنِي؟‘ “
\b
\m 
\v 22 ”أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’خْزَارْ، أَذْ سّْڭعّْذغْ أَفُوسْ إِنُو غَارْ ڒڭْنُوسْ ؤُ أَذْ سّْبدّغْ ثَاعدْجَانْثْ إِنُو إِ ڒڭْنُوسْ. \add خنِّي\add* أَذْ أَوْينْ إِحنْجِيرنْ نّمْ ذڭْ وحْسِينْ نْسنْ \add غَارْ ذَانِيثَا\add* ؤُشَا أَذْ أَرْبُونْ يسِّيمْ خْ ثْغَارْضِينْ نْسنْ.
\v 23 إِجدْجِيذنْ أَذْ شمْ صُوننْ، ثِيجدْجِيذِينْ أَذْ شمْ سُّوطّْذنْثْ. أَذْ أَضَارنْ زَّاثكْ س ؤُغمْبُوبْ نْسنْ غَارْ ثمُّورْثْ، أَذْ أَمْ ڒسْحنْ ثَاعجَّاشْثْ زڭْ إِضَارنْ نّمْ. \add خنِّي\add* أَذْ ثسّْنذْ أَقَا نشّْ ذ سِيذِي، ؤُشَا إِنِّي خَاسْ إِ غَا إِسِيثِيمنْ، وَارْ تّْسضْحِينْ شَا.‘ “
\b
\m 
\v 24 ”مَا إِزمَّارْ إِجّْ أَذْ إِكّسْ خْ ونِّي إِجهْذنْ زَّارْذثْ؟ مَا إِزمَّارْ أَذْ يَارْوڒْ ونِّي إِدْجَانْ ذ أَمحْبُوسْ ن ؤُمْسڭّذْ؟ \x ◘ \xo 49:‏24 \xt مت. 12‏:‏29\x*
\v 25 \add مَاشَا\add* أَمُّو إِ إِقَّارْ سِيذِي: ’أَذْ د-تّْوَاكّْسنْ إِمحْبَاسْ زڭْ ؤُفُوسْ ن ؤُمْزمَّارْ ؤُڒَا ذ ثَاكشَّاضْطْ ن ؤُقهَّارْ أَذْ ثخْثُوتّڒْ زِي جَارْ إِفَاسّنْ نّسْ. \add مَاغَارْ\add* ونِّي إِخْسنْ أَذْ شمْ إِشَارّعْ، نشّْ أَذْ ث شَارّْعغْ، ؤُشَا إِحنْجِيرنْ نّمْ أَذْ ثنْ سّْنجْمغْ.
\v 26 إِ يِينِّي شمْ إِحصَّارنْ أَذْ أَسنْ وْشغْ أَذْ شّنْ أَيْسُومْ \add ن يِيخفْ\add* نْسنْ ؤُ نِيثْنِي أَذْ سْشَارنْ س إِذَامّنْ نْسنْ أَمْ س بِينُو ژمّنْ ث جْذِيذْ، ؤُ مَارَّا إِوْذَانْ أَذْ سّْننْ أَقَا نشّْ، سِيذِي، ذ أَمْسنْجَامْ نّمْ ذ أَمفْذِي نّمْ، أَمْزمَّارْ ن يَاعْقُوبْ.‘ “ \x ◘ \xo 49:‏26 \xt أَسَا. 16‏:‏6\x*
\b
\b
\c 50
\s1 أَشثْشِي إِغشّنْ
\m 
\v 1 ”أَمُّو إِ إِقَّارْ سِيذِي: ’مَانِي ثدْجَا ثبْرَاثْ ن وَادْجَافْ، ثنِّي زِي سّْقبّْضغْ يمَّاثْومْ؟ نِيغْ إِ مَانْ ونْ زڭْ أَيْثْبَابْ ن وَارطَّارْ إِنُو كنِّيوْ زّنْزغْ؟ خْزَارْ، زِي سِّيبّثْ ن ڒْمُوعْصِييّثْ نْومْ ثمّنْزمْ ؤُ زِي سِّيبّثْ ن إِعذِّيينْ نْومْ ثمّنْزْ يمَّاثْومْ.
\v 2 مَايمِّي د-ؤُسِيغْ، وَارْ ذِينْ إِدْجِي ؤُڒَا ذ إِجّْ، مَايمِّي إِ ڒَاغِيغْ، وَارْ د-يَارِّي ؤُڒَا ذ إِجّْ؟ مَا أَفُوسْ إِنُو ذ أَقُوضَاضْ أَڒَامِي وَارْ إِزمَّارْ أَذْ إِفكّْ، مَا وَارْ ذَايِي إِدْجِي جّْهذْ، حِيمَا أَذْ فكّغْ؟ خْزَارْ، س ؤُسِيڭّْوذْ إِنُو أَذْ سِّيژْرغْ ڒبْحَارْ، أَذْ ڭّغْ إِغزْرَانْ ذ ڒخْڒَا ؤُشَا أَذْ أَژْغنْ \add أَڒَامِي\add* إِ غَا يَارْصُوضنْ إِسڒْمَانْ نْسنْ مَاغَارْ وَارْ \add ذِينْ\add* إِدْجِي \add عَاذْ\add* وَامَانْ، ؤُشَا أَذْ مّْثنْ زڭْ ؤُفَاذِي. \x ◘ \xo 50:‏2 \xt ڒخْڒ. 11‏:‏23؛ إِشا. 59‏:‏1\x*
\v 3 أَذْ سّْيَارْضغْ أَجنَّا س ثُوبَّارْشنْثْ، أَذْ ثنْ ڒحّْفغْ س ثْخَانْشثْ \add ن وشْضَانْ\add* أَمْ وَارُّوضْ \add نْسنْ\add*.‘ “
\b
\m 
\v 4 ”سِيذِي إِنُو، سِيذِي، إِوْشَا أَيِي إِڒسْ ن ؤُمحْضَارْ، مَاحنْذْ نشّْ أَذْ سّْنغْ مَامّشْ غَا سّْمحْذغْ ونِّي يُوحّْڒنْ س إِجّْ ن وَاوَاڒْ. قَاعْ ثُوفُّوثْ نتَّا إِسّْفَاقَا أَيِي، إِسّْفَاقَا أَيِي أَمزُّوغْ، مَاحنْذْ نشّْ أَذْ \add غَارسْ\add* سْڒِيغْ أَمْ ؤُمحْضَارْ.
\v 5 سِيذِي إِنُو، سِيذِي، يَارْزمْ أَيِي أَمزُّوغْ ؤُ نشّْ وَارْغوّْغغْ شَا، وَارْ د-دّْوِيڒغْ غَارْ ضفَّارْ. \x ◘ \xo 50:‏5 \xt يُوح. 14‏:‏31؛ فِيل. 2‏:‏8؛ عبر. 10‏:‏5‏-‏10\x*
\v 6 نشّْ وْشِيغْ أَعْرُورْ إِنُو إِ يِينِّي ذ أَيِي إِوْثِينْ، ؤُ إِغمِّيزنْ إِنُو إِ يِينِّي ذ أَيِي إِسّْنشْفنْ \add ثْمَارْثْ\add*. أَغمْبُوبْ إِنُو وَارْ ث سّْنُوفَّارغْ زَّاثْ إِ ؤُسحْقَارْ ذ ؤُسُوسفْ.
\v 7 \add مَاشَا\add* سِيذِي إِنُو، سِيذِي، أَذْ أَيِي إِوْشْ أَفُوسْ، خْ ؤُيَا وَارْ قطِّيغْ ذِي ڒفْضِيحثْ، خْ ؤُيَا جِّيغْ أَغمْبُوبْ إِنُو إِقْسحْ أَمْ سّدْجَاحْ، \add مِينْزِي\add* سّْنغْ، أَقَا نشّْ وَارْ تّْسضْحِيغْ شَا.
\v 8 ونِّي ذ أَيِي إِتّْسڭّْذنْ، أَقَا-ث يُوذسْ. مَانْ ونْ إِ غَا إِزعْمنْ أَذْ كِيذِي إِشَارّعْ؟ جّمْ أَنغْ أَذْ نْبدّْ نْمُونْ! مَانْ ونْ كِيذِي إِتّمْشَارَّاعنْ، أجّْ إِ-ث أَذْ غَارِي د-يَاسْ. \x ◘ \xo 50:‏8 \xt رُوم. 8‏:‏32، 33\x*
\v 9 خْزَارْ، سِيذِي إِنُو، سِيذِي، أَذْ أَيِي إِوْشْ أَفُوسْ. مَانْ ونْ إِزمَّارنْ أَذْ أَيِي إِڭّْ ڒْعِيبْ؟ خْزَارْ، نِيثْنِي مَارَّا أَمْ وَارُّوضْ إِدُّويْسَارنْ، أَذْ ثنْ ثشّْ ثْشِينْذَا.“
\b
\m 
\v 10 ”مَانْ ونْ \add إِ ذِينْ\add* جَارْ أَومْ إِتّڭّْوذْ زِي سِيذِي، مَانْ ونْ \add جَارْ أَومْ\add* إِتّسْڒَانْ إِ ثْمِيجَّا ن ؤُمْسخَّارْ نّسْ؟ ونِّي إِڭُّورنْ ذِي ثَادْجسْثْ ذ ونِّي ؤُمِي وَارْ غَارْ ثدْجِي ثَافَاوْثْ، أجّْ إِ-ث أَذْ إِتّْشڒْ خْ يِيسمْ ن سِيذِي، \add أجّْ إِ-ث\add* أَذْ إِعمّذْ خْ أَربِّي نّسْ.
\v 11 خْزَارْ، كنِّيوْ مَارَّا ثسَّارْغمْ ثِيمسِّي، ثْبيْسمْ إِخفْ نْومْ س فْڒِيثْشَاثْ إِ ؤُسشْمَاضْ. \add إِوَا،\add* ؤُيُورمْ \add خنِّي\add* ذِي ثْفَاوْثْ ن ثْمسِّي نْومْ ؤُ غَارْ \add ثْفَاوْثْ ن\add* فْڒِيثْشَاثْ يَارقّنْ نِّي ثسَّارْغمْ. أَيَا أَذْ خَاومْ د-يَاسْ زڭْ ؤُفُوسْ إِنُو، س ڒحْرِيقْ أَذْ ثزّْڒمْ \add ذِينِّي\add*.“
\b
\b
\c 51
\s1 أَفَاقِي ن ؤُغِيڒْ ن سِيذِي، ؤُرْشَالِيمْ ذ سِيحْيُونْ
\m 
\v 1 ”سْڒمْ غَارِي، \add أَ كنِّيوْ\add* إِنِّي إِضَافَّارنْ ثَاسڭْذَا، \add كنِّيوْ\add* إِنِّي يَارزُّونْ سِيذِي! خْزَارمْ غَارْ ثصْضَارْثْ مَانِيسْ ثتّْوَانقْشمْ ؤُ غَارْ وخْبُوشْ ن وَانُو مَانِيسْ د-ثتّْوَاغْزمْ.
\v 2 خْزَارمْ غَارْ إِبْرَاهِيمْ، جذِّيثْومْ، ؤُ غَارْ سَارَا، ثنِّي كنِّيوْ إِ د-يُورْونْ. مَاغَارْ ثُوغَا-ث \add عَاذْ\add* حَافِي ؤُمِي ث ڒَاغِيغْ، \add مَاشَا\add* نشّْ بَارْكغْ ث ؤُ أَرْزْفغْ أَسْ أَطَّاسْ ن وَارَا.
\v 3 مَاغَارْ سِيذِي أَذْ إِسّْفوّجْ صِيهْيُونْ، أَذْ إِسّْفوّجْ مَارَّا ڒْخِيرْبَاثْ نّسْ ؤُشَا أَذْ ت يَارّْ أَمْ \add جّنّثْ ن\add* عَاذْنْ ؤُ ڒخْڒَا نّسْ أَمْ وحْوِيشْ ذِي جّنّثْ ن سِيذِي. أَرْشَاقْ ذ ڒفْرَاحثْ أَذْ ذَايسْ ثنْ أَفنْ، أَقَاذِي ذ ڒْحسّْ ن إِزهِّيذنْ.“
\b
\m 
\v 4 ”سْڒمْ-د غَارِي، \add أَ\add* شّعْبْ إِنُو، ؤُ وْشمْ أَيِي أَمزُّوغْ، \add أَ\add* ڒْڭنْسْ إِنُو، مَاغَارْ أَذْ زَّايِي ثفّغْ شَّارِيعَا ؤُ نشّْ أَذْ ضمْنغْ ڒْحقّْ إِنُو أَڒْ غَا يِيڒِي \add ڒْحقّْ إِنُو\add* ذ ثَافَاوْثْ إِ ڒڭْنُوسْ.
\v 5 ثَاسڭْذَا إِنُو ثُوذسْ-د، أَسنْجمْ إِنُو إِتّفّغْ-د ؤُ إِغَادْجنْ إِنُو أَذْ شَارّْعنْ ڒڭْنُوسْ، أَذْ أَيِي رَاجَانْثْ ثڭْزِيرِينْ ؤُشَا أَذْ سِّيثْمنْثْ خْ ؤُغِيڒْ إِنُو.“
\b
\m 
\v 6 ”سْڭعّْذمْ ثِيطَّاوِينْ نْومْ غَارْ ؤُجنَّا، خْزَارمْ ثَامُّورْثْ ذَا سْوَادَّايْ، مَاغَارْ أَجنَّا أَذْ إِفَّارْفَارْ أَمْ دّخَّانْ، ثَامُّورْثْ أَذْ ثدُّويْسَارْ أَمْ وَارُّوضْ، ؤُشَا أَمُّو إِ غَا مّْثنْ \add ؤُڒَا ذ\add* إِمزْذَاغْ نّسْ، \add مَاشَا\add* أَسنْجمْ إِنُو أَذْ إِقِّيمْ إِ ڒبْذَا، ثَاسڭْذَا إِنُوعمَّارْصْ وَارْ ت قطِّينْ.“
\b
\m 
\v 7 ”سْڒمْ-د غَارِي، \add أَ كنِّيوْ\add* إِنِّي إِسّْننْ ثَاسڭْذَا، \add أَ شكْ\add* ڒْڭنْسْ نِّي \add يَاربُّونْ\add* شَّارِيعَا إِنُو ذڭْ وُوڒْ. وَارْ تّڭّْوْذمْ زِي ڒْحڭْرَا ن يوْذَانْ ؤُ وَارْ ثنْ تّجِّيمْ أَذْ شمْ أَرْژنْ س ؤُعيّبْ نْسنْ! \x ◘ \xo 51:‏7 \xt إِزهد. 37‏:‏31؛ 118‏:‏6؛ إِشا. 51‏:‏12\x*
\v 8 مَاغَارْ ثَاشِينْذَا أَذْ ثنْ ثشّْ أَمْ ثتّتّْ أَرُّوضْ، ؤُشَا أَكِيشُّو أَذْ ثنْ يشّْ أَمْ ثَاضُوفْثْ، \add مَاشَا\add* ثَاسڭْذَا إِنُو أَذْ ثقِّيمْ إِ ڒبْذَا ؤُ أَسنْجمْ إِنُو زِي جِّيڒْ أَڒْ جِّيڒْ.“ \x ◘ \xo 51:‏8 \xt إِشا. 50‏:‏9\x*
\b
\m 
\v 9 \bd ”فَاقْ، فَاقْ،\bd* أَرْضْ س جّْهذْ، \add أَ\add* أَغِيڒْ ن سِيذِي! فَاقْ أَمْ ذڭْ وُوسَّانْ ن زِيشْ، أَمْ ذِي جِّيڒَاثْ ن زّْمَانَاثْ ن وشْحَارْ ؤُيَا. مَا وَارْ إِدْجِي ذ شكْ، ونِّي إِقسّنْ رَاهَابْ، ذ ونِّي إِسّْنُوقّْبنْ ڒْهَايْشثْ؟
\v 10 مَا وَارْ إِدْجِي ذ شكْ ونِّي إِسِّيژْغنْ ڒبْحَارْ، أَمَانْ ن ڒْحمْڒثْ ن \add وَامَانْ\add* إِمقّْرَاننْ إِنّْهوْڒنْ \add مَا وَارْ إِدْجِي ذ شكْ\add* ونِّي يَارِّينْ أَبْرِيذْ ذڭْ وَامَانْ يُودْجْغنْ ن ڒبْحَارْ، أَڒَامِي زمَّارنْ أَذْ ژْوَانْ إِنِّي إِتّْوَافكّنْ؟ \x ◘ \xo 51:‏10 \xt إِشا. 43‏:‏16\x*
\v 11 إِنِّي إِفْذَا إِ-ثنْ سِيذِي أَذْ د-ذوْڒنْ، أَذْ د-أَسنْ غَارْ صِيهْيُونْ س ؤُسْڒِيوْڒوْ. ڒفْرَاحثْ نْ ڒبْذَا أَذْ ثِيڒِي خْ إِزدْجِيفنْ نْسنْ، نِيثْنِي أَذْ سّْوِيژّْضنْ \add إِفَاسّنْ نْسنْ\add* غَارْ وَارْشَاقْ ذ ڒفْرَاحثْ، \add أَمْ\add* إِ غَا يَارْوڒْ زَّايْسنْ وشْضَانْ ذ وسْحِيسّفْ.“
\b
\m 
\v 12 ”ذ نشّْ، \add وَاهْ،\add* ذ نشّْ ونِّي كنِّيوْ إِسّْفوّْجنْ. مِينْ \add ثعْنِيذْ\add* شكْ، أَقَا شكْ ثتّڭّْوذذْ زڭْ ورْيَازْ \add إِفنَّانْ\add*، زِي مِّيسْ ن بْنَاذمْ نِّي \add إِدْجَانْ أَمْ\add* أَرْبِيعْ، \x ◘ \xo 51:‏12 \xt إِزهد. 118‏:‏6؛ إِشا. 51‏:‏7\x*
\v 13 ثتّتُّوذْ سِيذِي ونِّي شكْ إِڭِّينْ، ونِّي إِبزّْعنْ أَجنَّا ذ ونِّي إِسَّارْسنْ ذْسُوسَا ن ثمُّورْثْ، أَقَا شكْ ثتّڭّْوذذْ ڒبْذَا، أَسّْ إِكْمڒْ، زِي سِّيبّثْ ن وسْعَارْ ن ونِّي إِحصَّارنْ ؤُمِي إِسّوْجَاذْ إِخفْ نّسْ مَاحنْذْ أَذْ يَاردّدْجْ؟ مَانِي إِدْجَا \add خنِّي\add* وسْعَارْ ن ونِّي إِحصَّارنْ؟ \x ◘ \xo 51:‏13 \xt أَيُوبْ 9‏:‏8؛ إِزهد. 104‏:‏2؛ إِشا. 40‏:‏22؛ 42‏:‏5؛ 44‏:‏24\x*
\v 14 ونِّي إِشَارّْفنْ س سّْنَاسڒْ أَمْ إِتّفْرِيغْ أَذْ إِتّْوَافكّْ ذَاوحْذَا. وَارْ إِتّْمتِّي ذڭْ وحْفُورْ \add ن إِمحْبَاسْ\add*، وَارْ زَّايسْ إِنقّصْ وغْرُومْ.
\v 15 \add مَاغَارْ\add* نشّْ ذ سِيذِي، أَربِّي نّشْ، ونِّي إِسّهْوَاڒنْ ڒبْحَارْ أَڒْ غَا هَاجَانْ ڒمْوَاجْ نّسْ، سِيذِي ن ڒْعسْكَارَاثْ ذ إِسمْ نّسْ.
\v 16 تّڭّغْ أَشْ أَوَاڒنْ إِنُو ذڭْ ؤُقمُّومْ نّشْ ؤُ سّْذُورُّويغْ شكْ ذِي ثِيڒِي ن ؤُفُوسْ إِنُو، مَاحنْذْ أَذْ ژُّوغْ أَجنَّا، أَذْ سَّارْسغْ ذْسُوسَا ن ثمُّورْثْ ؤُ أَذْ إِنِيغْ إِ صِيهْيُونْ: ’شكْ ذ ڒْڭنْسْ إِنُو!‘ “
\b
\m 
\v 17 \bd ”فَاقْ، فَاقْ،\bd* كَّارْ-د أَ ؤُرْشَالِيمْ! زڭْ ؤُفُوسْ ن سِيذِي ثسْوِيذْ زِي ڒْكَاسْ ن وسْعَارْ نّسْ أَمقّْرَانْ. ثشِّيذْ ڒخْمِيرَا زِي ڒْكَاسْ نِّي إِسّْذوَّاخنْ، \add وَاهْ،\add* ثْژمّذْ \add ت\add*. \x ◘ \xo 51:‏17 \xt إِزهد. 60‏:‏5؛ إِشا. 52‏:‏1\x*
\v 18 وَارْ ت إِتّْڭوِّيذْ ؤُڒَا ذ إِجّنْ زِي مَارَّا إِحنْجِيرنْ نِّي د-ثُورُووْ، ؤُ زِي مَارَّا إِحنْجِيرنْ نِّي ثسّْيمْ، وَارْ ت يطِّيفْ ؤُڒَا ذ إِجّْ زڭْ ؤُفُوسْ.
\v 19 ثْنَاينْ \add ن ثْمسْڒَايِينْ\add*-أَ ڒقْفنْثْ شمْ، \add مَاشَا\add* وِي خَامْ إِ غَا إِحِينّنْ؟ \add خْزَارْ،\add* أَخَارّبْ ذ وڒْبزْ ذ ڒَاژْ ذ سِّيفْ! مَامّشْ شمْ إِ غَا سّْفوّْجغْ؟ \x ◘ \xo 51:‏19 \xt إِشا. 47‏:‏9\x*
\v 20 وْضَانْ إِحنْجِيرنْ نّمْ، غَاشَانْ، زّْڒنْ غَارْ مَارَّا ثِيغمَّارْ ن إِبْرِيذنْ أَمْ ثْغَايْضِينْ ن وزْغَارْ ذِي ثْرَاشَّا. نِيثْنِي جِّيوْننْ س وسْعَارْ ن سِيذِي، س ؤُسِيڭّْوذْ ن أَربِّي نّمْ.“ \x ◘ \xo 51:‏20 \xt إِڭجذ. 2‏:‏11، 12\x*
\b
\m 
\v 21 ”س ؤُيَا سڒْ أَيَا، \add أَ شمْ\add* ڒْمِيسْكِينَا، ذ ثَامسْشَارْثْ، \add مَاشَا\add* وَارْ إِدْجِي س بِينُو!
\v 22 أَمُّو إِ إِقَّارْ سِيذِي نّمْ، سِيذِي، أَربِّي نّمْ، ونِّي إِشَّاثنْ دّعْوثْ خْ ڒْڭنْسْ نّسْ: ’خْزَارْ، نشّْ أَذْ كّْسغْ ڒْكَاسْ إِسّْذوَّاخنْ زڭْ ؤُفُوسْ نّمْ، وَارْ ثْسسّذْ عَاذْ كْثَارْ زِي ڒخْمِيرَا ن ڒْكَاسْ ن وسْعَارْ إِنُو.
\v 23 نشّْ أَذْ ث ڭّغْ ذڭْ ؤُفُوسْ ن يِينِّي ذَايمْ إِغزَّانْ، إِنِّي إِنَّانْ إِ ڒعْمَارْ نّمْ: سَاضَارْ إِخفْ نّمْ \add غَارْ ثمُّورْثْ\add*، نشِّينْ أَذْ خَامْ نژْوَا! أَمُّو إِ ثڭِّيذْ أَعْرُورْ نّمْ أَمْ مَامّشْ ثدْجِيذْ ذ ثَامُّورْثْ، \add ؤُشَا\add* ثُوغَا شكْ ذ أَبْرِيذْ ذِي طّْوعْ ن يِينِّي خَامْ إِژْوَانْ.‘ “
\b
\b
\c 52
\m 
\v 1 \bd ”فَاقْ، فَاقْ\bd*، أَرْضْ س جّهْذْ \add أَ،\add* صِيهْيُونْ، أَرْضْ س ورُّوضْ نّمْ إِشُّووَّارنْ، \add أَ\add* ؤُرْشَالِيمْ، ثَانْذِينْثْ ثَامْقدَّاسْثْ! زِي سَّا ثْسَاونْثْ وَارْ غَارمْ ث-إِ-د-إِتِّيذِيفْ عَاذْ ونِّي وَارْ إِتّْوَاخثْننْ ذ ؤُمخْمُوجْ.
\v 2 زرْزْ خَامْ ثَاعجَّاشْثْ، كَّارْ، قِّيمْ شمْ، \add أَ\add* ؤُرْشَالِيمْ! أَرْخُو سّْنَاسڒْ زڭْ يِيرِي نّمْ، \add أَ\add* ثَامحْبُوسْثْ، \add أَ\add* يدْجِيسْ ن صِيهْيُونْ!
\v 3 مَاغَارْ أَمُّو إِ إِقَّارْ سِيذِي: ’ثمّنْزمْ س بَاطڒْ، أَذْ ثتّْوَاسّْفكّمْ \add عَاوذْ\add* بْڒَا ثْمنْيَاثْ!‘
\v 4 مَاغَارْ أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’زِيشْ إِهْوَا ڒْڭنْسْ إِنُو غَارْ مِيصْرَا مَاحنْذْ أَذْ ذِينِّي إِقِّيمْ \add أَمْ ڒْبَارَّانِي\add*، ؤُشَا أَشُّورْ إِحْصَارْ إِ-ث خْ وَالُو!‘ “ \x ◘ \xo 52:‏4 \xt أَمز. 46‏:‏6\x*
\b
\m 
\v 5 ”ؤُشَا ڒخُّو، مِينْ غَارِي عَاذْ خَافِي أَذْ ت ڭّغْ ذَانِيثَا، إِقَّارْ سِيذِي، مَاغَارْ أَوْينْ ڒْڭنْسْ إِنُو بْڒَا سِّيبّثْ ؤُشَا إِنِّي خَاسْ إِتّْصلّْطنْ سّْغُويُّونْ، إِقَّارْ سِيذِي، أَسّْ مَارَّا تّْعيّْبنْ ذڭْ يِيسمْ إِنُو. \x ◘ \xo 52:‏5 \xt حِز. 36‏:‏20، 23؛ رُوم. 2‏:‏24\x*
\v 6 س ؤُيَا أَذْ إِسّنْ ڒْڭنْسْ إِنُو إِسمْ إِنُو، س ؤُيَا، أَقَا \bd نشّْ نشّْ\bd*، ونِّي إِقَّارنْ \bd ذڭْ وَاسّْ نِّي\bd*: نشّْ أَقَا أَيِي ذَا!“
\b
\m 
\v 7 ”مشْحَاڒْ شْنَانْ خْ إِذُورَارْ إِصُورَافْ ن ؤُمْبشَّارْ نِّي إِتّْبَارّْحنْ س ڒهْنَا، ن ؤُمْبشَّارْ ن \add ڒخْبَارْ\add* أَصبْحَانْ نِّي إِتّْبَارّْحنْ س ؤُسنْجمْ، ونِّي إِقَّارنْ إِ صِيهْيُونْ: ’أَربِّي نّمْ ذ أَجدْجِيذْ!‘ \x ◘ \xo 52:‏7 \xt نَحُم. 2‏:‏1؛ رُوم. 10‏:‏15\x*
\v 8 \add سْڒمْ إِ\add* ثْمِيجَّا ن إِعسَّاسنْ نّمْ! نِيثْنِي تّْسْڭعَّاذنْ ثْمِيجَّا \add نْسنْ\add*، تّسْڒِيوْڒِيونْ مُوننْ، مَاغَارْ ؤُذمْ ذڭْ ؤُذمْ \add أَكِيذسْ\add* أَذْ ثْوَاڒَانْ مَامّشْ إِ د غَا إِسّعْقبْ سِيذِي صِيهْيُونْ.
\v 9 سْغُويّنْثْ س ڒفْرَاحثْ، سْڒِيوْڒونْثْ ثْمُوننْثْ، \add أَ\add* ڒْخِيرْبَاثْ ن ؤُرْشَالِيمْ، مَاغَارْ سِيذِي إِسّْفوّجْ ڒْڭنْسْ نّسْ، إِفكّْ ؤُرْشَالِيمْ.
\v 10 إِعَارَّا سِيذِي أَغِيڒْ نّسْ أَمْقدّسْ زَّاثْ إِ ثِيطَّاوِينْ ن مَارَّا ڒڭْنُوسْ ؤُ مَارَّا ثِيمَاوِّينْ ن ثمُّورْثْ أَذْ ژَترنْثْ أَسنْجمْ ن أَربِّي نّغْ.“ \x ◘ \xo 52:‏10 \xt إِزهد. 98‏:‏2؛ لك. 3‏:‏6\x*
\b
\m 
\v 11 \bd ”رُوحمْ، رُوحمْ\bd*، فّْغمْ-د سّنِّي، وَارْ تّْحَاذَامْ وَالُو ن مِينْ إِخمْجنْ، فّْغمْ سّنِّي زِي ڒْوسْطْ نّسْ، سِيزذْڭمْ إِخفْ نْومْ، \add أَ كنِّيوْ\add* إِنِّي يَاربُّونْ ڒقْشُوعْ ن سِيذِي! \x ◘ \xo 52:‏11 \xt 2 كُور. 6‏:‏17؛ أَسَا. 18‏:‏4\x*
\v 12 مَاغَارْ كنِّيوْ وَارْ ثتّفّْغمْ س ثزْڒَا، وَارْ ثَاركّْوَاڒمْ، مَاغَارْ سِيذِي أَذْ يُويُورْ زَّاثْ نْومْ ؤُ أَربِّي ن إِسْرَائِيل أَذْ يِيڒِي ذ أَغزْذِيسْ نْومْ أَنڭَّارْ.“
\b
\c 53
\s1 أَسْوَاضعْ ن ؤُمْسخَّارْ ن سِيذِي (ڒخْبَارْ أَصبْحَانْ وِيسّْ خمْسَا)
\m 
\v 1 ”خْزَارْ، أَمْسخَّارْ إِنُو أَذْ يڭّْ س ڒعْقڒْ، أَذْ إِتّْوَاسّْعُودْجْ ؤُ أَذْ إِتّْوَاسُّوعْڒَا، \add وَاهْ،\add* أَذْ إِتّْوَاسّْعُودْجْ أَڒْ طَّارْفْ.
\v 2 أَمْ زَّايكْ نّْخڒْعنْ أَطَّاسْ - أَمُّو س وَاطَّاسْ إِخْسَارْ ؤُذمْ نّسْ، وَارْ إِدْجِي \add عَاذْ\add* أَمْ ن إِجّْ ن بْنَاذمْ، ؤُ أَدُّوذْ نّسْ، وَارْ إِدْجِي \add عَاذْ\add* أَمْ ن ثَارْوَا ن بْنَاذمْ - \x ◘ \xo 53:‏2 \xt إِشا. 53‏:‏3\x*
\v 3 أَمُّو إِ غَا إِسّنْڭزْ نتَّا أَطَّاسْ ن ڒڭْنُوسْ، \add وَاهْ، عَاذْ\add* إِجدْجِيذنْ أَذْ سّغْذنْ، مَاغَارْ مِينْ وَارْ ذ أَسنْ بَارّْحنْ، أَذْ ث ژَترنْ، ؤُ مِينْعمَّارْصْ وَارْ سْڒِينْ، أَذْ ث فهْمنْ.“ \x ◘ \xo 53:‏3 \xt رُوم. 15‏:‏21\x*
\b
\b
\m 
\v 4 ”مَانْ ونْ يُومْننْ ذِي ڒخْبَارْ نّغْ ؤُ وِي إِ ؤُمِي ذ إِتّْوَاسّْشنْ ؤُغِيڒْ ن سِيذِي؟ \x ◘ \xo 53:‏4 \xt يُوح. 12‏:‏38؛ رُوم. 10‏:‏16\x*
\m 
\v 5 \add مَاغَارْ\add* أَمْ ثْسطَّا إِمْغَارْ نتَّا زَّاثْ إِ وُوذمْ نّسْ، أَمْ وژْوَارْ زِي ثمُّورْثْ يُوژْغنْ. نتَّا ثُوغَا وَارْ غَارسْ أَدُّوذْ نِيغْ أَشوَّارْ \add خْمِي\add* ث نْژَارْ، وَارْ غَارسْ بُو وَاژْرِي ن ڒْخژْرَاثْ أَڒَامِي ذَايسْ إِ غَا نمّژْرِي.
\m 
\v 6 ثُوغَا إِتّْوَاسّحْقَارْ، إِمّنْضَارْ زڭْ إِوْذَانْ، أَرْيَازْ نْ ڒحْرِيقْ، إِسّنْ ڒحْڒَاشْ، أَمْ يِيجّنْ إِ ؤُمِي ڒحّْفنْ أَغمْبُوبْ، \add أَمُّو إِ\add* ثُوغَا إِتّْوَاسّحْقَارْ ؤُ نشِّينْ وَارْ ث نْحسِّيبْ وَالُو. \x ◘ \xo 53:‏6 \xt إِزهد. 22‏:‏7، 8؛ إِزهد. 69‏:‏2‏-‏4؛ إِشا. 49‏:‏7؛ 52‏:‏14؛ مك. 9‏:‏12\x*
\m 
\v 7 س ثِيذتّْ، إِكْسِي خَاسْ ڒحْڒَاشْ نّغْ ؤُشَا يَارْبُو ڒحْرِيقْ نّغْ، \add مَاشَا\add* نشِّينْ نْحسْبْ إِ-ث أَمْ يِيجّنْ ثڒْقفْ إِ-ث لْمُوصِيبَا، أَمْ يِيجّنْ إِغْضڒْ إِ-ث ؤُ إِحْصَارْ إِ-ث أَربِّي. \x ◘ \xo 53:‏7 \xt مت. 8‏:‏17\x*
\m 
\v 8 \add مَاشَا\add* نتَّا إِتّْوَاسّْنُوقّبْ خْ إِعذِّيينْ نّغْ، خْ ڒْمُوعْصِييّثْ نّغْ ڒبْزنْ ث. ثمَّارْسْ خَاسْ ثشْثِي نِّي ذ أَنغْ د-إِسَّاكّْوَاضنْ ڒهْنَا، ؤُ س إِيزِّيمنْ نّسْ إِذْوڒْ أَنغْ ذ أَڭنْفِي. \x ◘ \xo 53:‏8 \xt رُوم. 4‏:‏25؛ 5‏:‏1؛ 1 كُور. 15‏:‏3؛ أَفا. 2‏:‏14؛ 1 بُط. 2‏:‏24\x*
\m 
\v 9 مَارَّا نشِّينْ ثُوغَا نْودَّارْ أَمْ وُودْجِي، نذْوڒْ كُوڒْ  إِجّْ غَارْ وبْرِيذْ نّسْ، \add مَاشَا\add* سِيذِي يَارَّا أَذْ خَاسْ ثوْضَا ڒْمُوعْصِييّثْ نّغْ مَارَّا. \x ◘ \xo 53:‏9 \xt مت. 10‏:‏1، 5، 6\x*
\m 
\v 10 ذدْجنْ ث، ؤُشَا إِجَّا \add إِ-ثنْ\add* أَذْ ث سّْبهْذْڒنْ. وَارْ يَارْزِيمْ أَقمُّومْ نّسْ. أَمْ إِزْمَارْ نذْهنْ ث غَارْ ثْغَارْصْثْ، أَمْ ثخْسِي ثڭْنُو قِيبَاتْشْ إِ ونِّي ت إِدْجَاسنْ، أَمُّو وَارْ يَارْزِيمْ نتَّا أَقمُّومْ نّسْ. \x ◘ \xo 53:‏10 \xt مت. 26‏:‏63؛ 27‏:‏12، 14؛ مك. 14‏:‏61؛ 15‏:‏5؛ ڒخ. 8‏:‏32؛ 1 بُط. 1‏:‏19‏-‏20\x*
\m 
\v 11 إِمّكْسِي-د زِي ڒحْصَارثْ ؤُ زِي ڒحْكَامْ. مَانْ ونْ زِي جِّيڒْ نّسْ ثُوغَا إِخمّْ ذَايسْ، زعْمَا إِتّْوَاقسّْ زِي ثمُّورْثْ ن يِينِّي إِدَّارنْ، أَقَا خَاسْ ثِيشْثِي زِي سِّيبّثْ ن ؤُعذِّي نْ ڒْڭنْسْ إِنُو! \x ◘ \xo 53:‏11 \xt دَان. 9‏:‏26\x*
\m 
\v 12 إِمّوْشْ أَسْ ونْضڒْ غَارْ إِعفَّاننْ، \add مَاشَا\add* غَارْ تُّوجَارْ ثُوغَا-ث ذِي ڒْموْثْ نّسْ إِقسْحنْ، وَاخَّا نتَّاعمَّارْصْ وَارْ إِڭِّي لْعُونْفْ ؤُعمَّارْصْ وَارْ ثُوغِي ڒْغشّْ ذڭْ ؤُقمُّومْ نّسْ. \x ◘ \xo 53:‏12 \xt مت. 27‏:‏57‏-‏61؛ 1 بُط. 2‏:‏22؛ 1 يُوح. 3‏:‏5\x*
\m 
\v 13 \add مَاشَا\add* ثُوغَا إِدْجَا إِ أَرْضَا ن سِيذِي مَاحنْذْ أَذْ ث إِڒْبزْ، إِسّحْڒشْ \add إِ-ث\add*. ڒَامِي ڒعْمَارْ نّسْ إِڭَّا إِخفْ نّسْ ذ ثَاغَارْصْثْ ن ؤُمَارْوَاسْ \add إِ دّْنُوبْ نّغْ\add*، أَذْ إِژَارْ نتَّا زَّارِيعثْ، أَذْ إِسّْزُوڭَّارْ نتَّا ؤُسَّانْ نّسْ ؤُشَا أَرْضَا ن سِيذِي أَذْ إِقْفڒْ س ؤُفُوسْ نّسْ. \x ◘ \xo 53:‏13 \xt يُوح. 3‏:‏16\x*
\v 14 ذِي سِّيبّثْ ن ؤُمَارّثْ ن ڒعْمَارْ نّسْ أَذْ ث إِژَارْ ؤُشَا أَذْ إِجِّيونْ. س ثُوسّْنَا نّسْ أَذْ إِسڭّذْ ؤُمْسخَّارْ إِنُو، أَمْسڭّذْ، أَطَّاسْ ن يوْذَانْ، مَاغَارْ أَذْ يَارْبُو ڒْمُوعْصِييّثْ نْسنْ. \x ◘ \xo 53:‏14 \xt 1 يُوح. 5‏:‏20\x*
\m 
\v 15 س ؤُيَا أَذْ أَسْ وْشغْ ثَاسْغَارْثْ جَارْ إِمقّْرَاننْ ؤُشَا أَكْ-ذ أَيْثْبَابْ ن صُّولْطَا أَذْ إِبْضَا ثَاكشَّاضْثْ، مِينْزِي إِسبّڒْ ثُوذَارْثْ نّسْ إِ ڒْموْثْ ؤُشَا إِتّْوَاحْسبْ زڭْ إِنِّي إِتّْعدَّانْ ؤُشَا يَارْبُو دّْنُوبْ ن وَاطَّاسْ ؤُشَا إِتَّارْ ذِي طّْوعْ ن يِينِّي إِتّْعدَّانْ.“ \f ◼ \fr 53:‏15 \ft \bd ’ثُوذَارْثْ‘\bd* - س ثْعِيبْرَانِيثْ ’ڒعْمَارْ‘.\f*  \x ◘ \xo 53:‏15 \xt مك. 15‏:‏28؛ لك. 22‏:‏37؛ 23‏:‏34؛ كُول. 2‏:‏15\x*
\b
\b
\c 54
\s1 ڒفْرَاحثْ ن ثمْغَارْثْ إِ وَارْ د-إِتِّيرْونْ ن سِيحْيُونْ
\m 
\v 1 ”سْرِيوْڒوْ، \add شمْ\add* ثنِّي وَارْ إِتِّيرْونْعمَّارْصْ! ذُوقّزْ س ؤُسْڒِيوْڒوْ، سْغُويّْ س ڒفْرَاحثْ، \add أَ شمْ\add* ثنِّي وَارْ إِسِّيننْ ڒوْجعْ ن ثَارْوَا، مَاغَارْ ثَارْوَا ن ثنِّي ذِي سمْحنْ ذ أَطَّاسْ خْ إِحنْجِيرنْ ن ثنِّي غَارْ إِدْجَا ورْيَازْ، إِقَّارْ سِيذِي. \x ◘ \xo 54:‏1 \xt ڭال. 4‏:‏27\x*
\v 2 أڭّْ تَّاسِيعْ إِ إِقِيضَانْ نّمْ ؤُ أجّْ أَذْ بزّْعنْ أَرْوَاقَاثْ ن ثْزذِّيغِينْ نّمْ أَطَّاسْ، وَارْ \add ثنْ\add* منّعْ. سْزُوڭَّارْ ثِيمُورَارْ نّمْ ؤُشَا زِييَّارْ ڒوْثَاذْ!
\v 3 مَاغَارْ شمْ أَذْ ثِيرِيوذْ غَارْ يفُوسْ ؤُ غَارْ ؤُزڒْمَاضْ ؤُشَا زَّارِيعثْ نّمْ أَذْ ثطّفْ ڒڭْنُوسْ ذ ثَاسْغَارْثْ ؤُشَا نِيثْنِي أَذْ سّْزذْغنْ ثِيندَّامْ يَاردّْدْجنْ.“
\b
\m 
\v 4 ”وَارْ تّڭّْوذْ شَا، مَاغَارْ وَارْ ثْسضْحِيذْ ؤُ وَارْ تّْوَاسّْبَارّْقذْ شَا، مَاغَارْ وَارْ ثتّْوَافضْحذْ. أَذْ ثتُّوذْ ڒفْضِيحثْ ن ثمْژِي نّمْ، وَارْ ثتّعْقِيڒذْ خْ ڒحْشُومِييّثْ ن إِسڭّْوُوسَا نّمْ أَمْ ثَاجَّاتْشْ.
\v 5 مَاغَارْ أَرْيَازْ نّمْ ذ ونِّي شمْ إِڭِّينْ، ’سِيذِي ن ڒْعسْكَارَاثْ‘ ذ إِسمْ نّسْ، ؤُشَا أَمْقدَّاسْ ن إِسْرَائِيل ذ أَمفْذِي نّمْ. أَذْ أَسْ ڒَاغَانْ ’أَربِّي ن مَارَّا ثَامُّورْثْ‘.
\v 6 مَاغَارْ سِيذِي إِڒَاغَا خَامْ أَمْ إِ يِيشْثْ ن ثمْغَارْثْ إِ ذِي إِسْمحْ \add ورْيَازْ نّسْ\add*، إِ ذَايسْ أَشْضَانْ ذڭْ بُوحْبڒْ نّسْ، ؤُ \add أَمْ\add* ثمْغَارْثْ ن إِسڭّْوُوسَا ن ثمْژِي، وَاخَّا ثُوغَا-ت ثمّنْضَارْ، إِقَّارْ أَربِّي نّمْ.
\v 7 \add مْغِيرْ\add* ثَازحْزِيحْثْ سمْحغْ ذَايمْ، \add مَاشَا\add* س أَرّحْمثْ ثَامقّْرَانْثْ أَذْ شمْ سّْمُونغْ \add غَارِي\add*.
\v 8 ؤُمِي ڭِّيغْ أَذُوقّزْ ن وغْضَابْ إِنُو أَذْ إِسْفِي، أَقَا سّْنُوفَّارغْ زَّايمْ أَغمْبُوبْ إِنُو إِ يِيشْثْ ثْزحْزِيحْثْ \add وَاهَا\add*، \add مَاشَا\add* س ثْمخْسِيوْثْ إِشُووَّارنْ ن ڒبْذَا أَذْ أَيِي ثزِّيدْجْزذْ، إِقَّارْ سِيذِي، أَمفْذِي نّمْ.“
\b
\m 
\v 9 ”مَاغَارْ وَا أَذْ يِيڒِي إِ نشّْ \add أَمْ\add* وُوسَّانْ ن نُوحْ ؤُمِي جُّودْجغْ أَقَا أَمَانْ ن نُوحْعمَّارْصْ وَارْ سّْفِيينْ ثَامُّورْثْ. أَمُّو إِ جُّودْجغْ \add ڒخُّو\add*، أَقَاعمَّارْصْ وَارْ تّڭّغْ أَذْ خَامْ إِدُّوقّزْ وغْضَابْ إِنُو ؤُ وَارْ شمْ تّْعِيقِيبغْ \add عَاذْ\add*. \x ◘ \xo 54:‏9 \xt أَمز. 9‏:‏11\x*
\v 10 مَاغَارْ إِذُورَارْ أَذْ ذوْڒنْ غَارْ ؤُغزْذِيسْ ؤُ ثِيوْرِيرِينْ أَذْ نّْهزّنْثْ، \add مَاشَا\add* ثَامخْسِيوْثْ إِنُو إِشوَّارنْعمَّارْصْ أَذْ خَامْ ثْحيّذْ ؤُشَا ڒْعَاهْذْ ن ڒهْنَا إِنُو وَارْ إِتّنْهزِّيعمَّارْصْ، إِقَّارْ سِيذِي، ونِّي ؤُمِي ثزِّيدْجْزذْ.“
\b
\m 
\v 11 ”\add أَ، شمْ\add* ثنِّي إِتّْوَاحْصَارنْ، ثنِّي إِقطّبْ ؤُسمِّيضْ، ثنِّي نْهْڒَا أَفوّجْ! خْزَارْ، نشّْ أَذْ قُووَّارغْ إِژْرَا نّمْ \add إِغْڒَانْ\add* س \add إِشْثْ ن ثْمَا\add* ثَابَارْشَانْثْ ؤُشَا أَذْ ڭّغْ ذْسَاسْ نّمْ خْ ثْيَاقُوثِينْ ن صَافِّيرْ.
\v 12 نشّْ أَذْ ڭّغْ ڒكْوَازَا نّمْ إِ ثْفُوشْثْ زڭْ ؤُكْرِيسْثَالْ، ؤُڒَا ذ ثِيوُّورَا نّمْ ن ڒعْقَاقْ إِزڭّْوَاغنْ ذ مَارَّا ڒحْيُوضْ نّمْ إِ ذ أَمْ إِنّْضنْ زڭْ إِژْرَا إِغْڒَانْ. \x ◘ \xo 54:‏12 \xt أَسَا. 22‏:‏19‏-‏21\x*
\v 13 مَارَّا إِحنْجِيرنْ نّمْ أَذْ إِڒِينْ ذ إِمحْضَارنْ ن سِيذِي ؤُشَا ڒهْنَا ن إِحنْجِيرنْ نّمْ أَذْ يِيڒِي ذ أَمقّْرَانْ. \x ◘ \xo 54:‏13 \xt يُوح. 6‏:‏45\x*
\v 14 شمْ أَذْ ثِيڒِيذْ ثَاركّْنذْ س ثْسڭْذَا. أَذْ ثِيڒِيذْ ثتَّاڭّْوجذْ خْ ڒحْصَارثْ، مَاغَارْ وَارْ \add ذِينْ\add* مِينْ زِي غَا ثڭّْوذذْ، ؤُڒَا خْ ؤُنخْڒِيعْ، مِينْزِي وَارْ د غَارمْ إِتِّيكّْوِيضْ شَا.
\v 15 خْزَارْ، أَذْ سّْمُوننْ، \add مَاشَا أَيَا\add* وَارْ إِدْجِي زَّايِي. وِي خَامْ إِ غَا إِسّْمُوننْ، أَذْ زَّايمْ إِوْضَا.
\v 16 خْزَارْ، نشّْ خڒْقغْ-د أَمْزِيڒْ ونِّي إِتّْسُوضنْ ثِيرْجِينْ ن ثْمسِّي ؤُ إِسُّوفُّوغْ-د إِشْثْ ن ڒْقشْعثْ إِ ڒْخذْمثْ نّسْ. \add أَمُّو\add* إِ د-خڒْقغْ عَاوذْ أَمْثحَّايْ مَاحنْذْ أَذْ يَاردّدْجْ.
\v 17 كُوڒْ ڒسْنَاحْ نِّي إِتّْوَاڭّنْ ضِيدّْ نّمْ، وَارْ إِتِّيوضْ، ؤُشَا كُوڒْ  إِڒسْ نِّي خَامْ إِ د غَا إِڭعّْذنْ ذِي دّعْوثْ، أَذْ ث ثْحكْمذْ شمْ. ثَا ذ ثَاسْغَارْثْ ن إِمْسخَّارنْ ن سِيذِي ؤُشَا ثَاسڭْذَا نْسنْ ثفّغْ-د زَّايِي، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.“
\b
\b
\c 55
\s1 أَسمْ-د غَارْ وَامَانْ
\m 
\v 1 ”أَ، مَارَّا إِنِّي إِفُّوذنْ، \bd أَسمْ-د\bd* غَارْ وَامَانْ، ونِّي وَارْ غَارْ دْجِينْثْ ثنْعَاشِينْ، \bd أَسمْ-د\bd*، سْغمْ، شّمْ، \add وَاهْ،\add* \bd أَسمْ-د\bd* ؤُشَا سْغمْ بِينُو ذ ؤُغِي، بْڒَا ثِينْعَاشِينْ ؤُ بْڒَا تَّامَانْ. \x ◘ \xo 55:‏1 \xt يُوح. 7‏:‏37، 38؛ أَسَا. 22‏:‏17، 20\x*
\v 2 مَايمِّي ثْوزّْنمْ نُّوقَارْثْ إِ مِينْ وَارْ إِدْجِينْ ذ أَغْرُومْ ؤُ \add مَايمِّي\add* ثْجهْذمْ إِ مِينْ وَارْ إِجِّيوْننْ؟ سْڒمْ-د غَارِي مْلِيحْ، شّمْ مِينْ إِشْنَانْ ؤُشَا أجّْ ڒعْمَارْ نْومْ أَذْ إِغبَّا ثَاذُونْثْ.
\v 3 وْشمْ أَمزُّوغْ ؤُشَا \bd أَسمْ-د\bd* غَارِي، سْڒمْ، \add خنِّي\add* أَذْ إِدَّارْ ڒعْمَارْ نْومْ، \add مَاغَارْ\add* نشّْ أَذْ أَكِيذْومْ ڭّغْ إِجّْ ن ڒْعَاهْذْ إِ ڒبْذَا، ثِيمڭَّا ن ثْمخْسِيوْثْ ن ڒَامَانْ إِشوَّارنْ ن ذَاوُوذْ. \x ◘ \xo 55:‏3 \xt ڒخ. 13‏:‏34\x*
\b
\m 
\v 4 خْزَارْ، ڭِّيغْ ث ذ أَشهَّاذْ إِ شُّوعُوبْ، ذ ڒْحَاكمْ، ذ بَابْ ن ڒُومُورْ إِ شُّوعُوبْ.
\v 5 خْزَارْ، أَذْ ثْڒَاغِيذْ إِجّْ ن ڒْڭنْسْ إِ وَارْ ثسِّينذْ، ؤُ ڒْڭنْسْ إِ وَارْ شكْ إِسِّيننْ أَذْ غَاركْ د-يَاسْ ذِي طّْوعْ ن سِيذِي، أَربِّي نّشْ، ؤُ ذِي طّْوعْ ن ؤُمْقدَّاسْ ن إِسْرَائِيل، مِينْزِي نتَّا إِسّْعُودْجْ شكْ.“
\b
\m 
\v 6 ”أَرْزُومْ خْ سِيذِي ڒَامِي نتَّا إِتّجَّا إِخفْ نّسْ أَذْ إِتّْوَافْ، ڒَاغَامْ أَسْ ڒَامِي د-يُوذسْ نتَّا.
\v 7 أجّْ أَعفَّانْ أَذْ إِسْمحْ ذڭْ وبْرِيذْ نّسْ ؤُشَا أَرْيَازْ ن ڒْغشّْ ذڭْ إِخَارِّيصنْ نّسْ. أجّْ إِ-ث أَذْ د-إِذْوڒْ غَارْ سِيذِي، \add خنِّي\add* نتَّا أَذْ أَسْ إِزِّيدْجزْ، ؤُ غَارْ أَربِّي نّغْ، مَاغَارْ نتَّا إِغفَّارْ أَطَّاسْ ن ثْوَاڒَاوِينْ.
\b
\m 
\v 8 مَاغَارْ إِخَارِيصّنْ إِنُو وَارْ دْجِينْ أَمْ يِيخَارِيصّنْ نْومْ ؤُ إِبْرِيذنْ إِنُو وَارْ دْجِينْ أَمْ يِيبْرِيذنْ نْومْ، إِقَّارْ سِيذِي.
\v 9 مَاغَارْ أَمْ مَامّشْ ؤُعْڒَانْ إِجنْوَانْ خْ ثمُّورْثْ، أَمُّو إِ يُوعْڒَانْ إِبْرِيذنْ إِنُو خْ إِبْرِيذنْ نْومْ ؤُ إِخَارِّيصنْ إِنُو خْ إِخَارِّيصنْ نْومْ.
\v 10 مَاغَارْ أَمْ مَامّشْ إِ د-إِهكّْوَا ونْژَارْ ذ وذْفڒْ زڭْ ؤُجنَّا ؤُ وَارْ غَارسْ د-إِذِّيكّْوِيڒْ شَا، مَاشَا إِسُّوفَّا ثَامُّورْثْ ذ أَمزْوَارُو ؤُشَا إِتَّارَّا إِ-ت أَذْ ثوْشْ ڒْغِيدْجثْ، أَذْ ثَاوِي أَغمُّويْ ؤُشَا \add أَوَارْنِي أَسْ\add* إِتِّيشْ زَّارِيعثْ إِ ونِّي إِژَارّْعنْ ذ وغْرُومْ إِ ونِّي إِتّتّنْ،
\v 11 أَمُّو إِ غَا يِيڒِي ؤُڒَا ذ أَوَاڒْ إِ د-إِتّفّْغنْ زڭْ ؤُقمُّومْ إِنُو. وَارْ د غَارِي إِذِّيكّْوِيڒْ إِخْوَا، مَاشَا أَذْ يڭّْ مِينْ خْسغْ ؤُ أَذْ يَاوضْ \add مَارَّا\add* مِينْ غَارْ ث سّكّغْ.“
\b
\m 
\v 12 ”مَاغَارْ أَذْ ثفّْغمْ س ڒفْرَاحثْ ؤُشَا أَذْ كنِّيوْ سّْقبّْضنْ ذِي ڒهْنَا. إِذُورَارْ ذ ثوْرِيرِينْ أَذْ دُّوقّْزنْ س ؤُسْڒِيوْڒوْ زَّاثْ إِ وُوذمْ نْومْ ؤُ مَارَّا ثِيشجُّورَا ن ييَّارْ أَذْ وْثنْثْ شَامْخَا س إِفَاسّنْ. \x ◘ \xo 55:‏12 \xt 1 إِم. 16‏:‏33\x*
\v 13 ذڭْ ومْشَانْ ن ؤُسنَّانْ أَذْ ثغْمِي \add ثْشجَّارْثْ ن\add* ؤُمرْزِي، ذڭْ ومْشَانْ ن ثْزڭّْوَارْثْ أَذْ ثغْمِي ثْشجَّارْثْ ن ثَارِيحَانْثْ. أَيَا أَذْ يِيڒِي إِ سِيذِي، إِ \add شَّانْ ن\add* يِيسمْ \add نّسْ\add*، إِ ڒعْڒَامثْ نْ ڒبْذَا إِ وَارْ إِمحِّينْعمَّارْصْ.“ \f ◼ \fr 55:‏13 \ft \bd ’أَمرْزِي‘\bd* - نِيغْ ’أَمضْزِي‘.\f*
\b
\b
\c 56
\s1 لْوُوعُوذْ إِ ونِّي يَارزُّونْ ثَاسڭْذَا ؤُشَا أَذْ ثُوبنْ
\m 
\v 1 ”أَمُّو إِ إِقَّارْ سِيذِي: ’حْضَامْ ڒْحقّْ ؤُشَا ڭّمْ ثَاسڭْذَا، مِينْزِي أَسنْجمْ إِنُو يُوذسْ-د، أَذْ د-يَاسْ ذغْيَا، ؤُشَا ثَاسڭْذَا إِنُو \add ثِيوضْ-د\add* حِيمَا أَذْ ثتّْوَاسَّارْڭبْ.
\v 2 سّعْذْ ن ورْيَازْ نِّي إِتّڭّنْ أَمُّو ؤُڒَا ذ مِّيسْ ن بْنَاذمْ نِّي إِمنّْعنْ ذِي مَانْ أَيَا، ونِّي إِحطَّانْ أَسّْ ن سّبْثْ حِيمَا وَارْ إِتّْوَاسّْعِيدْجِيثْ، ذ ونِّي إِحطَّانْ أَفُوسْ نّسْ أَڒَامِي وَارْ إِتّڭّْ زِي مَارَّا مِينْ وَارْ إِحْڒِينْ.
\v 3 وَارْ تّجِّي أَبَارَّانِي ونِّي إِقّْننْ غَارْ سِيذِي أَذْ يِينِي: ’سِيذِي إِعْزڒْ أَيِي قَاعْ خْ ڒْڭنْسْ نّسْ!‘، ؤُشَا وَارْ تّجِّي ونِّي ؤُمِي تّْوَادّْزنْ إِمدْجَاڒنْ أَذْ يِينِي: ’خْزَارْ، نشّْ ذ ثَاشجَّارْثْ يُوژْغنْ!‘ \f ◼ \fr 56:‏3 \ft \bd ’ثَاشجَّارْثْ‘\bd* - نِيغْ ’أَدَّاڭْ‘ (’إِدَّاڭنْ‘).\f*
\v 4 مَاغَارْ أَمُّو إِ إِقَّارْ سِيذِي خْ \add إِمْسخَّارنْ\add* إِنِّي ؤُمِي تّْوَادّْزنْ إِمدْجَاڒنْ، إِنِّي إِحطَّانْ ؤُسَّانْ إِنُو ن سّبْثْ ؤُ تِّيخْضَارنْ مِينْ إِدْجَانْ إِ أَرْضَا إِنُو ؤُ تّطّْفنْ ذِي ڒْعَاهْذْ إِنُو:
\v 5 نشّْ أَذْ أَسنْ ڭّغْ أَمْشَانْ ذِي ثَادَّارْثْ إِنُو ؤُ جَارْ ڒحْيُوضْ  إِنُو ؤُشَا أَذْ أَسنْ وْشغْ إِسمْ حْسنْ خْ \add يِيسمْ\add* ن إِحنْجِيرنْ ذ ثْحنْجِيرِينْ. كُوڒْ إِجّنْ زَّايْسنْ أَذْ أَسْ وْشغْ إِسمْ نْ ڒبْذَا نِّيعمَّارْصْ وَارْ إِمحِّينْ.
\b
\m 
\v 6 إِبَارَّانِييّنْ نِّي إِ غَا إِقّْننْ غَارْ سِيذِي حِيمَا أَذْ أَسْ سخَّارنْ ؤُ حِيمَا أَذْ خْسنْ إِسمْ ن سِيذِي، حِيمَا أَذْ إِڒِينْ ذ إِمْسخَّارنْ نّسْ - مَارَّا إِنِّي إِحطَّانْ أَسّْ ن سّبْثْ حِيمَا وَارْ إِتّْوَاسّْعِيدْجِيثْ، ؤُڒَا ذ إِنِّي إِمنّْعنْ ذِي ڒْعَاهْذْ إِنُو -
\v 7 أَذْ ثنْ أَوْيغْ \add عَاوذْ\add* غَارْ وذْرَارْ إِنُو إِقدّْسنْ ؤُ أَذْ ثنْ سّفْرَاحغْ ذِي ثَادَّارْثْ إِنُو ن ثْژَادْجِيثْ. ثِيغَارْصَا نْسنْ ن وشْمَاضْ ذ ثْغَارْصَا نْسنْ نّغْنِي أَذْ إِڒِينْثْ إِ أَرْضَا إِنُو خْ ؤُعَالْطَارْ إِنُو، مَاغَارْ ثَادَّارْثْ إِنُو أَذْ أَسْ ڒَاغَانْ ثَادَّارْثْ ن ثْژَادْجِيثْ إِ مَارَّا ڒڭْنُوسْ.‘ “ \x ◘ \xo 56:‏7 \xt مت. 21‏:‏13؛ مك. 11‏:‏17؛ لك. 19‏:‏46\x*
\b
\m 
\v 8 ”سِيذِي إِنُو، سِيذِي، ونِّي ذ إِسّْمُونَانْ إِنِّي خْ يُوژّْڒنْ ن إِسْرَائِيل، إِقَّارْ: ’نشّْ أَذْ غَارسْ د-سّْمُونغْ كْثَارْ خْ يِينِّي د-إِتّْوَاسّْمُوننْ غَارسْ \add عَاذْ\add*.‘ “
\b
\m 
\v 9 ”مَارَّا ڒوْحُوشْ ن ڒخْڒَا، أَسمْ-د إِ مَاشَّا، \add وَاهْ،\add* مَارَّا ڒْمَاڒْ ن وزْغَارْ! \f ◼ \fr 56:‏9 \ft \bd ’أَزْغَارْ‘\bd* - نِيغْ ’ڒْغَابثْ‘ نِيغْ ’ثَازْڭَانْثْ‘.\f*
\v 10 إِعسَّاسنْ نّسْ دَّارْغْڒنْ مَارَّا، وَارْ سِّيننْ وَالُو. مَارَّا نِيثْنِي ذ إِطَانْ إِبكْمنْ، وَارْ زمَّارنْ أَذْ زُونْ، طّْسنْ، زّْڒنْ، تّخْسنْ أَنُوذمْ.
\v 11 إِطَانْ-أَ أَرْجْفنْ أَڒْ طَّارْفْ، وَارْ سِّيننْ ثَايَاوَانْثْ. نِيثْنِي ذ إِمكْسَاونْ وَارْ إِفهّْمنْ، كُوڒْ  إِجّنْ \add زَّايْسنْ\add* إِضفَّارْ أَبْرِيذْ نّسْ، كُوڒْ إِجّْ يَارزُّو ثِيزِي نّسْ، عَاذْ ونِّي ذ أَنڭَّارْ زَّايْسنْ.
\v 12 \add قَّارنْ\add*: ’أَستِّيوْ-د، أَذْ د-أَوْيغْ بِينُو، أَذْ نسْشَارْ س شّْرَابْ. أَمْ وَاسّْ-أَ أَمُّو إِ غَا يِيڒِي ؤُڒَا ذ ثِيوشَّا، \add أَذْ يِيڒِي عَاذْ\add* ذ أَمقّْرَانْ ذ إِشْنَانْ \add خَاسْ\add*!‘ “
\b
\b
\c 57
\m 
\v 1 ”إِتّْوَاهلّكْ ؤُمْسڭّذْ ؤُشَا وَارْ ذِينْ ؤُڒَا ذ إِجّْ وِي ث إِتّْكسِّينْ غَارْ وُوڒْ. إِرْيَازنْ ذَايْسنْ ثَامخْسِيوْثْ إِشوَّارنْ مّكْسِينْ، بْڒَا مَا إِحطَّا ؤُڒَا ذ إِجّْ أَقَا أَمْسڭّذْ إِمّكْسِي قْبڒْ إِ د غَا يَاسْ \add أَسّْ ن\add* لْمُوصِيبَا. \x ◘ \xo 57:‏1 \xt إِزهد. 12‏:‏2؛ مِيخَا 7‏:‏2\x*
\v 2 نتَّا أَذْ د-يَاذفْ ذِي ڒهْنَا، أَذْ أَرّيْحنْ نِيثْنِي ذِي قَامَاثْ نْسنْ \add ذڭْ إِمضْڒَانْ\add*، \add كُوڒْ إِجّْ\add* ونِّي يُويُورنْ أَبْرِيذْ نّسْ إِسڭّْمنْ.“
\b
\m 
\v 3 ”قَارّْبمْ-د ذَا، \add أَ كنِّيوْ\add* إِحنْجِيرنْ ن ثْبزْڭِيوْثْ، ثَارْوَا ن يِينِّي إِزنَّانْ ؤُ ن ثمْغَارْثْ ن فَارْقْ-شّْغڒْ!
\v 4 وِي زِي ثسْثهزَّامْ أَمُّو، وِي خْ ثْشَارَّاڭمْ أَقمُّومْ ؤُ وِي غَارْ ثْجبّْذمْ إِڒسْ غَارْ بَارَّا؟ مَا وَارْ ثدْجِيمْ ذ إِحنْجِيرنْ ن ؤُعذِّي، ثَارْوَا ن ڒْغشّْ؟ \f ◼ \fr 57:‏4 \ft \bd ’ثَارْوَا‘\bd* - س ثْعِيبْرَانِيثْ ’زَّارِيعثْ‘.\f*
\v 5 \add كنِّيوْ\add* إِنِّي إِتّْهَاجنْ غَارْ ثْشجُّورَا ن لْ-أَصْنَامْ، سَاذُو كُوڒْ ثَاشجَّارْثْ ثَازِيزَاوْثْ، \add كنِّيوْ\add* إِنِّي إِغَارّْصنْ إِ إِحنْجِيرنْ إِمژْيَاننْ ذِي ثغْزُورِينْ، سْوَادَّايْ ذِي ثزِّييِينْ ن ڒجْرُوفْ. \f ◼ \fr 57:‏5 \ft \bd ’ثَاشجَّارْثْ‘\bd* - نِيغْ ’أَدَّاڭْ‘ (’إِدَّاڭنْ‘).\f*
\v 6 ثَاسْغَارْثْ نّمْ غَارْ إِژْرَا إِيُويْذَانْ ن ثغْزُورِينْ. أَقَا ذِينْ ثَاسْغَارْثْ إِ ذ أَمْ د-يكَّارنْ. ؤُڒَا إِ نِيثْنِي ثْزدْجْعذْ أَسنْ ثَاوْهِيبْثْ ن ؤُسيّبْ، ثْوهّْبذْ ثَاوْهِيبْثْ \add ن ڒْغِيدْجثْ\add*. مَا نشّْ أَذْ قِّيمغْ سْقَارغْ خْ مَانْ أَيَا؟“
\b
\m 
\v 7 ”خْ وذْرَارْ يُوعْڒَانْ ذ إِتّْوَاسّْڭعّْذنْ ثسُّوذْ قَامَا نّمْ. ؤُڒَا ذِينِّي ثْڭعّْذذْ حِيمَا أَذْ ثْوهّْبذْ ثَاغَارْصْثْ.
\v 8 أَوَارْنِي ثوَّارْثْ ذ ڒضْرُوفْ نّسْ \add غَارْ إِغزْذِيسنْ نّسْ\add* ثڭِّيذْ ڒعْڒَامثْ نّمْ ن ڒِيذَارثْ، \add ’مْزُوزَا نّمْ‘\add*، مَاغَارْ شمْ ثنْعزْڒذْ خَافِي ذ ثَاعَارْيَانْثْ ؤُ ثْڭعّْذذْ ذِينِّي سنّجْ. ثْعذْڒذْ إِ يِيخفْ نّمْ قَامَا ذ ثْمِيرِيوْثْ ؤُشَا ثْعَاهْذذْ إِخفْ نّمْ أَكْ-ذ شَا زَّايْسنْ. ثتّخْسذْ ثَاسُّوثْ نْسنْ، ثژْرِيذْ ثَارْيَاسْثْ \add نْسنْ\add*.
\v 9 أَكْ-ذ زّشْثْ ثْرُوحذْ غَارْ ؤُجدْجِيذْ ؤُشَا ثَارْنِيذْ أَطَّاسْ ذِي ڒعْطُورْ إِتّْفُوحنْ نّمْ. ثسّكّذْ إِمْسخَّارنْ نّمْ غَارْ ڒَاڭّْوَاجْ ؤُشَا ثسّْوَاضْعذْ إِخفْ نّمْ أَڒْ ڒَاخَارْثْ.
\v 10 زِي سِّيبّثْ ن وَاطَّاسْ ن إِمْسَاڭَارنْ نّمْ ثُوحْڒذْ، \add مَاشَا\add*عمَّارْصْ وَارْ ثنِّيذْ: ’وَارْ ذِينْ إِقِّيمْ ڒَايَاسْ!‘ ثُوفِيذْ جّهْذْ ن جْذِيذْ إِ ثُوذَارْثْ. خْ ؤُيَا وَارْ ثحْڒِيشذْ.
\v 11 مَانْ ونْ زِي ثسّْحِيسّْفذْ ؤُ ثڭّْوذذْ أَقَا شمْ ثسّْخَارّْقذْ خَافِي ؤُ وَارْ ذ أَيِي ثِيذَارذْ، وَارْ ذ أَيِي ثڭِّيذْ غَارْ وُوڒْ نّمْ؟ مَا وَارْ ثُوغِي نشّْ سّغْذغْ زڭْ وشْحَاڒْ ؤُيَا، \add أَڒَامِي\add* شمْ وَارْ زَّايِي ثڭّْوِيذذْ شَا \add عَاذْ\add*؟“ \x ◘ \xo 57:‏11 \xt إِشا. 42‏:‏14\x*
\b
\m 
\v 12 ”نشّْ أَذْ عَاوْذغْ خْ ثْسڭْذَا نّمْ ذ ثْمڭَّا نّمْ: وَارْ شمْ نفّْعنْ شَا.
\v 13 خْمِي غَا ثْڒَاغِيذْ، أجّْ خنِّي أَڭْرَاوْ نّمْ \add إِ غَارمْ ثسّْمُونذْ\add* أَذْ شمْ إِفكّْ. أَسمِّيضْ أَذْ ثنْ يَاوِي مَارَّا، إِجّْ ن ؤُسُوضِي أَذْ ثنْ إِكْسِي، \add مَاشَا\add* ونِّي غَارِي يَاركّْوَاڒنْ، أَذْ إِوَارْثْ ثَامُّورْثْ ذ وذْرَارْ إِنُو إِقدّْسنْ ذ ثَاسْغَارْثْ.“ \x ◘ \xo 57:‏13 \xt إِزهد. 34‏:‏9\x*
\b
\m 
\v 14 ”أَذْ يِينِي: ’سْڭعّْذمْ، سْڭعّْذمْ \add أَبْرِيذْ\add*، كْسمْ مِينْ إِسّنْقْرَاضنْ زڭْ وبْرِيذْ ن ڒْڭنْسْ إِنُو!‘
\v 15 مَاغَارْ أَمُّو إِ إِقَّارْ ونِّي يُوعْڒَانْ ؤُ ونِّي إِتّْوَاسّْڭعّْذنْ، ونِّي إِزدّْغنْ ذِي ڒبْذَا، ونِّي ؤُمِي قَّارنْ أَقَا أَمْقدَّاسْ \add إِ إِدْجَا\add*: ’نشّْ زدّْغغْ ذِي ڒُوعْڒَا ؤُ ذڭْ وقْذَاسْ ؤُ غَارْ ونِّي ؤُمِي إِتّْوَارْژْ بُوحْبڒْ ؤُ غَارْ ؤُمْوَاضعْ ن بُوحْبڒْ، مَاحنْذْ أَذْ أَرّغْ بُوحْبڒْ ن إِمْوَاضْعنْ ذ وُوڒْ نْ إِنِّي إِتّْوَارْژِينْ غَارْ ثُوذَارْثْ!‘
\v 16 مَاغَارْ نشّْ وَارْ تّمْشُوبُّوشغْ إِ ڒبْذَا ؤُ وَارْ تّڭّغْ أَذْ إِدُّوقّزْ وغْضَابْ إِنُو بْڒَا قطُّو، مِينْزِي \add خنِّي\add* إِڒِي أَذْ يَارْخُو \add كُوڒْ\add* بُوحْبڒْ زِي زَّاثْ ن وُوذمْ إِنُو، ڒعْمُورْ نِّي ڭِّيغْ.“ \x ◘ \xo 57:‏16 \xt إِزهد. 103‏:‏9؛ عبر. 12؛9\x*
\b
\m 
\v 17 ”نشّْ فُّوڭْمغْ خْ ڒْمُوعْصِييّثْ ن مژْرِي نّسْ ذڭْ وَارْبحْ ؤُشَا وْثِيغْ \add ڒْڭنْسْ\add*. نشّْ نُّوفَّارغْ ؤُشَا \add خنِّي\add* إِدُّوقّزْ وغْضَابْ إِنُو. \add مَاشَا\add* ڒْڭنْسْ يُويُورْ، إِذْوڒْ غَارْ وبْرِيذْ ن وُوڒْ نّسْ.“
\b
\m 
\v 18 ”نشّْ ژْرِيغْ إِبْرِيذنْ نّسْ، أَذْ ث سّْڭنْفِيغْ، أَذْ ث سّْقبّْضغْ، أَذْ أَسْ سّْفوّْجغْ ؤُشَا أَذْ أَسْ وْشغْ إِفوَّاجنْ، إِ نتَّا ؤُ إِ يِينِّي إِشضْننْ نّسْ.
\v 19 نشّْ أَذْ د-خڒْقغْ ڒْغِيدْجثْ ن إِينْشِيشنْ نْسنْ. ’ڒهْنَا، ڒهْنَا إِ يِينِّي إِڭّْوجنْ ؤُ إِ يِينِّي يُوذْسنْ‘، إِقَّارْ سِيذِي.
\v 20 مَاشَا إِعفَّاننْ ڭِّينْ أَمْ ڒبْحَارْ إِنّْهوْڒنْ إِ وَارْ إِزمَّارنْ أَذْ يَارْسَا، ؤُشَا أَمَانْ نّسْ إِوْينْ-د أَبَارْيُوضْ ذ ؤُبدْجَاعْ.
\v 21 إِعفَّاننْ وَارْ غَارْ إِدْجِي ڒهْنَا!، إِقَّارْ أَربِّي إِنُو.“ \x ◘ \xo 57:‏21 \xt إِشا. 48‏:‏22\x*
\b
\b
\c 58
\m 
\v 1 ”ڒَْاغَا س جّهْذْ، وَارْ تّْشطَّارْ، أجّْ ثْمِيجَّا نّشْ أَذْ ثْڭعّذْ أَمْ ؤُيِيشّْ ن إِشَارِّي ؤُشَا بَارّحْ إِ ڒْڭنْسْ إِنُو إِعذِّيينْ نْسنْ ؤُ إِ ثَادَّارْثْ ن يَاعْقُوبْ دّْنُوبْ نْسنْ!
\v 2 نِيثْنِي أَرزُّونْ خَافِي أَسّْ خْ وَاسّْ ؤُشَا إِعْجبْ أَسنْ ثُوسّْنَا ن إِبْرِيذنْ إِنُو، أَمشْنَاوْ \add دْجَانْ ذ\add* ڒْڭنْسْ نِّي إِتّڭّنْ ثَاسڭْذَا ؤُ وَارْ إِتّجِّي ڒْحقّْ ن أَربِّي نّسْ. نِيثْنِي تَّارنْ زَّايِي ڒحْكَامَاثْ إِسڭّْذنْ، إِعْجبْ أَسنْ أَذْ د-قَارّْبنْ غَارْ أَربِّي،
\v 3 \add مَاشَا نِيثْنِي قَّارنْ\add*: ’مَايمِّي نْژُومّْ، ؤُشَا شكْ وَارْ ث ثژْرِيذْ؟ \add مَايمِّي\add* نسّشْضَانْ بُوحْبڒْ نّغْ \add أَمْ\add* شكْ وَارْ ذ أَسْ ثْحكَّارذْ؟‘ خْزَارْ، ذڭْ وَاسّْ ن ؤُژُومِّي نْومْ، ثَارِّيمْ مژْرِي ؤُشَا ثْزيَّارمْ أَطَّاسْ مَارَّا إِخدَّامنْ نْومْ.
\v 4 خْزَارْ، أَژُومِّي نْومْ يِيوِي كنِّيوْ غَارْ ؤُمْشُوبّشْ ذ ؤُمنْغِي، غَارْ ثِييِّيثَا س ڒْپُونِييّثْ س ڒقْسَاحثْ. وَارْ تّْژُومّمْ أَمْ ثتّڭّمْ أَسّْ-أَ، مَاحنْذْ أَذْ ثتّْوَاسڒْ ثْمِيجَّا نْومْ ذِي ڒُوعْڒَا!
\v 5 مَا وَا ذ أَژُومِّي نِّي إِخْضَارغْ نشّْ: إِجّْ ن وَاسّْ نِّي ذِي غَا إِعدّبْ بْنَاذمْ ڒعْمَارْ نّسْ، ونِّي خْ إِ غَا إِميّڒْ بْنَاذمْ أَزدْجِيفْ نّسْ أَمْ ؤُغَانِيمْ، ؤُ أَذْ إِسَّارْسْ ثَاخَانْشثْ ن وشْضَانْ ذ يِيغّضْ أَمْ قَامَا نّسْ؟ مَا ثقَّارذْ إِ ؤُيَا أَژُومِّي، مَا أَيَا ذ أَسّْ إِ د-يُوسِينْ خْ ڒْخَاضَارْ إِ سِيذِي؟“\x ◘ \xo 58:‏5 \xt زَاك. 7‏:‏5\x*
\b
\m 
\v 6 ”مَا وَارْ إِدْجِي وَا ذ أَژُومِّي نِّي إِخْضَارغْ: أَفكِّي ن إِشذِّييّنْ ن ڒْغَارْ، أَزعْوَاضْ ن ثسْغُونِينْ ن زَّايْڒثْ، أَنُوفْسڒْ إِ يِينِّي إِتّْوَاحْصَارنْ، أَقَا أَذْ ثكّْسمْ قَاعْ زَّايْڒثْ؟
\v 7 مَا وَارْ إِدْجِي \add وَا ذ أَژُومِّي نِّي إِخْضَارغْ\add*، أَقَا أَذْ ثبْضِيذْ أَغْرُومْ نّشْ أَكْ-ذ ونِّي إِدْجُوزنْ ؤُشَا أَذْ ثسِّيذْفذْ ڒْمُوسَاكِينْ نِّي إِتّْوَاذَارّْشنْ غَارْ ثَادَّارْثْ؟ مَاڒَا شكْ ثژْرِيذْ أَعَارْيَانْ، أَذْ ث ثسّْيَارْضذْ ؤُ وَارْ ثسّْنُوفَارذْ إِخفْ نّشْ زڭْ ونِّي إِدْجَانْ زڭْ ويْسُومْ نّشْ؟ \x ◘ \xo 58:‏7 \xt حِز. 18‏:‏7، 16؛ مت. 25‏:‏35I\x*
\v 8 خنِّي ثَافَاوْثْ نّشْ أَذْ د-ثنْقَارْ أَمْ ثُوفُّوثْ ن ڒْحَاڒْ ؤُشَا أَسْڭنْفِي نّشْ أَذْ د-يَاوضْ ذغْيَا، ثَاسڭْذَا نّشْ أَذْ أَشْ ثِيزْوَارْ ؤُشَا أَعُودْجِي ن سِيذِي أَذْ يِيڒِي ذ أَغزْذِيسْ نّشْ أَنڭَّارُو.“
\b
\m 
\v 9 ”خنِّي أَذْ ثْڒَاغِيذْ ؤُشَا سِيذِي أَذْ خَاكْ د-يَارّْ. أَذْ ثسْغُويذْ غَارْ ثْوِيزَا، \add ؤُشَا خنِّي\add* أَذْ يِينِي نتَّا: ’خْزَارْ، أَقَا أَيِي ذَا!‘ مَاڒَا \add نِيشَانْ\add* ثكّْسذْ زَّايْرثْ زِي ڒْوسْطْ نّشْ، ؤُڒَا ذ أَشيَّارْ س ؤُضَاضْ ذ وَاوَاڒْ أَعفَّانْ،
\v 10 ؤُشَا أَذْ ثَارْزْمذْ ڒعْمَارْ نّشْ إِ ونِّي إِدْجُوژنْ ؤُ أَذْ ثسّْجِّيوْنذْ ڒعْمَارْ إِشضْننْ! \add خنِّي\add* أَذْ د-ثنْقَارْ ثْفَاوْثْ نّشْ ذِي ثَادْجسْثْ ؤُشَا ثُوبَّارْشنْثْ نّشْ أَذْ ثِيڒِي أَمْ طّْيَا ن ؤُزِيڒْ.
\v 11 سِيذِي أَذْ شكْ إِتّْڭوَّاذْ ڒبْذَا ؤُ نتَّا أَذْ إِسّْجِّيونْ ڒعْمَارْ نّشْ ذِي جّْوَايهْ يُوژْغنْ ؤُشَا أَذْ إِسّجْهذْ إِغْسَانْ نّشْ. أَذْ ثْذوْڒذْ أَمْ وحْوِيشْ إِتّْوَاسُّونْ ؤُ أَمْ ڒْعُونْصَارْ إِتَّازّْڒنْ ن وَامَانْ إِ وَارْ تّْغَارَّانْ أَمَانْ نّسْعمَّارْصْ.
\v 12 إِنِّي زَّايكْ \add د-إِفّْغنْ\add* أَذْ عَاوْذنْ أَسْبذِّي إِ ڒْخِيرْبَاثْ ن وشْحَاڒْ ؤُيَا، أَذْعذْڒنْ ذْسُوسَا ن جِّيڒَاثْ إِعْذُونْ ؤُشَا أَذْ أَشْ قَّارنْ: ’ونِّي إِعدّْڒنْ ثَارژِّيثِينْ، ذ ونِّي إِتَّارَّانْ إِزُوبَاقْ أَذْ ذَايْسنْ ؤُيُورنْ!‘ “
\b
\m 
\v 13 ”مَاڒَا \add خنِّي\add* ثْقڒْبذْ أَضَارْ نّشْ خْ \add وَاسّْ ن\add* سّبْثْ، خْ ثَاڭِّيثْ مِينْ ذ أَشْ إِتّعْجِيبنْ ذڭْ وَاسّْ إِنُو إِقدّْسنْ، ؤُشَا أَذْ ثْڒَاغِيذْ إِ \add وَاسّْ ن\add* سّبْثْ: ’طِّيبثْ!‘، إِ مِينْ إِدْجَانْ إِقدّْسنْ إِ سِيذِي: ’أَعُودْجِي!‘، ؤُشَا أَذْ ثْوقَّارذْ \add أَسّْ ن سّبْثْ\add* أَمْ وَارْ ثْضفَّارضْ إِبْرِيذنْ نّشْ، وَارْ ثتّڭِّيذْ مِينْ ذ أَشْ إِتّعْجِيبنْ ؤُ وَارْ ثسِّيوِيڒِيذْ \add غَارْ\add* ثِيزِي \add نّشْ\add*،
\v 14 خنِّي أَذْ ثَافذْ ڒفْرَاحثْ نّشْ ذِي سِيذِي ؤُ نشّْ أَذْ شكْ جّغْ أَذْ ثْنذْهذْ ثِيوَا إِ ڒڭْعُوذِي ن ثمُّورْثْ. أَذْ شكْ سّشّغْ زِي ثسْغَارْثْ ن بَابَاشْ يَاعْقُوبْ، مِينْزِي أَقمُّومْ ن سِيذِي إِسِّيوڒْ.“
\b
\b
\c 59
\s1 أَغِيڒْ ن سِيذِي أَربِّي وَارْ إِدْجِي ذ أَقُوذَاذْ أَڒَامِي وَارْ إِزمَّارْ أَذْ إِفكّْ
\m 
\v 1 ”خْزَارْ، أَفُوسْ ن سِيذِي وَارْ إِدْجِي ذ أَقُوضَاضْ حِيمَا أَذْ إِسّنْجمْ، أَمزُّوغْ نّسْ وَارْ إِدُّوهْشَارْ أَقَا نتَّا وَارْ إِتّسْڒِي، \x ◘ \xo 59:‏1 \xt ڒخْڒ. 11‏:‏23؛ إِشا. 50‏:‏2\x*
\v 2 مَاشَا ڒْمُوعْصِييّثْ نْومْ ذ مِينْ إِتّمْسبْضَانْ جَارْ أَومْ ذ أَربِّي نْومْ، ؤُشَا دّْنُوبْ نْومْ ڒحّْفنْ زَّايْومْ أَغمْبُوبْ نّسْ، أَقَا نتَّا وَارْ \add إِ ذ أَومْ\add* إِتّسْڒِي.
\v 3 مَاغَارْ تّْوَاسّْخمّْجنْ إِفَاسّنْ نْومْ س إِذَامّنْ، إِضوْضَانْ نْومْ س ڒْمُوعْصِييّثْ، إِينْشِيشنْ نْومْ سّْخَارِّيقنْ، إِڒسْ نْومْ إِنْطقْ س مِينْ وَارْ إِحْرِينْ.
\v 4 ؤُڒَا ذ إِجّْ إِسّْمُونَا س ثْسڭْذَا ؤُشَا ؤُڒَا ذ إِجّْ إِتّْوَاشَارّعْ س ڒْحقّْ. مَارَّا نِيثْنِي تّْعمّْذنْ خْ مِينْ إِدْجَانْ بَاطڒْ ؤُشَا قَّارنْ إِخَارِّيقنْ. أَقَا كسِّينْ س دّيْسثْ ن ثُوعفّْنَا ؤُ تَّارْونْ-د ڒْمُوعْصِييّثْ. \x ◘ \xo 59:‏4 \xt أَيُوبْ 15‏:‏35؛ إِزهد. 7‏:‏15\x*
\v 5 حبْضنْ خْ ثْمدْجَاڒِينْ ن ثْڒفْسَا ؤُ زطّنْ أَخْمَاڒْ ن قُونْذْعَا. ونِّي إِشّنْ زِي ثْمدْجَاڒِينْ نْسنْ، أَذْ إِمّثْ، ؤُ خْمِي إِتَّارژَّا إِجّْ إِشْثنْ، ثتّفّغْ-د زَّايسْ إِشْثْ ن ثْفِيغَارْثْ.
\v 6 إِخْمَارنْ نْسنْ وَارْ د-ؤُسِينْ إِ ورُّوضْ ؤُشَا وَارْ زمَّارنْ أَذْ أَرْضنْ إِخفْ نْسنْ س مِينْ ڭِّينْ \add إِفَاسّنْ نْسنْ\add*. مِينْ ڭِّينْ أَقَا ذ ڒخْذَايمْ ن ڒْمُوعْصِييّثْ ؤُڒَا ذ ڒْخذْمثْ ن ڒخْشُونثْ ن إِفَاسّنْ نْسنْ. \x ◘ \xo 59:‏6 \xt أَيُوبْ 8‏:‏14، 15\x*
\v 7 إِضَارنْ نْسنْ تَّازّْڒنْ غَارْ ڒْغَارْ ؤُ نِيثْنِي تّْقدْجِيقنْ مَاحنْذْ أَذْ سِّيزّْڒنْ إِذَامّنْ إِمزْذَاڭنْ. إِخَارِّيصنْ نْسنْ ذ إِخَارِّيصنْ \add شُّورنْ\add* أَكْ-ذ ڒْمُوعْصِييّثْ، أَردّدْجْ ذ ؤُكهّضْ أَقَا أَثنْ خْ إِبْرِيذنْ نْسنْ إِوَاطَانْ. \x ◘ \xo 59:‏7 \xt أَوڒن. 1‏:‏16؛ رُوم. 3‏:‏15\x*
\v 8 أَبْرِيذْ نْ ڒهْنَا وَارْ ث سِّيننْ ؤُ ڒَاثَارَاثْ نْسنْ وَارْ خَاسنْثْ وَالُو ن ڒْحقّْ. نِيثْنِي سّْفَارَّاغنْ إِزُوبَاقْ نْسنْ إِ يِيخفْ نْسنْ، مَارَّا إِنِّي ذَايْسنْ إِڭُّورنْ، وَارْ سِّيننْ ڒهْنَا.“
\b
\m 
\v 9 ”خْ ؤُيَا إِتّْغِيمَا ڒْحقّْ إِڭّْوجْ خَانغْ ؤُ ثَاسڭْذَا وَارْ د أَنغْ د-ثتِّيكّْوِيضْ. نشِّينْ نتّْرَاجَا ثَافَاوْثْ، \add مَاشَا\add* خْزَارْ، أَقَا ذِينْ طّْڒَامْ، نْرَاجَا ثِيسِّيقْثْ ن ثْفَاوْثْ، \add مَاشَا\add* نُويُورْ ذِي ثَادْجسْثْ.
\v 10 نتّْفَافَا أَمْ يِيضَارْغَاڒنْ أَكْ-ذ ڒْحِيضْ ؤُ نتّمْهَافَا \add سَّا غَارْ ذَا\add*، أَخْمِي وَارْ غَارْنغْ دْجِينْثْ ثِيطَّاوِينْ. نْوطَّا ذِي طّْحَا ن ؤُزِيڒْ أَخْمِي ذِي ثْبَامْبَاسْثْ خْ يِينِّي إِدَّارنْ أَخْمِي خْ إِمتَّانْ.
\v 11 نشِّينْ نْزهَّارْ مَارَّا أَمْ دُّوبَاثْ ؤُ نتّْڭرْڭُورْ أَمْ تّْڭرْڭُورنْثْ ثذْبِيرِينْ، نتّْرَاجَا ڒْحقّْ، \add مَاشَا\add* وَارْ د-يُوسِي، \add نتّْرَاجَا\add* أَسنْجمْ، \add مَاشَا\add* إِڭّْوجْ خَانغْ.
\v 12 مَاغَارْ إِعذِّيينْ نّغْ أَطَّاسْ قِيبَاتْشْ شكْ ؤُ دّْنُوبْ نّغْ شهّْذنْ خَانغْ، مِينْزِي إِعذِّيينْ نّغْ أَقَا أَثنْ غَارْنغْ ؤُ ڒْمُوعْصِييَّاثْ نّغْ أَقَا نسّنْ إِ-ثنْثْ:
\v 13 أَعذِّي ذ ؤُخَارّقْ خْ سِيذِي، ؤُشَا أَحيّذْ زِي أَربِّي نّغْ، ڒْهَارْذْ خْ دّدْجْ ذ ؤُغوّغْ، أَحَاوڒْ ذ ؤُسُوفّغْ ن إِخَارِّيقنْ زڭْ وُوڒْ.
\v 14 إِتّْوخَّارْ ڒْحقّْ غَارْ ضفَّارْ، ؤُشَا ثتّْغِيمَا ثْسڭْذَا غَارْ ڒَاڭّْوَاجْ، مَاغَارْ ثِيذتّْ ثنّذْرفْ ذڭْ وَازَّايْ ؤُشَا مِينْ إِسڭّْمنْ وَارْ إِزمَّارْ أَذْ د-يَاذفْ.
\v 15 ثْبطّڒْ ثِيذتّْ ؤُ ونِّي إِحيّْذنْ خْ ثُوعفّْنَا إِذْوڒْ ذ ثَاكشَّاضْثْ. أَيَا إِژْرَا إِ-ث سِيذِي ؤُشَا ثُوغَا-ث ذ أَعفَّانْ ذِي ثِيطَّاوِينْ نّسْ أَقَا وَارْ ذِينْ إِدْجِي ڒْحقّْ.
\v 16 إِژْرَا أَقَا وَارْ ذِينْ ؤُڒَا ذ إِجّنْ ؤُ نتَّا ثُوغَا إِتّبْهثْ ڒَامِي ؤُڒَا ذ إِجّْ إِكْسِي س ڒْمعْرُوفْ إِ ؤُشفَّاعْ. \add خنِّي\add* يِيوِي ؤُغِيڒْ نّسْ ذ أَسنْجمْ إِ نتَّا ؤُشَا ثَاسڭْذَا نّسْ ثُوغَا ذ أَعمّذْ نّسْ. \x ◘ \xo 59:‏16 \xt إِشا. 63‏:‏5\x*
\v 17 إِسّْيَارْضْ إِخفْ نّسْ ثَاسڭْذَا أَمْ وَارُّوضْ ن وُوزَّاڒْ ؤُشَا إِسَّارْسْ لْكَاسْكْ ن ؤُسنْجمْ خْ ؤُزدْجِيفْ نّسْ. نتَّا يَارْضْ أَرُّوضْ ن وخْڒَافْ ؤُشَا إِڒحّفْ س ثُوسْمِي \add إِقدّْسنْ\add* أَمْ إِڒحّفْ س ؤُسڒْهَامْ. \x ◘ \xo 59:‏17 \xt أَفا. 6‏:‏17؛ 1 تس. 5‏:‏8\x*
\v 18 أَمْ مَامّشْ سْذَاهْدْجنْثْ ثْمڭَّا \add نْسنْ\add*، أَمُّو إِ غَا إِخْڒفْ إِ إِغْرِيمنْ نّسْ س وسْعَارْ، إِ ڒْعذْيَانْ نّسْ مِينْ ذ أَسنْ د-يُوسِينْ. ثِيڭْزِيرِينْ أَذْ ثنْثْ إِوْشْ ڒخْڒفْ نْسنْثْ إِ إِسْذَاحْدْجنْ.“
\b
\m 
\v 19 ”\add خنِّي\add* أَذْ ڭّْوذنْ زڭْ يِيسمْ ن سِيذِي زِي مَانِيسْ ثْغدْجِي ثْفُوشْثْ، ؤُشَا أَعُودْجِي نّسْ زِي مَانِيسْ د-ثْنقَّارْ ثْفُوشْثْ. مَاغَارْ أَذْ د-يَاسْ أَمْ يغْزَارْ إِحْصَارنْ، أَسمِّيضْ ن سِيذِي أَذْ ث إِعَارْنْ.
\v 20 أَذْ د-يَاسْ ؤُمفْذِي زِي صِيهْيُونْ، إِ يِينِّي إِ غَا إِثُوبنْ زڭْ إِعذِّيينْ \add نْسنْ\add* زِي يَاعْقُوبْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.“ \x ◘ \xo 59:‏20 \xt إِشا. 10‏:‏21، 22؛ رُوم. 11‏:‏26\x*
\b
\m 
\v 21 ”وَا ذ ڒْعَاهْذْ إِنُو أَكِيذْسنْ، إِقَّارْ سِيذِي. أَرُّوحْ إِنُو، ونِّي خَاكْ \add إِدْجَانْ\add*، ذ وَاوَاڒنْ إِنُو نِّي ڭِّيغْ ذڭْ ؤُقمُّومْ نّشْ، وَارْ خَاكْ تّْحيِّيذنْ شَا زڭْ ؤُقمُّومْ نّشْ، وَارْ إِدْجِي زڭْ ؤُقمُّومْ ن ثَارْوَا نّشْ ؤُڒَا زڭْ ؤُقمُّونْ ن ثَارْوَا ن ثَارْوَا نّشْ، زِي ڒخُّو أَڒْ إِ ڒبْذَا، إِقَّارْ سِيذِي.“
\b
\b
\c 60
\s1 أَعُودْجِي ن صِيهْيُونْ ذڭْ وُوسَّانْ إِنڭُّورَا
\m 
\v 1 ”كَّارْ، أڭّْ ثْفَاوْثْ مَاغَارْ ثَافَاوْثْ نّمْ ثُوسَا-د ؤُ أَعُودْجِي ن سِيذِي يَارقّْ ثِيوَا نّمْ.
\v 2 مَاغَارْ خْزَارْ، ثَادْجسْثْ أَذْ ثْذڒْ ثَامُّورْثْ ؤُ أَسيْنُو إِبُّومْبسْ \add أَذْ إِذڒْ\add* شُّوعُوبْ، \add مَاشَا\add* ثِيوَا نّمْ أَذْ إِڭعّذْ سِيذِي ؤُ أَعُودْجِي نّسْ أَذْ د-إِضْهَارْ ثِيوَا نّمْ.
\v 3 ڒڭْنُوسْ أَذْ غَارمْ د-أَسنْ ؤُ إِجدْجِيذنْ غَارْ ثِيسِّيقْثْ ن ڒفْجَارْ نّمْ.“
\b
\m 
\v 4 ”سْڭعّذْ ثِيطَّاوِينْ نّمْ، خْزَارْ ذَا ذ ذِيهَا، خْزَارْ، مَارَّا نِيثْنِي مُوننْ، تَّاسنْ-د غَارمْ. إِحنْجِيرنْ نّمْ أَذْ د-أَسنْ زِي ڒَاڭّْوَاجْ، يسِّيمْ تّْوَاكْسِينْثْ إِ-د خْ ثْمصَّاضِينْ.
\v 5 خنِّي أَذْ ث ثْژَارذْ ؤُ أَذْ ثْسِيقْسِيقذْ ؤُشَا ؤُڒْ نّمْ أَذْ إِنْهزّْ س ؤُوقَّارْ ؤُ أَذْ إِنُّورْزمْ أَطَّاسْ، مَاغَارْ أَڭْڒَا ن ڒبْحَارْ أَذْ إِذْوڒْ غَارمْ، أَفيّشْ ن ڒڭْنُوسْ أَذْ غَارمْ د-يَاسْ. \x ◘ \xo 60:‏5 \xt إِزهد. 34‏:‏6؛ أَسَا. 21‏:‏26\x*
\v 6 إِجّْ ن ؤُبَارُّو ن إِڒغْمَانْ أَذْ شمْ إِذڒْ، إِڒغْمَانْ إِمژْيَاننْ زِي مِيذْيَانْ ذ عِييْفَا. مَارَّا أَذْ د-أَسنْ زِي شَابَا. أَذْ أَوْينْ ؤُرغْ ذ جَّاوِي، ؤُشَا أَذْ بشَّارنْ س وَاوَاڒنْ ن شَّانْ إِ سِيذِي.
\v 7 مَارَّا ؤُدْجِي ن قِيذَارْ أَذْ غَارمْ نّْجَارْونْ. إِشَارِّييّنْ ن نَابَايُوثْ أَذْ إِڒِينْ إِ ثْسخَّارْثْ نّمْ. أَذْ ثنْ سّْڭعّْذنْ س أَرْضَا خْ ؤُعَالْطَارْ إِنُو ؤُ نشّْ أَذْ سّْعُودْجغْ ثَادَّارْثْ ن ؤُعُودْجِي إِنُو س ثِيذتّْ.“
\b
\m 
\v 8 ”مَانْ إِنَا إِنِّي د-إِطَّاونْ غَارْ ذِينِّي أَمْ يِيسيْنُوثنْ، أَمْ ثذْبِيرِينْ غَارْ ڒكْوَازَا نْسنْثْ؟
\v 9 \add وَاهْ،\add* ثِيڭْزِيرِينْ أَذْ أَيِي ڒَاجَانْثْ، ؤُشَا إِغَارُّوبَا ن ثَارْشِيشْ أَذْ إِڒِينْ ذ إِمزْوُورَا مَاحنْذْ أَذْ أَوْينْ إِحنْجِيرنْ نّمْ زِي ڒَاڭّْوَاجْ، أَكْ-ذ نُّوقَارْثْ نْسنْ ذ وُورغْ نْسنْ، إِ يِيسمْ ن سِيذِي، أَربِّي نّمْ، إِ ؤُمْقدَّاسْ ن إِسْرَائِيل، مِينْزِي نتَّا إِسّْعُودْجْ شمْ.
\v 10 إِبَارَّانِييّنْ أَذْ بْنَانْ ڒحْيُوضْ نّمْ ؤُشَا إِجدْجِيذنْ أَذْ أَمْ سخَّارنْ، مَاغَارْ ذڭْ ؤُذُوقّزْ ن وغْضَابْ إِنُو وْثِيغْ شمْ، \add مَاشَا\add* ذِي أَرْضَا إِنُو ثزِّيدْجذْ أَيِي. \x ◘ \xo 60:‏10 \xt إِشا. 49‏:‏23\x*
\v 11 ثِيوُّورَا نّمْ أَذْ قِّيمنْثْ ڒبْذَا أَرْزْمنْثْ. أَسّْ ذ دْجِيڒثْ وَارْ تّْبلِّيعنْثْ مَاحنْذْ أَذْ غَارمْ سِّيذْفنْ أَڭْڒَا ن ڒڭْنُوسْ ؤُشَا أَذْ \add ذِينْ\add* سّْقبّْضنْ ؤُڒَا ذ إِجدْجِيذنْ نْسنْ نِّي د-إِوْينْ.
\v 12 مَاغَارْ ڒْڭنْسْ ذ ثْڭلْذِيثْ نِّي وَارْ تّخْسنْ أَذْ أَمْ سخَّارنْ، أَذْ هلّْكنْ، ؤُشَا ڒڭْنُوسْ \add نِّي\add* أَذْ تّْوَارذْدْجنْ قَاعْ.“
\b
\m 
\v 13 ”أَشُووَّارْ ن لُوبْنَانْ أَذْ غَارمْ د-يَاسْ، ثَاشجَّارْثْ ن ؤُمرْزِي، ثَاشجَّارْثْ ن دُّولْبْ ذ ثْشجَّارْثْ ن ثنْڭلْثْ مُوننْثْ، حِيمَا أَذْ زوّْقنْ أَمْشَانْ ن زَّاوشْثْ إِنُو إِقدّْسنْ، ؤُشَا أَمْشَانْ ن إِضَارنْ إِنُو أَذْ ث سّْعُودْجغْ. \f ◼ \fr 60:‏13 \ft \bd ’ثَاشجَّارْثْ‘\bd* - نِيغْ ’أَدَّاڭْ‘ (’إِدَّاڭنْ‘). \bd ’أَمرْزِي‘\bd* - نِيغْ ’أَمضْزِي‘.\f*
\v 14 إِحنْجِيرنْ ن يِينِّي ثُوغَا شمْ إِحصَّارنْ أَذْ غَارمْ د-أَسنْ س ؤُوَاضعْ، أَذْ أَضَارنْ غَارْ إِضَارنْ نّمْ مَارَّا إِنِّي زَّايمْ إِسْثهْزَانْ، ؤُشَا أَذْ أَمْ ڒَاغَانْ: ’ثَانْذِينْثْ ن سِيذِي، صِيهْيُونْ ن ؤُمْقدَّاسْ ن إِسْرَائِيل‘.“
\b
\m 
\v 15 ”إِ ؤُمِي، أَقَا شمْ ثُوغَا ثخْڒِيذْ ذ ثتّْوَاشَارْهذْ أَڒَامِي ؤُڒَا ذ إِجّْ وَارْ ذ خَامْ إِسِّيجّْ، أَذْ شمْ ڭّغْ ذ ڒْعزّْ إِتّْذُومَانْ ذ \add ڒْعُونْصَارْ ن\add* ڒفْرَاحثْ زِي جِّيڒْ أَڒْ جِّيڒْ. \x ◘ \xo 60:‏15 \xt إِشا. 49‏:‏19؛ 54‏:‏1، 6، 7\x*
\v 16 أَذْ ثطّْضذْ أَغِي ن ڒڭْنُوسْ ؤُ أَذْ ثطّْضذْ غَارْ إِفَّانْ ن إِجدْجِيذنْ. أَذْ ثسّْنذْ أَقَا نشّْ ذ سِيذِي، أَمْسنْجَامْ نّمْ ذ أَمفْذِي نّمْ، أَمْزمَّارْ ن يَاعْقُوبْ.“ \x ◘ \xo 60:‏16 \xt إِشا. 43‏:‏3\x*
\b
\m 
\v 17 ”ذڭْ ومْشَانْ ن نّْحَاسْ أَذْ أَوْيغْ ؤُرغْ، ذڭْ ومْشَانْ ن وُوزَّاڒْ نُّوقَارْثْ، ذڭْ ومْشَانْ ن ؤُكشُّوضْ نّْحَاسْ، ذڭْ ومْشَانْ ن يژْرَا ؤُزَّاڒْ. نشّْ أَذْ ڭّغْ ڒهْنَا ذ إِوقَّافنْ نّمْ ؤُڒَا ذ ثَاسڭْذَا ذ إِمْزيَّارنْ نّمْ.
\v 18 وَارْ سِّيوْڒنْ عَاذْ خْ لْعُونْفْ ذِي ثمُّورْثْ نّمْ، ؤُڒَا خْ وَاردّدْجْ ذ ؤُخَارّبْ ذِي جّْوَايهْ نّمْ. ڒحْيُوضْ نّمْ أَذْ أَسنْ إِنِينْ: ’أَسنْجمْ!‘، ؤُ إِ ثوُّورَا نّمْ: ’ثَاصبِّيحْثْ!‘.
\b
\m 
\v 19 وَارْ ثتِّيڒِي عَاذْ ثْفُوشْثْ ذ ثَافَاوْثْ نّمْ ذڭْ ؤُزِيڒْ ؤُ ثَازِيرِي وَارْ ذ أَمْ ثتِّيشْ عَاذْ ثِيسِّيقْثْ نّسْ، \add مَاشَا\add* سِيذِي أَذْ أَمْ يِيڒِي ذ ثَافَاوْثْ ن ڒبْذَا، ؤُشَا أَربِّي نّمْ أَذْ يِيڒِي ذ ڒهْزُوطْ نّمْ إِشْنَانْ قَاعْ.
\v 20 ثَافُوشْثْ نّمْ وَارْ ثْغدْجِي عَاذْ ؤُ ثَازِيرِي نّمْ وَارْ ثْنقّصْ، مَاغَارْ سِيذِي أَذْ يِيڒِي ذ ثَافَاوْثْ نّمْ ن ڒبْذَا ؤُشَا ؤُسَّانْ ن وشْضَانْ نّمْ أَذْ قْضَانْ.
\v 21 ڒْڭنْسْ نّمْ أَقَا أَثنْ مَارَّا ذ إِمْسڭَّاذنْ، نِيثْنِي أَذْ طّْفنْ ثَامُّورْثْ ذ ڒْوَارْثْ إِ ڒبْذَا: ثَاغدُّوثْ إِ ژُّوغْ، ڒْخذْمثْ ن إِفَاسّنْ إِنُو، أَقَا-ثنْ إِ ڒْعزّْ \add إِنُو\add*! \x ◘ \xo 60:‏21 \xt إِشا. 29‏:‏23؛ 45‏:‏11؛ مت. 15‏:‏13\x*
\v 22 أَمژْيَانْ قَاعْ أَذْ إِذْوڒْ ذ أَڒفْ ؤُ أَمُوقْڒِيڒْ قَاعْ أَذْ إِذْوڒْ ذ ڒْڭنْسْ إِجْهذْ، نشّْ، سِيذِي، أَذْ ث-إِ-د-نذْهغْ ذغْيَا خْمِي د غَا يَاوضْ ڒْحَاڒْ.“
\b
\b
\c 61
\s1 أَسڭّْوَاسْ ن ؤُسْڒِيوْڒوْ إِ سِيذِي
\m 
\v 1 ”أَرُّوحْ ن سِيذِي، سِيذِي، خَافِي مِينْزِي إِذْهنْ أَيِي سِيذِي إِنُو مَاحنْذْ أَذْ أَوْيغْ ڒخْبَارْ أَصبْحَانْ إِ إِمْوَاضْعنْ. نتَّا إِسّكّْ أَيِي-د، مَاحنْذْ أَذْ شفْنغْ إِنِّي ؤُمِي إِتّْوَارْژْ ؤُڒْ نْسنْ، مَاحنْذْ أَذْ بَارّْحغْ س ثْڒلِّي إِ إِمحْبَاسْ ذ ؤُنُوفْسڒْ زِي ڒحْبسْ إِ يِينِّي إِشَارْفنْ، \x ◘ \xo 61:‏1 \xt لك. 4‏:‏17، 18، 19، 20\x*
\v 2 مَاحنْذْ أَذْ بَارّْحغْ أَسڭّْوَاسْ ن أَرْضَا إِ سِيذِي ذ وَاسّْ ن وخْڒَافْ ن أَربِّي نّغْ، مَاحنْذْ أَذْ سّْفوّْجغْ مَارَّا إِنِّي إِشضْننْ، \x ◘ \xo 61:‏2 \xt إِشا. 63‏:‏4\x*
\v 3 مَاحنْذْ أَذْ ڭّغْ إِ يِينِّي إِشضْننْ ذِي صِيهْيُونْ أَقَا أَذْ أَسنْ وْشنْ ڒهْزُوطْ ذڭْ ومْشَانْ ن يِيغّضْ، زّشْثْ ن ڒفْرَاحثْ ذڭْ ومْشَانْ ن وشْضَانْ، أَرُّوضْ ن ؤُسمْغَارْ ذڭْ ومْشَانْ ن بُوحْبڒْ إِتّْوَارْژنْ، حِيمَا أَذْ أَسنْ ڒَاغَانْ ’ثِيشجُّورَا ن يِيڭّْ ن ثْسڭْذَا!‘، ثِينِّي إِتّْوَاژُّونْ زِي سِيذِي، إِ ڒْعزّْ \add نّسْ\add*!“
\b
\m 
\v 4 ”أَذْ سّْبدّنْ ڒْخِيرْبَاثْ ن وشْحَاڒْ ؤُيَا، أَذْعذْڒنْ ڒبْنِييَّاثْ إِهذْمنْ ن \add جِّيڒَاثْ\add* إِ ذ \add أَنغْ\add* إِزْوَارنْ، ؤُشَا أَذْ سّْبدّنْ عَاوذْ ثِيندَّامْ إِخَارّْبنْ نِّي ثُوغَا إِهذْمنْ زِي جِّيڒْ أَڒْ جِّيڒْ \add نّغْنِي\add*. \x ◘ \xo 61:‏4 \xt إِشا. 58‏:‏12\x*
\v 5 إِبَارَّانِييّنْ أَذْ إِڒِينْ وجْذنْ حِيمَا أَذْ أَروْسنْ ؤُدْجِي نْومْ، ؤُشَا إِغْرِيبنْ أَذْ إِڒِينْ ذ إِفدْجَاحنْ نْومْ ذ أَيْثْ ن ثْزَايَارْثْ نْومْ.
\v 6 \add مَاشَا\add* أَذْ كنِّيوْ ڒَاغَانْ ’إِكهَّاننْ ن سِيذِي!‘ ؤُشَا أَذْ أَومْ إِنِينْ ’إِمْسخَّارنْ ن أَربِّي نّغْ!‘. أَذْ ثشّمْ أَڭْڒَا ن ڒڭْنُوسْ ؤُشَا أَذْ ثْفيّْشمْ س ؤُعُودْجِي نْسنْ.\x ◘ \xo 61:‏6 \xt 1 بُط. 2‏:‏5، 9؛ أَسَا. 1‏:‏6؛ 5‏:‏10\x*
\v 7 ذڭْ ومْشَانْ ن ؤُسضْحِي نْومْ، \add أَذْ ذِينْ إِڒِينْثْ\add* ثْنَاينْ ن ثْسقَّارْ، ؤُ \add ذڭْ ومْشَانْ ن\add* ڒفْضِيحثْ، أَذْ سْڒِيوْڒونْ نِيثْنِي خْ ثسْغَارْثْ نْسنْ. س ؤُيَا أَذْ طّْفنْ ثْنَاينْ ن ثْسقَّارْ ذِي ثمُّورْثْ نْسنْ، ڒفْرَاحثْ إِتّْذُومَانْ أَذْ غَارْسنْ ثِيڒِي.
\v 8 مَاغَارْ نشّْ، سِيذِي، تّخْسغْ ڒْحقّْ، شَارّْهغْ ثُوكَّارْضَا س لْعُونْفْ. نشّْ أَذْ أَسنْ وْشغْ ڒْمُونثْ ذِي ڒَامَانْ، أَذْ كِيذْسنْ قّْنغْ إِجّْ ن ڒْعَاهْذْ إِتّْذُومَانْ.
\v 9 زَّارِيعثْ نْسنْ أَذْ ثذْوڒْ ثتّْوَاسّنْ جَارْ ڒڭْنُوسْ ؤُشَا ثَارْوَا نْسنْ ذِي ڒْوسْطْ ن ڒڭْنُوسْ. مَارَّا وِي ثنْ إِ غَا إِژَارنْ، أَذْ قنْعنْ أَقَا إِنَا ذ زَّارِيعثْ إِ إِبَاركْ سِيذِي.“
\b
\m 
\v 10 ”فَارْحغْ أَطَّاسْ ذِي سِيذِي، ڒعْمَارْ إِنُو إِفَارْحْ ذِي أَربِّي إِنُو مِينْزِي نتَّا إِسّْيَارْضْ أَيِي أَرُّوضْ ن ؤُسنْجمْ، ؤُ س ؤُسڒْهَامْ ن ثْسڭْذَا إِ ذ أَيِي إِڒحّفْ، أَمْ مُوڒَايْ إِ إِقّْننْ أَرژّثْ ن ؤُكهَّانْ ؤُ أَمْ ثسْڒِيثْ نِّي إِسّْوجْذنْ إِخفْ نّسْ س ڒهْزُوطْ نّسْ.
\v 11 مَاغَارْ أَمْ ثمُّورْثْ ثتّجَّا أَغمُّويْ نّسْ أَذْ د-إِفّغْ ؤُ أَمْ وحْوِيشْ إِسّْغمَّايْ مِينْ ذَايسْ إِزَارّْعنْ، أَمُّو إِ د إِسّغْمَايْ سِيذِي إِنُو، سِيذِي، ثَاسڭْذَا ذ شَّانْ زَّاثْ \add إِ ثِيطَّاوِينْ\add* ن مَارَّا ڒڭْنُوسْ.“
\b
\b
\c 62
\s1 شْضَارثْ ن سِيذِي إِ يدْجِيسْ ن سِيحْيُونْ
\m 
\v 1 ”ذِي طّْوعْ ن صِيهْيُونْ وَارْ زمَّارغْ أَذْ سّغْذغْ، ذِي طّْوعْ ن ؤُرْشَالِيمْ وَارْ تّسْقِيرِيغْ، أَڒْ د غَا ثنْقَارْ ثْسڭْذَا نّسْ أَمْ ثِيسِّيقْثْ ؤُ أَسنْجمْ نّسْ أَمْ وسْفضْ يَارقّنْ.
\v 2 أَذْ ژَترنْ ڒڭْنُوسْ ثَاسڭْذَا نّمْ ؤُ مَارَّا إِجدْجِيذنْ \add أَذْ ژَترنْ\add* أَعُودْجِي نّمْ. أَذْ أَمْ ڒَاغَانْ س يِيجّْ ن يِيسمْ ن جْذِيذْ نِّي ذ أَمْ إِ غَا إِڭَّا ؤُقمُّومْ ن سِيذِي. \x ◘ \xo 62:‏2 \xt إِشا. 65‏:‏15\x*
\v 3 أَذْ ثِيڒِيذْ ذ تَّاجْ إِشوَّارنْ ذڭْ ؤُفُوسْ ن سِيذِي ؤُڒَا ذ أَرژّثْ إِڭلّْذنْ ذڭْ ؤُفُوسْ ن أَربِّي نّمْ.
\v 4 وَارْ ذ أَمْ قَّارنْ عَاذْ ’ثنِّي ذِي سمْحنْ!‘ ؤُ وَارْ ذ أَسْ قَّارنْ عَاذْ إِ ثمُّورْثْ نّمْ ’ثَامُّورْثْ إِخْڒَانْ!‘، مَاشَا أَذْ أَمْ ڒَاغَانْ ’ڒْخَاضَارْ إِنُو!‘، ؤُ ثَامُّورْثْ نّمْ ’ثَانمْڒَاشْثْ!‘، مَاغَارْ ثُوسِيذْ-د خْ ڒْخَاضَارْ ن سِيذِي ؤُ ثَامُّورْثْ نّمْ أَذْ ثتّْوَامْڒشْ.
\v 5 مَاغَارْ أَمْ ؤُعزْرِي إِمْڒشْ ثَاعْزَارشْثْ، أَمُّو إِ كِيذمْ غَا مڒْشنْ إِحنْجِيرنْ نّمْ، ؤُشَا أَمْ مُوڒَايْ إِفَارّحْ إِ ثسْڒِيثْ، \add أَمُّو\add* إِ ذ أَمْ غَا إِفَارْحْ أَربِّي نّمْ.“
\b
\m 
\v 6 ”\add أَ\add* ؤُرْشَالِيمْ، سّْبدّغْ إِعسَّاسنْ خْ ڒحْيُوضْ نّمْ نِّي وَارْ سّْغِيذِينْ ڒبْذَا، ذڭْ وَاسّْ ذ دْجِيڒثْ. \add أَ\add* كنِّيوْ إِنِّي إِعقّْڒنْ خْ سِيذِي، وَارْ تَّاريّْحمْ!
\v 7 وَارْ تَّاريّْحمْ ذِي طّْوعْ نّسْ، أَڒْ د إِسّْبدّْ ؤُرْشَالِيمْ ؤُشَا إِڭَّا إِ-ت ذ أَصبّحْ خْ ثمُّورْثْ.
\v 8 سِيذِي إِجُّودْجْ غَارْ ؤُفُوسْ نّسْ أَفُوسِي ؤُ غَارْ ؤُغِيڒْ نّسْ إِجهْذنْ: ’عمَّارْصْ عَاذْ أَذْ وْشغْ إِمنْذِي نّمْ ذ مَاشَّا إِ ڒْعذْيَانْ نّمْ، ؤُعمَّارْصْ عَاذْ أَذْ سّسْوغْ إِبَارَّانِييّنْ بِينُو نّمْ ن جْذِيذْ إِ خْ ثكْسِيذْ ثَامَارَا!
\v 9 مَاغَارْ وِي ث غَا إِسّْمُوننْ، أَذْ زَّايسْ شّنْ ؤُ أَذْ سّمْغَارنْ سِيذِي، ؤُ وِي غَا إِڒقْضنْ أَضِيڒْ، أَذْ زَّايسْ سْونْ ذِي ڒمْرَاحَاثْ ن زَّاوشْثْ إِنُو إِقدّْسنْ.‘ “
\b
\m 
\v 10 ”عْذُومْ، عْذُومْ زِي ثوُّورَا ؤُشَا سْوجْذمْ إِ ڒْڭنْسْ أَبْرِيذْ. سْڭعّْذمْ، سْڭعّْذمْ أَبْرِيذْ إِوَاطَانْ، كّْسمْ إِژْرَا، سْڭعّْذمْ ثَاعدْجَانْثْ إِ ڒڭْنُوسْ! \x ◘ \xo 62:‏10 \xt إِشا. 40‏:‏3؛ 57‏:‏14\x*
\v 11 خْزَارْ، سِيذِي إِڭَّا أَذْ سْڒنْ أَڒْ طَّارْفْ ن ثمُّورْثْ. إِنِيمْ إِ يدْجِيسْ ن صِيهْيُونْ: ’خْزَارْ، أَسنْجمْ نّمْ يُوسَا-د، خْزَارْ، ڒْمُونثْ نّسْ غَارسْ ؤُشَا ڒخْڒَاصْ نّسْ غَارْ زَّاثسْ.‘
\v 12 أَذْ أَسنْ قَّارنْ: ’ڒْْڭنْسْ أَمْقدَّاسْ، إِنِّي إِتّْوَافكّنْ ن سِيذِي!‘، ؤُشَا أَذْ أَمْ قَّارنْ: ’ثنِّي خْ ثُوغَا أَرزُّونْ!‘ ذ ’ثَانْذِينْثْ إِ وَارْ إِتّْوَاجّنْ!‘.“ \f ◼ \fr 62:‏12 \ft \bd ’إِمفْذِييّنْ‘\bd* - خْزَارْ إِزهد. 78‏:35.\f*
\b
\b
\c 63
\s1 ڒْحُوكْمْ خْ إِذُومْ، ڒعْذُو أَمزْوَارُو ن إِسْرَايِيلْ
\m 
\v 1 ”مِينْ إِعْنَا ونِّي د-يُوسِينْ زِي إِذُومْ، زِي بُوصْرَا، ذڭْ وَارُّوضْ س ؤُزّڭّْوَاغْ يُودْجْڒنْ، إِعُودْجنْ ذڭْ وَارُّوضْ نّسْ، ونِّي إِڭُّورنْ ذِي جّهْذْ نّسْ أَمقّْرَانْ؟“
\m ”ذ نشّْ، ونِّي إِسَّاوَاڒنْ ذِي ثْسڭْذَا، ذ ونِّي إِزمَّارنْ أَذْ إِسّنْجمْ!“
\b
\m 
\v 2 ”مَايمِّي أَرُّوضْ نّشْ ذ أَزڭّْوَاغْ ؤُ \add مَايمِّي\add* أَرُّوضْ نّشْ أَمْ ورُّوضْ ن ونِّي إِعفّْسنْ خْ ثْسِيرْثْ ن ؤُضِيڒْ؟“ \x ◘ \xo 63:‏2 \xt أَسَا. 19‏:‏13\x*
\b
\m 
\v 3 ”نشّْ وحّْذِي ذ ونِّي إِعفْسنْ ثَاسِيرْثْ ن بِينُو ؤُ وَارْ ذِينْ ثُوغِي ؤُڒَا ذ إِجّْ أَكِيذِي زِي ڒڭْنُوسْ.عفْسغْ خَاسنْ ذڭْ وغْضَابْ إِنُو، ڒبْزغْ ثنْ ذڭْ وسْعَارْ إِنُو. إِذَامّنْ نْسنْ رُوشّنْ خْ وَارُّوضْ إِنُو، ؤُشَا سَّارْصُوضنْ مَارَّا أَرُّوضْ إِنُو.
\v 4 مَاغَارْ أَسّْ ن وخْڒَافْ أَقَا-ث غَارِي ذڭْ وُوڒْ، ؤُ يُوسَا-د ؤُسڭّْوَاسْ إِ يِينِّي إِتّْوَافكّنْ س ؤُفُوسْ إِنُو.“ \f ◼ \fr 63:‏4 \ft \bd ’إِمفْذِييّنْ‘\bd* - خْزَارْ إِزهد. 78‏:35.\f*  \x ◘ \xo 63:‏4 \xt إِشا. 61‏:‏2 \x*
\b
\m 
\v 5 ”نشّْ خْزَارغْ \add أَمُّو ذ وَامُّو\add*، مَاشَا وَارْ \add ذِينْ\add* ثُوغِي ؤُڒَا ذ إِجّْ إِ ذ أَيِي إِوْشِينْ أَفُوسْ. نشّْ ثُوغَا تّْبهْثغْ، مِينْزِي ؤُڒَا ذ إِجّنْ وَارْ كِيذِي إِبدّْ. \add ؤُفِيغْ\add* مْغِيرْ أَغِيڒْ إِنُو إِ ذ أَيِي إِسّْنجْمنْ ؤُشَا أَسْعَارْ إِنُو ثُوغَا ذ أَعمّذْ إِنُو. \x ◘ \xo 63:‏5 \xt إِشا. 59‏:‏16\x*
\v 6 نشّْعفْسغْ خْ ڒڭْنُوسْ ذڭْ وغْضَابْ إِنُو، نشّْ سّسْشَارغْ ثنْ ذڭْ وسْعَارْ إِنُو ؤُشَا ڭِّيغْ إِذَامّنْ نْسنْ تَّازّْڒنْ غَارْ ثمُّورْثْ.“
\b
\s1 أَسمْغَارْ ذ ثْكسِّيثْ س ڒْمعْرُوفْ زَّاثْ إِ أَربِّي
\m 
\v 7 ”نشّْ خْسغْ أَذْ إِذَارغْ ثِيمڭَّا ن ثْمخْسِيوْثْ ن سِيذِي، ثِيمڭَّا إِصبْحنْ ن سِيذِي، مَارَّا مِينْ إِ ذ أَنغْ إِڭَّا سِيذِي، ؤُڒَا ذ ڒْخِيرْ أَمقّْرَانْ إِ إِسّْشنْ إِ ثَادَّارْثْ ن إِسْرَائِيل عْلَاحْسَابْ أَرّحْمثْ نّسْ ذ ڒمْغَارثْ ن ثْمخْسِيوْثْ نّسْ إِشوَّارنْ.
\v 8 نتَّا إِنَّا: ’نِيثْنِي ذ ڒْڭنْسْ إِنُو، إِحنْجِيرنْ نِّي وَارْ إِسّْخَارِّيقنْ!“ ؤُشَا نتَّا إِذْوڒْ ذ أَمْسنْجمْ إِ نِيثْنِي.
\v 9 ذِي مَارَّا ڒحْصَارثْ نْسنْ ثُوغَا ؤُڒَا ذ نتَّا إِتّْوَاحْصَارْ، ؤُشَا لْمَالَاكْ ن وُوذمْ نّسْ إِسّنْجمْ إِ-ثنْ. ذِي ثَايْرِي نّسْ ذ أَرْضَا نّسْ إِفكّْ إِ-ثنْ. نتَّا إِسّْڭعّذْ إِ-ثنْ ؤُشَا يَارْبُو ثنْ ذِي مَارَّا ؤُسَّانْ ن وشْحَاڒْ ؤُيَا.“ \x ◘ \xo 63:‏9 \xt أَعَوذ. 7‏:‏7، 8، 9\x*
\b
\m 
\v 10 ”نِيثْنِي \add مَاشَا\add*غوّْغنْ ؤُشَا سّْشضْننْ أَرُّوحْ إِقدّْسنْ نّسْ. \add خَاسْ ؤُشَا\add* إِذْوڒْ أَسنْ ذ ڒعْذُو إِ نِيثْنِي، إِمّْنغْ أَكِيذْسنْ. \x ◘ \xo 63:‏10 \xt ڒخْڒ. 14‏:‏11؛ إِزهد. 78‏:‏57؛ 95‏:‏9‏-‏11\x*
\v 11 \add وَاخَّا أَمنِّي\add* إِعْقڒْ خْ وُوسَّانْ ن زّْمَانَاثْ ن وشْحَاڒْ ؤُيَا، خْ مُوسَا ذ ڒْڭنْسْ نّسْ. مَانِي إِدْجَا ونِّي ذ أَسنْ د-إِسّْڭعّْذنْ زِي ڒبْحَارْ أَكْ-ذ إِمكْسَاونْ ن وُودْجِي نّسْ؟ مَانِي إِدْجَا ونِّي إِڭِّينْ أَرُّوحْ نّسْ إِقدّْسنْ ذِي ڒْوسْطْ نْسنْ، \f ◼ \fr 63:‏11 \ft \bd ’إِمكْسَاونْ‘\bd* - نِيغْ ’إِنِيتْشَانْ‘.\f*
\v 12 ونِّي إِڭِّينْ أَفُوسْ نّسْ إِتّْسقْسِيقنْ أَطَّاسْ أَذْ يُويُورْ أَكْ-ذ مُوسَا، ونِّي إِبْضَانْ أَمَانْ زَّاثْ إِ ثِيطَّاوِينْ نْسنْ حِيمَا أَذْ د-يَاوِي إِ يِيخفْ نّسْ إِسمْ إِ ڒبْذَا، \f ◼ \fr 63:‏12 \ft \bd ’زَّاثْ إِ ثِيطَّاوِينْ نْسنْ‘\bd* - س ثْعِيبْرَانِيثْ ’زَّاثْ إِ وُوذْمَاونْ نْسنْ‘.\f*
\v 13 ونِّي ثنْ إِنذْهنْ ذڭْ \add وَامَانْ\add* إِنّْهوْڒنْ؟ أَمْ ؤُيِيسْ ذِي ڒخْڒَا وَارْ نّْقَارْضنْ شَا، \x ◘ \xo 63:‏13 \xt إِزهد. 105‏:‏37\x*
\v 14 أَمْ ڒْمَاڒْ نِّي د-إِهكّْوَانْ ذِي ثغْزُورْثْ، \add أَمُّو\add* إِ إِسَّاريّحْ إِ-ثنْ أَرُّوحْ ن سِيذِي، أَمُّو ثْنذْهذْ ڒْڭنْسْ نّشْ مَاحنْذْ أَذْ د-ثَاوْيذْ إِ يِيخفْ نّشْ إِجّْ ن إِسمْ إِتّْسقْسِيقنْ أَطَّاسْ.“
\b
\m 
\v 15 ”سِيجّْ زڭْ ؤُجنَّا، ؤُ وَاڒَا زِي ثْزذِّيغْثْ \add نّشْ\add* \add ثشُّورْ س\add* ثَامْقدَّاسْثْ نّشْ ذ ثسِّيقْثْ نّشْ! مَانِي ثدْجَا ثُوسْمِي نّشْ \add إِقدّْسنْ\add* ؤُ \add مَانِي دْجَانْثْ\add* ثْمڭَّا نّشْ إِجهْذنْ؟ ثسِّيڭّْوجذْ خَافِي ڒهْنُونشْثْ نّشْ ذ أَرّحْمثْ نّشْ. \x ◘ \xo 63:‏15 \xt أَعَوذ. 26‏:‏15\x*
\v 16 أَقَا شكْ ذ بَابَاثْنغْ، مَاغَارْ إِبْرَاهِيمْ وَارْ ذ أَنغْ إِسِّينْ ؤُشَا ؤُڒَا ذ إِسْرَائِيل وَارْ ذ أَنغْ إِسِّينْ. شكْ، \add أَ\add* سِيذِي، ذ بَابَاثْنغْ، أَمفْذِي نّغْ، إِسمْ نّشْ أَقَا-ث زِي ڒبْذَا.
\v 17 \add أَ\add* سِيذِي، مَايمِّي إِ ذ أَنغْ ثجِّيذْ نتّفّغْ زڭْ إِبْرِيذنْ نّشْ، مَايمِّي ثسّقْسحذْ ؤُڒْ نّغْ أَڒَامِي وَارْ شكْ نڭّْوذْ؟ ذْوڒْ-د ذِي طّْوعْ ن إِمْسخَّارنْ نّشْ، \add ذِي طّْوعْ ن\add* ثْقبَّاڒْ ن ثسْغَارْثْ نّشْ.
\v 18 ڒْڭنْسْ نّشْ إِطّفْ إِ-ت ذ ڒْوَارْثْ مْغِيرْ شْوَايْثْ ن ڒْوقْثْ. إِغْرِيمنْ نّغْعفْسنْ خْ زَّاوشْثْ نّشْ إِقدّْسنْ. \x ◘ \xo 63:‏18 \xt إِزهد. 74‏:‏7\x*
\v 19 أَقَا نذْوڒْ أَمْ يِينِّي إِ وَارْ خْ ثْحكْمذْ زِي زّْمَانَاثْ ن وشْحَاڒْ ؤُيَا ؤُ إِ خْ وَارْ إِتّْوَاڒَاغَا إِسمْ نّشْ. مْڒِي ثْشَارّْڭذْ إِجنْوَانْ، حِيمَا أَذْ د-ثهْوِيذْ، أَذْ أَرْجِيجنْ إِذُورَارْ زَّاثْ إِ وُوذمْ نّشْ.“
\b
\b
\c 64
\m 
\v 1 ”\add مْڒِي د-ثهْوِيذْ،\add* أَمْ ثِيمسِّي ثسَّارغْ ثِيزْڭِي ؤُ أَمْ ثْمسِّي ثسّْثَارْثَارْ أَمَانْ، مَاحنْذْ أَذْ إِتّْوَاسّْشنْ إِسمْ نّشْ إِ إِغْرِيمنْ نّشْ، حِيمَا أَذْ أَرْجِيجنْ زَّاثكْ ڒڭْنُوسْ،
\v 2 ؤُمِي ثڭِّيذْ ثِيمسْڒَايِينْ إِسَّاڭّْوَاذنْ إِ وَارْ ثنْثْ نْرِيجِيعمَّارْصْ. مْڒِي د-ثهْوِيذْ \add أَڒَامِي\add* أَرْجِيجنْ إِذُورَارْ زَّاثْ إِ وُوذمْ نّشْ.“
\b
\m 
\v 3 ”زڭْ وشْحَاڒْ ؤُيَاعمَّارْصْ وَارْ \add ث\add* سْڒِينْ، ڒَا ذ أَمزُّوغْ وَارْ \add ث\add* إِسْڒِي، ؤُڒَا ذ ثِيطّْ وَارْ \add ث\add* ثژْرِي، أَقَا إِجّْ ن أَربِّي نّغْنِي نْهْڒَا شكْ، ونِّي إِتّڭّنْ شَا ذِي طّْوعْ ن يِينِّي خَاسْ إِتّْرَاجَانْ. \x ◘ \xo 64:‏3 \xt إِزهد. 31‏:‏19، 20؛ 1 كُور. 2‏:‏9\x*
\v 4 ونِّي إِفَارّْحنْ زِي ثْسڭْذَا ؤُشَا أَذْ زَّايسْ يڭّْ، أَذْ ث ثڒْقِيذْ شكْ، إِنِّي خَاكْ إِتّعْقِيڒنْ ذڭْ إِبْرِيذنْ نّشْ. خْزَارْ، ثفُّوڭْمذْ، \add مِينْزِي\add* نشِّينْ نخْضَا. نڭَّا إِ-ث \add عَاذْ\add* ڒبْذَا، مَا \add خنِّي\add* أَذْ نجْمنْ؟
\v 5 نشِّينْ مَارَّا أَمْ ؤُمخْمُوجْ، مَارَّا ڒْمُوعْصِييّثْ نّغْ أَمْ وَارُّوضْ إِخدْجْضنْ ذڭْ إِذَامّنْ، نشِّينْ مَارَّا أَمْ ثْفَارْثْ نِيسّْڒَاوْ، ؤُشَا ڒْمُوعْصِييّثْ نّغْ ثْكسِّي أَنغْ أَمْ ؤُسمِّيضْ. \x ◘ \xo 64:‏5 \xt إِزهد. 90‏:‏5، 6\x*
\v 6 ؤُڒَا ذ إِجّْ وَارْ إِتّْڒِيغِي إِسمْ نّشْ، \add ؤُڒَا ذ إِجّْ\add* إِتّكَّارْ حِيمَا أَذْ ذَايكْ إِطّفْ، مَاغَارْ شكْ ثسّْنُوفَّارذْ أَغمْبُوبْ نّشْ خَانغْ ؤُشَا ثجِّيذْ أَنغْ أَذْ نْغَارْقْ ذڭْ ؤُفُوسْ ن ڒْمُوعْصِييّثْ نّغْ.
\v 7 \add مَاشَا\add* ڒخُّو، \add أَ\add* سِيذِي، شكْ ذ بَابَاثْنغْ، نشِّينْ ذ ثْڒَاخْثْ ؤُ شكْ ذ بُو-ثْڒَاخْثْ نّغْ، نشِّينْ مَارَّا ذ ڒْخذْمثْ ن إِفَاسّنْ نّشْ.
\v 8 \add أَ\add* سِيذِي، وَارْ ثڭِّيذْ أَذْ إِدُّوقّزْ وغْضَابْ نّشْ أَمُّو أَطَّاسْ ؤُ وَارْ تِّيذَارْ إِ ڒبْذَا ڒْمُوعْصِييّثْ. أَقَا ذَا، خْزَارْ، نشِّينْ مَارَّا ذ ڒْڭنْسْ نّشْ. \x ◘ \xo 64:‏8 \xt إِزهد. 79‏:‏8\x*
\v 9 ثِيندَّامْ نّشْ ثِيمْقدَّاسِينْ ذوْڒنْثْ ذ ڒخْڒَا، صِيهْيُونْ ثذْوڒْ ذ ثَانزْرُوفْثْ، ؤُرْشَالِيمْ ذ أَمْشَانْ إِتّْوَاردّْدْجنْ.
\v 10 ثَادَّارْثْ نّغْ ثشُّورْ س ثمْقدَّاسْثْ ذ ثِيسِّيقْثْ، مَانِي ڒجْذُوذْ نّغْ سّمْغَارنْ شكْ، ثتّْوَاشْمضْ س ثْمسِّي ؤُ مَارَّا مِينْ خَانغْ إِعِيزّنْ، إِذْوڒْ ذ ڒْخِيرْبثْ.
\v 11 مَا ثْزمَّارذْ أَذْ ثْمنْعذْ إِخفْ نّشْ ذِي قَاعْ أَيَا، \add أَ\add* سِيذِي، مَا ثْزمَّارذْ أَذْ ثسّغْذذْ ؤُ أَذْ أَنغْ ثحْصَارذْ أَمُّو أَطَّاسْ؟“
\b
\b
\c 65
\s1 ڒْحُوكْمْ ذ ؤُسنْجمْ إِ ڒْڭنْسْ ن أَربِّي خْ وذْرَارْ ن سِيحْيُونْ
\m 
\v 1 ”ثُوغَا تّْبَانغْ أَسنْ-د إِ يِينِّي وَارْ خَافِي سّقْسِينْ، زمَّارنْ أَذْ أَيِي أَفنْ إِنِّي وَارْ خَافِي يَارزُّونْ. نشّْ نِّيغْ إِ ڒْڭنْسْ إِ وَارْ إِڒِيغِينْ س يِيسمْ إِنُو: ’أَقَا أَيِي ذَا، خْزَارْ، أَقَا أَيِي ذَا!‘
\v 2 أَسّْ مَارَّا سّْوِيژَّاضغْ إِفَاسّنْ إِنُو غَارْ ڒْڭنْسْ إِغوّْغنْ، ونِّي يُويُورنْ ذڭْ إِجّْ ن وبْرِيذْ وَارْ إِحْڒِينْ، خْ ڒحْسَابْ إِخَارِّيصنْ نّسْ،
\v 3 ڒْڭنْسْ نِّي ذ أَيِي إِسعَّارنْ ڒبْذَا ذڭْ وُوذمْ إِنُو، أَمْ قدّْمنْ ثِيغَارْصَا ذهْ إِحْوِيشنْ ؤُ بخَّارنْ \add ثِيوْهِيبِينْ\add* خْ لَّاجُورْ.
\v 4 نِيثْنِي تّْغِيمَانْ ذڭْ إِمضْڒَانْ، ؤُ تّْنُوسَانْ ذڭْ إِفْرَانْ أَمْ تّتّنْ أَيْسُومْ ن إِڒْفَانْ ؤُ غَارْسنْ إِجّْ ن نّْعِي ن أَرّْوَا ذِي مَارْمِيثَاثْ نْسنْ. \x ◘ \xo 65:‏4 \xt إِشا. 66‏:‏17\x*
\v 5 نِيثْنِي قَّارنْ: ’قِّيمْ مَانِي ثدْجِيذْ، وَارْ ذ أَيِي د-ثَاذسْ، مَاغَارْ نشّْ ذ أَمْقدّسْ زَّايكْ!‘ أَقَا أَثنْ \add أَمْ\add* دّخَّانْ ذڭْ ونْزَارنْ إِنُو، \add أَمْ\add* ثْمسِّي يَارقّنْ أَسّْ إِكْمڒْ.
\v 6 خْزَارْ، أَيَا يُورَا زَّاثْ إِ وُوذمْ إِنُو، وَارْ سّْغِيذِيغْ، مَاشَا أَذْ خڒْفغْ، \add وَاهْ،\add* أَذْ خڒْفغْ \add أَيَا\add* ذڭْ وحْسِينْ نْسنْ: \f ◼ \fr 65:‏6 \ft \bd ’أَحْسِينْ‘\bd* - نِيغْ ’أَبحْرُورْ‘.\f*
\v 7 ڒْمُوعْصِييَّاثْ نْومْ ذ ڒْمُوعْصِييَّاثْ ن إِبَابَاثنْ نْومْ، إِنِّي وهّْبنْ ڒبْخُورْ خْ إِذُورَارْ ؤُ إِنِّي ذ أَيِي إِسّحْقَارنْ خْ ثوْرِيرِينْ. نشّْ سِيمَانْثْ إِنُو أَذْ أَسنْ خدْجْصغْ ڒْمُونثْ نْسنْ إِ سْذَاهْدْجنْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.“
\b
\m 
\v 8 ”أَمُّو إِ إِقَّارْ سِيذِي: ’أَمْ مَامّشْ ؤُمِي ؤُفِينْ أَژمِّي ن ؤُضِيڒْ ذڭْ ؤُزكُّونْ ؤُشَا قَّارنْ: وَارْ ث جَارّحْ، مَاغَارْ ذَايسْ لْبَارَاكَا!، أَمُّو إِ غَا ڭّغْ ذِي طّْوعْ ن إِمْسخَّارنْ إِنُو، حِيمَا وَارْ ثنْ قطِّيغْ مَارَّا.
\v 9 نشّْ أَذْ د-جّغْ زَّارِيعثْ زِي يَاعْقُوبْ ؤُ أَذْ سُّوفّْغغْ أَوْرِيثْ ن إِذُورَارْ إِنُو زِي يَاهُوذَا. إِنِّي زَّايِي إِتّْوَافَارْزنْ أَذْ ت طّْفنْ ذ ثَاسْغَارْثْ ؤُشَا إِمْسخَّارنْ إِنُو أَذْ ذِينِّي زذْغنْ.
\v 10 ڒوْضَا ن شَارُونْ أَذْ يِيڒِي ذ ثَاكسَّاوْثْ ن وُودْجِي، ؤُ ثَاغْزُورْثْ ن أَخُورْ ذ أَمْشَانْ ن أَرَّاحثْ إِ إِفُونَاسنْ، إِ ڒْڭنْسْ إِنُو ونِّي خَافِي يَارزُّونْ.“
\b
\m 
\v 11 ”كنِّيوْ مَاشَا إِنِّي إِسمْحنْ ذِي سِيذِي، إِنِّي إِتُّونْ أَذْرَارْ إِنُو إِقدّْسنْ، إِنِّي إِسّْوجْذنْ طَّابْڒَا إِ جَاذْ ؤُ إِنِّي إِشُّورنْ \add أَغَارَّافْ س\add* بِينُو إِخدْجْضنْ إِ مِينِي،
\v 12 نشّْ أَذْ كنِّيوْ حسْبغْ إِ سِّيفْ. كنِّيوْ أَذْ ثَاضَارمْ مَارَّا مَاحنْذْ أَذْ تّْوَاغَارْصمْ، ؤُمِي نشّْ إِ ذ أَومْ ڒَاغِيغْ، \add مَاشَا\add* كنِّيوْ وَارْ \add خَافِي\add* د-ثَارِّيمْ، \add ؤُمِي\add* نشّْ غَارْومْ سِّيوْڒغْ، \add مَاشَا\add* كنِّيوْ وَارْ \add غَارِي\add* ثسْڒِيمْ، مَاشَا ثڭِّيمْ مِينْ إِدْجَانْ ذ أَعفَّانْ ذِي ثِيطَّاوِينْ إِنُو، ؤُ ثِيخْضَارمْ مِينْ وَارْ ذ أَيِي د-يُوسِينْ خْ ڒْخَاضَارْ.“
\b
\m 
\v 13 ”س ؤُيَا، أَمُّو إِ إِقَّارْ سِيذِي إِنُو، سِيذِي: ’خْزَارْ، إِمْسخَّارنْ إِنُو أَذْ شّنْ، \add مَاشَا\add* كنِّيوْ أَذْ ثْدْجَاژمْ. خْزَارْ، إِمْسخَّارنْ إِنُو أَذْ سْونْ، \add مَاشَا\add* كنِّيوْ أَذْ ثفَّاذمْ. خْزَارْ، إِمْسخَّارنْ إِنُو أَذْ فَارْحنْ، \add مَاشَا\add* كنِّيوْ أَذْ ثْسضْحَامْ.
\v 14 خْزَارْ، إِمْسخَّارنْ إِنُو أَذْ سْڒِيوْڒونْ س ڒفْرَاحثْ ن وُوڒْ، \add مَاشَا\add* كنِّيوْ أَذْ ثسْغُويمْ زِي ڒحْرِيقْ ن وُوڒْ، أَذْ ثْوعّْضمْ زِي أَرْژِييّثْ ن بُوحْبڒْ.
\v 15 أَذْ ثجّمْ إِسمْ نْومْ أَمْ نّعْڒثْ إِ يِينِّي زَّايِي إِتّْوَافَارْزنْ، ؤُشَا سِيذِي إِنُو، سِيذِي، أَذْ كنِّيوْ إِنغْ، \add مَاشَا\add* إِمْسخَّارنْ نّسْ أَذْ خَاسنْ إِڒَاغَا س إِجّْ ن يِيسمْ نّغْنِي،
\v 16 أَڒَامِي ونِّي إِخْسنْ أَذْ إِبَاركْ إِخفْ نّسْ ذِي ثمُّورْثْ، أَذْ إِبَاركْ إِخفْ نّسْ ذِي أَربِّي ن ثِيذتّْ، ؤُ ونِّي إِخْسنْ أَذْ إِجُّودْجْ ذِي ثمُّورْثْ، أَذْ إِجُّودْجْ غَارْ أَربِّي ن ثِيذتّْ، مَاغَارْ ڒحْصَارَاثْ ن زِيشْ أَذْ تّْوَاتُّونْثْ ؤُ أَذْ تّْوَاسّْنُوفَّارنْثْ زَّاثْ إِ ثِيطَّاوِينْ إِنُو.‘ “
\b
\m 
\v 17 ”مَاغَارْ خْزَارْ، نشّْ أَذْ ڭّغْ إِجنْوَانْ ن جْذِيذْ ذ ثمُّورْثْ ن جْذِيذْ. وَارْ تّعْقِيڒنْ عَاذْ خْ ثْمسْڒَايِينْ إِعْذُونْ، وَارْ د-تِّيسنْثْ \add عَاذْ\add* إِ ؤُڒَا ذ إِجّْ غَارْ ڒْبَاڒْ.
\v 18 فَارْحمْ خنِّي ؤُ فَارّْجمْ إِ ڒبْذَا خْ مِينْ إِ د غَا خڒْقغْ، مَاغَارْ خْزَارْ، نشّْ أَذْ د-خڒْقغْ ؤُرْشَالِيمْ ذ ڒفْرَاحثْ ؤُ ڒْڭنْسْ نّسْ ذ أَفَارّجْ.
\v 19 نشّْ أَذْ سْڒِيوْڒوغْ خْ ؤُرْشَالِيمْ، أَذْ فَارْحغْ زِي ڒْڭنْسْ إِنُو.عمَّارْصْ عَاذْ أَذْ ذَايسْ سْڒنْ إِ ڒْحسّْ ن إِمطَّاونْ نِيغْ ن ؤُغُويِّي.
\v 20 أَحْضِيضْ إِ غَا إِدَّارنْ شَا ن وُوسَّانْ \add وَاهَا\add*، وَارْ إِتِّيڒِي عَاذْ، ؤُڒَا ذ أَوسَّارْ نِّي وَارْ إِتّْكمِّيڒنْ ؤُسَّانْ نّسْ. مَاغَارْ أَحُوضْرِي أَذْ إِمّثْ خْمِي غَارسْ غَا يِيڒِي مْيَا ن إِسڭّْوُوسَا، ؤُ أَمذْنُوبْ أَذْ إِتّْوَانْعڒْ خْمِي غَارسْ غَا يِيڒِي مْيَا ن إِسڭّْوُوسَا.
\v 21 نِيثْنِي أَذْ بْنَانْ ثُوذْرِينْ أَذْ ذَايْسنْثْ زذْغنْ، أَذْ ژُّونْ ثِيزَايَارِينْ ذڭْ إِمَارْجَاعنْ، أَذْ شّنْ ڒْغِيدْجثْ نْسنْ.
\v 22 نِيثْنِي وَارْ بنِّينْ \add مَاحنْذْ\add* ونّغْنِي أَذْ \add ذَايسْ\add* إِزْذغْ، وَارْ تّژُّونْ \add مَاحنْذْ\add* ونّغْنِي أَذْ \add زَّايسْ\add* يشّْ، مَاغَارْ ؤُسَّانْ ن ڒْڭنْسْ إِنُو أَذْ إِڒِينْ أَمْ وُوسَّانْ ن ثْشجَّارْثْ، ؤُ إِنِّي زَّايِي إِتّْوَافَارْزنْ أَذْ أَوْينْ أَرِيقِّي زِي ڒْخذْمثْ ن إِفَاسّنْ نْسنْ. \f ◼ \fr 65:‏22 \ft \bd ’ثَاشجَّارْثْ‘\bd* - نِيغْ ’أَدَّاڭْ‘ (’إِدَّاڭنْ‘).\f*
\v 23 نِيثْنِي وَارْ خدّْمنْ عَاذْ بَاطڒْ، وَارْ تِّيرْونْ إِحنْجِيرنْ إِ ؤُشڒْوَاوْ س ڒْغفْڒثْ، مَاغَارْ نِيثْنِي ذ زَّارِيعثْ ن يِينِّي إِتّْوَابَارْكنْ زِي سِيذِي، ؤُڒَا ذ ثَارَّاوْثْ نْسنْ أَكِيذْسنْ.
\v 24 قْبڒْ مَا أَذْ ڒَاغَانْ، أَذْ \add خَاسنْ\add* د-أَرّغْ، خْوَانْسُو عَاذْ سَّاوَاڒنْ، أَذْ \add أَسنْ\add* سْڒغْ.
\v 25 ؤُشّنْ ذ إِزْمَارْ أَذْ أَروْسنْ مُوننْ، أَيْرَاذْ أَذْ إِشّْ ڒُومْ أَمْ ؤُفُونَاسْ، ؤُشَا أَفَارْ أَذْ يِيڒِي ذ مَاشَّا إِ ؤُفِيغَارْ. وَارْ تّڭّنْ ثُوعفّْنَا ؤُ وَارْ سّكَّارنْ ڒقْجَارثْ خْ مَارَّا أَذْرَارْ إِنُو إِقدّْسنْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.“ \x ◘ \xo 65:‏25 \xt إِشا. 11‏:‏6، 7، 8، 9؛ مت. 18‏:‏3\x*
\b
\b
\c 66
\s1 سِيذِي ذ ڒْقَاضِي أَذْ إِحْكمْ زِي زَّاوشْثْ إِقدّْسنْ
\m 
\v 1 ”أَمُّو إِ إِقَّارْ سِيذِي: ’أَجنَّا ذ ڒْعَارْشْ إِنُو ؤُ ثَامُّورْثْ ذ ثَانبْذَاثْ إِ إِضَارنْ إِنُو. مَانِي \add إِ غَا ثِيڒِي\add* خنِّي ثَادَّارْثْ نِّي ثخْسمْ أَذْ أَيِي ثبْنَامْ ؤُ مَانِي \add إِ غَا يِيڒِي\add* ومْشَانْ ن أَرَّاحثْ إِنُو؟ \x ◘ \xo 66:‏1 \xt 1 إِج. 8‏:‏27؛ 2 إِم. 6‏:‏18؛ ڒخ. 7‏:‏48،49؛ 17‏:‏24\x*
\v 2 مَارَّا أَيَا إِڭَّا إِ-ث ؤُفُوسْ إِنُو ذ مَارَّا أَيَا ثُوغَا إِدْجَا عَاذْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي، \add مَاشَا\add* نشّْ أَذْ نْضَارغْ ثِيطَّاوِينْ إِنُو خْ ؤُمزْڒُوضْ، خْ ونِّي إِتّْوَارْژَانْ بُوحْبڒْ نّسْ ؤُ خْ ونِّي إِتَّارْجِيجِينْ زَّاثْ إِ وَاوَاڒْ إِنُو.‘ “
\b
\m 
\v 3 ”ونِّي إِغَارْصنْ إِ ؤُفُونَاسْ، إِنْغَا \add ؤُڒَا ذ\add* أَرْيَازْ، ؤُ ونِّي يِيوْينْ إِجّنْ زڭْ وُودْجِي ذ دّْبِيحثْ، يَارْژَا \add عَاوذْ\add* إِرِي إِ يِيطَانْ، ؤُ ونِّي إِقدّْمنْ ثَاوْهِيبْثْ \add ن ڒْغِيدْجثْ\add*، \add إِقدّمْ\add* \add ؤُڒَا ذ\add* إِذَامّنْ ن يِيڒفْ، ؤُ ونِّي إِسّْبخَّارنْ جَّاوِي، إِبَاركْ \add ؤُڒَا ذ\add* أَعْبذْ ن ڒخْيَاڒَاثْ. نِيثْنِي إِخْضَارنْ إِبْرِيذنْ \add إِ يِيخفْ نْسنْ\add* ؤُشَا ڒعْمَارْ نْسنْ إِعْجبْ أَسْ نّْعَاوَاثْ نْسنْ ن لْ-أَصْنَامْ.
\v 4 أَمُّو إِ غَا أَرشّْحغْ ؤُڒَا ذ نشّْ ثِييِّيثَا نْسنْ إِ نِيثْنِي ؤُشَا أَذْ خَاسنْ أَوْيغْ مِينْ زِي تّڭّْوذنْ، مَاغَارْ نِيثْنِي وَارْ د-أَرِّينْ ؤُمِي نشّْ ذ أَسنْ ڒَاغِيغْ، \add مَاغَارْ\add* نِيثْنِي وَارْ سْڒِينْ ؤُمِي غَارْسنْ سِّيوْڒغْ، \add مَاشَا\add* نِيثْنِي ڭِّينْ مِينْ إِدْجَانْ ذ أَعفَّانْ ذِي ثِيطَّاوِينْ إِنُو ؤُشَا إِخْضَارنْ مِينْ وَارْ د-يُوسِينْ خْ ڒْخَاضَارْ إِنُو.“ \x ◘ \xo 66:‏4 \xt أَوڒن. 1‏:‏24؛ إِشا. 65‏:‏12؛ إِرْم. 7‏:‏13\x*
\b
\m 
\v 5 ”سْڒمْ إِ وَاوَاڒْ ن سِيذِي، \add أَ كنِّيوْ\add* إِنِّي إِتَّارْجِيجِينْ زَّاثْ إِ وَاوَاڒْ نّسْ: ’أَيْثْمَاثْومْ، إِنِّي كنِّيوْ إِشَارّْهنْ، إِنِّي كنِّيوْ إِنْضَارنْ ذِي طّْوعْ ن يِيسمْ إِنُو ؤُشَا قَّارنْ: إِڒِي أَذْ إِتّْوَاسّْعُودْجْ سِيذِي، سْشنْ أَنغْ ڒفْرَاحثْ نْومْ!، أَذْ سضْحَانْ. \x ◘ \xo 66:‏5 \xt إِشا. 5‏:‏19\x*
\v 6 أَذْ د-إِفّغْ دّْرِيزْ إِمْغَارْ زِي ثنْذِينْثْ، ثْمِيجَّا زِي زَّاوشْثْ ثَامقّْرَانْثْ، ثْمِيجَّا ن سِيذِي، ونِّي إِ غَا إِخدْجْصنْ ڒْعذْيَانْ نّسْ ڒْمُونثْ نْسنْ إِ إِسْذَاهدْجنْ.‘ “ \x ◘ \xo 66:‏6 \xt أَسَا.16‏:‏1، 17. \x*
\b
\s1 أَخْڒَاقْ إِ إِسّْثبْهْثنْ ن ثَارْوَا ن سِيحْيُونْ
\m 
\v 7 ”قْبڒْ إِ غَا إِطّفْ ڒحْرِيقْ ن ثَارْوَا \add إِ ثمْغَارْثْ صِيهْيُونْ\add*، أَقَا ثُورُووْ-د، قْبڒْ إِ ت غَا منْعنْ ڒوْجعْ ن ثَارُوثْ، ثڭَّا \add أَحنْجِيرْ\add* ذ أَوْثمْ أَذْ إِنْجمْ. \x ◘ \xo 66:‏7 \xt أَسَا. 12‏:‏1‏-‏6\x*
\v 8 وِي إِسْڒَانْ أَيَا؟ مَانْ ونْ إِ إِژْرِينْ أَيَا؟ مَا أَذْ د-ثخْڒقْ إِشْثْ ن ثمُّورْثْ ذڭْ إِجّْ ن وَاسّْ \add وَاهَا\add*؟ مَا أَذْ د-إِخْڒقْ إِجّْ ن ڒْڭنْسْ ذڭْ إِشْثْ ن ثشْثِي \add وَاهَا\add*؟ مَاشَا ؤُسِينْ أَسْ-د إِ صِيهْيُونْ ڒوْجعْ ن ثَارُوثْ عَاذْ شْوَايْثْ \add وَاهَا\add*، أَقَا ثُورُووْ-د إِحنْجِيرنْ نّسْ.“
\b
\m 
\v 9 ”مَا أَذْ أَسْ أَرْزْمغْ أَعذِّيسْ نْهْڒَا مَا جِّيغْ \add ت\add* أَذْ ثَارُو؟، إِقَّارْ سِيذِي. مَا نشّْ ونِّي إِسَّارَاونْ \add ثِيمْغَارِينْ\add*، أَذْ \add أَسنْثْ\add* بلّْعغْ \add ثَاعذِّيسْثْ\add*؟إِقَّارْ أَربِّي نّمْ.“
\b
\m 
\v 10 ”فَارْحمْ أَكْ-ذ ؤُرْشَالِيمْ ؤُشَا سْڒِيوْڒِيومْ أَسْ، \add أَ\add* مَارَّا كنِّيوْ إِنِّي ت إِتّخْسنْ. فَارْحمْ زَّايسْ س ؤُسْڒِيوْڒوْ، مَارَّا \add كنِّيوْ\add* إِنِّي ثُوغَا خَاسْ إِشضْننْ،
\v 11 حِيمَا أَذْ ثطّْضمْ، أَذْ ثجِّيوْنمْ زڭْ إِبَّاشْ نّسْ إِشُّورنْ س ؤُفوّجْ، حِيمَا أَذْ ثسْومْ س ثْيَاوَانْثْ ؤُ أَذْ ثَارّمْ مژْرِي زِي مِينْ إِدْجَانْ ذ أَصبْحَانْ قَاعْ ن ؤُعُودْجِي نّسْ!“
\b
\m 
\v 12 ”مَاغَارْ أَمُّو إِ إِقَّارْ سِيذِي: ’خْزَارْ، نشّْ أَذْ أَسْ سِّيزّْڒغْ ڒهْنَا أَمْ يغْزَارْ ؤُ أَعُودْجِي ن ڒڭْنُوسْ أَمْ ثغْزَارْثْ إِحمْڒنْ، حِيمَا كنِّيوْ أَذْ \add زَّايسْ\add* ثطّْضنْ. أَذْ كنِّيوْ أَرْبُونْ خْ ثْمصَّاضِينْ ؤُ أَذْ خَاومْ سّْحِينّْبنْ خْ إِفَادّنْ. \x ◘ \xo 66:‏12 \xt إِشا. 49‏:‏22؛ 60‏:‏4\x*
\v 13 أَمْ إِجّْ ن ورْيَازْ نِّي ثسّْڒهَّا أَسْ يمَّاسْ، أَمُّو كنِّيوْ إِ غَا سّڒْهُوغْ، ذِي ؤُرْشَالِيمْ أَذْ كنِّيوْ سّْفوّْجنْ.
\v 14 أَذْ ثْژَارمْ أَيَا، أَذْ إِفَارْحْ وُوڒْ نْومْ، ؤُ إِغْسَانْ نْومْ أَذْ تّْوَانعْشنْ أَمْ أَرْبِيعْ أَزِيزَا. أَمُّو إِ غَا إِتّْوَاسّنْ ؤُفُوسْ ن سِيذِي غَارْ إِمْسخَّارنْ نّسْ، \add مَاشَا\add* نتَّا أَذْ إِسْخضْ خْ ڒْعذْيَانْ نّسْ.‘ “
\b
\m 
\v 15 ”مِينْزِي، خْزَارْ، أَذْ د-يَاسْ سِيذِي ذِي ثْمسِّي، إِكَارُّوثنْ نّسْ \add أَذْ ڭّنْ\add* أَمْ ثْحَارْيَاضْثْ، حِيمَا أَذْ يجّْ أَغْضَابْ نّسْ أَذْ يَارْسَا س إِجّْ ن ؤُذُوقّزْ ن وسْعَارْ نّسْ ؤُ ثَافْقحْثْ نّسْ س إِحُوذَاقْ ن ثْمسِّي.
\v 16 مَاغَارْ سِيذِي أَذْ إِحْكمْ مَارَّا دَّاثْ س ثْمسِّي ذ سِّيفْ ؤُشَا إِنِّي غَا إِتّْوَانْغنْ زِي سِيذِي أَذْ إِڒِينْ ذڭْ وَاطَّاسْ.
\v 17 \add مَارَّا\add* إِنِّي إِسّْقدّْسنْ ؤُ إِسِّيزْذِيڭنْ إِخفْ نْسنْ ذڭْ إِحْوِيشنْ أَوَارْنِي إِ يِيجّنْ، إِنِّي إِتّتّنْ أَيْسُومْ ن إِڒْفَانْ ؤُڒَا ذ نّْعِي \add ن ڒْمَاڒْ\add* ذْ إِغَارْذَاينْ، أَقَا مَارَّا نِيثْنِي أَذْ تّْوَاقْضَانْ!، \add أَمُّو إِ\add* إِقَّارْ سِيذِي.“ \x ◘ \xo 66:‏17 \xt إِشا. 65‏:‏3، 4؛ حِز. 8‏:‏11، 12\x*
\b
\m 
\v 18 ”نشّْ \add أَذْ خدْجْصغْ\add* ثِيمڭَّا نْسنْ ذ إِخَارِّيصنْ نْسنْ، ؤُشَا أَذْ إِمْسَارْ أَذْ سّْمُونغْ مَارَّا ڒڭْنُوسْ ذ إِڒْسَاونْ ؤُ نِيثْنِي أَذْ د-أَسنْ أَذْ ژَترنْ أَعُودْجِي إِنُو.
\v 19 نشّْ أَذْ ڭّغْ إِشْثْ ن ڒعْڒَامثْ جَارْ أَسنْ ؤُشَا أَذْ سّكّغْ إِنِّي زَّايْسنْ إِنّجْمنْ غَارْ ڒڭْنُوسْ، غَارْ ثَارْشِيشْ، فُوطْ ذ لُوذْ، إِمْجبَّاذنْ ن ڒْقوْسْ، غَارْ ثُوبَالْ ذ يَاوَانْ، غَارْ ثڭْزِيرِينْ إِڭّْوجنْ، ثِينِّي وَارْ إِسْڒِينْ ڒخْبَارْ خَافِي ؤُ وَارْ إِژْرِينْ أَعُودْجِي إِنُو. نِيثْنِي أَذْ بَارّْحنْ أَعُودْجِي إِنُو إِ ڒڭْنُوسْ،
\v 20 أَذْ أَوْينْ أَيْثْمَاثْومْ زِي مَارَّا ڒڭْنُوسْ ذ ثَاوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* إِ سِيذِي: خْ ييْسَانْ ذ إِكَارُّوثنْ، ذِي ڒكْرَاسِي إِتّْوَاربُّونْ، خْ إِسَارْذَانْ ذ إِڒغْمَانْ ن إِشْثْ ن ثْڭعْرُورْثْ، غَارْ وذْرَارْ إِنُو أَمْقدّسْ، غَارْ ؤُرْشَالِيمْ، \add أَمُّو إِ\add* إِقَّارْ سِيذِي إِنُو، أَمْ مَامّشْ تَّاوْينْ أَيْثْ ن إِسْرَائِيل ثَاوْهِيبْثْ \add ن ڒْغِيدْجثْ\add* ذِي ثْقدُّوحْثْ ثزْذِيڭْ غَارْ ثَادَّارْثْ ن سِيذِي.
\v 21 ؤُڒَا زَّايْسنْ أَذْ فَارْزغْ \add شَا مَاحنْذْ أَذْ إِڒِينْ\add* ذ إِكهَّاننْ ذ إِلَاوِييّنْ، إِقَّارْ سِيذِي.
\v 22 مَاغَارْ أَمْ يِيجنْوَانْ ن جْذِيذْ ذ ثمُّورْثْ ن جْذِيذْ نِّي إِ غَا ڭّغْ أَذْ بدّنْ زَّاثْ إِ وُوذمْ إِنُو، إِقَّارْ سِيذِي، أَمُّو إِ غَا \add ثقِّيمْ\add* ثْبدّْ ؤُڒَا ذ زَّارِيعثْ نْومْ ذ إِسمْ نْومْ \add زَّاثْ إِ وُوذمْ إِنُو\add*. \x ◘ \xo 66:‏22 \xt إِشا. 65‏:‏17؛ 2 بُط. 3‏:‏13؛ أَسَا. 21‏:‏1\x*
\v 23 أَذْ إِمْسَارْ زِي قَاعْ أَبذِّي ن ؤُيُورْ أَڒْ قَاعْ أَبذِّي نّغْنِي ؤُ زڭْ وَاسّْ ن سّبْثْ أَڒْ أَسّْ ن سّبْثْ نّغْنِي أَذْ د-أَسنْ مَارَّا إِوْذَانْ مَاحنْذْ أَذْ بنْذْقنْ زَّاثْ إِ وُوذمْ إِنُو، \add أَمُّو إِ\add* إِقَّارْ سِيذِي. \f ◼ \fr 66:‏23 \ft \bd ’مَارَّا إِوْذَانْ‘\bd* - س ثْعِيبْرَانِيثْ ’مَارَّا دَّاثْ‘.\f*
\v 24 نِيثْنِي أَذْ فّْغنْ، أَذْ ژَتڒنْ ڒْخشْبَاثْ ن يرْيَازنْ نِّي خَافِي إِعدَّانْ، مَاغَارْ أَكشَّا نْسنْعمَّارْصْ وَارْ إِتّْمتِّي ؤُڒَا ذ ثِيمسِّي نْسنْعمَّارْصْ وَارْ ثتّْخسِّي. أَذْ إِڒِينْ ذ نّْعِي إِ مَارَّا إِوْذَانْ ذ ڒْمَاڒْ.“ 
