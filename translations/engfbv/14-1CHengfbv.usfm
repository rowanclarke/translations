\v 21 Joah \w his|strong="H5838"\w* \w son|strong="H1121"\w*, Iddo \w his|strong="H5838"\w* \w son|strong="H1121"\w*, Zerah \w his|strong="H5838"\w* \w son|strong="H1121"\w*, \w and|strong="H1121"\w* Jeatherai \w his|strong="H5838"\w* \w son|strong="H1121"\w*.
\p 
\v 22 \w The|strong="H1121"\w* \w descendants|strong="H1121"\w* \w of|strong="H1121"\w* Kohath: Amminadab \w his|strong="H8480"\w* \w son|strong="H1121"\w*, \w Korah|strong="H7141"\w* \w his|strong="H8480"\w* \w son|strong="H1121"\w*, Assir \w his|strong="H8480"\w* \w son|strong="H1121"\w*,
