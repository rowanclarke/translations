\v 2 \w Dan|strong="H1835"\w*, \w Joseph|strong="H3130"\w*, \w and|strong="H1144"\w* \w Benjamin|strong="H1144"\w*;
\p \w Naphtali|strong="H5321"\w*, \w Gad|strong="H1410"\w*, \w and|strong="H1144"\w* Asher.
\s1 Judah’s Descendants
\p 
\v 3 \w The|strong="H3205"\w* \w sons|strong="H1121"\w* \w of|strong="H1121"\w* \w Judah|strong="H3063"\w*:
\p \w Er|strong="H6147"\w*, Onan, \w and|strong="H1121"\w* \w Shelah|strong="H7956"\w*. \w These|strong="H4191"\w* \w three|strong="H7969"\w* \w were|strong="H1961"\w* \w born|strong="H3205"\w* \w to|strong="H4191"\w* \w him|strong="H3205"\w* \w by|strong="H3068"\w* Bathshua, \w a|strong="H3068"\w* \w Canaanite|strong="H3669"\w* \w woman|strong="H1323"\w*. \w Er|strong="H6147"\w*, \w Judah|strong="H3063"\w*’s \w firstborn|strong="H1060"\w*, \w displeased|strong="H7451"\w* \w the|strong="H3205"\w* \nd \w Lord|strong="H3068"\w*\nd*, \w so|strong="H1961"\w* \w the|strong="H3205"\w* \nd \w Lord|strong="H3068"\w*\nd* \w killed|strong="H4191"\w* \w him|strong="H3205"\w*.
\p 
\v 4 \w Tamar|strong="H8559"\w*, \w Judah|strong="H3063"\w*’s \w daughter-in-law|strong="H3618"\w*, \w bore|strong="H3205"\w* \w to|strong="H3205"\w* \w him|strong="H3205"\w* \w Perez|strong="H6557"\w* \w and|strong="H1121"\w* \w Zerah|strong="H2226"\w*. \w Judah|strong="H3063"\w* \w had|strong="H3205"\w* \w five|strong="H2568"\w* \w sons|strong="H1121"\w* \w in|strong="H1121"\w* \w all|strong="H3605"\w*.
\p 
