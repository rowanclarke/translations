\v 29 Pero Jacob dijo: Tú mismo \w sabes|strong="H3045"\w* lo \w que|strong="H3045"\w* te serví y \w cómo|strong="H1961"\w* \w estuvo|strong="H1961"\w* tu \w ganado|strong="H4735"\w* conmigo.  
\v 30 \w Pues|strong="H3588"\w* \w poco|strong="H4592"\w* \w tenías|strong="H1961"\w* \w antes|strong="H6440"\w* \w de|strong="H3588"\w* \w mi|strong="H1961"\w* \w venida|strong="H1961"\w*, \w y|strong="H1571"\w* aumentó \w mucho|strong="H7230"\w*. \nd \+w Yavé|strong="H3068"\+w*\nd* \w te|strong="H3588"\w* \w bendijo|strong="H1288"\w* \w con|strong="H3588"\w* \w mi|strong="H1961"\w* \w presencia|strong="H6440"\w*. \w Así|strong="H1571"\w* \w que|strong="H3588"\w*, ¿\w cuándo|strong="H3588"\w* trabajaré \w yo|strong="H3588"\w* \w por|strong="H3588"\w* \w mi|strong="H1961"\w* propia \w casa|strong="H1004"\w*?   
\p
\v 31 \w Y|strong="H3068"\w* \w él|strong="H6213"\w* contestó: ¿\w Qué|strong="H4100"\w* te \w daré|strong="H5414"\w*?  
\p \w Y|strong="H3068"\w* \w Jacob|strong="H3290"\w* dijo: \w No|strong="H3808"\w* me \w des|strong="H5414"\w* \w algo|strong="H3972"\w*. \w Volveré|strong="H7725"\w* \w a|strong="H3068"\w* apacentar \w tu|strong="H6213"\w* \w rebaño|strong="H6629"\w* \w si|strong="H3808"\w* \w haces|strong="H6213"\w* \w esto|strong="H2088"\w* \w para|strong="H5414"\w* mí:  
\v 32 \w Hoy|strong="H3117"\w* \w pasaré|strong="H5674"\w* por \w todo|strong="H3605"\w* tu \w rebaño|strong="H6629"\w* y separaré de \w entre|strong="H8033"\w* las \w cabras|strong="H5795"\w* y \w ovejas|strong="H6629"\w* \w toda|strong="H3605"\w* manchada y moteada, y \w toda|strong="H3605"\w* oscura. Éstas \w serán|strong="H1961"\w* \w mi|strong="H1961"\w* \w salario|strong="H7939"\w*.  
\v 33 \w Así|strong="H3588"\w* \w mañana|strong="H4279"\w*, \w cuando|strong="H3588"\w* vayas \w a|strong="H3068"\w* comprobar \w mi|strong="H5921"\w* \w salario|strong="H7939"\w*, \w mi|strong="H5921"\w* honradez \w responderá|strong="H6030"\w* \w por|strong="H5921"\w* \w mí|strong="H5921"\w*: \w Todo|strong="H3605"\w* \w lo|strong="H1931"\w* \w que|strong="H3588"\w* \w no|strong="H3588"\w* sea moteado \w o|strong="H3068"\w* manchado \w entre|strong="H5921"\w* \w las|strong="H5921"\w* \w cabras|strong="H5795"\w*, \w o|strong="H3068"\w* \w de|strong="H5921"\w* color oscuro \w entre|strong="H5921"\w* \w los|strong="H5921"\w* corderos, \w se|strong="H1931"\w* considerará \w hurtado|strong="H1589"\w* \w por|strong="H5921"\w* \w mí|strong="H5921"\w*.   
\p
\v 34 \w Y|strong="H3068"\w* \w Labán|strong="H3837"\w* respondió: ¡Convenido! ¡\w Que|strong="H1697"\w* \w sea|strong="H1961"\w* \w como|strong="H1961"\w* tú \w dices|strong="H1697"\w*!   
\p
\v 35 Sin embargo, \w aquel|strong="H1931"\w* \w mismo|strong="H1931"\w* \w día|strong="H3117"\w* Labán separó \w todas|strong="H3605"\w* las \w cabras|strong="H5795"\w* y \w los|strong="H1121"\w* machos cabríos manchados y moteados. \w Toda|strong="H3605"\w* \w aquella|strong="H1931"\w* \w que|strong="H1931"\w* \w tenía|strong="H1931"\w* algo \w de|strong="H1121"\w* \w blanco|strong="H3836"\w* y \w todos|strong="H3605"\w* \w los|strong="H1121"\w* corderos \w de|strong="H1121"\w* color \w los|strong="H1121"\w* \w entregó|strong="H5414"\w* \w en|strong="H5493"\w* \w manos|strong="H3027"\w* \w de|strong="H1121"\w* \w sus|strong="H1931"\w* \w hijos|strong="H1121"\w*.  
\v 36 Además interpuso \w tres|strong="H7969"\w* \w días|strong="H3117"\w* de \w camino|strong="H1870"\w* entre él y \w Jacob|strong="H3290"\w*. \w Y|strong="H3068"\w* \w Jacob|strong="H3290"\w* \w quedó|strong="H3498"\w* y \w apacentaba|strong="H7462"\w* el resto del \w rebaño|strong="H6629"\w* de \w Labán|strong="H3837"\w*.   
\p
\v 37 Entonces \w Jacob|strong="H3290"\w* \w tomó|strong="H3947"\w* \w varas|strong="H4731"\w* \w verdes|strong="H3892"\w* \w de|strong="H5921"\w* álamo, \w de|strong="H5921"\w* avellano \w y|strong="H5921"\w* \w de|strong="H5921"\w* castaño, \w y|strong="H5921"\w* descortezó \w en|strong="H5921"\w* \w ellas|strong="H5921"\w* mondaduras \w blancas|strong="H3836"\w* \w para|strong="H5921"\w* descubrir así \w lo|strong="H5921"\w* \w blanco|strong="H3836"\w* \w de|strong="H5921"\w* \w las|strong="H5921"\w* \w varas|strong="H4731"\w*.  
\v 38 Puso las \w varas|strong="H4731"\w* \w que|strong="H4325"\w* descortezó en los abrevaderos, \w delante|strong="H5227"\w* \w del|strong="H8354"\w* \w rebaño|strong="H6629"\w* en las canales \w de|strong="H4325"\w* \w agua|strong="H4325"\w* donde \w bebían|strong="H8354"\w* las \w ovejas|strong="H6629"\w*, las cuales se apareaban cuando iban \w a|strong="H3068"\w* \w beber|strong="H8354"\w*.  
\v 39 Las \w ovejas|strong="H6629"\w* se apareaban delante de las \w varas|strong="H4731"\w* y \w parían|strong="H3205"\w* \w borregos|strong="H6629"\w* \w listados|strong="H6124"\w*, moteados y manchados.   
\p
\v 40 Entonces \w Jacob|strong="H3290"\w* separaba \w los|strong="H5921"\w* \w corderos|strong="H6629"\w*, \w y|strong="H5921"\w* colocaba \w con|strong="H5921"\w* su propio \w rebaño|strong="H6629"\w* \w lo|strong="H3808"\w* listado \w y|strong="H5921"\w* \w todo|strong="H3605"\w* \w lo|strong="H3808"\w* \w que|strong="H3808"\w* era oscuro \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w rebaño|strong="H6629"\w* \w de|strong="H5921"\w* \w Labán|strong="H3837"\w*. \w Él|strong="H5921"\w* colocó su \w manada|strong="H5739"\w* aparte \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w la|strong="H5921"\w* mezcló \w con|strong="H5921"\w* \w el|strong="H5921"\w* \w rebaño|strong="H6629"\w* \w de|strong="H5921"\w* \w Labán|strong="H3837"\w*.  
\v 41 \w Sucedía|strong="H1961"\w* \w que|strong="H1961"\w* cuantas veces \w se|strong="H1961"\w* apareaban las robustas, \w Jacob|strong="H3290"\w* colocaba las \w varas|strong="H4731"\w* en \w los|strong="H3605"\w* abrevaderos \w delante|strong="H5869"\w* \w de|strong="H5869"\w* las \w ovejas|strong="H6629"\w* \w para|strong="H1961"\w* \w que|strong="H1961"\w* concibieran ante las \w varas|strong="H4731"\w*.  
\v 42 En cambio, \w cuando|strong="H1961"\w* las débiles llegaban, \w no|strong="H3808"\w* las colocaba. Así las \w más|strong="H3808"\w* débiles \w eran|strong="H1961"\w* \w para|strong="H1961"\w* \w Labán|strong="H3837"\w*, y las \w más|strong="H3808"\w* fuertes \w para|strong="H1961"\w* \w Jacob|strong="H3290"\w*.   
\p
\v 43 El hombre \w se|strong="H1961"\w* enriqueció muchísimo y logró poseer \w numerosos|strong="H7227"\w* rebaños, esclavas y esclavos, \w camellos|strong="H1581"\w* y \w asnos|strong="H2543"\w*.   
\c 31  
\s1 El regreso a Canaán  
\p
\v 1 Pero \add Jacob\add* \w escuchaba|strong="H8085"\w* las \w palabras|strong="H1697"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Labán|strong="H3837"\w*, \w que|strong="H1697"\w* decían: \w Jacob|strong="H3290"\w* \w tomó|strong="H3947"\w* \w todo|strong="H3605"\w* \w lo|strong="H1697"\w* \w que|strong="H1697"\w* \w era|strong="H1121"\w* \w de|strong="H1121"\w* nuestro padre. \w Toda|strong="H3605"\w* \w esta|strong="H2088"\w* riqueza \w la|strong="H3605"\w* adquirió con \w lo|strong="H1697"\w* \w que|strong="H1697"\w* \w era|strong="H1121"\w* \w de|strong="H1121"\w* nuestro padre.  
\v 2 \w Jacob|strong="H3290"\w* observaba \w el|strong="H5973"\w* semblante \w de|strong="H6440"\w* \w Labán|strong="H3837"\w*, y \w miraba|strong="H7200"\w* que \w no|strong="H6440"\w* era \w hacia|strong="H6440"\w* \w él|strong="H5973"\w* \w como|strong="H5973"\w* \w antes|strong="H6440"\w*.   
\p
\v 3 \w Entonces|strong="H7725"\w* \nd \+w Yavé|strong="H3068"\+w*\nd* dijo \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w*: \wj Regresa \+w a|strong="H3068"\+w* la tierra \+w de|strong="H5973"\+w* tus antepasados y \+w a|strong="H3068"\+w* tu \+w parentela|strong="H4138"\+w*, y Yo estaré \+w contigo|strong="H5973"\+w*.\wj*   
\p
\v 4 Luego \w Jacob|strong="H3290"\w* \w mandó|strong="H7971"\w* \w llamar|strong="H7121"\w* \w a|strong="H3068"\w* Raquel y \w a|strong="H3068"\w* \w Lea|strong="H3812"\w* al \w campo|strong="H7704"\w*, donde tenía su \w rebaño|strong="H6629"\w*,  
\v 5 \w y|strong="H3588"\w* les dijo: Observo \w que|strong="H3588"\w* \w el|strong="H3588"\w* semblante del padre \w de|strong="H3588"\w* ustedes \w hacia|strong="H6440"\w* \w mí|strong="H1961"\w* \w no|strong="H3588"\w* \w es|strong="H1961"\w* \w como|strong="H3588"\w* \w antes|strong="H6440"\w*, \w pero|strong="H3588"\w* \w el|strong="H3588"\w* \nd ʼElohim\nd* \w de|strong="H3588"\w* \w mi|strong="H1961"\w* padre \w estuvo|strong="H1961"\w* \w conmigo|strong="H5978"\w*.  
\v 6 Ustedes \w saben|strong="H3045"\w* también \w que|strong="H3588"\w* \w con|strong="H3588"\w* \w toda|strong="H3605"\w* mi \w fuerza|strong="H3581"\w* he servido \w a|strong="H3068"\w* \w su|strong="H3588"\w* padre,  
\v 7 pero su padre me engañó, y cambió mi \w salario|strong="H4909"\w* \w diez|strong="H6235"\w* \w veces|strong="H4489"\w*. \w Sin|strong="H3808"\w* embargo, \nd ʼElohim\nd* \w no|strong="H3808"\w* le \w permitió|strong="H5414"\w* hacerme \w mal|strong="H7489"\w*.  
\v 8 \w Si|strong="H1961"\w* \w él|strong="H3605"\w* decía \w así|strong="H3541"\w*: \w Los|strong="H3605"\w* moteados \w serán|strong="H1961"\w* tu \w salario|strong="H7939"\w*, entonces \w todas|strong="H3605"\w* las \w ovejas|strong="H6629"\w* \w parían|strong="H3205"\w* moteados. \w Y|strong="H3068"\w* \w si|strong="H1961"\w* decía: \w Los|strong="H3605"\w* \w listados|strong="H6124"\w* \w serán|strong="H1961"\w* tu \w salario|strong="H7939"\w*, entonces \w todas|strong="H3605"\w* las \w ovejas|strong="H6629"\w* \w parían|strong="H3205"\w* \w listados|strong="H6124"\w*.  
\v 9 Así \nd ʼElohim\nd* despojó del \w ganado|strong="H4735"\w* \w a|strong="H3068"\w* su padre, y me lo \w dio|strong="H5414"\w* \w a|strong="H3068"\w* mí.   
\p
\v 10 \w Sucedió|strong="H1961"\w* \w que|strong="H5921"\w* \w en|strong="H5921"\w* un \w sueño|strong="H2472"\w*, \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w tiempo|strong="H6256"\w* \w cuando|strong="H1961"\w* \w las|strong="H5921"\w* \w ovejas|strong="H6629"\w* \w se|strong="H1961"\w* apareaban, levanté \w mis|strong="H5375"\w* \w ojos|strong="H5869"\w* \w y|strong="H5921"\w* \w miré|strong="H7200"\w* \w que|strong="H5921"\w* \w los|strong="H5921"\w* machos \w que|strong="H5921"\w* montaban \w a|strong="H3068"\w* \w las|strong="H5921"\w* \w ovejas|strong="H6629"\w* \w eran|strong="H1961"\w* \w listados|strong="H6124"\w*, moteados \w y|strong="H5921"\w* manchados.   
\p
\v 11 \w Y|strong="H3068"\w* el \w Ángel|strong="H4397"\w* de \nd ʼElohim\nd* me dijo en el \w sueño|strong="H2472"\w*: \wj \+w Jacob|strong="H3290"\+w*.\wj*  
\p \w Y|strong="H3068"\w* \w yo|strong="H2009"\w* dije: \w Aquí|strong="H2009"\w* estoy.   
\p
\v 12 \w Y|strong="H3068"\w* \w Él|strong="H5921"\w* dijo: \wj \+w Levanta|strong="H5375"\+w* \+w ahora|strong="H4994"\+w* tus \+w ojos|strong="H5869"\+w* \+w y|strong="H3588"\+w* \+w verás|strong="H7200"\+w* \+w que|strong="H3588"\+w* \+w todos|strong="H3605"\+w* \+w los|strong="H5921"\+w* machos \+w que|strong="H3588"\+w* montan \+w a|strong="H3068"\+w* \+w las|strong="H5921"\+w* \+w ovejas|strong="H6629"\+w* \+w son|strong="H3588"\+w* \+w listados|strong="H6124"\+w*, moteados \+w y|strong="H3588"\+w* manchados, \+w porque|strong="H3588"\+w* \+w Yo|strong="H3588"\+w* \+w veo|strong="H7200"\+w* \+w todo|strong="H3605"\+w* \+w lo|strong="H5921"\+w* \+w que|strong="H3588"\+w* \+w Labán|strong="H3837"\+w* \+w te|strong="H5869"\+w* \+w hace|strong="H6213"\+w*.\wj*  
\v 13 \wj \+w Yo|strong="H4480"\+w* soy \+w el|strong="H1008"\+w* \+w ʼEL|strong="H1008"\+w* \+w de|strong="H4480"\+w* Bet-ʼEl, \+w donde|strong="H8033"\+w* ungiste \+w la|strong="H2063"\+w* estela y \+w donde|strong="H8033"\+w* \+w me|strong="H4480"\+w* hiciste un \+w voto|strong="H5087"\+w*. \+w Levántate|strong="H6965"\+w* \+w ahora|strong="H6258"\+w*, \+w sal|strong="H3318"\+w* \+w de|strong="H4480"\+w* \+w esta|strong="H2063"\+w* tierra y regresa \+w a|strong="H3068"\+w* \+w la|strong="H2063"\+w* tierra \+w de|strong="H4480"\+w* tu \+w nacimiento|strong="H4138"\+w*.\wj*   
\p
\v 14 Al \w responder|strong="H6030"\w* Raquel y \w Lea|strong="H3812"\w*, le preguntaron: ¿Tenemos \w parte|strong="H2506"\w* \w o|strong="H3068"\w* \w herencia|strong="H5159"\w* \w en|strong="H5750"\w* la \w casa|strong="H1004"\w* \w de|strong="H5750"\w* nuestro padre?  
\v 15 ¿\w No|strong="H3808"\w* nos \w consideraba|strong="H2803"\w* \w ya|strong="H1571"\w* \w como|strong="H3588"\w* extrañas, \w pues|strong="H3588"\w* nos \w vendió|strong="H4376"\w* \w y|strong="H1571"\w* consumió \w también|strong="H1571"\w* nuestro \w dinero|strong="H3701"\w*?  
\v 16 \w Porque|strong="H3588"\w* \w toda|strong="H3605"\w* \w la|strong="H1931"\w* riqueza \w que|strong="H3588"\w* \nd ʼElohim\nd* despojó \w a|strong="H3068"\w* nuestro padre \w es|strong="H1931"\w* nuestra \w y|strong="H3588"\w* \w de|strong="H3588"\w* nuestros \w hijos|strong="H1121"\w*. \w Ahora|strong="H6258"\w* \w pues|strong="H3588"\w*, \w haz|strong="H6213"\w* \w todo|strong="H3605"\w* \w lo|strong="H1931"\w* \w que|strong="H3588"\w* \nd ʼElohim\nd* \w te|strong="H3588"\w* dijo.   
\p
\v 17 Entonces \w Jacob|strong="H3290"\w* \w se|strong="H5921"\w* \w levantó|strong="H5375"\w* \w y|strong="H5921"\w* montó \w a|strong="H3068"\w* sus \w hijos|strong="H1121"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* sus esposas \w en|strong="H5921"\w* \w los|strong="H1121"\w* \w camellos|strong="H1581"\w*,  
\v 18 y condujo \w todo|strong="H3605"\w* su \w ganado|strong="H4735"\w* y \w toda|strong="H3605"\w* su ganancia \w que|strong="H3605"\w* acumuló, \w el|strong="H3605"\w* \w ganado|strong="H4735"\w* \w que|strong="H3605"\w* le pertenecía \w que|strong="H3605"\w* adquirió en \w Padan-aram|strong="H6307"\w*, para ir \w a|strong="H3068"\w* \add la casa de\add* \w Isaac|strong="H3327"\w* su padre, \w a|strong="H3068"\w* \w la|strong="H3605"\w* tierra de \w Canaán|strong="H3667"\w*.   
\p
\v 19 Mientras tanto, \w Labán|strong="H3837"\w* \w fue|strong="H1980"\w* \w a|strong="H3068"\w* trasquilar sus \w ovejas|strong="H6629"\w*. Raquel \w hurtó|strong="H1589"\w* los ídolos domésticos de su padre.  
\v 20 \w Jacob|strong="H3290"\w* engañó \w a|strong="H3068"\w* \w Labán|strong="H3837"\w* \w el|strong="H1931"\w* arameo \w al|strong="H5921"\w* \w no|strong="H1097"\w* avisarle \w que|strong="H3588"\w* \w se|strong="H1931"\w* iba.  
\v 21 \w Él|strong="H1931"\w* \w huyó|strong="H1272"\w* con \w todo|strong="H3605"\w* \w lo|strong="H1931"\w* \w que|strong="H1931"\w* \w tenía|strong="H1931"\w*. \w Y|strong="H3068"\w* al \w levantarse|strong="H6965"\w*, vadeó \w el|strong="H1931"\w* \w río|strong="H5104"\w* y \w se|strong="H1931"\w* dirigió \w hacia|strong="H6440"\w* \w la|strong="H1931"\w* montaña \w de|strong="H6440"\w* \w Galaad|strong="H1568"\w*.   
\p
\v 22 Al tercer \w día|strong="H3117"\w* le informaron \w a|strong="H3068"\w* \w Labán|strong="H3837"\w* \w que|strong="H3588"\w* \w Jacob|strong="H3290"\w* \w huyó|strong="H1272"\w*.  
\v 23 \w Entonces|strong="H3117"\w* \w tomó|strong="H3947"\w* \w a|strong="H3068"\w* sus parientes \w consigo|strong="H5973"\w*, lo \w persiguió|strong="H7291"\w* durante \w siete|strong="H7651"\w* \w días|strong="H3117"\w* y lo alcanzó \w en|strong="H5973"\w* la montaña \w de|strong="H5973"\w* \w Galaad|strong="H1568"\w*.   
\p
\v 24 Pero \w en|strong="H5973"\w* \w el|strong="H5973"\w* \w sueño|strong="H2472"\w* \w de|strong="H5973"\w* \w la|strong="H8104"\w* \w noche|strong="H3915"\w*, \nd ʼElohim\nd* \w llegó|strong="H5704"\w* \w a|strong="H3068"\w* \w Labán|strong="H3837"\w* \w el|strong="H5973"\w* arameo \w y|strong="H5704"\w* \w le|strong="H5973"\w* \w dijo|strong="H1696"\w*: \wj ¡Ten cuidado \+w de|strong="H5973"\+w* \+w no|strong="H6435"\+w* \+w hablar|strong="H1696"\+w* \+w a|strong="H3068"\+w* \+w Jacob|strong="H3290"\+w* \+w bien|strong="H2896"\+w* \+w ni|strong="H5704"\+w* \+w mal|strong="H7451"\+w*!\wj*   
\p
\v 25 \w Labán|strong="H3837"\w* \w alcanzó|strong="H5381"\w* \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w*, quien ya había plantado sus tiendas en la montaña. \w Labán|strong="H3837"\w* acampó con sus parientes en la misma montaña de \w Galaad|strong="H1568"\w*.  
\v 26 \w Y|strong="H3068"\w* \w Labán|strong="H3837"\w* preguntó \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w*: ¿\w Qué|strong="H4100"\w* \w hiciste|strong="H6213"\w*? ¡Me engañaste y te trajiste \w a|strong="H3068"\w* mis \w hijas|strong="H1323"\w* \w como|strong="H4100"\w* prisioneras de guerra!  
\v 27 ¿\w Por|strong="H4100"\w* \w qué|strong="H4100"\w* te escondiste para huir? Me engañaste y \w no|strong="H3808"\w* me avisaste para despedirte con festejos y cantares, con tamboril y \w arpa|strong="H3658"\w*.  
\v 28 \w Ni|strong="H3808"\w* siquiera me \w dejaste|strong="H5203"\w* \w besar|strong="H5401"\w* \w a|strong="H3068"\w* mis \w nietos|strong="H1121"\w* \w ni|strong="H3808"\w* \w a|strong="H3068"\w* mis \w hijas|strong="H1323"\w*. ¡Actuaste \w de|strong="H1121"\w* manera insensata!  
\v 29 \w Hay|strong="H3426"\w* \w poder|strong="H3027"\w* \w en|strong="H5973"\w* mi \w mano|strong="H3027"\w* \w para|strong="H5704"\w* \w hacerles|strong="H6213"\w* \w mal|strong="H7451"\w*, pero \w el|strong="H5973"\w* \nd ʼElohim\nd* \w de|strong="H5973"\w* \w tu|strong="H6213"\w* padre \w me|strong="H5973"\w* \w habló|strong="H1696"\w* anoche: \wj Ten \+w cuidado|strong="H3027"\+w* \+w de|strong="H5973"\+w* \+w no|strong="H6213"\+w* \+w hablar|strong="H1696"\+w* \+w bien|strong="H2896"\+w* \+w ni|strong="H5704"\+w* \+w mal|strong="H7451"\+w* \+w a|strong="H3068"\+w* \+w Jacob|strong="H3290"\+w*.\wj*  
\v 30 \w Y|strong="H3068"\w* \w ahora|strong="H6258"\w*, \w si|strong="H3588"\w* decidiste irte \w por|strong="H3588"\w* \w la|strong="H3588"\w* nostalgia \w que|strong="H3588"\w* tenías \w por|strong="H3588"\w* \w la|strong="H3588"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* tu padre, ¿\w por|strong="H3588"\w* \w qué|strong="H3588"\w* robaste mis ídolos caseros?   
\p
\v 31 \w Jacob|strong="H3290"\w* \w respondió|strong="H6030"\w* \w a|strong="H3068"\w* \w Labán|strong="H3837"\w*: \w Porque|strong="H3588"\w* tuve \w miedo|strong="H3372"\w*, \w pues|strong="H3588"\w* pensé \w que|strong="H3588"\w* \w me|strong="H3588"\w* \w quitarías|strong="H1497"\w* \w por|strong="H3588"\w* fuerza \w a|strong="H3068"\w* tus \w hijas|strong="H1323"\w*,  
\v 32 \w pero|strong="H3588"\w* aquél \w con|strong="H5973"\w* \w quien|strong="H4100"\w* \w halles|strong="H4672"\w* tus ídolos caseros, ¡\w que|strong="H3588"\w* \w no|strong="H3808"\w* \w viva|strong="H2421"\w*! \w Delante|strong="H5048"\w* \w de|strong="H3588"\w* nuestros hermanos examina \w qué|strong="H3588"\w* tengo \w de|strong="H3588"\w* \w lo|strong="H4100"\w* tuyo \w y|strong="H3588"\w* \w tómalo|strong="H3947"\w* \w contigo|strong="H5973"\w*, \w porque|strong="H3588"\w* \w Jacob|strong="H3290"\w* \w no|strong="H3808"\w* \w sabía|strong="H3045"\w* \w que|strong="H3588"\w* Raquel \w los|strong="H5973"\w* \w hurtó|strong="H1589"\w*.   
\p
\v 33 Por tanto \w Labán|strong="H3837"\w* entró \w en|strong="H3318"\w* la tienda de \w Jacob|strong="H3290"\w*, \w en|strong="H3318"\w* la tienda de \w Lea|strong="H3812"\w*, y \w en|strong="H3318"\w* la tienda de las \w dos|strong="H8147"\w* esclavas, pero \w no|strong="H3808"\w* los \w halló|strong="H4672"\w*. Al \w salir|strong="H3318"\w* de la tienda de \w Lea|strong="H3812"\w* entró \w en|strong="H3318"\w* la tienda de Raquel.  
\v 34 Pero Raquel ya \w había|strong="H4672"\w* \w tomado|strong="H3947"\w* \w los|strong="H3427"\w* ídolos \w y|strong="H5921"\w* \w los|strong="H3427"\w* metió debajo \w de|strong="H5921"\w* \w la|strong="H5921"\w* pieza principal \w del|strong="H5921"\w* aparejo \w que|strong="H3808"\w* sirve \w para|strong="H5921"\w* montar \w sobre|strong="H5921"\w* \w el|strong="H5921"\w* \w camello|strong="H1581"\w*, \w y|strong="H5921"\w* \w se|strong="H5921"\w* sentó \w encima|strong="H5921"\w* \w de|strong="H5921"\w* \w ellos|strong="H5921"\w*. \w Labán|strong="H3837"\w* rebuscó \w por|strong="H5921"\w* \w toda|strong="H3605"\w* \w la|strong="H5921"\w* tienda, pero \w no|strong="H3808"\w* \w los|strong="H3427"\w* \w halló|strong="H4672"\w*.   
\p
\v 35 \w Entonces|strong="H3588"\w* ella dijo \w a|strong="H3068"\w* \w su|strong="H3588"\w* padre: \w No|strong="H3808"\w* \w se|strong="H3808"\w* enciendan \w de|strong="H3588"\w* enojo \w los|strong="H3588"\w* \w ojos|strong="H5869"\w* \w de|strong="H3588"\w* mi \tl ʼadón\tl* \w porque|strong="H3588"\w* \w no|strong="H3808"\w* \w me|strong="H3588"\w* \w puedo|strong="H3201"\w* \w levantar|strong="H6965"\w* \w ante|strong="H6440"\w* ti, \w pues|strong="H3588"\w* estoy \w en|strong="H3588"\w* \w el|strong="H3588"\w* período \w de|strong="H3588"\w* las mujeres. \w Y|strong="H3068"\w* \w él|strong="H3588"\w* buscó, \w pero|strong="H3588"\w* \w no|strong="H3808"\w* \w halló|strong="H4672"\w* \w los|strong="H3588"\w* ídolos.   
\p
\v 36 \w Entonces|strong="H3588"\w* \w Jacob|strong="H3290"\w* \w se|strong="H4100"\w* encolerizó \w y|strong="H3588"\w* recriminó \w a|strong="H3068"\w* \w Labán|strong="H3837"\w*. \w Jacob|strong="H3290"\w* tomó \w la|strong="H3588"\w* palabra \w y|strong="H3588"\w* preguntó \w a|strong="H3068"\w* \w Labán|strong="H3837"\w*: ¿\w Cuál|strong="H4100"\w* \w es|strong="H3588"\w* \w mi|strong="H6030"\w* transgresión \w o|strong="H3068"\w* \w cuál|strong="H4100"\w* \w mi|strong="H6030"\w* \w pecado|strong="H2403"\w* \w para|strong="H3588"\w* \w que|strong="H3588"\w* \w me|strong="H3588"\w* persigas \w con|strong="H3588"\w* tal ardor?  
\v 37 ¿\w Qué|strong="H3588"\w* \w hallaste|strong="H4672"\w* \w de|strong="H3588"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* objetos \w de|strong="H3588"\w* tu \w casa|strong="H1004"\w*? \w Porque|strong="H3588"\w* rebuscaste \w todos|strong="H3605"\w* mis \w enseres|strong="H3627"\w*. \w Ponlo|strong="H7760"\w* \w aquí|strong="H3541"\w* \w delante|strong="H5048"\w* \w de|strong="H3588"\w* mis parientes \w y|strong="H3588"\w* tus parientes, \w y|strong="H3588"\w* juzguen \w entre|strong="H3588"\w* \w nosotros|strong="H3605"\w* \w dos|strong="H8147"\w*.   
\p
\v 38 \w En|strong="H5973"\w* \w estos|strong="H2088"\w* 20 \w años|strong="H8141"\w* \w que|strong="H3808"\w* estuve \w contigo|strong="H5973"\w*, tus \w ovejas|strong="H6629"\w* y tus \w cabras|strong="H5795"\w* \w nunca|strong="H3808"\w* \w abortaron|strong="H7921"\w*, \w ni|strong="H3808"\w* yo comí carneros \w de|strong="H5973"\w* tu \w rebaño|strong="H6629"\w*.  
\v 39 \w Lo|strong="H3808"\w* desgarrado \w por|strong="H3027"\w* fieras \w no|strong="H3808"\w* te \w lo|strong="H3808"\w* traía; yo pagaba el daño. \w Lo|strong="H3808"\w* \w hurtado|strong="H1589"\w*, tanto de \w día|strong="H3117"\w* como de \w noche|strong="H3915"\w*, me \w lo|strong="H3808"\w* cobrabas.  
\v 40 \w De|strong="H5869"\w* \w día|strong="H3117"\w* me consumía el calor y \w de|strong="H5869"\w* \w noche|strong="H3915"\w* la helada, y el \w sueño|strong="H8142"\w* huía \w de|strong="H5869"\w* mis \w ojos|strong="H5869"\w*.  
\v 41 \w Así|strong="H2088"\w* estuve 20 \w años|strong="H8141"\w* en tu \w casa|strong="H1004"\w*: 14 \w años|strong="H8141"\w* te serví \w por|strong="H2088"\w* tus \w dos|strong="H8147"\w* \w hijas|strong="H1323"\w*, y \w seis|strong="H8337"\w* \w años|strong="H8141"\w* \w por|strong="H2088"\w* tu \w ganado|strong="H6629"\w*, y has cambiado mi \w salario|strong="H4909"\w* \w diez|strong="H6235"\w* \w veces|strong="H4489"\w*.  
\v 42 \w Si|strong="H3588"\w* \w el|strong="H3588"\w* \nd ʼElohim\nd* \w de|strong="H3588"\w* \w mi|strong="H1961"\w* padre, \w el|strong="H3588"\w* \nd ʼElohim\nd* \w de|strong="H3588"\w* Abraham \w y|strong="H3588"\w* \w el|strong="H3588"\w* \w Temor|strong="H6343"\w* \w de|strong="H3588"\w* \w Isaac|strong="H3327"\w* \w no|strong="H3884"\w* hubiera \w estado|strong="H1961"\w* conmigo, \w de|strong="H3588"\w* \w cierto|strong="H3588"\w* \w me|strong="H3588"\w* despedirías \w ahora|strong="H6258"\w* \w vacío|strong="H7387"\w*. \nd ʼElohim\nd* \w vio|strong="H7200"\w* \w mi|strong="H1961"\w* \w aflicción|strong="H6040"\w* \w y|strong="H3588"\w* \w la|strong="H3588"\w* fatiga \w de|strong="H3588"\w* mis \w manos|strong="H3709"\w*, \w y|strong="H3588"\w* \w te|strong="H3588"\w* reprendió anoche.   
\p
\v 43 \w Entonces|strong="H3117"\w* \w Labán|strong="H3837"\w* \w respondió|strong="H6030"\w* \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w*: Las \w hijas|strong="H1323"\w* son mías, \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* son míos, las \w ovejas|strong="H6629"\w* son mías, y \w todo|strong="H3605"\w* \w lo|strong="H1931"\w* \w que|strong="H4100"\w* \w tú|strong="H6213"\w* \w ves|strong="H7200"\w* \w es|strong="H1931"\w* mío. \w Así|strong="H1931"\w* \w pues|strong="H7200"\w*, ¿\w qué|strong="H4100"\w* puedo \w hacer|strong="H6213"\w* \w hoy|strong="H3117"\w* \w a|strong="H3068"\w* \w estas|strong="H6213"\w* \w hijas|strong="H1323"\w* mías, \w o|strong="H3068"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w que|strong="H4100"\w* \w ellas|strong="H1931"\w* dieron \w a|strong="H3068"\w* luz?  
\v 44 \w Ven|strong="H3212"\w* \w pues|strong="H6258"\w*, concertemos \w ahora|strong="H6258"\w* un \w pacto|strong="H1285"\w* tú y yo, y \w sea|strong="H1961"\w* \w testigo|strong="H5707"\w* entre tú y yo.   
\p
\v 45 Entonces \w Jacob|strong="H3290"\w* \w tomó|strong="H3947"\w* una piedra y la erigió como estela.  
\v 46 \w Y|strong="H3068"\w* \w Jacob|strong="H3290"\w* dijo \w a|strong="H3068"\w* sus parientes: Recojan piedras. \w Tomaron|strong="H3947"\w* piedras \w e|strong="H3068"\w* \w hicieron|strong="H6213"\w* un \w montón|strong="H1530"\w*, \w y|strong="H5921"\w* comieron \w allí|strong="H8033"\w* \w sobre|strong="H5921"\w* \w aquel|strong="H6213"\w* \w montón|strong="H1530"\w*.  
\v 47 \w Labán|strong="H3837"\w* lo \w llamó|strong="H7121"\w* Yegar-sajadutah, y \w Jacob|strong="H3290"\w* lo \w llamó|strong="H7121"\w* \w Galaad|strong="H1567"\w*.   
\p
\v 48 \w Entonces|strong="H3117"\w* \w Labán|strong="H3837"\w* dijo: \w Este|strong="H2088"\w* \w montón|strong="H1530"\w* \w es|strong="H2088"\w* \w testigo|strong="H5707"\w* \w hoy|strong="H3117"\w* \w entre|strong="H5921"\w* tú \w y|strong="H5921"\w* yo. \w Por|strong="H5921"\w* \w tanto|strong="H3651"\w* fue \w llamado|strong="H8034"\w* su \w nombre|strong="H8034"\w* \w Galaad|strong="H1530"\w*  
\v 49 \w y|strong="H3588"\w* \w Mizpa|strong="H4709"\w*, \w por|strong="H3588"\w* \w cuanto|strong="H3588"\w* dijo: Vigile \nd \+w Yavé|strong="H3068"\+w*\nd* \w entre|strong="H3588"\w* tú \w y|strong="H3588"\w* \w yo|strong="H3588"\w* \w cuando|strong="H3588"\w* nos apartemos \w el|strong="H3588"\w* uno del \w otro|strong="H7453"\w*.  
\v 50 \w Si|strong="H5921"\w* maltratas \w a|strong="H3068"\w* mis \w hijas|strong="H1323"\w*, \w o|strong="H3068"\w* \w si|strong="H5921"\w* tomas otras \w mujeres|strong="H1323"\w* \w además|strong="H5921"\w* \w de|strong="H5921"\w* mis \w hijas|strong="H1323"\w*, \w mira|strong="H7200"\w*, \nd ʼElohim\nd* es \w testigo|strong="H5707"\w* \w entre|strong="H5921"\w* tú \w y|strong="H5921"\w* yo. Nadie \add más\add* \w está|strong="H5921"\w* \w con|strong="H5973"\w* \w nosotros|strong="H5973"\w*.   
\p
\v 51 \w Y|strong="H3068"\w* \w Labán|strong="H3837"\w* dijo \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w*: \w Aquí|strong="H2009"\w* \w está|strong="H2088"\w* \w este|strong="H2088"\w* \w montón|strong="H1530"\w*, y fíjate, la estela \w que|strong="H2088"\w* erigí entre tú y \w yo|strong="H2009"\w*.  
\v 52 Sea \w testigo|strong="H5707"\w* \w este|strong="H2088"\w* \w montón|strong="H1530"\w* y sea \w testigo|strong="H5707"\w* \w la|strong="H2063"\w* estela \w de|strong="H7451"\w* \w que|strong="H3808"\w* \w no|strong="H3808"\w* \w pasaré|strong="H5674"\w* \w de|strong="H7451"\w* \w este|strong="H2088"\w* \w montón|strong="H1530"\w* hacia ti, \w ni|strong="H3808"\w* tú \w pasarás|strong="H5674"\w* \w de|strong="H7451"\w* \w este|strong="H2088"\w* \w montón|strong="H1530"\w*, \w ni|strong="H3808"\w* \w de|strong="H7451"\w* \w esta|strong="H2063"\w* estela hacia mí para \w mal|strong="H7451"\w*.  
\v 53 ¡El \nd ʼElohim\nd* de Abraham, de Nacor y de sus antepasados, \w juzgue|strong="H8199"\w* entre nosotros!  
\p Pero \w Jacob|strong="H3290"\w* \w juró|strong="H7650"\w* por el \w Temor|strong="H6343"\w* de su padre \w Isaac|strong="H3327"\w*.  
\v 54 \w Jacob|strong="H3290"\w* \w ofreció|strong="H2076"\w* un \w sacrificio|strong="H2077"\w* en la montaña y \w llamó|strong="H7121"\w* \w a|strong="H3068"\w* sus parientes \w a|strong="H3068"\w* comer \w pan|strong="H3899"\w*. Ellos comieron \w pan|strong="H3899"\w* y pernoctaron en la montaña.   
\p
\v 55 Temprano por la mañana Labán se levantó, besó \w a|strong="H3068"\w* sus hijos y \w a|strong="H3068"\w* sus hijas y los bendijo. Luego salió y regresó \w a|strong="H3068"\w* su lugar.   
\c 32  
\s1 Los dos campamentos  
\p
\v 1 También Jacob prosiguió su camino, y unos ángeles \w de|strong="H1121"\w* \nd ʼElohim\nd* salieron \w a|strong="H3068"\w* su encuentro.  
\v 2 Cuando los vio, \w Jacob|strong="H3290"\w* dijo: Este es el campamento de \nd ʼElohim\nd* y llamó aquel lugar Mahanaim.   
\p
\v 3 \w Jacob|strong="H3290"\w* envió mensajeros \w delante|strong="H1931"\w* de \w él|strong="H1931"\w* \w a|strong="H3068"\w* \w su|strong="H1931"\w* hermano Esaú, \w a|strong="H3068"\w* \w la|strong="H1931"\w* tierra de Seír, al \w campo|strong="H4264"\w* de Edom,  
\v 4 y les ordenó: Así dirán \w a|strong="H3068"\w* mi \tl ʼadón\tl* \w Esaú|strong="H6215"\w*: Tu esclavo \w Jacob|strong="H3290"\w* dice así: Viví temporalmente con Labán, con quien me detuve hasta ahora.  
\v 5 Tengo bueyes, asnos \w y|strong="H5704"\w* ovejas, esclavos \w y|strong="H5704"\w* esclavas, \w y|strong="H5704"\w* \w envío|strong="H6680"\w* \w a|strong="H3068"\w* declararlo \w a|strong="H3068"\w* mi \tl ʼadón\tl* \w para|strong="H5704"\w* hallar gracia ante tus ojos.   
\p
\v 6 \w Los|strong="H1961"\w* mensajeros volvieron \w a|strong="H3068"\w* Jacob \w y|strong="H7794"\w* dijeron: \w Fuimos|strong="H1961"\w* \w a|strong="H3068"\w* tu hermano Esaú, \w y|strong="H7794"\w* también él viene \w a|strong="H3068"\w* tu encuentro con 400 hombres.   
\p
\v 7 \w Jacob|strong="H3290"\w* se angustió \w y|strong="H1571"\w* tuvo gran temor. Dividió \w el|strong="H5973"\w* \w pueblo|strong="H5973"\w*, las ovejas, ganado vacuno \w y|strong="H1571"\w* \w los|strong="H5973"\w* camellos \w que|strong="H1571"\w* tenía \w consigo|strong="H5973"\w* \w en|strong="H5973"\w* dos campamentos,  
\v 8 pues \w se|strong="H5971"\w* dijo: Si viene Esaú contra un \w campamento|strong="H4264"\w* \w y|strong="H1241"\w* lo ataca, \w el|strong="H4264"\w* otro \w campamento|strong="H4264"\w* escapará.   
\p
\v 9 \w Y|strong="H3068"\w* Jacob dijo: ¡Oh \nd ʼElohim\nd* de \w mi|strong="H1961"\w* antepasado Abraham \add y\add* de \w mi|strong="H1961"\w* padre Isaac! Oh \nd \+w Yavé|strong="H3068"\+w*\nd*, \w que|strong="H1961"\w* me dijiste: \wj ¡Regresa \+w a|strong="H3068"\+w* tu tierra y \+w a|strong="H3068"\+w* tu parentela y Yo te haré bien!\wj*  
\v 10 Soy indigno \w de|strong="H5973"\w* tus misericordias y \w de|strong="H5973"\w* toda la fidelidad que has mostrado \w a|strong="H3068"\w* tu esclavo, pues \w con|strong="H5973"\w* mi cayado pasé este Jordán y ahora tengo dos campamentos.  
\v 11 Líbrame, \w te|strong="H3588"\w* ruego, \w de|strong="H3588"\w* \w la|strong="H3588"\w* mano \w de|strong="H3588"\w* \w mi|strong="H1961"\w* hermano Esaú, \w pues|strong="H3588"\w* temo, \w que|strong="H3588"\w* \w venga|strong="H1961"\w* \w y|strong="H3588"\w* \w me|strong="H3588"\w* ataque \w a|strong="H3068"\w* \w la|strong="H3588"\w* madre \w con|strong="H3588"\w* \w los|strong="H3605"\w* hijos.  
\v 12 \w Pero|strong="H3588"\w* Tú mismo dijiste: \wj \+w Ciertamente|strong="H3588"\+w* \+w te|strong="H5921"\+w* haré \+w bien|strong="H3588"\+w* \+w y|strong="H3588"\+w* multiplicaré tu descendencia \+w como|strong="H3588"\+w* \+w la|strong="H5921"\+w* arena \+w del|strong="H5921"\+w* mar, \+w que|strong="H3588"\+w* \+w por|strong="H5921"\+w* ser tanta \+w no|strong="H6435"\+w* \+w se|strong="H5921"\+w* puede contar.\wj*   
\p
\v 13 Pernoctó allí aquella noche. Tomó un presente \w de|strong="H5973"\w* \w lo|strong="H3808"\w* \w que|strong="H3808"\w* \w le|strong="H5973"\w* vino \w a|strong="H3068"\w* mano \w para|strong="H5973"\w* su hermano Esaú:  
\v 14 200 cabras y 20 machos cabríos, 200 ovejas y 20 carneros,  
\v 15 30 camellas que amamantaban, con sus crías, 40 novillas y diez novillos, 20 asnas y diez pollinos.  
\v 16 \w Los|strong="H1121"\w* entregó en mano \w de|strong="H1121"\w* sus esclavos, \w cada|strong="H6235"\w* manada por separado.  
\p \w Y|strong="H3068"\w* dijo \w a|strong="H3068"\w* sus esclavos: Pasen adelante \w de|strong="H1121"\w* mí y dejen espacio entre manada y manada.  
\v 17 \w Y|strong="H3068"\w* le \w ordenó|strong="H7760"\w* al primero: \w Cuando|strong="H5650"\w* mi hermano Esaú te encuentre y te pregunte: ¿\w De|strong="H6440"\w* quién eres, y \w a|strong="H3068"\w* dónde vas, y \w para|strong="H5414"\w* quién \w es|strong="H3027"\w* esto \w que|strong="H3027"\w* llevas \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ti?  
\v 18 \w le|strong="H4310"\w* dirás: \w Es|strong="H3588"\w* un presente \w de|strong="H3588"\w* tu esclavo Jacob, enviado \w para|strong="H3588"\w* mi \tl ʼadón\tl* \w Esaú|strong="H6215"\w*. \w Y|strong="H3068"\w* \w por|strong="H3588"\w* \w cierto|strong="H3588"\w*, \w él|strong="H3588"\w* también viene tras nosotros.   
\p
\v 19 Ordenó \w también|strong="H1571"\w* al segundo, al tercero \w y|strong="H1571"\w* \w a|strong="H3068"\w* todos \w los|strong="H1931"\w* \w que|strong="H1931"\w* iban tras aquellas manadas: \w La|strong="H1931"\w* \w misma|strong="H1931"\w* cosa \w le|strong="H1931"\w* dirán \w a|strong="H3068"\w* \w Esaú|strong="H6215"\w* \w cuando|strong="H1571"\w* \w lo|strong="H1931"\w* encuentren.  
\v 20 \w Y|strong="H3068"\w* \w además|strong="H1571"\w* le dirán: Mira, tu esclavo Jacob \w viene|strong="H1980"\w* tras \w nosotros|strong="H3605"\w*. Porque pensaba: Apaciguaré su \w ira|strong="H1980"\w* \w con|strong="H1571"\w* \w el|strong="H3605"\w* presente \w que|strong="H1571"\w* \w va|strong="H3068"\w* delante \w de|strong="H1697"\w* mí. \w Luego|strong="H2088"\w* veré su rostro, \w y|strong="H1571"\w* \w tal|strong="H2088"\w* vez \w él|strong="H3605"\w* me acepte.  
\v 21 Pasó, \w pues|strong="H3588"\w*, \w el|strong="H3588"\w* \w presente|strong="H4503"\w* \w delante|strong="H6440"\w* \w de|strong="H3588"\w* \w él|strong="H3588"\w*, \w y|strong="H1571"\w* aquella noche pernoctó \w en|strong="H3588"\w* \w el|strong="H3588"\w* campamento.   
\p
\v 22 \w Aquella|strong="H1931"\w* \w misma|strong="H1931"\w* \w noche|strong="H3915"\w* \w se|strong="H1931"\w* levantó, tomó \w a|strong="H3068"\w* \w sus|strong="H1931"\w* \w dos|strong="H6440"\w* esposas, \w a|strong="H3068"\w* \w sus|strong="H1931"\w* \w dos|strong="H6440"\w* esclavas \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w sus|strong="H1931"\w* 11 hijos, \w y|strong="H5921"\w* atravesó \w el|strong="H1931"\w* vado \w de|strong="H5921"\w* Jaboc.  
\v 23 \w Los|strong="H1931"\w* \w tomó|strong="H3947"\w*, les ordenó \w pasar|strong="H5674"\w* \w el|strong="H1931"\w* arroyo y \w luego|strong="H1931"\w* ordenó \w pasar|strong="H5674"\w* todo \w lo|strong="H1931"\w* \w que|strong="H1931"\w* \w tenía|strong="H1931"\w*.   
\s1 La lucha con el Ángel  
\p
\v 24 Jacob se quedó solo, y un Varón luchó con \w él|strong="H5674"\w* hasta rayar \w el|strong="H5674"\w* alba.  
\v 25 Pero viendo \w que|strong="H5704"\w* no podía \w con|strong="H5973"\w* \w él|strong="H5973"\w*, \w le|strong="H5973"\w* atacó \w el|strong="H5973"\w* encaje \w de|strong="H5973"\w* su muslo, \w y|strong="H5704"\w* se \w le|strong="H5973"\w* descoyuntó \w el|strong="H5973"\w* muslo \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w* \w mientras|strong="H5704"\w* luchaba \w con|strong="H5973"\w* \w Él|strong="H5973"\w*.  
\v 26 \w Entonces|strong="H3588"\w* \w el|strong="H5973"\w* Varón dijo: \wj Déjame, \+w por|strong="H3588"\+w* \+w que|strong="H3588"\+w* raya \+w el|strong="H5973"\+w* alba.\wj*  
\p \w Y|strong="H3068"\w* \w Jacob|strong="H3290"\w* dijo: \w No|strong="H3808"\w* \w te|strong="H3588"\w* dejaré, \w si|strong="H3588"\w* \w no|strong="H3808"\w* \w me|strong="H3588"\w* bendices.   
\p
\v 27 Le preguntó: \wj ¿\+w Cuál|strong="H3588"\+w* \+w es|strong="H3588"\+w* tu nombre?\wj*  
\p \w Y|strong="H3068"\w* \w él|strong="H3588"\w* respondió: Jacob.   
\p
\v 28 \w Y|strong="H3068"\w* dijo: \wj \+w Ya|strong="H3068"\+w* \+w no|strong="H4100"\+w* será tu \+w nombre|strong="H8034"\+w* \+w Jacob|strong="H3290"\+w*, sino Israel, \+w porque|strong="H4100"\+w* luchaste con \+nd ʼElohim\+nd* y con los hombres, y venciste.\wj*  
\v 29 \w Entonces|strong="H3588"\w* \w Jacob|strong="H3290"\w* \w le|strong="H5973"\w* dijo: \w Te|strong="H3588"\w* ruego \w que|strong="H3588"\w* \w me|strong="H3588"\w* declares tu \w Nombre|strong="H8034"\w*. \w Y|strong="H3068"\w* \w Él|strong="H5973"\w* respondió: \wj ¿\+w Por|strong="H3588"\+w* \+w qué|strong="H3588"\+w* preguntas \+w por|strong="H3588"\+w* mi \+w Nombre|strong="H8034"\+w*?\wj* \w Y|strong="H3068"\w* \w lo|strong="H3808"\w* bendijo allí.  
\v 30 \w Jacob|strong="H3290"\w* \w llamó|strong="H8034"\w* \w aquel|strong="H2088"\w* lugar Peni-ʼEl, \w porque|strong="H4100"\w* \w dijo|strong="H5046"\w*: Vi \w a|strong="H3068"\w* \nd ʼElohim\nd* cara \w a|strong="H3068"\w* cara, y aun \w así|strong="H2088"\w* fue librada \w mi|strong="H4994"\w* vida.   
\p
\v 31 \w Cuando|strong="H3588"\w* pasó Peni-ʼEl, salió \w el|strong="H3588"\w* sol, \w y|strong="H3588"\w* cojeaba \w por|strong="H3588"\w* \w causa|strong="H6440"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* muslo.  
\v 32 \w Por|strong="H5921"\w* \w eso|strong="H1931"\w* \w hasta|strong="H5921"\w* hoy \w los|strong="H5921"\w* hijos \w de|strong="H5921"\w* Israel \w no|strong="H5921"\w* comen \w del|strong="H5921"\w* tendón \w de|strong="H5921"\w* \w la|strong="H1931"\w* cadera \w que|strong="H1931"\w* \w está|strong="H1931"\w* \w sobre|strong="H5921"\w* \w la|strong="H1931"\w* coyuntura \w del|strong="H5921"\w* \w muslo|strong="H3409"\w*, \w porque|strong="H5921"\w* \w Él|strong="H1931"\w* tocó \w la|strong="H1931"\w* coyuntura \w del|strong="H5921"\w* \w muslo|strong="H3409"\w* \w de|strong="H5921"\w* Jacob \w en|strong="H5921"\w* \w el|strong="H1931"\w* tendón \w de|strong="H5921"\w* \w la|strong="H1931"\w* cadera.   
\c 33  
\s1 Encuentro de Jacob y Esaú  
\p
\v 1 \w Jacob|strong="H3290"\w* \w levantó|strong="H5375"\w* \w la|strong="H5921"\w* mirada, \w y|strong="H5921"\w* \w al|strong="H5921"\w* \w ver|strong="H7200"\w* \w que|strong="H5921"\w* \w Esaú|strong="H6215"\w* \w se|strong="H5921"\w* acercaba \w con|strong="H5973"\w* sus 400 \w hombres|strong="H8147"\w*, repartió sus \w hijos|strong="H3206"\w* \w entre|strong="H5921"\w* \w Lea|strong="H3812"\w*, Raquel \w y|strong="H5921"\w* \w las|strong="H5921"\w* \w dos|strong="H8147"\w* esclavas.  
\v 2 Colocó adelante \w a|strong="H3068"\w* las esclavas con sus \w hijos|strong="H3206"\w*, detrás \w a|strong="H3068"\w* \w Lea|strong="H3812"\w* con los suyos, y últimos \w a|strong="H3068"\w* Raquel con \w José|strong="H3130"\w*.  
\v 3 Pero \w él|strong="H1931"\w* \w pasó|strong="H5674"\w* \w adelante|strong="H5704"\w* \w de|strong="H6440"\w* \w ellos|strong="H1931"\w* \w y|strong="H5704"\w* \w se|strong="H1931"\w* postró \w en|strong="H5704"\w* tierra \w siete|strong="H7651"\w* \w veces|strong="H6471"\w*, \w hasta|strong="H5704"\w* acercarse \w a|strong="H3068"\w* \w su|strong="H1931"\w* hermano.   
\p
\v 4 \w Esaú|strong="H6215"\w* \w corrió|strong="H7323"\w* \w a|strong="H3068"\w* su encuentro \w y|strong="H5921"\w* \w lo|strong="H5921"\w* abrazó. \w Se|strong="H5921"\w* \w echó|strong="H5307"\w* \w sobre|strong="H5921"\w* su \w cuello|strong="H6677"\w* \w y|strong="H5921"\w* \w lo|strong="H5921"\w* \w besó|strong="H5401"\w*, \w y|strong="H5921"\w* \w lloraron|strong="H1058"\w*.  
\v 5 \w Cuando|strong="H5650"\w* \w levantó|strong="H5375"\w* sus \w ojos|strong="H5869"\w* y \w vio|strong="H7200"\w* \w a|strong="H3068"\w* las mujeres y \w a|strong="H3068"\w* los \w niños|strong="H3206"\w*, \w él|strong="H4310"\w* preguntó: ¿\w Quiénes|strong="H4310"\w* son éstos para ti?  
\p \w Y|strong="H3068"\w* \w él|strong="H4310"\w* respondió: Son los \w niños|strong="H3206"\w* \w que|strong="H4310"\w* \nd ʼElohim\nd* bondadosamente ha dado \w a|strong="H3068"\w* tu esclavo.   
\p
\v 6 \w Entonces|strong="H2007"\w* las esclavas \w llegaron|strong="H5066"\w* con sus \w hijos|strong="H3206"\w* y se postraron.  
\v 7 \w Igualmente|strong="H1571"\w* \w Lea|strong="H3812"\w* se \w acercó|strong="H5066"\w* \w con|strong="H1571"\w* sus \w hijos|strong="H3206"\w* \w y|strong="H1571"\w* se postraron, \w y|strong="H1571"\w* finalmente \w José|strong="H3130"\w* \w y|strong="H1571"\w* Raquel se acercaron \w y|strong="H1571"\w* se postraron.   
\p
\v 8 \w Y|strong="H3068"\w* preguntó: ¿\w Qué|strong="H4310"\w* \w te|strong="H5869"\w* propones con \w todos|strong="H3605"\w* \w estos|strong="H2088"\w* grupos \w que|strong="H4310"\w* encontré?  
\p \w Y|strong="H3068"\w* Jacob respondió: \w Hallar|strong="H4672"\w* \w gracia|strong="H2580"\w* ante \w los|strong="H3605"\w* \w ojos|strong="H5869"\w* \w de|strong="H5869"\w* mi \tl ʼadón\tl*.   
\p
\v 9 \w Y|strong="H3068"\w* \w Esaú|strong="H6215"\w* dijo: Yo \w tengo|strong="H3426"\w* suficiente, hermano mío. \w Sea|strong="H1961"\w* \w para|strong="H1961"\w* ti lo \w que|strong="H1961"\w* \w es|strong="H1961"\w* tuyo.   
\p
\v 10 \w Pero|strong="H3588"\w* \w Jacob|strong="H3290"\w* dijo: ¡\w No|strong="H3588"\w*, \w te|strong="H5869"\w* \w ruego|strong="H4994"\w*! \w Si|strong="H3588"\w* \w hallé|strong="H4672"\w* \w ahora|strong="H4994"\w* \w gracia|strong="H2580"\w* \w delante|strong="H6440"\w* \w de|strong="H5921"\w* \w ti|strong="H5921"\w*, \w toma|strong="H3947"\w* \w el|strong="H5921"\w* \w presente|strong="H4503"\w* \w de|strong="H5921"\w* \w mi|strong="H5921"\w* \w mano|strong="H3027"\w*. \w Porque|strong="H3588"\w* \w miro|strong="H7200"\w* tu \w rostro|strong="H6440"\w* \w como|strong="H3588"\w* \w el|strong="H5921"\w* \w que|strong="H3588"\w* \w mira|strong="H7200"\w* \w el|strong="H5921"\w* \w rostro|strong="H6440"\w* \w de|strong="H5921"\w* \nd ʼElohim\nd*, \w y|strong="H3588"\w* \w me|strong="H5921"\w* recibiste favorablemente.  
\v 11 Acepta, \w te|strong="H3588"\w* \w ruego|strong="H4994"\w*, \w mi|strong="H4994"\w* \w presente|strong="H1293"\w* \w que|strong="H3588"\w* fue traído \w para|strong="H3588"\w* ti, \w pues|strong="H3588"\w* \nd ʼElohim\nd* \w me|strong="H3588"\w* ha favorecido, \w porque|strong="H3588"\w* \w tengo|strong="H3426"\w* \w de|strong="H3588"\w* \w todo|strong="H3605"\w*. Le rogó \w con|strong="H3588"\w* insistencia, \w y|strong="H3588"\w* Esaú \w lo|strong="H3605"\w* aceptó.   
\p
\v 12 Luego dijo: \w Anda|strong="H3212"\w*, vámonos. Yo \w iré|strong="H3212"\w* \w delante|strong="H5048"\w* \w de|strong="H5048"\w* ti.  
\v 13 \w Pero|strong="H3588"\w* Jacob \w le|strong="H5921"\w* contestó: \w Mi|strong="H5921"\w* \tl ʼadón\tl* \w sabe|strong="H3045"\w* \w que|strong="H3588"\w* \w los|strong="H5921"\w* \w niños|strong="H3206"\w* \w son|strong="H3588"\w* delicados \w y|strong="H3588"\w* \w que|strong="H3588"\w* \w tengo|strong="H5921"\w* \w ovejas|strong="H6629"\w* \w y|strong="H3588"\w* \w vacas|strong="H1241"\w* \w que|strong="H3588"\w* están criando, \w y|strong="H3588"\w* \w si|strong="H3588"\w* \w las|strong="H5921"\w* fatigan, \w en|strong="H5921"\w* un \w día|strong="H3117"\w* podría \w morir|strong="H4191"\w* \w todo|strong="H3605"\w* \w el|strong="H5921"\w* \w rebaño|strong="H6629"\w*.  
\v 14 \w Pase|strong="H5674"\w* \w ahora|strong="H4994"\w* \w mi|strong="H4994"\w* \tl ʼadón\tl* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* su esclavo. \w Yo|strong="H4994"\w* iré \w con|strong="H5704"\w* lentitud \w al|strong="H5704"\w* \w paso|strong="H5674"\w* del ganado \w que|strong="H4994"\w* \w va|strong="H3068"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* \w mí|strong="H4994"\w* \w y|strong="H5704"\w* \w al|strong="H5704"\w* \w paso|strong="H5674"\w* \w de|strong="H6440"\w* los \w niños|strong="H3206"\w* \w hasta|strong="H5704"\w* \w que|strong="H4994"\w* llegue \w a|strong="H3068"\w* \w mi|strong="H4994"\w* \tl ʼadón\tl* \w en|strong="H5704"\w* \w Seír|strong="H8165"\w*.   
\p
\v 15 \w Y|strong="H3068"\w* \w Esaú|strong="H6215"\w* dijo: Dejaré \w contigo|strong="H5973"\w* parte \w de|strong="H4480"\w* la \w gente|strong="H5971"\w* \w que|strong="H4100"\w* \w vino|strong="H4100"\w* \w conmigo|strong="H5973"\w*. Pero \w él|strong="H5973"\w* respondió: ¿\w Para|strong="H4480"\w* \w qué|strong="H4100"\w* \w esto|strong="H2088"\w*? \w Halle|strong="H4672"\w* \w yo|strong="H4480"\w* \w gracia|strong="H2580"\w* ante \w mi|strong="H4994"\w* \tl ʼadón\tl*.  
\v 16 \w Aquel|strong="H1931"\w* \w día|strong="H3117"\w* \w Esaú|strong="H6215"\w* regresó \w por|strong="H1870"\w* \w su|strong="H1931"\w* \w camino|strong="H1870"\w* \w a|strong="H3068"\w* \w Seír|strong="H8165"\w*,  
\v 17 \w y|strong="H5921"\w* \w Jacob|strong="H3290"\w* salió \w hacia|strong="H6213"\w* Sucot. \w Edificó|strong="H1129"\w* una \w casa|strong="H1004"\w* \w para|strong="H5921"\w* \w él|strong="H5921"\w*, \w e|strong="H3068"\w* \w hizo|strong="H6213"\w* cobertizos \w para|strong="H5921"\w* su \w ganado|strong="H4735"\w*. \w Por|strong="H5921"\w* \w eso|strong="H3651"\w* \w llamó|strong="H7121"\w* \w aquel|strong="H6213"\w* \w lugar|strong="H4725"\w* Sucot.   
\p
\v 18 Cuando volvió \w de|strong="H6440"\w* \w Padan-aram|strong="H6307"\w*, \w Jacob|strong="H3290"\w* llegó en paz \w a|strong="H3068"\w* la \w ciudad|strong="H5892"\w* \w de|strong="H6440"\w* Siquem \w que|strong="H7927"\w* está en la tierra \w de|strong="H6440"\w* \w Canaán|strong="H3667"\w*, y acampó frente \w a|strong="H3068"\w* la \w ciudad|strong="H5892"\w*.  
\v 19 \w Allí|strong="H8033"\w* \w donde|strong="H8033"\w* plantó su tienda \w compró|strong="H7069"\w* la parcela del \w campo|strong="H7704"\w* \w de|strong="H1121"\w* \w mano|strong="H3027"\w* \w de|strong="H1121"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Hamor|strong="H2544"\w*, padre \w de|strong="H1121"\w* Siquem, \w por|strong="H3027"\w* 100 monedas.  
\v 20 Después \w erigió|strong="H5324"\w* \w allí|strong="H8033"\w* un \w altar|strong="H4196"\w*, y lo \w llamó|strong="H7121"\w* \tl ʼEl-ʼElohey-Israel.\tl*   
\c 34  
\s1 Rapto de Dina  
\p
\v 1 Entonces \w Dina|strong="H1783"\w*, la \w hija|strong="H1323"\w* \w que|strong="H1323"\w* \w Lea|strong="H3812"\w* dio \w a|strong="H3068"\w* luz \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w*, \w salió|strong="H3318"\w* \w a|strong="H3068"\w* \w ver|strong="H7200"\w* \w a|strong="H3068"\w* las \w hijas|strong="H1323"\w* de aquella tierra.  
\v 2 Siquem, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Hamor|strong="H2544"\w*, \w el|strong="H1121"\w* \w heveo|strong="H2340"\w* \w príncipe|strong="H5387"\w* \w de|strong="H1121"\w* aquella tierra, la \w miró|strong="H7200"\w* y la \w tomó|strong="H3947"\w*. Se unió \w a|strong="H3068"\w* ella y la deshonró.  
\v 3 Pero su \w alma|strong="H5315"\w* \w se|strong="H5921"\w* apegó \w a|strong="H3068"\w* \w Dina|strong="H1783"\w*, \w hija|strong="H1323"\w* \w de|strong="H5921"\w* \w Jacob|strong="H3290"\w*. \w Se|strong="H5921"\w* enamoró \w de|strong="H5921"\w* \w la|strong="H5921"\w* muchacha \w y|strong="H5921"\w* \w habló|strong="H1696"\w* \w amorosamente|strong="H3820"\w* \w a|strong="H3068"\w* \w la|strong="H5921"\w* joven.  
\v 4 Siquem habló \w a|strong="H3068"\w* su padre \w Hamor|strong="H2544"\w*: \w Tómame|strong="H3947"\w* \w a|strong="H3068"\w* \w esta|strong="H2063"\w* jovencita para \w que|strong="H7927"\w* sea mi esposa.   
\p
\v 5 \w Jacob|strong="H3290"\w* \w oyó|strong="H8085"\w* \w que|strong="H3588"\w* Siquem \w contaminó|strong="H2930"\w* \w a|strong="H3068"\w* \w su|strong="H3588"\w* \w hija|strong="H1323"\w* \w Dina|strong="H1783"\w*. \w Pero|strong="H3588"\w* \w como|strong="H3588"\w* sus \w hijos|strong="H1121"\w* \w estaban|strong="H1961"\w* \w con|strong="H3588"\w* \w su|strong="H3588"\w* \w ganado|strong="H4735"\w* \w en|strong="H5704"\w* \w el|strong="H3588"\w* \w campo|strong="H7704"\w*, \w Jacob|strong="H3290"\w* guardó silencio \w hasta|strong="H5704"\w* \w cuando|strong="H3588"\w* ellos llegaran.   
\p
\v 6 Entonces \w Hamor|strong="H2544"\w*, padre de Siquem, \w salió|strong="H3318"\w* para \w hablar|strong="H1696"\w* con \w Jacob|strong="H3290"\w*.  
\v 7 \w Cuando|strong="H3588"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H4480"\w* \w Jacob|strong="H3290"\w* regresaron \w del|strong="H4480"\w* \w campo|strong="H7704"\w* \w y|strong="H3588"\w* \w lo|strong="H3808"\w* supieron, aquellos \w varones|strong="H3588"\w* \w se|strong="H4480"\w* airaron. \w Se|strong="H4480"\w* enardecieron muchísimo, \w porque|strong="H3588"\w* Siquem \w hizo|strong="H6213"\w* una \w vileza|strong="H5039"\w* \w en|strong="H4480"\w* \w Israel|strong="H3478"\w* \w con|strong="H4480"\w* \w la|strong="H3588"\w* \w hija|strong="H1323"\w* \w de|strong="H4480"\w* \w Jacob|strong="H3290"\w*, \w lo|strong="H3808"\w* \w cual|strong="H3588"\w* \w no|strong="H3808"\w* \w se|strong="H4480"\w* debía \w hacer|strong="H6213"\w*.   
\p
\v 8 Pero \w Hamor|strong="H2544"\w* \w habló|strong="H1696"\w* con ellos y les \w dijo|strong="H1696"\w*: \w El|strong="H1121"\w* \w alma|strong="H5315"\w* \w de|strong="H1121"\w* \w mi|strong="H4994"\w* \w hijo|strong="H1121"\w* Siquem se apegó \w a|strong="H3068"\w* la \w hija|strong="H1323"\w* \w de|strong="H1121"\w* ustedes. Les \w ruego|strong="H4994"\w* \w que|strong="H4994"\w* se la den \w para|strong="H5414"\w* \w que|strong="H4994"\w* sea su esposa.  
\v 9 Emparenten con nosotros. Dennos sus \w hijas|strong="H1323"\w* y \w tomen|strong="H3947"\w* nuestras \w hijas|strong="H1323"\w* \w para|strong="H5414"\w* ustedes.  
\v 10 Vivan con nosotros. La tierra \w está|strong="H1961"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ustedes. Vivan y negocien y adquieran posesión en ella.   
\p
\v 11 \w Y|strong="H3068"\w* Siquem dijo al padre \w de|strong="H5414"\w* ella y \w a|strong="H3068"\w* sus hermanos: \w Halle|strong="H4672"\w* yo \w gracia|strong="H2580"\w* ante ustedes, y \w daré|strong="H5414"\w* lo \w que|strong="H7927"\w* me digan.  
\v 12 \w Aumenten|strong="H7235"\w* \w mucha|strong="H7235"\w* dote \w y|strong="H5921"\w* regalos \w a|strong="H3068"\w* \w mi|strong="H5921"\w* cargo, \w que|strong="H5921"\w* yo \w daré|strong="H5414"\w* \w cuanto|strong="H5921"\w* \w me|strong="H5921"\w* digan, pero denme \w la|strong="H5921"\w* muchacha \w para|strong="H5921"\w* \w que|strong="H5921"\w* sea \w mi|strong="H5921"\w* esposa.   
\s1 La venganza  
\p
\v 13 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Jacob|strong="H3290"\w* \w respondieron|strong="H6030"\w* con doblez \w a|strong="H3068"\w* Siquem y \w a|strong="H3068"\w* \w Hamor|strong="H2544"\w* su padre, porque Siquem violó \w a|strong="H3068"\w* su hermana \w Dina|strong="H1783"\w*.  
\v 14 Les \w dijeron|strong="H1697"\w*: \w No|strong="H3808"\w* \w podemos|strong="H3201"\w* \w hacer|strong="H6213"\w* \w esto|strong="H2088"\w* \w de|strong="H3588"\w* \w dar|strong="H5414"\w* nuestra hermana \w a|strong="H3068"\w* un hombre \w que|strong="H3588"\w* tenga \w prepucio|strong="H6190"\w*, \w porque|strong="H3588"\w* \w es|strong="H1931"\w* \w afrenta|strong="H2781"\w* \w para|strong="H3588"\w* \w nosotros|strong="H1931"\w*.  
\v 15 Solo con \w esto|strong="H2063"\w* \w los|strong="H3605"\w* consentiremos: \w que|strong="H1961"\w* \w sean|strong="H1961"\w* \w como|strong="H3644"\w* \w nosotros|strong="H3605"\w*, al circuncidar \w todo|strong="H3605"\w* \w varón|strong="H2145"\w* de ustedes.  
\v 16 Entonces les \w daremos|strong="H5414"\w* nuestras \w hijas|strong="H1323"\w* y \w tomaremos|strong="H3947"\w* las \w de|strong="H5971"\w* ustedes. Viviremos con ustedes y \w seremos|strong="H1961"\w* un \w pueblo|strong="H5971"\w*.  
\v 17 Pero \w si|strong="H3808"\w* \w no|strong="H3808"\w* aceptan circuncidarse, entonces \w tomaremos|strong="H3947"\w* nuestra \w hija|strong="H1323"\w* y nos \w iremos|strong="H1980"\w*.   
\p
\v 18 Las \w palabras|strong="H1697"\w* \w de|strong="H1121"\w* ellos parecieron buenas \w a|strong="H3068"\w* \w Hamor|strong="H2544"\w* y \w a|strong="H3068"\w* Siquem, \w hijo|strong="H1121"\w* \w de|strong="H1121"\w* \w Hamor|strong="H2544"\w*.  
\v 19 \w No|strong="H3808"\w* demoró \w el|strong="H1931"\w* joven \w en|strong="H3588"\w* hacerlo, \w porque|strong="H3588"\w* \w se|strong="H1931"\w* deleitaba \w con|strong="H3588"\w* \w la|strong="H1931"\w* \w hija|strong="H1323"\w* \w de|strong="H3588"\w* \w Jacob|strong="H3290"\w*. \w Él|strong="H1931"\w* \w era|strong="H1931"\w* \w el|strong="H1931"\w* \w más|strong="H3588"\w* distinguido \w de|strong="H3588"\w* \w toda|strong="H3605"\w* \w la|strong="H1931"\w* \w casa|strong="H1004"\w* \w de|strong="H3588"\w* \w su|strong="H1931"\w* padre.  
\v 20 \w Hamor|strong="H2544"\w* y su \w hijo|strong="H1121"\w* Siquem fueron \w a|strong="H3068"\w* la \w puerta|strong="H8179"\w* \w de|strong="H1121"\w* su \w ciudad|strong="H5892"\w* y \w hablaron|strong="H1696"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hombres|strong="H1121"\w* \w de|strong="H1121"\w* su \w ciudad|strong="H5892"\w*:  
\v 21 \w Estos|strong="H1992"\w* hombres son pacíficos con nosotros. Vivirán en la tierra y negociarán en ella. Pues miren, la tierra \w es|strong="H3027"\w* bastante amplia \w para|strong="H5414"\w* \w ellos|strong="H1992"\w*. \w Tomaremos|strong="H3947"\w* \w sus|strong="H1992"\w* \w hijas|strong="H1323"\w* \w para|strong="H5414"\w* \w que|strong="H1323"\w* sean nuestras esposas, y \w les|strong="H1992"\w* \w daremos|strong="H5414"\w* nuestras \w hijas|strong="H1323"\w*.   
\p
\v 22 Pero solo con \w esto|strong="H2063"\w* consentirán en vivir con \w nosotros|strong="H3605"\w* \w para|strong="H1961"\w* ser un \w pueblo|strong="H5971"\w*: \w que|strong="H5971"\w* \w todo|strong="H3605"\w* \w varón|strong="H2145"\w* nuestro \w sea|strong="H1961"\w* \w circuncidado|strong="H4135"\w*, \w así|strong="H2063"\w* \w como|strong="H1961"\w* \w ellos|strong="H1992"\w* \w son|strong="H1961"\w* circuncidados.  
\v 23 ¿Entonces \w no|strong="H3808"\w* \w serán|strong="H1992"\w* nuestros \w su|strong="H1992"\w* \w ganado|strong="H4735"\w*, \w sus|strong="H1992"\w* bienes y \w todos|strong="H3605"\w* \w sus|strong="H1992"\w* animales? Solo convengamos con \w ellos|strong="H1992"\w*, y vivirán con \w nosotros|strong="H3605"\w*.   
\p
\v 24 \w Todos|strong="H3605"\w* \w los|strong="H1121"\w* \w que|strong="H1121"\w* \w salían|strong="H3318"\w* por \w la|strong="H3605"\w* \w puerta|strong="H8179"\w* \w de|strong="H1121"\w* su \w ciudad|strong="H5892"\w* \w obedecieron|strong="H8085"\w* \w a|strong="H3068"\w* \w Hamor|strong="H2544"\w* y \w a|strong="H3068"\w* su \w hijo|strong="H1121"\w* Siquem, y circuncidaron \w a|strong="H3068"\w* \w todo|strong="H3605"\w* \w varón|strong="H2145"\w* \w que|strong="H1121"\w* \w salía|strong="H3318"\w* por \w la|strong="H3605"\w* \w puerta|strong="H8179"\w* \w de|strong="H1121"\w* su \w ciudad|strong="H5892"\w*.   
\p
\v 25 \w Aconteció|strong="H1961"\w* \w al|strong="H5921"\w* tercer \w día|strong="H3117"\w*, \w cuando|strong="H3117"\w* \w ellos|strong="H5921"\w* \w estaban|strong="H1961"\w* \w más|strong="H5921"\w* adoloridos, \w que|strong="H5921"\w* \w dos|strong="H8147"\w* \w de|strong="H5921"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Jacob|strong="H3290"\w*, \w Simeón|strong="H8095"\w* \w y|strong="H5921"\w* \w Leví|strong="H3878"\w*, hermanos \w de|strong="H5921"\w* \w Dina|strong="H1783"\w*, \w después|strong="H5921"\w* \w de|strong="H5921"\w* \w tomar|strong="H3947"\w* \w cada|strong="H3605"\w* uno su \w espada|strong="H2719"\w*, salieron \w contra|strong="H5921"\w* \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w* desprevenida \w y|strong="H5921"\w* asesinaron \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H1121"\w* \w varones|strong="H2145"\w*.  
\v 26 Asesinaron \w a|strong="H3068"\w* filo \w de|strong="H1121"\w* \w espada|strong="H2719"\w* \w a|strong="H3068"\w* \w Hamor|strong="H2544"\w* y \w a|strong="H3068"\w* su \w hijo|strong="H1121"\w* Siquem, \w sacaron|strong="H3318"\w* \w a|strong="H3068"\w* \w Dina|strong="H1783"\w* \w de|strong="H1121"\w* la \w casa|strong="H1004"\w* \w de|strong="H1121"\w* Siquem y \w salieron|strong="H3318"\w*.  
\v 27 \w Los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Jacob|strong="H3290"\w* pasaron \w sobre|strong="H5921"\w* \w los|strong="H1121"\w* \w muertos|strong="H2491"\w* \w y|strong="H5921"\w* saquearon \w la|strong="H5921"\w* \w ciudad|strong="H5892"\w*, \w por|strong="H5921"\w* \w cuanto|strong="H5921"\w* violaron \w a|strong="H3068"\w* su hermana.  
\v 28 \w Tomaron|strong="H3947"\w* sus \w ovejas|strong="H6629"\w*, su \w ganado|strong="H6629"\w* \w vacuno|strong="H1241"\w* \w y|strong="H1241"\w* sus \w asnos|strong="H2543"\w*, lo que estaba en la \w ciudad|strong="H5892"\w*, lo que estaba en el \w campo|strong="H7704"\w*  
\v 29 y \w toda|strong="H3605"\w* su hacienda. Se llevaron cautivas \w a|strong="H3068"\w* \w todas|strong="H3605"\w* sus criaturas y sus mujeres, y saquearon \w todo|strong="H3605"\w* \w lo|strong="H3605"\w* \w que|strong="H3605"\w* había en las \w casas|strong="H1004"\w*.   
\p
\v 30 Entonces \w Jacob|strong="H3290"\w* dijo \w a|strong="H3068"\w* \w Simeón|strong="H8095"\w* \w y|strong="H5921"\w* \w a|strong="H3068"\w* \w Leví|strong="H3878"\w*: Ustedes \w me|strong="H5921"\w* arruinaron \w al|strong="H5921"\w* hacer \w que|strong="H5921"\w* yo sea odioso ante \w los|strong="H3427"\w* \w habitantes|strong="H3427"\w* \w de|strong="H5921"\w* \w esta|strong="H3427"\w* tierra, \w el|strong="H5921"\w* \w cananeo|strong="H3669"\w* \w y|strong="H5921"\w* \w el|strong="H5921"\w* ferezeo. \w Por|strong="H5921"\w* \w cuanto|strong="H5921"\w* \w tengo|strong="H5921"\w* \w pocos|strong="H4557"\w* \w hombres|strong="H4962"\w*, \w se|strong="H5921"\w* juntarán \w contra|strong="H5921"\w* \w mí|strong="H5921"\w* \w y|strong="H5921"\w* \w me|strong="H5921"\w* atacarán. Yo \w y|strong="H5921"\w* \w mi|strong="H5921"\w* \w casa|strong="H1004"\w* seremos exterminados.   
\p
\v 31 Pero dijeron ellos: ¿Debía \w él|strong="H6213"\w* tratar \w a|strong="H3068"\w* nuestra hermana como \w a|strong="H3068"\w* una prostituta?   
\c 35  
\s1 Jacob en Bet-ʼEl  
\p
\v 1 Entonces \nd ʼElohim\nd* dijo \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w*: \wj \+w Levántate|strong="H6965"\+w*, \+w sube|strong="H5927"\+w* \+w a|strong="H3068"\+w* Bet-ʼEl y vive \+w allí|strong="H8033"\+w*. \+w Haz|strong="H6213"\+w* \+w allí|strong="H8033"\+w* un \+w altar|strong="H4196"\+w* al \+nd \+w ʼEL|strong="H1008"\+w*\+nd* que se te \+w apareció|strong="H7200"\+w* cuando huías \+w de|strong="H6440"\+w* \+w tu|strong="H6213"\+w* hermano \+w Esaú|strong="H6215"\+w*.\wj*   
\p
\v 2 \w Entonces|strong="H5493"\w* \w Jacob|strong="H3290"\w* dijo \w a|strong="H3068"\w* su \w casa|strong="H1004"\w* y \w a|strong="H3068"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* \w que|strong="H3605"\w* estaban \w con|strong="H5973"\w* \w él|strong="H5973"\w*: Quiten \w los|strong="H3605"\w* ídolos \w que|strong="H3605"\w* hay \w entre|strong="H8432"\w* ustedes, purifíquense y muden sus \w ropas|strong="H8071"\w*.  
\v 3 \w Levantémonos|strong="H6965"\w* y \w subamos|strong="H5927"\w* \w a|strong="H3068"\w* Bet-ʼEl. \w Allí|strong="H8033"\w* \w haré|strong="H6213"\w* un \w altar|strong="H4196"\w* al \nd \+w ʼEL|strong="H1008"\+w*\nd* \w que|strong="H3117"\w* me \w respondió|strong="H6030"\w* \w el|strong="H1008"\w* \w día|strong="H3117"\w* de \w mi|strong="H1961"\w* \w angustia|strong="H6869"\w*, y ha \w estado|strong="H1961"\w* \w conmigo|strong="H6213"\w* dondequiera \w que|strong="H3117"\w* he ido.  
\v 4 \w Le|strong="H5973"\w* \w dieron|strong="H5414"\w* \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w* \w todos|strong="H3605"\w* \w los|strong="H3605"\w* ídolos \w que|strong="H7927"\w* tenían \w en|strong="H5973"\w* su \w poder|strong="H3027"\w* y \w los|strong="H3605"\w* zarcillos \w que|strong="H7927"\w* tenían \w en|strong="H5973"\w* sus orejas. \w Jacob|strong="H3290"\w* \w los|strong="H3605"\w* enterró \w debajo|strong="H8478"\w* \w de|strong="H8478"\w* un roble \w que|strong="H7927"\w* estaba \w junto|strong="H5973"\w* \w a|strong="H3068"\w* Siquem.  
\v 5 \w Cuando|strong="H1961"\w* \w salieron|strong="H5265"\w*, \w hubo|strong="H1961"\w* un terror sobrenatural \w sobre|strong="H5921"\w* \w las|strong="H5921"\w* \w ciudades|strong="H5892"\w* circunvecinas, \w y|strong="H5921"\w* \w no|strong="H3808"\w* \w persiguieron|strong="H7291"\w* \w a|strong="H3068"\w* \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H5921"\w* \w Jacob|strong="H3290"\w*.   
\p
\v 6 \w Jacob|strong="H3290"\w*, \w con|strong="H5973"\w* \w todo|strong="H3605"\w* \w el|strong="H1931"\w* \w pueblo|strong="H5971"\w* \w que|strong="H1931"\w* \w lo|strong="H1931"\w* acompañaba, llegó \w a|strong="H3068"\w* \w Luz|strong="H3870"\w*, \w que|strong="H1931"\w* \w es|strong="H1931"\w* Bet-ʼEl, \w en|strong="H5973"\w* tierra \w de|strong="H5973"\w* \w Canaán|strong="H3667"\w*.  
\v 7 \w Edificó|strong="H1129"\w* \w allí|strong="H8033"\w* un \w altar|strong="H4196"\w* \w y|strong="H3588"\w* \w llamó|strong="H7121"\w* \w el|strong="H1008"\w* \w lugar|strong="H4725"\w* ʼEl-bet-ʼEl, \w porque|strong="H3588"\w* \w allí|strong="H8033"\w* se le reveló \nd ʼElohim\nd* \w cuando|strong="H3588"\w* \w huía|strong="H1272"\w* \w de|strong="H3588"\w* \w su|strong="H3588"\w* hermano.   
\p
\v 8 Entonces \w Débora|strong="H1683"\w*, \w ama|strong="H3243"\w* \w de|strong="H8478"\w* crianza \w de|strong="H8478"\w* \w Rebeca|strong="H7259"\w*, \w murió|strong="H4191"\w*. Fue \w sepultada|strong="H6912"\w* \w en|strong="H6912"\w* la parte baja \w de|strong="H8478"\w* Bet-ʼEl, \w debajo|strong="H8478"\w* del roble, y Jacob lo \w llamó|strong="H7121"\w* Roble del Llanto.   
\p
\v 9 \nd ʼElohim\nd* se \w apareció|strong="H7200"\w* \w otra|strong="H5750"\w* vez \w a|strong="H3068"\w* \w Jacob|strong="H3290"\w* después que regresó \w de|strong="H5750"\w* \w Padan-aram|strong="H6307"\w*. Lo \w bendijo|strong="H1288"\w*  
\v 10 \w y|strong="H3588"\w* \nd ʼElohim\nd* le dijo:  
\q1 \wj Tu \+w nombre|strong="H8034"\+w* \+w es|strong="H1961"\+w* \+w Jacob|strong="H3290"\+w*.\wj*  
\q1 \wj \+w Ya|strong="H3068"\+w* \+w no|strong="H3808"\+w* \+w será|strong="H1961"\+w* tu \+w nombre|strong="H8034"\+w* \+w Jacob|strong="H3290"\+w*,\wj*  
\q1 \wj \+w Sino|strong="H3588"\+w* tu \+w nombre|strong="H8034"\+w* \+w será|strong="H1961"\+w* \+w Israel|strong="H3478"\+w*.\wj*  
\q1 \wj \+w Y|strong="H3068"\+w* \+w lo|strong="H3808"\+w* \+w llamó|strong="H7121"\+w* \+w Israel|strong="H3478"\+w*.\wj*   
\p
\v 11 \w Después|strong="H1961"\w* \nd ʼElohim\nd* le dijo: \wj \+w Yo|strong="H4480"\+w* \+w soy|strong="H1961"\+w* \+nd ʼEL-Shadday\+nd*: Fructifica y multiplícate. Una \+w nación|strong="H1471"\+w* y un grupo \+w de|strong="H4480"\+w* \+w naciones|strong="H1471"\+w* \+w procederá|strong="H3318"\+w* \+w de|strong="H4480"\+w* \+w ti|strong="H4480"\+w*, y \+w reyes|strong="H4428"\+w* \+w saldrán|strong="H3318"\+w* \+w de|strong="H4480"\+w* \+w ti|strong="H4480"\+w*.\wj*  
\v 12 \wj La tierra que \+w di|strong="H5414"\+w* \+w a|strong="H3068"\+w* Abraham y \+w a|strong="H3068"\+w* \+w Isaac|strong="H3327"\+w*, te la \+w doy|strong="H5414"\+w* \+w a|strong="H3068"\+w* ti. También la \+w daré|strong="H5414"\+w* \+w a|strong="H3068"\+w* tu \+w descendencia|strong="H2233"\+w*.\wj*  
\v 13 \nd ʼElohim\nd* ascendió \w de|strong="H5921"\w* su lado, \w del|strong="H5921"\w* \w lugar|strong="H4725"\w* \w donde|strong="H5921"\w* \w habló|strong="H1696"\w* \w con|strong="H5921"\w* \w él|strong="H5921"\w*.   
\p
\v 14 \w Jacob|strong="H3290"\w* \w erigió|strong="H5324"\w* una estela \w en|strong="H5921"\w* \w el|strong="H5921"\w* \w lugar|strong="H4725"\w* \w donde|strong="H5921"\w* \w habló|strong="H1696"\w* \w con|strong="H5921"\w* \w él|strong="H5921"\w*, una estela \w de|strong="H5921"\w* piedra. \w Derramó|strong="H3332"\w* una \w libación|strong="H5262"\w* \w y|strong="H5921"\w* \w aceite|strong="H8081"\w* \w sobre|strong="H5921"\w* \w ella|strong="H5921"\w*.  
\v 15 \w Jacob|strong="H3290"\w* \w llamó|strong="H7121"\w* \w el|strong="H1008"\w* \w lugar|strong="H4725"\w* \w donde|strong="H8033"\w* \nd ʼElohim\nd* \w habló|strong="H1696"\w* con \w él|strong="H1008"\w* Bet-ʼEl.  
\v 16 \w Salieron|strong="H5265"\w* \w de|strong="H5750"\w* Bet-ʼEl, y \w cuando|strong="H1961"\w* faltaba una corta distancia \w para|strong="H1961"\w* llegar \w a|strong="H3068"\w* Efrata, le llegó \w a|strong="H3068"\w* Raquel \w el|strong="H1008"\w* trance \w de|strong="H5750"\w* dar \w a|strong="H3068"\w* luz. Su parto \w fue|strong="H1961"\w* difícil.  
\v 17 \w Aconteció|strong="H1961"\w* \w que|strong="H3588"\w* \w en|strong="H3588"\w* \w la|strong="H1571"\w* dificultad \w de|strong="H3588"\w* \w su|strong="H3588"\w* parto, \w la|strong="H1571"\w* partera le dijo: \w No|strong="H3588"\w* \w temas|strong="H3372"\w*, \w que|strong="H3588"\w* \w también|strong="H1571"\w* \w tendrás|strong="H1961"\w* \w este|strong="H2088"\w* \w hijo|strong="H1121"\w*.   
\s1 Muerte de Raquel e Isaac  
\p
\v 18 Ocurrió \w que|strong="H3588"\w* al \w salir|strong="H3318"\w* \w su|strong="H3588"\w* \w alma|strong="H5315"\w*, \w pues|strong="H3588"\w* \w murió|strong="H4191"\w*, lo \w llamó|strong="H7121"\w* \w Benoni|strong="H1126"\w*, \w pero|strong="H3588"\w* \w su|strong="H3588"\w* padre lo \w llamó|strong="H7121"\w* \w Benjamín|strong="H1144"\w*.   
\p
\v 19 \w Así|strong="H1931"\w* Raquel \w murió|strong="H4191"\w*, y \w fue|strong="H1931"\w* \w sepultada|strong="H6912"\w* \w en|strong="H6912"\w* \w el|strong="H1931"\w* \w camino|strong="H1870"\w* de Efrata, \w la|strong="H1931"\w* \w cual|strong="H1931"\w* \w es|strong="H1931"\w* Belén.  
\v 20 \w Jacob|strong="H3290"\w* \w erigió|strong="H5324"\w* una estela \w sobre|strong="H5921"\w* \w su|strong="H1931"\w* \w sepultura|strong="H6900"\w*. \w Ésta|strong="H1931"\w* \w es|strong="H1931"\w* \w la|strong="H1931"\w* estela \w de|strong="H5921"\w* \w la|strong="H1931"\w* tumba \w de|strong="H5921"\w* Raquel \w hasta|strong="H5704"\w* \w hoy|strong="H3117"\w*.   
\p
\v 21 \w Israel|strong="H3478"\w* salió y plantó su tienda más \w allá|strong="H1973"\w* de la torre de Éder.  
\v 22 Mientras \w Israel|strong="H3478"\w* vivía \w en|strong="H3212"\w* \w aquella|strong="H1931"\w* tierra, \w aconteció|strong="H1961"\w* \w que|strong="H1931"\w* \w Rubén|strong="H7205"\w* \w fue|strong="H1961"\w* y \w se|strong="H1961"\w* unió con \w Bilha|strong="H1090"\w*, \w la|strong="H1931"\w* \w concubina|strong="H6370"\w* \w de|strong="H1121"\w* \w su|strong="H1931"\w* padre, \w e|strong="H3068"\w* \w Israel|strong="H3478"\w* \w se|strong="H1961"\w* enteró \w de|strong="H1121"\w* \w ello|strong="H1931"\w*.   
\p
\v 23 Ahora bien, \w los|strong="H1121"\w* \w hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Jacob|strong="H3290"\w* fueron 12.  
\p \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* \w Lea|strong="H3812"\w*: \w Rubén|strong="H7205"\w* \w el|strong="H1121"\w* \w primogénito|strong="H1060"\w*, \w Simeón|strong="H8095"\w*, \w Leví|strong="H3878"\w*, \w Judá|strong="H3063"\w*, Isacar y \w Zabulón|strong="H2074"\w*.   
\p
\v 24 \w Hijos|strong="H1121"\w* \w de|strong="H1121"\w* Raquel: \w José|strong="H3130"\w* y \w Benjamín|strong="H1144"\w*.   
\p
