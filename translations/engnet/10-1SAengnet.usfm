\v 14  Ahimelech \w replied|strong="H6030"\w* \w to|strong="H4428"\w* \w the|strong="H3605"\w* \w king|strong="H4428"\w*, “\w Who|strong="H4310"\w* \w among|strong="H4310"\w* \w all|strong="H3605"\w* \w your|strong="H3605"\w* \w servants|strong="H5650"\w* \w is|strong="H4310"\w* faithful \w like|strong="H1004"\w* \w David|strong="H1732"\w*? \w He|strong="H3605"\w* \w is|strong="H4310"\w* \w the|strong="H3605"\w* \w king|strong="H4428"\w*’s \w son-in-law|strong="H2860"\w*, \w the|strong="H3605"\w* leader \w of|strong="H4428"\w* \w your|strong="H3605"\w* bodyguard, \w and|strong="H6030"\w* \w honored|strong="H3513"\w* \w in|strong="H1004"\w* \w your|strong="H3605"\w* \w house|strong="H1004"\w*!  
