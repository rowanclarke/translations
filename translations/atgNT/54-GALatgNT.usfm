\id GAL - Okphela
\h iGalesha
\toc1 iGalesha
\toc2 iGalesha
\toc3 iGal
\mt2 Ebe ni iPọlu ọ kẹkẹ ghi ẹgbọ
\mt1 IGalesha
\mt2 Eni e miesuọ
\c 1
\p 
\v 1 Mhẹmhẹ iPọlu aghiusomhi na kẹẹ ni ọa khi obọ oyi ẹgbọ mhi te bhale, wẹkhi obọ oyi ọgbọ a te ghie mhẹ, ama obọ oyi iJesu iKirisiti ali Ẹshinẹgba Ita ni ọ rọte eghuli guise ọli le mhi te bhale, mhẹmhẹ mhi kẹkẹ ebe ona.
\v 2 Mhẹmhẹ ali inyọghuo ni e miesuọ nya ni e nu mhẹ la, anye ga tsẹ igbaa nya eyi eni e mie iJesu iKirisiti suọ ni e la ẹoli iGalesha nya.
\p 
\v 3 Ẹshinẹgba itawa ali iJesu iKirisiti Ọnọmhuẹ ọyawa e ka li okhale na ẹ, e ri opfọmhẹ na ẹ.
\v 4 Lọli ọ ri egbọli bhale shi iluasobo shi olamhẹ eyawa ni ọ rọ pfa awa shi ekẹ agbọ ọkhọlọ ali agbọ ingmobe ni awa la ena abi o ghọle Ẹshinẹgba ọyawa ni ọ gbo khi ita awa.
\v 5 Lọli a ri ufumhi ya na ya ramhi ẹlẹ na agbọagbọ. Atsẹ.
\s1 Usomhi onete olese ọa ke la ọ
\p 
\v 6 Abọ e sha mhẹ khi a she gbẹ kie ọni ọ rọte isomhelemhi oyi iKirisiti lu ẹ, a mu egbe nyenẹ ẹ deba usomhi onete olese ni o khili ọda,
\v 7 ni o khia khi ẹa fẹ ga khi usomhi onete. O rọkhasẹ khi ẹgbọ eghuo e she pfi ẹ lo ọmunu ali khi ẹẹ dua ni e mu usomhi onete oyi iKirisiti ukhomhi pfi kpọkẹ
\v 8 Ama ini otseku khi aanye, okekhi agẹni ni ọ rọte iloghie tiemhile, ọ ya gue usomhi olese yẹ ẹ ni o khi ọda shi oni anye kpẹ gue ye ẹ, a zẹ ni a rue ọli shi ọgbọ ni a she pfa ẹzọ mu je ilimhi iriẹriẹ.
\p 
\v 9 Abi anye kpẹ ngme lọli mhi gbo riẹlẹ ngme memena, khi ini ọgbọ ọ bhale ya gue usomhi onete olese yẹ ẹ ni o khi ọda shi oni a miesuọ, ọni a pfa ẹzọ mu ọ pfua agbọagbọ ọ khi!
\p 
\v 10 Eri mhia nono ni ẹgbọ e ba mie shi mhẹ ọ abi khi Ẹshinẹgba mhia nono ni ọ mie shi mhẹ ọ? Abi khi ẹgbọ mhia nono ni mhi ri egbe mu? Ini o khia khi ẹgbọ mhi kiele a nono ni mhi ri egbe mu lọ, mhi aa kha khi aghiusomhi ọyi iKirisiti.
\s1 Ẹshinẹgba ọ lu iPọlu
\p 
\v 11 Mhia nono ni mhi gueyẹ ẹ inyọghuo-mhẹ khi usomhi onete ni mhi rọ ọ tse abọ ọa khi obọ oyi ọgbọ o te bhale.
\v 12 Mhi aa rọte obọ oyi ọgbọkhọghuo mie ọli, wẹkhi eri a sẹsẹ mhẹ luẹ. Imẹ-alo mhi te mie ọli rọte obọ oyi iJesu iKirisiti.
\p 
\v 13 Irari khi a she kpẹ suọ mhẹ eko abi mhi rọ la ugamhi oyi ẹgbọ iJu, abi mhi li lolo rọshẹka ẹ mu okhọli vule shi ena igbaa oyi eni e mie iJesu iKirisiti suọ oyi Ẹshinẹgba ọ. Mhi rọshẹka ini mhi yese imiesuọ oyẹwẹ-a.\f + \fr 1:13 \ft Li zẹ \fq Ika 8.3; 22.4-5; 26.9-11\f*
\v 14 Mhi fu shi oni ugamhi ẹgbọ iJu dọsẹ ebubu ẹgbọ ni anye la otu oghuo, ali mhi mhọli ọmuegbe shi ishi eyi eni e bia mhẹ.\f + \fr 1:14 \ft Li zẹ \fq Ika 22.3\f*
\v 15 Ama abi Ẹshinẹgba ni ọ rọte ekẹ zẹ mhẹ kẹẹ neni inyẹmhẹ ọ bia mhẹ, ni ọ lu mhẹ rọte okhale oyọli. Egbe mu ọli khi
\v 16 ọ ri omiọli khasẹ mhẹ ni a bhale ya ẹ khi mhi ri ọli tsabọ ifuabọ ẹgbọ iJẹta. Mhi aa vu ya mhila ọgbọkhọghuo,\f + \fr 1:16 \ft Li zẹ \fq Ika 9.3-6; 22.6-10; 26.13-18\f*
\v 17 wẹkhi eri mhi je ẹoli iJerusalẹmu ya mẹ eni e khi ighiusomhi na kẹẹ, neni ọ zẹ mhẹ, ama eri mhi je ekẹ Arebia ali mhi tigbe nyenẹ egbe jele ẹoli iDamasikọsi.
\p 
\v 18 Abi ikpe esẹ e rọ dọsẹ se, mhi rọ tigbe nga iJerusalẹmu ni mhẹmhẹ ali iPita anye lẹsẹ egbe, mhi nu ọli la ogbẹlẹ igbẹshe.\f + \fr 1:18 \ft Li zẹ \fq Ika 9.26-30\f*
\v 19 Mhi aa mẹ aghiusomhi na kẹẹ ọlese sẹ khi iJemhisi ni ọ khi inyọghuo Ọnọmhuẹ.
\p 
\v 20 Mhia gueyẹ ẹ ukpẹloe Ẹshinẹgba khi emini mhi kẹkẹ ẹ ghi ẹ ẹa khi ẹgbhọli.
\v 21 Ẹlẹlese, mhi je ekẹ iSiria ali ekẹ iSilisha.
\v 22 Ọgbọkhọghuo ọa la elemhi igbaa nya eyi eni e mie iJesu iKirisiti suọ na ekẹ iJudia ni ọ mẹ mhẹ ukpẹloe ghue.
\v 23 Eko ni e lẹsẹ suọ khi: “Ọni ọmọse ni ọ kpẹ mu okhọli vule shi awa ọ, eri ọ ke tsabọ oni ungmemhi irudunga oni ọ kpẹ dua ni luẹ yese-a.”
\v 24 E kuẹghiẹ Ẹshinẹgba itobọ oyẹmhẹ.
\c 2
\s1 Ighiusomhi na kẹ e mie IPọlu
\p 
\v 1 Ikpe igbẹne e dọsẹ, mhi nga iJerusalẹmu. Utona, iBanabasi ọ deba mhẹ. Mhi li gbo rue iTatọsi.\f + \fr 2:1 \ft Li zẹ \fq Ika 11.30; 15.2\f*
\v 2 Eri mhi nga obọ ni mhi rọ ri imẹalo ni mhi mẹ gbe akanya, ali ni mhi rọkhasẹ wẹ usomhi onete ni mhi rọ ọ tse abọ ifuabọ ẹgbọ iJẹta. Ama eri mhi bẹna riẹlẹ ona khasẹ ẹgbọ ni e khi eni ẹẹ ralo, irari khi ulishi oo mu mhẹ ini ikanya ni mhi kpe gbe ghue ali ena ikpukhokho eyẹmhẹ e ya khi afuẹ.
\v 3 ITatọsi ni ọ nu mhẹ kia, aa liẹ khi ọ mema shẹlẹ-a, abi ọ tseku khi ọngi iGiriki.
\v 4 Eri ingme oshẹlẹ onana o lasele irari khi inyọghuo eghuo ena ẹgbhọli e bẹna lo anye ifuabọ, ni e ba mẹ asha guanọ udi ẹpfua ni iJesu iKirisiti ọ rọ na anye, mu anye ighumha.
\v 5 Ama anye ẹa tigbe lama na wẹ ukuku ẹghẹghẹ ni a rọ bhale ya ẹ khi igẹsikia oyi oni usomhi onete o nu ẹ kie la.
\p 
\v 6 Ẹgbọ eni ẹ bino egbewẹ khi wẹwẹ e mu ẹloe, ẹa mu mhẹ ẹloe, irari khi Ẹshinẹgba ọa mhuẹ ọni ọ kpe mhẹ nẹ, ali khi abi ọgbọ li edato ọa rọli ẹ gue ọgbọ ẹzọ. Eni ẹgbọ eghọghọ ẹa mhuẹ emini e rọ ma mhẹ usomhi onete.\f + \fr 2:6 \ft Li zẹ \fq iDẹut 10.17\f*
\v 7 Ama eri e mẹ khi a she ri akanya itsabọ usomhi onete ghi ẹgbọ iJẹta nga mhẹ obọ, ẹzẹzẹ abi a li li ghie iPita ghi ẹgbọ iJu.
\v 8 Irari khi abi Ẹshinẹgba ọ li nu iPita ẹ gbe akanya abi aghiusomhi na kẹẹ ni a ghie ghi ẹgbọ iJu, ighọ ọ li nu mhẹ gbe abi aghiusomhi ni a ghie ghi ẹgbọ iJẹta.
\v 9 IJemhisi ali iPita ali iJọni ni a lẹsẹ khi wẹwẹ e mu oni igbaa oyi eni e mie iJesu iKirisiti suọ mhuẹ, e mẹ khi Ẹshinẹgba ọ ri isomhopfa na kẹ na mhẹmhẹ ali iBanabasi, e rọ lama na anye, anye ke tsabọ oni usomhi onete oghuo ye ẹgbọ iJẹta. Wẹwẹ e tsabọ ye ẹgbọ iJu.
\v 10 Emini e ngme khi anye ke kpaghiẹ ẹgbọ ni ẹa mhọli obọ, ighọ mhi li rọshẹka riẹlẹ ọli.
\s1 IPọlu ọ gueyẹ iPita khi ọa guẹ riẹlẹ
\p 
\v 11 Abi iPita ọ rọ bhale Atiọki, mhi gueyẹ ọli gboo ghemhẹ ghe ẹ khi ọa guẹ kia, irari khi ọ lue.
\v 12 Neni ẹgbọ ni iJemhisi ọ ghie usomhi, e bhale, iPita ọ kpẹ nu ẹgbọ iJẹta a le eminale kugbe, ama abi eni ẹgbọ e rọ bhale, ọ ti je ukhokho na iJẹta eghọ, irari khi ulishi oyi ẹgbọ ni ẹ liẹ khi ọgbọ ọ mema shẹlẹ-a oo mu ọli.
\v 13 Ẹgbọ iJu eni e miesuọ enekpọle e li kuma ọli ọ riẹlẹ ikokoalo, ya ramhi khi oni ikokoalo o li ri iBanabasi kuma wẹ ọ.
\p 
\v 14 Abi mhi rọ mẹ khi, ẹa rọte odẹ igẹsikia abi oni usomhi onete o ngme, mhi la ukpẹloe eni ẹgbọ liẹ iPita, “Ọgbọ iJu u khi, ama wa ngeli abi ọgbọ iJẹta. Elọ o zẹ ni u ke rọ nono ni i ri itoto mu ẹgbọ iJẹta ke riẹlẹ ighuighuẹ eyi ẹgbọ iJu?
\p 
\v 15 “Ẹgbọ iJu a bia awa, awa aa khi ẹgbọ iJẹta ena olamhẹ,” abi a lu wẹ.
\v 16 Lẹsẹ khi aa ya pfa na ọgbọ irari khi ọ ri ushi a gbe akanya, ama itobọ irudunga iJesu iKirisiti. Ighọ awa li li ri udu nga iJesu iKirisiti ni a rọ pfa na awa. Ọa khi itobọ irushi-gbe akanya, irari khi ọgbọkhọghuo ọa la ọ ni a ya pfa na irari khi ọ dobẹ ri ushi a gbe akanya.\f + \fr 2:16 \ft Li zẹ \fq Iwolo 143.2; iRom 3.20,22\f*
\v 17 “Abi awa liẹ dua ni awa khi eni a pfa na elemhi iKirisiti, eri o rọkhasẹ khi ena olamhẹ awa khi. Oghọ khi eri iJesu ọ mu ẹ ma olamhẹ? Iiye o, ọa khi ighọ!
\v 18 Mhi kha riẹlẹ emini mhi guọghọ-a rọkọ, eri mhi rọkhasẹ khi ọgbushia mhi khi.
\v 19 Irari khi rọte ushi mhi te ghu pfa ushi, ni mhi dobẹ la ọ na Ẹshinẹgba.
\v 20 A she li ta mhẹ ma apfida abi a li ta iJesu ma apfida, ali khi aa ke khi mhẹmhẹ mhi ke la agbọ, ama iKirisiti ọ ke la agbọ oyẹmhẹ. Agbọ ni mhi la elemhi idiegbe oyẹmhẹ memena, irudunga Omi Ẹshinẹgba mhi te la ọ, ni ọ nono ingme oyẹmhẹ, ni ọ ghu-a, ni ọ ri agbọ oyọli na mhẹ.
\v 21 Mhi aa ri obọ gbe isomhelemhi oyi Ẹshinẹgba nyẹ, irari khi ini o khia khi itobọ iri-ushi-gbe akanya ọgbọ rọ pfuasẹ lọ, eghuli afuẹ iKirisiti ọ ghu!”
\c 3
\s1 Irudunga tsẹ o khi odẹ imiepfuese
\p 
\v 1 Ẹẹ eyẹghẹ ẹgbọ iGalesha! Ọghuo ọ ri ogbhọ na ẹ le? Ukpẹloe oyẹẹ a la ri iJesu iKirisiti khasẹ gboo khi eri a ta li ma apfida.
\v 2 Mhia nono ni mhi rọte obọ oyẹẹ lẹsẹ emhi oghuo. Eri a mie Ayẹmhẹ oyi Ẹshinẹgba irari khi a ri ushi gbe akanya, abi khi irari khi a mie emini a suọ suọ?
\v 3 Eeyẹghẹ a ghọ khi? A kha ri Ayẹmhẹ oyi Ẹshinẹgba gba ekẹle se, a tigbe ẹ dua ni a ri ekpabọ ọgbọ gbe oni akanya pfo?
\v 4 Eri a na lina mẹ osoli shi afuẹ? Ini afuẹ a mẹ osoli,
\v 5 Ayẹmhẹ oyi Ẹshinẹgba ni ọ rọ na ẹ, ali ikanya ọshabọ ni ọ gbe iteva oyẹẹ, itobọ khi a ri Ishi eyi iMosisi gbe akanya lọ abi khi irari emini a mie ingme oyi iKirisiti suọ, o zẹ ni ọ rọ riẹlẹ ena?
\p 
\v 6 A sa ingme oyi Aburaamu ghue, “Eri ọ mie Ẹshinẹgba suọ ni a rọ pfa na li khi ọ pfuasẹ.”\f + \fr 3:6 \ft Li zẹ \fq Igbae 15.6; iRom 4.3\f*
\v 7 A lẹsẹ ọli shọ, khi ẹgbọ ni e miesuọ, e khi imi Aburaamu.\f + \fr 3:7 \ft Li zẹ \fq iRom 4.16\f*
\v 8 Ebe-no-pfuasẹ o kpẹ ngme ọli shi ekẹ khi Ẹshinẹgba ọ ya rọte irudunga oyi ẹgbọ iJẹta pfa na wẹ, ọ gue oni ungmemhi yẹ Aburaamu ọọ li, “A ya rọte obọ oyẹ khivọsẹ na ishishi ena ekagbọ nya.”\f + \fr 3:8 \ft Li zẹ \fq Igbae 12.3\f*
\v 9 Irarighọ, eni e mhọli irudunga a ya khivọsẹ na abi a li khivọsẹ na Aburaamu, ikhi ọmọse irudunga.
\p 
\v 10 Ẹgbọ nya ni e ri egbe da iri-ushi gbe akanya, a pfi unu na, irari khi a kẹkẹ ọli khi, “Unu a pfi na ọgbọ ni ọa da ri emini a kẹkẹ shi ebe ushi nya gbe akanya.”\f + \fr 3:10 \ft Li zẹ \fq iDẹut 27.26\f*
\v 11 Mena, aa mẹ ọgbọkhọghuo ni a pfa na odalo Ẹshinẹgba irari khi ọ ri ushi gbe akanya, itobọ khi, “Eni e pfuasẹ, irudunga o rẹ wẹ ya la agbọ.”\f + \fr 3:11 \ft Li zẹ \fq Abak 2.4\f*
\v 12 Odẹ irudunga o kiọda shi odẹ ushi, ni ọọ, “Ọni ọ da ri ushi gbe akanya, ushi ọ rọ ya la agbọ.”\f + \fr 3:12 \ft Li zẹ \fq iLẹv 18.5\f*
\v 13 Eri iKirisiti ọ pfa awa shi ekẹ elemhi ipfiunu-a oyi ushi abi ọ li khi ọni a pfi unu na irari oyawa, irari khi a kẹkẹ ọli khi, “Unu a pfi na ọgbọkpa ni a soli-a shi ọọra.”\f + \fr 3:13 \ft Li zẹ \fq iDẹut 21.23\f*
\v 14 Eri ọ pfa awa shi ekẹ ni ikhivọsẹ eyi Aburaamu e ramhi ẹgbọ iJẹta egbe, rọte iJesu iKirisiti, ni awa mẹ ikhivọsẹ oyi ishobọ Ayẹmhẹ-nọ-pfuasẹ rọte irudunga.
\s1 Oni Ushi ali oni ishobọ
\p 
\v 15 Inyọghuo a zẹ mhẹ ri angeli ẹlẹkpa rue irọkhọkhọ. Ẹzẹzẹ abi ọgbọkhọghuo ọa li dobẹ ya shishi ọ-a, wẹkhi eri ọ dobẹ ya rọ ma ilamashọ, ni Ẹshinẹgba ọ nu ọgbọ lama shọ, ni o she gbọla migha. Ighọ oni ingme onana o li.
\v 16 Oni ishobọ, Aburaamu ali omiọli a shi ọli na. Ebe-no-pfuasẹ ọa liẹ, “Ali imiọli,” ni e khi ebubu ẹgbọ, ama, “Ali omiẹ,” ni ọ khi ọgbọ ọghuo, ni ọ khi iKirisiti.\f + \fr 3:16 \ft Li zẹ \fq Igbae 12.7\f*
\v 17 Emini mhi ri ona ngme khi, ushi ni a tigbe rọ lasele abi ikpe egbhuẹ uye ali uye ali igbe (430) e rọ dọsẹ se, ọa guọghọ oni ishobọ ni Ẹshinẹgba ọ shi-a, ni a yele oni ekha-a.\f + \fr 3:17 \ft Li zẹ \fq Okiali 12.40\f*
\v 18 Ini oni ugu o migha shi ushi lọ, ọa kha ke migha nga ishobọ, Ama rọte isomhelemhi oyi Ẹshinẹgba ọ rọ shi oni ishobọ na Aburaamu.\f + \fr 3:18 \ft Li zẹ \fq iRom 4.14\f*
\p 
\v 19 Elọ o zẹ ni a rọ ri ushi bhale? Eri a ri ushi bhale ni a rọ rọkhasẹ khi awa lamhẹ. Eri a rọli shi ekẹ ramhi ẹghẹghẹ ni omiomi Aburaamu ni a riẹlẹ ishobọ khẹ ọ rọ ya bhale. Ẹshinẹgba ọ ri oni ushi na igẹni tiemhile na iMosisi ni ọ la iteva ọgbọ ali Ẹshinẹgba.
\v 20 Awa kha da ngme ingme ọmigha-na ọgbọ ne, o rọkhasẹ khi ẹgbọ aava e mema lasele shi aghọ, Ama Ẹshinẹgba lọlighuo ọ shi oni ishobọ ona, Ẹshinẹgba ọghuo, ọ khi.
\s1 Emini ushi o migha shi
\p 
\v 21 Eri ushi o ke a zu ishobọ oyi Ẹshinẹgba odẹ? Iiye o! Irari ini eri a ri ushi bhale ni o ri agbọ ke na ọgbọ lọ, a kha ri irarighọ pfa na ọgbọkpa ini ọ ri ushi gbe akanya.
\v 22 Ama Ebe-no-pfuasẹ o ngme ghọ khi ekpabọ olamhẹ o mhẹsẹ a na agbọ nya, ni a ba bhale ya ẹ khi emini a shobọ, ni a rọ ọ na ọgbọ rọte obọ oyi iJesu iKirisiti ni a rọli na ẹgbọ ni e miesuọ.
\p 
\v 23 Neni oni irudunga o bhale, eri ushi o mu awa ighumha, o pfi awa okpẹ ramhi ni irudunga o rọ bhale.
\v 24 Eri a ri ushi na awa ni o sẹsẹ awa odẹ ramhi ni iKirisiti ọ rọ bhale, ni a rọte irudunga pfa na awa.
\v 25 Memena abi ẹghẹghẹ irudunga o rọ bhale, ushi ọa ke ẹ sẹsẹ awa odẹ.
\s1 Imi Ẹshinẹgba
\p 
\v 26 Ẹẹ nya, imi Ẹshinẹgba a khi rọte irudunga oyi iJesu iKirisiti.
\v 27 Irari khi ẹẹ nya ni a batazi elemhi iKirisiti, a she ri iKirisiti sọ.
\v 28 Ikhiọda ọa la ọ na ọgbọ iJu ali ọgbọ iJẹta, wẹkhi ikhiọda o la oghumha, ali ọni ọa khi oghumha, wẹkhi ọmọse ali ọkpotso, irari khi ẹẹ nya, ọghuo a khi shi iJesu iKirisiti ọ.
\v 29 Ini a khi ọnayi iKirisiti, ẹghẹghẹ aghọ imi Aburaamu a khi, a khi eni e mhọli okemhi shi oni ishobọ.\f + \fr 3:29 \ft Li zẹ \fq iRom 4.13\f*
\c 4
\p 
\v 1 Emini mhia ngme khi, ini ọni oni ugu o gọ lu ọ da kie khi ukuku ọmọ ne, ọa kiọda shi oghumha ọ, ama lọli ọ kie ya mhọli eni apfẹ nya.
\v 2 Eri ọ kiele ya la obọ oyi eni e ri ẹloe ẹ khu ọli, ali eni a ri eni ugu nga obọ ne, ya ramhi ẹghẹghẹ ni itali ọ shi shi ekẹ, ni ọ rọ ya womhẹ ẹloe.
\v 3 Ighọ o li khi shi awa egbe. Ighumha eyi iyẹmhẹ ni ẹ mhẹsẹ na agbọ nya, e mhẹsẹ ẹ na awa neni awa mhọli iwomhẹloe elemhi ayẹmhẹ.
\v 4 Ama abi oni ẹghẹghẹ o rọ ramhi, Ẹshinẹgba ọ ghie omiọli ni ọkpotso ọ bia, ni a bia shi ẹghẹghẹ ushi,
\v 5 ni ọ rọ tsumhi ẹgbọ ni ushi o mhẹsẹ ẹ na, ni awa tẹ eni a lu Imi Ẹshinẹgba.
\v 6 Itobọ khi a khi imiọli, Ẹshinẹgba ọ rọ ghie Ayẹmhẹ oyi Omiọli bhale udu oyawa, Ayẹmhẹ ni ọ tsẹsẹ liẹ, “Itamhẹ, Itamhẹ.”
\v 7 Itobọ ona, wa a ke khi oghumha ama omiọli, abi u ke rọ khi omiọli eghọ, Ẹshinẹgba ọ she rẹ mie oni ishobọ. \f + \fr 4:7 \ft Li zẹ \fq iRom 8.15-17\f*
\s1 Ọmuegbe ni iPọlu ọ mhọli na ẹgbọ iGalesha
\p 
\v 8 Ẹghẹghẹ ni o dọsẹ ni aa rọ kpẹ lẹsẹ Ẹshinẹgba, a khi ighumha eyi emini e khi ilitsa ni ẹa khi Ẹshinẹgba.
\v 9 Ama memena ni a ke rọ lẹsẹ Ẹshinẹgba, ali abi Ẹshinẹgba ọ ke rọ lẹsẹ ẹ ena, elọ o zẹ khi a nono ni a nyenẹ egbe gbo deba iyẹmhẹ afuẹ ni ẹa mhuẹ ekpabọ? Elọ o zẹ ni a rọ ọ nono ni e gbo mu ẹ ighumha utonuzi-eva?
\v 10 A ri ẹloe ẹ shi ogbẹlẹ na kẹ ali iki ali ẹghẹghẹ ali ikpe.
\v 11 Ulishi ọọ mu mhẹ irari khi o li mhẹ ẹloe abinẹ khi eri mhi pfuse ẹghẹghẹ-a shi ẹ egbe shi afuẹ.
\p 
\v 12 Mhia lema ẹ, inyọghuo a li abi mhi li, irari khi eri mhi li abi a li. Aa li mhẹ ingmobe.
\v 13 A yelele, khi elemhi umha ze mhi la ni mhi rọ tse abọ usomhi onete yẹ ẹ odo-odẹ.
\v 14 Abi o tseku khia khi ughuamhi oyẹmhẹ khi eri o li abi anasẹmhẹ na ẹ, aa ri ẹloe gbe mhẹ, aa kie mhẹ. Ochoghọ, eri a kpe abọ mie mhẹ abinẹ khi agẹni Ẹshinẹgba mhi khi, abi a kha li mie iJesu iKirisiti.
\v 15 Elọ o li oghẹlẹ oyẹẹ? Mhi dobẹ ya pfi ọtsẹlẹ khi ini o zẹ ya li lọ khi a kha ga vuọnyọ ikpamhi alo eyẹ ẹ na mhẹ.
\v 16 Mhi she mele ọbe ẹ-a irari khi mhi gue igẹsikia ye ẹ?
\p 
\v 17 Ẹgbọ ẹ nono ni e ti ẹ ma egbe, ama ọa khia odẹ ni o ti o khi. Emini ẹ nono khi ni e rẹ ẹ mele epfẹsẹ-a shi anye ọ, ni a khi eni e mhọli ọmuegbe na wẹ.
\v 18 O ti ni ọgbọ ọ mhọli ọmuegbe ini o da khi eminete ọ mhọli ọli shi, ali ni ọ ke mhọli ọli ẹghẹghẹ kpa, ọa khi ini mhi da lẹsẹ la aghọ tsẹ.
\v 19 Imimhẹ, egbe ẹ to mhẹ shi ingme oyẹẹ, abi ọkpotso ni oku ọọ to, ni a rọ bhale ya ẹ khi a mẹ iKirisiti agbọ oyẹẹ.
\v 20 Abi a khẹ khi mhi nu ẹ la, ni mhi mu uruli oyẹmhẹ pfi, irari khi egbe e pfọ mhẹ-a shi ingme oyẹ ẹ!
\s1 Ega ali iSera
\p 
\v 21 A gueyẹ mhẹ ghue, ikhi ẹẹ ni a nono ni a khi eni ushi o mhẹsẹ a na, a lẹsẹ abi ushi o ngme?
\v 22 Irari khi a kẹkẹ ọli khi Aburaamu, ọ bia eniyẹ emọse aava, ọghuo ọọ khi omi ọkpotso oghumha, ọnọkpọle ọ khi omi ọgbọ.\f + \fr 4:22 \ft Li zẹ \fq Igbae 16.15; 21.2\f*
\v 23 Ọmọ ni oghumha ọ bia na li, eri a bia li rọte odẹ na tsẹ, ama ọni egbegbi ọkpotso ọ bia, a bia li rọte odẹ ishobọ.
\p 
\v 24 Eni ingme ena nya e mhọli emini e migha shi, irari khi ikpotso aava ena, ilama na egbe eva e khi. Ilama-negbe oghuo o khi ona ukhomhi ute iSinai, ọ bia eniyẹ ni e ya khili ighumha. Lọli khi Ega.
\v 25 Mena, Ega ọ migha shi ute iSinai na ekẹ Arebia ni o khili ẹoli iJerusalẹmu, irari khi eri ọ nu imiọli khili ighumha.
\v 26 Ama inyọ awa ọ khi ẹoli iJerusalẹmu ni o la odane, omi ọgbọ ọ khi.
\v 27 Irari khi a kẹkẹ ọli, ẹ li:
\q1 “Ke ghẹlẹ, yẹyẹ aga
\q2 ni ọa bia eniyẹ,
\q1 ri oghẹlẹ tsẹsẹ leghe,
\q2 yẹyẹ ni oku ọa to ghue,
\q1 irari khi ọkpotso ni a kie,
\q2 ọ mhọli eniyẹ ni e bu
\q2 dọsẹ ọkpotso ni ọ mhọli ọdọ.”\f + \fr 4:27 \ft Li zẹ \fq Aza 54.1\f*
\p 
\v 28 Memena, inyọghuo-mhẹ, eniyẹ ishobọ a li khi ẹzẹzẹ abi Aziki ọ li khi ọmọ ishobọ.
\v 29 Abi o kpẹ li oni ẹghẹghẹ, ni ọmọ ni a bia elemhi idiegbe, ọọ li mu okhọli vule shi ọmọ ni a ri ekpabọ Ayẹmhẹ oyi Ẹshinẹgba bia ọ, ighọ o kie li memena.\f + \fr 4:29 \ft Li zẹ \fq Igbae 21.9\f*
\v 30 Ama sẹ Ebe-no-pfuasẹ o ngme? Ọọ, “Khu ọkpotso oghumha ali omiọli vu, irari khi omi ọkpotso oghumha ọa tigbe ya nu omi egbegbi ọkpotso kemhi ugu.”\f + \fr 4:30 \ft Li zẹ \fq Igbae 21.10\f*
\v 31 Irarighọ, inyọghuo, awa aa khi eniyẹ eyi ọkpotso oghumha ama eniyẹ eyi ọkpotso ni ọ khi omi ọgbọ.
\c 5
\s1 Irueọle ni o la obọ oyi iKirisiti
\p 
\v 1 IKirisiti ọ she rue awa ọ le. Irarighọ, a migha gbaa shi oni irueọle, a khi ke gbo zẹ ni a gbo ya nyenẹ ri egbe ẹ khi ighumha oyi ushi.
\p 
\v 2 A ghe i! Mhẹmhẹ iPọlu, mhi gue ẹ yẹ ẹ khi, akanya ni iKirisiti ọ gbe ọa ke ya mhọli elele okhọghuo na ẹ, ini a ya shẹlẹ-a.
\v 3 Mhi gbo gue ẹ ye ọgbọ ni ọ da zẹ ni a shẹlẹ ọli-a ne, ọ mema ya ri ushi nya gbe akanya.
\v 4 Ẹẹ ni a dua ni a khi eni a pfa na rọte iri-ushi gbe akanya, aa ke mhọli obọ shi ikanya ni iKirisiti ọ gbe, a she de okhale oyọli-a.
\v 5 Ama rọte irudunga awa te lolo migha a khẹ ipfuasẹ ni awa ri udu nga rọte elemhi Ayẹmhẹ-nọ-pfuasẹ.
\v 6 Irari khi elemhi iJesu iKirisiti, oshẹlẹ ali umha-shẹlẹ-a ẹa mhuẹ eleli. Emini o mema mu egbe khi irudunga ni o mhọli inono.
\p 
\v 7 A kpẹ guẹ ẹ kia. Ọghuo ọ mu alo nyenẹ ni aa ke rọ ọ deba igẹsikia?
\v 8 Ọni ọ lina mu ẹ alo nyenẹ, ọa rọte obọ oyi iKirisiti ọni ọ lu ẹ bhale.
\v 9 “Ọgbọ ọbe ọtuọghuo ọ dobẹ ya yese ẹgbọ eni e bu-a. Eri ọ li abi umiesobọ oghuo, ni o ri oili ẹ gbolo enekpọle-a.”\f + \fr 5:9 \ft Li zẹ \fq 1 iKọri 5.6\f*
\v 10 Ama mhi regbenga ẹ khi eyi Ọnọmhuẹ a khi. Onana o rẹ mhẹ lẹsẹ gboo khi emini mhi gueyẹ ẹ a ya riẹlẹ, khi aa ya riẹlẹ emini ọgbọẹse ọ gueyẹ ẹ. Ọgbọ ni ọọ nasẹ ẹ, ọ ya ri ukhomhi kpẹ ọ, ọnini ọ riẹ khi.
\p 
\v 11 Inyọghuo, ini ishẹlẹ-a mhi kiele rọ tse abọ lọ, abi ẹgbọ eghuo ẹẹ ngme, elọ a mu okhọli vule shi mhẹ ọ kẹ shi? Ini o khi ighọ lọ, ungmemhi apfida ọa kha ke ri elemhi ke bi.
\v 12 Ẹgbọ ni e na ri ingme oshẹlẹ a nasẹ ẹ ena, mhi kha ga liẹ e bie wali egbewẹ-a.
\s1 Agbọ na elemhi Ayẹmhẹ
\p 
\v 13 Ẹẹ oyẹẹ, inyọghuo-mhẹ, eri a lu ẹ ni a la elemhi ẹpfua. Ama a khi zẹ ni a ri oni ẹpfua ona ke riẹlẹ emini idiegbe olamhẹ oyẹ ọọ nono. Ochoghọ a ri inono ke ga egbe ẹ.
\v 14 Irari khi emini a rọ zẹ ushi nya ukhomhi khi, “Nono ọnuzava ọyẹ abi u li nono egbiẹ.”\f + \fr 5:14 \ft Li zẹ \fq iLẹv 19.18\f*
\v 15 Ini a mu okhọli vule ẹ shi egbe ẹ ọ, ni a rọ ọ khu egbe ẹ, a mhuẹ ẹgbhẹ ini a khi a ya pfuse egbe ẹ-a.
\p 
\v 16 Emini mhia ngme khi, a ke kia okiali elemhi Ayẹmhẹ, ẹghẹghẹ aghọ aa ya riẹlẹ ọghuẹmhẹ oyi idiegbe olamhẹ.
\v 17 Irari khi idiegbe, ọbe Ayẹmhẹ o khi, ali khi emini Ayẹmhẹ ọ nono, eri ẹ zu ọghuẹmhẹ idiegbe olamhẹ odẹ. Wẹwẹ ava-ava ọbe e khi shi egbe ọ, lọli o zẹ khi u waa dobẹ a riẹlẹ emini u wa nono ni u riẹlẹ.\f + \fr 5:17 \ft Li zẹ \fq iRom 7.15-23\f*
\v 18 Ama ini Ayẹmhẹ ọ rẹ ẹ kia, waa tigbe ya riẹlẹ oghumha ọyi ushi.
\p 
\v 19 Emini ikanya idiegbe olamhẹ ẹẹ gbe na; Itsẹbọ, ikanya ichimhi na itsẹbọ ali angeli efiala,
\v 20 ikhumhi igaga, ali ogbhọ ipfipfi, ibiselemhi, umha lama a na egbe, ofuma ikpekpe, ofu imhọli, ikanya ukphẹ, elemhi ibibi, ikemhi egbe,
\v 21 Idegbe-ọkọnyọ, idonyọ dọsẹ, iye-ukue ni a la li itsẹbọ, ali emhi elese eghọghọ. Mhi tse agua ye ẹ, abi mhi kpẹ li tse ọli ye ẹ, khi ẹgbọ ni e da a ngeli angeli eghọghọ ne khi ẹa ya mhọli okemhi shi Eghiele oyi Ẹshinẹgba.
\p 
\v 22 Emini Ayẹmhẹ ọ rọ ọ lasele khi; Inono, oghẹlẹ, opfọmhẹ, irabọmudu, isomhelemhi, onete, izẹ-ri-egbeda,
\v 23 Ipfọmhẹ, iguẹ-regbekia. Ushi ọa ya mu ọgbọ shi ọ ini ọ riẹlẹ enana nya.
\v 24 Eni e khi eyi iJesu iKirisiti e she rọte idiegbe olamhẹ oyẹwẹ ali ọghuẹmhẹ eyẹwẹ nya ma apfida.
\v 25 Aborọkhia khi Ayẹmhẹ ọ ri awa a kia eghọ, awa ke deba ẹtẹ-awẹ eyọli.
\v 26 Awa khi ke mu egbawa ẹloe dọsẹ odẹ, yẹsẹ elemhi ke bi egbe, ni o ri awa a ke kpe ofuma deba egbe.
\c 6
\s1 A ke riẹlẹ onete na ẹgbọ nya
\p 
\v 1 Inyọghuo-mhẹ, a kha bhale ya ẹ khi a mu ọgbọkhọghuo shi olamhẹ, ẹẹ ni a la elemhi ayẹmhẹ, a kuegbe-a sheshe ọli shi odẹ fiẹ. Ama a ke tọ egbe ẹ ọkpẹ, ini a khi li de pfilo imufẹ.
\v 2 A kpaghiẹ egbe ẹ itsua, ini a li ighọ, a ya riẹlẹ ọghuẹmhẹ oyi iKirisiti.
\v 3 Ini ọgbọ ọ dabi khi lọli mu ẹloe, ni a rọ bhale ya ẹ khi ọa khi emhikhọghuo, egbọli ọọ di.
\v 4 Ọgbọgbọ ọ ke mu angeli eyọli fẹ ni ọ bino ini e ti. Oni ẹghẹghẹ, ọ tigbe mẹ asha a titi egbọli. Ọ khi ri egbọli khọkhọ ọgbọẹse.
\v 5 Ọgbọgbọ ọ tsua itsua eyọli.
\p 
\v 6 A ke ri eminete nya somhi ọgbọ ni ọọ sẹsẹ ẹ emini Ẹshinẹgba ọ ngme.
\p 
\v 7 Khi di egbe ẹ. Ọgbọkhọghuo ọa dobẹ ya ghagha Ẹshinẹgba. Emini ọgbọ ọ rọ kọ, lọli ọ ya khiẹsẹ.
\v 8 Ini ọgbọ ọ deba ọghuẹmhẹ oyi idiegbe olamhẹ oyọli rọ kọ ọ khiẹsẹ epfua. Ọni ọ rọ kọ rọ ri egbe mu Ayẹmhẹ, ọ ya khiẹsẹ agbọ na agbọagbọ.
\v 9 A khi zẹ ni onete iriẹlẹ o khuese awa, irari khi o kha ramhi oni ẹghẹghẹ, awa ya khiẹsẹ, ini ọa da lọsẹ awa.
\v 10 Irarighọ, abi awa da mhọli oni ẹghẹghẹ kpa, awa ke riẹlẹ onete deba ọgbọkpa, tee-tee, ena ọmhuẹ-apfẹ irudunga.
\s1 Itse-agua ni o kpukhokho
\p 
\v 11 A bino ikpamhi alo ebe eniẹmhi ni mhi ri obọ oyẹmhẹ kẹkẹ ghi ẹ.
\v 12 Ẹgbọ ni ẹẹ riẹlẹ abamẹmhẹ, ẹ dua ni e ri itoto ti ẹ shi ishẹlẹ-a, emini o zẹ ni e rọ ọ li ighọ khi, ẹa nono ni a mu okhọli vule shi wẹ ọ shi osẹsẹ oyi apfida oyi iKirisiti.
\v 13 Egbegbi eni e shẹlẹ-a, ẹa ri ushi ẹ gbe akanya, ama ẹ nono ni a shẹlẹ ẹ-a, ni e ba mẹ asha ke neta ọmọse khi e rẹ ẹ shẹ shẹlẹ-a.
\v 14 Ama mhi aa tigbe ri emhikhọghuo ya neta ọmọse, ini ọa li khi ingme oyi apfida oyi iJesu iKirisiti Ọnọmhuẹ ọyawa. Itobọ oni apfida ona, mhi rọ ghu pfa ọghuẹmhẹ agbọ, ọghuẹmhẹ agbọ o ghu pfa agbọ oyẹmhẹ.
\v 15 Ishẹlẹ-a ali umha shẹlẹ-a ọa mhọli abi o ngme, emini o mu egbe khi, ni a rọ riẹlẹ ọgbọ bia elemhi iKirisiti.
\v 16 Opfọmhẹ ali ilẹlemhi e ka nu eni e deba osẹsẹ onana la elemhi agbọ oyẹwẹ, li shi ẹgbọ iZirẹni eyi Ẹshinẹgba.
\p 
\v 17 Ọzukhomhi emhikpa khi, ọgbọkhọghuo ọ khi ke nasẹ mhẹ, irari khi mhi mhọli ẹmẹli oyi iJesu shi egbe oyẹmhẹ.
\p 
\v 18 Inyọghuo-mhẹ, okhale oyi iJesu iKirisiti Ọnọmhuẹ ọyawa, ọ ka nu ayẹmhẹ oyẹ ẹ nya la. Atsẹ.
