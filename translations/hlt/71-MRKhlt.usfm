\c 11  
\s1 Hosanna  
\p
\v 1 \w Jerusalem|strong="G2414"\w*, \w Olive|strong="G1636"\w* \w tlang|strong="G3735"\w* \w kah|strong="G4314"\w* \w Bethphage|strong="G0967"\w* \w neh|strong="G2532"\w* \w Bethany|strong="G0963"\w* a \w pha|strong="G1448"\w* tom uh \w vaengah|strong="G3753"\w* \w a|strong="G0846"\w* \w hnukbang|strong="G3101"\w* rhoek \w khuiah|strong="G3588"\w* \w panit|strong="G1417"\w* te a \w tueih|strong="G0649"\w*.  
