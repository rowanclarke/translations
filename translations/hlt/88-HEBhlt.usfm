\c 1
\s1 Capa Paihmuen
\p 
\v 1 \w Pathen|strong="G2316"\w* \w loh|strong="G3588"\w* a \w pa|strong="G3962"\w* rhoek \w te|strong="G3588"\w* \w tonghma|strong="G4396"\w* \w rhoek|strong="G3815"\w* \w lamloh|strong="G1722"\w* a \w hnukhmai|strong="G4187"\w* la \w puet|strong="G4181"\w* a \w voek|strong="G2980"\w* \w dingrhae|strong="G3819"\w* coeng.
\v 2 Tedae \w tahae|strong="G5130"\w* kah \w hnukkhueng|strong="G2078"\w* \w khohnin|strong="G2250"\w* \w ah|strong="G1909"\w* \w capa|strong="G5207"\w* \w lamloh|strong="G1722"\w* \w mamih|strong="G2254"\w* taengah a \w thui|strong="G2980"\w*. \w Anih|strong="G3739"\w* te \w cungkuem|strong="G3956"\w* aka \w pangkung|strong="G2818"\w* la a \w hmoel|strong="G5087"\w* tih \w lunglai|strong="G0165"\w* \w te|strong="G3588"\w* \w khaw|strong="G2532"\w* \w anih|strong="G3739"\w* \w rhangneh|strong="G1223"\w* a \w saii|strong="G4160"\w*.
\v 3 \w Anih|strong="G3739"\w* tah \w thangpomnah|strong="G1391"\w* \w khosaeng|strong="G0541"\w* \w neh|strong="G2532"\w* \w a|strong="G0846"\w* \w ngaikhueknah|strong="G5287"\w* \w kah|strong="G3588"\w* \w mueimae|strong="G5491"\w* la \w om|strong="G5607"\w*. \w A|strong="G0846"\w* \w thaomnah|strong="G1411"\w* \w olka|strong="G4487"\w* \w neh|strong="G3588"\w* a \w cungkuem|strong="G3956"\w* a \w khoem|strong="G5342"\w*. \w Tholh|strong="G0266"\w* \w cimcaihnah|strong="G2512"\w* a \w saii|strong="G4160"\w* tih hmuen \w sang|strong="G5308"\w* \w kah|strong="G1722"\w* \w Boeilennah|strong="G3172"\w* \w bantang|strong="G1188"\w* \w ah|strong="G1722"\w* \w ngol|strong="G2523"\w*.
\v 4 \w Heyet|strong="G5118"\w* a \w then|strong="G2909"\w* \w la aka\w* \w om|strong="G1096"\w* \w puencawn|strong="G0032"\w* \w boeih|strong="G3745"\w* \w lakah|strong="G3844"\w* \w amih|strong="G0848"\w* loh \w poekhloep|strong="G1313"\w* la a \w ming|strong="G3686"\w* a \w pang|strong="G2816"\w*.
\s1 Capa Tah Tanglue
\p 
\v 5 \x - \xo 1.5 \xt Tgt 2. 7; \xt 2Sa 7. 14; 1Kh 17. 13.\x*\w Mebang|strong="G5101"\w* \w puencawn|strong="G0032"\w* rhoek khaw, “\w Nang|strong="G4771"\w* tah \w kamah|strong="G3450"\w* \w ca|strong="G5207"\w* \w ni|strong="G1488"\w*. \w Kai|strong="G1473"\w* loh \w tihnin|strong="G4594"\w* ah \w nang|strong="G4571"\w* kan \w sak|strong="G1080"\w*, \w kai|strong="G1473"\w* tah \w a|strong="G0846"\w* \w napa|strong="G3962"\w* \w la|strong="G1519"\w* ka \w om|strong="G2071"\w* \w vetih|strong="G2532"\w* \w anih|strong="G0846"\w* khaw \w ka|strong="G3427"\w* \w ca|strong="G5207"\w* \w la|strong="G1519"\w* \w om|strong="G2071"\w* ni,” a \w ti|strong="G2036"\w* nah \w noek|strong="G4218"\w* nim?
\p 
\v 6 \x - \xo 1.6 \xt Olr 32. 43.\x*Te \w dongah|strong="G1161"\w* \w lunglai|strong="G3625"\w* \w la|strong="G1519"\w* \w camingomthang|strong="G4416"\w* \w koep|strong="G3825"\w* han \w khuen|strong="G1521"\w* \w vaengah|strong="G3752"\w*, “\w Pathen|strong="G2316"\w* kah \w puencawn|strong="G0032"\w* rhoek loh \w amah|strong="G0846"\w* te \w boeih|strong="G3956"\w* \w bawk|strong="G4352"\w* uh saeh,” a \w ti|strong="G3004"\w*.
\p 
\v 7 \x - \xo 1.7 \xt Tgt 104. 4.\x*\w Tedae|strong="G2532"\w* \w puencawn|strong="G0032"\w* rhoek \w ngawn|strong="G3303"\w* \w tah|strong="G3588"\w*, “\w Amah|strong="G0846"\w* kah \w puencawn|strong="G0032"\w* rhoek \w te|strong="G3588"\w* \w khohli|strong="G4151"\w* la, \w amah|strong="G0846"\w* kah \w bibikung|strong="G3011"\w* rhoek \w te|strong="G3588"\w* \w hmai|strong="G4442"\w* \w hmaitak|strong="G5395"\w* la a \w saii|strong="G4160"\w*,” a \w ti|strong="G3004"\w*.
\p 
