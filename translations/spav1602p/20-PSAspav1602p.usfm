\v 5 \w Y|strong="H3068"\w* \w cantarán|strong="H7891"\w* \w de|strong="H3588"\w* \w los|strong="H3588"\w* \w caminos|strong="H1870"\w* del \w SEÑOR|strong="H3068"\w*: \w que|strong="H3588"\w* \w la|strong="H3588"\w* \w gloria|strong="H3519"\w* del \w SEÑOR|strong="H3068"\w* \w es|strong="H3588"\w* \w grande|strong="H1419"\w*.
\m 
\v 6 \w Porque|strong="H3588"\w* \w el|strong="H3588"\w* \w alto|strong="H1364"\w* \w SEÑOR|strong="H3068"\w* \w atiende|strong="H7200"\w* al \w humilde|strong="H8217"\w*; \w mas|strong="H3588"\w* al altivo \w mira|strong="H7200"\w* \w de|strong="H3588"\w* lejos.
\m 
\v 7 \w Si|strong="H5921"\w* \w anduviere|strong="H3212"\w* yo \w en|strong="H5921"\w* \w medio|strong="H3027"\w* \w de|strong="H5921"\w* \w la|strong="H5921"\w* \w angustia|strong="H6869"\w*, tú \w me|strong="H5921"\w* vivificarás: \w con|strong="H5921"\w*­tra \w la|strong="H5921"\w* \w ira|strong="H3212"\w* \w de|strong="H5921"\w* mis enemigos exten­derás tu \w mano|strong="H3027"\w*, \w y|strong="H5921"\w* salvaráme tu \w diestra|strong="H3225"\w*.
\m 
\v 8 El \w SEÑOR|strong="H3068"\w* perfeccionará \add lo que\add* me toca: tu \w misericordia|strong="H2617"\w*, oh \w SEÑOR|strong="H3068"\w*, \add es\add* para \w siempre|strong="H5769"\w*; no desampares las \w obras|strong="H4639"\w* de tus \w manos|strong="H3027"\w*.
\c 139
\d Al Músico principal: Salmo de David.
\m 
\v 1 OH \w SEÑOR|strong="H3068"\w*, tú me has examinado y \w conocido|strong="H3045"\w*.
\m 
\v 2 Tú has \w conocido|strong="H3045"\w* mi \w sentarme|strong="H3427"\w* y mi \w levantarme|strong="H6965"\w*, has \w entendido|strong="H3045"\w* desde \w lejos|strong="H7350"\w* mis pensamientos.
\m 
\v 3 Mi senda y mi acostarme has rodeado, y estás impuesto en \w todos|strong="H3605"\w* mis \w caminos|strong="H1870"\w*.
\m 
\v 4 \w Pues|strong="H3588"\w* \w aún|strong="H3588"\w* \w no|strong="H3588"\w* está \w la|strong="H3605"\w* palabra \w en|strong="H3588"\w* mi \w lengua|strong="H3956"\w*, \w y|strong="H3588"\w* he \w aquí|strong="H2005"\w*, oh \w SEÑOR|strong="H3068"\w*, tú \w la|strong="H3605"\w* \w sabes|strong="H3045"\w* \w toda|strong="H3605"\w*.
\m 
\v 5 Detrás \w y|strong="H5921"\w* \w delante|strong="H5921"\w* \w me|strong="H5921"\w* guarnecis­\w te|strong="H5921"\w*, \w y|strong="H5921"\w* \w sobre|strong="H5921"\w* \w mí|strong="H5921"\w* \w pusiste|strong="H7896"\w* tu \w mano|strong="H3709"\w*.
\m 
\v 6 \w Más|strong="H4480"\w* maravilloso es el conoci­miento \w que|strong="H4480"\w* mi capacidad; \w alto|strong="H7682"\w* es, \w no|strong="H3808"\w* \w puedo|strong="H3201"\w* comprenderlo.
\m 
\v 7 ¿Adónde me \w iré|strong="H3212"\w* \w de|strong="H6440"\w* tu \w espíritu|strong="H7307"\w*? ¿y adónde huiré \w de|strong="H6440"\w* tu \w presencia|strong="H6440"\w*?
\m 
\v 8 \w Si|strong="H2005"\w* \w subiere|strong="H5266"\w* al \w cielo|strong="H8064"\w*, \w allí|strong="H8033"\w* estás tú: y \w si|strong="H2005"\w* en el infierno hiciere mi cama, he \w aquí|strong="H8033"\w* \w allí|strong="H8033"\w* tú estás.
\m 
\v 9 Si \w tomare|strong="H5375"\w* las \w alas|strong="H3671"\w* del alba, y \w habitare|strong="H7931"\w* en el extremo del \w mar|strong="H3220"\w*,
\m 
\v 10 \w Aun|strong="H1571"\w* \w allí|strong="H8033"\w* me guiará tu \w mano|strong="H3027"\w*, \w y|strong="H1571"\w* me asirá tu \w diestra|strong="H3225"\w*.
\m 
\v 11 \w Si|strong="H1157"\w* dijere: Ciertamente las \w tinieblas|strong="H2822"\w* me encubrirán; aun la \w noche|strong="H3915"\w* resplandecerá tocante \w a|strong="H3068"\w* mí.
\m 
\v 12 \w Aun|strong="H1571"\w* las \w tinieblas|strong="H2822"\w* \w no|strong="H3808"\w* \w encubren|strong="H2821"\w* \w de|strong="H4480"\w* \w ti|strong="H4480"\w*, \w y|strong="H1571"\w* \w la|strong="H1571"\w* \w noche|strong="H3915"\w* resplandece \w como|strong="H1571"\w* \w el|strong="H1571"\w* \w día|strong="H3117"\w*: \w lo|strong="H3808"\w* \w mismo|strong="H1571"\w* \add te son\add* las \w tinieblas|strong="H2822"\w* \w que|strong="H4480"\w* \w la|strong="H1571"\w* luz.
\m 
\v 13 \w Porque|strong="H3588"\w* tú \w poseiste|strong="H7069"\w* mis entrañas; \w cubrísteme|strong="H5526"\w* \w en|strong="H3588"\w* \w el|strong="H3588"\w* vientre \w de|strong="H3588"\w* mi madre.
\m 
\v 14 \w Te|strong="H5921"\w* \w alabaré|strong="H3034"\w*; \w porque|strong="H3588"\w* asombrosamente \w y|strong="H3588"\w* admirablemente soy \w hecho|strong="H5315"\w*: \w maravillosas|strong="H6381"\w* \w son|strong="H3588"\w* tus \w obras|strong="H4639"\w*, \w y|strong="H3588"\w* \w mi|strong="H5921"\w* \w alma|strong="H5315"\w* \w lo|strong="H5921"\w* \w sabe|strong="H3045"\w* \w muy|strong="H3966"\w* \w bien|strong="H3588"\w*.
\m 
\v 15 \w No|strong="H3808"\w* \w fue|strong="H3808"\w* encubierto \w de|strong="H4480"\w* \w ti|strong="H4480"\w* mi sustancia, cuando \w en|strong="H4480"\w* secreto \w fui|strong="H3808"\w* formado, y entretejido \w en|strong="H4480"\w* \w lo|strong="H3808"\w* \w más|strong="H4480"\w* \w profundo|strong="H8482"\w* \w de|strong="H4480"\w* la tierra.
\m 
\v 16 Tus \w ojos|strong="H5869"\w* \w vieron|strong="H7200"\w* \w mi|strong="H5921"\w* sustancia, siendo \w aún|strong="H3808"\w* imperfecto; \w y|strong="H5921"\w* \w en|strong="H5921"\w* tu \w libro|strong="H5612"\w* estaban \w escritos|strong="H3789"\w* \w todos|strong="H3605"\w* mis miembros, \w que|strong="H3808"\w* \w fueron|strong="H5869"\w* luego formados, \w cuando|strong="H3117"\w* \w aún|strong="H3808"\w* \w no|strong="H3808"\w* había \w ni|strong="H3808"\w* uno \w de|strong="H5921"\w* \w ellos|strong="H5921"\w*.
\m 
\v 17 Así \w que|strong="H4100"\w* ¡\w cuán|strong="H4100"\w* \w preciosos|strong="H3365"\w* me son, \w oh|strong="H4100"\w* Dios, tus pensamientos! ¡\w cuán|strong="H4100"\w* grande es la suma de ellos!
\m 
\v 18 Si \w los|strong="H5973"\w* cuento, \w multiplícanse|strong="H7235"\w* \w más|strong="H5750"\w* que la arena: \w despierto|strong="H6974"\w*, y \w aún|strong="H5750"\w* estoy \w contigo|strong="H5973"\w*.
\m 
\v 19 \w De|strong="H4480"\w* cierto, oh Dios, matarás \w al|strong="H4480"\w* \w impío|strong="H7563"\w*; \w apartaos|strong="H5493"\w* \w pues|strong="H4480"\w* \w de|strong="H4480"\w* mí, hombres \w sanguinarios|strong="H1818"\w*.
\m 
\v 20 Porque \w blasfemias|strong="H4209"\w* dicen ellos contra ti: tus enemigos \w toman|strong="H5375"\w* en vano \add tu nombre\add*.
\m 
\v 21 ¿\w No|strong="H3808"\w* tengo en odio, oh \w SEÑOR|strong="H3068"\w*, \w a|strong="H3068"\w* los \w que|strong="H3808"\w* te \w aborrecen|strong="H8130"\w*, y me conmuevo contra tus ene­migos?
\m 
\v 22 Aborrézcolos con perfecto \w odio|strong="H8135"\w*; téngolos por \w enemigos|strong="H8130"\w*.
\m 
\v 23 \w Examíname|strong="H2713"\w*, oh Dios, y cono­ce mi \w corazón|strong="H3824"\w*: pruébame y reco­noce mis pensamientos:
\m 
\v 24 \w Y|strong="H3068"\w* \w ve|strong="H7200"\w* si hay en mí \w camino|strong="H1870"\w* de perversidad, y \w guíame|strong="H5148"\w* en el \w camino|strong="H1870"\w* \w eterno|strong="H5769"\w*.
\c 140
\d Al Músico principal: Salmo de David.
\m 
\v 1 LÍBRAME, oh SEÑOR, de hombre malo: guárdame de hombre violento;
\m 
\v 2 Los cuales maquinan \w males|strong="H7451"\w* en el corazón, cada día urden con­tiendas.
\m 
\v 3 Aguzaron su lengua como \w la|strong="H3605"\w* serpiente; veneno \w de|strong="H7451"\w* áspid hay debajo \w de|strong="H7451"\w* sus labios. Selah.
\m 
\v 4 Guárdame, oh SEÑOR, \w de|strong="H8478"\w* manos del impío, presérvame del hombre injurioso; que han pen­sado \w de|strong="H8478"\w* trastornar mis pasos.
\m 
\v 5 Hanme escondido lazo y cuer­das los soberbios; han tendido red \w junto|strong="H3027"\w* \w a|strong="H3068"\w* \w la|strong="H8104"\w* senda; me han puesto lazos. Selah.
\m 
\v 6 He dicho al SEÑOR: Dios mío eres tú; escucha, oh SEÑOR, la voz de mis ruegos.
\m 
\v 7 Oh \w DIOS|strong="H3068"\w* el \w Señor|strong="H3068"\w*, fortaleza de mi salvación, tú has cubierto mi cabeza en el día de la batalla.
\m 
\v 8 No des, oh SEÑOR, al impío sus deseos; no saques adelante su pensamiento, \add que no\add* se ensober­bezca. Selah.
\m 
\v 9 En cuanto \w a|strong="H3068"\w* los que \w por|strong="H5414"\w* todas partes me rodean, la maldad \w de|strong="H5414"\w* sus propios labios cubrirá su cabeza.
\m 
\v 10 Caerán sobre ellos brasas ardientes: serán lanzados en el fuego, en profundos abismos de donde no se levanten.
\m 
\v 11 \w El|strong="H5921"\w* hombre deslenguado \w no|strong="H1077"\w* será \w firme|strong="H6965"\w* \w en|strong="H5921"\w* \w la|strong="H5921"\w* tierra: \w el|strong="H5921"\w* mal cazará \w al|strong="H5921"\w* hombre injusto \w para|strong="H5921"\w* derribarle.
\m 
\v 12 Yo sé que hará el SEÑOR el juicio del \w afligido|strong="H7451"\w*, el juicio \w de|strong="H7451"\w* los menesterosos.
\m 
\v 13 \w Ciertamente|strong="H3588"\w* \w los|strong="H3588"\w* justos \w darán|strong="H6213"\w* gracias \w a|strong="H3068"\w* \w tu|strong="H6213"\w* nombre; \w los|strong="H3588"\w* rectos morarán \w en|strong="H3588"\w* \w tu|strong="H6213"\w* presencia.
\c 141
\d Salmo de David.
\m 
\v 1 \w SEÑOR|strong="H3068"\w*, \w a|strong="H3068"\w* ti he \w clamado|strong="H7121"\w*; \w apresúrate|strong="H2363"\w* \w a|strong="H3068"\w* mí; escucha mi \w voz|strong="H6963"\w*, cuando te \w invocare|strong="H7121"\w*.
\m 
\v 2 Sea enderezada mi \w oración|strong="H8605"\w* \w delante|strong="H6440"\w* \w de|strong="H6440"\w* ti como un \w perfume|strong="H7004"\w*, el don \w de|strong="H6440"\w* mis \w manos|strong="H3709"\w* como la ofren­da \w de|strong="H6440"\w* la \w tarde|strong="H6153"\w*.
\m 
\v 3 \w Pon|strong="H7896"\w*, oh \w SEÑOR|strong="H3068"\w*, \w guarda|strong="H5341"\w* \w a|strong="H3068"\w* \w mi|strong="H5921"\w* \w boca|strong="H6310"\w*: \w guarda|strong="H5341"\w* \w la|strong="H5921"\w* \w puerta|strong="H1817"\w* \w de|strong="H5921"\w* mis \w labios|strong="H8193"\w*.
\m 
\v 4 \w No|strong="H1077"\w* dejes \w que|strong="H1697"\w* se \w incline|strong="H5186"\w* mi \w corazón|strong="H3820"\w* \w a|strong="H3068"\w* \w cosa|strong="H1697"\w* \w mala|strong="H7451"\w*, \w a|strong="H3068"\w* hacer \w obras|strong="H5949"\w* impí­as con los \w que|strong="H1697"\w* obran iniquidad, y \w no|strong="H1077"\w* \w coma|strong="H3898"\w* yo \w de|strong="H1697"\w* sus deleites.
\m 
\v 5 \w Que|strong="H3588"\w* \w el|strong="H3588"\w* \w justo|strong="H6662"\w* \w me|strong="H3588"\w* castigue, \add será\add* un favor, \w y|strong="H3588"\w* \w que|strong="H3588"\w* \w me|strong="H3588"\w* \w reprenda|strong="H3198"\w* \add será\add* un excelente \w bálsamo|strong="H8081"\w* \add que\add* \w no|strong="H3588"\w* \w me|strong="H3588"\w* herirá \w la|strong="H3588"\w* \w cabeza|strong="H7218"\w*: \w así|strong="H3588"\w* \w que|strong="H3588"\w* \w aun|strong="H5750"\w* mi \w oración|strong="H8605"\w* \add tendrán\add* \w en|strong="H3588"\w* \w sus|strong="H1986"\w* calamida­des.
\m 
\v 6 Serán derribados \w en|strong="H3588"\w* lugares peñascosos sus \w jueces|strong="H8199"\w*, \w y|strong="H3588"\w* \w oirán|strong="H8085"\w* mis palabras, \w que|strong="H3588"\w* \w son|strong="H3588"\w* suaves.
\m 
\v 7 \w Como|strong="H3644"\w* quien hiende y rompe la tierra, \w son|strong="H6310"\w* esparcidos nuestros \w huesos|strong="H6106"\w* \w a|strong="H3068"\w* la \w boca|strong="H6310"\w* de la sepultura.
\m 
\v 8 \w Por|strong="H3588"\w* tanto \w a|strong="H3068"\w* ti, oh \w DIOS|strong="H3069"\w* \w el|strong="H3588"\w* Señor, \add miran\add* mis \w ojos|strong="H5869"\w*: \w en|strong="H3588"\w* ti he confiado, \w no|strong="H3588"\w* \w desampares|strong="H6168"\w* \w mi|strong="H5315"\w* \w alma|strong="H5315"\w*.
\m 
\v 9 \w Guárdame|strong="H8104"\w* de los \w lazos|strong="H4170"\w* \w que|strong="H3027"\w* me han tendido, y de los armadijos de los \w que|strong="H3027"\w* obran iniquidad.
\m 
\v 10 \w Caigan|strong="H5307"\w* los \w impíos|strong="H7563"\w* \w a|strong="H3068"\w* una \w en|strong="H5704"\w* sus redes, \w mientras|strong="H5704"\w* yo \w pasaré|strong="H5674"\w* \w adelante|strong="H5704"\w*.
\c 142
\d Masquil de David: Oración que hizo cuando estaba en la cueva.
\m 
\v 1 CON \w mi|strong="H1961"\w* voz clamaré al SEÑOR, con \w mi|strong="H1961"\w* voz pediré al SEÑOR misericordia.
\m 
\v 2 Delante de él derramaré mi querella; delante de él denuncia­ré mi angustia.
\m 
\v 3 Cuando mi espíritu se angus­tiaba \w dentro|strong="H6440"\w* \w de|strong="H6440"\w* mí, tú conociste mi senda. En el camino en que andaba, me escondieron lazo.
\m 
\v 4 Miraba \w a|strong="H3068"\w* \w la|strong="H5921"\w* mano derecha, \w y|strong="H5921"\w* observaba; \w mas|strong="H5921"\w* \w no|strong="H5921"\w* había quien \w me|strong="H5921"\w* \w conociese|strong="H3045"\w*; \w no|strong="H5921"\w* tuve refugio, \w no|strong="H5921"\w* había quien cuidara \w por|strong="H5921"\w* \w mi|strong="H5921"\w* alma.
\m 
\v 5 Clamé \w a|strong="H3068"\w* \w ti|strong="H4480"\w*, oh SEÑOR, dije: Tú eres \w mi|strong="H5315"\w* esperanza, y \w mi|strong="H5315"\w* \w por|strong="H4480"\w*­ción \w en|strong="H4480"\w* la tierra \w de|strong="H4480"\w* los vivientes.
\m 
\v 6 Escucha mi clamor, que estoy muy afligido; líbrame de los que me persiguen, porque son más fuertes que yo.
\m 
\v 7 Saca mi alma \w de|strong="H4480"\w* \w la|strong="H3588"\w* cárcel \w para|strong="H3588"\w* \w que|strong="H3588"\w* alabe tu nombre: \w me|strong="H4480"\w* rodea­rán \w los|strong="H7291"\w* justos, \w porque|strong="H3588"\w* tú \w me|strong="H4480"\w* serás propicio.
\c 143
\d Salmo de David.
\m 
\v 1 OH \w SEÑOR|strong="H3068"\w*, \w oye|strong="H8085"\w* \w mi|strong="H6030"\w* \w oración|strong="H8605"\w*, \w escucha|strong="H8085"\w* mis \w ruegos|strong="H8469"\w*: \w respóndeme|strong="H6030"\w* por tu verdad, por tu \w justicia|strong="H6666"\w*.
\m 
\v 2 \w Y|strong="H3068"\w* \w no|strong="H3808"\w* entres \w en|strong="H3588"\w* \w juicio|strong="H4941"\w* \w con|strong="H3588"\w* tu \w siervo|strong="H5650"\w*; \w porque|strong="H3588"\w* \w no|strong="H3808"\w* \w se|strong="H3808"\w* \w justificará|strong="H6663"\w* \w delante|strong="H6440"\w* \w de|strong="H3588"\w* ti \w ningún|strong="H3605"\w* \w viviente|strong="H2416"\w*.
\m 
\v 3 \w Porque|strong="H3588"\w* ha perseguido \w el|strong="H3588"\w* enemigo \w mi|strong="H5315"\w* \w alma|strong="H5315"\w*; ha postrado \w en|strong="H3588"\w* tierra \w mi|strong="H5315"\w* \w vida|strong="H5315"\w*; hame \w hecho|strong="H5315"\w* habi­tar \w en|strong="H3588"\w* tinieblas \w como|strong="H3588"\w* \w los|strong="H3427"\w* ya \w muertos|strong="H4191"\w*.
\m 
\v 4 \w Y|strong="H3068"\w* \w mi|strong="H5921"\w* \w espíritu|strong="H7307"\w* \w se|strong="H5921"\w* angustió den­tro \w de|strong="H5921"\w* \w mí|strong="H5921"\w*; \w pasmóse|strong="H8074"\w* \w mi|strong="H5921"\w* \w corazón|strong="H3820"\w*.
\m 
\v 5 \w Acordéme|strong="H2142"\w* de \w los|strong="H3605"\w* \w días|strong="H3117"\w* \w antiguos|strong="H6924"\w*; \w meditaba|strong="H7878"\w* en \w todas|strong="H3605"\w* tus \w obras|strong="H4639"\w*; \w reflexionaba|strong="H7878"\w* en las \w obras|strong="H4639"\w* de tus \w manos|strong="H3027"\w*.
\m 
\v 6 \w Extendí|strong="H6566"\w* mis \w manos|strong="H3027"\w* \w a|strong="H3068"\w* ti; \w mi|strong="H5315"\w* \w alma|strong="H5315"\w* \w a|strong="H3068"\w* ti como la tierra \w sedienta|strong="H5889"\w*. \w Selah|strong="H5542"\w*.
\m 
\v 7 \w Respóndeme|strong="H6030"\w* \w presto|strong="H4118"\w*, oh \w SEÑOR|strong="H3068"\w* \w que|strong="H4480"\w* desmaya \w mi|strong="H6030"\w* \w espíritu|strong="H7307"\w*: \w no|strong="H6440"\w* \w escondas|strong="H5641"\w* \w de|strong="H4480"\w* \w mí|strong="H6030"\w* tu \w rostro|strong="H6440"\w*, y \w venga|strong="H3381"\w* \w yo|strong="H4480"\w* \w a|strong="H3068"\w* ser \w semejante|strong="H4911"\w* \w a|strong="H3068"\w* \w los|strong="H5973"\w* \w que|strong="H4480"\w* \w descienden|strong="H3381"\w* \w a|strong="H3068"\w* la sepultura.
\m 
\v 8 Hazme \w oír|strong="H8085"\w* \w por|strong="H3588"\w* \w la|strong="H3588"\w* \w mañana|strong="H1242"\w* tu \w misericordia|strong="H2617"\w*, \w porque|strong="H3588"\w* \w en|strong="H3588"\w* ti he confiado: hazme \w saber|strong="H3045"\w* \w el|strong="H3588"\w* \w camino|strong="H1870"\w* \w por|strong="H3588"\w* donde \w ande|strong="H3212"\w*, \w porque|strong="H3588"\w* \w a|strong="H3068"\w* ti he alzado \w mi|strong="H5375"\w* \w alma|strong="H5315"\w*
\m 
\v 9 \w Líbrame|strong="H5337"\w* de mis enemigos, oh \w SEÑOR|strong="H3068"\w*: \w a|strong="H3068"\w* ti me acojo.
\m 
\v 10 \w Enséñame|strong="H3925"\w* \w a|strong="H3068"\w* \w hacer|strong="H6213"\w* \w tu|strong="H6213"\w* volun­tad, \w porque|strong="H3588"\w* \w tú|strong="H6213"\w* eres mi Dios: \w tu|strong="H6213"\w* \w buen|strong="H2896"\w* \w espíritu|strong="H7307"\w* \w me|strong="H3588"\w* guíe \w a|strong="H3068"\w* tierra \w de|strong="H3588"\w* \w rectitud|strong="H4334"\w*.
