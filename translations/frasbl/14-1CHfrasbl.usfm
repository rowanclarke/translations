\v 1 \w Les|strong="H1121"\w* \w fils|strong="H1121"\w* \w de|strong="H1121"\w* \w Lévi|strong="H3878"\w* : Guershon, \w Kehath|strong="H6955"\w* \w et|strong="H1121"\w* \w Merari|strong="H4847"\w*.
\v 2 \w Fils|strong="H1121"\w* \w de|strong="H1121"\w* Kehath : Amram, Izhar, Hébron \w et|strong="H1121"\w* Uzziel.
\v 3 \w Fils|strong="H1121"\w* d'\w Amram|strong="H6019"\w* : \w Aaron|strong="H1121"\w*, Moïse \w et|strong="H1121"\w* Miriam. \w Fils|strong="H1121"\w* d'\w Aaron|strong="H1121"\w* : Nadab, \w Abihu|strong="H1121"\w*, \w Éléazar|strong="H1121"\w* \w et|strong="H1121"\w* Ithamar.
\v 4 \w Éléazar|strong="H1121"\w* engendra Phinhas, Phinhas engendra Abishua,
\v 5 Abishua engendra Bukki. Bukki engendra Uzzi.
\v 6 Uzzi engendra Zerahiah. Zérachia engendra Meraïoth.
\v 7 Meraïoth engendra Amaria. Amariah engendra Ahitub.
\v 8 Achithub engendra Zadok. Zadok engendra Ahimaaz.
\v 9 Achimaats engendra Azaria. Azariah engendra Johanan.
\v 10 Johanan engendra Azaria, \w qui|strong="H1121"\w* \w exerça|strong="H1121"\w* \w la|strong="H1121"\w* fonction \w de|strong="H1121"\w* prêtre \w dans|strong="H1121"\w* \w la|strong="H1121"\w* \w maison|strong="H1121"\w* \w que|strong="H1121"\w* Salomon construisit \w à|strong="H1121"\w* \w Jérusalem|strong="H1121"\w*.
\v 11 Azaria engendra Amaria. Amaria engendra Ahitub.
\v 12 Ahitub engendra Zadok. Zadok engendra Shallum, \w qui|strong="H1121"\w* engendra Shallum.
\v 13 Schallum engendra Hilkija. Hilkija engendra Azaria, \w qui|strong="H1121"\w* engendra Azaria.
\v 14 Azaria engendra Seraja. Seraja engendra Jéhozadak.
\v 15 Jehozadak partit \w en|strong="H1121"\w* captivité \w lorsque|strong="H1121"\w* Yahvé emporta \w Juda|strong="H1121"\w* \w et|strong="H1121"\w* \w Jérusalem|strong="H1121"\w* par \w la|strong="H1121"\w* main \w de|strong="H1121"\w* Nabuchodonosor.
\p 
