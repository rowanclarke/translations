\v 10 \w but|strong="H3588"\w* Eleazar \w stood|strong="H6965"\w* \w there|strong="H3117"\w* \w and|strong="H6965"\w* fought \w the|strong="H3588"\w* \w soldiers|strong="H5971"\w* \w of|strong="H3068"\w* Philistia \w until|strong="H5704"\w* \w his|strong="H3068"\w* \w arm|strong="H3027"\w* \w became|strong="H7725"\w* \w very|strong="H5704"\w* \w tired|strong="H3021"\w*, \w with|strong="H3068"\w* \w the|strong="H3588"\w* result \w that|strong="H3588"\w* \add his hand cramped and\add* \w he|strong="H1931"\w* \w could|strong="H6965"\w* \w not|strong="H6213"\w* stop gripping \w his|strong="H3068"\w* \w sword|strong="H2719"\w*. \w Yahweh|strong="H3068"\w* won \w a|strong="H3068"\w* \w great|strong="H1419"\w* \w victory|strong="H8668"\w* \w on|strong="H3117"\w* \w that|strong="H3588"\w* \w day|strong="H3117"\w*. \w And|strong="H6965"\w* afterwards \w the|strong="H3588"\w* \add other\add* Israeli \w soldiers|strong="H5971"\w* \w returned|strong="H7725"\w* \add to where Eleazar was\add*, \w and|strong="H6965"\w* \w stripped|strong="H6584"\w* \w off|strong="H6584"\w* \w the|strong="H3588"\w* \add armor from the men whom he had\add* \w killed|strong="H5221"\w*.
